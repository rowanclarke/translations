\id EXO - Tarok
\h Nfa
\toc3 Nfa
\toc2 Nfa
\toc1 Nlir Nfa
\mt1 Nlir Nfa
\c 1
\s1 Mɓək anung aIsa̱rila ka̱ aMasar.
\p 
\v 1 Aɗin ovan oga aIsa̱rila ova̱ ga aMasar ká̱ uYakup, udanggo ká̱ nzhi wò te oma ta̱.
\v 2 URuben ká̱ uSimeyon, ká̱ uLawi ká̱ uYahuda,
\v 3 ká̱ uYisakar, ká̱ uZebulun, ká̱ uBenjamin,
\v 4 ká̱ uDan, ká̱ uNaftali, ká̱ uGat, ká̱ uAsher.
\v 5 Akum ìjili aYakup pa̱ kpaktak te, ìsəm pa̱ ifangshat. UYusufu ka̱ yà chit ka̱ ashe mbin aMasar jiwò.
\v 6 UYusufu ká̱ nkpaktak ogənang wò ká̱ nlwàk oza̱ kú.
\v 7 Ká̱ nna te oga aIsa̱rila myak ga mpyal pa̱ makmak, á kam pa̱ gənggəng kang oza̱ yə́l mələk ashe mbin aMasar.
\p 
\v 8 Te uponzhi upipye uro wong yà ka̱ aMasar, uva̱ nyi iya̱m iro ka̱ apal aYusufu ka̱t.
\v 9 Uza̱ là onəm wò pa̱, <<Ó dər, onəm oga aIsa̱rila ova̱ ta̱ yə́l kang à kam chit ji yi.
\v 10 Re í mwo aghan aga nggəl mmyak oza̱ ka̱t te, onəm oga nkpàng yi á ru yi ká̱ ìkum te, oza̱ i gwang awo ká̱ oza̱ i lung yi. Te i wong i chəng i re mbin yi.>>
\p 
\v 11 Te uPonzhi uga aMasar ká̱ onəm ochumchum wò nak onəm oga mpángchí ozwal pa̱ á na inok iɗəkɗək ôvan oga aIsa̱rila i va i na idumdùm ôza̱ pa̱ makmak. Á me oga ìtong ka̱kul mɓut iya̱m ûFirona va mí wór pa̱ aFitom ka̱ aRamaset.
\v 12 Kap ká̱ nva̱ pa̱ oga aMasar kà̱ nnəm idumdùm oIsa̱rila te, oIsa̱rila ga mpyal ká̱ mmyak ga chu iyə́l oza̱ ɓan nna ayər oga aMasar.
\v 13 Te oga aMasar nəm ifan oza̱ pa̱ zhalatzhalat kà̱ nnəm izwal.
\v 14 Oza̱ dungshi ìgwak oga aIsa̱rila ká̱ inok iɗəkɗək, i nak oza̱ i kà̱p amyè, i tòng, i nəm abərki ká̱. Kang à nəm ifan ôza̱ kà̱ nnəm inok ka̱ ashe íram oza̱.
\p 
\v 15 UPonzhi oga aMasar là ôchar va̱ kà̱ nnəm inok nka̱m amar óchar oHiburu, oma uSifira ka̱ uFuya pa̱,
\v 16 <<O wong nka̱mshi ochar oHiburu kà̱ mmar te, o dər a yà pa̱ uyennunggwan te, o gba̱l, kang a yà pa̱ uyenchar nnyi te, o re na ka̱ irirì.>>
\v 17 Ka̱kul pa̱ ochar ova̱ ta ra ayər Inan ra te, oza̱ kpak iya̱m iva̱ uponzhi là ka̱t, oza̱ re onunggwan ka̱ irirì kpa.
\v 18 Te uponzhi oga aMasar wór ochar ova̱ ta ɓəp oza̱ pa̱, <<Sang kang o nəm wa nva̱ ta̱ yà? Ó nəm sang kang o re ovan onunggwan ka̱ irirì yà?>>
\p 
\v 19 Ochar ova̱ ta là uFirona pa̱, <<Ochar oHiburu wa oga aMasar ka̱t, oza̱ kam byet, kang î ga ka̱ atak oza̱ te, oza̱ mar chit.>>
\p 
\v 20 Inan nəm inəna̱n ôchar oga nka̱m amar ava̱ ta. Te à nak onəm yə́l kang oza̱ kam pa̱ gənggəng.
\v 21 Ka̱kul ochar ova̱ ta̱ oma ka̱ ayər Inan te, Inan na ovan ôza̱ pa̱ makmak.
\p 
\v 22 Te uFirona nak nkpaktak onəm wò pa̱, <<Nza̱ uyennunggwan nggo mmá mar te, o mang ka̱ ashe awang aNilu. Kang nza̱ uyenchar nggo te, o re ka̱ irirì.>>
\c 2
\s1 AMar AMusa
\p 
\v 1 UNəm uro ka̱ akum aLawi ka̱m uchar ka̱ akum oza̱.
\v 2 Uchar uva̱ ta yar anyám te, á mar uyennunggwan. Uza̱ ya ri ìgwak à na te, à bwam na apye pa̱ shatɗing.
\v 3 Kang uza̱ ya pa̱ ò kur mbwam na làp ka̱t te, uza̱ yar nya mbanda̱r nro nva ngga nlòk ká̱ amár kang uza̱ ɓam nsəsəm ka̱ njəng ìkáng, te uza̱ nak uyen va̱ ta ka̱ ashishe, à yar gá nak ka̱ ashe oga isəksək ka̱ anung akonkong awang aNilu.
\v 4 Ugənang ayenba̱k uva̱ ta uchar ta̱l ka̱ atak aro pa̱ gba̱ngba̱ng na ô dər pa̱ iza̱ i nəm na yà.
\p 
\v 5 Uya aFirona uyenchar fər ga ngwòr izər ka̱ awang aNilu, kang ovan ochar ozwal oga nnəm inok á na nnyi te, oza̱ ka̱ nchen ka̱ anung awang aNilu. Uza̱ ya nya mbanda̱r ka̱ ashe isəksək te, á re uzəngtəng ka̱ ashe ovan ochar va̱ ta à ga yar.
\v 6 Uya aFirona uva̱ ta bol te, a ya uyenba̱k ka̱ nyə́ng ka̱ ashishe. Te à rwa ìgwak à na uza̱ là pa̱, <<Uyen uva̱ ta̱ amar oHiburu.>>
\v 7 Te ugənangg ayenba̱k uva̱ ta ɓəp uya aFirona pa̱, <<N ga n ram uchar uga nna mbyal uyen ka̱ ashe oHiburu na á ɓa á nak ishi a ɓu ka̱ uyen uva̱ ta ɗak ɓo?>>
\p 
\v 8 Uya aFirona ma̱n á na pa̱, <<À, ga.>> Te uza̱ ga wór unang ayen ava̱ ta ɓa.
\v 9 Uya aFirona là uchar uva̱ ta pa̱, <<Yar uyenba̱k uva̱ ta̱ ga ká̱, nak ishi ka̱ na á mi, te mi mwa ɓu kà̱.>> Unang ayen yar uyen uva̱ ta ga ká̱, nak ishi ka̱ na.
\v 10 Uza̱ nyáng te, unənang ga ka̱ na ûya aFirona uyenchar, uza̱ sat uyiyen ununggwan. Uya aFirona sok aɗin á na pa̱ uMusa, <<Ka̱kul n yar na ka̱ ashe ndəng.>>
\v 11 Kà̱ nra nva̱ uMusa nyáng unəm te, uza̱ fa ga atak onəm wò. Uza̱ ga ya apir mɓək anung va̱ mí nəm ôza̱. Uza̱ ya unəm oga aMasar ka̱ nnə́m unəm wò uHiburu.
\v 12 Te uza̱ dər atak, uza̱ ya unəm uro ka̱t te, uza̱ gba̱l unəm oga aMasar va̱ ta, dəp na ka̱ ashe ashishiri.
\v 13 UMusa fa chit kà̱ɗi ka̱ ìpin ikpa̱kkpa̱k te, uza̱ ya oHiburu pa̱ oparəm ka̱ nlung ìkum. Uza̱ là ûvəngva̱ ka̱ mpat pa̱, <<Sang kang ɓu nə́m ugənang ɓu yà?>>
\p 
\v 14 Te uza̱ là pa̱, <<Uda nak ɓu uponzhi ká̱ unəm uga nnap-akwali á yi yà? U ɗom pa̱ u gba̱l mi wa nva u gba̱l unəm oga aMasar ɗò?>> Ta byet te ayər nəm uMusa pa̱, <<Ya mmá nyi nnap va̱ chit.>>
\p 
\v 15 Kà̱ nva̱ng nva̱ uFirona fe nnap va̱ ta te, uza̱ mo asa̱l aga ngba̱l uMusa. Te uMusa chər uFirona á ga təm ka̱ mbin aMidiyan ka̱ anung ndəng mɓokɓok.
\v 16 Unəm uga mpyal awop oga aMidiyan uwa yà ka̱ ovan ochar pa̱ ofangshat. Oza̱ ɓa nɗyang ndəng na ó yə́ng oga agulong oza̱, ka̱kul nna iya̱m nkang apo oza̱.
\v 17 Te onəm oga nkpak iya̱m nkang oro ɓa ɓàk ovan ochar va̱ ta. Te uMusa wong fa ka̱ oza̱ ka̱ awo onəm va̱ ta, ɗyang ndəng na iya̱m nkang oza̱.
\p 
\v 18 Te oza̱ le atak apo oza̱ uReyuwel (uwa uYeturo), kang upo oza̱ ɓəp oza̱ pa̱, <<Sang kang o le pa̱ kəlak nda va̱ ta̱ yà?>>
\p 
\v 19 Oza̱ là ûpo oza̱ pa̱, <<Unəm oga aMasar à fa ka̱ yi ka̱ awo onəm oga nkpak iya̱m nkang. Kang uza̱ ɗyang ndəng kpá na iya̱m nkang yi.>>
\v 20 Upo oza̱ ɓəp oza̱ pa̱, <<Unəm va̱ ta ka̱ che yà? Sang kang o re na ka̱ ta yà? O ga o wór na á ɓa, na uza̱ á ri iya̱m-nrì nzəng ká̱ yi.>>
\v 21 UMusa ma̱n təm nzəng ka̱ oza̱. Unəm va̱ ta na uyen wò uZipora á na təm uchəchar.
\v 22 UZipora mar uyennunggwan te, uMusa sok aɗin á na pa̱ uGershom, a nyám pa̱, <<Mmami uɗyanəm kà̱ mbin nkak.>>
\v 23 Kà̱ nva̱ng izun pa̱ kyák te, uponzhi oga aMasar kú. Te onəm oIsa̱rila shìn ka̱ mɓək anung inok, oza̱ yə́ng ka̱ nkam i ram nka̱mshi, ayə́ng oza̱ aga nram nka̱mshi ka̱ ashe idumdùm á ga chu atak Inan.
\v 24 Inan fe ashìn oza̱. Te Inan rəng nsar nnap-nlà wò va̱ ò yar ká̱ uAbəraham, ká̱ uIshaku, ká̱ uYakup á.
\v 25 Te Inan ya ovan oga óIsa̱rila, Inan nyi mɓək anung oza̱ kang à dər oza̱ ká̱ aɗor.
\c 3
\s1 Inan wór uMusa
\p 
\v 1 Ká̱ nda nro te, uMusa uwa kà̱ nkpak iya̱m nkang ágwar wò uYeturo unəm uga mpyal awop oga aMidiyan. Uza̱ ga ká̱ iya̱m nkang ka̱ asa̱l awu ntar alum ka̱ ashe nzam te, uza̱ ɓa chu aHorep va mí i wór pa̱ aɓam Inan.
\v 2 Te uMa̱leka aYawe fa á na wa aməlam apər ka̱ ishimshe ikun iyenyen. Uza̱ dər te, uza̱ ya apər kà̱ nsal ka̱ ashe ikun iyenyen va̱ ta, ká̱ nna kpa te, a ri iya̱m iro ka̱t.
\v 3 UMusa là pa̱, <<Nva̱ ta̱ nnap mpipye, mi səng mi ga dát na ń dər, sang kang apər ka̱ nri kang ikun pwák ka̱t yà?>>
\p 
\v 4 Nva̱ngva̱ uYawe ya uMusa kà̱ mɓa ndát pa̱ ô dər te, Inan wór na ka̱ ashe ikun va̱ ta pa̱, <<ÁMusa, áMusa.>>
\p UMusa ma̱n pa̱, <<Mmami nà ta̱.>>
\p 
\v 5 Uza̱ là pa̱, <<Kang wa ɓa dát ka̱t, zəp akwap aga ashar ɓu ka̱kul atak va̱ u sat ka̱ ta te, Atak Ayə́ryər.
\v 6 Mmami na Inan okəka ɓu, Inan aAbəraham, Inan aIshaku, ká̱ Inan aYakup.>> Ayər nəm uMusa te, á ká asa̱l awu wò na kang ô dər Inan ka̱t.
\p 
\v 7 Te uYawe là pa̱, <<Nnandər, n ya idumdùm onəm mi va̱ ya kà̱ mbin aMasar. N fe ayə́ng oza̱ chit ka̱kul onəm oga nkpak ozwal. N nyi mɓək anung oza̱ nyi.
\v 8 N vàng chit pa̱ ń fa ká̱ oza̱ ka̱ ashe awo oga aMasar, kà̱ mbin va̱ ta na ń ga ká̱ oza̱ ka̱ ashe mbin nnəna̱n mbalbal nva mbyal ka̱ mmàl irizhe i nang kà̱.\f + \fr 3.8 \fq mbin nva mbyal ka̱ mmàl irizhe i nang kà̱ \ft kà̱ nnyam pa̱ \fq mbin ndopdop.\f* Atak oKanana, ká̱ oHiti, ká̱ oAmori, ká̱ oPerizi ká̱ oHivi, ká̱ oYebusi.
\v 9 Dər, ayə́ng aga mɓək anung onəm oga aIsa̱rila ɓa chu atak mi chit. N ya apir mɓək anung va̱ chit oga aMasar kà̱ nnəm ôza̱.
\v 10 Ka̱kul nva̱ ta te, ga, Mmami ka̱ nre ɓu ka̱ atak aFirona na u fa ká̱ onəm mi oIsa̱rila ka̱ aMasar.>>
\p 
\v 11 Te uMusa là Inan pa̱, <<Mmami uda kang mi ga mpyal aFirona pa̱ n fa ka̱ onəm oga aIsa̱rila ka̱ aMasar yà?>>
\p 
\v 12 Uza̱ là pa̱, <<Nna mi yà nzəng ka̱ ɓu. Iya̱m va ta̱ i nyám pa̱ mmami na n re ɓu. Nva̱ngva̱ u fa ka̱ oza̱ ka̱ ashe aMasar te, ó wop Inan ka̱ apal aɓam va ta̱.>>
\p 
\v 13 Te uMusa là Inan pa̱, <<A yà pa̱ n ga ka̱ atak onəm oga aIsa̱rila n là ôza̱ pa̱, <Inan okəka wo à re mi ka̱ atak wo,> kang oza̱ á ɓəp mi pa̱, <Aɗiɗin pa̱ uda yà?> Te mi là oza̱ sang yà?>>
\p 
\v 14 Te Inan là uMusa pa̱, <<Mmami na Mmami.>> Iya̱m va ta̱ ɓu là ônəm oga aIsa̱rila, <<Mmami>> Mmami na n re ɓu ka̱ atak wo.
\p 
\v 15 Inan là uMusa kpa pa̱, <<Iya̱m va ta̱ ɓu là ônəm oga aIsa̱rila, <UYawe, Inan okəka wo, Inan aAbəraham, ká̱ Inan aIshaku, ká̱ Inan uYakup à re mi ka̱ atak wo.> Aɗin mi nata̱, ghar mbyet. Nnà mí rəng ká̱ kà̱ nza̱ nlwàk nggo.
\p 
\v 16 <<Ga, ɓut onəmgbak oga aIsa̱rila là ôza̱ pa̱, <UYawe, Inan okəka wo, Inan aAbəraham, ká̱ aIshaku, ká̱ uYakup, fa nyám ishi wò á mi kang uza̱ là pa̱, <<N nak ishi ká̱ wo kang n ya iya̱m va̱ chit mmá nəm a wo ka̱ aMasar.
\v 17 N là pa̱ mi fa ká̱ wo ka̱ ashe idumdùm oga aMasar. Mi ga ka̱ kà̱ mbin oKanana, ká̱ oHiti, ká̱ oAmori, ká̱ oPerizi ká̱ oHivi, ká̱ oYebusi, mbin va mbyal ka̱ mmàl irizhe i nang kà̱.>> >
\p 
\v 18 <<Te oza̱ í gwong achwang ka̱ iya̱m va̱ mi là. Ɓu ga nzəng ka̱ onəmgbak oga aIsa̱rila ka̱ atak aponzhi oga aMasar, na o là á na pa̱, <UYawe, Inan oHiburu, á nyám ishi wò á yi chit. Ka̱kul nva̱ ta te, kusukkusuk, re yi na í ga achen aga nra pa̱ nshatɗing ka̱ ashe ǹzam na í na nləfər iya̱m ipápà ûYawe, Inan yi.>
\v 19 Ká̱ nnà te, n nyinyi pa̱ uponzhi oga aMasar i re wo o ga ka̱t, ya mí nak awo ka̱ na kang.
\v 20 Te mi yichi awo, mi lə̀p aMasar ká̱ nkpaktak iya̱m iga nɗaktak va̱ mi nəm ka̱ ashishe. Nna chit te, uza̱ i re wo o ga ɗak.
\p 
\v 21 <<Mi nak nchə̀r oIsa̱rila í bà̱l kà̱ mpyal oga aMasar, na o wong nfa te, o fa ká̱ awo alakchi ka̱t.
\v 22 Nza̱ uchar nggo i ɓəp oga iya̱m ìsham iga aazurfa ka̱ azənariya ká̱ ílukwan ka̱ atak ochar oga aMasar oga mbəp nzhi oza̱ ka̱ oga ashe ǹzhi oza̱, oga iya̱m ìsham va ta na o mwak ôvan wo onunggwan ka̱ ochar. Wa nnà ta o vyat iya̱m oza̱ ká̱.>>
\c 4
\s1 NRe aMusa
\p 
\v 1 Te uMusa ma̱n uYawe pa̱, <<A yà pa̱ oIsa̱rila à na nnandər ká̱ mi ka̱t, á nak ishi ká̱ iya̱m va̱ mi là ka̱t, kang oza̱ a là pa̱, <UYawe nyám ishi wò a ɓu ka̱t> ɗò?>>
\p 
\v 2 Te uYawe ɓəp na pa̱, <<Iza̱ ta ka̱ awo ɓu yà?>>
\p UMusa là pa̱, <<Idari.>>
\p 
\v 3 UYawe là á na pa̱, <<Mandar kà̱ mbin.>>
\p UMusa mandar idari kà̱ mbin te á wal ìzwa, te uza̱ myat fər ka̱ cho.
\v 4-5 UYawe là ûMusa pa̱, <<Yichi awo ɓu kpán ká̱ ka̱ aswal, ka̱kul pa̱ na oza̱ á na nnandər pa̱ uYawe, Inan okəká oza̱, Inan aAbəraham, Inan aIshaku, ká̱ Inan àYakup à nyám ishi wò a ɓu.>> Te uza̱ yichi awo wò kpán ká̱ te á wal idari ka̱ awuwo.
\p 
\v 6 UYawe là ûMusa kà̱ɗi pa̱, <<Pá awo ka̱ ashe abasəm ɓu.>> Te uza̱ pá awo ka̱ ashe abasəm wò kang à tur fa te, awo yà ká̱ nlak, fə̀r wa aɗəɗal.
\p 
\v 7 Te uYawe là pa̱, <<Le ká̱ awo ka̱ ashe abasəm ɓu kà̱ɗi.>> Te uMusa le ká̱ awo wò kang uza̱ fa ka̱ te, awo le yà wa aɓo izəzər.
\v 8 Te uYawe là pa̱, <<Kang a yà pa̱ oza̱ á na nnandər ká̱ ɓu ka̱t, kang oza̱ nak ishi ká̱ iya̱m iga nɗaktak iga nggəshi ka̱t te, oza̱ í na nnandər ká̱ iga ipəpar.
\v 9 A yà pa̱ oza̱ na nnandər ká̱ iya̱m iga nɗaktak iga iparəm va̱ ta̱ ka̱t kang oza̱ nak ishi ká̱ ichu ɓu ka̱t te, pá ndəng ka̱ ashe awang aNilu, tar kà̱ mbin, te ndəng va̱ ta i wal nchə̀r.>>
\p 
\v 10 Ká̱ nnà te, uMusa là ûYawe pa̱, <<ÁPonzhinan, mmami ka̱ n yà unəm uga iɓa̱ksok, n nyi nnap-nlà ka̱t, kap ká̱ nva̱ ka̱ u yà kà̱ nlà nnap ká̱ mi, ghar ǹyangmata̱.>>
\p 
\v 11 Te uYawe ɓəp na pa̱, <<Uda nəm anung anəm, ka̱t te uda nəm na i là nnap ka̱t, ka̱t te i fe achwang ka̱t, ka̱t te i ya atak ka̱t, ka̱t te a fufo yà? Mmami na uYawe ka̱t ɗò?
\v 12 Gá ǹyangmata̱. Mi yà nzəng ká̱ anung ɓu, mi ɗyang a ɓu iya̱m va̱ ɓu là.>>
\p 
\v 13 Te uMusa là pa̱, <<Kusukkusuk, áPonzhinan, re unəm ukak á ga.>>
\p 
\v 14 Te ìgwak shì uYawe kà̱ uMusa, uza̱ là pa̱, <<Ugənang ɓu uHaruna unəm oLawi sang yà? N nyi pa̱ uza̱ nyi nnap-nlà nyi kang uwa cho kà̱ mɓa nggwang ɓu ka̱ asa̱l. Uza̱ i ya ɓu te ìgwak i chàng na.
\v 15 Te ɓu là nnap á na, kang ɓu nak nnap-nlà ka̱ anunung. Mi yà nzəng ká̱ anung ɓu ká̱ anunung kang mi ɗyang á wó iya̱m va̱ ó nəm.
\v 16 Uza̱ i là nnap a ɓu ká̱ onəm, kang uza̱ i yà anung ɓu, te ɓu yà wa Inan ka̱tətak.
\v 17 Yar idari ata̱ ka̱ awo ɓu, ká̱ í yà ɓu nəm iya̱m iga nɗaktak.>>
\p 
\v 18 Te uMusa le ga atak agwar wò uYeturo, á là á na pa̱, <<Kusukkusuk, re mi n le atak onal mi va̱ ka̱ aMasar ka̱kul na n dər mo te oma yà ká̱ irirì nggo.>>
\p Te uYeter là ûMusa pa̱, <<Ga ka̱ nnap nnəna̱n.>>
\p 
\v 19 Te uYawe là ûMusa ka̱ aMidiyan pa̱, <<Le ga aMasar ka̱kul nkpaktak onəm va̱ ka̱ yà kà̱ mmwo irirì ɓu te, oza̱ kú chit.>>
\v 20 Te uMusa yar uchar wò ka̱ ovan wò onunggwan nak oza̱ ka̱ apal azhaki, te á kpán asa̱l mbin aMasar. UMusa kpán idari aYawe va̱ ka̱ awo wò.
\p 
\v 21 Te uYawe là ûMusa kà̱ɗi pa̱, <<Nva̱ngva̱ u le aMasar te, nkpaktak iya̱m iga nɗaktak va̱ n na ichumchumchumchum ka̱ awo ɓu, te ɓu nəm oza̱ kà̱ mpyal aFirona. Ká̱ nnà te, mi nak igugwak i twat, uza̱ i yà ka̱ nre onəm i ga ka̱t.
\v 22 Te ɓu là ûFirona pa̱, <Iya̱m va ta̱ uYawe là, uIsa̱rila uwa uyen mi ununggwan uga nggəshi.
\v 23 Ka̱ n là a ɓu pa̱, <<Re uyen mi ununggwan á ga ka̱kul na uza̱ a wop mi,>> te u yang ka̱ nre na pa̱ á ga. Ka̱kul nva̱ ta te, mi ga ngba̱l uyennunggwan ɓu uga nggəshi.> >>
\p 
\v 24 Ka̱ apal asa̱l ka̱ atak njul te, uYawe gwang ka̱ na te, á mwo pa̱ o gba̱l na.
\v 25 Te uZipora yar ikpàl iriri uza̱ pà ache uyen wò ká̱, kang à dok ashishar ká̱. Te là á na pa̱, <<Mmaɓu uɓar mi uga nchə̀r.>>
\v 26 Te uYawe re na. (Nva̱ uza̱ là pa̱, <<Mmaɓu uɓar uga nchə̀r,>> te uza̱ kà̱ nlà nnap mpà ache va ta.)
\p 
\v 27 Te uYawe là ûHaruna pa̱, <<Ga gwang uMusa ka̱ ashe ǹzam.>> Te uza̱ ga gwang na ka̱ aɓam Inan, uza̱ má njàng á na.
\v 28 Te uMusa là ûHaruna nkpaktak iya̱m va̱ uYawe re na ká̱, ká̱ nkpaktak iya̱m iga nɗaktak va̱ uza̱ nak na pa̱ á nəm.
\p 
\v 29 Te uMusa ká̱ uHaruna ga ɓut nkpaktak onəmgbak oIsa̱rila.
\v 30 UHaruna là nkpaktak iya̱m va̱ uYawe là ûMusa, te uMusa\f + \fr 4.30 \fq uMusa: \ft ká̱ iHiburu nggwan nnap-nlà nva̱ mmá nəm inok ká̱ ka̱ ta te, \fq uza̱.\f* nəm oga iya̱m iga nɗaktak va̱ kà̱ mpyal onəm.
\v 31 Onəm na nnandər ká̱. Nva̱ngva̱ oza̱ fe pa̱ uYawe nak ishi ká̱ kang à ya mɓək anung oIsa̱rila chit te, oza̱ kúchi nəm awop.
\c 5
\s1 UMusa ká̱ uHaruna ga mpyal aFirona
\p 
\v 1 UMusa ká̱ uHaruna tar atak áFirona kang à là á na pa̱, <<Iya̱m va ta̱ uYawe, Inan oIsa̱rila là, <Re onəm mi á ga ka̱kul na oza̱ á nəm awop aga nrí ká̱ ngwa á mi ka̱ ashe anyin.> >>
\p 
\v 2 UFirona na ama̱n pa̱, <<Uda uYawe va̱ kang mi fe ichəchu mi re uIsa̱rila i ga yà? N nyi uYawe ka̱t, kang mi re uIsa̱rila i ga ka̱t.>>
\p 
\v 3 Te oza̱ là pa̱, <<Inan oHiburu à gwang ká̱ yi. Kusukkusuk, re yi í nəm achen aga nra pa̱ nshatɗing ka̱ ashe anyin ka̱kul na i na nləfər iya̱m ipápà ûYawe, Inan yi, le kang uza̱ a lə̀p yi ká̱ arwa aɓá̱ngɓa̱ng ka̱t te ká̱ ndokchi ka̱t.>>
\p 
\v 4 Te uponzhi uga aMasar là pa̱, <<ÁMusa ká̱ uHaruna, sang kang o yar nnap nnəm onəm ka̱ atak inok oza̱ yà? Ó le atak inok wo.>>
\v 5 UFirona là kpa pa̱, <<Dər, onəm oga mbin va̱ ta̱ yəl byet, kang ó dáng oza̱ kà̱ nnəm inok oza̱.>>
\p 
\v 6 Ká̱ nda va ta uFirona nak onəm oga nkpak ozwal nzəng ká̱ ogá nak ishi ká̱ inok pa̱,
\v 7 <<Kang o ga mpyal ka̱ nna ìɗùktum iro ónəm va̱ ta ka̱kul nnəm abərki wa nva̱ kà̱ nra va̱ watar lap ka̱t, re oza̱ á ga á mwo ka̱kul ishi oza̱.
\v 8 Ká̱ nna te, nak oza̱ á nəm abərki wa kà̱ nra va̱ watar, kang á yen ka̱t. Ka̱kul oza̱ onəm pwompwom, nna nak kang oza̱ kà̱ ǹyə́ng ayə́ng pa̱, <Re yi í ga i na nləfər iya̱m ipápà Inan yi.>
\v 9 Kà̱r oza̱ ká̱ inok imakmak, ka̱kul na á dáng oza̱ kà̱ nggwong achwang kà̱ oga akwàm va̱ ta.>>
\p 
\v 10 Te onəm oga nkpak ozwal ká̱ oga nnak ishi ká̱ inok ga là ônəm pa̱, <<Iya̱m va ta̱ uFirona là, <Mí na ìɗùktum a wo ka̱t.
\v 11 O ga o mwo ìɗùktum ka̱ ishiwo ka̱ atak va̱ o ya kà̱ á, ká̱ nna te, mí yà ká̱ nkəla̱p inok a wo ka̱t.> >>
\v 12 Te onəm lyangshin ka̱ ashe nkpaktak mbin aMasar i cák ìɗùktùm.
\v 13 Onəm oga nkpak ozwal sat atak ôza̱, í là pa̱, <<O nəm inok wo iga nza̱ nra nggo wa nva mmá ka̱ yà kà̱ nna ìɗùktum a wo á.>>
\v 14 Te onəm oga nkpak ozwal aFirona nə́m oIsa̱rila oga nak ishi ká̱ inok va̱ oza̱ kyep ka̱ apal oza̱, ɓəp pa̱, <<Sang kang o yə́l mmák abərki wa nva̱ ka̱ yà ó nəm ká̱ nlam ká̱ nda va̱ ta̱ ka̱t yà?>>
\p 
\v 15 Te oIsa̱rila oga nak ishi ká̱ inok ga atak áFirona yə́ng á na pa̱, <<Sang kang ɓu nəm ózwal ɓu wa nta̱ yà?
\v 16 Mmá kà̱ nna ìɗùktum ózwal ɓu ka̱t, ká̱ nna te, oza̱ là á yi pa̱, <Ó nəm abərki.> Dər, mmá kà̱ nnə́m ózwal ɓu ka̱kul mpat onəm ɓu na.>>
\p 
\v 17 Te uza̱ là pa̱, <<Ó pwom paɗi. Nna nak kang o là pa̱, <Re yi í ga í na nləfər iya̱m ipápà ûYawe.>
\v 18 Ǹyangmata̱, o le, o ga atak inok, mí na ìɗùktum a wo ka̱t, ká̱ nnà te, o nəm mmák abərki wa mmatmat.>>
\p 
\v 19 OIsa̱rila oga nak ishi ká̱ inok nyi pa̱ mmawó ka̱ ashe nɗaktak, nva̱ mmá là óza̱ pa̱, <<Ó yà ká̱ nnəm mmák abərki va̱ ta i yen aga nza̱ nra nggo ka̱t.>>
\v 20 Nva̱ngva̱ oza̱ fa ka̱ atak áFirona te, oza̱ gwang uMusa ká̱ uHaruna tong kà̱ nlok oza̱.
\v 21 Oza̱ là ûMusa ká̱ ûHaruna pa̱, <<Re uYawe á dər wo á nap akwali a wo, nva̱ o nak í tong onəm oɓá̱ngɓa̱ng kà̱ mpyal àFirona ká̱ ozuzwal. O nak ndokchi ka̱ awo oza̱ pa̱ á gbá̱ng yi.>>
\p 
\v 22 Te uMusa le ga atak áYawe là pa̱, <<Sang kang u na mɓək anung ónəm va̱ ta̱ wa nva̱ ta̱ yà, áPonzhinan? Sang kang u re mi yà?
\v 23 Á ɓàn matmat nva̱ n ga atak áFirona pa̱ n là nnap ká̱ aɗin ɓu te, uza̱ nəm mɓək anung ónəm va̱ ta̱, kap ká̱ nnà te, nna u fa ká̱ onəm ɓu chit ka̱t.>>
\c 6
\p 
\v 1 Te uYawe na ama̱n ûMusa pa̱, <<Ǹyangmata̱ te, ɓu ga ǹya iya̱m va̱ mi nəm uFirona. Uza̱ i re oza̱ i ga ka̱kul ìkam awo mi, ka̱kul ìkam awo mi uza̱ i wà oza̱ i fa ka̱ ashe mbin wò.>>
\p 
\v 2 Te Inan là ûMusa pa̱, <<Mmami na uYawe.
\v 3 N nyám ishi mi uAbəraham, ká̱ uIshaku, ká̱ uYakup, wa Inan ìChumchum, kang m bol ôza̱ pa̱ aɗin mi pa̱ uYawe ka̱t.
\v 4 N yar nsar nnap-nlà ká̱ oza̱ pa̱, mi na mbin ngga aKanana ôza̱, mbin nva oza̱ kà̱ ntəm ka̱ ashishe wa onəmchən.
\v 5 Kà̱ɗi te, n fe ashìn onəm oIsa̱rila chit, nva̱ oga aMasar í nak nkpak oza̱ í nəm inok wa ozwal, kang n rəng ká̱ nsar nnap nla mi chit.
\p 
\v 6 <<Ka̱kul nva̱ ta te, là ôIsa̱rila pa̱, <Mmami na uYawe, mi fa ká̱ wo ka̱ atak inok iga nkpak oga aMasar, mi fən wo ka̱ atak nnəm izwal óza̱, mi ka̱mshi wo ká̱ awo mi akamkam, ká̱ akwali achumchum.
\v 7 Mi ka̱m wó o yà onəm mi, kang mi yà Inan wo. Te o nyi pa̱ Mmami na uYawe, Inan wó, uva fa ká̱ wó ka̱ atak inok iga nkpak oga aMasar.
\v 8 Te mi ɓa ká̱ wó ka̱ ashe mbin va n sóng anung pa̱ mi na ûAbəraham, ká̱ ûIshaku, ká̱ ûYakup, te mi na á wó i yà njiwó. Mmami na uYawe.> >>
\p 
\v 9 Te uMusa là iya̱m va̱ ta̱ ôIsa̱rila, te oza̱ gwong achwang kà̱ na ka̱t. Á rusok izər óza̱ ka̱kul oza̱ ka̱ ashe inok iɗəkɗək.
\p 
\v 10 Te uYawe là ûMusa pa̱,
\v 11 <<Ga là uFirona uponzhi oga aMasar á re oIsa̱rila á fa ka̱ ashe mbibin.>>
\p 
\v 12 Te uMusa là kà̱ mpyal àYawe pa̱, <<A yà pa̱ oIsa̱rila i gwong achwang kà̱ mi ka̱t te, i yar sang kang uFirona i gwong achwang kà̱ mi yà? Nnà mmami unəm uga aɓələm aɗəkɗək á?>>
\p 
\v 13 Te uYawe là nnap-nlà ûMusa ká̱ ûHaruna pa̱, <<O ga o là ûIsa̱rila ká̱ ûFirona uponzhi oga aMasar, pa̱ n nak wo chit pa̱ o fa ká̱ oIsa̱rila ka̱ ashe mbin aMasar.>>
\s1 Akum ALawi
\mi1 
\v 14 Onəm oga mpyal akum ìjili okəká oza̱ omata̱.
\pi1 Ovan aRuben uya aIsa̱rila uga nggəshi, oma uHanok ká̱ uFalu, ká̱ uHezuron ká̱ uKarmi, omata akum aRuben.
\pi1 
\v 15 Ovan aSimeyon, oma uYemuyel, ká̱ uYamin, ká̱ uOhat, ká̱ uYakan, ká̱ uZohar, ká̱ uShawul uwa unənang uyen oga aKanana, omata akum aSimeyon.
\pi1 
\v 16 Aɗin ovan aLawi omata̱ ká̱ akum oza̱, oma uGershon, ká̱ uKohat, ká̱ uMerari. ULawi nəm ìzun ìgba̱l pa̱ ìzəng ká̱ ìsəm pa̱ ishatɗing ama̱n pa̱ fangshat.
\pi1 
\v 17 Ovan aGershon oma, uLibəni ká̱ uShimayi, ka̱ atak akum oza̱.
\pi1 
\v 18 Ovan aKohat oma, uAməram, uIzhar, uHebəron, ká̱ uUza̱yel. UKohat nəm ìzun ìgba̱l pa̱ ìzəng ká̱ ìsəm pa̱ ishatɗing ama̱n pa̱ shatɗing.
\pi1 
\v 19 Ovan aMerari oma, uMakli ka̱ uMushi. Akum oLawi nata, mmá dàt oza̱ ka̱ akum ka̱ akum.
\pi1 
\v 20 UAməram ka̱m uYokabyet ugənang apupon, kang uza̱ mar uHaruna ká̱ uMusa á na. UAməram nəm ìzun ìgba̱l pa̱ ìzəng ká̱ ìsəm pa̱ ishatɗing ama̱n pa̱ fangshat.
\pi1 
\v 21 Ovan aIzhar oma, uKora, ká̱ uNefek, ká̱ uZikri.
\pi1 
\v 22 Ovan aUza̱yel oma, uMishayel, ká̱ uEləzafan, ká̱ uSitəri.
\pi1 
\v 23 Te uHaruna ka̱m uElisheba uya aAminadap ugənang aNashon, á mar uNadap, ká̱ uAbihu, ká̱ uEliyaza, ká̱ uItama á na.
\pi1 
\v 24 Ovan áKora oma, uAshir, ká̱ uElkana, ká̱ uAbiyasap, omata akum oKora.
\pi1 
\v 25 Te uEleazar uya áHaruna ka̱m uzəngtəng ka̱ ashe ovan aFutiyel. Uza̱ mar uFinehas á na. Oma onəm oga mpyal onəm aLawi ka̱ atak akum oza̱.
\p 
\v 26 UHaruna ká̱ uMusa, oma uYawe là ôza̱ pa̱, <<Ó fa ká̱ oIsa̱rila ka̱ ashe mbin aMasar ìdonkong ìdonkong.>>
\v 27 UMusa ká̱ uHaruna, oma là nnap ûFirona uponzhi oga aMasar pa̱, uza̱ á re onəm oIsa̱rila á fa ka̱ ashe mbin aMasar.
\s1 UMusa ká̱ uHaruna kà̱ mpyal aFirona
\p 
\v 28 Ka̱ nda va̱ uYawe kà̱ là nnap ká̱ uMusa ka̱ ashe mbin aMasar te,
\v 29 uza̱ là á na pa̱, <<Mmami na uYawe. Là úFirona uponzhi oga aMasar nkpaktak iya̱m va̱ mmami kà̱ nləla a ɓu.>>
\p 
\v 30 Te uMusa na ama̱n kà̱ mpyal aYawe pa̱, <<Mmami unəm uga aɓələm aɗəkɗək, n nyi nnap-nlà ka̱t, te i yar sang kang uFirona i gwong achwang kà̱ mi yà?>>
\c 7
\p 
\v 1 Te uYawe là ûMusa pa̱, <<Nak nnap nnəm ɓu pa̱ dakdak kà̱ nnap va̱ ta̱. N nak ɓu chit wa Inan kà̱ mpyal aFirona, kang uHaruna ugənang ɓu i yà unəm uga nlà ìchu ɓu.
\v 2 Ɓu là nkpaktak iya̱m va̱ n là a ɓu ûHaruna ugənang ɓu, kang uza̱ i là ûFirona pa̱ á re oIsa̱rila á fa ka̱ ashe mbin wò.
\v 3 Te mi nak ìgwak aFirona i twat ka̱kul na ń nak oga iya̱m iga nɗaktak mi ká̱ iga nnəm ayər á yà pa̱ kyak ka̱ ashe mbin aMasar.
\v 4 Te uFirona i gwong achwang kà̱ wo ka̱t, te mi nak awo mi ka̱ apal aMasar kang mi fa ká̱ nggatək onəm mi oIsa̱rila ka̱ ashe mbin aMasar ká̱ akwali achumchum.
\v 5 Te oga aMasar i nyi pa̱ mmami uYawe, nva̱ngva̱ n yichi awo mi ka̱ apal aMasar kang n fa ká̱ oIsa̱rila ka̱ ashe oza̱.>>
\p 
\v 6 Te uMusa ká̱ uHaruna nəm dakdak wa nva uYawe là ôza̱.
\v 7 UMusa ka̱ yà uyen uga ìzun ìsəm na̱nne kang uHaruna uyen uga ìzun ìsəm na̱nne ama̱n pa̱ shatɗing ka̱ ashe nra va̱ oza̱ là nnap ká̱ uFirona.
\p 
\v 8 Te uYawe là ûMusa ká̱ ûHaruna pa̱,
\v 9 <<Nva̱ngva̱ uFirona á là a wo pa̱, <Ó nəm iya̱m iga nnəm ayər á wò,> te là ûHaruna pa̱, <Yar idari ɓu mandar kà̱ mpyal áFirona.> Te i wal ìzwa.>>
\p 
\v 10 Te uMusa ká̱ uHaruna tar atak áFirona nəm dakdak wa nva uYawe nak. Te uHaruna mandar idari wò kà̱ mpyal aFirona ká̱ okparikpari, te á wal ìzwa.
\v 11 Ká̱ nna te, uFirona wór onəm wò oga ntàn, ká̱ onəm omámmàm oga aMasar, oza̱ nəm ka̱ atak nnap inunggwan oza̱ kpa wa nva oza̱ nəm.
\v 12 Nza̱ uzəngtəng oza̱ nggo mandar idari wò, te á wal ìzwa, kang idari aHaruna wur ijo oza̱ ma̱ng.
\v 13 Káp ká̱ nna te, ìgwak aFirona ì yà tutwat, uza̱ yang ká̱ nggwong achwang kà̱ oza̱, wa nva uYawe ka̱ là.
\s1 Nɗaktak nggəshi, nchə̀r
\p 
\v 14 Te uYawe là ûMusa pa̱, <<Ìgwak aFirona tutwat, uza̱ yang ǹre onəm pa̱ á ga.
\v 15 Ga atak aFirona ká̱ ìpin ya uza̱ kà̱ nfa ngga anung awang aNilu, sat ka̱ anung akonkong lok na. Yar idari va̱ kà̱ wal ìzwa ka̱ awo ɓu.
\v 16 Là á na pa̱, <UYawe, Inan oHiburu à re mi pa̱ ń là a ɓu pa̱, <<Re onəm mi á ga ka̱kul na oza̱ a wop mi ka̱ ashe anyin.>> Kang ghar ǹyangmata̱ u yang ká̱ nggwong achwang.
\v 17 Iya̱m va ta̱ uYawe là, <<Ka̱ apal nnata̱ ɓu nyi pa̱ mmami uYawe.>> Mi ngga mpan ndəng aNilu ká̱ idari va̱ ta̱ ka̱ awo mi, kang i wal nchə̀r.
\v 18 Te igwali iga awang aNilu i kú, aNilu i nəng, ndəng awang aNilu i ma̱t oga aMasar kà̱ ngwa.> >>
\p 
\v 19 Te uYawe là ûMusa pa̱, <<Là ûHaruna pa̱, <Yar idari ɓu na ú yichi awo ɓu ka̱ apal oga ndəng ngga aMasar, ka̱ apal oga awang oza̱, ka̱ apal oga ngwangsang, ka̱ apal oga apyáp, ka̱ apal oga nshənggət, ka̱kul na oza̱ á wal nchə̀r. Te nchə̀r i yà ka̱ ashe nkpaktak mbin aMasar, ká̱ ashe oga iya̱m iga nchwong ndəng iga akún ká̱ iga ipang.> >>
\p 
\v 20 UMusa ká̱ uHaruna nəm dakdak wa nva uYawe nak. Uza̱ gha̱p idari pàn ndəng ngga awang aNilu ká̱ kà̱ iwu aFirona ká̱ okparikpari, kang nkpaktak ndəng ngga awang aNilu wal nchə̀r.
\v 21 Igwali va̱ ka̱ ashe awang aNilu kú, awang aNilu nnsəng, ndədəng ma̱t oga aMasar kà̱ ngwa. Kang nchə̀r gang ashe mbin aMasar pa̱ lat.
\p 
\v 22 Ká̱ nna te, onəm omámmàm oga aMasar nəm ka̱ atak nnap inunggwan oza̱ kpa wa nva oza̱ nəm. Te ìgwak aFirona twat, kang uza̱ fe oza̱ ka̱t, wa nva uYawe ka̱ là.
\v 23 UFirona ga̱ɓa̱n ga ashe ǹzhi wò, kang uza̱ nak ishi ká̱ nkpaktak oga iya̱m va̱ ta ka̱t na kpa.
\v 24 Nkpaktak oga aMasar ɓok akonkong awang aNilu pa̱ na o ya ndəng o wá, ka̱kul ndəng ngga awang aNilu ma̱t oza̱ chit kà̱ ngwa.
\p 
\v 25 Á yə́l nra chit pa̱ nfangshat kà̱ nva̱ngva̱ uYawe pàn awang aNilu á.
\c 8
\s1 Nɗaktak ngga mparəm, mpwakap
\p 
\v 1 Te uYawe là ûMusa pa̱, <<Ga là ûFirona pa̱, <UYawe là pa̱, <<Re onəm mi á ga ka̱kul na oza̱ a wop mi.
\v 2 A yà pa̱ ɓu yang ká̱ ǹre oza̱ te, mi ga nre ǹre ká̱ oga mpwakap kà̱ nkpaktak aswari mbin ɓu.
\v 3 Awang aNilu i yə́l ká̱ mpwakap, kang oza̱ i táng ashe nkəlang iponzhi ɓu ká̱ ashe ǹzhi nra ɓu, ká̱ apal alyer ɓu, ká̱ nzhi okpari ɓu, kang ka̱ apal onəm ɓu ká̱ oga igəng iga ngwang iya̱m ɓu, ká̱ oga asu aga nkál mmá̱k ɓu.
\v 4 Oga mpwakap i kyen a ɓu ka̱ izər, ká̱ onəm ɓu, ká̱ nkpaktak okpari ɓu.>> > >>
\p 
\v 5 Te uYawe là ûMusa pa̱, <<Là ûHaruna pa̱, <Yichi idari ɓu ka̱ apal oga awang, ká̱ ngwangsang, ká̱ oga apyáp na oga mpwakap á fa ka̱ apambin aMasar.> >>
\p 
\v 6 Te uHaruna yichi awo wò ka̱ apal oga ndəng ngga aMasar, kang oga mpwakap fa dàngchi mbin aMasar.
\v 7 Te onəm omámmàm nəm ka̱ atak nnap inunggwan oza̱ kpa, wa nva oza̱ nəm, oga mpwakap fa ka̱ apambin aMasar.
\p 
\v 8 Te uFirona wór uMusa ká̱ uHaruna, uza̱ là pa̱, <<Chal uYawe ka̱kul na uza̱ á wur oga mpwakap á le á mi ká̱ onəm mi, te mi re onəm i ga ka̱kul na oza̱ á na nləfər ûYawe.>>
\p 
\v 9 Te uMusa là ûFirona pa̱, <<Yak awalang va̱ u ɗom pa̱ n chal ka̱kul ɓu, ká̱ okpari ɓu, ká̱ onəm ɓu, pa̱ mmá yar oga mpwakap á le a ɓu ká̱ oga nzhi wó, na oza̱ á yà ka̱ ashe awang aNilu na chwat.>>
\p 
\v 10 Te uFirona là pa̱, <<Ìpin.>>
\p Te uMusa là pa̱, <<I yà wa nva u là á, ka̱kul na u nyi pa̱, unəm uro yà wa áYawe, Inan yi ka̱t.
\v 11 Uza̱ i wur oga mpwakap i le a ɓu, ká̱ okpari ɓu, ká̱ onəm ɓu, i re oza̱ ka̱ ashe awang aNilu nà chwat.>>
\p 
\v 12 Te uMusa ká̱ uHaruna fa ka̱ atak aFirona, nna chit te, uMusa chal uYawe pa̱ á wur oga mpwakap va̱ uza̱ re ǹre ûFirona ká̱ á le.
\v 13 Te uYawe nəm wa nva uMusa ɓəp, kang oga mpwakap ka̱ ashe oga nzhi, ká̱ ashe agəla̱n, ká̱ ashe ǹzam kú.
\v 14 Oga aMasar ɓut mpwakap va̱ ta nchələ́ngnchələ́ng, kang à nnəng ashe mbin va̱ ta.
\v 15 Te nva̱ngva̱ uFirona ya pa̱ oga mpwakap yà lap ka̱t te, uza̱ twat ìgwak wò, uza̱ gwong achwang kà̱ oza̱ ka̱t, wa nva uYawe là.
\s1 Nɗaktak ngga nshatɗing, mməsham
\p 
\v 16 Te uYawe là ûMusa pa̱, <<Là ûHaruna pa̱, <Yichi idari ɓu na ú pàn mɓwang mbin ká̱ na á wal mməsham ka̱ ashe nkpaktak mbin aMasar.> >>
\v 17 Te oza̱ nəm wa nnà ta, kang nva̱ngva̱ uHaruna yichi awo wò pàn mbin ká̱ idari wò, te oga mməsham fa kyen unəmləbər ka̱ izər ká̱ iga iya̱m nkang. Nkpaktak mɓwang mbin ka̱ ashe aMasar ga̱ɓa̱n yà mməsham.
\v 18 Onəm omámmàm ɗak pa̱ ó fa ká̱ mməsham kpa ka̱ atak nnap inunggwan oza̱, te á ma̱t oza̱. Oga mməsham káp ka̱ izər ánəmləbər ká̱ iya̱m nkang.
\p 
\v 19 Onəm omámmàm là ûFirona pa̱, <<Ìfang Inan ta̱.>> Kang ìgwak aFirona ì ya à tutwat, te uza̱ gwong achwang kà̱ oza̱ ka̱t, wa nva uYawe kà̱ là.
\s1 Nɗaktak ngga nneɗing, ichəngchəng
\p 
\v 20 Te uYawe là ûMusa pa̱, <<Wong ká̱ iɓotak na ú sat kà̱ mpyal aFirona kà̱ nfə́r ngga awang, là á na pa̱, <Iya̱m va ta̱ uYawe là, <<Re onəm mi á ga ka̱kul na oza̱ a wop mi.
\v 21 Kang a yà pa̱ ɓu re onəm mi i ga ka̱t, te nyi pa̱ mi ga nre ǹre ká̱ iga ichəngchəng pa̱ makmak ka̱ apal ɓu, ká̱ okpari ɓu, ká̱ onəm ɓu. Ashe nzhi oga aMasar yə́l ká̱ ichəngchəng kang ichəngchəng i dàngchi mbin oza̱ kpa.
\v 22 Kang kà̱ ilum va̱ ta te, mi va̱n mbin aGoshen atak va̱ onəm mi ka̱ ntəm kà̱. Mí ya ichəngchəng ka̱ ta juwo ka̱t, ka̱kul na ú nyi pa̱ mmami na uYawe, n na n yà ka̱ ashe mbin va̱ ta̱.
\v 23 Mi nak aswari kà̱ ishimshe onəm mi ká̱ onəm ɓu. Iya̱m iga nɗaktak va̱ ta̱ i ga nfa ìpin.>> > >>
\p 
\v 24 Te uYawe nəm wa nnà ta, ichəngchəng fa pa̱ makmak yə́l ashe nzhi iponzhi áFirona ká̱ oga nzhi okparikpari. Te nkpaktak mbin aMasar vyap ka̱kul iga ichəngchəng.
\p 
\v 25 Te uFirona wór uMusa ká̱ uHaruna là ôza̱ pa̱, <<O ga o na nləfər Înan wo ka̱ ashe mbin va ta̱.>>
\p 
\v 26 Te uMusa là pa̱, <<Ì mmá pa ka̱t. Nləfər iya̱m ipápà va̱ í ga nnəna ûYawe, Inan yi te, i yà iya̱m iga nnəm ajan ka̱ atak oga aMasar. A yà pa̱ í na nləfər iya̱m ipápà iga nnəm ajan va̱ ta oza̱ kà̱ ǹyəya te, oza̱ i kwan yi ká̱ ipang í kú ka̱t ɗò?
\v 27 Nkpak pa̱ í nəm achen aga nra pa̱ nshatɗing ka̱ ashe anyin, na í na nləfər iya̱m ipápà ûYawe, Inan yi, wa nva uza̱ i là á yi.>>
\p 
\v 28 Te uFirona là pa̱, <<Mi re wo o ga ashe anyin na o na nləfər iya̱m ipápà ûYawe, Inan wo. Ká̱ nna te, kang o ga á gbà̱ng ka̱t. O chal ka̱kul mi.>>
\p 
\v 29 Te uMusa là pa̱, <<Mi fa ka̱ atak ɓu i gbà̱ng nva̱ng ka̱t te, mi chal uYawe kang ìpin te, uza̱ í nak iga ichəngchəng imakmak va̱ ta̱ i lar i le ka̱ atak aFirona, ká̱ okparikpari, ká̱ nkpaktak onənəm. Ká̱ nna te, kang wa tàng yi kà̱ɗi wa yang ká̱ ǹre onəm pa̱ á ga á na nləfər iya̱m ipápà ûYawe ka̱t.>>
\p 
\v 30 Te uMusa fa kà̱ mpyal aFirona te, á chal uYawe,
\v 31 te uYawe nəm wa nva uMusa là, kang à nak ichəngchəng va̱ ta lar ka̱ atak aFirona, ká̱ okparikpari, ká̱ onənəm, kang ichəngchəng iro pa̱ izəng re ka̱t.
\v 32 Ká̱ nna te, uFirona twat ìgwak wò kà̱ɗi, á yang re onəm ga ka̱t.
\c 9
\s1 Nɗaktak ngga ntukun, iya̱m nkang
\p 
\v 1 Te uYawe là ûMusa pa̱, <<Ga atak aFirona là á na pa̱, <Iya̱m va ta̱ uYawe, Inan oHiburu là, <<Re onəm mi á ga ka̱kul na oza̱ a wop mi.>>
\v 2 Kang a yà pa̱ ɓu ga mpyal ká̱ nkpán oza̱, ɓu re oza̱ i ga ka̱t te,
\v 3 uYawe i nak awo wò aga nɗaktak nɗəkɗək ka̱ apal iya̱m nkang wo va̱ ka̱ ashe ǹzam, ka̱ apal ipəri, azhaki, alakəmi, ína, oga inagàm ká̱ iɓəl.
\v 4 Ká̱ nna te, uYawe i va̱n iya̱m nkang oIsa̱rila ka̱ ashe ijo oga aMasar, kang na iya̱m nkang oIsa̱rila iro pa̱ izəng á kú ka̱t.> >>
\p 
\v 5 Te uYawe nak awalang, á là pa̱, <<Ìpin te, uYawe i ga nnəm iya̱m ata̱ ka̱ ashe mbin.>>
\v 6 Ìpin kpa̱k te, uYawe nəm iya̱m ata. Nkpaktak iya̱m nkang oga aMasar kú, nnyi te, iya̱m nkang oga oIsa̱rila iro kú pa̱ izəng ka̱t.
\v 7 Te uFirona re onəm ga sòng kang à ya pa̱, iya̱m nkang oga aIsa̱rila iro pa̱ izəng kú ka̱t. Káp ká̱ nna te, ìgwak àFirona twat, te uza̱ yang ká̱ ǹre onəm pa̱ á ga.
\s1 Nɗaktak ngga nkpa̱kɗing, nsòmò
\p 
\v 8 Te uYawe là ûMusa ká̱ uHaruna pa̱, <<Ó kpa̱k ǹchwang ka̱ ashe achər ka̱ awo wà pa̱ súr na uMusa á swang á ga apal kà̱ ìwu aFirona.
\v 9 I wal mɓwang nnəna̱n ka̱ apal nkpaktak mbin aMasar, kang nsòmò nlóklok i fa ka̱ apal onəm ká̱ iya̱m nkang ka̱ ashe nkpaktak mbin aMasar.>>
\p 
\v 10 Te oza̱ kpa̱k nchwang ngga ashe achər sat ká̱ kà̱ mpyal aFirona, te uMusa swang á ga apaɓur, kang nòmò nlóklok fa ónəm ka̱ izər ká̱ oga iya̱m nkang.
\v 11 Onəm omámmàm chu pa̱ o sat kà̱ mpyal aMusa ka̱t ka̱kul oga nsòmò. Oga nsòmò fa ónəm omámmàm ká̱ nkpaktak onəm oga aMasar.
\v 12 Ká̱ nnà te, uYawe nak ìgwak aFirona twat kang uza̱ yang ka̱ nggwong achwang, wa nva uYawe ka̱là ûMusa.
\s1 Nɗaktak ngga nfangshat, aɗəɗal
\p 
\v 13 Te uYawe là ûMusa pa̱, <<Wong ká̱ iɓotak ga atak aFirona. Là á na pa̱, <Iya̱m va ta̱ uYawe, Inan oHiburu là, <<Re onəm mi á ga ka̱kul na oza̱ a wop mi.
\v 14 Pá ka̱t te, mi ga nre ǹre ka̱ nkpaktak nɗaktak mi ka̱ apal ishi ɓu, ká̱ okpari ɓu, ká̱ onəm ɓu. Nnà chit te, ɓu nyi pa̱ unəm uro yà wa njem lap ka̱ ashe nkpaktak apambin ka̱t.
\v 15 Wa ǹyangmata̱ te, ká̱ n yichi awo mi chit ká̱ ń ləp ɓu ká̱ onəm ɓu ká̱ nɗaktak, kang ká̱ n zhì wo chit ka̱ apambin.
\v 16 Ká̱ nnà te, n re ɓu ka̱ irirì ka̱kul ìpir nnap va ta̱, pa̱ na ń nyám ichumchum mi a ɓu, na mmá shet aɗin mi ka̱ ashe nkpaktak apambin.
\v 17 Ká̱ nnà te, mmaɓu kà̱ nnyám nggá̱r ka̱ apal onəm mi, u yang ka̱ ǹre oza̱ pa̱ á ga.
\v 18 Ìpin ká̱ atak wa nta̱ te, mi pə̀ng aɗəɗal va nna ka̱ yà chit ka̱t kà̱ ǹra va̱ mmá pak aMasar ká̱ á, ya ǹyangmata̱.
\v 19 Ka̱kul nva̱ ta te, nak mmá ɓa ká̱ iya̱m nkang ɓu ka̱ afo ká̱ nkpaktak iya̱m va mmaɓu ká̱ ka̱ ashe ǹzam. Nza̱ unəm nggo ká̱ iya̱m nkang va̱ ka̱ ashe ǹzam kang mmá ɓa ká̱ ka̱ ashe ka̱t te, i ga nkú a yà pa̱ aɗəɗal pə̀ng óza̱ á.>> > >>
\p 
\v 20 Onəm va̱ ka̱ ashe okpari áFirona va̱ nəm ayər nnap-nlà aYawe te, oza̱ nak ozwal oza̱ ká̱ iga iya̱m nkang chəng táng afo.
\v 21 Te onəm va̱ gwong achwang kà̱ nnap-nlà aYawe ka̱t te, á re ozwal oza̱ ká̱ iya̱m nkang oza̱ ka̱ ashe ǹzam.
\p 
\v 22 Te uYawe là ûMusa pa̱, <<Yichi awo ɓu á ga apaɓur na aɗəɗal á pə̀ng kà̱ nkpaktak mbin aMasar, ka̱ apal ánəmləbər ká̱ iya̱m nkang, ká̱ nkpaktak iya̱m nsuk ka̱ ashe íram oga aMasar.>>
\v 23 Te uMusa yichi idari wò á ga apaɓur, te uYawe re ǹre ká̱ ìgbarman ká̱ aɗəɗal. UYawe fə́r ká̱ aməlam kang à pə̀ng aɗəɗal kà̱ mbin aMasar.
\v 24 Aɗəɗal ká̱ aməlam fə́r, apipir nnà yà chit ka̱ ashe aMasar ka̱t matmat nva̱ uza̱ ka̱ yà mbin á.
\v 25 Aɗəɗal chwan iya̱m va̱ ka̱ ashe ǹzam kà̱ nkpaktak mbin aMasar, á ɓan kà̱ unəmləbər, ká̱ iya̱m nkang, ká̱ iya̱m nsuk, kang à chwan ikún kpa.
\v 26 Mbin aGoshen atak va̱ oIsa̱rila təm kà̱, nna byet aɗəɗal yà kà̱ ka̱t.
\p 
\v 27 Te uFirona re ǹre kà̱ uMusa ká̱ uHaruna là ôza̱ pa̱, <<Ka̱ walang ata̱ mmami ká̱ mpat. UYawe uwa unəna̱n, kang mmami ká̱ onəm mi ì pəpat.
\v 28 Chal uYawe, igbarman ká̱ aɗəɗal Inan kúr chit. Mi ga ǹre wó, ó ga, á mal pa̱ o kali lap ka̱t.>>
\p 
\v 29 UMusa là á na pa̱, <<Mi re ìtong va̱ ta̱ i gbà̱ng nva̱ng ka̱t, mi gha̱p oga awo mi ûYawe te, igbarman i sat, kang aɗəɗal i yà lap ka̱t. Te ɓu nyi pa̱ apambin nja aYawe.
\v 30 Te n nyinyi pa̱ mmaɓu ká̱ okpari ɓu o nəm ayər áYawe, Inan chit ka̱t.>>
\p 
\v 31 (Ǹyangmata̱ nfət ká̱ ibəshi chwan, ka̱kul ibəshi yál chit, kang nfət te kà̱ mba̱l.
\v 32 Izangzəng jote, á vyap ka̱t, ka̱kul i ya ɓwop chit ka̱t.)
\p 
\v 33 Te uMusa re uFirona fa re ìtong, te uza̱ gha̱p oga awo wò ûYawe te, igbarman ká̱ aɗəɗal sat, iva̱r pə̀ng ka̱ apambin lap ka̱t.
\v 34 Kà̱ nva̱ngva̱ uFirona ya pa̱ iva̱r, ká̱ aɗəɗal, ká̱ igbarman sat chit, te uza̱ nəm nnap mɓá̱ngɓa̱ng kà̱ɗi, uza̱ twat ìgwak, uza̱ ká̱ okpari wò.
\v 35 Ìgwak aFirona twat, uza̱ yang ká̱ nre oIsa̱rila pa̱ á ga, dakdak wa nva uYawe ka̱ là ka̱ atak aMusa á.
\c 10
\s1 Nɗaktak ngga nna̱nne, mbankum
\p 
\v 1 Te uYawe là ûMusa pa̱, <<Ga atak aFirona, ka̱kul n nak ìgugwak chit twat ká̱ ìgwak okparikpari, ka̱kul na n nyám oga iya̱m iga nɗaktak mi va̱ ta̱ kà̱ ishimshe oza̱.
\v 2 N nəm iya̱m va̱ ta̱ ka̱kul na u shet ôvan ɓu ká̱ ôkəka ɓu nva̱ n nəm ká̱ oga aMasar pa̱ vyakshin ká̱ iya̱m iga nɗaktak va̱ n nəm ka̱ ashe oza̱, na o nyi pa̱ mmami na uYawe.>>
\p 
\v 3 Te uMusa ká̱ uHaruna ga atak áFirona là á na pa̱, <<Iya̱m va ta̱ uYawe, Inan oHiburu là, <I gbà̱ng wa nsang nna u yang ká̱ ǹyen ká̱ ishi ɓu á mi yà? Re onəm mi á ga ka̱kul na oza̱ a wop mi.
\v 4 Kang a yà pa̱ u yang ká̱ ǹre onəm mi pa̱ á ga te, nyi pa̱ ìpin te, mi ga nre ǹre ká̱ mbankum kà̱ mbin ɓu.
\v 5 Oza̱ i dàngchi apambin, unəm uro i ya mbin ka̱t. Te oza̱ i ri aɓo iya̱m va̱ re á wó kà̱ nva̱ng aɗəɗal, kang i ri nkpaktak ikun wó va̱ kà̱ ntə́p ka̱ ashe ǹzam.
\v 6 Oza̱ i yə́l oga ashe ǹzhi ɓu, ká̱ nkpaktak oga ashe ǹzhi okpari ɓu, ká̱ nkpaktak nzhi oga aMasar. OPo ɓu ká̱ okəka ɓu oma ya mbankum chit wa nva̱ ta ka̱t ka̱ ashe nra va̱ oza̱ ɓa ashe apambin ká̱, á ɓa chu nra nva̱ ta̱.> >> Te uza̱ ga̱ɓa̱n fa re mpyal aFirona.
\p 
\v 7 Te okpari áFirona ɓəp na pa̱, <<I gbà̱ng wa nsang uɓàng va̱ ta̱ i sat nɗaktak á yi yà? Re onəm va̱ ta̱ á ga ka̱kul pa̱ na oza̱ a wop uYawe, Inan oza̱. Nna u nyi chit pa̱ aMasar agúng ka̱t ɗò?>>
\p 
\v 8 Te mmá le nva̱ng ká̱ uMusa ká̱ uHaruna ka̱ atak áFirona. UFirona là ôza̱ pa̱, <<Ó ga ó wop uYawe Inan wó. Uda ká̱ uda i ga yà?>>
\p 
\v 9 UMusa là pa̱, <<Í ga nzəng ká̱ ovannza̱m ká̱ ónəmgbak, kang í ga ká̱ ovan yi onunggwan, ká̱ ochar, ká̱ oga iya̱m nkang ká̱ ína yi ka̱kul na i nəm awop aga nchang izər ûYawe.>>
\p 
\v 10 UFirona là pa̱, <<UYawe á yà nzəng ká̱ wó, a yà pa̱ n re wó o ga nzəng ká̱ ovan wó te, á nyám pa̱ nna ó yà ká̱ nrəng nggha ngga ka̱ ashe wó.
\v 11 Pa ka̱t. O re onunggwan má chwat á ga a wop uYawe, ka̱kul iya̱m va ta ó pak mɓəɓəp.>> Te mmá ɓak oza̱ re mpyal áFirona.
\p 
\v 12 Te uYawe là ûMusa pa̱, <<Yichi awo ɓu ka̱ apambin aMasar na oga mbankum á fa kà̱ mbin aMasar na á ri nkpaktak iya̱m nsuk va aɗəɗal ka̱ chwan ka̱t.>>
\p 
\v 13 Te uMusa yichi idari wò ka̱ apambin aMasar, kang uYawe nak nyə̀r ngga asa̱l awulum apyep kà̱ nkpaktak ilum iga nda va̱ ta ka̱ nkpaktak ìzwam. Anung ìpin ɓa te, nyə̀r ngga asa̱l awulum ɓa ká̱ oga mbankum.
\v 14 Mbankum ɓa dàngchi nkpaktak mbin aMasar, á ru kà̱ nkpaktak aswari mbin aMasar. Mmak mbankum ka̱ yà chit pa ka̱t, kang i yà pa lap ka̱t.
\v 15 Oza̱ dàngchi nkpaktak apambin nva̱ ta kang à nak mbin kpà̱r, kang oza̱ ri nkpaktak oga iya̱m nsuk, ká̱ nkpaktak awar ikún va̱ re kà̱ nva̱ng aɗəɗal. Iya̱m iga ndəng ipəpà iro yà re ka̱ izər ikún, ka̱t te iya̱m nsuk ka̱t, kà̱ nkpaktak mbin aMasar.
\p 
\v 16 UFirona re ǹre kà̱ uMusa ká̱ uHaruna pa̱ kəlak, á là pa̱, <<N nəm nnap mɓá̱ngɓa̱ng ûYawe, Inan wó, ká̱ wó.
\v 17 Ka̱kul nva̱ ta te, kusukkusuk, o chal uYawe Inan wó á yar nnap mɓá̱ngɓa̱ng á mi ka̱ awalang va̱ ta̱, ka̱kul na uza̱ á yar ikú va̱ ta̱ á le á mi.>>
\p 
\v 18 Te uMusa re uFirona á ga chal uYawe.
\v 19 Te uYawe ga̱ɓa̱n ayə́r wal nyə̀r ngga asa̱l awu ntar alum nkamkam pyep kang à wur oga mbankum swang ka̱ ashe Ìwá Ìsəksək. Ko mbankum nro re pa̱ nzəng ka̱t, ka̱ ashe nkpaktak mbin aMasar.
\v 20 Kang uYawe nak ìgwak aFirona twat, uza̱ re oIsa̱rila ga ka̱t.
\s1 Nɗaktak ngga nfangzəngtəng, atak akpá̱rkpà̱r
\p 
\v 21 Te uYawe là ûMusa pa̱, <<Yichi awo ɓu á ga apaɓur ka̱kul na atak akpá̱rkpà̱r á zəpchi mbin aMasar, nkpa̱r atak va mí dudok.>>
\v 22 Te uMusa yichi awo wò á ga apaɓur te, atak akpá̱rkpà̱r aɗinɗin á yà kà̱ nkpaktak mbin aMasar, nra pa̱ nshatɗing.
\v 23 Ko unəm uro pa̱ uzəng chu ǹya uwanwò ka̱t, á nəm nra pa̱ nshatɗing oza̱ wong ka̱ atak va̱ oza̱ kà̱ ka̱t. Káp ká̱ nna te, nkpaktak oIsa̱rila ka̱ ashe atak ghanghan ká̱ atak va̱ oza̱ təm kà̱.
\p 
\v 24 Te uFirona wór uMusa là á na pa̱, <<Ga, wop uYawe. Ovan wó kpa i gəga nzəng ká̱ wó, nnyi te, oga iya̱m nkang wó ka̱ ína nna byet i re kà̱ nva̱ng.>>
\p 
\v 25 Te uMusa là pa̱, <<Te ɓu na nləfər iya̱m ipápà ká̱ iga nshì pa̱ ɗwot á yi ka̱ awo kpa, na í na ûYawe, Inan yi.
\v 26 Iya̱m nkang yi i ga nzəng ká̱ yi kpa, ko ifir í re kà̱ nva̱ng ka̱t. Ka̱kul í wur iro ka̱ ashishe na í wop uYawe, Inan yi ká̱, te nna í nyi iya̱m va̱ chit í ga ngwop uYawe ká̱ ka̱t, ya í chu ka̱ ta kang.>>
\p 
\v 27 Te uYawe nak ìgwak áFirona twat, uza̱ ma̱n pa̱ o re oza̱ á ga ka̱t.
\v 28 UFirona là ûMusa pa̱, <<Wong fa le á mi ka̱ cho. Kang wa ma̱n wa ya asa̱l awu mi lap ka̱t. Ka̱kul ilum va̱ ɓu ya asa̱l awu mi te, ɓu kú.>>
\p 
\v 29 Te uMusa là pa̱, <<Wa nva u là. Mi yà ka̱ ǹya asa̱l awu ɓu lap ka̱t.>>
\c 11
\s1 Nɗaktak ngga ngba̱pchi, uyen ugəshi
\p 
\v 1 UYawe là ûMusa pa̱, <<Mi ga mɓa ká̱ nɗaktak kà̱ɗi pa̱ nzəng ka̱ apal aFirona ká̱ mbin aMasar. Kà̱ nva̱ng nva̱ ta te, uza̱ i re wó ó ga. Awalang va̱ uza̱ i re wó pa̱ ó ga te, uza̱ i ɓàk wó ó fa ka̱ ta̱.
\v 2 Ǹyangmata̱ nak ka̱ chwang oIsa̱rila là oza̱ pa̱, onunggwan ká̱ ochar á ɓəp iya̱m ìsham iga aazurfa ká̱ azənariya ka̱ atak oMasar, onəm oga nggɓa̱k oza̱.>>
\v 3 UYawe nak nchə̀r oza̱ bà̱l kà̱ mpyal oga aMasar. UMusa yà unəm uchumchum kà̱ mbin aMasar kà̱ ìwu okpari áFirona ká̱ onəm kpa.
\p 
\v 4 Te uMusa là pa̱, <<Iya̱m va ta̱ uYawe là, <Ká̱ ishimshe ìzwam te, mi watar ka̱ ashe mbin aMasar,
\v 5 kang nza̱ uyennunggwan nggo amar agəshi ka̱ ashe mbin aMasar i kú. I ɓàn ka̱ apal ayen ununggwan ugəshi áFirona, i ga i chu uyen ugəshi àyen uchar uzwal uva̱ ka̱ apal akò, ká̱ nza̱ amar ágəshi nggo aga iya̱m nkang.
\v 6 Te mí fe ayə́ng aga aɗor kà̱ nkpaktak mbin aMasar ava nna mmá ká̱ ya chit ka̱t, ka̱t te pa̱ nna mí ga ǹyiya lap ka̱t.
\v 7 Kang ka̱ atak nkpaktak oIsa̱rila te, ìva ìro ìswak unəm ka̱t, ka̱t te iya̱m nkang ka̱t, ka̱kul na o nyi pa̱ uYawe nyám nva̱n chit kà̱ ishimshe oga aMasar ká̱ oIsa̱rila.
\v 8 Nkpaktak okpari ɓu va̱ ta̱, oza̱ i fə́ng i kuchi kà̱ mpyal mi, i là pa̱, <<O fa mmaɓu ká̱ nkpaktak onəm va̱ i yar nva̱ng ɓu,>> kà̱ nva̱ng nva̱ ta te, mi ga.> >> Te ìgwak shì uMusa fa re atak áFirona.
\p 
\v 9 UYawe là ûMusa pa̱, <<UFirona i yà ká̱ nggwong achwang ká̱ wó ka̱t, ka̱kul pa̱ na ń nəm oga iya̱m iga nɗaktak ka̱ ashe mbin aMasar.>>
\v 10 UMusa ká̱ uHaruna nəm nkpaktak oga iya̱m iga nɗaktak va̱ ta̱ kà̱ mpyal áFirona, te uYawe nak ìgwak áFirona twat, te uza̱ re oIsa̱rila pa̱ á fa ka̱ ashe mbin wò ka̱t.
\c 12
\s1 ÌLum nggantal
\p 
\v 1 UYawe là nnap ká̱ ûMusa ká̱ ûHaruna kà̱ mbin aMasar pa̱,
\v 2 <<Apye va ta̱, i yà apye aga nggəshi á wó ka̱ ashe ìzun.
\v 3 Là nkpaktak mɓut ôIsa̱rila pa̱, kà̱ nra ngga ngba̱pchi ka̱ apye va̱ ta̱ te, nza̱ unəm nggo á kpán ìya iya̱m nkang\f + \fr 12.3 \fq ìya iya̱m nkang\ft : Ka̱ iHiburu te, ìya ìtam ka̱t te ìɓəl.\f* ka̱kul nza̱ ǹzhi nggo.
\v 4 Kang a yà pa̱ ashe ǹzhi va̱ yə́l kur nrì iya̱m nkang va̱ ta ka̱t te, re uza̱ á kap ka̱ unəm uga ngba̱k ǹzhi wò, ka̱ apal ìyəl onəm oga nrì iya̱m nkang va̱ ta kà̱ nza̱ ǹzhi nggo.
\v 5 Iya̱m nkang va̱ ta á yà inunggwan iga ìzun pa̱ ìzəng, ìtam ka̱t te ìɓəl, iva yà ká̱ mbyèt ka̱t.
\v 6 O nak ishi a ga chu nra ngga ngba̱pchi ama̱n pa̱ neɗing aga apye va̱ ta, te nkpaktak mɓut oIsa̱rila i pà iya̱m nkang va̱ ta ká̱ arurong.
\v 7 Te oza̱ i dok nchəchər í ɓàp kà̱ oga ndar ngga mparəm ngga oga anung nzhi ká̱ apal oga anung nzhi nva̱ oza̱ í ri kà̱.
\v 8 Oza̱ i ri ìzhe iwángwàng va̱ ta ká̱ ìzwam va ta, nzəng ká̱ nzəngkəng ngga ǹyà ká̱ anyer ka̱t ká̱ azang aɗúlɗul.
\v 9 Kang o ri iro ilulong, ka̱t te ipə́kpə́k ká̱ ndəng ka̱t. Ó wàng ká̱ pər, ishishi ká̱ oga mbwángbwáng, ká̱ oga iya̱mfu.
\v 10 Kang o re iro achu ìpin ka̱t. O shì ivəngva̱ le kang atak á tàn kà̱ ka̱t.
\v 11 Asa̱l va ta̱ o ri ká̱. O ran ilukwan wo ká̱ ngbat, akwap wo ka̱ ashar wo, kang idari wo ka̱ awo wo. O ri ká̱ ngha̱n, iya̱m-nrì áYawe iga nggantal.
\p 
\v 12 <<Te mi watar ka̱ ashe mbin aMasar ká̱ ìzwam va̱ ta, kang mi gbá̱ng nkpaktak amar aga nggəshi ka̱ ashe mbin aMasar, unəmləbər ká̱ iya̱m nkang, te mi gəl akwali nkpaktak oga inan iga aMasar. Mmami na uYawe.
\v 13 Nchə̀r va̱ o ɓàp ka̱ anung oga ǹzhi te, i yà iya̱m iga ǹnyám atak va̱ mmawó kà̱, a yà pa̱ n ya nchə̀r te, mi gantal wó. Nɗaktak ikú i dok wó ka̱t, kà̱ awalang va̱ n ləp aMasar á.
\p 
\v 14 <<Nra va̱ ta̱ i yà iya̱m iga nrəng ká̱, te ó nak na i yà nchang izər awop ûYawe ka̱ ashe nkpaktak nlwàk wó, o nak ishi ká̱ nnap nnəm va̱ ta̱ ghar mbyet.
\v 15 Nra pa̱ nfangshat o ri nzəngkəng nva mmá nəm ka̱ anyer ka̱t. Ka̱ apal nra ngga nggəshi te, o fa ka̱ anyer ka̱ ashe oga nzhi wó, ka̱kul unəm va̱ ari iya̱m iga anyer á ɓàn kà̱ nra ngga nggəshi ga chu ngga nfangshat te, mí tutur í fa ka̱ ashe aIsa̱rila.
\v 16 Mɓut nyə́ryər á yà ka̱ apal nra ngga nggəshi, kang mɓut nyə́ryər i yà kà̱ nra ngga nfangshat. Inok iro yà ó nəm ka̱ ashe oga nra va̱ ta ka̱t, ya nnəm iya̱m-nrì chwat pa̱ ko udanggo á ri, nna byet o nəm.
\p 
\v 17 <<Ó nəm nchang izər ngga nzəngkəng ngga ǹyà ká̱ anyer ka̱t, ka̱kul kà̱ ilum iva ta̱ n fa ká̱ nggatək wó ka̱ ashe mbin aMasar. O nak ishi ká̱ nnap nnəm va̱ ta̱ ghar mbyet ka̱ ashe oga nlwàk wó.
\v 18 Ka̱ ashe apye aga nggəshi, á ɓàn ká̱ arurong aga nra ngga ngba̱pchi ama̱n pa̱ neɗing ga chu arurong aga nra ngga ìsəm pa̱ iparəm ama̱n pa̱ zəng te, o ri nzəngkəng ngga anyer ka̱t.
\v 19 Ka̱kul nra pa̱ nfangshat mí ya anyer ka̱ ashe oga ńzhi wo ka̱t. Unəm va̱ kpaktak i ri iya̱m va̱ ka̱ anyer te, mí fa ká̱ na ka̱ ashe mɓut oIsa̱rila, uɗyanəm ka̱t te uyen uga mbin.
\v 20 Iya̱m va pa̱ káp mmá nəm ka̱ anyer te, a sat nkpak o ri ka̱t, kà̱ nkpaktak atak va̱ o təm kà̱ te, o ri nzəngkəng va yà ka̱ anyer ka̱t á.>>
\p 
\v 21 Te uMusa wór nkpaktak onəmgbak oga aIsa̱rila là ôza̱ pa̱, <<O ga, o yak ivan iya̱m nkang kang ô pà, na nzhi wó á nəm nchang izər ngga nggantal ká̱.
\v 22 Te o yar ìzuzul\f + \fr 12.22 \fq ìzuzul\ft : Ka̱ iHiburu te, apir ìkun iro iva mí ɓàp iya̱m ká̱.\f* o pá ka̱ ashe nchə̀r va̱ ka̱ ashe asu, ó ɓàp kà̱ oga ndar ngga mparəm ngga anung nzhi ká̱ apal anung nzhi ka̱ nchə̀r va̱ ka̱ ashe asu. Te nkpak kang uro ka̱ ashe wo á fa ka̱ anung ǹzhi ka̱t atak á tàn kang.
\v 23 Nva̱ngva̱ uYawe i watar pa̱ ô ləp oMasar, kang i ya nchə̀r kà̱ oga ndar ngga mparəm ngga anung nzhi ká̱ apal anung nzhi te, uYawe i gantal anung nzhi va̱ ta, kang i yà ká̱ ǹre unəm uga nzhì atak i tar nzhi wó pa̱ á ləp wó ka̱t.
\p 
\v 24 <<O nak ishi ká̱ nnap nnəm va̱ ta̱ ka̱kul ishi wo, ká̱ ovan onunggwan wo ghar mbyet.
\v 25 Nva̱ng nva̱ o chu mbin va̱ uYawe i ga nnəna a wo wa nva uza̱ là te, o ga mpyal ká̱ nnap nnəm va̱ ta̱.
\v 26 Awalang ava̱ ovan wó á ɓəp wó pa̱, <Iza̱ ìpir nnap nnəm va̱ ta̱ ka̱ atak wó yà?>
\v 27 te o là ôza̱ pa̱, <Nləfər iya̱m ipápà iga nggantal ûYawe, uva gantal oga nzhi oIsa̱rila ka̱ ashe aMasar, nva̱ uza̱ ləp oga aMasar kang uza̱ gar oga nzhi yi.> >> Te onəm kúchi nəm awop.
\v 28 Te oIsa̱rila nəm wa nva uYawe nak uMusa ká̱ uHaruna.
\p 
\v 29 Ká̱ ishimshe ìzwam te, uYawe ləp nkpaktak ovan onunggwan oga nggəshi ka̱ ashe mbin aMasar. Uza̱ ɓàn kà̱ uya aFirona ununggwan uga nggəshi uva təm ka̱ apal itok iponzhi, ghar ga chu uyennunggwan uga nggəshi anəm uga ashe ìkan uva̱ kà̱ nzhi ìkan, ká̱ nkpaktak ivan iya̱m nkang iga nggəshi.
\v 30 UFirona yenda̱l ka̱ ìzwam, ká̱ nkpaktak onəm ochumchum wò, ká̱ nkpaktak onəm oga aMasar, kang ayə́ng náp pa̱ bóbó ka̱ ashe mbin aMasar, ka̱kul ko nzhi nro pa̱ nzəng nva pa̱ unəm kú kà̱ ka̱t te á yà ka̱t.
\p 
\v 31 Te uza̱ wór uMusa ká̱ uHaruna ka̱ ashe ìzwam va̱ ta, á là pa̱, <<O wong, o fa ka̱ ashe onəm mi, nkpaktak wó ká̱ oIsa̱rila. O ga o wop uYawe, wa nva o chal á.
\v 32 O wur iya̱m nkang wó, ká̱ ína wó, na ó ga wa nva o chal. O nak nnap nnəna̱n á mi kpa.>>
\p 
\v 33 Oga aMasar sat atak onəm oga aIsa̱rila pa̱, oza̱ á fa pa̱ kəlak á re mbin va̱ ta, oza̱ là pa̱, <<Nkpaktak yi í ga nkú.>>
\v 34 Te onəm wur mmá̱k mɓitɓit nva yà ká̱ anyer ka̱t, ká̱ oga asu oza̱ aga nkál mmá̱k, lur oza̱ ka̱ ashe ilukwan, kang à wur ka̱ apal oga agar oza̱.
\v 35 Te oIsa̱rila nəm wa nva uMusa là, oza̱ ɓəp ilukwan, ká̱ oga iya̱m ìsham iga aazurfa ká̱ azənariya ka̱ atak oga aMasar.
\v 36 Te uYawe nak nchə̀r onəm va̱ ta̱ bà̱l ka̱ atak oga aMasar, te oza̱ na iya̱m va̱ óIsa̱rila ɓəp kà̱ oza̱. Wa nnà ta oza̱ vyat ndur oga aMasar ká̱.
\p 
\v 37 OIsa̱rila nəm achen ká̱ ashar, á ɓàn ka̱ aRamaset ga chu aSukkot. Ìyəl onunggwan ga wa ìkalong ìgba̱l pa̱ ìkpa̱ɗing. Mmá kung ovan ká̱ ochar ka̱t.
\v 38 Idonkong onəm oro pa̱ makmak ga nzəng ká̱ oza̱, ká̱ nggatək oga iya̱m nkang ká̱ ína pa̱ makmak.
\v 39 Oza̱ wàng nzəngkəng ká̱ mmá̱k mɓiɓit va̱ oza̱ fa ká̱ ka̱ aMasar, ka̱kul á yà ká̱ anyer ka̱t. Awalang va̱ mmá ɓak oza̱ fa ka̱ ashe aMasar te, oza̱ kali ka̱t, kang oza̱ nəm iya̱m-nrì iro ka̱kul ishi oza̱ ka̱t kpa.
\p 
\v 40 Ntəm onəm oga aIsa̱rila ka̱ aMasar nəm ìzun ìgba̱l pa̱ ìneɗing ka̱ ìsəm pa̱ ishatɗing.
\v 41 Kà̱ nkur ìzun ìgba̱l pa̱ ineɗing ká̱ ìsəm pa̱ ishatɗing va̱ ta, ká̱ nda va ta nkpaktak nggatək onəm áYawe fa ka̱ ashe mbin aMasar.
\v 42 Ìzwam va̱ uYawe pángchí ka̱kul na ó fa ká̱ oza̱ ka̱ ashe mbin áMasar, te nkpaktak oIsa̱rila ra nda ká̱ ìzwam va̱ ta ka̱t, ka̱kul nna ichumchum ûYawe ká̱, ka̱ ashe oga nlwàk ká̱ nlwàk.
\p 
\v 43 Te uYawe là ûMusa ká̱ ûHaruna pa̱, <<Oga nnap nnəm ngga nggantal nata̱, kang uɗyanəm á ri iya̱m-nrì iga nggantal ka̱t.
\v 44 Uzwal va̱ mmá yiyáp te, uza̱ i riri a yà pa̱ mmá pà ache á na chit á.
\v 45 Unəm va̱ mmá yar ka̱ inok mbwai, ká̱ unəmchən te, oza̱ i ri ka̱t.
\p 
\v 46 <<Mí ri kà̱ nzhi pa̱ nzəng. O yà ká̱ ǹyar ìzhe iro i fa agbai ka̱t, kang o ɓəkchi akúkup aro ka̱t.
\v 47 Nkpaktak mɓut oIsa̱rila í nəm nchang izər va̱ ta.
\p 
\v 48 <<A yà pa̱ unəmchən təm nzəng ká̱ wó kang á ɗom nnəm nggantal ûYawe te, re nkpaktak onunggwannunggwan á pà ache, nna chit te, uza̱ i nəm nggantal, te uza̱ i yà wa áyen uga mbin. Kang nza̱ ununggwan nggo uva̱ pà ache ka̱t te, i ri nggantal ka̱t.
\v 49 Nnap nnəm nzəngtəng va ta̱ i yà ka̱ apal áyen uga mbin, ká̱ unəmchən va̱ təm ka̱ ashe wó.>>
\p 
\v 50 Te nkpaktak oIsa̱rila nəm dakdak, wa nva̱ uYawe nak uMusa ká̱ uHaruna.
\v 51 Kang ká̱ nda va ta uYawe fa ká̱ oIsa̱rila ka̱ ashe mbin aMasar idonkong idonkong.
\c 13
\s1 Nggar uyennunggwan amar aga agəshi
\p 
\v 1 Te uYawe là ûMusa pa̱,
\v 2 <<Gar nkpaktak ovan onunggwan óIsa̱rila amar aga nggəshi á mi, ka̱kul nza̱ amar afu aga nggəshi anəmləbər, ká̱ iya̱m nkang te, i jem.>>
\p 
\v 3 Te uMusa là ônəm pa̱, <<O rəng ilum va̱ ta̱, iva o fa ká̱ ka̱ ashe mbin aMasar, nzhi izwal, ka̱kul uYawe à fa ká̱ wó ká̱ awo wò akamkam. O rəng, kang o ri iya̱m iga anyer ka̱t.
\v 4 N̂da va̱ ta̱, ka̱ ashe apye aAbip, mmawó kà̱ ngga nfa.
\v 5 Awalang va̱ uYawe ɓa ká̱ wo ka̱ ashe mbin oKanana, ká̱ oHiti, ká̱ oAmori, ká̱ oHivi, ká̱ oYebusi, nva uza̱ sóng anung ôpo wó pa̱ ò ga nna á wó, mbin va mbyal ká̱ mmàl irizhe i nang ka̱ ashishe, nkpak o nəm nnap nnəm va̱ ta ka̱ ashe apye va̱ ta̱.
\v 6 Nra pa̱ nfangshat o ri nzəngkəng ngga ǹyà ká̱ anyer ka̱t, kang kà̱ ilum iga ifangshat te, o nəm nchang izər ûYawe.
\v 7 O ri nzəngkəng ngga ǹyà ká̱ anyer ka̱t ka̱ ashe oga nra ngga nfangshat, kang mmá ya iya̱m iga anyer ka̱ ashe wó ká̱ nkpaktak aswari wó ka̱t.
\v 8 Kà̱ nra ngga nfangshat va̱ ta te, o là ipipir ôvan wó pa̱, <Ka̱kul iya̱m va uYawe nəm á yi kà̱ ilum va̱ í fa ká̱ ka̱ ashe aMasar.>
\v 9 Re á ta̱l á wó wa iya̱m iga nnyám ipir nnap ka̱ awo wó kang wa iya̱m iga nrəng ká̱ kà̱ isu wó, na á nak nnap mpakpak àYawe á yà ka̱ anung wó, ka̱kul uYawe fa ká̱ wó ka̱ ashe aMasar ká̱ awo akamkam.
\v 10 O kpak nnap nnəm nva̱ ta̱ ka̱ apal nra va mmá nak, nza̱ ìzun nggo.>>
\p 
\v 11 <<UYawe i ga mɓa ká̱ wó ka̱ ashe mbin oKanana, wa nva uza̱ sóng anung á wó ká̱ ôpo wó. Awalang va̱ uza̱ i na á wó te,
\v 12 o na nza̱ amar afu aga nggəshi nggo ûYawe. Nza̱ amar aga nggəshi iya̱m nkang inunggwan nggo te, i ji áYawe.
\v 13 Nza̱ amar azhaki aga nggəshi nggo te, ka̱m ishishi ká̱ iya̱m nkang, kang a yà pa̱ o ka̱m ishishi ka̱t te, o ɓəkchi ishishak. O ka̱mshi nza̱ amar áyen ununggwan uga nggəshi ánəmləbər nggo.
\p 
\v 14 <<Ka̱ ashe nra ngga mɓa te, uyen ɓu i ɓəp ɓu pa̱, <Iya̱m va̱ ta̱ ipipir iza̱ yà?> te là á na pa̱, <Ká̱ awo akamkam uYawe fa ká̱ yi ka̱ aMasar, nzhi izwal.
\v 15 Nva̱ngva̱ uFirona yang ká̱ nkak ishi pa̱ ò re yi í ga ka̱t te, uYawe gbá̱ng nkpaktak amar aga nggəshi onunggwan ka̱ ashe mbin aMasar, ɓàn ká̱ amar aga nggəshi ánəmləbər ká̱ aga nggəshi iya̱m nkang. Nna nak kang í pà amar afu aga nggəshi ûYawe, kang í ka̱mshi nkpaktak ovan onunggwan yi oga nggəshi.>
\v 16 Re á ta̱l á wó wa iya̱m iga nnyám ipir nnap ka̱ awo wó, kang wa iya̱m iga nrəng ká̱ kà̱ isu wó, ka̱kul uYawe fa ká̱ yi ka̱ ashe aMasar ká̱ awo wò akamkam.>>
\s1 Ǹdáng ìlulu ká̱ ǹdáng apər
\p 
\v 17 Nva̱ngva̱ uFirona re onəm va̱ ta ga te, Inan wòl ká̱ oza̱ ka̱ asa̱l va̱ watar ka̱ ashe mbin oFilitti ka̱t, káp ká̱ nva̱ nna asa̱l adatdat á. Ka̱kul Inan là pa̱, <<A yà pa̱ onəm á ya ìkum te, i ga̱ɓa̱n igwak oza̱, i le aMasar.>>
\v 18 Te uza̱ wòl ká̱ onəm ka̱ asa̱l aga ashe anyin ava wòl isu Ìwá Ìsəksək. Kang oIsa̱rila re aMasar wa nra izər ìkum.
\p 
\v 19 UMusa wur akup aYusufu ka̱ awo, ka̱kul uYusufu nak oIsa̱rila sóng anung pa̱, <<Nnandər Inan i ka̱mshi wó, te nkpak pa̱ o wur akup mi ká̱ wo o fa ká̱ ka̱ ta̱.>>
\p 
\v 20 Oza̱ wong ka̱ aSukkot oza̱ ga lə̀p apa̱k ka̱ aEtam ka̱ a ranchwang nzam.
\v 21 UYawe ləp mpyal óza̱ ka̱ ashe ǹdáng ìlulu ká̱ alum na ó kpak oza̱ ka̱ asa̱l, kang ká̱ ǹdáng apər ká̱ ìzwam pa̱ á ghan atak oza̱ ka̱kul na oza̱ á chen achen ìzwam ká̱ alum.
\v 22 Ǹdáng ìlulu ká̱ alum kà̱ mpyal onəm, kang ǹdáng apər ká̱ ìzwam kà̱ mpyal oza̱.
\c 14
\s1 Mpa̱l Ìwá Ìsəksək
\p 
\v 1 Te uYawe là ûMusa pa̱,
\v 2 <<Là ônəm oga aIsa̱rila pa̱, oza̱ a ga̱ɓa̱n oza̱ á lə̀p apa̱k kà̱ mpyal aFi-hahirot kà̱ ishimshe aMikdol ká̱ ìwá, oza̱ á lə̀p apa̱k á nak ìkwoksok ká̱ aBaal Zefon.
\v 3 Te uFirona i rəng pa̱, <OIsa̱rila kà̱ nránggang ka̱ ashe mbin, ká̱ nzwar kang ǹzam kuk oza̱ chit.>
\v 4 Te mi nak ìgwak aFirona i twat, uza̱ i ɓàk nva̱ng wó. Mí rup ká̱ mi ka̱ atak áFirona ká̱ nkpaktak onəm ikukum, te oga aMasar i nyi pa̱ mmami na uYawe.>> Te oIsa̱rila ga̱ɓa̱n pak apa̱k ka̱ ta wa nva uYawe là ôza̱.
\p 
\v 5 Awalang va̱ mmá là ûponzhi oga aMasar pa̱, oIsa̱rila chəng chit, te nrəng nnap áFirona ká̱ ókparikpari ga̱ɓa̱n ka̱ apal oza̱. Oza̱ là pa̱, <<Iza̱ í nəm ta̱ yà? Nna í re oIsa̱rila ga kang í lang onəm oga nnəm inok á yi á.>>
\v 6 Te uFirona gbar akeke ipəri wò kang à wur onəm ìkum wò nzəng ka̱ na.
\v 7 Uza̱ wur oga akeke ipəri anəna̱n igba̱l pa̱ ìkpa̱ɗing nzəng ká̱ aɓo akeke ipəri oga aMasar pa̱ kpaktak ká̱ onəm oga mpyal ìkum ka̱ apəpal.
\v 8 UYawe nak ìgwak aFirona uponzhi oga aMasar twat, kang uza̱ ɓàk nva̱ng oIsa̱rila, ova kà̱ nfa nzəng ká̱ nkam ìgwak.
\v 9 Nkpaktak ipəri aFirona ká̱ akeke ipəri ká̱ onəm oga nkwák ipəri, ká̱ onəm ìkum oga aMasar ɓàk nva̱ng oza̱. Oza̱ ɓàn oIsa̱rila lə̀p apa̱k ka̱ anung awang kà̱ ngba̱k aFi-hahirot kà̱ mpyal aBaal Zefon.
\p 
\v 10 Nva̱ uFirona kà̱ mɓa kang onəm oIsa̱rila wong ká̱ íwu ya oga aMasar kà̱ mɓa kà̱ oza̱ te, ayər nəm oza̱ pa̱ gənggəng kang oza̱ yə́ng ûYawe.
\v 11 Te oza̱ là ûMusa pa̱, <<Ka̱kul pa̱ atak nli onəm yà ka̱ aMasar ka̱t kang u fa ká̱ yi pa̱ na i kú ka̱ ashe anyin ɗò? Iza̱ u nəm á yi ta̱, u fa ka̱ yi ka̱ ashe aMasar yà?
\v 12 Iya̱m va ta̱ í là a ɓu ka̱ aMasar pa̱, <Re yi na í nəm inok oga aMasar> ka̱t ɗò? Ka̱kul á kapkap á yi pa̱, í nəm inok oga aMasar ká̱ nva̱ pa̱, í kú ka̱ ashe anyin.>>
\p 
\v 13 UMusa là ônəm pa̱, <<Kang ayər a nəm wó ka̱t, ó tong pa̱ kwák na ó dər nka̱mshi va̱ uYawe i ga mɓa ká̱ á wó nda va̱ ta̱. Onəm oga aMasar va̱ ó ya nda va̱ ta̱ te, ó yà ká̱ ǹya oza̱ lap ka̱t.
\v 14 UYawe i lung ìkum ka̱kul wó. Ó má̱ng pa̱ kwák.>>
\p 
\v 15 Te uYawe là ûMusa pa̱, <<Sang kang ɓu yə́ng á mi yà? Là ôIsa̱rila pa̱ oza̱ á yà kà̱ ngga.
\v 16 Mmaɓu te, gha̱p idari ɓu, yichi awo ɓu ka̱ apal ìwá, te i kap na oIsa̱rila á chen kà̱ ishimshe ìwá ka̱ apambin ngwomwom.
\v 17 Mmami nnyi te, mi nak ìgwak oga áMasar i twat, te oza̱ i táng kà̱ nva̱ng wó, kang mí rup ká̱ mi ka̱ atak áFirona, ká̱ nkpaktak onəm ikukum, ká̱ akeke ipəripəri, ká̱ onəm oga nkwák ipəripəri.
\v 18 Oga aMasar i nyi pa̱, mmami na uYawe, nva̱ngva̱ mí rup ká̱ mi ka̱ atak áFirona, ká̱ akeke ipəripəri, ká̱ onəm oga nkwák ipəripəri.>>
\p 
\v 19 UMa̱leka Inan, va̱ ka̱ yà kà̱ nchen kà̱ mpyal oIsa̱rila le ga asa̱l nsəm oza̱. Ǹdáng ìlulu le kà̱ mpyal oza̱ ga sat ka̱ asa̱l nsəm oza̱,
\v 20 kà̱ ishimshe onəm oIsa̱rila ká̱ onəm oga aMasar. Te ìlulu va̱ ta na atak akpá̱rkpà̱r kà̱ ngba̱k nro kang atak aghanghan kà̱ ngba̱k nro, kang unəm uro dat ká̱ uwanwò ka̱t, nkpaktak ìzwam.
\p 
\v 21 Te uMusa yichi awo wò ka̱ apal ìwá kang uYawe dà̱n ìwá ká̱ nyə̀r nkamkam ka̱ asa̱l awu alum nkpaktak ìzwam, te á nak ìwá kap re mbin ngwomwom.
\v 22 Kang oIsa̱rila chen kà̱ ishimshe ìwá ka̱ apambin ngwomwom, te ndəng nəm akamsəlang ka̱ awo ari ká̱ awo apəra̱m oza̱.
\p 
\v 23 Oga aMasar ɓàk nva̱ng oza̱ táng ashe ìwá, nkpaktak ipəri áFirona, ká̱ oga akeke ipəripəri, ká̱ onəm oga nkwák ipəripəri.
\v 24 Ká̱ iɓotak te, uYawe ka̱ ashe ǹdáng ngga apər, ká̱ ìlulu, á dər onəm ìkum oga aMasar te, á nak onəm oga aMasar ka̱ ashe nzwar.
\v 25 Te uza̱ ran ashar akeke ipəri oza̱ á nak nchəng ma̱t oza̱. Oga aMasar là pa̱, <<Re í chəng ka̱ atak oIsa̱rila ka̱kul uYawe kà̱ nlung ìkum ôza̱ ka̱ apal yi.>>
\p 
\v 26 UYawe là ûMusa pa̱, <<Yichi awo ɓu ka̱ apal ìwá na ndəng á ledok ka̱ apal oga aMasar, ká̱ oga akeke ipəri, ká̱ onəm oga nkwák ipəri.>>
\v 27 UMusa yichi awo wò ka̱ apal ìwá kang ká̱ ntàn atak te, ìwá le atak nva̱ng wò. Oga aMasar kà̱ nchəng pa̱ o fa te, uYawe gún onəm oga nnəm ìkum ka̱ ashe ndəng.
\v 28 Ndəng le nva̱ng gún akeke ipəri ká̱ onəm oga nkwák ipəri ká̱ nkpaktak onəm ìkum áFirona, va̱ ɓàk nva̱ng oIsa̱rila ka̱ ashe ìwá. Uro ka̱ ashe oza̱ le pa̱ uzəng ka̱t.
\p 
\v 29 OIsa̱rila chen ka̱ apambin ngwomwom kà̱ ishimshe ìwá, ndəng nəm akamsəlang ka̱ awo ari ká̱ awo apəra̱m oza̱.
\v 30 Nda va̱ ta te, uYawe fa ká̱ aIsa̱rila ka̱ awo oga aMasar, kang oIsa̱rila ya oga aMasar kú, ra ka̱ anung ìwá.
\v 31 Awalang va̱ oIsa̱rila ya inok ichumchum va̱ uYawe nəm ka̱ apal oga aMasar te, onəm nəm ayər aYawe, kang oza̱ na nnandər ká̱ uYawe kang ká̱ uzuzwal uMusa.
\c 15
\s1 Nnap nshì áMusa
\p 
\v 1 Te uMusa ká̱ ovan oga aIsa̱rila shì nnap-nshì va̱ ta̱ ûYawe pa̱,
\q1 <<Mi shì nnap-nshì ûYawe,
\q2 uza̱ kúkúr pa̱ mmá rup ka̱ na.
\q1 Ipəri ká̱ onəm oga nkúkwák
\q2 uza̱ swang ka̱ ashe ìwá.
\q1 
\v 2 UYawe uwa nggwanggwang mi nkamkam,
\q2 kang uwa nka̱mshi irirì mi.
\q1 Inan mi yà ta̱, kang mi shep na,
\q2 Inan apo mi, mi rup ka̱ na.
\q1 
\v 3 UYawe uwa unəm uga nlung ìkum,
\q2 aɗiɗin pa̱ uYawe.
\q1 
\v 4 Akeke ipəri áFirona ká̱ onəm ìkukum,
\q2 uza̱ swang ka̱ ashe ìwá.
\q1 Onənəm onəna̱n oga mpyal ìkum,
\q2 zhì ka̱ ashe Ìwá Ìsəksək.
\q1 
\v 5 Ngbà̱ng ìwá gún oza̱,
\q2 oza̱ zhip fa ga ìjili wa ipang.
\q1 
\v 6 Awo ari ɓu, áYawe,
\q2 ká̱ ìkam ìchumchum.
\q1 Awo ari ɓu, áYawe,
\q2 dəshin okpa ìkum.
\q1 
\v 7 Ka̱ ashe rup ichumchum ɓu,
\q2 u túng okpa ìkum ɓu,
\q1 u re ǹre ká̱ nfə́l ìgwak ɓu
\q2 kang à ri oza̱ wa akùkwa.
\q1 
\v 8 Ka̱ atak mɓur ǹyì ngga alúr ɓu te,
\q2 ìgum ndəng wong shàng.
\q1 Ndəng nnángnáng ɓut nchələng,
\q2 ngbà̱ng ndəng nə́k kà̱ ishimshe ìwá.
\q1 
\v 9 Ukpa ìkum là pa̱,
\q2 <Mi ɓàk oza̱, mi kpán oza̱,
\q1 mi wur idur oza̱,
\q2 ká̱ nkpaktak iya̱m iva̱ n ɗom.
\q1 Mi dapchi ndokchi mi,
\q2 kang awo mi nzhì oza̱.>
\q1 
\v 10 Te u ɓur ǹyì ɓu,
\q2 kang ìwá gún oza̱.
\q1 Oza̱ zhip wa acham aləbər
\q2 ka̱ ashe ìnang ìwá.
\q1 
\v 11 Uda wa nji ɓu, áYawe, ka̱ ashe oga inan yà?
\q2 Uda wa nji ɓu, ká̱ ichumchum iga iyə́ryər,
\q1 uga nəm ayə́r uva yə́l ká̱ ashep,
\q2 uva i nnəm iya̱m iga nɗaktak yà?
\q1 
\v 12 U yichi awo ari ɓu,
\q2 kang mbin ma̱ng oza̱.
\q1 
\v 13 Ka̱ ashe mma̱n ɓu ngga nnandər
\q2 u ləp mpyal ónəm va̱ u fa ká̱ oza̱,
\q1 ká̱ ìkàm u pángchí oza̱
\q2 ka̱ atak ntəm ɓu ayə́ryər.
\q1 
\v 14 Mbin fe te. Oza̱ tán,
\q2 kang ayər kpán oFilitti.
\q1 
\v 15 Oponzhi oga aEdom təm ká̱ nləp ìchəgwak,
\q2 ayər kpán onəm oga mpyal aMowap,
\q1 onəm oga aKanana sərak le,
\q2 
\v 16 ngga̱m ká̱ nləp ìchəgwak ru ka̱ apal oza̱.
\q1 Ka̱ atak ichumchum ìkàm ɓu
\q2 oza̱ sat pa̱ chə́k wa ipang
\q1 onəm ɓu watar kang, áYawe,
\q2 onəm va̱ u yáp watar kang.
\q1 
\v 17 U ɓa ká̱ oza̱ kang u ɓal oza̱ ka̱ apal aɓam ɓu,
\q2 áYawe, atak va u nəm ka̱kul ntəm ɓu,
\q2 anəm uga nzhi, Atak Ayə́ryər va awo ɓu pak.
\q1 
\v 18 UYawe i nəm ichumchum mbyet mbyet.>>
\s1 Nnap nshì aMiriya̱m
\p 
\v 19 Awalang va̱ ipəri áFirona, ká̱ akeke ipəri, ká̱ onəm oga nkwák ipəri táng ashe ìwá te, uYawe le nva̱ng ká̱ ndəng ìwá gún oza̱, kang oIsa̱rila chen kà̱ ìshimshe ìwá ka̱ apambin ngwomwom.
\v 20 Te uMiriya̱m uchar uga nlà ìchu Inan, ugənang aHaruna, yar akəshákkəshák ka̱ awo wò, kang nkpaktak ochar yar nvəva̱ng ká̱ akəshákkəshák ká̱ ngba̱p nza̱m.
\v 21 Te uMiriya̱m shì nnap-nshì óza̱.
\q1 <<Shì nnap-nshì ûYawe,
\q2 uza̱ kúkúr pa̱ mmá rup ka̱ na.
\q1 Ipəri ká̱ unəm uga nkúkwák
\q2 uza̱ swang ka̱ ashe ìwá.>>
\s1 Ndəng nɗuɗul
\p 
\v 22 Te uMusa dàp nkpánggang oIsa̱rila ka̱ anung Ìwá Ìsəksək, oza̱ ga ashe anyin aShur. Oza̱ chen ka̱ ashe anyin nra pa̱ nshatɗing, kang oza̱ ya ndəng ka̱t.
\v 23 Oza̱ ɓa aMara\f + \fr 15.23 \fq aMara \ft ìpir aMara ká̱ iHiburu na ta̱ pa̱ "nɗul"\f* te, ndədəng ma̱t oza̱ kà̱ ngwa ka̱kul á ɗuɗul.
\v 24 Te onəm lwang nnap ka̱ apal áMusa, i là pa̱, <<Iza̱ í wá yà?>>
\v 25 Te uza̱ yə́ng ûYawe kang uYawe nyám ìkun iro á na. Uza̱ kakchi mandar ka̱ ashe ndəng te, ndəng chàng.
\p UYawe nak nnap nnəm óza̱, kang uza̱ ma oza̱ ka̱ ta.
\v 26 Te uza̱ là pa̱, <<A yà pa̱ o gwong achwang pa̱ dakdak kà̱ ìchu aYawe Inan wó, kang o nəm iya̱m va inəna̱n kà̱ mpipyal, o nak achwang kà̱ oga nnap mpakpakpakpak, o kpak nkpaktak oga nɗiɗyang te, mi yà ká̱ nlə̀p wó ká̱ arwa va̱ ka̱ n lə̀p oga aMasar ká̱ ka̱t. Ka̱kul mmami uYawe uva tàn wó.>>
\p 
\v 27 Te oza̱ ɓa aElim, atak va oga acé aga mɓəl ndəng kà̱, pa̱ gba̱pchi ama̱n pa̱ parəm, ká̱ oga ikún akulom ìsəm pa̱ ifangshat, kang oza̱ lə̀p apa̱k ka̱ ta ka̱ anung ndəng.
\c 16
\p 
\v 1 Nkpaktak mɓut oIsa̱rila re aElim oza̱ ɓa ǹzam aSin va̱ ká̱ ishimshe aEləp ká̱ aSinayi, kà̱ nra ngga ngba̱pchi ama̱n pa̱ tukun ka̱ apye aga parəm kà̱ nva̱ngva̱ oza̱ re mbin aMasar.
\v 2 Nkpaktak mɓut oIsa̱rila lwang nnap ka̱ apal áMusa ká̱ uHaruna ka̱ ashe ǹzam.
\v 3 AIsa̱rila là óza̱ pa̱, <<Kàpkàp ká̱ í kú ka̱ awo áYawe kà̱ mbin aMasar, kà̱ nra nva̱ í təm ka̱ anung ngbət ìzhe kang í ri iya̱m-nrì kúr yi, kang o ɓa ká̱ yi ka̱ ashe ǹzam va̱ ta̱ na nkpaktak mɓut va̱ ta̱ á kú ká̱ ayang.>>
\p 
\v 4 Te uYawe là ûMusa pa̱, <<Mi ga npə̀ng nzəngkəng a wo ka̱ paɓuɓur, onəm i fa nza̱ ilum nggo kang i wur i kúr oza̱ nda va̱ ta. Ka̱ asa̱l va ta̱ mi mmá oza̱ mwote oza̱ i kpak nnap mpakpak mi ka̱t te i kpak ka̱t nggo.
\v 5 Ka̱ apal nra ngga nkpa̱ɗing, nva̱ oza̱ i ɗa̱mshi iya̱m va̱ oza̱ i ɓa ká̱ te, i mak i yà nva̱ng pa̱ mparəm wa nva̱ oza̱ mà wur kà̱ oga ilum.>>
\p 
\v 6 Te uMusa ká̱ uHaruna là ńkpaktak oIsa̱rila pa̱, <<Ká̱ arurong te ó nyi pa̱ uYawe àfa ká̱ wo ka̱ ashe mbin aMasar.
\v 7 Ká̱ ìpin te ó ya ìzhàn àYawe ka̱kul uza̱ fe nlwang nnap wo chit ka̱ apal áYawe. Ka̱kul mmayi oda kang o lwang nnap ka̱ apal ishi yi yà?>>
\v 8 UMusa là pa̱, <<UYawe i na ìzhe pa̱ o ri ká̱ arurong ká̱ nzəngkəng ka̱ ìpin pa̱ na ákur wo ka̱kul uYawe fe nlwang nnap va̱ chit o lwang ka̱ apal ishishi. Mmayi oda yà? Nlwang nnap wo ka̱ apal yi ka̱t ka̱ apal áYawe.>>
\p 
\v 9 Te uMusa là úHaruna pa̱, <<Là ńkpaktak oIsa̱rila pa̱ <O ɓa datkulung ká̱ mpyal àYawe, ka̱kul uza̱ fe nlwang nnap wo chit.> >>
\p 
\v 10 Nva̱ uHaruna là nnap ká̱ nkpaktak mɓut oIsa̱rila te, oza̱ ga̱ɓa̱n dər ìsu ǹzam, kang oza̱ ya ìzhàn àYawe fa ka̱ ashe ìlulu.
\p 
\v 11 UYawe là nnap ká̱ Musa pa̱,
\v 12 <<N fe nlwang nnap oIsa̱rila chit. Là óza̱ pá̱ <Ká̱ anungrurong te ó ri ìzhe, kang ká̱ ìpin te ó ri nzəngkəng i kúr wo. Te ó nyi pa̱ mmami uYawe, Inan wo.> >>
\p 
\v 13 Ká̱ arurong te, írəkpam wong gún apa̱k, kang ká̱ ìpin te ìmimyang ra gáng apa̱k.
\v 14 Ìmimyang wong ka̱ apal ǹzam ngwomwom te mmá ya iya̱m ro wa nzəngkəng ndátdàt ka̱ apambin.
\v 15 Nva̱ngva̱ oIsa̱rila ya te, oza̱ ɓəp owan oza̱ pa̱, <<Iza̱ ta̱ yà?>> Ka̱kul oza̱ nyi iya̱m ata ka̱t.
\p UMusa là óza̱ pa̱ <<Nzənkəng va uYawe na pa̱ o ri.
\v 16 Iya̱m va ta̱ uYawe là, <Nza̱ uzəngtəng wo nggo a ɓut á mal ká̱ ǹri wò. Yə́l ikpáng\f + \fr 16.16 \ft Ikpáng va̱ ka̱ yà mí mma aMana ká̱ te mí wór pa̱ <<Omer>> ká̱ iHiburu.\f* à nza̱ uzəngtəng nggo ka̱ atak ìyə̀l onəm oga ashe aghəghal.> >>
\p 
\v 17 Te oIsa̱rila nəm wa nnà ta. Oro ɓut pa̱ makmak oro ɓut pa̱ ɗa̱p.
\v 18 Nva̱ mmá ka̱ ikpáng iga mmáya̱m te, ka̱ udánggo ɓut kúr anung ǹri oza̱. Onəm va̱ ɓut pa̱ makmak te, á mak ji nkàm oza̱ ka̱t, kang onəm va̱ ɓut pa̱ ɗa̱p te áyen oza̱ ka̱t.
\p 
\v 19 UMusa là óza̱ pa̱, <<Kang unəm uro are ìpin akpa̱k kà̱ ka̱t.>>
\p 
\v 20 Te oza̱ gwong achwang kà̱ uMusa ka̱t, oro re aɓuɓo ìpin fa kpa̱k kà̱, kang áru izur anəng. Te ìgwak lak uMusa kà̱ oza̱.
\p 
\v 21 Nza̱ ìpin nggo oza̱ ɓut. Ko udánggo ka̱ anung ǹriri, alum sur te ásərak.
\v 22 Kà̱ nra ngga nkpa̱ɗing te oza̱ ɓut nzəngkəng ikpáng iga mmáya̱m pa̱ iparəm ka̱kul á nza̱ unəm nggo. Nkpaktak mɓut onəm oga mpyal ga là ûMusa.
\v 23 Uza̱ là óza̱ pa̱, <<Iya̱m va ta̱ uYawe là, <Ìpin ìkpa̱kkpà̱k te ilum njul, aSati ayə́ryər ûYawe. Ndata̱ te o wàng iya̱m va̱ o wàng, o pə́k iya̱m va̱ o pə́k, kang aɓo iya̱m va̱ le te o re íshiwo ka̱kul ìpin.> >>
\p 
\v 24 Oza̱ nak aɓuɓo chu ìpin ìkpa̱kkpa̱k wa nva̱ uMusa là, te anəng ka̱t kang izur yà ka̱ ashishe ka̱t.
\v 25 Te uMusa là pa̱ <<O ri aɓuɓo ata ńdata̱, ka̱kul ńdata̱ aSati ûYawe. O ya iya̱m ka̱ ashe ǹzam ka̱t.
\v 26 Ka̱ ashe nra pa̱ nkpa̱ɗing ó ɓut, kang kà̱ nra ngga ǹfangshat, aSati, iya̱m iro i yà ka̱t.>>
\p 
\v 27 Ká̱ nna te, kà̱ nra ngga nfangshat onəm oro fa ga pa̱ na o ɓut, kang oza̱ ya iya̱m ka̱t.
\v 28 Te uYawe là ûMusa pa̱, <<Igbà̱ng wa nsang o yang ká̱ nkpak nnap mpakpak mi ká̱ oga nɗyang mi yà?
\v 29 O dər, uYawe na ilum aSati a wo chit, ka̱kul nva̱ ta te uza̱ i na nzəngkəngg a wo ka̱kul nra pa̱ mparəm kà̱ nra ngga nkpa̱ɗing. Ko udánggo átəm ka̱ atak va uza̱ kà̱, kang unəm uro áre atak wò kà̱ ilum iga ìfangshat ka̱t.>>
\v 30 Te onəm jul kà̱ ilum iga ifangshat.
\p 
\v 31 Nzhi àIsa̱rila na aɗin iya̱m va̱ ta pa̱ amá na. Áfa izər ká̱ nzəngkəng kang à chàng na mmá nəm ká̱ izhin iləfər ká̱ mmàl irizhe.
\v 32 UMusa là pa̱, <<Iya̱m va ta̱ uYawe là, <Yə́l ikpáng ká̱ aMana na mmá gor ka̱kul oga nlwàk wo, na oza̱ á ya nzəngkəng va̱ n ri ká̱ wo ká̱ ka̱ ashe ǹzam nva̱ n fa ká̱ wo kà̱ mbin aMasar.> >>
\p 
\v 33 Te uMusa là ûHaruna pa̱, <<Yar ìɗyeri nak ikpáng amá na pa̱ izəng ka̱ ashishe. Te gor kà̱ mpyal àYawe ka̱kul oga nlwàk wo.>>
\p 
\v 34 Wa nva uYawe nak uMusa te, uHaruna nak kà̱ mpyal akwati aga nsar nnap-nlà ka̱kul na mmá gòr.
\v 35 OIsa̱rila ri amá na ìzun ìsəm neɗing, har oza̱ ɓa chu mbin va̱ oza̱ i təm kà̱. Oza̱ ri amá na har oza̱ ɓa chu aswari mbin aKanana.
\p 
\v 36 (Ikpáng iga mmá iya̱m pa̱ izəng mí wór ká̱ iHiburu pa̱, <<Omer>> nna uzəng ka̱ ashe agba̱pchi ka̱ ashe nkatəp\f + \fr 16.36 \ft Mí wór ká̱ iHiburu pa̱ <<ephah.>>\f*.)
\c 17
\p 
\v 1 Nkpaktak mɓut oIsa̱rila re ǹzam aSin, oza̱ nəm achen ka̱ apal nlà àYawe ága ləp apa̱k ka̱ aRefidəm, ka̱ ta te ndəng yà ónəm pa̱ áwá ka̱t.
\v 2 Te onəm kyep nnap-nlà úMusa pa̱, <<Na ndəng á yi na í wá.>> UMusa là óza̱ pa̱, <<Sang kang o kyep nnap á mi yà? Sang kang ó mmá uYawe yà?>>
\v 3 Ndəng gbá̱l onəm ka̱ ta, te ónəm lwang nnap ka̱ apal áMusa, oza̱ là pa̱, <<Sang kang u fa ká̱ yi ka̱ ashe aMasar pa̱ ú gbá̱ng yi ká̱ ovan yi ká̱ iya̱m nkang yi, ká̱ ndəng gbà̱l yà?>>
\v 4 Te uMusa yə́ng ûYawe pa̱, <<Iza̱ mi nəm ká̱ onəm va̱ ta̱ yà? I gbà̱ng ka̱t te oza̱ i kwan mi ká̱ ipáng>>
\v 5 UYawe là ûMusa pa̱, <<Watar mpyal ónəm va̱ ta te wur onəmgbak oIsa̱rila oro nzəng ká̱ ɓu. Yar idari va̱ u pàn aNilu ká̱ ka̱ awo na ú ga.
\v 6 Mi ga nsat ka̱ ta kà̱ mpyal ɓu ka̱ apal ipáng ka̱ aHorep, te ɓu pàn ipáng va̱ ta kang ndəng i fa ka̱ ashishe te onəm i wá.>> Te ûMusa nəm iya̱m va̱ ta kà̱ ìwú onəmgbak oga aIsa̱rila.
\v 7 Uza̱ wór atak ata pa̱ aMasak ká̱ aMeriba, ka̱kul oIsa̱rila kyep nnap, kang oza̱ ma uYawe, i là pa̱, <<UYawe uwa yà ka̱ ashe yi ɗò, ka̱t te yà ka̱t?>>
\p 
\v 8 OAmalek ɓa ru oIsa̱rila ká̱ ìkum ka̱ aRefidəm.
\v 9 UMusa là uJoshuwa pa̱, <<Yak onunggwan ayi, na o ga o lung oAmalek. Ìpin te mi ga nsat ka̱ apal aɗuktum ká̱ idari Inan ka̱ awo mi.>>
\v 10 Te uJoshuwa nəm wa nva uMusa là á na, uza̱ lung oAmalek. UMusa, uHaruna ká̱ uHur nnyi te kyen itəngtəng aɗuktum.
\v 11 Nva̱ngva̱ uMusa i gha̱p awo wò ka̱ apal te uIsa̱rila i nəm igwan, nva̱ngva̱ uza̱ i jul awo wò te uAmalek i nəm igwan.
\v 12 Kà̱ nva̱ngva̱ awo wom uMusa te oza̱ yar ìpang nak á na kang uza̱ təm ka̱ apəpal. Te uHaruna ká̱ uHur tə́p awuwo, uro ká̱ ngba̱k nro kang uro kà̱ nro te awuwo sat pa̱ kwák har alum ga tar.
\v 13 Te uJoshuwa ri uAmalek ká̱ onənəm ká̱ ndokchi.
\v 14 Te uYawe là ûMusa pa̱, <<Lir iya̱m va̱ ta̱ ka̱ apal awá na átəm iya̱m iga nrəng ká̱, te kung úJoshuwa, ka̱kul mi dəkən nrəng ká̱ oAmalek pa̱ chatchat ka̱vəng apaɓur.
\v 15 Te uMusa me atak nshì iya̱m awop kang à wór aɗiɗin pa̱ <UYawe Nissi\f + \fr 17.15 \ft UYawe uwa atani mi\f*,>
\v 16 te uza̱ là pa̱, <Gha̱p atani\f + \fr 17.16 \ft Ipipir fa ká̱ iHiburu pa̱ càk ka̱t\f* aYawe ka̱ apal.> UYawe i ga nlung oAmalek nlwàk ka̱ apal nlwàk.>>
\c 18
\p 
\v 1 UYeturo unəm uga mpyal awop oga aMidiyan, ugwar aMusa fe nkpaktak iya̱m va̱ Inan nəm úMusa ká̱ onəm wò oIsa̱rila, ká̱ asa̱l va̱ uYawe fa ka̱ oIsa̱rila ka̱ ashe aMasar.
\v 2 Nva̱ngva̱ uMusa nak uchar wò uZipora ga te uYeturo ugugwar ka̱m na
\v 3 nzəng ká̱ ovəvan pa̱ oparəm. (Aɗin áyen ugəshi pa̱ uGershom, ka̱kul uza̱ là pa̱, <<Mmami uɗyanəm kà̱ mbin nkak>>,
\v 4 Kang aɗin áyen uga uparəm pa̱ uEliyezer, ka̱kul uza̱ là pa̱, <<Inan àpomi ka̱mshi mi chit ka̱ atak ndokchi aFirona>>).
\v 5 Te uYeturo nzəng ká̱ uchar aMusa ká̱ ovəvan ɓa atak aMusa ka̱ ashe ǹzam ka̱ atak va̱ uza̱ ləp apa̱k kà̱ ka̱ aɓam Inan.
\v 6 Uza̱ nak ǹre ûMusa, <<Mmami uYeturo ugwar ɓu kà̱ mɓa atak ɓu ká̱ uchar ɓu ká̱ ovəvan pa̱ oparəm.>>
\v 7 UMusa fa ga nggwang ugwar wò, te uza̱ vàng ká̱ izər kang uza̱ má ǹjang á na. Oza̱ ɓəp ikángkáng owan oza̱ te táng aghal.
\v 8 UMusa shal úgwar wo ǹchatchat iya̱m va̱ uYawe nəm ûFirona ká̱ oga aMasar ka̱kul oIsa̱rila, ká̱ nkpaktak nɓəknung va̱ ya oza̱ ka̱ asa̱l, ká̱ asa̱l va̱ uYawe fa ká̱ oza̱.
\v 9 UYeturo lan ka̱kul nkpaktak iya̱m inəna̱n va̱ uYawe nəm oIsa̱rila nva̱ uza̱ fa ká̱ oza̱ ka̱ awo oga aMasar.
\v 10 UYeturo là pa̱, <<Nnap nnəna̱n təm nja aYawe. Uza̱ va fa ká̱ wo ka̱ awo oga aMasar ká̱ awo áFirona, kang àfa ká̱ onəm ka̱ atak ìkam oga aMasar.
\v 11 Ǹyangmata̱ n nyi chit pa̱ uYawe rup ji nkpaktak ínan ji, ka̱kul ǹva̱ uza̱ fa ká̱ onəm wò ka̱ atak onəm va̱ nəm nkak ishi óza̱.>>
\v 12 UYeturo ugwar aMusa ɓa ká̱ nləfər iya̱m ipápà ká̱ iga nshì pa̱ ɗwot Inan. Te uHaruna ɓa ká̱ nkpaktak onəmgbak oga aIsa̱rila na o ri ìya̱mnrì ká̱ ugwar àMusa ká̱ mpyal Inan.
\p 
\v 13 Ìpin fa kpa̱k te uMusa təm pa̱ na ó kat akwali ónəm, kang onəm tong gáng uMusa áɓàn ká̱ ìpin har arurong.
\v 14 Kà̱ nva̱ngva̱ ugwar aMusa ya nkpaktak iya̱m va̱ uza̱ kà̱ nnənəm ónəm te, uza̱ là pa̱, <<Ǹza̱ iya̱m ta̱ ɓu nəm ónəm yà? Sang mmaɓu ká̱ nkukwa kà̱ ntəm kang nkpaktak onəm tong gáng ɓu áɓàn ká̱ ìpin har arurong yà?>>
\v 15 UMusa là úgwar wò pa̱, <<Ka̱kul onəm ɓa atak mi pa̱ ń ɓəp Inan.
\v 16 A yà pa̱ oza̱ a yà ká̱ nɗaktak te oza̱ á ɓa atak mi, te mi kat ishimshe anəm ká̱ ùwangwò, kang mi ɗyang nnap nnəm Inan óza̱ ká̱ nɗiɗyang.>>
\v 17 Ugwar aMusa là á na pa̱, <<Iya̱m va̱ mmaɓu kà̱ nnənəm te aɓyen ka̱t.
\v 18 Ɓu ɓə́shì, mmaɓu ká̱ onəm va̱ nzəng ká̱ɓu ta̱, ka̱kul iya̱m ata̱ ji nkàm ɓu ji. U kúr nnənəm ká̱ nkukwa ɓu ka̱t.
\v 19 Gong achwang kà̱ ìchu mi ǹyangmata̱, mi na ichən a ɓu, te re Inan á yà nzəng ká̱ ɓu. Ɓu yà unəmsa̱l onəm kà̱ mpyal Inan, kang ɓu ga ká̱ oga nɗaktak oza̱ Ínan.
\v 20 Ɗyáng nnap mpakpakpakpak ká̱ nɗiɗyang ôza̱, kang ɓù nyám ôza̱ asa̱l va̱ oza̱ i təm ká̱ iya̱m va̱ oza̱ i nəm.
\v 21 Te yak ka̱ ashe nkpaktak onəm, onəm va kúkúr, oga nnəm ayər Inan, onəm oga nnandər, ova i yà ká̱ ajan nka̱m iya̱m iga mmulam anung. Te kyep ka̱ apal oza̱ onəm ochumchum oga íkalong, onəm ochumchum oga ìgbá̱l, onəm ochumchum oga ìsəm pa̱ ìtukun, onəm ochumchum oga ngba̱pchi
\v 22 Oza̱ i kat akwali ónəm nza̱ awalàng nggo. Nkpaktak nnap-nlà nchumchum te oza̱ i ɓa ká̱ a ɓu, kang nkpaktak nnap-nlà nkəla̱pkə̀la̱p te oza̱ á kat ká̱ ishi oza̱. Ná ákəla̱p a ɓu te oza̱ i yar a ɓu kà̱.
\v 23 A yà pa̱ u nəm iya̱m va̱ ta̱ wa nva Inan nak ɓu, te ɓu ya nkám ìgwak kang nkpaktak onəm va̱ ta̱ kpa i ga ǹzhi ká̱ ikángkáng.>>
\v 24 UMusa gwong achwang kà̱ ichu agwar wò kang à nəm nkpaktak iya̱m va̱ uza̱ là.
\v 25 Te uMusa yak onəm va kúkúr ka̱ ashe nkpaktak áIsa̱rila kang uza̱ nak oza̱ onəm oga mpyal ka̱ apal onəm, onəm ochumchum oga íkalong, onəm ochumchum oga ìgbá̱l, onəm ochumchum oga ìsəm pa̱ ìtukun, onəm ochumchum oga ngba̱pchi.
\v 26 Oza̱ i kat akwali ónəm nza̱ awàlàng nggo, nnap-nlà nɗəkɗək te oza̱ ga ká̱ ka̱ atak áMusa kang nnap-nlà nkəla̱pkə̀la̱p te oza̱ kat.
\v 27 Te uMusa re ùgwar wò, te uYetro kpán asa̱l ga mbin wò.
\c 19
\p 
\v 1 Ka̱ ashe apye aga shatɗing kà̱ nva̱ngva̱ oIsa̱rila re mbin aMasar, ká̱ nda va̱ ta oza̱ táng ǹzam aSinayi.
\v 2 Kà̱ nva̱ngva̱ oza̱ re aRefidəm te, oza̱ táng ǹzam aSinayi kang oza̱ ləp apa̱k ka̱ ashe ǹzam, te oIsa̱rila ləp apa̱k ka̱ ta kà̱ mpyal aɓàm.
\v 3 UMusa kyen ɓa ga atak Inan, te uYawe wór na ka̱ ashe aɓàm là pa̱, <<Iya̱m va ta̱ ɓu là ńzhi àYakup, kang ɓu là oIsa̱rila.
\v 4 <O yəya ká̱ ishi wo iya̱m va̱ n nəm oga aMasar, ká̱ asa̱l va̱ n wur wo ká̱ wa nva̱ nkumàngga̱p i wur ovan wò ka̱ apal abasəm kang n ɓa ká̱ ka̱ atak mi.
\v 5 Ka̱kul nva̱ ta te, a yà pa̱ o gwong achwang kà̱ ìchu mi pa̱ dakdak kang ó kpak nsar nnap nla mi te, o yà iya̱m mi iga anung anì ka̱ ashe nkpaktak onəm, ka̱kul nkpaktak apambin njem.
\v 6 Te o yà iponzhi onəm oga nshì iya̱m awop á mi, akum ayə́ryər.> Oga nnap-nlà va ta̱ ɓu là oIsa̱rila.>>
\p 
\v 7 Te uMusa ga wór onəmgbak onəm, uza̱ là nkpaktak oga nnap-nlà va̱ ta̱ kà̱ mpyal oza̱ wa nva uYawe nak na.
\v 8 Te nkpaktak onəm ma̱n ka̱ anung zəngtəng oza̱ là pa̱, <<Nkpaktak iya̱m va̱ uYawe là te í nənəm.>> Te uMusa le ká̱ nnap-nlà onəm uYawe.
\v 9 UYawe là úMusa pa̱, <<Dər, mi ga mɓa atak ɓu ka̱ ashe ìlulu ìɗinɗin, na onəm áfe awalang va̱ mi là nnap ká̱ ɓu te pa̱ ɗəkər oza̱ i na nnandər ká̱ ɓu.>> Ǹva̱ngva̱ uMusa là uYawe nnap-nlà va̱ onəm là,
\v 10 te uYawe là ûMusa pa̱, <<Ga atak onəm na ú gor oza̱ nda ta̱, kang ìpín te oza̱ i nàl ilukwan oza̱,
\v 11 te oza̱ á gbar izər kà̱ nra ngga nshatɗing, ka̱kul kà̱ nra ngga nshatɗing te uYawe i fə́r ka̱ apal aɓam aSinayi kà̱ ìwu nkpaktak onəm.
\v 12 Nak aswari á gáng pa̱ kpaktak ka̱kul onəm, là pa̱, <Ó nəm dakdak kang o kyen oga apal aɓam, ka̱t te o dok ìjilìjili ka̱t. Ko udánggo va̱ dòk aɓàm te uza̱ i kú ikúkú.
\v 13 Awo i dòk na ka̱t, ka̱ɗor nva̱ ta te mí kwan na ka̱t te mí tat, ka̱ iya̱m nkang ka̱t te unəmləbər i lár ka̱t.> Awalàng va̱ agbəshi ìtam i nap pa̱ gbá̱ngbá̱ng te, oza̱ i kyen i ga akum aɓàm.>>
\v 14 Te uMusa fə́r vàng ka̱ apal aɓàm ka̱ atak onəm kang àgor oza̱, te oza̱ nàl ílukwán oza̱.
\v 15 Uza̱ là ónəm pa̱, <<Ó gbar izər ka̱kul nra pa̱ nshatɗing, kang o dat ká̱ ochar ka̱t.>>
\v 16 Kà̱ nra ngga nshatɗing ka̱ ìpín te ìgbarman lə́p ká̱ amməlám, ká̱ ìlulu iɗəkɗək ka̱ apal aɓàm, ká̱ nnap agbəshi pa̱ gbá̱ngbá̱ng, kang nkpaktak onəm va̱ ka̱ ashe apa̱k tán.
\v 17 Te uMusa fa ká̱ onəm ka̱ ashe apa̱k na oza̱ agwang ká̱ Inan, te oza̱ tong ka̱ akum aɓàm.
\v 18 UYawe vàng ka̱ ashe apər ka̱ apal aɓam aSinayi te nggu gún nkpaktak apəpal. Nggugu wong apal wa nggu ngga achər ala acham, te nkpaktak aɓàm tán pa̱ gənggəng.
\v 19 Agbəshi ga mpyal ká̱ nnap pa̱ gbá̱ngbá̱ng te, uMusa là nnap kang Inan ma̱n á na ká̱ ìchu.
\v 20 Te uYawe fə́r ka̱ apal aɓam aSinayi, kà̱ ìtəngtəng aɓàm, kang uYawe wór uMusa kà̱ ìtəngtəng aɓàm, te uMusa kyen.
\v 21 UYawe là ûMusa pa̱, <<Fə́r gá na ú won onəm kang oza̱ a pa̱ng aɓa pa̱ o dər uYawe ka̱t, le kang mmákmak oza̱ atàk.
\v 22 Onəm oga mpyal awop kpa, oma i ɓa datkulung ká̱ uYawe te, nkpak pa̱ oza̱ ágor ishi oza̱ le kang uza̱ anyám mmən ìkum wò ka̱ apal oza̱.>>
\v 23 Te uMusa là uYawe pa̱, <<Onəm i yà ká̱ nkyen aɓam aSinayi ka̱t, ka̱kul u won yi pa̱, <Nak aswari ka̱ aɓàm na ú gor na.> >>
\v 24 Te uYawe là á na pa̱, <<Fə́r gá na ú kyen ú ɓa ká̱ uHaruna. Kang onəm oga ǹshi iya̱m awop ká̱ onəm a pa̱ng aɓa atak aYawe ka̱t, le kang uza̱ anyám mmən ìkum wò ka̱ apal oza̱.>>
\v 25 Te uMusa fə́r ga atak onəm là nnap óza̱.
\c 20
\s1 Oga Nnap mpakpak ngga Mgba̱pchi
\p 
\v 1 Te Inan là nkpaktak oga nnap-nlà va̱ ta̱.
\p 
\v 2 <<Mmami na uYawe, Inan ɓu va̱ fa ká̱ ɓu ka̱ ashe mbin aMasar, kà̱ nzhi izwal.>>
\p 
\v 3 <<Ɓu yà ká̱ ìnan iro watar mi ka̱t.
\p 
\v 4 <<Ɓu yà ká̱ nnəm ìchə̀r ìro ka̱kul ishi ɓu, mwote iga nfa izər ká̱ iya̱m iro ka̱ ashe apaɓur ka̱ apal, ka̱t te iva̱ ka̱ apambin ka̱vəng, ka̱t te iva̱ ka̱ ashe ndəng ka̱vəng ka̱t.
\v 5 Ɓu yà ká̱ nkúchi óza̱ ka̱t, ka̱t te ɓu wop oza̱, ka̱kul mmami uYawe Inan ɓu, mmami Inan iga ìkpar. Mi pyát mpat opon va yang mi ka̱ apal ovan ka̱ okəká, ka̱ okəká oga ntə́mbərə́ng.
\v 6 Nnyi te, mi nyám mma̱n ngga nnandər oga nlwàk ìkalong ova̱ ma̱n mi kang kà̱ nkpak nnap mpakpak mi.
\p 
\v 7 <<Ɓu yà ká̱ ǹwór aɗin áYawe, Inan ɓu ka̱ anungmwang ka̱t, ka̱kul uYawe i yà ká̱ ǹre nyám ntàn úka̱ udánggo va wór aɗiɗin ka̱ anungmwang ka̱t.
\p 
\v 8 <<Rəng ká̱ ilum aSati, gor na.
\v 9 Ɓu nəm inok ka̱ apal nra pa̱ nkpa̱ɗing te ɓu nəm nkpaktak inok ɓu.
\v 10 Nra ngga nfangshat aSati uYawe, Inan ɓu. Nkpak ɓu yà ka̱ nnəm inok iro ka̱t, mmaɓu, uyen ɓu ununggwan, ka̱t te uyenchar, uzwal ɓu ununggwan, ka̱t te uchar, iya̱m nkang ɓu, ka̱t te uɗyanəm va ka̱ anung nkəlang ɓu.
\v 11 Ka̱kul ka̱ ashe nra pa̱ nkpa̱ɗing uYawe nəm apa ɓuɓur ká̱ apambin, ìwá ká̱ nkpaktak iya̱m va̱ ka̱ ashe oza̱, te uza̱ jul ka̱ apal ilum iga ifangshat. Ka̱kul nva̱ ta te uYawe nak nnap nnəna̱n ílum aSati kang uza̱ gor na yà ìnəna̱n.
\p 
\v 12 <<Ná ichumchum úpo ɓu ká̱ unàng ɓu na ú yà ká̱ nra ǹganggang ka̱ apambin va̱ uYawe, Inan ɓu kà̱ nna a ɓu.
\p 
\v 13 <<Ɓu yà ká̱ ǹgbá̱l únəm ka̱t.
\p 
\v 14 <<Ɓu yà ká̱ nra uchar anəm ka̱t.
\p 
\v 15 <<Ɓu yà ká̱ nnəm ayi ka̱t.
\p 
\v 16 <<Ɓu yà ká̱ ǹshet nnap ngga akwam ka̱ apal áwan ɓu ka̱t.
\p 
\v 17 <<Ɓu yà ká̱ nnəm ìkpar ǹzhi àwanɓu ka̱t. Ɓu yà ká̱ nnəm ìkpar achar àwanɓu ka̱t, ka̱t te úzuzwal ununggwan ka̱t te uchar, ìnəna ka̱t te azhaki, ka̱t te ka̱ iza̱ nggo iva ija áwanɓu.>>
\p 
\v 18 Nkpaktak onəm ya aməlam ká̱ ìgbarman, nnáp agbəshi, kang aɓàm kà̱ ǹdung nggu. Ǹva̱ngva̱ onəm ya te, oza̱ tán kang oza̱ tong ǹdàchi.
\v 19 Te oza̱ là ûMusa pa̱, <<Là nnap ayi, te í gwong achwang. Kang wa re Inan á là nnap ayi ka̱t, ka̱t te í kú.>>
\p 
\v 20 UMusa là onəm pa̱, <<Kang ayər a nəm wo ka̱t, ka̱kul Inan vàng pa̱ na ô ma wo, na ayəyər á yà ka̱ apal wo ka̱kul na kang o nəm nnap mɓá̱ngɓa̱ng ka̱t.>>
\v 21 Te onəm tong ǹdàchi kang uMusa ga dat ká̱ atak akpá̱rkpà̱r va̱ Inan kà̱.
\v 22 Te uYawe là ûMusa pa̱, <<Iya̱m va ta̱ ɓu là oIsa̱rila, <O ya chit ká̱ ishi wo pa̱ n là nnap ká̱ wo ka̱ apaɓur.
\v 23 Kang o nəm oga inan iga aazurfa a ban ká̱ mi ka̱t, ka̱t te o nəm inan iga azənariya íshi wo ka̱t.> >>
\p 
\v 24 << <Ɓu me atak nshì iya̱m awop á mi aga amyè, te ɓu pà nləfər iya̱m inana ɓu iga nshì pa̱ ɗwot ká̱ iya̱m inana iga ntəm ikángkáng, ítam ɓu ká̱ ína ɓu ka̱ apəpal. Kà̱ nkpaktak atak va̱ n nak pa̱ mmá rəng ká̱ aɗin mi, mi ɓa atak ɓu kang mi nak nnap nnəna̱n a ɓu.
\v 25 A yà pa̱ ɓu me atak nshì iya̱m awop á mi ká̱ ipáng te, kang wa me ká̱ ipáng ikpákpà ka̱t ka̱kul ɓu ga̱ɓa̱n ìɗangsal ka̱ apəpal te, ɓu vyap na.
\v 26 Kang wa kyen atak nshì iya̱m awop mi ka̱ asa̱l akyenkyen ka̱t, le kang mmá ya imaləng ɓu.> >>
\c 21
\p 
\v 1 <<Oga nnap-akwali va ta̱ ɓu nak kà̱ mpyal oza̱.>>
\p 
\v 2 <<A yà pa̱ u yáp uzwal uHiburu te, uza̱ i nəm inok ìzun pa̱ ìkpa̱ɗing, kang kà̱ ìzun iga ifangshat te uza̱ i fa unəm ufənfən nzəng ká̱ amwa ka̱t.
\v 3 Kang a yà pa̱ uza̱ ɓa ká̱ nkukwa te uza̱ i ga ká̱ nkukwa, a yà pa̱ uza̱ ɓa ká̱ uchar te uchəchar i ga nzəng ka̱ na.
\v 4 A yà pa̱ unəm uga ǹzhizhi na uchar á na kang uza̱ mar ovan onunggwan ka̱t te ovan ochar á na te, uchar va̱ ta ká̱ ovan wò i yà oja anəm uga ǹzhizhi, te unəm va̱ ta i ga ká̱ nkukwa.
\v 5 Kang a yà pa̱ uzwal va̱ ta là pa̱, <N ma̱n unəm uga nzhi mi ma̱n, ká̱ uchar mi ká̱ ovan mi, n ɗom pa̱ ń ga wa anəm ufənfən ka̱t,>
\v 6 te unəm uga ǹzhizhi i ɓa ká̱ na ka̱ atak Inan\f + \fr 21.6 \ft onəm oga nnáp akwali\f*. Uza̱ i ɓa ká̱ na ka̱ anung ǹzhi ka̱t te kà̱ ndar ngga mparəm ngga anung ǹzhi kang unəm uga ǹzhizhi i tul achwang á na ká̱ mɓəmɓəm, te uza̱ i nəm inok á na mbyet mbyet.
\p 
\v 7 <<A yà pa̱ unəm yáp ká̱ uyen wò uchar yà uzwal te, uza̱ i yà ka̱ nfa wa ozwal onunggwan ka̱t.
\v 8 Kang a yà pa̱ unəm uga nzhizhi va yak na ka̱kul ishi wò, kang a ɗom na ka̱t te, uza̱ i re mí ka̱m ishishi. Uza̱ yá ka̱ ichumchum iga ǹyàp ka̱ na úɗyanəm ka̱t, ka̱kul uza̱ nəm ka̱ na chit pa̱ vyakshin.
\v 9 Kang a yà pa̱ uza̱ yak na ka̱kul ayen wò ununggwan te, uza̱ i nəm ka̱ na wa nva̱ nnap nnəm nyám pa̱ mmá nəm ká̱ ovan ochar.
\v 10 A yà pa̱ unəm va̱ ta yar ùkak kà̱ɗi ka̱kul ishi wò te, uza̱ i ya ká̱ nret iya̱m-nrì, ìlukwan ká̱ ngga atak nra kà̱ na ka̱t.
\v 11 Kang a yà pa̱ uza̱ i nəm iya̱m iga ishatɗing va̱ ta̱ á na ka̱t te, uza̱ i fa amwa aro yà ká̱ ka̱t.
\p 
\v 12 <<Nza̱ unəm nggo va̱ lə̀p unəm kú te, nkpak mí gba̱l na.
\v 13 Kang a yà pa̱ uza̱ nəm ká̱ avyal ka̱t, Inan re pa̱ á yà pa te, mi nak atak ro ka̱kul ɓu ava ɓu chər ɓu ga kà̱.
\v 14 A yà pa̱ unəm gúp uwangwò gba̱l ká̱ ntàn, kang uza̱ a ga a bwam ka̱ atak nshì iya̱m awop mi te, wa fa ka̱ na mmá gba̱l.
\p 
\v 15 <<Nza̱ unəm nggo va̱ lə̀p upo wò ka̱t te unàng wò te, mmá gba̱l na.
\p 
\v 16 <<Nza̱ unəm nggo va̱ kpán unəm ká̱ ayi, kang à yáp ka̱ na ka̱t te mmá ya ka̱ awuwo te, mmá gba̱l na.
\p 
\v 17 <<Nza̱ unəm nggo va̱ vyap upo wò ka̱t te unàng wò te, mmá gba̱l na.
\p 
\v 18 <<A yà pa̱ onəm gba̱ng anung kang uro lə̀p uwan wò ká̱ awo ka̱t te ká̱ ìpang, kang unəm uga aɓáng va̱ ta kú ka̱t, a ra kà̱ ìgban,
\v 19 kang a yà pa̱ uza̱ wong chen ra nggang ka̱ agbai ka̱ ìdari wò te, unəm va̱ lə̀p na te i fa ka̱ ashe mpat. Uza̱ i mwa nlak awalangwalang ka̱ ǹtətan pa̱ chatchat.
\p 
\v 20 <<A yà pa̱ unəm lə̀p uzwal wò ununggwan ka̱t te uchar ká̱ ìdari kang ùzwal va̱ ta kú ka̱ awuwo te, nkpak mí pyát á na.
\v 21 Kang a yà pa̱ uza̱ wong kà̱ nra ngga nzəng ka̱t te ngga mparəm te, mí pyát á na ka̱t ka̱kul uza̱ ǹdudur.
\p 
\v 22 <<A yà pa̱ onəm ka̱ ashe nlung ìkum, kang uro lə̀p uchar uga anyám te nak na wak, kang aɓang yà ka̱ ka̱t te, mí nak amwa á na iya̱m va uɓar achar va̱ ta ɗom ka̱tətak. Te uza̱ i mwa wa nva akwali nak.
\v 23 Kang a yà pa̱ aɓáng yiyà te, ɓu na irirì ka̱ anung irirì,
\v 24 ìwu ka̱ anung ìwú, inyin ka̱ anung inyin, awo ka̱ anung awo, ashar ka̱ anung ashar,
\v 25 nshì ka̱ anung nshì, mmətchi ka̱ anung mmətchi, aɓáng ka̱ anung aɓáng.
\p 
\v 26 <<A yà pa̱ unəm lə̀p ìwú úzwal wò ununggwan ka̱t te uchar kang a vyap ìwúwu te, uza̱ i re na i fa ka̱kul ìwúwu.
\v 27 Kang a yà pa̱ uza̱ lə̀p inyin azwal wò ununggwan ka̱t te uchar tutur te, uza̱ i re na i fa ka̱kul inyinyin.
\p 
\v 28 <<A yà pa̱ ìna ta̱p ununggwan ka̱t te uchar kú te, nkpak mí kwan ìna va̱ ta ká̱ ipáng kang izhizhe mí ri ka̱t, te unəm uga ìna i fa ka̱ ashe mpat.
\v 29 Kang a yà pa̱ ìna va̱ ta iga ǹtá̱p onəm kang mma won unənəm, káp ká̱ nna uza̱ pángchí ka̱t kang à gba̱l unəm ka̱t te uchar, te mí kwan ìna va̱ ta ka̱ ipáng kang mí gba̱l unənəm kpa.
\v 30 A yà pa̱ mmá nak amwa á na te, uza̱ i mwa ka̱ anung irirì wò pa̱ chur wa ǹva mmá nak á na.
\v 31 Ka̱ te a yà pa̱ ta̱p uyennunggwan ka̱t te uyenchar, te mí nəm ka̱ na ka̱ apal akwali azəngtəng va ta̱.
\v 32 Kang a yà pa̱ ìna ta̱p uzwal ununggwan ka̱t te uchar te, uza̱ i na ashekel ìsəm pa̱ ishatɗing aga azənariya unəm uga nzhizhi kang ìna va̱ ta mí kwan ká̱ ipáng.
\p 
\v 33 <<A yà pa̱ unəm bòl ache ka̱t te ɓok ache kang à gún ka̱t, te ìna ka̱t te azhaki ru ka̱ ashishe,
\v 34 te unəm uga ache va̱ ta i mwa akəkat, uza̱ i mwa mbubwai ûnənəm kang iya̱m nkang ikukù i yà ijini.
\p 
\v 35 <<A yà pa̱ ìna anəm uro nak aɓá̱ng ìna awang wò kang à kú te, oza̱ i yáp ká̱ ìna irirì te oza̱ i kap mbubwai, kang oza̱ i kap ìna ikukù kpa.
\v 36 Kang a yà pa̱ mmá nyi ìna va̱ ta nyi ká̱ ntá̱p atak kang ùnənəm pángchí ka̱t, te uza̱ i mwa akəkat pa̱ chur, ìna ka̱ anung ìna kang ikukù i yà ijini.>>
\c 22
\p 
\v 1 <<A yà pa̱ unəm nəm ayi ìna ka̱t te ìtam kang à pà ka̱t te á yáp ká̱ te, uza̱ i mwa ína pa̱ ítukun ka̱ anung ìna, kang ítam pa̱ íneɗing ka̱ anung ìtam.
\v 2 Kang a yà pa̱ mmá kpán uyi kà̱ nchwan atak kang mmá nə́m na mmá gba̱l te, mí mwo nchəchər ka̱ awo anəm uro ka̱t.
\v 3 A yà pa̱ mmá gba̱l na atak tàn chit te, mpat ǹtar nchə̀r nna yà. A yà pa̱ mmá kpán uyi va̱ ta te, uza̱ i mwa amumwa pa̱ chur, kang a yà pa̱ uza̱ yà ká̱ iya̱m iro ka̱t te, mí yáp ka̱ na ka̱kul ayiyi.
\v 4 A yà pa̱ mmá ya iya̱m ayiyi ka̱ awuwo ka̱ irirì, mwote ìna ka̱t te azhaki ka̱t te ìtam te, uza̱ i mwa ndán pa̱ mparəm.>>
\p 
\v 5 <<A yà pa̱ unəm kpak iya̱m nkang wò ka̱ ashe ìram ka̱t te iram ìba̱ngba̱ng, kang uza̱ re iya̱m nkang va̱ ta ga ashe iram anəm uro te, uza̱ i mwa amumwa ká̱ iya̱m inəna̱n iva ji iga ìrəram ka̱t te iga ìram ìba̱ngba̱ng ba̱ngba̱ng.
\p 
\v 6 <<A yà pa̱ apər fa rap ka̱ ashe ǹzam, te ri ikur iɓənɓən ká̱ itóngtong, ka̱t te ashe ìram, te unəm va̱ pá apər va̱ ta i mwa amumwa.
\p 
\v 7 <<A yà pa̱ unəm na mbwai ka̱t te iya̱m inok ûwan wò pa̱ á nak, te mmá nəm ayiyi ká̱ nzhi anəm va̱ ta, kang a yà pa̱ mmá kpán uyi va̱ ta te, uza̱ i mwa ndán pa̱ mparəm.
\v 8 A yà pa̱ mmá kpán uyi va̱ ta ka̱t, te mí ɓa ká̱ unəm uga nzhi va̱ ta ka̱ atak Inan na mmá dər a yà pa̱ uza̱ uwa wur iya̱m awang wò ka̱t nggo.
\v 9 A yà pa̱ ndap atam wong ka̱ apal nnap ìna, azhaki, ìtam, ìlukwan, ka̱t te iya̱m iro ilárlar iva̱ unəm uro là pa̱, <Ijəm ta̱,> te nnap-nlà nkpaktak oza̱ iga atak Inan. Unəm va̱ Inan i nak mpat á na te uza̱ i mwa ûwan wò ndán pa̱ mparəm.
\p 
\v 10 <<A yà pa̱ unəm na azhaki, ka̱t te ìna, ka̱t te ìtam, ka̱t te nza̱ iya̱m nkang nggo ûwan wò pa̱ á nak ishi ká̱, kang à kú, ka̱t te ka̱m aɓang, ka̱t te mmá kpán ka̱ ayi unəm uro ya ka̱t,
\v 11 te nsóng anung ká̱ uYawe i va̱n ishimshe mparəm oza̱, na a nyám pa̱ uza̱ dok iya̱m awang wò ka̱t. Te unəm uga iya̱m va̱ ta i ma̱n ká̱ kang uza̱ i mwa akəkat ka̱t.
\v 12 Kang a yà pa̱ nnandər mmá kpán iya̱m nkang va̱ ta ká̱ ayi ka̱ awuwo, te uza̱ i mwa akəkat ûnənəm.
\v 13 A yà pa̱ izhé iga anyin à kan te, uza̱ i ɓa ká̱ aɓuɓo na a nyám nnandərnandər, te uza̱ i yà ká̱ mmwa akəkat ka̱t.
\p 
\v 14 <<A yà pa̱ unəm ka̱m iya̱m nkang ka̱ atak áwan wò kang à ka̱m aɓáng ka̱t te á kú ká̱ na ûnənəm yà ka̱ ta ka̱t, te uza̱ i mwa akəkat pa̱ chur.
\v 15 Kang a yà pa̱ ùnənəm nzəng ká̱ na te uza̱ i mwa akəkat ka̱t. A yà pa̱ mmá ka̱m ka̱kul mbwai te mbwai va̱ mmá mwa te i təm ka̱ anunung.>>
\p 
\v 16 <<A yà pa̱ unəm tàng uyen ɓyen va̱ uwa nyi ununggwan chit ka̱t, ùva̱ unəm uro kà̱ nnəm ngya ká̱ ka̱t, kang à ra ka̱ na te uza̱ i mwa ndudur íshi wò i yà uchəchar.
\v 17 Kang a yà pa̱ upupo yang pa̱ kyàk ká̱ nna á na te, uza̱ i mwa ká̱ mbwai i mal dakdak ká̱ ìdur ayenɓyen ùva̱ nyi ununggwan chit ka̱t.
\p 
\v 18 <<Kang wa re uchar uga ishe á lár ka̱t.
\p 
\v 19 <<Unəm va̱ ra ká̱ iya̱m nkang te nkpak mí gba̱l na.
\p 
\v 20 <<Unəm va̱ na nləfər iya̱m pápà inan iro te mí zhì na, ya uYawe chwat.
\p 
\v 21 <<Kang wa mwar ka̱t te wa ka̱r uɗyanəm ka̱t, ka̱kul ka̱ o yà oɗyanəm kà̱ mbin aMasar.
\p 
\v 22 <<Kang o ɓək anung uchar ùkpələng ka̱t te uyen ùkpələng ka̱t.
\v 23 A yà pa̱ wa ɓək anung á na kang uza̱ yə́ng a mi te, nnandər mi fe ayiyə́ng aga mɓək anung,
\v 24 kang a shì ìgwak a mi te, mi gbá̱ng wo ká̱ ndokchi te ochar wo i yà okpələng kang ovan wo i yà okpələng.
\p 
\v 25 <<A yà pa̱ u na akat mbwai ónəm mi oga nkùn ka̱ ashe wo te, kang wa ram mmákmak kà̱ ka̱t.
\v 26 Kang a yà pa̱ u ka̱m ìlukwan àwan ɓu ka̱ apal pa̱ uza̱ i mwa kang te, le ká̱ á na kang alum ì tar,
\v 27 ka̱kul ìlukwan iga ndàng izəzər yà ta byet, te uza̱ i ra ka̱ ashe iza̱ yà? Kang a yà pa̱ uza̱ yə́ng á mi te mi fe, ka̱kul mmami uga aɗor.
\p 
\v 28 <<Kang wa pwat Inan ka̱t te wa vyap aɗin ánəm uga mpyal ka̱ ashe onəm ɓu ka̱t.
\v 29 Kang wa kali ká̱ iya̱mmɓən ká̱ ndəng ìba̱ngba̱ng ǹsámsàm ka̱t. Na ovan onunggwan ɓu oga nggəshi á mi.
\v 30 Wa nəm iya̱m izəngtəng ká̱ ina, itam ká̱ iɓəl ɓu. Oza̱ i nəm nra pa̱ nfangshat nzəng ká̱ ínang oza̱, kang kà̱ nra ngga nna̱nne te, wá na oza̱ á mi.
\v 31 Ó yà onəm ogorgor mi. Kang ô ri izhé iya̱m nkang va̱ izhé iga anyin kan ka̱t, o swang íva.>>
\c 23
\p 
\v 1 <<Kang wa zàl nnap-nlà ngga akwam ka̱t. Kang wa gwang awo ká̱ unəm unga, wa shet akwam ka̱t.
\v 2 Kang wa yar nva̱ng nggatək ka̱ ashe nnəm iya̱m inga ka̱t. Kang wa náp akwam ka̱ atak akwali ká̱ ngga̱ɓa̱n asəm ǹyàr nva̱ng nggatək pa̱ ávyap nnandər ka̱t.
\v 3 Kang wa nyám nɗom ishi únəm uga nkun ka̱ ashe akwalikwali ka̱t.
\p 
\v 4 <<A yà pa̱ u ya ìna ka̱t te azhaki ákpa ìkum ɓu lar te, wa le ká̱ á na.
\v 5 A yà pa̱ u ya azhaki ánəm uga ńyang ɓu ru ká̱ iya̱m iɗəkɗək kang u ɗom nnəm nka̱mshi ka̱t, te nkpak pa̱ ú ka̱m ishishi a wong ká̱.
\p 
\v 6 <<Kang wa ga̱ɓa̱n nnandər onəm ɓu oga nkun ka̱ ashe akwali oza̱ ka̱t.
\v 7 Wa gbà̱ng ká̱ nnap-nlà ngga akwam. Kang wa gbá̱l unəm uga ǹnyi nnap anəm nro ka̱t, ká̱ unəm ùnəna̱n ka̱t, ka̱kul mi yà ká̱ nlà pa̱ unəm unga unəna̱n ka̱t.
\v 8 Kang wa ka̱m imwa iga ǹmulam anung ka̱t, ka̱kul imwa iga ǹmulam anung i fo iwu onəm kang i vyap nnap-nlà onəm onəna̱n.
\v 9 Kang wa ka̱r uɗyanəm ka̱t, o nyi ntəm aɗyanəm nyi ka̱kul mmawó ká̱ ishi wo te, ka̱ o yà oɗyanəm ka̱ ashe mbin aMasar.
\s1 Nnap-mpakpak ka̱ apal ilum njul
\p 
\v 10 Ɓu suk ìram ɓu ìzun pa̱ ìkpa̱ɗing te ɓu ɓən iyəya̱m.
\v 11 Kang ka̱ ashe ìzun iga ifangshat te ɓu re i ra afəp, na onəm oga nkun ɓu á ri ka̱ ashishe kang ízhe iga anyin i ri aɓuɓo va̱ oza̱ re, wa nəm iya̱m izəngtəng ka̱ iram ìba̱ngba̱ng ɓu ka̱ iram mpyet ɓu.
\v 12 Ka̱ apal nra pa̱ nkpa̱ɗing ɓu nəm inok ɓu, te ɓu jul kà̱ nra ngga nfangshat na ìna ɓu ká̱ azhaki ɓu á yì, kang uya azwal ɓu uchar nzəng ká̱ uɗyanəm á yì.
\v 13 Wá nak ishi ká̱ nkpaktak iya̱m va̱ n là a wo. Kang o wór aɗin inan iro ka̱t, kang mmá fe aɗin oza̱ ka̱ anung ɓu ka̱t.
\p 
\v 14 <<Nva̱ng pa̱ nshatɗing ka̱ ashe ìzun te, ɓu nəm nchang izər á mi.
\v 15 Wa kpak nchang izər nzəngkəng ngga ǹyà ká̱ anyer \f + \fr 23.15 \fq Nchàng izər Ǹzənkəng ngga ǹyà ká̱ Anyer \ft The were written in lower chases, and they need chonsideration for upper chases as sen above. Feasts are to be in this form or not. \f*ka̱t wa nva n nak a ɓu. Wa ri nzəngkəng ngga ǹyà ká̱ anyer ka̱t, nra pa̱ nfangshat ká̱ awalang va mmá nak ka̱ ashe apye aga aAbip, o fa ka̱ ashe mbin aMasar ka̱ ashe apye va ta. Kang oza̱ a ɓa mpyal mi ká̱ awo alakchi ka̱t.
\v 16 Nəm nchang izər ngga mɓən iya̱m iga nggəshi ɓu va u suk ka̱ ashe iram. Nəm nchang izər ngga ngwur ikur kà̱ nkùr ìzun ká̱ awalang va̱ u ɓut iya̱m ngwap ɓu ka̱ ashe iram.
\v 17 Nva̱ng pa̱ nshatɗing ka̱ ashe ìzun, nkpaktak ovan onunggwan ɓu i ɓa mpyal aPoǹzhinan uYawe.>>
\p 
\v 18 <<Wa yichi nchə̀r nləfər iya̱m pápà a mi ká̱ iya̱m iro iga anyer ka̱t. Kang mpip nləfər iya̱m pápà iga nnəm nchang izər mi á kpa̱k ìpin ka̱t.
\p 
\v 19 <<Ɓa ká̱ oga awar ikún aga nggəshi va ɓyen ji aga ashe ìram ɓu ka̱ ashe ǹzhi aYawe, Inan ɓu. Kang wa pə́k ìya ìtam ka̱ ashe mbyal ìnənang ka̱t.
\p 
\v 20 <<Dər, mmami ká̱ ngga nre ǹre ká̱ uma̱leka kà̱ mpyal ɓu na apángchí ɓu ka̱ apal asa̱l kang ì ɓa ká̱ ɓu ka̱ atak va̱ n ɗa̱mshi chit.
\v 21 Nak ishi ka̱ na kang ɓu gwong achwang ká̱ ichəchu. Kang wa fa iya̱m ika̱k ká̱ na ka̱t, ka̱kul uza̱ i yà ká̱ ǹyàr mpat ɓu ka̱t, ka̱kul aɗin mi nna ka̱ ashishe.
\v 22 A yà pa̱ u kpak nnap nləlà pa̱ dakdak kang u nəm nkpaktak iya̱m va̱ n là te, mi yà unəm ìkum okpa ìkum ɓu kang mi yang onəm va̱ yang ɓu.
\v 23 Nva̱ngva̱ uma̱leka mí lə́p mpyal a ɓu i ɓa ka̱ ɓu ka̱ ashe oAmori, ká̱ oHiti, ká̱ oPerizi, ká̱ oKanana, ká̱ oHivi, ká̱ oYebusi, te mi zhì oza̱.
\v 24 Kang wa kuchi ínan oza̱, ka̱t te wa wop oza̱, ka̱t te wa ɗyang nnap nnəm oza̱ ka̱t. Ka̱ɗor nva̱ ta te wa kan oza̱ kang ɓu chwan oga ǹdáng ipáng oza̱ nyə́ryər pa̱ nyimənnyimən.
\v 25 O wop uYawe Inan wo, kang uza̱ i nak nnap nnəna̱n íya̱m nrì wo ká̱ ndəng wo, kang i yar arwa i le ka̱ ashe wo.
\v 26 Uchar ro i wak ka̱t, kang i yà usatsat ka̱ ashe mbin wo ka̱t. Mi na nra ngá nggang a ɓu.
\p 
\v 27 <<Mi ga kà̱ mpyal ɓu na nnak okpa ìkum ɓu á nəm ayər ɓu. Mi ɓa ká̱ nzwar onəm va̱ ɓu lung oza̱, kang mi nak oza̱ i ga̱ɓa̱n asəm i chəng ɓu.
\v 28 Mi re ǹre ká̱ iya̱m iga nzwar atak kà̱ mpyal ɓu i ɓàk oHivi, ká̱ oKanana, ká̱ oHiti kà̱ mpyal ɓu.
\v 29 Mi yà ká̱ mɓəɓak ká̱ mpyal ɓu pa̱ kpaktak ka̱ ashe ìzun pa̱ izəng ka̱t, ka̱t te mbin va̱ ta i yà ashe anyin te ízhe iga anyin i yə́l ka̱ ashishe i ji ɓu.
\v 30 Mi ɓàk oza̱ kà̱ mpyal ɓu pa̱ ɗa̱pɗa̱p, ɓu yə́l ɓu gang mbin va̱ ta kang.
\v 31 Mi nak aswari ɓu i ɓàn kà̱ Ìwá Ìsəksək i ga i chu ìwa iga aFilitti\f + \fr 23.31 \fq aFilitti \ft ìwa va mí wór pa̱ ìwa ìləbər a.\f* kang i ɓàn kà̱ ǹzam aSinayi i ga i chu awang aYufəriti. Te mi na onəm oga ashe mbin va̱ ta ka̱ awo ɓu, kang ɓu ɓàk oza̱ i fa kà̱ mpyal ɓu.
\v 32 Kang wa yar nsar nnap-nlà ká̱ oza̱ ka̱t te oga ichər oza̱ ka̱t.
\v 33 Kang oza̱ atəm nzəng ká̱ ɓu ka̱t, le kang oza̱ á nak ɓu wa nəm nnap mɓá̱ngɓa̱ng á mi, ka̱kul a yà pa̱ u wop ichər oza̱ te, i sat ajəp a ɓu.>>
\c 24
\p 
\v 1 Te uza̱ là ûMusa pa̱, <<Kyen ɓa atak mi, mmaɓu ká̱ uHaruna, ká̱ uNadap, ká̱ uAbihu, ká̱ onəmgbak oIsa̱rila va̱ ìsəm pa̱ ifangshat, o nəm awop ǹdatchi.
\v 2 UMusa uwa chwat á ɓa adatkulung ká̱ uYawe, kang oza̱ á ɓa adatkulung ka̱t, kang onəm á kyen á ga nzəng ka̱ na ka̱t.>>
\p 
\v 3 UMusa ga là ónəm nkpaktak nnap-nlà àYawe ká̱ oga nkpaktak nnap-akwali, te nkpaktak onəm ma̱n ká̱ ìchu pa̱ izəng pa̱, <<Nkpaktak nnap-nlà va̱ uYawe là te í nənəm.>>
\v 4 Te uMusa lir nkpaktak oga nnap-nlà àYawe. Uza̱ wong ká̱ iɓotak kà̱ ìpin ikpa̱kkpà̱k kang uza̱ me atak nshì iya̱m awop ka̱ akum aɓàm, te nak ǹdáng ipáng pa̱ igba̱pchi ama̱n pa̱ pa̱rəm ka̱ anung akum oIsa̱rila aga agba̱pchi ama̱n pa̱ aparəm.
\v 5 Te uza̱ re ovan ǹza̱m oga aIsa̱rila, oza̱ yichi oga iya̱m inana iga nshì pa̱ ɗwot kang oza̱ na nləfər iya̱m ipápà oga akut iga ntəm ikángkáng uYawe.
\v 6 Te uMusa tok nchə̀r ka̱ ashe asu, kang aɓo nchə̀r nro te uza̱ sháng ka̱ izər atak nshì iya̱m awop.
\v 7 Te uza̱ yar ǹlir ngga nsar nnap-nlà, uza̱ kung ónəm fe. Te oza̱ ma̱n pa̱, <<Nkpaktak iya̱m va̱ uYawe là te í nənəm kang í kpəkpak.>>
\v 8 UMusa yar nchə̀r sháng ka̱ apal onəm, uza̱ là pa̱, <<Dər, nchə̀r ngga nsar nnap-nlà va ta̱ uYawe nəm ká̱ wo ka̱ apal nkpaktak oga nnap-nlà va̱ ta̱.>>
\p 
\v 9 Te uMusa kyen gà ká̱ uHaruna, ká̱ uNadap, ká̱ uAbihu, ká̱ onəmgbak oIsa̱rila oga ìsəm pa̱ ifangshat va̱,
\v 10 te oza̱ ya Inan oIsa̱rila. Ka̱ avəng ashishar te iya̱m iro wa abərki nnəm ngga ipáng iɓyenɓyen iga ndəng izər ìvyau, wa atak ghanghan agbagba apaɓur.
\v 11 Inan nak awo wò ka̱ apal onəm ochumchum oga aIsa̱rila va̱ ta̱ ka̱t. Oza̱ ya Inan kang oza̱ ri oza̱ wa.
\p 
\v 12 UYawe là ûMusa pa̱, <<Kyen atak mi ka̱ apal aɓam na ú ta̱l ka̱ ta, ka̱kul na ń na oga achuchwal ìpang a ɓu, va n lir oga nɗyang ká̱ nnap mpakpak na ú ɗyang óza̱.>>
\v 13 Te uMusa wong ká̱ unəm uga nka̱mshi wò uJoshuwa, te uMusa kyen apal aɓam Inan.
\v 14 Uza̱ là ónəmgbak pa̱, <<O lòk yi ka̱ ta̱ kang i le atak wo. UHaruna ká̱ uHur oma yà nzəng ká̱ wo. Nkpaktak onəm va̱ ká̱ ǹdap atam te á ga atak oza̱.>>
\v 15 UMusa kyen apal aɓam kang ìlulu gún aɓàm.
\v 16 Ìzhàn àYawe təm ka̱ apal aɓam aSinayi, kang ìlulu gún na nra pa̱ nkpa̱ɗing. Ka̱ apal nra ngga nfangshat te, uza̱ wór uMusa ka̱ ashe ìlulu.
\v 17 Ìzhàn àYawe wa apər i ri ka̱ apal itə́ngtə́ng aɓam kà̱ ìwu oIsa̱rila.
\v 18 UMusa tar ashe ìlulu, kyen apal aɓam. UMusa təm ka̱ apal aɓàm nra ìsəm pa̱ ineɗing ká̱ ìzwam ìsəm pa̱ ineɗing.
\c 25
\p 
\v 1 Te uYawe là ûMusa pa̱,
\v 2 <<Là ónəm oIsa̱rila pa̱ á ɓa ka̱ iya̱m inana á mi. Nza̱ unəm nggo va̱ á yiyar ka̱ ashe ìgwak pa̱ o nəna te, uza̱ á ɓa ká̱ iya̱m inana wò.
\v 3 Oga iya̱m inana va ta̱ ɓu ka̱m ka̱ atak oza̱. Oma azənariya, aazurfa, ká̱ acham arəzang,
\v 4 ká̱ awulu va wa izər ìvyau, awulu va wa mba̱l akətəkəu arə́zang pa̱ ga̱r, ká̱ alinin va alukutlukut anəna̱n, ká̱ akpap iɓəl ka̱kul ìlukwan,
\v 5 awá inagám va mmá ɓán ká̱ ǹzazí ká̱ awa izhé iro anəna̱n, ká̱ akun akasiya,
\v 6 ká̱ mmì ka̱kul apitila, ká̱ oga iya̱m inə́ngnəng ichángchàng ka̱kul mmì ngga nggar kang ka̱kul iya̱m inəngnəng ichángchàng kpa.
\v 7 Ká̱ ipáng iza̱mza̱m, ipáng iga mɓam kà̱ izər ìya ìlukwan ìkwoksok, ká̱ ìlukwan ìkwoksok.
\p 
\v 8 <<N ɗom oza̱ pa̱ á me Atak Ayə́ryər á mi na ń təm nzəng ká̱ oza̱
\v 9 Nkpak pa̱ ú nəm aghal áYawe va̱ ta̱ ká̱ nkpaktak iya̱m iga ashishe á yà pa̱ dakdak á mal ká̱ ala̱ka̱n ava̱ mi gà ǹnyinyám a wo.>>
\p 
\v 10 <<Oza̱ á nəm akwati ká̱ akun akasiya ava ngwuwang ashar pa̱ shatɗing ká̱ aɓuɓo, mbəbal ashar pa̱ parəm ká̱ aɓuɓo, nrurup ashar pa̱ parəm ká̱ aɓuɓo.
\v 11 Wa ɓam nsəsəm ká̱ ashishe ká̱ azənariya anəna̱n wa rà̱p nza̱m ká̱ azənariya kà̱ nza̱ aranchwang nggo.
\v 12 Wa lá nkalɓang azənariya pa̱ nneɗing á gwang ka̱ ashishar kà̱ nza̱ ngba̱k nggo nkalɓang pa̱ mparəm.
\v 13 Nəm oga nkpá nggang ngga akun akasiya ɓəl izər oza̱ ká̱ azənariya.
\v 14 Mwak oga nkpá nggang va̱ ta ka̱ ashe nkalɓang va̱ nna ká̱ nza̱ ngba̱k akwati nggo ka̱kul nyiyar
\v 15 Oga nkpá nggang ngga nyiyar va̱ ta mí zə̀p ka̱t, mí re ká̱ izər nkalbang.
\v 16 Wa nak achuchwal nnap nshetshet nlìlir nva mi ga nnəna a ɓu ka̱ ashe akwati va̱ ta.
\v 17 Te wa nəm anung aga nkuk akwati va̱ ta ká̱ azənariya anəna̱n, ngwuwang ashar pa̱ shatɗing ká̱ aɓuɓo, mbə́bal ashar pa̱ parəm ká̱ aɓuɓo.
\v 18 Wa lá oga akerup\f + \fr 25.18 \fq aKerup \ft Iya̱m iga apaɓur ká̱ abasəm, iva i nyám ǹyà àYawe ká̱ ichumchumchumchum.\f* pa̱ parəm ká̱ azənariya, wá nak ka̱ apal anung aga nkukuk.
\v 19 Nəm akerup pa̱ zəng kà̱ ngba̱k nro kang aro kà̱ ngba̱k nzəntəng. Nəm oga akerup ka̱ anung aga nkukuk ká̱ azənariya azəngtəng va ta kà̱ nkùr oga aranchwangranchwang aga aparəm.
\v 20 Oga akerup va̱ ta i bol abasəm oza̱ i gún anung aga nkukuk, kang ì dər owan oza̱. Asa̱l awu oga akerup va̱ ta i dər anung aga nkukuk.
\v 21 Nak anung aga nkukuk va̱ ta ka̱ apal akwati, kang ɓù nak nnap nshetshet nva̱ mi ga nnəna a ɓu ka̱ ashe akwati va̱ ta.
\v 22 Ka̱ atak va ta mi gwang ká̱ ɓu, mi là nnáp ká̱ ɓu, ká̱ ishimshe oga akerup aga aparəm va̱ ka̱ anung aga nkuk akwati nnap nshetshet. Mi na oga nnap mpakpak a ɓu ka̱kul onəm oga aIsa̱rila.>>
\p 
\v 23 <<Te wa pak atebəl ká̱ akun akasiya ngwuwang ashar pa̱ shatɗing, mbəbal ashar pa̱ zəng ká̱ aɓuɓo, kang nrurup ashar pa̱ parəm ká̱ aɓuɓo.
\v 24 Ɓam ká̱ azənariya anəna̱n, kang ɓu rà̱p nza̱m oga aranchwangranchwang ká̱ azənariya.
\v 25 Nak ìɗər ka̱ aranchwangranchwang á yà wa mbal awo á gang, kang ɓu rà̱p nza̱m ká̱ azənariya.
\v 26 Nəm oga nkalɓang azənariya á na pa̱ nneɗing, na ú ɓáp oga nkalɓang va̱ ta kà̱ isu oga nggúlyanggú ngga neɗing va̱ ta ka̱ atak ashishar.
\v 27 Oga nkalɓang ngga nkpán nkpá nggang ngga ǹyàr atebəl va̱ ta á dat ká̱ ìɗər.
\v 28 Nəm oga nkpá nggang ká̱ akun akasiyá na ú ɓam izər oza̱ ká̱ azənariya. Te mí yar atebəl va̱ ta ká̱ omà.
\v 29 Nəm oga adakdai, ká̱ asu, ká̱ oga ibəchi, ka̱kul nna iya̱m inana iga ngwa. Nəm ká̱ azənariya anəna̱n.
\v 30 Nak nzəngkəng àYawe ka̱ apal atebəl kà̱ mpyal mi pa̱ ɗəkər.>>
\s1 Apitila aga Idari
\p 
\v 31 <<Nəm apitila aga idari ká̱ azənariya anəna̱n. La ìjilijili ká̱ idaridari, ká̱ oga ásusu, ká̱ mɓənggúmɓənggúm, ká̱ mbəba̱l á yà iya̱m pa̱ izəng.
\v 32 Oga igwong pa̱ ìkpa̱ɗing i yà kà̱ oga ngba̱k apitila aga ìdari pa̱ ishatɗing kà̱ ngba̱k nro, kang pa̱ ishatɗing kà̱ ngba̱k nzəngtəng.
\v 33 Oga asu pa̱ shatɗing wa mɓənggúm mba̱l i yà ka̱ apal ìgwong pa̱ ìzəng, pa̱ shatɗing kà̱ ìgwong ìro, wa nnà ta i yà kà̱ nkpaktak oga igwong iga ìkpa̱ɗing ka̱ igwong izər apitila aga idari.
\v 34 Oga asu pa̱ neɗing wa mɓənggum mba̱l ká̱ mba̱l i yà ka̱ apal apitila aga idari.
\v 35 Te mɓənggúm mba̱l á yà pa̱ zəng ka̱ akum ígwong pa̱ iparəm iga nggəshi, mɓənggúm mba̱l á yà pa̱ nzəng ka̱ akum ígwong pa̱ iparəm iga ipəpar, kang mbəngúm mba̱l ì yà pa̱ nzəng ka̱ akum ígwong pa̱ iparəm iga ishəshat, ka̱kul oga ígwong iga ìkpa̱ɗing va̱ ka̱ izər apitila aga ìdari.
\v 36 Oga mɓənggúm oza̱ ká̱ ígwong oza̱ á yà iya̱m pa̱ izəng. Nkpaktakkpaktak nlá azənariya anəna̱n.
\v 37 Nəm apitila pa̱ fangshat, te chwong oza̱ ka̱ apəpal na aghan atak kà̱ mpipyal.
\v 38 Te mɓəmɓəmɓəmɓəm ká̱ asu apər á yà ká̱ azənariya anəna̱n.
\v 39 Nəm apitila aga idari ká̱ nkpaktak oga iya̱m inok va̱ ta̱ ká̱ azənariya anəna̱n ava iɗəɗək ìsəm pa̱ ishatɗing.
\v 40 Nak ishi ká̱, na u nəm oza̱ á yà pa̱ dakdak á mal ká̱ ala̱ka̱n wa nva mmá nyám a ɓu ka̱ apal aɓam.>>
\c 26
\p 
\v 1 <<Nəm aghal aYawe ká̱ atani pa̱ gba̱pchi ava mmá lok ká̱ alinin anəna̱n, aga ndəng izər ìvyau, ká̱ ndəng nrəzang pa̱ gà̱r, ká̱ ndəng nrəzang. Nəm oza̱ á yà ká̱ ala̱ka̱n oga akerup ka̱ atak aghan anəm uga inok.
\v 2 Nwang atani va̱ ta á yà ashar ìsəm pa̱ ineɗing ama̱n pa̱ parəm, mbəbal ashar pa̱ kpa̱ɗing. Nkpaktak oga atani va̱ ta á mal izər.
\v 3 Gwang oga atani pa̱ tukun á yà pa̱ zəng, te gwang aɓo aga tukun á yà pa̱ zəng.
\v 4 Nəm oga mɓol ká̱ afini ndəng izər ivyau kà̱ nkur arangchwang aga ǹggəshi oga atani va̱ ta. Wa nnà ta kpa nəm oga mɓol kà̱ nkur azəngtəng arangchwang atani.
\v 5 Nəm oga mɓol ìsəm pa̱ ìtukun ka̱ izər atani azəngtəng, kang ɓù nəm oga mɓol ìsəm pa̱ ìtukun kà̱ nkùr aranchwang atani azəngtəng. Oga mɓol va̱ ta á mal ikwoksok ká̱ owan oza̱.
\v 6 Nəm oga iya̱m iga nzùzong ìsəm pa̱ ìtukun ká̱ azənariya, te gwang oga atani aga aparəm va̱ ta ka̱ anung zəngtəng ka̱ atak nzùzong, na aghal aYawe á yà pa̱ zəng.
\p 
\v 7 <<Kà̱p atani pa̱ gba̱pchi ama̱n pa̱ zəng ká̱ akpap íɓəl ka̱kul nkuk aghal aYawe.
\v 8 Nwang nza̱ atani nggo á yà ashar ìsəm pa̱ ineɗing ama̱n pa tuka̱n kang mbəbal ashar pa̱ kpa̱ɗing. Nkpaktak atani aga agba̱pchi ama̱n pa̱ zəng va̱ ta á mal izər.
\v 9 Gwang atani pa̱ tukun ka̱ anung zəngtəng, kang atani aga kpa̱ɗing ka̱ anung zəngtəng. Te kup atani aga akpa̱ɗing va̱ ta pa̱ mparəm á gún mpyal aghal.
\v 10 Nəm oga mɓol ìsəm pa̱ ìtukun ka̱ aranchwang atani azəngtəng, kang ɓù nəm oga mɓol ìsəm pa̱ ìtukun kà̱ nkùr aranchwang atani azəngtəng.
\v 11 Nəm oga iya̱m iga nzùzong ìsəm pa̱ ìtukun ká̱ acham arəzang, te mwak oga iya̱m iga nzùzong va̱ ta ka̱ ashe oga mɓol kang ɓù gwang aghal va̱ ta ka̱ anung zəngtəng na á yà pa̱ zəng.
\v 12 Te aɓo atani ava̱ le ka̱ apal aghal te i zong kà̱ nsəm aghal aYawe.
\v 13 Ashar pa̱ zəng ká̱ aɓuɓo kà̱ ngba̱k nro kang ashar pa̱ zəng ká̱ aɓuɓo kà̱ ngba̱k nzəngtəng. Oga aɓo ngwang atani aghal va̱ le te i zong kà̱ oga ngba̱k aghal aYawe na á gún na.
\v 14 Nəm iya̱m iga nggún apal aghal ká̱ awá pa̱ parəm, iro ka̱ awá inagám va mmá ɓán ka̱ ǹzazí, kang iro iga nggugún kà̱ awá anəna̱n.
\p 
\v 15 <<Kyen oga ndar aghal aYawe ngga akun akasiya aga nsat nzwang.
\v 16 Nza̱ nzəngtəng nggo ngwuwang á yà ashar pa̱ gba̱pchi ama̱n pa̱ tukun, mbəbal á yà ashar pa̱ parəm ka̱ aɓuɓo.
\v 17 Nza̱ ndar nggo te, á yà ká̱ ǹcà nggang pa̱ mparəm ka̱kul nggwang oza̱ ka̱ anung zəngtəng. Wa nnà ta ɓu kyen nkpaktak oga ndar aghal áYawe.
\v 18 Kyen oga ndar aghal áYawe va̱ ta ìsəm pa̱ iparəm ka̱kul ngba̱k ngga nkwandal.
\v 19 Te nəm oga atak mmùmwak ká̱ aazurfa ìsəm pa̱ ineɗing ka̱ avəng oga ndar ngga ìsəm pa̱ iparəm va̱ ta. Atak mmùmwak pa̱ mparəm ka̱ akum ndar ǹggəshi ka̱kul oga ncà nggangcà nggang, kang atak mmùmwak pa̱ mparəm ka̱ akum ndar ngga ngbəbak ka̱kul oga ncà nggangcà nggang.
\v 20 Nggba̱k ngga mpal aghal áYawe va̱ ta, wa nnà ta kpa oga ndar á yà ìsəm pa̱ iparəm,
\v 21 nzəng ká̱ atak mmwàk oza̱ ngga aazurfa ìsəm pa̱ ineɗing. Oga atak mmùmwak pa̱ mparəm ka̱ akum ndar ǹggəshi, kang oga atak mmùmwak pa̱ mparəm ka̱ akum ndar ngga ngbəgba̱k.
\v 22 Te kyen ndar aghal áYawe pa̱ nkpa̱ɗing ka̱kul ngba̱k ngga asa̱l ǹsəm.
\v 23 Kyen oga ndar pa̱ mparəm ka̱kul oga nggúlyanggú nsəm aghal áYawe.
\v 24 Ɓak oza̱ ka̱ akum á ɓa á chu apal na á yà ka̱ ashe nkalbang pa̱ nzəng. Wa nnà ta i yà ńkpaktak oza̱, oza̱ i yà nggúlyanggú pa̱ mparəm.
\v 25 Te ndar á yà pa̱ nna̱nne ká̱ oga atak mmwàk oza̱ ngga aazurfa pa̱ gba̱pchi ama̱n pa̱ kpa̱ɗing. Oga atak mmùmwak á yà pa̱ parəm ka̱ akum ndar ǹggəshi kang oga atak mmùmwak ì yà pa̱ mparəm ka̱ akum ndar ngga ngbəgba̱k.
\p 
\v 26 <<Kyen oga ndar nnárnàr ngga akun akasiya pa̱ ntukun ka̱kul oga ndar ngga ngba̱k aghal áYawe,
\v 27 ká̱ ndar nnárnàr pa̱ ntukun ka̱kul ndar ngga ngba̱k nzəngtəng, kang ká̱ nro pa̱ ntukun ka̱kul ndar ngga ngba̱k ngga asa̱l ǹsəm aghal áYawe.
\v 28 Ndar nnárnàr ngga ishimshe oga ndar i gantal kà̱ nkùr nro i ga i cú nkùr nro.
\v 29 Te ɓam oga ndar va̱ ta ká̱ azənariya, kang ɓù nəm oga nkalɓankalɓang ká̱ azənariyá na á kpán oga ndar nnárnàr va̱ ta. Ɓam oga ndar nnárnàr va̱ ta ká̱ azənariya.
\v 30 Pak aghal áYawe va̱ ta pa̱ dakdak wa nva mmá nyám a ɓu ka̱ apal aɓàm á.
\p 
\v 31 <<Nəm atani aga nkap afu ǹzhi aga ndəng ìzər ivyau, ka̱ ndəng nrəzang pa̱ gà̱r, ká̱ ndəng nrəzang, ká̱ alinin anəna̱n. Nəm ká̱ ala̱ka̱n oga akerup ka̱ atak aghan anəm uga inok u va̱ a nyi nchicà pa̱ gənggəng á.
\v 32 Zong atani va̱ ta ka̱ apal ǹdar akún akasiya ava mmá ɓam ká̱ azənariya, ká̱ iya̱m iga nzùzong iga azənariya ka̱ apal atak mmùmwak aga aneɗing aga aazurfa.
\v 33 Zong atani va̱ ta ka̱ akum oga iya̱m iga nzùzong, te tar ká̱ akwati aga nsar nnap-nlà ká̱ nsəsəm. Atani va̱ ta i kap ishimshe Atak Ayə́ryər ká̱ Atak Ayə́ryər ava ji.
\v 34 Nak anung aga nkuk akwati ka̱ apal akwati aga nsar nnap-nlà ka̱ ashe atak ayəryə́r ava ji.
\v 35 Yal atebəl kà̱ mpyal atani aga nkap afu ǹzhi ka̱ asa̱l mpal aghal áYawe, te yal apitila aga idari á mal ìkwoksok ká̱ atebəl ka̱ asa̱l nkwandal.
\p 
\v 36 <<Nəm atani aga anung asa̱l aghal áYawe ká̱ afini aga ndəng izər ìvyau, ká̱ ndəng nrəzang pa̱ ga̱r, ká̱ ndəng nrəzang, ká̱ alinin anəna̱n ava mmá lok ɓyen pa̱ gənggəng.
\v 37 Kyen oga ndar akún akasiya pa̱ ntukun te ɓam ká̱ azənariya ka̱kul atani va̱ ta. Iya̱m iga nzong oza̱ á yà iga azənariya, te nəm atak mmwàk óza̱ pa̱ ntukun ká̱ acham arəzang.>>
\c 27
\s1 Atak nshì Iya̱m Awop
\p 
\v 1 UYawe la uMusa pa̱, <<Nəm atak nshì iya̱m awop aga asu, mbəbal ashar pa̱ fangshat ká̱ aɓuɓo, ngwuwang ashar pa̱ fangshat ká̱ aɓuɓo. Atak nshì iya̱m awop va̱ ta á mal izər, te mməmak ashar pa̱ neɗing ká̱ aɓuɓo.
\v 2 Nəm agbəshi á na kà̱ nggulyanggugulyanggu ngga nneɗing, na oga agbəshi va̱ ta ká̱ atak nshì iya̱m awop á yà iya̱m zəngtəng. Ɓam na ká̱ acham arə́zang.
\v 3 Nəm oga asu nchwang, ká̱ ashefər, ká̱ asu, ká̱ ìga̱pchi ìga ifáng, ká̱ asu apər. Nəm nkpaktak iya̱m inok va̱ ta ká̱ acham arə́zang.
\v 4 Pàntal oga acham arə́zang á na wa alariya, te nəm oga nkalɓang ngga acham arə́zang kà̱ nza̱ nggúlyanggú ngga nneɗing nggo.
\v 5 Pá alariya va̱ ta ka̱ akum alə̀gər atak nshì iya̱m awop, ná á yà kà̱ nkap ishimshe atak nshì iya̱m awop.
\v 6 Nəm oga nkpá nggang ká̱ akún akasiya ka̱kul atak nshì iya̱m awop, te ɓam ká̱ acham arə́zang.
\v 7 Mwàk oga nkpá nggang va̱ ta ka̱ ashe nkalɓang, na oza̱ á yà ka̱ ngba̱k ngga mparəm ka̱ izər atak nshì iya̱m awop ka̱kul nyiyar.
\v 8 Nəm atak nshì iya̱m awop va̱ ta á yà awong ká̱ akún abalbal. Nəm na pa̱ dakdak wa nva mmá nyám a ɓu ka̱ apal aɓàm á.>>
\s1 Agəla̱n
\p 
\v 9 <<Nəm agəla̱n aghal aYawe. Nggba̱k nkwandal á yà ashar igba̱l ká̱ ìsəm pa̱ ìtukun, te atani á yà anəna̱n nlok alinin,
\v 10 Ká̱ oga ndar ngga acham arə́zang ìsəm pa̱ iparəm, ká̱ oga atak mmumwak aga acham arə́zang ìsəm pa̱ iparəm, kang ká̱ iya̱m iga nzuzong ká̱ iga nrəran ká̱ izər ndáng á yà iga aazurfa.
\v 11 Asa̱l mpal agəla̱n va̱ ta ngwuwang á yà ashar igba̱l ká̱ ìsəm pa̱ ìtukun na kpa, kang i yà ká̱ atani, ká̱ ndar ngga acham arə́zang ìsəm pa̱ iparəm, ká̱ atak mmumwak aga acham arə́zang ìsəm pa̱ iparəm, kang ká̱ iya̱m iga nzuzong ká̱ atak nrəran ká̱ izər ndáng iga aazurfa.
\v 12 Mbal atani ka̱kul agəla̱n ka̱ asa̱l ntar alum á yà ashar ìsəm pa̱ ifangshat ama̱n pa̱ tukun, ká̱ ndar pa̱ ngba̱pchi ká̱ atak mmwàk oza̱ pa̱ ngba̱pchi.
\v 13 Ka̱ asa̱l nfa alum agəla̱n te, mbəbal á yà ashar ìsəm pa̱ ifangshat ama̱n pa̱ tukun na kpa.
\v 14 Nwang atani á yà ashar ìsəm parəm ama̱n pa̱ parəm ká̱ aɓuɓo kà̱ ngba̱k anung asa̱l, ká̱ oga ndar pa̱ nshatɗing ká̱ atak mmumwak pa̱ nshatɗing.
\v 15 Te ngwang atani kà̱ ngba̱k nzəngtəng á yà ashar ìsəm pa̱ iparəm ama̱n pa̱ parəm ka̱ aɓuɓo, ká̱ oga ndar pa̱ nshatɗing ká̱ atak mmumwak pa̱ nshatɗing.
\v 16 Nwang atani aga anung asa̱l agəla̱n va̱ ta á yà ashar ìsəm pa̱ ishatɗing ava mmá lok ɓyen pa̱ gənggəng ká̱ afini alinin aga ndəng izər ivyau, ká̱ nrəzang pa̱ ga̱r, ká̱ nrəzang. Á yà ká̱ oga ndar pa̱ nneɗing ká̱ atak mmumwak pa̱ nneɗing.
\v 17 Nkpaktak oga ndar va̱ ka̱ ashe agəla̱n te, á yà ká̱ iya̱m iga nrəran ká̱ nzuzong iga aazurfa, ká̱ atak mmumwak ngga acham arəzang.
\v 18 Nwang agəla̱n va̱ ta á yà ashar igba̱l ka̱ ìsəm pa̱ ìtukun, mbəbal ashar ìsəm pa̱ ifangshat ama̱n pa̱ tukun, mməmak ashar pa̱ fangshat ka̱ aɓuɓo, ká̱ atani aga nlok ká̱ afini alinin anəna̱n, ká̱ atak mmumwak aga acham arəzang.
\v 19 Nkpaktak oga iya̱m inok aghal aYawe ka̱kul nza̱ inok nggo, ká̱ nkpaktak oga avan akun aga nrán aghal ká̱ oga avan akun agəla̱n á yà aga acham arəzang.
\p 
\v 20 <<Nak oIsa̱rila á ɓa ká̱ mmì mpyet nnəna̱n a ɓu ka̱kul apər, na apitila va̱ ta á yà kà̱ nnrì pa̱ ɗəkər.
\v 21 Ka̱ ashe Aghal Mɓut kà̱ nsəm atani ava kà̱ mpyal akwati aga nsar nnap-nlà te, uHaruna ká̱ ovan wò á nak ishi ká̱ apitila va̱ ta á yà kà̱ nrí pa̱ ɗəkər kà̱ mpyal aYawe á ɓàn ká̱ arurong á ga á chu ìpin. Nva̱ ta̱ á yà nnap nnəm ngga mbyet mbyet óIsa̱rila ka̱ ashe nkpaktak nlwàk oza̱.>>
\c 28
\s1 Iya̱m isham ANəm uga mpyal awop
\p 
\v 1 <<Ɓa ká̱ ùgənang ɓu uHaruna ká̱ ovəvan onunggwan ka̱ ashe oIsa̱rila á yà nzəng ká̱ ɓu, uNadap ká̱ uAbihu, uEleazar ká̱ uItama na ó nəm inok onəm oga mpyal awop á mi.
\v 2 Dán ílukwán íyə́ryər ugənnang ɓu uHaruna ka̱kul ìzhàn ká̱ iɓyen.
\v 3 Là nkpaktak onəm oga nnyi inok awo ova n yə́l oza̱ ká̱ aghan na oza̱ á dán ílukwán iga nggar uHaruna ka̱kul nnəm inok anəm uga mpyal awop á mi.
\v 4 Oga ilukwan va ta̱ oza̱ i dán, ìya ìlukwan ìkwoksok, ìlukwan ìkwoksok, ìlukwan iwángwang, ìlukwan iga ashe, iya̱m ishi, ká̱ ngbat. Oza̱ á dán ílukwán iyə́ryər va̱ ta̱ ugənang ɓu uHaruna ká̱ ovəvan onunggwan na oza̱ á nəm inok onəm oga ǹshi iya̱m awop á mi.
\v 5 Oza̱ á nəm ká̱ azənariya, ká̱ afini aga ndəng ízər ivyau, ká̱ nrəzang pa̱ gà̱r, ká̱ nrəzang, kang ká̱ alinin anəna̱n.>>
\s1 Ilukwan Ikwoksok
\p 
\v 6 <<Oza̱ á dán ìlukwan ìkwoksok va̱ ta, á lok ká̱ afini azənariya aga ndəng ízər ivyau, ká̱ nrəzang pa̱ gà̱r, ká̱ nrəzang, ká̱ alinin anəna̱n, inok ánəm uga aghan.
\v 7 Á yà ká̱ ngbat agar pa̱ mparəm ka̱ aranchwangranchwang aga aparəm ka̱kul nrəran.
\v 8 Nggbat ìlukwan ikwoksokkwoksok nloklok á yà nnəm nzəngtəng ká̱ afini azənariya aga ndəng ízər ivyau, ká̱ nrəzang pa̱ gà̱r, ká̱ nrəzang, kang ká̱ alinin anəna̱n.
\v 9 Wur ipáng iza̱mza̱m pa̱ iparəm te gyok aɗin ovan aIsa̱rila ka̱ apal oza̱.
\v 10 Aɗin á yà pa̱ kpa̱dəng ka̱ apal ipáng iro kang pa̱ kpa̱dəng ka̱ apal izəngtəng ka̱ atak inəmgbak oza̱.
\v 11 Gyok aɗin ovan áIsa̱rila ka̱ apal ipáng iga iparəm va̱ ta wa nva̱ unəm uga nkpà ipáng i gyok asitam. Mwak oza̱ ka̱ ashe iya̱m iga nkpəkpán iga azənariya.
\v 12 Ɓam oga ipáng iga iparəm va̱ ta ka̱ apal ngbat agar ìlukwan ìkwoksok wa ipáng iga nrəng ká̱ ovan áIsa̱rila. UHaruna á zong oga aɗin va̱ ta ka̱ apal agar wò kà̱ mpyal aYawe ka̱kul nrəng ká̱ oza̱.
\v 13 Nəm iya̱m iga nkpəkpán iga azənariya,
\v 14 ká̱ oga nzwar mmyarmyar pa̱ mparəm ngga azənariya anəna̱n. Te ran oga nzwar mmyarmyar va̱ ta ka̱ izər iya̱m iga nkpəkpán iga azənariya va̱ ta.>>
\s1 Mpuluk ngga apal Ilukwan Ika̱ksok
\p 
\v 15 <<Te dán mpuluk ka̱kul nva̱n nnap, inok ánəm uga aghan. Nəm wa ìlukwan ìkwoksok ká̱ azənariya, ká̱ afini aga ndəng izər ivyau, ká̱ nrəzang pa̱ gà̱r, ká̱ nrəzang, kang ká̱ alinin amyarmyar anəna̱n.
\v 16 Mma kùp te á mal izər, ngwuwang ká̱ mbəbal á yà mbal awo nza̱ ngba̱k nggo.
\v 17 Te dàt oga ipáng inəna̱n va̱ ta ǹzhi pa̱ nneɗing ka̱ pəpal. Ndàt nggəshi á yà ipáng irəzang va i ya atak pa̱ halakhalak, ká̱ iva̱ wa ndəng ilur, ká̱ iga ndəng ilyanggu.
\v 18 Ndàt ngga mparəm á yà ipáng va ká̱ nrezang, ká̱ iva̱ ikamkam, ká̱ iva̱ fəfər wa apye.
\v 19 Ndàt ngga nshatɗing á yà ká̱ ipáng iga ndəng ishan, ká̱ iva̱ wa ndəng agba̱k, ká̱ iva̱ irezang pa̱ ga̱r.
\v 20 Ndàt ngga nneɗing á yà ká̱ ipáng iga ndəng izər ivyau, ká̱ ipáng iza̱mza̱m, ká̱ iga ndəng ipəpa. Mwak oza̱ ka̱ ashe iya̱m iga nkpəkpán iga azənariya.
\v 21 Ípang iga igba̱pchi ama̱n pa̱ parəm va̱ ta ámal ka̱ anung aɗin ovan áIsa̱rila oga ogba̱pchi ama̱n pa̱ parəm. Nza̱ ipáng nggo te, mmá gyok aɗin akum pa̱ zəng ka̱ izəzər ka̱ ashe aga agba̱pchi ama̱n pa̱ parəm wa asitam.
\p 
\v 22 <<Myar oga nzwar ngga azənariya anəna̱n ka̱kul ìya ìlukwan ìkwoksok.
\v 23 Te nəm nkalɓang azənariya pa̱ mparəm, mwak ka̱ nggulyanggu ngga mparəm ngga apal ìya ìlukwan ìkwoksok.
\v 24 Mwak nzwar azənariya ngga mparəm va̱ ta ká̱ izər nkalɓang ngga mparəm va̱ kà̱ nggulyanggu ìya ìlukwan ìkwoksok.
\v 25 Te mwak ìjili nzwar ngga mparəm va̱ ta kà̱ izər iya̱m iga nkpəkpán iga azənariya. Mwak ka̱ mpyal ngbat agar ìlukwan ìkwoksok.
\v 26 Nəm oga nkalɓang azənariya pa̱ mparəm kà̱ɗi, te mwak oza̱ ka̱ ashe ka̱ avəng nggulyanggu ngga mparəm ngga ìya ìlukwan ìkwoksok.
\v 27 Nəm nkalɓang nkak kà̱ɗi ngga zənariya pa̱ mparəm, te mwak oza̱ ka̱ akum ngbat agar ìlukwan ìkwoksok ká̱ nzwar kà̱ mpipyal á dat ka̱ atak ngugwang.
\v 28 Te ran nkalɓang ngga izər ìya ìlukwan ìkwoksok ká̱ izər nkalbang ngga izər ìlukwan ìkwoksok ká̱ asang aga ndəng izər ivyau, á yà ka̱ apal ngbat ìlukwan ìkwoksok ka̱kul na á kpán ìya ìlukwan ìkwoksok kang a yok ka̱t.
\v 29 Te uHaruna i yar aɗin ovan aIsa̱rila ka̱ apal ìya ìlukwan ìkwoksok ngga nva̱n nnap kà̱ ìkwoksok wò, awalang va̱ uza̱ i tar Atak Ayə́ryər ka̱kul nva̱n nnap kà̱ mpyal aYawe pa̱ ɗəkər.
\v 30 Nak aUrim ká̱ aTummim ka̱ ashe ìya ìlukwan ìkwoksok iga nva̱n nnap. Oza̱ á yà kà̱ ìkwoksok aHaruna awalang va̱ uza̱ i tar mpyal aYawe. Wa nnà ta uHaruna i yar oga iya̱m va̱ ta pa̱ ɗəkər ka̱kul nva̱n nnap ka̱ apal oIsa̱rila kà̱ mpyal aYawe.
\v 31 Dán ìlukwan iwángwang iga avəng ìlukwan ìkwoksok á yà ndəng izər ivyau.
\v 32 Á yà ká̱ atak mpa ishi kà̱ ishimsheshimshe, lok ishishak ka̱kul kang acha ka̱t.
\v 33 Ka̱ anunung ka̱ avəng te, nəm oga awar ìkúmkúm iga ndəng izər ivyau, ká̱ nrəzang pa̱ ga̱r, ká̱ nrəzang a gang anunung aga avəvəng ká̱ oga iɓa̱ngga̱ng azənariya kà̱ ishimshe oza̱.
\v 34 Dàt oza̱, awar ìkúmkúm i le te iɓa̱ngga̱ng azənariya, i le te awar ìkúmkúm, i le te iɓa̱ngga̱ng azənariya, wa nnà ta á ga agang avəvəng pa̱ lat.
\v 35 UHaruna i pá ìlukwan iwángwang va̱ ta̱ awalang va̱ uza̱ kà̱ nnəm inok, kang mí yà kà̱ nfe nnənap nva̱ngva̱ uza̱ tar ashe atak ayəyər kà̱ mpyal aYawe ká̱ nva̱ngva̱ uza̱ i fa, ka̱kul kang uza̱ a kú ka̱t.
\p 
\v 36 <<Nəm achuchwal aga azənariya anəna̱n, te gyok na wa nggyok asitam, <Unəna̱n ûYawe.>
\v 37 Te ran ka̱ izər iya̱m ishi ká̱ asang aga ndəng izər ivyau, á yà kà̱ mpyal iya̱m ishi.
\v 38 Á yà kà̱ isu uHaruna, kang uHaruna i yar nkpaktak mpat ka̱ atak nná oga iya̱m inana inəna̱n va̱ oIsa̱rila gar ka̱ ashe imwa oza̱ inəna̱n. Á yà kà̱ isu aHaruna pa̱ ɗəkər ka̱kul na iya̱m inana á yà iya̱m ikángkáng ka̱ atak aYawe.
\v 39 Dán ìlukwan iga ashe ká̱ afini alinin anəna̱n, lok iya̱m ishi ká̱ afini alinin anəna̱n, te Kà̱p ngbat á yà inok ánəm uga nzəza̱m.
\v 40 Dán ílukwan iga ashe, kà̱p oga ngbat ká̱ oga iya̱m ishi óvan aHaruna. Dán oza̱ ka̱kul ìɓyen ká̱ ìzhàn.
\v 41 Nva̱ngva̱ u mwak ilukwan va̱ ta̱ chit ûHaruna ugənang ɓu ka̱ ovəvan onunggwan, te gor oza̱, nak awo óza̱, na oza̱ á yà o gargar kang oza̱ i nəm inok onəm oga mpyal awop á mi.
\v 42 Dán iya̱m aɗək iga afini alinin iva ikùr ka̱ isong ka̱kul ndàng imaləng oza̱.
\v 43 UHaruna ka̱ ovan wò onunggwan a mwak awalang va̱ oza̱ kà̱ ntáng ashe Aghal Mɓut, ka̱t te oza̱ ɓa atak nshì iya̱m awop pa̱ o nəm inok ka̱ ashe atak ayəyər, na kang oza̱ á ɓa ká̱ mpat ishi oza̱ akú ka̱t. Iya̱m va̱ ta̱ á yà nnap nnəm ngga mbyet mbyet ka̱ atak aHaruna ka̱ akum ìjili jili.
\c 29
\s1 Nggar Onəm oga nshì iya̱m awop
\p 
\v 1 <<Iya̱m va ta̱ ɓu nəm oza̱ na á gar oza̱ ka̱kul na oza̱ á yà onəm oga ǹshi iya̱m awop mi. Kpán iya inà inunggwan ká̱ inagam pa̱ iparəm iva yà ká̱ mbyèt ka̱t,
\v 2 ká̱ nzəngkəng ngga ǹyà ká̱ annyer ka̱t, ká̱ awoina va yà ká̱ annyer ka̱t ká̱ mmì, ká̱ nzəngkəng ndatdat ngga ǹyà ká̱ anyer ka̱t va mmá ɓəl ká̱ mmì. Nəm oza̱ ká̱ mmá̱k izangzəng ǹyalyal.
\v 3 Nak oza̱ ka̱ ashe nkatəp kang ɓu ɓa ká̱ ka̱ ashe nkatəp va̱ ta, ɓa ká̱ inà inunggwan ka̱ ínagam iga iparəm va̱ ta.
\v 4 Ɓa ká̱ uHaruna ká̱ ovəvan onunggwan ka̱ anung asa̱l Aghal Mɓut, te nàl oza̱ ká̱ ndəng.
\v 5 Te mwak ilukwan uHaruna, iga ashe, iwangwang, iga ìkwoksok, ka̱ mpuluk, kang ɓu kpán aɗək á na ká̱ ngbat.
\v 6 Pá iya̱m ishi á na ká̱ ishishi, te ɓam achuchwal ayə́ryər va̱ ta ka̱ izər iya̱m ishi.
\v 7 Yar mmì ngga nggor, zuk á na ka̱ ishi gar na.
\v 8 Kà̱ nvəva̱ng te ɓa ká̱ ovəvan, mwak ílukwan iga ashe óza̱,
\v 9 Kpán aɗək ûHaruna ká̱ ovan wò ká̱ ngbàt kang ɓu mwak iya̱m ishi óza̱, te inok mpyal awop i yà nji oza̱ mbyet mbyet. Asa̱l va ta̱ ɓu gar uHaruna ká̱ ovan wò.>>
\p 
\v 10 Te ɓa ká̱ iya inà inunggwan ka̱ anung asa̱l Aghal Mɓut, te uHaruna ká̱ ovan wò i nak awo oza̱ ka̱ apal ishishi.
\v 11 Te pà iya inà inunggwan va̱ ta kà̱ mpyal aYawe ka̱ anung asa̱l Aghal Mɓut.
\v 12 Dok nchə̀r iya inà inunggwan va̱ ta ká̱ ifang ɓu na u ɓàp kà̱ oga nggungung atak nshì iya̱m awop, te tar aɓuɓo pa̱ kpaktak ka̱ akum atak nshì iya̱m awop.
\v 13 Wur nkpaktak mpip va̱ gún oga iya̱mfu ka̱ nvəngva̱ ka̱ izər anì, ka̱ oga arusok aga aparəm ká̱ mpip oza̱, te shì ka̱ apal atak nshì iya̱m awop.
\v 14 Te wur izhé iya inà inunggwan va̱ ta ká̱ awuwa ká̱ oga iya̱mfu, shì oza̱ ka̱ apər kà̱ nsəm apa̱k, iya̱m inana nnap mɓá̱ngɓa̱ng.
\p 
\v 15 <<Te kpán ìnagam pa̱ izəng, na uHaruna ka̱ ovan wò á nak awo oza̱ ka̱ apal ishi ìnagam va̱ ta.
\v 16 Pà ìnagam va̱ ta, te dok nchəchər sháng kà̱ nkpaktak ngba̱k atak nshì iya̱m awop.
\v 17 Te nyat ìnagam va̱ ta, nàl iya̱mfufu ká̱ oga mbwangbwangbwángbwáng, te gwang oza̱ ka̱ ìnyatnyat va̱ ká̱ ishishi.
\v 18 Te shì nkpaktak ìnagam va̱ ta ka̱ apal atak nshì iya̱m awop. Iya̱m inana iga nshì pa̱ ɗwot ûYawe, inəngnəng ichángchàng, iya̱m inana iga nshì ûYawe.>>
\p 
\v 19 <<Te kpán ìnagam izəngtəng na uHaruna ká̱ ovan wò á nak awo oza̱ ka̱ apal ishi ìnagam va̱ ta.
\v 20 Pà ìnagam va̱ ta te dok nchəchər na u ɓàp ka̱ apal arwangchwang achwang aga awóri aHaruna ka̱ ovəvan onunggwan. Dok kà̱ ífang inunggwan iga awóri, ká̱ ífang inunggwan iga shar ari oza̱. Te shang aɓo nchə̀r va̱ ta kà̱ nkpaktak ngba̱k atak nshì iya̱m awop.
\v 21 Dok nchə̀r va̱ ka̱ apal atak nshì iya̱m awop, ká̱ mmì ngga nggar, te shang ka̱ apal aHaruna ká̱ ìlukwanlukwan, ká̱ ovəvan onunggwan ká̱ ìlukwan oza̱. Uza̱ ká̱ ovəvan onunggwan ká̱ ílukwan oza̱ i yà oyə́ryər.>>
\p 
\v 22 Wur mpip ìnagam va̱ ta, mpip aswal, ká̱ ngga iya̱mfu, ká̱ ngga anì, ká̱ arusok aga aparəm ká̱ mpip oza̱, ká̱ isong iga awóri, ka̱kul ìnagam iga nnak awo.
\v 23 Yar mɓit nzəngkəng, ká̱ awoina pa̱ zəng ava mmá nəm ká̱ mmì, ká̱ nzəngkəng ndatdat pa̱ nzəng a fa ka̱ ashe nkatəp nzəngkəng va ngga ǹyà ká̱ anyer ka̱t va ká̱ mpyal aYawe.
\v 24 Nak nkpaktak oga iya̱m va̱ ta̱ ka̱ ashe awo aHaruna ká̱ ovəvan, na oza̱ á gha̱p, iya̱m inana iga ǹyegye ûYawe.
\v 25 Ka̱m ka̱ awo oza̱, te shì ka̱ apal atak nshì iya̱m awop, iya̱m inana inəngnəng ichángchàng kà̱ mpyal aYawe. Iya̱m inana iga nshì pa̱ ɗwot ûYawe.
\v 26 Yar ǹjat ìnagam iga nnak awo ûHaruna, te gha̱p wa iya̱m inana iga ǹyegye kà̱ mpyal aYawe, na á yà ǹji ɓu.
\p 
\v 27 <<Gar ǹjat iya̱m inana iga ǹyegye nva̱ mmá yegye ká̱ isong ngga iya̱m iɓutɓut iva̱ mmá gha̱p ka̱ ashe ìnagam iga nnak awo, ka̱ ashe iya̱m va̱ iji aHaruna ká̱ ovəvan.
\v 28 Iya̱m va̱ ta̱ i yà iji aHaruna ká̱ ovəvan ka̱ ashe oIsa̱rila pa̱ ɗəkər ka̱kul iya̱m inana. I yà iya̱m inana ka̱ atak oIsa̱rila ka̱ ashe nləfər oza̱ ngga iya̱m inana iga ntəm ikángkáng, iya̱m inana oza̱ ûYawe.>>
\p 
\v 29 <<Ilukwan iyə́ryər aHaruna i yà iji ovəvan kà̱ nvəva̱ng, te mí zuk mmì óza̱ mí nak awo óza̱.
\v 30 Unəm va̱ yà unəm uga mpyal awop ka̱ nva̱ng aHaruna ka̱ ashe ovəvan te, uza̱ i mwak oga ílukwan va̱ ta̱ i nəm nra pa̱ nfangshat kang uza̱ i ɓa ashe Aghal Mɓut pa̱ ô nəm inok ka̱ atak ayəryər.
\p 
\v 31 <<Yar ìnagam iga nnak awo, te pək izhìzhe ka̱ Atak Ayə́ryər.
\v 32 UHaruna ká̱ ovan wò onunggwan á ri izhé ìnagam va̱ ta nzəng ka̱ nzəngkəng va̱ ka̱ ashe nkatəp ka̱ anung asa̱l Aghal Mɓut.
\v 33 Te oza̱ á ri iya̱m va̱ mmá mwa ishi ká̱ ka̱kul nnak awo ká̱ nggar oza̱. Unəm ugafak i ri oza̱ ka̱t ka̱kul oza̱ iya̱m iyə́ryər.
\v 34 A yà pa̱ izhé, ka̱t te nzəngkəng ka̱kul nnak awo achu ìpin kpa̱kkpa̱k te, shì ká̱ apər, mí ri ka̱t ka̱kul iyə́ryər.
\p 
\v 35 <<Asa̱l va ta̱ ɓu nəm ká̱ uHaruna ká̱ ovan wò wa nva̱ ka̱ n nak ɓu, nnak awo óza̱ i yar nra pa̱ nfangshat.
\v 36 Nza̱ ilum nggo te na iya inà inunggwan iya̱m inana nnap mɓá̱ngɓa̱ng ka̱kul mmwa ishi. Jen atak nshì iya̱m awop ka̱ atak mmwa ishi ka̱kukul, te gor na u gar na.
\v 37 Mwa ishi atak nshì iya̱m awop ka̱ apal nra pa̱ nfanshat na u gar na á yà ayə́ryər va ji. Nkpaktak iya̱m va̱ i dok te i yà iyə́ryər.
\p 
\v 38 <<Iya̱m va ta̱ ɓu yichi ka̱ apal atak nshì iya̱m awop nza̱ ilum nggo. Itam iga ìzun pa̱ ìzəng pa̱ iparəm.
\v 39 Yichi ìtam pa̱ ìzəng ká̱ ìpin, te pa̱ ìzəng ká̱ arurong.
\v 40 Ìtam iga nggəshi te yichi nzəng ká̱ mma̱k ǹyalyal ka̱ ashe ìkpáng mma̱k pa̱ ìzəng, ká̱ mmì mpyet pa̱ ɗa̱p ká̱ ndəng ìba̱ngba̱ng ǹsámsàm akwaya pa̱ zəng, iya̱m inana iga ngwa.
\v 41 Yichi ìtam izəngtəng ká̱ arurong wa nva u yichi iya̱m inana ìpirkur ká̱ iga ngwa ká̱ ìpin, inəngnəng ichángchàng, iya̱m inana iga nshì ûYawe.
\v 42 I yà iya̱m inana iga nshì pa̱ ɗwot pa̱ ɗəkər ka̱ ashe oga nlwàk wo ka̱ anung Aghal Mɓut kà̱ mpyal aYawe, ka̱ atak va̱ ta mi gwang ka̱ ɓu kang mi là nnap ká̱ ɓu.
\v 43 Mi gwang ká̱ oIsa̱rila ka̱ atak va̱ ta, kang i yà ayə́ryər ka̱ atak ìzhàn mi.
\v 44 Mi gar Aghal Mɓut ká̱ atak nshì iya̱m awop, kang uHaruna ká̱ ovan wò te mi gar i nəm inok á mi wa onəm oga ǹshi iya̱m awop.
\v 45 Mi təm ka̱ ashe onəm oIsa̱rila mi yà Inan oza̱.
\v 46 Kang oza̱ i nyi pa̱ mmami na uYawe, Inan oza̱ ùva̱ fa ká̱ oza̱ ka̱ ashe mbin aMasar ka̱kul na n təm ka̱ ashe oza̱. Mmami na uYawe, Inan oza̱.
\c 30
\p 
\v 1 <<Mye atak nshì iya̱m awop ka̱kul nshì iya̱m inə́ngnəng ichángchàng, nəm ká̱ akun akasiya.
\v 2 Mbəbal á yà ashar pa̱ zəng ka̱ aɓuɓo, ngwuwang á yà ashar pa̱ zəng ká̱ aɓuɓo, ngwuwang ká̱ mbəbal á mal izər, te irurup á yà ashar pa̱ shatɗing. Nggúnggúnggúnggúng á yà nnəm iya̱m izəngtəng.
\v 3 Ɓam aranchwangranchwang ká̱ oga ngbəgba̱k ká̱ nggúnggúnggúnggúng ká̱ azənariya anəna̱n. Rà̱p nza̱m kà̱ nkpaktak oga ngbəgba̱k ká̱ azənariya.
\v 4 Nəm nkalɓang azənariya ka̱ avəng aranchwangrangchwang pa̱ mparəm kà̱ nza̱ ngba̱k nggo ka̱kul á yà atak mmwàk nkpá nggang ngga ǹyəyar.
\v 5 Nəm oga nkpá nggang ngga akun akasiya, te ɓam izəzər ká̱ azənariya.
\v 6 Nak atak nshì iya̱m awop va̱ ta kà̱ mpyal atani va ká akwati aga nsar nnap-nlà, kà̱ mpyal anung aga nkukuk va ka̱ apal akwati aga nsar nnap-nlà, ka̱ atak va̱ ta mi gwang ká̱ ɓu.
\v 7 UHaruna á dung iya̱m inəngnəng ichángchàng ka̱ apəpal nza̱ ìpin nggo, nva̱ uza̱ i ɗa̱mshi oga apitila te, uza̱ á dung.
\v 8 UHaruna á dung ká̱ arurong nva̱ uza̱ i ɗa̱mshi oga apitila, iya̱m inəngnəng ichángchàng iga ndung pa̱ ɗəkər kà̱ mpyal aYawe ka̱ ashe nkpaktak oga nlwàk wo.
\v 9 Kang wa dung nro pa̱ɗi, ka̱t te wa yichi iya̱m inana iga nshì pa̱ ɗwot, ka̱t te iya̱m inana iga ìpirkur ka̱ apəpal ka̱t. Kang wa tar iya̱m inana iga ngwa ka̱ apəpal ka̱t.
\v 10 Nva̱ng pa̱ zəng ka̱ ashe ìzun uHaruna á nəm mmwa ishi ka̱ apal oga nggúnggúnggúnggúng ka̱ ashe nchə̀r iya̱m inana nnap mɓá̱ngɓa̱ng ngga mmwa ishi. Pa̱ nzəng ka̱ ashe ìzun uza̱ i mwa ishishi ka̱ ashe nkpaktak nlwàk wo, ayə́ryər va̱ ji pa̱ kpaktak ûYawe.>>
\p 
\v 11 Te uYawe là uMusa pa̱,
\v 12 <<Awalang va ɓu kung iyə̀l oIsa̱rila te, nkpaktak oza̱ i mwa ishi oza̱ ûYawe, na kang arwa aɓá̱ngɓa̱ng aro á ɓa ka̱ apal oza̱ ka̱kul nkung oza̱ ka̱t.
\v 13 Iya̱m va ta̱ nkpaktak unəm va̱ mmà kung na chit te i mwa, agera\f + \fr 30.13 \fq agerar \ft mmàl ìɗək iya̱m ka̱ ashe achu iHiburu\f* pa̱ gba̱pchi nna nkap ashekel kà̱ ishimshe ka̱ anung ashekel aga Atak Ayə́ryər. AGera pa̱ gba̱pchi va̱ ta i yà iya̱m iɓutɓut ûYawe.
\v 14 Nkpaktak unəm va̱ mmá kung na chit, á ɓan kà̱ ìzun ìsəm pa̱ iparəm ɓa ga apal te, i na iya̱m iɓutɓut ûYawe.
\v 15 Unəm uga ndur i na i mak iji agerah pa̱ gba̱pchi ka̱t, kang unəm uga nkun i na iyən agba̱pchi ka̱t, nva̱ ó ɓa ká̱ iya̱m iɓutɓut ûYawe ka̱kul mmwa ishi wo a.
\v 16 Ka̱m mbwai ngga mmwa ishi va̱ ta ka̱ atak oIsa̱rila, na u nəm inok ká̱ ka̱ Aghal Mɓut, te i yà iya̱m iga nrəng ká̱ óIsa̱rila kà̱ mpyal aYawe ka̱kul mmwa ishi oza̱.>>
\p 
\v 17 Te uYawe là uMusa pa̱,
\v 18 <<Nəm asu ká̱ izan iga nchəcher ká̱ acham arəzang ka̱kul nnal awo ká̱ ashar. Sung kà̱ mbagar Aghal Mɓut ká̱ atak nshì iya̱m awop, te nak ndəng ka̱ ashishe.
\v 19 UHaruna ká̱ ovan wò i nàl awo oza̱ ká̱ ashar oza̱ ká̱ ndəng va̱ ta.
\v 20 Kang oza̱ i táng ashe Aghal Mɓut ka̱t te i ɓa atak nshì iya̱m awop pa̱ o nəm inok, o yichi iya̱m inana iga apər ûYawe te, oza̱ i nàl ishi oza̱ na kang oza̱ á kú ka̱t.
\v 21 Oza̱ i nàl awo ká̱ ashar oza̱ na kang oza̱ á kú ka̱t. I yà nnap nnəm óza̱ mbyet mbyet, ka̱kul aHaruna ká̱ akukum ka̱ ashe nkpaktak oga nlwàk oza̱.>>
\p 
\v 22 Te uYawe là uMusa pa̱,
\v 23 <<Kwap ishi ɓu oga iya̱m iga nggol iya̱m-nrì inəna̱n, njəng ìkun iɗəɗek ashekel igba̱l pa̱ ìtukun, ká̱ mmá̱kma̱k ikwoksok ìkun ìɗəkɗək ashekel igba̱l pa̱ ìparəm ká̱ ìsəm pa̱ ìtukun, ká̱ nggal iɗəkɗek ashekel igba̱l pa̱ iparəm ká̱ ìsəm pa̱ ìtukun,
\v 24 ká̱ mmá̱kma̱k agwal ìkun ìɗəɗək igba̱l pa̱ ìtukun, ka̱ anung ashekel aga Atak Ayə́ryər, ká̱ mmì mpyet pa̱ ɗa̱p.
\v 25 Nəm mmì nyə́ryər ngga nggar nggwánggwáng, á yà mmì ngga nggar.
\v 26 Te gor Aghal Mɓut ká̱ akwati aga nsar nnap-nlà,
\v 27 ká̱ atebəl ká̱ nkpaktak oga iya̱m inunok, ká̱ apitila aga idari ká̱ oga iya̱m inunok, ká̱ atak ndùng nturari,
\v 28 ká̱ atak nshì iya̱m inana ká̱ nkpaktak iya̱m inunok, ká̱ asu ká̱ izəzan.
\v 29 Gar oza̱ na oza̱ á yà iyə́ryər va ji pa̱ kpaktak. Nkpaktak iya̱m va̱ i dok oza̱ te i yà iyə́ryər.
\v 30 Gor uHaruna ká̱ ovəvan na u gar oza̱ á nəm inok á mi wa onəm oga nshi iya̱m awop.
\v 31 Te ɓù là óIsa̱rila pa̱, <Nna ta̱ i yà mmì mi nyə́ryər ngga nggar ka̱ ashe nkpaktak oga nlwàk wo.
\v 32 Mí yà ka̱ nzuk unəm ka̱ izər na pa ka̱t, ó yà ka̱ nnəm nro wa nva̱ ta ka̱t, iya̱m iyə́ryər, i yà iya̱m iyə́ryər a wo.
\v 33 Unəm va kpaktak nəm apir mmì va̱ ta̱, ka̱t te á zuk unəm ugafak uga mpyal awop ka̱t te, mí tutur na i fa ka̱ ashe onəm mi.> >>
\p 
\v 34 UYawe là ûMusa pa̱, <<Wur íshi ɓu, oga iya̱m iga nggol iya̱m-nrì, anatap, aushelet, awehelbənah, ká̱ njeng nnə́ngnəng ichángchàng nnəna̱n, oza̱ á mal izər.
\v 35 Te gwang nturari wa ánəm uga nnyi ngugwang, nak mmán kà̱, á yà pa̱ zarara̱, nyə́ryər.
\v 36 Kpa̱k ka̱ ashishe kpà pa̱ ɓirəkɓirək, te nak kà̱ mpyal akwati aga nsar nnap-nlà ka̱ ashe Aghal Mɓut, ka̱ atak va ta mi gwang ká̱ ɓu, á yà iyə́ryər va ji pa̱ kpaktak a wo.
\v 37 Nturari va̱ ó nəm ka̱ asa̱l ata̱ te, ó yà ka̱ nnənəm ka̱kul ishi wo ka̱t, o nak á yà iya̱m iyə́ryər ûYawe.
\v 38 Nkpaktak unəm va̱ nəm wa nva̱ ta̱ ka̱kul ishi wò te, mí tutur na i fa ka̱ ashe onəm mi.>>
\c 31
\s1 UYawe yak uBezalel ká̱ uOholiyap
\p 
\v 1 Te uYawe là uMusa pa̱,
\v 2 <<Dər, n yak uBezalel uya aUri ukà aHur akum aYahuda chit.
\v 3 N nak aRuhu mi á na, ká̱ aghan, ká̱ nkpán ìpir nnàp, ká̱ nnyi, ká̱ nkpaktak nnyi ngga nəm iya̱m iga awo pa̱ ɗongɗong,
\v 4 na uza̱ á fa ká̱ iya̱m nnəm pa̱ ɗongɗong, azənariya, aazurfa, ká̱ acham arəzang,
\v 5 ká̱ ipáng igyokgyok ka̱kul atak aga ndədat, ká̱ nkpà akun ká̱ inok iga awo pa̱ ɗongɗong.
\v 6 Dər, n yak uOholiyap uya aAhisamak uga akum aDan nzəng ká̱ na. N na aghan aga nnyi nəm inok nkpaktak onəm oga nnyi nnəm inok, na oza̱ á nəm nkpaktak iya̱m iva n nak ɓu pa̱ û nəm,
\v 7 Aghal Mɓut, ká̱ akwati aga nsar nnap-nlà, ká̱ anung aga nkukuk ava̱ ka̱ apəpal, ká̱ nkpaktak oga iya̱m iga ashe aghal,
\v 8 ateɓəl ká̱ iya̱m inunok, idari apitila, ká̱ atak nshì iya̱m awop inə́ngnəng ichángchàng,
\v 9 ká̱ atak nshì iya̱m awop inana ká̱ iya̱m inunok, ká̱ asu ká̱ izəzan,
\v 10 ká̱ ìlukwan iloklok inəna̱n, ká̱ ìlukwan iyə́ryər ka̱kul ánəm uga mpyal awop, uHaruna, ká̱ ìlukwan ovəvan onunggwan ka̱kul inok oza̱ onəm oga mpyal awop,
\v 11 ká̱ mmì ngga nggor ká̱ nnə́ngnəng ncángchàng ka̱kul atak ayəyər. Oza̱ á nəm oza̱ pa̱ chatchat wa nva n là a ɓu.>>
\s1 ALum aSati
\p 
\v 12 Te uYawe là uMusa pa̱,
\v 13 <<Là óIsa̱rila pa̱, <Nkpak pa̱ o nak ishi ká̱ ilum aSati mi, ka̱kul nnyám ìpir nnàp kà̱ ishimshe mi ká̱ wo ká̱ oga nlwàk wo ngga mɓa ka̱kul na o nyi pa̱ mmami uYawe uva̱ gar wo.
\p 
\v 14 << <O kpak ilum aSati, ka̱kul á yə́yər ka̱ atak wo. Nkpaktak unəm uva̱ nəm vyakshin ká̱ ilum iva̱ ta te, mí gba̱l na. Nkpaktak unəm uva̱ nəm inok kà̱ ilum iva̱ ta te, mí tutur na í fa ka̱ ashe onənəm.
\v 15 Nra pa̱ nkpa̱ɗing ó nəm inok ka̱ shishe, kang nra ngga nfangshat i yà aSati ilum iga njul, i yə́ryər ûYawe. Nkpaktak unəm uva̱ nəm inok kà̱ ilum iva̱ ta te, nkpak mí gba̱l na.
\v 16 OIsa̱rila á kpak ilum aSati ava̱ ta á nak ishi ká̱ nnap mpakpak ka̱ ashe oga nlwàk oza̱ ngga mɓa ghar mbyet.
\v 17 I yà iya̱m iga nnyám ìpir nnàp kà̱ ishimshe mi ká̱ oIsa̱rila ghar mbyet, ka̱kul ka̱ ashe nra pa̱ nkpa̱ɗing uYawe nəm apaɓur ka̱ apambin, te uza̱ jul kang a yì kà̱ nra ngga nfangshat.> >>
\p 
\v 18 Nva̱ngva̱ uYawe gba̱l nlà nnap ká̱ uMusa ka̱ apal aƁam aSinayi te, uza̱ na oga achuchwal ìpang nnap nshetshet á na pa̱ iparəm iga nlìr ifang Inan.
\c 32
\s1 Nnəm iya ìna iga azənariya
\p 
\v 1 Nva̱ngva̱ onəm ya pa̱ uMusa kali kà̱ nfə́r ka̱ apal aɓam te, oza̱ ɓut gáng uHaruna là á na pa̱, <<Wong, nəm inan á yi na á ləp mpyal á yi, ka̱kul í nyi iya̱m iva̱ ya uMusa uva̱ fa ká̱ yi ka̱ mbin aMasar ka̱t.>>
\v 2 Te uHaruna là óza̱ pa̱, <<O zə̀p iya̱m achwang azənariya ka̱ achwang óchar wo ká̱ ovan wo onunggwan ká̱ ovan ochar ó ɓa ká̱ á mi.>>
\v 3 Te nkpaktak onəm zə̀p oga iya̱m achwang oza̱ iga azənariya ka̱ achwang oza̱ ɓa ká̱ ûHaruna.
\v 4 Uza̱ ka̱m ka̱ awo oza̱ á tap ka̱ apər te a me ichər gyok izəzər ka̱ iya̱m inok á ya wa iya ìnà. Te oza̱ là pa̱, <<ÓIsa̱rila, inan wo yà ta̱ iva̱ fa ká̱ wo ka̱ ashe mbin aMasar.>>
\v 5 Nva̱ng nva̱ uHaruna ya te uza̱ me atak awop kà̱ mpipyal, te uHaruna wór awór là pa̱, <<Ìpin te i yà nnəm nchang izər ûYawe.>>
\v 6 Te oza̱ wong ka̱ iɓotak kà̱ ìpin ìkpa̱kkpa̱k kang oza̱ yichi iya̱m ináná iga nshì pa̱ ɗwot ká̱ iya̱m inana iga ntəm ikángkáng. Onəm təm ri iya̱m-nrì ka̱ ngwa iya̱m iwawa te, oza̱ wong gba̱p nza̱m akpit.
\v 7 Te uYawe là ûMusa pa, <<Fər kəlak, onəm va̱ u fa ká̱ oza̱ ka̱ ashe mbin aMasar te, oza̱ vyap ishi oza̱ chit.
\v 8 Oza̱ gha̱n kà̱ ga̱ɓa̱n nre asa̱l ava̱ n nák ôza̱ kang oza̱ nəm ichər iya ìnà ishi oza̱ ká̱ azənariya. Te oza̱ kuchi na nləfər á na kang oza̱ là pa̱, <ÓIsa̱rila, inan wo yà ta̱, iva fa ká̱ wo ka̱ ashe mbin aMasar.> >>
\v 9 Te uYawe là ûMusa pa̱, <<N yà onəm ova̱ ta̱ chit, oza̱ onəm oga nkak ishi.
\v 10 Ǹyangmata̱ te, re mi na nlak ìgwak mi a vang ka̱ apal ishi oza̱ na n zhì oza̱. Te mi nak ɓu yà akum achumchum.>>
\p 
\v 11 Ka̱ nna te uMusa sak anung uYawe, Inan wo pa̱, <<ÁYawe, sang kang ìgwak lak ɓu ká̱ onəm ɓu va u fa ká̱ ka̱ ashe mbin aMasar ká̱ ikam ichumchum ká̱ awo akamkam yà?
\v 12 U ɗom pa̱ na oga aMasar á là pa̱, <Inan oza̱ fa ká̱ oza̱ ká̱ nrəng mɓá̱ngɓa̱ng pa̱ u gbá̱ng oza̱ ka̱ ashe oga aɓam, na u dərkən oza̱ ká̱ apambin> ɗò? Ga̱ɓa̱n nfə́l ìgwak ɓu, re nrəng nnap ɓu nsusur ngga ǹzhi onəm ɓu.
\v 13 Rəng ozwal ɓu, uAbəraham, uIshaku, ká̱ uYakup, ova u sóng anung óza̱ ká̱ ishi ɓu pa̱, <Mi nak àkum wo i yə́l wa izhan iga apaɓur, te nkpaktak mbin nva̱ ta̱ nva̱ n yar nsar nnap-nlà pa̱ mi na ovan wo í yà iya̱m akúp oza̱ mbyet mbyet.> >>
\v 14 Te uYawe ga̱ɓa̱n nrəng nnap wò ka̱ apal nɗaktak nva̱ uza̱ ka̱ yar pa̱ o ɓa ká̱ onəm wò.
\v 15 Te uMusa fər ka̱ apal aɓam ká̱ oga achuchwal ipang aga nnap nshetshet pa̱ aparəm ka̱ awo wò, achuchwal ava mmá lir iya̱m kà̱ nkpaktak ngba̱k oza̱ ngga mparəm.
\v 16 Oga achuchwal ava̱ ta̱ te Inan à nəm oza̱, kang iya̱m ǹlir va̱ ka̱ apəpal te Inan à gyok.
\v 17 uJoshuwa fe nnáp ngham achu onəm te, uza̱ là ûMusa pa̱, <<Nnáp achu ikùm ka̱ ashe apa̱k.>>
\p 
\v 18 Kang uMusa là pa̱,
\q1 <<Ìcù igwan ka̱t,
\q2 ka̱t te ìcù pa̱ mmá ri onəm ká̱ ìkum ka̱t.
\q2 Nnyi te, mmami kà̱ ǹfe ìcù nnap-nshì.>>
\p 
\v 19 Nva̱ngva̱ oza̱ ɓa dat ka̱ apa̱k te, uMusa ya ìya inà iva̱ oza̱ nəm kang oza̱ kà̱ ngba̱p nza̱m, ka̱ ashe nfə́l ìgwak pa̱ gənggəng, te uza̱ swang oga achuchwal ava̱ ka̱ awo wò ka̱ avəng aɓam kang oza̱ achwang pa̱ rukutrukut.
\v 20 Uza̱ yar ìya inà va oza̱ nəm shì kà̱ apər, uza̱ kpà wal mmá̱k, wung ka̱ apal ndəng, te nak oIsa̱rila wá.
\v 21 Te uMusa ɓəp uHaruna pa̱, <<Iza̱ onəm ova̱ ta̱ nəm a ɓu kang u dapchi nnap mɓá̱ngɓa̱ng nchumchum ôza̱ yà?>>
\p 
\v 22 Te uHaruna là pa̱, <<Kang ìgwak a lak unəm uga ǹzhi mi ka̱t, u nyi onəm va̱ ta̱ nyi ká̱ nɗom nnəm iya̱m iɓá̱ngɓa̱ng.
\v 23 Oza̱ là á mi pa̱, <Nəm inan á yi na á ləp mpyal á yi, ka̱kul uMusa ta̱ unəm uva fa ká̱ yi kà̱ mbin aMasar, í nyi iya̱m iva̱ yá na ka̱t.>
\v 24 Te n là ôza̱ pa̱, <Nkpaktak unəm va̱ uwa yà ká̱ azənariya te, oza̱ á zèp á ɓa á mi.> Oza̱ ɓa ká̱ á mi kang n swang ka̱ ashe apər te, ìya inà iva̱ ta̱ fa.>>
\p 
\v 25 Ka̱ nva̱ngva̱ uMusa ya chit pa̱ uHaruna nəm onəm ova̱ ta̱ chit í nfe nnap lap ka̱t, kang oza̱ sat iya̱m iga ǹyəl kà̱ mpyal okpà ìkum oza̱ te,
\v 26 uza̱ sat ka̱ anung asa̱l ntar ashe apa̱k, kang uza̱ là pa̱, <<Nkpaktak unəm va̱ uja aYawe te, re uza̱ á ɓa atak mi.>> Te nkpaktak onunggwan oLawi ɓa gang na.
\p 
\v 27 Uza̱ là ôza̱ pa̱, <<Iya̱m iva ta̱ uYawe, Inan oIsa̱rila là, <Nza̱ unəm nggo á gal ndokchi kà̱ ngba̱k wò. Te o ga anung asa̱l ava̱ ta̱ o le ava̱cho ka̱ ashe apa̱k. Ko udanggo á gba̱l ugənnang wò, ko udanggo á gba̱l ukpa wò, kang ko udanggo í gba̱l unəm uga ngba̱k nzhi wò.> >>
\v 28 OLawi kpak iya̱m iva̱ uMusa là ôza̱, te onəm ìkalong pa̱ ishatɗing ka̱ ashe onəm tàk nda nva̱ ta.
\v 29 Te uMusa là pa̱, <<N̂da nva̱ ta̱ o gar ishiwó chit ka̱kul inok áYawe. Ka̱kul ko udanggo gbá̱ng ovan wò ka̱t te ugənnang chit, ka̱kul nva̱ ta te, uYawe nak nnap nnəna̱n á wó chit.>>
\p 
\v 30 Ìpin fa kpa̱k te, uMusa là ônəm pa̱, <<O nəm nnap mɓá̱ngɓa̱ng nchumchum chit. Ǹyangmata̱ te, mi kyen atak áYawe mwote, mi nəm mwa ishi ka̱kul nnap mɓá̱ngɓa̱ng wó nggo.>>
\p 
\v 31 Te uMusa le atak áYawe á là pa̱, <<Iya̱m iwusa, onəm ata̱ nəm nnap mɓá̱ngɓa̱ng nchumchum, ka̱kul oza̱ nəm ichər iga azənariya îshi oza̱.
\v 32 Ká̱ nnà te, yar nnap mɓá̱ngɓa̱ng oza̱, a yà pa ka̱t te, yà dəkən aɗin mi á le ka̱ ashe ǹlir ɓu nva̱ u lir á.>>
\p 
\v 33 UYawe là ûMusa pa̱, <<Mi dəkən aɗin anəm uva kpaktak nəm nnap mɓá̱ngɓa̱ng á mi ka̱ ashe ǹlir mi.
\v 34 Ǹyangmata̱ te, ga lə́p mpyal onəm á ga atak va̱ n là a ɓu. Dər, uma̱leka mi i watar mpyal ɓu. Kap ká̱ nnà te, mi nyám ntàn óza̱ ka̱kul nnap mɓá̱ngɓa̱ng oza̱.>>
\p 
\v 35 Te uYawe la̱p onəm ká̱ arwa aɓá̱ngɓa̱ng ka̱kul oza̱ wop ìchər iva̱ uHaruna nəm.
\c 33
\p 
\v 1 UYawe là ûMusa pa̱, <<Wong re atak va̱ ta̱, mmaɓu ká̱ onəm va̱ u fa ká̱ oza̱ ka̱ ashe mbin aMasar o ga mbin nva̱ n sóng anung ûAbəraham, ká̱ uIshaku, ká̱ uYakup, n là pa̱, <Mi ga nnəna âkum ìjili wó.>
\v 2 Mi ngga re ǹre ká̱ uma̱leka kà̱ mpyal wó, te mi ɓak oKanana, ká̱ oAmori, ká̱ oHiti, ká̱ oPerizi, ká̱ oHivi, ká̱ oYebusi kpa.
\v 3 Ga ashe mbin nva mbyal ká̱ mmàl irizhe i nang kà̱. Ká̱ nna te, mi ga nzəng ká̱ wo ka̱t ka̱kul mmawó onəm oga nkak ishi, le kang ma zhì wó ka̱ apal asa̱l.>>
\p 
\v 4 Nva̱ngva̱ onəm fe nnap-nlà nrwarwa wa nva̱ ta te, oza̱ təm ká̱ aɗor te unəm uro mwak iya̱m ìsham wò ka̱t.
\v 5 Ka̱kul uYawe là ûMusa pa̱, <<Là oIsa̱rila pa̱, <Mmawo onəm oga nkak ishi. A yà pa̱ mi ga nzəng ká̱ wó i gba̱ng va̱ng ka̱t, te mi zhì wó. Ǹyangmata̱ o zə̀p iya̱m ìsham wó, te mi yak iya̱m iva̱ mal pa̱ n nəm ká̱ wó.> >>
\v 6 Te oIsa̱rila zə̀p iya̱m ìsham oza̱ ka̱ aɓam aHorep.
\p 
\v 7 UMusa pa̱ ɗəkər te i yar aghal kang à pak kà̱ nsəm apa̱k pa̱ gbà̱ngbà̱ng, te uza̱ wór pa̱ Aghal Mɓut. Kang nkpaktak unəm uva̱ ɗom mmwo uYawe te, uza̱ i ga Aghal Mɓut nva kà̱ nsəm apa̱k á.
\v 8 Nza̱ awalang nggo va̱ uMusa i fa ngga atak aghal te, nkpaktak onəm i wong i tong, nza̱ unəm nggo ka̱ anung aghal wò, i dər uMusa i tar ashe aghal ava̱ ta kang.
\v 9 Awalang ava̱ uMusa a tar ashe aghal te, ǹdáng ìlulu i vang i sat ka̱ anung aghal, te uYawe i là nnap ká̱ uMusa.
\v 10 Onəm i ya ǹdáng ìlulu sat chit ka̱ anung asa̱l ǹtar aghal te, nkpaktak oza̱ i wong kang nza̱ uzəngtəng oza̱ nggo i kúchi ka̱ anung aghal wò.
\v 11 UYawe i là nnap ká̱ uMusa ìwu ká̱ ìwu wa nva unəm i là nnap ká̱ ukpa wò. Te uMusa i le apa̱k, ká̱ nnà te uJoshuwa ukparikpari, uyenza̱m uya aNun á re ashe aghal ava̱ ta jo ka̱t.
\p 
\v 12 UMusa là ûYawe pa̱, <<Dər, u là á mi pa̱, <Lə́p mpyal onəm ova̱ ta̱,> kang nna u là á mi chit unəm uva̱ ɓu re i ga nzəng ká̱ mi ka̱t. Ká̱ nna te, u là á mi chit pa̱, <N nyi ɓu ká̱ aɗin, kang ká̱ nna kpa nchə̀r ɓu bà̱l chit kà̱ mpyal mi.>
\v 13 Ǹyangmata̱, kusukkusuk a yà pa̱ nchə̀r mi bəbà̱l kà̱ mpyal ɓu te, kusuk, ɗyang oga asa̱l ɓu á mi na ń nyi ɓu, na ń yà ká̱ nchə̀r mbá̱lbà̱l kà̱ mpyal ɓu. Nak ishi ká̱ kpa pa̱ onəm ova̱ ta̱ onəm ɓu.>>
\p 
\v 14 Te uYawe là pa̱, <<Mi ga nzəng ká̱ ɓu, kang mi na ǹjul a ɓu.>>
\p 
\v 15 Te uMusa là á na pa̱, <<A yà pa̱ ɓu ga nzəng ká̱ yi ka̱t te, kang a re yi i wong ka̱ atak ava̱ ta̱ ka̱t.
\v 16 Mí nəm sang mí nyi pa̱ mmami ká̱ nchə̀r mba̱lbà̱l kà̱ mpyal ɓu, mmami ká̱ onəm ɓu, a yà pa̱ u ga nzəng ká̱ yi ka̱t yà? Iza̱ i nyám nɗongɗong mi ká̱ onəm ɓu ka̱ ashe nza̱ onəm nggo va̱ ka̱ apambin yà?>>
\p 
\v 17 Te uYawe là ûMusa pa̱, <<Mi nəm iya̱m iva̱ ta̱ iva u ɓəp, ka̱kul pa̱ u yà ká̱ nchə̀r mba̱lba̱l chit kà̱ mpyal mi, kang n nyi ɓu ká̱ aɗin.>>
\p 
\v 18 Te uMusa là pa̱, <<Kusuk, nyám ìzhàn ɓu á mi.>>
\p 
\v 19 Te uYawe là pa̱, <<Mi nak nkpaktak inəna̱n mi i watar kà̱ mpyal ɓu, te mi wór aɗin mi ayə́ryər kà̱ mpyal ɓu, kang mi nyám nrusok afu unəm uva̱ mi nyám nrusok afu, te mi nyám nrwa ìgwak unəm uva̱ mi nyám nrwa ìgwak.
\v 20 Ká̱ nnà te, ɓu yà ká̱ n ya asa̱l awu mi ka̱t, ka̱kul unəmləbər uro yà i ya mi kang i lár ka̱t.>>
\p 
\v 21 Te uYawe là pa̱, <<Dər, atak nata̱ kà̱ ngba̱k mi, ava ɓu ta̱l kà̱ ka̱ apal aɓam,
\v 22 nva̱ ìzhàn mi i yà kà̱ ngwatar te, mi nak ɓu ká̱ mbagar ìpang iva̱ ta, te mi ka̱ ɓu ka̱ awo mi ya mi watar kang.
\v 23 Nna chit te, mi yar awo mi i le te, ɓu ya asəm mi. Ká̱ nnà te, mí ya asa̱l awu mi ka̱t.>>
\c 34
\s1 Oga achuchwal ìpang ipipye
\p 
\v 1 UYawe là ûMusa pa̱, <<Kpà oga achuchwal ìpang pa̱ iparəm wa iga nggəshi nva, te mi lir ka̱ apal oza̱ oga nnap-nlà nzəngtəng nva ka̱ apal achuchwal aga nggəshi nva̱ ka̱ u chwan á.
\v 2 Gbar izər na ìpin na u kyen aƁam aSinayi, na u gwang ká̱ mi ka̱ apal itəngtəng aɓam ava̱ ta.
\v 3 Kang unəm uro á kyen nzəng ká̱ ɓu ka̱t, kang a re mmá ya unəm uro kà̱ nkpaktak izər aɓam ava̱ ta ka̱t. Kang a re iya̱m nkang, ka̱t te ína á ri nrì adatkulung ká̱ aɓam ava̱ ta ka̱t.>>
\p 
\v 4 Te uMusa kpà oga achuchwal ìpang pa̱ iparəm wa iga nggəshi nva, kang uza̱ wong ká̱ iɓotak ga aƁam aSinayi, wa nva uYawe kà̱ nak na. Uza̱ wur oga achuchwal ìpang iga iparəm ava̱ ka̱ awo wò.
\v 5 UYawe fər vang ka̱ ashe ǹdáng ìlulu ta̱l ká̱ na ka̱ta, kang à wór aɗin wò ayə́ryər, uYawe.
\v 6 Te uYawe watar kà̱ mpipyal kang à wór awór pa̱, <<UYawe, uYawe, Inan iga nrwa ìgwak ká̱ nrusok afu, iga nlak ìgwak pa̱ kəlak ka̱t, ká̱ mma̱n mmákmak ká̱ nnanda̱r.
\v 7 Mi nyám mma̱n ngga nkur ka̱t ngga nlwàk íkalong, mi yar mpat ká̱ nfa iya̱mkak ká̱ nnap mɓá̱ngɓa̱ng, kang mi yà ká̱ nre nnyám ntàn ka̱t, mi mwo mpat opon ka̱ apal ovan, ká̱ okəká oga mɓa, ka̱ apal nlwàk ngga nshatɗing ká̱ ngga nneɗing.>>
\p 
\v 8 Te uMusa ɓəram pa̱ kəlak ka̱ mbin nəm awop.
\v 9 Uza̱ là pa̱, <<Kusuk, aPonzhinan, a yà pa̱ nchə̀r mi bəbà̱l kà̱ mpyal ɓu te, re uPonzhinan á ga nzəng ká̱ yi. Káp ka̱ nva̱ pa̱ onəm ova̱ ta̱ oga nkak ishi, yar mpat ká̱ nnap mɓá̱ngɓa̱ng á yi kang ɓu ka̱m yi wa onəm ɓu.>>
\p 
\v 10 UYawe là pa̱, <<Dakdak, mmami kà̱ ǹyar nsar nnap-nlà. Mi ga nnəm iya̱m iga nnəm ayər kà̱ mpyal nkpaktak onəm ɓu, iva nna ka̱ fa chit ka̱ ashe apambin ka̱t te oga mbin ka̱t. Te nkpaktak onəm ova̱ mmaɓu kà̱ ishimshe oza̱ í ya inok áYawe, ka̱kul mi ngga nnəm iya̱m iga nnəm ayər ka̱ ashe wó.
\v 11 Nak ishi ká̱ nnap mpakpak nva̱ mmami kà̱ nnəna a ɓu nda nva̱ ta̱. Dər, mi ga mɓàk kà̱ mpyal ɓu oAmori, oKanana, ká̱ oHiti, ká̱ oPerizi, ká̱ oHivi ká̱ oYebusi kpa.
\v 12 O nəm dakdak kang o yar nsar nnap-nlà ká̱ onəm oga mbin va̱ mmawó kà̱ ngga ashishe ka̱t, le a yà ajə̀p kà̱ ishimshe wó.
\v 13 Ka̱ɗor nva̱ ta te, o shin atak awop oza̱, o chwan ǹdáng nyə́ryər oza̱, kang ô kyen oga ndar aAshera oza̱.
\v 14 Kang o wop inan iro ka̱t, ka̱kul mmami uYawe, uva aɗin mi pa̱ ìkpar, Inan iga ìkpar.
\p 
\v 15 <<Kang wa yar nsar nnap-nlà ká̱ onəm ova̱ kà̱ ntəm ka̱ ashe mbin va̱ ta ka̱t, ka̱kul oza̱ í nəm mmai ká̱ inan oza̱, kang í na nləfər iya̱m ipápà ínan oza̱, te oza̱ á chal ɓu pa̱ u ga ká̱ oza̱, te ɓu ri nləfər oza̱.
\v 16 Kang wa yar nsar nnap-nlà ká̱ onəm ova̱ kà̱ ntəm ka̱ ashe mbin va̱ ta ka̱t, ka̱kul wa ka̱m ovan ochar oza̱ ôvan ɓu onunggwan, ova í nəm mmai ka̱ atak ngwop oga inan oza̱ te, í nak ovan ɓu onunggwan í nəm mmai á mi.
\p 
\v 17 <<Ɓu yà ká̱ nlá inan íshiɓu ka̱t.
\p 
\v 18 <<Wá nak ishi ká̱ nnəm nchang izər ngga nrì iya̱m-nrì iga ǹyà ká̱ anyer ka̱t. Nra pa̱ nfangshat ká̱ awalang va mmá nak ka̱ ashe apye aAbip,\f + \fr 34.18 \fq aAbip \ft na apye va iya̱m izhakan i fa ká̱.\f* ri iya̱m-nrì iga ǹyà ká̱ anyər ka̱t wa nva̱ kà̱ n nak ɓu, ka̱kul ka̱ ashe apye ava ta na o fa ká̱ ka̱ ashe mbin aMasar.
\p 
\v 19 <<Nza̱ amar aga nggəshi ayen anunggwan nggo te á ja̱m, kang nkpaktak amar iya̱mkang ɓu agəshi inunggwan á ja̱m.
\v 20 Mwa ishi amar azhaki aga nggəshi ká̱ ìtam, kang a yà pa̱ u mwa ishishi ka̱t te, ɓəkchi ishishak. Wa mwa ishi nkpaktak ovan onunggwan ɓu oga nggəshi.
\p <<Kang unəm uro a ɓa mpyal mi ka̱ awo lakchi ka̱t.
\p 
\v 21 <<Wa nəm inok nra pa̱ nkpa̱ɗing kang kà̱ ilum iga ifangshat te, nkpak ɓu jul. Ko ka̱ awalang aga nsuk iya̱m ká̱ aga mɓəɓən kpa.
\p 
\v 22 <<Wa nak ishi ká̱ nnəm nchang izər oga asati ká̱ awar aga nggəshi aga ibəshi, ka̱ nnəm nchang izər ngga mɓən iya̱m-nrì kà̱ nkùr ìzun.
\v 23 Nkpaktak onunggwan ɓu nkpak í nyám ishi oza̱ kà̱ mpyal uNəm Uga Nzhi uYawe, Inan oIsa̱rila, nva̱ng pa̱ nshatɗing ka̱ ashe ìzun.
\v 24 Mi ɓak oga mbin kà̱ mpyal ɓu kang mi bol aswari ɓu, te unəm uro kúr nnəm aɗom mbin ɓu ka̱t, a yà pa̱ u ɓa mpyal aYawe, Inan ɓu nva̱ng pa̱ nshatɗing nza̱ ìzun nggo.
\p 
\v 25 <<Kang wa yichi nzəngkəng ngga nəm ká̱ anyer ka̱ awalang ava̱ ɓu na nləfər iya̱mkang á mi ka̱t. Kang wa re nləfər ngga nggantal á chu ìpin ìkpa̱kkpa̱k ka̱t.
\p 
\v 26 <<Wa ɓa ká̱ oga awar anəna̱n aga nggəshi ìram ɓu kà̱ ǹzhi aYawe, Inan ɓu.
\p <<Kang wa pə́k iya aɓəl ka̱t te ìtam iva̱ kà̱ mma mbyal ka̱t.>>
\p 
\v 27 UYawe là ûMusa kpa pa̱, <<Lir oga nnap-nlà nva̱ ta̱, ka̱kul ka̱ atak oga nnap-nlà nva ta̱ n yar nsar nnap-nlà ká̱ ɓu kang ká̱ oIsa̱rila.>>
\v 28 UMusa təm ka̱ta ká̱ uYawe nra ìsəm pa̱ ineɗing ká̱ ìzwam ìsəm pa̱ ineɗing, á ri ka̱t á wá ka̱t. Te uza̱ lir oga nsar nnap-nlà ka̱ apal oga achuchwal ìpang, nna nnap mpakpak ngga ngba̱pchi.
\p 
\v 29 Nva̱ uMusa fər ka̱ apal aɓam aSinayi ká̱ oga achuchwal ìpang pa̱ iparəm iga nnap nshetshet ka̱ awo wò te, asa̱l awúwu kà̱ aməlamməlam ka̱kul uza̱ kà̱ là nnap ká̱ uYawe, kang uza̱ nyi ka̱t.
\v 30 Nva̱ngva̱ uHaruna ka̱ nkpaktak onəm oIsa̱rila ya asa̱l awu áMusa aməlam te, ayər nəm oza̱ kà̱ ngga ndatkulung ká̱ na.
\v 31 Ká̱ nnà te, uMusa wór oza̱, kang uHaruna ká̱ nkpaktak onəm oga mpyal mɓut onəm le ɓa atətak, kang uMusa là nnap ká̱ oza̱.
\v 32 Ka̱ nvəva̱ng nva̱ ta te, nkpaktak oIsa̱rila ɓa dat, te uMusa na nkpaktak oga nnap mpakpak nva̱ uYawe na á na ka̱ apal aɓam aSinayi.
\p 
\v 33 Nva̱ngva̱ uMusa gba̱l ká̱ nlà nnap ká̱ oza̱ te, uza̱ dang asa̱l awuwu ká̱ iya̱m iga ndang ishi.
\v 34 Ká̱ nnà te, awalang ava̱ káp uMusa i ga mpyal aYawe pa̱ ô là nnap ká̱ na te, uza̱ i yar iya̱m iga ndang ishi iva̱ ta i le. Kang nva̱ngva̱ uza̱ i fa te, uza̱ là oIsa̱rila iya̱m iva̱ uYawe kà̱ nak na,
\v 35 kang oIsa̱rila i ya asa̱l awu áMusa i məlam. Te uMusa i dang asa̱l awu wò ká̱ iya̱m iga ndang ishi, ya uza̱ i le i ga nlà nnap ká̱ uYawe kà̱ɗi kang.
\c 35
\s1 Oga nnap nkpakkpak ngga ilum aSati
\p 
\v 1 UMusa wór mɓut nkpaktak oIsa̱rila là ôza̱ pa̱, <<Oga iya̱m iva ta̱ uYawe nak wo pa̱ ó nəm.
\v 2 O nəm inok ka̱ apal nra pa̱ nkpa̱ɗing kang ilum iga ifangshat nnyi te, i yá asati ilum iga njul, i yə́ryər ûYawe. Unəm uva̱ i nəm inok kà̱ ilum iva̱ ta te, mí gba̱l na.
\v 3 Ko apər te ó ma̱k ka̱ ashe oga nzhi wó kà̱ ilum asati ka̱t.>>
\s1 Iya̱m inana ka̱kul nzhi awop
\p 
\v 4 Te uMusa là nkpaktak oIsa̱rila pa̱, <<Iya̱m iva ta̱ uYawe nak chit pa̱ mmá nəm.
\v 5 O kwap iya̱m iɓutɓut ûYawe. Re unəm uva̱ yəyar kà̱ ìgwak wò te, uza̱ á ɓa ká̱ azənariya, aazurfa, ká̱ acham arəzang,
\v 6 ká̱ iya̱m iga ndəng izər ivyau, ká̱ iga mɓan pa̱ ga̱r, ká̱ irəzang, ká̱ alinin anəna̱n, ka̱ akpap iɓəl,
\v 7 ká̱ awá inagám va mmá ɓán ká̱ ǹzazí, ká̱ awá iɓəl anəna̱n ká̱ akun akasiya,
\v 8 ká̱ mmì ka̱kul apitila, ká̱ iya̱m iga nggòl iya̱m ka̱kul mmì ngga nggar onəm, ká̱ iya̱m inəngnəng ichángchàng,
\v 9 ipáng iza̱mza̱m ká̱ oga ipáng iro iva mi mɓam i dàt ka̱ izər ìlukwan ìkwoksok ká̱ mpuluk.
\p 
\v 10 <<Nkpaktak onəm oga nnyi inok awo ka̱ ashe wó á ɓa á nəm nza̱ iya̱m nggo va̱ uYawe nak pa̱ mmá nəm,
\v 11 aghal áYawe ká̱ iya̱m iga nggugún, ká̱ iya̱m iga nzùzong ká̱ ndədar, ká̱ ndədar nnárnàr, ká̱ ndədang, ká̱ atak mmùmwak,
\v 12 ká̱ akwati aga nsar nnap-nlà, ká̱ ídari iga ǹyəyar, ká̱ iya̱m iga nkukuk, ká̱ atani aga nká Atak Ayə́ryər ava ji,
\v 13 ká̱ atebəl, ká̱ ídari iga ǹyəyar, ká̱ nkpaktak oga iyəya̱m, ká̱ nzəngkəng áYawe,
\v 14 ká̱ ìdari apitila ká̱ oga iyəya̱m, ká̱ oga apitila, ká̱ mmì ka̱kul nghan atak,
\v 15 ká̱ atak nshì iya̱m inəngnəng ichángchàng, ká̱ oga nkpá nggankpá nggang, ká̱ mmì ngga nggəgar, ká̱ iya̱m inəngnəng ichángchàng iga nshì, ká̱ atani aga nggún anung asa̱l aghal áYawe,
\v 16 ká̱ atak awop aga nshì iya̱m awop, ká̱ ìcha iga ngwàng iya̱m, ká̱ oga ídari iga ǹyəyar, ká̱ oga iyəya̱m, ká̱ asu achumchum, ká̱ akəkar,
\v 17 ká̱ oga atani aga agəla̱n, ká̱ ídari iga mmùmwak, ká̱ atak mwak oza̱, ká̱ atani anung asa̱l aga ntar ashe agəla̱n,
\v 18 ká̱ oga akun aga mpak aghal ká̱ agəla̱n, ká̱ oga asang oza̱,
\v 19 ká̱ ílukwan inəna̱n iloklòk iva onəm oga mpyal awop í mwak ka̱kul nnəm inok ka̱ ashe Atak Ayə́ryər, ká̱ ílukwan iyə́ryər ka̱kul aHaruna, unəm uga mpyal awop, ká̱ íji ovəvan onunggwan onəm oga mpyal awop.>>
\p 
\v 20 Te nkpaktak oIsa̱rila re atak aMusa,
\v 21 kang nkpaktak unəm uva yəyar kà̱ ìgwak wò pa̱ o nəna te, a ɓa ká̱ iya̱m inana ûYawe, ka̱kul mpak aghal aYawe. Kang oza̱ ɓa ká̱ iza̱ nggo iva̱ mmá ɗom ka̱kul nnəm awop, kang ka̱kul nnəm ílukwan ánəm uga mpyal awop kpa.
\v 22 Nkpaktak onunggwan ká̱ ochar ova̱ yəyar kà̱ ìgwak ɓa ká̱ oga iya̱m ìsham, oga nkalɓang azənariya ngga ifang, ká̱ ngga achwang, ká̱ ishuwa ishak. Oza̱ na iya̱m pa̱ ɗongɗong iga azənariya iya̱m inana iga ǹyegye ûYawe.
\v 23 Unəm uva kpaktak uwa yà ká̱ afini aga ndəng izər ivyau, ká̱ arəzang pa̱ ga̱r, ká̱ arəzang, ká̱ alinin anəna̱n, ká̱ akpap iɓəl, ká̱ oga awá ítam aga mɓán ká̱ ǹzazí, ɓa ká̱ oza̱.
\v 24 Ovəngva̱ ká̱ aazurfa ká̱ acham arəzang ɓa ká̱ uYawe, kang nza̱ uzəngtəng oza̱ nggo nva̱ ká̱ akun akasiya aɓyenɓyen ka̱kul nza̱ inok nggo ɓa ká̱.
\v 25 Nkpaktak ochar ova̱ ká̱ aghan aga nlòk iya̱m ɓa ká̱ iya̱m iva̱ oza̱ lòk ká̱ awo oza̱, afini anəna̱n aga ndəng izər ivyau, ká̱ nrəzang pa̱ ga̱r, ká̱ arəzang, ká̱ ìlukwan alinin anəna̱n.
\v 26 Nkpaktak ochar oga aghan va̱ lwom oza̱ ka̱ ashe ìgwak lòk akpap íɓəl.
\v 27 Onəm oga mpyal ɓa ká̱ ipáng iza̱mza̱m ká̱ oga ipáng íro inəna̱n pa̱ mmá ɓàm ka̱ apal ìya ìlukwan ìkwoksok.
\v 28 Oza̱ ɓa ká̱ oga iya̱m iga nggòl iya̱m kang ká̱ mmì ka̱kul apitila, ká̱ mmì ngga nggar onəm, ká̱ oga iya̱m inəngnəng ichángchàng.
\v 29 Nkpaktak oIsa̱rila onunggwan ká̱ ochar ova̱ ɗom pa̱ ó na iya̱m inana ka̱kul inok áYawe va̱ nak ka̱ atak áMusa te, oza̱ ɓa ká̱ iya̱m inana iga nɗom ìgwak oza̱ ûYawe.
\s1 UBezalel ká̱ uOholiyap
\p 
\v 30 Te uMusa là ôIsa̱rila pa̱, <<O dər, uYawe yak uBezalel chit uya aUri ukà aHur ka̱ akum ìjili aYahuda.
\v 31 Uza̱ yə́l na chit ká̱ aRuhu Inan, á na aghan á na, ká̱ nkpán ìpir nnap ká̱ nnyi nnəm nza̱ apir inok awo nggo,
\v 32 pa̱ uza̱ á fa ká̱ iya̱m nnəm pa̱ ɗongɗong iga azənariya, ká̱ aazurfa, ká̱ acham arəzang,
\v 33 ká̱ nnyi nggyòk ipáng ka̱kul atak aga ndədat, ká̱ nnyi nkpa akun kang á nnyi nnəm nza̱ apir inok nggo.
\v 34 UYawe nak chit kà̱ igugwak pa̱ uza̱ á ɗyang, uza̱ ká̱ uOholiyap uya aAhisamak ka̱ akum ìjili aDan.
\v 35 Uza̱ yə́l oza̱ chit ká̱ aghan aga nnəm nza̱ apir inok nggo wa nkyen nza̱m, ká̱ nlulok ká̱ afini aga ndəng izər ivyau, ká̱ arəzang pa̱ ga̱r, ká̱ arəzang, ká̱ alinin anəna̱n, kang ká̱ ílukwan ikak. Oza̱ nyi nza̱ apir inok nggo nyi iva mmá ɗuɗom ka̱ ashe inok onəm oga inok.
\c 36
\p 
\v 1 <<Te uBezalel ká̱ uOholiyap ká̱ nza̱ unəm uga aghan nggo uva uYawe na aghan ká̱ nnyi nnəm nza̱ apir inok nggo te, oza á ɗa̱mshi Atak Ayə́ryər wa nva uYawe nak.>>
\p 
\v 2 Te uMusa wór uBezalel ká̱ uOholiyap ká̱ nza̱ unəm nggo nva̱ uYawe na nnyi á na ká̱ aghan aga inok awo, uva lwom na kà̱ ìgwak pa̱ ô ɓa ô nəm inok iva̱ ta.
\v 3 Te oza̱ ka̱m nkpaktak iya̱m iɓutɓut ka̱ atak áMusa iva oIsa̱rila ɓa ká̱ ka̱kul nnəm ka̱ Atak Ayə́ryər. Kang oza̱ ga mpyal ká̱ mɓa ká̱ iya̱m inana iga nɗom ìgwak ûMusa nza̱ ìpin nggo.
\v 4 Te nkpaktak onəm oga nnyi inok awo va̱ ka̱ yà kà̱ nnəm inok ka̱ Atak Ayə́ryər, nza̱ unəm nggo ka̱ atak inok iva̱ oza̱ kà̱ nnənəm re,
\v 5 kang à ɓa là ûMusa pa̱, <<Onəm kà̱ mɓa ká̱ iya̱m inok watar iva̱ mmá ɗom ka̱kul ngba̱l inok va̱ uYawe nak pa̱ mmá nəm.>>
\p 
\v 6 Te uMusa nák nre ga ashe apa̱k pa̱, <<Ónunggwan ká̱ ochar, kang unəm uro a ɓa ká̱ iya̱m inana iro lap ka̱kul nnəm Atak Ayə́ryər ka̱t.>> Nna chit te onəm re mɓa ká̱ iya̱m ɗak.
\v 7 Iya̱m va̱ mmá ɓa ká̱ chit te, mməmak kúr ngba̱l nkpaktak inok va̱ ta aga watar.
\s1 Aghal áYawe
\p 
\v 8 Nkpaktak onəm oga nnyi inok awo va̱ ka̱ ashe onəm oga nnəm inok nəm aghal áYawe. Oza̱ nəm ká̱ oga atani pa̱ agba̱pchi nlòk alinin anəna̱n, ká̱ afini aga ndəng izər ivyau, ká̱ arəzang pa̱ ga̱r, ká̱ arəzang, ká̱ ala̱ka̱n oga akerup ka̱ izəzər va unəm uga nnyi inok awo à nəm.
\v 9 Nza̱ atani nggo te, ngwuwang ashar ìsəm pa̱ ineɗing ama̱n pa̱ aparəm, kang mbəbal ashar pa̱ akpa̱ɗing. Nkpaktak oga atani va̱ ta nrup oza̱ mal izər.
\v 10 Oza̱ gwang atani pa̱ atukun ka̱ izər awan oza̱ yà pa̱ zəng kang aɓo aga atukun uza̱ gwang ka̱ izər awan oza̱ na kpa yà pa̱ zəng.
\v 11 Oza̱ nəm oga mɓol afini ndəng izər ivyau ka̱ anung atani\f + \fr 36.11\fq atani \ft nna oga atani aga atukun ava̱ mmá gwang yà pa̱ zəng.\f* aga nggəshi ka̱ agbai kang à nəm iya̱m zəngtəng va ta ka̱ anung atani apəpar ka̱ agbai.
\v 12 Oza̱ nəm oga mɓol ìsəm pa̱ ìtukun ka̱ apal atani aga nggəshi ka̱ agbai, kang oga mɓol ìsəm pa̱ ìtukun ka̱ arwangchwang atani aga apəpar na oga mɓol va̱ ta á mal ìkwoksok ká̱ owan oza̱.
\v 13 Te oza̱ nəm oga iya̱m iga nkam atani iga azənariya ìsəm pa̱ ìtukun ka̱kul ngwang oga atani ka̱ izər awan oza̱, na aghal áYawe va̱ ta á yà iya̱m pa̱ izəng.
\p 
\v 14 Oza̱ nəm oga atani aga akpap íɓəl pa̱ gba̱pchi ama̱n pa̱ zəng ka̱kul nggún apal ishi aghal áYawe.
\v 15 Nza̱ atani nggo ngwuwang ashar ìsəm pa̱ ìneɗing ama̱n pa̱ atukun kang mbəbal nnyi te ashar pa̱ kpa̱ɗing. Nkpaktak atani aga agba̱pchi ama̱n pa̱ zəng ava̱ ta á mal izər.
\v 16 Oza̱ gwang oga atani pa̱ tukun va̱ ta ka̱ anung zəngtəng kang aga akpa̱ɗing ka̱ anung zəngtəng.
\v 17 Oza̱ nəm oga mɓol ìsəm pa̱ ìtukun ka̱ arwangchwang atani aga nggəshi ka̱ agbai, kang oga mɓol ìsəm pa̱ ìtukun ka̱ aranchwang aga apəpar.
\v 18 Oza̱ nəm oga iya̱m iga nkam atani iga acham arəzang ìsəm pa̱ ìtukun, na á iya̱m iga ndədang pa̱ izəng.
\v 19 Oza̱ nəm iya̱m iga nggún aghal ka̱ awá itám va mmá ɓan ká̱ ǹzazí, kang ká̱ aga ndang apəpal ká̱ awá iɓə́l anəna̱n.
\v 20 Oza̱ nəm oga ndar akasiya aga ntong nzwang ka̱kul aghal áYawe.
\v 21 Nza̱ ngwang ndar va̱ ta nggo te, ashar pa̱ gba̱pchi ama̱n pa̱ tukun, mbəbal ashar pa̱ parəm ká̱ aɓuɓo.
\v 22 Nza̱ ndar nggo te, mmá nəm ká̱ nchak pa̱ mparəm ka̱kul nggwang ngwuwan. Oza̱ nəm nkpaktak oga ndar aghal áYawe wa nnà ta.
\v 23 Oza̱ nəm oga ndar ìsəm pa̱ iparəm ka̱kul asa̱l nkwandal aghal áYawe.
\v 24 Oza̱ nəm oga atak mmùmwak aga aazurfa ìsəm pa̱ ìneɗing ka̱ akum ndar ngga ìsəm pa̱ iparəm va̱ ta. Atak mmùmwak pa̱ mparəm ka̱ akum nza̱ ndar nggo ka̱kul nggwang ncà nggangcà nggang ngga mparəm, kang wa nnà ta, atak mmùmwak pa̱ mparəm ka̱kul oga ǹcà nggang ndar nzəngtəng.
\v 25 Ka̱ ngba̱k asa̱l mpal aghal áYawe te, oza̱ nəm oga ndar ìsəm pa̱ iparəm,
\v 26 ká̱ oga atak mmùmwak aga aazurfa ìsəm pa̱ ineɗing. Atak mmùmwak pa̱ mparəm ka̱ akum nza̱ ndar nggo.
\v 27 Oza̱ nəm oga ndar pa̱ nkpa̱ɗing ka̱ asa̱l nsəm aghal áYawe, ka̱ asa̱l ntar alum.
\v 28 Oza nəm oga ndar nro kà̱ɗi pa̱ mparəm ka̱kul nggulyanggu ngga mparəm ngga nsəm aghal áYawe.
\v 29 Kà̱ nggulyanggu ngga mparəm nva̱ ta oza̱ agwang ka̱ akum kang à pá ìkan á na ka̱ apal á yà iya̱m pa̱ izəng ka̱ apal. Iya̱m va ta̱ oza̱ nəm.
\v 30 Oga ndar nva̱ oza̱ nəm pa̱ kpaktak ka̱ nsəm aghal te, pa̱ nna̱nne ká̱ atak mwak oza̱ ngga aazurfa pa̱ gba̱pchi ama̱n pa̱ kpa̱ɗing, pa̱ mparəm ka̱ akum nza̱ ndar nggo.
\p 
\v 31 Oza̱ nəm oga ndar nnárnàr ngga akun akasiya pa̱ ntukun ka̱kul aghal áYawe ka̱ ngba̱k nggəshi,
\v 32 ndar nnárnàr pa̱ ntukun ka̱kul ngba̱k nzəngtəng, kang ndar nnárnàr pa̱ ntukun ka̱kul nsəm aghal áYawe, ka̱ asa̱l ntar alum.
\v 33 Oza̱ nəm ndar ngga ishimshe nnárnàr, nva ɓan kà̱ ngba̱k nro ga chu nro.
\v 34 Oza ɓam oga ndar nva̱ ta ká̱ azənariya, kang à nəm oga nkalɓang ngga nkpán oga ndar nnárnàr nva̱ ta ká̱ azənariya, kang à ɓam ndar nnárnàr nva̱ ta ká̱ azənariya.
\p 
\v 35 Te oza̱ nəm atani aga afini ndəng izər ivyau, ka̱ arəzang pa̱ ga̱r, ká̱ arəzang, ká̱ alinin anəna̱n. Oza̱ lòk ká̱ ala̱ka̱n oga akerup ka̱ izəzər, inok ánəm uga nnyi inok awo.
\v 36 Oza̱ nəm ndar pa̱ nneɗing ngga akun akasiya kang à ɓam oza̱ ká̱ azənariya, ká̱ iya̱m iga nzùzong ngga azənariya, kang oza̱ nəm atak mwak oza̱ aga aazurfa pa̱ neɗing.
\v 37 Oza̱ nəm atani aga anung asa̱l aghal ká̱ afini aga ndəng izər ivyau, ká̱ arəzang pa̱ ga̱r, ká̱ arəzang, ká̱ alinin anəna̱n, ava mmá lòk ɓyen pa̱ gənggəng.
\v 38 Oza̱ nəm oga ndar pa̱ ntukun ká̱ oga iya̱m iga nzong oza̱. Oza̱ ɓam ishi oza̱ ká̱ iya̱m iga nran oza̱ ká̱ azənariya, kang oza̱ nəm atak mwak oza̱ pa̱ tukun ká̱ acham arəzang.
\c 37
\s1 AKwati
\p 
\v 1 UBezalel nəm akwati aga nsar nnap-nlà ká̱ akun akasiya, ngwuwang ashar pa̱ shatɗing ká̱ aɓuɓo, mbəbal ashar pa̱ parəm ká̱ aɓuɓo, nrurup ashar pa̱ parəm ká̱ aɓuɓo.
\v 2 Uza̱ ɓam ká̱ azənariya anəna̱n ka̱ ashe ká̱ nsəm, kang à me anunung gang ká̱ azənariya.
\v 3 Uza̱ lá oga nkalɓang azənariya pa̱ nneɗing kang à ran oza̱ ká̱ ka̱ ashar aga nneɗing, oga nkalɓang pa̱ parəm nza̱ ngba̱k nggo.
\v 4 Te uza̱ nəm oga ndar akun akasiya kang à ɓam oza̱ ká̱ azənariya.
\v 5 Uza̱ mwak oga ndar nva̱ ta ka̱ ashe oga nkalɓang nva̱ ka̱ oga ngba̱k akwati ka̱kul ǹyəyar.
\p 
\v 6 Te uza̱ nəm anung akwati ava̱ ta ká̱ azənariya anəna̱n, ngwuwang ashar pa̱ shatɗing ká̱ aɓuɓo, kang mbəbal ashar pa̱ parəm ká̱ aɓuɓo.
\v 7 Uza̱ lá oga akerup pa̱ parəm ká̱ azənariya kà̱ nkùr anung arwangchwang akwati ava̱ ta.
\v 8 AKerup pa̱ zəng kà̱ ngba̱k nro, kang akerup pa̱ azəng kà̱ nkùr ngba̱k nzəngtəng. Uza̱ lá oga akerup ká̱ iya̱m izəngtəng ká̱ anunung.
\v 9 Oga akerup ava̱ ta ɓol oga abasəm oza̱ ka̱ apal kuk anung akwati. Asa̱l awu oga akerup va̱ ta i dər owan oza̱ ka̱ apal anung akwati.
\s1 ATebəl
\p 
\v 10 UBezalel nəm atebəl aga akun akasiya, ngwuwang ashar pa̱ shatɗing, mbəbal ashar pa̱ zəng ká̱ aɓuɓo, kang nrurup ashar pa̱ parəm ká̱ aɓuɓo.
\v 11 Uza̱ ɓam izəzər ka̱ azənariya anəna̱n kang à me anunung gang ká̱ azənariya.
\v 12 Uza̱ nəm ìɗər wa mbal awo gang aranchwangranchwang, kang à me azənariya ka̱ apəpal.
\v 13 Uza̱ lá oga nkalɓang azənariya pa̱ nneɗing ka̱kukul, kang uza̱ gwang oza̱ ka̱ izər oga arwangchwang atebəl va̱ ta ka̱ atak ashishar.
\v 14 Oga nkalɓang va̱ ta mmá mwak datkulung ká̱ ìɗər ka̱kul oga ndar ngga ǹyàr atebəl ava̱ ta.
\v 15 Uza̱ nəm oga ndar akun akasiya ka̱kul ǹyàr atebəl, kang à ɓam izər oza̱ ká̱ azənariya.
\v 16 Uza̱ nəm oga iya̱m inok iga apal atebəl pa̱ kpaktak ká̱ azənariya anəna̱n. Omà oga adakdai, ká̱ asu, ká̱ ibəchi, ka̱kul nnak iya̱m inana iwawa.
\s1 ÌDari apitila
\p 
\v 17 Uza̱ nəm idari apitila ka̱ azənariya anəna̱n, uza̱ lá ìjilijili ká̱ idaridari, ká̱ oga ásusu, ká̱ mɓənggúmɓənggum, ká̱ mbəba̱l, ká̱ iya̱m izəngtəng.
\v 18 Idari apitila va̱ ta chak ìgwong pa̱ ìkpa̱ɗing ka̱ izər idari iga ishimshe. Ìgwong pa̱ ishatɗing kà̱ ngba̱k nro kang pa̱ ishatɗing kà̱ ngba̱k nzəngtəng.
\v 19 Ká̱ oga asu pa̱ shatɗing wa mɓənggum mba̱l ka̱ apal ìgwong iga nggəshi, pa̱ ishatɗing kà̱ ìgwong ìro, wa nnà ta kà̱ nkpaktak oga igwong iga ìkpa̱ɗing ka̱ izər idari apitila va̱ ta.
\v 20 Ka̱ izər idari apitila te, oga asu pa̱ neɗing wa mɓənggum, ká̱ mɓənggum, ká̱ oga mba̱l,
\v 21 ká̱ mɓənggum ka̱ avəng nchak igwong iga iparəm ngga nggəshi, mɓənggum ka̱ avəng nchak igwong iga iparəm ngga mparəm, kang mɓənggum ka̱ avəng nchak igwong iga iparəm ngga nshatɗing, wa nnà ta ka̱ anung nchak igwong iga iparəm iga ishatɗing va̱ ta ka̱ izər idari apitila.
\v 22 Nkpaktak oga mɓənggumɓənggum, ká̱ oga igugwong, ká̱ idari apitila mmá lá ká̱ azənariya anəna̱n ká̱ iya̱m izəngtəng.
\p 
\v 23 Uza̱ nəm oga apitila pa̱ fangshat ka̱kul idari apitila, kang uza̱ nəm mɓəmɓəmɓəmɓəm, ká̱ asusu ká̱ azənariya anəna̱n.
\v 24 Uza̱ nəm ìdari apitila va̱ ta ká̱ nkpaktak oga iya̱m inunok ká̱ azənariya va iɗəɗək ashekel ìkalong pa̱ ishatɗing.
\s1 ATak nshì iya̱m awop aga iya̱m inəngnəng ichángchàng
\p 
\v 25 Uza̱ nəm atak nshì iya̱m inəngnəng ichángchàng ká̱ akun akasiya. Ngwuwang ashar pa̱ zəng ká̱ aɓuɓo, mbəbal ashar pa̱ zəng ká̱ aɓuɓo, kang nrurup ashar pa̱ shatɗing. Oga agbəshigbəshi mmá nəm ká̱ iya̱m izəngtəng.
\v 26 Uza̱ ɓam apəpal, ká̱ nkpaktak ngbəgba̱k, ká̱ oga agbəshi ká̱ azənariya anəna̱n, kang à me ìɗər gang arwangchwang.
\v 27 Uza̱ nəm nkalɓang azənariya pa̱ mparəm kà̱ nza̱ ngba̱k nggo kang à mwak ka̱ avəng ìɗər ka̱kul oga ndar ngga ǹyəyar.
\v 28 Uza̱ nəm oga ndar ngga ǹyəyar kang à ɓam ká̱ azənariya.
\p 
\v 29 Te uza̱ nəm mmì nyə́ryər ngga nggor, ká̱ iya̱m inəngnəng ichángchàng, inok ánəm uga nggwang iya̱m inə́ngnəng ichángchàng kpa.
\c 38
\s1 ATak nshì iya̱m awop aga nshì iya̱m inana
\p 
\v 1 UBezalel nəm atak nshi iya̱m awop aga nshì iya̱m inana ká̱ akun akasiya, ngwuwang ashar pa̱ fangshat ká̱ aɓuɓo, mbəbal ashar pa̱ fangshat ká̱ aɓuɓo, kang nrurup ashar pa̱ neɗing ká̱ aɓuɓo.
\v 2 Uza̱ nəm agbəshi pa̱ zəng kà̱ nza̱ nggulyanggugulyanggu ngga nneɗing nggo, oga agbəshi va̱ ta ká̱ atak nshì iya̱m awop yà iya̱m zəngtəng, kang uza̱ ɓam ka̱ acham arəzang.
\v 3 Te uza̱ nəm oga iya̱m inok ka̱kul atak nshì iya̱m awop va̱ ta, omà oga ngbət, ká̱ oga ashefər, ká̱ oga asu, ká̱ oga iga̱pchi iga ifang, ká̱ oga asu apər. Nkpaktak oza̱ nnəm acham arəzang.
\v 4 Uza̱ nəm alariya ká̱ acham arəzang pá ka̱ akum alə̀gər nkap ishimshe atak nshì iya̱m awop.
\v 5 Te uza̱ lá nkalɓang pa̱ nneɗing kà̱ nggulyanggu ngga nneɗing ká̱ izər alariya aga acham arəzang va̱ ta ka̱kul nkpán oga ndar.
\v 6 Uza̱ nəm oga ndar ká̱ akun akasiya kang à ɓam oza̱ ka̱ acham arəzang.
\v 7 Te uza̱ mwak oga ndar va̱ ta ká̱ ashe oga nkalɓang ká̱ ngba̱k atak nshì iya̱m awop ka̱kul ǹyəyar. Uza̱ nəm atak nshì iya̱m awop va̱ ta awulong ká̱ akun.
\s1 ASu ka̱kul nnàl awo ká̱ ashar
\p 
\v 8 Kang uza̱ nəm asu aga acham arəzang ka̱kul nnàl awo ká̱ ashar kang izəzan iga acham arəzang ka̱ atak oga agəlat ochar va i nəm inok ka̱ anung Aghal Mɓut.
\s1 AGəla̱n
\p 
\v 9 UBezalel nəm agəla̱n ava mmá ká ká̱ atani aga alinin anəna̱n. Ka̱ asa̱l nkwandal te, ngwuwang ashar ìgba̱l pa̱ izəng ká̱ ìsəm pa̱ ìtukun.
\v 10 Uza̱ nəm oga ndar ka̱kul atani ìsəm pa̱ ìparəm ká̱ oga atak mmùmwak ngga acham arəzang ìsəm pa̱ ìparəm, kang ká̱ oga iya̱m iga nzuzong ká̱ iga nrəran iga aazurfa.
\v 11 Uza̱ nəm oga atani aga asa̱l mpal, ngwuwang ashar igba̱l ka̱ ìsəm pa̱ ìtukun na kpa, ká̱ oga ndar oza̱ ìsəm pa̱ iparəm, ka̱ oga atak mmwàk oza̱ ngga acham arəzang ìsəm pa̱ iparəm, kang ká̱ oga iya̱m iga nzuzong, ká̱ iga nrəran iga aazurfa.
\v 12 Uza̱ nəm oga atani ava̱ ka̱ asa̱l ntar alum, mbəbal ashar ìsəm pa̱ ìfangshat ama̱n pa̱ tukun, ká̱ oga ndar oza̱ pa̱ ngba̱pchi, ká̱ oga atak mmùmwak pa̱ ngba̱pchi, kang ká̱ oga iya̱m iga nzuzong ká̱ iga nrəran iga aazurfa.
\v 13 Ka̱ asa̱l nfa alum te, mbəbal ashar ìsəm pa̱ ifangshat ama̱n pa̱ tukun.
\v 14 Kà̱ ngba̱k ngga nzəng ngga asa̱l aga ntar uza̱ nəm oga atani aga nzuzong, ngwuwang ashar ìsəm pa̱ ìparəm ama̱n pa̱ parəm ká̱ aɓuɓo, ká̱ oga ndar oza̱ pa̱ nshatɗing ká̱ atak mmwàk oza̱ pa̱ nshatɗing.
\v 15 Kang kà̱ ngba̱k nzəntəng, uza̱ nəm oga atani ngwuwang ashar ìsəm pa̱ ìparəm ama̱n pa̱ parəm ká̱ aɓuɓo, ká̱ oga ndar oza̱ pa̱ nshatɗing ká̱ oga atak mmwàk oza̱ pa̱ nshatɗing.
\v 16 Nkpaktak oga atani va̱ gáng agəla̱n aghal va̱ ta mmá nəm ká̱ alinin aloklòk anəna̱n.
\v 17 Oga atak mmwàk oga ndar va̱ ta mmá nəm ká̱ acham arəzang, ká̱ oga atak nzuzong ká̱ oga iya̱m iga nrəran iga aazurfa. Apal oza̱ mmá ɓam ká̱ aazurfa, kang nkpaktak oga ndar agəla̱n va̱ ta mmá ran ká̱ oga nkalɓang ngga aazurfa.
\v 18 Uza̱ nəm atani aga anung asa̱l agəla̱n va̱ ta uza̱ lok ká̱ alinin anəna̱n aga ndəng izər ivyau, ká̱ nrəzang pa̱ ga̱r, ká̱ arəzang, ká̱ alinin anəna̱n, kang ngwuwang ashar ìsəm pa̱ ishatɗing kang nrurup ashar pa̱ ìfangshat ká̱ aɓuɓo wa nrup atani aga agəla̱n.
\v 19 Mmá təp atani ava̱ ta ká̱ ndar pa̱ nneɗing ká̱ atak aga mmwàk oza̱ ngga acham arəzang, ká̱ oga iya̱m iga nzong oza̱, ká̱ iga nrəran iga aazurfa, kang mmá ɓam apal oza̱ ká̱ aazurfa.
\v 20 Nkpaktak oga iya̱m iva̱ mmá mpak aghal áYawe ká̱, kang ká̱ agəla̱n te, mmá nəm ká̱ acham arəzang.
\s1 OGa iya̱m va̱ mmá nəm inok ká̱
\p 
\v 21 Ǹlir ìyəl oga iya̱m iga nəm aghal áYawe nnà ta̱, aghal aga nnap mpakpak nva uMusa nak mmá lir. UMusa nak oLawi ova ka̱ nəm inok ka̱ avəng aItama uya aHaruna, unəm uga mpyal awop, pa̱ á lir ìyəl iya̱m iga nəm aghal áYawe.
\v 22 UBezalel uya aUri, ukà aHur, uga akum aYahuda, nəm nkpaktak iya̱m iva̱ uYawe là ûMusa.
\v 23 Nzəng ká̱ unəm uga ka̱m ishishi, uOholiyap uya aAhisamak uga akum aDan, unəm uga nnyi nggyok iya̱m, nlir nza̱m iya̱m, ká̱ nlok iya̱m ká̱ afini ndəng izər ivyau, ká̱ nrəzang pa̱ ga̱r, ká̱ arəzang, ká̱ alinin anəna̱n.
\v 24 Nkpaktak azənariya va̱ mmá me Atak Ayə́ryər ká̱ te, ka̱ ashe iya̱m inana iga ǹyegye, iɗəɗək ashekel ìkalong ìsəm pa̱ ìna̱nne ama̱n pa̱ fangshat ka̱ ashekel ìgba̱l pa̱ ìfangshat ka̱ ìsəm pa̱ ishatɗing, á mal ká̱ ashekel aga Atak Ayə́ryər.
\p 
\v 25 Ìyəl aazurfa va̱ mmá ya ka̱ atak nkung ìyəl mɓut oIsa̱rila te, iɗəɗək ashekel ìkalong ìgba̱l pa̱ ishatɗing ká̱ ama̱n pa̱ zəng, ká̱ ìgba̱l pa̱ ìfangshat ká̱ ìsəm pa̱ ifangshat ama̱n pa̱ tukun, á mal ká̱ ashekel aga Atak Ayə́ryər.
\v 26 Nza̱ unəm nggo na abəka pa̱ azəng, nna aɓo ashekel ka̱ atak mmák ashekel aga Atak Ayə́ryər, ka̱ anung á nza̱ unəm nggo va mmá lir ka̱ ashe nkung iyəl onəm oga ìkalong ìgba̱l pa̱ ìkpa̱ɗing ká̱ ama̱n pa̱ shatɗing, ká̱ ìgba̱l pa̱ ìtukun ká̱ ìsəm pa̱ ìtukun, á ɓan kà̱ unəm uga ìzun ìsəm pa̱ ìparəm.
\v 27 Mmá nəm inok ká̱ aazurfa ava ìɗəɗək ashekel ìkalong ìgba̱l pa̱ ishatɗing, nkpaktak oga atak aga mwak oga ndar ngga Atak Ayə́ryər ká̱ atani aga Atak Ayə́ryər ìgba̱l pa̱ ìzəng. Ìɗək ashekel ìkalong pa̱ ishatɗing iga aazurfa ka̱kul nza̱ atak mmwak nggo.
\v 28 Aɓo ashekel aga ìkalong pa̱ ìzəng ká̱ ìgba̱l pa̱ ìfangshat ká̱ ìsəm pa̱ ìfangshat ama̱n pa̱ tukun te, uBezalel nəm oga iya̱m iga nzong oga ndar ká̱ oga iya̱m iga nran oza̱ ká̱, kang á ɓam oga apal ndar.
\p 
\v 29 Acham arəzang iya̱m inana iga ǹyegye va̱ mmá ɓa ká̱ te, iɗəɗək ashekel ìkalong ìgba̱l pa̱ ìparəm ká̱ ugba̱pchi ama̱n pa̱ parəm ká̱ ìgba̱l pa̱ ineɗing.
\v 30 Ká̱ nnà ta uza̱ nəm oga atak mmwàk ka̱kul oga ndar ngga anung asa̱l aga aghal aYawe, ká̱ atak nshì iya̱m awop aga acham arəzang, ká̱ alariya aga acham arəzang, ká̱ nkpaktak iya̱m inunok,
\v 31 ká̱ oga atak mmwàk gang nkpaktak agəla̱n, ká̱ oga atak mmwàk atani ka̱ anung asa̱l aga ntar agəla̱n, ká̱ nkpaktak oga iya̱m iga mpak aghal áYawe, ká̱ agəla̱n.
\c 39
\s1 OGa ilukwan ánəm uga mpyal awop
\p 
\v 1 Onəm oga nnəm inok awo nəm oga ilukwan iyə́ryər inəna̱n iga ndəng izər ivyau, ká̱ nrəzang pa̱ ga̱r, ká̱ nrəzang iva unəm uga mpyal awop í pa ka̱kul nnəm inok ka̱ ashe Atak Ayə́ryər. Oza̱ nəm oga ilukwan iyə́ryər ka̱kul áHaruna, wa nva uYawe nak uMusa.
\s1 ÌLukwan ìkwoksok
\p 
\v 2 Oza̱ nəm ìlukwan ìkwoksok iga azənariya ká̱ afini aga ndəng izər ivyau, ká̱ nrəzang pa̱ ga̱r, ká̱ nrəzang, ká̱ alinin anəna̱n.
\v 3 Oza̱ lá azənariya pa̱ pileppilep kang oza̱ cha pa̱ səlen wa afini ka̱kul ntat kà̱ ishimshe alinin anəna̱n, kang ká̱ ishimshe ndəng izər ivyau, ká̱ nrəzang pa̱ ga̱r, kang ká̱ afini arəzang, inok ánəm uga aghan.
\v 4 Oza̱ nəm iya̱m iga apal agar pa̱ mparəm ka̱kul ìlukwan ìkwoksok kang ɓam ka̱ ngba̱kgba̱k n ngga mparəm ka̱kul nrəran.
\v 5 Oza̱ nəm ngbat nnəna̱n ngga nrán ìlukwan ìkwoksok va̱ ta ká̱ iya̱m inok izəngtəng ká̱ azənariya, kang ká̱ afini aga ndəng izər ivyau, ká̱ nrəzang pa̱ ga̱r, ká̱ nrəzang, kang ká̱ alinin anəna̱n, wa nva uYawe nak uMusa.
\p 
\v 6 Oza̱ da̱mshi oga ipáng iza̱mza̱m ká̱ iya̱m iga nkpán oza̱ iga azənariya. Te oza̱ gyok aɗin ovan oIsa̱rila ka̱ apəpal.
\v 7 Te oza̱ ran oza̱ ka̱ apal iya̱m iga apal agar ìlukwan ìkwoksok, ipáng iga nrəng ká̱ akum oIsa̱rila pa̱ ìgba̱pchi ama̱n pa̱ parəm, wa nva uYawe nak uMusa.
\s1 Ìya ìlukwan ìkwoksok
\p 
\v 8 Oza̱ nəm ìya ìlukwan ìkwoksok ka̱ iya̱m inok izəngtəng iva mmá nəm ìlukwan ìkwoksok ká̱, ká̱ azənariya, kang ká̱ afini aga ndəng izər ivyau, ká̱ nrəzang pa̱ ga̱r, ká̱ arəzang, ká̱ alinin aloklòk anəna̱n.
\v 9 Oza̱ nəm ìya ìlukwan ìkwoksok va̱ ta, te mmá kup ngwuwang ká̱ mbəbal mal izər ká̱ mbal awo.
\v 10 Te oza̱ nəm atak ndàt ipang inəna̱n pa̱ nneɗing ka̱ apəpal. Ka̱ atak mwak ngga nggəshi te, ìpang irəzang iva̱ i ya atak pa̱ halakhalak, ká̱ ìpang iga ndəng ilur, kang ká̱ ìpang iga ndəng agwal ikun,
\v 11 ka̱ atak ndàt ngga mparəm te, ìpang iga ndəng izər ivyau, ká̱ ìpang ìkámkám, kang ká̱ ìpang ìfərfər wa apye.
\v 12 Kà̱ atak ndàt ngga nshatɗing te, ìpang iga ndəng ishàn, ká̱ ìpang ndəng awar agba̱k, kang ká̱ ìpang irəzang pa̱ ga̱r.
\v 13 Kang atak ndàt ngga nneɗing te, ìpang iga ndəng ilyanggu, ká̱ ìpang iza̱mza̱m, kang ká̱ ìpang iga ndəng ipəpa. Nkpaktak oga ipang va̱ ta̱ mmá mwak ka̱ ashe iya̱m iga nkpəkpán iga azənariya.
\v 14 Nza̱ ìpang nggo iga igba̱pchi ama̱n pa̱ parəm va̱ ta ka̱ anung aɗin ovan oIsa̱rila, kang nza̱ ìpang nggo mmá gyok aɗin akum pa̱ zəng ka̱ izəzər wa asitam.
\p 
\v 15 Oza̱ nəm oga nzwar ngga azənariya anəna̱n ka̱kul ìya ìlukwan ìkwoksok.
\v 16 Kang oza̱ nəm nkalɓang ngga azənariya pa̱ mparəm, ká̱ iya̱m iga nkpəkpán pa̱ iparəm, kang oza̱ mwak nkalɓang nva̱ ta kà̱ nggulyanggu ngga mparəm ngga apal ìya ìlukwan ìkwoksok.
\v 17 Te oza̱ ran oga nzwar azənariya ngga mparəm va̱ ta kà̱ mɓol nkalɓang ngga mparəm nva̱ kà̱ nggulyanggu ìya ìlukwan ìkwoksok,
\v 18 kang kà̱ ngba̱k ngga mparəm ngga anung oga nzwar nva̱ ta, oza̱ ran ka̱ izər iya̱m iga nkpəkpán kang oza̱ ran ka̱ iya̱m iga apal agar aga ìlukwan ìkwoksok ka̱ asa̱l mpyal.
\v 19 Te oza̱ nəm oga nkalɓang ngga azənariya pa̱ mparəm mwak kà̱ nggulyanggu ngga mparəm ngga asa̱l avəng ka̱ ashe aga ìya ìlukwan ìkwoksok dat ká̱ ìlukwan ìkwoksok.
\v 20 Oza̱ nəm oga nkalɓang azənariya pa̱ mparəm, kang oza̱ ran ka̱ asa̱l mpyal iya̱m iga apal agar ìlukwan ìkwoksok a datkulung ka̱ atak ngguwang kang ka̱ asa̱l apal ngbat.
\v 21 Te oza̱ ran oga nkalɓang ngga ìya ìlukwan ìkwoksok ká̱ oga nkalɓang ngga ìlukwan ìkwoksok ká̱ asang ngga ndəng izər ivyau, ka̱ asa̱l apal ngbat ngga nran ìlukwan ìkwoksok, na kang ìya ìlukwan ìkwoksok a ra nggang ka̱ izər ìlukwan ìkwoksok ka̱t, wa nva uYawe nak uMusa.
\s1 OGa ilukwan ánəm uga mpyal awop iro
\p 
\v 22 Uza̱ nəm ìlukwan iwangwang iga avəng ìlukwan ìkwoksok ká̱ ìlukwan iga ndəng izər ivyau, inok ánəm uga nlok iya̱m.
\v 23 Mmá re mɓol kà̱ ishimshe ìlukwan iwangwang iva̱ ta wa mɓol ishak ìlukwan, mmá lok ishishak á gang pa̱ lat ka̱kul kang a cha ka̱t.
\v 24 Oza̱ nəm awar ikumkum ká̱ afini aga ndəng izər ivyau, ká̱ nrəzang pa̱ ga̱r, ká̱ arəzang kà̱ nkur ìlukwan iwangwang.
\v 25 Oza̱ nəm iɓa̱ngga̱ng ká̱ azənariya anəna̱n mwak kà̱ mbagar awar ikumkum gang kà̱ nkur ìlukwan iwangwang kà̱ ishimshe ikumkum iva̱ ta.
\v 26 Oza̱ dat iɓa̱ngga̱ng iva̱ ta ká̱ awar ikumkum kà̱ ishimshe owan oza̱ gang nkpaktak akum ìlukwan iwangwang iva̱ ta iga nnəm inok ánəm uga mpyal awop, wa nva uYawe nak uMusa.
\p 
\v 27 Oza̱ nəm ilukwan iga ashe iga alinin anəna̱n ûHaruna ká̱ ovəvan onunggwan, inok ánəm uga nlok iya̱m,
\v 28 ká̱ iya̱m ishi inəna̱n ka̱kul aHaruna kang ká̱ oga iya̱m ishi ka̱kul ovəvan aga alinin anəna̱n, ká̱ ìlukwan iga ashe nlok alinin anəna̱n,
\v 29 ká̱ ngbat nlòk alinin anəna̱n ká̱ afini aga ndəng izər ivyau, ká̱ nrəzang pa̱ ga̱r, ká̱ arəzang, inok ánəm uga nlok iya̱m, wa nva uYawe nak uMusa.
\p 
\v 30 Oza̱ nəm achuchwal iya̱m ishi anəna̱n aga azənariya te gyok iya̱m nlir ka̱ izəzər pa̱, <<UNəna̱n ûYawe.>>
\v 31 Te oza̱ pá asang aga ndəng izər ivyau kà̱ ka̱kul nran ka̱ apal iya̱m ishi, wa nva uYawe nak uMusa pa̱ á nəm.
\s1 UMusa song aghal áYawe
\p 
\v 32 Wa nnà ta nkpaktak inok aghal áYawe, Aghal Mɓut á kur. OIsa̱rila nəm iza̱ nggo, wa nva uYawe nak uMusa.
\v 33 Te oza̱ ɓa ka̱ aghal áYawe ava̱ ta ûMusa, aghal ká̱ oga iya̱m inunok, oga iya̱m iga nzuzong, ká̱ oga ndar nsungsung, ká̱ oga ndar nnárnàr, ká̱ oga ndar, ká̱ oga atak mmùmwak,
\v 34 ká̱ oga awá inagam aga nggugún ava mmá ɓán ká̱ ǹzazí, ká̱ oga awá anəna̱n, ká̱ atani aga nká atak,
\v 35 ká̱ akwati aga nsar nnap-nlà ká̱ nkpá nggankpá nggang, ká̱ anunung,
\v 36 ká̱ atebəl ká̱ nkpaktak iya̱m inunok ka̱ nzəngkəng aYawe,
\v 37 ká̱ idari apitila iga azənariya anəna̱n, ká̱ oga apitilapitila, ká̱ nkpaktak iya̱m inunok, ká̱ mmì oga apitila,
\v 38 ká̱ atak nshì iya̱m awop aga azənariya, ká̱ mmì ngga nggar, ká̱ inə́ngnəng ichángchàng kang ká̱ atani aga anung asa̱l aghal,
\v 39 ká̱ atak nshì iya̱m awop aga acham arəzang, ká̱ alariya aga acham arəzang, ká̱ oga nkpà nggankpá nggang, ká̱ nkpaktak iya̱m inunok, ká̱ asu, ká̱ izəzan,
\v 40 ká̱ oga atani aga agəla̱n, ká̱ oga ndədar, ká̱ oga atak mmùmwak, ká̱ atani aga anung asa̱l agəla̱n, ká̱ oga asəsang, ká̱ oga iya̱m iga mpak aghal, ká̱ nkpaktak iya̱m iga nnəm inok ka̱ atak Aghal Mɓut,
\v 41 ká̱ ilukwan iloklok inəna̱n ka̱kul nnəm inok ka̱ ashe Atak Ayə́ryər, ilukwan iyə́ryər ka̱kul áHaruna unəm uga mpyal awop ká̱ ìlukwan ka̱kul ovəvan na oza̱ á nəm inok onəm oga nshì iya̱m awop ká̱.
\p 
\v 42 OIsa̱rila nəm nkpaktak oga inok iva̱ uYawe nak uMusa.
\v 43 UMusa song nkpaktak inok te, á ya oza̱ nəm dakdak wa nva uYawe nak. Te uMusa nak nnap nnəna̱n ôza̱.
\c 40
\s1 MPak aghal áYawe
\p 
\v 1 Te uYawe là ûMusa pa̱,
\v 2 <<Pak aghal áYawe, Aghal Mɓut kà̱ nra ngga nggəshi ka̱ ashe apye aga azəng.
\v 3 Te wa nak akwati aga nsar nnap-nlà ka̱ ashishe wa gún ká̱ atani.
\v 4 Wa ɓa ká̱ atebəl kang ɓu dàt oga iya̱m inok ka̱ apəpal, kang ɓu ɓa ká̱ idari apitila kang ɓu chwong oga apitila ka̱ apəpal.
\v 5 Te wa nak atak nshì iya̱m inəngnəng iga azənariya kà̱ mpyal akwati aga nsar nnap-nlà kang ɓu zong atani aga anung asa̱l aghal áYawe.
\p 
\v 6 <<Wa nak atak nshì iya̱m inana iga nshì pa̱ ɗwot kà̱ anung asa̱l aghal áYawe, Aghal Mɓut.
\v 7 Wa cher asu kà̱ ishimshe Aghal Mɓut ká̱ atak nshì iya̱m awop, kang ɓu yə́l ndəng ka̱ ashishe.
\v 8 Wa ká agəla̱n á gang pa̱ kpaktak kang ɓu zong atani aga anung agəla̱n kà̱.
\p 
\v 9 <<Te wa yar mmì ngga nggor na u gor aghal áYawe ká̱ nkpaktak oga iya̱m inok iva̱ ka̱ ashishe, na oza̱ á yà iya̱m iyə́ryər.
\v 10 Wa shang mmì ngga nggugor ka̱ apal atak nshì iya̱m inana iga nshì ká̱ nkpaktak iya̱m inunok na u gòr atak nshì iya̱m awop á yà atak nshì iya̱m awop ayə́ryər ava ji.
\v 11 Te wa gòr asu ká̱ izəzan, na u gar oza̱.
\p 
\v 12 <<Wa ɓa ká̱ uHaruna ká̱ ovəvan ka̱ anung Aghal Mɓut, na u wòr oza̱ ká̱ ndəng.
\v 13 Te wa mwak ìlukwan iyə́ryər ûHaruna kang ɓu gor na, ɓu gar na uza̱ i yà unəm uga mpyal awop mi.
\v 14 Wa ɓa ká̱ ovəvan wa mwak ilukwan iga ashe ôza̱,
\v 15 Gor oza̱ wa nva u gor upo oza̱, na oza̱ á yà onəm oga mpyal awop á mi. I yà óza̱ nggor ngga akum onəm oga mpyal awop mbyet mbyet ka̱kul oga nlwàk oza̱ ngga mɓa.>>
\v 16 Te uMusa nəm nkpaktak iya̱m va̱ uYawe nak na kà̱. Wa nnà ta uza̱ nəm.
\p 
\v 17 Te mmá pak aghal áYawe ka̱ apal nra ngga nggəshi ka̱ apye aga zəng ka̱ ashe ìzun iga iparəm.
\v 18 UMusa pak aghal áYawe, à dat oga atak mwak ndar, kang uza̱ mwak oga ndədar, ká̱ oga ndar nnárnàrnárnàr, kang à gha̱p oga ndədar.
\v 19 Uza̱ nàr atani aga akpap íɓəl ka̱ apal aghal áYawe kang à nak iya̱m iga nggugún iga awá ka̱ apəpal, wa nva uYawe nak uMusa.
\p 
\v 20 Uza̱ yar oga achuchwal ipang iga nsar nnap-nlà kang à nak oza̱ ka̱ ashe akwati. Te uza̱ mwak oga ndar ka̱ ashe oga nkalɓang ka̱ izər akwati ava̱ ta, kang uza̱ nak anung akwati ava̱ ta ka̱ apəpal.
\v 21 Uza̱ tar ká̱ akwati aga nsar nnap-nlà ka̱ ashe aghal, te uza̱ zong atani aga nká atak akwati aga nsar nnap-nlà wa nva uYawe nak uMusa.
\p 
\v 22 Uza̱ nak atebəl ka̱ ashe Aghal Mɓut ka̱ asa̱l mpal aghal kà̱ mpyal atani.
\v 23 Te uza̱ dàt nzəngkəng ka̱ apal atebəl kà̱ mpyal aYawe, wa nva uYawe nak uMusa.
\p 
\v 24 Uza̱ cher idari apitila ka̱ asa̱l nkwandal ka̱ ashe Aghal Mɓut, mal ìkwoksok ká̱ atebəl.
\v 25 Te uza̱ ma̱l oga apitila kà̱ mpyal aYawe, wa nva uYawe nak uMusa.
\p 
\v 26 Uza̱ nak atak nshì iya̱m awop aga azənariya ka̱ ashe Aghal Mɓut kà̱ mpyal atani,
\v 27 te uza̱ shì iya̱m inəngnəng ichángchàng ka̱ apəpal, wa nva uYawe nak uMusa.
\v 28 Uza̱ zong atani ka̱ anung aghal áYawe.
\p 
\v 29 Uza̱ nak atak nshì iya̱m inana iga nshì ka̱ anung asa̱l Aghal Mɓut, te uza̱ yichi iya̱m inana iga nshì pa̱ ɗwot ká̱ iga ìpirkur ka̱ apəpal, wa nva uYawe nak uMusa.
\p 
\v 30 Uza̱ cher asu ká̱ ishimshe Aghal Mɓut ká̱ atak nshì iya̱m awop, te uza̱ nak ndəng ka̱ ashishe.
\v 31 UMusa ká̱ uHaruna ká̱ ovan aHaruna i nàl awo ká̱ ashar oza̱ ká̱.
\v 32 Awalang ava̱ oza̱ i tar Aghal Mɓut kang awalang ava̱ oza̱ i dat atak nshì iya̱m awop te, oza̱ i nàl awo ká̱ ashar oza̱, wa nva uYawe nak uMusa.
\p 
\v 33 Te uMusa dàt agəla̱n gang nkpaktak aghal ká̱ atak nshì iya̱m awop, te uza̱ zong atani ka̱ anung agəla̱n va̱ ta. Wa nnà ta uMusa gba̱l ká̱ inok iva̱ ta.
\s1 Ìzhàn áYawe
\p 
\v 34 Te ìlulu gún Aghal Mɓut, kang ìzhàn aYawe yə́l ashe aghal áYawe.
\v 35 UMusa chu ntar ashe Aghal Mɓut nva̱ ta ka̱t, ka̱kul ìlulu dàngchi apəpal, kang ìzhàn aYawe yə́l ashe aghal áYawe.
\p 
\v 36 Nkpaktak awalang va̱ ìlulu i wong ka̱ apal aghal ava̱ ta te, oIsa̱rila i wong achen oza̱.
\v 37 A yà pa̱ ìlulu ya wong chit ka̱t te, oza̱ i wong ka̱t, ya nda va ìlulu i wong kang.
\v 38 Ka̱kul ìlulu aYawe ka̱ yà ka̱ apal aghal ká̱ alum kang apər ka̱ ashishe ká̱ ìzwam, kà̱ iwu nkpaktak nzhi aIsa̱rila ka̱ ashe nkpaktak achen oza̱.
