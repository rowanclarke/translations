\v 30  \w As|strong="H5927"\w* \w David|strong="H1732"\w* \w was|strong="H1732"\w* \w going|strong="H1980"\w* \w up|strong="H5927"\w* \w the|strong="H3605"\w* \w Mount|strong="H5927"\w* \w of|strong="H7218"\w* \w Olives|strong="H2132"\w*, \w he|strong="H1931"\w* \w was|strong="H1732"\w* \w weeping|strong="H1058"\w* \w as|strong="H5927"\w* \w he|strong="H1931"\w* \w went|strong="H1980"\w*; \w his|strong="H3605"\w* \w head|strong="H7218"\w* \w was|strong="H1732"\w* \w covered|strong="H2645"\w* \w and|strong="H1980"\w* \w his|strong="H3605"\w* feet \w were|strong="H5971"\w* bare. \w All|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* \w who|strong="H3605"\w* \w were|strong="H5971"\w* \w with|strong="H1980"\w* \w him|strong="H1931"\w* \w also|strong="H1732"\w* \w had|strong="H1732"\w* \w their|strong="H3605"\w* \w heads|strong="H7218"\w* \w covered|strong="H2645"\w* \w and|strong="H1980"\w* \w were|strong="H5971"\w* \w weeping|strong="H1058"\w* \w as|strong="H5927"\w* \w they|strong="H5971"\w* \w went|strong="H1980"\w* \w up|strong="H5927"\w*.  
