\v 22 \w Entonces|strong="H3588"\w* \w Josué|strong="H3091"\w* respondió al \w pueblo|strong="H5971"\w*: Ustedes \w son|strong="H3588"\w* \w testigos|strong="H5707"\w* contra ustedes mismos \w en|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w a|strong="H3068"\w* \w que|strong="H3588"\w* \w se|strong="H5971"\w* eligieron \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w para|strong="H3588"\w* servirle. Ellos respondieron: ¡Somos \w testigos|strong="H5707"\w*!   
\p
\v 23 ¡Aparten, \w pues|strong="H6258"\w*, los \tl ʼelohim\tl* extraños \w que|strong="H6258"\w* hay \w entre|strong="H7130"\w* ustedes, \w e|strong="H3068"\w* inclinen su \w corazón|strong="H3824"\w* hacia \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* de \w Israel|strong="H3478"\w*!   
\p
\v 24 \w Y|strong="H3068"\w* el \w pueblo|strong="H5971"\w* respondió \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*: ¡\w A|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd* \w serviremos|strong="H5647"\w* y \w obedeceremos|strong="H8085"\w*!   
\p
\v 25 \w Así|strong="H1931"\w* \w Josué|strong="H3091"\w* \w pactó|strong="H1285"\w* \w alianza|strong="H1285"\w* con \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* y \w le|strong="H1931"\w* estableció \w Estatutos|strong="H2706"\w* y Decretos en Siquem.  
\v 26 Luego \w Josué|strong="H3091"\w* \w escribió|strong="H3789"\w* estas \w palabras|strong="H1697"\w* \w en|strong="H8478"\w* el Rollo \w de|strong="H8478"\w* la \w Ley|strong="H8451"\w* \w de|strong="H8478"\w* \nd ʼElohim\nd*. \w Y|strong="H3068"\w* \w tomó|strong="H3947"\w* una \w gran|strong="H1419"\w* piedra y la \w erigió|strong="H6965"\w* \w allí|strong="H8033"\w*, \w debajo|strong="H8478"\w* del roble \w que|strong="H1697"\w* estaba junto \w al|strong="H8478"\w* \w Santuario|strong="H4720"\w* \w de|strong="H8478"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 27 \w Josué|strong="H3091"\w* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w*: \w Ciertamente|strong="H3588"\w* \w esta|strong="H2063"\w* piedra \w será|strong="H1961"\w* \w testigo|strong="H5713"\w* \w contra|strong="H5973"\w* \w nosotros|strong="H3605"\w*, \w pues|strong="H3588"\w* \w ella|strong="H1931"\w* \w oyó|strong="H8085"\w* \w todas|strong="H3605"\w* las \w palabras|strong="H1696"\w* \w que|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nos \w dijo|strong="H1696"\w*. \w Será|strong="H1961"\w*, \w pues|strong="H3588"\w*, \w testigo|strong="H5713"\w* \w contra|strong="H5973"\w* ustedes \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H6435"\w* renieguen \w de|strong="H3588"\w* \w su|strong="H1931"\w* \nd ʼElohim\nd*.   
\p
\v 28 Luego \w Josué|strong="H3091"\w* \w despidió|strong="H7971"\w* al \w pueblo|strong="H5971"\w* y \w mandó|strong="H7971"\w* \w a|strong="H3068"\w* cada uno \w a|strong="H3068"\w* su \w heredad|strong="H5159"\w*.   
\p
\v 29 \w Después|strong="H1961"\w* \w de|strong="H1121"\w* estas \w cosas|strong="H1697"\w*, \w sucedió|strong="H1961"\w* \w que|strong="H1697"\w* \w murió|strong="H4191"\w* \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w*, esclavo \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*,\nd* \w a|strong="H3068"\w* la \w edad|strong="H8141"\w* \w de|strong="H1121"\w* 110 \w años|strong="H8141"\w*.  
\v 30 Lo \w sepultaron|strong="H6912"\w* \w en|strong="H6912"\w* el límite de su \w heredad|strong="H5159"\w* \w en|strong="H6912"\w* Timnat-sera, que está \w en|strong="H6912"\w* \w la|strong="H1366"\w* región montañosa de Efraín, al \w norte|strong="H6828"\w* de \w la|strong="H1366"\w* montaña \w Gaas|strong="H1608"\w*.   
\p
\v 31 \w Israel|strong="H3478"\w* \w sirvió|strong="H5647"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* de \w Josué|strong="H3091"\w*, y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* de \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* \w que|strong="H3045"\w* sobrevivieron \w a|strong="H3068"\w* \w Josué|strong="H3091"\w* y \w que|strong="H3045"\w* \w conocían|strong="H3045"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4639"\w* \w que|strong="H3045"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w hizo|strong="H6213"\w* por \w Israel|strong="H3478"\w*.   
\p
\v 32 \w Los|strong="H1121"\w* \w huesos|strong="H6106"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*, \w que|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w habían|strong="H1961"\w* \w subido|strong="H5927"\w* \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w*, \w fueron|strong="H1961"\w* \w sepultados|strong="H6912"\w* \w en|strong="H6912"\w* Siquem, \w en|strong="H6912"\w* la porción del \w campo|strong="H7704"\w* \w que|strong="H1121"\w* \w Jacob|strong="H3290"\w* \w compró|strong="H7069"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hamor|strong="H2544"\w*, padre \w de|strong="H1121"\w* Siquem, \w por|strong="H7069"\w* 100 monedas, y así \w quedó|strong="H1961"\w* \w en|strong="H6912"\w* \w posesión|strong="H5159"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*.   
\p
\v 33 Eleazar, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Aarón, también \w murió|strong="H4191"\w*, y lo \w sepultaron|strong="H6912"\w* \w en|strong="H6912"\w* la colina \w de|strong="H1121"\w* su \w hijo|strong="H1121"\w* Finees, \w que|strong="H1121"\w* le fue \w dada|strong="H5414"\w* \w en|strong="H6912"\w* la región montañosa \w de|strong="H1121"\w* Efraín.   