\v 137 \qac V\qac*z-nqblq-zvzq nzmncngr kxtubq-esz'ngr,
\q2 X drtwr kcng tqyrlqq rsakrlrngr.
\q1 
\v 138 Natq kcng tqkapxq nzabrkitr drtwr,
\q2 Murde nztubq-zvzng.
\q1 
\v 139 Zngya ngr drtwrnge apule nyr kc tqngc,
\q2 Murde enqmi rngeng mrbrtr mz drtwrdr Nzryrngrkxtr.
\q1 
\v 140 Nzesalz-krm pq zlwz mz drtwrnge
\q2 Murde angidati-zvzme bange.
\q1 
\v 141 Kxmule-esz' leplz nzobqszolr ninge,
\q2 A' trmrbrtru mz drtwrnge nzalvztr-krmqng.
\q1 
\v 142 Yawe, nztubq-krm tqyc, tqyc,
\q2 X Loukxtr scm ngi da angidr zvz.
\q1 
\v 143 Delc kxmule-esz' nzkxpungr x nzvzkr drtwr nzprtzmqng bange,
\q2 A' abrtz-ngrne nzo-zli-zvz-krnge nzti rm.
\q1 
\v 144 Vz zvz nzokatr-krm ninge nzmc-krnge
\q2 Nztubq-zvzkr natqm, murde ma tqbzx.
\qa Wztx-ngrpwo Nzkrka'-krbo Bam
\q1 
\v 145 \qac W\qac*ztx-ngrpwo nzkrka'-krbo bam.
\q2 X ayzlum natqnge, murde nao-zlix lrpzki rm.
\q1 
\v 146 Yrnimi-zvzbo bam nzarlapx-krm ninge,
\q2 Murde nayrlq-angidrx Loukxtr scm.
\q1 
\v 147 Kqle-zvzx nim mz nourla kxtopwz mz nzokatr-krm ninge,
\q2 Murde abrtrpo drtwrnge mz nzesalz-krm.
\q1 
\v 148 Obqtx-zvzx mz nrlckxbq,
\q2 Mz nzaotikr drtwrnge me pnz drtwrm.
\q1 
\v 149 Mz nzaodu-zvz-krm ninge, xlrm natqnge,
\q2 X mailz ninge mz nzalvztr-krmqng.
\q1 
\v 150 Kxmule-esz' kxnzxpqbrlr-ngrdr nqmq krm
\q2 Nzesolvztilr ninge, a' trmwxlrwxu.
\q1 
\v 151 Murde eso-aepztrpe' bange,
\q2 X drtwr amrlx kcng tqyrlqq da angidr zvz.
\q1 
\v 152 Wz-ngrn natqm murde nayc-alo,
\q2 Da kc tqwai nzkrlz-krngele, abzo mzli kc pnz.
\qa Xlrm Natqnge Da Kc Tqwai Nzesalz-krmle
\q1 
\v 153 \qac X\qac*lrm natqnge x arlapx ninge mz nzkxpu-krnge,
\q2 Murde dcpx zvz mz drtwrnge Loukxtr scm.
\q1 
\v 154 X pipxbz mz leplz kx nqmq krnge tubq,
\q2 Da kc tqwai nzesalz-krmle, murde ma tqbzx.
\q1 
\v 155 Kxdrka'-ngrng trtxpnzngr nzrlapx-krdr,
\q2 Murde trnzrtangrtilru nzti rm.
\q1 
\v 156 Yawe, axplr mou ninge mz nzetukr nzaodu-krm,
\q2 Murde vz-nqblqx me pnz drtwrm.
\q1 
\v 157 Kxmule-esz' enqmi rngeng nzkqlu-zlwzng,
\q2 A' trtxpnzngr nzesablqti-krnge Nzryrngrkxtr.
\q1 
\v 158 Pxtxpx-ngrne kx drtwrdr litrpz bam,
\q2 Murde trnzlxngitilru da kxtubq mz nzobq-krm.
\q1 
\v 159 Yawe, arlapx ninge mz nivz lrm,
\q2 Murde mrlzm bange nzalvztr-krmqng.
\q1 
\v 160 X natqm mqngio mz da kxtubq.
\q2 Delc drtwr amrlx kcng tqyrlqq nztubq-kzng.
\qa Yrlq-angidrx Nzalvztr-krmqng
\q1 
\v 161 \qac Y\qac*awe, kxnzetung nzatrkati-krdr ninge trpnzngr noude,
\q2 A' amatq-zlwzx natqm.
\q1 
\v 162 Apux bcnyr kc tqrmctile da kxpqtr mz nabzde,
\q2 Murde abrtz-ngrne Nzryrngrkxtr
\q1 
\v 163 Trkam bange natq ngr nzpokiangr,
\q2 A' mrlzm bange natqm.
\q1 
\v 164 Glqpx-zvzx nim mz zbq kang kqlu,
\q2 Murde drtwr kcng tqyrlqq tubq-esz'ngr.
\q1 
\v 165 Krkcng tzmrlz badr Loukxtr scm, nzmnc-zpwxng.
\q2 X trpnzngr doa x da kx na-ataole nidr.
\q1 
\v 166 Yawe, brti drtwrnge nzarlapx-krm ninge,
\q2 Mz nzale-zvz-krnge da kx pitimeng.
\q1 
\v 167 Lolvz-amqngix nqmq krm,
\q2 Mz nzmrlz-zlwz-krmle bange.
\q1 
\v 168 Yrlq-angidrx nzalvztr-krm,
\q2 Da kc tqwai nzmc-krmle.
\qa Zyzlr Ngrm Napnamilxtile Nabznge
\q1 
\v 169 \qac Z\qac*yzlr ngrm napnamilxtile nabznge,
\q2 Mz nzayzlu-krme natqnge mz nzvz-nqblq-krde nzesalz-krm.
\q1 
\v 170 Lalztq-ngrm nzkrka'-krnge,
\q2 X arlapx ninge mz nzvz-nqblq-krde natqm.
\q1 
\v 171 Naglqlz-zvz-ngrne nim
\q2 Mz nzalvztr-krme bange nqmq krm.
\q1 
\v 172 Na-angrlvzx nzesalz-krm,
\q2 Murde drtwr amrlx kcng tqyrlqq tubq-esz'ngr.
\q1 
\v 173 Oliqm mz nzokatr-krm ninge,
\q2 Murde lolvz-amqngi-zvzx me pnz drtwrm.
\q1 
\v 174 Yawe, obqtipxx nzarlapx-krm ninge,
\q2 Murde mrlzm bange Loukxtr scm.
\q1 
\v 175 Okatrp ninge mz Nzryrngrkxtr
\q2 Murde naglqpxx nim mzli ka tqlu-ngrne.
\q1 
\v 176 Zmrlz ngrm nakqlelvzti-zvzle ninge.
\q2 Murde kxmule-esz' vecpx-lzbqbo bam,
\q2 A' trmrbrtitru mz drtwrnge lrpzki rm.
\c 120
\cl Sam Kratrtqki-esz'-nzpnu-li (120)
\s1 Ncblo Ngr Nrwx
\d Nabz kx nzngrnelzngr Jerusalem mz nzangiongr.
\q1 
\v 1 Mzli kc tqmnc-ngrne mz nzkxpungr, kqlex Yawe,
\q2 X ayzlu-ngrmle natqnge.
\q1 
\v 2 Rpibo bade kx, “Yawe, arlapxbz ninge
\q2 Mz leplz kxnzpokiang x nzesabrng.”
\q1 
\v 3 ?Nimu leplz kxnzpokiang,
\q2 Krlzpeamu da kx nawaisrngr Yawe nimu?
\q1 
\v 4 Sa na-ayrplapx-zlwzle nimu
\q2 Mz nipna sc ncblo ngr vea x mz nyr kxpq zlwz.
\q1 
\v 5 Nzmnc-lxblr-krgu trka-zlwzm bange,
\q2 Apule kx mnckr badr leplz kxdrka'-ngrng.
\q1 
\v 6 Mzli boitx zlwz mnctibo bamu,
\q2 Nimu leplz kcng tzpxtxpx-ngrdr nrwx.
\q1 
\v 7 Dekc mzli kc tqryapwxtr-ngrne mz nrwx,
\q2 Suti alzu drtwrmu nzotangr.
\c 121
\cl Sam Kratrtqki-esz'-nzpnu-li-nrade-esz' (121)
\s1 Gct Aclve-zpwxle Nigu
\d Nabz kx nzngrnelzngr Jerusalem mz nzangiongr.
\q1 
\v 1 ?Myx me narmcti-ngrne kxnaokatrle ninge?
\q2 ?Sa navzom mz newz ngr nrlc ka?
\q1 
\v 2 Trtingr. Murde Yawe Kxrpalz kc tqwz-ngrde bongavz x drtc',
\q2 Nide txpwz kx naokatrle ninge.
\q1 
\v 3-4 Da zpwx! Murde Yawe obq zvz,
\q2 X aclve-angidrle nigu lr Israel,
\q1 Mz nzapu-krgu sip nedeng.
\q2 A' tramau x trmwiu, murde ma tqtaoku.
\q1 
\v 5 Yawe ngi tegu badr,
\q2 X tu-zvzm mz nibrgu,
\q1 
\v 6 Murde trtxpnzngr doa x da kx na-atrkatile nigu
\q2 Mz nrlckxgrlx x mz nrlckxbq.
\q1 
\v 7 Yawe arlapxle nigu mz nzkxpu-krgung amrlx,
\q2 Murde namnc-zpwxku.
\q1 
\v 8 X aclve-zvzle nzvz-krgu x nzmnc-krgu,
\q2 Mzli ka x tqyc, tqyc.
\c 122
\cl Sam Kratrtqki-esz'-nzpnu-li-nrade-li (122)
\s1 Jerusalem Ngi Mzteadau Nyz Yawe
\d Nabz ne Devet kx nzngrnelzngr Jerusalem mz nzangiongr.
\q1 
\v 1-2 Drtwrnge elalzm mz nzrpi-ngrm bange kx, “Navzdzpeku mz Mangr-nzangiongr Yawe.”
\q2 Zbz sc tqvztrpekr mz naobz ngr mzteadau nyzde. \fig Navzdzpeku mz Mangr-nzangiongr Yawe mz nzvztr-krgu mz naobz ngr mzteadau nyzde.|alt="024 Jerusalem, Q Sheba approaching on road." src="024-CO01111b.tif" size="SPAN" loc="PSA 122:1-2" copy="David C. Cook" ref="122:1-2"\fig*
\q1 
\v 3 Jerusalem lc nzlrmztio nzrwzngr,
\q2 X mzte opx nzmwitr-lxblrkr ma ngrdeng.
\q1 
\v 4 Nigu neidu lr Israel vzmgu mrlcde mz nzawi-krbzku mz Yawe,
\q2 Da kc tqwai nzpi-krdele.
\q1 
\v 5 X Jerusalem ngi mzteadau nyz king rgung, kcng tzvzpxmqng mz nqvi lr Devet.
\q2 X nzaclvelr leplz nedrng elr mz nzwxbuo-krdr mz tron.
\q1 
\v 6-7 Delc, nakrka'-ngrgu Jerusalem mz nzrpi-krgu kx, “Gct rgr, aclve zpwx nigr lr Jerusalem,
\q2 Murde leplz nemqng kcng tzmrlztilr nim
\q1 Namnc-zpwxng mz ma nyzdr,
\q2 X narmctilr nrwx mz nzmncpx-krmlr mz drkq ngr mzteadau nyzm.
\q1 
\v 8-9 Yawe, rlxtibzkr bam
\q2 Kx na-aclve-kzpzme lr mrnyzgr x kztegrng kcng tzmncng elr.
\q1 Amrlz zvz leplz amrlx kcng tzmncng elr
\q2 Mz nzmrlzti-krdr Mangr-nzangiongr nim. Eu, angida.”
\c 123
\cl Sam Kratrtqki-esz'-nzpnu-li-nrade-tq (123)
\s1 Yawe, Nayc Mz Drtwrm Nigr
\d Nabz kx nzngrnelzngr Jerusalem mz nzangiongr.
\q1 
\v 1 Yawe, mnc-xglex nim
\q2 Mz nzwxbu-krm mz tron nyzm Heven.
\q1 
\v 2 X nzmnc-xgle-zvz-krgr nim navz navz nakrlzbzle mzli kx ycngr mz drtwrm nigr.
\q2 Murde apukr ncblo x olvz kx nzawzng kx nzmnc-xglelr kxnzetu rdrng.
\q1 
\v 3 Yawe, nayc mz drtwrm nigr mz nzokatr-krm nigr.
\q2 Murde kxnzakxputing nzapusr-ngrdr nigr brmrda.
\q1 
\v 4 X drtqgr satxtrpebz nzxtrngatitrkr kxnzrngiscng nigr,
\q2 X kxnzglqlz-lzbqng nzobqszo-zvzlr nigr.
\c 124
\cl Sam Kratrtqki-esz'-nzpnu-li-nrade-pwx (124)
\s1 Yawe Arlapxle Leplz Nedeng
\d Nabz ne Devet kx nzngrnelzngr Jerusalem mz nzangiongr.
\q1 
\v 1 Nigu lr Israel nakrlz-angidrku
\q2 Kx Yawe ngi-te-zvzku badr mz nzotangr.
\q1 
\v 2 X mz nzngi-te-zvz-krgu badr
\q2 Mzli kc enqmi rgung nzrpilr na-atrkati-ngrdr nigu,
\q1 
\v 3 Rblxbz badr nzmilxtxo-krdr nigu
\q2 Mz nzngyati-zlwzkr drtwrdr nigu.
\q1 
\v 4-5 X trnznibqlru nigu mz nzapu-krdr srkau kx mrilvzole nigu.
\q2 X nrc kxetu ngr srkau lc trabooleu nigu.
\q1 
\v 6 Delc na-awi-ngrbzku mz Yawe
\q2 Mz trnzrlr-krpwzleu nigu mz mq enqmi rgung.
\q1 
\v 7 Mzli lc sc tqapupeku utc mz nzdwapx-krmgu mz br sc kxnzmwang,
\q2 X drtqgu opxpe murde Yawe pingebzle br scdr.
\q1 
\v 8 Yawe nide Kxrpalz kc tqwz-ngrde bongavz x drtc',
\q2 X Mevalu kc tqokatrle nigu, mz zmatq drtqde.
\c 125
\cl Sam Kratrtqki-esz'-nzpnu-li-nrade-nzlvqn (125)
\s1 Kxnztubqng X Kxdrka'-ngrng
\d Nabz kx nzngrnelzngr Jerusalem mz nzangiongr.
\q1 
\v 1 Nigu kcng nzabrtrpzlr drtwrdr mz Yawe,
\q2 Apuku Newz Saeon kx trycngrlru, a' tutx alo.
\q1 
\v 2 X Yawe apule newz kcng tztu-ngalelvzlr Jerusalem,
\q2 Murde vz zvz nztu-krmle mz nibrgu, nigu leplz nedeng.
\q1 
\v 3 X tr-rlr-ngrpwzleu mz kxdrka'-ngrng nzaclve-alo-krdr mrnyzgu, nigu kxnztubqng.
\q2 Murde ma tqvz-nqblqku nqmq krdr kxtrka.
\q1 
\v 4 Delc Yawe, krka'-ngrgr kx na-amrlzq nigr lr Israel kxnztubqng
\q2 Mz nzyrlq-angidr-krgr natqm.
\q1 
\v 5 A' mzli kc na-ayrplapx-ngrn kxdrka'-ngrng,
\q2 Mrlzm bagr nzayrplapx-kz-krm kzdung nigr
\q1 Kcng tzpxtxpx-ngrdr nzvz-nqblqngr nim.
\q2 A' amnc zpwx nigr lang.
\c 126
\cl Sam Kratrtqki-esz'-nzpnu-li-nrade-esz'mz (126)
\s1 Yawe Amnc-zpwx-moule Lr Jerusalem
\d Nabz kx nzngrnelzngr Jerusalem mz nzangiongr.
\q1 
\v 1 Mzli kc Yawe tqamnc-zpwx-mou-ngrde nigu lr Jerusalem,
\q2 Opxm kx trngiu da zpwx, a' rmwibleku.
\q1 
\v 2 Mzli lcde, yrpale-twzku x ngr-katoku, mz nzabrtz-zlwz-krgu.
\q2 Zbz sc tzrpipe lr mrkzbleng kx, “Yawe rwz-ngrbz da kxetuting kx okatr-ngrde nidr.”
\q1 
\v 3 X abrtztx-zlwz-ngrgu
\q2 Da lcdeng tqetuting tqwz-ngrmleng bagu.
\q1 
\v 4 Delc Yawe, na-amnc-zpwx-mou-ngrde nigu mzli ka,
\q2 Da kc tqwai tewa nzdc-krde x lrti-moungr ningali kx pztipeng.
\q1 
\v 5 Murde leplz kcng tzyrning mzli kc tzpe-ngrdr dakxnzng mz drtc',
\q2 Na-abrtzng mzli kc narkqlz-ngrdr.
\q1 
\v 6 X leplz kcng tzyrning mzli kc tzrtwz-ngrdr dakxnzng kx napetilr mz nrlanc,
\q2 Sa nangr-abrtzng mzli kc nartwz-ngrmlr dakxnzng brma mz mzli r nzrkqlzngr.
\c 127
\cl Sam Kratrtqki-esz'-nzpnu-li-nrade-rlimz (127)
\s1 Nqvi Lr Ncblo
\d Nabz ne Solomon kx nzngrnelzngr Jerusalem mz nzangiongr.
\q1 
\v 1 Nzmu Yawe trnangiu Kxetu r nqvi lrgu le,
\q2 Mane nzaetunepx-krgu nqvi lrgu.
\q1 Nzmu trna-aukztileu lr mrnyzgu,
\q2 Mane nzaclve-krgu nidr.
\q1 
\v 2 Nzmu trna-abrtrpwzkuu drtwrgu mz Yawe
\q2 Mz nzrka-krmle dakxnzng bagu,
\q1 Mane nzo-rlangr mz nzwz-katongr x nzyzlu-ngrm mz nina,
\q2 Murde krlz-kzle nzrka-krmle da bagu mzli kc tqmwi-ngrgu.
\q1 
\v 3-5 X Yawe nide kz kx rkam doa kxnztopwzng mz nqvi lrgu,
\q2 Mzli kc tqngi-oblabe-ngrgu.
\q1 Murde mzli kc tqngi-lrtzlvzpe-ngrgu, doa lcng na-aclvelr nigu.
\q2 Sa namrlzbz mz ncblo kc mrlxde tqkqlu.
\q1 Murde mzli kc kzdq ncblo narnqniti-lzbq-ngrdr bade,
\q2 Mrlxdeng sa natubzng mz nibrde.
\q1 X mz nzrka-krbz kxnzrmailzng drtwr kxtubq,
\q2 Drtqde trnamyau murde nztu-krbz mrlxdeng lcng mz nibrde.
\c 128
\cl Sam Kratrtqki-esz'-nzpnu-li-nrade-rtqmz (128)
\s1 Trte Kx Mailzle Lr Ma Nyzde
\d Nabz kx nzngrnelzngr Jerusalem mz nzangiongr.
\q1 
\v 1 Yawe sa na-amrlzle trte kx amrluele nide,
\q2 X o-zli-zvzle nzti rde.
\q1 
\v 2 Murde da kx naokatrle lr ma nyzde navzpxm mz nzwz-krde,
\q2 X na-abrtz-ngrde nzmnc-zpwx-krdr.
\q1 
\v 3 Olvz nalzde na-apule nc bia kc nrade tqkqlu,
\q2 Murde doa nedrng kalr na-apulr nrtr ngr nc brpi mz nzwxbu-ngalelvz-krdr nyr pnrde.
\q1 
\v 4 Delc Yawe tqamrlz-ngrde
\q2 Trte kx amrluele nide.
\q1 
\v 5-6 Yawe, mz nzmncpx-krme Mangr-nzangiongr,
\q2 Amrlz nigr lr Israel, murde namnc-zpwxkr.
\q1 X trtegr lcng namc-zvzlr da kxmrlzting kcng tqaleme bagr, nigr lr Jerusalem.
\q2 X namc-kzlr nzmnckr doa ne doa nedrng, x sc tzbz-ateng.
\c 129
\cl Sam Kratrtqki-esz'-nzpnu-li-nrade-rpwxmz (129)
\s1 Enqmi r Lr Israel
\d Nabz kx nzngrnelzngr Jerusalem mz nzangiongr.
\q1 
\v 1 Nigu lr Israel nadcpx mz drtwrgu kx enqmi rgung nzatrkatilr nigu
\q2 Yzuo mzli kc tqpipzbe-ngrgu mrnyzgu.
\q1 
\v 2 A' kxmule-esz' enqmi rgung nzatrkati-zlwzlr nigu,
\q2 Yzuo mzli kc tqpipzbe-ngrgu mrnyzgu, a' trnzaovxio-pnzlru nigu.
\q1 
\v 3 X kxmule-esz' nzikla-zlwzlr nigu,
\q2 X bzmrde mnz-aboitxtr-alom mz nibrgu,
\q1 
\v 4 A' Yawe kc tqtubq-esz'ngr,
\q2 Aopxpebzle drtqgu mz mqdr.
\q1 
\v 5 Delc Yawe, nigr lr Saeon rlxtibzkr bam, nzmaneutipx-krbzme enqmi rgrng amrlx,
\q2 Murde drtqdr namyatx-zlwzng.
\q1 
\v 6 X ayangrnga nidr
\q2 Mzli lc tztopwzbe-ngrdr.
\q1 
\v 7 Murde ma tqtakitrde nidr nzota-moungr,
\q2 Nzmu enqmi rgr kc-kzng tzrlxtibzlr badr nzokatr-krdr nidr mz vea.
\q1 
\v 8 X bzkq rlrpx-ngrn nzrpi-krbz badr kx,
\q2 “Amrlzkr nimu mz drtq Yawe!”
\c 130
\cl Sam Kratrtqki-esz'-nzpnu-tq (130)
\s1 Nzoliq-zvzkr Yawe Mz Nzokatr-krde Leplz Nedeng
\d Nabz kx nzngrnelzngr Jerusalem mz nzangiongr.
\q1 
\v 1 Yawe, kqlex nim mz nzokatr-krm ninge
\q2 Mz mzlir nzkxpu-krngeng.
\q1 
\v 2 Lalztqm mz nzkrka'-krnge, kx Kxetu,
\q2 X ayzlum natqnge.
\q1 
\v 3 Yawe, nzmu napx-ngrn nzipqpx-krm alwx rgrng,
\q2 Trpnzngr kx narlapxbz mz nzayrplapxngr.
\q1 
\v 4 A' oliq-zvzq nzipq-krm nigr,
\q2 Murde na-amrluekr nim.
\q1 
\v 5-6 Yawe, obqtipxx nzokatr-krm ninge.
\q2 X brti drtwrnge kx sa na-atutrq natqm.
\q1 Da kc tzwai kxnzaukzng mz nzaenzli-krdr rngalx nzpnamilxtilz-ani-krmle,
\q2 Murde nzkrlzlr kx nepi sa naprkilz-zvzm mz nourla kang kqlu.
\q1 A' suti zlwz drtwrnge nzvz-ani-krme,
\q2 Myaszpxle nzsutikr drtwrdr nzprtz-krm nepi.
\q1 
\v 7 X nigu lr Israel, na-abrtrpzku drtwrgu mz Yawe, murde aodu-zvzle nigu.
\q2 X oliq zvz nzarlapx-krde nigu.
\q1 
\v 8 X sa naxpepxle nigu
\q2 Mz alwx ngrgung amrlx.
\c 131
\cl Sam Kratrtqki-esz'-nzpnu-tq-nrade-esz' (131)
\s1 Apux Doa Kx Yrpz Lxede
\d Nabz ne Devet kx nzngrnelzngr Jerusalem mz nzangiongr.
\q1 
\v 1 Yawe, trglqpx-lzbqpc'u bam, mz nzvz-lvi-krnge bz kc tqyrlqme bange.
\q2 X tramatq-lzbqwxu murde naprtrpo mz kxnzetung mz nzycmnetr-krdr mz da kxmyaszpxle nzrkrlz-krnge.
\q1 
\v 2 Murde abrtz-ngrne nzapu-krnge doa kxtopwz kx yrpz lxede.
\q2 Delc tqmnc-zpwx-ngrne mz nrlc.
\q1 
\v 3 X nigu lr Israel navz zvz nzabrtr-krbzku drtwrgu mz Yawe,
\q2 Murde namnc-zpwx-kzku.
\c 132
\cl Sam Kratrtqki-esz'-nzpnu-tq-nrade-li (132)
\s1 Nzesz'tikr Drtwr Yawe Ncdr Devet
\d Nabz kx nzngrnelzngr Jerusalem mz nzangiongr.
\s2 Devet Suti Drtwrde Nzrwzngr Mangr-nzangiongr Yawe
\q1 
\v 1 Yawe, na-aoti drtwrm nzkxpukr Devet,
\q2 Mz nzwztr-krbzle bam.
\q1 
\v 2 Nim Gct kc tqrninr tqangio Jekop.
\q2 X Devet esalzbz bam.
\q1 
\v 3-4 Rpibzle kx, “Yawe, trtxpnzngr nzvz-krnge ma nyznge o mz nelvq nyznge,
\q2 X trtxpnzngr nzama-krnge x nzmwi-krnge,
\q1 
\v 5 A' nawzti-kaix dq ma kx namnc-ngrn,
\q2 Mz nzngini-krm Gct r Jekop.”
\s2 Devet Rmctile Bokis Kc Tqyclz-ngrm Nzesz'tikr Drtwrdr Badr Gct
\q1 
\v 6 Mzli kc Devet badr ncblo nedeng tzmnc-ngrdr Efrata,
\q1 Nzxlrlr nrpa ngr Bokis kc tqyclz-ngrm Nzesz'tikr Drtwrdr Badr Gct.
\q2 X sc tzrmctipelr mz mztea Jerim mz nrlarnrlc lcde.
\q1 
\v 7 X sc tzrpipelr kx, “Naglqpeku Bokis lc mz Tentkxtr nyz Yawe.
\q2 Mz nzangio-krgu nide mrkc tqwxbu-ngrde mz tron.”
\q1 
\v 8 X sc tzrpipebzlr mz Gct kx, “Yawe, vzm mz Tentkxtr nyzm,
\q2 Murde namnc-zvzq mrkc tqycngr Bokis ngr zmatq ngrm.
\q1 
\v 9 Murde pris nemqng nayapwxtipxbzlr nztubq-esz'ngr-krm mz leplz nedrng,
\q2 Kcng na-angrlvzlr nim.”
\s2 Nzesz'tikr Drtwr Yawe Ncdr Devet
\q1 
\v 10 Yawe, mzli ka bzkq pxtxpx-ngrn king rgr kc tqmcpxbzme,
\q2 A' atutr nzesalz-krbzme mz kxnzawz nem, King Devet.
\q1 
\v 11 Murde esalz-ngrbzme bade da kx trnzkatxu,
\q2 Mz nzrpi-krbzme bade kx, “Sa nayrlqbo dq mrlxm kx nanginide king kx na-aclvele lr Israel mz nibrm. \x + \xo 132:11 \xt Aposol 2:30\x*
\q1 
\v 12 X nzmu mrlxdrng nayrlq-angidrlr nzesz'tikr drtwrgr badr,
\q2 X navz-nqblqlr natqnge kc tqkapxbo badr,
\q1 Sa nangini-zvzdr king,
\q2 Badr mrlxdrng, tqyc tqyc.”
\s2 Mevalu Kc Navzpxm Mz Nqvi Lr Devet
\q1 
\v 13 Yawe, rlxtibzkr nzamrlz-krm king nem.
\q2 Murde mcpxq Jerusalem nangi mztea nyzm,
\q1 
\v 14 Mz nzrpi-krm kx, “Krlc mztea kx namnc-alo-ngrne,
\q2 Mz nzvz-nqblq-krde me pnz drtwrnge.
\q1 
\v 15 Sa nakabo mz lr mztea nyznge lc da kxmrlzting kxkqlu.
\q2 X sa na-aputrx kxtrnzrngiscung murde nelzdr nakrlc x naesatxpx zpwx.
\q1 
\v 16 Sa nabatrpo mz pris nengeng nzyapwxtipx-krbzlr mz leplz nengeng nzarlapx-krnge nidr,
\q2 Murde leplz kxnztr lcng namalqlvzlr ninge.
\q1 
\v 17 Sa nayrlqx king kc tqmatq Jerusalem kx navzpxm mz nqvi lr Devet,
\q2 X nzaclve-krde trtxpnzngr nzesaki-krde.
\q1 
\v 18 Sa na-amyalzx nide mz nzalao-krbo kraon mz narde,
\q2 A' sa nabatrpo nzmyakr drtq enqmi rdeng.”
\c 133
\cl Sam Kratrtqki-esz'-nzpnu-tq-nrade-tq (133)
\s1 Nzesz'tikr Drtwrgu
\d Nabz ne Devet kx nzngrnelzngr Jerusalem mz nzangiongr.
\q1 
\v 1 Lqngipx x mrlzvxi
\q2 Mzli kc leplz tzmnctr-lxblr-ngrdr mz nzesz'tikr drtwrdr. \fig Lqngipx x mrlzvxi mzli kc leplz tzmnctr-lxblr-ngrdr mz drtwr kxesz'.|alt="025 unity, brotherhood, reconciliation" src="025-AB02706b.tif" size="COL" loc="PSA 133:1" copy="John Lear" ref="133:1"\fig*
\q1 
\v 2 Nzesz'tikr drtwr lqngipx apule nzyrleokr tolo mz nar Eron x nrpnr naode, krlzo-kzpzle lrpzde,
\q2 Mzli kc tzaelu-ngrde tolo mz nzngini-krde Nardr Pris.
\q1 
\v 3 X nzesz'tikr drtwr mrlzvxi apule nzdco-krm tewa
\q2 Mz newz nyzgung mrkc tqmingr zvz.
\q1 Murde da kc tqmrlzting amrlx tqkam Yawe bagu nzvzpxmqng Jerusalem,
\q2 Myapxbz nzmnc-zpwx-zvz-krgu mz drtc' nyzgu.
\c 134
\cl Sam Kratrtqki-esz'-nzpnu-tq-nrade-pwx (134)
\s1 Naglqpxku Yawe
\d Nabz kx nzngrnelzngr Jerusalem mz nzangiongr.
\q1 
\v 1 Naglqpxku Yawe, nigu kxnzawz nedeng.
\q2 Naprtrku mz Mangr-nzangiongr nide.
\q1 
\v 2 Glalzku mqgu Mrkc Tqtr.
\q2 Glqpxku Yawe mz nrlckxbq.
\q1 
\v 3 X krka'-ngrgr kx Yawe na-amrlzle nimu mz nzmnc-krde Mzteadau nyzde.
\q2 Nide kc tqwz-ngrde bongavz x drtc'.
\c 135
\cl Sam Kratrtqki-esz'-nzpnu-tq-nrade-nzlvqn (135)
\s1 Nigu Nqvi Lr Israel Naglqlzku Yawe
\d Nabz kx nzngrnelzngr Jerusalem mz nzangiongr.
\s2 Mcpx Gct Nqvi Lr Israel
\q1 
\v 1-2 \bd Naglqlz-zvzku Yawe,\bd*
\q2 Murde nide Gct rgu.
\q1 X nigu kxnzawz nedeng na-amrlueku nide
\q2 Mz nzkrka'-krmu mz Mangr-nzangiongr x makoa ngrde.
\q1 
\v 3 Na-amatqku nide murde mrlz-esz'ngr.
\q2 X na-angrlvz-ngrgu nide nivz lrde.
\q1 
\v 4 Murde mcpxle nqvi lr Jekop, nigu lr Israel,
\q2 Mz nzngini-krgu leplz nedeng.
\s2 Kxrpalz
\q1 
\v 5 Krlzku kx Kxetu rgu, Yawe, nide Gct kc tqmyatxlz-esz'ngr,
\q2 Myaszlzle kxnzmncng mzlilxlr amrlx.
\q1 
\v 6 Vz-nqblq-txpwzle me pnz drtwrde mz da kx alele
\q2 Kxmule-esz' mz bongavz, nrlc, prla, x me boo-ngrng.
\q1 
\v 7 Wz-ngrde zbo nzvzdz-krdr mz lclxlr mz bongavz,
\q1 X bzlrpc nzvzmi-krm trlipu le.
\q2 X batrpzle nzwqkr nenq.
\s2 Kxaovxio
\q1 
\v 8 Sc tqnibqtile ncblo kx ayrnrngr Ijipt,
\q2 Kr neng leplz x kr neng animol.
\q1 
\v 9 Rwzngr da kxnzkctipxng kxkqlu mrlcde,
\q2 Mz nzayrplapx-krde king rdr x kxnzetu nedeng.
\q1 
\v 10 Aovxiole lr mrkzbleng kxkqlu
\q2 Mz nznibqti-krde king kxnzxplr-zlwzng.
\q1 
\v 11 Krlcng King Sihon, King Og, x kzdu-kzng king
\q2 Kcng tzaclveng mz drtc' Kenan.
\q1 
\v 12 X drtc' nyzdrng katimleng bagu,
\q2 Nigu lr Israel, da kc tqwai nzpi-krmlele bagu.
\s2 Gct Angidr
\q1 
\v 13 Nqmq kr Yawe tqyc tqyc.
\q2 X nzrkrlzngr drtqde tqvzpe tqvzpe.
\q1 
\v 14 Yawe sa napipxbzle mz leplz nedeng kxnzvz-rbrng o trtingr,
\q2 X sa na-aodu-zvzle nidr.
\q1 
\v 15 Kxnzmnc-mrbrng nzangiolr mqngr da kx nzlz,
\q2 Kcng tzwzngr ncblo mz silvz x gol.
\q1 
\v 16 Mqngr da kxnzlz lcng naodr x mztr ycbz,
\q2 A' trnzycmneung x trnzrmcung da.
\q1 
\v 17 Nradrtqdr x nctqdr ycbz,
\q2 A' trnzxlrung da x trnzycmini-kzung.
\q1 
\v 18 Leplz kcng tzrwz-ngrng nzapu-kzlr mqngr lcng.
\q2 Murde nznabung, trnzobqung, nradrtqdr ngq, x trpnzngr nzlungr badr.
\s2 Lr Israel Naglqlzlr Yawe
\q1 
\v 19 A' Nigu nqvi lr Israel, naglqlzku Yawe.
\q2 X nimu pris, nqvi lr Eron, na-amrlue-kzamu nide.
\q1 
\v 20 X nimu kxnzawz nedeng, nqvi lr Livae, na-amatqamu nide.
\q2 Nigu amrlx kcng tzamrluelr nide, na-angrlvzku nide.
\q1 
\v 21 Na-angioku Yawe Jerusalem, mz Newz Saeon.
\q2 \bd Naglqlz-zvzku Yawe.\bd*
\c 136
\cl Sam Kratrtqki-esz'-nzpnu-tq-nrade-esz'mz (136)
\s1 Aodu-zvzle Nigu
\s2 Kxrpalz
\q1 
\v 1 Aodu-zvzle nigu. Awi-ngrbzku bade
\q2 Mz nzmrlz-esz'ngr-krde. Aodu-zvzle nigu.
\q1 
\v 2-3 Aodu-zvzle nigu. Kxetu r kxnzetung
\q2 Myaszlzle kxnzmncng mzlilxlr. Aodu-zvzle nigu.
\q1 
\v 4-5 Aodu-zvzle nigu. Wz-ngrde rkx kxmatq,
\q2 Bongavz mz nzyrplapx-krde. Aodu-zvzle nigu.
\q1 
\v 6 Aodu-zvzle nigu. Wznedz-ngrmle drtc'
\q2 Me boongr prla. Aodu-zvzle nigu.
\q1 
\v 7-8 Aodu-zvzle nigu. X wz-ngrde nepi
\q2 Nayzlr mz nrlckxngrlx. Aodu-zvzle nigu.
\q1 
\v 9 Aodu-zvzle nigu. Wz-ngrde temz badr vri
\q2 Nayzlrng mz nrlckxbq. Aodu-zvzle nigu.
\s2 Aovxiole Enqmi Rgung
\q1 
\v 10 Aodu-zvzle nigu. Nibqtile enqmi rgung,
\q2 Kxmztr nzmc kai ne lr Ijipt. Aodu-zvzle nigu.
\q1 
\v 11 Aodu-zvzle nigu. Rkamilzmle nigu
\q2 Lr Israel mz mzlir lr Ijipt. Aodu-zvzle nigu.
\q1 
\v 12-14 Aodu-zvzle nigu. Mz zmatq ngrde kx xplr,
\q2 Akipxle Prla Bla. Aodu-zvzle nigu.
\q1 Aodu-zvzle nigu. X mailzkimle nigu,
\q2 Leplz nedeng mz nzti rde. Aodu-zvzle nigu.
\q1 
\v 15 Aodu-zvzle nigu. A' rtco-ngrde prla
\q2 King x ami r lr Ijipt. Aodu-zvzle nigu.
\q1 
\v 16 Aodu-zvzle nigu. X mailztrle nigu
\q2 Leplz nedeng lzke. Aodu-zvzle nigu.
\q1 
\v 17-18 Aodu-zvzle nigu. Nibqtile king kxnzxplrng.
\q2 Apoopemle king kxnzmatqng. Aodu-zvzle nigu.
\q1 
\v 19 Aodu-zvzle nigu. Nibqle King Sihon,
\q2 King r lr Amctq. Aodu-zvzle nigu.
\q1 
\v 20 Aodu-zvzle nigu. X aovxiole King Og,
\q2 Kc tqngi king r lr Basan. Aodu-zvzle nigu.
\q1 
\v 21-22 Aodu-zvzle nigu. Aprcmle drtc' nyzdr
\q2 Bagu, nigu lr Israel. Aodu-zvzle nigu.
\s2 Aclve-zvzle Nigu
\q1 
\v 23 Aodu-zvzle nigu. Trmrbrtru mz drtwrde
\q2 Nzkxpu-zlwz-krgung. Aodu-zvzle nigu.
\q1 
\v 24 Aodu-zvzle nigu. Arlapxbzle nigu
\q2 Mz mq enqmi rgung. Aodu-zvzle nigu.
\q1 
\v 25 Aodu-zvzle nigu. X rkabz dakxnzng
\q2 Mz krkcng tzlung amrlx. Aodu-zvzle nigu.
\q1 
\v 26 Aodu-zvzle nigu. Glqlzku Gct kc Heven,
\q2 X awibzku bade, aodu-zvzle nigu.
\c 137
\cl Sam Kratrtqki-esz'-nzpnu-tq-nrade-rlimz (137)
\s1 Rblx Nzngr-abrtz-krgr Mz Nzmnc-krgr Bxbilon
\q1 
\v 1 Kx dcpx mz drtwrgr nzodatingr Jerusalem,
\q2 Sc tqyrnipekr mz nzwxbune-krgr mrkzble mz nqlvi r ningaling Bxbilon.
\q1 
\v 2 X gita negrng adotxlzpekrng
\q2 Mz nounc kx nztung mrlcde.
\q1 
\v 3 Krkcng tzlolvztilr nigr, tzxtrnga-ngrdr nigr, nzrpimlr bagr kx,
\q2 “Ngr-ngrmamu du bagr nabz kxtr nemung.”
\q1 
\v 4 A' mz drtwrgr rpikr kx, “Rblx nzngr-abrtz-krbzkr mz Yawe,
\q2 Mz nzmnc-krgr mz mztea nyz kxtrnzrlxngitiung.
\q1 
\v 5 Murde nzmu kx tqmrbrtitr drtwrnge Jerusalem,
\q2 Namrbrtitr kz drtwrnge kxmu nzayrni-krnge gita nenge.
\q1 
\v 6 X nzmu kx tqrblx nzdcpx-kaikr Jerusalem mz nabznge,
\q2 Narblx kz nzngr-krnge nabz ngrdeng.”
\q1 
\v 7 Yawe, nadcpxpwz mz drtwrm alwx ngr lr Edom.
\q2 Murde mzli kc lr Bxbilon tzodati-ngrdr Jerusalem,
\q1 Sc tzrpibzlr badr kx, “Odatiamu!
\q2 Odatiamu x natutx-lxlrngr.”
\q1 
\v 8 Yawe, rlxtibzkr bam nzamrlz-krm ncblo kc naodati-atwrnr-ngrde lr Bxbilon,
\q2 Mz nzayzlu-krbzle badr da kcng tzwaisr-ngrdr nigr. \x + \xo 137:8 \xt Nzaelwapxngr 18:6\x*
\q1 
\v 9 Murde na-abrtz-ngrde nzlolvzti-krde doa lcng,
\q2 Mz nztamyrtitx-krde nidr.
\c 138
\cl Sam Kratrtqki-esz'-nzpnu-tq-nrade-rtqmz (138)
\s1 Drtq Yawe X Natqde
\d Nabz ne Devet.
\q1 
\v 1 Yawe, awibo bam mz nabznge atwrnrngr.
\q2 X angrlvzx nim mz mz kxnzmatqng.
\q1 
\v 2 Lxlvrkibo Mangr-nzangiongr nim mz nzglqlz-krnge drtqm.
\q2 X awi-ngrbo bam nqmq krm,
\q1 Nzaodu-krm, x nzangidati-krm.
\q2 Murde drtqm x natqm nzmyatxpx-esz'ngr.
\q1 
\v 3 Mzli kc tqkrka'-ngrbo bam, ayzlume natqnge,
\q2 Mz nzaetunepx-krm nzxplr-krnge.
\q1 
\v 4 Yawe, king amrlx mz nrlc sa naglqlzlr nim,
\q2 Mz nzxlr-krdr nzmrlzkr natqm.
\q1 
\v 5 X sa na-angrlvzlr kxmu nzale-krmqng da,
\q2 Mz nzmc-krdr kx myatxlz-esz'ngrn.
\q1 
\v 6 Kxmule-esz' myalz-esz'ngrn, a' sc tqaclve-zvzq kxnzavzo-lzbqng.
\q2 X avzome kxnzglqpx-lzbqng.
\q1 
\v 7 X kxmule-esz' nzkxpungr nzprtzmqng bange, a' amnc-zpwxq ninge.
\q2 X tu-zvzme mz nibrnge mz nzngyatikr drtwr enqmi rngeng ninge.
\q1 X arlapxq ninge mz zmatq ngrm.
\q2 
\v 8 Yawe, krlzx kx sa na-angidatiq drtwr amrlx kcng tqyrlq-pz'liti-ngrn ninge.
\q1 Murde nzaodu-krm tqyc tqyc.
\q2 Bzkq esaki nzaclve-krm krkcng amrlx tqwz-ngrn.
\c 139
\cl Sam Kratrtqki-esz'-nzpnu-tq-nrade-rpwxmz (139)
\s1 Nzrkrlzkr Yawe Myatxlz-esz'ngr X Krlz-kzle Nqmq Nr Nabzm
\d Nabz ne Devet kx yrbzle mz kxrmailz ngr dzbe kxnzngrng.
\s2 Obqplxq Nabznge
\q1 
\v 1 Yawe, obqplxq nabznge,
\q2 X krlz-atwrnr-ngrn ninge.
\q1 
\v 2 Krlzq da amrlx kcng tqalex.
\q2 Kxmule-esz' mncme rlru, a' krlz-zvzq nzao-krnge drtwrnge.
\q1 
\v 3 Kxmule-esz' wzx o amax, a' sa tqmc-zvzq ninge.
\q2 X krlz-kaiq da amrlx kcng nartrngztibo mz zbq kxesz'.
\q1 
\v 4 Abzo pnz mzli kc trycmneka-ngrne
\q2 Nzkrlz-kai-krm natq kznike napixng.
\q1 
\v 5 Zmatq ngrm okatrle ninge
\q2 Mz nztu-ngalelvz-krde ninge.
\q1 
\v 6 Nzkrlz-krm ninge etu zlwz.
\q2 X trtakitrpwc'u nzrkrlz-krm.
\s2 Esz'-ngrn Nrlc
\q1 
\v 7 ?Drlve kc navzkix murde trnamcwq ninge?
\q2 Trpnzngr kxnamule lc murde esz'-ngrn nrlc.
\q1 
\v 8 X kxmule-esz' vzdzx Heven, a' sc tqmncq elr.
\q2 X kxmule-esz' bzx x nzyrtzmqnge, a' sc tqmnc-kzq elr.
\q1 
\v 9 Kxmule-esz' alilvc-kzx me prkilzm nepi
\q2 O me takiole,
\q1 
\v 10 A' sc tqmncq elr mz nzokatr-krm ninge
\q2 X nzrmailz-krm ninge mz mqm.
\q1 
\v 11 Kxmule-esz' mnc-kapqx mz nzlo
\q2 X mz drtwrnge nrlckxngrlx nangitx nrlckxbq,
\q1 
\v 12 A' nzlo x nrlckxbq rblx nzamnc-kapq-krdr ninge,
\q2 Murde nzlo x zyzlr kxnamu-txpwzlr esz' mz nzobq-krm.
\s2 Nzlrmztio-krm Ninge
\q1 
\v 13-15 Murde mzli kc tqmclq ninge mz nelz lxenge
\q2 Nim txpwz kx rkrlz nzmnc-lrpipx-krmc mrlcde.
\q1 Wz-ngrn dalr nrkrdrtqnge x nrvr rngeng.
\q2 X amwitr-lxblr-kzqng amrlx, mz nzvz-nqblq-krde me pnz drtwrm.
\q1 X kctipxx x awitx-ngrbo bam
\q2 Nzlrmztio-krm ninge.
\q1 
\v 16 X mzli kc trnzmckangr mzke',
\q2 Yrlqpe-kaiq me nakrlzbz me nangi bz ngr nzlu-krnge.
\s2 Rblxm Bange Nzao-krm Drtwrm
\q1 
\v 17 A' rblxm bange nzkrlz-angidr-krnge nzao-krm drtwrm
\q2 Murde nzkqlu-zlwzng.
\q1 
\v 18 A' nzmu narlwxxleng drtwrnge mrbrtrpz,
\q2 Murde nzmyaszpxlr drta' ngr prla amrlx.
\q1 X kxmule-esz' nayrkrpx nzrlwx-krngeleng,
\q2 A' tryatrkapc' nzkrlz-angidr-krnge nim.
\s2 Kxdrka'-ngrng
\q1 
\v 19 Murde rblxbep bange drtwr ngr nqmq krm.
\q1 ?Memule tqasa-ngrn nzayrplapx-krm kxdrka'-ngrng?
\q2 ?Myx kxmule trnamilxtxokalq nidr?
\q1 
\v 20 Murde nzpiti-ngrdr nim natq kxtrka,
\q2 X nzrnzlvzolr nqmq krm.
\q1 
\v 21-22 Yawe, pxtxpx-ngrne krkcng tzpxtxpx-ngrdr nim x ni-kzdr enqmi rngeng.
\q2 Murde trnzmnclzpwzung mz zmatq ngrm.
\s2 Aelwa-ngrm Bange Nqmq Krnge Kxtrka
\q1 
\v 23 Gct, obqplxti zpwx nqmq nr nabznge
\q2 Mz nzkrlz-krm nzao-krnge drtwrnge.
\q1 
\v 24 Murde na-aelwa-ngrme bange nqmq krnge kxtrka,
\q2 X namailzq ninge mz nzti kxtubq.
\c 140
\cl Sam Kratrtqki-esz'-nzpnu-pwx (140)
\s1 Kxna-atrkatilr Ninge
\d Nabz ne Devet kx yrbzle mz kxrmailz ngr dzbe kxnzngrng.
\s2 Arlapxbz Ninge
\q1 
\v 1 Yawe, arlapxbz ninge mz kxdrka'-ngrng
\q2 Kcng tzsuti drtwrdr nzatrkati-krdr ninge.
\q1 
\v 2 Nzryrlq-zvzng drtwr kxtrka mz nabzdr,
\q2 X nzapqtr-zvzlr drtwr ngr nzotangr.
\q1 
\v 3 Natqdr nzlvati apule nipna kr ningidoe kc tqrtq,
\q2 Mz nzrpikitingr x nzrpibqtingr. \x + \xo 140:3 \xt Rom 3:13\x*
\s2 Mz Mq Enqmi Rngeng
\q1 
\v 4 Yawe, arlapxbz ninge mz zmatq ngrdr.
\q2 X aclve-angidrbz ninge mz krkcng tzryrlqng drtwr kx na-atrkati-ngrdr ninge.
\q1 
\v 5 Sc tzglqpx-lzbqng nzamwi-kapqlr trtxki kx naprtz-ngrne mz nzatu-krdr br mz nzti rnge.
\q2 X tzryrlqng drtwr kx nalolvz-ngrdr ninge.
\s2 Nim Gct Rnge
\q1 
\v 6 Yawe, xlrm nzkrka'-krnge,
\q2 Murde rpi-zvzbo bam kx, “Yawe, nim Gct rnge.”
\q1 
\v 7 Kxetu rnge, nzxplr-krm arlapxle ninge.
\q2 X amyaq narnge mz nzvecngr.
\q1 
\v 8 Bzkq rlr-ngrbzme nzngidatikr drtwr kcng tzyrlq kxdrka'-ngrng lcng
\q2 Mz nzbilvz-krdr nzlolvz-krdr ninge, kxmule-esz' nzsuti zlwz drtwrdr.
\s2 Ayrplapx Nidr
\q1 
\v 9 Enqmi lcng tztu-ngalelvzlr ninge.
\q2 Batrpz nzayzlu-krbz badr natq ngr zngya kcng tzpimlr bange, murde nangq-moule nidr.
\q1 
\v 10 X nyr natatiom nangc-ngrdr,
\q2 X nartctiongr nidr mz gq kx trnarlapx-ngrdru.
\q1 
\v 11 Suti drtwrnge kx krkcng tzpokiang nzmnc-krdr mz drtc' natangqneo.
\q2 X da kxtrka nadwatibzle krkcng tzota-zvzng mz nzodati-krde nidr.
\s2 Okatr Ninge
\q1 
\v 12 Yawe, krlzx kx tu-zvzbzme mz nibr kx trpnzngr scde zmatq,
\q2 X okatrq kxnzkxpung mz nzatubqti-krm da kx vz-rbr.
\q1 
\v 13 Leplz kxnztubqng sa na-awibzng bam,
\q2 X namnc-zvzamu badr.
\c 141
\cl Sam Kratrtqki-esz'-nzpnu-pwx-nrade-esz' (141)
\s1 Arlapxbz Ninge Mz Zmatq Ngr Alwx X Kxdrka'-ngrng
\d Nabz ne Devet.
\q1 
\v 1 Yawe, kqle-zvzx nim. Xlrm natqnge.
\q2 Vz-anim x okatrp ninge. Yawe, kqle-zvzx nim.
\q1 
\v 2 Abrtzlvz nzkrka'-krnge nzvzdz-krbzle bam na-apule zsikapu ngr bqlr nc ninz kc tzangcbz bam.
\q2 X nzglalz-krnge mqnge na-apubzle bam blz ngr milzpq.
\q1 
\v 3 Yawe, mailz ninge murde ma tqrpitix natq kxtrka,
\q2 A' nzycmne-krnge natubqpwz.
\q1 
\v 4 Bzkq rlr-ngrme nzsutikr drtwrnge da kxdrka'ngr,
\q2 Murde ma tqprtrpo badr kxnzaleng alwx
\q1 Mz nzale-krdr da kxvz-rbr,
\q2 X ma tqprlvz mzke' da kxtrka.
\q1 
\v 5 A' mz nzprtr-krbo badr, mrlzvxitx nzayrplapxngr ninge.
\q2 Murde nzatubqtingr apule tolo ngr nzamrlzngr.
\q1 Bzkq narnge mqngi,
\q2 Murde krka'-zvz-ngrne kx nayrlqpx-lzbqnge mz nzvz-rbr-krdr.
\q1 
\v 6 X ncblo sa na-abrtz-ngrdr natq ngr nzatubqti-krnge nidr
\q2 Mzli kc namc-ngrdr nzbzkr kxnzetu r kxdrka'-ngrng mz nzayrplapxngr nidr.
\q1 
\v 7 X nrvr ngrdr sa natwzbetxne mz drtc'
\q2 Mz nzapu-krdr lrdz kcng tqalvxlz nrc.
\q1 
\v 8 Yawe, nim Gct rnge, abrtr-zvzbo drtwrnge bam.
\q2 Nanginim lrpalvc nyznge, murde ma tqmnc-lxlrx.
\q1 
\v 9 Mailz ninge murde ma tqprtzx mz trtxki sc kxdrka'-ngrng,
\q2 X ma tqtaox mz gq kx nzekqtilr.
\q1 
\v 10 Mrlzvxitx nzdwatr-mou-krdr mz br scdr,
\q2 A' drtqnge naopx zvz.
\c 142
\cl Sam Kratrtqki-esz'-nzpnu-pwx-nrade-li (142)
\s1 Aopxbz Drtqnge Mz Nzkxpu-krngeng
\d Nabz ne Devet mzli kc tqmncpx-ngrmle mz butqbr.
\q1 
\v 1 Yawe, yrni-katobo bam,
\q2 Murde naokatrq ninge.
\q1 
\v 2 X pibo bam da kx lctr-ngrbz drtwrnge,
\q2 X nzkxpungr kcng tqprtzmqng bange.
\q1 
\v 3 Kxmule-esz' nabznge baonepe, a' nim kc tqrtwayz zvz mz nzvz-krnge.
\q2 Murde enqmi rngeng nzryrlq-kapqpeng trtxki mz lrpzki rnge.
\q1 
\v 4 X kx obq-ngalex kc nrlc, trpnzngr kx mcx kx naokatrle ninge,
\q2 X trpnzngr kz kx na-aclve-zpwxle ninge.
\q1 
\v 5 Yawe, kqlex nim,
\q2 Murde nim me rlakitrx, x nim nou nzmnc-zpwx-krnge.
\q1 
\v 6 Ayzlum natqnge
\q2 Murde nabznge talvzo zlwz.
\q1 
\v 7 Aopxbz drtqnge mz nzkxpu-krngeng murde na-awibo bam,
\q2 X kxnztubqng natu-ngalelvzlr ninge mz nzglqlz-krdr nim mz nzamrlz-zlwz-krm ninge.
\c 143
\cl Sam Kratrtqki-esz'-nzpnu-pwx-nrade-tq (143)
\s1 Nzadwatrlr Ninge Mz Nzlo
\d Nabz ne Devet.
\s2 Xlrm Nzkrka'-krnge
\q1 
\v 1 Yawe, xlrm nzkrka'-krnge x ayzlum natqnge,
\q2 Murde tubq-esz'ngrn x angidati-zvzq.
\q1 
\v 2 Bzkq ayrplapxq ninge, kxnzawz nem,
\q2 Murde trpnzngr leplz mz nrlc kxtubq mz nzobq-krm.
\q1 
\v 3 Enqmi rngeng nzmaneutilr ninge x nzrnzbrtiolr ninge mz drtc',
\q2 X nzadwatrlr ninge mz nzlo, apux kxbz kx mnclzm mz gq.
\q1 
\v 4 Nabznge baonepe,
\q2 X talvzo zlwz.
\q1 
\v 5 A' amqtrx drtwrnge mz nzaotikr drtwrnge zbq kcng tqvztxpeng.
\q2 X dcpx mz drtwrnge da kxnzkctipxng kcng tqalemeng bagr.
\q1 
\v 6 Delc tqglalz-ngrbo mqnge bam,
\q2 Murde brlxkztitx zlwz drtwrnge nim.
\s2 Ayzlum Natqnge
\q1 
\v 7 Yawe, ayzlu-anim natqnge murde nabznge baonepe.
\q2 Bzkq rlaszq ninge, murde ma tqbzx.
\q1 
\v 8 A' pi-zvzm bange mz rngalx kang kqlu kx aodu-zvzq ninge,
\q2 Murde abrtrpo drtwrnge bam.
\q1 X mailz ninge mz lrpzki kx nao-zlix,
\q2 Murde mnc-xgle-zvzx nim.
\q1 
\v 9 Yawe, bzkq rlr-ngrbzme mz enqmi rngeng nzlolvz-krdr ninge,
\q2 Murde nim me rlakitrx.
\q1 
\v 10 Gct rnge, alvztrp bange nzale-krnge me pnz drtwrm.
\q2 X rtwayzm bange mz zmrlz ngrm, murde namnc-zpwxx.
\q1 
\v 11 Yawe, arlapx ninge da kc tqwai nzpi-krmle murde ma tqbzx.
\q2 X tum mz nibrnge mz nzkxpu-krngeng amrlx, murde tubq-esz'ngrn.
\q1 
\v 12 Lolvzting enqmi rngeng x milxtxo alo nidr.
\q2 Murde aodu-zvzq ninge, kxnzawz nem.
\c 144
\cl Sam Kratrtqki-esz'-nzpnu-pwx-nrade-pwx (144)
\s1 Sa Namrlzbz Mz Leplz Mrkcng Amrlx Tqamrlz Yawe
\d Nabz ne Devet.
\s2 Mevalu Rnge
\q1 
\v 1 Yawe, glqpxx nim, murde nim butqbr nyznge.
\q2 X alvztrpe' bange nzrpnangr x axplrq ninge mz nzotangr.
\q1 
\v 2 Brti drtwrnge nzngini-krm lrpalvc nyznge.
\q2 Nim Mevalu kx xplr x me rlakitrx.
\q1 Nim temz ngr lomrnge kc tqyrputrngr nipna.
\q2 X okatr-zvzq ninge mz nzaovxio-krnge lr mrkzbleng.
\q1 
\v 3 ?A' memule tqmatq-ngrgr mz drtwrm?
\q2 ?X memule tqmrlzti-ngrn nigr leplz txneng?
\q1 
\v 4 Nzmrbcnekr nzlukr leplz apule nzyrplaokr nrc kxesz'.
\q2 X apu-kzle zmio kc tqmrbr mz milzpq.
\q1 
\v 5 Yawe, lvxpx bongavz mz nzvzo-krme.
\q2 Maletr newz murde nasikapung nzapulr trmami.
\q1 
\v 6 Atwzlro-ngrm bzlrpc mz nzaodaliti-krm enqmi rngeng.
\q2 Pnzting nidr mz nipna scmqng murde navotxng.
\q1 
\v 7 Yawe, rtrngztiom ninge mz nzokatr-krm ninge,
\q1 Na-apule kx veclzme ninge me boongr prla.
\q2 X arlapxbz ninge mz mq lr mrkzbleng.
\q1 
\v 8 Murde nzmrlzti-txpwzlr nigr mz nzycmne-krdr.
\q2 A' trnzatutrlru nzesz'tikr drtwrgr badr.
\s2 Nzkrka'-krnge
\q1 
\v 9 Gct, sa nangr-ngrbo bam nabz kxmrna.
\q2 X na-angrlvzx nim mz nzayrni-krnge gita.
\q1 
\v 10 Murde okatr-zvzq king nemqng mz nzaovxio-krdrng.
\q2 X sc tqarlapxpebzme ninge mz toki r vea kxmalc, murde ninge kxnzawz nem.
\q1 
\v 11 Mzli ka arlapx-mopwz ninge mz mq lr mrkzbleng murde nzmrlzti-txpwzlr nigr mz nzycmne-krdr.
\q2 A' trnzatutrlru nzesz'tikr drtwrgr badr.
\q1 
\v 12 Delc mz nzkqlukr enqmi rgrng,
\q2 Krka'-ngrgr kx na-amrlzq nigr lr mrnyzm.
\q1 Murde obla negrng naxplrnelzm mz nzapu-krdr nounc kx xplr.
\q2 X olvi negrng naxplr-kzng x mztr nalqngi mz nzapu-krdr nctrpou ngr ma nyz king.
\q1 
\v 13 Dalr nrlanc nyzgrng nalvc-angidrng,
\q2 Murde bxli scgrng nayrbu zvz mz dakxnzng.
\q1 X animol negrng naeloting
\q2 Murde neidrng nayrlwrtxne.
\q1 
\v 14 X kxnzrmailz rgrng na-ale-zpwxlr nzwz-krdr,
\q1 Murde leplz ma tztangetrplr drkq ngr mztea nyzgr mz nzvzmi-krdr nigr mrnyzdr,
\q2 X lr mztea nyzgrng ma tzodalineng mz nzvzdz-krm nelzdr.
\q1 
\v 15 Yawe, leplz kcng tqokatrq mz da lcng, sa na-abrtz-ngrdr nzmnc-zpwx-krdr.
\q2 Murde leplz amrlx kcng tqnginim Gct rdr sa namnc-zpwx-zvzng.
\c 145
\cl Sam Kratrtqki-esz'-nzpnu-pwx-nrade-nzlvqn (145)
\s1 Zluli X Zmatq Ngr Yawe
\d Nabz ngr nzrglqpxngr ne Devet.
\s2 Kzdq Nabz Ngr A, B, C
\q1 
\v 1 \qac A\qac*wi-zvzbo bam mz nzglqpx-krnge nim,
\q2 Murde nim Gct rnge x mnclzbo bam.
\q1 
\v 2 \qac B\qac*ilvzx nim mz nzawi-krbo bam.
\q2 X sa naglqpx-zvzx nim mz zbq kang kqlu.
\q1 
\v 3 \qac C\qac*lveq nrlc mz zmatq ngrm kx trpnzngr kxrkrlz.
\q2 Yawe, myatxlz-esz'ngrn x takitrde nzrglqlzngr nim.
\q1 
\v 4 \qac D\qac*oa nemqng sa nayapwxti-zvzbzlr mz doa nedrng,
\q2 Da kcng tqetuting tqmatq tqaletiqng.
\q1 
\v 5 \qac E\qac*u, x sa na-aoti-zvz-kzx drtwrnge nzwz-krmqng kxmrlzvxing,
\q2 X nzetu-esz'ngr-krm mz zmatq.
\q1 
\v 6 \qac G\qac*ct, sa nayapwxtipx leplz da kxnzkctipxng kcng tqwz-ngrn.
\q2 X sa napipxx nzmyalz-esz'ngr-krm.
\q1 
\v 7-8 \qac I\qac*pq-aniq leplz murde yc mz drtwrm nidr.
\q2 Murde nivz lrm x nzaodu-krm tqyc tqyc.
\q1 \qac J\qac*zsiq leplz mz nztubqngr x sa na-angrlvzlr nim.
\q2 Sa nalepxlr nrpa ngr nzmrlz-esz'ngr-krm.
\q1 
\v 9 \qac K\qac*xetu, mrlztiq leplz amrlx,
\q2 X yc zlwz mz drtwrm doa amrlx kcng tqwz-ngrn.
\q1 
\v 10 \qac L\qac*eplz nemqng amrlx sa na-awibzng bam,
\q2 X doa amrlx kcng tqwz-ngrn sa naglqlzlr nim.
\q1 
\v 11 \qac M\qac*z nrlc tulvzo, sa nayapwxtipxlr nzmyalz-esz'ngr-krm,
\q2 X nzetukr zmatq ngrm mz nzngini-krm king.
\q1 
\v 12 \qac N\qac*rpa ngr nzwz-krmqng etu, mz da kxmrlzting kcng tqwz-ngrn mz nzaclve-krm,
\q2 Sa nakrlz leplz amrlx.
\q1 
\v 13 \qac O\qac*bqom mz nrlc mz nzaclve-krm kc tqyc tqyc,
\q2 X nzngini-krm king tqvzpe tqvzpe.
\q1 \qac P\qac*ipx-zvzq natq kx na-angidatiq,
\q2 X aelwapx-zvzq nivz lrm mz da amrlx kcng tqaleq.
\q1 
\v 14 \qac R\qac*ngiscm zmatq kx okatrle leplz kcng tzkxpung,
\q2 X axplrle nabz leplz kcng tqtalvzo.
\q1 
\v 15 \qac S\qac*a narkabzme dakxnzng mz kxnzlung amrlx,
\q2 Mz nzmnc-xgle-krdr nim mz da amrlx.
\q1 
\v 16 \qac T\qac*ekqtrq nzbrtale-krdr mz nzakrlc-krbzme nelzdr,
\q2 X drtwrdr esatxpx zpwx.
\q1 
\v 17 \qac V\qac*z zvz nzale-krm da kx tubq-esz'ngr,
\q2 X aelwapx-zvzq nivz lrm mz da amrlx kcng tqaleq.
\q1 
\v 18 \qac W\qac*xbu-aepztrpzme mz krkcng tzkqlelr nim,
\q2 Mz nzbrti-zpwxkr drtwrdr nim.
\q1 
\v 19 \qac X\qac*lrq nzyrnikr leplz kcng tzamrluelr nim,
\q2 X ayzlubzme natqdr mz nzarlapx-krm nidr.
\q1 
\v 20 \qac Y\qac*awe, tu-zvzbzme mz nibr leplz kx nzmrlztilr nim,
\q2 A' odati-atwrnr-ngrn kxdrka'-ngrng.
\q1 
\v 21 \qac Z\qac*bq kalvz sa naglqlzx nim.
\q2 X krkcng tzlung tqwz-ngrn, nzangio-krdr nim tqvzpe tqvzpe.
\c 146
\cl Sam Kratrtqki-esz'-nzpnu-pwx-nrade-esz'mz (146)
\s1 Na-abrtxtrpwzku Drtwrgu Mz Yawe
\q1 
\v 1 \bd Naglqlzku Yawe!\bd*
\q2 Na-angiox nide mz nabznge.
\q1 
\v 2 Naglqlzx Gct rnge mzli ka tqlube-ngrne,
\q2 X na-angrlvzx nide.
\q1 
\v 3 Bzkq abrtrpzku drtwrgu mz kxnzrmailzng,
\q2 Murde leplz trnzkrlzlru nzarlapx-krdr nigu.
\q1 
\v 4 Nabzng x nzyrtzmqng mz drtc',
\q2 X mzli lcpwz drtwr kcng tzyrlqlr botxpx-kzpz.
\q1 
\v 5 A' nangi da kxmrlz nzabrtr-krbzku drtwrgu mz Yawe.
\q2 Murde takitrde mz nzmnc-xgle-krgu Gct r Jekop.
\q1 
\v 6 X Yawe nide Kxrpalz,
\q1 Kc tqwz-ngrde bongavz, nrlc, x prla, x dalrdrng amrlx.
\q2 X atutr-zvzle natqdeng amrlx.
\q1 
\v 7 Nzatubqti-krbz Yawe da mz kxnzkxpung tubq.
\q1 X rka-zvzbz dakxnzng mz kxnzbrtaleng.
\q2 X aopxbzle drtq kxnzmnclzbzng mz mq enqmi rdrng.
\q1 
\v 8-9 X nide kz kx aopxbzle mzku.
\q2 X atulzmle kxnzobqszong.
\q1 Yawe aclvele lr mrkzbleng kx mnckung badr.
\q2 X okatrle kxnzbzszng x kxnzabzong.
\q1 Mrlztile kxnztubq nedeng,
\q2 A' odatile drtwr kcng tzyrlq kxdrka'-ngrng.
\q1 
\v 10 Yawe ni-alode King!
\q1 Nzaclvekr Gct rgu, nigu lr Jerusalem, tqvzpe tqvzpe.
\q2 \bd Naglqlzku Yawe!\bd*
\c 147
\cl Sam Kratrtqki-esz'-nzpnu-pwx-nrade-rlimz (147)
\s1 Yawe Amrlzle Nigu Leplz Nedeng Mz Zmatq Ngrde
\s2 Yawe Rngisc Zmatq Kx Xplr
\q1 
\v 1 \bd Naglqlzku Yawe!\bd*
\q1 Mrlzvxitx nzangrlvz-krgu Gct rgu.
\q2 Brngzvxitx x takitrde nzglqlz-krgu nide.
\q1 
\v 2 Yawe yrlq-zpwx-moule Jerusalem,
\q2 Mz nzvzmi-kr-mople lr Israel kcng tzlolvzting enqmi rdrng.
\q1 
\v 3 Rka-mopwz nzabrtzngr mz leplz lcng drtwrdr tqtalvzo,
\q2 Mz nzawxo-krbzle drtwrdr apule kx pnutibzle kxsqki rdr.
\q1 
\v 4 Krlzle me krlzbz nzkqlukr vri,
\q2 X yrlqtibzle drtqdrng amrlx.
\q1 
\v 5 Yawe etu-esz'ngr x rngisc zmatq kx xplr.
\q2 X trpnzngr kx rkrlzlzbz nzyrplapx-krde.
\q1 
\v 6 Atubxlzle kxnzobqszong,
\q2 A' rnzbrtiole kxdrka'-ngrng mz drtc'.
\s2 Mnc-xgleku Zmatq Rde
\q1 
\v 7 Nangr-ngrgu nabz kx yrlvi mz nzayrni-krbzku gita mz Yawe,
\q2 Mz nzawi-krbzku bade.
\q1 
\v 8 Murde yrlqtibzle dcbz mz bongavz x adco-ngrmle tewa nalrprngr drtc',
\q2 Murde nalutingr nabr kxvo mz nra.
\q1 
\v 9 Rkabz dakxnzng mz animol amrlx,
\q2 X aputrle nei utc amrlx mz nzyrni-krbzlr bade mz dale ngr nelzdr.
\q1 
\v 10 Delc trmrlz-ngrpwzleu mz Yawe nzabrtr-ngrbzku drtwrgu mz nzxplrkr hcsi ngr vea negung,
\q2 X nzaovxiokr ncblo ngr vea negung.
\q1 
\v 11 A' mrlzbz bade krkcng tzamrluelr nide,
\q2 X tzmnc-xglelr nzaodu-zvz-krde nidr.
\s2 Zmatq Ngr Natqde
\q1 
\v 12 Nigu lr Jerusalem kcng tzangiolr Yawe mz Newz Saeon,
\q2 Naglqlzku nide, kc tqngi Gct rgu.
\q1 
\v 13-14 Murde amqngitibzle naonrx ngr Jerusalem x bz ngr mrnyzgr.
\q2 Amrlz-zvzle lr mzteadau nyzde,
\q1 X amnc-zpwxle nigu leplz nedeng amrlx
\q2 Mz nzrka-krmle bagu da kxmrlzting.
\q1 
\v 15 Mzli kc tqycmnepx-ngrde
\q2 Dalr nrlc nzvz-nqblq-anilr natqde.
\q1 
\v 16 Mz mzli r zbao, sncu prlxlvztxde drtc' apule lrpz kxprki.
\q2 X dcbz vzom mz nrlc apule zsikapu.
\q1 
\v 17 X muli-aes rlxom mrkcng amrlx.
\q2 Murde da amrlx lcng nayclzbzng mz zmatq ngr zbao.
\q1 
\v 18 A' mz nzycmne-mou-krde, nrlc kc tqpqpe,
\q2 X nzwqkr nenq kxpq ayrle-mouleng lue kcng tqngi aes.
\q1 
\v 19 X natq lc tqmatq tqpim Yawe bagu, nigu leplz nedeng,
\q2 Murde nayrlq-angidrku nzalvztr-krdeng x Loukxtr scde.
\q1 
\v 20 Trpipxpwzleu lou scdeng mz lr mrkzbleng,
\q2 A' nigu txpwz, mz nzngini-krgu leplz nedeng.
\q2 \bd Naglqlzku Yawe.\bd*
\c 148
\cl Sam Kratrtqki-esz'-nzpnu-pwx-nrade-rtqmz (148)
\s1 Nzrglqlz-zvzngr Yawe
\q1 
\v 1-2 \bd Glqlz-zvzamu Yawe\bd*, nimu lr Heven amrlx.
\q2 Nimu enjrl nedeng, glqlz-zvzamu Yawe.
\q1 
\v 3 Glqlz-zvzamu Yawe, nepi ncdr temz.
\q2 X nimu vri amrlx, glqlz-zvzamu Yawe.
\q1 
\v 4 Glqlz-zvzamu nide, dalr bongavz amrlx.
\q2 X nimu lue kcng wq, glqlz-zvzamu nide.
\q1 
\v 5 Glqlz-zvzamu drtqde. Kxrpalz wz-ngrde nimu,
\q2 Mz natq kx kapxle. Glqlz-zvzamu drtqde.
\q1 
\v 6 Natqde tqyc tqyc. Yrlqti-lxblrbzle
\q2 Me namnc-alo-ngrnamu. Natqde tqyc tqyc.
\q1 
\v 7 Glqlz-zvzamu Yawe, nimu nc x mepwz amrlx
\q2 Ngr prla x me boongr. Glqlz-zvzamu Yawe.
\q1 
\v 8 Vz-nqblqamu natqde, bzlrpc x muli aes.
\q2 Dcbz, nenq x tewa, vz-nqblqamu natqde.
\q1 
\v 9 Glqlz-zvzamu Yawe, newz x nra amrlx.
\q2 Nimu nounc ngr peto, glqlz-zvzamu Yawe.
\q1 
\v 10 Glqlz-zvzamu nide, animol x utc amrlx.
\q2 X da kx nzngrlaneng, glqlz-zvzamu nide.
\q1 
\v 11 Naglqlz-kzku Yawe, nigu lr nrlc amrlx.
\q2 Kxnzetung x kxnzrmailzng, naglqlz-kzku Yawe.
\q1 
\v 12 Naglqlz-kzku nide, nigu obla x olvi.
\q2 Itoto x lrtzlvzng, naglqlz-kzku nide.
\q1 
\v 13 Naglqlzku drtqde, nigu amrlx ngrgu.
\q2 Drtqde myatxlz-esz'ngr. Naglqlzku drtqde.
\q1 Nzmyalz-esz'ngr-krde myaszlzle drtc',
\q2 X bongavz kz. Nzmyalz-esz'ngr-krde!
\q1 
\v 14 Naglqlz-zvzku Yawe, nigu lr Israel nedeng.
\q2 Axplrle x aodule nigu, \bd naglqlz-zvzku Yawe.\bd*
\c 149
\cl Sam Kratrtqki-esz'-nzpnu-pwx-nrade-rpwxmz (149)
\s1 Nzbilvz-krgu Nzaovxiokr Yawe
\q1 
\v 1 \bd Naglqlzku Yawe!\bd*
\q1 Nangr-ngrbzku bade nabz kxmrna.
\q2 Naglqlzku nide mz nzyrlwrpx-krm leplz nedeng mz Mangr-nzangiongr nide.
\q1 
\v 2 Nigu lr Israel na-abrtzlvzku Yawe mz nzngini-krde Kxrpalz.
\q2 X nigu lr Jerusalem naelalz-ngrm drtwrgu King rgu.
\q1 
\v 3 Naelabzku bade
\q2 Mz nzrta-krgu kcte x nzayrni-krgu gita.
\q1 
\v 4 Murde Yawe abrtz-zlwz-ngrde nigu leplz nedeng,
\q2 X aovxiole enqmi rgung mz nzmnc-xgle-krgu nide.
\q1 
\v 5 Delc nigu kxnztrng nabilvzku nzaovxio-krgu.
\q2 X nangr-abrtzku mz nrlckxbq krlzbzle mz nrlckxngrlx.
\q1 
\v 6 Naogu namalqlvzlr Gct.
\q2 X narmaleku toki r vea mz mqgu.
\q1 
\v 7 Murde na-ayzlubzku da mz lr mrkzbleng,
\q2 Mz nzatutr-krgu nzaryplapxkr Gct leplz lcng.
\q1 
\v 8 X nape-amqngiku king rdrng,
\q2 Badr kxnzrmailz rdrng amrlx mz nzaovxio-krgu nidr.
\q1 
\v 9 Mz nzamatqkr Gct nigu, rlr-ngrmle bagu, nigu leplz nedeng,
\q2 Nzprtr-krgu mz nzatutr-krde natqde mz nzayrplapx-krgu lr mrkzbleng.
\q2 \bd Naglqlzku Yawe!\bd*
\c 150
\cl Sam Kratrtqki-esz'-nzpnu-nzlvqn (150)
\s1 Naelabzku Mz Yawe
\q1 
\v 1 \bd Naglqlzku Yawe\bd* mz nzmnc-krde Mangr-nzangiongr,
\q2 X nzmnc-krde Heven kc tqmyalz.
\q1 
\v 2 Na-angrlvzku nide nzmyalz-esz'ngr-krde
\q2 Mz nzale-krde da kcng tqmatq.
\q1 
\v 3-5 Naelamibzku nrasrpwale
\q2 X natz-katobzku bade kcte.
\q1 Naelabzku bade navzmi nzayrpla-krgu da,
\q2 Nzrta-krgu da, x nzayrlewz-krgu da mz mqgu.
\q1 Navxubzku trpu x ncblei.
\q2 X na-ayrniku gita x ukzlele mz nzglqlz-krgu nide. \fig Naelabzku mz Yawe.|alt="027 dancing music makers" src="027-Jud5.1.tif" size="SPAN" loc="PSA 150:3-5" copy="LLL Language Recording" ref="150:3-5"\fig*
\q1 
\v 6 Nigu kxnzlung amrlx, naelalz-ngrm drtwrgu Yawe.
\q2 \bd Naglqlzku Yawe!\bd* 
