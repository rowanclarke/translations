\id HEB  
\h Hebera 
\toc1 Hebera 
\toc2 Hebera 
\toc3 Hebera 
\mt1 Hebera  
\c 1  
\s1 O KA EPISETOLE  
\b  
\q1
\v 1 O KE Akua, o ka mea i olelo pinepine mai i na wa kahiko i ka poe kupuna, me kela mea a me keia mea, ma ka poe kaula,   
\q1
\v 2 Oia ka i olelo hou mai ia kakou i keia mau la muli iho nei ma ke Keiki, ka mea i hooliloia e ia i haku no na mea a pau, ma ona la hoi ia i hana'i i ka lani a me ka honua.   
\q1
\v 3 Oia ka olinolino o kona nani, a me ka like loa o kona ano maoli, e hoomau ana i na mea a pau ma kana olelo mana iho, a, hoolilo iho la ia ia iho i mea e maemae ai ko kakou hewa, noho iho la ia ma ka lima akau o ka Moi maluna lilo;   
\q1
\v 4 A ua hookiekieia'e maluna loa o na anela, e like me ka oi ana o ka maikai o kona inoa i loaa ia ia, mamua o ko lakou.   
\q1
\v 5 No ka mea, o ka anela hea kana i olelo aku ai i kekahi manawa, O oe no ka'u Keiki, i keia la no ua hoohanau aku au ia oe? Eia hoi, E lilo au i Makua nona, a e lilo oia i Keiki na'u?   
\q1
\v 6 Eia hou hoi, i kona hookomo ana i ka makahiapo i ke ao nei, i iho la ia, E hoomana mai ka poe anela a pau o ke Akua ia ia.   
\q1
\v 7 A ua oleloia mai hoi no ka poe anela, Ua hoolilo oia i kona poe anela i mau makani, a i kana poe kauwa lawelawe i lapalapa o ke ahi.   
\q1
\v 8 Aka no ke Keiki, O kou nohoalii, e ke Akua, e mau loa ana no ia; a he hoailonamoi o ka pono ka hoailonamoi o kou aupuni.   
\q1
\v 9 Ua makemake hoi oe i ka pono, a ua inaina i ka hewa; nolaila i poni ai ke Akua, kou Akua, ia oe me ka aila o ka olioli maluna o kou mau hoa.   
\q1
\v 10 Eia hoi, i ka wa kahiko, ua hookumu oe, e ka Haku, i ka honua; a o na lani hoi ka hana a kou mau lima.   
\q1
\v 11 E pau ana no lakou, aka, e mau ana no oe; e lualua loa ana no lakou a pau me he kapa la;   
\q1
\v 12 A e opiopi ana no oe ia lakou me he aahu la, a e lilo aku; aka, e oia mau ana no oe, a o kou mau makahiki, aole loa e pau.   
\q1
\v 13 O ka anela hea kana i olelo aku ai i kekahi manawa, E noho oe ma ko'u lima akau, a hoolilo iho au i kou mau enemi i paepae wawae non?   
\q1
\v 14 Aole anei lakou a pau he poe uhane lawelawe i hoounaia, e kokua i ka poe e lilo ana i poe hooilina o ke ola?   
\c 2  
\b  
\q1
\v 1 NOLAILA hoi, e pono e lelepau kakou ia mau mea a kakou i lohe ae nei, o haule ia kakou i kekahi manawa.   
\q1
\v 2 No ka mea, ina i kau paa ia ke kanawai i oleloia mai ma ka poe anela, a ua hoopai pono ia ka hala, a me ka hoopale a pau;   
\q1
\v 3 Pehea la uanei kakon e pakele ai ke malama ole i ke ola nui nei; ka mea i haiia mai i kinohi e ka Haku, a i hooiaioia mai hoi ia kakou e ka poe i lohe;   
\q1
\v 4 O ke Akua kekahi e hooiaio pu mai ana ma na hoailona, a me na mea kupanaha, a me kela hana mana, a me keia hana mana, a me ka haawi ana mai o ka Uhane Hemolele, e like me kona makemake?   
\b  
\q1
\v 5 Aole hoi oia i hoolilo iho malalo iho o ka poe anela i ke ao e hiki mai ana, a makou e olelo nei.   
\q1
\v 6 Aka, ua hoike mai kekahi ma kekahi wahi, i ka olelo ana mai, Heaha ke kanaka i manao mai ai oe ia ia? a o ke koiki a ke kanaka i ike mai ai oe ia ia?   
\q1
\v 7 Ua hana iho oe ia ia malalo iki iho o ka poe anela: ua kau mai oe maluna ona i ka nani a me ka mahalo i lei nona; ua hoolilo oe ia ia i haku no na mea a kou lima i hana'i.   
\q1
\v 8 Nau no i waiho na mea a pau malalo ae o kona mau wawae. A, i kona hoolilo ana i na mea a pau malalo iho ona, aohe mea koe ia ia i waiho ole ia'e malalo ona. Aole nae kakou i ike i na mea a pau i waihoia'e malalo ona:   
\q1
\v 9 Aka, ua ike kakou ia Iesu i ka mea i hooliloia malalo iki iho o ka poe anela, no ka make aua, i hooleiia mai ai i ka nani a me ka mahalo; i lilo hoi ia i ka make no na kanaka a pau, ma ka lukomaikai o ke Akua.   
\q1
\v 10 No ka mea, ua pono i ka mea nona na mea a pau, nana hoi na mea a pau, i kona alakai ana i na keiki he nui wale iloko o ka nani, ma o ka hooehaia ana, e hoonani loa ai i ko lakou Alii e ola'i.   
\q1
\v 11 No ka mea, o ka mea nana i hoohuikala mai, a o ka poe i hoohuikalaia mai, no ka mea hookahi lakou a pau; no ia mea, aole ia i hilahila ke kapa aku ia lakou he mau hoahanau,   
\q1
\v 12 I ka i ana, E hai aku au i kou inoa i ko'u mau hoahanau; e hoolea hoi au ia oe mawaeoa o ke anaina kanaka.   
\q1
\v 13 Eia hou hoi, E hilinai aku au ia ia. Eia hou hoi, Eia hoi au, me na keiki a ke Akua i haawi mai ai ia'u.   
\q1
\v 14 A, i ka lawe pu ana o na keiki i ka io a me ke koko, pela hoi oia i lawe pu ai i ua mau mea la; i hiki ai ia ia, ma kona make ana, ke hoopio i ka mea ia ia ka mana e make ai, oia ka diabolo:   
\q1
\v 15 A e hoola hoi i ka poe i noho pio i ko lakou wa e ola nei a pau, no ka makau i ka make.   
\q1
\v 16 Aole hoi oia i kokua i ka poe anela; aka, ua kokua mai oia i na mamo a Aberahama.   
\q1
\v 17 Nolaila, ua pono e hoohalike loa ia oia me kona poe hoahanau, i lilo ai ia i kahunanui aloha, a me ka hoopono ma na mea no ke Akua, i hiki ai ia ka hoomalu ana no ka hewa o kanaka.   
\q1
\v 18 A, no ka mea ua ehaeha oia i ka hoowalewaleia, ua hiki no ia ia ke kokua i ka poe i hoowalewaleia mai.   
\c 3  
\b  
\q1
\v 1 NO ia mea hoi, e na hoahanau laa, ka poe i hea pu ia mai mai ka lani mai, e manao nui i ka Lunaolelo, a me ke Kahuna nui a kakou i hooiaio aku ai, o Kristo Iesu;   
\q1
\v 2 Ka mea i malama pono i kona mea nana i hoolilo mai, e like hoi me Mose iloko o kona hale a pau.   
\q1
\v 3 No ka mea, ua pono e hoonani nui ia aku oia mamua o Mose, e like me ka oi ana o ka mahaloia o ka mea nana i hana i ka hale mamua o ka hale.   
\q1
\v 4 A o kela hale keia hale a pau, ua hanaia ia e kekahi; a o ka mea nana i hana na mea a pau, o ke Akua ia.   
\q1
\v 5 A ua hoopono no o Mose iloko o kona hale a pau i kona kahu ana, no ka hoike ana i na mea e haiia ana.   
\q1
\v 6 Aka, o Kristo, i konakeiki ana maluna o kona hale iho: o kakou no hoi ua hale la, ke hoopaa kakou i ka manao pono, a me ka manaolana e olioli ai i mau a hiki i ka hopena.   
\q1
\v 7 Nolaila, i ka olelo ana mai o ka Uhane Hemolele, I keia la, i ko oukou lohe ana i kona leo,   
\q1
\v 8 Mai hoopaakiki i ko oukou naau e like me ia i ka hoonaukiuki ana, i ka la i hoaoia'i ma ka nahelehele;   
\q1
\v 9 I ka hoolawehala ana mai o ko oukou poe kupuna ia'u, a me ka hoao ana mai ia'u, i ko lakou ike ana mai i ka'u mau hana i na makahiki he kanaha.   
\q1
\v 10 Nolaila, i huhu aku ai au ia hanauna, i aku la hoi au, Ua lalau mau lakou ma ka naau; aole hoi lakou i hooiaio mai i ko'u mau aoao.   
\q1
\v 11 Pela hoi au i ko'u huhu ana i hoohiki aku ai, Aole lakou e komo i ko'u wahi maha.   
\q1
\v 12 E ao hoi, e na hoahanau, o noho ka naau ino hoomaloka iloko o kekahi o oukou, i haalele ai ia i ke Akua ola.   
\q1
\v 13 Aka, e hooikaika mau kekahi i kekahi i ka wa i kapaia o Keia la, o hoopaakikiia kekahi o oukou ma ka hoopunipuni ana o ka hewa.   
\q1
\v 14 No ka mea, e loaa mai ana no o Kristo ia kakou, ke hoopaa kakou i ko kakou manao pono mua i mau a hiki i ka hopena;   
\q1
\v 15 A i ka olelo ana, I keia la i ko oukou lohe ana i kona leo, mai hoopaakiki i ko oukou naau, e like me ia i ka hoonaukiuki ana.   
\q1
\v 16 Owai la ka poe i lohe, alaila hoonaukiuki aku la? Aole anei o ka poe a pau i hele mai, ma o Mose la, mai Aigupita mai?   
\q1
\v 17 Owai la hoi ka poe ana i huhu mai ai i na makahiki he kanaha? Aole anei o ka poe i hana hewa, a haule iho ko lakou mau kupapau ma ka nahelehele?   
\q1
\v 18 Ia wai la hoi kana i hoohiki ai, aole lakou e komo i kona wahi maha, ke ole ka poe i manaoio ole?   
\q1
\v 19 Nolaila la, ua ike kakou, aole i hiki ia lakou ke komo iloko, no ka manaoio ole.   
\c 4  
\b  
\q1
\v 1 NO ia hoi, i ka waiho ana mai o ka olelo mua no ke komo ana iloko o kona wahi maha, e ao kakou o loaa ole ia i kekahi o oukou.   
\q1
\v 2 No ka mea, ia kakou kekahi i haiia mai ka euanelio e like me ia ia lakou; aka, o ka olelo i lohea, aole ia i hoopomaikai ia lakou, i ka hoopili ole ia me ka manaoio iloko o ka poe i lohe.   
\q1
\v 3 Aka hoi, o kakou ka poe manaoio ke komo iloko o kahi maha, me ia kana olelo ana, Pela hoi aui ko'u huhu i. hoohiki ai, aole lakou e komo iloko o ko'u wahi maha; oia hoi i ka pau ana o na hana mahope iho o ka hookumu ana o ke ao nei.   
\q1
\v 4 No ka mea, ua olelo mai ia ma kekahi wahi no ka hiku o ka la, peneia, I ka hiku o ka la i hoomaha'i ke Akua i kana mau hana a pau.   
\q1
\v 5 Eia hoi peneia, Aole lakou e komo iloko o ko'u wahi maha.   
\q1
\v 6 Oia hoi, no ke koe ana mai o ke komo ana o kekahi poe iloko o ua mea la, a o ka poe i hai mua ia'ku ai keia pono, aole lakou i komo no ka manaoio ole;   
\q1
\v 7 Ua hoakaka hou mai ia i kekahi la, e olelo ana ma Davida, I keia la, i ka manawa mahope loa mai; ua oleloia mai peneia, I keia la i ko oukou lohe ana i kona leo, mai hoopaakiki i ko oukou naau.   
\q1
\v 8 No ka mea, ina ua hoomaha aku o Iosua ia lakou, ina aole ia i olelo hou no kekahi la okoa.   
\q1
\v 9 Nolaila hoi, e waiho ana no he wahi maha no na kanaka o ke Akua.   
\q1
\v 10 A o ka mea hoi i komo iloko o kona wahi maha, ua hoomaha no ia i kana mau hana iho, me ke Akua la hoi i hoomaha ai i kana.   
\q1
\v 11 No ia mea, e hooikaika nui kakou e komo iloko o ia wahi maha, i ole ai e haule kekahi mamuli o ua manaoio ole la.   
\q1
\v 12 No ka mea, he ikaika, he mana hoi ko ka olelo a ke Akua, he oi nui kona mamua o ko ka pahikaua oi lua, e o ana a kaawale ke ola a me ka uhane, o na ami a me ka lolo; oia ka lunakanawai no ka noonoo a me ka naau.   
\q1
\v 13 Aohe mea nalo i kona maka; aka, ua weheia, a ua akaka loa na mea a pau i ka maka o ka mea ia ia kakou e hai aku ai.   
\b  
\q1
\v 14 A, no ka loaa ana ia kakou ke kahuna nui, i hala aku i na lani, o Iesu, ke Keiki a ke Akua, e hoopaa kakou i ko kakou hooiaio ana.   
\q1
\v 15 No ka mea, aole ia kakou ke kahuna i aloha ole mai i ko kakou nawaliwali; aka, o kekahi i hoowalewaleia'ku i na mea a pau me kakou la i hoowalewaleia mai ai, aole hoi ona hala.   
\q1
\v 16 Nolaila, e hookokoke aku kakou ma ka nohoalii aloha me ka manaolana, i alohaia mai kakou, a i loaa hoi ka lokomaikai e kokua mai ai i ka wa popilikia.   
\c 5  
\b  
\q1
\v 1 A O kela kahuna nui a o keia kahuna nui i hookaawaleia ae mai waena mai o kanaka, ua hooliloia no ia no na kanaka, ma na mea o ke Akua, e kaumaha aku ai i na alana a me namohai no ka hewa.   
\q1
\v 2 E hiki no ia ia ke lokomaikai aku i ka poe naaupo, a me ka poe hele hewa; no ka mea, oia no kekahi i hoopuniia mai e ka nawaliwali;   
\q1
\v 3 Nolaila, e pono no e kaumaha aku oia i ka mohaihala nona iho, me ia hoi la no na kanaka.   
\q1
\v 4 Aole hoi e lawelawe kekahi i keia nani nona iho, aka, ua hookaawaleia mai ia e ke Akua, me Aarona hoi la.   
\q1
\v 5 Pela no hoi aole o Kristo i hoonani ia ia iho e lilo i kahuna nui; aka, o ka mea i olelo iho ia ia, O oe no ka'u Keiki, i keia la no. ua hoohanau aku au ia oe;   
\q1
\v 6 Oia ka i olelo hou pela ma kekahi wahi e ae, He kahuna mau loa no oe mamuli o ke ano o Melekisedeka.   
\q1
\v 7 Oia hoi, i na la o kona noho kino ana, ua kaumaha aku la i ka pule, a me ka nonoi ana, me ke kahea nui ana, a me na waimaka helelei, i ka mea e hiki ia ia ke hoopakele mai ia ia i ka make, a ua lohea mai oia no na mea ana i makau ai;   
\q1
\v 8 He Keiki no ia, ua ao no nae ia i ka hoolohe, ma na mea ana i ehaeha ai;   
\q1
\v 9 A i ka hoohemoleleia'na ona, na lilo oia i Ola e ola mau loa ai no ka poe a pau i hoolohe ia ia.   
\q1
\v 10 Ua kapaia iho la ia e ke Akua, he kahuna nui mamuli o ke ano o Melekisedeka.   
\b  
\q1
\v 11 He nui no pa mea a makou e olelo aku ai nona, aole hiki wawe ke hoomaopopo aku, no ka mea, he poe hookananuha oukou.   
\q1
\v 12 No ka mea, o ko oukou pono no e lilo i mau kumu i keia manawa, eia nae, ua kupono oukou i ke ao hou ia'ku i na hua mua o ka olelo a ko Akua; a o ka waiu ka mea e pono ai oukou, aole ka ai paa.   
\q1
\v 13 No ka mea, o na mea i ai wain, aole ia i akamai i ka olelo o ka pono; he keiki hou no ia.   
\q1
\v 14 Aka, o ka ai paa, na ka poe oo no ia, ka poe makaukau no ka mea e ike ai i ka pono a me ka hewa.   
\c 6  
\b  
\q1
\v 1 NOLAILA e waiho ana i na hua mua o na olelo a Kristo, e hele aku kakou imua a hiki i ke oo loa ana; aole e hoonoho hou ana i ke kumu no ka mini ana i na hana e make ai, a no ka mauaoio i ke Akua,   
\q1
\v 2 A no ke ao ana i na bapetizo ana, a no ke kau ana o na lima, a no ke alahouana o ka poe make, a me ka hoopai mau loa ana.   
\q1
\v 3 Oia ka kakou e hana'i, ina i pono ia i ke Akua.   
\q1
\v 4 No ka mea, aole e hiki i ka poe i hoonaauaoia mai, a i hoao hoi i ka haawina mai ka lani mai, a i hoolakoia hoi e ka Uhane Hemolele,   
\q1
\v 5 A i ai hoi i ka olelo maikai a ke Akua, a me ka mana o ke ao e hiki mai ana,   
\q1
\v 6 A ua haule iho no nae, aole e hiki ke hoala hou ia i ka mihi: ua kau hou aku lakou i ke Keiki a ke Akua ma ko kea no lakou iho, me ka hoomainoino aku ia ia ma ke akea.   
\q1
\v 7 O kahi lepo hoi i inu iho i ka ua e haule pinepine ana maluna iho ona, a i hoohua mai no hoi i na hua e pono ai ka poe nana e mahi, ua hoomaikaiia mai ia e ke Akua.   
\q1
\v 8 Aka, o kahi i hookupu mai i ke kakalaioa, a me ka nahelehele ooi, he pono ole ia, ua kokoke ia i ka hoahewaia mai; a o kona hope ka puhiia i ke ahi.   
\b  
\q1
\v 9 Aka, e ka poe aloha, ke manao nei makou i na mea maikai aku no oukou, i na mea e pili ana i ke ola, i ko makou olelo ana no hoi pela.   
\q1
\v 10 Aole he lokoino ke Akua i poina ai ka oukou hana ana, a me ke aloha a oukou i hoike aku ai i kona inoa, i ko oukou malama ana i ka poe hoano, a me oukou hoi e malama nei.   
\q1
\v 11 Ke makemake nei no hoi makou e hoike oukou i ua hooikaika mau ana la, i maopopo loa ai ka manaolana a hiki i ka hopena.   
\q1
\v 12 Aole e hoomolowa ana oukou, aka, e hoohalike ana me ka poe i loaa ka pono i hai mua ia mai ai, ma ka manaoio a me ke ahonui.   
\b  
\q1
\v 13 No ka mea, i ko ke Akua hai mua ana ia Aberahama, no ka hiki ole ia ia ke hoohiki ma o ka mea oi aku, ua hoohiki iho oia ma ona la iho,   
\q1
\v 14 I iho la, He oiaio hoi e hoomaikai loa aku ana au ia oe, a e hoonui loa ana au ia oe.   
\q1
\v 15 A kali aku la hoi ia me ke ahonui, a loaa mai la ia ia ka pono i hai mua ia mai.   
\q1
\v 16 O kanaka hoi ke hoohiki nei ma ka mea i oi aku; a o ka hoohiki ana e hooiaio ai, o ko lakou mea ia e oki ai ka hoopaapaa ana.   
\q1
\v 17 Pela hoi ke Akua i kona makemake ana e hoomaopopo loa i ka poe hooilina o kana pono i ka luli ole ana o kona manao, ua hooiaio mai oia me ka hoohiki ana;   
\q1
\v 18 Ma na mea luli ole elua, kahi i hiki ole ai i ke Akua he hoopunipuni, e hoohoihoi loa ia mai ai kakou ka poe i holo i ka puuhonua, e hoopaa i ka manaolana i waihoia mai ma ko kakou alo:   
\q1
\v 19 I ko kakou mea e hoopili aku ai me he heleuma la no ka uhane, he paa, a he panee ole, i ka mea hoi i komo loa ae iloko ae o ka pale;   
\q1
\v 20 I kahi i komo ai no kakou o Iesu o ko kakou mea hele mua, i hooliloia'e hoi i kahuna nui mau loa mamuli o ke ano o Melekisedeka.   
\c 7  
\b  
\q1
\v 1 A O ua Melekisedeka la hoi, ke alii o Salema, he kahuna no ke Akua kiekie loa, oia hoi ka i halawai pu me Aberahama i kona hoi ana mai mai ka luku ana'ku i na'lii, a hoomaikai iho la ia ia.   
\q1
\v 2 Ia ia hoi i haawi aku ai o Aberahama i ka hapaumi o na mea a pau: ma ka unuhi olelo ana, o kona inoa mua ke Alii o ka pono, alaila ke Alii o Salema ia, o ke ano oia, ke Alii e maluhia ai.   
\q1
\v 3 Aole ona makuakane, aohe makuwahine, aole kuauhau, aohe kumu o kona mau la, aole oki kona ola ana; aka, ua hoohalikeia me ke Keiki a ke Akua, e noho kahuua mau ana.   
\b  
\q1
\v 4 Ano la hoi, e hoomanao i ke ano kiekie o ua kanaka la, ia ia i haawi aku ai o Aberahama ka makualii i ka hapaumi o ka waiwai pio.   
\q1
\v 5 A o na mamo a Levi, ka poe i lawe i ka oihana a ke kahuna, ua kauohaia mai lakou ma ke kanawai e lawe i ka hapaumi o ka waiwai o kanaka, o ko lakou poe hoahanau, a ua hele mai no nae lakou mai loko mai o ko Aberahama puhaka:   
\q1
\v 6 Aka, o ka mea i kuauhau ole ia, mai laila mai, oia ka i lawe i ka hapaumi o ko Aberahama waiwai, a ua hoomaikai aku hoi i ka mea nona na olelo mua.   
\q1
\v 7 A he mea hoopaapaa ole ia keia, ua hoomaikaiia'ku ka mea i emi iho e ka mea i oi aku.   
\q1
\v 8 Maanei hoi, ua loaa ka hapaumi o ka waiwai i kanaka e make ana; aka, malaila i ka mea i oleloia mai ai, e ola ana ia.   
\q1
\v 9 Oia hoi, ina e hiki ia'u ke olelo penei, o Levi hoi, o ka mea i loaa ia ia ka hapaumi o ka waiwai, oia kekahi i haawi aku i ka hapaumi o ka waiwai iloko o Aberahama.   
\q1
\v 10 No ka mea, maloko no oia o ka puhaka o kona kupuna i ka wa i halawai ai o Melekisedeka me ia.   
\b  
\q1
\v 11 A, ina i loaa ka mea e pono ai ma ka oihana kahuna a Levi, (ua haawi pu ia mai ke kanawai i kanaka me ia,) heaha la anei hoi ko laila hemahema e ku hou ai kekahi kahuna e mamuli o ke ano o Melekisedeka, aole hoi i kapaia mamuli o ke ano o Aarona?   
\q1
\v 12 Aka, i kahuliia ka oihana kahuna, he pono no hoi e kahuliia ke kanawai.   
\q1
\v 13 No ka mea, o ka mea nona keia mau mea i oleloia ai, no ka ohana e no ia, aole kekahi o lakou i malama ma ke kuahu.   
\q1
\v 14 Ua akaka no ka puka ana o ka Haku, mai loko mai o Iuda, ka ohana i olelo ole ia'i no ka oihana kahuna e Mose.   
\q1
\v 15 A ua akaka loa ae kela mea, i ke kupu ana o kekahi kahuna e, e like me Melekisedeka,   
\q1
\v 16 I hooliloia pela, aole make kanawai o ko ke kino, aka, ma ka mana o ke ola e mau loa ana.   
\q1
\v 17 Ua hooiaio mai no hoi ia, He kahuna mau loa oe mamuli o ke ano o Melekisedeka.   
\q1
\v 18 Ua waikoia'o no kela kanawai mua, no kona nawaliwali, a me kona pono ole.   
\q1
\v 19 Aole ma ke kanawai, i pono loa ai kekahi mea, aka, ma ka hookomo ana i ka manaolana maikai ae, ka mea e kookokoke aka ai kakou i ke Akua.   
\q1
\v 20 A no ka mea hoi, aole me ka hoohiki ole ana,   
\q1
\v 21 (No ka mea, ua hooliloia'e kela poe i kahuna, me ka hoohiki ole, aka, oia nei me ka hoohiki ana e ka mea nana i olelo ia ia, Ua hoohiki ka Haku, aole hoi ia e lole hou ae, He kahuna mau loa oe mamuli o ke ano o Melekisedeka;)   
\q1
\v 22 Ma ia mea hoi i lilo ai o Iesu i panai no ka berita maikai ae.   
\q1
\v 23 A, o kela poe kahuna he lehulehu lakou, no ka mea, aole i haawiia mai e mau lakou, no ka make;   
\q1
\v 24 Aka, oia nei, no kona mau loa ana, he oihana kahuna lilo ole kana.   
\q1
\v 25 No ia mea, e hiki mau ai ia ia ke hoola i ka poe i hele mai i ke Akua ma ona la, no kona ola mau loa ana e uwao ana no lakou.   
\b  
\q1
\v 26 Oia ke ano o ke kahuna e pono ai kakou, ka mea hemolele, hewa ole, maemae wale, kaawale hoi i na lawehala, a i hookiekieia'e hoi maluna o ua lani;   
\q1
\v 27 Aole hoi i ku ia ia ke kaumaha ana i ka mohai i kela la i keia la, e like me ua mau kahuna nui la, no ko lakou mau hewa ponoi mamua, alaila no ko na kanaka hewa; no ka mea, hookahi wale no kana hana ana ia mea, i kona wa i kaumaha ai ia ia iho.   
\q1
\v 28 Na ke kanawai hoi i hoolilo i kanakanawaliwali i kahuna nui; aka, na ka olelo o ka hoohiki ana, ka mea mahope mai o ke kanawai, i hoolilo i ke Keiki, ka mea i hoohemolele mau loa ia'ku.   
\c 8  
\b  
\q1
\v 1 A O na mea a makou i olelo ae nei, eia ka nui; pela ke ano o ko kakou kahuna nui, ka mea i hoonohoia ma ka lima akau o ka nohoalii o ka Moi ma ka lani;   
\q1
\v 2 He lawehaua no kahi hoano, no ka halelewa oiaio, na ka Haku i kukulu, aole na ke kanaka.   
\q1
\v 3 No ka mea, ua hookaawaleia na kahuna nui e kaumaha aku ai i na alana a me na mohai: nolaila hoi e pono e loaa ia ia nei kekahi meae kaumaha aku ai.   
\q1
\v 4 Aka, ina ma ka honua ia, ina aole he kahuna ia; no ka mea, eia no ka poe kahuna e kaumaha ana i na alana mamuli o ke kanawai,   
\q1
\v 5 Ka poe i hana ma ke kumu hoohalike, a ma ke aka o ko ka lani, no ka mea, o Mose i ke kokoke ana o kona kukulu ana i ka halelewa, ua aoia mai ia e ke Akua, peneia; E nana oe, wahi ana, e hana oe i na mea a pau mamuli o ke kumuhoohalike i hoikeia ia oe ma ka mauna.   
\q1
\v 6 Aka, ano, ua loaa ia ia ka oihana maikai ae, e like me ka oi ana aku o ka maikai o ka berita ana i uwao ai, ka mea i hoopaaia ma na olelo hoopomaikai maikai ae.   
\q1
\v 7 A ina i kina ole kela berita mua, ina aole i imi hou ia kahi kaawale no ka lua:   
\q1
\v 8 Aka, i ka loaa ana o ke kina, ua olelo mai oia ia lakou, Eia hoi, wahi a Iehova, e hiki mai ana no na la e hana hou aku ai au i berita hou me ka ohana Iseraela, a me ka ohana Iuda;   
\q1
\v 9 Aole hoi e like me ka berita a'u i hana aku ai me ko lakou mau makua, i ka la i lalau aku ai au i ko lakou lima e alakai mai ia lakou mai ka aina o Aigupita mai; no ka mea, aole lakou i noho paa ma ko'u berita, a ua haalele au ia lakou, wahi a Iehova.   
\q1
\v 10 Aka, eia ka berita a'u e hana aku ai me ka ohana Iseraela, mahope iho o ua mau la la, wahi a Iehova; E pai au i ko'u mau kanawai ma ko lakou manao, a e kakau iho ia mau mea ma ko lakou naau; a e lilo au i Akua no lakou, a e lilo mai lakou i poe kanaka no'u.   
\q1
\v 11 Aole lakou e ao aku, kela kanaka i kona hoanoho, a keia kanaka i kona hoahanau, me ka olelo ana aku, E ike i ka Haku; no ka mea, e pau auanei lakou i ka ike ia'u mai ka mea liilii a hiki i ka mea nui o lakou.   
\q1
\v 12 No ka mea, e ahonui aku no au i ko lakou mau hewa, aole au e hoomanao hou aku i ko lakou mau kina a me ko lakou mau hala.   
\q1
\v 13 I kana olelo ana, He berita hou, ua hoolilo oia i ka mea mua i lualua; a o ka mea lualua, e elemakule ana hoi, ua kokoke no ia e nalo aku.   
\c 9  
\b  
\q1
\v 1 HE mau oihana no hoi ka ka berita mua, no ka hoomana ana, a me kahi hoano ma ka honua.   
\q1
\v 2 No ka mea, ua hanaia no he halelewa; o ka mua kahi i waihoia'i ka ipukukui, a me ka papa, a me ka berena hoike; ua kapaia ia o kahi hoano.   
\q1
\v 3 A mahope o ka palelua, ka halelewa i kapaia ka hoano loa.   
\q1
\v 4 Malaila ke kapuahi gula, a me ka pahuberita i uhiia i ke gula a puni, kahi i waihoia'i ka ipu gula o ka mane, a me ko Aarona kookoo, ka mea i opuu ae, a me na papa kanawai;   
\q1
\v 5 A maluna iho ona na kerubima nani e hoomalumalu ana i ka noho aloha; aole hiki ia makou ke olelo maopopo loa i keia mau mea, ano.   
\q1
\v 6 A hoomakaukauia pela ua mau mea la, ua komo mau na kahuna i ka halelewa mua e hooko ana i na oihana.   
\q1
\v 7 Aka, iloko o ka lua i komo ai ke kahuna nui wale no, pakahi wale no ke komo ana i ka makahiki, aole me ke koko ole, ka mea ana i kaumaha aku ai nona iho, a no na hewa hoi o na kanaka.   
\q1
\v 8 Ma ia mea i hoakaka mai ai ka Uhane Hemolele, aole i weheia kahi e komo ai i ka hoano loa, i ka wa i ku ai ka halelewa mua;   
\q1
\v 9 He aka no ia a hiki i keia manawa, kahi i kaumahaia aku ai na alana a me na mohai, na mea i hiki ole ke hoomaopopo loa i ka pono ma ka naau o ka mea nana ia oihana;   
\q1
\v 10 Na oihana ma ke kino, ma ka mea ai, a me ka mea inu, a me kela holoi ana, a me keia holoi ana, i kauohaia mai a hiki i ka manawa e hooponopono hou ia ai.   
\b  
\q1
\v 11 Aka, i ka hiki ana mai o Kristo, o ke kahuna nui no ka pono e hiki mai ana, ma ka halelewa nui ae, hemolele loa, aole i hanaia e na lima, aole ia no keia ao.   
\q1
\v 12 Hookahi wale no kona komo ana iloko o kahi hoano, aole me ke koko o na kao a me na bipikane, aka, me kona koko ponoi no, e loaa ana ka mea e ola mau ai.   
\q1
\v 13 A ina i hoohuikala ke koko o na bipikane, a me na kao, a me ka lehu o ka bipiwahine, e pipi ana i ka mea haumia, i maemae ai ke kino;   
\q1
\v 14 E hiki loa aku i ke koko o Kristo, o ka mea i kaumaha aku ia ia iho i ke Akua ma ka Uhane mau loa me ke kina ole, ke hoohuikala i ko oukou naau i na hana e make ai, e malama aku ai i ke Akua ola.   
\q1
\v 15 No ia mea, ua lilo oia i uwao no ka berita hou, a i ka lilo ana o kona make ana i uku hoola no na hewa i hanaia ma ka berita mua, e hiki ai i ka poe i kaheaia ke loaa ka hooilina mau i hai mua ia mai.   
\q1
\v 16 A ina he kauoha hooilina, e manaoia ana ua make ka mea nana ke kauoha i paa'i.   
\q1
\v 17 No ka mea, o ke kauoha, ua paa loa ia mahope wale no o ka make ana o kanaka, aole ia i paa i ka wa e ola ana ka mea nana ke kauoha.   
\q1
\v 18 Nolaila, aole i hoopaaia ka berita mua me ke koko ole.   
\q1
\v 19 No ka mea, a pau na kauoha ma ke kanawai i ka heluheluiae Mose, i ka poe kanaka a pau, lawe iho la ia i ke koko o na bipikane, a me na kao, a me ka wai, a me ka huluhulu ula, a me ka husopa, a kopipi iho la i ka buke a me ka poe kanaka a pau,   
\q1
\v 20 I iho la, Eia ke koko o ka berita a ke Akua i kauoha mai ai ia oukou.   
\q1
\v 21 Pela hoi i kopipi aku ai me ke koko i ka halelewa, a me na ipu a pau o ia oihana.   
\q1
\v 22 Aneane pau na mea ma ke kanawai i ka hoomaemaeia i ke koko; aohe kala ana ke hookahe ole ia ke koko.   
\b  
\q1
\v 23 Nolaila, ua kupono e hoohuikalaia na kumu hoohalike i ko ka lani, ma ia mau mea; aka, o ko ka lani mau mea ma na mohai maikai aku.   
\q1
\v 24 No ka mea, aole o Kristo i komo iloko o ka halelewa i hanaia e na lima, he aka wale no no ka mea oiaio; aka, iloko o ka lani ponoi i hoike mau ia ia iho ma ke alo o ke Akua no kakou.   
\q1
\v 25 Aole no hoi no ke kaumaha pinepine ana ia ia iho, e like me ka ke kahuna nui komo ana i kela makahiki a i keia makahiki iloko o kahi hoano me ke koko, aole o kona iho;   
\q1
\v 26 Ina pela, ina ua make pinepine oia mai ka hookumu ana mai o ke ao nei; aka, ano, ma keia hope o ke ao, ua hoike hookahi mai oia ia ia iho no ka hoomaemae aua i ka hewa ma ka mohai ana ia ia iho.   
\q1
\v 27 A ua hoomaopopoia ka make hookahi ana o na kanaka, a ma ia hope aku ka hoopai ana:   
\q1
\v 28 Pela hoi o Kristo, a pau kona hoolilo hookahi ana ia ia iho i mohai e halihali aku i ka hewa o ka lehulehu, e ike hou ia oia me ka mohai ole, i ka lua o kona hiki ana mai, e ola'i ka poe e kiai ana ia ia.   
\c 10  
\b  
\q1
\v 1 A O ke kanawai ia ia ke aka no na mea maikai e hiki mai ana, aole ke kino maoli a ua mau mea la, aole loa e hiki ia ia me na mohai i kaumahaia'ku i kela makahiki a i keia makahiki ke hoohemolele i ka poe i hookoke ilaila.   
\q1
\v 2 No ka mea, ina i hiki ia ia, aole auei i oki ua mau mohai la? no ka mea, o ka poe hoomana, i hoohuikala hookahi ia, aole lakou i ike hou i ko lakou hewa iho.   
\q1
\v 3 Aka, ma ua mau mohai la i hoomanaoia'i ka hewa i kela makahiki a i keia makahiki.   
\q1
\v 4 A he oiaio, he mea hiki ole i ke koko o na bipikane a me na kao ke kala aku i ka hewa.   
\q1
\v 5 Nolaila, i kona hiki ana mai i ke ao nei, i aku la ia, O ka mohai a me ka alana, o kau ia i makemake ole ai, aka, he kino kau i hoomakaukau ai no'u.   
\q1
\v 6 Aole hoi oe i oluolu i na mohai kuni, a me na mohai no ka hala.   
\q1
\v 7 Alaila, i iho la au, Eia hoi, ua hele mai nei au, (ua palapalaia no'u ma ka buke palapala,) e hana aku i kou makemake, e ke Akua.   
\q1
\v 8 I kana olelo mua ana, O na mohai, a me na alana, o na mohaikuni, a me na mohaihala, o kau ia i makemake ole ai, a i oluolu ole ai; o na mea i kaumahaia aku ai mamuli o ke kanawai;   
\q1
\v 9 Alaila, olelo hou ae la, Eia hoi, ua hele mai nei au e hana aku i kou makemake, e ke Akua. Ua hookae oia i ka mea mua, e hookupaa ai ia i ka lua.   
\q1
\v 10 Ma ia makemake hoi, ua loaa ia kakou ka huikala ana, ma ka mohai hookahi ana i ke kino o Iesu Kristo.   
\q1
\v 11 A o na kahuna ua ku lakou e hana ana i ka oihana i kela la i keia la, e kaumaha pinepine ana i ua mau mohai la, i na mea hiki ole ke kala i ka hewa;   
\q1
\v 12 Aka, o keia hoi, mahope iho o kona kaumaha ana i ka mohai hookahi no ka hewa, noho iho la ia a mau loa, ma ka lima akau o ke Akua;   
\q1
\v 13 E kali ana, a hooliloia mai kona poe enemi i paepae wawae nona.   
\q1
\v 14 Ma ka mohai hookahi hoi, i hana'i oia i ka mea e pono mau ai ka poe nona ka huikala.   
\q1
\v 15 A ua hoike mai ka Uhane Hemolele i keia mea ia kakou; no ka mea, ua olelo ia,   
\q1
\v 16 Eia ka berita a'u e hana aku ai me lakou, mahope iho o ua mau la la, wahi a ka Haku; E pai iho au i ko'u mau kanawai ma ko lakou naau, a e kakau iho hoi ia mau mea ma ko lakou manao:   
\q1
\v 17 Aole hoi au e hoomanao hou i ko lakou mau hewa a me ko lakou mau hala.   
\q1
\v 18 A ma kahi i pau ai ia mau mea i ke kalaia, aohe mohai hou aku no ka hewa.   
\b  
\q1
\v 19 A i ka loaa ana ia kakou, e na hoahanau, ke komo ana iloko o kahi hoano ma ke koko o Iesu,   
\q1
\v 20 Ma ka aoao hou e ola'i, ana i hoomakaukau ai mawaena o ka paku, oia kona kino;   
\q1
\v 21 A he Kahuna nui hoi maluna o ka hale o ke Akua;   
\q1
\v 22 E hookokoke kakou me ka maopopo loa o ka manaoio, a me ka naau oiaio, me ka huikalaia o ko kakou naau kaumaha i ka hewa, a me ka holoiia o ko kakou kino me ka wai maemae;   
\q1
\v 23 E hoopaa kakou i ka manaolana a kakou i hai aku ai me ka luli ole; no ka mea, he ku paa io ko ka mea nana i hai mua mai ka pono.   
\q1
\v 24 A e nana pono hoi kakou i kekahi i kekahi, e hooikaika ai i ke aloha a me na hana maikai.   
\q1
\v 25 Aole hoi e haalele ana i ko kakou hoakoakoa ana e like me ka hana ana a kekahi poe; aka, e hooikaika pu ana, me ka ikaika nui ae, i ko oukou ike ana aku e kokoke mai ana ua la la.   
\b  
\q1
\v 26 A ina e hana hewa kakou me ka ae o ka naau, mahope iho o ka loaa ana mai ia kakou ka ike ana i ka olelo oiaio, aohe mohai hou no na hala;   
\q1
\v 27 Aka, o ke kali weliweli ana i ka hoopaiia mai, a me ka huhu wela e pau ai ka poe enemi.   
\q1
\v 28 O ka mea i pale i ke kanawai o Mose, ua make ia me ke aloha ole ia, ma na mea hoike elua, ekolu paha:   
\q1
\v 29 Heaha la i ko oukou manao ka make eha nui aku e manaoia ana he pono, no ka mea nana i hehi malalo iho o ka wawae i ke Keiki a ke Akua, me ka manao i ke koko o ka berita ana i hoolaaia ai he mea haumia, a me ka hoowahawaha aku i ka Uhane lokomaikai?   
\q1
\v 30 Ua ike no hoi kakou i ka mea nana i olelo iho, No'u no ka hoopai ana, na'u no ia e uku aku, wahi a ka Haku; eia hou hoi, Na ka Haku no e hoopai i kona poe kanaka.   
\q1
\v 31 He mea weliweli ka haule ana iloko o na lima o ke Akua ola.   
\b  
\q1
\v 32 E hoomanao hoi oukou i na la mamua, i ka manawa i hoomanawanui ai oukou i ka paio nui ana, me ka ehaeha, mahope iho o ko oukou naauao ana;   
\q1
\v 33 No ko oukou lilo ana i mea nanaia mai ai, ma ka hoino ana, a me ka ehaeha ana kekahi; a, o kekahi, no ka oukou lilo ana i mau hoaaloha no ka poe i koloheia pela.   
\q1
\v 34 A ua aloha io hoi oukou i na mea i hoopeaia, a ua ae aku me ka oluolu, i ka hao ana aku o ko oukou waiwai, e ike ana no, aia i ka lani ka waiwai maikai aku no oukou, ka mea e oia mau ana.   
\q1
\v 35 Nolaila, mai kiola aku oukou i ko oukou paulele ana, ka mea e uku nui ia mai ana.   
\q1
\v 36 O ke ahonui ko oukou mea e pono ai, i loaa mai ai ia oukou ka pono i hai mua ia mai, mahope iho o ka oukou hana ana i ka makemake o ke Akua.   
\q1
\v 37 A liuliu iki aku, o ka mea e hiki mai ana e hiki mai no ia, aole e hookaulua aku.   
\q1
\v 38 A o ka mea i pono, e ola no ia ma ka manaoio; aka, ina e hoi ihope kekahi, aole e oluolu ko'u uhane ia ia.   
\q1
\v 39 Aole hoi makou no ka poe hoi ihope e make ai; aka, no ka poe manaoio e ola'i ka uhane.   
\c 11  
\b  
\q1
\v 1 O KA manaoio, o ka hilinai ana no ia ma na mea i manaolanaia'i, a o ka hoomaopopo ana hoi o na mea i ike maka ole ia.   
\q1
\v 2 No ia hoi, i hoaponoia mai ai ka poe kahiko.   
\q1
\v 3 Ma ka manaoio na ike kakou ua hanaia ka lani a me ka honua e ka olelo a ke Akua, o na mea i nanaia, aole no loko mai o na mea i ikeia.   
\q1
\v 4 Ma ka manaoio i kaumaha aku ai o Abela i ke Akua i ka mohai maikai aku i ko Kaina, malaila hoi i hoaponoia'i oia he pono, oia ka ke Akua hoike ana mai no kona alana; malaila hoi ke olelo nei oia ka mea i make.   
\q1
\v 5 No ka manaoio i lawe ola ia'ku o Enoka, me ka ike ole i ka make; aole ia i ike hou ia, no ka mea, ua lawe ola aku ke Akua ia ia. A ua hoaponoia oia no kona hooluolu ana i ke Akua mamua aku o kona laweia'ku.   
\q1
\v 6 Aka, he mea hiki ole ke hooluolu i ke Akua me ka manaoio ole; no ka mea, o ka mea e hele ana i ke Akua, e pono no e manaoio oia, he mea io no ia, a, he mea hoi e uku mai ana i ka poe i imi ikaika ia ia.   
\q1
\v 7 Ma ka manaoio o Noa i aoia'i e ke Akua no na mea i ike maka ole ia, ua hoomakaukau oia me ka makau, i halelana e ola'i kona hale; ma ia mea hoi ia i hoahowa aku ai i ko ke ao nei, a ua loaa ia ia ka hoapono ana no ka manaoio.   
\q1
\v 8 Ma ka manaoio hoi i hoolohe ai o Aberahama, i ka wa i heaia mai ai e hele aku i kahi e loaa mai ai ia ia ka noho ana; a hele aku la ia me ka ike ole i kona wahi i hele ai.   
\q1
\v 9 Ma ka manaoio i noho malihini ai oia i ka aina i olelo mua ia'i, ka aina o ka poe e, e noho ana ia iloko o na halelewa, me Isaaka a me Iakoba, na hooilina pu me ia no ka mea hookahi i hai mua ia mai ai:   
\q1
\v 10 No ka mea, ua imi aku ia i ke kulanakauhale i hookumuia, a o kona mea nana i hana, a i kukulu hoi, o ke Akua ia.   
\q1
\v 11 Ma ka manaoio i loaa'i ia Sara ka ikaika e hapai keiki ai, a hanau mai, mahope iho o ka manawa maoli o kona ola ana, no kona manao ana i ka oiaio o ka mea nana i hai mua mai.   
\q1
\v 12 Nolaila i laha mai ai mai kela mea hookahi, a o ua mea la me he mea make la, ka poe mamo e like me na hoku o ka lani ka lehulehu, a me ke one ma kahakai aole pau i ka heluia.   
\b  
\q1
\v 13 A make aku la kela poe a pau, iloko o ka manaoio, aole hoi i loaa ia lakou na mea i oleloia mai, aka, i ko lakou ike ana ia mau mea i kahi loihi, ua manaoio a paulele ilaila, a ua hai aku ia lakou iho, he poe kanaka e, he poe malihini ma ka honua.   
\q1
\v 14 A o ka poe i hai aku pela, ua hoike maopopo lakou i ko lakou imi ana i wahi e noho ai.   
\q1
\v 15 No ka mea, ina i manao lakou i kela aina a lakou i haalele ai, ua hiki no ia lakou ke hoi aku ilaila.   
\q1
\v 16 Aka, na makemake lakou i aina maikai aku, oia o ko ka lani. No ia mea, aole ke Akua i hilahila ia lakou ke kapaia oia he Akua no lakou; no ka mea, ua hoomakaukau oia i kulanakauhale no lakou.   
\b  
\q1
\v 17 Ma ka manaoio i kaumaha aku ai o Aberahama ia Isaaka i kona wa i hoaoia mai ai; a o ka mea nona ka pono i hai mua ia mai, ua mohai aku la oia i kana keiki hookahi;   
\q1
\v 18 Ia ia hoi ka olelo ana mai, E kapaia'ku kau mau mamo. mamuli o Isaaka.   
\q1
\v 19 Ua manao hoi ia, e hiki i ke Akua ke hoala mai ia ia mai ka make mai; mai laila mai hoi, i loaa ai oia ia ia ma ke aka.   
\q1
\v 20 Ma ka manaoio i hoomaikai aku ai o Isaaka ia Iakoba a me Esau no na mea e hiki mai ana.   
\q1
\v 21 Ma ka manaoio i hoomaikai aku ai o Iakoba i na keiki elua a Iosepa i kona wa e kokoke i ka make; a kulou iho la ia maluna o ke poo o kona kookoo.   
\q1
\v 22 Ma ka manaoio, i ka pau ana o kona ea, i olelo ai o Iosepa i ka hele ana'ku o na mamo a Iseraela; a ua kauoha aku la no kona mau iwi.   
\q1
\v 23 Ma ka manaoio i hunaia'i o Mose i na malama ekolu e kona mau makua mahope iho o kona hanau ana, no ko laua ike ana he keiki maikai ia; aole hoi laua i makau i ke kauoha a ke alii.   
\q1
\v 24 Ma ka manaoio i ae ole aku ai o Mose i kona wa oo e kapaia mai he keiki na ke kaikamahine a Parao;   
\q1
\v 25 E koho ana ma ka pilikia pu me ko ke Akua poe kanaka, aole ma ka lealea pau koke o ka hewa;   
\q1
\v 26 E manao ana hoi i ka hoino ana a Kristo i hoinoia'i he waiwai ia e oi aku ana mamua o ko Aigupita waiwai; no ka mea, ua manao aku oia i ka hoonkuia mai.   
\q1
\v 27 Ma ka manaoio no oia i haalele ai ia Aigupita, me ka makau ole aku i ka huhu o ke alii; no ka mea, ua ku paa oia me he mea la e ike maoli ana i ka mea i ike maka ole ia.   
\q1
\v 28 Ma ka manaoio hoi oia i malama ai i ka moliaola, a me ka pipi ana o ke koko, i ole ai e hoopa mai ia lakou ka mea nana i luku mai i na makahiapo.   
\q1
\v 29 Ma ka manaoio i hele ai lakou mawaena o ke Kaiula me he hele ana la ma ka aina maloo, ka mea a ko Aigupita i hoao ai a make iho la i ke kai.   
\q1
\v 30 No ka manaoio i hiolo ai na pa o Ieriko, i ka pau o ka hoopuni ana i na la ehiku.   
\q1
\v 31 No ka manaoio i make pu ole ai o Rahaba ka wahine hookamakama me ka poe hoomaloka, mahope iho o kona hookipa ana i na kiu me ke aloha.   
\b  
\q1
\v 32 A heaha hoi ka'u e olelo hou aku ai? No ka mea, e pau e no kuu manawa ke hai aku i ka Gideona a me Baraka, a me Samesona a me Iepeta, a me Davida hoi, a me Samuela, a me ka poe kaula;   
\q1
\v 33 Ka poe nana ma ka manaoio i hoopio ai i na aupuni, i hoopai ai hoi ma ka pono, i loaa ai hoi he mau pono i hai mua ia mai, i papani ai hoi i na waha o na liona,   
\q1
\v 34 I hoopio ai hoi i ka wela o ke ahi, i pakele ai hoi i ka maka o ka pahikaua, i hooikaikaia'i hoi i ka nawaliwali ana, a i lilo ai hoi i poe ikaika i ke kana, i auhee ai hoi ka poe kaua o na aina e.   
\q1
\v 35 Ua loaa hou i na wahine ma ke alahouana, ko lakou poe make; ua hoehaehaia kekahi poe, aole nae i ae lakou i ka hookuu ana, i loaa mai ia lakou ke alahou maikai ae.   
\q1
\v 36 A ua hoaoia kekahi poe me ka hoomaewaewaia, a me ka hahau ana, a me ka hoopea ana, a me ka paa ana i ka halepaahao;   
\q1
\v 37 Ua hailukuia lakou; ua oloia a kaawale; ua hoowalewaleia; ua pepehi wale ia me ka pahikaua; ua kaahele lakou me na aahu ili hipa, a me na ili kao, me ka ilihune, a me ka popilikia, a me ke koloheia;   
\q1
\v 38 Aohe pono ko ke ao nei e like me ko lakou; ua auwana ma na waonahele, a ma na mauna, a ma na ana hoi, a me na lua o ka honua.   
\q1
\v 39 A o ua poe a pau, ka poe i hoaponoia no ko lakou manaoio, aole i loaa ia lakou ka pono i haiia mai;   
\q1
\v 40 Na ke Akua i hoomakaukau i ka pono nui no kakou, aole i loaa ia lakou ka hooko loa ana o ka mea e pono ai, ke ole kakou.   
\c 12  
\b  
\q1
\v 1 NO ka mea hoi, ua hoopuniia kakou e ia poe hoike he nui loa, e waiho aku kakou i na mea kaumaha a pau, a me ka hewa e hoopili wale mai ana ia kakou, e holo kakou me ke ahonui i ka haihai ana i hoomaopopoia mamua o kakou,   
\q1
\v 2 E nana aku ana hoi ia Iesu, i ka mea nana i hookumu, nana hoi e hoohemolele ko kakou manaoio; nana hoi i hoomanawanui i ke kea me ka manao ole i ka hilahila, no ka olioli i hoomaopopoia mamua ona, a noho iho hoi ma ka lima akau o ka nohoalii o ke Akua.   
\q1
\v 3 E hoomanao hoi oukou i ka mea i hoomanawanui i ke ku e ana mai o ka poe i hana hewa ia ia, o nawaliwali ko oukou manao a maule hoi oukou.   
\q1
\v 4 Aole oukou i pale aku me ka hookaheia mai o ke koko, i ko oukou paio ana aku i ka hewa.   
\q1
\v 5 Ua poina ia oukou ka olelo hooikaika ia oukou me he poe keiki la, E ka'u keiki, mai hoowahawaha oe i ka hahau ana mai a ka Haku, aole hoi e maule i kona hoeha ana mai ia oe:   
\q1
\v 6 No ka mea, o ka ka Haku mea i aloha mai ai, oia kana i hahau mai ai, a ua hoeha me ka hahau i na keiki a pau ana i aloha mai ai.   
\q1
\v 7 A ina i hahauia mai oukou, ua hana mai ke Akua ia oukou me he poe keiki la; no ka mea, auhea la ke keiki i hahau ole ia e ka makuakane?   
\q1
\v 8 A ina i hahau ole ia mai oukou, me na keiki a pau i hahauia'i, alaila he poe hanau pono ole oukou, aole he poe keiki hanau pono.   
\q1
\v 9 A o ko kakou mau makuakane, no ko kakou kino, ua hahau mai ia kakou, a ua hoomaikai aku kakou ia lakou; aole anei e oi aku ko kakou hoolohe ana i ka Makua o ko kakou mau uhane, i ola kakou?   
\q1
\v 10 Na lakou no kakou i hahau mai i ka wa pokole mamuli o ko lakou makemake no, aka, nana i hahau mai e pono ai kakou, i loaa pu mai ai ia kakou kona hemolele.   
\q1
\v 11 A o na hahau ana a pau, aole ia i manaoia i kona manawa, he mea olioli, he mea ehaeha no; aka, ma ia hope iho, ua hoohua mai ia i ka hua o ka pono e pomaikai ai no ka poe i hooponoponoia ilaila.   
\q1
\v 12 Nolaila, e hooikaika i na lima palupalu a me na kuli nawaliwali;   
\q1
\v 13 A e hoopololei i na alanui no ko oukou mau wawae, i ole ai e okupe ae ka mea oopa; o aho hoi e hoolaia ia.   
\b  
\q1
\v 14 E hahai ma ke kuikahi me na kanaka a pau, a ma ka hemolele hoi, aohe kanaka i nele ia mea e ike aku i ka Haku.   
\q1
\v 15 E malama hoi oukou o loaa ole mai i kekahi ka hoomaikaiia mai e ke Akua, o kupu mai hoi kekahi mole awaawa iwaena o oukou e hihia'i oukou, a e haumia ai hoi kekahi poe he nui no;   
\q1
\v 16 O lilo paha kekahi i moe kolohe, i haihaia paha e like me Esau, nana i hoolilo aku i ko ka hanau mua pomaikai ana, no ka mea ai hookahi.   
\q1
\v 17 No ka mea, ua ike oukou, i kona makemake ana mahope iho e loaa ia ia ka hoomaikaiia, ua hooleia oia; aole hoi i loaa ia ia kahi e lole hou mai ai, ua imi aku no nae oia ia mea me ka waimaka.   
\b  
\q1
\v 18 Eia hoi, aole oukou i hele mai i ka mauna e hiki ke hoopa kino ia aku, a me ke ahi e lapalapa ana, a me na ao eleele, a me ka pouli, a me ka ino,   
\q1
\v 19 Aole hoi i ke kani ana o ka pu, a me ka leo o na olelo, ka mea a ka poe lohe i papa ai aole make hoohui hou ia mai kekahi huaolelo:   
\q1
\v 20 (No ka mea, aole i hiki ia lakou ke hoomanawanui i ka papa ana mai, Ina e pili ka holoholona i ka mauna e hailukuia oia, a houhouia paha i ka ihe:   
\q1
\v 21 A no ka weliweli nui ke nana aku, i iho la o Mose, Ke weliweli nei au me ka haalulu:)   
\q1
\v 22 Aka, na hele mai no oukou i ka mauna Ziona, a i ke kulanakauhale o ke Akua ola, i ko ka lani Ierusalema, a i ke anaina hiki ole ke heluia o na anela;   
\q1
\v 23 A i ke anaina nui a me ka ekalesia o ka poe makahiapo, i kakauia ko lakou mau inoa ma ka lani, a i ke Akua, ka Lunakanawai o na mea a pau, a i na uhane o ka poe pono i hoohemoleleia,   
\q1
\v 24 A i ka uwao o ka berita hou, ia Iesu, a i ke koko no ka pipi ana, e olelo ana i na mea maikai oi aku mamua o ko Abela.   
\q1
\v 25 Malama oukou, mai haalele i ka mea nana i olelo mai; no ka mea, ina i pakele ole ka poe i haalele i ka mea nana i ao mai ia lakou ma ka honua, aole loa hoi kakou e pakele ke haalele kakou i ka mea i ao mai mai ka lani mai.   
\q1
\v 26 Ia manawa ua hoonauwewe mai kona leo i ka honua; aka, ua hai mai nei no ia, i ka i ana, E hoonauwewe hou aku ana au aole i ka honua wale no, aka, i ka lani kekahi.   
\q1
\v 27 A o ke ano o na Hou aku ana, o ka hemo ana ia o na mea hoonauweweia, me he mea i hanaia la, i mau hoi na mea e hoonauwewe ole ia.   
\q1
\v 28 Nolaila, i ka loaa ana ia kakou ke aupuni e hoonauwewe ole ia, e hoopaa kakou i ke aloha, ka mea e pono ai ko kakou malama ana i ke Akua, me ka mahalo, a me ka weliweli pono;   
\q1
\v 29 No ka mea, o ko kakou Akua, he ahi ia e hoopau ana.   
\c 13  
\b  
\q1
\v 1 E MAU aku hoi ke aloha hoahanau.   
\q1
\v 2 Mai hooki i ka hookipa; no ka mea, malaila no kekahi poe i hookipa ai i na anela me ka ike ole aku.   
\q1
\v 3 E hoomanao i ka poe pio me he mau hoapio pu la oukou; a i ka poe i hoinoia hoi me he mea la iloko o ke kino oukou.   
\q1
\v 4 E mahaloia ka mare no na mea a pau, a e hoopaumaele ole ia hoi kahi moe: no ka mea, e hoahewa mai ana no ke Akua i ka poe hooipoipo, a me ka poe moe kolohe.   
\q1
\v 5 E noho oukou me ka punikala ole, oluolu no i na mea i loaa ia oukou; no ka mea, ua olelo mai oia, Aole loa au e hoonele aku ia oe, aole hoi e haalele ia oe;   
\q1
\v 6 E hiki no ia kakou ke olelo wiwo ole aku, O ka Haku ko'u mea nana e kokua mai, aole au e makau i ka kanaka e hana mai ai ia'u.   
\b  
\q1
\v 7 E hoomanao i ko oukou mau alakai, na mea nana i hai mai i ka olelo a ke Akua ia oukou; e noonoo pono i ka hope o ka lakou hana ana, e hele hoi mamuli o ko lakou manaoio.   
\q1
\v 8 O Iesu Kristo, he oia mau no ia, i nehinei, a i keia la no, a i ka wa pau ole.   
\q1
\v 9 Mai hoohuliia oukou mao a mao e kela olelo a e keia olelo e; no ka mea, he mea pono ke hookupaaia ka naau ma ka pono io; aole ma na ai, na mea i pono ole ai ka poe i malama malaila.   
\q1
\v 10 He kuahu, ko kakou, aole e pono ke ai i ko laila, ka poe i malama ma ka halelewa.   
\q1
\v 11 A o na kino o na holoholona, ke haliia'e ko lakou koko e ke kahuna nui iloko o kahi hoano, i mohai no ka hewa, ua puhiia lakou i ke ahi mawaho o kahi e hoomoana'i.   
\q1
\v 12 Nolaila, o Iesu hoi, i lilo ia i kalahala no kanaka, ma kona koko iho, ua make ia mawaho o ka ipuka.   
\q1
\v 13 No ia mea, e hele aku kakou io na la mawaho o kahi e hoomoana'i, e auamo ana i kona hoinoia ana.   
\q1
\v 14 No ka mea, aole o kakou kulanakauhale e mau ana maanei, aka, ke imi nei kakou ia mea ma ia hope aku.   
\q1
\v 15 Ma ona la hoi e kaumaha mau aku ai kakou i ka mohai mahalo i ke Akua, oia ka hua o ko kakou mau lehelehe, e hoolea ana i kona mea.   
\q1
\v 16 Mai hoopoina hoi i ka hana lokomaikai aku, a me ka manawalea aku; no ka mea, o ka ke Akua mau mohai ia e oluolu nui ai.   
\q1
\v 17 Hoolohe i ka oukou mau kumu, a e noho mamuli o lakou; no ka mea, ua kiai lakou i ko oukou mau uhane, me he poe e hoike ana la, i hoike lakou me ka olioli, aole me ke kaumaha; no ka mea, he pono ole ia ia oukou.   
\b  
\q1
\v 18 E pule oukou no makou; no ka mea, ke manao nei makou, he naau hoopono ko makou, me ka makemake e hana pololei aku makou ma na mea a pau.   
\q1
\v 19 Ke noi ikaika aku nei au i keia mea, i hoihoi koke ia aku ai au ia oukou.   
\b  
\q1
\v 20 Na ke Akua hoopomaikai, na ka mea i hoala mai i ko kakou Haku ia Iesu mai ka make mai, i ka mea i lilo mai, ma ke koko o ka berita mau loa, i Kahu nui no ka poe hipa.   
\q1
\v 21 E hoomakaukau mai ia oukou no na hana maikai a pau e hana aku i kona makemake, e hana mai ana oia iloko o oukou i ka mea pono imua o kona maka, ma o Iesu Kristo la; nona ka hoonani mau loa ia'ku i ke ao pau ole. Amene.   
\b  
\q1
\v 22 Eia hoi, ke nonoi aku nei au ia oukou, e na hoahanau, o ae oluolu mai i keia olelo hooikaika; no ka mea, ua palapala pokole aku au ia oukou.   
\q1
\v 23 E ike hoi oukou, ua hookuuia'ku nei ka hoahanau o Timoteo; a i hoi koke mai ia, e ike pu maua ia oukou.   
\q1
\v 24 E aloha aku i ko oukou mau alakai, a me ka poe haipule a pau. Ke uwe aku nei ko Italia nei ia oukou.   
\b  
\q1
\v 25 No oukou a pau loa ke aloha. Amene.   