\id SNG Biblica® Open Lingala Contemporary Bible 2020 
\h Loyembo ya Salomo 
\toc1 Loyembo ya Salomo 
\toc2 Loyembo ya Salomo 
\toc3 Loy 
\mt1 Loyembo ya Salomo 
\c 1  
\p  
\v 1 Oyo nde nzembo oyo eleki kitoko kati na banzembo ya Salomo. 
\b  
\s1 Kosanzola bolingo 
\s2 Elenge mwasi 
\q1  
\v 2 Tika ete bibebu na yo epesa ngai beze, 
\q2 pamba te bolingo na yo eleki vino na elengi. 
\q1  
\v 3 Solo ya malasi na yo ezali kitoko, 
\q2 mobimba na yo ezali lokola solo ya malasi ya kitoko 
\q1 oyo epanzani ; 
\q2 yango wana bilenge basi balingaka yo ! 
\q1  
\v 4 Tokende na yo elongo, tokima mbangu ! 
\q2 Mokonzi akotisi ngai na bashambre na ye ! 
\q1 Tovanda elongo na esengo mpe tosepela na tina na yo, 
\q2 tosanzola bolingo na yo, oyo eleki vino ya kitoko na elengi. 
\q2 Solo, ezali na pamba te nde basi balulaka yo ! 
\b  
\q1  
\v 5 Oh bilenge basi ya Yelusalemi, 
\q2 nazali mwindo, kasi nazali kitoko ! 
\q1 Solo, nazali mwindo lokola bandako ya kapo ya Kedari, 
\q2 lokola barido ya kitoko na ndako ya kapo ya Salomo. 
\q1  
\v 6 Kokamwa ngai te mpo ete nazali mwindo, 
\q2 pamba te moyi nde eyindisi ngai. 
\q1 Bana mibali ya mama na ngai basilikelaki ngai, 
\q2 bakomisaki ngai mokengeli bilanga ya vino. 
\q1 Solo, bilanga na ngai moko ya vino, 
\q2 nazalaki kokoka lisusu te kokengela yango. 
\b  
\q1  
\v 7 Oh mobali oyo ngai nalingaka, 
\q2 yebisa ngai esika nini oleisaka bibwele na yo, 
\q2 esika nini opemisaka bampate na yo na midi ! 
\q1 Mpo na nini nazala lokola mwasi oyo azali koyengayenga 
\q2 sima na bibwele ya baninga na yo ? 
\s2 Babateli bibwele 
\q1  
\v 8 Oh mwasi oyo aleki basi nyonso na kitoko, 
\q2 soki oyebi yango te, landa kaka matambe ya bibwele, 
\q1 na banzela oyo yango elekeli, 
\q2 mpe leisa bana bantaba ya basi na yo pembeni ya bandako ya kapo ya babateli bibwele. 
\s2 Elenge mobali 
\q1  
\v 9 Oh bolingo na ngai, nazali komona yo 
\q2 lokola mpunda ya mwasi oyo ebendaka shar ya Faraon. 
\q1  
\v 10 Matama na yo ezalaka kitoko kati na biloko ya matoyi, 
\q2 mpe kingo na yo ebongaka na mayaka. 
\s2 Babateli bibwele 
\q1  
\v 11 Tokolukela yo biloko ya matoyi ya wolo 
\q2 oyo batia bambuma ya mike-mike ya palata. 
\s2 Elenge mwasi 
\q1  
\v 12 Tango mokonzi azalaki kolia na mesa na ye, 
\q2 malasi na ngai ya nare ezalaki kopanza 
\q2 solo na yango ya kitoko. 
\q1  
\v 13 Molingami na ngai azali mpo na ngai 
\q2 lokola liboke ya malasi ya mire, 
\q2 akolekisa butu na ye na kati-kati ya mabele na ngai. 
\q1  
\v 14 Molingami na ngai azali mpo na ngai 
\q2 lokola liboke ya bambuma ya ene oyo ewutaka 
\q2 na bilanga ya vino ya Eyini-Gedi. 
\s2 Elenge mobali 
\q1  
\v 15 Oh mwasi na ngai ya motema, ozali kitoko ! 
\q2 Solo, ozali penza kitoko makasi ! 
\q2 Miso na yo elala lokola ebenga. 
\s2 Elenge mwasi 
\q1  
\v 16 Mobali na ngai, tala ndenge nini ozali kitoko ! 
\q2 Ozali penza elengi. 
\q2 Mbeto na biso ezali nde matiti ya mobesu, 
\q1  
\v 17 makonzi ya ndako na biso esalemi na banzete ya sedele, 
\q2 mpe balate na yango, na banzete ya sipele. 
\c 2  
\s1 Mwasi 
\q1  
\v 1 Nazali lokola fololo oyo ebotaka na etando ya Saroni, 
\q2 fololo oyo babengaka lisi ya lubwaku. 
\s2 Elenge mobali 
\q1  
\v 2 Ndenge fololo oyo babengaka lisi ezalaka kati na banzube, 
\q2 ndenge wana mpe mwasi na ngai ya motema 
\q2 azalaka kati na bilenge basi. 
\s2 Elenge mwasi 
\q1  
\v 3 Ndenge nzete ya pome ezalaka kati na banzete ya zamba, 
\q2 ndenge wana mpe mobali na ngai azalaka 
\q2 kati na bilenge mibali. 
\q1 Nasepelaka kovanda na se ya elilingi na ye, 
\q2 mpe mbuma na ye ezalaka elengi na monoko na ngai. 
\q1  
\v 4 Amemaki ngai na esika oyo bamelaka masanga, 
\q2 mpe bendele na ye likolo na ngai ezali bolingo. 
\q1  
\v 5 Lendisa ngai na bagato oyo basali na bambuma ya vino, 
\q2 sunga ngai na bapome, 
\q2 pamba te nabeli maladi ya bolingo. 
\q1  
\v 6 Tika ete loboko na ye ya mwasi ezala na se ya moto na ngai, 
\q2 mpe loboko na ye ya mobali ekanga ngai nzoto ! 
\s2 Elenge mobali 
\q1  
\v 7 Bilenge basi ya Yelusalemi, nabondeli bino 
\q2 na kombo ya mboloko mpe ya mbuli ya bilanga : 
\q1 Bolamusa Bolingo na ngai te 
\q2 liboso ete ye moko akoma na posa ya kolamuka. 
\s2 Elenge mwasi 
\q1  
\v 8 Yoka mongongo ya Bolingo na ngai ! 
\q2 Tala ye wana ! Ye wana azali koya, 
\q1 azali kopumbwa na likolo ya bangomba, 
\q2 azali kodenda na likolo ya bangomba mike. 
\q1  
\v 9 Molingami na ngai azali lokola mboloko to mwana ya mbuli. 
\q2 Tala ye wana ! Atelemi na sima ya mir na biso, 
\q1 azali kotala na lininisa, 
\q2 azali kotala na mayele na kiyungulu ya lininisa. 
\q1  
\v 10 Molingami na ngai alobi mpe ayebisi ngai : 
\q2 « Mwasi na ngai ya motema, telema ; 
\q2 mwasi na ngai ya kitoko, yaka epai na ngai ! 
\q1  
\v 11 Pamba te, tala eleko ya malili esili koleka, 
\q2 bamvula esili mpe ekeyi. 
\q1  
\v 12 Bafololo ebimi na mboka, 
\q2 tango ya koyemba banzembo ekoki. 
\q1 Makelele ya banzembo ya bibenga ekomi lisusu 
\q2 koyokana na mokili. 
\q1  
\v 13 Nzete ya figi ebimisi bambuma na yango ya liboso, 
\q2 bafololo ya bilanga ya vino ekomi kopanza 
\q2 solo na yango ya kitoko. 
\q1 Mwasi na ngai ya motema, telema ; 
\q2 mwasi na ngai ya kitoko, yaka epai na ngai. 
\s2 Elenge mobali 
\q1  
\v 14 Ebenga na ngai oyo obombami kati na madusu ya mabanga, 
\q2 kati na madusu ya bangomba, 
\q1 monisa ngai ata elongi na yo 
\q2 mpe sala ete nayoka ata mongongo na yo, 
\q1 pamba te mongongo na yo ezalaka elengi 
\q2 mpe elongi na yo ezalaka kitoko mingi ! » 
\s2 Bandeko mibali 
\q1  
\v 15 Bokangela biso bambwa ya zamba mpe bana na yango 
\q2 oyo ezali kobebisa bilanga na biso ya vino, 
\q2 pamba te bilanga na biso ya vino ebimisi bafololo. 
\s2 Elenge mwasi 
\q1  
\v 16 Mobali na ngai ya bolingo azali ya ngai, 
\q2 mpe ngai nazali ya ye ; 
\q1 aleisaka bibwele na ye na bilanga 
\q2 oyo etondi na bafololo oyo babengaka lisi. 
\q1  
\v 17 Mobali na ngai ya bolingo, zonga ; 
\q2 awa moyi ebandi kobima mpe molili ekimi, 
\q1 zala lokola mboloko to mwana ya mbuli 
\q2 na bangomba ya Beteli. 
\c 3  
\s2 Elenge mwasi 
\q1  
\v 1 Butu mobimba, na mbeto na ngai, 
\q2 nazali koluka mobali oyo motema na ngai elingaka ; 
\q2 naluki ye, kasi namonaki ye te. 
\q1  
\v 2 Esengeli na ngai kolamuka sik’oyo 
\q2 mpe kobima libanda ya engumba, 
\q1 na balabala na yango mpe na bisika 
\q2 oyo bato nyonso bakutanaka ; 
\q1 nakoluka mobali oyo motema na ngai elingaka. 
\q2 Nalukaki ye, kasi namonaki ye te. 
\q1  
\v 3 Bakengeli bamonaki ngai 
\q2 tango bazalaki koleka-leka na balabala ya engumba. 
\q1 Natunaki bango : 
\q2 « Bomoneli ngai te mobali 
\q2 oyo motema na ngai elingaka ? » 
\q1  
\v 4 Tango kaka nalekaki bango, 
\q2 mbala moko, namonaki mobali 
\q1 oyo motema na ngai elingaka. 
\q2 Nakangaki ye mpe natikaki ye lisusu te kokende. 
\q1 Namemaki ye kino na ndako ya mama na ngai, 
\q2 na shambre ya mwasi oyo abotaki ngai. 
\s2 Elenge mobali 
\q1  
\v 5 Bilenge basi ya Yelusalemi, nabondeli bino 
\q2 na kombo ya mboloko mpe ya mbuli ya bilanga : 
\q1 Bolamusa Bolingo na ngai te 
\q2 liboso ete ye moko akoma na posa ya kolamuka. 
\s2 Elenge mwasi 
\q1  
\v 6 Nani oyo abimi na esobe lokola molinga oyo ezali komata, 
\q2 azali kobimisa solo ya malasi ya mire mpe ya ansa, 
\q1 oyo basali na biloko ya mike-mike ya solo kitoko 
\q2 ya moto ya mombongo ? 
\q1  
\v 7 Tala ! Ezali nde tsipoyi ya mokonzi Salomo ! 
\q2 Basoda na ye ya mpiko, bato ya lokumu ya Isalaele, 
\q2 tuku motoba nde bamemi yango. 
\q1  
\v 8 Bango nyonso balati mipanga ; 
\q2 bango nyonso bazali makasi na bitumba, 
\q2 baselingwa mpo na bitumba ya butu. 
\b  
\q1  
\v 9 Mokonzi Salomo asalisaki tsipoyi ; 
\q2 basalaki yango na mabaya ya mboka Libani. 
\q1  
\v 10 Basalaki bisimbelo na yango na palata, 
\q2 mokongo na yango, na wolo. 
\q1 Balatisaki evandelo na yango 
\q2 bilamba ya motuya ya langi ya motane makasi. 
\q1 Bongo, bilenge basi ya Yelusalemi babongisaki 
\q2 kati na yango na motema ya bolingo. 
\q1  
\v 11 Bino bilenge basi ya Siona, bobima ; 
\q2 botala ndenge nini mokonzi Salomo alati motole, 
\q1 motole oyo mama na ye alatisaki ye 
\q2 na mokolo ya libala na ye, 
\q2 na mokolo oyo motema na ye ezalaki na esengo. 
\c 4  
\s2 Elenge mobali 
\q1  
\v 1 Oh mwasi na ngai ya motema, 
\q2 ozali kitoko, ozali penza kitoko makasi ! 
\q1 Miso na yo, na se ya vwale, elala lokola ebenga ; 
\q2 suki na yo ezali lokola etonga ya bantaba ya basi 
\q2 oyo ekitaka na ngomba Galadi. 
\q1  
\v 2 Minu na yo ezali lokola etonga ya bameme 
\q2 oyo balongoli bapwale, 
\q2 bongo bawuti kosukola yango. 
\q1 Meme moko na moko ezali na lipasa na yango ; 
\q2 moko te ezangi mwana. 
\q1  
\v 3 Bibebu na yo ezali lokola kitendi ya motane, 
\q2 mpe elobeli na yo epesaka esengo ; 
\q1 matama na yo ezali lokola mbuma ya grenade, 
\q2 na se ya vwale. 
\q1  
\v 4 Kingo na yo ezali lokola ndako molayi ya Davidi, 
\q2 oyo batongi mpo na kobomba bibundeli ; 
\q1 banguba nkoto moko ediembisami kuna, 
\q2 banguba ya basoda ya mpiko. 
\q1  
\v 5 Mabele na yo nyonso mibale ezali 
\q2 lokola bana mapasa mibale ya mboloko, 
\q2 oyo ezali kolia kati na bafololo oyo babengaka lisi. 
\q1  
\v 6 Kino tongo ekotana mpe molili ekolimwa, 
\q2 nakokende na ngomba ya mire 
\q2 mpe na ngomba moke ya ansa. 
\q1  
\v 7 Mwasi na ngai ya motema, 
\q2 mobimba na yo ezali kitoko mingi ; 
\q2 ata elembo moko te emonani mabe kati na yo. 
\b  
\q1  
\v 8 Longwa na Libani mpe yaka elongo na ngai, 
\q2 mwasi na ngai ya motema ; 
\q1 longwa na Libani, yaka elongo na ngai. 
\q2 Tala wuta na basonge ya bangomba Amana, 
\q2 Seniri mpe Erimoni 
\q2 epai wapi ezali na ndako ya bankosi mpe ngomba ya bankoyi. 
\q1  
\v 9 Obetisi ngai motema makasi, 
\q2 Oh ndeko na ngai ya mwasi, mwasi na ngai ya motema ; 
\q1 obetisi ngai motema na komona etaleli ya miso na yo, 
\q2 mpe na komona moko ya sheneti ya kingo na yo. 
\q1  
\v 10 Solo, bolingo na yo eleki elengi, 
\q2 ndeko na ngai ya mwasi, mwasi na ngai ya motema ! 
\q1 Solo, bolingo na yo eleki vino na kitoko ; 
\q2 solo ya mafuta na yo eleki malasi nyonso na kitoko. 
\q1  
\v 11 Bibebu na yo ezali kobimisa mafuta ya elengi, 
\q2 mwasi na ngai ya motema ; 
\q1 se ya lolemo na yo etondi na mafuta ya nzoyi mpe na miliki, 
\q2 mpe solo ya bilamba na yo ezali lokola solo ya Libani. 
\q1  
\v 12 Ozali elanga ekangama, 
\q2 ndeko na ngai ya mwasi, mwasi na ngai ya motema ; 
\q1 ozali etima oyo ezipami 
\q2 mpe liziba oyo ekangami. 
\q1  
\v 13 Ozali kopesa pio lokola elanga ya banzete ya grenade, 
\q2 oyo ezali na bambuma kitoko, 
\q2 elongo na banzete ya solo kitoko : ene mpe nare, 
\q1  
\v 14 nare mpe safarani, kaneli ya solo kitoko, sinamoni, 
\q2 elongo na lolenge nyonso ya banzete 
\q1 oyo epesaka malasi ya ansa, 
\q2 ya aloe mpe ya mire, mpe malasi nyonso oyo eleki kitoko. 
\q1  
\v 15 Ozali liziba kati na elanga, 
\q2 etima oyo etiolaka wuta na Libani. 
\s2 Elenge mwasi 
\q1  
\v 16 Oh mopepe ya nor, lamuka ; 
\q2 oh mopepe ya sude, yaka ! 
\q1 Pepa kati na elanga na ngai, 
\q2 mpe tika ete solo kitoko na yango epanzana kino mosika ! 
\q1 Tika ete mwasi na ngai ya motema aya 
\q2 kati na elanga na ye 
\q2 mpe alia mbuma na yango ya elengi makasi ! 
\c 5  
\s1 Mobali 
\q1  
\v 1 Oh molingami na ngai, mwasi na ngai ya motema ; 
\q2 nayei na elanga na ngai, 
\q1 nayei kobuka mbuma na ngai oyo basalelaka malasi ya mire, 
\q2 nayei kobuka biloko na ngai ya mike-mike ya solo kitoko, 
\q1 nayei kolia mafuta na ngai ya nzoyi, 
\q2 nayei komela vino mpe miliki na ngai. 
\s2 Baninga 
\q1 Oh baninga, bolia mpe bomela na bino, 
\q2 bomela mpe bolangwa na bino, balingami na ngai. 
\s2 Elenge mwasi 
\q1  
\v 2 Nalalaki, kasi makanisi na ngai ezalaki ya kolamuka. 
\q2 Yoka ! Mongongo ya molingami na ngai 
\q2 ezali koyokana na ekuke ! 
\s2 Elenge mobali 
\q1 « Molingami na ngai, mwasi na ngai ya motema, 
\q2 ebenga na ngai, oyo azali kitoko koleka mpo na ngai, 
\q2 fungolela ngai ndako, 
\q1 pamba te moto na ngai etondi na londende, 
\q2 mpe suki na ngai epoli na matanga ya londende ya butu. » 
\s2 Elenge mwasi 
\q1  
\v 3 Nasili kolongola nzambala na ngai, nalata yango lisusu ? 
\q2 Nasili kosukola makolo na ngai, nabebisa yango lisusu ? 
\q1  
\v 4 Mobali na ngai ya motema akotisi 
\q2 loboko na ye na lidusu ya ekuke, 
\q2 bongo motema na ngai ekomi kobeta mpo na ye. 
\q1  
\v 5 Natelemaki mpo na kokende kofungolela 
\q2 mobali na ngai ya motema ndako, 
\q1 mpe maboko na ngai ebimisaki solo ya malasi ya mire, 
\q2 misapi na ngai etangisaki yango na bikangelo ya ndako. 
\q1  
\v 6 Nafungolelaki mobali na ngai ya motema ndako, 
\q2 kasi akendeki na ye mpe alimwaki. 
\q1 Nakweyaki mayanga wana azalaki koloba ; 
\q2 nalukaki ye, kasi namonaki ye lisusu te ; 
\q2 nabengaki ye, kasi ayanolaki ngai te. 
\q1  
\v 7 Tango bakengeli ya mir bazalaki koleka-leka kati na engumba, 
\q2 bamonaki ngai, babetaki ngai, bazokisaki ngai 
\q2 mpe balongolaki ngai vwale na moto. 
\q1  
\v 8 Oh bilenge basi ya Yelusalemi, nabondeli bino, 
\q2 soki bomoni mobali na ngai, 
\q1 bokoloba na ye nini ? 
\q2 Boloba na ye ete nabeli maladi ya bolingo. 
\s2 Bilenge basi 
\q1  
\v 9 Oh mwasi oyo aleki basi nyonso na kitoko, 
\q2 mobali na yo aleki mibali mosusu na nini ? 
\q1 Nini penza ya malonga oyo mobali na yo azali na yango, 
\q2 oyo eleki mibali mosusu 
\q2 mpo ete oloba na biso boye ? 
\s2 Elenge mwasi 
\q1  
\v 10 Mobali na ngai azali na poso pembe, 
\q2 azali moto oyo asimba bendele kati na mibali nkoto zomi. 
\q1  
\v 11 Moto na ye ezali lokola wolo ya peto, 
\q2 suki na ye elingama-lingama, 
\q2 mpe azali mwindo lokola yanganga. 
\q1  
\v 12 Miso na ye ezali kitoko lokola bibenga 
\q2 pembeni ya moluka, 
\q1 ezali lokola basukolaka yango na miliki 
\q2 mpe avandaka kati na sani ya bomengo. 
\q1  
\v 13 Matama na ye ezali lokola mikala ya banzete ya malasi, 
\q2 lokola ekolo ya bafololo ya solo kitoko ; 
\q1 bibebu na ye ezali lokola fololo oyo babengaka lisi 
\q2 oyo ebimisaka mire ya kitoko. 
\q1  
\v 14 Maboko na ye ezali lokola bapete ya wolo 
\q2 oyo batia mabanga ya Krizolite. 
\q1 Nzoto na ye ezali lokola pembe ya nzoko 
\q2 oyo babongisi mpe babakisi mabanga ya safiri. 
\q1  
\v 15 Makolo na ye ezali lokola makonzi ya mabanga ya marbre 
\q2 oyo evandi likolo ya moboko ya wolo ya peto. 
\q1 Azali lokola bangomba ya Libani, 
\q2 kitoko lokola banzete ya sedele ya Libani. 
\q1  
\v 16 Elobeli na ye esalaka elengi na motema, 
\q2 mpe nzoto na ye mobimba esalaka ete balula ye. 
\q1 Tala ndenge mobali na ngai ya motema, molingami na ngai, azali, 
\q2 oh bilenge basi ya Yelusalemi ! 
\c 6  
\s2 Bilenge basi 
\q1  
\v 1 Oh mwasi oyo aleki basi nyonso na kitoko, 
\q2 mobali na yo akei wapi ? 
\q1 Akoti nzela nini mpo ete tosunga yo 
\q2 mpo na koluka ye ? 
\s2 Elenge mwasi 
\q1  
\v 2 Mobali na ngai akei na elanga na ye, 
\q2 na mikala ya banzete ya solo kitoko 
\q1 mpo na koleisa bibwele na ye 
\q2 mpe kobuka fololo oyo babengaka lisi. 
\q1  
\v 3 Nazali mpo na mobali na ngai, 
\q2 mpe mobali na ngai azali mpo ngai. 
\q1 Azali koleisa bibwele na ye na bilanga 
\q2 ya bafololo oyo babengaka lisi. 
\s2 Elenge mobali 
\q1  
\v 4 Oh mwasi na ngai ya motema, 
\q2 ozali kitoko lokola engumba ya Tiritsa ; 
\q1 elongi na yo ezali kitoko lokola engumba Yelusalemi ; 
\q2 obangisaka lokola mampinga ya basoda 
\q2 na se ya bendele na bango. 
\q1  
\v 5 Tika kotala ngai, 
\q2 pamba te miso na yo ezali kokweyisa ngai mayanga. 
\q1 Suki na yo ezali lokola etonga ya bantaba ya basi 
\q2 oyo ewutaka na Galadi. 
\q1  
\v 6 Minu na yo ezali lokola etonga ya bameme 
\q2 oyo bawuti kosukola. 
\q1 Meme moko na moko ezali na lipasa na yango, 
\q2 moko te ezangi mwana. 
\q1  
\v 7 Matama na yo, na se ya vwale, 
\q2 ezali lokola liboke ya bambuma ya grenade. 
\b  
\q1  
\v 8 Mokonzi akoki kozala na basi tuku motoba, 
\q2 bamakangu tuku mwambe 
\q2 mpe bilenge basi ebele penza. 
\q1  
\v 9 Kasi ebenga na ngai, mwasi na ngai oyo akoka na nyonso, 
\q2 azali kaka ye moko ; 
\q1 azali kaka ye moko mwana mwasi ya mama na ye, 
\q2 oyo aleki kitoko na libumu ya mama oyo abota ye. 
\q1 Tango bilenge basi bamonaka ye, 
\q2 balulaka ye mpe batatolaka ete azali mwasi na esengo. 
\q2 Basi ya bakonzi mpe bamakangu bakumisaka ye soki bamoni ye. 
\s2 Baninga 
\q1  
\v 10 Nani oyo azali komonana lokola moyi ya tongo, 
\q2 kitoko lokola sanza, 
\q1 azali kongenga lokola moyi, 
\q2 abangisaka lokola mampinga ya basoda na se 
\q2 ya bendele na bango ? 
\s2 Elenge mobali 
\q1  
\v 11 Nakendeki na elanga ya bakokoti 
\q2 mpo na koluka milona kati na lubwaku, 
\q1 mpo na kotala soki banzete ya vino ebandi kobimisa mito 
\q2 to banzete ya grenade ebandi kobimisa bafololo. 
\q1  
\v 12 Nasosolaki te ndenge nini molimo na ngai ememaki ngai 
\q2 kino na bashar ya mokonzi ya bato na ngai. 
\c 7  
\s2 Baninga 
\q1  
\v 1 Zonga, zonga, oh mwasi ya Sulami ! 
\q2 Zonga, zonga mpo ete tokoka kotala yo malamu ! 
\q1 Mpo na nini bolingi kotala malamu mwasi ya Sulami 
\q2 ndenge batalaka mabina ya mindule ya masanga mibale ? 
\s2 Elenge mobali 
\q1  
\v 2 Oh elenge mwasi ya lokumu ! 
\q2 Makolo na yo ebimaka kitoko soki olati basandale. 
\q1 Zingazinga ya loketo na yo ezali lokola lopete 
\q2 oyo esalemi na maboko ya basali bikeko. 
\q1  
\v 3 Motolu na yo ezali lokola kopo ya kitoko 
\q2 oyo ezangaka vino ya kitoko te. 
\q1 Libumu na yo ezali lokola mopiku ya ble 
\q2 oyo ezingami na fololo oyo babengaka lisi. 
\q1  
\v 4 Mabele na yo nyonso mibale ezali 
\q2 lokola bana mapasa mibale ya mboloko. 
\q1  
\v 5 Kingo na yo ezali lokola ndako molayi 
\q2 oyo batonga na pembe ya nzoko. 
\q1 Miso na yo ezali lokola maziba ya engumba Eshiboni, 
\q2 pembeni ya ekuke ya Bati-Rabimi. 
\q1 Zolo na yo ezali lokola ndako molayi ya Libani 
\q2 oyo etalani na Damasi. 
\q1  
\v 6 Moto na yo ezali lokola ngomba Karimeli, 
\q2 mpe suki ya moto na yo ezali lokola elamba ya motane ; 
\q2 mokonzi akangami na mazita na yango. 
\q1  
\v 7 Oh tala ndenge ozali penza kitoko ! 
\q2 Bolingo na ngai, osalaka esengo ya motema na ngai ; 
\q2 kitoko na yo esalaka ngai esengo na motema ! 
\q1  
\v 8 Molayi na yo ezali lokola nzete ya mbila, 
\q2 mabele na yo ezali lokola maboke ya bambuma. 
\q1  
\v 9 Namilobeli : « Nakomata na nzete ya mbila, 
\q2 nakobuka bambuma na yango ! » 
\b  
\q1 Tika ete mabele na yo ezala lokola maboke 
\q2 ya bambuma ya vino ! 
\q2 Tika ete solo ya monoko na yo ezala lokola bapome ! 
\q1  
\v 10 Mpe tika ete monoko na yo ezala 
\q2 lokola vino ya kitoko koleka ! 
\s2 Elenge mwasi 
\q1 Tika ete vino yango esopanela bolingo na ngai na pete, 
\q2 eleka na bibebu ya bato oyo bazali kolala. 
\q1  
\v 11 Ngai, nazali ya mobali na ngai ; 
\q2 mpe ye, azalaka kaka na posa na ngai. 
\q1  
\v 12 Yaka, mobali na ngai ; tika ete tokende na biso na elanga, 
\q2 tolekisa butu na biso kati na mboka ! 
\q1  
\v 13 Na tongo, tokokende na bilanga ya vino 
\q2 mpo na kotala soki banzete ya vino ebandi kobimisa bafololo, 
\q1 soki mito na yango efungwami, 
\q2 mpe soki banzete ya bambuma ya grenade ebimisi bafololo. 
\q2 Kuna nde nakopesa yo babeze na ngai. 
\q1  
\v 14 Bambuma ya mandragore ezali kobimisa solo na yango ; 
\q2 mpe na ekuke na biso, tozali na bambuma nyonso ya kitoko : 
\q1 ezala ya sika to ya kala, oyo nabombeli yo, 
\q2 mobali na ngai ya motema. 
\b  
\c 8  
\q1  
\v 1 Ah, soki ozalaki ndeko na ngai ya mobali 
\q2 oyo amelaki mabele ya mama na ngai ! 
\q1 Soki nakutanaki na yo na libanda, 
\q2 nalingaki kopesa yo beze, 
\q2 mpe moto moko te alingaki kotiola ngai. 
\q1  
\v 2 Nalingaki komema yo 
\q2 mpe kokotisa yo na ndako ya mama na ngai, 
\q1 mpo ete oteya ngai bolingo. 
\q2 Nalingaki komelisa yo vino ya kitoko, 
\q2 oyo basali na bambuma ya grenade. 
\b  
\q1  
\v 3 Tika ete loboko na ye ya mwasi ezala na se ya moto na ngai, 
\q2 mpe loboko na ye ya mobali ekanga ngai nzoto ! 
\b  
\q1  
\v 4 Bilenge basi ya Yelusalemi, nabondeli bino : 
\q2 bolamusa Bolingo na ngai te 
\q2 liboso ete ye moko akoma na posa ya kolamuka. 
\s1 Bilenge basi 
\q1  
\v 5 Nani oyo abimi na esobe 
\q2 mpe alaleli mobali na ye ya motema ? 
\s2 Elenge mwasi 
\q1 Nalamusaki yo na se ya nzete ya pome, 
\q2 na esika oyo mama na yo azwaki zemi na yo, 
\q2 esika oyo abotaki yo na pasi. 
\q1  
\v 6 Tia ngai lokola kashe na motema na yo, 
\q2 lokola kashe na loboko na yo ; 
\q1 pamba te bolingo ezali makasi lokola kufa, 
\q2 zuwa ezali makasi lokola mokili ya bakufi. 
\q1 Moto ya bolingo epelaka makasi 
\q2 lokola kake kowuta epai na Yawe. 
\q1  
\v 7 Mayi minene ekoki koboma moto ya bolingo te ; 
\q2 ezala mayi ya bibale, ekoki komela yango te. 
\q1 Soki moto apesi biloko na ye nyonso ya ndako 
\q2 mpo na kosomba bolingo, 
\q2 solo penza bakotiola ye. 
\s1 Bandeko mibali 
\q1  
\v 8 Tozali na ndeko moko ya mwasi, azali nanu moke ; 
\q2 azali nanu ata na mabele te. 
\q1 Tokosala nini mpo na ye 
\q2 na mokolo oyo bakoluka ye na libala ? 
\q1  
\v 9 Soki azalaki mir, tolingaki kotonga likolo na ye 
\q2 ndako oyo esalemi na palata ; 
\q1 soki azalaki ekuke, tolingaki kokanga ye 
\q2 na libaya ya sedele. 
\s2 Elenge mwasi 
\q1  
\v 10 Nazali mir, mpe mabele na ngai ezali 
\q2 lokola bandako milayi. 
\q1 Boye, na miso na ye, nazali lokola mwasi 
\q2 oyo azwi kimia. 
\s2 Elenge mobali 
\q1  
\v 11 Salomo azali na elanga ya vino kati na Bala-Amoni, 
\q2 apesi yango na bakengeli ; 
\q1 moko na moko kati na bango azalaki kopesa 
\q2 mbongo ya bibende ya palata, nkoto moko 
\q2 mpo na kosomba bambuma na yango. 
\q1  
\v 12 Oh Salomo, mbongo ya bibende ya palata, 
\q2 nkoto moko ezali ya yo, 
\q1 mpe bibende nkama mibale ezali ya bakengeli bambuma ; 
\q2 kasi elanga na ngai ya vino, oyo ezali liboso na ngai, ezali ya ngai. 
\b  
\q1  
\v 13 Yo oyo ovandi kati na bilanga, 
\q2 baninga na yo balingi koyoka mongongo na yo ; 
\q2 tika ete oyokisa ngai yango ! 
\s2 Elenge mwasi 
\q1  
\v 14 Oh bolingo na ngai, kima mbangu, 
\q2 zala lokola mboloko to lokola mwana ya mbuli ; 
\q1 kende na likolo ya bangomba oyo etondi 
\q2 na matiti ya solo kitoko.