\v 4 \w When|strong="H1961"\w* \w he|strong="H1931"\w* gets \w ready|strong="H6213"\w* \w to|strong="H1961"\w* \w go|strong="H1540"\w* \w to|strong="H1961"\w* \w sleep|strong="H7901"\w*, \w take|strong="H6213"\w* careful \w notice|strong="H3045"\w* \w of|strong="H4725"\w* \w the|strong="H6213"\w* \w place|strong="H4725"\w* \w where|strong="H8033"\w* \w he|strong="H1931"\w* \w lies|strong="H7901"\w* \w down|strong="H7901"\w*. \w Then|strong="H1961"\w* \w go|strong="H1540"\w*, \w uncover|strong="H1540"\w* \w his|strong="H3045"\w* legs, \w and|strong="H8033"\w* \w lie|strong="H7901"\w* \w down|strong="H7901"\w* \w beside|strong="H4772"\w* \w him|strong="H5046"\w*. \w He|strong="H1931"\w* \w will|strong="H1961"\w* \w tell|strong="H5046"\w* \w you|strong="H6213"\w* \w what|strong="H3045"\w* \w you|strong="H6213"\w* \w should|strong="H4725"\w* \w do|strong="H6213"\w*.”
\v 5 Ruth replied \w to|strong="H6213"\w* Naomi, “\w I|strong="H6213"\w* \w will|strong="H6213"\w* \w do|strong="H6213"\w* \w everything|strong="H3605"\w* \w you|strong="H3605"\w* \w have|strong="H3605"\w* \w told|strong="H6213"\w* \w me|strong="H6213"\w* \w to|strong="H6213"\w* \w do|strong="H6213"\w*.”
