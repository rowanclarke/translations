\toc1 Segundo libro de Samuel
\mt1 2 Samuel
\c 1
\s1 El informe para David
\p 
\v 1 \w Aconteció|strong="H1961"\w* \w que|strong="H3117"\w* \w después|strong="H3427"\w* de la \w muerte|strong="H4191"\w* de \w Saúl|strong="H7586"\w*, \w cuando|strong="H3117"\w* \w David|strong="H1732"\w* regresó de la derrota de \w los|strong="H3427"\w* amalecitas, \w David|strong="H1732"\w* permaneció \w dos|strong="H8147"\w* \w días|strong="H3117"\w* \w en|strong="H5221"\w* \w Siclag|strong="H6860"\w*.
\v 2 \w Al|strong="H5921"\w* tercer \w día|strong="H3117"\w* \w sucedió|strong="H1961"\w* \w que|strong="H4480"\w* un hombre \w del|strong="H4480"\w* \w campamento|strong="H4264"\w* \w de|strong="H4480"\w* \w Saúl|strong="H7586"\w* llegó \w con|strong="H5973"\w* sus ropas rotas \w y|strong="H5921"\w* tierra \w sobre|strong="H5921"\w* su \w cabeza|strong="H7218"\w*. Ocurrió \w que|strong="H4480"\w* \w cuando|strong="H3117"\w* llegó \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w cayó|strong="H5307"\w* \w en|strong="H5921"\w* tierra \w y|strong="H5921"\w* \w se|strong="H1961"\w* postró.
\p 
\v 3 \w David|strong="H1732"\w* le preguntó: ¿De dónde vienes?
\p \w Y|strong="H3068"\w* \w él|strong="H4264"\w* le respondió: \w Escapé|strong="H4422"\w* del \w campamento|strong="H4264"\w* de \w Israel|strong="H3478"\w*.
\p 
\v 4 \w David|strong="H1732"\w* le preguntó: ¿\w Cómo|strong="H4100"\w* salieron las \w cosas|strong="H1697"\w*? ¡Dímelo, \w por|strong="H4480"\w* favor! \w Y|strong="H3068"\w* \w él|strong="H5307"\w* contestó: \w El|strong="H5307"\w* \w pueblo|strong="H5971"\w* \w huyó|strong="H5127"\w* \w de|strong="H4480"\w* \w la|strong="H1571"\w* \w batalla|strong="H4421"\w*, \w y|strong="H1571"\w* \w muchos|strong="H7235"\w* \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w* \w cayeron|strong="H5307"\w* \w y|strong="H1571"\w* \w murieron|strong="H4191"\w*.
\p \w También|strong="H1571"\w* \w Saúl|strong="H7586"\w* \w y|strong="H1571"\w* su \w hijo|strong="H1121"\w* Jonatán \w murieron|strong="H4191"\w*.
\p 
\v 5 \w Entonces|strong="H3588"\w* \w David|strong="H1732"\w* le preguntó: ¿\w Cómo|strong="H3588"\w* \w sabes|strong="H3045"\w* \w que|strong="H3588"\w* \w Saúl|strong="H7586"\w* \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w* Jonatán \w murieron|strong="H4191"\w*?
\p 
\v 6 \w El|strong="H5921"\w* joven \w que|strong="H5921"\w* \w le|strong="H5921"\w* informaba \w dijo|strong="H5046"\w*: \w Me|strong="H5921"\w* encontraba \w casualmente|strong="H7122"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* montaña Gilboa. Vi \w que|strong="H5921"\w* \w Saúl|strong="H7586"\w* \w estaba|strong="H2009"\w* apoyado \w sobre|strong="H5921"\w* su \w lanza|strong="H2595"\w* \w y|strong="H5921"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* carruajes \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w jinetes|strong="H6571"\w* \w lo|strong="H5921"\w* alcanzaron.
\v 7 Cuando él \w miró|strong="H7200"\w* hacia atrás me \w vio|strong="H7200"\w* y me \w llamó|strong="H7121"\w*. \w Y|strong="H3068"\w* respondí: \w Aquí|strong="H2005"\w* estoy.
\p 
\v 8 \w Y|strong="H3068"\w* \w él|strong="H4310"\w* \w me|strong="H4310"\w* preguntó: ¿\w Quién|strong="H4310"\w* eres tú?
\p \w Y|strong="H3068"\w* \w le|strong="H4310"\w* respondí: Soy un amalecita.
\p 
\v 9 \w Entonces|strong="H3588"\w* \w me|strong="H5921"\w* dijo: Colócate \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w mí|strong="H5921"\w* \w y|strong="H3588"\w* mátame \w ya|strong="H4994"\w*, \w porque|strong="H3588"\w* \w la|strong="H5921"\w* agonía \w se|strong="H5921"\w* apoderó \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w aunque|strong="H3588"\w* \w mi|strong="H5921"\w* \w vida|strong="H5315"\w* \w está|strong="H5975"\w* \w todavía|strong="H5750"\w* \w en|strong="H5921"\w* \w mí|strong="H5921"\w*.
\p 
\v 10 \w Así|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H5921"\w* coloqué \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H3588"\w* \w lo|strong="H3808"\w* \w maté|strong="H4191"\w*, \w porque|strong="H3588"\w* \w sabía|strong="H3045"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w podía|strong="H3808"\w* \w vivir|strong="H2421"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* caída. \w Tomé|strong="H3947"\w* \w la|strong="H5921"\w* corona \w que|strong="H3588"\w* tenía \w en|strong="H5921"\w* \w su|strong="H3588"\w* \w cabeza|strong="H7218"\w* \w y|strong="H3588"\w* \w el|strong="H5921"\w* brazalete \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w brazo|strong="H2220"\w*, \w y|strong="H3588"\w* \w los|strong="H5921"\w* traje \w aquí|strong="H2008"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \tl ʼadón\tl*.
\p 
\v 11 \w Entonces|strong="H1571"\w* \w David|strong="H1732"\w* agarró sus ropas \w y|strong="H1571"\w* las \w rasgó|strong="H7167"\w*. \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w que|strong="H1571"\w* estaban \w con|strong="H1571"\w* \w él|strong="H3605"\w* hicieron \w lo|strong="H3605"\w* \w mismo|strong="H1571"\w*.
\v 12 \w Hicieron|strong="H1058"\w* duelo, \w lloraron|strong="H1058"\w* \w y|strong="H3588"\w* ayunaron \w hasta|strong="H5704"\w* llegar \w la|strong="H5921"\w* noche \w por|strong="H5921"\w* \w Saúl|strong="H7586"\w*, \w su|strong="H3588"\w* \w hijo|strong="H1121"\w* Jonatán, \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w y|strong="H3588"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w porque|strong="H3588"\w* \w cayeron|strong="H5307"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w*.
\p 
\v 13 \w Luego|strong="H2088"\w* \w David|strong="H1732"\w* preguntó al joven \w que|strong="H1616"\w* le informaba: ¿\w De|strong="H1121"\w* dónde eres tú?
\p \w Y|strong="H3068"\w* \w él|strong="H1121"\w* contestó: Soy \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* un \w extranjero|strong="H1616"\w* amalecita.
\p 
\v 14 \w Y|strong="H3068"\w* le dijo \w David|strong="H1732"\w*: ¿\w Por|strong="H3027"\w* \w qué|strong="H3808"\w* \w no|strong="H3808"\w* tuviste \w temor|strong="H3372"\w* \w de|strong="H3372"\w* \w extender|strong="H7971"\w* tu \w mano|strong="H3027"\w* para matar al \w ungido|strong="H4899"\w* \w de|strong="H3372"\w* \nd \w Yavé|strong="H3068"\w*\nd*?
\p 
\v 15 Entonces \w David|strong="H1732"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* uno de los jóvenes y le dijo: ¡Arremete y mátalo! \w Y|strong="H3068"\w* \w él|strong="H5066"\w* lo \w hirió|strong="H5221"\w* y \w murió|strong="H4191"\w*.
\v 16 \w David|strong="H1732"\w* \w le|strong="H5921"\w* dijo: ¡Tu \w sangre|strong="H1818"\w* sea \w sobre|strong="H5921"\w* tu \w cabeza|strong="H7218"\w*, \w pues|strong="H3588"\w* tu \w boca|strong="H6310"\w* \w atestiguó|strong="H6030"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w cuando|strong="H3588"\w* dijiste: \w Yo|strong="H3588"\w* \w maté|strong="H4191"\w* \w al|strong="H5921"\w* \w ungido|strong="H4899"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*!
\p 
\v 17 Entonces \w David|strong="H1732"\w* lamentó \w con|strong="H5921"\w* \w esta|strong="H2063"\w* \w endecha|strong="H7015"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* \w y|strong="H5921"\w* su \w hijo|strong="H1121"\w* Jonatán
\v 18 \w y|strong="H5921"\w* mandó \w que|strong="H5921"\w* \w enseñaran|strong="H3925"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \add la endecha del \add*\w Arco|strong="H7198"\w*. \w Ciertamente|strong="H2009"\w* \w está|strong="H5921"\w* \w escrita|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w del|strong="H5921"\w* Justo:
\s1 Endecha El Arco
\q1 
\v 19 ¡Pereció \w el|strong="H5921"\w* esplendor \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w sobre|strong="H5921"\w* tus alturas!
\q1 ¡\w Cómo|strong="H5921"\w* \w cayeron|strong="H5307"\w* \w los|strong="H5921"\w* \w valientes|strong="H1368"\w*!
\q1 
\v 20 \w No|strong="H6435"\w* lo proclamen en Gat,
\q1 \w Ni|strong="H6435"\w* lo anuncien en las \w plazas|strong="H2351"\w* de Ascalón.
\q1 \w Que|strong="H6435"\w* \w no|strong="H6435"\w* \w se|strong="H6435"\w* alegren las \w hijas|strong="H1323"\w* de los \w filisteos|strong="H6430"\w*,
\q1 \w Y|strong="H3068"\w* \w no|strong="H6435"\w* lo celebren las \w hijas|strong="H1323"\w* de los \w incircuncisos|strong="H6189"\w*.
\q1 
\v 21 ¡Oh montañas \w de|strong="H5921"\w* Gilboa,
\q1 \w Ni|strong="H1097"\w* \w rocío|strong="H2919"\w* \w ni|strong="H1097"\w* \w lluvia|strong="H4306"\w* caiga \w sobre|strong="H5921"\w* ustedes,
\q1 \w Ni|strong="H1097"\w* sean \w campos|strong="H7704"\w* \w de|strong="H5921"\w* \w ofrendas|strong="H8641"\w*!
\q1 \w Porque|strong="H3588"\w* \w allí|strong="H8033"\w* fue manchado \w el|strong="H5921"\w* \w escudo|strong="H4043"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w valientes|strong="H1368"\w*.
\q1 \w El|strong="H5921"\w* \w escudo|strong="H4043"\w* \w de|strong="H5921"\w* \w Saúl|strong="H7586"\w* \w no|strong="H1097"\w* estaba \w ungido|strong="H4899"\w* \w con|strong="H5921"\w* \w aceite|strong="H8081"\w*
\q1 
\v 22 \w Sino|strong="H3808"\w* con \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* \w heridos|strong="H2491"\w* y grasa \w de|strong="H1818"\w* \w valientes|strong="H1368"\w*.
\q1 ¡\w Arco|strong="H7198"\w* \w de|strong="H1818"\w* Jonatán \w que|strong="H3808"\w* \w jamás|strong="H3808"\w* retrocedió!
\q1 ¡\w Espada|strong="H2719"\w* \w de|strong="H1818"\w* \w Saúl|strong="H7586"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w volvía|strong="H7725"\w* \w vacía|strong="H7387"\w*!
\q1 
\v 23 \w Saúl|strong="H7586"\w* y Jonatán: Amados y amables en su \w vida|strong="H2416"\w*,
\q1 \w Ni|strong="H3808"\w* en su \w muerte|strong="H4194"\w* fueron separados.
\q1 \w Más|strong="H3808"\w* veloces \w que|strong="H3808"\w* las águilas,
\q1 \w Más|strong="H3808"\w* fuertes \w que|strong="H3808"\w* los leones.
\q1 
\v 24 Oh \w hijas|strong="H1323"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w lloren|strong="H1058"\w* \w por|strong="H5921"\w* \w Saúl|strong="H7586"\w*,
\q1 Quien \w las|strong="H5921"\w* vestía \w de|strong="H5921"\w* lino fino
\q1 \w Y|strong="H3068"\w* adornaba \w con|strong="H5973"\w* \w oro|strong="H2091"\w* sus ropas.
\q1 
\v 25 ¡\w Cómo|strong="H5921"\w* \w cayeron|strong="H5307"\w* \w los|strong="H5921"\w* \w valientes|strong="H1368"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w batalla|strong="H4421"\w*!
\q1 ¡Jonatán, herido \w en|strong="H5921"\w* tus alturas!
\q1 
\v 26 ¡\w Cómo|strong="H5921"\w* sufro \w por|strong="H5921"\w* \w ti|strong="H5921"\w*, oh Jonatán, hermano \w mío|strong="H5921"\w*!
\q1 ¡Ay, \w cómo|strong="H5921"\w* \w te|strong="H5921"\w* quería!
\q1 \w Más|strong="H5921"\w* maravilloso \w me|strong="H5921"\w* fue tu amor \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w mayor|strong="H3966"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* mujeres.
\q1 
\v 27 ¡Cómo \w cayeron|strong="H5307"\w* los \w valientes|strong="H1368"\w*,
\q1 \w Y|strong="H3068"\w* perecieron las \w armas|strong="H3627"\w* de \w guerra|strong="H4421"\w*!
\c 2
\s1 David en Hebrón
\p 
\v 1 \w Después|strong="H1961"\w* de \w esto|strong="H3651"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1961"\w* \w David|strong="H1732"\w* \w consultó|strong="H7592"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, y \w preguntó|strong="H7592"\w*: ¿Subo \w a|strong="H3068"\w* alguna de las \w ciudades|strong="H5892"\w* de \w Judá|strong="H3063"\w*? \w Y|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* le contestó: \wj \w Sube|strong="H5927"\w*. \wj* \w Y|strong="H3068"\w* \w David|strong="H1732"\w* \w preguntó|strong="H7592"\w*: ¿\w A|strong="H3068"\w* dónde subo? \w Y|strong="H3068"\w* Él respondió: \wj \w A|strong="H3068"\w* \w Hebrón|strong="H2275"\w*.\wj*
\v 2 \w David|strong="H1732"\w* \w subió|strong="H5927"\w* \w allá|strong="H8033"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* sus \w dos|strong="H8147"\w* esposas Ahinoam \w la|strong="H1571"\w* \w jezreelita|strong="H3159"\w*, \w y|strong="H1571"\w* Abigail, \w la|strong="H1571"\w* \w que|strong="H1571"\w* \w fue|strong="H1571"\w* esposa de \w Nabal|strong="H5037"\w* \w carmelita|strong="H3761"\w*.
\v 3 \w David|strong="H1732"\w* también llevó \w a|strong="H3068"\w* sus hombres que \w estaban|strong="H3427"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w*, cada uno \w con|strong="H5973"\w* su \w familia|strong="H1004"\w*, y vivieron \w en|strong="H5973"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5973"\w* \w Hebrón|strong="H2275"\w*.
\p 
\v 4 \w Los|strong="H5921"\w* hombres \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* llegaron \w y|strong="H5921"\w* \w ungieron|strong="H4886"\w* \w allí|strong="H8033"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w como|strong="H5921"\w* \w rey|strong="H4428"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*. \w Le|strong="H5921"\w* informaron \w a|strong="H3068"\w* \w David|strong="H1732"\w*: \w Los|strong="H5921"\w* hombres \w de|strong="H5921"\w* \w Jabes|strong="H3003"\w* \w de|strong="H5921"\w* \w Galaad|strong="H1568"\w* son \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w sepultaron|strong="H6912"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*.
\v 5 \w David|strong="H1732"\w* \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* \w los|strong="H5973"\w* hombres \w de|strong="H5973"\w* \w Jabes|strong="H3003"\w* \w de|strong="H5973"\w* \w Galaad|strong="H1568"\w* y \w les|strong="H5973"\w* dijo: \w Benditos|strong="H1288"\w* sean ustedes \w por|strong="H2088"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w porque|strong="H1732"\w* \w hicieron|strong="H6213"\w* \w esta|strong="H2088"\w* \w misericordia|strong="H2617"\w* \w con|strong="H5973"\w* su \tl ʼadón\tl* \w Saúl|strong="H7586"\w* al sepultarlo.
\v 6 \w Ahora|strong="H6258"\w* \nd \w Yavé|strong="H3068"\w*\nd* mostrará su bondad \w hacia|strong="H6213"\w* ustedes, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w yo|strong="H6213"\w* \w les|strong="H5973"\w* recompensaré esa bondad \w por|strong="H1697"\w* haber \w hecho|strong="H6213"\w* \w tal|strong="H2088"\w* \w cosa|strong="H1697"\w*.
\v 7 \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, fortalézcanse sus \w manos|strong="H3027"\w* \w y|strong="H1571"\w* \w sean|strong="H1961"\w* \w valientes|strong="H2428"\w*, \w pues|strong="H3588"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w morir|strong="H4191"\w* \w Saúl|strong="H7586"\w*, \w su|strong="H3588"\w* \tl ʼadón\tl*, \w los|strong="H1121"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w me|strong="H5921"\w* \w ungieron|strong="H4886"\w* \w como|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w ellos|strong="H3027"\w*.
\p 
\v 8 Pero Abner, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Ner|strong="H5369"\w*, \w jefe|strong="H8269"\w* del \w ejército|strong="H6635"\w* \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w*, \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* Is-boset, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w*, lo \w llevó|strong="H3947"\w* \w a|strong="H3068"\w* \w Mahanaim|strong="H4266"\w*
\v 9 \w y|strong="H5921"\w* \w lo|strong="H5921"\w* proclamó \w rey|strong="H4427"\w* \w sobre|strong="H5921"\w* \w Galaad|strong="H1568"\w*, Asurí, \w Jezreel|strong="H3157"\w*, Efraín, \w Benjamín|strong="H1144"\w* \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*.
\p 
\v 10 Is-boset, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Saúl|strong="H7586"\w*, \w tenía|strong="H1961"\w* 40 \w años|strong="H8141"\w* \w cuando|strong="H1961"\w* comenzó \w a|strong="H3068"\w* reinar \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* \w reinó|strong="H4427"\w* \w dos|strong="H8147"\w* \w años|strong="H8141"\w*. Solo \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w seguía|strong="H1961"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*.
\v 11 \w David|strong="H1732"\w* \w fue|strong="H1961"\w* \w rey|strong="H4428"\w* \w en|strong="H5921"\w* \w Hebrón|strong="H2275"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w* \w y|strong="H5921"\w* \w seis|strong="H8337"\w* \w meses|strong="H2320"\w*.
\p 
\v 12 Abner, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Ner|strong="H5369"\w*, \w salió|strong="H3318"\w* \w de|strong="H1121"\w* \w Mahanaim|strong="H4266"\w* \w a|strong="H3068"\w* \w Gabaón|strong="H1391"\w* con \w los|strong="H1121"\w* esclavos \w de|strong="H1121"\w* Is-boset, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w*.
\v 13 \w Joab|strong="H3097"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Sarvia, \w y|strong="H5921"\w* \w los|strong="H3427"\w* esclavos \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w salieron|strong="H3318"\w* \w y|strong="H5921"\w* \w los|strong="H3427"\w* encontraron \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w estanque|strong="H1295"\w* \w de|strong="H5921"\w* \w Gabaón|strong="H1391"\w*. \w Éstos|strong="H2088"\w* \w se|strong="H5921"\w* \w sentaron|strong="H3427"\w* \w a|strong="H3068"\w* \w un|strong="H3162"\w* lado \w del|strong="H5921"\w* \w estanque|strong="H1295"\w* \w y|strong="H5921"\w* aquéllos \w al|strong="H5921"\w* \w otro|strong="H2088"\w* lado.
\p 
\v 14 Abner dijo \w a|strong="H3068"\w* \w Joab|strong="H3097"\w*: ¡\w Levántense|strong="H6965"\w* los jóvenes y \w que|strong="H4994"\w* compitan \w ante|strong="H6440"\w* nosotros!
\p \w Y|strong="H3068"\w* \w Joab|strong="H3097"\w* respondió: ¡\w Que|strong="H4994"\w* se levanten!
\p 
\v 15 Se \w levantaron|strong="H6965"\w* y avanzaron: 12 por \w Benjamín|strong="H1144"\w* y por Is-boset, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w*, y 12 \w de|strong="H1121"\w* \w los|strong="H1121"\w* esclavos \w de|strong="H1121"\w* \w David|strong="H1732"\w*.
\v 16 \w Echó|strong="H5307"\w* \w mano|strong="H1931"\w* cada uno de \w la|strong="H1931"\w* \w cabeza|strong="H7218"\w* de \w su|strong="H1931"\w* contrario, \w le|strong="H1931"\w* hundió \w la|strong="H1931"\w* \w espada|strong="H2719"\w* en \w el|strong="H1931"\w* costado y \w cayeron|strong="H5307"\w* \w juntos|strong="H3162"\w*, por \w lo|strong="H1931"\w* \w cual|strong="H1931"\w* \w fue|strong="H1931"\w* \w llamado|strong="H7121"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* Campo de \w los|strong="H1931"\w* \w Lados|strong="H6654"\w*, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w está|strong="H1931"\w* en \w Gabaón|strong="H1391"\w*.
\p 
\v 17 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w la|strong="H1931"\w* \w batalla|strong="H4421"\w* \w fue|strong="H1961"\w* \w muy|strong="H3966"\w* \w dura|strong="H7186"\w*, pero Abner \w y|strong="H5704"\w* \w los|strong="H1931"\w* hombres \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w fueron|strong="H1961"\w* derrotados \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w los|strong="H1931"\w* esclavos \w de|strong="H6440"\w* \w David|strong="H1732"\w*.
\p 
\v 18 \w Estaban|strong="H1961"\w* \w allí|strong="H8033"\w* \w los|strong="H1121"\w* \w tres|strong="H7969"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Sarvia: \w Joab|strong="H3097"\w*, \w Abisai|strong="H7969"\w* y \w Asael|strong="H6214"\w*.
\p \w Y|strong="H3068"\w* \w Asael|strong="H6214"\w* \w era|strong="H1961"\w* tan veloz \w de|strong="H1121"\w* \w pies|strong="H7272"\w* \w como|strong="H1961"\w* las gacelas del \w campo|strong="H7704"\w*.
\v 19 \w Asael|strong="H6214"\w* \w persiguió|strong="H7291"\w* \w a|strong="H3068"\w* Abner, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* desviaba \w de|strong="H5921"\w* detrás \w de|strong="H5921"\w* Abner \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w derecha|strong="H3225"\w* \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w izquierda|strong="H8040"\w*.
\v 20 Abner, al regresar, le dijo: ¿Eres \w Asael|strong="H6214"\w*? \w Y|strong="H3068"\w* le respondió: Sí, soy yo.
