\c 1
\s1 En Babilonia
\p 
\v 1 \w El|strong="H5921"\w* tercer \w año|strong="H8141"\w* \w del|strong="H5921"\w* \w reinado|strong="H4428"\w* \w de|strong="H5921"\w* \w Joacim|strong="H3079"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, llegó \w a|strong="H3068"\w* Jerusalén \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, \w y|strong="H5921"\w* \w la|strong="H5921"\w* sitió.
\v 2 \nd ʼAdonay\nd* \w entregó|strong="H5414"\w* \w a|strong="H3068"\w* \w Joacim|strong="H3079"\w*, \w rey|strong="H4428"\w* \w de|strong="H5414"\w* \w Judá|strong="H3063"\w*, en su \w mano|strong="H3027"\w*, y parte \w de|strong="H5414"\w* los utensilios \w de|strong="H5414"\w* la \w Casa|strong="H1004"\w* \w de|strong="H5414"\w* \nd ʼElohim\nd*. Los llevó \w al|strong="H4428"\w* \w templo|strong="H1004"\w* \w de|strong="H5414"\w* su \tl ʼelohim\tl* en tierra \w de|strong="H5414"\w* Sinar. \w Puso|strong="H5414"\w* los utensilios en el tesoro del \w templo|strong="H1004"\w*.
\p 
\v 3 \w El|strong="H1121"\w* \w rey|strong="H4428"\w* dijo \w a|strong="H3068"\w* Aspenaz, jefe \w de|strong="H4480"\w* sus servidores \w del|strong="H4480"\w* palacio, \w que|strong="H4480"\w* trajera algunos israelitas \w del|strong="H4480"\w* \w linaje|strong="H2233"\w* \w real|strong="H4428"\w* y \w de|strong="H4480"\w* \w los|strong="H1121"\w* nobles,
\v 4 jóvenes de \w buen|strong="H2896"\w* \w parecer|strong="H4758"\w* \w en|strong="H5975"\w* quienes no hubiera defecto, \w que|strong="H3045"\w* mostraran \w inteligencia|strong="H7919"\w* \w en|strong="H5975"\w* \w toda|strong="H3605"\w* \w sabiduría|strong="H2451"\w*, dotados de \w entendimiento|strong="H2896"\w* y discernimiento, y aptos para \w enseñarles|strong="H3045"\w* \w la|strong="H3605"\w* literatura y \w la|strong="H3605"\w* \w lengua|strong="H3956"\w* de \w los|strong="H3605"\w* \w caldeos|strong="H3778"\w*.
\v 5 El \w rey|strong="H4428"\w* les asignó su \w ración|strong="H1697"\w* \w diaria|strong="H3117"\w* \w de|strong="H6440"\w* la mesa \w real|strong="H4428"\w* y del \w vino|strong="H3196"\w* \w que|strong="H1697"\w* él bebía, para alimentarlos durante \w tres|strong="H7969"\w* \w años|strong="H8141"\w* \w a|strong="H3068"\w* fin \w de|strong="H6440"\w* \w que|strong="H1697"\w* ellos fueran esclavos personales del \w rey|strong="H4428"\w*.
\p 
\v 6 Entre ellos \w estaban|strong="H1961"\w* \w Daniel|strong="H1840"\w*, \w Ananías|strong="H2608"\w*, \w Misael|strong="H4332"\w* y \w Azarías|strong="H5838"\w*, \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.
\v 7 \w El|strong="H1992"\w* \w jefe|strong="H8269"\w* \w de|strong="H8269"\w* \w los|strong="H1992"\w* servidores del palacio \w les|strong="H1992"\w* cambió \w los|strong="H1992"\w* \w nombres|strong="H8034"\w* \w a|strong="H3068"\w* \w éstos|strong="H1992"\w*: \w A|strong="H3068"\w* \w Daniel|strong="H1840"\w* \w llamó|strong="H8034"\w* \w Beltsasar|strong="H1095"\w*; \w a|strong="H3068"\w* \w Ananías|strong="H2608"\w*, Sadrac; \w a|strong="H3068"\w* \w Misael|strong="H4332"\w*, Mesac, y \w a|strong="H3068"\w* \w Azarías|strong="H5838"\w*, \w Abed-nego|strong="H5664"\w*.
\p 
\v 8 \w Daniel|strong="H1840"\w* \w propuso|strong="H7760"\w* \w en|strong="H5921"\w* su \w corazón|strong="H3820"\w* \w no|strong="H3808"\w* \w contaminarse|strong="H1351"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* ración \w de|strong="H5921"\w* \w la|strong="H5921"\w* comida \w del|strong="H5921"\w* \w rey|strong="H4428"\w*, \w ni|strong="H3808"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w vino|strong="H3196"\w* \w que|strong="H3808"\w* bebía. \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w* \w pidió|strong="H1245"\w* permiso \w al|strong="H5921"\w* \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* servidores \w del|strong="H5921"\w* palacio \w para|strong="H5921"\w* \w no|strong="H3808"\w* \w contaminarse|strong="H1351"\w*.
\v 9 \add \nd ʼElah\nd*\add* concedió \w a|strong="H3068"\w* \w Daniel|strong="H1840"\w* \w gracia|strong="H2617"\w* y compasión \w de|strong="H6440"\w* parte del \w jefe|strong="H8269"\w* \w de|strong="H6440"\w* los servidores del palacio.
\v 10 El \w jefe|strong="H7218"\w* \w de|strong="H4480"\w* los servidores \w del|strong="H4480"\w* palacio dijo \w a|strong="H3068"\w* \w Daniel|strong="H1840"\w*: Tengo temor \w a|strong="H3068"\w* mi \tl ʼadón\tl* el \w rey|strong="H4428"\w*, \w quien|strong="H4100"\w* asignó su \w comida|strong="H3978"\w* y su bebida. \w Si|strong="H6440"\w* él \w ve|strong="H7200"\w* sus \w rostros|strong="H6440"\w* demacrados \w en|strong="H4480"\w* comparación \w con|strong="H4480"\w* los jóvenes \w de|strong="H4480"\w* su edad, entonces ustedes pondrían mi \w cabeza|strong="H7218"\w* \w en|strong="H4480"\w* peligro \w ante|strong="H6440"\w* el \w rey|strong="H4428"\w*.
\p 
\v 11 Entonces \w Daniel|strong="H1840"\w* dijo \w al|strong="H5921"\w* inspector, \w a|strong="H3068"\w* quien \w el|strong="H5921"\w* \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* servidores \w del|strong="H5921"\w* palacio designó \w para|strong="H5921"\w* cuidarlo \w a|strong="H3068"\w* \w él|strong="H5921"\w*, \w a|strong="H3068"\w* \w Ananías|strong="H2608"\w*, \w a|strong="H3068"\w* \w Misael|strong="H4332"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w Azarías|strong="H5838"\w*:
\v 12 \w Te|strong="H4480"\w* \w ruego|strong="H4994"\w* \w que|strong="H4480"\w* hagas la \w prueba|strong="H5254"\w* \w con|strong="H4480"\w* tus esclavos durante \w diez|strong="H6235"\w* \w días|strong="H3117"\w*: \w que|strong="H4480"\w* \w nos|strong="H4480"\w* den \w legumbres|strong="H2235"\w* \w para|strong="H4480"\w* comer y \w agua|strong="H4325"\w* \w para|strong="H4480"\w* \w beber|strong="H8354"\w*,
\v 13 que luego nuestros semblantes sean comparados \w con|strong="H5973"\w* \w los|strong="H5973"\w* \w rostros|strong="H6440"\w* \w de|strong="H6440"\w* \w los|strong="H5973"\w* jóvenes que comen \w de|strong="H6440"\w* la comida \w del|strong="H5973"\w* \w rey|strong="H4428"\w*, y que \w hagas|strong="H6213"\w* después \w con|strong="H5973"\w* tus esclavos según \w lo|strong="H6213"\w* que \w veas|strong="H7200"\w*.
\v 14 Él convino con ellos \w e|strong="H3068"\w* hizo la \w prueba|strong="H5254"\w* durante \w diez|strong="H6235"\w* \w días|strong="H3117"\w*.
\p 
\v 15 \w Al|strong="H4480"\w* final \w de|strong="H4480"\w* \w los|strong="H3605"\w* \w diez|strong="H6235"\w* \w días|strong="H3117"\w*, \w los|strong="H3605"\w* semblantes \w de|strong="H4480"\w* \w ellos|strong="H4480"\w* \w se|strong="H4480"\w* \w veían|strong="H7200"\w* \w mejor|strong="H2896"\w* y \w más|strong="H4480"\w* nutridos \w que|strong="H4480"\w* \w los|strong="H3605"\w* \w de|strong="H4480"\w* \w los|strong="H3605"\w* otros jóvenes \w que|strong="H4480"\w* comían \w la|strong="H3605"\w* ración \w de|strong="H4480"\w* \w los|strong="H3605"\w* manjares \w del|strong="H4480"\w* \w rey|strong="H4428"\w*.
\v 16 \w Por|strong="H5414"\w* lo cual el inspector cambiaba la porción \w de|strong="H5414"\w* la comida \w de|strong="H5414"\w* ellos y el \w vino|strong="H3196"\w* \w que|strong="H1961"\w* debían beber, y les \w daba|strong="H5414"\w* \w legumbres|strong="H2235"\w*.
\p 
\v 17 \nd ʼElohim\nd* concedió \w conocimiento|strong="H4093"\w* \w e|strong="H3068"\w* \w inteligencia|strong="H7919"\w* en \w toda|strong="H3605"\w* literatura y \w sabiduría|strong="H2451"\w* \w a|strong="H3068"\w* \w estos|strong="H3605"\w* cuatro jóvenes, y \w Daniel|strong="H1840"\w* tenía entendimiento en visiones y \w sueños|strong="H2472"\w*.
\p 
\v 18 \w Al|strong="H4428"\w* terminar el \w tiempo|strong="H3117"\w* \w que|strong="H3117"\w* el \w rey|strong="H4428"\w* fijó para prepararlos, el \w jefe|strong="H8269"\w* \w de|strong="H6440"\w* los servidores del palacio los presentó \w ante|strong="H6440"\w* \w Nabucodonosor|strong="H5019"\w*.
\v 19 Cuando \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w habló|strong="H1696"\w* con \w ellos|strong="H3605"\w*, \w no|strong="H3808"\w* \w halló|strong="H4672"\w* \w entre|strong="H3808"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w a|strong="H3068"\w* uno como \w Daniel|strong="H1840"\w*, \w Ananías|strong="H2608"\w*, \w Misael|strong="H4332"\w* y \w Azarías|strong="H5838"\w*, \w por|strong="H6440"\w* \w lo|strong="H3808"\w* cual permanecieron \w delante|strong="H6440"\w* del \w rey|strong="H4428"\w*.
\v 20 \w Sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w asunto|strong="H1697"\w* \w de|strong="H5921"\w* \w sabiduría|strong="H2451"\w* \w e|strong="H3068"\w* inteligencia \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w les|strong="H1992"\w* consultaba, \w los|strong="H1992"\w* \w halló|strong="H4672"\w* \w diez|strong="H6235"\w* \w veces|strong="H3027"\w* mejores \w que|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H1992"\w* \w magos|strong="H2748"\w* \w y|strong="H5921"\w* astrólogos \w que|strong="H5921"\w* \w había|strong="H4672"\w* \w en|strong="H5921"\w* \w todo|strong="H3605"\w* \w su|strong="H1992"\w* \w reino|strong="H4438"\w*.
\p 
\v 21 \w Daniel|strong="H1840"\w* continuó \w hasta|strong="H5704"\w* el primer \w año|strong="H8141"\w* del \w rey|strong="H4428"\w* \w Ciro|strong="H3566"\w*.
\c 2
\s1 Un sueño de Nabucodonosor
\p 
\v 1 \w El|strong="H5921"\w* \w segundo|strong="H8147"\w* \w año|strong="H8141"\w* \w de|strong="H5921"\w* su \w reinado|strong="H4438"\w*, \w Nabucodonosor|strong="H5019"\w* \w tuvo|strong="H1961"\w* un \w sueño|strong="H2472"\w*. Su \w espíritu|strong="H7307"\w* \w se|strong="H1961"\w* perturbó \w de|strong="H5921"\w* tal modo \w que|strong="H5921"\w* \w no|strong="H1961"\w* pudo dormir.
\v 2 El \w rey|strong="H4428"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* los \w magos|strong="H2748"\w*, astrólogos, hechiceros y \w caldeos|strong="H3778"\w*, para que interpretaran el \w sueño|strong="H2472"\w* del \w rey|strong="H4428"\w*. Fueron y se presentaron \w ante|strong="H6440"\w* el \w rey|strong="H4428"\w*.
\v 3 \w Él|strong="H1992"\w* \w les|strong="H1992"\w* dijo: Tuve un \w sueño|strong="H2472"\w*, y mi \w espíritu|strong="H7307"\w* desespera \w por|strong="H4428"\w* entenderlo.
\p 
\v 4 Entonces los \w caldeos|strong="H3778"\w* \w respondieron|strong="H1696"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* en lengua aramea: ¡\w Vive|strong="H2418"\w* para siempre, oh \w rey|strong="H4428"\w*! \w Dí|strong="H1696"\w* el \w sueño|strong="H2493"\w* \w a|strong="H3068"\w* tus esclavos, y te diremos la interpretación.
\p 
\v 5 El \w rey|strong="H4430"\w* \w respondió|strong="H6032"\w* \w a|strong="H3068"\w* los \w caldeos|strong="H3779"\w*: Olvidé el asunto, pero \w si|strong="H2006"\w* \w no|strong="H3809"\w* me dicen el \w sueño|strong="H2493"\w* \w y|strong="H3809"\w* su interpretación, serán despedazados \w y|strong="H3809"\w* sus casas serán convertidas \w en|strong="H4481"\w* muladares.
\v 6 Sin embargo, \w si|strong="H2006"\w* me declaran el \w sueño|strong="H2493"\w* y su interpretación, recibirán regalos, recompensas y grandes honores \w de|strong="H4481"\w* \w mi|strong="H6925"\w* \w parte|strong="H6925"\w*. Solo declárenme el \w sueño|strong="H2493"\w* y su interpretación.
\p 
\v 7 \w Respondieron|strong="H6032"\w* por segunda vez: Diga el \w rey|strong="H4430"\w* el \w sueño|strong="H2493"\w* \w a|strong="H3068"\w* sus esclavos, y le diremos la interpretación.
\p 
\v 8 El \w rey|strong="H4430"\w* \w respondió|strong="H6032"\w*: \w En|strong="H4481"\w* \w verdad|strong="H3330"\w* veo \w que|strong="H1768"\w* ponen \w dilaciones|strong="H5732"\w*, \w porque|strong="H1768"\w* \w saben|strong="H3046"\w* \w que|strong="H1768"\w* el asunto se me fue.
\v 9 \w Si|strong="H2006"\w* \w no|strong="H3809"\w* me muestran \w el|strong="H1932"\w* \w sueño|strong="H2493"\w*, su \w sentencia|strong="H1882"\w* será \w una|strong="H1932"\w* \w sola|strong="H2298"\w*. Ciertamente preparan \w respuesta|strong="H4406"\w* \w mentirosa|strong="H3538"\w* \w y|strong="H3809"\w* perversa para presentármela, mientras pasa \w el|strong="H1932"\w* \w tiempo|strong="H5732"\w*. ¡Declárenme \w de|strong="H1768"\w* \w una|strong="H1932"\w* vez \w el|strong="H1932"\w* \w sueño|strong="H2493"\w*, \w y|strong="H3809"\w* sabré \w que|strong="H1768"\w* pueden interpretármelo!
\p 
\v 10 Los \w caldeos|strong="H3779"\w* \w respondieron|strong="H6032"\w* \w al|strong="H5922"\w* \w rey|strong="H4430"\w*: \w No|strong="H3809"\w* hay hombre \w en|strong="H5922"\w* la tierra \w que|strong="H1768"\w* \w pueda|strong="H3202"\w* \w declarar|strong="H2324"\w* lo \w que|strong="H1768"\w* pide el \w rey|strong="H4430"\w*. \w Ningún|strong="H3606"\w* \w rey|strong="H4430"\w*, aunque fuera poderoso, pidió \w cosa|strong="H4406"\w* \w semejante|strong="H1836"\w* \w a|strong="H3068"\w* algún \w mago|strong="H2749"\w*, astrólogo \w o|strong="H3068"\w* \w caldeo|strong="H3779"\w*.
\v 11 \w Porque|strong="H1768"\w* el asunto \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* \w demanda|strong="H7593"\w* es \w cosa|strong="H4406"\w* ardua, \w y|strong="H3809"\w* \w no|strong="H3809"\w* hay quien lo pueda \w declarar|strong="H2324"\w* al \w rey|strong="H4430"\w*, excepto los \tl ʼelohim\tl* \w cuya|strong="H1768"\w* morada \w no|strong="H3809"\w* está entre los hombres.
\p 
\v 12 Por \w esto|strong="H1836"\w* el \w rey|strong="H4430"\w*, airado y con gran \w enojo|strong="H7108"\w*, ordenó que \w todos|strong="H3606"\w* los \w sabios|strong="H2445"\w* de Babilonia fueran exterminados.
\v 13 Se publicó el edicto según el cual los \w sabios|strong="H2445"\w* fueran ejecutados. También buscaron \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* y \w a|strong="H3068"\w* sus compañeros para ejecutarlos.
\p 
\v 14 Entonces \w Daniel|strong="H1841"\w* \w habló|strong="H8421"\w* sabia y prudentemente \w a|strong="H3068"\w* Arioc, \w capitán|strong="H7229"\w* \w de|strong="H1768"\w* la guardia del \w rey|strong="H4430"\w*, encargado \w de|strong="H1768"\w* matar \w a|strong="H3068"\w* los \w sabios|strong="H2445"\w* \w de|strong="H1768"\w* Babilonia.
\v 15 Le preguntó \w a|strong="H3068"\w* Arioc, capitán \w del|strong="H4481"\w* \w rey|strong="H4430"\w*: ¿\w Por|strong="H4481"\w* cual razón el edicto \w del|strong="H4481"\w* \w rey|strong="H4430"\w* es tan urgente? Entonces Arioc informó \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* con respecto \w al|strong="H5922"\w* asunto.
\v 16 \w Daniel|strong="H1841"\w* \w entró|strong="H5954"\w* y pidió \w al|strong="H4481"\w* \w rey|strong="H4430"\w* \w que|strong="H1768"\w* le diera \w tiempo|strong="H2166"\w* para \w declarar|strong="H2324"\w* la interpretación \w al|strong="H4481"\w* \w rey|strong="H4430"\w*.
\p 
\v 17 Luego \w Daniel|strong="H1841"\w* fue \w a|strong="H3068"\w* su \w casa|strong="H1005"\w* \w e|strong="H3068"\w* informó el asunto \w a|strong="H3068"\w* sus compañeros \w Ananías|strong="H2608"\w*, \w Misael|strong="H4333"\w* y Azarías,
\v 18 \w para|strong="H5922"\w* \w que|strong="H1768"\w* pidieran compasión \w del|strong="H4481"\w* \nd ʼEloha\nd* \w del|strong="H4481"\w* \w cielo|strong="H8065"\w* \w con|strong="H5974"\w* respecto \w a|strong="H3068"\w* \w este|strong="H1836"\w* \w misterio|strong="H7328"\w*, \w a|strong="H3068"\w* fin \w de|strong="H4481"\w* \w que|strong="H1768"\w* \w Daniel|strong="H1841"\w* \w y|strong="H3809"\w* sus compañeros \w no|strong="H3809"\w* perecieran \w con|strong="H5974"\w* el resto \w de|strong="H4481"\w* los \w sabios|strong="H2445"\w* \w de|strong="H4481"\w* Babilonia.
\p 
\v 19 Entonces, en una visión nocturna, el \w misterio|strong="H7328"\w* le fue revelado \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w*, \w por|strong="H1768"\w* lo cual \w Daniel|strong="H1841"\w* \w bendijo|strong="H1289"\w* al \nd ʼEloha\nd* del \w cielo|strong="H8065"\w*.
\q1 
\v 20 \w Daniel|strong="H1841"\w* \w habló|strong="H6032"\w*:
\q1 \w Bendito|strong="H1289"\w* \w sea|strong="H1934"\w* \w el|strong="H1934"\w* \w Nombre|strong="H8036"\w* \w de|strong="H4481"\w* \nd ʼEloha\nd*
\q1 \w Por|strong="H4481"\w* los siglos \w de|strong="H4481"\w* los siglos,
\q1 \w Porque|strong="H1768"\w* la \w sabiduría|strong="H2452"\w* y \w el|strong="H1934"\w* poder pertenecen \w a|strong="H3068"\w* \w Él|strong="H1934"\w*.
\q1 
\v 21 \w Él|strong="H1932"\w* cambia los \w tiempos|strong="H5732"\w* y las épocas.
\q1 \w Él|strong="H1932"\w* remueve \w reyes|strong="H4430"\w* y establece los \w reyes|strong="H4430"\w*.
\q1 \w Él|strong="H1932"\w* \w da|strong="H3052"\w* \w sabiduría|strong="H2452"\w* \w a|strong="H3068"\w* los \w sabios|strong="H2445"\w*
\q1 \w Y|strong="H3068"\w* conocimiento \w a|strong="H3068"\w* los de entendimiento.
\q1 
\v 22 \w Revela|strong="H1541"\w* las cosas profundas y ocultas.
\q1 \w Conoce|strong="H3046"\w* lo \w que|strong="H4101"\w* está en la oscuridad.
\q1 La \w luz|strong="H5094"\w* \w mora|strong="H8271"\w* \w con|strong="H5974"\w* \w Él|strong="H1932"\w*.
\q1 
\v 23 ¡\w A|strong="H3068"\w* ti, oh \nd ʼEloha\nd* \w de|strong="H4481"\w* mis antepasados,
\q1 Doy gracias y \w alabo|strong="H7624"\w*!
\q1 \w Pues|strong="H1768"\w* me diste \w sabiduría|strong="H2452"\w* y fortaleza,
\q1 \w Y|strong="H3068"\w* me revelaste lo \w que|strong="H1768"\w* te pedimos:
\q1 ¡Nos diste \w a|strong="H3068"\w* conocer el asunto \w del|strong="H4481"\w* \w rey|strong="H4430"\w*!
\p 
\v 24 \w Después|strong="H3606"\w* \w de|strong="H5922"\w* \w esto|strong="H1836"\w* \w Daniel|strong="H1841"\w* \w fue|strong="H5954"\w* \w a|strong="H3068"\w* Arioc, \w a|strong="H3068"\w* quien el \w rey|strong="H4430"\w* designó \w para|strong="H5922"\w* matar \w a|strong="H3068"\w* los \w sabios|strong="H2445"\w* \w de|strong="H5922"\w* Babilonia, y le dijo: No mates \w a|strong="H3068"\w* los \w sabios|strong="H2445"\w* \w de|strong="H5922"\w* Babilonia. \w Llévame|strong="H5954"\w* ante el \w rey|strong="H4430"\w*, y \w yo|strong="H1836"\w* le mostraré la interpretación del sueño.
\p 
\v 25 Arioc llevó prontamente \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* ante el \w rey|strong="H4430"\w* y le dijo: Hallé \w a|strong="H3068"\w* un varón \w de|strong="H4481"\w* los deportados \w de|strong="H4481"\w* \w Judá|strong="H3061"\w* \w que|strong="H1768"\w* puede dar la interpretación \w al|strong="H4481"\w* \w rey|strong="H4430"\w*.
\p 
\v 26 El \w rey|strong="H4430"\w* preguntó \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w*, \w a|strong="H3068"\w* quien \w llamaban|strong="H8036"\w* \w Beltsasar|strong="H1096"\w*: ¿\w Puedes|strong="H3546"\w* tú declararme el \w sueño|strong="H2493"\w* \w que|strong="H1768"\w* \w vi|strong="H2370"\w* y su interpretación?
\p 
\v 27 \w Daniel|strong="H1841"\w* \w respondió|strong="H6032"\w* al \w rey|strong="H4430"\w*: El \w misterio|strong="H7328"\w* \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* \w demanda|strong="H7593"\w* \w no|strong="H3809"\w* se lo pueden \w revelar|strong="H3202"\w* \w ni|strong="H3809"\w* \w sabios|strong="H2445"\w*, \w ni|strong="H3809"\w* astrólogos, \w ni|strong="H3809"\w* \w magos|strong="H2749"\w* \w ni|strong="H3809"\w* \w adivinos|strong="H1505"\w*.
\v 28 Pero \nd ʼElah\nd* existe \w en|strong="H5922"\w* los cielos, Quien \w revela|strong="H1541"\w* los misterios, Quien informa \w al|strong="H5922"\w* \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* lo \w que|strong="H1768"\w* acontecerá \w en|strong="H5922"\w* los últimos \w días|strong="H3118"\w*.
\p \w Este|strong="H1836"\w* fue tu \w sueño|strong="H2493"\w* y las visiones \w que|strong="H1768"\w* tuviste \w en|strong="H5922"\w* tu cama:
\v 29 \w Cuando|strong="H1768"\w* tú estabas \w en|strong="H5922"\w* tu cama, oh \w rey|strong="H4430"\w*, tus pensamientos se dirigieron hacia lo \w que|strong="H1768"\w* ocurrirá \w en|strong="H5922"\w* lo futuro. \w El|strong="H1934"\w* \w que|strong="H1768"\w* \w revela|strong="H1541"\w* misterios te mostró lo \w que|strong="H1768"\w* sucederá.
\v 30 \w A|strong="H3068"\w* mí me fue revelado el \w misterio|strong="H7328"\w*, \w no|strong="H3809"\w* \w porque|strong="H1768"\w* hay \w más|strong="H3861"\w* \w sabiduría|strong="H2452"\w* \w en|strong="H5922"\w* mí \w que|strong="H1768"\w* \w en|strong="H5922"\w* cualquier \w otro|strong="H3606"\w* humano, \w sino|strong="H3861"\w* \w para|strong="H5922"\w* \w que|strong="H1768"\w* se declare la interpretación \w al|strong="H5922"\w* \w rey|strong="H4430"\w* \w y|strong="H3809"\w* \w que|strong="H1768"\w* entiendas tus pensamientos.
\p 
\v 31 Tú mirabas, oh \w rey|strong="H4430"\w*, y ¡ahí estaba una \w estatua|strong="H6755"\w* colosal! Esta \w estatua|strong="H6755"\w* gigantesca, cuyo esplendor era muy sublime, estaba en pie ante ti. \w Su|strong="H1934"\w* aspecto era asombroso.
\v 32 La cabeza \w de|strong="H1768"\w* esta \w estatua|strong="H6755"\w* \w era|strong="H1932"\w* \w de|strong="H1768"\w* \w oro|strong="H1722"\w* fino, su pecho y sus brazos \w de|strong="H1768"\w* \w plata|strong="H3702"\w*, su vientre y sus muslos \w de|strong="H1768"\w* bronce,
\v 33 sus piernas \w de|strong="H4481"\w* \w hierro|strong="H6523"\w*, sus \w pies|strong="H7271"\w*, \w en|strong="H4481"\w* parte \w de|strong="H4481"\w* \w hierro|strong="H6523"\w* y \w en|strong="H4481"\w* parte \w de|strong="H4481"\w* barro cocido.
\v 34 Estabas mirando \w hasta|strong="H5705"\w* \w que|strong="H1768"\w* fue lanzada una piedra \w no|strong="H3809"\w* con manos. Golpeó \w a|strong="H3068"\w* la \w estatua|strong="H6755"\w* \w en|strong="H5922"\w* \w sus|strong="H1934"\w* \w pies|strong="H7271"\w* \w de|strong="H5922"\w* \w hierro|strong="H6523"\w* \w y|strong="H3809"\w* barro, \w y|strong="H3809"\w* \w los|strong="H1994"\w* \w desmenuzó|strong="H1855"\w*.
\p 
\v 35 Entonces \w fueron|strong="H1934"\w* desmenuzados juntamente \w el|strong="H1934"\w* \w hierro|strong="H6523"\w*, \w el|strong="H1934"\w* barro cocido, \w el|strong="H1934"\w* bronce, la \w plata|strong="H3702"\w* \w y|strong="H3809"\w* \w el|strong="H1934"\w* \w oro|strong="H1722"\w*. \w Fueron|strong="H1934"\w* como conchas \w de|strong="H4481"\w* grano trillado \w en|strong="H4481"\w* las eras \w de|strong="H4481"\w* verano \w que|strong="H1768"\w* \w el|strong="H1934"\w* viento arrebata \w sin|strong="H3809"\w* \w que|strong="H1768"\w* \w de|strong="H4481"\w* ellas quede algún rastro. Pero la piedra \w que|strong="H1768"\w* golpeó \w a|strong="H3068"\w* la \w estatua|strong="H6755"\w* se volvió una gran montaña \w que|strong="H1768"\w* llenó \w toda|strong="H3606"\w* la tierra.
\p 
\v 36 \w Éste|strong="H1836"\w* es el \w sueño|strong="H2493"\w*, y ahora diremos al \w rey|strong="H4430"\w* su interpretación:
\v 37 Tú, oh \w rey|strong="H4430"\w*, eres el \w rey|strong="H4430"\w* \w de|strong="H1768"\w* \w reyes|strong="H4430"\w*, \w a|strong="H3068"\w* quien el \nd ʼElah\nd* del \w cielo|strong="H8065"\w* te \w dio|strong="H3052"\w* el \w reino|strong="H4437"\w* y el poder, la fortaleza y el esplendor.
\v 38 \w Él|strong="H1932"\w* \w entregó|strong="H3052"\w* en tu \w mano|strong="H3028"\w* las \w bestias|strong="H2423"\w* del \w campo|strong="H1251"\w* y las aves del espacio dondequiera \w que|strong="H1768"\w* viven los \w hijos|strong="H1123"\w* \w de|strong="H1768"\w* hombres. Te \w dio|strong="H3052"\w* \w el|strong="H1932"\w* dominio sobre \w todo|strong="H3606"\w*. ¡Tú eres la cabeza \w de|strong="H1768"\w* \w oro|strong="H1722"\w*!
\p 
\v 39 \w Después|strong="H4481"\w* \w de|strong="H4481"\w* ti, se levantará \w otro|strong="H3606"\w* \w reino|strong="H4437"\w* inferior \w al|strong="H4481"\w* tuyo, y \w luego|strong="H4481"\w* un \w tercer|strong="H8523"\w* \w reino|strong="H4437"\w* \w de|strong="H4481"\w* bronce, el cual dominará sobre \w toda|strong="H3606"\w* la tierra.
\v 40 \w Como|strong="H6903"\w* \w el|strong="H1934"\w* \w hierro|strong="H6523"\w*, \w el|strong="H1934"\w* \w cuarto|strong="H7244"\w* \w reino|strong="H4437"\w* será \w fuerte|strong="H8624"\w*. \w El|strong="H1934"\w* \w hierro|strong="H6523"\w* \w desmenuza|strong="H1855"\w* y rompe \w todas|strong="H3606"\w* las cosas. Así \w desmenuzará|strong="H1855"\w* y quebrantará \w todo|strong="H3606"\w*.
\v 41 Lo \w que|strong="H1768"\w* \w viste|strong="H2370"\w* \w de|strong="H4481"\w* los \w pies|strong="H7271"\w* y los dedos, \w en|strong="H4481"\w* parte \w de|strong="H4481"\w* barro cocido \w de|strong="H4481"\w* alfarero y \w en|strong="H4481"\w* parte \w de|strong="H4481"\w* \w hierro|strong="H6523"\w*, representan un \w reino|strong="H4437"\w* dividido. Pero habrá \w en|strong="H4481"\w* \w él|strong="H1934"\w* algo \w de|strong="H4481"\w* la solidez \w del|strong="H4481"\w* \w hierro|strong="H6523"\w*, según \w viste|strong="H2370"\w* \w el|strong="H1934"\w* \w hierro|strong="H6523"\w* \w mezclado|strong="H6151"\w* con \w el|strong="H1934"\w* barro cocido.
\v 42 \w Por|strong="H4481"\w* ser los dedos \w de|strong="H4481"\w* los \w pies|strong="H7271"\w* \w en|strong="H4481"\w* parte \w de|strong="H4481"\w* \w hierro|strong="H6523"\w* y \w en|strong="H4481"\w* parte \w de|strong="H4481"\w* barro cocido, \w el|strong="H1934"\w* \w reino|strong="H4437"\w* será \w en|strong="H4481"\w* parte \w fuerte|strong="H8624"\w* y \w en|strong="H4481"\w* parte débil.
\v 43 Según \w viste|strong="H2370"\w* \w el|strong="H1934"\w* \w hierro|strong="H6523"\w* \w mezclado|strong="H6151"\w* \w con|strong="H5974"\w* \w el|strong="H1934"\w* barro, se mezclarán \w por|strong="H1768"\w* medio \w de|strong="H1768"\w* alianzas humanas, pero \w no|strong="H3809"\w* se unirán \w el|strong="H1934"\w* uno \w con|strong="H5974"\w* \w el|strong="H1934"\w* otro, como \w el|strong="H1934"\w* \w hierro|strong="H6523"\w* \w no|strong="H3809"\w* se mezcla \w con|strong="H5974"\w* \w el|strong="H1934"\w* barro.
\p 
\v 44 En los \w días|strong="H3118"\w* \w de|strong="H1768"\w* estos \w reyes|strong="H4430"\w*, \w el|strong="H1932"\w* \nd ʼElah\nd* del \w cielo|strong="H8065"\w* establecerá un \w reino|strong="H4437"\w* \w que|strong="H1768"\w* jamás será destruido, \w ni|strong="H3809"\w* será dejado \w a|strong="H3068"\w* \w otro|strong="H3606"\w* \w pueblo|strong="H5972"\w*, sino \w que|strong="H1768"\w* \w desmenuzará|strong="H1855"\w* \w y|strong="H3809"\w* consumirá \w a|strong="H3068"\w* \w todos|strong="H3606"\w* estos \w reinos|strong="H4437"\w*. Pero \w él|strong="H1932"\w* \w permanecerá|strong="H6966"\w* para siempre,
\v 45 tal \w como|strong="H6903"\w* \w viste|strong="H2370"\w* \w que|strong="H1768"\w* una piedra fue lanzada \w de|strong="H1768"\w* la montaña \w no|strong="H3809"\w* con \w mano|strong="H3028"\w*, la cual \w desmenuzó|strong="H1855"\w* \w el|strong="H1934"\w* \w hierro|strong="H6523"\w*, \w el|strong="H1934"\w* bronce, \w el|strong="H1934"\w* barro, la \w plata|strong="H3702"\w* \w y|strong="H3809"\w* \w el|strong="H1934"\w* \w oro|strong="H1722"\w*. \w El|strong="H1934"\w* gran \nd ʼElah\nd* mostró al \w rey|strong="H4430"\w* lo \w que|strong="H1768"\w* \w va|strong="H3068"\w* \w a|strong="H3068"\w* suceder en lo futuro. \w El|strong="H1934"\w* \w sueño|strong="H2493"\w* es verdadero, \w y|strong="H3809"\w* \w su|strong="H1934"\w* interpretación es fiel.
\p 
\v 46 Entonces el \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* se postró, hizo reverencia \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* y mandó \w que|strong="H5922"\w* le ofrecieran \w presentes|strong="H4504"\w* \w e|strong="H3068"\w* incienso.
\v 47 \w Y|strong="H3068"\w* \w el|strong="H1932"\w* \w rey|strong="H4430"\w* \w habló|strong="H6032"\w* \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w*: ¡\w Ciertamente|strong="H7187"\w* tu \nd ʼElah\nd* es un \nd ʼElah\nd* \w de|strong="H4481"\w* \tl ʼelahs,\tl* \nd ʼAdón\nd* \w de|strong="H4481"\w* \w reyes|strong="H4430"\w* y revelador \w de|strong="H4481"\w* misterios, \w pues|strong="H1768"\w* pudiste \w revelar|strong="H3202"\w* \w este|strong="H1836"\w* \w misterio|strong="H7328"\w*!
\p 
\v 48 Entonces el \w rey|strong="H4430"\w* promovió \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w*, le \w dio|strong="H3052"\w* muchos presentes \w grandes|strong="H7260"\w* y lo constituyó gobernador \w de|strong="H5922"\w* \w toda|strong="H3606"\w* la provincia \w de|strong="H5922"\w* Babilonia y jefe \w de|strong="H5922"\w* \w todos|strong="H3606"\w* los \w sabios|strong="H2445"\w* \w de|strong="H5922"\w* Babilonia.
\v 49 Entonces \w Daniel|strong="H1841"\w* \w solicitó|strong="H1156"\w* \w del|strong="H4481"\w* \w rey|strong="H4430"\w* y obtuvo \w que|strong="H1768"\w* designara \w a|strong="H3068"\w* Sadrac, Mesac y Abed-nego como jefes \w de|strong="H4481"\w* la administración \w de|strong="H4481"\w* la provincia \w de|strong="H4481"\w* Babilonia, pero \w Daniel|strong="H1841"\w* permaneció \w en|strong="H5922"\w* la corte \w del|strong="H4481"\w* \w rey|strong="H4430"\w*.
\c 3
\s1 La altivez de Nabucodonosor
\p 
\v 1 El \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* \w hizo|strong="H5648"\w* \w una|strong="H5648"\w* \w estatua|strong="H6755"\w* \w de|strong="H1768"\w* \w oro|strong="H1722"\w* \w de|strong="H1768"\w* 27 metros \w de|strong="H1768"\w* \w altura|strong="H7314"\w* y 2,7 metros \w de|strong="H1768"\w* anchura. La levantó en la llanura \w de|strong="H1768"\w* Dura en la provincia \w de|strong="H1768"\w* Babilonia.
\v 2 El \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* ordenó \w que|strong="H1768"\w* se reunieran los \tl sátrapas\tl*, prefectos, gobernadores, jueces, tesoreros, consejeros, \w magistrados|strong="H5460"\w* y \w todos|strong="H3606"\w* los altos funcionarios \w de|strong="H1768"\w* las provincias para \w que|strong="H1768"\w* fueran \w a|strong="H3068"\w* la consagración \w de|strong="H1768"\w* la \w estatua|strong="H6755"\w* \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* levantó.
\v 3 Los \tl sátrapas\tl*, prefectos, gobernadores, jueces, tesoreros, consejeros, \w magistrados|strong="H5460"\w* y \w todos|strong="H3606"\w* los altos funcionarios \w de|strong="H1768"\w* las provincias fueron \w reunidos|strong="H3673"\w* para la consagración \w de|strong="H1768"\w* la \w estatua|strong="H6755"\w* \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* hizo. Se presentaron ante la \w estatua|strong="H6755"\w* \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* levantó.
\p 
\v 4 Entonces el heraldo pregonó \w a|strong="H3068"\w* gran voz: Pueblos, naciones y lenguas:
\v 5 ¡Se ordena \w que|strong="H1768"\w* al oír el son \w de|strong="H1768"\w* la corneta, el silbato, el tamboril, el arpa, el salterio, la zampoña y \w todo|strong="H3606"\w* \w instrumento|strong="H2178"\w* \w de|strong="H1768"\w* música, se postren y adoren la \w estatua|strong="H6755"\w* \w de|strong="H1768"\w* \w oro|strong="H1722"\w* \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* levantó!
\v 6 ¡El \w que|strong="H1768"\w* \w no|strong="H3809"\w* se postre en adoración será echado \w dentro|strong="H1459"\w* \w de|strong="H1768"\w* un horno \w de|strong="H1768"\w* \w fuego|strong="H5135"\w* ardiente en la misma \w hora|strong="H8160"\w*!
\p 
\v 7 \w Por|strong="H1768"\w* lo cual, al momento \w cuando|strong="H1768"\w* los diversos pueblos oyeron el son \w de|strong="H1768"\w* la corneta, el silbato, el tamboril, el arpa, el salterio, la zampoña y \w todo|strong="H3606"\w* \w instrumento|strong="H2178"\w* \w de|strong="H1768"\w* música, los pueblos \w de|strong="H1768"\w* \w toda|strong="H3606"\w* nación y lengua se postraron y adoraron la \w estatua|strong="H6755"\w* \w de|strong="H1768"\w* \w oro|strong="H1722"\w* \w que|strong="H1768"\w* el \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w* levantó.
\p 
\v 8 Con tal motivo, \w algunos|strong="H1400"\w* \w varones|strong="H1400"\w* \w caldeos|strong="H3779"\w* llegaron en aquel momento y acusaron maliciosamente \w a|strong="H3068"\w* los \w judíos|strong="H3062"\w*.
\v 9 Pidieron la palabra y dijeron al \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w*: ¡Oh \w rey|strong="H4430"\w*, \w vive|strong="H2418"\w* para siempre!
\v 10 Tú, oh \w rey|strong="H4430"\w*, decretaste \w que|strong="H1768"\w* \w todo|strong="H3606"\w* hombre \w que|strong="H1768"\w* oiga el son \w de|strong="H1768"\w* la corneta, el silbato, el tamboril, el arpa, el salterio, la zampoña y \w todo|strong="H3606"\w* \w instrumento|strong="H2178"\w* \w de|strong="H1768"\w* música, se postre y adore la \w estatua|strong="H6755"\w* \w de|strong="H1768"\w* \w oro|strong="H1722"\w*,
\v 11 \w y|strong="H3809"\w* el \w que|strong="H1768"\w* \w no|strong="H3809"\w* se postre en adoración sea echado \w dentro|strong="H1459"\w* del horno \w de|strong="H1768"\w* \w fuego|strong="H5135"\w* ardiente.
\v 12 Pero hay ciertos \w varones|strong="H1400"\w* \w judíos|strong="H3062"\w* \w a|strong="H3068"\w* quienes encomendaste la administración \w de|strong="H5922"\w* la provincia \w de|strong="H5922"\w* Babilonia: Sadrac, Mesac \w y|strong="H3809"\w* Abed-nego. Estos \w hombres|strong="H1400"\w*, oh \w rey|strong="H4430"\w*, \w no|strong="H3809"\w* te prestan atención, \w ni|strong="H3809"\w* \w adoran|strong="H6399"\w* \w a|strong="H3068"\w* tus \tl ʼelahs\tl*, \w ni|strong="H3809"\w* \w adoran|strong="H6399"\w* la \w estatua|strong="H6755"\w* \w de|strong="H5922"\w* \w oro|strong="H1722"\w* \w que|strong="H1768"\w* tú levantaste.
\p 
\v 13 Entonces \w Nabucodonosor|strong="H5020"\w*, con cólera y furor, mandó traer \w a|strong="H3068"\w* Sadrac, Mesac y Abed-nego, los cuales fueron llevados de inmediato ante el \w rey|strong="H4430"\w*.
\v 14 \w Nabucodonosor|strong="H5020"\w* tomó la palabra \w y|strong="H3809"\w* les dijo: Sadrac, Mesac \w y|strong="H3809"\w* Abed-nego: ¿Es verdad \w que|strong="H1768"\w* ustedes \w no|strong="H3809"\w* rinden culto \w a|strong="H3068"\w* mis \tl ʼelahs\tl*, \w ni|strong="H3809"\w* \w adoran|strong="H6399"\w* la \w estatua|strong="H6755"\w* \w de|strong="H1768"\w* \w oro|strong="H1722"\w* \w que|strong="H1768"\w* levanté?
\v 15 \w Ahora|strong="H3705"\w* \w pues|strong="H1768"\w*, \w si|strong="H2006"\w* \w al|strong="H4481"\w* oír \w el|strong="H1932"\w* son \w de|strong="H4481"\w* la corneta, \w el|strong="H1932"\w* silbato, \w el|strong="H1932"\w* tamboril, \w el|strong="H1932"\w* arpa, \w el|strong="H1932"\w* salterio, la zampoña \w y|strong="H3809"\w* \w todo|strong="H3606"\w* \w instrumento|strong="H2178"\w* \w de|strong="H4481"\w* música, están dispuestos \w a|strong="H3068"\w* postrarse \w en|strong="H4481"\w* adoración ante la \w estatua|strong="H6755"\w* \w que|strong="H1768"\w* hice, les irá bien. Pero \w si|strong="H2006"\w* \w no|strong="H3809"\w* la \w adoran|strong="H5457"\w* serán echados \w en|strong="H4481"\w* \w medio|strong="H1459"\w* \w del|strong="H4481"\w* horno \w de|strong="H4481"\w* \w fuego|strong="H5135"\w* ardiente \w en|strong="H4481"\w* la misma \w hora|strong="H8160"\w*. ¿\w Y|strong="H3068"\w* cuál \tl ʼelah\tl* los podrá \w librar|strong="H7804"\w* \w de|strong="H4481"\w* mis manos?
\p 
\v 16 Entonces Sadrac, Mesac \w y|strong="H3809"\w* Abed-nego \w respondieron|strong="H6032"\w* \w al|strong="H5922"\w* \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w*: \w No|strong="H3809"\w* necesitamos responderte con respecto \w a|strong="H3068"\w* \w este|strong="H1836"\w* asunto.
\v 17 ¡\w Si|strong="H2006"\w* es así, nuestro \nd ʼElah\nd* \w a|strong="H3068"\w* Quien servimos, \w puede|strong="H3202"\w* librarnos! Él \w tiene|strong="H1768"\w* \w poder|strong="H3028"\w*, oh \w rey|strong="H4430"\w*, para librarnos \w del|strong="H4481"\w* horno \w de|strong="H4481"\w* \w fuego|strong="H5135"\w* ardiente y nos librará \w de|strong="H4481"\w* tu \w mano|strong="H3028"\w*.
\v 18 \w Y|strong="H3068"\w* aunque \w no|strong="H3809"\w* lo haga, oh \w rey|strong="H4430"\w*, entiende \w que|strong="H1768"\w* tampoco rendiremos culto \w a|strong="H3068"\w* tus \tl ʼelahs\tl*, \w ni|strong="H3809"\w* nos postraremos ante la \w estatua|strong="H6755"\w* \w de|strong="H1768"\w* \w oro|strong="H1722"\w* \w que|strong="H1768"\w* levantaste.
\p 
\v 19 Entonces \w Nabucodonosor|strong="H5020"\w*, con el rostro alterado y lleno \w de|strong="H5922"\w* furia \w contra|strong="H5922"\w* Sadrac, Mesac y Abed-nego, ordenó \w que|strong="H1768"\w* el horno fuera calentado siete \w veces|strong="H2298"\w* más \w de|strong="H5922"\w* lo acostumbrado.
\v 20 Mandó \w a|strong="H3068"\w* \w algunos|strong="H1400"\w* valientes guerreros \w de|strong="H1768"\w* su ejército \w que|strong="H1768"\w* ataran \w a|strong="H3068"\w* Sadrac, Mesac y Abed-nego, y los echaran al horno \w de|strong="H1768"\w* \w fuego|strong="H5135"\w* ardiente.
\v 21 Entonces estos \w hombres|strong="H1400"\w* fueron \w atados|strong="H3729"\w* con sus calzones, sus túnicas, sus turbantes y sus mantos, y fueron echados en \w medio|strong="H1459"\w* del horno de \w fuego|strong="H5135"\w* ardiente.
\v 22 \w Como|strong="H6903"\w* la orden \w del|strong="H4481"\w* \w rey|strong="H4430"\w* era apremiante, y el horno estaba demasiado caliente, las llamas quemaron \w a|strong="H3068"\w* \w los|strong="H1994"\w* \w hombres|strong="H1400"\w* \w que|strong="H1768"\w* lanzaron \w a|strong="H3068"\w* Sadrac, Mesac y Abed-nego
\v 23 mientras los \w tres|strong="H8532"\w* \w varones|strong="H1400"\w*, Sadrac, Mesac y Abed-nego, caían \w atados|strong="H3729"\w* \w dentro|strong="H1459"\w* del horno de \w fuego|strong="H5135"\w* ardiente.
\p 
\v 24 Entonces el \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w*, estupefacto, se levantó de repente \w y|strong="H3809"\w* preguntó \w a|strong="H3068"\w* sus altos oficiales: ¿\w No|strong="H3809"\w* fueron \w tres|strong="H8532"\w* los \w varones|strong="H1400"\w* que cayeron \w atados|strong="H3729"\w* \w dentro|strong="H1459"\w* del \w fuego|strong="H5135"\w*?
\p Ellos \w respondieron|strong="H6032"\w* al \w rey|strong="H4430"\w*: \w Ciertamente|strong="H3330"\w*, oh \w rey|strong="H4430"\w*.
\p 
\v 25 Pero él \w respondió|strong="H6032"\w*: ¡Miren! Veo \w a|strong="H3068"\w* cuatro \w varones|strong="H1400"\w* \w sueltos|strong="H8271"\w* \w que|strong="H1768"\w* se pasean en \w medio|strong="H1459"\w* del \w fuego|strong="H5135"\w* \w sin|strong="H3809"\w* sufrir algún daño, \w y|strong="H3809"\w* el aspecto del \w cuarto|strong="H7244"\w* es \w semejante|strong="H1821"\w* \w a|strong="H3068"\w* un \w hijo|strong="H1247"\w* \w de|strong="H1768"\w* los \tl ʼelahs\tl*.
\p 
\v 26 \w Nabucodonosor|strong="H5020"\w* se acercó \w a|strong="H3068"\w* la puerta \w del|strong="H4481"\w* horno \w de|strong="H4481"\w* \w fuego|strong="H5135"\w* ardiente y gritó: ¡Sadrac, Mesac y Abed-nego, esclavos \w del|strong="H4481"\w* \nd ʼElah\nd* Altísimo, salgan y vengan!
\p \w Y|strong="H3068"\w* Sadrac, Mesac y Abed-nego \w salieron|strong="H5312"\w* \w de|strong="H4481"\w* \w en|strong="H4481"\w* \w medio|strong="H1459"\w* \w del|strong="H4481"\w* \w fuego|strong="H5135"\w*.
\v 27 Los \tl sátrapas\tl*, prefectos, gobernadores \w y|strong="H3809"\w* altos oficiales del \w rey|strong="H4430"\w* se reunieron alrededor \w y|strong="H3809"\w* vieron \w que|strong="H1768"\w* el \w fuego|strong="H5135"\w* \w no|strong="H3809"\w* hizo daño \w a|strong="H3068"\w* aquellos \w varones|strong="H1400"\w*. \w Ni|strong="H3809"\w* siquiera los cabellos \w de|strong="H1768"\w* sus \w cabezas|strong="H7217"\w* estaban chamuscados, sus ropas estaban intactas \w y|strong="H3809"\w* \w no|strong="H3809"\w* tenían \w olor|strong="H7382"\w* \w de|strong="H1768"\w* \w fuego|strong="H5135"\w*.
\p 
\v 28 Entonces \w Nabucodonosor|strong="H5020"\w* exclamó: ¡\w Bendito|strong="H1289"\w* sea el \nd ʼElah\nd* \w de|strong="H5922"\w* Sadrac, Mesac \w y|strong="H3809"\w* Abed-nego, \w que|strong="H1768"\w* \w envió|strong="H7972"\w* su Ángel \w y|strong="H3809"\w* libró \w a|strong="H3068"\w* sus esclavos \w que|strong="H1768"\w* confiaron \w en|strong="H5922"\w* Él, \w y|strong="H3809"\w* \w no|strong="H3809"\w* cumplieron el edicto del \w rey|strong="H4430"\w*! ¡Prefirieron entregar sus cuerpos \w que|strong="H1768"\w* servir \w y|strong="H3809"\w* adorar \w a|strong="H3068"\w* \w otro|strong="H3606"\w* \tl ʼelah\tl* \w que|strong="H1768"\w* \w no|strong="H3809"\w* era su \nd ʼElah\nd*!
\v 29 Decreto, \w pues|strong="H1768"\w*, \w que|strong="H1768"\w* \w todo|strong="H3606"\w* \w pueblo|strong="H5972"\w*, nación \w o|strong="H3068"\w* lengua \w que|strong="H1768"\w* pronuncie \w blasfemia|strong="H1768"\w* \w contra|strong="H5922"\w* el \nd ʼElah\nd* \w de|strong="H4481"\w* Sadrac, Mesac \w y|strong="H3809"\w* Abed-nego, sea descuartizado \w y|strong="H3809"\w* su \w casa|strong="H1005"\w* convertida \w en|strong="H5922"\w* \w muladar|strong="H5122"\w*, \w por|strong="H4481"\w* cuanto \w no|strong="H3809"\w* hay \tl ʼelah\tl* \w como|strong="H6903"\w* \w Éste|strong="H1836"\w* \w que|strong="H1768"\w* \w pueda|strong="H3202"\w* \w librar|strong="H5338"\w*.
\p 
\v 30 El \w rey|strong="H4430"\w* \w engrandeció|strong="H6744"\w* \w a|strong="H3068"\w* Sadrac, Mesac y Abed-nego en la provincia de Babilonia.
\c 4
\s1 Proclama real
\p 
\v 1 \w El|strong="H1934"\w* rey \w Nabucodonosor|strong="H5020"\w* \w a|strong="H3068"\w* todos los pueblos, naciones y lenguas que viven en toda la tierra: ¡Que abunde \w su|strong="H1934"\w* paz!
\v 2 Conviene \w que|strong="H5922"\w* yo publique las señales y prodigios \w que|strong="H5922"\w* el Altísimo \nd ʼElah\nd* hizo conmigo.
\p 
\v 3 ¡Cuán grandes son sus señales y cuán potentes sus maravillas! ¡Su reino es sempiterno y su señorío \w de|strong="H4481"\w* generación \w en|strong="H4481"\w* generación!
\s1 El gran árbol
\p 
\v 4 Yo, Nabucodonosor, estaba tranquilo en \w mi|strong="H6925"\w* casa \w y|strong="H3809"\w* floreciente en \w mi|strong="H6925"\w* palacio.
\v 5 Vi un \w sueño|strong="H2493"\w* \w que|strong="H1768"\w* me espantó. Tendido \w en|strong="H5705"\w* cama, me turbaron las imaginaciones y visiones \w de|strong="H1768"\w* \w mi|strong="H6925"\w* cabeza.
\v 6 \w Por|strong="H1768"\w* esto mandé \w que|strong="H1768"\w* \w todos|strong="H3606"\w* los sabios \w de|strong="H1768"\w* Babilonia vinieran ante mí para \w que|strong="H1768"\w* me mostraran la interpretación del \w sueño|strong="H2493"\w*.
\v 7 Magos, astrólogos, caldeos y adivinos llegaron, y relaté \w el|strong="H1934"\w* sueño \w delante|strong="H5922"\w* \w de|strong="H5922"\w* ellos. Pero no me pudieron mostrar \w su|strong="H1934"\w* interpretación
\v 8 hasta que se presentó ante mí Daniel, cuyo nombre es Beltsasar, como el nombre de mi \tl ʼelah\tl*, y en quien vive el Espíritu del \nd ʼElah\nd* santo. \w Y|strong="H3068"\w* relaté mi sueño \w a|strong="H3068"\w* él:
\p 
\v 9 Beltsasar, jefe \w de|strong="H4481"\w* los magos, ya \w que|strong="H4481"\w* entendí \w que|strong="H4481"\w* el Espíritu \w del|strong="H4481"\w* \nd ʼElah\nd* santo está \w en|strong="H4481"\w* ti, y \w que|strong="H4481"\w* \w ningún|strong="H3606"\w* misterio se te esconde, escucha las visiones \w del|strong="H4481"\w* sueño \w que|strong="H4481"\w* tuve y declárame su interpretación.
\v 10 Éstas \w fueron|strong="H1934"\w* las visiones \w de|strong="H4481"\w* mi cabeza \w cuando|strong="H4481"\w* me hallaba \w en|strong="H5922"\w* mi lecho: Miré y ahí estaba \w en|strong="H5922"\w* medio \w de|strong="H4481"\w* la tierra un árbol \w cuya|strong="H1934"\w* altura era enorme.
\v 11 El árbol crecía y se fortalecía. Su altura llegaba hasta el cielo y su extensión hasta el fin \w de|strong="H4481"\w* toda la tierra.
\v 12 Su follaje era hermoso, su fruto abundante y había alimento para todos en él. Las \w bestias|strong="H2423"\w* del \w campo|strong="H1251"\w* hallaban abrigo debajo \w de|strong="H1768"\w* él, y las aves del \w cielo|strong="H8065"\w* moraban en sus ramas. Todo ser viviente se alimentaba \w de|strong="H1768"\w* él.
\p 
\v 13 Mientras estaba \w en|strong="H5922"\w* mi cama yo miraba \w en|strong="H5922"\w* las visiones \w de|strong="H4481"\w* mi cabeza. Vi \w a|strong="H3068"\w* un vigilante santo \w que|strong="H4481"\w* descendía \w del|strong="H4481"\w* cielo
\v 14 y clamó \w a|strong="H3068"\w* gran voz: ¡Corten el árbol y quítenle sus ramas. Sacudan su follaje y desprendan su fruto. Váyanse las bestias \w que|strong="H1768"\w* están debajo \w de|strong="H5922"\w* él, y las aves \w de|strong="H5922"\w* sus ramas!
\v 15 Pero dejen el tronco con sus raíces en la tierra, con ligaduras \w de|strong="H1768"\w* hierro \w y|strong="H3809"\w* bronce entre la hierba del campo. Sea mojado con el rocío del cielo, \w y|strong="H3809"\w* comparta la hierba \w de|strong="H1768"\w* la tierra con las bestias.
\v 16 Sea cambiada su mente \w de|strong="H1768"\w* hombre, \w que|strong="H1768"\w* se le \w dé|strong="H1768"\w* instinto \w de|strong="H1768"\w* bestia y pasen siete tiempos sobre él.
\p 
\v 17 La sentencia es \w por|strong="H1768"\w* decreto \w de|strong="H1768"\w* los vigilantes y la decisión \w por|strong="H1768"\w* la palabra \w de|strong="H1768"\w* los santos, para \w que|strong="H1768"\w* los vivientes reconozcan \w que|strong="H1768"\w* el Altísimo domina sobre el reino \w de|strong="H1768"\w* los hombres, Quien lo da al \w que|strong="H1768"\w* le place y pone al más humilde \w de|strong="H1768"\w* los hombres sobre él.
\p 
\v 18 Yo, el rey Nabucodonosor, tuve este sueño. \w Y|strong="H3068"\w* tú, Beltsasar, declárame su interpretación, \w porque|strong="H3606"\w* ninguno de los sabios de mi reino puede darme su interpretación. Pero tú sí puedes, \w porque|strong="H3606"\w* en ti está el Espíritu de los \tl ʼelahs\tl* santos.
\s1 Interpretación
\p 
\v 19 Pero Daniel, \w cuyo|strong="H1768"\w* nombre es Beltsasar, quedó pasmado un buen rato, y sus pensamientos lo turbaron. Entonces el \w rey|strong="H4430"\w* habló: Beltsasar, no te turbe el sueño ni su interpretación.
\p Beltsasar respondió: \tl ʼadón\tl* mío, sea este sueño para los \w que|strong="H1768"\w* te aborrecen, y su interpretación para tus enemigos.
\v 20 El árbol \w que|strong="H1768"\w* \w viste|strong="H2370"\w*, \w que|strong="H1768"\w* crecía y se fortalecía, \w cuya|strong="H1768"\w* altura llegaba \w al|strong="H5922"\w* \w cielo|strong="H8065"\w* y era visible \w en|strong="H5922"\w* toda la tierra,
\v 21 \w cuyo|strong="H1768"\w* follaje \w era|strong="H1932"\w* hermoso y su fruto abundante, \w en|strong="H5922"\w* \w el|strong="H1932"\w* cual había alimento \w para|strong="H5922"\w* todos, debajo del cual vivían las bestias del campo, y \w en|strong="H5922"\w* cuyas ramas anidaban las aves del cielo,
\v 22 eres tú, oh rey. Creciste y te fortaleciste, \w pues|strong="H1768"\w* tu grandeza creció \w hasta|strong="H5705"\w* llegar \w al|strong="H5922"\w* \w cielo|strong="H8065"\w* y tu dominio \w hasta|strong="H5705"\w* \w el|strong="H1934"\w* fin \w de|strong="H4481"\w* la tierra.
\p 
\v 23 \w En|strong="H4481"\w* cuanto \w a|strong="H3068"\w* lo \w que|strong="H1768"\w* vio el rey, un vigilante santo \w que|strong="H1768"\w* descendía \w del|strong="H4481"\w* \w cielo|strong="H8065"\w* y decía: Corten el árbol y destrúyanlo. Sin embargo, dejen el tronco con sus raíces \w en|strong="H4481"\w* la tierra, pero atado con ligaduras \w de|strong="H4481"\w* hierro y bronce entre la hierba \w del|strong="H4481"\w* campo y sea mojado con el rocío \w del|strong="H4481"\w* \w cielo|strong="H8065"\w*. Comparta con las bestias \w del|strong="H4481"\w* campo, hasta \w que|strong="H1768"\w* pasen sobre él siete tiempos.
\p 
\v 24 \w Ésta|strong="H2006"\w* es la interpretación, oh \w rey|strong="H4430"\w*, y la sentencia del Altísimo, \w que|strong="H3861"\w* vino \w sobre|strong="H5922"\w* mi \tl ʼadón\tl*, \w el|strong="H1934"\w* \w rey|strong="H4430"\w*:
\v 25 Te echarán \w de|strong="H5922"\w* entre los hombres. Tu morada será con las bestias del campo. Con hierba del campo te apacentarán como \w a|strong="H3068"\w* los bueyes, y con el rocío del cielo serás mojado. Pasarán siete tiempos \w sobre|strong="H5922"\w* ti, hasta \w que|strong="H5922"\w* reconozcas \w que|strong="H5922"\w* el Altísimo tiene dominio \w sobre|strong="H5922"\w* el reino \w de|strong="H5922"\w* los hombres, y \w que|strong="H5922"\w* lo da \w a|strong="H3068"\w* quien Él quiere.
\v 26 \w En|strong="H5922"\w* cuanto \w a|strong="H3068"\w* la orden \w de|strong="H5922"\w* dejar \w el|strong="H1934"\w* tronco del árbol con \w sus|strong="H1934"\w* raíces \w en|strong="H5922"\w* la tierra, significa \w que|strong="H1768"\w* tu \w reino|strong="H4437"\w* te quedará firme, después \w que|strong="H1768"\w* reconozcas \w que|strong="H1768"\w* \w el|strong="H1934"\w* cielo gobierna.
\v 27 \w Por|strong="H1768"\w* tanto, oh \w rey|strong="H4430"\w*, acepta mi consejo: redime tus pecados con justicia \w y|strong="H3809"\w* borra tus iniquidades al mostrar misericordias \w a|strong="H3068"\w* los oprimidos. Tal vez esto sea \w una|strong="H1932"\w* prolongación \w de|strong="H1768"\w* tu prosperidad.
\s1 Cumplimiento
\p 
\v 28 Todo esto le llegó \w al|strong="H4481"\w* \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w*.
\v 29 Doce meses \w después|strong="H4481"\w*, el rey paseaba \w en|strong="H5922"\w* el palacio real \w de|strong="H4481"\w* Babilonia
\v 30 y dijo: ¿No es ésta la gran Babilonia \w que|strong="H1768"\w* \w yo|strong="H5403"\w* mismo edifiqué \w para|strong="H5922"\w* residencia real con la fuerza \w de|strong="H4481"\w* mi poder \w para|strong="H5922"\w* el esplendor \w de|strong="H4481"\w* mi majestad?
\v 31 Aún estaban estas palabras \w en|strong="H5922"\w* la boca del rey, \w cuando|strong="H1768"\w* una voz vino del \w cielo|strong="H8065"\w*: \wj Rey \w Nabucodonosor|strong="H5020"\w*, \w a|strong="H3068"\w* ti se te habla. El \w reino|strong="H4437"\w* te es quitado.\wj*
\v 32 \wj Serás apartado \w de|strong="H1768"\w* los hombres, \w y|strong="H3809"\w* tu morada será con las bestias del campo. Te apacentarán como \w a|strong="H3068"\w* los bueyes. Siete tiempos pasarán sobre ti, hasta \w que|strong="H1768"\w* reconozcas \w que|strong="H1768"\w* el Altísimo gobierna en el reino \w de|strong="H1768"\w* los hombres \w y|strong="H3809"\w* lo da \w a|strong="H3068"\w* quien le place. \wj*
\p 
\v 33 \w En|strong="H5922"\w* la misma hora se cumplió la Palabra \w sobre|strong="H5922"\w* Nabucodonosor, y fue apartado \w de|strong="H5922"\w* entre los hombres. Comía hierba como los bueyes. Su cuerpo se mojaba con el rocío del cielo hasta \w que|strong="H5922"\w* su pelo creció como plumas \w de|strong="H5922"\w* águila, y sus uñas como las \w de|strong="H5922"\w* las aves.
\p 
\v 34 Pero al fin del tiempo, yo, \w Nabucodonosor|strong="H5020"\w*, alcé mis ojos al \w cielo|strong="H8065"\w*, y mi razón me fue devuelta. Entonces bendije al Altísimo. Alabé y glorifiqué al \w que|strong="H1768"\w* vive para siempre, \w cuyo|strong="H1768"\w* dominio es sempiterno y su reino \w por|strong="H1768"\w* \w todas|strong="H3606"\w* las edades.
\v 35 Todos los habitantes de la tierra son considerados como nada. Él hace lo que quiere en la hueste del cielo y en los habitantes de la tierra. No hay quien detenga su mano y le pregunte: ¿Qué haces?
\p 
\v 36 En el mismo tiempo me fue devuelta mi razón y la majestad de mi reino. Mi dignidad y mi grandeza volvieron \w a|strong="H3068"\w* mí, y mis consejeros y mis nobles comenzaron \w a|strong="H3068"\w* buscarme. Fui restablecido en mi soberanía, y me fue añadida una extraordinaria grandeza.
\p 
\v 37 Ahora yo, Nabucodonosor, alabo, engrandezco y glorifico al Rey del cielo, porque todas sus obras son verdaderas y sus caminos justos. Él puede humillar \w a|strong="H3068"\w* los que andan con altivez.
\c 5
\s1 Belsasar
\p 
\v 1 El \w rey|strong="H4430"\w* \w Belsasar|strong="H1113"\w* \w hizo|strong="H5648"\w* un gran \w banquete|strong="H3900"\w* para 1.000 de sus dignatarios y \w bebía|strong="H8355"\w* \w vino|strong="H2562"\w* en presencia de los 1.000.
\p 
\v 2 Con el efecto \w del|strong="H4481"\w* \w vino|strong="H2562"\w*, \w Belsasar|strong="H1113"\w* mandó traer los \w vasos|strong="H3984"\w* \w de|strong="H4481"\w* \w oro|strong="H1722"\w* y \w de|strong="H4481"\w* \w plata|strong="H3702"\w* \w que|strong="H1768"\w* \w Nabucodonosor|strong="H5020"\w*, su padre, \w sacó|strong="H5312"\w* \w del|strong="H4481"\w* \w Templo|strong="H1965"\w* \w de|strong="H4481"\w* Jerusalén para \w que|strong="H1768"\w* el \w rey|strong="H4430"\w*, sus dignatarios, sus esposas y sus \w concubinas|strong="H3904"\w* bebieran \w en|strong="H4481"\w* \w ellos|strong="H4481"\w*.
\v 3 Entonces le llevaron los \w vasos|strong="H3984"\w* \w de|strong="H4481"\w* \w oro|strong="H1722"\w* \w que|strong="H1768"\w* sacaron \w del|strong="H4481"\w* Santuario \w del|strong="H4481"\w* \w Templo|strong="H1965"\w* \w del|strong="H4481"\w* \nd ʼElah\nd* \w de|strong="H4481"\w* Jerusalén. \w Y|strong="H3068"\w* el \w rey|strong="H4430"\w*, sus dignatarios, sus esposas y sus \w concubinas|strong="H3904"\w* \w bebieron|strong="H8355"\w* \w en|strong="H4481"\w* \w ellos|strong="H4481"\w*.
\v 4 \w Bebieron|strong="H8355"\w* \w vino|strong="H2562"\w* y alabaron \w a|strong="H3068"\w* los ʼelohim de \w oro|strong="H1722"\w*, \w plata|strong="H3702"\w*, bronce, \w hierro|strong="H6523"\w*, piedra y madera.
\p 
\v 5 \w De|strong="H5922"\w* repente aparecieron los dedos \w de|strong="H5922"\w* una \w mano|strong="H3028"\w* \w de|strong="H5922"\w* hombre \w que|strong="H1768"\w* escribía \w al|strong="H5922"\w* frente del candelero \w sobre|strong="H5922"\w* lo encalado \w de|strong="H5922"\w* la pared del palacio del \w rey|strong="H4430"\w*. El \w rey|strong="H4430"\w* \w veía|strong="H2370"\w* la parte \w de|strong="H5922"\w* la \w mano|strong="H3028"\w* \w que|strong="H1768"\w* escribía.
\v 6 Entonces el \w rey|strong="H4430"\w* palideció, sus pensamientos lo alarmaron, las coyunturas de sus caderas se aflojaron y sus rodillas se golpeaban la una contra otra.
\p 
\v 7 El \w rey|strong="H4430"\w* gritó \w a|strong="H3068"\w* gran voz \w que|strong="H1768"\w* acudieran los encantadores, los \w caldeos|strong="H3779"\w* y los \w adivinos|strong="H1505"\w*. \w Y|strong="H3068"\w* les dijo \w a|strong="H3068"\w* los \w sabios|strong="H2445"\w* \w de|strong="H5922"\w* Babilonia: \w Cualquiera|strong="H3606"\w* \w que|strong="H1768"\w* lea \w esta|strong="H1836"\w* inscripción y me explique su interpretación será vestido \w de|strong="H5922"\w* púrpura, tendrá \w en|strong="H5922"\w* su \w cuello|strong="H6676"\w* un collar \w de|strong="H5922"\w* \w oro|strong="H1722"\w* y tendrá autoridad como tercero \w en|strong="H5922"\w* el \w reino|strong="H4437"\w*.
\p 
\v 8 Entonces \w todos|strong="H3606"\w* los \w sabios|strong="H2445"\w* del \w rey|strong="H4430"\w* entraron, pero \w no|strong="H3809"\w* \w pudieron|strong="H3546"\w* \w leer|strong="H7123"\w* la inscripción, \w ni|strong="H3809"\w* mostrar al \w rey|strong="H4430"\w* su interpretación.
\v 9 El \w rey|strong="H4430"\w* \w Belsasar|strong="H1113"\w* se turbó muchísimo y palideció. Sus dignatarios estaban perplejos.
\p 
\v 10 Pero la reina, motivada por las \w palabras|strong="H4406"\w* del \w rey|strong="H4430"\w* y de sus dignatarios, \w entró|strong="H5954"\w* \w a|strong="H3068"\w* la sala del banquete y dijo: ¡\w Vive|strong="H2418"\w* para siempre, oh \w rey|strong="H4430"\w*! No te turben tus pensamientos, ni palidezca tu semblante.
\v 11 En tu \w reino|strong="H4437"\w* hay un hombre en el cual vive el \w Espíritu|strong="H7308"\w* \w de|strong="H1768"\w* los \tl ʼelahs\tl* \w santos|strong="H6922"\w*. En los \w días|strong="H3118"\w* \w de|strong="H1768"\w* tu padre fueron halladas en él \w luz|strong="H5094"\w*, inteligencia y \w sabiduría|strong="H2452"\w*, como la \w sabiduría|strong="H2452"\w* \w de|strong="H1768"\w* los \tl ʼelahs\tl*. El \w rey|strong="H4430"\w* \w Nabucodonosor|strong="H5020"\w*, tu padre, oh \w rey|strong="H4430"\w*, lo \w constituyó|strong="H6966"\w* jefe \w de|strong="H1768"\w* los \w magos|strong="H2749"\w*, astrólogos, \w caldeos|strong="H3779"\w* y \w adivinos|strong="H1505"\w*,
\v 12 \w porque|strong="H1768"\w* fueron hallados en él un \w espíritu|strong="H7308"\w* superior, ciencia y entendimiento para interpretar \w sueños|strong="H2493"\w*, descifrar enigmas y resolver \w dudas|strong="H7001"\w*, esto es, en \w Daniel|strong="H1841"\w*, al cual el \w rey|strong="H4430"\w* llamó \w Beltsasar|strong="H1096"\w*. \w Ahora|strong="H3705"\w* \w pues|strong="H1768"\w*, \w llámese|strong="H7123"\w* \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w*, y él te declarará la interpretación.
\p 
\v 13 Entonces \w Daniel|strong="H1841"\w* \w fue|strong="H5954"\w* llevado ante el \w rey|strong="H4430"\w*. \w Y|strong="H3068"\w* el \w rey|strong="H4430"\w* le preguntó \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w*: ¿Eres tú aquel \w Daniel|strong="H1841"\w* \w de|strong="H4481"\w* los \w hijos|strong="H1123"\w* \w de|strong="H4481"\w* la cautividad \w de|strong="H4481"\w* \w Judá|strong="H3061"\w*, \w que|strong="H1768"\w* \w mi|strong="H6925"\w* padre trajo \w de|strong="H4481"\w* \w Judea|strong="H3061"\w*?
\v 14 Oí con respecto \w a|strong="H3068"\w* ti \w que|strong="H1768"\w* el \w espíritu|strong="H7308"\w* \w de|strong="H5922"\w* los \tl ʼelahs\tl* santos está \w en|strong="H5922"\w* ti, y \w que|strong="H1768"\w* fueron hallados \w en|strong="H5922"\w* ti \w luz|strong="H5094"\w*, entendimiento y mayor \w sabiduría|strong="H2452"\w*.
\v 15 \w Ahora|strong="H3705"\w*, \w sabios|strong="H2445"\w* \w y|strong="H3809"\w* astrólogos fueron traídos \w a|strong="H3068"\w* \w mi|strong="H6925"\w* presencia para \w que|strong="H1768"\w* leyeran \w esta|strong="H1836"\w* inscripción \w y|strong="H3809"\w* me dieran su interpretación, pero \w no|strong="H3809"\w* \w pudieron|strong="H3546"\w* mostrarme la interpretación del asunto.
\v 16 Oí con respecto \w a|strong="H3068"\w* ti \w que|strong="H1768"\w* puedes dar interpretaciones y resolver enigmas. \w Ahora|strong="H3705"\w*, \w si|strong="H2006"\w* puedes \w leer|strong="H7123"\w* la inscripción y darme su interpretación, serás vestido \w de|strong="H5922"\w* púrpura, tendrás un collar \w de|strong="H5922"\w* \w oro|strong="H1722"\w* \w en|strong="H5922"\w* tu \w cuello|strong="H6676"\w* y tendrás autoridad como tercero \w en|strong="H5922"\w* el \w reino|strong="H4437"\w*.
\p 
\v 17 Entonces \w Daniel|strong="H1841"\w* \w respondió|strong="H6032"\w* al \w rey|strong="H4430"\w*: ¡Tus obsequios sean para ti y \w da|strong="H3052"\w* tus recompensas \w a|strong="H3068"\w* otro! Leeré la inscripción al \w rey|strong="H4430"\w* y le diré la interpretación.
\p 
\v 18 Oh \w rey|strong="H4430"\w*, el \nd ʼElah\nd* Altísimo \w dio|strong="H3052"\w* el \w reino|strong="H4437"\w*, la \w grandeza|strong="H7238"\w*, el esplendor y la majestad \w a|strong="H3068"\w* tu padre \w Nabucodonosor|strong="H5020"\w*.
\v 19 \w Por|strong="H4481"\w* la \w grandeza|strong="H7238"\w* \w que|strong="H1768"\w* le \w dio|strong="H3052"\w*, \w todos|strong="H3606"\w* los pueblos, naciones y lenguas temían y \w temblaban|strong="H2112"\w* ante \w él|strong="H1934"\w*. \w Al|strong="H4481"\w* \w que|strong="H1768"\w* \w quería|strong="H6634"\w* \w mataba|strong="H6992"\w* y \w al|strong="H4481"\w* \w que|strong="H1768"\w* \w quería|strong="H6634"\w* concedía vida. \w Al|strong="H4481"\w* \w que|strong="H1768"\w* \w quería|strong="H6634"\w* \w engrandecía|strong="H7313"\w* y \w al|strong="H4481"\w* \w que|strong="H1768"\w* \w quería|strong="H6634"\w* \w humillaba|strong="H8214"\w*.
\v 20 Pero \w cuando|strong="H1768"\w* su \w corazón|strong="H3825"\w* se ensoberbeció y su \w espíritu|strong="H7308"\w* se endureció \w en|strong="H4481"\w* su orgullo, fue depuesto \w del|strong="H4481"\w* \w trono|strong="H3764"\w* \w de|strong="H4481"\w* su \w reino|strong="H4437"\w* y despojado \w de|strong="H4481"\w* su esplendor.
\v 21 Fue apartado \w de|strong="H4481"\w* \w entre|strong="H5705"\w* los \w hijos|strong="H1123"\w* \w de|strong="H4481"\w* los hombres, su mente se hizo semejante \w a|strong="H3068"\w* la \w de|strong="H4481"\w* las \w bestias|strong="H2423"\w* y su morada fue \w con|strong="H5974"\w* los asnos monteses. Le hicieron comer \w hierba|strong="H6211"\w* como \w a|strong="H3068"\w* buey y su cuerpo fue mojado \w con|strong="H5974"\w* el \w rocío|strong="H2920"\w* \w del|strong="H4481"\w* \w cielo|strong="H8065"\w* \w hasta|strong="H5705"\w* \w que|strong="H1768"\w* reconoció \w que|strong="H1768"\w* el \nd ʼElah\nd* Altísimo \w tiene|strong="H1768"\w* dominio \w sobre|strong="H5922"\w* el \w reino|strong="H4437"\w* \w de|strong="H4481"\w* los hombres y pone \w al|strong="H5922"\w* \w que|strong="H1768"\w* le place \w en|strong="H5922"\w* él.
\p 
\v 22 \w Y|strong="H3068"\w* tú, su \w hijo|strong="H1247"\w* \w Belsasar|strong="H1113"\w*, aunque sabías \w todo|strong="H3606"\w* \w esto|strong="H1836"\w*, \w no|strong="H3809"\w* humillaste tu \w corazón|strong="H3825"\w*,
\v 23 sino te exaltaste \w contra|strong="H5922"\w* el \nd ʼAdón\nd* del \w cielo|strong="H8065"\w*. Trajiste los \w vasos|strong="H3984"\w* \w de|strong="H5922"\w* su Templo \w delante|strong="H6925"\w* \w de|strong="H5922"\w* ti. \w Y|strong="H3068"\w* tú, tus dignatarios, tus esposas \w y|strong="H3809"\w* tus \w concubinas|strong="H3904"\w* beben \w vino|strong="H2562"\w* \w en|strong="H5922"\w* ellos. Además \w de|strong="H5922"\w* esto, diste alabanza \w a|strong="H3068"\w* \tl ʼelahs\tl* \w de|strong="H5922"\w* \w plata|strong="H3702"\w*, \w oro|strong="H1722"\w*, bronce, \w hierro|strong="H6523"\w*, piedra \w y|strong="H3809"\w* madera, los cuales \w no|strong="H3809"\w* \w ven|strong="H2370"\w*, \w ni|strong="H3809"\w* \w oyen|strong="H8086"\w*, \w ni|strong="H3809"\w* \w saben|strong="H3046"\w*. Pero \w no|strong="H3809"\w* glorificaste \w al|strong="H5922"\w* \nd ʼElah\nd* \w en|strong="H5922"\w* \w cuya|strong="H1768"\w* \w mano|strong="H3028"\w* está tu aliento \w y|strong="H3809"\w* tus caminos.
\v 24 Entonces la \w mano|strong="H3028"\w* \w que|strong="H1768"\w* trazó \w esta|strong="H1836"\w* inscripción fue enviada \w de|strong="H4481"\w* su presencia.
\p 
\v 25 \w Esta|strong="H1836"\w* es la inscripción \w que|strong="H1768"\w* fue trazada: \tl \w Mene|strong="H4484"\w*, \w Mene|strong="H4484"\w*, \w Tekel|strong="H8625"\w*, Uparsin.\tl*
\p 
\v 26 \w Esta|strong="H1836"\w* es la interpretación del asunto:
\m \tl \w Mene|strong="H4484"\w*:\tl* \nd ʼElah\nd* \w contó|strong="H4483"\w* tu \w reino|strong="H4437"\w* y le señaló fin.
\m 
\v 27 \tl \w Tekel|strong="H8625"\w*\tl*: Fuiste \w pesado|strong="H8625"\w* en balanza y fuiste \w hallado|strong="H7912"\w* \w falto|strong="H2627"\w*.
\m 
\v 28 \tl Parsin:\tl* Tu \w reino|strong="H4437"\w* fue roto y dado \w a|strong="H3068"\w* los medos y \w a|strong="H3068"\w* los persas.
\p 
\v 29 Entonces \w Belsasar|strong="H1113"\w* dio órdenes. \w Vistieron|strong="H3848"\w* \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* \w de|strong="H5922"\w* púrpura y \add le pusieron\add* un collar \w de|strong="H5922"\w* \w oro|strong="H1722"\w* \w en|strong="H5922"\w* \w su|strong="H1934"\w* \w cuello|strong="H6676"\w*. Proclamaron con respecto \w a|strong="H3068"\w* \w él|strong="H1934"\w* \w que|strong="H1768"\w* tenía autoridad y era \w el|strong="H1934"\w* tercero \w en|strong="H5922"\w* \w el|strong="H1934"\w* \w reino|strong="H4437"\w*.
\p 
\v 30 Aquella misma \w noche|strong="H3916"\w* \w Belsasar|strong="H1113"\w*, \w rey|strong="H4430"\w* de los \w caldeos|strong="H3779"\w*, fue asesinado.
\v 31 Darío, el medo, tomó el reino \w a|strong="H3068"\w* los 72 años de edad.
\c 6
\s1 Darío
\p 
\v 1 \w A|strong="H3068"\w* \w Darío|strong="H1868"\w* le pareció bien establecer 120 \tl sátrapas\tl*, para gobernar en todo el \w reino|strong="H4437"\w*,
\v 2 y \w al|strong="H5922"\w* frente \w de|strong="H5922"\w* ellos tres gobernadores (uno \w de|strong="H5922"\w* ellos era Daniel), \w a|strong="H3068"\w* quienes estos \tl sátrapas\tl* dieran cuenta \w para|strong="H5922"\w* \w que|strong="H1768"\w* \w el|strong="H1934"\w* rey no sufriera pérdida.
\v 3 Este \w Daniel|strong="H1841"\w* se distinguía \w por|strong="H4481"\w* encima \w de|strong="H4481"\w* los \w gobernadores|strong="H5632"\w* \w y|strong="H3809"\w* \tl sátrapas\tl*, \w porque|strong="H1768"\w* poseía un Espíritu superior. \w El|strong="H1934"\w* \w rey|strong="H4430"\w* pensaba darle autoridad sobre todo \w el|strong="H1934"\w* reino.
\p 
\v 4 \w Por|strong="H5922"\w* lo cual los \w gobernadores|strong="H5632"\w* y \tl sátrapas\tl* buscaban ocasión \w contra|strong="H5922"\w* \w Daniel|strong="H1841"\w* \w en|strong="H5922"\w* lo relacionado con \w el|strong="H1934"\w* \w reino|strong="H4437"\w*, pero no podían hallar \w alguna|strong="H3606"\w* acusación \w o|strong="H3068"\w* falta, \w porque|strong="H1768"\w* \w él|strong="H1934"\w* era fiel. Ninguna negligencia \w o|strong="H3068"\w* corrupción fue hallada \w en|strong="H5922"\w* \w él|strong="H1934"\w*.
\v 5 Entonces aquellos hombres se dijeron: \w No|strong="H3809"\w* \w hallaremos|strong="H7912"\w* algún pretexto \w contra|strong="H5922"\w* este \w Daniel|strong="H1841"\w* \w para|strong="H5922"\w* acusarlo, excepto \w en|strong="H5922"\w* relación con la Ley \w de|strong="H5922"\w* \w su|strong="H1934"\w* \nd ʼElah\nd*.
\p 
\v 6 Entonces estos gobernadores \w y|strong="H3809"\w* \tl sátrapas\tl* se reunieron \w de|strong="H5922"\w* común acuerdo ante el rey \w y|strong="H3809"\w* le dijeron: ¡Rey Darío, vive \w para|strong="H5922"\w* siempre!
\v 7 Todos los \w gobernadores|strong="H5632"\w* del reino, magistrados, \tl sátrapas\tl*, jefes y capitanes acordaron \w por|strong="H5922"\w* consejo \w que|strong="H5922"\w* promulgues un edicto \w real|strong="H4430"\w* y lo firmes. Según este edicto cualquiera \w que|strong="H5922"\w* \w en|strong="H5922"\w* el espacio \w de|strong="H5922"\w* 30 días demande petición \w de|strong="H5922"\w* cualquier \nd ʼElah\nd* u hombre fuera \w de|strong="H5922"\w* ti, oh \w rey|strong="H4430"\w*, sea echado \w en|strong="H5922"\w* el foso \w de|strong="H5922"\w* los leones.
\v 8 Ahora, oh \w rey|strong="H4430"\w*, establece el \w edicto|strong="H7010"\w* y firma el documento para \w que|strong="H1768"\w* no sea modificado, según la ley \w de|strong="H4481"\w* medos y persas, \w que|strong="H1768"\w* es irrevocable.
\v 9 El \w rey|strong="H4430"\w* Darío \w firmó|strong="H7560"\w* el edicto \w y|strong="H3809"\w* la prohibición.
\p 
\v 10 Cuando Daniel supo que el edicto estaba firmado, entró en su casa y abrió las ventanas de su habitación que se abrían hacia Jerusalén. Se arrodillaba tres veces al día, hablaba con Dios y daba gracias \w a|strong="H3068"\w* su \nd ʼElah\nd*, \w como|strong="H6903"\w* solía hacer antes.
\v 11 Entonces aquellos hombres, \w por|strong="H4481"\w* acuerdo, \w fueron|strong="H1934"\w* y hallaron \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* \w cuando|strong="H1768"\w* \w hacía|strong="H5648"\w* petición y súplica ante \w su|strong="H1934"\w* \nd ʼElah\nd*.
\v 12 Luego llegaron al rey y le hablaron con respecto al edicto real: ¿No firmaste un edicto según el cual cualquiera que en el espacio de 30 días haga una petición \w a|strong="H3068"\w* cualquier \tl ʼelah\tl* u hombre fuera de ti, oh rey, sea echado en el foso de los leones?
\p El rey respondió: La declaración es verdadera, según la ley de medos y persas, la cual no puede ser abrogada.
\p 
\v 13 Entonces \w ellos|strong="H4481"\w* contestaron \w al|strong="H5922"\w* \w rey|strong="H4430"\w*: Daniel, quien es \w de|strong="H4481"\w* los cautivos \w de|strong="H4481"\w* Judá, \w no|strong="H3809"\w* te respeta, oh \w rey|strong="H4430"\w*, \w ni|strong="H3809"\w* acata el edicto \w que|strong="H1768"\w* firmaste, \w sino|strong="H3861"\w* \w hace|strong="H1156"\w* su petición tres veces \w al|strong="H5922"\w* \w día|strong="H3118"\w*.
\p 
\v 14 \w Cuando|strong="H1768"\w* el \w rey|strong="H4430"\w* oyó el asunto, le pesó muchísimo \w y|strong="H3809"\w* resolvió librar \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w*. Se esforzó \w para|strong="H5922"\w* librarlo hasta ocultarse el sol.
\p 
\v 15 Pero aquellos hombres rodearon \w al|strong="H5922"\w* \w rey|strong="H4430"\w* y le dijeron: Reconoce, oh \w rey|strong="H4430"\w*, \w que|strong="H1768"\w* es una ley \w de|strong="H5922"\w* medos y persas, según la cual ningún edicto \w o|strong="H3068"\w* decreto \w que|strong="H1768"\w* \w el|strong="H1934"\w* \w rey|strong="H4430"\w* establezca puede ser abrogado.
\s1 Fidelidad
\p 
\v 16 Entonces el \w rey|strong="H4430"\w* dio la orden. Llevaron \w a|strong="H3068"\w* Daniel \w y|strong="H3809"\w* lo echaron \w en|strong="H5922"\w* el foso \w de|strong="H5922"\w* los leones. Pero el \w rey|strong="H4430"\w* dijo \w a|strong="H3068"\w* Daniel: ¡Tu \nd ʼElah\nd*, \w a|strong="H3068"\w* Quien sirves continuamente, Él mismo te librará!
\p 
\v 17 \w Una|strong="H1932"\w* piedra fue llevada y puesta sobre la entrada del \w foso|strong="H1358"\w*, la cual \w el|strong="H1932"\w* \w rey|strong="H4430"\w* selló con su anillo y con \w el|strong="H1932"\w* anillo \w de|strong="H1768"\w* sus dignatarios, para \w que|strong="H1768"\w* \w el|strong="H1932"\w* acuerdo con respecto \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* no fuera alterado.
\v 18 Luego el \w rey|strong="H4430"\w* se retiró \w a|strong="H3068"\w* su palacio \w y|strong="H3809"\w* pasó la noche \w en|strong="H5922"\w* ayuno. \w No|strong="H3809"\w* le fueron llevados instrumentos \w de|strong="H5922"\w* música \w ni|strong="H3809"\w* concubinas bailarinas. El sueño huyó \w de|strong="H5922"\w* él.
\p 
\v 19 \w Al|strong="H5922"\w* rayar el alba, el \w rey|strong="H4430"\w* se levantó \w y|strong="H3809"\w* \w fue|strong="H5954"\w* apresuradamente \w al|strong="H5922"\w* foso \w de|strong="H5922"\w* los leones.
\v 20 \w Y|strong="H3068"\w* al acercarse al \w foso|strong="H1358"\w* gritó con voz afligida \w a|strong="H3068"\w* Daniel: ¡Daniel, esclavo del \nd ʼElah\nd* viviente! ¿El \nd ʼElah\nd* \w a|strong="H3068"\w* Quien sirves continuamente pudo librarte \w de|strong="H1768"\w* los leones?
\p 
\v 21 Entonces \w Daniel|strong="H1841"\w* \w respondió|strong="H6032"\w* \w al|strong="H4481"\w* \w rey|strong="H4430"\w*: ¡Oh \w rey|strong="H4430"\w*, vive para siempre!
\v 22 Mi \nd ʼElah\nd* envió \w a|strong="H3068"\w* su Ángel, el cual cerró las bocas \w de|strong="H5974"\w* los leones para que no me hicieran daño, porque fui hallado inocente ante Él, como también ante ti, oh \w rey|strong="H4430"\w*. Nada malo hice.
\p 
\v 23 Entonces el \w rey|strong="H4430"\w* se alegró muchísimo \w y|strong="H3809"\w* ordenó \w que|strong="H1768"\w* sacaran \w a|strong="H3068"\w* Daniel del foso. Daniel fue sacado del foso, \w y|strong="H3809"\w* \w no|strong="H3809"\w* se halló ninguna lesión en él, \w porque|strong="H1768"\w* confió en su \nd ʼElah\nd*.
\p 
\v 24 \w Luego|strong="H4481"\w* el \w rey|strong="H4430"\w* dio orden, \w y|strong="H3809"\w* aquellos hombres \w que|strong="H1768"\w* acusaron \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w*, junto con sus hijos \w y|strong="H3809"\w* sus esposas, fueron llevados \w y|strong="H3809"\w* echados \w en|strong="H5922"\w* el \w foso|strong="H1358"\w* \w de|strong="H4481"\w* los leones. Aún \w no|strong="H3809"\w* habían llegado \w al|strong="H5922"\w* fondo \w del|strong="H4481"\w* \w foso|strong="H1358"\w* \w cuando|strong="H1768"\w* los leones se apoderaron \w de|strong="H4481"\w* \w ellos|strong="H4481"\w* \w y|strong="H3809"\w* los descuartizaron.
\s1 Decreto de Darío
\p 
\v 25 El \w rey|strong="H4430"\w* Darío escribió \w a|strong="H3068"\w* \w todos|strong="H3606"\w* los pueblos, naciones \w y|strong="H3809"\w* lenguas \w de|strong="H1768"\w* la tierra: Paz les sea multiplicada.
\v 26 Decreto \w que|strong="H1768"\w* en \w todo|strong="H3606"\w* el dominio \w de|strong="H1768"\w* mi reino \add todos\add* teman y tiemblen ante el \nd ʼElah\nd* \w de|strong="H1768"\w* Daniel, \w porque|strong="H1768"\w* Él es el \nd ʼElah\nd* viviente, y permanece para siempre. Su reino no será destruido y su dominio perdurará para siempre.
\v 27 \w Él|strong="H1934"\w* salva \w y|strong="H3809"\w* libra. Hace señales \w y|strong="H3809"\w* maravillas \w en|strong="H5705"\w* \w el|strong="H1934"\w* cielo \w y|strong="H3809"\w* \w en|strong="H5705"\w* la tierra. \w Él|strong="H1934"\w* libró \w a|strong="H3068"\w* \w Daniel|strong="H1841"\w* \w del|strong="H4481"\w* poder \w de|strong="H4481"\w* los leones.
\p 
\v 28 Este \w Daniel|strong="H1841"\w* prosperó \w en|strong="H4481"\w* el reinado \w de|strong="H4481"\w* Darío y \w en|strong="H4481"\w* el reinado \w de|strong="H4481"\w* Ciro el persa.
\c 7
\s1 Las cuatro bestias
\p 
\v 1 El primer \w año|strong="H8140"\w* \w de|strong="H5922"\w* \w Belsasar|strong="H1113"\w*, \w rey|strong="H4430"\w* \w de|strong="H5922"\w* Babilonia, \w Daniel|strong="H1841"\w* tuvo un \w sueño|strong="H2493"\w* y visiones \w de|strong="H5922"\w* su cabeza mientras estaba \w en|strong="H5922"\w* su cama. Entonces \w escribió|strong="H3790"\w* el \w sueño|strong="H2493"\w* y relató un resumen \w de|strong="H5922"\w* él.
\p 
\v 2 \w Daniel|strong="H1841"\w* \w habló|strong="H6032"\w*: Yo \w miraba|strong="H2370"\w* en mi visión nocturna y \w vi|strong="H2370"\w* que los cuatro puntos cardinales del \w cielo|strong="H8065"\w* se desataban sobre \w el|strong="H1934"\w* gran \w mar|strong="H3221"\w*.
\v 3 Cuatro \w grandes|strong="H7260"\w* \w bestias|strong="H2423"\w*, diferentes la una \w de|strong="H4481"\w* la otra, \w subieron|strong="H5559"\w* \w del|strong="H4481"\w* \w mar|strong="H3221"\w*.
\p 
\v 4 La primera era como un león, y tenía \w alas|strong="H1611"\w* \w de|strong="H4481"\w* \w águila|strong="H5403"\w*. \w Yo|strong="H5403"\w* \w miraba|strong="H2370"\w* \w hasta|strong="H5705"\w* \w que|strong="H1768"\w* \w sus|strong="H1934"\w* \w alas|strong="H1611"\w* \w fueron|strong="H1934"\w* arrancadas, y ella fue levantada \w de|strong="H4481"\w* la tierra. La levantaron \w a|strong="H3068"\w* estar \w sobre|strong="H5922"\w* \w sus|strong="H1934"\w* dos \w pies|strong="H7271"\w*, \w a|strong="H3068"\w* manera \w de|strong="H4481"\w* hombre, y le fue dado \w corazón|strong="H3825"\w* \w de|strong="H4481"\w* hombre.
\p 
\v 5 Miré una \w segunda|strong="H8578"\w* \w bestia|strong="H2423"\w* \w semejante|strong="H1821"\w* \w a|strong="H3068"\w* un oso. Estaba elevado de un lado. Tenía \w tres|strong="H8532"\w* \w costillas|strong="H5967"\w* entre los dientes de su boca, y se le dijo: ¡\w Levántate|strong="H6966"\w* y devora \w mucha|strong="H7690"\w* \w carne|strong="H1321"\w*!
\p 
\v 6 Después \w de|strong="H5922"\w* eso \w yo|strong="H1836"\w* \w miraba|strong="H2370"\w*. Ahí estaba otra \w bestia|strong="H2423"\w*, \w semejante|strong="H1836"\w* \w a|strong="H3068"\w* un leopardo \w que|strong="H1768"\w* tenía cuatro \w alas|strong="H1611"\w* \w de|strong="H5922"\w* ave \w en|strong="H5922"\w* \w sus|strong="H1934"\w* espaldas. \w Esta|strong="H1836"\w* \w bestia|strong="H2423"\w* tenía cuatro \w cabezas|strong="H7217"\w*, y se le \w dio|strong="H3052"\w* dominio.
\p 
\v 7 \w Después|strong="H4481"\w* \w de|strong="H4481"\w* eso \w miraba|strong="H2370"\w* \w en|strong="H4481"\w* las visiones \w de|strong="H4481"\w* la \w noche|strong="H3916"\w*. Ahí estaba la cuarta \w bestia|strong="H2423"\w*, \w espantosa|strong="H1763"\w*, terrible y muy \w fuerte|strong="H8624"\w*, la cual tenía \w grandes|strong="H7260"\w* dientes \w de|strong="H4481"\w* \w hierro|strong="H6523"\w*, con los cuales devoraba y desmenuzaba, y lo sobrante lo aplastaba con \w sus|strong="H1934"\w* patas. \w Era|strong="H1932"\w* muy diferente \w de|strong="H4481"\w* \w todas|strong="H3606"\w* las \w bestias|strong="H2423"\w* \w que|strong="H1768"\w* \w vi|strong="H2370"\w* \w antes|strong="H4481"\w* \w de|strong="H4481"\w* \w ella|strong="H1932"\w*, y tenía \w diez|strong="H6236"\w* \w cuernos|strong="H7162"\w*.
\p 
\v 8 Yo observaba los \w cuernos|strong="H7162"\w*, y vi \w que|strong="H4481"\w* otro \w cuerno|strong="H7162"\w* \w pequeño|strong="H2192"\w* salía entre \w ellos|strong="H4481"\w*, ante \w el|strong="H1934"\w* cual \w tres|strong="H8532"\w* \w de|strong="H4481"\w* los primeros \w cuernos|strong="H7162"\w* \w fueron|strong="H1934"\w* arrancados \w de|strong="H4481"\w* raíz. \w Y|strong="H3068"\w* vi \w que|strong="H4481"\w* este \w cuerno|strong="H7162"\w* tenía \w ojos|strong="H5870"\w* \w como|strong="H5870"\w* \w de|strong="H4481"\w* hombre y una boca \w que|strong="H4481"\w* \w hablaba|strong="H4449"\w* \w grandes|strong="H7260"\w* cosas.
\p 
\v 9 Yo \w miraba|strong="H2370"\w* \w hasta|strong="H5705"\w* \w que|strong="H1768"\w* tronos \w fueron|strong="H1934"\w* puestos. Se sentó un Anciano \w de|strong="H1768"\w* \w Días|strong="H3118"\w*, \w cuya|strong="H1934"\w* ropa era blanca como la nieve y \w el|strong="H1934"\w* \w cabello|strong="H8177"\w* \w de|strong="H1768"\w* \w su|strong="H1934"\w* cabeza como lana pura. \w Su|strong="H1934"\w* \w trono|strong="H3764"\w* era llamas \w de|strong="H1768"\w* \w fuego|strong="H5135"\w*, y las ruedas del \w trono|strong="H3764"\w*, \w de|strong="H1768"\w* \w fuego|strong="H5135"\w* \w ardiente|strong="H1815"\w*.
\v 10 Un río \w de|strong="H4481"\w* \w fuego|strong="H5135"\w* \w procedía|strong="H5047"\w* \w de|strong="H4481"\w* \w delante|strong="H6925"\w* \w de|strong="H4481"\w* Él y corría. Millares \w de|strong="H4481"\w* millares le servían, y \w millones|strong="H7240"\w* \w de|strong="H4481"\w* \w millones|strong="H7240"\w* estaban \w en|strong="H4481"\w* pie \w delante|strong="H6925"\w* \w de|strong="H4481"\w* Él. El Juez se sentó, y los rollos fueron abiertos.
\p 
\v 11 Entonces yo \w miraba|strong="H2370"\w* \w a|strong="H3068"\w* causa \w del|strong="H4481"\w* ruido \w de|strong="H4481"\w* las \w palabras|strong="H4406"\w* arrogantes \w que|strong="H1768"\w* \w el|strong="H1934"\w* \w cuerno|strong="H7162"\w* \w hablaba|strong="H4449"\w*. Yo \w miraba|strong="H2370"\w* \w hasta|strong="H5705"\w* \w que|strong="H1768"\w* la \w bestia|strong="H2423"\w* fue matada, \w su|strong="H1934"\w* cuerpo destruido y echado \w al|strong="H4481"\w* fuego ardiente.
\v 12 \w En|strong="H5705"\w* cuanto \w a|strong="H3068"\w* las otras \w bestias|strong="H2423"\w*, se les quitó su dominio, pero la vida les fue prolongada por un \w tiempo|strong="H5732"\w* determinado.
\p 
\v 13 Yo observaba \w en|strong="H5705"\w* las visiones nocturnas. \w Vi|strong="H2370"\w* Uno como un \w Hijo|strong="H1247"\w* \w de|strong="H5974"\w* Hombre \w que|strong="H5705"\w* venía \w con|strong="H5974"\w* las nubes del \w cielo|strong="H8065"\w*. Llegó \w hasta|strong="H5705"\w* \w el|strong="H1934"\w* Anciano \w de|strong="H5974"\w* \w Días|strong="H3118"\w* y se presentó ante \w Él|strong="H1934"\w*.
\v 14 Se le concedió dominio, gloria \w y|strong="H3809"\w* un \w reino|strong="H4437"\w* para \w que|strong="H1768"\w* \w todos|strong="H3606"\w* los pueblos, naciones \w y|strong="H3809"\w* lenguas le sirvan. Su dominio es \w eterno|strong="H5957"\w*, \w que|strong="H1768"\w* \w no|strong="H3809"\w* pasará, \w y|strong="H3809"\w* su \w reino|strong="H4437"\w* \w no|strong="H3809"\w* será jamás destruido.
\p 
\v 15 En cuanto \w a|strong="H3068"\w* mí, \w Daniel|strong="H1841"\w*, se me turbó el \w espíritu|strong="H7308"\w* \w a|strong="H3068"\w* causa de esto, y las visiones de mi cabeza me alarmaban.
\v 16 Me acerqué \w a|strong="H3068"\w* uno \w de|strong="H4481"\w* los \w que|strong="H4481"\w* estaban \w en|strong="H5922"\w* pie, y le pregunté la \w verdad|strong="H3330"\w* con respecto \w a|strong="H3068"\w* \w todo|strong="H3606"\w* \w esto|strong="H1836"\w*.
\p Él me habló y me informó la interpretación \w de|strong="H4481"\w* las cosas:
\v 17 \wj Estas cuatro \w bestias|strong="H2423"\w* \w grandes|strong="H7260"\w* son cuatro \w reyes|strong="H4430"\w* \w que|strong="H1768"\w* se levantarán \w en|strong="H4481"\w* la tierra.\wj*
\v 18 \wj Después los \w santos|strong="H6922"\w* del Altísimo recibirán el \w reino|strong="H4437"\w*, y lo poseerán por toda la eternidad, por todas las edades venideras.\wj*
\p 
\v 19 Entonces quise saber \w la|strong="H3605"\w* verdad con respecto \w a|strong="H3068"\w* \w la|strong="H3605"\w* cuarta \w bestia|strong="H2423"\w* \w que|strong="H1768"\w* era diferente \w de|strong="H4481"\w* \w todas|strong="H3605"\w* las otras, \w espantosa|strong="H1763"\w* \w en|strong="H5922"\w* gran manera. Devoraba y descuartizaba con \w sus|strong="H1934"\w* dientes \w de|strong="H4481"\w* \w hierro|strong="H6523"\w* y uñas \w de|strong="H4481"\w* bronce. Aplastaba con \w sus|strong="H1934"\w* patas \w lo|strong="H3605"\w* sobrante.
\v 20 Tenía \w diez|strong="H6236"\w* \w cuernos|strong="H7162"\w* \w en|strong="H5922"\w* su cabeza. Le salió otro \w cuerno|strong="H7162"\w* \w delante|strong="H6925"\w* \w del|strong="H4481"\w* cual \w cayeron|strong="H5308"\w* \w tres|strong="H8532"\w* \w de|strong="H4481"\w* \w ellos|strong="H4481"\w*. Este \w cuerno|strong="H7162"\w* tenía \w ojos|strong="H5870"\w* y una boca \w que|strong="H1768"\w* \w hablaba|strong="H4449"\w* cosas \w grandes|strong="H7260"\w*. Su aspecto era más imponente \w que|strong="H1768"\w* el \w de|strong="H4481"\w* sus compañeros.
\v 21 Observaba que este \w cuerno|strong="H7162"\w* \w hacía|strong="H5648"\w* \w guerra|strong="H7129"\w* \w contra|strong="H5974"\w* los \w santos|strong="H6922"\w* y los vencía
\v 22 \w hasta|strong="H5705"\w* \w que|strong="H1768"\w* vino el Anciano \w de|strong="H1768"\w* \w Días|strong="H3118"\w*, y se \w dio|strong="H3052"\w* el \w juicio|strong="H1780"\w* \w a|strong="H3068"\w* los \w santos|strong="H6922"\w* del Altísimo. \w Cuando|strong="H1768"\w* llegó el \w tiempo|strong="H3118"\w*, los \w santos|strong="H6922"\w* \w poseyeron|strong="H2631"\w* el \w reino|strong="H4437"\w*.
\p 
\v 23 Dijo: \wj La cuarta \w bestia|strong="H2423"\w* será un \w cuarto|strong="H7244"\w* \w reino|strong="H4437"\w* \w en|strong="H4481"\w* la tierra, \w el|strong="H1934"\w* cual será diferente \w de|strong="H4481"\w* \w todos|strong="H3606"\w* los otros \w reinos|strong="H4437"\w*. Devorará, trillará y despedazará \w toda|strong="H3606"\w* la tierra.\wj*
\v 24 \wj \w En|strong="H4481"\w* cuanto \w a|strong="H3068"\w* los \w diez|strong="H6236"\w* \w cuernos|strong="H7162"\w*: \w diez|strong="H6236"\w* \w reyes|strong="H4430"\w* se levantarán \w de|strong="H4481"\w* ese \w reino|strong="H4437"\w*, y otro tras \w ellos|strong="H4481"\w*, \w el|strong="H1932"\w* cual será diferente \w de|strong="H4481"\w* los primeros, y \w a|strong="H3068"\w* \w tres|strong="H8532"\w* \w reyes|strong="H4430"\w* \w derribará|strong="H8214"\w*.\wj*
\v 25 \wj Hablará \w palabras|strong="H4406"\w* \w contra|strong="H6655"\w* el Altísimo y \w quebrantará|strong="H1080"\w* \w a|strong="H3068"\w* sus \w santos|strong="H6922"\w*. Intentará cambiar los \w tiempos|strong="H5732"\w* y la Ley. Serán entregados \w en|strong="H5705"\w* su \w mano|strong="H3028"\w* por un \w tiempo|strong="H5732"\w*, \w tiempos|strong="H5732"\w* y medio \w tiempo|strong="H5732"\w*.\wj*
\p 
\v 26 \wj Pero el Juez se sentará y le quitará su dominio para \w que|strong="H5705"\w* sea destruido y arruinado \w hasta|strong="H5705"\w* el fin.\wj*
\v 27 \wj El \w reino|strong="H4437"\w*, el dominio y la majestad \w de|strong="H1768"\w* los \w reinos|strong="H4437"\w* bajo \w todo|strong="H3606"\w* el \w cielo|strong="H8065"\w* será dado al \w pueblo|strong="H5972"\w* \w de|strong="H1768"\w* los \w santos|strong="H6922"\w* del Altísimo, \w cuyo|strong="H1768"\w* \w reino|strong="H4437"\w* es \w eterno|strong="H5957"\w*. \w Todos|strong="H3606"\w* los dominios le servirán y obedecerán.\wj*
\p 
\v 28 \w En|strong="H5922"\w* este punto terminó la revelación. \w En|strong="H5922"\w* cuanto \w a|strong="H3068"\w* mí, \w Daniel|strong="H1841"\w*, mis pensamientos me alarmaron muchísimo y mi semblante palideció, pero guardé el asunto \w en|strong="H5922"\w* mi corazón.
\c 8
\s1 El carnero y el macho cabrío
\p 
\v 1 El tercer \w año|strong="H8141"\w* del \w reinado|strong="H4428"\w* del \w rey|strong="H4428"\w* \w Belsasar|strong="H1112"\w*, yo, \w Daniel|strong="H1840"\w*, tuve una \w visión|strong="H2377"\w*, después de la anterior.
\v 2 \w En|strong="H5921"\w* esa \w visión|strong="H2377"\w* yo \w estaba|strong="H1961"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* río Ulai \w en|strong="H5921"\w* Susa, \w la|strong="H5921"\w* \w capital|strong="H1002"\w*, \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w provincia|strong="H4082"\w* \w de|strong="H5921"\w* \w Elam|strong="H5867"\w*.
\v 3 \w Alcé|strong="H5375"\w* los \w ojos|strong="H5869"\w* y \w miré|strong="H7200"\w*. Ahí \w estaba|strong="H5975"\w* un carnero parado frente \w al|strong="H4480"\w* río. Aunque tenía \w dos|strong="H6440"\w* \w cuernos|strong="H7161"\w* largos, uno era \w más|strong="H4480"\w* \w alto|strong="H1364"\w* \w que|strong="H4480"\w* el \w otro|strong="H8145"\w*, y el \w más|strong="H4480"\w* \w alto|strong="H1364"\w* creció posteriormente.
\v 4 \w Vi|strong="H7200"\w* \w que|strong="H3808"\w* \w el|strong="H3605"\w* carnero acometía con sus cuernos \w hacia|strong="H6213"\w* \w el|strong="H3605"\w* oeste, \w hacia|strong="H6213"\w* \w el|strong="H3605"\w* \w norte|strong="H6828"\w* y \w hacia|strong="H6213"\w* \w el|strong="H3605"\w* sur. \w Y|strong="H3068"\w* \w ninguna|strong="H3605"\w* \w bestia|strong="H2416"\w* prevalecía \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H3605"\w*, \w ni|strong="H3808"\w* \w había|strong="H5975"\w* \w quien|strong="H3605"\w* \w escapara|strong="H3808"\w* \w de|strong="H6440"\w* su \w poder|strong="H3027"\w*. \w Hacía|strong="H6213"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* quería y \w se|strong="H3808"\w* engrandecía.
\p 
\v 5 \w Mientras|strong="H3605"\w* \w yo|strong="H4480"\w* consideraba esto, vi \w que|strong="H4480"\w* un macho \w cabrío|strong="H5795"\w* \w llegaba|strong="H5060"\w* \w del|strong="H4480"\w* oeste \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* superficie \w de|strong="H4480"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra, sin \w tocar|strong="H5060"\w* \w el|strong="H5921"\w* suelo. \w Aquel|strong="H3605"\w* macho \w cabrío|strong="H5795"\w* \w tenía|strong="H1961"\w* un \w cuerno|strong="H7161"\w* \w notable|strong="H2380"\w* \w entre|strong="H5921"\w* sus \w ojos|strong="H5869"\w*.
\v 6 Fue \w hasta|strong="H5704"\w* el carnero \w de|strong="H6440"\w* \w dos|strong="H6440"\w* \w cuernos|strong="H7161"\w* \w que|strong="H5704"\w* yo \w vi|strong="H7200"\w* \w en|strong="H5704"\w* la ribera del río, \w y|strong="H5704"\w* \w lo|strong="H5704"\w* embistió \w con|strong="H5704"\w* toda la furia \w de|strong="H6440"\w* su \w fuerza|strong="H3581"\w*.
\v 7 \w Lo|strong="H3808"\w* \w vi|strong="H7200"\w* encendido \w en|strong="H5975"\w* cólera. \w Fue|strong="H1961"\w* hasta el carnero, \w lo|strong="H3808"\w* acometió y rompió sus \w dos|strong="H8147"\w* \w cuernos|strong="H7161"\w*. El carnero \w no|strong="H3808"\w* \w tuvo|strong="H1961"\w* \w fuerzas|strong="H3581"\w* \w para|strong="H1961"\w* enfrentarse \w a|strong="H3068"\w* él. \w Por|strong="H6440"\w* tanto \w lo|strong="H3808"\w* \w derribó|strong="H7993"\w* \w a|strong="H3068"\w* tierra, \w lo|strong="H3808"\w* pisoteó, y \w no|strong="H3808"\w* \w hubo|strong="H1961"\w* quien \w librara|strong="H5337"\w* al carnero \w de|strong="H6440"\w* su \w poder|strong="H3581"\w*.
\v 8 El macho \w cabrío|strong="H5795"\w* se \w engrandeció|strong="H1431"\w* muchísimo, pero \w cuando|strong="H5704"\w* estaba \w en|strong="H5704"\w* su \w mayor|strong="H1419"\w* poderío, aquel \w gran|strong="H1419"\w* \w cuerno|strong="H7161"\w* fue quebrado. \w En|strong="H5704"\w* su \w lugar|strong="H8478"\w* surgieron otros cuatro \w cuernos|strong="H7161"\w* notables hacia los cuatro puntos cardinales del \w cielo|strong="H8064"\w*.
\p 
