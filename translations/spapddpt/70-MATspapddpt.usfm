\p \w Entonces|strong="G1161"\w* \w sus|strong="G3588"\w* \w discípulos|strong="G3101"\w* \w se|strong="G1438"\w* \w le|strong="G1438"\w* acercaron \w y|strong="G2532"\w* \w le|strong="G1438"\w* \w rogaban|strong="G2065"\w*: Despídela, \w porque|strong="G3754"\w* grita \w detrás|strong="G3693"\w* \w de|strong="G3588"\w* \w nosotros|strong="G2249"\w*.   
\p
