\id MAT - Central Carrier NT -Canada 2011 (DBL -2013) 
\h Matthew 
\toc1 Yak'usda Ooghuni Unzoo-i Matthew 'Uk'unéyuzguz-i 
\toc2 Matthew 
\toc3 Mt 
\mt1 Yak'usda Ooghuni Unzoo-i Matthew 'Uk'unéyuzguz-i 
\c 1  
\s1 Sizi Gri ubé dinzutne 
\p  
\v 1 Ndi 'udustl'us 'uk'eguz-un 'et dutni, 'i be Sizi Gri 'en ubé dinzutne 'uhínt'oh, 'i Sizi David ts'u hainzut-un 'unt'oh. David 'en Abraham ts'u hainzut-un 'unt'oh. 
\q1  
\v 2 Abraham 'en Isaac oobá 'unt'oh. 
\q2 Isaac 'en Jacob oobá 'unt'oh. 
\q2 Jacob 'en Judah 'ink'ez bulhutsinke bubá 'unt'oh. 
\q2  
\v 3 Judah 'en nyoon ts'eke Tamar 'en be Perez 'ink'ez Zerah bubá 'unt'oh. 
\q2 Perez Hezron oobá 'ink'ez Hezron Ram oobá 'unt'oh. 
\q2  
\v 4 Ram 'en Amminadab oobá. 
\q2 Amminadab Nashon oobá, 
\q2 'ink'ez Nashon Salmon oobá 'unt'oh. 
\q2  
\v 5 Salmon oo'at Rahab 'en be Boaz oobá. Boaz Ruth 'en be Obed oobá. 
\q2 'Ink'ez Obed Jesse oobá 'unt'oh. 
\q2  
\v 6 Jesse lerwe David oobá. 
\q1 'Et lerwe David, mbe la Uriah oo'at inle'-un, 'en be Solomon oobá 'unt'oh. 
\q2  
\v 7 Solomon Rehoboam oobá. 
\q2 Rehoboam Abijah oobá, 
\q2 'ink'ez Abijah Asa oobá 'unt'oh. 
\q2  
\v 8 Asa Jehoshaphat oobá. 
\q2 Jehoshaphat Joram oobá, 
\q2 'ink'ez Joram Uzziah oobá 'unt'oh. 
\q2  
\v 9 Uzziah Jotham oobá. 
\q2 Jotham Ahaz oobá, 
\q2 'ink'ez Ahaz Hezekiah oobá 'unt'oh. 
\q2  
\v 10 Hezekiah Manasseh oobá. 
\q2 Manasseh Amon oobá, 
\q2 'ink'ez Amon Josiah oobá 'unt'oh. 
\q2  
\v 11 'Oh da' 'oh whuya whudizulh whe ts'iyanne dune keyoh whuti Babylon ts'e whebuhanla, 'et Josiah 'en Jeconiah 'ink'ez bulhutsinke 'enne bubá 'unt'oh. 
\p  
\v 12 Keyoh whuti Babylon whuz whebuhanla hukw'elh'az 'et Jaconiah Shealtiel oobá 'unt'oh. 
\q2 Shealtiel Zurubbabel oobá 'unt'oh. 
\q2  
\v 13 Zerubbabel Abiud oobá. 
\q2 Abiud Eliakim oobá, 
\q2 'ink'ez Eliakim Azor oobá 'unt'oh. 
\q2  
\v 14 Azor Zadok oobá. 
\q2 Zadok Achim oobá, 
\q2 'ink'ez Achim Eliud oobá 'unt'oh. 
\q2  
\v 15 Eliud Eleazor oobá. 
\q2 Eleazor Matthan oobá, 
\q2 'ink'ez Matthan Jacob oobá 'unt'oh. 
\q2  
\v 16 Jacob Joseph oobá 'unt'oh. 
\q2 'En Mary ooki 'ink'ez Mary 'en be Sizi whuzdli. 'En Christ huyulhni. 
\p  
\v 17 'Inka Abraham David whuts'un, 'enne ts'iyawh whunizyat 'on 'at dit-un bubé dindene 'uhint'oh. 'Ink'ez David 'oh da' whudizulh whe ts'iyanne keyoh whut'enne Babylon ts'e whebuhanla whuts'un, 'enne ts'iyawh whunizyat 'on 'at dit-un bubé dindene hinli. 'Ink'ez 'oh da' whudizulh whe ts'iyanne keyoh Babylon ts'e whebuhanla 'et hukw'elh'uz dich'oh dukeyoh yun k'ut Judah, whuz whenáhidil, Christ 'et whuts'un, 'enne ts'iyawh whunizyat 'on 'at dit-un bubé dindene hinli whe hint'oh. 
\s1 Sizi Gri whuzdli-un 
\p  
\v 18 'Et 'awet Sizi Gri whuzdli-un, ndiz un'a 'uhooja. Ooloo Mary 'en Joseph 'en yughu tidalh ha lhahódinla, 'ink'ez yughu tidalh whutso whe 'et nahoon'ai 'uda' ts'oodun ba 'unt'oh. Ndoni, 'i be 'uja. 
\p  
\v 19 'Et ndun Joseph 'en ts'ih'un dune unli, 'et huwa lhgho tikelh ts'iyanne toh yooya yoolhtselh whuch'a dudeni lhaidinla. 'Ink'ez whu'iz yuch'a natidalh hukwa' ninzun. 
\p  
\v 20 'Et howu nuni nuzut whe 'et huwu nusúti whe neMoodihti oolizas 'en yulhni, “Joseph David oots'u hainzut-un inli whe' 'int'oh. Wheniljut iloh whe Mary n'at tileh. Ndun ts'oodun Ndoni be chainya whe 'unt'oh. 
\p  
\v 21 'Et 'awet ooyaz, duneyaz tileh. Nyunch'oh boozi' oogha ídon'alh. Sizi dóni'. 'En 'utinelh ts'iyanne lubeshi ch'a ubutilhyih.” 
\p  
\v 22 'Et ndiz un'a 'uhooja, neMoodihti nyoon nus hoo'en-un, 'en be daja ni la, whunilhchoh 'oh túne'whust'en. 'Et nyoon nus hoo'en-un ndiz un'a nja dutni, 
\p  
\v 23 “Soo zulhts'ai ndun ts'eke 'aw dune t'enuszun-un 'et hoonts'i khunsul ts'oodun ba 'uja, 'ink'ez ooyaz dune tileh, boozi' Emmanuel hidutánelh, Yak'usda nebulh 'únt'oh, ni whe utni.” 
\p  
\v 24 'Inka Joseph ts'enanzut whe neMoodihti oolizas daja yulhni la, 'oh tune' 'ust'en 'ink'ez 'awet Mary yilhchoot oo'at yutáleh ha. 
\p  
\v 25 'Udechoo ooyaz whutileh t'eoonanzin 'et whuts'un 'aw yut'álhasnai. 'Et 'awet ooye' whuzdli, 'et 'andit za soo yughusda. 'Inka boozi' yugha ídin'ai Sizi yulhni. 
\c 2  
\s1 Dune whunihne, Majine hubuwhútnine, 'enne Jerusalem ts'e hoozdil 
\p  
\v 1 'Et 'awet yun k'ut Judea, keyoh Bethlehem whuz'ai-un, 'et Sizi whuzdli. 'Oh da' whuz un'a Herod lerwe unli whe 'et 'uhooja. 'Et 'awet whuzdli hukw'elh'az khunsul nda' whut'enne keyoh Jerusalem ts'e hoozdil. 'Enne whunihne Majine hubuhútnine, 'enne 'uhint'oh.\fig |src="cn01629b.tif" size="col" copy="©1978 David C. Cook Publishing Company" ref="Matthew 2.1" \fig* 
\p  
\v 2 'Ink'ez dune hoodulhkut, “Lizwifne bulerwe 'andit whuzdli-un, 'en nts'e whuzdli? 'Et ndi sum cho ts'an'en, 'i gha lhuts'úzdil. 'Et huwa ndaz de ndun ts'oodun 'en oots'un teni' ts'untilhdzilh ha whusats'ándilh.” 
\p  
\v 3 'Et hoonts'i lerwe Herod whulh udants'o whe ooba dzoh 'uhutni. Jerusalem whut'enne, 'enne cha whuz un'a za buba dzoh 'uhutni. 
\p  
\v 4 'Ink'ez ts'iyanne ba lubret bumoodihne 'ink'ez Moses be 'udustl'us 'uk'ununáguzne cha, 'enne ts'iyawh Herod 'anih ubudani'. 'Et 'enne buts'un nahootá'alh Christ ndet whutileh. 
\p  
\v 5 'Ink'ez huyulhni, “Yun k'ut Judea, keyoh Bethlehem whuz'ai-un, 'et whutileh. Ndet la nus hoo'en-un 'et 'uk'ehónguz-un, 'et whuz un'a nja dutni, 
\q1  
\v 6 ‘Yun k'ut Judea ts'e keyoh Bethlehem whut'enne, 
\q2 'et nohkeyoh hoontsool-unyaz hoonli, 
\q2 'et hoonts'i tube whudizti' tileh. 
\q1 'Alha nohkeyoh 'et whuts'un 'ilhoghun moodih ncha-un, 'et whusatiyalh. 'Ink'ez sdune'ne, 
\q2 Israel oots'u haindene, 
\q2 'enne 'usbai ghunline k'un'a bughu tileh.’” 
\p  
\v 7 'Et Herod whu'iz whe ndunne whunihne 'anih ubudáni'. 'Enne buts'un nahootá'alh ha 'et soo ndet dzin nts'oya hoozulh whe ndi sum be hóodiltsai. 
\p  
\v 8 'Et hukw'elh'az keyoh Bethlehem ts'e whebalh'a' 'ink'ez ndúbulhni, “Ahdulh 'ink'ez howa 'óohli whe ts'oodun nalhtih. 'Et nawhah'ai de, nts'e 'unt'oh 'et sts'ótl'a khuni ooh'alh. Si cha whuz tisyalh oots'u teni' ntisdzilh ha.” 
\p  
\v 9 'Et lerwe 'et ndúbulhni whe 'aho whehándil. 'oh whuya hidulh whe khunsul ndai la ndi sum ndaz ts'e hinalh'en-i, 'i hitilh'en 'ink'ez 'ants'i butso ults'ulh. 'Et nts'e la ts'oodun usda-un 'on do, 'et lhghá nelts'ut. 
\p  
\v 10 'Et ndet la sum hinalh'en da' 'uk'enus huhóont'i' k'et 'aw 'uhoot'e' ait'oh. 
\p  
\v 11 'Et 'ink'ez yoh dahunindil whe ndun ts'oodun hitilh'en. Ooloo Mary 'en cha 'et usda. Hibut nachánilya 'ink'ez hits'un teni' nalhdzun. Unzoo-i huye 'úzdla-i hidah lhch'az hiyilhchoot whe ndai la unzoo-i hiyé hahúyanla 'ink'ez hits'u hítilhdil. Gold, yoo sooltsun-i frankencense huyulhni, 'ink'ez yoo Myrrh huyulhni cha, 'i ts'iyawh hits'u hítilhdil. 
\p  
\v 12 'Ink'ez Yak'usda bubul be bugha dáni' 'et 'aw Herod 'en ookw'unaoohdilh junih budáni' 'Et huwa 'uts'o whuya dukeyoh ts'e whenáhidilh. 
\s1 Joseph, Mary te, 'ink'ez Sizi bulh yun k'ut Egypt ts'uwhútni, whuz whehándil 
\p  
\v 13 'Et 'awet whunáhidil hukw'elh'az neMoodihti oolizas Joseph nute whe benghun whe hóodiltsai. 'Et 'uyulhni, “Dudinyaih, ndun ts'oodun ooloo bulh ubilhchoot 'ink'ez yun k'ut Egypt 'a cho whuz ubalhtelh! 'Et nohdutásnelh 'et whuts'un 'et dólhts'i'! 'Et 'awet 'áho Herod ts'oodun yuka it'á'elh yutuzilhghelh ha!” 
\p  
\v 14 'Inka 'ulhdzis dunadija 'ink'ez ts'oodun ooloo bulh ubilhchoot 'ink'ez yun k'ut Egypt ts'outni whuz whehándil. 
\p  
\v 15 'Et Herod datitsah whuts'un 'et 'udutálts'ilh. 'Et ndúhut'en whe neMoodihti nyoon nus hoo'en-un, 'en be daja ni la 'et whunilhchoh 'oh tune' whust'en whe nja dutni, “Sye' 'anih dasni' yun k'ut Egypt whuch'a naooja' ha.” 
\s1 Lerwe Herod lhuganne ubulhni, “Keyoh Bethlehem ts'e duneyaz nat yus k'ut be suli'ne, 'enne ts'iyawh huboohghan” 
\p  
\v 16 'Et 'awet Herod t'eoonanzin ndunne whunihne, Majine huyulhni, nahinan'a, 'et huwa tube hunilch'e. 'Inka nts'oya hoozulh Majine hidáni' whe whulohne lhuganne keyoh Bethlehem ts'e whebalh'a'. 'Et 'ubulhni, 'et keyoh whut'enne ts'iyawh 'ink'ez whunat whut'enne cha mbene la duneyaz nat yus k'ut be suli'ne 'ink'ez whuts'un whudilhdzulhne cha, 'enne ts'iyawh huboohghan. 
\p  
\v 17 'Et whuz un'a nyoon nus hoo'en-un Jeremiah huyulhni, daja ni la 'et ts'iyawh whunilhchoh 'oh tune' whust'en whe nja dutni, 
\q1  
\v 18 “'Et keyoh Ramah buyiz dahts'o da' tso yahalhduk 
\q2 'ink'ez duduzkeh k'ehúnintai. 
\q1 Rachel ts'oodunne buk'etso yahalhduk. 
\q2 'Aw budzi do na'otneh ait'oh, 
\q1 bubuzkehke gak huzdli' 'et huwa.” 
\s1 Joseph, Mary, Sizi cha, keyoh Nazareth huwhútni hudutálts'ilh 
\p  
\v 19 'Awet Herod dazsai whe' hoont'oh. 'Et 'awet Egypt yun k'ut ts'e neMoodihti oolizas Joseph huwunute whe benghun néwhults'ut. 
\p  
\v 20 'Et ndúyulhni, “Dudinyaih! Ts'oodun duloo bulh nabilhchoot. Israel yun k'ut whuz nahdulh. 'Et whutso da' mbene la ts'oodun yukúniztaine hituzilhghelh ha, ts'iyawh yahadla.” 
\p  
\v 21 'Inka dudinya. Ts'oodun duloo bulh nabílhchoot 'ink'ez Israel yun k'ut ts'e whenáhidil. 
\p  
\v 22 'Et hoonts'i Joseph whulh udants'o Herod ooye' Archelaus huyulhni, 'en dubá k'edanya 'ink'ez 'andit Judea yun k'ut whulerwe unli. 'Et whuz tiyalh whe nuljut whe howu nusúti 'et Yak'usda yugha dáni'. 'Et huwa Galilee yun k'ut ts'e whuz whehándil. 
\p  
\v 23 Whuz hoozdil whe keyoh Nazareth huwhútni, 'et hudutálts'ilh. 'Et whuz un'a nus hoo'enne daja hutni la, 'oh túne'whust'en whe nja duhútni, “'En Nazareth whut'en-un hidutánelh.” 
\c 3  
\s1 John dune too be 'ulh'en-un ts'iyanne ubulhni, “Mbe la Yak'uz k'une' whul'en-un, 'awet nilhdukw netoh 'utit'elh” 
\p  
\v 1 'Et 'oh whuya hoozulh whe John dune too be 'ulh'en-un Judea yun k'ut dune lhuhoot'i ts'e, whuz whinya 'ink'ez dune bulh yalhduk. 
\p  
\v 2 'Et 'ubulhni, “Noheni náhandunoohleh. Mbe la yak'uz k'une' whul'en-un nohtoh 'utit'elh-un, 'awet nilhdukw.” 
\p  
\v 3 Ndun 'en nus hoo'en-un Isaiah yughu yalhduk whe nja dutni, 
\q1 “Dune lhuhoot'ih ts'e dune yiz dusts'ai whe 'ultus-un huyih whe nja dutni, 
\q1 ‘NeMoodihti ooti lhaoodahleh! 
\q2 Ooti soo lhts'eoodiz'a ooba whulhtsi.’” 
\p  
\v 4 'Ink'ez John dich'oh khuna-i gha, camel huyulhni, 'i ye dune unli 'ink'ez 'uzus se be ts'udilh'oo. Tulk'us cho 'ink'ez ts'ihnatl'uz 'ohwhi ya'alh. 
\p  
\v 5 'Et 'oh da' dunene ts'iyawh ndunne Jerusalem whut'enne cha, Judea yun k'ut whut'enne cha, 'ink'ez dunene 'et 'ukoh Jordan whut'enne, 'enne ts'iyawh John gho nindil. 
\p  
\v 6 'Ink'ez dulubeshi ghun hunahuhoolnuk whe 'et nyo 'et 'ukoh Jordan John 'en too be' balh'en. 
\p  
\v 7 'Et hoonts'i lhane Phariseene 'ink'ez Sadduceene cha, 'enne too be' hutilnelh ha highu nindil. 'Et hubunilh'en whe ndúbulhni, “Nohni lubezo tl'ughus buzkehke le'áht'oh! Yak'usda lubeshi 'ulh'enne bubulh huntalch'oh-un, 'et whuz de hóolts'ulh, mbe 'unohulhni whuch'a úlhwus? 
\p  
\v 8 Whute lubeshi ch'a noheni nahandunoohleh de, ndaht'en-un ts'iyanne t'ehonózin ndaht'oh la. 
\p  
\v 9 'Ink'ez khun lhts'un njan dudoohtni' junih, wheni Abraham oots'u haindene 'uts'int'oh. 'Alha ts'ih'un un'a nohdusni Yak'usda soo 'ultus whe 'unt'oh, ndi tse 'i hoonts'i 'i be Abraham oots'u haindene ubutilhtselh. 
\p  
\v 10 Njan soo cho whunulh'en, nohni duchun lé'aht'oh. 'Awet tsetselh be lhadínt'oh-un. 'Et nohni whulohne duchun oomai' hooloh-i, 'et ndaht'oh. 'Andit hoonts'i ndai la oomai' hooloh-i, tsetselh ooghih tubulh tsuhídantsel 'ink'ez hidutálhk'un. 
\p  
\v 11 Noheni nahunduníhla 'et huwa too za-i be too be' nohúsdla. 'Et whuz un'a za 'unohus'en. 'Et hoonts'i 'ilhoghun sk'elh'az whusatiyalh-un, 'en sanus dizti' whe 'unt'oh. 'Aw ookegon 'i hoonts'i ooba nétisdlelh huba soo lhe'usdzoo'. Ndun 'en Ndoni 'ink'ez kwun bulh 'i be too be' nohtilh'elh. 
\p  
\v 12 Lufoos tl'o mai' be tahawhúlts'ih-i, 'i 'ahoolhyiz nuyútun. 'Ink'ez ndi tl'o mai' yutahawhúlhts'ih-i, 'ink'ez yuk'ut 'ut'en-i cha yuk'ut lhadút'ih de, 'ink'ez yuna'ulhdoh. 'Ink'ez ndi mai ndai la lhaduja-i, 'i ts'iyawh deínudzih 'ink'ez mai bayoh ts'e wheyúli. 'Et hoonts'i ndai la ndi kwun 'aw nalhnusne, ndi oot'ooz, 'i be duták'un,” ubulhni. \fig |src="cn01655b.tif" size="col" copy="©1978 David C. Cook Publishing Company" ref="Matthew 3.12" \fig* 
\s1 John, Sizi too be 'ulya 
\p  
\v 13 'Et 'awet Sizi Galilee yun k'ut huwhutni ts'e hainya. 'Et Jordan koh ts'oozya John too be' yutilelh ha. 
\p  
\v 14 'Et hoonts'i John dah yúlhni. “Nyun too be' sonleh huba' hoont'oh. 'Ink'ez di ha si sts'ú tinya too be' nyoosdleh ha?” 
\p  
\v 15 'Et hoonts'i Sizi 'uyulhni, “Whute soo cho nilh'en, be ts'ih'un 'uhoont'oh-i, 'et ts'iyawh lhaoodutanelh whe' hoont'oh.” 'Et 'awet whute 'et dúyinla. 
\p  
\v 16 Sizi too be' yinla whe tooz hanája ibulh 'et 'aho 'en ba 'aho yak'uz daha' dankez 'ink'ez Yak'usda Ooyughi yunilh'en whe ndus de dut'ai, 'i dove huyúlhni, 'i k'un'a Sizi ookw'édinde. 
\p  
\v 17 Khunsul ndus de 'uwhutni, “Ndun 'en sYe' ook'esi' 'en 'unt'oh, 'ink'ez tube 'en bulh hoonúst'i',” ni. 
\c 4  
\s1 Netsudule Sizi tank'us yúnoolht'i hukwa' yulh'en 
\p  
\v 1 'Awet Sizi nts'e la dune lhuhoot'ih ts'e Ndoni 'onilha Sizi whuz wheyálh'a' netsudule yootálhdzih ha. 
\p  
\v 2 Dit whunizyat dzin sóo honih, 'et hukw'elh'az 'awet ooye'ílts'ul. 
\p  
\v 3 'Et yóolhdzih-un, 'en yughu ninya 'ink'ez 'uyúlhni, “'Alha Yak'usda ooYe' inli de, ndi tse lhes oole' dini.” 
\p  
\v 4 'Et hoonts'i Sizi yulhni, “Ndiz un'a Yak'usda ooghuni k'ut 'uk'usgus whe nja dutni, ‘'Aw lhes za iloh dune yuk'ukhuna, 'et khuni ts'iyawh Yak'usda daja ni, 'i cha hik'ukhuna.’” 
\p  
\v 5 'Et netsudule keyoh whudizti' ts'e yulh whin'az, 'ink'ez njan lugliz whucho 'udedo hukw'ut, 'et soo whuban nenilhya. 
\p  
\v 6 'Ink'ez 'uyulhni, “'Alha Yak'usda ooYe' inli de, njan whenghe' dudintneh! 'Alha 'uk'ehooguz whe nja dutni, 
\q1 ‘Yak'usda oolizas butl'ahon'ai whe 'enne nyun nka huwuhinli, 
\q2 'ink'ez dula be do nyuhóotatun, 
\q1 'et huwa 'aw nke tse t'aoonalh ait'oh.’” 
\p  
\v 7 'Et Sizi nduyulhni, “Cha za njan 'uk'ehooguz whe nja dutni, ‘Khun te Moodihti nYak'usda 'en nantan'ah hukwa ólhdzih junih!’” 
\p  
\v 8 'Et doo cha za netsudule ndi dzulh 'udedo hadít'ai ts'e whuz yulh whin'az. 'Et ndi yun k'ut ndulcho whe whenulhtun lerwene bube 'ut'en k'oh 'ink'ez huyé dizti'-i, 'i cha. 
\p  
\v 9 'Ink'ez 'uyulhni, “Ngwutsi be neninya 'ink'ez sts'u téni' nilhdzun de, 'et de ndi ts'iyawh, nch'e' tileh!” 
\p  
\v 10 'Ink'ez Sizi yulhni, “Satan naindalh! 'Et 'uk'ehooguz whe nja dutni, ‘Moodihti nYak'usda, 'aw 'en za oobut negwutsi be nets'iyaih, 'ink'ez oots'u téni' uznilhdzun, 'ink'ez 'en za ba né'ts'ut'en.’” 
\p  
\v 11 'Et 'awet netsudule whenaja 'ink'ez khunsul lizasne whusahándil 'ink'ez hiba ne'ut'en. 
\s1 Sizi dune bubulh yawhénilhduk 
\p  
\v 12 'Awet Sizi whulhúdants'o John 'ahuyan'ai. 'Et huwa Galilee yun k'ut ts'u whinya. 
\p  
\v 13 'Et keyoh Nazareth whuch'a séya 'ink'ez keyoh Capernaum whuz oozya 'ink'ez 'et tidalh. Njan keyoh 'et taba whuz'ai. 'Et lhendun yun k'ut Zebulun 'ink'ez Naphtali lhodin'ai. 
\p  
\v 14 'Et Isaiah nus hoon'en-un, 'et howu yailhduk-un lhaóodotneh whe nja dutni, 
\q1  
\v 15 “Yun k'ut Zebulun 'ink'ez yun k'ut Naphtali, 
\q2 ya too' k'uz wheti 'et whuz'ai. 
\q1 'Et njan Galilee yun k'ut, 
\q2 'i 'udun yun k'ut whut'enne, 
\q2 'enne buba 'uhoont'oh. 
\q1  
\v 16 Mbene la tsalhgus yo dilhts'ine, 
\q2 'enne kwun uncha-i hitilh'en. 
\q1 Nts'e la yun k'ut sa whus'ih whuz'ai-un, 
\q2 ndi sa whus'ih, 'i be daztitsah-i, 'i 'unt'oh. 
\q1 Mbene la 'et whut'enne, 'enne be hóot'en unli-i, 
\q2 'i be buba yulhkai le'hint'oh.” 
\p  
\v 17 'Et whuts'un Sizi dune bubulh yawhénilhduk whe ubúlhni, “Noheni náhandunoohleh! Yak'uz k'une' whul'en-un 'awet nilhdukw suli'.” 
\s1 Dine lho ha 'ut'enne Sizi, “'Anih,” ubúlhni 
\p  
\v 18 'Awet bunghun Galilee taba Sizi 'oh whuya uyalh 'et nane dune lhulhutsinke ubutilh'en. 'Ilhoghun 'en Simon cha huyulhni Peter cha huyulhni, 'et 'ilhoghun bulhutsin 'en Andrew huyulhni. 'Enne lhembilh tahúyalhdil lho ha 'ut'enne hinli. 
\p  
\v 19 'Ink'ez 'ubulhni, “Nanúlht'oh sunih'us. Dune ha 'ut'enne nohtiselh.” 
\p  
\v 20 'Et 'aho dulembil hiladitni 'ink'ez hik'oh ts'e oot'en ha huyuntiz'az. 
\p  
\v 21 'Et 'on 'un hidulh 'et doo cha za nane dune tilh'en. 'Enne cha lhulhutsinke Zebedee ooye'ke. 'Ilhoghun James huyulhni 'ink'ez 'ilhoghun John huyulhni. Dubá te ts'i cho be húdilhts'i 'ink'ez dulembil nahuyutl'oo. 'Et Sizi bukahizya. 
\p  
\v 22 'Et 'aho dubá bughu déhain'az 'awet ye usda whe 'ink'ez Sizi hik'oh ts'e oot'en ha hiyuntiz'az. 
\s1 Sizi lhane dune undudáne soo ná'bulh'en 
\p  
\v 23 'Et 'awet Galilee yun k'ut Sizi ndulcho nuya whe Lizwifne bulugliz 'et dune bubulh yálhduk. Mbe la yak'uz k'une' whul'en-un, 'en ghun khuni unzoo-i be bubulh yálhduk. Dune toh mbe la ndudane 'ink'ez ooyust'e tétsunne, 'enne cha ts'iyawh soo na'bulh'en. 
\p  
\v 24 'Et Syria yun k'ut whut'enne, 'enne cha ts'iyawh hiyulh údits'o. 'Et huwa mbene la lhenyoo dada bé undudane, 'ink'ez mbe la 'on nus bulh 'últs'ulhne cha, mbe la ntsi'-i nudúde ooyudindane cha, whusnine cha 'ink'ez ookaootuzukne 'ink'ez delh dusnine cha, 'enne ts'iyawh Sizi ts'u buhoozdla whe ts'iyawh soo ná'binla. 
\p  
\v 25 'Ink'ez Galilee yun k'ut whut'enne, Decapolis yun k'ut whut'enne cha, 'ink'ez keyoh Jerusalem whut'enne, Judea yun k'ut whut'enne cha, 'ink'ez Jordan koh 'on yah whéya whut'enne cha, 'enne ts'iyawh 'et huldlai k'et 'aw 'uzdooni' ait'oh. 'Et 'ultsukne 'ilhunaoosdil 'enne ts'iyawh hiyuntizdil. 
\c 5  
\s1 Sizi ubulhni, “Dawhuldzoo'-un 'et bughá whults'ut” 
\p  
\v 1 'Awet Sizi 'ilhunaoosdilne ubunilh'en whe ndo dzulh enun ts'e ndo whinya 'ink'ez 'et nátl'adida'. Mbene yugha hódul'ehne, 'enne hits'oozdil. 
\p  
\v 2 'Et 'awet whuwhebondunilh'e', 'et nja dúbulhni, 
\q1  
\v 3 “Mbene la ndunne lubeshi 'ulh'enne, 'enne bugha budzi tel'en unline, 
\q2 'enne yak'uz k'une' whul'en-un ooch'e' huzdli', 
\q2 'et huwa 'uk'enus hoonzoo-un bugha whults'ut. 
\q1  
\v 4 Mbene la dulubeshi ghu ni unline, 'enne 'uk'enus k'enánit'ane hutileh. 
\q2 'Enne 'uhuja 'uk'enus hoonzoo-un bugha whults'ut. 
\q1  
\v 5 Mbene la yo údudildzunne, 
\q2 'enne ndi yun k'ut buch'e' whutale 'et huwa 'enne 'uk'enus hoonzoo-un bugha whults'ut. 
\q1  
\v 6 Mbe la Yak'usda ye ts'ih'un 'unt'oh-i tube yuka' ninzunne, 'enne ndet hukwa' whuninzun-un, 'et bugha óotalts'ulh. 
\q2 'Et huwa 'enne 'uk'enus hoonzoo-un bughá whults'ut. 
\q1  
\v 7 Mbe la 'uyoonne gha te'ninzunne, 'enne Yak'usda cha bugha te'untazeh, 
\q2 'et huwa 'enne 'ukenus hoonzoo-un bughá whults'ut. 
\q1  
\v 8 Mbene la oodzi dutsun lhilohne, 
\q2 'enne k'at le Yak'usda huti'elh 'et huwa 'enne 'uk'enus hoonzoo-un bughá whults'ut. 
\q1  
\v 9 Mbe la ts'ih'un lhts'un 'uhoot'e'ne, 'enne Yak'usda buzkeh ubodutánelh. 
\q2 'Et huwa 'uk'enus hoonzoo-un bughá whults'ut. 
\q1  
\v 10 Mbene la ts'ih'un 'uhint'oh huwa dzoh nubuhulhdehne, 'enne yak'uz k'une' whul'en-un, 'et buch'e' hinli. 
\q2 'Et huwa 'uk'enus hoonzoo-un bughá whults'ut. 
\p  
\v 11 Nkede suba dune nohch'az yahutilhduk 'ink'ez dzoh nunohotilhdzut, 'ink'ez ts'iyaitsuk whuts'it khuni dutsun-i be nohch'a 'uts'un un'a yahutilhduk, 'et si sgha whuz un'a dune dzoh nunohulhdzut de, 'et 'uk'enus hoonzoo-un nohghá whults'ut. 
\p  
\v 12 'Et 'andit whuts'un k'udada whunúlhni 'ink'ez 'uk'enus hoonáht'i'! 'Alha yak'uz hooncha whe nohba k'elha whutaleh. Soo cho whunulh'en, njan mbe la nohtso nus hoo'en inle'ne, 'enne cha whuz un'a za bube huzula inle'. 
\s1 Ndi yun k'ut lubeshi 'ulh'enne buba be hoot'en-i 'ink'ez lisel cha léaht'oh 
\p  
\v 13 Nohni ndi yun k'ut lubeshi 'ulh'enne buba lisel leaht'oh. 'Et hoonts'i lisel 'aw nalhuwhúlhnih 'ulhih te, nts'en'a suba doo cha lisel oonawhúlni' naoodle'? 'Et whuz un'a 'aw hoonli ba lhe'ízoo' whe 'unt'oh. 'I 'ants'i dune tehúyulhkuk 'ink'ez hik'unúdilh whe' hoont'oh. 
\p  
\v 14 Ndi yun k'ut dunene buba be hoot'en-i le'aht'oh. 'Aw keyoh whuti dzulh k'ewhah'ai de, 'aw whuntoolh'ih ait'oh. 
\p  
\v 15 'Et whuz un'a za dune ndi too dizk'un naidulhk'an 'ink'ez 'aw chalhyal yunedóo'alh ait'oh. 'Et k'us lutab k'eyíta'alh 'ink'ez kwun 'i gha ts'iyanne huwhuntilh'elh. 
\p  
\v 16 'Et whuz un'a za nts'en'a la dune ba be hoot'en-i unli, 'et whuz un'a nohni cha nohedútadi. 'I be nohe'ut'en unzoo-i daldzoo' la, 'et whuz un'a dune yuntilh'elh 'ink'ez nohBá yak'uz usda-un, 'en 'uk'enus hidutálhti'.” 
\s1 Sizi ubulhni, “Moses be 'udustl'us 'ink'ez nus hoo'enne bube' 'udustl'us ts'iyawh lhadútisdleh” 
\p  
\v 17 “Moses be 'udustl'us 'ink'ez nus hoo'enne bube' 'udustl'us 'i gak natiselh 'et hukwa whusásya noohzin junih. 'I ts'iyawh lhadútisdleh 'et hukwa whusásya. 
\p  
\v 18 'Alha' dusni whe nohdusni, Moses be 'udustl'us Hebrew bughuni k'un'a hoont'um-unyaz whe 'uk'eguz-un 'ink'ez hoont'um-unyaz usgus-un, ndet 'uwhulhni, 'et ts'iyawh 'et ndúhooja de, 'et whuts'un 'aw ndi yun 'ink'ez yak'uz cha 'etsul 'uhóneh ait'oh. 
\p  
\v 19 Ndai khuni neghalts'ut-i, 'i k'une' ts'oot'en huba' hoont'oh, 'aw hoontsool-unyaz hoonts'i dune k'uhinínyuz de, 'ink'ez 'uyoonne cha whuz un'a za whubodutilh'eh, dune ndut'en de, 'et nts'e la yak'uz k'úne' whul'en-un, 'en 'aw hoonli lhiloh-un hidutánelh. 'Et hoonts'i ndi khuni netl'adilts'ut-i, dune ts'iyawh hik'une' 'ut'en de, 'ink'ez 'uyoonne cha whuz un'a 'az whubodutilh'eh, dune ndut'en de, 'et nts'e la yak'uz k'úne' whul'en-un, 'et 'i be ncha-un 'unt'oh hidutánelh. 
\p  
\v 20 Ts'ih'un nohdusni ndunne Moses be 'udustl'us 'uk'ununáguzne 'ink'ez Phariseene cha, 'enne hiye ts'ih'un un'a 'unt'oh-i 'ink'ez nohni be ts'ih'un un'a aht'oh-i, 'i buba nus ahzoo de, 'et de za nts'e la yak'uz k'une' whul'en-un ts'e ts'u tíhdulh. 
\s1 Nyulh dune hoonli-unyaz whe nch'az ditni t'ewhunínzun de, ooghu ninya 'ink'ez k'eke naooltselh 
\p  
\v 21 “'Et whutso da' whulh udahts'o nts'en'a dune daja hutni whe nja duhutni, ‘Dune solhghelh junih,’ 'ink'ez mbe la dune silhghi-un, 'et hukw'un'a buba nahutiyeh whe' hoont'oh. 
\p  
\v 22 'Et hoonts'i sich'oh 'unohdusni, mbene la 'ants'et dulh dune bulh hunilch'e de, 'enne ts'iyawh buba nahutideh whe' hoont'oh. 'Et mbe la dudulh dunene ‘Raca!’ 'ulhníne de, 'et ndi khuni dakelh k'un'a ‘ntsi'!’, ni whe 'utni, 'i gha nahiyilh-un but hutiyin. 'Ink'ez cha za mbe la dune, ‘Whuzini dune inli whe 'int'oh!’ yulhni de, mbe la ndutnine, 'enne tube whewhúnujut-un kwuncho yo ts'u buhutinoh. 
\p  
\v 23 'Et huwa hoonliyaz loodel k'ut howa' tán'alh-i, 'ink'ez nyulh dune hoonli-unyaz whe nch'az ditni t'eoonínzun de, 
\p  
\v 24 'et whutso nyulh dune bulh k'eke nalhoolhtselh. 'Et hukw'elh'az 'et 'andit za ndai la loodel k'ut huwa' tan'alh-i, 'et huwa óon'alh. 
\p  
\v 25 'Et khun dune hoonli-unyaz whe nch'az ditni de, 'aho oots'un ts'ih'un na'honleh. 'Et nahiyilh-un but nényutalhtelh 'et whutso ndóneh. 'Et 'aw ndúlhinel de, 'en mbe la nch'az ditni-un, 'en nahiyilh-un but nényutalhtelh. 'Et nahiyilh-un, 'en neilhchuk-un tl'anyutilhtelh 'ink'ez nch'az dána'duta'alh. 
\p  
\v 26 Ts'ih'un un'a nohdusni, ndai la ts'iyaitsuk ook'elha whutilhtselh 'et whuts'un, nts'en'a suba whuch'a naoohja'? 'Aw oohneh ait'oh! 
\s1 Mbe la ts'eke yunilh'en whe dudzi yo whe njan duninzun, “Bulh nínta' tist'elh hukwa' nuszun,” 'et 'uda' yulh ninta' 'ant'en whe 'unt'oh 
\p  
\v 27 “'Et whutso da' whulh udahts'o nts'en'a dune daja hutni whe nja dúhutni, ‘'Uyoon ts'eke bulh ninta' ont'en junih.’ 
\p  
\v 28 'Et hoonts'i sich'oh 'unohdusni mbe la ts'eke yunilh'en whe dudzi yo whe nja duninzun, ‘Bulh nínta' tist'elh hukwa' nuszun,’ 'et 'uda' yulh ninta' ant'en whe 'unt'oh. 
\p  
\v 29 'Et nailhni ts'e nyuna 'i be lubeshi inla de, hanón'alh 'ink'ez 'un ntolh'is. 'Et 'on nus soo' hoont'oh nohyust'e ndulcho dutágun-un whanus soo' hoont'oh whe' hoont'oh. 
\p  
\v 30 'Ink'ez nailhni ts'e nla be nínta' nint'en de, k'ont'as 'ink'ez 'un tolh'is. 'Et 'on nus soo' hoont'oh nohyust'e ndulcho dutágun-un whanus soo' hoont'oh. 
\s1 Dune ts'eke bulh lhgho dilhts'i-un, 'et 'ilhiz wheni 'otát'elh 
\p  
\v 31 “'Ink'ez 'et cha ndutni ‘Mbe la du'at 'etsul 'utilelh-un, 'et du'at 'udustl'us ye 'etsul itilelh-i yutl'ayóolhchoos huba' hoont'oh.’ 
\p  
\v 32 'Et hoonts'i sich'oh 'unohdusni oo'at 'uyoon dune bulh ninta' 'ant'en hukw'elh'az 'et huwa za ndi 'udustl'us dai la ye 'etsul itilelh-i yutl'ayóolhchoos huba' hoont'oh. 'Et whuz un'a ndúlhinel whe du'at 'etsul 'uyinla de, 'et de dich'oh du'at ninta' 'ant'en-un yulhtsih. 'Ink'ez ndun ts'eke 'uyoon dune ghu nasda de, 'et ndun dune 'en cha ninta' ut'ih-un unli whe 'unt'oh. 
\s1 Khun nyunch'oh nghuni k'ónyis junih 
\p  
\v 33 “'Et doo cha za niz de whudizulh da' ts'iyawh t'eoonáhzun 'uda' dune daja hutni whe nja duhutni, ‘Khun nyunch'oh nghuni k'ónyis junih. 'Et k'us neMoodihti whe oots'u nahizinya 'et whunilhchoh hukw'un'a 'ont'en huba' hoont'oh.’ 
\p  
\v 34 'Et hoonts'i sich'oh 'unohdusni, khun whuz un'a te ndudóohni junih. Khun ‘Yak'uz whunalh 'udusni,’ doohtni' junih. 'Alha yak'uz ts'e Yak'usda kw'uts'uzda cho dizti'-i, 'i 'et us'ai. 
\p  
\v 35 K'us ‘Ndi yun k'ut whunalh dusni,’ doohtni' junih. Yak'usda duke yuk'udílh'ez-i, 'i 'unt'oh 'et huwa. K'us khun te ‘Keyoh Jerusalem whunalh 'udusni,’ doohtni' junih. Lerwe k'us dizti'-un ookeyoh whucho 'uhoont'oh 'et huwa. 
\p  
\v 36 K'us khun te ‘Whe khusna-un whenahoosyeh,’ junih. 'Aw 'ilhudzin hoonts'i 'aw huwa naoodooh'ah ait'oh 'et huwa. 
\p  
\v 37 'Et k'us ndiz un'a nja dúdoohtni, 'et 'awet ‘A,’ dahni, ‘A,’ 'unt'oh. 'Ink'ez ‘'Awúndooh,’ dahni de cha, ‘'Awúndooh,’ 'uhoont'oh. 'Et 'uts'un un'a 'udutihnelh de, 'et de ntsi'-un ts'u hadutídoh whe 'unt'oh. 
\s1 Dune ntsi'-un, 'en ooch'az nónt'i 
\p  
\v 38 “'Et whutso da' whulh udahts'o nts'en'a dune daja hutni inle' whe nja duhutni, ‘Dune oona hoos̱'en silhtsi de, nyunch'oh nyúna be hoos̱'en tanleh. 'I be kw'elha whutalhtselh. 'Et ooghu dádilhchus de, nyunch'oh nghoo be kw'elha whutalhtselh,’ hutni inle'. 
\p  
\v 39 'Et hoonts'i sich'oh 'unohdusni, dune ntsi'-un k'ól'en junih. 'Et k'us mbe la nailhni ts'e nohnizkuk de, 'et 'intl'us ts'e oots'un nándunont'ah. 
\p  
\v 40 Khun mbe la nts'oot'an nahiyilh-un but nts'u yuka 'utni de, ndzoot 'i cha ooghá yolhchoos. 
\p  
\v 41 'Et mbe la dune dawhuldzoh la ha tányalh nyulhni de, 'et nat 'et 'uwhuldzoh ts'e bulh haóonya'. 
\p  
\v 42 'Et mbe la hoonliyaz nts'u há' 'utni de, 'i ooghá yon'alh. Hoonliyaz dughu sinla-un yulhni de, khun ooch'az naool'ah junih. 
\s1 Nohch'az ditnine buk'eoohtsi' 
\p  
\v 43 “Njan cha whulh údahts'o nts'en'a dune daja hutni whe 'et nduhutni, ‘Nyenghoh whut'i-un ook'eoontsi' 'ink'ez nch'az ditni-un, 'en oots'u doni'.’ 
\p  
\v 44 'Et hoonts'i sich'oh 'unohdusni, nohch'az ditnine hoonts'i buk'eoohtsi'. Mbene la denóhdulene, 'enne khuni unzoo-i be bubulh yaóolhduk. Mbene la nohts'u dutnine, 'enne buts'un oohzoo'. 'Et mbene la hoontsi'-un nohts'un ne'hut'en 'ink'ez dzoh nunohulhdzutne, 'enne cha buba tenadoohdli huba' hoont'oh. 
\p  
\v 45 'Et whuz un'a ts'iyanne whunúlhtun nohBá yak'uz usda-un, 'en buzkeh ahli whe 'aht'oh. 'Alha Yak'usda ndi sa ntsi'ne 'ink'ez unzoone lhgha ndi sa buk'idindi. 'Ink'ez ts'ih'un 'unt'ohne 'ink'ez ts'ih'un lhe'it'ohne, 'enne cha lhgha buk'ut nawhúlhtih. 
\p  
\v 46 Ndiz un'a nja duhoont'oh, mbene nohk'entsi'ne, 'enne za buk'ehtsi' de, di suba nohgha óokat? Gak! Ndunne sooneya nalhdzoohne, 'enne cha whuz un'a za nduhut'en. 
\p  
\v 47 'Ink'ez nohulhutsinke, 'enne za hadih budahni de, 'et 'uyoonne anus ahzoo na'dunáhzun eh? Gak! Ndunne sooneya nalhdzoohne, 'enne cha whuz un'a za nduhut'en. 
\p  
\v 48 Ndiz un'a nja dútiht'elh, nohBá yak'uz usda-un, 'en dant'oh whe ts'ih'un 'unt'oh, 'et nohni cha whuz un'a za 'ooht'e' huba' hoont'oh. 
\c 6  
\s1 'Ut'en unzoo-i 'ulh'en de, khun ts'iyanne nalh tube cho whe' 'ududolhti' junih 
\p  
\v 1 “Soo cho huwahli! Khun tel'enne gha' tih'alh de, ts'et whucho ndóht'en junih. 'Et whuz un'a ndaht'en de, nohBá yak'uz usda-un, 'en 'aw nohba k'elha hoolhtselh ait'oh. 
\p  
\v 2 'Et huwa tel'enne gha' tih'alh de, khun ts'iyanne nalh tube cho whe' 'ududolhti' junih. Ndunne duba na'udzoo'ne, 'enne 'et whuz un'a 'et duhút'en. Lizwif bulugliz k'us ti whulheguz-un 'et ts'iyanne ubunoolh'en ha, 'et nduhut'en. 'Alha' dusni, mbene la ba k'elha whutalehne, 'uda' buba k'elha whuzdli' whe' hoont'oh. 
\p  
\v 3 'Et hoonts'i tel'enne gha' tih'alh de, mbene la 'uk'enus nohts'un unzoone, 'enne hoonts'i bunanto 'oohneh. 
\p  
\v 4 'Et whuz un'a 'uyoonne t'ehonúszun 'et daht'en whe tel'enne gha 'áh'aih. 'Ink'ez nohBá yak'uz usda-un, 'en dahoont'oh huwa 'et ndaht'en-un, 'et ts'iyawh nohnilh'en whe 'unt'oh. 'Et huwa dich'oh ts'iyanne but hoonzoo whe nohba k'elha whutilhtselh. 
\s1 Ndiz un'a tenadoohdli huba' hoont'oh 
\p  
\v 5 “'Et tenadahdli de, khun duba na'udzoo'ne k'oh ts'e tenadoohdli junih. 'Enne whuz un'a lizwif bulugliz cha nódilhya, k'us ti whulhetoh cha, 'ants'i huhóont'i' whe whuz un'a tenahududli ts'iyanne ubunoolh'en ha. 'Alha' whe nohdúsni, mbe la ndut'enne buba k'elha yutáleh, 'i 'uda' buba k'elha yuzdli' whe' hoont'oh. 
\p  
\v 6 'Et nohni tenadutihdli de, nohnich'oh whaht'i-un, 'et danaoohdilh 'ink'ez dána'dihtan whe tenadoohdli. 'Et ndaht'en de 'et la nohBá lhist'en-un, 'en 'unt'oh, 'et nts'en'a la 'et ndaht'en de, ts'iyawh nohnilh'en. 'Et huwa dich'oh ts'iyanne nalh nohba k'elha whutilhtselh. 
\p  
\v 7 'Et tenadahdli de, lhat cho 'oh lhunahoohdeh junih. Whuz un'a lhendun keyoh whut'enne k'un'a tenahududli. 'Enne lhai khuni be tenahududli de, 'i be Yak'usda budutáts'o huninzun 'et huwa. 
\p  
\v 8 Khun te 'enne buk'un'a 'udoohtni' junih. NohBá ndet hukwa oodutalhkut-un, nohtso da' t'ewhunínzun whe 'unt'oh. 
\p  
\v 9 'Inka ndiz un'a tenadoohdli, 
\q1 ‘NeBá yak'uz sinda. 
\q1 Nyoozi' dóti'. 
\q1  
\v 10 Dahoont'oh whe lerwe inli, 
\q2 'et cha nets'ó toolts'it. 
\q1 Nts'en'a la hukwa' ninzun, 'et ndo honeh. 
\q2 'Ink'ez ndet la yak'uz ts'e hukwa' ninzun dahooja la, ndi yun k'ut cha, 
\q2 'et whuz un'a za 'et dúhoneh. 
\q1  
\v 11 Ndai 'andit dzin uzti'ulh-i, 
\q2 negha nín'aih. 
\q1  
\v 12 'Uyoonne bulh dulhyoh ts'uwhulh'ai de, 
\q2 buba whunats'odoolnoh. 
\q2 'Et whuz un'a za nelubeshi neba oonaoodolnoh. 
\q1  
\v 13 'Ink'ez ntsi'-un, 'en ch'a neghinli. 
\q1 'Et yak'uz k'une' 'int'en-un 'int'oh, 'ink'ez be ilhtus-i cha, 
\q2 'ink'ez bé dinti'-i cha, 'i 'ilhiz wheni 'i ts'iyawh nch'e' 'unt'oh. 
\q2 'Et ndo honeh.’ 
\p  
\v 14 'Et dune nohdulhyoh né'hut'en de, 'ink'ez buba whunaoodúlhnoh de, 'et de nohBá yak'uz usda-un, 'en cha nohba whunaoodutilnoh. 
\p  
\v 15 'Et hoonts'i dune nohdulhyoh né'hut'en de, 'ink'ez buba whunalhoduzulhnoh de, 'aw nohBá yak'uz usda-un, 'en cha nohba whunaoodoolnoh ait'oh. 
\s1 Soo hootahni de, 'et 'onghohne buch'a nonah'i' 
\p  
\v 16 “'Et ndet soo hóotahnih de, mbe la duba na'udzoo'ne, 'enne buk'un'a 'ooht'e' junih. 'Et dut'enne, 'enne dudzi yo 'uhilhdzun na'hududil'i whe' hint'oh. 'Ink'ez dunin be te'hududil'en 'ink'ez dzoh nuhuzut na'hududil'i. 'Et whuz un'a 'uyoonne whúbonulhtun nts'en'a la soo huhooni hukw'un'a. 'Alha' whe nohdusni, mbe la ndut'enne buba k'elha yutaleh-i, 'uda' buba k'elha whuzdli' whe' hint'oh. 
\p  
\v 17 'Et hoonts'i nohni soo hóotahni de, soo cho nena'noolhdeh 'ink'ez nohtsegha cha naoolhtlo. 
\p  
\v 18 'Et whuz un'a soo hóotahni de, 'et 'onghohne buch'a nonah'i'. 'Et hoonts'i nohBá lhuhoost'en ts'e hoonts'i whunilh'en, 'en ts'iyanne nalh nohba k'elha whutilhtselh whe' hoont'oh. 
\s1 Ndai la yak'uz be hoonzoo' hoont'oh-i, 'i yak'uz ts'e 'et whuz 'ilhoozóhlelh 
\p  
\v 19 “Ndi yun k'ut oonáht'i'-i 'ilhoozáhle iloh. Ndulh'en de, 'ants'i k'enaditsih 'ink'ez musdziyaz cha gak yutilhtselh. 'Undunut'ihne, 'enne cha nohghu dá'hutiyus 'ink'ez hiduntit'ih. 
\p  
\v 20 'Et k'us ndai la yak'uz be hoonzoo' hoont'oh-i, 'i yak'uz ts'e 'et whuz 'ilhoozáhla. 'Et whuz un'a 'aw k'enádotsih ait'oh. 'Ink'ez musdziyaz cha 'aw gak yoolhtselh ait'oh. 'Ink'ez 'aw nohghu da'hooyis 'ink'ez nohghe' hundunoot'ih ait'oh. 
\p  
\v 21 'Et huwa ndet la oonáht'i'-i 'ilhoozáhla, ndet 'usdla-un, nohdzi cha 'et za dutá'alh. 
\s1 Dune na 'ants'i too dizk'un le'unt'oh 
\p  
\v 22 “'Et nena 'ants'i neyust'e ba too dizk'un le'unt'oh. 'Et nohna soo 'unt'oh de, 'et nohyust'e be hoot'en-i dizbun. 
\p  
\v 23 'Et hoonts'i dune na lubeshi be untsi' de, 'et ooyust'e ndulcho whe tsalhgus be dutabun. 'Et huwa ndi be hoot'en nohbulh 'unt'oh tsalhgus k'un'a be hoodat'en de, 'et dáhoolcho-i be suba tsahólhgus oole'? 
\s1 Yak'usda ook'une' 'int'en de, 'aw sooneya cha k'une' 'ont'en ait'oh 
\p  
\v 24 “'Aw 'ilhoghun dune nane moodih ba 'oot'en ait'oh. 'Et 'ilhoghun 'en yuts'u dutitni 'ink'ez 'ilhoghun yuk'etitsi'. K'us 'ilhoghun yuk'úne' tit'en 'ink'ez 'ilhoghun yuch'az dútatni. 'Aw Yak'usda cha k'une' 'int'en 'ink'ez sooneya cha k'une' 'ont'en ait'oh. 
\s1 Yinka dúlhts'i-un huwu ni oohle' junih 
\p  
\v 25 “'Et huwa njan dunóhdusni, yinka dúlhts'i-un huwu ni oohle' junih. Ndai la tih'ulh-i 'ink'ez ndai la tihnelh-i cha, 'ink'ez nohyust'e soo naidutihleh, 'i cha, 'i ts'iyawh khun ooghu ni oohle' junih. Ndi tih'ulh-i be kháhna-i anus dizti' nahzun eh? K'us naih 'i nohuyust'e anus dizti' nahzun eh? 
\p  
\v 26 Ndo dut'ai núdilh-i nulh'en! 'Aw 'alhe' nusdloh 'ink'ez 'aw khit huba ilhe'osdle iloh. 'Et hoonts'i nohBá yak'uz usda-un, 'en bugha 'á'aih. 'I iloh lakw buba nus dáhti'? 
\p  
\v 27 Nohni nohtoh mbe 'unt'oh dalcho tileh howu ni unli? 'Aw 'et huwa 'on nus 'ulyiz oole' ait'oh! 
\p  
\v 28 'Et huwa di ha be dune tihleh wuni ahli? 'Indaiyaz nts'en'a haniyeh, 'et howu nuni nahzut. 'Aw lhe'hust'en 'ink'ez 'aw naih cha lhe'hulh'en hiye dune tileh ha. 
\p  
\v 29 'Et nohdusni Solomon 'en hoonts'i soo nadut'ih te, 'aw 'indaiyaz anus lhe'ildzoo'. 
\p  
\v 30 'Et Yak'usda tl'o unzoo-i yilh'i. 'I 'andit dzin tl'o k'ut haniyeh 'ink'ez bunde 'i tsehidutilhkut 'ink'ez duták'un. 'Et dáhoolcho-i be nohni 'on nus soo nanohdutileh? Nohni 'aw soo cho ooba 'alha lhe'hoot'ohne 'unohdúsni! 
\p  
\v 31 'Et huwa khun lhoodolhkut junih, di suba ts'oo'alh, k'us di suba ts'ootnai', k'us di suba be dune ts'oole', noohzin junih. 
\p  
\v 32 'Alha 'udun yun k'ut whut'enne 'et za hukwa hitís'en. 'Ink'ez 'alha 'i be nohBá yak'uz usda-un, ndai hoonliyaz be ts'uwhulhdoh-i, 'et ts'iyawh t'eooninzun. 
\p  
\v 33 'Et hoonts'i nts'en'a Yak'usda nohba lerwe tileh 'ink'ez be ts'ih'un un'a 'uhoont'oh-i nohch'e' tileh cha, 'et za hukwa' nahzun de, 'et de 'on 'un-i cha njan ts'iyawh nohgha tíkulh whe' hoont'oh. 
\p  
\v 34 'Et huwa bunde dawhútanelh, 'et howu ni oohle' junih. Bunde whusahoolts'ut de, 'et de la howu ni oohle'. Dzin totsuk soo' hoolcho hoontsi'-un whutih'elh 'et huwa. 
\c 7  
\s1 'Uyoonne ba nahoohyeh junih 
\p  
\v 1 “'Uyoonne ba nahoohyeh junih. Doo ka si nohba nahoodeh. 
\p  
\v 2 Nts'en'a 'uyoonne ba nahahyeh, 'et soo whuz un'a nohba nahutideh. 'Ink'ez nts'en'a 'uyoonne ghu nuni nahdzut, whuz un'a za nohghu nuní huntizut. 
\p  
\v 3 'Et di ha nyulhutsin lhusyaz oona k'et diztan, 'i nilh'en, 'et hoonts'i 'aw t'eoonuzinzun nyunch'oh duchun cho nyuna k'et diztan? 
\p  
\v 4 Nts'en'a nyulhutsin 'udutánelh, ‘Nyuna k'elts'ut-i nyuna k'ehanaóos'alh,’ 'ink'ez nyunch'oh lhelcho-i nyuna k'et 'us'ai-i 'aw lhnílh'en? 
\p  
\v 5 Nyunch'oh duba na'indzoo'! 'Udechoo lhelcho-i nyuna k'élts'ut-i, 'i cho nyuna k'éhanain'aih. 'Et de la soo whunilh'en whe oona k'élts'ut-i oona k'ehanáyon'alh. 
\p  
\v 6 Yak'usda ooghuni lubeshi ooghu hooloh-un, khun te lhike dult'ohne gha óoh'alh junih. K'us Yak'usda ye whúneodulh'eh-i, 'i kw'usul dizti'-i, pearl huyulhni 'et dult'oh-i, khun gugoos dult'ohne butso naóolhdilh junih. 'Et ndahja de, dulcho hik'unutílh'us 'ink'ez 'aho nohts'u náhulhya 'ink'ez yanohodutálhch'ulh. 
\s1 Yak'usda nohts'o hukwa' ninzun-un, 'et Yak'usda hukwa 'oodolhkut 'ink'ez nohgha whúta'alh 
\p  
\v 7 “'Et nohdusni Yak'usda ndai la ookayoodulhkut-i nohgha íta'alh. Ookunáhta 'ink'ez nahootáh'alh. Dati dunulhkw'uz 'ink'ez nohba dáha'dutikwus. 
\p  
\v 8 'Et 'oodulhkutne, 'enne Yak'usda bugha whúta'alh. Mbene la hoonliyaz hukunútane, 'enne nahahootá'alh. 'Ink'ez mbene la dati dunulkw'uzne, 'enne Yak'usda buba dáha' dutit'elh. 
\p  
\v 9 Mbene nohbáke nohtoh, ooye' lhes yuts'u ha 'utni de, 'aw tse yughá nduno'alh ait'oh. 
\p  
\v 10 K'us lho yuts'u ha 'utni de, 'aw 'i k'et tl'ughus yugha óot'elh ait'oh. 
\p  
\v 11 'Et ndiz un'a nja duhoont'oh, nohni lubeshi 'ulh'enne ahli, 'et hoonts'i t'eoonahzun nts'en'a unzoo-i nohuzke gha tíh'alh. 'Et dáwhulcho-i be 'on nus ndo yak'uz nohBá, mbene la yoodulhkutne, unzoo-i bugha ti'alh. 
\p  
\v 12 'Et huwa nts'en'a hukwa' nahzun dune danohotilh'elh-un, 'et whuz un'a za nohni cha 'et ndúboolh'en. 'Alha Moses be 'udustl'us cha 'ink'ez nus hoo'enne bube' 'udustl'us cha, 'et náhoolt'oh 'et duwhútni. 
\s1 Datí-un hoondat-un 
\p  
\v 13 “Njan datí-un hoondat-un 'et hukohdilh huba' hoont'oh. 'Et datí-un 'ink'ez ti hoontel-un, 'et kwuncho yo ts'u ti 'uhoont'oh 'ink'ez lhane whuz whedilh. 
\p  
\v 14 Njan 'et huwa 'et nduhut'en, njan datí-un hoondat 'ink'ez njan ti 'ilhiz be ts'ukhuna-un 'et howa whulna' whe' hoont'oh. 'Aw lhane iloh nahuhóo'aih. 
\s1 Dune dahút'en-un, 'et 'i be dahint'oh la t'ebuntihzeh 
\p  
\v 15 “Mbene la whuts'it be nus hoo'enne na'dudil'i, 'enne buka huwahli! 'Usbai zuz be soo dint'ohne, 'enne buyo ts'e yus soo 'uk'enus ntsi'-i 'enne lé'hint'oh. 
\p  
\v 16 'Et huwa dahút'en-un, 'et 'i be t'ebuntihzeh. 'Et duje isdloo whus chun gha huyoonuyin eh? K'us ndi mai, figs huyulhni, chuntoh whuduts'ul-un whutoh huyoonuyin eh? 'Awúndooh! 
\p  
\v 17 'Et whuz un'a za duchun unzoo-i, 'i mai unzoo-i ooghu haniyeh. 
\p  
\v 18 'Ink'ez duchun dalhjut-i, 'aw mai unzoo-i ooghu hanóoyeh ait'oh. 
\p  
\v 19 Ts'iya-i duchun 'aw mai unzoo-i ooghu hanooyeh ait'oh, 'i nánuhidutselh 'ink'ez hidilhk'un. 
\p  
\v 20 'Et huwa dune cha whuz un'a duhint'oh. 'Et huwa la t'ebunohzin. 
\s1 Yak'usda k'únulhe'ust'enne, 'enne Sizi Gri ooch'e'ne lhuhiloh 
\p  
\v 21 “'Aw ts'iyanne, ‘SMoodihti, sMoodihti,’ sulhnine, 'aw nts'e la yak'uz k'une' ts'uwhul'en-un whuz hutooya' ait'oh. Mbene la 'uBá buts'o hukwa' ninzun tune' 'ut'enne, 'aw 'enne za yak'uz ts'e hutidulh. 
\p  
\v 22 'Et mbene la njan dzin whusahoolts'ut de, ‘SMoodihti sMoodihti, 'alha iloh lakw nyoozi' be nus ts'úhoo'en? Nyoozi' be ntsi'-i nududeh-i 'uyoonne bughu whe náts'inanyoot! 'Ink'ez nyoozi' 'i be huwa 'ít'en tune' ts'ut'en.’ 
\p  
\v 23 'Et ndunt'ohne dune ts'iyawh budutásnelh, ‘'Aw t'enohnuzúszun. Sch'a nasahdilh! Nohni 'aw 'uk'unulhe'ust'enne aht'oh!’ 
\s1 Sizi Gri ooghuni soo cho whulh ts'ooyin 
\p  
\v 24 “'Et huwa mbene la sghuni yoozilhts'aine, 'ink'ez daja dusni-un hukw'une' hut'en, mbe la dune whunih-un duyoh tse k'ut neoonin'ai, 'en k'un'a 'uhint'oh. 
\p  
\v 25 'Et 'awet náhoonilhtan 'ink'ez too 'awet ulhtus suli', 'i njan yoh whut'aiznai. Nilhtsi ulhtus-i cha whudilhts'uk. 'Et hoonts'i njan yoh 'aw dalhúhoonel. Njan yoh tse k'ut whuz'ai 'et huwa. 
\p  
\v 26 'Et hoonts'i mbene la sghuni yudits'one 'ink'ez 'aw hik'unulhe'ust'en de, mbe la dune whusni-un, 'en yoh 'ants'i sai k'ut neoonin'aih, 'en duhúlt'oh. 
\p  
\v 27 'Et 'awet náhoonilhtan 'ink'ez too 'awet ulhtus suli', 'i njan yoh whut'aiznai. Nilhtsi ulhtus-i cha whudilhts'uk. 'Ink'ez njan yoh nahóolts'ut. 'Ink'ez wheóonujut whe nahóolts'ut.” 
\p  
\v 28 'Et Sizi ndi khuni ye bubulh yailhduk, 'i lhaduja whe 'ilhunaoosdilne tube buba hooncha. 
\p  
\v 29 T'eoonínzun daja ni whe whubodalh'e'. Nyoonne mbe la Moses be 'udustl'us k'ut 'uk'ununáguzne, 'aw whuz un'a hubulhodílh'el. 
\c 8  
\s1 Dune ooka whulhjut-un Sizi soo na'yinla 
\p  
\v 1 'Et 'awet Sizi ndus de shus k'uz hanaja whe lhane dune yunantisdil, 
\p  
\v 2 whe dune ooka whulhjut-un, 'i leprosy huyúlhni, 'en yududizya 'ink'ez yubut nachaniti 'ink'ez 'uyulhni, “SMoodihti nyun hukwa' ninzun de, ndi ndai la be ilhtus-i 'int'i-i, 'i be suna'ilhdeh.” 
\p  
\v 3 'Et Sizi dula be yut'aiznai 'ink'ez, “A, hukwa' nuszun. Nyuna'isdeh!” yúlhni. 'Et ooka whulhjut-un, 'et 'aho soo na'uja. 
\p  
\v 4 'Et Sizi 'uyulhni, “Khun te 'uyoonne doni' junih! 'Et k'us lubret oots'inyalh 'ink'ez ts'ih'un un'a díni nyust'e nts'en'a whe soo na'uja 'ink'ez nyunoolh'en. 'Et la Moses be 'udustl'us yuk'uyaoolhduk. 'I gha la ndai huwa tan'alh-i nyudóni'. 'Et whuz un'a ts'iyanne whubuntalhtun dainja whe soo na'inja-un.” 
\s1 'Ilhoghun Rome whut'enne saldanne bumoodih, 'en ooye' Sizi soo na'yinla 
\p  
\v 5 'Awet Sizi keyoh Capernaum ts'u whutni-un ts'oozya whe 'ilhoghun Rome whut'enne saldanne bumoodih, 'en yududizya whe yuts'u tedudli, 
\p  
\v 6 “SMoodihti se'ustlen k'us unsool-un, 'en njan yoh yun sulhti 'aw delhdusni whe tube dzoh nuzut.” 
\p  
\v 7 'Et Sizi yulhni, “Oots'u tisyalh 'ink'ez soo na'tisdlelh.” 
\p  
\v 8 'Et hoonts'i ndun saldanne bumoodih yulhni, “SMoodihti syoh ts'u tanyalh huba 'aw soo lhe'uzdzoo'. 'Ants'i nghuni be 'et ndúdinja de, 'et hoonts'i se'ustlen-un k'us unsool-un soo na'ootnelh la. 
\p  
\v 9 'Alha si cha 'onghohne sando 'uhint'oh whe hukwa' huninzun tune' suhulh'en. 'Et si cha whuz un'a za saldanne buba ndo 'ust'oh. 'Et 'ilhoghun, ‘Inyalh!’ dusni de, 'et 'aho whe yaih. 'Et 'uyoon ‘'Anih,’ dúsni de, 'et 'aho sghu yaih. 'Et se'ulhna-un, ‘Nja dineh!’ dúsni de, 'et 'aho 'et ndút'ih.” 
\p  
\v 10 Sizi ndun dune ndet 'uwhúlhni whulhúdants'o whe tube ba hooncha. 'Et huwa ndunne yunidulhne ubúlhni, “Israel ndulcho whe keyoh, 'aw ndun dune whuz un'a ooba 'alha' hoont'oh-un nalhizústi. 
\p  
\v 11 'Et nohdusni ndaz de 'ink'ez nooz de lhane whusatidulh whe yak'uz k'une' whul'en-un ts'e 'et Abraham cha, Isaac cha, 'ink'ez Jacob cha, 'enne 'alhgoh lhla ná'hutit'ulh. 
\p  
\v 12 'Et hoonts'i mbene la yak'uz k'une' hool'en huba 'unt'oh inle'ne, 'enne 'az tsahólhgus ts'e hubotilhdulh. 'Et ts'iyawh hutso 'ink'ez dughoo lhehídutik'us.” 
\p  
\v 13 'Et Sizi ndun saldanne bumoodih 'en 'uyulhni, “'Awet inyalh! 'Et nts'e whula mba 'alha' 'ust'oh, whuz un'a za mba whutánelh.” 'Et soo 'oh whuya 'uwhunit'o whe be' ustlen k'us untsool-un soo na'uja. 
\s1 Peter oo'at ooloo, 'en cha Sizi soo na'yinla 
\p  
\v 14 'Et Sizi Peter ooyoh daninya whe oo'at ooloo yunilh'en. 'Et lili k'ut sulhti dada nulwus-i be nduda. 
\p  
\v 15 Yuzih neninya 'ink'ez yula t'aiznai. 'Et 'aho nulwus nduda oots'u hanaidide. 'Et 'aho dunadija 'ink'ez bugha ná'unt'ai. 
\s1 Lhane ntsi'-i nududeh ooyudúlts'ine, Sizi dughuni be buts'a hábunanyoot 
\p  
\v 16 'Et 'awet sa yo tiz'ai whe lhane ntsi'-i nududeh ooyudúlts'ine, 'enne Sizi highu bunínla. Dughuni be ntsi'-i nududeh-i buyáhanainanyoot. 'Et ts'iyawh mbe la ndudane, 'enne ts'iyawh soo na'binla. 
\p  
\v 17 'Et whuz un'a Isaiah nus hon'en whe ndutni, 'et ts'iyawh 'et ndúhooja. 'Et huwa njan nja dutni, 
\q1 “Ndai la tetsun neilh'i-i, 'i ts'iyawh neghu nayílhchoot. 
\q2 'Ink'ez nedada' cha 'et ts'iyawh nets'u hanáhonla.” 
\s1 Mbe la Sizi Gri ba ne'tit'en-un hukwa' ninzun de, 'et de ndai la ndi yun k'ut hukw'entsi'-un, 'et ts'iyawh whuladootni huba' hoont'oh 
\p  
\v 18 'Et 'ilhunaoosdilne ts'iyawh hinasguz. 'Et Sizi whunalh'en whe 'et mbene la yulh 'ut'enne, 'enne ts'iyawh ubulhni, “Nyan uztooke'.” 
\p  
\v 19 'Et 'ilhoghun Moses be 'udustl'us 'uk'ununáguz-un, 'en yughu ninya whe 'uyulhni, “Nehodulh'eh-un nts'oh tula nutányalh, 'et dulcho nyunún tisyalh hukwa' nuszun.” 
\p  
\v 20 'Et Sizi 'uyulhni, “Soo cho howu nuní ninzut! Nanguz 'enne cha 'an whut'i whe' 'unt'oh 'ink'ez dut'aiyaz cha t'o ut'i. 'Et hoonts'i yinka dune ye', 'aw hukw'ut tsén tal'alh-un 'et hoonts'i lhuhóot'i'.” 
\p  
\v 21 'Et 'uyoon yugha hodul'eh-un, 'en 'uyulhni, “SMoodihti sba silh'i. 'Udechoo 'ubá 'aoostelh.” 
\p  
\v 22 'Et hoonts'i Sizi 'uyulhni, “K'at whute, sunanyalh. Dudulh yaidlanne didutch'oh 'analhuhoolyelh.” 
\s1 Nilhtsi 'ink'ez tatsi bulh 'i hoonts'i Sizi hik'une' 'ut'en 
\p  
\v 23 'Et 'awet ts'i beinya 'ink'ez yugha hodul'ehne, 'enne ts'iyawh hiyulh 'úja. 
\p  
\v 24 Nus huzki ibulh bubulh taoodilts'ut 'ink'ez 'awet ts'i be tawhendunitih, 'et hoonts'i Sizi 'en nanisti. 
\p  
\v 25 'Ink'ez yugha hodul'ehne, 'enne hits'u whindil ts'enahuyulhts'it. “NeMoodihti netalhyis! 'Awet too netighan!” 
\p  
\v 26 'Et 'ubulhni, “Di ha whénulhjut? 'Aw bé 'alha' whut'en-i soo 'últus-i lhaht'i' whe' dahni.” Dudinya whe khuniti be hukwa' yudáni' too 'ink'ez nilhtsi bulh yatilhduk, 'ink'ez 'awet dinghel. 
\p  
\v 27 'Et nyoonne dune buba hooncha whe 'ulhodutni, “Ndun dant'oh-un dune suba 'unt'oh? Nilhtsi 'ink'ez tatsi bulh 'i hoonts'i hik'une' 'ut'en.” 
\s1 Nane dune ntsi'-i nududeh-i buyudindane, 'enne Sizi ntsi'-i nududeh-i buts'a hanábunanyoot 
\p  
\v 28 'Et 'awet nyan hoozki whe ndunne Gergesene buyun k'ut huwhutni, whuz hoozdil. 'Et nane dune highu nin'az. 'Enne ntsi'-i nududeh-i buyudinda. Ndet la nezi 'ahule-un, 'et whuz de hahán'az. Soo ts'ih'un 'uhuninzun k'et 'aw dune buzih noya' ait'oh. 
\p  
\v 29 'Et khunsul tube cho 'uhutni, “Sizi nyun Yak'usda ooYe' inli whe 'int'oh! Ndet nets'u hukwa' ninzun? Nkede neba whusaóotilts'ulh-un whutso, dzoh nunetalhdzut ha 'inja whusainya?” 
\p  
\v 30 'Et njan howu nilhdza'-un, gugoos huldlai ndi ndai la butl'ahidantsut-i, 'i huyu'alh. 
\p  
\v 31 'Inka ntsi'-i nududehne, 'enne hits'u tedudlih whe huyulhni, “Whusanáneuntanyulh de, 'et de nghuz gugoos yúzdoodilh-un netl'ahón'alh.” 
\p  
\v 32 'Et “Ahdulh!” ubulhni. 'Et 'awet ntsi'-i nududeh-i ndunne dune buts'u haídande whe gugoos yudande. 'Aho gugoos bubulh whenghu hilghaz 'ink'ez too ubanghan. 
\p  
\v 33 'Et ndunne gugoos ghunline, ts'iyawh 'aho keyoh ts'e whehílghaz. 'Ink'ez keyoh whut'enne ts'iyawh bubodáni' dahooja la. Nyoonne nane mbene la ntsi'-i nududeh-i ooyudande inle'ne, 'et dahuja la whunilhchoh hubodáni'. 
\p  
\v 34 'Aho za 'et keyoh whut'enne, ts'iyawh 'az whehilghaz 'ink'ez Sizi dodizdil. Hitilh'en ibulh njan buyun k'ut whuch'a naóoja', 'et hukwa hits'u tedudli. 
\c 9  
\s1 Sizi ndun dune 'et dúyulhni, “Nlubeshi ts'iyawh mba hooloh suli'” 
\p  
\v 1 Sizi 'et 'awet ts'i benya 'ink'ez nyan yahúzkih nts'e la dich'oh dukeyoh ts'e. 
\p  
\v 2 'Aho 'awet ndun delhdusni-un, 'en lili be whusaháyankai. Sizi ubunilh'en 'ink'ez t'eooninzun buba 'alha' hoont'oh. 'Et délhdusni-un yulhni, “Hadih ts'oodun, do 'un dunilt'i! Nlubeshi ts'iyawh mba hooloh suli'!” 
\p  
\v 3 'Et 'aho za whulohne Moses be 'udustl'us 'uk'ununáguzne 'ulhodutni, “Ndun dune Yak'usda ch'az yalhduk whe 'utni!” 
\p  
\v 4 'Et daja huninzun za Sizi 'et ts'iyawh t'eooninzun. 'Inka ubulhni, “Di ha nohdzi yo whe ntsi'-i za ghu nuni nahzut? 
\p  
\v 5 Nts'en'a suba huwa lhúhoolna' k'un'a uzdooni'? ‘Lubeshi mba hooloh suli',’ k'us, ‘Dudinyaih 'ink'ez inyalh’? 
\p  
\v 6 'Et njan t'eoonóhzin yinka dune ye', 'en ndi yun k'ut ooba' hoont'oh whe 'unt'oh lubeshi 'un toolhdilh huba' hoont'oh whe 'unt'oh,” ubúlhni. 'Ink'ez ndun delhdusni-un, “Dudinyaih 'ink'ez kw'usinti-i nailhchoot 'ink'ez nyoh ts'e naindalh!” yulhni. 
\p  
\v 7 'Et 'aho za dunadija 'ink'ez duyoh ts'e whenája. 
\p  
\v 8 'Et 'ilhunaoodúlhne ts'iyawh buba hooncha 'ink'ez Yak'usda hudílhti', dunene, 'enne cha butl'ahon'ai whe buba hót'e' ha. 
\s1 Matthew sooneya nahulhdzooh-un 
\p  
\v 9 'Et hukw'elh'az Sizi 'oh whuya lhuseya whe ndet la sooneya naldzooh-un, 'et 'ilhoghun dune Matthew huyulhni, 'et usda whe yunilh'en. “Sunanyalh,” yulhni. 'Et dudinya 'ink'ez hik'oh ts'e oot'en ha yuntizya. 
\p  
\v 10 Sizi yeyoh ts'e daninya 'ink'ez buzih usda bula na'utit'ulh. Sooneya 'ilhunaoos'aihne 'ink'ez lubeshi 'ulh'enne, 'enne cha yoh dahunindil 'ink'ez Sizi 'ink'ez yugha hodul'ehne bubulh bulanahut'alh. 
\p  
\v 11 'Ink'ez nyoonne Phariseene hinilh'en whe yugha hodul'ehne bubuhoodulhkut, “Nohodulh'eh-un, 'et di ha sooneya 'ilhunaoos'aihne 'ink'ez lubeshi 'ulh'enne cha bubulh na'ut'alh?” 
\p  
\v 12 'Et Sizi bubulh údants'o daja huyulhni-un 'et ubúlhni, “Mbene la soo 'únt'ohne 'aw yoo be duyun halhe'hunizun. Ndudáne, 'enne za yoo be duyun ha' huninzun. 
\p  
\v 13 'Et huwa ahdulh ndet la hodulh'eh-un 'et noheni toh neoonahle 'et 'uk'uwhusguz whe nja dutni, ‘'Uyoonne gha te'ntihzilh 'et nohts'o hukwa' nuszun. Ndai loodel k'ut hidutalhk'un-i, 'i ooka lhe'núszun.’ Si cha whuz un'a za 'aw ts'ih'un 'unt'ohne, 'enne bubeni naháhundunooleh huba iloh sásya. 'Et lubeshi 'ulh'enne, 'enne dulubeshi ch'a bubeni naháhundunooleh ubudutásnilh ha, 'et huba whusásya.” 
\s1 John yugha hodul'ehne, 'enne hoonliyaz Sizi huyoodulhkut 
\p  
\v 14 'Et 'awet John yugha hodul'ehne, 'enne Sizi ts'u hoozdil whe huyoodulhkut, “Dáhoont'oh huwa wheni cha 'ink'ez Phariseene, 'enne cha lhat soo ts'úhoni. 'Ink'ez nyun ngha hoodulh'ehne, 'enne gak?” 
\p  
\v 15 'Et Sizi ubulhni, “Mbe la oo'at whutaleh-un, 'en ook'ekene, 'awhuz huyulh 'unt'oh, 'enne cha eh soo húhootanih? 'Awundooh! 'Et hoonts'i 'oh de de ook'ekene buch'a nahuyitálhtelh, 'et de za soo húhootanih. 
\p  
\v 16 'Ink'ez cha, 'aw 'uda'-i dzoot 'aw 'andidi-i naih be naoolhkut ait'oh. 'Et nyoo 'andidi-i naih naootáltsulh 'ink'ez oots'u hanaitich'ulh. 'Et de 'on nus hootátsi'. 
\p  
\v 17 'Et doo cha, 'aw ts'ekoo too' 'andidi-i 'aw 'ujut-i 'uzus be yóolhdzeh ait'oh. 'Et déyinla de, 'aho la bulh hóok'uholtalh. 'Et nyoo 'andidi-i ts'ekoo too' ts'iyawh nadutijulh, 'ink'ez ndi 'uzus 'i cha ninta' tit'elh. 'Et 'andidi-i ts'ekoo too', 'andidi-i 'uzus be húyalhdzo de, 'aw whe ninta' oot'en-un hooloh.” 
\s1 Sizi ts'oodun yula ilhchoot whe dunadija 'ink'ez 'ilhoghun ts'eke soo na'yinla 
\p  
\v 18 'Et nja dahooja la 'awhuz howu yalhduk whe khunsul 'ilhoghun moodih yughu ninya 'ink'ez yubut nachániti. 'Et ndúyulhni, “Stse' 'andit za dazsai. 'Et hoonts'i soo tilah syoh ts'e tónya', 'ink'ez nla be ookw'édolni, 'et de la nakhátna'!” 
\p  
\v 19 'Et Sizi dudinya 'ink'ez yuntizya. Yugha hodul'ehne, 'enne cha ts'iyawh huyulh 'ut'en. 
\p  
\v 20 'Et 'oh whuya hidulh whe khunsul 'ilhoghun ts'eke, 'en whunizyat 'on 'at nat yus k'ut inle' whe 'uskai' 'uyulh'en. Ndun ts'eke Sizi yut'a ts'e gha ninya 'ink'ez nayits'uz-i nyus ts'e yuban whut'aiznai. 
\p  
\v 21 'Et njan 'et dutinelh whuts'o dich'oh na'dudútni, “'Ants'i oonaih oot'aizasnai de, 'et de la soo ná'tisnelh.” 
\p  
\v 22 Sizi yuts'u nálh'a 'ink'ez yunilh'en 'ink'ez 'uyulhni, “Stse' do 'un dunilt'i! Be 'alha' hoont'oh-i mba 'alha' 'unt'oh 'et huwa soo na'inja.” 
\p  
\v 23 'Et 'awet Sizi ndun moodih ooyoh ts'e daninya whe ndi be ts'ujun-i, flute huyulhni, 'i hiye ujun whe bunilh'en. 'Et 'onghohne tube tahúditni whe tso yahalhduk whe ubúlhni, 
\p  
\v 24 “'Az náhdulh! Ndun ts'ekeyaz 'aw dálhitsal, 'ants'i nanisti whe 'unt'oh.” 'Et highudloh. 
\p  
\v 25 'Et dune ts'iyawh 'az whenábahalh'a'. Sizi yoh ts'e daninya whe ts'oodun yula ilhchoot ibulh dunadija. 
\p  
\v 26 'Et dahooja la, 'et yun k'ut ndulcho whe 'et hukw'u nahuwhulnuk. 
\s1 Nane dune hoos̱'enne, 'enne Sizi soo na'binla 
\p  
\v 27 'Et 'awet Sizi natisja whe nane dune hoos̱'enne hiyuntiz'az 'ink'ez hikazulh, “NeMoodihti David oots'u hainzut-un negha te'ninzeh!” 
\p  
\v 28 'Et Sizi yoh ts'e daninya whe nyoonne hoos̱'enne huyudánin'az. 'Et Sizi ubúlhni, “Nohba 'alha' hoont'oh eh njan 'et dutísnelh huba?” 'Et 'uhuyulhni, “A, neMoodihti!” 
\p  
\v 29 Buna yut'aíznai 'ink'ez ndúbulhni, “Nts'en'a la nohba 'alha' hoont'oh, whuz un'a 'uhóneh.” 
\p  
\v 30 'Et 'aho nahitát'en 'ink'ez honilh'en. Sizi khuni ulhtus-i be ndúbulhni, “Khun 'uyoonne dóhni' junih!” 
\p  
\v 31 'Et hoonts'i tenáhunt'az 'ink'ez ndi 'oh keyoh ndulcho whe ts'iyanne hudáni'. 
\s1 Ooba 'alha lhe'hoot'ohne, 'enne hutni, “Sizi 'en netsudule ye ulhtus-i be 'ut'en” 
\p  
\v 32 'Et tenáhundil whe 'ilhoghun dune 'aw yalhulhduk-un, ntsi'-i nududeh-i ooyudinda 'et huwa. 'En Sizi highu hinílhti. 
\p  
\v 33 'Et ndun ntsi'-i nududeh-i ye yáhanainanyoot. Nyoon dune 'aho yawhénilhduk. 'Et 'ilhunaoosdilne 'ulhodutni, “Israel yun k'ut ndulcho whe 'aw ndiz un'a lhe'whusne 'et 'andit ts'iya 'et 'udechoo ndúhooja!” 
\p  
\v 34 'Et nyoonne Phariseene nduhutni, “'Ants'i ntsi'-i nududeh-un, 'en bumoodih ye ulhtus-i, 'i gha ndi nududeh ntsi'-i yuts'u hanaínanyoot!” 
\s1 Sizi dune bugha te'ninzun 
\p  
\v 35 'Et 'awet Sizi njan keyoh whuti 'ink'ez keyoh whuyaz cha whunilhchoh nusiya. 'Ink'ez lizwifne bulugliz ndi khuni unzoo-i be yak'uz k'úne' whul'en-un, 'en ghun whubodulh'eh. 'Et dunene mbene la ooyust'e ndudane 'ink'ez tetsunne, 'enne ts'iyawh soo na'bulh'en. 
\p  
\v 36 'Ink'ez 'ilhunaoodilhne ubunilh'en. 'Enne ts'iyawh nehunintsai dóhot'en, 'aw 'uhooneh ait'oh. 'Ink'ez ts'iyaitsuk laditnine dohot'en. 'Ants'i 'usbaiyaz lhane 'aw bughunli-un hooloh le'hint'oh. 
\p  
\v 37 'Ink'ez yugha hodul'ehne, 'enne ubulhni, “'Alha 'awet ha' nukat-un newhúninzut 'ink'ez tl'o mai' lhai suli', 'et hoonts'i 'ut'enne 'aw soo lhe'huniltsuk. 
\p  
\v 38 'Inka Yak'usda ha' nukat-un whumoodih, dich'oh 'a'dudinla-un, 'uyoonne 'ut'enne cha whusáboolh'a', 'et huba tenadoohdli,” ubúlhni. 
\c 10  
\s1 Whunizyane 'on 'at nane whel'a'ne buboozi' 'uk'eítagus 
\p  
\v 1 'Et whunizyane 'on 'at nane Sizi yugha hodul'ehne, 'enne 'alhgoh 'anih ubudáni'. Ntsi'-i nududeh-i 'enne ts'iyawh ndet la whehílhtus-un cha, 'ink'ez k'une' bool'en ha, 'et cha, 'ink'ez ndet hukw'e húndudá-un cha, 'et ts'iyawh 'et whuch'a soo na'botilh'elh, 'et cha ts'iyawh butl'ahón'ai. 
\p  
\v 2 Njan 'et whunizyane 'on 'at nane whel'a'ne buboozi' 'uk'eítagus; 'udechoo Simon, 'en Peter cha huyulhni; 'en bulhutsin 'en Andrew huyulhni; 'et doo cha James cha Zebedee ooye', 'ink'ez John 'en cha 'en bulhutsin 'unt'oh; 
\p  
\v 3 Philip 'ink'ez Bartholomew; Thomas 'ink'ez sooneya nalhdzooh-un Matthew huyulhni; James 'en cha Alphaeus ooye' 'unt'oh, 'ink'ez Lebbaeus 'en ooboozi' 'udek'ez-un Thaddaeus huyulhni; 
\p  
\v 4 'et Simon cha, 'en Canaanite yun k'ut whut'en-un 'unt'oh, 'ink'ez Judas Iscariot 'en 'uja Sizi be 'onket-un 'unt'oh. 
\s1 Ndunne whunizyane 'on 'at nane, 'enne Sizi ubutilh'alh 
\p  
\v 5 'Et 'awet ndunne whunizyane 'on 'at nane, 'enne nts'e la 'uhutit'elh Sizi whuz ubutilh'alh. 'Et la khuni ulhtus-i butl'adan'ai whe ndubulhni, “Khun 'udun yun k'ut whut'enne buti ts'u te toohdilh junih. 'Ink'ez Samaritan bukeyoh ts'uti whuz te toohya' junih. 
\p  
\v 6 'Et k'us Israel oots'u haindene, 'enne 'ants'i 'usbai ninta nilh'az-i lé'hint'oh, 'enne za buts'un toohdilh. 
\p  
\v 7 'Et 'awet ahdulh whe butoh lhohdilh, njan 'et budutáhnelh, ‘Nts'en'a la yak'uz k'úne' whul'en-un 'awet nilhdukw.’ 
\p  
\v 8 Ndudáne 'ink'ez ooka whulhjutne, leprosy huyúlhni, 'enne cha ts'iyawh soo na'boolh'en. Yaidlanne cha dunabudóhlelh. Ntsi'-i nududehne, dune buts'a hanábunuhyukw. Ndai la 'ants'i nohgha nkat-i, 'i cha 'ants'i huwaóohle. 
\p  
\v 9 Khun te sooneya nohsooneya zus be óohdzaih junih! 
\p  
\v 10 Khun tihdulh de hoonliyaz toohla' junih. Lhook'ez 'ink'ez be kélh'a-i cha 'ink'ez nanki ts'oozt'an 'ink'ez nohtuz. 'Alha 'ut'en-un nts'en'a la ne'ut'en, 'et whuz un'a za nohni cha ooh'alh huba' hoont'oh. 
\p  
\v 11 Ndet la keyoh ts'u tihdulh 'et keyoh whuyaz k'us keyoh whuti, 'et ndunne keyoh whut'enne, 'enne hukwa boodolhkut k'us mbe suba dune oodzi unzoo, 'en ooyoh dólhts'i. 
\p  
\v 12 'Et ooghu danáhdil de, mbene la yoh dilhts'ine ts'iyawh hoonzoo-un nohghá holts'it-un, nohba hukwa' nídzun, 'et whuz un'a 'et dubúdohni. 
\p  
\v 13 'Et ndunne yoh 'et dilhts'ine, 'enne huhóont'i' whe bughu danáhdilh de, 'et nohdzi dant'oh la, ts'iyawh buts'ú be holhnih. 'Et 'aw 'et ndulhúhit'oh de, daja ubudáhni-un, 'aw whe la'hootneh ait'oh. 
\p  
\v 14 'Et mbene la 'aw nohghu nulhúhiyal 'ink'ez lhunoh huhoozilhts'ai de, 'et yoh tenaoohdilh 'et nyoh keyoh whuti 'et cha whuch'a naoohdilh. 'Ink'ez nohke ts'iyawh lhez ch'a naoohghat. 
\p  
\v 15 'Alha nohdusni ndet dune ba nahidzilh-un whusahoolts'ut de, ndunne Sodom whut'enne 'ink'ez Gomorrah whut'enne cha, njan keyoh whut'enne mbene la nohghu núlhiyalne, 'enne 'on nus 'uwhultsi'-un bugha óotalts'ulh. 
\s1 Sizi 'utni, “Si soozi' gha ts'iyanne nohts'u dutitni” 
\p  
\v 16 “Soo zulhts'ai, 'ants'i 'usbai yus yugha óolh'az le'hoont'oh ts'e whuz nohtis'a'. 'Et huwa tl'ughus k'un'a duwhunih áhlih 'ink'ez ndi dut'ai, dove huyulhni, 'i k'un'a nohbulh dune ndólhda' junih. 
\p  
\v 17 Whulohne dune buch'a kháhdli. 'Enne Lizwif nahiyilhne, 'enne bubut nenóhotalelh. 'Ink'ez Lizwif lugliz whambez ts'e 'et nohohóotalhtsus. 
\p  
\v 18 'Et 'ants'i yun k'ut whumoodihne 'ink'ez lerwene cha si sgha 'enne bubut nenóhotalelh. 'Ink'ez si sghun whubuntilhtun. 'Udun yun k'ut whut'enne, 'enne cha si sghun whubuntilhtun. 
\p  
\v 19 'Et 'awet whutl'anohuhanla de, nts'en'a la daja dutihnelh, 'et huwu ni oohle' junih. Nts'oya hoozulh whu la ndai la be yátilhduk-i, 'et la t'ewhunoohzeh. 
\p  
\v 20 'Alha 'aw nohnich'oh iloh yatilhduk. NohBá ooyughi 'i 'udutinelh. 
\p  
\v 21 'Et dune dulhutsin datítsah ha whutl'aítilhtelh. Bubá 'en duduzkeh cha whuz ubutilelh. Bubuzkeh dudusneke cha buch'az nehúdutadulh 'et whe dahutitsah-un huwá botalelh. 
\p  
\v 22 'Ink'ez si soozi' gha ts'iyanne nohts'o dutitni. 'Et hoonts'i mbene la 'udek'ez whuts'un 'et whulh núdalya'ne, 'aw 'enne za hudutijih. 
\p  
\v 23 'Et hoonts'i njan keyoh 'enne dzoh nanóhahulhdzut de, 'et 'udun keyoh ts'e buch'a tóohdilh. 'Et keyoh whuti 'et cha dzoh nunohohulhdeh de, doo cha 'on 'un keyoh buch'a tóohdilh. 'Alha' dusni 'et yinka dune ye' whusatiyalh whutso, 'aw njan Israel oots'u haindene, 'enne bukeyoh ts'iyawh whutulhóhdilh ait'oh. 
\p  
\v 24 Dune yugha hodul'eh-un, 'aw yuba dune hodulh'eh-un ando lhe'it'oh. 'Ink'ez be 'ulhna-un, 'en cha 'aw dumoodih ando lhe'it'oh. 
\p  
\v 25 Dune yugha hodul'eh-un, whuyodulh'eh-un k'un'a 'oot'e' huba' hoont'oh, 'ink'ez be 'ulhna-un, 'en dumoodih k'un'a 'oot'e' huba' hoont'oh. 'Et si Beelzebul suhútni de 'et nohni sgha hodul'ehne, nohni cha whuz un'a za 'et dunohodutánelh! 
\p  
\v 26 'Et huwa 'enne bube noolhjut junih! Ts'iyaitsuk lubeshi whu'iz 'unt'oh 'ink'ez ntilh'i-i, 'i ts'iyawh ts'et haóotikulh 'ink'ez ts'iyanne t'ehuntizeh. 
\s1 Yak'usda 'en za be noolhjut 
\p  
\v 27 “Njan daja nohdusni-un tsaholhgus-un ts'et whucho howu yaoolhduk. Ndet la whu'iz whudahts'o-un, 'et bun k'ut whuts'un khuniti be howu yaoolhduk. 
\p  
\v 28 Mbe la neyust'e hughanne 'et 'aw nezul 'i hizoolhghelh ait'oh, 'et ndunt'ohne, 'enne bube noolhjut junih. 'Et hoonts'i Yak'usda mbe la nohzul nohyust'e bulh kwuncho yo ts'e nohtinoh, 'en za bé noolhjut. 
\p  
\v 29 'Alha iloh lakw ndi nanki 'uchas, 'i 'ilho sooneya ts'uditi'-i, 'et 'ultsuk 'i be oohket? A, 'alha' 'uhoont'oh. 'Et hoonts'i neBá 'aw hukwa lhe'nizun de, 'aw 'ilhoghun ndi yun k'ut naoolts'it ait'oh. 
\p  
\v 30 'Ink'ez nohtsigha', 'i ts'iyawh 'ilho whe t'eininzun. 
\p  
\v 31 'Et huwa khun whenoolhjut junih. Nohni 'uchas anus dáhti' whe aht'oh. 
\s1 Dune nalh Sizi 'en sch'e' uzdooni' 
\p  
\v 32 “'Et huwa mbe la dune nalh 'et ndutni-un, Sizi, 'en si sch'e' 'unt'oh, mbe la 'et ndutnine, 'uBá yak'uz usda-un, 'en dutasnelh, nyoon 'en sch'e' 'unt'oh. 
\p  
\v 33 'Et hoonts'i mbene la dune nalh sts'ooditdlaine, si cha 'uBá yak'uz usda-un ndunne, 'enne 'aw sch'e' lhuhiloh dósni' la. 
\s1 Mbe la si sgha dich'oh ye khuna-i ninta inín'ai, 'en ndai la ye khuna-i nayitá'alh 
\p  
\v 34 “Ts'iyanne lhts'un ts'ih'un 'uhoot'e', 'et hukwa ndi yun k'ut whusásya noohzin junih! 'Aw lhts'un ts'ih'un 'uhoot'e' bugha ootas'alh hukwa iloh whusásya. 'Et ndi saluzti le'únt'oh-i, 'i bugha tís'alh 'et huba whusásya. 
\q1  
\v 35 Dune dubá ch'az nedútadalh 'ink'ez ootse' 'en duloo ch'az nedútadalh. 
\q2 'Ink'ez 'en ooyas'at 'en dubiz ch'az nedútadalh, 'et huba whusásya. 
\q1  
\v 36 Mbene la dune hiyoh whut'ine, 
\q2 'enne cha hich'azne dutadulh. 
\p  
\v 37 Mbe la dubá k'us duloo, si sanus buk'entsi' de, ndunt'ohne, 'enne 'aw sba soo lhe'hildzoo'! 'Ink'ez mbe la duye' 'ink'ez dutse' bulh, si sanus buk'entsi' de, 'en 'aw sba soo lhe'ildzoo'. 
\p  
\v 38 'Ink'ez cha mbene la dutulalhgus lhodistel de, 'ink'ez sulhonisdulh de, 'enne ts'iyawh sba soo lhe'hildzoo'. 
\p  
\v 39 Mbe la dich'oh whe khuna-un, 'et hoolhyih hukwa 'ut'en, 'en whe khuna-un ts'iyawh ninta ootá'alh whe 'unt'oh. 'Et hoonts'i mbe la si sgha dich'oh ye khuna-i ninta inín'ai, 'en ndai ye khuna-i nayitá'alh. 
\s1 Mbe la hoont'i' whe danyunilhti-un, 'en si cha hoont'i' whe dasúnilhti whe 'unt'oh 
\p  
\v 40 “Mbe la hoont'i' whe danyunilhti-un, 'en si cha hoont'i' whe dasúnilhti le'hoont'oh. Mbe la whesalh'a'-un, 'en cha hoont'i' whe daínilhti whe' hoont'oh. 
\p  
\v 41 Mbe la nus hoo'en-un, 'en 'et huwa dune hoont'i' whe daínilhti. 'Et nts'en'a ooba k'elha whutale, 'et ndun cha whuz un'a za ooba k'elha whutale. 'Et whuz un'a za mbe la ts'ih'un dune-un, 'en 'et huwa dune hoont'i' whe daínilhti, 'en ndet whe ooba k'elha whutale, 'et whuz un'a za ndun cha ba k'elha whutale. 
\p  
\v 42 'Ink'ez mbene la si sgha hodul'ehne, 'ink'ez mbe la butoh k'us hukw'e'ih 'unt'oh-un, 'en sgha hodul'eh-un 'unt'oh 'et huwa dune too suk'uz yubainkai de, 'alha' nohdusni, 'en hoonts'i ooba k'elha whutale whe' hoont'oh.” 
\c 11  
\s1 Nane John yugha hodul'ehne, 'enne John Sizi ts'u whebalh'a' 
\p  
\v 1 'Awet Sizi whunizyane 'on 'at nane yugha hodul'ehne, ts'iyantsuk ubudáni'-un 'etsul 'udija, 'et bughu whínya. 'Uts'un keyoh ts'e whinya dune hodutilh'eh 'ink'ez bubulh yatilhduk wheni. 
\p  
\v 2 'Awet John 'alts'ut whe 'et Christ be 'ut'en k'oh whulh udants'o. 'Et huwa nane yugha hodul'ehne, 'enne John Sizi ts'u whébalh'a'. 
\p  
\v 3 'Et huyoodulhkut, “Nyun eh whusatíyalh-un inli, k'us 'uyoon tilah ha ts'itó'en?” 
\p  
\v 4 'Et Sizi nja dúbulhni, “John ooghu nanaht'az de, ndet hooh'en 'ink'ez ndet whudáhts'o-un, 'et ts'iyawh dóhni. 
\p  
\v 5 'Et hoos̱'enne cha 'et huhoo'en nasdli'. Dzoh nudilhne, 'enne soo nahudilh nasdli'. Ooka whulhjutne cha leprosy huyúlhni, butsun hooloh nasdli', 'ink'ez lhe'dústs'one cha 'uhudits'o nasdli'. Yaidlanne cha dunahudidil 'ink'ez tel'enne cha khuni unzoo-i be bubulh yainduk whe' hint'oh. 
\p  
\v 6 'Et mbene la si sgha 'aw buba dzoh lhilel de, 'enne 'uk'enus hoonzoo-un bughá whults'ut.” 
\p  
\v 7 'Et ndunne nane whehán'az whe Sizi ndunne 'ilhunaoosdilne, 'enne njan John ghun bubulh yawhenilhduk whe ndúbulhni, “Di tih'elh ha dune lhuhóot'ih ts'e whéhdil? Tl'o ghazilh nonulhts'i, 'i tilah tih'elh nahzun eh? 
\p  
\v 8 Ndet suba hukwa tse hoohli whutih'elh-un? Dune naih duchut-i be soo naduja, 'en tilah tih'elh nahzun eh? Soo zulhts'ai mbene la naih duchut-i be dune unline, 'aw 'enne za lerwe yoh hudilhts'i. 
\p  
\v 9 'Et ndet whutih'elh-un hukwa tse hóohli? Nus hoo'en-un tilah? A, 'alha' hoont'oh. 'Et 'ink'ez nohdusni, nus hoo'en-un anus hoonzoo-un whunalh'en! 
\p  
\v 10 Ndun 'en ghun 'uk'unusguz-i 'et ndutni, 
\q1 ‘Soo zulhts'ai 'uyoon khuni sba na'a-un, 'en ntso tis'alh. 
\q2 Nts'oya la lhutányalh-un mba lhaoodutileh ha.’ 
\p  
\v 11 Ts'ih'un un'a nohdusni, ts'iyanne whuzdline, 'aw John dune too be 'ulh'en-un anus dízti'-un hooloh. 'Et hoonts'i nts'e la yak'uz k'úne' whul'en-un, mbe la 'uk'enus dizti' lhiloh-un, 'en anus uncha whe 'unt'oh. 
\p  
\v 12 'Et 'oh da' John dune too be 'ulh'en-un be whe' whudit'en, 'et 'andit dzin whuts'un, yak'uz nts'e la k'úne' whul'en-un, 'et yak'uz huhoolhdil, 'ink'ez huhoolhdilne, 'enne ts'iyawh yak'uz da'hudolhdis hukwa' hut'en. 
\p  
\v 13 John whusatiyalh whuts'un, nus hoo'enne bube' 'udustl'us cha, 'ink'ez Moses be 'udustl'us cha, ndet daóotanelh 'et hudani', 'et 'uwhulhni. 
\p  
\v 14 'Et daja nohdúsni-un, soo nohba 'alha' whutat'elh de, ndun nus hoo'en-un Elijah whusatiyalh-un, John 'en 'unt'oh, 'et huwa. 
\p  
\v 15 Mbe la oodzo hoonine, 'enne huhoozólhts'ai' huba' hoont'oh. 
\p  
\v 16 'Et yuk'edúdehne nts'en'a suba nohba lhzih nebosdlelh? Ndiz un'a nja duhínt'oh whe ts'oodunneyaz duhúlt'oh 'ink'ez nts'e la t'alh-i be 'ooket-un 'et hudilhts'i whe duk'ekene buts'u hahuyih whe ndúbotni, 
\q1  
\v 17 ‘Nohba ts'ujun be ts'ujun be, 
\q2 'et hoonts'i neba lhnuzahdai. 
\q1 'Ink'ez nohni nohba ts'odi ts'inli, 
\q2 'et hoonts'i 'aw oohtso ait'oh!’ 
\p  
\v 18 'Et John dune taninya whe 'aw lhe'us'al 'ink'ez 'aw talhusnai'. 'Et highu yalhduk whe' hutni, ‘Nududeh-i ntsi'-i ooyudinda,’ dahni. 
\p  
\v 19 'Et yinka dune ye', 'en dune butaninya whe bula whé'nin'al 'ink'ez bula tawhénitnai', 'et 'uhutni, ‘Ndun 'en oocha hooncha 'ink'ez ts'ekoo too' cha 'utnai. Sooneya nalhdzoohne 'ink'ez lubeshi 'ulh'enne, 'enne buk'eke 'unt'oh,’ dáhni. 'Et hoonts'i mbene la Yak'usda gha whunih suli'ne, 'enne ts'iyawh ndi hiye whunih-i, 'i be ts'ih'un 'uhint'oh suli'.” 
\s1 Mbene la dudeni nahánundunooleh hukwa lhe'hunízun, dawhultsi'-un bugha óotalts'ulh 
\p  
\v 20 'Et hukw'elh'az nts'e la keyoh whuti totsuk 'ut'en ncha-i ba' yílya-i, ndut'enne hukwa' budáni'. 'Aw dubeni nahándunoolelh hukwa lhe'hunízun. 
\p  
\v 21 'Et huwa 'utni, “Nohni Chorazin whut'enne, 'ink'ez nohni Bethsaida whut'enne, nohni cha, dawhultsi'-un 'et nohts'u hóolts'ulh! Soo cho soo zúlhts'ai! 'Uda' ndet la whunilhchoh hoolhtus-un nohnat ne'whust'en-un, ndunne Tyre 'ink'ez Sidon whut'enne, 'enne cha bunat 'et dúhooja de, 'uda' da' bubeni naháhundunooleh oole' da', 'et hoonts'i 'aw ndulhúhinel. Doso naih be húdilhts'i de 'ink'ez lhez k'ehidzih, 'et whuz un'a 'et nduhóoneh uhóoneh oole' da'. 
\p  
\v 22 'Et hoonts'i nohdusni, ndet dzin nohba whusaootilts'ulh nts'en'a la nohba nahutideh ha, 'et ndunne bubulh dawhutanelh la, 'et nohni 'on nus 'uwhultsi-un 'et nohts'u hoolts'ulh. 
\p  
\v 23 'Ink'ez nohni Capernaum whut'enne ndo yak'uz huba soo áht'oh nahzun eh? 'Awúndooh! 'Et k'us kwuncho yo ts'u nohotilhdulh! 'Alha 'uda' ndet la hoolhtus-un nohnat ne'whust'en-un, ndunne Sodom whut'enne, 'enne cha bunat 'et dúhooja de, 'enne dudzi nahondunizdla de, 'awhuz da' bukeyoh 'et whuz'ai oole' da'. 
\p  
\v 24 'Et hoonts'i ts'ih'un 'unohdusnih, dahoont'oh-un la nohba whusaootilts'ulh-un, nts'en'a whe nohba nahutideh ha, 'et ndunne Sodom whut'enne bubulh dawhutanelh la, 'et nohni 'on nus 'uwhultsi'-un 'et nohts'u hoolts'ulh.” 
\s1 Sizi ubulhni, “Nohni ts'iyawh diz ahdulh 'ink'ez natilhyis-un nohgha óotas'alh” 
\p  
\v 25 Sizi 'awhuz bubulh yalhduk whe 'et ndutni, “'UBá nyun nyudústi'. Yak'uz 'ink'ez yun k'ut huMoodihti inli. Whunihne 'ink'ez hodul'ehne, ndi 'i ts'iyawh buch'a whuntin'i. 'Et hoonts'i ts'oodunyaz le'unt'ohne, 'enne bunalhts'et hahon'ai. 
\p  
\v 26 'Et hoonts'i 'uBá ndet 'uhóonla-un hoonínt'i'. Ndo honeh. 
\p  
\v 27 'UBá ts'iyawh stl'ahónla, 'ink'ez 'en ooYe' mbe unli ts'iyanne t'ehonúszun. OoBá 'aw 'en za t'eininzun. 'Ink'ez mbe ooBá unli, ooYe' 'aw 'en za t'eininzun. 'Ink'ez mbe la ooYe' 'onghohne ts'iyawh whubuntilhtun hukwa' ninzun de, 'en za ooba' hoont'oh. 
\p  
\v 28 Nohni ts'iyawh mbe la 'ut'en ulhtus-i 'ulh'enne 'ink'ez mbe la ndaz-i nulene le'aht'oh, nohni ts'iyawh diz ahdulh 'ink'ez natilhyis-un nohgha óotas'alh. 
\p  
\v 29 Ndai la se' 'ut'en-i, 'i ulhchoot 'ink'ez nedúht'aih le'ahleh 'ink'ez si sghun hodulh'eh. 'Aw dune dach'e nulhe'zust'en 'ink'ez ts'iyanne toh te'duduz'en 'et huwa. 'Et whuz un'a la nohzul whe nátilyis-un ooba nahóh'alh. 
\p  
\v 30 Ndi la úlhchoot-i, 'aw nohba oogha lhúhoolna' tileh, 'ink'ez se' 'ut'en k'oh cha hoondza tileh.” 
\c 12  
\s1 Sizi 'en nats'ulyis dzin hoonts'i huMoodihti whe 'unt'oh 
\p  
\v 1 'Et 'awet 'ilhoh dzin 'et la lizwifne buba nalyis dzin huhoolh'i. 'Oh da' Sizi tl'o k'ut uyalh, 'ink'ez yugha hodul'ehne, 'enne cha huyulh udulh whe buye'ílts'ul. 'Et tl'o mai' huyoonuyin 'ink'ez huya'alh. 
\p  
\v 2 'Et ndunne Phariseene bubotilh'en ibulh Sizi huyoodulhkut, “Ngha hodul'ehne dahút'en ubunilh'en eh? 'Andit dzin nats'ulyis dzin 'uhoont'oh. 'Aw 'et nduhóot'en huba lhe'hoot'oh!” 
\p  
\v 3 'Et Sizi 'ubúlhni, “'Et lerwe David daja-un 'aw lakw hukw'u yalhuzulhduk? 'Et 'oh da' David 'ink'ez yulh 'ut'enne buye'ílts'ul? 
\p  
\v 4 'Et 'awet Yak'usda ooyoh daninya whe ndi lhes ndai la Yak'usda gha t'aih-i, 'i yu'alh 'ink'ez yulh 'ut'enne, 'enne cha huyan'al. Lubretne 'aw 'enne za huyoo'alh huba' hoont'oh, 'et hoonts'i David 'ink'ez yulh 'ut'enne cha nduhuja. 
\p  
\v 5 Moses be 'udustl'us do', 'aw ook'uyalhuzulhduk whe eh dahni? Ndiz un'a nja dutni, lubret nats'ulyis-un dzin lugliz whucho dahunindil 'ink'ez 'et 'uhut'en. Nts'en'a la 'uhuhoolhdzun-un, 'et k'uhoninyuz, 'et hoonts'i 'aw buk'elhúhoolts'ulh. 
\p  
\v 6 Whuz un'a nohdusni njan lugliz whucho 'et nohtoh 'ilhoghun whanus 'ulcho-un hoonli. 
\p  
\v 7 'Et 'uk'uwhusguz 'et ndutni, ‘'Uyoonne gha te'ntihzilh, 'et nohts'o hukwa' nuszun. Ndai loodel k'ut hidutalhk'un-i, 'i ooka lhe'nuszun,’ ni. 'Et ndi nja dutni-un, 'et t'eoonahzun de, 'et de mbe la ookw'elhúwhulhts'itne, 'enne 'aw buk'ehoh'alh hukwa aht'en iloh! 
\p  
\v 8 'Et huwa yinka dune ye' nats'ulyis dzin 'et hoonts'i humoodihti whe 'unt'oh.” 
\s1 Nats'ulyis dzin 'ut'en unzoo-i 'uts'oolh'en 
\p  
\v 9 'Et 'awet hukw'elh'az bugho whinya whe ndunne Lizwifne bulugliz ts'e daninya. 
\p  
\v 10 'Ilhoghun dune 'en 'et usda 'ink'ez 'aw oola 'aw ye nulhé'ust'en. 'Et Sizi huyoodulhkut, “'Et nats'ulyis dzin soo na'uztitnelh huba' hoont'oh eh?” 'Et whe hoonliyaz highu nahootá'alh hukwa' hut'en. 
\p  
\v 11 'Et ndúbulhni, “Mbe nohtoh 'utinelh 'usbaiyaz tsak'et 'álts'ut whe hanaítilhtelh nats'ulyis-un dzin 'et hoonts'i? 
\p  
\v 12 'Et dawhulcho-i be dune 'usbai anus dizti' whe 'unt'oh? 'Et huwa netl'ahóolts'ut nats'ulyis dzin 'ut'en unzoo-i 'uts'ulh'en whuba.” 
\p  
\v 13 'Et ndun dune ndúyulhni, “Nla lhts'e nadíntsih!” 'Et 'awet lhts'e naidizsi whe ookw'uz ts'e k'un'a sóo na'uja. 
\p  
\v 14 'Et Phariseene 'az whuhandil 'ink'ez huwu yahalhduk nts'en'a hituzilhghelh hukwa. 
\s1 Sizi mbe unli-un, 'aw whubuntilhtun hukwa lhe'nínzun 
\p  
\v 15 'Et Sizi hituzilhghelh huwu yahalhduk, 'et t'ewhunanzin ibulh bugho whenaja. Lhane ndudáne hiyuntizdil, 'et ts'iyawh soo ná'balh'en. 
\p  
\v 16 Khuni ulhtus-i be ubulhni, “'Uyoonne khun sghu yahoolhduk junih.” 
\p  
\v 17 'Et whe la nus hoo'en-un Isaiah, daja ni-un, 'oh te ne'whust'en. Ndi khuni nja dutni, 
\q1  
\v 18 “Ndun sYe' se'ustlen-un, 
\q2 'en 'utahásti-un 'unt'oh. 
\q1 'En 'aw 'en za ookw'esi'. 
\q1 'En gha szul tube yé hoont'i'. 
\q2 Syughi ookw'édutasdoh. 
\q1 'Et nts'en'a dahoont'oh dune ba nahisyilh, 
\q2 sYe' whuz un'a za 'udun yun k'ut whut'enne ubódutánelh. 
\q1  
\v 19 'Aw dune budulhyoh 'udooni' ait'oh. 
\q2 'Aw bubúlh 'aooldzul ait'oh. 
\q2 Ti nuya de, 'aw bubulh dóoltul ait'oh. 
\q1  
\v 20 'Aw tl'oghazilh nisdus-i, 'i hoonts'i k'idóch'as ait'oh. 
\q2 'Aw too dizk'un 'awet nanutneh-i, 'i hoonts'i, 'aw nainoolhneh ait'oh. 
\q1 'Et 'awet Yak'usda lubeshi ba nahuyeh 'et whuch'a' nilhde de, whuz un'a za sYe' 'utit'elh. 
\q2  
\v 21 'Ink'ez 'udun yun k'ut whut'enne ndun sYe' se'ustlen-un, 
\q2 'en boozi', 'i be 'et whut'aníhuntatan.” 
\s1 Mbene la lhch'az nedindilne, 'enne cha gak hutileh 
\p  
\v 22 'Et 'ilhudzin whe 'ilhoghun ntsi'-i nududeh ooyudinda-un, 'en hoos̱'en 'ink'ez yaoolhduk cha ait'oh. 'En Sizi ts'u huyoolhti whe soo na'yinla. 'Ink'ez ndun hoos̱'en-un 'ink'ez yaoolhduk cha ait'oh, 'en 'aho hoo'en 'ink'ez yawhenilhduk. 
\p  
\v 23 'Et 'ilhunaoosdilne ts'iyawh tube buba hooncha 'ink'ez dich'oh lhulh yáhalduk, “'En 'alha David oots'u hainzut-un toleh 'unt'oh.” 
\p  
\v 24 'Et Phariseene whulhódants'o whe 'et 'uhuyulhni, “Ndun Sizi, 'en Beelzebul, ntsi'-i nududehne bumoodih 'unt'oh, 'en be za ntsi'-i nududeh-i dune ts'u hanahinuyukw,” hutni. 
\p  
\v 25 Daja huninzun-un Sizi t'eooninzun 'inka 'et dúbulhni, “Nts'e la yak'uz k'une' whul'en-un, 'enne lhch'a nehúdindil de, 'enne ts'iyawh gak hutileh. 'Ink'ez keyohti whudune'ne k'us yoh dilhts'ine cha, ts'iyawh lhch'az nehúdindil de, 'enne cha gak hutileh. 
\p  
\v 26 Whuz un'a za Satan didutch'oh dune ts'u hanainuyukw de, 'et 'alha didutch'oh lhch'az ditni whe 'unt'oh. 'Ink'ez nts'en'a la whulerwe unli-un, 'ilhiz whutat'elh? 
\p  
\v 27 'Et si Beelzebul 'en be 'ust'en de, 'et de sudahni nohni nohye'ke, k'us mbe suba ntsi'-i nududeh-i dune ts'u hanábonuyukw? 'Et huwa 'enne bugha t'ewhuntihzeh tank'us údahni! 
\p  
\v 28 'Et hoonts'i Yak'usda ooyughi be ntsi'-i nududeh-un dune ts'u hanánusyukw de, 'et 'alha' hoont'oh whe nts'e la Yak'usda whe lerwe unli-un, 'et 'awet nohghu whults'ut whe' hoont'oh. 
\p  
\v 29 'Et nts'en'a 'utinelh 'ilhoghun dune 'et dune ulhtus-un ooyoh daninya 'ink'ez hoonli yughi tálhchulh? 'Aw ooneh ait'oh. Ndun dune 'udechoo yulhghel de, 'et de za ts'iyaitsuk yughi tálhchulh. 
\p  
\v 30 Mbene la sulh lhe'it'ohne, 'enne sch'az huditni whe' hint'oh. 'Ink'ez mbene la 'aw dune sla 'ilhulhósdlene, 'enne ts'iyawh 'ants'i yahitákulh le'hutinelh. 
\s1 Mbene la Ndoni ch'az ditni be yalhdukne, 'aw buba whunaoodootnoh ait'oh 
\p  
\v 31 “'Et huwa 'unohdusni, lubeshi ts'iyawh 'ink'ez Yak'usda ch'az yalhdukne, 'et ts'iyawh nohba whunaoowhudutilnoh. 'Et hoonts'i Ndoni ch'az ditni be yalhdukne, 'aw buba whunaoodootnoh ait'oh. 
\p  
\v 32 'Ink'ez mbene la yinka dune ye' ch'az yalhdukne, daja hutni-un, soo buba 'un whutilhdulh. 'Et hoonts'i mbene la Ndoni ch'az yalhdukne, 'aw buba 'un whutoolhdilh ait'oh. 'Andit dzin k'us nus de hoonts'i 'aw 'uhoneh ait'oh. 
\s1 Dant'oh-i duchun 'unt'oh, oomai' gha t'enahzun 
\p  
\v 33 “Ndiz un'a 'uhoont'oh, mai chun unzoo-i hanálhyai de, oomai' unzoo tileh. 'Et mai chun 'utsi'-i hanálhyai de, oomai' ntsi' tileh. 'Et oomai' whuzdli' de, dant'oh-i duchun 'unt'oh, oomai' gha t'entidzeh. 
\p  
\v 34 Nohni ts'iyawh lubezo tl'ughus buzkeh le'aht'oh! Nts'en'a ahtsi' 'ink'ez khuni unzoo-i be yalhduk? 'Alha nohdzi ndai be dizbun 'i be yalhduk. 
\p  
\v 35 Dune unzoo-un ndai la unzoo-i dudzi bez 'ilhunayodle-i, 'aw 'i za oots'u hanaídukat. 'Et dune untsi'-un, 'en ndai untsi'-i dudzi bez 'ilhunayosdle de, yalhduk te, 'aw 'i za oots'u hanaídukat. 
\p  
\v 36 'Et nohdusni mbene la 'aw khuni lhe'it'oh-i be yalhdukne, dune ba nahidilh-un dzin whusahóolts'ut de, nts'en'a khuni 'i be yalhduk-un, whuz un'a buba nahutideh. 
\p  
\v 37 'Et huwa nohghuni gha Yak'usda nalh ts'ih'un dune tihleh, k'us nohghuni gha kwuncho yo ts'u tihdulh k'un'a, whuz un'a nohba nahutideh.” 
\s1 Sizi buba 'alha' lhe'ít'ohne, 'enne hoonliyaz hooncha tune' whut'en-un, 'et za hoti'en hukwa' huninzun 
\p  
\v 38 'Awet whulohne Moses be 'udustl'us 'uk'ununáguzne cha 'ink'ez Phariseene, 'enne cha huyulhni, “Dune hodulh'eh-un neba huwa 'it'en tune' tant'en nts'u hukwa' uzninzun.” 
\p  
\v 39 'Et ubulhni, “'Andit whudizulhne dune hintsi', 'ink'ez 'ahoolhyiz dune ts'eke bulh ninta' hut'ih. 'Et hoonliyaz hooncha tune' whut'en-un, 'et za hukwa ihitis'en. 'I gha la t'ehonózin. 'Et hoonts'i huhoo'en-un bughá holts'it ait'oh. 'Et nts'en'a la nus hoo'en-un Jonah bulh dahooja-un, 'et za hoti'elh. 
\p  
\v 40 Ndiz un'a nja dúhooja, tat dzin 'ink'ez tat 'ulhdzis Jonah lho cho chandanda'. 'Et whuz un'a za yinka dune ye' 'en tat dzin 'ink'ez tat 'ulhdzis yun yo ts'e tidalh. 
\p  
\v 41 'Ink'ez 'oh whuya hoozulh-un dzin dune ba nahutideh de, Nineveh whut'enne nohni 'andit whudizulhne nohtoh do dutádulh 'ink'ez nohba nohotiyeh. Soo cho whunulh'en, 'oh da' Jonah bubulh yailhduk da', ts'iyawh dudeni nahondunizdla. 'Et 'awet soo zulhts'ai, 'ilhoghun 'en Jonah anus 'unt'oh-un 'andit nohtoh usyin. 
\p  
\v 42 'Et 'oh whuya hoozulh-un dzin dune ba nahutideh de, 'et whe nyaz de whulerwe ts'eke 'en nohtoh dudutáyalh 'et whe nohk'ehóotalts'ulh. Ndi yun k'ut nilhdzaz de hainya Solomon ye whunih-i yudutáts'o ha 'et huwa. 'Et hoonts'i 'ilhoghun Solomon anus whunih-un 'andit nohtoh usyin.” 
\s1 Dahooja la whe ntsi'-i nududeh-i doo cha za dune buyunaidide de 
\p  
\v 43 'Ink'ez 'ubúlhni, “'Et ntsi'-i nududeh-un dune ts'u hanádide whe yun whudizgih-un, 'et whuz nududeh natilyis-un hukwu núta. 'Et 'aw ndoohóont'oh-un nalhuhoo'al. 
\p  
\v 44 'Inka dich'oh na'dudútni, ‘'Et mbe la ooyudísda'-un, 'en oots'un za nátoosja',’ ni. 'Et whuz naoosja whe 'aw hoonli hooloh. 'Et ndun dune dudzi yo lhodítsun nawhulhtsi 'ink'ez ts'ih'un na'uja, 'et 'uwhulhni. 
\p  
\v 45 'Ink'ez 'et 'uts'un whedande 'ink'ez lhtak'ant'ine ntsi'-i nududeh-i, 'enne yanus 'ultsi'ne, 'enne 'et dune hiyéndil 'ink'ez 'et nehunina. 'Et ndun dune mbe la hiyudalts'i'-un, 'en 'et whutsoda' whanus 'ultsi' suli'. Nohni 'andit ndo whuya whudizulhne, nohni dune tube untsi'ne aht'oh, 'et whuz un'a za nohba 'uwhutánelh!” 
\s1 Sizi ooloo 'ink'ez bulhutsinke te hiyulh yatilhduk hukwa' huninzun 
\p  
\v 46 Sizi 'awhuz 'ilhunaoosdilne bubulh yalhduk whe ooloo 'ink'ez bulhutsinke te, 'az nódilhya 'et hiyulh yatilhduk hukwa' huninzun. 
\p  
\v 47 'Et 'ilhoghun dune yulhni, “Nilh'en! Nloo 'ink'ez nyulhutsin 'az nódilhya nyulh yahutilhduk hukwa' huninzun!” 
\p  
\v 48 'Et mbe la 'et nduyulhni-un, 'et Sizi 'uyulhni, “Mbe la sloo? 'Ink'ez mbe la sulhutsinke? Mbene hinli whe' dini?” 
\p  
\v 49 'Et Sizi mbene la yugha hodul'ehne, 'enne butune'úlhga, “Nilh'en ndunne, 'enne sloo 'ink'ez sulhutsinke 'uhint'oh. 
\p  
\v 50 'Et huwa sBá 'en yak'uz usda, hik'une' 'ut'enne, 'enne sulhutsin, 'ink'ez sulhtus, 'ink'ez sloo te 'uhint'oh!” 
\c 13  
\s1 Khuni be whuts'odul'eh-i 'a'nule-un ghun 
\p  
\v 1 'Et dzin za Sizi yoh teninya whe bun bá natl'adida'. 
\p  
\v 2 'Et 'awet dune lhane higha oozdil 'inka ts'i beinya, 'ink'ez ts'i bet natl'adida'. 'Et ts'iyawh taba 'et nódilhya. 
\p  
\v 3 Ndai la khuni be whuts'odul'eh-i 'et whe lhelhdun huwa bubulh yalhduk whe ndúbulhni, “Soo zulhts'ai, 'ilhoghun 'a'nule-un 'a'ntilelh ts'u whinya. 
\p  
\v 4 'Et 'a'nule whe ooloh ti nanánkat. 'I dut'aiyaz whusahándil 'ink'ez ts'iyawh hinildil. 
\p  
\v 5 'Et ooloh tse toh nanánkat, 'et huwa 'i 'aho hánuski, 'ankw'us yun hooloh huwa. 
\p  
\v 6 Ooghih hooloh 'et huwa hasain'ai whe ts'iyawh yanúdizgi 'ink'ez gak suli'. 
\p  
\v 7 'Et ooloh cha whus toh nanánkat. 'I cha whus cho whutoh bulh dúduninyai 'ink'ez bulh lhéwhultloh. 
\p  
\v 8 'Et 'onghoh-i yun unzoo-i k'ut nanánkat whe soo hananyai. Oomai whulukhi whunizyat whunizyai (100) oomai' suli', whulukhi lhk'utat whunizyai (60) oomai' suli', 'ink'ez whulukhi tat whunizyai (30) oomai' suli'. 
\p  
\v 9 Mbene la budzo hoonline, 'enne soo cho huyoozólhts'ai' huba' hoont'oh.” 
\s1 Khuni be whuts'odul'eh-i, 'i be za Sizi bubulh yalhduk 
\p  
\v 10 'Et 'awet yugha hodul'ehne highu nindil, 'et huyoodulhkut, 'ink'ez 'uhuyúlhni, “Di ha ndi khuni be whuts'odul'eh-i be za bubulh yaílhduk?” 
\p  
\v 11 'Et ndúbulhni, “Yak'uz be k'úne' whul'en-un be whe hoont'oh hooyoh-i, daja ni-un, nohni za nohghá whunt'ai. 'Et 'onghohne 'aw bugha lhúhoolts'ulh. 'Et huwa whuz un'a za bubulh yasduk. 
\p  
\v 12 'Et huwa ndiz un'a nja duhoont'oh, mbene la hoontsool-unyaz t'ehonínzunne, 'enne 'on nus lhat-un t'ehonínzun-un, 'et bugha whútalts'ulh. 'Et mbene la hoonli t'ewhunúszunne, hoontsool-unyaz, hodits'o ndai la 'aw 'í huyut'i-i, 'i hoonts'i bughu nayitálchulh. 
\p  
\v 13 'Et huwa ndi khuni be whuts'odul'eh-i, 'i be za bubulh yasduk. 
\q1 'Et whe doo ka la honalh'en 'et hoonts'i 'aw lhuhonilh'en. 
\q2 'Ink'ez hodits'o-un 'et hoonts'i 'aw lhuhodústs'o, 'aw t'ehonoozeh cha ait'oh. 
\p  
\v 14 'Et Isaiah nus hon'en whe daja ni 'enne bughun ts'iyawh lhaóodulya 'oh da' za. Ndiz un'a njan dutni, 
\q1 ‘'Ahoolhyiz whudahts'o 'et hoonts'i 'aw t'elhonuzahze. 
\q2 'Ahoolhyiz whunulh'en 'et hoonts'i 'aw ts'ih'un nelhózah'ai. 
\q1  
\v 15 Ndunne dune budzi 'ants'i buba' hoont'oh suli'ne 'et huwa, 
\q2 'ink'ez 'aw hoonli hodóts'o-un hooloh, 
\q2 'ink'ez ndai la be 'alha' hoont'oh-i, 
\q2 'aw hinoolh'en hukwa lhe'hunínzun. 
\q1 'Et huwa hoohoos̱'en lé'hint'oh. 
\q1 'Et whula gha ts'e huhoo'en ait'oh, 
\q2 'ink'ez dudzo be 'aw hodóts'o ait'oh. 
\q1 'Ink'ez dudzi be 'aw t'ehonoozeh-un hooloh. 
\q1 'Et whuz un'a ndulhúhit'oh de, 
\q2 'uda' da' dulubeshi ch'az nahulhya oole' da', 
\q2 'ink'ez da' Yak'usda uboolhyih,’ 
\m ni Isaiah. 
\p  
\v 16 'Et hoonts'i nohni ndai la nohna be whunulh'en-un, ts'ih'un un'a whunulh'en. 'Ink'ez nohdzeh whe soo whúdahts'o, 'et huwa 'uk'enus hoonzoo-un nohghá whults'ut. 
\p  
\v 17 Ts'ih'un 'unohdusni, 'oh da' lhane nus hoo'enne 'ink'ez ts'ih'un 'unt'ohne, ndai la nulh'en-i, 'i huyuntilh'elh hukwa' huninzun, 'et hoonts'i 'aw lhuhuyí'el! Ndet la whudahts'o-un, 'et soo ts'ih'un hodutats'o hukwa' huninzun, 'et hoonts'i 'aw lhuhodíts'il. 
\s1 Khuni be whuts'odul'eh-i be 'a'nule-un, 'en ghun nja dutni whe 'utni 
\p  
\v 18 “'Et huwa ndi khuni be whuts'odul'eh-i be 'a'nulih-un, 'en ghun, ndiz un'a nja dutni whe 'utni, 
\p  
\v 19 mbene la yak'uz nts'en'a 'uhuhoolhdzun-un whulh 'úhudits'o ndi khuni daja ni whe 'utni 'et hoonts'i dudeni be 'aw t'ehonuszun. Ndai la dune dudzi bez 'ahinanla-i, mbe la ntsi'-un whusayaih 'ink'ez budzi be hanaídan'ai! Ndi 'i 'unt'oh ti 'anilya-i, 'i 'unt'oh. 
\p  
\v 20 Ndi ndai da' tse toh 'anilya-i, ndunne 'i k'un'a za 'uhint'oh. Ndi khuni hidits'o te, 'ink'ez soo 'aho huhóont'i' whe huyilhchuk. 
\p  
\v 21 'Et hoonts'i didutch'oh 'aw bughih hooloh le'hint'oh. 'Et huwa 'atsulyaz za buba 'alha' hoont'oh. 'Ink'ez ndi khuni 'i gha dzoh nuhudeh 'ink'ez 'onghohne buch'az huditni. 'Et huwa 'aho whulahudutnih. 
\p  
\v 22 Ndai la whus toh 'anankat-i le'unt'ohne, 'enne ndiz un'a 'uhint'oh. 'Enne khuni hidits'o, 'et hoonts'i ndi yun k'ut huwu ni ts'inli-un, ndi yun k'ut hoonzoo' hoont'oh-un, 'et 'i ts'iyawh whus cho 'i be bulh lheyúllhuk dult'oh. 'Et huwa 'aw lhadúlyane hoole' ait'oh. 
\p  
\v 23 'Et hoonts'i ndet la yun unzoo-i k'éninkat-i le'unt'ohne, 'enne ndiz un'a nja duhint'oh. Ndi Yak'usda ooghuni hidits'o-i, t'ehinuzih te daja ni whe 'utni. 'Et huwa bumai' lhai lhih le'hint'oh. Whulukhun whunizyat whunizyai (100) suli'. 'Et doo cha whulukhun lhk'utat whunizyai (60) suli'. 'Et doo cha whulukhun tat whunizyai (30) suli'.” 
\s1 'Uyoo khuni be whuts'odutil'eh-i, 'i nts'en'a la yak'uz lerwe 'uhuhoolhdzun-un 
\p  
\v 24 Doo cha 'uyoo khuni be nawhutnuk-i be whuts'odul'eh-i, 'i be bubulh yalhduk 'et whe nja dúbulhni, “Nts'en'a la yak'uz lerwe 'uhuhoolhdzun-un, 'et diz un'a nja duhoont'oh. Dune ndi yun ookw'ut 'a'nukat. 'Uzoo'-i 'anukat-i 'ananla. 
\p  
\v 25 'Awhuz huztez whe dune yuch'az ditni-un whusainya. 'Et ndi 'ainanla-i 'uzoo'-i toh, ndi 'anukat-i, 'ut'antsi' ts'utni, 'i yutoh 'ananla, 'ink'ez whenaja. 
\p  
\v 26 'Et ts'iyawh hanányai whe ndi 'ut'antsi', 'i cha bulh hainanyai. 
\p  
\v 27 'Et yoh whumoodih be 'ulhnane highu nindil 'ink'ez 'uhuyulhni, ‘Hadih nemoodih di whe inla ndi unzoo-i hunuyeh ootoh 'ainanla? Di whe 'unt'oh ndi 'ut'antsi' dult'oh?’ 
\p  
\v 28 'Et ubulhni, ‘Sch'az ditni-un la 'uja.’ 'Et be 'ulhnane huyulhni, ‘Ndi 'ut'an untsi'-i ootoh hananyai-i, 'i hats'úntilelh hukwa' ninzun eh?’ 
\p  
\v 29 'Et ubulhni, ‘'Awúndooh! Whute 'unt'oh doo ka la ndi unzoo-i cha bulh 'óohneh. 
\p  
\v 30 Whute 'et ndulhdzun ha' úntikulh whuts'un. 'Et 'awet ha' nukat-un neooninzut de, ha' untilelhne, 'enne si budósni', 'udechoo 'ut'antsi' hanálhle 'ink'ez ulhghel duták'un huba. 'Ink'ez ndai la unzoo-i ts'iyawh hanáhle 'ink'ez haníyeh-i ba yoh whuz danáhle.’” 
\s1 Nts'en'a la yak'uz lerwe 'uhuhoolhdzun-un, ndi mai, mustard huyulhni, 'i k'un'a 'unt'oh 
\p  
\v 31 Doo cha 'uyoo khuni be nawhutnuk-i be whuts'odul'eh-i, 'i be bubulh yalhduk 'et whe nja dúbulhni, “Nts'en'a la yak'uz lerwe 'uhuhoolhdzun-un, 'et ndiz un'a nja duhoont'oh. Ndi mai, mustard huyulhni, 'i k'un'a 'unt'oh. 'I dune yílhchoot 'ink'ez duhanuyeh k'et 'ainanla. 
\p  
\v 32 Ndi mai soo 'uk'enus nint'um-i, 'i hanányai 'ink'ez oochun 'uk'enus dincha suli'. Ndi mustard huyulhni oochun, mai chun 'i ts'iyawh ba ndo idilyiz suli'. 'Et 'i dut'aiyaz 'i duchun dut'aiyaz yuzischum toh t'o nenínla. 'Et whuz un'a yak'uz lerwe 'uhuhoolhdzun-un 'on nus hooncha tileh.” 
\s1 Nts'en'a la yak'uz lerwe 'uhuhoolhdzun-un, 'et lhes ntuldoh-i dult'oh 
\p  
\v 33 Doo cha 'uyoo khuni be nawhutnuk-i be whuts'odul'eh-i, 'i be bubulh yalhduk 'et whe nja dúbulhni, “Nts'en'a la yak'uz lerwe 'uhuhoolhdzun-un, 'et ndiz un'a nja duhoont'oh, lhes ntuldoh-i dult'oh. Ndai la ts'eke yílhchoot 'ink'ez lhes nudzaih-i, 'i ta tsetsai be únde'ooldzih-i dizbun. 'I ntuldoh-i bulh 'ilho be yándzai, 'ink'ez yunilhtlus. 'Et hukw'elh'az 'udun neíninkai whe untílhdo. Ts'iyawh ntuldoh lhih.” 
\s1 Khuni be nawhulnuk-i be whuts'odul'eh-i, 'et whuz un'a za Sizi 'ilhunaoodulhne bubulh yailhduk 
\p  
\v 34 Ndi ts'iya-i khuni be nawhutnuk-i be whuts'odul'eh-i, 'et whuz un'a za Sizi 'ilhunaoodulhne bubulh yailhduk. 'Aw 'uts'un un'a lhe'budínel. 'Et diz un'a za budáni'. 
\p  
\v 35 'Et whuz un'a nyoon nus hoo'en-un daja dani' la, 'et ts'iyawh lhaóoduja whe nja dutni, 
\q1 “Khuni be nawhutnuk-i be whuts'odul'eh-i, 'i be bubulh yatisduk. 
\q2 Nts'oya hoozulh whe ndi yun 'uyinla 'et whuts'un, 
\q2 ndai la buch'a yuntiz'i-i, 'i ghun budutásnelh.” 
\s1 Ndi haniyeh-i toh 'ut'antsi' hanányai-i whubuntilhtun daja ni 
\p  
\v 36 'Et Sizi 'ilhozdilne, 'enne ts'iyawh whenábalh'a' 'ink'ez yoh danínya. 'Et yugha hodul'ehne highu nindil 'ink'ez huyúlhni, “Ndi khuni be nawhutnuk-i be whuts'odul'eh-i, ts'ih'un un'a nedini ndi haniyeh-i unzoo-i toh 'ut'antsi' hanányai-i, 'et daja ni whe 'utni?” 
\p  
\v 37 'Et ndúbulhni, “Ndai unzoo-i hanányai oomai' 'i, mbe la 'ainanla-un, 'en yinka dune ye' 'en 'unt'oh. 
\p  
\v 38 Haniyeh k'et, 'et ndi yun k'ut whunduwhult'oh whe' hoont'oh. Ndi mai unzoo-i, 'i yak'uz whulerwe buzkehne, 'enne duhúlt'oh. 'Et hoonts'i ndi 'ut'antsi', 'i ntsi'-un buzkeh duhúlt'oh. 
\p  
\v 39 'Ink'ez mbe la yuch'az ditni-un, ndi 'ut'antsi' 'ainanla-un, 'en netsudule. Ha'nukat-un 'et 'andit ndóya whudizulh-un 'et whulatoh. Mbene la ha' úntilelhne, 'enne lizas duhult'oh. 
\p  
\v 40 'Et huwa nts'en'a la ndi 'ut'antsi' nahidulhdzooh 'ink'ez hidilhk'un, whuz un'a za njan 'andit whudizulh-un whulatoh de cha, nduwhutanelh. 
\p  
\v 41 'Ink'ez yinka dune ye', 'en oolizas whunilhchoh ts'e whutl'abutilelh. Nts'e la whulerwe unli-un, mbene hukwaya hooni tune' 'úst'enne, 'enne 'ink'ez yuk'unulhe'ust'enne, 'enne ts'iyawh 'ilhunabotálelh. 
\p  
\v 42 Nts'e la kwun dizk'un huba' hoont'oh-un, 'et whuz hubotilhdulh. 'Ink'ez tso yahutilhduk 'ink'ez dughoo lhuhidutik'us. 
\p  
\v 43 'Et dzin nts'en'a la sa hadánat, mbene la ts'ih'un un'a 'unt'ohne, nts'e la buBá lerwe unli-un, 'enne cha whuz un'a za sa k'un'a buts'u haítiduz whe' hoont'oh. Mbene la budzo hoonline, 'enne soo cho huyoozólhts'ai' huba' hoont'oh. 
\s1 Yak'uz k'une' whul'en-un, dáwhudizti' la, 'et ndiz un'a nja dúhoont'oh 
\p  
\v 44 “Doo cha za nohdusni, yak'uz k'úne' whul'en-un, dáwhudizti' la 'et diz un'a nja dúhoont'oh. Ndun dune njan yun k'ut hoonzoo-un, 'et 'oh ho nunúta whe hoonliyaz dizti'-i, 'i la nayin'ai. 'Ink'ez 'on yo nayuntilh'i. 'Et hoont'i' k'et ndun dune ndai hoonli yut'i-i, 'i ts'iyawh ye 'ónket 'ink'ez ndi yun yuk'ut nayin'ai-i, 'i yun ndulcho whe yonket. 
\s1 Doo cha za yak'uz k'úne' whul'en-un, dáwhudizti' la, 'et ndiz un'a nja duhoont'oh 
\p  
\v 45 “Doo cha za nohdusni, yak'uz k'úne' whul'en-un, dáwhudizti' la 'et ndiz un'a nja duhoont'oh. 'Et doo cha 'uyoon dune, 'en hoonliyaz 'i ts'iyawh yooket. 'Et 'on 'un doo cha ye ná'ooket. 'En kw'usul k'us dunizti'-i, 'i hunúta. 
\p  
\v 46 'En 'ilho kw'usul k'us dunizti'-i, 'i la nainin'ai. Ndun dune ndai hoonli yut'i-i, 'i ts'iyawh ye 'ónket whe ndi kw'usul k'us dunizti'-i, 'i yoonanket. 
\s1 Yak'uz k'une' whul'en-un, 'et lhembilh tahúyalhdil, 'et whuz un'a nja duhoont'oh 
\p  
\v 47 “'Et doo cha za nohdusni, yak'uz k'úne' whul'en-un, 'et ndiz un'a nja dúhoont'oh. Ndiz un'a 'uhut'en, lhembilh tahúyalhdil 'ink'ez nonáhuyigus lhawh didowh-i huzdlooh. 
\p  
\v 48 'Et nohúyigus whe ts'iyawh lhtahaháyule. Ndai la lho 'utsi'-i, 'i ts'iyawh tanáhuyulhdilh. 'Ink'ez ndai la unzoo-i ts'iyawh nts'e 'uhitilh'elh ts'ú whehuyulhdilh. 
\p  
\v 49 'Et 'awet nts'oya hoozulh whe buba neóonin'ai-un, 'et buba whusahóolts'ut de, 'et hukw'un'a za 'uwhutánelh. Lizas whusahutidulh, 'enne ts'iyawh unzoone dune 'ink'ez ntsi'ne dune lhtahábotilelh. 
\p  
\v 50 Ntsi'ne, 'enne nts'e la kwun dizk'un huba' hoont'oh-un, 'et whuz hubotilhdulh. 'Ink'ez tso yahutilhduk 'ink'ez dughoo lhuhidutik'us.” 
\p  
\v 51 'Et 'awet Sizi ubúlhni, “Njan ndunóhdusni-un, 'et ts'iyawh eh t'eoonáhzun?” 'Et 'uhuyulhni, “A, neMoodihti, ts'iyawh t'ets'oninzun.” 
\p  
\v 52 'Et 'ubulhni, “'Et huwa mbe la Yak'usda ooghuni 'uk'eguz-i 'ink'ez yak'uz k'une' whul'en-un 'et huwun wheyodalh'e', ndun dune 'en yoh whumoodih-un, 'en dult'oh. 'Ink'ez ndai la yut'i-i toh ts'iyawh ts'et hayúle, 'andidi-i 'ink'ez 'uda'-i cha. 'Et whuz un'a dune hodulh'eh.” 
\s1 Keyoh Nazareth ts'e mbene la Sizi ooba 'alha lhe'hoot'ohne, 'enne ts'iyawh hits'u disnih 
\p  
\v 53 'Et ndi khuni be nawhutnuk-i be whuts'odul'eh-i, 'et 'awet Sizi ts'iyantsuk lhaoodinla whe nyo usda-un whuch'a nasja. 
\p  
\v 54 'Ink'ez dich'oh dukeyoh ts'e naoosja whe Lizwif bulugliz 'et whewhúbondunilh'e'. 'Et whe ts'iyanne buba hooncha suli', 'ink'ez 'et 'ulhodutni, “Ndun dune nts'ez de hahón'ai ndi khuni whutnih-i be yalhduk? 'Ink'ez hooncha tune' 'ut'en nts'en'a dat'en whe 'ut'en? 
\p  
\v 55 'Alha iloh lakw yoh 'uwhulh'en-un, 'en ooye' 'unt'oh? 'Ink'ez 'en iloh lakw ooloo Mary? K'us bulhutsinke iloh lakw 'enne James, Joses, Simon, 'ink'ez Judas? 
\p  
\v 56 'Et bulhtuske 'aw lakw ts'iyawh nebulh lhe'hit'oh? 'Et ndun dune ndi ts'iyawh nts'ez de hahónla whe 'utni?” 
\p  
\v 57 'Et huwa ts'iyawh hits'u disnih. 'Et Sizi ndúbulhni, “Mbe la nus hoo'en unli-un, 'en ts'iyanne yudilhti'. 'Et hoonts'i dich'oh ookeyoh whut'enne 'ink'ez dich'oh ooyoh, 'enne cha 'aw lhuhidílhti'.” 
\p  
\v 58 'Et Sizi 'en 'aw buba 'alha lhe'yit'oh. 'Et huwa dich'oh dukeyoh 'aw lhat-un hooncha tunulhé'it'el. 
\c 14  
\s1 John dune too be 'ulh'en-un, 'en hizilhghi 
\p  
\v 1 'Et 'oh da' 'oh whuya whudizulh whe lerwe Herod 'en Sizi yulh údants'o. 
\p  
\v 2 'Et Herod de 'ustlene 'ubulhni, “Ndun 'en John dune too be 'ulh'en-un, 'en 'unt'oh. Yaidlanne toh nahitna'. 'Et huwa 'ut'en hoolhtus te ne'út'en.” 
\p  
\v 3 Ndiz un'a 'uhooja whe 'oh da' Herod John huyílhchoot 'ink'ez huyulhghel 'ink'ez 'ahúyan'ai. Oobulhutsin Philip huyulhni, 'en oo'at Herodias huyulhni, 'en la toh ts'e yinla. 
\p  
\v 4 'Et John Herod ndúyulhni, “'Aw nyun mba ts'ih'un un'a lhe'hoot'oh whe 'uyoon oo'at oozih sinda.” 
\p  
\v 5 'Et Herod yutuzilhghelh hukwa' ninzun. 'Et hoonts'i dunene John 'en nus hoo'en-un 'unt'oh huninzun, 'et huwa Herod whenilhjoot. 
\p  
\v 6 'Et 'ilhoh dzin 'et Herod whuzdli dzin 'uhoont'oh whe Herodia ootse' 'en bubut nídai. Herod tube ooba hoonzoo. 
\p  
\v 7 'Et 'aho hits'u náhizya whe 'uyulhni, “Ndet sts'o hukwa' ninzun-un sts'o hukwa' dini.” 
\p  
\v 8 'Et nyoon ts'eke ooloo, 'en, “Herod oodilhkut 'ink'ez John dune too be 'ulh'en-un ootsi lusyet be stl'ainkaih dóni',” yulhni. 
\p  
\v 9 'Et huwun lerwe oodzi únduda suli'. 'Et ts'iyanne mbene la yuzih dilhts'ine, 'enne ts'iyawh hidánts'o, 'et whe ts'ekeyaz dughuni yutl'aidan'ai. 'Et huwa 'et whuz un'a 'uhuyooleh huba' hoont'oh. 
\p  
\v 10 'Et 'awet nts'e la 'adin'ai ts'e whuz wheyálh'a', 'ink'ez 'adinlane ghunline, John hitsi k'únintsel. 
\p  
\v 11 'Ink'ez lusyet be whusahúyankai, 'ink'ez ndun ts'ekeyaz tl'ahúyankai. 'Ink'ez duloo yughi nínkai. 
\p  
\v 12 Yugha hodul'ehne, 'enne whusahandil. Hizi huyilhchoot 'ink'ez 'ahúyalhti. 'Et hukw'elh'az Sizi ts'u whehandil 'ink'ez hidáni'. 
\s1 5,000ne dunene Sizi huyoo'alh-i bugha nín'ai 
\p  
\v 13 'Et Sizi whulh udants'o whe buch'a násja 'ink'ez ts'i be inya 'ink'ez nts'e la disoh ts'e whuz nehúninki. 'Et hoonts'i lhane dune t'ehonanzin ibulh nts'e la nehúninki ts'e, whuz lhelhdun keyoh whut'enne hiyuwhenándil. 
\p  
\v 14 'Et Sizi ts'i bé hainya whe dune soo ts'ih'un huldlai k'et 'aw 'uzdooni' ait'oh, 'enne bunilh'en. 'Et 'aho bugha té'nanzin 'ink'ez ndudane cha ts'iyawh soo na'binla. 
\p  
\v 15 'Andit 'awet hulhgha 'uhoont'oh 'et huwa yugha hodul'ehne, 'enne highu nindil 'ink'ez huyulhni, “Njan disoh 'uhoont'oh. 'Awet yoo 'un hoozulh. Ndunne ts'iyawh 'uts'un keyoh ts'e nabalh'alh, 'et whuz la huya'alh-i hoket.” 
\p  
\v 16 'Et hoonts'i Sizi ndubulhni, “'Aw nahutoodilh huba lhe'hóot'oh. Nohnich'oh bugha naínuht'aih.” 
\p  
\v 17 'Et 'uhuyulhni, “'Aw hoonli lhts'it'ih. Lhes kwulai' 'ink'ez lho nanki, 'aw 'i za ts'ut'i.” 
\p  
\v 18 'Et ndubulhni, “Diz sts'óhlelh!” 
\p  
\v 19 'Et mbene la 'ilhunaoosdilne, 'enne ts'iyawh tl'oyaz k'ut natl'ahudoolts'ih ubúlhni. 'Et ndi kwulai' lhes 'ink'ez nanki lho cha, 'i hitl'ahúyanla whe ndo whúnalh'en whe musi ni whe tenadidli. Lhes taidanyuz 'ink'ez lho cha 'et diyinla 'ink'ez yugha hodul'ehne butl'ayánla, 'ilhozdilne bugha húyo'alh ha. 
\p  
\v 20 'Et ts'iyawh 'uhan'al 'ink'ez 'uhunisdai. Ndai la ch'utizkat-i ts'iyawh nahuyalhdzoo whe whunizyai 'on 'at nanki chalhyal dizbun. 
\p  
\v 21 'Et nyoonne dunene, 'enne 'ankw'us 5000ne 'uhan'al. 'Et ts'oodunne 'ink'ez ts'ekoo 'enne cha 'uhan'al. 
\s1 Sizi too k'ut nuya 
\p  
\v 22 'Et 'aho Sizi yugha hodul'ehne ts'i bez whenábalh'a' whe, “Stso nyan ahkelh,” ubulhni. 'Ink'ez 'ilhunaoosdilne, 'enne cha dukeyoh ts'e whenábalh'a'. 
\p  
\v 23 'Et 'awet ndunne ts'iyawh whenábalh'a' whe didutch'oh ndo dzulh k'uz whinya tenadutidli ha. Dich'oh únli whe bé nadalhghel. 
\p  
\v 24 'Et 'awet ts'i bun k'ut taniz 'oh whuya ukwus nilhts'i tube búdudizts'i, 'ants'i lhents'ó dildus. 
\p  
\v 25 'Et 'awet bundada' yutilhkai whe Sizi too k'ut buts'u tizya. 
\p  
\v 26 'Et khunsul yugha hodul'ehne hitilh'en whe hunílhjoot, “Dune tsin 'ut'en!” hutni ibulh tsoya whehúnilhduk. 
\p  
\v 27 'Et 'aho Sizi buts'u yatilhduk, “Nohdzi ulhtus úlhtsi! Si 'ust'en! Whenulhjut íloh!” 
\p  
\v 28 Peter diz un'a yoodulhkut, “SMoodihti 'alha nyun 'int'en de, too k'ut nts'u toosya'-un stl'ahóon'aih.” 
\p  
\v 29 'Et 'aho 'uyulhni, “'Anih!” 'Et 'awet Peter ts'i be hainya 'ink'ez Sizi too k'ut yuts'u tiyalh ha. 
\p  
\v 30 'Et nyo whunilh'en whe nilhtsi tube ulhtus 'ink'ez whenilhjoot 'ink'ez yo útizdlat whe, “SMoodihti, sla 'ineh!” yulhni. 
\p  
\v 31 'Et 'aho Sizi yula súgooh whe ndi yulhni, “'Aw soo 'ultsuk-i be 'alha' hoont'oh-i lhint'ih. 'Et dahoont'oh huwa mba nawh 'uhoont'oh?” 
\p  
\v 32 'Et ts'i be náhit'az whe 'aho nilhts'i k'oh 'úja. 
\p  
\v 33 'Et mbene la ts'i bet dilhts'ine, ts'iyawh hibut nachánilya 'ink'ez 'uhuyulhni, “'Alha nyun Yak'usda ooYe' 'int'oh!” 
\s1 Gennesaret whut'enne undudáne Sizi soo na'bulh'en 
\p  
\v 34 'Et 'awet nyan Gennesaret ts'e yahuzki whe, 
\p  
\v 35 'et keyoh whut'enne Sizi hitilh'en ibulh, nahuyóolhts'it whe lhtunuhúnihust'ai. 'Ink'ez ts'iyawh ndudane hits'ú boozdla. 
\p  
\v 36 “Ndai la nyunaih naints'uz-i 'ants'i yus ts'e oot'áts'onalh,” huyulhni. Ts'iyawh mbene yut'aiznaine, 'enne soo ts'iyawh ts'ih'un un'a soo ná'huja. 
\c 15  
\s1 Ndai la nedzi be yats'ulhduk-i, 'i gha ts'intsi' lhih 
\p  
\v 1 'Et 'awet Jerusalem keyoh whuts'un ndunne Moses be 'udustl'us 'uk'ununáguzne 'ink'ez Phariseene, 'enne cha ts'iyawh Sizi highu nindil 'ink'ez 'uhutni, 
\p  
\v 2 “'Et di ha ngha hodul'ehne, netsoda'ne 'uda' ne'whust'en hukw'un'a 'aw hukw'unulhe'hust'en? Whunilh'en, ndunne ngha hodul'ehne, 'aw lanalhe'hulhde 'uhuti'ulh whutso!” 
\p  
\v 3 'Et dúbulhni, “'Et di ha nohnich'oh nohk'oh ts'e huwa Yak'usda ooghuni ook'unulhe'zaht'en? 
\p  
\v 4 Whunulh'en, nohni nts'en'a daht'en! Yak'usda dughuni nohtl'aidan'ai whe nja dutni, ‘Mbá 'ink'ez nloo bulh hubudólhti'.’ 'Et doo cha 'udun 'et nja dutni, ‘Mbe la duloo 'ink'ez dubá bulh dzoh ts'e bughu yatilhduk-un, 'en daootsa huba 'unt'oh.’ 
\p  
\v 5 'Et hoonts'i nohni ndiz un'a 'udahni, ‘Mbe la dubá k'us duloo nja dúbulhni-un, ndai 'ust'i-i, 'i be da' nohla 'oost'en oole', 'et hoonts'i 'i ts'iyawh Yak'usda gha núsdla.’ 
\p  
\v 6 'Et whuz un'a nohe'ut'en k'oh be 'aw duloo 'ink'ez dubá bulh lhubudílhti'. 'I be Yak'usda ooghuni nohtl'aidan'ai-i, 'i 'aw hoonliyaz lhiloh sulhtsi! 
\p  
\v 7 Nohni duba na'udzoo'ne ahli! Ndun nus hoo'en Isaiah, 'en 'uda' hon'en 'ink'ez ts'ih'un un'a 'utni nohni nohghun. Njan 'et nja dutni, 
\q1  
\v 8 ‘Ndunne dune dughuni be be za sodílhti'. 
\q2 'Et hoonts'i budzi, sughun nilhdza' 'unt'oh. 
\q1  
\v 9 Ndunne doo ka la 'ants'et sts'un teni 'uhunoolhdzin. 
\q2 'Ink'ez ndet la dune bube 'ut'en k'oh, 
\q2 'i Yak'usda ooghuni netl'aidan'ai-i 'i k'un'a 'uyoonne hubuhodoolh'eh hukwa' hut'en.’” 
\p  
\v 10 'Et Sizi 'ilhunaoodulhne, “'Anih! Diz áhdulh!” ubulhni, 'ink'ez 'et ndúbulhni, “Soo zúlhts'ai 'ink'ez soo cho t'eoonahzeh! 
\p  
\v 11 Ndai la dune buza yúkat-i, 'aw 'et whe íloh hintsi' hulhih. 'Et hoonts'i ndai khuni 'aw lhizoo'-i dune ye yalhduk-i, 'i be dune hintsi' lhih.” 
\p  
\v 12 'Et yugha hodul'ehne higho nindil whe 'uhuyulhni, “T'eoonínzun eh ndunne Phariseene nyodants'o whe daja dini-un, 'et ndúwhulcho whe buba dzoh 'údinja?” 
\p  
\v 13 'Et Sizi ubulhni, “'UBá yak'uz usda, ndai la 'aw 'alhinilel-i, 'i ooghih tubulh hahitilhch'ulh. 
\p  
\v 14 Whute! Ndunne 'aw buts'áhalhozah'ai! 'Enne moodih hoos̱'enne le'hint'oh. 'Et ndiz un'a nja duhoont'oh, 'ilhoghun hoos̱'en-un 'ink'ez 'ilhoghun hoos̱'en-un ghunli de, nahúlt'oh tsa k'et 'áhatilts'ulh.” 
\p  
\v 15 'Et Peter yoodulhkut, “Ndi be nawhutnuk 'i be whuts'odul'eh-i, nts'en'a daja ni, 'et ts'iyawh whunénilhtun.” 
\p  
\v 16 'Et 'uyulhni, “'Aw eh noheni talhodulhts'it whe eh dahni? 
\p  
\v 17 'Awhuz eh ts'ih'un nelhózah'ai? Dune ndai la ooza yúkat-i, 'i ts'iyawh oobut za be yukat. 'Ink'ez ooyust'e ts'u hanáyukat. 
\p  
\v 18 'Et ndai la dune khuni be yailhduk-i, 'i budzi ts'u hayúkat 'i 'unt'oh, 'ink'ez 'i dune dilhtsi'. 
\p  
\v 19 Soo cho whunulh'en, ndi 'et ndunt'oh-i, 'i dune budzi bez hayúkat, be ne-eni untsi'-i, dune hutuzilhghelh, 'uyoon dune oo'at k'us 'uyoon ts'eke ooki bulh ninta' ant'en-un, 'ink'ez 'aw lhghulhdilts'ine hoonts'i whuz un'a za ne'hut'en. 'Uduntit'ih-un, 'uyoonne ba whuts'it-un, 'ink'ez Yak'usda ch'az yalhduk-un cha. 
\p  
\v 20 'Et njan 'et dúhoont'oh-un, whunilhchoh whe dune hintsi' lhih. 'Et 'aw lanalhe'zulhde whe 'ah'alh-un, 'aw 'et huwa iloh hintsi' lhih.” 
\s1 Ndun ts'eke, 'udun yun k'ut whut'en-un, 'en ooba 'alha' hoont'oh hooncha whe' hoont'oh 
\p  
\v 21 'Et 'awet Sizi nyo usda-un whuch'a nasja whe Tyre keyoh 'ink'ez Sidon keyoh 'oh ho whenghoh ts'u naóosja. 
\p  
\v 22 'Et whuts'un 'ilhoghun ts'eke, 'en Canaan whut'en-un 'unt'oh, 'en yughu ninya. Tso bulh yalhduk whe' yulhni, “SMoodihti sgha te'ninzeh, t'enyunúszun David oots'u hainzut-un 'int'oh! Syaz ts'ekeyaz 'en tube hoontsi' hukw'un'a ntsi'-i nududeh-i ooyudinda!” 
\p  
\v 23 'Et 'aw daja lhidínel. 'Et yugha hodul'ehne highu nindil 'ink'ez 'uhuyulhni, “N'un nailh'alh, 'et la tso bulh yalhduk-un 'etsul udónih.” 
\p  
\v 24 'Et 'ubulhni, “Mbene la Israel ooyoh whut'ine, 'enne 'ants'i 'usbai ninta nih'az-i le'unt'ohne, 'enne za buts'ú tiz'a'.” 
\p  
\v 25 Ndun ts'eke 'en yughu ninya whe yubut nachaniti 'ink'ez, “SMoodihti, sla 'ineh!” yulhni. 
\p  
\v 26 'Et Sizi diz un'a 'uyulhni, “Ndai la ts'oodunne yu'alh-i lhikeyaz gha óoh'alh junih.” 
\p  
\v 27 'Et ts'eke 'uyulhni, “SMoodihti 'alha' dini. 'Et hoonts'i ndai la moodihti ludab k'ut tukat-i, 'i lhikeyaz huyuldil.” 
\p  
\v 28 'Et Sizi 'uyulhni, “'Ooh ts'eke hooncha whe mba 'alha' hoont'oh-un, 'et hooncha whe' hoont'oh. 'Et huwa hukwa' ninzun k'un'a 'uhoneh.” 'Et soo 'oh whuya hoozulh-un, ooyats'e soo na'uja. 
\s1 Lhane undudane, 'enne Sizi usda-un highu nindil 'ink'ez ts'iyawh soo ná'balh'en 
\p  
\v 29 'Et 'awet Sizi bughu natisja whe Galilee bun 'oh ho neninya. Ndo dzulh k'uz whinya, 'et natl'adida'. 
\p  
\v 30 'Et khunsul lhane dune, 'enne highu nindil. Mbene la nulhúsdilne, hoos̱'enne, yalhulhdukne, ooyust'e bodin'aine, 'ink'ez 'uyoonne cha, 'enne ts'iyawh hits'u botule. Hibut neboninla 'ink'ez ts'iyawh soo ná'balh'en. 
\p  
\v 31 Yalhulhdukne cha yawhehunilhduk, ooyust'e bodin'aine, 'enne cha soo na'huja. Nulhúsdilne cha nahúdilh nahusdli', hoos̱'enne cha huhoo'en nahusdli'. Ts'iyanne bunalh'en whe tube buba hooncha 'ink'ez Israel oodune'ne, 'enne buYak'usda 'en 'on nus hidálhti'. 
\s1 Sizi 4,000ne ghá' nin'ai 
\p  
\v 32 Sizi yugha hodul'ehne, 'enne 'anih budáni' 'ink'ez ndúbulhni, “Ts'iyawh ndunne dunene bugha té'nuszun. Tat dzin whuts'un nja szih hudilhts'i 'ink'ez 'aw huya'alh-i lhuhít'i'. 'Et 'aw lhe'hus'al whe bukeyoh ts'e nabutoos'a' ait'oh. 'Et dúbusdla de, nahidulh ts'e la bukaootoozit.” 
\p  
\v 33 Yugha hodul'ehne huyulhni, “Njan keyoh 'aw dune hooloh-un 'uhoont'oh. Nts'ez de suba soo 'últsuk-i t'alh-i nats'ólelh lhe'ultsukne dune gházti'alh-i?” 
\p  
\v 34 'Et Sizi ubúlhni, “Daltsuk lhes sut'e aht'i?” “Lhtak'ant'i lhes sut'e 'ink'ez lho nt'umiyaz bulh,” huyulhni. 
\p  
\v 35 'Et 'ilhozdilne natl'adulhts'ih ubulhni. 
\p  
\v 36 'Et ndi lhes lhtak'ant'i lho bulh yílhchoot 'ink'ez musi ni whe tenadidli. Taidanyuz 'ink'ez yugha hodul'ehne butl'ayánkai. 'I ts'iyawh natl'adilts'ine butahinínla. 
\p  
\v 37 Ts'iyawh na'hit'al 'ink'ez 'uhunisdai. 'Et yugha hodul'ehne lhtak'ant'i chalhyal dizbun 'i highá 'oz'al-i nahuyalhdzoo. 
\p  
\v 38 4,000ne dunene at'en 'uhan'al. Ts'oodunne 'ink'ez ts'ekoo 'enne cha 'uhan'al. 
\p  
\v 39 'Et 'awet Sizi 'ilhunaoosdilne bukeyoh ts'e whuz whenábalh'a' whe 'et ts'i be naja 'ink'ez yun Magdala huwhutni ts'e whuz whehánki. 
\c 16  
\s1 Phariseene 'ink'ez Sadduceene cha, 'enne huwa 'ít'en-un buba' hooleh hukwa huyoodulhkut 
\p  
\v 1 'Awet ndunne Phariseene 'ink'ez Sadduceene cha, 'enne highu nindil 'ink'ez huyóolhdzih whe huyoodulhkut, “'Aw yak'uz whuts'un hooncha tune' whut'en-un, whunénolhtun ait'oh?” 
\p  
\v 2 'Et ndúbulhni, “'Et hulhgha ts'e ndo yat whunulh'en. 'Et whudulk'un de, 'et dzin hoonzoo tileh dahnih. 
\p  
\v 3 'Et bundada' yat kw'us bulh dulk'un suli' whunulh'en de, 'awet azih whudutitsi' dahni. Nohni duba na'udzoo'ne ahli! 'Et ndo yat dawhut'en la, 'et t'eoonáhzun. 'Et hoonts'i ndoyá whudizulh dawhut'en la, 'et ndet 'uwhulhni, 'aw t'eoonuzáhzun! 
\p  
\v 4 Njan 'andit whudizulhne, 'enne lubeshi ts'u nint'ine za' 'uhint'oh. 'Ink'ez 'ahoolhyiz dune ts'eke bulh ninta' hutit'elh-un, 'et za whuts'ónint'i. 'Ink'ez hooncha huwa 'ít'en-un whuntilh'elh hukwa' nahzun. 'Et hoonts'i 'aw hooh'en-un nohghá holts'it ait'oh. 'Et nts'en'a la Jonah bulh dáhooja inle' la, 'et za whutih'elh whe' hoont'oh!” ubúlhni, 'ink'ez bughu whenája. 
\s1 Huwohoole' Phariseene 'ink'ez Herod bules untuldoh-i, 'i ch'a ubúlhni 
\p  
\v 5 'Et 'awet nyan nahooski whe yugha hodul'ehne lhes nahodilhnoh. 
\p  
\v 6 'Et Sizi ndúbulhni, “'Ahoolhyiz wheni khahdli ndunne Phariseene 'ink'ez Sadduceene cha, 'enne bules untuldoh-i ch'a.” 
\p  
\v 7 'Et 'aho lhulh yawhehunilhduk, “'Et 'aw lhes lhts'ít'ih 'et huwa 'utni.” 
\p  
\v 8 'Et Sizi t'eoonanzin whe 'et dúbulhni, “Nohni be 'alha' nahzun-i unsool! 'Et huwa' 'udahni. 'Aw lhes sálhah'al, 'et huwa eh 'et howu yalhduk? 
\p  
\v 9 'Awhuz eh 'aw ts'ih'un t'eoonuzahzun? 'Aw whunalhuzulhni whe kwulai' lhes 'i be 5,000ne gha náh'ai, 'ink'ez daltsuk chalhyal ch'utizkat-i, 'i nalhdzoo? 
\p  
\v 10 'Et doo cha lhtak'ant'i lhes 'i be 4,000ne gha náh'ai, 'et daltsuk chalhyal ch'utizkat-i, 'i nalhdzoo? 
\p  
\v 11 'Et nts'en'a aht'oh t'eoonuzahzun, 'aw lhes ghun nohbulh yalhuzusduk? 'Uda' nohdasni, ndunne Phariseene 'ink'ez Sadduceene cha, 'enne bules untuldoh-i huwohle', 'i ooghu yasduk whe' dusni.” 
\p  
\v 12 'Et 'aho t'ehoninzun ndunne Phariseene 'ink'ez Sadduceene cha, dune huhodulh'eh-un, 'et whuch'a buch'a huwahli, 'et 'uwhulhni. Ndi lhes bulh untuldoh-i, 'i ch'a huwahli ni iloh whe 'utni. 
\s1 Sizi 'en Christ 'unt'oh 'et Peter huwu yalhduk 
\p  
\v 13 'Et Sizi Caesarea Philippi buyun k'uz whinya whe yugha hodul'ehne, 'enne uboodulhkut, “Si yinka dune ye' 'ust'oh. 'Et hoonts'i n'awh dunene, mbe whe 'ust'oh hutni?” 
\p  
\v 14 'Et 'uhuyulhni, “Whulohne, 'enne nyun John dune too be 'ulh'en-un 'int'oh hutni. 'Et whulohne cha, nyun Elijah 'int'oh hutni. 'Et 'onghohne cha, nyun Jeremiah 'int'oh hutni. 'Ink'ez whulohne nyun nus hoo'en-un 'ilhoghun 'int'oh hutni.” 
\p  
\v 15 'Et 'ubulhni, “Nohni do', mbe 'ust'oh dahni?” 
\p  
\v 16 'Et Simon Peter yatilhduk whe 'uyulhni, “Nyun Christ, Yak'usda khuna-un, 'en ooYe' 'int'oh.” 
\p  
\v 17 'Et Sizi 'uyulhni, “Simon Jonah ooye', 'uk'enus hoonzoo-un nghá whults'ut! Ndet sudini-un, 'et 'aw ndi yun k'ut dune, 'enne iloh nyunalhts'et hahúhon'ai. 'UBá yak'uz usda-un, 'en nyunalhts'et hahon'ai. 
\p  
\v 18 'Ink'ez nyun Peter 'int'oh. 'Et ndi tse 'i k'ut slugliz neootas'alh. Njan mbe la kwuncho ulhtus-i yo ts'u haindilne, 'enne hoonts'i 'aw whuch'a hoolhdeh ait'oh. 
\p  
\v 19 Nts'e la yak'uz whulerwe usda-un, whulugli ntl'atis'alh. 'Et ndi yun k'ut ndai la whedinguz-i, 'et 'uda' yak'uz cha whuz un'a za whedint'i. 'Et ndai la ndi yun k'ut k'unain'uk-i, 'et yak'uz cha 'uda' whuz un'a za k'unatit'uk.” 
\p  
\v 20 'Et yugha hodul'ehne khuniti be 'ubúlhni, “Khun te 'uyoonne dóhni' junih si Sizi mbe la Christ, 'en 'ust'oh.” 
\s1 Dzoh nutizut-un 'ink'ez datítsah-un, 'et Sizi huwu yalhduk 
\p  
\v 21 'Et 'oh whuya hoozulh whuts'un Sizi yugha hodul'ehne, 'enne whubunulhtun nus daootanelh la. Nts'en'a whe Jerusalem ts'u tiyalh. 'Et keyoh ndunne 'utso whudilhdzulhne, 'ink'ez lubret bumoodihne cha, 'ink'ez Moses be 'udustl'us 'uk'ununáguzne cha, 'enne bube lhat-un whe dzoh nuhítilhdzut, 'ink'ez hituzilhghelh. 'Et whulh tát dzin, 'et dunadutádalh. 
\p  
\v 22 'Et Peter Sizi yílhchoot 'ink'ez 'udun neínilhti 'ink'ez hukwa' yudáni', “SMoodihti nyun Yak'usda ngha te'untazeh! 'Aw nyulh 'et dúhoneh ait'oh!” 
\p  
\v 23 Peter yuts'u nálh'a 'ink'ez 'uyulhni, “Satan st'a nenínyaih! Nyun yooya suzilhts'i! Yak'usda nts'en'a la dat'en-un, 'et 'aw howu nuni lhnuzinzut. Ndi yun k'ut dune nts'oh tula ne'hut'en-un, 'et hukw'un'a za nuni ninzut!” 
\s1 Mbe la whe khuna-un Sizi gha ninta oonin'ai de, 'en whe khuna-un whuch'a ootalhdoh 
\p  
\v 24 'Et Sizi yugha hodul'ehne ndúbulhni, “Mbe la dune se' 'ut'en k'oh oot'en ha suntiyalh hukwa' ninzun de, ndi yun k'ut dats'ínt'oh-un, 'et ts'iyawh whula dootni, 'ink'ez dutulalhgus yólhchoot 'ink'ez suntooya'. 
\p  
\v 25 'Et huwa mbene la whe khuna-un hotilhyihne, 'enne 'et hoonts'i ninta huhúta'alh. 'Et hoonts'i mbe la whe khuna-un si sgha ninta oonin'ai de, 'en whe khuna-un nahootá'alh. 
\p  
\v 26 'Et huwa dune ndi yun 'i ndulcho whe ooch'e' yúzdli' de, 'ink'ez duzul 'i ninta inín'ai de, ndet whe ooba whutázoo'? 'Ink'ez dich'oh duzul nayitalhchulh hukwa' ninzun de, di k'elha suba duzul nayoket? 
\p  
\v 27 'Et huwa yinka dune ye' whusatiyalh, ndai la ooBá ye dizti'-i 'ink'ez oolizas, 'enne bubulh, 'et whusainya de, nts'en'a la ts'iyanne dahit'en, whuz un'a 'ilhone whe buba k'elha whutaleh. 
\p  
\v 28 Soo ts'ih'un un'a nohdusni, whulohne njan núdilhyanne, 'enne ndet la dahutitsah-un 'et whuts'un yinka dune ye' nts'en'a la whe lerwe unli-un, 'et whuz un'a whuz de uyalh de, ndunne dahútitsa whuts'o huyuntilh'elh.” 
\c 17  
\s1 Sizi 'uts'un ot'en suli' 
\p  
\v 1 'Et 'awet whulh lhk'utat dzin inle' whe Sizi 'en Peter, James cha, 'ink'ez dulhutsin John, 'enne ndo dzulh k'uz dulh ubílya. 
\p  
\v 2 Khunsul bubut 'uts'un ot'en suli'. Oonin 'ants'i sa k'un'a oots'u ha'ánduz, 'ink'ez oonaih 'i cha khunsul 'ulhyul suli', 'ink'ez 'i cha oots'u ha' 'ánduz. 
\p  
\v 3 'Et khunsul Moses 'ink'ez Elijah bulh bube hóodilts'ai 'ink'ez Sizi hibulh yáwhenilhduk. 
\p  
\v 4 Peter Sizi ndúyulhni, “NeMoodihti njan uzdilhts'i hoonzoo. Hukwa' ninzun de, tat-un whut'ah uztitez-un 'uts'otilelh. 'Ilhoghun nyun mba, 'et 'ilhoghun Moses ba, 'ilhoghun cha Elijah ba.” 
\p  
\v 5 Peter yalhduk whe khunsul kw'us be tidat'en whe buk'einde. Kw'us toh ts'e khunsul 'uwhutni, “Ndun sYe' 'uk'enus ook'esi'-un 'unt'oh. 'En bulh hóonust'i'. 'En za 'oozúlhts'ai!” 
\p  
\v 6 Yugha hodul'ehne hídants'o whe hibut nachánildil, 'ink'ez tube whehúnilhjoot. 
\p  
\v 7 Sizi bughu ninya 'ink'ez but'aiznai whe ubulhni, “Dunadahdilh 'ink'ez whénulhjut iloh!” 
\p  
\v 8 'Et ndo nahítat'en whe 'aw 'uyoonne hooloh. Sizi didutch'oh za hiyan'en. 
\p  
\v 9 Ndet la dzulh k'ut whenáhudidil whe, 'et yo nahidulh whe Sizi khuni ulhtus-i be bubulh yalhduk whe 'et ndúbulhni, “Yinka dune ye' yaidlanne toh dunadutádalh whuts'un ndet hooh'en-un, khun 'uyoonne dóhni' junih!” 
\p  
\v 10 'Et yugha hodul'ehne, 'enne huyoodulhkut, “Ndunne Moses be 'udustl'us 'uk'ununáguzne, 'et di ha' hutni, Elijah 'en cho whusatiyalh huba' hoont'oh hutni?” 
\p  
\v 11 'Et Sizi ndúbulhni, “'Et 'alha Elijah 'en cho whusatiyalh 'ink'ez ndai hoonliyaz ts'iyawh lhanaidutileh. 
\p  
\v 12 'Et hoonts'i nohdusni, Elijah 'uda' whusainya whe 'unt'oh. 'Ink'ez 'en 'aw t'ehinúszun. 'Et hukwa' huninzun k'un'a 'uhuyinla. 'Et whuz un'a za 'enne bula be yinka dune ye' dzoh nutizut.” 
\p  
\v 13 'Et yugha hodul'ehne, 'enne ts'iyawh John dune too be 'ulh'en-un, 'en ghu yalhduk t'ehonanzin. 
\s1 Ts'oodun ntsi'-i nudúdeh-i ooyudinda-un, 'en Sizi soo ná'yinla 
\p  
\v 14 'Awet 'ilhozdilne butanahundil whe 'ilhoghun dune yughu ninya 'ink'ez yubut dugwutsi be nenínya. 'Ink'ez 'utni, 
\p  
\v 15 “SMoodihti sye' 'en oogha te'ninzeh! Ookaootuzuk 'ink'ez tube dzoh nuzut. Lhat tsudúlts'uk 'ink'ez talts'uk cha 'ut'i. 
\p  
\v 16 'Et ngha hodul'ehne bughi nústih hoonts'i 'aw soo na'huyooleh ait'oh.” 
\p  
\v 17 'Et Sizi ndutni, “Nohni 'andit whudizulhne, nohni 'aw be 'alha hoont'oh-i lhaht'ih, 'ink'ez tank'us za' 'iht'elh. 'Et dawhuldzoh nohtoh tisdalh? 'Ink'ez dawhuldzoh nohba 'et ndutist'elh? De', nye' 'en sghu nilhtih!” 
\p  
\v 18 'Et ntsi'-i nududeh-i ooyudinda-un, Sizi 'en ts'un khuni ulhtus-i be hukwa' yudáni'. 'Et whulh hulhgha za yuts'u hanája 'ink'ez ndun ts'oodun soo na'uja. 
\p  
\v 19 'Et Sizi yugha hodul'ehne, 'enne disoh ts'e highu nindil whe 'uhuyulhni, “'Et dahoont'oh huwa whe ndun ts'oodun ntsi'-i nududeh-i oots'u hanáts'inooyoot ait'oh?” 
\p  
\v 20 'Et Sizi ndúbulhni, “'Aw nohba 'alha lhe'hoot'oh 'et huwa 'aw 'oohleh ait'oh. 'Alha nohdusni ndi 'anukat-i lhe'niltsool-i, 'i mustard huyulhni, 'i k'un'a be nohba 'alha' hoont'oh-i, 'et 'ulcho de, 'et ndiz 'un'a da' 'udoohtni'. Ndi dzulh njan whuts'un, 'et nguz nailts'ut dahni de, 'aho 'et dutínelh. 'Et whuz un'a ts'iyaitsuk whuz un'a 'udahni de, 'et ndutít'elh. 
\p  
\v 21 'Et hoonts'i ndi ntsi'-i nududeh-i, netenadudli-i, 'ink'ez soo ts'úhoonih, 'et de za dune buts'u hanáts'iyuntiyulh whe' hoont'oh.” 
\s1 Sizi datitsah-un, 'et doo cha huwu yalhduk 
\p  
\v 22 'Et 'awet Sizi 'ink'ez yugha hodul'ehne, 'enne Galilee yun k'ut hudilhts'i whe ndúbulhni, “'Awet nilhdukw yinka dune ye', 'en 'uyoonne dune tl'ahítilhtelh. 
\p  
\v 23 Hituzilhghelh 'ink'ez whulh tat dzin inle' de, dunadutádalh.” 'Et hodánts'o whe ts'iyawh tube ts'odi huzdli'. 
\s1 Sizi 'en cha lugliz whucho whuzooneya yuk'elha hoolh'i 
\p  
\v 24 'Awet keyoh Capernaum whuz hoozdil whe 'ilhoghun sooneya 'ilhunaoo'aih-un, 'en Peter yughu ninya whe yoodulhkut, “Whunohodulh'eh-un 'en cha iloh lakw lugliz whucho whuzooneya yuk'elha hoolh'i?” 
\p  
\v 25 'Et, “A,” ni. 'Et Peter yoh ts'u whinya. 'Et Sizi yutso yatílhduk 'ink'ez 'et dúyulhni, “Simon, daja ninzun? Ndi ndai la sooneya dune buba k'elha yutaleh-i, ndi yun k'ut whulerwene, 'enne ndi sooneya 'ilhunahos'aih? Dich'oh bubuzkeh tilah k'us n'awh whut'enne tilah?” 
\p  
\v 26 'Et Peter ndúyulhni, “'Aw n'awh whut'enne, 'aw 'enne za.” Sizi 'uyúlhni, “'Et 'alha' dini. Lerwene dich'oh bubuzkeh 'enne 'aw buba k'elha hole' ait'oh. 
\p  
\v 27 'Et hoonts'i ndunne Capernaum whut'enne, 'enne nebulh hónilch'e hukw'un'a 'ubuts'oolh'en ait'oh. 'Et huwa ndi lugliz whucho whuzooneya', 'i la buba k'elha ts'uyoolhtselh. Dugwe', bun guz ts'inyalh 'ink'ez oolhjas. Soo 'udechoo lho silhjus-i, 'i ooze lhch'az 'uhoonleh. 'Et sooneya naitán'alh. 'I ilhchoot 'ink'ez neba bugha ínin'aih.” 
\c 18  
\s1 Yak'uz whulerwe dilhts'i-un mbe suba 'uk'enus dízti'? 
\p  
\v 1 'Et 'oh da' za Sizi yugha hodul'ehne, 'enne highu nindil 'ink'ez huyoodulhkut, “Yak'uz whulerwe dilhts'i-un mbe suba k'us dízti'?” 
\p  
\v 2 'Et Sizi ndun ts'oodunyaz 'anih yulhni, 'ink'ez butoh neínilhti. 
\p  
\v 3 'Ink'ez 'et ndúbulhni, “'Et soo ts'ih'un un'a 'unohdusni, 'et 'aw 'uts'un un'a nalhe'zahne de, 'ink'ez ts'oodunneyaz k'oh ts'e aht'oh nasahdli' de, 'et de za nts'e la yak'uz whulerwe unli-un whuz tihdulh. 
\p  
\v 4 'Et huwa ndun ts'oodunyaz, mbe la yuk'oh ts'e 'unt'oh-un, whuz un'a dich'oh te'dudil'en, 'et ndunt'oh-un, 'en nts'e la yak'uz k'une' whul'en-un, 'enne butoh k'us hidilhti'-un tileh whe 'unt'oh. 
\p  
\v 5 'Ink'ez mbe la ndun ts'oodunyaz, mbe la yuk'oh ts'e 'unt'oh-un, huhóont'i' 'i bulh highu nuseya, si cha whuz un'a za 'usuhinla.” 
\s1 Dune ntsi'-un lubeshi 'itálhchulh-un, 'et whuts'u yúlha 
\p  
\v 6 “'Et ndunne ts'oodunne buba 'alha' 'ust'ohne, ts'oodunne hoontsi' ts'e ubonilht'ine, mbe la dune edújane, 'enne tse cho buts'ilchun ehudinguz 'ink'ez k'us takhulh-un 'et tábuhano de, 'et 'on nus hootázoo'. 
\p  
\v 7 Ndi yun k'ut dilhts'ine, 'enne mbene la hukwaya hooni tune' 'ut'enne, 'enne dawhultsi'-un, 'et buts'u hóolts'ulh whe' hint'oh. 'Alha njan hukwaya hooni tune' hutit'en whe' hoont'oh. 'Et hoonts'i mbe la oogha 'et 'úhooja-un, 'enne dawhultsi'-un, 'et hoti'elh whe' hoont'oh! 
\p  
\v 8 'Et nla k'us nke 'i be hukwaya hooni tune' 'ínt'en de, k'unint'as 'ink'ez 'un tilh'is! 'Et dzoh ninya k'us nyust'e bodin'ai de, 'et whuz un'a 'ilhiz be ts'ukhuna-i nghalts'ut de, 'et whuz un'a 'uk'enus mba hootázoo'. 'Et hoonts'i nke nankult'oh cha 'ink'ez nla nankult'oh cha bulh 'ínt'oh whe kwun nalhnusne-i tanyoníno de, 'uk'enus mba hootátsi'. 
\p  
\v 9 'Ink'ez nyuna be hukwaya hooni tune' whut'en-un whunilh'en de, nyuna hanín'aih 'ink'ez 'un ntilh'is! 'Et nyuna 'ilho bulh za, 'et whuz un'a 'ilhiz be ts'ukhuna-i ngha nínzut de, 'uk'enus mba hootazoo'. 'Et hoonts'i nyuna nankult'oh bulh kwun nalhnusne-i tanyoníno de, 'uk'enus mba hootatsi'. 
\s1 Mbene la ninta ninkatne, 'enne Sizi ubutilhyih ha, 'et huba whusainya 
\p  
\v 10 “'Et ndunne ts'oodunne khun buka lhe'nuzoohzin junih! 'Alha lizas yak'uz dilhts'ine, 'enne bughu hinli 'ink'ez 'uBá yak'uz usda-un, bulizas 'enne 'ahoolhyiz hinalh ne'ut'en. 
\p  
\v 11 'Et huwa mbene la ninta ninkatne, 'enne yinka dune ye' 'ubutilhyih ha, 'et huba whusainya. 
\p  
\v 12 Nts'en'a daja nahzun? 'Et dune 'en whunizyat whunizyai (100) 'usbai 'ut'i whe 'enne butoh 'ilhoghun ninta nílhget whe yuloh 'et nébuninla 'ink'ez ndun 'ilhoghun ninta nilhget-un, 'en dzulh k'uz yukawhenántai. 
\p  
\v 13 'Et nayilhti de, ts'ih'un un'a nohdusni ndunne yuloh 'et nébuninlane, 'enne bugha whunilhni. 'Et hoonts'i ndun 'ilhoghun ninta nilhget-un, nayilhti de, 'en gha dahoolcho 'i be suba 'on nus whuntálhnih! 
\p  
\v 14 'Et whuz un'a za ndunne ts'oodunne, 'et 'ilhoghun hoonts'i kwuncho yo ts'u tiyalh de, nohBá yak'uz usda-un, 'en 'aw hukwa lhe'nizun. 
\s1 Nyulhutsin lubeshi be ndulhyo 'uja de, datánlelh? 
\p  
\v 15 “'Et nyulhutsin lubeshi be ndulhyo 'uja de, 'et oozih neninya 'ink'ez daja whe ndulhyo 'uja-un, 'et dóni'. 'Et nyun 'ink'ez nyulhutsin bulh nohnich'oh lhanaóodoohle. 'Et nghuni yílhchoot de, nyulhutsin whuch'a nanilde whe' hoont'oh. 
\p  
\v 16 'Et 'aw lhunyoozílhts'ai de, 'ilhoghun k'us nane te ilhchoot 'ink'ez 'et ooyoh ts'u natoohdilh. Nane k'us tane te mba lhgha 'úhudija de, 'et whuz un'a la 'uhót'e'. 'Et 'i be la daja hutni, ts'iya-i khuni ts'ih'un un'a 'uhoneh. 
\p  
\v 17 'Et hoonts'i 'et cha 'aw lhunoh oozílhts'ai de, 'et de Yak'usda ba 'ilhunaoodulhne, 'enne cha budóhni. 'Et 'enne cha 'aw lhuboozílhts'ai de, 'et de mbe la 'aw ooba 'alha lhe'hoot'oh-un k'us mbe la sooneya 'ilhunaoos'aih-un, 'et ndun lubeshi be ndulhyo 'uja-un, 'en 'enne buk'un'a noolh'en. 
\p  
\v 18 'Alha' dusni whe' dusni, nohni ndai la ndi yun k'ut ooladihni de, 'i ndo yak'uz cha oolaoodutitnih. 'Et ndi yun k'ut ndai lhgha 'úhudija de, 'i ndo yak'uz cha lhgha 'úwhutanelh. 
\p  
\v 19 Doo cha za nohdusni, ndai la ookwa oodutalhkut-i, 'ink'ez nane k'us tane ndi yun k'ut lhgha nohba soo' hoont'oh de, 'et mbe la yak'uz usda-un sBá, 'en nohba whutilelh. 
\p  
\v 20 'Et huwa nts'e la soozi' gha nane k'us tane 'ilhunaoodilh de, 'et de si cha nohtoh 'ust'oh whe' hoont'oh.” 
\s1 Lhba whunats'odoolnoh-un 
\p  
\v 21 'Et Peter yughu ninya whe yoodulhkut, “SMoodihti mbe la sulhutsin 'en lubeshi be sdulhyoh 'uja-un. Dawhultsuk sdulhyoh lubeshi 'utilelh 'ink'ez ooba whunaoodutiznoh? Lhtak'ant'it tilah 'et 'uwhultsuk-un?” 
\p  
\v 22 'Et Sizi ndúyulhni, “'Aw lhtak'ant'it lhduzusnih. 'Et lhtak'ant'it whunizyat (70) k'us 'on 'un tilah 'et 'uwhultsuk dusni whe' dusni. 
\p  
\v 23 'Et yak'uz k'úne' whul'en-un, 'et ndiz un'a nja duhoont'oh. Ilhoghun lerwe unli da', 'et be 'ulhnane, 'enne daltsuk be buts'ú whulh'ai, 'i ts'iyawh ye bubúlh lhanaoodutile, 'et hukwa' ninzun. 
\p  
\v 24 'Et whe' whunilh'en whe 'ilhoghun be 'ulhna-un dahinilhti. Ndai la ye yuts'ú whulh'ai-i, 'i 10,000 sooneya dizti'-i, 'et 'ultsuk. 
\p  
\v 25 Gak! Yuk'elha yoolhtselh-i hooloh. 'Et ndun lerwe dughuni be 'et ndi yulhni, 'et ndun dune, du'at, duduzkeh, 'ink'ez ndai yut'i-i cha, ts'iyawh ye 'óket. 'Et de soo sba k'elha whutilhtselh. 
\p  
\v 26 'Et huwa ndun be 'ulhna-un yubut nachániti 'ink'ez yuts'un tedudli whe 'uyulhni, ‘Smoodih k'at, huba silh'i! Ts'iyawh mba k'elha whutiselh!’ 
\p  
\v 27 Oomoodih tube yugha te'nanzin. 'Et ndai la ye yuts'u whulh'ai-i, ts'iyawh yuba whunaoodilhnoh, 'ink'ez whenayalh'a'. 
\p  
\v 28 'En 'ulhna za 'az whinya whe doo cha 'ilhoghun dudulh 'ulhna-un, 'en nayilhti. 'En whunizyat whunizyai (100) sooneya ts'uditi'-i, 'et 'ultsuk yuts'u whulh'ai. Yuzool ílhchoot whe 'uyúlhni, ‘Ndai la bé nts'o zus'ai-i, sba ook'elha hoolhtsi!’ 
\p  
\v 29 Ndun yubut dugwutsi be neninya 'ink'ez yuts'u tedudlih whe 'uyulhni, ‘K'at, huba silh'i. Ts'iyawh mba k'elha whutiselh!’ 
\p  
\v 30 'Et hoonts'i 'aw lhuyoozilhts'ai. 'Et k'us 'ayan'ai ndai la ye yuts'u whulh'ai-i, ts'iyawh yuba k'elha whutilhtselh 'et whuts'un. 
\p  
\v 31 'Et 'onghoh 'ulhnane, 'enne ts'iyawh honalh'en 'et dahooja la. 'Et ts'iyawh howu ni huzdli'. 'Et huwa dumoodih ts'u whehandil 'ink'ez ts'iyawh hidani'. 
\p  
\v 32 'Et mbe la 'et dúja-un, 'en oomoodih 'anih yudani' 'ink'ez 'et ndúyulhni, ‘Nyun 'ulhna-un k'us ntsi'-un azih 'int'oh! Sts'u tedindli ha 'et huwa ndai la be sts'o zilh'ai-i, ts'iyawh mba oonawhudizno! 
\p  
\v 33 Nts'en'a la ngha te'niszin, 'et whuz un'a za 'oneh huba' hoont'oh, nyulh 'ulhna-un ts'un!’ yulhni. 
\p  
\v 34 'Et oomoodih yulh hunilch'e. 'Et mbene la dune dzoh nulhdehne, 'enne butl'ayálhti. 'Et ndai la ye yuts'u whulh'ai-i, 'i ts'iyawh yuba k'elha whutilhtselh whuts'un. 
\p  
\v 35 'Et nohni cha nohulhutsinke ninta' hant'en de, 'ink'ez nohdzi ndulcho-i be 'aw buba whunalhodulhnoh de, 'et de sBá yak'uz usda-un, 'en cha whuz un'a za 'aw nohba whunaoodoolnoh ait'oh.” 
\c 19  
\p  
\v 1 'Et 'awet ndi khuni Sizi 'i be bubulh yalhduk-un 'etsul 'udija whe njan Galilee yun k'ut whuch'a nasja. 'Et Judea yun k'ut Jordan koh 'on ch'az whuz oozya. 
\p  
\v 2 Lhane dune 'et whuz huyoonizdil. 'Et soo na'balh'en. 
\p  
\v 3 'Et ndunne Phariseene, 'enne cha highu nindil hiyootálhdzih ha. 'Et huyoodulhkut, “'Et ndet huwa ne'atke 'ants'i 'oh huwun buch'a naztidalh de, 'et Moses khuni netl'aidan'ai-i, 'i ook'un'a eh 'uhoont'oh?” 
\p  
\v 4 'Et Sizi ubulhni, “'Et ndi 'udustl'us k'ut 'uk'eguz-i, 'i 'aw lakw ook'uyalhuzulhduk? Njan 'et, 'et ndutni, 'udechoo whe' whudit'en da' mbe dune inla-un, 'en dune 'ink'ez ts'eke bulh 'ubínla da'. 
\p  
\v 5 'Et 'ink'ez 'et ndutni, ‘Nja huwa dune dubá 'ink'ez duloo bulh buch'a ooya' huba' hoont'oh, 'ink'ez du'at bulh lhulh za hoot'e' huba' hoont'oh. 'Et whuz un'a nahúlt'o 'ilho hutileh.’ 
\p  
\v 6 'Et whuz un'a 'aw 'on 'un nane lhihiloh, 'ilho za hinli suli'. 'Et huwa mbe la Yak'usda lhgha bunilhtine, 'aw dune lhch'a nabólhtelh huba lhe'hoot'oh.” 
\p  
\v 7 'Et huyulhni, “'Et di ha Moses 'oh da' whuz un'a netl'ahón'ai 'ink'ez 'udustl'us cha neba inla inle' whe dune, 'i du'at tl'ayóolhchoos 'ink'ez naitoolh'a'.” 
\p  
\v 8 'Et ndúbulhni, “Nohni nohnich'oh nohdzi dulhts'un, 'et huwa Moses noh'at whuch'a naoohja-un nohtl'ahón'ai. 'Et hoonts'i whe'whudit'en whuts'un, 'aw 'et dulhúhoot'oh. 
\p  
\v 9 'Inka 'unohdusni, dune oo'at 'en 'uyoon dune bulh ninta' 'ant'en t'eoonanzin de, 'et de za ndi 'udustl'us ndai la ye 'etsul itilelh-i, 'i du'at tl'ayóolhchoos. 'Et oo'at 'aw edúlhinel 'et hoonts'i ndi 'udustl'us yutl'ayálhchooz de, 'ink'ez 'uyoon ts'eke ghu nasda de, 'et de dune ts'eke bulh ninta' 'ant'en-un suli'. 'Ink'ez ndun dune oo'at 'etsul 'uyinla-un 'ink'ez 'uyoon dune ghu nasda de, ndun dune 'en cha dune ts'eke bulh ninta' 'ant'en-un tileh.” 
\p  
\v 10 'Et Sizi yugha hodul'ehne, 'enne 'uhuyulhni, “'Et dune du'at bulh whuz un'a 'uhutit'elh de, 'aw lhghu lhuhíkoh de, 'et 'on nus soo' hoont'oh.” 
\p  
\v 11 'Et ndúbulhni, “Ndi khuni, 'i 'aw ts'iyanne ba lhe'it'oh. Mbe la ooghá whunt'aine, 'aw 'enne za buba' hoont'oh. 
\p  
\v 12 'Et whulohne dune 'aw bughez hoonuloh whe huwhuzdli. 'Et 'onghohne 'et whuz un'a dune 'ubinla. 'Ink'ez whulohne yak'uz whulerwe-un, 'en ba whuz un'a soo whulh 'utit'elhne, 'enne whuz un'a la whulh 'úhoot'e'.” 
\s1 Sizi ts'oodunneyaz dula be buk'udalni 
\p  
\v 13 'Et 'awet ts'oodunneyaz highu bunínla. Khun tilah buk'édolnih 'ink'ez buba tenadoodli ha. 'Et hoonts'i yugha hodul'ehne, 'enne dah hubuhútni. 
\p  
\v 14 'Et Sizi ndúbulhni, “Whute ts'oodunneyaz sts'ó toodilh. Khun te dah budóhni' junih! Mbene la yak'usda whe lerwe unli-un whuz dilhts'ine, 'enne ndunne ts'oodunneyaz ubunduhúlt'oh whe' hint'oh.” 
\p  
\v 15 Dula be buk'udalni, 'ink'ez buch'a nasja. 
\s1 Dune hoonzoo' 'unt'oh-un 
\p  
\v 16 'Et 'awet 'ilhoghun dune Sizi yughu ninya 'ink'ez yoodulhkut, “Dune hodulh'eh-un unzoo-un, nts'en'a hoonzoo k'un'a 'utist'elh whe 'ilhiz khutisnalh-un whuch'a ootásdoh?” 
\p  
\v 17 'Et Sizi ndúyulhni, “'Et di ha sudini, unzoo-un sudini? 'Aw 'ilhoghun unzoo-un hooloh. Yak'usda 'aw 'en za unzoo whe 'unt'oh. 'Et hoonts'i 'ilhiz be ts'otinalh-un hukwa' ninzun de, ndai la Yak'usda khuni dune tl'aidan'ai-i, 'i ook'une' 'int'en da.” 
\p  
\v 18 'Et 'uyulhni, “'Et k'us ndai whe' dini?” 'Ink'ez Sizi ndúyulhni, “Dune sólhghelh junih! Ts'ekoo bulh ninta' 'ont'en junih! Undunont'ih junih! 'Uyoonne ba honts'it junih! 
\p  
\v 19 Mbá 'ink'ez nloo bulh ubudólhti'! Nts'en'a la nyunch'oh k'enaintsi', whuz un'a za nyulh dune buk'eontsi'!” 
\p  
\v 20 'Et ndun chilh ndúyulhni, “Usool da' whuts'un, ndi ts'iyawh ook'une' zust'en. Nts'en'a 'on 'un datíst'elh?” 
\p  
\v 21 Sizi ndúyulhni, “Lhadulya-un tant'elh hukwa' ninzun de, ndai la 'int'i-i, 'i ts'iyawh be 'oonket, 'ink'ez tel'enne butainínle. 'Et de la ndo yak'uz ndai 'ilhoozanla-i, 'et mba tilalh. 'Ink'ez 'anih se' 'ut'en k'oh tune' ónt'en ha sunanyalh.” 
\p  
\v 22 'Et ndun chilh ndi khuni yudánts'o whe tube oodzi unduda whe yuch'a nasja. Tube hoonzoo' 'unt'oh-un 'unt'oh 'et huwa. 
\s1 Dune 'uhuhooleh ait'oh-un, 'et hoonts'i Yakusda ba huwa lhúhoolna' whe' hoont'oh 
\p  
\v 23 'Et Sizi yugha hodul'ehne ubúlhni, “Ndi 'i be soo ts'ih'un un'a nohdusni, yak'uz ts'e, nts'e lerwe unli-un, tube howa whulna' whe hoonzoo' 'unt'oh-un whuz tiyalh. 
\p  
\v 24 Doo cha za 'unohdúsni, ndi khuna ncha-i, camel huyulhni, 'i ooba howa whulna' whe ughabátsulh oola toh ookonín'a-un hukwa tílgwulh. 'Et hoonts'i whanus howa whulna' whe hoonzoo' 'unt'oh-un, 'en Yak'usda whe lerwe unli-un whuz datíyalh.” 
\p  
\v 25 'Et yugha hodul'ehne, 'enne hidants'o whe buba hooncha 'ink'ez 'et duhutni, “Mbe za dutijih ha' dini?” 
\p  
\v 26 Sizi ubunilh'en 'ink'ez ndúbulhni, “Dunene, 'aw ndet la 'uhuhooleh ait'oh-un, 'et hoonts'i Yak'usda ba huwa lhúhoolna' whe' hoont'oh.” 
\p  
\v 27 'Et Peter yatilhduk whe Sizi nja dúyulhni, “Whunilh'en, ndai la ts'ut'i-i, 'i ts'iyawh oolazditni, 'ink'ez nye 'ut'en k'oh ts'e ts'oot'en ha nyuts'un tizdil. 'Et huwa ndi la negha nínkat?” 
\p  
\v 28 Sizi ndúbulhni, “Ts'ih'un un'a nohdusni, nts'oya hoozulh whe ts'iyaitsuk 'andidi-i natidleh, 'et 'oh whuya hoozulh whe yinka dune ye', yukw'uts'uzda cho dizti'-i, 'i yuk'etl'adutadalh. 'Et nohni suntizdil inle'ne, nohni cha whunizyai 'on 'at nanki kw'uts'uzda-i dune buba nahutiyeh ha, 'et dutálhts'ilh. 'Et whe la Israel oots'u haindene, 'enne whunizyat 'on 'at nane lhendoh didowhne, 'enne buba nahutihyeh. 
\p  
\v 29 'Ink'ez mbe la si soozi' gha duyoh huwu tizya de, k'us dulhutsinke te, k'us dulhtuske te, k'us dubá cha 'ink'ez duloo cha te, k'us du'at te, k'us duzkehke te, k'us dukeyoh cha, njan si soozi' gha huwu tizya de, 'en la whunizyat whunizyai (100) 'et 'uwhultsuk-un ootl'anaóotikulh. 'Ink'ez 'ilhiz whe ts'ukhuna-un, 'et cha oogha óotalts'ulh. 
\p  
\v 30 'Et hoonts'i lhane mbene la 'udechoo 'unt'ohne 'udek'ezne nahutidleh. 'Ink'ez lhane mbene la 'udek'ez unline, 'enne 'udetsone nahutidleh.” 
\c 20  
\s1 Yak'uz whulerwe ts'iyawh k'une' whul'en-un 
\p  
\v 1 “Ndiz un'a yak'uz whulerwe ts'iyawh k'une' whul'en, 'Ilhoghun dune 'en ndi yun k'ut yun ut'i-un. 'Et ts'ekoo too' mai chun haniyeh k'et, 'et huba 'utit'elhne ha' ninzun. Bundada 'uda' 'et dune tilh'alh ha whuz whinya. 
\p  
\v 2 'Et ndunne ubalh'a'ne 'ilho sooneya ts'uditi' 'i dzin dulyiz whe hik'elha utit'elh-un, huhóost'et. 'Et huwa oots'ekoo too' mai chun haniyeh k'ez whebalh'a'. 
\p  
\v 3 'Et hukw'elh'az 9:00 at'en t'alh-i be 'óoket-un daninya whe dune bunilh'en 'ants'i 'oh nodilhya. 
\p  
\v 4 'Et nja dúbulhni, ‘Nohni cha nghuz ts'ekoo too' mai chun haniyeh ts'e ahdulh. 'Ink'ez nts'en'a la sooneya ts'ih'un 'unt'oh-i, 'i nohba k'elha tiselh.’ 'Ink'ez whuz whe handil. 
\p  
\v 5 'Et doo cha hukw'elh'az ts'etniz at'en k'us 3:00 at'en cha whuz whinya. 'et whuz un'a za doo cha za 'uja. 
\p  
\v 6 Doo cha za hulhgha ts'e at'en whuz whinya 'ink'ez 'uyoonne cha 'ants'i 'oh nodilhya whe bunilh'en. 'Enne cha ndúbulhni, ‘'Et di ha dzin dúwhulyiz whe 'ants'i 'óh nudulhya?’ 
\p  
\v 7 ‘'Et 'aw dune lhuneulh'oh 'et huwa ts'int'oh,’ huyulhni. 'Et ndúbulhni, ‘Nohni cha ghuz ts'ekoo too' mai chun haniyeh ts'e ahdulh. 'Ink'ez nts'en'a la sooneya ts'ih'un 'unt'oh-i, 'i nohba k'elha tiselh.’ 
\p  
\v 8 'Et 'awet hulhgha ts'e dune 'etsul ut'ih-un whe ndun ts'ekoo too' mai chun 'ut'i-un, 'en bughunli-un 'anih yudani' 'ink'ez 'uyulhni, ‘'It'enne ts'iyawh whusábinle, 'ink'ez buba k'elha hoolhtsi. 'Et mbe la 'udek'ez whe'dit'en-un, 'en cho ooba k'elha hoolhtsi.’ 
\p  
\v 9 Mbene la hulhgha ts'e at'en ul'a'ne whusahandil whe 'ilhone hinli 'ilho sooneya ts'uditi'-i buba k'elha yulhtsi. 
\p  
\v 10 'Et ndunne 'udechoo ul'a'ne, 'enne cha whusahandil. 'On nus lhai duba k'elha tileh huninzun. 'Et hoonts'i whuz un'a za 'ilhone hinli 'ilho sooneya ts'uditi'-i buba k'elha yulhtsi. 
\p  
\v 11 'Enne ts'iyawh buba 'uk'elha whuzdli' hukw'elh'az, 'et ndun yun ut'i-un hich'az yawhenilhduk. 
\p  
\v 12 'Et 'uhuyúlhni, ‘Ndunne 'udek'oh ubalh'a'ne, 'enne 'ilhoh sadzi hukw'uhoonist'oh-un za' hit'en. 'Ink'ez wheni dzin ndúwhulyiz whe sa ulhtus-i niz 'uts'it'en. 'Et hoonts'i 'enne neulh húlhgha za buba 'uk'elha whuzílhtsi.’ 
\p  
\v 13 'Et yun ut'i-un 'et ubúlhni, ‘Sk'ekene 'aw hoonliyaz whe 'aw tank'us un'a lhenohúsdli. 'Et ts'iyawh nohba soo' hoont'oh 'ilho sooneya ts'uditi'-i k'elha nohis'a'. 
\p  
\v 14 'Et 'awet ndai la nohch'e' ulhchoot 'ink'ez nahdulh. 'Et mbene la ndunne 'udek'oh 'ubis'a'ne, 'enne nohni nohk'un'a za 'et 'ultsuk 'i za buba k'elha tiselh 'et hukwa' nuszun. 
\p  
\v 15 'Alha iloh lakw ndai la ust'i-i nts'en'a hukwa' nuszun tune' 'ús'en? 'Uszoo' 'et huwa eh sghe oolhnih?’ ubúlhni.” 
\p  
\v 16 'Et 'awhuz Sizi njan howu yalhduk whe ubúlhni, “Mbene la 'udek'oh unline, 'enne 'udechoo nahutidleh. 'Ink'ez mbene la 'udechoo unline, 'enne 'udek'oh nahutidleh. 'Et huwa Yak'usda lhane 'anih dáni', 'et hoonts'i ntsoolneyaz za 'utahaínla.” 
\s1 Sizi datitsah-un whulh tat huwu yatilhduk 
\p  
\v 17 'Et 'awet Sizi Jerusalem ts'u tizya. 'Ink'ez ndunne whunizyanne 'on 'at nane mbene la yugha hodul'ehne, 'enne 'udun nebuninla 'ink'ez ndúbulhni, 
\p  
\v 18 “Soo zúlhts'ai, Jerusalem ts'uztidulh 'ink'ez yinka dune ye', 'en ndunne lubret moodihne, 'enne cha, 'ink'ez Moses be 'udustl'us 'uk'ununáguzne cha, 'et 'awet butl'ahitilhtelh, datitsah ha hiba nahutiyeh. 
\p  
\v 19 'Ink'ez 'udun yun k'ut whut'enne butl'ahitilhtelh. 'Et butl'ahúyalhti de, highu tidloh, huyootalhtsus, 'ink'ez 'et tulalhgus k'ehuyitalhtelh. 'Ink'ez hukw'elh'az whulh tat dzin dunadutádalh.” 
\s1 James 'ink'ez John bulh 'enne buloo, 'en Sizi yoodulhkut-un 
\p  
\v 20 'Et 'awet Zebedee buzkeh duloo te, 'et 'awet Sizi ts'o tizdil huyoodutalhkut ha. Buloo yubut nachaniti. 
\p  
\v 21 'Et Sizi ndi yulhni, “Ndet sts'o hukwa' ninzun?” 'Et ts'eke 'utni, “Nts'e whulerwe inli-un, ndunne nane suzkeh, 'enne 'ilhoghun nailhni ts'unk'us tidalh 'ink'ez 'ilhoghun intl'us ts'unk'us tidalh, sgha óonin'ai.” 
\p  
\v 22 'Et Sizi nja dutni, “Ndet hukwa' oodulhkut-un 'aw t'eoonuzahzun. Ndi lubot 'awet be' tisnelh-i, nohni cha be' tihnelh nahzun eh? 'Ink'ez ndai la dune be too be 'ul'en-i, 'i be 'usotilelh. Nohni cha whuz un'a za eh too be' tilhnelh?” 'Et nduhúyulhni, “A, 'et la 'et nduts'óoneh!” 
\p  
\v 23 'Et ndúbulhni, “'Alha slubot be' tihnelh, 'ink'ez be too be úzya-i, 'i be too be' tilhnelh. 'Et 'aw doosni' ait'oh mbe nailhni ts'e sts'unk'us tidalh 'ink'ez mbe intl'us ts'e sts'unk'us tidalh. Mbene la 'uBá buba lhaóodinlane, 'aw 'enne za buba' hoont'oh.” 
\p  
\v 24 'Et 'onghohne whunizyanne hidants'o whe, 'awet ndunne nane lhulhutsinke buba dzoh 'uhudija. 
\p  
\v 25 'Et Sizi ndunne ts'iyawh 'anih ubudani' 'ink'ez 'ubulhni, “Nohni t'eoonahzun ndunne 'udun yun k'ut whut'enne bumoodihne, 'enne dunene k'une' buhul'en. 'Ink'ez mbene la nchane, 'enne ndunne bumoodihne buba ando 'uhint'oh. 'Et whuz un'a bube 'ut'en k'oh hooni. 
\p  
\v 26 'Et hoonts'i nohni nohtoh whuz un'a 'utiht'elh noohzin junih. 'Et mbe la nohtoh ncha tileh hukwa' ninzun-un, 'en nohba ne'út'en-un oole'. 
\p  
\v 27 'Et mbe la nohtoh 'udechoo tileh hukwa' ninzun-un, 'en nohe'ulhna-un oole'. 
\p  
\v 28 Whuz un'a za yinka dune ye', 'aw ba ne'whutit'en hukwa whusálhiyal. 'Et k'us dune buba ne'ut'en-un tileh 'ink'ez buba datitsah, 'et whuz un'a lhane naootakulh. 'Et hukwa whusainya.” 
\s1 Nane hoos̱'enne, 'enne huhoo'en nasdli' 
\p  
\v 29 'Et 'awet hukw'elh'az Jericho keyoh whuch'a náhusdil whe lhane dune hiyuntizdil. 
\p  
\v 30 Nane hoos̱'enne ti whuzih huzkeh. 'Et Sizi 'oh whuya uyalh whe hiduzts'ai. 'Et 'ultus-un hika huyih, “Moodihti, David oots'u haínzut-un, negha te'ninzeh!” 
\p  
\v 31 'Et 'ilhunaoodilhne, “T'eduzahnih!” hubuhútni. 'Et hoonts'i 'on nus 'uhutni, “Moodihti, David oots'u haínzut-un, negha te'ninzeh!” 
\p  
\v 32 'Et Sizi lhgha neninya 'ink'ez ubulhni, “Diz áh'us. Ndet nohba 'uwhutisdlelh hukwa' nahzun?” 
\p  
\v 33 “NeMoodihti nena be ts'ontilh'elh hukwa' uzninzun,” huyúlhni. 
\p  
\v 34 'Ink'ez Sizi bugha te'nanzin whe dula be buna yut'aíznai. 'Et 'aho huhoo'en suli'. 'Et 'awet huyuntiz'az. 
\c 21  
\s1 Lhane huhoost'et whe Sizi keyoh Jerusalem ts'oozya 1 
\p  
\v 1 'Et 'awet Jerusalem whenghoh hidulh whe keyoh whuyaz Bethphage huwhutni-un, 'et whuz hoozdil. 'I dzulh enun, Olive huwhutni. 'Et Sizi nane yugha hodul'ehne, 'enne dutso whébalh'a' 
\p  
\v 2 whe ubulhni, “Njan keyoh whuyaz nohanch'az whuz ah'us. 'Et whuz oozah'az de, 'et 'aho yeztliyaz, donkey huyulhni, ooyaz bulh whehudint'i, 'et la ubunoolh'en. k'unabooh'uk 'ink'ez diz sts'ún 'ubutoolhdlooh. 
\p  
\v 3 'Et dune nohoodulhkut de, ‘Di ha 'ubulh'en?’ nohuwhútni de, ‘NeMoodihti yuka' ninzun,’ dóhni'. 'Et 'aho sts'un bula dutitnih.” \fig |src="cn01781b.tif" size="col" copy="©1978 David C. Cook Publishing Company" ref="Matthew 21.3" \fig* 
\p  
\v 4 'Et whuz un'a ndi ts'iyawh 'oh tune' whust'en. 'I be nus hon'en-un daja ni la, 'et ndulcho 'et dúhooja. Njan 'et nja dutni, 
\q1  
\v 5 “Zion ookeyoh whuti whut'enne, 
\q2 whunulh'en! Nohlerwe te'dudil'en whe nohts'u tiyalh. 
\q1 Donkey ooyaz, 'en yuk'usda. 
\q2 'En be nohts'u tiyalh.” 
\p  
\v 6 'Et ndiz un'a nja dúhooja, Sizi yugha hodul'ehne whuz whehan'az, 'ink'ez Sizi daja ubúlhni la, 'oh te né'hust'en. 
\p  
\v 7 'Et whuz un'a Donkey ooyaz bulh hits'u boolhti. Dunaih hik'ehíyinla 'ink'ez 'on dus de Sizi hik'etl'ahidilhda'. 
\p  
\v 8 Lhane dune dunaih ti hiba néhinilhbal nts'oya la lhutiyalh-un. 'Ink'ez 'onghohne, 'enne cha 'uzischum nanehidutselh 'ink'ez ti hiba nehídinla. 
\p  
\v 9 'Et 'awet 'ilhunaoodilhne whulohne ootso 'ink'ez whulohne ook'oh ts'e hidulh 'ink'ez tube cho huhuyih whe hutni, 
\q1 “David oots'u haínzut-un ba ts'odilhti'! 
\q1 NeMoodihti boozi' be whuz de úyalh. 
\q1 'En 'uk'enus hoonzoo-un ooba whults'ut. 
\q1 'Et soo yoodughi hidílhti'!” hutni. 
\p  
\v 10 'Et 'awet Sizi keyoh Jerusalem whuz oozya whe ndunne keyoh whut'enne khunahuntisdil whe 'ulhodutni, “Ndun mbe whe 'unt'oh?” 
\p  
\v 11 'Et 'ilhunaoosdilne hubuhútni, “Ndun 'en Sizi nus hoo'en-un, 'en 'unt'oh. Keyoh Nazareth yun k'ut Galilee whuz'ai-un, whuz de hainya-un 'unt'oh.” 
\s1 Mbene la lugliz whucho 'ooketne 'ink'ez 'e'ooketne, 'enne ts'iyawh Sizi tenabuninyoot 
\p  
\v 12 'Et 'awet Jerusalem bulugliz whucho whuna'niztl'oo-un daninya whe mbene la 'ooketne 'ink'ez 'e'óoketne, 'enne ts'iyawh tenabuninyoot. Sooneya lhk'enadulene bulutab 'i cha ts'iyawh buch'a yuntiz'ai. Mbene la dut'aiyaz, dove huyulhni, be 'óoketne, 'enne bukw'uts'uda 'i cha buch'a yuntiz'ai. 
\p  
\v 13 'Et ubúlhni, “'Uk'ehóoguz whe nja dutni, ‘'Et njan syoh tenadudli ba yoh dahni,’ 'et hoonts'i 'et cha nja dutni, ‘'Undunut'ihne, 'enne buyoh whuzúlhtsi.’” 
\p  
\v 14 'Et lugliz whucho 'et hoos̱'enne 'ink'ez ookechun ndudane, 'enne highu nindil, 'et soo na'balh'en. 
\p  
\v 15 'Et ndunne lubret bumoodihne 'ink'ez Moses be 'udustl'us 'uk'ununáguzne, 'enne njan huwa 'ít'en tune' 'ust'en whe hinalh'en. 'Ink'ez ts'oodunne, 'enne cha lugliz whucho sulyahalhduk whe nja duhutni, “David oots'u haínzut-un ooba ts'odilhti'!” 'Et njan ts'iyawh honalh'en whe hukwa honilch'e. 
\p  
\v 16 'Ink'ez Sizi 'et nduhúyulhni, “Ndi daja hutni la uboozílhts'ai eh?” 'Et ubulhni, “A, 'ink'ez dahúja-un 'aw hukw'uyalhuzusduk whe eh dahni? Ndiz un'a 'uk'ehonguz whe nja dutni, 
\q1 ‘Ts'oodunne 'ink'ez ts'oodunne nulhyehne cha, 
\q2 'enne bughuni 'i be' hutni, ts'ih'un un'a sba hodilhti' ubulhtsi.’” 
\p  
\v 17 'Et ndunne 'awet buch'a nasja 'ink'ez keyoh whuti huwu whenája. 'Ink'ez keyoh whuyaz Bethany ts'oozya whe 'et usda. 
\s1 Ndi duchun mai oots'u haníyeh-i, 'i Sizi yek'éhanya 
\p  
\v 18 'Et 'om bun 'uda' 'et keyoh whuti whuts'u hídulh whe khunsul ooye'ílts'ul. 
\p  
\v 19 'Et ti whuzih khunsul ndi mai chun, fig huyulhni, yutilh'en. 'Et yuts'oozya whe 'et 'aw oomai' ooghu hooloh. 'Ut'an za ooghu hoonli whe 'uyulhni, “'Et 'aw 'ilhiz nyumai' hootáloh.” Ni ibulh ndi duchun uyulhni-i dizgi. 
\s1 Ndi duchun, fig huyulhni, 'i be whuts'odutil'eh 
\p  
\v 20 Mbene la yugha hodul'ehne huyan'en whe tube buba hooncha. 'Et 'uhutni, “Nyoo mai chun, fig huyulhni, daja whe 'uja 'á stla dizgi?” 
\p  
\v 21 'Et Sizi ndúbulhni, “'Alha nohdusi, bé 'alha' hoont'oh-i aht'i de, 'ink'ez 'aw nohba nawh lhe'whutást'el whe ndi mai chun cha 'á dizgi, nohni cha whuz un'a za 'et dutihnelh. 'Ink'ez 'aw 'et za iloh, njan shus 'i la' dóhni, ‘Dudilhts'ih 'ink'ez bunghun whucho ts'e tailhts'ih,’ dahni de, 'et whuz un'a 'et duwhútanelh. 
\p  
\v 22 'Et ndai la ooka' dahni tenadudli be, nohba 'alha' hoont'oh de, 'i ts'iyawh nohgha tíkulh.” 
\s1 Sizi ndai gha dune ando 'unt'oh, 'et hukwa huyoodulhkut 
\p  
\v 23 'Et 'awet lugliz whucho daninya whe 'et dilhts'ine whe whúbondunilh'e'. 'Et 'udedo lubretne 'ink'ez dune 'utso whudilhdzulhne cha, 'enne highu nindil 'ink'ez 'uhuyúlhni, “Nedini ndai gha dune ando 'int'oh whe nja dint'en-un. K'us mbe ntl'ahon'ai whe dune ando 'int'oh-un?” 
\p  
\v 24 'Et Sizi 'ubulhni, “Si cha 'ilhoghun hukwa nohoodutaskut. 'Et sudahni de, 'et nohdutasnelh ndai gha dune ando 'ust'oh whe nja dust'en. 
\p  
\v 25 Nts'en'a John dune too be 'úlh'en? Mbe yutl'ahon'ai dune too be tilh'elh huba? Yak'uz ts'e tilah hahóolts'ut, k'us dune tilah ts'u hahóolts'ut?” Dich'oh lhtoh howu yahalhduk 'ink'ez 'uhutni, “'Et yak'uz ts'e hahóolts'ut ts'utni de, 'et la 'unedóne', ‘'Et diha John nohba 'alha' lhe'dusni?’ 
\p  
\v 26 'Et hoonts'i, ‘Dune ts'u hahóolts'ut whutilah 'uhoont'oh,’ ts'utni de, 'aw uzdooni' ait'oh, dune bubeznuljut, ts'iyawh John 'en nus hoo'en-un 'unt'oh huninzun 'et huwa.” 
\p  
\v 27 'Inka Sizi nduhuyulhni, “'Aw nts'ez de hahóolts'ut t'ets'onuszun.” 'Ink'ez Sizi ndúbulhni, “Ndai be dune ando 'ust'oh whe ndi nja duwhús'en-un, 'et si cha 'aw nohdósni' ait'oh.” 
\s1 Ndunne nane ndet oobá buba hukwa' ninzun 'oh te ne'hut'en eh? 
\p  
\v 28 “Nja huwun daja nahzun? 'Ilhoghun dune nane buzkeh. 'Enne 'udechoo-un yughu ninya 'ink'ez yulhni, ‘Sye' ts'ekoo too' mai chun haniyeh ts'e whuz inyalh 'ink'ez sba 'int'en.’ 
\p  
\v 29 'Et yuch'a tsédisnih inle'. 'Et hoonts'i hukw'elh'az ndunát'e' 'ink'ez whuz whinya. 
\p  
\v 30 'Et bulh nat-un ooye', 'en cha yughu ninya 'ink'ez yulhni. ‘A, whuz toosya' 'ink'ez 'oost'en la!’ yulhni. 'Et hoonts'i 'aw whuz lhtiyal.” 
\p  
\v 31 'Et Sizi 'utni, “Ndunne nane k'us mbe ndet oobá buba hukwa' ninzun 'oh te hukw'une' hust'en?” “'Et 'udechoo-un, 'en za,” hutni. 'Et Sizi ndúbulhni, “Ts'ih'un nohdusni ndunne sooneya nalhdzoohne 'ink'ez ts'ekoo 'ul'enne cha, nts'e la Yak'usda lerwe unli-un, whuz nohtso hutidulh. 
\p  
\v 32 Ndiz un'a nja duhoont'oh, be ts'ih'un un'a 'uhoont'oh-i, 'i be John dune too be 'ulh'en-un nohts'ó whusainya, 'ink'ez 'aw nohba 'alha lhe'hoot'oh. 'Et hoonts'i sooneya nalhdzoohne 'ink'ez ts'ekoo 'ul'enne, 'enne ts'iyawh buba 'alha' hoont'oh 'et huwa. 'Et nohni whunulh'en 'et hoonts'i 'aw noheni k'oh nálhe'uhlel. Whuz un'a za nohba 'alha lhe'hoot'oh.” 
\s1 Mai haníyeh k'et whulh'aíne, 'enne bugha whúts'odul'eh 
\p  
\v 33 “Nja 'uyoo be nawhutnuk-i be nohdutásnelh. Soo zólhts'ai'! 'Ilhoghun yoh whumoodih-un, 'en haniyeh k'et 'uhoonla, 'ink'ez mai ts'ekoo too' chun 'ananla. 'Ink'ez whuna'niztl'oo. 'Et tsak'et hahónkai mai too' 'utahahúlhtsus-un, 'et cha neóonin'ai. 'Ink'ez ook'ut yutist'en-i cha wheni 'uhinla. 'En la njan haniyeh k'et ndunne ha' nulhyehne butl'ahón'ai, 'ink'ez nilhdza' keyoh ts'e whinya. \fig |src="hk00105b.tif" size="col" copy="Horace Knowles" ref="Matthew 21.33" \fig* 
\p  
\v 34 'Et 'awet 'oonujin-un neooninzut whe yoh whumoodih de 'ulhnane, 'enne whuz whebalh'a' 'ink'ez ndunne 'ut'enne, 'enne buts'un mai hitalhchulh ha. 
\p  
\v 35 'Et ndunne ha' nulhyehne, 'enne yoh whumoodih de 'ulhnane hubílhchoot. 'Ilhoghun soo 'uzi 'unhitizno. 'Ilhoghun cha hizilhghi. 'Ilhoghun cha tse be hizilhghi. 
\p  
\v 36 'Et doo cha za 'onghohne 'ulhnane 'on nus 'ultsukne whuz whebalh'a'. 'Enne cha whuz un'a za 'et dúbuhinla. 
\p  
\v 37 'Et 'udek'ez-un duye' whuz buts'ú wheyalh'a'. ‘'En tilah hidólhti',’ ni. 
\p  
\v 38 'Et hoonts'i ndunne bughu whulh'aine hitilh'en whe 'et 'ulhodutni, ‘Ndun 'en nyoo haníyeh k'et ooch'e'-un, 'en ooye' 'út'en. Ts'uzoolhghelh! 'Et de la ndet la oots'ó tilts'ulh-un ts'iyawh 'et ndúwhulcho whe la ts'ohólhchoot!’ 
\p  
\v 39 'Inka huyílhchoot 'ink'ez njan haníyeh k'et tenáhinino 'ink'ez hizilhghi. 
\p  
\v 40 'Et huwa 'et njan mai ts'ekoo too' chun haniyeh-un, 'en ooch'e', 'en whusatiyalh. Whusainya de, 'et dábooleh suba?” 
\p  
\v 41 'Et nduhúyulhni, “'Et ndunne untsi'ne, 'enne hooncha hukw'un'a musai ubutilhtselh 'ink'ez njan haniyeh k'et 'uyoonne ha' úntilhyehne bugho tálh'alh. 'Et whuz un'a newhúzuk totsuk ndi mai higha hitalelh.” 
\p  
\v 42 'Et Sizi ndúbulhni, “'Aw eh hukw'u yalhuzulhduk Yak'usda ooghuni daja ni inle' da'? 'Et diz 'uk'ehooguz, 
\q1 ‘Ndi tse yoh 'uwhulh'enne 'ún hidutilh'uz-i, 
\q2 'i yoh ook'uwhuz'ai-un huba soo 'uk'enus tse 'unt'oh-i suli'. 
\q1 'Et la Moodihti whuz un'a 'uhoonla. 
\q2 'Ink'ez wheni tube neba hooncha whe' hoont'oh,’ ni. 
\p  
\v 43 'Et huwa nohdúsni, nts'e la Yak'usda lerwe unli-un, 'et ts'iyawh nohghu nahootálhchulh 'ink'ez 'udoh didowhne butl'aóoti'alh. 'Enne la 'ut'en unzoo-i buts'u haóokat. 
\p  
\v 44 'Ink'ez mbene la ndi tse hik'ilts'utne, 'enne ts'iyawh yahidutátih. 'Ink'ez mbene la ndi tse buk'édilts'utne, 'enne ts'iyawh musai hutileh.” 
\p  
\v 45 'Et ndunne Lizwif lubret bumoodihne 'ink'ez Phariseene cha, 'enne ndi khuni be nawhutnuk-i whulh 'úhudants'o whe t'ehonanzin Sizi 'enne didut bughu yalhduk. 
\p  
\v 46 Nts'en'a suba Sizi huyitálhchulh-un 'et hukwa' hut'en. 'Et hoonts'i dune éhunuljut. 'Enne Sizi 'en nus hoo'en-un 'unt'oh huninzun 'et huwa. 
\c 22  
\s1 Yak'uz k'une' whul'en-un, 'et lerwe ooye' oo'at whutaleh-un, 'et dult'oh 
\p  
\v 1 'Et doo cha za Sizi be nawhutnuk-i, 'i be whuts'odul'eh-i, 'i be bubulh yalhduk whe 'et dúbulhni, 
\p  
\v 2 “'Et yak'uz k'úne' whul'en-un, ndiz un'a nja dóohoont'oh, 'ilhoghun lerwe ooye' oo'at whutaleh, 'et huba lhadútitneh. 
\p  
\v 3 'Ink'ez mbene la bughu nuséyane, dude'ulhnane buts'u whebalh'a', 'anih ubuhudóni' ha, 'et hoonts'i buch'a tséhudisnih. 
\p  
\v 4 'Et doo cha za 'uyoonne cha dude'ulhnane whuz whilh'a'. Mbene la ooghu nusjane sba budohni', ‘'Awet t'alh-i lhadínt'oh. Njan musdoos ts'iyawh ndai la nilhk'a-i ts'iyawh sba huyanghan dune yuti'ulh whuba. Ts'iyai lhadínt'oh. 'Et 'awet ndunne lhghuskene bubulh na'uztit'ulh. Soo 'a dizáhdulh! sba budóhni'.’ 
\p  
\v 5 'Et hoonts'i ndunne bugha nusjane buba 'ants'i 'uhoont'oh. Ts'iyawh lhents'un whehándil. Whulohne cha há' hunulhyeh ts'e whenáhidil. 'Et whulohne cha bube 'ut'en k'oh whuz'ai ts'e whenáhidil. 
\p  
\v 6 Whulohne lerwe be 'ulhnane ubihílhchoot 'ink'ez dzoh ne'buhalh'en 'ink'ez ubuhanghan. 
\p  
\v 7 'Et lerwe whulh údants'o whe tube hunílch'e. Mbene la lhuganne ubut'ine ts'iyawh whuz whebalh'a'. Mbene la be 'ulhnane inghanne, 'enne ts'iyawh musai ubulhtsi 'ink'ez bukeyoh ts'iyawh hodálhk'un. 
\p  
\v 8 'Et hukw'elh'az 'uyoonne cha be 'ulhnane, 'enne ubulhni, ‘'Awet na'tit'úlh-un lhaoodint'oh, 'et hoonts'i ooghu nusjane 'aw huba soo lhe'hildzoo.’ 
\p  
\v 9 'Et huwa 'et 'awet ti ts'óhdulh. 'Ants'i lhane cho nahla de, 'enne ts'iyawh bughu nóhdilh. 
\p  
\v 10 'Et ndunne be 'ulhnane ti ts'e whehandil. Mbene la nabuhinlane, ntsi'ne 'ink'ez unzoone tubulh 'alhgoh ts'iyawh whusábahanla. 'Et 'awet na'hutit'ulh-un yoh whudizbun. 
\p  
\v 11 'Et 'awet lerwe buts'ó whusainya ooghu nusjane ubuntilh'elh ha. 'Et 'ilhoghun dune 'en 'aw naih dune lhghu dilhts'i whunaih be dune lhiloh whe yutilh'en. 
\p  
\v 12 'Et 'uyulhni, ‘Sk'eke 'aw dune lhghu dilhts'i whunaih be dune lhinloh. 'Ink'ez nts'en'a danínya?’ 'Et ndun dune 'aw whé 'oodoni'-un hoolel. 
\p  
\v 13 'Et lerwe duba ne'ut'enne ubúlhni, ‘Ndun dune ulhchoot 'ink'ez ulhghel. 'Ink'ez 'az tsalhgus yo ts'e táhneh! 'Et whuz la titso 'ink'ez dughoo lhudook'us.’ 
\p  
\v 14 Njan 'et ndutni whe 'utni, lhane ghu nusja 'et hoonts'i whulohne za 'utahálya.” 
\s1 Yun k'elha huhoolh'i-un hukwa' hoodulhkut 
\p  
\v 15 'Et 'awet ndunne Phariseene 'udun nehúnindil 'ink'ez howu yahalhduk, nts'en'a la Sizi ye yalhduk-i, 'i be hitilhgooh hukwa' hut'en. 
\p  
\v 16 'Et whe Phariseene bugha hodilh'e'ne 'ink'ez Herod didowhne cha, 'enne Sizi ts'e whebuhalh'a'. 'Et duhúyulhni, “Dune hodulh'eh-un t'ets'oninzun nyun ts'ih'un dune 'int'oh 'ink'ez khuni 'alha' 'unt'oh-i be Yak'usda k'un'a dune hodilh'eh. Ts'iyanne mba lhgha 'únt'oh. Nts'en'a la dune dahót'en 'et hoonts'i mba 'ants'i 'uhoont'oh. 
\p  
\v 17 'Et huwa nedini, ndi yun hik'elha huyilh'i-i, 'et ts'ih'un tilah 'uhoont'oh whe lerwe Caeser 'en tilah ooba k'elha ts'uyoolhtselh, k'us 'awúndooh tilah? Daja ninzun?” 
\p  
\v 18 'Et Sizi t'eooninzun nts'en'a la hoontsi' k'oh ts'e hoont'oh, 'et huwa ubulhni, “'Et di ha soo zúlhts'i? Nohni ts'iyawh duba na'udzoo'ne aht'oh! 
\p  
\v 19 De' la nyoo sooneya snalh ts'et nah'a!” 'Ilho sooneya ts'uditi'-i hitl'ahúyan'ai. \fig |src="hk00166b.tif" size="col" copy="Horace Knowles" ref="Matthew 22.19" \fig* 
\p  
\v 20 'Et ubulhni, “Mbe oonin 'ink'ez boozi' cha ook'usguz?” 
\p  
\v 21 “Lerwe Caesar,” huyulhni. 'Et ndúbulhni, “'Et huwa ndai la lerwe Caeser ooch'e', 'i ootl'anáyahle. 'Ink'ez ndai la Yak'usda ooch'e', 'i Yak'usda ootl'anáyahle.” 
\p  
\v 22 'Et hidants'o whe ts'iyawh buba hooncha 'ink'ez hich'a nasdil. 
\s1 Nat ts'uhítnaih huwun huyoodulhkut 
\p  
\v 23 'Et dzin za ndunne Sadduceene, 'enne highu nindil. 'Enne la 'uhutni dats'úzsai 'ink'ez 'aw nats'uhótnah aít'oh. 
\p  
\v 24 'Et nduhúyulhni, “Dune hodulh'eh-un Moses ndiz un'a nja dutni, 'et dune 'aw buzkeh hooloh whe dazsai 'ink'ez oo'at za khuna de, 'et bulhutsin 'en yughu naooda' huba' hoont'oh. 'Et ndun bulhutsin 'en dughe yughu nasda de, 'en ts'un dulhutsin ba buzkeh whutaleh. 
\p  
\v 25 'Et netoh lhtak'ant'ine lhulhutsinke, 'en 'udetso whudilhdzulh-un, 'en 'at ut'i. 'Ink'ez 'aw buzkeh hooloh whe dazsai. 'En du'at dulhutsin ba nayoosdzi. 
\p  
\v 26 Whúlh nane whuz un'a za dazsai. 'Et whulh tat-un, 'en cha whuz un'a za 'uja. 'Et dúwhulyiz whe lhtak'ant'ine ts'iyawh yahadla. 
\p  
\v 27 'Et 'udek'ez ndun ts'eke 'en cha dazsai. 
\p  
\v 28 'Et huwa nedini 'ilhudzin whusaootilts'ulh whe ts'iyanne dunadutádulh, 'et 'oh de de ndun ts'eke mbe oo'at tileh? 'Et whunulh'en lhtak'ant'ine ts'iyawh highinda'.” 
\p  
\v 29 'Et Sizi ndúbulhni, “Nohnich'oh na'dunaht'ah! 'Aw Yak'usda ooghuni t'enuzahzun. Ye ulhtus-i cha 'aw t'enuzahzun. 
\p  
\v 30 'Et ndet dzin dune dunadidil de, 'aw lhghu lhodutalhts'il 'et huwa. Dune dunadidilne, 'enne Yak'usda oolizas k'un'a 'uhutit'elh whe' hoont'oh. 
\p  
\v 31 'Et daja sudini yaidlanne toh dunadutádulh-un huwun, Yak'usda daja ni, 'aw eh hukw'u yalhuzulhduk? Njan nja dutni, 
\p  
\v 32 ‘Si Abraham, Isaac, 'ink'ez Jacob, buYak'usda 'ust'oh.’ 'Aw yaidlanne buYak'usda iloh 'unt'oh. Khunane buYak'usda unli 'et huwa.” 
\p  
\v 33 'Et 'ilhunaoosdilne dahoont'oh huwun budani' whe tube buba hooncha. 
\s1 'Ilho khuni 'uk'enus dizti'-i netl'aídan'ai 
\p  
\v 34 'Et Phariseene whulh 'úhudants'o nts'en'a la Sizi ubudani'-un, 'et hukwa Sadduceene 'aw yahutoolhdih ait'oh whe hinat 'ilhunahosdil. 
\p  
\v 35 'Et 'awet 'ilhoghun butoh-un, ni moodih unli-un, 'en Sizi yóolhdzih whe yoodulhkut, 
\p  
\v 36 “Dune hodulh'eh-un k'us undai khuni k'us dizti'-i neba yutulhúhizye'?” 
\p  
\v 37 'Et Sizi ndúyulhni, “ ‘Yak'usda nyuMoodihti ndzi ndulcho-i be cha, nzul ndulcho-i be cha, nyunut'i ts'iyawh 'i be cha, nyeni ts'iyawh 'i be cha, 'et whuz un'a 'en ook'eoontsi'.’ 
\p  
\v 38 Ndi ndai la nohba yutulhuhizye'-i, 'i 'udechoo 'ink'ez 'uk'enus dizti'-i 'unt'oh. 
\p  
\v 39 'Et bulh nanki, 'i 'udechoo-i k'un'a 'unt'oh whe ndiz un'a nja dutni, ‘'Et dahoont'oh hukw'un'a nyunch'oh k'enaintsi', 'et whuz un'a za 'onghohne cha buk'eoontsi'.’ 
\p  
\v 40 Ndi nanki khuni nohtl'adílts'ut-i, 'i be Moses be 'udustl'us cha 'ink'ez nus hoo'enne bube' 'udustl'us cha, 'i ts'iyawh 'ants'i yoh ook'ut whuz'ai-i, 'i le'unt'oh.” 
\s1 Christ mbe unli-un 'unt'oh? 
\p  
\v 41 'Et 'awhuz ndunne Phariseene 'ilhunahosdil whe Sizi uboodulhkut, 
\p  
\v 42 “Christ mbe unli-un 'unt'oh nahzun? K'us mbe oots'u hainzut-un suba 'unt'oh?” “'En David oots'u hainzut-un 'unt'oh,” huyulhni. 
\p  
\v 43 'Et 'ubúlhni, “Nts'en'a 'unt'oh David Ndoni be nyun sMoodihti 'int'oh nyudúsni ni whe 'et ndiz un'a nja dutni, 
\q1  
\v 44 ‘Moodihti 'en sMoodihti 'uyulhni, 
\q2 nailhni ts'ungus sinda 'oh de la nch'az ditnine buk'ut nke naóolhyis mba ubooselh.’ 
\p  
\v 45 'Et whuz un'a David, ‘SMoodihti,’ yulhni. Nts'en'a suba 'en oots'u hainzut-un oole'?” 
\p  
\v 46 'Aw dune yuts'u yatoolhdihne hooloh. 'Et ts'iyanne whehunuljut whe 'aw 'on 'un huyoodolhkut ait'oh. 
\c 23  
\s1 Moses be 'udustl'us 'uk'ununáguzne 'ink'ez Phariseene cha, 'enne dawhultsi'-un 'et buts'u hoolts'ulh 
\p  
\v 1 'Et 'awet Sizi 'ilhunaoosdilne 'ink'ez yugha hodul'ehne cha bubulh yawhenilhduk whe ndutni, 
\p  
\v 2 “Mbe la Moses be 'udustl'us 'uk'ununáguzne 'ink'ez Phariseene, 'enne cha 'enne dune hodutilh'eh 'et wheni Moses yuk'usda-i k'ut natl'ahudilts'i. 
\p  
\v 3 'Et huwa ndai la khuni hiye nohbulh yalhduk-i, 'et ts'iyawh hólhchoot 'ink'ez buk'úne' 'ooht'en. 'Et hoonts'i khun buk'un'a ne'óoht'en junih. 'Et 'alha daja hutni-un, 'oh te nulhé'hust'en. \fig |src="hk00274b.tif" size="col" copy="Horace Knowles" ref="Matthew 23.3" \fig* 
\p  
\v 4 'Et diz un'a né'hut'en, lhai cho lhunuhúlhtl'oo tube howa whulna' dune neyúghe huba. Dune buwus k'ehúyile. 'Et didutch'oh dulasga 'ilho hoonts'i nahayoolhna' ait'oh. 
\p  
\v 5 Ndai la 'uhuyulh'en-i, 'i 'uyoonne yunoolh'en huba za 'uhuyulh'en. 'Ink'ez ndi Yak'usda ooghuni zus, Phylacteries huyulhni, 'on nus ncha huyilh'i ts'iyanne hinoolh'en ha. 'Ink'ez ndi luglok tenahududli te nahuyits'uz-i, 'i cha ootso 'on nus 'udilyiz nahuyulhtsih. 
\p  
\v 6 'Et 'uhat'alh-un 'ink'ez lugliz cha soo k'us hoonzoo-un 'et za hudutálts'ilh hukwa' huninzun. 
\p  
\v 7 'Ink'ez ndet la t'alh-i be 'óoket-un, 'et ts'iyanne hubodílhti' whe hadih buhutni, 'et huhóont'i'. 'Ink'ez ts'iyawh 'ilhone hinli whe, ‘Rabbi! Nehodulh'eh-un!’ hubodóni' hukwa' huninzun. 
\p  
\v 8 'Et hoonts'i khun te 'uyoonne ‘Rabbi’ nohodóni' junih! 'Aw 'ilhoghun za whunohodulh'eh-un hoonli 'et huwa, Christ 'en 'unt'oh. 'Et nohni ts'iyawh lhulhutsinke ahli. 
\p  
\v 9 'Et ndi yun k'ut 'ants'i 'ohne ‘'ubá’ budohne' junih. 'Aw 'ilhoghun za nohBá unli 'et huwa, Yak'uz usda-un, 'en 'unt'oh. 
\p  
\v 10 'Ink'ez khun te 'uyoonne ‘nemoodih’ nohodóni' junih. 'Aw 'ilhoghun za nohMoodihti hoonli 'et huwa, 'en Christ 'unt'oh. 
\p  
\v 11 Mbene la nohtoh unchane, 'enne nohba ne'út'enne oole'. 
\p  
\v 12 'Ink'ez mbe la dich'oh ncha nadudil'i'-un, 'en 'udeyo tel'en-un tileh. 'Et mbe la 'udeyo 'ududildzun-un, 'en 'udedo ncha-un tileh.” 
\p  
\v 13 'Et nohni Moses be 'udustl'us 'uk'ununáguzne nohni Phariseene cha, nohni duba na'udzoo'ne aht'oh! Dawhultsi'-un 'et nohts'u hóolts'ulh. Ndiz un'a nja daht'en, nts'e la lerwe yak'uz usda-un, 'et whudáti dune ch'a dána'dihtan. Nohnich'oh hoonts'i daóohya' ait'oh. 'Ink'ez mbene la whuz udulhne, 'enne cha 'aw dábohlelh ait'oh. 
\p  
\v 14 Nohni Moses be 'udustl'us 'uk'ununáguzne, nohni Phariseene cha, nohni duba na'udzoo'ne aht'oh! Dawhultsi'-un 'et nohts'u hóolts'ulh! Tsandilhne buyoh bugha haoondunaht'ah. 'Et ndi tenadudli 'i be whuz un'a za 'onilha sa' cho tenadahdli. 'Et huwa 'on nus 'uwhulcho whe nohba nahutideh. 
\p  
\v 15 Nohni Moses be 'udustl'us 'uk'ununáguzne, nohni Phariseene cha, nohni duba na'udzoo'ne aht'oh! Dawhultsi'-un 'et nohts'u hóolts'ulh! Ndi yun k'ut ndulcho whe náhdilh 'ink'ez too k'ut ndulcho whe nahke, 'ilhoghun tilah nohnich'oh nohk'un'a 'unt'oh oolhtselh. 'Et whuch'a nulhde de, 'et de ndun nat 'uwhultsi' whe nohanus kwuncho yo whuye' tileh. 
\p  
\v 16 Nohni hoos̱'enne lé'aht'oh, dawhultsi'-un nohts'u hóolts'ulh. Lhe'aht'oh whuzih'en 'et hoonts'i dune ti whubuntilhtun hukwa' aht'en. 'Et ndiz un'a dune whubodulh'eh, njan lugliz whucho hoozi' be dune nahuhizya de, 'et 'ants'i 'uhoont'oh. 'Et hoonts'i lugliz whucho 'et gold 'ink'ez silver bulh 'uhoolya, 'et 'i be whuz un'a nahuhizya de, 'et whuz un'a 'uhuhooleh huba' hoont'oh, dahni. 
\p  
\v 17 Nohni whusnine 'ink'ez hoos̱'enne ahli! K'us ndet 'uk'enus whudizti'? Lugliz whucho k'us gold bulh 'úhoolya-i, 'et tilah? 'Et lugliz whucho 'et 'uk'enus whudizti'. 'Et gold bulh 'uhoolya-i, 'i 'ants'i Yak'usda ba 'udun nenínkat-i 'unt'oh. 
\p  
\v 18 Ndi 'i cha dune whubodulh'eh, mbe la loodel 'i be hoonliyaz whe yuts'u nahizya, 'et 'ants'i 'uhoont'oh. 'Et hoonts'i ndai la 'ants'i huwa t'aih-i, 'i loodel k'eyin'ai, 'et 'i be dune yuts'u nahizya de, 'et nduyóoleh huba' hoont'oh. 'Et whuz un'a dune whubodulh'eh. 
\p  
\v 19 Nohni whusnine 'ink'ez hoos̱'enne ahli. K'us ndet 'uk'enus whudizti'? 'Ants'i huwa t'aih-i tilah k'us loodel tilah? Ndi loodel 'i 'uk'enus dizti'! Ndi 'ants'et huwa t'aih-i, 'i loodel 'i gha Yak'usda ooch'e' suli' 'et huwa. 
\p  
\v 20 'Et huwa mbe la loodel 'i be hoonliyaz whe yuts'u nahizya, ndi loodel 'ink'ez ook'uyuzdla-i, 'i ts'iyawh 'i be yuts'u nahizya. 
\p  
\v 21 'Ink'ez mbe la lugliz whucho 'et whe yuts'u nahizya-un, lugliz whucho 'ink'ez Yak'usda 'et usda-un, 'et ts'iyawh whe yuts'u nahizya. 
\p  
\v 22 'Ink'ez mbe la yak'uz whe yuts'u nahizya, Yak'usda yukw'uts'uzda cho dizti'-i, 'ink'ez mbe la yuk'usda-un, 'en be yuts'u nahizya. 
\p  
\v 23 Nohni Moses be 'udustl'us 'uk'ununáguzne, nohni Phariseene cha, nohni duba na'udzoo'ne aht'oh! Dawhultsi'-un 'et nohts'u hóolts'ulh! Ndiz un'a nja daht'en, ndai la haníyeh-i, 'ut'an sooltsun-i cha, anise huyulhni, 'i cha, 'ink'ez cummin huyulhni, 'i cha, 'i ooloh za, 10%, 'i Yak'usda ghah'aih. 'Et hoonts'i Moses be 'udustl'us k'ut 'uk'enus whudízti'-un, 'et ts'iyawh whuladihtnih. Ndiz un'a ts'ih'un 'uhoont'oh. Njan ndet la ts'ih'un un'a neáht'en-un, ye negha te'untazeh-i cha, 'ink'ez be néba 'alha' hoont'oh-i, 'i cha, njan 'et ts'iyawh whuladihtnih, 'et hoonts'i whuz un'a ndóht'en huba' hoont'oh, 'ink'ez 'onghun-i cha 'aw lhálhduzahle whe oola doohtnih junih. 
\p  
\v 24 Lhe'aht'oh whuzih'en 'et hoonts'i dune, ti whúbuntilhtun hukwa' aht'en. Lhe'aht'en, ndai ahnai-i nizghes yé tat'o de, 'i 'ukutilhsus, 'et hoonts'i nohni ndi khuna-i cho, camel huyulhni, 'ants'i le'hoont'oh tilhnoh! 
\p  
\v 25 Nohni Moses be 'udustl'us 'uk'ununáguzne, nohni Phariseene cha, nohni duba na'udzoo'ne aht'oh. Dawhultsi'-un 'et nohts'u hóolts'ulh! Lusyet 'ink'ez lubot cha yoo'az ts'e tunáhgus. 'Et hoonts'i bez ts'e 'et whe ndai la 'uyoonne be bé' whulhts'it-i, 'ink'ez nts'en'a la hukwa' nahzun tune' aht'en 'et whe 'i be nohlusyet 'ink'ez nohlubot te dizbun. 
\p  
\v 26 Nohni Phariseene hoos̱'enne ahli! Ndi lusyet 'ink'ez lubot bulh 'udechoo bez ts'e tunáwhahgus 'et de la yoo'az cha 'aw lhditsun oole'. 
\p  
\v 27 Nohni Moses be 'udustl'us 'uk'ununáguzne, Phariseene nohni cha, duba na'udzoo'ne aht'oh! Dawhultsi'-un 'et nohts'u hóolts'ulh! 'Ants'i ts'un k'ut whuduchun 'udustl'us-i lé'aht'oh. Yoo'az ts'e tube soo ot'en, 'ink'ez bez ts'e whudutsun 'ink'ez dune ts'un be whudizbun. 
\p  
\v 28 'Et whuz un'a za dune nalh nohyust'e yoo'az ts'e ts'ih'un dune unline dóht'en. 'Et hoonts'i nohyo ts'e ts'ih'un lhe'aht'oh. Ndai la duba na'udzoo' 'ink'ez 'uk'únulhe'ust'en-i cha, 'i be whudizbun. 
\p  
\v 29 Nohni Moses be 'udustl'us 'uk'ununáguzne, Phariseene nohni cha, duba na'udzoo'ne aht'oh! Dawhultsi'-un 'et nohts'u hóolts'ulh! Nohni nus hoo'enne, 'enne buba tse bet 'ahudutilhtelh-un 'uwhulh'en. 'Ink'ez ts'ih'un 'unt'ohne, 'enne buts'un k'ut hoonzoo whulhtsi. 
\p  
\v 30 'Ink'ez ndiz un'a nja dudáhni, ‘'Uwhe 'oh da' netsoda'ne bubúlh ts'ukhuna inle' ndúcha. 'Oh da' ts'ukhuna de, 'et nus hoo'enne buhughan da', 'aw bula' ts'oot'en ait'oh inle'.’ 
\p  
\v 31 'Et ndi nja dudáhni, 'i be nohnich'oh ch'az dahtni. Ts'iyanne whubunulhtun 'aw 'uyoonne mbene la nus hoo'enne bubanghanne, nohni 'enne buts'u haíndene ahli! 
\p  
\v 32 'Et 'awet ndai la 'ut'en untsi'-i nohbáke whe'hidilh'en-un, 'et ts'iyawh lhaóodahla. 
\p  
\v 33 Tl'ughus lubezo buzkehke lé'aht'oh! Njan kwuncho yo wheni nohba nahutideh-un, nts'en'a 'utihnelh whenghoo táhdulh? Soo gak! 
\p  
\v 34 'Et hukwa soo cho soo zulhts'ai, 'et nus hoo'enne cha, 'ink'ez dune whunihne cha, 'ink'ez Yak'usda ooghuni hodulh'ehne cha, 'enne ts'iyawh nohts'ú butis'alh. 'Enne whulohne butihghan. 'Et whuz un'a tulalhgus ubunduntálht'oh. Whulohne nohlugliz bez ts'e 'et ubootalhtsus. 'Et whuz un'a lhendun keyoh whut'enne nubuntihyulh. 
\p  
\v 35 'Ink'ez 'et huwa 'et ndiz un'a nohk'ehootalts'ulh. Mbene la ts'ih'un 'unt'oh buzkai' yun k'ut nájul, 'enne bughá 'utihnelh nohk'ehootalts'ulh. 'Oh da' Abel 'en 'uja buzkai' yun k'ut nájul. 'Et njan Zechariah buzkai' yun k'ut nájul 'et whuts'un. 'En 'unt'oh Berechiah ooye'. Ndun 'en njan lugliz whucho 'et loodel eguz 'et nohtsoda'ne, 'enne hizilhghi inle'. 
\p  
\v 36 Ts'ih'un un'a be nohdusni 'andit whudilhdzulhne, 'et nohni hukw'elha whutilhtselh whe' aht'oh. 
\s1 Jerusalem whut'enne, 'enne bugha Sizi oodzi unduda suli' 
\p  
\v 37 “Nohni Jerusalem whut'enne, dáwhultsi'-un nohts'u hóolts'ulh! Nohni aht'en nus hoo'enne ahghan. 'Ink'ez mbene la nohts'u tílh'a'ne, 'enne cha tse be bubahghan. Dant'oh la lugok duduzkeh dudints'un be buboontun, whuz un'a nohni cha lhat-un whe 'ilhunanohootásdlelh hukwa' nuszun, 'et hoonts'i 'aw hukwa lhe'nahzun. \fig |src="hk00379b.tif" size="span" copy="Horace Knowles" ref="Matthew 23.37" \fig* 
\p  
\v 38 Soo cho whunulh'en, 'awet nohni Jerusalem whut'enne nohkeyoh 'aw hoonli hooloh suli' whe nohba 'et nenáwhults'ut, 'et whuz un'a Yak'usda nohladutitnih. 
\p  
\v 39 'Inka 'aw 'on 'un sulhtuzih'el. 'Et ndet la whusaootilts'ulh, 'et whusahóolts'ut de, 'et ndudútihnelh, ‘Mbe la Yak'usda boozi' be whusatíyalh-un, 'en 'uk'enus hoonzoo-un oots'ó tilts'ulh,’ 'et de sutih'elh!” 
\c 24  
\s1 Njan Lizwifne bulugliz whucho gak whutáleh-un, 'et Sizi huwu yalhduk 
\p  
\v 1 'Et 'awet njan lugliz whucho Sizi 'az whenaja whe yugha hodul'ehne highu nindil. Njan lugliz whucho nts'en'a 'uhóolya 'et whuhínulhtun. 
\p  
\v 2 'Et Sizi ndúbulhni, “Njan ts'iyawh 'áw lhonúlh'en? Ts'ih'un un'a nohdusni, 'aw 'ilho tse lhk'ulhdutásdlal, ts'iyawh nadúntijulh whe' hoont'oh.” 
\s1 Ndet whe hóodutalts'ilh-un, 'et la huwa t'ets'onoozeh 
\p  
\v 3 'Et 'awet haoodit'ai-unyaz dzulh Olive huyulhni, 'et usda. 'Et mbene la yugha hodul'ehne ts'iyawh highu nindil, 'ink'ez whu'izyaz huyoodulhkut, “Njan nkede 'uwhutánelh? Nts'owhuya hoozulh whe whusanátandalh, 'ink'ez nts'owhuya whudizulh whe whulatoh whutaleh? Ndet whe hóodutaltsilh-un, 'et huwa la t'ets'onoozeh? 'Et nedíni!” 
\p  
\v 4 'Et 'awet Sizi ndúbulhni, “Soo cho howahli. Khun te dune nanohnoo'ah junih. 
\p  
\v 5 'Alha lhane soozi' gha whusahutidulh 'ink'ez 'uhudutinelh, mbe la Christ unli-un, si 'ust'oh, duhutni whe lhane nahunti'ah. 
\p  
\v 6 Dune lhugan-un whulh 'údutahts'o. 'Ink'ez dune lhutigan-un cha howu yahutilhduk. 'Et cha whudutáhts'o. Khun te whénoolhjut junih. Njan dawhutanelh la 'et ts'iyawh nduwhutanelh, 'et hoonts'i 'awhuz whulatoh iloh 'uhoont'oh. 
\p  
\v 7 'Et huwa lhelhdowh didowhne lhch'az nehúdutadulh. 'Ink'ez yinka ndulcho lerwe be 'ustlene, 'enne cha lhehútidulh. 'Et dai whútaleh, 'ink'ez dada cha whutáleh. 'Et lhelhdun yun nukhutitnah. 
\p  
\v 8 Njan dzoh nuts'udeh-un 'andit ts'iya whe'whudit'en whe'whutat'elh. 
\p  
\v 9 'Oh de 'et neooninzut de, 'et dzoh nunohotilhdeh ha whutl'anohotilelh. Whulohne nohotighan. 'Ink'ez si soozi' gha 'udun yun k'ut whut'enne nohts'o dutitni. 
\p  
\v 10 'Et hukw'elh'az 'et lhane la buba dzoh tileh, 'ink'ez nohnich'oh nohtoh lhgha hawhútilhyeh 'ink'ez lhts'udutihtni. 
\p  
\v 11 Lhane whuts'it be nus hoo'en unline, 'enne lhane dune nahunti'ah. 
\p  
\v 12 'Ink'ez mbene la 'uk'unulhe'ust'enne, 'enne 'on nus 'uhultsi' tileh. Dune ye lhk'etsi'-i, 'i cha k'oh 'utinelh. 
\p  
\v 13 'Et hoonts'i mbene la soo whulatoh whuts'un whulh úsyinne, 'aw 'enne za hudutijih. 
\p  
\v 14 'Et yak'uz k'une' whul'en-un, 'en ghun khuni unzoo-i yun k'ut ndulcho whe be yatiduk. 'I be 'udun yun k'ut whut'enne, 'enne buba whubuntilhtun tileh. 'Et de 'awet whulatoh whusaóotilts'ulh.” 
\s1 'Uk'enus whewhunujut-un 
\p  
\v 15 “'Et huwa ndi 'uk'enus be whunujut-un, 'en musai yutilhtselh-un, 'en 'uk'enus whudizti' ts'e usyin whe nulh'en de, ndun Daniel nus hoo'en-un 'oh da' howu yalhduk inle'. (Hadi' ndi mbe la yuk'uyalhdukne, 'enne soo cho bubeni taóodolts'it). 'Et nkede la nulh'en de, 
\p  
\v 16 'et mbe la Judea yun k'ut dilhts'ine, shus k'uz tsehutoolhdilh. 
\p  
\v 17 Mbe la duyoh hukw'usda-un khun te nanaóoja' 'ink'ez duyoh ts'e na'ólhchoot junih. \fig |src="hk00233b.tif" size="span" copy="Horace Knowles" ref="Matthew 24.17" \fig* 
\p  
\v 18 Mbe la haníyeh k'et 'ut'en-un, 'en khun duyoh ts'e dunaih kunaóoda' junih. 
\p  
\v 19 'Et 'oh de de, mbe la ts'ekoo buzkeh whutalehne, 'ink'ez duzkeh e'úlht'ukwne, 'enne buba tube 'on nus hootátsi'. 
\p  
\v 20 Nkede whuch'a tsétilhdulh-un, khit k'us nats'ulyis dzin, 'et te 'uhoneh junih, 'et huba tenadahdli. 
\p  
\v 21 'Et 'alha 'oh de whusahoolts'ut de, hooncha whe dune dzoh nuhutide. 'Et ndi yun k'ut whe'whudit'en da', 'ink'ez 'andit dzin whuts'un, 'aw whuz un'a doo cha za ndó honeh ait'oh, 'ilhoh za' whutanelh. 
\p  
\v 22 'Oh de hoondukw nalhuhóodlel de, 'aw dune doojihne hooloh. 'Et hoonts'i 'utahályane, 'enne bugha hoondukw whutilhtselh. 
\p  
\v 23 'Et 'oh de de, ndun Christ nja usda k'us nguz usda, 'et nohoútni de, khun nohba 'alha' hudooni' junih. 
\p  
\v 24 'Alha whuts'it be Christne 'ink'ez whuts'it be nus hoo'enne, 'enne lhane nohtoh whutaleh. 'Ink'ez nohtoh tube hooncha te ne'hutit'en. 'Ink'ez huwa 'it'en-un cha nohtoh ne'hutit'en. 'Et ndi nja dótit'elh-un, khun tilah 'utahályane nabonoo'ah huninzun, 'et hukwa' hutit'elh. 
\p  
\v 25 'Et soo zulhts'ai, whutsoda' 'uda' nohdásni'. 
\p  
\v 26 'Et huwa dune nohúlhni de, ‘Nulh'en nda 'at dune lhuhoot'ih-un 'et usda!’ hutni de, khun whuz toohdilh junih. K'us, ‘'Et yoh bez ts'e usda,’ hutni de, khun nohba 'alha' hudooni' junih. 
\p  
\v 27 Ndiz un'a nja duwhútanelh, 'et ditni kwun ndaz de hadánat 'ink'ez noo' whe dánat. 'Et ts'iyanne dune yunoolh'en ha, 'et whuz un'a yinka dune ye' whusatiyalh. 
\p  
\v 28 'Et huwa nts'e la nezi súlht'i-un, 'et la tsibalyan huwe' 'ulhozdil. 
\s1 Yinka dune ye' whusanátidalh-un 
\p  
\v 29 “'Et 'oh de de dune dzoh nuhutideh-un, 
\q1 'et 'oh de ndúhooja de, hukw'elh'az 'aho sa dulhgus tileh. 
\q2 'Ulhdzis ooza' cha 'aw be lhóohoost'en tileh. 
\q1 Sum cha ts'iyawh ndus de hatíkulh. 
\q2 'Ink'ez ndai la yak'uz whelhtus-un dulcho whe nuhótitnah. 
\p  
\v 30 'Et 'awet ts'iyanne dune yunoolh'en ha yinka dune ye' yak'uz ts'e be hóodutaltsilh. 'Et 'oh whuya hoozulh de, 'et dune ndi yun k'ut ndulcho whe tso yahutilhduk. 'Et yinka dune ye' whuz de yalh whe huyuntilh'elh. Kw'us k'ut yak'uz ts'e hatíyalh. Ye dizti'-i 'ink'ez ye ulhtus-i, 'i be tinelh. 
\p  
\v 31 Be ts'ujih-i tube cho be' duts'o whe oolizas whuz ubutilh'alh. 'Utahályanne, 'enne ts'iyawh 'ilhunaboohootálelh. Diwh hukw'un'a hutidulh 'ink'ez yat dulcho nótidulh. 'Et ndulcho whe 'ilhunaboohootálelh. 
\s1 Mai, fig huyulhni, ooduchun, 'i be nawhutnuk be whuts'odul'eh-i 
\p  
\v 32 “Ndi mai, fig huyulhni, ooduchun, 'i be nawhutnuk be whuts'odul'eh-i, soo ts'ih'un un'a cho bodulh'eh. Ndi 'i 'unt'oh, oozischum ulughih te, 'et 'awet oot'an whulih, 'i gha t'ewhunáhzun 'awet shin nilhdukw suli'. 
\p  
\v 33 Nohni cha whuz un'a za ndi ts'iyawh nohdasni'. 'Et whe nkede la nulh'en 'et 'awet t'ewhunóhzin, 'en nohenghoh. 'Ants'i dati usyin le'hoont'oh. 
\p  
\v 34 'Alha ts'ih'un un'a nohdusni, 'andit whudizulhne 'aw yalhihitásdla, 'et ndi dótanelh-un ts'iyawh 'et lhawhúdutanelh, 'et whuts'un. 
\p  
\v 35 Yat 'ink'ez ndi yun k'ut cha gak whutaleh. 'Et hoonts'i ndi sghuni 'aw gak lhtisdleh. 
\p  
\v 36 Ndet dzin 'ink'ez nts'oya hoozulh whe whutanelh, 'aw t'eoonínzunne hooloh. Lizas yak'uz dilhts'ine, 'enne hoonts'i 'aw t'ehonúszun. 'UBá yak'uz usda-un, 'aw 'en za t'eooninzun. 
\p  
\v 37 'Et 'oh da' Noah khuna da', dune dahínt'oh la, 'et whuz un'a za 'uwhutát'elh whe yinka dune ye' whusanátidalh. 
\p  
\v 38 Soo cho whunulh'en, yunka too be' whutanelh da', whutso da', ts'iyanne 'a'alh 'ink'ez 'uhutnai. Dune 'ink'ez ts'ekoo bulh lhgho dilhts'i, Noah ts'i cho be tiyalh 'et whuts'un. 
\p  
\v 39 Dunene 'aw t'ehonuszun nkede too dudutált'o. 'Et 'awet dutadilt'o whe ts'iyawh too ubanghan. 'Et whuz un'a za yinka dune ye' whusainya de, 'et ndó tanelh. 
\p  
\v 40 'Et dzin nane, 'enne haniyeh k'et 'uhut'en. Lizasne, 'enne 'ilhoghun hitalhchulh 'ink'ez 'ilhoghun 'awet tidalh. 
\p  
\v 41 Nane hiti'ulh-i hundunulhdus. 'Ilhoghun hitalhchulh 'ink'ez 'ilhoghun 'awet tidalh. 
\p  
\v 42 'Et huwa soo cho huwahli! Nts'oya hoozulh whe nohMoodihti whusatiyalh 'aw t'eoonuzahzun. 
\p  
\v 43 'Et ndi noheni taoonahle, mbe la yoh moodih-un, nts'owhuya la whudizulh-un undunut'ih-un whusatiyalh, 'et t'ewhuninzun de, 'et soo ts'ih'un da' huwole', 'ink'ez 'aw hiyoh da'óoyis ait'oh. 
\p  
\v 44 'Et huwa nohni cha lhadóoht'e'. 'Alha nts'owhuya whudizulh-un, 'et ookwa tse lhúwhahlih-un, 'et yinka dune ye' 'et whusatiyalh.” 
\s1 'Ulhna-un ts'ih'un 'unt'oh-un 
\p  
\v 45 “K'us mbe 'ulhna-un, 'en ts'ih'un 'unt'oh 'ink'ez whunih-un 'unt'oh? Oomoodih dich'oh de 'ulhna-un, 'en 'onghohne de 'ulhnane duyoh humoodih yutilhtselh. 'Oh de de 'awet 'et neooninzut de, 'et 'andit za 'onghohne hiti'ulh-i bugha ita'alh. 
\p  
\v 46 'Et oomoodih whusanaja de 'ink'ez de 'ulhna-un whuz un'a nduja-un 'et whunilh'en de, 'en 'uk'enus hoonzoo-un oots'u hóolts'ulh. 
\p  
\v 47 'Alha nohdusni ndai la yut'i-i, 'i cha ts'iyawh k'une' yul'en yutilhtselh. 
\p  
\v 48 'Et hoonts'i ndun be 'ulhna-un ntsi'-un dich'oh dudzi yo whe 'et nduninzun, ‘SMoodih sa' sla whusanádaih.’ 
\p  
\v 49 'Et khunsul 'onghohne dudulh 'ulhnane bube whe ninyaih, 'ink'ez tatnaine cha bula whe'nin'al 'ink'ez bula tawhénitnai'. 
\p  
\v 50 Ndet dzin ndun oomoodih whusanátidalh 'ink'ez nts'oya 'uhunit'oh-un utinelh 'aw t'ewhunúszun, 'et 'oh whuya 'uhunit'oh whe whusanátidalh. 
\p  
\v 51 'Et k'ube' yutálht'oh 'ink'ez ndai la oots'itikulh-i, 'i ts'iyawh ndai la duba na'udzoo'ne buts'itikulh-i, 'enne buk'un'a 'i za oots'itikulh. 'Et whuz un'a tso bulh dughoo lhidutik'us.” 
\c 25  
\s1 Whunizyane t'edukoo 'enne dune t'enuszunne, kwulane, 'enne huwhunih 'ink'ez kwulane, 'enne huwhusni 
\p  
\v 1 “Yak'uz nts'e la lerwe usda-un ndi yun k'ut whusahóolts'ut de, 'et whuz un'a ndótanelh, whunizyanne t'edukoo 'enne dune t'enuszunne, ndi kwun be hoot'en-i huyilhchoot 'ink'ez mbe la dune 'at tit'elh-un 'az 'et hiba sulh'i. 
\p  
\v 2 Kwulane, 'enne huwhunih 'ink'ez kwulane, 'enne huwhusni. 
\p  
\v 3 Ndunne whusnine ndi too dizk'un hut'i 'et hoonts'i ndi too dizk'un hiye náhitilhdzoh-i hiyit 'uja. 
\p  
\v 4 'Et whunihne too dizk'un denáhitilhdzoh-i cha hutiz'ai. 
\p  
\v 5 'Et 'at tit'elh-un sa' sla whusayaih. 'Et ts'iyawh nehunintsai 'ink'ez ts'iyawh bulh buk'édilts'ut, whe nahunistez. 
\p  
\v 6 Tuzniz at'en 'ilhoghun huyih, ‘'Awet 'at tit'elh-un 'az de yalh. Dunadahdilh 'ink'ez oodudíhdilh!’ 
\p  
\v 7 'Et ndunne t'edukoo ts'iyawh dodindil 'ink'ez too dizk'un-i ts'iyawh nahidulhk'an. 
\p  
\v 8 Whusnine, 'enne ndunne whunihne hubuhutni, ‘Too dizk'un negha núlhdzeh, netoo dizk'un 'awet bé ha' duk'aih!’ 
\p  
\v 9 'Et whunihne, ‘'Awúndooh!’ hutni ‘Nohgha uznilhdzo de, nohni cha 'ink'ez wheni cha 'aw neba soo lhé'iltsuk.’ 'Et ubuhutni, ‘'E'óoket ts'e whuz ahdulh, 'ink'ez nohnich'oh 'oohket.’ 
\p  
\v 10 'Et whuz whehandil whe 'at tit'elh-un buk'elh'o whusaínya. 'Ink'ez ndune yuba lhadint'ohne, 'enne na'hutit'ulh ts'e huyúlh danindil, 'ink'ez dati dánahidintan, 'ink'ez dánahidin'ai. 
\p  
\v 11 'Et hukw'elh'az ndunne t'edukoo whusnine sanáhidil whe, ‘NeMoodih, nemoodih, neba dáhana'dintih!’ huyulhni. 
\p  
\v 12 'Et ndúbulhni, ‘'Alha 'aw t'enohnuzúszun!’ 
\p  
\v 13 'Et whuz un'a nohni cha soo cho huwahli! 'Alha ndet dzin 'ink'ez nts'oya hoozulh whe yinka dune ye' whusanatidalh, 'aw dune t'eoonúszunne hooloh.” 
\s1 Dune dude 'ulhnane, ndai la yut'i-i, 'i butl'ayánla, 'et yak'uz lerwe usda-un dult'oh be nawhutnuk-i 
\p  
\v 14 “Yak'uz ndet la lerwe usda-un, ndi yun k'ut whusahóolts'ut de, 'et whuz un'a ndótanelh, ndun dune dukeyoh huwu tiyalh. 'Et tiyalh whutso dude 'ulhnane 'anih ubudani'. Ndai la yut'i-i, 'i butl'ayánla. 
\p  
\v 15 'Ilhoghun kwulai' sooneya dizti'-i yutl'ainla. 'Et 'ilhoghun cha nanki sooneya dizti'-i yutl'ainla. 'Et doo cha 'ilhoghun 'en 'ilho za yutl'ain'ai. 'Ilhone hinli whe nts'en'a la soo hoonzoo hukw'un'a hiye' whutilelh, 'et wheni butl'ayánla. 
\p  
\v 16 'Et hukw'elh'az 'awet whinya. 'Et 'ilhoghun kwulai' yutl'ainla-un, 'en 'on 'un kwulai' uniltsuk-i ye' 'ínla. 
\p  
\v 17 'Et whuz un'a za 'ilhoghun 'en nanki yutl'ainla whe nanki ye yúba na'yinla. 
\p  
\v 18 'Et hoonts'i 'ilhoghun 'ilho za yutl'ain'ai-un, 'en yun hahónkai 'ink'ez whuz dumoodih oozooneya yuntilh'i. 
\p  
\v 19 'Et hukw'elh'az sa' inle' whe ndunne 'ulhnane bumoodih whusanaja. 'Et nahootá'alh hukwa' ninzun nts'en'a la dahúyinla. 
\p  
\v 20 'Et ndun kwulai' yutl'ainla-un, 'en kwulai' be 'on 'un 'uniltsuk-i, 'i yuba whusanáyanla. 'Et ndúyulhni, ‘Smoodih kwulai' sooneya dizti'-i stl'ainla. Nah! Nilh'en kwulai' be 'on nus mba na'usdla.’ 
\p  
\v 21 'Et oomoodih ndúyulhni, ‘Tube soo 'inja! Nyun tube inzoo. Whunilhchoh whe k'une' nyutis'en. Nyun tube 'ulhna-un unzoo-un inli. 'Et hoontsool-unyaz whe k'une' nyutis'en inle'. 'Et 'andit n'un whe lhai ghu tanleh. 'Anih, ndai la nyumoodih ye hoont'i'-i, nyun cha be hóotant'e'.’ 
\p  
\v 22 'Et 'ilhoghun nanki sooneya dizti'-i yutl'ainla-un, 'en cha whusainya. 'Et ndúyulhni, ‘Smoodih nanki sooneya dizti'-i stl'ainla. Nah! Nilh'en nanki be 'on nus mba na'usdla.’ 
\p  
\v 23 'Et oomoodih ndúyulhni, ‘Tube soo 'inja! Nyun cha tube inzoo. Whunilhchoh whe k'une' nyutis'en. Nyun cha tube 'ulhna unzoo-un inli. 'Et nyun cha hoontsool-unyaz whe k'une' nyutis'en inle'. 'Et 'andit nyun cha n'un whe lhai ghu tanleh. 'Et nyun cha 'anih, ndi ndai la nyumoodih ye hoont'i'-i, nyun cha be hootant'e'.’ 
\p  
\v 24 'Et doo cha 'ilhoghun 'ilho sooneya dizti' yutl'ain'ai-un, 'en cha whusainya 'ink'ez yúlhni, ‘Smoodih t'eoonuszun nyun 'aw t'elhe'nínzun-un 'int'oh. Nts'e la alhe'nuzinloh-un 'et hoonts'i 'et na'ilhdzooh. Nts'e la haníyeh 'ulhe'nínlel-un 'et hoonts'i 'et cha ha' ninlih. 
\p  
\v 25 Tube whenuzjut 'et huwa ndi sooneya dizti' yun yo ts'e ntís'i'. Nah! Nilh'en ndi stl'ain'ai-i ntl'anás'aih.’ 
\p  
\v 26 'Et oomoodih yulhni, ‘Nyun untsi'-un 'ink'ez tsedutni-un 'ulhna 'int'oh. 'Alha t'eooninzun nts'e la alhe'nuzusdloh-un, 'et hoonts'i 'et cha na'usdzooh. 'Ink'ez nts'e la haníyeh 'ulhnúsdlel-un, 'et hoonts'i 'et cha ha' nusdle. 
\p  
\v 27 'Et huwa 'oh da' ndiz un'a nja dónleh huba' hoont'oh. Ndi uszooneya ntl'as'ai-i, sooneya lhk'enada'aihne, 'enne butl'alhizin'ai. 'Et de da' szooneya 'on nus 'uniltsuk-i be ná'oozneh oole' da'.’ 
\p  
\v 28 'Et huwa ubulhni, ‘Ndun ndi uszooneya dizti'-i, ooghu nayulhchoot. Mbe la whunizyai sooneya dizti'-i yut'i-un, 'en oogha ínah'aih. 
\p  
\v 29 'Et mbe la yuloh za 'ut'i-un, 'en 'on nus lhai oogha tílts'ulh. 'Et whuz un'a lhai tit'elh. 'Et hoonts'i mbe la ntsool-iyaz ut'i-un, 'i hoonts'i ooghu nayitálchulh. 
\p  
\v 30 'Et 'awet ndun 'ulhna-un ntsi'-un, ulhchoot 'ink'ez 'az tsaholhgus yo ts'e táhneh.’ 'Et whuz la tso bulh la dughoo lhudook'us si.” 
\s1 Yinka dune ye' whusanátidalh de, 'et de yinka dune'ne, 'enne ts'iyawh buba nahutiyeh 
\p  
\v 31 “'Et 'awet yinka dune ye' nkede oots'u ha' 'ánduz whe whusanátidalh, 'et nyoonne lizas lubeshi ooghu hoolohne, 'enne huyulh whusanátidulh. 'Et 'ink'ez 'oh de de, yukw'uts'uzda cho dizti'-i, 'i k'ut nanátl'adutidalh. 
\p  
\v 32 'Et 'ink'ez yinka dune'ne, 'enne ts'iyawh hibut 'ilhunabuhootálelh. 'Et 'usbai ghunli-un k'un'a 'usbai, 'i dube tahanaítilelh, 'et whuz un'a ndótanelh. 
\p  
\v 33 'Usbaiyaz 'enne nailhni ts'unk'us nebutalelh. 'Et dube 'enne 'intl'us ts'unk'us nebutalelh. 
\p  
\v 34 'Et lerwe 'et ndunne nailhni ts'unk'us 'unt'ohne 'et whuz un'a ndubudutanelh, ‘Nohni 'uBá 'uk'enus hoonzoo-un la nohghá whults'utne ahli. 'Et huwa 'anih! Ndi yun 'utilnelh whutso, ndet la lerwe yak'uz úsda-un, 'et ndet nohba lhaoodinla, 'et 'andit za nohtl'aootilts'ulh. 
\p  
\v 35 Soo cho whunulh'en, sye'ílts'ul whe tis'ulh-i sgha náh'ai. Ta'oosda whe ndai la tisnelh-i sgha náhkai. 'Uts'un whút'en-un usdli 'et hoonts'i nohyoh ts'e dásunulhti. 
\p  
\v 36 'Aw naih lhúst'i whe 'enásalhti. Ndusda whe sts'un nusahdil. 'Adus'ai whe sts'un nusahdil.’ 
\p  
\v 37 'Ink'ez ndunne ts'ih'un 'unt'ohne huyoodutalhkut, ‘NeMoodihti nkeda' nye'ílts'ul whe nts'uyan'en 'ink'ez tan'ulh-i ngháznin'aih? 'Ink'ez ta'óonda whe tantnelh-i nghá uzninkai? 
\p  
\v 38 'Et nkeda' 'uts'un whút'en-un inli whe dánts'inilhti inle'? K'us naih lhint'i' whe naih ngházninla inle'? 
\p  
\v 39 Nkeda' ndinda whe nts'inálh'en k'us 'adin'ai whe nts'un nuts'uzdil inle'?’ 
\p  
\v 40 'Et lerwe nja dúbudutanelh, ‘'Alha-i be nohdusni, ndunne sulhutsinke, mbene la 'aw nchane lhiloh, 'enne 'ilhoghun hoonts'i whuz un'a 'et dúbahla de, 'et si 'usáhla whe' hoont'oh.’ 
\p  
\v 41 'Et 'awet ndunne 'intl'us ts'ungus 'unt'ohne diz un'a ubudutánelh, ‘Ndai la Yak'usda ye hunilch'e-i nohbulh 'unt'ohne sahli'! Sch'a nasahdilh! 'Et 'awet ndi kwun 'aw nalhnusne-i netsudule dulizasne te buba' hóolya-un, 'et nohni cha whuz tihdulh! 
\p  
\v 42 Sye'ílts'ul inle' 'et hoonts'i 'aw tis'ulh-i sgha lhah'al. Ta'óosda 'et hoonts'i 'aw tisnelh-i sgha lhahkal. 
\p  
\v 43 'Uts'un whut'en-un usdli, 'aw 'et dasúlhulhtel. 'Oh da' 'aw naih lhust'i' 'et hoonts'i 'aw be oosda'-i hooloh naih sgha lhahlel. 'Oh da' ndusda whe 'ink'ez adus'ai-i whe 'aw sts'un nulhahdulh.’ 
\p  
\v 44 'Et diz un'a 'uhidutanelh, ‘NeMoodihti nkeda da' nts'uyan'en whe dini? Nkeda' nye'ilts'ul 'ink'ez ta'oonda? K'us 'uts'un whut'en-un inle', k'us be dune onle'-i lhínt'i'? K'us ndinda 'ink'ez 'adan'a'? 'Et whuz un'a nts'uyan'en 'et hoonts'i 'aw hoonliyaz whe nlalhe'ts'ínel dini?’ 
\p  
\v 45 'Et la budutanelh, ‘'Alha-i be 'unohdusni, ndunne mbene la sulhutsinke 'aw ncha lhilohne, 'et 'aw 'ilhoghun hoonts'i whuz un'a lhebáhlel. 'Et huwa si cha 'aw ndusúlhahlel le'hoont'oh.’ 
\p  
\v 46 'Et ndunt'ohne, 'enne 'ilhiz wheni dzoh notideh ts'o tidulh. 'Et hoonts'i ndunne ts'ih'un 'unt'ohne, 'enne 'ilhiz whe ts'ukhuna-un bugha óotakulh.” 
\c 26  
\s1 Sizi yooya whútsul hikunúta hituzilhghelh ha 
\p  
\v 1 'Et 'awet Sizi ts'iyantsuk whe lhadúja whe yugha hodul'ehne 'et ndúbulhni, 
\p  
\v 2 “'Et t'eoonahzun 'awet nat dzin whuz'ai whe butus lhuseya-un 'et whunahutilnih. 'Et 'oh de de yinka dune ye' 'awet butl'ahitilhtelh 'ink'ez tulalhgus k'ehúyitalhtelh.” 
\p  
\v 3 'Et soo 'oh whuya hoozulh whe za, 'et lubret 'udedone, 'ink'ez Moses be 'udustl'us 'uk'ununáguzne, 'ink'ez dune 'utso whudilhdzulhne cha, 'enne ts'iyawh lubret 'uk'enus dízt'i'-un, 'en Caiaphas huyulhni, ooyoh soo' whulcho 'inka 'et 'ilhunahootádulh. 
\p  
\v 4 'Et 'alhgoh yahalhduk 'ink'ez howhuts'it whe hoonli hiba' hoonla whe Sizi huyitálhchulh 'ink'ez hituzilhghelh. 
\p  
\v 5 “'Et hoonts'i njan butus lhuseya-un 'et whutoh 'uts'inla de kwa la dunene lhtahahót'alh.” hutni. 
\s1 Datitsah whutso ts'eke Sizi k'unutsútjul-i yutsi k'eyilhdzo 
\p  
\v 6 'Et 'awet keyoh whuyaz Bethany huwhútni-un, 'et Simon ooka whulhjut ínle'-un, leprosy huyúlhni, ooyoh 'en Sizi yuzih usda. 
\p  
\v 7 'Et 'ilhoghun ts'eke bughu daninya whe 'en ndi tse dízti'-i, Alabaster huyúlhni, 'i be ndi luboodai 'ulya, 'i yi'alh. Ndi yoo sooltsun-i, 'i tube dizti' whe 'unt'oh. 'Et lutab k'ut na'ut'alh whe yutsi k'eyilhdzo. 
\p  
\v 8 'Et ndunne yugha hodul'ehne hinilh'en whe hukwa lhe'hunizun. 'Ink'ez 'enne ndúlhodutni, “'Et di ha ndi 'ants'i ninta' yulh'ih? 
\p  
\v 9 Ndi yoo dizti'-i bé' ts'onket de, 'i ts'iyawh tel'enne gha ts'oodzaih oole' da'!” 
\p  
\v 10 'Et Sizi t'eoonanzin whe 'et ndúbulhni, “Ndun ts'eke oots'áhalhozah'ai. 'Ut'en unzoo-i sba inla whe 'unt'oh. 
\p  
\v 11 'Ahoolhyiz tel'enne bubulh áht'oh, 'et hoonts'i si 'ahoolhyiz 'aw nohbulh lhe'tuzist'el. 
\p  
\v 12 'Alha ndi yoo sooltsun-i 'adutistelh huba syust'e yuk'éyilhdzo whe 'ut'en. 'Et whuz un'a lhasúdinla. 
\p  
\v 13 'Alha nohdusni ndi yun k'ut ndulcho whe ndi khuni unzoo-i nudútikat, ndun ts'eke ndet 'uhoonla-un, 'et hukw'u naootitnuk 'et whe dune yunatilnih.” 
\s1 Judas Sizi be 'óotakulh hukwa' ninzun 
\p  
\v 14 'Et 'awet ndunne whunizyanne 'on 'at nane, 'enne butoh 'ilhoghun Judas Iscariot huyulhni, 'en lubret bumoodihne buts'u whinya. 
\p  
\v 15 'Et ndúbulhni, “Daltsuk sgha tíh'alh ndun dune nohtl'ásti de?” “'Et tat whunizyai sooneya, silver,” huyulhni, 'et 'ultsuk hiba huyolhto. 
\p  
\v 16 'Et whuts'un nts'en'a butl'aitilhtelh-un 'et hukwunúta. 
\s1 Sizi 'en yugha hodul'ehne butus lhuséya-un bubulh na'ut'alh 
\p  
\v 17 'Et 'andit 'awet ndi lhes lhuntildoh-un dzin whusahóolts'ut whe mbene Sizi yugha hodul'ehne, 'enne highu nindil 'ink'ez huyoodulhdut, “Njan butus lhuseya-un 'uta'úlh-un, nts'e mba lhats'odutileh hukwa ninzun?” 
\p  
\v 18 'Et ubúlhni, “Nghuz keyoh whuti whuz ahdulh. 'Ilhoghun dune sba dáhni, ‘Nehodulh'eh-un nja dutni, 'awet sba nilhdukw hoozulh. Nyoh ts'e ndunne sgha hodul'ehne nja butus lhuseya-un, 'et 'alhgoh bubulh whunatiznih.’” 
\p  
\v 19 'Ink'ez yugha hodul'ehne Sizi daja ubudani', 'et whuz un'a nduhuja. 'Ink'ez njan butus lhuseya-un 'et wheni lhaháduja. 
\p  
\v 20 'Et 'awet hulhgha whusahonzut whe whunizyanne 'on 'at nane yugha hodul'ehne, 'enne bubulh natl'adida' bula natit'ulh ha. 
\p  
\v 21 'Et 'uha'alh whutoh 'et ndúbulhni, “'Alha nohdusni njan nohtoh 'ilhoghun whutl'asutilhtelh.” 
\p  
\v 22 'Et ts'iyawh ni huzdli', 'ink'ez 'ilhone hinli whe huyoodulhkut, “SMoodihti si tilah sudini?” 
\p  
\v 23 'Et ndúbulhni, “Mbe la dules sulh tunayuz'ai-un, 'en 'utinelh whutl'asútilhtelh. 
\p  
\v 24 'Alha yinka dune ye' nts'en'a la ba 'uk'ehooguz, whuz un'a 'utinelh datitsah. 'Et dune mbe la whutl'ayálhti-un, 'en dune 'uk'enus hoontsi'-un oogha óotalts'ulh. Ndun dune 'aw lhuhóolel de, 'et de da' 'on nus ooba hózoo' oole'.” 
\p  
\v 25 'Et Judas, mbe la whutl'aitilhtelh-un, 'en Sizi yoodulhkut, “Rabbi si eh sudíni?” 'Et 'uyulhni, “Nyunch'oh údini.” 
\s1 Sizi 'udek'ez na'ut'alh-un 
\p  
\v 26 'Et 'awet 'uhan'al whe Sizi lhes yilhchoot. Musi ni whe tenadidli. Lhts'e danyuz 'ink'ez yugha hodul'ehne butl'ayán'ai. 'Et ndúbulhni, “Ulhchoot 'ink'ez ah'alh. Ndi syust'e 'unt'oh.” 
\p  
\v 27 'Et lubot 'i cha yilhchoot 'ink'ez musi ni whe tenadidli. 'Et ndúbulhni, “Nohni ts'iyawh 'i be ahnai. 
\p  
\v 28 'Et huwa ndi suzkai' 'i be 'andidi be nohts'u nahizusya, 'et huba 'ulya. Lhane ba nadútilt'ih. 'Et 'i be bulubeshi buba gak natidleh. 
\p  
\v 29 Njan 'et nohdusni, ndi mai too' 'aw doo cha za oosnai' ait'oh. 'Et hoonts'i ndi mai too' 'andidi-i, 'i nohbulh tisnelh. Nts'e la 'uBá lerwe unli-un, 'et whuz oozahdil-un, 'et dzin nohbulh tisnelh.” 
\p  
\v 30 'Et Yak'usda ooyun be híjun 'ink'ez ndo shus k'us Olive huyulhni, whuz whehandil. 
\p  
\v 31 'Et 'awet Sizi ndúbulhni, “'Andit 'ulhdzis nohni ts'iyawh skayátihleh. Diz un'a 'uk'ehoogus whe ndutni, 
\q1 ‘'Usbai ghunli-un, tuzilghelh huba whutl'atístelh. 
\q2 'Et de 'usbai ts'iyawh yahitalh'us.’ 
\m  
\v 32 'Et dunadusja hukw'elh'az de, 'et yun k'ut Galilee ts'e nohtso tisyalh.” 
\s1 Sizi Peter ulhni, “T'esunuzinzun dutanelh” 
\p  
\v 33 'Et Peter 'uyúlhni, “'Et ts'iyawh nyun nkayahutileh 'et hoonts'i si 'aw nkayálhtuzisdle.” 
\p  
\v 34 'Et Sizi nja dúyulhni, “'Alha-i be nyudusni, 'et 'andit 'ulhdzis lugok dune 'udutinelh whutso, 'et tat t'esunuzínzun dutanelh.” 
\p  
\v 35 'Et Peter 'utni, “Nyúlh datisah de, 'et hoonts'i 'aw t'enyunuzúszun doosni' ait'oh.” 'Et 'onghohne yugha hodul'ehne, 'enne cha whuz un'a za 'uhutni. 
\s1 Sizi Gethsemane 'et tenadudli 
\p  
\v 36 'Et la 'ilhoghun haniyeh k'et Gethsemane huwhútni-un ts'e whuz hoozdil whe Sizi yugha hodul'ehne ubúlhni, “Nohni njan dulhts'i. 'Et si nda 'at tenadutisdli.” 
\p  
\v 37 Peter 'ink'ez Zebedee buzkeh, nane, 'enne ubilhchoot 'ink'ez dulh whebildilh. 'Et 'awet ts'odi cho ook'édilts'ut 'ink'ez oodzi tube yo 'uja. 
\p  
\v 38 'Ink'ez ubulhni, “Szul tube ts'odi suli' k'et 'awet datisah le'ust'oh. Nja dúlhts'i 'ink'ez sla huwahli.” 
\p  
\v 39 'On 'unyaz le whinya whe 'et nachániti 'ink'ez tenawhendunidli 'ink'ez nja dutni, “'UBá ndi lubot be dzoh nutiszut-i, whuz un'a 'unt'oh de, 'et whute senghólts'it. 'Et hoonts'i 'aw si hukwa' nuszun k'un'a iloh. Nyun hukwa' ninzun hukw'un'a 'et 'uhóneh.” 
\p  
\v 40 'Et nyoonne yugha hodul'ehne nahunistez whe bughu nanja. 'Et Peter ndúyulhni, “'Aw eh 'ilhoh sadzi hukw'uhunist'o whe sulh huwonle' ait'oh? 
\p  
\v 41 Tank'us nínt'i-un whuch'a howinli 'ink'ez tenadinli! 'Alha dune yughi whuz un'a hukwa' ninzun, 'et hoonts'i ooyust'e tetsun.” 
\p  
\v 42 'Et doo cha za whulh nat bugho whenaja tenadutidli ha. 'Et nja dutni, “'UBá ndi lubot 'aw sghu naóolhchoot ait'oh, 'i ts'iyawh usnai' 'et de za. 'Et whuz un'a za hukwa' ninzun de, 'et ndó honeh.” 
\p  
\v 43 'Et doo cha za nahuniztez whe bughu nanja. Bulh buba yilhtus k'et 'aw hitó'en ait'oh. 
\p  
\v 44 'Et 'awet bugho whenaja 'ink'ez whulh tat-i khuni 'i be za tenadidli. 
\p  
\v 45 'Et 'awet yugha hodul'ehne bughu nanja 'ink'ez 'ubulhni, “'Awhuz nalhyis 'ink'ez sahtez whé eh aht'oh? Soo zulhts'ai 'awet sba whusahóolts'ut. Yinka dune ye' ndunne mbene la lubeshi 'ulh'enne, 'enne butl'ahítilhtelh. 
\p  
\v 46 Soo 'ah dunadahdilh! 'Awet uztoodilh sih! Whunulh'en mbe la whutl'asútilhtelh-un, 'awet senghoh uyalh!” 
\s1 Sizi 'awet huyílhchoot 
\p  
\v 47 'Awhuz yalhduk whe 'et khunsul Judas, 'en whusainya whe 'en ndunne whunizyanne 'on 'at nane whel'a'ne, 'enne ndun 'ilhoghun 'unt'oh. 'En bulh lhane dune yulh whusaindil. Whulohne saluzti nuhúle, 'ink'ez whulohne tut'oh nódule. Lubret bumoodihne 'ink'ez dune 'utso whudilhdzulhne, 'enne whusahábahalh'a'. 
\p  
\v 48 'Et 'awet mbe la Sizi whutl'aitilhtelh-un, 'en 'ilhunaoosdilne ubulhni, “Mbe la nadists'ooz-un, 'en 'udúsni. 'En 'aho ólhchoot!” 
\p  
\v 49 'Et 'aho 'en Sizi yughu ninya whe “Hadih Rabbi,” yulhni 'ink'ez naidits'ooz. 
\p  
\v 50 'Et Sizi ndutni, “Syadan di ha whusainya?” 'Et 'awet whusahandil Sizi 'aho huyilhchoot. 
\p  
\v 51 'Et khunsul 'ilhoghun Sizi yulh 'unt'oh-un ndi saluzti hayálhtsus 'ink'ez lubret 'uk'enus dizti'-un be 'ulhna-un, 'en yudzo yuts'a ha bé' yalht'o. 
\p  
\v 52 'Et Sizi ndúyulhni, “Nyoo saluzti t'unádint'aih! 'Alha mbene la 'et dut'enne, 'enne 'et hukw'e dahutitsah. 
\p  
\v 53 'Et si hukwa' nuszun de, 'uBá ooduskut de 'ink'ez 'andit 'aho 70,000ne lizas 'on 'un 'ultsukne, 'enne da' sts'o tl'aboolelh oole' da' sla hutinelh ha. 'Et 'aw t'eoonuzínzun whe 'int'en. 
\p  
\v 54 'Et za ndust'en de, nts'en'a Yak'usda ooghuni lhadútineh? Nts'en'a la sts'un dawhut'ih-un, 'et whuz un'a 'uhóneh huba' hoont'oh.” 
\p  
\v 55 'Et 'awet 'oh whuya 'uhunit'oh whe Sizi 'ilhunaoosdilne ndúbulhni, “'Et di ha saluzti cha 'ink'ez tut'oh cha nuhle 'ink'ez 'undunust'ih hukw'un'a skatíhdil? Dzin totsuk lugliz whucho 'et nohtoh susda 'ink'ez whunohodus'eh. 'Et hoonts'i 'aw sulhúlhchulh. 
\p  
\v 56 'Et huwa, nus hoo'enne bube' 'udustl'us ook'ehooguz-un, 'et ts'iyawh lhawhúdutanelh.” 'Et 'awet higha hodul'ehne, 'enne highu whetsélhdil. 
\s1 Sizi nahiyilhne bubut nenínya 
\p  
\v 57 'Et 'awet mbene la Sizi yilhchootne, 'enne lubret 'uk'enus dizti'-un, Caiaphas huyulhni, ghu hinílhti. Moses be 'udustl'us 'uk'ununáguzne, 'ink'ez dune tso whudilhdzulhne cha, whuz 'ilhunahosdil. 
\p  
\v 58 'Et Peter 'on niz de bubuniyalh whe lubret 'uk'enus dizti'-un ooyoh whuna'niztl'oo-un whuz bubunéninya. Whuz bughu daninya whe neilhchukne buzih natl'adida' 'ink'ez naldzilh, daootanelh whuntilh'elh 'et hukwa. 
\p  
\v 59 'Et lubret bumoodihne, 'ink'ez 'utso whudilhdzulhne cha, 'ink'ez nahiyilhne cha, 'enne ts'iyawh hoonli-unyaz whuts'it huwun highu nahó'alh hukwa' hut'en whe hituzilhghelh-un. 
\p  
\v 60 'Et hoonts'i 'aw hiyulh náho'alh-un hooloh. Lhane dune whusahándilh 'ink'ez huwhuts'it be highu yalhduk. 'Et hoonts'i 'awhuz hoonli hiyulh nalhuwhus'ai. 'Et khunsul nane dune whuts'itne whusain'az 
\p  
\v 61 whe nduhútni, “'Et ndun dune 'utni Yak'usda oolugliz whucho hooloh whutilhtselh 'ink'ez tat dzin whutoh 'udun na'whutilelh ni,” hutni. 
\p  
\v 62 'Et 'awet lubret 'uk'enus dizti'-un duninya 'ink'ez Sizi yoodulhkut, “'Aw eh daja lhdutuzanel? Daja hutni-un 'et huwun daja ninzun?” 
\p  
\v 63 'Et Sizi 'aw t'edusnih. 'Et lubret 'uk'enus dizti'-un, 'en yulhni, “Mbe la Yak'usda khuna-un, 'en be nyudusni yatolhdih huba' hoont'oh. 'I be mba nahutideh. Nedini Christ Yak'usda ooYe', 'en eh 'int'oh?” 
\p  
\v 64 'Et Sizi ndúyulhni, “Nyunch'oh 'et 'údini. 'Et njan huwun nohbulh yasduk, k'at le de yinka dune ye', 'en mbe la ulhtus-un, 'en nailhni ts'unk'us yughu usda, 'et whutih'elh. 'Ink'ez kw'us k'ut ndus de hatiyalh, 'et cha whutih'elh.” 
\p  
\v 65 'Et lubret 'uk'enus dizti'-un ye usda-i dubut ka lhts'e yalhch'ul 'ink'ez 'utni, “Yak'usda ch'az ditni whe yalhduk. 'Aw 'uyoonne nedóni' hukwa lhe'uznízun. 'Andit whunulh'en Yak'usda ch'az ditni-un ts'iyawh nohni nohnalh 'utni. 
\p  
\v 66 Daja nahzun?” 'Et 'uhutni, “Daóotsah huba 'unt'oh!” 
\p  
\v 67 Hinin ts'e huyoonuzo. Huyoolhchis 'ink'ez whulohne huyoonukat. 
\p  
\v 68 'Et whuz un'a nduhúyulhni, “Neba nus whutan'elh. Nyun 'int'oh Christ inli de, mbe nyinla nyunízkuk?” huyúlhni. 
\s1 Peter 'utni, “Sizi 'aw t'enuzuszun” 
\p  
\v 69 'Et Peter n'az whuna'niztl'oo-un whez ts'e usda whe ts'ekeyaz yughu ninya. 'Ink'ez ndúyulhni, “Ndun Sizi Galilee whut'en-un, nyun cha bulh 'int'en inle'!” 
\p  
\v 70 'Et ts'iyawh bubut whuts'oodidlai whe ndutni, “Daja dini-un 'aw t'eoonuzúszun.” 
\p  
\v 71 'Inka 'az tenánja. 'Uyoon ts'eke cha yunilh'en, 'ink'ez 'oh nudilhyanne, 'enne ndúbulhni, “Ndun 'en cha Sizi Nazareth whut'en-un bulh 'unt'oh inle'.” 
\p  
\v 72 'Et doo cha za Ndoghi nalh whuts'oodísdlat whe ndutni, “Ndun dune 'aw t'enuzuszun!” 
\p  
\v 73 Hukw'elh'az mbene la yuzih nudalya'ne, 'enne highu nindil whe huyúlhni, “'Alha mbene la yulh ant'e'ne, 'enne nyun cha 'ilhoghun 'int'oh. Nts'en'a la yailhduk-un, 'et huwa t'ets'unyunínzun.” 
\p  
\v 74 'Et Peter 'et ndutni, “Yak'usda sts'e'tilhtsus 'aw ts'ih'un lhe'duzusnih de, ndun dune 'udáhni-un, 'aw t'enuzuszun.” 'Et 'aho lugok dune 'udíja. 
\p  
\v 75 'Et Sizi daja ni la 'et Peter whunalni whe nja dutni, “'Et lugok dune 'udutinelh whutso, tat 'aw t'esunuzinzun dutanelh.” 'Et 'az whenaja 'ink'ez tube cho howintse. 
\c 27  
\s1 Sizi Pilate but nenínya 
\p  
\v 1 'Et 'om bun bundada 'uda' lubret bumoodihne, 'enne ts'iyawh, dune 'utso whudilhdzulhne, 'enne cha, 'enne Sizi hich'az ditni whe howu yahalhduk hituzilhghelh hukwa. 
\p  
\v 2 'Et Sizi hiyulhghel 'ink'ez yun k'ut whumoodih, 'en Pontius Pilate huyulhni, hits'u hayoolhti. 
\s1 Judas tsená'usguz 
\p  
\v 3 'Et mbe la whutl'ayálhti-un, 'en Judas huyúlhni-un, 'et 'awet Sizi datitsah huba ba nahisda whe, 'et t'eoonanzin whe tube oodzi nduda suli'. 'Et ndi tat whunizyai sooneya silver huyulhni, ndunne lubret bumoodihne 'ink'ez dune 'utso whudilhdzulhne cha, buba whusanáyandzai. 
\p  
\v 4 'Et ndúbulhni, “Ndun dune ninta lhe'ust'í-un, 'en whutl'ásti-un 'et whe ninta' nust'en.” 'Et 'uhuyúlhni, “Wheni neba lhe'hóot'oh. Nyunch'oh za mba' hoont'oh!” 
\p  
\v 5 'Et ndi tat whunizyai silver ts'utni-i sooneya lugliz whucho yun bubut nayántsut. 'Et 'ink'ez 'az whenaja 'ink'ez tsená'usguz. 
\p  
\v 6 'Et ndunne lubret bumoodihne ndi sooneya silver ts'utni-i, 'i huyilhchoot 'ink'ez 'uhutni, “Dune buzkai' suli'-i 'unt'oh. 'Et huwa 'aw Yak'usda ba be 'úzdla-i be náts'oodzaih ait'oh.” 
\p  
\v 7 'Et dich'oh dutoh howu yahalhduk. 'Ink'ez mbe la lhez oosa' 'ulh'en-un, ndi sooneya 'i be 'en yun hiyónket. 'I k'ut 'uts'un whut'enne, 'enne 'uhule 'et wheni. 
\p  
\v 8 'Et huwa soo 'andit njan dzin 'et whuts'un ndi yun boozi' 'i 'uskai' yun huyulhni. 
\p  
\v 9 'Et whuz un'a 'oh da' ndun nus hoo'en-un Jeremiah daja ni la 'et whunilhchoh 'oh túne' whust'en whe lhaóoduja whe nja dutni, “Ndi sooneya silver ts'utni, 'et tat whunizyai 'et 'ultsuk uschoot. 'Et 'ultsuk whe hiyolhto 'et ndunne Israel oots'u haindene, 'enne buba k'elha huyulhtsi. 
\p  
\v 10 'Ink'ez lhez oosa' 'ulh'en-un, 'en ooyun hiyónket. 'Et whuz un'a Moodihti sudani'.” 
\s1 Sizi Pilate yubut usyin 
\p  
\v 11 'Et 'awet Sizi mbe la yun moodih 'en yubut usyin. 'Et yun moodih yoodulhkut, “Nyun eh 'int'oh Lizwif bulerwe inli?” 'Et Sizi 'uyulhni, “A, 'alha' dini.” 
\p  
\v 12 'Ink'ez ndunne Lizwif bumoodihne 'ink'ez dune 'utso whudilhdzulhne cha, 'enne hik'eho'alh hukwa' hut'en. 'Et hoonts'i 'aw hoonliyaz lhe'dínel. 
\p  
\v 13 'Et Pilate yoodulhkut, “'Aw eh lhubuduzínts'o lhe'whultsuk-un whe nch'az yáhalhduk?” 
\p  
\v 14 'Et 'aw 'ilho khuni be hoonts'i daja lhdinel. 'Et whe yun k'ut whumoodih tube ooba hooncha. 
\s1 Pilate Barabbas buba yulanaditni 
\p  
\v 15 'Et nawhudizulh totsuk lizwif butus lhuseya 'et whunahulnih, 'et whutoh yun moodih mbe la 'adin'ai-un 'ilhoghun hika' ninzun-un, 'en ts'iyanne buts'u lanadutitnih. 'Et whuz un'a buk'oh ts'e 'uhoont'oh. 
\p  
\v 16 'Ilhoghun 'adin'ai-un, 'en Barabbas huyulhni, ts'iyanne t'ehinínzun. 
\p  
\v 17 'Et ts'iyawh 'ilhunahosdil whe Pilate uboodulhkut, “Mbe nohba oolanadutisnih hukwa' nahzun, Barabbas k'us Sizi, 'en Christ huyulhni?” 
\p  
\v 18 T'eooninzun 'oonih gha butl'ahayalhti. 
\p  
\v 19 'Et Pilate dune ba nahidilh-i, kw'uts'uzda k'usda whe oo'at 'en khuni yuts'ó tl'ain'ai, 'et ndúyulhni, “Ndun dune 'en ts'ih'un 'unt'oh-un. Hoonliyaz onleh junih! 'Alha 'andit dzin 'en oogha huwu nusústi 'et whe dzoh nusúszut.” 
\p  
\v 20 'Et ndunne lubret bumoodihne 'ink'ez 'utso whudilhdzulhne cha, 'enne 'ilhunaoodilhne ba hunint'i 'et whuz un'a 'uhóoneh ha, 'enne Pilate Barabbas yulanadootni 'ink'ez Sizi hooloh huyoolhtselh ha. Whuz un'a 'uhudooni' ha. 
\p  
\v 21 'Et 'awet yun moodih 'en uboodulhkut, “Ndunne nane, 'enne k'us mbe nohba oolanadutisnih hukwa' nahzun?” 'Ink'ez 'et 'uhuyúlhni, “Barabbas.” 
\p  
\v 22 'Et ndun Pilate ndúbulhni, “'Et ndun do', Sizi mbe la Christ huyúlhni-un, 'en nts'en'a cha daóosdlih ha la?” 'Et 'ilhunaoosdilne nduhúyulhni, “Tulalhgus kélhtih!” 
\p  
\v 23 'Et yun moodih 'et ndutni, “Di ha? Ndet whe ninta' 'ant'en?” ubulhni. 'Et hoonts'i sul'ehúdilya, “Tulalhgus kélhtih!” hutni. 
\p  
\v 24 'Et ndun Pilate t'ewhunínzun 'aw hoonliyaz 'uhooleh ait'oh. Ndunne 'ilhunaoosdilne 'awet lhtahotát'alh le'hoont'oh. 'Ink'ez 'ilhozdilne bubut too be lana'ilde 'ink'ez ubúlhni, “Ndun ts'ih'un dune buzkai' oot'aóosnalh hukwa lhe'núszun. Nohnich'oh za nohba 'uhoont'oh.” 
\p  
\v 25 Ts'iyanne dune 'et nduhutni, “Wheni ts'iyawh neuzkeh tubulh buzkai' whutaleh-un, 'et nek'éholts'it!” 
\p  
\v 26 'Et 'awet Barabbas buba yulanaditni 'ink'ez Sizi huyolhtsus. 'Et hukw'elh'az butl'ayálhti tulalhgus k'ehíyolhtelh ha. 
\s1 Lhuganne Sizi highu núwhulhya 
\p  
\v 27 'Et 'awet yun moodih 'en la lhuganne ubut'ine, 'enne Sizi huyilhchoot 'ink'ez duyoh ts'e whehúyalhti, 'i Praetorium huwhútni. 'Et ts'iyawh ndunne lhuganne Sizi higha óosguz. 
\p  
\v 28 'Et hinaih hits'u húnuhuyulhch'ul whe luglok dulk'un-i hit'uháyulhchooz. 
\p  
\v 29 Whus cho nahinílhjaz-i, 'i hitsi nehídan'ai. 'Ink'ez tl'oghazilh nailhni ts'e hila k'ehídantan. Lerwe k'un'a yot'e' ha hitl'ahídantan. Hibut nachánuldulh cha' huyulh'en. 'Et whuz un'a highudloh. 'Ink'ez “Lizwif bulerwe sa' cho hona'!” huyúlhni. 
\p  
\v 30 Highá dizoh, 'ink'ez tl'oghazilh be hitsi oonulht'a. 
\p  
\v 31 'Et highudloh-un 'etsul 'uhudija whe ndi luglok highun náhuyílhchoot 'ink'ez dich'oh oonaih be náhuyalhti. 'Et 'awet tulalhgus k'ehuyítalhtelh ts'e hítilhti. 
\p  
\v 32 'Awet Sizi tehínilhti whe 'ilhoghun dune Cyrene whut'en-un 'unt'oh, 'en Simon huyulhni, 'en hidudizdil whe ndi Sizi ootulalhgus ooba idantelh huyúlhni. 
\p  
\v 33 'Et 'awet njan Golgotha ts'uwhútni-un whuz hoozdil. 'Et ndi khuni 'utsints'un niz'ai ni whe 'utni. 
\p  
\v 34 'Et ts'ekoo too' dunink'oz-i 'ink'ez yoo, gall ts'utni, hitadínla. 'I yulh yootnai' hukwa' huyinla. 'Et hoonts'i yunawhúzdlih 'ink'ez 'aw yootnai' hukwa lhe'nízun. 
\p  
\v 35 'Et tulalhgus 'uhidunilht'o hukw'elh'az hinaih higha 'áinli. Dahuja-un 'et 'oh da' nus hoo'en-un nts'en'a 'udani', 'et ts'iyawh hukw'un'a 'uhooja. Ndiz un'a nja dudani', 
\q1 “Ndi snaih dich'oh lhtahuyulya. 
\q1 'Ink'ez ooloh higha 'ainli cha' huyinla.” 
\p  
\v 36 'Et 'awet nátl'ahudilts'i 'ink'ez highunli. 
\p  
\v 37 Ootsi 'an dus ts'e dzihtelyaz hodunilht'o. 'Ink'ez ndet la hik'ehoon'ai-un 'et 'uk'ehuhoonguz. 'Et ndutni, 
\qc Ndun Sizi 'en 'unt'oh Lizwifne bulerwe. 
\p  
\v 38 Nane undunut'ihne, 'enne cha hiyulh tulalhgus k'ebuhilhti. 'Ilhoghun nailhni ts'e, 'ink'ez 'ilhoghun 'intl'us ts'e. 
\p  
\v 39 Mbene la 'oh whuya whedilhne nodunul'us 'ink'ez hich'az ditni whe yahalhduk. \fig |src="cn01838c.tif" size="col" copy="©1978 David C. Cook Publishing Company" ref="Matthew 27.39" \fig* 
\p  
\v 40 'Et 'uhuyúlhni, “Nyun 'int'oh lugliz whucho nanaóodutanlelh 'ink'ez tat dzin za na'whutanlelh dini! Nyunch'oh 'ududílyih! Yak'usda ooYe' inli de, ndi tulalhgus k'ut ook'ut nanaíndaih!” 
\p  
\v 41 'Et ndunne lubret bumoodihne, 'enne cha whuz un'a za highudloh. Moses be 'udustl'us 'uk'ununáguzne, 'enne cha 'ink'ez dune 'utso whudilhdzulhne cha, ts'iyawh whuz un'a za 'uhutni whe ndiz un'a nja duhutni, 
\p  
\v 42 “'Uyoonne ulhyis 'et hoonts'i dich'oh 'aw 'ududoolyih ait'oh. Israel oots'u haindene, 'enne ba lerwe unli de, 'et de ndi tulalhgus yuk'ut nanaóoja' oole' da'. 'Et de da' neba 'alha' 'oot'e'. 
\p  
\v 43 'En Yak'usda t'anínintan. 'Et huwa Yak'usda yuka' ninzun de, 'andit 'aho da' yoolhyih. 'En 'utni si Yak'usda ooYe' 'ust'oh.” 
\p  
\v 44 Ndunne 'undunut'ihne yuzih tulalhgus k'usulhtine, 'enne cha whuz un'a za 'et duhúyulhni. 
\s1 Sizi ye khuna-i yuladitni 
\p  
\v 45 Dzetniz hukw'elh'az 3:00 at'en 'ink'ez hulhgha 6:00 at'en 'et whuts'un ndi yun k'ut ndúwhulcho whe tsahólhgus suli'. 
\p  
\v 46 'Et 6:00 at'en Sizi tube cho ka' dija whe, “Eli, Eli, lama sabachthani?” Ndi khuni, “SYak'usda, SYak'usda di ha sla dantnih,” ni whe 'utni. 
\p  
\v 47 Whulohne dune 'et núdilhyane hidánts'o 'ink'ez 'uhutni, “'Ah! Elijah hahayih whe 'utni!” 
\p  
\v 48 'Et 'aho 'ilhoghun whusalgai, 'ink'ez duchun oola'dul'oo-i ts'ekoo too' dunink'oz-i ye tunayuzsi 'ink'ez ndo Sizi yuze yunaóonulhtsul. 
\p  
\v 49 'Onghohne “K'at oots'ú ha lhozah'ai! Elijah yughu ninya 'ink'ez tilah yoolhyih.” 
\p  
\v 50 Cha za Sizi tube cho 'udíja 'ink'ez duyughi yula ditni. 
\p  
\v 51 Khunsul lugliz whucho dutai-i hukwa dímbal-i lhulcho lhk'ench'ul. 'Et yun cha núhisnai, 'ink'ez tse cho lhts'edankat. 
\p  
\v 52 Ts'un k'ut dune 'adinla-un dáhana'dankat. 'Ink'ez lhane Yak'usda ooch'e'ne nahunistez inle', 'enne dunahudidil. 
\p  
\v 53 'Et 'awet tse be tsa k'et ts'e hanáhidil, 'ink'ez keyoh Jerusalem ts'e whehandil. 'Et lhane nalhts'et bube hóodiltsai, 'et whe whúbunilhtan. Sizi nakhitna' hukw'elh'az ndulcho whe 'et dúhooja. 
\p  
\v 54 'Et 'awet ndun lhuganne bumoodih 'en, 'ink'ez yulh 'ut'enne, 'enne mbene la Sizi yughunline, yun núkhisnai 'ink'ez nts'oh te ne'whust'en-un, 'et honalh'en, 'et whe tube whehúnilhjoot 'ink'ez 'et 'uhutni, “'Alha azih ndun dune, 'en Yak'usda ooYe' 'unt'oh.” 
\p  
\v 55 Ts'ekoo cha 'et núdilhya whe yoo 'az de whuts'un honilh'en. 'Enne Galilee ts'u haindilne 'uhut'en. 'Enne Sizi huyuwhusanándilne 'ink'ez hiba ne'úst'enne 'uhint'oh. 
\p  
\v 56 'Enne butoh Mary Magdala whut'en-un, 'en cha 'ut'en, 'ink'ez Mary James 'ink'ez Joses bulh 'enne buloo, 'en cha 'ut'en, 'et Zebedee ooye'ke 'enne buloo cha, 'ut'en. \fig |src="cn01841b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="Matthew 27.56" \fig* 
\s1 Joseph Sizi 'ayalhti 
\p  
\v 57 'Et 'awet hulhgha whenghoh hoozulh whe 'ilhoghun Arimathea whut'en-un, dune hoonzoo' 'unt'oh-un, 'en Joseph huyulhni. 'En cha Sizi yugha hodul'eh-un 'ilhoghun suli'. 
\p  
\v 58 'En Pilate ts'u whinya, 'ink'ez Sizi oozi yuts'u yuka 'utni dutl'ayóolhtelh ha. 'Et Pilate ubulhni, “Sizi oozi ndun dune ootl'ayúlhtih.” 
\p  
\v 59 'Et Joseph Sizi oozi ndus de hanáyalhti 'ink'ez naih dizti'-i, 'aw lhditsun, 'i yugha íyozduz. 
\p  
\v 60 'Et dich'oh ootse be tsa k'et 'andit-un 'uhoonla, 'et whambez ts'e 'et neínilhti. 'Et tse cho whudanádan'ai 'ink'ez whenája. 
\p  
\v 61 Mary Magdala whut'en-un, 'en cha 'et usda. Njan tsa k'et whanch'az, 'et 'uyoon Mary cha 'et usda. 
\s1 Sizi nts'e la 'ayalhti-un, ndi tse k'ut whuduná'hudalhdze 
\p  
\v 62 'Et njan dzenis whutih 'et wheni lhazdutneh-un dzin 'uhoont'oh. 'Et 'om bun dzin ndunne lubret bumoodihne 'ink'ez Phariseene cha, 'enne ts'iyawh Pilate ts'u whehandil. 
\p  
\v 63 'Et nduhúyulhni, “Nemoodih ndun nenan'a-un 'awhuz khuna whe daja neúlhni la, 'et whunats'ilni whe ‘Tat dzin inle' de dunádutásdalh,’ ni. 
\p  
\v 64 'Et whe nghuni be budóni' njan tsa k'et da'duta'alh whulh tat dzin 'et whuts'un. 'Et 'aw ndúlhinel de ndunne yugha hodul'ehne 'ulhdzis whusahándil 'ink'ez tilah hizi hidunoot'ih. 'Ink'ez la ts'iyanne hudóni' ndunne yaidlanne butoh dunadija whé 'unt'oh. 'Et whuz un'a 'udek'ez whuts'it-i, 'udechoo-i anus 'ultsi' whutáleh,” huyulhni. 
\p  
\v 65 'Et Pilate ndúbulhni, “Nohni cha huwunline aht'i whe aht'oh. 'Awet nahdulh 'ink'ez nohnich'oh soo duts'o cho whe dána'dih'aih!” 
\p  
\v 66 'Et whehándil 'ink'ez ndi tse k'ut whuduná'hudilhdze. 'I be duts'o cho whuzdli'. 'Et 'ink'ez huwunline 'et nehúninla. 
\c 28  
\s1 Sizi dunadija 
\p  
\v 1 Nats'ulyis dzin hukw'elh'az lisman 'udechoo dzin-un, soo yutilhkai-un, 'et Mary Magdala whut'en-un 'ink'ez 'uyoon Mary bulh ts'un k'uz hooz'az 'ink'ez honilh'en. 
\p  
\v 2 Khunsul 'ilhoghun neMoodihti oolizas yak'uz hainya-un. 'Et huwa yun cha núhisnai. Whusainya 'ink'ez ndi tse whudahaidunalhgai, 'ink'ez yuk'étl'adida. 
\p  
\v 3 Oonin 'ants'i ditni kwun duwhút'en. Oonaih yus k'un'a 'ulhyul. \fig |src="cn01853b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="Matthew 28.3" \fig* 
\p  
\v 4 'Et huwa nyoonne huwunline nujut k'et hudutlut, 'ink'ez 'ants'i dune dazsaine lhe'huja. 
\p  
\v 5 Lizas ndunne ts'ekoo ubúlhni, “Nulhjut íloh. T'eoonuszun Sizi mbe la tulalhgus k'ut dazai-un, 'en ookwunáhta whé 'aht'en. 
\p  
\v 6 'Aw njan hooloh! Dunadija whe 'unt'oh. Nts'en'a la datínelh ni, whuz un'a dunadija whé 'unt'oh. 'Anih, njan whunulh'en, ndet la neMoodihti ilhte'-un! 
\p  
\v 7 'Et 'a cho whuz ah'us 'ink'ez mbene la yugha hodul'ehne ubudáhni yaidlanne toh dunadija whé 'unt'oh. Soo zulhts'ai nohtso Galilee ts'oyalh. 'Et tih'elh. Soo cho soo zulhts'ai 'uda' nohdásni'.” 
\p  
\v 8 'A cho tse be tsa k'et whuch'a nahust'az. Whehunuljut 'et hoonts'i 'on nus huhóont'i' cha' hint'oh. 'Ink'ez mbene la yugha hodul'ehne buts'u whuhilgaih ubodutánelh ha. 
\s1 Sizi hits'u teni' nilhdzun 
\p  
\v 9 'Et mbene la yugha hodul'ehne ts'u hí'us whe khunsul Sizi buts'u dizya 'ink'ez, “Whunúlhnih,” ubulhni. Hizih nenin'az 'ink'ez hike óontun 'ink'ez hits'u téni' nalhdzin. 
\p  
\v 10 'Et Sizi ndúbulhni, “'Aw whénulhjut iloh. Sulhutsinke buts'oh'us 'ink'ez sba budúhni, nohni ts'iyawh Galilee ts'u toohdilh. 'Et la sooh'en.” 
\s1 Saldanne sooneya bugha hinindzai 
\p  
\v 11 'Et 'awet hutizdil whe 'et huwunline oolune Jerusalem ts'ú hoozdil. 'Et whuz hoozdil whe 'et ndunne lubret bumoodihne, 'enne ts'iyantsuk bubodáni' njan ndet la dahooja-un huwun. 
\p  
\v 12 'Et 'awet lubret bumoodihne 'ink'ez dune 'utso whudilhdzulhne, 'enne ts'iyawh 'ilhunahozdil 'ink'ez howu yahalhduk. 'Ink'ez lhai sooneya 'i saldanne bugha hinindzai 'ink'ez 'ubuhútni, 
\p  
\v 13 “'Et nohni diz un'a 'udutihnelh, ‘'Et 'ulhdzis 'awhuz ts'uztez whe mbene la yugha hodul'ehne whusahánil'i 'ink'ez oozi neghu hitilhti.’ 
\p  
\v 14 'Et yun moodih whulh 'údants'o de, soo kháznint'a whe yats'oolhduk si. 'Et de la whuz un'a 'aw hoonli nohts'u lhe'hosne.” 
\p  
\v 15 'Et huwa ndunne saldanne ndi sooneya huyilhchoot, 'ink'ez nts'en'a la ubodáni', 'et whuz un'a za 'onghohne cha budáni'. 'Et soo 'andit dzin 'et whuts'un, 'et whuz un'a lizwifne dich'oh dutoh howu yahalhduk. 
\s1 Sizi yak'uz whenaja whutso khuni netl'aídan'ai hik'une' ts'oot'en ha 
\p  
\v 16 'Et 'awet ndunne whunizyanne 'on 'at 'ilhoghun 'enne yugha hodul'ehne, 'enne Galilee ts'e whehandil. Ndi dzulh k'uz Sizi ubudani', whuz whehandil. 
\p  
\v 17 Hiyan'en whe hits'u teni' nalhdzin. 'Et hoonts'i whulohne buba nawh 'uhoont'oh. 
\p  
\v 18 Sizi buts'o whusainya whe bubulh yalhduk 'ink'ez nja dúbulhni, “Yak'uz 'ink'ez ndi yun k'ut 'et ts'iyawh whando 'ust'oh-un, 'et stl'ahóolts'ut. 
\p  
\v 19 'Et huwa lhelhts'un keyoh whut'enne, 'enne ts'iyawh buts'óhdulh 'ink'ez si sgha hodul'ehne ubulhts'i. 'UBá 'ink'ez 'uYe' 'ink'ez Ndoni, ndi boozi' be 'i be too be' butilh'elh. 
\p  
\v 20 Ndai khuni nohtl'adís'ai-i, 'i ts'iyawh hik'une' 'oot'en-un hubodoolh'eh. 'Ink'ez soo zulhts'ai, 'et dzin whulatoh lhaooduja de, 'et whuts'un 'ahoolhyiz nohbulh 'útist'elh whe' hoont'oh.” 'Et ndo honeh.