\b  
\q1
\v 10 \w You|strong="H5750"\w* people \w of|strong="H1323"\w* \w Tarshish|strong="H8659"\w*, \w you|strong="H5750"\w* must grow crops \w in|strong="H5750"\w* \w your|strong="H5674"\w* land \add instead of trading\add*;  
\q2 \w spread|strong="H5674"\w* \w out|strong="H5674"\w* \w over|strong="H5674"\w* \w your|strong="H5674"\w* land \w like|strong="H1323"\w* [SIM] \w the|strong="H5674"\w* \w Nile|strong="H2975"\w* \add River\add* spreads \w over|strong="H5674"\w* \w the|strong="H5674"\w* land \add of Egypt\add* \w when|strong="H5674"\w* \w it|strong="H5674"\w* floods,  
\q2 because \w there|strong="H2975"\w* \w is|strong="H1323"\w* no harbor \add in Tyre for your ships\add* now.   
\q1
\v 11  \add It is as though\add* \w Yahweh|strong="H3068"\w* \w stretched|strong="H5186"\w* \w out|strong="H5186"\w* \w his|strong="H3068"\w* \w hand|strong="H3027"\w* \w over|strong="H5921"\w* \w the|strong="H5921"\w* \w sea|strong="H3220"\w*  
\q2 \w and|strong="H3068"\w* \w shook|strong="H7264"\w* \w the|strong="H5921"\w* \w kingdoms|strong="H4467"\w* \w of|strong="H3068"\w* \w the|strong="H5921"\w* earth.  
\q1 \w He|strong="H3068"\w* \w commanded|strong="H6680"\w* \w that|strong="H3068"\w* \w in|strong="H5921"\w* Phoenicia/\w Canaan|strong="H3667"\w*  
\q2 \w all|strong="H5921"\w* \w its|strong="H5921"\w* \w fortresses|strong="H4581"\w* must \w be|strong="H3027"\w* \w destroyed|strong="H8045"\w*.   
\q1
\v 12 \w He|strong="H8033"\w* said \w to|strong="H6965"\w* \w the|strong="H5674"\w* \w people|strong="H3808"\w* \w of|strong="H1323"\w* \w Sidon|strong="H6721"\w*,  
\q2 “\w You|strong="H5117"\w* \w will|strong="H1571"\w* \w never|strong="H3808"\w* \w rejoice|strong="H5937"\w* \w again|strong="H5750"\w*, \w because|strong="H8033"\w* \w you|strong="H5117"\w* \w will|strong="H1571"\w* \w be|strong="H3808"\w* \w crushed|strong="H6231"\w*;  
\q1 \w even|strong="H1571"\w* if \w you|strong="H5117"\w* flee \w to|strong="H6965"\w* \w Cyprus|strong="H3794"\w* \add island\add*,  
\q2 \w you|strong="H5117"\w* \w will|strong="H1571"\w* \w not|strong="H3808"\w* \w escape|strong="H6965"\w* destruction.”   
\b  
\q1
\v 13 \w Think|strong="H7760"\w* \w about|strong="H1961"\w* \w what|strong="H2088"\w* \w happened|strong="H1961"\w* \w in|strong="H5971"\w* \w Babylonia|strong="H3778"\w*:  
\q2 \w the|strong="H7760"\w* \w people|strong="H5971"\w* \w who|strong="H5971"\w* \w were|strong="H1961"\w* \w in|strong="H5971"\w* \w that|strong="H5971"\w* land \w have|strong="H1961"\w* disappeared.  
\q1 \add The armies of\add* Assyria \w have|strong="H1961"\w* \w caused|strong="H1961"\w* \w that|strong="H5971"\w* land \w to|strong="H1961"\w* \w become|strong="H1961"\w* \w a|strong="H3068"\w* \w place|strong="H7760"\w* \w where|strong="H2088"\w* wild \w animals|strong="H1961"\w* \w from|strong="H6965"\w* \w the|strong="H7760"\w* \w desert|strong="H6728"\w* live.  
\q1 \w The|strong="H7760"\w* Assyrians built dirt ramps \w to|strong="H1961"\w* \w the|strong="H7760"\w* top \w of|strong="H5971"\w* \w the|strong="H7760"\w* walls \add of the city of Babylon\add*;  
\q2 \add then they entered the city and\add* tore \w down|strong="H7760"\w* \w the|strong="H7760"\w* palaces  
\q2 \w and|strong="H6965"\w* \w caused|strong="H1961"\w* \w the|strong="H7760"\w* city \w to|strong="H1961"\w* \w become|strong="H1961"\w* \add a heap of\add* rubble.   
\b  
\q1
\v 14  \add So\add* \w wail|strong="H3213"\w*, \w you|strong="H3588"\w* \add sailors on the\add* ships \w of|strong="H4581"\w* \w Tarshish|strong="H8659"\w*,  
