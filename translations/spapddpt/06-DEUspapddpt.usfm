\v 19 \w porque|strong="H3588"\w* tuve temor \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w ira|strong="H2534"\w* \w y|strong="H1571"\w* \w el|strong="H1931"\w* \w furor|strong="H2534"\w* \w por|strong="H5921"\w* \w los|strong="H5921"\w* cuales \nd \w Yavé|strong="H3068"\w*\nd* estaba \w tan|strong="H1931"\w* \w enojado|strong="H7107"\w* \w contra|strong="H5921"\w* ustedes \w para|strong="H5921"\w* \w destruirlos|strong="H8045"\w*. \w Pero|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H5921"\w* \w escuchó|strong="H8085"\w* \w también|strong="H1571"\w* \w aquella|strong="H1931"\w* \w vez|strong="H6471"\w*.
