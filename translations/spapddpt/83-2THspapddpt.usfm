\p
\v 1 \w Pablo|strong="G3972"\w*, \w Silvano|strong="G4610"\w* \w y|strong="G2532"\w* \w Timoteo|strong="G5095"\w*, \w a|strong="G1722"\w* \w la|strong="G3588"\w* \w iglesia|strong="G1577"\w* \w de|strong="G1722"\w* \add los\add* \w tesalonicenses|strong="G2331"\w* \w en|strong="G1722"\w* \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Padre|strong="G3962"\w* \w y|strong="G2532"\w* \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w*:  
\v 2 \w Gracia|strong="G5485"\w* \w y|strong="G2532"\w* \w paz|strong="G1515"\w* a ustedes de \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Padre|strong="G3962"\w* \w y|strong="G2532"\w* del \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w*.   
\s1 Una justa retribución  
\p
\v 3 Hermanos, tenemos \w que|strong="G3754"\w* dar \w gracias|strong="G2168"\w* \w a|strong="G1519"\w* \w Dios|strong="G2316"\w* \w siempre|strong="G3842"\w* \w por|strong="G1519"\w* ustedes \w como|strong="G2531"\w* es apropiado, \w pues|strong="G2532"\w* \w su|strong="G3588"\w* \w fe|strong="G4102"\w* crece maravillosamente \w y|strong="G2532"\w* \w abunda|strong="G4121"\w* \w el|strong="G3588"\w* amor \w de|strong="G4012"\w* \w cada|strong="G1538"\w* \w uno|strong="G1520"\w* \w de|strong="G4012"\w* ustedes \w hacia|strong="G1519"\w* \w los|strong="G3588"\w* \w otros|strong="G3588"\w*,  
\v 4 \w tanto|strong="G5620"\w* \w que|strong="G3588"\w* \w nos|strong="G1438"\w* enaltecemos \w por|strong="G1722"\w* ustedes \w en|strong="G1722"\w* \w las|strong="G3588"\w* \w iglesias|strong="G1577"\w* \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* \w por|strong="G1722"\w* \w su|strong="G3588"\w* \w paciencia|strong="G5281"\w* \w y|strong="G2532"\w* \w fe|strong="G4102"\w* \w en|strong="G1722"\w* medio \w de|strong="G1722"\w* \w todas|strong="G3956"\w* \w las|strong="G3588"\w* \w persecuciones|strong="G1375"\w* \w y|strong="G2532"\w* \w aflicciones|strong="G2347"\w* \w que|strong="G3588"\w* enfrentan,  
\v 5 evidencia \w del|strong="G3588"\w* \w justo|strong="G1342"\w* \w juicio|strong="G2920"\w* \w de|strong="G1519"\w* \w Dios|strong="G2316"\w*, \w para|strong="G1519"\w* \w que|strong="G3588"\w* ustedes sean considerados dignos \w del|strong="G3588"\w* reino \w de|strong="G1519"\w* \w Dios|strong="G2316"\w*, \w por|strong="G5228"\w* \w el|strong="G3588"\w* \w cual|strong="G3739"\w* \w también|strong="G2532"\w* sufren.   
\p
\v 6 \w En|strong="G3844"\w* verdad es \w justo|strong="G1342"\w* \w que|strong="G3588"\w* \w Dios|strong="G2316"\w* retribuya \w aflicción|strong="G2347"\w* \w a|strong="G3844"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w los|strong="G3588"\w* afligen,  
\v 7 \w y|strong="G2532"\w* \w a|strong="G1722"\w* ustedes, \w que|strong="G3588"\w* son afligidos, les da reposo \w con|strong="G3326"\w* \w nosotros|strong="G2249"\w* \w en|strong="G1722"\w* \w la|strong="G3588"\w* manifestación \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* \w Jesús|strong="G2424"\w* desde \w el|strong="G3588"\w* \w cielo|strong="G3772"\w* \w con|strong="G3326"\w* ángeles \w de|strong="G1722"\w* \w su|strong="G3588"\w* \w poder|strong="G1411"\w*,  
\v 8 \w en|strong="G1722"\w* \w llama|strong="G5395"\w* \w de|strong="G1722"\w* \w fuego|strong="G4442"\w* \w para|strong="G1722"\w* castigar \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w no|strong="G3361"\w* \w conocieron|strong="G1492"\w* \w a|strong="G1722"\w* \w Dios|strong="G2316"\w*, \w y|strong="G2532"\w* \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w no|strong="G3361"\w* \w obedecen|strong="G5219"\w* \w a|strong="G1722"\w* \w las|strong="G3588"\w* Buenas Noticias \w de|strong="G1722"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w* \w Jesús|strong="G2424"\w*.   
\p
\v 9 \w Éstos|strong="G3588"\w* sufrirán pena \w de|strong="G3588"\w* eterna ruina lejos \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w presencia|strong="G4383"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* \w y|strong="G2532"\w* \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w gloria|strong="G1391"\w* \w de|strong="G3588"\w* \w su|strong="G3588"\w* poder,  
\v 10 \w cuando|strong="G3752"\w* \w venga|strong="G2064"\w* \w en|strong="G1722"\w* \w aquel|strong="G3588"\w* \w día|strong="G2250"\w* \w para|strong="G1909"\w* ser glorificado \w en|strong="G1722"\w* \w sus|strong="G3588"\w* santos \w y|strong="G2532"\w* ser admirado \w por|strong="G1722"\w* \w todos|strong="G3956"\w* \w los|strong="G3588"\w* \w que|strong="G3754"\w* \w creyeron|strong="G4100"\w*, \w porque|strong="G3754"\w* ustedes \w creyeron|strong="G4100"\w* \w nuestro|strong="G2249"\w* \w testimonio|strong="G3142"\w*.   
\p
\v 11 \w Por|strong="G1722"\w* \w lo|strong="G3588"\w* \w cual|strong="G3739"\w* \w también|strong="G2532"\w* hablamos \w con|strong="G1722"\w* \w Dios|strong="G2316"\w* \w siempre|strong="G3842"\w* \w acerca|strong="G4012"\w* \w de|strong="G4012"\w* ustedes, \w para|strong="G1519"\w* \w que|strong="G3588"\w* \w nuestro|strong="G2249"\w* \w Dios|strong="G2316"\w* \w los|strong="G3588"\w* considere dignos \w del|strong="G3588"\w* llamamiento \w y|strong="G2532"\w* cumpla \w con|strong="G1722"\w* \w poder|strong="G1411"\w* \w todo|strong="G3956"\w* deseo \w de|strong="G4012"\w* bondad \w y|strong="G2532"\w* \w obra|strong="G2041"\w* \w de|strong="G4012"\w* \w fe|strong="G4102"\w*,  
\v 12 \w para|strong="G3704"\w* \w que|strong="G3588"\w* \w el|strong="G3588"\w* \w Nombre|strong="G3686"\w* \w de|strong="G1722"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w* \w Jesús|strong="G2424"\w* \w sea|strong="G3588"\w* glorificado \w en|strong="G1722"\w* ustedes, \w y|strong="G2532"\w* ustedes \w en|strong="G1722"\w* \w Él|strong="G3588"\w*, \w según|strong="G2596"\w* \w la|strong="G3588"\w* \w gracia|strong="G5485"\w* \w de|strong="G1722"\w* \w nuestro|strong="G2249"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w*.   
\c 2  
\s1 La manifestación del Anticristo  
\p
\v 1 \w Pero|strong="G1161"\w* \w con|strong="G1909"\w* respecto \w a|strong="G1909"\w* \w la|strong="G3588"\w* \w venida|strong="G3952"\w* \w de|strong="G1909"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w* \w y|strong="G2532"\w* \w nuestra|strong="G3588"\w* reunión \w con|strong="G1909"\w* \w Él|strong="G3588"\w*, \w les|strong="G1909"\w* \w rogamos|strong="G2065"\w*, hermanos,  
\v 2 \w que|strong="G3754"\w* \w no|strong="G3361"\w* se muevan \w fácilmente|strong="G5030"\w* \w del|strong="G3588"\w* \w entendimiento|strong="G3563"\w*, \w ni|strong="G3366"\w* sean perturbados \w por|strong="G1223"\w* \w espíritu|strong="G4151"\w*, \w ni|strong="G3366"\w* \w por|strong="G1223"\w* \w palabra|strong="G3056"\w*, \w ni|strong="G3366"\w* \w por|strong="G1223"\w* \w epístola|strong="G1992"\w* \w como|strong="G5613"\w* \add si fuera\add* \w de|strong="G1519"\w* \w nosotros|strong="G2249"\w*, \w en|strong="G1519"\w* \w el|strong="G3588"\w* \w sentido|strong="G3563"\w* \w de|strong="G1519"\w* \w que|strong="G3754"\w* \w el|strong="G3588"\w* \w día|strong="G2250"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* llegó.   
\p
\v 3 ¡\w Que|strong="G3754"\w* \w nadie|strong="G3367"\w* \w los|strong="G3588"\w* \w engañe|strong="G1818"\w* \w en|strong="G2596"\w* \w ninguna|strong="G3367"\w* \w manera|strong="G5158"\w*! \w Pues|strong="G2532"\w* \add no sucederá\add* \w si|strong="G1437"\w* \w la|strong="G3588"\w* apostasía \w no|strong="G3361"\w* \w viene|strong="G2064"\w* \w primero|strong="G4413"\w*, \w y|strong="G2532"\w* \w se|strong="G2532"\w* manifiesta \w el|strong="G3588"\w* hombre \w de|strong="G2596"\w* iniquidad, \w el|strong="G3588"\w* \w hijo|strong="G5207"\w* \w de|strong="G2596"\w* destrucción,  
\v 4 \w el|strong="G3588"\w* oponente \w que|strong="G3754"\w* \w se|strong="G1438"\w* levanta \w contra|strong="G1909"\w* \w todo|strong="G3956"\w* \w lo|strong="G3588"\w* \w que|strong="G3754"\w* es \w llamado|strong="G3004"\w* \w Dios|strong="G2316"\w* \w o|strong="G2228"\w* es objeto \w de|strong="G1909"\w* adoración, \w hasta|strong="G1519"\w* \w el|strong="G3588"\w* punto \w de|strong="G1909"\w* tomar asiento \w en|strong="G1519"\w* \w el|strong="G3588"\w* Santuario \w de|strong="G1909"\w* \w Dios|strong="G2316"\w* \w para|strong="G1519"\w* proclamar \w que|strong="G3754"\w* \w él|strong="G3588"\w* mismo es \w Dios|strong="G2316"\w*.   
\p
\v 5 ¿\w No|strong="G3756"\w* recuerdan \w que|strong="G3754"\w* \w les|strong="G4314"\w* \w decía|strong="G3004"\w* \w estas|strong="G3778"\w* cosas cuando yo estaba \w aún|strong="G2089"\w* \w con|strong="G4314"\w* ustedes?   
\p
\v 6 \w Ahora|strong="G3568"\w* \w saben|strong="G1492"\w* \w lo|strong="G3588"\w* \w que|strong="G3588"\w* \add lo\add* detiene, \w a|strong="G1519"\w* fin \w de|strong="G1722"\w* \w que|strong="G3588"\w* \w sea|strong="G3588"\w* revelado \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w tiempo|strong="G2540"\w* \w de|strong="G1722"\w* \w él|strong="G3588"\w*.  
\v 7 \w Porque|strong="G1063"\w* \w ya|strong="G2235"\w* \w se|strong="G1096"\w* mueve \w el|strong="G3588"\w* \w misterio|strong="G3466"\w* \w de|strong="G1537"\w* \w la|strong="G3588"\w* iniquidad. \w En|strong="G1537"\w* \w el|strong="G3588"\w* tiempo presente \w está|strong="G3588"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* \add lo\add* detiene, \w hasta|strong="G2193"\w* \w que|strong="G3588"\w* \w sea|strong="G1096"\w* quitado \w de|strong="G1537"\w* \w en|strong="G1537"\w* \w medio|strong="G3319"\w*.   
\p
\v 8 \w Entonces|strong="G5119"\w* \w se|strong="G2532"\w* manifestará \w el|strong="G3588"\w* inicuo, a \w quien|strong="G3739"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w* matará \w con|strong="G2532"\w* \w el|strong="G3588"\w* aliento \w de|strong="G3588"\w* \w su|strong="G3588"\w* \w boca|strong="G4750"\w*, \w y|strong="G2532"\w* \add lo\add* reducirá a \w la|strong="G3588"\w* impotencia \w con|strong="G2532"\w* \w la|strong="G3588"\w* gloria \w de|strong="G3588"\w* \w su|strong="G3588"\w* \w venida|strong="G3952"\w*.  
\v 9 \w La|strong="G3588"\w* \w venida|strong="G3952"\w* \add del inicuo\add* \w es|strong="G3739"\w* \w por|strong="G1722"\w* \w operación|strong="G1753"\w* \w de|strong="G1722"\w* \w Satanás|strong="G4567"\w*, \w con|strong="G1722"\w* \w toda|strong="G3956"\w* clase \w de|strong="G1722"\w* poderes, \w señales|strong="G4592"\w* milagrosas \w y|strong="G2532"\w* \w prodigios|strong="G5059"\w* falsos,  
\v 10 \w y|strong="G2532"\w* \w con|strong="G1722"\w* \w todo|strong="G3956"\w* engaño \w de|strong="G1722"\w* iniquidad \w para|strong="G1519"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w se|strong="G1438"\w* pierden, \w porque|strong="G2532"\w* \w no|strong="G3756"\w* aceptaron \w el|strong="G3588"\w* amor \w a|strong="G1519"\w* \w la|strong="G3588"\w* verdad \w para|strong="G1519"\w* ser \w salvos|strong="G4982"\w*.   
\p
\v 11 \w Por|strong="G1223"\w* \w esto|strong="G3778"\w* \w Dios|strong="G2316"\w* \w les|strong="G1519"\w* \w envía|strong="G3992"\w* \w una|strong="G3588"\w* \w operación|strong="G1753"\w* engañosa \w para|strong="G1519"\w* \w que|strong="G3588"\w* \w ellos|strong="G3588"\w* \w crean|strong="G4100"\w* \w en|strong="G1519"\w* \w la|strong="G3588"\w* \w mentira|strong="G5579"\w*,  
\v 12 \w a|strong="G2443"\w* fin \w de|strong="G3588"\w* \w que|strong="G3588"\w* sean juzgados \w todos|strong="G3956"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w no|strong="G3361"\w* \w creyeron|strong="G4100"\w* \w en|strong="G3588"\w* \w la|strong="G3588"\w* verdad, \w sino|strong="G3361"\w* se deleitaron \w en|strong="G3588"\w* \w la|strong="G3588"\w* injusticia.   
\s1 Escogidos para salvación  
\p
\v 13 Hermanos amados \w por|strong="G1722"\w* \add el\add* \w Señor|strong="G2962"\w*, \w nosotros|strong="G2249"\w* tenemos \w que|strong="G3754"\w* dar \w gracias|strong="G2168"\w* \w siempre|strong="G3842"\w* \w a|strong="G1519"\w* \w Dios|strong="G2316"\w* \w por|strong="G1722"\w* ustedes, \w pues|strong="G1161"\w* desde \w el|strong="G3588"\w* principio \w Él|strong="G3588"\w* \w los|strong="G3588"\w* escogió \w para|strong="G1519"\w* \w salvación|strong="G4991"\w* \w por|strong="G1722"\w* medio \w de|strong="G4012"\w* \w la|strong="G3588"\w* santificación \w del|strong="G3588"\w* \w espíritu|strong="G4151"\w* \w y|strong="G2532"\w* \w fe|strong="G4102"\w* \w en|strong="G1722"\w* \w la|strong="G3588"\w* \w verdad|strong="G4102"\w*.  
\v 14 \w A|strong="G1519"\w* \w esto|strong="G3739"\w* \w los|strong="G3588"\w* \w llamó|strong="G2564"\w* \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1519"\w* nuestras Buenas Noticias \w para|strong="G1519"\w* \w que|strong="G3588"\w* obtengan \w la|strong="G3588"\w* \w gloria|strong="G1391"\w* \w de|strong="G1519"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w*.   
\p
\v 15 \w Así|strong="G2532"\w* \w que|strong="G3588"\w*, hermanos, estén \w firmes|strong="G4739"\w* \w y|strong="G2532"\w* retengan \w las|strong="G3588"\w* \w tradiciones|strong="G3862"\w* \w como|strong="G2532"\w* \w las|strong="G3588"\w* enseñamos, bien \w por|strong="G1223"\w* \w palabra|strong="G3056"\w* \w o|strong="G1535"\w* \w por|strong="G1223"\w* \w epístola|strong="G1992"\w* \w nuestra|strong="G3588"\w*.   
\p
\v 16 \w El|strong="G3588"\w* mismo \w Señor|strong="G2962"\w* \w nuestro|strong="G2249"\w*, \w Jesucristo|strong="G2424"\w*, \w y|strong="G2532"\w* \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Padre|strong="G3962"\w*, \w Quien|strong="G3588"\w* \w nos|strong="G2316"\w* \w amó|strong="G2962"\w* \w y|strong="G2532"\w* \w nos|strong="G2316"\w* \w dio|strong="G1325"\w* \w consolación|strong="G3874"\w* eterna \w y|strong="G2532"\w* buena \w esperanza|strong="G1680"\w* \w por|strong="G1722"\w* \w gracia|strong="G5485"\w*,  
\v 17 \w consuele|strong="G3870"\w* \w y|strong="G2532"\w* \w confirme|strong="G4741"\w* \w sus|strong="G3588"\w* \w corazones|strong="G2588"\w* \w en|strong="G1722"\w* \w toda|strong="G3956"\w* \w obra|strong="G2041"\w* \w y|strong="G2532"\w* buena \w palabra|strong="G3056"\w*.   
\c 3  
\s1 Petición especial de Pablo  
\p
\v 1 \w Por|strong="G4012"\w* \w lo|strong="G3588"\w* \w demás|strong="G3063"\w*, hermanos, hablen \w con|strong="G4314"\w* \w Dios|strong="G2962"\w* \w con|strong="G4314"\w* \w respecto|strong="G4012"\w* \w a|strong="G4314"\w* \w nosotros|strong="G2249"\w* \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w la|strong="G3588"\w* \w Palabra|strong="G3056"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* \w corra|strong="G5143"\w* \w y|strong="G2532"\w* \w sea|strong="G3588"\w* magnificada, \w como|strong="G2531"\w* \w también|strong="G2532"\w* \add ocurrió\add* \w con|strong="G4314"\w* ustedes,  
\v 2 \w y|strong="G2532"\w* \w para|strong="G2443"\w* \w que|strong="G3588"\w* seamos \w librados|strong="G4506"\w* \w de|strong="G3588"\w* \w los|strong="G3588"\w* hombres perversos \w y|strong="G2532"\w* \w malos|strong="G4190"\w*, \w porque|strong="G1063"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w no|strong="G3756"\w* \w es|strong="G3756"\w* \w de|strong="G3588"\w* \w todos|strong="G3956"\w*.   
\p
\v 3 \w Pero|strong="G1161"\w* \w fiel|strong="G4103"\w* \w es|strong="G3739"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w*, \w Quien|strong="G3739"\w* \w los|strong="G3588"\w* afianzará \w y|strong="G2532"\w* protegerá \w del|strong="G3588"\w* \w malo|strong="G4190"\w*.  
\v 4 Ponemos la confianza \w en|strong="G1722"\w* \w el|strong="G3739"\w* \w Señor|strong="G2962"\w* \w con|strong="G1722"\w* respecto \w a|strong="G1909"\w* ustedes, \w que|strong="G3754"\w* \w hacen|strong="G4160"\w* \w y|strong="G2532"\w* \w harán|strong="G4160"\w* \w lo|strong="G3739"\w* \w que|strong="G3754"\w* mandamos.  
\v 5 \w El|strong="G3588"\w* \w Señor|strong="G2962"\w* dirija \w sus|strong="G3588"\w* \w corazones|strong="G2588"\w* \w al|strong="G3588"\w* amor \w de|strong="G1519"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w a|strong="G1519"\w* \w la|strong="G3588"\w* \w paciencia|strong="G5281"\w* \w de|strong="G1519"\w* \w Cristo|strong="G5547"\w*.   
\s1 Contra el desorden  
\p
