\v 3 \wj \+w El|strong="G3588"\+w* \+w portero|strong="G2377"\+w* \+w le|strong="G2596"\+w* abre \+w y|strong="G2532"\+w* \+w las|strong="G3588"\+w* \+w ovejas|strong="G4263"\+w* oyen \+w su|strong="G3588"\+w* \+w voz|strong="G5456"\+w*. \+w Llama|strong="G5455"\+w* \+w a|strong="G2596"\+w* \+w sus|strong="G3588"\+w* \+w ovejas|strong="G4263"\+w* \+w por|strong="G2596"\+w* \+w nombre|strong="G3686"\+w* \+w y|strong="G2532"\+w* \+w las|strong="G3588"\+w* \+w saca|strong="G1806"\+w*.\wj*  
