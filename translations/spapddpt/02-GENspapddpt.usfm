\v 15 \w Cuando|strong="H3588"\w* \w los|strong="H3605"\w* hermanos \w de|strong="H3588"\w* \w José|strong="H3130"\w* \w vieron|strong="H7200"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* padre \w murió|strong="H4191"\w*, dijeron: Quizás \w José|strong="H3130"\w* nos guarde rencor \w y|strong="H3588"\w* nos devuelva \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w mal|strong="H7451"\w* \w que|strong="H3588"\w* le hicimos.  
\v 16 Entonces \w mandaron|strong="H6680"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* \w José|strong="H3130"\w*: Tu padre dio órdenes \w antes|strong="H6440"\w* \w de|strong="H6440"\w* su \w muerte|strong="H4194"\w*:   
\p
\v 17 \w Así|strong="H3541"\w* dirán \w a|strong="H3068"\w* \w José|strong="H3130"\w*: \w Te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* \w perdones|strong="H5375"\w* \w la|strong="H3588"\w* transgresión \w de|strong="H3588"\w* tus hermanos \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w pecado|strong="H2403"\w*, \w pues|strong="H3588"\w* ellos \w te|strong="H3588"\w* \w hicieron|strong="H1058"\w* \w mal|strong="H7451"\w*. \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, \w te|strong="H3588"\w* rogamos \w que|strong="H3588"\w* \w perdones|strong="H5375"\w* \w la|strong="H3588"\w* transgresión \w de|strong="H3588"\w* \w los|strong="H3588"\w* esclavos del \nd ʼElohim\nd* \w de|strong="H3588"\w* tu padre. \w Y|strong="H3068"\w* \w José|strong="H3130"\w* \w lloraba|strong="H1058"\w* \w mientras|strong="H3588"\w* \w hablaban|strong="H1696"\w* \w con|strong="H3588"\w* \w él|strong="H3588"\w*.   
\p
\v 18 \w Entonces|strong="H1571"\w* sus hermanos se acercaron, se postraron \w ante|strong="H6440"\w* \w él|strong="H5307"\w* \w y|strong="H1571"\w* dijeron: ¡\w Aquí|strong="H2009"\w* estamos \w como|strong="H1571"\w* esclavos tuyos!   
\p
\v 19 \w Pero|strong="H3588"\w* \w José|strong="H3130"\w* les respondió: \w No|strong="H3588"\w* \w teman|strong="H3372"\w*. ¿Estoy \w yo|strong="H3588"\w* \w en|strong="H3588"\w* \w lugar|strong="H8478"\w* \w de|strong="H3588"\w* \nd ʼElohim\nd*?  
\v 20 Aunque ustedes \w pensaron|strong="H2803"\w* \w mal|strong="H7451"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*, \nd ʼElohim\nd* \w lo|strong="H2088"\w* encaminó \w para|strong="H4616"\w* \w bien|strong="H2896"\w* \w al|strong="H5921"\w* producir \w el|strong="H5921"\w* presente resultado \w para|strong="H4616"\w* preservar \w viva|strong="H2421"\w* \w a|strong="H3068"\w* \w mucha|strong="H7227"\w* \w gente|strong="H5971"\w*.  
\v 21 \w Así|strong="H6258"\w* \w que|strong="H6258"\w*, \w no|strong="H5921"\w* \w teman|strong="H3372"\w*. Yo \w los|strong="H5921"\w* sustentaré \w a|strong="H3068"\w* ustedes \w y|strong="H5921"\w* \w a|strong="H3068"\w* sus pequeños. \w Así|strong="H6258"\w* \w los|strong="H5921"\w* consoló \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w habló|strong="H1696"\w* \w al|strong="H5921"\w* \w corazón|strong="H3820"\w*.   
\p
\v 22 \w Así|strong="H1931"\w* \w que|strong="H1931"\w* \w José|strong="H3130"\w* y \w la|strong="H1931"\w* \w familia|strong="H1004"\w* de \w su|strong="H1931"\w* padre permanecieron en \w Egipto|strong="H4714"\w*. \w Y|strong="H3068"\w* \w José|strong="H3130"\w* \w vivió|strong="H2421"\w* 110 \w años|strong="H8141"\w*.  
\v 23 \w José|strong="H3130"\w* \w vio|strong="H7200"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Efraín \w hasta|strong="H5921"\w* \w la|strong="H5921"\w* tercera generación. \w También|strong="H1571"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Maquir, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Manasés|strong="H4519"\w*, \w nacieron|strong="H3205"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w rodillas|strong="H1290"\w* \w de|strong="H5921"\w* \w José|strong="H3130"\w*.   
\s1 Última voluntad de José  
\p
\v 24 Después \w José|strong="H3130"\w* dijo \w a|strong="H3068"\w* sus hermanos: \w Yo|strong="H4480"\w* voy \w a|strong="H3068"\w* \w morir|strong="H4191"\w*, pero \nd ʼElohim\nd* \w ciertamente|strong="H4191"\w* los \w visitará|strong="H6485"\w* y los hará \w subir|strong="H5927"\w* \w de|strong="H4480"\w* \w esta|strong="H2063"\w* tierra \w a|strong="H3068"\w* \w la|strong="H2063"\w* tierra \w que|strong="H4480"\w* \w juró|strong="H7650"\w* dar \w a|strong="H3068"\w* Abraham, \w a|strong="H3068"\w* \w Isaac|strong="H3327"\w* y \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*.  
\v 25 Entonces \w José|strong="H3130"\w* juramentó \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*: \nd ʼElohim\nd* \w ciertamente|strong="H6485"\w* \w los|strong="H1121"\w* \w visitará|strong="H6485"\w*. Entonces ustedes harán \w subir|strong="H5927"\w* \w de|strong="H1121"\w* \w aquí|strong="H2088"\w* mis \w huesos|strong="H6106"\w*.   
\p
\v 26 \w José|strong="H3130"\w* \w murió|strong="H4191"\w* \w a|strong="H3068"\w* la \w edad|strong="H8141"\w* \w de|strong="H1121"\w* 110 \w años|strong="H8141"\w*. Lo \w embalsamaron|strong="H2590"\w* y fue puesto en un ataúd en \w Egipto|strong="H4714"\w*.   