\q1 
\v 17 Oh \w Fortaleza|strong="H5797"\w* mía, \w te|strong="H3588"\w* \w cantaré|strong="H7891"\w* salmos.
\q1 \w Porque|strong="H3588"\w* Tú, \nd ʼElohim\nd*, \w eres|strong="H1961"\w* \w Fortaleza|strong="H5797"\w*,
