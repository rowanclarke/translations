\b
\iex (We have not yet translated chapter 6. It says that the Philistia mob sent God’s special box back to Israel, to a place called Kiriath-Jearim.)
\c 7
\s1 God rescued the Israel mob at Mizpah
\p 
\v 1 \w The|strong="H8104"\w* \w Kiriath-Jearim|strong="H7157"\w* mob \w took|strong="H5927"\w* \w God|strong="H3068"\w*’s special box \w back|strong="H5927"\w* \w to|strong="H3068"\w* \w their|strong="H3068"\w* country, \w to|strong="H3068"\w* \w the|strong="H8104"\w* \w house|strong="H1004"\w* \w of|strong="H1121"\w* \w a|strong="H3068"\w* \w man|strong="H1121"\w* called Abinadab. \w That|strong="H3068"\w* \w house|strong="H1004"\w* \w stood|strong="H3068"\w* \w on|strong="H3068"\w* \w the|strong="H8104"\w* top \w of|strong="H1121"\w* \w a|strong="H3068"\w* \w hill|strong="H1389"\w*. \w And|strong="H1121"\w* \w they|strong="H3068"\w* picked \w his|strong="H8104"\w* \w son|strong="H1121"\w* Eleazar \w to|strong="H3068"\w* \w look|strong="H3068"\w* \w after|strong="H5927"\w* \w that|strong="H3068"\w* box.\x * \xo 7:1 \xt 2 Samuel 6:2-4; 1 Chronicles 13:5-7\x*
\v 2 \w God|strong="H3068"\w*’s special box \w stood|strong="H3068"\w* \w there|strong="H1961"\w* \w at|strong="H3427"\w* \w that|strong="H3605"\w* \w house|strong="H1004"\w* \w for|strong="H3068"\w* 20 \w years|strong="H8141"\w*.
\p \w All|strong="H3605"\w* \w that|strong="H3605"\w* \w time|strong="H3117"\w* \w the|strong="H3605"\w* \w Israel|strong="H3478"\w* mob felt sad. \w They|strong="H3117"\w* thought \w God|strong="H3068"\w* \w left|strong="H1961"\w* \w them|strong="H1961"\w*, \w so|strong="H1961"\w* \w they|strong="H3117"\w* \w kept|strong="H1961"\w* \w on|strong="H3117"\w* asking \w him|strong="H3605"\w* \w to|strong="H3478"\w* \w help|strong="H1961"\w* \w them|strong="H1961"\w*.
\v 3 \w Then|strong="H7725"\w* \w Samuel|strong="H8050"\w* asked \w them|strong="H7725"\w*, “\w Is|strong="H3068"\w* \w it|strong="H8432"\w* \w true|strong="H3068"\w* \w that|strong="H3605"\w* \w you|strong="H3605"\w* mob want \w to|strong="H7725"\w* \w turn|strong="H7725"\w* \w back|strong="H7725"\w* \w to|strong="H7725"\w* \w God|strong="H3068"\w*? Well, \w you|strong="H3605"\w* \w have|strong="H3068"\w* \w to|strong="H7725"\w* \w do|strong="H5647"\w* \w this|strong="H7725"\w*. Throw \w away|strong="H5493"\w* \w all|strong="H3605"\w* \w those|strong="H3605"\w* statues \w made|strong="H3559"\w* \w of|strong="H1004"\w* wood \w and|strong="H3478"\w* stone. Throw \w away|strong="H5493"\w* \w those|strong="H3605"\w* statues \w of|strong="H1004"\w* women called Astarti. \w Those|strong="H3605"\w* \w things|strong="H3605"\w* \w do|strong="H5647"\w* \w not|strong="H7725"\w* belong \w to|strong="H7725"\w* \w us|strong="H7725"\w* \w Israel|strong="H3478"\w* mob. \w They|strong="H3068"\w* \w are|strong="H3478"\w* \w from|strong="H7725"\w* \w another|strong="H8432"\w* \w place|strong="H3027"\w*. \w You|strong="H3605"\w* mob \w have|strong="H3068"\w* \w to|strong="H7725"\w* show respect \w only|strong="H3605"\w* \w to|strong="H7725"\w* \w God|strong="H3068"\w*. \w Turn|strong="H7725"\w* \w back|strong="H7725"\w* \w to|strong="H7725"\w* \w him|strong="H3027"\w*. \w Give|strong="H7725"\w* \w yourselves|strong="H3027"\w* \w only|strong="H3605"\w* \w to|strong="H7725"\w* \w him|strong="H3027"\w*. If \w you|strong="H3605"\w* \w do|strong="H5647"\w* \w that|strong="H3605"\w*, \w he|strong="H3068"\w* \w will|strong="H3068"\w* \w save|strong="H5337"\w* \w you|strong="H3605"\w* \w from|strong="H7725"\w* \w the|strong="H3605"\w* Philistia mob.”
\v 4 \w So|strong="H5493"\w* \w the|strong="H5647"\w* \w Israel|strong="H3478"\w* mob listened \w to|strong="H3478"\w* \w him|strong="H5647"\w* \w and|strong="H1121"\w* threw \w away|strong="H5493"\w* \w all|strong="H3068"\w* \w those|strong="H1121"\w* \w things|strong="H3478"\w*, \w those|strong="H1121"\w* statues \w like|strong="H3478"\w* \w men|strong="H1121"\w* called \w Baal|strong="H1168"\w* \w and|strong="H1121"\w* \w those|strong="H1121"\w* other statues \w like|strong="H3478"\w* women called Astarti. \w And|strong="H1121"\w* \w they|strong="H3068"\w* \w turned|strong="H5493"\w* \w back|strong="H5493"\w* \w to|strong="H3478"\w* \w God|strong="H3068"\w* \w and|strong="H1121"\w* showed respect only \w to|strong="H3478"\w* \w him|strong="H5647"\w*.
\p 
