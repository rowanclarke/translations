\v 3 \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w provincias|strong="H4082"\w*, \w los|strong="H5921"\w* \tl sátrapas,\tl* \w los|strong="H5921"\w* \w gobernadores|strong="H6346"\w* \w y|strong="H3588"\w* \w los|strong="H5921"\w* funcionarios menores \w del|strong="H5921"\w* \w rey|strong="H4428"\w* apoyaban \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w judíos|strong="H3064"\w*, \w pues|strong="H3588"\w* \w el|strong="H5921"\w* \w temor|strong="H6343"\w* \w a|strong="H3068"\w* Mardoqueo \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*.
