\id TIT Ika New Testament 2009 
\h Taịtọsị 
\toc1 Ẹhụhụọ-Ozi Pọlụ Dejẹnni Taịtọsị 
\toc2 Taịtọsị 
\toc3 Taị 
\mt2 Ẹhụhụọ-Ozi Pọlụ Dejẹnni 
\mt1 Taịtọsị 
\c 1  
\cl Isi Nke Ohu 
\p  
\v 1 Mmẹ wụ Pọlụ de ẹhụhụọ-ozini. M wụ igbọn Osolobuẹ; m wụzịkwọ onyẹ-ozi pụ-ichẹn Jizọs' Kraịstị. Ọrụn m wụ ịkwadọn okukwe ndị hụ Osolobuẹ họrị, kẹn'ọ gha ihun, lẹ imẹ ịhịan marịn ezioku ahụn k'e mẹ wẹ femẹ Osolobuẹ k'o furu.  
\v 2 M rị a rụn kẹni wẹ nwẹhẹn ihiẹn ahụn ẹnyi rị e lee ẹnya a: ndụn itẹbitẹ ahụn Osolobuẹ ghalẹni a tụ ntụ kwe nkwa a nị ogẹn d'e bidọndẹ,  
\v 3 o ru nwan ogẹn o tumẹ, ọ nọ nwan wepụha ihiẹn o ku ifọn ghahanị ozini ya wụ Osolobuẹ Onyẹ-nzụọpụha-ẹnyi ye m zisọnmẹ. 
\p  
\v 4 M rị e dejẹnni Taịtọsị, hụn wụ ezigbo nwa m imẹ okukwe ẹnyi. Ẹfọma lẹ udọn, hụn gha ẹka Osolobuẹ Nẹdi ẹnyi lẹ Kraịstị wụ Jizọsị Onyẹ-nzụọpụha ẹnyi a bịa, ya rịn'ị. 
\s1 Ọrụn Taịtọsị K'a Rụn 
\p  
\v 5 Ihiẹn haịn m gi na ị tọ alị Kriti wụ n'ị hụn ụzọ dọnkwama ihiẹn ndị họdụnị lẹ n'i hụn ụzọ tumẹsọnmẹ ndị-ndu ụka imẹ obodo ọwụlẹ kẹ m dọn gwa ị. 
\s1 Ndị-isi Ụka 
\p  
\v 6 Onyẹ-isi ụka k'a wụrịrị onyẹ nwọnlẹni nkọrịanị. O k'a wụrịrị onyẹ nwọn nwunyẹ ohu sụọ; onyẹ ụmụ a wụ ndị kwerini—ndị hụn o mẹ ni o nwọnni onyẹ k'a s'ẹka kpọ wẹ ndị e mẹ ihiẹn-ifẹnrẹn lẹ ndị isi-ikẹn. 
\p  
\v 7 Ebe o mẹ ni onyẹ-isi ụka e lefụ ọrụn Osolobuẹ ẹnya, o furuni n'o nwọn nkọrịanị. Ọ wụkọ onyẹ ghalẹni a nị ndị ọzọ e kuye mọbụ onyẹ e bukẹnrin olulu mọbụ onyẹ-manya mọbụ onyẹ ẹka-ikẹn mọbụ onyẹ e gi ẹnya-naị a chọ egho. 
\p  
\v 8 Kama, o k'a wụrịrị onyẹ ma nabanhan ndị ọbịa; onyẹ ihiẹn rị mma a sụọ; onyẹ e leban ihiẹn ẹnya, e gi uche e mẹ ihiẹn; onyẹ kụma enwẹn ẹ ọtọ; onyẹ rị nsọ, onyẹ e kwọndọn enwẹn ẹ. 
\p  
\v 9 O k'a marịnrịrị ẹnya nkuzi ahụn furu w'a tụkwasị obi hụn rị okukwe ẹnyi, marịn kẹ wẹ dọn a kuzi ẹ, kẹni ọ saẹka gi nkuzi zu oke a kpasu obi ndị ọzọ, e gi ẹ a ghọzịkwọ ndị hụn a papụ nkuzi ahụn nị wẹ rị e mẹfie. 
\p  
\v 10 Makẹni ndị rị a gba isi-akwanran ebe ezigbo-nkuzi rị lẹ ndị e ku mpụ lẹ ndị-ndufie bu ọda, tụmadụ ndị hụn a kwadọn ịkwa-ugun. 
\p  
\v 11 O furu ni wẹ kpukin wẹ ọnụ! Makẹni, wẹ rị e gi ihiẹn ahụn furulẹni wẹ gi ifiri egho a kuzi a sụkpọsọnmẹ ikpun-ụnọ. 
\p  
\v 12 Onyẹ Kriti ibe wẹ hụn e deni e kugụọd'a, sị, “Ndị Kriti wụ ndị-ntụ; ezigbo eje-anụ kẹ wẹ wụ, ndị okẹn ihiẹn-oriri, ndị ghalẹni e ri-ẹka a rụn ihiẹn ọwụlẹ.”  
\v 13 Ihiẹnni o ku wụ ezioku. Gi ifiri ẹ a jụgbọ wẹ ọhụnma-ọhụnma, kẹni wẹ hụn ụzọ turu ọhụnma imẹ okukwe,  
\v 14 gọnbehi ilu ndị Ju ntịn, mẹbehi ihiẹn ndị gbakịtọgụụ ezioku azụụn sị wẹ e mẹ. 
\p  
\v 15 Ndị rụlẹni e weri ẹ nị ihiẹn ile rị ụchan, kanị, nke ndị rụnị, hụn kwerilẹni, ihiẹn ile rụ-arụ ebe wẹ rị: kẹ uche wẹ kẹ ịhọrị wẹ rụchanrịndẹ arụ.  
\v 16 Wẹ sị n'a marịnghọ wẹ Osolobuẹ, kanị wẹ e gi ihiẹn w'e mẹ a ghọsị n'a marịn w'a. Wẹ wụ ihiẹn izize; wẹ a gba isi-akwanran; o nwọnni ọrụn-ọma wẹ furu ịrụnnị. 
\c 2  
\cl Isi Nke Ẹbụọ 
\s1 Ihiẹn Wẹ K'a Kuzi Ndị Rị Ichẹn-ichẹn 
\p  
\v 1 Kanị ịyụ nwẹn, i k'a kuzirịrị ihiẹn ya lẹ nkuzi kụrụ-ọtọ wụ ohu. 
\p  
\v 2 Kuzi ikẹnnyẹ-ọba w'e bukẹnrinlẹ olulu; wẹ wụrụ ndị ghalẹni e gi ihiẹn wẹ buche wẹ ẹka e gu egu, ndị e kwọndọn enwẹn wẹ, ndị zeni imẹ okukwe lẹ ihiẹn-ọsụsụọ lẹ ndidi. 
\p  
\v 3 Kuzizịkwọ ikpoho-ọba nị wẹ e bi obibi furu ndị rị nsọ e bi; wẹ e mẹlẹ ndị-nkutọ, w'e mẹlẹ igbọn manya; kama, wẹ wụrụ ndị a kuzi ndị ọzọ ihiẹn rị mma—  
\v 4 kẹni wẹ s'ẹka e mẹ ikpoho rị wẹ ebe alị mụnrụn kẹ w'a dọn nwẹ ihiẹn-ọsụsụọ di wẹ lẹ ụmụ wẹ,  
\v 5 wụrụ ndị e kwọndọn enwẹn wẹ, ndị e dọnmẹ enwẹn wẹ, ndị ma bi obi-ụlọ, ndị ẹfọma, ndị e we enwẹn wẹ e che okpuru di wẹ—amamgbe ịhịan e kutọ oku Osolobuẹ. 
\p  
\v 6 Ẹrịrazịkwọ, kuzi ikorọbịa nị wẹ wụrụ ndị e kwọndọn enwẹn wẹ. 
\p  
\v 7 Gi enwẹn i hẹnrin ihiẹn wẹ e leri ebe ọrụn-ọma ọwụlẹ rị. Ebe nkuzi i rị, wụrụ onyẹ ezioku lẹ onyẹ ghalẹni e gi nkuzi e gu egu.  
\v 8 E gi oku kụrụ-ọtọ nwọnlẹni nkọrịanị a kuzi, kẹni ifẹnrẹn mẹ ndị iṅẹnrẹn makẹni ahụnnị wẹ eje-ihiẹn wẹ e gi kuja oku ẹnyi. 
\p  
\v 9 Kuzi ndị-idibo lẹ ndị rị okpuru ịhịan wẹ e humẹni ndị wẹ rị okpuru wẹ isi; sị wẹ a lịlịma nị wẹ e mẹ ihiẹn a sụọ ndị hụ wẹ rị okpuru wẹ. W'a shịagwarịlẹ wẹ oku.  
\v 10 W'e zunlẹ wẹ ohin. Kama, wẹ ghọsịchanrịn nị wẹ wụ ndị furu wẹ gi e dọn-ẹnya ogẹn ile, kẹni wẹ gi obibi wẹ e mẹ nkuzi Osolobuẹ Onyẹ-nzụọfụha ẹnyi a wụrụ ihiẹn a la ẹnya. 
\p  
\v 11 Makẹni, ẹfọma Osolobuẹ hụn e wẹhẹ nzụọpụha a pụhagụọnị ịhịan ile.  
\v 12 Ẹfọma hụ a kuzi ẹnyi ịjụ obibi rịlẹni mma ẹnya Osolobuẹ lẹ ihiẹn-ọlịla-ẹnya ụwanị, igi uche e bi, ibi obibi kụrụ-ọtọ lẹ ịtụ egun Osolobuẹ—hụnnị ẹnyi rị eluni,  
\v 13 kẹ ẹnyi dọn rị e che okẹn-ngọzi ahụn ẹnyi rị e lee ẹnya a, hụn wụ ọbịbịa Osolobuẹ uku ẹnyi wụ Jizọsị Kraịstị Onyẹ-nzụọpụha ẹnyi jẹnkọ d'e gi ọghọ bịa.  
\v 14 Jizọsị Kraịstị gi ifiri ẹnyi we enwẹn ẹ ye, n'ọ gbafụha ẹnyi imẹ njọ ile, kẹni o gi ẹ chanchanpụhanị enwẹn ẹ ndị k'a wụ nke ẹ, dọn wẹ nsọ, a wụrụchanrịn wẹ ndị ihiẹn rị mma a dụ omumẹ. 
\p  
\v 15 Ya wụ, ihiẹn ndịnị kẹ i k'a gha a kuzi wẹ, a gba wẹ umẹ, a jụgbọ wẹ. E mẹchanrịn wẹ ile rịkẹ onyẹ oku rịchanrịn ẹka. Anịkwọlẹ onyẹ ọwụlẹ legberi i. 
\c 3  
\cl Isi Nke Ẹtọ 
\s1 Obibi Onyẹ Itu-Kraịstị 
\p  
\v 1 Nyanhan nị wẹ nị wẹ e we enwẹn wẹ e che okpuru ndị-ndu lẹ ndị-ọkịkị, wẹ e humẹ isi; wẹ kwademẹ nị wẹ e mẹ ihiẹn ọwụlẹ rị mma.  
\v 2 Gwa wẹ ekutọlẹ onyẹ ọwụlẹ, wẹ e mẹlẹ oku, wẹ wụrụ ndị e mẹ jụụ lẹ ndị e ye onyẹ ọwụlẹ mgbaye.  
\v 3 Makẹni, ẹnyi nwẹn te wụzịkwọ ndị-nzuzu, ndị nnupụ-isi; eje-ihiẹn ndị a gụnnị ẹnyi lẹ ihiẹn a sụọ ụsụọ rị ichẹn-ichẹn te dufiezikwọ ẹnyi, kwọndọn ẹnyi kẹ igbọn. Ẹnyi e te e mẹ ibe ẹnyi eje-ihiẹn, e we iwe-ẹnya, ize ẹnyi hụ e ze ịhịan, ẹnyi hụ e zetarị izize ibe ẹnyi.  
\v 4 Kanị, ogẹn ẹfọma lẹ ihiẹn-ọsụsụọ Osolobuẹ Onyẹ-nzụọpụha ẹnyi gi bịa,  
\v 5 ọ nọ zụọpụha ẹnyi, ẹlẹ ifiri ihiẹn rị mma ẹnyi mẹsọnmẹ, kanị, makẹ omikẹn ẹ. Ọ nọ chanchan ẹnyi ghahanị ịmụdọnzi ni ẹnyi lẹ imẹ ẹnyi wụrụ ndị ọhụn ghahanị Mmọn-nsọ  
\v 6 hụn o ghaha ẹka Jesu Kristi Onyẹ-nzụọfụha ẹnyi hukpu ẹnyi ọhụnma-ọhụnma.  
\v 7 Ya wụ, hụnnị o gigụụ nwan ẹfọma a kuni ẹnyi ọhụnma, ẹnyi e hẹnringụọ ụmụ a hụn nwẹ olile-ẹnya ghalẹni e mẹ ntụ: n'o k'e keye ẹnyi ndụn itẹbitẹ.  
\v 8 Ọnwan wụ ezioku. M chọ ni y'e ku ihiẹn ndịnị, e kushi wẹ ikẹn, kẹni ndị hụn kwerigụụ nị Osolobuẹ dọnrin ẹnya e mẹsọnmẹ ihiẹn rị mma. 
\p Ihiẹn ndịnị a rịka mma, w'a ban nị ịhịan ile erere. 
\p  
\v 9 Kanị, latọ ndọndọ nzuzu lẹ itu-mpupu ihiẹn hụn w'e tusọnmẹ lẹ ndọndọ lẹ ikpe banyeni Iwu Mozizi, makẹni oku ndị hụ wụ ihiẹn la iwi, o nwọnni erere rị imẹ wẹ. 
\p  
\v 10 O mẹ nke onyẹ e kebeni, dọ a ẹka-ntịn nke ibuzọ, y'a dọzị a ya nke ẹbụọ; ọ tọkwọ e mẹ ihiẹn ahụn o mẹ, y'a la a tọ—'yụ lẹ ịya enwẹzilẹ mmẹkọ,  
\v 11 makẹni ya marịnghọ nị uche onyẹ nọ ẹrịra a rụgụọ, nị omẹ-njọ k'ọ wụ; o gigụọ njọ ọ rị e mẹ ma enwẹn ẹ ikpe. 
\s1 Mmẹkin 
\p  
\v 12 Ozigbo m zihẹ n'i Atemasị mọbụ Taịkikọsị, y'a nwan ikẹn i ile n'ị bịa Nịkopolisi d'e kunrun m, makẹni a kwademẹgụọ m obi m nị m k'a nọdị ebẹhụ ogẹn oyini lalanị. 
\p  
\v 13 Mẹ ihiẹn ile i k'a s'ẹka mẹ n'i yeni Ọka-iwu wụ Zẹnasị lẹ Apolọsị ẹka wẹ jẹnkọnị ijẹn wẹ; hụn a n'o nwọnni ihiẹn kọnị wẹ.  
\v 14 Ndị nke ẹnyi wẹ mụnrụn imẹsọnmẹ ihiẹn rị mma, kẹni wẹ saẹka e ye ẹka ogẹn ọwụlẹ ezigbo mkpa gi pụha; w'e bilẹ obibi ghalẹni a ban erere. 
\p  
\v 15 Ndị ile mmẹ lẹ wẹ rị ebeni e zi ekele. Kele ndị ile ihiẹn ẹnyi a sụọ makẹ okukwe ẹnyi. 
\p Ẹfọma Osolobuẹ ya rịnị ọnụ!