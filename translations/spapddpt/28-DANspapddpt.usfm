\v 14 \w En|strong="H5921"\w* \w aquellos|strong="H1992"\w* \w tiempos|strong="H6256"\w* \w se|strong="H5921"\w* levantarán \w muchos|strong="H7227"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w del|strong="H5921"\w* sur. \w Hombres|strong="H1121"\w* violentos \w de|strong="H5921"\w* tu \w pueblo|strong="H5971"\w* \w se|strong="H5921"\w* levantarán \w para|strong="H5921"\w* cumplir \w la|strong="H5921"\w* \w visión|strong="H2377"\w*, pero fracasarán.
\v 15 Vendrá el \w rey|strong="H4428"\w* del \w norte|strong="H6828"\w*, levantará \w baluartes|strong="H5550"\w* y \w tomará|strong="H3920"\w* la \w ciudad|strong="H5892"\w* fortificada. Las \w fuerzas|strong="H3581"\w* del sur \w no|strong="H3808"\w* podrán sostenerse, \w ni|strong="H3808"\w* sus tropas \w escogidas|strong="H4005"\w*, \w porque|strong="H3808"\w* \w no|strong="H3808"\w* \add tendrá\add* \w fuerzas|strong="H3581"\w* \w para|strong="H5971"\w* resistir.
\v 16 \w El|strong="H6213"\w* \w que|strong="H3027"\w* vendrá \w contra|strong="H6440"\w* \w él|strong="H6213"\w* \w hará|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H3027"\w* quiera, y \w no|strong="H6213"\w* \w habrá|strong="H5975"\w* \w quien|strong="H6213"\w* se le \add pueda\add* enfrentar. \w Permanecerá|strong="H5975"\w* \w en|strong="H5975"\w* la tierra gloriosa, la cual \w será|strong="H6213"\w* destruida bajo su \w poder|strong="H3027"\w*.
\v 17 Luego \add el rey del norte\add* dirigirá su mirada \w para|strong="H5414"\w* conquistar \w todo|strong="H3605"\w* \w el|strong="H5973"\w* \w reino|strong="H4438"\w* \add del sur\add*. \w Hará|strong="H6213"\w* convenios \w con|strong="H5973"\w* \w él|strong="H5973"\w* y \w le|strong="H5973"\w* \w dará|strong="H5414"\w* \w a|strong="H3068"\w* su \w hija|strong="H1323"\w* \w como|strong="H5973"\w* esposa \w para|strong="H5414"\w* \w destruirlo|strong="H7843"\w*, pero \w no|strong="H3808"\w* \w permanecerá|strong="H5975"\w* \w ni|strong="H3808"\w* \w tendrá|strong="H1961"\w* éxito.
\v 18 \w Entonces|strong="H7725"\w* \w volverá|strong="H7725"\w* su \w rostro|strong="H6440"\w* \w a|strong="H3068"\w* las costas, y \w tomará|strong="H3920"\w* \w muchas|strong="H7227"\w* \add de ellas\add*. Pero un \w príncipe|strong="H7101"\w* hará cesar su \w afrenta|strong="H2781"\w*, y \w aun|strong="H7725"\w* hará \w volver|strong="H7725"\w* su \w oprobio|strong="H2781"\w* sobre él.
