\v 17 \w Est-ce|strong="G2228"\w* \w donc|strong="G3767"\w* \w qu|strong="G3739"\w*’\w en|strong="G2532"\w* \w formant|strong="G2532"\w* \w ce|strong="G3739"\w* \w dessein|strong="G2443"\w* \w j|strong="G1473"\w*’aurais agi \w avec|strong="G2532"\w* \w légèreté|strong="G1644"\w* ? \w Ou|strong="G2228"\w* \w bien|strong="G2532"\w* \w est-ce|strong="G2228"\w* \w que|strong="G3739"\w* \w les|strong="G2532"\w* projets \w que|strong="G3739"\w* \w je|strong="G1473"\w* \w fais|strong="G2532"\w*, \w je|strong="G1473"\w* \w les|strong="G2532"\w* \w fais|strong="G2532"\w* \w selon|strong="G2596"\w* \w la|strong="G2532"\w* \w chair|strong="G4561"\w*, \w de|strong="G2532"\w* \w sorte|strong="G2443"\w* \w qu|strong="G3739"\w*’\w il|strong="G2532"\w* \w y|strong="G2532"\w* \w ait|strong="G2532"\w* \w en|strong="G2532"\w* \w moi|strong="G1473"\w* \w le|strong="G2532"\w* \w oui|strong="G3483"\w* \w et|strong="G2532"\w* \w le|strong="G2532"\w* \w non|strong="G3756"\w* ?
