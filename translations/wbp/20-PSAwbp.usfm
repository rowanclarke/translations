\id PSA - Warlpiri Short Bible -Australia 2000 [wbp] (DBL 2015) 
\h Psalm 
\toc1 Psalm 
\toc2 Psa 
\mt1 Psalms  
\c 23  
\p
\v 1 YAAWIYI Kaatu, yungurnangkurla pulka-pinyi nyuntu-kuju purlapa yunparninjarlu:  
\q1 Ngaju kanpaju warrawarra-kanyi jakumanu-piyarluju.  
\q2 Jakumanurlu kajana jiyipi warrawarra-kanyi ngurrjungku.  
\q2 Wardinyi karnangku marlaja-nyina nyiyarningkijarra-kurlu.   
\q1
\v 2 Ngajulujurna wukayi,  
\q2 ngulaju kanpaju kanyi yama-kurra walyka-kurra.  
\q1 Ngajulujurna yarnunjuku,  
\q2 ngulaju kanpaju kanyi miyi ngarninjaku.  
\q1 Ngajulujurna purraku,  
\q2 ngulaju kanpaju kanyi mulju-kurra ngapa ngarninjaku.   
\q1
\v 3 Ngajuluju kanpaju kanyi yungurna pirrjirdi-jarri.  
\q2 Junga-nyayirnirli kanpaju milki-yirrarni jungarniki yaninjaku.   
\q1
\v 4 YAAWIYI, wangka karnangku,  
\q2 ‘Nyampuju karna lanilani-jarri wuurnpa-puru.’  
\q1 YAAWIYI, wangka karnangku,  
\q2 ‘Nyampuju karna lanilani-jarri munga-puru.’  
\q1 Kuja-puruju ngalijarraju wungu karli yani.  
\q2 Nyuntuku karnangku marlaja-nyina lani-wangulku.  
\q2 Nyuntu kanpaju palkangku warrawarra-kanyi.  
\q2 Jukati-kirlirli kanpaju ngajuluku ngarlkin-mani nyiyarlangu-kujaku.   
\q1
\v 5 Yapa kajulu panu-nyayirni kulu-jarrimi.  
\q2 Ngajuluju ngulangkuju kajulu maju-watirli putaputa-pakarni.  
\q2 Nyuntulurlu kanpa-jana warla-pajirni ngaju-kujaku murrumurru-maninja-kujakuju yungu-julu wiri-pajirnilki.  
\q1 Panu-jarlu kanpaju yinyi kurapakaju,  
\q2 nyanyi kajulu ngarninja-kurra.  
\q1 Nyuntu kanpaju jaraju yaarl-winjirni jurru-kurraju,  
\q2 ngula-kurlurluju kanpaju wiri-pajirni.  
\q1 Nyuntu kanpaju warrarda winjirni pamaju kartaku-kurra yungunpaju wiri-pajirni. \fig |alt="shepherd sitting with sheep" src="HK00003B.TIF" size="span" loc="bottom of page full width" copy="Horace Knowles" ref="23.5" \fig*  
\q2 Ngula-jangkaju pirrjirdilki karna nyinami pirda-kurluju.   
\q1
\v 6 YAAWIYI, ngajuju karnangku wala-nyinami.  
\q1 Nyuntu kanpaju tarnnga-juku nyina yimiri ngajulu-kuju.  
\q1 Ngajulukuju ngurrju-juku kapunpaju warrarda nyina.  
\q1 Tarnnga-juku kapurna nyina yuwarlirlaju nyuntu-nyangurla.  
\m Ngula-juku karnangku pulka-pinyi nyuntulukuju.   