\v 17 \w El|strong="H1121"\w* mensajero \w respondió|strong="H6030"\w*: \w Israel|strong="H3478"\w* \w huyó|strong="H5127"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w*, \w y|strong="H1571"\w* \w hubo|strong="H1961"\w* \w también|strong="H1571"\w* una \w gran|strong="H1419"\w* \w matanza|strong="H4046"\w* entre \w el|strong="H1121"\w* \w pueblo|strong="H5971"\w*. \w También|strong="H1571"\w* tus \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w*, Ofni \w y|strong="H1571"\w* Finees, \w murieron|strong="H4191"\w*, \w y|strong="H1571"\w* \w el|strong="H1121"\w* Arca \w de|strong="H6440"\w* \nd ʼElohim\nd* \w fue|strong="H1961"\w* capturada.
\p 
\v 18 \w Cuando|strong="H3588"\w* mencionó \w el|strong="H1931"\w* Arca \w de|strong="H5921"\w* \nd ʼElohim\nd*, \w aconteció|strong="H1961"\w* \w que|strong="H3588"\w* \w cayó|strong="H5307"\w* \w de|strong="H5921"\w* \w su|strong="H1931"\w* silla \w hacia|strong="H5921"\w* atrás, \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w puerta|strong="H8179"\w*. \w Se|strong="H1961"\w* \w le|strong="H1931"\w* \w quebró|strong="H7665"\w* \w la|strong="H1931"\w* nuca \w y|strong="H3588"\w* \w murió|strong="H4191"\w*, \w porque|strong="H3588"\w* \w era|strong="H1961"\w* hombre anciano \w y|strong="H3588"\w* \w pesado|strong="H3515"\w*. \w Él|strong="H1931"\w* \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* 40 \w años|strong="H8141"\w*.
\p 
\v 19 \w Su|strong="H3588"\w* \w nuera|strong="H3618"\w*, \w la|strong="H5921"\w* \w esposa|strong="H3618"\w* \w de|strong="H5921"\w* Finees, \w que|strong="H3588"\w* estaba embarazada \w y|strong="H3588"\w* cercana \w al|strong="H5921"\w* parto, \w al|strong="H5921"\w* \w escuchar|strong="H8085"\w* \w la|strong="H5921"\w* noticia \w de|strong="H5921"\w* \w que|strong="H3588"\w* \w el|strong="H5921"\w* Arca \w de|strong="H5921"\w* \nd ʼElohim\nd* fue capturada \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* \w suegro|strong="H2524"\w* \w y|strong="H3588"\w* \w su|strong="H3588"\w* esposo \w murieron|strong="H4191"\w*, \w se|strong="H5921"\w* agachó, \w pues|strong="H3588"\w* \w le|strong="H5921"\w* llegaron \w los|strong="H5921"\w* dolores \w y|strong="H3588"\w* dio \w a|strong="H3068"\w* luz.
\v 20 \w En|strong="H5921"\w* \w el|strong="H5921"\w* momento \w cuando|strong="H3588"\w* moría, \w las|strong="H5921"\w* \w que|strong="H3588"\w* \w estaban|strong="H5324"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ella|strong="H5921"\w* decían: \w No|strong="H3808"\w* \w temas|strong="H3372"\w*, \w porque|strong="H3588"\w* diste \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*. \w Pero|strong="H3588"\w* \w ella|strong="H5921"\w* \w no|strong="H3808"\w* \w respondió|strong="H6030"\w* \w ni|strong="H3808"\w* prestó atención.
\p 
\v 21 \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* al \w niño|strong="H5288"\w* Icabod \w y|strong="H3519"\w* dijo: ¡\w Traspasada|strong="H1540"\w* es la \w gloria|strong="H3519"\w* de \w Israel|strong="H3478"\w*, \w porque|strong="H1540"\w* el Arca de \nd ʼElohim\nd* \w fue|strong="H1540"\w* capturada! Su \w suegro|strong="H2524"\w* \w y|strong="H3519"\w* su esposo murieron.
\v 22 \w Y|strong="H3068"\w* dijo: ¡\w La|strong="H3588"\w* \w gloria|strong="H3519"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w es|strong="H3588"\w* \w traspasada|strong="H1540"\w*, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* Arca \w de|strong="H3588"\w* \nd ʼElohim\nd* \w fue|strong="H1540"\w* capturada!
\c 5
\s1 El Arca entre los filisteos
\p 
\v 1 Cuando los \w filisteos|strong="H6430"\w* \w tomaron|strong="H3947"\w* el Arca de \nd ʼElohim\nd*, la \w llevaron|strong="H3947"\w* de Ebenezer \w a|strong="H3068"\w* Asdod.
\v 2 Los \w filisteos|strong="H6430"\w* \w tomaron|strong="H3947"\w* el Arca de \nd ʼElohim\nd*, la introdujeron en el \w templo|strong="H1004"\w* de \w Dagón|strong="H1712"\w* y la pusieron junto \w a|strong="H3068"\w* \w Dagón|strong="H1712"\w*.
\v 3 Cuando los \w de|strong="H6440"\w* Asdod \w madrugaron|strong="H7925"\w* \w el|strong="H5307"\w* día \w siguiente|strong="H4283"\w*, ¡ahí \w estaba|strong="H2009"\w* \w Dagón|strong="H1712"\w* \w postrado|strong="H5307"\w* en tierra \w ante|strong="H6440"\w* \w el|strong="H5307"\w* Arca \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*! \w Y|strong="H3068"\w* \w tomaron|strong="H3947"\w* \w a|strong="H3068"\w* \w Dagón|strong="H1712"\w* y lo devolvieron \w a|strong="H3068"\w* su \w sitio|strong="H4725"\w*.
\v 4 \w El|strong="H5921"\w* día \w siguiente|strong="H4283"\w*, \w al|strong="H5921"\w* volver \w a|strong="H3068"\w* levantarse \w de|strong="H5921"\w* \w mañana|strong="H1242"\w*, ¡ahí \w estaba|strong="H2009"\w* \w Dagón|strong="H1712"\w* tendido, \w caído|strong="H5307"\w* \w en|strong="H5921"\w* tierra \w ante|strong="H6440"\w* \w el|strong="H5921"\w* Arca \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*! \w Y|strong="H3068"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w Dagón|strong="H1712"\w* \w y|strong="H5921"\w* sus \w manos|strong="H3027"\w* \w estaban|strong="H7218"\w* \w cortadas|strong="H3772"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* entrada. \w Solo|strong="H7535"\w* \w le|strong="H5921"\w* \w quedó|strong="H7604"\w* \w a|strong="H3068"\w* \w Dagón|strong="H1712"\w* \w el|strong="H5921"\w* tronco.
\v 5 \w Por|strong="H5921"\w* \w esta|strong="H2088"\w* causa, \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w de|strong="H5921"\w* \w Dagón|strong="H1712"\w* \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H3808"\w* entran \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w templo|strong="H1004"\w* \w de|strong="H5921"\w* \w Dagón|strong="H1712"\w*, \w no|strong="H3808"\w* \w pisan|strong="H1869"\w* \w la|strong="H5921"\w* entrada \w de|strong="H5921"\w* \w Dagón|strong="H1712"\w* \w en|strong="H5921"\w* Asdod \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.
\p 
\v 6 \w La|strong="H1366"\w* \w mano|strong="H3027"\w* de \nd \w Yavé|strong="H3068"\w*\nd* se endureció sobre los de Asdod y los castigó. \w En|strong="H5221"\w* Asdod y \w en|strong="H5221"\w* todos sus alrededores los \w hirió|strong="H5221"\w* con tumores.
\v 7 \w Cuando|strong="H3588"\w* \w los|strong="H3427"\w* hombres \w de|strong="H5921"\w* Asdod \w vieron|strong="H7200"\w* \w que|strong="H3588"\w* \w eso|strong="H3651"\w* era \w así|strong="H3651"\w*, dijeron: \w El|strong="H5921"\w* Arca \w del|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* debe permanecer \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w*, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w* \w es|strong="H3027"\w* dura \w contra|strong="H5921"\w* \w nosotros|strong="H5973"\w* \w y|strong="H3588"\w* \w contra|strong="H5921"\w* \w Dagón|strong="H1712"\w*, nuestro \tl ʼelohim\tl*.
\p 
\v 8 Convocaron \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* jefes de \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w* y dijeron: ¿\w Qué|strong="H4100"\w* \w hacemos|strong="H6213"\w* con \w el|strong="H3605"\w* Arca del \nd ʼElohim\nd* de \w Israel|strong="H3478"\w*?
\p \w Y|strong="H3068"\w* \w ellos|strong="H3605"\w* respondieron: \w Que|strong="H4100"\w* \w el|strong="H3605"\w* Arca del \nd ʼElohim\nd* de \w Israel|strong="H3478"\w* sea trasladada \w a|strong="H3068"\w* Gat. \w Y|strong="H3068"\w* trasladaron \w el|strong="H3605"\w* Arca del \nd ʼElohim\nd* de \w Israel|strong="H3478"\w*.
\v 9 Pero \w sucedió|strong="H1961"\w*, \w después|strong="H1961"\w* \w que|strong="H5704"\w* la trasladaron, \w que|strong="H5704"\w* la \w mano|strong="H3027"\w* \w de|strong="H5704"\w* \nd \w Yavé|strong="H3068"\w*\nd* cayó \w contra|strong="H1961"\w* la \w ciudad|strong="H5892"\w* \w y|strong="H5704"\w* causó \w gran|strong="H1419"\w* consternación. Golpeó \w a|strong="H3068"\w* \w los|strong="H1961"\w* hombres \w de|strong="H5704"\w* aquella \w ciudad|strong="H5892"\w*, \w desde|strong="H5704"\w* el \w pequeño|strong="H6996"\w* \w hasta|strong="H5704"\w* el \w grande|strong="H1419"\w*, \w y|strong="H5704"\w* \w se|strong="H1961"\w* llenaron \w de|strong="H5704"\w* tumores.
\p 
\v 10 Entonces \w enviaron|strong="H7971"\w* el Arca \w de|strong="H5971"\w* \nd ʼElohim\nd* \w a|strong="H3068"\w* \w Ecrón|strong="H6138"\w*. \w Y|strong="H3068"\w* \w cuando|strong="H1961"\w* el Arca \w de|strong="H5971"\w* \nd ʼElohim\nd* llegó \w a|strong="H3068"\w* \w Ecrón|strong="H6138"\w*, \w los|strong="H1961"\w* ecronitas dieron voces y dijeron: ¡Trajeron el Arca del \nd ʼElohim\nd* \w de|strong="H5971"\w* \w Israel|strong="H3478"\w* \w para|strong="H1961"\w* matarnos \w a|strong="H3068"\w* nosotros y \w a|strong="H3068"\w* nuestro \w pueblo|strong="H5971"\w*!
\p 
\v 11 Convocaron \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* jefes \w de|strong="H3588"\w* \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w* \w y|strong="H3588"\w* dijeron: ¡Envíen \w el|strong="H3588"\w* Arca del \nd ʼElohim\nd* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w vuelva|strong="H7725"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* propio \w lugar|strong="H4725"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* nos \w mate|strong="H4191"\w* \w a|strong="H3068"\w* \w nosotros|strong="H3605"\w* \w y|strong="H3588"\w* \w a|strong="H3068"\w* nuestro \w pueblo|strong="H5971"\w*! \w Porque|strong="H3588"\w* \w hubo|strong="H1961"\w* un pánico mortal \w en|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w*, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \nd ʼElohim\nd* \w se|strong="H1961"\w* endureció \w allí|strong="H8033"\w*.
\p 
\v 12 Los \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w morían|strong="H4191"\w* \w eran|strong="H3808"\w* afectados con tumores, y el \w clamor|strong="H7775"\w* de la \w ciudad|strong="H5892"\w* \w subía|strong="H5927"\w* al \w cielo|strong="H8064"\w*.
\c 6
\s1 Devolución del Arca
\p 
\v 1 El Arca de \nd \w Yavé|strong="H3068"\w*\nd* permaneció \w siete|strong="H7651"\w* \w meses|strong="H2320"\w* en el \w campo|strong="H7704"\w* de \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w*.
\v 2 Entonces los \w filisteos|strong="H6430"\w* convocaron \w a|strong="H3068"\w* sus \w sacerdotes|strong="H3548"\w* y \w adivinos|strong="H7080"\w* y les preguntaron: ¿\w Qué|strong="H4100"\w* \w hacemos|strong="H6213"\w* con \w el|strong="H6213"\w* Arca de \nd \w Yavé|strong="H3068"\w*\nd*? Dígannos de \w qué|strong="H4100"\w* manera la debemos enviar \w a|strong="H3068"\w* su \w lugar|strong="H4725"\w*.
\p 
\v 3 \w Y|strong="H3068"\w* \w respondieron|strong="H7725"\w*: \w Si|strong="H3588"\w* envían \w el|strong="H3588"\w* Arca \w del|strong="H4480"\w* \nd ʼElohim\nd* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w no|strong="H3808"\w* \w la|strong="H3588"\w* envíen \w vacía|strong="H7387"\w*, \w sino|strong="H3588"\w* \w ciertamente|strong="H3588"\w* deben devolverle \w a|strong="H3068"\w* \w Él|strong="H3588"\w* una ofrenda \w por|strong="H3588"\w* \w la|strong="H3588"\w* culpa, \w y|strong="H3588"\w* \w entonces|strong="H5493"\w* serán sanados. \w De|strong="H4480"\w* esta manera \w sabrán|strong="H3045"\w* \w por|strong="H3588"\w* \w qué|strong="H3588"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w* \w no|strong="H3808"\w* \w se|strong="H3045"\w* apartó \w de|strong="H4480"\w* \w sobre|strong="H4480"\w* ustedes.
\p 
\v 4 \w Y|strong="H3068"\w* \w ellos|strong="H3605"\w* preguntaron: ¿\w Cuál|strong="H4100"\w* será \w la|strong="H3588"\w* ofrenda \w por|strong="H3588"\w* \w la|strong="H3588"\w* culpa \w que|strong="H3588"\w* le debemos enviar?
\p \w Y|strong="H3068"\w* \w respondieron|strong="H7725"\w*: \w Cinco|strong="H2568"\w* tumores \w de|strong="H3588"\w* \w oro|strong="H2091"\w* \w y|strong="H3588"\w* \w cinco|strong="H2568"\w* \w ratones|strong="H5909"\w* \w de|strong="H3588"\w* \w oro|strong="H2091"\w*, según \w el|strong="H3588"\w* \w número|strong="H4557"\w* \w de|strong="H3588"\w* \w los|strong="H3605"\w* jefes \w de|strong="H3588"\w* \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* una misma \w plaga|strong="H4046"\w* estuvo sobre \w todos|strong="H3605"\w* ustedes \w y|strong="H3588"\w* sus jefes.
\v 5 \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, \w hagan|strong="H6213"\w* figuras \w de|strong="H5921"\w* sus tumores \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w ratones|strong="H5909"\w* \w que|strong="H5921"\w* destruyen \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* den \w gloria|strong="H3519"\w* \w al|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*. Tal vez alivie su \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* ustedes, sus \tl ʼelohim\tl*, \w y|strong="H5921"\w* su tierra.
\v 6 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* endurecen sus \w corazones|strong="H3824"\w*, \w como|strong="H4100"\w* los \w egipcios|strong="H4713"\w* y \w Faraón|strong="H6547"\w* \w endurecieron|strong="H3513"\w* sus \w corazones|strong="H3824"\w*? Después \w que|strong="H4100"\w* él \w se|strong="H3808"\w* burló de ellos, ¿\w no|strong="H3808"\w* los dejaron \w ir|strong="H3212"\w*, y salieron?
\p 
\v 7 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, \w tomen|strong="H3947"\w* \w y|strong="H5921"\w* preparen un carruaje \w nuevo|strong="H2319"\w* \w y|strong="H5921"\w* \w dos|strong="H8147"\w* \w vacas|strong="H6510"\w* \w que|strong="H3808"\w* estén criando, \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* cuales \w no|strong="H3808"\w* \w se|strong="H5921"\w* haya \w puesto|strong="H5927"\w* \w ningún|strong="H3808"\w* \w yugo|strong="H5923"\w*. Sujeten \w las|strong="H5921"\w* \w vacas|strong="H6510"\w* \w al|strong="H5921"\w* carruaje \w y|strong="H5921"\w* dejen sus becerros \w en|strong="H5921"\w* \w el|strong="H5921"\w* establo lejos \w de|strong="H5921"\w* \w ellas|strong="H5921"\w*.
\v 8 Después \w tomen|strong="H3947"\w* el Arca \w de|strong="H5414"\w* \nd \w Yavé|strong="H3068"\w*\nd* y pónganla en el carruaje. \w Y|strong="H3068"\w* \w pondrán|strong="H7760"\w* en una caja al \w lado|strong="H6654"\w* \w de|strong="H5414"\w* ella los objetos \w de|strong="H5414"\w* \w oro|strong="H2091"\w* que le devuelven como ofrenda \w por|strong="H5414"\w* la culpa. \w Y|strong="H3068"\w* \w dejarán|strong="H7971"\w* que \add el Arca\add* se vaya.
\v 9 Observen, \w si|strong="H3588"\w* \w sube|strong="H5927"\w* \w por|strong="H3588"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w su|strong="H1931"\w* territorio \w hacia|strong="H1870"\w* Bet-semes, \add entendemos que\add* \w Él|strong="H1931"\w* nos \w hizo|strong="H6213"\w* \w este|strong="H1931"\w* \w gran|strong="H1419"\w* \w mal|strong="H7451"\w*. \w Pero|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3808"\w*, \w entonces|strong="H3588"\w* sabremos \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w fue|strong="H1961"\w* \w su|strong="H1931"\w* \w mano|strong="H3027"\w* \w la|strong="H1931"\w* \w que|strong="H3588"\w* nos golpeó, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* nos ocurrió \w por|strong="H3588"\w* \w accidente|strong="H4745"\w*.
\p 
\v 10 \w Y|strong="H3068"\w* aquellos \w hombres|strong="H8147"\w* \w lo|strong="H6213"\w* \w hicieron|strong="H6213"\w* \w así|strong="H3651"\w*: \w Tomaron|strong="H3947"\w* \w dos|strong="H8147"\w* \w vacas|strong="H6510"\w* \w que|strong="H1121"\w* estaban criando, las sujetaron al carruaje y encerraron sus becerros en \w el|strong="H1121"\w* establo.
\v 11 Luego \w pusieron|strong="H7760"\w* el Arca de \nd \w Yavé|strong="H3068"\w*\nd* en el carruaje, junto con la caja de los \w ratones|strong="H5909"\w* de \w oro|strong="H2091"\w* y las figuras de sus tumores.
\v 12 \w Las|strong="H5921"\w* \w vacas|strong="H6510"\w* \w se|strong="H5921"\w* encaminaron \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w de|strong="H5921"\w* Bet-semes, \w y|strong="H5921"\w* \w seguían|strong="H5921"\w* un \w camino|strong="H1870"\w* recto, andaban \w y|strong="H5921"\w* bramaban \w sin|strong="H3808"\w* \w apartarse|strong="H5493"\w* \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w derecha|strong="H3225"\w* \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w izquierda|strong="H8040"\w*. \w Los|strong="H5921"\w* jefes \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* \w fueron|strong="H1980"\w* tras \w ellas|strong="H5921"\w* \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* límite \w de|strong="H5921"\w* Bet-semes.
\p 
\v 13 Los \w de|strong="H5869"\w* Bet-semes cosechaban el \w trigo|strong="H2406"\w* en el \w valle|strong="H6010"\w*, y al levantar sus \w ojos|strong="H5869"\w*, \w vieron|strong="H7200"\w* el Arca y se regocijaron al verla.
\v 14 El carruaje \w llegó|strong="H5927"\w* \w al|strong="H5930"\w* \w campo|strong="H7704"\w* de \w Josué|strong="H3091"\w* de Bet-semes, y se detuvo \w allí|strong="H8033"\w*, \w donde|strong="H8033"\w* \w había|strong="H5975"\w* una \w gran|strong="H1419"\w* piedra. Ellos entonces cortaron la \w madera|strong="H6086"\w* del carruaje, y ofrecieron las \w vacas|strong="H6510"\w* \w en|strong="H5975"\w* \w holocausto|strong="H5930"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 15 \w Levitas|strong="H3881"\w* \w bajaron|strong="H3381"\w* \w el|strong="H1931"\w* Arca de \nd \w Yavé|strong="H3068"\w*\nd* y \w la|strong="H1931"\w* caja \w que|strong="H1931"\w* \w estaba|strong="H7760"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* lado, \w que|strong="H1931"\w* \w tenía|strong="H1931"\w* adentro \w los|strong="H1931"\w* objetos de \w oro|strong="H2091"\w*, y \w los|strong="H1931"\w* \w pusieron|strong="H7760"\w* sobre \w aquella|strong="H1931"\w* \w gran|strong="H1419"\w* piedra. \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w los|strong="H1931"\w* hombres de Bet-semes ofrecieron \w holocaustos|strong="H5930"\w* y \w sacrificios|strong="H2077"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 16 \w Cuando|strong="H3117"\w* \w los|strong="H1931"\w* \w cinco|strong="H2568"\w* jefes \w de|strong="H2568"\w* \w los|strong="H1931"\w* \w filisteos|strong="H6430"\w* \w vieron|strong="H7200"\w* \w esto|strong="H1931"\w*, regresaron \w a|strong="H3068"\w* \w Ecrón|strong="H6138"\w* \w aquel|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w*.
\p 
\v 17 Los tumores de \w oro|strong="H2091"\w* que los \w filisteos|strong="H6430"\w* \w pagaron|strong="H7725"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* como ofrenda por la culpa, fueron estos: uno por Asdod, uno por \w Gaza|strong="H5804"\w*, uno por Ascalón, uno por Gat y uno por \w Ecrón|strong="H6138"\w*.
\v 18 \w Los|strong="H5921"\w* \w ratones|strong="H5909"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w* eran \w según|strong="H5921"\w* \w el|strong="H5921"\w* \w número|strong="H4557"\w* \w de|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* pertenecientes \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w cinco|strong="H2568"\w* jefes, \w tanto|strong="H5921"\w* \w ciudades|strong="H5892"\w* fortificadas \w como|strong="H5921"\w* \w pueblos|strong="H2568"\w* sin \w muro|strong="H6521"\w*. \w La|strong="H5921"\w* \w gran|strong="H1419"\w* piedra \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* cual \w pusieron|strong="H3240"\w* \w el|strong="H5921"\w* Arca \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, permanece \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w campo|strong="H7704"\w* \w de|strong="H5921"\w* \w Josué|strong="H3091"\w* \w de|strong="H5921"\w* Bet-semes \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.
\p 
\v 19 \w Pero|strong="H3588"\w* \w Él|strong="H3588"\w* castigó \w a|strong="H3068"\w* algunos \w de|strong="H3588"\w* \w los|strong="H3588"\w* hombres \w de|strong="H3588"\w* Bet-semes \w porque|strong="H3588"\w* \w miraron|strong="H7200"\w* dentro del Arca \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w De|strong="H3588"\w* todo \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w mató|strong="H5221"\w* \w a|strong="H3068"\w* 50.070 hombres, \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* hizo duelo \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* lo castigó \w con|strong="H3588"\w* \w gran|strong="H1419"\w* \w mortandad|strong="H4347"\w*.
\v 20 Entonces \w los|strong="H5921"\w* hombres \w de|strong="H5921"\w* Bet-semes dijeron: ¿\w Quién|strong="H4310"\w* \w podrá|strong="H3201"\w* permanecer \w en|strong="H5921"\w* \w pie|strong="H5975"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w el|strong="H5921"\w* \nd ʼElohim\nd* \w santo|strong="H6918"\w*? ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* \w subirá|strong="H5927"\w* \w desde|strong="H6440"\w* \w nosotros|strong="H5921"\w*?
\p 
\v 21 \w Y|strong="H3068"\w* \w enviaron|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de Quiriat-jearim y dijeron: ¡\w Los|strong="H3427"\w* \w filisteos|strong="H6430"\w* devolvieron \w el|strong="H3427"\w* Arca de \nd \w Yavé|strong="H3068"\w*\nd*! Bajen, y súbanla al lugar de ustedes.
\c 7
\s1 Samuel, juez de Israel
\p 
\v 1 Entonces \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H1121"\w* Quiriat-jearim \w fueron|strong="H5927"\w* y \w subieron|strong="H5927"\w* \w el|strong="H1121"\w* Arca \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w a|strong="H3068"\w* \w la|strong="H8104"\w* región montañosa. \w La|strong="H8104"\w* pusieron en \w casa|strong="H1004"\w* \w de|strong="H1121"\w* Abinadab y consagraron \w a|strong="H3068"\w* Eleazar, su \w hijo|strong="H1121"\w*, para \w que|strong="H1121"\w* \w guardara|strong="H8104"\w* \w el|strong="H1121"\w* Arca \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 2 Desde \w el|strong="H3605"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w el|strong="H3605"\w* Arca \w quedó|strong="H1961"\w* en Quiriat-jearim \w pasaron|strong="H3427"\w* \w muchos|strong="H7235"\w* \w días|strong="H3117"\w*, 20 \w años|strong="H8141"\w*, y \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w* \w lamentaba|strong="H5091"\w* tras \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 3 \w Samuel|strong="H8050"\w* habló \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* de \w Israel|strong="H3478"\w*: Si \w vuelven|strong="H7725"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* con \w todo|strong="H3605"\w* su \w corazón|strong="H3824"\w*, quiten de \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de ustedes \w los|strong="H3605"\w* \tl ʼelohim\tl* extraños y \w a|strong="H3068"\w* Astarot, preparen su \w corazón|strong="H3824"\w* \w para|strong="H5493"\w* \nd \w Yavé|strong="H3068"\w*\nd* y sirvan solo \w a|strong="H3068"\w* \w Él|strong="H3605"\w*, \w Él|strong="H3605"\w* \w los|strong="H3605"\w* \w librará|strong="H5337"\w* de \w la|strong="H3605"\w* \w mano|strong="H3027"\w* de \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w*.
\v 4 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w quitaron|strong="H5493"\w* \w los|strong="H1121"\w* baales y \w a|strong="H3068"\w* Astarot, y \w sirvieron|strong="H5647"\w* solo \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 5 Luego dijo \w Samuel|strong="H8050"\w*: Reúnan \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* en \w Mizpa|strong="H4709"\w*, y yo oraré \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w por|strong="H1157"\w* ustedes.
\v 6 \w Se|strong="H1931"\w* reunieron en \w Mizpa|strong="H4709"\w*. \w Sacaron|strong="H7579"\w* \w agua|strong="H4325"\w* y \w la|strong="H1931"\w* \w derramaron|strong="H8210"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*. Ayunaron \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w allí|strong="H8033"\w* y dijeron: ¡\w Pecamos|strong="H2398"\w* \w contra|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*! \w Y|strong="H3068"\w* \w Samuel|strong="H8050"\w* \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* en \w Mizpa|strong="H4709"\w*.
\p 
\v 7 \w Cuando|strong="H3588"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w oyeron|strong="H8085"\w* \w que|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* se reunieron \w en|strong="H3588"\w* \w Mizpa|strong="H4709"\w*, \w los|strong="H1121"\w* jefes \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w subieron|strong="H5927"\w* \w contra|strong="H6440"\w* \w Israel|strong="H3478"\w*. Al \w oír|strong="H8085"\w* esto, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* tuvieron \w temor|strong="H3372"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w*.
\v 8 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* dijeron \w a|strong="H3068"\w* \w Samuel|strong="H8050"\w*: No \w ceses|strong="H2790"\w* \w de|strong="H4480"\w* \w clamar|strong="H2199"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* nuestro \nd ʼElohim\nd* \w por|strong="H4480"\w* nosotros \w para|strong="H4480"\w* \w que|strong="H4480"\w* \w nos|strong="H4480"\w* \w salve|strong="H3467"\w* \w de|strong="H4480"\w* \w mano|strong="H3027"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w*.
\v 9 \w Samuel|strong="H8050"\w* \w tomó|strong="H3947"\w* un corderito lechal y lo \w ofreció|strong="H5927"\w* \w entero|strong="H3632"\w* en \w holocausto|strong="H5930"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w Samuel|strong="H8050"\w* \w clamó|strong="H2199"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w por|strong="H1157"\w* \w Israel|strong="H3478"\w*, y \nd \w Yavé|strong="H3068"\w*\nd* lo escuchó.
\p 
\v 10 \w Aconteció|strong="H1961"\w* \w que|strong="H1931"\w* mientras \w Samuel|strong="H8050"\w* ofrecía \w el|strong="H1931"\w* \w holocausto|strong="H5930"\w*, \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* \w llegaron|strong="H5066"\w* \w para|strong="H5921"\w* \w combatir|strong="H4421"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*. Pero \nd \w Yavé|strong="H3068"\w*\nd* \w tronó|strong="H7481"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w con|strong="H5921"\w* \w grande|strong="H1419"\w* \w estruendo|strong="H6963"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w desbarató|strong="H5062"\w*. \w Fueron|strong="H1961"\w* derrotados \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.
\v 11 \w Los|strong="H7291"\w* hombres \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w salieron|strong="H3318"\w* \w de|strong="H4480"\w* \w Mizpa|strong="H4709"\w*, \w persiguieron|strong="H7291"\w* \w a|strong="H3068"\w* \w los|strong="H7291"\w* \w filisteos|strong="H6430"\w* \w y|strong="H5704"\w* \w los|strong="H7291"\w* \w mataron|strong="H5221"\w* \w hasta|strong="H5704"\w* \w más|strong="H4480"\w* \w abajo|strong="H8478"\w* \w de|strong="H4480"\w* Bet-car.
\p 
\v 12 \w Luego|strong="H5704"\w* \w Samuel|strong="H8050"\w* \w tomó|strong="H3947"\w* una piedra \w y|strong="H5704"\w* la asentó entre \w Mizpa|strong="H4709"\w* \w y|strong="H5704"\w* Sen. La \w llamó|strong="H7121"\w* Ebenezer \w y|strong="H5704"\w* dijo: \w Hasta|strong="H5704"\w* \w aquí|strong="H2008"\w* nos \w ayudó|strong="H5826"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 13 Así \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w* \w fueron|strong="H1961"\w* sometidos, y \w no|strong="H3808"\w* volvieron \w a|strong="H3068"\w* entrar \w dentro|strong="H5750"\w* del límite \w de|strong="H5750"\w* \w Israel|strong="H3478"\w*. \w La|strong="H1366"\w* \w mano|strong="H3027"\w* \w de|strong="H5750"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w estuvo|strong="H1961"\w* \w contra|strong="H3478"\w* \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w de|strong="H5750"\w* \w Samuel|strong="H8050"\w*.
\v 14 Las \w ciudades|strong="H5892"\w* \w que|strong="H5704"\w* \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w* les \w tomaron|strong="H3947"\w* \w fueron|strong="H1961"\w* restituidas \w a|strong="H3068"\w* \w los|strong="H1961"\w* hijos \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*, \w desde|strong="H5704"\w* \w Ecrón|strong="H6138"\w* \w hasta|strong="H5704"\w* Gat. \w Israel|strong="H3478"\w* \w libró|strong="H5337"\w* su territorio \w de|strong="H5704"\w* \w mano|strong="H3027"\w* \w de|strong="H5704"\w* \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w*. También \w hubo|strong="H1961"\w* \w paz|strong="H7965"\w* entre \w Israel|strong="H3478"\w* \w y|strong="H5704"\w* \w los|strong="H1961"\w* amorreos.
\p 
\v 15 \w Samuel|strong="H8050"\w* \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* de su \w vida|strong="H2416"\w*.
\v 16 \w Él|strong="H1008"\w* acostumbraba \w ir|strong="H1980"\w* \w cada|strong="H3605"\w* \w año|strong="H8141"\w* en un \w camino|strong="H1980"\w* por Bet-ʼEl, \w Gilgal|strong="H1537"\w* y \w Mizpa|strong="H4709"\w*, y \w juzgaba|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* en \w todos|strong="H3605"\w* esos \w lugares|strong="H4725"\w*.
\v 17 Después regresaba \w a|strong="H3068"\w* \w Ramá|strong="H7414"\w*, \w pues|strong="H3588"\w* \w allí|strong="H8033"\w* \w estaba|strong="H1004"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w*. \w Allí|strong="H8033"\w* también \w juzgaba|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w y|strong="H3588"\w* \w allí|strong="H8033"\w* \w edificó|strong="H1129"\w* un \w altar|strong="H4196"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\c 8
\s1 Los hijos de Samuel como jueces
\p 
\v 1 \w Aconteció|strong="H1961"\w* \w que|strong="H1121"\w* \w cuando|strong="H1961"\w* \w Samuel|strong="H8050"\w* \w envejeció|strong="H2204"\w*, designó \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w como|strong="H1961"\w* \w jueces|strong="H8199"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.
\v 2 Su \w hijo|strong="H1121"\w* \w primogénito|strong="H1060"\w* \w era|strong="H1961"\w* \w Joel|strong="H3100"\w*, y \w el|strong="H1121"\w* \w segundo|strong="H4932"\w*, Abías. \w Eran|strong="H1961"\w* \w jueces|strong="H8199"\w* en Beerseba.
\v 3 Pero sus \w hijos|strong="H1121"\w* \w no|strong="H3808"\w* andaban \w por|strong="H1870"\w* \w los|strong="H1121"\w* \w caminos|strong="H1870"\w* \w de|strong="H1121"\w* \w él|strong="H1121"\w*, \w sino|strong="H3808"\w* \w se|strong="H3808"\w* apartaron tras la \w ganancia|strong="H1215"\w* deshonesta. Recibían \w soborno|strong="H7810"\w* y pervertían la \w justicia|strong="H4941"\w*.
\s1 Clamor de Israel por un rey
\p 
\v 4 Entonces \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* de \w Israel|strong="H3478"\w* se reunieron y fueron \w a|strong="H3068"\w* \w Samuel|strong="H8050"\w* en \w Ramá|strong="H7414"\w*,
\v 5 y le dijeron: \w Mira|strong="H2009"\w*, \w tú|strong="H8199"\w* envejeciste, y tus \w hijos|strong="H1121"\w* \w no|strong="H3808"\w* \w andan|strong="H1980"\w* \w por|strong="H1870"\w* tus \w caminos|strong="H1870"\w*. \w Por|strong="H1870"\w* tanto, desígnanos un \w rey|strong="H4428"\w* \w que|strong="H3808"\w* nos \w juzgue|strong="H8199"\w*, como \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w* tienen.
\p 
\v 6 Pero fue desagradable ante \w Samuel|strong="H8050"\w* \w que|strong="H1697"\w* dijeran: \w Danos|strong="H5414"\w* un \w rey|strong="H4428"\w* \w que|strong="H1697"\w* nos \w juzgue|strong="H8199"\w*. \w Y|strong="H3068"\w* \w Samuel|strong="H8050"\w* \w oró|strong="H6419"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 7 \nd \w Yavé|strong="H3068"\w*\nd* dijo \w a|strong="H3068"\w* \w Samuel|strong="H8050"\w*: \wj \w Oye|strong="H8085"\w* \w la|strong="H5921"\w* \w voz|strong="H6963"\w* \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w en|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* \w te|strong="H5921"\w* digan, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* rechazan \w a|strong="H3068"\w* \w ti|strong="H5921"\w*, \w sino|strong="H3588"\w* \w a|strong="H3068"\w* \w Mí|strong="H5921"\w*, \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w reine|strong="H4427"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*.\wj*
