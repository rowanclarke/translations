\id NAM - Biblica® Open Shona Contemporary Bible 2017 
\h Nahumi 
\toc1 Nahumi 
\toc2 Nahumi 
\toc3 Nahu 
\mt1 NAHUMI 
\c 1  
\p  
\v 1 Chirevo pamusoro peNinevhe. Bhuku rezvakaonekwa naNahumi muErikoshi. 
\s1 Kutsamwa kwaJehovha pamusoro peNinevhe 
\q1  
\v 2 Jehovha ane godo uye ndiMwari anotsiva; 
\q2 Jehovha anotsiva uye azere nehasha. 
\q1 Jehovha anotsiva kuvavengi vake 
\q2 uye anochengetera vavengi vake hasha dzake. 
\q1  
\v 3 Jehovha anononoka kutsamwa uye ane simba guru; 
\q2 Jehovha haangasiye ane mhosva asina kurangwa. 
\q1 Nzira yake iri muchamupupuri nedutu, 
\q2 uye makore ndiwo guruva retsoka dzake. 
\q1  
\v 4 Anotuka gungwa agoriomesa; 
\q2 anoita kuti nzizi dzose dziome. 
\q1 Bhashani neKarimeri zvasvava 
\q2 uye kutumbuka kweRebhanoni kwapera. 
\q1  
\v 5 Makomo anodengenyeka pamberi pake 
\q2 uye zvikomo zvinonyungudika. 
\q1 Nyika inodedera pamberi pake, 
\q2 nyika uye navose vanogara mairi. 
\q1  
\v 6 Ndiani angadzivisa hasha dzake? 
\q2 Ndiani angashingirire pahasha dzake dzinotyisa? 
\q1 Hasha dzake dzadururwa somoto; 
\q2 matombo apwanyika pamberi pake. 
\q1  
\v 7 Jehovha akanaka, 
\q2 utiziro panguva dzokutambudzika. 
\q1 Anochengeta avo vanovimba naye, 
\q2  
\v 8 asi namafashamu ane simba guru, 
\q1 achaparadza Ninevhe; 
\q2 achateverera vavengi vake kusvikira murima. 
\b  
\q1  
\v 9 Zvose zvavakaronga pamusoro paJehovha 
\q2 iye achazviparadza; 
\q2 dambudziko haringauyi kechipiri. 
\q1  
\v 10 Vachakorokodzwa pakati peminzwa 
\q2 uye vachadhakwa newaini yavo; 
\q2 vachaparadzwa samashanga akaoma. 
\q1  
\v 11 Kubva mauri, iwe Ninevhe, 
\q2 pane mumwe akabuda anoronga zvakaipa pamusoro paJehovha 
\q2 uye anopa zano rakaipa. 
\p  
\v 12 Zvanzi naJehovha: 
\q1 “Kunyange vane vabatsiri uye vakawanda, 
\q2 vachaurayiwa vakasazovapozve. 
\q1 Kunyange ndakakutambudza, iwe Judha, 
\q2 handichazokutambudzazve. 
\q1  
\v 13 Zvino ndichavhuna joko ravo kubva pamutsipa wako 
\q2 uye ndichadambura ngetani dzako.” 
\b  
\q1  
\v 14 Jehovha arayira shoko pamusoro pako, iwe Ninevhe, rokuti, 
\q2 “Hauchazovi nezvizvarwa zvinopiwa zita rako. 
\q1 Ndichaparadza zvifananidzo zvakavezwa nezvifananidzo zvakaumbwa, 
\q2 zviri mutemberi yavamwari vako. 
\q1 Ndichachera guva rako, 
\q2 nokuti iwe wakaipa kwazvo.” 
\b  
\q1  
\v 15 Tarira, pamakomo apo, 
\q2 tsoka dzouyo anouya namashoko akanaka, 
\q2 anoparidza rugare! 
\q1 Pemberera mitambo yako, iwe Judha, 
\q2 uye uzadzise mhiko dzako. 
\q1 Vakaipa havachakurwisazve; 
\q2 vachaparadzwa zvachose. 
\c 2  
\s1 Ninevhe richawa 
\q1  
\v 1 Murwisi anouya kuzokurwisa iwe, Ninevhe; 
\q2 rindai nhare, 
\q2 tarirai kunzira, 
\q2 sungai zviuno zvenyu, 
\q2 unganidzai simba renyu rose! 
\q1  
\v 2 Jehovha achadzosa kurumbidzwa kwaJakobho 
\q2 sokurumbidzwa kwaIsraeri, 
\q1 kunyange vaparadzi vakavaparadza 
\q2 uye vakaparadza mizambiringa yavo. 
\b  
\q1  
\v 3 Nhoo dzavarwi vake dzatsvuka; 
\q2 mhare dzokurwa dzapfeka nguo tsvuku. 
\q1 Matare engoro ovaima 
\q2 pazuva rokugadzirirwa kwadzo; 
\q2 mapfumo omupaini anovheyeswa-vheyeswa. 
\q1  
\v 4 Ngoro dzovirima mumigwagwa, 
\q2 dzinomhanya dzichienda nokudzoka muchivara. 
\q1 Dzinoita samazhenje omoto; 
\q2 dzinomhanya-mhanya semheni. 
\b  
\q1  
\v 5 Anodana mauto ake akasarudzwa, 
\q2 asi vanogumburwa panzira yavo. 
\q1 Vanomhanyira kurusvingo rweguta; 
\q2 nhoo yokuzvidzivirira yaiswa panzvimbo payo. 
\q1  
\v 6 Masuo enzizi azarurwa 
\q2 uye muzinda wamambo wakoromoka. 
\q1  
\v 7 Shoko ratemwa rokuti guta 
\q2 ritapwe, uye riendeswe kure. 
\q1 Varandakadzi varo vanochema senjiva 
\q2 uye vanorova zvipfuva zvavo. 
\q1  
\v 8 Ninevhe rakafanana nedziva, 
\q2 uye mvura yaro iri kuerera ichipera. 
\q1 Vanochema vachiti, “Mirai! Mirai!” 
\q2 asi hapana anocheuka. 
\q1  
\v 9 Pambai sirivha! 
\q2 Pambai goridhe! 
\q1 Kuwanda kwazvo hakuperi, 
\q2 ihwo upfumi hunobva pamhando dzose dzepfuma yaro! 
\q1  
\v 10 Rabirwa, rapambwa, ratorerwa zvose! 
\q2 Mwoyo yanyungudika, mabvi odedera, 
\q2 miviri yobvunda, zviso zvose zvachenuruka. 
\b  
\q1  
\v 11 Riripiko bako reshumba, 
\q2 nzvimbo yadzaipira vana vadzo zvokudya, 
\q1 kwaienda shumba nehadzi yayo, 
\q2 uye navana, pasina chokutya. 
\q1  
\v 12 Shumba yaiuraya zvaikwanira vana vayo 
\q2 uye yakadzipira hadzi yayo nyama, 
\q1 ichizadza mapako ayo nezvayakauraya 
\q2 uye mapako ayo nenyama. 
\b  
\q1  
\v 13 “Ndine mhaka newe,” 
\q2 ndizvo zvinotaura Jehovha Wamasimba Ose. 
\q1 “Ndichapisa ngoro dzenyu dzive utsi, 
\q2 uye munondo uchaparadza shumba dzenyu duku. 
\q1 Ndichakusiyai musina nyama panyika. 
\q2 Mazwi enhume dzako haangazonzwikazve.” 
\c 3  
\s1 Ninevhe rine nhamo 
\q1  
\v 1 Rine nhamo guta reropa, 
\q2 rizere nenhema, 
\q1 rizere nezvakapambwa, 
\q2 harigari risina varinotambudza! 
\q1  
\v 2 Kurira kwetyava, 
\q2 utsvikitsviki hwamavhiri, 
\q1 mutsindo wamabhiza 
\q2 nomubvumo wokutinhira kwengoro! 
\q1  
\v 3 Kumhanya kwavatasvi vamabhiza, 
\q2 kupenya kweminondo 
\q2 namapfumo anovaima! 
\q1 Vazhinji vakaurayiwa, 
\q2 mirwi yevakafa, 
\q1 mitumbi isingaverengeki, 
\q2 vanhu vachigumburwa nezvitunha. 
\q1  
\v 4 Zvose izvi nokuda kwokuchiva kuzhinji kwechifeve, 
\q2 chinokwezvera, mukuru wouroyi, 
\q1 akatapa ndudzi noufeve hwake 
\q2 namarudzi avanhu nouroyi hwake. 
\q1  
\v 5 “Ndine mhaka newe,” ndizvo zvinotaura Jehovha Wamasimba Ose. 
\q2 Ndichafukura nguo yako ifukidze chiso chako 
\q1 “Ndicharatidza ndudzi kushama kwako 
\q2 namadzimambo kunyadziswa kwako. 
\q1  
\v 6 Ndichakukandidzira tsvina, 
\q2 ndichakuita akazvidzika 
\q2 uye ndichakuita chiseko. 
\q1  
\v 7 Vose vachakuona vachakutiza uye vachati, 
\q2 ‘Ninevhe raparara, ndiani acharichema?’ 
\q2 Ndingawana kupi munhu angakunyaradza?” 
\b  
\q1  
\v 8 Uri nani kupfuura Tebhesi here, 
\q2 rakavakwa paNairi, 
\q2 rakakomberedzwa nemvura? 
\q1 Rwizi ndirwo rwairidzivirira, 
\q2 mvura iri rusvingo rwaro. 
\q1  
\v 9 Etiopia neIjipiti ndizvo zvaiva simba rayo guru; 
\q2 Puti neRibhiya dzaiva pakati pavabatsiri vayo. 
\q1  
\v 10 Kunyange zvakadaro yakatapwa 
\q2 ikaendeswa kuutapwa. 
\q1 Vacheche varo vakaputsanyiwa 
\q2 kumavambo kwemigwagwa yose. 
\q1 Mijenya yakakandwa pamusoro pemachinda avo, 
\q2 uye vakuru vavo vakasungwa nengetani. 
\q1  
\v 11 Newewo uchadhakwa; 
\q2 uchavanda 
\q2 ugotsvaka utiziro kubva kumuvengi wako. 
\b  
\q1  
\v 12 Nhare dzako dzose dzafanana nemiti yemionde 
\q2 ine michero yokutanga yaibva; 
\q1 paanozunzwa, 
\q2 maonde anodonhera mumuromo momudyi. 
\q1  
\v 13 Tarira mauto ako, 
\q2 vose vakadzi! 
\q1 Masuo enyika yako 
\q2 akazarurirwa kuvavengi vako; 
\q2 moto waparadza mazariro awo. 
\b  
\q1  
\v 14 Cherai mvura kuitira kukombwa, 
\q2 simbisai nhare dzenyu! 
\q1 Gadzirai ivhu, 
\q2 kanyai dhaka, 
\q2 mugadzire zvidhina zvenyu! 
\q1  
\v 15 Moto uchakuparadzai imomo; 
\q2 munondo uchakuurayai, 
\q2 uye uchakuparadzai semhashu. 
\q1 Berekanai semhashu, 
\q2 muberekane sehwiza! 
\q1  
\v 16 Makawedzera uwandu hwavatengesi venyu 
\q2 kusvikira vapfuura nyeredzi dzedenga kuwanda. 
\q2 Asi sehwiza, vanoparadza nyika 
\q2 vobhururuka vachienda. 
\q1  
\v 17 Varindi venyu vakaita sehwiza, 
\q2 machinda enyu segundamusaira rehwiza 
\q2 dzinomhara pamadziro musi wakunotonhora, 
\q1 asi kana zuva rabuda dzinobhururuka dzichienda, 
\q2 uye hapana anoziva kuti kupi. 
\b  
\q1  
\v 18 Iwe mambo weAsiria, vafudzi vako vanotsumwaira; 
\q2 machinda ako anorara pasi kuti azorore. 
\q1 Vanhu vako vakapararira pamusoro pamakomo 
\q2 pasina angavaunganidza. 
\q1  
\v 19 Hapana chingarapa ronda rako; 
\q2 kukuvara kwako kuchakuuraya. 
\q1 Mumwe nomumwe anonzwa nezveguhu rako 
\q2 anorova maoko ake pakuwa kwako, 
\q1 nokuti ndianiko asina kunzwa 
\q2 utsinye hwako husina magumo?