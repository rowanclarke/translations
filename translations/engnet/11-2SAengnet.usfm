\v 12  Now \w Mephibosheth|strong="H4648"\w* \w had|strong="H1121"\w* \w a|strong="H3068"\w* \w young|strong="H1121"\w* \w son|strong="H1121"\w* \w whose|strong="H1121"\w* \w name|strong="H8034"\w* \w was|strong="H8034"\w* \w Mica|strong="H4316"\w*. \w All|strong="H3605"\w* \w the|strong="H3605"\w* \w members|strong="H1004"\w* \w of|strong="H1121"\w* \w Ziba|strong="H6717"\w*’s \w household|strong="H1004"\w* \w were|strong="H1121"\w* \w Mephibosheth|strong="H4648"\w*’s \w servants|strong="H5650"\w*.  
\v 13  \w Mephibosheth|strong="H4648"\w* \w was|strong="H1931"\w* \w living|strong="H3427"\w* \w in|strong="H3427"\w* \w Jerusalem|strong="H3389"\w*, \w for|strong="H3588"\w* \w he|strong="H1931"\w* \w was|strong="H1931"\w* \w a|strong="H3068"\w* \w regular|strong="H8548"\w* guest \w at|strong="H3427"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w*’s \w table|strong="H7979"\w*. \w But|strong="H3588"\w* \w both|strong="H8147"\w* \w his|strong="H5921"\w* \w feet|strong="H7272"\w* \w were|strong="H7272"\w* crippled.   
\c 10  
\p
\v 1  \w Later|strong="H1961"\w* \w the|strong="H8478"\w* \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w the|strong="H8478"\w* \w Ammonites|strong="H1121"\w* \w died|strong="H4191"\w* \w and|strong="H1121"\w* \w his|strong="H1961"\w* \w son|strong="H1121"\w* \w Hanun|strong="H2586"\w* \w succeeded|strong="H8478"\w* \w him|strong="H4427"\w*.  
\v 2  \w David|strong="H1732"\w* said, “\w I|strong="H5650"\w* \w will|strong="H5650"\w* \w express|strong="H5162"\w* \w my|strong="H1732"\w* \w loyalty|strong="H2617"\w* \w to|strong="H7971"\w* \w Hanun|strong="H2586"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Nahash|strong="H5176"\w* \w just|strong="H6213"\w* \w as|strong="H6213"\w* \w his|strong="H7971"\w* \w father|strong="H1121"\w* \w was|strong="H1732"\w* \w loyal|strong="H2617"\w* \w to|strong="H7971"\w* \w me|strong="H7971"\w*.” \w So|strong="H6213"\w* \w David|strong="H1732"\w* \w sent|strong="H7971"\w* \w his|strong="H7971"\w* \w servants|strong="H5650"\w* \w with|strong="H5973"\w* \w a|strong="H3068"\w* message expressing \w sympathy|strong="H5162"\w* \w over|strong="H3027"\w* \w his|strong="H7971"\w* \w father|strong="H1121"\w*’s death. \w When|strong="H7971"\w* \w David|strong="H1732"\w*’s \w servants|strong="H5650"\w* entered \w the|strong="H6213"\w* land \w of|strong="H1121"\w* \w the|strong="H6213"\w* \w Ammonites|strong="H1121"\w*,  
