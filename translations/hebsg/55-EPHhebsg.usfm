\id EPH
\h אפרים 
\toc1 אִגֶּרֶת פּוֹלוֹס הַשָּׁלִיחַ אֶל־הָאֶפְסִיִּים 
\toc2 אִגֶּרֶת פּוֹלוֹס הַשָּׁלִיחַ אֶל־הָאֶפְסִיִּים 
\toc3 אפרים 
\mt1 אִגֶּרֶת פּוֹלוֹס הַשָּׁלִיחַ אֶל־הָאֶפְסִיִּים  
\c 1
\cp  א
\cl פרק א 
\p
\v 1 \vp א\vp* פּוֹלוֹס שְׁלִיחַ יֵשׁוּעַ הַמָּשִׁיחַ בִּרְצוֹן אֱלֹהִים אֶל־הַקְּדוֹשִׁים בְּאֶפְסוֹס וְאֶל־אֲשֶׁר נֶאֱמָן לִבָּם לִפְנֵי יֵשׁוּעַ הַמָּשִׁיחַ׃  
\v 2 \vp ב\vp* חֶסֶד וְשָׁלוֹם יִתֵּן לָכֶם אֱלֹהִים אָבִינוּ וְיֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ׃  
\v 3 \vp ג\vp* בָּרוּךְ הוּא הָאֱלֹהִים אֲבִי אֲדֹנֵינוּ יֵשׁוּעַ הַמָּשִׁיחַ אֲשֶׁר בֵּרַךְ אֹתָנוּ מִשְּׁמֵי מְעוֹנוֹ בְּכָל־בִּרְכַּת הַנֶּפֶשׁ בַּמָּשִׁיחַ׃  
\v 4 \vp ד\vp* כַּאֲשֶׁר בּוֹ בְחָרָנוּ עַד לֹא נוֹסְדָה אָרֶץ לִהְיוֹת קְדֹשִׁים וּתְמִימִים לְפָנָיו׃  
\v 5 \vp ה\vp* וּבְאַהֲבָתוֹ יְעָדָנוּ מֵרֹאשׁ לִהְיוֹת לוֹ לְבָנִים עַל־יְדֵי יֵשׁוּעַ הַמָּשִׁיחַ כְּחֵפֶץ לִבּוֹ הַטּוֹב׃  
\v 6 \vp ו\vp* לְתִפְאֶרֶת עֹז חַסְדּוֹ אֲשֶׁר־גָּמַל עָלֵינוּ בִּידִידוֹ׃  
\v 7 \vp ז\vp* כִּי־בוֹ נִמְצָא פְדוּת וּסְלִיחָה לְחַטֹּאתֵינוּ בְּדָמוֹ הַשָּׁפוּךְ כַּהֲמוֹן חֲסָדָיו׃  
\v 8 \vp ח\vp* אֲשֶׁר הִרְבָּה עָלֵינוּ בְּכָל־חָכְמָה וּבִינָה׃  
\v 9 \vp ט\vp* וַיּוֹדַע לָנוּ אֶת־סוֹד רְצוֹנוֹ כַּעֲצָתוֹ הַטּוֹבָה הַיְעוּצָה בְלִבּוֹ מִקֶּדֶם׃  
\v 10 \vp י\vp* לְקַבֵּץ בַּמָּשִׁיחַ בִּמְלֹאת יְמֵי הַפְּקֻדָּה כֹּל אֲשֶׁר בַּשָּׁמַיִם וְכֹל אֲשֶׁר בָּאָרֶץ וְהָיוּ בוֹ לַאֲחָדִים׃  
\v 11 \vp יא\vp* וְגַם עַל־יָדוֹ נַחֲזִיק בַּמּוֹרָשָׁה כַּאֲשֶׁר נִבְחַרְנוּ לָהּ מֵאָז מִטַּעַם הָעֹשֶׂה כֹּל כַּעֲצַת חֶפְצוֹ׃  
\v 12 \vp יב\vp* לְמַעַן יֵרָאֶה עָלֵינוּ הֲדַר כְּבוֹדוֹ בִּהְיוֹת אֲנַחְנוּ הָרִאשֹׁנִים אֲשֶׁר בָּטַחְנוּ בַּמָּשִׁיחַ׃  
\v 13 \vp יג\vp* וּבוֹ בֹטְחִים גַּם־אַתֶּם אַחֲרֵי אֲשֶׁר שְׁמַעְתֶּם אֶת־דְּבַר הָאֱמֶת אֶת־דְּבַר הַבְּשׁרָה לִתְשׁוּעַתְכֶם וְכַאֲשֶׁר הֶאֱמַנְתֶּם בּוֹ כֵּן גַּם־נֶחְתָּמִים אַתֶּם בְּרוּחַ הַקֹּדֶשׁ כַּאֲשֶׁר דִּבֵּר׃  
\v 14 \vp יד\vp* אֲשֶׁר עֵרָבוֹן הוּא לְמוֹרָשָׁתֵנוּ עַד אֲשֶׁר־תִּגָּאֵל וְהָיְתָה־לָּנוּ לַאֲחֻזָּה לִתְהִלַּת שֵׁם כְּבוֹדוֹ׃  
\v 15 \vp טו\vp* וַאֲשֶׁר עַל־כֵּן גַּם־אָנֹכִי אַחֲרֵי שָׁמְעִי אֶת־אֱמוּנַתְכֶם בְּיֵשׁוּעַ אֲדֹנֵינוּ וְאַהֲבַתְכֶם לְכָל־הַקְּדוֹשִׁים׃  
\v 16 \vp טז\vp* לֹא חָדַלְתִּי מֵהוֹדוֹת בַּעַדְכֶם וּלְהַזְכִּירְכֶם בִּתְפִלּוֹתַי׃  
\v 17 \vp יז\vp* כִּי אֱלֹהֵי יֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ אֲבִי הַכָּבוֹד יִתֵּן לָכֶם רוּחַ הַחָכְמָה וְהֶחָזוֹן לָדַעַת אֹתוֹ׃  
\v 18 \vp יח\vp* וּלְהָאִיר עֵינֵי שִׂכְלְכֶם לְהַשְׂכִּיל מָה הִיא תִקְוַת קְרוּאָיו וּמֶה חֹסֶן כָּבוֹד לִקְדשָׁיו בְּנַחֲלָתוֹ׃  
\v 19 \vp יט\vp* וּמָה עֹצֶם גֹּדֶל גְּבוּרָתוֹ אֲשֶׁר פָּעַל בָּנוּ הַמַּאֲמִינִים בּוֹ לְפִי תֹקֶף עֻזּוֹ׃  
\v 20 \vp כ\vp* הוּא אֲשֶׁר פָּעַל בַּמָּשִׁיחַ בַּאֲשֶׁר הֲקִימוֹ מִן־הַמֵּתִים וַיּוֹשִׁיבֵהוּ לִימִינוֹ בַּמָּרוֹם׃  
\v 21 \vp כא\vp* גָּבוֹהַּ מִכָּל־מִשְׂרָה וְשִׁלְטוֹן וּגְבוּרָה וּמֶמְשָׁלָה וּמִכָּל־אֲשֶׁר נִקְרָא בְשֵׁם גַּם־בָּעוֹלָם הַזֶּה וְגַם־בָּעוֹלָם הַבָּא׃  
\v 22 \vp כב\vp* וְכֹל שָׁת תַּחַת רַגְלָיו וַיִּתְּנֵהוּ לְרֹאשׁ לְכָל־הָעֵדָה׃  
\v 23 \vp כג\vp* אֲשֶׁר הִיא גְוִיָּתוֹ וּמְלֹאוֹ כִּי מָלֵא הוּא אֶת־כֹּל בַּכֹּל׃   
\c 2
\cp  ב
\cl פרק ב 
\p
\v 1 \vp א\vp* גַּם־אַתֶּם אֲשֶׁר מֵתִים הֱיִיתֶם בְּפִשְׁעֵיכֶם וְחַטֹּאתֵיכֶם׃  
\v 2 \vp ב\vp* כִּי־בְאָרְחוֹתָם הֲלַכְתֶּם לְפָנִים כְּמִנְהַג בְּנֵי הָעוֹלָם הַזֶּה וְכִרְצוֹן שַׂר חֵיל הָרוּחוֹת מִתַּחַת הַשָּׁמָיִם הוּא הָרוּחַ הַמִּתְעוֹרֵר בְּלֵב בָּנִים לֹא־אָבוּ שְׁמוֹעַ׃  
\v 3 \vp ג\vp* וּכְמוֹהֶם גַּם־אֲנַחְנוּ רָדַפְנוּ תַאֲוֹת בְּשָׂרִים לְמַלֵּא מִשְׁאֲלוֹת הַבָּשָׂר וְהַלֵּב הָרָע עַד אֲשֶׁר־נִדְמִינוּ בְּדַרְכֵי חַיֵּינוּ לִשְׁאָר בָּנִים עוֹרְרֵי זָעַם׃  
\v 4 \vp ד\vp* אַךְ אֵל מָלֵא רַחֲמִים בְּרֹב אַהֲבָתוֹ אֲשֶׁר אָהַב אֹתָנוּ׃  
\v 5 \vp ה\vp* הֶחֱיָנוּ עִם־הַמָּשִׁיחַ בִּהְיוֹתֵנוּ מֵתִים בַּפְּשָׁעִים וְאַךְ בַּחֶסֶד נוֹשַׁעְתֶּם׃  
\v 6 \vp ו\vp* כִּי הֲקִימָנוּ בְּיֵשׁוּעַ הַמָּשִׁיחַ וַיִּתֶּן־לָנוּ לָשֶׁבֶת עִמּוֹ בַּמָּרוֹם׃  
\v 7 \vp ז\vp* לְהַרְאוֹת בַּיָּמִים יָבוֹאוּ אֶת־גֹּדֶל עשֶׁר חַסְדּוֹ אֲשֶׁר־גָּמַל עָלֵינוּ לְטוֹבָה בְּיֵשׁוּעַ הַמָּשִׁיחַ׃  
\v 8 \vp ח\vp* כִּי־בַחֶסֶד נוֹשַׁעְתֶּם עֵקֶב אֱמוּנַתְכֶם וְלֹא מִיֶּדְכֶם הָיְתָה זֹּאת לָכֶם כִּי־מַתַּת אֱלֹהִים הִיא׃  
\v 9 \vp ט\vp* לֹא בִשְׂכַר מַעֲשֵׂיכֶם פֶּן־יִתְהַלֵּל אִישׁ׃  
\v 10 \vp י\vp* כִּי אֲנַחְנוּ מַעֲשֵׂה יָדָיו נוֹצַרְנוּ בְיֵשׁוּעַ הַמָּשִׁיחַ לְמַעֲשִׂים טוֹבִים אֲשֶׁר הֵכִין לָנוּ מִקֶּדֶם לָלֶכֶת בָּם׃  
\v 11 \vp יא\vp* עַל־כֵּן זִכְרוּ זֹאת כִּי־גוֹיִם עַרְלֵי בָשָׂר הֱיִיתֶם לְפָנִים וְהַנִּקְרָאִים נִמּוֹלֵי בָשָׂר אֲשֶׁר הוּא מַעֲשֵׂה יָדַיִם קָרְאוּ לָכֶם עֲרֵלִים׃  
\v 12 \vp יב\vp* וְכִי־בָעֵת הַהִיא הֱיִיתֶם בְּלֹא מָשִׁיחַ נָכְרִים לְכָל־אֶזְרָח בְּיִשְׂרָאֵל וְזָרִים לְכָל־בְּרִית וְהַבְטָחָה בְּאֶפֶס תִּקְוָה וּבְלֹא אֱלֹהִים בָּאָרֶץ׃  
\v 13 \vp יג\vp* אַךְ בְּיֵשׁוּעַ הַמָּשִׁיחַ אַתֶּם הָרְחֹקִים מֵאָז נִקְרַבְתֶּם כַּיּוֹם בְּדַם הַמָּשִׁיחַ׃  
\v 14 \vp יד\vp* כִּי הוּא שְׁלוֹמֵנוּ אֲשֶׁר עָשָׂה שְׁנַיִם לְאֶחָד וְאֶת־הַקִּיר הַמַּבְדִּיל בֵּינֵינוּ הָרָס׃  
\v 15 \vp טו\vp* כִּי־בִבְשָׂרוֹ מָחָה אֶת־הָאֵיבָה וְאֶת־מִצְוֹת הַחֻקִּים בַּתּוֹרָה וַיַּעַשׂ שְׁנַיִם לְאִישׁ־אֶחָד חָדָשׁ בְּנַפְשׁוֹ וּבָזֹאת עָשָׂה לָנוּ שָׁלוֹם׃  
\v 16 \vp טז\vp* כִּי עַל־הַצְּלִיב הִשְׁלִים שְׁנֵיהֶם בְּגֵו אֶחָד אֶל־הָאֱלֹהִים וַיִּמַח אֶת־הָאֵיבָה בְּנַפְשׁוֹ׃  
\v 17 \vp יז\vp* וַיָּבֹא וַיְבַשֵּׂר שָׁלוֹם לָרְחוֹקִים וְשָׁלוֹם לַקְּרוֹבִים׃  
\v 18 \vp יח\vp* כִּי־בוֹ נִפְתַּח לִשְׁנֵינוּ מָבוֹא לָגֶשֶׁת בְּרוּחַ אֶחָד אֶל־אָבִינוּ׃  
\v 19 \vp יט\vp* עַל־כֵּן אֵינְכֶם עוֹד גֵּרִים וְתוֹשָׁבִים כִּי אִם־אֶזְרְחֵי הָעִיר בְּקֶרֶב הַקְּדוֹשִׁים וּבְנֵי בֵית הָאֱלֹהִים׃  
\v 20 \vp כ\vp* בְּנוּיִים עַל־מוֹסְדוֹת הַשְּׁלִיחִים וְהַנְּבִיאִים שֶׁשָּׁם יֵשׁוּעַ הַמָּשִׁיחַ הָיָה לְרֹאשׁ פִּנָּה׃  
\v 21 \vp כא\vp* וּבוֹ כָּל־הַבִּנְיָן חֻבָּר וַיִּגְדַּל לְהֵיכַל קָדוֹשׁ בַּיהוָֹה׃  
\v 22 \vp כב\vp* וּבוֹ נִבְנֵיתֶם גַּם־אַתֶּם לְמִשְׁכַּן אֱלֹהִים בָּרוּחַ׃   
\c 3
\cp  ג
\cl פרק ג 
\p
\v 1 \vp א\vp* בַּעֲבוּר זֹאת אֵפוֹא אֲנִי פוֹלוֹס הִנְנִי אֲסִיר יֵשׁוּעַ הַמָּשִׁיחַ לְמַעַנְכֶם הַגּוֹיִם׃  
\v 2 \vp ב\vp* הֲלֹא שְׁמַעְתֶּם כִּי נִתְּנָה לִּי פְקֻדָּתִי בְּחֶסֶד אֵל בַּעֲבוּרְכֶם׃  
\v 3 \vp ג\vp* וְכִי הוֹדִיעַ לִי הַסּוֹד בַּמַּחֲזֶה כַּאֲשֶׁר כָּתַבְתִּי לְפָנִים בְּלָשׁוֹן קְצָרָה לֵאמֹר׃  
\v 4 \vp ד\vp* אִם תִּקְרְאוּ דְבָרַי תּוּכְלוּ לְהַכִּיר כְּי הַדַּעַת אִתִּי בְּסוֹד הַמָּשִׁיחַ׃  
\v 5 \vp ה\vp* אֲשֶׁר לֹא נוֹדַע לִבְנֵי אָדָם בְּדֹרוֹת מִקֶּדֶם כַּאֲשֶׁר נִגְלָה כַיּוֹם לִשְׁלִיחָיו הַקְּדֹשִׁים וְלִנְבִיאָיו עַל־פִּי הָרוּחַ׃  
\v 6 \vp ו\vp* כִּי יִקְחוּ הַגּוֹיִם חֵלֶק גַּם־הֵם בְּנַחֲלָתוֹ לִהְיוֹת כְּאֵבָרִים בִּגְוִיָּתוֹ וַחֲבֵרִים לִפְנֵי יֵשׁוּעַ הַמָּשִׁיחַ לְקַבֵּל הַבְטָחָתוֹ עַל־פִּי הַבְּשׂרָה׃  
\v 7 \vp ז\vp* אֲשֶׁר הָיִיתִי לָהּ לִמְשָׁרֵת בְּמַתְּנַת חֶסֶד אֱלֹהִים אֲשֶׁר נָתַן לִי לְפִי פְּעֻלַּת גְּבוּרָתוֹ׃  
\v 8 \vp ח\vp* אֲנִי הַצָּעִיר בַּצְּעִירִים בֵּין הַקְּדוֹשִׁים נָתוּן לִי הַחֶסֶד הַזֶּה לְבַשֵּׂר אֶל־הַגּוֹיִם חֹסֶן הַמָּשִׁיחַ כִּי־רַב הוּא לְאֵין חֵקֶר׃  
\v 9 \vp ט\vp* וּלְהָאִיר עֵינֵי־כֹל לָדַעַת עֵרֶךְ הַסּוֹד אֲשֶׁר צָפוּן הָיָה מֵעוֹלָם בֵּאלֹהִים יוֹצֵר הַכֹּל עַל־יְדֵי יֵשׁוּעַ הַמָּשִׁיחַ׃  
\v 10 \vp י\vp* וּבָזֹאת יִוָּדַע עַל־פִּי הָעֵדָה לְרָאשֵׁי הַצָּבָא וּלְגִבֹּרֵי כֹחַ בַּמָּרוֹם נִפְלְאוֹת חָכְמַת אֱלֹהִים׃  
\v 11 \vp יא\vp* כָּעֵצָה אֲשֶׁר יָעַץ מִקֶּדֶם בְּיֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ׃  
\v 12 \vp יב\vp* אֲשֶׁר בּוֹ נוֹסִיף אֹמֶץ לָגֶשֶׁת אֵלָיו בֶּאֱמוּנָתוֹ בְּלֵב נָכוֹן׃  
\v 13 \vp יג\vp* עַל־כֵּן זֹאת אֲנִי מְבַקֵּשׁ אַל־נָא תִּתְעַטְּפוּ בְצָרוֹתַי אֲשֶׁר אֲפָפוּנִי לְמַעַנְכֶם כִּי זֹאת הִיא תִּפְאַרְתְּכֶם׃  
\v 14 \vp יד\vp* עַל־כֵּן אֶכְרְעָה עַל בִּרְכָּי לִפְנֵי אָבִי אֲדוֹנֵינוּ יֵשׁוּעַ הַמָּשִׁיחַ׃  
\v 15 \vp טו\vp* אֲשֶׁר נִקְרָא שְׁמוֹ עַל כָּל־צִבְאוֹתָיו בַּשָּׁמַיִם וּבָאָרֶץ׃  
\v 16 \vp טז\vp* וְהוּא יִתֵּן לָכֶם כְּפִי־חֹסֶן כְּבוֹדוֹ לְהִתְאַזֵּר בִּגְבוּרָה עַל־פִּי רוּחוֹ בָּאָדָם הַפְּנִימִי׃  
\v 17 \vp יז\vp* וְהַמָּשִׁיחַ יִשְׁכֹּן בְּקֶרֶב לִבְּכֶם בֶּאֱמוּנָה כִּי תַשְׁרִישׁוּ וְתִוָּסְדוּ בְּאַהֲבָה׃  
\v 18 \vp יח\vp* אָז תּוּכְלוּ לְהַשְׂכִּיל עִם כָּל־הַקְּדוֹשִׁים מַה־הוּא הָרֹחַב וְהָאֹרֶךְ וְהַגֹּבַה וְהָעֹמֶק׃  
\v 19 \vp יט\vp* וּלְהִתְבּוֹנֵן בְּאַהֲבַת הַמָּשִׁיחַ אֲשֶׁר מִדַּעַת נִשְׂגָּבָה עַד־אֲשֶׁר תִּמָּלְאוּ מִכָּל־מְלֹא הָאֱלֹהִים׃  
\v 20 \vp כ\vp* וְהוּא אֲשֶׁר יָדָיו רַב לוֹ לְעוֹרֵר בַּכֹּחַ לִבֵּנוּ וְלַעֲשׂוֹת לָנוּ יֶתֶר עַל־כָּל־מִשְׁאֲלוֹתֵינוּ וּמַחְשְׁבוֹתֵינוּ׃  
\v 21 \vp כא\vp* לוֹ הוּא הַכָּבוֹד בְּתוֹךְ הָעֵדָה וּבְיֵשׁוּעַ הַמָּשִׁיחַ מִדּוֹר לְדוֹר וּמֵהָעוֹלָם וְעַד־הָעוֹלָם אָמֵן׃   
\c 4
\cp  ד
\cl פרק ד 
\p
\v 1 \vp א\vp* וַאֲנִי אֲסִיר הָאָדוֹן אֶפְצַר בָּכֶם לָלֶכֶת כְּנָאוָה לְמַצַּב הַקְּרֻאִים כָּמוֹכֶם׃  
\v 2 \vp ב\vp* בְּהַצְנֵעַ וַעֲנָוָה בְּאֹרֶךְ אַפָּיִם וְלָשֵׂאת אִישׁ אֶת־רֵעֵהוּ בְּאַהֲבָה׃  
\v 3 \vp ג\vp* לִשְׁקֹד וְלִשְׁמֹר לְיַחֵד רוּחֲכֶם בְּמַחְבֶּרֶת הַשָּׁלוֹם׃  
\v 4 \vp ד\vp* לִהְיוֹת כְּאֵבָרִים בְּגוּף אֶחָד וּבְרוּחַ אֶחָד כַּאֲשֶׁר גַּם־נִקְרַאתֶם לְמַצַּבְכֶם בְּתִקְוָה אֶחָת׃  
\v 5 \vp ה\vp* אָדוֹן אֶחָד אֱמוּנָה אַחַת וּטְבִילָה אֶחָת׃  
\v 6 \vp ו\vp* אֵל אֶחָד וַאֲבִי־כֹל אֲשֶׁר הוּא עַל־כֹּל וְעִם־כֹּל וּבְתוֹךְ כֻּלְכֶם׃  
\v 7 \vp ז\vp* אַךְ לְאִישׁ אִישׁ מִמֶּנּוּ חֻלַּק מְנָת חָסֶד כְּמִדַּת מַתְּנַת הַמָּשִׁיחַ׃  
\v 8 \vp ח\vp* עַל־כֵּן הוּא אֹמֵר עָלָה לַמָּרוֹם שָׁבָה שֶׁבִי וַיִּתֵּן מַתָּנוֹת לָאָדָם׃  
\v 9 \vp ט\vp* וְכִי נֹאמַר כִּי־עָלָה אֵין זֶה כִּי אִם־יָרַד בָּרִאשֹׁנָה לְתַחְתִּיּוֹת אָרֶץ׃  
\v 10 \vp י\vp* הַיֹּרֵד הוּא הָעֹלֶה לְמַעְלָה מִכָּל־שְׁמֵי מָרוֹם לְמַלֵּא אֶת־הַכֹּל׃  
\v 11 \vp יא\vp* וְהוּא נָתַן אֶת־אֵלֶּה לִהְיוֹת שְׁלִיחִים וְאֶת־אֵלֶּה נְבִיאִים וְאֶת־אֵלֶּה מְבַשְּׂרִים וְאֶת־אֵלֶּה רֹעִים וּמוֹרִים׃  
\v 12 \vp יב\vp* לְהַשְׁלִים אֶת־הַקְּדֹשִׁים לִמְלֶאכֶת עֲבֹדַת הַקֹּדֶשׁ לְמַעַן יִבָּנֶה גּוּף הַמָּשִׁיחַ׃  
\v 13 \vp יג\vp* עַד אֲשֶׁר כֻּלָּנוּ נָבוֹא לְיַחֵד לְבָבֵנוּ בֶּאֱמוּנָה אַחַת וּבְדַעַת בֶּן־הָאֱלֹהִים וְהָיִינוּ לְאָדָם שָׁלֵם בַּמִּדָּה כִּמְלֹא קוֹמַת הַמָשִׁיחַ׃  
\v 14 \vp יד\vp* לְבִלְתִּי נִהְיֶה עוֹד עוֹלֲלִים נִדָּפִים וְנִגְרָשִׁים מִפְּנֵי כָל־רוּחַ בְּתוֹרַת אֲנָשִׁים וְתַרְמִיתָם אֲשֶׁר בְּנִכְלֵיהֶם יָצוּדוּ חֵרֶם׃  
\v 15 \vp טו\vp* כִּי אִם־נַחֲזִיק בָּאֱמֶת מֵאַהֲבָה וְהָלַכְנוּ הָלוֹךְ וְגָדוֹל לִפְנֵי הַמָּשִׁיחַ אֲשֶׁר הוּא הָרֹאשׁ׃  
\v 16 \vp טז\vp* וּבוֹ מֻדְבָּק וּמְקֻשָּׁר כָּל־הַגּוּף עִם כָּל־פרקיו וַחֲלָקָיו אֶל־נָכוֹן אֲשֶׁר בְּאַהֲבָה יַעַבְדוּן לְהַגְדִּילוֹ וּלְהַאֲדִירוֹ כְּדֵי כֹחָם׃  
\v 17 \vp יז\vp* וְעַתָּה הַעִדֹתִי בָכֶם לִפְנֵי הָאָדוֹן לֵאמֹר אַל־תֵּלְכוּ כְּיֶתֶר הַגּוֹיִם אֲשֶׁר אַחֲרֵי הַבְלֵי שָׁוְא לִבָּם הֹלֵךְ׃  
\v 18 \vp יח\vp* מְאוֹר דַּעְתָּם חָשַׁךְ וְחַיֵּי אֱלֹהִים מוּזָרִים לָהֶם עֵקֶב אֲשֶׁר הִקְשׁוּ רוּחָם בְּאִוַּלְתָּם׃  
\v 19 \vp יט\vp* הֵם אֲשֶׁר טָפַשׁ לִבָּם וַיִּתְמַכְּרוּ לַעֲשׂוֹת כָּל־נְבָלָה וְתוֹעֵבָה וְלֹא יֵדְעוּ שָׂבְעָה׃  
\v 20 \vp כ\vp* וְאַתֶּם לֹא כָזֹאת לְמַדְתֶּם דַּרְכֵי הַמָּשִׁיח׃  
\v 21 \vp כא\vp* אִם רַק מַקְשִׁיבִים הֱיִיתֶם לְקוֹלוֹ וְלִמּוּדֵי דְבָרוֹ אַתֶּם כִּי הֵם אֱמֶת בִּפְנֵי יֵשׁוּעַ׃  
\v 22 \vp כב\vp* וְעֵן עֲזַבְתֶּם דַּרְכֵיכֶם הָרִאשֹׁנִים עַד־לְהָסִיר מֵעֲלֵיכֶם אֶת־הָאָדָם הַקַּדְמֹנִי הַנִּשְׁחָת וְהַנִּתְעֶה בְּתַאֲוָתוֹ׃  
\v 23 \vp כג\vp* לְהִתְחַדֵּשׁ בְּרוּחַ חֲדָשָׁה בְּקֶרֶב לִבְּכֶם׃  
\v 24 \vp כד\vp* וְלִלְבּשׁ אֶת־הָאָדָם הֶחָדָשׁ הַנִּבְרָא בְצֶדֶק וּבְקֹדֶשׁ בֶּאֱמֶת כְּלֵב הָאֱלֹהִים׃  
\v 25 \vp כה\vp* עַל־כֵּן הַרְחִיקוּ שֶׁקֶר מִכֶּם וְדַבְּרוּ אֱמֶת אִישׁ אֶת־רֵעוֹ כִּי אֵבָרִים אֲנַחְנוּ אִישׁ לְאָחִיו׃  
\v 26 \vp כו\vp* רִגְזוּ וְאַל־תֶּחֱטָאוּ וְלֹא תָבוֹא הַשֶּׁמֶשׁ בְּעוֹד רֹגֶז בְּאַפְּכֶם׃  
\v 27 \vp כז\vp* פֶּן־תִּתְּנוּ מָקוֹם לַשָּׂטָן׃  
\v 28 \vp כח\vp* מִי שֶׁגָּנַב אַל־יֹסֵף לִגְנֹב עוֹד כִּי אִם־יַעֲמֹל לַעֲשׂוֹת טוֹב בְּיָדָיו לִהְיוֹת לוֹ לָתֵת לָאֶבְיוֹן׃  
\v 29 \vp כט\vp* כָּל־דְּבַר בְּלִיַּעַל לֹא־יֵצֵא מִפִּיכֶם כִּי אִם־דְּבָרִים טוֹבִים וּנְכֹחִים לְהָשִׁיב נֶפֶשׁ וְלָתֶת־חֵן לְשֹׁמְעֵיהֶם׃  
\v 30 \vp ל\vp* וְאַל־תְּעַצְּבוּ אֶת־רוּחַ הַקֹּדֶשׁ הוּא רוּחַ הָאֱלֹהִים אֲשֶׁר בּוֹ נֶחְתָּמִים אַתֶּם עַד יוֹם הַגְּאֻלָּה׃  
\v 31 \vp לא\vp* וְהַרְחִיקוּ מִכֶּם כָּל־מְרִירוּת לֵב וַחֲרוֹן אָף רֹגֶז וּתְלוּנָּה וּנְאָצָה עִם כָּל־דָּבָר רָע׃  
\v 32 \vp לב\vp* אֲבָל חֹנְנִים תִּהְיוּ זֶה לָזֶה מְרַחֲמִים וְסַלָּחִים אִישׁ לְאָחִיו כַּאֲשֶׁר גַּם־הָאֱלֹהִים סָלַח לָכֶם בַּמָּשִׁיחַ׃   
\c 5
\cp  ה
\cl פרק ה 
\p
\v 1 \vp א\vp* לָכֵן אַחֲרֵי אֱלֹהֵיכֶם תֵּלֵכוּ כְּבָנִים אֲהוּבִים׃  
\v 2 \vp ב\vp* וּבְאַהְבָה תָּכִינוּ צְעָדֵיכֶם כַּאֲשֶׁר גַּם־הַמָּשִׁיחַ אָהַב אֹתָנוּ וַיִּתֵּן אֶת־נַפְשׁוֹ תַּחַת נַפְשֵׁנוּ לְקָרְבָּן וָזֶבַח לְרֵיחַ נִיחֹחַ לֵאלֹהִים׃  
\v 3 \vp ג\vp* אַךְ זְנוּת וְכָל־זִמָּה וּבֶצַע לֹא יִשָּׁמַע עַל־פִּיכֶם כַּאֲשֶׁר נָכוֹן לְאַנְשֵׁי קֹדֶשׁ׃  
\v 4 \vp ד\vp* וְכֵן לֹא דִבְרֵי נְבָלָה וְלֹא הוֹלֵלוֹת וְתָהֳלָה אֲשֶׁר לֹא לְתִפְאֶרֶת לָכֶם כִּי אִם־אִמְרֵי תְהִלָּה׃  
\v 5 \vp ה\vp* כִּי־זֹאת יָדֹע תֵּדְעוּ כִּי כָּל־אִישׁ זֹנֶה וְטַמֵא אוֹ אֹהֵב בֶּצַע מַעֲשַׁקּוֹת אֲשֶׁר הוּא כְּעֹבֵד אֱלִילִים אֵין לָהֶם נַחֲלָה בְּמַלְכוּת מְשִׁיחֵנוּ וֵאלֹהֵינוּ׃  
\v 6 \vp ו\vp* אַל־תִּתְּנוּ לִבְּכֶם לִשְׁגּוֹת בְּדִבְרֵי מַהְבִּלִים כִּי בִגְלַל־זֶה יְשַׁלַּח אֱלֹהִים חֲרוֹן אַפּוֹ בְּבָנִים סוֹרְרִים׃  
\v 7 \vp ז\vp* עַל־כֵּן לֹא תִהְיוּ חֲבֵרִים לָהֶם׃  
\v 8 \vp ח\vp* כִּי־חֲשֵׁכָה הֱיִיתֶם לְפָנִים וְעַתָּה נֶהְפַּכְתֶּם לְאוֹרָה בַּאֲדֹנֵינוּ הִתְהַלְּכוּ־נָא כִּבְנֵי־אוֹר׃  
\v 9 \vp ט\vp* וְזֶה פְּרִי הָרוּחַ הוּא עֲשׂוֹת חֶסֶד לַכֹּל וְצֶדֶק וֶאֱמֶת׃  
\v 10 \vp י\vp* וּבָחוֹן מַה־יִּיטַב בְּעֵינֵי אֲדֹנֵינוּ׃  
\v 11 \vp יא\vp* וְאַל־תִּתְעָרְבוּ בְּמַעַלֲלֵי רִיק וְחֹשֶׁךְ כִּי אִם־הוֹכֵחַ תּוֹכִיחוּן אֹתָם׃  
\v 12 \vp יב\vp* כִּי אֶת־אֲשֶׁר הֵם עֹשִׂים בַּמַּחְשָׁךְ חֶרְפָּה הִיא לְסַפֵּר׃  
\v 13 \vp יג\vp* אַךְ כַּאֲשֶׁר יִוָּכְחוּ אָז יִגָּלוּ לָאוֹר מָה הֵם לָאוֹר הַמְגַלֶּה אֹתָם׃  
\v 14 \vp יד\vp* וְעַל־זֶה נֶאֱמַר קוּם לְךָ נִרְדָּם הָקִיצָה מִן־הַמֵּתִים וְהַמָּשִׁיחַ יִזְרַח עָלֶיךָ׃  
\v 15 \vp טו\vp* וְעַתָּה תָּשִׂימוּ עַיִן עַל־דַּרְכֵיכֶם לְהֵיטִיב לֶכֶת וְלֹא כֶאֱוִילִים כִּי אִם־כַּחֲכָמִים׃  
\v 16 \vp טז\vp* דִּי עִדָּנָא זָבְנִין בַּעֲבוּר כִּי רָעִים הַיָּמִים׃  
\v 17 \vp יז\vp* וְלֹא תִהְיוּ חַסְרֵי לֵב כִּי אִם־תַּשְׁכִּילוּ לָדַעַת מַה חֵפֶץ אֲדֹנֵינוּ׃  
\v 18 \vp יח\vp* וְאַל־תִּסְבְּאוּ יַיִן אֲשֶׁר רוּחַ עִוְעִים בְּקִרְבּוֹ רַק הִמָּלְאוּ רוּחַ עֶלְיוֹן׃  
\v 19 \vp יט\vp* וְאִמְרוּ בְנַפְשְׁכֶם תְּהִלּוֹת וְשִׁירוֹת וְזִמְרוֹת יָהּ שִׁירוּ וְזַמְּרוּ בִלְבַבְכֶם לַיהוָֹה׃  
\v 20 \vp כ\vp* וְעַל־הַכֹּל הוֹדוּ לֵאלֹהֵינוּ אָבִינוּ תָּמִיד בְּשֵׁם יֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ׃  
\v 21 \vp כא\vp* הִכָּנְעוּ אִישׁ מִפְּנֵי אָחִיו בְּיִרְאַת אֱלֹהִים׃  
\v 22 \vp כב\vp* וְהַנָּשִׁים נִכְנָעוֹת תִּהְיֶינָה מִפְּנֵי בַעֲלֵיהֶן כְּמוֹ מִפְּנֵי הָאָדוֹן׃  
\v 23 \vp כג\vp* כִּי הַבַּעַל הוּא־רֹאשׁ הָאִשָּׁה כְּמוֹ גַם־הַמָּשִׁיחַ רֹאשׁ הָעֵדָה וְהוּא הַמוֹשִׁיעַ לִגְוִיָּתוֹ׃  
\v 24 \vp כד\vp* אַךְ כַּאֲשֶׁר נִכְנַעַת הָעֵדָה מִלִּפְנֵי מְשִׁיחָהּ כֵּן גַּם־הַנָּשִׁים תִּכָּנַעְנָה מִלִּפְנֵי בַעֲלֵיהֶן בְּכָל־אָרְחוֹתָן׃  
\v 25 \vp כה\vp* וְאַתֶּם אֲנָשִׁים אֶהֱבוּ אֶת־נְשֵׁיכֶם כַּאֲשֶׁר גַּם־הַמָּשִׁיחַ אֶת־עֲדָתוֹ אָהֵב וַיִּתֵּן אֶת־נַפְשׁוֹ תַּחַת נַפְשָׁהּ׃  
\v 26 \vp כו\vp* לְמַעַן יְקַדְּשֶׁנָּה בִדְבָרוֹ אַחֲרֵי אֲשֶׁר־רָחַץ אֹתָהּ בְּמִקְוֵה מָיִם׃  
\v 27 \vp כז\vp* לְהָקִים לוֹ עֵדָה נִכְבָּדָה בָּרָה וּתְמִימָה מִבְּלִי בַהֶרֶת אוֹ פְּחֶתֶת וְכָל־מוּם אֵין בָּהּ׃  
\v 28 \vp כח\vp* כֵּן הַמִּצְוָה עַל־הָאֲנָשִׁי לְאַהֲבָה אֶת־נְשֵׁיהֶם כְּגוּפָם כִּי הָאֹהֵב אֶת־אִשְׁתּוֹ הוּא אֹהֵב אֶת־עַצְמוֹ וְאֶת־בְּשָׂרוֹ׃  
\v 29 \vp כט\vp* כִּי מֵעוֹלָם לֹא־שָׂנֵא אִישׁ אֶת־בְּשָׂרוֹ רַק מְכַלְכֵּל וּמְפַנֵּק אֹתוֹ כַּאֲשֶׁר גַּם־הַמָּשִׁיחַ אֶת־עֲדָתוֹ׃  
\v 30 \vp ל\vp* כִּי־אֵבָרֵי גוּפוֹ אֲנָחְנוּ מִבְּשָׂרוֹ וּמֵעֲצָמָיו׃  
\v 31 \vp לא\vp* עַל־כֵּן יַעֲזָב־אִישׁ אֶת־אָבִיו וְאֶת־אִמּוֹ וְדָבַק בְּאִשְׁתּוֹ וְהָיוּ שְׁנֵיהֶם לְבָשָׂר אֶחָד׃  
\v 32 \vp לב\vp* גָּדוֹל הַסּוֹד הַזֶּה וַאֲנִי מְדַבֵּר עַל־הַמָּשִׁיחַ וְעַל־עֲדָתוֹ׃  
\v 33 \vp לג\vp* אַךְ גַּם־אַתֶּם אִישׁ אִישׁ מִכֶּם יֶאֱהַב אֶת־אִשְׁתּוֹ כְּנַפְשׁוֹ וְהָאִשָּׁה אֶת־בַּעְלָהּ תִּירָא׃   
\c 6
\cp  ו
\cl פרק ו 
\p
\v 1 \vp א\vp* שִׁמְעוּ בָנִים בְּקוֹל יֹלְדֵיכֶם בַּאֲדֹנֵינוּ כִּי דָבָר יָשָׁר הוּא׃  
\v 2 \vp ב\vp* כַּבֵּד אֶת־אָבִיךָ וְאֶת־אִמֶּךָ זֹאת הַמִּצְוָה הָרִאשֹׁנָה אֲשֶׁר שְׂכָרָהּ בְּצִדָּהּ׃  
\v 3 \vp ג\vp* לְמַעַן יִיטַב לָךְ וּלְמַעַן יַאֲרִיכוּן יָמֶיךָ עַל־הָאֲדָמָה׃  
\v 4 \vp ד\vp* וְהָאָבוֹת אַל־תָּעִירוּ חֲמַת בְּנֵיכֶם כִּי אִם־תְּגַדְּלוּם בְּמוּסַר אֲדֹנֵינוּ וּבְתוֹכַחְתּוֹ׃  
\v 5 \vp ה\vp* וְאַתֶּם עֲבָדִים הַקְשִׁיבוּ לְקוֹל אֲדֹנֵיכֶם אֲדֹנֵי גְוִיַּתְכֶם בְּיִרְאָה וּרְעָדָה וּבְתָם־לֵב כְּמוֹ לַמָּשִׁיחַ׃  
\v 6 \vp ו\vp* וְלֹא בַעֲבֹדָה לְמַרְאֵה עֵינַיִם לְהָפִיק רָצוֹן מִבְּנֵי אָדָם כִּי אִם־כְּעַבְדֵי הַמָּשִׁיחַ הָעֹשִׂים רְצוֹן אֱלֹהִים בְּכָל־נַפְשָׁם׃  
\v 7 \vp ז\vp* וְעֹבְדִים מִטּוּב לֵב כְּעֹבְדֵי אֲדֹנֵינוּ וְלֹא כְּעֹבְדֵי אֲנָשִׁים׃  
\v 8 \vp ח\vp* הֲלֹא יְדַעְתֶּם כָּל־דָּבָר טוֹב אֲשֶׁר יַעֲשֶׂה אֹתוֹ הָאָדָם אֲדֹנֵינוּ יְשַׁלֶּם־לוֹ אִם־עֶבֶד הוּא אוֹ בֶן־חוֹרִים׃  
\v 9 \vp ט\vp* וְגַם־אַתֶּם אֲדֹנִים כֵּן תַּעֲשׂוּ לָהֶם חִדְלוּ מִגְּעָר־בָּם בַּאֲשֶׁר יְדַעְתֶּם כִּי גַם־לָהֶם וְלָכֶם אָדוֹן בַּשָּׁמַיִם אֲשֶׁר אֵין עִמּוֹ מַשּׂוֹא פָנִים׃  
\v 10 \vp י\vp* וְיֶתֶר הַדְּבָרִים אֶחָי הִנְנִי אֹמֵר הִתְעוֹדְדוּ בַאֲדֹנֵינוּ וּבְעֹז גְּבוּרָתוֹ׃  
\v 11 \vp יא\vp* חִגְרוּ כְלֵי־נֶשֶׁק אֱלֹהִים לְמַעַן תּוּכְל לָקוּם לִפְנֵי נִכְלֵי הַשָּׂטָן׃  
\v 12 \vp יב\vp* כִּי לֹא עִם־בָּשָׂר וָדָם מִלְחָמָה לָנוּ אַךְ עִם־אַלּוּפִים וְאֵילִים שַׁלִּיטֵי אֶרֶץ מַאְפֵּלְיָה וּמַלְאֲכֵי רָעִים אֲשֶׁר בַּמְּרוֹמִים׃  
\v 13 \vp יג\vp* עַל־כֵּן קְחוּ לָכֶם כְּלֵי־נֶשֶׁק אֱלֹהִים וְתוּכְלוּ לְהִתְיַצֵּב בִּפְנֵי הַקָּמִים עֲלֵיכֶם בְּיוֹם רָע וּלְהִשָּׁאֵר נִצָּבִים בִּכְלוֹת כָּל־קְרָב׃  
\v 14 \vp יד\vp* עִמְדוּ־נָא מָתְנֵיכֶם חֲגוּרֵי אֱמֶת וְשִׁרְיוֹן צֶדֶק לְבוּשְׁכֶם׃  
\v 15 \vp טו\vp* וּפְעָמֵיכֶם יָפוֹת בַּנְּעָלִים לְבַשֵּׂר בְּשׂרַת הַשָּׁלוֹם׃  
\v 16 \vp טז\vp* וּבַכֹּל עִרְכוּ מָגֵן הָאֱמוּנָה אֲשֶׁר תּוּכְּלוּ לְכַבּוֹת בּוֹ חִצִּים לֹהֲטִים מִיַּד הַצָּר׃  
\v 17 \vp יז\vp* וְהִתְיַצְּבוּ בְכֹבַע הַיְשׁוּעָה וּבְחֶרֶב הָרוּחַ אֲשֶׁר הוּא דְּבַר הָאֱלֹהִים׃  
\v 18 \vp יח\vp* וְהִתְפַּלְּלוּ בְכָל־עֵת כָּל־תְּפִלָּה וּתְחִינָּה מִקֶּרֶב לֵב וָרוּחַ וְשֹׁקְדִים תִּהְיוּ לְהַעְתִּיר וּלְהִתְחַנֵּן בְּעַד כָּל־הַקְּדוֹשִׁים׃  
\v 19 \vp יט\vp* וְגַם־בְּעַד נַפְשִׁי כִּי יוּשַׂם דָּבָר בְּפִי וְעֹז כִּי־אֶפְתַּח שְׂפָתַי לְהַגִּיד סוֹד הַבְּשׁרָה׃  
\v 20 \vp כ\vp* הַבְּשׁרָה אֲשֶׁר אֲנִי מַלְאָכָהּ אָסוּר בִּכְבָלִים וּלְהִנָּתֶן־לִי לְמַלֵּל בְּיָד רָמָה כַּאֲשֶׁר נָכוֹן לִי׃  
\v 21 \vp כא\vp* אַךְ לְבַעֲבוּר תֵּדְעוּן מָה עִמָּדִי וְכָל־אֲשֶׁר אֲנִי עֹשֶׂה הִנֵּה טוּכִיקוֹס הָאָח הָאָהוּב וְהַמְשָׁרֵת הַנֶּאֱמָן לַאֲדֹנֵינוּ יַגִּיד לָכֶם כֹּל׃  
\v 22 \vp כב\vp* כִּי לַדָּבָר הַזֶּה שְׁלַחְתִּיו אֲלֵיכֶם לְהוֹדִיעֲכֶם מַה מַּעֲשֵׂינוּ וּלְנַחֵם אֶת־לִבְּכֶם׃  
\v 23 \vp כג\vp* שָׁלוֹם אַהֲבָה וֶאֱמוּנָה אֶל־הָאַחִים מֵאֵת אֱלֹהִים אָבִינוּ וּמֵאֵת יֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ׃  
\v 24 \vp כד\vp* חֶסֶד לְכָל־הָאֹהֵב אֶת־אֲדֹנֵינוּ יֵשׁוּעַ הַמָּשִׁיחַ בְּאַהֲבָה נִצָּחַת׃   