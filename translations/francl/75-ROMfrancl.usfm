\v 16 \w Car|strong="G1063"\w* \w je|strong="G2532"\w* \w n|strong="G3756"\w*’\w ai|strong="G1510"\w* \w pas|strong="G3756"\w* \w honte|strong="G1870"\w* \w de|strong="G2532"\w* \w l|strong="G2532"\w*’\w Évangile|strong="G2098"\w* ; \w c|strong="G2532"\w*’\w est|strong="G3588"\w* \w une|strong="G2532"\w* \w force|strong="G1411"\w* divine \w pour|strong="G1519"\w* \w le|strong="G2532"\w* \w salut|strong="G4991"\w* \w de|strong="G2532"\w* \w tout|strong="G3956"\w* \w homme|strong="G2532"\w* \w qui|strong="G3588"\w* \w croit|strong="G4100"\w*, \w premièrement|strong="G4412"\w* \w du|strong="G2532"\w* \w Juif|strong="G2453"\w*, \w puis|strong="G2532"\w* \w du|strong="G2532"\w* \w Grec|strong="G1672"\w*\f + \fr 1:16 \ft Au vers. 14, S. Paul, se plaçant au point de vue grec, partageait l’humanité en Grecs et en Barbares ; ici, du point de vue juif ou religieux, il la divise en Juifs et en Grecs.\f*.  
\v 17 \w En|strong="G1722"\w* \w effet|strong="G1063"\w*, \w en|strong="G1722"\w* \w lui|strong="G1519"\w* \w est|strong="G3588"\w* \w révélée|strong="G3588"\w* \w une|strong="G1722"\w* \w justice|strong="G1343"\w* \w de|strong="G1537"\w* \w Dieu|strong="G2316"\w* \w qui|strong="G3588"\w* \w vient|strong="G3588"\w* \w de|strong="G1537"\w* \w la|strong="G1722"\w* \w foi|strong="G4102"\w* \w et|strong="G1161"\w* \w est|strong="G3588"\w* destinée \w à|strong="G1519"\w* \w la|strong="G1722"\w* \w foi|strong="G4102"\w*, \w selon|strong="G2531"\w* \w qu|strong="G1063"\w*’\w il|strong="G1161"\w* \w est|strong="G3588"\w* \w écrit|strong="G1125"\w* : « \w Le|strong="G1722"\w* \w juste|strong="G1342"\w* \w vivra|strong="G2198"\w* \w par|strong="G1722"\w* \w la|strong="G1722"\w* \w foi|strong="G4102"\w*\f + \fr 1:17 \ft Une justice de Dieu, c’est-à-dire une justice venant de Dieu et communiquée à l’homme. C’est une justice qui vient de la foi, a son principe dans la foi \fq ex fide\ft , et est destinée à la foi \+qt in fidem\+qt*, c’est-à-dire est accordée à la foi. La suite de l’Épître explique les caractères de cette justice brièvement résumée en ces deux termes \+qt ex fide, in fidem\+qt*.\f*. »   
\ms1 PREMIÈRE PARTIE [DOGMATIQUE]. [I, 18 — 11, 36.] DE LA JUSTIFICATION PAR LA FOI.  
\s1 SECTION 1 [I, 18 — 4, 25.] Nécessité de la justification.  
\s2 1. Chap. 1, 18-32. Les peuples païens : Méconnaissance coupable du vrai Dieu (18-25). Le jugement divin (24-32).  
\p
\v 18 \w En|strong="G1722"\w* \w effet|strong="G1063"\w*, \w la|strong="G2532"\w* \w colère|strong="G3709"\w* \w de|strong="G2532"\w* \w Dieu|strong="G2316"\w* \w éclate|strong="G2316"\w* \w du|strong="G2532"\w* \w haut|strong="G1722"\w* \w du|strong="G2532"\w* \w ciel|strong="G3772"\w* \w contre|strong="G1909"\w* \w toute|strong="G3956"\w* \w impiété|strong="G3956"\w* \w et|strong="G2532"\w* \w toute|strong="G3956"\w* \w injustice|strong="G3956"\w* \w des|strong="G2532"\w* \w hommes|strong="G2532"\w*, \w qui|strong="G3588"\w*, \w par|strong="G1722"\w* \w leur|strong="G2532"\w* \w injustice|strong="G3956"\w*, \w retiennent|strong="G2722"\w* \w la|strong="G2532"\w* \w vérité|strong="G1722"\w* captive ;  
\v 19 \w car|strong="G1063"\w* \w ce|strong="G3588"\w* \w qui|strong="G3588"\w* \w se|strong="G3588"\w* peut \w connaître|strong="G5319"\w* \w de|strong="G1722"\w* \w Dieu|strong="G2316"\w*, \w est|strong="G3588"\w* \w manifeste|strong="G5319"\w* \w parmi|strong="G1722"\w* \w eux|strong="G1722"\w* : \w Dieu|strong="G2316"\w* \w le|strong="G1722"\w* \w leur|strong="G1722"\w* \w a|strong="G1722"\w* \w manifesté|strong="G5319"\w*\f + \fr 1:19 \ft Ce qui se peut connaître, ce que la raison naturelle nous apprend de son existence et de sa nature.\f*.  
\v 20 \w En|strong="G2532"\w* \w effet|strong="G1063"\w* \w ses|strong="G2532"\w* perfections invisibles, \w son|strong="G2532"\w* \w éternelle|strong="G1411"\w* \w puissance|strong="G1411"\w* \w et|strong="G2532"\w* \w sa|strong="G2532"\w* \w divinité|strong="G2305"\w* \w sont|strong="G3588"\w*, \w depuis|strong="G2532"\w* \w la|strong="G2532"\w* \w création|strong="G2937"\w* \w du|strong="G2532"\w* \w monde|strong="G2889"\w*, rendues \w visibles|strong="G3588"\w* \w à|strong="G1519"\w* \w l|strong="G2532"\w*’\w intelligence|strong="G3539"\w* \w par|strong="G2532"\w* \w le|strong="G2532"\w* moyen \w de|strong="G2532"\w* \w ses|strong="G2532"\w* \w œuvres|strong="G2532"\w*. \w Ils|strong="G2532"\w* \w sont|strong="G3588"\w* \w donc|strong="G2532"\w* inexcusables,  
\v 21 \w puisque|strong="G1360"\w*, \w ayant|strong="G2532"\w* \w connu|strong="G1097"\w* \w Dieu|strong="G2316"\w*, \w ils|strong="G2532"\w* \w ne|strong="G3756"\w* \w l|strong="G2532"\w*’\w ont|strong="G3588"\w* \w pas|strong="G3756"\w* \w glorifié|strong="G1392"\w* \w comme|strong="G5613"\w* \w Dieu|strong="G2316"\w* \w et|strong="G2532"\w* \w ne|strong="G3756"\w* \w lui|strong="G2532"\w* \w ont|strong="G3588"\w* \w pas|strong="G3756"\w* \w rendu|strong="G2532"\w* \w grâces|strong="G2168"\w* ; \w mais|strong="G2532"\w* \w ils|strong="G2532"\w* \w sont|strong="G3588"\w* \w devenus|strong="G2532"\w* vains \w dans|strong="G1722"\w* \w leurs|strong="G2532"\w* \w pensées|strong="G1261"\w*, \w et|strong="G2532"\w* \w leur|strong="G2532"\w* \w cœur|strong="G2588"\w* \w sans|strong="G2532"\w* \w intelligence|strong="G3756"\w* \w s|strong="G2532"\w*’\w est|strong="G3588"\w* enveloppé \w de|strong="G2532"\w* \w ténèbres|strong="G4654"\w*.  
\v 22 Se \w vantant|strong="G5335"\w* d’\w être|strong="G5335"\w* \w sages|strong="G4680"\w*, ils sont devenus \w fous|strong="G3471"\w* ;  
\v 23 \w et|strong="G2532"\w* \w ils|strong="G2532"\w* \w ont|strong="G3588"\w* échangé \w la|strong="G2532"\w* majesté \w du|strong="G2532"\w* \w Dieu|strong="G2316"\w* \w incorruptible|strong="G1722"\w* \w pour|strong="G2532"\w* \w des|strong="G2532"\w* \w images|strong="G1504"\w* \w représentant|strong="G3667"\w* \w l|strong="G2532"\w*’\w homme|strong="G2532"\w* \w corruptible|strong="G5349"\w*, \w des|strong="G2532"\w* \w oiseaux|strong="G4071"\w*, \w des|strong="G2532"\w* \w quadrupèdes|strong="G5074"\w* \w et|strong="G2532"\w* \w des|strong="G2532"\w* \w reptiles|strong="G2062"\w*\f + \fr 1:23 \ft Sag. 13, 2, 10\ft  ; 14, 14 sv.\f*.   
\p
