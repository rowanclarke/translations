\id EZK - Biblica® Open Igbo Contemporary Bible 2020
\h Izikiel
\toc1 Izikiel
\toc2 Izikiel
\toc3 Izk
\mt1 Izikiel
\c 1
\s1 Ọhụ mbụ Izikiel hụrụ
\p 
\v 1 O ruo nʼafọ nke iri atọ, nʼọnwa nke anọ, nʼụbọchị nke ise ya, mgbe mụ onwe m na ndị ahụ e mere ka ha gaa biri na mba ọzọ nọ nʼakụkụ iyi ukwu Keba, na e meghere eluigwe mee ka m hụ ọhụ dị iche iche site nʼaka Chineke.
\p 
\v 2 Nʼụbọchị nke ise nʼọnwa ahụ, ọ bụ nʼafọ nke ise mgbe a dọkpụụrụ eze Jehoiakin jee mba ọzọ,
\v 3 okwu \nd Onyenwe anyị\nd* ruru Izikiel onye nchụaja nwa Buzi ntị, mgbe ọ nọ nʼakụkụ iyi ukwu Keba, nke dị nʼala ndị Kaldịa.\f + \fr 1:3 \ft Kaldịa bụkwa \fqa Babilọn\f* Nʼebe ahụ kwa ka aka \nd Onyenwe anyị\nd* nọ dịkwasị ya nʼahụ.
\p 
\v 4 Elere m anya hụ oke ifufe nke si nʼugwu na-abịa, ahụkwara m oke igwe ojii na amụma nke na-egbuke egbuke; ìhè nke na-enwu nnọọ vaa gbara ya gburugburu. Etiti ọkụ ahụ nwere ihe dịka ọlaọkụ na-amụke amụke.
\v 5 Ihe e kere eke anọ dị ndụ, nke yiri mmadụ nʼụdịdị ha, nọkwa nʼetiti oke ihe ahụ.
\v 6 Nke ọbụla nʼime ha nwere ihu anọ, na nku anọ.
\v 7 Ụkwụ ha guzoro kwem; ọbụ ụkwụ ha dịka nke nwa ehi, na-amụkekwa dịka bronz e hichara nke ọma.
\v 8 Nʼokpuru nku ha, ha nwere aka yiri aka mmadụ nʼakụkụ anọ ha niile. Otu a ka ihu ha na nku anọ dị.
\v 9 Nku ha na-emetụ na nke ibe ha. Mgbe ha na-efe, ha na-eche ihu ha nʼotu ụzọ, ha adịghị agha anya ha nʼazụ mgbe ha na-aga.
\p 
\v 10 Maka oyiyi ihu ha: Ha anọ nwere ihu mmadụ, nʼakụkụ aka nri ha nwere ihu ọdụm, nʼakụkụ aka ekpe ha bụ ihu ehi, onye ọbụla nwekwara ihu ugo.
\v 11 Otu ahụ ka ihu ha niile dị. Ha gbasara nku ha nʼelu, nke ọbụla nwere nku abụọ, otu nʼime nku ndị a na-emetụ nku nke ibe ya, ebe abụọ kpuchiri ahụ ha.
\v 12 Ha niile gawara nʼihu. Ebe ọbụla mmụọ ahụ gara ka ha na-aga, na-eleghị anya nʼazụ.
\v 13 Nʼetiti ihe ndị a dị ndụ, e nwere ihe dịka icheku ọkụ na-enwu enwu, dịkwa ka ọwa na-enwu ọkụ. Ọkụ na-esi nʼetiti ihe ndị ahụ dị ndụ na-aga ihu na azụ, ọkụ ahụ nwupụrụ enwupụ, amụma eluigwe sikwa na ya egbupụta.
\v 14 Ihe ndị ahụ dị ndụ na-efegharị nʼebe a, na-efegharịkwa nʼebe nke ọzọ, dịka mgbe amụma na-egbu.
\p 
\v 15 Mgbe m na-ele ihe e kere eke dị ndụ ndị a anya, ahụrụ m ụkwụ ụgbọ agha anọ nke dị nʼala nʼokpuru ha. Onye ọbụla nwere nke ya.
\v 16 Ụkwụ ụgbọala ahụ niile dị ka ihe e ji nkume na-egbu maramara a na-akpọ beril\f + \fr 1:16 \ft Nʼakwụkwọ ụfọdụ ị ga-ahụ topaazi\f* kpụọ. Nke ọbụla nʼime ha anọ yikwara ibe ya. Ha niile dịkwa ka wịịlu a kpụrụ tinye nʼetiti ụkwụ ụgbọala buru ibu.
\v 17 Mgbe ha pụrụ, ha na-aga nʼakụkụ anọ nke ha chere ihu ha, ma ụkwụ ụgbọ agha ahụ adịghị echigharị echigharị mgbe ha na-aga.
\v 18 Azụ ụkwụ ụgbọ agha ha dị elu, dịkwa egwu. Anya jupụtakwara nʼazụ ụkwụ ụgbọ agha ndị ahụ.
\p 
\v 19 Mgbe ihe ndị a dị ndụ fepụrụ gaa nʼihu, ụkwụ ụgbọala ndị ahụ dị nʼakụkụ ha na-eso ha. Mgbe ha feliri elu, ụkwụ ndị ahụ na-esokwa.
\v 20 Ebe ọbụla mmụọ ha jere, ebe ahụ ka ha na-aga, ụkwụ ụgbọ agha ahụ na-esokwa ha, nʼihi na mmụọ nke anụ ndị ahụ dị ndụ dị nʼụkwụ ụgbọ agha ndị ahụ.
\v 21 Mgbe ha biliri, ndị ọzọ na-ebilikwa. Mgbe ha guzoro otu ebe, ndị ọzọ na-eguzokwa. Mgbe ha feliri elu, ụkwụ ụgbọala ahụ na-eso ha. Nʼihi na mmụọ anụ ndị ahụ dị ndụ dị nʼime ụkwụ ụgbọ agha ndị ahụ.
\p 
\v 22 A tụsara ihe sara mbara dịka mbara eluigwe nʼelu isi ihe ndị ahụ dị ndụ. Ọ na-eyi egwu, ma na-egbukwa nweghenweghe dịka kristal.
\v 23 Nʼokpuru ihe ahụ ka ha gbasapụrụ nku ha, ka ọ na-emetụ nke ibe ya. Ha niile nʼotu nʼotu nwere nku abụọ nke na-ekpuchi ahụ ya.
\v 24 Mgbe ha na-aga, nku ha na-eme mkpọtụ dị ka mkpọtụ ebili mmiri na-amagharị amagharị. Mkpọtụ ahụ dịkwa ka ịda ụda nke olu Onye pụrụ ime ihe niile, ka olu iti mkpu nke usuu ndị agha. Mgbe ọbụla ha guzoro, ha na-achịtu nku ha.
\p 
\v 25 Mgbe ahụ ha kwụsịrị mechie nku ha olu sitere nʼime ihe ahụ dịka mbara eluigwe nke dị nʼelu isi ha na-abịa.
\v 26 Nʼelu mbara eluigwe ahụ, o nwere ihe dịka ocheeze e ji nkume dị oke ọnụahịa a na-akpọ safaia wuo. Otu onye, nke ụdịdị ya dị ka nwoke, nọkwasịkwara nʼelu oche ahụ.
\v 27 Site nʼụkwụ ya ruo nʼisi ya, ahụ onye ahụ na-egbu maramara dịka ọkụ. Site nʼụkwụ ya ruo nʼukwu ya, ọ dị ka ọkụ na-enwu enwu, ìhè nke na-enwukwa ka ọkụ gbara ya gburugburu.
\v 28 Ìhè ahụ gbara ya gburugburu, nke a na-ahụ anya, dịkwa ka ìhè eke na egwurugwu, nke a na-ahụ anya nʼoge mmiri na-ezo.
\p Otu a ka ebube \nd Onyenwe anyị\nd* si gosi m onwe ya. Mgbe m hụrụ ya, adara m nʼala kpuo ihu m nʼala. Mgbe ahụ, anụrụ m olu onye na-ekwu okwu.
\c 2
\s1 Ọkpụkpọ Izikiel
\p 
\v 1 Ọ sịrị m, “Nwa nke mmadụ, bilie ọtọ, guzo nʼụkwụ gị abụọ, nʼihi na ana m aga ịgwa gị okwu.”
\v 2 Mmụọ ahụ banyere nʼime m mgbe ahụ ọ na-ekwu okwu, mee ka m guzo ọtọ nʼụkwụ m abụọ. Anụrụ m ka ọ gwara m okwu.
\p 
\v 3 Ọ sịrị m, “Nwa nke mmadụ, ana m eziga gị ka i jekwuru ndị Izrel, ndị bụ mba na-enupu isi, ndị nupuru isi megide m. Ha na nna nna ha enupula isi megide m, ruo ọ bụladị nʼụbọchị taa.
\v 4 Ndị ahụ m na-eziga gị ka i jekwuru bụ ndị isiike na ndị nnupu isi. Sị ha, ‘Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu.’
\v 5 Ma ha gere gị ntị, ma ha egeghị gị ntị (ha bụ ndị na-enupu isi), ihe dị mkpa bụ na ha ga-amata na onye amụma anọọla nʼetiti ha.
\v 6 Ma gị nwa nke mmadụ, atụla ha egwu. Ka ụjọ okwu si ha nʼọnụ ghara ịtụkwa gị. Atụla egwu, ọ bụladị ma a sị na ogwu na uke gbara gị gburugburu, ọ bụladị ma a sị na i bi nʼetiti ụmụ akpị. Ka ụjọ ghara ịtụ gị nʼihi okwu ọnụ ha, ekwekwala ka ha menye gị egwu, nʼihi na ha bụ ndị na-enupu isi.
\v 7 Ị ghaghị izi ha ozi m ziri gị zie ha, ma ha gere ntị ma ha egeghị ntị, nʼihi na ha bụ ndị na-enupu isi.
\v 8 Ma gị, nwa nke mmadụ, gee ntị nʼihe m na-agwa gị. Enupula isi dịka ha si nupu isi. Meghee ọnụ gị taa ihe m ga-etinye gị nʼọnụ.”
\p 
\v 9 Otu mgbe ahụ, elere m anya hụ aka e setịpụrụ, nke ji akwụkwọ a fụkọrọ afụkọ,
\v 10 nke e dekwara ihe nʼime ya, ihu na azụ ya. Aka ahụ ji ya gbasapụrụ ya mee ka m hụ ihe e dere nʼime ya. Ọ bụ okwu ịkwa akwa na iru ụjụ na ahụhụ.
\c 3
\p 
\v 1 Ọ sịrị m, “Nwa nke mmadụ, rie ihe a m gaje inye gị. Taa akwụkwọ a a fụkọrọ afụkọ; pụọ gaa gwa ụmụ Izrel okwu.”
\v 2 Ya mere, a saghere m ọnụ m, o nyere m akwụkwọ ahụ a fụkọrọ afụkọ ka m rie.
\p 
\v 3 Ọ sịrị m, “Nwa nke mmadụ, taa akwụkwọ a niile m nyere gị, tajuo ya afọ gị.” Atara m ya. Ma mgbe m na-ata ya, ọ tọrọ m ụtọ nʼọnụ dịka a ga-asị na ọ bụ mmanụ aṅụ.
\p 
\v 4 Ọ sịrị m, “Nwa nke mmadụ, bilie jekwuru ụmụ Izrel gwa ha okwu m niile.
\v 5 Nʼihi na-ezighị m gị ka i jekwuru mba ndị okwu ha edoghị anya na ndị a naghị aghọta asụsụ ha, kama ọ bụ ijekwuru ụlọ Izrel.
\v 6 Ezikwaghị m gị ka i jekwuru mba nwere asụsụ na-edoghị anya, nke ị na-adịghị aghọta okwu ha. Nʼihi na a sị na ọ bụ ndị dị otu a ka m zigara gị ka i jekwuru, ha gaara ege gị ntị.
\v 7 Ma ụlọ Izrel agaghị ekwe gee gị ntị, nʼihi na ha jụrụ ige m ntị. Nʼihi na ụlọ Izrel bụ ndị obi ha siri ike, na ndị isiike.
\v 8 Lee, emeela m ka ihu gị sie ike karịa nke ha, ka egedege ihu gị siekwa ike karịa nke ha.
\v 9 Aga m emekwa ka egedege ihu gị dị ka nkume siri ike, sie ike karịa nkume. Nʼihi ya, atụla ha egwu; ọ bụ ezie na ha bụ ndị na-enupu isi, ma atụla ihu ha egwu.”
\p 
\v 10 Ọ sịrị m, “Nwa nke mmadụ, gee ntị nke ọma nʼokwu ndị a niile m na-agwa gị, tinyekwa ha nʼuche gị.
\v 11 Jekwuru ndị gị a dọtara nʼagha nọ na mba ọzọ, sị ha, ‘Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu,’ Gwa ha ya, ma ha gere gị ntị ma ha egeghị gị ntị.”
\p 
\v 12 Mgbe ahụ, Mmụọ ahụ buliri m elu. Anụrụ m olu mere oke ụzụ nʼazụ m, mgbe ebube nke \nd Onyenwe anyị\nd* sị nʼọnọdụ ya bilie.
\v 13 Ọ bụ ụzụ nke nku ihe ndị ahụ dị ndụ na-eme mgbe ha na-emetụrịta nku ibe ha; ọ bụkwa ụzụ ụkwụ wịịlu ha nke dị nʼakụkụ ha.
\v 14 Mmụọ ahụ buliri m, bupụ m. Ejegharịrị m nʼobi ilu na iwe nke mmụọ m, ebe aka \nd Onyenwe anyị\nd* dịkwa ike nʼahụ m.
\v 15 A bịakwutere m ndị ahụ a dọọrọ nʼagha, ha aga biri na Tel Abib\f + \fr 3:15 \ft Nʼime akwụkwọ ụfọdụ aha ị ga-ahụ bụ Tel Aviv\f* nʼakụkụ osimiri Keba. Nʼebe ahụ, bụ ebe ha na-ebi, anọdụrụ m nʼetiti ha abalị asaa, nʼọnọdụ obi ilu na ọnụma.
\s1 Ọrụ Izikiel dịka onye nche
\p 
\v 16 Mgbe abalị asaa gasịrị, okwu \nd Onyenwe anyị\nd* bịakwutere m,
\v 17 “Nwa nke mmadụ, emeela m gị ka ị bụrụ onye nche nye ụlọ Izrel. Nʼihi ya, gee ntị nʼihe m na-ekwu, ka ị dọọrọ m ha aka na ntị.
\v 18 Mgbe m na-asị onye ajọ omume, ‘Ị ghaghị ịnwụ,’ ma ọ bụrụ na ị dọghị ya aka na ntị, maọbụ ị kwughị okwu ime ka ha chigharịa site nʼụzọ ọjọọ ha niile pụta nʼihi ịzọpụta ndụ ha, onye ahụ na-emebi iwu ga-anwụ nʼihi mmehie ya niile, ma nʼaka gị ka m ga-ajụta ọbara ha.
\v 19 Ma ọ bụrụ na ị dọọ onye ajọ omume aka na ntị, ma ha esighị nʼajọ omume maọbụ nʼụzọ ọjọọ ha niile chigharịa, ha ga-anwụ nʼihi mmehie, ma ndụ gị ka ị zọpụtara.
\p 
\v 20 “Ma ọ bụrụ na onye ezi omume esite nʼụzọ ezi omume ya wezuga onwe ya bido ime ihe ọjọọ, m siere ha ọnya,\f + \fr 3:20 \ft Itinye ihe ịsọ ngọngọ nʼụzọ mmadụ\f* ha ga-anwụ nʼihi na ị dọghị ha aka na ntị, ha ga-anwụ nʼihi mmehie ha. Agaghịkwa echeta ihe ọma niile ndị ha mere, ma ị ga-aza ajụjụ maka ọnwụ ha.
\v 21 Ma ọ bụrụ na ị dọọ onye ezi omume aka na ntị ka ọ ghara ime mmehie, ha gharakwa ime mmehie, ha ga-adị ndụ nʼihi na ha nabatara ịdọ aka na ntị ahụ. Gị onwe gị azọpụtakwala ndụ gị, nʼụzọ dị otu a.”
\p 
\v 22 Aka \nd Onyenwe anyị\nd* dịgidesịrị ike nʼahụ m nʼebe ahụ. Ma ọ sịrị m, “Bilie gaa nʼebe ahụ obosara ala dị ka m gwa gị okwu nʼebe ahụ,”
\v 23 Ebiliri m gaa nʼebe ahụ ala dị larịị. Ebube Onyenwe anyị guzo nʼebe ahụ dịka ebube nke m hụrụ nʼakụkụ iyi Keba. Adara m kpuo ihu m nʼala.
\p 
\v 24 Mgbe ahụ, Mmụọ ahụ banyere nʼime m mee ka m guzo ọtọ nʼụkwụ m abụọ. Ọ gwara m okwu sị m, “Gaa, baa nʼụlọ, mechibido onwe gị ụzọ.
\v 25 Ma gị, nwa nke mmadụ, a ga-eji ụdọ kee gị ka ị ghara inwe ike ịpụ gaa nʼetiti ndị mmadụ.
\v 26 Aga m eme ka ire gị rapara nʼakpo ọnụ gị, ka ị ghọọ onye ogbi, gharakwa ịbụ onye na-adọ ha aka na ntị, nʼihi na ha bụ ndị na-enupu isi.
\v 27 Ma mgbe ọbụla m ziri gị ozi, aga m atọghepụ ire gị. Ị ga-asịkwa ha, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru.’ Ka onye nwere ntị nụrụ, ka onye nke na-achọghị ịnụ ghara ịnụ, nʼihi na ha bụ ndị na-enupu isi.
\c 4
\s1 Ndị iro gbara Jerusalem gburugburu
\p 
\v 1 “Ugbu a, gị nwa nke mmadụ, were otu ọkpụrụkpụ aja, tọgbọ ya nʼihu gị. Sepụtakwa obodo Jerusalem nʼelu ya.
\v 2 Seekwa ihe nnọchigide nʼagha megide ya, wuokwa ụlọ ndị agha gburugburu ya, wukọta ụlọ ikwu dị iche iche megide ya na ihe e ji akụdasị mgbidi ya niile.
\v 3 Werekwa efere igwe debe nʼetiti gị na obodo ahụ dịka mgbidi e ji igwe wuo. Chee obodo ahụ ihu gị, ka ị chegide ya nke ọma nʼihi na ndị iro gbara ya gburugburu. Nke a ga-abụ ihe ama nye ndị Izrel.
\p 
\v 4 “Ugbu a, dinara ala nʼakụkụ aka ekpe gị, aga m enye gị ntaramahụhụ mmehie ndị Izrel, ị ga-ata ahụhụ mmehie ha ụbọchị niile nke ị ga-edina nʼakụkụ gị.
\v 5 Nʼihi na ana m enye gị narị ụbọchị atọ na iri ụbọchị itoolu, ọnụọgụgụ nke a na ọnụọgụgụ nke afọ ntaramahụhụ ha ga-abụ otu, ọ bụ oge ha. Otu a ka ị ga-esi buru mmehie Izrel.
\p 
\v 6 “Mgbe i mesịrị nke a, ị ga-edina ala nke ugboro abụọ, ma ọ ga-abụ nʼakụkụ aka nri gị, ị ga-eburu ntaramahụhụ mmehie ndị Juda. Ọ bụ iri abalị anọ, otu ụbọchị ga-anọchi anya otu afọ.
\v 7 Chee ihu gị nʼebe nnọchibido Jerusalem, gbara aka nkịtị buo amụma megide ya.
\v 8 Aga m eke gị eriri ahụ gị niile, ka ị ghara inwe ike tụgharịa site nʼotu akụkụ gaa nʼakụkụ nke ọzọ tutu ụbọchị nnọchigide gị ahụ niile ezuo.
\p 
\v 9 “Ma gị were ọka wiiti na ọka balị, werekwa akịdị na lentil, na ọka milet na spelti. Tinyekọta ha nʼotu ite were ha meere onwe gị achịcha. Nʼụbọchị ole ahụ niile nke ị ga-edina nʼakụkụ gị, narị ụbọchị atọ na iri ụbọchị itoolu, ọ bụ ya ka ị ga-eri.
\v 10 A ga-atụ ihe oriri gị atụ, nri nke ị ga-eri otu mgbe ga-abụ narị gram abụọ na iri gram atọ; naanị otu mgbe ka ị ga-eri nri nʼụbọchị.
\v 11 A ga-ekupụtakwa mmiri ị ga-aṅụ, ị ga-aṅụ mmiri naanị otu ugboro nʼụbọchị, otu udu mmiri e kere ụzọ isii.\f + \fr 4:11 \ft Nke a bụ otu ụzọ site nʼụzọ isii nke e kere otu lita mmiri.\f*
\v 12 Ị ga-eri ya dịka ogbe achịcha ọka balị, ị ga-eghe ya nʼelu nsị mmadụ kpọrọ nkụ mgbe ndị mmadụ nọ na-ele gị anya.”
\v 13 \nd Onyenwe anyị\nd* kwuru, “Otu a ka ndị Izrel ga-esi rie nri rụrụ arụ, nʼetiti mba dị iche iche ebe m ga-achụga ha.”
\p 
\v 14 Mgbe ahụ, asịrị m, “E e, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* lee, emerụbeghị m onwe m site na nwantakịrị m ruo ugbu a, eribeghị ihe ọbụla nwụrụ nʼonwe ya, maọbụ nke anụ ọhịa dọgburu, anụ na-adịghị ọcha abatụbeghị m nʼọnụ.”
\p 
\v 15 Ọ sịrị, “Ọ dị mma, aga m enye gị nsị ehi nʼọnọdụ nke mmadụ, nʼelu ya ka ị ga-akwado achịcha gị.”
\p 
\v 16 Mgbe ahụ, ọ gwara m, “Nwa nke mmadụ, lee, aga m eme ka nri kọ na Jerusalem; ha ga-eji nchegbu rie nri a tụpụtara atụpụta, jirikwa egwu ṅụọ mmiri e kupụtara ekupụta.
\v 17 Aga m eme ka ihe oriri na mmiri ọṅụṅụ kọọ ha. Ha ga na-elerịta onwe ha anya nʼoke egwu, ha ga-anwụkwa nʼihi mmehie ha.”
\c 5
\s1 Agụba nke ikpe ọmụma Chineke
\p 
\v 1 “Ma gị, nwa nke mmadụ, were mma agha dị nkọ dịka agụba onye ọkpụisi, kpụchaa isi gị na afụọnụ gị; werekwa ihe e ji atụ ihe ọtụtụ tụọ agịrị isi gị, ka ụzọ ọbụla hara nʼotu.
\v 2 Ị ga-ewere otu ụzọ nʼụzọ atọ, kpọọ ya ọkụ nʼetiti obodo ahụ mgbe ụbọchị nke nnọchigide ahụ zuru; ị ga-ewere otu ụzọ, jiri mma agha chabichaa ya gburugburu obodo ahụ, otu ụzọ nke ọzọ ka ị ga-efesacha nʼikuku. Nʼihi na aga m eji mma agha chụsachaa ha.
\v 3 Ma ị ga-esite nʼime ya wepụta agịrị isi dị ole na ole, kedo ha nʼọnụ ọnụ uwe gị.
\v 4 Ọzọkwa, site na ndị a, ị ga-ewere ụfọdụ tụnye ha nʼime ọkụ ka ha ree ọkụ, site na ha ka ọkụ ga-esi banye nʼụlọ Izrel niile.
\p 
\v 5 “Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, Nke a bụ Jerusalem, obodo m mere ka ọ dịrị nʼetiti mba dị nʼụwa, nke mba dị iche iche gbara gburugburu.
\v 6 Ma o sitela nʼajọ omume ya, nupu isi nʼiwu na ụkpụrụ m nyere, karịa mba na obodo ndị ọzọ ahụ niile gbara ya gburugburu. Ọ jụkwara idebe iwu m, jụkwa ịgbaso ụkpụrụ m.
\p 
\v 7 “Nʼihi ya, ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu: Ị bụrụla onye nnupu isi karịa mba niile ndị gbara gị gburugburu. Ị jụkwara idebe iwu m na ịgbaso ụkpụrụ m, ọ bụghịkwa dịka iwu na atụmatụ nke mba dị iche iche nọ gị gburugburu ka ị mere.
\p 
\v 8 “Ya mere, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị, Mụ onwe m, ọ bụladị mụ onwe m, ga-emegide gị bụ Jerusalem, kpee gị ikpe nʼihu mba niile.
\v 9 Nʼihi ihe arụ gị niile, aga m eme gị ihe m na-emebeghị mbụ, nke m agaghị emekwa ọzọ.
\v 10 Nʼihi nke a, ndị bụ nna ga-eri ụmụ ha nʼetiti gị, ụmụ ga-erikwa ndị nna ha. Aga m ekpe gị ikpe mee ka ndị fọdụrụ ndụ gbasasịa nʼụwa niile.
\v 11 Ya mere, dịka mụ onwe m na-adị ndụ, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara, ebe ọ bụ na i jirila oyiyi ihe arụ na omume rụrụ arụ merụọ ụlọ m, aga m esite nʼebe ị nọ wezuga ịhụnanya m. Agaghị m emekwara gị ebere maọbụ hapụ ịta gị ahụhụ.
\v 12 Otu ụzọ nʼime ụzọ atọ nke ndị bi nʼime gị ga-anwụ site nʼagụụ maọbụ na ọrịa; otu ụzọ ga-anwụ site na mma agha nke ndị iro nọ nʼazụ mgbidi gị, otu ụzọ fọdụrụ ka a ga-achụsa nʼifufe, a ga-eji mma agha ndị iro chụsasịa ha.
\p 
\v 13 “Mgbe ahụ, iwe m ga-akwụsị, ọnụma m megide ha ga-adajụkwa, na nke a ka a ga-abọrọ m ọbọ. Ha ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd* kwuru okwu site nʼekworo mgbe m mezuru ọnụma m nʼahụ ha.
\p 
\v 14 “Nʼihi ya, aga m eme ka ị bụrụ ihe e bibiri ebibi, na ihe e ji eme ihe ọchị nye mba niile gbara gị gburugburu, na nʼihu ndị na-agafe nʼụzọ ahụ.
\v 15 Ị ga-abụ ihe e ji eme ihe ọchị na ihe nkọcha nye mba dị iche iche gbara gị gburugburu, mgbe m ga-eji iwe na obi ọkụ na ntaramahụhụ dị egwu kpee gị ikpe, mụ onwe m bụ \nd Onyenwe anyị\nd* ekwuola.
\v 16 Mgbe m gbara gị àkụ ọjọọ ahụ na-eweta ọnwụ na ịla nʼiyi, bụ àkụ nke oke ụnwụ, aga m agba gị ya, gbajaa gị. Aga m anọgide na-ezite ụnwụ tutu ruo mgbe e mere ka ihe oriri kọọ gị.
\v 17 Aga m ezitere gị oke ụnwụ na ajọ anụ ọhịa, ha ga-agbawa gị aka nwa, ọrịa ọjọọ na ọbara ga-esi nʼetiti gị gafee; aga m eji mma agha megide gị. Mụ onwe m bụ \nd Onyenwe anyị\nd* ekwuola.”
\c 6
\s1 Mbibi dịrị ugwu Izrel niile
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, chee iru gị nʼugwu niile nke nʼIzrel, buo amụma megide ha,
\v 3 sị, ‘Unu ugwu niile nke Izrel, nụrụnụ okwu nke Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị nye ugwu ukwu na ugwu nta niile, na iyi mmiri niile, na ndagwurugwu niile. Mụ, ọ bụladị mụ onwe m, ga-eme ka agha bịakwasị unu, aga m ebibikwa ebe dị iche iche unu na-achụ aja.
\v 4 A ga-etikpọ ebe ịchụ aja unu, tipịa ebe unu na-anọ esure ihe nsure ọkụ na-esi isi ụtọ. Aga m atụsa ndị unu e gburu egbu nʼihu arụsị unu.
\v 5 Aga m atọgbọ ozu ndị Izrel nʼihu arụsị ha. Aga m aghasakwa ọkpụkpụ unu gburugburu ebe ịchụ aja unu.
\v 6 Ebe ọbụla unu bi, a ga-etikpọ obodo ndị ahụ, tipịakwa ebe ịchụ aja niile, si otu a mee ka ebe ịchụ aja unu ghọọ mkpọmkpọ ebe nke tọgbọrọ nʼefu. A ga-etipịakwa arụsị unu, kụjiekwa ebe unu na-anọ esure ihe nsure ọkụ na-esi isi ụtọ. Ihe niile unu ji aka unu mepụta ka a ga-ekpochapụkwa.
\v 7 Ndị e gburu egbu ga-ada nʼetiti unu, unu ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\p 
\v 8 “ ‘Ma aga m eme ka ụfọdụ nʼime ndị m fọdụ. Ndị ahụ fọdụrụ ga-esi nʼihu mma agha gbapụ, gbasasịa nʼala niile, na mba niile nke ụwa.
\v 9 Mgbe ha nọ dịka ndị a dọtara nʼagha na mba ọzọ, ndị ahụ gbapụrụ ọsọ ga-echeta m. Ha ga-echeta otu ha si jiri obi nke ịkwa iko jupụtara nʼime ya, nke si nʼebe m nọ wezuga onwe ya, na anya nke na-agbaso arụsị ha, mee ka obi jọọ m njọ. Ha ga-akpọ onwe ha asị nʼihi ihe ọjọọ ndị ahụ ha mere, ya na ọchụchụ aja rụrụ arụ ha chụrụ.
\v 10 Ha ga-amata na m bụ \nd Onyenwe anyị\nd*, matakwa na mgbe m gwara ha na ihe ndị a niile gaje ịbịakwasị ha, na ọ bụghị okwu efu ka m kwuru.
\p 
\v 11 “ ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị, kụkọọ ọbọ aka gị abụọ ọnụ, zọkwaa ụkwụ gị nʼala, ma tisikwaa mkpu akwa ike site nʼobi mwute, nʼihi ihe ọjọọ niile na omume rụrụ arụ ndị Izrel mere. Nʼihi na ha ga ịla nʼiyi site nʼoke ụnwụ, na site nʼagha, na site nʼọrịa na-efe efe.
\v 12 Ndị nọ nʼebe dị anya ga-anwụ site nʼọrịa na-efe efe, ndị nọ nso ga-anwụ site na mma agha, ndị fọdụrụ ndụ ga-anwụ site nʼagụụ. Aga m eme ka ha nụrụ ụfụ oke iwe m.
\v 13 Unu ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*, mgbe ozu ndị e gburu egbu ga-atọgbọsị nʼetiti arụsị niile, na nʼebe ịchụ aja niile, na nʼugwu nta niile, na nʼugwu ukwu niile, na nʼokpuru osisi ọbụla, na nʼokpuru osisi ook niile, ebe ha na-anọ na-esure ụda na-esi isi ụtọ nye arụsị ha.
\v 14 E, aga m esetipụ aka m megide ha, mee ka ala ha laa nʼiyi, nʼebe niile ha bi, site nʼọzara\f + \fr 6:14 \ft Maọbụ, \fqa mbara ịkpa\f* ruo na Ribla. Mgbe ahụ, ha ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.’ ”
\c 7
\s1 Ọgwụgwụ abịala
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Ma gị onwe gị, Nwa nke mmadụ, nke a bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị ala Izrel:
\q1 “ ‘Ọgwụgwụ!
\q2 Ọgwụgwụ abịakwasịla akụkụ anọ nke ala ahụ.
\q1 
\v 3 Ugbu a ka ọgwụgwụ bịakwasịrị unu.
\q2 Lee, aga m eme ka iwe m bịakwasị unu;
\q1 aga m ekpe unu ikpe dịka omume unu si dị,
\q2 aga m ata unu ahụhụ maka arụ unu niile.
\q1 
\v 4 Agaghị m enwekwa ọmịiko nʼebe ị nọ,
\q2 agaghị m emekwara gị ebere,
\q1 kama aga m ata unu ahụhụ maka omume unu
\q2 na arụ niile dị nʼetiti unu.
\b
\m “ ‘Mgbe ahụ, unu ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.’
\b
\p 
\v 5 “Nke a bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị,
\q1 “ ‘Oke mbibi, oke mbibi nke a na-anụbeghị ụdị ya mbụ.
\q2 Lee, ka ọ na-abịa.
\q1 
\v 6 Ọgwụgwụ abịala!
\q2 Ọgwụgwụ abịala!
\q1 Ọ kpalitela onwe ya imegide unu.
\q2 Lee, ka ọ na-abịa!
\q1 
\v 7 Oke nsogbu abịakwasịla gị,
\q2 gị onwe gị bi nʼala ahụ.
\q1 Oge ahụ abịala! Ụbọchị ahụ dịkwa nso!
\q2 Ọgbaaghara dị ebe niile, ọ bụghị ọṅụ dị nʼelu ugwu niile.
\q1 
\v 8 Ejikerela m ịwụkwasị gị ọnụma m nʼahụ
\q2 mee ka oke iwe m zuo gị ahụ niile.
\q1 Aga m ekpe gị ikpe dịka omume gị si dị,
\q2 kwụghachikwa gị nʼihi ibi ndụ rụrụ arụ gị niile.
\q1 
\v 9 Agaghị m emere gị ebere,
\q2 agakwaghị m ahapụ ịta gị ahụhụ.
\q1 Aga m akwụghachi gị dịka omume gị si dị,
\q2 kwụghachikwa gị nʼihi ibi ndụ rụrụ arụ niile nke dị nʼetiti unu.
\b
\m “ ‘Mgbe ahụ, ị ga-amata na ọ bụ mụ onwe m bụ \nd Onyenwe anyị\nd*, na-eti unu ihe ndị a.
\q1 
\v 10 “ ‘Lee, ụbọchị ahụ!
\q2 Lee, ka ọ na-abịa!
\q1 Oke nsogbu enupụtala,
\q2 mkpanaka agbala okoko
\q2 nganga amaala ifuru!\f + \fr 7:10 \ft Ya bụ, na nganga na-abawanye\f*
\q1 
\v 11 Ihe ike ebilitala,
\q2 mkpọrọ eji ata ndị ajọ omume ahụhụ.
\q1 O nweghị onye ọbụla nʼime ha nke ga-afọdụ,
\q2 maọbụ igwe mmadụ
\q1 maọbụ ụba ha,
\q2 o nweghịkwa nke bara uru.
\q1 
\v 12 Mgbe ahụ abịala!
\q2 Ụbọchị ahụ abịakwala nso.
\q1 Ka onye na-azụ ahịa ghara ịṅụrị ọṅụ
\q2 ka onye na-ere ere ghara iru ụjụ,
\q2 nʼihi na ọnụma ahụ dịrị igwe mmadụ niile.
\q1 
\v 13 Onye rere ahịa agaghị enwetaghachi
\q2 ngwa ahịa nke erere ere
\q2 ọ bụladị dịka onye rere na onye zụrụ na-adị ndụ.
\q1 Nʼihi na ọhụ nke a gbasara igwe mmadụ niile
\q2 bụ nke a na-apụghị ịgbanwe.
\q1 Nʼihi mmehie ha niile, o nweghị onye nʼime ha
\q2 nke pụrụ ichebe ndụ ya.
\b
\q1 
\v 14 “ ‘Ha afụọla opi ike,
\q2 ha edoziela ihe niile
\q1 ma o nweghị onye ga-aga ibu agha
\q2 nʼihi na ọnụma m dịkwasịrị igwe mmadụ ahụ niile.
\q1 
\v 15 Mma agha dị nʼezi;
\q2 ajọ ọrịa na-efe efe na ụnwụ dịkwa nʼime.
\q1 Onye nọ nʼọhịa
\q2 ga-anwụ site na mma agha,
\q1 ndị nọ nʼime obodo ukwu
\q2 ka ụnwụ na ọrịa na-efe efe ga-eripịa.
\q1 
\v 16 Ma ndị gbapụrụ agbapụ
\q2 ga-agbaga nọrọ nʼugwu.
\q1 Ọ bụ dịka nduru nke ndagwurugwu,
\q2 ha niile ga-asụ ude akwa,
\q2 onye ọbụla nʼihi mmehie ha.
\q1 
\v 17 Aka niile ga-akụda,
\q2 ikpere niile ka a ga-eji amịrị nyụdee.
\q1 
\v 18 Ha ga-eyikwasị akwa mkpe,
\q2 oke ihe egwu ga-ekpuchi ha.
\q1 Ọ bụkwa ihu niile ka ihere ga-ekpuchi,
\q2 a ga-akpụchakwa isi niile.
\b
\q1 
\v 19 “ ‘Ha ga-etufu ọlaọcha ha niile nʼokporoụzọ niile,
\q2 ọlaedo ha ga-aghọkwa ihe na-adịghị ọcha.
\q1 Ọlaọcha na ọlaedo ha
\q2 agaghị enwe ike napụta ha
\q2 nʼụbọchị nrubiga oke nke oke iwe \nd Onyenwe anyị\nd*.
\q1 Ha agaghị eme ka agụ gharakwa ịgụ ha,
\q2 maọbụ mee ka afọ ju ha,
\q2 nʼihi na ọ bụụrụ ha ihe ịsọ ngọngọ nke ịdaba na mmehie.
\q1 
\v 20 Ihe ịchọ mma ha ghọọrọ ha ihe ịkpa nganga,
\q2 ha jikwa ya mepụta arụsị rụrụ arụ ha dị iche iche.
\q1 Ha ji ya metakwa oyiyi ihe arụ niile jọgburu onwe ya;
\q2 ya mere, aga m eme ka ọ bụụrụ ha ihe rụrụ arụ.
\q1 
\v 21 Aga m ewere akụnụba ha nye ndị mba ọzọ dịka ihe apụnatara nʼagha,
\q2 nyekwa ya ndị ajọ omume nke ụwa dịka ihe nkwata
\q2 ndị ga-emerụ ya.
\q1 
\v 22 Aga m esite nʼebe ha nọ wezuga ihu m
\q2 ndị ohi ga-emerụkwa ebe ahụ m kpọrọ ihe dị oke ọnụahịa.
\q1 Ha ga-abata nʼime ya
\q2 merụọkwa ya.
\b
\q1 
\v 23 “ ‘Kwadoonụ ụdọ igwe.
\q2 Nʼihi na ala ha jupụtara nʼigbu ọchụ na ịwụsa ọbara,
\q2 obodo ahụ jupụtara nʼihe ike.
\q1 
\v 24 Aga m akpọta mba ndị ahụ jọgburu onwe ha
\q2 ka ha bịa nwetara onwe ha ụlọ ha niile.
\q1 Aga m eme ka mpako nke ndị bụ dike kwụsị,
\q2 meekwa ka ebe nsọ ha niile bụrụ ebe e merụrụ emerụ.
\q1 
\v 25 Mgbe ihe mmekpa ahụ bịara,
\q2 ha ga-achọ udo ma o nweghị nke ga-adị.
\q1 
\v 26 Mbibi ga-esochi mbibi,
\q2 akụkọ na-enweghị isi ga-esochikwa akụkọ na-enweghị isi.
\q1 Ha ga-agagharị na-achọ ọhụ site nʼaka onye amụma,
\q2 ntụziaka onye nchụaja ga-akwụsị,
\q2 ndụmọdụ nke ndị okenye agaghị adịkwa.
\q1 
\v 27 Eze ga-eru ụjụ,
\q2 nwa eze ga-eyikwasị ịda mba nke obi dịka uwe,
\q2 aka ga-ama ndị ala ahụ niile jijiji nʼihi egwu.
\q1 Aga m emeso ha dịka omume ha si dị,
\q2 aga m ekpekwa ha ikpe dịka ihe ha kwenyeere si dị.
\b
\m “ ‘Mgbe ahụ, ha ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.’ ”
\c 8
\s1 Ikpere arụsị nʼụlọ ukwu
\p 
\v 1 Nʼafọ nke isii, nʼọnwa nke isii, nʼụbọchị nke ise nke ọnwa ahụ, mgbe mụ onwe m nọdụ ala nʼụlọ m, ndị okenye Juda na-anọdụkwa ala nʼihu m, aka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* dịkwasịrị m nʼahụ nʼebe ahụ.
\v 2 Ahụrụ m oyiyi yiri mmadụ. Akụkụ oyiyi a nke dị site nʼụkwụ ya ruo nʼala ya na-acha dịka ọkụ, sitekwanụ nʼụkwụ ya rigoo, ọ na-egbu nnọọ amụma dịka nkume amba dị oke ọnụahịa.
\v 3 Oyiyi a setịpụrụ ihe dịka aka mmadụ, jiri ya jide m nʼagịrị isi m. Mgbe ahụ, Mmụọ nke Chineke buliri m elu nʼetiti ala na mbara eluigwe. Nʼime ọhụ nke Chineke, o buuru m jee Jerusalem, nʼọnụ ụzọ ama nke dị nʼugwu, nʼime ogige ya, ebe arụsị ahụ na-akpasu ekworo guzo.
\v 4 Ma, lee, ebube Chineke Izrel jupụtara nʼebe ahụ, dị ka m si hụ ya na mbụ na ndagwurugwu.
\p 
\v 5 Ọ sịrị m, “Nwa nke mmadụ, welie anya gị lee nʼụzọ nke ugwu.” Eweliri m anya m lee nʼụzọ ugwu, ma lee, nʼọnụ ụzọ e si abata nʼime ebe ịchụ aja, ahụrụ m oyiyi arụsị ekworo ka o guzo nʼakụkụ ugwu ya.
\p 
\v 6 Ọ sịrị m, “Nwa nke mmadụ, ị na-ahụ ihe ha na-eme, arụ dị egwu nke ụlọ Izrel na-eme nʼebe a, ihe ndị ga-achụpụ m nʼebe dị anya site nʼebe nsọ m? Ma ị ga-ahụkwa ihe arụ ndị dị ukwuu karịa ndị a.”
\p 
\v 7 O mere ka m guzo nʼọnụ ụzọ ogige ahụ, mgbe m lere anya, ahụrụ m oghere dị nʼaja ụlọ ahụ.
\v 8 Ọ sịrị m, “Nwa nke mmadụ, ugbu a gwupuo aja ụlọ a.” Mgbe m gwupuru ya, ahụrụ m ọnụ ụzọ e si aba nʼebe ahụ.
\p 
\v 9 Ọ sịrị m, “Banye nʼime ka ị hụ ihe arụ ọjọọ niile nke ha na-eme nʼebe a.”
\v 10 Abanyere m hụ na ihe jupụtara nʼahụ ụlọ ahụ bụ naanị oyiyi e sere ese, nke ihe na-akpụ akpụ dịka agwọ dị iche iche, ngwere na anụmanụ rụrụ arụ dị iche iche, tinyekwara arụsị niile nke ụlọ Izrel na-efe.
\v 11 Nʼihu ihe ndị a, ka iri ndị okenye asaa nke ụlọ Izrel, ha na Jaazanaya nwa Shefan guzo nʼebe ahụ. Onye ọbụla nʼime ha ji ihe nsure ọkụ na-esi isi ụtọ nʼaka ya, anwụrụ ọkụ si nʼihe nsure ọkụ ndị a na-agbagokwa elu.
\p 
\v 12 Ọ sịrị m, “Nwa nke mmadụ, ị hụla ihe ndị okenye ụlọ Izrel na-eme nʼọchịchịrị, onye ọbụla nʼime ụlọ ya nʼihu arụsị ya? Ma ha na-asị, ‘\nd Onyenwe anyị\nd* adịghị ahụ anyị, O sitela nʼala anyị wezuga onwe ya.’ ”
\v 13 Ọzọ, ọ sịrị m, “Ị ga-ahụkwa oke ihe arụ karịrị ndị a ha na-eme!”
\p 
\v 14 O mere ka m bịakwa nʼọnụ ụzọ ahụ dị nʼakụkụ ugwu nke ụlọnsọ nke \nd Onyenwe anyị\nd*. Nʼebe ahụ, ahụrụ m ndị inyom nọ na-akwa akwa nʼihi Tamuz, chi ha.
\v 15 Mgbe ahụ, ọ sịrị m, “Ị hụla ihe ndị a, nwa nke mmadụ? Ị ga-ahụkwa ihe arụ ndị dị ukwuu karịa ndị a.”
\p 
\v 16 O mere ka m baa nʼime ogige dị nʼime ụlọ ukwu nke \nd Onyenwe anyị\nd*, nʼebe ahụ, nʼọnụ ụzọ ụlọnsọ ukwu nke \nd Onyenwe anyị\nd*, nʼagbata ebe ịchụ aja na mpụta ọnụ ụlọ ahụ, ka ihe ruru iri mmadụ abụọ na ise guzo, chee ihu ha nʼakụkụ ọwụwa anyanwụ na-efe anyanwụ. Ha gbakụtara ụlọnsọ ukwu nke \nd Onyenwe anyị\nd* azụ mgbe ha na-eche ihu nʼọwụwa anyanwụ na-akpọ isiala nye anyanwụ.
\p 
\v 17 Ọ sịrị m, “Ị hụla nke a, nwa nke mmadụ? Ọ bụ ihe dị nta nye ụlọ Juda, bụ ime ihe arụ niile ndị a ha na-eme nʼebe a? Ha ga-ejikwa ihe ike mejupụta ala, siri otu a na-akpasu m iwe mgbe niile? Lee ka ha si nọgide na-akparị m, na-etinye alaka nʼimi ha.
\v 18 Nʼihi ya, aga m eme ka ha nụrụ ụfụ iwe m, ọ dịkwaghị onye m ga-ahapụ. Ọ bụrụkwa na ha anọgide na-ebe akwa nʼoke olu, agaghị m aṅa ha ntị.”
\c 9
\s1 Ikpe ọmụma dịrị ndị na-ekpere arụsị
\p 
\v 1 Mgbe ahụ, a nụrụ m ka o ji oke olu kpọọ oku sị, “Bịanụ nso, unu bụ ndị ahọpụtara ilekọta obodo a, onye ọbụla jidekwa ngwa agha nʼaka ya.”
\v 2 A hụrụ m ndị ikom isii si nʼọnụ ụzọ ama nke dị nʼakụkụ ebe dị elu na-apụta, nke chere ihu nʼugwu, onye ọbụla jikwa mma agha nʼaka ya. Otu onye nʼime ha yi uwe akwa ọcha, nyarakwa nwa akpa nke ihe e ji ede akwụkwọ dị nʼime ya. Ha niile batara nʼime ụlọnsọ, guzokwa nʼakụkụ ebe ịchụ aja e ji bronz wuo.
\p 
\v 3 Ma ebube nke Chineke Izrel sitere nʼelu cherubim ndị ahụ, ebe ọ nọ na mbụ, bilie bịa guzokwa nʼọnụ ụzọ ụlọnsọ ahụ. Mgbe ahụ, \nd Onyenwe anyị\nd* kpọrọ nwoke ahụ yi uwe akwa ọcha bụ onye nya akpa ahụ nke ihe e ji ede ihe dị nʼime ya,
\v 4 ọ sịrị ya, “Bilie, jegharịa nʼokporoụzọ niile nke obodo Jerusalem, kakwasị akara nʼegedege ihu ndị niile na-akwa akwa na ndị niile na-asụ ude nʼihi ihe arụ niile nke a na-eme nʼime ya.”
\p 
\v 5 Anụkwara m ka ọ gwara ndị ọzọ, “Soronụ ya baa nʼime obodo, gbukwaanụ, unu emekwarala onye ọbụla ebere maọbụ ọmịiko.
\v 6 Gbuonụ ha niile, ndị okenye, na ụmụ okorobịa, na ụmụ agbọghọbịa, na ndị inyom, na ụmụntakịrị. Ma unu emetụkwala onye ọbụla nwere akara ahụ nʼihu ya. Malitenụ nʼebe a, nʼime ụlọnsọ ukwu m.” Ya mere, ha malitere igbu ndị okenye ndị nọ nʼihu ụlọnsọ.
\p 
\v 7 Ọ sịkwara ha, “Merụọnụ ụlọnsọ a! Werekwanụ ozu ndị unu gburu egbu tụjuo nʼime ogige ya! Gaanụ!” Ha pụrụ baa nʼime obodo, bido igbu ndị mmadụ.
\v 8 Mgbe ha nọ na-egbu ndị mmadụ maọbụ naanị m fọdụrụ, adara m nʼala kpuchie ihu m, tie mkpu akwa, sị, “Ewoo, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*! Ị ga-esite nʼoke iwe ị na-eweso Jerusalem bibie ihe niile fọdụrụ nʼIzrel?”
\p 
\v 9 Ọ sịrị m, “Mmehie niile nke ụlọ Izrel na Juda dị ukwuu rie nne. Ala niile jupụtakwara nʼọbara ndị egburu, obodo jupụtakwara nʼikpe ikpe na-ezighị ezi. Nʼihi na ha na-asị, ‘\nd Onyenwe anyị\nd* esitela nʼala anyị wezuga onwe ya. Ọ dịghị ihe \nd Onyenwe anyị\nd* na-ahụ.’
\v 10 Nʼihi ya, agaghị m ahapụ ha, agakwaghị m enwe ọmịiko nʼahụ ha. Aga m akwụghachi ha nʼihi ihe ọjọọ niile ha mere.”
\p 
\v 11 Mgbe ahụ, nwoke ahụ yi uwe akwa ọcha, nke nya akpa nke ihe e ji ede akwụkwọ dị nʼime ya, lọghachiri sị, “Arụchaala m ọrụ i nyere m ịrụ.”
\c 10
\s1 Ebube Chineke apụọ
\p 
\v 1 Mgbe ahụ, elere m anya hụ ocheeze ọma e ji nkume safaia wuo ka ọ pụtara ihe na mbara eluigwe, nʼelu ebe ahụ isi cherubim ndị ahụ dị.
\v 2 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị nwoke ahụ yi uwe akwa ọcha, “Baa nʼetiti ụkwụ ụgbọala ahụ dị nʼokpuru cherubim ndị ahụ. Site nʼetiti cherubim ndị ahụ kpojuo icheku ọkụ nke na-ere ere nʼaka gị, fesachaa ha nʼime obodo ahụ niile.” Ọ bara nʼime ka m nʼele ya anya.
\p 
\v 3 Cherubim ndị ahụ na-eguzo nʼakụkụ ndịda nke ụlọnsọ ahụ mgbe nwoke ahụ banyere. Igwe ojii jupụtakwara nʼogige ime ụlọnsọ ahụ.
\v 4 Mgbe ahụ, ebube \nd Onyenwe anyị\nd* sitere nʼelu cherubim bilie, bịa guzo nʼọnụ ụzọ ụlọnsọ ahụ. Ụlọnsọ ahụ jupụtakwara nʼigwe ojii, ihe nke ebube \nd Onyenwe anyị\nd* jupụtakwara nʼogige ụlọnsọ ahụ.
\v 5 Ụzụ nke nku cherubim ndị ahụ na-eme dịkwa ka olu Chineke Onye pụrụ ime ihe niile. A na-anụkwa ụzụ nku ndị ahụ nʼogige ụlọnsọ ahụ dị nʼezi.
\p 
\v 6 Mgbe \nd Onyenwe anyị\nd* nyere nwoke ahụ yi uwe ezi akwa ọcha iwu, sị, “Gaa nʼetiti cherubim ahụ gụta ụfọdụ icheku ọkụ dị nʼetiti wịịlu ụgbọala ahụ,” nwoke ahụ banyere guzo nʼakụkụ otu wịịlu ahụ.
\v 7 Mgbe ahụ, otu nʼime ndị cherubim ahụ setịpụrụ aka ya nʼebe ọkụ ahụ dị nʼetiti ha. Ọ gụtara ụfọdụ icheku ọkụ tinye nʼaka nwoke ahụ yi uwe akwa ọcha onye weere ya pụọ.
\v 8 Nʼokpuru nku ndị cherubim ahụ ka a na-ahụta ihe yiri aka mmadụ.
\p 
\v 9 Elere m anya hụ wịịlu anọ, nke dị nʼakụkụ cherubim ndị ahụ. Cherubim ọbụla nwere otu wịịlu nʼakụkụ ya. Wịịlu ndị a niile na-egbu maramara dịka nkume beril.
\v 10 Wịịlu anọ ndị ahụ yiri onwe ha. Nke ọbụla nʼime ha dịka wịịlu a rụnyere nʼetiti wịịlu ọzọ.
\v 11 Mgbe ha na-aga, ha niile na-eche ihu nʼakụkụ ọbụla nke cherubim ndị ahụ chere ihu. Wịịlu ndị a adịghị echigharị echigharị mgbe cherubim ndị a na-agagharị. Kama ebe isi cherubim ndị ahụ chere ihu ka wịịlu ndị ahụ na-aga. Ha adịghị elekwa\f + \fr 10:11 \ft Maọbụ, \fqa aghakwa\f* anya nʼazụ dịka ha na-aga.
\v 12 Gburugburu ha, nʼanụ ahụ ha niile, ma nʼazụ ha, ma nʼaka ha, ma na nku ha, ma na wịịlu ndị ahụ, ihe jupụtara ha bụ anya. Anya dị nʼakụkụ ha niile.
\v 13 Aha m nụrụ a na-akpọ wịịlu ndị ahụ bụ, Ọgba gburugburu.
\v 14 Nke ọbụla nʼime cherubim ndị a nwere ihu anọ. Ihu nke mbụ dịka ihu cherub. Nke abụọ dịka ihu mmadụ; nke atọ dịka ihu ọdụm, ma nke anọ dịka ihu ugo.
\p 
\v 15 Mgbe ahụ, Cherubim ndị ahụ buliri onwe ha elu. Ndị a bụ ihe ndị ahụ dị ndụ nke m hụrụ na mbụ nʼakụkụ osimiri Keba.
\v 16 Mgbe cherubim ndị ahụ na-aga, wịịlu ndị ahụ dị nʼakụkụ ha na-eso ha na-aga. Mgbe ha na-achili nku ha i si nʼala bulie onwe ha elu, wịịlu ha na-anọgidekwa nʼakụkụ ha.
\v 17 Mgbe cherubim ndị ahụ guzoro nʼotu ebe, wịịlu ahụ na-eguzokwa. Mgbe ha na-ebuli onwe ha elu, wịịlu ndị ahụ na-ebulikwa onwe ha elu, nʼihi na mmụọ nke ihe ahụ dị ndụ dị nʼime ha.
\p 
\v 18 Emesịa, ebube nke \nd Onyenwe anyị\nd* sitere na mbata ọnụ ụzọ ụlọnsọ ahụ pụọ, gaa guzo nʼelu cherubim ndị ahụ.
\v 19 Mgbe m nọ na-ele anya, cherubim ahụ gbasapụrụ nku ha felie, wịịlu ha niile dịkwa nʼakụkụ ha. Ha guzoro na mbata ọnụ ụzọ nke dị nʼakụkụ ọwụwa anyanwụ nke ụlọ \nd Onyenwe anyị\nd*, na ebube nke Chineke nke Izrel dịkwa nʼelu ha.
\p 
\v 20 Ndị a bụ ihe ndị ahụ dị ndụ, nke m hụrụ nʼokpuru Chineke Izrel nʼakụkụ osimiri Keba, amatara m na ha bụ cherubim.
\v 21 Nke ọbụla nʼime ha nwere ihu anọ na nku anọ, na ihe yiri aka mmadụ nʼokpuru nku ha.
\v 22 Ihu ha yikwara ihu ihe ndị ahụ m hụrụ nʼakụkụ osimiri Keba. Nke ọbụla na-agakwa ije nʼihu ihu na-eleghị anya nʼazụ.
\c 11
\s1 Ikpe ọmụma Chineke nke dịrị Jerusalem
\p 
\v 1 Mgbe ahụ, Mmụọ nke Chineke buliri m mee ka m bịaruo nʼọnụ ụzọ ama ụlọ \nd Onyenwe anyị\nd*, nke dị nʼakụkụ ọwụwa anyanwụ. Nʼebe ahụ, nʼoghere nke ọnụ ụzọ ama ahụ, ahụrụ m iri mmadụ abụọ na ise. Ahụkwara m nʼetiti ha, Jaazanaya nwa Azoa na Pelataya nwa Benaya, bụ ndịisi ndị Izrel.
\v 2 Ọ sịrị m, “Nwa nke mmadụ, ndị a bụ ndị ikom na-agba izu ajọ ihe, na-enyekwa ndụmọdụ ọjọọ niile a na-enye nʼobodo a.
\v 3 Ha na-asị, ‘Oge a ga-ewuzi ụlọ ndị ahụ ọ dịghị nso? Obodo a bụ ite igwe, anyị onwe anyị bụkwa anụ dị nʼime ya.’
\v 4 Nʼihi ya, nwa nke mmadụ, buo amụma megide ha.”
\p 
\v 5 Mgbe ahụ, Mmụọ nke \nd Onyenwe anyị\nd* bịakwasịrị m sị m kwuo, “Otu a ka \nd Onyenwe anyị\nd* sịrị: otu a ka unu na-ekwukwa, unu ndị ndu ụlọ Izrel, ma amaara m ihe unu bụ nʼuche.
\v 6 Unu egbuola ọtụtụ mmadụ nʼime obodo a, meekwa ka okporoụzọ ya jupụta nʼozu ndị nwụrụ anwụ.
\p 
\v 7 “Nʼihi ya ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* ji sị, ozu ndị ahụ niile tọgbọ nʼokporoụzọ obodo unu bụ anụ ndị ahụ unu gburu egbu, obodo a bụkwa ite. Ma aga m eme ka unu site nʼime ya pụta.
\v 8 Mma agha ahụ unu na-atụ egwu ya ka m ga-eme ka ọ bịakwasị unu. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.
\v 9 Aga m esitekwa nʼetiti ya kpọpụta unu, were unu nyefee nʼaka ndị mba ọzọ, ma kpekwa unu ikpe.
\v 10 Unu ga-ada site na mma agha. Ọ bụ nʼoke ala Izrel niile ka m ga-anọ kpee unu ikpe. Mgbe ahụ, unu ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\v 11 E, obodo a agaghị abụrụ unu ite. Unu agaghị anọkwa nʼime ya dịka anụ. Aga m ekpe unu ikpe nʼoke ala Izrel niile.
\v 12 Mgbe ahụ, unu ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*. Nʼihi na unu bụ ndị na-enupu isi site nʼiwu m na ụkpụrụ m. Ma unu na-agbaso nzọ ụkwụ nke mba ndị ahụ niile gbara unu gburugburu.”
\p 
\v 13 Mgbe m ka nọ na-ebu amụma, Pelataya nwa Benaya nwụrụ. Mụ onwe m kpuo ihu m nʼala kwaa akwa sị, “Ewoo, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* ị ga-ebibi ndị niile fọdụrụ nʼala Izrel?”
\s1 Nkwa banyere nlọghachi Izrel
\p 
\v 14 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 15 “Nwa nke mmadụ, ụmụ nke nna gị, ọ bụladị ụmụnna gị, na ndị mgbapụta\f + \fr 11:15 \ft Ndị a dọkpụụrụ gaa mba ọzọ\f* gị na ezinaụlọ Izrel niile, ọ bụ ha ka ndị bi na Jerusalem sịrị, ‘Ha esitela nʼebe \nd Onyenwe anyị\nd* nọ gaa ebe dị anya, ọ bụkwa anyị ka enyere ala nke a ka ọ bụrụ ihe nnweta anyị,’
\p 
\v 16 “Nʼihi nke a, kwuo, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-asị, Nʼagbanyeghị na m zipụrụ ha gaa ebe dị anya nʼetiti mba dị iche iche, chụsakwaa ha nʼetiti ala dị iche iche, ma nwa mgbe nta, a bụụrụ m ha ebe dị nsọ nʼala niile ahụ bụ ebe ha gara.’
\p 
\v 17 “Ya mere kwuo, ‘Nke a bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu: Aga m achịkọtakwa unu ọnụ ọzọ, site nʼobodo niile bụ ebe unu gbasara, nyeghachikwa unu ala Izrel.’
\p 
\v 18 “Ha ga-alọghachi nʼebe ahụ, sitekwa nʼetiti ya wezuga oyiyi ihe arụ niile, na arụsị niile bụkwa ihe arụ.
\v 19 Aga m enyekwa ha otu obi, tinyekwa mmụọ ọhụrụ nʼime ha. Aga m ewepụ site nʼime ha obi kpọrọ\f + \fr 11:19 \ft Ya bụ, obi nkume\f* nkụ ma nye ha obi nke anụ ahụ.
\v 20 Nke a ga-eme ka ha soro ụkpụrụ m na iwu m niile, leziekwa anya idebe ha. Ha ga-abụ ndị nke m, mụ onwe m ga-abụkwa Chineke ha.
\v 21 Ma banyere ndị ahụ obi ha na-agbaso ihe ọjọọ na ihe niile rụrụ arụ, mmehie ha ka m ga-atụkwasị nʼisi ha; otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.”
\p 
\v 22 Mgbe ahụ, cherubim ndị ahụ weliri nku ha elu, wịịlu ndị ahụ dịkwa nʼakụkụ ha ma ebube nke Chineke nke Izrel guzokwa nʼelu ha.
\v 23 Ebube \nd Onyenwe anyị\nd* sitere nʼetiti obodo ahụ rigoo, guzo nʼelu ugwu, nʼakụkụ ọwụwa anyanwụ.
\v 24 Nʼime ọhụ, Mmụọ nke Chineke buliri m elu bubata m na Kaldịa, ebe ndị a dọkpụụrụ gaa mba ọzọ nọ.
\p Otu a ka ọhụ m hụrụ si hapụ m.
\v 25 Agwakwara m ndị niile ahụ e mere ka ha jee biri na mba ọzọ ihe niile nke \nd Onyenwe anyị\nd* gosiri m.
\c 12
\s1 Ihe ngosi maka ndọta nʼagha
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, i bi nʼetiti ndị na-enupu isi, ndị nwere anya ịhụ ụzọ ma ha adịghị ahụ; ndị nwere ntị ịnụ ihe ma ha adịghị anụ ihe, nʼihi na ha bụ ndị nnupu isi.
\p 
\v 3 “Ya mere, nwa nke mmadụ, kwakọtaa ngwongwo ụlọ gị maka ị ga biri nʼala ọzọ, mee nke a nʼehihie dịka ha na-ele gị anya, hapụ ụlọ gị gaa nʼebe ọzọ. Ma eleghị anya ha ga-aghọta, ọ bụ ezie na ha bụ ndị nnupu isi.
\v 4 Kwapụta ngwongwo gị nʼezi nʼehihie ka ha hụ ya. Ma hapụ ụlọ gị nʼabalị dịka ndị na-agba ọsọ ndụ si eme, mgbe ha na-amalite ije ha, nke ịga ibi nʼala ọzọ.
\v 5 Mgbe ha na-ele gị anya, gwupuo mgbidi, site na ya kwara ngwongwo gị pụọ.
\v 6 Mgbe ha nọ na-ele gị anya, bulie ibu gị, tụkwasị ya nʼubu gị, pụọ gawa nʼime ọchịchịrị, kpuchie ihu gị, ka ị ghara ihu ala ahụ anya. Nʼihi na emela m gị ihe ịrịbama nye ụlọ Izrel niile.”
\p 
\v 7 Emere m ihe e nyere m nʼiwu. Ebupụtara m ngwongwo m nʼehihie, jikọta ha maka ịgba ọsọ ndụ. Nʼanyasị, eji m aka m gwuo ọnụ na mgbidi ahụ. Ebukwasịrị m ngwongwo m nʼubu, bulie ije nʼime ọchịchịrị mgbe ha nọ na-ele m anya.
\p 
\v 8 Nʼụtụtụ echi ya, okwu \nd Onyenwe anyị\nd* bịakwutere m,
\v 9 “Nwa nke mmadụ, ọ bụ na ụlọ Izrel ndị nnupu isi ahụ ajụbeghị gị, ‘o lee ihe ị na-eme?’
\p 
\v 10 “Gwa ha, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Amụma a bụ maka onyeisi nọ na Jerusalem, nʼụlọ Izrel niile nọkwa ebe ahụ.’
\v 11 Sị ha, ‘Mụ onwe m bụ ihe ama nye unu.’
\p “Dịka m mere, otu a kwa ka a ga-eme nye ha. Ha ga-aga na mba ọzọ biri ka ndị a dọtara nʼagha.
\p 
\v 12 “Nwa eze nke nọ nʼetiti ha ga-amaburu ibu ya nʼubu pụọ nʼọchịchịrị, ọ ga-egwupụ mgbidi aja nke obodo site nʼebe ahụ pụọ. Ọ ga-ekpuchikwa ihu ya ka ọ ghara iji anya ya hụ obodo ahụ.
\v 13 Ma aga m eji ụgbụ m jide ya, meekwa ka ọ bịaruo Babilọn bụ ala ndị Kaldịa. Ebe ahụ ka ọ ga-anọ nwụọ, ma ọ gaghị ahụ ya anya.
\v 14 Ndị niile gbara ya gburugburu na ndị agha ya niile ka m ga-achụsa nʼala niile, ọ bụkwa mma agha ka m ga-amịpụta jiri chụọ ha ọsọ.
\p 
\v 15 “Ha ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*, mgbe m chụsachara ha nʼetiti mba niile dị iche iche, fesaakwa ha nʼala niile.
\v 16 Ma ọ bụ mmadụ ole na ole nʼime ha ka m ga-edebe ndụ site na mma agha, na ụnwụ na ọrịa na-efe efe. Ka ha nwee ike kọọ akụkọ ihe arụ niile ha nʼetiti mba dị iche iche ebe ha gbagara ọsọ. Ha ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*.”
\p 
\v 17 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 18 “Nwa nke mmadụ, tụọ egwu mgbe ị na-eri nri gị. Jirikwa ihe ọtụtụ tụpụta mmiri ọṅụṅụ gị, dịka a ga-asị na ọ bụ ihe ikpeazụ i nwere.
\v 19 Ị ga-asịkwa ndị bi nʼala ahụ, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu banyere ndị bi na Jerusalem, nʼala nke Izrel, sị, Ha ga-eji ụjọ rie achịcha ha, jirikwa obi ịlọ mmiri ṅụọ mmiri ha, nʼihi na a ga-ekpochapụ ihe niile dị nʼala ha, nʼihi ihe ike nke ndị bi nʼime ya.
\v 20 Obodo niile nke ndị mmadụ bi nʼime ya ga-ala nʼiyi, otu aka ahụ, ala unu niile ga-abụ ebe tọgbọrọ na nkịtị. Mgbe ahụ, unu ga-amata na mụ onwe bụ \nd Onyenwe anyị\nd*.’ ”
\s1 Ọ gaghị adị anya mmezu
\p 
\v 21 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 22 “Nwa nke mmadụ, kedụ ihe ilu a na-atụ nʼIzrel pụtara, nke na-asị ‘Ụbọchị adịla oke anya, ọhụ niile abụrụkwala ihe na-enweghị isi?’
\v 23 Gwa ha, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu, Aga m eme ka ilu a kwụsị, ha agaghị atụkwa ya dịka ilu nʼIzrel ọzọ.’ Kama gwa ha, ‘Nʼụbọchị ahụ adịla nso mgbe ọhụ niile ga-emezu.
\v 24 Nʼihi na agaghị enwekwa ọhụ ụgha ọzọ, maọbụ ịjụ ase ire ụtọ nʼetiti ụlọ Izrel.
\v 25 Ma mụ onwe m bụ \nd Onyenwe anyị\nd* ga-ekwu ihe m zubere. Ihe ọbụla m kwuru ga-emezu na-atụfughị oge. Nʼihi na ọ bụ nʼoge unu dị ndụ, unu ndị nnupu isi, ka m ga-emezu ihe ọbụla bụ nke m kwuru. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.’ ”
\p 
\v 26 Okwu nke \nd Onyenwe anyị\nd* bịakwutere m,
\v 27 “Nwa nke mmadụ, lee, ụlọ nke Izrel na-asị, ‘Ọhụ niile ọ na-ahụ bụ maka ọtụtụ afọ dị nʼihu, amụma ya bụkwa maka oge na-abịa nʼihu.’
\p 
\v 28 “Nʼihi ya, gwa ha, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị, ọ dịghịkwa okwu m nke a ga-atụfu oge ọzọ nʼime ya, ihe ọbụla m kwuru ka a ga-emezu. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.’ ”
\c 13
\s1 Okwu megide ndị amụma ụgha
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, buo amụma megide ndị amụma nke Izrel ndị na-ebu amụma ugbu a, gwa ndị amụma ahụ na-ekwu ihe sitere ha nʼuche: ‘Nụrụnụ okwu nke \nd Onyenwe anyị\nd*.
\v 3 Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, Ahụhụ ga-adịrị ndị amụma nzuzu ndị na-agbaso mmụọ nke onwe ha, ndị ọ dịghị ihe ha na-ahụ.
\v 4 Gị Izrel, lee, ndị amụma gị niile dị ka nkịta ọhịa bi na mkpọmkpọ ebe.
\v 5 Unu arịgobeghị na oghere jupụtara na mgbidi maọbụ rụzie mgbidi aja ndị ahụ maka nchekwa ndị Izrel ka o nwee ike kwudosie ike nʼụbọchị agha nke \nd Onyenwe anyị\nd*.
\v 6 Ọhụ ha bụ ụgha, otu a, ịjụ ase ha bụkwa ụgha, ha na-asị, “\nd Onyenwe anyị\nd* kwupụtara,” ebe \nd Onyenwe anyị\nd* ezipụghị ha, ha na-agakwa nʼihu na-atụ anya ka o mezuo okwu ha.
\v 7 Ọ bụghị ọhụ ụgha ka unu hụrụ, ọ bụghịkwa okwu ịjụ ase ụgha ka unu kwuru, mgbe unu na-asị, “Otu a ka \nd Onyenwe anyị\nd* kwupụtara,” nʼagbanyeghị na mụ onwe m ekwughị okwu?
\p 
\v 8 “ ‘Nʼihi ya, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị, aga m ebibi unu nʼihi okwu ụgha na ọhụ ụgha unu niile. Edoola m onwe m imegide unu, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\v 9 Aka m ga-emegide ndị amụma niile ahụ bụ ndị na-ahụ ọhụ ụgha, na-agbakwa afa ụgha. Ha a gaghị esonye na otu ọgbakọ ndị m maọbụ bụrụ ndị agụnyekọrọ nʼakwụkwọ ndekọta aha ụlọ nke Izrel, ha agaghị abakwa nʼala ndị Izrel. Mgbe ahụ unu ga-amata na mụ onwe m bụ Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*.
\p 
\v 10 “ ‘Nʼihi na ha eduhiela ndị m, mgbe ha na-asị, “Udo,” ebe udo na-adịghị, nʼihi na mgbe e wuru mgbidi na-esighị ike, ndị amụma ndị a jara ha mma, werekwa nzu techie ya.
\v 11 Ya mere, gwa ndị ahụ jiri nzu techie mgbidi ahụ na ọ ga-ada. Oke mmiri ozuzo nke ga-ezobiga oke ga-ezo, aga m ezitekwa mkpụrụ mmiri dị ukwuu nke ga-ada, na oke ifufe nke ga-akwada ya.
\v 12 Mgbe mgbidi ahụ dara, ndị mmadụ ọ gaghị ajụ, “Olee ebe mgba ọcha ahụ ị ji techie ya dị?”
\p 
\v 13 “ ‘Ya mere, Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, aga m eji oke ifufe nke ọnụma m, na oke mmiri ozuzo nke iwe m, ma oke akụmmiri nke oke iwe m mebie ya.
\v 14 Aga m akwada mgbidi ahụ unu tere nzu, aga m emekwa ka ọ daruo ala nke ga-eme ka ahụ ntọala ya anya; ọ ga-adakwasịkwa unu, gwepịa unu. Mgbe ọ dara ọ ga-egbuchapụ unu niile; unu ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\v 15 Otu a ka m ga-esi gosipụta iwe m nʼebe mgbidi ahụ nọ, na nʼahụ ndị ahụ ji nzu techie ya. Aga m asị unu, “Mgbidi ahụ adịghịkwa, otu a ka ọ dịkwa ndị ahụ ji nzu techie ya,
\v 16 bụ ndị amụma Izrel ndị ahụ buru amụma nye Jerusalem, ndị hụkwara ya ọhụ udo mgbe udo na-adịghị, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.” ’
\p 
\v 17 “Ma ugbu a, gị nwa nke mmadụ, chee ihu nʼebe ụmụada ndị unu nọ, ndị nke na-ebu amụma dị ka o si si ha nʼobi pụta. Buo amụma megide ha
\v 18 sị, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu, Ahụhụ dịrị ndị inyom na-adụnye ọgwụ mgbaasị na nkwoji aka ha na-emekwa akwa mgbokwasị nke ikpuchi isi maka ndị mmadụ dị iche iche, iji raata ha. Unu si aṅaa chee na unu ga-echebe ndụ unu mgbe unu buru ụzọ mee ka ndị m maa nʼọnya?
\v 19 Unu emeela ka m ghara ịdị nsọ nʼetiti ndị m, nʼihi mkpoju aka ọka balị na iberibe achịcha ole na ole. Nʼihi ya, unu emeela ka ha nwụọ bụ ndị na-ekwesighị ịnwụ anwụ. Unu edebekwala ha ndụ bụ ndị na-ekwesighị ịdị ndụ, site nʼokwu ụgha unu na-agwa ndị m, bụ ndị na-aṅa ntị nʼokwu ụgha.
\p 
\v 20 “ ‘Nʼihi nke a, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu, ana m emegide ọgwụ mgbaasị niile nke unu ji achụ nta mkpụrụobi ndị m dịka nnụnụ. Aga m adọwapụ ha site nʼaka unu, napụtakwa ndị m, bụ ndị unu ji nʼọnya dị ka nnụnụ e tinyere nʼụlọ akpara akpa.
\v 21 Aga m adọwa akwa mgbokwasị ọgwụ unu, napụta ndị m site nʼaka unu. Ha agaghị amakwa nʼọnya nke ike unu ọzọ. Nʼụzọ dị otu a unu ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\v 22 Nʼihi na ụgha unu emeela ka obi ndị ezi omume daa mba, mgbe ọ na-abụghị uche m na ihe dị otu a ga-eme. Ma unu emeela ka obi ndị ajọ omume sie ike site na nkwa ogologo ndụ unu kwere ha, mee ka ha ghara isite nʼụzọ ọjọọ ha chegharịa ma zọpụta ndụ ha.
\v 23 Nʼihi nke a, unu agaghị ahụkwa ọhụ ụgha ọzọ, maọbụ gbaa afa. M ga-anapụta ndị nke m site nʼaka unu. Mgbe ahụ unu ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.’ ”
\c 14
\s1 Okwu megide ndị na-ekpere arụsị
\p 
\v 1 Ụfọdụ nʼime ndị okenye Izrel bịakwutere m, nọdụ ala nʼihu m.
\v 2 Mgbe ahụ okwu \nd Onyenwe anyị\nd* ruru m ntị,
\v 3 “Nwa nke mmadụ, ndị ikom ndị a na-efe arụsị nʼime obi ha, ma tinyekwa ihe ịsụ ngọngọ nke ajọ omume ya nʼihu ha.\f + \fr 14:3 \ft Kwenye ka arụsị ndị a na-eduba ha na mmehie\f* Aga m ekwenye ka ha jụta m ase ọbụla?
\v 4 Ya mere, gwa ha okwu sị ha ‘Nke a bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Mgbe onye Izrel ọbụla na-agbaso arụsị nʼobi ya, nke na-ekwekwa ka arụsị ndị a na-eduba ya na mmehie, bịakwutere onye amụma ịjụta ya ase, mụ onwe m bụ \nd Onyenwe anyị\nd* ga-aza onye ahụ dịka o si dị, ya bụ dịka ịba ụba nke arụsị ya niile si dị.
\v 5 Nʼụzọ dị otu a ka m ga-esi nwetaghachikwa obi ndị Izrel niile bụ ndị si nʼebe m nọ wezuga onwe ha, ma malite ife arụsị.’
\p 
\v 6 “Nʼihi ya, gwa ụlọ Izrel, ‘Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu, Chegharịanụ! Sitenụ nʼife arụsị unu niile chigharịa, jukwanụ omume unu niile rụrụ arụ.
\p 
\v 7 “ ‘Nʼihi na onye ọbụla nʼụlọ Izrel maọbụ onye ọbụla nʼime ndị ọbịa bi nʼala Izrel, nke kewapụrụ onwe ya site nʼiso m, si otu a mee ka arụsị ọ na-efe baa ya nʼobi, nke na-etinye ihe ịsọ ngọngọ ajọ omume nʼihu ha, mechaa, gakwuru onye amụma maka isite nʼaka ya ịjụta m ase, mụ onwe m bụ \nd Onyenwe anyị\nd* ga-azaghachi ha.
\v 8 Aga m edokwa onwe m imegide ha, mee ka ha bụrụ ihe ịmaatụ na ilu nye ndị ọzọ. Aga m esitekwa nʼetiti ndị m wezuga ha. Mgbe ahụ, unu ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\p 
\v 9 “ ‘Ọ bụrụ na arafuo onye amụma ahụ ka o buo amụma, ọ bụ mụ onwe m bụ \nd Onyenwe anyị\nd* rafuru onye amụma ahụ. Aga m esetipụ aka m megide ya, bipụkwa ya site nʼetiti ndị m, bụ Izrel.
\v 10 Ha ga-ata ahụhụ nʼihi mmehie ikpe ọmụma ha, dịka ikpe ọmụma dịrị onye na-ajụ ase, otu a ka ọ ga-adịkwa nye onye amụma ụgha ahụ.
\v 11 Mgbe ahụ, ụmụ Izrel agaghị esitekwa nʼiso m kpafuo ọzọ.\f + \fr 14:11 \ft Maọbụ, \fqa wezuga onwe ha\f* Ha agakwaghị eji mmehie merụọ onwe ha, kama ha ga-abụ ndị m, mụ onwe m ga-abụkwa Chineke ha. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara ya.’ ”
\s1 Ikpe ọmụma aghaghị ịbịa
\p 
\v 12 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 13 “Nwa nke mmadụ, ọ bụrụ na ndị bi nʼala emehie megide m, site nʼekwesighị ntụkwasị obi ha, ọ bụrụ na m esetipụ aka m mee ka oke ụnwụ bịakwasị ha, ọ bụrụkwa na m emee ka mmadụ na anụmanụ niile dị nʼala a nwụchasịa,
\v 14 a sịkwa na Noa, Daniel na Job bi nʼetiti ya, ha ga-azọpụta naanị onwe\f + \fr 14:14 \ft Ya bụ, mkpụrụobi ha\f* ha nʼezi omume ha. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.
\p 
\v 15 “Asị na m eziga anụ ọhịa ọjọọ ka ha bịa bibie ala ahụ, mee ka ọ ghọọ ebe tọgbọrọ nʼefu meekwa ka mmadụ ọbụla ghara ị site nʼime ya gafee nʼihi anụ ọhịa ndị ahụ,
\v 16 dịka m na-adị ndụ ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu, ọ bụrụkwarị na ndị ikom atọ ndị a nọ nʼebe a, ha agaghị anapụta ọ bụladị ụmụ ha ndị nwoke maọbụ ụmụ ha ndị nwanyị site nʼịla nʼiyi. Naanị ha ka a ga-azọpụta, ma ala ahụ ga-abụ ihe tọgbọrọ nʼefu.
\p 
\v 17 “Ọ bụrụ na a sị na m mere ka mma agha bịakwasị ala ahụ, m sị, ‘Ka mma agha gabiga site nʼala ahụ niile gburugburu,’ ma gbuo mmadụ na anụmanụ niile dị nʼime ya,
\v 18 dịka m na-adị ndụ, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri, a sịkwarị na ndị ikom atọ ndị a nọ nʼala ahụ, ha agaghị anapụta ụmụ ndị ikom na ụmụ ha ndị inyom site nʼịla nʼiyi. Kama, ọ bụ naanị ha onwe ha ka a ga-anapụta.
\p 
\v 19 “Ọzọkwa, ọ bụrụ na m eziga oke iwe m site nʼajọ ọrịa na-efe efe, ọ bụrụ na ọrịa ahụ egbuo mmadụ na anụmanụ ha niile,
\v 20 dịka m na-adị ndụ, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri, a sịkwa na Noa, Daniel na Job bi nʼime ya, ha agaghị anapụta ụmụ ha ndị ikom maọbụ ndị inyom site nʼịla nʼiyi. Ha ga-azọpụta naanị onwe ha nʼezi omume ha.
\p 
\v 21 “Nʼihi na otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, a ga-esi aṅaa napụta ya, mgbe m zipụrụ ụzọ ikpe m anọ dị oke egwu nke na-echere Jerusalem. Ikpe ndị a bụ: mma agha na ụnwụ, anụ ọhịa ọjọọ na-adọgbu adọgbu na ọrịa na-efe efe, ka ha gbuchapụ mmadụ na anụmanụ niile dị nʼime ya.
\v 22 Ma a ga-enweta ụfọdụ ndị ga-afọdụ ndụ, bụ ụmụ unu ndị nwoke na ndị nwanyị, ndị a ga-anapụta site nʼahụhụ ndị a. Ha ga-abịakwute unu. Mgbe unu hụrụ omume ha, na obibi ndụ ha, ha ga-abụrụ unu ihe nkasiobi nʼihi na unu ga-esite na ha mata ụdị mbibi nke m mere ka ọ bịakwasị Jerusalem.
\v 23 A ga-akasịkwa unu obi mgbe unu hụrụ omume ha na obibi ndụ ha, unu ga-amatakwa na ọ bụghị nʼefu ka m mere ka ihe ndị a niile dakwasị ha.” Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.
\c 15
\s1 Jerusalem, osisi vaịnị na-abaghị uru
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, olee, ụzọ osisi vaịnị si pụọ iche site nʼalaka osisi ndị ọzọ dị nʼime oke ọhịa?
\v 3 A na-esi nʼime osisi ya were mepụta ihe ọbụla bara uru? Ọ bụ site na ya ka a na-esi emepụta osisi nke e ji ekonye ihe?
\v 4 Uru ha bara bụ iji ha menye ọkụ. Ma mgbe isi ya abụọ repịara, mgbe etiti ya rekwara ọkụ, o nwere ihe ọzọ mmadụ nwere ike iji ya mee?
\v 5 Ọ bụrụ na ọ baghị uru mgbe o zuruoke, a ga-esi aṅa were ya mepụta ihe bara uru mgbe ọkụ repịasịrịla ya, ọ ghọọ unyi?
\p 
\v 6 “Nʼihi ya, ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu, dịka m sitere nʼetiti ọhịa niile wepụta osisi vaịnị nye ka ọ bụrụ nkụ e ji emenye ọkụ, otu a ka m ga-esi mesoo ndị bi na Jerusalem.
\v 7 Aga m eche ihu m\f + \fr 15:7 \ft Maọbụ, \fqa Aga m eguzo onwe m\f* imegide ha. Ọ bụ ezie na ha esitela nʼọkụ pụta, ma ọkụ ga-erepịa ha. Unu ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*, mgbe m guzoro onwe m megide ha.
\v 8 Aga m emekwa ka ala ha tọgbọrọ nʼefu, nʼihi na ha bụ ndị na-ekwesighị ntụkwasị obi. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.”
\c 16
\s1 Ekwesighị ntụkwasị obi Jerusalem
\p 
\v 1 Okwu nke \nd Onyenwe anyị\nd* bịakwutere m,
\v 2 “Nwa nke mmadụ, gwa Jerusalem okwu mee ka ọ mara banyere ndụ ya niile rụrụ arụ
\v 3 sị ya, ‘Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-agwa Jerusalem: Ịpụta ụwa gị na ọmụmụ gị bụ nʼala ndị Kenan; nna gị bụ onye Amọrị, nne gị bụ onye Het.
\v 4 Nʼụbọchị ahụ a mụrụ gị, ebeghị otubo gị, ọ dịghị onye lekọtara gị maọbụ jiri mmiri saa gị ahụ ị sachapụ gị unyi maọbụ tee gị nnu, maọbụ jiri akwa kechie gị.
\v 5 Ọ dịghị onye nwere obi ebere nʼebe ị nọ. Ọ dịghị onye ihe banyere gị metụrụ nʼobi, ọ dịkwaghị onye lekọtara gị. Kama nʼụbọchị ahụ a mụrụ gị a tufuru gị nʼọhịa, nʼihi na-eledara gị anya.
\p 
\v 6 “ ‘Ma mgbe m si nʼebe ahụ ị tọgbọ na-agafe, ahụrụ m gị ka i chịlịri ụkwụ gị, ọbara jukwara gị ahụ, dịka ị dina nʼime ọbara gị. Nʼoge ahụ, ihe pụrụ m nʼọnụ bụ, “Dị ndụ.”
\v 7 Emere m ka ị too dịka osisi na-eto eto nʼime ọhịa. I tolitere, too ogologo ma tozuo oke na nwanyị, ị kpụrụ ara, agịrị isi gị pukwara, ma gị onwe gị gba ọtọ.
\p 
\v 8 “ ‘Emesịa, a gafere m nʼakụkụ gị, mgbe m lere gị anya ahụrụ m na i tozuola onye mmadụ ga-ahụ nʼanya. A gbasapụrụ m akụkụ akwa m nʼahụ gị, jiri ya kpuchie ọtọ gị. Aṅụrụ m gị iyi, mụ na gị gbara ndụ, ị ghọkwara nke m. Ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara.
\p 
\v 9 “ ‘Eji m mmiri saa gị ahụ, sachapụ ọbara dị gị nʼahụ, teekwa gị mmanụ.
\v 10 Enyere m gị akwa ọcha na uwe a kpara nke ọma, nke i ji kpuchie ahụ gị. Nyekwa gị akpụkpọụkwụ e ji ezi akpụkpọ kwaa, jirikwa ezi akwa ọcha na uwe ndị dị oke ọnụ kpuchie gị.
\v 11 Eyinyere m gị ihe ịchọ mma, tinye ọlaaka nʼaka gị, nakwa ọlaolu nʼolu gị.
\v 12 Etinyekwara m gị ọla nʼimi, tinye gị ọlantị abụọ na ntị gị, na okpueze mara mma nʼisi gị.
\v 13 E ji ihe ịchọ mma ọlaọcha na ọlaedo chọọ gị mma. Uwe gị bụkwa uwe ezi akwa ọcha, uwe dị oke ọnụ, na uwe a kpara nke ọma. Nri ị na-eri bụ ụtụ ọka a yọchaziri nke ọma, na mmanụ aṅụ, na mmanụ oliv. Mma gị pụtaziri ihe nke ọma, ị ruo ogo ịbụ eze nwanyị.
\v 14 Aha gị dara ụda nke ukwuu nʼetiti mba dị iche iche nʼihi mma gị, nke zuruoke site nʼebube ahụ bụ nke m tụkwasịrị gị. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara.
\p 
\v 15 “ ‘Ma ị tụkwasịrị mma gị obi, jiri nʼihi na a mara aha gị ghọọ onye akwụna. I wekwaara onwe gị nye nwoke ọbụla gabigara mee ka mma gị bụrụ nke ya.
\v 16 Ị were uwe gị ụfọdụ, meere onwe gị ebe dị iche iche dị elu nke tụrụ agwa, ebe doziri ihe ndina ịkwa iko gị. Ihe dị otu a emetụbeghị mbụ, ha ekwesịkwaghị ime mgbe ọbụla.
\v 17 Ị chịrị ọlaọcha na ọlaedo ndị ahụ mara mma, bụ nke m nyere gị, were ha kpụọrọ onwe gị oyiyi nwoke dị iche iche, ndị ị na-akpọ isiala nye. Nʼụzọ dị otu a ka gị na ha si na-akwakọ iko.
\v 18 Uwe ọma ahụ a kpara akpa ka i ji kpuchie ha. Mmanụ m na ụda m na-esi isi ụtọ ka ị chere nʼihu ha dịka onyinye.
\v 19 Ọzọkwa, ụtụ ọka ọma, mmanụ oliv na mmanụ aṅụ, nri ndị m nyere gị ka i rie, ka i ji chụọ aja na-esi isi ụtọ nʼihu ha. Otu a ka o si dị, ka Onyenwe anyị \nd Onyenwe anyị\nd* kwupụtara.
\p 
\v 20 “ ‘Ụmụ niile ị mụtaara m, nwoke na nwanyị, ka i ji chụọrọ arụsị gị aja ka ha rie. Ọ bụ na ịgba akwụna gị ezughịrị gị?
\v 21 Ma i gburu ụmụ m, jiri ha chụọ aja nye arụsị!
\v 22 Nʼoge ndị a niile ị na-akwa iko, na-eme ihe arụ ndị a niile, o metụbeghị gị nʼobi ka i cheta ụbọchị niile ndị ahụ ị bụ nwantakịrị, mgbe ị nọ na-agba ọtọ, mgbe ọbara jupụtara gị nʼahụ.
\p 
\v 23 “ ‘Ahụhụ, ahụhụ, ga-adịrị gị, ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri. Tinyekwara ajọ omume gị niile,
\v 24 i wuuru arụsị gị ụlọ ebe ịkwa iko, wuokwa ụlọ arụsị ndị ọzọ nʼakụkụ okporoụzọ niile.
\v 25 I wuuru onwe gị ebe ịchụ aja e wuliri elu dị iche iche nʼisi ụzọ niile, si otu a merụọ mma gị. Nʼebe ahụ ka ị na-anọ na-emeghere\f + \fr 16:25 \ft Ya bụ, eghebere\f* onye ọbụla gafetara ụkwụ gị abụọ,\f + \fr 16:25 \ft Na-enyekwa onye ọbụla onwe gị\f* mee ka ịkwa iko gị na-amụbanye.
\v 26 Ị kwasoro ndị Ijipt bụ ndị agbataobi gị iko, ndị anụahụ ha dị ukwuu. I si otu a mee ka iwe dị ukwuu wee m megide ịkwa iko gị nke na-aba ụba.
\v 27 Nʼihi ya, esetipụrụ m aka megide gị, e webilatara m oke ala gị ka ọ dị ntakịrị; ewere m gị nyefee oke ọchịchọ nke ndị iro gị, bụ ndị inyom Filistia, ndị ihere mere nʼihi omume gị niile ruru unyi.
\v 28 Gị na ndị Asịrịa akwaala iko, nʼihi na afọ adịghị eju gị. Ọ bụladị mgbe nke a gasịrị, ị bụkwa onwe na-enweghị afọ ojuju.
\v 29 I mere ka ịkwa iko gị mụbaa ruo ala ndị Kaldịa, mba ahụ ịzụ ahịa doro anya. Ma ọbụladị na nke a afọ ejughịkwa gị.
\p 
\v 30 “ ‘Iwe m dị ọkụ megide gị,\f + \fr 16:30 \ft Lee ka i si bụrụ onye na-ata ahụ, onye obi ya na-esighị ike.\f* otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara. Mgbe ị na-eme ihe ndị a, ị na-eme ha nnọọ dị ka onye akwụna nke ihere adịghị eme.\f + \fr 16:30 \ft Onye na-adịghị ezo-ezo maọbụ na-eme omume ọ dịghị onye m hụrụ\f*
\v 31 Mgbe ị rụrụ ụlọ arụsị nʼisi ụzọ niile, wuokwa ụlọ ịkwa iko gị na mbara ụzọ niile, i meghị ya dịka akwụna, nʼihi na ị jụrụ ịnara ndị gị na ha kwara iko ego ọbụla.
\p 
\v 32 “ ‘Nʼezie, ị bụ nwanyị na-akwa iko ma ị nọ na di, onye na-anabata ndị ikom ọzọ karịa di ya!
\v 33 Ndị akwụna niile na-anata onyinye, ma gị onwe gị na-enye ndị ikom niile hụrụ gị nʼanya onyinye, inye ha ngarị ka ha bịakwute gị site nʼebe niile bịakwute gị nʼihi ịgba akwụna gị.
\v 34 Nʼihi ya, ị dị iche nʼetiti ndị inyom ndị ọzọ nʼụdị ịgba akwụna gị, o nweghị onye na-agbaso gị na-arịọ gị maka ịkwaso gị iko. Ị kwụrụ ụgwọ ma o nweghị ụgwọ a kwụrụ gị, nʼụzọ dị otu a ị dị iche.
\p 
\v 35 “ ‘Nʼihi nke a, gị nwanyị akwụna, nụrụ okwu \nd Onyenwe anyị\nd*!
\v 36 Nke a bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, Nʼihi na ị wụpụrụ agụụ nke anụ ahụ gị, kpugheekwa ọtọ gị nʼịkwa iko gị nke gị na ndị ị hụrụ nʼanya na-akwa, na nʼihi arụsị gị niile rụrụ arụ, nakwa nʼihi na ị nyere ha ọbara ụmụ gị,
\v 37 nʼihi ya, aga m achịkọta ndị niile bụ ndị ahụ niile ị hụrụ nʼanya, ndị gị na ha na-enwe obi ụtọ, ndị ị hụrụ nʼanya, ma ndị ị kpọrọ asị. Aga m achịkọta ha site gburugburu gị imegide gị, gbaa gị ọtọ nʼihu ha, ka ha hụ ọtọ gị niile.
\v 38 Aga m ata gị ahụhụ a na-ata ndị inyom na-akwa iko, na ndị inyom na-egbu mmadụ. Aga m eme ka ịbọ ọbọ ọbara nke ọnụma m, ya na ekworo m, bịakwasị gị.
\v 39 Aga m enyefe gị nʼaka ndị ahụ ị hụrụ nʼanya, bụ ọtụtụ mba ahụ dị iche iche. Ha ga-ebibi gị, kwada ụlọ ịkwa iko gị, na ụlọ arụsị gị niile dị elu, gbaa gị ọtọ, narakwa gị uwe gị niile, na ihe ịchọ mma gị niile, hapụ gị ka ihere mee gị.
\v 40 Ha ga-akpọta igwe mmadụ ga-emegide gị, ndị ga-atụ gị nkume, jirikwa mma agha ha bọkasịa gị.
\v 41 Ha ga-agba ụlọ gị ọkụ ma takwaa gị ahụhụ nʼihu ọtụtụ ndị inyom. Aga m ahụkwa na ị kwụsịrị ịkwa iko ị na-akwa, ị ga-akwụsịkwa ịkwụ ụgwọ ahụ ị na-akwụ ndị iko gị.
\v 42 Mgbe ahụ, oke iwe m megide gị ga-adajụ, ekworo m ga-esite nʼebe ị nọ gabiga. Aga m anọ nwayọọ gharakwa iwe iwe ọzọ.
\p 
\v 43 “ ‘Ebe ọ bụ na ị chetaghị ụbọchị ndị ahụ niile, mgbe ị dị nʼagbọghọbịa, ma i ji ihe ọjọọ ndị a niile ị na-eme kpasuo m iwe. Ya mere, aghaghị m ịkwụghachi gị dịka mmehie gị si dị. Ọ bụ na i meghị omume ndị a rụrụ arụ, tinyekwara mmehie agụụ ịkwa iko? Ọ bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\p 
\v 44 “ ‘Lee, onye ọbụla na-atụ ilu, ga-atụ ilu a banyere gị sị, “Otu ọ dị nne ka ọ dị nwa ya nwanyị.”
\v 45 Nʼezie, ị dị ka nne gị, nʼihi na nne gị kpọrọ di ya na ụmụ ya asị. Ị dịkwa ka ụmụnne gị ndị inyom. Ha na-akpọ di ha na ụmụ ha asị. Nʼezie, nne gị bụ onye Het, nna gị bụkwa onye Amọrị.
\v 46 Ada nne gị bụ Sameria, ya na ụmụ ya bi nʼugwu. Nwanne gị nwanyị nke nta bụ Sọdọm, ya na ụmụ ya bi nʼala ndịda.
\v 47 Ọ bụghị naanị na ị soro ụzọ ha niile, ị ṅomiri omume ibi ndụ arụ ha niile, kama dịka a ga-asị na nke a bụ ihe nta, nʼụzọ gị niile, ị ghọrọ onye rụrụ arụ karịa ha.
\v 48 Ebe m na-adị ndụ, ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, Sọdọm na ụmụ ya ndị inyom emetụbeghị ihe ndị a gị na ụmụ gị ndị inyom mere.
\p 
\v 49 “ ‘Mmehie nwanne gị nwanyị Sọdọm bụ nganga, na umengwụ, na oke oriri. Ha jụrụ inyere ndị nọ na mkpa, na ndị agụụ na-agụ nọ nʼọnụ ụzọ ha aka.
\v 50 Ha dị elu nʼobi ha, mee ihe arụ nʼihu m. Nʼihi ya, esitere m nʼihu m wezuga ha dịka ị hụrụ.
\v 51 Ọ bụladị Sameria emerughị ọkara mmehie niile i mere. I meela ihe arụ bara ụba karịa nke ha mere, si otu a gụọ ụmụnne gị ndị inyom ka ndị ezi omume site nʼihe ndị a niile nke ị mere.
\v 52 Gị onwe gị buru ihe ihere gị, nʼihi na omume gị ekpepụtala ụmụnne gị ndị inyom. Nʼihi na mmehie gị dị njọ, dịkwa ukwuu karịa nke ha, ha bụ ndị a gụrụ na ndị ezi omume karịa gị. Ya mere, ka ihere mee gị, burukwa ọnọdụ ihere gị, nʼihi na ị meela ka a gụọ ụmụnne gị ndị inyom dịka ndị ezi omume.
\p 
\v 53 “ ‘Ma otu ọ dị, aga m eme ka ọganihu nke Sọdọm na ụmụ ya ndị inyom, na ọganihu nke Sameria na ụmụ ya ndị inyom, na ọganihu nke gị dịghachikwa nʼetiti ha:
\v 54 Ka i nwee ike bụrụ ọnọdụ ihere gị, ka ihere mekwa gị nʼihi ihe niile i mere, nʼịkasị ha obi.
\v 55 Ọzọ ndị ụmụnne gị nwanyị bụ Sọdọm na Sameria na ụmụ ha ndị inyom ga-alọta nʼọnọdụ mbụ ha; gị na ụmụ gị ndị inyom ga-alọtakwa nʼọnọdụ mbụ unu.
\v 56 Ma ị pụghị emeghe ọnụ gị kpọọ aha nwanne gị nwanyị bụ Sọdọm nʼụbọchị nganga gị,
\v 57 tupu e kpughe ajọ omume gị. Ọ bụladị otu ahụ, ugbu a ị bụ ihe ịkwa emo nye ndị ada Edọm\f + \fr 16:57 \ft Ọtụtụ akwụkwọ mgbe ochie na-ede Aram\f* na ndị agbataobi ya niile, na ndị ada ndị Filistia. Ndị niile nọ gị gburugburu na-elelịkwa gị anya.
\v 58 Ị ga-anata ụgwọ ọrụ nke ịkwa iko gị, na ihe arụ ndị ọzọ ị na-eme. Otu a ka \nd Onyenwe anyị\nd* kwubiri ya.
\p 
\v 59 “ ‘Nke a bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị, Aga m akwụghachi gị dịka omume gị si dị, nʼihi na ị ledara iyi ahụ ị ṅụrụ anya site nʼimebi ọgbụgba ndụ ahụ.\f + \fr 16:59 \ft Ị kpachara anya mebie ọgbụgba ndụ nke mụ na gị gbara.\f*
\v 60 Ma otu ọbụla o si dị, aga m edebezu nkwa ahụ niile m kwere gị mgbe ị dị na nwantakịrị. Aga m eme ka ọgbụgba ndụ ahụ dị nʼetiti mụ na gị guzosie ike ruo ebighị ebi.
\v 61 Mgbe ahụ, ị ga-echeta ụzọ gị niile, ma nwee ihere, mgbe m ga-ewere ụmụnne gị ndị inyom ndị ahụ tọrọ gị na ndị nke ị tọrọ nye gị ha dịka ụmụ, ma ọ bụghị nʼihi ọgbụgba ndụ m.
\v 62 Aga m eme ka ọgbụgba ndụ mụ na gị guzosie ike, ị ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\v 63 Mgbe ahụ, aga m ekpuchiri gị ajọ omume niile bụ nke ị mere. Ihere ga-eme gị mgbe i chetara ndụ ọjọọ gị, ị gaghị emeghekwa ọnụ gị kwuo okwu nʼihi oke mweda nʼala gị. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.’ ”
\c 17
\s1 Ugo abụọ na otu osisi vaịnị
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, tụọ ilu kọwaara ụlọ Izrel akụkọ ihe ọmụma atụ.
\v 3 Sị ha, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, otu ugo nke nwere nku abụọ buru ibu, nke abụba ya tụrụ agwa agwa ma dịkwa ogologo, feere bịa na Lebanọn, tụjiri ọnụ ọnụ osisi sida kachasị ibe ya ogologo.
\v 4 Ọ kubipụrụ ọnụ ọnụ alaka osisi a, buru ya gaa nʼala ebe ọtụtụ ndị na-azụ ahịa juru, kụọ ya nʼobodo ahụ.
\p 
\v 5 “ ‘O sitekwara nʼala ahụ were otu mkpụrụ kụọ ya nʼala mara nnọọ ezi mma. Ọ kụrụ ya dịka e si akụ osisi wilo nʼakụkụ ebe enwere ụba mmiri.
\v 6 Ọ dịghị anya, mkpụrụ osisi ahụ gbara mgbọrọgwụ, too, ghọọ osisi vaịnị dị mkpụmkpụ, nke na-awasa awasa, nke alaka ya niile chere ihu nʼebe ugo ahụ nọ. O nwekwara alaka siri ike, na akwụkwọ mara mma.
\p 
\v 7 “ ‘Ma e nwekwara ugo ọzọ, nke nwere nku sara mbara, nke jupụtara nʼabụba. Mgbe ugo a bịara, osisi vaịnị a gbasakwara mgbọrọgwụ ya na alaka ya, chee ugo ahụ ihu, ka ọ gbakwasị ya mmiri.
\v 8 A kụrụ ya nʼebe ala dị mma, nʼakụkụ ọtụtụ mmiri, ka o nwee ike wapụta ngalaba, mịa mkpụrụ, ghọọkwa ezigbo vaịnị mara mma.’
\p 
\v 9 “Sị ha, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Ọ ga-adịhụkwa? Ọ bụ na agaghị ehopu mgbọrọgwụ ya niile, bipụkwa mkpụrụ ya niile mee ka ọ kpọnwụọ? Ka akwụkwọ ndụ niile nke na-epute ọhụrụ kpọnwụọ. Ọ gaghị ewekwa ogwe aka dị ike maọbụ ọtụtụ ndị mmadụ ihopụta ya site na mgbọrọgwụ ya.
\v 10 A kụọla ya ma ọ ga-etokwa? Ọ gaghị akpọnwụ kpamkpam mgbe oke ifufe si nʼọwụwa anyanwụ feturu ya, kpọnwụchakwaa nʼala ebe ahụ ọ nọ puo?’ ”
\p 
\v 11 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 12 “Ugbu a, gwa ndị nnupu isi ahụ, ‘unu maara ihe ilu a pụtara?’ Sị ha, ‘Lee, Babilọn bịara na Jerusalem dọkpụrụ eze ya na ndị ọchịchị ya laa Babilọn.
\v 13 O were otu onye site nʼezinaụlọ eze, ya na ya gbara ndụ, bụ onye o mere ka ọ ṅụọ iyi. O sitekwara nʼala ahụ bupụ ndị ndu obodo ahụ niile.
\v 14 Nʼụzọ dị otu a, alaeze ahụ ghọrọ alaeze e wedara nʼala nke ukwuu, nke na-enweghịkwa ike ibili ọzọ. Ọganihu nke alaeze ahụ dabeere naanị na ndebe ha debere ọgbụgba ndụ ahụ.
\v 15 Ma o nupuru isi nʼokpuru ya site nʼiziga ndị ozi nʼIjipt ka ha nye ya ọtụtụ ịnyịnya na ndị agha. Ọ ga-enwetakwa ihe ọ chọrọ? Onye na-eme ihe dị otu a, ọ pụrụ ịgbanarị ntaramahụhụ? Ọ pụrụ imebi ọgbụgba ndụ ma gbalaga?
\p 
\v 16 “ ‘Nʼezie, dịka mụ onwe m na-adị ndụ, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri, ọ ga-anwụ na Babilọn, nʼala nke eze ahụ mere ka ọ nọkwasị nʼocheeze, bụ onye o ledara ịṅụ iyi ya anya mebikwaa ọgbụgba ndụ ya.
\v 17 Nʼagbanyeghị igwe ndị agha ya siri ike, Fero agaghị enwe ike zọpụta ya nʼagha, mgbe ha ga-ewulite mgbidi agha, gwuokwa olulu nnọchibido iji gbuo ọtụtụ mmadụ.
\v 18 O lelịrị ịṅụ iyi ahụ site nʼimebi ọgbụgba ndụ ahụ. Nʼihi na o nyere aka ya nʼihe ibe ma gaa nʼihu mee ihe ndị a niile, mgbapụ agaghị adịrị ya.
\p 
\v 19 “ ‘Ya mere, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị, Dịka mụ onwe m na-adị ndụ, aga m akwụghachi ya nʼihi nleda anya o ledara ịṅụ iyi m nakwa nʼihi ọgbụgba ndụ nke o mebiri.
\v 20 Aga m agbasa ụgbụ m nʼụzọ o si aga; ọnya m ga-amakwa ya. Aga m ewetakwa ya na Babilọn, nọdụkwa nʼebe ahụ taa ya ahụhụ nʼihi na ọ kwesighị ntụkwasị obi nye m.
\v 21 Mma agha ka a ga-eji gbuo ndị agha ya niile na-agbapụ ọsọ, ndị niile fọdụrụ ka a ga-achụsasị nʼakụkụ niile. Mgbe ahụ, ị ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd* ekwuola ya.
\p 
\v 22 “ ‘Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, Mụ onwe m ga-esi nʼọnụ ọnụ osisi kachasị mma nke osisi sida kachasị elu kụrụ ihe m ga-akụ. Aga m esi nʼọnụ ọnụ osisi sida dị elu kụrụ alaka dị nro, nke m ga-akụ nʼugwu dị ezigbo elu.
\v 23 Ọ bụ nʼelu ugwu niile nke Izrel ka m ga-akụnye ya. Ọ ga-awapụtakwa alaka ya, mịa mkpụrụ, bụrụkwa sida mara oke mma. Ụmụ nnụnụ dị iche iche ga-ewu akwụ ha na ya, ha ga-achọtakwa ebe obibi na ndo nke alaka ya niile.
\v 24 Nʼoge ahụ, osisi ọhịa niile ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*, bụ onye na-egbuda osisi niile dị elu, ma na-ewelikwa ndị dị nta elu. Na ọ bụ m na-eme ka osisi dị ndụ kpọnwụọ, ma na-emekwa ka nke nwụrụ anwụ dịrị ndụ.
\p “ ‘Mụ onwe m bụ \nd Onyenwe anyị\nd* ekwuola ya. Aghakwaghị m ime ya.’ ”
\c 18
\s1 Mkpụrụobi mehiere ga-anwụ
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị, sị,
\v 2 “Gịnị ka unu bụ mmadụ na-ekwu mgbe unu na-atụ ilu a banyere ala Izrel?
\q1 “ ‘Ndị bụ nna eriela mkpụrụ vaịnị na-achaghị acha,
\q2 eze ụmụntakịrị a na-eru ha izizi.’
\p 
\v 3 “Dịka m na-adị ndụ, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri, unu agaghị atụkwa ilu a ọzọ nʼala Izrel.
\v 4 Nʼihi na mkpụrụobi niile bụ nke m, ma nke nna ma nke nwa, ha niile bụ nke m. Mkpụrụobi ọbụla mehiere bụ nke ga-anwụ.
\q1 
\v 5 “Ọ bụrụ na-enwere otu onye ezi omume
\q2 nke na-eme naanị ihe ziri ezi na ihe dị mma,
\q1 
\v 6 onye na-adịghị eje nʼugwu iri oriri
\q2 maọbụ welie anya ya nʼebe arụsị niile nke Izrel dị,
\q1 onye na-adịghị emerụ nwunye onye agbataobi ya,
\q2 maọbụ dinakwuru nwanyị nọ nʼoge nsọ ya.
\q1 
\v 7 Onye na-adịghị emegbu ndị mmadụ,
\q2 kama ọ na-akwụghachi ụgwọ o ji, maọbụ na-enyeghachi ihe ọ naara dịka ihe mbe,
\q1 ọ dịghị apụnara mmadụ ihe o nwere nʼike,
\q2 kama ọ na-enye ndị agụụ na-agụ nri,
\q2 na-enyekwa ndị gbaa ọtọ akwa mkpuchi.
\q1 
\v 8 Ọ dịghị agbazinye mmadụ ego nara mụrụ nwa,
\q2 ọ dịghị ana ụma site nʼaka ha.
\q1 Ọ na-esite nʼihe ọjọọ sepụ aka ya,
\q2 na-ekpekwa ikpe ziri ezi nʼetiti mmadụ na ibe ya.
\q1 
\v 9 Ọ na-edebezu iwu m niile,
\q2 na-agbaso ụkpụrụ m niile nʼikwesị ntụkwasị obi.
\q1 Onye ezi omume ka nwoke ahụ bụ;
\q2 ọ ghaghị ịdịkwa ndụ,
\q2 otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\p 
\v 10 “Ọ bụrụ na o nwere nwa nwoke na-akpa ike, na-akwafu ọbara, na-emekwa ihe ndị ọzọ dị iche iche,
\v 11 ọ bụ ezie na nna ya emeghị ihe ndị a:
\q1 “Ma ọ na-eri nri nʼụlọ arụsị dị nʼugwu,
\q1 na-emerụ nwunye onye agbataobi ya;
\q1 
\v 12 Ọ na-emegbu ndị ogbenye na ndị nọ na mkpa.
\q1 Ọ na-apụnara mmadụ ihe nʼike.
\q1 Ọ dịghị eweghachi ihe o naara na mbe.
\q1 Ọ na-efe arụsị,
\q1 na-emekwa ihe arụ ndị ọzọ dị iche iche.
\q1 
\v 13 Ọ na-anara ndị ọ gbazinyere ego ọmụrụnwa na ụma.
\m O kwesiri ka onye dị otu a dị ndụ? Ọ gaghị adị ndụ. Nʼihi na o meela ihe ndị a niile rụrụ arụ. A ga-egbu ya. Ọbara ya ga-adịkwa nʼisi ya.
\p 
\v 14 “Ọ bụrụkwa na nwoke a nwere nwa nwoke nke hụrụ ihe ọjọọ ndị a niile nna ya na-eme, ma kpebie na ọ gakwaghị ebi ụdị ndụ ahụ.
\q1 
\v 15 “Ọ dịghị eri nri nʼụlọ arụsị dị nʼelu ugwu
\q2 maọbụ welie anya lee arụsị niile nke Izrel.
\q1 Ọ dịghị emerụ nwunye onye agbataobi ya.
\q1 
\v 16 Ọ dịghị emegbu onye ọbụla,
\q2 maọbụ anara ihe mbe nʼihi ego ọ gbazinyere mmadụ.
\q1 Ọ dịghị apụnara mmadụ ihe o nwere nʼike,
\q2 kama na ọ na-enye ndị agụ na-agụ ihe oriri ya,
\q2 na-enyekwa ndị gbaa ọtọ akwa mkpuchi;
\q1 
\v 17 ọ bụrụ na ọ dịghị etinye aka na mmehie ọbụla,
\q2 na ọ naghị anara ọmụrụnwa na ụma nʼaka ndị o binyere ego,
\q1 na ọ na-erubekwara iwu m niile isi, na-agbaso ụkpụrụ m niile.
\m Onye dị otu a agaghị anwụ nʼihi mmehie nke nna ya mere. Ọ ga-adị ndụ.
\v 18 Ma nna ya ga-anwụ nʼihi mmehie niile o mere, nʼihi na ọ bụ onye na-ewe ihe na-abụghị nke ya, onye na-apụnara ndị ọzọ ihe ha nwere nʼike. Ọ bụkwa onye na-eme ihe ọjọọ dị iche iche nʼetiti ndị ya.
\p 
\v 19 “Ma unu na-ajụ, ‘Gịnị mere nwa adịghị eketa oke nʼahụhụ nke ajọ omume nna ya?’ Ihe dị otu ahụ apụghị ime, ebe ọ bụ na nwa ya emeela ihe ziri ezi ma leziekwa anya debezuo ụkpụrụ m niile, ọ ghaghị ịdị ndụ.
\v 20 Onye ahụ mere mmehie bụ onye ga-anwụ. Nwa agaghị ata ahụhụ nʼihi ihe nna ya metara, nna agakwaghị ata ahụhụ nʼihi ihe nwa ya metara. Onye ezi omume ga-anata ụgwọ ezi omume o mere, ma onye ajọ omume ga-anata ụgwọ nʼihi ajọ ihe o mere.
\p 
\v 21 “Ma ọ bụrụ na onye ajọ omume esite na mmehie niile o mere chigharịa, malite idebe ụkpụrụ m niile, ma na-emekwa ihe ziri ezi na nke dị mma, onye ahụ aghaghị ịdị ndụ, ọ gaghị anwụ.
\v 22 Ọ dịghị ajọ omume niile bụ nke ha mere a ga-echeta megide ha. Ha ga-adị ndụ nʼihi ihe ezi omume ha mere.
\v 23 Ọ na-atọ m ụtọ bụ ọnwụ nke ndị ajọ omume? Ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara. Kama, ọ bụghị mgbe ha si nʼụzọ ha chigharịa, dịrị ndụ, ka obi na-atọ m ụtọ?
\p 
\v 24 “Ma ọ bụrụ na onye ezi omume esite nʼezi omume ya chigharịa, mee mmehie na-emekwa ihe arụ nke ndị ajọ mmadụ na-eme, ha ọ ga-adị ndụ? Mba! Ọ dịghị ihe ezi omume nke onye dị otu a mere nke a ga-echetakwa. Nʼihi ekwesighị ntụkwasị obi ha, ha bụ ndị ikpe mara, nʼihi mmehie ndị ha mere, ha ga-anwụ.
\p 
\v 25 “Ma unu na-asị, ‘Ụzọ Onyenwe anyị ezighị ezi!’ Geenụ ntị, unu ụlọ Izrel. Ọ bụ nʼụzọ m ezighị ezi? Ọ bụghị ụzọ unu niile bụ nke na-ezighị ezi?
\v 26 Ọ bụrụ na onye ezi omume esite nʼezi omume ya chigharịa malite ime mmehie, ọ ga-anwụ maka ya; nʼihi mmehie ahụ o mere ka ọ ga-anwụ.
\v 27 Ọ bụrụ na onye ajọ omume esite nʼajọ omume niile nke o mere chigharịa malite ime ihe ziri ezi na nke dị mma, ọ ga-azọpụta ndụ ya.
\v 28 Nʼihi na ọ tuleela nʼobi ya, kpebiekwa ịhapụ mmehie ya niile, ma malite ibi ndụ ziri ezi. Ndụ ga-abụ nke ya. Ọ gaghị anwụ.
\v 29 Ma ụlọ Izrel na-asị, ‘Ụzọ Onyenwe anyị ezighị ezi!’ Ọ bụ nʼụzọ m niile ezighị ezi, unu ụlọ Izrel? Ọ bụghị ụzọ unu niile bụ nke na-ezighị ezi?
\p 
\v 30 “Ya mere, unu ụlọ Izrel, aga m ekpe onye ọbụla nʼime unu ikpe dịka ụzọ ya si dị, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya. Chegharịanụ, sitenụ na njehie unu niile unu chigharịa, mgbe ahụ, mmehie agaghị a bụrụ unu ihe ịsọ ngọngọ.
\v 31 Wezuganụ njehie niile unu jehiere nʼime ya, ka unu nweta obi ọhụrụ na mmụọ ọhụrụ. Ụlọ Izrel, gịnị mere unu ga-eji nwụọ?
\v 32 Nʼihi na ọ dịghị atọ obi m ụtọ ịhụ na onye ọbụla na-anwụ, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara. Chegharịakwanụ, ka unu dịrị ndụ!
\c 19
\s1 Abụ akwa nʼihi ọnọdụ ụmụ eze Izrel
\p 
\v 1 “Ma gị onwe gị, bụọrọnụ ndịisi Izrel abụ akwa a,
\v 2 ma kwuo,
\q1 “ ‘Ụdị nne Ọdụm gịnị ka nne gị bụ
\q2 nʼetiti ụmụ ọdụm.
\q1 Ọ dinara nʼetiti ha,
\q2 na-azụ ụmụ ya.
\q1 
\v 3 Ọ zụlitere otu nʼime ụmụ ya
\q2 nke ghọrọ nwa ọdụm siri ike.
\q1 Ọ mụtakwara ka e si adọrisi anụ ọhịa,
\q2 ghọọ ọdụm na-eri mmadụ.
\q1 
\v 4 Mba niile nụrụ maka ihe banyere ya,
\q2 mee ka ọ danye nʼolulu ha gwuru.
\q1 Ha ji nko koro ya,
\q2 duru ya gaa nʼala Ijipt.
\b
\q1 
\v 5 “ ‘Mgbe ọ hụrụ na ọ dịkwaghị ihe ọzọ o nwere ike ime banyere ọnọdụ ahụ,
\q2 matakwa na olileanya ya abụrụla ihe efu,
\q1 ọ họpụtara nwa ya ọzọ
\q2 kuziere ya otu ọ ga-esi bụrụ ọdụm dị ike.
\q1 
\v 6 Ọ ghọrọ onyeisi ụmụ ọdụm niile,
\q2 nʼihi na ọ bụ ọdụm siri ike,
\q1 ọ mụtakwara ka e si ejide anụ ọhịa,
\q2 ya onwe ya ghọkwara ọdụm na-eri mmadụ.
\q1 
\v 7 O tikpọrọ ebe ha niile e wusiri ike
\q2 meekwa obodo ha niile mkpọmkpọ ebe.
\q1 Ala ahụ na ndị niile nọ nʼime ya,
\q2 mara jijiji site nʼoke egwu nʼihi olu ịgbọ ụja ya.
\q1 
\v 8 Mgbe ahụ, ndị agha nke mba niile dị iche iche
\q2 pụtara gbaa ya gburugburu.
\q1 Ha sitere nʼakụkụ niile nwude ya
\q2 nʼọnya olulu ha siiri ya.
\q1 
\v 9 Ha tinyere ya nko nʼimi, were dọkpuo ya nʼụlọ igwe a kpara akpa,
\q2 bute ya nʼihu eze Babilọn.
\q1 E mere ka o biri na mba ọzọ dịka ohu,
\q2 ka a ghara ịnụ ụda olu ya ọzọ
\q2 nʼugwu niile nke Izrel.
\b
\q1 
\v 10 “ ‘Nne gị dịka osisi vaịnị nʼogige vaịnị
\q2 a kụrụ nʼakụkụ mmiri,
\q1 nke nwere ọtụtụ alaka, nke na-amịkwa mkpụrụ
\q2 nʼihi mmiri ọ na-enweta.
\q1 
\v 11 Alaka ya niile siri ike,
\q2 ha topụtara ghọọ mkpara eze.
\q1 O topụrụ etopụ,
\q2 tokarịa alaka ndị ọzọ elu.
\q1 Nke a mere e ji na-ahụ ya anya
\q2 site nʼebe dị anya.
\q1 
\v 12 Ma e ji oke iwe hopu ya
\q2 tụpụ ya nʼala.
\q1 Oke ifufe si nʼọwụwa anyanwụ mere ka akwụkwọ ya kpọnwụsịa,
\q2 meekwa ka mkpụrụ ya daa.
\q1 Alaka ya ndị ahụ dị ike kpọnwụsịrị,
\q2 ọkụ rechapụkwara ha niile.
\q1 
\v 13 Ugbu a, akụọla ya nʼime ọzara
\q2 ebe kpọrọ nkụ nke mmiri na-adịghị.
\q1 
\v 14 Ọkụ esitela nʼogwe ya rechapụ alaka ya
\q2 na mkpụrụ ya niile.
\q1 Ọ dịkwaghị alaka siri ike fọdụrụ
\q2 nke dịkwa mma ịbụ mkpara eze.’
\m Abụ a bụ abụ akwa, nke e kwesiri ịbụ mgbe ịkwa akwa.”
\c 20
\s1 Izrel ndị na-enupu isi
\p 
\v 1 O ruo, nʼọgwụgwụ ọnwa ise, nʼafọ nke asaa, ụfọdụ nʼime ndị okenye Izrel bịara ịjụta \nd Onyenwe anyị\nd* ase. Ha nọdụrụ ala nʼihu m.
\p 
\v 2 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 3 “Nwa nke mmadụ, gwa ndị okenye Izrel okwu sị ha, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ajụ, Ọ bụ ịjụpụta ase nʼaka m ka unu bịara? Dịka mụ onwe m na-adị ndụ, agaghị m ekwe ka unu jụọ m ase ọbụla, ọ bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.’
\p 
\v 4 “Ị ga-ekpe ha ikpe? Ị ga-ekpe ha ikpe, nwa nke mmadụ? Mee ka ha mara banyere ihe arụ niile nna nna ha mere.
\v 5 Gwa ha, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị, nʼụbọchị m họpụtara Izrel, eweliri m aka m ṅụọrọ ya na ụmụ ya bụ ụlọ Jekọb iyi ma kpugheekwa onwe m gosi ha nʼala Ijipt. Site nʼiweli aka m, agwara m ha okwu sị, “Mụ onwe m bụ \nd Onyenwe anyị\nd* bụ Chineke unu.”
\v 6 Nʼụbọchị ahụ, aṅụụrụ m ha iyi na m ga-esi nʼala Ijipt dupụta ha baa nʼala nke m chọpụtara ha, ala mmiri ara ehi na mmanụ aṅụ na-eru na ya, bụ ala nke kachasị ibe ya mma.
\v 7 Mgbe ahụ, agwara m ha, “Onye ọbụla nʼime unu, wezuganụ oyiyi ihe arụ niile ndị ahụ bụ nke unu legidere anya, unu ejikwala arụsị niile nke Ijipt merụọ onwe unu. Mụ onwe m bụ \nd Onyenwe anyị\nd* bụ Chineke unu.”
\p 
\v 8 “ ‘Ma ha nupuru isi megide m. Ha aṅaghị m ntị. Ha ewezugakwaghị oyiyi ihe arụ ndị a, bụ nke ha lekwasịrị anya, maọbụ hapụkwanụ arụsị niile nke ndị Ijipt. Nʼihi ya, aga m awụkwasị ha oke iwe m, meekwa ka iwe m zuo oke nʼahụ ha nʼIjipt.
\v 9 Ma nʼihi aha m, e si m Ijipt kpọpụta ha. E mere m nke a ka a ghara imerụ aha m bụ nke dị nsọ, nʼanya ndị mba dị iche iche nʼetiti ndị ha binyere, bụ ndị mkpughere onwe m nye Izrel nʼihu ha.
\v 10 Nʼihi ya, esitere m nʼIjipt dupụta ha, dubata ha nʼọzara.
\v 11 Nʼebe ahụ ka m nọ nye ha iwu m niile, gosikwa ha ụkpụrụ m, gwa ha na onye ọbụla debere ha ga-adị ndụ.
\v 12 Ọzọ, e nyekwara m ha ụbọchị izuike, ka ọ bụrụ ihe ịrịbama dị nʼetiti mụ na ha, ka ha maara na mụ onwe m bụ \nd Onyenwe anyị\nd*, na-edo ha nsọ.
\p 
\v 13 “ ‘Ma ụlọ nke Izrel nupuru isi megide m. Nʼime ọzara ahụ, ha jụrụ idebe iwu m. Ha agbasoghị usoro m, ọ bụ ezie na ịgbaso ya pụtara ịdị ndụ. Ha edebeghị ụbọchị izuike m nsọ. Nʼihi ya, ekpebikwara m na m ga-awụkwasị ha iwe ọkụ m, ka m kpochapụ ha nʼime ọzara.
\v 14 Ma nʼihi aha m, e mere m ihe ga-eme ka a ghara ime ya ka ọ hapụ ịdị nsọ nʼanya ndị mba niile, bụ ndị hụrụ mgbe m si Ijipt kpọpụta ha.
\v 15 Ma nʼime ọzara ahụ, eweliri m aka ṅụọrọ ha iyi na m agaghị eduba ha nʼala ahụ m nyere ha, ala mmiri ara ehi na mmanụ aṅụ na-eru na ya, ala ahụ kachasị ala niile ọzọ dị nʼụwa mma.
\v 16 Nʼihi na ha jụrụ iwu m, ha jụkwara ịgbaso ụkpụrụ m niile. Ha merụrụ ụbọchị izuike m, nʼihi na obi ha niile dị nʼebe arụsị ha dị.
\v 17 Ma eji m obi ebere lee ha anya ma ghara ịla ha nʼiyi. Ekpochapụghị m ha nʼọzara.
\v 18 Mgbe ahụ, agwara m ụmụ ha okwu nʼọzara, “Unu agbasola nzọ ụkwụ nna unu ha maọbụ debe iwu ha maọbụ jiri arụsị ha merụọ onwe unu.
\v 19 Mụ onwe m bụ Onyenwe na Chineke gị. Gbasoonụ iwu m niile, lezie anya ka ị sorokwa ụzọ m niile.
\v 20 Doonụ ụbọchị izuike m nsọ, ka ha ghọọkwa ihe ịrịbama nʼetiti mụ na unu. Mgbe ahụ, unu ga-amata na mụ onwe m bụ Onyenwe na Chineke unu.”
\p 
\v 21 “ ‘Ma ụmụ ahụ nupuru isi megide m. Ha ejegharịghị nʼụkpụrụ m, ha elezighị anya ka ha debe iwu nke m kwuru banyere ha, “Na onye ọbụla na-erubere ha isi ga-adị ndụ site na ha,” ha merụrụ ụbọchị izuike m. Nʼihi ya, asịrị m, Aga m awụkwasị ha ọnụma m, mezuokwa iwe m megide ha nʼọzara.
\v 22 Ọzọkwa, eseghachiri m aka m, nʼihi aha m, e mere m ihe ga-eme ka a ghara ime ya ka ọ hapụ ịdị nsọ nʼanya ndị mba niile, bụ ndị hụrụ mgbe m si Ijipt kpọpụta ha
\v 23 E jikwa m iweli aka elu ṅụọrọ ha iyi nʼime ọzara, na m ga-achụsasị ha nʼetiti mba niile, mee ka ha gbasaa nʼakụkụ niile nke ụwa,
\v 24 nʼihi na ha edebeghị iwu m, kama ha jụrụ ụkpụrụ niile, lelịa ma merụọkwa ụbọchị izuike m. Naanị ihe na-agụ ha bụ arụsị niile nke nna ha.
\v 25 Ahapụrụ m ha ka ha nabatara onwe ha iwu na omenaala dị iche iche nke na-abaghị uru. Nʼihi na site nʼidebe omenaala ndị a, ha apụghị inweta ndụ.
\v 26 E merụrụ ha site nʼonyinye ha, bụ, iji nwa mbụ ọbụla chụọ aja, ka m si otu a menye ha egwu ka ha mara na mụ onwe m bụ Onyenwe.’
\p 
\v 27 “Ya mere, nwa nke mmadụ, gwa ụlọ Izrel okwu, sị ha, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu, Nna unu ha kwuluru m na nke a, site na-ekwesighị ntụkwasị obi nye m.
\v 28 Mgbe m dubatara ha nʼala ahụ nke m ṅụrụ nʼiyi inye ha, ha hụrụ ugwu dị elu maọbụ osisi nwere ọtụtụ akwụkwọ, ebe ahụ ha chụrụ aja ha, nyekwa onyinye ha, si otu a kpasuo m iwe. Ha doro ha ihe ndị ahụ niile na-esi isi ụtọ, wụsakwara ha aja ihe ọṅụṅụ
\v 29 Ya mere a jụrụ m ha, Gịnị ka a na-akpọ ebe ịchụ aja a unu na-aga?’ ” (A na-akpọ ya Baama ruo taa.)
\s1 Ikpe ọmụma na nlọghachi
\p 
\v 30 “Nʼihi nke a, gwa ụlọ Izrel, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Unu ọ ga-emerụ onwe unu dịka nna nna unu ha mere site nʼịchụso oyiyi ihe arụ ha dị iche iche?
\v 31 Mgbe unu na-enye onyinye unu, na-eme ka ụmụ unu site nʼọkụ gafee, unu na-aga nʼihu jiri arụsị unu niile na-emerụ onwe unu ruo taa. Mụ onwe m, m ga-ekwe ka unu jụta m ase, O ụlọ Izrel? Dịka mụ onwe m na-adị ndụ, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri, agaghị m ekwe ka unu jụọ m ase.
\p 
\v 32 “ ‘Unu na-ekwu nʼobi unu sị, “Anyị chọrọ ịdị ka mba ndị ọzọ, dịka agbụrụ ndị ọzọ nọ nʼụwa, ndị na-akpọ isiala nye osisi na nkume.” Ma ihe unu bu nʼobi agaghị emezu.
\v 33 Dịka m na-adị ndụ, aga m eji aka ike na ogwe aka e setịrị eseti nakwa nwụpụ nke oke iwe m chịa unu, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.
\v 34 Aga m akpọpụta unu site na mba dị iche iche, chịkọtaa unu site na mba ndị ahụ a chụsasịrị unu. Ọ bụ aka m dị ike, aka m setịpụrụ na ọnụma a wụpụrụ ka m ga-eji mee ya.
\v 35 Aga m akpọbata unu nʼọzara nke mba niile, nọdụ nʼebe ahụ kpee unu ikpe nʼihu nʼihu.
\v 36 Dịka m kpere nna nna unu ha ikpe nʼọzara nke dị nʼala Ijipt, otu a ka m ga-esi kpee unu ikpe, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\v 37 Aga m eme ka unu si nʼokpuru mkpanaka m gafee,\f + \fr 20:37 \ft Dịka mgbe onye ọzụzụ atụrụ na-agụ atụrụ ya ọnụ maọbụ na-achọ ịmata ọnọdụ ahụ ha\f* aga m akpọbata unu na njikọ nke ọgbụgba ndụ ahụ.
\v 38 Aga m esi nʼetiti unu wezuga ndị na-ekwe ntị ike ma na-enupu isi megide m. Ọ bụ ezie na m ga-akpọpụta ha site nʼala ahụ ha bi, ma ha agaghị abata nʼala Izrel. Mgbe ahụ, unu ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\p 
\v 39 “ ‘Ma banyere unu, bụ ụlọ Izrel, nke a bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu: Gaanụ fee arụsị unu niile dị iche iche, onye ọbụla nʼime unu. Ma emesịa, unu aghaghị ịṅa m ntị, ọ dịghịkwa mgbe unu ga-eji onyinye na arụsị unu niile merụọ aha nsọ m.
\v 40 Nʼihi na ọ bụ nʼelu ugwu m dị nsọ, nke bụ elu ugwu ukwu nke Izrel, ka Izrel niile ga-anọ fee m. Nʼebe ahụ ka m ga-anọkwa nabata onyinye unu na onyinye pụrụ iche unu, na aja nsọ unu dị iche iche. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\v 41 Aga m anabatakwa unu dịka onyinye ihe nsure ọkụ na-esi isi ụtọ, mgbe m si na mba dị iche iche kpọlata unu, mgbe m ga-achịkọta unu site nʼobodo ahụ niile a chụgara unu. Mgbe ahụ, mba niile ga-amata na m dị nsọ.
\v 42 Mgbe m mere ka unu lọta nʼala Izrel, bụ ala ahụ m weliri aka elu ṅụọ iyi inye nna nna unu ha, unu ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\v 43 Nʼebe ahụ, unu ga-echeta obibi ndụ na omume mmehie niile unu ji merụọ onwe unu. Unu ga-asọkwa onwe unu oyi, nʼihi ihe ọjọọ niile unu mere.
\v 44 Unu ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*, mgbe m mesochara unu mmeso nʼihi aha m, na-agụghị ajọ omume unu maọbụ otu ụzọ ọjọọ niile unu si dị, unu bụ ụlọ Izrel. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara.’ ”
\s1 Amụma megide ndịda
\p 
\v 45 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 46 “Nwa nke mmadụ, chee ihu gị nʼụzọ ndịda. Kwuokwa okwu megide ala ahụ dị na ndịda, na oke ọhịa niile dị na ndịda.
\v 47 Sị oke ọhịa ndịda ahụ, ‘Nụrụ okwu nke \nd Onyenwe anyị.\nd* Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Ana m akwado isunye gị ọkụ, nke ga-erechapụ osisi niile dị nʼime gị, ma ndị dị ndụ ma ndị kpọnwụrụ akpọnwụ. A pụghị imenyụ oke ọkụ ahụ, ọ ga-erechapụkwa ihu niile site na ndịda ruo nʼugwu niile.
\v 48 Ihe niile bụ mmadụ, ga-ahụ na mụ onwe m bụ \nd Onyenwe anyị\nd*, sunyere ọkụ ahụ. A gaghị emenyụkwa ya.’ ”
\p 
\v 49 Mgbe ahụ, ekwuru m sị, “Ewoo, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* ha na-ekwu banyere m, sị, ‘Ọ bụghị naanị ilu ka ọ na-atụ?’ ”
\c 21
\s1 Babilọn, mma agha Chineke
\p 
\v 1 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, chee ihu gị nʼụzọ Jerusalem, buo amụma megide ụlọnsọ ukwu ahụ. Bukwaa amụma megide ala Izrel
\v 3 sị ala Izrel otu a, ‘Otu a ka \nd Onyenwe anyị\nd* na-ekwu, Mụ onwe m na-emegide gị. Aga m esite nʼọbọ mịpụta mma agha m, site na gị gbuchapụ ma onye ezi omume na onye ajọ omume.
\v 4 Nʼihi na m na-aga igbuchapụ ndị ezi omume na ndị ajọ omume, mma agha m ga-esite nʼọbọ ya pụta megide onye ọbụla site nʼugwu ruo na ndịda.
\v 5 Mgbe ahụ, mmadụ niile ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd* amịpụtala mma agha m site nʼọbọ ya, ọ gaghị amịghachi baa nʼọbọ ọzọ.’
\p 
\v 6 “Nʼihi ya, sụọ ude, nwa nke mmadụ, sụọ ude nʼihu ha nʼọnọdụ oke mwute na obi mgbawa.
\v 7 Mgbe ha jụrụ gị, ‘Gịnị kpatara i ji asụ ude?’ Ị ga-asị, ‘Nʼihi ozi nke na-abịa. Obi niile ga-agbaze site nʼegwu, aka niile ga-akụdakwa; mmụọ niile ga-ada mba,\f + \fr 21:7 \ft Maọbụ, \fqa ike ga-agwụ mmụọ niile\f* ikpere niile ga-ede mmiri site nʼamịrị.’ Ọ na-abịa, ọ ghaghị imezu, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.”
\p 
\v 8 Ọzọkwa, okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 9 “Nwa nke mmadụ buo amụma sị, ‘Ihe a ka Onyenwe anyị kwuru:
\q1 “ ‘Lee, mma agha, lee, mma agha,
\q2 a mụọla ya, hichakwaa ya.
\q1 
\v 10 Amụọla ya nʼihi oke ogbugbu nke gaje ịdị,
\q2 hichakwaa ya nke ọma ka ọ na-egbu dịka amụma.
\p “ ‘Anyị ọ ga-aṅụrị ọṅụ na mkpara eze nwa m nwoke Juda? Mma agha na-elelị mkpara niile dị otu a anya.
\q1 
\v 11 “ ‘E nyere iwu ka e hichazie mma agha ahụ,
\q2 ka e jidekwa ya nʼaka.
\q1 A mụọla ya, hichazie ya.
\q2 E doziela ya maka onye ahụ ga-eji ya laa ndụ nʼiyi.
\q1 
\v 12 Nwa nke mmadụ, tie mkpu akwa ma kwasie akwa ike,
\q2 nʼihi na ọ bụ megide ndị m
\q2 ọ bụkwa megide ndịisi Izrel niile.
\q1 A na-atụnyere ha mma agha ga-egbu ha,
\q2 ha na ndị m.
\q1 Nʼihi ya, tie aka gị nʼobi gị.\f + \fr 21:12 \ft Maọbụ, \fqa tie aka nʼapata ụkwụ gị\f*
\p 
\v 13 “ ‘Ọnwụnwa aghaghị ịbịa. Ma gịnị ga-eme, ma ọ bụrụ na mkpara eze nke mma agha na-elelị anya, agaghị nʼihu na-adịgide? Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.’
\q1 
\v 14 “Nʼihi ya, buo amụma, nwa nke mmadụ.
\q2 Kụkọọ ọbụ aka gị abụọ,
\q1 ka mma agha gbuo ugboro abụọ
\q2 e, ọ bụladị ugboro atọ.
\q1 Ọ bụ mma agha e debere maka ogbugbu,
\q2 nke e debere maka oke ogbugbu
\q2 nke ga-abịachibido ha gburugburu.
\q1 
\v 15 Ka obi ha gbazee site nʼegwu,
\q2 ka ndị na-ada ada hie nne,
\q1 nʼihi na edoziela m mma agha ahụ nʼọnụ ụzọ ama ha niile
\q2 maka oke ogbugbu.
\q1 Lee, mma agha ahụ na-egbu amụma,
\q2 etinyela ya nʼaka onye ga-egbu oke ogbugbu.
\q1 
\v 16 Gị mma agha, ebe ọbụla ị chọrọ, ebe ọbụla i nwere ike, gbuo onye ọbụla,
\q2 ma ọ nọ gị nʼaka nri
\q2 ma ọ nọ gị nʼaka ekpe.
\q1 
\v 17 Mụ onwe m ga-akụkọtakwa ọbụ aka m,
\q2 ime ka iwe m jụrụ.
\q1 Mụ onwe m bụ \nd Onyenwe anyị\nd* ekwuola.”
\p 
\v 18 Okwu nke \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 19 “Nwa nke mmadụ mee ụzọ abụọ nke mma agha eze Babilọn ga-eso. Ka ụzọ abụọ ndị a malite nʼotu obodo. Dee ihe ngosi manye ha nʼebe ahụ ụzọ wara abụọ.
\v 20 Mee ka otu nʼime ụzọ ndị ahụ bụrụ ebe mma agha ga-esi bịa megide Raba nke Amọn, ka nke ọzọ megide Juda na Jerusalem, bụ ebe e wusiri ike.
\v 21 Nʼihi na eze Babilọn ga-abịa guzo nʼebe ahụ ụzọ wara abụọ,\f + \fr 21:21 \ft Maọbụ, \fqa nʼagbata ụzọ\f* nʼisi ụzọ abụọ ahụ ịchọ ihe ama. Ọ ga-esite nʼịgba àkụ nke ife nza, jụọ ase site nʼaka arụsị ya niile, nyochakwaa umeju ahụ.
\v 22 Nʼụzọ dị nʼaka nri, ka ihe ịjụ ase banyere Jerusalem ga-esi bịa. Nʼebe ahụ ka ọ ga-ewu ihe niile ha ji etida mgbidi obodo ahụ. Nʼebe ahụ ka ọ ga-anọ nye iwu maka igbuchapụ ndị niile, na iwu ido ihe e ji etipu mgbidi nʼọnụ ụzọ ama niile, na iwu a ga-eji wuo nkwasa agha na mgbidi e ji ebuso ya agha.
\v 23 Ọ ga-adị ha dịka ọjụjụ ase nke na-abaghị uru, nye ndị ahụ ṅụrụ ha iyi, ma ọ ga-echetara ha ihe ọjọọ\f + \fr 21:23 \ft Ya bụ, ajọ omume ha\f* ha mere, dọkpụrụ ha nʼike.
\p 
\v 24 “Nʼihi ya, ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru. ‘Ebe ọ bụ na unu esitela na nnupu isi unu mee ka e cheta ajọ omume unu, si otu a na-ekpughe mmehie unu nʼihe niile unu na-eme. Ebe ọ bụ na unu emeela ihe dị otu a, a ghaghị ịdọta unu nʼagha.
\p 
\v 25 “ ‘Gị onye rụrụ arụ, onye na-emebi iwu, gị nwa eze nʼIzrel, gị onye ụbọchị ahụhụ ya rurula,
\v 26 ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị, yipụ okpueze gị, ya na akwa ị na-atụghị nʼisi. Ihe agaghị adịkwa dịka o si adị na mbụ. A ga-ebuli ndị dị ala, wedata ndị dị elu.
\v 27 Mbibi, mbibi. Aga m eme ka ọ ghọọ ihe e bibiri ebibi. A gaghị eweghachikwa ya ọzọ tutu ruo mgbe onye ahụ o ruuru nʼizi ezi bịara. Ya ka m ga-enyefe ya nʼaka.’
\p 
\v 28 “Ma gị onwe gị, Nwa nke mmadụ, buo amụma kwuo, ‘Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru megide ndị Amọn nʼihi ịkwa emo ha:
\q1 “ ‘Lee mma agha, lee mma agha,
\q2 nke a mịpụtara maka oke ogbugbu.
\q1 E hichaziela ya mee ka ọ dị nkọ iripịa,
\q2 ka ọ na-egbu amụma dịka amụma egbe eluigwe.
\q1 
\v 29 Nʼagbanyeghị ọhụ ụgha nke a na-ahụ banyere unu,
\q2 na a jụtakwala ase ụgha banyere unu,
\q1 a ga-etinye ya nʼolu
\q2 ndị mmebi iwu ahụ a gaje igbu egbu,
\q1 bụ ndị ụbọchị ha rurula,
\q2 ndị oge ịta ahụhụ ha zukwara.
\b
\q1 
\v 30 “ ‘Mịghachinụ ya nʼọbọ ya.
\q2 Nʼebe ahụ e kere unu
\q1 nʼala nna nna unu ha,
\q2 Aga m ekpe unu ikpe.
\q1 
\v 31 Aga m awụkwasị unu ọnụma m,
\q2 kukwasịkwa unu ikuku nke oke iwe m.
\q1 Aga m ewere unu nyefee nʼaka ndị na-eme ihe ike,
\q2 ndị bụ ọka na ịla mmadụ nʼiyi.
\q1 
\v 32 Unu ga-aghọkwa mmanụ a na-awụnye nʼọkụ.
\q2 A ga-awụsịkwa ọbara unu nʼala unu.
\q2 Ọ dịkwaghị onye ga-echeta unu ọzọ,
\q1 nʼihi na mụ onwe m bụ \nd Onyenwe anyị\nd* ekwuola.’ ”
\c 22
\s1 Ikpe ọmụma nʼihi mmehie Jerusalem
\p 
\v 1 Okwu nke \nd Onyenwe anyị\nd* ruru m ntị, sị:
\b
\p 
\v 2 “Ma gị onwe gị, Nwa nke mmadụ, ị ga-ekpe ya ikpe? Ị ga-ekpe obodo ọbara a ikpe? Mgbe ahụ, ị ga-eguzogide ya ihu nʼihu mee ka ọ mara ihe arụ niile o mere.
\v 3 ‘Ị ga-asị, Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu: Gị obodo nke na-ewetara onwe gị mbibi nʼihi ọbara niile a na-awụsi nʼetiti gị, na arụsị niile i ji na-emerụ onwe gị.
\v 4 Lee ka i si bụrụ onye ikpe mara nʼihi ọbara ị wụsiri. Leekwa ka i si bụrụ onye e merụrụ emerụ site nʼarụsị niile ị kpụrụ. I jirila aka gị mee ka ọgwụgwụ gị dị nso, leekwa na ọgwụgwụ gị dị nso, leekwa na ọgwụgwụ gị abịala nʼezie. Nʼihi ya, aga m eme gị ka ị bụrụ ihe nkọcha nye mba niile, na ihe ịkwa emo nye mba dị iche iche.
\v 5 Ndị nọ gị nso na ndị nọ gị ebe dị anya ga-achị gị ọchị, gị obodo rụrụ arụ, na nke jupụtara nʼọgbaaghara.
\p 
\v 6 “ ‘Lee ka ndịisi Izrel nọ nʼime gị si e ji ike ha nwere na-awụsi ọbara.
\v 7 A na-elelị nne na nna nʼime gị. Ndị mbịarambịa ka e ji anya ike na-emegbu. Ndị na-enweghị nna na ndị inyom di ha nwụrụ ka a na-akpagbu, na-emejọkwa.
\v 8 I lelịala ihe nsọ m niile, merụọkwa ụbọchị izuike m niile.
\v 9 Ndị nkwutọ, ndị na-awụsi ọbara nọ nʼime gị. Ndị na-eri nri nʼihu arụsị niile dị nʼelu ugwu, na ndị na-eme omume rụrụ arụ nọkwa nʼime gị.
\v 10 Nʼime gị ka ndị na-akwaso nwunye nna ha iko dị, nʼime gị ka ndị na-awakpo ụmụ nwanyị mgbe ha nọ na nsọ ha, bụ mgbe ha nọ nʼọnọdụ adịghị ọcha.
\v 11 Nʼime gị ka otu nwoke na-eme ihe arụ ya na nwunye onye agbataobi ya, onye ọzọ na-enweghị ihere emerụọla nwunye nwa ya, onye ọzọkwa, emerụkwala nwanne ya nwanyị, bụ ada nke nna ya mụrụ.
\v 12 E nwekwara ndị na-anara ego gbuo mmadụ ibe ha nʼime gị. Gị onwe gị na-anarakwa ndị i binyere ego ụma buru ibu, na-esitekwa nʼaka ike na-anara ndị mmadụ ihe ha. I chefuokwala m. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\p 
\v 13 “ ‘Lee, aghaghị m ịkụkọta ọbụ aka m abụọ nʼihi uru nke na-ezighị ezi ị na-eri, na ọbara niile nke ị wụsiri nʼetiti gị.
\v 14 Obi gị ọ ga-esikwa ike? Ị ga-eguzokwa nʼụbọchị m ga-ekpe gị ikpe? Nʼihi na mụ onwe m bụ \nd Onyenwe anyị\nd* ekwuola. Aga m emezukwa ya.
\v 15 Aga m achụsa unu nʼetiti mba niile, fesaa unu nʼetiti mba niile. Aga m emekwa ka adịghị ọcha unu kwụsị.
\v 16 Mgbe e mere ka ị ghara ịdị nsọ nʼanya ndị mba dị iche iche, ị ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*.’ ”
\p 
\v 17 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 18 “Nwa nke mmadụ, ụlọ Izrel aghọọlara m ihe efu. Ha niile aghọọla ọla, na gbamgbam, na igwe, na ọla opu a hapụrụ nʼọkụ. Ha bụ nnọọ ihe efu nke ọlaọcha.
\v 19 Nʼihi ya, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: ‘Nʼihi na unu niile aghọọla ihe efu, aga m achịkọta unu nʼime Jerusalem.
\v 20 Dịka a na-achịkọta ọlaọcha, na ọla, na igwe, na opu, na gbamgbam, tinye ha nʼoke ọkụ ka ha gbazee, otu a ka m ga-esite nʼiwe m na ọnụma m chịkọtaa unu nʼime obodo ahụ gbazee unu.
\v 21 Aga m achịkọta unu, fụkwasị unu ọkụ nke ọnụma m, mee ka unu gbazee nʼime ya.
\v 22 Dịka ọlaọcha si agbaze nʼọkụ, otu a ka unu ga-esi gbazee nʼime ya. Unu ga-amatakwa nʼezie na mụ onwe m bụ \nd Onyenwe anyị\nd* awụkwasịla unu iwe m.’ ”
\p 
\v 23 Ọzọkwa, okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 24 “Nwa nke mmadụ, gwa ala ahụ okwu, ‘Ị bụ ala nke a na-emebeghị ka ọ dị ọcha, maọbụ mmiri izokwasị ya nʼụbọchị ọnụma.’
\v 25 E nwere izuzu ọjọọ nke ndị ụmụ eze\f + \fr 22:25 \fq Ụmụ eze \ft nʼebe pụtara \fqa ndị amụma\f* nọ nʼime ya, dịka ọdụm nke na-agbọ ụja na-adọgbu anụ ọ na-eri eri, ha na-eripịa ndị mmadụ. Ha ewerela akụ ha na ihe ha niile dị oke ọnụahịa, mekwa ka ụmụ nwanyị na-enweghị di baa ụba nʼetiti ya.
\v 26 Ndị nchụaja ya na-enupu isi nʼiwu m niile, mee ka ihe nsọ m niile gharakwa ịdị nsọ, nʼebe nsọ m. Ha adịghị akpakwa oke nʼetiti ihe dị nsọ na ihe na-adịghị nsọ. Ha na-ezi ndị m na ihe dị iche ọbụla adịghị nʼetiti ihe dị ọcha na ihe na-adịghị ọcha. Ha adịghị akpọkwa ụbọchị izuike m ihe ọbụla. Nʼihi ya, e mere ka m ghara ịdịkwa nsọ nʼetiti ha.
\v 27 Ndịisi nọ nʼime gị dịka nkịta ọhịa na-adọgbu anụ o gbutara. Ha na-awụsi ọbara, ime ka mkpụrụobi mmadụ laa nʼiyi nʼihi uru akpa ha.
\v 28 Ndị amụma ha eteela nzu nʼọrụ ha niile site nʼọhụ ụgha nʼịgba afa ụgha mgbe ha na-ahụghị ọhụ ọbụla. Ha na-asị, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị,’ mgbe \nd Onyenwe anyị\nd* na-ekwughị ihe ọbụla.
\v 29 Ndị ala a na-eji aka ike na-apụnara ndị ọzọ ihe ha nwere na-ezukwa ohi. Ha na-emegbu ndị ogbenye na ndị nọ na mkpa, na-emegbukwa ndị ọbịa site nʼụzọ ekpeghị ikpe ziri ezi.
\p 
\v 30 “Achọrọ m otu onye nʼetiti ha bụ onye nke ga-ewuzi mgbidi ogige, guzokwa nʼihu m ikwuchite ọnụ ala a, ka m ghara ịla ala a nʼiyi, ma ọ dịghị onye m hụrụ.
\v 31 Nʼihi ya, aga m awụkwasị ha ọnụma m, jirikwa iwe m dị ọkụ rechapụ ha. Aga m ebokwasịkwa ahụhụ niile nke mmehie ha, nʼisi ha, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.”
\c 23
\s1 Ụmụnne nwanyị abụọ na-akwa iko
\p 
\v 1 Okwu nke \nd Onyenwe anyị\nd* ruru m ntị, sị m,
\v 2 “Nwa nke mmadụ, ọ dị ndị inyom abụọ nke otu nne mụrụ.
\v 3 Ha ghọrọ ndị akwụna nʼala Ijipt site na mgbe ha bụ agbọghọ. Nʼala ahụ, a bịagidere ara ha aka, pịakwa ọnụ ara agbọghọ ha aka nʼọnọdụ igwuri egwu.
\v 4 Aha nke okenye bụ Ohola. Aha nwanne ya nwanyị bụ Oholiba. Ha bụrịị nkem, ha mụtakwara m ụmụ ndị nwoke na ndị nwanyị. Ohola bụ Sameria, Oholiba bụkwa Jerusalem.
\p 
\v 5 “Ohola na-agba akwụna mgbe ọ ka bụ nkem. O nwere agụụ ịkwa iko nʼebe ndị niile ọ hụrụ nʼanya nọ, bụ ndị dike nʼagha nke ndị Asịrịa,
\v 6 ndị yi uwe anụnụ, ndịisi ọchịchị na ndị ọchịagha, ha niile bụ ụmụ okorobịa mara mma nʼile anya, na ndịisi agha, ndị ikom na-amakwasị nʼelu ịnyịnya.
\v 7 O weere onwe ya nyefee nʼaka ndị ikom Asịrịa ogugo ha kachasị elu dịka onye akwụna, merụọkwa onwe ya site nʼife arụsị dị iche iche nke onye ọbụla agụụ ya gụrụ obi ya.
\v 8 Ma ọ hapụghị mmụọ akwụna ahụ dị nʼime ya, bụ nke o bidoro nʼIjipt, nke bụ na mgbe ọ bụ agbọghọ ya na ndị ikom dinakọrọ, ha na-apịkwa ọnụ ara agbọghọ ya aka, na-awụkwasịkwa agụụ nke ọchịchọ ọjọọ ha nʼahụ ya.
\p 
\v 9 “Nʼihi nke a enyefere m ya nʼaka ndị ahụ hụrụ ya nʼanya, bụ ndị Asịrịa, ndị agụụ ha na-agụ ya.
\v 10 Ha gbara ya ọtọ, ha kpọọrọ ụmụ ya ndị ikom na ndị inyom, ma ya onwe ya ka ha were mma agha gbuo. Nʼụzọ dị otu a, ọ ghọrọ ihe akụkọ ilu nʼetiti ndị inyom niile, a takwara ya ahụhụ.
\p 
\v 11 “Oholiba bụ nwanne ya nwanyị hụrụ ihe ndị a, ma nʼime agụụ ihe ọjọọ nke gụrụ ya nakwa ịgba akwụna, ọ kpara agwa jọrọ njọ karịa nke nwanne ya nwanyị.
\v 12 Ya onwe ya kwa, agụụ ụmụ Asịrịa gụrụ ya, bụ ndịisi ọchịchị, na ndị ọchịagha, ndị dike nʼagha yi uwe agha dịka o kwesiri, ndị ikom na-amakwasị nʼelu ịnyịnya, ha niile bụ ụmụ okorobịa dị mma nʼile anya.
\v 13 Ahụrụ m na ya onwe ya merụkwara onwe ya; ha abụọ si otu ụzọ aga.
\p 
\v 14 “O gara nʼihu tụkwasị ihe nʼịgba akwụna ya karịa. Ọ hụrụ onyinyo ndị ikom atụnyere nʼahụ aja, bụ onyinyo nke ndị Kaldịa e ji ihe chara uhie uhie sepụta,
\v 15 ha kere ihe okike\f + \fr 23:15 \ft Maọbụ, \fqa belịt\f* nʼukwu ha nakwa akwa okike nʼisi ha; nʼile anya ha niile dịka ndịisi ụgbọ agha ndị Babilọn, Kaldịa bụ ala amụrụ ha.
\v 16 Ngwangwa ọ na-ele ha anya, agụ ha gụrụ ya, o zipụrụ ha ndị ozi na Kaldịa.
\v 17 Mgbe ahụ ndị Babilọn bịakwutere ya, nʼelu ihe ndina ịhụnanya, nʼime agụụ nke anụ ahụ ha, ha merụrụ ya. Mgbe ha mesịrị ka ọ bụrụ ihe rụrụ arụ site nʼịkwa iko, o si nʼebe ha nọ wezuga onwe ya nʼọnọdụ ịsọ ha oyi.
\v 18 Mgbe ọ gara nʼihu na-akwa iko nʼezoghị ezo na-ekpughekwa ọtọ ya, elepụrụ m ya anya nʼihi ịsọ oyi, dịka m mere lepụkwara anya site nʼebe nwanne ya nwanyị nọ.
\v 19 Ma ọ gara nʼihu na-akwa iko karịa, dịka ọ na-echeta ndụ akwụna o biri nʼIjipt mgbe ọ bụ agbọghọ.
\v 20 Nʼebe ahụ, agụụ ndị ikom ya na ha na-akwa iko gụrụ ya, bụ ndị anụahụ ha dịka nke ịnyịnya ibu, ndị ihe ha na-anyụpụta dịkwa ka nke ịnyịnya.
\v 21 Ya bụ, na-agụụ ndụ ọjọọ nke i biri mgbe ị bụ agbọghọ na-agụsị gị ike, mgbe ị nọ nʼIjipt ebe a na-abịagide gị aka nʼara, ebe apịkwara ọnụ ara nta gị aka.
\p 
\v 22 “Nʼihi nke a, gị Oholiba, nke a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Aga m akpali ndị ahụ hụrụ gị nʼanya\f + \fr 23:22 \fq Ndị ahụ hụrụ gị nʼanya \ft ya bụ ndị iko ya\f* megide gị, bụ ndị ahụ ihe ha na-amasịkwaghị gị ọzọ. Aga m esi nʼakụkụ niile kpọta ha, megide gị.
\v 23 Ndị Babilọn, ndị Kaldịa niile, ndị ikom Pekod, ndị Shoa, na ndị Koa, na ndị Asịrịa niile ha na ha soo. Ụmụ okorobịa niile dị mma ile anya, ha niile bụ ndị na-achị achị na ndị ọchịagha, ndịisi na-agba ịnyịnya, na ndị ikom ọkwa ha dị elu, ha niile ga-anọkwasị nʼelu ịnyịnya.
\v 24 Ha ga-eji ngwa agha dị iche iche, ụgbọala nke agha na ọtụtụ igwe ndị mmadụ dị iche iche; ha ji ọta ukwu na ọta nta, kpurukwa okpu agha igwe, were ọnọdụ gburugburu gị nʼakụkụ ọbụla, imegide gị. Aga m enyefe gị nʼaka ha, ka ha taa gị ahụhụ, ha ga-atakwa gị ahụhụ dịka usoro ikpe ha si dị.
\v 25 Aga m edo ekworo nke iwe m megide gị, ha ga-eji iwe na ọnụma mesie gị ike. Ha ga-ebipụ imi unu na ntị unu, ndị fọdụkwara nʼime unu ga-anwụ site na mma agha. Ha ga-achịkọrọ ụmụ unu ndị ikom na ndị inyom pụọ, unu ndị nke fọdụrụ ka ọkụ ga-erepịa.
\v 26 Ha ga-eyipụ gị uwe ọma gị niile, chikọrọ ihe ịchọ mma gị niile.
\v 27 Nʼụzọ dị otu a, a ga-eme ka agụ ọchịchọ ọjọọ nke anụahụ na ịkwa iko, bụ nke i bidoro nʼala Ijipt kwụsị. Ị gaghị enwekwa agụụ ile ihe ndị a niile anya maọbụ chetakwa Ijipt nʼuche gị.
\p 
\v 28 “Nʼihi na otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Lee, ana m aga iwere gị nyefee nʼaka ndị ahụ kpọrọ gị asị, bụ ndị ahụ ị wezugara onwe gị site nʼebe ha nọ nʼihi ịsọ oyi.
\v 29 Ha ga-esite nʼịkpọ asị mesie gị ike, pụnara gị ihe niile i nwere nke ị dọgburu onwe gị nʼọrụ nʼihi ha. Ha ga-ahapụ gị ka ịgbara ọtọ ihu na azụ, mgbe ahụ ihere nke ịgba akwụna gị ga-apụta ihe. Agụụ nke ọchịchọ ọjọọ na ịkwa iko gị
\v 30 emeela ka ihe ndị a bịakwasị gị, nʼihi na agụụ mmekọrịta nʼebe mba ndị ọzọ gụrụ gị, ị jikwa arụsị ha merụọ onwe gị.
\v 31 Ị gbasoro nzọ ụkwụ nwanne gị nwanyị, nʼihi ya, aga m ewere iko ya tinye gị nʼaka.\f + \fr 23:31 \ft Aga m ata gị ahụhụ dịka m si taa ya.\f*
\p 
\v 32 “Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru:
\q1 “Iko nwanne gị nwanyị ka ị ga-aṅụ
\q2 bụ iko sara mbara ma dịkwa omimi;
\q1 nke ga-eme ka ị ghọọ onye a na-achị ọchị na onye a na-akwa emo,
\q2 nʼihi na ọ na-anagide ihe dị ukwuu.
\q1 
\v 33 Ị ga-ejupụta nʼịṅụbiga mmanya oke na iru ụjụ,
\q2 nʼihi iko mbibi na ntikpọsi,
\q2 bụ iko nke nwanne gị nwanyị bụ Sameria.
\q1 
\v 34 Ị ga-aṅụ ya, ṅụchaa ihe dị nʼiko ahụ.
\q2 Ị ga-atapịakwa iberibe\f + \fr 23:34 \ft Maọbụ, \fqa ejuju\f* ya niile,
\q2 dọkasịakwa ara gị abụọ.
\m Ekwuola m. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\b
\p 
\v 35 “Nʼihi ya, ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Ebe ọ bụ na i chefuola m, gbakụta m azụ gị, ị ga-ata ahụhụ niile ruuru gị nʼihi mmehie, agụụ ọchịchọ ọjọọ na ịgba akwụna gị.”
\p 
\v 36 \nd Onyenwe anyị\nd* sịrị m, “Nwa nke mmadụ, ị ga-ekpe Ohola na Oholiba ikpe? Mgbe ahụ, guzogide ha mee ka ha mara ihe arụ niile ha na-eme.
\v 37 Nʼihi na ha akwaala iko, ọbara jupụtakwara nʼaka ha, ha na arụsị ha kwakwara iko. Ha jikwa ọ bụladị ụmụ nke ha mụtaara m chụọ aja nsure ọkụ nye ha.
\v 38 Ihe ọzọ ha mere m bụ nke a: Ha merụrụ ebe nsọ m nʼotu ụbọchị ahụ ha mere ka ụbọchị izuike m gharakwa ịdị nsọ.
\v 39 Nʼihi na nʼotu ụbọchị ahụ ha ji ụmụ ha chụọ aja nye arụsị ha, bụkwa ụbọchị ha batara nʼụlọnsọ m merụọ ya. Ihe dị otu a ka ha mere nʼụlọnsọ m.
\p 
\v 40 “Ọ bụghị naanị nke a, ha zigara ndị ozi ịkpọ ndị ikom na-esi ebe dị anya bịa, mgbe ha bịara, nʼihi ha, ị sachara ahụ gị nke ọma, tee ihe nʼanya gị, yirikwa ezigbo ihe ịchọ mma gị.
\v 41 Ị nọdụrụ nʼelu ihe ndina e doziri nke ọma, na tebul e doro nʼusoro dịkwa nʼihu ya nke ị dọbara ihe nsure ọkụ na-esi isi ụtọ na mmanụ oliv bụ nke m nʼelu ya.
\p 
\v 42 “Olu igwe mmadụ ndị obi dị ụtọ na-ada gburugburu ya nʼime ụlọ, e sitekwara nʼọzara bubata ndị ṅụbigara mmanya oke, ha na ọtụtụ ndị ọzọ, Ha gbanyekwara nwanyị a na nwanne ya nwanyị mgbaaka na nkwoji aka ha, yinyekwa ha okpueze mara mma nʼisi.
\v 43 Mgbe ahụ, ihe m kwuru banyere nwanyị ahụ ịkwa iko riri ahụ bụ nke a, ‘Ugbu a, ka ha mesoo ya mmeso dịka onye na-agba akwụna, nʼihi na nke ahụ ka ọ bụ.’
\v 44 Ha bara dinakwuru ya. Dịka ndị ikom si abakwuru nwanyị akwụna, otu a ka ha si bakwuru ụmụ nwanyị ndụ ọjọọ a bụ Ohola na Oholiba.
\v 45 Ma ndị ikpe ezi omume ga-ama ha ụdị ikpe a na-ama ndị inyom na-akwa iko na ndị na-awụsikwa ọbara. Nʼihi na ha bụ ndị na-akwa iko, na ndị ọbara dị nʼaka ha.
\p 
\v 46 “Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị, aga m akpọkọta igwe ndị mmadụ ga-emegide ha, nyefee ha nʼaka oke ihe egwu, nakwa ihe nlụta nʼagha.
\v 47 Mkpọkọta mmadụ ahụ ga-atụ ha nkume, werekwa mma agha gbudasịa ha. Ha ga-egbu ụmụ ha ndị ikom na ụmụ ha ndị inyom, kpọkwaa ụlọ ha niile ọkụ.
\p 
\v 48 “Otu a, aga m eme ka ibi ndụ ọjọọ kwụsị nʼala ahụ, ka esi otu a adọ ndị inyom niile aka na ntị, ka ha hapụ ịgbaso nzọ ụkwụ gị.
\v 49 Ị ghaghị ịta ahụhụ nʼihi ndụ ọjọọ nke ịkwa iko gị, hụkwaa ahụhụ nʼihi mmehie niile nke ịkpọ isiala nye arụsị. Mgbe ahụ ị ga-amata na mụ onwe m bụ Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*.”
\c 24
\s1 Izrel dịka ite e sikwasịrị nʼọkụ
\p 
\v 1 O ruo nʼafọ nke itoolu, nʼọnwa nke iri, nʼụbọchị nke iri, okwu nke \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, detuo ụbọchị taa nʼakwụkwọ, nʼihi na ọ bụ taa ka eze Babilọn gbara Jerusalem gburugburu.
\v 3 Ugbu a, tụọrọ ndị a na-enupu isi ilu a, gwa ha: ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru:
\q1 “ ‘Sikwasịnụ ite ahụ nʼọkụ; sikwasị ya
\q2 kunyekwanụ mmiri nʼime ya.
\q1 
\v 4 Tinyenụ anụ a bọrọ abọ nʼime ya.
\q2 Tinye anụ dị mma, apata ya na aka ya.
\q1 Tinyekwa ọkpụkpụ ndị ahụ dị mma nʼime ya.
\q2 
\v 5 Werenụ naanị ndị kachasị mma na ndị ahọpụtara site nʼigwe ewu na atụrụ,
\q1 kwajuokwa nkụ nʼokpuru ya maka ọkpụkpụ ndị ahụ,
\q2 mee ya ka ọ gbọọ nke ọma,
\q2 sie ọkpụkpụ ndị ahụ nʼime ya.
\b
\m 
\v 6 “ ‘Nʼihi na Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị,
\q1 “ ‘Ahụhụ dịrị obodo ahụ a na-awụsi ọbara nʼime ya.
\q2 E, ahụhụ dịrị ite ahụ nchara dị nʼime ya,
\q2 nke a na-apụghị ịsachapụ nchara ya.
\q1 Wepụtasịanụ ha nʼotu nʼotu.
\q2 Ka a hapụ ifekwa nza mgbe a na-eme nke a.
\b
\q1 
\v 7 “ ‘Nʼihi na ọbara ọ wụsiri dị nʼetiti ya.
\q2 Ọ bụkwa nʼelu nkume ka a wụsiri ya.
\q1 Ọ bụghị nʼelu ala efu,
\q2 ebe e nwere ike jiri aja kpochie ya.
\q1 
\v 8 Ọ bụ nʼihi ikpali ọnụma na ịbọ ọbọ
\q2 ka m ji hapụ ọbara ahụ nʼelu nkume,
\q2 ebe a na-apụghị iji aja kpochie ya.
\b
\m 
\v 9 “ ‘Ya mere, ihe a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu,
\q1 “ ‘Ahụhụ dịrị gị obodo ahụ na-awụsi ọbara.
\q2 Mụ onwe m ga-akwanyekwa nkụ dị ukwuu nʼọkụ.
\q1 
\v 10 Chịkọtaanụ nkụ dị ukwuu,
\q2 mụnyekwanụ ọkụ.
\q1 Jirinụ ụda dị iche iche
\q2 sizie anụ ahụ nke ọma;
\q2 surekwaanụ ọkpụkpụ ya ọkụ.
\q1 
\v 11 Sinyekwanụ ite ahụ ihe na-adịghị nʼime ya nʼọkụ,
\q2 tutu ruo mgbe ọ nụrụ ọkụ, chagharịa,
\q1 gbazee ihe niile na-abụghị ọla dị nʼime ya ga-asọpụtasị,
\q2 nchara ya ga-agwụsịkwa.
\q1 
\v 12 Ndọgbu nʼọrụ niile a emeghị ka nchara ahụ pụọ.
\q2 Ọ bụladị ọkụ dị ukwuu ahụ a kwanyere nʼokpuru ya
\q2 emeghị ka ọ gbazee.
\p 
\v 13 “ ‘Ugbu a, adịghị ọcha gị sitere na ndụ ọjọọ nke ịkwa iko gị. Nʼihi na m agbalịala ime ka ị dị ọcha, ma i kweghị adị ọcha site na mmerụ gị, ị gaghị adịkwa ọcha ọzọ tutu ruo mgbe ọnụma m megide gị zuruoke.
\b
\p 
\v 14 “ ‘Mụ onwe m bụ \nd Onyenwe anyị\nd* ekwuola ya. Oge m ji emezu ihe m kwuru eruola. Agaghị m ahapụ imezu ya. Agaghị m eme ebere maọbụ weghachi aka m azụ. A ga-ekpe gị ikpe dịka omume na obibi ndụ gị si dị. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.’ ”
\s1 Ọnwụ nwunye Izikiel
\p 
\v 15 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 16 “Nwa nke mmadụ, ana m aga iwere ihe otiti napụ gị onye ahụ ihe ya na-atọ gị ụtọ. Ma mgbe o mere, ị gaghị eti aka nʼobi maọbụ kwaa akwa. Anya mmiri agakwaghị esi gị nʼanya pụta.
\v 17 I nwere ike sụọ ude, ma asụsila ya ike. Ị gaghị eru uju nʼihi onye nwụrụ anwụ. Kechie isi gị, yirikwa akpụkpọụkwụ gị, ekpuchila egbugbere ọnụ gị, maọbụ rie nri ndị na-eru ụjụ na-eri.”
\p 
\v 18 Agwara m ndị mmadụ okwu a nʼụtụtụ, ma nʼanyasị nwunye m nwụrụ. Nʼụtụtụ echi ya, emere m ihe niile dịka e siri nye m ya nʼiwu.
\p 
\v 19 Mgbe ahụ, ndị mmadụ sịrị m, “Ị gaghị agwa anyị ihe ihe ndị a pụtara? Gịnị mere iji eme omume dị otu a?”
\p 
\v 20 Ya mere a sịrị m ha, “Okwu nke \nd Onyenwe anyị\nd* bịakwutere m,
\v 21 Gwa ụlọ Izrel, ‘Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu: Ana m aga ime ka ebe nsọ m ghara ị dị nsọ, bụ ebe e wusiri ike nke unu ji na-anya isi, ihe na-amasị anya unu, nke ihe banyere ya na-atọ obi unu ụtọ. Ụmụ unu ndị ikom na ndị inyom, ndị unu hapụrụ ga-ada site na mma agha.\f + \fr 24:21 \ft Ga-anwụ site na mma agha\f*
\v 22 Mgbe ahụ, unu ga-eme dịka m mere. Unu agaghị ekpuchi egbugbere ọnụ unu, maọbụ rie nri ndị na-eru ụjụ kwesiri iri.
\v 23 Ihe ikechi isi unu ga-adịgide nʼisi unu, akpụkpọụkwụ unu ga-adịkwa nʼụkwụ unu. Unu agaghị akwa akwa maọbụ tie aka nʼobi, kama unu ga-ata ahụ nʼihi mmehie unu, sụkwaa ude nʼetiti onwe unu.
\v 24 Izikiel ga-abụrụ unu ihe ịmaatụ. Unu ga-emekwa dịka o mere mgbe ihe ndị a mezuru. Unu ga-amata nʼezie na mụ onwe m bụ Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*.’
\p 
\v 25 “Ma gị, nwa nke mmadụ, nʼụbọchị ahụ m napụrụ ha ebe ha siri ike, nke bụ ọṅụ ha na ebube ha, na ihe anya ha na-achọsi ike; na ihe na-atọ obi ha ụtọ, na ụmụ ha ndị ikom na ụmụ ha ndị inyom,
\v 26 nʼụbọchị ahụ, ọ bụ onye na-agba ọsọ ndụ ga-agbakwute gị ịkọrọ gị ihe mere.
\v 27 Nʼoge ahụ, ị ga-asaghe ọnụ gị. Gị na onye ahụ na-agba ọsọ ndụ ga-ekwurịta okwu. Ị gaghị anọkwa juu ọzọ. Nʼihi ya, ị ga-aghọrọ ha ihe ịrịbama. Ha ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*.”
\c 25
\s1 Amụma megide Amọn
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, chee ihu gị nʼala ụmụ Amọn buo amụma megide ha.
\v 3 Gwa ndị Amọn, ‘Nụrụnụ okwu nke Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Nʼihi na ị sịrị “Aha!” megide ebe nsọ m mgbe e merụrụ ya na megide ala Izrel, mgbe e mere ka ọ tọgbọrọ nʼefu, na mgbe a dọtara ndị Juda nʼagha duru ha gaa mba ọzọ dịka ohu,
\v 4 nʼihi ya, aga m ewere gị nyefee nʼaka ndị si nʼọwụwa anyanwụ pụta, ka ị bụrụ ihe nketa ha. Ha ga-ewu ebe obibi nʼetiti gị, rie mkpụrụ ubi gị, ṅụọkwa mmiri ara ehi gị.
\v 5 Aga m eme ka obodo Raba ghọọ ebe ịta nri nye ịnyịnya kamel, meekwa ka ala Amọn ghọọ ebe igwe ewu na atụrụ na-amakpu. Mgbe ahụ, ị ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\v 6 Nʼihi na otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu: Nʼihi na ị kụrụ aka gị, zọọ ụkwụ gị nʼala gidim, ma sitekwa nʼịkpọ asị nke obi gị ṅụrịa ọṅụ megide ala Izrel,
\v 7 nʼihi ya, lee, aga m esetipụ aka m megide gị, were gị nyefee nʼaka ọtụtụ mba, ndị ga-alụta gị nʼagha. Aga m eme ka ị gwụsịa, mee ka ị hapụ ịdịkwa ọzọ. Aga m ala gị nʼiyi. Ị ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*.’ ”
\s1 Amụma megide Moab
\p 
\v 8 “Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu, ‘Nʼihi na Moab na Sia sịrị, “Lee, Juda adịrịla ka mba ndị ọzọ niile,”
\v 9 nʼihi nke a, aga m emeghe akụkụ Moab, site nʼobodo nke nsọtụ oke ala ya niile, bụ Bet-Jeshimọt, Baal-Meon na Kiriatem, nke bụ ebube nke ala ahụ.
\v 10 Aga m ewere Moab na Amọn nyefee ha nʼaka ndị ga-esi nʼọwụwa anyanwụ pụta, ka ọ bụrụ nke ha. Nʼụzọ dị otu a, a gaghị agụkwa maọbụ cheta Amọn nʼetiti mba niile.
\v 11 Aga m ata Moab ahụhụ. Mgbe ahụ, ha ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*.’ ”
\s1 Amụma megide Edọm
\p 
\v 12 “Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu, ‘Nʼihi na Edọm bọọrọ onwe ha ọbọ megide ụlọ Juda sitekwa nʼịbọ ọbọ ha bụrụ ndị ikpe mara,
\v 13 nʼihi nke a, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Aga m esetipụ aka m megide Edọm, gbuo ndị bi nʼime ya, ma mmadụ ma anụmanụ. Aga m eme ka ọ tọgbọrọ nʼefu. Ndị niile bi nʼala ahụ site na Teman ruo na Dedan ka a ga-eji mma agha gbuo.
\v 14 Ọ bụ site nʼaka ndị nke m Izrel ka m ga-esi bọọ ọbọ megide Edọm, ha ga-emeso ndị Edọm dịka ịba ụba nke iwe m na ọnụma m si dị, ha ga-amata ihe ịbọ ọbọ bụ, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.’ ”
\s1 Amụma megide Filistia
\p 
\v 15 “Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: ‘Nʼihi na ndị Filistia esitela na mmụọ nke ịbọ ọbọ, na mmụọ ịkpọ asị nke dị ha nʼobi bọọrọ onwe ha ọbọ, chọọ ịla ha nʼiyi.
\v 16 Ya mere, ihe a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, ana m aga isetipụ aka m megide ndị Filistia. Aga m ebipụ ndị Keret, bibie ndị ahụ niile bi nʼọnụ mmiri osimiri.
\v 17 Aga m esite nʼoke ọnụma bọọ ha ọbọ site na ịta ha ahụhụ. Mgbe ahụ ha ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*, mgbe m ga-abọgwata ha ọbọ.’ ”
\c 26
\s1 Amụma megide Taịa
\p 
\v 1 Nʼụbọchị nke mbụ nʼọnwa, nʼafọ nke iri na otu, okwu nke \nd Onyenwe anyị\nd* rutere m ntị sị,
\v 2 “Nwa nke mmadụ, Taịa aṅụrịala ọṅụ nʼihi ọdịda Jerusalem. Ọ na-ekwukwa na-asị, ‘Ahaa, agbajiela obodo ahụ bụ ọnụ ụzọ e si eje mba dị iche iche. Ọnụ ụzọ ama ya niile egherekwala oghe nye m. Ugbu a, e mebirila ya, ihe ga-agara m nke ọma karịa.’
\v 3 Nʼihi ya, ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu: Lee, ana m eguzo imegide gị Taịa. Aga m emekwa ka ọtụtụ mba bilie bịakwasị gị dịka ebili mmiri nke oke osimiri.
\v 4 Ha ga-etida mgbidi Taịa niile, kwadakwa ụlọ elu ya niile. Aga m akọchapụ aja mgbidi ya dakpọrọ adakpọ mee ka ala ahụ ghọọ ala nkume nkume.
\v 5 Ọ ga-aghọkwa ebe ndị ọkụ azụ na-agbasa ụgbụ ha nʼetiti oke osimiri. Nʼihi na mụ onwe m ekwuola ya. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara. Ọ ga-aghọkwara mba niile dị iche iche ihe a kwatara nʼagha.
\v 6 Ma a ga-eji mma agha laa ụmụada ya bi nʼelu ala nʼiyi. Mgbe ahụ, ha ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.”
\p 
\v 7 “Nʼihi na otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Aga m esite na mgbago ugwu kpọta Nebukadneza eze Babilọn, onye bụ eze ndị eze, ọ ga-achị ọtụtụ ndị agha na ụgbọala, na ndị na-agba ịnyịnya bilie imegide Taịa.
\v 8 Ọ ga-ebu ụzọ jiri mma agha bibie ndị gị bi nʼelu ala. Ọ ga-agbakwa obodo gị gburugburu, wulie mgbidi agha ya elu, imegide mgbidi obodo gị. Ọ ga-ewelikwa ọta agha ya elu.
\v 9 Ọ ga-echezikwa ihe agha e ji akwatu mgbidi nʼebe mgbidi gị dị, jiri ngwa agha ya kwada ụlọ elu gị niile.
\v 10 Ịnyịnya ya ga-adị ọtụtụ nke ga-eme ka ha jiri uzuzu kpuchie gị. Mgbidi gị ga-ama jijiji nʼihi oke ụzụ nke ịnyịnya agha ndị a, na ụgbọ agha, na wagọn ịnyịnya na-adọkpụ ga-eme, mgbe ha na-abata nʼọnụ ụzọ ama gị, dị ka mgbe ọtụtụ mmadụ na-abanye nʼime obodo e tidara mgbidi ya.
\v 11 Ọ ga-eji ụkwụ ịnyịnya ya niile zọtọọ okporoụzọ gị niile, jirikwa mma agha gbuchapụ ndị gị niile. Ogidi niile nke ike gị ga-adaru ala.
\v 12 Ha ga-akwara akụ gị niile, na ihe ahịa gị niile dịka ihe ha dọtara nʼagha. Ha ga-akwatu mgbidi gị niile, na ụlọ ọma gị niile, kpokọtaa osisi gị niile, na nkume niile, na ngwongwo niile nʼabaghị uru wụnye ha nʼime osimiri.
\v 13 Aga m emekwa ka ụzụ nke abụ gị niile kwụsị. A gaghị anụkwa ụda ụbọ akwara gị ọzọ.
\v 14 Aga m emekwa ka ala gị ghọọ ala nkume nkume, nke ihe na-adịghị nʼime ya. Ị ga-abụkwa ebe ndị ọkụ azụ ga na-agbasa ụgbụ ha. Ọ dịghị onye ga-ewuzi gị ọzọ. Mụ onwe m bụ \nd Onyenwe anyị\nd* ekwuola ya. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\p 
\v 15 “Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-agwa Taịa, Ọ bụ na agaghị anụ mkpọtụ ọdịda gị na mba ndị ahụ niile dị nʼọnụ mmiri osimiri, mgbe ndị e merụrụ ahụ ga na-asụ ude nʼoge a na-egbu ndị bi nʼime gị?
\v 16 Mgbe ahụ, ndị ndu nʼobodo ndị ahụ niile dị nʼọnụ mmiri osimiri ga-esi nʼocheeze ha rịdata. Ha ga-eyipụ uwe mwụda ha, yipụsịakwa uwe ha niile a kpara nke ọma. Ha ga-anọdụ ọdụ nʼala na-ama jijiji site nʼoke egwu nʼihi ihe ha hụrụ dakwasịrị gị.
\v 17 Ha ga-ebulikwa abụ akwa banyere gị, sị gị,
\q1 “ ‘Lee ka i si laa nʼiyi, gị obodo a maara aha ya,
\q2 nke ndị na-ejegharị nʼosimiri bi nʼime ya.
\q1 Na mbụ, ị bụ obodo nke ịdị ike ya pụtara ihe nʼosimiri niile,
\q2 gị na ndị bi nʼime gị.
\q1 Ị na-emenyekwa
\q2 ndị bi nʼime ya egwu.
\q1 
\v 18 Ugbu a, lee na ala niile dị nʼọnụ mmiri nke osimiri
\q2 na-ama jijiji nʼihi ọdịda gị.
\q1 Ọ bụladị agwa etiti niile ka ụjọ juru obi
\q2 nʼihi nkwatu a kwatụrụ gị.’
\p 
\v 19 “Ihe a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Mgbe m mere ka ị ghọọ obodo tọgbọrọ nʼefu, dịka obodo niile nke mmadụ na-ebighị, mgbe m mekwara ka ogbu mmiri nke oke osimiri bịakwasị gị, mgbe ọtụtụ mmiri ya kpuchiri gị,
\v 20 mgbe ahụ ka m ga-eme ka ị rịdaruo nʼala mmụọ, gị na ndị na-arịda nʼolulu, ka i jekwuru ndị mgbe ochie. Aga m eme ka ebe obibi gị bụrụ nʼokpuru ime ime ala, ka ị dịrị ka obodo ndị ochie ahụ e tikpọrọ etikpọ. Gị na ndị ahụ na-arịdaru nʼolulu. Ị gaghị esitekwa nʼebe ahụ lọghachi ịbịa isoro ndị dị ndụ birikwa.
\v 21 Aga m eme ka ọgwụgwụ gị bụrụ ihe a ga-atụ egwu. Ị gaghị adịkwa. A ga-achọ gị, ma agaghị achọta gị. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.”
\c 27
\s1 Abụ akwa nʼihi Taịa
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, bulie abụ akwa banyere Taịa,
\v 3 sị ya, gị oke obodo dị nʼọnụ oke osimiri, onye bụ onye ahịa nke mba niile dị nʼọnụ osimiri. ‘Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru:
\q1 “ ‘Gị onwe gị, bụ Taịa, na-asị,
\q2 “Ezuru m oke nʼịma mma.”
\q1 
\v 4 I meela ka oke ala gị dịrị nʼetiti oke osimiri.
\q2 Ndị wuru gị emeekwala ka ịma mma gị zuo oke.
\q1 
\v 5 Osisi e ji wuo ahụ ụgbọ gị
\q2 sitere nʼosisi junipa nke si Senia;
\q1 ọ bụkwa osisi sida nke si Lebanọn
\q2 ka e ji jidesie ihu ụgbọ ahụ ike.
\q1 
\v 6 Osisi ook nke si Bashan
\q2 ka e ji mee ụmara gị niile.
\q1 Osisi e si Saiprọs bubata
\q2 ka e ji wuo ala ụgbọ gị, jirikwa ọdụ machie ya nʼọnọdụ ịchọ ya mma.
\q1 
\v 7 Ezi akwa ọcha a kpara nke ọma, nke e si Ijipt bubata,
\q2 ka e ji mee ọkọlọtọ gị.
\q1 Akwa ndo gị bụkwa akwa na-acha anụnụ anụnụ, na odo odo,
\q2 nke e si nʼobodo ọnụ mmiri Elisha bubata.
\q1 
\v 8 Ndị ikom si Saịdọn na Avad bụ ndị na-akwọrọ gị ụgbọ mmiri gị.
\q2 Ndị ǹka ndị ikom gị, gị Taịa, nọ nʼụgbọ dịka ndị ọka nʼịkwọ ụgbọ mmiri.
\q1 
\v 9 Ndị okenye na ndị nka Gebal a maara aha ha nọ nʼime ụgbọ mmiri gị.
\q2 Ọrụ ha bụ imechisi oghere ọbụla dị nʼụgbọ ahụ.
\q1 Ụgbọ mmiri niile na ndị na-anya ha
\q2 na-abata nʼọnụ mmiri gị nʼihi ịzụ ihe ahịa gị.
\b
\q1 
\v 10 “ ‘Ndị ikom Peshịa na Lidiya,\f + \fr 27:10 \ft Maọbụ, \fqa Lud\f* na Put,
\q2 jere gị ozi dịka ndị agha nʼusuu ndị agha gị.
\q1 Ha kokwasịrị ọta ha na okpu agha igwe ha nʼaja ụlọ gị,
\q2 na-ewetara gị ebube.
\q1 
\v 11 Ndị ikom Avad, na Helek
\q2 bụ ndị na-eche mgbidi gị nʼakụkụ niile.
\q1 Ndị ikom Gamad
\q2 na-eche nche nʼụlọ elu gị niile e wusiri ike.
\q1 Ha konyekwara ọta ha nʼusoro na mgbidi gị,
\q2 ime ka ịma mma gị zuo oke.
\p 
\v 12 “ ‘Tashish bụ onye ahịa gị, nʼihi ịba ụba nke akụ gị. Ọ bụ ọlaọcha na igwe, na gbamgbam, na opu, ka ha ji akwụ gị ụgwọ ihe ha si nʼaka gị zụrụ.
\p 
\v 13 “ ‘Ndị Griis,\f + \fr 27:13 \ft Maọbụ, \fqa Javan\f* Tubal na Meshek, bụkwa ndị ahịa gị. Ha na-ebutere gị ndị ohu, na ihe e ji bronz kpụọ, iji kwụọ gị ụgwọ ihe ha si nʼaka gị zụrụ.
\p 
\v 14 “ ‘Otu a kwa ndị ikom Bet Togama jikwa ịnyịnya ụgbọ, na ịnyịnya agha, na ịnyịnya ibu na-agbanwere\f + \fr 27:14 \ft Nke a bụ nʼọnọdụ ịkwụ ụgwọ, mgbe ụfọdụ ọ bụrụ na mmadụ ejighị ego, o nwere ike jiri ihe o nwere kwụọ ụgwọ ihe ọ zuru, site nʼụzọ ịgbanwere ihe.\f* ihe ha zụrụ.
\p 
\v 15 “ ‘Ndị ahịa si na Dedan bụkwa ndị ahịa gị. Otu a kwa ọtụtụ ndị bi nʼọnụ mmiri bụkwa ndị ahịa gị. Ha ji ọdụ, na osisi eboni kwụọ gị ụgwọ ihe ha zụrụ gị.
\p 
\v 16 “ ‘Ndị Aram ka gị na ha zụrụ ahịa nʼihi ọtụtụ ngwa ahịa gị. Ha na-ejikwa nkume dị oke ọnụ tọkwọisi na akwa e sijiri esiji odo odo, na akwa a kpara nke ọma, na ezi akwa ọcha, na koral, na nkume oke ọnụahịa rubi na-akwụ gị ụgwọ ihe ha zụrụ gị.
\p 
\v 17 “ ‘Ndị Juda na ndị Izrel niile bụkwa ndị ahịa gị. Ha na-eji ọka wiiti nke si nʼobodo Minit, ya na shuga, na mmanụ aṅụ, na mmanụ, na mmanụ otite na-akwụ gị ụgwọ ihe ha zụrụ gị.
\p 
\v 18 “ ‘Damaskọs bụkwa ndị ahịa gị, nʼihi ọtụtụ ngwa ahịa na ụba ihe ndị ị nwere ire ere. Ọ bụkwa mmanya si Helbon, na ajị anụ dị ọcha nke esi Zaha weta,
\v 19 na mmanya a gbara nʼudu nʼudu nke si Ụzal, na igwe nwupụrụ enwupụ, na kashia, na kalamus, ka ha ji akwụ gị ụgwọ ihe ha zụrụ gị.
\p 
\v 20 “ ‘Dedan bụ onye ahịa gị nʼakwa a na-agbasa nʼelu ịnyịnya anọkwasị ọdụ.
\p 
\v 21 “ ‘Arebịa na ụmụ eze niile nke Keda bụkwa ndị ahịa gị. Ọ bụ ụmụ atụrụ, na ebule, na mkpi, ka gị na ha nʼazụrịta na-erekwa.
\p 
\v 22 “ ‘Ndị ahịa Sheba, na Raama, bụkwa ndị ahịa gị. Ha ji ụda dị iche iche na nkume dị oke ọnụahịa, na ọlaedo akwụ gị ụgwọ ihe ha zụrụ.
\p 
\v 23 “ ‘Ndị Haran, Kanne na Eden, na ndị ahịa Sheba, Ashọ na Kilmad, bụ ndị gị na ha zụkọrọ ahịa.
\v 24 Ha na-eweta uwe mara mma dị iche iche, na akwa e tejiri anụnụ anụnụ, na akwa a kpara nke ọma, na kapeeti mara mma dị iche iche, nke e ji ụdọ kpazie nke ọma, nke e tejiri nʼụdị dịkwa iche iche nʼọma ahịa gị.
\q1 
\v 25 “ ‘Ụgbọ mmiri niile nke Tashish
\q2 bụ ndị na-ebu ihe ahịa gị.
\q1 I jupụtara nʼihe ahịa,
\q2 gị obodo dị nʼetiti mmiri.
\q1 
\v 26 Ndị na-anyagharị ụgbọ mmiri gị
\q2 na-ebuba gị nʼosimiri.
\q1 Ma ifufe siri ike nke si nʼọwụwa anyanwụ
\q2 ga-etiwasị gị nʼetiti osimiri.
\q1 
\v 27 Akụ gị niile, na ngwa ahịa gị niile, na ihe ịzụ ahịa gị niile,
\q2 na ndị niile na-arụ ọrụ nʼụgbọ mmiri gị, na ndị na-anya ụgbọ mmiri, ma ndị na-edozi ụgbọ mmiri gị,
\q1 ma ndị na-azụ ahịa gị, ma ndị agha gị niile,
\q2 ha na ndị niile nọ nʼime ụgbọ gị
\q1 ka mmiri ga-eri nʼetiti mmiri,
\q2 nʼụbọchị ahụ ụgbọ gị ga-emikpu.
\q1 
\v 28 Ala niile dị nʼọnụ mmiri ga-ama jijiji
\q2 mgbe ndị ọka ụgbọ mmiri gị ga-eti mkpu akwa.
\q1 
\v 29 Ndị niile na-anya ụgbọ mmiri,
\q2 na ndị ọka ụgbọ niile nke oke osimiri,
\q1 ga-esitekwa nʼụgbọ ha
\q2 rịdata guzo nʼelu ala.
\q1 
\v 30 Ha ga-eti mkpu akwa,
\q2 ha ga-akwa akwa nke ukwuu,
\q1 werekwa aja wụkwasị onwe ha nʼisi,
\q2 na-atụrụkwa onwe ha na ntụ.
\q1 
\v 31 Ha ga-akpụchapụ agịrị isi ha,
\q2 yirikwa akwa mkpe,
\q1 kwaa akwa nʼihi ịdị ilu nke mkpụrụobi ha.
\q2 Ha ga-etikwa aka ha nʼobi.
\q1 
\v 32 Mgbe ha ga na-eti mkpu akwa na-erikwa uju nʼihi gị,
\q2 nke a bụ abụ akwa a ga-abụ banyere gị,
\q1 “Onye ka e mere ka o dere duu ka e si mee obodo Taịa,
\q2 nke osimiri gbara gburugburu?”
\q1 
\v 33 Mgbe e si nʼime gị na-ebupụsị ihe ahịa gị,
\q2 e ji ha na-enyeju mba dị iche iche afọ.
\q1 E sitekwara nʼakụ gị dị ukwuu na ngwa ahịa gị
\q2 mee ka ọtụtụ ndị eze nke ụwa bụrụ ọgaranya.
\q1 
\v 34 Ugbu a, mmiri e riela gị,
\q2 ọ bụ nʼokpuru osimiri ka ị tọgbọ.
\q1 Akụ gị niile na ihe ahịa gị niile,
\q2 na ndị niile nọ nʼime gị esorola gị laa nʼiyi.
\q1 
\v 35 Ihe ndị a niile ga-eju ndị bi nʼala ọnụ mmiri
\q2 osimiri niile anya.
\q1 Ndị eze ha niile tụkwara egwu nke ukwuu;
\q2 ihu ha gbarụkwara agbarụ site nʼegwu.
\q1 
\v 36 Ndị ahịa nke mba dị iche iche na-efufe isi ha,
\q2 nʼihi na ihe mere gị dị egwu.
\q2 Ị laala nʼiyi ruo ebighị ebi.’ ”
\c 28
\s1 Amụma megide eze Taịa
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, gwa eze Taịa, ‘Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị:
\q1 “ ‘Nʼihi nganga nke juru gị obi,
\q2 ị na-ekwu sị, “Mụ onwe m bụ chi,
\q1 mụ onwe m na-anọkwasị nʼocheeze nke otu chi,
\q2 nke dị nʼetiti oke osimiri niile.”
\q1 Ma gị onwe gị bụ mmadụ efu, ị bụghị chi,\f + \fr 28:2 \ft Maọbụ, \fqa Chineke\f*
\q2 ọ bụ ezie na ị na-eche na ị mara ihe dịka chi.\f + \fr 28:2 \ft Maọbụ, \fqa Chineke\f*
\q1 
\v 3 Ị maara ihe karịa Daniel?
\q2 Ọ bụ na o nweghị ihe e zoro ezo nʼebe ị nọ?
\q1 
\v 4 I werela amamihe gị na nghọta gị
\q2 nwetara onwe gị akụ,
\q1 tụkọba ọlaedo na ọlaọcha,
\q2 nʼime ụlọakụ gị dị iche iche.
\q1 
\v 5 E, mmụta nʼịzụ ahịa gị
\q2 emeela ka ị ghọọ ọgaranya,
\q1 nʼihi akụnụba inwere
\q2 ị bụrụla onye na-akpa nganga.
\p 
\v 6 “ ‘Ya mere, nke a bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu;
\q1 “ ‘ebe ọ bụ na ị gụrụ onwe gị dịka onye maara ihe
\q2 onye maara ihe dịka chi,
\q1 
\v 7 ana m aga ịkpọbata ndị mba ọzọ megide gị,
\q2 bụ mba kachasị mba niile dị iche iche njọ na-enweghị obi ebere.
\q1 Ha ga-amịpụta mma agha ha megide ịma mma gị na amamihe gị,
\q2 ha ga-adụwakwa ebube nke mma gị.
\q1 
\v 8 Ha ga-eme ka ị rịdaruo nʼolulu nke ala mmụọ.
\q2 Ị ga-anwụ ọnwụ ike
\q2 nʼetiti oke osimiri niile.
\q1 
\v 9 Mgbe nke a mere, ị ga-asị, “Mụ onwe m bụ chi,”
\q2 nʼihu ndị ahụ na-egbu gị?
\q1 Ma gị onwe gị bụ mmadụ efu, ị bụghị chi,
\q2 nʼaka ndị ahụ na-egbu gị.
\q1 
\v 10 Ị ga-anwụ ọnwụ dịka ndị a na-ebighị ugwu,
\q2 site nʼaka ndị ọbịa.
\m Mụ onwe m ekwuola, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.’ ”
\b
\p 
\v 11 Okwu nke \nd Onyenwe anyị\nd* rutere m ntị, sị,
\v 12 “Nwa nke mmadụ, bulie abụ akwa banyere eze Taịa ma gwa ya, ‘Ihe a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru,
\q1 “ ‘Gị onwe gị bụ akara izuoke,
\q2 ị jupụtara na amamihe na ịma mma.
\q1 
\v 13 Ị nọ nʼIden,
\q2 nʼubi Chineke a gbara ogige.
\q1 Nʼebe ahụ ka e ji nkume dị oke ọnụahịa ndị a chọọ gị mma,
\q2 rubi,\f + \fr 28:13 \ft Maọbụ, \fqa kanelien\f* na topaazi, na emeralụdụ,
\q2 na krisolaịt, na ọniks, na jaspa,
\q2 na safaia, na tọkwọisi, na beril.
\q1 A rụnyere nkume ndị a niile nʼime ọlaedo.
\q2 Ọ bụkwa nʼụbọchị ahụ e kere gị ka e doziri ha.
\q1 
\v 14 Ahọpụtara m gị mee gị ka ị bụrụ cherub,
\q2 ọrụ ahụ e doro gị iche ịrụ.
\q1 Ọ bụ nʼugwu nsọ Chineke ka ị na-anọ,
\q2 na-ejegharịkwa nʼetiti nkume ndị ahụ na-acha ọkụ.
\q1 
\v 15 Ị bụ onye na-enweghị ịta ụta
\q2 nʼụzọ gị niile site nʼụbọchị e kere gị,
\q2 tutu ruo mgbe a hụrụ ajọ omume nʼime gị.
\q1 
\v 16 Site nʼịba ụba nke ọzụzụ ahịa gị
\q2 ị ghọrọ onye na-eme ihe ike,
\q2 si otu a mehiekwa.
\q1 Nʼihi ya, esi m nʼugwu Chineke chụpụ gị, nʼihi adịghị nsọ gị.
\q2 Esitekwara m nʼetiti nkume ọkụ ndị ahụ chụpụ gị,
\q2 gị cherub na-ekpuchi ekpuchi.
\q1 
\v 17 Obi gị jupụtara na nganga
\q2 nʼihi ịma mma gị,
\q1 i mere ka amamihe gị
\q2 bụrụ ihe rụrụ arụ nʼihi ebube nke ịma mma gị.
\q1 Nʼihi ya, achụdara m gị, tụọ gị nʼala,
\q2 mee ka ị bụrụ ihe nlere anya nye ndị eze niile.
\q1 
\v 18 Nʼihi ọtụtụ mmehie gị, na ịzụ ahịa aghụghọ gị,
\q2 i meela ka ụlọnsọ gị niile ghọọ ihe rụrụ arụ.
\q1 Nʼihi ya, emere m ka ọkụ si nʼetiti gị pụta,
\q2 repịa gị.
\q1 Ka ị ghọọ ntụ nʼelu ala,
\q2 nʼihu ndị ahụ niile na-ele gị anya.
\q1 
\v 19 Ndị niile maara gị
\q2 ka ihe ndị a juru anya,
\q1 nʼihi na ị ghọọla ihe oke egwu.
\q2 Ị laala nʼiyi ruo ebighị ebi.’ ”
\s1 Amụma megide Saịdọn
\p 
\v 20 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 21 “Nwa nke mmadụ, chee ihu nʼebe Saịdọn dị buo amụma megide ya,
\v 22 ma kwuo, ‘Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru,
\q1 “ ‘Mụ onwe m na-emegide gị, gị Saịdọn,
\q2 nʼetiti unu ka m ga-egosipụta otuto m.
\q1 Unu ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*
\q2 mgbe m mere ka ahụhụ dakwasị unu,
\q2 nʼime unu, a ga-anwapụta na m bụ onye dị nsọ.
\q1 
\v 23 Aga m ezite ajọ ọrịa na-efe efe, nke ga-emegide ya,
\q2 meekwa ka ọbara jupụta nʼokporoụzọ ya niile.
\q1 Ndị e gburu egbu ga-ada nʼime ya,
\q2 site na mma agha nke ga-abịakwasị ya nʼakụkụ niile.
\q1 Mgbe ahụ, ha ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\p 
\v 24 “ ‘Ụlọ Izrel agaghị enwekwa mba kpọrọ ha asị gbara ha gburugburu ndị dịka uke, nke na-adụ adụ, na ogwu nke na-egbu mgbu. Ha ga-amatakwa na mụ onwe m bụ Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*.
\p 
\v 25 “ ‘Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Ndị Izrel ga-alọghachi biri nʼala nke aka ha ọzọ, ala nke m nyere nna ha Jekọb ohu m. Nʼihi na aga m esite na mba niile ha gbasasịrị chịkọtaa ha, si otu a gosi mba niile nke ụwa ịdị nsọ m.
\v 26 Ha ga-ebi nʼala a na ntụkwasị obi. Ha ga-ewu ụlọ, kụọ ubi vaịnị, birikwa na-atụghị egwu ọbụla. Mgbe m pịachara mba niile dị ha gburugburu ụtarị, bụ mba ndị ahụ mekpara ha ahụ, mgbe ahụ, ha ga-amata nʼezie na mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke ha.’ ”
\c 29
\s1 Amụma megide Ijipt
\s2 Ikpe ọmụma dịrị Fero
\p 
\v 1 Nʼafọ nke iri, nʼọnwa nke iri, nʼụbọchị nke iri na abụọ, okwu nke \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, chee ihu gị nʼIjipt buo amụma megide Fero bụ eze Ijipt, na ala Ijipt niile.
\v 3 Gwa ya okwu, sị, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị:
\q1 “ ‘Lee, mụ onwe m na-emegide gị, Fero eze Ijipt,
\q2 gị onye bụ ogologo anụ ọjọọ ahụ na-amakpu nʼetiti mmiri iyi.
\q1 Nʼihi na ị sịrị, “Ọ bụ m nwe Naịl,
\q2 ọ bụkwa mụ onwe m mere ya nye onwe m.”
\q1 
\v 4 Ma aga m etinye nko nʼagba gị,
\q2 mee ka azụ niile nke iyi gị niile rapara nʼakpịrịkpa gị.
\q1 Aga m adọpụta gị site nʼetiti iyi gị niile,
\q2 mee ka azụ niile rapara nʼakpịrịkpa gị.
\q1 
\v 5 Aga m ahapụ gị
\q2 na azụ niile nke osimiri iyi gị nʼọzara,
\q1 ebe ahụ ka unu ga-anọ nwụọ nʼala ubi,
\q2 a gaghị eli unu eli maọbụ tụtụọ unu,
\q1 nʼihi na emeela m ka unu bụrụ nri
\q2 nye anụ ọhịa niile, na nnụnụ niile.
\m 
\v 6 Mgbe ahụ, ndị niile bi nʼIjipt ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\b
\p “ ‘Ị dịrịla ka mkpanaka achara nʼebe ụlọ Izrel nọ.
\v 7 Mgbe ha jidere gị nʼaka, ị nyajiri dọwaa ha ubu ha. Mgbe ha dabeere na gị, ị gbajiri mee ka ha ghara inwekwa ike iguzosi ike nʼụkwụ ha.
\p 
\v 8 “ ‘Nʼihi ya, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Lee, aga m eme ka mma agha bịakwasị gị, aga m ebipụkwa mmadụ na anụmanụ niile dị nʼime gị.
\v 9 Ala Ijipt ga-aghọ ebe tọgbọrọ nʼefu; ha ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\p “ ‘Nʼihi na ị sịrị, “Osimiri Naịl bụ nke m. Ọ bụ m kere ya.”
\v 10 Nʼihi ya, aga m edo onwe m megide gị, megidekwa osimiri gị. Aga m ala Ijipt niile nʼiyi site na Migdol ruo Aswan, ruokwa nʼoke ala ha na ndị Kush.\f + \fr 29:10 \ft Ya bụ, mgbago Naịl\f*
\v 11 Ọ dịghị ụkwụ anụmanụ maọbụ mmadụ ga-agafe nʼime ya, agaghị ebikwa nʼime ya ruo mgbe iri afọ anọ gasịrị.
\v 12 Aga m emekwa ka ala Ijipt bụrụ ebe tọgbọrọ nʼefu nʼetiti mkpọmkpọ ala niile, obodo ya niile ga-atọgbọrọ nʼefu iri afọ anọ nʼetiti obodo ndị e mere ka ha laa nʼiyi. Aga m achụsasị ndị Ijipt nʼetiti mba niile, fesaa ha nʼala niile.
\p 
\v 13 “ ‘Ọzọkwa, Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị, nʼọgwụgwụ iri afọ anọ ahụ, aga m achịkọtakwa ndị Ijipt site nʼebe niile ha gbasara.
\v 14 Aga m emekwa ka ndị ya niile laghachi nʼala Patros, ala ebe a mụrụ ha. Ma Ijipt agaghị abụkwa alaeze a maara nke ọma ọzọ.
\v 15 Ọ ga-abụ alaeze dị nnọọ ala karịa alaeze niile. Ọ dịkwaghị mgbe ọzọ ọ ga-eweli onwe ya elu karịa mba ọzọ niile. Aga m emekwa ka ha dị nta, nke ha agaghị inwe ike achịkwa mba niile ọzọ.
\v 16 Ijipt agaghị abụkwara ụlọ Izrel ihe ntụkwasị obi, kama ọ ga-abụrụ ha ihe iji cheta mmehie ha mere mgbe ha lere anya enyemaka site nʼaka ya. Mgbe ahụ, ha ga-amata na mụ onwe m bụ Onye kachasị ihe niile elu, bụ\f + \fr 29:16 \ft Maọbụ, \fqa Onyenwe ha\f*\nd Onyenwe anyị\nd*.’ ”
\s2 Ụgwọ ọrụ Nebukadneza
\p 
\v 17 Ọ ruo, nʼiri afọ abụọ na asaa, nʼọnwa mbụ, nʼụbọchị nke mbụ, ka okwu nke \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 18 “Nwa nke mmadụ, Nebukadneza bụ eze Babilọn mere ka ndị agha ya lụsoo Taịa ọgụ nʼebe ọ dị ukwuu. Isi niile ọbụla ka e mere ka ọ kwọchasịa, ubu niile kwa echihịara echihịa. Ma ya na ndị agha ya anataghị ụgwọ ọrụ ọbụla, nʼagha ahụ o buru megide Taịa.
\v 19 Nʼihi nke a, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu sị: Lee, ana m aga inye Nebukadneza eze Babilọn ala Ijipt. Ọ ga-akwakọrọ akụnụba ya, ọ ga-azacha ma bukọrọkwa ihe niile nke dị nʼala ahụ. Ha ga-abụkwa ụgwọ ọrụ nke ndị agha ya.
\v 20 Enyefeela m ala Ijipt nʼaka ya, ka ọ bụrụ ụgwọ ọrụ nʼihi ọrụ ya, nʼihi na ya na ndị agha ya rụụrụ m ya. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.”
\p 
\v 21 “Nʼụbọchị ahụ, aga m eme ka otu mpi\f + \fr 29:21 \fq Mpi \ft Nʼebe a na-egosipụta ịdị ike\f* puputara ụlọ Izrel. Aga m asaghekwa ọnụ gị nʼetiti ha. Mgbe ahụ, ha ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.”
\c 30
\s2 Abụ akwa nʼihi Ijipt
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, buo amụma sịkwa, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu,
\q1 “ ‘Kwasienụ akwa ike ma sị,
\q2 “Ewoo, nʼihi ụbọchị ahụ!”
\q1 
\v 3 Nʼihi nʼụbọchị ahụ adịla nso,
\q2 Ụbọchị nke \nd Onyenwe anyị\nd* abịala nso,
\q1 ụbọchị igwe ojii,
\q2 ụbọchị ga-ewetara mba dị iche iche mbibi.
\q1 
\v 4 Mma agha ga-abịakwasị Ijipt,
\q2 ihe mgbu ga-adakwasị Kush.
\q1 Mgbe ndị e gburu egbu ga-abụ aja dị nʼala,
\q2 a ga-ekpokọrọkwa akụnụba ya,
\q2 mebikwaa ntọala ya. Ala ya ga-abụkwa ihe e bibiri ebibi.
\m 
\v 5 Kush\f + \fr 30:5 \ft Ya bụ, Itiopia\f* na Libiya, Lidiya na ndị Arebịa niile gwara ọgwa, Kub na ndị mba ọgbụgba ndụ ahụ, na Ijipt ga-eso daa site na mma agha.
\p 
\v 6 “ ‘Ọ bụ ihe a ka \nd Onyenwe anyị\nd* kwuru:
\q1 “ ‘Ndị niile na-akwagide Ijipt ga-ada,
\q2 nganga niile nke ike ya ga-agwụsịkwa.
\q1 Site na Migdol ruo nʼAswan,
\q2 ọ bụ site na mma agha ka ha ga-ada nʼime ya.\f + \fr 30:6 \ft Ka a ga-eji gbuchapụ ha\f*
\q2 Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\q1 
\v 7 Ha ga-atọgbọrọ nʼefu,
\q2 nʼetiti ala niile tọgbọrọ nʼefu.
\q1 Obodo ha niile ga-abụ mkpọmkpọ ebe,
\q2 nʼetiti ọtụtụ obodo e bibiri ebibi.
\q1 
\v 8 Mgbe ahụ, ha ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*,
\q2 mgbe m tinyesịrị ọkụ nʼIjipt,
\q2 mgbe m gwepịara ndị niile na-enyere ya aka.
\p 
\v 9 “ ‘Nʼụbọchị ahụ, aga m ezipu ndị ozi ndị ga-eji ụgbọ dị iche iche, ka ha gaa menye ndị Kush egwu, bụ ndị onwe ha jụrụ afọ. Oke egwu ga-ejidekwa ha nʼoge ahụ nʼihi ihe dakwasịrị Ijipt, nʼihi ihe ndị a aghaghị imezu.
\b
\p 
\v 10 “ ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru,
\q1 “ ‘Aga m esite nʼaka Nebukadneza eze Babilọn
\q2 bibie igwe ndị agha Ijipt niile.
\q1 
\v 11 Ya onwe ya na ndị agha ya, bụ mba kachasị mba niile njọ na-enweghị obi ebere,
\q2 ka a ga-akpọbata ka ha bịa bibie ala ahụ.
\q1 Ha ga-amịpụta mma agha ha megide Ijipt,
\q2 werekwa ozu ndị e gburu egbu tụsasịa nʼala ahụ.
\q1 
\v 12 Aga m eme ka osimiri Naịl taa. Ọ ga-aghọkwa ala kpọrọ nkụ.
\q2 Aga m ewerekwa ala ahụ resi mba ndị ọjọọ.
\q1 Aga m ala ala ahụ na ihe niile dị nʼime ya nʼiyi.
\q2 Ọ bụkwa ndị mba ọzọ ka m ga-eji mee ya.
\m Mụ onwe m bụ \nd Onyenwe anyị\nd* ekwuola ya.
\b
\p 
\v 13 “ ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru,
\q1 “ ‘M ga-ala arụsị niile nʼiyi,
\q2 mekwaa ka ihe niile a kpụrụ akpụ dị na Memfis kwụsị.
\q1 Onye eze agakwaghị adị ọzọ nʼIjipt,
\q2 aga m emekwa ka egwu jupụta nʼala ahụ niile.
\q1 
\v 14 Aga m emekwa ka Patros tọgbọrọ nʼefu.
\q2 Aga m etinye ọkụ na Zoan,
\q2 ma taa Tibs ahụhụ.
\q1 
\v 15 M ga-awụkwasị Pelusium\f + \fr 30:15 \ft Maọbụ, \fqa Sin\f* ọnụma m,
\q2 bụ ebe siri ike nke Ijipt,
\q2 m ga-ebipụkwa igwe ndị Tibs niile.
\q1 
\v 16 Aga m amụnye ọkụ nʼIjipt,
\q2 Pelusium ga-anọ nʼoke ihe mgbu.
\q1 A ga-eji ike tipịa Tibs.
\q2 Memfis ga-anọgidekwa nʼọnọdụ ọjọọ ụbọchị niile.
\q1 
\v 17 Ụmụ okorobịa Heliopolis na Bubasti
\q2 ga-anwụ site na mma agha.
\q2 Obodo ndị a niile ga-abụkwa ndị a dọtara nʼagha.
\q1 
\v 18 Ụbọchị ahụ ga-agba ọchịchịrị na Tapanhis
\q2 mgbe m ga-agbaji yoku Ijipt,
\q2 nʼebe ahụ ka mpako nke ike ya ga-agwụsị.
\q1 Igwe ojii ga-ekpuchi ya,
\q2 a ga-adọtakwa obodo nta ya niile nʼagha.
\q1 
\v 19 Aga m eme ka Ijipt taa ahụhụ dị ukwuu,
\q2 ka ha mata nʼezie na mụ onwe m bụ \nd Onyenwe anyị\nd*.’ ”
\s2 Aka Fero agbajiela
\p 
\v 20 O ruo, nʼafọ nke iri na otu ya, nʼụbọchị nke asaa, nʼọnwa nke mbụ, okwu nke \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 21 “Nwa nke mmadụ, agbajiela m ogwe aka Fero, eze Ijipt. Lee, o nwebeghị onye gbara ya ọkpụkpụ, ma ọ bụkwanụ kee ya ihe, ka o sie ike ọzọ ijide mma agha.
\v 22 Nʼihi ya, nke a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị: Lee, mụ onwe m na-emegide Fero bụ eze Ijipt. Aga m agbaji ogwe aka ya abụọ, ma nke siri ike ma nke gbajiri agbaji na mbụ. Aga m emekwa ka mma agha ya si nʼaka ya dapụ.
\v 23 Aga m achụsa ndị Ijipt nʼetiti mba niile tụsaakwa ha nʼobodo niile,
\v 24 meekwa ka ogwe aka abụọ nke eze Babilọn sie ike. Aga m etinye mma agha m nʼaka ya, ma ogwe aka abụọ nke Fero ka m ga-agbajisi. Mgbe ahụ, Fero ga-asụ ude nʼihu eze Babilọn dịka onye e merụrụ ahụ.
\v 25 Aga m eme ka ogwe aka abụọ nke eze Babilọn sie ike; ma ogwe aka Fero ga-akpọnwụ. Mgbe ahụ, ha ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*, mgbe m tinyere mma agha nʼaka eze Babilọn, na mgbe o setịpụrụ ya imegide Ijipt.
\v 26 Aga m achụsa ndị Ijipt nʼetiti mba niile, fesaa ha nʼala niile. Mgbe ahụ, ha ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.”
\c 31
\s2 Fero dịka osisi sida nke Lebanọn
\p 
\v 1 O ruo, nʼafọ nke iri na otu, nʼọnwa nke atọ, nʼụbọchị nke mbụ ya, okwu nke \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, gwa Fero eze Ijipt na ndị agha ya niile okwu sị ha,
\q1 “ ‘Olee onye ahụ yiri gị nʼịdị ukwuu?
\q1 
\v 3 Tulee nʼobi gị ihe gbasara Asịrịa,
\q2 nke bụ oke obodo bụrụkwa mba a maara aha ya.
\q1 Ọ dị ka osisi sida nke Lebanọn,
\q2 nke jupụtara nʼalaka mara mma,
\q1 nke ọtụtụ alaka ya na-enye ndo, nke dị ezi ogologo,
\q2 nke alaka ọnụ ya topụrụ tokarịa osisi ọhịa niile.
\q1 
\v 4 O nwetara mmiri mere ka o buo ibu,
\q2 na isi iyi mmiri miri emi nke mere ka o too ogologo.
\q1 Iyi ha niile
\q2 na-asọ nʼokpuru ya.
\q1 Ebe ahụ ka ha si ezipu
\q2 ụzọ mmiri ndị na-enye osisi ndị ọzọ dị nʼọhịa mmiri.
\q1 
\v 5 Nʼihi ya, o toro tokarịa
\q2 osisi niile nʼogologo.
\q1 Ngalaba ya bara ụba,
\q2 alaka ya topụkwara ogologo
\q2 nʼihi ịdị ukwuu nke mmiri ha na-enweta.
\q1 
\v 6 Nʼalaka ya niile
\q2 ka anụ ufe niile nke eluigwe na-akpa akwụ,
\q1 nʼokpuru ndo nke alaka ya niile
\q2 ka ụmụ anụ ọhịa niile mụrụ ụmụ,
\q1 oke mba niile dị iche iche
\q2 bikwara nʼokpuru ndo ya.
\q1 
\v 7 Ọ mara mma nʼịdị ukwuu ya,
\q2 nʼogologo nke alaka ya nʼawasa,
\q1 nʼihi na mgbọrọgwụ ya mibara emiba
\q2 nʼebe mmiri dị ukwuu.
\q1 
\v 8 Osisi sida niile dị nʼubi Chineke a gbara ogige
\q2 erughị ya nʼọtụtụ.
\q1 Ọ dịghị osisi junipa niile
\q2 nwere ngalaba a ga-eji tụnyere nke ya,
\q1 osisi plenụ niile
\q2 adịghịkwa ka alaka ya,
\q1 ọ dịghịkwa osisi dị nʼubi Chineke a gbara ogige,
\q2 nke yiri ya nʼịma mma ya
\q1 
\v 9 Emere m ya ka ọ maa mma
\q2 site nʼịba ụba nke alaka o nwere,
\q1 ọ bụ ihe ekworo nye osisi niile nọ nʼIden
\q2 nʼubi Chineke a gbara ogige.
\p 
\v 10 “ ‘Nʼihi ya, ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Nʼihi na o\f + \fr 31:10 \ft Ya bụ, sida ukwu ahụ\f* toro ogologo tokarịa osisi ọhịa niile, nʼihi na ọ nyara isi banyere ọnọdụ ịdị ogologo ya karịa ndị ọzọ,
\v 11 Eweere m ya nyefee nʼaka onye ahụ na-achị mba niile, ka o mesie ya ike, dịka ịba ụba nke ajọ omume ya si dị. Ewezugakwara m ya nʼakụkụ.
\v 12 Mba ahụ kachasị mba niile njọ na-enweghị obi ebere gbuturu ya, hapụ ya ka ọ tọgbọrọ nʼala. Ngalaba ya dara nʼelu ugwu ukwu niile nakwa nʼime ndagwurugwu niile. Alaka ya kwa dajisịrị danyesịa nʼime ebe niile gbawara agbawa nke ala mmiri si eru. Mba niile nke ụwa sitere nʼokpuru ndo ya pụta wezuga onwe ha.
\v 13 Ụmụ nnụnụ niile bere nʼelu ukwu osisi ahụ dara ada, nʼetiti alaka ya niile ka ụmụ anụ ọhịa bịara biri.
\v 14 Ya mere, ka osisi niile nke dị nʼakụkụ mmiri gharakwa eto ogologo, maọbụ ka ọnụ ọnụ ya ghakwara ịdị elu karịa alaka ndị ahụ bara ụba. Nyekwa na ọ dịkwaghị osisi ọbụla na-enwetazu mmiri nke ga-etoru osisi ndị ahụ nʼogologo. Nʼihi na edebela ha nye ọnwụ, nye ịrịdaru nʼokpuru ụwa, nʼetiti ndị mmadụ ndị na-arịda nʼolulu omimi ahụ.
\p 
\v 15 “ ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Nʼụbọchị ahụ e mere ka ọ rịdaruo nʼala mmụọ, a kwụsịrị m ogbu mmiri niile were ha kpuchie ya. A kwụsịrị nsọgharị nke mmiri, meekwa ka ịba ụba nke mmiri ya niile kwụsị. Nʼihi ya, eyinyere m Lebanọn uwe mkpe, osisi niile nke ọhịa kpọnwụkwara nʼihi ya.
\v 16 Emere m ka mba niile maa jijiji nʼegwu nʼihi ọdịda ya, mgbe m tụnyere ya na ndị ahụ na-aga nʼolulu nʼime ala mmụọ. Mgbe ahụ, a kasịrị osisi niile mara mma obi, bụ osisi ndị ahụ dị nʼogige Iden, na osisi ọma niile nke Lebanọn, ndị nke mgbọrọgwụ ha na-enweta mmiri nke ọma.
\v 17 Ha onwe ha kwa, dịka sida ukwuu ahụ, sokwaara gbadaruo nʼala mmụọ, gakwuru ndị niile eji mma agha gbuo, ha na ndị ikom ji mma agha bụ ndị biri nʼokpuru ndo ya nʼetiti mba dị iche iche.
\p 
\v 18 “ ‘Olee osisi dị nʼIden a ga-eji tụnyere gị nʼịma mma, na nʼịdị ebube? Ma gị onwe gị kwa, na osisi ndị a niile dị nʼIden ka a ga-eme ka unu rịdaruo nʼokpuru ụwa. Ị ga-edina nʼetiti ndị a na-ebighị ugwu, gị na ndị eji mma agha gbuo.
\p “ ‘Nke a bụ Fero na usuu ndị agha ya niile, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.’ ”
\c 32
\s2 Abụ akwa nʼihi Fero
\p 
\v 1 Nʼafọ nke iri na abụọ, nʼọnwa nke iri na abụọ, nʼụbọchị nke mbụ ya, okwu nke \nd Onyenwe anyị\nd* rutere m ntị, sị,
\v 2 “Nwa nke mmadụ, buliere Fero bụ eze Ijipt, abụ akwa sị ya,
\q1 “ ‘Ị dị ka ọdụm nʼetiti mba niile.
\q2 Ị dịkwa ka ogologo anụ ọjọọ na-anọ nʼosimiri.
\q1 I na-akpụgharị onwe gị nʼime mmiri.
\q2 I ji ụkwụ abụọ na-agbarụ mmiri,
\q2 na-emekwa ka mmiri iyi niile gbarụọ.
\p 
\v 3 “ ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị,
\q1 “ ‘Aga m eji ọtụtụ ndị dị ukwuu nʼọnụọgụgụ
\q2 gbasaa ụgbụ m nʼelu gị.
\q2 Ha ga-adọkpụkwara gị nʼime ụgbụ m.
\q1 
\v 4 Aga m atụsa gị nʼala,
\q2 nʼọhịa ka m ga-atụfukwa gị,
\q1 meekwa ka ụmụ nnụnụ niile nke eluigwe bekwasị gị.
\q2 Aga m emekwa ka anụ ọhịa nke ụwa niile rijuo afọ nʼanụ ahụ gị.
\q1 
\v 5 Aga m tụsasịkwa anụ ahụ gị nʼugwu niile,
\q2 werekwa ihe ọbụla fọdụrụ nʼime gị mejuo ndagwurugwu niile.
\q1 
\v 6 M ga-eji ọbara gị na-asọ asọ dee ala niile dịka mmiri
\q2 ọ bụladị ruo nʼugwu niile,
\q2 ebe niile mmiri si erufe ga-ejupụtakwa nʼanụ ahụ gị.
\q1 
\v 7 Mgbe m ga-emenyụ gị dịka ọkụ, aga m ekpuchi ihu eluigwe,
\q2 meekwa ka kpakpando niile jie nji.
\q1 Aga m eji igwe ojii mechie ihu anyanwụ,
\q2 ọnwa agakwaghị enye ìhè ya.
\q1 
\v 8 Ihe niile nke na-enye ìhè nʼeluigwe
\q2 ka m ga-eme ka ha jie nji nʼelu gị,
\q2 mee ka ọchịchịrị gbachie nʼala gị niile, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.
\q1 
\v 9 Aga m eweta obi mgbawa nʼetiti ndị mmadụ dị iche iche
\q2 mgbe m ga-eme ka mbibi gị bịa nʼetiti mba niile
\q2 nʼime ala dị iche iche nke ị na-amaghị.
\q1 
\v 10 Aga m eme ka i ju ọtụtụ ndị mmadụ anya,\f + \fr 32:10 \ft Nwee akpata oyi nʼebe ị nọ\f*
\q2 ndị eze ha ga-ama jijiji nʼụjọ maka gị
\q2 mgbe m ga-efegharị mma agha m nʼihu ha.
\q1 Onye ọbụla nʼime ha ga-ama jijiji\f + \fr 32:10 \ft Nke a bụ nʼihi egwu\f*
\q2 na ntabi anya ọbụla nʼihi ndụ ya
\q2 nʼụbọchị ahụ, ị ga-ada.
\p 
\v 11 “ ‘Nʼihi na nke a bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru,
\q1 “ ‘Mma agha nke eze Babilọn
\q2 ga-abịakwasị gị.
\q1 
\v 12 Usuu ndị agha gị ga-adakwa nʼihu mma agha
\q2 nke ndị dị ike,
\q2 bụ ndị mba ahụ kachasị mba niile njọ.
\q1 Nganga niile nke Ijipt na ndị ya, ka ha ga-egwepịa.
\q2 Ha ga-akwatu usuu ndị agha ha niile.
\q1 
\v 13 Aga m emekwa ka anụmanụ ya niile,
\q2 nke na-ata ahịhịa nʼakụkụ mmiri laa nʼiyi.
\q1 Ụkwụ mmadụ, na ụkwụ anụmanụ
\q2 agakwaghị agbarụ mmiri ahụ ọzọ.
\q1 
\v 14 Nʼihi ya, mmiri niile nke ya ga-adị ọcha,
\q2 na-asọkwa dịka mmanụ.
\q2 Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru.
\q1 
\v 15 Mgbe m bibiri Ijipt,
\q2 kpochapụkwa ihe niile dị nʼime ya,
\q1 mgbe m tidara ndị niile bi nʼime ya,
\q2 ha ga-amata nʼezie na mụ onwe m bụ \nd Onyenwe anyị\nd*.’
\p 
\v 16 “Nke a bụ abụ akwa ha ga-abụrụ ya. Ndị inyom mba dị iche iche ga-abụ ya. Ha ga-abụ ya nʼihi Ijipt na usuu ndị agha ya, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.”
\s2 Nrịda Ijipt baa nʼala ndị nwụrụ anwụ
\p 
\v 17 Nʼafọ nke iri na abụọ ahụ, nʼụbọchị nke iri na ise nke ọnwa ahụ, okwu nke \nd Onyenwe anyị\nd* rutere m ntị sị,
\v 18 “Nwa nke mmadụ, tie mkpu akwa nʼihi usuu ndị agha Ijipt niile, wezuga ha baa nʼokpuru ụwa ma ndị inyom mba dị iche iche dị ukwuu, ha na ndị ahụ na-arịdaru nʼolulu.
\v 19 Gwa ha okwu sị ha, ‘Unu o nwere ihuọma karịa ndị ọzọ? Lee, ihe na-eche gị bụ olulu. Ọ bụkwa ndị a na-ebighị ugwu ka ị ga-edinakwuru.’
\v 20 Nʼetiti ndị e ji mma agha gbuo ka ha ga-ada. Amịpụtala mma agha maka ya, ka a dọkpụrụ ya na igwe ndị ya niile pụọ.
\v 21 Ndị dike nke ndị ndu dike ga-esite nʼala mmụọ kwuo banyere Ijipt na ndị niile ha na ya dị na mma, ‘Ha arịdatala, ha na-edina ala ha na ndị a na-ebighị ugwu, nakwa ndị niile ahụ e ji mma agha gbuo.’
\p 
\v 22 “Nʼebe ahụ ka Asịrịa na ndị agha ya niile nọ; ili ndị niile o gburu egbu gbara ya gburugburu, bụ ndị niile nwụrụ site na mma agha.
\v 23 Ili ha dị na nsọtụ niile nke olulu, ndị agha ya niile gbakwara ili ya gburugburu. E gbudala ndị niile mere ka oke egwu dị nʼala ndị dị ndụ. Ndị a nwụrụ site na mma agha.
\p 
\v 24 “Nʼebe ahụ ka Elam na usuu ndị agha ya nọ gbaa ili ya gburugburu. Ha niile bụ ndị e gburu egbu, ndị nwụrụ site na mma agha. Ndị niile mere ka oke egwu dị nʼala ndị dị ndụ arịdaruola nʼolulu ahụ dịka ndị a na-ebighị ugwu. Ha esorola ndị ahụ rịdaruru nʼala mmụọ keta oke nʼihere dịrị ha.
\v 25 E meere ya ebe ndina nʼetiti ndị nwụrụ anwụ. Igwe mmadụ ya nwụrụ anwụ gbakwara ili ya gburugburu. Ha niile bụ ndị a na-ebighị ugwu, ndị e ji mma agha gbuo, nʼihi na-emere ka oke egwu ha dị nʼala ndị dị ndụ, ma ha na-eburu ihere ha, ha na ndị ahụ na-arịdaru nʼolulu. Ha bụ ndị e debere nʼetiti ndị nwụrụ anwụ.
\p 
\v 26 “Meshek na Tubal nọkwa nʼebe ahụ, ha na usuu ndị agha ha niile, gburugburu ili ha. Ha niile bụkwa ndị a na-ebighị ugwu, ndị e ji mma agha gbuo, nʼihi na ha mere ka oke egwu ha dị nʼala ndị dị ndụ.
\v 27 Ugbu a, e likọọla ha na ndị a na-ebighị ugwu, bụ ndị dike nʼagha, ndị nwụrụ anwụ, ndị ji ngwa agha ha gbadaa nʼime ili ha, ndị e hinyere ngwa agha ha nʼokpuru isi ha, ebe ọta\f + \fr 32:27 \ft Eleghị anya ihe a ga-agụta nʼakwụkwọ Hibru; ya bụ akwụkwọ Masoreti ga-abụ \fqa ntaramahụhụ ha dịkwasịrị nʼọkpụkpụ ha\f* ha dịkwasịrị nʼọkpụkpụ mgbe e tinyere ha nʼili. Ma nʼezie, ndị a bụ dike nʼagha mere ka oke egwu dị nʼala ndị dị ndụ.
\p 
\v 28 “Ma gị onwe gị, bụ Fero, otu a ka a ga-esi gbajie gị, ị ga-edinakwa nʼetiti ndị a na-ebighị ugwu, gị na ndị e ji mma agha gbuo.
\p 
\v 29 “Nʼebe ahụ ka Edọm na ndị eze ya, na ndịisi ya niile nọ. Nʼagbanyeghị ịdị ike ha, ha na ndị e ji mma agha gbuo tọgbọrọ nʼebe ahụ. Ha na ndị a na-ebighị ugwu so dinaa, bụ ndị na-arịdaru nʼolulu.
\p 
\v 30 “Ndịisi nke mba ndị ugwu, na ndị Saịdọn niile nọ nʼebe ahụ. Ụjọ niile nke ha sitere nʼisiike ha menye ndị mmadụ egbochighị ha iketa oke nʼihere nke iso ndị e gburu egbu nwụọ. Ha soro ndị eji mma agha gbuo dinaa na-ebighị ugwu, buru ihere ha, ha na-arịdaru nʼolulu.
\p 
\v 31 “Fero na ndị agha ya niile ga-ahụ ndị a, ọ ga-enwe nkasiobi maka ndị ya niile, na usuu ndị agha ya niile ndị eji mma agha gbuo. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara.
\v 32 Nʼagbanyeghị na emeela m ka ọ gbasaa ụjọ\f + \fr 32:32 \ft Maọbụ, \fqa ka ụjọ ya dị\f* nʼala ndị dị ndụ, Fero na igwe mmadụ a niile ka a ga-eli nʼetiti ndị a na-ebighị ugwu, ya na ndị ejiri mma agha gbuo. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.”
\c 33
\s1 Nlọghachi Izikiel dịka onye nche
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, gwa ndị gị okwu sị ha, ‘Mgbe m wetara mma agha imegide mba ọbụla, ma ndị ala ahụ ahọpụta otu onye nʼetiti ha mee ya ka ọ ghọrọ ha onye nche,
\v 3 onye ga-ahụ mma agha ka ọ na-abịakwasị ala ahụ, ọ bụrụ na o gbuo opi ike, ịdọ ndị bi na mba ahụ aka na ntị banyere mma agha nke na-abịa,
\v 4 ọ bụrụkwa na onye ọbụla anụ opi ike ahụ ma jụ ịnabatara onwe ya ịdọ aka na ntị ahụ, mma agha ahụ gbuo ya, ọbara ya ga-adịkwasị ya nʼisi.
\v 5 Nʼihi na ha nụrụ ụda opi nke ịdọ aka na ntị ahụ ma ha geghị ntị. Ọ bụ ha wetaara onwe ha ịla nʼiyi. A sị na ha gere ntị ha gaara azọpụta ndụ ha.
\v 6 Ma ọ bụrụ na onye nche elepụ anya hụ ndị agha ka ha na-abịa hapụ igbu opi ịdọ ndị mmadụ aka na ntị, ọnwụ ha dị nʼisi ya. Ha ga-anwụ nʼime mmehie ha, ma aga m ajụta ọbara ha site nʼaka onye nche ahụ.’
\p 
\v 7 “Nwa nke mmadụ, emeela m gị ka ị bụrụ onye nche nye ụlọ Izrel. Nʼihi ya, gee ntị nʼihe m na-ekwu, ka ị dọọrọ m ha aka na ntị.
\v 8 Mgbe m na-asị onye ajọ omume, gị onye na-emebi iwu, ị ghaghị ịnwụ! Ọ bụrụ na ị kwughị okwu, ime ka o chigharịa site nʼụzọ ya pụta, onye ahụ na-emebi iwu ga-anwụ nʼihi mmehie ya niile, ma nʼaka gị ka m ga-ajụta ọbara ha.
\v 9 Ma ọ bụrụ na ị dọọ onye ajọ omume aka na ntị ka o chigharịa site nʼụzọ ya pụta, ma o meghị nke a, ha ga-anwụ nʼihi mmehie ha, ma ndụ gị onwe gị ka ị zọpụtara.
\p 
\v 10 “Nwa nke mmadụ, gwa ụlọ Izrel, ‘Otu a ka unu na-ekwu, “Njehie niile anyị na mmehie niile anyị adịla arọ nʼahụ anyị. Ọ bụkwa nʼime ya ka anyị na-ata ahụ. Olee otu anyị ga-esi dị ndụ?” ’
\v 11 Gwa ha, ‘Dịka m na-adị ndụ, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara, ọnwụ onye na-emebi iwu adịghị atọ m ụtọ, kama ọ na-atọ m ụtọ mgbe onye na-emebi iwu sitere nʼụzọ\f + \fr 33:11 \fq Ụzọ \ft nʼebe a, na-ekwu maka mmebi iwu\f* ya chegharịa dịrị ndụ. Chigharịanụ, sitenụ nʼụzọ ọjọọ\f + \fr 33:11 \ft Maọbụ, \fqa mmehie unu\f* unu niile chigharịa. Nʼihi gịnị ka unu ga-eji nwụọ, unu bụ ụlọ Izrel?’
\p 
\v 12 “Nʼihi ya, nwa nke mmadụ, gwa ndị ala gị, ‘Ezi omume nke onye na-eme ezi ihe agaghị azọpụta ya ma ọ bụrụ na ọ tụgharịa, mee ihe ọjọọ. Otu a kwa, mmehie niile nke onye na-emebi iwu agaghị eme ka ọ laa nʼiyi ma ọ bụrụ na o chegharịa pụọ site na mmehie.’
\v 13 Ọ bụrụ na m asị onye ezi omume, na ọ ghaghị ịdị ndụ, ma onye dị otu a atụkwasị obi nʼezi omume ya mee ajọ ihe, ọ dịghị ihe ezi omume nke onye dị otu a mere nke a ga-echetakwa. Ha ga-anwụ nʼihi ajọ ihe ha mere.
\v 14 Ma ọ bụrụ na m asị onye ajọ omume, ‘Ị ghaghị ịnwụ,’ ma onye ahụ esite na mmehie ya chigharịa, mee ihe ziri ezi na nke dị mma,
\v 15 ọ bụrụ na o nyeghachi ihe ebe ọ naara nʼaka ndị ọ gbazinyere ego, kwụghachi ihe niile o zuuru nʼohi, gbasoo ụkpụrụ ahụ niile bụ nke na-enye ndụ, gharakwa ime ajọ omume; onye dị otu a aghaghị ịdị ndụ, ọ gaghị anwụ.
\v 16 Ọ dịghị mmehie niile nke onye ahụ mere nke a ga-echeta megide ya. Nʼihi na o meela ihe ziri ezi na nke dịkwa mma, ọ gaghị ịdị ndụ.
\p 
\v 17 “Ma ndị gị na-asị, ‘Ụzọ Onyenwe anyị ezighị ezi.’ Ma ọ bụ ụzọ ha bụ nke na-ezighị ezi.
\v 18 Ọ bụrụ na onye ezi omume esite nʼezi omume ya chigharịa malite ime ihe ọjọọ, ọ ga-anwụ maka ya.
\v 19 Ma ọ bụrụ na onye ajọ omume esite nʼajọ omume ya chigharịa malite ime ihe ziri ezi na nke dị mma, ọ ga-adị ndụ site nʼime nke a.
\v 20 Ma unu bụ ụlọ Izrel na-asị, ‘Ụzọ Onyenwe anyị ezighị ezi.’ Ma aga m ekpe onye ọbụla nʼime unu ikpe dịka ụzọ ya si dị.”
\s1 Nkọwa maka ọdịda Jerusalem
\p 
\v 21 O ruo nʼafọ nke iri na abụọ nke e mere ka anyị jee biri na mba ọzọ, nʼọnwa nke iri, nʼụbọchị nke ise nke ọnwa ahụ, otu onye nʼime ndị sitere na Jerusalem gbapụ bịakwutere m gwa m sị, “Obodo ahụ adaala.”
\v 22 Ma nʼanyasị, tupu onye ahụ gbapụrụ agbapụ abịa, aka \nd Onyenwe anyị\nd* ruru m ahụ, mee ka m nweekwa ike ikwu okwu ọzọ.
\p 
\v 23 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 24 “Nwa nke mmadụ, ndị ahụ bi nʼebe dakpọsịrị adakpọsị nʼala Izrel na-asị, ‘Ebraham bụ otu nwoke, ma o nwetachara ala a niile! Ma anyị dị ukwuu, nʼihi enyela anyị ala dịka ihe nweta anyị.’
\v 25 Ya mere, gwa ha, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Ebe ọ bụ na unu na-eri anụ nke ọbara dị nʼime ya, na-elekwasịkwa arụsị unu anya, na-awụsikwa ọbara, o kwesiri ka unu nweta ala a?
\v 26 Unu na-atụkwasị obi unu na mma agha unu, unu na-eme ihe arụ dị iche iche, onye ọbụla nʼime unu na-emerụ nwunye onye agbataobi ya. Ọ bụkwa ala nke a ka unu ga-enweta?’
\p 
\v 27 “Gwa ha nke a, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, dịka m na-adị ndụ, ndị niile fọdụrụ nʼobodo ahụ e tikpọrọ etikpọ ga-anwụcha site na mma agha. Ndị bi nʼọhịa ka anụ ọhịa ga-atagbu. Ndị niile bi nʼọgba na nʼebe niile e wusiri ike ga-anwụ site nʼọrịa.
\v 28 Aga m eme ka ala unu ghọọ ebe tọgbọrọ nʼefu. Nganga ya, na ike ya ga-agwụsị. Obodo niile dị nʼugwu Izrel ga-aghọ ebe e tikpọrọ etikpọ, mmadụ agakwaghị esite nʼebe ahụ gafee ọzọ.
\v 29 Ha ga-amakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*, mgbe m mesiri ka ala ahụ ghọọ mkpọmkpọ ebe tọgbọrọ nʼefu, nʼihi ihe arụ niile nke ha mere.’
\p 
\v 30 “Ma gị onwe gị, nwa nke mmadụ, ndị ala gị na-ekwu banyere gị nʼakụkụ mgbidi ha na nʼọnụ ụzọ ụlọ ha. Ha na-asịrịta onwe ha, ‘Bịanụ ka anyị gaa nụrụ ozi sitere nʼọnụ \nd Onyenwe anyị\nd*.’
\v 31 Ha na-abịakwute gị dịka ndị mmadụ si abịa, ha na-anọrọ ala nʼihu gị na-anụ ihe ị na-ekwu ma ha anaghị emepụta ya nʼomume: nʼihi na ha na-eji egbugbere ọnụ ha na-egosi ịhụnanya, ma obi ha nọ naanị na uru ọjọọ ha ga-enweta.
\v 32 Nʼanya ha, ị dịka onye ji ezigbo olu na-ekwe ukwe ịhụnanya, dịka onye nwere olu ụtọ, nke na-abụ abụ dị ụtọ, na onye maara ka e si eti ịgba. Ha na-anụ ihe ị na-ekwu ma ha ejighị ya kpọrọ ihe ọbụla.
\p 
\v 33 “Ma mgbe nke a bịara na mmezu, nʼihi ọ ghaghị ịbịa, ha ga-amata na onye amụma anọtụla nʼetiti ha.”
\c 34
\s1 \nd Onyenwe anyị\nd* ga-abụ onye ọzụzụ atụrụ Izrel
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, buo amụma megide ndị ọzụzụ atụrụ Izrel niile, buo amụma sị ha, ‘Ihe a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Ahụhụ na-adịrị unu ndị ọzụzụ atụrụ Izrel, ndị na-enyeju naanị onwe ha afọ. Ọ kwesighị ka onye ọzụzụ atụrụ lekọtazie igwe atụrụ e tinyere nʼaka ya anya?
\v 3 Unu na-eri abụba ha niile, unu na-eyi uwe ajị anụ, na-egbu anụ ndị mara abụba nʼagbanyeghị na unu adịghị elekọta igwe ewu na atụrụ m ndị a.
\v 4 Unu anaghị eme ka ndị na-adịghị ike dị ike, maọbụ gwọọ ndị na-arịa ọrịa, maọbụ kechie ọnya ndị merụrụ ahụ. Unu adịghị akpọghachite ndị kpafuru akpafu, maọbụ pụọ ịchọ ndị furu efu. Kama naanị aka ike ka unu ji na-achị ha.
\v 5 Nʼihi ya, ha agbasasịala nʼihi na onye ọzụzụ atụrụ anọghị ya. Ha aghọkwaarala anụ ọhịa niile ihe oriri.
\v 6 Igwe ewu na atụrụ nke m na-awagharị nʼugwu niile, na nʼelu ugwu nta niile. Ọ bụkwa nʼelu ụwa niile ka ha gbasara. Ọ dịkwaghị onye na-ajụ ajụjụ banyere ha. Ọ dịkwaghị onye na-elenye anya nʼebe ha nọ.
\p 
\v 7 “ ‘Nʼihi nke a, unu ndị ọzụzụ atụrụ, nụrụnụ okwu nke \nd Onyenwe anyị\nd*:
\v 8 Dịka mụ onwe m na-adị ndụ, ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara, ebe unu hapụrụ igwe atụrụ m na-enweghị onye ọzụzụ atụrụ, mee ka ha ghọọrọ anụ ọhịa ihe oriri, ebe unu na-achọgharịghị ha, kama unu nọ na-enyeju onwe unu afọ, ma hapụ igwe atụrụ m ka agụụ gbuo ha,
\v 9 nʼihi ya, unu ndị ọzụzụ atụrụ, nụrụnụ okwu nke \nd Onyenwe anyị\nd*:
\v 10 Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, Ana m edo onwe m megide ndị ọzụzụ atụrụ niile. Ọ bụkwa nʼaka ha ka m ga-ajụta ihe banyere igwe ewu na atụrụ m. Aga m eme ka ha kwụsị ị bụ ndị na-azụ igwe ewu na atụrụ m, ka ndị ọzụzụ atụrụ ndị a ghara ịzụ onwe ha nri ọzọ. Aga m esite nʼọnụ ha napụta igwe ewu na atụrụ m, ha agaghị abụkwara ha nri ọzọ.
\p 
\v 11 “ ‘Nʼihi na Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị, mụ onwe m ga-eji aka m pụọ gaa chọgharịa igwe atụrụ m. Mụ onwe m kwa ga-elekọta ha.
\v 12 Dịka onye ọzụzụ atụrụ si elekọta igwe ewu na atụrụ ya anya, mgbe ha na ya nọ, otu a ka m ga-esi lekọta igwe atụrụ m. Aga m anapụta ha site nʼebe niile ha gbasasịrị gaa, nʼụbọchị igwe ojii na ọchịchịrị ahụ.
\v 13 Aga m esite nʼobodo niile, na mba niile ha nọ kpọghachi ha nʼala nke ha. Aga m azụ ha nri nʼelu ugwu niile nke Izrel, na nʼakụkụ mmiri niile, ebe ala na-ewepụta nri nke ọma.
\v 14 Aga m azụ ha nʼebe ịta ahịhịa mara mma, na nʼelu ugwu niile nke Izrel. Nʼebe ahụ ka ha ga-amakpukwa nʼudo. Ha ga-ata nri nʼebe ịta ahịhịa mara mma nke elu ugwu Izrel.
\v 15 Ọ bụ mụ onwe m ga-abụ onye ọzụzụ atụrụ nke atụrụ m niile. Aga m eme ka ha makpuru nʼudo, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara.
\v 16 Aga m achọ ndị furu efu nʼime ha, ndị kpafuru akpafu, kpọghachite ha nʼụlọ. Aga m ekechi ọnya ndị merụrụ ahụ, meekwa ka ọ dị ike. Ma ndị mara abụba na nke ndị ahụ dị ike ka m ga-ala nʼiyi. Aga m eji ikpe ziri ezi zụọ ha.
\p 
\v 17 “ ‘Ma unu onwe unu, ụmụ igwe anụ ụlọ m, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, aga m ekpe ikpe nʼetiti atụrụ na atụrụ, ebule na mkpi.
\v 18 Ọ bụ unu ihe nta nʼanya na unu na-ata nri kachasị mma? Unu ga-ejikwa ụkwụ zọtọsịa nke fọdụrụ? Ọ bụ unu ihe nta nʼanya na unu na-aṅụ mmiri nke kachasị mma? Unu ga-ejikwa ụkwụ unu na-agbarụ nke fọdụrụ?
\v 19 Ọ bụ ihe kwesiri ekwesi na igwe atụrụ m ga-ata nri unu zọtọrọ azọtọ, ma ṅụọkwa mmiri unu gbarụrụ agbarụ?
\p 
\v 20 “ ‘Nʼihi ya, nke a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị ha, nʼezie, mụ onwe m ga-ekpe ikpe nʼetiti atụrụ ndị gbara abụba, na atụrụ ndị a tara ahụ.
\v 21 Nʼihi na unu ji akụkụ ahụ unu, na ubu aka unu na-enupu ha. Unu jikwa mpi unu na-enupu ndị na-adịghị ike, tutu ruo mgbe unu chụsachara ha.
\v 22 Lee, aga m azọpụta igwe ewu na atụrụ m. Aga m ekpe ikpe nʼetiti otu atụrụ na ibe ya. Ha agaghị aghọkwa ihe oriri ọzọ. Aga m ekpe ikpe nʼetiti otu atụrụ na ibe ya.
\v 23 Aga m edobe otu onye ọzụzụ atụrụ nke ga-elekọta ndị m, ọ bụladị ohu m Devid. Ya onwe ya ga-elekọta ha, bụrụkwa onye ọzụzụ atụrụ nye ha.
\v 24 Ma mụ onwe m bụ \nd Onyenwe anyị\nd*, ga-abụ Chineke ha, ma ohu m Devid ga-abụ onyeisi nʼetiti ndị m. Mụ onwe m bụ \nd Onyenwe anyị\nd* ekwuola ya.
\p 
\v 25 “ ‘Mụ na ha ga-agba ndụ udo. Aga m achụpụkwa anụ ọjọọ niile nʼala ha, ka ndị m nwee ike ibi nʼudo nʼọzara, ma rahụkwa ụra ọ bụladị nʼetiti oke ọhịa nʼenweghị nsogbu.
\v 26 Aga m agọzi ndị m, gọziekwa ebe obibi ha na ihe niile gbara ugwu nta m gburugburu. Aga m ezite mmiri ozuzo nʼoge ya, nʼezie, ngọzị ga-ezoro ha dịka mmiri.
\v 27 Osisi ọhịa ga-amị mkpụrụ ya, ala ga-eme ihe omume ya. Ndị m ga-anọkwa nʼudo nʼala ha na-atụghị ụjọ. Ha ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*, mgbe m tijasịrị mkpọrọ yoku niile ha, napụta ha site nʼaka ndị na-akpagbu ha.
\v 28 Ha agaghị abụkwa mba ndị ọzọ na-apụnara ihe ha nwere, maọbụ ndị anụ ọhịa ga-adọgbu. Ha ga-ebi na-atụghị ụjọ, ọ dịkwaghị onye ga-eme ka ha tụọ egwu.
\v 29 Aga m enye ha ala nke amaara nke ọma nʼihi ihe na-epupụta nʼime ya, ha agaghị abụkwa ndị ụnwụ mekpara ahụ nʼala ahụ ọzọ, maọbụ ihe a na-akwa emo nke mba dị iche iche.
\v 30 Ha ga-amata na mụ onwe m, bụ \nd Onyenwe anyị\nd* Chineke ha, na m na-anọnyere ha, na ha onwe ha kwa, bụ ụlọ Izrel, bụ ndị m, otu a ka Onyenwe anyị Chineke kwupụtara.
\v 31 Unu bụ igwe ewu na atụrụ m, atụrụ nke ebe ịta nri m, mụ onwe m bụkwa Chineke unu. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.’ ”
\c 35
\s1 Amụma megide Edọm
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, chee ihu imegide nʼugwu Sia, buo amụma megide ya,
\v 3 sị ya, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị: Mụ onwe m na-emegide gị, gị ugwu Sia. Aga m esetikwa aka m imegide gị, mee gị ka ị ghọọ ebe tọgbọrọ nʼefu.
\v 4 Obodo gị niile ka m ga-eme ka ha ghọọ mkpọmkpọ ebe, gị onwe gị ga-abụkwa ebe tọgbọrọ nʼefu. Mgbe ahụ, ị ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\p 
\v 5 “ ‘Nʼihi na i sitere nʼiro ahụ dị gị nʼobi siterịị na mgbe ochie rara ụmụ Izrel nye nʼaka mma agha, nʼoge ha nọ na-ahụju anya, nʼoge ahụ ịta ahụhụ nke ajọ omume ruru nʼogo dị ukwuu.
\v 6 Nʼihi nke a, ebe m na-adị ndụ, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri, aga m enyefe gị nʼaka ndị na-awụsi ọbara. Ọbara ga-achụkwa gị ọsọ. Ebe ọ bụ na ị kpọghị iwusi ọbara asị, ọbara a ga-awụsị nʼime gị ga-achụ gị ọsọ.
\v 7 Aga m eme ka ugwu Sia ghọọ ebe tọgbọrọ nʼefu. Aga m esitekwa nʼime ya bipụ ndị na-abata abata, na ndị na-apụ apụ.
\v 8 Ugwu ukwu gị niile ga-ejupụta nʼozu ndị nwụrụ anwụ, ugwu nta niile, na ndagwurugwu niile na mgbawara niile dị nʼala ga-ejupụta nʼozu ndị e ji mma agha gbuo.
\v 9 Ị gaghị ebulitekwa isi gị ọzọ. Ebe tọgbọrọ nʼefu ka ị ga-abụ ruo ebighị ebi. A gaghị ewuzikwa obodo gị ọzọ. Ị ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\p 
\v 10 “ ‘Nʼihi na ị sịrị, “Mba abụọ ndị a, na ala abụọ ndị a ga-abụ nke anyị, anyị ga-enweta ha,” nʼagbanyeghị na mụ onwe m bụ \nd Onyenwe anyị\nd* nọ nʼebe ahụ.
\v 11 Nʼihi ya, ebe m na-adị ndụ, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri, aga m emeso gị mmeso dịka ịba ụba nke iwe gị na ekworo gị si dị, bụ nke i gosiri mgbe ị kpọrọ ha asị. Aga m emekwa ka ha mata onye m bụ, mgbe m kpesịrị gị ikpe.
\v 12 Mgbe ahụ, ị ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd* nụrụ okwu ọjọọ ndị ahụ niile i kwuru megide ugwu Izrel niile, na-asị, “E meela ha ebe tọgbọrọ nʼefu, ewerela ha nyefee anyị nʼaka ka anyị dọgbuo ha.”
\v 13 Unu nyakwara isi megide m, kwuo okwu kwugide m dịka o si dị unu mma. Anụkwara m ihe niile unu kwuru.
\v 14 Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị, Mgbe ụwa niile na-aṅụrị ọṅụ ka m ga-eme ka ị ghọọ mkpọmkpọ ebe.
\v 15 Dịka ị ṅụrịrị ọṅụ mgbe ihe nketa Izrel ghọrọ mkpọmkpọ ebe, otu a ka m ga-esi mesoo gị mmeso. Ị ga-aghọkwa ebe tọgbọrọ nʼefu, gị ugwu Sia, gị na ndị Edọm niile. Mgbe ahụ, ha ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.’ ”
\c 36
\s1 Olileanya nye ugwu Izrel niile
\p 
\v 1 “Nwa nke mmadụ, buo amụma nye ugwu niile dị nʼIzrel, na-asị ha, ‘Ugwu niile nke Izrel, nụrụnụ okwu nke \nd Onyenwe anyị\nd*.
\v 2 Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Ndị iro unu ekwuola megide unu sị, “Ahaa! Ebe niile dị elu nke mgbe ochie aghọọla ihe nnweta anyị.” ’
\v 3 Nʼihi ya, buo amụma sị, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Nʼihi na ha emeela ka unu tọgbọrọ nʼefu, chụgharịa unu ọsọ nʼakụkụ niile, mekwaa ka unu ghọọrọ mba niile ihe nnweta, ma meekwa ka unu bụrụ ndị a na-ekwujọ, na ndị a na-akọcha,
\v 4 nʼihi ya, unu ugwu niile nke Izrel, nụrụnụ okwu Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*. Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-agwa ugwu ukwuu na ugwu nta niile, na mgbawara niile dị nʼala, na ndagwurugwu niile, na ebe niile tọgbọrọ nʼefu, na obodo ndị ahụ niile ndị mmadụ na-ebighị nʼime ya, nke ndị mba ọzọ kwakọọrọ ihe dị ha nʼime, ma jirikwa ha na-eme ihe ọchị.
\v 5 Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, Ọ bụ site nʼịnụ ọkụ nke obi m ka m ji kwuo okwu megide mba ndị ọzọ, ma megidekwa Edọm, nʼihi na ọ bụ site nʼịkpọ asị nke obi ha ka ha ji mee ka ala m bụrụ ihe nnweta ha, ka ha si otu a kposaa, ma chịkọrọkwa ihe niile dị nʼebe ịta nri nke anụ ụlọ ala ahụ.’
\v 6 Nʼihi nke a, buo amụma banyere Izrel, gwa ugwu ukwu ya na ugwu nta ya niile, na mgbawara ala ya, na ndagwurugwu ya niile, sị, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị, ọ bụ site nʼọnụma nke ekworo ka m ji ekwu okwu ndị a, nʼihi na unu ahụọla ahụhụ site na nlelị ndị mba ọzọ na-elelị unu.
\v 7 Nʼihi ya, ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, eweliri m aka m elu ṅụọ iyi na mba ndị a gbara unu gburugburu ga-anọkwa nʼọnọdụ ihere.
\p 
\v 8 “ ‘Ma unu, ugwu niile nke Izrel ga-awapụta ngalaba, mịakwa mkpụrụ nke ndị m ga-eri, nʼihi na oge ha ga-alọghachi adịghịkwa anya.
\v 9 Lee, mụ onwe m dịnyeere unu; aga m abịa inyere unu aka, nʼihi na a ga-akọgharịkwa unu, kụọkwa mkpụrụ nʼime unu.
\v 10 Aga m emekwa ka ọnụọgụgụ ndị ga-ebi nʼime unu baa ụba, ọ bụladị ụlọ Izrel niile. Ha ga-ebikwa nʼobodo niile, wugharịakwa ebe niile e tikpọrọ etikpọ.
\v 11 Aga m eme ka ọnụọgụgụ ndị mmadụ, na anụ ụlọ dị nʼime gị baa ụba. Ha ga-amụbakwa, jupụtakwa ebe niile. Ndị mmadụ ga-ebikwa nʼelu gị dịka ha si biri nʼoge gara aga. Aga m emekwa ka ihe gaara ha nke ọma karịa ka ọ dị na mbụ. Mgbe ahụ, unu ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\v 12 Aga m eme ka ndị m, ndị m bụ Izrel, biri nʼime unu. Unu ga-abụ ihe nweta ha, unu ga-aghọkwara ha ihe nketa. Unu agakwaghị agbaba ha aka ụmụ ọzọ.
\p 
\v 13 “ ‘Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị, nʼihi na ụfọdụ mba na-ekwutọ gị na-asị, “Ị bụ ala na-eri ụmụ ya, ala na-agbaba ndị ya aka ụmụ.”
\v 14 Nʼihi nke a, ị gaghị erikwa mmadụ ọzọ. Ị gaghị agbawakwa mba gị aka ụmụ ọzọ. Ọ bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\v 15 Agaghị m emekwa ka ị nụrụ mkparị nke ndị mba ọzọ na-akparị gị. Ị gaghị anọkwa ọnọdụ nke ga-eme ka ndị mba ọzọ lelịa gị, maọbụ nọọ ọnọdụ nke ga-eme ka ị sọọ ngọngọ. Ọ bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.’ ”
\s1 Nkwa banyere nlọghachi Izrel
\p 
\v 16 Ọzọkwa, okwu nke \nd Onyenwe anyị\nd* rutere m ntị, sị,
\v 17 “Nwa nke mmadụ, mgbe ụmụ Izrel bi nʼala nke aka ha, ha merụrụ ya, site na ndụ ọjọọ ha, na omume ha. Ndụ ọjọọ ha nʼihu m, dị ka adịghị ọcha nke nwanyị nʼoge ọ nọ na nsọ ya, nʼọnwa niile.
\v 18 Nʼihi ya, awụkwasịrị m ha ọnụma m, nʼihi na ha na-awụsi ọbara nʼala ahụ, jirikwa arụsị ha na-emerụ ya.
\v 19 Achụsasịrị m ha na mba dị iche iche. Otu a ka m si kpee ha ikpe nʼihi ụzọ ọjọọ ha, na omume ọjọọ ha.
\v 20 Ma ebe niile ha gara nʼetiti mba niile, ha mere ka aha nsọ m gharakwa ịdị nsọ, nʼihi na a na-ekwu banyere ha, sị, ‘Ndị a bụ ndị nke \nd Onyenwe anyị\nd*, ma agbanyeghị nke a, ha sitere nʼala ya pụọ.’
\v 21 Ihe na-ewutekwa m bụ aha nsọ m, nke ụlọ Izrel mere ka ọ ghara ịdị nsọ nʼetiti mba niile bụ ebe ha gara.
\p 
\v 22 “Ya mere, gwa ụlọ Izrel, Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Ọ bụghị nʼihi na unu, ụlọ Izrel, ka m ji na-eme ihe ndị a, kama ọ bụ nʼihi aha nsọ m, nke unu mere ka ọ ghara ịdị nsọ nʼetiti mba niile dị iche iche ebe ndị unu gara.
\v 23 Aga m eme ka ịdị nsọ nke aha ukwuu m, nke unu mere ka ọ ghara ịdị nsọ nʼetiti mba niile, pụta ìhè. Mgbe ahụ, mba niile ga-amakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara, mgbe a ga-edo m nsọ site nʼime unu nʼanya ha.
\p 
\v 24 “ ‘Nʼihi na aga m esi na mba niile dị iche iche kpọpụta unu. Aga m achịkọta unu site nʼala niile, mee ka unu bata nʼala unu.
\v 25 Aga m efekwasị unu mmiri dị ọcha, unu ga-adịkwa ọcha. Aga m eme ka unu dị ọcha\f + \fr 36:25 \ft Maọbụ, \fqa Aga m asachapụ unu\f* site na-adịghị ọcha unu niile, na site nʼikpere arụsị unu niile.
\v 26 Aga m enye unu obi ọhụrụ, kenyekwa unu mmụọ ọhụrụ. Aga m ewepụ obi nkume nke mmehie dị nʼime unu, nye unu mkpụrụobi nke anụ ahụ.
\v 27 Aga m etinyekwa mmụọ m nʼime unu, mee ka unu gbaso ụkpụrụ m niile ma lezie anya mekwaa ihe niile m nyere nʼiwu.
\v 28 Unu ga-ebikwa nʼala ahụ nke m nyere nna unu ha. Unu ga-abụ ndị m, aga m abụkwa Chineke unu.
\v 29 Aga m azọpụta unu site na-adịghị ọcha unu niile. M ga-akpọ mkpụrụ ubi, mee ka o rie nne nke ukwu, agaghị m emekwa ka ụnwụ dakwasị unu ọzọ.
\v 30 Aga m emekwa ka mkpụrụ osisi na ihe owuwe ubi baa ụba nke ukwuu, ka unu gharakwa ịnata ihere ọzọ nʼihi ụnwụ,\f + \fr 36:30 \ft Maọbụ, \fqa nʼihi ụkọ nri\f* nʼetiti mba niile dị iche iche.
\v 31 Mgbe ahụ, unu ga-echeta ụzọ ọjọọ unu niile na omume ọjọọ unu niile, unu ga-asọkwa onwe unu oyi nʼihi mmehie unu na ihe arụ niile unu mere.
\v 32 Ma achọrọ m ka unu mata na ọ bụghị nʼihi mma unu ka m ji na-eme ihe ndị a. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara. Unu ụlọ Izrel, ihere kwesiri ime unu nʼihi omume ọjọọ unu mere.
\p 
\v 33 “ ‘Nke a bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Nʼụbọchị ahụ m ga-eme ka ị dị ọcha site na mmehie gị niile, aga m eme ka unu lọghachi nʼobodo unu biri, a ga-ewugharịkwa ebe niile tọgbọrọ nʼefu.
\v 34 Ala ubi ndị ahụ nke tọgbọrọ nʼefu agaghị atọgbọkwa nʼefu nʼihu anya ndị na-agafe agafe. A ga-akọkwa ha niile.
\v 35 Mgbe ahụ, ha ga-asị, “Ala a, nke naara atọgbọ nʼefu, aghọọla ubi a gbara ogige, nke yiri ogige Iden. Leekwa na obodo niile ndị ahụ e tikpọrọ etikpọ, ka e wuzikwara, werekwa mgbidi gbaa ha ogige. Ugbu a, ndị mmadụ jupụtakwara nʼime ha.”
\v 36 Mgbe ahụ, mba niile gbara unu gburugburu, bụ ndị fọdụrụ, ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd* wuziri ebe niile e tikpọrọ etikpọ, kụọkwa mkpụrụ nʼebe niile tọgbọrọ nʼefu. Mụ onwe m bụ \nd Onyenwe anyị\nd*, ekwuola, aga m emekwa ya.’
\p 
\v 37 “Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, ọzọkwa, aga m ege ntị, zaa ekpere ụlọ Izrel, mezuoro ha arịrịọ ha. Aga m eme ka ha baa ụba dịka igwe anụ ụlọ,
\v 38 dịka igwe anụ ụlọ, nke na-ejupụta na Jerusalem nʼoge mmemme ya niile a kara aka. Nʼụzọ dị otu a, obodo niile e tikpọrọ etikpọ ga-ejupụtakwa na mmadụ ọzọ. Mgbe ahụ ha ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*.”
\c 37
\s1 Ndagwurugwu ọkpụkpụ kpọrọ nkụ
\p 
\v 1 Aka nke \nd Onyenwe anyị\nd* dịkwasịrị m, o sitekwara nʼike Mmụọ nke Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* bulie m, debe m nʼetiti ndagwurugwu nke jupụtara nʼọkpụkpụ.
\v 2 O mere ka m jegharịa nʼetiti ha. Ahụrụ m ọkpụkpụ kpọrọ nkụ, nke dị ukwuu nʼọnụọgụgụ, ka ha ghasa na ndagwurugwu ahụ.
\v 3 Ọ sịrị m, “Nwa nke mmadụ, ọkpụkpụ ndị a ha pụrụ ịdị ndị ọzọ?”
\p Asịrị m, “Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* ọ bụ naanị gị onwe gị maara.”
\p 
\v 4 Mgbe ahụ, ọ sịrị m, “Buo amụma nye ọkpụkpụ ndị ahụ, gwa ha, ‘Unu ọkpụkpụ niile kpọrọ nkụ, geenụ ntị nʼokwu nke \nd Onyenwe anyị\nd*.
\v 5 Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-agwa ọkpụkpụ ndị a. Lee, aga m eme ka ume baa nʼime unu, unu ga-adịkwa ndụ.
\v 6 Aga m etinyekwasị unu akwara, na anụ ahụ, werekwa akpụkpọ ahụ kpuchie unu. Aga m etinye ume nʼime unu, unu ga-adịkwa ndụ. Mgbe ahụ, unu ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.’ ”
\p 
\v 7 Ya mere, eburu m amụma dịka e sị nye m nʼiwu. Mgbe m nọ na-ebu amụma ahụ, anụrụ m ụzụ, ụzụ mkpọtụ. Ma lee, ọkpụkpụ ndị ahụ niile bịara ibe ha nso; ọkpụkpụ malitekwara ijikọta onwe ha ọnụ.
\v 8 Mgbe m nọkwa na-ele anya, lee, ahụrụ m ka akwara na anụ ahụ malitere ịbịakwasị nʼelu ọkpụkpụ ndị ahụ, akpụkpọ ahụ kpuchikwara elu ha. Ma nʼoge a ume ọbụla adịghị nʼime ha.
\p 
\v 9 Mgbe ahụ, ọ sịrị m, “Buo amụma nye ifufe; buo amụma, nwa nke mmadụ, sị ifufe, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: site nʼakụkụ anọ nke ụwa bịa, gị ume na-enye ndụ, kukwasị ndị a e gburu egbu ka ha dịkwa ndụ ọzọ.’ ”
\v 10 Ya mere, eburu m amụma dịka o si nye m nʼiwu. Ume ndụ banyekwara nʼime ha. Ha niile dịịrị ndụ, bilie ọtọ, guzo nʼụkwụ ha, ghọọ usuu ndị agha dị ukwuu nʼọnụọgụgụ.
\p 
\v 11 Mgbe ahụ, ọ gwara m, “Nwa nke mmadụ, ọkpụkpụ ndị a nọchiri anya ụlọ Izrel niile. Ha na-asị, ‘Anyị aghọọla ọkpụkpụ kpọrọ nkụ, olileanya niile agwụkwala, anyị abụrụla ndị e bipụrụ.’
\v 12 Nʼihi ya, buo amụma gwa ha, ‘otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, Ndị m, aga m emeghe ili unu, si nʼebe ahụ wepụta unu. Aga m eme ka unu lọghachitakwa nʼala Izrel.
\v 13 Nʼikpeazụ, mgbe m meghere ili unu mee ka unu si nʼime ya pụta, unu bụ ndị m ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\v 14 Aga m etinye Mmụọ m nʼime unu, unu ga-adị ndụ, lọghachikwa nʼala unu ọzọ. Unu ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*, ekwuola ya, meekwa ya, otu a ka \nd Onyenwe anyị\nd* kwubiri.’ ”
\s1 Otu mba, otu eze
\p 
\v 15 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 16 “Nwa nke mmadụ, were osisi dee ihe ndị a nʼelu ya, ‘Osisi a nọchiri anya Juda na ndị Izrel e kekọtara ya na ha ọnụ.’ Werekwa osisi ọzọ deekwa okwu ndị a nʼelu ya. ‘Osisi a nọchiri anya Ifrem, na Josef, na ndị Izrel niile e jikọtara ha na ndị a ọnụ.’
\v 17 Jidekọtaa osisi abụọ ndị a ọnụ, mee ka ha bụrụ otu osisi nʼaka gị.
\p 
\v 18 “Mgbe ndị gị jụrụ gị, ‘Ị gaghị egosi anyị ihe nke a pụtara?’
\v 19 gwa ha, sị, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu: Lee, agaje m iwere osisi Josef, nke dị Ifrem nʼaka, nke bụkwa ihe nọchiri anya ebo ụfọdụ ndị Izrel, jidekọtaa ya na osisi nọchiri anya Juda, mee ha ka ha ghọọ otu osisi, bụrụkwa otu nʼaka m.’
\v 20 Were mkpirisi osisi ndị ahụ i dere ihe nke dị nʼaka gị, gosi ha,
\v 21 ma gwakwa ha, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu: Aga m esite na mba niile ndị Izrel jere biri kpọpụta ha. Aga m achịkọtakwa ha site nʼakụkụ niile, kpọbata ha nʼala nke aka ha.
\v 22 Aga m eme ha ka ha bụrụ otu mba nʼala ahụ, nʼugwu niile nke Izrel. Ha ga-enwe naanị otu eze nke ga-achị ha niile. Ha agaghị abụkwa mba abụọ maọbụ alaeze abụọ ọzọ.
\v 23 Ha agaghị ejikwa arụsị ha niile, maọbụ ihe a pịrị apị rụrụ arụ, maọbụ jiri ihe ọjọọ ndị ọzọ dị iche iche merụọ onwe ha ọzọ. Nʼihi na aga m azọpụta ha site na ịlaghachi azụ nʼụzọ mmehie ha niile, meekwa ka ha dị ọcha. Ha ga-abụ ndị m, mụ onwe m ga-abụkwa Chineke ha.
\p 
\v 24 “ ‘Ohu m, Devid, ga-abụ eze ga-achị ha, ha ga-enwekwa otu onye ọzụzụ atụrụ. Ha ga-edebezu iwu m niile, na ụkpụrụ m niile.
\v 25 Ha ga-ebi nʼala ahụ m nyere ohu m Jekọb, ala ebe nna nna ha biri. Ha na ụmụ ha ga-ebi nʼime ya. Ụmụ ụmụ ha ruo ọgbọ niile ga-ebikwa nʼime ya. Ohu m Devid ga-abụ eze ha ruo ebighị ebi.
\v 26 Mụ na ha ga-agba ndụ udo, ọgbụgba ndụ nke ga-adị ruo mgbe ebighị ebi. Aga m agọzi ha, mee ka ha baa ụba. Nʼetiti ha kwa ka ụlọnsọ m ga-adị ruo mgbe ebighị ebi.
\v 27 Ebe obibi m ga-abụkwa nʼetiti ha. E, aga m abụ Chineke ha, ha ga-abụkwa ndị m.
\v 28 Mgbe ụlọnsọ m ga-adị nʼetiti ha ruo ebighị ebi, mba niile ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd* na-edo Izrel nsọ.’ ”
\c 38
\s1 Mmeri dị ukwuu nke \nd Onyenwe anyị\nd* meriri ọtụtụ mba
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,
\v 2 “Nwa nke mmadụ, chee ihu nʼala Magog, bukwaa amụma megide Gog, bụ onyeisi nke Meshek\f + \fr 38:2 \ft Ya bụ, Roshu\f* na Tubal. Buo amụma megide ya,
\v 3 sị, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Ana m edo onwe m imegide gị, Gog, eze ukwu ndị Meshek na Tubal.
\v 4 Aga m echigharị gị, tinye gị nko nʼagba gị abụọ, jiri ya kpụpụta gị na usuu ndị agha gị niile, na ịnyịnya gị, na ndị na-agba ịnyịnya gị na ihe agha ha, na usuu ndị agha gị niile, ndị ji ọta ukwu na ọta nta, ndị niile na-ejide mma agha ha.
\v 5 Peshịa na Itiopia,\f + \fr 38:5 \ft Maọbụ, \fqa Kush.\f* na Put, ga-esonyere ha, ha niile ga-ejikwa ọta ha na okpu agha ha.
\v 6 Goma na usuu ndị agha ya niile, na ndị agha Bet Togama ndị si nʼakụkụ ugwu, dị ebe dị anya na ọtụtụ ndị mba ọzọ ga-eso gị.
\p 
\v 7 “ ‘Jikere! Jikere onwe gị, gị onwe gị na usuu ndị agha ahụ nọ gị gburugburu, gị Gog, bụrụkwa onyendu ha.
\v 8 Mgbe ọtụtụ ụbọchị gasịrị, a ga-akpọlite gị ibu agha. Nʼogologo oge dị nʼihu, ị ga-ebuso ala ahụ agha bụ ala ahụ na-enwetaghachi onwe ya site na mbibi nke ibu agha; ala ahụ e si na mba dị iche iche chịkọtaa ndị bi nʼime ya, mee ka ha birikwa nʼugwu niile nke Izrel ahụ naara atọgbọ nʼefu. E bulatara ha site na mba dị iche iche, ma ugbu a, ha anọrọla nʼudo.
\v 9 Gị onwe gị, na ndị agha gị niile, na ọtụtụ ndị mba ahụ dị iche iche ndị na-eso gị, jiri ọsọ, dịka ikuku siri ike, rigoo, kpuchie ala ahụ dịka igwe ojii.
\p 
\v 10 “ ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Nʼụbọchị ahụ, echiche ọjọọ ga-abata nʼobi gị, mgbe ị na-atule ọtụtụ ihe dị iche iche nʼobi gị.
\v 11 Ị ga-asị, “Aga m ebuli megide nʼala na-enweghị mgbidi, aga m awakpo ndị nọ nʼudo na-adịghị atụ anya nsogbu ọbụla, ha niile bụ ndị bi nʼebe na-enweghị mgbidi, ha enweghịkwa ibo ọnụ ụzọ na mkpọrọ e ji akpọchi ha.
\v 12 Aga m akwata ihe nkwata, lụtakwa ihe nlụta nʼagha. Aga m eweli aka m megide obodo ndị a niile e wugharịrị ewugharị, megidekwa ndị a niile e si na mba dị iche iche chịkọtaa, bụ ndị bara ọgaranya nʼanụ ụlọ na ngwongwo dị iche iche, ndị bikwa nʼetiti ala a.”
\v 13 Ndị Sheba na Dedan, na ndị ahịa Tashish niile, na ụmụ ọdụm ya niile ga-ajụ gị, “Ị bịara ịkwata ihe nkwata? Ị chịkọtara usuu ndị agha gị nʼihi ịkwara ihe nlụta, na iburu ọlaọcha na ọlaedo, na ịchịrị igwe anụ ụlọ ha, na ngwongwo ha, na ịkwakọrọ ihe ha nwere nʼike?” ’
\s1 Amụma megide Gog
\p 
\v 14 “Nʼihi ya, nwa nke mmadụ, buo amụma sị Gog, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Nʼụbọchị ahụ mgbe ndị m bụ Izrel na-ebi nʼudo nʼala ha, ọ bụ na ị gaghị ahụta ya?
\v 15 Ị ga-esi nʼebe obibi gị dị nʼugwu bịa, gị na ọtụtụ mba dị iche iche, ndị na-anọkwasị nʼịnyịnya. Ha ga-adị ukwuu, bụrụ ndị agha dị ike.
\v 16 Unu ga-abịa ibuso ndị m Izrel agha, kpuchie ala ha dịka igwe ojii. Nʼụbọchị ndị ahụ dị nʼihu, aga m eme ka gị, bụ Gog, bịa buso ala m agha, ka mba niile si otu a mata m, mgbe m mere ka ịdị nsọ m pụta ìhè nʼanya ha site nʼihe m ga-eme.’
\p 
\v 17 “ ‘Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Ọ bụ gị, bụ onye ahụ m kwuru okwu banyere ya nʼoge gara aga, site nʼọnụ ndị ohu m, bụ ndị amụma Izrel, ndị buru amụma ọtụtụ afọ na mgbe ahụ, sị, na m ga-eme ka ị megide ndị m.
\v 18 Lee ihe ga-eme nʼụbọchị ahụ. Mgbe Gog busoro ala Izrel agha, ọ ga-esi otu a kpalie iwe m dị ọkụ. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara.
\v 19 Nʼihi na esitere m nʼịnụ ọkụ nke obi m, na oke iwe m kwupụta sị, na ala ọma jijiji dị ukwuu ga-adị nʼIzrel nʼụbọchị ahụ.
\v 20 Azụ niile dị nʼoke osimiri, na anụ ufe nke eluigwe, na anụ ọhịa, na ihe niile na-akpụ akpụ, na mmadụ niile nọ nʼelu ụwa ga-ama jijiji nʼihu m. A ga-akwatu ugwu niile, ebe niile dị mkputamkpu ga-adarukwa ala.
\v 21 Aga m akpọlite mma agha ka o megide Gog nʼugwu m niile. Onye ọbụla ga-ejikwa mma agha ya megide nwanne ya nwoke. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.
\v 22 Aga m eji ọrịa na-efe efe na iwusi ọbara kpee ya ikpe. Aga m awụkwasị ya na ndị agha ya na ọtụtụ mba dị iche iche ndị ahụ so ya, oke mmiri ozuzo na akụmmiri, na nkume ọkụ.
\v 23 Otu a ka m ga-esi gosi ịdị ukwuu m, na ịdị nsọ nke aha m. Aga m emekwa ka a mara m nʼanya mba niile dị iche iche. Mgbe ahụ, ha ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*.’
\c 39
\p 
\v 1 “Ma gị, nwa nke mmadụ buo amụma megide Gog, sị, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu: Ana m emegide gị, Gog, onyeisi nke Meshek na Tubal.
\v 2 Aga m echigharị gị, kpụrụ gị na-aga. Aga m esi nʼebe dịkarịsịrị anya nʼakụkụ ugwu kpọta gị, ziga gị ka i buso ugwu niile nke Izrel agha.
\v 3 Mgbe ahụ, aga m etichapụ ụta dị gị nʼaka ekpe, meekwa ka àkụ niile nke dị nʼaka nri gị dachapụ.
\v 4 Nʼelu ugwu niile nke Izrel ka ị ga-ada, gị onwe gị, na usuu ndị agha gị niile, na mba niile dị iche iche ndị na-eso gị. Udele niile dị iche iche na anụ ọhịa niile ka m ga-enyefe anụ ahụ unu ka ha were unu mere ihe oriri.
\v 5 Ị ga-ada nʼọhịa na-enweghị ebe nzobe, nʼihi na m ekwuola ya. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\v 6 Aga m awụkwasị ọkụ nʼahụ Magog, na nʼahụ ndị ahụ niile bi nʼudo, nʼọnụ mmiri niile. Ha ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*.
\p 
\v 7 “ ‘Aga m eme ka amara aha nsọ m nʼetiti ndị m bụ Izrel. Agaghị m ekwekwa ka e lelịa aha nsọ m anya ọzọ.\f + \fr 39:7 \ft Mee ka ọ ghara ịdị nsọ ọzọ\f* Mba niile dị iche iche ga-amatakwa na mụ onwe m bụ \nd Onyenwe anyị\nd*, bụ Onye nsọ nọ nʼIzrel.
\v 8 Lee, ọ na-abịa, nʼezie, ọ ga-emekwa, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri. Nke a bụ ụbọchị ahụ nke m kwuru ihe banyere ya.
\p 
\v 9 “ ‘Nʼoge ahụ, ndị bi nʼobodo niile nke Izrel ga-apụ tụtụkọtaa ngwa agha ndị ahụ, were fụnwue ọkụ, surekwaa ha ọkụ, ma ọta ukwu ma ọta nta niile, ụta na àkụ niile, ma mkpọ agha na ùbe niile. Ọ bụ afọ asaa ka ha ga-eji ha mere nkụ.
\v 10 Ha agaghị akpatakwa nkụ site nʼọhịa ọzọ, maọbụ gbuta ha site nʼoke ọhịa, nʼihi na ha ga-eji ngwa agha ndị a mere ihe ịfụnwu ọkụ. Mgbe ahụ, ha ga-akwata ihe onwunwe nke ndị ahụ kwakọrọ ihe onwunwe ha nʼagha, lụtakwa ihe onwunwe nke ndị ahụ lụnara ha ihe onwunwe ha nʼike. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\p 
\v 11 “ ‘Nʼụbọchị ahụ, aga m enye Gog ebe olili ya nʼIzrel, nʼime ndagwurugwu si ọwụwa anyanwụ gawa nʼụzọ oke osimiri. Ọ ga-anọchi ụzọ ndị ije nʼihi na ebe ahụ ka a ga-eli Gog na usuu ndị agha ya. Ya mere, a ga-akpọ ya Ndagwurugwu Hamọn Gog.
\p 
\v 12 “ ‘Ọnwa asaa ka ọ ga-ewe ndị Izrel ili ozu ahụ niile, ime ka ala ahụ dị ọcha.
\v 13 Ndị niile nke ala ahụ ga-eli ha, ụbọchị ahụ m ga-eme ka ebube m pụta ìhè ga-abụ ụbọchị ihe ncheta nye ha. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\v 14 A ga-ekewapụtakwa ndị ọrụ ha ga-abụ naanị ime ka ala ahụ dị ọcha. Ha ga-ejegharị nʼala ahụ niile, ha na ndị ọzọ, na-eli ozu ọbụla bụ ndị tọgbọrọ nʼala.
\p “ ‘Mgbe ọnwa asaa zuru, ha ga-edo anya chọgharịa nʼala ahụ ma o nwere ebe ozu ọzọ dị.
\v 15 Mgbe ahụ, ha na-ejegharị, ọ bụrụ na onye ọbụla achọta ọkpụkpụ mmadụ ọ ga-amanye ihe ịrịbama nʼakụkụ ya, ka ndị na-eli ozu hụ ha, kporokwa ha gaa na Ndagwurugwu Gog na ndị agha ya lie ha.
\v 16 Ọzọkwa, otu obodo aha ya bụ Hamona, nke pụtara ọtụtụ, ga-adị nʼebe ahụ. Otu a ka ha ga-esi mee ka ala ahụ dị ọcha.’
\p 
\v 17 “Nwa nke mmadụ, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, kpọọ ụmụ nnụnụ niile oku, na anụ ọhịa niile dị iche iche, sị ha, ‘Chịkọtaanụ onwe unu, site nʼakụkụ niile bịanụ nʼọchụchụ aja m, nke mụ onwe m na-achụ nʼihi unu, bụ aja dị ukwuu nke m na-achụ nʼelu ugwu niile dị nʼIzrel. Nʼebe ahụ ka unu ga-anọ taa anụ, ṅụọkwa ọbara.
\v 18 Anụ ahụ ndị dị ike ka unu ga-eri, ọ bụkwa ọbara ndịisi niile nke ụwa ka unu ga-aṅụ, dịka a ga-asị na ha bụ ebule na ụmụ atụrụ, na mkpi, na oke ehi, anụ mara abụba nke si na Bashan.
\v 19 Unu ga-erijukwa abụba afọ, ṅụbigakwa ọbara oke ruo mgbe ọ ga-ebu unu, site nʼaja mmemme nke m na-achụ nʼihi unu.
\v 20 Afọ anụ ịnyịnya, na ụgbọala, na nke ndị dike, na nke ndị agha niile ga-eju unu na tebul m.’ Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.
\p 
\v 21 “Mgbe ahụ, aga m egosi ebube m na nsọpụrụ m nʼetiti mba niile dị iche iche. Mba niile ga-ahụkwa ahụhụ nke m tara ha, na aka m nke m tụkwasịrị ha.
\v 22 Site nʼụbọchị ahụ gaa nʼihu, ụlọ Izrel ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke ha.
\v 23 Mba niile ga-amatakwa na ọ bụ nʼihi mmehie ka e ji dọta Izrel nʼagha, buru ha jee mba dị iche iche. Ha ga-amata na ihe dị otu a dakwasịrị ha nʼihi ekwesighị ntụkwasị obi ha. Ọ bụ nʼihi ya ka m ji zoo ihu m site nʼebe ha nọ, were ha nyefee nʼaka ndị iro ha. Ha niile dakwara site na mma agha.
\v 24 Atara m ha ahụhụ dịka adịghị ọcha ha na ajọ omume ha si dị. Ezokwara m ihu m site nʼebe ha nọ.
\p 
\v 25 “Nʼihi ya, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, Aga m eme ka Jekọb a dọtara nʼagha lọta. Aga m enwekwa obi ebere nʼahụ ndị Izrel niile. Aga m esitekwa nʼekworo mee ka aha m dịgide nsọ.
\v 26 Ha ga-echezọkwa ihe ihere ha, na-ekwesighị ntụkwasị obi ha niile, nke ha gosiri m, mgbe ha biri nʼudo nʼala ha, na-enweghị onye na-eme ka ha tụọ egwu.
\v 27 Mgbe m mere ka ha site na mba dị iche iche pụta, mgbe m sitere nʼala niile nke ndị iro ha kpọpụta ha, aga m esite na ha gosi ịdị nsọ m nye mba dị iche iche.
\v 28 Mgbe ahụ, ha ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke ha. Ha ga-amata na ọ bụ ezie na ọ bụ m mere ka a dọta ha nʼagha buru ha jee mba dị iche iche, na m ga-achịkọta ha mee ka ha lọghachi nʼala nke aka ha. Ọ dịkwaghị onye a ga-ahapụ na mba ọzọ.
\v 29 Agaghị m ezokwa ihu m ọzọ nʼebe ha nọ, nʼihi na aga m awụkwasị ụlọ Izrel Mmụọ m. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.”
\c 40
\s1 Ụlọnsọ ukwu ọhụrụ
\p 
\v 1 Nʼafọ nke iri abụọ na ise nke e mere ka anyị biri na mba ọzọ, na mbido afọ ahụ, nʼụbọchị nke iri, nke ọnwa ahụ nʼafọ nke iri na anọ site na mgbe obodo ahụ dara, nʼotu ụbọchị ahụ ka aka \nd Onyenwe anyị\nd* dịkwasịrị m nʼahụ. O mere ka m bịa nʼebe ahụ.
\v 2 Nʼọhụ dị iche iche Chineke mere ka m hụ, o buuru m gaa nʼala Izrel, debe m nʼelu ugwu dị elu nke ukwu, ebe m nọ hụ ihe dịka obodo a na-ewu ọhụrụ, nke dị nʼakụkụ ndịda ugwu ahụ.
\v 3 O mere ka m bịaruo nʼebe ahụ, ma lee, ahụrụ m otu nwoke nke ụdịdị ya na-enwu dịka bronz ka o guzo nʼakụkụ ọnụ ụzọ ama. Ọ na-ejide eriri akwa ọcha, na osisi e ji atụ ihe nʼaka ya.
\v 4 Nwoke ahụ sịrị m, “Nwa nke mmadụ, lezie anya nke ọma, gekwaa ntị tinyekwa ihe niile m gaje igosi gị nʼobi, nʼihi na-akpọtara m gị nʼebe a nʼihi ka ịhụ ihe ndị a. Gwakwa ụmụ Izrel ihe niile ị hụrụ.”
\s2 Ọnụ ụzọ ama nke ọwụwa anyanwụ na ogige dị na mpụta
\p 
\v 5 Mgbe ahụ, ahụrụ m mgbidi gbara ụlọnsọ ahụ gburugburu. Ịdị ogologo nke osisi ihe ọtụtụ nke dị nʼaka nwoke ahụ, ruru mita atọ na ụma abụọ, nke ọbụla nʼime ha ruru iri sentimita ise na atọ.\f + \fr 40:5 \ft Maọbụ, \fqa iri sentimita anọ na ise nakwa otu ntu-aka\f* Ọ tụrụ mgbidi ahụ, chọpụta na ịla elu ya dị mita atọ na ọkara. Ịsa mbara ya dịkwa mita atọ na ọkara.
\p 
\v 6 Emesịa, ọ gara nʼọnụ ụzọ ahụ chere ihu nʼọwụwa anyanwụ, rigoro nʼihe nrigo elu, tụọ ala ala ụzọ mbata nke ọnụ ụzọ ahụ. Obosara ya dị mita atọ na ọkara.
\v 7 Oghere dị nʼụlọ ahụ nke bụ ebe ndị nche na-anọ dị mita atọ nʼọkara nʼobosara. Mgbidi dị nʼetiti ha dị mita abụọ na ụma asaa nʼigbidi. Ebe e si abata na mpụta ọnụ ụzọ ama nke chere ụlọnsọ ukwu ahụ ihu, dị mita atọ nʼọkara nʼomimi.
\p 
\v 8 O jikwa ihe ọtụtụ tụọ ebe mpụta ọnụ ụlọ nke ọnụ ụzọ ama,
\v 9 ọ dị mita anọ na ụma abụọ nʼomimi. Ogidi dị nʼakụkụ ya dị otu mita nʼigbidi. Ebe mpụta ọnụ ụlọ nke ụzọ ama ya chere ihu nʼụlọnsọ ukwu.
\p 
\v 10 Nʼime ọnụ ụzọ ama nke ọwụwa anyanwụ, e nwere oghere atọ dị nʼakụkụ ọbụla, oghere atọ ndị ahụ ha nʼotu. Ihu akụkụ aja ya niile nke chere ha ihu bụkwa otu nʼọtụtụ.
\v 11 Mgbe ahụ, ọ tụrụ obosara nke mbata ọnụ ụzọ ama ahụ, ọ dị mita ise na ụma atọ nʼobosara, na mita isii na ụma itoolu nʼogologo.
\v 12 Nʼihu oghere niile nke ụlọ ahụ e nwere mgbidi dị otu ọkara mita nʼịdị elu ya. Akụkụ anọ nke oghere ndị a ha otu. Ha ruru mita atọ mita atọ.
\v 13 Mgbe ahụ, ọ tụrụ obosara ọnụ ụzọ ama ahụ, site nʼelu ụlọ nke otu ime ụlọ ruo nʼelu ụlọ nke ime ụlọ chere ya ihu; obosara ya dị mita iri na atọ, site nʼotu oghere ruo nʼoghere nke chere ya ihu.
\v 14 Ọ tụrụ ogologo ogidi niile dị nʼakụkụ nʼime mgbidi ọnụ ụzọ ama ụlọ ahụ, chọpụta na ọ dị iri mita atọ na abụọ, ọ bụladị ruo nʼakụkụ mgbidi nke chere ihu nʼọnụ ụzọ ama ogige ahụ.
\v 15 Site nʼihu ọnụ ụzọ ama mbata ahụ, ruo nʼebe ngwụcha nke ọnụ ụzọ dị na mpụta ọnụ ụlọ ya dị iri mita abụọ na asaa.
\v 16 Ọnụ ụlọ ndị ahụ niile nwere oghereikuku dị warawara nʼakụkụ aja ụlọ ha, dịka mpụta ọnụ ụlọ ahụ nwekwara; oghereikuku ndị a dị gburugburu dị nʼime, nʼetiti ọnụ ụlọ ndị a. Nʼaja ụlọ ndị a niile, e nwere oyiyi nkwụ dị iche iche e sere nʼelu ha.
\s2 Ogige dị nʼezi
\p 
\v 17 Ọ kpọbatara m nʼogige dị nʼezi. Nʼebe ahụ, ahụrụ m ụfọdụ ọnụụlọ dị na pevumentị e wunyere gburugburu ogige ahụ niile. Ha dị iri ọnụụlọ atọ dị nʼogologo pevumentị ahụ.
\v 18 Ebe nzọkwasị ụkwụ a gara ogologo ruo nʼakụkụ ọnụ ụzọ ama, ogologo ya na ọnụ ụzọ ama ahụ ha, nke a bụ pevumentị nke dịkarịrị ala.
\v 19 Mgbe ahụ, ọ tụrụ ịdị ogologo ya, site nʼime ọnụ ụzọ ama nke dịkarịrị ala ruo nʼọnụ ụzọ nke ime ogige, o ruru iri mita ise na atọ nʼakụkụ ihu anyanwụ nakwa nʼakụkụ ugwu.
\s2 Ọnụ ụzọ mbata dị nʼugwu
\p 
\v 20 Ọ tụrụ ogologo na obosara ọnụ ụzọ nke dị nʼugwu, nke e si abanye nʼogige dị nʼezi.
\v 21 Ime ụlọ ya dị ọnụ ụlọ atọ nʼakụkụ ya ọbụla. Akụkụ aja na mpụta ọnụ ụlọ ya, bụ otu ọtụtụ dịka ọtụtụ nke ọnụ ụzọ ama mbụ. Ịdị ogologo ya dị iri mita abụọ na asaa, ebe obosara ya dị mita iri na atọ.
\v 22 Oghereikuku ya, mpụta ọnụ ụzọ ya na osisi nkwụ e sere nʼahụ aja ụlọ ahụ niile, dịka e mere nʼakụkụ ọnụ ụzọ ama nke na-eche ihu nʼọwụwa anyanwụ, bụ otu ọtụtụ. Ihe nrigo nwere nzọ ụkwụ asaa dị nke e si aga na mpụta ọnụ ụlọ ahụ na ncherita ihu ogige ezi.
\v 23 Otu ọnụ ụzọ dị nke gara nʼogige dị nʼime, nke chere ihu ọnụ ụzọ mbata dị nʼugwu, dịka ọ dịkwa nʼakụkụ nke ọwụwa anyanwụ. Ọ tụrụ site nʼotu ọnụ ụzọ ama ruo na nke chere ya ihu, ọ dị iri mita ise na anọ.
\s2 Ọnụ ụzọ mbata dị na ndịda
\p 
\v 24 Mgbe ahụ, o duuru m gaa nʼakụkụ ndịda, a hụrụ m ọnụ ụzọ mbata ndịda. Ọ tụrụ tụọ akụkụ ogidi ọnụ ụzọ ahụ na mpụta ọnụ ụlọ ya, chọpụta na ya na ndị ọzọ bụ otu ọtụtụ.
\v 25 Ọnụ ụzọ ama ya na mpụta ọnụ ụlọ ya nwere oghereikuku dị warawara gbaa gburugburu, dịka e nwere na ndị ọzọ niile. Ịdị ogologo ya dị iri mita abụọ na asaa, ebe obosara ya dị mita iri na atọ
\v 26 Ihe nrigo nwere nzọ ụkwụ asaa dịkwa iji rigoo ya, mpụta ọnụ ụlọ ya dịkwa na ncherita ihu ha, o nwekwara ihe ịchọ mma osisi nkwụ e sere nʼahụ akụkụ aja ahụ, otu nʼotu akụkụ, nke ọzọ nʼakụkụ nke ọzọ.
\v 27 Ogige nke dị nʼime, nwekwara ọnụ ụzọ ama nke na-echere ihu na ndịda. Ọ tụrụ site nʼotu ọnụ ụzọ ama ruo na nke chere ya ihu, ọ dị iri mita ise na anọ.
\s2 Ụzọ ndị na-eduba nʼogige ime
\p 
\v 28 O duuru m site nʼọnụ ụzọ dị na ndịda banye nʼogige dị nʼime. Ọ tụrụ ọnụ ụzọ mbata a hụ na ya na ọnụ ụzọ nke dị ọzọ bụ otu ọtụtụ.
\v 29 Nʼọnụ ụlọ ya niile, nʼakụkụ aja ya niile, na mpụta ọnụ ụlọ ya bụkwa otu ọtụtụ dịka ndị ọzọ niile. Ọnụ ụzọ ama ya na mpụta ọnụ ụlọ ya nwere oghere gbaa gburugburu. Ịdị ogologo ya dị iri mita abụọ na asaa, ebe obosara ya dị mita iri na atọ.
\v 30 Mpụta ọnụ ụlọ nke ndị dị gburugburu ogige nke ime, dị iri mita na atọ nʼobosara, na mita abụọ na ụma atọ nʼịdị omimi.
\v 31 Mpụta ọnụ ụlọ ya chere ihu nʼogige dị nʼezi, oyiyi osisi nkwụ ka eji chọọ ogidi ọnụ ụlọ ahụ mma, ihe nrigo nwere nzọ ụkwụ asatọ ka eji arịgo ya.
\s1 Ogige ime na ọnụ ụzọ mbata ọwụwa anyanwụ
\p 
\v 32 Ọ kpọbatakwara m nʼogige dị nʼime site nʼọnụ ụzọ mbata nke ọwụwa anyanwụ. Ọ tụkwara ọnụ ụzọ ama ahụ, chọpụta na ya na ndị ọzọ bụkwa otu ọtụtụ.
\v 33 Nʼọnụ ụlọ ya niile, nʼakụkụ aja ya niile, na mpụta ọnụ ụlọ ya niile bụkwa otu ọtụtụ dịka ndị ọzọ niile. Ọnụ ụzọ ama ya na mpụta ọnụ ụlọ ya nwere oghere gbaa gburugburu. Ịdị ogologo ya dị iri mita abụọ na asaa, ebe obosara ya dị mita iri na atọ.
\v 34 Mpụta ọnụ ụlọ ya chere ihu nʼogige dị nʼezi. Oyiyi nkwụ e sere ese ka eji chọọ akụkụ ogidi ọnụ ụzọ ya mma, nʼakụkụ nke a, nakwa nʼakụkụ nke ọzọ. Ihe nrigo nwere nzọ ụkwụ asatọ ka eji arịgo ya.
\p 
\v 35 O mere ka m bịaruo nʼọnụ ụzọ ama mbata nke ugwu. Ọ tụrụ ya, chọpụta na ọtụtụ ya dịkwa ka nke ndị ọzọ,
\v 36 dịka ọnụ ụlọ ya niile, nʼakụkụ aja ya niile, na mpụta ọnụ ụlọ ya, ha niile nwere oghere gbaa gburugburu. Ịdị ogologo ya dị iri mita abụọ na asaa, ebe obosara ya dị mita iri na atọ
\v 37 Mpụta ọnụ ụlọ ya chere ihu nʼogige dị nʼezi. Oyiyi nkwụ e sere ese ka eji chọọ akụkụ ogidi ọnụ ụzọ ya mma, nʼakụkụ nke a, nakwa nʼakụkụ nke ọzọ. Ihe nrigo nwere nzọ ụkwụ asatọ ka eji arịgo ya.
\s2 Ọnụụlọ dị iche iche ebe ikwado aja
\p 
\v 38 Otu ọnụụlọ nke nwere ọnụ ụzọ dịkwa nʼakụkụ mpụta ọnụ ụlọ nke ime ime ọnụ ụzọ ama ọbụla, ebe a na anọ asacha anụ aja nsure ọkụ niile.
\v 39 Nʼime mpụta ọnụ ụlọ nke ọnụ ụzọ ama, ka tebul abụọ dị nʼotu akụkụ, abụọ nke ọzọ dịkwa nʼakụkụ nke ọzọ nke ọnụ ụlọ ahụ. Nʼelu ha ka a na-egbu anụ e ji achụ aja nsure ọkụ, maọbụ aja mmehie, maọbụ onyinye nʼihi aja ikpe ọmụma.
\v 40 Nʼakụkụ mgbidi ezi nke mpụta ọnụ ụlọ nke ọnụ ụzọ ama, nʼakụkụ ihe nrigo nke dị na mbata ọnụ ụzọ ugwu, e nwere tebul abụọ, nʼakụkụ nke ọzọkwa nke ihe nrigo ahụ, e nwekwara tebul abụọ nʼebe ahụ.
\v 41 Ya mere, e nwere tebul anọ nʼotu akụkụ ihe nrigo ahụ, nwekwa anọ nʼakụkụ nke ọzọ ya, ya bụ, tebul asatọ ma agụkọta ya ọnụ, ebe a na-anọ egbu anụ e ji achụ aja.
\v 42 E nwekwara tebul anọ ndị ọzọ nʼime ọnụ ụlọ ahụ e ji nkume a wara awa wuo. Nʼelu ya ka a na-anọ akwado anụ a ga-eji chụọ aja nsure ọkụ. Ịdị elu tebul ndị a bụ iri sentimita asatọ. Obosara elu ha nʼakụkụ niile dị iri sentimita ise na atọ. Ngwongwo niile e ji egbu anụ e ji achụ aja na-adị nʼelu tebul ndị a.
\v 43 E ji nko nke ịdị ogologo ya dị sentimita itoolu ejigidesi tebul ndị ahụ ike nʼahụ aja ụlọ. Nko ndị a dị gburugburu tebul ndị ahụ. Ọ bụkwa nʼelu tebul ndị a ka a na-edebe anụ niile e ji enye onyinye.
\s2 Ọnụ ụlọ ndị nchụaja
\p 
\v 44 Nʼime ogige dị nʼime, e nwere ọnụụlọ abụọ nke nwere ụzọ e si abanye nʼogige dị nʼime. Otu dị nʼakụkụ ọnụ ụzọ ama dị nʼugwu, chee ihu nʼọdịda anyanwụ, nke ọzọ dị nʼakụkụ ọnụ ụzọ ama dị nʼọdịda anyanwụ, chee ihu nʼugwu.
\v 45 Ọ gwara m, “Ọnụụlọ ahụ dị nʼakụkụ ọnụ ụzọ ama dị nʼugwu bụ nke ndị nchụaja, ndị na-eje ozi nʼụlọnsọ ukwu.
\v 46 Ọnụụlọ nke dị nʼakụkụ ọnụ ụzọ ama chere ihu nʼugwu, bụ nke ndị nchụaja ndị na-eche ebe ịchụ aja nche. Ndị a bụ ụmụ ụmụ Zadọk. Ọ bụ naanị ha ka e kwere ka ha nwee ike ịbịaru \nd Onyenwe anyị\nd* nso, ijere ya ozi site nʼetiti ebo Livayị niile.”
\p 
\v 47 Mgbe ahụ, ọ tụrụ ogige ime ahụ, chọpụta na ogologo ya dị iri mita ise na asatọ. Obosara ya bụkwa otu ihe ahụ. Ebe ịchụ aja dịkwa nʼihu ụlọnsọ ukwu ahụ.
\s1 Ụlọnsọ ukwu ọhụrụ ahụ
\p 
\v 48 O mere ka m bịaruo na mpụta ọnụ ụlọ nke ụlọnsọ ukwu ahụ, ọ tụrụ akụkụ ogidi ọnụ ụzọ nke mpụta ọnụ ụlọ ahụ, o ruru mita abụọ na ụma atọ nʼobosara, nʼakụkụ ya abụọ. Ebe mbata ya ruru mita asaa na ụma anọ nʼobosara, ebe akụkụ aja ụlọ ahụ ruru otu mita na ụma isii nʼobosara, nʼotu akụkụ nakwa nʼakụkụ nke ọzọ ya.
\v 49 Ebe mpụta ọnụ ụlọ ahụ dị ihe ruru mita iri na otu nʼobosara, sitekwa nʼazụ ruo nʼihu ya ruru mita isii na ụma anọ. Ọ bụ ihe nrigo iri ka eji arịgo ya. Ogidi dịkwa nʼakụkụ ọnụ ụzọ abụọ ahụ otu nʼakụkụ nke a ọzọ nʼakụkụ nke ọzọ ya.
\c 41
\p 
\v 1 Mgbe ahụ, nwoke ahụ kpọbatara m nʼọnụ ụlọ ezumezu ahụ, ọ tụrụ akụkụ ọnụ ụzọ ya. Akụkụ ya ọbụla dị mita atọ na ụma abụọ, nke a bụ obosara ụlọ ikwu ahụ.
\v 2 Obosara ọnụ ụzọ mbata ya dị mita ise na ụma atọ. Akụkụ aja abụọ nke ọnụ ụzọ ahụ dịkwa mita abụọ na ụma asaa. Ọ tụkwara ogologo ụlọ ezumezu ahụ; ya dịrị iri mita abụọ na otu nʼogologo, obosara ya dị mita iri na otu.
\p 
\v 3 Mgbe ahụ, ọ banyere nʼime ime ebe nsọ ahụ, tụọ ogidi dị nʼọnụ ụzọ e si abanye nʼime ya, chọpụta na obosara nke ọbụla bụ otu mita na otu ụma, obosara ọnụ ụzọ ahụ nʼonwe ya dị mita atọ na ụma abụọ. Akụkụ aja nke ọnụ ụzọ ọbụla dị mita atọ na ụma asaa nʼobosara.
\v 4 Ọ tụrụ ogologo ime ebe nsọ ahụ, ya dị mita iri na ọkara, obosara ya dịkwa mita iri na ọkara, nʼogologo ụlọ ezumezu ahụ. Ma ọ sịrị m, “Ebe a bụ Ebe Kachasị Nsọ.”
\p 
\v 5 Ọ tụkwara mgbidi ụlọnsọ ukwu ahụ chọpụta na ịdị igbidi ya bụ mita atọ na ụma abụọ. E nwekwara ọnụụlọ ndị dị gburugburu ụlọnsọ ukwu ahụ, nke ọbụla dị mita abụọ na otu ụma nʼigbidi.
\v 6 Ọnụụlọ nta ndị a dị nʼokpukpu atọ, nke ọbụla nʼelu ibe ya, okpukpu ọbụla nwere iri ọnụụlọ atọ. E nwere mgbidi gbara aja ụlọnsọ ahụ gburugburu nʼakụkụ niile, ka ha bụrụ ihe nkwado nye ọnụụlọ nta ndị a, ka ihe nkwado ndị a ghara ịbụ ihe a rụnyere nʼaja ụlọnsọ ukwu ahụ.
\v 7 E wuru ọnụụlọ nta ndị a ka obosara ọnụụlọ ndị ahụ niile dị nʼelu ibe ha dị ukwuu karịa obosara ndị nke dị nʼokpuru ha. Nʼụzọ dị otu a, obosara ọnụụlọ niile dị nʼokpukpu nke abụọ dị ukwuu karịa nke dị nʼala; nke atọ dịkwa ukwuu karịa nke abụọ. E wukwara ebe e si arịgo site nʼokpukpu nke dịkarịsịrị ala rigoruo nʼọnụụlọ ndị kachasị elu, site nʼokpukpu nke dị nʼetiti.
\p 
\v 8 Ahụrụ m na ụlọnsọ ukwu ahụ nwere ebe e wuliri elu nʼakụkụ ya niile. Ọ bụkwa ebe a dị elu ka e ji mee ntọala ọnụụlọ nta ndị ahụ niile. Ịdị ogologo nke ebe ahụ e wuliri elu bụ mita atọ na ụma abụọ.
\v 9 Ịdị arọ nke mgbidi ọnụụlọ nta ndị a nʼakụkụ ezi bụ mita abụọ na ụma atọ. Ala tọgbọrọ nʼefu nʼetiti ọnụụlọ nta ụlọnsọ ukwu ahụ,
\v 10 na ọnụụlọ ndị nchụaja dị mita iri na ọkara nʼobosara, gbaa gburugburu ụlọnsọ ukwu ahụ.
\v 11 E nwere ọnụ ụzọ ndị a na-esi abanye nʼọnụụlọ nta ndị ahụ, site nʼala ahụ na-enweghị ihe arụrụ na ya, otu ọnụ ụzọ nʼakụkụ ugwu, nke ọzọ nʼakụkụ ndịda. Obosara ala nke fọdụrụ dị mita abụọ na ụma atọ nʼakụkụ niile gbaa gburugburu.
\p 
\v 12 Ma ụlọ nke na-eche ihu nʼogige ụlọnsọ ukwu ahụ, nʼakụkụ ọdịda anyanwụ, dị iri mita atọ na asaa nʼobosara, ịdị igbidi nke aja ụlọ ahụ dị mita abụọ na ụma atọ, gbaa gburugburu, ogologo ya dịkwa iri mita anọ na asatọ.
\p 
\v 13 Mgbe ahụ, ọ tụrụ ụlọnsọ ukwu ahụ, ya dịrị iri mita ise na atọ, ogige ụlọnsọ, na ụlọ ahụ nakwa mgbidi ya, dịkwa iri mita ise na atọ nʼogologo.
\v 14 Obosara nke ogige ụlọnsọ nʼakụkụ ọwụwa anyanwụ, tinyere ebe ihu ụlọnsọ ukwu ahụ, dị iri mita ise na atọ.
\p 
\v 15 Ọ tụrụ ịdị ogologo nke ụlọ ahụ chere ihu nʼogige dị nʼazụ ụlọnsọ ukwu ahụ, tinyere ebe njegharị ya nke dị nʼakụkụ abụọ ya. Ọ dị iri mita ise na atọ.
\p Ụlọ ezumezu ahụ, nʼime ebe nsọ ahụ, na mpụta nke ọnụ ụlọ, bụ nke chere ihu nʼogige ahụ,
\v 16 ya na ọnụ ụzọ ndị ahụ, na oghereikuku niile dị warawara, na ebe njegharị gbara ha atọ gburugburu, ihe niile, elu ma ala, tinyere ọnụ ụzọ bụ nke eji osisi mmachite. Ala ya, na mgbidi ya ruo na oghereikuku, ma oghereikuku niile bụkwa ihe ekpuchiri ekpuchi.
\v 17 Nʼelu oghere dị nʼebe ọnụ ụzọ ezi, nke gara nʼime ebe nsọ, nakwa nʼahụ aja niile, na nkebi na nkebi, gbaa gburugburu nʼime na nʼezi ebe nsọ ahụ,
\v 18 ka a tụrụ oyiyi cherubim na osisi nkwụ. Cherubim na-esota osisi nkwụ. Osisi nkwụ ọbụla na-esotakwa cherubim. Cherub ọbụla nwere ihu abụọ:
\v 19 otu akụkụ cherub nke bụ ihu mmadụ chere ihu nʼotu nkwụ. Ihu ya nke ọzọ, nke bụ ihu ọdụm, chere ihu na nkwụ nke dị akụkụ nke ọzọ. A tụrụ ha gburugburu ụlọnsọ ukwu ahụ.
\v 20 Site nʼala ụlọ ruo nʼelu ọnụ ụzọ ya, a tụrụ oyiyi cherubim na osisi nkwụ nʼahụ aja ụlọ ezumezu ahụ.
\p 
\v 21 Ọnụ ụlọ ezumezu ahụ nwere mbudo ibo nke akụkụ anọ ya ha otu nʼọtụtụ. Nke dị nʼihu Ebe ahụ Kachasị Nsọ, yiri ndị ọzọ.
\v 22 Ebe ịchụ aja ya bụ nke eji osisi wuo. Akụkụ niile nke ebe ịchụ aja a ha nʼotu. Ọ dị otu mita na ọkara nʼogologo, dịrịkwa iri sentimita itoolu nʼakụkụ ya ọbụla. Osisi ka e ji wuo nkuku anọ ya, akụkụ ya niile, na ntọala ya. Mgbe ahụ, nwoke ahụ gwara m, “Nke a bụ tebul na-adị nʼihu \nd Onyenwe anyị\nd*.”
\v 23 Ma ụlọ ezumezu, ma Ebe ahụ Kachasị Nsọ, nwere ọnụ ụzọ abụọ, nʼotu nʼotu.
\v 24 Ọnụ ụzọ ọbụla nwere ibo abụọ, ibo abụọ nke a na-akwagharị gburugburu.
\v 25 A tụnyere onyinyo cherubim na osisi nkwụ nʼelu ibo na-edubanye nʼụlọ ezumezu ahụ, dịka ndị ahụ a tụrụ nʼahụ mgbidi niile. E jikwa osisi rụchie elu ihu mpụta nke ọnụ ụlọ ahụ.
\v 26 Windo\f + \fr 41:26 \ft Ya bụ, oghereikuku\f* dị warawara dị nʼaja mpụta ọnụ ụlọ ahụ, nke e sekwasịrị oyiyi osisi nkwụ; ọnụụlọ nta niile nke ụlọnsọ ukwu ahụ nwekwara ihe a rụnyere nʼelu ụzọ ya, nke a machiri amachi.
\c 42
\s1 Ọnụụlọ ndị nchụaja
\p 
\v 1 Nwoke ahụ duuru m gaa nʼakụkụ ugwu, banye nʼime ogige ahụ dị nʼezi, kpọbata m nʼime ọnụụlọ ndị ahụ dị na ncherita ihu nʼakụkụ ugwu nke ụlọnsọ ukwu ahụ.
\v 2 Ụlọ ahụ nke ọnụ ụzọ ya chere ihu nʼebe ugwu dị iri mita ise na atọ nʼogologo, ebe obosara ya dị iri mita abụọ na asaa.
\v 3 Ma nʼakụkụ nke dị iri mita na otu, site nʼime ogige nakwa nʼakụkụ nke dị na ncherita ihu pevumentị nke ogige dị nʼezi, ebe njegharị chere ebe njegharị ọzọ ihu, nʼokpukpu atọ ahụ.
\v 4 Nʼihu ọnụụlọ ndị a, e nwere ka ụzọ njegharị nke dị mita ise na ụma atọ nʼobosara, dịkwa iri mita ise na atọ nʼogologo. Ọnụ ụzọ ha niile chere ihu nʼugwu.
\v 5 Okpukpu ụlọ nke dị nʼelu asaghị mbara dịka nke dị nʼala, nʼihi na ebe njegharị ndị ahụ weere ọtụtụ oghere karịa ka ọ dị nʼọnụụlọ ndị dị okpukpu nke dị nʼala na nke etiti ụlọ ahụ.
\v 6 Ebe a na-ejighị ogidi wuo ụlọ a, dịka e si wuo ndị dị nʼogige, nke a mere ka ụlọ ndị dị nʼelu na-akpa nkpa karịa ndị nke dị nʼala, na ndị dị nʼetiti.
\v 7 E nwere mgbidi aja nke dị nʼezi nʼakụkụ ọnụụlọ niile, nʼụzọ ogige nke dị nʼezi. Ọ mapụtara nʼihu ọnụụlọ ndị ahụ, ogologo ihe dị iri mita abụọ na asaa.
\v 8 Nʼọtụtụ ogologo ọnụụlọ ndị a, ndị dị nso nʼogige mpụta, ruru mita iri abụọ na itoolu, ebe ogologo ndị nke dịkarịsịrị nso ebe nsọ ahụ, ruru mita iri ise na asatọ.
\v 9 Nʼokpuru ọnụụlọ ndị a, e nwere ụzọ mbata nʼakụkụ ọwụwa anyanwụ, dịka mmadụ na-abata ha site nʼogige dị na mpụta.
\p 
\v 10 Nʼakụkụ ndịda, nʼogologo aja ụlọ dị nʼogige mpụta, nke dị nʼakụkụ ogige ụlọnsọ ukwu, nke chere aja ụlọ mpụta ihu, ọtụtụ ọnụụlọ dị ya.
\v 11 Ụzọ njegharị dị nʼetiti akụkụ abụọ ụlọ ahụ, ha dịkwa ka ọnụụlọ ndị ahụ nke dị nʼụzọ ugwu. Ogologo ha na obosara ha bụ otu; ha niile yiri onwe ha. Ọnụ ụzọ ya dịkwa ka ọnụ ụzọ dị nʼugwu.
\v 12 Otu a ka ọnụ ụzọ e si abanye nʼime ọnụụlọ ndị a dị na ndịda si dị. E nwere ọnụ ụzọ na mpụta, nke dị na mgbidi ahụ chere ihu nʼọwụwa anyanwụ. Ebe a ka e si abanye nʼime ọnụụlọ ndị ahụ.
\p 
\v 13 Mgbe ahụ, ọ sịrị m, “Ime ọnụụlọ niile dị nʼugwu, na ime ọnụụlọ ndị dị na ndịda, bụ ndị a chere ogige ụlọnsọ ahụ ihu, bụ ime ụlọ dị nsọ, nke ndị nchụaja. Ebe ndị nchụaja ndị na-abịa nso \nd Onyenwe anyị\nd* ịchụ aja ga-anọ rie nri niile nke kachasị nsọ, nʼebe ahụ ka ha ga-edebekwa aja ịnata ihuọma, aja mmehie na aja ikpe ọmụma, nʼihi na ụlọ ndị a dị nsọ.
\v 14 Mgbe ndị nchụaja bara nʼime ebe nsọ ahụ nke e kewapụrụ iche, ha aghaghị esikwa nʼebe ahụ pụta nʼogige mpụta ezi, tupu ruo mgbe ha yisara uwe ha yii jee ozi, nʼihi na uwe ndị a dị nsọ. Ha ga-eyiri uwe ọzọ, tupu ha abanye nʼakụkụ ụlọ ndị ahụ dịịrị ndị ọzọ.”
\p 
\v 15 Mgbe ọ tụchara ihe ndị dị nʼime ebe ụlọnsọ ahụ, o duuru m site nʼọnụ ụzọ dị nʼọwụwa anyanwụ pụta, tụkwaa nʼakụkụ niile gburugburu.
\v 16 O ji ihe ọtụtụ dị ogologo tụọ akụkụ ọwụwa anyanwụ, ọ dị ihe ruru narị mita abụọ na iri mita isii na ise.
\v 17 O ji mkpirisi osisi ahụ e ji atụ ihe tụọ akụkụ nke ugwu ma chọpụta na ọ dị ihe ruru narị mita abụọ na iri mita isii na ise.
\v 18 Ọ tụkwara akụkụ nke ndịda, chọpụtakwa na ọ dị ihe ruru narị mita abụọ na iri mita isii na ise.
\v 19 Mgbe ahụ, ọ tụgharịrị jirikwa ihe ọtụtụ ahụ tụọkwa akụkụ nke ọdịda anyanwụ. Ọ dị ihe ruru narị mita abụọ na iri mita isii na ise.
\v 20 Ya mere, ọ tụrụ akụkụ anọ niile nke ebe ahụ. Mgbidi gbara ya gburugburu. Ọtụtụ ha dị ihe ruru narị mita abụọ na iri mita isii na ise, nʼogologo, obosara ya dịkwa ihe ruru narị mita abụọ na iri mita isii na ise, iji kewapụta ebe dị nsọ site nʼebe ndị ọzọ.
\c 43
\s1 Nlọghachi nke ebube Chineke
\p 
\v 1 Emesịa, ọ kpọbatakwara m nʼọnụ ụzọ mbata nke chere ihu nʼọwụwa anyanwụ.
\v 2 Ma lee, ahụrụ m ebube Chineke nke Izrel ka o si nʼakụkụ ọwụwa anyanwụ na-apụta. Olu ya dị ka mbigbọ nke ebili mmiri, ebube ya nwukwara nʼala ahụ niile.
\v 3 Ọ dịkwa ka ọhụ mbụ m hụrụ, nke m buru ụzọ hụ nʼakụkụ ọnụ mmiri Keba, ya na nke m hụrụ na Jerusalem mgbe ọ bịara ibibi obodo ahụ. Adara m nʼala kpugide ihu m nʼaja.
\v 4 Ebube \nd Onyenwe anyị\nd* sitere nʼọnụ ụzọ chere ihu nʼọwụwa anyanwụ bata nʼime ụlọnsọ ahụ.
\v 5 Mgbe ahụ, Mmụọ nke Chineke buliri m bubata m nʼime ogige nke ime, ma ebube nke \nd Onyenwe anyị\nd* jupụtara nʼụlọnsọ ukwu ahụ.
\p 
\v 6 Mgbe ahụ, anụrụ m olu ka o si nʼụlọnsọ ahụ na-agwa m okwu, dịka nwoke ahụ na-eguzokwa nʼakụkụ m.
\v 7 Ọ sịrị m, “Nwa nke mmadụ, ebe a bụ ebe nke ocheeze, na ebe nke ọbụ ụkwụ m abụọ ga-anọgide, ebe a ka m ga-ebi nʼetiti ụmụ Izrel ruo mgbe ebighị ebi. Ụlọ Izrel agaghị emerụkwa aha nsọ m ọzọ, ha onwe ha maọbụ ndị eze ha, site nʼikpere arụsị niile ha na ibubata onyinye olili ozu ndị eze ha, mgbe ha nwụrụ anwụ.
\v 8 Mgbe ha wuru mbata ọnụ ụzọ ha nʼakụkụ mbata ọnụ ụzọ m, tinye ọnụ ụzọ ha nʼakụkụ ọnụ ụzọ m, ọ bụkwa naanị mgbidi bụ ihe dị nʼetiti mụ na ha. Ha merụrụ aha nsọ m site nʼihe arụ niile ha mere. Ya mere m ji bibie ha nʼiwe m.
\v 9 Ugbu a, ka ha wezuga adịghị ọcha na ife chi ndị ọzọ ha nʼihu m, bupụkwa onyinye olili ozu ndị eze ha nʼebe m nọ, mgbe ahụ, aga m ebi nʼetiti ha ruo mgbe ebighị ebi.
\p 
\v 10 “Nwa nke mmadụ, kọwaara ụmụ Izrel ụlọnsọ ahụ m ziri gị. Gwa ha ụdịdị ya, na ịpụ iche ya, ka ihere mee ha nʼihi mmehie ha.
\v 11 Ọ bụrụ nʼezie na ihere emee ha nʼihi ihe ha mere, mgbe ahụ, kọwaara ha ihe niile metụtara otu a ga-esi wuo ụlọnsọ a, na ihe gbasara nkwado ya, na ihe gbasara ọnụ ụzọ ọpụpụ na mbata ya niile, ihe metụtara ebumnobi nke owuwu ya niile na usoro na iwu niile banyere ya. Depụta ihe ndị a nʼihu ha, nye ha ka ha lezie anya mezuo ihe niile metụtara usoro a ga-agbaso wuo ya.
\p 
\v 12 “Nke a bụ iwu ụlọ banyere nsọ ukwu ahụ. Ebe niile gbara elu ugwu a gburugburu ga-abụ ebe dịkarịsịrị nsọ! Nke a bụ iwu ụlọnsọ ahụ.
\s1 Ebe ịchụ aja ukwu ahụ
\p 
\v 13 “Nke a bụ ọtụtụ niile gbasara ebe ịchụ aja ya: Ịdị elu nke ala ya bụ iri sentimita ise na atọ; ịgba gburugburu nke ọnụ ya bụ iri sentimita abụọ na atọ; obosara ya dị iri sentimita ise na atọ. Otu a ka ebe ịchụ aja ahụ ga-aha nʼogologo.
\v 14 Site nʼụkwụ ya nke dị nʼala ruo nʼokere ya nke etiti, ọ ga-adị otu mita nʼogologo nakwa nʼuhie; site nʼokere nke nta ruo na nke ukwu ga-adị mita abụọ nʼogologo na ọkara nʼuhie.
\v 15 Ebe nsure ọkụ nke ebe ịchụ aja ahụ ga-adị mita abụọ, mpi anọ sikwa nʼakụkụ ya gbagoo elu, nke ọbụla nʼime ha ga-adị ọkara mita nʼogologo.
\v 16 Ebe nsure ọkụ nke ebe ịchụ aja ahụ ga-adị mita isii nʼogologo na mita isii nʼuhie, nwee akụkụ anọ nke ha nʼotu.
\v 17 Nke dị nʼokpuru ga-adị mita asatọ nʼakụkụ ọbụla; a ga-arụlite ọnụ ọnụ ya gburugburu, ka ịdị elu nke ọnụ ọnụ ya bụrụ iri sentimita abụọ na asaa. Akụkụ ya niile gbasapụrụ site nʼelu ya ruo nʼala. Ọtụtụ mgbasapụ a dị iri sentimita ise na atọ. Nʼakụkụ ọwụwa anyanwụ ka ihe e ji arịgo ya dị.”
\p 
\v 18 Mgbe ahụ, ọ gwara m, “Nwa nke mmadụ, ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Ndị a bụ usoro metụtara iwu ịchụ aja nke aja nsure ọkụ, na ifesa ọbara nʼelu ebe ịchụ aja mgbe e wusiri ya.
\v 19 Ị ga-enye ndị nchụaja bụ ndị Livayị si nʼezinaụlọ Zadọk, bụ ndị na-abịa m nso ife ofufe nʼihu m, otu oke ehi maka aja mmehie, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\v 20 Unu ga-ewere ụfọdụ nʼọbara ya tee na mpi anọ nke ebe ịchụ aja, na nʼakụkụ anọ nke ebe ịchụ aja, na nʼakụkụ anọ nke mbadamba nkume dị nʼelu, na gburugburu ọnụ ọnụ ya, si otu a sachaa ebe ịchụ aja ahụ, kpuchikwaara ya mmehie.
\v 21 Mgbe ahụ, a ga-ewere nwa oke ehi e ji chụọ aja mmehie ahụ, kpọọ ya ọkụ nʼebe a kwadoro nʼezi ụlọnsọ ukwu ahụ.
\p 
\v 22 “Nʼụbọchị nke abụọ, ị ga-eji nwa mkpi na-enweghị ntụpọ chụọ aja mmehie.\f + \fr 43:22 \ft Nwa mkpi zuruoke bụ nke na-enweghị ntụpọ, nke ọrịa na-adịghị arịa, nke ọnya na-adịghị nʼahụ ya, na nke na-enweghịkwa apa.\f* A ga-eme ka ebe ịchụ aja dị ọcha, dịka e ji oke ehi ahụ mee ka ọ dị ọcha.
\v 23 Mgbe i mechara mmemme nsacha ndị a, werekwa nwa oke ehi ọzọ nke na-enweghị ntụpọ, na nwa ebule site nʼigwe anụ nke na-enweghị ntụpọ chụọ aja.
\v 24 Were ha jee chee nʼihu \nd Onyenwe anyị\nd*, ka ndị nchụaja were nnu fesa ha dịka aja nsure ọkụ a chụrụ nye \nd Onyenwe anyị\nd*.
\p 
\v 25 “Ụbọchị asaa, kwa ụbọchị ka ị ga-ewepụta otu mkpi, na nwa oke ehi, na nwa ebule site nʼigwe anụ ndị ahụ, chụọ aja mmehie. Ha niile ga-abụ ụmụ anụmanụ ndị na-enweghị ntụpọ.
\v 26 Ụbọchị asaa ka ha ga na-achụ aja ikpuchi mmehie nʼihi ebe ịchụ aja, mee ka ọ dị ọcha, site otu a doo ya nsọ.
\v 27 Ụbọchị nke asatọ, na nʼụbọchị ọbụla so ya, ndị nchụaja ga-achụ aja nsure ọkụ nʼebe ịchụ aja, chụọkwa aja udo. Mgbe ahụ, aga m anabatakwa unu. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.”
\c 44
\s1 Ụmụ eze, ndị Livayị, na ndị nchụaja
\p 
\v 1 Mgbe ahụ, o mere ka m laghachi nʼụzọ, nʼọnụ ụzọ ama nke ebe nsọ ahụ, nke dị nʼezi, nke na-eche ihu nʼọwụwa anyanwụ, ma a gbachiri ya agbachi.
\v 2 Ma \nd Onyenwe anyị\nd* sịrị m, “Ọnụ ụzọ ama nke a ga-abụ ihe e mechiri emechi. A gaghị emeghe ya ọzọ, ọ dịghị onye ọbụla ga-esi na ya bata. Nʼihi na \nd Onyenwe anyị\nd*, bụ Chineke Izrel esitela na ya bata. Ya mere, ọ bụ ihe emechiri emechi.
\v 3 Naanị nwa eze, naanị ya onwe ya, bụ onye ga-anọdụ ala nʼime ya, iri nri nʼihu \nd Onyenwe anyị\nd*. Ọ ga-esite na mpụta ọnụ ụlọ nke ọnụ ụzọ bata, ọ bụkwa ebe ahụ ka ọ ga-esi pụọ.”
\p 
\v 4 Mgbe ahụ, o mere ka m bịaruo nʼọnụ ụzọ ama dị nʼugwu, nʼihu ụlọnsọ ukwu ahụ. Elere m anya hụ na ebube nke \nd Onyenwe anyị\nd* jupụtara nʼụlọnsọ nke \nd Onyenwe anyị\nd*. Nʼihi ya, adara m nʼala kpugide ihu m nʼaja.
\p 
\v 5 \nd Onyenwe anyị\nd* sịrị m, “Nwa nke mmadụ, leruo anya nke ọma, gee ntị nke ọma nʼihe niile m na-agwa gị banyere iwu m niile na usoro niile nke ụlọnsọ ukwu nke \nd Onyenwe anyị\nd*. Leruo anya nke ọma banyere ọnụ ụzọ ịbata nʼụlọnsọ ukwu a, na nke ọpụpụ niile nke ebe nsọ a.
\v 6 Ị ga-agwa ndị Izrel bụ ndị ụlọ nnupu isi, ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị, o zuola bụ ibi ndụ arụ unu niile ahụ, unu ndị Izrel!
\v 7 Nʼihi na ọ bụghị naanị na ihe arụ unu mere dị ukwu, kama unu mekwara ihe arụ kachasị site nʼịkpọbata ndị ala ọzọ a na-ebighị anụ ahụ ha na obi ha ugwu nʼime ụlọnsọ, si otu a merụọ ụlọnsọ mgbe unu na-ewetara m nri nsọ, nke bụ abụba na ọbara. Nʼụzọ dị otu a, unu emebiela ọgbụgba ndụ m.
\v 8 Unu edebeghị iwu m nyere unu banyere ihe m ndị dị nsọ, kama unu goro ndị ọzọ ka ha bụrụ ndị na-elekọta ebe nsọ m.
\v 9 Ihe ndị a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, o nweghị onye ala ọzọ ọbụla a na-ebighị anụ ahụ ya na obi ya ugwu kwesiri ịbata nʼụlọnsọ m. Ọ bụladị ndị ọbịa ndị bi nʼetiti ụmụ Izrel.
\p 
\v 10 “ ‘Ndị ikom agbụrụ Livayị niile, ndị sitere nʼijere m ozi wezuga onwe ha mgbe Izrel bidoro ịgbaso arụsị niile ha, ga-ata ahụhụ nʼihi ekwesighị ntụkwasị obi ha.
\v 11 Ha ga-abụ ndị na-eje ozi nʼime ebe nsọ m, ndị nlekọta nke ọnụ ụzọ ama nke ụlọnsọ ukwuu, na-ejekwa ozi nʼime ya; ha ga-egburu ndị m anụ e wetara maka ịchụ aja nsure ọkụ na nke aja ndị ọzọ, ha ga-eguzokwa nʼihu ha jeere ha ozi.
\v 12 Ma nʼihi na ha guzoro nʼihu arụsị jeere ha ozi, mee ka ụlọ Izrel daba na mmehie ikpere arụsị,\f + \fr 44:12 \ft Ghọrọ ụlọ Izrel ihe ịsọ ngọngọ nke ajọ omume\f* nʼihi nke a, eweliela m aka elu na-aṅụ iyi na ha aghaghị ịta ahụhụ mmehie ha. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\v 13 Ha agaghị abịakwute m nso ije ozi dịka ndị nchụaja, maọbụ bịaruo nso ihe nsọ m niile ọbụla maọbụ onyinye m dị nsọ karịchasịa onyinye nsọ niile, ha aghaghị ibu ọnọdụ ihere nke ihe arụ niile ha mere.
\v 14 Ma aga m ahọpụta ha ka ha bụrụ ndị ilekọta ụlọnsọ m dị nʼaka, nʼihi ịrụ ọrụ niile na ije ozi niile dị nʼime ya.
\p 
\v 15 “ ‘Ma ndị nchụaja, bụ ụmụ Zadọk, ndị Livayị, ndị chegidere ebe nsọ m nche, mgbe Izrel niile sitere nʼebe m nọ kpafuo, ga-abịa nso ijere m ozi, ha ga-eguzo nʼihu m chụọ aja abụba na ọbara. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\v 16 Ọ bụ naanị ha ga-abanye nʼime ebe nsọ m, naanị ha ga-abịakwa na tebul m ije ozi nʼihu m, na ife m dịka ndị nche.
\p 
\v 17 “ ‘Mgbe ha na-abata nʼọnụ ụzọ ama nke ogige dị nʼime, ha ga-eyi naanị akwa ọcha. Ha agaghị eyi uwe ọbụla e ji ajị anụ kpaa mgbe ha na-eje ozi nʼogige ime nke ụlọnsọ ukwu m.
\v 18 Ha ga-eji akwa ọcha kee nʼisi ha, yirikwa uwe ọcha nʼukwu ha. Ha agaghị eyi ihe ọbụla ga-eme ka ọsịsọọ gbaa ha.
\v 19 Mgbe ha na-apụ nʼogige dị nʼezi ebe ndị mmadụ nọ, ha ga-eyipụ uwe ha yi mgbe ha na-eje ozi, hapụkwa ha nʼime ọnụụlọ nsọ ndị a, yiri uwe ọzọ, ka ha ghara ime ka ndị mmadụ bụrụ ndị e doro nsọ site nʼimetụ uwe ha ahụ.
\p 
\v 20 “ ‘Ha agaghị ekwe ka agịrị isi ha too ogologo, ha agakwaghị akpụchapụ ya. Naanị mkpacha ka ha ga na-akpacha isi ha.
\v 21 Onye nchụaja ọbụla agaghị aṅụ mmanya vaịnị mgbe ọ na-abata nʼogige dị nʼime.
\v 22 Ha agaghị alụ nwanyị nke di ya nwụrụ anwụ, maọbụ nwanyị gbaara di ya alụkwaghị m. Kama ọ bụ naanị ụmụ agbọghọ ndị sitere nʼagbụrụ Izrel ndị na-amaghị nwoke, maọbụ nwunye ndị nchụaja nwụrụ anwụ.
\v 23 Ha ga-akụziri ndị m ihe dị iche nʼetiti ihe dị nsọ na ihe na-adịghị nsọ; gosi ha otu esi amata ihe dị iche nʼetiti ihe na-adịghị ọcha na nke dị ọcha.
\p 
\v 24 “ ‘Ha ga-abụ ndị ikpe, idozi esemokwu dapụtara nʼetiti ndị m. Usoro iwu m niile ka ha ga-eji kpee ikpe. Ndị nchụaja nʼonwe ha kwa ga-erube isi nʼiwu m niile nʼoge mmemme ọbụla dị nsọ. Ha ga-ahụkwa na e doro ụbọchị izuike nsọ.
\p 
\v 25 “ ‘Onye nchụaja agaghị emerụ onwe ya site nʼije nʼebe ozu dị, karịakwa maọbụ ozu nna ya maọbụ nne ya, ma o bụ nwa ya, maọbụ nwanne ya nwoke, maọbụ nwanne ya nwanyị na-enweghị di.
\v 26 Mgbe e mechara ka ọ dị ọcha ọzọ, ọ ga-echere ruo ụbọchị asaa.
\v 27 Ma nʼụbọchị ahụ, ọ ga-alọghachi nʼụlọ ukwu ahụ ịbanye nʼime ebe nsọ, ọ ga-ebu ụzọ chụọ aja mmehie nʼihi onwe ya. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\p 
\v 28 “ ‘Ọ bụ naanị mụ onwe m bụ ihe nketa nke ndị nchụaja ga-enweta. Unu agaghị enye ha ihe nweta ọbụla nʼIzrel. Mụ onwe m bụ ihe nketa ha.
\v 29 Ha ga-eri onyinye ịnata ihuọma, ihe aja mmehie, ihe aja ikpe ọmụma, ihe niile dị nʼIzrel e doro nsọ nye \nd Onyenwe anyị\nd* ga-abụ nke ha.
\v 30 Mkpụrụ mbụ kachasị mma site na mkpụrụ ubi ọbụla na onyinye niile pụrụ iche ga-abụ nke ndị nchụaja. Ọka mbụ a kwọrọ akwọ, nke a na-eweta nʼihe ubi ga-abụkwa nke ndị nchụaja, ime ka ngọzị dịkwasị nʼụlọ unu.
\v 31 Ndị nchụaja agaghị ata nnụnụ ọbụla, maọbụ anụ nke nwụrụ ọnwụ chi ya, maọbụ nke anụ ọzọ dọgburu.
\c 45
\s1 Okike a ga-eke ala ahụ
\p 
\v 1 “ ‘Mgbe unu ga-eke ala ahụ dịka ihe nketa, unu ga-ebu ụzọ nye \nd Onyenwe anyị\nd* otu oke nʼime ya ka ọ bụrụ oke dị nsọ nke ala ahụ. Ogologo ya ga-adị kilomita iri na atọ, obosara ya ga-abụ kilomita iri na otu. Ihe dị nsọ ka ala ahụ niile ga-abụ gbaa gburugburu.
\v 2 Site nʼala, otu akụkụ dị narị mita abụọ na iri itoolu na otu, na iri sentimita asaa na ise, ga-abụ maka ebe nsọ. A ga-ahapụ ala dị iri mita abụọ na itoolu gburugburu ya.
\v 3 Site nʼoke ebe ahụ dị nsọ, tụpụta oke ogologo ya dị kilomita iri na atọ, obosara ya kilomita ise na ọkara. Ọ bụ nʼime ya ka ebe nsọ, ya bụ Ebe ahụ Kachasị Nsọ ga-adị.
\v 4 Ọ ga-abụ oke ala ndị nchụaja, ndị na-eje ozi nʼebe nsọ, na ndị na-abịa nso ije ozi nʼihu \nd Onyenwe anyị\nd*. Ọ ga-abụkwa ebe ụlọ obibi ha ga-adị, bụrụkwa ebe dị nsọ maka ebe nsọ ahụ.
\v 5 Ala ọzọ dị ya nʼakụkụ, nke ga-adị kilomita iri na atọ nʼogologo, kilomita ise na ọkara nʼobosara ya, ga-abụ ebe obibi ndị Livayị, ndị na-arụ ọrụ nʼụlọnsọ ukwuu ahụ.
\p 
\v 6 “ ‘Nʼakụkụ obodo nsọ ka a ga-ekewapụta ala nke ogologo ya dị kilomita iri na atọ, nke obosara ya dịkwa kilomita abụọ na ọkara, nke a ga-abụ nke ndị Izrel.
\p 
\v 7 “ ‘A ga-ewepụta ala pụrụ iche maka nwa eze. Ala a ga-adị nʼakụkụ abụọ nke ala nsọ ahụ, na obodo ahụ. Ala a ga-agbatịrị site nʼakụkụ ọdịda anyanwụ ebe oke ya dị ruo nʼosimiri Mediterenịa. Ọ ga-esitekwa nʼoke ala ya nʼọwụwa anyanwụ gbatịrị ruo nʼebe ebo Izrel nwere ala ha. Nʼụzọ dị otu a, ala a ga-aha ka ala ebo Izrel ketara.
\v 8 Ala a ga-abụrụ ya ihe nketa nʼIzrel. Ndịisi m agaghị emegbu ndị m ọzọ, ma ha ga-ahapụ ndị Izrel ka ha keta ala ndị a dịka ebo niile ha si dị.
\p 
\v 9 “ ‘Nke a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: O zuolara unu, unu ụmụ ndị eze Izrel. Kwụsịnụ ịpụnara ndị m ihe ha nwere nʼike, kpeenụ ikpe ziri ezi na-emekwa ihe kwesiri ekwesi. Kwụsịnụ ịchụpụ ndị m site nʼihe ha, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara.
\v 10 Ka ihe ọtụtụ unu ji ere ahịa unu bụrụ ezigbo efa na ezigbo baf\f + \fr 45:10 \ft Otu ihe ọtụtụ bat na-erite galọọnụ isii\f* nke a na-ejighị aghụghọ kpụọ.
\v 11 Ka ihe ọtụtụ homa bụrụ ihe unu ga-eji na-atụ ihe niile, ma mmanụ, ma ọka. Ihe ọtụtụ ndị ọzọ unu ga-enwe ga-abụ efa, nke bụ otu ụzọ nʼụzọ iri nke homa, maka ịtụ ihe dịka ọka. Nke ọzọ bụ baf, nke bụkwa otu ụzọ nʼụzọ iri nke homa, maka ịtụ ihe dịka mmanụ.
\v 12 Ihe ọtụtụ a ga-eji mata ịdị arọ nke ihe ọbụla ga-abụ shekel. Ihe a ga-eji gbanwere shekel a bụ iri gera abụọ naanị. Iri shekel isii ka a ga-ejikwa gbanwere otu mina.
\s1 Ịchụ aja na mmemme dị iche iche
\p 
\v 13 “ ‘Nke a bụ onyinye pụrụ iche unu ga-enye: otu ụzọ nʼụzọ isii nke efa, site nʼotu homa nke ọka wiiti unu. Unu ga-enyekwa otu ụzọ nʼụzọ isii nke efa\f + \fr 45:13 \ft Ihe ruru kilogram abụọ na ụma asaa\f* site nʼotu homa ọka balị unu.
\v 14 Dịka e nyere ya nʼiwu, unu ga-eji ihe ọtụtụ baf, weta mmanụ oliv bụ otu ụzọ nʼime ụzọ iri\f + \fr 45:14 \ft Ya bụ lita abụọ na ụma abụọ\f* site nʼotu kọ ọbụla (kọ na-erita baf iri, nʼihi na baf iri, bụ ọtụtụ otu homa).
\v 15 Ọzọkwa, otu atụrụ nke sitere nʼigwe atụrụ dị narị atụrụ abụọ, nke si nʼebe ịta nri nke Izrel a gbara mmiri nke ọma ka unu ga-eweta. A ga-eji ndị a chụọ aja mkpụrụ ọka, na aja nsure ọkụ, na aja udo, maka ikpuchiri ndị wetara ha mmehie ha. Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.
\v 16 Ndị niile nke nʼala ahụ ga-eso nwa eze Izrel bute onyinye ndị a.
\v 17 Nwa eze ahụ ka ọ dịrị iweta ihe eji achụ aja nsure ọkụ niile, aja mkpụrụ ọka, aja ihe ọṅụṅụ niile, na nke Ọnwa ọhụrụ nakwa nke ụbọchị izuike niile, nʼoge mmemme niile nke ndị Izrel. Ọ ga-ewetakwa ihe eji achụ aja mmehie, aja mkpụrụ ọka, aja nsure ọkụ, aja udo maka ikpuchiri ụmụ Izrel mmehie ha.
\p 
\v 18 “ ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru: Nʼụbọchị mbụ nke ọnwa mbụ ọbụla, unu ga-ewere nwa oke ehi nke na-enweghị ntụpọ, chụọ aja ido ụlọnsọ m nsọ.
\v 19 Onye nchụaja ga-ewere ụfọdụ ọbara nke aja mmehie ahụ tee ya nʼakụkụ ọnụ ụzọ ụlọnsọ m, na nʼakụkụ anọ nke ọnụ ebe ịchụ aja, na nʼahụ ibo nke ọnụ ụzọ ogige ime.
\v 20 Unu ga-emekwa otu ihe ahụ nʼabalị asaa nke ọnwa ahụ nʼihi onye ọbụla mehiere na-amaghị ama, maka ikpuchi mmehie metụtara ụlọnsọ m.
\p 
\v 21 “ ‘Nʼụbọchị nke iri na anọ nke ọnwa mbụ, ka unu ga-edebe Mmemme Ngabiga. Ọ ga-abụ mmemme abalị asaa. Nʼụbọchị ndị a, naanị achịcha nke a na-ejighị ihe na-eko achịcha mee ka unu ga-eri.
\v 22 Nʼụbọchị ahụ, onyeisi ga-eweta otu nwa oke ehi maka aja mmehie nke onwe ya, na maka mmehie mmadụ niile nke ala ahụ.
\v 23 Nʼụbọchị asaa nke mmemme ahụ, kwa ụbọchị, ọ ga-eweta oke ehi asaa na ebule asaa, ndị na-enweghị ntụpọ ọbụla, dịka ihe ịchụ aja nsure ọkụ nye \nd Onyenwe anyị\nd*. Ọ ga-enyekwa nwa mkpi kwa ụbọchị maka aja mmehie.
\v 24 Ọ ga-ewetakwa nʼihi onyinye ịnata ihuọma, narị lita ọka anọ na iri itoolu,\f + \fr 45:24 \ft Nha otu ọtụtụ efaf\f* nke bụ otu ọtụtụ otu oke ehi, otu ọtụtụ otu ebule. Tinyere lita mmanụ oliv atọ na ụma asatọ. Lita mmanụ atọ na ụma asatọ dịkwara otu efaf ọka.
\p 
\v 25 “ ‘Nʼoge mmemme ụbọchị asaa ahụ, nke ga-ebido nʼụbọchị iri na ise nke ọnwa asaa, ọ ga-ewetakwa ihe a ga-eji chụọ aja mmehie na aja nsure ọkụ, na aja mkpụrụ ọka, na mmanụ.
\c 46
\p 
\v 1 “ ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, Ọnụ ụzọ ama nke ogige ime, nke na-eche ihu nʼọwụwa anyanwụ ga-abụ ihe e mechiri emechi nʼụbọchị isii niile unu na-arụ ọrụ. Ma a ga-emeghe ya nʼụbọchị izuike, na nʼụbọchị mmemme ọnwa ọhụrụ.
\v 2 Nwa eze ga-esitekwa na mpụta ọnụ ụlọ nke ọnụ ụzọ ama bata, guzoro nʼakụkụ ọnụ ụzọ ama. Ndị nchụaja ga-edozikwa aja nsure ọkụ ya, na aja udo ya. Ọ ga-anọkwa nʼụlọ mbata kpọọ isiala nke ofufe ya, sitekwa nʼebe ahụ pụọ. Ma a gaghị emechi ọnụ ụzọ ahụ tutu ruo anyasị.
\v 3 Nʼihu ọnụ ụzọ ama ka ndị ala a ga-anọ fee \nd Onyenwe anyị\nd* ofufe nʼụbọchị izuike na nʼụbọchị mmemme ọnwa ọhụrụ.
\v 4 Ihe nwa eze ahụ ga-eji chụọrọ \nd Onyenwe anyị\nd* aja nsure ọkụ nʼụbọchị izuike na nʼoge mmemme ọnwa ọhụrụ ga-abụ ụmụ ebule isii, na otu ebule, ndị na-enweghị ntụpọ.
\v 5 Ọ ga-eweta ihe e ji achụ aja mkpụrụ ọka, nke bụ iri lita ụtụ ọka abụọ na abụọ, na otu ebule. Ọ ga-ewetakwa lita mmanụ oliv asaa maka iri lita ụtụ ọka abụọ na abụọ ahụ, tinyere onyinye ụmụ atụrụ dịka o si masị ya.
\v 6 Nʼụbọchị mmemme ọnwa ọhụrụ, ọ ga-eweta otu nwa oke ehi, ụmụ atụrụ isii na otu ebule, ha niile ọ dịghị nke ga-enwe ntụpọ ọbụla.
\v 7 Ọ ga-ewetakwa otu oke ehi na iri lita ụtụ ọka iri abụọ na abụọ, maka aja mkpụrụ ọka. Ọ ga-enye ebule ahụ na iri lita ụtụ ọka iri abụọ na abụọ. Ọ ga-enyekwa ụmụ atụrụ ndị ahụ na ụtụ ọka dịka o si masị ya inye ha, tinyere iri lita ọka abụọ na abụọ, nke ọ ga-eweta maka lita mmanụ oliv asaa.
\v 8 Mgbe nwa eze ga-abata nʼụlọ ahụ, ọ ga-esite na mpụta ọnụ ụlọ nke ọnụ ụzọ ama, ebe ahụ kwa ka ọ ga-esikwa pụọ.
\p 
\v 9 “ ‘Ma mgbe ndị ala ahụ ga-abata nʼihu \nd Onyenwe anyị\nd* nʼoge mmemme dị nsọ, onye ọbụla sitere nʼọnụ ụzọ dị nʼugwu bata aghaghị ịpụ site nʼọnụ ụzọ nke dị na ndịda. Ndị si na ndịda bata ga-esitekwa nʼụzọ nke ugwu pụọ. Ọ dịghị onye ga-esi nʼụzọ o si bata laghachi, kama ha ga-esi ụzọ nke chere ebe ha si bata ihu pụọ.
\v 10 Nwa eze ga-anọ nʼetiti ha, ọ bụrụ na ha abanye, ọ ga-eso ha banye, ọ bụrụkwa na ha apụwa, ọ ga-esokwa ha pụọ.
\v 11 Nʼoge mmemme ndị ahụ pụrụ iche, na mmemme ndị akara aka, ihe a ga-eji nye onyinye mkpụrụ ọka ga-abụ iri lita ụtụ ọka abụọ na abụọ, na otu oke ehi, na iri lita ụtụ ọka abụọ na abụọ na otu ebule, tinyere ụmụ atụrụ nke ọnụọgụgụ ya ga-abụ dịka o si masị ya, tinyere lita mmanụ asaa maka iri lita ụtụ ọka abụọ na abụọ ọbụla.
\p 
\v 12 “ ‘Mgbe ọbụla onyeisi chọrọ inye onyinye afọ ofufu, maka ịchụrụ \nd Onyenwe anyị\nd* aja nsure ọkụ maọbụ aja udo, a ga-emeghere ya ọnụ ụzọ ime nke dị nʼọwụwa anyanwụ ka o si nʼebe ahụ bata. Ọ ga-enye onyinye ya dịka e si enye ya nʼụbọchị izuike. Emesịa, ọ ga-atụgharịa pụọ. A ga-emechikwa ụzọ ahụ mgbe ọ pụchara.
\p 
\v 13 “ ‘Ọ bụ nwa atụrụ gbara otu afọ nke na-enweghị ntụpọ ka ị ga-eweta ụbọchị niile maka ịchụ aja nsure ọkụ nye \nd Onyenwe anyị\nd*, ọ bụ kwa ụtụtụ, kwa ụtụtụ ka ị ga-eweta ya.
\v 14 Ị ga-ewetakwa onyinye mkpụrụ ọka kwa ụtụtụ kwa ụtụtụ tinyere ya, ihe niile ga-emejupụta ya bụ lita ụtụ ọka isii, na lita mmanụ abụọ e ji agwakọta ya. Iche onyinye mkpụrụ ọka a nʼihu \nd Onyenwe anyị\nd* bụ ụkpụrụ ga-adịgide ruo mgbe ebighị ebi.
\v 15 Ya mere, ha ga-edozi nwa atụrụ na ụtụ ọka na mmanụ oliv ahụ, kwa ụtụtụ kwa ụtụtụ, maka aja nsure ọkụ a na-achụ kwa mgbe niile.
\p 
\v 16 “ ‘Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, ọ bụrụ na onyeisi enye onye ọbụla nʼime ụmụ ya ndị ikom onyinye site nʼihe nketa ya, ihe ahụ ga-abụ nke ya, bụrụkwa nke mkpụrụ ya, ọ ga-abụ oke ha site nʼihe nketa ruo ebighị ebi.
\v 17 Ọ bụrụkwanụ na o kenye otu nʼime ndị ohu ya ala site nʼihe nketa ya, ala ahụ ga-abụ nke ohu ahụ tutu ruo nʼafọ inwere onwe, nke bụ afọ asaa ọbụla. Mgbe ahụ, ohu ahụ ga-enwere onwe ya, ma ala ahụ ga-aghọkwa nke nwa eze ahụ. Ihe nketa ya bụ nke dịịrị naanị ụmụ ya, nke ha ka ọ bụ.
\v 18 Nwa eze ahụ agaghị ewere ala ọbụla site nʼihe nketa ndị mmadụ nʼaka ike, si otu a chụpụ ha site nʼala ha. Ala ọbụla ọ na-enye ụmụ ya ga-abụrịrị ihe nketa sitere nʼala nke aka ya. Ka a ghara ime ka ọ bụladị otu nʼime ndị m bụrụ onye e kewapụrụ site nʼihe nketa ha.’ ”
\p 
\v 19 Mgbe nke a gasịrị, o duuru m site nʼọnụ ụzọ dị nʼakụkụ ọnụ ụzọ ama kpọbata m nʼọnụụlọ ndị ahụ dị nsọ, nke chere ihu nʼugwu, nke bụ ihe nketa ndị nchụaja. O gosiri m otu ebe dị na nsọtụ akụkụ ọdịda anyanwụ.
\v 20 Ọ sịrị m, “Ebe a ka ndị nchụaja ga-anọ sie anụ aja ikpe ọmụma na aja mmehie. Ebe a ka ha ga-anọkwa ghee onyinye mkpụrụ ọka, ka a ghara iwebata ha na mpụta ogige a nakwa ido ndị mmadụ nsọ.”
\p 
\v 21 Mgbe ahụ, o mere ka m pụta ọzọ nʼogige ezi. O duuru m gaa nʼakụkụ anọ nke ogige ahụ. Ahụrụ m na e nwere ogige nke dị nʼakụkụ ọbụla.
\v 22 Nʼakụkụ anọ nke ogige ndị a, ogige ndị ọzọ dị nʼime ha. Ha ruru mita iri abụọ na atọ nʼogologo, ebe obosara ha rukwara mita iri na asaa nʼọkara. Ogige anọ ndị a ha nʼotu.
\v 23 Nʼime ụlọ ahụ, gburugburu ya, e nwere ahịrị e ji nkume doo, nke nwere ekwu dị nʼokpuru ahịrị nkume ahụ.
\v 24 Ọ sịrị m, “Ndị a bụ ụlọ ebe ndị niile na-eje ozi nʼụlọnsọ ukwu ahụ ga-anọ na-esi ihe aja niile ndị mmadụ webatara.”
\c 47
\s1 Iyi si nʼime ụlọnsọ ukwu
\p 
\v 1 Mgbe ahụ, nwoke ahụ mere ka m lọghachikwa nʼọnụ ụzọ ụlọnsọ ukwu ahụ. Ahụrụ m iyi nke na-asọ na-aga nʼakụkụ ọwụwa anyanwụ (nʼihi na ihu ụlọnsọ ahụ chere ihu nʼọwụwa anyanwụ). Mmiri ahụ si nʼokpuru ụlọnsọ ukwu ahụ nʼakụkụ aka nri nke ebe ịchụ aja, nʼakụkụ ndịda ya na-asọpụta,
\v 2 O mere ka m si nʼọnụ ụzọ dị nʼugwu pụta, ma gaa nʼọnụ ụzọ nke ọwụwa anyanwụ, ebe m hụrụ mmiri ahụ ka o si na ndịda na-asọpụta.
\p 
\v 3 Mgbe anyị na-aga, o ji ihe ọtụtụ dị ya nʼaka tụpụta ihe ruru narị mita ise na iri mita atọ. O duuru m na-agafe mmiri ahụ. Nʼoge a, mmiri ahụ erutela na nkwonkwo ụkwụ.
\v 4 O jikwa ihe ọtụtụ ya tụpụtakwa ihe ruru narị mita ise na iri mita atọ ọzọ, durukwa m na-aga. Nʼoge a, mmiri ahụ erutela m nʼikpere. Mgbe ọ tụpụtara ihe ruru narị mita ise na iri mita atọ ọzọ, o duuru m gafee mmiri ruru m nʼukwu.
\v 5 Ọ tụpụtakwara ihe ruru narị mita ise na iri mita atọ ọzọ, mmiri ahụ ghọrọ osimiri nke m na-apụghị ịgafe, nʼihi na mmiri ahụ toro eto bụrụ mmiri ogwugwu, osimiri nke mmadụ na-apụghị iji ije ụkwụ gafee.
\v 6 Ọ sịrị m, “Nwa nke mmadụ, ị hụrụ ihe ndị a?”
\p O duuru m laghachi nʼọnụ mmiri.
\v 7 Mgbe m rutere nʼọnụ mmiri, lee, ahụrụ m ọtụtụ osisi nke toro nʼakụkụ abụọ nke iyi ahụ.
\v 8 Ọ sịrị, “Iyi a na-asọ na-aga akụkụ ọwụwa anyanwụ, sọbanye nʼime Araba,\f + \fr 47:8 \ft Maọbụ, \fqa Ndagwurugwu Jọdan\f* tutu bịa sọbanye nʼosimiri nnu ahụ. Mgbe ọ sọbanyere nʼosimiri nnu ahụ, mmiri ya na-aghọ mmiri dị mma ọṅụṅụ
\v 9 Ọtụtụ ihe e kere eke dị ndụ ga-ebi nʼebe ọbụla mmiri a na-asọ aga. Azụ dị ukwuu ga-ejupụta nʼebe ahụ, nʼihi na mmiri a na-asọbanye nʼebe ahụ, na-eme ka mmiri osimiri ghọọ mmiri dị mma ịṅụ aṅụ. Ya mere, ihe niile dị nʼebe ọbụla mmiri a sọjere ga-adị ndụ.
\v 10 Ndị ọkụ azụ ga-eguzo nʼọnụ mmiri, site nʼEn-Gedi ruo nʼEn-Eglaim a gaghị enweta ebe a na-agbasa ụgbụ e ji egbu azụ. Azụ dị iche iche ga-adịkwa, dịka azụ osimiri Mediterenịa.
\v 11 Ma ebe apịtị ya niile, nʼebe niile mmiri na-adọ, agaghị adị ọhụrụ, ọ bụ nnu ga-aga ka a ga-ahapụrụ ebe ndị ahụ.
\v 12 Mkpụrụ osisi dị iche iche ga-eto nʼakụkụ abụọ nke iyi ahụ. Akwụkwọ ha agaghị akpọnwụ akpọnwụ, mkpụrụ ga-adị nʼelu ha mgbe niile. Mkpụrụ ọhụrụ ga-adị nʼọnwa ọbụla, nʼihi na ọ bụ mmiri si nʼebe nsọ ahụ na-agba ha mmiri. Mkpụrụ ha ga-abụ nri, akwụkwọ ha ga-abụkwa maka ịgwọ ọrịa.”
\s1 Oke ala ahụ
\p 
\v 13 Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru, “Nke a ga-abụ oke ala nke unu ga-eke nʼetiti ebo iri na abụọ nke Izrel dịka ihe nketa ha, Josef ga-enweta oke ala abụọ.
\v 14 Ebo ọbụla ga-eketa dịka ibe ya ketara, nʼihi na-eweliri m aka ṅụọ iyi na m ga-enye ndị nna nna unu ala ahụ, na ala a ga-aghọkwa ihe nketa unu.
\b
\li4 
\v 15 “Nke a ga-abụkwa oke ala nke ala unu ahụ.
\b
\li1 “Nʼakụkụ ugwu, ọ ga-esite nʼosimiri Mediterenịa nʼakụkụ ụzọ Hetlon, gafee Lebo gawa Zedad,
\v 16 site ya ruo Berota na Sibraim (nke dị nʼoke ala dị nʼagbata Damaskọs na Hamat), rukwaa na Haza Hatikon, nke dị nʼoke ala Hauran.
\v 17 Oke ala ahụ ga-esite nʼoke osimiri gbasoro oke ala nke ugwu Damaskọs ruo Haza Enan. Oke ala ndị Hamat ga-adịkwa nʼakụkụ ugwu. Nke a ga-abụ oke ala nke akụkụ ugwu unu.
\li1 
\v 18 Oke ala nʼakụkụ ọwụwa anyanwụ ga-esite nʼagbata Hauran na Damaskọs soro akụkụ osimiri Jọdan, nʼagbata ndị Gilead na ala ndị Izrel ruo nʼosimiri dị nʼọwụwa anyanwụ, ruokwa Tama. Nke a ga-abụkwa oke ala unu nʼakụkụ ọwụwa anyanwụ.
\li1 
\v 19 Oke ala na ndịda, ọ ga-esite na Tama ruo ọbụladị mmiri Meriba Kadesh, soro ụzọ ọdọ mmiri iyi Ijipt ruo osimiri Mediterenịa. Nke a bụ oke ala ahụ na ndịda.
\li1 
\v 20 Nʼọdịda anyanwụ, osimiri Mediterenịa ga-abụ oke ala, ruo na ncherita ihu ụzọ e si abata Hamat. Nke a bụ oke ala unu nʼakụkụ ọdịda anyanwụ.
\b
\p 
\v 21 “Ala niile dị nʼime oke ala ndị a, ka unu ga-eke nʼetiti onwe unu dịka ebo Izrel si dị.
\v 22 Keenụ ha ka ha bụrụ ihe nketa nye onwe unu, ma nyekwa ndị ọbịa bi nʼetiti unu, bụ ndị ọbịa niile mụtara ụmụ. Unu ga-agụ ha dịka ndị amụrụ nʼala Izrel. Ha ga-esokwa unu keta oke nʼihe nketa a na-ekenye ndị ebo niile nke Izrel.
\v 23 A ga-ekenye ndị ọbịa ihe nketa nʼebo ọbụla ha bi nʼetiti ha.” Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri.
\c 48
\s1 Okike e kere ala ahụ
\li4 
\v 1 “Nke a bụ aha ebo niile, na ala ha ga-eketa:
\b
\li1 “Dan otu oke. Site na nsọtụ ugwu, nʼakụkụ ụzọ Hetlon ruo mbata Hamat. Haza Enan na oke ala ugwu Damaskọs, nke dị nʼakụkụ Hamat ga-abụ akụkụ oke ala ha site nʼakụkụ ọwụwa anyanwụ ruo nʼọdịda anyanwụ.
\li1 
\v 2 Asha ga-enwe otu oke. Ọ ga-abụ nʼakụkụ oke ala Dan, site nʼọwụwa anyanwụ ruo nʼọdịda anyanwụ.
\li1 
\v 3 Naftalị ga-enwe otu oke. Ọ ga-abụ nʼakụkụ oke ala Asha, site nʼọwụwa anyanwụ ruo nʼọdịda anyanwụ.
\li1 
\v 4 Manase nwere otu oke. Ọ ga-abụ nʼakụkụ oke ala Naftalị, site nʼọwụwa anyanwụ ruo nʼọdịda anyanwụ.
\li1 
\v 5 Ifrem ga-enwe otu oke. Ọ ga-abụ nʼakụkụ oke ala Manase, site nʼọwụwa anyanwụ ruo nʼọdịda anyanwụ.
\li1 
\v 6 Ruben ga-enwe otu oke. Ọ ga-abụ nʼakụkụ oke ala Ifrem, site nʼọwụwa anyanwụ ruo nʼọdịda anyanwụ.
\li1 
\v 7 Juda ga-enwe otu oke. Ọ ga-abụ nʼakụkụ oke ala Ruben, site nʼọwụwa anyanwụ ruo nʼọdịda anyanwụ.
\b
\p 
\v 8 “Ala nke ya na oke ala ndị Juda ga-agbatị site nʼọwụwa anyanwụ ruo nʼọdịda anyanwụ, ka ị ga-enye dịka onyinye pụrụ iche. Obosara ya ga-abụ ihe dị kilomita iri na atọ. Ogologo ya site nʼọwụwa anyanwụ ruo nʼọdịda anyanwụ ga-aha ka ala otu ebo ketara. Ụlọnsọ ukwu ahụ ga-adịkwa nʼetiti ya.
\p 
\v 9 “Ogologo ebe a ewepụtara iche nye \nd Onyenwe anyị\nd* ga-adị kilomita iri na atọ, obosara ya ga-abụ kilomita ise na ọkara.
\v 10 Nke a ga-abụ ala dị nsọ e debere iche nye ndị nchụaja. Nʼakụkụ ugwu, ịdị ogologo ala ahụ ga-abụ kilomita iri na atọ. Nʼakụkụ ọdịda anyanwụ, ogologo ya bụ kilomita ise na ọkara. Ogologo nke akụkụ ndịda na nke ugwu bụ otu. Otu a kwa, ogologo nke akụkụ ọwụwa anyanwụ na ọdịda anyanwụ bụ otu. Ebe nsọ \nd Onyenwe anyị\nd* ga-adị nʼetiti ya.
\v 11 Ọ ga-adịrị ndị nchụaja, bụ ụmụ Zadọk ndị e doro nsọ, ndị sitere nʼikwesị ntụkwasị obi jeere m ozi, ndị na-esiteghị nʼiso ụzọ m kpafuo dịka ndị Izrel na agbụrụ Livayị mere mgbe ha mehiere.
\v 12 Ọ bụ onyinye pụrụ iche a na-enye ha site nʼala ahụ dị nsọ, bụ ala ahụ kachasị nsọ, nke ya na ala ndị Livayị nwekọrọ oke ala.
\p 
\v 13 “Nʼakụkụ ala ndị nchụaja, a ga-ekenye ndị Livayị ala nke ha. Ha ga-eketa ala nke ogologo ya bụ kilomita iri na atọ, nke obosara ya bụ kilomita ise na ọkara.
\v 14 O nweghị akụkụ ala nsọ a a ga-ere ere, maọbụ nye ya ndị ọzọ, nʼihi na ihe dị nsọ ka ọ bụ nye \nd Onyenwe anyị\nd*.
\p 
\v 15 “Ala nke fọdụrụ, nke ogologo ya dị kilomita iri na atọ, nke obosara ya dị kilomita ise na ọkara ga-abụ ala ọha. A ga-ewu ebe obibi nʼelu ya, wukwaa ebe ịzụ anụ ụlọ. Obodo ga-adị nʼetiti ya,
\v 16 nke ogologo akụkụ ugwu ruru kilomita abụọ na ụma anọ, akụkụ ndịda ruru kilomita abụọ na ụma anọ, akụkụ ọwụwa anyanwụ ruru kilomita abụọ na ụma anọ, na akụkụ ọdịda anyanwụ rukwara kilomita abụọ na ụma.
\v 17 Ogologo nke ala ebe ịta nri nke ga-agba obodo ahụ gburugburu ga-aha nʼotu. Ọ ga-adị narị mita na iri mita atọ na ise nʼugwu, na ndịda narị mita na iri mita atọ na ise, nʼọwụwa anyanwụ narị mita na iri mita atọ na ise, nʼakụkụ nʼọdịda anyanwụ narị mita na iri mita atọ na ise.
\v 18 Ma nke ga-afọdụ na ya, nʼakụkụ oke ala ahụ dị nsọ nke gara ogologo ya niile, ga-abụ nʼakụkụ ọwụwa anyanwụ kilomita ise na ọkara nʼakụkụ ọdịda anyanwụ ga-abụkwa kilomita ise na ọkara. Ihe omume ya ga-abụ nri nye ndị ọrụ nke obodo ahụ.
\v 19 Ndị ọrụ si nʼobodo, bụ ndị na-akọ ya ga-abụkwa ndị sị nʼebo niile nke Izrel.
\v 20 Ala ahụ niile, ma ala ahụ e doro nsọ, ma ala ndị obodo, ga-adị kilomita iri na atọ nʼakụkụ ya ọbụla.
\p 
\v 21 “Ala niile fọdụrụ nʼakụkụ abụọ nke ala ahụ dị nsọ, na ala ndị obodo ga-abụ nke nwa eze. Ọ ga-agbatị ruo ọwụwa anyanwụ site nʼọtụtụ kilomita iri na atọ nke oke ahụ dọ nsọ ruo nʼoke ala ọwụwa anyanwụ, sitekwa na kilomita iri na atọ nʼakụkụ ọdịda anyanwụ ruo oke ala ọdịda anyanwụ. Akụkụ abụọ ndị a nke gbatịrị ruo nʼoke ala ndị obodo ga-abụ nke onye ọchịchị, ebe nsọ ahụ na ụlọ ukwu ahụ ga-adị nʼetiti ha.
\v 22 Ya mere, oke ala nke ndị Livayị na ala ndị obodo ga-adị nʼetiti ala nke nwa eze nwee. Oke ala nke nwa eze ahụ ga-adị nʼetiti oke ala Juda na oke ala Benjamin.
\b
\li4 
\v 23 “Ala e nyere ebo fọdụrụ dị otu a:
\b
\li1 “Benjamin ga-enwe otu oke, nke sitere nʼọwụwa anyanwụ ruo nʼọdịda anyanwụ.
\li1 
\v 24 Simiọn ga-enwe otu oke; ha na ndị Benjamin ga-enwekọ otu oke ala nʼakụkụ ọwụwa anyanwụ na nʼakụkụ ọdịda anyanwụ.
\li1 
\v 25 Isaka ga-enwe otu oke; ha na ndị Simiọn ga-enwekọ oke ala nʼakụkụ ọwụwa anyanwụ, na nʼakụkụ ọdịda anyanwụ.
\li1 
\v 26 Zebụlọn ga-enwe otu oke; ha na ndị Isaka ga-enwekọ oke ala nʼakụkụ ọwụwa anyanwụ, na nʼakụkụ ọdịda anyanwụ.
\li1 
\v 27 Gad ga-enwe otu oke; ha na ndị Zebụlọn ga-enwekọ oke ala nʼakụkụ ọwụwa anyanwụ na nʼakụkụ ọdịda anyanwụ.
\li1 
\v 28 Ma oke ala Gad nke chere ihu nʼakụkụ ndịda ga-esi na Tama ruo nʼiyi Meriba Kadesh, sorokwa ọdọ mmiri Ijipt ruo nʼosimiri Mediterenịa.
\b
\li4 
\v 29 “Nke a bụ ala unu ga-ekenye ebo Izrel niile dịka oke ha. Ha ga-abụkwara ha ihe nketa.” Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwubiri ya.
\s1 Ọnụ ụzọ ama obodo ọhụrụ
\li4 
\v 30 “Ndị a ga-abụ ọnụ ụzọ ama e si apụ nʼobodo ahụ.
\b
\li1 “Nʼakụkụ nke ugwu, nke ịdị ogologo mgbidi ya bụ kilomita abụọ,
\v 31 ọnụ ụzọ ama obodo ahụ ga-abụ aha ebo niile nke Izrel. Ọnụ ụzọ ama atọ nʼakụkụ ugwu ga-abụ ọnụ ụzọ ama Ruben, ọnụ ụzọ ama Juda, na ọnụ ụzọ ama Livayị.
\li1 
\v 32 Nʼakụkụ ọwụwa anyanwụ, nke mgbidi ya dị kilomita abụọ nʼogologo, ọnụ ụzọ ama atọ ga-adị ya. Ha ga-aza ọnụ ụzọ ama Josef, ọnụ ụzọ ama Benjamin, na ọnụ ụzọ ama Dan.
\li1 
\v 33 Nʼakụkụ ndịda, nke ogologo ya bụkwa kilomita abụọ, ọnụ ụzọ ama atọ ga-adị ya: ọnụ ụzọ ama Simiọn, ọnụ ụzọ ama Isaka, na ọnụ ụzọ ama Zebụlọn.
\li1 
\v 34 Nʼakụkụ ọdịda anyanwụ nke ịdị ogologo mgbidi ya bụ kilomita abụọ, ọnụ ụzọ ama atọ ga-adị ya: ọnụ ụzọ ama Gad, ọnụ ụzọ ama Asha, na ọnụ ụzọ ama Naftalị.
\b
\li4 
\v 35 “Gburugburu obodo ahụ bụ kilomita iri.
\b
\p “Aha a ga-akpọ obodo ahụ site nʼoge ahụ gawa, ga-abụ, ‘\nd Onyenwe anyị\nd* nọ nʼebe ahụ.’ ”
