\v 15 \w Hubo|strong="H1961"\w* \w temblor|strong="H2731"\w* en \w el|strong="H3605"\w* \w campamento|strong="H4264"\w*, en \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w campo|strong="H4264"\w* \w y|strong="H1571"\w* entre \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*. \w Aun|strong="H1571"\w* \w la|strong="H1571"\w* guarnición \w y|strong="H1571"\w* \w los|strong="H1992"\w* merodeadores \w temblaron|strong="H2729"\w*. \w La|strong="H1571"\w* tierra \w tembló|strong="H2729"\w*, \w de|strong="H5971"\w* modo \w que|strong="H1571"\w* \w aquel|strong="H3605"\w* \w fue|strong="H1961"\w* un gran \w temblor|strong="H2731"\w*.
