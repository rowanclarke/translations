\id 2JN - Okphela 
\h 2 iJọni 
\toc1 2 iJọni 
\toc2 2 iJọni 
\toc3 2 iJọn 
\mt2 Ebe onuzi-eva ni 
\mt1 IJọni 
\mt2 Ọ kẹkẹ 
\c 1  
\p  
\v 1 Mhẹmhẹ ọgbhali na igbaa oyi eni e mie iJesu iKirisiti suọ mhia kẹkẹ ebe ona ghi ẹ. 
\p Yẹyẹ ọkpotso ni Ẹshinẹgba ọ zẹ ali imi ẹ, ni mhi nono ingme oyẹwẹ mhi kẹkẹ ọli ghi. Ọa khi mhẹmhẹghuo tsẹ mhi nono ingme oyẹẹ, li shi eni e lẹsẹ igẹsikia.  
\v 2 Eri anye nono ingme oyẹẹ, itobọ igẹsikia ni o la anye egbe, ni o kie ya la anye egbe agbọagbọ.  
\v 3 Mhi lema Ẹshinẹgba Ita ali iJesu iKirisiti Omiọli e ri okhale ali ilẹlemhi ali opfọmhẹ na awa elemhi igẹsikia ali inono. 
\p  
\v 4 Egbe ma mu mhẹ gba abi mhi rọ suọ ingme oyi imi ẹ eghuo, ni e la angeli odẹ oyi Ẹshinẹgba, ni ẹẹ riẹlẹ emini ẹ ghọle Ita.  
\v 5 Irarighọ, nọkpotso, onana ọa khi omhẹsẹ onogbọ ni mhia yele ẹ le, ama oni awa rọte ekẹ lẹsẹ lọ. Eri mhiẹ awa nono ingme egbe awa.\f + \fr 1:5 \ft Li zẹ \fq iJọn 13.34; 15.12,17\f* 
\v 6 Inono ni mhia ngme khi awa mema ya ke ri omhẹsẹ oyi Ẹshinẹgba gbe akanya. Oni omhẹsẹ abi ẹẹ nya a she li suọ li rọte ekẹ vu khi, ẹẹ nya a mema la angeli inono. 
\p  
\v 7 Ebubu ẹgbọ ni ẹ di ẹgbọ e she lasele shi asha kpa elemhi agbọ, ni ẹẹ liẹ khi iJesu iKirisiti ọa li abi ọgbọ li bhale agbọ. Ẹgbọ enana nya, ẹgbọ elo-ẹgbhuẹ e khi, e gbo khi eni ẹẹ khọli Ọmiepfuese.  
\v 8 Irarighọ, a mu egbe ẹ ini emini awa gbe akanya a shi o khi de awa obọ-a, ama ni awa khi eni a somhopfa gba pfo. 
\p  
\v 9 Mhi gueyẹ ẹ khi ọnini ọa da mu emini iKirisiti ọ sẹsẹ mhuẹ, ni ọ da ọ, ọa mhọli Ẹshinẹgba. Ama ọnini ọ da mu emini iKirisiti ọ sẹsẹ mhuẹ ne, ọ mhọli Ẹshinẹgba Ita ali Omiọli.  
\v 10 Irarighọ, ini ọgbọkhọghuo ọ bhale debẹ ni ọ rọ tsua osẹsẹ olese ni ọa khi onana bhale, khi zẹ ọli lo owa oyẹ le, khi ga fẹ mhọli ikpaghiobọ shi ọli oni osẹsẹ.  
\v 11 Ọnini ọ da mhọli ikpaghiobọ shi ọni ọgbọ ọghọghọ osẹsẹ ne, eri ọ kugbe ọli ọ, ni e ga riẹlẹ oni ọkhọlọ. 
\s1 Ungmemhi ni o kpukhokho 
\p  
\v 12 Mhi ga mhọli emhi ebubu ni mhi kha kẹkẹ ghi ẹ, ama mhi aa nono ni mhi kẹkẹ wẹ shi ebe. Eri mhi ya ri ochoghọ bhale ya bino ẹ, isheghọ ni awa mẹ egbe imi-alo nu egbe ngme. Ni oghẹlẹ oyawa o vọ.  
\v 13 Imi inyọghuẹ ni ọkpotso ni Ẹshinẹgba ọ zẹ, ẹẹ tsẹ.