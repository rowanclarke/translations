\v 11 \w quienes|strong="G5101"\w* \w les|strong="G1519"\w* preguntaron: Varones \w galileos|strong="G1057"\w*, ¿\w por|strong="G1519"\w* \w qué|strong="G3588"\w* miran \w al|strong="G3588"\w* \w cielo|strong="G3772"\w*? \w Este|strong="G3778"\w* \w Jesús|strong="G2424"\w*, \w Quien|strong="G5101"\w* \w fue|strong="G4198"\w* tomado \w de|strong="G1519"\w* ustedes \w al|strong="G3588"\w* \w cielo|strong="G3772"\w*, \w vendrá|strong="G2064"\w* \w así|strong="G3779"\w* \w como|strong="G2532"\w* \w lo|strong="G3588"\w* contemplaron \w al|strong="G3588"\w* ascender.   
\s1 Supuesto sucesor de Judas  
\p
\v 12 \w Entonces|strong="G5119"\w* regresaron \w a|strong="G1519"\w* Jerusalén \w de|strong="G1519"\w* \w la|strong="G3588"\w* Montaña \w de|strong="G1519"\w* \w Los|strong="G3588"\w* Olivos, \w la|strong="G3588"\w* \w cual|strong="G3739"\w* \w está|strong="G3588"\w* \w cerca|strong="G1451"\w* \w de|strong="G1519"\w* Jerusalén, \w que|strong="G3588"\w* \w tiene|strong="G2192"\w* \w camino|strong="G3598"\w* \w de|strong="G1519"\w* \w un|strong="G3588"\w* \w sábado|strong="G4521"\w*.\f + \fr 1:12 \fqa Como un kilómetro de distancia.\f*  
\v 13 \w Al|strong="G3588"\w* \w entrar|strong="G1525"\w* \w en|strong="G1519"\w* \w la|strong="G3588"\w* ciudad, subieron \w al|strong="G3588"\w* \w aposento|strong="G5253"\w* alto \w donde|strong="G3757"\w* estaban hospedados \w Pedro|strong="G4074"\w*, \w Juan|strong="G2491"\w*, \w Jacobo|strong="G2385"\w*, Andrés, \w Felipe|strong="G5376"\w*, \w Tomás|strong="G2381"\w*, Bartolomé, \w Mateo|strong="G3156"\w*, \w Jacobo|strong="G2385"\w*, \add hijo\add* \w de|strong="G1519"\w* Alfeo, \w Simón|strong="G4613"\w* \w el|strong="G3588"\w* Zelote \w y|strong="G2532"\w* \w Judas|strong="G2455"\w*, \add hermano\add* \w de|strong="G1519"\w* \w Jacobo|strong="G2385"\w*.  
\v 14 \w Todos|strong="G3956"\w* \w éstos|strong="G3778"\w* estaban dedicados \w con|strong="G4862"\w* propósito a \w la|strong="G3588"\w* conversación \w con|strong="G4862"\w* Dios, \w con|strong="G4862"\w* \add algunas\add* \w mujeres|strong="G1135"\w*, \w y|strong="G2532"\w* \w María|strong="G3137"\w*, \w la|strong="G3588"\w* \w madre|strong="G3384"\w* \w de|strong="G3588"\w* \w Jesús|strong="G2424"\w*, \w y|strong="G2532"\w* \w los|strong="G3588"\w* hermanos \w de|strong="G3588"\w* \w Él|strong="G3588"\w*.   
\p
\v 15 \w Los|strong="G3588"\w* reunidos eran \w como|strong="G5613"\w* 120. \w En|strong="G1722"\w* \w esos|strong="G3778"\w* \w días|strong="G2250"\w*, \w Pedro|strong="G4074"\w* \w dijo|strong="G3004"\w* \w a|strong="G1909"\w* \w sus|strong="G3588"\w* hermanos:  
\v 16 Varones hermanos, \w fue|strong="G1096"\w* \w necesario|strong="G1163"\w* \w que|strong="G3588"\w* \w se|strong="G1096"\w* cumpliera \w la|strong="G3588"\w* \w Escritura|strong="G1124"\w* \w que|strong="G3588"\w* \w el|strong="G3588"\w* \w Espíritu|strong="G4151"\w* Santo predijo \w por|strong="G1223"\w* \w boca|strong="G4750"\w* \w de|strong="G4012"\w* \w David|strong="G1138"\w* \w con|strong="G1223"\w* \w respecto|strong="G4012"\w* \w a|strong="G1223"\w* \w Judas|strong="G2455"\w*, \w quien|strong="G3739"\w* \w fue|strong="G1096"\w* \w guía|strong="G3595"\w* \w de|strong="G4012"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* arrestaron \w a|strong="G1223"\w* \w Jesús|strong="G2424"\w*,  
\v 17 \w porque|strong="G3754"\w* \w era|strong="G1510"\w* \w uno|strong="G3588"\w* \w de|strong="G1722"\w* \w nosotros|strong="G2249"\w* \w y|strong="G2532"\w* participaba \w en|strong="G1722"\w* \w este|strong="G3778"\w* \w ministerio|strong="G1248"\w*.   
\p
\v 18 \w Éste|strong="G3778"\w* compró \w un|strong="G3588"\w* \w campo|strong="G5564"\w* \w con|strong="G1537"\w* \w el|strong="G3588"\w* \w pago|strong="G3408"\w* \w por|strong="G1537"\w* \w su|strong="G3588"\w* iniquidad. \add Allí\add* cayó \w de|strong="G1537"\w* cabeza, \w reventó|strong="G2997"\w* \w por|strong="G1537"\w* \w el|strong="G3588"\w* \w medio|strong="G3319"\w* \w y|strong="G2532"\w* \w se|strong="G1096"\w* le derramaron \w todos|strong="G3956"\w* \w sus|strong="G3588"\w* órganos internos.  
\v 19 \w Esto|strong="G3778"\w* \w lo|strong="G3588"\w* supieron \w todos|strong="G3956"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* viven \w en|strong="G3588"\w* Jerusalén, \w de|strong="G3588"\w* \w modo|strong="G5620"\w* \w que|strong="G3588"\w* \w aquel|strong="G3588"\w* \w campo|strong="G5564"\w* \w se|strong="G1096"\w* \w llama|strong="G2564"\w* \w en|strong="G3588"\w* \w su|strong="G3588"\w* \w propia|strong="G2398"\w* \w lengua|strong="G1258"\w* \it Acéldama,\it* \w es|strong="G1096"\w* decir, \w Campo|strong="G5564"\w* \w de|strong="G3588"\w* Sangre.   
\p
\v 20 \w En|strong="G1722"\w* \w un|strong="G3588"\w* rollo \w de|strong="G1722"\w* \w salmos|strong="G5568"\w* \w está|strong="G3588"\w* \w escrito|strong="G1125"\w*:  
\m \w Sea|strong="G1096"\w* \w desierta|strong="G2048"\w* \w su|strong="G3588"\w* morada,  
