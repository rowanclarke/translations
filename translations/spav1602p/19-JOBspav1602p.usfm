\v 7 \w Y|strong="H3068"\w* \w aconteció|strong="H1961"\w* \w que|strong="H3588"\w* \w después|strong="H1961"\w* \w que|strong="H3588"\w* \w habló|strong="H1696"\w* \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w* estas \w palabras|strong="H1697"\w* \w a|strong="H3068"\w* Job, \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* Elifaz \w temanita|strong="H8489"\w*: \w Mi|strong="H1961"\w* ira \w se|strong="H1961"\w* encendió \w contra|strong="H1961"\w* ti \w y|strong="H3588"\w* tus \w dos|strong="H8147"\w* \w compañeros|strong="H7453"\w*: \w porque|strong="H3588"\w* \w no|strong="H3808"\w* habéis \w hablado|strong="H1696"\w* \w por|strong="H3588"\w* \w mí|strong="H1961"\w* \w lo|strong="H1697"\w* \w recto|strong="H3559"\w*, \w como|strong="H3588"\w* \w mi|strong="H1961"\w* \w siervo|strong="H5650"\w* Job.
