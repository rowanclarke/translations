\id PRO - Biblica® Open New Serbian Translation Latin 2017
\h Priče Solomonove
\toc1 Priče Solomonove
\toc2 Priče Solomonove
\toc3 Pri
\mt1 Priče Solomonove
\c 1
\ms1 Svrha i tema
\p 
\v 1 Mudre priče\f + \fr 1,1 \ft Ili: \fqa poslovice, mudre izreke.\f* Solomona, Davidovog sina, cara Izrailja:
\q1 
\v 2 da se steknu mudrost i ukor,
\q2 pouka razumnim rečima;
\q1 
\v 3 da se primi ukor,
\q2 razmišlja o pravdi, o pravednosti i čestitosti;
\q1 
\v 4 da se razboritost lakovernima, znanje
\q2 i domišljatost mladima.
\q1 
\v 5 Neka sluša ko je mudar i neka još više shvati,
\q2 neka učeni dobije mudar savet:
\q1 
\v 6 da pronikne pouku, zagonetku,
\q2 reči mudrih i njihove priče.
\b
\q1 
\v 7 Znanje otpočinje bogobojaznošću,
\q2 a mudrost i prekor budale preziru.
\ms1 Uvod: poziv na prihvatanje mudrosti
\s1 Upozorenje na poziv grešnika
\q1 
\v 8 Sine moj, poslušaj pouku oca svoga
\q2 i majke svoje savet ne odbacuj.
\q1 
\v 9 Jer, oni će biti prelepi venac na tvojoj glavi
\q2 i privesci oko tvoga vrata.
\b
\q1 
\v 10 Sine moj, ako li te grešnici zavode,
\q2 ti ne pristaj.
\q1 
\v 11 Kažu li: „Hajde s nama,
\q2 u zasedu da legnemo, krv nevinog
\q2 i nedužnog hajde da vrebamo!
\q1 
\v 12 Hajde da ih poput Sveta mrtvih\f + \fr 1,12 \ft U izvornom tekstu \tl Šeol\tl*, ili \fqa podzemlje\ft , gde prebivaju duše umrlih.\f* progutamo,
\q2 i žive i jedre, kao one što u raku idu.
\q1 
\v 13 Pokupimo sva dobra, sve blago!
\q2 Nakrcajmo svoje kuće plenom!
\q1 
\v 14 Sa nama ćeš dobitak da deliš,
\q2 nek nam svima bude jedna kesa.“
\q1 
\v 15 Sine moj, nemoj ići putem s njima,
\q2 ne daj nozi na njihove staze.
\q1 
\v 16 Jer im noge ka zlu trče
\q2 i srljaju da krv liju.
\q1 
\v 17 Uzalud se širi mreža
\q2 naočigled ptice.
\q1 
\v 18 Ali oni čekaju u zasedi krv svoju,
\q2 vrebaju svoj život.
\q1 
\v 19 Takve su staze svakog ko grabi nepošten dobitak,
\q2 života koštaju.
\s1 Mudrost prekoreva
\q1 
\v 20 Mudrost po ulicama viče,
\q2 po trgovima diže glas svoj;
\q1 
\v 21 po raskršćima, u najvećoj vrevi objavljuje,
\q2 na ulazima gradskih vrata kazivanja svoja daje:
\b
\q1 
\v 22 „Dokle ćete, lakoverni, voleti lakovernost;
\q2 dokle ćete, rugači, u ruganju uživati;
\q2 dokle ćete, tupoglavi, mrzeti znanje?
\q1 
\v 23 Obratite se po prekoru mome.
\q2 Evo, izliću vam duha svoga,
\q2 objaviću vam svoje reči.
\q1 
\v 24 Jer ja sam vas zvala, a vi ste se oglušili,
\q2 pružala sam ruku, a niko mario nije;
\q1 
\v 25 sve moje savete ste zanemarili
\q2 i prekore moje niste prihvatili.
\q1 
\v 26 Sada ću se i ja smejati propasti vašoj,
\q2 rugaću se kad bude došla strahota vaša;
\q1 
\v 27 kad vaša strahota prođe kao razaranje
\q2 i propast vaša kao oluja kada huči,
\q2 kada vas zadese muka i nevolja.
\b
\q1 
\v 28 Tada će me zvati, a ja se neću odazivati,
\q2 tražiće me željno alʼ me neće naći.
\q1 
\v 29 Zato što su mrzeli znanje
\q2 i nisu izabrali bogobojaznost;
\q1 
\v 30 moj savet nisu poslušali
\q2 i odbacili su svaki moj prekor.
\q1 
\v 31 Zato će jesti plod svog puta,
\q2 preješće se saveta svojih.
\q1 
\v 32 Jer lakoverne će upropastiti otpadništvo,
\q2 a budale satrće lakomislenost.
\q1 
\v 33 A ko mene sluša živeće spokojno,
\q2 siguran, bez bojazni od nedaća.“
\c 2
\s1 Blagodati mudrosti
\q1 
\v 1 Sine moj, prihvatiš li moje reči
\q2 i u sebi sačuvaš zapovesti moje;
\q1 
\v 2 tad pažljivo slušaj mudrost
\q2 i srcem teži da razumeš.
\q1 
\v 3 Ako prizoveš pronicljivost
\q2 i zavapiš razboritosti;
\q1 
\v 4 potražiš li to kao srebro,
\q2 tragaš li za tim kao za skrivenim blagom;
\q1 
\v 5 onda ćeš znati za bogobojaznost
\q2 i naći ćeš bogopoznanje.
\q1 
\v 6 Jer Gospod mudrost daje,
\q2 znanje i razboritost iz njegovih su usta.
\q1 
\v 7 On pravednima sabira istinsku mudrost,
\q2 štit je onima što čestito žive,
\q1 
\v 8 da zaštiti staze pravednosti
\q2 i sačuva put verujućih svojih.
\b
\q1 
\v 9 Onda ćeš razumeti pravednost, pravdu i čestitost,
\q2 baš svaku stazu valjanu.
\q1 
\v 10 Onda će ti mudrost doći u srce
\q2 i znanje biće milo duši tvojoj;
\q1 
\v 11 domišljatost će bdeti nad tobom
\q2 i razboritost čuvaće te.
\b
\q1 
\v 12 Izbaviće te od puta izopačenog,
\q2 od onih što izopačeno govore,
\q1 
\v 13 od onih koji napuštaju pravednu stazu
\q2 da bi koračali stazama mraka,
\q1 
\v 14 od onih koji se raduju kada čine zlo
\q2 i kliču izopačenosti zla,
\q1 
\v 15 kojima su staze pokvarene,
\q2 a bogaze iskvarene.
\b
\q1 
\v 16 Izbaviće te od bludnice,
\q2 od uspaljenice slatkorečive,
\q1 
\v 17 one što napušta muža mladosti svoje
\q2 i zaboravlja zavet Boga svoga.
\q1 
\v 18 Njena kuća tone u smrt,
\q2 a staze njene među pokojne.
\q1 
\v 19 Ne vraća se niko ko joj ode,
\q2 ne domognu se staza života.
\b
\q1 
\v 20 Zato ti idi putem dobrih ljudi,
\q2 drži se staza pravednika.
\q1 
\v 21 Jer će zemlju pravednici naslediti
\q2 i besprekorni će u njoj prebivati.
\q1 
\v 22 A zli će se iz zemlje istrebiti,
\q2 nevernike će počupati iz nje.
\c 3
\s1 Blagodati mudrosti
\q1 
\v 1 Sine moj, pouku moju ne zaboravljaj
\q2 i u srcu čuvaj zapovesti moje,
\q1 
\v 2 jer će ti produžiti dane i godine života,
\q2 mir će ti pridodati.
\b
\q1 
\v 3 Milost i istina neka ne odlaze od tebe.
\q2 Veži ih oko vrata,
\q2 upiši ih na ploču srca!
\q1 
\v 4 I tad ćeš naći milost i naklonost
\q2 i u Božijim i u ljudskim očima.
\b
\q1 
\v 5 U Gospoda pouzdaj se svim srcem svojim
\q2 i nemoj se oslanjati na mudrost svoju.
\q1 
\v 6 Misli na njega na svojim putevima
\q2 da bi tvoje staze učinio ravnim.
\b
\q1 
\v 7 U očima svojim nemoj biti mudar,
\q2 boj se Gospoda i beži od zla.
\q1 
\v 8 To će ti telu doneti zdravlje,
\q2 kosti će ti podmladiti.
\b
\q1 
\v 9 Daj čast Gospodu svojim dobrima
\q2 i prvinama svega što si stekao.
\q1 
\v 10 Tada će se obilno napuniti ambari tvoji,
\q2 prelivaće se širom kace tvoje.
\b
\q1 
\v 11 Sine moj, ne uzimaj olako Gospodnji odgoj,
\q2 i ne kloni kada te on kori,
\q1 
\v 12 jer Gospod kori onog koga voli,
\q2 baš kao i otac sina u kome mu je milina.
\b
\q1 
\v 13 Kako je blagosloven čovek koji je našao mudrost,
\q2 čovek koji je dobio razboritost!
\q1 
\v 14 Jer je ona dragocenija nego dobit od srebra,
\q2 korist je njena od zlata veća.
\q1 
\v 15 Vrednija je od dragulja
\q2 i ravna joj nisu sva uživanja tvoja.
\q1 
\v 16 U desnici njenoj je dugi život,
\q2 a u njenoj levici su bogatstvo i ugled.
\q1 
\v 17 Putevi su njeni putevi blagi
\q2 i sve njene staze su mirne.
\q1 
\v 18 Ona je drvo života onima koji je se drže
\q2 i blagosloveni su oni koji su čvrsto prionuli uz nju.
\b
\q1 
\v 19 Mudrošću je Gospod utemeljio zemlju
\q2 i razboritošću je postavio nebesa.
\q1 
\v 20 Znanje je njegovo provalilo bezdane
\q2 i oblaci su prokapali rosom.
\b
\q1 
\v 21 Sine moj, ne skreći pogled sa toga
\q2 i očuvaj istinsku mudrost i domišljatost;
\q1 
\v 22 biće to život tvojoj duši
\q2 i privezak oko tvoga vrata.
\q1 
\v 23 Tada ćeš spokojno koračati svojim putem
\q2 i noga se tvoja neće spotaknuti.
\q1 
\v 24 Kad počineš, nećeš se bojati,
\q2 kada legneš slatko ćeš da spavaš.
\q1 
\v 25 Nećeš se bojati kad strahota bane,
\q2 kada zlikovačko razaranje dođe.
\q1 
\v 26 Jer će Gospod pored tebe biti
\q2 i čuvaće tvoj korak od zamke.
\b
\q1 
\v 27 Ne uskraćuj pomoć nevoljnicima
\q2 kada su ti ruke kadre da učine.
\q1 
\v 28 Nemoj reći svome bližnjem –
\q2 „Sutra dođi i daću ti“ –
\q2 kada imaš to kod sebe.
\q1 
\v 29 Ne smišljaj zlobu bližnjemu svome,
\q2 jer on sa tobom spokojno živi.
\q1 
\v 30 Ne svađaj se s bilo kime bez razloga
\q2 ako ti nije naneo zlo.
\b
\q1 
\v 31 Ne zavidi nasilniku
\q2 i ne biraj bilo koju od staza njegovih.
\b
\q1 
\v 32 Jer je Gospodu oduran pokvarenjak,
\q2 a blizak je s čestitima.
\q1 
\v 33 Na kući je zlikovačkoj Gospodnje prokletstvo,
\q2 a njegovi blagoslovi na kući pravednika.
\q1 
\v 34 Rugačima Bog se ruga,
\q2 a poniznima iskazuje milost.
\q1 
\v 35 Mudri ljudi naslediće ugled,
\q2 a bezumnima sleduje sramota.
\c 4
\s1 Zadobij mudrost po svaku cenu
\q1 
\v 1 Deco, poslušajte očev prekor
\q2 i budite pažljivi da se naučite iz pouke.
\q1 
\v 2 Jer ja vam dobar savet dajem,
\q2 stoga ne zapostavljajte pouku moju.
\q1 
\v 3 Jer ja sam bio očev sin
\q2 i mili jedinac majke svoje.
\q1 
\v 4 On me je učio i govorio mi:
\q2 „Neka ti srce prione čvrsto uz reči moje,
\q2 drži se mojih zapovesti i živećeš.
\q1 
\v 5 Stiči mudrost! Stiči razumevanje!
\q2 Ne zaboravljaj i ne otuđuj se od onoga što ti kazujem.
\q1 
\v 6 Ne napuštaj mudrost i ona će te čuvati,
\q2 voli je i braniće te.
\q1 
\v 7 Mudrost je najvažnija! Stiči mudrost!
\q2 Sa svom svojom stečevinom ti stiči razumevanje.
\q1 
\v 8 Uzdiži je i uzdignuće te,
\q2 veličaće te jer si je prigrlio.
\q1 
\v 9 Prelepi venac će ti staviti na glavu,
\q2 daće ti slavnu krunu.“
\b
\q1 
\v 10 Sine moj, poslušaj i prihvati reči moje
\q2 i mnogo će godina života tvoga biti.
\q1 
\v 11 Upućujem te putem mudrosti
\q2 i pravednim te stazama vodim.
\q1 
\v 12 Noge ti neće klecati dok hodaš
\q2 i nećeš posrtati dok budeš trčao.
\q1 
\v 13 Drži se opomene i ne napuštaj je.
\q2 Brani je, jer ti je ona život.
\q1 
\v 14 Ne idi stazom pokvarenjaka
\q2 i ne sledi put zlikovaca.
\q1 
\v 15 Kloni ga se i ne idi njime,
\q2 okreni se od njega i idi dalje!
\q1 
\v 16 Jer oni ne spavaju ako zlo ne nanesu,
\q2 san im je ukraden ako koga ne sapletu.
\q1 
\v 17 Jer oni jedu hleb bezakonja
\q2 i nasilja vino piju.
\b
\q1 
\v 18 A staza je pravednika poput svetla zore koje osvaja
\q2 i svetli dok dan ne osvane.
\q1 
\v 19 Dok je staza pokvarenih mračna,
\q2 pa oni i ne znaju o šta se sve spotiču.
\b
\q1 
\v 20 Sine moj, pazi na moje reči
\q2 i prikloni uho svoje kazivanjima mojim.
\q1 
\v 21 Neka se ne odmiču od očiju tvojih
\q2 i čuvaj ih usred srca svoga.
\q1 
\v 22 Jer su one život onima što ih nađu
\q2 i zdravlje su celom telu njihovome.
\q1 
\v 23 Od svega što se čuva ti najviše čuvaj srce svoje,
\q2 jer su u njemu izvori života.
\q1 
\v 24 Od sebe odbaci nepošten govor
\q2 i obmanu usana daleko baci od sebe.
\q1 
\v 25 Oči tvoje nek gledaju pravo,
\q2 ispred sebe ti prikuj svoj pogled.
\q1 
\v 26 Poravnaj stazu koraka svoga
\q2 i bezbedni će biti svi tvoji putevi.
\q1 
\v 27 Ne skreći ni desno ni levo
\q2 i korak svoj ukloni od zla.
\c 5
\s1 Upozorenje protiv preljube
\q1 
\v 1 Sine moj, pazi na moju mudrost
\q2 i poslušaj dobro razboritost moju,
\q1 
\v 2 domišljatost da očuvaš
\q2 i usta da ti očuvaju znanje.
\q1 
\v 3 Jer sa usana bludnice med curi,
\q2 zavodljive reči mekše od ulja.
\q1 
\v 4 Ali na kraju je kao pelen gorka
\q2 i oštra kao mač dvosekli.
\q1 
\v 5 Noge joj silaze u smrt,
\q2 do Sveta mrtvih noge joj dopiru.
\q1 
\v 6 Ona ne mari za put života,
\q2 staze joj vrludaju, a ona to ne zna.
\b
\q1 
\v 7 Zato me poslušajte, deco,
\q2 i ne odstupajte od onoga što vam kazujem.
\q1 
\v 8 Zaobiđi je nadaleko
\q2 i ne primiči se ulazu njene kuće,
\q1 
\v 9 da ne bi drugima dao obraz svoj
\q2 i okrutnom čoveku godine svoje;
\q1 
\v 10 da tuđinci ne bi ispili ti snagu
\q2 i trud ti ostao u kući tuđina;
\q1 
\v 11 da ne bi kukao na svome svršetku
\q2 kada ti propadnu i telo i zdravlje.
\q1 
\v 12 I ti ćeš reći: „Kako sam mrzeo opomenu,
\q2 dok mi je srce preziralo ukor.
\q1 
\v 13 Nisam slušao glas svoga učitelja,
\q2 nisam poslušao vaspitače svoje.
\q1 
\v 14 Umalo nisam pao u svakojako zlo
\q2 usred zbora i usred zajednice.“
\b
\q1 
\v 15 Pij vodu sa svoga bunara,
\q2 žubor vodu sa izvora svoga.
\q1 
\v 16 Zar će se razlivati izvori tvoji po poljima
\q2 i potoci vode po trgovima?
\q1 
\v 17 Neka oni budu samo tvoji,
\q2 a ne tuđinaca što su sa tobom.
\q1 
\v 18 Da je blagosloven izvor tvoj!
\q2 Radovao se ti sa ženom mladosti svoje!
\q1 
\v 19 Ona ti je košuta voljena i srna mila.
\q2 Naslađuj se uvek grudima njenim,
\q2 ljubavlju njenom se opijaj stalno.
\q1 
\v 20 Zašto bi se opijao, sine moj,
\q2 sa preljubnicom i grlio nedra tuđe žene?
\b
\q1 
\v 21 Jer su svi čovekovi putevi pred Gospodnjim očima
\q2 i on ih odmerava.
\q1 
\v 22 Pokvarenjaka će porobiti krivice njegove,
\q2 biće sputan vezama njegovog greha.
\q1 
\v 23 I umreće, jer nije imao odgoj,
\q2 zastraniće zbog veličine svoje budalaštine.
\c 6
\s1 Upozorenje protiv bezumlja
\q1 
\v 1 Sine moj, ako jamčiš za bližnjega svoga
\q2 i ruku si pružio tuđincu;
\q1 
\v 2 vezan si rečima usta svojih,
\q2 obavezan svojim obećanjem.
\q1 
\v 3 Ti onda učini ovo, sine moj, da slobodan budeš,
\q2 jer si dopao rukama svog bližnjeg:
\q1 Idi, ponizi se
\q2 i saleći bližnjeg svog!
\q1 
\v 4 Ne daj sna očima svojim
\q2 i svojim kapcima da dremaju.
\q1 
\v 5 Otmi se kao srna lovcu,
\q2 kao ptica iz ruku ptičara.
\b
\q1 
\v 6 O, lenjivče, idi mravu,
\q2 sagledaj njegove puteve i postani mudar!
\q1 
\v 7 On nema ni vojvodu,
\q2 ni zapovednika, ni vladara,
\q1 
\v 8 ali sprema sebi hranu tokom leta,
\q2 tokom žetve skuplja sebi jelo.
\b
\q1 
\v 9 O, lenjivče, dokle ćeš da planduješ,
\q2 kada ćeš od sna da se preneš?
\q1 
\v 10 Još malo snova, još malo dremeža,
\q2 još malo dokono da sklopiš ruke;
\q1 
\v 11 i doći će tvoje siromaštvo kao skitnica
\q2 i nemaština kao nasilnik.
\b
\q1 
\v 12 Ništarija i pokvarenjak se skita
\q2 i nepošteno govori;
\q2 
\v 13 namiguje svojim očima,
\q2 podgurkuje nogama,
\q2 upire prstima;
\q2 
\v 14 izopačenosti su mu u srcu,
\q2 svakog časa smišlja zlo i unosi razdor.
\q1 
\v 15 Zato će nenadano stići njegova propast,
\q2 u trenu će biti slomljen, a leka mu neće biti.
\b
\q1 
\v 16 Šest je stvari koje Gospod mrzi
\q2 i sedam mu se duši ogadilo:
\q3 
\v 17 oči uznosite,
\q3 jezik lažljiv,
\q3 ruke koje liju nevinu krv;
\q3 
\v 18 srce što smišlja opake naume,
\q3 noge što srljaju i na zlo su brze;
\q3 
\v 19 Lažljiv svedok što laže čim zine
\q3 i ko seje razdor među braćom.
\s1 Upozorenje protiv preljube
\q1 
\v 20 Sine moj, drži zapovest oca svoga
\q2 i ne zaboravljaj pouku majke svoje.
\q1 
\v 21 Vezuj ih istrajno za srce svoje
\q2 i obmotaj oko svoga vrata.
\q1 
\v 22 Vodiće te dok budeš hodao,
\q2 čuvaće te dok budeš spavao
\q2 i govoriće ti kada se probudiš.
\q1 
\v 23 Jer je zapovest svetiljka i pouka je svetlo,
\q2 a prekori odgoja staza su života.
\q1 
\v 24 Čuvaće te od opake žene,
\q2 od laskavog jezika žene preljubnice.
\b
\q1 
\v 25 Ne poželi u svom srcu njenu lepotu,
\q2 ne daj da te pogledom opčini;
\q1 
\v 26 jer zbog bludnice čovek spadne na komad hleba
\q2 i tuđa žena lovi dragocenu dušu.
\q1 
\v 27 Može li čovek da u nedra žeravicu stavi,
\q2 a da mu se odeća ne zapali?
\q1 
\v 28 Može li čovek da hoda po uglju vrelom,
\q2 a da ne opeče stopala svoja?
\q1 
\v 29 Tako je i sa onim ko odlazi ženi svoga bližnjeg,
\q2 neće proći nekažnjeno svaki koji je se dotiče.
\b
\q1 
\v 30 Ljudi ne sramote lopova kada krade
\q2 da nasiti svoju dušu, jer je gladan;
\q1 
\v 31 ali kad uhvaćen bude, nadoknadiće sedmostruko,
\q2 daće svako dobro iz kuće svoje.
\q1 
\v 32 Bezuman je ko sa ženom preljubu čini,
\q2 a to radi onaj ko satire samog sebe.
\q1 
\v 33 Takav dopada i rana i srama,
\q2 njegova se bruka neće izbrisati.
\b
\q1 
\v 34 Zbog ljubomore je muž gnevan
\q2 i nema milosti u danu osvete.
\q1 
\v 35 On ne gleda ni na kakav otkup,
\q2 ne pristaje ni na velik mito.
\c 7
\s1 Upozorenje protiv preljubnice
\q1 
\v 1 Sine moj, drži se mojih reči
\q2 i zapovesti mojih, u sebi ih čuvaj.
\q1 
\v 2 Moje zapovesti čuvaj i živećeš,
\q2 pouku moju ko zenicu svoga oka.
\q1 
\v 3 Veži ih oko prstiju svojih,
\q2 upiši ih na ploču srca!
\q1 
\v 4 Mudrosti kaži „Sestro moja!“
\q2 i „rođenom“ pronicljivost zovi;
\q1 
\v 5 da te čuvaju od žene tuđinke,
\q2 od preljubnice slatkorečive.
\b
\q1 
\v 6 Elem, na prozoru kuće svoje,
\q2 kroz rešetke gledao sam,
\q1 
\v 7 posmatrao sam lakoverne
\q2 i među mladićima zapazio bezumnoga momka.
\q1 
\v 8 Prolazio je ulicom, pored njenog ugla
\q2 i išao prema njenoj kući,
\q1 
\v 9 potkraj dana, kad je sumrak,
\q2 usred noći i pomrčine.
\b
\q1 
\v 10 I gle, presrete ga žena u odeći bludnice
\q2 i prevejanog srca;
\q1 
\v 11 napadna, jogunasta,
\q2 noge je u kući ne drže;
\q1 
\v 12 sad je na ulici, sad je na trgu,
\q2 na svakom ugla vreba u zasedi.
\q1 
\v 13 I zgrabi ga, poljubi ga bez stida na licu
\q2 i reče mu:
\b
\q1 
\v 14 „Imam kući meso žrtava mira,
\q2 jer sam danas ispunila zavete svoje.
\q1 
\v 15 Zato sam izašla da te sretnem,
\q2 baš tebe da tražim.
\q2 I našla sam te.
\q1 
\v 16 Svoj sam krevet ukrasila zastorima,
\q2 šarenim lanom iz Egipta;
\q1 
\v 17 smirnom, alojom i cimetom
\q2 ležaj sam namirisala.
\q1 
\v 18 Dođi! Do jutra se opijajmo ljubavlju svojom.
\q2 Hajde da se nauživamo u ljubavi!
\q1 
\v 19 Jer muž nije u kući svojoj,
\q2 na daleki put je otišao;
\q1 
\v 20 sa sobom je poneo kesu s novcem
\q2 i neće doći kući do dana punog meseca.“
\b
\q1 
\v 21 Tako ga je namamila svojom uverljivom pričom,
\q2 nagovorila ga svojim zavodljivim usnama.
\q1 
\v 22 I on je odmah krenuo za njom,
\q2 kao vo na klanje išao je
\q1 i kao bezumnik okovan za kaznu;
\q2 
\v 23 dok mu strela ne probode jetru,
\q1 kao ptica što u zamku srlja
\q2 on i ne zna da tu glavu gubi.
\b
\q1 
\v 24 Zato me poslušajte, sinovi,
\q2 i pazite na ono što vam govorim!
\q1 
\v 25 Neka ti srce ne zastrani na puteve njene
\q2 i ne lutaj po njenim stazama.
\q1 
\v 26 Jer mnoge smrtno ranjene je oborila
\q2 i nema broja ljudima koje je pobila.
\q1 
\v 27 Kuća je njena na putevima za Svet mrtvih,
\q2 a oni silaze u odaje smrti.
\c 8
\s1 Mudrost poziva
\q1 
\v 1 Zar to mudrost ne poziva,
\q2 ne diže li razboritost glas svoj?
\q1 
\v 2 Eno je na uzvišicama, pokraj puta,
\q2 na raskršćima se postavila;
\q1 
\v 3 na kapijama, na ulazima u grad,
\q2 na ulaznim vratima ona viče:
\q1 
\v 4 „Ljudi, vas dozivam
\q2 i glas dižem celom čovečanstvu!
\q1 
\v 5 Razboritosti se naučite, lakoverni ljudi,
\q2 urazumite srce, nerazumni.
\q1 
\v 6 Slušajte, jer ja objavljujem dragocene stvari,
\q2 čestite će biti izreke usana mojih.
\q1 
\v 7 Baš istinu kazivaću
\q2 jer je zloba mrska usnama mojim.
\q1 
\v 8 Pravedne su sve reči mojih usta
\q2 i nema u njima izopačenosti i nepoštenja.
\q1 
\v 9 Sve su one jasne razboritom
\q2 i ispravne onima što znanje stiču.
\q1 
\v 10 Prihvatite pouku moju, a ne srebro,
\q2 izaberite znanje pre nego suvo zlato.
\q1 
\v 11 Jer je mudrost od dragulja bolja
\q2 i sva joj uživanja ni prineti nisu.
\b
\q1 
\v 12 Ja, mudrost, s razboritošću živim,
\q2 pronalazim znanje i domišljatost.
\q1 
\v 13 Bogobojaznost znači mrzeti zlo,
\q2 jer ja mrzim bahati ponos,
\q2 put zlobe i usta pokvarena.
\q1 
\v 14 U meni je savet, pouzdana mudrost.
\q2 U meni je umnost, ja imam snagu.
\q1 
\v 15 Carevi vladaju uz moju pomoć
\q2 i vladari dele pravdu.
\q1 
\v 16 Glavari, knezovi i sve pravedne sudije
\q2 vladaju uz moju pomoć.
\q1 
\v 17 Ja volim sve koji vole mene,
\q2 nalaze me svi koji me pomno traže.
\q1 
\v 18 Čast, imetak, trajno blagostanje
\q2 i pravednost su sa mnom.
\q1 
\v 19 Od zlata, od suvoga zlata je rod moj bolji,
\q2 i dobit moja bolja od probranog srebra.
\q1 
\v 20 Ja hodam putem pravednosti
\q2 i posred staza pravde,
\q1 
\v 21 da onima koji me vole dam nasledstvo
\q2 i njihove riznice napunim.
\b
\q1 
\v 22 Mene je imao Gospod na početku njegovog puta,
\q2 još pre dela svojih drevnih.
\q1 
\v 23 Postavljena sam od davnina,
\q2 od iskona, pre postanja zemlje.
\q1 
\v 24 Rođena sam kad bezdana još nije bilo,
\q2 kada nije bilo ni izvora obilnih voda.
\q1 
\v 25 Pre planina postavljenih
\q2 i pre brda rođena sam,
\q1 
\v 26 dok još zemlju on stvorio nije,
\q2 ni polja, ni prvo tlo sveta.
\q1 
\v 27 Kada je stvorio nebesa, ja sam bila tamo,
\q2 kada je ocrtavao horizont nad licem bezdana;
\q1 
\v 28 kada je gore učvršćivao oblake
\q2 i kada su nabujali izvori bezdana;
\q1 
\v 29 kada je moru postavio njegove obale,
\q2 kako voda ne bi prelazila njegovu zapovest,
\q2 i kada je označio temelje zemljine.
\q1 
\v 30 Bila sam uz njega kao graditeljka,
\q2 bila sam mu radost svakodnevna,
\q2 veselila se pred njim stalno;
\q1 
\v 31 veselila se po svetu, po njegovoj zemlji
\q2 i radovala se sa potomcima ljudi.
\b
\q1 
\v 32 Zato me, deco, poslušajte.
\q2 O, kako su blagosloveni oni koji se drže mojih puteva!
\q1 
\v 33 Poslušajte pouku moju,
\q2 radite mudro i ne odbacujte je.
\q1 
\v 34 Kako je blagosloven čovek koji me sluša,
\q2 koji svakodnevno bdije na mojim vratima
\q2 i pazi na dovracima vrata mojih!
\q1 
\v 35 Jer ko mene nađe, našao je život
\q2 i dobio naklonost Gospodnju.
\q1 
\v 36 Ali ko mene ne nađe, sebi samom škodi,
\q2 a svi koji me mrze vole smrt.“
\c 9
\s1 Poziv mudrosti i ludosti
\q1 
\v 1 Mudrost je kuću svoju sazidala
\q2 i za nju sedam stubova isklesala.
\q1 
\v 2 Poklala je svoju stoku, vino svoje začinila,
\q2 svoju trpezu postavila;
\q1 
\v 3 poslala je sluškinje svoje
\q2 i poziva sa najviših gradskih mesta:
\q2 
\v 4 „Neka ovde svrati ko god je lakoveran!“
\q1 A bezumnome govori:
\q2 
\v 5 „Dođite, jedite moju hranu
\q2 i pijte vino koje sam začinila!
\q1 
\v 6 Okanite se lakoverja i živećete,
\q2 napredujte razumnim putem.“
\b
\q1 
\v 7 Sramotu na sebe navlači ko podsmevača savetuje,
\q2 sebi škodi onaj ko kori zlikovca.
\q1 
\v 8 Ne prekorevaj podsmevača da te ne bi zamrzeo,
\q2 prekorevaj mudrog i voleće te.
\q1 
\v 9 Reci mudrom i biće mudriji,
\q2 pouči pravednoga i učeniji će biti.
\b
\q1 
\v 10 Mudrost otpočinje bogobojaznošću
\q2 i znanje poznavanjem Svetog.
\q1 
\v 11 Sa mnom će se dani tvoji umnožiti
\q2 i godina tvog života biće mnogo.
\q1 
\v 12 Ako si mudar, mudar si za svoje \add dobro\add*,
\q2 a ako si podsmevač, to ti je na teret.
\b
\q1 
\v 13 Bezumlje je žena goropadna,
\q2 lakoverna i ničem poučena.
\q1 
\v 14 Ona sedi na vratima svoje kuće,
\q2 na gradskim uzvišenjima,
\q1 
\v 15 dovikuje onima što putem prolaze
\q2 i stazama svojim pravo idu:
\q2 
\v 16 „Neka ovde svrati ko god je lakoveran!“
\q1 A bezumnome govori:
\q2 
\v 17 „Slatke li su ukradene vode,
\q2 ukusan li je hleb iz potaje!“
\q1 
\v 18 Ali on ne zna da su tamo pokojnici,
\q2 da su njene zvanice u dubinama Sveta mrtvih.
\c 10
\ms1 Priče Solomonove
\p 
\v 1 Mudre priče Solomona:
\q1 Mudar sin raduje svog oca,
\q2 a bezuman sin je žalost majci svojoj.
\b
\q1 
\v 2 Beskorisno je nepošteno bogatstvo,
\q2 a pravednost izbavlja od smrti.
\b
\q1 
\v 3 Ne da Gospod da je gladna duša pravednika,
\q2 a žudnju zlikovca odbacuje.
\b
\q1 
\v 4 Siromah je ko god radi rukama lenjivim,
\q2 a bogatstvo stiču ruke marljivih.
\b
\q1 
\v 5 Mudar je sin koji leti sakuplja,
\q2 a sramotno radi sin što o žetvi spava.
\b
\q1 
\v 6 Blagoslovi su nad glavom pravednika,
\q2 a usta zlikovaca nasilje skrivaju.
\b
\q1 
\v 7 Blaženo je sećanje na pravednika,
\q2 a spomen na zlikovca će istruliti.
\b
\q1 
\v 8 Čovek mudrog srca prihvata zapovesti,
\q2 a blebetavi bezumnik će satrven biti.
\b
\q1 
\v 9 Spokojno živi ko čestito živi,
\q2 a ko nakaradno živi biće razotkriven.
\b
\q1 
\v 10 Jad zadaje ko okom namiguje,
\q2 a blebetalo će satrveno biti.
\b
\q1 
\v 11 Usta su pravednikova vrelo života,
\q2 a usta zlikovaca nasilje skrivaju.
\b
\q1 
\v 12 Mržnja zameće svađu,
\q2 a ljubav sve grehe pokriva.
\b
\q1 
\v 13 Mudrost ćeš naći na usnama oštroumnog,
\q2 a batina je za leđa bezumnoga.
\b
\q1 
\v 14 Mudri ljudi sabiraju znanje,
\q2 a brbljiva usta blizu su propasti.
\b
\q1 
\v 15 Bogatstvo je bogatome poput utvrđenja,
\q2 a siromasima siromaštvo njihovo poput ruševine.
\b
\q1 
\v 16 Pravedniku je život nagrada,
\q2 a kazna za grehe naknada zlikovcu.
\b
\q1 
\v 17 Na stazi života je onaj ko pazi na opomenu,
\q2 a tumara onaj ko ne mari za ukor.
\b
\q1 
\v 18 Bezumnik je ko prikriva mržnju lažljivim usnama,
\q2 a širi klevetu.
\b
\q1 
\v 19 Kad je reči mnogo, greh je neizbežan;
\q2 razborito čini onaj ko zauzda usta.
\b
\q1 
\v 20 Srebro je probrano pravednikov jezik,
\q2 a srce zlikovca male je vrednosti.
\b
\q1 
\v 21 Mnoge hrane usta pravednika,
\q2 a bezumni ginu zbog bezumlja.
\b
\q1 
\v 22 Gospodnji blagoslov obogaćuje
\q2 i tegobu sa sobom ne nosi.
\b
\q1 
\v 23 Zlobniku je zloba ko zabava,
\q2 a mudrost je za promišljenog.
\b
\q1 
\v 24 Zlikovca stiže ono čega se boji,
\q2 a pravednom se želja ispunjava.
\b
\q1 
\v 25 Kao kad prohuji vihor vetar, tako ni zlikovca nema,
\q2 a pravednikovi temelji su večni.
\b
\q1 
\v 26 Kao sirće zubima i dim očima,
\q2 takav je lenština onome ko ga uposli.
\b
\q1 
\v 27 Bogobojaznost umnožava dane,
\q2 a godine zlikovaca će se skratiti.
\b
\q1 
\v 28 Pravedni se raduju u nadi,
\q2 a nada će zlobnih da ishlapi.
\b
\q1 
\v 29 Put Gospodnji je tvrđava čestitome,
\q2 a propast za zlotvore.
\b
\q1 
\v 30 Pravednika neće doveka poljuljati,
\q2 a zlotvori neće naseliti zemlju.
\b
\q1 
\v 31 Mudrošću rađaju usta pravednika,
\q2 a jezik će razvratnika iščupan da bude.
\b
\q1 
\v 32 Uživanje nije strano pravednim usnama,
\q2 a ni razvrat ustima zlikovca.
\c 11
\q1 
\v 1 Gospodu su gadne terazije lažne,
\q2 a tegovi tačni njemu su milina.
\b
\q1 
\v 2 Kada gordost dođe, dođe i sramota,
\q2 a mudrost je u krotkim ljudima.
\b
\q1 
\v 3 Čestitost vodi poštene,
\q2 a nevernike upropašćuje dvoličnost njihova.
\b
\q1 
\v 4 Nema koristi od bogatstva u dan gneva,
\q2 a pravednost od smrti izbavlja.
\b
\q1 
\v 5 Pravednost besprekornom put ravna,
\q2 a zlobnik pada zbog zlobe svoje.
\b
\q1 
\v 6 Pravednost izbavlja neporočne,
\q2 a pokvareni se hvataju u žudnji.
\b
\q1 
\v 7 Kada umre pokvarenjak, umire i nada,
\q2 propada mu nadanje u snagu.
\b
\q1 
\v 8 Od nevolje je izbavljen pravednik,
\q2 a zlikovac stiže na njegovo mesto.
\b
\q1 
\v 9 Bezbožnik ustima ruši bližnjeg svoga,
\q2 a znanje spasava pravednika.
\b
\q1 
\v 10 U napretku pravednika grad se raduje,
\q2 a od sreće kliče kada stradaju zlikovci.
\b
\q1 
\v 11 Blagoslovom čestitih grad se uzdiže,
\q2 a ruši se zbog usta pokvarenih.
\b
\q1 
\v 12 Bezuman je ko prezire bližnjeg svoga,
\q2 a razborit čovek ćuti.
\b
\q1 
\v 13 Klevetnik se skita i otkriva tajne,
\q2 a ko je vernog duha taj ćuti o tome.
\b
\q1 
\v 14 Narod propada gde nema mudrog saveta,
\q2 i uspeh je u mnogim savetnicima.
\b
\q1 
\v 15 Zlopati se onaj ko jamči za tuđinca,
\q2 a bezbedan je čovek koji mrzi da jamči.
\b
\q1 
\v 16 Blagonaklona žena zavređuje čast,
\q2 a okrutni ljudi blago osvajaju.
\b
\q1 
\v 17 Milostiv čovek čini dobro duši svojoj,
\q2 a silnik samom sebi škodi.
\b
\q1 
\v 18 Pokvarenjak zadobija nepoštenu nadnicu,
\q2 a ko seje pravdu dobija poštenu nadnicu.
\b
\q1 
\v 19 Život daje stamena pravednost,
\q2 a u smrt hrli onaj što zlo čini.
\b
\q1 
\v 20 Gospodu je gadno srce pokvarenih,
\q2 a uživanje su mu ljudi besprekornog puta.
\b
\q1 
\v 21 Nesumnjivo je da zlikovac neće proći nekažnjeno,
\q2 a potomci pravednika biće izbavljeni.
\b
\q1 
\v 22 Lepa žena koja se odrekla pameti,
\q2 zlatna je brnjica na njušci krmače.
\b
\q1 
\v 23 Želja pravednika je samo na dobro,
\q2 a gnevna je nada zlikovaca.
\b
\q1 
\v 24 Neko prosipa, a opet ima više,
\q2 a neko čuva i ne da šta bi trebalo, pa ipak osiromaši.
\b
\q1 
\v 25 Darežljiva duša biće nagrađena
\q2 i napojen onaj koji druge poji.
\b
\q1 
\v 26 Ljudi kunu onog ko zadržava žito,
\q2 a blagoslov daju onom što ga prodaje.
\b
\q1 
\v 27 Ko predano traži dobro, traži naklonosti,
\q2 a ko traga za zlom, ono ga i stiže.
\b
\q1 
\v 28 Pašće svako ko se uzda u svoje bogatstvo,
\q2 a pupiće pravednici ko zelena grana.
\b
\q1 
\v 29 Ko zapusti porodicu naslediće vetar,
\q2 bezumnik će biti sluga srcu mudrom.
\b
\q1 
\v 30 Plod pravednika je drvo života
\q2 i mudar je onaj koji zadobija duše.
\b
\q1 
\v 31 Gle, već je i pravednik na zemlji nagrađen,
\q2 a kamoli zločinac i grešnik neće biti!
\c 12
\q1 
\v 1 Ko voli opomenu voli znanje,
\q2 a prostak je ko prezire ukor.
\b
\q1 
\v 2 Dobar čovek dobija Gospodnju naklonost,
\q2 a on proklinje čoveka koji pravi spletke.
\b
\q1 
\v 3 Pokvarenošću se niko neće učvrstiti,
\q2 a koren je pravednika nepokolebljiv.
\b
\q1 
\v 4 Čestita je žena kruna mužu svome,
\q2 a žena raskalašna mu je kao trulež u kostima.
\b
\q1 
\v 5 Pravedni su naumi pravednika,
\q2 a saveti pokvarenih su obmana.
\b
\q1 
\v 6 Reči zlih ljudi krv vrebaju u zasedi,
\q2 a čestiti se ustima svojim oslobađaju.
\b
\q1 
\v 7 Zlikovci se ruše i više ih nema,
\q2 a dom pravednika istrajava.
\b
\q1 
\v 8 Čovek se ceni prema razboritosti svojoj,
\q2 a srce pokvarenjaka biće prezreno.
\b
\q1 
\v 9 Bolji je neugledan čovek, a sa slugom,
\q2 nego onaj što uzdiže sebe, a nema da jede.
\b
\q1 
\v 10 Pravednik se brine i za dobro svojih životinja,
\q2 a zlobnici su okrutni i kad se smiluju.
\b
\q1 
\v 11 Izobilje hrane ima onaj koji svoju zemlju radi,
\q2 a šupljoglavac teži bezvrednim stvarima.
\b
\q1 
\v 12 Zlobnik žudi za zlim plenom,
\q2 a koren pravednika je plodonosan.
\b
\q1 
\v 13 Zlobniku je zamka u grehu usana,
\q2 a pravednik se kloni nevolje.
\b
\q1 
\v 14 Čovek se nasiti dobra plodom usta svojih
\q2 i vrati mu se sve što rukama radi.
\b
\q1 
\v 15 Bezumnik smatra da živi ispravno,
\q2 ali je mudar onaj ko sluša savet.
\b
\q1 
\v 16 Bezumnikov se gnev odmah prepozna,
\q2 a ko je obazriv pokriva sramotu.
\b
\q1 
\v 17 Kad verni svedok svedoči, on objavljuje pravdu,
\q2 a lažljivi svedok obmanjuje.
\b
\q1 
\v 18 Ima ljudi koji govore nesmotreno kao da bodu mačem,
\q2 a jezik mudrih leči.
\b
\q1 
\v 19 Istinoljubiva usta će doveka utvrđena biti,
\q2 a lažljivi jezik će nestati dok trepnem.
\b
\q1 
\v 20 Obmana je u srcu onih što smišljaju zlo,
\q2 a radost sleduje one što zovu na mir.
\b
\q1 
\v 21 Pravednika ne snalazi nikakva nevolja,
\q2 a zlikovci su puni nemira.
\b
\q1 
\v 22 Lažljive su usne odurne Gospodu,
\q2 a milina su mu istinotvorci.
\b
\q1 
\v 23 Obazriv čovek ne otkriva znanje,
\q2 a srce budalastih razglašava bezumlje.
\b
\q1 
\v 24 Ruka marljivih ljudi će vladati,
\q2 a lenština mora da robuje.
\b
\q1 
\v 25 Srce što strepi povija čoveka,
\q2 a dobra reč ga vedri.
\b
\q1 
\v 26 Pravednik bira sebi prijatelja,
\q2 a nepravednike zavodi put njihov.
\b
\q1 
\v 27 Nema pečenja za lenštinu,
\q2 čoveku je blago marljivost njegova.
\b
\q1 
\v 28 Život je na putu pravednosti
\q2 i nema smrti na njenoj stazi.
\c 13
\q1 
\v 1 Mudar sin \add prihvata\add* očevo vaspitanje,
\q2 a podrugljivac ne sluša ukor.
\b
\q1 
\v 2 Čovek se nasiti dobra od ploda usta svojih,
\q2 a pokvarenjaci su gladni nasilja.
\b
\q1 
\v 3 Ko god čuva usta svoja čuva život svoj,
\q2 a propast sleduje onome ko širi svoje usne.
\b
\q1 
\v 4 Duša lenštine je gladna, ali nema ništa,
\q2 a duša se marljivih ljudi nahrani.
\b
\q1 
\v 5 Pravednik mrzi laž,
\q2 a zlobnik odurno i sramno postupa.
\b
\q1 
\v 6 Pravednost čuva put čestitog,
\q2 a nepravda obara grešnika.
\b
\q1 
\v 7 Neko sebe predstavlja bogatim, ali nema ništa,
\q2 a neko sebe predstavlja siromašnim, a prebogat je.
\b
\q1 
\v 8 Čovek bogatstvom otkupljuje dušu svoju,
\q2 a siromah i ne čuje pretnju.
\b
\q1 
\v 9 Svetlo pravednika blešti,
\q2 a svetiljka zlikovaca gasne.
\b
\q1 
\v 10 Bahatost jedino razdor izaziva,
\q2 a mudrost je kod onih koji primaju savet.
\b
\q1 
\v 11 Naglo stečeno bogatstvo se umanjuje,
\q2 a uvećava se ono sakupljano radom.
\b
\q1 
\v 12 Dugotrajno nadanje žalosti srce,
\q2 a ispunjena želja je kao drvo života.
\b
\q1 
\v 13 Ko prezire reč sebi samom škodi,
\q2 a ko strahuje od zapovesti nagrađen će biti.
\b
\q1 
\v 14 Mudračeva pouka vrelo je života
\q2 i odvraća od smrtnih zamki.
\b
\q1 
\v 15 Pronicljivost stiče naklonost,
\q2 a put nevernih je nepromenjiv.
\b
\q1 
\v 16 Svaki obazriv čovek radi prema znanju,
\q2 a bezumni širi bezumlje.
\b
\q1 
\v 17 Glasnik zla u zlo pada,
\q2 a svedok istine leči.
\b
\q1 
\v 18 Siromaštvo i sramota stižu onog ko ne mari za opomenu,
\q2 a počašćen će biti onaj ko prihvata ukor.
\b
\q1 
\v 19 Slatka je duši želja ispunjena,
\q2 a bezumniku je mrsko da se od zla odvrati.
\b
\q1 
\v 20 Biće mudar ko ide s mudrima,
\q2 a nastradaće ko se druži s bezumnima.
\b
\q1 
\v 21 Grešnike propast progoni,
\q2 a pravednici su dobrom nagrađeni.
\b
\q1 
\v 22 Dobar čovek ostavlja nasledstvo unucima,
\q2 a grešnikova se dobra čuvaju za pravednika.
\b
\q1 
\v 23 Obilje je hrane na neuzoranom polju siromaha,
\q2 ali ga nepravda odnosi.
\b
\q1 
\v 24 Ko svoj prut štedi mrzi svoga sina,
\q2 a voli ga ko ga na vreme kori.
\b
\q1 
\v 25 Kada jede, pravedniku se duša najede,
\q2 a stomak zlobnika ostaje gladan.
\c 14
\q1 
\v 1 Svaka mudra žena kući svoju kuću,
\q2 a bezumna je žena raskućuje rukama svojim.
\b
\q1 
\v 2 Gospoda se boji ko čestito živi,
\q2 a prezire ga onaj ko pokvareno živi.
\b
\q1 
\v 3 Bezumnikov govor je batina za leđa njegova,
\q2 a mudre čuvaju usta njihova.
\b
\q1 
\v 4 Gde volova nema i jasle su čiste,
\q2 u snazi je vola obilje plodova.
\b
\q1 
\v 5 Veran svedok ne govori laži,
\q2 a lažljivi svedok odiše lažima.
\b
\q1 
\v 6 Podrugljivac mudrost traži i ne nalazi je,
\q2 a poučen čovek znanje pronalazi lako.
\b
\q1 
\v 7 Idi od bezumnika,
\q2 od njega nećeš čuti pametne reči.
\b
\q1 
\v 8 Mudrošću obazriv čovek shvata put svoj,
\q2 a bezumlje bezumnih je obmana.
\b
\q1 
\v 9 Bezumnici se rugaju grehu,
\q2 a među čestitima je dobra volja.
\b
\q1 
\v 10 Srcu je poznata gorčina njegova
\q2 i tuđinac ne deli njegovo veselje.
\b
\q1 
\v 11 Kuća će zlobnika biti razorena,
\q2 a šator pravednika će procvetati.
\b
\q1 
\v 12 Neki put pred čovekom kao da je prav,
\q2 ali završava na putevima smrti.
\b
\q1 
\v 13 Srce boli i u smehu,
\q2 a i radost na svom kraju ponekad je žalost.
\b
\q1 
\v 14 Svojih će se puteva nasititi otpadnik,
\q2 a i dobar čovek \add biće sit\add* od svojih.
\b
\q1 
\v 15 Lakoverni svačemu veruje,
\q2 a obazriv pazi na svoj korak.
\b
\q1 
\v 16 Mudar se čovek boji greha, kloni ga se,
\q2 a nemudar je raspojasan, u sebe siguran.
\b
\q1 
\v 17 Budalasto radi čovek koji brzo plane,
\q2 a i spletkaroš je omražen.
\b
\q1 
\v 18 Lakovernim sleduje bezumlje,
\q2 a obazrivi se znanjem kite.
\b
\q1 
\v 19 Pred dobrim će se ljudima zlobnici klanjati
\q2 i pokvarenjaci pred vratima pravednih.
\b
\q1 
\v 20 I susedu svome mrzak je siromah,
\q2 a mnogo je onih što vole bogatoga.
\b
\q1 
\v 21 Grešan je čovek što prezire bližnjeg svoga,
\q2 a blagosloven je onaj koji je naklonjen poniznima.
\b
\q1 
\v 22 Ne zastranjuju li spletkaroši?
\q2 Milost i istina onima što dobro smišljaju.
\b
\q1 
\v 23 Od svakog \add vrednoga\add* rada dolazi zarada,
\q2 a od praznih priča samo oskudica.
\b
\q1 
\v 24 Mudrima je kruna njihovo bogatstvo,
\q2 nemudrost je nemudrog glupava.
\b
\q1 
\v 25 Istinoljubiv svedok spasava živote,
\q2 a lažljivi slaže čim zine.
\b
\q1 
\v 26 U bogobojaznosti je pouzdanje jakom
\q2 i utočište deci njegovoj.
\b
\q1 
\v 27 Vrelo je života bogobojaznost
\q2 i odvraća od smrtnih zamki.
\b
\q1 
\v 28 Careva je slava u mnoštvu naroda,
\q2 a kad življa nema, tad vladar propada.
\b
\q1 
\v 29 Ko se sporo srdi vrlo je razborit,
\q2 a ko brzo plane veliča bezumlje.
\b
\q1 
\v 30 Zdravo srce – zdravo telo;
\q2 ljubomora – trulež u kostima.
\b
\q1 
\v 31 Ko tlači ubogog sramoti mu Sazdatelja,
\q2 a slavi ga onaj što se ubogom smiluje.
\b
\q1 
\v 32 Opaki će srušen biti opakošću svojom,
\q2 a pravednik i u smrti utočište ima.
\b
\q1 
\v 33 Mudrost počiva u srcu razumnog čoveka,
\q2 čak je i u nutrini bezumnika obelodanjena.
\b
\q1 
\v 34 Pravednost uzdiže narod,
\q2 a greh je sramota narodu.
\b
\q1 
\v 35 Car poštuje slugu što čestito radi,
\q2 a gnevan je na onoga što radi sramotno.
\c 15
\q1 
\v 1 Blagi odgovor utišava gnev,
\q2 a gruba reč pokreće jarost.
\b
\q1 
\v 2 Jezik mudrih dobro vlada znanjem,
\q2 a usta bezumnih bljuju bezumljem.
\b
\q1 
\v 3 Gospodnje su oči na svakome mestu,
\q2 motreći na zle i na dobre.
\b
\q1 
\v 4 Zdrav je jezik ko drvo života,
\q2 a duh slama jezik pogan.
\b
\q1 
\v 5 Bezumnik prezire opomenu svoga oca,
\q2 a razborit je ko mari za ukor.
\b
\q1 
\v 6 Veliko je blago u domu pravednika,
\q2 a zlobniku je muka da zaradi.
\b
\q1 
\v 7 Znanje rasipaju usta mudrih ljudi,
\q2 što ne čini srce bezumnika.
\b
\q1 
\v 8 Gadna je Gospodu žrtva zlikovaca,
\q2 molitva čestitih njemu je milina.
\b
\q1 
\v 9 Gospodu je mrzak put zlobnika,
\q2 a voli onoga koji pravdu sledi.
\b
\q1 
\v 10 Nemilo je poučenje za onoga ko se odriče puta,
\q2 a umreće onaj ko mrzi prekor.
\b
\q1 
\v 11 Pred Gospodom su i Svet mrtvih i trulež mrtvih,
\q2 a kamoli srca ljudskih potomaka.
\b
\q1 
\v 12 Podrugljivac ne voli onoga koji ga kori
\q2 i ne ide kod mudrih ljudi.
\b
\q1 
\v 13 Veselo srce vedri lice,
\q2 žalosno srce slama duh.
\b
\q1 
\v 14 Razborito srce teži znanju,
\q2 a usta se bezumnika bezumljem hrane.
\b
\q1 
\v 15 Nemili su svi dani nevoljnika,
\q2 a čovek se dobrog srca gosti neprestano.
\b
\q1 
\v 16 Bolje je i malo u bogobojaznosti,
\q2 nego blago silno i sa njim strepnja.
\b
\q1 
\v 17 Bolji je tanjir povrća u ljubavi,
\q2 nego utovljeni vo u mržnji.
\b
\q1 
\v 18 Gnevan čovek raspaljuje svađu,
\q2 a smireni čovek utišava sukob.
\b
\q1 
\v 19 Put lenštine je obrastao trnjem,
\q2 a put je čestitih poravnan.
\b
\q1 
\v 20 Mudar sin raduje oca,
\q2 a bezuman čovek prezire majku svoju.
\b
\q1 
\v 21 Bezumnika raduje bezumlje,
\q2 a razborit čovek ravno ide putem.
\b
\q1 
\v 22 Naumi se izjalove kad nema saveta,
\q2 a ostvare s mnoštvom savetnika.
\b
\q1 
\v 23 Čovek se raduje kad odgovori \add tačno\add*;
\q2 kako je dobra reč u pravo vreme!
\b
\q1 
\v 24 Staza života za razumnog prema gore vodi,
\q2 i ne da mu prema dole, u Svet mrtvih da skrene.
\b
\q1 
\v 25 Gospod ruši kuću gordih ljudi
\q2 i jača među udovice.
\b
\q1 
\v 26 Namere zlikovca gadne su Gospodu,
\q2 a čiste su \add mu\add* reči ljubaznosti.
\b
\q1 
\v 27 Kući svojoj bedu navaljuje ko nečasno i lakomo stiče,
\q2 a živeće onaj čovek kom se mito gadi.
\b
\q1 
\v 28 Srce pravednika promišlja odgovor,
\q2 a usta pokvarenih ljudi zlom bljuju.
\b
\q1 
\v 29 Gospod je daleko od pokvarenjaka,
\q2 a sluša molitvu pravednika.
\b
\q1 
\v 30 Bistar pogled i srce veseli,
\q2 a dobre vesti podmlađuju kosti.
\b
\q1 
\v 31 Uho koje sluša pouku života,
\q2 trajaće u društvu mudrih ljudi.
\b
\q1 
\v 32 Ko ne mari za opomenu, prezire sam sebe,
\q2 a ko sluša ukor stiče razboritost.
\b
\q1 
\v 33 Bogobojaznost je pouka mudrosti,
\q2 a pre časti dolazi poniznost.
\c 16
\q1 
\v 1 Čovek nešto srcem namerava,
\q2 ali od Gospoda je jezika odgovor.
\b
\q1 
\v 2 U očima svojim čoveku su čisti putevi,
\q2 ali Gospod proverava namere srca.
\b
\q1 
\v 3 Svoja dela prepusti Gospodu
\q2 i učvrstiće tvoje naume.
\b
\q1 
\v 4 Gospod je načinio sve za svoju svrhu,
\q2 pa čak i zlobnika za dan stradanja.
\b
\q1 
\v 5 Gospodu je mrsko svako uznosito srce.
\q2 Nema sumnje da taj neće proći nekažnjeno.
\b
\q1 
\v 6 Milošću i istinom otkupljuje se krivica
\q2 i bogobojaznost odvraća od zla.
\b
\q1 
\v 7 Kada su Gospodu mili čovekovi putevi,
\q2 on ga i sa neprijateljima njegovim miri.
\b
\q1 
\v 8 Bolje je i malo, a po pravdi,
\q2 nego obilje stečenog, a po nepravdi.
\b
\q1 
\v 9 Srce čovekovo smera svojim putem,
\q2 ali Gospod usmerava njegove korake.
\b
\q1 
\v 10 Car presuđuje nadahnutom objavom
\q2 i odluke mu nisu nepravedne.
\b
\q1 
\v 11 Pravedne su Gospodnje mere i terazije,
\q2 svi tegovi u torbi njegovo su delo.
\b
\q1 
\v 12 Gadost je kad carevi pokvareno rade,
\q2 jer se pravednošću učvršćuje presto.
\b
\q1 
\v 13 Carevi cene pravdoljubiva usta,
\q2 oni vole onog ko iskreno zbori.
\b
\q1 
\v 14 Careva je srdžba kao vesnik smrti
\q2 i mudar je čovek gasi.
\b
\q1 
\v 15 Život je u vedrini carevog lica,
\q2 naklonost je njegova kao oblak prolećne kiše.
\b
\q1 
\v 16 Koliko je bolje težiti mudrosti nego zlatu,
\q2 težiti umnosti više nego težiti srebru!
\b
\q1 
\v 17 Put čestitih je odvraćanje od zla,
\q2 život svoj čuva onaj ko svoj put sačuva.
\b
\q1 
\v 18 Pred propašću ide ponos
\q2 i pred padom ide duh nadmeni.
\b
\q1 
\v 19 S poniznima bolje biti ponizan,
\q2 nego plen deliti s bahatima.
\b
\q1 
\v 20 Dobro nalazi ko na reč pripazi
\q2 i kako je blagosloven onaj ko se u Gospoda pouzda!
\b
\q1 
\v 21 Promućurnim zovu onog srca mudrog
\q2 i ljubazne usne su uverljivije.
\b
\q1 
\v 22 Vrelo je života pronicljivost onima što je imaju,
\q2 a bezumlje je šiba bezumnima.
\b
\q1 
\v 23 Srce mudrome daje šta će da kaže
\q2 i usnama njegovim jača ubedljivu pouku.
\b
\q1 
\v 24 Medeno saće su reči ljubazne,
\q2 slast su duši i zdravlje kostima.
\b
\q1 
\v 25 Neki put pred čovekom kao da je prav,
\q2 ali završava na putevima smrti.
\b
\q1 
\v 26 Sebi radi ko god da radi,
\q2 jer ga gladna usta nagone na to.
\b
\q1 
\v 27 Ništarija iskopava zlo
\q2 i usne su mu poput vatre koja prlji.
\b
\q1 
\v 28 Spletkaroš spletke spliće
\q2 i klevetnik razdvaja bliske prijatelje.
\b
\q1 
\v 29 Nasilnik mami bližnjeg svoga
\q2 i groznim ga putem vodi;
\q1 
\v 30 namiguje očima i gadosti smišlja,
\q2 stiska usta i zlo postiže.
\b
\q1 
\v 31 Prelepa je kruna kosa seda
\q2 \add kad\add* se nađe na pravednom putu.
\b
\q1 
\v 32 Bolji je dugotrpljiv čovek od junaka,
\q2 i onaj koji sobom vlada od osvajača grada.
\b
\q1 
\v 33 U krilo se kocka baca,
\q2 ali od Gospoda dolazi svaka odluka njena.
\c 17
\q1 
\v 1 Bolji je i zalogaj suvog hleba u spokoju,
\q2 nego kuća puna žrtvenog mesa u svađi.
\b
\q1 
\v 2 Čestiti sluga će vladati nad nečasnim naslednikom
\q2 i deliće nasledstvo sa braćom.
\b
\q1 
\v 3 Topionica je za srebro i peć je za zlato,
\q2 a Gospod ispituje srca.
\b
\q1 
\v 4 Zlotvor pazi na usne zlikovačke,
\q2 a zavodnik sluša jezik razdora.
\b
\q1 
\v 5 Ko se ruga siromahu sramoti mu Sazdatelja,
\q2 nekažnjeno neće proći ko likuje zbog propasti.
\b
\q1 
\v 6 Unuci su starcima ko kruna
\q2 i dika su roditelji deci.
\b
\q1 
\v 7 Budali ne stoje usne besedničke,
\q2 a kamoli knezu usne lažljivice.
\b
\q1 
\v 8 Mito je za davaoca kao dragi kamen,
\q2 jer mu čini da uspeva gde se god okrene.
\b
\q1 
\v 9 Ko prestup pokriva, teži ljubavi,
\q2 a ko priču prepričava razdvaja bliske prijatelje.
\b
\q1 
\v 10 Ukor razumnoga proniče duboko,
\q2 više nego nerazumnog stotinu udaraca.
\b
\q1 
\v 11 Zlikovcu je samo do meteža stalo,
\q2 ali će mu biti poslan surovi poslanik.
\b
\q1 
\v 12 Bolje je čoveku da nabasa na medvedicu kojoj su oteli medvediće,
\q2 nego na bezumnika u ludosti njegovoj.
\b
\q1 
\v 13 Ko na dobro zlom uzvraća,
\q2 nikada mu od zla neće počinuti kuća.
\b
\q1 
\v 14 Ko prepirku otpočinje, taj bujicu oslobađa.
\q2 Zato se zavade kloni pre nego što šikne.
\b
\q1 
\v 15 I onaj što opravdava krivog i onaj što okrivljuje pravog –
\q2 obojica su mrski Gospodu.
\b
\q1 
\v 16 Čemu blago u ruci nemudrog,
\q2 kad namere nema da mudrost zatraži?
\b
\q1 
\v 17 Prijatelj voli u svako doba,
\q2 a i brat se za nevolju rađa.
\b
\q1 
\v 18 Nerazuman čovek ruku pruža
\q2 i sigurno jamči za bližnjega svoga.
\b
\q1 
\v 19 Ko voli razdor voli i prestup,
\q2 posrnuće traži ko podiže vrata svoja u visine.\f + \fr 17,19 \ft Drevna slika ljudi koji svoja \fqa vrata\ft , svoja usta oholo razjapljuju.\f*
\b
\q1 
\v 20 Čovek srca pokvarenog ne nalazi dobro,
\q2 a kome je pogan jezik u nevolju pada.
\b
\q1 
\v 21 Žalostan je ko rodi bezumnog
\q2 i nema radosti ocu neukoga.
\b
\q1 
\v 22 Veselo srce dobro zdravlje daje,
\q2 a duh potišteni suši kosti.
\b
\q1 
\v 23 Pokvarenjak prima mito iz nedara
\q2 da pokvari staze pravednosti.
\b
\q1 
\v 24 Mudrost je pred licem razumnog čoveka,
\q2 a oči bezumnog na kraju su zemlje.
\b
\q1 
\v 25 Budalasti sin tuga je svom ocu,
\q2 ogorčenje onoj što ga je rodila.
\b
\q1 
\v 26 Nije dobro globiti pravednika
\q2 ni šibati čestite zbog pravde.
\b
\q1 
\v 27 Istinski je mudar čovek štedljiv na rečima,
\q2 a ko je plemenitog duha razuman je čovek.
\b
\q1 
\v 28 I bezumnik čak se čini mudrim kada ćuti,
\q2 kad zatvara usne svoje razumnim ga drže.
\c 18
\q1 
\v 1 Za željom svojom žudi samoživi čovek,
\q2 na mudrost se svaku iznervira.
\b
\q1 
\v 2 Bezumnik ne uživa u razboritosti,
\q2 nego u razotkrivanju svoga srca.
\b
\q1 
\v 3 Kada dođe zao čovek dolaze i prezir
\q2 i bruka sa sramotom.
\b
\q1 
\v 4 Duboke su vode reči u ustima ljudskim
\q2 i vrelo mudrosti potok je nabujali.
\b
\q1 
\v 5 Strašno je držati stranu nepravedniku
\q2 da bi pravedniku oduzeli pravdu.
\b
\q1 
\v 6 U svađu srljaju usne bezumnika
\q2 i batine mu usta prizivaju.
\b
\q1 
\v 7 Bezumnika ruše sopstvena usta
\q2 i usne mu život vrebaju.
\b
\q1 
\v 8 Reči klevetnika su kao poslastice
\q2 što u stomak klize.
\b
\q1 
\v 9 Ko je lenj u poslu svome
\q2 pobratim je velikom rasipniku.
\b
\q1 
\v 10 Ime je Gospodnje moćna kula
\q2 u koju se na visinu sklanja pravednik.
\b
\q1 
\v 11 Bogatstvo je bogatome poput utvrđenja,
\q2 poput zida visokoga u mašti njegovoj.
\b
\q1 
\v 12 Srce se čoveka uznese pred propast,
\q2 a pre časti dolazi poniznost.
\b
\q1 
\v 13 Budalast je i sramotan onaj
\q2 koji uzvraća reč pre nego je čuo.
\b
\q1 
\v 14 S bolešću se svojom nosi duh u čoveku.
\q2 Ali ko se nosi s duhom utučenim?
\b
\q1 
\v 15 Znanju teži srce promućurnog,
\q2 a i uho mudrog predano je njemu.
\b
\q1 
\v 16 Čovek darom sebi put otvara
\q2 i on ga odvodi pred velike ljude.
\b
\q1 
\v 17 U pravu je ko je prvi u svojoj parnici,
\q2 ali onda dođe njegov bližnji pa ga ispituje.
\b
\q1 
\v 18 Žreb prekida razmirice
\q2 i neslogu među moćnicima.
\b
\q1 
\v 19 Uvređeni brat je tvrđi od utvrđenog grada
\q2 i razmirice su kao rešetka tvrđave.
\b
\q1 
\v 20 Plodom usta svojih siti čovek stomak svoj,
\q2 siti ga plodom usana svojih.
\b
\q1 
\v 21 Jezik vlada i životom i smrću;
\q2 ko ga voli, ješće njegov plod.
\b
\q1 
\v 22 Ko nađe ženu, našao je blago,
\q2 blagodat je dobio od Gospoda.
\b
\q1 
\v 23 Molećivo siromah besedi,
\q2 a bogataš oštro odgovara.
\b
\q1 
\v 24 Čovek s mnogo prijatelja može i da strada,
\q2 ali ima prijatelja prisnijih od brata.
\c 19
\q1 
\v 1 Bolji je i siromah što čestito živi,
\q2 nego čovek nečistih usana i bezumnik.
\b
\q1 
\v 2 I čovek bez znanja je opak
\q2 i onaj što srlja, taj luta.
\b
\q1 
\v 3 Ludost čoveku podriva put
\q2 i srce mu se na Gospoda gnevi.
\b
\q1 
\v 4 Bogatstvo donosi mnogo prijatelja,
\q2 a siromah je napušten od svog prijatelja.
\b
\q1 
\v 5 Lažljiv svedok neće proći bez kazne
\q2 i ko laži širi izbaviti se neće.
\b
\q1 
\v 6 Mnogi se dodvoravaju velikodušnom
\q2 i svi su prijatelji sa darežljivim.
\b
\q1 
\v 7 Siromaha mrze sva braća njegova,
\q2 njegovi ga prijatelji još više napuštaju!
\q1 On ih traži,
\q2 doziva ih, a njih nema.
\b
\q1 
\v 8 Ko srce ispituje, samog sebe voli;
\q2 ko se drži razboritosti pronalazi dobro.
\b
\q1 
\v 9 Lažljiv svedok neće proći bez kazne,
\q2 nastradaće taj što laži širi.
\b
\q1 
\v 10 Budalastom raskoš ne pristaje,
\q2 a kamoli sluzi da vlada glavarima.
\b
\q1 
\v 11 Čovekova obazrivost čuva ga od srdžbe,
\q2 na čast mu je da pređe preko uvrede.
\b
\q1 
\v 12 Careva je srdžba lavić koji riče,
\q2 a njegova naklonost je ko rosa po travi.
\b
\q1 
\v 13 Bezuman sin upropaštava oca svoga,
\q2 a ženine su svađe kao stalno prokišnjavanje.
\b
\q1 
\v 14 Kuća i imanje nasledstvo su od otaca,
\q2 a od Gospoda je žena obazriva.
\b
\q1 
\v 15 Lenjost vodi u duboki san,
\q2 a dokoni će gladovati.
\b
\q1 
\v 16 Život svoj čuva ko zapovest drži,
\q2 a umreće onaj ko prezire puteve svoje.
\b
\q1 
\v 17 Gospodu pozajmljuje ko daje siromahu,
\q2 on će da mu uzvrati za to dobročinstvo.
\b
\q1 
\v 18 Sina svoga kažnjavaj dokle ima nade,
\q2 ali srcem ne poželi da ga do smrti dovedeš.
\b
\q1 
\v 19 Besan čovek plaća globu
\q2 i ako ga od nje spaseš, moraćeš to ponovo da radiš.
\b
\q1 
\v 20 Slušaj savet i prihvati ukor
\q2 da postaneš mudar u zrelim danima.
\b
\q1 
\v 21 U srcu čoveka mnoge su namere,
\q2 ali Gospodnji se naum ostvaruje.
\b
\q1 
\v 22 Odanost je poželjna za čoveka\f + \fr 19,22 \ft Ovaj deo stiha može da se prevede i ovako: \fqa Čoveku je na sramotu njegova pohlepa.\f*;
\q2 bolje i siromašan nego lažljiv.
\b
\q1 
\v 23 Bogobojaznost znači život,
\q2 pa ispunjen čovek počiva nepoharan zlom.
\b
\q1 
\v 24 Lenština umače ruku u čanak,
\q2 ali je ustima svojim ne prinosi.
\b
\q1 
\v 25 Šibaj podrugljivca pa će lakoverni postati mudar,
\q2 prekori razumnog i shvatiće pouku.
\b
\q1 
\v 26 Ko oca zlostavlja i tera majku,
\q2 sin je koji donosi bruku i sramotu.
\b
\q1 
\v 27 Sine, prestani, i slušaj ukor
\q2 da ne zastraniš od pouka znanja.
\b
\q1 
\v 28 Bezvredan se svedok ruga pravdi
\q2 i usta zlih ljudi proždiru zlobu.
\b
\q1 
\v 29 Za podsmevače spremljena je kazna
\q2 i batina za leđa bezumnika.
\c 20
\q1 
\v 1 Vino je podsmevač i žestoko piće svađalica,
\q2 nemudar je ko se zbog njih tetura.
\b
\q1 
\v 2 Carevo je nasilje kao rika lavića,
\q2 ko ga razdražuje sebi samom škodi.
\b
\q1 
\v 3 Na čast je čoveku da se kloni svađe,
\q2 a svaki se bezumnik izbezumi.
\b
\q1 
\v 4 Kad je jesen – lenština ne ore,
\q2 kad je žetva – on prosi i oskudeva.
\b
\q1 
\v 5 Duboka je voda zamisao čovekovog srca,
\q2 alʼ je crpsti može samo čovek razboriti.
\b
\q1 
\v 6 Mnogi ljudi objavljuju svima svoju dobrotu,
\q2 ali ko će naći odanog čoveka?
\b
\q1 
\v 7 Pravednik živi čestitost svoju
\q2 i kako su samo blagoslovena deca nakon njega!
\b
\q1 
\v 8 Car koji sedi na sudskom prestolu
\q2 pogledom svojim sve zlo rasipa.
\b
\q1 
\v 9 Može li ko reći: „Srce sam svoje očistio,
\q2 čist sam od greha svoga“?
\b
\q1 
\v 10 Nejednaki tegovi i mera dvojaka –
\q2 oboje su ogavni Gospodu.
\b
\q1 
\v 11 I dete se po delima svojim prepoznaje,
\q2 da li su mu dela ispravna i čista.\f + \fr 20,11 \ft Ovaj stih može i ovako da se prevede: \fqa Čak i dete delima svojim sakriva svoje prave motive, da ne znaš jesu li mu dela ispravna i čista.\f*
\b
\q1 
\v 12 I uho što čuje i oko što vidi,
\q2 i jedno i drugo stvorio je Gospod.
\b
\q1 
\v 13 Ne voli spavanje da ne osiromašiš,
\q2 probudi se i naješćeš se hleba.
\b
\q1 
\v 14 „Bezvredno! Bezvredno!“ – govori kupac –
\q2 a onda se hvali kada ode svojim putem.
\b
\q1 
\v 15 Postoji zlato i mnoštvo dragulja,
\q2 ali učene usne su kao dragoceni nakit.
\b
\q1 
\v 16 Uzmi haljinu onome što jamči za tuđinca,
\q2 i zalog mu uzmi kad jamči za neznanca.
\b
\q1 
\v 17 Čoveku je sladak nepošteni hleb,
\q2 ali su mu posle usta peska puna.
\b
\q1 
\v 18 Namere osmisli savetom
\q2 i mudrim vođenjem ratuj.
\b
\q1 
\v 19 Ogovarač skita i odaje tajne,
\q2 zato se ne petljaj sa brbljivcem.
\b
\q1 
\v 20 Ko proklinje i oca i majku,
\q2 svetiljka mu dogoreva u najcrnjoj tami.
\b
\q1 
\v 21 U početku naglo zgrnuto nasledstvo
\q2 ostaje neblagosloveno na svom kraju.
\b
\q1 
\v 22 Nemoj reći: „Uzvratiću zlu!“
\q2 Čekaj Gospoda da te izbavi.
\b
\q1 
\v 23 Gospodu su mrski nejednaki tegovi
\q2 i strašne su terazije nejednake.
\b
\q1 
\v 24 Od Gospoda su čovekovi koraci,
\q2 pa kako bi neko dokučio svoj vlastiti put?
\b
\q1 
\v 25 Čoveku je zamka kad nepromišljeno kaže da je nešto posvećeno,
\q2 a da posle zavete razmatra.
\b
\q1 
\v 26 Car će mudar razvejati zlikovce,
\q2 vršidbenim točkom preko njih će preći.
\b
\q1 
\v 27 Svetiljka Gospodnja je čovekov dah,
\q2 ispituje dubine nutrine.
\b
\q1 
\v 28 Odanost i istina čuvaju cara,
\q2 on odanošću ostaje na prestolu svome.
\b
\q1 
\v 29 Mladiću je čast u njegovoj snazi
\q2 a seda je kosa dostojanstvo starih.
\b
\q1 
\v 30 Rane i masnice čiste od zla,
\q2 a šiba čisti dubine nutrine.
\c 21
\q1 
\v 1 Ko potoci vode carevo je srce u ruci Gospodnjoj,
\q2 on ga vodi kako njemu godi.
\b
\q1 
\v 2 U sopstvenim očima čoveku je čist svaki put,
\q2 ali Gospod proverava namere srca.
\b
\q1 
\v 3 Da se čini po pravu i pravdi
\q2 Gospodu je milije od žrtve.
\b
\q1 
\v 4 Uznosite oči i oholo srce
\q2 svetiljka su pokvarenih, a to je greh.
\b
\q1 
\v 5 Namere marljivog jedino obilju vode,
\q2 a svih onih što srljaju samo siromaštvu.
\b
\q1 
\v 6 Sticanje bogatstva jezikom lažljivim
\q2 je poput pare lelujave; u smrt srljaju takvi.
\b
\q1 
\v 7 Nasilnike će pomesti nasilje njihovo,
\q2 jer su odbili da čine po pravdi.
\b
\q1 
\v 8 Kriv je put krivca,
\q2 a nedužno je delo nedužnoga.
\b
\q1 
\v 9 Bolje je sedeti na uglu krova
\q2 nego sa ženom svadljivom u zajedničkoj kući.
\b
\q1 
\v 10 Za zlom žudi duša zlotvora,
\q2 samilost mu bližnji njegov ne vidi u oku.
\b
\q1 
\v 11 Kazni podrugljivca, pa će lakoverni postati mudar,
\q2 pouči razumnog i shvatiće pouku.
\b
\q1 
\v 12 Svepravedni motri na kuću zloga,
\q2 on obara zle u propast.
\b
\q1 
\v 13 Ko zatvara uho svoje od plača ubogog
\q2 i sam će plakati, a uslišen neće biti.
\b
\q1 
\v 14 Tajni poklon ljutnju utišava
\q2 i mito u nedrima pogolemu srdžbu.
\b
\q1 
\v 15 Pravedniku je radost da radi po pravdi,
\q2 a jeza je za one što nepravdu rade.
\b
\q1 
\v 16 Čovek što zaluta s puta razumnoga
\q2 završiće u društvu pokojnih.
\b
\q1 
\v 17 Siromašan čovek biće ko voli veselje,
\q2 ko vino i ulje voli bogat biti neće.
\b
\q1 
\v 18 Zlobnik je otkup za pravednika
\q2 i nevernik za ispravnoga.
\b
\q1 
\v 19 Bolje biti i u zemlji pustoj,
\q2 nego sa ženom svadljivom i goropadnom.
\b
\q1 
\v 20 Primamljivo blago i ulje su u domu mudrog,
\q2 a bezumni čovek sve to proćerda.
\b
\q1 
\v 21 Ko pravdi i ljubavi teži
\q2 nalazi i život i pravdu i čast.
\b
\q1 
\v 22 Mudar se uspinje u grad junaka
\q2 i obara bedem njihovog uzdanja.
\b
\q1 
\v 23 Usta svoja i jezik svoj ko čuva,
\q2 od nevolja sebe brani.
\b
\q1 
\v 24 Bahati i oholi – ime mu podrugljivac –
\q2 onaj je što radi u obesti bezmernoj.
\b
\q1 
\v 25 Lenštinu ubija njegova želja,
\q2 jer odbija da radi rukama.
\b
\q1 
\v 26 On mahnito traži od jutra do sutra,
\q2 a pravednik deli i ne cicijaši.
\b
\q1 
\v 27 Mrske su žrtve zlobnika,
\q2 a još više kad ih prinosi u zlobi!
\b
\q1 
\v 28 Lažljivi svedok će nastradati,
\q2 a čovek koji sluša s uspehom će da svedoči.
\b
\q1 
\v 29 Zlobnik na licu pokazuje drskost,
\q2 a čestiti put svoj razaznaje.
\b
\q1 
\v 30 Ni mudrosti ni znanja,
\q2 ni saveta nema nasuprot Gospodu.
\b
\q1 
\v 31 Za dan boja konj je spreman,
\q2 ali pobeda je od Gospoda.
\c 22
\q1 
\v 1 Bolje je izabrati ime nego bogatstvo golemo
\q2 i blagonaklonost je bolja od srebra i zlata.
\b
\q1 
\v 2 I bogataš i siromah se sreću,
\q2 jer sve ih je Gospod sazdao.
\b
\q1 
\v 3 Obazriv čovek primeti nevolju, pa se skrije,
\q2 a lakoverni idu dalje i budu kažnjeni.
\b
\q1 
\v 4 Obilje, čast i život su nagrada
\q2 za poniznost i bogobojaznost.
\b
\q1 
\v 5 Zamke su i trnje na stazi podlaca
\q2 a od njih je podaleko onaj koji čuva dušu svoju.
\b
\q1 
\v 6 Vaspitaj dete za put kojim mu valja ići
\q2 pa i kada ostari od njega se odmaknuti neće.
\b
\q1 
\v 7 Bogati vlada siromasima,
\q2 a ko zajmi služi zajmodavcu.
\b
\q1 
\v 8 Ko nepravdu seje nevolju će žeti,
\q2 slomiće se šiba gneva njegovoga.
\b
\q1 
\v 9 Blagosloven biće darežljivi,
\q2 jer daje siromahu parče svoga hleba.
\b
\q1 
\v 10 Oteraš li podrugljivca, svađa prestaće,
\q2 parničenje i sramota nestaće.
\b
\q1 
\v 11 Ko voli čisto srce i milost mu je na usnama
\q2 ima cara za prijatelja.
\b
\q1 
\v 12 Oči Gospodnje čuvaju znanje,
\q2 on obara reči onih što nepravdu čine.
\b
\q1 
\v 13 Lenština govori: „Lav je na ulici!
\q2 Zaklaće me nasred trga!“
\b
\q1 
\v 14 Jama duboka usta su bludnice,
\q2 u nju pašće onaj na koga je Gospod srdit.
\b
\q1 
\v 15 Dečije je srce svezano bezumljem
\q2 koje šiba opomene nadaleko od njega uklanja.
\b
\q1 
\v 16 I ko tlači siromaha da za sebe zgrne
\q2 i ko daje bogatome, sigurno im sledi nemaština.
\ms1 Mudre priče
\s2 Prva priča
\q1 
\v 17 Prikloni uho, poslušaj reči mudrih ljudi
\q2 i srce prikloni mom znanju.
\q1 
\v 18 Jer će ti biti zadovoljstvo da ih držiš u sebi,
\q2 da budu spremne na usnama tvojim.
\q1 
\v 19 A da ti u Gospodu pouzdanje bude,
\q2 ja ti ih danas objavljujem, baš tebi.
\q1 
\v 20 Nisam li ih za tebe zapisao
\q2 trideset mudrih priča
\q2 kroz savete i znanje;
\q1 
\v 21 da te upoznam s istinitošću pouzdanih reči,
\q2 kako bi uzvratio pouzdanim rečima onima koji te šalju?
\s2 Druga priča
\q1 
\v 22 Ne otimaj siromahu jer je siromah,
\q2 ne satiri ubogoga na sudskim vratima.
\q1 
\v 23 Jer Gospod će braniti njegov slučaj
\q2 i oteće dušu onima što njima otimaju.
\s2 Treća priča
\q1 
\v 24 Ne druži se s razjarenim,
\q2 ne idi sa besnim čovekom;
\q1 
\v 25 jer ćeš naviknuti na puteve njegove
\q2 i sebe ćeš uplesti u zamku.
\s2 Četvrta priča
\q1 
\v 26 Ne budi od onih koji ruku daju
\q2 i od onih koji jamče za dugove.
\q1 
\v 27 Ako nemaš dovoljno da platiš,
\q2 zašto da ti neko uzme i postelju ispod tebe?
\s2 Peta priča
\q1 
\v 28 Ne pomiči drevni međaš
\q2 što su tvoji preci postavili.
\s2 Šesta priča
\q1 
\v 29 Da li si video čoveka veštog u svom poslu?
\q2 Pred carevima će on stajati,
\q2 a neće stajati pred beznačajnim.
\c 23
\s2 Sedma priča
\q1 
\v 1 Kad sa vladarom sedaš da jedeš
\q2 pažljivo razmotri šta je pred tobom;
\q1 
\v 2 nož ćeš staviti pod grlo svoje
\q2 ako si alav.
\q1 
\v 3 Ne žudi za njegovim đakonijama,
\q2 jer je to varljiva hrana.
\s2 Osma priča
\q1 
\v 4 Ne napinji se da stekneš bogatstvo
\q2 i svoje se pameti prođi.
\q1 
\v 5 Pustiš li na njega oči svoje, gle njega nema,
\q2 jer je sebi načinilo krila poput orla,
\q2 što se vine u nebesa.
\s2 Deveta priča
\q1 
\v 6 Ne jedi hranu samoživca,
\q2 ne poželi đakonije njegove.
\q1 
\v 7 Jer kako se on u sebi preračunava,
\q2 baš je takav kada ti kaže –
\q1 „Jedi i pij!“ –
\q2 a srce mu nije s tobom.
\q1 
\v 8 Izbljuvaćeš zalogaj koji si pojeo,
\q2 proćerdaćeš sve ljubazne reči svoje.
\s2 Deseta priča
\q1 
\v 9 Ne govori ušima bezumnog,
\q2 jer će prezreti poruku tvojih reči.
\s2 Jedanaesta priča
\q1 
\v 10 Ne pomiči drevni međaš,
\q2 ne zalazi u njive siročadi.
\q1 
\v 11 Jer je jak njihov Otkupitelj,
\q2 odbraniće njihov slučaj od tebe.
\s2 Dvanaesta priča
\q1 
\v 12 Srce svoje predaj opomeni,
\q2 svoje uši poučnim rečima.
\s2 Trinaesta priča
\q1 
\v 13 Ne uskraćuj kaznu detetu,
\q2 jer neće da umre ako ga i udariš šibom.
\q1 
\v 14 Tuci ga šibom
\q2 i dušu mu od Sveta mrtvih spasi.
\s2 Četrnaesta priča
\q1 
\v 15 O, moj sine, ako ti je srce mudro
\q2 i moje se srce raduje;
\q1 
\v 16 raduje se nutrina moja,
\q2 kad ti usne čestito govore.
\s2 Petnaesta priča
\q1 
\v 17 Nek ti srce grešnicima ne zavidi,
\q2 u bogobojaznosti ti povazdan budi.
\q1 
\v 18 Nema sumnje, budućnost postoji,
\q2 tvoja nada neće propasti.
\s2 Šesnaesta priča
\q1 
\v 19 Sine moj, poslušaj i mudar budi,
\q2 svoje srce ti na put usmeri.
\q1 
\v 20 Ne druži se sa onima što se vinom opijaju,
\q2 sa onima koji žderu meso.
\q1 
\v 21 Jer, osiromašiće i pijanica i izelica,
\q2 mamurluk će ih obući u dronjke.
\s2 Sedamnaesta priča
\q1 
\v 22 Slušaj oca svoga što te je rodio,
\q2 majku svoju ne preziri ni kada ostari.
\q1 
\v 23 Istinu kupuj i ne prodaji
\q2 mudrost, prekor i pouku.
\q1 
\v 24 Jako se raduje otac pravednog sina,
\q2 ko je rodio mudrog sina uživa u njemu.
\q1 
\v 25 Neka se raduju i otac tvoj i majka tvoja,
\q2 neka se veseli ona koja te je rodila.
\s2 Osamnaesta priča
\q1 
\v 26 Srce mi svoje daj, sine moj,
\q2 i neka ti oči počivaju na putevima mojim.
\q1 
\v 27 Jer bludnica je duboka jama,
\q2 tuđinka je uzano ždrelo.
\q1 
\v 28 Ona je ko lopov što vreba iz potaje
\q2 i među muškarcima umnožava neverne.
\s2 Devetnaesta priča
\q1 
\v 29 Ko to kuka? Ko to ječi?
\q2 Ko se svađa? Ko to prigovara?
\q1 Ko ima rane bezrazložne
\q2 i kome su zakrvavljene oči?
\q1 
\v 30 Onima što se izležavaju kraj vina,
\q2 onima što idu da probaju vino izmešano.
\q1 
\v 31 Ne gledaj vino dok se rumeni,
\q2 dok se svetluca u čaši,
\q2 dok lagano klizi.
\q1 
\v 32 Kao zmija na kraju ujeda,
\q2 kao otrovnica ubada.
\q1 
\v 33 Čudne će prizore da vide oči tvoje
\q2 i srce govoriće ludorije.
\q1 
\v 34 Bićeš kao onaj što leži usred mora,
\q2 kao onaj što leži navrh jarbola.
\q1 
\v 35 \add I reći ćeš\add*: „Udarili su me, a bolestan nisam,
\q2 tukli su me, osetio nisam.
\q1 Kada ću se probuditi
\q2 da ponovo potražim piće?“
\c 24
\s2 Dvadeseta priča
\q1 
\v 1 Ne zavidi zlima,
\q2 ne poželi da si s njima;
\q1 
\v 2 jer u srcu svome smišljaju nasilje,
\q2 najavljuju usnama nevolju.
\s2 Dvadeset prva priča
\q1 
\v 3 Mudrošću se podiže kuća,
\q2 a razboritošću je osnovana;
\q1 
\v 4 znanjem su joj sobe napunjene
\q2 svakim blagom poželjnim i vrednim.
\s2 Dvadeset druga priča
\q1 
\v 5 Čovek ratnik je jak,
\q2 ali onaj koji zna jača snagu svoju;
\q1 
\v 6 jer ćeš rat dobiti mudrim savetima
\q2 i pobeda je u mnogim savetnicima.
\s2 Dvadeset treća priča
\q1 
\v 7 Visoka je mudrost nemudrome,
\q2 on usta svoja ne otvara na sudskim vratima.
\s2 Dvadeset četvrta priča
\q1 
\v 8 Ko je predan da zlo smišlja
\q2 nazvaće ga spletkarošem.
\q1 
\v 9 Greh su bezumni naumi
\q2 i podrugljivac je oduran ljudima.
\s2 Dvadeset peta priča
\q1 
\v 10 Kloneš li u danu nevolje,
\q2 klonuće i tvoja snaga.
\q1 
\v 11 Spasavaj one koje u smrt vuku,
\q2 izvlači one što teturaju na pogubljenje.
\q1 
\v 12 Jer, kažeš li – „Ali, mi to nismo znali!“ –
\q2 neće li shvatiti onaj što proniče srca?
\q1 Neće li znati onaj koji ti život čuva
\q2 i uzvratiti čoveku po delu njegovom?
\s2 Dvadeset šesta priča
\q1 
\v 13 Jedi med, sine moj, jer je zdrav
\q2 i nepcu je tvome sladak med iz saća.
\q1 
\v 14 Takvo je poznanje mudrosti duši tvojoj
\q2 ako je pronađeš; tada budućnost postoji
\q2 i tvoja nada neće propasti.
\s2 Dvadeset sedma priča
\q1 
\v 15 Ne vrebaj ko zlikovac u potaji na dom pravednika
\q2 i konačište njegovo ne ruši.
\q1 
\v 16 Jer padne li pravednik i sedam puta, ustaće,
\q2 a zlikovac će posrnuti u nevolji.
\s2 Dvadeset osma priča
\q1 
\v 17 Ne raduj se dok se ruši dušmanin tvoj,
\q2 kad posrne neka ti se srce ne veseli;
\q1 
\v 18 da Gospod to ne vidi i to bude zlo pred njime,
\q2 pa sa dušmanina povuče svoj gnev.
\s2 Dvadeset deveta priča
\q1 
\v 19 Ne žesti se zbog zlotvora,
\q2 ne zavidi zlikovcima;
\q1 
\v 20 jer budućnost ne pripada zlotvoru,
\q2 dogoreva svetiljka zlikovcu.
\s2 Trideseta priča
\q1 
\v 21 Boj se Gospoda, sine moj, baš kao i cara;
\q2 ne druži se s buntovnima;
\q1 
\v 22 jer iznenadna dolazi njihova propast
\q2 i ko će da sazna svršetak ove dvojice?
\ms1 Ostale mudre priče
\p 
\v 23 I ovo se tiče mudrih ljudi:
\q1 Strahota je kad se gleda ko je ko na sudu.
\q1 
\v 24 Naime, ko kaže zlome – „Ti si pravedan!“ –
\q2 ljudi će ga proklinjati,
\q2 narodi ga prezirati.
\q1 
\v 25 A onima koji ga prekore uživanje će biti,
\q2 na njih će doći blagoslov dobra.
\b
\q1 
\v 26 Usne voli onaj ko uzvraća pravednim rečima.
\b
\q1 
\v 27 Posao svoj na polju završi,
\q2 pripremi njivu svoju, a onda izgradi kuću svoju.
\b
\q1 
\v 28 Ne svedoči bez razloga protiv bližnjeg svoga,
\q2 zar ćeš da obmanjuješ usnama svojim?
\q1 
\v 29 Ne reci – „Kako je on uradio meni, tako ću i ja da uradim njemu.
\q2 Uzvratiću mu po delu njegovom!“
\b
\q1 
\v 30 Prošao sam pored polja lenštine
\q2 i pored vinograda bezumnika.
\q1 
\v 31 I gle, u trnje je sve zaraslo,
\q2 koprivama sve obraslo,
\q2 zid kameni beše srušen.
\q1 
\v 32 Kada sam to video, srcem sam shvatio,
\q2 video sam i prihvatio pouku:
\q1 
\v 33 Još malo snova, još malo dremeža,
\q2 još malo dokono da sklopiš ruke;
\q1 
\v 34 i doći će tvoje siromaštvo kao skitnica
\q2 i nemaština kao nasilnik.
\c 25
\ms1 Ostale mudre priče
\p 
\v 1 I ovo su Solomonove mudre priče koje su prepisali ljudi Jezekije, Judinog cara:
\q1 
\v 2 Božija je slava da sakriva stvari,
\q2 a caru je slava da stvar istražuje.
\q1 
\v 3 Nebo je visoko, zemlja je duboka,
\q2 a i srca carska niko ne istraži.
\b
\q1 
\v 4 Ukloni sa srebra zguru
\q2 i eto ga čanak za kovača:
\q1 
\v 5 ukloni zloga od cara
\q2 i u pravdi presto njegov utvrđen će biti.
\b
\q1 
\v 6 Pred carem se ne veličaj
\q2 i ne stoj na mestu velikaša;
\q1 
\v 7 jer je bolje da ti kaže – „Gore dođi!“ –
\q2 nego da te ponizi pred plemićem.
\b
\q1 A to\f + \fr 25,7 \ft Misli se na plemića iz prethodnog stiha.\f* što su ti oči videle
\q2 
\v 8 ne dovodi žurno na suđenje,
\q1 jer šta ćeš kada te na kraju
\q2 posrami bližnji tvoj?
\b
\q1 
\v 9 Reši spor sa bližnjem svojim
\q2 i tajnu drugoga ne otkrivaj;
\q1 
\v 10 da te ne bi osramotio onaj koji sluša
\q2 i zao glas ostao na tebi.
\b
\q1 
\v 11 Blagovremeno kazana reč
\q2 je poput zlatnih jabuka u srebrnim činijama.
\q1 
\v 12 Minđuša zlatna i ukras od čistog zlata
\q2 je ukor mudrog onome koji sluša.
\b
\q1 
\v 13 Kao studen snega na dan žetve
\q2 je verni glasnik onom ko ga šalje –
\q2 osvežava dušu svoga gospodara.
\q1 
\v 14 Poput oblaka i vetra bez kiše
\q2 čovek je što se hvali darom nedarovanim.
\b
\q1 
\v 15 Strpljivošću se nagovara vladar,
\q2 a i jezik blagi može kost da slomi.
\b
\q1 
\v 16 Kad nađeš med, jedi dok se ne najedeš,
\q2 jer ćeš ga povratiti ako se prejedeš.
\q1 
\v 17 Neka ti je noga retko u kući bližnjeg tvoga,
\q2 da te se ne zasiti i ne zamrzi te.
\b
\q1 
\v 18 Poput buzdovana, mača i strele oštre
\q2 je čovek koji svedoči protiv bližnjeg svoga, a lažov je.
\q1 
\v 19 Zub pokvaren i klecava noga
\q2 je poverenje u izdajnika u danu nevolje.
\q1 
\v 20 Kao čovek što haljinu skida po zimskome danu
\q2 i kao sirće na šalitri,
\q2 takav je onaj koji pesme peva srcu žalosnome.
\b
\q1 
\v 21 Ako je tvoj neprijatelj gladan, nahrani ga,
\q2 i ako je žedan, napoj ga vodom.
\q1 
\v 22 Jer ako tako činiš, zgrnućeš žar ugljeni na njegovu glavu,
\q2 a Gospod će da ti plati.
\b
\q1 
\v 23 Severac kišu donosi,
\q2 a jezik ogovarački srdita lica.
\b
\q1 
\v 24 Bolje je sedeti na uglu krova
\q2 nego sa ženom svadljivom u zajedničkoj kući.
\b
\q1 
\v 25 Što je studena voda duši iznurenoj,
\q2 to je dobra vest iz daleke zemlje.
\q1 
\v 26 Zamućen izvor i bunar zarušeni
\q2 je pravednik što tetura pred nepravednikom.
\b
\q1 
\v 27 Nije dobro preždrati se meda
\q2 i ljudima na čast nije da čast svoju traže.
\b
\q1 
\v 28 Grad provaljen i bez zida
\q2 je čovek koji ne zna sebe samog da obuzda.
\c 26
\q1 
\v 1 Kao sneg leti i kiša o žetvi,
\q2 tako čast ne stoji bezumnom.
\q1 
\v 2 Kao kad prhne vrabac i lasta kad odleti,
\q2 tako i kletva ne stiže bez povoda.
\q1 
\v 3 Bič je za konja, uzde za magarca,
\q2 a batina za leđa bezumnog.
\q1 
\v 4 Ne uzvraćaj bezumnome po bezumlju njegovome,
\q2 da i sam ne bi bio njemu nalik.
\q1 
\v 5 Uzvrati bezumnome po bezumlju njegovome,
\q2 da sam sebi ne bi bio mudar.
\q1 
\v 6 Noge svoje sam saseca, nasiljem se podnapija
\q2 ko poruku šalje rukama bezumnog.
\q1 
\v 7 Kako noge vise oduzetom,
\q2 takva je mudra priča u ustima bezumnoga.
\q1 
\v 8 Kamen u praćku veže
\q2 ko bezumnom počast daje.
\q1 
\v 9 Trnova grana u ruci pijanca
\q2 je mudra priča u ustima bezumnoga.
\q1 
\v 10 Poput strelca što ranjava koga stigne,
\q2 takav je čovek što unajmljuje bezumnika
\q2 i onaj što unajmljuje prolaznika.
\q1 
\v 11 Vraća se pas na svoju bljuvotinu
\q2 kao što se i bezumnik vraća bezumlju svome.
\q1 
\v 12 Vidiš li čoveka koji misli za sebe da je mudar?
\q2 Više je nade za bezumnika nego za njega!
\b
\q1 
\v 13 Lenština govori: „Lav je na ulici!
\q2 Lav je nasred trga!“
\q1 
\v 14 Na šarkama okreću se vrata,
\q2 a lenština na krevetu svome.
\q1 
\v 15 Lenština umače ruku u čanak,
\q2 ali je preumoran da ustima svojim je prinese.
\q1 
\v 16 Samom sebi lenština je mudriji
\q2 od sedmorice što razborito odgovaraju.
\b
\q1 
\v 17 Psa za uši hvata
\q2 ko se u prolazu ljuti zbog tuđe rasprave.
\b
\q1 
\v 18 Kao mahnitavi što baklje,
\q2 strele i smrt seje,
\q1 
\v 19 takav je čovek što vara bližnjeg svoga,
\q2 pa još kaže: „Nisam li se našalio?!“
\b
\q1 
\v 20 Kada nema drva i vatra se gasi,
\q2 kada nema klevetnika i svađa se stiša.
\q1 
\v 21 Ugalj je za žeravicu i drvo za vatru,
\q2 a čovek svađalica da potpali svađu.
\q1 
\v 22 Reči klevetnika su kao poslastice
\q2 što u stomak klize.
\b
\q1 
\v 23 Posrebrena grnčarija –
\q2 to su usne uglađene i zlo srce.
\q1 
\v 24 Onaj koji mrzi skriva se usnama svojim,
\q2 a u sebi sakuplja prevaru.
\q1 
\v 25 Ne veruj čoveku umilnog glasa
\q2 kome je u srcu sedmostruka gadost.
\q1 
\v 26 On se skriva, mržnju prikriva,
\q2 ali će se razotkriti u zboru pokvarenost njegova.
\q1 
\v 27 Ko jamu kopa, sam u nju pada
\q2 i ko kamen valja, na njega se svalja.
\q1 
\v 28 Lažljiv jezik mrzi one koje drobi
\q2 i usta laskava ruševine prave.
\c 27
\q1 
\v 1 Ne hvali se sutrašnjim danom,
\q2 jer ne znaš šta donosi taj dan.
\b
\q1 
\v 2 Drugi nek te hvali, a ne ti sebe samog;
\q2 neznanac, a ne usne tvoje.
\b
\q1 
\v 3 Težak je kamen i pesak je težak,
\q2 ali od oboje je teži bezobrazluk bezočnoga.
\b
\q1 
\v 4 Okrutan je bes, srdžba je goropadna
\q2 i sa ljubomorom ko da se suoči?
\b
\q1 
\v 5 Javni ukor je bolji
\q2 od tajne ljubavi.
\b
\q1 
\v 6 Pouzdanije su modrice od onoga koji te voli
\q2 od mnogih poljubaca onoga koji te mrzi.
\b
\q1 
\v 7 Sita duša saće meda gazi,
\q2 a gladnoj je duši slatko i sve gorko.
\b
\q1 
\v 8 Poput ptice proterane iz gnezda,
\q2 takav je i čovek proteran iz svog zavičaja.
\b
\q1 
\v 9 Ulje i miris dragi su srcu
\q2 i sladak je prijatelj koji od srca savetuje.
\b
\q1 
\v 10 Ne napuštaj prijatelja i prijatelja svog oca;
\q2 ne odlazi u dom svoga brata na dan svoje nevolje;
\q2 bolji je sused koji je blizu, nego brat koji je daleko.
\b
\q1 
\v 11 Mudar budi, sine moj, i srce mi razveseli,
\q2 pa da mogu podrugljivcu rečju da uzvratim.
\b
\q1 
\v 12 Obazriv čovek primeti nevolju, pa se skrije,
\q2 a lakoverni idu dalje i budu kažnjeni.
\b
\q1 
\v 13 Uzmi haljinu onome što jamči za tuđinca,
\q2 i zalog mu uzmi kad jamči za tuđinku.
\b
\q1 
\v 14 Ko od ranog jutra svoga bližnjeg blagosilja na sav glas,
\q2 to će mu se računati kao kletva.
\b
\q1 
\v 15 Žena svadljiva je poput stalnog prokišnjavanja
\q2 po kišnom danu.
\q1 
\v 16 Ko nju obuzdava, vetar obuzdava
\q2 i kao da drži ulje u desnici.
\b
\q1 
\v 17 Gvožđe se o gvožđe oštri,
\q2 a čovek se oštri o čoveka.
\b
\q1 
\v 18 Od smokvinog ploda ješće ko se za nju brine;
\q2 poštovan će biti onaj koji štiti svoga gospodara.
\b
\q1 
\v 19 Kao što se lice odslikava u vodi
\q2 tako se i srce čoveka u čoveku vidi.
\q1 
\v 20 Kao što su i Svet mrtvih i trulež mrtvih nezasiti,
\q2 tako su nezasite i oči čoveka.
\b
\q1 
\v 21 Topionica je za srebro i peć je za zlato,
\q2 a čovek se iskušava pohvalama koje prima.
\b
\q1 
\v 22 Istucaš li tučkom nerazumnog
\q2 sa prekrupom u avanu,
\q2 njegova se ludost neće skinuti sa njega.
\b
\q1 
\v 23 Svoje stado dobro pazi,
\q2 pobrini se dobro za krda svoja;
\q1 
\v 24 jer imetak ne traje doveka,
\q2 a ni kruna kroz sva pokolenja.
\q1 
\v 25 Kosi se trava da nova nikne,
\q2 sakupi se seno po brdima;
\q1 
\v 26 jagnjad te oblače,
\q2 a jarcima plaćaš za polja.
\q1 
\v 27 Tad imaš obilje kozjeg mleka sebi za hranu,
\q2 za hranu ukućana, za život sluškinja svojih.
\c 28
\q1 
\v 1 Nepravednik beži, a niko ga ne goni,
\q2 a pravednik je kao lavić hrabar.
\b
\q1 
\v 2 Zemlja zbog prestupa ima mnoge glavare,
\q2 ali traje dugo sa čovekom poučenim i razumnim.
\b
\q1 
\v 3 Siromah koji ubogoga tlači
\q2 je kao pljusak koji nosi, a roda ne donosi.
\b
\q1 
\v 4 Zlog hvale oni koji Zakon\f + \fr 28,4 \ft Osim značenja \fqa Zakon \ft jevrejski izraz \tl tora\tl* se odnosi i na pouku, uputstvo u smislu širem od Mojsijevog Zakona.\f* zaboravljaju,
\q2 a na njih su kivni oni koji Zakon čuvaju.
\b
\q1 
\v 5 Zlotvori ne shvataju pravdu,
\q2 a sve razume onaj što Gospoda traži.
\b
\q1 
\v 6 Bolji je i siromah koji časno živi
\q2 od bogataša što nečasno živi.
\b
\q1 
\v 7 Razuman je sin koji Zakon drži,
\q2 a svog oca sramoti onaj što se druži s izelicama.
\b
\q1 
\v 8 Ko imetak sebi zgrće od kamate i zelenaštva,
\q2 sakuplja onome koji je milostiv ubogima.
\b
\q1 
\v 9 Uho svoje ko odvrati i ne sluša Zakon,
\q2 njegova je molitva odvratna.
\b
\q1 
\v 10 U svoju će jamu pasti
\q2 ko zavodi pravedne na put zla,
\q2 a dobro će besprekorni da naslede.
\b
\q1 
\v 11 Bogati je sebi samom mudar,
\q2 ali ga razumni siromah istražuje pomno.
\b
\q1 
\v 12 Velika je slava u radosti pravednika,
\q2 a kada se zli osile, čovek se sakriva.
\b
\q1 
\v 13 Ko sakriva sagrešenja svoja, nema mu napretka;
\q2 pomilovan biva ko se zbog njih kaje i odriče ih se.
\b
\q1 
\v 14 Blažen li je čovek što je stalno na oprezu,
\q2 a u zlo će pasti onaj što je srce svoje skamenio.
\b
\q1 
\v 15 Lav što riče, medved raspomamljen,
\q2 takav je i zlobni vladar ubogom narodu.
\b
\q1 
\v 16 Golemi je iznuđivač nerazborit vladar,
\q2 a ko se gnuša iznuđenog dobitka produžava svoje dane.
\b
\q1 
\v 17 Krvoprolićem opterećen čovek hrli jami
\q2 i neka mu niko ne pomogne.
\b
\q1 
\v 18 Izbavljen će biti onaj što besprekorno živi,
\q2 a u trenu pašće onaj što nečasno živi.
\b
\q1 
\v 19 Izobilje hrane ima onaj koji svoju zemlju radi,
\q2 a izobilje siromaštva onaj koji teži bezvrednim stvarima.
\b
\q1 
\v 20 Veran će čovek obilno biti blagosloven,
\q2 a nekažnjeno neće proći ko srlja da se obogati.
\b
\q1 
\v 21 Strahota je kad se gleda ko je ko,
\q2 jer će čovek da sagreši i za parče hleba.
\b
\q1 
\v 22 Škrtica srlja da se obogati,
\q2 a i ne zna da mu stiže oskudica.
\b
\q1 
\v 23 Veću blagonaklonost naposletku nalazi onaj koji kori čoveka
\q2 nego onaj koji laska jezikom.
\b
\q1 
\v 24 Ko potkrada majku svoju i oca svojega,
\q2 pa još kaže da tu greha nema,
\q2 taj se druži sa dželatom.
\b
\q1 
\v 25 Bahat čovek otpočinje svađu,
\q2 a napreduje ko se uzda u Gospoda.
\b
\q1 
\v 26 Bezuman je čovek što veruje srcu svome,
\q2 a ko mudro živi izbavljen će biti.
\b
\q1 
\v 27 Nema oskudice ko siromahu pruža,
\q2 a ko sa njega skreće pogled prepun je prokletstva.
\b
\q1 
\v 28 Kada se osile zlikovci, svako se sklanja,
\q2 a kada stradaju, množe se pravednici.
\c 29
\q1 
\v 1 Kada tvrdoglavi još više otvrdoglavi uprkos karanju,
\q2 slomiće se nenadano i neće mu biti leka.
\b
\q1 
\v 2 Kad se množe pravednici, narod se raduje,
\q2 a kad zlikovac zavlada, narod uzdiše.
\b
\q1 
\v 3 Oca svog raduje čovek koji voli mudrost,
\q2 a s bludnicom ko se druži, imetak svoj ruži.
\b
\q1 
\v 4 Car po pravdi zemlju gradi,
\q2 a gramzivi tlačitelj je razgrađuje.
\b
\q1 
\v 5 Čovek što laska bližnjem svome
\q2 mrežu širi nogama njegovim.
\b
\q1 
\v 6 U grehu je zamka zlikovačka,
\q2 a pravednik kliče i veseli se.
\b
\q1 
\v 7 Pravednik razume slučaj siromaha,
\q2 a nepravednik za tu stvar ne mari.
\b
\q1 
\v 8 Podsmevači grad razjare,
\q2 a mudri stišavaju gnev.
\b
\q1 
\v 9 Kad se mudar čovek sudi s čovekom nemudrim,
\q2 ljutio se ilʼ smejao, počinka mu nema.
\b
\q1 
\v 10 Krvnici mrze čoveka bez mane,
\q2 a pravedni mu dušu štite.
\b
\q1 
\v 11 Svu ćud svoju istresa bezumnik,
\q2 a mudar se povlači i stišava.
\b
\q1 
\v 12 Vladar koji sluša laži
\q2 imaće za sluge sve same zlikovce.
\b
\q1 
\v 13 I siromahu i tlačitelju jedno je zajedničko:
\q2 obojici Gospod prosvetljuje oči.
\b
\q1 
\v 14 Doveka će stajati presto cara
\q2 što ubogom sudi po istini.
\b
\q1 
\v 15 Šiba prekora donosi mudrost,
\q2 a dete raspušteno sramoti svoju majku.
\b
\q1 
\v 16 Kad se zlobnici umnožavaju, umnožavaju se i gresi,
\q2 ali će pravednici gledati njihovu propast.
\b
\q1 
\v 17 Opomeni svoga sina i doneće ti spokoj,
\q2 i doneće radost duši tvojoj.
\b
\q1 
\v 18 Gde viđenja nema, narod se razuzda;
\q2 a kako je blagosloven čovek što se pouke drži!
\b
\q1 
\v 19 Rečima se ne popravlja sluga,
\q2 jer ako ih i razume, on se ne odaziva.
\b
\q1 
\v 20 Vidiš li čoveka brzopletog u govoru?
\q2 Više je nade za bezumnog nego za njega.
\b
\q1 
\v 21 Ko svom sluzi od malena povlađuje
\q2 za nevolju kraj mu sprema.
\b
\q1 
\v 22 Razjareni svađu započinje,
\q2 goropadni obiluje gresima.
\b
\q1 
\v 23 Bahatost unižava čoveka,
\q2 a ponizni zavređuje čast.
\b
\q1 
\v 24 Ko se druži sa lopovom mrzi dušu svoju,
\q2 jer on čuje kletvu, ali je prećuti.
\b
\q1 
\v 25 Strah čoveku zamku postavlja,
\q2 a zbrinut je onaj što se u Gospoda uzda.
\b
\q1 
\v 26 Mnogi traže vladarevu naklonost,
\q2 ali od Gospoda je pravda za čoveka.
\b
\q1 
\v 27 Nepravednik je mrzak pravednicima,
\q2 a zlobnicima je mrzak čovek čestitog života.
\c 30
\ms1 Agurove priče
\p 
\v 1 Poruke Agura, Jekajevog sina,
\q1 proroštvo ovog čoveka kazano Itilu,
\q2 Itilu i Ukalu.
\q1 
\v 2 „Elem, ja sam prostiji od bilo koga
\q2 i nemam pameti ljudske;
\q1 
\v 3 nisam se poučio mudrosti
\q2 i znanje Svetog nemam.
\q1 
\v 4 Ko se to uspeo na nebesa pa sišao?
\q2 Ko je sabrao vetar u šake svoje?
\q1 Ko je to uvio vode u plašt?
\q2 Ko je postavio sve zemljine krajeve?
\q1 Kako mu je ime
\q2 i kako mu se sin zove,
\q3 znaš li?
\b
\q1 
\v 5 Svaka je Božija reč oprobana.
\q2 On je štit onima koji u njemu utočište nalaze.
\q1 
\v 6 Ne dodaji rečima njegovim
\q2 da te ne bi prekorio,
\q2 da se ne bi pokazalo da si lažov.
\b
\q1 
\v 7 Dve stvari od tebe tražim,
\q2 ne uskrati mi ih dok sam živ:
\q1 
\v 8 beskorisnu, lažljivu reč od mene udalji;
\q2 ne daj mi siromaštva i bogatstva,
\q2 daj mi hleba da jedem tek da se najedem;
\q1 
\v 9 da se ne bih zasitio, pa se odrekao
\q2 i rekao ’Ko je Gospod?’
\q1 Ili da ne bih osiromašio, pa krao
\q2 i ružio ime Boga svoga.
\b
\q1 
\v 10 Ne kleveći slugu gospodaru njegovom
\q2 da te ne bi proklinjao, pa bi kriv bio.
\b
\q1 
\v 11 Neki soj proklinje oca svoga
\q2 i majku svoju ne blagosilja.
\q1 
\v 12 Neki je soj sebi samom čist
\q2 pa od izmeta svog ostaje neopran.
\q1 
\v 13 O, kako neki soj uzdiže oči
\q2 i kako mu je pogled nadmen!
\q1 
\v 14 Nekom su soju zubi ko mačevi
\q2 a vilice ko noževi,
\q1 da sa zemlje prožderu uboge
\q2 i nesrećnike ljudskog roda.
\b
\q1 
\v 15 Pijavica ima dve ćerke –
\q2 Daj i Daj.
\b
\q1 Tri su stvari nezasite
\q2 i četiri nikada ne kažu ’Dosta!’:
\q3 
\v 16 Svet mrtvih,
\q3 jalova utroba,
\q3 zemlja vode nikad sita
\q3 i vatra što ne kaže ’Dosta!’
\b
\q1 
\v 17 Oko što se ocu ruga
\q2 i prezire poslušnost majci,
\q1 iskljucaće potočni gavrani
\q2 i poješće orlići.
\b
\q1 
\v 18 Tri su mi stvari začuđujuće
\q2 i četiri su mi nepoznate:
\q3 
\v 19 orlov let po nebesima,
\q3 puzanje zmije po steni,
\q3 plovidba lađe posred mora
\q3 i put muškarca sa devojkom.
\b
\q1 
\v 20 A put žene preljubnice je ovakav:
\q2 ona jede, obriše usta pa kaže:
\q2 ’Nikakvo zlo nisam uradila!’
\b
\q1 
\v 21 Pod tri stvari zemlja se potresa
\q2 i četiri ne može da nosi:
\q3 
\v 22 slugu kada se zacari,
\q3 budalu kad je sita hleba,
\q3 
\v 23 nevoljenu, a udatu ženu,
\q3 i sluškinju kad zameni gazdaricu svoju.
\b
\q1 
\v 24 Četiri su stvora malena na zemlji,
\q2 a opet su preko mere učinjena mudrim:
\q1 
\v 25 mravi, nejak narod,
\q2 ali leti sebi pripremaju hranu;
\q1 
\v 26 damani, nejak narod,
\q2 ali dom svoj na stenama prave;
\q1 
\v 27 skakavci, iako bez cara,
\q2 alʼ svi lete u poretku;
\q1 
\v 28 gušter, iako ga s obe ruke hvataš,
\q2 eno ga u odajama carskim.
\b
\q1 
\v 29 Tri su stvora koraka ponosnog
\q2 i četiri što otmeno gaze:
\q3 
\v 30 lav, od svih zveri jači, ni pred čim ne uzmiče;
\q3 
\v 31 petao kada se šepuri,
\q3 jarac
\q3 i car sa vojskom pored sebe.
\b
\q1 
\v 32 Ako si budalast bio sebe uzdižući,
\q2 ako li si spletkario,
\q2 ruku na usta stavi.
\q1 
\v 33 Jer kada se mleko bućka, nastaje maslo;
\q2 i kada se nos istrlja, krv procuri;
\q2 a kada bes uskipi, to donosi svađu.“
\c 31
\ms1 Priče cara Lemuila
\p 
\v 1 Poruke cara Lemuila, proroštva kojim ga je poučila njegova majka:
\q1 
\v 2 „Čuj, sine moj! Čuj, sine utrobe moje!
\q2 Čuj, sine zaveta mojih!
\q1 
\v 3 Ne daj svoju snagu ženama,
\q2 ni puteve svoje onima što ruše careve.
\b
\q1 
\v 4 Nije za careve, Lemuilo,
\q2 nije za careve da piju vino
\q2 i za vladare sklonost žestokom piću.
\q1 
\v 5 Da ne bi uz piće zaboravili šta su odredbe,
\q2 pa onda uskratili pravo svim ojađenima.
\q1 
\v 6 Žestoko piće ostavi za umirućeg
\q2 i vino za unesrećenu dušu.
\q1 
\v 7 Neka takav pije, neka zaboravi svoju bedu
\q2 i svog jada neka se ne seća.
\b
\q1 
\v 8 Govori umesto bezglasnog
\q2 i zastupaj sve ljude koji umiru.
\q1 
\v 9 Govori i sudi pravedno,
\q2 odbrani pravo siromaha i ubogog.“
\ms1 Čestita žena
\q1 
\v 10 Ko da nađe čestitu ženu?
\q2 Takva vredi mnogo više od dragulja.
\q1 
\v 11 U nju se pouzdaje srce njenog muža
\q2 i neće ostati bez dobitka.
\q1 
\v 12 Dobro, a ne zlo ona mu čini
\q2 kroz sve dane života svoga.
\q1 
\v 13 Prihvata se vune i lana
\q2 pa uživa u radu ruku svojih.
\q1 
\v 14 Ona je poput trgovačkih galija,
\q2 jer izdaleka donosi sebi hleba.
\q1 
\v 15 Diže se dok je još mrklo,
\q2 hranu deli ukućanima
\q2 i poslove sluškinjama svojim.
\q1 
\v 16 Razgleda njivu pa je kupi,
\q2 od zarade svojih ruku sadi vinograd.
\q1 
\v 17 Odvažno se prihvata posla
\q2 i mišice svoje jača.
\q1 
\v 18 Uviđa da dobro zarađuje
\q2 i svetiljka joj se po noći ne gasi.
\q1 
\v 19 Rukama se preslice dohvata,
\q2 dlanovima prihvata vreteno.
\q1 
\v 20 Siromahu otvara šaku,
\q2 ruke pruža ubogome.
\q1 
\v 21 Ne strahuje za ukućane kada je sneg,
\q2 jer svi u domu nose dvostruku odeću\f + \fr 31,21 \ft Ovo je prevod prema Septuaginti, a prema jevrejskom tekstu reč je o \fqa grimiznoj odeći.\f*.
\q1 
\v 22 Pokrivače sebi šije
\q2 i odeću od tankoga platna i skerleta.
\q1 
\v 23 Poznaje se njen muž na vratima
\q2 kada sedi sa starešinama zemlje.
\q1 
\v 24 Ona šije lanene košulje i prodaje ih,
\q2 pojasevima snabdeva trgovce.
\q1 
\v 25 Oblači se u čast i u diku
\q2 i smeje se danu što dolazi.
\q1 
\v 26 Mudro otvara usta svoja,
\q2 a na jeziku su joj pouke istine.
\q1 
\v 27 Nadgleda kako joj ukućani žive
\q2 i ne jede hleb u dokolici.
\q1 
\v 28 Sinovi njeni se dižu i blagosiljaju je,
\q2 a njen je muž hvali:
\q1 
\v 29 „Čestite su mnoge žene
\q2 ali ti ih sve nadmašuješ!“
\q1 
\v 30 Dopadljivost je zavodljiva i lepota je prolazna,
\q2 ali će hvaljena biti žena koja se Gospoda boji.
\q1 
\v 31 Podajte joj nešto od ploda njenih ruku
\q2 i neka je na vratima \add grada\add* hvale dela njena!
