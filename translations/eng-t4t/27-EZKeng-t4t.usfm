\v 8 \w When|strong="H3588"\w* \w she|strong="H3588"\w* \w was|strong="H4714"\w* \w a|strong="H3068"\w* young woman \w in|strong="H5921"\w* \w Egypt|strong="H4714"\w*, \w she|strong="H3588"\w* started being \w a|strong="H3068"\w* prostitute, \w and|strong="H4714"\w* \add young\add* \w men|strong="H6213"\w* caressed \w her|strong="H5921"\w* \w breasts|strong="H1717"\w* \w and|strong="H4714"\w* \w had|strong="H3588"\w* \w sex|strong="H7901"\w* \w with|strong="H6213"\w* \w her|strong="H5921"\w*; \w and|strong="H4714"\w* \w when|strong="H3588"\w* \w she|strong="H3588"\w* became older, \w she|strong="H3588"\w* \w did|strong="H6213"\w* \w not|strong="H3808"\w* quit \w acting|strong="H1992"\w* \w like|strong="H3808"\w* \w a|strong="H3068"\w* prostitute.   
\p
\v 9 \w So|strong="H3651"\w* \w I|strong="H5414"\w* \w allowed|strong="H5414"\w* \w the|strong="H5921"\w* Assyrian \w soldiers|strong="H1121"\w*, whom \w she|strong="H5921"\w* wanted \w to|strong="H5921"\w* \w have|strong="H1121"\w* sex \w with|strong="H5921"\w*, \w to|strong="H5921"\w* capture \w her|strong="H5414"\w*.  
\v 10 \w They|strong="H1992"\w* \w stripped|strong="H1540"\w* \w all|strong="H6213"\w* \w her|strong="H1540"\w* clothes \w off|strong="H1540"\w* \w her|strong="H1540"\w*. \w They|strong="H1992"\w* \w took|strong="H3947"\w* \w away|strong="H3947"\w* \w her|strong="H1540"\w* \w sons|strong="H1121"\w* \w and|strong="H1121"\w* \w daughters|strong="H1323"\w*. \w And|strong="H1121"\w* \w then|strong="H1961"\w* \w they|strong="H1992"\w* \w killed|strong="H2026"\w* \w her|strong="H1540"\w* \w with|strong="H6213"\w* \w a|strong="H3068"\w* \w sword|strong="H2719"\w*. \add Other\add* \w women|strong="H1323"\w* \w started|strong="H1961"\w* talking \w about|strong="H1961"\w* \w what|strong="H6213"\w* \w had|strong="H1961"\w* \w happened|strong="H1961"\w* \w to|strong="H1961"\w* \w her|strong="H1540"\w*, \w about|strong="H1961"\w* \w how|strong="H6213"\w* she \w had|strong="H1961"\w* \w been|strong="H1961"\w* punished.   
\p
