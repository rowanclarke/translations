\id JHN
\h San Juan
\toc1 Tu̱hun va̱ha na̱ca̱hyí Juan sa̱há ña̱ na̱caja Jesucristo
\toc2 San Juan
\toc3 Jn.
\mt1 Tu̱hun va̱ha na̱ca̱hyí Juan sa̱há ña̱ na̱caja Jesucristo
\c 1
\s1 Jesucristo cúú á tu̱hun Ndióxi̱ ta na̱nduu a ña̱yivi
\p 
\v 1 Tá na̱ca̱va̱ sáhá sa̱ha̱ ñuyíví sa̱ íin va mé á naní tu̱hun Ndióxi̱. Na̱sahi̱in mé á xi̱hi̱n Ndióxi̱ ta in cúú mé á xi̱hi̱n Ndióxi̱.
\v 2 Ta ja̱nda̱ mé sa̱ha̱ sa̱ íin va xi̱hi̱n Ndióxi̱.
\v 3 Ta mé a̱ cán cúú á Jesucristo ta na̱caja Ndióxi̱ ña̱ na̱cava̱ha mé á tócó ndihi ña̱ha. Ta ni in túhún toho ña̱ha íin, a̱ cóo tá ná a̱ cáva̱ha mé á ña̱, nduu.
\v 4 Ta mé á quéa̱ cája ña̱ ná catacu tócó ndihi ña̱ha ta mé á jándiyéhe̱ a̱ ínima̱ ña̱yivi já ná ndicuni na yo cúú mé á.
\v 5 Mé Jesucristo cúú á tátu̱hun in ñúhu̱ cáyi̱ ña̱ jándiyéhe̱ a̱ xoo naá ta a̱ cu̱ú nda̱hva̱ ña̱.
\p 
\v 6 Ta ndaja coo na̱chindahá Ndióxi̱ in da̱ta̱a naní Juan.
\v 7 Na̱quixi da ca̱xi tu̱hun da xi̱hín ña̱yivi ña̱ cúú Jesucristo ña̱ jándiyéhe̱ ínima̱ ña̱yivi, na̱ ndúu nu̱ú naá já ná cuu candúsa na mé á sa̱há ña̱ na̱ca̱ha̱n da̱.
\v 8 Mé Juan yóho co̱ cúú dá mé á jándiyéhe̱ ínima̱ ña̱yivi. Na̱quixi cuití da̱ ca̱xi tu̱hun da xi̱hín ña̱yivi ña̱ mé Jesucristo quéa̱ jándiyéhe̱ ínima̱ ña̱yivi.
\v 9 Mé Jesucristo na̱xi̱nu̱ a̱ ñuyíví yóho ta cúú ndusa mé a̱ ña̱ jándiyéhe̱ ínima̱ tócó ndihi ña̱yivi.
\p 
\v 10 Na̱quixi mé a̱ naní tu̱hun Ndióxi̱ ta na̱sahi̱in a ñuyíví yóho. Ta xi̱hín ña̱ na̱caja Jesucristo na̱cava̱ha Ndióxi̱ ñuyíví. Joo ña̱yivi ndúu ñuyíví yóho co̱ó na̱xeen na canda̱a̱ ini na yo cúú mé á.
\v 11 Na̱quixi Jesucristo ñuyíví ña̱ na̱cava̱ha mé á joo na̱ ñuu mé á co̱ó na̱xeen toho na ndique̱he va̱ha na mé á.
\v 12 Joo ndá na̱ ná ndiquehe va̱ha mé á ta candeé ini na mé á já quéa̱ sáhan mé á ña̱ma̱ni̱ nu̱ ná ña̱ ná nduu na na̱ cúú cuéntá Ndióxi̱.
\v 13 Ta na̱ cán cúú na̱ na̱nduu ja̱hyi mé á. Ta co̱ cúú á sa̱há ña̱ na̱cacu na ñuyíví yóho ta ni co̱ cúú á sa̱há ña̱ cúni̱ in ta̱a cacu in ja̱hyi da. Na̱nduu na ja̱hyi mé á jáchi̱ já na̱sacu ini mé á coo.
\p 
\v 14 Mé Jesucristo, mé a̱ naní tu̱hun Ndióxi̱ cán na̱nduu a in ta̱a ta na̱quixi a na̱sahi̱in a tañu nde̱. Ta tócó ndihi ña̱ na̱sacaja mé á na̱sa̱cuu a ña̱ nda̱a̱. Ta a̱ ju̱ú quia̱hva quíhvi̱ ini a ña̱yivi. Ta na̱xini nde̱ ndá quia̱hva cáhnu cúú mé á jáchi̱ sa̱há ña̱ cúú mé á in túhún ji̱ni̱ já ja̱hyi Ndióxi̱ sa̱há ña̱ cán quéa̱ na̱caja Ndióxi̱ ña̱ ná ndicáhnu ndiva̱ha mé á.
\v 15 Tá na̱ndicani mé Juan sa̱há Jesús nu̱ú ña̱yivi já na̱cachi da já sa̱ha̱ mé á:
\p —Mé a̱ yóho cúú á ña̱ na̱ca̱ha̱n i̱ sa̱há nu̱ ndo̱ tá na̱cachi i̱ xi̱hi̱n ndo̱ ña̱ va̱xi inga a̱ ja̱tá ye̱he̱. Ta na̱cachi i̱ xi̱hi̱n ndo̱ ña̱ íin chága̱ sa̱ha̱ mé a̱ cán a̱ ju̱ú ga̱ ye̱he̱ jáchi̱ ja̱nda̱ tá cáma̱ní yi̱í cacu u̱ sa̱ íin va mé á —na̱cachi Juan.
\p 
\v 16 Ta sa̱há ña̱ íin ndiva̱ha ña̱ma̱ni̱ nu̱ mé á sa̱há ña̱ cán quéa̱ a̱ ju̱ú quia̱hva ñéhe̱ táhvi̱ tócó ndihí nu̱ mé á.
\v 17 Na̱ca̱hyí Moisés ley Ndióxi̱ sa̱nahá. Joo Jesucristo, mé á cúú á ña̱ nda̱a̱ na̱quixi a ñuyíví yóho sa̱há ña̱ quíhvi̱ ndiva̱ha ini a mí.
\v 18 Ta ni in túhún toho ña̱yivi co̱ó na̱xini na Ndióxi̱. In túhún Jesucristo, mé á cúú in túhún ji̱ni̱ já ja̱hyi Ndióxi̱, mé a̱ cán quéa̱ xíni̱ ndá quia̱hva íin Ndióxi̱ jáchi̱ in cúú á xi̱hi̱n á ta mé a̱ quéa̱ na̱na̱ha̱ ña̱ yóho nu̱ yo̱.
\s1 Ndícani Juan nu̱ú ña̱yivi yo cúú Jesús
\r (Mt. 3:11-12; Mr. 1:7-8; Lc. 3:15-17)
\p 
\v 19 Ta ndaja coo java na̱ sa̱cua̱ha̱ nu̱ú na̱ Israel, na̱ ndúu ñuu Jerusalén cán na̱chindahá na̱ java ju̱tu̱ xi̱hín java na̱ na̱quixi chi̱chi Leví nu̱ íin Juan ña̱ ná nda̱ca̱ tu̱hún na̱ da̱ á cúú dá da̱ na̱sa̱ha̱n Ndióxi̱ tu̱hun a chindahá a̱ ñuyíví.
\v 20 Ta cáxí táhyí na̱ca̱ha̱n Juan xi̱hi̱n ná ña̱ co̱ cúú dá da̱ cán ta já na̱cachi da já:
\p —A̱ ju̱ú toho ye̱he̱ cúú da̱ na̱cachi Ndióxi̱ chindahá a̱ cacomí cuéntá sa̱há ña̱yivi —na̱cachi Juan.
\p 
\v 21 A̱nda̱ já na̱nda̱ca̱ tu̱hún tucu na da̱ já na̱cachi na já xi̱hi̱n dá:
\p —Yo já cúú yóhó, dá já. Á a̱ ju̱ú yóhó cúú profeta Elías —na̱cachi na.
\p —A̱ ju̱ú toho ye̱he̱ cúú profeta Elías —na̱cachi Juan.
\p A̱nda̱ já na̱cachi tucu na já xi̱hi̱n dá:
\p —Á a̱ ju̱ú toho yóhó cúú profeta da̱ na̱cachi Ndióxi̱ chindahá a̱, dá já —na̱cachi na.
\p Joo na̱nducú ñehe Juan tu̱hun nu̱ ná já na̱cachi da já xi̱hi̱n ná:
\p —Ni in túhún toho da cáchí ndó ja̱n co̱ cúú ye̱he̱.
\p 
\v 22 A̱nda̱ já na̱cachi tucu na já xi̱hi̱n dá:
\p —Ndítahan ndicani lohún nu̱ú nde̱ yo cúú yóhó. Jáchi̱ java na̱ na̱chindahá na̱ nde̱he̱ ña̱ ná quixi nde̱ nda̱ca̱ tu̱hún nde̱ yo̱hó. Ta tá co̱ cúnu̱n ca̱xi tu̱hún xi̱hín nde̱ yo cúú yóhó, ndá cu̱hu̱n nde̱ quehe nde̱ tu̱hun nducú ñehe nde̱ nu̱ú na̱ na̱chindahá nde̱he̱ cán —na̱cachi na.
\p 
\v 23 A̱nda̱ já na̱cachi Juan já xi̱hi̱n ná:
\p —Ye̱he̱ cúú da̱ xíca nuu tañu yucú íchí ta cáyuhú cóhó i̱ já cáchí i̱ já xi̱hín ña̱yivi: “Cuná ndó in íchi̱ nda̱cú nu̱ mé á ña̱ ná ndi̱hvi a ínima̱ ndo̱” —na̱cachi Juan xi̱hi̱n ná tá quia̱hva na̱ca̱hyí profeta Isaías sa̱nahá.
\p 
\v 24 Ta na̱ na̱nda̱ca̱ tu̱hún Juan cán na̱sa̱ha̱n na̱ jáchi̱ já na̱ta̱hnda̱ chuun na̱caja na̱ fariseo, mé na̱ sáhndá chuun ñuu Jerusalén cán.
\v 25 Já na̱cachi tucu na já xi̱hi̱n Juan:
\p —Ndá cuéntá quéa̱ cája ndúta̱ yóhó ña̱yivi tá ta̱ co̱ cúún Cristo, da̱ na̱chindahá Ndióxi̱ cacomí cuéntá sa̱há ña̱yivi. Ta ndá cuéntá quéa̱ jácandútu̱n ña̱yivi tá ta̱ ni co̱ cúún Elías ta ni co̱ cúún mé profeta, da̱ na̱cachi Ndióxi̱ chindahá a̱ —na̱cachi na̱ cán.
\p 
\v 26 A̱nda̱ já na̱cachi Juan já xi̱hi̱n ná:
\p —Ye̱he̱ cája ndutá i̱ ña̱yivi xi̱hín ticui̱í joo tañu mé ndó íin in da co̱ xíni̱ ndo̱.
\v 27 Ta va̱xi in da̱ ja̱tá ye̱he̱ ta íin cua̱ha̱ chága̱ sa̱ha̱ dá a̱ ju̱ú ga̱ ye̱he̱. Ta chí ni co̱ó sa̱há i̱ ndaxí i̱ correa ndu̱sa̱ dá —na̱cachi Juan xi̱hín na̱ na̱sa̱ha̱n ndáca̱ tu̱hún ñahá cán.
\p 
\v 28 Tócó ndihi ña̱ yóho na̱ya̱ha chí ñuu Betábara ña̱ ndáca̱a̱n inga xoo yu̱ta Jordán nu̱ú na̱caja ndúta̱ Juan ña̱yivi.
\s1 Jesús cúú á tátu̱hun in ndicachi rí jóco̱ na̱ nu̱ Ndióxi̱
\p 
\v 29 Ta inga qui̱ví ita̱a̱n já na̱xini Juan cáyati Jesús va̱xi a nu̱ íin da. Já na̱cachi Juan já xi̱hín ña̱yivi ndúu cán:
\p —Cande̱hé ndo̱. Da̱ va̱xi ja̱n cúú dá tátu̱hun ndicachi jóco̱ na̱ nu̱ Ndióxi̱. Ta da̱ ja̱n cúú da̱ jándoo cua̱chi ña̱yivi ndúu ñuyíví.
\v 30 Da̱ ja̱n cúú da̱ cáchí i̱ sa̱ha̱ ña̱ va̱xi in da ja̱tá ye̱he̱ ta íin cua̱ha̱ chága̱ sa̱ha̱ dá a̱ ju̱ú ga̱ ye̱he̱. Jáchi̱ ja̱nda̱ tá cáma̱ní cacu ye̱he̱ sa̱ íin va mé da̱ ja̱n.
\v 31 Ta ni mí i̱ co̱ó na̱xini i̱ ndá quia̱hva cáa da joo na̱casáhá i̱ jácandutá i̱ ña̱yivi xi̱hín ticui̱í já ná canda̱a̱ ini na̱ Israel yo cúú mé dá —na̱cachi Juan.
\p 
\v 32 Ta na̱ndicani da ña̱ na̱xini da já na̱cachi da já:
\p —Sa̱ xíní xi̱hín nu̱u̱ mí i̱ ndá quia̱hva na̱nuu ínima̱ yi̱i̱ Ndióxi̱ ja̱tá Jesús. Mé ínima̱ yi̱i̱ Ndióxi̱ cán na̱nuu a indiví ta cáa tá quia̱hva cáa in ndija̱ta.
\v 33 Mé a̱ nda̱a̱ co̱ó na̱xini toho ye̱he̱ yo cúú mé da̱ yóho, nduu. Joo Ndióxi̱, mé a̱ na̱chindahá ye̱he̱ jácandutá i̱ ña̱yivi xi̱hín ticui̱í, mé a̱ cán quéa̱ na̱cachi já xi̱hín i̱: “Ndá da̱ ná cunún ná nuu ínima̱ yi̱i̱ mí i̱ ta saco̱o a ja̱ta̱ dá, da̱ cán cúú da̱ jándicutú ini ña̱yivi xi̱hi̱n ínima̱ yi̱i̱ mí i̱”, na̱cachi Ndióxi̱ xi̱hín i̱.
\v 34 Ta viti mé a̱ nda̱a̱ sa̱ xíni̱ vi̱ yo cúú mé á ta cáxi tu̱hun i̱ xi̱hi̱n ndo̱ ña̱ mé á cúú á in túhún ji̱ni̱ já ja̱hyi Ndióxi̱ —na̱cachi Juan.
\s1 Tá na̱casáhá java ña̱yivi ndíco̱ na̱ Jesús xíca na xi̱hi̱n á
\p 
\v 35 Ta inga qui̱ví ita̱a̱n na̱sahi̱in tucu Juan cán xi̱hín i̱vi̱ na̱ xíca xi̱hi̱n dá.
\v 36 Já na̱xini da ña̱ yáha Jesús cua̱ha̱n já na̱cachi Juan já xi̱hín na̱ xíca xi̱hi̱n dá cán:
\p —Cande̱hé ndo̱. Da̱ ja̱n cúú tátu̱hun ndicachi, rí jóco̱ na̱ nu̱ Ndióxi̱ —na̱cachi Juan.
\p 
\v 37 Tá na̱xini jo̱ho da̱ ndíta xi̱hín da̱ cán ña̱ yóho já ndíco̱ da̱ ja̱tá Jesús cua̱ha̱n da̱.
\v 38 Tá na̱xini Jesús ña̱ ndíco̱ da̱ cán ja̱tá já na̱ndicoto nihni a nu̱ dá já na̱cachi a xi̱hi̱n ndíví da̱ cán já:
\p —Ndía̱ cúni̱ ndo̱ —na̱cachi a.
\p Já na̱cachi da̱ cán já xi̱hi̱n á:
\p —Maestro, ndájá íin vehe ndó já —na̱cachi da.
\p 
\v 39 A̱nda̱ já na̱nducú ñehe Jesús tu̱hun nu̱ dá já na̱cachi a já:
\p —Cóho̱ ná cuni ndó, dá já —na̱cachi a.
\p Já ndáca táhan da na̱sa̱ha̱n da̱ xi̱hi̱n á sánde̱hé da̱ nu̱ íin a. Ta na̱sacuu a tátu̱hun ca̱a̱ co̱mi̱ sa̱hini já na̱sa̱nduu da xi̱hi̱n á.
\p 
\v 40 In táhan da na̱xini jo̱ho ña̱ na̱cachi Juan ta ndíco̱ da̱ ja̱tá Jesús cán naní da̱ Andrés, da̱ cúú ñani Simón, da̱ cáha̱n na̱ Pedro xi̱hi̱n cán.
\v 41 Mé Andrés yóho ndáva da na̱sa̱ha̱n da̱ ndínducú da̱ ñani da, da̱ naní Simón cán. Ta tá na̱ndiñe̱he̱ ñahá da̱ já na̱cachi da já xi̱hi̱n dá:
\p —Na̱nditahan nde̱ da̱ na̱chindahá Ndióxi̱ cacomí cuéntá sa̱há ña̱yivi, mé a̱ cúú Cristo —na̱cachi da.
\p 
\v 42 Tá na̱ndihi já ndáca Andrés cán ñani da na̱sa̱ha̱n da̱ nu̱ Jesús. Ta tá na̱xini Jesús da̱ já na̱cachi a já xi̱hi̱n dá:
\p —Yóhó cúún Simón, ja̱hyi Jonás. Joo ye̱he̱ chinúu i̱ qui̱vu̱n cananún Cefas viti —na̱cachi Jesús.
\p Qui̱vi̱ Cefas yóho in cúú va xi̱hi̱n Pedro ta cúni̱ cachi a in tóto̱.
\s1 Cána Jesús Felipe xi̱hín Natanael ña̱ ná caca tuun da xi̱hi̱n á
\p 
\v 43 Ta inga qui̱ví ita̱a̱n já na̱quee Jesús cua̱ha̱n chí estado Galilea. Ta cán na̱nditahan mé á da̱ naní Felipe já na̱cachi a já xi̱hi̱n dá:
\p —Naha quíi̱ caca tuún xi̱hín i̱ —na̱cachi a xi̱hi̱n dá.
\p 
\v 44 Mé Felipe yóho cúú dá da̱ ñuu Betsaida ta mé ñuu cán cúú ri ñuu Andrés xi̱hi̱n Pedro.
\v 45 Ta ndaja coo Felipe yóho ndáva da na̱sa̱ha̱n da̱ na̱ndinducú da̱ Natanael ta tá na̱ndiñe̱he̱ ñahá da̱ já na̱cachi da já xi̱hi̱n dá:
\p —Na̱nditahan nde̱ da̱ na̱ca̱hyí Moisés sa̱ha̱ nu̱ ley sa̱nahá. Ta jári na̱ profeta na̱ca̱hyí ri na sa̱ha̱ dá. Ta mé dá cúú Jesús, ja̱hyi José, da̱ ñuu Nazaret —na̱cachi Felipe xi̱hín Natanael cán.
\p 
\v 46 A̱nda̱ já na̱cachi Natanael já:
\p —Ndá quehe ri ña̱ha va̱ha quixi chí ñuu Nazaret ja̱n —na̱cachi da.
\p A̱nda̱ já na̱cachi Felipe já xi̱hi̱n dá:
\p —Cóho̱ cande̱hún —na̱cachi da.
\p A̱nda̱ já na̱quee da cua̱ha̱n da̱ nu̱ íin Jesús.
\p 
\v 47 Ta tá na̱xini Jesús na̱cayati Natanael nu̱ á já na̱cachi a já:
\p —Da̱ yóho cúú ndusa in da̱ na̱quixi chi̱chi Israel ta cúú dá ta̱a cája ña̱ nda̱a̱ cuití va —na̱cachi Jesús.
\p 
\v 48 Tá na̱xini jo̱ho Natanael ña̱ yóho já na̱nda̱ca̱ tu̱hún da̱ Jesús já na̱cachi da já xi̱hi̱n á:
\p —Á xíni̱ ndó ye̱he̱, va̱ha.
\p A̱nda̱ já na̱cachi Jesús já xi̱hi̱n dá:
\p —Ja̱nda̱ tá cáma̱ní quee Felipe cu̱hu̱n da̱ cana da yo̱hó já na̱xini i̱ íin coún sa̱ha̱ ti̱tó ñu̱hú —na̱cachi Jesús xi̱hín Natanael.
\p 
\v 49 A̱nda̱ já na̱casáhá cáchí da̱ já xi̱hín Jesús:
\p —Maestro, jivi ndusa cúú ndó in túhún ji̱ni̱ já ja̱hyi Ndióxi̱ ta cúú ndó ña̱ cómí cuéntá sa̱há ña̱yivi Israel —na̱cachi da xi̱hín Jesús.
\p 
\v 50 A̱nda̱ já na̱nducú ñehe Jesús tu̱hun nu̱ dá já na̱cachi a já:
\p —Na̱candúsún ye̱he̱ sa̱há ña̱ na̱cachi i̱ xu̱hu̱n ña̱ na̱xini i̱ íin coún sa̱ha̱ ti̱tó ñu̱hú. Joo náhnu chága̱ ña̱ha cunún xi̱hín nduchú núún caja i̱ —na̱cachi Jesús xi̱hi̱n dá.
\p 
\v 51 A̱nda̱ já na̱cachi tucu Jesús já:
\p —Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱ ña̱ cuni ndó xi̱hín nu̱u̱ ndó ña̱ nu̱ná indiví. Ta cuni ndó táto̱ Ndióxi̱ ndaa na ta nuu na xi̱nu̱ na nu̱ íin ye̱he̱, da̱ na̱chindahá Ndióxi̱ nduu ña̱yivi —na̱cachi Jesús.
\c 2
\s1 Tá na̱sa̱ha̱n Jesús in vicó tánda̱ha̱
\p 
\v 1 Tá na̱ya̱ha u̱ni̱ qui̱vi̱ já na̱sahi̱in in vicó tánda̱ha̱ ñuu Caná ña̱ ndáca̱a̱n estado Galilea cán. Ta na̱sa̱ha̱n María, náná Jesús mé víco̱ cán.
\v 2 Ta jári na̱cana na Jesús xi̱hín na̱ xíca tuun xi̱hi̱n á ta chí na̱sa̱ha̱n ndihi na mé víco̱ cán.
\v 3 Joo ndaja coo nani cúú víco̱ cán na̱ndihi va vino xíhi na. Ta tá na̱xini náná Jesús ña̱ yóho já na̱cachi ñá já xi̱hín Jesús:
\p —Sa̱ na̱ndihi va vino xíhi na —na̱cachi ñá xi̱hi̱n á.
\p 
\v 4 Já na̱cachi Jesús já xi̱hi̱n ñá:
\p —Co̱ xíní ñúhú toho ca̱ha̱n ndó já xi̱hín i̱ jáchi̱ cáma̱ní yi̱i̱ va ndindaa hora caja i̱ ña̱ha xitúhún —na̱cachi Jesús xi̱hi̱n ña̱.
\p 
\v 5 Tá na̱ndihi já na̱cachi náná Jesús já xi̱hín na̱ jácaca vino cán:
\p —Ndá ña̱ha ná cahnda Jesús nu̱ ndó caja ndó, caja ndó ña̱ —na̱cachi ñá xi̱hi̱n ná.
\p 
\v 6 Ta mé vehe nu̱ cúú víco̱ cán na̱sahi̱in i̱ñu̱ yoo náhnu ña̱ na̱cava̱ha na xi̱hín yu̱u̱. Mé yoo cán na̱sa̱cuu a nu̱ táán na̱ Israel cán ticui̱í, dó ndája vií na̱ mé ná tá quia̱hva sáhndá ley nu̱ ná caja na. Ta tátu̱hun co̱mi̱ jícó á in ciento litro ticui̱í quéta ini in in yoo náhnu cán.
\v 7 Tá na̱ndihi já na̱cachi Jesús já xi̱hín na̱ jácaca vino cán:
\p —Jácutú ndihi ndó yoo náhnu ja̱n xi̱hín ticui̱í.
\p Ta chí na̱jácutú jíní nda̱a̱ na̱ yoo náhnu cán xi̱hín ticui̱í.
\v 8 Tá na̱ndihi já na̱cachi tucu Jesús já xi̱hi̱n ná:
\p —Ta viti tavá loho ndó do̱ ta quia̱hva ndó do̱ ná coto ndojó da̱ cómí chuun sa̱ha̱ víco̱ yóho —na̱cachi Jesús.
\p Já ñéhe na do̱ na̱sa̱ha̱n na̱ nu̱ú da̱ cómí chuun sa̱ha̱ víco̱ cán.
\v 9 Joo sa̱ na̱caja Jesús ña̱ ná nduu ticui̱í cán vino. Ta na̱xito ndojó da̱ do̱ joo co̱ xíni̱ da̱ ndájá na̱quixi dó. In túhún na̱ xíni̱ cúú na̱ na̱xini ña̱ na̱ndaja Jesús cán ticui̱í ña̱ ná nduu dó vino. Tá na̱xito ndojó mé da̱ cómí chuun yóho do̱ já na̱catóntó da̱ ta na̱cana da mé da̱ tánda̱ha̱ cán.
\v 10 Já na̱cachi da já xi̱hi̱n dá:
\p —Ndijáá ña̱yivi tá cája na in víco̱ já sáhan na vino va̱ha nu̱ cuítí nu̱ú na̱ táhan cán. Ta tá sa̱ na̱xi̱hi̱ cua̱há na̱ já sáhan na dó núu cán. Joo yóhó na̱sacu va̱hún vino va̱ha ta ja̱ víti sáhún do̱ nu̱ú na̱ tácá víco̱ —na̱cachi da.
\p 
\v 11 Ña̱ xitúhún yóho na̱caja Jesús ñuu Caná cuéntá estado Galilea na̱sa̱cuu a̱ ña̱ xitúhún nu̱ cuítí na̱caja Jesús já ná cuni ña̱yivi ndá quia̱hva cáhnu cúú mé á. Ta xi̱hín ña̱ yóho na̱candeé ini na̱ xíca tuun xi̱hín a̱ cán mé á.
\p 
\v 12 Tá sa̱ na̱ya̱ha ña̱ yóho já na̱quee a cua̱ha̱n xi̱hín na̱ xíca tuun xi̱hi̱n á chí ñuu Capernaum. Ta ndáca táhan náná a̱ xi̱hín ñani a ndíco̱ na̱ cua̱ha̱n na̱ xi̱hi̱n á. Ta na̱sa̱nduu na ñuu Capernaum cán chá qui̱vi̱ cuití va.
\s1 Tává Jesús na̱ ndúu jícó veñu̱hu cáhnu ñuu Jerusalén
\r (Mt. 21:12-13; Mr. 11:15-18; Lc. 19:45-46)
\p 
\v 13 Tá na̱cayati qui̱ví caja na̱ Israel vicó pascua já na̱quee Jesús na̱sa̱ha̱n chí ñuu Jerusalén.
\v 14 Ta tá na̱xi̱nu̱ co̱o a veñu̱hu cáhnu ndáca̱a̱n Jerusalén cán já na̱xini a ña̱ ja̱ndá joho ndúu na̱ jícó. Java na jícó tindi̱qui̱ xi̱hín ndicachi xi̱hín ndija̱ta viti ta java na ndúu coo ndíjama jiu̱hún.
\v 15 Ta chí na̱tiin Jesús yóho̱ ta na̱cava̱ha in churrú xi̱hi̱n á já na̱casáhá táxí ndihi a na̱ ndúu jícó cán. Ta ja̱nda̱ tindi̱qui̱ xi̱hín ndicachi ja̱na̱ ná na̱tavá a̱ ri̱ quee rí cu̱hu̱n ri̱. Ta já na̱xi̱nu̱ co̱o a nu̱ ndúu na̱ ndíjama jiu̱hún cán já na̱xicó ñehe a mesa na̱ já na̱cu̱yu ndihi jiu̱hún na̱ nu̱ ñúhu̱.
\v 16 Ta na̱sahnda a̱ chuun nu̱ú na̱ jícó ndija̱ta cán já na̱cachi a já:
\p —Tavá ndihi ndó ña̱ jícó ndó ja̱n. A̱ cája ndó xi̱hín vehe tátá i̱ ña̱ cúú á nu̱ cáya̱hvi ña̱ha —na̱cachi Jesús xi̱hi̱n ná.
\p 
\v 17 Tá na̱ndihi já na̱ndicu̱hu̱n ini na̱ xíca tuun xi̱hín Jesús cán ña̱ cáchí tu̱hun Ndióxi̱. Já cáchí a̱ já: “A̱ ju̱ú quia̱hva xójo̱ ini i̱ sa̱há ña̱ co̱ cája cáhnu ña̱yivi vehe Ndióxi̱”, cáchí tu̱hun Ndióxi̱.
\p 
\v 18 Tá na̱xini na̱ Israel cán ña̱ na̱caja Jesús ña̱ yóho já na̱nda̱ca̱ tu̱hún na̱ mé á já na̱cachi na já xi̱hi̱n á:
\p —Xíní ñúhú cajún in ña̱ha xitúhún já ná cuni nde̱ ña̱ mé a̱ nda̱a̱ íin sa̱hún tasún na̱ ndúu jícó veñu̱hu yóho —na̱cachi na xi̱hín Jesús.
\p 
\v 19 A̱nda̱ já na̱nducú ñehe Jesús tu̱hun nu̱ ná já na̱cachi a já xi̱hi̱n ná:
\p —Tá ná jándita̱ni̱ ndó veñu̱hu yóho ta ti̱xi u̱ni̱ qui̱vi̱ já jácandichi tucu u̱ ña̱ —na̱cachi Jesús xi̱hi̱n ná.
\p 
\v 20 A̱nda̱ já na̱cachi na̱ Israel cán já xi̱hi̱n á:
\p —Co̱ cándúsa nde̱ ña̱ cáchún jáchi̱ na̱caja chúun na i̱vi̱ jico i̱ñu̱ cui̱a̱ já na̱xi̱nu̱ veñu̱hu ja̱n. Ta yóhó cáchún ña̱ ti̱xi u̱ni̱ víxí qui̱vi̱ jácandichi tucún ña̱, va̱ha —na̱cachi na̱ cán xi̱hín Jesús.
\p 
\v 21 Joo co̱ cáha̱n toho Jesús sa̱há veñu̱hu cáhnu cán jáchi̱ cáha̱n mé á sa̱ha̱ yiquí cu̱ñu a.
\v 22 Ña̱ cán quéa̱ tá na̱xi̱hi̱ Jesús ta na̱nditacu tucu a ti̱xi u̱ni̱ qui̱vi̱ já na̱ndicu̱hu̱n ini na̱ xíca tuun xi̱hi̱n á cán sa̱há tu̱hun na̱ca̱ha̱n mé á nu̱ú na̱ Israel yóho. Ta chí na̱candúsa na tu̱hun Ndióxi̱ ta na̱candúsa na tócó ndihi ña̱ na̱ca̱ha̱n Jesús xi̱hi̱n ná.
\s1 Sa̱ xíni̱ va Jesús ínima̱ ña̱yivi
\p 
\v 23 Cua̱há ña̱yivi ñuu Jerusalén cán na̱candúsa na Jesús nani na̱sahi̱in a víco̱ pascua cán sa̱há ña̱ náhnu xi̱hín ña̱ xitúhún na̱caja nu̱ ná.
\v 24 Va̱tí na̱cachi na cándúsa na mé á joo co̱ó na̱candúsa toho Jesús na̱ jáchi̱ xíni̱ va̱ha mé á ndá ínima̱ ñéhe in in na̱ cán.
\v 25 Ta co̱ xíní ñúhú toho a ña̱ ca̱xi tu̱hun na xi̱hi̱n á ndá quia̱hva íin in in ña̱yivi jáchi̱ sa̱ xíni̱ ndihi va mé á ínima̱ ná.
\c 3
\s1 Ndítúhún Nicodemo xi̱hín Jesús
\p 
\v 1 Na̱sahi̱in in da̱ xíca cuéntá na̱ fariseo naní Nicodemo ta cúú dá da̱ sa̱cua̱ha̱ nu̱ú na̱ Israel cán.
\v 2 Ta ñuú na̱queta da cua̱ha̱n da̱ coto nihni da Jesús. Ta tá na̱xi̱nu̱ co̱o da nu̱ á já na̱cachi da já xi̱hi̱n á:
\p —Maestro, cánda̱a̱ cáxí ini nde̱ ña̱ na̱chindahá Ndióxi̱ ndo̱hó va̱xi ndó nu̱ú nde̱ ña̱ ná jána̱ha̱ ndó nu̱ú nde̱. Jáchi̱ ni in túhún toho ña̱yivi a̱ cu̱ú caja ña̱ náhnu cája mé ndó tá ta̱ co̱ íin Ndióxi̱ xi̱hi̱n ná —na̱cachi da xi̱hín Jesús.
\p 
\v 3 A̱nda̱ já na̱nducú ñehe Jesús tu̱hun nu̱ dá já na̱cachi a já:
\p —Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱ ña̱ ni in túhún ña̱yivi a̱ cúu cacomí Ndióxi̱ cuéntá sa̱ha̱ tá ná a̱ ndícó co̱o tucu na cacu tucu na —na̱cachi a.
\p 
\v 4 A̱nda̱ já na̱nda̱ca̱ tu̱hún Nicodemo Jesús já na̱cachi da:
\p —Ndá quia̱hva cuu cacu tucu na tá sa̱ na̱cayatá na̱. Ama ná ndi̱hvi tucu na ti̱xi náná na̱ já cacu tucu na —na̱cachi Nicodemo xi̱hín Jesús.
\p 
\v 5 A̱nda̱ já na̱cachi tucu Jesús já xi̱hi̱n dá:
\p —Cáha̱n i̱ ña̱ nda̱a̱ xi̱hi̱n ndo̱. Tá na̱candúta̱ ña̱yivi xi̱hín ticui̱í ta tá na̱ndicutú nda̱a̱ ínima̱ ná xi̱hi̱n ínima̱ yi̱i̱ Ndióxi̱ já cúú á tátu̱hun cácu tucu na ta a̱nda̱ já cuu cacomí Ndióxi̱ cuéntá sa̱ha̱ ná.
\v 6 Jáchi̱ ñuyíví yóho cácu ja̱hyi ña̱yivi ta sa̱ já ña̱yivi cúú va na. Joo na̱ jándicutú Ndióxi̱ xi̱hi̱n ínima̱ yi̱i̱ mé á, na̱ cán cúú ja̱hyi mé á.
\v 7 Ta co̱ ndítahan catóntó ndó tá cáchí i̱ xi̱hi̱n ndó ña̱ ndítahan cacu tucu ndihi ña̱yivi já ná cacomí Ndióxi̱ cuéntá sa̱ha̱ ná.
\v 8 Jáchi̱ cúú á tátu̱hun tá xícó ta̱chi̱ ndá xoo cúni̱ mé á. Va̱tí xíni̱ jo̱ho í xícó ta̱chi̱ joo co̱ xíni̱ yo̱ ndá xoo quíxi a ta co̱ xíni̱ yo̱ ndá xoo cua̱ha̱n. Quia̱hva já íin ínima̱ yi̱i̱ Ndióxi̱ jáchi̱ va̱tí co̱ xíní ña̱yivi mé á joo xíní na̱ ndá quia̱hva cája mé á tá ñúhu a ini na —na̱cachi Jesús xi̱hín Nicodemo.
\p 
\v 9 Tá na̱ndihi já na̱cachi Nicodemo já xi̱hín Jesús:
\p —Co̱ cánda̱a̱ toho ini i̱ ña̱ cáchí ndo̱ xi̱hín i̱ —na̱cachi da.
\p 
\v 10 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n dá:
\p —Cúú ndó da̱ jána̱ha̱ nu̱ú ña̱yivi Israel ta ndítahan canda̱a̱ ini ndó ña̱ yóho, nduu jáchi̱ cúú ndó maestro cáhnu nu̱ ná.
\v 11 Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. Cáha̱n nde̱ sa̱há ña̱ cánda̱a̱ ini nde̱ ta sa̱há ña̱ na̱xini nde̱ xi̱hín nu̱ú nde̱ joo ndóhó co̱ cándúsa ndó ña̱ cáha̱n nde̱ xi̱hi̱n ndo̱.
\v 12 Cáha̱n i̱ sa̱há ña̱ha ñuyíví yóho xi̱hi̱n ndo̱ ta co̱ cándúsa ndó ña̱. Ndaja ga̱ ví caja ndó tá ná ca̱ha̱n i̱ sa̱há ña̱ha íin indiví.
\p 
\v 13 ʼNi in túhún toho ña̱yivi a̱ ñáha ndaa cu̱hu̱n chí indiví. In túhún da̱ ndaa indiví cúú da̱ na̱nuu, da̱ na̱quixi ñuyíví yóho. Ta da̱ cán cúú ye̱he̱, da̱ na̱chindahá Ndióxi̱ nduu ña̱yivi.
\v 14 Sa̱nahá ndiva̱ha na̱cata caa Moisés in co̱o, rí na̱cava̱ha xi̱hín ca̱a nu̱ yíto̱ yucú íchí. Quia̱hva já cata caa ri na ye̱he̱, da̱ na̱chindahá Ndióxi̱ nduu ña̱yivi ndi̱ca crúxu̱
\v 15 já quéa̱ ná ca̱cu ndaa ínima̱ ña̱yivi já ná a̱ cúhu̱n na̱ indayá tá ná candeé ini na ye̱he̱. Ta xi̱hín ña̱ yóho catacu na a̱nda̱ ama cáa qui̱vi̱.
\s1 Quíhvi̱ ndiva̱ha ini Ndióxi̱ ña̱yivi ndúu ñuyíví
\p 
\v 16 ʼJáchi̱ sa̱ha̱ ña̱ na̱qui̱hvi̱ ndiva̱ha ini Ndióxi̱ ña̱yivi ndúu ñuyíví sa̱há ña̱ cán quéa̱ na̱chindahá mé á in túhún ji̱ni̱ já ja̱hyi a ñuyíví yóho. Já quéa̱ tá ná candeé ini na mé á cuu ca̱cu ndaa ínima̱ ná já ná catacu na a̱nda̱ ama cáa qui̱vi̱.
\v 17 Co̱ó na̱chindahá Ndióxi̱ ja̱hyi a ña̱ ná quixi da jándihi da sa̱há na̱ ndúu ñuyíví yóho. Na̱chindahá a̱ ja̱hyi a jáchi̱ cúni̱ a̱ jáca̱cu a ña̱yivi.
\p 
\v 18 ʼTa ndá na̱ sa̱ cándeé ini ye̱he̱, ña̱ cúú u̱ ja̱hyi Ndióxi̱, na̱ cán cúú na̱ cája cáhnu ini Ndióxi̱ sa̱ha̱. Joo na̱ co̱ó na̱xeen cándúsa ñahá cán, na̱ cán cúú na̱ co̱ cája cáhnu ini Ndióxi̱ sa̱ha̱ jáchi̱ co̱ó na̱xeen na cándúsa na da̱ cúú in túhún ji̱ni̱ já ja̱hyi mé á.
\v 19 Ta na̱ co̱ó na̱xeen cándúsa cán sa̱ na̱sacu va Ndióxi̱ sa̱ha̱ ná cu̱hu̱n na̱ indayá jáchi̱ na̱ca̱an na cája na ña̱ núu. Sa̱há ña̱ cán quéa̱ na̱xi̱nu̱ mé á cúú ja̱hyi Ndióxi̱ ñuyíví yóho ta cúni̱ a̱ jándiyéhe̱ a̱ nu̱ú ña̱yivi. Jáchi̱ cátóó chága̱ na̱ canduu na nu̱ú naá jáchi̱ cája na ña̱ núu.
\v 20 Jáchi̱ tócó ndihi na̱ cája ña̱ núu cándají na̱ ña̱ va̱ha, ña̱ cúú tátu̱hun ña̱ yéhe̱. Ta co̱ cúni̱ na̱ cayati na nu̱ú ña̱ yéhe̱ cán já ná a̱ ndíti̱vi ña̱ núu cája na.
\v 21 Joo na̱ cája ña̱ nda̱a̱, na̱ cán cúú na̱ cáyati chága̱ nu̱ú ña̱ va̱ha, ña̱ cúú tátu̱hun ña̱ yéhe̱ já ná na̱ha̱ ña̱ mé a̱ nda̱a̱ cája na ña̱ cúni̱ Ndióxi̱ —na̱cachi Jesús.
\s1 Ndícani tucu Juan sa̱há Jesús
\p 
\v 22 Tá sa̱ na̱ya̱ha ña̱ yóho já na̱quee Jesús na̱sa̱ha̱n chí estado Judea xi̱hín na̱ xíca tuun xi̱hi̱n á. Ta cán na̱sahi̱in a chá tiempo xi̱hi̱n ná jáchi̱ na̱jácandúta̱ ná ña̱yivi mé cán.
\v 23 Ta jári Juan va na̱jácandúta̱ dá ña̱yivi chí ñuu naní Enón yati ñuu Salim cán jáchi̱ cán ñúhu cua̱há ticui̱í. Ta cua̱há ña̱yivi na̱sa̱ha̱n na̱ cán candúta̱ ná.
\v 24 Tócó ndihi ña̱ yóho na̱ya̱ha tá cáma̱ní tiin na Juan chica̱a̱n na̱ da̱ veca̱a.
\p 
\v 25 In tañu java na̱ xíca xi̱hi̱n Juan cán na̱casáhá na̱ ndítúhún i̱hvi̱ na̱ xi̱hín java na̱ Israel sa̱há ña̱ yóho: á ndíya̱hvi chága̱ tá cája ndúta̱ Juan ña̱yivi á tá cája ndúta̱ na̱ xíca tuun xi̱hín Jesús ña̱yivi.
\v 26 Tá na̱ndihi já ndáva na̱ xíca xi̱hi̱n Juan na̱sa̱ha̱n na̱ cáha̱n na̱ xi̱hi̱n dá já na̱cachi na já:
\p —Maestro, da̱ta̱a, da̱ na̱nditúhún xi̱hi̱n ndó inga xoo yu̱ta Jordán cán, da̱ na̱ca̱ha̱n mé ndó sa̱ha̱ nu̱ú nde̱ cán, viti xíca nuu da jácandúta̱ dá ña̱yivi ta ja̱ndá joho tócó ndihi ña̱yivi ndíco̱ na̱ da̱ viti —na̱cachi na̱ cán xi̱hi̱n Juan.
\p 
\v 27 A̱nda̱ já na̱cachi Juan já xi̱hín na̱ cán:
\p —Ni in túhún toho ña̱ha a̱ cúu caja ña̱yivi tá co̱ sáhan Ndióxi̱ ña̱ma̱ni̱ nu̱ ná caja na ña̱.
\v 28 Ta sa̱ na̱xini jo̱ho ndó ña̱ na̱ca̱xi tu̱hun ya̱chi̱ vi̱ xi̱hi̱n ndo̱ ña̱ co̱ cúú ye̱he̱ da̱ na̱sa̱ha̱n Ndióxi̱ tu̱hun a chindahá a̱ cacomí a̱ cuéntá sa̱há ña̱yivi. Na̱chindahá Ndióxi̱ ye̱he̱ já ná cacu tia̱hva i̱ íchi̱ nu̱ú quixi mé da̱ cán.
\v 29 Cande̱hé ndo̱. Cúú á tátu̱hun tá cúu in víco̱ tánda̱ha̱. Ta da̱ cúú amigo da̱ tánda̱ha̱ cán ndáti da casa̱a̱ da̱. Ta cáji̱i̱ ini da tá xíni̱ jo̱ho da nu̱ cáha̱n vatá da̱ tánda̱ha̱ cán jáchi̱ íin ñájíhí da̱ xi̱hi̱n dá. Ta quia̱hva já cáji̱i̱ ini i̱ jáchi̱ cásáhá ña̱yivi ndíco̱ na̱ ja̱ta̱ Jesús viti.
\v 30 Mé Jesús ja̱n ndicáhnu joho ga̱ cu̱hu̱n a̱. Ta ye̱he̱ ndítahan nuu ndáha joho i̱ cu̱hu̱n i̱ —na̱cachi Juan.
\s1 Jesús quéa̱ na̱quixi chí indiví
\p 
\v 31 Mé Jesús na̱quixi chí indiví ta cáhnu chága̱ mé á nu̱ ndíhi ña̱ha. Ta ña̱yivi na̱cacu ñuyíví yóho cáha̱n na̱ sa̱há ña̱ha ñuyíví cuití va. Joo mé á na̱quixi chí indiví cán cúú á ña̱ cáhnu chága̱ nu̱ tócó ndihi ña̱ha.
\v 32 Ta cáha̱n mé a̱ cán sa̱há ña̱ na̱xini xi̱hín nu̱u̱ a̱ ta cáha̱n sa̱há ña̱ na̱xini jo̱ho a. Joo ni in na co̱ cúni̱ candúsa na ña̱ cáha̱n mé á.
\v 33 Joo ndá na̱ cándúsa nu̱ cáha̱n mé á, na̱ cán cúú na̱ cánda̱a̱ cáxí ini na ña̱ cáha̱n Ndióxi̱ ña̱ nda̱a̱.
\v 34 Ndióxi̱ quéa̱ na̱chindahá mé á ta cáha̱n ndinuhu tu̱hun Ndióxi̱ jáchi̱ co̱ ndáhví toho cúú ini Ndióxi̱ jándicutú nda̱a̱ mé a̱ cán xi̱hín ínima̱ yi̱i̱ mé á.
\v 35 Ta Ndióxi̱, tátá a̱ ña̱ íin indiví quíhvi̱ ndiva̱ha ini a in túhún ji̱ni̱ já ja̱hyi a ta na̱sa̱ha̱n ndée̱ a̱ nu̱ú ja̱hyi a ña̱ ná cuu caja tócó ndihi ña̱ha.
\v 36 Ta ndá na̱ cándeé ini mé a̱ cúú in túhún ji̱ni̱ já ja̱hyi Ndióxi̱ cán, na̱ cán cúú na̱ catacu a̱nda̱ ama cáa qui̱vi̱. Joo na̱ co̱ cúni̱ candúsa ñahá cán, na̱ cán cúú na̱ a̱ ñéhe̱ táhvi̱ toho na catacu na xi̱hi̱n Ndióxi̱. Ña̱ caja Ndióxi̱ xi̱hi̱n ná quéa̱ chindahá a̱ na̱ cu̱hu̱n na̱ indayá a̱nda̱ ama cáa qui̱vi̱.
\c 4
\s1 Ndítúhún Jesús xi̱hín in ñáñáha̱ cuéntá Samaria
\p 
\v 1 Ta ndaja coo na̱ fariseo na̱canda̱a̱ ini na ña̱ cua̱ha̱ chága̱ ña̱yivi ndíco̱ ja̱tá Jesús ta cua̱ha̱ chága̱ ña̱yivi jácandúta̱ Jesús a̱ ju̱ú ga̱ Juan.
\v 2 Va̱tí a̱ ju̱ú mé Jesús jácandúta̱ ña̱yivi joo na̱ xíca tuun xi̱hi̱n á cán jácandúta̱ ñahá.
\v 3 Ta tá na̱xini jo̱ho Jesús ña̱ cáha̱n ña̱yivi sa̱há já na̱quee a estado Judea xi̱hín na̱ xíca tuun xi̱hi̱n á cua̱ha̱n na̱ ndicó co̱o na chí estado Galilea.
\p 
\v 4 Ta nu̱ú cu̱hu̱n a̱ Galilea cán ndúsa̱ ya̱ha nda̱a̱ estado Samaria já xi̱nu̱ a̱ nu̱ú cu̱hu̱n a̱ cán.
\v 5 Ta na̱xi̱nu̱ a̱ in ñuu loho naní Sicar cuéntá mé Samaria cán yati nu̱ú ñundáhyi̱ ña̱ na̱jándicoo ta̱hvi̱ Jacob nu̱ José, ja̱hyi da.
\v 6 Ta cán na̱sahi̱in in chi̱co̱ho̱ ña̱ naní chi̱co̱ho̱ Jacob. Ta cúú á tátu̱hun ca̱xi̱vi̱ tá na̱xi̱nu̱ co̱o Jesús ñuu Sicar cán. Ta chí a̱ váha ga̱ na̱canaá a̱ sa̱há ña̱ cán quéa̱ na̱saco̱o a yati yuhú chi̱co̱ho̱ cán.
\v 7 Ta nani íin coo a cán já na̱xi̱nu̱ in ñáñáha̱ cuéntá Samaria tavá ña̱ ticui̱í ini chi̱co̱ho̱ cán. Já na̱cachi Jesús já xi̱hi̱n ñá:
\p —Quia̱hva loho ticui̱í ná coho i̱ —na̱cachi a xi̱hi̱n ñá.
\v 8 Jáchi̱ sa̱ cua̱ha̱n na̱ xíca tuun xi̱hi̱n á ñuu cueen na ña̱ha cuxu na.
\p 
\v 9 A̱nda̱ já na̱catóntó ña̱ jáchi̱ co̱ xíní táhan va̱ha na̱ Israel xi̱hín na̱ Samaria. Ta na̱cachi ñá já xi̱hín Jesús já:
\p —Ndá cuéntá quéa̱ xíca̱ yóhó, da̱ Israel, ticui̱í nu̱ú i̱ cohún ta ñá Samaria va cúú ye̱he̱ —na̱cachi ñá cán xi̱hín Jesús.
\p 
\v 10 Já na̱cachi a já xi̱hi̱n ñá:
\p —Tá ná canda̱a̱ inún yo cúú ye̱he̱, da̱ xíca̱ ticui̱í nu̱u̱n ta tá ná canda̱a̱ inún ndá quia̱hva íin ña̱ cúni̱ Ndióxi̱ quia̱hva nu̱u̱n já ca̱cún ña̱ nu̱ú i̱. Jáchi̱ ye̱he̱ cuu caja i̱ ña̱ ná catacún a̱nda̱ ama cáa qui̱vi̱ ta ña̱ yóho cuu a tátu̱hun ticui̱í, do̱ a̱ cúu ndihi sa̱ha̱ —na̱cachi Jesús.
\p 
\v 11 A̱nda̱ já na̱cachi ñá cán já xi̱hi̱n á:
\p —Cande̱hé ndo̱. Ni yáxi̱ co̱ ñéhe ndó tavá ndó ticui̱í ini chi̱co̱ho̱ yóho ta chi̱co̱ho̱ cúná ndiva̱ha cúú ña̱ yóho. Ndá cuu caja ri ndó quia̱hva ndó ticui̱í cáchí ndo̱ ja̱n nu̱ú i̱.
\v 12 Tásáhnu jícó nde̱, da̱ naní Jacob cán na̱jándacoo chi̱co̱ho̱ yóho nu̱ú nde̱. Ta nu̱ú chi̱co̱ho̱ yóho na̱xihi da̱ cán ticui̱í ta sa̱ mé chi̱co̱ho̱ yóho na̱xihi ri ja̱hyi da̱ cán ta yóho na̱xihi ri quíti̱ ja̱na̱ dá. Ama ná cuu quia̱hva mé ndó ticui̱í va̱ha chága̱ a̱ ju̱ú ga̱ dó na̱jándacoo Jacob nu̱ú nde̱ —na̱cachi ñá cán xi̱hín Jesús.
\p 
\v 13 A̱nda̱ já na̱nducú ñehe Jesús tu̱hun nu̱ ñá já na̱cachi a já:
\p —Ndá ña̱yivi na̱cuu va xíhi ticui̱í chi̱co̱ho̱ yóho já quéa̱ i̱chi̱ tá i̱chi̱ ini na.
\v 14 Joo ndá na̱ ná coho ticui̱í táhan dó sáhan ye̱he̱, na̱ cán cúú na̱ a̱ ndícó co̱o ga̱ na̱ i̱chi̱ ini na a̱nda̱ ama cáa qui̱vi̱. Jáchi̱ cúú á tátu̱hun sa̱ mé ini mé va na cana ticui̱í, dó a̱ ndíhi sa̱ha̱ ta catacu na a̱nda̱ ama cáa qui̱vi̱ —na̱cachi Jesús xi̱hi̱n ñá.
\p 
\v 15 A̱nda̱ já na̱cachi ñá cán já xi̱hín Jesús:
\p —Quia̱hva mé ndó ticui̱í, dó co̱ ndíhi sa̱ha̱ ja̱n nu̱ú i̱ ña̱ ná a̱ íchi̱ ga̱ ini i̱ ticui̱í já ná a̱ quíxi ga̱ i̱ yóho tavá i̱ dó coho i̱ —na̱cachi ñá xi̱hi̱n á.
\p 
\v 16 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ña̱:
\p —Cuáhán cana yíu̱n ná quixi da yóho xu̱hu̱n.
\p 
\v 17 A̱nda̱ já na̱nducú ñehe ñá cán tu̱hun nu̱ á já na̱cachi ñá já:
\p —Co̱ó toho yií i̱.
\p A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ñá:
\p —Mé a̱ nda̱a̱ co̱ó toho yíu̱n.
\v 18 Joo na̱sahi̱in u̱hu̱n yíu̱n ta da̱ íin xu̱hu̱n viti ja̱n co̱ cúú toho da yíu̱n. Nda̱a̱ ndusa cáhu̱n —na̱cachi Jesús.
\p 
\v 19 Já na̱cachi ñá já xi̱hi̱n á:
\p —Jivi ndusa in profeta cúú mé ndó.
\v 20 Tásáhnu jícó nde̱, na̱ Samaria yóho na̱caja cáhnu na Ndióxi̱ yati ji̱ni̱ yúcu̱ ja̱n. Joo ndóhó, na̱ Israel cáchí ndo̱ ña̱ ndúsa̱ ndítahan nu̱ú nde̱ cu̱hu̱n nde̱ ñuu Jerusalén caja cáhnu nde̱ Ndióxi̱. Ta mé ndó ndaja cachi ndó —na̱cachi ñá cán xi̱hín Jesús.
\p 
\v 21 A̱nda̱ já na̱nducú ñehe Jesús tu̱hun nu̱ ñá já na̱cachi a já xi̱hi̱n ñá:
\p —Xíní ñúhú candúsún ña̱ cáha̱n i̱ jáchi̱ mé a̱ nda̱a̱ va̱xi qui̱vi̱ caja cáhnu ndihi ndó Ndióxi̱, tátá yo̱ ndá xoo na̱cuu va. A̱ cúní ñúhú ga̱ ndó cu̱hu̱n ndo̱ ji̱ni̱ yúcu̱ cáa ta ni a̱ cúní ñúhú ga̱ ndó cu̱hu̱n ndó ñuu Jerusalén caja cáhnu ndó Ndióxi̱.
\v 22 Joo ndóhó, na̱ Samaria cája cáhnu cuáá ndo̱ Ndióxi̱ jáchi̱ co̱ xíni̱ ndó a̱. Joo nde̱he̱, na̱ Israel xíni̱ va̱ha nde̱ yo cúú Ndióxi̱ cája cáhnu nde̱. Jáchi̱ chi̱chi mé nde̱, na̱ Israel na̱sacu ini Ndióxi̱ quixi mé á jáca̱cu ña̱yivi.
\v 23 Ta viti na̱xi̱nu̱ qui̱vi̱ tá ndítahan caja cáhnu ña̱yivi Ndióxi̱, tátá yo̱ xi̱hín ndinuhu ini na tá quia̱hva cúni̱ ínima̱ yi̱i̱ Ndióxi̱ jáchi̱ quia̱hva já cúni̱ Ndióxi̱, tátá yo̱ ña̱ ná caja cáhnu ña̱yivi mé á.
\v 24 A̱ cu̱ú cuni yó Ndióxi̱ jáchi̱ co̱ó toho yiquí cu̱ñu a sa̱há ña̱ cán quéa̱ xíní ñúhú caja cáhnu ña̱yivi mé á xi̱hín ínima̱ ná ta xi̱hín ndiñuhu ini na —na̱cachi Jesús xi̱hi̱n ña̱.
\p 
\v 25 A̱nda̱ já na̱cachi tucu ñá cán já:
\p —Sa̱ cánda̱a̱ cáxí ini i̱ ña̱ va̱xi qui̱vi̱ quixi da̱ chindahá Ndióxi̱ cacomí a̱ cuéntá sa̱há ña̱yivi, mé da̱ cúú Cristo. Ta tá ná quixi da̱ cán já ndicani ndihi da nu̱ú nde̱ ndaja coo —na̱cachi ñá cán xi̱hín Jesús.
\p 
\v 26 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ñá:
\p —Da̱ cán cúú ye̱he̱, da̱ cáha̱n xu̱hu̱n viti —na̱cachi Jesús xi̱hi̱n ñá.
\p 
\v 27 Ta nani cáha̱n Jesús xi̱hi̱n ñá na̱xi̱nu̱ co̱o na̱ xíca tuun xi̱hi̱n á já na̱catóntó na̱ jáchi̱ na̱xini na ndítúhún a̱ xi̱hín in ñáñáha̱. Joo ni in túhún na̱ co̱ó na̱sa̱ha̱n ndeé ini na cu̱hu̱n na̱ nda̱ca̱ tu̱hún ñahá ndá a̱ cúni̱ ñá cán, á ndá sa̱ha̱ ndítúhún a̱ xi̱hi̱n ñá.
\v 28 Tá na̱ndihi já na̱jándacoo ñá cán yoo ñá ta na̱quee ñá cua̱ha̱n ñá ñuu. Ta cán na̱casáhá cáha̱n ñá xi̱hín na̱ ñuu cán já cáchí ña̱ já xi̱hi̱n ná:
\p 
\v 29 —Naha quíi̱ ndó. Cande̱hé ndó in da̱ta̱a, da̱ na̱ca̱ha̱n ndihi da tá quia̱hva na̱caja i̱. Á a̱ ju̱ú da̱ yóho cúú Cristo, da̱ na̱cachi Ndióxi̱ chindahá a̱ cacomí cuéntá sa̱há ña̱yivi —na̱cachi ñá cán xi̱hi̱n ná.
\p 
\v 30 Tá na̱ndihi já na̱queta ndihi na̱ cán cua̱ha̱n na̱ xi̱hi̱n ña̱ nu̱ íin Jesús.
\v 31 Joo tá cáma̱ni̱ xi̱nu̱ co̱o na nu̱ íin Jesús já na̱jáca̱ha̱n na̱ xíca xi̱hi̱n á mé á ña̱ ná cuxu a va̱tí loho.
\p 
\v 32 A̱nda̱ já na̱cachi Jesús já xi̱hín na̱ xíca tuun xi̱hi̱n á cán:
\p —Sa̱ íin va ña̱ha cuxu u̱. Ta ndóhó, co̱ xíni̱ toho ndó ndá a̱ que̱á —na̱cachi Jesús xi̱hi̱n ná.
\p 
\v 33 Tá na̱ndihi já na̱casáhá na̱ cán ndáca̱ tu̱hún táhan na já cáchí na̱ já:
\p —Ndá na̱ sa̱ na̱quixi ñehe va ña̱ha cuxu a —cáchí xi̱hi̱n táhan na.
\p 
\v 34 Sa̱há ña̱ cán quéa̱ na̱cachi Jesús já xi̱hi̱n ná:
\p —Tá quia̱hva ndíva̱ha ini ña̱yivi tá xíxi na quia̱hva já ndíva̱ha ini i̱ tá cája i̱ chuun ña̱ na̱chindahá Ndióxi̱ ye̱he̱ caja i̱ ñuyíví yóho. Ta xíní ñúhú caja i̱ ña̱ ja̱nda̱ quia̱hva ná jáxi̱nu̱ co̱o i̱ ña̱.
\v 35 Xíní ñúhú ndiñehe ndó nu̱u̱ ndó cande̱hé ndo̱ ña̱yivi jáchi̱ cúú ná tátu̱hun nu̱ú na̱xutu na trigo. Joo co̱ xíní ñúhú caja ndó tá quia̱hva cája ña̱yivi tá ndáti na co̱mí yo̱o̱ jáquee na trigo. Jáchi̱ viti ñúhú íin tia̱hva ña̱yivi ndiquehe na tu̱hun Ndióxi̱.
\v 36 Ndá na̱ xíca chíndeé ña̱yivi ndiquehe na tu̱hun Ndióxi̱, na̱ cán cúú ná tátu̱hun na̱ xíca jáquee trigo. Ta a̱ cája chúun uun toho na jáchi̱ quehe na ya̱hvi sa̱há chuun cája na. Ta na̱ ndíquehe tu̱hun Ndióxi̱ cán cúú na̱ cu̱hu̱n catacu indiví a̱nda̱ ama cáa qui̱vi̱. Ta sa̱há na̱ cán cavatá da̱ na̱xutu xi̱hín da̱ na̱jáquee.
\v 37 Jáchi̱ íin in tu̱hun ta nda̱a̱ cáha̱n ña̱. Já cáchí a̱ já: “In da xútu ta inga da jáquee jáchi̱ cúú ndíví da̱ da̱ cája chúun nu̱ú in xitoho.”
\v 38 Ta quia̱hva já na̱ya̱ha xi̱hi̱n mé ndó jáchi̱ ye̱he̱ na̱chindahá i̱ ndo̱hó ña̱ ná cu̱hu̱n ndó chindeé ndo̱ ña̱yivi ndi̱hvi na íchi̱ cuéntá Ndióxi̱ va̱tí co̱ó na̱ndoho ini ndó ca̱xi tu̱hun ndó tu̱hun Ndióxi̱ xi̱hi̱n ná. Jáchi̱ inga na na̱ca̱xi tu̱hun tu̱hun Ndióxi̱ xi̱hín na̱ cán joo ndóhó ñéhe̱ táhvi̱ ndó chíndeé ndó na̱ ndi̱hvi na íchi̱ cuéntá Ndióxi̱ —na̱cachi Jesús xi̱hín na̱ xíca tuun xi̱hi̱n á cán nani cáma̱ni̱ xi̱nu̱ co̱o ña̱yivi ñuu cán nu̱ á.
\p 
\v 39 Ta cua̱há ña̱yivi ñuu Samaria cán na̱candúsa na Jesús sa̱há ña̱ na̱ca̱ha̱n ñáñáha̱ cán xi̱hi̱n ná jáchi̱ na̱cachi ñá cán já xi̱hi̱n ná: “Na̱cachi mé á xi̱hín i̱ ndaja cáa tócó ndihi ña̱ na̱caja i̱.”
\v 40 Sa̱há ña̱ cán quéa̱ tá na̱xi̱nu̱ co̱o na̱ Samaria cán nu̱ íin Jesús já na̱xi̱ca̱ ta̱hví na̱ nu̱ á ña̱ ná coo chága̱ xi̱hi̱n ná. Sa̱há ña̱ cán quéa̱ na̱cando̱o Jesús na̱sahi̱in a i̱vi̱ qui̱vi̱ xi̱hín na̱ cán.
\v 41 Ta cua̱há java ga̱ na̱ Samaria cán na̱candúsa na Jesús sa̱há tu̱hun na̱ca̱ha̱n mé á xi̱hi̱n ná.
\v 42 Já na̱cachi mé na̱ Samaria cán xi̱hín ñáñáha̱ cán já:
\p —Na̱candúsa nde̱ yo̱hó tá na̱ca̱hún sa̱há Jesús nu̱ú nde̱ joo viti cándeé ini nde̱ mé á jáchi̱ na̱xini jo̱ho nde̱ nu̱ cáha̱n mé á. Ta viti ndusa cándúsa nde̱ ña̱ cúú á Cristo, mé á na̱chindahá Ndióxi̱ jáca̱cu a ña̱yivi ñuyíví —na̱cachi na̱ Samaria cán xi̱hi̱n ñá.
\s1 Tá na̱ndaja va̱ha Jesús ja̱hyi in da̱ cája chúun cuéntá gobierno
\p 
\v 43 Tá sa̱ na̱ya̱ha i̱vi̱ qui̱vi̱ na̱sahi̱in Jesús mé Samaria cán já na̱quee tucu a cua̱ha̱n chí estado Galilea.
\v 44 Jáchi̱ sa̱ na̱cachi mé Jesús já: “Ni in túhún toho profeta co̱ cája cáhnu na da̱ ñuu da”, na̱cachi Jesús.
\v 45 Joo tá na̱xi̱nu̱ co̱o Jesús estado Galilea cán já na̱ndiquehe va̱ha na̱ cán mé á jáchi̱ sa̱ na̱sa̱ha̱n ri na̱ cán vicó pascua ñuu Jerusalén ta cán na̱xini na ña̱ náhnu na̱caja mé á.
\p 
\v 46 A̱nda̱ já na̱xi̱nu̱ co̱o tucu Jesús ñuu Caná cuéntá Galilea cán nu̱ú na̱ndaja mé á ticui̱í na̱nduu dó vino. Ta mé ñuu cán na̱sahi̱in in da̱ta̱a, da̱ cája chúun cuéntá gobierno. Ta a̱ ju̱ú quia̱hva quíhvi̱ ja̱hyi da cándúhu̱ dá ñuu Capernaum.
\v 47 Ta tá na̱xini jo̱ho da̱ cán ña̱ sa̱ na̱quee Jesús estado Judea ta íin a estado Galilea viti já ndáva da na̱sa̱ha̱n da̱ nu̱ á já na̱xi̱ca̱ ta̱hví da̱ nu̱ á ña̱ ná cu̱hu̱n a̱ vehe da ndaja va̱ha ja̱hyi da jáchi̱ sa̱ ndícáhví da̱ cándúhu̱ dá.
\v 48 Tá na̱ndihi já na̱cachi Jesús já xi̱hi̱n dá:
\p —Ndúsa̱ caja i̱ ña̱ náhnu xi̱hín ña̱ xitúhún nu̱ ndo̱ já cuu candúsa ndó ye̱he̱ á tá co̱ó ta co̱ cúni̱ ndó candúsa ndó ye̱he̱ —na̱cachi Jesús.
\p 
\v 49 A̱nda̱ já na̱nducú ñehe da̱ cája chúun cuéntá gobierno cán tu̱hun nu̱ú Jesús já na̱cachi da já xi̱hi̱n á:
\p —Á a̱ cu̱ú caja ndó ña̱ma̱ni̱ cu̱hu̱n quíi̱ ndó vehe e̱ jáchi̱ cúni̱ quivi ja̱hyi i̱ —na̱cachi da xi̱hín Jesús.
\p 
\v 50 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n dá:
\p —Cuáhán ndicó co̱o ndó vehe ndó jáchi̱ na̱ndiva̱ha ja̱hyi ndó —na̱cachi Jesús xi̱hi̱n dá.
\p Ta na̱candúsa da̱ cán ña̱ na̱cachi Jesús xi̱hi̱n dá chí na̱quee da na̱ndicó co̱o da cuanúhu̱ dá.
\v 51 Ta tá sa̱ yati xi̱nu̱ co̱o da vehe da já ndáva nihni na̱ cúú mozo da na̱sa̱ha̱n na̱ ñe̱he̱ ná da̱ já na̱cachi na já xi̱hi̱n dá:
\p —Sa̱ co̱ quíhvi̱ ga̱ ja̱hyi ndó viti.
\p 
\v 52 A̱nda̱ já na̱nda̱ca̱ tu̱hún da̱ cán mozo da̱ já cáchí da̱ já:
\p —Ndá hora na̱casáhá na̱ndiva̱ha ja̱hyi i̱ —na̱cachi da xi̱hi̱n ná.
\p Já na̱cachi na̱ cán já:
\p —Cuni tátu̱hun ca̱a̱ in sa̱hini já na̱ndindaa ña̱ chíca̱a̱n cáhni̱ á da̱.
\p 
\v 53 Xi̱hín ña̱ yóho na̱canda̱a̱ ini da̱ cán ña̱ mé a̱ nda̱a̱ na̱ndaja va̱ha Jesús ja̱hyi da jáchi̱ mé hora cán na̱cachi Jesús xi̱hi̱n dá ña̱ tácú tá tácú ja̱hyi da. Sa̱há ña̱ cán quéa̱ na̱candúsa mé dá xi̱hín na̱ vehe da Jesús.
\p 
\v 54 Ta xi̱hín ña̱ yóho na̱xi̱nu̱ i̱vi̱ ña̱ xitúhún na̱caja Jesús estado Galilea cán a̱nda̱ nani na̱quee a Judea já na̱ndicó co̱o tucu a Galilea.
\c 5
\s1 Tá na̱ndaja va̱ha Jesús in da̱ quíhvi̱, da̱ íin yuhú ticui̱í naní Betesda
\p 
\v 1 Tá na̱ya̱ha ña̱ yóho já na̱quee Jesús cua̱ha̱n ñuu Jerusalén nu̱ cája na̱ Israel víco̱.
\v 2 Ta mé nu̱ quíhvi joho na ñuu Jerusalén cán íin in yéhé naní yéhé ndicachi. Ta yati cán na̱sahi̱in in vehe ta íin u̱hu̱n yuyéhé nu̱ quíhvi na ini a ta ini mé vehe cán ndáca̱a̱n in pila cáhnu nu̱ ñúhu ticui̱í ta naní a̱ Betesda tu̱hun hebreo.
\v 3 Ta níí ini mé vehe cán na̱caníhni na̱ quíhvi̱ ndúu na. Java na̱ cúú ná na̱ cua̱á. Java na quíhvi̱ sa̱ha̱. Ta java na na̱xi̱hi̱ tu̱chu. Níí cán na̱caníhni na ndúu na ndáti na ndica̱nda̱ ticui̱í cán.
\v 4 Jáchi̱ ndá tañu núu táto̱ Ndióxi̱ ta jándica̱nda̱ mé á ticui̱í cán. Ta ndá na̱ ná que̱ta nuu nu̱ cuítí ini mé ticui̱í cán tá na̱ndihi na̱ndica̱nda̱ do̱ já ndiva̱ha na ta co̱ cája toho a ndá cue̱he̱ ndóho na.
\v 5 Ta tañu tócó ndihi na̱ quíhvi̱ na̱sa̱nduu cán na̱sa̱ndaca̱a̱n in da̱ta̱a, da̱ sa̱ íin o̱co̱ sa̱hu̱n u̱ni̱ cui̱a̱ quíhvi̱ da̱.
\v 6 Ta tá na̱xini Jesús cándúhu̱ dá tañu na̱ quíhvi̱ cán ta tá na̱canda̱a̱ ini a ña̱ sa̱nahá ndiva̱ha quíhvi̱ da̱ já na̱nda̱ca̱ tu̱hún a̱ da̱ já na̱cachi a já xi̱hi̱n dá:
\p —Á ndiva̱hún cúnu̱n.
\p 
\v 7 A̱nda̱ já na̱nducú ñehe da̱ cán tu̱hun nu̱ á já na̱cachi da já:
\p —Co̱ó ni in ña̱yivi yóho ña̱ chindeé na̱ ye̱he̱ que̱ta nuu i̱ ini ticui̱í tá ndíca̱nda̱ do̱. Jáchi̱ tá ja̱cá cáhán uun i̱ jáque̱ta i̱ mí i̱, sa̱ na̱quee va̱ha va inga na nu̱ú i̱. Ña̱ cán quéa̱ a̱ cu̱ú ndiva̱ha i̱ —na̱cachi da̱ cán xi̱hín Jesús.
\p 
\v 8 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n dá:
\p —Cuáhán ndaco̱o nditivún yívu̱n ta cuanúhu̱n —na̱cachi Jesús xi̱hín da̱ cán.
\p 
\v 9 Tá na̱cachi Jesús já chí i̱vi̱ la̱á na̱ndiva̱ha da̱ quíhvi̱ cán já na̱ndiquehe da yívi̱ dá já na̱casáhá da̱ xíca da. Ta sa̱há ña̱ cúú á qui̱vi̱ ndíquehe ndée̱ ná
\v 10 sa̱há ña̱ cán quéa̱ na̱queta java na̱ sa̱cua̱ha̱ nu̱ú na̱ Israel já na̱cachi na já xi̱hi̱n dá:
\p —Viti cúú á qui̱vi̱ ndíquehe ndée̱ yo̱ ta co̱ ndítahan toho nu̱u̱n cojún yívu̱n caca nuún —na̱cachi na xi̱hi̱n dá.
\p 
\v 11 A̱nda̱ já na̱nducú ñehe da̱ cán tu̱hun nu̱ ná já na̱cachi da já:
\p —Mé da̱ na̱ndaja va̱ha ye̱he̱ cán cúú da̱ na̱sahnda chuun nu̱ú i̱ ña̱ ná cojo i̱ yívi̱ cu̱hu̱n i̱ —na̱cachi da̱ cán xi̱hi̱n ná.
\p 
\v 12 Já na̱nda̱ca̱ tu̱hún tucu na̱ Israel cán da̱ já na̱cachi na já:
\p —Yo já na̱cachi xu̱hu̱n ña̱ ná ndicojún yívu̱n cu̱hu̱n —na̱cachi na̱ cán.
\p 
\v 13 Joo da̱ cán co̱ xíni̱ da̱ yo na̱ndaja va̱ha ñahá jáchi̱ tá na̱ndaja va̱ha Jesús da̱ já na̱qui̱hvi nuu a cán tañu ña̱yivi cua̱ha̱ cán cua̱ha̱n.
\v 14 Tá na̱ndihi já na̱nditahan Jesús da̱ cán ini veñu̱hu cáhnu já na̱cachi a já xi̱hi̱n dá:
\p —Cande̱hé. Sa̱ co̱ quíhvi̱ ga̱ún viti. A̱ ndícó co̱o ga̱ún cajún cua̱chi jáchi̱ tia̱hva náá quixi ña̱ ndeé chága̱ ví ndohún —na̱cachi Jesús xi̱hi̱n dá.
\p 
\v 15 Tá na̱ndihi já ndáva da̱ cán na̱sa̱ha̱n da̱ cáxi tu̱hun da nu̱ú na̱ Israel ña̱ Jesús cúú ña̱ na̱ndaja va̱ha ñahá.
\v 16 Sa̱há ña̱ cán quéa̱ na̱casáhá na̱ Israel cán cája xíxi na xi̱hín Jesús. Ndúcú na̱ cahní na̱ a̱ sa̱há ña̱ cája chúun a ndája va̱ha mé á na̱ quíhvi̱ qui̱vi̱ ndíquehe ndée̱ ná.
\v 17 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ná:
\p —Cája chúun ta cája chúun Ndióxi̱, tátá i̱ sa̱há ña̱ cán quéa̱ cája chúun ta cája chúun ri ye̱he̱ va —na̱cachi Jesús.
\p 
\v 18 Sa̱há ña̱ cán quéa̱ ví ga̱ ví cúni̱ na̱ Israel cán cahní na̱ Jesús jáchi̱ cáchí na̱ co̱ cája cáhnu a Ndióxi̱ qui̱vi̱ ndíquehe ndée̱ ná tá quia̱hva cáchí ley. Ta cúni̱ na̱ cahní na̱ mé á jáchi̱ cáchí a̱ ña̱ cúú á in túhún ji̱ni̱ já ja̱hyi Ndióxi̱ ta xi̱hín ña̱ yóho ndája mé á tátu̱hun mé Ndióxi̱.
\s1 Ña̱ cúú cája Jesús sa̱há ña̱ cúú á in túhún ji̱ni̱ já ja̱hyi Ndióxi̱
\p 
\v 19 Já na̱cachi Jesús já xi̱hín na̱ Israel cán:
\p —Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. Ye̱he̱ cúú u̱ in túhún ji̱ni̱ já ja̱hyi Ndióxi̱ ta co̱ cája i̱ ni in ña̱ha cuéntá mí i̱ jáchi̱ cája i̱ ña̱ xíní i̱ cája Ndióxi̱, tátá i̱. Ta tócó ndihi ña̱ cája tátá i̱ ña̱ cán cúú ña̱ cája ri ye̱he̱ va.
\v 20 Jáchi̱ sa̱há ña̱ quíhvi̱ ini Ndióxi̱, tátá i̱ ye̱he̱ sa̱há ña̱ cán quéa̱ náha̱ mé á nu̱ú i̱ ndaja táhan ña̱ha cája mé á. Ta ja̱nda̱ ña̱ha náhnu chága̱ ví na̱ha̱ mé á nu̱ú i̱ ta chí catóntó ndihi ndó tá ná cuni ndó ña̱.
\v 21 Jáchi̱ tá quia̱hva cája Ndióxi̱, tátá i̱ jánditacu a ndi̱i ña̱ ná catacu na quia̱hva já cuu caja ri ye̱he̱ jánditacu u̱ na̱ cúni̱ mí i̱ catacu.
\v 22 Ta mé Ndióxi̱, tátá i̱ co̱ cája vií toho a sa̱há ña̱yivi. Ña̱ na̱caja mé á quéa̱ na̱sa̱ha̱n ña̱ma̱ni̱ nu̱ú i̱, da̱ cúú in túhún ji̱ni̱ já ja̱hyi mé á, ña̱ ná caja vií i̱ sa̱ha̱ ná.
\v 23 Já quéa̱ ná caja cáhnu ña̱yivi ye̱he̱ tá quia̱hva cája cáhnu na Ndióxi̱, tátá i̱. Jáchi̱ ndá na̱ co̱ cája cáhnu ye̱he̱ náha̱ ña̱ co̱ cája cáhnu na Ndióxi̱, tátá i̱ jáchi̱ mé a̱ cán na̱chindahá ye̱he̱ va̱xi i̱.
\p 
\v 24 ʼMé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. Ndá na̱ táa jo̱ho va̱ha nu̱ cáha̱n i̱ ta cándúsa na Ndióxi̱, mé a̱ na̱chindahá ye̱he̱ quixi i̱, na̱ cán cúú na̱ catacu a̱nda̱ ama cáa qui̱vi̱. Ta a̱ jándoho Ndióxi̱ ini na indayá jáchi̱ cúú á tátu̱hun sa̱ na̱jánditacu tucu Ndióxi̱ na̱.
\v 25 Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱ ña̱ va̱xi qui̱vi̱ ta cúú á tiempo viti tá na̱ co̱ tácú cuni jo̱ho na ña̱ cáha̱n ye̱he̱, da̱ cúú in túhún ji̱ni̱ já ja̱hyi Ndióxi̱. Ta ndá na̱ ná ndiquehe va̱ha tu̱hun cáha̱n i̱ xi̱hi̱n ná catacu na a̱nda̱ ama cáa qui̱vi̱.
\v 26 Jáchi̱ tá quia̱hva cuu caja Ndióxi̱ catacu ña̱yivi quia̱hva já na̱caja mé á ña̱ ná caja ri ye̱he̱, da̱ cúú in túhún ji̱ni̱ já ja̱hyi mé á, ña̱ ná cuu catacu ña̱yivi.
\v 27 Ta na̱sa̱ha̱n mé á ña̱ma̱ni̱ nu̱ú i̱ ña̱ ná caja vií i̱ sa̱há ña̱yivi ñuyíví jáchi̱ ye̱he̱ cúú da̱ na̱quixi indiví nduu in ña̱yivi.
\v 28 A̱ cátóntó ndo̱ sa̱há ña̱ cáha̱n i̱ xi̱hi̱n ndo̱ yóho jáchi̱ mé a̱ nda̱a̱ va̱xi qui̱vi̱ tá cuni jo̱ho tócó ndihi na̱ sa̱ na̱xi̱hi̱ nu̱ú ca̱ha̱n i̱ xi̱hi̱n ná
\v 29 já queta na camasanto. Ta na̱ na̱caja va̱ha cán nditacu na ta cu̱hu̱n na̱ catacu na a̱nda̱ ama cáa qui̱vi̱. Ta na̱ na̱caja ña̱ quini nditacu na ta cu̱hu̱n na̱ indayá ndoho ini na.
\s1 Náha̱ Jesús ña̱ íin sa̱ha̱ cája tócó ndihi ña̱ cája
\p 
\v 30 ʼTócó ndihi ña̱ cája i̱ a̱ ju̱ú in túhún mí i̱ caja ña̱. Tá quia̱hva sáhndá Ndióxi̱, tátá i̱ chuun nu̱ú i̱ ña̱ ná caja vií i̱ sa̱há ña̱yivi quia̱hva já cája vií i̱ sa̱ha̱ ná. Ta cája vií nda̱a̱ i̱ sa̱ha̱ ná jáchi̱ co̱ ndúcú u̱ caja i̱ ña̱ cúni̱ mí i̱. Ña̱ ndúcú u̱ caja i̱ cúú ña̱ cúni̱ Ndióxi̱, tátá i̱ caja i̱ jáchi̱ mé á na̱chindahá ye̱he̱ quixi i̱.
\v 31 Jáchi̱ tá sa̱ha̱ mí i̱ ná caca nuu i̱ ca̱ha̱n i̱, co̱ nditahan ndíquehe ndó ña̱ cáha̱n i̱ sa̱há i̱. Co̱ ndítahan nu̱ú i̱ ca̱ha̱n i̱ sa̱ha̱ mí i̱
\v 32 jáchi̱ íin inga ña̱ cáha̱n sa̱há i̱ ta ña̱ cáha̱n mé a̱ cán sa̱há i̱ cúú á ña̱ nda̱a̱.
\v 33 Ta mé ndó na̱chindahá ndo̱ java na na̱sa̱ha̱n na̱ ndáca̱ tu̱hún na̱ Juan sa̱há i̱. Ta ña̱ nda̱a̱ na̱sa̱cuu tócó ndihi tu̱hun na̱nducú ñehe da̱ cán nu̱ ndo̱.
\v 34 Va̱tí co̱ ndáti i̱ cándúsa ndó ye̱he̱ sa̱há ña̱ cáha̱n in ña̱yivi sa̱há i̱ joo cuu ca̱cu ndaa ínima̱ ndó tá ná candúsa ndó ña̱ cáha̱n Juan sa̱há i̱.
\v 35 Jáchi̱ mé Juan, da̱ na̱caja ndúta̱ ña̱yivi cán na̱sa̱cuu da tátu̱hun in íti̱, dó jándiyéhe̱ nu̱u̱ ndo̱. Joo chá tiempo cuití va na̱caji̱i̱ ini ndó xi̱hín tu̱hun na̱ca̱ha̱n da̱.
\v 36 Íin inga ña̱ cáhnu chága̱ a̱ ju̱ú ga̱ ña̱ na̱ca̱ha̱n Juan sa̱há i̱. Ta ña̱ cán cúú á ña̱ náhnu xi̱hín ña̱ xitúhún na̱xini ndó na̱caja i̱. Ta ña̱ yóho náha̱ nu̱ ndo̱ yo cúú ye̱he̱ ta náha̱ ña̱ cúú á ña̱ nda̱a̱ ña̱ na̱chindahá Ndióxi̱, tátá i̱ ye̱he̱. Jáchi̱ tócó ndihi ña̱ cája i̱ cúú á ña̱ na̱cachi Ndióxi̱, tátá i̱ xi̱hín i̱ caja i̱.
\v 37 Ta Ndióxi̱, tátá i̱, mé á na̱chindahá ye̱he̱ náha̱ tu̱hun sa̱há i̱. Joo ndóhó, co̱ xíni̱ jo̱ho ndó nu̱ cáha̱n mé á ta ni co̱ xíní tívi ndó a̱.
\v 38 Ta ni co̱ó tu̱hun mé á ndáca̱a̱n ínima̱ ndo̱ jáchi̱ co̱ cándúsa ndó ye̱he̱, da̱ na̱chindahá mé á quixi ñuyíví yóho.
\v 39 Va̱tí jácuaha va̱ha ndó tu̱hun Ndióxi̱ sa̱há ña̱ ndúcú ndo̱ ndaja cuu catacu ndó a̱nda̱ ama cáa qui̱vi̱ joo co̱ cánda̱a̱ ini ndó ña̱ mé tu̱hun Ndióxi̱ cán cúú á ña̱ cáha̱n sa̱há ye̱he̱.
\v 40 Ta co̱ cúni̱ ndó quixi ndó nu̱ú i̱ já ná caja i̱ ña̱ ná catacu ndó a̱nda̱ ama cáa qui̱vi̱.
\p 
\v 41 ʼCo̱ ndúcú toho i̱ ña̱ ná caja cáhnu ndó ye̱he̱.
\v 42 Sa̱ xíni̱ va̱ha i̱ ínima̱ ndo̱ ta cánda̱a̱ ini i̱ ña̱ co̱ quíhvi̱ ini ndó Ndióxi̱.
\v 43 Na̱xi̱nu̱ i̱ ñuyíví yóho cuéntá Ndióxi̱, tátá i̱ ta co̱ cúni̱ ndó ndique̱he va̱ha ndó ye̱he̱. Joo tá ná quixi in da cuéntá mé dá já ndique̱he va̱ha ndusa ndó da̱.
\v 44 Jáchi̱ mé ndó cátóó ndó cando̱o va̱ha ndó nu̱ú ña̱yivi cuití va ta co̱ ndúcú ndó cando̱o va̱ha ndó nu̱ Ndióxi̱. Sa̱há ña̱ cán quéa̱ i̱hvi̱ ndiva̱ha cúú ini ndó cándeé ini ndó in túhún ji̱ni̱ Ndióxi̱.
\v 45 Coto a̱ ju̱ú ca̱hán ndo̱ ña̱ jácojo i̱ cua̱chi ja̱ta̱ ndo̱ nu̱ Ndióxi̱, tátá i̱. Mé ley na̱ca̱hyí Moisés, ña̱ cán cúú á chíca̱a̱n cua̱chi ja̱ta̱ ndó va̱tí cándeé ini ndó da̱.
\v 46 Tá ta̱ mé a̱ nda̱a̱ cándúsa ndó ña̱ na̱ca̱hyí Moisés sa̱nahá já quéa̱ cándúsa ndó ye̱he̱ jáchi̱ sa̱há ye̱he̱ na̱ca̱hyí Moisés sa̱nahá.
\v 47 Joo sa̱há ña̱ co̱ cándúsa ndó ña̱ na̱ca̱hyí Moisés sa̱há i̱ sa̱há ña̱ cán quéa̱ co̱ cándúsa ndó ña̱ cáha̱n i̱ xi̱hi̱n ndo̱ —na̱cachi Jesús xi̱hín na̱ Israel cán.
\c 6
\s1 Sáhan Jesús ña̱ cuxu u̱hu̱n mil ta̱a
\r (Mt. 14:13-21; Mr. 6:30-44; Lc. 9:10-17)
\p 
\v 1 Tá sa̱ na̱ya̱ha tócó ndihi ña̱ yóho já na̱quee Jesús cua̱ha̱n inga xoo tañu̱hú Galilea cán. Ta mé tañu̱hú cán cáha̱n tucu na xi̱hi̱n dó naní do̱ Tiberias.
\v 2 Ta cua̱há ndiva̱ha ña̱yivi ndíco̱ ja̱ta̱ Jesús cua̱ha̱n na̱ jáchi̱ na̱xini na ña̱ náhnu na̱caja mé á tá na̱ndaja va̱ha mé á na̱ quíhvi̱.
\v 3 Tá na̱ndihi já na̱ndaa Jesús in xi̱qui̱ ta cán na̱saco̱o a xi̱hín na̱ xíca tuun xi̱hín a̱ cán.
\v 4 Ta mé tiempo já sa̱ cáyati vicó pascua ña̱ cája mé na̱ Israel cán.
\v 5 Ta tá na̱ndicoto nihni Jesús já na̱xini a ña̱ ndíco̱ cua̱há ña̱yivi ja̱tá va̱xi na já na̱cachi a já xi̱hín Felipe:
\p —Ndájá cájún cuéntá co̱hó cueen na̱há yo̱ ña̱ cuxu tócó ndihi ña̱yivi yóho —na̱cachi Jesús xi̱hi̱n dá.
\p 
\v 6 Na̱cachi Jesús ña̱ yóho xi̱hín Felipe jáchi̱ cúni̱ a̱ cuni a ndía̱ cachi da̱ cán xi̱hi̱n á. Jáchi̱ sa̱ xíni̱ va̱ha Jesús ndáa̱ quéa̱ caja ña̱ ná cuxu ndihi na̱ cán.
\v 7 A̱nda̱ já na̱nducú ñehe Felipe tu̱hun nu̱ú Jesús já na̱cachi da já xi̱hi̱n á:
\p —Ni i̱vi̱ ciento denario ná cañehé, a̱ quéta toho ña̱ cán cueén pan ná quia̱hva in yuhú in yuhú cuxu in in ña̱yivi ndúu yóho —na̱cachi da̱ cán xi̱hín Jesús.
\p 
\v 8 A̱nda̱ já na̱ca̱ha̱n Andrés, da̱ cúú in táhan na̱ xíca tuun xi̱hín Jesús, da̱ cúú ñani Simón Pedro. Já na̱cachi da já xi̱hín Jesús:
\p 
\v 9 —Yóho íin in ta̱a loho ta ñéhe da u̱hu̱n pan cebada xi̱hín i̱vi̱ ti̱yacá. Joo ama ná queta ri ña̱ yóho cuxu tócó ndihi ña̱yivi ja̱n —na̱cachi Andrés xi̱hín Jesús.
\p 
\v 10 A̱nda̱ já na̱cachi Jesús já:
\p —Ca̱ha̱n ndó xi̱hi̱n ná ña̱ ná caco̱o na.
\p A̱nda̱ já na̱saco̱o ndihi na̱ cán. Ta a̱ ju̱ú quia̱hva ndató na̱sahnu yu̱cu̱ nu̱ú na̱saco̱o tátu̱hun u̱hu̱n mil ta̱a.
\v 11 Tá na̱ndihi já na̱tiin Jesús pan cán já na̱ndiquia̱hva ndixa̱hvi nu̱ Ndióxi̱. Ta tá na̱ndihi já na̱sa̱ha̱n ña̱ nu̱ú na̱ xíca tuun xi̱hi̱n á ta na̱ndicahnda na ña̱ nu̱ú na̱ ndúu coo cán. Ta quia̱hva já na̱caja ri a xi̱hín ti̱yacá va. Ta na̱xixi ndihi na ja̱nda̱ quia̱hva na̱chutú ti̱xi na.
\v 12 Ta tá na̱ndihi já na̱cachi Jesús já xi̱hín na̱ xíca tuun xi̱hi̱n á cán:
\p —Jánditaca ndó tócó ndihi ña̱ na̱cando̱o ja̱n já ná a̱ tíví ña̱ —na̱cachi Jesús xi̱hi̱n ná.
\p 
\v 13 Sa̱há ña̱ cán quéa̱ na̱jánditaca na ña̱ ta na̱jándicutú na̱ u̱xu̱ i̱vi̱ to̱yi̱cá xi̱hín ña̱ na̱cando̱o.
\v 14 Tá na̱xini ndihi ña̱yivi cán ña̱ xitúhún na̱caja Jesús yóho já na̱casáhá cáchí xi̱hi̱n táhan na já:
\p —Jivi ndusa da̱ yóho cúú profeta na̱cachi Ndióxi̱ chindahá a̱ ñuyíví yóho —cáchí xi̱hi̱n táhan na.
\p 
\v 15 Joo na̱quee Jesús cua̱ha̱n in túhún mé á coo a yúcu̱ jáchi̱ xíni̱ mé á ña̱ ndúcú ña̱yivi cañehe ndúsa̱ na̱ mé á jáchi̱ cúni̱ na̱ ndaja na mé á rey nu̱ ná.
\s1 Tá na̱xi̱ca sáhá Jesús nu̱ú tañu̱hú
\r (Mt. 14:22-27; Mr. 6:45-52)
\p 
\v 16 Tá sa̱ na̱cuaá já na̱nuu na̱ xíca tuun xi̱hín Jesús xi̱qui̱ cán cua̱ha̱n chí yuhú tañu̱hú cán.
\v 17 Ta chí sa̱ na̱canaá va̱ha va ta co̱ó Jesús xínu̱ co̱o nu̱ ndúu na sa̱há ña̱ cán quéa̱ na̱ndaa na ja̱tá in barco ta na̱casáhá na̱ jándicaca na do̱ jáchi̱ cúni̱ na̱ cu̱hu̱n na̱ ñuu Capernaum.
\v 18 Ta ndaja coo na̱casáhá ndíco̱jo̱ ticui̱í nu̱ú tañu̱hú cán jáchi̱ na̱casáhá xícó in ta̱chi̱ ndeé ndiva̱ha.
\v 19 Ta tá sa̱ na̱caxícá na̱ u̱hu̱n á i̱ñu̱ kilometro cua̱ha̱n na̱ xi̱hi̱n barco cán nu̱ú ticui̱í já na̱xini na xíca sáhá Jesús cua̱ha̱n nu̱ú ticui̱í já cáyati a nu̱ barco cándójó na̱ cán. A̱nda̱ já na̱casáhá yíhví na̱ ndúu na.
\v 20 Ta tá na̱xi̱nu̱ co̱o Jesús nu̱ ná já na̱cachi a já xi̱hi̱n ná:
\p —A̱ cáyi̱hví toho ndó jáchi̱ ye̱he̱ va cúú u̱ —na̱cachi a xi̱hi̱n ná.
\p 
\v 21 A̱nda̱ já cávatá na̱ na̱jándaa na a̱ ja̱ta̱ barco. Ta i̱vi̱ la̱á sa̱ na̱xi̱nu̱ co̱o na nu̱ú cua̱ha̱n na̱.
\s1 Ndínducú ña̱yivi Jesús
\p 
\v 22 Tá na̱ti̱vi inga qui̱ví ita̱a̱n já na̱casáhá ña̱yivi ndínducú na̱ Jesús jáchi̱ na̱xini na ña̱ co̱ó na̱ndaa toho a in túhún barco na̱sahi̱in cán xi̱hín na̱ xíca tuun xi̱hi̱n a̱ jáchi̱ mé cuití na̱ cán sa̱ na̱ndaa cua̱ha̱n.
\v 23 Ta nani ndúu na yuhú tañu̱hú yati nu̱ú na̱ndaja cua̱ha̱ Jesús pan tá na̱ndihi na̱ndiquia̱hva mé á ndixa̱hvi nu̱ Ndióxi̱ cán já na̱xi̱nu̱ co̱o java barco, dó na̱quixi chí ñuu Tiberias.
\v 24 Ta sa̱há ña̱ co̱ó na̱nditahan na Jesús sa̱há ña̱ cán quéa̱ na̱ndaa na barco cán já na̱quee na cua̱ha̱n na̱ ñuu Capernaum ndinducú ñahá na̱.
\s1 Jesús cúú á tátu̱hun pan xíxi ña̱yivi já tácú na̱
\p 
\v 25 Tá na̱xi̱nu̱ co̱o na̱ cán inga xoo tañu̱hú já na̱nditahan na Jesús. Ta na̱casáhá ndáca̱ tu̱hún na̱ mé á já cáchí na̱ já:
\p —Maestro, ndá hora na̱xi̱nu̱ co̱o ndó yóho —na̱cachi na xi̱hi̱n á.
\p 
\v 26 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ná:
\p —Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. Xíca ndó ndínducú ndó ye̱he̱ joo co̱ cúú á sa̱há ña̱ na̱canda̱a̱ ini ndó yo cúú ye̱he̱. Sa̱há ña̱ náhnu na̱caja i̱ tá na̱sa̱ha̱n i̱ ña̱ na̱xixi ndó ja̱nda̱ na̱chutú ti̱xi ndó sa̱há ña̱ cán quéa̱ ndínducú ndó ye̱he̱.
\v 27 Co̱ ndítahan ndi̱hi nahá ini ndó sa̱há ña̱ cuxu ndó ñuyíví yóho. Ña̱ ndítahan caja ndó quéa̱ ndinducú ndó ndá quia̱hva catacu ndó a̱nda̱ ama cáa qui̱vi̱. Jáchi̱ ye̱he̱ cúú da̱ na̱chindahá Ndióxi̱ nduu ña̱yivi ta cuu caja i̱ ña̱ ná catacu ndó a̱nda̱ ama cáa qui̱vi̱. Jáchi̱ Ndióxi̱, tátá i̱ náha̱ ña̱ mé a̱ nda̱a̱ na̱ca̱xi a ye̱he̱ caja i̱ chuun yóho —na̱cachi Jesús xi̱hín na̱ cán.
\p 
\v 28 A̱nda̱ já na̱cachi na̱ cán já xi̱hi̱n á:
\p —Ndía̱ ndítahan nu̱ú nde̱ caja nde̱ já ná jáxi̱nu̱ co̱o nde̱ ña̱ cúni̱ Ndióxi̱ —na̱cachi na xi̱hín Jesús.
\p 
\v 29 Já na̱cachi Jesús já xi̱hi̱n ná:
\p —Ña̱ cúni̱ Ndióxi̱ caja ndó quéa̱ ná candúsa ndó ye̱he̱, da̱ na̱chindahá mé á ñuyíví yóho.
\p 
\v 30 A̱nda̱ já na̱cachi tucu na̱ cán já xi̱hi̱n á:
\p —Ndá ña̱ha xitúhún chága̱ cuu caja ndó nu̱ú nde̱ viti ña̱ ná cuni nde̱ ña̱ já ná cuu candúsa nde̱ ndo̱hó. Ndá a̱ náhnu quéa̱ cuu caja ndó.
\v 31 Jáchi̱ mé tásáhnu jícó nde̱ na̱xixi na pan tá na̱xi̱ca na yucú íchí nu̱ co̱ ndúu ña̱yivi cán. Já cáchí tu̱hun Ndióxi̱ já: “Na̱xixi na pan ña̱ na̱quixi indiví na̱caja Moisés” —na̱cachi na̱ cán xi̱hín Jesús.
\p 
\v 32 Já na̱cachi Jesús já xi̱hi̱n ná:
\p —Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. A̱ ju̱ú toho Moisés cúú da̱ na̱sa̱ha̱n pan ña̱ na̱quixi indiví nu̱ ná. Jáchi̱ Ndióxi̱, tátá i̱ cúú ndusa ña̱ na̱sa̱ha̱n pan na̱quixi indiví nu̱ ná. Ta viti cúni̱ Ndióxi̱ quia̱hva in ña̱ha va̱ha chága̱ nu̱ ndo̱ a̱ ju̱ú ga̱ ña̱ na̱sa̱ha̱n Moisés nu̱ú na̱ cán sa̱nahá.
\v 33 Jáchi̱ ye̱he̱ cúú u̱ tátu̱hun pan ña̱ na̱nuu indiví na̱caja Ndióxi̱ ña̱ ná cuu catacu ña̱yivi a̱nda̱ ama cáa qui̱vi̱ —na̱cachi Jesús xi̱hín na̱ cán.
\p 
\v 34 A̱nda̱ já na̱cachi na̱ cán já xi̱hi̱n á:
\p —Nini qui̱vi̱ quia̱hva ndó táhan pan ja̱n nu̱ú nde̱, xitoho.
\p 
\v 35 Já na̱cachi Jesús já xi̱hi̱n ná:
\p —Ye̱he̱ cúú u̱ tátu̱hun mé pan ja̱n. Tá ná ndiquehe ña̱yivi ye̱he̱ já ndiva̱ha ini na ta cúú á tátu̱hun a̱ cuíco ga̱ na̱. Ta ndá na̱ cándúsa na mí i̱ já cúú á tátu̱hun a̱ íchi̱ ga̱ ini na ticui̱í.
\v 36 Joo cúú á tá quia̱hva na̱cachi i̱ xi̱hi̱n ndo̱: co̱ cándúsa toho ndó ye̱he̱ va̱tí xíní ndó ye̱he̱.
\v 37 Joo tócó ndihi na̱ va̱xi nu̱ú i̱ cája Ndióxi̱, na̱ cán cúú na̱ cándúsa ye̱he̱. Ta ndá na̱ cándúsa ye̱he̱, na̱ cán co̱ táxí i̱ na̱ ña̱ ná quee na cu̱hu̱n na̱.
\v 38 Jáchi̱ va̱tí na̱nuu i̱ indiví nu̱ íin Ndióxi̱ joo co̱ó na̱quixi i̱ caja i̱ ña̱ cúni̱ mí i̱. Va̱xi i̱ caja i̱ ña̱ cúni̱ Ndióxi̱, tátá i̱ jáchi̱ mé á na̱chindahá ye̱he̱.
\v 39 Ta ña̱ cúni̱ Ndióxi̱ quéa̱ ña̱ ná a̱ quiáhva i̱ ña̱ma̱ni̱ ndihi sa̱há na̱ na̱sa̱ha̱n mé á nu̱ú i̱. Ña̱ cúni̱ mé á quéa̱ ná jánditacu u̱ tócó ndihi na tá ná xi̱nu̱ co̱o qui̱ví nu̱ ndíhí.
\v 40 Ña̱ cúni̱ Ndióxi̱ quéa̱ ná catacu ña̱yivi, na̱ cándeé ini ye̱he̱ a̱nda̱ ama cáa qui̱vi̱. Ta ye̱he̱, da̱ cúú in túhún ji̱ni̱ já ja̱hyi mé á jánditacu u̱ na̱ qui̱vi̱ nu̱ ndíhí cuíí —na̱cachi Jesús.
\p 
\v 41 A̱nda̱ já na̱casáhá na̱ Israel cán cáha̱n núu na sa̱há Jesús jáchi̱ sa̱ na̱cachi a ña̱ cúú á tátu̱hun pan ta na̱cachi a ña̱ na̱nuu a chí indiví.
\v 42 Ta já na̱cachi xi̱hi̱n táhan na̱ cán já:
\p —Á a̱ ju̱ú ja̱hyi José va cúú Jesús yóho. Ta xíni̱ va̱ha va mí yo cúú náná da̱ xi̱hi̱n tátá da̱. Ta ndá cuéntá quéa̱ cáchí ri da ña̱ na̱quixi da chí indiví, dá já —na̱cachi xi̱hi̱n táhan na̱ cán.
\p 
\v 43 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ná:
\p —A̱ cáha̱n núu ga̱ ndó sa̱há i̱.
\v 44 Jáchi̱ jáca̱ha̱n Ndióxi̱, tátá i̱, ña̱yivi ña̱ ná candúsa na ye̱he̱. Ta ni in túhún toho ña̱yivi a̱ cu̱ú candúsa na ye̱he̱ tá ta̱ co̱ jáca̱ha̱n Ndióxi̱ ínima̱ ná, mé á na̱chindahá ye̱he̱. Ta na̱ cán cúú na̱ jánditacu u̱ qui̱ví nu̱ ndíhí.
\v 45 Já na̱ca̱hyí na̱ profeta sa̱nahá: “Jána̱ha̱ Ndióxi̱ tócó ndihi ña̱yivi.” Ña̱ cán quéa̱ tócó ndihi ña̱yivi, na̱ xíni̱ jo̱ho nu̱ cáha̱n Ndióxi̱ ta cája na ña̱ jána̱ha̱ mé á nu̱ ná, na̱ cán cúú na̱ va̱xi nu̱ú i̱.
\p 
\v 46 ʼJoo a̱ ju̱ú ca̱hán ndo̱ ña̱ cuu cuni java ña̱yivi Ndióxi̱, tátá i̱. Jáchi̱ ye̱he̱, da̱ na̱chindahá mé á ñuyíví yóho, cúú in túhún da̱ xíní ñahá.
\v 47 Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. Ndá na̱ cándeé ini ye̱he̱, na̱ cán cúú na̱ catacu a̱nda̱ ama cáa qui̱vi̱.
\v 48 Jáchi̱ ye̱he̱ cúú u̱ tátu̱hun pan ña̱ cuu caja ña̱ ná catacu na.
\v 49 Sa̱ xíni̱ ndó tásáhnu jícó ndo̱ na̱xixi na pan yucú íchí sa̱nahá joo na̱xi̱hi̱ tá na̱xi̱hi̱ na̱.
\v 50 Joo ye̱he̱ cúú u̱ tátu̱hun pan ña̱ na̱nuu chí indiví já quéa̱ ndá na̱ cándúsa ye̱he̱ cúú ná tátu̱hun na̱ xíxi pan ta já a̱ quíví na̱. Jáchi̱ tá ná cuxu na pan quia̱hva i̱ nu̱ ná já quéa̱ catacu na a̱nda̱ ama cáa qui̱vi̱.
\v 51 Ye̱he̱ cúú u̱ tátu̱hun mé pan xíxi na. Na̱nuu i̱ indiví ta a̱ cúu ndihi sa̱há i̱. Ta jivi mé yiquí cu̱ñu i̱ cúú á tátu̱hun pan xíxi na yóho ta va̱xi qui̱vi̱ ndiquia̱hva i̱ ña̱ nu̱ ná já ná cuu ca̱cu ndaa ínima̱ ná. Ta tá ná cuxu na ña̱ já catacu na a̱nda̱ ama cáa qui̱vi̱ —na̱cachi Jesús.
\p 
\v 52 A̱nda̱ já na̱casáhá na̱ Israel cán ndítúhún cue̱he̱ xi̱hi̱n táhan na já na̱cachi na já:
\p —Cáchí da̱ yóho ña̱ cúú yiquí cu̱ñu da tátu̱hun pan xíxi ña̱yivi. Ndaja cuu caja ri da quia̱hva da ña̱ nu̱ yo̱ cuxú —cáchí xi̱hi̱n táhan na.
\p 
\v 53 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ná:
\p —Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. A̱ cu̱ú catacu ndó a̱nda̱ ama cáa qui̱vi̱ tá ta̱ co̱ cándúsa ndó ye̱he̱. Ta tá cándúsa ndó ye̱he̱ cúú á tátu̱hun xíxi ndó yiquí cu̱ñu i̱ ta cúú á tátu̱hun xíhi ndó ni̱í i̱.
\v 54 Ndá na̱ xíxi na yiquí cu̱ñu i̱ ta xíhi na ni̱í i̱, na̱ cán cúú na̱ ca̱cu ndaa ínima̱ ná ta jánditacu u̱ na̱ qui̱vi̱ nu̱ ndíhí.
\v 55 Jáchi̱ yiquí cu̱ñu i̱ cúú ndusa tátu̱hun in ña̱ha va̱ha ndiva̱ha cuxu na ta ni̱í i̱ cúú dó tátu̱hun in dó va̱ha xíhi na.
\v 56 Ndá na̱ ná ndiquehe va̱ha ye̱he̱ cúú á tátu̱hun ndiquehe va̱ha na in pan cuxu na ta cúú á tátu̱hun ndiquehe na ticui̱í xíhi na. Já quéa̱ in nduu na xi̱hín i̱ ta já in nduu ri ye̱he̱ va xi̱hi̱n mé ná.
\v 57 Ta sa̱há ña̱ tácú Ndióxi̱, tátá i̱, mé a̱ na̱chindahá ye̱he̱ sa̱há ña̱ cán quéa̱ tácú ri ye̱he̱ va cája mé á. Quia̱hva já ya̱ha ri xi̱hín ña̱yivi jáchi̱ tá ná ndiquehe va̱ha na ye̱he̱ já catacu na caja i̱.
\v 58 Jáchi̱ ye̱he̱ cúú u̱ ndusa tátu̱hun pan ña̱ na̱nuu indiví. Ta co̱ cúú á tátu̱hun ña̱ na̱ya̱ha xi̱hi̱n tásáhnu jícó ndo̱ tá na̱xixi na pan naní maná yucú íchí cán jáchi̱ tá na̱ndihi na̱xi̱hi̱ tá na̱xi̱hi̱ na̱ cán. Joo ndá na̱ cándeé ini ye̱he̱ cúú ná tátu̱hun na̱ xíxi pan ña̱ na̱quixi indiví. Ta na̱ cán catacu na a̱nda̱ ama cáa qui̱vi̱ —na̱cachi Jesús.
\p 
\v 59 Tócó ndihi ña̱ yóho na̱jána̱ha̱ Jesús nu̱ ná ini veñu̱hu ñuu Capernaum cán.
\s1 Cuu catacu ña̱yivi a̱nda̱ ama cáa qui̱vi̱ tá ná candeé ini na Jesús
\p 
\v 60 Ta cua̱há táhan na̱ xíca xi̱hín Jesús cán tá na̱xini jo̱ho na ña̱ na̱ca̱ha̱n mé á já na̱casáhá cáha̱n núu na sa̱há já cáchí na̱ já:
\p —Yáncá ndiva̱ha candúsa í tu̱hun cáha̱n Jesús yóho. A̱ cúu toho caja í xi̱hi̱n á —na̱cachi na̱ cán.
\p 
\v 61 Tá na̱xini Jesús ña̱ cáhvi núu ini na̱ xíca xi̱hín a̱ cán já na̱casáhá cáchí a̱ já xi̱hi̱n ná:
\p —Ndíhi̱hvi̱ ndó sa̱há tu̱hun na̱ca̱ha̱n i̱ yóho.
\v 62 Ndaja ga̱ ví ndihi̱hvi̱ ndó tá ná cuni ndó ye̱he̱ ndaa i̱ cu̱hu̱n i̱ indiví nu̱ú na̱sahi̱in i̱ jáchi̱ ye̱he̱ cúú u̱ da̱ na̱chindahá Ndióxi̱ nduu ña̱yivi.
\v 63 Na̱sa̱ha̱n Ndióxi̱ in ínima̱ nu̱ú in in ña̱yivi ña̱ ná chindeé a̱ na̱ ndinducú na̱ mé á. Joo yiquí cu̱ñu ña̱yivi co̱ chíndeé toho a na̱ ndínducú na̱ mé á. Ta tócó ndihi ña̱ na̱ca̱ha̱n i̱ xi̱hi̱n ndo̱ cúú á ña̱ cuu xi̱nu̱ ini ínima̱ ndo̱ ña̱ ná catacu ndó a̱nda̱ ama cáa qui̱vi̱.
\v 64 Joo ndúu java ndó cáma̱ní yi̱í candúsa ndó ña̱ cáha̱n i̱ xi̱hi̱n ndo̱ —na̱cachi a.
\p Na̱cachi Jesús ña̱ yóho jáchi̱ sa̱ xíni̱ mé á a̱nda̱ sa̱ha̱ ndá na̱ cúú na̱ co̱ cándúsa ñahá. Ta sa̱ xíni̱ Jesús ndá da̱ cúú da̱ ji̱có túhún ñahá.
\v 65 A̱nda̱ já na̱cachi tucu a já:
\p —Sa̱há ña̱ cán quéa̱ cáchí i̱ xi̱hi̱n ndó ña̱ ni in túhún toho ña̱yivi a̱ cu̱ú candúsa na ye̱he̱ tá co̱ jáca̱ha̱n Ndióxi̱ ínima̱ ná —na̱cachi Jesús.
\p 
\v 66 Tá na̱cachi Jesús ña̱ yóho já quéa̱ cua̱ha̱ táhan na̱ na̱saxi̱ca xi̱hín a̱ cán na̱jándacoo na mé á ta chí co̱ó na̱xeen ga̱ na̱ caca nuu na xi̱hi̱n á.
\v 67 A̱nda̱ já na̱nda̱ca̱ tu̱hún Jesús ndíhu̱xu̱ i̱vi̱ na̱ xíca tuun xi̱hín a̱ cán já na̱cachi a já xi̱hi̱n ná:
\p —Á cu̱hu̱n ri ndóhó va cúni̱ ndo̱ —na̱cachi a.
\p 
\v 68 A̱nda̱ já na̱nducú ñehe Simón Pedro tu̱hun nu̱ú Jesús já na̱cachi da já:
\p —Cande̱hé ndo̱, xitoho i̱. Yo nu̱ú ga̱ cuu cu̱hu̱n nde̱. Tu̱hun cáha̱n ndó xi̱hín nde̱ caja ña̱ ná cu̱hu̱n nde̱ catacu nde̱ a̱nda̱ ama cáa qui̱vi̱ tá ná candúsa nde̱ ña̱.
\v 69 Ta nde̱he̱ sa̱ na̱candúsa va nde̱ ndo̱hó. Ta sa̱ xíni̱ va̱ha nde̱ ña̱ cúú ndó Cristo, ña̱ in túhún ji̱ni̱ já ja̱hyi Ndióxi̱, ña̱ tácú indiví —na̱cachi Pedro cán xi̱hín Jesús.
\p 
\v 70 A̱nda̱ já na̱cachi Jesús já:
\p —Mé a̱ nda̱a̱ na̱ca̱xi i̱ ndíhu̱xu̱ i̱vi̱ ndó ña̱ ná caca tuun ndó xi̱hín i̱. Ta va̱tí na̱ca̱xi i̱ ndihi ndó joo in táhan ndó cúú dá cuéntá tiñáhá sa̱cua̱ha̱ —na̱cachi Jesús.
\p 
\v 71 Na̱cachi Jesús ña̱ yóho sa̱ha̱ Judas, ja̱hyi Simón Iscariote jáchi̱ mé Judas cán cúú dá da̱ ji̱có túhún ñahá chága̱ chí nu̱u̱ va̱tí cúú dá in táhan da̱ u̱xu̱ i̱vi̱ na̱ xíca tuun xi̱hín Jesús cán.
\c 7
\s1 Co̱ cúni̱ na̱ cúú ñani Jesús candúsa na mé á
\p 
\v 1 Tá na̱ya̱ha ña̱ yóho já na̱xi̱ca nuu Jesús tá ñuu tá ñuu estado Galilea cán. Co̱ó na̱xeen ga̱ cu̱hu̱n a̱ chí Judea jáchi̱ cán na̱casáhá na̱ ndúcú na̱ mé á cahní na̱ a̱.
\v 2 Joo sa̱há ña̱ na̱cayati víco̱ tá ndúu ña̱yivi vehe ti̱yahvá válí cája na̱ Israel
\v 3 sa̱há ña̱ cán quéa̱ na̱cachi java ñani Jesús já xi̱hi̱n á:
\p —Ndía̱ cájún coún yóho. Cuáhán chí Judea já ná cuni na̱ xíca xu̱hu̱n cán ndaja ndáa ña̱ náhnu cájún.
\v 4 Jáchi̱ tá cúni̱ in da̱ta̱a na̱ha̱ da̱ ña̱ náhnu cája da já quéa̱ co̱ ndáco̱o je̱hé toho da cája da ña̱. Tá ta̱ mé a̱ nda̱a̱ cájún ña̱ náhnu já quéa̱ xíní ñúhú cajún ña̱ já ná cuni níí cúú ña̱yivi ndaja náhnu ña̱ha cájún —na̱cachi ñani Jesús xi̱hi̱n á.
\p 
\v 5 Na̱cachi na̱ cán ña̱ yóho jáchi̱ ni mé ñani a cán co̱ó na̱candúsa ñahá.
\v 6 A̱nda̱ já na̱cachi Jesús xi̱hín na̱ cán já:
\p —Cáma̱ní yi̱í ndindaa hora cu̱hu̱n i̱. Ta va̱ha ri ndóhó ndá hora na̱cuu va cuu cu̱hu̱n ndó ja̱n.
\v 7 Jáchi̱ ña̱yivi cája ña̱ núu ñuyíví yóho a̱ cu̱ú candají toho na ndo̱hó joo cándají na̱ ye̱he̱ jáchi̱ cáxí táhyí cáha̱n i̱ xi̱hi̱n ná ña̱ cája na ña̱ núu.
\v 8 Cuáhán mé ndó víco̱ tá cúni̱ ndó cu̱hu̱n ndo̱ jáchi̱ ye̱he̱ a̱ cúhu̱n toho i̱ jáchi̱ cáma̱ní yi̱í xi̱nu̱ hora cu̱hu̱n i̱ —na̱cachi a.
\p 
\v 9 Ña̱ yóho na̱cachi Jesús xi̱hín ñani a. Ta na̱cando̱o mé á estado Galilea cán.
\s1 Tá na̱xi̱nu̱ co̱o Jesús vicó vehe ti̱yahvá cán
\p 
\v 10 Joo tá na̱ndihi na̱quee ñani Jesús cán cua̱ha̱n na̱ víco̱ já na̱quee ri Jesús cua̱ha̱n mé víco̱ cán. Joo co̱ó na̱xeen a na̱ha̱ tívi a mé á nu̱ú ña̱yivi.
\v 11 Ta mé na̱ sa̱cua̱ha̱ nu̱ú na̱ Israel cán na̱casáhá na̱ ndúcú na̱ Jesús: “Ndá xíca nuu da tañu víco̱ cán”, cáhán na̱.
\p 
\v 12 Ta ja̱ndá joho ndítúhún ya̱á ña̱yivi sa̱há Jesús xíca nuu na víco̱ cán. Java na cáchí na̱ sa̱há Jesús ña̱ cúú dá ta̱a cája va̱ha. Ta java na cáchí na̱: “Co̱ cúú toho da ta̱a va̱ha jáchi̱ xíca nuu cuití da̱ jándahvi da ña̱yivi”, cáchí na̱.
\p 
\v 13 Joo ni in na co̱ sáhan ndeé ini ca̱ha̱n sa̱há nu̱ú na̱ sa̱cua̱ha̱ nu̱ú na̱ Israel cán jáchi̱ yíhví ñahá na̱.
\p 
\v 14 Ta tá na̱ta̱hvi̱ java víco̱ cán já na̱qui̱hvi Jesús ini veñu̱hu cáhnu ñuu Jerusalén cán já na̱casáhá jána̱ha̱ nu̱ú ña̱yivi.
\v 15 Ta tá xíni̱ jo̱ho na̱ Israel cán nu̱ cáha̱n Jesús chí cátóntó na̱ já na̱casáhá ndáca̱ tu̱hún táhan na já cáchí na̱ já:
\p —Ndájá na̱catia̱hva na̱há da̱ yóho ña̱ jána̱ha̱ da̱ nu̱ yo̱ jáchi̱ a̱ ju̱ú da̱ na̱xi̱ca jácuaha cúú dá —na̱cachi xi̱hi̱n táhan na̱ cán.
\p 
\v 16 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ná:
\p —Ña̱ jána̱ha̱ i̱ nu̱ ndo̱ yóho co̱ cúú á ña̱ na̱quixi ji̱ni̱ mí i̱ jáchi̱ cúú á ña̱ quíxi nu̱ Ndióxi̱, tátá i̱, mé á na̱chindahá ye̱he̱.
\v 17 Ta tá mé a̱ nda̱a̱ sácú ini ndó caja ndó ña̱ cúni̱ Ndióxi̱ já quéa̱ cuu canda̱a̱ ini ndó á cáha̱n i̱ cuéntá Ndióxi̱, á cáha̱n i̱ cuéntá mí cuití vi̱.
\v 18 Jáchi̱ ndá na̱ cáha̱n cuéntá mé ná já quéa̱ ndúcú na̱ ña̱ ná caja cáhnu ña̱yivi na̱. Joo ndá na̱ ndúcú ña̱ ná ndicáhnu mé á na̱chindahá ñahá cán, na̱ cán cúú ndusa na̱ cáha̱n ña̱ nda̱a̱ ta co̱ cája na ña̱ co̱ ndítahan nu̱ ná caja na.
\p 
\v 19 ʼMé a̱ nda̱a̱ na̱jándacoo Moisés ley nu̱ ndo̱ joo ni in túhún ndo̱ co̱ cája ndó ña̱ cáchí a̱. Ta viti cúni̱ ndó cahní ndó ye̱he̱ —na̱cachi Jesús.
\p 
\v 20 A̱nda̱ já na̱nducú ñehe na̱ cán tu̱hun nu̱ á já na̱cachi na já:
\p —Rí quini va ndáca̱a̱n ini yóhó jáchi̱ ni in túhún toho na co̱ ndúcú cahní yo̱hó —na̱cachi na̱ cán.
\p 
\v 21 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ná:
\p —Chí cátóntó ndiva̱ha ndó sa̱há in túhún ña̱ cáhnu na̱caja i̱ qui̱vi̱ ndíquehe ndée̱ yo̱.
\v 22 Joo cande̱hé ndo̱. Moisés cúú da̱ na̱sahnda chuun nu̱ tásáhnu jícó yo̱ ña̱ ná chica̱a̱n na̱ marca yiquí cu̱ñu na va̱tí a̱ ju̱ú Moisés na̱tavá sa̱há, va̱ha. Mé tásáhnu jícó yo̱ na̱tavá sa̱há ta mé ndó chíca̱a̱n tá chíca̱a̱n ndó marca yiquí cu̱ñu ta̱a va̱lí va̱tí cúú á qui̱vi̱ ndíquehe ndée̱ yo̱.
\v 23 Ta viti cáchí ndo̱ xi̱hín i̱ ndaja cáa ri ña̱ yóho. Mé ndó chíca̱a̱n ndó marca yiquí cu̱ñu da̱ va̱lí va̱tí cúú á qui̱vi̱ ndíquehe ndée̱ yo̱ jáchi̱ co̱ cúni̱ ndó ya̱ha nu̱ú ña̱ na̱sahnda Moisés nu̱ ndó. Ta viti xójo̱ ini ndó xi̱hín i̱ sa̱há ña̱ na̱ndaja va̱ha i̱ in níí yiquí cu̱ñu in da̱ta̱a qui̱vi̱ ndíquehe ndée̱ yo̱. Ndaja cáa ri ña̱ ja̱n cáa já.
\v 24 Mé ndó ndaja na̱cuu cáha̱n núu ndó sa̱há ña̱yivi ta co̱ ndítahan toho caja ndó já. Jáchi̱ ndítahan nu̱ ndó canda̱a̱ ini ndó ña̱ cúú ña̱ nda̱a̱ —na̱cachi Jesús xi̱hín na̱ cán.
\s1 Ndícani Jesús ndáchí na̱quixi a
\p 
\v 25 Ta java na̱ ñuu Jerusalén na̱casáhá ndáca̱ tu̱hún táhan na já cáchí na̱ já:
\p —Á a̱ ju̱ú da̱ yóho cúú da̱ xíca na ndúcú na̱ cahní na̱.
\v 26 Nu̱ ndíhi na cándichi da jána̱ha̱ da̱ ta ni in na co̱ ndáa cúu da. Á tá co̱ó ta ja̱nda̱ na̱ jutixia cáa cándúsa na ña̱ cúú dá Cristo, da̱ na̱chindahá Ndióxi̱ cacomí a̱ cuéntá sa̱há ña̱yivi.
\v 27 Joo mí xíni̱ va̱ha í ndá ñuu na̱quixi da̱ yóho ña̱ cán quéa̱ xíni̱ yo̱ ña̱ co̱ cúú toho da Cristo jáchi̱ tá ná quixi ndusa Cristo cán ni in na a̱ cánda̱a̱ ini ndá ñuu quixi da —na̱cachi na̱ cán cáha̱n na̱ sa̱há Jesús.
\p 
\v 28 Ta nani jána̱ha̱ Jesús ini veñu̱hu cáhnu cán já na̱casáhá cáha̱n cóhó a̱ já na̱cachi a já:
\p —Mé a̱ nda̱a̱ xíni̱ va̱ha ndó ye̱he̱ ta xíni̱ ndó ndá ñuu na̱quixi i̱. Joo co̱ó va̱xi ye̱he̱ cuéntá mí i̱. Mé Ndióxi̱ na̱chindahá ye̱he̱ va̱xi i̱, mé a̱ cán cája ña̱ nda̱a̱. Joo mé ndó co̱ xíni̱ toho ndó a̱.
\v 29 Ye̱he̱ xíni̱ va̱ha i̱ yo cúú mé á jáchi̱ na̱quixi i̱ nu̱ íin mé á ta na̱chindahá mé á ye̱he̱ va̱xi i̱ —na̱cachi a.
\p 
\v 30 A̱nda̱ já ndúcú na̱ tiin na Jesús chica̱a̱n na̱ a̱ veca̱a joo ni in na co̱ó na̱sa̱ha̱n ndeé ini tiin ñahá jáchi̱ cáma̱ní yií ndindaa hora tiin na a̱.
\v 31 Ta cua̱ha̱ táhan ña̱yivi na̱xini jo̱ho nu̱ú na̱ca̱ha̱n Jesús cán na̱candúsa na mé á ta já cáchí na̱ já:
\p —Á a̱ ju̱ú da̱ yóho cúú Cristo jáchi̱ tá ná quixi inga da ama ná caja da ña̱ha xitúhún chága̱ a̱ ju̱ú ga̱ da̱ yóho —na̱cachi na.
\s1 Ndúcú na̱ fariseo chica̱a̱n na̱ Jesús veca̱a
\p 
\v 32 Tá na̱xini jo̱ho na̱ fariseo ña̱ cáha̱n núu ña̱yivi sa̱há Jesús já na̱ndindeé ini na ta na̱ndindeé ini ri na̱ sa̱cua̱ha̱ nu̱ú ju̱tu̱ cán chí na̱chindahá na̱ java soldado cuéntá veñu̱hu cáhnu cán ña̱ ná tiin na Jesús chica̱a̱n na̱ a̱ veca̱a.
\v 33 A̱nda̱ já na̱cachi tucu Jesús já:
\p —Chá tiempo cuití va coo tóo i̱ xi̱hi̱n ndo̱ ñuyíví yóho jáchi̱ tá na̱ndihi já cu̱hu̱n tucu u̱ nu̱ íin mé á na̱chindahá ye̱he̱.
\v 34 A̱nda̱ jáví caca nuu ndó ndinducú ndó ye̱he̱ joo a̱ ndítahan ndó ye̱he̱ jáchi̱ a̱ cúu cu̱hu̱n ndó nu̱ú coo i̱ —na̱cachi Jesús.
\p 
\v 35 Tá na̱xini jo̱ho na̱ Israel cán ña̱ na̱cachi Jesús já na̱casáhá ndáca̱ tu̱hún táhan na já cáchí na̱ já:
\p —Ta ndáchí já cu̱hu̱n ri da̱ yóho ña̱ cáchí da̱ ña̱ a̱ cúu nditahan í da̱. Á cu̱hu̱n xícá da̱ ñuu na̱ tóho̱ nu̱ ndúu na̱ Israel ña̱ ná jána̱ha̱ da̱ nu̱ú na̱ griego.
\v 36 Ndía̱ cúni̱ cachi da xi̱hi̱n yó tá na̱cachi da ña̱ ndinducú yó da̱ ta a̱ ndítahan toho í da̱. Jáchi̱ na̱cachi da xi̱hi̱n yó ña̱ a̱ cúu co̱ho̱ nu̱ú coo da —na̱cachi xi̱hi̱n táhan na̱ cán jáchi̱ co̱ó na̱canda̱a̱ ini na ña̱ na̱cachi Jesús xi̱hi̱n ná.
\s1 Jesús cúú á tátu̱hun yu̱ta ticui̱í
\p 
\v 37 Ta mé qui̱ví nu̱ ndíhí víco̱ cán na̱sacuu a qui̱vi̱ cáhnu chága̱ nu̱ú na̱ Israel. Ta mé qui̱vi̱ cán na̱nda̱ca̱ ndichi Jesús já na̱cayuhú a̱ já na̱cachi a já:
\p —Ndá ndó íchi̱ ini ticui̱í, naha ndó nu̱ú i̱ já ná caja i̱ ña̱ ná ndiva̱ha ini ndó.
\v 38 Jáchi̱ já na̱ca̱hyi̱ a̱ nu̱ú tu̱hun Ndióxi̱: “Ndá na̱ ná cándeé ini ye̱he̱, ini mé ínima̱ ná cana tátu̱hun yu̱ta ticui̱í, dó caja ña̱ ná catacu na” —na̱cachi Jesús xi̱hín na̱ cán.
\p 
\v 39 Ña̱ cúni̱ Jesús cachi a xi̱hín na̱ yóho quéa̱ tá ná candeé ini na mé á já xi̱nu̱ qui̱ví ndiquehe na ínima̱ yi̱i̱ Ndióxi̱ ini ínima̱ ná. Va̱tí mé a̱ nda̱a̱ a̱ ñáha toho xi̱nu̱ ínima̱ yi̱i̱ Ndióxi̱ ini ña̱yivi jáchi̱ cáma̱ní yi̱í va ndindita Jesús ndicáhnu ndiva̱ha mé á indiví.
\s1 Sa̱ jíin sa̱ jíin ña̱ha cáha̱n ña̱yivi sa̱há Jesús
\p 
\v 40 Java na̱ ndúu tañu ña̱yivi cua̱ha̱ cán tá na̱xini jo̱ho na ña̱ yóho já na̱casáhá cáchí na̱ já:
\p —Jivi ndusa da̱ yóho cúú profeta na̱cachi Ndióxi̱ chindahá a̱ ñuyíví yóho —cáchí na̱.
\p 
\v 41 Ta java na cáchí na̱ sa̱há Jesús ña̱ cúú á Cristo, da̱ na̱chindahá Ndióxi̱ cacomí cuéntá sa̱há ña̱yivi. Ta java na cáchí na̱ ña̱ a̱ ju̱ú toho a jáchi̱ cáhán na̱ ña̱ a̱ cúu toho quixi Cristo estado Galilea.
\v 42 Jáchi̱ cáchí tu̱hun Ndióxi̱ ña̱ tá ná quixi Cristo ñuyíví yóho cacuu da da̱ quixi chi̱chi David, da̱ na̱sacomí cuéntá sa̱há ña̱yivi Israel sa̱nahá. Ta cáchí tu̱hun Ndióxi̱ ña̱ cacu da̱ cán ñuu Belén nu̱ú na̱cacu mé David cán.
\p 
\v 43 Ta chí na̱casáhá na̱ sáhndá java táhan na sa̱há ña̱ co̱ó na̱ndique táhan tu̱hun na sa̱ha̱ Jesús.
\v 44 Ta java na cúni̱ na̱ tiin na a̱ ña̱ ná cañehe ñahá na̱ cu̱hu̱n a̱ veca̱a. Joo ni in na co̱ó na̱tiin ñahá.
\s1 Co̱ cúni̱ na̱ jutixia candúsa na Jesús
\p 
\v 45 Tá na̱ndihi já na̱ndicó co̱o soldado cuéntá veñu̱hu cán nu̱ ndúu na̱ fariseo xi̱hín na̱ sa̱cua̱ha̱ nu̱ú ju̱tu̱ cán joo co̱ó Jesús ñéhe na ná casa̱a̱ na̱. Já na̱casáhá na̱ ndúu cán ndáca̱ tu̱hún ñahá na̱ já cáchí na̱ já:
\p —Ndá cuéntá quéa̱ co̱ó na̱tiin ndó da̱ —na̱cachi na̱ cán xi̱hín soldado.
\p 
\v 46 A̱nda̱ já na̱nducú ñehe soldado cán tu̱hun nu̱ ná já cáchí da̱ já xi̱hi̱n ná:
\p —Na̱catóntó nde̱ na̱xini jo̱ho nde̱ nu̱ cáha̱n da̱ jáchi̱ ñúchí ndiva̱ha cáha̱n da̱ ta ni in túhún na̱ co̱ó na̱ca̱ha̱n tá quia̱hva cáha̱n mé dá —na̱cachi soldado cán.
\p 
\v 47 Já na̱cachi na̱ fariseo já xi̱hi̱n dá:
\p —Á jári ndóhó va na̱jándahvi da ja̱n viti.
\v 48 Jáchi̱ ja̱nda̱ ni in túhún toho táhan na̱ sa̱cua̱ha̱ ndúu tañu mé nde̱ co̱ cándúsa nde̱ da̱ ja̱n. Ta ni in na̱ fariseo co̱ cándúsa na nu̱ cáha̱n Jesús ja̱n.
\v 49 Joo cháhan va va̱xi ja̱tá ña̱yivi cándeé ini Jesús ja̱n jáchi̱ co̱ xíni̱ na̱ ña̱ cáchí ley Moisés —na̱cachi na̱ fariseo xi̱hín soldado.
\p 
\v 50 A̱nda̱ já na̱ndica̱ha̱n Nicodemo, da̱ cúú in táhan na̱ fariseo cán, mé dá na̱sa̱ha̱n da̱ na̱nditúhún xi̱hín Jesús in ñuú. Já na̱cachi da já xi̱hín na̱ java ga̱ cán:
\p 
\v 51 —Cáchí ley ña̱ a̱ cu̱ú tiín in ta̱a ta já chica̱a̱n ndaja na̱cuú da̱ veca̱a. Ña̱ cáchí ley quéa̱ ndítahan cuni jo̱ho í nu̱ú ca̱ha̱n da̱ já ná canda̱a̱ iní ndaja cáa ña̱ na̱caja da —na̱cachi Nicodemo.
\p 
\v 52 A̱nda̱ já na̱caja cue̱he̱ na̱ xi̱hín Nicodemo já na̱cachi na já xi̱hi̱n dá:
\p —Á da̱ Galilea cúú ri yóhó va. Cuáhán cahvi va̱ha tu̱hun Ndióxi̱ já cunún ña̱ co̱ cána ni in profeta estado Galilea —na̱cachi na xi̱hín Nicodemo.
\p 
\v 53 Tá na̱ndihi já na̱ndicui̱ta nuu ndihi na̱ cán cuánúhu̱ ná vehe na.
\c 8
\s1 Cája cáhnu ini Jesús sa̱há in ñáñáha̱
\p 
\v 1 Ta ndaja coo na̱quee Jesús cua̱ha̱n chí yúcu̱ yitó olivo.
\v 2 Ta tá na̱ti̱vi inga qui̱ví ita̱a̱n já na̱ndicó co̱o tucu a veñu̱hu cáhnu cán. Ta tá na̱cayati ña̱yivi nu̱ á já na̱saco̱o a ta na̱casáhá jána̱ha̱ nu̱ ná.
\v 3 Ta ndaja coo na̱ jána̱ha̱ ley Moisés xi̱hín na̱ fariseo ñéhe na in ñáñáha̱ na̱sa̱a̱ na̱ nu̱ á. Mé ñáñáha̱ cán na̱nditahan na ña̱ mé hora cándúhu̱ ñá xi̱hín in da̱ta̱a, da̱ co̱ cúú yíi̱ ña̱. Ta já ñéhe na ñá na̱sacu ndichi na ña̱ nu̱ú na̱ ndúu cán.
\v 4 Já na̱cachi na já xi̱hín Jesús:
\p —Cande̱hé ndo̱ Maestro. Na̱nditahan nde̱ ñáñáha̱ yóho cándúhu̱ ñá xi̱hín in da̱ta̱a, da̱ co̱ cúú yíi̱ ña̱.
\v 5 Ta nu̱ ley na̱jándacoo Moisés nu̱ú nde̱ táhnda̱ chuun ña̱ ná cuun nde̱ yu̱u̱ na̱ji̱hí cája já. Ta mé ndó ndía̱ cachi ndó —na̱cachi na.
\p 
\v 6 Na̱cachi na̱ cán já xi̱hín Jesús jáchi̱ cúni̱ na̱ coto ndojó cuití ñahá na̱ ta cúni̱ na̱ ñe̱he̱ íní na̱ jácojo na cua̱chi ja̱tá Jesús. Tá na̱ndihi já na̱saco̱o Jesús já na̱casáhá cáhyí a̱ nu̱ ñúhu̱ cán xi̱hín nducu ndáha̱ á.
\v 7 Ta sa̱há ña̱ ndúcú ndéé na̱ cán ndáca̱ tu̱hún ñahá na̱ na̱nda̱ca̱ ndichi Jesús já na̱cachi a já xi̱hi̱n ná:
\p —Ndá ndó, na̱ co̱ó na̱caja cua̱chi jácana jihna ñúhú ndó yu̱ú ja̱ta̱ ña̱ —na̱cachi a xi̱hi̱n ná.
\p 
\v 8 Já na̱saco̱o tucu a cáhyí a̱ nu̱ ñúhu̱ cán xi̱hín nducu ndáha̱ á.
\v 9 Ta tá na̱xini jo̱ho tócó ndihi na̱ cán ña̱ na̱cachi Jesús já na̱casáhá na̱ cácahan nu̱u̱ ná ta tá in tá in na na̱casáhá quée na cua̱ha̱n na̱. Ta jihna ñúhú ga̱ na̱ yatá na̱casáhá quée cua̱ha̱n já ndíco̱ na̱ yúta̱ chága̱ cua̱ha̱n na̱. Ta tá sa̱ na̱quee ndihi na cua̱ha̱n na̱ já na̱cando̱o mé Jesús xi̱hi̱n ñá cán.
\v 10 A̱nda̱ já na̱nda̱ca̱ ndichi a ta na̱nda̱ca̱ tu̱hún a̱ ña̱ já na̱cachi a já xi̱hi̱n ñá:
\p —Ndáchí cua̱ha̱n na̱ jácojo cua̱chi ja̱tu̱n. Á co̱ó ga̱ na̱ jácojo cua̱chi ja̱tu̱n viti —na̱cachi Jesús xi̱hi̱n ña̱.
\p 
\v 11 A̱nda̱ já na̱cachi ñá cán já xi̱hín Jesús:
\p —Mé a̱ nda̱a̱ co̱ó ga̱ na̱.
\p A̱nda̱ já na̱cachi Jesús já:
\p —Ta ni ye̱he̱ a̱ chíca̱a̱n i̱ cua̱chi ja̱tu̱n. Cuánúhu̱ vehún ta a̱ cája ga̱ún cua̱chi —na̱cachi a.
\s1 Jesús cúú á tátu̱hun ñúhu̱ ña̱ jándiyéhe̱ ínima̱ ña̱yivi
\p 
\v 12 Já na̱casáhá tucu Jesús cáha̱n xi̱hín ña̱yivi já cáchí a̱ já xi̱hi̱n ná:
\p —Ye̱he̱ cúú u̱ tátu̱hun ñúhu̱ ña̱ jándiyéhe̱ ínima̱ ña̱yivi ta ndá na̱ cándeé ini ye̱he̱ cúú á tátu̱hun a̱ cáca ga̱ na̱ nu̱ú naá. Jáchi̱ jándiyéhe̱ e̱ nu̱ ná ta cája i̱ ña̱ ná catacu na a̱nda̱ ama cáa qui̱vi̱.
\p 
\v 13 A̱nda̱ já na̱cachi na̱ fariseo já:
\p —Sa̱ha̱ mé vún cáhu̱n ta xi̱hín ña̱ ja̱n náhún ña̱ cúnu̱n ndíñehe jícún mún. Ta xi̱hín ña̱ ja̱n náha̱ ña̱ co̱ cáhu̱n ña̱ nda̱a̱ —na̱cachi na.
\p 
\v 14 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ná:
\p —Tócó ndihi ña̱ cáha̱n i̱ sa̱ha̱ mí i̱ cúú á ña̱ nda̱a̱ ta íin sa̱há va̱tí mí i̱ cáha̱n i̱ ña̱. Jáchi̱ xíni̱ va̱ha i̱ ndá na̱quixi i̱ ta xíni̱ va̱ha i̱ ndá cu̱hu̱n i̱. Joo ndóhó, co̱ xíni̱ toho ndó ndá na̱quixi i̱ ta co̱ xíni̱ toho ndó ndá cu̱hu̱n i̱.
\v 15 Mé ndó cátóó ndó cánde̱hé ndaa ndó ña̱yivi tá quia̱hva cája ña̱yivi ñuyíví. Joo ye̱he̱ co̱ cája toho i̱ já.
\v 16 Joo tá ná caja vií i̱ sa̱há ña̱yivi, caja i̱ ña̱ tá quia̱hva ndítahan caja i̱ jáchi̱ cája i̱ ña̱ nda̱a̱. Ta a̱ ju̱ú in túhún ye̱he̱ caja vií sa̱ha̱ ná jáchi̱ Ndióxi̱, tátá i̱, mé a̱ na̱chindahá ye̱he̱, mé á cán quéa̱ caja vií sa̱ha̱ ná xi̱hi̱n mí i̱.
\v 17 Nu̱ ley mé ndó cáchí a̱ ña̱ tá in nu̱ú cáha̱n i̱vi̱ ña̱yivi sa̱há ña̱ na̱ya̱ha já náha̱ ña̱ cúú á ña̱ nda̱a̱.
\v 18 Ta viti cuni jo̱ho ndó jáchi̱ quia̱hva já yáha ri xi̱hín ye̱he̱ va. Jáchi̱ ye̱he̱ cúú in testigo ta cáha̱n i̱ sa̱ha̱ mí i̱. Ta inga testigo cúú Ndióxi̱, tátá i̱, mé a̱ na̱chindahá ye̱he̱ —na̱cachi Jesús xi̱hi̱n ná.
\p 
\v 19 A̱nda̱ já na̱nda̱ca̱ tu̱hún na̱ Jesús já cáchí na̱ já xi̱hi̱n á:
\p —Ndájá íin tátún ja̱n —na̱cachi na.
\p A̱nda̱ já na̱cachi Jesús já:
\p —Tá ná cuni ndó yo cúú ye̱he̱ já cuu canda̱a̱ ri ini ndó yo cúú tátá i̱. Joo co̱ xíni̱ ndo̱ yo cúú ye̱he̱ ta cáchí ga̱ ví tátá i̱ co̱ xíni̱ ndó a̱ —na̱cachi Jesús.
\p 
\v 20 Tócó ndihi ña̱ yóho na̱cachi Jesús xi̱hi̱n ná nani jána̱ha̱ ini veñu̱hu cáhnu yati nu̱ú na̱sahi̱in sa̱to̱ ndée jiu̱hún jóco̱ na̱ cán. Joo ni in na̱ co̱ó na̱sa̱ha̱n ndeé ini tiin ñahá chica̱a̱n veca̱a jáchi̱ co̱ó na̱sa̱ha̱n Ndióxi̱ ña̱ma̱ni̱ sa̱há ña̱ cáma̱ní yi̱í ndindaa hora tiin na mé á.
\s1 Cáha̱n Jesús xi̱hín ña̱yivi ña̱ a̱ cúu toho cu̱hu̱n na̱ nu̱ú cu̱hu̱n mé á
\p 
\v 21 A̱nda̱ já na̱casáhá tucu Jesús cáchí a̱ já xi̱hi̱n ná:
\p —Va̱xi qui̱vi̱ quee ye̱he̱ cu̱hu̱n i̱. Ta caca nuu ndó ndinducú ndó ye̱he̱ joo a̱ ndíñehe ndó ye̱he̱ jáchi̱ cája tá cája ndó cua̱chi ja̱nda̱ quia̱hva xi̱nu̱ qui̱ví quivi ndó. Ta sa̱há ña̱ cán quéa̱ a̱ cúu cu̱hu̱n ndó nu̱ú cu̱hu̱n ye̱he̱ cán —na̱cachi Jesús.
\p 
\v 22 A̱nda̱ já na̱casáhá na̱ Israel cán ndítúhún xi̱hi̱n táhan na já cáchí na̱ já:
\p —Á cahní da̱ yóho mé dá cúni̱ da̱ ña̱ cán quéa̱ cáchí da̱ xi̱hi̱n yo̱ ña̱ a̱ cúu toho caja í co̱hó nu̱ú cu̱hu̱n da̱ —cáchí na̱.
\p 
\v 23 Já na̱cachi tucu Jesús já:
\p —Mé ndó cúú ndó ña̱yivi ndúu ñuyíví yóho joo ye̱he̱ cúú u̱ da̱ na̱quixi chí indiví. Mé ndó cúú ndó cuéntá ñuyíví yóho joo ye̱he̱ co̱ cúú toho i̱ cuéntá ñuyíví yóho.
\v 24 Sa̱há ña̱ cán quéa̱ na̱cachi i̱ xi̱hi̱n ndó ña̱ caja ndó cua̱chi ja̱nda̱ quia̱hva xi̱nu̱ qui̱ví quivi ndó. Jáchi̱ tá co̱ cándúsa ndó ña̱ cúú ye̱he̱ da̱ cáchí i̱ cúú u̱, da̱ na̱chindahá Ndióxi̱, já quéa̱ quivi ndó sa̱há cua̱chi ndó —na̱cachi Jesús.
\p 
\v 25 A̱nda̱ já na̱nda̱ca̱ tu̱hún na̱ cán Jesús já na̱cachi na já xi̱hi̱n á:
\p —Ta ndá da̱ cúú yóhó, dá já —na̱cachi na.
\p Já na̱cachi Jesús já:
\p —Ja̱nda̱ sa̱há va na̱ca̱ha̱n i̱ xi̱hi̱n ndó yo cúú ye̱he̱.
\v 26 Ta ña̱ xíni̱ jo̱ho i̱ cáha̱n mé á na̱chindahá ye̱he̱, ña̱ cán cúú ña̱ cáha̱n i̱ xi̱hín ña̱yivi ñuyíví. Ta ndinuhu ña̱ nda̱a̱ quéa̱ cáha̱n mé á. Ta mé a̱ nda̱a̱ íin cua̱há ndiva̱ha ña̱ núu cája ndó ta cuu tavá i̱ sa̱há nu̱ ndó tá ná caja vií i̱ sa̱ha̱ ndo̱ —na̱cachi Jesús.
\p 
\v 27 Joo co̱ó na̱canda̱a̱ ini na ña̱ cáha̱n Jesús sa̱ha̱ Ndióxi̱, tátá a̱ tá na̱cachi a já xi̱hi̱n ná.
\v 28 Sa̱há ña̱ cán quéa̱ na̱cachi tucu a já xi̱hi̱n ná:
\p —Tá na̱ndihi ná cata caa ndó ye̱he̱, da̱ na̱chindahá Ndióxi̱ nduu ña̱yivi ndi̱ca crúxu̱ já quéa̱ canda̱a̱ ndusa ini ndó ña̱ ye̱he̱ cúú u̱ da̱ cáchí i̱ cúú u̱. Ta ni in túhún ña̱ha co̱ cája i̱ cuéntá mí i̱. Ta ña̱ jána̱ha̱ i̱ nu̱ ndo̱ cúú ña̱ na̱jána̱ha̱ Ndióxi̱, tátá i̱ nu̱ú i̱.
\v 29 Ta mé á na̱chindahá ye̱he̱ co̱ na̱jándacoo ndáha̱ toho a̱ ye̱he̱ jáchi̱ íin tuun Ndióxi̱, tátá i̱ xi̱hín i̱. Ta níí tiempo ña̱ cája i̱ cúú ña̱ cáji̱i̱ ini Ndióxi̱ xi̱hi̱n —na̱cachi Jesús.
\p 
\v 30 Ta chí cua̱há ña̱yivi na̱candúsa na Jesús tá na̱xini jo̱ho na tócó ndihi ña̱ yóho.
\s1 Na̱ ndúu ndáha̱ rí quini xi̱hín na̱ ndúu ndáha̱ Ndióxi̱
\p 
\v 31 A̱nda̱ já na̱ca̱ha̱n Jesús xi̱hín java na̱ Israel, na̱ sa̱ na̱candúsa ñahá cán já na̱cachi a já xi̱hi̱n ná:
\p —Tá ná caja ndó tá íin na̱ca̱ha̱n i̱ xi̱hi̱n ndo̱ já na̱ha̱ ndó ña̱ mé a̱ nda̱a̱ táhyí cúú ndó na̱ cuéntá mí i̱.
\v 32 Ta já canda̱a̱ ini ndó ña̱ nda̱a̱ ta ña̱ cán caja ña̱ ná a̱ cácuu ga̱ ndó tátu̱hun in mozo, da̱ ndúu ndáha̱ rí quini —na̱cachi Jesús.
\p 
\v 33 A̱nda̱ já na̱cachi na̱ cán já xi̱hi̱n á:
\p —Na̱ na̱quixi chi̱chi Abraham cúú nde̱. Ta ja̱nda̱ ni in túhún tañu co̱ó na̱sa̱cuu nde̱ mozo. Joo yóhó cáchún xi̱hín nde̱ ña̱ a̱ cácuu ga̱ nde̱ mozo. Ndaja cáa ña̱ cáa ri a já —na̱cachi na.
\p 
\v 34 Já na̱cachi Jesús já xi̱hi̱n ná:
\p —Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. Tócó ndihi na̱ sá caja cua̱chi cúú tá cúú na̱ tátu̱hun mozo nu̱ú cua̱chi jáchi̱ cómí a̱ cuéntá sa̱ha̱ ná.
\v 35 Ta da̱ cúú mozo nu̱ú in xitoho, co̱ó sa̱ha̱ dá coo nahá da̱ xi̱hín xitoho da jáchi̱ va̱xi qui̱vi̱ ndítahan quee da cu̱hu̱n da̱. Joo da̱ cúú ja̱hyi mé da̱ cúú xitoho cán íin sa̱ha̱ dá coo nahá da̱ xi̱hi̱n tátá da̱ jáchi̱ cúú dá da̱ vehe tátá da̱.
\v 36 Ta quia̱hva já íin xi̱hín ye̱he̱, da̱ cúú ja̱hyi Ndióxi̱. Cája i̱ ña̱ ná a̱ cácomí ga̱ cua̱chi cuéntá sa̱ha̱ ndo̱ ta já a̱ cácuu ga̱ ndó tátu̱hun mozo nu̱ú cua̱chi cája ndó.
\v 37 Ta sa̱ cánda̱a̱ va̱ha ini i̱ ña̱ cúú ndó ña̱yivi na̱quixi chi̱chi Abraham. Joo mé ndó cúni̱ ndó cahní ndó ye̱he̱ jáchi̱ co̱ cúni̱ ndó ndiquehe va̱ha ndó tu̱hun cáha̱n i̱.
\v 38 Cáha̱n i̱ sa̱ha̱ tócó ndihi ña̱ na̱na̱ha̱ Ndióxi̱, tátá i̱ nu̱ú i̱. Joo ndóhó cája ndó ña̱ cáha̱n tátá ndo̱ xi̱hi̱n ndó —na̱cachi Jesús.
\p 
\v 39 A̱nda̱ já na̱cachi na̱ cán já xi̱hi̱n á:
\p —Abraham cúú tátá nde̱ jáchi̱ chi̱chi da̱ cán na̱quixi nde̱ —na̱cachi na.
\p Já na̱cachi Jesús já xi̱hi̱n ná:
\p —Tá jivi ndusa cúú ndó na̱ na̱quixi chi̱chi Abraham já quéa̱ caja ndó tá quia̱hva na̱caja da̱ cán, nduu.
\v 40 Joo ndúcú ndó cahní ndó ye̱he̱ jáchi̱ cáha̱n i̱ ña̱ nda̱a̱ xi̱hi̱n ndo̱ tá cáchí i̱ ña̱ na̱jána̱ha̱ Ndióxi̱ nu̱ú i̱. Mé Abraham co̱ó na̱caja toho da já.
\v 41 Joo cája ndó ña̱ núu tá quia̱hva cája tátá ndo̱ —na̱cachi Jesús.
\p Já na̱cachi na̱ cán já xi̱hi̱n á:
\p —A̱ ju̱ú ja̱hyi ndáhví toho ña̱yivi cúú nde̱he̱. Ndióxi̱ cúú ndusa tátá nde̱ —na̱cachi na.
\p 
\v 42 Já na̱cachi Jesús já:
\p —Tá Ndióxi̱ ndusa ná cacuu tátá ndo̱ ta qui̱hvi̱ ini va ndó ye̱he̱, nduu. Jáchi̱ Ndióxi̱ na̱chindahá ye̱he̱ va̱xi i̱ ta íin i̱ yóho viti. Co̱ó va̱xi toho i̱ cuéntá mí i̱. Ndióxi̱ quéa̱ na̱chindahá ye̱he̱ va̱xi i̱.
\v 43 Joo co̱ cánda̱a̱ ini ndó tócó ndihi ña̱ ndícani i̱ nu̱ ndo̱ ta cúú á sa̱há ña̱ co̱ cúni̱ ndó cuni jo̱ho ndó nu̱ cáha̱n i̱ xi̱hi̱n ndo̱.
\v 44 Tátá ndo̱ cúú tiñáhá sa̱cua̱ha̱ ta cája ndó ña̱ cúni̱ rí cán jáchi̱ ñúhu ndó ndáha̱ ri̱. Ta rí sáhní ndi̱i cúú rí cán ja̱nda̱ mé sa̱ha̱. Ta ni in túhún tañu co̱ó na̱tiin rí ña̱ nda̱a̱ já ca̱ha̱n rí ña̱. Jáchi̱ cáha̱n rí ña̱ tu̱hún cuití va ta cuéntá mé rí quíxi ndihi ña̱ tu̱hún.
\v 45 Cande̱hé ndo̱. Co̱ cúni̱ ndó candúsa ndó ye̱he̱ jáchi̱ cáha̱n i̱ ña̱ nda̱a̱ xi̱hi̱n ndó.
\v 46 Ni in túhún toho ndó a̱ cúu na̱ha̱ nu̱ú ña̱yivi ña̱ íin cua̱chi i̱. Ta tá cáha̱n i̱ ña̱ nda̱a̱ cuití va xi̱hi̱n ndó ndá cuéntá quéa̱ co̱ cándúsa ndó ye̱he̱, dá já.
\v 47 Jáchi̱ ndá na̱ cúú ndusa cuéntá Ndióxi̱ táa jo̱ho na ña̱ cúú tu̱hun Ndióxi̱. Joo náha̱ cáxí a̱ ña̱ co̱ cúú ndó cuéntá Ndióxi̱ jáchi̱ co̱ cúni̱ ndó cuni jo̱ho ndó nu̱ cáha̱n mé á xi̱hi̱n ndo̱ —na̱cachi Jesús.
\s1 Ja̱nda̱ tá cáma̱ní cacu Abraham sa̱ íin va Jesús
\p 
\v 48 A̱nda̱ já na̱cana̱há na̱ Israel xi̱hín Jesús já na̱cachi na já:
\p —Mé a̱ nda̱a̱ cúún in da̱ Samaria ta ndáca̱a̱n rí quini inún —na̱cachi na.
\p 
\v 49 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ná:
\p —Co̱ó toho rí quini ndáca̱a̱n ínima̱ ye̱he̱. Ña̱ cája i̱ quéa̱ cája cáhnu i̱ Ndióxi̱, tátá i̱. Joo quéhe núu ndiva̱ha ndó ye̱he̱.
\v 50 Co̱ cúni̱ toho i̱ ña̱ ná caja cáhnu ndó ye̱he̱ va̱tí mé a̱ nda̱a̱ cúni̱ Ndióxi̱ ña̱ ná caja cáhnu ndó ye̱he̱. Ta mé a̱ cán quéa̱ caja vií sa̱ha̱ ndo̱.
\v 51 Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndó. Ndá na̱ ná caja ña̱ cáha̱n i̱ yóho, na̱ cán catacu na a̱nda̱ ama cáa qui̱vi̱ —na̱cachi Jesús.
\p 
\v 52 Já na̱nducú ñehe na̱ cán tu̱hun nu̱ á já na̱cachi na já xi̱hi̱n á:
\p —Viti ndusa cánda̱a̱ ini nde̱ ña̱ ndáca̱a̱n rí quini inún jáchi̱ cáchún ña̱ tá ná caja nde̱ ña̱ cáhu̱n já quéa̱ catacu nde̱ a̱nda̱ ama cáa qui̱vi̱. Joo xíni̱ va̱ha nde̱ ña̱ na̱xi̱hi̱ tá na̱xi̱hi̱ Abraham, tásáhnu jícó nde̱ ta jári na̱ profeta na̱sanduu sa̱nahá na̱xi̱hi̱ na̱.
\v 53 Á cáhnu chága̱ yóhó a̱ ju̱ú ga̱ Abraham, da̱ na̱sacuu tásáhnu jícó nde̱, dá já. Mé Abraham na̱xi̱hi̱ da̱ ta jári mé na̱ profeta na̱xi̱hi̱ ri na̱ cán va. Á cájún cuéntá ña̱ cúún da̱ cáhnu chága̱ a̱ ju̱ú ga̱ na̱ cán, dá já —na̱cachi na xi̱hín Jesús.
\p 
\v 54 Já na̱cachi Jesús já xi̱hi̱n ná:
\p —Tá ná caja cáhnu i̱ mí i̱, co̱ó sa̱ha̱ toho ña̱ cája i̱. Joo Ndióxi̱, tátá i̱ jándicáhnu a ye̱he̱. Ta jári mé ndó cáchí ndo̱ ña̱ jivi mé a̱ cán cúú Ndióxi̱ cája cáhnu ndó.
\v 55 Joo co̱ xíni̱ toho ndó yo cúú mé á. Ye̱he̱ xíni̱ yo cúú mé á. Tá ná cachi i̱ ña̱ co̱ xíni̱ toho i̱ mé á, cúú u̱ in da̱ tu̱hún tátu̱hun mé ndó. Joo mé a̱ nda̱a̱ xíni̱ va̱ha i̱ yo cúú Ndióxi̱ ta cája i̱ ña̱ cáchí mé á.
\v 56 Ta mé Abraham, da̱ na̱sa̱cuu tásáhnu jícó ndo̱ na̱caji̱i̱ íní da̱ jáchi̱ na̱ñe̱he̱ dá tu̱hun ña̱ quixi ye̱he̱ ñuyíví yóho. Ta a̱ ju̱ú quia̱hva na̱caji̱i̱ ini da tá na̱xini da ña̱ yóho —na̱cachi Jesús.
\p 
\v 57 A̱nda̱ já cána̱há chága̱ na̱ Israel xi̱hi̱n á já na̱cachi na já xi̱hi̱n á:
\p —Ni i̱vi̱ jícó u̱xu̱ cui̱a̱ co̱ ndáca̱a̱n yóhó viti. Ta ndaja cúú cáchún na̱xinún Abraham, da̱ cúú tásáhnu jícó nde̱ —na̱cachi na.
\p 
\v 58 Já na̱nducú ñehe Jesús tu̱hun nu̱ ná já na̱cachi a já xi̱hi̱n ná:
\p —Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. Ja̱nda̱ tá cáma̱ní cacu Abraham sa̱ íin va ye̱he̱ jáchi̱ cúú u̱ Ndióxi̱ —na̱cachi Jesús.
\p 
\v 59 A̱nda̱ já na̱tiin na̱ Israel cán yu̱u̱ ña̱ janí na̱ ja̱tá. Joo na̱ndaco̱o je̱hé Jesús já na̱ya̱ha tañu na̱ cán ta na̱quee a veñu̱hu cáhnu cán cua̱ha̱n.
\c 9
\s1 Cája Jesús ña̱ ná ndinu̱na̱ nu̱ú in da̱ta̱a na̱cacu cuáá
\p 
\v 1 In tañu tá xíca Jesús cua̱ha̱n já na̱xini a in da̱ta̱a, da̱ na̱cacu cuáá.
\v 2 A̱nda̱ já na̱casáhá na̱ xíca tuun xi̱hín Jesús cán ndáca̱ tu̱hún na̱ mé á sa̱há da̱ cua̱á cán já cáchí na̱ já xi̱hi̱n á:
\p —Maestro, ndá cuéntá quéa̱ na̱cacu cuáá da̱ yóho. Á na̱cacu cuáá da̱ sa̱há cua̱chi na̱caja tátá da̱ á náná da̱. Á na̱cacu cuáá da̱ sa̱há cua̱chi na̱caja mé dá —na̱cachi na.
\p 
\v 3 Já na̱nducú ñehe Jesús tu̱hun nu̱ ná já na̱cachi a já xi̱hi̱n ná:
\p —Co̱ó na̱cacu cuáá toho da̱ yóho sa̱há cua̱chi mé dá ta ni sa̱há cua̱chi tátá da̱ á náná da̱. Na̱cacu cuáá da̱ já ná na̱ha̱ i̱ nu̱ú ña̱yivi ndá quia̱hva náhnu ña̱ha cúú cája Ndióxi̱.
\v 4 Jáchi̱ ndítahan caja i̱ chuun, ña̱ na̱chindahá tátá i̱ caja i̱ nani xíca nuu i̱ ñuyíví yóho. Ta cúú á tátu̱hun ndiví táhyí cúú á viti joo va̱xi qui̱vi̱ a̱ cóo ga̱ i̱ caja i̱ ña̱ yóho ta já cacuu a tátu̱hun na̱cuaá ndiva̱ha. Ta mé tiempo já ni in na a̱ cúu caja chúun.
\v 5 Nani íin tóo i̱ ñuyíví yóho cúú á tátu̱hun jándiyéhe̱ mí i̱ nu̱ú na̱ ndúu ñuyíví yóho —na̱cachi Jesús.
\p 
\v 6 Tá na̱ndihi na̱cachi Jesús ña̱ yóho já na̱xihnu a tóji̱í a̱ nu̱ ñúhu̱. Ta xi̱hín tóji̱í a̱ cán na̱cava̱ha in mbohla loho nda̱hyi̱ ta na̱chindaa mé á ña̱ nduchú núú da̱ cua̱á cán.
\v 7 Tá na̱ndihi já na̱cachi a já xi̱hi̱n dá:
\p —Cuáhán chi̱co̱ho̱ naní Siloé ta cán cuchún nu̱ún —na̱cachi Jesús xi̱hi̱n dá. Mé tu̱hun Siloé yóho cúni̱ cachi a: Da̱ na̱chindahá na̱.
\p A̱nda̱ já na̱quee mé da̱ cua̱á cán na̱sa̱ha̱n da̱ na̱chichí nu̱ú da̱ ta tá na̱ndicó co̱o da̱ cán sa̱ sánde̱hé va da na̱casa̱a̱ da̱.
\v 8 Ta ndaja coo java na̱ cúú ñani táhan da xi̱hín java na̱ na̱xini ña̱ sáti da̱ cán tá na̱xini na ña̱ sánde̱hé tucu da já na̱cachi na xi̱hi̱n táhan na já:
\p —Á a̱ ju̱ú da̱ yóho cúú da̱ da̱ cua̱á sáco̱o sáti yuhú íchi̱ —cáchí xi̱hi̱n táhan na.
\p 
\v 9 Ta já cáchí java na já:
\p —Jivi da̱ ja̱n cúú dá.
\p Ta java na cáchí na̱:
\p —A̱ ju̱ú toho da̱ ja̱n cúú dá va̱tí quia̱hva já cáa da —na̱cachi na.
\p Joo mé da̱ na̱sahi̱in cuáá cán cáha̱n da̱ xi̱hi̱n ná já cáchí da̱ já:
\p —Jivi ye̱he̱ cúú da̱ na̱sa̱cuu da̱ cua̱á cán —cáchí da̱.
\p 
\v 10 A̱nda̱ já na̱casáhá na̱ ndáca̱ tu̱hún na̱ da̱ já cáchí na̱ já xi̱hi̱n dá:
\p —Ndaja na̱cajún na̱nu̱ná nu̱u̱n —cáchí na̱.
\p 
\v 11 Já na̱cachi da̱ cán já:
\p —Da̱ naní Jesús cúú da̱ na̱cava̱ha in mbohla loho nda̱hyi̱. Ta na̱chindaa da ña̱ nu̱ú i̱ ta na̱cachi da xi̱hín i̱ ña̱ ná cu̱hu̱n i̱ cuchú nu̱ú i̱ chi̱co̱ho̱ naní Siloé. Ta já na̱sa̱ha̱n i̱ na̱chichí nu̱ú i̱ cán ta xi̱hín ña̱ yóho na̱nu̱ná nu̱ú i̱. Sánde̱hé e̱ viti —na̱cachi da.
\p 
\v 12 Já na̱nda̱ca̱ tu̱hún tucu na̱ cán da̱ já cáchí na̱ já:
\p —Ta ndájá cua̱ha̱n da̱ na̱ndaja va̱ha yo̱hó viti —na̱cachi na.
\p —Co̱ xíni̱ toho i̱ —na̱cachi da xi̱hi̱n ná.
\s1 Ndája ndi̱chi̱ na̱ fariseo da̱ cua̱á, da̱ na̱ndiva̱ha cán
\p 
\v 13 Tá na̱ndihi ndáca na da̱ na̱sa̱cuu da̱ cua̱á cán na̱sa̱ha̱n da̱ nu̱ú na̱ fariseo
\v 14 jáchi̱ na̱sa̱cuu a qui̱vi̱ ndíquehe ndée̱ na̱ tá na̱ndaja va̱ha Jesús da̱ cua̱á cán xi̱hi̱n mbohla loho nda̱hyi̱ na̱chindaa a nu̱ú da̱ cán.
\v 15 Já na̱nda̱ca̱ tu̱hún na̱ fariseo cán da̱ ndá quia̱hva na̱nu̱ná nu̱u̱ dá sánde̱hé da̱ viti. Já na̱nducú ñehe da tu̱hun nu̱ ná já na̱cachi da já xi̱hi̱n ná:
\p —Na̱chindaa da nda̱hyi̱ nu̱ú i̱ ta na̱chichí nu̱ú i̱ ta viti tívi nu̱ú i̱ sánde̱hé e̱ —na̱cachi da xi̱hi̱n ná.
\p 
\v 16 Joo java na̱ fariseo na̱cachi na xi̱hín da̱ na̱sa̱cuu da̱ cua̱á cán já:
\p —Da̱ na̱ndaja va̱ha yo̱hó co̱ó va̱xi toho da cuéntá Ndióxi̱ jáchi̱ co̱ cája cáhnu da qui̱vi̱ ndíquehe ndée̱ yo̱ —na̱cachi na.
\p Joo já cáchí java na̱ fariseo já:
\p —Tá da̱ cája cua̱chi ná cacuu Jesús ja̱n ta a̱ cúu caja da ña̱ha xitúhún na̱há tátu̱hun ña̱ yóho, nduu —na̱cachi java na.
\p Chí co̱ó na̱cuu ndique táhan va̱ha tu̱hun na̱ fariseo cán sa̱há ña̱ cán quéa̱ na̱sahnda táhan ndaja táhan mé va na.
\v 17 Já na̱casáhá ndáca̱ tu̱hún tucu na da̱ na̱sacuu da̱ cua̱á cán já cáchí na̱ já xi̱hi̱n dá:
\p —Ta viti na̱nu̱ná nu̱u̱n na̱caja da̱ ja̱n. Yo já cúú dá cáchún —na̱cachi na.
\p Já na̱nducú ñehe da tu̱hun nu̱ ná já na̱cachi da já xi̱hi̱n ná:
\p —Ye̱he̱ cáchí i̱ ña̱ cúú dá in profeta —na̱cachi da.
\p 
\v 18 Joo co̱ó na̱xeen na̱ Israel cán candúsa na ña̱ na̱sa̱cuu da̱ da̱ cua̱á ta ni co̱ cándúsa na ña̱ na̱nu̱ná nu̱u̱ dá. Sa̱há ña̱ cán quéa̱ na̱sa̱ha̱n na̱ na̱cana na tátá náná da̱.
\v 19 Ta já na̱nda̱ca̱ tu̱hún na̱ tátá da̱ xi̱hi̱n náná da̱ já na̱cachi na já xi̱hi̱n ná:
\p —Á ja̱hyi ndó cúú da̱ yóho. Á mé a̱ nda̱a̱ sa̱ já cuáá já cáa da̱ na̱cacu da. Ta ndá cuéntá quéa̱ sa̱ tívi nu̱u̱ dá viti —na̱cachi na.
\p 
\v 20 A̱nda̱ já na̱nducú ñehe na̱ cán tu̱hun nu̱ú na̱ Israel cán já na̱cachi na já xi̱hi̱n ná:
\p —Cánda̱a̱ cáxí ini nde̱ ña̱ ja̱hyi nde̱ cúú da̱ yóho. Ta xíni̱ va̱ha nde̱ ña̱ na̱cacu cuáá da̱.
\v 21 Joo co̱ xíni̱ nde̱ ndaja na̱cuu na̱nu̱ná nu̱u̱ dá sánde̱hé da̱ viti. Ta ni co̱ xíni̱ nde̱ yo cúú da̱ na̱suná nu̱u̱ dá. Ja̱n íin mé ja̱hyi nde̱. Nda̱ca̱ tu̱hún ndó mé dá. Sa̱ quia̱hva ca̱ha̱n mé da̱ ja̱n xi̱hi̱n ndo̱ cúú á jáchi̱ a̱ ju̱ú da̱ loho ga̱ cúú dá ja̱n —na̱cachi tátá da̱ na̱sa̱cuu da̱ cua̱á cán xi̱hín na̱ Israel cán.
\p 
\v 22 Na̱cachi na ña̱ yóho jáchi̱ yíhví na̱ ña̱ ná a̱ quiáhva ga̱ na̱ Israel cán ña̱ma̱ni̱ nu̱ ná ndi̱hvi na veñu̱hu. Jáchi̱ mé na̱ Israel cán na̱jándique táhan na tu̱hun na ña̱ a̱ quiáhva ga̱ na̱ ña̱ma̱ni̱ nu̱ú ña̱yivi qui̱hvi na ini veñu̱hu tá ta̱ cáha̱n na̱ ña̱ cúú Jesús da̱ na̱chindahá Ndióxi̱ cacomí cuéntá sa̱há ña̱yivi.
\v 23 Sa̱há ña̱ cán quéa̱ na̱cachi tátá náná da̱ na̱sacuu da cua̱á cán xi̱hín na̱ Israel ña̱ ndítahan nda̱ca̱ tu̱hún na̱ mé dá jáchi̱ a̱ ju̱ú ga̱ da̱ loho cúú da̱ ja̱n.
\p 
\v 24 Tá na̱ndihi já na̱cana tucu na̱ Israel da̱ na̱sa̱cuu da̱ cua̱á cán já na̱cachi na já xi̱hi̱n dá:
\p —Xíní ñúhú caja cáhnún Ndióxi̱ ta a̱ cája cáhnún Jesús ja̱n jáchi̱ xíni̱ va̱ha nde̱ ña̱ cúú dá in da̱ cája cua̱chi —na̱cachi na.
\p 
\v 25 A̱nda̱ já na̱cachi da̱ cán já xi̱hín na̱ Israel:
\p —Co̱ xíni̱ toho i̱ á cúú dá da̱ cája cua̱chi á cúú dá da̱ co̱ cája cua̱chi. Ña̱ xíni̱ ndusa i̱ quéa̱ na̱sa̱cuu u̱ da̱ cua̱á ta jivi da̱ ja̱n na̱suná nu̱ú i̱ sánde̱hé e̱ viti —na̱cachi da xi̱hi̱n ná.
\p 
\v 26 A̱nda̱ já na̱casáhá ndáca̱ tu̱hún tucu na da̱ já cáchí na̱ já xi̱hi̱n dá:
\p —Ta ndaja na̱caja da na̱suná da̱ nduchú núún. Ndía̱ na̱caja da xu̱hu̱n —na̱cachi na xi̱hi̱n dá.
\p 
\v 27 A̱nda̱ já na̱cachi da̱ na̱sa̱cuu da̱ cua̱á cán já xi̱hi̱n ná:
\p —Sa̱ na̱cachi vi̱ xi̱hi̱n ndo̱ ndá quia̱hva na̱caja da na̱suná da̱ nu̱ú i̱. Joo co̱ cúni̱ ndó candúsa ndó ye̱he̱. Ndá cuéntá quéa̱ ndáca̱ tu̱hún tucu ndó ye̱he̱. Á cu̱hu̱n ri ndóhó va caca nuu ndó xi̱hi̱n dá cúni̱ ndo̱, va̱ha —na̱cachi da xi̱hi̱n ná.
\p 
\v 28 Já na̱casáhá na̱ Israel cán cána̱há na̱ xi̱hi̱n dá ta já na̱cachi na já xi̱hi̱n dá:
\p —Yóhó va cúú da̱ xíca nuu xi̱hín da̱ ja̱n. Joo nde̱he̱ jácuaha nde̱ ley Moisés cuití va.
\v 29 Jáchi̱ cánda̱a̱ va̱ha ini nde̱ ña̱ na̱ca̱ha̱n Ndióxi̱ xi̱hín Moisés. Joo mé Jesús ja̱n co̱ cúú dá cuéntá Ndióxi̱ ta ni co̱ xíni̱ nde̱ ndájá na̱quixi da ja̱n —na̱cachi na xi̱hín da̱ na̱sa̱cuu da̱ cua̱á cán.
\p 
\v 30 A̱nda̱ já na̱cachi tucu da̱ cán já xi̱hi̱n ná:
\p —Mé a̱ nda̱a̱ cátóntó vi̱ xi̱hín ña̱ yóho jáchi̱ jivi Jesús ja̱n na̱suná da̱ nu̱ú i̱ ta ndóhó ni co̱ cánda̱a̱ ini ndó ndá da̱ cúú dá ta ni co̱ xíni̱ ndo̱ ndájá na̱quixi da.
\v 31 Sa̱ xíni̱ yo̱ ña̱ co̱ xíni̱ jo̱ho Ndióxi̱ ña̱ xíca̱ ta̱hví ña̱yivi cája cua̱chi nu̱ á. Joo xíni̱ jo̱ho mé á nu̱ cáha̱n ña̱yivi tá cája cáhnu na mé á ta tá cája na ña̱ cúni̱ a̱.
\v 32 Ta viti cande̱hé ndo̱. Ja̱nda̱ sa̱ha̱ ñuyíví a̱ ñáha cuni jo̱ho í ña̱ ndícuná in da̱ta̱a nduchú núú in da̱ na̱cacu cuáá.
\v 33 Ta Jesús yóho a̱ cúu toho caja cuná a̱ nu̱ú i̱ tá ta̱ co̱ cúú á ña̱ na̱quixi cuéntá Ndióxi̱ —na̱cachi da.
\p 
\v 34 A̱nda̱ já na̱nducú ñehe na̱ cán tu̱hun nu̱ dá já na̱cachi na já xi̱hi̱n dá:
\p —A̱nda̱ tá na̱cacún na̱chutú nda̱ún xi̱hín cua̱chi. Ta viti chí cúni̱ ri yóhó jána̱hún nde̱he̱ —na̱cachi na̱ Israel cán xi̱hi̱n dá.
\p A̱nda̱ já na̱taxí na̱ da̱ veñu̱hu cán.
\s1 Ña̱yivi, na̱ sánde̱hé cúú ná tátu̱hun na̱ co̱ tívi nu̱u̱
\p 
\v 35 Tá na̱ndihi já na̱canda̱a̱ ini Jesús ña̱ na̱taxí na̱ da̱ na̱sa̱cuu da̱ cua̱á cán veñu̱hu. Ta tá na̱nditahan tucu Jesús da̱ já na̱cachi a já xi̱hi̱n dá:
\p —Á cándeé inún da̱ na̱chindahá Ndióxi̱ nduu ña̱yivi —na̱cachi Jesús xi̱hi̱n dá.
\p 
\v 36 Já na̱cachi da já xi̱hi̱n á:
\p —Cachi ndó xi̱hín i̱ yo já cúú dá ña̱ ná cuu candeé ini i̱ da̱ —na̱cachi da.
\p 
\v 37 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n dá:
\p —Sa̱ na̱xini vún ye̱he̱ ta jivi ye̱he̱, da̱ cáha̱n xu̱hu̱n yóho cúú da̱ na̱chindahá Ndióxi̱ nduu ña̱yivi —na̱cachi Jesús.
\p 
\v 38 Ta tá na̱cachi Jesús ña̱ yóho já na̱caxítí da̱ cán nu̱ á caja cáhnu da a̱ já na̱cachi da já xi̱hi̱n á:
\p —Mé a̱ nda̱a̱ cándeé ini i̱ ndo̱hó, xitoho i̱ —na̱cachi da.
\p 
\v 39 A̱nda̱ já na̱cachi tucu Jesús já xi̱hi̱n dá:
\p —Ye̱he̱ na̱quixi i̱ ñuyíví yóho já ná na̱ha̱ i̱ nu̱ú ña̱yivi ndá quia̱hva ndáa ña̱ cája na. Jáchi̱ ndá na̱ cándeé ini ye̱he̱ cúú ná tátu̱hun na̱ sa̱ na̱ndiye̱he̱ nu̱u̱. Joo ndá na̱ cáhán ña̱ cúú ná na̱ sa̱ na̱ndiye̱he̱ nu̱u̱ cúú ná tátu̱hun na̱ cua̱á —na̱cachi Jesús.
\p 
\v 40 Ta java na̱ fariseo, na̱ ndíta xi̱hín Jesús cán tá na̱xini jo̱ho na ña̱ yóho já na̱nda̱ca̱ tu̱hún na̱ mé á já cáchí na̱ já:
\p —Á co̱ cáhún ña̱ cúú ri nde̱he̱ va na̱ cua̱á —na̱cachi na.
\p 
\v 41 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ná:
\p —Tá ná ndicuni ndó ña̱ cúú ndó tátu̱hun na̱ cua̱á ta co̱ó toho cua̱chi ndó, nduu. Joo tá cáchí ndó ña̱ tívi va̱ha ndiva̱ha nu̱u̱ ndo̱ ta co̱ xíní ñúhú ndó in na̱ jána̱ha̱ ndo̱hó sa̱há ña̱ cán quéa̱ íin tá íin cua̱chi ndó —na̱cachi Jesús xi̱hi̱n ná.
\c 10
\s1 Jesús cúú á tátu̱hun in da̱ ndáá ndicachi
\p 
\v 1 A̱nda̱ já na̱cachi Jesús já:
\p —Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. Tá ná qui̱hvi in da̱ta̱a ini in corra nu̱ ñúhu ndicachi joo co̱ cúni̱ da̱ qui̱hvi da chí yéhé nu̱ quíhvi mé rí ta ña̱ cája da quéa̱ ndáva ndojó da̱ corra ri̱ já náha̱ xi̱cá a̱ ña̱ cúú dá da̱ cui̱hná.
\v 2 Joo mé da̱ quíhvi chí yéhé cúú dá da̱ ndáá ndicachi.
\v 3 Ta mé da̱ ndáá yéhé corra nu̱ ñúhu ndicachi cán súná da̱ yéhé ña̱ ná ndi̱hvi da̱ ndáá ndicachi ta jácana da rí cán tá qui̱vi̱ in in rí. Ta mé ndicachi cán ndícuni rí ta̱chi̱ dá já quéta rí cua̱ha̱n rí caca nuu rí xi̱hi̱n dá.
\v 4 Ta tá sa̱ na̱queta ndihi rí já ndáca da ri̱. Ta cánu̱ú da̱ nu̱ ri̱ cua̱ha̱n da̱ já va̱ha cua̱ha̱n rí xi̱hi̱n dá jáchi̱ ndícuni va̱ha rí ta̱chi̱ dá.
\v 5 Joo co̱ ndíco̱ rí ja̱tá ña̱yivi tóho̱ jáchi̱ co̱ ndícuni rí ta̱chi̱ ná jáchi̱ cúú ná na̱ tóho̱. Ña̱ cája rí quéa̱ xínu rí nu̱ ná —na̱cachi Jesús xi̱hín na̱ fariseo.
\p 
\v 6 Ta ña̱ yóho na̱sa̱cuu in quia̱hva na̱sacu Jesús nu̱ú na̱ fariseo joo co̱ó na̱canda̱a̱ ini na ña̱ cúni̱ mé á cachi a xi̱hi̱n ná.
\p 
\v 7 A̱nda̱ já na̱cachi tucu Jesús já xi̱hi̱n ná:
\p —Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. Ye̱he̱ cúú u̱ tátu̱hun in yéhé nu̱ yáha ndicachi já ndíhvi rí corra ri̱.
\v 8 Tócó ndihi na̱ na̱quixi tá cáma̱ní xi̱nu̱ i̱ ñuyíví yóho na̱jándahvi na ña̱yivi ta cúú ná tátu̱hun na̱ cui̱hná. Joo co̱ó na̱xeen na̱ cúú cuéntá mí i̱, na̱ cúú tátu̱hun ndicachi taa jo̱ho na̱ nu̱ cáha̱n na̱ cán.
\v 9 Ye̱he̱ cúú u̱ tátu̱hun in yéhé ta ndá na̱ ná quixi nu̱ú i̱ quia̱hva i̱ ña̱ma̱ni̱ nu̱ ná qui̱hvi na já ná ca̱cu ndaa ínima̱ ná. Cúú á tátu̱hun núná nu̱ú ndicachi qui̱hvi rí ini corra ri̱ ta núná nu̱ú rí queta tucu rí jáchi̱ íin yu̱cu̱ cuíi̱ nu̱ ri̱ xíxáhan rí.
\p 
\v 10 ʼJáchi̱ da̱ cúú da̱ cui̱hná cán cája cuíhná da̱ ri̱ ta sáhní da̱ ri̱ ta jándihi da sa̱ha̱ ri̱. Joo ye̱he̱ na̱quixi i̱ ñuyíví yóho já ná cuu catacu va̱ha ña̱yivi ta já ná cuu coo va̱ha na a̱nda̱ ama cáa qui̱vi̱.
\v 11 Ye̱he̱ cúú u̱ tátu̱hun in da̱ ndáá va̱ha ndicachi. Jáchi̱ da̱ cán co̱ yíhví da̱ quivi da sa̱há ndicachi jana dá.
\v 12 Joo da̱ quéhe ya̱hvi sa̱há ña̱ ndáá da̱ ndicachi, ndáá da̱ ri̱ sa̱ha̱ ya̱hvi quéhe da̱ cán cuití va. Sa̱há ña̱ cán quéa̱ tá xíní da̱ va̱xi ndiva̱hyí quehe rí in ndicachi, ña̱ cája da quéa̱ xínu da cua̱ha̱n da̱ ta jándacoo da ndicachi ndáhví cán. Jáchi̱ co̱ cúú dá da̱ ndáá va̱ha rí ta ni ja̱na̱ dá co̱ cúú ndicachi cán. Ta co̱ sáhní da̱ mé dá tá ná xi̱nu̱ co̱o ndiva̱hyí ña̱ ná tiin rí ndicachi cán cata nuu ñahá ri̱.
\v 13 Da̱ quéhe ya̱hvi cán jándacoo da ri̱ jáchi̱ co̱ cúú rí ja̱na̱ mé dá ta co̱ sáhní da̱ mé dá cúú ndicachi.
\p 
\v 14 ʼJoo ye̱he̱ cúú u̱ tátu̱hun in da̱ ndáá va̱ha ndicachi. Tá quia̱hva xíni̱ va̱ha da̱ cán ndá rí cúú ndicachi ja̱na̱ dá quia̱hva já xíni̱ va̱ha i̱ ndá na̱ cúú cuéntá mí i̱. Ta jári xíni̱ va̱ha mé ná ye̱he̱.
\v 15 Tá quia̱hva xíni̱ va̱ha Ndióxi̱, tátá i̱ ye̱he̱ ta xíni̱ va̱ha i̱ mé á quia̱hva já xíni̱ va̱ha i̱ na̱ cúú cuéntá mí i̱. Ta sa̱há ña̱ yóho íin tia̱hva i̱ ndiquia̱hva i̱ mí i̱ quivi i̱ sa̱ha̱ ná jáchi̱ cúú ná tátu̱hun ndicachi ja̱ná i̱.
\v 16 Joo ndúu java ga̱ ña̱yivi inga ñuu ta cacuu na cuéntá mí i̱. Xíní ñúhú ndiquehe e̱ na̱ cán ña̱ ná cuni jo̱ho na nu̱ cáha̱n i̱. Ta in nduu ndihi na ña̱ ná candaa i̱ tócó ndihi na.
\p 
\v 17 ʼQuíhvi̱ ini Ndióxi̱, tátá i̱ ye̱he̱ jáchi̱ ndíquia̱hva i̱ mí i̱ quivi i̱ sa̱há na̱ cúú cuéntá mí i̱ ta tá na̱ndihi nditacu tucu u̱.
\v 18 Ta ni in na a̱ cúu cahní ye̱he̱ ndaja na̱cuu joo ndíquia̱hva i̱ mí i̱ quivi i̱ jáchi̱ cúni̱ caja i̱ ña̱. Núná nu̱ú i̱ ndiquia̱hva i̱ mí i̱ quivi i̱ ta núná nu̱ú i̱ nditacu tucu u̱. Ña̱ yóho cúú chuun na̱sahnda tátá i̱ nu̱ú i̱ caja i̱ —na̱cachi Jesús.
\p 
\v 19 Tá na̱xini jo̱ho na̱ Israel cán ña̱ yóho já na̱casáhá na̱ sáhndá táhan tucu na.
\v 20 Ta cua̱ha̱ táhan na̱ cán na̱casáhá cáchí na̱ já:
\p —Ndá cuéntá quéa̱ táa jo̱ho ndó nu̱ cáha̱n da̱ ja̱n ta da̱ na̱cata̱chi̱ va cúú dá. Tiñáhá va ndáca̱a̱n ini da —cáchí xi̱hi̱n táhan na.
\p 
\v 21 Joo java na cáha̱n va̱ha na sa̱há Jesús já cáchí na̱ já:
\p —Ni in toho ña̱yivi a̱ cúu ca̱ha̱n va̱ha na̱há tátu̱hun cáha̱n Jesús yóho tá ndáca̱a̱n tiñáhá ini ínima̱ ná. Jáchi̱ ama ná cuu caja ri tiñáhá jándiye̱he̱ rí nu̱ú na̱ cua̱á —cáchí java na̱ cán.
\s1 Cándají na̱ Israel Jesús
\p 
\v 22 Na̱xi̱nu̱ co̱o qui̱vi̱ cája na víco̱ nu̱ cuía̱ ñuu Jerusalén tá cája cáhnu na qui̱ví na̱xi̱nu̱ veñu̱hu cáhnu ñuu Jerusalén. Ta mé tiempo vi̱xi na̱sa̱cuu a cán.
\v 23 Ta jivi ini mé veñu̱hu cáhnu cán na̱sahi̱in Jesús ta xíca nuu a yati yuyéhé naní Salomón.
\v 24 Já na̱ca̱va̱ ti̱yi̱vi̱ na̱ Israel cán mé á já na̱casáhá ndáca̱ tu̱hún na̱ mé á já na̱cachi na já xi̱hi̱n á:
\p —Ndaja cáa chí qui̱ví ca̱xi tu̱hun nda̱u̱n xi̱hín nde̱ ña̱ á jivi ndusa cúún Cristo, da̱ chindahá Ndióxi̱ cacomí cuéntá sa̱há ña̱yivi. Jáchi̱ in i̱vi̱ joho cáhu̱n xíní nde̱ ta co̱ cánda̱a̱ va̱ha ini nde̱ á jivún á a̱ ju̱ú tohún —na̱cachi na̱ cán.
\p 
\v 25 A̱nda̱ já na̱nducú ñehe Jesús tu̱hun nu̱ ná já na̱cachi a já:
\p —Sa̱ na̱ca̱ha̱n vi̱ xi̱hi̱n ndó joo co̱ó na̱candúsa ndó ye̱he̱. Tócó ndihi ña̱ náhnu cája i̱, cája i̱ ña̱ xi̱hi̱n ndée̱ sáhan tátá i̱ nu̱ú i̱ ta jivi mé ña̱ náhnu ja̱n náha̱ nu̱ ndó ña̱ cúú u̱ da̱ na̱chindahá Ndióxi̱.
\v 26 Joo ndóhó co̱ cándúsa ndó ye̱he̱ jáchi̱ co̱ cúú ndó tátu̱hun ndicachi ja̱ná i̱.
\v 27 Joo ña̱yivi, na̱ cúú tátu̱hun ndicachi ja̱ná i̱, na̱ cán cúú na̱ ndícuni nu̱ cáha̱n i̱ ta ndícuni i̱ na̱ ña̱ cúú ná cuéntá mí i̱ ta já ndíco̱ na̱ ye̱he̱.
\v 28 Ta caja i̱ ña̱ ná catacu na a̱nda̱ ama cáa qui̱vi̱ já ná a̱ ndíhi sa̱ha̱ ná. Ta ni in túhún ña̱yivi a̱ cúu caja candaa na̱ cán ndahá i̱ tá sa̱ ñúhu na ndahá i̱.
\v 29 Ndióxi̱, tátá i̱ na̱sa̱ha̱n na̱ cán nu̱ú i̱ ta mé á quéa̱ cáhnu chága̱ nu̱ tócó ndihi ña̱ha. Ta ni in na a̱ cúu caja candaa na̱ cán ndáha̱ mé á.
\v 30 Ye̱he̱ xi̱hi̱n Ndióxi̱, tátá i̱ in cúú va nde̱ —na̱cachi Jesús.
\p 
\v 31 A̱nda̱ já na̱tiin tucu na̱ Israel cán yu̱u̱ cuun na Jesús ña̱ cahní ñahá na̱.
\v 32 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ná:
\p —Cua̱há ndiva̱ha ña̱ náhnu na̱caja i̱ nu̱ ndó, ña̱ na̱sa̱ha̱n tátá i̱ ña̱ma̱ní nu̱ú i̱ caja i̱ nu̱ ndo̱ yóho ta viti cachi ndó xi̱hín i̱ ndá quéa̱ co̱ táhan ini ndó xi̱hi̱n. Ndá cuéntá quéa̱ va̱xi ndó cuun ndó yu̱ú ye̱he̱ —na̱cachi Jesús.
\p 
\v 33 A̱nda̱ já na̱cachi na̱ cán já xi̱hi̱n á:
\p —Co̱ ndúcú toho nde̱ cuun nde̱ yu̱u̱ yo̱hó sa̱há ña̱ náhnu cájún. Cuun nde̱ yu̱u̱ yo̱hó cúni̱ nde̱ jáchi̱ ndája núún Ndióxi̱. Jáchi̱ cúún in ta̱a tátu̱hun nde̱he̱ ta ndájún mún cúún Ndióxi̱ —na̱cachi na̱ cán.
\p 
\v 34 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ná:
\p —Nu̱ ley na̱jándacoo Moisés nu̱ ndo̱ cáchí a̱ ña̱ cúú ña̱yivi tátu̱hun Ndióxi̱ sa̱há ña̱ cúú ná ja̱hyi mé á.
\v 35 Ta sa̱ cánda̱a̱ va̱ha iní ña̱ a̱ cu̱ú ta̱hnu̱ ña̱ cáha̱n tu̱hun Ndióxi̱. Ta na̱cachi Ndióxi̱ xi̱hín na̱ na̱ndiquehe tu̱hun mé á ña̱ cúú ná tátu̱hun Ndióxi̱.
\v 36 Sa̱há ña̱ cán quéa̱ ndá cuéntá quéa̱ cáchí ndo̱ ña̱ na̱ndaja núu i̱ Ndióxi̱ sa̱há ña̱ cáchí i̱ cúú u̱ in túhún ji̱ni̱ já ja̱hyi Ndióxi̱. Jáchi̱ mé Ndióxi̱ na̱ca̱xi a ye̱he̱ ta na̱chindahá a̱ ye̱he̱ va̱xi i̱ ñuyíví yóho.
\v 37 Sa̱há ña̱ cán quéa̱ co̱ ndítahan candúsa ndó ye̱he̱ tá ta̱ co̱ cája i̱ ña̱ náhnu tátu̱hun ña̱ cája Ndióxi̱, tátá i̱.
\v 38 Joo tá cája i̱ ña̱ já quéa̱ xíní ñúhú candúsa ndó ña̱ náhnu xíní ndo̱ cája i̱ va̱tí co̱ cúni̱ ndó candúsa ndó ye̱he̱. Ta xi̱hín ña̱ yóho cuu candúsa ndó ña̱ in cúú Ndióxi̱, tátá i̱ xi̱hín i̱ ta in cúú ye̱he̱ xi̱hi̱n mé á —na̱cachi Jesús.
\p 
\v 39 A̱nda̱ já ndúcú tucu na tiin na a̱ chica̱a̱n na̱ a̱ veca̱a joo na̱chije̱hé a̱ nu̱ ná cua̱ha̱n.
\p 
\v 40 Ta já na̱quee tucu a cua̱ha̱n chí inga xoo yu̱ta Jordán nu̱ú na̱caja ndúta̱ Juan ña̱yivi nu̱ cuítí cán. Ta na̱cando̱o Jesús na̱sahi̱in a cán.
\v 41 Ta cua̱há ña̱yivi na̱casáhá na̱ xínu̱ na̱ nu̱ á ta já cáchí xi̱hi̱n táhan na já:
\p —Mé a̱ nda̱a̱ co̱ó toho ña̱ha xitúhún na̱caja Juan. Joo tócó ndihi ña̱ na̱cachi da̱ cán sa̱ha̱ Jesús yóho cúú á ña̱ nda̱a̱ —na̱cachi xi̱hi̱n táhan na̱ cán.
\p 
\v 42 Ta cua̱ha̱ ná na̱candúsa na Jesús mé nu̱ú na̱sahi̱in a cán.
\c 11
\s1 Tá na̱jánditacu Jesús Lázaro
\p 
\v 1 Ta ndaja coo na̱quehe cue̱he̱ in da̱ naní Lázaro, da̱ ñuu Betania. Ta jivi mé ñuu yóho cúú ri ñuu María xi̱hi̱n Marta, qui̱hvi̱ ña̱.
\v 2 Mé María, ñá cúú quia̱hva Lázaro yóho cúú ñá ñá na̱xo̱jo̱ perfume ja̱tá sa̱há Jesús ta na̱jándihi̱chi̱ ñá do̱ xi̱hín ijí ji̱ni̱ ña̱.
\v 3 Ta mé ñá xi̱hín qui̱hvi̱ ña̱ na̱chindahá na̱ chuun cua̱ha̱n nu̱ú Jesús ña̱ cácáhví ndiva̱ha Lázaro, da̱ quíhvi̱ ini mé á.
\p 
\v 4 Ta tá na̱ñe̱he̱ Jesús tu̱hun yóho já na̱cachi a já:
\p —A̱ ju̱ú cue̱he̱ cahní ñahá cúú toho ña̱ yóho. Joo xi̱hín cue̱he̱ yóho cuu na̱ha̱ ndá quia̱hva cáhnu cúú Ndióxi̱. Ta xi̱hín ña̱ yóho na̱ha̱ nu̱ú ña̱yivi ndá quia̱hva cáhnu cúú ye̱he̱, da̱ cúú in túhún ji̱ni̱ já ja̱hyi Ndióxi̱ —na̱cachi a.
\p 
\v 5 Ta ndaja coo quíhvi̱ ndiva̱ha ini Jesús Marta xi̱hín qui̱hvi̱ ñá ta quia̱hva já quíhvi̱ ri ini a Lázaro viti.
\v 6 Joo tá na̱ñe̱he̱ Jesús tu̱hun ña̱ quíhvi̱ Lázaro já na̱cando̱o a i̱vi̱ qui̱vi̱ chága̱ mé nu̱ú na̱sahi̱in a̱ cán.
\v 7 Ta tá na̱ndihi já na̱cachi Jesús já xi̱hín na̱ xíca tuun xi̱hi̱n á:
\p —Xíhín ndo̱ ná co̱ho̱ tucú chí Judea —na̱cachi a.
\p 
\v 8 A̱nda̱ já na̱cachi na̱ cán já xi̱hi̱n á:
\p —Maestro, viti chá va ndúcú ña̱yivi ndúu cán cahní na̱ ndo̱hó xi̱hín yu̱u̱ ta cáa tucu ri ndó cu̱hu̱n ndo̱ cúni̱ ndo̱ —na̱cachi na.
\p 
\v 9 Joo sa̱ xíni̱ Jesús ña̱ cáma̱ní xi̱nu̱ qui̱vi̱ quivi a sa̱há ña̱ cán quéa̱ na̱cachi a já xi̱hi̱n ná:
\p —Cande̱hé ndó. U̱xu̱ i̱vi̱ hora ndáca in qui̱vi̱ ta tá xíca nuu na ndiví a̱ cúu toho cachihin sa̱ha̱ ná jáchi̱ tívi xícá yéhe̱ nu̱ xíca na.
\v 10 Joo ndá na̱ xíca nuu ñuú cuu cachihin sa̱ha̱ ná jáchi̱ co̱ yéhe̱ nu̱ xíca na —na̱cachi Jesús.
\p 
\v 11 Tá na̱ndihi já na̱cachi tucu a já xi̱hi̱n ná:
\p —Sa̱ na̱qui̱ji̱ va amigo yo̱ Lázaro viti. Joo víla̱á cu̱hu̱n i̱ ndiñehe e̱ da̱ —na̱cachi Jesús.
\p 
\v 12 A̱nda̱ já na̱cachi na̱ cán já xi̱hi̱n á:
\p —Maestro, tá ta̱ na̱naá ini da na̱qui̱ji̱ dá já quéa̱ íin va̱ha da, dá já —na̱cachi na̱ cán.
\p 
\v 13 Joo ña̱ cúni̱ cachi Jesús quéa̱ sa̱ na̱xi̱hi̱ va Lázaro va̱tí na̱ xíca tuun xi̱hín a̱ cán na̱ca̱hán na̱ ña̱ cúni̱ mé á cachi a quéa̱ na̱qui̱ji̱ Lázaro cán tá quia̱hva quíji̱ tócó ndihi ña̱yivi.
\v 14 A̱nda̱ já na̱ca̱ha̱n cáxí táhyí tucu Jesús xi̱hi̱n ná já na̱cachi a já:
\p —Na̱xi̱hi̱ va Lázaro.
\v 15 Joo cáji̱i̱ va ini i̱ ña̱ co̱ó i̱ ná sahi̱in i̱ tá na̱xi̱hi̱ da̱ jáchi̱ ña̱ yóho chindeé a̱ ndo̱hó já ná candúsa chága̱ ndó ye̱he̱. Cóho̱ cande̱hé yo̱ Lázaro —na̱cachi Jesús.
\p 
\v 16 A̱nda̱ já na̱casáhá Tomás, da̱ cáha̱n na̱ cuátí xi̱hi̱n cán cáha̱n da̱ xi̱hín java ga̱ na̱ xíca tuun xi̱hín Jesús já cáchí da̱ já:
\p —Cóho̱ ri mí ví quiví xi̱hi̱n mé dá, dá já —cáchí da̱.
\p Já na̱quee na cua̱ha̱n na̱.
\s1 Cúú cája Jesús ña̱ ná nditacu tucu na̱ sa̱ na̱xi̱hi̱
\p 
\v 17 Tá na̱xi̱nu̱ co̱o Jesús yati ñuu Betania cán já na̱ñe̱he̱ á tu̱hun ña̱ sa̱ na̱xi̱hi̱ Lázaro ta sa̱ íin co̱mí qui̱vi̱ na̱chica̱a̱n va na da̱ ini in cáva̱.
\v 18 Mé ñuu Betania cán ñéhe táhan yati a xi̱hín Jerusalén tátu̱hun u̱ni̱ kilometro ñéhe táhan.
\v 19 Ta cua̱ha̱ táhan na̱ Israel cán na̱sa̱ha̱n na̱ ndúu tóo na xi̱hi̱n Marta xi̱hi̱n María tá quia̱hva jáya̱ha na ini na sa̱há ña̱ na̱xi̱hi̱ Lázaro quia̱hva na.
\v 20 Ta tá na̱ñe̱he̱ Marta tu̱hun ña̱ cáyati Jesús ñuu cán cua̱ha̱n já ndáva ñá na̱sa̱ha̱n ñe̱he̱ ñahá ña̱. Joo na̱cando̱o María vehe.
\v 21 Tá na̱ndique táhan Marta xi̱hín Jesús já na̱cachi ñá já xi̱hi̱n á:
\p —Xitoho, tá ná coo ndó yóho ta ni a̱ quíví toho Lázaro quia̱hva i̱, nduu.
\v 22 Joo cánda̱a̱ va̱ha ini i̱ ña̱ tá ná ca̱ca̱ ndó ña̱ cúni̱ mé ndó nu̱ Ndióxi̱ quia̱hva va mé a̱ cán ña̱ nu̱ ndo̱ —na̱cachi Marta.
\p 
\v 23 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ñá:
\p —Cande̱hé Marta. A̱ ndícani inún jáchi̱ nditacu tucu va Lázaro, quia̱hvún ja̱n —na̱cachi Jesús.
\p 
\v 24 A̱nda̱ já na̱cachi ñá já xi̱hi̱n á:
\p —Sa̱ xíni̱ vi̱ ña̱ nditacu tucu quia̱hva i̱ tá ná xi̱nu̱ co̱o qui̱vi̱ nu̱ ndíhí tá ná nditacu tócó ndihi na̱ sa̱ na̱xi̱hi̱ —na̱cachi Marta.
\p 
\v 25 Já na̱cachi Jesús já xi̱hi̱n ñá:
\p —Ye̱he̱ cúú da̱ cuu caja ña̱ ná nditacu tucu ndi̱i ta cuu caja i̱ ña̱ ná catacu ña̱yivi a̱nda̱ ama cáa qui̱vi̱. Ta ndá na̱ cándeé ini ye̱he̱ va̱tí ná quivi na catacu tá catacu na.
\v 26 Ta tócó ndihi na̱ cándeé ini ye̱he̱ catacu na a̱nda̱ ama cáa qui̱vi̱ ta a̱ ndíhi toho sa̱ha̱ ná ini indayá. Á cándúsún ña̱ cáha̱n i̱ xu̱hu̱n —na̱cachi Jesús.
\p 
\v 27 A̱nda̱ já na̱cachi Marta já xi̱hi̱n á:
\p —Cándúsa i̱ ndo̱hó ña̱ cúú ndó in túhún ji̱ni̱ já ja̱hyi Ndióxi̱ ta cándúsa i̱ ña̱ mé ndó cúú Cristo, da̱ na̱chindahá Ndióxi̱ quixi ñuyíví yóho —na̱cachi ñá xi̱hi̱n á.
\s1 Sácu Jesús sa̱ha̱ Lázaro
\p 
\v 28 Tá na̱ndihi já na̱quee Marta na̱sa̱ha̱n ñá cana ñá María qui̱hvi̱ ña̱. Ta já na̱ca̱ha̱n ya̱á ña̱ xi̱hín María já na̱cachi ñá já xi̱hi̱n ña̱:
\p —Sa̱ na̱xi̱nu̱ co̱o Jesús, xitoho í ta íin a yóho. Cuáhán nu̱ íin a jáchi̱ cána yo̱hó —na̱cachi Marta xi̱hín qui̱hvi̱ ñá.
\p 
\v 29 Tá na̱xini jo̱ho María cán ña̱ na̱cachi qui̱hvi̱ ña̱ xi̱hi̱n ña̱ chí i̱vi̱ la̱á ndáva ñá na̱sa̱ha̱n ña̱ nu̱ íin Jesús.
\v 30 Mé Jesús na̱sandati a cán yuhú ñuu, mé nu̱ú na̱ndique táhan xi̱hi̱n Marta cán.
\v 31 Ta ndaja coo mé na̱ Israel, na̱ ndúu jáya̱ha ini ñá cán tá na̱xini na na̱quee númi̱ joho ñá cua̱ha̱n ña̱ já na̱ndicui̱ta na ndíco̱ na̱ ja̱ta̱ ñá cua̱ha̱n na̱. Jáchi̱ na̱ca̱hán na̱ cua̱ha̱n ñá cuacu ñá nu̱ ndáca̱a̱n Lázaro, quia̱hva ñá.
\v 32 Ta tá na̱xi̱nu̱ co̱o ñá nu̱ íin Jesús já na̱caxítí ña̱ nu̱ á já na̱casáhá cáchí ña̱ já xi̱hi̱n á:
\p —Tá ná coo ndó yóho, nduu ta ni a̱ quíví toho Lázaro quia̱hva i̱ —na̱cachi ñá.
\p 
\v 33 Ta tá na̱xini Jesús ña̱ sácu cóhó María xi̱hín na̱ Israel, na̱ ndíco̱ na̱sa̱a̱ xi̱hi̱n ñá cán já na̱ta̱hvi̱ ndiva̱ha ini a ja̱nda̱ quia̱hva na̱ndisa̱a̱ ini a.
\v 34 A̱nda̱ já na̱nda̱ca̱ tu̱hún a̱ María cán já na̱cachi a já xi̱hi̱n ña̱:
\p —Ndájá na̱chica̱a̱n ndó da̱ já —na̱cachi Jesús.
\p —Na̱ha̱ quíi̱ ndó, xitoho i̱. Cande̱hé ndo̱ nu̱ú na̱chica̱a̱n nde̱ da̱ —na̱cachi María.
\p 
\v 35 A̱nda̱ já na̱sacu Jesús.
\v 36 Tá na̱xini na̱ Israel ña̱ yóho já na̱casáhá cáchí xi̱hi̱n táhan na já:
\p —Cande̱hé ndo̱ ndaja náha̱ na̱qui̱hvi̱ ini Jesús yóho Lázaro —na̱cachi na.
\p 
\v 37 Ta java na na̱casáhá cáchí na̱ já:
\p —Mé Jesús yóho na̱suná da̱ nduchú núú na̱ cua̱á. Á chí a̱ cu̱ú cuití caja da chindeé da̱ Lázaro já ná a̱ quíví da̱, nduu —na̱cachi java na̱ cán.
\s1 Jánditacu tucu Jesús Lázaro
\p 
\v 38 Tá na̱ndihi já na̱casáhá táhvi̱ ndiva̱ha tucu ini Jesús ta já na̱cayati a nu̱ú na̱chica̱a̱n na̱ yiquí cu̱ñu Lázaro. Mé nu̱ú ndáca̱a̱n da̱ cán na̱sa̱cuu a in ndi̱ca cáva̱ ta in yu̱u̱ jáhndá cáhnu na̱saji nuu yéhé cán.
\v 39 A̱nda̱ já na̱ndica̱ha̱n Jesús xi̱hín java na̱ ndúu cán ña̱ ná jácaxoo na yu̱u̱ ndájí nuu nu̱ ndáca̱a̱n Lázaro cán. Joo ndaja coo Marta, ña̱ cúú quia̱hva mé ndi̱i cán na̱casáhá ña̱ cáchí ña̱ já xi̱hín Jesús:
\p —Cande̱hé ndo̱, xitoho i̱. Sa̱ quini cúú sáhan ndi̱i quia̱hva i̱ ja̱n jáchi̱ sa̱ íin co̱mí qui̱ví na̱xi̱hi̱ da̱ —na̱cachi ñá.
\p 
\v 40 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ñá:
\p —Xíní ñúhú ndicu̱hu̱n inún tá na̱cachi i̱ xu̱hu̱n ña̱ tá ná candúsún Ndióxi̱ já cunún ndá quia̱hva cáhnu ña̱ha cuu caja mé á —na̱cachi Jesús.
\p 
\v 41 Tá na̱ndihi já na̱jácaxoo na yu̱u̱ cáhnu ña̱ na̱saji nuu nu̱ú na̱sa̱ndaca̱a̱n Lázaro. Já na̱ndiñehe Jesús nu̱u̱ á chí indiví já na̱cachi a já:
\p —Tátá Ndióxi̱, ndíquia̱hva i̱ ndixa̱hvi nu̱ ndo̱ jáchi̱ na̱xini jo̱ho ndó nu̱ú na̱ca̱ha̱n i̱ xi̱hi̱n ndo̱.
\v 42 Va̱tí mé a̱ nda̱a̱ cánda̱a̱ va̱ha ini i̱ ña̱ níí tiempo xíni̱ jo̱ho ndó nu̱ cáha̱n i̱ xi̱hi̱n ndo̱. Joo cáha̱n i̱ ña̱ yóho sa̱há ña̱ ná cuni jo̱ho ña̱yivi ndúu xi̱hín i̱ yóho já ná candúsa na ña̱ mé ndó na̱chindahá ndó ye̱he̱ va̱xi i̱ ñuyíví yóho —na̱cachi Jesús ndíquia̱hva ndixa̱hvi nu̱ Ndióxi̱.
\p 
\v 43 Tá na̱ndihi já na̱cayuhú cóhó a̱ já na̱cachi a já:
\p —Lázaro, cuáhán queta.
\p 
\v 44 Tá na̱ndihi já na̱queta Lázaro nu̱ú na̱sa̱ndaca̱a̱n da. Na̱ca̱va nuu ndáha̱ dá a̱nda̱ sa̱ha̱ dá xi̱hín ti̱co̱to̱ ta ndáji jáhma̱ nu̱u̱ dá na̱queta da va̱xi da. A̱nda̱ já na̱cachi Jesús xi̱hín java na̱ ndúu cán ña̱ ná ndaxí na̱ da̱ já ná quee da cu̱hu̱n da̱. Ta já na̱caja na.
\s1 Jándique táhan na̱ Israel tu̱hun na ña̱ tiin na Jesús chíca̱a̱n na̱ veca̱a
\r (Mt. 26:1-5; Mr. 14:1-2; Lc. 22:1-2)
\p 
\v 45 Ta cua̱ha̱ táhan na̱ Israel, na̱ ndáca táhan na̱sa̱ha̱n xi̱hín María cán tá na̱xini na ña̱ na̱jánditacu tucu Jesús Lázaro cán já na̱candúsa na mé á.
\v 46 Joo java táhan na̱ Israel cán ndáva na na̱sa̱ha̱n na̱ cáha̱n na̱ xi̱hín na̱ fariseo ta na̱ndicani na nu̱ ná ña̱ na̱caja Jesús.
\v 47 A̱nda̱ já na̱casáhá na̱ fariseo xi̱hín na̱ sa̱cua̱ha̱ nu̱ú ju̱tu̱ cán na̱játaca na tócó ndihi na̱ sa̱cua̱ha̱ nu̱ú na̱ Israel já na̱cachi na já xi̱hi̱n ná:
\p —Ndía̱ caja í xi̱hín Jesús viti jáchi̱ cua̱há ndiva̱ha ña̱ha xitúhún cája da̱ yóho.
\v 48 Xíní ñúhú caji nuu í nu̱ dá jáchi̱ tá ná a̱ cájí nu̱u̱ í nu̱ dá va̱xi qui̱vi̱ tá tócó ndihi ña̱yivi candeé ini na mé dá. Ta xi̱hín ña̱ yóho xi̱nu̱ ini na̱ jutixia ñuu Roma quixi na jándicani na veñu̱hu í ta jándihi na sa̱ha̱ tócó ndihi mí, na̱ Israel —na̱cachi na.
\p 
\v 49 Joo in táhan da̱ ndúu cán naní da̱ Caifás, da̱ na̱sa̱cuu da̱ sa̱cua̱ha̱ chága̱ nu̱ ndíhi ju̱tu̱ mé cui̱a̱ cán, na̱ndica̱ha̱n da̱ já na̱cachi da já:
\p —Mé ndó cúú ndó ña̱yivi co̱ xíní túni̱.
\v 50 Jáchi̱ co̱ cánda̱a̱ ini ndó ña̱ va̱ha chága̱ ña̱ ná quivi in ta̱a nu̱ ndíhi ña̱yivi já ná a̱ ndíhi sa̱ha̱ tócó ndihi ña̱yivi. Ña̱ cán quéa̱ cáhán i̱ ña̱ va̱ha chága̱ ná quivi Jesús ja̱n já ná a̱ ndíhi sa̱ha̱ mí —na̱cachi Caifás.
\p 
\v 51 Joo co̱ó na̱ca̱ha̱n Caifás ña̱ yóho sa̱há ña̱ na̱quixi a ji̱ni̱ mé dá. Ndióxi̱ quéa̱ na̱jáca̱ha̱n ínima̱ dá ña̱ cáchí da̱ já jáchi̱ mé tiempo já na̱sa̱cuu da sa̱cua̱ha̱ chága̱ nu̱ ndíhi ju̱tu̱ ta na̱jáca̱ha̱n Ndióxi̱ ínima̱ dá ña̱ ná cachi da ña̱ ndítahan quivi Jesús sa̱há na̱ Israel.
\v 52 Ta a̱ ju̱ú sa̱há in túhún na̱ Israel cuití va va̱ha jáchi̱ mé Jesús na̱nditahan quivi a sa̱ha̱ tócó ndihi na̱ cúú cuéntá Ndióxi̱, na̱ ndícui̱ta nuu ndúu ndijáá ñuyíví já ná cuu coo in ñuu.
\v 53 Chí ja̱nda̱ mé qui̱vi̱ já na̱sacu ini na̱ Israel cán cahní na̱ Jesús.
\p 
\v 54 Sa̱há ña̱ cán quéa̱ co̱ó na̱xi̱ca nuu tívi ga̱ Jesús tañu na̱ Israel cán. Ña̱ na̱caja mé á quéa̱ na̱quee a estado Judea cán já na̱sa̱ha̱n chí in ñuu naní Efraín, ña̱ íin yati xoo yucú íchí nu̱ú co̱ó ña̱yivi. Cán na̱sahi̱in a xi̱hín na̱ xíca tuun xi̱hi̱n á.
\p 
\v 55 Tá na̱cayati qui̱ví coo vicó pascua cája na̱ Israel já na̱quee cua̱há ña̱yivi ndúu ndijáá ñuu cán cua̱ha̱n na̱ chí Jerusalén jáchi̱ cúni̱ na̱ ndaja vií na̱ mé ná, ná coo tia̱hva na tá quia̱hva na̱sahnda ley Moisés nu̱ ná caja na tá cáma̱ni̱ chá qui̱ví coo vicó pascua.
\v 56 Tá na̱taca ña̱yivi ñuu Jerusalén cán na̱casáhá ndúcú na̱ Jesús. Joo nani ñúhu na veñu̱hu cáhnu cán ndáca̱ tu̱hún táhan na sa̱há Jesús já cáchí xi̱hi̱n táhan na já:
\p —Ndaja xíní ndo̱ á quixi Jesús á a̱ quíxi toho a vicó pascua yóho —na̱cachi xi̱hi̱n táhan na̱ cán.
\p 
\v 57 Ta na̱ fariseo xi̱hín na̱ sa̱cua̱ha̱ nu̱ú ju̱tu̱ na̱sahnda na chuun ña̱ ndá na̱ ná cuni Jesús já ná cu̱hu̱n na̱ ca̱xi tu̱hun na xi̱hín na̱ cán ndájá íin a jáchi̱ cúni̱ na̱ tiin na a̱ chica̱a̱n na̱ a̱ veca̱a.
\c 12
\s1 Tá na̱chojó in ñáñáha̱ perfume sa̱há Jesús
\r (Mt. 26:6-13; Mr. 14:3-9)
\p 
\v 1 Ta tá cama̱ni̱ i̱ñu̱ qui̱ví coo vicó pascua já na̱quee Jesús na̱sa̱ha̱n ñuu Betania, mé ñuu nu̱ íin Lázaro, da̱ na̱jánditacu tucu mé á cán.
\v 2 Ta cán na̱caja ndíví na̱ ña̱ cajíni Jesús jáchi̱ cúni̱ na̱ caja cáhnu na mé á. Ta mé Marta cúú ñá cája ndíví nu̱ ná. Ta Lázaro cúú in táhan da̱ íin coo nu̱ mesa xíxi xi̱hín Jesús.
\v 3 Ta ndaja coo María na̱sa̱ha̱n ñá quehe ñá tátu̱hun java litro perfume, dó ya̱hvi ndiva̱ha. Jáchi̱ cúú dó dó na̱cava̱ha xi̱hín ndinuhu yu̱cu̱ támi sáha̱n naní nardo. Na̱jácu̱yu ñá do̱ ja̱ta̱ sáha̱ Jesús. Ta tá na̱ndihi já na̱jáhi̱chi̱ ñá sa̱há xi̱hín ijí ji̱ni̱ ña̱. Ta níí ini vehe cán na̱ndicui̱ta nuu jíco̱ perfume cán.
\v 4 A̱nda̱ já na̱xini in táhan da̱ xíca tuun xi̱hín Jesús, da̱ naní Judas Iscariote cán ña̱ yóho. Mé Judas yóho cúú dá da̱ ji̱có túhún Jesús tá nu̱ ndíhí ta já cáchí da̱ já:
\p 
\v 5 —Ndá cuéntá quéa̱ co̱ó na̱caya̱hvi perfume yóho já ná cana jiu̱hún jasá yó nu̱ú na̱ nda̱hví, nduu. Jáchi̱ quia̱hva na u̱ni̱ ciento denario sa̱ha̱ dó, nduu —na̱cachi Judas cán. Ta in denario cúú ña̱ quéhe ña̱yivi cája chúun na in qui̱vi̱.
\p 
\v 6 Joo co̱ó na̱cachi Judas ña̱ yóho sa̱há ña̱ quíhvi̱ ini ndusa da na̱ nda̱hví, va̱ha. Na̱cachi da já jáchi̱ cúú dá da̱ cui̱hná ta ndáha̱ mé dá ñúhu ndihi jiu̱hún ta cája cuíhná da̱ ña̱ tá cúni̱ da̱.
\v 7 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n dá:
\p —A̱ cáhu̱n xi̱hi̱n ñá jáchi̱ na̱sacu va̱ha ñá do̱ ña̱ ná chojó ñá do̱ yiquí cu̱ñu i̱. Jáchi̱ sa̱ xíni̱ ñá ña̱ sa̱ na̱cayati qui̱ví quivi i̱.
\v 8 Ta níí tiempo canduu na̱ nda̱hví ja̱n tañu ndó ta ndá tañu cúni̱ mé ndó cuu chindeé ndó na̱. Joo ye̱he̱ a̱ cóo tuun toho i̱ xi̱hi̱n ndo̱ —na̱cachi Jesús.
\s1 Sácú ini na̱ sa̱cua̱ha̱ nu̱ú ju̱tu̱ cahní na̱ Lázaro
\p 
\v 9 Cua̱há na̱ Israel cán na̱ñe̱he̱ ná tu̱hun ña̱ íin Jesús ñuu Betania. Sa̱há ña̱ cán quéa̱ na̱sa̱ha̱n na̱ cán jáchi̱ cúni̱ na̱ cuni na Jesús ta cúni̱ na̱ cuni na Lázaro, mé da̱ na̱jánditacu tucu Jesús.
\v 10 A̱nda̱ já na̱sacu ini na̱ sa̱cua̱ha̱ nu̱ú ju̱tu̱ cán cahní ri na̱ Lázaro viti.
\v 11 Jáchi̱ sa̱ha̱ Lázaro cán cua̱há na̱ Israel na̱casáhá na̱ cándeé ini na Jesús. Ta na̱jándacoo na ndíco̱ na̱ ja̱tá na̱ sa̱cua̱ha̱ nu̱ú na̱ Israel.
\s1 Tá na̱qui̱hvi Jesús ñuu Jerusalén
\r (Mt. 21:1-11; Mr. 11:1-11; Lc. 19:28-40)
\p 
\v 12 Ta inga qui̱ví ita̱a̱n cua̱há ndiva̱ha ña̱yivi na̱xi̱nu̱ co̱o na ñuu Jerusalén nu̱ú coo vicó pascua. Ta tá na̱canda̱a̱ ini na ña̱ xínu̱ co̱o Jesús ñuu Jerusalén cán
\v 13 já na̱sa̱ha̱n na̱ na̱sahnda na ndáha̱ tó ñu̱u̱ já ndáva na na̱sa̱ha̱n na̱ na̱ñe̱he̱ ñahá na̱. Ta cáyuhú na̱ já cáchí na̱ já:
\p —Cája cáhnu í Ndióxi̱. Cáhnu na̱há ná cacuu da̱ cómí cuéntá sa̱há na̱ Israel jáchi̱ cúú dá da̱ va̱xi yuhú nu̱u̱ Ndióxi̱ —cáchí na̱.
\p 
\v 14 Na̱nditahan Jesús in búrro̱ ta na̱sanúu a ri̱ tá quia̱hva na̱cachi tu̱hun Ndióxi̱ sa̱nahá tá cáchí a̱ já:
\q1 
\v 15 A̱ cáyi̱hví toho ndó, na̱ ndúu ñuu Sión.
\q1 Cande̱hé ndó da̱ cómí cuéntá sa̱ha̱ ndó ja̱n,
\q1 cánúu da ja̱ta̱ búrro̱ loho va̱xi da, cáchí tu̱hun Ndióxi̱.
\p 
\v 16 Ta co̱ó na̱canda̱a̱ ini na̱ xíca tuun xi̱hín Jesús cán ndá cuéntá quéa̱ cája ña̱yivi já xi̱hi̱n á. Joo chága̱ chí nu̱u̱ tá sa̱ na̱ndindita Jesús cua̱ha̱n indiví já na̱canda̱a̱ ini na ña̱ quia̱hva já ndáa̱ nu̱ú tu̱hun Ndióxi̱ sa̱nahá ña̱ caja na xi̱hín Jesús.
\p 
\v 17 Mé ña̱yivi, na̱ na̱sa̱nduu xi̱hín Jesús tá na̱ca̱ha̱n xi̱hi̱n Lázaro ña̱ ná queta da nu̱ú na̱ndu̱xu̱ da̱ ña̱ nditacu da, mé na̱ cán na̱ndicani na nu̱ú java ga̱ ña̱yivi ña̱ na̱xini na na̱caja Jesús cán.
\v 18 Sa̱há ña̱ cán quéa̱ na̱queta ña̱yivi na̱sa̱ha̱n na̱ ñe̱he̱ ná Jesús jáchi̱ na̱ñe̱he̱ ná tu̱hun sa̱há ña̱ cáhnu na̱caja mé a̱ cán.
\v 19 Tá na̱xini na̱ fariseo ña̱ yóho já na̱casáhá cáchí xi̱hi̱n táhan na já:
\p —Cande̱hé ndo̱. Ndá cuu caja í quee va̱ha í xi̱hín da̱ ja̱n. Jáchi̱ tócó ndihi ña̱yivi cáti na cua̱ha̱n na̱ xi̱hín da̱ ja̱n —na̱cachi xi̱hi̱n táhan na̱ fariseo cán.
\s1 Java na̱ griego ndínducú na̱ Jesús
\p 
\v 20 Tañu ña̱yivi cua̱ha̱ na̱xi̱nu̱ co̱o cája cáhnu Ndióxi̱ víco̱ ñuu Jerusalén cán na̱xi̱nu̱ co̱o ri java na̱ na̱quixi chí ñundáhyi̱ cuéntá Grecia.
\v 21 Ta mé na̱ griego yóho na̱cayati na nu̱ Felipe, da̱ ñuu Betsaida cuéntá Galilea cán. Ta já na̱casáhá na̱ cáha̱n nda̱hví na̱ xi̱hi̱n dá já na̱cachi na já xi̱hi̱n dá:
\p —Ca̱ha̱n nde̱ xi̱hín Jesús cúni̱ nde̱ —na̱cachi na.
\p 
\v 22 A̱nda̱ já na̱quee Felipe na̱sa̱ha̱n da̱ ca̱xi tu̱hun da̱ xi̱hín Andrés ta já ndáca táhan ndíví da̱ na̱sa̱ha̱n da̱ ndícani da ña̱ nu̱ú Jesús.
\v 23 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n dá:
\p —Sa̱ na̱xi̱nu̱ co̱o va tiempo caja cáhnu Ndióxi̱ ye̱he̱, da̱ na̱chindahá mé á nduu ña̱yivi.
\v 24 Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. Tá quia̱hva ndihi sa̱ha̱ in ndiquí trigo tá ndícava ña̱ ini ñundáhyi̱ quia̱hva já ndítahan nu̱ú i̱ quivi i̱. Jáchi̱ tá ná a̱ ndíhi sa̱ha̱ ndiquí trigo cán já in já cacuu va ña̱. Joo tá ná ndihi sa̱há ña̱ cán já ndu̱ta̱ ña̱ ta já ndicua̱há ndiva̱ha ña̱.
\v 25 Ndá na̱ cátóó chága̱ cája ña̱ cúni̱ mé cuití na̱ a̱ ju̱ú ga̱ ña̱ cúni̱ Ndióxi̱, na̱ cán cúú na̱ ndihi sa̱ha̱. Joo na̱ cája ña̱ cúni̱ Ndióxi̱, na̱ cán cúú na̱ catacu a̱nda̱ ama cáa qui̱vi̱.
\v 26 Ta ndá na̱ cúni̱ caja chúun cuéntá mí i̱ ndítahan nu̱ ná candi̱co̱ na̱ ye̱he̱. Jáchi̱ nu̱ú coo ye̱he̱, cán coo ri na̱ cája ña̱ cúni̱ ye̱he̱. Ta na̱ cán cacuu na na̱ ndiñehe jícó Ndióxi̱.
\s1 Cáxi tu̱hun Jesús ña̱ quivi a
\p 
\v 27 ʼTa viti ñúhú cácuéha̱ ndiva̱ha ini i̱. Ta a̱ cu̱ú caca ta̱hví i̱ nu̱ Ndióxi̱ ña̱ ná a̱ quiáhva mé á ña̱ma̱ni̱ ndoho ini i̱ jáchi̱ sa̱há chuun yóho na̱quixi i̱ ñuyíví yóho.
\v 28 Ña̱ ndítahan cachi i̱ quéa̱: “Tátá Ndióxi̱, cáhnu ná cacuu mé ndó” —na̱cachi Jesús.
\p Tá na̱cachi Jesús ña̱ yóho, na̱ca̱ha̱n Ndióxi̱ indiví já na̱cachi a já:
\p —Sa̱ na̱ndaja cáhnu i̱ mí i̱ ta caja tucu u̱ ña̱ —na̱cachi a.
\p 
\v 29 Ta ña̱yivi ndúu cán tá na̱xini jo̱ho na ña̱ yóho já na̱cachi na ña̱ ja̱vi̱ va cána. Ta java na na̱cachi na táto̱ Ndióxi̱ quéa̱ na̱ca̱ha̱n.
\p 
\v 30 A̱nda̱ já na̱ndica̱ha̱n Jesús xi̱hi̱n ná já na̱cachi a já:
\p —A̱ ju̱ú sa̱há ye̱he̱ na̱xini jo̱ho ndó ña̱ yóho. Joo na̱catácu̱ a̱ já ná cuni jo̱ho mé ndó.
\v 31 Ta sa̱ na̱tandaa qui̱ví cavií sa̱há ña̱yivi ndúu ñuyíví ta sa̱ na̱tandaa qui̱vi̱ ndihi sa̱há ña̱ cája tiñáhá sa̱cua̱ha̱, mé rí sáhndá chuun ñuyíví yóho.
\v 32 Jáchi̱ tá ná cata caa na ye̱he̱ já caja i̱ ña̱ ná casáhá ña̱yivi níí cúú ñuyíví candeé ini na ye̱he̱ —na̱cachi Jesús.
\p 
\v 33 Xi̱hín ña̱ yóho cúni̱ mé á ndicani a nu̱ ná ña̱ quivi a ndi̱ca crúxu̱.
\v 34 A̱nda̱ já na̱cachi ña̱yivi ndúu cán já xi̱hi̱n á:
\p —Tá cáhvi nde̱ ley Moisés na̱ca̱hyi̱ sa̱nahá já cánda̱a̱ ini nde̱ ña̱ a̱nda̱ ama cáa qui̱vi̱ catacu da chindahá Ndióxi̱ cacomí cuéntá sa̱há ña̱yivi. Yo já cúú da̱ cáhu̱n sa̱ha̱. Tá ta̱ mé a̱ nda̱a̱ cúún da̱ na̱chindahá Ndióxi̱ nduu ña̱yivi, da̱ catacu a̱nda̱ ama cáa qui̱vi̱ ndá cuéntá quéa̱ cáchún quivún —na̱cachi na xi̱hín Jesús.
\p 
\v 35 Já na̱cachi Jesús já xi̱hi̱n ná:
\p —Ye̱he̱ cúú da̱ jándiye̱he̱ ínima̱ ña̱yivi ta coo tóo loho chága̱ i̱ xi̱hi̱n ndo̱. Sa̱há ña̱ cán quéa̱ xíní ñúhú caca nuu ndó nani jándiye̱he̱ íchi̱ cu̱hu̱n ndo̱ ta viti núná nu̱ ndó caja ndó ña̱. Jáchi̱ va̱xi qui̱ví quivi i̱ caja na ta a̱nda̱ já cacuu a tátu̱hun canaá yávi̱ ta já a̱ cánda̱a̱ ini ndó ndá xoo cu̱hu̱n ndo̱.
\v 36 Xíní ñúhú candeé ini ndó ye̱he̱ jáchi̱ cúú u̱ da̱ jándiye̱he̱ nu̱ ndó nani íin i̱ xi̱hi̱n ndó. A̱nda̱ jáví xi̱nu̱ co̱o ndó cacuu ndó ña̱yivi cuéntá mí i̱ —na̱cachi Jesús.
\p Tá na̱ndihi já na̱quee Jesús cua̱ha̱n chíje̱hé a̱ nu̱ ná.
\s1 Co̱ cándúsa na̱ Israel Jesús
\p 
\v 37 Va̱tí na̱caja Jesús cua̱há ña̱ xitúhún nu̱ú ña̱yivi cán joo co̱ó na̱xeen na candúsa na mé á.
\v 38 Já na̱sahi̱in jáchi̱ na̱nditahan xi̱nu̱ co̱o nu̱ú tu̱hun ña̱ na̱ca̱hyi̱ Isaías sa̱nahá cán tá na̱cachi a já:
\q1 Tátá Ndióxi̱, co̱ cúni̱ na̱ candúsa na tu̱hun ña̱ cáha̱n í xi̱hi̱n ná.
\q1 Va̱tí xíní na̱ ña̱ náhnu cája mé ndó joo co̱ cúni̱ na̱ candúsa na ndo̱hó, já na̱ca̱hyí Isaías sa̱nahá.
\m 
\v 39 Sa̱há ña̱ cán quéa̱ co̱ó na̱cuu candúsa ñahá ña̱yivi cán. Ta inga tucu tu̱hun na̱ca̱hyí Isaías quéa̱ cáchí já:
\q1 
\v 40 Mé Ndióxi̱ quéa̱ na̱jácuaá ñahá ta co̱ó na̱suná a̱ ínima̱ ná,
\q1 já ná a̱ cúu canda̱a̱ ini na yo cúú mé á,
\q1 já ná a̱ cúu ndicó co̱o na nu̱ mé á ña̱ ná ndaja va̱ha mé á na̱, na̱ca̱hyí Isaías.
\p 
\v 41 Quia̱hva já na̱ca̱ha̱n Isaías jáchi̱ na̱xini mé dá ndá quia̱hva cáhnu cúú Jesús.
\p 
\v 42 Ta cua̱ha̱ táhan na̱ Israel cán na̱candeé ini na Jesús. Ta ja̱nda̱ java na̱ sa̱cua̱ha̱ nu̱ú na̱ Israel cán na̱candeé ini na Jesús. Joo co̱ó na̱xeen na na̱ha̱ tu̱hun na sa̱há jáchi̱ na̱yi̱hví na̱ taxí na̱ fariseo cán na̱ veñu̱hu.
\v 43 Jáchi̱ cúni̱ na̱ cando̱o va̱ha chága̱ na̱ nu̱ú ña̱yivi a̱ ju̱ú ga̱ nu̱ Ndióxi̱.
\s1 Táhvi̱ ini ña̱yivi sa̱há cua̱chi na tá xíni̱ jo̱ho na nu̱ cáha̱n Jesús
\p 
\v 44 Tá na̱ndihi já na̱ca̱ha̱n cóhó Jesús já na̱cachi a já:
\p —Ndá na̱ cándeé ini ye̱he̱ já quéa̱ a̱ ju̱ú in túhún ye̱he̱ cándeé ini na, va̱ha. Jáchi̱ cándeé ini ri na̱ Ndióxi̱, tátá i̱, mé a̱ na̱chindahá ye̱he̱ va̱xi i̱ ñuyíví yóho.
\v 45 Ta ndá na̱ xíní ye̱he̱ xíní ri na mé a̱ na̱chindahá ye̱he̱ va̱xi i̱ ñuyíví.
\v 46 Ye̱he̱ na̱quixi i̱ ñuyíví yóho ña̱ ná jándiyéhe̱ ínima̱ ña̱yivi já quéa̱ ndá na̱ ná candeé ini ye̱he̱, a̱ cánduu ga̱ na̱ nu̱ú naá.
\v 47 Joo na̱ xíni̱ jo̱ho nu̱ cáha̱n i̱ ta co̱ cája na ña̱, a̱ ju̱ú toho ye̱he̱ chíca̱a̱n cua̱chi ja̱ta̱ ná. Joo tu̱hun cáha̱n i̱ quéa̱ chíca̱a̱n cua̱chi ja̱ta̱ ná. Jáchi̱ co̱ó va̱xi i̱ ñuyíví yóho chica̱a̱n i̱ cua̱chi ja̱tá ña̱yivi. Na̱quixi i̱ já ná cuu ca̱cu ndaa ínima̱ ná.
\v 48 Ndá na̱ cándají ye̱he̱ ta co̱ cúni̱ na̱ caja na ña̱ cáchí i̱ xi̱hi̱n ná, na̱ cán cúú na̱ cu̱hu̱n indayá jáchi̱ mé tu̱hun na̱ca̱ha̱n i̱ cacuu a ña̱ chíca̱a̱n cua̱chi ja̱ta̱ ná tá ná xi̱nu̱ co̱o mé qui̱ví nu̱ ndíhí cuíí.
\v 49 Jáchi̱ co̱ jána̱ha̱ i̱ ña̱ quíxi ji̱ni̱ mé cuití i̱. Tócó ndihi ña̱ cáha̱n i̱ ta tócó ndihi ña̱ jána̱ha̱ i̱ nu̱ú ña̱yivi cúú á ña̱ na̱chindahá Ndióxi̱, tátá i̱ ye̱he̱ jána̱ha̱ i̱ nu̱ ná.
\v 50 Ta cánda̱a̱ cáxí ini i̱ ña̱ tócó ndihi ña̱ jána̱ha̱ Ndióxi̱, tátá i̱ caja ña̱ ná cu̱hu̱n na̱ coo na indiví a̱nda̱ ama cáa qui̱vi̱. Ta tócó ndihi ña̱ cáha̱n i̱ xi̱hín ña̱yivi, cáha̱n i̱ ña̱ tá quia̱hva na̱sahnda Ndióxi̱, tátá i̱ nu̱ú i̱ caja i̱ —na̱cachi Jesús.
\c 13
\s1 Jándoo Jesús sa̱há na̱ xíca tuun xi̱hi̱n á
\p 
\v 1 Tácáma̱ni̱ in qui̱vi̱ coo vicó pascua já sa̱ xíni̱ Jesús ña̱ sa̱ na̱xi̱nu̱ co̱o qui̱ví quivi a jándacoo a ñuyíví yóho já ndaa mé á ndique táhan xi̱hi̱n Ndióxi̱, tátá a̱. Níí tiempo na̱qui̱hvi̱ ini Jesús tócó ndihi na̱ cúú cuéntá mé á ndúu ñuyíví yóho ta co̱ó na̱jándacoo mé á ña̱ quíhvi̱ ini a na̱.
\p 
\v 2 Ta ndaja coo íin Jesús xi̱hín na̱ xíca tuun xi̱hi̱n á xíjíni na. Jihna sa̱ na̱jáca̱ha̱n tiñáhá sa̱cua̱ha̱ Judas Iscariote, da̱ cúú ja̱hyi Simón, ña̱ ná ji̱có túhún da̱ Jesús.
\v 3 Joo sa̱ xíni̱ va̱ha Jesús ña̱ na̱sa̱ha̱n Ndióxi̱, tátá a̱ tócó ndihi ndée̱ á nu̱ mé á. Ta sa̱ xíni̱ a̱ ña̱ na̱quixi a nu̱ Ndióxi̱ ta jivi nu̱ Ndióxi̱ ndindita tucu a cu̱hu̱n a̱.
\v 4 Ta nani xíjíni na na̱nda̱ca̱ ndichi Jesús já na̱tavá a̱ cotó níhnu a ta já na̱tiin a in jáhma̱ na̱chiñee a tóco̱ á.
\v 5 Tá na̱ndihi já na̱taán a̱ ticui̱í ini in tisa̱ha̱n loho já na̱casáhá jándoo a sa̱há na̱ xíca tuun xi̱hín a̱ cán. Ta já na̱jándihi̱chi̱ a̱ sa̱ha̱ ná xi̱hi̱n jáhma̱ cáñee tóco̱ á cán.
\p 
\v 6 Ta tá na̱nditahan ndoo sa̱ha̱ Simón Pedro já na̱nda̱ca̱ tu̱hún da̱ Jesús já cáchí da̱ já:
\p —Á mé a̱ nda̱a̱ jándoo ndó sa̱há i̱, xitoho i̱ —na̱cachi da.
\p 
\v 7 Já na̱cachi Jesús já xi̱hi̱n dá:
\p —Viti ñúhú co̱ cánda̱a̱ toho inún ndía̱ quéa̱ cája i̱ yóho joo chága̱ chí nu̱u̱ já canda̱a̱ inún ndá cuéntá quéa̱ cája i̱ já —na̱cachi Jesús.
\p 
\v 8 A̱nda̱ já na̱cachi Pedro já:
\p —Chí a̱ quiáhva toho mí i̱ ña̱ma̱ní nu̱ ndó jándoo ndó sa̱há i̱ —na̱cachi da.
\p A̱nda̱ já na̱cachi Jesús já xi̱hi̱n dá:
\p —Tá ná a̱ quiáhvún ña̱ma̱ni̱ jándoo i̱ sa̱hún já a̱ cúu cacuún cuéntá mí i̱ —na̱cachi Jesús.
\p 
\v 9 A̱nda̱ já na̱cachi tucu da já xi̱hín Jesús:
\p —Tá ta̱ já cáchí ndo̱ quia̱hva va i̱ sa̱há i̱ jándoo ndó ta quia̱hva ri̱ ña̱ma̱ní jándahá ndó ye̱he̱ ta quia̱hva ri̱ ña̱ma̱ní chihin ndó ji̱ní i̱ viti —na̱cachi da.
\p 
\v 10 A̱nda̱ já na̱nducú ñehe Jesús tu̱hun nu̱ dá já na̱cachi a já xi̱hi̱n dá:
\p —Tá sa̱ na̱chichi va̱ha ña̱yivi já ndúu vií na̱ ta sa̱ha̱ cuití va ndó xíní ñúhú ndicata i̱. Mé ndó, na̱ xíca tuun xi̱hín i̱, sa̱ ndúu vií ndo̱ jáchi̱ sa̱ na̱jándoo i̱ cua̱chi ndó sa̱há ña̱ cándeé ini ndó ye̱he̱ va̱tí a̱ ju̱ú ndihi ndó ndúu vií —na̱cachi Jesús.
\p 
\v 11 Na̱cachi Jesús a̱ ju̱ú ndihi na ndúu vií jáchi̱ sa̱ na̱canda̱a̱ va ini mé á ndá da̱ cúú da̱ ji̱có túhún ñahá.
\p 
\v 12 Tá na̱ndihi na̱jándoo Jesús sa̱ha̱ ná já na̱candixi tucu a cotó níhnu a. Já na̱saco̱o tucu a nu̱ mesa já na̱cachi a já xi̱hi̱n ná:
\p —Cája i̱ cuéntá co̱ cánda̱a̱ va̱ha ini ndó ndá cuéntá quéa̱ na̱jándoo i̱ sa̱ha̱ ndo̱. Sa̱há ña̱ cán quéa̱ ndicani i̱ ña̱ nu̱ ndo̱ viti.
\v 13 Mé ndó cáchí ndo̱ maestro xi̱hín i̱ ta cáchí ndo̱ cúú u̱ xitoho ndó ta nda̱a̱ cáha̱n ndó jáchi̱ jivi ndusa i̱.
\v 14 Ta viti cande̱hé ndó. Ye̱he̱ cúú u̱ maestro ndo̱ ta cúú u̱ xitoho ndó ta na̱jándoo i̱ sa̱ha̱ ndo̱. Sa̱há ña̱ cán quéa̱ quia̱hva já ndítahan caja ndó xi̱hi̱n ndaja táhan mé ndó.
\v 15 Sa̱ na̱sacu u̱ in quia̱hva nu̱ ndo̱ ta ndítahan caja ndó tá quia̱hva na̱caja mí i̱ xi̱hi̱n ndo̱.
\v 16 Xíní ñúhú canda̱a̱ ini ndó ña̱ ni in túhún toho mozo a̱ cu̱ú cacuu da da̱ cáhnu chága̱ a̱ ju̱ú ga̱ xitoho da. Ta mé a̱ nda̱a̱ íin chága̱ sa̱há in da̱ sáhndá chuun a̱ ju̱ú ga̱ mé da̱ cua̱ha̱n caja chúun cán.
\v 17 Tá na̱canda̱a̱ ini ndó ña̱ cáha̱n i̱ xi̱hi̱n ndo̱ yóho ta tá ná caja ndó ña̱ já quéa̱ cuu caji̱i̱ ini ndó.
\p 
\v 18 ʼA̱ ju̱ú sa̱ha̱ tócó ndihi ndó cáha̱n i̱ jáchi̱ sa̱ cánda̱a̱ va̱ha ini mí i̱ ndá ndó na̱ca̱xi i̱. Joo sa̱há in ndó ndítahan xi̱nu̱ co̱o nu̱ú tu̱hun Ndióxi̱ tá na̱cachi a já: “In da̱ sáco̱o tuun xíxi xi̱hín i̱, da̱ cán cúú da̱ na̱ndicui̱ta xi̱hín i̱”, cáchí tu̱hun Ndióxi̱.
\v 19 Sa̱ cáxi tu̱hun cuéé e̱ ña̱ yóho xi̱hi̱n ndo̱ já quéa̱ tá sa̱ na̱xi̱nu̱ ña̱ yóho já candeé ini ndó ye̱he̱, ña̱ cúú u̱ da̱ cáchí i̱ cúú u̱.
\v 20 Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. Ndá na̱ ná ndiquehe va̱ha in da̱ ná chindahá i̱, cúú á tátu̱hun ndíquehe va̱ha na ye̱he̱. Ta ndá na̱ ndíquehe va̱ha ye̱he̱, ndíquehe va̱ha ri na Ndióxi̱, mé a̱ na̱chindahá ye̱he̱ quixi i̱ ñuyíví yóho —na̱cachi Jesús.
\s1 Cáxi tu̱hun Jesús ña̱ cúú Judas da̱ ji̱có túhún ñahá
\r (Mt. 26:20-25; Mr. 14:17-21; Lc. 22:21-23)
\p 
\v 21 Tá na̱ndihi na̱cachi Jesús ña̱ yóho já na̱cacuéha̱ ndiva̱ha ini a já na̱cachi a já:
\p —Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. In táhan ndó cacuu da̱ cu̱hu̱n ji̱có túhún ye̱he̱ —na̱cachi Jesús.
\p 
\v 22 Tá na̱ndihi já na̱casáhá na̱ xíca tuun xi̱hín Jesús cán sánde̱hé nu̱ táhan na. “Yo sa̱ha̱ cáha̱n Jesús”, cáhán na̱.
\v 23 Jíi̱n Jesús cán íin coo in táhan da̱ xíca tuun xi̱hi̱n á, da̱ quíhvi̱ ini mé á cán.
\v 24 Sa̱há ña̱ cán quéa̱ na̱cuu ndáha̱ Simón Pedro nu̱ dá ña̱ ná nda̱ca̱ tu̱hún da̱ mé á sa̱ha̱ ndá da̱ cúú da̱ ji̱có túhún ñahá.
\v 25 A̱nda̱ já na̱cativi chága̱ da̱ cán jíi̱n Jesús já na̱casáhá da̱ ndáca̱ tu̱hún ñahá da̱ já na̱cachi da já:
\p —Ndá da̱ cúú dá, xitoho i̱ —na̱cachi da.
\p 
\v 26 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n dá:
\p —Viti ñúhú chindaxi i̱ in túhu̱n pan ta ndá da̱ ná quia̱hva i̱ túhu̱n pan cán nu̱u̱, da̱ cán cúú dá —na̱cachi Jesús.
\p Tá na̱ndihi já na̱chindaxi a in túhu̱n pan já na̱sa̱ha̱n ña̱ nu̱ Judas Iscariote, da̱ cúú ja̱hyi Simón.
\v 27 Ta tá na̱tiin Judas pan cán chí i̱vi̱ la̱á na̱ndi̱hvi tiñáhá sa̱cua̱ha̱ ini da. Já na̱cachi Jesús já xi̱hi̱n dá:
\p —Xíní ñúhú ndihi inún cajún ña̱ na̱sacu inún cajún —na̱cachi Jesús.
\p 
\v 28 Joo ni in túhún java ga̱ na̱ ndúu coo xíxi xi̱hín Jesús cán co̱ó na̱canda̱a̱ ini na ndá cuéntá quéa̱ na̱cachi Jesús ña̱ yóho xi̱hi̱n Judas.
\v 29 Java na na̱ca̱hán na̱ ña̱ na̱sahnda Jesús chuun nu̱ Judas ña̱ ná cu̱hu̱n da̱ cueen da ña̱ha cuéntá víco̱ pascua. Ta java na na̱ca̱hán na̱ ña̱ na̱sahnda chuun nu̱ dá ña̱ ná jasá da̱ jiu̱hún nu̱ú na̱ nda̱hví jáchi̱ ndáha̱ mé dá ñúhu ndihi jiu̱hún.
\v 30 Tá na̱ndihi na̱tiin Judas pan na̱sa̱ha̱n Jesús nu̱ dá chí i̱vi̱ la̱á na̱quee da cua̱ha̱n da̱. Ta sa̱ ñuú va quéa̱ cán.
\s1 Ndítahan qui̱hvi̱ ini táhan na̱ cúú cuéntá Jesús
\p 
\v 31 Tá sa̱ na̱queta Judas cua̱ha̱n da̱ já na̱casáhá cáchí Jesús já xi̱hín na̱ xíca tuun xi̱hi̱n á:
\p —Viti ndusa quéa̱ na̱casáhá ndicáhnu ndiva̱ha ye̱he̱, da̱ na̱chindahá Ndióxi̱ nduu ña̱yivi. Ta sa̱há ña̱ caja i̱ ndicáhnu ndiva̱ha Ndióxi̱, tátá i̱.
\v 32 Ta tá náha̱ ye̱he̱ ndá quia̱hva cáhnu cúú Ndióxi̱, tátá i̱ quia̱hva já náha̱ ri Ndióxi̱ ndá quia̱hva cáhnu cúú ye̱he̱, da̱ na̱chindahá Ndióxi̱ nduu ña̱yivi. Ta ja̱ chá cáma̱ní coo tócó ndihi ña̱ yóho.
\v 33 Cande̱hé ndo̱, ja̱hyi mání i̱. Ja̱ chá cuití tiempo coo i̱ xi̱hi̱n ndo̱. A̱nda̱ já ndinducú ndó ye̱he̱ joo a̱ ndíñehe ndó ye̱he̱. Ndítahan ndicu̱hu̱n ini ndó tá na̱cachi i̱ xi̱hín na̱ Israel ña̱ a̱ cúu cu̱hu̱n na̱ nu̱ú cu̱hu̱n ye̱he̱. Quia̱hva já cáchí ri̱ xi̱hi̱n ndóhó va: A̱ cúu cu̱hu̱n ndó nu̱ú cu̱hu̱n i̱.
\v 34 Ta viti sáhndá i̱ inga chuun nu̱ ndo̱ ta cúú á ña̱ sa̱á. Ta ña̱ yóho cúú á: Ndítahan qui̱hvi̱ ini táhan ndó. Tá quia̱hva quíhvi̱ ini ye̱he̱ ndo̱hó quia̱hva já ndítahan qui̱hvi̱ ri ini táhan ndó.
\v 35 Jáchi̱ tá ná qui̱hvi̱ ini táhan ndó já canda̱a̱ ini tócó ndihi ña̱yivi ña̱ mé a̱ nda̱a̱ táhyí cúú ndó cuéntá mí i̱ —na̱cachi Jesús.
\s1 Cáxi tu̱hun Jesús ña̱ chije̱hé tu̱hun Pedro ña̱ xíni̱ da̱ mé á
\r (Mt. 26:31-35; Mr. 14:27-31; Lc. 22:31-34)
\p 
\v 36 A̱nda̱ já na̱nda̱ca̱ tu̱hún Simón Pedro cán Jesús já na̱cachi da já xi̱hi̱n á:
\p —Xitoho i̱, ndájá cu̱hu̱n ndó já —na̱cachi da.
\p A̱nda̱ já na̱cachi Jesús já xi̱hi̱n dá:
\p —A̱ cu̱ú toho cu̱hu̱n yóhó nu̱ú cu̱hu̱n i̱ viti. Joo cacuáchi̱ lohún já xi̱nu̱ co̱ún cán —na̱cachi Jesús.
\p 
\v 37 A̱nda̱ já na̱cachi Pedro já xi̱hín Jesús:
\p —Ndá cuéntá quéa̱ cáchí ndo̱ ña̱ a̱ cúu candi̱co̱ i̱ ndo̱hó cu̱hu̱n i̱ nu̱ú cu̱hu̱n ndó viti. Jáchi̱ sa̱ íin tia̱hva i̱ quivi i̱ sa̱ha̱ ndo̱ —na̱cachi Pedro.
\p 
\v 38 Já na̱nducú ñehe Jesús tu̱hun nu̱ dá já na̱cachi a já xi̱hi̱n dá:
\p —Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xu̱hu̱n. Va̱tí íin tia̱hvún quivún sa̱há i̱ joo tá cáma̱ni̱ cana chéle já u̱ni̱ tañu chije̱hé tu̱hún sa̱há i̱ ta ca̱hún ña̱ co̱ xíni̱ tohún ye̱he̱ —na̱cachi Jesús xi̱hi̱n Pedro.
\c 14
\s1 Ndáca Jesús ña̱yivi cu̱hu̱n na̱ nu̱ Ndióxi̱, tátá a̱
\p 
\v 1 Já na̱cachi tucu Jesús já:
\p —Coto a̱ ndícani ini ndó. Ndítahan candeé ini ndó Ndióxi̱ ta ndítahan candeé ini ndó ye̱he̱.
\v 2 Mé nu̱ íin Ndióxi̱, tátá i̱, cán íin cua̱há ndiva̱ha nu̱ núná nu̱ ndó canduu ndó. Tá ná a̱ cóo nu̱ú canduu ndó cán ja̱nda̱ mé sa̱ha̱ va sa̱ na̱ca̱xi tu̱hun i̱ xi̱hi̱n ndó, nduu. Ta cu̱hu̱n i̱ cacu tia̱hva i̱ mé nu̱ú canduu ndó cán.
\v 3 Tá sa̱ ná quee e̱ cu̱hu̱n i̱ ta tá sa̱ ná caja ndíví i̱ nu̱ú canduu ndó cán já quixi tucu u̱ ndiquehe e̱ ndo̱hó já ná cu̱hu̱n ndó canduu ndó xi̱hín i̱ mé nu̱ú coo i̱ cán.
\v 4 Mé ndó sa̱ xíni̱ ndó ndá íchi̱ candi̱co̱ ndó já cuu sa̱a̱ ndó nu̱ú cu̱hu̱n i̱ —na̱cachi Jesús xi̱hín na̱ xíca tuun xi̱hín a̱ cán.
\p 
\v 5 A̱nda̱ já na̱ndica̱ha̱n Tomás xi̱hín Jesús já na̱cachi da já xi̱hi̱n á:
\p —Mé nde̱ co̱ xíni̱ toho nde̱ ndájá cu̱hu̱n ndo̱, xitoho nde̱. Ndaja caja ri nde̱ canda̱a̱ ini nde̱ ndá íchi̱ quehe nde̱ cu̱hu̱n nde̱ —na̱cachi da xi̱hi̱n á.
\p 
\v 6 Já na̱nducú ñehe Jesús tu̱hun nu̱ dá já na̱cachi a já xi̱hi̱n dá:
\p —Ye̱he̱ cúú tátu̱hun íchi̱ ña̱ ndítahan candi̱co̱ ña̱yivi ta ye̱he̱ cúú da̱ jána̱ha̱ ña̱ nda̱a̱. Ta ye̱he̱ cúú da̱ cája ña̱ ná catacu ña̱yivi a̱nda̱ ama cáa qui̱vi̱. Ta in túhún ye̱he̱ ndítahan candeé ini ña̱yivi já ná cuu xi̱nu̱ co̱o na nu̱ Ndióxi̱, tátá i̱.
\v 7 Tá xíni̱ ndó yo cúú ye̱he̱ já xíni̱ ri ndó yo cúú Ndióxi̱, tátá i̱. Ta viti xi̱hi̱n chí nu̱u̱ xíni̱ ndó a̱ jáchi̱ sa̱ na̱xini ndó a̱ —na̱cachi Jesús.
\p 
\v 8 A̱nda̱ já na̱cachi Felipe já xi̱hín Jesús:
\p —Xitoho nde̱, jána̱ha̱ ndó nu̱ú nde̱ yo cúú tátá ndo̱ já ná caji̱i̱ ini nde̱ —na̱cachi da.
\p 
\v 9 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n dá:
\p —Ndá cuéntá quéa̱ cáchún já jáchi̱ ja̱nda̱ jihna ndiva̱ha va íin i̱ xi̱hi̱n ndo̱ ta sa̱ ndítahan canda̱a̱ ini ndó yo cúú ye̱he̱. Jáchi̱ ndá na̱ sa̱ xíni̱ yo cúú ye̱he̱ xíni̱ ri na yo̱ cúú Ndióxi̱, tátá i̱. Sa̱há ña̱ cán quéa̱ ndá cuéntá quéa̱ cúni̱ ndó ña̱ ná jána̱ha̱ i̱ tátá i̱ nu̱ ndo̱.
\v 10 Xíní ñúhú candúsa ndó ña̱ in cúú va ye̱he̱ xi̱hi̱n Ndióxi̱, tátá i̱ ta in cúú va mé á xi̱hín i̱. Tócó ndihi ña̱ cáha̱n i̱ xi̱hi̱n ndo̱ yóho co̱ cáha̱n i̱ ña̱ sa̱há ña̱ quíxi a ji̱ni̱ mé cuití vi̱. Cáha̱n i̱ ña̱ quixi nu̱ Ndióxi̱ jáchi̱ íin mé á xi̱hín i̱. Ta chuun cája i̱ quixi a nu̱ Ndióxi̱ jáchi̱ cája chúun mé á.
\v 11 Xíní ñúhú candúsa ndó ña̱ in cúú ye̱he̱ xi̱hi̱n Ndióxi̱, tátá i̱ ta in cúú Ndióxi̱, tátá i̱ xi̱hín i̱. Ta tá co̱ cúni̱ ndó candúsa ndó ña̱ já quéa̱ xíní ñúhú candúsa ndó ña̱ sa̱há ña̱ náhnu na̱xini ndó na̱caja i̱.
\v 12 Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. Ndá na̱ cándeé ini ye̱he̱, cuu caja na ña xitúhún tátu̱hun ña̱ cája mí i̱. Ta ja̱nda̱ ña̱ náhnu chága̱ cuu caja na jáchi̱ cu̱hu̱n i̱ nu̱ íin Ndióxi̱, tátá i̱.
\v 13 Ta tócó ndihi ña̱ ca̱ca̱ ndó nu̱ Ndióxi̱, xíní ñúhú ca̱ca̱ ndó ña̱ xi̱hín qui̱vi̱ mí i̱ já ná caja i̱ ña̱. Ta ndicáhnu Ndióxi̱, tátá i̱ xi̱hín ña̱ caja i̱ sa̱ha̱ ndo̱.
\v 14 Ta caja i̱ ndá ña̱ ná ca̱ca̱ ndo̱ nu̱ú i̱ tá ná ca̱ca̱ ndó ña̱ xi̱hín qui̱vi̱ mí i̱.
\s1 Sáhan Jesús tu̱hun a ña̱ chindahá a̱ ínima̱ yi̱i̱ Ndióxi̱ cañuhu a ini ña̱yivi
\p 
\v 15 ʼTá mé a̱ nda̱a̱ quíhvi̱ ini ndó ye̱he̱, caja tá caja ndó ña̱ sáhndá i̱ nu̱ ndo̱ caja ndó.
\v 16 Ta ca̱ca̱ i̱ nu̱ Ndióxi̱, tátá i̱ ña̱ ná chindahá mé á ínima̱ yi̱i̱ mé á nu̱ ndo̱. Ta chíndeé mé á ndo̱hó já ná quia̱hva tu̱hun ndéé ini ndó ta já cuu coo tuun a xi̱hi̱n ndo̱.
\v 17 Joo ña̱yivi, na̱ co̱ cúú cuéntá mí i̱, a̱ cúu ndiquehe na ña̱ jáchi̱ co̱ cánda̱a̱ ini na yo cúú mé á ta ni co̱ cúni̱ na̱ ndiquehe va̱ha na ña̱. Joo ndóhó xíni̱ va̱ha ndó a̱ jáchi̱ sa̱ íin a xi̱hi̱n ndo̱ ta níí tiempo cañuhu a ini ndó.
\v 18 A̱ jándacoo ndáha̱ toho i̱ ndo̱hó jáchi̱ ndicó co̱o tucu u̱ já coo i̱ xi̱hi̱n ndo̱.
\v 19 Ja̱ chá cuití ta a̱ cúní ga̱ ña̱yivi cuéntá ñuyíví ye̱he̱. Joo mé ndó cuni tá cuni ndó ye̱he̱. Ta sa̱há ña̱ nditacu tucu u̱ sa̱há ña̱ cán quéa̱ cuu catacu mé ndó a̱nda̱ ama cáa qui̱vi̱.
\v 20 Ta mé qui̱vi̱ cán canda̱a̱ ini ndó ña̱ mé a̱ nda̱a̱ in cúú ye̱he̱ xi̱hi̱n Ndióxi̱, tátá i̱. Ta canda̱a̱ ini ndó ña̱ quia̱hva já in cúú ndó xi̱hín i̱ ta in cúú ye̱he̱ xi̱hi̱n mé ndó viti.
\v 21 Ndá na̱ ndíquehe va̱ha tu̱hun cáha̱n i̱ ta cája na ña̱, náha̱ na̱ xi̱hín ña̱ yóho ña̱ mé a̱ nda̱a̱ quíhvi̱ ini na ye̱he̱. Ta mé Ndióxi̱, tátá i̱ quíhvi̱ ini a ndijáá na̱ quíhvi̱ ini ye̱he̱. Ta quíhvi̱ ri ini ye̱he̱ na̱ ta na̱ha̱ i̱ mí i̱ nu̱ ná —na̱cachi Jesús.
\p 
\v 22 A̱nda̱ já in da̱ naní Judas, da̱ co̱ cúú toho da̱ naní Judas Iscariote, na̱nda̱ca̱ tu̱hún da̱ Jesús já na̱cachi da já xi̱hi̱n á:
\p —Xitoho nde̱, ndá cuéntá quéa̱ cáchí ndó ña̱ na̱ha̱ ndó mé ndó nu̱ú nde̱ joo a̱ náha̱ toho ndó mé ndó nu̱ú ña̱yivi cuéntá ñuyíví —na̱cachi da.
\p 
\v 23 Já na̱nducú ñehe Jesús tu̱hun nu̱ dá já na̱cachi a já xi̱hi̱n dá:
\p —Ndá na̱ quíhvi̱ ini ye̱he̱, na̱ cán cúú na̱ cája ña̱ cáha̱n i̱. Ta já quíhvi̱ ini Ndióxi̱, tátá i̱ na̱ ta já quixi nde̱ coo nde̱ xi̱hi̱n ná.
\v 24 Joo na̱ co̱ quíhvi̱ ini ye̱he̱, na̱ cán cúú na̱ quéhe núu tu̱hun cáha̱n i̱. Ta mé tu̱hun cáha̱n i̱ nu̱ ndó yóho co̱ cúú á ña̱ quíxi ji̱ni̱ mí i̱. Cúú á tu̱hun Ndióxi̱, tátá i̱, mé a̱ na̱chindahá ye̱he̱ quixi i̱ ñuyíví yóho.
\p 
\v 25 ʼTócó ndihi ña̱ yóho ndícani i̱ ña̱ nu̱ ndó viti nani íin i̱ xi̱hi̱n ndo̱.
\v 26 Joo ínima̱ yi̱i̱ Ndióxi̱, mé a̱ chindahá Ndióxi̱ yuhú nu̱ú i̱ quixi a, chindeé a̱ ndo̱hó. Mé a̱ cán quéa̱ jána̱ha̱ tócó ndihi ña̱ha nu̱ ndo̱. Ta jándicu̱hu̱n a̱ ini ndó tócó ndihi ña̱ na̱cachi i̱ xi̱hi̱n ndo̱.
\p 
\v 27 ʼTá sa̱ ná quee e̱ cu̱hu̱n i̱ já caja i̱ ña̱ ná coo va̱ha ini ndó. Joo a̱ cácuu a tátu̱hun tá cája ña̱yivi cuéntá ñuyíví. “Ná coo va̱ha ini ndó”, cáchí xi̱hi̱n táhan na joo co̱ íin va̱ha ini xi̱hi̱n táhan na. Coto a̱ ndícani na̱há ini ndó ta coto a̱ yíhví ndo̱ jáchi̱ caja i̱ ña̱ ná coo va̱ha ini ndó.
\v 28 Sa̱ na̱xini jo̱ho ndó ña̱ na̱cachi i̱ xi̱hi̱n ndo̱ ña̱ quee e̱ cu̱hu̱n i̱ ta ndicó co̱o tucu u̱ já coo i̱ xi̱hi̱n ndo̱. Ta tá mé a̱ nda̱a̱ quíhvi̱ ndusa ini ndó ye̱he̱ já quéa̱ caji̱i̱ ini ndó sa̱há ña̱ cáchí i̱ cu̱hu̱n i̱ nu̱ íin Ndióxi̱, tátá i̱. Ta íin chága̱ sa̱ha̱ mé á a̱ ju̱ú ga̱ ye̱he̱.
\v 29 Sa̱ ndícani cuéé vi̱ ña̱ yóho nu̱ ndo̱ já quéa̱ tá ná xi̱nu̱ co̱o ña̱ cáchí i̱ xi̱hi̱n ndo̱ coo já quéa̱ cuu candúsa ndó ye̱he̱.
\p 
\v 30 ʼJa̱ chá cuití va coo i̱ ñuyíví yóho nditúhún i̱ xi̱hi̱n ndo̱ jáchi̱ sa̱ na̱tandaa hora xi̱nu̱ rí quini, rí cómí cuéntá sa̱há ña̱yivi ñuyíví yóho va̱tí mé a̱ nda̱a̱ co̱ ndée̱ rí caja rí ni in ña̱ha xi̱hín i̱.
\v 31 Joo ya̱ha tá ya̱ha ña̱ cúni̱ ri̱ caja rí xi̱hín i̱. Ta xi̱hín ña̱ yóho canda̱a̱ ini ña̱yivi ndúu ñuyíví ña̱ mé a̱ nda̱a̱ quíhvi̱ ini ndusa i̱ Ndióxi̱, tátá i̱ ta cája i̱ ña̱ na̱sahnda mé á nu̱ú i̱ caja i̱. Candichi ndó. Xíhín ndo̱ ná co̱ho̱ —na̱cachi Jesús xi̱hín na̱ xíca tuun xi̱hín a̱ cán.
\c 15
\s1 Jesús cúú á tátu̱hun in tó uva
\p 
\v 1 A̱nda̱ já na̱cachi tucu Jesús já xi̱hi̱n ná:
\p —Ye̱he̱ cúú ndusa tátu̱hun in tó uva ta Ndióxi̱, tátá i̱ cúú á tátu̱hun da̱ ndája vií sa̱ha̱ mé tó uva cán.
\v 2 Ta ña̱yivi cúú ná tátu̱hun ndáha̱ tó uva cán. Ta ndá na̱ co̱ xe̱én caja ña̱ cúni̱ Ndióxi̱ jácaxoo a na̱ nu̱ mé á tá quia̱hva cája da̱ ndája vií dó cán tá chítúhu̱n dá ndáha̱ tó uva, ña̱ co̱ cána uva nu̱u̱. Joo tá cána cua̱ha̱ uva nu̱ do̱ já quéa̱ ndája vií da̱ ndáha̱ do̱ ta ndíja̱tá da̱ do̱ já ná cana cua̱ha̱ chága̱ uva nu̱ do̱. Quia̱hva já cája ri Ndióxi̱ xi̱hín ña̱yivi, na̱ cája ña̱ cúni̱ mé á.
\v 3 Joo mé ndó sa̱ na̱ndivií va ndó jáchi̱ na̱xini jo̱ho ndó ña̱ jána̱ha̱ i̱ nu̱ ndo̱.
\v 4 Xíní ñúhú in cacuu ndó xi̱hín i̱ tá quia̱hva in cúú ye̱he̱ xi̱hi̱n ndo̱. Jáchi̱ in ndáha̱ tó uva a̱ cu̱ú cana uva nu̱ do̱ tá co̱ tíin dó tóco̱ tó uva cán. Quia̱hva já íin ri xi̱hi̱n ndóhó va. A̱ cúu caja ndó ña̱ cúni̱ Ndióxi̱ tá co̱ó in cúú ndó xi̱hín i̱.
\p 
\v 5 ʼYe̱he̱ cúú u̱ tátu̱hun tó uva ta ndóhó cúú ndó tátu̱hun ndáha̱ mé tó uva cán. Ta ndá na̱ in cúú xi̱hín i̱ tá quia̱hva in cúú u̱ xi̱hi̱n ná já quéa̱ cuu caja ndihi na ña̱ cúni̱ Ndióxi̱. Cacuu a tátu̱hun cána cua̱ha̱ uva va̱ha nu̱ ndáha̱ tó uva cán. Jáchi̱ mé a̱ nda̱a̱ ni in túhún ña̱ha a̱ cúu caja ndó tá ná a̱ chíndeé ye̱he̱ ndo̱hó.
\v 6 Ta ndá na̱ co̱ cúni̱ in cacuu xi̱hín i̱, na̱ cán cúú na̱ jácaxoo Ndióxi̱. Ta cúú ná tátu̱hun in ndáha̱ tó uva, dó sa̱ na̱hi̱chi̱ ta nditaca dó cu̱hu̱n dó ca̱yi̱ do̱.
\p 
\v 7 ʼTá in ná cacuu ndó xi̱hín i̱ ta tá ná caja ndó ña̱ na̱jána̱ha̱ i̱ nu̱ ndo̱ já cuu ca̱ca̱ ndó ndá ña̱ cúni̱ mé ndó nu̱ú i̱ já quia̱hva i̱ ña̱ nu̱ ndo̱.
\v 8 Mé Ndióxi̱, tátá i̱ ndicáhnu ndiva̱ha tá ná caja ndó ña̱ cúni̱ a̱ xi̱hi̱n ndinuhu ini ndó. Ta xi̱hín ña̱ yóho náha̱ ndó ña̱ cúú ndó cuéntá mí i̱.
\v 9 Quíhvi̱ ini i̱ ndo̱hó tá quia̱hva quíhvi̱ ini Ndióxi̱, tátá i̱ ye̱he̱. Xíní ñúhú coo tuun ndó xi̱hín i̱ jáchi̱ quíhvi̱ ini i̱ ndo̱hó.
\v 10 Tá ná caja ndó tócó ndihi ña̱ sáhndá i̱ nu̱ ndo̱ caja ndó já quéa̱ coo tuun ndó xi̱hín i̱ jáchi̱ quíhvi̱ ini i̱ ndo̱hó. Quia̱hva já cája ri ye̱he̱ va. Cája i̱ tócó ndihi ña̱ na̱sahnda Ndióxi̱, tátá i̱ caja i̱ ta xi̱hín ña̱ yóho íin tuun i̱ xi̱hi̱n á jáchi̱ quíhvi̱ ini a ye̱he̱.
\p 
\v 11 ʼCáxi tu̱hun i̱ ña̱ yóho xi̱hi̱n ndo̱ já ná caji̱i̱ íní ndo̱ tá quia̱hva cáji̱i̱ íní ye̱he̱. Ta xi̱hín ña̱ yóho ndicutú nda̱a̱ ínima̱ ndo̱ xi̱hín ña̱ cáji̱i̱ ini ndó.
\v 12 Cuni jo̱ho ndó ña̱ sáhndá i̱ nu̱ ndo̱ yóho: Ndítahan qui̱hvi̱ ini táhan ndó tá quia̱hva quíhvi̱ ini ye̱he̱ ndo̱hó.
\v 13 Tá mé a̱ nda̱a̱ táhyí quíhvi̱ ini ña̱yivi ñani táhan na já quéa̱ íin tia̱hva na quivi na sa̱ha̱ ná.
\v 14 Mé ndó cúú ndó amigo i̱ tá cája ndó ña̱ sáhndá i̱ nu̱ ndó caja ndó.
\v 15 Cáchí i̱ xi̱hi̱n ndo̱ ña̱ cúú ndó amigo i̱ jáchi̱ cáxi tu̱hun ndihi i̱ xi̱hi̱n ndo̱ ña̱ cáha̱n Ndióxi̱, tátá i̱ xi̱hín i̱. Ta a̱ cáha̱n ga̱ i̱ xi̱hi̱n ndo̱ ña̱ cúú ndó mozo jáchi̱ in mozo co̱ xíni̱ toho da ndaja cáa ña̱ cája xitoho da.
\v 16 Mé ndó co̱ó na̱ca̱xi ndó ye̱he̱ caca nuu i̱ xi̱hi̱n ndo̱. Joo mí i̱ na̱ca̱xi i̱ ndo̱hó ña̱ ná caca nuu ndó xi̱hín i̱. Ta na̱jána̱ha̱ i̱ ndo̱hó ndá quia̱hva caja ndó já ná cacuu ndó tátu̱hun in yíto̱, dó sáhan cua̱há cui̱hi ña̱ a̱ ndíhi sa̱ha̱. Tá ná caja ndó ña̱ cúni̱ Ndióxi̱ já quia̱hva tátá i̱ ndá a̱ cúni̱ mé ndó tá ná ca̱ca̱ ndó ña̱ xi̱hín qui̱vi̱ mí i̱.
\v 17 Ña̱ yóho quéa̱ sáhndá i̱ nu̱ ndó caja ndó: Qui̱hvi̱ ini táhan ndó.
\s1 Cándají ña̱yivi cuéntá ñuyíví Jesús ta cándají ri na na̱ cúú cuéntá mé á
\p 
\v 18 ʼCande̱hé ndo̱. Tá ná casáhá candají ña̱yivi cuéntá ñuyíví ndo̱hó xíní ñúhú ndicu̱hu̱n ini ndó ña̱ jihna ñúhú ga̱ na̱candají ri na̱ ye̱he̱ va.
\v 19 Tá ná caja ndó tá quia̱hva cája ña̱yivi ñuyíví já quéa̱ qui̱hvi̱ ini va na̱ cán ndo̱hó. Jáchi̱ já cája xi̱hi̱n táhan mé na̱ cán. Joo ye̱he̱ na̱ca̱xi i̱ ndo̱hó ña̱ ná quee ndó tañu na̱ cán. Sa̱há ña̱ cán quéa̱ co̱ cúni̱ na̱ cán ndo̱hó jáchi̱ co̱ cúú ga̱ ndó na̱ ñuyíví yóho.
\v 20 Coto a̱ ndíndójó ndo̱ ña̱ na̱ca̱ha̱n i̱ xi̱hi̱n ndo̱ tá na̱cachi i̱ ña̱ ni in túhún toho mozo a̱ cúu cacuu da da̱ cáhnu chága̱ nu̱ú xitoho da. Ta ni mé ndó co̱ cúú ndó na̱ náhnu chága̱ a̱ ju̱ú ga̱ ye̱he̱. Jáchi̱ tá quia̱hva na̱caja xíxi na xi̱hín ye̱he̱ quia̱hva já caja xíxi ri na xi̱hi̱n ndóhó va. Tá ná candúsa na ña̱ na̱ca̱ha̱n i̱ xi̱hi̱n ná quia̱hva já candúsa ri na ña̱ ná ca̱ha̱n ri ndóhó va xi̱hi̱n ná.
\v 21 Tócó ndihi ña̱ yóho caja na xi̱hi̱n ndo̱ sa̱há ña̱ cándeé ini ndó ye̱he̱. Jáchi̱ co̱ xíni̱ na̱ Ndióxi̱, tátá i̱, mé a̱ na̱chindahá ye̱he̱ va̱xi i̱ ñuyíví yóho.
\p 
\v 22 ʼTá ná a̱ quíxi toho i̱ ñuyíví yóho ca̱xi tu̱hun i̱ xi̱hín ña̱yivi, nduu co̱ó toho na̱ jácojo cua̱chi ja̱ta̱ ná, nduu. Joo viti na̱quixi i̱ ñuyíví yóho ta ndítahan nu̱ ná ndiquia̱hva na cuéntá sa̱há cua̱chi na.
\v 23 Ndá ña̱yivi cándají ye̱he̱, cándají ri na Ndióxi̱, tátá i̱.
\v 24 Na̱caja i̱ ña̱ náhnu nu̱ ná joo co̱ó na̱candúsa na ye̱he̱ sa̱há ña̱ cán quéa̱ ndójo na cua̱chi. Ta ni in túhún toho ña̱yivi co̱ó na̱caja ña̱ náhnu tá quia̱hva na̱caja i̱ nu̱ ná. Va̱tí na̱xini na ña̱ náhnu na̱caja i̱ joo cándají na̱ ye̱he̱ ta cándají na̱ Ndióxi̱, tátá i̱.
\v 25 Joo xi̱hi̱n tócó ndihi ña̱ cúu yóho xínu̱ co̱o nu̱ ley na̱jándacoo Moisés nu̱ ná sa̱nahá tá cáchí a̱ já: “Chí co̱ó sa̱ha̱ ná candají na̱ ye̱he̱”, já na̱cachi Moisés sa̱nahá.
\p 
\v 26 ʼTá ná quixi ínima̱ yi̱i̱ Ndióxi̱, mé a̱ chindahá i̱ cuéntá Ndióxi̱, tátá i̱, mé a̱ cán quéa̱ ca̱ha̱n va̱ha sa̱há i̱. Ta jána̱ha̱ ña̱ nda̱a̱ sa̱ha̱ Ndióxi̱ ta chindeé a̱ ña̱yivi.
\v 27 Ta jári mé ndó ca̱ha̱n va̱ha ndó sa̱há i̱ jáchi̱ ja̱nda̱ sa̱ha̱ tá na̱casáhá cája chúun i̱ ñuyíví yóho na̱sa̱nduu tuun ndó xi̱hín i̱ —na̱cachi Jesús.
\c 16
\p 
\v 1 Já na̱cachi tucu Jesús já:
\p —Ca̱xi tu̱hun i̱ ña̱ yóho xi̱hi̱n ndó já ná a̱ jándacoo ndó ña̱ cándeé ini ndó ye̱he̱.
\v 2 Jáchi̱ va̱xi qui̱ví tá taxí ña̱yivi ndo̱hó veñu̱hu. Ta ndá na̱ ná cahní ndo̱hó ca̱hán na̱ ña̱ cája chúun na cuéntá Ndióxi̱.
\v 3 Caja na ña̱ yóho jáchi̱ co̱ xíni̱ na̱ yo cúú Ndióxi̱, tátá i̱ ta ni co̱ xíni̱ na̱ ye̱he̱.
\v 4 Sa̱ cáxi tu̱hun cuéé e̱ ña̱ yóho xi̱hi̱n ndo̱ já quéa̱ tá ná xi̱nu̱ co̱o qui̱vi̱ cán já ndicu̱hu̱n ini ndó ña̱ sa̱ na̱ca̱xi tu̱hun ya̱chi̱ vi̱ xi̱hi̱n ndo̱ ña̱ já coo.
\s1 Ña̱ cája ínima̱ yi̱i̱ Ndióxi̱
\p ʼCo̱ó na̱ca̱xi tu̱hun i̱ ña̱ yóho xi̱hi̱n ndó jihna jáchi̱ na̱sahi̱in i̱ xi̱hi̱n ndo̱.
\v 5 Ja̱ chá cu̱hu̱n i̱ coo i̱ xi̱hi̱n Ndióxi̱, tátá i̱, mé a̱ na̱chindahá ye̱he̱ ñuyíví yóho joo ni in ndó co̱ ndáca̱ tu̱hún ndó ye̱he̱ ndájá cu̱hu̱n i̱.
\v 6 Ña̱ cája ndó quéa̱ cácuéha̱ ndiva̱ha ini ndó sa̱há ña̱ ndícani i̱ tócó ndihi ña̱ yóho nu̱ ndo̱.
\v 7 Joo mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱: Va̱ha chága̱ ná quee e̱ cu̱hu̱n i̱. Jáchi̱ tá ná a̱ quée ye̱he̱ cu̱hu̱n i̱ já a̱ cúu quixi ínima̱ yi̱i̱ Ndióxi̱ coo a xi̱hi̱n ndo̱ ta mé a̱ cán chindeé a̱ ndo̱hó. Joo tá ná quee e̱ cu̱hu̱n i̱ já chindahá i̱ mé á quixi a nu̱ ndo̱.
\v 8 Ta tá ná xi̱nu̱ a̱ cán jána̱ha̱ cáxí táhyí a̱ nu̱ú ña̱yivi ña̱ cája na cua̱chi. Ta jána̱ha̱ nu̱ ná ndaja íin íchi̱ cuéntá ña̱ nda̱a̱. Ta jána̱ha̱ nu̱ ná ndá quia̱hva cavií sa̱há ña̱yivi caja Ndióxi̱.
\v 9 Ta jána̱ha̱ cáxí táhyí a̱ ña̱ íin cua̱chi na jáchi̱ co̱ cándeé ini na ye̱he̱.
\v 10 Ta jána̱ha̱ ínima̱ yi̱i̱ Ndióxi̱ ndaja íin íchi̱ cuéntá ña̱ nda̱a̱ jáchi̱ quee e̱ cu̱hu̱n i̱ nu̱ íin Ndióxi̱, tátá i̱ ta a̱ cúní ga̱ ndó ye̱he̱.
\v 11 Ta jána̱ha̱ cáxí táhyí a̱ ña̱ caja vií Ndióxi̱ sa̱há cua̱chi jáchi̱ sa̱ na̱caja vií a̱ sa̱há tiñáhá sa̱cua̱ha̱ va̱tí viti ñúhú cómí rí cuéntá sa̱há ña̱yivi ñuyíví yóho.
\p 
\v 12 ʼÍin cua̱há ndiva̱ha ña̱ha cúni̱ ca̱ha̱n chága̱ i̱ xi̱hi̱n ndo̱. Joo va̱ti̱ já va viti jáchi̱ a̱ cándo̱o ga̱ ji̱ni̱ ndo̱.
\v 13 Tá ná xi̱nu̱ ínima̱ yi̱i̱ Ndióxi̱, mé a̱ cúú ña̱ nda̱a̱, mé a̱ cán candaca ndo̱hó íchi̱ cuéntá ña̱ nda̱a̱. Ta a̱ cáha̱n toho a cán ña̱ quixi ji̱ni̱ mé á jáchi̱ ca̱ha̱n mé á ña̱ xíni̱ jo̱ho a cáha̱n Ndióxi̱. Ta ca̱xi tu̱hun a xi̱hi̱n ndo̱ ndá a̱ coo chága̱ chí nu̱u̱.
\v 14 Ta mé a̱ cán caja cáhnu a ye̱he̱ jáchi̱ jána̱ha̱ nu̱ ndó ña̱ cúni̱ mí i̱ jána̱ha̱ i̱ nu̱ ndo̱.
\v 15 Tócó ndihi ña̱ha jána̱ha̱ Ndióxi̱, tátá i̱ cúú ri a ña̱ jána̱ha̱ ye̱he̱ va. Sa̱há ña̱ cán quéa̱ cáchí i̱ xi̱hi̱n ndó ña̱ ínima̱ yi̱i̱ mé á ca̱xi tu̱hun a xi̱hi̱n ndó ña̱ cúni̱ mí i̱ jána̱ha̱ i̱ nu̱ ndo̱.
\p 
\v 16 ʼJa̱ chá cuití coo i̱ xi̱hi̱n ndo̱ ta a̱ cúní ga̱ ndó ye̱he̱ jáchi̱ quee e̱ cu̱hu̱n i̱ nu̱ íin Ndióxi̱, tátá i̱. Joo tá na̱ndihi já cuni tucu ndó ye̱he̱ —cáchí Jesús.
\p 
\v 17 A̱nda̱ já na̱casáhá java na̱ xíca tuun xi̱hi̱n á cán ndáca̱ tu̱hún táhan na já cáchí xi̱hi̱n táhan na já:
\p —Ndía̱ cúni̱ ri Jesús cachi a xo̱ho̱ tá cáchí a̱ ña̱ ja̱ chá cuití va ta a̱ cúní ga̱ í mé á ta tá na̱ndihi já cuni tucú mé á. Ta cáchí a̱ ña̱ cúú á sa̱há ña̱ quee a cu̱hu̱n a̱ nu̱ íin Ndióxi̱, tátá a̱.
\v 18 Ndía̱ cúni̱ ri a cachi a ña̱ ja̱ chá cuití va cuní mé á. Co̱ cánda̱a̱ va̱ha toho iní ndía̱ cúni̱ mé á cachi a xi̱hín tu̱hun yóho —na̱cachi xi̱hi̱n táhan na.
\p 
\v 19 Joo na̱canda̱a̱ ini Jesús ña̱ cúni̱ na̱ nda̱ca̱ tu̱hún na̱ mé á sa̱há ña̱ cán quéa̱ na̱cachi a já xi̱hi̱n ná:
\p —Na̱cachi i̱ xi̱hi̱n ndó ña̱ ja̱ chá cuití ta a̱ cúní ga̱ ndó ye̱he̱ ta tá na̱ndihi já cuni tucu ndó ye̱he̱. Ta viti cúni̱ ndo̱ nda̱ca̱ tu̱hún ndó ye̱he̱ ndía̱ cúni̱ cachi ña̱ yóho.
\v 20 Mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xi̱hi̱n ndo̱. Tandaa qui̱vi̱ cuacu ndó ta cacuéha̱ ndiva̱ha ini ndó ta ña̱yivi ñuyíví yóho cavatá ndiva̱ha na sa̱há ña̱ ndoho i̱. Ta va̱tí cacuéha̱ ini ndó joo in cuití ndaja̱ma ña̱ ja̱n ta já caji̱i̱ ndiva̱ha ini ndó.
\v 21 Cacuu a tátu̱hun tá xínu̱ co̱o hora cacu ja̱hyi in ñáñáha̱ ta já casáhá ndóho ini ñá. Joo tá sa̱ na̱cacu ja̱hyi ñá ndíndójó ndihi ñá sa̱há ña̱ na̱ndoho ini ñá jáchi̱ sa̱ na̱cacu ja̱hyi ñá ta cáji̱i̱ ndiva̱ha ini ñá xi̱hi̱n á.
\v 22 Quia̱hva já ndóho ini ndó xi̱hín ña̱ táhnda̱ ini ndó viti. Joo ndicó co̱o tucu ye̱he̱ já cuni táhan tucú ta já ndicutú nda̱a̱ ínima̱ ndó xi̱hín ña̱ cáji̱i̱ íní ndo̱. Ta ni in na a̱ cúu caja caji nuu nu̱ú ña̱ cáji̱i̱ íní ndó ja̱n.
\p 
\v 23 ʼMé qui̱vi̱ cán co̱ó ga̱ ña̱ha ca̱ca̱ ndó nu̱ú i̱. Jáchi̱ mé Ndióxi̱, tátá i̱ quia̱hva tócó ndihi ña̱ xíní ñúhú ndo̱ tá ná ca̱ca̱ ndó ña̱ nu̱ á xi̱hín qui̱vi̱ mí i̱.
\v 24 Ja̱nda̱ viti a̱ ñáha ca̱ca̱ ndó ña̱ha nu̱ Ndióxi̱, tátá i̱ xi̱hín qui̱ví ye̱he̱. Joo viti xíní ñúhú ca̱ca̱ ndó ña̱ cúni̱ ndó nu̱ mé á xi̱hín qui̱ví ye̱he̱ ta já quia̱hva mé á ña̱ nu̱ ndo̱. Ta xi̱hín ña̱ yóho cuu ndicutú nda̱a̱ ini ndó xi̱hín ña̱ cáji̱i̱ íní ndo̱.
\s1 Na̱quee va̱ha Jesús nu̱ tócó ndihi ña̱ núu ñuyíví yóho
\p 
\v 25 ʼXi̱hín quia̱hva cuití na̱ca̱ha̱n i̱ ña̱ yóho xi̱hi̱n ndo̱. Joo tandaa qui̱vi̱ ta a̱ cáha̱n ga̱ i̱ xi̱hín quia̱hva nu̱ ndo̱. Ña̱ caja i̱ quéa̱ cáxí táhyí ca̱ha̱n i̱ sa̱ha̱ Ndióxi̱, tátá i̱ nu̱ ndo̱.
\v 26 Ta mé qui̱vi̱ cán ca̱ca̱ ndó ña̱ cúni̱ ndó nu̱ Ndióxi̱, tátá i̱ xi̱hín qui̱vi̱ mí i̱. Sa̱ núná nu̱ ndó ca̱ca̱ ta̱hví ndó nu̱ á ta co̱ xíní ñúhú ga̱ ca̱ca̱ ta̱hví ye̱he̱ nu̱ mé á sa̱ha̱ ndo̱.
\v 27 Jáchi̱ sa̱ quíhvi̱ ini tátá i̱ ndo̱hó sa̱há ña̱ quíhvi̱ ini ndó ye̱he̱ ta sa̱há ña̱ na̱candúsa ndó ña̱ na̱chindahá mé á ye̱he̱ va̱xi i̱.
\v 28 Mé nu̱ íin Ndióxi̱, tátá i̱ na̱quee e̱ va̱xi i̱ ñuyíví yóho. Ta ya̱chi̱ chá ta jándacoo i̱ ñuyíví yóho já ndicó co̱o tucu u̱ cu̱hu̱n i̱ nu̱ íin Ndióxi̱, tátá i̱ —na̱cachi Jesús.
\p 
\v 29 A̱nda̱ já na̱cachi na̱ xíca tuun xi̱hi̱n á cán já:
\p —Viti ndusa quéa̱ cáha̱n cáxí táhyí ndo̱ xi̱hín nde̱ ta co̱ sácú ga̱ ndó quia̱hva nu̱ú nde̱.
\v 30 Ta viti ndusa cánda̱a̱ ini nde̱ ña̱ xíni̱ ndo̱ tócó ndihi ña̱ha. Ta ni co̱ xíní ñúhú toho ndó ña̱ ná nda̱ca̱ tu̱hún nde̱ ndo̱hó jáchi̱ sa̱ xíni̱ va ndó ña̱ cúni̱ nde̱ canda̱a̱ ini nde̱. Sa̱há ña̱ cán quéa̱ cándúsa nde̱ ña̱ na̱quixi ndó nu̱ íin Ndióxi̱ —na̱cachi na.
\p 
\v 31 Já na̱nducú ñehe Jesús tu̱hun nu̱ ná já na̱cachi a já xi̱hi̱n ná:
\p —Á ja̱ víti ndusa cándúsa ndó ye̱he̱.
\v 32 Joo sa̱ na̱xi̱nu̱ co̱o va hora ndicui̱ta nuu ndó ndá na̱cuu cu̱hu̱n ndo̱ ta jándacoo in túhún ndó ye̱he̱. Va̱tí mé a̱ nda̱a̱ a̱ cándo̱o mé toho i̱ jáchi̱ íin Ndióxi̱, tátá i̱ xi̱hín i̱.
\v 33 Cáxi tu̱hun i̱ ña̱ yóho xi̱hi̱n ndo̱ já ná coo va̱ha ini ndó sa̱há ña̱ in cúú ndó xi̱hín i̱. Mé a̱ nda̱a̱ ndoho tá ndoho ini ndó ñuyíví yóho. Joo a̱ cáyi̱hví toho ndó jáchi̱ ye̱he̱ na̱candeé e̱ na̱sa̱hnu̱ i̱ nu̱ tócó ndihi ña̱ núu ñuyíví yóho —na̱cachi Jesús xi̱hín na̱ xíca tuun xi̱hi̱n á cán.
\c 17
\s1 Xíca̱ ta̱hví Jesús nu̱ Ndióxi̱ sa̱há na̱ xíca tuun xi̱hi̱n á
\p 
\v 1 Tá na̱ndihi na̱cachi Jesús tócó ndihi ña̱ yóho xi̱hín na̱ xíca tuun xi̱hi̱n á cán já na̱ndiñehe a nu̱u̱ á chí indiví já na̱cachi a já:
\p —Tátá Ndióxi̱, sa̱ na̱xi̱nu̱ co̱o qui̱ví quivi i̱. Caja ndó ña̱ ndicáhnu ndiva̱ha mí i̱, da̱ cúú in túhún ji̱ní já ja̱hyi mé ndó já ná cuu caja cáhnu ri ye̱he̱ va ndo̱hó.
\v 2 Jáchi̱ mé ndó na̱sa̱ha̱n ndó nu̱ú i̱ ña̱ ná cacomí i̱ cuéntá sa̱ha̱ tócó ndihi ña̱yivi já ná cuu caja i̱ ña̱ ná catacu na a̱nda̱ ama cáa qui̱vi̱ jáchi̱ cúú ná na̱ na̱sa̱ha̱n ndo̱ nu̱ú i̱.
\v 3 Ta tá xíni̱ na̱ yo cúú mé ndó ta tá xíni̱ na̱ yo cúú ye̱he̱, da̱ na̱chindahá ndó ñuyíví yóho já cuu catacu na a̱nda̱ ama cáa qui̱vi̱. Jáchi̱ in túhún mé ndó cúú ndusa Ndióxi̱.
\p 
\v 4 ʼSa̱ na̱caja cáhnu i̱ ndo̱hó nani íin i̱ ñuyíví yóho ta sa̱ na̱jáxi̱nu̱ co̱o ndihi i̱ ña̱ na̱sahnda ndó nu̱ú i̱ caja i̱.
\v 5 Ta viti xíca̱ ta̱hví i̱ nu̱ ndo̱, tátá Ndióxi̱ ña̱ ná na̱ha̱ ndo̱ nu̱ú ña̱yivi ndaja cáhnu cúú ye̱he̱ nu̱ mé ndó jáchi̱ quia̱hva já in cáhnu na̱sa̱cuu u̱ xi̱hi̱n ndó ja̱nda̱ tá cáma̱ní ca̱va̱ sáhá sa̱ha̱ ñuyíví.
\p 
\v 6 ʼTa na̱ca̱xi ndó na̱ cacuu cuéntá mí i̱ tañu ña̱yivi cuéntá ñuyíví yóho. Ta sa̱ na̱ca̱xi tu̱hun i̱ xi̱hi̱n ná yo cúú mé ndó. Na̱ca̱xi ndó na̱ ta na̱ndiquia̱hva ndó na̱ nu̱ú i̱. Ta na̱candúsa na tu̱hun ndó.
\v 7 Ta viti cánda̱a̱ ini na ña̱ tócó ndihi ña̱ sáhan ndó nu̱ú i̱ quíxi a cuéntá mé ndó.
\v 8 Ta sa̱ na̱ca̱xi tu̱hun i̱ xi̱hi̱n ná tócó ndihi ña̱ na̱sa̱ha̱n ndó nu̱ú i̱ ta na̱ndiquehe va̱ha na ña̱. Ta sa̱ na̱canda̱a̱ ini na ña̱ mé a̱ nda̱a̱ na̱quixi i̱ cuéntá mé ndó. Ta na̱candúsa na ña̱ na̱chindahá ndó ye̱he̱.
\p 
\v 9 ʼCo̱ xíca̱ ta̱hví i̱ nu̱ ndó sa̱há ña̱yivi cuéntá ñuyíví yóho. Joo xíca̱ ta̱hví i̱ nu̱ ndó sa̱há na̱ na̱sa̱ha̱n ndó nu̱ú i̱ jáchi̱ cúú ná cuéntá mé ndó.
\v 10 Tócó ndihi na̱ cúú cuéntá mí i̱ cúú ná cuéntá mé ndó viti. Ta tócó ndihi na̱ cúú cuéntá mé ndó cúú ri na̱ cuéntá ye̱he̱ va. Ta ndicáhnu ndiva̱ha mí i̱ sa̱há ña̱ cája na.
\p 
\v 11 ʼA̱ cóo ga̱ i̱ ñuyíví yóho jáchi̱ sa̱a̱ i̱ nu̱ íin mé ndó. Joo na̱ na̱ca̱xi ndó yóho canduu tóo na ñuyíví yóho. Tátá Ndióxi̱, yi̱i̱ ndiva̱ha cúú mé ndó. Xíca̱ ta̱hví i̱ nu̱ ndó ña̱ ná candaa va̱ha ndó na̱ cúú cuéntá mé ndó jáchi̱ xi̱hi̱n ndée̱ mé ndó cuu candi̱co̱ na̱ íchi̱ cuéntá mé ndó. Já quéa̱ in ná nduu ndihi na tá quia̱hva in cúú mé ndó xi̱hín ye̱he̱.
\v 12 Jáchi̱ nani íin i̱ xi̱hi̱n ná ñuyíví yóho ndáá i̱ na̱ xi̱hi̱n ndée̱ mé ndó. Ta ni in túhún toho táhan na̱ na̱sa̱ha̱n ndó nu̱ú i̱ cacomí i̱ cuéntá sa̱ha̱ cán co̱ó na̱ndihi sa̱ha̱. In túhún da̱ na̱ndihi sa̱ha̱ cúú da̱ ja̱nda̱ sa̱nahá na̱sahi̱in sa̱ha̱ ña̱ ndihi sa̱ha̱ dá já ná cuu xi̱nu̱ co̱o nu̱ú ña̱ na̱ca̱hyi̱ nu̱ú tu̱hun Ndióxi̱ sa̱nahá.
\p 
\v 13 ʼTa viti quee e̱ ñuyíví yóho sa̱a̱ i̱ nu̱ íin ndó ja̱n. Joo cáha̱n i̱ ña̱ yóho xi̱hi̱n ndó nani íin i̱ ñuyíví yóho já ná ndicutú nda̱a̱ ini na̱ yóho xi̱hín ña̱ cáji̱i̱ íní na̱ tá quia̱hva cáji̱i̱ íní mí i̱.
\v 14 Sa̱ na̱ca̱xi tu̱hun i̱ tu̱hun mé ndó nu̱ ná. Joo na̱ cúú cuéntá ñuyíví cándají na̱ na̱ cúú cuéntá mí i̱ jáchi̱ co̱ cúú ná cuéntá ñuyíví yóho tá quia̱hva co̱ cúú toho ye̱he̱ cuéntá ñuyíví yóho.
\v 15 Co̱ xíca̱ ta̱hví i̱ nu̱ ndo̱ ña̱ ná tavá ndo̱ na̱ ñuyíví yóho. Ña̱ cúni̱ quéa̱ ná chindeé ndó na̱ já ná a̱ quée va̱ha tiñáhá sa̱cua̱ha̱ xi̱hi̱n ná.
\v 16 Tá quia̱hva co̱ cúú toho i̱ da̱ cuéntá ñuyíví yóho quia̱hva já co̱ cúú ga̱ na̱ cán ña̱yivi cuéntá ñuyíví.
\v 17 Ta xíca̱ ta̱hví i̱ nu̱ ndó ña̱ ná ndaja vií ndó na̱ xi̱hín tu̱hun mé ndó ña̱ jána̱ha̱ ndó nu̱ ná jáchi̱ tu̱hun mé ndó cúú ña̱ nda̱a̱.
\v 18 Ta tá quia̱hva na̱caja ndó na̱chindahá ndó ye̱he̱ tañu na̱ ñuyíví yóho quia̱hva já chíndahá ri ye̱he̱ va na̱ cúú cuéntá mí i̱ tañu ña̱yivi cuéntá ñuyíví.
\v 19 Ta ndíquia̱hva i̱ mí i̱ caja i̱ ña̱ cúni̱ mé ndó já quéa̱ ná cuu ndiquia̱hva na̱ yóho mé ná ndáha̱ mé ndó sa̱há ña̱ sa̱ xíni̱ na̱ ña̱ nda̱a̱.
\p 
\v 20 ʼTa a̱ ju̱ú sa̱há na̱ yóho cuití va xíca̱ ta̱hví i̱ nu̱ ndo̱, va̱ha. Xíca̱ ta̱hví ri nu̱ ndó sa̱há na̱ ná candúsa ye̱he̱ chága̱ chí nu̱u̱ sa̱há tu̱hun ca̱ha̱n mé na̱ yóho xi̱hi̱n ná.
\v 21 Tátá Ndióxi̱, xíca̱ ta̱hví i̱ nu̱ ndó ña̱ ná caja ndó ña̱ in ná nduu tócó ndihi na̱ cúú cuéntá mé ndó yóho. Ta caja ndó ña̱ in ná nduu ndihi na xi̱hi̱n yó tá quia̱hva in cúú ndó xi̱hín ye̱he̱ ta in cúú ye̱he̱ xi̱hi̱n mé ndó. Jáchi̱ tá ná caja ndó ña̱ in ná nduu tócó ndihi na já cuu candúsa ña̱yivi cuéntá ñuyíví ña̱ mé a̱ nda̱a̱ na̱chindahá ndó ye̱he̱ va̱xi i̱.
\v 22 Na̱caja i̱ ña̱ na̱ndicáhnu na̱ cán tá quia̱hva na̱ndaja cáhnu ndó ye̱he̱. Já quéa̱ in ná nduu ndihi na tá quia̱hva in cúú mé ndó xi̱hín ye̱he̱.
\v 23 Ta in cúú ye̱he̱ xi̱hi̱n ná tá quia̱hva in cúú mé ndó xi̱hín i̱ já ná xi̱nu̱ co̱o ndihi na cacuu na tátu̱hun in víxí ña̱yivi. Ta já ná cuni ña̱yivi cuéntá ñuyíví ña̱ mé a̱ nda̱a̱ na̱chindahá ndó ye̱he̱ va̱xi i̱. Ta já ná cuni na ña̱ quíhvi̱ ini ndó na̱ tá quia̱hva quíhvi̱ ini ndó ye̱he̱.
\p 
\v 24 ʼTátá Ndióxi̱, na̱caja ndó ña̱ cómí i̱ cuéntá sa̱há na̱ yóho. Ta cúni̱ ña̱ ná coo na xi̱hín i̱ nu̱ú coo i̱ já ná cuni na ndá quia̱hva cáhnu cúú u̱ jáchi̱ na̱caja ndó ña̱ ná ndicáhnu ndiva̱ha i̱. Jáchi̱ ja̱nda̱ tá cama̱ní ca̱va̱ sáhá sa̱ha̱ ñuyíví quíhvi̱ ini ndó ye̱he̱.
\v 25 Tátá Ndióxi̱, cája ndó ña̱ nda̱a̱. Ta ña̱yivi cuéntá ñuyíví yóho co̱ xíni̱ toho na ndo̱hó. Joo ye̱he̱ xíni̱ va̱ha i̱ ndo̱hó ta na̱ cúú cuéntá mí i̱ yóho sa̱ cánda̱a̱ va̱ha ini na ña̱ na̱chindahá ndó ye̱he̱.
\v 26 Sa̱ na̱caja i̱ ña̱ ná canda̱a̱ ini na yo cúú mé ndó ta cája i̱ ña̱ ná canda̱a̱ chága̱ ini na sa̱ha̱ ndo̱. Ta xi̱hín ña̱ yóho canda̱a̱ ini na ña̱ quíhvi̱ ini ndó na̱ tá quia̱hva quíhvi̱ ini ndó ye̱he̱ ta já in ná nduu na xi̱hín i̱ —na̱cachi Jesús xíca̱ ta̱hví a̱ nu̱ Ndióxi̱.
\c 18
\s1 Tá na̱tiin na Jesús
\r (Mt. 26:47-56; Mr. 14:43-50; Lc. 22:47-53)
\p 
\v 1 Tá na̱ndihi na̱xi̱ca̱ ta̱hví Jesús nu̱ Ndióxi̱ já na̱queta mé á xi̱hín na̱ xíca tuun xi̱hín a̱ cán cua̱ha̱n chí inga xoo yívi̱ naní Cedrón. Ta yati cán cáa cua̱ha̱ yitó cui̱hi nu̱ú na̱qui̱hvi Jesús xi̱hín na̱ xíca tuun xi̱hi̱n á.
\v 2 Ta Judas Iscariote, mé da̱ jícó túhún ñahá cán sa̱ xíni̱ va̱ha da nu̱ sáhi̱in Jesús xi̱hín na̱ xíca tuun xi̱hi̱n á jáchi̱ cua̱há tañu na̱nditútú ndihi na̱ cán.
\v 3 Ña̱ cán quéa̱ ndáca da in táhndá soldado ta ndáca da java policía, na̱ ndáá veñu̱hu cáhnu ñuu Jerusalén cán. Cúú ná na̱ na̱chindahá na̱ sa̱cua̱ha̱ nu̱ú ju̱tu̱ xi̱hín na̱ fariseo. Ta ja̱ndá joho ñéhe na ña̱ha ná cani na a̱ cua̱ha̱n na̱ ta ñéhe ri na ití yúsá jándiyéhe̱ na̱ nu̱ ná.
\v 4 Joo sa̱ xíni̱ va̱ha Jesús ndía̱ ndítahan ndoho a sa̱há ña̱ cán quéa̱ na̱queta nu̱ ná já na̱nda̱ca̱ tu̱hún a̱ na̱ já na̱cachi a já xi̱hi̱n ná:
\p —Yo ndínducú ndo̱ já —na̱cachi a.
\p 
\v 5 Já na̱nducú ñehe na̱ cán tu̱hun nu̱ á já na̱cachi na já xi̱hi̱n á:
\p —Ndínducú nde̱ Jesús, da̱ ñuu Nazaret —na̱cachi na.
\p —Ye̱he̱ cúú u̱ da̱ ndínducú ndo̱ —na̱cachi a.
\p Ta tañu na̱ cán ndáca̱a̱n ri Judas, da̱ na̱ji̱có túhún ñahá cán.
\v 6 Tá na̱cachi Jesús: “Ye̱he̱ cúú u̱ da̱ ndínducú ndo̱”, já na̱xi̱ca játá na̱ ta na̱cu̱yu na nu̱ ñúhu̱.
\v 7 Já na̱nda̱ca̱ tu̱hún tucu Jesús na̱ já na̱cachi a já xi̱hi̱n ná:
\p —Yo ndínducú ndo̱ já —na̱cachi a.
\p Já na̱nducú ñehe na̱ cán tu̱hun nu̱ á já na̱cachi na já xi̱hi̱n á:
\p —Jesús, da̱ ñuu Nazaret ndínducú nde̱ —na̱cachi na.
\p 
\v 8 A̱nda̱ já na̱cachi tucu Jesús já xi̱hi̱n ná:
\p —Sa̱ na̱cachi vi̱ xi̱hi̱n ndo̱ ña̱ ye̱he̱ cúú u̱ da̱ ndínducú ndo̱. Sa̱há ña̱ cán quéa̱ quia̱hva ndó ña̱ma̱ni̱ nu̱ú na̱ yóho ña̱ ná quee na cu̱hu̱n na̱ —na̱cachi Jesús.
\p 
\v 9 Na̱cachi Jesús ña̱ yóho já ná a̱ tíin na na̱ xíca tuun xi̱hín a̱ cán já ná xi̱nu̱ co̱o nu̱ú tu̱hun ña̱ na̱cachi mé á tá na̱xi̱ca̱ ta̱hví a̱ nu̱ Ndióxi̱ tá na̱cachi a já: “Tátá Ndióxi̱, ni in túhún toho táhan na̱ na̱sa̱ha̱n ndó nu̱ú i̱ co̱ó na̱ndihi sa̱ha̱ jáchi̱ na̱sandaa va̱ha i̱ na̱.”
\v 10 Ta ndaja coo na̱sañee in machítí nu̱ tóco̱ Simón Pedro. Já na̱tuhun da ña̱ ta na̱chitúhu̱n dá jo̱ho cuáha in da̱ naní Malco, da̱ cúú mozo nu̱ú da̱ cúú sa̱cua̱ha̱ chága̱ nu̱ ndíhi ju̱tu̱.
\v 11 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n Pedro:
\p —Chica̱a̱n va̱ha machítí ja̱n. Jáchi̱ sa̱ na̱sacu ini Ndióxi̱, tátá i̱ ndoho ini i̱ tócó ndihi ña̱ va̱xi nu̱ú i̱ ta íin tia̱hva i̱ ndoho ini i̱ —na̱cachi Jesús.
\s1 Ñéhe na Jesús cua̱ha̱n na̱ nu̱ú da̱ sa̱cua̱ha̱ chága̱ nu̱ ndíhi ju̱tu̱
\r (Mt. 26:57-58; Mr. 14:53-54; Lc. 22:54)
\p 
\v 12 Tócó ndihi soldado cán xi̱hín da̱ sáhndá chuun nu̱ dá xi̱hín java na̱ ndáá veñu̱hu cán na̱tiin na Jesús ta na̱cató na̱ a̱.
\v 13 Jihna ñúhú ñéhe na a̱ na̱sa̱ha̱n na̱ nu̱ Anás, da̱ cúú xo̱jo Caifás, da̱ sa̱cua̱ha̱ chága̱ nu̱ ndíhi ju̱tu̱ mé cui̱a̱ cán.
\v 14 Mé Caifás yóho cúú dá da̱ na̱cachi xi̱hín na̱ Israel ña̱ va̱ha chága̱ ña̱ ná quivi in ta̱a nu̱ ndíhi ña̱yivi já ná a̱ ndíhi sa̱ha̱ tócó ndihi ña̱yivi.
\s1 Chíje̱hé tu̱hun Pedro ña̱ xíni̱ da̱ Jesús
\r (Mt. 26:69-70; Mr. 14:66-68; Lc. 22:55-57)
\p 
\v 15 Ta ndaja coo Simón Pedro xi̱hín inga táhan da̱ xíca tuun xi̱hín Jesús cán ndíco̱ na̱ ja̱tá nu̱ ñéhe na a̱ cua̱ha̱n na̱. Ta da̱ inga cán xíni̱ táhan va̱ha da xi̱hín da̱ sa̱cua̱ha̱ chága̱ nu̱ ndíhi ju̱tu̱ ña̱ cán quéa̱ na̱ñe̱he̱ dá ña̱ma̱ní ndi̱hvi da xi̱hín Jesús yuyéhé vehe ju̱tu̱ cán.
\v 16 Joo na̱cando̱o Pedro ja̱ta̱ véhe yati yéhé cán. Joo da̱ inga cán na̱ndicó co̱o da já na̱xi̱ca̱ da̱ ña̱ma̱ni̱ nu̱ ñá ndáá yéhé vehe ju̱tu̱ cán ña̱ ná quia̱hva ñá ña̱ma̱ni̱ nu̱ Pedro qui̱hvi da. Sa̱há ña̱ cán na̱qui̱hvi Pedro chí yuyéhé vehe cán.
\v 17 Ta mé ñá ndáá yéhé cán na̱nda̱ca̱ tu̱hún ña̱ Pedro já na̱cachi ñá já xi̱hi̱n dá:
\p —Á a̱ ju̱ú in táhan da̱ xíca tuun xi̱hín Jesús cúú yóhó —na̱cachi ñá.
\p A̱nda̱ já na̱cachi Pedro já xi̱hi̱n ña̱:
\p —Co̱ cúú toho i̱ in táhan da̱ xíca tuun xi̱hi̱n á —na̱cachi Pedro.
\p 
\v 18 Ta mé ñuú cán vi̱xi xíní na̱ cúú mozo xi̱hín na̱ ndáá veñu̱hu cán. Sa̱há ña̱ cán quéa̱ na̱ndicahmi na ñúhu̱ ta na̱nda̱ca̱ nduu na xítúní na̱ ta tañu na̱ cán cándichi ri Pedro xítúní da̱.
\s1 Ndája ndi̱chi̱ da̱ sa̱cua̱ha̱ chága̱ nu̱ ndíhi ju̱tu̱ Jesús
\r (Mt. 26:59-66; Mr. 14:55-64; Lc. 22:66-71)
\p 
\v 19 Tá na̱ndihi já na̱casáhá da̱ sa̱cua̱ha̱ chága̱ nu̱ ndíhi ju̱tu̱ cán ndája ndi̱chi̱ da̱ Jesús já na̱nda̱ca̱ tu̱hún da̱ mé á sa̱há na̱ na̱xi̱ca tuun xi̱hi̱n á. Ta na̱nda̱ca̱ tu̱hún da̱ mé á sa̱há ña̱ na̱jána̱ha̱ nu̱ú ña̱yivi.
\v 20 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n dá:
\p —Co̱ó na̱ca̱ha̱n je̱hé toho i̱ xi̱hín ña̱yivi tá na̱jána̱ha̱ i̱ nu̱ ná. Níí tiempo na̱jána̱ha̱ i̱ tu̱hun Ndióxi̱ nu̱ ná ini veñu̱hu ta quia̱hva já na̱jána̱ha̱ i̱ nu̱ ná nu̱ tácá na̱ ini veñu̱hu cáhnu ñuu Jerusalén. Ta ni in túhún toho ña̱ha co̱ó na̱jána̱ha̱ je̱hé e̱ nu̱ ná.
\v 21 Ta viti cachi ndó xi̱hín i̱ ndá cuéntá quéa̱ ndáca̱ tu̱hún ndó ye̱he̱ sa̱há ña̱ yóho. Cuáhán ndó nda̱ca̱ tu̱hún ndo̱ ña̱yivi, na̱ na̱jána̱ha̱ i̱ nu̱ cán já ná ndicani na̱ cán nu̱ ndo̱ ndaja cáa ña̱ na̱jána̱ha̱ i̱ nu̱ ná. Jáchi̱ xíni̱ va̱ha na ña̱ na̱ca̱ha̱n i̱ xi̱hi̱n ná —na̱cachi Jesús.
\p 
\v 22 Tá na̱cachi Jesús ña̱ yóho já na̱cani in da̱ ndáá veñu̱hu cán ja̱hndá nu̱u̱ á já na̱cachi da já xi̱hi̱n á:
\p —A̱ váha toho ndiñehe yúhu̱n nu̱ú da̱ sa̱cua̱ha̱ chága̱ nu̱ ndíhi ju̱tu̱ —na̱cachi da.
\p 
\v 23 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n dá:
\p —Tá co̱ váha ná caja i̱, ca̱ha̱n xi̱hín i̱ ndá cúú ña̱ co̱ó na̱caja va̱ha i̱. Joo tá na̱caja va̱ha i̱ ndá cuéntá quéa̱ cánún ye̱he̱ —na̱cachi Jesús.
\p 
\v 24 Tá na̱ndihi já na̱sa̱ñehe na Jesús nu̱ú Caifás, da̱ sa̱cua̱ha̱ chága̱ nu̱ ndíhi ju̱tu̱ cán ta sa̱ já ndíco̱ a̱ xi̱hi̱n yóho̱ ñéhe na a̱ cua̱ha̱n na̱.
\s1 Chíje̱hé tu̱hun tucu Pedro ña̱ xíni̱ da̱ Jesús
\r (Mt. 26:71-75; Mr. 14:69-72; Lc. 22:58-62)
\p 
\v 25 Ta ndaja coo íin coo yi̱i̱ Pedro xítúní da̱ xi̱hín java na̱ ndúu cán. Ta já na̱casáhá na̱ cán ndáca̱ tu̱hún na̱ da̱ já na̱cachi na já xi̱hi̱n dá:
\p —Á a̱ ju̱ú táhan da̱ xíca tuun xi̱hín Jesús cúú yóhó —na̱cachi na.
\p Joo na̱chije̱hé tu̱hun Pedro ña̱ xíni̱ da̱ Jesús já na̱cachi da já:
\p —Co̱ cúú toho i̱ in táhan da̱ xíca tuun xi̱hi̱n á —na̱cachi da.
\p 
\v 26 Joo tá na̱ndihi já na̱nda̱ca̱ tu̱hún in da̱ cúú mozo nu̱ú da̱ sa̱cua̱ha̱ chága̱ nu̱ ndíhi ju̱tu̱ cán, da̱ cúú in táhan da̱ na̱chitúhu̱n Pedro jo̱ho. Ta na̱cachi da já xi̱hi̱n Pedro:
\p —Cája i̱ cuéntá na̱xini i̱ yo̱hó nu̱ cáa cua̱ha̱ yitó cui̱hi nu̱ú na̱tiin na Jesús cán —na̱cachi da.
\p 
\v 27 Joo na̱chije̱hé tu̱hun tucu Pedro ña̱ xíni̱ da̱ Jesús ta i̱vi̱ la̱á na̱cana chéle tá quia̱hva na̱cachi Jesús xi̱hi̱n dá coo.
\s1 Ñéhe na Jesús cua̱ha̱n na̱ nu̱ Pilato
\r (Mt. 27:1-2, 11-14; Mr. 15:1-5; Lc. 23:1-5)
\p 
\v 28 Ta tá na̱ti̱vi yaa já na̱tavá na̱ Jesús vehe Caifás cán já ñéhe na a̱ cua̱ha̱n na̱ vechúun nu̱ ndáca̱a̱n da̱ cúú gobernador cuéntá ñuu Roma. Joo mé na̱ Israel co̱ó na̱xeen na ndi̱hvi na vechúun cán jáchi̱ cáchí ley na̱ ña̱ tá ná ndi̱hvi na vehe na̱ tóho̱ já cuu yu̱xu̱ na̱ ta já a̱ cúu cajíni na vicó pascua ña̱ coo qui̱ví ita̱a̱n.
\v 29 Sa̱há ña̱ cán quéa̱ na̱queta Pilato, da̱ cúú gobernador ja̱ta̱ véhe ca̱ha̱n da̱ xi̱hín na̱ Israel já na̱cachi da já:
\p —Ndá cua̱chi na̱caja da̱ yóho —na̱cachi Pilato.
\p 
\v 30 Já na̱nducú ñehe na̱ Israel cán tu̱hun nu̱ dá já na̱cachi na já:
\p —Ta tá a̱ ju̱ú ta̱a quini ná cacuu da̱ yóho ta a̱ cáñehe toho nde̱ da̱ quixi da nu̱ ndó, nduu —na̱cachi na.
\p 
\v 31 Já na̱cachi Pilato já xi̱hi̱n ná:
\p —Mé ndó cañehe ndó da̱ cu̱hu̱n ndo̱. Caja vií ndó sa̱ha̱ dá tá quia̱hva sáhndá ley mé ndó —na̱cachi Pilato.
\p Já na̱cachi na̱ Israel cán já xi̱hi̱n dá:
\p —Ña̱ cúni̱ nde̱ quéa̱ ná cata caa ndó da̱ ndi̱ca crúxu̱ jáchi̱ cúú nde̱ na̱ Israel ta co̱ ñéhe toho nde̱ ña̱ma̱ni̱ cahní nde̱ ña̱yivi —na̱cachi na.
\p 
\v 32 Ta xi̱hín ña̱ yóho na̱xi̱nu̱ co̱o nu̱ú ña̱ na̱cachi Jesús tá na̱cachi a ndá quia̱hva quivi a.
\v 33 Tá na̱ndihi já na̱ndi̱hvi tucu Pilato ini vechúun cán ta na̱cana da Jesús já na̱nda̱ca̱ tu̱hún ñahá da̱ já na̱cachi da já xi̱hi̱n á:
\p —Á mé a̱ nda̱a̱ cúún in rey, da̱ cómí cuéntá sa̱há na̱ Israel —na̱cachi da.
\p 
\v 34 Já na̱cachi Jesús já xi̱hi̱n dá:
\p —Á ji̱ni̱ mé ndó na̱quixi ña̱ ndáca̱ tu̱hún ndó ye̱he̱. Á ndáca̱ tu̱hún ndó ye̱he̱ sa̱há ña̱ na̱cachi ña̱yivi sa̱há i̱ —na̱cachi a.
\p 
\v 35 A̱nda̱ já na̱cachi Pilato já xi̱hín Jesús:
\p —Co̱ cánda̱a̱ ini i̱ sa̱ha̱ ña̱ yóho jáchi̱ co̱ cúú ye̱he̱ da̱ Israel. Mé ña̱yivi Israel ja̱n xi̱hín na̱ sa̱cua̱ha̱ nu̱ú ju̱tu̱ cúú na̱ na̱ndiquia̱hva yo̱hó ndahá i̱. Ndía̱ na̱cajún, va̱ha —na̱cachi Pilato.
\p 
\v 36 Já na̱nducú ñehe Jesús tu̱hun nu̱ dá já na̱cachi a já xi̱hi̱n dá:
\p —Co̱ cómí i̱ cuéntá sa̱há ña̱yivi tátu̱hun cája ña̱yivi cuéntá ñuyíví. Jáchi̱ tá ná cacomí i̱ cuéntá sa̱ha̱ ná tátu̱hun na̱ ñuyíví já quéa̱ cuu caja i̱ xi̱hín na̱ cómí i̱ cuéntá sa̱ha̱ ña̱ ná cani táhan na xi̱hín na̱ Israel ña̱ ná a̱ tíin na ye̱he̱. Joo co̱ cómí toho i̱ cuéntá sa̱ha̱ ná tátu̱hun cája ña̱yivi cuéntá ñuyíví —na̱cachi a.
\p 
\v 37 A̱nda̱ já na̱cachi tucu Pilato já xi̱hín Jesús:
\p —Á cúún da̱ cómí cuéntá sa̱há ña̱yivi, dá já —na̱cachi da.
\p Já na̱cachi Jesús já xi̱hi̱n dá:
\p —Ña̱ nda̱a̱ quéa̱ cáha̱n ndó ja̱n. Ye̱he̱ cúú u̱ da̱ cómí cuéntá sa̱há ña̱yivi cuéntá mí i̱ jáchi̱ na̱cacu u̱ ñuyíví yóho ña̱ ná caja i̱ já. Ta na̱quixi i̱ já ná ca̱xi tu̱hun i̱ ña̱ nda̱a̱ xi̱hín ña̱yivi. Ta tócó ndihi na̱ cúú cuéntá ña̱ nda̱a̱ xíni̱ jo̱ho ña̱ cáha̱n i̱ —na̱cachi a.
\p 
\v 38 Já na̱cachi tucu Pilato já xi̱hi̱n á:
\p —Yo xíni̱ ndía̱ cúú ña̱ nda̱a̱ —na̱cachi da.
\p Tá na̱ndihi já na̱queta tucu Pilato vechúun ca̱ha̱n da̱ xi̱hín na̱ Israel já na̱cachi da já xi̱hi̱n ná:
\p —Chí co̱ ndíñe̱he̱ mí vi̱ ndá cua̱chi quéa̱ na̱caja da̱ yóho.
\v 39 Tañu mé víco̱ pascua íin in costumbre ndo̱ ña̱ ná janí i̱ in da̱ sá ndaca̱a̱n veca̱a. Ta viti cachi ndó xi̱hín i̱ á co̱ cúni̱ ndó ña̱ ná janí i̱ da̱ cúú rey nu̱ú na̱ Israel —na̱cachi Pilato.
\p 
\v 40 Ta já na̱casáhá tócó ndihi na̱ cán cáyuhú cóhó na̱ já cáchí na̱ já:
\p —A̱ jání toho ndó Jesús ja̱n. Va̱ha chága̱ ná janí ndó Barrabás ja̱n —cáchí na̱ cáyuhú na̱ nu̱ Pilato.
\p Ta Barrabás cán na̱sa̱cuu da in ta̱a cui̱hná.
\c 19
\s1 Sácú na̱ sa̱há Jesús quivi a
\p 
\v 1 A̱nda̱ já na̱sahnda Pilato chuun ña̱ ná jácaxáhan na Jesús xi̱hín churrú.
\v 2 Ta da̱ cúú soldado cán na̱je̱hén da̱ in ti̱yi̱vi̱ xi̱hi̱n íñu̱ já na̱chinúu da a̱ ji̱ni̱ á ta na̱chinúu da in jáhma̱ cuáhá túu̱n ja̱tá.
\v 3 Tá na̱ndihi já na̱cativi da nu̱ á sácu̱ ndaa i̱chi̱ ñahá da̱ já na̱cachi da já xi̱hi̱n á:
\p —Cáhnu nahá ná cacuu yóhó, da̱ cúú rey nu̱ú na̱ Israel —na̱cachi da.
\p A̱nda̱ já cáni da nu̱u̱ á.
\p 
\v 4 Tá na̱ndihi já na̱queta tucu Pilato chí ja̱ta̱ já na̱cachi da já xi̱hi̱n tócó ndihi na̱ ndúu cán:
\p —Cande̱hé ndo̱. Tavá ñéhe e̱ Jesús nu̱ ndo̱ já ná canda̱a̱ ini ndó ña̱ co̱ó toho cua̱chi da ndítahan i̱ —na̱cachi da.
\p 
\v 5 Tá na̱ndihi já na̱tavá ñéhe Pilato Jesús ta sa̱ já cánúu ti̱yi̱vi̱ íñu̱ ji̱ni̱ á. Ta sa̱ já tácaa jahmá cuáhá túu̱n ja̱tá na̱queta. A̱nda̱ já na̱casáhá cáchí Pilato já:
\p —Cande̱hé ndo̱. Yóho íin da —na̱cachi da.
\p 
\v 6 Joo na̱ sa̱cua̱ha̱ nu̱ú ju̱tu̱ xi̱hín na̱ ndáá veñu̱hu tá na̱xini na Jesús já na̱casáhá na̱ cáyuhú cóhó na̱ já cáchí na̱ já:
\p —Cata caa ndó da̱ ndi̱ca crúxu̱, cata caa ndó da̱ —cáchí na.
\p A̱nda̱ já na̱cachi Pilato já xi̱hi̱n ná:
\p —Mé ndó cañehe ndó da̱ cu̱hu̱n ndo̱ cata caa ndó da̱ ndi̱ca crúxu̱ tá cúni̱ ndo̱. Jáchi̱ ye̱he̱ co̱ ndítahan i̱ ndá cua̱chi na̱caja da —na̱cachi Pilato.
\p 
\v 7 A̱nda̱ já na̱cachi na̱ Israel cán já xi̱hín Pilato:
\p —Nu̱ ley mé nde̱ ndítahan quivi da jáchi̱ cáchí da̱ cúú dá in túhún ji̱ni̱ já ja̱hyi Ndióxi̱ —na̱cachi na.
\p 
\v 8 Tá na̱xini jo̱ho Pilato cán ña̱ yóho já na̱yi̱hví chága̱ ví da̱.
\v 9 Já na̱qui̱hvi tucu Pilato xi̱hín Jesús ini vechúun cán já na̱nda̱ca̱ tu̱hún da̱ mé á já na̱cachi da já xi̱hi̱n á:
\p —Ndá ñuu na̱quisún já —na̱cachi da.
\p Joo co̱ó na̱nducú ñehe Jesús tu̱hun nu̱ dá.
\p 
\v 10 Já na̱cachi tucu Pilato já:
\p —Ndá cuéntá quéa̱ co̱ cúnu̱n nducú ñehún tu̱hun nu̱ú i̱. Á co̱ xíni̱ tohún ña̱ cuu cahnda i̱ chuun ña̱ ná cata caa na yo̱hó ndi̱ca crúxu̱. Ta cuu janí ri̱ yo̱hó ña̱ ná queún cu̱hu̱n tá cúni̱ —na̱cachi da.
\p 
\v 11 A̱nda̱ já na̱nducú ñehe Jesús tu̱hun nu̱ dá já na̱cachi a já xi̱hi̱n dá:
\p —Ni in túhún toho ña̱ha co̱ núná nu̱ ndó caja ndó xi̱hín i̱ tá co̱ sáhan Ndióxi̱, tátá i̱ ña̱ma̱ni̱ nu̱ ndo̱. Joo mé a̱ nda̱a̱ íin chága̱ cua̱chi nu̱ú da̱ na̱ndiquia̱hva ye̱he̱ ndáha̱ ndó a̱ ju̱ú ga̱ ndóhó —na̱cachi Jesús.
\p 
\v 12 A̱nda̱ já na̱nducú Pilato ndá quia̱hva caja da janí da̱ Jesús ña̱ ná quee a cu̱hu̱n a̱. Joo co̱ó na̱xeen na̱ Israel ta na̱casáhá na̱ cáyuhú cóhó na̱ nu̱ dá já cáchí na̱ já:
\p —Tá ná janí ndó Jesús ja̱n já quéa̱ náha̱ ña̱ co̱ cúú ndó da̱ ñéhe táhan va̱ha xi̱hín da̱ cómí cuéntá sa̱há ña̱yivi ñuu Roma. Jáchi̱ Jesús ja̱n cáchí da̱ ña̱ cúú dá da̱ cómí cuéntá sa̱há ña̱yivi ta xi̱hín ña̱ yóho jándihi̱hvi̱ da̱ emperador, da̱ cómí cuéntá sa̱há ña̱yivi ñuu Roma —na̱cachi na.
\p 
\v 13 Tá na̱xini jo̱ho Pilato ña̱ yóho já na̱sahnda da chuun ña̱ ná tavá na̱ Jesús. Ta na̱saco̱o mé dá nu̱ sáco̱o da̱ sáhndá chuun vechúun. Mé nu̱ sáco̱o da̱ cán naní a̱ Gabata tu̱hun hebreo. Mé tu̱hun yóho cúni̱ cachi a nu̱ú na̱qui̱hvi piso yu̱u̱.
\v 14 Na̱ya̱ha tócó ndihi ña̱ yóho tá cáma̱ní in qui̱vi̱ coo víco̱ pascua. Ta cúú á tátu̱hun caxi̱vi̱ ta na̱nda̱ca̱ ndichi Pilato já na̱cachi da já xi̱hín na̱ Israel cán:
\p —Ja̱n íin da̱ cúú rey nu̱ ndo̱ —na̱cachi da.
\p 
\v 15 Joo na̱ cán na̱casáhá tucu na cáyuhú cóhó na̱ nu̱ dá já cáchí na̱ já:
\p —Cahní ndó da̱. Ná quivi da. Cata caa ndó da̱ ndi̱ca crúxu̱ —cáchí na̱.
\p Já na̱cachi Pilato já xi̱hi̱n ná:
\p —Ama ná cata caa ri da̱ cúú rey nu̱ ndó ndi̱ca crúxu̱ —na̱cachi Pilato.
\p A̱nda̱ já na̱cachi na̱ sa̱cua̱ha̱ nu̱ú ju̱tu̱ cán já:
\p —Da̱ cómí cuéntá sa̱há ñuu Roma, in túhún da̱ cán cuití va cúú rey nu̱ú nde̱ —na̱cachi na̱ cán.
\p 
\v 16 A̱nda̱ já na̱ndiquia̱hva Pilato Jesús nu̱ ná ña̱ ná cañehe na a̱ cu̱hu̱n na̱ cata caa na a̱ ndi̱ca crúxu̱.
\s1 Cáta caa na Jesús ndi̱ca crúxu̱
\r (Mt. 27:32-44; Mr. 15:21-32; Lc. 23:26-43)
\p 
\v 17 Na̱chinúu na in crúxu̱ jo̱co̱ Jesús já ndójo a do̱ cua̱ha̱n chí xi̱qui̱ naní a̱ nu̱ ndúu lásá yiquí jíní ndi̱i. Ta cáchí na̱ Gólgota xi̱hi̱n á tu̱hun hebreo.
\v 18 Ta cán na̱cata caa na a̱ ndi̱ca crúxu̱ ta na̱cata caa ri na inga i̱vi̱ da̱ xi̱hi̱n á, in in da̱ in in xoo jíi̱n á. Ta tácaa Jesús ma̱hñú ndíví da̱ cán.
\v 19 Ta na̱sahnda Pilato chuun ña̱ ná cu̱hu̱n java na chítivi ndaa na in tabla ndi̱ca crúxu̱ yati ji̱ni̱ Jesús cán. Ta nu̱ tabla cán na̱ca̱hyí na̱: “Da̱ yóho cúú Jesús, da̱ ñuu Nazaret, da̱ cúú rey nu̱ú na̱ Israel.”
\v 20 Ta cua̱há na̱ Israel na̱cahvi na ña̱ na̱ca̱hyi̱ cán jáchi̱ yati yuhú ñuu Jerusalén na̱cata caa na Jesús. Ta ña̱ ndáa̱ nu̱ tabla cán na̱ca̱hyí na̱ ña̱ tu̱hun hebrero ña̱ cáha̱n na̱ Israel xi̱hín tu̱hun latín ña̱ cáha̱n na̱ ñuu Roma xi̱hín tu̱hun griego ña̱ cáha̱n na̱ nación Grecia.
\v 21 Ta tá na̱xini na̱ sa̱cua̱ha̱ nu̱ú ju̱tu̱ cán ña̱ yóho já na̱cachi na já xi̱hín Pilato:
\p —A̱ cáhyí toho ndó ña̱ cúú da̱ ja̱n rey nu̱ú na̱ Israel. Va̱ha chága̱ ná ca̱hyí ndó ña̱ cáchí da̱ cúú dá rey nu̱ú na̱ Israel —na̱cachi na.
\p 
\v 22 Já na̱nducú ñehe Pilato tu̱hun nu̱ ná já na̱cachi da já xi̱hi̱n ná:
\p —Coo tá coo ña̱ sa̱ na̱sacu u̱ ta a̱ tává toho i̱ ña̱ —na̱cachi da.
\p 
\v 23 Tá na̱ndihi na̱cata caa mé soldado Jesús ndi̱ca crúxu̱, já na̱tiin da jahmá a̱ ta na̱ndicahnda nu̱ táhan ndíco̱mi̱ dá ña̱. Ta cotó ndéé a̱ cúú á ña̱ na̱cava̱ha níí na̱ ña̱ ji̱ni̱ á ta ja̱nda̱ sa̱há ta co̱ó na̱cucu na ña̱. Ta na̱tiin da ña̱
\v 24 ta já na̱cachi xi̱hi̱n táhan da̱ já:
\p —Ná a̱ jácuachí toho í jáhma̱ ja̱n já ná coo níí yi̱i̱ va. Ña̱ cuu caja í quéa̱ cajíquí yo̱ sa̱há ta ndá da̱ ná quee va̱ha, da̱ cán ndiquehe jáhma̱ ja̱n —na̱cachi xi̱hi̱n táhan da̱ cán.
\p Na̱caja da ña̱ yóho já ná xi̱nu̱ co̱o nu̱ú tu̱hun Ndióxi̱ na̱ca̱hyi̱ sa̱nahá tá na̱cachi a já: “Na̱ndicahnda nu̱ táhan mé ná jahmá i̱ ta já na̱sajíquí na̱ sa̱há cotó ndéé e̱ ta da̱ na̱quee va̱ha cán na̱ndiquehe da ña̱.” Quia̱hva já na̱ca̱hyi̱ tu̱hun Ndióxi̱ sa̱nahá. Ta quia̱hva já na̱caja soldado cán xi̱hi̱n jáhma̱ á.
\p 
\v 25 Ta jíi̱n mé crúxu̱ nu̱ú na̱cata caa na Jesús cán na̱sa̱ndichi náná a̱ xi̱hín qui̱hvi̱ ñá cán xi̱hín María, ñá cúú ñájíhí Cleofas xi̱hín María, ñá ñuu Magdala.
\v 26 Tá na̱xini Jesús ña̱ cándichi náná a̱ sa̱ha̱ crúxu̱ ta tá na̱xini a cándichi ye̱he̱, da̱ naní Juan, da̱ xíca tuun xi̱hi̱n á, da̱ quíhvi̱ ndiva̱ha ini mé á chí já na̱cachi a já xi̱hi̱n náná a̱:
\p —Da̱ ja̱n cúú tátu̱hun ja̱hyi ndó viti —na̱cachi Jesús.
\p 
\v 27 Tá na̱ndihi já na̱cachi a já xi̱hi̱n mé da̱ xíca tuun xi̱hín a̱ cán:
\p —Candaa va̱ha ñá jáchi̱ cúú ñá tátu̱hun nánún viti —na̱cachi Jesús.
\p Tá na̱xini jo̱ho da ña̱ yóho já na̱ndiquehe va̱ha da María cán ndáá da̱ ñá tátu̱hun náná da̱.
\s1 Tá na̱xi̱hi̱ Jesús
\r (Mt. 27:45-56; Mr. 15:33-41; Lc. 23:44-49)
\p 
\v 28 Tá sa̱ na̱ya̱ha tócó ndihi ña̱ yóho já sa̱ xíni̱ va̱ha Jesús ña̱ sa̱ na̱xi̱nu̱ co̱o tócó ndihi ña̱ na̱cachi tu̱hun Ndióxi̱ coo. Ta na̱xi̱nu̱ co̱o nu̱ú ña̱ na̱ca̱hyi̱ nu̱ú tu̱hun Ndióxi̱ sa̱há Jesús sa̱nahá tá na̱cachi a já:
\p —Íchi̱ ini i̱ ticui̱í.
\p 
\v 29 Mé cán na̱sa̱ndichi in ti̱ndo̱ho̱ na̱chutú jíní xi̱hi̱n vino iyá. Ta na̱jándaxi na in ti̱co̱to̱ xi̱hi̱n vino cán já na̱cató da̱ ña̱ nu̱ú in yíto̱ naní hisopo ta já na̱chitivi na ña̱ yati yúhu̱ Jesús ña̱ ná coho a do̱.
\v 30 A̱nda̱ já na̱xihi Jesús mé vino iyá cán já na̱cachi a já:
\p —Sa̱ na̱ya̱ha tócó ndihi ña̱ha ña̱ ndítahan ndoho i̱ —na̱cachi a.
\p Já na̱ndito̱o ji̱co̱ á. Na̱xi̱hi̱ a̱.
\s1 Tá na̱tuxú na̱ in yíto̱ tátu̱hun póyá yicá ndícá Jesús
\p 
\v 31 Ta ndaja coo na̱sa̱ha̱n na̱ Israel cán na̱xi̱ca̱ na̱ ña̱ma̱ni̱ nu̱ Pilato ña̱ ná cahnda da chuun ña̱ ná ca̱hnu̱ da̱ lásá sa̱há da̱ tácaa ndi̱ca crúxu̱ cán já ná quivi ya̱chi̱ da̱. Jáchi̱ co̱ó na̱xeen na̱ Israel cán ña̱ ná tacaa ndi̱i ndi̱ca crúxu̱ inga qui̱vi̱ ita̱a̱n. Jáchi̱ cacuu a qui̱vi̱ ndiquehe ndée̱ ná ta cacuu a in qui̱ví yi̱i̱ ndiva̱ha nu̱ ná.
\v 32 Sa̱há ña̱ cán quéa̱ na̱quee soldado na̱sa̱ha̱n da̱ já na̱sa̱hnu̱ da̱ lásá sa̱há ndíví da̱ tácaa ndi̱ca crúxu̱ jíi̱n Jesús cán.
\v 33 Joo tá na̱cayati da nu̱ Jesús ña̱ ca̱hnu̱ da̱ lásá sa̱há, na̱xini da ña̱ sa̱ na̱xi̱hi̱ va mé á sa̱há ña̱ cán quéa̱ co̱ó na̱sa̱hnu̱ da̱ lásá sa̱há.
\p 
\v 34 Joo in táhan soldado cán na̱tuxú da̱ in yíto̱ tátu̱hun póyá yicá ndícá a̱ já na̱cana ni̱i̱ xi̱hín ticui̱í cán.
\v 35 Ta ye̱he̱ cúú u̱ da̱ ndícani ña̱ yóho nu̱ ndo̱ ta na̱xini i̱ ña̱ xi̱hín nu̱ú i̱. Ta cúú á ña̱ nda̱a̱. Ta cánda̱a̱ cáxí ini i̱ ña̱ cáha̱n i̱ ña̱ nda̱a̱ já ná candúsa ndó ña̱ ndícani i̱ nu̱ ndo̱.
\v 36 Jáchi̱ tócó ndihi ña̱ yóho na̱ya̱ha já ná xi̱nu̱ co̱o nu̱ú tu̱hun Ndióxi̱ tá cáchí a̱ já: “Ni in túhún toho lásá da̱, a̱ cáhnu̱ na̱”, já cáchí tu̱hun Ndióxi̱.
\v 37 Ta inga tucu cáchí tu̱hun Ndióxi̱ já: “Cuni tucu na da̱, da̱ na̱tuxú na̱ póyá yicá ndícá”, já na̱ca̱hyí na̱ nu̱ú tu̱hun Ndióxi̱ sa̱nahá.
\s1 Tá na̱jándu̱xu̱ na̱ Jesús
\r (Mt. 27:57-61; Mr. 15:42-47; Lc. 23:50-56)
\p 
\v 38 Tá sa̱ na̱ya̱ha tócó ndihi ña̱ yóho já na̱xi̱nu̱ co̱o in da̱ naní José, da̱ ñuu Arimateo, nu̱ Pilato. Ta na̱xi̱ca̱ da̱ ña̱ma̱ni̱ nu̱ Pilato ña̱ ná ndiquehe da yiquí cu̱ñu Jesús cañehe da cu̱hu̱n da̱. Mé José yóho cúú dá cuéntá Jesús joo co̱ó na̱na̱ha̱ tu̱hun da sa̱há jáchi̱ yíhví da̱ na̱ Israel. Ta ndaja coo na̱sa̱ha̱n Pilato ña̱ma̱ni̱ nu̱ dá ña̱ ná ndiquehe da yiquí cu̱ñu Jesús. Chí na̱sa̱ha̱n da̱ na̱ndiquehe da ña̱.
\v 39 Ta jári íin in da̱ naní Nicodemo ta ñéhe da tátu̱hun o̱co̱ u̱xu̱ kilo perfume, dó na̱cava̱ha xi̱hín ña̱ naní mirra ta xi̱hín ña̱ naní aloes. Mé Nicodemo yóho cúú da̱ da̱ na̱sa̱ha̱n na̱nditúhún xi̱hín Jesús tá ñuú.
\v 40 Ña̱ cán quéa̱ na̱tiin José xi̱hi̱n Nicodemo yiquí cu̱ñu Jesús ta na̱chitiví na̱ ña̱ xi̱hín in jáhma̱ va̱ha ña̱ na̱chindaxi da xi̱hi̱n mé perfume cán. Jáchi̱ quia̱hva já íin costumbre na̱ Israel cája na tá jándu̱xu̱ na̱ ndi̱i.
\v 41 Ta yati nu̱ú na̱cata caa na Jesús cán na̱sahi̱in nu̱ cáa cua̱ha̱ yitó cui̱hi. Ta tañu yíto̱ cán na̱sahi̱in in yávi̱ ndi̱ca cáva̱ nu̱ú cuu chica̱a̱n na̱ ndi̱i. Mé cáva̱ cán na̱sa̱cuu a ña̱ sa̱á jáchi̱ ni in ndi̱i a̱ ñáha chica̱a̱n na̱ ini ña̱ cán.
\v 42 Ta cán na̱chica̱a̱n da̱ yiquí cu̱ñu Jesús jáchi̱ yati na̱sahi̱in a. Ta númi̱ dá jáchi̱ sa̱ na̱cativi qui̱vi̱ ndiquehe ndée̱ na̱ Israel.
\c 20
\s1 Tá na̱nditacu tucu Jesús
\r (Mt. 28:1-10; Mr. 16:1-8; Lc. 24:1-12)
\p 
\v 1 Ta tá sa̱ na̱ya̱ha mé qui̱vi̱ ndíquehe ndée̱ ná ta naha va̱ha chá qui̱vi̱ domingo tá cáma̱ni̱ queta ca̱ndii já na̱sa̱ha̱n María, ñá ñuu Magdala nu̱ú na̱chica̱a̱n na̱ yiquí cu̱ñu Jesús cán. Já na̱xini ñá ña̱ na̱caxoo yu̱u̱ cáhnu na̱sa̱ndaji yuhú cáva̱ cán.
\v 2 A̱nda̱ já na̱xinu ñá na̱sa̱ha̱n ñá nu̱ íin Simón Pedro xi̱hín inga da̱ na̱xi̱ca tuun xi̱hi̱n Jesús, da̱ quíhvi̱ ndiva̱ha ini mé á cán. Ta tá na̱xi̱nu̱ co̱o ñá nu̱ dá já na̱cachi ñá já xi̱hi̱n dá:
\p —Na̱tavá na̱ yiquí cu̱ñu xitoho i̱ ta yo xíni̱ ndájá na̱sacu na ña̱ —na̱cachi ñá.
\p 
\v 3 A̱nda̱ já na̱queta Pedro xi̱hín inga da̱ na̱xi̱ca tuun xi̱hi̱n Jesús cán ndáva da cua̱ha̱n da̱ nu̱ú na̱sandaca̱a̱n Jesús.
\v 4 In nu̱ú xínu ndíví da̱ cua̱ha̱n da̱. Joo ni̱hi̱ chága̱ xínu da̱ inga cán a̱ ju̱ú ga̱ Pedro ña̱ cán quéa̱ jihna ñúhú da̱ na̱xi̱nu̱ co̱o da nu̱ú na̱ndaca̱a̱n Jesús cán.
\v 5 A̱nda̱ já na̱candayi da sánde̱hé da̱ nu̱ú na̱sandaca̱a̱n Jesús cán. Já na̱xini da ñúhu ti̱co̱to̱ na̱satíví a̱ cán cuití va. Joo co̱ó na̱ndi̱hvi da ja̱nda̱ mé ini cáva̱ cán.
\v 6 A̱nda̱ já na̱xi̱nu̱ co̱o Simón Pedro ta na̱ndi̱hvi da cán. Ta na̱xini da mé ti̱co̱to̱ na̱sativí yiquí cu̱ñu Jesús cán.
\v 7 Ta na̱xini da ti̱co̱to̱ ña̱ na̱sativí ji̱ni̱ á na̱caxoo jíin ña̱ cán ta na̱nditi̱vi̱ va̱ha ña̱.
\v 8 A̱nda̱ já na̱ndi̱hvi ri da̱ inga cán, da̱ na̱xi̱nu̱ jihna ñúhú. Ta tá na̱xini da ña̱ co̱ó yiquí cu̱ñu Jesús ndáca̱a̱n já na̱candúsa da ña̱ na̱nditacu tucu a.
\v 9 Jáchi̱ co̱ó na̱canda̱a̱ ini na̱ cúú cuéntá mé á ña̱ cáchí tu̱hun Ndióxi̱ nu̱ cáchí a̱ ña̱ nditacu tucu Jesús.
\v 10 Tá na̱ndihi já ndáca táhan ndíví da̱ na̱xi̱ca tuun xi̱hín Jesús cán na̱ndicó co̱o da vehe nu̱ú na̱sa̱nduu na.
\s1 Tá na̱xini María, ñá ñuu Magdala Jesús
\r (Mr. 16:9-11)
\p 
\v 11 Ta nani na̱ya̱ha tócó ndihi ña̱ yóho, na̱ndicó co̱o María mé nu̱ú na̱sa̱ndaca̱a̱n yiquí cu̱ñu Jesús. Sácu ñá íin ñá yuhú cáva̱ cán. Ta nani sácu ñá na̱candayi ñá ndicoto nihni ñá ini cáva̱ cán.
\v 12 Já na̱xini ñá i̱vi̱ táto̱ Ndióxi̱, ña̱ ndíxi jahmá yaa. Ndáa ndúu coo a nu̱ú na̱sahi̱in yiquí cu̱ñu Jesús: in a nu̱ú na̱sahi̱in ji̱ni̱ Jesús ta inga nu̱ú na̱sahi̱in sa̱há.
\v 13 A̱nda̱ já na̱nda̱ca̱ tu̱hún táto̱ Ndióxi̱ cán María já na̱cachi a já xi̱hi̱n ñá:
\p —Ndá cuéntá quéa̱ sácún —na̱cachi a.
\p Já na̱cachi ñá já xi̱hi̱n á:
\p —Sácu u̱ jáchi̱ na̱quehe na yiquí cu̱ñu Jesús, xitoho i̱ ta co̱ xíni̱ ndájá na̱sacu na ña̱ —na̱cachi ña̱.
\p 
\v 14 Tá ja̱cá na̱cachi uun ñá ña̱ yóho já na̱ndicoto nihni ñá já na̱xini ñá in a cándichi a nu̱ ñá já va joo co̱ó na̱ndicuni ñá ña̱ cúú á Jesús.
\v 15 A̱nda̱ já na̱nda̱ca̱ tu̱hún Jesús ña̱ já na̱cachi a já xi̱hi̱n ñá:
\p —Ndá cuéntá quéa̱ sácún. Yo já ndínducún —na̱cachi a.
\p Ta na̱ca̱hán María ña̱ mé da̱ cáha̱n xi̱hi̱n ñá cúú dá da̱ ndáá mé yitó cui̱hi cáa cán. Sa̱há ña̱ cán quéa̱ já na̱cachi ñá já:
\p —Tá na̱tavún yiquí cu̱ñu Jesús ña̱ na̱sa̱ndaca̱a̱n ini cáva̱ yóho, ca̱xi tu̱hún xi̱hín i̱ ndájá na̱sacún ña̱ já ná cu̱hu̱n i̱ ndiquehe e̱ ña̱ —na̱cachi María.
\p 
\v 16 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ña̱:
\p —María.
\p A̱nda̱ já na̱ca̱va̱ nu̱u̱ ñá já na̱ndicuni ñá Jesús ta na̱ca̱ha̱n ñá tu̱hun hebreo xi̱hi̱n á já na̱cachi ñá já:
\p —Raboni —mé tu̱hun yóho cúni̱ cachi a maestro.
\p 
\v 17 Já na̱cachi Jesús já xi̱hi̱n ña̱:
\p —A̱ tíin tuún ye̱he̱. Jáchi̱ a̱ ñáha toho ndindita i̱ cu̱hu̱n i̱ indiví nu̱ íin Ndióxi̱, tátá i̱. Joo cuáhán ca̱xi tu̱hún xi̱hín na̱ cúú cuéntá mí i̱ ña̱ cu̱hu̱n i̱ nu̱ íin Ndióxi̱, tátá i̱, mé a̱ cúú tátá mé ndó viti. Cúú á Ndióxi̱ nu̱ mí i̱ ta cúú ri a Ndióxi̱ nu̱ mé ndó —na̱cachi Jesús.
\p 
\v 18 A̱nda̱ já ndáva María, ñá ñuu Magdala na̱sa̱ha̱n ñá na̱ndicani ñá nu̱ú na̱ na̱xi̱ca tuun xi̱hín Jesús cán ña̱ na̱xini ñá mé á. Ta na̱ndicani ñá ña̱ na̱cachi Jesús xi̱hi̱n ña̱.
\s1 Tá na̱xini na̱ na̱xi̱ca tuun xi̱hín Jesús mé á
\r (Mt. 28:16-20; Mr. 16:14-18; Lc. 24:36-49)
\p 
\v 19 Ta tá na̱cuaá mé qui̱vi̱ domingo cán já na̱nditútú tócó ndihi na̱ na̱xi̱ca tuun xi̱hín Jesús cán. Ñúhu tuun na ini vehe ta na̱chicaji tuun na̱ yéhé jáchi̱ yíhví na̱ xi̱nu̱ na̱ Israel cán tiin ñahá na̱. Ta in cuití na̱xi̱nu̱ co̱o Jesús nu̱ ná ta na̱nda̱ca̱ ndichi a ma̱hñú nda̱a̱ nu̱ ndúu na̱ cán. Já na̱ca̱ha̱n Ndióxi̱ a̱ xi̱hi̱n ná já na̱cachi a já:
\p —Ná coo va̱ha ini ndó —na̱cachi a.
\p 
\v 20 Ta tá na̱cachi a ña̱ yóho já na̱jána̱ha̱ ndáha̱ á xi̱hín yicá ndícá a̱ nu̱ ná ña̱ ná canda̱a̱ ini na ña̱ jivi cúú mé á. Ta na̱caji̱i̱ íní na̱ tá na̱xini na a̱.
\v 21 Tá na̱ndihi já na̱cachi tucu Jesús já xi̱hi̱n ná:
\p —Ná coo va̱ha ini ndó. Tá quia̱hva na̱caja Ndióxi̱, tátá i̱ na̱chindahá a̱ ye̱he̱ ñuyíví yóho quia̱hva já chíndahá ri ye̱he̱ va ndo̱hó cu̱hu̱n ndo̱ ca̱xi tu̱hun ndó xi̱hín ña̱yivi sa̱ha̱ mí i̱ —na̱cachi Jesús.
\p 
\v 22 A̱nda̱ já na̱tivi a nu̱ ná já na̱cachi a já xi̱hi̱n ná:
\p —Ndiquehe ndó ínima̱ yi̱i̱ Ndióxi̱.
\v 23 Ta tá ná caja cáhnu ini ndó sa̱há cua̱chi ña̱yivi, na̱ cán cúú na̱ sa̱ na̱caja cáhnu ini Ndióxi̱ sa̱ha̱. Ta tá ná a̱ cája cáhnu ini ndó sa̱há cua̱chi, na̱ cán cúú na̱ co̱ó na̱caja cáhnu ini Ndióxi̱ sa̱ha̱ —na̱cachi Jesús.
\s1 Tá na̱xini xi̱hín nu̱u̱ Tomás Jesús
\p 
\v 24 In táhan da̱ na̱xi̱ca tuun xi̱hín Jesús, da̱ naní Tomás, da̱ cáha̱n na̱ cuátí xi̱hi̱n cán, co̱ó toho da na̱sahi̱in xi̱hín na̱ cán tá na̱quixi Jesús nu̱ ndúu na.
\v 25 Tá na̱ndihi já na̱ca̱xi tu̱hun na̱ java cán xi̱hi̱n dá já na̱cachi na já:
\p —Na̱xini nde̱ Jesús, xitoho í —na̱cachi na.
\p Já na̱nducú ñehe Tomás tu̱hun nu̱ ná já na̱cachi da já xi̱hi̱n ná:
\p —A̱ cándúsa toho i̱ ña̱ cáchí ndo̱ ja̱nda̱ quia̱hva ná cuni xi̱hín nu̱ú i̱ ndáha̱ Jesús ta já jáqui̱hvi i̱ nducu ndahá i̱ ini yávi̱ nu̱ú na̱qui̱hvi clavo na̱caja na̱ cán. Ta xíní ñúhú jáqui̱hvi i̱ nducu ndahá i̱ ini yávi̱ na̱caán na̱ yicá ndícá a̱ cán. A̱nda̱ jáví candúsa i̱ ndo̱hó —na̱cachi da.
\p 
\v 26 Tá na̱ya̱ha u̱na̱ qui̱vi̱ já na̱ndique táhan tucu na̱ na̱xi̱ca tuun xi̱hín Jesús cán ini in vehe. Ta mé tañu já na̱sahi̱in Tomás xi̱hi̱n ná. Ta quia̱hva já na̱saji tuun tucu na yéhé vehe nu̱ ñúhu na̱ cán. A̱nda̱ já in cuití na̱xi̱nu̱ co̱o Jesús nu̱ ná ta na̱nda̱ca̱ ndichi a ma̱hñú na̱ cán ta na̱ca̱ha̱n Ndióxi̱ á xi̱hi̱n ná já na̱cachi a já xi̱hi̱n ná:
\p —Ná coo va̱ha ini ndó —na̱cachi a.
\p 
\v 27 Tá na̱ndihi já na̱cachi a já xi̱hín Tomás:
\p —Naha quíi̱ jáqui̱hvi nducú ndáhu̱n ini ndahá i̱ ta cande̱hé ini ndahá i̱ nu̱ú na̱qui̱hvi clavo. Ta jáqui̱hvi nducú ndáhu̱n yicá ndícá i̱ já ná cunún nu̱ú na̱jándicue̱he̱ na̱ ye̱he̱. A̱ cáhvi̱ i̱vi̱ jo̱ho inún jáchi̱ xíní ñúhú candúsún ye̱he̱ —na̱cachi Jesús.
\p 
\v 28 A̱nda̱ já na̱catóntó Tomás já na̱cachi da já:
\p —Mé ndó cúú xitoho i̱ ta cúú ndó Ndióxi̱ ña̱ cája cáhnu i̱ —na̱cachi da.
\p 
\v 29 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n dá:
\p —Mé a̱ nda̱a̱ cándúsún ye̱he̱ viti jáchi̱ na̱xinún ye̱he̱. Joo caji̱i̱ ini ña̱yivi, na̱ cándúsa ye̱he̱ va̱tí co̱ó i̱ xíní na̱ xi̱hín nu̱u̱ ná —na̱cachi Jesús.
\s1 Cáha̱n Juan ndá sa̱há na̱ca̱hyí da̱ libro yóho
\p 
\v 30 Cua̱há ndiva̱ha java ga̱ ña̱ xitúhún na̱caja Jesús nu̱ú na̱ na̱xi̱ca tuun xi̱hín a̱ cán va̱tí co̱ ná ca̱hyi̱ a̱ nu̱ libro yóho.
\v 31 Joo ña̱ yóho na̱ca̱hyi̱ a̱ já ná candúsa ndó ña̱ cúú Jesús da̱ na̱chindahá Ndióxi̱ cacomí cuéntá sa̱há ña̱yivi, mé a̱ cúú in túhún ji̱ni̱ já ja̱hyi Ndióxi̱. Ta sa̱há ña̱ cándeé ini ndó mé á cuu catacu ndó a̱nda̱ ama cáa qui̱vi̱.
\c 21
\s1 Náha̱ Jesús mé á nu̱ú u̱sa̱ táhan na̱ na̱xi̱ca tuun xi̱hín a̱ cán
\p 
\v 1 Tá sa̱ na̱ya̱ha ña̱ yóho já na̱na̱ha̱ tucu Jesús mé á nu̱ú na̱ na̱xi̱ca tuun xi̱hi̱n á nani na̱sa̱nduu na yati yuhú tañu̱hú naní Tiberias cán. Ta quia̱hva joho na̱sahi̱in a.
\v 2 In tañu ndúu tútú Simón Pedro xi̱hín Tomás, da̱ cáha̱n na̱ cuátí xi̱hi̱n cán. Ta jári ndúu Natanael, da̱ ñuu Caná cuéntá Galilea cán xi̱hín ndíví da̱ cúú ja̱hyi Zebedeo cán. Ta na̱sa̱nduu ri inga i̱vi̱ ga̱ táhan da̱ na̱xi̱ca tuun xi̱hín Jesús.
\v 3 A̱nda̱ já na̱ca̱ha̱n Simón Pedro xi̱hi̱n tócó ndihi na̱ cán já na̱cachi da já xi̱hi̱n ná:
\p —Cu̱hu̱n i̱ tavá i̱ ti̱yacá —na̱cachi da.
\p —Cu̱hu̱n ri nde̱he̱ va tavá nde̱ ti̱yacá xu̱hu̱n —na̱cachi na̱ cán xi̱hi̱n dá.
\p Já na̱ndi̱hvi ndihi na ini barco cua̱ha̱n na̱ tavá na̱ ti̱yacá. Joo co̱ó ti̱yacá na̱tavá na̱ mé ñuú cán.
\v 4 Ta tá sa̱ cua̱ha̱n ndúcú ti̱vi já na̱canáha̱ Jesús yuhú ticui̱í cán. Joo na̱ na̱xi̱ca tuun xi̱hín a̱ cán co̱ xíni̱ na̱ ña̱ cúú á Jesús.
\v 5 A̱nda̱ já na̱cayuhú Jesús ndáca̱ tu̱hún á na̱ já na̱cachi a já xi̱hi̱n ná:
\p —Á co̱ó toho ti̱yacá na̱tavá ndo̱, ñani —na̱cayuhú a̱.
\p —Co̱ó mé rí ná tavá nde̱ —na̱nducú ñehe na tu̱hun nu̱ á.
\p 
\v 6 A̱nda̱ já na̱cachi tucu Jesús já xi̱hi̱n ná:
\p —Jácana tucu ndó ñúnu̱ ndó chí xoo cuáha barco ja̱n já tavá ndó ri̱ —na̱cachi a.
\p A̱nda̱ já na̱jácana na ñúnu̱ ná cán xoo cuáha barco ta tá na̱ndihi chí co̱ ndéé na̱ tavá na̱ ñúnu̱ cán jáchi̱ a̱ ju̱ú quia̱hva na̱chutú nda̱a̱ ña̱ xi̱hín ti̱yacá.
\v 7 A̱nda̱ já na̱ndica̱ha̱n ye̱he̱, da̱ quíhvi̱ ndiva̱ha ini mé a̱ cán já na̱cachi i̱ já xi̱hi̱n Pedro:
\p —Cúú á Jesús, xitoho í —na̱cachi i̱.
\p Tá na̱xini jo̱ho Simón Pedro ña̱ cúú a̱ cán Jesús já na̱ndicandixi da cotó da̱ jáchi̱ co̱ó toho cotó da̱ ndíxi da, nduu. Tá na̱ndihi já ndáva da cua̱ha̱n da̱ jitá da̱ ticui̱í chí yuhú tañu̱hú cán.
\v 8 Tá na̱ndihi já na̱xi̱nu̱ co̱o java ga̱ na̱ na̱xi̱ca tuun xi̱hín Jesús cán xi̱hi̱n barco na̱ chí yuhú tañu̱hú já ñúhu na ñúnu̱ na̱chutú xi̱hín ti̱yacá cán na̱sa̱a̱ na̱ ja̱nda̱ yúhu̱. Jáchi̱ tátu̱hun in ciento metro na̱sa̱ndichi barco na̱ yuhú tañu̱hú cán tá na̱tavá na̱ ti̱yacá.
\v 9 Tá na̱xi̱nu̱ co̱o na̱ cán nu̱ ñúhu̱ já na̱xini na cáyi̱ ñúhu̱. Ta na̱xini na cánúu in ti̱yacá yáta rí nu̱ ñúhu̱ cán. Ta na̱xini na ña̱ sa̱ íin pan cuxu na viti.
\v 10 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ná:
\p —Taxi ndó java ti̱yacá, rí ja̱cá na̱tavá ndó ja̱n —na̱cachi a.
\p 
\v 11 A̱nda̱ já ndáva Simón Pedro na̱sa̱ha̱n da̱ na̱ndaa da ja̱ta̱ barco cán já ñúhu da ñúnu̱, ña̱ na̱chutú nda̱a̱ xi̱hín ti̱yacá náhnu cán, na̱xi̱nu̱ da̱ ja̱nda̱ yúhu̱. Ta na̱sa̱cuu rí in ciento i̱vi̱ jico sa̱hu̱n u̱ni̱. Ta va̱tí cua̱ha̱ ndiva̱ha cúú rí co̱ó na̱ta̱hnda̱ ñúnu̱ nu̱ú na̱sañuhu rí cán.
\v 12 A̱nda̱ já na̱cachi Jesús já xi̱hi̱n ná:
\p —Naha ndó caji̱ni ndó —na̱cachi a.
\p Ta ni in túhún na̱ cán co̱ó na̱sa̱ha̱n ndeé ini na nda̱ca̱ tu̱hún na̱ yo cúú mé á. Jáchi̱ sa̱ na̱canda̱a̱ cáxí ini na ña̱ cúú á Jesús, xitoho na.
\v 13 Tá na̱ndihi já na̱tiin Jesús pan cán já na̱sahnda java ña̱ já na̱sa̱ha̱n ña̱ nu̱ ná. Ta quia̱hva já na̱caja ri a xi̱hín ti̱yacá va, na̱ndicahnda ri̱ já na̱sa̱ha̱n rí nu̱ ná.
\p 
\v 14 Xi̱hín ña̱ yóho na̱xi̱nu̱ u̱ni̱ tañu na̱na̱ha̱ Jesús mé á nu̱ú na̱ na̱xi̱ca tuun xi̱hi̱n á ja̱nda̱ naní na̱nditacu tucu a.
\s1 Cáha̱n Jesús xi̱hín Simón Pedro
\p 
\v 15 Tá na̱ndihi na̱xiji̱ni na já na̱nda̱ca̱ tu̱hún Jesús Simón Pedro já na̱cachi a já xi̱hi̱n dá:
\p —Simón, da̱ cúú ja̱hyi Jonás á quíhvi̱ ini chágún ye̱he̱ a̱ ju̱ú ga̱ na̱ java yóho —na̱cachi a.
\p Já na̱cachi da̱ cán já:
\p —Mé ndó cúú ndó xitoho i̱ ta sa̱ xíni̱ va̱ha ndó ña̱ quíhvi̱ ini i̱ ndo̱hó —na̱cachi da.
\p Já na̱cachi Jesús já xi̱hi̱n dá:
\p —Xíní ñúhú candaa va̱hún na̱ cúú cuéntá mí i̱ tá quia̱hva ndáá va̱ha pastó ndicachi válí ja̱na̱ dá —na̱cachi a.
\p 
\v 16 A̱nda̱ já na̱cachi tucu Jesús já xi̱hi̱n dá:
\p —Simón, da̱ cúú ja̱hyi Jonás, á quíhvi̱ inún ye̱he̱ —na̱cachi a.
\p A̱nda̱ já na̱cachi da já xi̱hi̱n á:
\p —Mé ndó cúú ndó xitoho i̱ ta cánda̱a̱ va̱ha ini ndó ña̱ quíhvi̱ ini i̱ ndo̱hó —na̱cachi da.
\p Já na̱cachi Jesús já xi̱hi̱n dá:
\p —Xíní ñúhú candaa va̱hún na̱ cúú cuéntá mí i̱ tá quia̱hva ndáá va̱ha pastó ndicachi ja̱na̱ dá —na̱cachi a xi̱hi̱n dá.
\p 
\v 17 A̱nda̱ já na̱nda̱ca̱ tu̱hún tucu a da̱ táhndá u̱ni̱ já na̱cachi a já xi̱hi̱n dá:
\p —Simón, da̱ cúú ja̱hyi Jonás, á mé a̱ nda̱a̱ quíhvi̱ inún ye̱he̱ —na̱cachi a.
\p Tá na̱xini mé Simón Pedro cán ña̱ na̱xi̱nu̱ u̱ni̱ táhndá ndáca̱ tu̱hún Jesús da̱ sa̱há ña̱ yóho já na̱cacuéha̱ ini da já na̱cachi da já xi̱hín Jesús:
\p —Jesús, mé ndó xíni̱ va̱ha ndó tócó ndihi ña̱ha. Mé ndó xíni̱ va̱ha ndó ña̱ quíhvi̱ ini i̱ ndo̱hó —na̱cachi da.
\p Já na̱cachi Jesús já xi̱hi̱n dá:
\p —Xíní ñúhú candaa va̱hún na̱ cúú cuéntá mí i̱ tá quia̱hva ndáá va̱ha pastó ndicachi ja̱na̱ dá.
\v 18 Jáchi̱ mé a̱ nda̱a̱ ná ca̱ha̱n i̱ xu̱hu̱n. Tá na̱sa̱cuún ta̱a yúta̱ chá já ndícandisún jáhmu̱n ña̱ cúnu̱n ta já cua̱hún ndá nu̱ cúni̱ mún cu̱hu̱n. Joo tá ná cayatún já jáca̱ún ndáhu̱n ta inga na jácandixi yo̱hó jáhmu̱n. Ta já tiin ndaa na yo̱hó cu̱hún xi̱hi̱n ná nu̱ú co̱ cúni̱ mún cu̱hu̱n —na̱cachi a.
\p 
\v 19 Xi̱hín ña̱ yóho cúni̱ Jesús ndicani a nu̱ Pedro cán ndá quia̱hva quivi da ña̱ ná caja cáhnu da Ndióxi̱. Tá na̱ndihi já na̱cachi Jesús já xi̱hi̱n dá:
\p —Xíní ñúhú candi̱cún ye̱he̱ —na̱cachi a.
\s1 Ndáca̱ tu̱hún Pedro sa̱ha̱ Juan nu̱ Jesús
\p 
\v 20 Nani xíca na cása̱ha̱n na̱ xi̱hín Jesús já na̱ndicoto nihni Pedro chí ja̱ta̱ dá já na̱xini da tácaa Juan va̱xi da. Mé Juan yóho cúú dá da̱ quíhvi̱ ndiva̱ha ini mé Jesús. Ta sa̱ mé Juan yóho cúú ye̱he̱, da̱ na̱sahi̱in coo jíi̱n á tá na̱xijíni na vicó pascua. Ta cúú ye̱he̱, da̱ na̱nda̱ca̱ tu̱hún mé á sa̱ha̱ ndá da̱ cúú da̱ ji̱có túhún ñahá.
\v 21 Tá na̱xini Pedro ndíco̱ da̱ yóho ja̱ta̱ ná já na̱nda̱ca̱ tu̱hún da̱ Jesús já na̱cachi da já xi̱hi̱n á:
\p —Ta ndaja coo Juan yóho, xitoho i̱. Ndaja quivi da —na̱cachi Pedro.
\p 
\v 22 A̱nda̱ já na̱nducú ñehe Jesús tu̱hun nu̱ dá já na̱cachi a já xi̱hi̱n dá:
\p —Tá cúni̱ ye̱he̱ ña̱ ná catacu da ja̱nda̱ quia̱hva ná xi̱nu̱ co̱o qui̱ví ndicó co̱o i̱ ñuyíví yóho, co̱ ndítahan toho ndi̱hi inún sa̱há. Ña̱ ndítahan cajún quéa̱ candi̱cún ye̱he̱ —na̱cachi a.
\p 
\v 23 Ta sa̱há ña̱ na̱cachi Jesús ña̱ yóho sa̱há ña̱ cán quéa̱ na̱ndicui̱ta nuu tu̱hun tañu tócó ndihi na̱ na̱xi̱ca tuun xi̱hín Jesús cán. Ta cáchí na̱ sa̱há i̱ ña̱ a̱ quíví toho i̱. Joo a̱ ju̱ú toho ña̱ yóho quéa̱ cúni̱ Jesús cachi a xi̱hi̱n ná. Ña̱ na̱cachi Jesús quéa̱ tá cúni̱ mé á catacu u̱ ja̱nda̱ quia̱hva ná ndicó co̱o mé á, co̱ ndítahan toho ndi̱hi ini Pedro sa̱há ña̱ cán.
\p 
\v 24 Ta jivi mé da̱ cáha̱n na̱ sa̱ha̱ cán cúú ye̱he̱, da̱ cáhyí tócó ndihi ña̱ yóho. Ta tócó ndihi na xíni̱ na̱ ña̱ cúú á ña̱ nda̱a̱.
\p 
\v 25 Cua̱há ndiva̱ha nu̱ú ña̱ha na̱caja chága̱ Jesús. Tá ná cacu ini i̱ ca̱hyí i̱ tá in tá in ña̱ na̱caja mé á, cája i̱ cuéntá a̱ quéta toho ñuyíví yóho coo libro ca̱ha̱n sa̱há ña̱ na̱caja mé á. Já ná coo.
