\p
\v 38 Straight away \w the|strong="G2532"\w* man \w said|strong="G5346"\w*, “\w Sir|strong="G2962"\w*, \w I|strong="G2532"\w* \w believe|strong="G4100"\w* \w in|strong="G2532"\w* \w you|strong="G2532"\w*.” \w And|strong="G2532"\w* \w he|strong="G2532"\w* got \w down|strong="G4352"\w* \w on|strong="G1161"\w* \w his|strong="G2532"\w* knees \w in|strong="G2532"\w* front \w of|strong="G2532"\w* \w Jesus|strong="G2532"\w*, \w to|strong="G2532"\w* show \w him|strong="G3588"\w* respect.   
\p
\v 39 \w Then|strong="G2532"\w* \w Jesus|strong="G2424"\w* \w said|strong="G3004"\w*, “\w I|strong="G1473"\w* \w came|strong="G2064"\w* \w to|strong="G1519"\w* \w the|strong="G2532"\w* \w world|strong="G2889"\w* \w to|strong="G1519"\w* judge \w people|strong="G3004"\w*, \w and|strong="G2532"\w* \w to|strong="G1519"\w* \w split|strong="G1096"\w* \w them|strong="G3588"\w* \w into|strong="G1519"\w* 2 mobs. \w One|strong="G3588"\w* mob know \w that|strong="G2443"\w* \w they|strong="G2532"\w* don’\w t|strong="G3588"\w* understand \w the|strong="G2532"\w* \w true|strong="G3588"\w* \w things|strong="G3778"\w* \w about|strong="G1519"\w* \w God|strong="G3004"\w*. \w It|strong="G2532"\w*’s \w like|strong="G2443"\w* \w they|strong="G2532"\w* \w are|strong="G3588"\w* \w blind|strong="G5185"\w*. \w But|strong="G2532"\w* \w they|strong="G2532"\w* \w let|strong="G1096"\w* \w me|strong="G1473"\w* help \w them|strong="G3588"\w* understand \w those|strong="G3588"\w* \w things|strong="G3778"\w*, \w like|strong="G2443"\w* \w I|strong="G1473"\w* \w make|strong="G1519"\w* \w them|strong="G3588"\w* see. \w The|strong="G2532"\w* \w other|strong="G3361"\w* mob think \w they|strong="G2532"\w* understand \w all|strong="G2532"\w* \w about|strong="G1519"\w* \w God|strong="G3004"\w*. \w It|strong="G2532"\w*’s \w like|strong="G2443"\w* \w they|strong="G2532"\w* think \w they|strong="G2532"\w* \w can|strong="G3004"\w* already see, \w so|strong="G2443"\w* \w they|strong="G2532"\w* don’\w t|strong="G3588"\w* \w let|strong="G1096"\w* \w me|strong="G1473"\w* help \w them|strong="G3588"\w*. \w But|strong="G2532"\w* \w they|strong="G2532"\w* don’\w t|strong="G3588"\w* really understand, \w so|strong="G2443"\w* \w it|strong="G2532"\w*’s \w like|strong="G2443"\w* \w they|strong="G2532"\w* stay \w blind|strong="G5185"\w*.”   
\p
