\id ISA - Cishingini Agwara Kambari [asg]
\toc3 Ish
\toc2 Ishaya
\toc1 Katagarda ki Ishaya
\mt2 Katagarda ka
\mt1 ISHAYA
\imt1 Kuɓa̱yuwa̱
\ip Kula ku katagarda ki Ishaya kula ku ɗa ku keneki ka gbayin ko yoku ka na ko yongoi a Urushelima a̱ya̱ n a̱bunda̱i a na a lazai ɗe. Ka yaꞋan ta̱ kadanshi ka atakaci a na iɗika i Yahuda i soꞋi e ekiye aza a Asiriya, n tsu na keneki ka ke ɗekei uma a koɓolo n aza e kelime e le adama a na o yongo n wuma u ciɗa ayin tutu, n tsu na ukpa̱ɗi u kupanaka Ka̱shile u tsu tuka̱ n atakaci. Katagarda ka yaꞋin kpamu kadanshi ke kusheshe ku Ka̱shile a kubana u uma a̱ ni n tsu na a kuyaꞋan n iɗika i na i buwai, n tsu na kpamu o kutono wila̱ u kanna ka Ashibi, n alyuka n kuyaꞋan ka avasa. Ushani u kadanshi ku uyevi punu a katagarda ka u ɗaɗa a masala ma 61:1-2, udani u na Yesu u yaꞋankai ulinga a ayin a na u gita̱i ulinga u ni.
\iot Ili i na yi punu udari a katagarda ka nampa:
\io1 Uɓarangi n uzuwakpani 1:1; 12:6
\io1 Atakaci a iɗika kakau 13:1; 23:18
\io1 Afada a̱ Ka̱shile a̱ kuta̱wa̱ aduniyan 24:1; 27:13
\io1 Uɓarangi u kelime n uzuwakpani 28:1; 35:10
\io1 Mogono Hezikaya vu Yahuda n aza a Asiriya 36:1; 39:8
\io1 Akaka a uzuwakpani koɓolo n a̱pa̱ 40:1--55:13
\io1 Uɓarangi kakau n uzuwakpani kakau feu 56:1; 66:24
\c 1
\p 
\v 1 Kene ku na Ishaya maku ma Amazo we enei adama a Urishelima n Yahuda a ayin o tsugono a Uzaya, n Jotan, n Ahazu, n Hezikaya ngono n Yahuda.
\s1 Iɗika yu ugbamukaci
\q1 
\v 2 Gaɗi pana, ka̱ta̱ avu iɗika vu zuwa atsuvu,
\q2 adama a na Vuzavaguɗu u dansa ta̱,
\q1 <<Muku n na n kumgbasai ɗa n la̱na̱i,
\q2 a yaꞋanka mu ta̱ ugbamukaci.
\q1 
\v 3 Anaka e yeve ta̱ maguɓi me le,
\q2 njaki feu n yeve ta̱ ubuta̱ u na kesheku ke le ke ci neꞋe le ilikulya,
\q1 ama aza a Isaraila e yeve ba,
\q2 uma a̱ va̱ e yeve ba.>>
\q1 
\v 4 A̱ɗa̱ iɗika yu unushi,
\q2 uma a na i tukpa n kawuya,
\q1 ka̱tsura̱ ka aza a̱ nkunu,
\q2 muku n na n nekei ka̱ci ke le adama a kuyaꞋan ku kalyaꞋa.
\q1 A̱ ka̱sukpa̱i uye u Vuzavaguɗu,
\q2 ɗa o goyoi vuza Ciɗa vi Isaraila,
\q2 ali ɗa o bonoi a zuwakai ni kucina̱.
\q1 
\v 5 Yiɗa̱i i zuwai ɗa vu buwai o morono ma adama ali ɗa a buwai a kulyaꞋa kelime n kulapa wu?
\q2 Yiɗa̱i i zuwai ɗa vi a kulyaꞋa kelime n ugbamukaci?
\q1 Kaci ka̱ nu ki gbaga ba,
\q2 ka̱ɗu ka̱ nu kpamu ka̱ ciya̱ ta̱ muna.
\q1 
\v 6 Ili i na i gita̱i punu a ataka e ene a̱ nu, ali a kubana a kaci,
\q2 babu ubuta̱ u na wi gbaga,
\q1 Sai ukpan wo ojuno,
\q2 n untsu, n ajakata,
\q1 I feu uza̱Ꞌi ba,
\q2 ko wali n akashi ko usuri m maniꞋin.
\b
\q1 
\v 7 Iɗika i ɗa̱ yo okpo ta̱ agali,
\q2 ɗa kpamu likuci i ɗa̱ i kula̱i n akina.
\q1 Omoci a isai ashina a̱ ɗa̱,
\q2 a̱ɗa̱ e kene,
\q2 ɗa a̱ la̱nga̱sa̱i ili dem i na e enei punu.
\q1 
\v 8 A̱ ka̱sukpa̱ ta̱ likuci i Urishelima,
\q2 tsu ka̱pa̱m ka kindi ka kashina ki itacishi,
\q1 ko tsu ka̱pa̱m ka na ki a̱ ubuta̱ u kashina ka̱ nɗimbi ma Ayahuda,
\q2 uteku ci likuci i na a lyaꞋi n kuvon.
\q1 
\v 9 Ishi baci Vuzavaguɗu MalaꞋimili
\q2 u buwaka aza o yoku n wuma ba,
\q1 ci ishi ta̱ o kokpo tsu Sodom,
\q2 ka̱ta̱ kpamu tso okpo tsu Gomora.
\b
\q1 
\v 10 Panai kadanshi ka Vuzavaguɗu,
\q2 a̱ɗa̱ na yi tsa aza o tsugono o Sodom,
\q1 panai wila̱ u Ka̱shile ka̱ tsu,
\q2 a̱ɗa̱ na yi tsu uma o Gomora.
\q1 
\v 11 Vuzavaguɗu u danai, <<Ka̱bunda̱i ka alyuka ka̱ ɗa̱,
\q2 yiɗa̱i ki a kuyaꞋanka mu.
\q1 N ciya̱ ta̱ alyuka o kusongu
\q2 a a̱giri koɓolo n anaka a ikyamba ali u laꞋi tsu na n cikalai.
\q1 Mi m mali ma mpasa
\q2 mo obomburom ni nkyon koɓolo nu nraɗika ba.
\b
\q1 
\v 12 <<Ana vu ta̱wa̱i wa̱ va̱,
\q2 yayi we ecei nu ili i nampa,
\q2 a̱ kuka̱ra̱sa̱ punu a ulanga wa̱ a̱Ꞌisa̱?
\q1 
\v 13 Ka̱sukpa̱ kutuka̱ n alyuka a na i ili i makara wa̱ va̱ ba,
\q2 ili i ma̱gula̱ni i nu yo okpo ta̱ ili yu unata a kuta̱wa̱ wa̱ va̱.
\q1 I ci indana ta̱ ka̱ɗiva̱ ko wotoi u savu, n kanna ka Ashibi, n oɓolo a gbayin,
\q2 ama mpa ma̱ kushuku n oɓolo a kavama a̱ unushi a̱ ɗa̱ a nanlo ba.
\q1 
\v 14 N ciga ka̱ɗiva̱ ko wotoi u savu u ɗa̱,
\q2 koɓolo n ka̱ɗiva̱ kakau a na yi n aɗa ba.
\q1 O okpo mu ta̱ ucanuku a kaci ka̱ va̱,
\q2 mo woꞋo ta̱ n kucanuku u ɗa̱.
\q1 
\v 15 Ayin a na baci i ɗengusa̱i ekiye adama a na i yaꞋan kavasa a kubana wa̱ va̱,
\q2 mi ta̱ o kusokongu a̱shi a̱ va̱
\q1 ko i vasa baci n ugbami,
\q2 mi a kupanaka ɗa̱ ba.
\q1 Ekiye a̱ ɗa̱ a̱ na̱mgba̱ ta̱ nu mpasa ma aza a na i n unushi ba.
\q2 
\v 16 SaꞋi i takpa nshinda̱ n ɗa̱.
\q1 Takpai ukuna u wuya u ɗa̱
\q2 kelime ka̱ va̱.
\q1 ka̱sukpa̱i kuyaꞋan ku kawuya,
\q2 
\v 17 piꞋisai kuyaꞋan ku kasingai,
\q1 la̱nsa̱i nwalu n singai,
\q2 ɓa̱nka̱i aza a na i o kusoꞋo atakaci.
\q1 Ɓa̱nka̱i mkpan,
\q2 koɓolo n agapa.
\b
\q1 
\v 18 <<Ta̱wa̱i gogo na ci sheshei koɓolo
\q2 Vuzavaguɗu u danai,
\q1 Ko a na unushi u ɗa̱ u yaꞋin ɗe tsu na ili i ci yaꞋan ushili ka̱u,
\q2 wi ta̱ o kubono wa̱ri ka̱u tsa akaɗa,
\q1 ko u ɗa wi ushili an kejikenle,
\q2 wi ta̱ o kubono wa̱ri an tsugbere.
\q1 
\v 19 Yu ushuku baci ɗa i tonoi,
\q2 yi ta̱ a kulyaꞋa ili i na i laꞋi n kugaꞋan a iɗika ya,
\q1 
\v 20 ama i iwan baci ɗa i yaꞋin ugbamukaci,
\q2 kotokobi ki ta̱ e kupeɗe mpasa n ɗa̱.>>
\p Ɗaɗa ili i na yu uta̱i a̱ una̱ u Vuzavaguɗu.
\s1 Likuci yi unambi wu usuɓi
\b
\q1 
\v 21 Indanai biꞋi tsu na likuci yu uneki u ka̱ɗu
\q2 yo okpoi an kashakanlai.
\q1 Yi ishi ta̱ n kasingai ka̱u
\q2 koɓolo n usuɓi kpamu u tsu yongo ta̱ punu,
\q2 ama gogo na o okpo ta̱ aza a̱ ma̱ga̱la̱ka̱.
\q1 
\v 22 Azurufa a̱ ɗa̱ okpo ta̱ babu a̱miki.
\q2 Ma̱ra̱ ma̱ nu ma na vu laꞋi n kuciga mo okpoi usatari m mini.
\q1 
\v 23 Aza e kelime a̱ ɗa̱ i ta̱ n ugbamukaci,
\q2 okpoi a̱ja̱Ꞌa̱ o oboki,
\q1 okpoi kpamu n ucigi u kalyaꞋa
\q2 koɓolo n ucigi u kisa kuneꞋe.
\q1 A̱ ɓa̱nka̱ aza a na i mkpan ba,
\q2 o doku kpamu e keɓece n ukuna wa aza a na i agapa ba.
\q1 
\v 24 Adama a nannai, Vuzavaguɗu, MalaꞋimili mo Osoji a gaɗi,
\q2 Vuzagbayin va aza a Isaraila u dana ta̱,
\q1 <<To mi ta̱ o kuyotsongu wupa u va̱ wa aza a na a iwain mu,
\q2 ka̱ta̱ kpamu n tsupa wa irala a̱ va̱.
\q1 
\v 25 Mi ta̱ o kubono ma̱ shilika̱ n a̱ɗa̱,
\q2 mi ta̱ a kulapula ukpa̱ɗi u kusuɓa̱ u ɗa̱
\q1 ka̱ta̱ n takpa ukpa̱ɗi u kuyongo ciɗa u ɗa̱.
\q1 
\v 26 Mi ta̱ o kubonoko n ayaꞋinafada a̱ɗa̱ tsu na ishi ɗe n tsumani,
\q2 koɓolo n aza e kuneke odoki tsu na cau ishi.
\q1 Nannai ɗa e kuɗeke ɗa̱
\q2 Likuci ya aza a Usuɓi,
\q2 Likuci yu uneki u ka̱ɗu.>>
\b
\q1 
\v 27 Sihiyona wi ta̱ a̱ kuciya̱ ushibi n kasingai,
\q2 aza a na a̱ shika̱i unushi i ta̱ a kisa le n usuɓi.
\q1 
\v 28 Ama aza a ugbamukaci n aza a̱ unushi i ta̱ a kuyaꞋan wuni,
\q2 aza a na a iwain Vuzavaguɗu i ta̱ a kuyaꞋan uniꞋwa̱ta̱ngi.
\q1 
\v 29 Vi ta̱ a kupana wono adama a maɗanga mo oku
\q2 ma na vu zuwakai ka̱ɗu,
\q1 vi ta̱ o kokpo n wono adama a kashina ki ishiꞋwan
\q2 ka na vu zagbai.
\q1 
\v 30 Vi ta̱ o kokpo an maɗanga mo oku ma na a̱vuku a̱ ni a lumbai,
\q2 tsu kashina ki ishiꞋwan ka na ka nambai mini.
\q1 
\v 31 Vuza vu utsura wi ta̱ o kokpo an ciꞋiwa̱
\q2 ka̱ta̱ ulinga u ni u leɓece a akina.
\q1 Ele n ulinga u kawuya u le i ta̱ a̱ kukula̱ koɓolo,
\q2 babu vuza na u kufuɗa wa̱ kima̱sa̱ akina a nanlo.
\c 2
\s1 Kusan ku Vuzavaguɗu
\p 
\v 1 Na ɗa kene ku na Ishaya maku ma Amazo me enei adama a Yahuda n Urishelima.
\p 
\v 2 A kanna ku uteku,
\q1 kusan ku kpaꞋa ku Vuzavaguɗu ki ta̱ a kuyaꞋan ugiti,
\q2 ki ta̱ o kokpo ku gbayin wa aza a na a buwai,
\q1 ka̱ta̱ a̱ ɗengusa̱ ku ɗa ku laꞋa nsasan n na m buwai dem,
\q2 ka̱ta̱ kpamu iɗika kakau i na i buwai n a̱bunda̱i i shida̱ ɗe.
\p 
\v 3 Uma n a̱bunda̱i i ta̱ a̱ kuta̱wa̱ ka̱ta̱ a dana,
\q1 <<Ta̱wa̱i tsu banai a̱ ubuta̱ u kusan ku Vuzavaguɗu,
\q2 a kpaꞋa ku Ka̱shile ka Yakubu.
\q1 Adama a na u yotsongu tsu uye u ni,
\q2 ka̱ta̱ a̱ tsu tsu tono ura̱ u ni.>>
\q1 Wila̱ u Vuzavaguɗu wi ta̱ a̱ kuta̱ a Sihiyona,
\q2 ka̱ta̱ kadanshi ka̱ ni kuta̱ a Urishelima feu.
\q1 
\v 4 Wi ta̱ a kuyaꞋanka iɗika kakau afada,
\q2 ka̱ta̱ kpamu u tatsukpa vishili u uma n a̱bunda̱i.
\q1 I ta̱ a kulapa otokobi e le a̱ ka̱ta̱la̱ a ɗa,
\q2 ka̱ta̱ kpamu a jara nsara n le mo okpo tsu nkaun n kugeceke ili.
\q1 Iɗika yo kudoku ya̱ shilika̱ n iɗika i yoku ba,
\q2 ko o doku o yotsongbonoi tsu na a kuyaꞋan kuvon kpamu.
\b
\q1 
\v 5 A̱ɗa̱ ntsukaya n Yakubu,
\q2 ta̱wa̱i tsu walai a̱ ubuta̱ u kutashi ku Vuzavaguɗu.
\s1 Kanna ka Vuzavaguɗu
\q1 
\v 6 Mayun Vuzavaguɗu vu ka̱sukpa̱ ta̱ uma a̱ nu
\q2 aza a kpaꞋa ku Yakubu
\q1 adama a na a shana ta̱ n ukuna u tsuboci wa aza a kasana,
\q2 o yongoi a kuyaꞋansa ulinga u kula̱na̱ tsa aza A̱filisiya̱
\q1 ɗa o ɓolongi una̱ n aza o kutono a̱ma̱li.
\q1 
\v 7 Iɗika i le i shana ta̱ n Azurufa koɓolo n azanariya,
\q2 uciyi u le wi n uteku ba.
\q1 Iɗika i le i shana ta̱ n odoku,
\q2 ekeke o odoku e le i n uteku n kula ba.
\q1 
\v 8 Iɗika i le i shana ta̱ n a̱ma̱li kakau,
\q2 a ci cikpa ta̱ ili i na a yaꞋin n ka̱ci ke le,
\q2 i na ekiye e le a yaꞋin.
\q1 
\v 9 Adama a nannai i ta̱ o kubonoko vuma ukuna u gbani,
\q2 umaci u vuma dem u ciya̱ ugoyi,
\q2 adama a nannai ka̱ta̱ vu cinukpaka le ba.
\b
\q1 
\v 10 Banai i uwa a akpanlai
\q2 ka̱ta̱ i sheɗeku punu a kayala,
\q1 adama o wovon u Vuzavaguɗu
\q2 koɓolo n ugaꞋin u tsugbayin u ni.
\q1 
\v 11 A̱shi a vuza va a̱ra̱ɗi i ta̱ a̱ kuciya̱ kugoyi,
\q2 ka̱ta̱ a̱ra̱ɗi a uma a yaꞋan ucipiki,
\q1 ka̱ta̱ yeve Vuzavaguɗu endeꞋen u ciya̱ ucikpi a kanna ka nanlo.
\b
\q1 
\v 12 Vuzavaguɗu MalaꞋimili u zagba ta̱ ɗe kanna
\q2 ka na aza a na i n a̱ra̱ɗi n ugbamukaci,
\q2 ele na a tsu kungbasa ka̱ci ke le
\q2 ra̱ka̱ ci le i ta̱ a kuyaꞋan ugoyi.
\q1 
\v 13 Uma a ugaɗi tsu nɗanga n sida\f + \fr 2:13 \ft Sida maɗanga mo yoku maꞋa ma na mo yotsoi maɗanga ma kakawu\f* n Lebano i ta̱ a kuyaꞋan wuni,
\q2 nannai ɗa feu a kuyaꞋan n uma a gbagbaꞋin ra̱ka̱ a na i tsu nɗanga n Oku ma aza a Bashan,
\q1 
\v 14 nu nsasan mu ugaɗi dem
\q2 ali n aginda a ugaɗi feu,
\q1 
\v 15 mashilya mu ugaɗi de dem
\q2 koɓolo m mashilya ma gbayin,
\q1 
\v 16 n antsu a gbagbaꞋin a̱ mini dem a na i a Tarishi
\q2 n antsu e kenkeꞋen a singai feu.
\q1 
\v 17 Ugbamukaci u vuma wi ta̱ a̱ kuciya̱ kugoyi,
\q2 ka̱ta̱ a̱ra̱ɗi a uma a yaꞋan ucipiki,
\q1 ka̱ta̱ yeve Vuzavaguɗu endeꞋen u ciya̱ ucikpi a kanna ka nanlo,
\q2 
\v 18 ka̱ta̱ a̱ma̱li a̱ puwa̱nka̱ gbende-gbende.
\b
\q1 
\v 19 Uma i ta̱ a kusuma a kuꞋuwa a aɓatsu punu a akpanlai
\q2 koɓolo n enle punu a iɗika,
\q1 adama a wovon u Vuzavaguɗu
\q2 koɓolo n ugaꞋin u tsugbayin u ni
\q2 a ayin a na baci u ɗa̱nga̱i ɗa u gba̱ɗa̱i iɗika.
\q1 
\v 20 A kanna ka nanlo uma i ta̱ a kuvakanku
\q2 mpopi n a̱zuwa̱
\q1 a̱ma̱li a na a yaꞋin n Azurufa n a na a yaꞋin n azanariya dem,
\q2 a na a yaꞋankai ka̱ci ke le adama a na a cikpa.
\q1 
\v 21 I ta̱ a kusuma kubana a aɓatsu a gbagbaꞋin
\q2 a na i a akpanlai n amgbu
\q1 adama o wovon u Vuzavaguɗu
\q2 koɓolo n ugaꞋin u ni,
\q2 a ayin a na baci u ɗa̱nga̱i kugba̱ɗa̱sa̱ iɗika.
\q1 
\v 22 ka̱sukpa̱ kuneke katsura ka̱ nu u vuma,
\q2 a̱yi na wi n ikyamba nu mpasa.
\q1 A̱yi yiɗa̱i tamkpamu wi?
\c 3
\s1 Afada adama a Urishelima n Yahuda
\q1 
\v 1 Indana, Vuzavaguɗu,
\q2 Ka̱shile ko osoji a gaɗi,
\q1 wi ta̱ a kuciga kutakpa Urushelima n Yahuda ili ra̱ka̱ i na a zuwakai katsura.
\q2 Wi ta̱ a kutakpa ubuta̱ u na a̱ ci ciya̱ ilikulya
\q1 n ubuta̱ u na a̱ ci ciya̱ mini dem a Urishelima koɓolo n Yahuda,
\q2 
\v 2 kovonshi koɓolo n kosoji,
\q2 kayaꞋinkafada n keneki,
\q1 aza a kindana koɓolo nu nkoshi m gba̱ra̱-gba̱ra̱,
\q1 
\v 3 vuza kelime vu kinda osoji amangerenkupa n vuza vu tsugbayin,
\q2 aza o odoki, eyevi koɓolo n aza a kindana.
\q1 
\v 4 Mi ta̱ a kuzuwa a̱ɗa̱nga̱ni okpo aza gbagbaꞋin e le,
\q2 muku tamkpamu n lyaꞋaka le tsugono.
\q1 
\v 5 Uma i ta̱ a kutakacikanai,
\q2 yaba dem n vuza ni, yaba dem kpamu n vuza na i ida̱shi ɗeɗevu.
\q1 A̱ɗa̱nga̱ni i ta̱ o kugoyo nkoshi,
\q2 ka̱ta̱ aza a na i ili i yoku ba o goyo aza a na i n tsugbayin.
\b
\q1 
\v 6 Vuza wi ta̱ a̱ kuka̱na̱ vuza ni
\q2 a kpaꞋa ke esheku a̱ ni ka̱ta̱ u dana,
\q1 <<Vi ta̱ n kuminya, okpo vuza kelime vu tsu,
\q2 la̱na̱ ka̱kiza̱ ka agali ka nampa ka.>>
\q1 
\v 7 Ama a kanna ka nanlo wi ta̱ a̱ kushika̱ n ka̱la̱ka̱tsu ka̱u a kudana,
\q2 <<Mi n a̱guma̱ ba.
\q1 Mi n tsuwaꞋa ko akashi a kpaꞋa ku va̱ ba,
\q2 ka̱ta̱ vu zuwa mu mo okpo vuza kelime vu uma ba.>>
\b
\q1 
\v 8 Adama a na Urushelima wi ta̱ a̱ kuta̱ɗa̱tsa̱,
\q2 Yahuda wi ta̱ a̱ kuyikpa̱,
\q1 kadanshi ke le n ulinga u le ka̱ uta̱ u Vuzavaguɗu ba,
\q2 a kushika tsugbayin ci ni a̱yi e kene.
\q1 
\v 9 Kindi ku a̱shi ku le kuyotsongu ta̱ tsu na i,
\q2 a̱ uta̱i e keteshe a̱ ubuta̱ u kuyaꞋan ku unushi u le tsu Sodom
\q2 babu usokongi.
\q1 Ili ya atakaci i ɗa a kubana we le,
\q2 o ronoko ta̱ ka̱ci ke le kadama.
\b
\q1 
\v 10 Danai aza a usuɓi e le i n kadama ko yoku ba,
\q2 a kupana ta̱ uyoꞋo wu ulinga wu usuɓi u na a yaꞋin.
\q1 
\v 11 Ili ya atakaci i ɗa a kubana wa aza a kawuya, kagbanigbani ki ta̱ a kaci ke le,
\q2 i ta̱ a kutsupa le adama a ili i na ekiye e le a yaꞋin.
\b
\q1 
\v 12 A̱ɗa̱nga̱ni takacikai uma a̱ va̱,
\q2 a̱ma̱ci lyaꞋi tsugono we le.
\q1 A̱ɗa̱ uma a̱ va̱, aza e kelime a̱ ɗa̱ a uka ɗa̱ ta̱ a kakamba,
\q2 a ɓatsai n a̱ɗa̱ i ka̱sukpa̱i uye.
\b
\q1 
\v 13 Vuzavaguɗu u da̱sa̱ngu ta̱ a kakuba ka afada ka̱ ni,
\q2 u ɗa̱nga̱ ta̱ adama a na u yaꞋanka uma a̱ ni afada.
\q1 
\v 14 Vuzavaguɗu wi ta̱ a kuyaꞋan afada,
\q2 aza e kelime n aza gbagbaꞋin a uma a̱ ni, u danai,
\q1 <<A̱ɗa̱ ɗa i la̱nga̱sa̱i kashina ki itacishi ka̱ va̱,
\q2 i ɓolongi a iꞋuwa i ɗa̱ ili i na i pura̱i a ubuta̱ wa aza a unambi.
\q1 
\v 15 Vuzavaguɗu vo osoji a gaɗi u danai, yiɗa̱i vi cigai n kuminjarangu uma a̱ va̱
\q2 ɗa kpamu vi iyai a̱shi a aza a unambi?>>
\b
\q1 
\v 16 Vuzavaguɗu u danai,
\q2 a̱ma̱ci a Sihiyona i ta̱ n kadanshi ka̱ a̱ra̱ɗi,
\q1 a kuwala n lelei eɗeku ci ishakau,
\q2 a kuyaꞋan kuyun n a̱shi e le,
\q1 ɗa kpamu i a kudasa n adyangi ɗeɗevu,
\q2 n nshingi m gba̱ra̱-gba̱ra̱ u uki a asangulu e le.
\q1 
\v 17 Adama a nannai, Vuzavaguɗu wi ta̱ a kuzuwa usa̱n a aci a̱ a̱ma̱ci a Sihiyona,
\q2 u zuwa aci e le o okpo n kukpani.
\p 
\v 18 A kanna ka nanlo Vuzavaguɗu wi ta̱ a kisa ili dem i na i ci neke yi ugaꞋin, ilikuɗeku, nshingi ma asangulu, n vutali vu kaci,
\v 19 ili ya atsuvu, m mawaru ma̱ kuyun, koɓolo n ka̱ka̱la̱bi,
\v 20 ogoni a kaci, ni nshingi ma asangulu i n kazuwatsu, n kuluba vu maniꞋin ma̱ ma̱gula̱ni koɓolo n alaꞋwin,
\v 21 nkawani mu urotu u ka̱ta̱mba̱ri nu nkawani n vunu,
\v 22 n aminya a singai, nu ntogu, n a̱bu koɓolo n azuwatsu,
\v 23 m mindatsu, koɓolo n kuminya ku urumbuki n vutali vu kaci koɓolo m kalaba.
\q1 
\v 24 A na wa yaꞋan ma̱gula̱ni vi ta̱ o kubono ushami,
\q2 a na wa yaꞋan kaɗambura wi ta̱ o kubono kawin,
\q1 a na wa yaꞋan ka̱nji ka na a lapulai sa̱wu wi ta̱ o kubono kukpani,
\q2 a na wa yaꞋan kuminya ku singai wi ta̱ o kubono kakashi,
\q2 a na wa yaꞋan n tsuloboi wi ta̱ o kubono ili i wono.
\q1 
\v 25 Ali a̱ ɗa̱ i ta̱ a kubana ukpa̱ u kotokobi,
\q2 osoji a̱ ɗa̱ i ta̱ a̱ kukuwa̱ a ubuta̱ u kuvon.
\q1 
\v 26 Utsutsu u Sihiyona wi ta̱ a̱ kushika̱ ka̱ta̱ kpamu u yongo n una̱mgbuka̱tsuma̱,
\q2 wi ta̱ a̱ kuda̱sa̱ngu a iɗika koshomboɗi.
\c 4
\p 
\v 1 A kanna ka nanlo a̱ma̱ci e cindere i ta̱ a̱ kuka̱na̱ vali vi te ka̱ta̱ a dana, <<Ci ta̱ a̱ kuɓa̱na̱ ka̱ci ka̱ tsu ka̱ta̱ kpamu tsu tsulaka ka̱ci ka̱ tsu akashi, ka̱sukpa̱ e ɗeke tsu n kula ku nu. Takpaka tsu wono u nampa.>>
\s1 Masaɓu ma Vuzavaguɗu
\p 
\v 2 A kanna ka nanlo Masaɓu ma Vuzavaguɗu mi ta̱ a̱ kugaꞋan ka̱ta̱ kpamu ma̱ ciya̱ tsugbayin, ka̱ta̱ umaci wi iɗika ya wo okpo ili ya a̱ra̱ɗi koɓolo n tsugbayin tsa aza a na a laꞋakai a Isaraila.
\v 3 Aza a na o okpoi a Sihiyona, n ele vu na a buwai a Urishelima i ta̱ e kuɗeke le uma a ciɗa, a̱yi na baci dem kula ku ni ki uɗani a̱ ka̱tsuma̱ ka aza a na a kubuwa n wuma a Urishelima.
\v 4 Vuzavaguɗu wi ta̱ a̱ kuza̱Ꞌa̱ unata wa̱ a̱ma̱ci wa aza a Sihiyona, wi ta̱ a kutakpa mpasa n na n taɗakpakai aza a Urishelima n utsura wa ayinviki a afada koɓolo n ayinviki a akina.
\v 5 Vuzavaguɗu wi ta̱ a kupala Kusan ku Sihiyona n aza a na o ɓolongi ɗe n keleshu ka̱ a̱miki koɓolo n ka̱nga̱ a kanna dem, n kutashi ka akina n kayin dem. Tsugbayin tsu Vuzavaguɗu ci ta̱ a kuyaꞋan an ka̱pa̱m ka gbayin ka na ka tsu pala ubuta̱ dem.
\v 6 Wi ta̱ o kokpo ubuta̱ u kuvuka n kulu adama a usuɗukpi u kanna, koɓolo kpamu n ubuta̱ u kusheɗeku n u kuyongo adama a̱ mini ma na u kuyoꞋo n akpanga.
\c 5
\s1 Vishipa vu kashina ki itacishi
\p 
\v 1 Mi ta̱ a kuyaꞋanka macigi ma̱ va̱
\q2 vishipa vu kashina ki itacishi i ni,
\q1 macigi ma̱ va̱ mi ta̱ n kashina ki itacishi
\q2 a ubuta̱ u tsuta̱ wu uɓon wu nsasan.
\q1 
\v 2 Ɗa u za̱ɗukpa̱i iɗika ya, ɗa u ɓolongi atali a na i punu,
\q2 ɗa u shikpa̱i nɗanga mi itacishi i na u laꞋi n kuciga.
\q1 U maꞋi punu mashilya ma vuza kindi
\q2 ɗa u doku u lapulai lo ubuta̱ u kupisha umaci u mambulu wa.
\q1 U la̱nsa̱i icuꞋu yu umaci wu nɗanga i singai,
\q2 ama i ɗa i matsai umaci u gbani-gbani.
\q1 
\v 3 <<Gogo na a̱ɗa̱ aza a̱ ida̱shi a Urishelima n uma a Yahuda,
\q2 yaꞋankai tsu afada a nampa mpa n kashina ki itacishi ka̱ va̱.
\q1 
\v 4 Yiɗa̱i yi ishi i gaꞋin n yaꞋan n kashina ki itacishi ka̱ va̱
\q2 u laꞋi i na n yaꞋin ɗe?
\q1 Ana n sheshei mi ta̱ a̱ kuciya̱ umaci u singai,
\q2 yiɗa̱i i zuwai ɗa i kpa̱ɗa̱i kumatsa umaci u mambulu u singai?
\q1 
\v 5 Gogo na mi ta̱ a kudana wu
\q2 ili i na n kuyaꞋan n kashina ki itacishi ka̱ va̱.
\q1 Mi ta̱ a kutakpa ubaru u na mi ishi n zuwai va,
\q2 ka̱ta̱ ta na ka yaꞋan ula̱nga̱shi,
\q1 ka̱ta̱ m ɓoso mashilya ma,
\q2 ka̱ta̱ ta na a dasasa kaꞋa.
\q1 
\v 6 Mi ta̱ o kubonoko kaꞋa ka̱pula̱ka̱,
\q2 babu ukanaꞋi ko ucimbi
\q2 ka̱ta̱ mataci n awana o gbonguro punu.
\q1 Mi ta̱ a kudana Ka̱shile
\q2 ko yoꞋo mini punu ba.>>
\b
\q1 
\v 7 Adama a na kashina ki itacishi ka Vuzavaguɗu MalaꞋimili
\q2 kpaꞋa ki Isaraila ku ɗa,
\q1 aza a Yahuda
\q2 ele ɗa ica̱Ꞌa̱shi i singai i na u cigai.
\q1 U la̱nsa̱i kasingai ama ɗa kucikpa we enei kutsuwa̱n ku mpasa,
\q2 wi indanai ko u kuciya̱ ta̱ usuɓi ɗa kucikpa u panai ma̱shi ma̱ vishili.
\s1 Atakaci koɓolo n afada
\q1 
\v 8 Ili ya atakaci i ɗa a kubana wa aza a na a tsu tsula iꞋuwa kakau n a̱bunda̱i
\q2 koɓolo n uba̱nga̱ u kumaꞋa kakau n a̱bunda̱i
\q1 ali ubuta̱ dem u kotso,
\q2 ka̱ta̱ vi yongo endeꞋen a̱ ubuta̱ wa.
\p 
\v 9 Vuzavaguɗu MalaꞋimili u yaꞋan ta̱ kadanshi atsuvu a̱ va̱ a kupana,
\q1 <<Mayun iꞋuwa n a̱bunda̱i yi ta̱ o kokpo agali,
\q2 ka̱ta̱ iꞋuwa i gbagbaꞋin yo okpo lekeɗi babu vuza punu.
\q1 
\v 10 Nsala kupa n kashina ki itacishi ki ta̱ a̱ kuta̱ m ma̱kya̱n ma aza a Yahuda kenu gbani, nca̱Ꞌa̱tsu kupa mi icuꞋu mi ta̱ a kumatsa ma̱ca̱Ꞌa̱tsu me te koci.>>
\b
\q1 
\v 11 Ili ya atakaci i ɗa a kubana wa aza a na a̱ tsu ɗa̱nga̱ n usana
\q2 a̱ kula̱nsa̱ ma̱ra̱,
\q1 ka̱ta̱ o yongo ɗe ali kayin ka gbayin
\q2 o kusoꞋo ali ma maka le.
\q1 
\v 12 I ta̱ n umolu koɓolo n ugogi a̱ ubuta̱ u ka̱ɗiva̱ ki ilikulya ke le,
\q2 m medele mi ishipa n vushari koɓolo m ma̱ra̱,
\q1 ama babu kukeɓece n ukuna wi ili i Vuzavaguɗu,
\q2 ko e keɓece kpamu n ili i na u yaꞋin.
\q1 
\v 13 Adama a nannai uma a̱ va̱ i ta̱ a kubana tsugbashi a iɗika i yoku
\q2 adama a unambi u kuyeve,
\q1 aza a na i n tsugbayin i ta̱ a̱ kukuwa̱ n kambulu,
\q2 ka̱ta̱ aza a na a buwai kpamu a̱ kuwa̱ n kakuli.
\q1 
\v 14 Adama a nannai kasaun ko yongoi a kulapula kelentsu ka̱ ni
\q2 ɗa ka̱ ɓa̱yuwa̱i una̱ u ni n wanshi ka̱u,
\q1 ciya̱ ugaꞋin u Urishelima n ka̱bunda̱i ka uma a̱ ni ka̱ zura̱ngu punu a asuvu.
\q2 Aza a gbagbaꞋin n aza a kacaꞋa a na i lo dem, i ta̱ a̱ kuzura̱ngu punu.
\q1 
\v 15 Umaci u vuma dem ra̱ka̱ wi ta̱ a̱ kuciya̱ ugoyi
\q2 ka̱ta̱ o bonoko vuma ukuna u gbani,
\q1 a̱shi a vuza va̱ a̱ra̱ɗi i ta̱ a kuyaꞋan ugoyi.
\q1 
\v 16 Ama Vuzavaguɗu MalaꞋimili wi ta̱ a̱ kuciya̱ ucikpi, adama a kasingai ka̱ ni,
\q2 ka̱ta̱ Ka̱shile ka ciɗa ko yotsongu ka̱ci ka̱ ni ciɗa n utsura wu usuɓi u ni.
\q1 
\v 17 Nkyon mi ta̱ a kulina ba̱ri tsu ubuta̱ u kalina u le,
\q2 ka̱ta̱ muku mu nlala n lina a agali a aza a̱ uciyi.
\b
\q1 
\v 18 Ili ya atakaci i ɗa a kubana wa aza na i o kurono unushi o kutono le ka̱ca̱pa̱ n kawin ko modoruko,
\q2 o kurono kawuya m mabana ma awin,
\q1 
\v 19 ele na i a kudana, <<YaꞋan Ka̱shile ka yaꞋan gogoꞋo,
\q2 yaꞋan u dakaka ulinga u ni
\q1 ciya̱ ce ene u ɗa.
\q2 YaꞋan kusheshe ku Vuza ciɗa va aza a Isaraila ku yawa ɗevu,
\q2 ka̱ta̱ ku lyaꞋa kelime, ciya̱ ci yeve ku ɗa.>>
\b
\q1 
\v 20 Ili ya atakaci i ɗa wa aza a na e ci ɗeke kawuya ili i singai,
\q2 kasingai tamkpamu e ɗeke yi kawuya,
\q1 aza a na o tsu bonoko ka̱yimbi kokpo kutashi,
\q2 kutashi tamkpmu kubono ka̱yimbi.
\q1 Aza a na o tsu bonoko okono o okpo uyoꞋo,
\q2 uyoꞋo tamkpamu u bono ili yo okono.
\b
\q1 
\v 21 Ili ya atakaci i ɗa a kubana wa aza na i n ugboji a̱ a̱shi e le,
\q2 n kuyeve ku ka̱ci ke le feu.
\b
\q1 
\v 22 Ili ya atakaci i ɗa a kubana wa aza a gbagbaꞋin o osoꞋi a̱ ma̱ra̱,
\q2 koɓolo n aza a na e yevei kumbuku ma̱ra̱ mayin,
\q1 
\v 23 ele na a tsu isaka aza a unushi kadanshi n utsura u katsupu u na e kuneke le,
\q2 ka̱ta̱ a nanna ka singai ka vuza na wi n ka mayun.
\q1 
\v 24 Adama a nannai, tsu na melentsu ma akina ma tsu laɓana ciꞋiwa̱,
\q2 n tsu na kpamu mita̱ me ci leɓece a akina.
\q1 Nannai ɗa aralu e le a kushama
\q2 ka̱ta̱ a̱pa̱lu e le o ɗoɗo ali wunla̱i u ɗika tsu kubuta̱,
\q1 adama a na a iwan ta̱ wila̱ u Vuzavaguɗu MalaꞋimili
\q2 ɗa kpamu o goyoi kadanshi ka Vuza ciɗa va aza a Isaraila.
\q1 
\v 25 Adama a nannai wupa u Vuzavaguɗu wi ta̱ a̱ kukula̱ adama a uma a̱ ni,
\q2 kukiye ku ni ku ba̱rukpa̱ ta̱ ɗa ku lapai le.
\q1 Nsasan m gba̱ɗa̱i,
\q2 ɗa even a ikyamba o okpoi an ka̱viri a uye u wawaꞋa u likuci.
\b
\q1 Ama ko n nannai dem, wupa u ni u kotso ba,
\q2 kukiye ku ni ku buwa ta̱ uba̱rukpi.
\b
\q1 
\v 26 U ɗengusa̱i kakashi ku urotu adama a iɗika i na yi dadaꞋin,
\q2 u yaꞋankai aza a na i a uteku wa aduniyan izumgbi n yula̱.
\q1 Ele ta na a̱ ta̱wa̱i n ilaɗi m moloko.
\q1 
\v 27 Ko vuza te vi le woꞋo ko u ta̱ɗa̱tsa̱ ba,
\q2 babu vuza na u gbaɗikai ko u latai,
\q1 babu kaɗambura ka̱ kuyun ka na ka̱ ɗa̱mba̱i
\q2 ko vunu vu kataka vu na vu kasai.
\q1 
\v 28 AyaꞋa e le i ta̱ lyalyaꞋan,
\q2 utan u le gbende wi ta̱ ukatsuki,
\q1 ɗaka va adasukpatsu vo odoku e le wi ta̱ ugbami an katali ka̱ a̱ta̱nza̱ri,
\q2 anci a ekeke o odoku e le a kuwala an kabatalikpau.
\q1 
\v 29 Izumgbi i le ci izumgbi i kawu,
\q2 a̱ yura̱ tsu muku mi ikawu,
\q1 yura̱ tsu na a tsu kiyangu nnama n na a tsu takuma
\q2 ka̱ta̱ a lazaka babu vuza na u kisa le.
\q1 
\v 30 A kanna ka nanlo i ta̱ a kuyaꞋan yura̱
\q2 tsu na mala ma tsu vutsukpa n yura̱.
\q1 Vuza wi inda baci a iɗika i ɗekpu,
\q2 wi ta̱ e kene ka̱yimbi n atakaci,
\q2 ko kutashi ki ta̱ o kubono ka̱yimbi adama e eleshu.
\c 6
\s1 Ka̱shile ke ɗekei Ishaya
\p 
\v 1 A̱ ka̱ya̱ ka na mogono Uzaya u kuwa̱i, ɗa me enei Vuzavaguɗu ida̱shi zuva a kakuba ko tsugono n tsugbayin, ɗa wanshi u kuminya u ni u shanai A̱Ꞌisa̱ a gbayin.
\v 2 Anan Corobin\f + \fr 6:2 \ft Corobin ili i wuma i ɗa n evelyu\f* a shamgbai ɗe a gaɗi vi ni, yaba dem vi le n evelyu a̱ ta̱li, ere a ɗa a palakai a̱shi, e re kpamu a palakai ene, ere a na a buwai a ɗaɗa a na i a kuyaꞋanka ciɗinkpi.
\v 3 E meɗekenshenei,
\q1 <<Vuza ciɗa, vuza ciɗa, vuza ciɗa a̱yi ɗa Vuzavaguɗu MalaꞋimili,
\q2 iɗika dem i shana ta̱ n tsugbayin ci ni.>>
\v 4 Adama a kacaꞋa ka̱ ka̱la̱ka̱tsu ka vuza na u yaꞋin meɗevile ɗa iga̱Ꞌin a̱ utsutsu a̱ gba̱ɗa̱i ali n uvari wa dem, ɗa a̱Ꞌisa̱ a gbayin a shanai n ka̱nga̱.
\p 
\v 5 N danai, <<Ili ya atakaci i ɗa a kubana wa̱ va̱, n yawa ta̱ uteku, mpa una̱ u va̱ u tsu gaꞋan ba, ɗa kpamu mi o kuyongo n uma a na i n kadanshi ka singai a̱ una̱ u le ba. Me ene ta̱ Mogono ma, Vuzavaguɗu MalaꞋimili n a̱shi a̱ va̱.>>
\p 
\v 6 Corobin vi te vi imkpai ɗa vu ta̱wa̱i wa̱ va̱ n ka̱ga̱ruwa̱shi e kukiye ku ni, ka na u kaɓai n ikaɓatsu ya akina ɗe a katalikalyuka.
\v 7 Ɗa u saꞋwai una̱ u va̱ n ka̱ga̱ruwa̱shi ka ɗa u danai, <<Indana, ili i nampa i saꞋwa ta̱ una̱ u nu, a takpa ta̱ kawuya ka̱ nu, ɗa kpamu a cinukpakai nu unushi u nu.>>
\p 
\v 8 Ɗaɗa m panai ka̱la̱ka̱tsu ka Vuzavaguɗu a kudana, <<Yayi n kusuku? Yayi u kubana ka tsu?>>
\p Ɗa mu ushuki, <<Mpa ɗa na. Suku mu.>>
\v 9 Ɗaɗa u danai, <<Bana vu dana uma a nampa,
\q1 << <Yi ta̱ a kupana mayin, ama ye kuyeve ba.
\q2 Yi ta̱ a kinda mayin, ama ya̱ kuka̱na̱ punu ili ba.>
\q1 
\v 10 Zuwa a̱ɗu a uma a nampa a kpanduku,
\q2 vu votsuku atsuvu e le
\q2 ka̱ta̱ kpamu vu pala a̱shi e le.
\q1 Nannai ɗa baci ba, i ta̱ a̱ kene n a̱shi e le,
\q2 ka̱ta̱ a pana n atsuvu e le,
\q2 e yeve n a̱ɗu e le
\q1 ka̱ta̱ a sabaꞋa o potso.>>
\p 
\v 11 Ɗaɗa me ecei, <<Ali makyan me ne maꞋi, Vuzavaguɗu?>>
\p Ɗa wu ushuki mu,
\q1 <<Ali sai ayin a na iɗika kakau yo okpoi agali
\q2 babu vuza vi ida̱shi ɗe,
\q1 sai ayin a na iꞋuwa yo okpoi lekeɗi,
\q2 ashina feu o bonoi a̱pula̱ka̱,
\q1 
\v 12 sai ayin a na Vuzavaguɗu u suki yaba dem daꞋin,
\q2 ɗa iɗika ya yo okpoi lekeɗi.
\q2 
\v 13 Ko ka̱pa̱m ka uma kaꞋa baci ko okpoi koci,
\q2 ko ta na a una le baci feu.
\q1 Ama tsu na a̱gunli o tsu okpo
\q2 a ayin a na baci a kapai nɗanga,
\q2 ta feu uma o yoku a na n zagbai o kokpo nannai.>>
\c 7
\s1 A̱ suki Ishaya a kubana u mogono Ahazu
\p 
\v 1 Ayin a na Ahazu, kolobo ko Jotan matsukaya ma Uzaya u lyaꞋi tsugono ci Yahuda, n Rezin mogono ma Siriya, m Paka kolobo ka Ramaliya mogono ma aza a Isaraila o foɓusoi kubanka aza a Urushelima n kuvon. N nannai dem a fuɗa a yaꞋan ili i yoku ba.
\p 
\v 2 Gogo na a dana ta̱ kpaꞋa ku Dawuda, <<Siriya u yaꞋan ta̱ una̱ u te n Ifirayimu.>> Ɗaɗa ka̱ɗu ka Ahazu n ka uma a̱ ni a̱ gba̱ɗa̱i, tsu na nɗanga n kakamba n tsu gba̱ɗa̱ adama a̱ wunla̱i.
\p 
\v 3 Ɗaɗa Vuzavaguɗu u danai Ishaya, <<Uta̱ avu n kolobo ka̱ nu Shiya-jashubu, adama a na i cina ɗe Ahazu a uteku u ma̱ka̱riki ma na me ci yene mini ɗe a kaginda ka kadaɓa ka na ki ɗevu n uye a̱ ubuta̱ u na a̱ tsu za̱Ꞌa̱ akashi.
\v 4 Dana yi, <YaꞋan mayin, shamgba bini ka̱ta̱ kpamu vu pana wovon ba. Ka̱ta̱ ka̱ɗu ka̱ nu ka̱ muɗa̱ adama a̱ ngunli ma akina n re n nampa n na mi a̱ kulula̱ na ba, ko adama a wupa u gbani-gbani u Rezin n Asiriya koɓolo n wu muku u Ramaliya ba.
\v 5 Aram n Ifirayimu koɓolo m muku n Ramaliya o foɓuso ta̱ kawuya a kubana wa̱ nu, a danai
\v 6 <<Ka̱sukpa̱ tsu kambuku Yahuda, yaꞋan tsu kara yi apashi-apashi tsu pecuku ka̱ci ka̱ tsu, ka̱ta̱ tsu zuwa maku ma Tubalu mo okpo mogono me le.>>
\v 7 Ama ili i na Ka̱shile Vuzavaguɗu u danai i ɗa na,
\b
\q1 << <Ili yi lo ba,
\q2 ko ili ya kuyaꞋan ba,
\q1 
\v 8 iɗika i gbayin i Siriya i ɗaɗa Dimaska,
\q2 mogono ma Dimaska tamkpamu ma ɗaɗa Rezin.
\q1 A̱ ka̱tsuma̱ ka̱ a̱ya̱ amangatatsu n tawun
\q2 i ta̱ a̱ kula̱nga̱sa̱ uma a Ifiraimu gbani-gbani, ko vuza wa kubuwa ba.
\q1 
\v 9 Iɗika i gbayin i Ifirayimu i ɗaɗa Samariya,
\q2 mogono ma Samariya tamkpamu a̱yi ɗa maku ma Ramaliya.
\q1 Vu shamgba baci n katsura n uneki u ka̱ɗu u nu ba,
\q2 va kufuɗa kushamgba ba, ko kenu.> >>
\s1 Urotu wi Imanuwelu
\p 
\v 10 Ɗaɗa kpamu Vuzavaguɗu u yaꞋin kadanshi n Ahazu.
\v 11 <<Ece Vuzavaguɗu Ka̱shile ka̱ nu u yotsongu wu urotu, ko ta baci u ɗa wi uzura̱ngi ɗaka ko uzura̱ngi gaɗi ka̱u.>>
\p 
\v 12 Ama ɗa Ahazu u danai, <<Me kece ba, Mi o kukondo Vuzavaguɗu ba.>>
\p 
\v 13 Ɗaɗa Ishaya u danai, <<Panai gogo na a̱ɗa̱ kpaꞋa ku Dawuda. Kupiya uremi u ka̱ɗu u uma u yawa ba? Sai kpamu i piya uremi u ka̱ɗu u Ka̱shile ka̱ va̱?
\v 14 Adama a nannai Vuzavaguɗu n ka̱ci ka̱ ni wi ta̱ e kuneke ɗa̱ urotu, mekere ma na ka̱ta̱ me yevei vali ba mi ta̱ a kuyaꞋan ka̱tsuma̱ u matsa maku, ka̱ta̱ e ɗeke maꞋa Imanuwelu\f + \fr 7:14 \ft Kaci ka kula Imanuwelu ɗaɗa Ka̱shile ki ta̱ koɓolo n a̱ tsu\f*.
\v 15 Wi ta̱ a kutakuma ukuja u mani ka̱ta̱ u lyaꞋa ishigi, ayin a na baci u yevei kuꞋiwan ka gbani-gbani ka̱ta̱ u zagba kasingai.
\v 16 Ama kafu maku ma ma fuɗa kuꞋiwan ka gbani-gbani ka̱ta̱ u zagba kasingai, iɗika yi ngono n re n na yi a kupana wovon wa yi ta̱ a kuyaꞋan u ka̱sukpi.
\v 17 Vuzavaguɗu wi ta̱ a̱ kutuka̱ wu n atakaci, avu n uma a̱ nu koɓolo m kpaꞋa ke esheku a̱ nu, ayin a nanlo a saꞋwa kuyaꞋan we le ba ali n ayin a na aza e Ifirayimu e pecemgbenei n Yahuda. Wi ta̱ a̱ kutuka̱ m mogono ma Asiriya ma takacika wu.>>
\p 
\v 18 A kanna ka nanlo Vuzavaguɗu wi ta̱ a kuyaꞋanka aza a Masar izumgbi i yula̱, ka̱ta̱ a̱ ta̱wa̱ tsa ayun a na i daꞋin e nyeneke n Nilu ka̱ta̱ feu aza a Asiriya a̱ uta̱ a iɗika i le a̱ ta̱wa̱ ci ishigi.
\v 19 I ta̱ a̱ kuta̱wa̱ ka̱ta̱ a vaku ra̱ka̱ vi le a iɗika i na yi n tsuta̱, koɓolo n a̱ra̱Ꞌa̱, n aɓatsu a atali ali n ubuta̱ wu nɗanga ma awana dem.
\p 
\v 20 A kanna ka nanlo Vuzavaguɗu wi ta̱ o kukopuku mogono ma Asiriya ma upashi u kuyene ku Efarata ka̱ta̱ u yaꞋan ulinga n a̱yi tsu kutanu, ciya̱ a puna aci a̱ a̱ɗa̱, n cileme ci ikyamba tsu ɗa̱, ali nu ntsa̱ka̱ dem.
\p 
\v 21 A kanna ka nanlo ka, vuma wi ta̱ a kubuwa m medendem me te koɓolo nu nraɗika n re n wuma.
\v 22 Adama a̱ ka̱bunda̱i ka mani ka na a̱ ci ciya̱ we le, wi ta̱ a̱ kuciya̱ ukuja u mani u na u kutakuma. Aza a na a buwai punu a iɗika ya ra̱ka̱ i ta̱ a kutakuma ukuja u mani ka̱ta̱ o doku kpamu a lyaꞋa ishigi.
\p 
\v 23 A kanna ka nanlo, a̱ ubuta̱ dem u na wi ishi n ashina a itacishi a na a̱ kuciya̱ punu ili i na i kuyawa azanariya a̱kpa̱n-a̱kpa̱n, i ta̱ o kubono imacishi i kavama n awana.
\v 24 Ali i ta̱ a kubana ɗe n utan n aya, adama a na iɗika ya yi ta̱ a kuyaꞋan upali n imacishi i kavama koɓolo n awana.
\v 25 Aginda a na a saꞋwai kuciya̱ ucimbi ɗe n kushe, yi ta̱ a kupana wovon u kubana ɗe adama a imacishi i kavama koɓolo n awana. Ubuta̱ wa wi ta̱ o kubono tsu ubuta̱ u na anaka o ci yongo ushikpi ka̱ta̱ kpamu nlala n yongo ilaɗi a uteku u le.
\c 8
\s1 Asiriya, ili yu ulinga i kuvon i Vuzavaguɗu
\p 
\v 1 Vuzavaguɗu u danai mu, <<Ɗika meshemberu ma katali mu wanshi, ka̱ta̱ vu ɗana punu mayin Maha-shala-hasha-baza\f + \fr 8:1 \ft Kupura̱ ku gogoꞋo n kulazaka gogoꞋo, \f* n kayakiɗani ka na a kiwanakai.
\v 2 Mi ta̱ e kuɗeke ganu Uriya n Zakariya kolobo ka Jeberekiya o okpo mu ngan n singai.>>
\p 
\v 3 Ɗa n vaki n vuka vu va̱ keneki, ɗa u yaꞋin ka̱tsuma̱ ɗa u matsai maku mo koloɓo. Ɗa Vuzavaguɗu u danai mu, <<NeꞋe yi kula Maha-shala-hasha-baza.
\v 4 Kafu maku ma fuɗa kuɗeke <Dada> ko <Mma,> mogono ma Asiriya mi ta̱ a̱ kupura̱ uciyi u Dimaska koɓolo n wa aza Samariya.>>
\v 5 Vuzavaguɗu u yaꞋin kadanshi nu mpa kpamu,
\v 6 <<Adama a na uma a nampa a iwan ta̱ kuyene ku mini ma sawu ma Shilo, ɗa a yaꞋin ma̱za̱nga̱ adama e Rezin koɓolo m maku ma Ramaliya,
\v 7 Adama a nannai Vuzavaguɗu wi ta̱ a̱ kutuka̱ le m mini ma gbayin me kuyene ma na ma kaya, ɗaɗa mogono ma Asiriya n utsura u ni dem. Mi ta̱ e kuyene ma lyaꞋa nyeneke n ni dem koɓolo ni nka̱riki feu,
\v 8 ka̱ta̱ ma̱ pura̱ngu ali ma lyaꞋa a kubana a Yahuda, tsu na mini ma ci lyaꞋa ali a kubana e kuɗeku. Wi ta̱ a̱ kuba̱rukpa̱ evelyu a̱ ni ka̱ta̱ u la̱na̱ iɗika i ɗa̱, avu Imanuwelu.>>
\b
\q1 
\v 9 Ɓolongi Ra̱ka̱ vu ɗa̱ adama o wovon a̱ɗa̱ iɗika kakau,
\q2 panai a̱ɗa̱ iɗika i daꞋin,
\q1 lyaꞋi kelime n ofoɓuso adama o kuvon, ama i ta̱ a kugbasha ɗa̱,
\q2 mayun ɗa foɓusoi adama o kuvon i ta̱ a kugbasha ɗa̱.
\q1 
\v 10 Sheshei ili i na i kuyaꞋan, ama ya̱ kuciya̱ uye ba,
\q2 doki ugboji u ɗa̱ utsura, ama u ɗa wi a kubana ɗa̱ nanlo ba,
\q2 adama a na Ka̱shile ki ta̱ koɓolo n a̱ tsu.
\s1 Panai wovon u Ka̱shile, tonoi Vuzavaguɗu
\p 
\v 11 Vuzavaguɗu u yaꞋin kadanshi nu mpa n utsura u danai ka̱ta̱ n tono uye u uma a nampa a ba,
\v 12 <<Ka̱ta̱ i ɗeke kusheshe ku gbani-gbani ili i na uma e ci ɗeke kusheshe ku gbani-gbani ba, ka̱ta̱ kpamu i pana wovon wi ili i na ele a tsu pana wovon ba.
\v 13 Vuzavaguɗu MalaꞋimili a̱yi ɗa koci vuza na va kindana tsu vuza ciɗa, a̱yi ɗa va kupana wovon, yaꞋan a̱yi wo okpo wu ili i wovon koci,
\v 14 wi ta̱ o kokpo a̱Ꞌisa̱, ama wi iꞋuwa ya aza a Isaraila dem wi ta̱ o kokpo katali ka na ka tsu zuwa uma a̱ ta̱ɗa̱tsa̱ n kakpanlai ka na ka tsu zuwa uma a̱ yikpa̱. Ama wa aza a Urushelima wi ta̱ o kokpo maza koɓolo m maza ma̱ nnu a kubana we le.
\v 15 Aza e le o yoku n a̱bunda̱i i ta̱ a̱ kuta̱ɗa̱tsa̱, ka̱ta̱ a̱ yikpa̱ ali o koɗo, i ta̱ a kaza le ali e reme le a lazaka.>>
\v 16 Ɓa̱na̱i kuyotsongusu ku Ka̱shile, ka̱ta̱ i dana kadanshi ka̱ ni wa aza a na i o kutono mu.
\v 17 Mi ta̱ a kuvana Vuzavaguɗu, a̱yi na u shirikpa̱ka̱i kpaꞋa ku Yakubu kucina̱. Mi ta̱ e kuneke katsura ka̱ va̱ wa̱ ni.
\v 18 Mpa ɗa na, koɓolo m muku n na Vuzavaguɗu u nekei mu. A̱ tsu urotu u ɗa u Vuzavaguɗu MalaꞋimili wa aza a Isaraila, u na wi ida̱shi a Kusan ku Sihiyona.
\p 
\v 19 Uma o yoku a dana wu baci vu bana vu takpa uteku wa aza a̱ a̱guma̱ n oboci, n aza a na a tsu kumba ibori, u gaꞋan uma a bana o folono Ka̱shile ke le ba? Yiɗa̱i i zuwai ɗa vuza u kubana wa̱ a̱kpisa̱ a̱ una̱ wa aza a wuma?
\v 20 A ukuna u kadanshi ka̱ wila̱ n kuyotsongusu, a dansa baci ili i na kadanshi ka nampa ki a kudansa ba, i ɗaɗa adama a na i n kutashi ba.
\v 21 I ta̱ a kupasamgbanai punu a iɗika ya, n atakaci a gbayin koɓolo n kambulu. Ayin a na baci a panai kambulu, i ta̱ a kuyaꞋan wupa ka̱ta̱ a dansa kadanshi ka gbani-gbani a kubana u mogono me le n Ka̱shile ke le, ka̱ta̱ a kpatala a̱shi e le a uɓon u yoku.
\v 22 Ka̱ta̱ a indana a iɗika e ene atakaci koɓolo n ka̱yimbi n ka gbani-gbani ka na ki lo, ka̱ta̱ a vakangu le a̱ ubuta̱ u ka̱yimbi wa.
\c 9
\s1 A matsaka tsu ta̱ maku
\p 
\v 1 N nannai dem, babu ka̱yimbi kpamu adama a aza a na i a̱ ka̱tsuma̱ ka atakaci. A ayin a na a lazai ɗe o goyo ta̱ iɗika i Zabalun koɓolo n iɗika i Nafutali, ama na kelime wi ta̱ a kucikpa Ga̱lili va aza a̱ ka̱yimbi, n uye u mala u na u walai n upashi u kuyene ku Urudu.
\b
\q1 
\v 2 Uma a na i a nwalu a̱ ka̱yimbi,
\q2 e ene ta̱ kutashi ku gbayin,
\q1 aza a na i o kuyongo a̱ kulu ki iɗika ya̱ a̱kpisa̱,
\q2 we le kutashi ki ta̱ a ku akana.
\q1 
\v 3 Yi ta̱ a kuzuwa iɗika ya aza a Isaraila i gbonguro,
\q2 ka̱ta̱ uma a̱ ni a yaꞋan ma̱za̱nga̱ ka̱u.
\q1 I ta̱ a kuyaꞋan ma̱za̱nga̱ a kubana wa̱ nu,
\q2 tsu na uma a ci yaꞋan ma̱za̱nga̱ a ayin a vikyaꞋa,
\q2 n tsu na kpamu osoji a ci yaꞋan ma̱za̱nga̱ i baci e kupece ili i na a̱ pura̱i gbani a̱ ubuta̱ u kuvon.
\q1 
\v 4 Tsu na vi yaꞋin ɗa vu unai osoji a Midiya, tsu nanlo tsu ɗa va kuyaꞋan ka̱ta̱ vu koɗo
\q2 maɗanga ma kaburakpatsu ka tsugbashi ke le,
\q2 ka̱ta̱ vu takpa ucanuku wa̱ a̱miki u na wi a avangatsu e le.
\q2 Vi ta̱ o kukoɗo kalangu ka vuza na u ci neke atakaci.
\q1 
\v 5 I songu ataka dem o kovonshi a na a yaꞋankai ulinga a̱ ubuta̱ u kuvon koɓolo m
\q2 motogu ma na ma saꞋwai mpasa,
\q2 wo okpo an maniꞋin ma akina.
\q1 
\v 6 A matsaka tsu ta̱ maku, wa̱ tsu u ɗa e nekei maku, tsugono ci ta̱ a kushamgba a kaci ka̱ ni.
\q2 I ta̱ e kuɗeke yi vuza va
\q2 odoki vi ili i Mereve, Ka̱shile MalaꞋimili,
\q2 Dada vu uteku n uteku, Mogono ma̱ ma̱ta̱na̱.
\q1 
\v 7 Tsugono ci ni m ma̱ta̱na̱ ma̱ ni
\q2 mi o kukotso ba.
\q1 Wi ta̱ a kulyaꞋa tsugono ci ni tsu na tsu uta̱i a̱ ubuta̱ wa akaya a̱ ni Dawuda,
\q2 u ka̱na̱ tsu ɗa ka̱ta̱ u la̱na̱ tsu ɗa,
\q1 n ugaꞋin m ma̱ta̱na̱ kpamu
\q2 ali sai uteku n uteku. Ucikali u Vuzavaguɗu MalaꞋimili wi ta̱ a kushatangu ili i nanlo.
\s1 Wupa u Vuzavaguɗu adama a aza a Isaraila
\q1 
\v 8 Vuzavaguɗu u suku ta̱ kadanshi ka na ka̱ kpa̱ɗa̱i kuyokpo u Yakubu,
\q2 ka ɗa ki ta̱ ta na a̱ kuta̱wa̱ wa aza a Isaraila.
\q1 
\v 9 Uma ra̱ka̱ i ta̱ e kuyeve kaꞋa,
\q2 Ifirayimu n aza a na i ida̱shi a Samariya,
\q1 ele na i a kadanshi n a̱ra̱ɗi koɓolo n a̱ɗu a gbani-gbani,
\q1 
\v 10 <<Iputa̱ ya i yikpa̱ ta̱ a iɗika,
\q2 ama ci ta̱ a kumaꞋasaka i ɗa n atali a na e sheꞋwei mayin,
\q1 maɗanga ma zaitu ma yaꞋan ta̱ uvakangi,
\q2 ama ci ta̱ o kubono tsa̱ shikpa̱ punu nɗanga ma akawu a una̱ u nanlo wa.>>
\q1 
\v 11 Ama ɗa Vuzavaguɗu u ɗengusa̱i irala i le aza e Rezin a̱ shilika̱i n ele,
\q2 ɗa u kushangi irala i le ya.
\q1 
\v 12 Aza a Siriya a̱ uta̱i a kasana, A̱filisiya̱ a̱ uta̱i a̱ ka̱livi
\q2 ɗa a kambuki aza a Isaraila n anga e le uɓa̱yuwi.
\q1 Ama n nannai dem wupa u Vuzavaguɗu u kotso ba.
\q2 Ka̱kuꞋun ka̱ ni ka buwa ta̱ ukuꞋunki an wa lapa.
\q1 
\v 13 Ama uma a o bono u vuza na wu unai le ba,
\q2 ko a̱ la̱nsa̱ Vuzavaguɗu MalaꞋimili vu na u takacikai le.
\q1 
\v 14 A kanna ke te Vuzavaguɗu wi ta̱ a kugbatya kaci n winja wa aza a Isaraila dem,
\q2 koɓolo n kacaka ke kekeme ka mashuwa ka singai ka m mita̱ dem,
\q1 
\v 15 nkoshi m gba̱ra̱-gba̱ra̱ n aza a gbagbaꞋin ele ɗa kaci ka,
\q2 eneki a na a yaꞋin kuyotsongu ka aꞋuwa ele ɗa winja.
\q1 
\v 16 Aza a na o tonoi n uma a nampa a vakangu le ta̱,
\q2 ɗa aza a na a vakangi va a̱ puwa̱nka̱i.
\q1 
\v 17 Adama a nannai Vuzavaguɗu wi a kupana uyoꞋo n a̱ɗa̱nga̱ni ba,
\q2 wi kpamu a kupana asuvayali a mkpaꞋan n agapa ba,
\q1 adama a na yaba dem wi n asuvu a singai ko n ukuna u singai a kubana a̱ ubuta̱ u Ka̱shile ba,
\q2 una̱ u yaba dem wi ta̱ a kudansa ili i gbani-gbani.
\q1 N nannai dem, wupa u ni u kotso ba,
\q2 kukiye ku ni ku buwa ta̱ uɗengushi an wa lapa.
\q1 
\v 18 Mayun kawuya ka̱ tsu kula̱ ta̱ tsa akina,
\q2 ko tsu songu ta̱ awana n kapanɗalala,
\q1 ka̱ta̱ kpamu ke leɓece kakamba ka gbayin n akina
\q2 ali ka̱nga̱ kuta̱ a̱gusu-a̱gusu.
\q1 
\v 19 N wupa u Vuzavaguɗu MalaꞋimili
\q2 iɗika yi ta̱ a̱ kuciya̱ uva̱li,
\q1 ka̱ta̱ uma e leɓece a akina,
\q2 babu vuza na u kisa vuza ni.
\q1 
\v 20 A usingai i ta̱ a kuminjarangu, ama kambulu ko kukotso le ba,
\q2 a ugula̱ i ta̱ a a kulyaꞋa, ama i a̱ kucuwa̱ ba.
\q1 Yaba dem wi ta̱ a kutakuma inyama yi muku n na u matsai.
\q1 
\v 21 Manasa wi ta̱ a kulyaꞋa Ifirayimu, ka̱ta̱ feu Ifirayimu u lyaꞋa Manasa.
\q2 Dem vi le o bono a tsurala n Yahuda.
\q1 N nannai dem, wupa u ni wi o kukotso ba,
\q2 kukiye ku ni kpamu ku buwa ta̱ uɗengushi an wa lapa.
\c 10
\q1 
\v 1 Ili ya atakaci i ɗa a kubana wa aza a na a̱ tsu kpa̱ɗa̱ kuzuwa wila̱ mejege,
\q2 koɓolo n aza a na e ci neke wila̱ wa atakaci,
\q1 
\v 2 a̱ sa̱nka̱ aza a unambi ili i na yi i le,
\q2 ka̱ta̱ a isa kasingai a̱ ubuta̱ u uma a̱ va̱ a na i a̱ ka̱tsuma̱ ka atakaci,
\q1 o bonoko agapa a̱ a̱ma̱ci ilikulyaꞋa i le
\q2 ka̱ta̱ kpamu a̱ fa̱ba̱na̱ ili yi mkpan.
\q1 
\v 3 Yiɗa̱i va kuyaꞋan a kanna ka atakaci,
\q2 kawuya kuta̱ baci daꞋin ɗa ka̱ ta̱wa̱i?
\q1 U yayi va kusuma va bana va̱ la̱nsa̱ uɓa̱nki?
\q2 Te ɗai va kuka̱sukpa̱ uciyi u nu?
\q1 
\v 4 Va kubuwa n ili i na va kuyaꞋan ba, sai vu kuɗa̱ngu koɓolo n agbashi
\q2 ko vu yikpa̱ a̱ ubuta̱ wa aza a na a unai ɗe.
\q1 N nannai va dem, wupa u ni u kotso ba,
\q2 kukiye ku ni ku buwa ta̱ uɗengushi an wa lapa.
\s1 Afada a̱ Ka̱shile a kubana wa aza a Asiriya
\q1 
\v 5 Ili ya atakaci i ɗa a kubana wa aza a Asiriya
\q2 kalangu ka wupa ka̱ va̱, aza a na kukiye ku le ku ɗa ma̱gba̱la̱mgba̱la̱m ma wupa ma̱ va̱.
\q1 
\v 6 N suku ta̱ aza a Asiriya a banka iɗika i na i yevei Ka̱shile ba n kuvon,
\q2 u uma a na a tsu zuwa mu wupa.
\q1 N suku le ta̱ a bana a̱ pura̱ ucanuku u le,
\q2 a dasasa le an kopoti ka na ka ci yaꞋan a uye.
\q1 
\v 7 Ama ili i nampa i ɗa u sheshei ba,
\q2 i ɗaɗa ili i na wi n i ɗa a̱ ka̱ɗu ba,
\q1 ama kusheshe ku ni ku ɗaɗa wu una,
\q2 u yawaka iɗika n a̱bunda̱i uteku.
\q1 
\v 8 U danai,
\q2 <<Ovonshi a̱ va̱ ra̱ka̱ ngono n ɗa ba?
\q1 
\v 9 Tsu la̱nga̱sa̱ ta̱ Kaluno uteku tsu na ci yaꞋin n Kakemishi.
\q2 Ɗa Hamatu u nekei utan uteku tsu Apada,
\q2 ɗa tsu la̱nga̱sa̱i Samariya uteku tsu na ci yaꞋin n Dimaska.
\q1 
\v 10 Tsu na kukiye ku va̱ kisai tsugono tsu na a̱ma̱li i a kulyaꞋa,
\q2 tsugono tsu na ululu a laꞋi a̱ma̱li a Urishelima koɓolo n a̱ma̱li a Samariya,
\q1 
\v 11 mi a̱ kula̱nga̱sa̱ Urishelima n a̱ma̱li a̱ ni
\q2 tsu na n la̱nga̱sa̱i Samariya n a̱ma̱li a̱ ni ba?>>
\b
\p 
\v 12 Ayin a na baci Vuzavaguɗu u kotsoi ulinga u ni a Kusan u Sihiyona n Urishelima, wi ta̱ a kudana, mi ta̱ e kuneke mogono ma aza a Siriya atakaci adama a̱ a̱ra̱ɗi a gbani-gbani koɓolo n ugbamukaci u gbasa u na wi a̱ a̱shi a̱ ni.
\v 13 Adama a na u dana ta̱,
\b
\q1 <<N utsura we ekiye u va̱ u ɗa n yaꞋin ili i nampa,
\q2 n ugboji u va̱ adama a na mi ta̱ n kuyeve.
\q1 N takpai uteku u ka̱buza̱ wi iɗika kakau,
\q2 m pura̱i uciyi u le,
\q2 an kovonshi vu utsura n yawakai ngono n le uteku.
\q1 
\v 14 Kukiye ku va̱ ku gaꞋakai n uciyi
\q2 wi iɗika n a̱bunda̱i tsu na vuza u tsu uka kukiye ku ni a cikinda
\q1 ka̱ta̱ u pura̱ okowo a na a̱ ka̱sukpa̱i,
\q2 ta m ɓolongi iɗika kakau nannai,
\q1 babu vuza na u ɗengusa̱ka̱i mu kuvelyu
\q2 ko u ɓa̱yuwa̱ una̱ u keɓece mu.>>
\b
\q1 
\v 15 Kogovu ki ta̱ a kuyaꞋan a̱ra̱ɗi u laꞋa vuza na wi a̱ kuɓa̱na̱ yi,
\q2 ko ugangafu u yaꞋan a̱ra̱ɗi u laꞋa a̱yi na wi a̱ kuɓa̱na̱ yi?
\q1 Ko kalangu ka ci yaꞋan ta̱ malapuka babu kukiye?
\q2 Ba kukiye kuɗa ki uremi n kalangu ka ba?
\q1 
\v 16 Adama a nannai Vuzavaguɗu, Vuzavaguɗu MalaꞋimili,
\q2 a̱yi wi ta̱ a̱ kusuku ma̱dukpa̱ ma gbani-gbani a kubana wa osoji a̱ a̱ra̱ɗi a aza a Siriya,
\q1 ka̱ta̱ a̱ ka̱tsuma̱ ku utsura u ni a tasuku akina a̱ usuɗukpi
\q2 o yongo a̱ kukula̱ n usuɗukpi ka̱u.
\q1 
\v 17 Kutashi ka aza a Isaraila ki ta̱ o kokpo akina,
\q2 Vuza Ciɗa wi ta̱ o kubono ka̱vusa̱ ka akina.
\q1 Wi ta̱ e kuleɓece
\q2 awana m mita̱ ma gbani-gbani n akina a kanna ke te.
\q1 
\v 18 UgaꞋin u mura̱ta̱i u ni koɓolo n iɗika i tsuta̱ i ni
\q2 wi ta̱ a̱ kula̱nga̱sa̱ ka̱ɗu n ikyamba dem,
\q2 tsu na vuza vu mɓa̱la̱ u tsu na̱mgba̱.
\q1 
\v 19 Nɗanga m mura̱ta̱i n nanlo ma kubuwa n a̱bunda̱i ba, kenu ɗa o kokpo
\q2 ali tsu na maku ma kufuɗa me kece le.
\s1 Aza a Isaraila a na a buwai
\p 
\v 20 A kanna ka nanlo uma a na a kubuwa a Isaraila, n aza a na a laꞋakai a kpaꞋa ku Yakubu o kudoku a zuwaka vuza na u kuna le katsura ba, ama i ta̱ a kuzuwaka Vuzavaguɗu, Vuza Ciɗa vi Isaraila katsura.
\v 21 Aza a na a buwai va i ta̱ o kubono, aza a na a laꞋakai a kpaꞋa ku Yakubu i ta̱ o kubono u Ka̱shile MalaꞋimili.
\v 22 Ko uma a̱ ɗa̱ aza a Isaraila a yimkpa an kayala ka mala, aza a na a buwai ɗa koci o kubono. O foɓuso ta̱ ɗe munuka a kubana u uma a̱ ni, munuka ma na ma yaꞋin derere n ele.
\v 23 Vuzavaguɗu, Ka̱shile MalaꞋimili, a̱yi ɗa u kula̱nga̱sa̱ iɗika dem tsu na u foɓusoi ɗe kuyaꞋan.
\p 
\v 24 Adama a nannai, na ɗa ili i na Vuzavaguɗu, Vuzavaguɗu MalaꞋimili u danai, <<A̱ɗa̱ uma a̱ va̱ aza a na i a̱ ida̱shi a Sihiyona, ka̱ta̱ i pana wovon wa aza a Asiriya ba, aza a na a tsu lapa ɗa̱ n alangu koɓolo n kuyaꞋan ko oɓolo adama a̱ ɗa̱ tsu na aza a Masar a yaꞋin.
\v 25 M megeshe ba, wupa u va̱ a kubana wa̱ ɗa̱ wi ta̱ o kukotso, ka̱ta̱ u ɗa u bono ili i na i kula̱nga̱sa̱ le.
\v 26 Vuzavaguɗu MalaꞋimili wi ta̱ a kufaba le m mashawuri, tsu na u lapai aza a Midiya a kakpanlai ko Orebu, ka̱ta̱ u ɗengusa̱ kalangu ka̱ ni a gaɗi vu mala tsu na u yaꞋin a Masar.
\v 27 A kanna ka nanlo a̱miki e le i ta̱ a kuyaꞋan utakpi a avangatsu a̱ ɗa̱, kogboro ke le ki ta̱ a kuyaꞋan utakpi e kuɗeku ku nu. Maɗanga ma anaka ma a vicimba va vi ta̱ a kuyaꞋan ukoɗi adama a na vi yaꞋan ta̱ ikyamba ka̱u.>>
\b
\q1 
\v 28 U yawai a Aita,
\q1 u walai m Miguro,
\q2 ɗa u foɓoi ucanuku u ni a Mikamasha.
\q1 
\v 29 A pasai upashi ɗaɗa a danai,
\q2 Ci ta̱ a kasa a Geba.
\q1 Ɗaɗa aza a Rama a panai wovon,
\q2 aza a Gibiya likuci i Shawulu a sumai.
\q1 
\v 30 Lapai una̱ ka̱u a̱ɗa̱ uma a Galima,
\q2 panai a̱ɗa̱ aza a Laishaha,
\q2 n a̱ɗa̱ aza a Anato.
\q1 
\v 31 Aza a Madamena a suma ta̱,
\q2 aza a na i ida̱shi a Gebi a̱ la̱nsa̱i ubuta̱ u kusheɗeku.
\q1 
\v 32 A̱ ka̱tsuma̱ ka ayin a nanlo i ta̱ a̱ kutsura̱ngu o Nobu,
\q2 wi ta̱ e kuveɗece ka̱kuꞋun ka̱ ni
\q2 a Kusan ku Sihiyona,
\q2 a kaginda ka Urushelima.
\b
\q1 
\v 33 Ama indana Vuzavaguɗu, Vuzavaguɗu MalaꞋimili
\q2 wi ta̱ a kugbatya maɗanga ma gbayin ma aza a Asiriya n utsura u gbayin.
\q1 Nɗanga n ɗa̱nga̱-ɗa̱nga̱ mi ta̱ a̱ kuyikpa̱,
\q2 ka̱ta̱ mu ugaɗi-ugaɗi n yaꞋan ugbati.
\q1 
\v 34 Wi ta̱ a kukapa ubuta̱ u na wi tukpa m mura̱ta̱i n kogovu,
\q2 Lebano wi ta̱ a̱ kuyikpa̱ e kelime ka MalaꞋimili.
\c 11
\s1 Kacaka ka na kuta̱i a kumaci ku Jesi
\p 
\v 1 Kumi ku Jesi ki ta̱ o kutopo,
\q2 ka̱ta̱ kacaka punu a utopi wa ka matsa umaci.
\q1 
\v 2 Ayinviki a Vuzavaguɗu i ta̱ o kuyongo n a̱yi.
\q2 Ayinviki e kuyeve n cicoꞋo,
\q2 ayinviki e kuneke kadanshi n utsura,
\q2 ayinviki e kuneke kuyeve n kupana wovon u Vuzavaguɗu.
\q1 
\v 3 UyoꞋo wi ida̱shi u ni wi ta̱ o kuyongo n wovon u Vuzavaguɗu.
\q1 A̱yi wa kuyaꞋan afada a ili i na wi e kene n a̱shi a̱ ni,
\q2 ko u yaꞋan ulinga n i na u panai uma a kudansa n atsuvu a̱ ni ba.
\q1 
\v 4 Ama n usuɓi u ɗa u kuyaꞋanka aza a yali afada.
\q2 N kasingai kpamu ka̱ta̱ u ɓa̱nka̱ aza a unambi a aduniyan a nampa,
\q1 n kadanshi ku una̱ ka̱ ni ɗa u voɗotsoi a̱ɗu a uma,
\q2 n ayinviki a una̱ u ni a ɗaɗa u kunaka aza a na a ci yaꞋan kawuya.
\q1 
\v 5 Usuɓi u ɗa u kokpo maganda ma̱ kuyun ma̱ ni,
\q2 ka̱ta̱ ukuna u mayun wo okpo maganda me melengeɗi ma̱ ni.
\b
\q1 
\v 6 A kanna ka nanlo meshe ma kakamba mi ta̱ o kuyongo m maku mo mokyon,
\q2 kanama kpamu ko yongo m maku ma maraɗika.
\q1 Medendem kpamu ma yaꞋan kalina n kawu,
\q2 maku me kenu maꞋa ma kuguɓa le.
\q1 
\v 7 Kanaka ki ta̱ a kulina m manama ma na e ci ɗeke ma̱kunzukunzu,
\q2 muku n le kpamu n vaku a̱ ubuta̱ u te,
\q2 ka̱ta̱ kawu kpamu u takuma ijanu an kanaka.
\q1 
\v 8 Mereɓu mi ta̱ a kuyaꞋan ugulani e kpenle ku keyenku babu i na i kusaꞋwa yi.
\q2 Maku ma na a kasai mani mi ta̱ a kuzuwa kukiye ku ni a kangu ka kagbaturu ama u kuluma yi ba.
\q1 
\v 9 Babu ili i na i kuforo ko yuna vuza
\q2 a nsasan n ciɗa n va̱ ra̱ka̱,
\q1 adama a na aduniyan i ta̱ a kushana n uyevi u Vuzavaguɗu,
\q2 tsu na mini ma tsu pala mala.
\b
\p 
\v 10 A kanna ka nanlo vuza yoku a̱ ka̱tsuma̱ ka ntsukaya n Jesi wi ta̱ o kokpo an urotu u kakashi a aduniyan dem. Aduniyan dem i ta̱ a kuzuwa katsura wa̱ ni, ka̱ta̱ iɗika i na wi ida̱shi yo okpo n tsugbayin.
\p 
\v 11 A kanna ka nanlo Vuzavaguɗu wi ta̱ o kudoku kpamu wa̱ ba̱rukpa̱ kukiye ku ni ire adama a na wi isa uma a̱ ni a na a buwai a Asiriya, n Ɗaka vu Masar, m Masar vu gaɗi, m Patoro, n Kush\f + \fr 11:11 \ft Kushi, kula ku yoku ku ɗa ku Itopiya\f*, n aza a na i Elim n Shinar kpamu a Babila, n Hamata, n kotogu ka na ki a mala.
\b
\q1 
\v 12 Wi ta̱ a̱ kuɗa̱ngusa̱ urotu u kakashi adama a aduniyan,
\q2 ka̱ta̱ u ɓolongu aza a Isaraila a na o lokoi,
\q1 ka̱ta̱ u ɓolongu aza a Yahuda
\q2 a na a wacuwai a uɓon u na̱shi wa aduniyan.
\q1 
\v 13 A ayin a nanlo cisheꞋe tsa aza a Ifirayimu ci ta̱ o kukotso,
\q2 ka̱ta̱ aza a na i a tsurala n Yahuda a zuwa uteku.
\q1 Ifirayimu u kuyaꞋan cisheꞋe n Yahuda ba,
\q2 Yahuda feu u kuyaꞋan tsurala n Ifirayimu kpamu ba.
\q1 
\v 14 Koɓolo kaꞋa a kugasa ka̱ta̱ a̱ shilika̱ n aza a A̱filisiya̱ a na i a̱ ka̱livi,
\q2 ka̱ta̱ a̱ pura̱ ucanuku gbani wa aza a na i ida̱shi a uɓon u kasana.
\q1 I ta̱ a kulyaꞋa aza e Edom m Mowabu,
\q2 ka̱ta̱ aza a Amona a panaka le.
\q1 
\v 15 Vuzavaguɗu wi ta̱ e kuɗekpetengu
\q2 ubuta̱ wu uga̱vi u mala ma shili,
\q1 wi ta̱ a kuzuwa kukiye ku ni kulapa ka̱ta̱ kuɗekpetengu mala ma Yufiretus.
\q2 Wi ta̱ a̱ kusuku wunla̱i wu utsura
\q1 ka̱ta̱ u zuwa kuyene ka ku pecuku ali ugboku u cindere
\q2 tsu na uma a kufuɗa a pasa ku ɗa n ene.
\q1 
\v 16 Wi ta̱ a kuzuwa uye u gbayin
\q2 adama a uma a̱ ni a na a buwai a Asiriya,
\q1 tsu na yaꞋankai aza Isaraila
\q2 a ayin a na a̱ uta̱i a Masar.
\c 12
\s1 Ishipa i kucikpa
\q1 
\v 1 A kanna ka nanlo avu vi ta̱ a kucanana,
\q1 <<Mi ta̱ a kucikpa wu Vuzavaguɗu,
\q2 ko a na vi a wupa nu mpa.
\q1 Wupa u nu u laza ta̱
\q2 ɗa avu vu nekei mu kadanshi ku uremi u ka̱ɗu.
\b
\q1 
\v 2 <<Mayun Ka̱shile kaꞋa kishi ka̱ va̱.
\q2 Mi ta̱ a kuzuwa ka̱ɗu ka̱ va̱ ma kupana wovon ba.
\q1 Adama a na Ka̱shile Vuzavaguɗu a̱yi ɗa katsura ka̱ va̱ n vishipa vu va̱.
\q2 A̱yi ɗa wo okpoi kishi ka̱ va̱.>>
\b
\p 
\v 3 M ma̱za̱nga̱ ɗaɗa ve kukenuku mini a ayinva a̱ wishi.
\v 4 A kanna ka nanlo vi ta̱ a kudana,
\b
\q1 <<Cikpai Vuzavaguɗu,
\q2 ɗeke kula ku ni,
\q1 ka̱sukpa̱ uma aduniyan e yeve i na Vuzavaguɗu u yaꞋin a kubana u uma a̱ ni,
\q2 i dana kpamu a cikpa kula ku ni.
\b
\q1 
\v 5 <<Cananai vishipa a kubana u Vuzavaguɗu adama a na a̱yi u yaꞋan ta̱ ili i mereve.
\q2 ka̱sukpa̱ aduniyan ra̱ka̱ e yeve i singai i na u yaꞋin.
\q1 
\v 6 Orukpoi ka̱ta̱ i canana vishipa adama a̱ ma̱za̱nga̱, uma o Sihiyona.
\q2 Adama a na a̱yi vuzagbayin ɗa a̱yi Vuza CIƊA vuza vi Isaraila a̱yi na wi o kuyongo e mere ma̱ nu.>>
\c 13
\s1 Kene ku wuya adama a Babila
\p 
\v 1 Na va ɗaɗa akaka adama a Babila a na Ishaya maku ma Amazo wi isai a̱ ubuta̱ u Ka̱shile.
\b
\q1 
\v 2 Ɗengusa̱i urotu u kakashi a nsasan n na mi n ili ba,
\q2 orukpokoi le ka̱u,
\q1 ɗekei le n kukiye adama a na a uwa
\q2 utsutsu u likuci ya aza a gbagbaꞋin.
\q1 
\v 3 N neke ta̱ ɗe kadanshi a kubana wa aza ciɗa a̱ va̱.
\q2 N ɗeke ta̱ ɗe osoji a̱ va̱ a bana o yotsongu a na mpa mi a wupa.
\q2 I ta̱ a kuyaꞋan ma̱za̱nga̱ a ayin a na baci n lyaꞋi.
\b
\q1 
\v 4 Panai, kacaꞋa a gaɗi vu kusan
\q2 an koɓolo ka gbayin ka uma, adanshi ka̱bunda̱i ko osoji kaꞋa ki nwalu a kubana a ubuta̱ u kuvon.
\q1 Panai uteku u na tsugono kakau ci o yoroli,
\q2 adanshi uma a aduniyan a ɗa i a nwalu koɓolo.
\q1 Vuzavaguɗu ɗa wi o kufoɓuso
\q2 osoji adama o kuvon.
\q1 
\v 5 A̱ uta̱ ta̱ a iɗika i daꞋin ka̱u,
\q2 ɗe a uteku wa aduniyan,
\q1 Vuzavaguɗu wi ta̱ a̱ kuta̱wa̱ n yunatsu i wupa u ni
\q2 adama a na wu una aduniyan dem.
\b
\q1 
\v 6 Lapai una̱, adama a na kanna ka Vuzavaguɗu ka yawa ta̱ ɗevu.
\q2 Ki ta̱ a̱ kuta̱wa̱ tsu na munuka ma̱ tsu uta̱ u MalaꞋimili.
\q1 
\v 7 Adama a nannai ekiye dem i ta̱ a̱ kukuwa̱ adama o wovon,
\q2 Ka̱ɗu de dem ki ta̱ e kuderekpe.
\q1 
\v 8 Ka̱ta̱ uma a̱ rikpa̱ adama o wovon.
\q2 Mɓa̱la̱ n una̱mgbi u ka̱tsuma̱ mi ta̱ kuna le,
\q2 i ta̱ a kupana mɓa̱la̱ tsu vuka va̱ a̱ga̱nda̱ a limata.
\q1 I ta̱ a̱ kindanai n wovon
\q2 ka̱ta̱ o oro a̱shi e le adama o wono.
\b
\q1 
\v 9 La̱na̱, kanna ka Vuzavaguɗu ka ki ta̱ lo a̱ kuta̱wa̱,
\q2 kanna ka atakaci n kanna ka̱ mɓa̱la̱, koɓolo n wupa u gbayin
\q1 an wo bonoko likuci ya agali.
\q2 Ka̱ta̱ wu una aza a unushi a na i punu dem.
\q1 
\v 10 Azangata a gaɗi n ili i na yi punu a̱ ka̱tsuma̱ ke le dem
\q2 o kudoku e neke kutashi ba.
\q1 Kanna ki ta̱ o kokpo n ka̱yimbi,
\q2 wotoi kpamu wo kudoku we neke kutashi ba.
\q1 
\v 11 Mi ta̱ a kutakacika aduniyan adama a kawuya ka̱ ni,
\q2 aza a gbani-gbani kpamu adama a unushi u le.
\q1 Mi ta̱ a kuzuwaka aza a ugbamukaci uteku
\q2 ka̱ta̱ m bonoko a̱ra̱ɗi a aza a ugbamukaci ukuna u gbani.
\q1 
\v 12 Mi ta̱ a kuzuwa uma a yaꞋan ugushi u laꞋa azanariya endeꞋen,
\q2 ka̱ta̱ n zuwa vuma wo okpo atakaci a̱ kuciya̱ uteku tsa azanariya a singai a Ofiri.
\q1 
\v 13 Adama a nannai a kanna ka na ka̱ɗu ka̱ va̱ ka̱ kula̱i, mi ta̱ a̱ kugba̱ɗa̱sa̱ gaɗi,
\q2 ka̱ta̱ aduniyan a̱ gba̱ɗa̱ a̱ ubuta̱ u na i
\q1 adama a wupa u Vuzavaguɗu MalaꞋimili,
\q2 a kanna ka wupa u gbayin u ni.
\q1 
\v 14 Uma dem i ta̱ a kusuma an mesheun ma na o lokoi a̱ ubuta̱ u kutambu,
\q2 ko tsu nlala n na mi babu maguɓi.
\q1 Vuma dem wi ta̱ o kubono a̱ ubuta̱ u uma a̱ ni,
\q2 yaba dem wi ta̱ a kusuma o kubono a iɗika i ni.
\q1 
\v 15 Vuza na baci de a̱ ciya̱i i ta̱ a kusapa yi m masara sai ukpa̱,
\q2 vuza na kpamu a̱ ka̱na̱i i ta̱ a kuna yi n kotokobi.
\q1 
\v 16 I ta̱ a kukiɗa nreɓu n le gbati-gbati
\q2 a̱ a̱shi e le.
\q1 I ta̱ a̱ kula̱nga̱sa̱ i iꞋuwa i le a̱ pura̱ ucanuku u le,
\q2 ka̱ta̱ a̱ ka̱na̱sa̱ a̱ma̱ci e le a yaꞋan tsugbani n ele.
\b
\q1 
\v 17 VUZAVAGUƊU u danai, La̱na̱, mi ta̱ a kukushangu aza a Madaya a̱ shilika̱ n ele,
\q2 uma a na e keɓecei n azanariya
\q2 ko a cigai azurufa ba.
\q1 
\v 18 Ni njiki n le n ɗa a kunaka olobo a utsura,
\q2 a kupana asuvayali a nreɓu
\q2 ko o yotsongu ka̱ɗu ka asuvayali a kubana u muku ba.
\q1 
\v 19 Babila, tsugbayin tsu tsugono,
\q2 a̱ra̱ɗi a tsugbayin tsa aza a Kaldiya,
\q1 i ta̱ o kokpo tsu na u yaꞋin n Sodom n Gomora,
\q2 ayin a na baci Ka̱shile ka vakangi le.
\q1 
\v 20 Babu vuza na u kuda̱sa̱ngu ɗe
\q2 ko u yongo ɗe ali nu ntsukaya n na n kuta̱wa̱.
\q1 Babu kpamu vuza va Alaraba vu na u kuka̱nza̱ ɗe ka̱pa̱m ka̱ ni,
\q2 babu maguɓi ma na ma kulina ɗe n ushiga u ni.
\q1 
\v 21 Nnama n kakamba mi ta̱ a kuvaku lo.
\q2 NsheꞋe n kakamba mi ta̱ a kushana a kpaꞋa ku ni.
\q1 Mkpa̱tuwa̱n mi ta̱ a kuyaꞋan lo cikinda,
\q2 nren mi ta̱ o kuyongo lo a kaɗikpangusu.
\q1 
\v 22 A̱kunzu i ta̱ o kuyongo a nshilya mu utsura n ni,
\q2 ka̱ta̱ nsheꞋe n kakamba n yaꞋan enle e kefeku ka singai ka̱ ni.
\q1 Ayin a iɗika i Babila o okpo ta̱ ukeci,
\q2 a ɗa a buwa m megeshe ba.
\c 14
\p 
\v 1 Vuzavaguɗu wi ta̱ a kupana asuvayali a Yakubu, wi ta̱ kpamu a kuzagba Isaraila ka̱ta̱ u zuwa le a̱ da̱sa̱ngu a iɗika i le kpamu. Omoci i ta̱ a kubana ɗe feu ka̱ta̱ o ɓolongu kaci ke le m kpaꞋa ku Yakubu.
\v 2 Aduniyan i ta̱ a kuɗika le ka̱ta̱ o bonoko le a iɗika i le. KpaꞋa ka aza Isaraila ki ta̱ a kuzuwa aza a iɗika n a̱bunda̱i ali n a̱ma̱ci a yaꞋanka le tsugbashi a iɗika i Vuzavaguɗu. I ta̱ o kubonoko aza a na ishi a zuwai le okpo agbashi-agbashi, ka̱ta̱ a lyaꞋa tsugono a gaɗi va aza na ishi a kutakacika le.
\p 
\v 3 A kanna ka na Vuzavaguɗu u nekei nu wuvuki a̱ ubuta̱ wa atakaci n una̱mgbi u ka̱tsuma̱ n tsugbashi tsu wuya-wuya,
\v 4 vi ta̱ a kuɗika ili yi izoshi i nampa a kubana u mogono ma Babila,
\b
\q1 <<Uteku tsu na katakaciki ka yawai uteku,
\q2 tsu na wupa u ni u zuwai uteku.
\q1 
\v 5 Vuzavaguɗu u koɗo ta̱ kalangu ka vuza va asuvawuya,
\q2 kalangu ko ngono,
\q1 
\v 6 ka na ka lapai uma n wupa
\q2 wu babu uteku,
\q1 ɗa ka lyaꞋi tsugono a iɗika
\q2 n wupa u na wi babu kukotso.
\q1 
\v 7 Ama a ukocishi ɗa iɗika dem i ciya̱i wuvuki m ma̱ta̱na̱
\q2 ali ɗa a cananai ishipa adama a̱ ma̱za̱nga̱.
\q1 
\v 8 Ko nɗanga ma awana a̱ a̱ri, koɓolo nu nɗanga n ciɗa n Lebano n yaꞋan ta̱ ma̱za̱nga̱ adama a̱ nu
\q2 ɗa a danai,
\q1 <Gogo na a na a variki nu ɗe,
\q2 babu kakapi ka maɗanga ka na ko kudoku ka gbatya tsu ka vakangu.>
\q1 
\v 9 Kasaun ki ta̱ a̱ ma̱za̱nga̱ ka̱u
\q2 adama a na ka gasa n avu.
\q1 U ɗengusa̱ ta̱ a̱kpisa̱ adama a na a rabasa wu,
\q2 aza na ishi n tsugbayin dem aduniyan,
\q1 u tsu zuwa le ta̱ a̱ ɗa̱nga̱ a akuba o tsugono e le,
\q2 koɓolo n aza a na ishi ngono a aduniyan dem.
\q1 
\v 10 Ra̱ka̱ vi le i ta̱ a̱ kushuku,
\q2 ka̱ta̱ a dana,
\q1 <Avu feu vu okpo ta̱ babu utsura, uteku tsu na ci,
\q2 tso okpo ta̱ derere.>
\q1 
\v 11 A̱ra̱ɗi a̱ nu dem a yaꞋan ta̱ uvakangi a iɗika ya̱ a̱kpisa̱,
\q2 koɓolo n kacaꞋa ki ishari ka̱ nu dem.
\q1 Azun a ɗa okpoi kajiba ki ivaꞋin ka̱ nu
\q2 ɗa kpamu okpoɗou o okpoi ipalatsu i nu.
\b
\q1 
\v 12 <<Inda tsu na vu uranai gaɗi ɗa vi yikpa̱i,
\q2 avu na vi kazangata ku usana, maku mu usana.
\q1 A vakangu wu ta̱ a aduniyan,
\q2 avu na vu unai uma n a̱bunda̱i a aduniyan.
\q1 
\v 13 Vu danai ka̱ci ka̱ nu,
\q2 <Mi ta̱ a kukumba gaɗi,
\q1 ka̱ta̱ n kiyangu kakuba ka̱ va̱ a gaɗi va azangata a̱ Ka̱shile,
\q2 n zuwa kakuba ka̱ va̱ gaɗi
\q1 n da̱sa̱ngi ɗe a kusan ka̱ a̱ma̱li
\q2 daꞋangi a kubana uɓon u gaɗi.
\q1 
\v 14 Mi ta̱ a kukumba gaɗi ve eleshu,
\q2 ka̱ta̱ m bonoko ka̱ci ka̱ va̱ tsu MalaꞋimili.>
\q1 
\v 15 Ama a̱ ciɗa̱ngu wu ta̱ a kasaun,
\q2 punu a iɗika ya̱ a̱kpisa̱.
\q1 
\v 16 Aza a na e enei nu i ta̱ o kumoɗoko wu a̱shi
\q2 ka̱ta̱ a yaꞋan mereve ka̱ta̱ e ece,
\q1 <Vuma nampa ɗa gaji vuza na u zuwai iɗika i gba̱ɗa̱i,
\q2 ɗa kpamu tsugono n a̱bunda̱i tsu panai wovon wa?
\q1 
\v 17 Vuma vu na u zuwai aduniyan o okpoi an kakamba,
\q2 a̱yi na u la̱nga̱sa̱i likuci n a̱bunda̱i i ni
\q2 ɗa kpamu u sa̱nka̱i agbashi a̱ ni kubono a kpaꞋa?>
\q1 
\v 18 Ngono ma aduniyan ra̱ka̱ a̱ ciɗa̱ngu le ta̱ n tsugbayin,
\q2 yaba dem vi le n kasaun ka̱ ni.
\q1 
\v 19 Ama avu a taɗuku wu ta̱ pulai
\q2 tsu kacaka babu uciɗa̱ngi u singai.
\q1 Vi ta̱ upali n aza na a unai, ele na na a gbatyasai n kotokobi,
\q2 aza a na a̱ yikpa̱i ɗaka vu kpenle ka atali,
\q2 an keven ka na i e kukpeteshe.
\q1 
\v 20 Avu va̱ kuciya̱ uciɗa̱ngi u singai ba,
\q2 adama na avu vu la̱nga̱sa̱ ta̱ iɗika i nu
\q2 ɗa kpamu vu unai uma a̱ nu.
\b
\q1 <<O kudoku a kula limata
\q2 i vuza gbani-gbani kpamu ba.
\q1 
\v 21 Lapula ubuta̱ adama a na vi kiɗa muku n ni
\q2 adama a̱ unushi wi ikaya i le.
\q1 Adama a na ta lo a̱ ɗa̱nga̱ a ka̱na̱ iɗika ya,
\q2 ko a shatangu iɗika ya n likuci n a̱bunda̱i.>>
\b
\p 
\v 22 Mpa Vuzavaguɗu MalaꞋimili n danai, <<Mi ta̱ a̱ kuɗa̱nga̱ ka̱ta̱ n shilika̱ n ele, ka̱ta̱ n la̱nga̱sa̱ Babila, n kula ku ni, n aza a na a buwai n wuma, koɓolo m muku n ni n ntsukaya n ni.>>
\v 23 <<Mi ta̱ o kubonoko Babila tsa agali, ubuta̱ u kuyongo wu mkponguron n adaɓa. Mi ta̱ a̱ kupura̱ngu Babila m menju ma munuka,>> Mpa ɗa Vuzavaguɗu MalaꞋimili n danai.
\s1 Kene adama a Siriya.
\q1 
\v 24 A̱yi Vuzavaguɗu u kucina ta̱ ɗe.
\q1 <<Mayun ɗa tsu na n sheshei ɗe
\q2 ta u kokpo nannai,
\q1 tsu na kpamu n zuwai
\q2 ta ka kushamgba nannai.
\q1 
\v 25 Mi ta̱ a kuna aza a Asiriya a iɗika i va̱,
\q2 mi ta̱ a kudasa yi n ene a nsasan n va̱.
\q1 Atakaci a̱ ni i ta̱ a kuyaꞋan utakpi a̱ ubuta̱ u uma u va̱,
\q2 ka̱ta̱ a takpa a̱miki a̱ ni a avangatsu e le.>>
\b
\q1 
\v 26 Na va ɗaɗa ili i na u foɓusoi
\q2 kuyaꞋanka aduniyan dem.
\q1 Kukiye ku va̱ ki ta̱ uba̱rukpi
\q2 adama a na kutakacika uma a aduniyan dem.
\q1 
\v 27 Adama a na Vuzavaguɗu MalaꞋimili u sheshe ta̱ ɗe,
\q2 yayi wa kufuɗa wa sabaꞋa kaꞋa?
\q1 U ba̱ra̱kpa̱ ta̱ ɗe kukiye ku ni
\q2 babu vuza na u kusa̱nka̱ yi?
\s1 Akaka a kubana wa aza a A̱filisiya̱
\p 
\v 28 Kadanshi ka nampa ka̱ ta̱wa̱ ta̱ a̱ ka̱ya̱ ka na mogono Ahazu u kuwa̱i.
\b
\q1 
\v 29 A̱ɗa̱ aza A̱filisiya̱ ka̱ta̱ i yaꞋan ma̱za̱nga̱ ba,
\q2 ka̱ta̱ i dana kalangu ka na ko foroi ɗa̱ va ka kukoɗo ta̱ ba.
\q1 Punu a umaci u koko ka nanlo i ta̱ a kumatsa maku ma kagbaturu.
\q2 Ili i na u matsai kpamu yi ta̱ a kuyaꞋan n tsukono tsu koko.
\q1 
\v 30 Muku mu ugiti ma aza a unambi i ta̱ a̱ kucuwa̱,
\q2 ka̱ta̱ a̱ la̱nsa̱i a vaku m ma̱ta̱na̱,
\q1 ama mi ta̱ a kuna kumiꞋi ku nu n kambulu,
\q2 ka̱ta̱ a una aza a na a buwai n wuma.
\q1 
\v 31 Shika̱i ka̱ta̱ i lapa una̱ a̱ utsutsu u likuci u ɗa̱,
\q2 kuwa̱i n wovon a̱ɗa̱ A̱filisiya̱ ra̱ka̱.
\q1 Keleshu ka̱ ka̱nga̱ kuta̱i a uɓon u gaɗi,
\q2 babu kowonvoni a̱ ka̱tsuma̱ ke le.
\b
\q1 
\v 32 Wushuki we ne u ɗai vuza u kuneke azusuki a iɗika a?
\q1 <<Vuzavaguɗu ɗa u zuwai Sihiyona,
\q2 a̱ ubuta̱ u ni u ɗa aza a na i n atakaci a̱ kuciya̱ wishi.>>
\c 15
\s1 Kene ku wuya adama a Muwabu
\p 
\v 1 Na va ɗaɗa kadanshi ka na a yaꞋin a kubana wa aza a Muwabu,
\q1 o bonoko ta̱ likuci i Aru agali i na yi a iɗika i Muwabu,
\q2 a̱ la̱nga̱sa̱ ta̱ i ɗa a̱ ka̱tsuma̱ ka kayin ke te.
\q1 Kiru vu Muwabu vo okpo ta̱ agali,
\q2 wo okpoi agali a̱ ka̱tsuma̱ ka kayin ke te.
\v 2 Uma a Dibon i ta̱ a kubana a̱ a̱Ꞌisa̱ e le
\q2 a na i a gaɗi va aginda adama a na a yaꞋan kpalu.
\q1 I ta̱ a kubana a̱ nva̱li n le ka̱ta̱, a̱ ka̱na̱ ma̱shi adama a Nebo m Medeba
\q2 n o gbonduwoi aci e le n a punai ntsa̱ka̱ dem.
\q1 
\v 3 A uka akashi a una̱mgbuka̱tsuma̱ ka̱ta̱ a̱ uta̱ a baya,
\q2 a̱ ka̱na̱ ma̱shi a gaɗi vu kukpa̱Ꞌa̱ vi le n ubuta̱ u kuyongo u uma n a̱bunda̱i
\q2 ali n a vaki a iɗika adama a̱ ma̱shi a.
\q1 
\v 4 Uma a Heshibon n Eliyali i ta̱ a̱ kushika̱
\q2 ali aza daꞋin a na i a Jahaza a pana ma̱shi me le.
\q1 Ali osoji a Muwabu o orukpo m ma̱shi
\q2 adama a na a̱ɗu e le a shama ta̱ n wovon.
\q1 
\v 5 N shika̱ ta̱ n ka̱ɗu adama a aza a Muwabu.
\q2 Uma a̱ ni i ta̱ a kusuma a kubana a̱ likuci i Zora koɓolo n Igila-shelishiya.
\q1 M ma̱shi ka̱ta̱ o tono n uye u Luhita,
\q2 ali ka̱ta̱ ma̱shi ma adama a munuka me le ma yawa a Haroniya.
\q1 
\v 6 Kuyene ku Nimirim
\q2 ku ɗekpe ta̱
\q1 ali m mita̱ dem me ɗekpei,
\q2 Ica̱shi dem ko ili i ta̱ku i buwa ba.
\q1 
\v 7 Adama a nannai, ɗa a̱ pura̱i uciyi wa̱ a̱bunda̱i
\q2 u na ishi o foɓoi,
\q1 ɗa kpamu a lazai a pasai
\q2 kuyene ku nɗanga ku na e ci ɗeke Wilo.
\q1 
\v 8 Ma̱shi ma atakaci me le ma yawa ta̱
\q2 a iɗika i Muwabu,
\q1 ili i na i ɗikai a uteku u nampa ali a kubana a uteku u nan ɗe,
\q2 u gita̱i a Igilamu ali a kubana a Beri-elamu.
\q1 
\v 9 Adama a na mini mo kuɗolu ma Dibon ma shana ta̱ nu mpasa,
\q2 ama ka̱ta̱ n kotso n ele ba.
\q1 Kawu wi ta̱ a kutamba aza a Muwabu a na a cigai kulaꞋa n wuma u le,
\q2 ka̱ta̱ u kotso wu una aza a na i punu a iɗika ya.
\c 16
\p 
\v 1 Suku maku ma malala tsu kuneꞋe a kubana u vuza vu tsugono vi iɗika,
\q1 n ɗa mu uta̱ a Sila o tono nu n ɗa n uye u kakamba,
\q2 a kubana a kusan ku singai ku Sihiyona.
\q1 
\v 2 A̱ma̱ci aza o Mowabu o okpo ta̱ uteku tsu nnu
\q1 n na o lokoi a cikinda
\q2 ɗa a wacuwai ɗe a kapasa ko kuyene ku Anu.
\b
\q1 
\v 3 <<Nekei kadanshi,
\q2 ka̱ta̱ i yaꞋan kasingai,
\q1 pala tsu uteku tsu maɗanga ma na me ci neke kulu
\q2 a kanna ku usuɗukpi,
\q1 ka̱ta̱ vu ka̱sukpa̱ tsu tsu uvuka a̱ kulu ku nu.
\q2 A̱ tsu olokushi a ɗa, sokongu tsu a̱ ubuta̱ u na vuza we kene tsu ba.
\q1 
\v 4 ka̱sukpa̱i aza a Muwabu a na
\q2 o lokoi o yongo n a̱ɗa̱,
\q1 okpoi aza a na a kisa le,
\q2 a̱ ubuta̱ wa aza a na a kuna le.
\q1 Keneki ka atakaci ki ta̱ a kuyawa a uteku,
\q2 ka̱ta̱ munuka mo kotso,
\q1 aza a̱ vishili feu i ta̱ a̱ kuka̱sukpa̱ iɗika ya.
\q1 
\v 5 N ucigi Vuzavaguɗu wi ta̱ a kuzuwa kakuba ko tsugono,
\q2 n kasingai ka̱ta̱
\q2 vuza yoku e kefeku ka Dawuda
\q1 a̱yi na u ci yaꞋan afada n kasingai,
\q2 ka̱ta̱ u yaꞋan moloko u tuka̱ n kasingai.>>
\b
\q1 
\v 6 Tsu pana ta̱ ɗe a̱ra̱ɗi a aza a Muwabu,
\q2 uteku tsu na wi n a̱ra̱ɗi,
\q1 n ugbamukaci, n a̱ra̱ɗi kpamu koɓolo n ishikushi i ni.
\q2 Ama a̱ra̱ɗi a̱ ni gbani ɗa.
\q1 
\v 7 Adama a nannai yaꞋan aza a Muwabu a̱ shika̱ adama a̱ ka̱ci ke le.
\q2 Shika̱i
\q1 ka̱ta̱ i yaꞋan una̱mgbuka̱tsuma̱
\q2 adama a uma a Kiri-harese.
\b
\q1 
\v 8 Ashina o Heshibon a lumba ta̱,
\q2 koɓolo n itacishi i Sibuma feu.
\q1 Ngono ma aduniyan
\q2 n la̱nga̱sa̱ ta̱ itacishi i na i laꞋi n ugaꞋin,
\q1 i na i tatsai ali i yawai Jaza
\q2 ali a kubana a kakamba.
\q1 Aralu e le a walai
\q2 ali a yawai a mala
\q1 
\v 9 Ɗaɗa n shika̱i tsu na Jaza u shika̱i,
\q2 adama a itacishi i Sibuma.
\q1 n ta̱na̱ta̱ngu wu ta̱ n kujilya.
\q2 Avu Heshibon n Eliyali,
\q1 KacaꞋa ka̱ ma̱za̱nga̱ adama a umaci u na u geꞋwei koɓolo n ayin a vikyaꞋa a̱ nu
\q2 ka yawa ta̱ uteku.
\q1 
\v 10 Ma̱za̱nga̱ n kupana ku yoꞋo ma buwa lo a ashina a ba.
\q1 A ashina a itacishi babu vuza na u kuyaꞋan kacaꞋa ko vishipa.
\q2 Babu vuza na u kudoku wa pisha ma̱kya̱n
\q1 a̱ ubuta̱ u kupisha u le,
\q2 adama a na n zuwa ta̱ uteku u ma̱za̱nga̱ wa.
\q1 
\v 11 Adama a nannai ka̱ɗu ka̱ va̱ ka̱ na̱mgba̱ ta̱ uteku tsu kacaꞋa ku umolu adama a Muwabu,
\q2 punu a̱ ka̱tsuma̱ ka̱ va̱ kpamu adama a̱ Kiru-harese.
\b
\p 
\v 12 A ayin a na baci Muwabu wu uta̱ka̱i ka̱ci ka̱ ni e keteshe ka̱ a̱Ꞌisa̱, ka̱ci ka̱ ni kaꞋa u koꞋuso koci. Ayin a na baci u banai a̱ ma̱va̱li ma̱ ni adama a na u yaꞋan kavasa, wi a̱ kuciya̱ wu ushuki ba.
\p 
\v 13 Na va ɗaɗa kadanshi ka na Vuzavaguɗu u dansai m megeshe ɗe adama a Muwabu.
\v 14 Ama gogo na Vuzavaguɗu u yaꞋan ta̱ kadanshi u danai, <<A̱ ka̱tsuma̱ ka̱ a̱ya̱ a tatsu uteku tsu na kagbashi ka na a ɗikai ulinga u tsu kece. Kupana ku uyoꞋo ku Muwabu n ka̱bunda̱i ka uma a̱ ni, i ta̱ o kokpo n wono, aza a na a kulaꞋa kpamu i ta̱ o kokpo kenu babu utsura.>>
\c 17
\s1 Kene ku wuya adama a iɗika i Dimaska
\p 
\v 1 A kaka adama a Dimaska,
\b
\q1 La̱na̱, Dimaska wo kokpo likuci kpamu ba,
\q2 ama wi ta̱ o kubono agali.
\q1 
\v 2 Likuci n a̱bunda̱i ya aza a Aro yi ta̱ o kokpo ukuna u gbani,
\q2 ka̱ta̱ wo okpo ubuta̱ u kalina ku ushiga wu nlala,
\q2 ka̱ta̱ a vaku lo babu vuza na u kuneke le wovon.
\q1 
\v 3 Vuzavaguɗu MalaꞋimili u danai, Likuci yu ukanji i Ifirayimu yi ta̱ o kukotso,
\q2 ka̱ta̱ tsugbayin tsu tsugono tsu Dimaska,
\q1 n aza a na a buwai a Siriya tsu puwa̱nka̱
\q2 an tsugbayin tsu muku mi Isaraila.
\b
\q1 
\v 4 A kanna ka nanlo tsugbayin tsu Yakubu ci ta̱ a̱ kuyikpa̱,
\q2 ka̱ta̱ ugbonguri wi ikyamba u ni u yamba.
\q1 
\v 5 Wi ta̱ o kokpo tsu na kacimbi ka tsu kapa ilikulya,
\q2 ka̱ta̱ kpamu u kyaꞋa n ekiye a̱ ni,
\q1 n uteku tsu na kpamu vuza u ci yaꞋan kuɗayu
\q2 a̱ ka̱ra̱Ꞌa̱ ka Rafi.
\q1 
\v 6 Vuzavaguɗu Ka̱shile ki Isaraila u danai, ko n nannai ili i kuɗayu yi ta̱ a kubuwa,
\q2 uteku tsu na a tsu lapa maɗanga ma zaitu
\q1 ka̱ta̱ a nusa umaci u re ko u tatsu
\q2 ko u na̱shi ko u tawun
\q1 ɗe a acaka a na a laꞋi
\q2 n daꞋin n kumatsa ka̱u.
\b
\p 
\v 7 A ayin a nanlo uma i ta̱ a kinda kayaꞋin ke le, ka̱ta̱ o bonoko a̱shi e le a ubuta̱ u vuza ciɗa va aza a Isaraila.
\v 8 I o kudoku a kinda atali alyuka a na a yaꞋin n ekiye e le ba, i kpamu o kudoku a cikpa ili i na a yaꞋin n ekiye e le ba, ko Asherimi ko atali alyuka a ili i ma̱gula̱ni.
\p 
\v 9 A kanna ka nanlo likuci i gbagbaꞋin i le, i na a̱ ka̱sukpa̱i adama a aza a Isaraila yi ta̱ o kokpo tsu ubuta̱ u na a̱ ka̱sukpa̱i ɗa wo okpoi mura̱ta̱i n a̱vuku. Ra̱ka̱ wi ta̱ o kokpo agali.
\b
\q1 
\v 10 Adama a na avu vi cinukpa ta̱ n Ka̱shile ka na ki isai nu,
\q2 vi ciɓa n kakpanlai ka na ko sokongi nu va ba.
\q1 Adama a nannai, vi ca̱Ꞌi icuꞋu i na vi cigai,
\q2 ɗa vi ca̱Ꞌi icuꞋu yi itacishi i yoku i na yu uta̱i a̱ ubuta̱ u yoku.
\q1 
\v 11 Vi ta̱ a kufuɗa va zuwa le o gbonguro a kanna ka na vi ca̱Ꞌi le,
\q2 ka̱ta̱ kpamu vu zuwa le a yaꞋan a̱pa̱lu n usana u na vi ca̱Ꞌi le.
\q1 Ko n nannai vikyaꞋa vu nu vi ta̱ o kokpo ukuna u gbani
\q2 a kanna ka̱ mɓa̱la̱ nu mɓa̱la̱ n na n kukpa̱ɗa̱ kuta̱na̱.
\b
\q1 
\v 12 Panai osoji a aduniyan n a̱bunda̱i
\q2 a̱ yura̱ tsu yura̱ i mala,
\q1 panai akpanga a gbagbaꞋin o osoji
\q2 a̱ kushida̱ m moloko uteku tsa aɓau a utsura.
\q1 
\v 13 Aduniyan n a̱bunda̱i a̱ yura̱ uteku tsu yura̱ i mini ma̱ a̱bunda̱i,
\q2 ama Ka̱shile ki ta̱ a kudansika le, ka̱ta̱ ele a imkpa a bana daꞋangi
\q1 o kutono wunla̱i an kopo a gaɗi vu nsasan
\q2 tsu na wunla̱i u kabatalikpau u tsu shida̱ n kubuta̱.
\q1 
\v 14 M makyan ma̱ kulivi, ka̱ta̱ wovon u gbayin u ta̱wa̱,
\q2 ama kafu usana ka̱ta̱ u ɗa u kotso.
\q1 Na ɗa u kokpo ugboku wa aza a na i o kudoro tsu,
\q2 koɓolo n katsupu ka aza a na i a̱ kupura̱ ucanuku u tsu.
\c 18
\s1 Kene ku wuya adama a iɗika i Itopiya
\p 
\v 1 Ili ya atakaci i ɗa a kubana wi iɗika yi izumgbi i malapa me evelyu,
\q2 i na yi upashi u kuyene ki Itopiya,
\q1 
\v 2 i na i suki aza a akaka a na o tonoi m mini
\q2 n antsu a na a yaꞋin m mita̱ ma na e ci ɗeke papiru\f + \fr 18:2 \ft Papiru kula ku mita̱ mo yoku maꞋa ma na a ci yaꞋanka antsu a̱ mini\f*.
\q1 Walai a̱ɗa̱ aza a na a tsu banka n akaka gogoꞋo,
\q2 a kubana u uma a na i n ugaɗi n ikyamba ugbori,
\q1 aza a na uma i a kupana wovon u le, aza a daꞋangi n aza ɗeɗevu
\q2 n iɗika i na yi n utsura koɓolo n ulyaꞋi,
\q2 i na yi upeciki ni nyeneke.
\b
\q1 
\v 3 A̱ɗa̱ umaci wa aduniyan ra̱ka̱,
\q2 a̱ɗa̱ aza a na i ida̱shi aduniyan dem,
\q1 ayin a na baci a̱ ɗengusa̱i urotu a gaɗi vu kusan, yi ta̱ e kene.
\q2 Ayin a na baci kpamu a̱ lika̱i vugbala, yi ta̱ a kupana.
\q1 
\v 4 Ili i nampa ya i ɗa Vuzavaguɗu u danai mu,
\q1 <<Mi ta̱ a̱ kuda̱sa̱ngu a̱ ubuta̱ wi ida̱shi i va̱ ka̱ta̱ m paɗa bini mi indana,
\q2 uteku tsu usuɗukpi u kpandari n kanna,
\q2 ko keleshu ka ciza a ayin a vikyaꞋa.>>
\q1 
\v 5 Kafu vikyaꞋa vi yawa, ayin a na baci a̱pa̱lu a̱ sa̱ruwa̱i,
\q2 ɗa a̱pa̱lu a o bonoi umaci u na u geꞋwei,
\q1 wi ta̱ a kutaꞋa umaci wa n kokoꞋi,
\q2 ka̱ta̱ u koɗo acaka a u vakangu.
\q1 
\v 6 I ta̱ a̱ kuka̱sukpa̱ka̱
\q2 asakali a nsasan koɓolo
\q2 nu nnama n kakamba even a ikyamba i le adama a na a takuma.
\q1 Nnu mi ta̱ a kulyaꞋa le a ayin a kpandari dem,
\q2 nnama n kakamba tamkpamu n takuma le a ayin a̱ uta̱ni dem.
\b
\p 
\v 7 A ayin a nanlo uma a na i n ugaɗi n ikyamba ugbori,
\b
\q1 aza a na uma i a kupana wovon u le,
\q2 aza a daꞋangi n aza ɗeɗevu n iɗika i na yi n utsura
\q1 koɓolo n ulyaꞋi, i na yi upeciki ni nyeneke i ta̱ a̱ kutuka̱ n kuneꞋe a ubuta̱ u kusan
\q2 ku Sihiyona a̱ ubuta̱ u kula ku Vuzavaguɗu MalaꞋimili.
\c 19
\s1 Kene ku wuya adama a iɗika i Masar
\p 
\v 1 Na va ɗaɗa kadanshi adama a Masar,
\b
\q1 La̱na̱i Vuzavaguɗu ɗa lo a̱ kuta̱wa̱ e keleshu
\q2 ka na ki a kusuma ka̱u a̱ kuta̱wa̱ a Masar.
\q1 A̱ma̱li aza a Masar i ta̱ e kujeꞋeke ikyamba kelime ka̱ ni
\q2 ɗa ikyamba ya aza a Masar i kuwa̱i.
\q1 
\v 2 <<Mi ta̱ a kukushangu aza a Masar a̱ shilika̱ uteku u le,
\q2 ka̱ta̱ a̱ shilika̱ vuza n vuza ni,
\q2 yaba dem n vuza na i ida̱shi koɓolo,
\q2 likuci kpamu i shilika̱ n likuci i yoku, tsugono kpamu a̱ shilika̱ n tsugono ci yoku.
\q1 
\v 3 Aza a Masar i ta̱ a̱ kuta̱ka̱ n a̱ɗu e le,
\q2 ka̱ta̱ mpa n zuwa kusheshe ku le kokpo ukuna u gbani,
\q1 i ta̱ a kucinaka a̱ma̱li e le n a̱kpisa̱
\q2 koɓolo n eneki n oboci.
\q1 
\v 4 Vuzavaguɗu MalaꞋimili u danai kpamu,
\q2 mi ta̱ e kuneke aza a Masar
\q1 u vuzagbayin va asuvu awuya,
\q2 ka̱ta̱ mogono ma asuvu a usuɗukpi ma lyaꞋa tsugono we le.>>
\b
\q1 
\v 5 Mini ma mala mi ta̱ e kuɗekpe,
\q2 ka̱ta̱ kuyene ku kotso ali ku kuɗekpe.
\q1 
\v 6 Nka̱riki dem mi ta̱ a̱ kuꞋinka̱,
\q2 nyeneke n wawaꞋa dem m Masar mi ta̱ e kuɗekpe.
\q2 Ka̱ta̱ ajanu n apulufa ra̱ka̱ a lumba,
\q1 
\v 7 koɓolo kpamu n ica̱Ꞌa̱shi i na yi a uɓon u mala ma̱ Nilu,
\q2 n i na yi a̱ ka̱kina̱ ka mala feu.
\q1 Kashina ka na ki uca̱Ꞌi a uɓon u mala dem ki ta̱ e kuɗekpe,
\q2 ka̱ta̱ wunla̱i u pura̱ le babu ili i na i kubuwa.
\q1 
\v 8 Osoruku i ta̱ a̱ kushika̱ n una̱mgbuka̱tsuma̱,
\q2 n aza a na a ci yaꞋan karaɗa dem e kuyene ku Nilu,
\q1 n aza a na a tsu taɗuku ubirigi
\q2 i ta̱ o kuyongo a̱ yura̱.
\q1 
\v 9 Aza a na a ci yaꞋan kucaꞋa n tsugbere tsa akaɗa i ta̱ a̱ kuka̱sukpa̱,
\q2 aza a na kpamu a tsu caꞋa aminya kpamu i ta̱ a̱ kuta̱ka̱ n a̱ɗu e le.
\q1 
\v 10 Aza a na i a kuyaꞋan ulinga u kucaꞋa ka akashi a̱ɗu a̱ kuna̱mgba̱ le ta̱.
\q2 Aza a na a ci yaꞋan zamalinga a̱ɗu a̱ kuna̱mgba̱ le ta̱.
\b
\q1 
\v 11 Aza gbagbaꞋin a Zowa alau gbani-gbani a ɗa,
\q2 aza a ugboji a na e ci neke FiriꞋauna kadanshi e neke yi ta̱ odoki a gbani-gbani.
\q1 Nini ɗai va kudana FiriꞋauna.
\q2 <<Mpa mi ta̱ a̱ ka̱tsuma̱ ka aza a ugboji,
\q2 maku mo ngono ma aza a cau>>?
\q1 
\v 12 Te ɗai aza ugboji a̱ ɗa̱ i?
\q2 YaꞋan a dana ɗa̱
\q2 ka̱ta̱ a̱ ka̱sukpa̱ ɗa̱ i yeve ili i na Vuzavaguɗu MalaꞋimili u sheshei kuyaꞋanka aza a Masar.
\q1 
\v 13 Aza a̱ gba̱ra̱-gba̱ra̱ a Zowa o okpo ta̱ alau,
\q2 o doro ta̱ aza e kelime a Manpis,
\q1 aza a tsugbayin a̱ likuci i le
\q2 ele ɗa a vakangi aza a Masar.
\q1 
\v 14 Vuzavaguɗu u suꞋuku ta̱ aza a Masar n wunla̱i u gbani-gbani,
\q1 u ɗa wi ta̱ a kuzuwa aza a Masar a tambalukpa n i na a kuyaꞋan dem,
\q2 tsu na kosoꞋi ka̱ ma̱ra̱ u tsu puɗa̱la̱ a̱ ubuta̱ wa ashama a̱ ni.
\q1 
\v 15 Ili i yoku yi lo i na aza a Masar a kuyaꞋan ba,
\q2 a buwa n ka̱ɓa̱nki ba, kaci ko winja, kacaka ke kekeme ko kapulufa.
\p 
\v 16 A kanna ka nanlo aza a Masar i ta̱ o kokpo an a̱ma̱ci. I ta̱ o kokpo n wovon ka̱u adama Vuzavaguɗu MalaꞋimili u ɗengusa̱ ta̱ kukiye ku ni an wa takacika le.
\v 17 Iɗika i Yahuda yi to o kokpo ili i wovon a kubana wa aza a Masar, yaba dem vu na baci u panai e ɗekei kula ku Yahuda wi ta̱ a kupana wovon adama a ili na Vuzavaguɗu MalaꞋimili u sheshei ɗe kuyaꞋanka le.
\p 
\v 18 A kanna ka nanlo likuci i tawun i kuyaꞋan ta̱ lo ya aza a Masar, i na i tsu dansa n kelentsu ka aza KanaꞋana ka̱ta̱ kpamu a yaꞋan akucina o kutono Vuzavaguɗu MalaꞋimili. A̱ ka̱tsuma̱ ke le i ta̱ e kuɗeke likuci i te likuci i munuka.
\p 
\v 19 A kanna ka nanlo i ta̱ a̱ kuciya̱ katalikalyuka ka Vuzavaguɗu punu e mere mi iɗika i Masar, ka̱ta̱ a cina ɗe ma̱shikpu ma Vuzavaguɗu e kureꞋe ku ni.
\v 20 Wi ta̱ o kokpo ili yi urotu nu ngaꞋan u Vuzavaguɗu MalaꞋimili a iɗika i Masar. Ayin a na baci a̱ shika̱i a kubana u Vuzavaguɗu adama aza na i a kutakacika le, wi ta̱ a̱ kusuꞋuku le vuza na u kisa le n vuza na u kuɓa̱nka̱ le ka̱ta̱ wi isa le.
\v 21 A ayin a nanlo Vuzavaguɗu wi ta̱ o kuyotsongu ka̱ci ka̱ ni a kubana wa aza Masar, a kanna ka nanlo i ta̱ e kuyeve Vuzavaguɗu. I ta̱ a kucikpa yi n alyuka n kuneꞋe, ka̱ta̱ a yaꞋanka Vuzavaguɗu akucina ka̱ta̱ o tono a ɗa.
\v 22 Vuzavaguɗu wi ta̱ a kulapa aza Masar m ma̱dukpa̱, wi ta̱ a kulapa le ka̱ta̱ u ta̱na̱ta̱ngu le. I ta̱ o kubono u Vuzavaguɗu ka̱ta̱ u panaka le ufolu u le ka̱ta̱ u potsotongu le.
\p 
\v 23 A ayin a nanlo i ta̱ a kuyaꞋan uye u gbayin ɗe a Masar a kubana a Asiriya. Aza a Asiriya i ta̱ a kubana a Masar, aza a Masar kpamu i ta̱ a kubana wa aza a Asiriya. Ka̱ta̱ aza a Asiriya n aza a Masar a cikpa Vuzavaguɗu koɓolo.
\p 
\v 24 A kanna ka nanlo aza a Isaraila i ta̱ o kokpo vuza tatsu koɓolo n aza a Masar n aza a Asiriya, o okpo una̱singai a aduniyan.
\v 25 Adama a na Vuzavaguɗu MalaꞋimili wi ta̱ a kuzuwaka le una̱singai, ka̱ta̱ u dana, <<Una̱singai u ɗa a̱ɗa̱ aza a Masar uma a̱ va̱, n aza a Asiriya a na n yaꞋin n ekiye a̱ va̱, n aza a Isaraila aza agadu a̱ va̱.>>
\c 20
\s1 Kene ku wuya adama a Masar n Itopiya
\p 
\v 1 A̱ ka̱ya̱ ka na Sagon mogono ma Asiriya u suki kovonshi vu gbayin, u banai a Ashidodu ɗa u shilika̱i n likuci ya ɗa wi isai i ɗa.
\v 2 A ayin a nanlo ɗa Vuzavaguɗu u yaꞋin kadanshi n Ishaya maku ma Amozu. U danai ni, <<Bana vu foɗo akashi a̱ una̱mgbuka̱tsuma̱ a ikyamba i nu, n ataka a e ene a̱ nu.>> Ɗa ta na u yaꞋin nannai, ɗa u ka̱na̱i nwalu koshomboɗi babu kpamu ataka e ene a̱ ni.
\p 
\v 3 Ɗa Vuzavaguɗu u danai, <<Tsu na kagbashi ka̱ va̱ Ishaya u walai koshomboɗi babu kpamu ataka e ene a̱ ni ali a̱ya̱ a tatsu, na va ɗaɗa urotu u na n kutuka̱ n kawuya wa aza a Masar n aza a Itopiya.
\v 4 Nannai ɗa mogono ma Asiriya u kutono n agbashi a aza a Masar koɓolo n aza a̱ Kush oshomboɗi babu ataka kpamu e ene e le, nkoshi n a̱ɗa̱nga̱ni, n atagulu e le e keteshe, ɗa wo okpoi ili i wono a kubana a iɗika i Masar.
\v 5 Aza a na a zuwai a̱ɗu e le a̱ ubuta̱ wa aza a̱ Kush ɗa a yaꞋin a̱ra̱ɗi a kubana wa aza a Masar, i ta̱ a kupana wovon ka̱ta̱ o okpo n wono.
\v 6 A kanna ka nanlo uma a na i ida̱shi a̱ ka̱kina̱ ka mala i ta̱ a kudana, <Indanai ili i na i cinakai aza a na ci nekei katsura, aza a na a̱ tsu tsu suma tsu bana we le ka̱ta̱ a isa tsu e ekiye o mogono ma Asiriya. Nini ɗai tsa kuyaꞋan ka̱ta̱ tsu uruka?> >>
\c 21
\s1 Kene ku wuya adama a Babila
\p 
\v 1 Akaka a i ta̱ a kadanshi ke meremune ma na mi a uɓon u mala.
\q1 Uteku tsu kabatalikpau ka na kuta̱i e Negebu ka̱ta̱ ka̱ pura̱ngu kakamba ku uɓon u ɗaka n utsura,
\q2 nannai ɗa kawuya ka̱ uta̱ ɗe,
\q2 ka̱ta̱ ka̱ pura̱ngu iɗika i gbani-gbani.
\b
\q1 
\v 2 A dana mu ta̱ tsa alatani o wovon,
\q2 kodori u lyaꞋa kelime m modoruko, vuza munuka u lyaꞋa kelime m munuka ma̱ ni.
\q1 Ɗenga̱i a̱ɗa̱ aza a Elim n aza a Midiya i kambuku ka̱ta̱ a̱ shilika̱ n aza a Babila.
\q2 Adama a na mpa Vuzavaguɗu n kucina ta̱ an ma zuwa uteku wa atakaci a na a̱ tuka̱i.
\b
\q1 
\v 3 U ɓa̱la̱ mu ta̱ ka̱u, uteku tsu vuka va̱ a̱ga̱nda̱ a limata.
\q2 Ikyamba i va̱ i kuwa̱ ta̱ ɗa u ɓa̱la̱i mu ka̱u,
\q1 ali ɗa m kpa̱ɗa̱i kufuɗa kupana ko me ene.
\q1 
\v 4 Ka̱ɗu ka̱ va̱ ka̱ shulyuku ta̱ ka̱u,
\q2 ɗa wovon u zuwai mu kujeꞋeke ikyamba,
\q1 kayin ka na mi a kuvana ka̱ ta̱wa̱,
\q2 ɗa ko okpoi mu ko wovon.
\b
\q1 
\v 5 O foɓusoi ka̱ɗiva̱ ki ilikulya,
\q2 o poloi ajiba adama a na uma a̱ da̱sa̱ngu,
\q2 yaba dem a kulyaꞋa n u soꞋi,
\q1 gogoꞋo ɗa̱nga̱i, a̱ɗa̱ aza a̱ gba̱ra̱-gba̱ra̱,
\q2 putalai nra̱ga̱ n ɗa̱ maniꞋin.
\p 
\v 6 Ili i na Vuzavaguɗu u danai mu i ɗa na,
\q1 <<Bana vu zuwa kindi,
\q2 ka̱ta̱ u dana uma ili i na we enei.
\q1 
\v 7 Ɗa baci we enei akumbi,
\q2 e ekeke o odoku a aza e re e re,
\q1 a gaɗi vo odoku n akumbi a njaki,
\q2 koɓolo n akumbi a arakuma,
\q1 yaꞋan u zuwa atsuvu u pana mayin,
\q2 u yongo ufoɓushi.>>
\p 
\v 8 Ɗa kindi ka ka dansai n ka̱la̱ka̱tsu ka̱u u danai,
\q1 <<A kanna dem, vuzagbayin vu va̱, n tsu shamgba ta̱ gaɗi vu mashilya ma kindana,
\q2 a kayin lakam n tsu shamgba ta̱ a̱ ubuta̱ u na a zuwai mu.
\q1 
\v 9 La̱na̱, vuma ɗa lo a̱ kuta̱wa̱ e keke vo odoku,
\q2 koɓolo n ka̱tsura̱ ko odoku.
\q1 Ɗa wu ushuki le u danai,
\q2 <Babila u yikpa̱ ta̱, mayun u yikpa̱ ta̱.
\q1 Urotu wa̱ a̱ma̱li a̱ ni dem
\q2 u yikpa̱i furali a iɗika.> >>
\b
\q1 
\v 10 Uma a̱ va̱, aza a na a lapai ɗa e yelyukpei a kagbata,
\q2 n dana ɗa̱ ta̱ ili i na m panai
\q1 a̱ ubuta̱ u Vuzavaguɗu MalaꞋimili,
\q2 Ka̱shile ka aza Isaraila.
\s1 Kene ku uwuya adama a Edom
\p 
\v 11 Akaka adama a aza a Duma\f + \fr 21:11 \ft Ili i na Duma wi a kudana i ɗaɗa ka̱bini\f*.
\q1 Vuza yoku u ɗeke mu ta̱ ɗe a Siyaru u danai,
\q2 <<Kindi, wana ɗai kayin ko kukotso?
\q2 Wana ɗai ko kukotso?>>
\q1 
\v 12 Ɗa kindi ka ku ushuki,
\q2 <<Kayin ki ta̱ a kasa, kanna kpamu ki ta̱ o kukotso.
\q1 Vi baci n keci, ece,
\q2 ka̱ta̱ vu doku vu bono kpamu.>>
\s1 Kene ku wuya adama a aza a Alaraba
\p 
\v 13 Akaka adama aza a Alaraba,
\q1 a̱ɗa̱ aza a tsulaga a nwalu a Dedanu,
\q2 aza a na a vaki a kakamba ka̱ durum ka Alaraba,
\q2 
\v 14 tuka̱i m mini adama aza a kakuli,
\q1 a̱ɗa̱ vu na yi ida̱shi a iɗika i Tima.
\q2 Tuka̱i n ilikulya adama a aza a na a sumai adama o kuvon.
\q1 
\v 15 Adama a na a suma ta̱ adama o kotokobi,
\q2 a̱ ubuta̱ wu ukpa̱ u kotokobi,
\q1 a̱ ubuta̱ wu utan u na a katsuki,
\q2 koɓolo n ubuta̱ u na kuvon ku suɗukpai.
\p 
\v 16 Ili i na Vuzavaguɗu u danai mu i ɗaɗa na, <<A̱ ka̱tsuma̱ ka̱ ka̱ya̱ ke te, tsu na a ci ɗika vuza vu zamalinga ka̱ta̱ u ka̱na̱ kukece, ta tsugbayin tsu Kedaru tsa kuyawa uteku nannai.
\v 17 Vuzavaguɗu, Ka̱shile ka aza a Isaraila ka danai, aza o kuvon e Kedaru, i ta̱ o kokpo kenu.>>
\c 22
\s1 Kene ku wuya adama a Urishelima
\p 
\v 1 Na ɗa akaka adama a̱ ka̱ra̱Ꞌa̱ ka tsalatani.
\q1 Yiɗa̱i yi o koꞋuso wu gogo na,
\q2 ali ɗa dem vu ɗa̱ i kumbai gaɗi vu kukpa̱ va asaka,
\q1 
\v 2 a̱ɗa̱ likuci i na yi tukpa n kacaꞋa,
\q2 likuci i na i shanai n yoroli i ma̱za̱nga̱ n a̱ra̱ɗi?
\q1 Aza a̱ ɗa̱ a na a̱ kuwa̱i ɗe va, a̱ kuwa̱ n ukpa̱ u kotokobi ba,
\q2 ko ukpa̱ wu ubuta̱ u kuvon ba.
\q1 
\v 3 Aza e kelime a̱ ɗa̱ dem a suma ta̱ ra̱ka̱,
\q2 e reme le ta̱ babu utawi.
\q1 Ra̱ka̱ vu ɗa̱ vu na a̱ ka̱na̱i a banka ɗa̱ ta̱ ugbashi,
\q2 ko a na wo okpoi a sumai ɗe daꞋin.
\q1 
\v 4 Adama a nannai ɗa n danai, <<Ɗenka̱i mu lo,
\q2 ka̱sukpa̱i mu n shika̱.
\q1 Ka̱ta̱ i leꞋeshe mu
\q2 adama a ula̱nga̱shi u na i yaꞋankai uma a̱ va̱ ba.>>
\q1 
\v 5 Vuzavaguɗu, Vuzavaguɗu MalaꞋimili wi ta̱ n kanna
\q2 ka wuya, n kanna ka atakaci, kanna ko wovon,
\q2 a̱ Ka̱ra̱Ꞌa̱ ka Tsalatani,
\q1 kanna ka̱ ma̱shi n kacaꞋa
\q2 a̱ kula̱nsa̱ uɓa̱nki a kusan.
\q1 
\v 6 Aza e Elim o woki njiki koɓolo
\q2 n ekeke o odoku n akumbi e le,
\q2 ɗa aza a Kiru e remei nra̱ga̱.
\q1 
\v 7 A̱ra̱Ꞌa̱ a̱ nu a na vu laꞋi n kuciga dem, a shana ta̱ n ekeke o odoku,
\q2 ɗa a zuwai akumbi o odoku a shamgbai a̱ utsutsu u likuci,
\q2 
\v 8 Ka̱shile ka takpai ka̱ɓa̱nka̱tsu ka Yahuda.
\b
\q1 A kanna ka nanlo kaꞋa i kula̱nsa̱
\q2 ucanuku u kuvon u na wi usokongi a kakamba,
\q1 
\v 9 ye ene ta̱ nshilya n likuci i Dawuda
\q2 m ɓatsasa ta̱ n a̱bunda̱i,
\q1 ɗa i kenuki mini
\q2 a adaɓa a ɗaka.
\q1 
\v 10 I kecei imashi ya asaka a na i a Urushelima,
\q2 ɗa i ɓosoi asaka o yoku adama a na i maꞋasaka mashilya ma̱ ciya̱ mo doku utsura.
\q1 
\v 11 Ɗa kpamu i ga̱va̱i ubuta̱ u na i kukpada mini e mere ma nshilya n re
\q2 n likuci ma adama a kadaɓa ka̱ kuku,
\q1 ama i bonoko ma̱riki ma̱ ɗa̱ a kubana a̱ ubuta̱ u vuza na u yaꞋin mini ma,
\q2 ko kpamu i bonoko Vuza na u sheshei kuyaꞋan ili i nampa ya n tsumani ili ba.
\b
\q1 
\v 12 A kanna ka nanlo, ɗa Vuzavaguɗu MalaꞋimili dem,
\q2 u ɗekei ɗa̱ adama a na
\q1 i shika̱ n una̱mgbuka̱tsuma̱,
\q2 i gbonduwo aci a̱ ɗa̱ ka̱ta̱ i uka akashi a una̱mgbi u ka̱tsuma̱.
\q1 
\v 13 Ama la̱na̱i, ma̱za̱nga̱ mi ta̱ lo n kupana ku uyoꞋo,
\q2 kukiɗa ka anaka nu nlala,
\q2 kutakuma ki inyama n kusoꞋo ku ma̱kya̱n,
\q1 <<YaꞋan ci lyaꞋa ka̱ta̱ tsu soꞋo,
\q2 adama a na mkpaꞋa ci ta̱ a̱ kukuwa̱.>>
\p 
\v 14 Vuzavaguɗu MalaꞋimili u dansa ta̱ kadanshi ka nampa a atsuvu a̱ va̱, <<Mayun unushi u nampa a kucinukpa n u ɗa ba, ali sai kanna ka na vu kuwa̱i.>> Mpa Vuzavaguɗu MalaꞋimili n dansa ta̱.
\p 
\v 15 Ili i na Vuzavaguɗu MalaꞋimili u danai mu i ɗaɗa na,
\q1 <<Bana gogoꞋo vu dana kagbashi ka nampa ka
\q2 Shebuna vuza na wi a̱ kula̱na̱ kefeku ko tsugono ka.
\q1 
\v 16 Yiɗa̱i vi a kuyaꞋan na, yayi kpamu vuza na u nekei nu katsura ka na
\q2 vu sheꞋweke ka̱ci ka̱ nu kasaun punu na,
\q1 avu na vu ga̱va̱i kasaun ka̱ nu zuva,
\q2 ɗa vu sheꞋwei ubuta̱ u kuvuka u nu a kakpanlai?
\q1 
\v 17 Yeve, Vuzavaguɗu u sheshe ta̱ an wa reme wu gbam-gbam,
\q2 ka̱ta̱ u vakangu wu daꞋin, avu vuma vu utsura.
\q1 
\v 18 Wi ta̱ a̱ kuka̱ta̱la̱ wu ka̱ta̱ u shiya wu gbam-gbam
\q2 ka̱ta̱ u taɗuku tsu kolo a kubana a iɗika i gbayin,
\q1 ta ɗe va̱ kukuwa̱
\q2 ka̱ta̱ kpamu ekeke o odoku a̱ nu a shama ɗe.
\q2 Vo okpo ta̱ ili i wono a kpaꞋa ku vuzagbayin vu nu.
\q1 
\v 19 Mi ta̱ a̱ kuta̱ka̱ wu a ubuta̱ wu ulinga u nu,
\q2 ka̱ta̱ m bonoko tsugbayin tsu nu a iɗika.
\v 20 A kanna ka nanlo mi ta̱ a̱ kusuku e ɗekeke mu kagbashi ka̱ va̱ Eliyakimu kolobo ka Hilikiya.
\v 21 Mi ta̱ a kuꞋuka yi motogu mu ulinga ma̱ nu ka̱ta̱ n shiya yi n kaɗambura ka̱ nu a̱ kuyun ku ni, ka̱ta̱ i neke yi tsugbayin tsu nu wa̱ ni. Wi ta̱ o kokpo esheku a aza a na i ida̱shi a Urishelima, n aza a kpaꞋa ku Yahuda.
\v 22 Mi ta̱ e kuneke yi katsura ka kpaꞋa ku Dawuda, Ili i na baci u ɓa̱yuwa̱i babu vuza na u kuɓa̱ya̱ngu, i na kpamu u ɓa̱ya̱ngi babu ka̱ɓa̱yuwi.
\v 23 Mi ta̱ a kukutangu yi tsu kaguta a̱ ubuta̱ wu utsura, ka̱ta̱ wo okpo kakuba ko tsugono ku ucikpi ka kpaꞋa ke esheku a̱ ni.
\v 24 I ta̱ kpamu e kuneke yi tsugbayin tsu kpaꞋa tsu le ra̱ka̱, ka̱ta̱ kumaci ku kpaꞋa ku le ra̱ka̱ ku bono ku zuwaka yi a̱miki, tsu na a tsu saku ili yu ulinga, nvene, n edele a gaɗi vu kirukpa.
\v 25 A kanna ka nanlo, Vuzavaguɗu MalaꞋimili u danai, kaguta ka na a̱ shikpa̱i a̱ ubuta̱ wu utsura wa, ki ta̱ o kukoɗo ka̱ta̱ ka̱ yikpa̱, ucanuku u na wi usaɓangi gaɗi vi ni u yikpa̱. Adama a na Vuzavaguɗu ɗa u danai.>>
\c 23
\s1 Kene ku wuya adama a̱ likuci i Taya
\p 
\v 1 Kene adama a̱ likuci i Taya,
\q1 na̱mgba̱i a̱tsuma̱, a̱ɗa̱ antiki a antsu a Taya a na uta̱i a Tarishi,
\q2 adama a na a̱ la̱nga̱sa̱ ta̱ Taya
\q2 ɗa wo okpoi babu kpaꞋa
\q1 n ubuta̱ u kuzuwa antsu dem.
\q2 Ɗaɗa kadanshi kuta̱i a iɗika i Sairusu ɗa ka̱ ta̱wa̱i we le.
\b
\q1 
\v 2 Shika̱ n ka̱bini a̱ɗa̱ na yi ida̱shi o kotogu,
\q2 a̱ɗa̱ aza a tsulaga a Sidon, aza a tsulaga a̱ ɗa̱ a pasa ta̱ mala,
\q2 adama a na a zuwa likuci i ɗa̱ yo okpo yi uciyi.
\q1 
\v 3 Ili i kashina i Shiho,
\q2 yu uta̱ ta̱ a mala me Meditereniya,
\q1 i na a cimbai o kuyene ku Nilu, i ɗaɗa a̱ tuka̱i a Taya,
\q2 ɗa Taya wo okpoi kuden ku gbayin ka aduniyan dem.
\b
\q1 
\v 4 Pana wono, avu Sidon, avu katsura ka mala
\q2 adama a na mala ma dansa ta̱,
\q1 adama a na mala ma iwan wu ta̱ ma danai, <<Mpa n saꞋwa kuyaꞋan a̱ga̱nda̱ a limata ba, ko m matsa,
\q2 n saꞋwa kuyaꞋan ka̱ɓa̱na̱ ka̱ muku mo olobo ba, ko ke nkere.>>
\q1 
\v 5 A ayin a na baci a̱ tuka̱i n kadanshi ka na ka̱ uta̱i a Masar,
\q2 i ta̱ o kokpo n una̱mgbuka̱tsuma̱ n kadanshi ka Taya ka.
\b
\q1 
\v 6 Pasai a kubana a Tarishi,
\q2 na̱mgba̱i a̱tsuma̱ a̱ɗa̱ na yi ida̱shi o otogu.
\q1 
\v 7 Na va ɗaɗa likuci i ma̱za̱nga̱ i ɗa̱
\q2 i na yi lo ali n ayin a tsumani,
\q1 i na i zuwai uma a̱ ni
\q2 a̱ da̱sa̱ngi a̱ likuci kakau daꞋin?
\q1 
\v 8 Yayi u yaꞋankai aza a Taya kusheshe ku wuya ku nampa,
\q2 a̱yi na u tsu neke tsugono,
\q1 i na aza a tsulaga a̱ ni i tsu muku mu ngono,
\q2 ɗa kpamu e yevei aza a tsulaga a̱ ni a̱ ka̱tsuma̱ ki iɗika dem?
\q1 
\v 9 Vuzavaguɗu MalaꞋimili ɗa u foɓusoi kaꞋa nannai,
\q2 u foɓusoi i ɗa adama a na u yawaka aza a̱ a̱ra̱ɗi uteku,
\q2 u neke uma e le a na i n tsugbayin wono a aduniyan.
\b
\q1 
\v 10 Betuwei a iɗika i ɗa̱ tsu na mala ma̱ Nilu me ci yene,
\q2 a̱ɗa̱ uma Tarishi,
\q2 adama a na i buwa n ubuta̱ u na i tsu zuwa antsu ba.
\q1 
\v 11 Vuzavaguɗu u ɗengusa̱i kukiye ku ni ɗa u sapangi mala ma,
\q2 ɗa u zuwai tsugono ci ni tsu gba̱ɗa̱i.
\q1 Vuzavaguɗu u neke ta̱ kadanshi adama a na
\q2 a̱ la̱nga̱sa̱ ubuta̱ wu utsura u KanaꞋana.
\q1 
\v 12 U danai, <<Vo kudoku va yaꞋan ma̱za̱nga̱ ba,
\q2 a̱ɗa̱ uma a Sidon.
\b
\q1 <<Ɗenga̱ ka̱ta̱ vu pasa a kubana a iɗika i Sairusu,
\q2 ko ɗe va va̱ kuciya̱ wuvuki ba.>>
\q1 
\v 13 La̱na̱ iɗika i Babila,
\q2 uma a na gogo na vuza u buwai a kadanshi ke le ba.
\q1 Aza a Siriya o bonoko ta̱ ubuta̱ wa
\q2 kakamba ka nnama,
\q1 ɗa a maꞋi mashilya me le ma na a kukambuku le n kuvon,
\q2 o ɓosoi efeku o ngono
\q2 ɗa o bonokoi likuci ya agali.
\b
\q1 
\v 14 Lapai una̱ ka̱ta̱ yo orukpo a̱ɗa̱ antiki antsu a Tarishi,
\q2 adama a na ubuta̱ u kuzuwa antsu u ɗa̱ u na̱mgba̱ ta̱.
\p 
\v 15 A ayin a nanlo i ta̱ a kucinukpa n Taya ali a̱ya̱ amangatatsunkupa tsa̱ a̱ya̱ o mogono mo yoku. A ukocishi wa̱ a̱ya̱ amangatatsunkupa ka ki ta̱ feu a kuyaꞋan nannai n Taya uteku tsu vishipa vu kashakanlai,
\q1 
\v 16 <<Ɗika umolu u nu ka̱ta̱ vu tono e mere ma̱ likuci,
\q2 avu kashakanlai ka na a cinukpai,
\q1 waꞋa umolu wa mayin ka̱ta̱ vi canana ishipa n a̱bunda̱i
\q2 ciya̱ a ciɓa n avu kpamu.>>
\p 
\v 17 A kubana ukocishi wa̱ a̱ya̱ amangatatsunkupa Vuzavaguɗu wi ta̱ a̱ kula̱na̱sa̱ka̱ Taya. Ka̱ta̱ Taya u lyaꞋa kelime n kuyaꞋan tsulaga ci ni a aduniyan dem.
\v 18 Ili i na u ciya̱i a̱ ubuta̱ u tsulaga u ni wi ta̱ a kuzuwaka Vuzavaguɗu, o kufoɓo i na a̱ ciya̱i ba, ama ili i na i uwai ni va i ta̱ e kuneke aza a na e nekei a̱ɗu e le u Vuzavaguɗu, adama a na a̱ ciya̱ ilikulyaꞋa ba̱ri n akashi a singai.
\c 24
\s1 Vuzavaguɗu wi ta̱ a kutakacika aduniyan
\q1 
\v 1 Inda Ka̱shile ki ta̱ a̱ kula̱nga̱sa̱ aduniyan
\q2 ka̱ta̱ u bonoko a ɗa tsa agali,
\q1 wi ta̱ a̱ kula̱nga̱sa̱ a ɗa
\q2 ka̱ta̱ u wacuwa uma a̱ ni a na i punu.
\q1 
\v 2 Ili i te i na i kuciya̱
\q2 anan ganu ta kpamu i kuciya̱ uma nannai
\q2 ali a gbagbaꞋin n agbashi feu nannai,
\q2 a̱ma̱ci a gbagbaꞋin ni nkere feu nannai.
\q2 Atsuli n edengi,
\q2 okopuki n aza e kuneke okopu,
\q2 aza o kutono atan n aza e kuneke atan.
\q1 
\v 3 Aduniyan i ta̱ o kokpo ukuna u gbani
\q2 ka̱ta̱ a ɗa a̱ na̱mgba̱ wuya-wuya, aduniyan i ta̱ o kubono agali ta Vuzavaguɗu u yaꞋin kadanshi nannai.
\q1 
\v 4 Aduniyan a lumba ta̱ ra̱ka̱-ra̱ka̱,
\q2 aduniyan kpamu e ɗekpei ɗa a̱ na̱mgba̱i.
\q2 Aza a gbagbaꞋin a yambai ɗa a̱ na̱mgba̱i.
\q1 
\v 5 Aduniyan a yaꞋan ta̱ ula̱nga̱shi,
\q2 adama a na a iwan ta̱ kutono wila̱ u Ka̱shile,
\q1 a̱ la̱nga̱sa̱i i singai
\q2 ɗa kpamu a iwain kutono uzuwakpani u ko wanai.
\q1 
\v 6 Adama a nannai una̱ u gbani-gbani u ka̱na̱ ta̱ iɗika,
\q2 uma a̱ ni a na i punu a ɗika ta̱ unushi u le.
\q1 Adama a nannai uma aduniyan i ta̱ a kuyaꞋan usongi gbende,
\q2 kenu ɗa a̱ kuka̱sukpa̱.
\q1 
\v 7 Ma̱kya̱n ma savu ma me ɗekpe ta̱, itacishi i ni kpamu i lumba ta̱,
\q2 aza a̱ ma̱za̱nga̱ dem a̱ na̱mgba̱ ta̱ ka̱tsuma̱.
\q1 
\v 8 Kucaɗa ku medele ka ku kotso ta̱,
\q2 kacaꞋa ka aza a̱ ma̱za̱nga̱ ka ka shamgba ta̱,
\q2 izumgbi i ma̱za̱nga̱ yu umolu ya i paɗa ta̱ bini.
\q1 
\v 9 O doku o soꞋo ma̱kya̱n n ishipa kpamu ba,
\q2 ma̱kya̱n ma mo okpo ta̱ n okono a̱ ubuta̱ wo soꞋi wa.
\q1 
\v 10 Likuci i na i na̱mgba̱i va yo okpo ta̱ agali,
\q2 iꞋuwa dem i yaꞋan ta̱ uɓa̱ya̱ngi babu ili i na i kuꞋuwa.
\q1 
\v 11 Ayin a̱ ma̱za̱nga̱ o kotso ta̱ a aduniyan, o doku a yaꞋan ishipa i ma̱kya̱n ba,
\q2 ma̱za̱nga̱ dem mo okpo ta̱ ili i wovon,
\q2 a̱ sa̱nka̱ ta̱ ma̱za̱nga̱ a aduniyan dem.
\q1 
\v 12 Likuci i yaꞋan ta̱ ula̱nga̱shi,
\q2 utsutsu u ni kpamu u yaꞋan ta̱ uɓoshi.
\q1 
\v 13 Nannai ɗa ka kuyaꞋan punu a iɗika
\q2 n aduniyan dem,
\q1 tsu ayin a na a tsu lapa umaci u maɗanga ma zaitu,
\q2 n tsu ayin a kuɗayu wana ɗai a taɓa mambulu.
\b
\q1 
\v 14 A̱ ɗengusa̱i a̱la̱ka̱tsu e le, a cananai ishipa i ma̱za̱nga̱,
\q2 na ɗe a̱ ka̱livi o orukpoi adama a tsugbayin tsu Vuzavaguɗu.
\q1 
\v 15 Adama a nannai a̱ɗa̱ na yi a kasana nekei tsugbayin a kubana u Vuzavaguɗu,
\q2 aza a na i o kotogu
\q2 nekei kula ku Vuzavaguɗu vi Isaraila tsugbayin.
\q1 
\v 16 Ali ɗe a uteku wa aduniyan ɗa tsu panai ishipa i kucikpa,
\q2 <<Tsugbayin a kubana u Vuza vu usuɓi.>>
\b
\q1 Ama ɗa n danai, <<Mo okpo ta̱ ukuna u gbani, mo okpo ta̱ ukuna u gbani.
\q2 Ili ya atakaci i ɗa a̱ kuta̱wa̱ wa̱ va̱,
\q1 aza a kuvakangu uma i ta̱ a kulyaꞋa kelime n kuvakangu mu.
\q2 A lyaꞋi kelime kpamu n a kulya ku uma.>>
\q1 
\v 17 Wovon, maza m Kpenle a kuvana ɗa̱,
\q2 a̱ɗa̱ uma a aduniyan a nampa.
\q1 
\v 18 Vuza na wi a kuciga wa suma adama a kacaꞋa ko wovon
\q2 wi ta̱ a̱ kuyikpa̱ e kpenle.
\q1 Vuza na baci u livanki a̱ kuta̱ pulai vu kpenle va,
\q2 maza mi ta̱ a̱ kuka̱na̱ yi.
\b
\q1 Adama a na atusu a gaɗi i ta̱ uɓa̱yuwi,
\q2 ɗa uvari wi iɗika u gba̱ɗa̱i.
\q1 
\v 19 Aduniyan a yaꞋan ta̱ umijarangi ra̱ka̱,
\q2 aduniyan ra̱ka̱ i ta̱ upeci,
\q2 aduniyan dem a̱ gba̱ɗa̱ ta̱ n katsura.
\q1 
\v 20 Aduniyan a̱ ka̱na̱i kuletishe an kosoꞋi,
\q2 a̱ kuvita̱la̱sa̱ a̱ wunla̱i tsu na ka̱pa̱m ka̱ tsu gba̱ɗa̱,
\q1 a̱miki a̱ unushi u ni i ta̱ o kurono yi a̱ kuta̱wa̱ a iɗika,
\q2 ka̱ta̱ u yikpa̱ babu kpamu kufuɗa kuɗa̱nga̱.
\b
\q1 
\v 21 A kanna ka nanlo Vuzavaguɗu wi ta̱ a kutakacika
\q2 utsura u na wi a̱da̱nga̱shile gaɗi,
\q2 ka̱ta̱ kpamu u takacika ngono ma aduniyan punu a aduniyan a nampa.
\q1 
\v 22 I ta̱ o kuɓolongu le a̱ ubuta̱ u te
\q2 tsa agbashi e kpenle ku te,
\q1 i ta̱ a̱ kuɓa̱ya̱ngu le a̱ ubuta̱ wu ugbashi,
\q2 ka̱ta̱ a yaꞋan baci ayin n a̱bunda̱i yeve a takacika le.
\q1 
\v 23 Kutashi ku wotoi ki ta̱ o kubono kpa̱ɓa̱, ka̱ta̱ usuɗukpi u kanna feu u ra̱ma̱,
\q2 Adama a na Vuzavaguɗu MalaꞋimili wi ta̱ a kulyaꞋa tsugono
\q1 a Kusan ku Sihiyona punu a̱ Urushelima,
\q2 ka̱ta̱ tsugbayin ci ni ci shamgba a̱ ubuta̱ wu nkoshi m gba̱ra̱-gba̱ra̱ n ni.
\c 25
\s1 Ucikpi a kubana u Vuzavaguɗu
\q1 
\v 1 Vuzavaguɗu avu ɗa Ka̱shile ka̱ va̱,
\q2 mi ta̱ e kuneke wu tsugbayin ka̱ta̱ n cikpa kula ku nu,
\q1 adama a na vi yaꞋan ta̱ ili i singai.
\q2 Adama a na vi yaꞋan ta̱ ili i mereve derere,
\q2 ili i na e sheshei ali m megeshe ɗe.
\q1 
\v 2 Vu bonoko ta̱ likuci ya kotomo ka atali,
\q2 likuci i mashilya ma gbayin kpamu yo okpoi agali,
\q1 likuci yi utsura yo omoci i buwa ba,
\q2 i ɗa yi kpamu kudoku kumaꞋasaka ba.
\q1 
\v 3 Adama a nannai likuci yu utsura i ta̱ e kuneke wu tsugbayin,
\q2 iɗika i na yi n asuvawuya yi ta̱ a kupana wovon u nu.
\q1 
\v 4 Avu vo okpo ta̱ ubuta̱ u kusheɗeku u vuza vu unambi,
\q2 koɓolo n vuza na wi a̱ kula̱nsa̱ uɓa̱nki, a̱ ka̱tsuma̱ ka atakaci ka̱ ni,
\q1 vo okpo ta̱ kpamu ubuta̱ u kusheɗeku a ayin a̱ mini ma̱ wunla̱i,
\q2 koɓolo n kulu a ayin a̱ usuɗukpi u kanna,
\q1 adama a na ayinviki a aza a gbani-gbani
\q2 i ta̱ tsu mini ma̱ wunla̱i ma na ma̱ tsu pura̱ mashilya,
\q2 
\v 5 tsu na usuɗukpi u ci yaꞋan a iɗika i magbanda.
\q1 Ama avu Vuzavaguɗu sa̱nka̱ kacaꞋa ko omoci,
\q2 uteku u na usuɗukpi u tsu jebe a ayin a na baci keleshu ka yaꞋin ka̱ta̱m,
\q2 nannai ɗa vishipa va aza a na i n asuvawuya, vo kukotso.
\q1 
\v 6 Punu a kusan ku nampa ku ɗa Vuzavaguɗu MalaꞋimili u kufoɓuso
\q2 ka̱ɗiva̱ ka gbayin ki ilikulyaꞋa i na i laꞋi n kugaꞋan adama a uma ra̱ka̱,
\q1 n ka̱ɗiva̱ ki ili i kusoꞋo i singai kpamu n tsuwaꞋa tsu singai,
\q2 koɓolo n inyama i na i laꞋi n kugaꞋan feu.
\q1 
\v 7 Punu a kusan ku nampa wi ta̱ a kutakpa
\q2 ili i na yi ishi e kuneke aduniyan dem una̱mgbuka̱tsuma̱,
\q1 kapalatsu ka na ka palai aduniyan.
\q1 
\v 8 Vuzavaguɗu n ka̱ci ka̱ ni u danai, wi ta̱ a kutakpa ili i na i tsu tuka̱ n ukpa̱
\q1 Wi ta̱ kpamu a kura ma̱shi
\q2 a̱ a̱shi a uma dem,
\q1 ka̱ta̱ kpamu u takpa ili i wono u uma a̱ ni
\q2 a iɗika dem.
\p 
\v 9 A ayin a nanlo i ta̱ a kudana,
\q1 <<Mayun na va a̱yi ɗa Ka̱shile ka̱ tsu,
\q2 ci keɗe ta̱ a̱pa̱ wa̱ ni ɗa ta na wi isai tsu.
\q1 A̱yi na ɗa Vuzavaguɗu, vu na ci keɗei a̱pa̱ a kubana wa̱ ni,
\q2 yaꞋan ci yaꞋin ma̱za̱nga̱ n kupana ku uyoꞋo adama a wishi u ni.>>
\q1 
\v 10 Kukiye ku Vuzavaguɗu ki ta̱ a kuvuka a kusan ku nampa.
\q2 Ama uma a Mowabu ita̱ a kutakacika ka̱u,
\q2 tsu na a tsu dasa mita̱ e kpenle an ciꞋiwa̱.
\q1 
\v 11 Aza a Muwabu i ta̱ e kupetikpe ekiye e le a gaɗi,
\q2 tsu na vuza vu ka̱da̱sa̱ u tsu petikpe ekiye adama a na u da̱sa̱.
\q1 Vuzavaguɗu wi ta̱ a̱ kucipa̱ka̱ a̱ra̱ɗi e le,
\q2 ko a na i n ugboji a̱ a̱shi e le.
\q1 
\v 12 Wi ta̱ a̱ kufa̱da̱ nshilya mu ugaɗi n ɗa̱ dem ka̱ta̱ u vakangu,
\q2 wi ta̱ a̱ kufa̱da̱ le ali iɗika,
\q1 wi ta̱ o kuɓoso le miri-miri
\q2 ka̱ta̱ u bonoko le kubuta̱.
\c 26
\s1 Vishipa vu kucikpa Vuzavaguɗu
\p 
\v 1 A kanna ka nanlo a kucanana ta̱ vishipa vu nampa a iɗika i Yahuda,
\q1 ci ta̱ n likuci yu utsura,
\q2 Ka̱shile ka̱ tuka̱ ta̱ n wishi
\q2 ci ta̱ ukanji m mashilya ushikpi mayin.
\q1 
\v 2 Ɓa̱yuwa̱i utsutsu u likuci
\q2 adama a na uma a usuɓi a uwa punu,
\q2 uma a na i n uneki u ka̱ɗu.
\q1 
\v 3 Avu zuwa yi u yongo m ma̱ta̱na̱
\q2 a̱yi na ka̱ɗu ka̱ ni ki ida̱shi wa̱ nu,
\q2 adama a na u zuwa ta̱ katsura wa̱ nu.
\q1 
\v 4 A ayin dem neke Vuzavaguɗu ka̱ɗu ka̱ nu,
\q2 adama a na Vuzavaguɗu Ka̱shile ka̱ tsu a̱yi ɗa katali ke kusheɗeku ka na ka ci shamgba n utsura ko wannai.
\q1 
\v 5 U bonoko ta̱ aza a na i n a̱ra̱ɗi ukuna u gbani,
\q2 ɗa u la̱nga̱sa̱i likuci yu ugbamukaci i le,
\q1 u fa̱da̱ ta̱ i ɗa gbani-gbani,
\q2 ali ɗa u ɓosoi i ɗa yo okpoi kubuta̱.
\q1 
\v 6 Aza a unambi n aza a na i o kusoꞋo atakaci
\q2 a dasa ta̱ i ɗa n ene e le.
\b
\q1 
\v 7 Ama aza a na i n usuɓi, uye u le wi ta̱ derere m mejege,
\q2 avu ɗa Ka̱shile ka na ka ci yaꞋan ili i singai, avu ɗa vu gboroi uye wa.
\q1 
\v 8 Vuzavaguɗu ta nannai ci ta̱ a kuwala a uye u wila̱ u na vu zuwai,
\q2 tsu vana ta̱ adama a na ci yevesheke wu mayin,
\q1 kula ku nu ku ɗaɗa tsu ili i na ci a kuciga
\q2 ayin dem punu a̱ a̱ɗu a̱ tsu.
\q1 
\v 9 Ka̱ɗu ka̱ va̱ ko ci yongo ta̱ a̱ kula̱nsa̱ wu n kayin dem,
\q2 n usana ka̱ɗu ka̱ va̱ ko ci yongo ta̱ a kuciga kene wu.
\q1 Ayin a na baci afada a̱ nu a̱ ta̱wa̱i a aduniyan a nampa,
\q2 uma a iɗika i ta̱ a kupiꞋisa ili i na i kutuka̱ n usuɓi.
\q1 
\v 10 O yotsongu baci vuza vu gbani-gbani kasingai,
\q2 ɗa u kpa̱ɗa̱i kupiꞋisa ukuna wu usuɓi,
\q1 ali a iɗika ya aza a usuɓi dem wi ta̱ a kulyaꞋa kelime n kavama,
\q2 wi kpamu o kutono tsugbayin tsu Vuzavaguɗu ba.
\q1 
\v 11 Avu Vuzavaguɗu, kukiye ku nu ku yaꞋan ta̱ uɗengushi,
\q2 n ufoɓushi adama a na ku takacika le, ama ele e yeve ba.
\q1 YaꞋan e ene ulinga u nu a̱ ubuta̱ u uma a̱ nu ka̱ta̱ a pana wono,
\q2 ka̱sukpa̱ akina a̱ nu a na i uzuwi adama irala i nu o songu le ra̱ka̱.
\b
\q1 
\v 12 Vuzavaguɗu neke tsu ma̱ta̱na̱
\q2 adama a ili i na ci yaꞋin dem, ci yaꞋan ta̱ n utsura u nu.
\q1 
\v 13 Vuzavaguɗu Ka̱shile ka̱ tsu, a̱ma̱li o yoku a lyaꞋa ta̱ tsugono wa̱ tsu,
\q2 n nannai dem ama kula ku nu ku ɗa koci ci e kuneke tsugbayin.
\q1 
\v 14 Gogo na irala i tsu dem a̱ kuwa̱ ta̱ ɗe o kudoku a̱ ɗa̱nga̱ kpamu ba, vu takacika le ta̱ ɗe,
\q2 wuma u le u na u lazai ɗe u buwa kpamu a̱ kuɗa̱nga̱ n wuma ba.
\q1 Vu takacikai le ɗa vu unai le kpamu,
\q2 o kudoku a ciɓa n ele kpamu ba.
\q1 
\v 15 Avu Vuzavaguɗu vu zuwa ta̱ iɗika i gbonguroi,
\q2 vu zuwa ta̱ iɗika i gbonguroi.
\q1 Vi ciya̱ ta̱ tsugbayin
\q2 ɗa kpamu uteku wi iɗika dem u doki wanshi adama a̱ nu.
\q1 
\v 16 Vuzavaguɗu, n atakaci a ɗa tsu ta̱wa̱i kula̱nsa̱ wu
\q2 ayin a na baci vu takacikai le
\q1 wi ta̱ a kuyaꞋan le n atakaci kafu a vasa\f + \fr 26:16 \ft N kelentsu ka aza a Ibirahi, kakariki ka nampa ka ki ta̱ n atakaci e kuyeve\f*.
\q1 
\v 17 Tsu na vuka vu ka̱tsuma̱ u tsu takacika a̱ ubuta̱ wa̱ a̱ga̱nda̱ a limata,
\q2 a̱ yura̱ m ma̱shi adama a̱ mɓa̱la̱,
\q2 ta ci ishi nannai a̱ ubuta̱ u nu, Vuzavaguɗu.
\q1 
\v 18 Ci ishi ta̱ tsu vuka vu ka̱tsuma̱ a̱ ubuta̱ wa̱ a̱ga̱nda̱ a limata,
\q2 ama ce ene maku ba sai wunla̱i koci.
\q1 Tsu tuka̱ n wishi a iɗika ba.
\q2 Tsu tuka̱ n wuma a iɗika i nampa ba.
\b
\q1 
\v 19 Vuzavaguɗu u danai, aza a̱ ɗa̱ a na a̱ kuwa̱i ɗe i ta̱ a̱ kuɗa̱nga̱ n wuma,
\q2 keven ki ikyamba ke le ki ta̱ a̱ kuɗa̱nga̱.
\q1 A̱ɗa̱ na yi ida̱shi a̱ kubuta̱,
\q2 ɗa̱nga̱i ka̱ta̱ yo orukpo adama a̱ ma̱za̱nga̱,
\q1 tsu na ciza tsu usana tsu tsu ta̱na̱ta̱ngu iɗika,
\q2 adama a na iɗika yi ta̱ a̱ kuta̱ka̱ n aza a na a̱ kuwa̱i.
\b
\q1 
\v 20 Lazai uma a̱ va̱, uwai a̱ unu a̱ ɗa̱
\q2 ka̱ta̱ i ɓa̱ya̱ngu utsutsu,
\q1 i sokongu ka̱ci ka̱ ɗa̱ ali a kubana megeshe kenu
\q2 sai ayin a na wupa u ni u lazai.
\q1 
\v 21 La̱na̱i, Vuzavaguɗu wi ta̱ a̱ kuta̱wa̱ na ɗe gaɗi a̱ ubuta̱ u na wi o kuyongo
\q2 adama a na u takacika uma aduniyan adama a unushi u le.
\q1 Aduniyan i ta̱ a̱ kuta̱ka̱ n aza a na a̱ tsuwa̱in mpasa punu wa̱ ni,
\q2 wi ta̱ a̱ kuta̱ka̱ le e keteshe adama a na yaba dem we ene.
\c 27
\s1 Wishi wa aza a Isaraila
\p 
\v 1 A kanna ka nanlo,
\q1 Vuzavaguɗu n ka̱ci ka̱ ni wi ta̱ a kutakaci Liviyata n kotokobi ka̱ ni,
\q2 kotokobi ka̱ ni ku utsura koɓolo n alyu,
\q1 Liviyata koko kaꞋa ku ugaɗi,
\q2 Liviyata koko kaꞋa ku uka̱ta̱li,
\q1 wi ta̱ a kuna ka̱di ka na ko ci yongo a mala kpamu.
\p 
\v 2 A kanna ka nanlo,
\q1 Vuzavaguɗu wi ta̱ a kudana, <<Cananai vishipa adama a kashina ka nɗanga ki itacishi.
\q2 
\v 3 Mpa Vuzavaguɗu mi ta̱ a kinda kaꞋa
\q2 ka̱ta̱ kpamu n tsungusu kaꞋa mini ayin dem.
\q1 Mi inda kpamu kaꞋa kanna n kayin
\q2 adama a na ta lo vuza u kula̱nga̱sa̱ kaꞋa.
\q2 
\v 4 Mi a wupa n kashina ki itacishi ba.
\q1 Awana a ɗa baci n katsupa i ɗe koci.
\q2 Mi ta̱ a kudasa le n vishili,
\q2 ka̱ta̱ n songu le ra̱ka̱ n akina.
\q1 
\v 5 Ta baci nannai ba, yaꞋan a̱ ta̱wa̱ wa̱ va̱ ciya̱ mi isa le,
\q2 yaꞋan o tono mu m ma̱ta̱na̱,
\q1 e, o tono mu m ma̱ta̱na̱.>>
\b
\q1 
\v 6 A kubana na kelime Yakubu wi ta̱ a̱ kuciya̱ kumi,
\q2 aza Isaraila kpamu o kutopo ta̱ ka̱ta̱ a yaꞋan a̱pa̱lu
\q2 ka̱ta̱ a matsa a shatangu aduniyan.
\b
\q1 
\v 7 Vuzavaguɗu u lapa yi ta̱
\q2 tsu na u lapai aza a na i a tsurala n a̱yi?
\q1 A una yi ta̱
\q2 tsu na a unai aza na a unai ni?
\q1 
\v 8 Vuzavaguɗu u takacika ta̱ uma a̱ ni a̱ ubuta̱ u na a̱ suki le a kubana ubuta̱ wu ugbashi,
\q2 u pura̱ngi le tsu na wunla̱i u ci yaꞋan,
\q2 u ɗikai le n wupa tsu na wunla̱i u kasana u tsu pura̱ ili.
\q1 
\v 9 Ama Vuzavaguɗu u yaꞋan ta̱ nannai adama a na u cinukpaka aza a Isaraila unushi,
\q2 ka̱ta̱ nannai u zuwa u cinukpaka le n unushi u le ra̱ka̱:
\q1 Ana u yaꞋin atalyalyuka a̱ tali
\q2 o yotsoi katali ka̱ ka̱ɓisa̱ka̱ ka na ko kuɓoso miri-miri,
\q1 babu ka̱ma̱li ka aza a Ashatara ko ma̱va̱li ma aza a̱ ka̱yimbi
\q2 ma na ma kubuwa babu uɓoshi.
\q1 
\v 10 Likuci i na yi ukanji i bonoi tsa agali,
\q2 babu vuza na kpamu wi ida̱shi punu, wo okpoi an kakamba,
\q1 ta ɗe ndendem a ci yaꞋan kalina,
\q2 ta ɗe kpamu a tsu vaku,
\q2 n o gborotsoi ili i na yi punu dem babu i na i kubuwa.
\q1 
\v 11 A ayin a na baci acaka a̱ ni e ɗekpei, ɗa o koɗosoi,
\q2 a̱ma̱ci i ta̱ a̱ kuta̱wa̱ ciya̱ a zama nɗanga n kusonuko.
\q1 Adama a na uma a i n kuyeve ba,
\q2 Vuza na u yaꞋin le wa kupana asuvayali e le ba,
\q2 Vuza na u tuka̱i le a aduniyan wa̱ kusa̱Ꞌa̱ le ba.
\p 
\v 12 A kanna ka nanlo Vuzavaguɗu wi ta̱ e kupece ilya n kopo. Wi ta̱ o kuɓolongu le vuza te-te o kuyene ku Yufiretu a kasana ali a kubana a̱ ka̱sha̱n ka Masar.
\v 13 A kanna ka nanlo i ta̱ a̱ kulika̱ kavana n utsura. Aza a na i ɗe a̱ kuna̱mgba̱ a Asiriya n aza a na a banai ugbashi a Masar i ta̱ o kubono ka̱ta̱ a yaꞋanka Vuzavaguɗu tsugbashi a Urushelima a kusan ku ciɗa.
\c 28
\s1 Ili ya atakaci a kubana wa aza a Ifirayimu
\q1 
\v 1 Ili ya atakaci i ɗa i na yi lo a kuvana likuci ya̱ a̱ra̱ɗi i Samariya,
\q2 ubuta̱ u na wo okpoi oroliko o osoꞋi a aza israila,
\q1 i ɗa yi ta̱ ida̱shi gaɗi vi ɗika i ka̱ra̱Ꞌa̱ ka̱ tsuta̱, ama tsuloboi ci ni ci ta̱ o kuɗoɗo tsa̱ a̱pa̱lu.
\q2 Likuci i ɗaɗa a̱ra̱ɗi a uma a na a̱ yikpa̱i adama a̱ ma̱ra̱.
\q1 
\v 2 La̱na̱, Vuzavaguɗu wi ta̱ n kagbashi ka na ki n ikyamba koɓolo n utsura.
\q2 Wi ta̱ tsu mini ma atali n tsu wunla̱i u koli a̱ kutsuwa̱n a iɗika ka̱ta̱ ma aya,
\q1 wi ta̱ a̱ kutsuwa̱n maꞋa n utsura a iɗika.
\q1 
\v 3 Oroliko a̱ a̱ra̱ɗi o osoꞋi a Ifirayimu,
\q2 i ta̱ a kuyaꞋan ukpeti n ene.
\q1 
\v 4 A̱pa̱lu a na o tsu ɗoɗo va, a na i tsuloboi tsu tsugbayin ci ni,
\q2 uzuwi a̱ ida̱shi a̱ ka̱ra̱Ꞌa̱ ka̱ tsuta̱,
\q1 i ta̱ o kokpo tsu umaci u ga̱ba̱ u na u geꞋwei u maɗanga ma zaitu kafu ayin a vikyaꞋa a yawa.
\q2 Ɗa baci vuza we enei ali ɗa u taɓai n kukiye ku ni,
\q2 wi ta̱ o kusoɗongu.
\b
\q1 
\v 5 A kanna ka nanlo Vuzavaguɗu MalaꞋimili
\q2 wi ta̱ o kokpo tso oroli a tsugbayin,
\q1 ka̱ta̱ kpamu wo okpo ili i ma̱za̱nga̱ n a̱ra̱ɗi
\q2 a kubana u uma a na a buwai n wuma.
\q1 
\v 6 Wi ta̱ o kokpo ayinviki a̱ usuɓi
\q2 a kubana u vuza na u ci yaꞋan afada,
\q1 ka̱ta̱ kpamu wo okpo ka̱ɓa̱nki
\q2 wo ovonshi a na a tsu shamgba a̱ utsutsu.
\b
\q1 
\v 7 Ele nampa kpamu a̱ ga̱la̱i m ma̱ra̱
\q2 ɗa a jarai n washi,
\q1 anan ganu n eneki feu o soꞋi
\q2 ɗa aci e le a̱ ripula̱i adama a̱ ma̱ra̱,
\q1 a jarai m ma̱ra̱,
\q2 e ce ene mayin ba, a ayin a na i a kuyaꞋan kene ku tsa alatani,
\q2 ka̱ta̱ a̱ shiliku ili a ayin a na i e kuneke odoki.
\q1 
\v 8 Irikpa e le dem a̱ sumba̱ ta̱ n ashama,
\q2 babu ubuta̱ u gbani.
\b
\q1 
\v 9 <<Yayi tamkpamu u kuyaꞋanka kuyotsongu?
\q2 Yayi kpamu u kudana akaka a?
\q1 U muku n na a kasai ɗe mani,
\q2 ko aza a na a kasai mani gogoꞋo.
\q1 
\v 10 Ili i na ci a kupana,
\q2 utonu u gbani u ɗa koci,
\q2 i ɗa yi ta̱ kakariki-kakariki,
\q2 na kenu na ɗe kenu.>>
\b
\q1 
\v 11 Yi baci a kupanaka mu ba,
\q2 Vuzavaguɗu wi ta̱ a kuyaꞋan kadanshi n a̱ɗa̱ n kelentsu ka na atsuvu a̱ ɗa̱ a kiwanai kupana ba, n kelentsu ka na kpamu ki ka̱ ɗa̱ ba.
\q1 
\v 12 U danai le tsu nampa,
\q2 <<Nava ɗaɗa ubuta̱ u kuvuka, yaꞋan aza a na i n woꞋwi a uvuka na.>>
\q1 Nava ɗaɗa kpamu, ubuta̱ u kuvuka u ka̱bini.
\q2 Ama ali n gogo na a pana ba.
\q1 
\v 13 Adama a nannai kadanshi ka Vuzavaguɗu,
\q2 ki ta̱ o kokpo le tsu utonu,
\q2 kakariki-kakariki,
\q2 na kenu na ɗe kenu.
\q1 Nannai ɗa i kubana kelime ka̱ta̱ i bono i yikpa̱ n kucina̱,
\q2 yi ta̱ a kuꞋuka muna, ka̱ta̱ a̱ ka̱na̱ ɗa̱ a banka ugbashi.
\q1 
\v 14 Adama a nannai panai kadanshi ka Vuzavaguɗu, a̱ɗa̱ aza a ulami
\q2 a na a lyaꞋakai uma a nampa tsugono tsu Urushelima.
\q1 
\v 15 I lapa ta̱ ma̱ka̱nga̱ i danai, <<Ci yaꞋan ta̱ ɗe uzuwakpani n ukpa̱,
\q2 ci yaꞋan ta̱ uzuwakpani n ubuta̱ wu ukpisa̱.
\q1 Muna ma gbani-gbani ma na mi lo a̱ kuta̱wa̱ ma yawa baci,
\q2 ma kusaꞋwa tsu ba,
\q1 adama a na tsu bonoko ta̱ aꞋuwa ubuta̱ u kusheɗeku,
\q2 modoruko kpamu mo okpoi ubuta̱ u kuvuka u tsu.>>
\p 
\v 16 Nava ɗaɗa ili i na Vuzavaguɗu Uba̱nga̱ri u danai,
\q1 <<Indana, n shikpa̱ ta̱ ɗe katali a Sihiyona,
\q2 ka na ka̱ ciya̱i ɗe ukondi,
\q1 katali ka singai ke kenene ko mogon adama a kuvaraka kumaꞋa babu munla̱i,
\q2 <Vuza na baci u zuwakai ɗe katsura wa̱ kuyikpa̱ ba.>
\q1 
\v 17 Mi ta̱ o kubonoko afada a singai okpo kagisamkpatsu ka kumaꞋa,
\q2 usuɓi tamkpamu wo okpo tsu kagisamkpatsu ka,
\q1 minimatali mi ta̱ o kuɓoso ubuta̱ u kusheɗeku wa aꞋuwa u ɗa̱,
\q2 ka̱ta̱ mini ma aya ma lyaꞋa ubuta̱ u kuvuka u ɗa̱.
\q1 
\v 18 Uzuwakpani u na vi yaꞋin adama a na vu doro ukpa̱ wi ta̱ a kuyaꞋan utakpi,
\q2 uzuwakpani u na vi yaꞋin kpamu adama a na vu were ubuta̱ wu ukpisa̱ wi ta̱ feu a kuyaꞋan utakpi.
\q1 Makyan ma na baci vurala vu gbani-gbani vu walai,
\q2 vi ta̱ a kuɓasangu a iɗika.
\q1 
\v 19 Ayin tutu mini ma na ma tsu aya nanlo mi ta̱ a kulaza n avu,
\q2 usana lakam kanna n kayin,
\q1 sai ayin a na ma̱ pura̱i nu.>>
\b
\q1 Kuyeve ku ukuna wa akaka a nampa
\q2 i ta̱ e kuneke uma a̱ nu wovon.
\q1 
\v 20 IvaꞋantsu i nu i laꞋa ta̱ kenu an vuza wa̱ ba̱rukpa̱ ɗe,
\q2 ipalatsu i nu feu i laꞋa ta̱ kenu an ya pala ikyamba ra̱ka̱.
\q1 
\v 21 Adama a na Vuzavaguɗu wi ta̱ a̱ kuɗa̱nga̱ tsu na u yaꞋin a Kusan ku Perazimu,
\q2 ka̱ta̱ u ɗengusa̱ kpamu ka̱ci ka̱ ni tsu na u yaꞋin a̱ ka̱ra̱Ꞌa̱ ka̱ Gibiyon
\q1 adama a na u yaꞋan ulinga u savu,
\q2 u yaꞋan ulinga u na u kiwanai kuyaꞋan ba,
\q1 
\v 22 Gogo na ka̱sukpa̱ tsugoyi tsu nu,
\q2 ta baci nannai ba atakaci a̱ ɗa̱ i ta̱ a kulasuka kuyimkpa,
\q1 adama a na m pana ta̱ wila̱ adama a̱ kula̱nga̱su u na Ka̱shile Vuzavaguɗu vo osoji a gaɗi
\q2 u kuyaꞋanka uma a aduniyan dem.
\b
\q1 
\v 23 Zuwai atsuvu ka̱ta̱ i pana ka̱la̱ka̱tsu ka̱ va̱,
\q2 shamgbai shiriri ka̱ta̱ i pana ili i na n kudana.
\q1 
\v 24 Kacimbi ka tsu nima ta̱ kashina ka̱ ni ka̱ta̱ u kpa̱ɗa̱ kuka̱sukpa̱ biꞋi adama a na u ca̱Ꞌa̱?
\q2 Ko ta u tsu ka̱na̱ kunima iɗika nannai koci?
\q1 
\v 25 Ɗa baci u kotsoi kunima kashina ka̱ ni ra̱ka̱,
\q2 u tsu la̱nsa̱ icuꞋu, ka̱ta̱ u ca̱Ꞌa̱ ilya ba?
\q1 Ka̱ta̱ u ca̱Ꞌa̱ punu ya̱nji m masala ma̱ ni ba?
\q2 Itabi feu m masala ma̱ ni
\q2 ka̱ta̱ u kara ugboku u ni ba?
\q1 
\v 26 Kacimbi ka ke yeve ta̱ ili i na u kuyaꞋan,
\q2 adama a na Vuzavaguɗu u tsu neke yi ta̱ kuyeve.
\b
\q1 
\v 27 A tsu lapa igeɓetsu n kalangu ka kulapu ba,
\q2 ama a tsu lapa ta̱ i ɗa n kalangu ke kenu,
\q1 keke vo odoku vu kulapu va kulapa igeɓetsu ba,
\q2 ama i ta̱ a kufaba i ɗa m macaka kenkeꞋen.
\q1 
\v 28 Mayun ɗa a iya ili i na yi n icuꞋu adama o boroji,
\q2 ama a kulyaꞋa kelime n kulapa i ɗa n kalangu ali a kubana ba.
\q1 Wi ta̱ a kufuɗa kutuka̱ n keke vo odoku vi ni lo,
\q2 ama odoku a̱ ni a kugasa n keke va punu ba.
\q1 
\v 29 Ukuna u nampa ra̱ka̱ wu uta̱ ta̱ a̱ ubuta̱ u Vuzavaguɗu MalaꞋimili,
\q2 vuza na wi n odoki a singai, koɓolo n kuyeve ku utsura.
\c 29
\s1 Ili ya atakaci a kubana a̱ likuci i Dawuda
\q1 
\v 1 Ili ya atakaci i ɗa a kubana wa̱ nu, Ariyelu, Ariyelu,
\q2 likuci i na Dawuda u da̱sa̱ngi.
\q1 ka̱ya̱ dem
\q2 ɗa va kulyaꞋa kelime n kuyaꞋan ka̱ɗiva̱ ka̱ nu.
\q1 
\v 2 N nannai dem mi ta̱ a̱ kutuka̱ Ariyelu
\q2 n atakaci, wi ta̱ a kuyaꞋan kpalu ka̱ta̱ u shika̱,
\q2 wi ta̱ o kokpo an katalikalyuka wa̱ va̱ upali nu mpasa.
\q1 
\v 3 Mi ta̱ a kubanka likuci ya n kuvon,
\q2 n kambuku i ɗa ka̱ta̱ n shilika̱ n i ɗa,
\q1 mi ta̱ a kumaꞋa idasakpatsu i mashilya
\q2 adama a na m banka n kuvon.
\q1 
\v 4 I ta̱ o kubonoko wu ka̱ca̱pa̱ punu a iɗika ka̱ta̱ vi yaꞋan kadanshi,
\q2 kadanshi ka̱ nu ki ta̱ a̱ kuzuɗa̱ punu a̱ kubuta̱.
\q1 Ka̱la̱ka̱tsu ka̱ nu ki ta̱ o kokpo tsu ka̱la̱ka̱tsu ka kafataluwa punu a iɗika,
\q2 ka̱la̱ka̱tsu ka̱ nu ki ta̱ o kuyongo e yemeni punu a̱ kubuta̱.
\q1 
\v 5 Ama irala i nu n a̱bunda̱i yi ta̱ o kubono an kubuta̱ ku lenwu,
\q2 aza a na i a kutamba wu i ta̱ a kulaza an kopo ka na ko tsu tono wunla̱i.
\q1 Ki ta̱ a kuyaꞋan nannai gogoꞋo, babu uzuki
\q2 
\v 6 Vuzavaguɗu MalaꞋimili wi ta̱ a̱ kuta̱wa̱
\q2 n akpanga n kugba̱ɗa̱ ki iɗika n kacaꞋa ka gbangam,
\q1 n wunla̱i wu utsura m melentsu ma akina ma na mi a̱ kukula̱.
\q1 
\v 7 Ka̱ta̱ ka̱bunda̱i ka aduniyan ra̱ka̱ ka na ka̱ shilika̱i n Ariyelu,
\q2 koɓolo n aza a na a̱ shilika̱i n a̱yi ali n ubuta̱ wu utsura u ni dem ɗa a kambuki ni,
\q1 wi ta̱ o kokpo adanshi alatani a ɗa,
\q2 tsu kene ku na ku tsu ta̱wa̱ vuma n kayin.
\q1 
\v 8 Tsu na vuza vu kambulu u ci yaꞋan alatani a na wi a kulyaꞋa ilikulyaꞋa,
\q2 ka̱ta̱ u ɗa̱nga̱ baci u cina kambulu ka ka buwa yi ta̱,
\q1 tsu vuza na wi a kupana kakuli u ci yaꞋan alatani a na wi o kusoꞋo mini,
\q2 ama ka̱ta̱ u jimgba u cina kakuli ka̱ ni a kulyaꞋa kelime n kutakacika yi.
\q1 Nannai ɗa ka kuyaꞋan n iɗika kakau n a̱bunda̱i
\q2 i na u shilika̱i n Kusan ku Sihiyona.
\b
\q1 
\v 9 YaꞋan tsulau ka̱ta̱ kpamu vi yaꞋan mereve,
\q2 lyaꞋa kelime n kubonoko ka̱ci ka̱ nu ka̱yimba̱.
\q1 Maka ka̱ci ka̱ nu n ili i yoku babu vu soꞋo ma̱ra̱,
\q2 okpo ga̱lu babu vu soꞋo i na i kumaka wu.
\q1 
\v 10 Vuzavaguɗu u tuka̱ ɗa̱ ta̱ n alavu a na a̱ kuwa̱i.
\q2 U paɗarai a̱shi a̱ ɗa̱, a̱ɗa̱ eneki,
\q2 u palai aci a̱ ɗa̱, a̱ɗa̱ oboci.
\q1 
\v 11 Wa̱ nu kene ku nampa dem ili i ɗa ba, ama tsu kadanshi ka na ki u ɓa̱ya̱ngi a katagarda. Vu neke baci katagarda ka u vuza na u kufuɗa we kece, ɗa a danai ni, <<Adama a̱ Ka̱shile kece,>> wi ta̱ a̱ kushuku ka̱ta̱ u dana, <<Ma kufuɗa ba, ki ta̱ uɓa̱ya̱ngi.>>
\v 12 Ko vu neke baci katagarda ka u vuza na u yevei mekecu ba, ɗa vu danai, <<Adama a̱ Ka̱shile kece,>> wi ta̱ a̱ kushuku ka̱ta̱ u dana, <<N yeve mekecu ba.>>
\p 
\v 13 Ɗa Vuzavaguɗu u danai,
\q1 <<Uma a nampa a tsu dana ta̱ ele uma a̱ va̱ a ɗa i ama n una̱,
\q2 ka̱ta̱ kpamu e neke mu tsugbayin n una̱ koci,
\q2 ama punu a̱ a̱ɗu e le, i ta̱ daꞋin nu mpa.
\q1 Kucikpa ku na a ci yaꞋan a kubana wa̱ va̱,
\q2 kuta̱ ta̱ a̱ ubuta̱ u kuyotsongusu ku uma.
\q1 
\v 14 Adama a nannai kpamu, mi ta̱ a kuyaꞋan ili i mereve n uma a nampa,
\q2 ili i mereve kakau,
\q1 ka̱ta̱ kuyeve ka aza a ugboji e le ku na̱mgba̱,
\q2 ugboji wa aza a ugboji e le u kotso.>>
\q1 
\v 15 Ili ya atakaci i ɗa a kubana wa aza a na o tsu sokongu
\q2 kuyeve ku le daꞋin adama a Vuzavaguɗu,
\q1 ele na a ci yaꞋan ulinga u le a̱ ka̱yimbi ka̱ta̱ e sheshe a dana,
\q2 <<Yayi we enei tsu? Yayi u kuyeve i na ci yaꞋin?>>
\q1 
\v 16 I sabaꞋi ili ɗa i bonokoi i ɗa mavadai,
\q2 adanshi e sheshe ta̱ kamaꞋi ko mogbodo ko bono ciꞋin tsu kumaꞋa,
\q1 ili i na a yaꞋin va yi ta̱ a kudana yayi u yaꞋin mu,
\q2 <<A̱yi ɗa u yaꞋin mu ba>>?
\q1 Mogbodo mi ta̱ a kudana kamaꞋi ka,
\q2 <<U yeve ili ba>>?
\b
\q1 
\v 17 M megeshe kenu, Lebano wi ta̱ o kubono iɗika i tsuta̱,
\q2 ka̱ta̱ ubuta̱ u tsuta̱ u yotso an kakamba ba?
\q1 
\v 18 A kanna ka nanlo kagulani ki ta̱ a kupana vuza yoku e kukece katagarda,
\q2 ka̱ta̱ ka̱yimba̱ kene
\q2 wo kudoku wo yongo a̱ ubuta̱ u ka̱yimbi ba.
\q1 
\v 19 Aza a na o goyoi ka̱ci ke le i ta̱ a kuyaꞋan ma̱za̱nga̱ a̱ ubuta̱ u Vuzavaguɗu,
\q2 aza a unambi a yaꞋan ma̱za̱nga̱ adama a vuza Ciɗa vi Isaraila.
\q1 
\v 20 Aza a ugbamukaci i ta̱ o kukotso,
\q2 aza a na a ci yaꞋan ulami i ta̱ o kukotso,
\q2 ka̱ta̱ aza a na a kiwanai n kuyaꞋan ku ukuna u wuya a yaꞋan wuni,
\q1 
\v 21 aza a na n kadanshi ku una̱ koci a tsu zuwa vuma u yaꞋan unushi
\q2 i ta̱ a kaza vuza na wi n kadanshi ka mayun a̱ ubuta̱ wa afada,
\q2 koɓolo n aza a na a ci yaꞋan aꞋuwa adama a na a̱ la̱nga̱sa̱ aza a usuɓi.
\p 
\v 22 Adama a nannai ili i na Vuzavaguɗu vu na u shiba̱i Ibirahi u danai kpaꞋa ku Yakubu i ɗaɗa na,
\q2 <<Yakubu wo kudoku wa yaꞋan wono kpamu ba,
\q2 a̱shi a̱ ni o kudoku a runza ba.
\q1 
\v 23 Makyan ma na baci we enei muku n ni,
\q2 adama a ulinga we ekiye u va̱,
\q1 i ta̱ a kuzuwa kula ku va̱ ku yongo ciɗa,
\q2 ka̱ta̱ o bonoko vuza Ciɗa vu kpaꞋa ku Yakubu wo okpo ciɗa kpamu.
\q2 I ta̱ a kushamgba n uneki u tsugbayin a kubana u Ka̱shile ka Yakubu.
\q1 
\v 24 Ka̱ta̱ uma a na a̱ puwa̱nka̱i punu a̱ a̱ɗu e le o bono a̱ ciya̱ kuyeve,
\q2 aza a̱ ka̱sa̱la̱ kpamu i ta̱ a kisa odoki.>>
\c 30
\s1 Ili ya atakaci a kubana u likuci yu ugbamukaci.
\q1 
\v 1 Vuzavaguɗu u danai,
\q2 <<Ili ya atakaci i ɗa a̱ɗa̱ muku mu ugbamukaci,
\q1 a̱ɗa̱ na i tsu tono kusheshe ku ɗa̱, ku na ki ku va̱ ba,
\q2 a̱ɗa̱ na i ɓolongi una̱ babu kusheshe ku va̱,
\q2 nannai va ɗa yi o kudoku unushi katsura,
\q1 
\v 2 ɗa kpamu i lazai a kubana a Masar,
\q2 babu na ye ecei mu,
\q1 adama a na i la̱nsa̱ uɓa̱nki a̱ ubuta̱ u FiriꞋauna,
\q2 ka̱ta̱ i la̱nsa̱ ubuta̱ u kusheɗeku a̱ mululu m Masar.
\q1 
\v 3 Ama uɓa̱nki u FiriꞋauna wi ta̱ o kokpo ɗa̱ ili i wono,
\q2 kulu ku Masar ki ta̱ a̱ kutuka̱ ɗa̱ n wono.
\q1 
\v 4 Utsura u mogono wa u yawa ta̱ likuci i Zowa,
\q2 daꞋangi n tsuɗaka tsu Hane.
\q1 
\v 5 Yaba dem wi ta̱ o kokpo n wono,
\q2 adama a uma a singai a na i n ukuna u singai ba,
\q1 aza a na a̱ tsu ɓa̱nka̱ ba, ko a yaꞋan kasingai ko yoku
\q2 ama sai wono koci n ukuna u pete.>>
\q1 
\v 6 Akaka adama a nnama n kakamba n Negebu.
\q1 A̱ ubuta̱ wi iɗika i gbani-gbani n atakaci,
\q2 a̱ ubuta̱ u na ikawu i tsu ta̱wa̱,
\q2 n ubuta̱ wa agbaturu koɓolo n oko a gbani-gbani,
\q1 kololu ka uma ka ka ɗikai uciyi u le a njaki,
\q2 koɓolo n gaɗi va arakuma,
\q1 a kubana u uma a nanlo a a na i kuyaꞋanka u ɗa ulinga ba.
\q2 
\v 7 Uɓa̱nki wi ɗika u Masar u gbani u ɗa, babu ili.
\q1 Adama a nannai ɗa n ɗekei ni
\q2 <<Rahapu ka̱di ka na ka tsu saꞋwa vuza ba.>>
\b
\q1 
\v 8 Gogo na, bana vu ɗana kaꞋa a magbaganla ele e kene,
\q2 ka̱ta̱ vu doku vu ɗanaka le kaꞋa a katakarda,
\q1 vu dana a kanna ka na ka̱ kuta̱wa̱
\q2 ki ta̱ o kokpo ngan n ayin dem.
\q1 
\v 9 Adama a na ele uma a ugbamukaci a ɗa n aza a uwa,
\q2 muku n na n cigai kupana kadanshi ka Vuzavaguɗu ba.
\q1 
\v 10 Ɗa a danai oboci a,
\q2 <<Ka̱ta̱ i doku i yaꞋan kene ba,>>
\q1 u danai kpamu eneki,
\q2 <<Ka̱ta̱ i doku i yaꞋanka tsu kene ku mayu ba.
\q1 Danai tsu ukuna u singai,
\q2 ko wa aꞋuwa u ɗa baci,
\q1 
\v 11 ka̱sukpa̱i uye u nampa wa,
\q2 ka̱ta̱ i doku i tono u ɗa ba,
\q1 ka̱sukpa̱i kudana tsu
\q2 ukuna u Vuza ciɗa vi Isaraila.>>
\p 
\v 12 A dama a nannai, ili na Vuza ciɗa vi Isaraila u danai i ɗaɗa na.
\q1 <<Uteku tsu na i iwain akaka a nampa,
\q2 adama na i goyo ta̱ akaka a nampa,
\q1 ɗa i bonoi i zuwai katsura a̱ ubuta̱ wi ili i gbani-gbani,
\q2 koɓolo n ukuna u modoruko,
\q1 
\v 13 adama a nannai unushi u nampa wi ta̱ o kokpo
\q2 tsu uɓaci u mashilya mu ugaɗi, ma na ma̱ ka̱ga̱lukpa̱i ra̱ka̱,
\q2 an ma̱ yikpa̱ babu megeshe.
\q1 
\v 14 Wi ta̱ o kuɓoso miri-miri tsu mogbodo,
\q2 ma na mo ɓosoi ka̱mbu-ka̱mbu,
\q1 ma na a̱ ka̱tsuma̱ ka̱ a̱mbu a̱ ni vi a̱ kuciya̱ punu ka̱mbu
\q2 ka na va kukenuku akina ba,
\q2 ko ka na va kukenuku mini o kogbodo ba.>>
\p 
\v 15 Na ɗa ili na Vuzavaguɗu Ka̱shile, Vuza ciɗa vi Isaraila u danai.
\q1 <<N kushika̱ ku unushi n kuvuka wa̱ va̱ ɗaɗa i kuciya̱ wishi,
\q2 kuyongo n ka̱bini n uneki wa a̱ɗu u ɗa̱, ɗaɗa katsura ka̱ ɗa̱,
\q2 ama ɗa i iwain.
\q1 
\v 16 Ɗa vu danai, <A̱Ꞌa̱, ci ta̱ a kusuma gaɗi vo odoku.>
\q2 Adama a nannai yi ta̱ a kusuma.
\q1 Ɗa a̱ɗa̱ i danai, <A̱ tsu ci ta̱ a kusuma gaɗi vo odoku a ilaɗi,>
\q2 Adama a nannai uma a̱ ɗa̱ a na i a kukiyangu tsu i ta̱ a kulaꞋa n ilaɗi.
\q1 
\v 17 Uma a̱ ɗa̱ ka̱kpa̱n i ta̱ a kusuma
\q2 adama a vuma vi te,
\q1 ye ene baci uma a tawun
\q2 yi ta̱ a kusuma ra̱ka̱ vu ɗa̱,
\q1 ali i ta̱wa̱ yo okpo
\q2 tsu urotu u kakashi a gaɗi vu kusan,
\q2 uteku tsu urotu a kusan.>>
\b
\q1 
\v 18 Adama a nannai Vuzavaguɗu u vana ta̱, adama a na u yotsongu ucigi u ni wa̱ ɗa̱,
\q2 ɗa kpamu u ɗa̱nga̱i adama na u yotsongu ɗa̱ asuvayali a̱ ni.
\q1 Adama a na Vuzavaguɗu a̱yi Ka̱shile ka mayun kaꞋa,
\q2 una̱singai u ɗa dem wa aza a na a vanai ni.
\p 
\v 19 A̱ɗa̱ uma a na i ida̱shi a Sihiyona, n Urushelima, yi a ku doku kushika̱ kpamu ba. Mayun ɗa a̱yi wi ta̱ a kuciga ɗa̱, a ayin a na baci i lapai una̱ adama a na a̱ ɓa̱nka̱ ɗa̱. Makyan ma na baci u panai dem wi ta̱ a kushuku ɗa̱.
\v 20 Ko an wo okpoi Vuzavaguɗu u neke ɗa̱ ta̱ ilikulyaꞋa ya atakaci m mini ma atakaci, ko n nannai a̱yi malum ma̱ ɗa̱ wo kudoku wo sokongu a̱shi a̱ ni kpamu ba, ama n a̱shi a̱ ɗa̱ yi ta̱ e kene le.
\v 21 Atsuvu a̱ nu i ta̱ a kupana kadanshi a̱ kucina̱ ku nu, a kudana <<Na va ɗaɗa uye, tono u ɗa,>> ko vu kpatala baci a usingai ko a ugula̱.
\v 22 Ka̱ta̱ a̱ɗa̱ i la̱nga̱sa̱ a̱ma̱li a̱ ɗa̱ a na i yimai ɗa i paɗarai n azurufa koɓolo n ululu a azanariya a na i shikpa̱i. Ka̱ta̱ i varuku le uteku ci ili yu unata. Ka̱ta̱ i dana le, <<Walai, ka̱sukpa̱i tsu.>>
\v 23 Wi ta̱ o kuyoꞋoko ɗa̱ mini adama a̱ icuꞋu i na i ca̱Ꞌi a iɗika, ka̱ta̱ ilikulyaꞋa i na i kumatsa punu a iɗika ya i gaꞋan ka̱ta̱ kpamu i yaꞋan ba̱ri. A kanna ka nanlo kuzuwa ku ɗa̱ ki ta̱ a kulina a̱ ubuta̱ wi ijanu wa̱ a̱bunda̱i.
\v 24 Obomburon ni njaki n na mi a kuyaꞋan kunima i ta̱ a kutakuma ijanu i singai, i na a lapulai mayin.
\v 25 A kanna ka nanlo, ka na a kiɗai irala i ɗa̱, ɗa kpamu nshilya n kindi n yikpa̱i. Nyeneke m mini mi ta̱ e kuyene a gaɗi va aginda nu nsasan dem.
\v 26 Kutashi ku wotoi kpamu ki ta̱ a kakana tsu kanna, ka̱ta̱ wakani u kanna u laꞋa tsu na wi ishi ali kucindere, uteku tsu kutashi ku ayin e cindere derere, a ayin a na Vuzavaguɗu wu urasai ukpanwojuno u uma a̱ ni ɗa kpamu u ta̱na̱ta̱ngi untsu a na u yaꞋankai le.
\q1 
\v 27 La̱na̱, kula ku Vuzavaguɗu a̱ kuta̱wa̱ na ɗe daꞋangi,
\q2 n ka̱ɗu ukuli koɓolo n ka̱nga̱ ka̱ lima̱ ka̱u,
\q1 kadanshi ka̱ ni tukpa n wupa,
\q2 kelentsu ka̱ ni kpamu m munuka tsa akina.
\q1 
\v 28 Ayinviki a̱ ni i ta̱ tsu kuyene ku na ku lyaꞋi
\q2 ali ku yawai e kuɗeku.
\q1 A̱ kusa̱sa̱ aduniyan e meshere ma munuka,
\q2 ka̱ta̱ u uka mgbagulu n uma
\q2 iryangama i na i kuzuwa le a̱ puwa̱nka̱.
\q1 
\v 29 Yi ta̱ a kuyaꞋan vishipa
\q2 tsu kayin ka na a ci yaꞋan ka̱ɗiva̱ ka kanna ka ciɗa,
\q1 ta a̱ɗu a̱ ɗa̱ a kuyaꞋan ma̱zanga̱ nannai,
\q2 a ayin a na baci uma a̱ lika̱i igbala
\q1 a̱ ubuta̱ u kusan ku Vuzavaguɗu,
\q2 a kakpanlai ka aza a Isaraila.
\q1 
\v 30 Vuzavaguɗu wi ta̱ a kuzuwa uma a pana ka̱la̱ka̱tsu ka tsugbayin ka̱ ni,
\q2 ka̱ta̱ u ka̱sukpa̱ le e ene kukiye ku utsura ku ni a̱ kucipa̱, n wupa nu nlentsu ma akina,
\q2 n eleshu a̱ mini, n akpanga koɓolo m mini ma atali.
\q1 
\v 31 Ka̱la̱ka̱tsu ka Vuzavaguɗu ki ta̱ a kukiruma aza a Asiriya,
\q2 wi ta̱ a kulapa le n kalangu ka̱ ni.
\q1 
\v 32 Ulapi u na baci de Vuzavaguɗu u yaꞋankai le dem
\q2 m mashawuri ma mafabuka ma̱ ni,
\q1 wi ta̱ o kokpo an tsuwaꞋi ci ndele n umolu,
\q2 n kukiye ku utsura ku ni ku ɗa u kushila̱ka̱ n ele a̱ ubuta̱ u kuvon.
\q1 
\v 33 M megeshe ma ɗe o foɓuso ta̱ ubuta̱,
\q2 wa akina a̱ a̱bunda̱i a na o kusongu mogono ma Asiriya.
\q1 Kpenle ka akina ku ni a yaꞋan ta̱ ku ɗa n uga̱vi koɓolo n wanshi,
\q2 n akina punu tukpa nu nɗanga,
\q1 Vuzavaguɗu wi ta̱
\q2 a̱ kuvula̱ akina a̱ ka̱nga̱ ko tsukono ku utsura,
\q2 adama a na u songu.
\c 31
\s1 Ili ya atakaci i ɗa wa aza na a zuwakai aza a Masar katsura
\q1 
\v 1 Ili ya atakaci i ɗa a kubana wa aza na a banai Masar kula̱nsa̱ uɓa̱nki,
\q2 ɗa kpamu a zuwakai odoku utsura,
\q1 ɗa a̱ ushuki n ka̱bunda̱i ke ekeke e le
\q2 koɓolo n utsura wa akumbi o odoku e le,
\q1 ama ɗa a iwain kula̱nsa̱ uɓa̱nki u Vuza Ciɗa va aza a Isaraila
\q2 ko kpamu a̱ la̱nsa̱ uɓa̱nki a̱ ubuta̱ u Vuzavaguɗu.
\q1 
\v 2 Ko n nannai a̱yi wi ta̱ n ugboji, wi kpamu a kufuɗa kutuka̱ n kawuya,
\q2 a̱yi u tsu yaꞋansaka kadanshi ka̱ ni ba.
\q1 Ama u tsu ɗa̱nga̱ ta̱ adama na u shilika̱ n iꞋuwa ya aza asuvawuya,
\q2 koɓolo n aza na a̱ tsu ɓa̱nka̱ aza na a tsu yaꞋan ka gbani-gbani.
\q1 
\v 3 Aza a Masar uma a ɗa Ka̱shile kaꞋa i ba.
\q2 Odoku e le kpamu ikyamba i ɗa nu mpasa, alijani a ɗa ba.
\q1 Ayin a na baci Vuzavaguɗu u ba̱rukpa̱i kukiye ku ni adama a na u takacika le,
\q2 ka̱ɓa̱nki ka ki ta̱ a̱ kuta̱ɗa̱tsa̱ ka̱ta̱ u yikpa̱,
\q1 a̱yi kpamu vuza na a̱ ɓa̱nka̱i va wi ta̱ a̱ kuyikpa̱,
\q2 ka̱ta̱ dem vu le a̱ niꞋwa̱n koɓolo.
\p 
\v 4 Ili i na Vuzavaguɗu u danai mu i ɗa na,
\q1 <<Uteku tsu na kawu u ci yaꞋan yura̱
\q2 wana ɗai u ka̱na̱ malala,
\q1 ko ka̱bunda̱i ka nguɓi
\q2 ko o ɓolongu baci adama a̱ ni,
\q1 wa kupana wovon adama a kacaꞋa ke le ba,
\q2 ko ka̱ɗu ka̱ ni ka̱ muɗa̱ adama a kacaꞋa ke le,
\q1 nannai ɗa Vuzavaguɗu MalaꞋimili u kucipa̱
\q2 ka̱ta̱ u shilika̱ a kusan ku Sihiyona n kaginda ka̱ ni.
\q1 
\v 5 Tsu na nnu n tsu imkpa gaɗi,
\q2 nannai ɗa Vuzavaguɗu MalaꞋimili u kisa Urishelima,
\q1 wi ta̱ a̱ kula̱na̱ i ɗa ka̱ta̱ wi isa i ɗa̱,
\q2 wi ta̱ a kukpada kawuya ka na ka̱ kuta̱wa̱ punu.>>
\p 
\v 6 Aza a Isaraila, bonoi, adama a na i ka̱sukpa̱ ta̱ uye u Vuzavaguɗu ra̱ka̱-ra̱ka̱.
\v 7 Adama a na a kanna ka nanlo ka yaba dem, wi ta̱ a kuvaruku a̱ma̱li a azurufa n azanariya, a na ekiye a̱ unushi a̱ ɗa̱ a yaꞋin.
\q1 
\v 8 <<Ka̱ta̱ aza Asiriya a̱ kuwa̱ n ukpa̱ u kotokobi,
\q2 ka na ekiye a vuma a yaꞋin ba, ka ɗa ka kuna le.
\q1 Ka̱ta̱ a suma adama ukpa̱ u kotokobi,
\q2 ka̱ta̱ a zuwa a̱ɗa̱nga̱ni e le a yaꞋan ulinga u tsugbashi.
\q1 
\v 9 Ubuta̱ wu utsura u le wi ta̱ a̱ kuyikpa̱ adama a aza a gbani-gbani,
\q2 aza e kelime o kuvon a̱ ni i ta̱ a kusuma a ayin a na baci e enei urotu u kakashi u kuvon u ɗa̱,>>
\q1 Vuzavaguɗu u danai nannai,
\q2 a̱yi na akina a̱ ni ta ɗe i a Sihiyona,
\q2 ɗa kenle ka̱ ni ki a Urushelima.
\c 32
\s1 Tsugono tsu usuɓi
\q1 
\v 1 La̱na̱, mogono mi ta̱ a kulyaꞋa tsugono tsu usuɓi,
\q2 ka̱ta̱ ngono n lyaꞋa tsugono n kasingai.
\q1 
\v 2 Yaba dem wi ta̱ o kokpo tsu ubuta̱ u kusheɗeku adama a̱ wunla̱i wu utsura,
\q2 n ubuta̱ u kusheɗeku adama a̱ mini ma atali ma munuka,
\q1 uteku ci nyeneke m mini n na n ɗekpei a kakamba,
\q2 an kulu ku kakpanlai ka gbayin a iɗika i ɗekpu.
\q1 
\v 3 Ka̱ta̱ a̱shi a aza a na i e kene a̱ kpa̱ɗa̱ kuyumba̱tsa̱sa̱ka̱,
\q2 ka̱ta̱ kpamu atsuvu a za na i a kupana, a pana.
\q1 
\v 4 Vuza na wi n uremi u ka̱ɗu ba, wi ta̱ a̱ kuciya̱ kuyeve ka̱ta̱ u fuɗa,
\q2 ka̱ta̱ kelentsu ka vuza vu cikeku ka fuɗa ka dansa mayin.
\q1 
\v 5 A buwa e kuɗeke kalau vuza vu ma̱riki ba,
\q2 ko e ɗeke vuza vu kalyaꞋa vuma vu gbayin.
\q1 
\v 6 Adama a na kalau ka ci yaꞋan ta̱ kadanshi ka tsulau,
\q2 ka̱ɗu ka̱ ni kpamu ki ta̱ ushani tukpa n kawuya,
\q1 u ci yongo ta̱ a kuyaꞋansa ili i na yi i Ka̱shile ba,
\q2 ka̱ta̱ u ka̱na̱ kuripula̱sa̱ uma adama a Vuzavaguɗu,
\q1 aza a kambulu u ka̱sukpa̱ le lekeɗi,
\q2 ka̱ta̱ aza a kakuli u ka̱sukpa̱ le n kakuli ke le.
\q1 
\v 7 Ama vuza vu kalyaꞋa, uteku u na u ci yaꞋan ili i ni wi ta̱ tukpa n kawuya,
\q2 u ci yaꞋan ta̱ kusheshe ku wuya
\q1 adama a na u doro aza a unambi n kadanshi ka aꞋuwa,
\q2 ko ufolu u le u singai u ɗa baci.
\q1 
\v 8 Ama vuma vu ma̱riki, u ci yaꞋan ta̱ kusheshe ku singai,
\q2 n kusheshe ku singai ku ɗa kpamu u tsu shamgba.
\s1 A̱ma̱ci a Urushelima
\q1 
\v 9 Ɗenga̱i, a̱ɗa̱ a̱ma̱ci a na yi ida̱shi i ka̱ci ka̱ ɗa̱,
\q2 panai ka̱la̱ka̱tsu ka̱ va̱,
\q1 a̱ɗa̱ nkere n na yi ida̱shi i ba̱ri,
\q2 ka̱ta̱ i zuwaka mu atsuvu i pana kadanshi ka̱ va̱.
\q1 
\v 10 An ka̱ya̱ ka lazai,
\q2 a̱ɗa̱ a̱ma̱ci a na yi ida̱shi i ba̱ri yi ta̱ e kujeꞋeke ikyamba,
\q1 kutaɓa umaci wi itacishi u kusuɓa̱ ba,
\q2 ka̱ta̱ kpamu i namba nɗanga n kutaɓa.
\q1 
\v 11 JeꞋekei ikyamba, a̱ɗa̱ a̱ma̱ci a na yi ida̱shi i ka̱ci ka̱ ɗa̱,
\q2 jeꞋekei avangatsu, a̱ɗa̱ a̱ma̱ci a na yi ida̱shi i ba̱ri.
\q1 Foɗosoi aminya a̱ ɗa̱,
\q2 i shiya akashi a̱ a̱kyuꞋun a̱ ɗa̱.
\q1 
\v 12 Na̱mgba̱i a̱tsuma̱ adama a na a̱ la̱nga̱sa̱ ta̱ ashina a̱ ɗa̱ koɓolo ashina a itacishi a̱ ɗa̱,
\q1 
\v 13 adama a na iɗika i uma a̱ va̱ i matsa ta̱ awana n kerepu,
\q1 na̱mgba̱i a̱tsuma̱ adama a na a̱ la̱nga̱sa̱ ta̱ iꞋuwa i ma̱za̱nga̱ i ɗa̱.
\q1 
\v 14 Adama a na i ta̱ a̱ kuka̱sukpa̱ kefeku ko mogono ka,
\q2 likuci i na yi tukpa n uma yo okpo ta̱ agali,
\q1 kaginda koɓolo n ubuta̱ u kindi wi ta̱ o kokpo ubuta̱ u ka̱rikpa̱ni ko wannai,
\q2 ka̱ta̱ wo okpo ubuta̱ u ma̱za̱nga̱ wu njaki n kakamba n ilikuzuwa adama a kalina ka na a kuyaꞋan punu,
\q1 
\v 15 ali sai ayin a na a̱ suꞋuki tsu ayinviki na ɗe gaɗi,
\q2 ka̱ta̱ kakamba kokpo iɗika i tsuta̱,
\q2 ka̱ta̱ iɗika i tsuta̱ ya i matsa umaci n a̱bunda̱i.
\q1 
\v 16 A ayin a nanlo a ɗa a kuyaꞋan ka mayun ɗe a kakamba ka,
\q2 ka̱ta̱ a yaꞋan feu ku usuɓi a iɗika i tsuta̱.
\q1 
\v 17 UgaꞋin u kuyaꞋan ki ili yu usuɓi wi ta̱ o kokpo ma̱ta̱na̱,
\q2 ka̱ta̱ kpamu usuɓi u tuka̱ n ida̱shi i ma̱ta̱na̱ i babu uteku n windi mayin.
\q1 
\v 18 Uma a̱ va̱ i ta̱ o kuyongo a̱ ubuta̱ wi ida̱shi i ma̱ta̱na̱,
\q2 asuvu a iꞋuwa i na yi babu kadama,
\q2 n ubuta̱ u na wi n ka̱bini n windanai mayin.
\q1 
\v 19 Ko mini ma atali ma varukusu baci nɗanga n kakamba,
\q2 ɗa likuci i ɓosoi ra̱ka̱-ra̱ka̱,
\q1 
\v 20 una̱singai u ɗa a kubana wa̱ ɗa̱,
\q2 a̱ɗa̱ na yi a kuyaꞋan vica̱Ꞌa̱ vi icuꞋu i ɗa̱ ɗevu n kuyene,
\q2 ɗa kpamu i ka̱sukpa̱i anaka ni njaki n ɗa̱ a kulina ba̱ri.
\c 33
\s1 Kavasa ku uɓa̱nki
\q1 
\v 1 Ili ya atakaci i ɗa a kubana wa̱ nu, avu na vu tsu una uma,
\q2 avu na ka̱ta̱ a unai ba.
\q1 Ili ya atakaci a kubana wa̱ nu, avu vuza modoruko,
\q2 avu na ka̱ta̱ a saꞋwai kudoro ba.
\q1 Ayin a na baci vu ka̱sukpa̱i kula̱nga̱sa̱ uma,
\q2 i ta̱ a̱ kula̱nga̱sa̱ wu,
\q1 vu ka̱sukpa̱ baci kpamu kudoro uma,
\q2 ka̱ta̱ feu o doro wu.
\q1 
\v 2 Vuzavaguɗu, pana asuvayali a̱ tsu,
\q2 ci neke ta̱ a̱ɗu a̱ tsu wa̱ nu.
\q1 Okpo katsura ka̱ tsu ayin dem,
\q2 ka̱ta̱ visa tsu ayin a na baci atakaci a̱ ta̱wa̱i.
\q1 
\v 3 N usari u ka̱la̱ka̱tsu ka gbayin ka̱ nu, ɗa uma a sumai,
\q2 ayin na baci kpamu vu ɗa̱nga̱i kashani, ka̱ta̱ aduniyan u wacuwa,
\q1 
\v 4 Uma o ɓolongi ucanuku u kuvon, uteku tsu na nta̱ɗa̱ma̱ci n tsu ɓolongu ka̱ta̱ kpamu akyuꞋun a pala kashina, ta uma a a̱ kukpa̱nta̱ ili ya nannai.
\b
\q1 
\v 5 Vuzavaguɗu vuzagbayin ɗa, wi ta̱ ida̱shi ɗe gaɗi,
\q2 wi ta̱ a kushatangu Sihiyona n kasingai koɓolo n ka mayun,
\q1 
\v 6 a̱yi ɗa u kokpo kumiꞋi ku nu a ayin a nanlo,
\q2 n wishi wa̱ a̱bunda̱i, n kuyeve n ugboji.
\q1 Kupana ku wovon ku Vuzavaguɗu ku ɗaɗa uciyi u nu.
\b
\q1 
\v 7 La̱na̱, osoji a utsura a̱ ma̱shi a uye,
\q2 aza a usuki a̱ ma̱ta̱na̱ a̱ ma̱shi wuya-wuya.
\q1 
\v 8 Uye u gbagbaꞋin u na̱mgba̱ ta̱,
\q2 aza a nwalu o doku o tono u ɗa ba.
\q1 Ɗa uzuwakpani u yaꞋin ukoɗi,
\q2 ɗa likuci kakau i yaꞋin ugoyi,
\q2 vuma u doku u ciya̱ ucikpi kpamu ba.
\q1 
\v 9 Ɗa iɗika i na̱mgba̱i ka̱tsuma̱ ɗa i lumbai,
\q2 ɗa nɗanga n Lebano n yambai ɗa n lumbai,
\q1 Ka̱ra̱Ꞌa̱ ka Sharon ke ɗekpe ta̱, ɗa wo okpoi tsu kakamba,
\q2 ɗa Bashan koɓolo n Kamelu a̱ sa̱ruwa̱i a̱vuku e le.
\b
\q1 
\v 10 Vuzavaguɗu u danai, <<Gogo na mi ta̱ a̱ kuɗa̱nga̱,>>
\q2 ka̱ta̱ kpamu a cikpa mu,
\q2 <<Gogo na mi ta̱ e kuneke ka̱ci ka̱ va̱ tsugbayin.
\q1 
\v 11 I na yi a kuyaꞋansa yi ta̱ tsu kopo
\q2 i bonoi i matsai ciꞋiwa̱,
\q2 ayinviki a̱ ɗa̱ i ta̱ tsa akina a na e kuleɓece ɗa̱.
\q1 
\v 12 Uma a̱ nu i ta̱ a̱ kukula̱ gbende-gbende,
\q2 tsu awana a kakamba a na a kapai ɗa o songi n akina.>>
\b
\q1 
\v 13 A̱ɗa̱ na yi daꞋangi, panai i na n yaꞋin,
\q2 a̱ɗa̱ na yi ɗevu, yevei utsura u va̱.
\q1 
\v 14 Aza a̱ unushi a Sihiyona a pana ta̱ wovon,
\q2 aza a na e yevei Ka̱shile ba, e jeꞋeke ta̱ ikyamba, ɗa a danai,
\q1 <<Yayi a̱ ka̱tsuma̱ ka̱ tsu u kufuɗa kuda̱sa̱ngu n akina o mosonku?
\q2 Yayi kpamu a̱ ka̱tsuma̱ ka̱ tsu u kufuɗa kuyongo n akina a na i a̱ kukula̱ babu uteku?>>
\q1 
\v 15 Vuza na wi a kuyaꞋan nwalu mu usuɓi
\q2 ɗa kpamu wi a kuyaꞋan kadanshi ki ili i na i gaꞋin,
\q1 ɗa u iwain kuɗika i na i uwai ni n uye u kalyaꞋa,
\q1 a̱yi na u iwain kupanaka aza a na e ci sheshe ukuna u munuka,
\q2 a̱yi na u tsu yimba̱tsa̱ka̱ a̱shi a̱ ni adama a na u kpa̱ɗa̱ kinda ukuna u wuya,
\q1 
\v 16 wi ta̱ o kuyongo gaɗi,
\q2 ubuta̱ u kusheɗeku u ni wi ta̱ kokpo ubuta̱ wu nsasan m gbagbaꞋin.
\q1 Ka̱ta̱ e neke yi ilikulya,
\q2 wi a kunamba kpamu mini mo kusoꞋo ba.
\b
\q1 
\v 17 Vi ta̱ e kene mogono n ugaꞋin u ni,
\q2 ka̱ta̱ ve ene kpamu i ɗika i na yi n ka̱ba̱nga̱ n a̱bunda̱i ali a kubana daꞋangi.
\q1 
\v 18 N ka̱ɗu ka̱ nu vi ta̱ a kuciɓa n i na i saꞋwai kuzuwa wu wovon, ka̱ta̱ vu dana
\q2 <<Te ɗai biꞋi, vuza vu mekecu va,
\q1 Te ɗai kishi ku utafu ka?
\q2 Te ɗai kpamu kekeci ki imashi ka?>>
\q1 
\v 19 Yi o kudoku kene uma a ugbamukaci kpamu ba,
\q2 aza na kadanshi ke le ki n atakaci a̱ kuyeve,
\q2 i a kadanshi n cikeku tsu na ya kufuɗa kuyeve ba.
\b
\q1 
\v 20 La̱na̱ Sihiyona, likuci i na a̱ tsu ci yaꞋansa ka̱ɗiva̱ ka̱ tsu.
\q2 A̱shi a̱ nu i ta̱ e kene Urishelima,
\q2 likuci yi ida̱shi i ma̱ta̱na̱, wi ta̱ o kokpo tsu ka̱pa̱m ka na ki kushewerengu ba,
\q1 aguta a ni kpamu i kumuɗa̱ ba,
\q2 babu kawin kete ka̱ ni ka na ki a kukasa.
\q1 
\v 21 Ta ɗe Vuzavaguɗu n utsura u ni wi adama a̱ tsu,
\q2 Tsu ubuta̱ u na wi n kuyene n adaɓa i,
\q1 gaɗi vi le antsu o kuvon a kubana ɗe ba,
\q2 babu kpamu antsu a gbagbaꞋin.
\v 22 Adama a na Vuzavaguɗu ɗa kayaꞋin ka afada ka̱ tsu,
\q2 Vuzavaguɗu ɗa keneki ka̱ wila̱ ka̱ tsu,
\q1 a̱yi ɗa kpamu mogono ma̱ tsu,
\q2 wi ta̱ a kisa tsu.
\b
\q1 
\v 23 Ashiyatsu a usaki a a̱ ba̱ɗa̱ ta̱,
\q2 o doku reme kalangu ka
\q2 kakashi ka tsu na kpantsu ka kuwala mayin ba.
\q1 Ka̱ta̱ a ayin a nanlo a i peceshe ucanuku wa̱ a̱bunda̱i u na a̱ pura̱i va,
\q2 ali nkutu feu n raliwa tsu na a cigai.
\q1 
\v 24 Babu vuza na wi ida̱shi a Sihiyona u kudana, <<Mpa mi gbaga ba>>
\q2 I ta̱ a kucinukpaka aza a na i ida̱shi ɗe unushi u le.
\c 34
\s1 Afada adama a uma aduniyan
\p 
\v 1 Ta̱wa̱i ɗevu, a̱ɗa̱ iɗika i limoci ya aduniyan ka̱ta̱ i pana,
\q2 bonokoi asuvu a̱ ɗa̱ ubuta̱ u te a̱ɗa̱ uma.
\q1 YaꞋan iɗika n i na yi punu dem i pana,
\q2 ka̱sukpa̱ aduniyan n i na i tsu uta̱ punu dem i yeve.
\q1 
\v 2 Adama a na Vuzavaguɗu wi ta̱ a wupa n aduniyan ra̱ka̱,
\q2 wupa wu usuɗukpi ka̱ɗu u ni, wi ta̱ a̱ ubuta̱ wi irala i le ra̱ka̱.
\q1 Wi ta̱ a kuna le ra̱ka̱,
\q2 wi ta̱ kpamu a̱ kuka̱sukpa̱ a kiɗa le.
\q1 
\v 3 Even a ikyamba e le a̱ kuciya̱ uciɗa̱ngi ba,
\q2 ka̱ta̱ ushami we even a ikyamba i le a̱ ka̱ra̱Ꞌa̱ iɗika,
\q1 ka̱ta̱ nsansa n yene nu mpasa n le.
\q1 
\v 4 Ka̱ta̱ kpamu ili i kutashi i gaɗi ra̱ka̱ a̱ niꞋwa̱n,
\q2 Gaɗi wi ta̱ a̱ ka̱ta̱la̱ tsu kajiba,
\q1 ka̱ta̱ azangata o ɗoɗo a iɗika
\q2 tsa̱ a̱vuku a itacishi a na a lumbai,
\q2 ko uteku tsu na umaci u ma̱biri u na u ɗekpei.
\q1 
\v 5 Ayin a na baci kotokobi ka̱ va̱ ko kotsoi ulinga u ni na ɗe gaɗi,
\q2 la̱na̱, ka ki ta̱ a̱ kucipa̱ adama a afada a aza e Edom,
\q1 a̱ ubuta̱ u uma a na n sheshei kuna.
\q1 
\v 6 Kotokobi ka Vuzavaguɗu ka̱ sumba̱ ta̱ nu mpasa,
\q2 ki ta̱ upali nu ushuma
\q1 koɓolo nu mpasa mu nlala nu nga̱ji,
\q2 ushuma u muku n ka̱tsuma̱ ma̱ a̱giri.
\q1 Adama a na Vuzavaguɗu wi ta̱ n alyuka a Boza,
\q2 koɓolo m makiɗaka ma̱ a̱bunda̱i wa aza a Edom.
\q1 
\v 7 Uma i ta̱ a̱ kukuwa̱ tsu njuma,
\q2 koɓolo n a̱ɗa̱nga̱ni n aza a utsura feu.
\q1 Iɗika yi ta̱ o kusoꞋo mpasa,
\q2 ka̱ta̱ kayala ka̱ cuwa̱ n ushuma.
\b
\q1 
\v 8 Adama a na Vuzavaguɗu wi ta̱ n kanna ka kutsupa,
\q2 ka̱ya̱ ka kutsupa i na a yaꞋankai Sihiyona.
\q1 
\v 9 Ka̱ta̱ nyeneke n Edom m bono maniꞋin ma na a tsu sura a uye,
\q2 kayala ka̱ ni ko bono tsa akina a̱ ka̱nga̱ ko tsukono,
\q2 ka̱ta̱ iɗika i ni kpamu i kula̱ tsa akina a na i a kulala ka̱u.
\q1 
\v 10 Kanna n kayin dem a̱ kukima̱ a ɗa ba,
\q2 ka̱nga̱ ka ni ki ta̱ a̱ kuɗa̱nga̱ babu kuzuwa uteku.
\q1 Ali n tsukaya n tsukaya, u ɗa wi ta̱ o kokpo ukuna u gbani,
\q2 babu vuza na u kudoku wo tono u ɗa.
\q1 
\v 11 Ma̱kpa̱tuwa̱n n kagawun i ta̱ o kuyongo punu a̱ ubuta̱ wa,
\q2 ka̱ta̱ a yaꞋan ɗe cikinda.
\q1 Adama a na Ka̱shile ki ta̱ a kugisangu iɗika i nanlo ya n cicoꞋo,
\q2 wi ta̱ a kugisangu i ɗa adama a na u tuka̱ n kawuya
\q2 koɓolo m munuka.
\q1 
\v 12 Babu tsugbayin tsu na tsa kubuwa tsu na tsa kuzagba tsugono,
\q2 muku mu ngono ra̱ka̱ mi ta̱ a̱ kuniꞋwa̱n.
\q1 
\v 13 Awana i ta̱ o kugbonguro ka̱ta̱ a lyaꞋa iꞋuwa yi utsura i le,
\q2 awanagbede i ta̱ a̱ kuta̱ a isa kefeku ko ngono koɓolo n likuci i na yi ni nshilya.
\q1 I ɗa yi ta̱ o kokpo ubuta̱ u kuyongo wi nsheꞋe n kakamba,
\q2 n iꞋuwa yi mkpa̱tuwa̱n.
\q1 
\v 14 Ka̱ta̱ nnama n kamba n gasa n a̱kunzu,
\q2 ka̱ta̱ nreꞋe n shika̱ka̱ itoku i le,
\q1 mayu, ta ɗe ili i kayin i kuyongo,
\q2 ka̱ta̱ a̱ la̱nsa̱ka̱ ka̱ci ke le ubuta̱ u kuvuka.
\q1 
\v 15 Ta ɗe ma̱kpa̱tuwa̱ ma kuyaꞋan cikinda ka̱ta̱ a zuwa okowo,
\q2 ka̱ta̱ u gyaꞋwan, ka̱ta̱ u ɓolongu muku ni a asuvu e evelyu a̱ ni,
\q1 mayun ta ɗe kpamu asakali o kuyongo,
\q2 vuza n vuka vi ni.
\p 
\v 16 La̱na̱ ka̱ta̱ vi kece a katagarda ka Vuzavaguɗu.
\q1 Babu ili i te punu a katagarda ka i na i kupuwa̱nka̱,
\q2 babu vuza na u kunamba vuza ni.
\q1 Adama a na n una̱ u ni u ɗa Vuzavaguɗu u yaꞋin kadanshi ka,
\q2 ayinviki a̱ ni i ta̱ o kuɓolongu le a̱ ubuta̱ u te.
\q1 
\v 17 U zagbaka le ta̱ ubuta̱ u na yaba dem u kuyongo,
\q2 n ekiye a̱ ni ɗa u pecekei le n kagisamkpatsu,
\q1 i ta̱ a̱ kuka̱na̱ i ɗa ali sai uteku n uteku
\q2 ta ɗe o kuyongoso ali n tsukaya n tsukaya.
\c 35
\s1 Ma̱za̱nga̱ ma vuza na a̱ Shiba̱i
\p 
\v 1 Meremune n agbata i ta̱ a kuyaꞋan ma̱za̱nga̱,
\q2 kakamba ki ta̱ a kuyaꞋan ma̱za̱nga̱ ka̱ta̱ ka yaꞋan a̱pa̱lu
\q1 tsa apulufa,
\v 2 wi ta̱ a̱ kuba̱za̱lukpa̱ a̱pa̱lu n a̱bunda̱i
\q2 ka̱ta̱ u yaꞋan ma̱za̱nga̱ m ma̱ta̱na̱ n ishipa.
\q1 I ta̱ e kuneke yi tsugbayin tsu Lebano,
\q2 uteku tsugbayin tsu kusan ku Kamelu n ka̱ra̱Ꞌa̱ ka Sharon.
\q1 I ta̱ e kene tsugbayin tsu Vuzavaguɗu Ka̱shile ka̱ tsu,
\q2 tsugono tsu Ka̱shile ka̱ tsu.
\v 3 Ɓa̱nka̱i aza a na oꞋoi,
\q2 ka̱ta̱ i ɓa̱nka̱ aza a na a buwai n utsura ba.
\q1 
\v 4 Danai aza na i n a̱ɗu o wovon,
\q2 <<Gbamai asuvu, ka̱ta̱ i pana wovon ba,
\q1 Ka̱shile ka̱ ɗa̱ ki ta̱ a̱ kuta̱wa̱,
\q2 wi ta̱ a̱ kuta̱wa̱ n katsupu,
\q1 ka̱ta̱ wi isa ɗa̱.>>
\b
\q1 
\v 5 Ka̱ta̱ a̱shi a̱ a̱yimba̱ a̱ ɓa̱yuwa̱,
\q2 ka̱ta̱ atsuvu a kagulani kpamu a pana,
\q1 
\v 6 ka̱ta̱ nkutsuma̱ n taɗukpa tsu nreꞋe,
\q2 ka̱ta̱ kelentsu ke kebebe ko orukpo adama a̱ ma̱za̱nga̱.
\q1 Ka̱ta̱ mini mu uta̱ e meremune,
\q2 n nyeneke n yene a kakamba.
\q1 
\v 7 Iɗika yu usuɗukpi yi ta̱ o kokpo kadaɓa ka̱ mini,
\q2 ka̱ta̱ iɗika i ɗekpu i yene mini.
\q1 Ka̱ta̱ ubuta̱ u na nsheꞋe n kakamba mi ishi n ci yongo, u shana m mita̱,
\q2 n ikiku koɓolo n abatamini i ta̱ o kugbonguro.
\q1 
\v 8 Uye u gbayin u kuyaꞋan ta̱ ɗe,
\q2 i ta̱ e kuɗeke u ɗa uye u ciɗa,
\q1 aza a unata a kuwala punu ba.
\q2 U ɗa wi ta̱ o kokpo uye wa aza a na i o kutono uye u Ka̱shile,
\q2 ko alau o kutono u ɗa ba.
\q1 
\v 9 Babu kawu vu na u kuyongo ɗe,
\q2 babu kpamu nnama m gbani-gbani n na n kutono ɗe,
\q2 e kene le ɗe ba,
\q1 ama aza a na Vuzavaguɗu wi isai koci ele ɗa o kutono uye wa,
\q2 
\v 10 ka̱ta̱ aza na Vuzavaguɗu u Shiba̱i o bono,
\q1 ka̱ta̱ a uwa Sihiyona n ishipa,
\q2 ka̱ta̱ ma̱za̱nga̱ ma babu uteku mo yongo n ele,
\q1 ka̱ta̱ a̱ ciya̱ ma̱za̱nga̱ m ma̱ta̱na̱,
\q2 ka̱ta̱ una̱mgbuka̱tsuma̱ n atakaci o kotso.
\c 36
\s1 Sanakaribu, u rikpa̱sa̱i aza a Yahuda
\p 
\v 1 A̱ ka̱tsuma̱ ka̱ ka̱ya̱ ka kupa n a̱na̱shi ka na Mogono Hezikaya wi a kulyaꞋa tsugono, ɗa Sanakaribu mogono ma Asiriya u shilika̱i n likuci yu ukanji ya aza a Yahuda ra̱ka̱ ali ɗa wi isai i ɗa.
\v 2 Ɗaɗa Mogono ma Asiriya u suki kovonshi vi ni, wu uta̱i e Lakishi a kubana a̱ ubuta̱ u Mogono Hezikaya ɗe Urishelima. Ɗa ka̱bunda̱i ko osoji ka banai n a̱yi, ɗa ka̱suki ka ka shamgbai a kapasa ka kadaɓa ka gaɗi, a uye wu ubuta̱ u na a ci yaꞋan kuza̱Ꞌa̱,
\v 3 ɗa Eliyakimu maku ma Hilikiya vuza vu ulinga vu kefeku ko mogono, n Shebuna kaɗani, koɓolo n Jowa maku ma Asafu kofoɓi ka atagarda o mogono, ɗa a banai a gasai n a̱yi.
\p 
\v 4 Ɗa vuza kelime vu Asiriya u danai aza e kelime a Yahuda, <<Dana Hezikaya, <Ili i na vuzagbayin mogono, mogono ma Asiriya u dansai i ɗa na. U Yayi vi nekei ka̱ɗu ka̱ nu ali ɗa vi a̱ra̱ɗi?
\v 5 Vi sheshe ta̱ vi ta̱ n ugboji n utsura wo osoji? Ama ɗa vi yaꞋin kadanshi ka gbani. U yayi vu zuwakai katsura, ali ɗa vi kuyaꞋanka mu ugbamukaci?
\v 6 La̱na̱, vu zuwa ta̱ katsura ka̱ nu wa aza a Masar, a̱yi kokoɗi ka kakungu ka nanlo, ka na ka kufuɗa kukiɗa kukiye ku vuma, ka̱ta̱ ka kiɗa vuza na u tsubaki wa̱ ni. Ta kpamu mogono FiriꞋauna vu Masar wi nannai wa aza na e nekei a̱ɗu e le wa̱ ni.
\v 7 Vu dana mu baci, <<Ci ta̱ e kuneke a̱ɗu a̱ tsu u Vuzavaguɗu Ka̱shile ka̱ tsu,>> A̱yi ɗa vuza na ubuta̱ u kucikpa wa̱ a̱Ꞌisa̱ n atalyalyuka a̱ ni a na Hezikaya u muɗa̱i va ba? Ɗa u danai aza a Yahuda n aza a Urishelima, <<Mayun ɗa i cikpa katalikalyuka ka nampa ka ba?>>
\v 8 Ta̱wa̱ gogo na, vu bana vi yaꞋan kadanshi ka tsulaga n vuza gbayin vu va̱, mogono ma Asiriya. Mi ta̱ e kuneke wu odoku ali a̱kpa̱n ere, vi baci a kufuɗa va zuwa akumbi gaɗi vi le.
\v 9 Nini ɗai va ku fuɗa kulaꞋa utsura u kosoji ke kenu ka vuzagbayin vu va̱, avu na sai biꞋi vu zuwaka aza Masar katsura e neke wu ekeke odoku n akumbi?
\v 10 N tsu nampa i sheshe ta̱ n ta̱wa̱ ta̱ mu una ɗa̱ babu uɓa̱nki u Vuzavaguɗu? Vuzavaguɗu u dana mu ta̱, bana vi shilika̱ n iɗika ya ka̱ta̱ vu una i ɗa.> >>
\p 
\v 11 Ɗaɗa Eliyakimu n Shebuna koɓolo n Jowa a danai vuza kelime vo osoji, <<Vuzagbayin, ci ta̱ ufolu u nu, yaꞋanka agbashi a̱ nu kadanshi n kelentsu ka aza a Ibirahi, adama a na ci ta̱ a kupana kaꞋa. Ka̱ta̱ vi yaꞋanka tsu kadanshi n kelentsu ka aza a Ibirahi ba, adama a na uma a na i a gaɗi vu mashilya i ta̱ a kupana.>>
\p 
\v 12 Ama ɗa vuza kelime va wu ushuki u danai, <<Ye ene ta̱ u vuzagbayin vu ɗa̱ ɗa koci n a̱ɗa̱ vuzagbayin vu va̱ u suki mu n dana ɗa̱ kadanshi ka nampa, koɓolo feu n aza a na i a gaɗi vu mashilya ba, ele na i uteku tsu ɗa̱ a kulyaꞋa a̱wiya̱n e le ɗa kpamu i o kusoꞋo akyana e le ba?>>
\p 
\v 13 Ɗaɗa vuza kelime va u ɗa̱nga̱i kashani ɗa u dansai n kelentsu ka aza a Ibirahi, u danai, <<Panai kadanshi ko mogono ma gbayin, mogono ma aza a Asiriya.
\v 14 I na mogono ma dansai i ɗa na, <Ka̱ta̱ i ka̱sukpa̱ Hezikaya u ya̱nsa̱ ɗa̱ ba, adama a na wa kufuɗa kisa ɗa̱ ba.
\v 15 Ka̱ta̱ yu ushuku n Hezikaya u leꞋeshe ɗa̱ i zuwa a̱ɗu a̱ ɗa̱ u Vuzavaguɗu ba, ɗa baci u danai, <<Vuzavaguɗu wi ta̱ a kisa tsu, likuci i nampa ya kuꞋuwa e ekiye o mogono ma Asiriya ba.>>
\v 16 Ka̱ta̱ i panaka Hezikaya ba. Ili i na mogono ma Asiriya ma danai i ɗa na, yaꞋin ida̱shi i ma̱ta̱na̱ nu mpa ka̱ta̱ i ta̱wa̱ wa̱ va̱. Ka̱ta̱ yaba dem vu ɗa̱ u lyaꞋa punu a umaci u kashina ki itacishi i ni, m maɗanga ma̱ ma̱biri ma̱ ni, ka̱ta̱ kpamu u soꞋo mini ma kayinva ka̱ ni,
\v 17 sai ayin a na n ta̱wa̱i n ɗikai ɗa̱ ɗa m bankai a iɗika i na i yotsoi iɗika i ɗa̱, iɗika i na yi n ili i kashina m ma̱kya̱n ma savu, n ilikulyaꞋa n itacishi i inabi.
\v 18 Ka̱ta̱ i ka̱sukpa̱ Hezikaya u ya̱nsa̱ ɗa̱ ba, ɗa baci u danai, <<Vuzavaguɗu wi ta̱ a kisa tsu,>> Ka̱ma̱li ki iɗika i yoku ka saꞋwa ta̱ ɗe kisa iɗika i ni, e kukiye ku mogono ma aza a Asiriya?
\v 19 Te ɗai a̱ma̱li a Hamata n a̱ma̱li a Arpadu i? Te ɗai kpamu a̱ma̱li a Sefarwayim i? A fuɗa ta̱ a isa aza a Samariya e kukiye a̱ va̱?
\v 20 A̱ ka̱tsuma̱ ka̱ a̱ma̱li a iɗika i nanlo ra̱ka̱, ka̱ma̱li ke ne kaꞋi ka saꞋwai kisa i ɗika i ni e kukiye ku va̱? Nini ɗai Vuzavaguɗu u kufuɗa kisa aza a Urishelima e kukiye ku va̱?> >>
\p 
\v 21 Ama tsugbayin tsa aza Yahuda a paɗai bini, ɗa a̱ kpa̱ɗa̱i kukeɓece kakuna, adama a na mogono ma dana ta̱, <<Ka̱ta̱ vuza u keɓece yi ba.>>
\p 
\v 22 Ɗa Eliyakimu maku ma Hilikiya, vuza gbayin vu kefeku ko mogono, n Shebuna kaɗani, n Jowa maku ma Asafu kofoɓi ka atagarda o mogono, ɗa ra̱ka̱ vi le a banai a̱ ubuta̱ u Hezikaya nu ntogu n le ukari, ɗa a danai ni ili i na vuza kelime vo osoji va Asiriya va u danai.
\c 37
\s1 Hezikaya u la̱nsa̱i uɓa̱nki u Vuzavaguɗu.
\p 
\v 1 Ana Mogono Hezikaya u panai kadanshi ka aza gbagbaꞋin a̱ ni, ɗa ta na u karai ntogu n ni adama a una̱mgbi u ka̱tsuma̱, ɗa u ukai akashi a una̱mgbi u ka̱tsuma̱, ɗa u lazai a kubana a̱ ma̱va̱li ma Vuzavaguɗu.
\v 2 Ɗa u suki Eliyakimu vuza gbayin vu kefeku ko mogono, koɓolo n Shebuna kaɗani, n ganu vu gbagbaꞋin, ra̱ka̱ vi le ta na i ta̱ u uki nu ntogu mu una̱mgbi u ka̱tsuma̱, ɗa a lazai a kubana u keneki Ishaya maku ma Amozu.
\v 3 Ɗa a danai ni, <<Ili i na mogono Hezikaya u dansai i ɗa na. Anana kanna ku una̱mgbuka̱tsuma̱ kaꞋa, koɓolo n kanna ka mashikaka n kugoyi. Wi ta̱ kpamu tsu na ka̱tsuma̱ ka na ka yawai kumatsa, ama i n utsura u na a kumatsa muku ma ba.
\v 4 U gaꞋan ba Vuzavaguɗu Ka̱shile ka̱ ɗa̱ ki ta̱ a kupana kadanshi ka vuza vu kelime vo osoji a Asiriya va, vuza na vuzagbayin mogono ma Asiriya u suki u goyo Ka̱shile ka wuma, ka̱ta̱ u ɓarangu yi adama a kadanshi ka na Vuzavaguɗu Ka̱shile ka̱ ɗa̱ ka panai. Adama a nannai vasa adama a uma a na a buwai n wuma.>>
\p 
\v 5 Ana agbashi o mogono Hezikaya a̱ ta̱wa̱i wi Ishaya, ɗa a danai ni ili na Mogono ma danai,
\v 6 ɗa Ishaya u danai le, <<Danai vuzagbayin vu ɗa̱, <Ili i na Vuzavaguɗu u dansai i ɗa na. Ka̱ta̱ i pana wovon u kadanshi ka̱ a̱ra̱ɗi ka na agbashi o mogono ma Asiriya a yaꞋankai mu ba.
\v 7 Panai, mi ta̱ a kuzuwa ili i yoku a̱ ka̱ɗu ka̱ ni, adama a na u pana baci ili i na akaka a a danai, wi ta̱ o kubono a iɗika i ni, ta ɗe n kuzuwa a una yi n kotokobi.> >>
\p 
\v 8 Ana vuza kelime vo osoji a Asiriya u panai a na mogono ma̱ ni ma̱ ka̱sukpa̱i likuci i Lakishi, ɗa u banai kushilika̱ n aza a Libina. Ɗa feu u lazai a kubana ɗe.
\p 
\v 9 Gogo na Senekeribu u pana ta̱ akaka a na Tirihaka mogono mi Itopiya wu uta̱ ta̱ adama a na u shilika̱ n a̱yi. Ɗa u suki alingata a kubana u Hezikaya, a danai,
\v 10 <<Danai Hezikaya mogono ma Yahuda, ka̱ta̱ vu ushuku n Ka̱shile ka̱ nu ka na ka ko doroi nu ɗa ka danai, we e kuneke Urushelima e ekiye o mogono ma Asiriya ba.>
\v 11 Mayun vu pana ta̱ tsu na mogono ma Asiriya ma yaꞋin n iɗika kakau, wu unai le gbende-gbende. Avu vi ta̱ a kulaꞋaka?
\v 12 Ikaya i va̱ i la̱nga̱sa̱i ta̱ Likuci i Gozan n Haran, n Rezefa, koɓolo n aza a Adini a na i Telasaru a̱ma̱li a iɗika i nanlo ya a fuɗa yi isai le ba
\v 13 Te ɗai mogono ma Hamata m mogono ma Arpada i anana? Te ɗai kpamu mogono ma̱ likuci i Sefarwayim, m mogono ma Hena, m mogono ma Iwa i gogo na?>>
\s1 Hezikaya u yaꞋin kavasa
\p 
\v 14 Ɗa Hezikaya wi isai akaka a katagarda a e ekiye alingata a, ɗa u kecei. Ɗa u banai a̱ ma̱va̱li ma Vuzavaguɗu, ɗa ta na u ɓa̱yuwa̱i akaka a katagarda e kelime ka Vuzavaguɗu.
\v 15 Ɗa Hezikaya u yaꞋin kavasa a kubana u Vuzavaguɗu.
\v 16 <<Vuzavaguɗu MalaꞋimili, Ka̱shile ki Isaraila, avu na vi ida̱shi e mere ma Corobin, avu ɗa Ka̱shile endeꞋen o tsugono ra̱ka̱ tsa aduniyan. Vi yaꞋan ta̱ gaɗi n iɗika.
\v 17 Vuzavaguɗu, zuwaka mu atsuvu a̱ nu, ka̱ta̱ vu panaka mu avasa a̱ va̱, ɓa̱yuwa̱ a̱shi a̱ nu Vuzavaguɗu ka̱ta̱ ve ene, inda kadanshi ki ishikushi ka na mogono Sanakaribu u suki a yaꞋanka Ka̱shile ka wuma.
\p 
\v 18 <<Mayun ɗa, Vuzavaguɗu, ngono ma aza Asiriya a una ta̱ uma a ra̱ka̱ n iɗika i le dem.
\v 19 Ɗa a variki a̱ma̱li e le a asuvu a kina ɗa o songi a ɗa, adama a na ele a̱ma̱li a mayun a ɗa ba, nɗanga n ɗa n atali koci, a na vuma u yaꞋin n ekiye a̱ ni.
\v 20 Gogo na, Vuzavaguɗu Ka̱shile ka̱ tsu, isa tsu e ekiye a̱ ni, adama a na tsugono ra̱ka̱ tsa aduniyan ci yeve a na avu ɗa Vuzavaguɗu endeꞋen.>>
\s1 Sanakaribu u yikpa̱i
\r (2 Ng 19:20-34)
\p 
\v 21 Ɗaɗa Ishaya maku ma Amozu u suki n akaka a kubana u Hezikaya, u danai, <<Na ɗa i na Vuzavaguɗu Ka̱shile ki Isaraila, ka danai. Adama a na vi yaꞋan ta̱ kavasa a̱ kuta̱wa̱ wa̱ va̱, adama a Sanakaribu mogono ma Asiriya,
\v 22 na ɗa kadanshi ka na Vuzavaguɗu u yaꞋin adama a̱ ni,
\q1 <<Sihiyona wi tsu mekere ma na ka̱ta̱ me yevei vali ba,
\q2 u goyo wu ta̱ ɗa u yaꞋankai nu ma̱ka̱n.
\q1 Mekere ma Urishelima
\q2 u yaꞋanka wu ta̱ iberetei a̱ kucina̱ ku nu.
\q1 
\v 23 Yayi vi shikai ɗa kpamu vi yaꞋankai kadanshi ki ishikushi?
\q2 Yayi vu ɗengusa̱ka̱i ka̱la̱ka̱tsu
\q1 ali ɗa vu uta̱ka̱i a̱shi a̱ a̱ra̱ɗi?
\q2 Nu mpa ɗa vi a tsura vuza Ciɗa vi Isaraila.
\q1 
\v 24 N alingata a̱ nu a ɗa
\q2 vu goyoi Vuzavaguɗu.
\q1 Ɗa vu danai,
\q2 <N ekeke o odoku a̱ a̱bunda̱i a̱ va̱ a ɗa
\q1 mi isai nsasan n na n laꞋi n ugaɗi, ɗa n uwai punu e mere-mere
\q2 u ɓata̱ u na u lai nu gaɗi a kakamba ka Lebano.
\q1 Adama a na n kapa ta̱ nɗanga n Sida n na n laꞋi n ugaɗi,
\q2 nu nɗanga n sipirus n na n laꞋi n kugaꞋan.
\q1 Ɗa vu danai, n yawa ta̱ a uteku u na u laꞋi n zuva,
\q2 ɗa n uwai n galai kuntsu ku ni.
\q1 
\v 25 N ga̱va̱ ta̱ ayinva,
\q2 ɗa n soꞋi mini me le.
\q1 N ataka e ene a̱ va̱
\q2 ɗa n dasai n ɗekpetengi nyeneke ma aza a Masar ra̱ka̱.>
\b
\q1 
\v 26 <<Vu saꞋwa kupana ba?
\q2 A na mpa n sheshe ɗe ili i nampa ali m megeshe ɗe?
\q1 N foɓuso ta̱ i ɗa n ayin acau a ɗe,
\q2 ɗa gogo mi a kuzuwa i ɗa i yaꞋan,
\q1 uteku u na vo kuɓoso likuci yu ukanji
\q2 ka̱ta̱ vu bonoko i ɗa kotomo ka agali.
\q1 
\v 27 I ɗaɗa i zuwai ɗa uma e le i babu utsura u makara, o okpoi n wovon
\q2 ɗa a̱ ripula̱i.
\q1 O okpoi babu utsura tsu mita̱,
\q2 babu atakaci e kukpete an mita̱ ma savu ma na mi a̱ kuta̱.
\q1 I ta̱ tsu mita̱ ma na mo tsu topo a gaɗi vu tsusaki, ka̱ta̱ ma lumba ma̱ kpa̱ɗa̱ kugbonguro.
\b
\q1 
\v 28 <<Ama n yeve ta̱ ubuta̱ u na vi ida̱shi, n ayin a na vu tsu ta̱wa̱, n ayin a na vu tsu laza, n tsu na vi n wupa n a̱bunda̱i adama a̱ va̱.
\v 29 Adama a na vi yaꞋan ta̱ wupa n a̱bunda̱i nu mpa,
\q2 ɗa kpamu kadanshi ku ugbamukaci u nu ka yawai a atsuvu a̱ va̱,
\q1 mi ta̱ a kuꞋuka kuɗopi a̱ vunu vu nu,
\q2 ka̱ta̱ kpamu n zuwa iryangama a̱ una̱ u nu.
\q1 Ka̱ta̱ n zuwa wu vu bono vu tono
\q2 nu uye u na vu tuka̱i.
\p 
\v 30 <<Na va wi ta̱ o kokpo urotu wa̱ nu, avu Hezikaya,
\q1 <<Lala vi ta̱ a kulyaꞋa i na i matsai n ka̱ci ka̱ ni,
\q2 ka̱ta̱ ka̱ya̱ vi lyaꞋa umaci u na o doku a matsasakai ɗe.
\q1 A̱ ka̱ya̱ ka tatsu vi ta̱ a̱ kuca̱Ꞌa̱ n ka̱ci ka̱ nu ka̱ta̱ vi kyaꞋa,
\q2 vi ca̱Ꞌa̱ kashina ki itacishi ka̱ta̱ vi lyaꞋa umaci u ni.
\q1 
\v 31 Ka̱ta̱ aza a na a buwai n wuma a Yahuda,
\q2 a lapula ida̱shi mayin uteku tsu maɗanga ma na ma tsu zuwa aralu a iɗika ka̱ta̱ u matsa mayin gaɗi.
\q1 
\v 32 Adama a na kagimi ka uma a̱ va̱ ki ta̱ a̱ kuta̱ punu a Urushelima,
\q2 ka̱ta̱ koɓolo ka aza a na a laꞋakai n wuma kuta̱ a Kusan ku Sihiyona.
\q1 Vuzavaguɗu kovonshi vo osoji a gaɗi
\q2 wi ta̱ a kuyaꞋan ili i nampa.
\v 33 <<Adama a nannai ili i na vuzavaguɗu u dansai adama o mogono ma Asiriya i ɗa na.
\q1 <<Wa kuꞋuwa a̱ likuci i nampa ya ba,
\q2 ko ta na u taɗuku punu kaya.
\q1 U kuꞋuwa punu i ɗa m ma̱ra̱ga̱
\q2 ko kpamu u maꞋa idasakpatsu i na u kuꞋuka punu ba.
\v 34 Vuzavaguɗu u danai, Wa kuꞋuwa a̱ likuci i nampa ba, n uye u na wu utuka̱i u ɗaɗa u kubonoko.>>
\v 35 <<Mi ta̱ a kukanza likuci i nampa ya ka̱ta̱ mi isa i ɗa,
\q2 adama a̱ ka̱ci ka̱ va̱ n kagbashi ka̱ va̱ Dawuda.>>
\p 
\v 36 Ɗa kalingata ka Vuzavaguɗu ka banai kunai aza a Asiriya ali uma a̱kpa̱n amangatawun n amanga̱na̱shi n a tawun. Ana kayin kasai ɗa e enei even a ikyamba a uma a̱ ubuta̱ dem.
\v 37 Ɗa Sanakaribu mogono ma Asiriya u lazai u bonoi a̱ likuci i ni, e Niniva.
\p 
\v 38 Kanna ke te, ana wi a kuyaꞋan kavasa a̱ kunu ku ka̱ma̱li ka̱ ni Nisaroku, ɗa muku n ni Adurameleki n Shareza a unai ni n kotokobi. Ɗa a sumai a kubana iɗika i Arara. Ɗa Isarhadon kolobo ka̱ ni ko okpoi mogono a̱ una̱ u ni.
\c 38
\s1 Mɓa̱la̱ n Hizekiya n kupotso ku ni \x - \xo 38:0 \xt 2 Ng 20:1-11; 2 Ar 32:24-26\x*
\p 
\v 1 A ayin a na Hizekiya wi ishi mogono, u ka̱na̱i mɓa̱la̱ kenu ana wa̱ kuwa̱. Ɗa Ishaya keneki kolobo ka Amozu ka banai wa̱ ni, ɗa u danai ni, <<Na ɗa ili i na Vuzavaguɗu u danai. Foɓuso kpaꞋa ku nu, adama a na vi ta̱ a̱ kukuwa̱, vi o kupotso ba.>>
\p 
\v 2 Ɗa ta na Hezekaya u za̱lika̱i a̱shi a̱ ni a tsusaki ɗa u yaꞋin kavasa a kubana u Vuzavaguɗu,
\v 3 ɗa u danai, <<Ciba, Vuzavaguɗu, tsu na n tonoi nu n uneki u ka̱ɗu koɓolo n ka̱ɗu ke te, ɗa kpamu n yaꞋin ili i singai a̱ a̱shi a̱ nu.>> Ɗa Hezekaya u shika̱i ka̱u.
\p 
\v 4 Ɗa kadanshi ka Vuzavaguɗu ka̱ ta̱wa̱i wi Ishaya.
\v 5 <<Bana vu dana Hezikaya va, <Na ɗa ili i na Vuzavaguɗu, Ka̱shile ke esheku a̱ ɗa̱ Dawuda, u danai. M pana ta̱ avasa a̱ nu m ma̱shi ma̱ nu. Adama a nannai mi ta̱ o kudoku wu a̱ya̱ gendu a wuma u nu.
\v 6 Mi ta̱ a kisa wu n likuci i Urushelima e kukiye ku mogono ma Asiriya, ka̱ta̱ kpamu mi inda likuci i nampa ya.
\p 
\v 7 << <Nava ɗaɗa urotu u Vuzavaguɗu a̱ kuta̱wa̱ nu, Vuzavaguɗu wi ta̱ a kuyaꞋan ili i nampa i na u yaꞋin uzuwakpani.
\v 8 Mi ta̱ a kuzuwa kululu ku kanna kubono n ka̱ca̱pa̱ ali adanga kupa, tsu na kagisamkpatsu ka kanna ko mogono Ahazu ki.> >> Ɗa kutashi ku kanna ku bonoi n ka̱ca̱pa̱ ali adanga kupa ta na.
\p 
\v 9 Ana Mogono Hezekaya u ta̱na̱i, ɗa u ɗanai vishipa vu ucikpi vu nampa.
\q1 
\v 10 N danai, <<A̱ ka̱tsuma̱ ka ayin a utsura u va̱
\q2 u yotso ta̱ m bana ubuta̱ wa̱ a̱kpisa̱ n utsura u va̱,
\q2 ali n namba a̱ya̱ a na a gaꞋin n yongo n wuma?>>
\q1 
\v 11 Ɗa n doku n danai, <<Mo kudoku me kene Vuzavaguɗu ba,
\q2 Vuzavaguɗu vu na wi a iɗika ya aza a wuma,
\q1 mpa mi o kudoku me kene uma
\q2 ko n yongo n ele vu na i punu a aduniyan a nampa ba.
\q1 
\v 12 A takpa ta̱ wuma u va̱ uteku tsu na a̱ tsu muɗa̱ ka̱pa̱m ka maguɓi.
\q2 Ɗa n ka̱ta̱la̱i wuma u va̱ uteku tsu kacaꞋi,
\q1 uteku tsu kacaꞋi kaꞋa vu ka̱ta̱la̱i wuma u va̱,
\q2 ɗa u gbatyai mu ɗe a uleɓengi,
\q2 ɗa kanna n kayin vi yawakai mu uteku.
\q1 
\v 13 M gbamai asuvu ali a kubana a usana,
\q2 ama uteku tsu kawu ɗa o koɗosoi etele a̱ va̱ ra̱ka̱,
\q2 ɗa kanna n kayin vi yawakai mu uteku.
\q1 
\v 14 N lapai una̱ tsu manunu,
\q2 ɗa kpamu n na̱mgba̱i ka̱tsuma̱ tsu moɗoi.
\q1 A̱shi a̱ va̱ o okpoi ga̱lu a ayin a na mi a kinda gaɗi.
\q2 Vuzavaguɗu, mi ta̱ a̱ ka̱tsuma̱ ka atakaci, ta̱wa̱ vu ɓa̱nka̱ mu.>>
\b
\q1 
\v 15 Ama yiɗa̱i n kudansa?
\q2 Adama a na a̱yi u yaꞋan ta̱ ɗe kadanshi nu mpa, a̱yi a̱ ka̱ci ka̱ ni feu u saꞋwa ta̱ ɗe kuyaꞋan ili i nampa.
\q1 Mi ta̱ a kuwala sawu a ayin a wuma u va̱ dem,
\q2 adama a̱ una̱mgbi u ka̱ɗu u va̱ u nampa.
\q1 
\v 16 Vuzavaguɗu, uneki wa atakaci u nu wi ta̱ n ugaꞋin,
\q2 adama a na u banka mu ta̱ a wuma u singai m ma̱ta̱na̱ kpamu.
\q1 Vu bonokoi mu m ma̱ta̱na̱
\q2 ɗa vu ka̱sukpa̱i mu n yongo n wuma.
\q1 
\v 17 Mayun,
\q2 adama a ugaꞋin u va̱ u ɗa n soꞋi atakaci tsu nampa.
\q1 N ucigi u nu ɗa vu foɓoi mu
\q2 adama a na m kpa̱ɗa̱ kuꞋuwa e kpenle ku munuka,
\q1 ɗa vu zuwakai unushi u va̱ dem
\q2 a̱ kucina̱ ku nu.
\q1 
\v 18 Adama a na ka̱kpisa̱ ka kucikpa wu ba,
\q2 ka̱kpisa̱ ka kuyaꞋanka wu vishipa vu kucikpa ba,
\q1 aza a na a uwai ɗe a̱ ubuta̱ wu ukpisa̱
\q2 a buwa e kukeɗe a̱pa̱ adama a uneki u ka̱ɗu u nu ba.
\q1 
\v 19 Vuza wuma ɗa koci wa kufuɗa wa cikpa wu,
\q2 tsu na mi a kuyaꞋan anana,
\q1 anan dada a tsu dana ta̱ muku n le
\q2 ukuna wu uneki u ka̱ɗu u nu.
\b
\q1 
\v 20 Vuzavaguɗu wi ta̱ a kisa mu,
\q2 ka̱ta̱ a̱ tsu ci canana ishipa koɓolo n umolu
\q1 a ayin a wuma u tsu dem
\q2 punu a̱ a̱Ꞌisa̱ a Vuzavaguɗu.
\p 
\v 21 Ishaya u dana ta̱, <<Foɓusoi maniꞋin ma maɗanga ma̱ ma̱biri ka̱ta̱ i tsungu a kamici ka, wi ta̱ a̱ kuta̱na̱.>>
\p 
\v 22 Ɗa Hezikaya we ecei, <<Yiɗa̱i i kokpo urotu u na mpa n kubana a̱ a̱Ꞌisa̱ a Vuzavaguɗu?>>
\c 39
\s1 Alingata a na a̱ uta̱i a Babila\x - \xo 39:0 \xt 2 Ng 20:12-19\x*
\p 
\v 1 A makyan ma nanlo Merodaka-balada maku ma Balada mogono ma Babila, u suꞋuki Hezikaya n akaka koɓolo n kuneꞋen, adama a na u pana ta̱ ukuna wu mɓa̱la̱ u ni n tsu na u potsoi.
\v 2 Ɗa Hezikaya u rabasai le m ma̱za̱nga̱, ali ɗa u yotsongi le ili i na yi punu o mpon n ni dem, azurufa a̱ ni, n azanariya a̱ ni, n ucanuku u wali u ni, m maniꞋin ma singai ma̱ ni, n ucanuku u kuvon u ni dem, koɓolo n ucanuku u na u buwai punu dem. Babu ili i na i buwai a kpaꞋa ku ni, n i na yi punu a̱ ubuta̱ u tsugono u ni ra̱ka̱, i na Hezikaya u kpa̱ɗa̱i kuyotsongu le.
\p 
\v 3 Ɗa Ishaya keneki u banai u mogono Hezikaya, ɗa we ecei, <<Yiɗa̱i uma a nanlo a danai, ko te ɗai a̱ uta̱i?>> Ɗa Hezikaya wu ushuki, <<A̱ uta̱ ta̱ a̱ likuci yi mɓa̱ri, ta ɗe a̱ uta̱i a Babila ɗa a̱ ta̱wa̱i wa̱ va̱.>>
\p 
\v 4 Ɗa u danai, <<Yiɗa̱i e enei a kpaꞋa ku nu?>> Ɗa Hezikaya wu ushuki, <<E ene ta̱ ili i na yi kpaꞋa ku va̱ ra̱ka̱. Babu ili i na i buwai punu o mpon n va̱ i na m kpa̱ɗa̱i kuyotsongu le.>>
\p 
\v 5 Ɗa Ishaya u danai Hezikaya, <<Pana kadanshi ka Vuzavaguɗu MalaꞋimili.
\v 6 Vuzavaguɗu u dana ta̱, mayun ayin i ta̱ lo a̱ kuta̱wa̱ a na ili i na yi punu dem a kpaꞋa ku nu, n i na isheku i nu i foɓoi ali a̱ kuta̱wa̱ anana, I ta̱ a̱ kupura̱ i ɗa ra̱ka̱ a banka i ɗika i Babila. Babu i na a̱ kuka̱sukpa̱.
\v 7 Ka̱ta̱ a ɗika muku n nu n yoku n na a matsakai nu a lazaka, i ta̱ o kubonoko le ndari e kefeku ko mogono ma Babila.>>
\v 8 Ɗa Hezikaya u danai Ishaya, <<Akaka a Vuzavaguɗu a na vu dansai na a gaꞋan ta̱.>> Adama a na a̱yi u sheshe ta̱, <<Ma̱ta̱na̱ n ida̱shi i ma̱ta̱na̱ yi ta̱ a kuyaꞋan a ayin a wuma u va̱.>>
\c 40
\s1 Odoki a kubana u uma a̱ Ka̱shile
\q1 
\v 1 Ka̱shile ka̱ ɗa̱ ka danai,
\q2 YaꞋan odoki, yaꞋankai uma a̱ ɗa̱ odoki
\q1 
\v 2 YaꞋankai Urushelima kadanshi n ka̱ɗu ida̱shi,
\q2 ka̱ta̱ vu dana yi
\q1 atakaci a̱ ni o kotso ta̱,
\q2 a cinukpaka yi ta̱ unushi u ni,
\q1 mayun Vuzavaguɗu u takacika yi ta̱
\q2 ali kure adama a unushi u ni ra̱ka̱.
\q1 
\v 3 Ka̱la̱ka̱tsu e meɗevile e meremune, <<Foɓusoi uye adama a Vuzavaguɗu, lapulai uye u gbayin a kakamba adama a̱ Ka̱shile ka̱ tsu.
\v 4 A̱ra̱ ra̱ka̱ a yaꞋan uciɗa̱ngi,
\q2 ka̱ta̱ kusan koɓolo m masasan a yaꞋan usa̱di,
\q1 ubuta̱ u na wi n yolu u bono derere,
\q2 ka̱ta̱ ubuta̱ u gbani-gbani u bono mayin.
\q1 
\v 5 Ka̱ta̱ tsugbayin tsu Vuzavaguɗu tsu uta̱ e keteshe,
\q2 ka̱ta̱ uma ra̱ka̱ e ene u ɗa,
\q1 adama na Vuzavaguɗu ɗa u dansai.>>
\b
\q1 
\v 6 Ka̱la̱ka̱tsu ka danai, <<Sala>>
\q2 Ɗa me ecei, <<Yiɗa̱i n kusala?>>
\b
\q1 <<Sala vu dana uma ra̱ka̱ i ta̱ tsu mita̱,
\q2 tsuloboi ci le kpamu ci ta̱ uteku tsu a̱pa̱lu a kakamba.
\q1 
\v 7 Mita̱ me ci ɗekpe ta̱, a̱pa̱lu kpamu o tsu ɗoɗo ta̱
\q2 a ayin a na baci ayinviki a Vuzavaguɗu a̱ uvula̱i le,
\q2 mayu uma mita̱ ma a.
\q1 
\v 8 Mita̱ me ci ɗekpe ta̱,
\q2 a̱pa̱lu kpamu o tsu ɗoɗo ta̱,
\q1 ama kadanshi ka̱ Ka̱shile ka̱ tsu ki ta̱ lo ko wanai.>>
\b
\q1 
\v 9 Avu vu na vu tsu tuka̱ n arabali a singai a Sihiyona,
\q2 Ɗa̱nga̱ vu kumba kusan ku ugaɗi,
\q1 Avu Sihiyona, avu na vu tsu tuka̱ n kadanshi ka singai.
\q2 Ɗengusa̱ ka̱la̱ka̱tsu ka̱ nu n utsura avu Urishelima,
\q1 ka̱ta̱ vu pana wovon ba,
\q2 dana likuci kakau ya aza a Yahuda,
\q2 <<Ka̱shile ka̱ ɗa̱ ka na.>>
\q1 
\v 10 La̱na̱i, Vuzavaguɗu MalaꞋimili wi ta̱ lo a̱ kuta̱wa̱ n utsura,
\q2 ka̱ta̱ u lyaꞋa tsugono n kukiye ku utsura ku ni, la̱na̱i,
\q1 wi ta̱ koɓolo n katsupu ka ni
\q2 a ayin a na baci u yawai.
\q1 
\v 11 Wi ta̱ a̱ kula̱na̱ ushiga u ni tsu maguɓi,
\q2 ka̱ta̱ u ɓolongu nlala a̱ ubuta̱ u ni,
\q1 u doku u ɗika le wo oɓongu,
\q2 ka̱ta̱ u guɓa aza a na i m muku sawu.
\b
\q1 
\v 12 Yayi u kufuɗa kugisangu mala n kataka ke kukiye ku ni,
\q2 ko ta na u gisangu a̱da̱nga̱shile n wanshi u kukiye u ni?
\q1 Yayi u saꞋwai kuɓa̱na̱ kubuta̱ ka aduniyan a mabana,
\q2 ko u gisangu a̱miki a nsansa
\q2 n aginda n kagisamkpatsu?
\q1 
\v 13 Yayi u kufuɗa kuyeve kusheshe ku Vuzavaguɗu,
\q2 ko ta na u neke yi kadanshi tsu vuza va odoki a̱ ni?
\q1 
\v 14 Yayi Vuzavaguɗu u cinakai adama a na u doku yi kuyeve?
\q2 Yayi vuza na u yotsongi ni uye u singai?
\q1 Yayi vuza na kpamu u yotsongi ni kuyeve,
\q2 ɗa kpamu u yotsongi ni uye u kufuɗa?
\b
\q1 
\v 15 Mayu aduniyan i ta̱ tsu uɗa̱kpi u mini o kogbodo ka̱ mini,
\q2 i ta̱ tsu uteku tsu kubuta̱ a kagisamkpatsu. U bonoko ta̱ otogu ra̱ka̱ adanshi kubuta̱ ku ɗa.
\q1 
\v 16 Nɗanga n Lebano n kuyawa kusongu a katalikalyuka ba,
\q2 ko ta na nnama n ni feu n yawa kuyaꞋanka kuneꞋe ku kusongu.
\q1 
\v 17 Uma a aduniyan dem wa̱ ni ili i ɗa i ba,
\q2 u kece le ba,
\q2 u bonoko le ili kpamu ba.
\b
\q1 
\v 18 N yayi va kugisanku n Ka̱shile?
\q2 N iyoci ye ne i ɗai va kugisanku yi?
\q1 
\v 19 Ka̱ma̱li vuma ɗa u yaꞋin ni,
\q2 ɗa kawakana ka kumai ni n azanariya,
\q2 ɗa u doku u ukai ni ikani ya azurufa.
\q1 
\v 20 Vuma vu unambi vu na wi n i na u kuyaꞋanka kuneꞋe ba,
\q2 u tsu zagba ta̱ maɗanga ma na ma tsu shama ba.
\q1 U tsu la̱nsa̱ ta̱ vuza na u yevei kusheꞋwe,
\q2 ka̱ta̱ u sheꞋweke yi ka̱ma̱li ka na ka tsu wala ba.
\b
\q1 
\v 21 Ka̱ta̱ vu yeve ba?
\q2 Ka̱ta̱ vu pana ba?
\q1 Ka̱ta̱ a saꞋwa kudana wu n ayin a̱ ugiti ba?
\q2 Ka̱ta̱ vu ciya̱ kuyeve ukuna u nampa ali kafu a yaꞋan aduniyan ba?
\q1 
\v 22 A̱yi ɗa vuza na wi ida̱shi gaɗi vi ɗika,
\q2 uma a̱ ni i ta̱ uteku tsa akyun,
\q1 ɗa u ba̱ra̱kpa̱i gaɗi tsu kafalaka,
\q2 ɗa u ba̱ra̱kpa̱i le uteku tsu ma̱va̱li ma na o ci yongo.
\q1 
\v 23 A̱yi ɗa vuza na u bonokoi ngono ukuna u gbani,
\q2 ɗa u bonokoi tsugono tsa aduniyan ili i yoku ba.
\q1 
\v 24 I ta̱ uteku tsu mita̱ mu wuti usavu,
\q2 a makyan ma na baci a̱ ca̱Ꞌi le
\q2 ma na mu uta̱i babu aralu a̱ ma̱riki.
\q1 Ayin a na baci Vuzavaguɗu u lapai wunla̱,
\q2 e ci ɗekpe ta̱ ka̱ta̱ o tono wunla̱i an kopo.
\b
\q1 
\v 25 Vuza ciɗa u danai,
\q2 <<N yayi a kugisanku mu, an mo kokpo uteku ci ni?>>
\q1 
\v 26 Ɗengusa̱i a̱shi a̱ ɗa̱ gaɗi ka̱ta̱ i la̱na̱.
\q2 Yayi u yaꞋin ili nampa ya?
\q1 U tsu uta̱ka̱ le vuza te vu te,
\q2 ka̱ta̱ u ɗeke yaba dem n kula ku ni,
\q1 adama a tsugbayin tsu utsura ci ni tsu na ci kugisanku ba,
\q2 babu vuza te vu na u nusai.
\b
\q1 
\v 27 Avu Yakubu,
\q2 <<Adama a̱ yiɗa̱i va kudana Vuzavaguɗu we ene ta̱ atakaci a̱ nu ba?
\q2 Uye u va̱ wi ta̱ usokongi a̱ a̱shi a Vuzavaguɗu, Avu Isaraila yi ɗa̱i i zuwai ɗa va kudana Ka̱shile ka iwan ta̱ kasingai ka̱ nu?>>
\q1 
\v 28 A̱ɗa̱ i yeve ba?
\q2 Ka̱ta̱ yi ishi i pana ba?
\q1 Vuzavaguɗu Ka̱shile ka kowanai kaꞋa.
\q2 Vuza na u yaꞋin aduniyan dem.
\q1 A̱yi utsura u ni u tsu jebe ba ko woꞋo,
\q2 kusheshe ku ni kpamu ki kuyeve ba.
\q1 
\v 29 U tsu neke ta̱ aza a woꞋi katsura,
\q2 ka̱ta̱ u doku aza a unambi wu utsura katsura.
\q1 
\v 30 Ko a̱ɗa̱nga̱ni a ci yaꞋan ta̱ ulinga ka̱ta̱ o oꞋwo,
\q2 olobo feu i ta̱ a̱ kuta̱ɗa̱tsa̱ ka̱ta̱ a̱ yikpa̱.
\q1 
\v 31 Ama aza na e nekei a̱ɗu e le u Vuzavaguɗu
\q2 i ta̱ a̱ kuciya̱ utsura u savu.
\q1 Ka̱ta̱ a imkpa gaɗi n evelyu tsu kajimba,
\q2 I ta̱ a kusuma ama o koꞋo ba.
\q2 I ta̱ a kuyaꞋan nwalu ama a̱ kulima̱ ba.
\c 41
\s1 Ka̱ɓa̱nki ka aza a Isaraila
\q1 
\v 1 Vuzavagɗu u danai, <<Paɗai bini ka̱ta̱ i panuka mu, a̱ɗa̱ iɗika i na yi ɗevu m mala.
\q2 YaꞋan uma o dokusu n utsura,
\q1 yaꞋan a̱ ta̱wa̱ ɗevu nu mpa ka̱ta̱ a dansa,
\q2 YaꞋan tsu ɓolongu ra̱ka̱ vu tsu adama a na ci sheshei kakuna.
\b
\q1 
\v 2 <<Yayi u kushangi mogono ma kasana ma nampa ma,
\q2 ali ɗa u zuwai u ciya̱i ulyaꞋi a̱ ubuta̱ u na u banai dem?
\q1 Yayi u nekei ni ulyaꞋi a̱ ubuta̱ wu ngono n iɗika i na i buwai,
\q2 kotokobi ka̱ ni ko bonokoi le tsu kubuta̱.
\q1 AyaꞋa a̱ ni a wacuwai le tsa awana o kutono wunla̱i.
\q1 
\v 3 U kiyangi le ɗa u walai babu atakaci,
\q2 a nwalu m moloko adanshi ene a̱ ni a kusaꞋwa iɗika ba.
\q1 
\v 4 Yayi u zuwai ili i nampa i yaꞋan?
\q2 Yayi u ɗekei tsumani ali n ayin a̱ ugiti?
\q1 Mpa Vuzavaguɗu n yongo ta̱ lo ali n ayin a̱ ugiti, Mpa Vuzavaguɗu mi ta̱ kpamu a kuyaꞋan lo
\q2 ali a kubana uteku.>>
\b
\q1 
\v 5 Aza a na i o kotogu e ene ta̱ ɗa kpamu a panai wovon,
\q2 likuci ya aduniyan ra̱ka̱ i jeꞋekei ikyamba.
\q1 Ɗa kpamu o ɓolongi ɗa yawai ɗevu.
\q2 
\v 6 Yaba dem u ɓa̱nka̱i vuza na wi ɗevu n a̱yi
\q2 n a danansanai, <<Gbama ka̱ɗu>>
\q1 
\v 7 KesheꞋwi ka̱ a̱ma̱li u tsu dana ta̱ kayimi ka azanariya, kya̱sa̱ wu n ulinga,
\q2 ka̱ta̱ vuza na u tsu lapula azanariya a yaꞋan mayin, u tsu dokusu ta̱ kpamu vuza na u tsu ɓolongu a ɗa dem,
\q1 ka̱ta̱ u dana, <<Ulinga wa u gaꞋan ta̱>>
\q2 ka̱ta̱ u vara kaꞋa n ikusa ta lo ka̱ yikpa̱.
\b
\q1 
\v 8 <<Ama avu Isaraila, avu ɗa kagbashi ka̱ va̱, Yakubu vuza na n zagbai, kumaci ki Ibirahi ka̱ja̱Ꞌa̱ ka̱ va̱,
\q1 
\v 9 Avu na n ɗikai na ɗe a uteku wa aduniyan,
\q2 na ɗe a̱ ubuta̱ u na u laꞋi n daꞋangi,
\q1 ɗa n danai, <Avu ɗa kagbashi ka̱ va.>
\q2 N zagba wu ta̱, mi ta na feu a kuvaruku wu ba.
\q1 
\v 10 Ka̱ta̱ vu pana wovon ba,
\q2 mi ta̱ koɓolo n avu, ka̱ta̱ kpamu ka̱ɗu ka̱ nu ka̱ muɗa̱ ba, adama a na mpa ɗa Ka̱shile ka̱ nu.
\q1 Mi ta̱ a kuzuwa wu vu tsurakpa ka̱ta̱ m ɓa̱nka̱ wu.
\q2 Mi ta̱ a̱ kuɗa̱ngusa̱ wu n kukiye ku usuɓi ku usingai ku va̱.
\b
\q1 
\v 11 <<Aza a na i a wupa n avu ra̱ka̱ mayun i ta̱ a kuyaꞋan wono,
\q2 ka̱ta̱ a̱ ciya̱ kugoyi. Aza na kpamu i a tsurala n avu,
\q2 i ta̱ o kokpo ukuna u gbani ka̱ta̱ a̱ kuwa̱.
\q1 
\v 12 Vi ta̱ a̱ kula̱nsa̱ irala i nu,
\q2 ama ve kene le ba.
\q1 Aza a na kpamu i o kuvon n avu
\q2 i ta̱ o kokpo ukuna u gbani.
\q1 
\v 13 Adama a na mpa ɗa Vuzavaguɗu Ka̱shile ka̱ nu,
\q2 vuza na u tsu ɓa̱na̱ kukiye ku usingai ku nu,
\q1 ɗa n danai nu, ka̱ta̱ vu pana wovon ba,
\q2 mi ta̱ a̱ kuɓa̱nka̱ wu.
\q1 
\v 14 Ka̱ta̱ vu pana wovon ba, avu Yakubu,
\q2 Isaraila vu kenu,
\q1 adama a na mpa mi ta̱ a̱ kuɓa̱nka̱ wu, Vuzavaguɗu u dansai
\q2 Kishi ka̱ ɗa̱ vuza ciɗa vi Isaraila.
\q1 
\v 15 <<La̱na̱i, mi ta̱ o kubonoko ɗa̱ tsa alangu a kulapu,
\q2 a na i usavu n utsura.
\q1 Yi ta̱ a kulapa nsasan ka̱ta̱ i ɓoso n ɗa,
\q2 ka̱ta̱ kpamu i sa̱ra̱ aginda o okpo kubuta̱.
\q1 
\v 16 Yi ta̱ e kuyelyukpe le ka̱ta̱ wunla̱i u pura̱ngu le,
\q2 ka̱ta̱ kabatalikpau ka̱ pura̱ngu le.
\q1 Ama a̱ɗa̱ yi ta̱ a kuyaꞋan ma̱za̱nga̱ u Vuzavaguɗu,
\q2 n tsugbayin tsu Vuza ciɗa vi Isaraila.
\b
\q1 
\v 17 <<A ayin a na baci aza a unambi n a̱ la̱nsa̱i i a̱ kula̱nsa̱ mini,
\q2 ɗa a nambai,
\q2 ali ɗa ogboroli e ɗekpei adama a kakuli,
\q1 Mpa, Vuzavaguɗu mi ta̱ a kushuku le.
\q1 Mpa, Ka̱shile ki Isaraila, mi a̱ kuka̱sukpa̱ le ba.
\q1 
\v 18 Mi ta̱ a kuzuwa nɗolu mu uta̱ ɗe a aginda,
\q2 ka̱ta̱ nyeneke tamkpamu mu uta̱ a̱ a̱ra̱Ꞌa̱.
\q1 Mi ta̱ o kubonoko kakamba kokpo kuyene,
\q2 ka̱ta̱ kpamu iɗika i ɗekpu yo okpo ka̱shi ka̱ mini.
\q1 
\v 19 Mi ta̱ a kuzuwa ɗe a kakamba
\q2 nɗanga n sida nu nɗanga ma akashiya, nu nɗanga m murti, koɓolo nu nɗanga n zaitu
\q1 mu uta̱ ɗe a agbata,
\q2 n nɗanga n safire koɓolo n Firi n dobino, ciya̱ o okpo kutsun,
\q1 
\v 20 i nampa yi ta̱ a kuyaꞋan adama a na uma e ene ka̱ta̱ e yeve,
\q2 o coꞋoko ka̱ta̱ e yevesheke
\q1 a na kukiye ku Vuzavaguɗu ku ɗa ku yaꞋin ili nampa ya,
\q2 Vuza ciɗa va aza a Isaraila ɗa u yaꞋin i ɗa.
\b
\q1 
\v 21 Mpa Vuzavaguɗu, mogono mi Isaraila n danai,
\q2 <<Tuka̱i m mawansa ma̱ ɗa̱ wa̱ va̱. Mogono ma Yakubu madanai.
\q1 
\v 22 <<Tuka̱i n a̱ma̱li a̱ ɗa̱ ka̱ta̱ a
\q2 dana tsu i na yi lo a̱ kuta̱wa̱.
\q1 Danai tsu tsu na ili i cau i yongoi,
\q2 ciya̱ ci ɗika i ɗa n a̱miki
\q2 ka̱ta̱ kpamu ci yeve ulinga u na i ɗa i yaꞋin,
\q1 ko i dana tsu i na i kuta̱wa̱.
\v 23 Danai tsu ili i na i kuta̱wa̱ na kelime,
\q2 adama a na ci yeve a na a̱ɗa̱ a̱ma̱li a ɗa yi.
\q1 YaꞋin ili i yoku, ko i singai ko i gbani-gbani,
\q2 adama a na ci yaꞋan mereve ali tsu pana wovon.
\q1 
\v 24 Ama a̱ɗa̱ i yawa biꞋi ili i yoku ba,
\q2 ulinga u ɗa̱ kpamu ɗa wi wasasa,
\q2 vuza na u zagbai ɗa̱ va wo okpo ta̱ ili yu unata.
\b
\q1 
\v 25 <<N zagba ta̱ ɗe vuza yoku a uɓon wa aza gaɗi, mi ta̱ a̱ kuta̱wa̱ n a̱yi,
\q2 adama a na u ta̱wa̱ n vishili a uɓon u gaɗi.
\q1 U kudasa ta̱ ngono ka̱ta̱ mo okpo adanshi ciꞋin tsu ɗa,
\q2 uteku u na kamaꞋi ka tsu dasa ciꞋin.
\q1 
\v 26 Yayi u dansai ili nampa ɗe ayin a̱ ugiti, adama na tsu yeve,
\q2 ko n ka mayun, adama na tsu dana, <Wi ta̱ n kamayun>?
\q2 Babu vuza na u dansai ili i nampa,
\q1 babu vuza na u dansai ka,
\q2 babu kpamu vuza na u panai kadanshi wa̱ nu.
\q1 
\v 27 Mpa ɗa ugiti u na n danai Sihiyona <la̱nuku, ele ɗa na a̱ kuta̱wa̱>
\q2 N neke ta̱ Urushelima kalingata ka arabali a singai.
\q1 
\v 28 Ɗa n la̱nuki punu a̱ ka̱tsuma̱ ke le, ama ko vuza te n ciya̱ ba,
\q2 babu vuza te a̱ ka̱tsuma̱ ke le vu na u kufuɗa kuneke odoki,
\q2 babu vuza na kpamu u kuneke wu ushuki ayin a na baci me ecei le.
\q1 
\v 29 La̱na̱, ra̱ka̱ vu le a uwa a ɗa,
\q2 ulinga u le, gbani ɗa.
\q2 A̱ma̱li a̱ ɗa̱ ra̱ka̱ ofoli a ɗa tsu wunla̱.
\c 42
\s1 Kagbashi ka Vuzavaguɗu
\p 
\v 1 <<Nava ɗaɗa kagbashi ka̱ va̱, vuza na n kumgbasai,
\q2 a̱yi ɗa vuza na mpa n zagbai, n vuza na ka̱ɗu ka̱ va̱ ka cigai.
\q1 N zuwa ta̱ ayinviki a̱ va̱ wa̱ ni.
\q2 Wi ta̱ a̱ kutuka̱ n kasingai a aduniyan.
\q1 
\v 2 Wi o ku orukpo ka̱u ba,
\q2 ko tana u ɗengusa̱ ka̱la̱ka̱tsu, ko kuta̱ e keteshe tsu na uma a pana ba.
\q1 
\v 3 Ko kososhi wi o kukoɗo ba,
\q2 wi tana feu a kukima̱ ma̱kuni ma na mi a kukima̱ ba.
\q1 N kamayun kaꞋa u kutuka̱ n kasingai,
\q2 
\v 4 a̱yi wi o koꞋo ba, ba le tana u na̱mgba̱ ka̱ɗu,
\q2 ali sai ayin a na u zuwai kasingai ka̱ ka̱ra̱Ꞌi aduniyan dem.
\q1 A̱ wila̱ u ni u ɗa aza o kotogu a kuzuwa a̱pa̱ e le.>>
\b
\q1 
\v 5 Na ɗa ili i na Ka̱shile Vuzavaguɗu u danai,
\q1 vuza na u yaꞋin gaɗi ɗa u ba̱ra̱kpa̱i i ɗa.
\q2 Vuza na u yaꞋin iɗika n i na yi punu a i ɗa,
\q1 a̱yi na u nekei uma ayinviki,
\q2 n wuma kpamu wa aza a na i punu a nwalu i ɗa.
\q1 
\v 6 <<Mpa ɗa Vuzavaguɗu, n ɗeke wu ta̱ adama a kasingai,
\q2 Mi ta̱ a kuɗika wu e ekiye a̱ va̱,
\q2 Mi ta̱ a̱ kuka̱na̱ wu ka̱ta̱ m bonoko wu
\q2 vo okpo uzuwukpani adama a uma
\q2 kutashi kpamu adama aza ka̱yimbi,
\q1 
\v 7 adama na vu ɓa̱yuwa̱ a̱shi a na i n uyimba̱,
\q2 ka̱ta̱ vu uta̱ka̱ n aza na i a kunu ku ugbashi
\q2 ka̱ta̱ kpamu mu uta̱ka̱ aza na i ida̱shi a̱ ka̱yimbi.
\b
\p 
\v 8 <<Mpa ɗa Vuzavaguɗu, ɗaɗa kula ku va̱,
\q2 Mpa n kuneke tsugbayin tsu va̱ u vuza ba,
\q2 ko n ka̱sukpa̱ ucikpi u va̱ a kubana a̱ ubuta̱ wa̱ a̱ma̱li.
\q1 
\v 9 La̱na̱i, ili i cau i ta̱wa̱ ta̱ ɗa i lazai ɗe,
\q2 gogo na ili i savu i ɗa mi a kudansa,
\q1 kafu i ɗa i yaꞋan
\q2 ɗa mi a kudana ɗa̱ i ɗa.>>
\s1 Vishipa vu cikpi u Vuzavaguɗu
\p 
\v 10 YaꞋankai Vuzavaguɗu vishipa vu savu,
\q2 yaꞋin vishipa va a̱ɗa̱ a aduniyan,
\q1 n a̱ɗa̱ vu na i tsu wala a mala, koɓolo n i na yi punu ra̱ka̱,
\q1 a̱ɗa̱ otogu n aza a na i ɗe ida̱shi.
\p 
\v 11 ka̱sukpa̱ aza a na i a̱ likuci dem m meremune ma̱ ni a̱ ɗengusa̱ a̱la̱ka̱tsu e le a cikpa yi,
\q2 ka̱sukpa̱ uma a̱ likuci i wawaꞋa i Kedaru a yaꞋan ishipa adama a̱ ni.
\q1 ka̱sukpa̱ uma a Sila a canana ishipa i ma̱za̱nga̱ a kubana wa̱ ni,
\q2 ka̱sukpa̱ le o orukpo ɗe a gaɗi vu nsansa a kubana wa̱ ni.
\q1 
\v 12 ka̱sukpa̱ le e neke Vuzavaguɗu tsugbayin,
\q2 ka̱ta̱ a sala ucikpi u ni o otogu.
\q1 
\v 13 Vuzavaguɗu u tsu bana ta̱ a̱ ubuta̱ u kuvon tsu kovonshi,
\q2 tsu kosoji tsu ɗa u tsu shilika̱ n utsura,
\q1 u ci yaꞋan ta̱ yoroli i kuvon,
\q2 ka̱ta̱ wu una irala i ni babu wovon.
\b
\q1 
\v 14 <<M megeshe m paɗa ta̱ bini,
\q2 m paɗa ta̱ bini ɗa m kpa̱ɗa̱i kukeɓece.
\q1 Ama gogo na uteku tsu vuka va a̱ga̱nda̱,
\q2 mo orukpoi, n inkai n yaꞋin yura̱.
\q1 
\v 15 Mi ta̱ a̱ kuka̱sukpa̱ nsansa n aginda a takacika,
\q2 ka̱ta̱ n ɗekpetengu ica̱Ꞌa̱shi i le ra̱ka̱,
\q1 ka̱ta̱ m bonoko nɗolu mo okpo iɗika i gbani,
\q2 ka̱ta̱ n ɗekpetengu adaɓa.
\q1 
\v 16 Mi ta̱ o kutono n a̱yimba̱ a uye u na e yevei ba,
\q2 n uye u na e yevei ba u ɗa mpa n kutono n ele,
\q1 ka̱ta̱ m bonoko ka̱yimbi kutashi a̱ a̱shi e le,
\q2 ka̱ta̱ kpamu n lapula ubuta̱ u gbani-gbani u gaꞋan.
\q1 Na ɗa ili i na n kuyaꞋanka le,
\q2 Mpa mi a kuka̱sukpa̱ le ba.
\q1 
\v 17 Ama aza a na e nekei a̱ɗu e le wa̱ a̱ma̱li,
\q2 aza a na a tsu dana ululu, <A̱ɗa̱ ɗa a̱ma̱li a̱ tsu>
\q1 i ta̱ o kokpo n wono.
\s1 A̱yimba̱ n Agulani a aza Isaraila
\q1 
\v 18 Vuzavaguɗu u danai, <<Panai, a̱ɗa̱ agulani,
\q2 la̱na̱i, a̱ɗa̱ a̱yimba̱, ka̱ta̱ ye ene.
\q1 
\v 19 Yayi wi ka̱yimba̱ tsu kagbashi ka̱ va̱,
\q2 ko wi kagulani uteku tsu kalingata ka na n suki?
\q1 Yayi kpamu wi ka̱yimba̱ tsu vuza na u nekei ka̱ci ka̱ ni wa̱ va̱,
\q2 ko wi ka̱yimba̱ tsu kagbashi ka Vuzavaguɗu?
\q1 
\v 20 Ye ene ta̱ ili n a̱bunda̱i, ama i coꞋoko ba,
\q2 atsuvu a̱ ɗa̱ i ta̱ uɓa̱yuwi, ama i pana ba.>>
\q1 
\v 21 Vuzavaguɗu we enei u gaꞋan yi ta̱
\q2 adama a usuɓi ka̱ ni,
\q1 u zuwa wila̱ u ni u tsurakpa koɓolo n tsugbayin.
\q1 
\v 22 Ama ele ɗa uma a na a̱ pura̱i gbani ɗa a yaꞋankai uboki,
\q2 ra̱ka̱ vi le ɗa a̱ ka̱na̱i e kpenle
\q2 ko yi usokongi a̱ ubuta̱ wu ugbashi,
\q1 okpo ta̱ ucanuku u kuvon,
\q2 n babu vuza na wa kisa le,
\q1 okpoi eremishi,
\q2 m babu vuza na wa kudana, <<Bonokoi le.>>
\b
\q1 
\v 23 Yayi a̱ ka̱tsuma̱ ka̱ ɗa̱ u kuzuwa atsuvu adama a ili i nampa,
\q2 ko u coꞋoko mayin adama a ayin a na a kuta̱wa̱?
\q1 
\v 24 Yayi u nekei kpaꞋa ku Yakubu ɗa a yaꞋankai ku ɗa uboki,
\q2 ko e nekei Isaraila e ekiye a aza a na a̱ pura̱i ili le gbani?
\q1 Ashe Vuzavaguɗu ɗa ba,
\q2 a̱yi ɗa vuza na tsu nusakai?
\q1 A̱yi ɗa vuza na tsu kpa̱ɗa̱i kutono uye u ni,
\q2 a̱yi ɗa vuza na tsu kpa̱ɗa̱i kushuku n wila̱ u ni?
\q1 
\v 25 Adama a nannai ɗa u tsunki le wupa u gbayin u ni,
\q2 n wupa u kuvon ku usuɗukpi.
\q1 U kambuki le akina, ama n nannai dem a fuɗa e yeve ba,
\q2 u songi le, ama o coꞋoko ba.
\c 43
\s1 Kishi ka aza Isaraila koci.
\q1 
\v 1 Ama gogo na, ili i na Vuzavaguɗu u dansai i ɗaɗa na,
\q2 a̱yi na u yaꞋin nu, avu Yakubu,
\q2 a̱yi na u ta̱wa̱i n avu, avu Isaraila.
\q1 <<Ka̱ta̱ vu pana wovon ba, adama a na mpa ɗa n shiba̱i ɗa̱, ɗa n ɗekei ɗa̱ yaba dem n kula kuni, a̱ɗa̱ uma a̱ va̱ a ɗa yi.
\q1 
\v 2 Ayin a na baci vu pasai kuyene,
\q2 mpa n kuyongo ta̱ koɓolo n avu,
\q1 ayin na baci kpamu vu pasai kuɗolu,
\q2 ma mi a kupura̱ wu ba.
\q1 I wala baci a̱ ka̱tsuma̱ ka akina,
\q2 yi a̱ kukula̱ ba,
\q2 nlentsu ma akina ma mo kusongu ɗa̱ ba.
\q1 
\v 3 Adama a na mpa ɗa Vuzavaguɗu, Ka̱shile ka̱ nu,
\q2 vuza Ciɗa vi Isaraila, Kishi ka̱ nu.
\q1 N neke ta̱ Masar adama a̱ wishi u nu,
\q2 Ɗa n sabaꞋi Itopiya n Sheba o okpoi una̱ u nu.
\q1 
\v 4 A na wo okpoi avu vi ta̱ n ugaꞋin n tsugbayin wa̱ va̱,
\q2 ɗa kpamu mpa n cigai nu,
\q1 mi ta̱ a kuneke uma kasabaꞋa a una̱ u nu,
\q2 koɓolo n uma a aduniyan adama kasabaꞋa n wuma u nu.
\q1 
\v 5 Ka̱ta̱ vu pana wovon ba, adama a na mpa mi ta̱ koɓolo n avu,
\q2 mi ta̱ a̱ kutuka̱ m muku n nu a uɓon u kasana,
\q1 ka̱ta̱ m ɓolongu ɗa̱ ɗe n uɓon u ka̱livi.
\q1 
\v 6 Ka̱ta̱ n dana aza a uɓon u gaɗi, <Ka̱sukpa̱i le>
\q2 aza ɗaka tamkpamu, <Ka̱ta̱ i bonoko le ba.>
\q1 Bonokoi Olobo a̱va̱ a na i daꞋangi,
\q2 ni nkere n va̱ n na mi a uteku wa aduniyan.
\q1 
\v 7 Yaba dem vu na e ɗekei n kula ku va̱,
\q2 vuza na n yaꞋin adama a tsugbayin tsu va̱,
\q1 vuza na n foɓusoi ɗa n tuka̱i.>>
\q1 
\v 8 Uta̱ka̱i n uma a na i n a̱shi ama a̱yimba̱ a ɗa,
\q2 n aza a na kpamu i n atsuvu ama agulani a ɗa.
\q1 
\v 9 Aduniyan ra̱ka̱ a gasai a̱ ubuta̱ u te,
\q2 ɗa uma o ɓolongi.
\q1 Yayi a̱ ka̱tsuma̱ ke le wa kufuɗa kudansa ukuna u nampa,
\q2 ka̱ta̱ u yotsongu tsu ili i cau?
\q1 YaꞋan a̱ tuka̱ nu nga n le ka̱ta̱ a dansa kaꞋa mayun adama e le,
\q2 adama a na uma o yoku a pana kaꞋa ka̱ta̱ feu a dana, mayun ɗa.
\q1 
\v 10 Ɗa Vuzavaguɗu u danai, <<A̱ɗa̱ nga n va̱,>>
\q2 <<A̱ɗa̱ kpamu agbashi a̱ va̱ a na n zagbai,
\q1 adama a na i yeve ka̱ta̱ i neke a̱ɗu wa̱ va̱,
\q2 ka̱ta̱ kpamu i coꞋoko a na mpa ɗa.
\q2 A saꞋwa kuciya̱ Ka̱shile ko yoku kafu mpa ba, i ta na feu a̱ kuciya̱ ko yoku na kelime ba.
\q1 
\v 11 Mpa, mpa ɗa Vuzavaguɗu,
\q2 kishi ko yoku ki lo ba.
\q1 
\v 12 Mpa Vuzavaguɗu n danai,
\q2 n yaꞋin uzuwakpani n kisa ɗa̱, ɗa ta na n ka̱na̱i uzuwakpani wa,
\q1 a̱ɗa̱ ɗa nga n va̱ n na n yevei an babu Ka̱shile ko yoku, ka na ka yaꞋin ili i nampa.
\q2 
\v 13 Mayun ɗa, ali n ayin a̱ ugiti sai a kubana ko wanai mpa ɗa Ka̱shile.
\q2 Babu vuza na u kufa̱ba̱na̱ vuma e ekiye a̱ va̱.
\q1 N yaꞋan baci ili yayi u kuyaꞋansuka i ɗa?>>
\s1 Ucigi u Ka̱shile a kubana wa aza Isaraila wi n uteku ba
\q1 
\v 14 Ili i na Vuzavaguɗu u dansai i ɗa na,
\q2 ka̱shibi ka̱ ɗa̱, Vuza Ciɗa vi Isaraila,
\q1 <<Adama a̱ ɗa̱ mi ta̱ a̱ kusuꞋuku Babila uma,
\q2 adama a na a una aza a Babila ra̱ka̱,
\q1 ciya̱ m bonoko yoroli i ma̱za̱nga̱ i le yo okpo ma̱shi.
\q1 
\v 15 Mpa ɗa Vuzavaguɗu, Vuza Ciɗa vu ɗa̱,
\q2 a̱yi na u yaꞋin aza a Isaraila, mogono ma̱ ɗa̱.>>
\b
\q1 
\v 16 Ili i na Vuzavaguɗu u danai i ɗaɗa na
\q2 a̱yi ɗa u yaꞋin uye a mala,
\q2 ɗa kpamu u ɓatsai uye e kuyene ku gbayin,
\q1 
\v 17 a̱yi vu na wu utuka̱i n ekeke o odoku koɓolo n odoku,
\q2 osoji koɓolo n ovonshi,
\q1 ɗa a vaki a iɗika ya a fuɗa ta na a̱ ɗa̱nga̱ ba,
\q2 a̱ kuwa̱i tsa akina a̱ ma̱kuni a na a̱ kimsa̱i.
\q1 
\v 18 <<Ama cinukpa n ili i cau,
\q2 ka̱ta̱ vu ciɓa n ili i kuku ba.
\q1 
\v 19 La̱na̱, mpa mi ta̱ a kuciga kuyaꞋan ili i savu,
\q2 Gogo na i ɗa yuta̱ ta̱, ka̱ta̱ ye ene i ɗa ba?
\q1 Mpa mi ta̱ a kuyaꞋan uye e meremune
\q2 n kuyene a iɗika yu ɗekpu
\q1 
\v 20 Nnama n kakamba ra̱ka̱ mi ta̱ a kucikpa mu,
\q2 nsheꞋe n kakamba koɓolo n a̱da̱la̱ dem,
\q1 adama a na n neke le ta̱ mini e meremune, ka̱ta̱ kpamu n ta̱sa̱
\q2 nyeneke a iɗika i ɗekpu,
\q1 n neke uma a na n zagbai mini mo kusoꞋo,
\q2 
\v 21 uma a na n yaꞋin adama a̱ ka̱ci ka̱ va̱
\q2 adama a na a sala ucikpi u va̱ e keteshe.
\b
\q1 
\v 22 <<Ama Yakubu, mpa ɗa vuza na vu cikpai ba,
\q2 avu oꞋuso ka̱ci ka̱ nu adama a̱ va̱ ba, avu Isaraila.
\q1 
\v 23 I tuka̱ mu m mokyon adama e kuneꞋe ku kusongu ba,
\q2 ko kpamu i cikpa mu n alyuka a̱ ɗa̱ ba.
\q1 Mpa n takacika ɗa̱ n adama e kuneꞋe ki ili i kashina ba,
\q2 n damusa ɗa̱ kpamu adama a ili i ma̱gula̱ni ba.
\q1 
\v 24 A̱ɗa̱ i tuka̱ n ili i ma̱gula̱ni yi uyo wa̱ va̱ ba,
\q2 ko i neke mu ushuma wa alyuka u ɗa̱ ba.
\q1 Ama ɗa yi a kutakacika mu nu unushi u ɗa̱,
\q2 ɗa kpamu yi o ko oꞋuso mu n kawuya ka̱ ɗa̱.
\b
\q1 
\v 25 <<Mpa, mpa ɗa, vuza na u takpai
\q2 ugbamukaci u ɗa̱, adama a ka̱ci ka̱ va̱,
\q2 ɗa n cinukpai n unushi u ɗa̱ ra̱ka̱-ra̱ka̱.
\q1 
\v 26 Ciɓakai mu n ili i gbani-gbani i na n yaꞋankai ɗa̱,
\q2 yaꞋan ci yaꞋin kanananai ka kadanshi ka koɓolo,
\q2 dansai e keteshe ukuna wu unushi u ɗa̱ wa.
\q1 
\v 27 Ikaya i ɗa̱ yu ugiti i nusa ta̱,
\q2 ɗa kpamu aza kelime a̱ ɗa̱ a yaꞋankai mu ugbamukaci.
\q1 
\v 28 Adama a nannai mpa n kuneke ta̱ tsugbayin tsa̱ a̱Ꞌisa̱ wono,
\q2 ɗa n nekei Yakubu adama munuka
\q2 aza Isaraila kpamu adama ishikushi.
\c 44
\s1 Isaraila aza a na Vuzavaguɗu u zagbai
\q1 
\v 1 <<Ama gogo na pana, avu Yakubu kagbashi ka̱ va̱,
\q2 Isaraila, avu na n zagbai.
\q1 
\v 2 Na ɗa i na Vuzavaguɗu u dansai,
\q2 a̱yi vuza na u yaꞋin nu, a̱yi na u zuwai nu a̱ ka̱tsuma̱,
\q2 a̱yi ɗa kpamu vuza na u ku ɓa̱nka̱ wu.
\q1 Ka̱ta̱ vu pana wovon ba, avu Yakubu kagbashi ka̱ va̱,
\q2 Jeshuru, avu na n zagbai.
\q1 
\v 3 Adama na mi ta̱ o kuyoꞋo mini a iɗika i ɗekpu,
\q2 ka̱ta̱ kpamu n zuwa nyeneke a iɗika yu ɗekpu.
\q1 Ka̱ta̱ mpa n zuwa ayinviki a̱ va̱ u muku n nu, una̱singai u va̱ kpamu u tsukaya tsu nu.
\q1 
\v 4 I ta̱ a̱ kuta̱ uteku tsu mita̱ a maɗanga a̱ ka̱kina̱ ka mini,
\q2 uteku tsu maɗanga o kuɗolu ku na ki e kuyene.
\q1 
\v 5 Vuza yoku wi ta̱ a kudana n utsura, a̱yi vuma vu Vuzavaguɗu ɗa,
\q2 vuza yoku kpamu ka̱ta̱ u ɗeke ka̱ci ka̱ ni n kula ku Yakubu,
\q1 ka̱ta̱ kpamu vuza yoku u ɗana e kukiye ku ni, <Mpa vuza vu Vuzavaguɗu vu ɗa.>
\q2 Ka̱ta̱ kpamu u ɗika kula ki Isaraila adanshi ku ni ku ɗa.>>
\s1 Vuzavaguɗu ka̱ma̱li ka ba
\q1 
\v 6 <<Ili i na Vuzavaguɗu u danai i ɗaɗa na,
\q1 mogono ma aza a Isaraila n vuza na u kushiba̱ uma, Vuzavaguɗu vo osoji a gaɗi. Mpa ɗa ugiti n ukocishi,
\q2 Ka̱shile ko yoku ki lo ba, sai mpa.
\q1 
\v 7 Yayi wi lo tsu va̱?
\q2 YaꞋan wu uta̱ u dansa,
\q1 yaꞋan u dansa ka̱ta̱ wu uta̱ka̱ mu i ɗa e keteshe. U dana mu tsu na a yaꞋin ɗa n yaꞋin uma a cau
\q2 koɓolo n i na i kuta̱wa̱,
\q2 mayu yaꞋan u dana mu ili i na i kuta̱wa̱.
\q1 
\v 8 Ka̱ta̱ i jeꞋeke ikyamba ba,
\q2 ka̱ta̱ kpamu i pana wovon ba. N saꞋwa kudansa ukuna u nampa ali ɗa n yaꞋin kene m megeshe ma ɗe adama a u ɗa ba?
\q1 A̱ɗa̱ ɗa ngan n va̱. Ka̱shile ko yoku ki ta̱ lo, m ba mpa ba?
\q2 Babu kakpanlai ko yoku, mpa n yeve ko yoku ba.>>
\b
\q1 
\v 9 Aza a na a yaꞋin a̱ma̱li dem ukuna u gbani u ɗa,
\q2 ili i na kpamu a zuwakai katsura ya kuyaꞋan le ili ba.
\q1 Ele vu na a gaꞋin a yaꞋanka le kadanshi a̱yimba̱ a ɗa,
\q2 i ta̱ kpamu n tsulau ɗa okpoi n wono.
\q1 
\v 10 Yayi u sheꞋwei ka̱ma̱li ko u luwa̱i kululu
\q2 ku na ki e kuneke yi ili ba?
\q1 
\v 11 N dana ɗa̱,
\q2 a̱yi n aza a̱ ni ra̱ka̱ i ta̱ a kuyaꞋan wono, ayimi a ili uma ɗa.
\q1 YaꞋan ra̱ka̱ vi le a gasa ka̱ta̱ a zagba i na i kuta̱ka̱ le.
\q2 I ta̱ a kupana wovon, ka̱ta̱ ra̱ka̱ vi le a yaꞋan wono.
\b
\q1 
\v 12 Kawakana ka tsu ɗika ta̱ ucanuku wu ulinga,
\q2 ka̱ta̱ u zuwa a kina u yuma ili.
\q1 U tsu yima ta̱ ili ya m matalaka u ka̱na̱ kugbasha
\q2 i ɗa n utsura.
\q1 Kambulu ka̱ ka̱na̱ yi baci u tsu okpo ta̱ babu utsura,
\q2 kakuli ka̱ ka̱na̱ yi baci feu u tsu lima̱ ta̱.
\q1 
\v 13 KesheꞋwi ka tsu gisanku ta̱ maɗanga
\q2 ka̱ta̱ u zuwaka maꞋa urotu n ili yu ulinga i ni,
\q1 ka̱ta̱ u sheꞋwe kaꞋa
\q2 ali kokpo an vuma vu singai.
\q1 U yaꞋan yi tsu na a kuzuwa yi a kpaꞋa.
\q1 
\v 14 U tsu kapa ta̱ nɗanga n sida,
\q2 ko kpamu u zagba nɗanga n sipuru ko maɗanga ma oku
\q1 ka̱ta̱ u ka̱sukpa̱ maꞋa mo gbonguro koɓolo nu nɗanga n kuntsu,
\q2 ko u ca̱Ꞌa̱ nɗanga n sida ka̱ta̱ mini ma̱ Ka̱shile ma zuwa n ɗa m gbonguro.
\q1 
\v 15 N tso okpo ta̱ ili i kutasuku akina i vuma,
\q2 u tsu kenuku ta̱ n yoku u tasuku akina a na u kunyashika,
\q2 U tsu tasuku ta̱ akina a ka̱ta̱ u kangala boroji.
\q1 Ka̱ta̱ kpamu u sheꞋwe ka̱ma̱li ka na u kucikpa,
\q2 u bonoko kaꞋa ka̱ma̱li ka̱ta̱ u kuɗa̱nku kaꞋa.
\q1 
\v 16 Ka̱ta̱ u songu kagimi ka maɗanga ka a akina,
\q2 adama a na u zungu inyama
\q1 Ka̱ta̱ u doku u nyashika. Ka̱ta̱ u dana,
\q2 <<Kai, akina a nampa yokpo ta̱.>>
\q1 
\v 17 Ka̱ta̱ kagimi ka maɗanga ka na ka buwai u bonoko kaꞋa ka̱ma̱li, ka̱ma̱li ka̱ ka̱ci ka̱ ni,
\q2 u tsu kuɗa̱nku ta̱ kaꞋa ka̱ta̱ u cikpa kaꞋa.
\q1 U tsu bana ta̱ u vasa ɗe ka̱ta̱ u dana,
\q2 <<Isa mu, avu ɗa ka̱ma̱li ka̱ va̱.>>
\q1 
\v 18 E yeve ili ba, a fuɗa kpamu ukuna ba,
\q2 adama a na a̱shi e le i ta̱ upali ɗa a̱ kpa̱ɗa̱i kufuɗa kene
\q1 a̱ɗu e le dem a kufuɗa kuyeve ba.
\q1 
\v 19 Babu vuza na u coꞋokoi adama a na u sheshe,
\q2 babu kpamu vuza na wi n kuyeve ko kufuɗa ku na u kudana,
\q2 <<N yaꞋan ta̱ ulinga n kagimi ɗa n songi a akina
\q1 ali ɗa n kangalai boroji vu va̱ n tsikina ci ni
\q2 ɗa kpamu n zungi inyama n takumai.
\q1 Nini ɗai n kubonoko kagimi ka ili yu unata?
\q2 Kucikpa n kuɗa̱ngu n cikpa kogboli?>>
\q1 
\v 20 Kokomo kaꞋa u tsu lyaꞋa, ka̱ɗu ka gbani-gbani ka̱ ni ka vakangi ni,
\q2 adama a nannai wi a kufuɗa kisa ka̱ci ka̱ ni ba, ko u fuɗa u dana,
\q1 <<Ili i na n ka̱na̱i e kukiye ku singai ku va̱ ka aꞋuwa ɗa ba?>>
\b
\q1 
\v 21 Ciɓa n ukuna u nampa, avu Yakubu koɓolo n Isaraila,
\q2 adama na avu ɗa kagbashi ka̱ va̱.
\q1 Mpa ɗa n yaꞋin nu, avu ɗa kagbashi ka̱ va̱.
\q2 Avu Isaraila, mpa mi a kucinukpa n avu ba.
\q1 
\v 22 Mpa n takpa ta̱ una̱mgbi u nu ce eleshu,
\q2 ɗa kpamu n takpai unushi u nu ce egele a usana.
\q1 Bono wa̱ va̱,
\q2 adama a na mpa n shiba̱ wu ta̱ ɗe.>>
\b
\q1 
\v 23 Gaɗi, cananai ishipa i ma̱za̱nga̱,
\q2 dama a na Vuzavaguɗu ɗa u
\q1 yaꞋin ili i nampa ya, orukpoi ka̱u,
\q2 a̱ɗa̱ ɗaka vi iɗika.
\q1 Ɓosongi ishipa, a̱ɗa̱ nsasan,
\q2 koɓolo nu nɗanga n kutsun dem n na mi punu,
\q1 adama a na Vuzavaguɗu u shiba̱ ta̱ Yakubu,
\q2 ka̱ta̱ aza a Isaraila a cikpa yi.
\s1 Urushelima ɗa ubuta̱ wi ida̱shi u va̱
\q1 
\v 24 Ili i na Vuzavaguɗu u danai i ɗaɗa na,
\q2 ka̱shibi ka̱ nu, a̱yi na u yaꞋin nu avu a̱ ka̱tsuma̱.
\b
\q1 <<Mpa ɗa Vuzavaguɗu,
\q2 vuza na u yaꞋin ili ra̱ka̱,
\q1 vuza na kpamu endeꞋen u ba̱rukpa̱i gaɗi,
\q2 ɗa kpamu u poloi iɗika n ka̱ci ka̱ ni babu ka̱ɓa̱nki,
\q1 
\v 25 <<Mpa ɗa m bonokoi nlum ma aꞋuwa ukuna u gbani,
\q2 eneki kpamu okpoi alau.
\q1 Vuza na u tsu bonoko eyevi ka̱ca̱pa̱
\q2 ka̱ta̱ u zuwa kuyeve ku le kokpo tsulau,
\q1 
\v 26 a̱yi na u tsu shatangu kadanshi ka kagbashi ka̱ ni,
\q2 ka̱ta̱ kpamu u shatangu ukuna u na alingata a dansai,
\q1 <<ele na a danai aza a Urishelima, <Uma i ta̱ o kubono n ida̱shi punu na kpamu>
\q2 Iɗika i Yahuda tamkpamu, <I ta̱ a̱ kudoku kumaꞋasaka wu,
\q1 ka̱ta̱ n ɗengusa̱ agali a̱ nu dem>
\q1 
\v 27 vuza na u danai mala mu uga̱vi, <Ɗekpe,
\q2 ka̱ta̱ kpamu n ɗekpetengu nyeneke n ɗa̱>
\q1 
\v 28 Vuza na u danai Sairusu, <A̱yi ɗa maguɓi ma̱ va̱,
\q2 wi kpamu a kushatangu kusheshe ku va̱ ra̱ka̱,
\q1 wi ta̱ a kudana Urishelima, <<YaꞋan o doku a maꞋasaka yi,>>
\q2 ukuna wa̱ a̱Ꞌisa̱ tamkpamu, <<YaꞋan a vara kumaꞋa ku ni.>>>
\c 45
\s1 Sairusu ili yu ulinga i Ka̱shile.
\q1 
\v 1 I na Vuzavaguɗu u danai Mazagbi ma̱ ni i ɗaɗa na,
\q2 a̱yi Sairusu, vuza na n ka̱na̱i kukiye ku usingai ku ni adama a na
\q1 u lyaꞋa aduniyan n kuvon,
\q2 ka̱ta̱ u takpa utsura wu ngono,
\q1 ka̱ta̱ a̱ ɓa̱yuwa̱ka̱ yi utsutsu u na babu vuza na u
\q2 kuɓa̱ya̱ngu u ɗa.
\q1 
\v 2 <<Mpa n kulaza ta̱ kelime ka̱ nu
\q2 ka̱ta̱ n sa̱ra̱ nsasan,
\q1 n fa̱da̱ kpamu utsutsu u na a yaꞋin n iyum i shili,
\q2 ka̱ta̱ m gbatya aburakpatsu a̱ iyum miri-miri.
\q1 
\v 3 Mpa n kuneke wu ta̱ kawalatsu,
\q2 n uciyi u na wi a̱ ubuta̱ wu usokongi,
\q1 adama na vi yeve a na mpa ɗa Vuzavaguɗu,
\q2 Ka̱shile ki Isaraila, vuza na u ɗekei nu n kula ku nu.
\q1 
\v 4 <<Adama a kagbashi ka̱ va̱ Yakubu,
\q2 n Isaraila vuza na n zagbai,
\q1 n ɗeke wu ta̱ n kula ku nu,
\q2 ɗa n neꞋi nu kula ku tsugbayin,
\q2 ko a na vi yevei mu ba.
\q1 
\v 5 Mpa ɗa Vuzavaguɗu, vuza yoku wi lo kpamu ba,
\q2 Ka̱shile ki lo ba sai mpa koci,
\q1 n neke wu ta̱ katsura,
\q2 ko a na vi yeve mu ba,
\q1 
\v 6 adama a na uma e yeve,
\q2 a ili i na i ɗikai a kasana ali a kubana a̱ ka̱livi,
\q1 vuza yoku wi lo ba sai mpa.
\q2 Mpa ɗa Vuzavaguɗu, vuza yoku wi lo kpamu ba.
\q1 
\v 7 Mpa ɗa n yaꞋin kutashi ɗa kpamu n yaꞋin ka̱yimbi,
\q2 mpa ɗa n yaꞋin kasingai n kawuya,
\q1 Mpa ɗa Vuzavaguɗu, vuza na u yaꞋin ili i nampa ra̱ka̱.
\b
\q1 
\v 8 <<Avu gaɗi, yaꞋan ukuna u kasingai,
\q2 yaꞋan eleshu a̱ tuka̱ n kaꞋa a iɗika.
\q1 YaꞋan iɗika i ɓa̱yuwa̱ n wanshi,
\q2 adama a na wishi u yimkpa,
\q1 yaꞋan usuɓi u gbonguro n kaꞋa,
\q2 mpa Vuzavaguɗu ɗa n yaꞋin i ɗa.
\b
\q1 
\v 9 <<Ili ya atakaci i ɗa u vuza na u shamgbai a kanananai n vuza na u yaꞋin ni,
\q2 Ili ya atakaci i ɗa mogbodo ma na ma yaꞋan kanananai n kamaꞋi ka̱ ni,
\q1 ko ciꞋin ci ta̱ kece kamaꞋi,
\q2 <Yiɗa̱i vi a kuyaꞋan?>
\q1 Ko kpamu avu vi yeve,
\q2 ulinga u nu ba?>
\q1 
\v 10 Ili ya atakaci i ɗa u vuza na u kudana esheku a̱ ni,
\q2 <Yiɗa̱i i zuwai ɗa vu matsai mu?>
\q1 Ko u dana a̱na̱ku a̱ ni,
\q2 yiɗa̱i vu matsai?>
\b
\q1 
\v 11 <<Ili i na Vuzavaguɗu u danai i ɗaɗa na,
\q2 Vuza Ciɗa vi Isaraila, n vuza na kpamu u yaꞋin ni,
\q1 ka̱ta̱ ve ece mu ukuna wi ili i na yi lo a̱ kuta̱wa̱, adama a̱ ukuna wu muku n va̱ ba,
\q2 ko kpamu vu dana mu ili i na i gaꞋin n yaꞋan?
\q1 
\v 12 Mpa ɗa n yaꞋin aduniyan,
\q2 ɗa n yaꞋin kpamu vuma punu.
\q1 N ekiye a̱ va̱ a ɗa n yaꞋin gaɗi,
\q2 ɗa kpamu n zuwai ili i na yi ɗe va dem.
\q1 
\v 13 Vuzavaguɗu MalaꞋimili u danai, Mpa n kuɗa̱ngusa̱ ta̱ Sairusu adama a na u shatangu ulinga u kasingai u va̱,
\q2 mi ta̱ a kuzuwa nwalu n ni ra̱ka̱ n yaꞋan derere.
\q1 Wi ta̱ a kumaꞋasaka likuci i va̱
\q2 ka̱ta̱ u shikpa agbashi a̱ va̱,
\q1 u kuyaꞋan nannai va adama ikebe ko n katsupu ko yoku ba,
\q2 i ɗaɗa i na Vuzavaguɗu malyaimili u danai>>
\q1 
\v 14 Ili i na Vuzavaguɗu u danai i ɗa na,
\q1 <<Uciyi wa aza a Masar n aza a tsulaga a Kush,
\q2 koɓolo n wa aza a uɓon u gaɗi,
\q1 koɓolo n uma a ugaɗi a Sabina
\q2 i ta̱ a̱ kuta̱wa̱ wa̱ ɗa̱ ra̱ka̱
\q1 ka̱ta̱ okpo aza a̱ ɗa̱.
\q2 I ta̱ a̱ kuta̱wa̱ koɓolo n aza a tsulaga e le ra̱ka̱,
\q1 ka̱ta̱ o tono ɗa̱ kucina̱,
\q2 ushiyi n ikani i tsugbashi.
\q1 I ta̱ a̱ kukuɗa̱nku ɗa̱
\q2 ka̱ta̱ o folono ɗa̱ a̱ ka̱na̱ kudana,
\q1 <Mayun Ka̱shile ki ta̱ koɓolo n a̱ɗa̱, babu kpamu vuza yoku,
\q2 Ka̱shile ko yoku ki lo ba.> >>
\b
\q1 
\v 15 Mayun, avu Ka̱shile kaꞋa ka na ko tsu sokongu ka̱ci ka̱ ni,
\q2 avu Ka̱shile ki Isaraila n Kishi.
\q1 
\v 16 A yaꞋin a̱ a̱ma̱li ra̱ka̱ i ta̱ a kuyaꞋan wono, ka̱ta̱ o okpo n kugoyi,
\q2 i ta̱ a̱ kuyikpa̱ o wono ra̱ka̱.
\q1 
\v 17 Ama aza a Isaraila i ta̱ a̱ kuciya̱ wishi a̱ ubuta̱ u Vuzavaguɗu
\q2 n wishi babu kukotso,
\q1 a̱ɗa̱ ya kuyaꞋan wono ba,
\q2 ko ta na i ciya̱ kugoyi ku na ka̱ kukpa̱ɗa̱ kukotso.
\b
\q1 
\v 18 Ili i na Vuzavaguɗu u danai i ɗa na,
\q1 a̱yi na u yaꞋin gaɗi,
\q2 a̱yi ɗa Ka̱shile.
\q1 A̱yi ɗa u foɓusoi tsu na u kuyaꞋan aduniyan,
\q1 a̱yi ɗa u yaꞋin a ɗa,
\q1 u yaꞋan a ɗa tsu na a ɗa o kokpo lekeɗi ba,
\q2 ama u yaꞋin a ɗa adama a na uma o yongo punu.
\q1 Ɗa u danai,
\q1 <<Mpa ɗa Vuzavagɗu
\q2 vuza yoku wi lo kpamu ba.
\q1 
\v 19 N yaꞋan kadanshi ka̱ va̱ usokongi
\q2 a̱ ubuta̱ u ka̱yimbi ba.
\q1 Mpa mi ishi a kudana ntsukaya n Yakubu,
\q2 <Ka̱ta̱ i la̱nsa̱ mu gbani ba, ishi baci a̱ kuciya̱ mu ba,
\q1 Mpa Vuzavaguɗu n tsu dansa ta̱ ili i na yi i mayun,
\q2 ka̱ta̱ kpamu n sala ukuna u na wi derere.
\b
\q1 
\v 20 <<Ɓolongi ka̱ci ka̱ ɗa̱ ka̱ta̱ i ta̱wa̱,
\q2 yawai ɗevu, a̱ɗa̱ vu na i laꞋakai n wuma a aduniyan.
\q1 Umici u ɗa wi o kuforo aza a na a ci ɗika a̱ma̱li a na a yaꞋin nu nɗanga a̱ kuka̱ra̱ka̱,
\q2 ele vu na a tsu vasa u ka̱ma̱li ka na ka ci isa vuza ba.
\q1 
\v 21 Dansai ili i na yi lo, tuka̱i n ukuna wa,
\q2 yaꞋan o goɗumo u ɗa koɓolo.
\q1 Yayi u yaꞋin kene adama a ukuna u nampa n ayin a cau a ɗe,
\q2 yayi u dansai kaꞋa m megeshe ma ɗe?
\q1 Mpa ɗa ba, mpa Vuzavaguɗu?
\q2 Babu Ka̱shile ko yoku ka na ki lo,
\q1 Ka̱shile ku usuɓi n Kishi,
\q2 vuza yoku wi lo ba sai mpa koci.
\b
\q1 
\v 22 <<Bonoi wa̱ va̱ ka̱ta̱ i ciya̱ wishi,
\q2 a̱ɗa̱ vu na yi dadaꞋin dem a aduniyan.
\q2 Adama a na mpa ɗa Ka̱shile, vuza yoku wi lo kpamu ba.
\q1 
\v 23 N kucuna ta̱ n kula ku va̱,
\q2 n dansa ta̱ ukuna u mayun,
\q2 mi o kubono ma̱ sa̱da̱kpa̱ kadanshi ka nanlo ba.
\q1 A̱ka̱nga̱tsu dem i ta̱ a̱ kukuɗa̱nku mu,
\q2 kelentsu ka yaba dem ki ta̱ a kudansa ukuna u singai.
\q1 
\v 24 I ta̱ a kudana adama a̱ va̱,
\q2 <Usuɓi n utsura u Vuzavaguɗu u ɗa wi koci.> >>
\q1 Aza a na a yaꞋin wupa n a̱yi
\q2 i ta̱ a̱ kubana wa̱ ni ra̱ka̱ ka̱ta̱ okpo n wono.
\q1 
\v 25 Ama u Vuzavaguɗu u ɗa ntsukaya mi Isaraila ra̱ka̱
\q2 n kuciya̱ kasingai koɓolo n tsugbayin.
\c 46
\s1 A̱ma̱li aza a Babila
\q1 
\v 1 A̱ma̱li a aza a Babila a na e ci ɗeke Belu n Nebo a̱ ciya̱ ta̱ ugoyi ka̱u,
\q2 a canuku ta̱ ululu e le a̱ ka̱na̱i kuka̱ra̱ka̱ a ɗa.
\q1 Gogo na i ta̱ a gaɗi vu nnama n na n tsu canuku ucanuku
\q2 nnama n nampa mo oꞋwo ta̱ adama a ucanuku u ululu u na a ɗikai va.
\q1 
\v 2 A̱ma̱li a a̱ ciya̱i kugoyi ɗa a kuɗa̱ngi koɓolo n aza a na a ɗikai le,
\q2 a fuɗa ta na a̱ ɓa̱nka̱ a̱miki a ba,
\q2 ɗa a ɗikai dem vi le a kubana a̱ ubuta̱ wu ugbashi.
\q1 
\v 3 <<Panakai mu, a̱ɗa̱ aza a Yakubu,
\q2 a̱ɗa̱ vu na i buwai dem a̱ ka̱tsuma ka kpaꞋa ki Isaraila.
\q1 A̱ɗa̱ vu na n la̱na̱i kafu a matsa ɗa̱, ɗa n ɗengusa̱i ɗa̱
\q2 ali n ayin a na a matsai ɗa̱.
\q1 
\v 4 Ali n ayin a tsukutsa a̱ ɗa̱
\q2 Mpa ɗa a̱yi, ali a kubana a ayin a na i kuta̱ ka̱nji ka̱ri, mi ta̱ a kuɗika utsura u ɗa̱.
\q1 Mpa ɗa n yaꞋin ɗa̱ mi ta̱ a̱ kula̱na̱ ɗa̱,
\q2 mi ta̱ a kinda ɗa̱ ka̱ta̱ mi isa ɗa̱.
\q1 
\v 5 <<N yayi ya kugisangu mu, ka̱ta̱ i ɗika ci ta̱ derere?
\q2 N yayi kpamu ci yotsonoi, ali ɗa i kugisanku tsu?
\q1 
\v 6 Aza o yoku a̱ ɓa̱yuwa̱i nsolo n le ɗa i ugulani n azanariya,
\q2 a tsu gisanku ta̱ azurufa e le a̱ ka̱kunzukpa̱tsu,
\q1 ele ɗa a tsu ɗika kayimi ka azanariya ka̱ta̱ u bonoko a ɗa ka̱ma̱li,
\q2 ka̱ta̱ a̱ kuɗa̱nku kaꞋa ali sai iɗika a cikpa yi.
\q1 
\v 7 A ci ɗika ta̱ kaꞋa a avangatsu e le a̱ kuka̱ra̱ka̱,
\q2 a zuwa baci kaꞋa ta lo ka ci shamgba
\q2 ka tsu wala ba.
\q1 Ka̱ tsu zumgba̱ ba, ko a vasa baci wa̱ ni u tsu ushuku ba.
\q2 Ka̱ tsu uta̱ka̱ vuza a kadama ba.
\b
\q1 
\v 8 <<Ka̱ta̱ i cinukpa n kakuna ka nampa ba,
\q2 ka̱ta̱ i zuwa kaꞋa a̱ ka̱ɗu. Ciɓai n ukuna u nampa, a̱ɗa̱ aza a unushi.
\q1 
\v 9 Ciɓasai n ili i cau, i na i lazai n ayin a ɗe.
\q2 Adama a na mpa ɗa Ka̱shile, babu kpamu vuza yoku,
\q2 mpa ɗa Ka̱shile, babu vuza na wi tsu va̱.
\q1 
\v 10 N ugiti n tsu dana ta̱ uma ukuna wu ukocishi,
\q2 n ili i cacau, koɓolo n i na yi lo a̱ kuta̱wa̱.
\q1 N danai, kadanshi ka̱ va̱ ki ta̱ a kushamgba,
\q2 mi ta̱ kpamu a kuyaꞋan i na n cikalai kuyaꞋan dem.
\q1 
\v 11 N ɗekei vuza yoku a kasana tsu manu ma na ma tsu shaɗa ili,
\q2 a iɗika i daꞋin kpamu vuma na u kushatangu kusheshe ku va̱.
\q1 N dansa ta̱ ili i na n kuyaꞋan,
\q2 mi ta̱ ta na a kuyaꞋan i ɗa.
\q1 
\v 12 Panakai mu, a̱ɗa̱ uma a ugbamukaci,
\q2 a̱ɗa̱ na yi daꞋangi n kuyaꞋan ku kasingai.
\q1 
\v 13 Mpa mi ta̱ ufoɓushi adama a na n zuwa ili i wala derere,
\q2 makyan mi punu ka̱u ba,
\q1 ama gogo na wishi u va̱ wi a kuyaꞋan megeshe ba.
\q2 Mi ta̱ a kuzuwa wishi u va̱ a Urushelima,
\q1 tsugbayin tsu va̱ tamkpamu a Isaraila.
\c 47
\s1 Uyikpi u Babila
\q1 
\v 1 <<Cipa̱ ka̱ta̱ vu da̱sa̱ngu a iɗika
\q2 avu Babila,
\q1 da̱sa̱ngu a kayala babu kakuba,
\q2 avu Babila.
\q1 O kudoku e ɗeke wu
\q2 meleshushe ko vuza babu utsura ba.
\q1 
\v 2 Ɗika kutalikukiya ka̱ta̱ vi yaꞋan kiya,
\q2 foɗo ka̱ka̱la̱bi ka̱ nu.
\q1 Va̱ga̱lukpa̱ fatari vu nu, vu ka̱sukpa̱ ene pulai,
\q2 ka̱ta̱ vu wala vu pasamgbanai o nɗolu.
\q1 
\v 3 Ciyanpu tsu nu ci ta̱ a̱ kuta̱ pulai,
\q2 ka̱ta̱ wono u nu wo okpo e keteshe.
\q1 Mpa n kutsupa ta̱,
\q2 mi kpamu a kubuwaka vuza n wuma ba.>>
\q1 
\v 4 Ka̱shibi ka̱ tsu, Vuzavaguɗu MalaꞋimili ɗa kula ku ni,
\q2 a̱yi ɗa vuza ciɗa vi Isaraila.
\b
\q1 
\v 5 <<Desa̱ngu ɗe n ka̱bini a̱ ka̱yimbi,
\q2 avu Babila,
\q1 a buwa e kuɗeke wu
\q2 mogono ma vuka mo tsugono ba.
\q1 
\v 6 N yaꞋan ta̱ wupa n uma a̱ va̱ aza a Isaraila,
\q2 m bonokoi le ukuna u gbani,
\q1 n nekei le e ekiye a̱ nu,
\q2 ɗa vu kpa̱ɗa̱i kupana asuvayali e le.
\q1 Ko a tsukutsa ci le,
\q2 ɗa vu ka̱na̱i kuneke le atakaci.
\q1 
\v 7 Ɗa vu danai, <Mpa mi ta̱ a kulyaꞋa kelime
\q2 n kulyaꞋa tsugono tsa̱ a̱ma̱ci ali a kubana uteku n uteku.
\q1 Ama vu kpa̱ɗa̱i kindana ili i nampa ya,
\q2 ko vi ciɓa n ili i na i ɗa i kutuka̱.
\b
\q1 
\v 8 <<Gogo na, pana kakuna ka nampa,
\q2 avu na vi ci ciga kupana ku uyoꞋo, avu na vu tsu yongo ukanji mayin,
\q1 avu na vu tsu dana n ka̱ci ka̱ nu,
\q2 <Mpa ɗa biꞋi, babu kpamu vuza yoku sai mpa.
\q1 Mpa mo kokpo kagapa ba
\q2 ko n namba maku a̱ ka̱tsuma̱ ka̱ muku n va̱ ba.>
\q1 
\v 9 Ukuna u re u nampa dem wi ta̱ a kucina wu babu megeshe,
\q2 a kanna ke te,
\q2 unambi u muku n tsugapa
\q1 ci ta̱ a̱ kuta̱wa̱ wa̱ nu m makara,
\q2 ko n ukuna u ka̱bunda̱i
\q2 ko oboci a̱ nu koɓolo n tsuboci le dem.
\q1 
\v 10 Vi neke ta̱ katsura n kawuya ka̱ nu
\q2 ali ɗa vu danai, <Babu vuza na we enei mu.>
\q1 Ugboji u nu n kuyeve ku nu ku nu ku vakangi nu
\q2 ana vu danai ka̱ci ka̱ nu,
\q2 <Mpa ɗa, babu kpamu vuza yoku tsu va̱.>
\q1 
\v 11 Mayu atakaci a̱ kuta̱wa̱ ta̱ wa̱ nu,
\q2 va kufuɗa kutere a ɗa n alaꞋwin ta na ba.
\q1 Kawuya ki ta̱ a̱ kuta̱wa̱ wa̱ nu,
\q2 vi ta na a kufuɗa kisa ka̱ci ka̱ nu ba,
\q1 ili i wuya i na vi uyevi n i ɗa ba,
\q2 yi ta̱ a kucinaka wu.
\b
\q1 
\v 12 <<Gogo na yaꞋan ulinga n alaꞋwin o tsuboci a̱ nu,
\q2 yaꞋan ulinga n uye u na vu tonoi ali n ayin a ɗe.
\q1 U gaꞋan ba u ɗa wi ta̱ a kuyaꞋanka wu kasingai,
\q2 ko u ɗa u zuwa vuza yoku kupana wovon u nu.
\q1 
\v 13 Kadanshi ko odoki ka na vi isai dem ko oꞋuso wu ta̱
\q2 Te ɗai aza a tsusaki ku ukuna a̱ nu i ra̱ka̱,
\q1 eyevi a azangata a ele na a tsu dana i na yi lo a̱ kuta̱wa̱ o wotoi dem,
\q2 yaꞋan a isa wu a̱ ubuta̱ wi ili i na yi lo a̱ kuta̱wa̱ wu.
\q1 
\v 14 Mayu i ta̱ tsu mita̱ ma̱ ciꞋiwa̱, ma na mi a kukula̱ akina.
\q2 A kina i ta̱ o kusongu le ra̱ka̱. A kufuɗa ki isa ka̱ci ke le, a̱ ubuta̱ wu utsura wa akina ba.
\q1 Cikina ci lo tsu na vuza u kunyashika ba,
\q2 babu kpamu akina a na vuza u kutasuku.
\q1 
\v 15 I nampa i ɗa koci a kufuɗa kuyaꞋanka ɗa̱
\q2 ele vu na vu soꞋi atakaci adama e le, ele vu na i yongoi koɓolo ali n ayin a na yi muku.
\q1 Yaba dem u tsu tono ta̱ uye u ni,
\q2 babu vuza te vu na wa kisa wu.
\c 48
\s1 Ugbamukaci wa aza a Isaraila
\q1 
\v 1 <<Panai ili i nampa, a̱ɗa̱ aza a kpaꞋa ku Yakubu,
\q2 a̱ɗa̱ na e ci ɗeke n kula ka aza a Isaraila,
\q2 ɗa yu uta̱i a tsukaya ci Yahuda,
\q1 ɗa kpamu i kucinai n kula ku Vuzavaguɗu
\q2 ali ɗa i ɗekei Ka̱shile ki Isaraila,
\q2 ama ba mayun ɗa i yaꞋin nannai ko n usuɓi ba,
\q1 
\v 2 a̱ɗa̱ na i ci ɗeke ka̱ci ka̱ ɗa̱ aza a ida̱shi a iɗika i ciɗa,
\q2 ɗa kpamu i nekei katsura u Ka̱shile ka aza a Isaraila,
\q2 Vuzavaguɗu MalaꞋimili ɗa kula ku ni.
\q1 
\v 3 N dana ta̱ ɗe ukuna wi ili i cau m megeshe ma ɗe,
\q2 una̱ u va̱ u ɗa u dansai kaꞋa, ɗa kpamu n zuwai uma e yevei kaꞋa,
\q2 ɗa n yaꞋin gogoꞋo n yaꞋin kaꞋa ɗa ta na yu uta̱i nannai.
\q1 
\v 4 Adama a na n yeve ta̱ tsu na yi n ugbamukaci,
\q2 eɗeku a̱ ɗa̱ ugbami ci iyum,
\q2 a̱ca̱n a̱ ɗa̱ feu utsura ci iyum i shili.
\q1 
\v 5 Adama a nannai n dana ɗa̱ ta̱ ili i nampa ali n ayin a ɗe,
\q2 kafu i ɗa i ta̱wa̱ n dana ɗa̱ ta̱ i ɗa
\q1 adama a na ka̱ta̱ i kpa̱ɗa̱ kudana,
\q2 <A̱ma̱li a̱ va̱ a ɗa a yaꞋin le,
\q2 a̱ma̱li a̱ usheꞋwi a̱ va̱ koɓolo n a̱ma̱li a̱ iyum a̱ va̱ a ɗa a zuwai le.>
\q1 
\v 6 I pana ta̱ ili i nampa, indanai i ɗa.
\q2 Ya̱ kushuku n i ɗa ba?
\b
\q1 <<Ili i na i ɗikai anana mi ta̱ a kudana ɗa̱ ukuna u savu,
\q2 ili yu usokongi i na ka̱ta̱ i saꞋwai kuyeve ba.
\q1 
\v 7 Gogo na ɗa a yaꞋin i ɗa, ka̱ta̱ i ɗa i yaꞋan megeshe ba.
\q2 I saꞋwa kupana i ɗa ba sai anana.
\q1 Babu tsu na i kudana,
\q2 <E, n yeve ta̱ tsu na i.>
\q1 
\v 8 I saꞋwa kupana ba, i saꞋwa feu kuyeve ba,
\q2 ali n ayin a cau atsuvu a̱ ɗa̱ a saꞋwa kuɓa̱yuwa̱ ba.
\q1 Adama a na n yeve ta̱ tsu na yi n kawuya,
\q2 e ci ɗeke ɗa̱ ta̱ kpamu aza a ugbamukaci ali kafu a matsa ɗa̱.
\q1 
\v 9 Adama a kula ku va̱ ɗa n ka̱na̱i wupa u va̱,
\q2 adama a na n ciya̱ ucikpi ɗa m kpa̱ɗa̱ta̱ngi i na mi ishi a kuyaꞋanka ɗa̱,
\q2 ta lo ma takpa ɗa̱ a̱ ubuta̱ u va̱.
\q1 
\v 10 La̱na̱i, n luwa̱ ɗa̱ ta̱, ama ba tsa azanariya ba,
\q2 n kondo ɗa̱ ta̱ e kenle ka atakaci.
\q1 
\v 11 Adama a̱ ka̱ci ka̱ va̱, e, adama a̱ ka̱ci ka̱ va̱, ɗa n yaꞋin ili i nampa.
\q2 Nini ɗai n kuka̱sukpa̱ kula ku va̱ ku na̱mgba̱?
\q2 Mpa me kupece tsugbayin tsu va̱ n vuza ba.
\q1 
\v 12 <<Panaka mu, avu Yakubu,
\q2 n Isaraila, avu na n ɗekei.
\q1 Mpa ɗa,
\q2 mpa ɗa ugiti, mpa ɗa kpamu ukocishi.
\q1 
\v 13 Ekiye a̱ va̱ a ɗa a varai kumi ka aduniyan,
\q2 ɗa kukiye ku usingai ku va̱ ku poloi gaɗi,
\q1 n ɗeke le baci
\q2 a̱ tsu uta̱ ta̱ ka̱ta̱ a shamgba koɓolo.
\b
\q1 
\v 14 <<Ta̱wa̱i koɓolo dem vu ɗa̱, ka̱ta̱ i pana.
\q2 Ka̱ma̱li ke ne ka i ka saꞋwai kudansa ili i nampa?
\q1 Mpa Vuzavaguɗu n ciga yi ta̱,
\q2 wi ta̱ a kushatangu ulinga u ni a Babila,
\q2 kukiye ku ni ki ta̱ o kokpo tsurala n aza a Babila.
\q1 
\v 15 Mpa, Vuzavaguɗu n dansa ta̱,
\q2 mayu, mpa ɗa n ɗekei ni.
\q1 Mi ta̱ a̱ kuta̱wa̱ n a̱yi,
\q2 ka̱ta̱ ta na u shatangu ili na u cigai kuyaꞋan.
\b
\p 
\v 16 Ta̱wa̱i ɗevu nu mpa ka̱ta̱ i pana ukuna u nampa.
\q1 <<Ali n kadanshi ka na n gita̱i kuyaꞋan n yaꞋan kaꞋa usokongi ba,
\q2 a ayin a na ili i nanlo i yaꞋin mpa mi ta̱ ɗe.>>
\b
\q1 Gogo na ta na Vuzavaguɗu Ka̱shile u suku mu ta̱,
\q2 koɓolo n ayinviki a singai a̱ ni.
\b
\q1 
\v 17 Ili i na Vuzavaguɗu u danai i ɗa na,
\q2 Ka̱shibi ka̱ ɗa̱, Vuza ciɗa vi Isaraila.
\q1 <<Mpa ɗa Vuzavaguɗu Ka̱shile ka̱ ɗa̱
\q2 vuza na u tsu yotsongu ɗa̱ i na i gaꞋin ɗa̱,
\q2 a̱yi na u tsu tono n a̱ɗa̱ a uye u na i kuwala.
\q1 
\v 18 Ishi baci i yeve ɗa i zukai mayin n wila̱ u va̱,
\q2 ma̱ta̱na̱ ma̱ ɗa̱ mi ishi ta̱ o kokpo an kuyene,
\q1 ka̱ta̱ usuɓi u ɗa̱ feu wo okpo tsa aɓau a mala.
\q1 
\v 19 Muku n nu mi ishi ta̱ o kokpo tsu kayala,
\q2 ka̱ta̱ ntsukaya n nu tamkpamu mo okpo tsu ushen wi ili i kashina i ni,
\q1 ula e le a kusaꞋwa kuyaꞋan utakpi ba,
\q2 ko a yaꞋan ula̱nga̱shi wa̱ va̱.>>
\b
\q1 
\v 20 Uta̱i punu a Babila,
\q2 sumai i ka̱sukpa̱ aza a Kaldiya.
\q1 Salai kakuna ka nampa m ma̱za̱nga̱ ma kacaꞋa,
\q2 ka̱ta̱ i dansa kaꞋa.
\q1 Suki kaꞋa daꞋin a uteku wa aduniyan,
\q2 i dana, <<Vuzavaguɗu u shiba̱ ta̱ kagbashi ka̱ ni Yakubu.>>
\q1 
\v 21 Ele a pana kakuli ko yoku a ayin a na Vuzavaguɗu u tonoi n ele e meremune ba,
\q2 u zuwai mini mu uta̱i le a kakpanlai,
\q1 u ɓosoi kakpanlai ka
\q2 ɗa mini mu uta̱i punu.
\b
\q1 
\v 22 Ɗa Vuzavaguɗu u danai, <<Vuza va asuvawuya wa̱ kuciya̱ ma̱ta̱na̱ ba.>>
\c 49
\s1 Kagbashi ka Vuzavaguɗu
\q1 
\v 1 Panakai mu, a̱ɗa̱ aza a̱ ka̱kina̱ ka mala,
\q2 panai kakuna ka nampa, a̱ɗa̱ na yi a̱ mpulu.
\q1 Vuzavaguɗu u neꞋe mu ta̱ kula mpa punu biꞋi a̱ ka̱tsuma̱,
\q2 u ɗeke ta̱ kula ku va̱ ayin a na mpa biꞋi mereɓu.
\q1 
\v 2 Ɗa u bonokoi una̱ u va̱ tsu kotokobi ka alyu,
\q2 u sokongi mu a̱ kululu ku kukiye ku ni,
\q1 u gboroi mu tsu kaya
\q2 ɗa u foɓoi mu a majiki ma ni.
\q1 
\v 3 Ɗa u danai mu, <<Avu ɗa kagbashi ka̱ va̱,
\q2 Isaraila, wa̱ nu u ɗa n kuciya̱ tsugbayin.>>
\q1 
\v 4 Ama ɗa n danai, <<N yaꞋan ta̱ ulinga u gbani,
\q2 n la̱nga̱sa̱i utsura u va̱ gbani babu ili i yoku.
\q1 Ama n yaꞋan ta̱ i ɗa adama a Vuzavaguɗu,
\q2 katsupu ka̱ va̱ kpamu e ekiye a̱ Ka̱shile.
\q1 
\v 5 Ɗa gogo na Vuzavaguɗu u danai,
\q2 a̱yi na u yaꞋin mu ali mpa biꞋi ka̱tsuma̱ adama a na mo okpo kagbashi ka̱ ni,
\q1 ciya̱ m bonoko n Yakubu wa̱ ni,
\q2 ka̱ta̱ aza a Isaraila o ɓolongu wa̱ ni.
\q1 Adama a na n ciya̱ ta̱ tsugbayin a̱ a̱shi a Vuzavaguɗu,
\q2 Ka̱shile ka̱ va̱ kaꞋa katsura ka̱ va̱,
\q1 
\v 6 ɗa u danai,
\q1 <<Avu kagbashi ka̱ va̱ kaꞋa vi koci ba, ka na ka̱ kuɗa̱ngusa̱ kumaci ku Yakubu,
\q2 ka̱ta̱ vu bonoko n uma a Isaraila a na a buwai.
\q1 Ama mi ta̱ kpamu a kuzuwa wu vo okpo kutashi ka aza ka̱yimbi,
\q2 adama a na wishi u va̱ u bana ali a uteku wa aduniyan.>>
\b
\q1 
\v 7 Na ɗa ili i na Vuzavaguɗu u danai,
\q2 ka̱shibi ka aza a Isaraila n aza a ciɗa a̱ ni,
\q1 vuza na uma a iwain ɗa aduniyan kpamu o goyoi,
\q2 u vuza na wi kagbashi ko ngono,
\q1 <<Ngono mi ta̱ e kene wu ka̱ta̱ a̱ ɗa̱nga̱ kashani, e neke wu tsugbayin,
\q2 muku mu ngono mi ta̱ e kene wu ka̱ta̱ a̱ kuɗa̱nku wu a iɗika
\q1 adama a Vuzavaguɗu, vuza na wi n kasingai,
\q2 vuza ciɗa vi Isaraila a̱yi ɗa u zagbai nu.>>
\s1 Uboni wu muku mi Isaraila
\p 
\v 8 Na ɗa ili i na Vuzavaguɗu u danai,
\b
\q1 <<A ayin a kasingai mi ta̱ e kuneke ɗa̱ wu ushuki,
\q2 ka̱ta̱ a ayin a wishi m ɓa̱nka̱ ɗa̱,
\q1 mi ta̱ a̱ kuka̱na̱ ɗa̱
\q2 ka̱ta̱ n zuwa ɗa̱ yo okpo ci ili yu uzuwakpani a kubana a̱ ubuta̱ u uma,
\q1 ka̱ta̱ m bonoko iɗika ya kpamu derere
\q2 ali m bono m peceke aza a iɗika ya iɗika i le kpamu i na yi ishi agali,
\q1 
\v 9 n dana agbashi, <Uta̱i pulai>
\q2 aza a na i a̱ ka̱yimbi,
\q1 <Ta̱wa̱i e keteshe>
\q1 I ta̱ a kulyaꞋa ali a̱ cuwa̱ a uye u na a kuwala dem,
\q2 ka̱ta̱ kpamu o doku a̱ ciya̱ i na a kulyaꞋa a̱ ubuta̱ wu nsasan feu.
\q1 
\v 10 Kambulu n kakuli ki a̱ kuka̱na̱ le ba,
\q2 usuɗukpi u kanna n u wunla̱i u kuka̱na̱ le ba.
\q1 Vuza na wi a kupana asuvayali e le wi ta̱ a̱ kula̱na̱ le,
\q2 ka̱ta̱ u tono n ele a̱ ubuta̱ u mini dem.
\q1 
\v 11 <<Mi ta̱ a kuyaꞋan uye a̱ ubuta̱ wu nsasan n va̱ ra̱ka̱,
\q2 ka̱ta̱ kpamu m bonoko uye u gbayin u ɗa̱nga̱ gaɗi.
\q1 
\v 12 La̱na̱, ili i nampa yi ta̱ a̱ kuta̱ a̱ mpulu,
\q2 a iɗika yu uɓon u gaɗi n ka̱livi,
\q2 ali n na ɗe daꞋin a iɗika i Sini.>>
\b
\q1 
\v 13 YaꞋin ishipa, a̱ɗa̱ gaɗi,
\q2 yaꞋin ma̱za̱nga̱, a̱ɗa̱ aduniyan,
\q2 ɓosongi ishipa a̱ɗa̱ nsasan.
\q1 Adama a na Vuzavaguɗu u neke ta̱ uma a̱ ni kadanshi ku uremi u ka̱ɗu,
\q2 wi ta̱ kpamu a kupana asuvayali a uma a̱ ni a na i a atakaci.
\b
\q1 
\v 14 Ama ɗa uma a Sihiyona a danai,
\q2 <<Vuzavaguɗu u vakangu mu ta̱, u cinukpa ta̱ nu mpa.>>
\b
\q1 
\v 15 <<Kamaci ki ta̱ a kucinukpa m maku ma na wi e kuneꞋe mani
\q2 ali u kpa̱ɗa̱ kupana asuvayali a maku ma na u matsai va?
\q1 Ko vuka va wi baci a kucinukpa,
\q2 mpa mi a kucinukpa n a̱ɗa̱ ba.
\q1 
\v 16 La̱na̱, n ɗana wu ta̱ a kataka ke kukiye ka̱ va̱,
\q2 nshilya n nu mi ta̱ wa̱ va̱ ali sai uteku n uteku.
\q1 
\v 17 Aza a na a maꞋasakai nu i ta̱ a kuyaꞋan ulinga wa gogoꞋo,
\q2 a laꞋa aza a na a̱ la̱nga̱sa̱i nu, ka̱ta̱ aza a na a̱ la̱nga̱sa̱i nu a laza.
\q1 
\v 18 Ɓa̱yuwa̱ a̱shi a̱ nu ka̱ta̱ vu la̱na̱ akambu dem,
\q2 uma a̱ nu ra̱ka̱ o ɓolongu ka̱ta̱ a̱ ta̱wa̱ wa̱ nu.
\q1 Vuzavaguɗu u danai, <<Tsu na de mi n wuma na, vi ta̱ a̱ kuka̱ɓa̱ngu le e
\q2 kuɗeku a na ucanuku wo ogoni,
\q2 vi ta̱ a kuꞋuka le tsu vuka vu savu.
\b
\q1 
\v 19 Ko a na wo okpoi a̱ la̱nga̱sa̱ ta̱ iɗika i nu,
\q2 ɗa i ɗa yo okpoi agali,
\q1 i ɗa yi ta̱ a̱ kuta̱wa̱ ya shana n uma a̱ nu,
\q2 ka̱ta̱ aza a na a yawakai nu uteku a shamgba daꞋin n avu.
\q1 
\v 20 Muku n nu n na a matsai a̱ ubuta̱ wu ugbashi i ta̱ o kubono
\q2 ka̱ta̱ a dana wu a atsuvu,
\q1 <<Ubuta̱ u nampa u gusa̱ tsu ta̱,
\q2 doku tsu ubuta̱ u na tsa̱ kuda̱sa̱ngu.>
\q1 
\v 21 Ka̱ta̱ vu dana n ka̱ɗu ka̱ nu,
\q2 <Yayi u nekei mu ntsukaya n nampa dem?
\q1 Adama a na muku n va̱ n a̱bunda̱i n yaꞋan ta̱ wuni,
\q2 ɗa a ɗikai aza a na a buwai a bankai ugbashi. A̱ ka̱sukpa̱i mu na gba̱ɗa̱.
\q2 Te ɗai tamkpamu uma a nampa a̱ uta̱i?
\q1 Yayi u matsai muku n nampa?
\q2 Yayi u kumgbasakai mu ele?> >>
\p 
\v 22 Ili i na Vuzavaguɗu MalaꞋimili u danai i ɗaɗa na.
\q1 <<La̱na̱, mi ta̱ e kuɗeke aduniyan n kukiye,
\q2 ka̱ta̱ n ɗengusa̱ urotu u kakashi u va̱ a̱ ubuta̱ u uma,
\q1 i ta̱ a̱ kutuka̱ ɗa̱ m muku mo olobo n ɗa̱ woɓongi e ekiye,
\q2 ka̱ta̱ a canuku muku mi nkere n ɗa̱ a avangatsu e le.
\q1 
\v 23 Ngono mi ta̱ o kokpo ɗa̱ ishekpu i na i kula̱na̱ ɗa̱,
\q2 ka̱ta̱ ngono ma̱ a̱ma̱ci n le mo okpo ina̱kpu i ɗa̱ i na i kuwoꞋo ɗa̱.
\q1 I ta̱ a̱ kukuɗa̱nku ɗa̱ ali a iɗika
\q2 ka̱ta̱ e peɗe kubuta̱ ku na ki e ene a̱ ɗa̱.
\q1 Nannai ɗa i kuyeve a na mpa ɗa Vuzavaguɗu,
\q2 aza a na e keɗei a̱pa̱Ꞌa̱ e le a̱ kuta̱wa̱ wa̱ va̱, a kuyaꞋan wono ba.>>
\b
\q1 
\v 24 Yayi wa kufuɗa kisa ucanuku u na a̱ pura̱i gbani a̱ ubuta̱ u kuvon e ekiye o kovonshi,
\q2 ko wi isa uma na e remei a̱ ubuta̱ u kuvon e ekiye o mogono ma asuvawuya?
\p 
\v 25 Ama ili i na Vuzavaguɗu u danai i ɗaɗa na,
\q1 <<Mayu, aza a na e remei a̱ ubuta̱ wu ugbashi mi ta̱ a kisa le e ekiye o kovonshi,
\q2 ka̱ta̱ ucanuku u na a̱ pura̱i gbani a̱ ubuta̱ u kuvon m bonoko le n u ɗa.
\q1 Mi ta̱ a̱ kushilika̱ n aza a na a̱ shilika̱i n a̱ɗa̱,
\q2 ka̱ta̱ mi isa muku n ɗa̱.
\q1 
\v 26 Mi ta̱ a kuzuwa irala i ɗa̱ i takumasanai,
\q2 i ta̱ o kusoꞋo mpasa n le, tsu na a ci yaꞋan m ma̱ra̱.
\q1 Ka̱ta̱ aduniyan ra̱ka̱ e yeve a na
\q2 mpa ɗa vuzavaguɗu kishi ka̱ ɗa̱,
\q2 n Ka̱shibi ka̱ ɗa̱, Uba̱nga̱ri vi Isaraila.>>
\c 50
\s1 Unushi wa aza a Isaraila n kagbashi ka̱ ma̱riki
\p 
\v 1 Ili i na Vuzavaguɗu u danai i ɗa na,
\q1 <<Te ɗai katakarda ku upeci u yolo ka̱ a̱na̱vu,
\q2 ka na n danai n ka̱sukpa̱i ta̱?
\q1 Ko u vuza vu kutan vu va̱ ve ne ɗai
\q2 n dengei wu ta̱?
\q1 Adama a̱ unushi u ɗa n dengei ɗa̱,
\q2 adama a kawuya ka̱ ɗa̱ ɗa n lokoi a̱na̱kpa̱ a̱ ɗa̱.
\q1 
\v 2 <<Ana n ta̱wa̱i yiɗa̱i i zuwai ɗa m kpa̱ɗa̱i kucina vuza ɗe?
\q2 Ana n ɗekei yiɗa̱i ɗa vuza u kpa̱ɗa̱i kuyaꞋan lo a na wa̱ kushuku?
\q1 Kukiye ku va̱ kugusa̱ ta̱ ali ɗa ka̱ kukpa̱ɗa̱ kushiba̱ uma a?
\q2 Ko ta na ku namba utsura u na ka kisa vuza? La̱na̱,
\q1 n uɓarangi u va̱ koci ɗa n ɗekpetengi mala,
\q2 m bonokoi nɗolu ubuta̱ u ɗeku,
\q1 adan e le a shamai adama a unambi u mini,
\q2 ɗa a̱ kuwa̱i n kakuli ali ɗa a shamai.
\q1 
\v 3 M palai gaɗi n ka̱yimbi,
\q2 ɗa n yaꞋankai ni ili i kupalaka ka̱ci ka̱ ni m motogu mu una̱mgbuka̱tsuma̱.>>
\b
\q1 
\v 4 Vuzavaguɗu MalaꞋimili u neke mu ta̱ kadanshi ku ugboji,
\q2 adama a na n yeve kadanshi ko kudokusu uma ka̱ɗu ka na ko kuɓa̱nka̱ aza a na i babu utsura.
\q1 Usana lakam u tsu jimgbasa mu ta̱
\q2 atsuvu a̱ va̱ ciya̱ m pana tsa aza a na a̱ ciya̱i uyotsongi.
\q1 
\v 5 Vuzavaguɗu Ka̱shile u ɓa̱yuwa̱ ta̱ atsuvu a̱ va̱,
\q2 n yaꞋan ugbamukaci kpamu ba,
\q2 m kpatala feu kucina̱ ba.
\q1 
\v 6 N neke ta̱ kucina̱ ku va̱ a̱ ubuta̱ wa aza a na i a kulapa mu,
\q2 n nekei nguji n va̱ kpamu a̱ ubuta̱ wa aza a na i o kurono ntsa̱ka̱ n va̱.
\q1 Mpa ta na m kpatala a̱shi a̱ va̱ a̱ ubuta̱
\q2 wa aza a na i a kushikasa mu n a jirakai mu ntsa̱n ba.
\q1 
\v 7 Adama na Vuzavaguɗu MalaꞋimili u tsu ɓa̱nka̱ mu ta̱,
\q2 mpa mi a kuciya̱ kugoyi ba.
\q1 Adama a nannai n shikpa̱ ta̱ a̱shi a̱ va̱ tsu katali,
\q2 n yeve ta̱ ta na mi a kuyaꞋan wono ba.
\q1 
\v 8 A̱yi na u nekei mu uba̱ruwi wi ta̱ lo ɗevu.
\q2 Yayi u kugbaga mu n kavama?
\q2 YaꞋan n tsu kondonoi ce ene.
\q1 Anan yayi aza a nsata a̱ va̱?
\q2 ka̱sukpa̱ wu uta̱ na ɗevu nu mpa.
\q1 
\v 9 La̱na̱, Vuzavaguɗu MalaꞋimili wi ta̱ koɓolo nu mpa.
\q2 Yayi u kudana mi ta̱ n unushi?
\q1 I ta̱ a kushama ra̱ka̱ tsa akashi,
\q2 ka̱ta̱ azun a takuma le ra̱ka̱.
\b
\q1 
\v 10 Yayi a̱ ka̱tsuma̱ ka̱ ɗa̱ wi a kupana wovon u Vuzavaguɗu
\q2 ɗa kpamu wi a kupana ka̱la̱ka̱tsu ka kagbashi ka̱ ni?
\q1 YaꞋan a̱yi na wi a nwalu a̱ ka̱yimbi
\q2 babu kutashi,
\q1 u zuwaka kula ku Vuzavaguɗu katsura,
\q2 ka̱ta̱ kpamu u bonoko a̱miki a̱ ni u Ka̱shile ka̱ ni.
\q1 
\v 11 Ama la̱na̱i, a̱ɗa̱ ra̱ka̱ vu na i tsu tasuku akina,
\q2 ka̱ta̱ i zamaka ka̱ci ka̱ ɗa̱ nkuni n na mi a kulala n kutashi,
\q1 walai a̱ ubuta̱ u kutashi ka akina ku ɗa̱
\q2 koɓolo n kutashi ku nkuni ku na i zamai,
\q1 ili i na i kuciya̱ wa̱ va̱ i ɗa na.
\q2 Yi ta̱ a̱ kuyikpa̱ a̱ ka̱tsuma̱ ka atakaci a gbani-gbani.
\c 51
\s1 Wishi u Sihiyona u na u kukpa̱ɗa̱ kukotso
\q1 
\v 1 <<Panakai mu, a̱ɗa̱ vu na yi a kuguva kasingai,
\q2 ɗa kpamu yi a̱ kula̱nsa̱ Vuzavaguɗu,
\q1 la̱na̱i a kakpanlai ka na e sheꞋwei ɗa̱
\q2 koɓolo n ubuta̱ u ka̱ta̱mba̱ u na a̱ ga̱va̱i ɗa̱.
\q1 
\v 2 Indanai Ibirahi eshekpu a̱ ɗa̱,
\q2 koɓolo n Saratu a̱yi na u matsai ɗa̱.
\q1 A ayin a na n ɗekei ni wi m maku ba,
\q2 ama ɗa n zuwakai ni una̱singai ɗa n doku n zuwai kumaci ku ni ku yimkpai n ka̱bunda̱i.
\q1 
\v 3 Adama a na Vuzavaguɗu wi ta̱ e kuneke Sihiyona kadanshi ku uremi u ka̱ɗu
\q2 ka̱ta̱ kpamu wi indana agali a̱ ni ra̱ka̱ n asuvayali,
\q1 u bonoko kakamba ka̱ ni tsu Adini,
\q2 akamba a̱ ni o bono tsu kashina ka Vuzavaguɗu.
\q1 A̱ kuciya̱ ta̱ ma̱za̱nga̱ n izoshi wa̱ ni,
\q2 koɓolo n kucikpa ali n ishipa.
\b
\q1 
\v 4 <<Panakai mu uma a̱ va̱,
\q2 ka̱ta̱ i zuwaka mu atsuvu, a̱ɗa̱ aduniyan a̱ va̱,
\q1 adama a na mi ta̱ e kuneke wila̱,
\q2 ka̱ta̱ n zuwa kasingai ka̱ va̱ ko okpo kutashi a̱ ubuta̱ u uma.
\q1 
\v 5 Usuɓi u va̱ wi ta̱ lo a kuyawa ɗevu m moloko,
\q2 wishi u va̱ wi ta̱ lo a uye a̱ kuta̱wa̱,
\q2 obolu a utsura a̱ va̱ i ta̱ a̱ kutuka̱ aduniyan n kasingai.
\q1 Aza a na i ida̱shi a ka̱kina̱ ka̱ mini i ta̱ e kukeɗe a̱pa̱Ꞌa̱ wa̱ va̱,
\q2 ka̱ta̱ kpamu a vana obolu a utsura a̱ va̱.
\q1 
\v 6 Ɗengusa̱i a̱shi a̱ ɗa̱ gaɗi zuva,
\q2 ka̱ta̱ yi inda ɗaka vi iɗika,
\q1 adama a na gaɗi wi ta̱ a̱ kupuwa̱nka̱ tsu ka̱nga̱,
\q2 ka̱ta̱ iɗika i shama tsu kakashi,
\q2 ka̱ta̱ aza a na i o kuyongo punu a̱ kuwa̱ tsa ayun.
\q1 Ama wi ishi u va̱ wi o kukotso ba,
\q2 usuɓi u va̱ feu wo kokpo uye ba.
\b
\q1 
\v 7 <<Panakai mu, a̱ɗa̱ vu na i yevei kasingai,
\q2 a̱ɗa̱ aza na yi n wila̱ u va̱ a̱ a̱ɗu a̱ ɗa̱,
\q1 Ka̱ta̱ i pana wovon wu ujari u uma ba
\q2 ko wovon wi ishikushi i le ba.
\q1 
\v 8 Adama a na kayan ki ta̱ a kutakuma le tsu kuminya,
\q2 ka̱ta̱ okpoɗou o sovo le o okpo an tsugbere,
\q1 ama usuɓi u va̱ wi o kukotso ba,
\q2 wishi u va̱ feu wi ta̱ o kuyongo ko wannai.>>
\b
\q1 
\v 9 Jimgba, jimgba, Vuzavaguɗu, ɗengusa̱ obolu a̱ nu n utsura,
\q2 ɗa̱nga̱ tsu ayin cau,
\q1 tsu na ili yi ishi n tsumani.
\q2 Avu ɗa vu gbatyai Rahapu miri-miri ba,
\q2 yayi u gbatyasai ka̱di ka nanlo ka?
\q1 
\v 10 Avu ɗa vu ɗekpetengi mala ma ba,
\q2 mini ma na mi n uga̱vi ka̱u,
\q1 yayi u yaꞋin uye punu a mala mu uga̱vi
\q2 adama a na aza a na a̱ ciya̱i ushibi a pasa punu?
\q1 
\v 11 Ka̱ta̱ aza a na a̱ ciya̱i wishi u Vuzavaguɗu o bono.
\q2 I ta̱ a kuꞋuwa a Sihiyona n ishipa,
\q2 ma̱za̱nga̱ ma babu kukotso mi ta̱ o kokpo le tso oroliko.
\q1 Uyo m ma̱ta̱na̱ mi ta̱ a̱ kuta̱wa̱ we le,
\q2 ka̱ta̱ una̱mgbuka̱tsuma̱ n unambi u ma̱za̱nga̱ u kotso.
\b
\q1 
\v 12 <<Mpa ɗa vuza na n tsu dokusu wu ka̱ɗu utsura,
\q2 avu ɗa ya vu pana wovon u vuza na wi a̱ kukuwa̱,
\q2 umaci u vuma u na wi uyaꞋin tsu mita̱?
\q1 
\v 13 Ali ɗa vu cinukpai n Vuzavaguɗu, Vuza na u yaꞋin nu,
\q2 a̱yi na u ba̱rukpa̱i gaɗi
\q2 ɗa kpamu u varai kumi ka aduniyan,
\q1 ɗa vi a kulyaꞋa kelime n kupana wovon ali a kanna ka̱ɓa̱la̱
\q2 adama a wupa u vuza gbani-gbani,
\q1 vuza na u zuwai ɗe ka̱ci ka̱ ni a uye u na u kukuwa̱?
\q2 Ama te ɗai biꞋi wupa u vuza gbani-gbani wa wi?
\q2 
\v 14 Aza a na i a kutakacika i ta̱ a kuyaꞋan uba̱ruwi gogoꞋo,
\q1 i ta̱ a kuyaꞋan ayin a̱ a̱bunda̱i n wuma
\q2 ka̱ta̱ kpamu a lyaꞋa ilikulya i na a cikalai.
\q1 
\v 15 Adama a na mpa ɗa Vuzavaguɗu Ka̱shile ka̱ nu,
\q2 vuza na u tsu vura̱ mala ka̱ta̱ aɓau a̱ ni a̱ shida̱,
\q2 Vuzavaguɗu MalaꞋimili ɗa kula ku va̱.
\q1 
\v 16 Mpa n zuwa ta̱ kadanshi ka̱ va̱ punu a̱ una̱ u nu,
\q2 ɗa m palai nu n kululu ku kukiye ku va̱.
\q1 Mpa na n yaꞋin gaɗi
\q2 ɗa kpamu n varai kumi ka aduniyan,
\q2 a̱yi na u danai Sihiyona, <A̱ɗa̱ ɗa uma a̱ va̱.> >>
\q1 
\v 17 Jimgbai, jimgbai,
\q2 Ɗenga̱ kashani, avu Urushelima,
\q1 avu na vu soꞋi ɗe e kukiye ku Vuzavaguɗu,
\q2 moko ma wupa ma̱ ni,
\q1 avu na vu soꞋi ali vi teneꞋi
\q2 keɓeletsu ka na ka tsu zuwa uma ma maka le.
\q1 
\v 18 A̱ ka̱tsuma̱ ka limata i nu
\q2 babu vuza te vu na u buwai a na wa kinda wu,
\q1 muku n na vu woꞋi dem
\q2 babu kpamu vuza te vu na u kuɓa̱na̱ yi kukiye a̱ ka̱tsuma̱ ke le
\q1 
\v 19 Ili i re i nampa ya i ta̱wa̱ ta̱ wa̱ nu,
\q2 yayi u kudokusu wu utsura u ka̱ɗu?
\q1 Kula̱nga̱su m munuka, n kambulu n kuvon,
\q2 yayi u kudokusu wu utsura u ka̱ɗu?
\q1 
\v 20 Muku n nu n lima̱ ta̱,
\q2 a vaku ta̱ a nsanji mu uye dem,
\q2 tsu mereꞋen ma na mazai a̱ bilili,
\q1 i ta̱ tukpa n wupa u Vuzavaguɗu,
\q2 n Uɓarangi u Ka̱shile ka̱ ɗa̱.
\q1 
\v 21 Adama a nannai pana ukuna u nampa, a̱ɗa̱ na i ci yaꞋan kagbanigbani,
\q2 yo okpoi osoꞋi ama ba kusoꞋo ku ma̱ra̱ ba.
\q1 
\v 22 Na ɗa ili i na Vuzavaguɗu MalaꞋimili u danai,
\q2 Ka̱shile ka̱ ɗa̱ ka na ko tsu folono adama a uma a̱ ni u danai,
\q1 <<La̱na̱, n takpa ta̱ kaꞋa ekiye a̱ nu
\q2 matan ma na ma tsu zuwa vo okpo adanshi ma̱ra̱ ma maka wu ta̱ va,
\q1 keɓeletsu ka wupa u va̱ ka na vi ishi
\q2 o kusoꞋo va ka buwa ba.
\q1 
\v 23 Mi ta̱ a kukucukpa ma zuwa matan ma e ekiye a aza a na i a kutakacika wu,
\q2 aza na a danai nu,
\q2 <Kuɗa̱ngu adama a na tsu wala gaɗi vu nu.>
\q1 Ɗa ta na vu zuwai kokondo ka̱ nu ci iɗika,
\q2 tsu uye adama a na uma a wala.>>
\c 52
\s1 Vuzavaguɗu wi ta̱ a kisa Urushelima
\q1 
\v 1 Jimgba, jimgba, avu Sihiyona,
\q2 zuwa utsura,
\q1 uka ntogu n singai n nu,
\q2 avu Urushelima likuci i ciɗa.
\q1 Adama a na babu vuza na u kudoku wa̱ ta̱wa̱ wa̱ nu
\q2 babu ukiɗi u kavaja ko n unata.
\q1 
\v 2 Ka̱pa̱tsa̱ kubuta̱ ki ikyamba ku ɗa̱
\q2 ka̱ta̱ vu ɗa̱nga̱ vu da̱sa̱ngu, avu Urushelima,
\q1 Shikpa kawin ka na ki e kuɗeku ku nu,
\q2 avu Sihiyona kagbashi.
\p 
\v 3 Adama a na i na Vuzavaguɗu u danai i ɗa na,
\q1 <<Gbani ɗa e dengei nu,
\q2 gbani ɗa kpamu a̱ kushiba̱ wu babu ikebe.>>
\p 
\v 4 Na ɗa ili i na Vuzavaguɗu Ka̱shile ka danai,
\q1 <<N ugiti uma a̱ va̱ a bana ta̱ a Masar adama a na a̱ da̱sa̱ngu ɗe,
\q2 ɗa aza a Asiriya a̱ ta̱wa̱i a takacikai le gbani.
\p 
\v 5 Ɗa Vuzavaguɗu we ecei <<Gogo na yiɗa̱i mi n i ɗa punu na>>?
\q1 Me enei a ɗikai uma a̱ va̱ gbani,
\q2 ɗa kpamu aza a na i a kulyaꞋa tsugono we le
\q1 a̱ ka̱na̱i kuyaꞋanka le ma̱ka̱n,>> u doku u danai,
\q2 <<Ɗa kpamu a̱ ka̱na̱i kugoyo kula ku va̱ a kanna dem.
\q1 
\v 6 Adama a nannai uma a̱ va̱ i ta̱ e kuyeve kula ku va̱.
\q2 Adama a nannai a kanna ka nanlo i ta̱ e kuyeve
\q1 a na mpa ɗa mi a kadanshi,
\q2 mayun, mpa ɗa na.>>
\q1 
\v 7 Indana biꞋi tsu na wi n ugaꞋin a gaɗi vu nsasan,
\q2 ene a aza a na i a̱ kuta̱wa̱ n arabali a singai,
\q1 aza a na a kusala arabali a̱ ma̱ta̱na̱.
\q2 U salai ukuna wu ulyaꞋi
\q2 ɗa kpamu u salai ukuna u wishi,
\q1 a̱yi na u danai Sihiyona,
\q2 <<Ka̱shile ka̱ ɗa̱ mogono maꞋa.>>
\q1 
\v 8 Panai, aza kindi a̱ nu a̱ ɗengusa̱ ta̱ a̱la̱ka̱tsu e le
\q2 koɓolo ɗa a yaꞋin ishipa i ma̱za̱nga̱.
\q1 Ayin a na baci Vuzavaguɗu u bonoi a Sihiyona,
\q2 i ta̱ e kene yi n a̱shi e le.
\q1 
\v 9 Ɓosongi ishipa i ma̱za̱nga̱ koɓolo,
\q2 a̱ɗa̱ agali a na i a Urushelima,
\q1 adama a na Vuzavaguɗu u neke ta̱ ɗe uma a̱ ni kadanshi ku udokushi wa̱ a̱ɗu,
\q2 a̱yi u shiba̱ ta̱ ɗe Urushelima.
\q1 
\v 10 Vuzavaguɗu wi ta̱ a̱ kuba̱rukpa̱ ekiye a ciɗa a̱ ni
\q2 e kelime ka̱ a̱shi a aduniyan dem,
\q1 ka̱ta̱ uteku wa aduniyan ra̱ka̱ we ene
\q2 wishi u Ka̱shile ka̱ tsu.
\b
\q1 
\v 11 Lazai, lazai, uta̱i punu ɗe,
\q2 ka̱ta̱ i saꞋwa ili yu unata ba,
\q1 uta̱i punu wa̱ ni ka̱ta̱ yo okpo ciɗa,
\q2 a̱ɗa̱ vu na i ɗikai ucanuku u Vuzavaguɗu.
\q1 
\v 12 Adama a na a̱ɗa̱ yi a̱ kuta̱ m moloko ba,
\q2 ko kpamu n ilaɗi ba,
\q1 adama na Vuzavaguɗu wi ta̱ a kuwala kelime ka̱ ɗa̱,
\q2 ka̱ta̱ Ka̱shile ki Isaraila ke geɓemgu ɗa̱ kucina̱.
\q1 
\v 13 La̱na̱i, kagbashi ka̱ va̱ ki ta̱ a kuyaꞋan ulinga n ugboji,
\q2 wi ta̱ a̱ kuciya̱ ucikpi n tsugbayin tsu gbangam.
\q1 
\v 14 Ama tsu na uma n a̱bundei i a kuyaꞋan mereve adama a̱ ni.
\q2 Wuti u ni tsu vuma u sabaꞋa ta̱, u doku u yotso vuza kpamu ba,
\q1 vi o kudoku ve yeve yi a na vuma ɗa wi kpamu ba,
\q1 
\v 15 ta u kuzuwa uma a aduniyan n a̱bunda̱i a̱ rikpa̱ nannai,
\q2 ka̱ta̱ ngono m paɗa una̱ u le bini adama a̱ ni.
\q1 Adama a na ili i na ka̱ta̱ a saꞋwai kudana le ba, i ta̱ e kene i ɗa,
\q2 i na kpamu a saꞋwai kupana ba, e yeve i ɗa.
\c 53
\q1 
\v 1 Yayi wu ushuki n ili i na tsu panai?
\q2 U yayi kpamu Vuzavaguɗu u yotsongi kukiye ku utsura ku ni?
\q1 
\v 2 Adama a na u gbonguro ta̱ a̱ ubuta̱ u Vuzavaguɗu ci ili i na i topoi usavu,
\q2 tsu karalu ka na kuta̱i a iɗika i ɗekpu.
\q1 Wi n tsuloboi ko n tsugbayin a na tso bonoko asuvu a̱ tsu wa̱ ni ba,
\q2 babu ugaꞋin u na wi n u ɗa u na u kuzuwa ci cikala yi.
\q1 
\v 3 Ɗa uma o goyoi ni ɗa kpamu a iwain ni,
\q2 vuma vu una̱mgbuka̱tsuma̱ koɓolo n ukiwani wa atakaci.
\q1 Tsu zuwakai ni kucina̱ ɗa tsu tonoi a uye u yoku,
\q2 o goyoi ni ama a̱ tsu ci keɓece n a̱yi ba.
\q1 
\v 4 Mayun ɗa, u ɗika ta̱ mma̱la̱ n tsu
\q2 n una̱mgbi u ka̱tsuma̱ u tsu,
\q1 ama ɗa a̱ tsu ci sheshei tsu danai atakaci a̱ ni ta a̱ uta̱i u Ka̱shile,
\q2 atakaci adama a̱ unushi u ni.
\q1 
\v 5 Ama ɗa u ciya̱i usovi adama a kawuya ka tsu,
\q2 u ciya̱i ufori adama a̱ unushi u tsu.
\q1 Atakaci a na a̱ tuka̱i tsu m ma̱ta̱na̱ ta a̱ uta̱i wa̱ ni,
\q2 n adama a̱ usa̱n u ni u ɗaɗa tsu potsoi.
\q1 
\v 6 Ra̱ka̱ vu tsu ci ta̱ tsu nkyon n na n tambalukpai,
\q2 ɗa yaba dem u ka̱na̱i uye u ni,
\q1 ɗa Vuzavaguɗu u nekei ni
\q2 a̱miki a̱ unushi u tsu dem.
\b
\q1 
\v 7 E nekei ni a takacikai, ɗa a gbarai ni,
\q2 ama n nannai dem u ɓa̱yuwa̱ una̱ u ni ba,
\q1 a lazai n a̱yi tsu ma̱giri ma na i a kubanka a̱ ubuta̱ u kukiɗa,
\q2 n tsu malala ma na o poloi bini a̱ ubuta̱ wa apuwanci,
\q2 u ɓa̱yuwa̱ una̱ u ni ba.
\q1 
\v 8 N atakaci koɓolo n afada ɗa a lazai n a̱yi,
\q2 yayi u kuyaꞋan kadanshi ka ntsukaya n ni?
\q1 Adama na a takpa yi ta̱ punu a̱ ka̱tsuma̱ ki iɗika i wuma,
\q2 ama ɗa a̱ ga̱la̱i ni adama a̱ unushi u uma a̱ va̱.
\q1 
\v 9 U saꞋwa kuyaꞋanka vuza ili i gbani-gbani ba,
\q2 Ko kadanshi ka gbani-gbani ka saꞋwa kuta̱ una̱ u ni ba,
\q1 a zuwai ni a kasaun ka vuza vu uciyi,
\q2 ɗa a̱ ciɗa̱ngi ni tsu vuza vu ma̱ga̱la̱ka̱.
\b
\q1 
\v 10 N nannai dem, ucikali u Vuzavaguɗu a ɗa ciya̱ u takacika yi, ka̱ta̱ u zuwa yi una̱mgbuka̱tsuma̱.
\q2 Ko an Vuzavaguɗu u bonokoi wuma u ni kuneꞋe ku unushi,
\q2 wi ta̱ e kene ntsukaya n ni ka̱ta̱ u doku ayin a wuma u ni,
\q1 ka̱ta̱ ofoɓuso a singai a Vuzavaguɗu o yongo e ekiye a̱ ni.
\q1 
\v 11 Ayin a na baci atakaci a̱ ka̱ɗu a̱ ni a lazai,
\q2 wi ta̱ e kene kutashi ku wuma ka̱ta̱ u pana uyo,
\q1 n kuyeve ku ni kagbashi ku usuɓi ka̱ va̱ ki ta̱ a kisa uma n a̱bunda̱i,
\q2 ka̱ta̱ kpamu u canuku a̱miki a̱ unushi e le ra̱ka̱.
\q1 
\v 12 Adama a nannai mi ta̱ e kuneke yi ugboku a̱ ka̱tsuma̱ ku u gbayin,
\q2 ka̱ta̱ u pece i na a̱ pura̱i gbani koɓolo n aza a utsura a,
\q1 adama a na u neke ta̱ wuma u ni adama a na u kuwa̱,
\q2 ɗa kpamu e kecei ni a̱ ka̱tsuma̱ ka aza a ugbamukaci.
\q1 Adama a na u ɗika ta̱ unushi u uma n a̱bunda̱i,
\q2 ɗa kpamu u yaꞋin kavasa adama a aza a ugbamukaci wa.
\c 54
\s1 Tsugbayin tsu Urushelima tsu na ci kelime
\q1 
\v 1 Vuzavaguɗu u danai, <<YaꞋan ishipa avu madari ma vuka,
\q2 avu na ka̱ta̱ vu saꞋwai kumatsa maku ba,
\q1 ɓosongu vishipa ka̱ta̱ vu orukpo adama a̱ ma̱za̱nga̱,
\q2 avu na vu saꞋwai a̱ga̱nda̱ a limata ba,
\q1 adama a na ka̱bunda̱i ka̱ muku n vuka vu na vi madari
\q2 ki ta̱ a kulaꞋa ka vuka vu na vi n vali.>>
\q1 
\v 2 <<Doku ka̱ba̱nga̱ ka̱ ma̱va̱li ka̱ nu,
\q2 ba̱rukpa̱ akashi a̱ utsutsu o doku a yaꞋan wanshi.
\q2 Ka̱ta̱ vu shikpa̱ aguta a a yaꞋan utsura mayin,
\q1 vu dokusu awin a yaꞋan ugaɗi,
\q2 vu dokusu le utsura.
\q1 
\v 3 Adama a na vi ta̱ a̱ kuka̱ra̱Ꞌa̱ a̱ ubuta̱ dem usingai n ugula̱ feu,
\q2 ka̱ta̱ ntsukaya n nu n ka̱na̱ iɗika kakau
\q2 ali a̱ da̱sa̱ngu punu a̱ likuci i na yo okpoi ɗe agali.
\b
\q1 
\v 4 <<Ka̱ta̱ vu pana wovon ba, vi a kuyaꞋan feu wono ba.
\q2 Ka̱ta̱ vu pana wovon ba, babu ili i wono i na i kuta̱wa̱ wu kpamu.
\q2 Vo kudoku va ciɓa n ili i wono i na vi yaꞋansai a ayin a na vi ka̱ɗa̱nga̱ni ba,
\q2 koɓolo n una̱mgbuka̱tsuma̱ u na kpamu vi ishi n u ɗa a ayin a na vi ishi babu vali.
\q1 
\v 5 Adama a na Vuza na u yaꞋin nu a̱yi ɗa vali nu,
\q2 kula ku ni ku ɗa Vuzavaguɗu MalaꞋimili.
\q1 Vuza Ciɗa vi Isaraila a̱yi ɗa u shiba̱i nu,
\q2 a̱yi ɗa e ci ɗeke Ka̱shile ka aduniyan ra̱ka̱.
\q1 
\v 6 Vuzavaguɗu wi ta̱ e kuɗeke wu u bonoko,
\q2 tsu vuka vu na o lokoi ɗa a̱ ka̱sukpa̱i ni n una̱mgbuka̱tsuma̱
\q1 tsu vuka vu na vali vi ni vu lokoi,
\q2 a ayin o yolo i savu i ni,>>
\q1 
\v 7 <<M megeshe kenu n loko wu ta̱,
\q2 ama n asuvayali a gbayin mi ta̱ o kubonoko wu.
\q1 
\v 8 Vuzavaguɗu Ka̱shibi ka̱ ɗa̱ u danai,
\q2 a̱ ka̱tsuma̱ ka wupa wa̱ a̱bunda̱i ɗa m paɗai bini ali megeshe kenu,
\q1 ama n ucigi u babu kukotso
\q2 mi ta̱ a kupana asuvayali a̱ nu.>> Vuzavaguɗu ɗa u dansai vuza na u shiba̱i ɗa̱.
\b
\q1 
\v 9 <<N tsu va̱ na wi ta̱ derere n tsu ayin a̱ Nufu,
\q2 ana n kucinai n danai, mini ma ayin a̱ Nufu mi o kudoku kupala aduniyan ba.
\q1 Adama a nannai gogo na n kucina ta̱ mi o kudoku kuyaꞋan wupa n avu ba,
\q2 mi kpamu o kudoku kudansaka wu ba.
\q1 
\v 10 Ko nsansa m puwa̱nka̱
\q2 ka̱ta̱ kpamu aginda a̱ muɗa̱,
\q1 ama ucigi u gbangam u va̱ wi o kukotso wa̱ nu ba,
\q2 uzuwakpani u ma̱ta̱na̱ u va̱ vuza wa kutakpa u ɗa ba,>>
\q2 Vuzavaguɗu vu na wi a kupana asuvayali a̱ nu u danai.
\b
\q1 
\v 11 Vuzavaguɗu u danai, <<Avu Urushelima, likuci i na yi o kusoꞋo atakaci n wunla̱i u mini ma atali, babu vuza na u kuyaꞋanka wu kadanshi ku uremi u ka̱ɗu,
\q2 mi ta̱ a kuvarasaka kumaꞋa ku nu n atali a singai.
\q1 
\v 12 Mi ta̱ a kumaꞋa nshilya n nu n atali a langu-langu,
\q2 utsutsu u nu kpamu n atali a na i tsa̱ a̱ta̱mba̱,
\q1 nshilya m kpaꞋa kpamu n atali a na o yotsoi yaza.
\q1 
\v 13 Vuzavaguɗu wi ta̱ a kuyaꞋanka muku n nu ra̱ka̱ kuyotsongusu,
\q2 ma̱ta̱na̱ ma gbayin mi ta̱ a̱ kuta̱wa̱ u muku n nu.
\q1 
\v 14 N kasingai koɓolo n ka mayun ɗa vo ku yonko,
\q1 ka̱ta̱ kpamu kawuya ka yaꞋan daꞋangi n avu,
\q2 vi a kupana wovon wi ili ba,
\q1 i ta̱ a kutakpa ka kagbanigbani a banka daꞋangi,
\q2 ki a kuyawa ɗevu n avu ba.
\q1 
\v 15 Vuza na baci u kumbai nu n vishili, na lo kusheshe ku va̱ ku ɗa ba,
\q2 vuza na baci u kumbai nu wi ta̱ o kubono wo kokpo n wono.
\b
\q1 
\v 16 <<La̱na̱, Mpa ɗa vuza na n yaꞋin kawakana
\q2 ka na ka̱ tsu fa̱la̱ akina ali a tasa,
\q2 ka̱ta̱ u yuma ucanuku u munuka adama a ulinga u le.
\q1 Mpa ɗa kpamu vuza na u yaꞋin ka̱la̱nga̱shi adama a na u la̱nga̱sa̱,
\q2 
\v 17 Vuzavaguɗu u danai, babu ucanuku u munuka u na a kuyaꞋan adama a̱ ɗa̱ ka̱ta̱ u ɗa u lyaꞋa ɗa̱,
\q2 ka̱ta̱ kpamu i ɓa̱ya̱ngu kelentsu dem ka na ka kubanka ɗa̱ nu nsata.
\q1 Na va ɗaɗa agadu a kagbashi ka Vuzavaguɗu,
\q2 ɗaɗa kpamu wishi u na wu uta̱i wa̱ va̱.>>
\c 55
\s1 Ubaniki u Vuzavaguɗu adama a̱ wishi
\q1 
\v 1 <<Ta̱wa̱i, yaba dem vu na wi a kupana kakuli,
\q2 ta̱wa̱i a̱ ubuta̱ u mini,
\q1 vuza na baci de dem wi n ikebe ba,
\q2 u ta̱wa̱, u tsula ili ka̱ta̱ u lyaꞋa.
\q1 Ta̱wa̱i, i gasa ma̱kya̱n m mani
\q2 babu ikebe ko babu katsupu.
\q1 
\v 2 Yiɗa̱i i zuwai ɗa i la̱nga̱sa̱i ikebe i ɗa̱ a̱ ubuta̱ wi ili i na yi ilikulya ba,
\q2 adama a̱ yiɗa̱i yi a̱ kula̱nga̱sa̱ ikebe i katsupu i ɗa̱ a̱ ubuta̱ wi ili i na yi a̱ kuciya̱ punu ili ba?
\q1 Panakai mu mayin, lyaꞋi ili i singai,
\q2 ka̱ta̱ i ɓa̱nka̱ wuma u ɗa̱ n ilikulyaꞋa i singai.
\q1 
\v 3 Zuwakai mu atsuvu ka̱ta̱ i ta̱wa̱ wa̱ va̱,
\q2 panakai mu, adama a na wuma u ɗa̱ u yongo lo.
\q1 Mi ta̱ a kuyaꞋan uzuwakpani n a̱ɗa̱ u na u kukpa̱ɗa̱ kukotso,
\q2 mi ta̱ e kuneke ɗa̱ ucigi u mayun u na u tsu kpa̱ɗa̱ kukotso tsu na n yaꞋankai Dawuda.
\q1 
\v 4 La̱na̱i, n zuwa yi ta̱ wo okpo magaꞋan a̱ ubuta̱ u uma,
\q2 vuzagbayin n kovonshi ka uma.
\q1 
\v 5 Mayun yi ta̱ e kuɗeke uma a̱ likuci kakau i na i yevei ba,
\q2 ka̱ta̱ likuci i na i yevei ɗa̱ ba i suma a̱ kuta̱wa̱ wa̱ ɗa̱,
\q1 adama a Vuzavaguɗu Ka̱shile ka̱ ɗa̱,
\q2 n Vuza Ciɗa va aza a Isaraila,
\q2 adama a na a̱yi ɗa u nekei ɗa̱ tsugbayin.>>
\q1 
\v 6 La̱nsa̱i Vuzavaguɗu a ayin a na wi kuciya̱,
\q2 ɗekei ni a makyan ma na wi ɗevu.
\q1 
\v 7 YaꞋan vuza gbani-gbani u ka̱sukpa̱ uye u gbani-gbani u ni,
\q2 ka̱ta̱ vuza na u kpa̱ɗa̱i kusuɓa̱ u ka̱sukpa̱ feu kusheshe ku ni,
\q1 yaꞋan u bono u tono Vuzavaguɗu adama a na u pana asuvayali a̱ ni,
\q2 n Ka̱shile ka̱ tsu, a̱yi na u kucinukpaka le unushi u le ba̱ri.
\b
\q1 
\v 8 Vuzavaguɗu u danai,
\q2 <<Adama a na kusheshe ku va̱ ku ɗaɗa kusheshe ku ɗa̱ ba, nwalu n ɗa̱ n ɗaɗa nwalu n va̱ ba.>>
\q1 
\v 9 <<Uteku tsu na gaɗi wi daꞋangi n iɗika,
\q2 ta feu nwalu n va̱ mi daꞋangi nu nwalu n ɗa̱ nannai,
\q2 kusheshe ku va̱ kpamu ku laꞋa ta̱ kusheshe ku ɗa̱.
\q1 
\v 10 Tsu na mini ma zuva n kuta̱nu ku minimatali
\q2 a̱ tsu uta̱ gaɗi,
\q1 ka̱ta̱ kpamu a̱ kpa̱ɗa̱ kubono ɗe
\q2 sai a̱ ta̱na̱ta̱ngu iɗika ali i ɗa i ta̱na̱ ka̱ta̱ i shama,
\q1 nannai aza a̱ vica̱Ꞌa̱ a̱ kuciya̱ kuca̱Ꞌa̱,
\q2 ka̱ta̱ aza a na a kulyaꞋa ilikulya a̱ ciya̱ a lyaꞋa,
\q1 
\v 11 Ta feu kadanshi ka na ka̱ tsu uta̱ una̱ u va̱ ki nannai,
\q2 ka ki o kubono wa̱ va̱ ekiye a agaɗa ba,
\q1 ama ki ta̱ a kushatangu i na n sheshei kuyaꞋan,
\q2 ka̱ta̱ kpamu ka fuɗa ka yaꞋan i na n suꞋuki ni.
\q1 
\v 12 Yi ta̱ a̱ kuta̱ m ma̱za̱nga̱
\q2 ka̱ta̱ kpamu o tono n a̱ɗa̱ m ma̱ta̱na̱,
\q1 nsasan koɓolo n aginda
\q2 i ta̱ o kuɓosongu ishipa a kubana wa̱ nu,
\q1 ka̱ta̱ nɗanga n kakamba ra̱ka̱
\q2 m ɓasa ekiye e le.
\q1 
\v 13 Ubuta̱ u na wi ishi a kumatsasa awana wi ta̱ o kubono wa matsa mambulu,
\q2 ka̱ta̱ kpamu ubuta̱ u na wi ishi u tsu matsa mataci u bono matsa igeɓetsu. U ɗa wi ta̱ a kuyaꞋan kula adama a Vuzavaguɗu,
\q1 n urotu u na u kuyongo ko wannai,
\q2 u na wi kula̱nga̱sa̱ ba.>>
\c 56
\s1 Una̱singai a kubana u uma dem
\q1 
\v 1 Na ɗa ili i na Vuzavaguɗu u danai,
\q1 <<YaꞋin kasingai
\q2 ka̱ta̱ kpamu i yaꞋan ili i na yi derere,
\q1 adama a na wishi u va̱ u yawa ta̱ ɗevu,
\q2 ka̱ta̱ ukuna u wishi u va̱ kpamu wu uta̱ e keteshe.
\q1 
\v 2 Una̱singai u ɗa a kubana u vuza na u ci yaꞋan ili i nampa,
\q2 a̱yi na u tsu reme i ɗa n ugbami,
\q1 vuza na u ci yaꞋan ugulani n kanna ka Ashibi ba,
\q2 ka̱ta̱ kpamu u takpa ekiye a̱ ni a̱ ubuta̱ u kuyaꞋan ki ili i gbani-gbani.>>
\b
\q1 
\v 3 Ka̱ta̱ komoci ka na ki o kutono Vuzavaguɗu ka dansa tsu nampa ba,
\q2 <<Mayu Vuzavaguɗu wi ta̱ e kupece mu n uma a̱ ni.>>
\q1 Ka̱ta̱ kpamu madari ma vali ma̱ kpa̱ɗa̱ kudana,
\q2 <<Mpa maɗanga me ɗeku koci.>>
\p 
\v 4 Na ɗa ili i na Vuzavaguɗu u danai.
\q2 <<A kubana u madari ma vali, a̱yi na wi a̱ kula̱na̱ kanna ka Ashibi ka̱ va̱ mayin,
\q1 a̱yi na u tsu zagba i na i ci yaꞋanka mu uyo
\q2 ka̱ta̱ kpamu u ɓa̱na̱ uzuwakpani u va̱ derere,
\q1 
\v 5 Mi ta̱ e kuneke le kula punu a kpaꞋa ku va̱
\q2 ka̱ta̱ ku ɗa kokpo ili i kuciɓasa a̱ ubuta̱ u uma a̱ va̱
\q1 ku na ku laꞋi ku muku n ali m muku ma̱ a̱ma̱ci,
\q2 mi ta̱ e kuneke le kula ku kowannai
\q2 ku na ki o kukotso ba.
\q1 
\v 6 Omoci a na o bonokoi a̱ɗu e le a̱ ubuta̱ u Vuzavaguɗu,
\q2 adama a na a yaꞋanka yi ulinga,
\q1 a ciga kpamu kula ku Vuzavaguɗu,
\q2 ɗa kpamu a cikpai ni,
\q1 vuza na de dem wi a̱ kuɓa̱na̱ kanna ka Ashibi mayin, ɗa kpamu o kugoyo a ɗa ba,
\q2 ɗa kpamu wi e kureme uzuwakpani u va̱ n utsura,
\q1 
\v 7 ele ɗa n kubanka a kusan ku ciɗa ku va̱,
\q2 ka̱ta̱ kpamu n zuwa le a yaꞋan ma̱za̱nga̱ a kpaꞋa ka avasa ku va̱.
\q1 KuneꞋe ku kusongu ku le koɓolo n alyuka e le
\q2 i ta̱ a̱ kuciya̱ wishi a katalikalyuka ka̱ va̱,
\q1 adama a na kpaꞋa ku va̱ uma ra̱ka̱ i ta̱ e kuɗeke ku ɗa
\q2 kpaꞋa ka avasa ku uma ra̱ka̱.>>
\q1 
\v 8 Vuzavaguɗu MalaꞋimili,
\q2 vuza na u ɓolongi aza a ugbashi a Isaraila u danai,
\q1 <<Mi ta̱ o kudoku mo ɓolonku le uma o yoku
\q2 kau n aza a na m ɓolongi ɗe.>>
\s1 Nsata n Ka̱shile a kubana wa aza a kawuya
\q1 
\v 9 Ta̱wa̱i ra̱ka̱ a̱ɗa̱ nnama n kakamba,
\q2 ta̱wa̱i ra̱ka̱ a̱ɗa̱ nnama n kutsun. Ta̱wa̱i i kpa̱ta̱ra̱ uma a̱ va̱.
\q1 
\v 10 Aza a kindi a Isaraila a̱yimba̱ a ɗa,
\q2 ra̱ka̱ vi le i n kuyeve ba,
\q1 nsheꞋe n ka̱bini n ɗa i,
\q2 a ci yaꞋan wali ba,
\q1 o ci yongo ta̱ ucigi wa alavu ka̱u,
\q2 sai alatani a ɗa o ci yongo a kuyaꞋan.
\q1 
\v 11 Ele nsheꞋe n ɗa n na mi n kutsa̱n ka̱u,
\q2 ili i ci yawa le ba.
\q1 Ele nguɓi n ɗa n na mi n unambi u kuyeve,
\q2 yaba dem vu le u ɓatsai a uye u ni,
\q2 yaba dem vu le a̱ kula̱nsa̱ i na i kuꞋuwa yi.
\q1 
\v 12 Yaba dem u danai, <<Ta̱wa̱i, yaꞋan ci ciya̱ ma̱ra̱,
\q2 yaꞋan kpamu tsu soꞋo ka̱ta̱ ma maka tsu.
\q1 Ka̱ta̱ kpamu mkpa tsu doku ci yaꞋan nannai ali
\q2 u laꞋa tsu nanlo.>>
\c 57
\q1 
\v 1 Vuma vu usuɓi u tsu geshe ba,
\q2 ama babu vuza na u keɓecei,
\q1 a̱ pura̱ ta̱ aza a usuɓi ra̱ka̱,
\q2 ama babu vuza na u yevei.
\q1 Mayun a yaꞋan ta̱ nannai
\q2 adama a na e pece le a̱ ubuta̱ u kuyaꞋan ka gbani-gbani.
\q1 
\v 2 Aza a na a walai derere i ta̱ o
\q2 kuyongo m ma̱ta̱na̱,
\q1 i ta̱ kpamu a̱ kuciya̱ wuvuki a ayin a na baci a̱ kuwa̱i.
\q1 
\v 3 <<Ama a̱ɗa̱ ta̱wa̱i na,
\q2 a̱ɗa̱ muku mo olobo mo oboci, a̱ɗa̱ ntsukaya ma aza a tsugbani koɓolo n ashakanlai.
\q1 
\v 4 Yayi yo o kuzoꞋosoko?
\q2 Yayi i ɓa̱yuwa̱ka̱i una̱ ɗa kpamu
\q1 yi a̱ kumeɗeke una̱?
\q2 Ashe a̱ɗa̱ muku mu ugbamukaci n ɗa yi ba?
\q1 Kumaci ka aza a aꞋuwa?
\q1 
\v 5 Yi a kucikpa a̱ma̱li a̱ ɗa̱ m mali ma gbani-gbani
\q2 asuvu a nɗanga n oku koɓolo n ubuta̱ wu nɗanga n na n kimba̱i dem,
\q1 ɗa i kiɗai muku n ɗa̱
\q2 punu a̱ a̱ra̱Ꞌa̱ n angu a akpanlai.
\q1 
\v 6 Vi ɗikai atali a ugbori a̱ ka̱ra̱Ꞌa̱ ɗa vu bonokoi a ɗa a̱ma̱li o kutono a̱ nu,
\q2 ele ɗa i na vi ciya̱i.
\q1 Mayu, we le u ɗa i nekei kuneꞋe ki ili kusoꞋo
\q2 koɓolo n kuneꞋe ki ili i kashina.
\q2 Ɗa i kudana m pana uyoꞋo ba?
\q1 
\v 7 Gaɗi ɗe zuva a kusan ku leku ɗa vu poloi ɗe kajiba ka̱ nu,
\q2 ɗa vu banai ɗe a̱ ubuta̱ wa adama a na vi yaꞋan alyuka a̱ nu.
\q1 
\v 8 A̱ kucina̱ ku utsutsu u nu koɓolo n iga̱Ꞌin a̱ utsutsu a̱ nu a
\q2 ɗa vu zuwai ɗe urotu wa̱ a̱ma̱li a̱ nu dem.
\q1 Vu ka̱sukpa̱i mu ɗa vu vaki a kajiba koɓolo n a̱ma̱li a unata a nanlo,
\q2 ɗa vu nekei ka̱ɗu ka̱ nu we le,
\q1 ɗa vi yongoi a kucikalasa
\q2 vi inda ciyampa ci le.
\q1 
\v 9 Vu banai u ka̱ma̱li Moleki m maniꞋin ma zaitu
\q2 ɗa kpamu vu doki ili i ma̱gula̱ni i nu.
\q1 Vu suki alingata a̱ nu daꞋin,
\q2 ɗa avu a̱ ka̱ci ka̱ nu vu cipa̱i a̱ ubuta̱ wa asaun.
\q1 
\v 10 Vo oꞋusoi ka̱ci ka̱ nu n ukuna u kutoni u nu dem,
\q2 ama vu dana, <Mo oꞋwo ta̱ ba>
\q1 Vu ciya̱ka̱i ka̱ci ka̱ nu utsura u savu,
\q2 ɗaɗa ta na vu kpa̱ɗa̱i kuka̱sukpa̱.
\b
\q1 
\v 11 <<U yayi vi e kujeꞋeke ikyamba n wovon,
\q2 ali ɗa vi yaꞋankai mu aꞋuwa,
\q1 ɗa kpamu vi cinukpai nu mpa
\q2 ɗa vu kpa̱ɗa̱i kuciɓa nu mpa.
\q1 Adama a na n yaꞋan ta̱ megeshe mpa bini?
\q2 i ɗaɗa i zuwai ɗa i kpa̱ɗa̱i kupana wovon u va̱?
\q1 
\v 12 Mi ta̱ a̱ ku uta̱ka̱ usuɓi u nu n i na vi yaꞋansai e keteshe,
\q2 ama i ɗa yi o kudoku wu ili ba.
\q1 
\v 13 Ayin a na baci vu lapai una̱ adama a̱ uɓa̱nki,
\q2 yaꞋan a̱ma̱li a na vu ɓolongi va a isa wu.
\q1 Wunla̱i wi ta̱ a ɗika le ra̱ka̱,
\q2 ka̱ta̱ ayinviki feu a̱ pura̱ngu le.
\q1 Ama a̱yi na u la̱nsa̱i ubuta̱ u kusheɗeku wa̱ va̱,
\q2 wi ta̱ a̱ kuka̱na̱ iɗika ya yo okpo i ni
\q2 ka̱ta̱ kpamu wo okpo vuza na u kuka̱na̱ kusan ku ciɗa ku va̱.>>
\s1 Ka̱shile ka cinukpakai aza unushi
\p 
\v 14 Ka̱shile ka danai,
\b
\q1 <<Lapulai, lapulai, lapulai uye mayin.
\q2 Takpai a̱guli a na i lo a uye u uma a̱ va̱ dem.>>
\q1 
\v 15 Na ɗa ili i na vuza na wi a̱da̱nga̱shile n ucikpi,
\q2 a̱yi na wi n wuma ko wannai, vuza na kula ku ni ki ciɗa u danai.
\q1 <<Mi ta̱ ida̱shi na gaɗi n ubuta̱ u ciɗa,
\q2 koɓolo kpamu n uma a na i n ka̱ɗu yuwu babu a̱ra̱ɗi,
\q1 adama a na n zuwa aza a na i n una̱mgbi wa̱ a̱tsuma̱ e reme a̱ɗu
\q2 ka̱ta̱ kpamu n dokusu aza o yoku utsura wa̱ a̱ɗu.
\q1 
\v 16 Mpa mi a kulyaꞋa kelime n kushila̱ka̱ n a̱ɗa̱ ba,
\q2 ko n yongo a wupa ayin tutu,
\q1 nannai wi ta̱ a kuzuwa ka̱ɗu ka vuma kuyongo ulimi a̱ kuta̱wa̱ wa̱ va̱,
\q2 ayinviki a vuma a na mpa n yaꞋin n ekiye a̱ va̱.
\q1 
\v 17 N yaꞋin wupa adama a̱ unushi u ni,
\q2 n takacikai ni ɗa kpamu n zuwakai ni kucina̱ adama a wupa,
\q1 ama n nannai dem u lyaꞋi kelime n kuyaꞋan ili i kavama i ni.
\q1 
\v 18 Mpa mene ta̱ nwalu n ni,
\q2 ama mi ta̱ o kupotsotongu yi, mpa n kutono ta̱ n a̱yi ka̱ta̱ m bonoko yi n ida̱shi i ma̱ta̱na̱,
\q2 
\v 19 a̱ kutuka̱ n kadanshi ka kucikpa Ka̱shile a̱ una̱ u le.
\q1 YaꞋan a̱ ciya̱ ma̱ta̱na̱ ma̱ a̱bunda̱i, ali na ɗe a̱ mpulu n ɗevu dem,>>
\q2 Vuzavaguɗu u danai, <<Mpa n kupotsotongu le ta̱.
\q1 
\v 20 <<Ama aza a na a ci yaꞋan ili i wuya i ta̱ tsu mala ma na mo ci yongo a kuvuzukpa,
\q2 babu kupaɗa bini,
\q1 aɓau a̱ ni a̱ tsu utuka̱ ta̱ n kolyon koɓolo n cilili.
\q1 
\v 21 Ka̱shile ka̱ va̱ ka danai, <<Ma̱ta̱na̱ mi lo adama a vuza vu kawuya ba.>>
\c 58
\s1 Kuka̱na̱ ku una̱ ku mayun
\q1 
\v 1 Vuzavaguɗu u danai, <<Shika̱i n kacaꞋa, ka̱ta̱ i kpa̱ɗa̱ ba,
\q2 ɗengusa̱i a̱la̱ka̱tsu a̱ ɗa̱ adanshi ishari ɗa.
\q1 Dansukai uma a̱ va̱ adama a ugbamukaci u le,
\q2 ka̱ta̱ kpamu i sala ukuna wu unushi u kpaꞋa ku Yakubu.
\q1 
\v 2 O ci yongo ta̱ a kucikpa mu ayin tutu
\q2 ka̱ta̱ kpamu o yongo a̱ ma̱za̱nga̱ ma na e yeve nwalu n va̱,
\q1 adanshi uma o yoku a ɗa a na i ishi i ci yaꞋan ukuna u singai
\q2 ɗa kpamu a̱ kpa̱ɗa̱i kuka̱sukpa̱ wila̱ u Ka̱shile.
\q1 E ci ece mu ta̱ ciya̱ m ɓa̱nka̱ le n afada a mayun
\q2 ɗa kpamu u yaꞋin adanshi i ta̱ a̱ ma̱za̱nga̱ ma na a̱ ta̱wa̱ a cikpa Ka̱shile.
\q1 
\v 3 A danai, <Yiɗa̱i i zuwai ɗa tsu ka̱na̱i una̱,
\q2 ɗa Vuzavaguɗu u kpa̱ɗa̱i ku cikpa i na ci yaꞋin?
\q1 Ci nekei ikyamba i tsu atakaci,
\q1 ama vu kpa̱ɗa̱i kucoꞋoko?>
\b
\q1 Vuzavaguɗu wu ushuki, <<La̱na̱i, a kanna ka na i kuka̱na̱ una̱, i ci yaꞋan ta̱ tsu na u yokpoi ɗa̱
\q2 ka̱ta̱ i takacika aza a ulinga ɗa̱ ra̱ka̱.
\q1 
\v 4 La̱na̱i, i ka̱na̱ ta̱ una̱ koci
\q2 ka̱ta̱ i yaꞋan kanananai n vishili ka̱ta̱ i lapanai n a̱kun a gbani-gbani.
\q1 Yi a̱ kuka̱na̱ una̱ tsu na i yaꞋin anana,
\q2 ka̱ta̱ i ciga a pana a̱la̱ka̱tsu a̱ ɗa̱ na ɗe gaɗi ba.
\q1 
\v 5 IcuꞋu i kuka̱na̱ ku una̱ ku nampa ku ɗa n zagbai,
\q2 kanna ke te koci adama a na vuma u bono u goyo ka̱ci ka̱ ni?
\q1 A kanna ka ɗaɗa u kuja̱lika̱ kaci ka ni tsu nkoru,
\q2 ka̱ta̱ kpamu u vaku n akashi o kokomo?
\q1 Na ɗa ili na vu ɗekushei kuka̱na̱ ku una̱,
\q2 kanna ka na Vuzavaguɗu wu ushuki n kaꞋa?
\b
\q1 
\v 6 <<Na ɗa kuka̱na̱ ku una̱ ku na n zagbai,
\q2 adama na i shikpa aza a na i atakaci,
\q1 ka̱ta̱ kpamu i cipuka̱ a̱miki a na i e eɗeku a uma,
\q2 i zuwa aza a na i a̱ ka̱tsuma̱ ka atakaci a̱ ba̱ruwa̱,
\q1 ali i koɗo kaburakpatsu ka atakaci u uma
\q1 
\v 7 Pece ilikulyaꞋa i nu n aza a kambulu,
\q2 ka̱ta̱ kpamu i tuka̱ n aza a na i n iꞋuwa ba, a iꞋuwa i ɗa̱,
\q1 ve ene baci vuza koshomboɗi, pala yi,
\q2 ka̱ta̱ vu sokongu a̱shi a̱ nu a̱ ubuta̱ u vuza nu ba.
\q1 
\v 8 I yaꞋan baci nannai, kutashi ku ɗa̱ ki ta̱ a kakana tsu wakani wu usana,
\q2 ka̱ta̱ kpamu usa̱n u ɗa̱ u ta̱na̱ gogoꞋo,
\q1 kasingai ka̱ ɗa̱ ki ta̱ a kuwala n a̱ɗa̱,
\q2 ka̱ta̱ wishi u Vuzavaguɗu wo okpo ili i na i kinda ɗa̱ mayin.
\q1 
\v 9 Ka̱ta̱ gogo na i ɗeke, Vuzavaguɗu wi ta̱ a̱ kushuku ɗa̱,
\q2 I shika̱ adama a na u ɓa̱nka̱ ɗa̱, wi ta̱ ta na a kudana, <Mpa ɗa na.>
\b
\q1 <<I ka̱sukpa̱ baci a̱miki a ukuna u gbani a na i caniki,
\q2 n ukuna u masapangbanai ma̱ a̱jivu koɓolo n kuyaꞋan ku kadanshi ka kavama,
\q1 
\v 10 ɗa baci i bonokoi ka̱ci ka̱ ɗa̱ tsa aza a kambulu
\q2 ɗa kpamu i ɓa̱nka̱i aza a na i o kusoꞋo atakaci,
\q1 kutashi ku ɗa̱ ki ta̱ a kakana a̱ ubuta̱ u ka̱yimbi,
\q2 ka̱ta̱ ka̱yimbi ka na ki ɗevu n a̱ɗa̱ kokpo an kutashi ku kanna.
\q1 
\v 11 Vuzavaguɗu wi ta̱ a kinda ɗa̱ ayin dem,
\q2 wi ta̱ e kuneke ɗa̱ ili na i cigai a ubuta̱ u na u canai ba,
\q2 ka̱ta̱ kpamu u dokusu ikyamba i ɗa̱ utsura.
\q1 Nannai wi ta̱ a kuzuwa yo okpo an kashina ki ishiꞋwan ka na ka̱ ciya̱i kuta̱nu mayin, n uteku tsu kuyene ku na mini ma̱ ni ma̱ tsu kpa̱ɗa̱ kuɗekpe.
\q1 
\v 12 Yi ta̱ a kumaꞋasaka likuci i cau i ɗa̱ i na yi ishi yo okpoi agali,
\q2 yi ta̱ a̱ kuɗa̱ngusa̱ kumi ka aza a na ishi lo ali n tsumani,
\q1 ka̱ta̱ kpamu e ɗeke ɗa̱ Alapuli a Nshilya n na m ɓosoi,
\q2 koɓolo n Alapuli a Uye a̱ ubuta̱ u na uma a̱ tsu da̱sa̱ngu.
\b
\q1 
\v 13 <<I ka̱na̱ kanna ka Ashibi adama a na kokpo ciɗa,
\q2 i ka̱sukpa̱ kutono mali ma̱ ɗa̱ a kanna ka nanlo,
\q1 ama i kucukpa i pana uyo u kanna ka Ashibi ka, ka̱ta̱ i dansa ukuna u kaꞋa n a̱ɗu a̱ ɗa̱ a̱ ma̱za̱nga̱ tsu
\q2 kanna ka ciɗa ka Vuzavaguɗu.
\q1 I cikpa kanna ka Ashibi ka n ili i na i kuyaꞋan a kanna ka nanlo dem,
\q2 ka̱ta̱ i tono mali ma̱ ɗa̱ ko i dansa ukuna u kavama ba,
\q1 
\v 14 nannai ɗa i kuciya̱ ma̱za̱nga̱ ma̱ ɗa̱ a̱ ubuta̱ u Vuzavaguɗu,
\q2 ka̱ta̱ kpamu n zuwa ɗa̱ i yongo ubuta̱ u ɓati wi iɗika i gaɗi koɓolo n ka̱ɗiva̱ ɗe ubuta̱ wa agadu wa̱ esheku a̱ ɗa̱ Yakubu.>> Vuzavaguɗu ɗa u dansai nannai n una̱ u ni.
\c 59
\s1 Unushi, kushika̱ ku unushi n ushibi
\q1 
\v 1 Panai, kukiye ku Vuzavaguɗu ku gusa̱ ali ku ɗa kukpa̱ɗa̱ kisa ɗa̱ ba,
\q2 ko kutsuvu ku ni ku gulana ali u kpa̱ɗa̱ kufuɗa kupana ba.
\q1 
\v 2 Ama unushi u ɗa̱
\q2 u pece ɗa̱ ta̱ n Ka̱shile ka̱ ɗa̱,
\q1 ukuna u wuya u ɗa̱ u ɗa u zuwai u sheɗeki n a̱shi a̱ ni
\q2 adama a na u kpa̱ɗa̱ kupanaka ɗa̱.
\q1 
\v 3 Adama a na ekiye a̱ ɗa̱ a̱ na̱mgba̱ ta̱ nu mpasa m munuka,
\q2 a̱jivu a̱ ɗa̱ kpamu a shana ta̱ tukpa n unushi.
\q1 Una̱ u ɗa̱ u dansa ta̱ aꞋuwa,
\q2 elentsu a̱ ɗa̱ kpamu a dansa ta̱ kadanshi ka wuya.
\q1 
\v 4 Babu vuza na u cigai afada a mayun,
\q2 babu kpamu vuza na u folonoi a yaꞋanka yi afada a singai.
\q1 A zuwai katsura ke le a̱ ubuta̱ u kadanshi ka aꞋuwa,
\q2 e sheshei ukuna u gbani-gbani u ɗaɗa u bonoi u vazai kawuya.
\q1 
\v 5 A tsu gyaꞋwan ta̱ oko a gbani-gbani
\q2 ka̱ta̱ kpamu a caꞋa tsugbere tsu kanata.
\q1 Vuza na baci de dem u takumai okowo a̱ ni wi ta̱ a̱ kukuwa̱,
\q2 kokowo ka na baci de dem ko ɓosoi, koko kaꞋa ki a̱ kuta̱.
\q1 
\v 6 Tsu na tsunata ci le ci a kufuɗa kucaꞋa kuminya ba,
\q2 ta feu nannai i a kufuɗa kupala ka̱ci ke le ni ili i na a yaꞋin ba.
\q1 Ulinga u le ra̱ka̱ wi ta̱ tukpa n kawuya,
\q2 ibori i vishili i ɗaɗa le ili i kuyaꞋan.
\q1 
\v 7 A ci yaꞋan ta̱ moloko a̱ ubuta̱ u kuyaꞋan ku unushi,
\q2 koɓolo m moloko mu ubuta̱ u kuna aza a na i babu unushi.
\q1 Ukuna wu unushi u ɗa o ci yongo e kusheshe koci,
\q2 asuvu awuya n vishili ɗaɗa ili i na o ci yonko.
\q1 
\v 8 E yeve uye u ma̱ta̱na̱ ba,
\q2 ko tsu na o kuyongo n ugaꞋin ba.
\q1 O bonokoi uye u le uye wa atakaci,
\q2 babu kpamu vuza na wi a kuwala a uye u le ɗa u yevei ili i na e ci ɗeke ma̱ta̱na̱.
\q1 
\v 9 Ci m ma̱ta̱na̱ a̱ ubuta̱ u tsu ba,
\q2 usuɓi feu wi punu a̱ a̱ɗu a̱ tsu ba.
\q1 Tsu la̱nsa̱i kutashi, ama kucikpa ce enei ka̱yimbi.
\q2 Tsu la̱nsa̱i wakani na ɗe gaɗi, ama ɗa tsu kucukpai tsu walai a̱ ka̱ta̱m.
\q1 
\v 10 Ci yongoi a kupapa tsusaki tsu ka̱yimba̱,
\q2 a̱ kula̱nsa̱ uye tsu uma a na i n a̱shi ba.
\q1 N kanna e keteshe ci yongoi a̱ kuta̱ɗa̱tsa̱sa̱ adanshi ka̱yimbi kaꞋa ki lo,
\q2 a̱ ka̱tsuma̱ ka aza a utsura ɗa tso okpoi a na a̱kpisa̱.
\q1 
\v 11 Ci yongoi a̱ yura̱ dem vu tsu tsa anama,
\q2 tsu ka̱na̱i ma̱shi tsu moɗoi.
\q1 Tsu la̱nsa̱ ta̱ afada a singai, ama ci ciya̱ ba,
\q2 tsu la̱nsa̱i kpamu wishi ama ci ciya̱ u ɗa ba.
\b
\q1 
\v 12 Adama a na unushi u tsu u yaꞋan ta̱ a̱bunda̱i wa̱ nu,
\q2 unushi wa kpamu wu uta̱ka̱ tsu ta̱ e keteshe.
\q1 Unushi u tsu wi ta̱ punu koɓolo n a̱ tsu,
\q2 a̱ tsu ta na feu ci uyevi n u ɗa,
\q1 
\v 13 Ci yeve ta̱ a na ci yaꞋin ugbamukaci ɗa tsu nanai Vuzavaguɗu.
\q2 Tsu zuwakai Ka̱shile ka̱ tsu kucina̱,
\q1 ci yeve ta̱ tsu na tsu kpa̱ɗa̱i kuyaꞋan i na yi derere,
\q2 a kudansa aꞋuwa a na i tukpa a̱ a̱ɗu a̱ tsu.
\q1 
\v 14 Kasingai ka̱ kpa̱ɗa̱i kudoku kuyaꞋan ulinga,
\q2 ɗa tsu zuwai usuɓi u shamgbai daꞋangi n a̱ tsu,
\q1 ukuna u mayun u buwa kuciya̱ a̱ ubuta̱ u uma ba,
\q2 ama a̱ tsu ci iwain kuyaꞋan ka mayun.
\q1 
\v 15 Ukuna u mayun u buwa kuciya̱ ba,
\q2 vuza na baci u iwain kawuya i ta̱ a̱ kugba̱da̱la̱ngu yi.
\b
\q1 Vuzavaguɗu u la̱na̱i ɗa u kpa̱ɗa̱i kupana uyo
\q2 an kasingai ko kotsoi.
\q1 
\v 16 Ɗa we enei babu vuza na u buwai lo
\q2 a na wa uwa e mere ko u ɓa̱nka̱ aza a na i o kusoꞋo atakaci.
\q1 Ɗa a̱yi a̱ ka̱ci ka̱ ni u uwai adama a na wi isa le n kukiye ku utsura ku ni,
\q2 ɗa ta na ukuna u singai u ni u tonoi n a̱yi.
\q1 
\v 17 U ukai usuɓi wo okpoi ni an ma̱ra̱ga̱ mi ikyamba,
\q2 m ma̱kun ma̱ wishi a kaci ka̱ ni,
\q1 u ukai ka̱ci ka̱ ni motogu ma na u kutsupaka,
\q2 ɗa kpamu u lapangi mali ma kuyaꞋan ili i singai tsu kalaba.
\q1 
\v 18 Derere uteku wi ili,
\q2 nannai ɗa u kutsupa irala i ni
\q1 n wupa u gbayin koɓolo n kawuya dem,
\q2 wi ta̱ kpamu a kutsupa aza a na i a iɗika yo otogu i na a yaꞋin.
\q1 
\v 19 Ili i na i ɗikai a̱ ka̱livi, uma i ta̱ a kupana wovon u kula ku Vuzavaguɗu,
\q2 ka̱ta̱ ili i na i ɗikai a kasana a̱ gita̱ kupana wovon u tsugbayin.
\q1 Adama na a̱yi wi ta̱ a̱ kuta̱wa̱ tsu kuɗolu ku na ki e kuyene n utsura,
\q2 ku na wunla̱i u Vuzavaguɗu wi a̱ kuvula̱ ka̱u.
\b
\q1 
\v 20 Vuzavaguɗu u danai, <<Ka̱shibi ka ki ta̱ a̱ kucipa̱ a Sihiyona,
\q2 wa aza a Yakubu ele na a̱ shika̱i unushi u le.>>
\p 
\v 21 Vuzavaguɗu u danai <<Na ɗa uzuwakpani u va̱ n ele, n neke ɗa̱ ta̱ ayinviki a̱ va̱, n kadanshi ka̱ va̱, ka̱ta̱ kadanshi ka nanlo ka̱ ka̱sukpa̱ una̱ u ɗa̱, m muku n ɗa̱, ko una̱ wu ntsukaya n ɗa̱ ba. Na uzuwakpani u ɗa u gogo na ali a kubana uteku.>>
\c 60
\s1 Tsugbayin tsu Urushelima tsu na ci kelime.
\q1 
\v 1 <<Ɗenga̱, ka̱ta̱ vu akana adama a na kutashi ku nu ku yawa ta̱,
\q2 tsugbayin tsu Vuzavaguɗu ci cipa̱ ta̱ wa̱ nu.
\q1 
\v 2 La̱nuku, ka̱yimbi ka pala ta̱ aduniyan ra̱ka̱,
\q2 ɗa ka̱yimbi ka gbangam ka palai uma,
\q1 ama wa̱ nu u ɗa kutashi ku Vuzavaguɗu ki a kakana,
\q2 tsugbayin ci ni tsu ta̱wa̱ wa̱ nu.
\q1 
\v 3 Aduniyan dem i ta̱ a̱ kuta̱wa̱ a̱ ubuta̱ u kutashi ku nu,
\q2 ngono tamkpamu i ta̱ a̱ kuta̱wa̱ a̱ ubuta̱ u kutashi ku usana ku nu.
\b
\q1 
\v 4 <<Ɗengusa̱ a̱shi a̱ nu vu ka̱ra̱ka̱ a̱ ubuta̱ dem,
\q2 ka̱ta̱ ye ene tsu na o ɓolongi a̱ ubuta̱ u te, ɗa a̱ ta̱wa̱i wa̱ nu,
\q1 muku n ɗa̱ mi ta̱ a̱ kuta̱ daꞋangi,
\q2 ɗa a̱ ka̱na̱i nkere n nu e ekiye.
\q1 
\v 5 A̱shi a̱ nu i ta̱ e kene ka̱ta̱ a tasa,
\q2 ka̱ɗu ka̱ nu ki ta̱ a kushana ka̱ta̱ ka shita adama a̱ ma̱za̱nga̱,
\q1 uciyi u na wi a mala i ta̱ a̱ kutuka̱ u ɗa wa̱ nu,
\q2 wa̱ nu u ɗa uciyi wa aduniyan ra̱ka̱ u kubono.
\q1 
\v 6 Ka̱bunda̱i ka arakuma ki ta̱ a kupala wu,
\q2 arakuma a wawaꞋa a Midiya koɓolo n Ifa,
\q1 aza na i a Sheba ra̱ka̱ i ta̱ a̱ kuta̱wa̱,
\q2 ucaniki n azanariya koɓolo n ili i ma̱gula̱ni,
\q2 n a salai ukuna u kucikpa Vuzavaguɗu.
\q1 
\v 7 Ushiga wi ilikuzuwa ya aza a Kida i ta̱ o kuɓolongu u ɗa wa̱ nu,
\q2 a̱giri a aza a Nebatu i ta̱ a kuyaꞋanka wu ulinga,
\q1 i ta̱ a kisa a ɗa ci ili i kuneꞋe a katalikalyuka ka̱ va̱,
\q2 ka̱ta̱ kpamu n lapulaka kpaꞋa ku singai ku va̱.
\b
\q1 
\v 8 <<Anan yayi a imkpai gaɗi tsa eleshu tsa,
\q2 tsu moɗoi a kubana a̱ ubuta̱ u cikinda u le?
\q1 
\v 9 Mayun aza o kotogu i ta̱ a kuzuwa a̱pa̱Ꞌa̱ e le wa̱ va̱,
\q2 antsu a aza a Tarishi a ɗa o kokpo aza a ugiti,
\q1 a̱ kutuka̱ muku n ɗa̱ na ɗe daꞋangi,
\q2 koɓolo n azurufa n azanariya e le,
\q1 adama a kucikpa kula ku Vuzavaguɗu Ka̱shile ka̱ ɗa̱,
\q2 n Vuza Ciɗa va aza a Isaraila,
\q2 adama a na a̱yi ɗa u zuwai nu vo okpo n tsuloboi.
\b
\q1 
\v 10 <<Omoci i ta̱ a kumaꞋasaka ɗa̱ nshilya n ɗa̱,
\q2 ka̱ta̱ ngono n le mo okpo aza a na a kuyaꞋanka ɗa̱ tsugbashi,
\q1 ko a na wi n wupa u ɗa n lapai ɗa̱,
\q2 ama n ucigi u ɗa n kuyotsongu ɗa̱ asuvayali a̱ va̱.
\q1 
\v 11 Utsutsu u ɗa̱ wi ta̱ o kuyongo uɓa̱yuwi ayin tutu,
\q2 a̱ kuɓa̱ya̱ngu u ɗa ba kanna n kayin dem,
\q1 adama a na uma a̱ tuka̱ wu n uciyi wa aduniyan dem,
\q2 n ngono n le a kuwalaka le kelime udari a̱ kuta̱wa̱ wa̱ nu.
\q1 
\v 12 Adama a na iɗika ko tsugono tsu na tsu tonoi nu ba, ci ta̱ a̱ kukuwa̱,
\q2 i ta̱ o kubonoko i ɗa agali ra̱ka̱-ra̱ka̱.
\b
\q1 
\v 13 <<Tsugbayin tsa aza a Lebano ci ta̱ a̱ kuta̱wa̱ wa̱ nu,
\q2 koɓolo nu nɗanga n singai sipirus n firi, n pini dem,
\q1 adama a na n lapulaka ubuta̱ u ma̱va̱li ma̱ va̱,
\q2 ka̱ta̱ kpamu n neke ubuta̱ u kuzuwa adasukpatsu a̱ va̱ tsugbayin.
\q1 
\v 14 Muku ma aza a na a takacikai ɗa̱ mi ta̱ a̱ kuta̱wa̱ ka̱ta̱ a̱ kuɗa̱nku ɗa̱,
\q2 aza a na o goyoi ɗa̱ dem i ta̱ a̱ kuta̱wa̱ ka̱ta̱ a̱ kuɗa̱ngu a idasakpatsu i ɗa̱,
\q1 ka̱ta̱ e ɗeke ɗa̱ likuci i Vuzavaguɗu,
\q2 Sihiyona vu ciɗa va aza a Isaraila.
\b
\q1 
\v 15 <<Ko an wi ishi a iwain nu ɗa a̱ ka̱sukpa̱ nu,
\q2 ali babu vuza te vu na u kuwala punu a̱ ubuta̱ u nu,
\q1 mi ta̱ o kubonoko wu ili ya̱ a̱ra̱ɗi i na i kukotso ba,
\q2 koɓolo m ma̱za̱nga̱ ma babu uteku.
\q1 
\v 16 Yi ta̱ a kupana uyo wi uciyi wa aduniyan,
\q2 ka̱ta̱ a lyatangu ɗa̱ n ilikulya yi ngono.
\q1 Nannai ɗa i kuyeve a na Mpa ɗa Vuzavaguɗu, Kishi ka̱ ɗa̱
\q2 n Ka̱shibi ka̱ ɗa̱, Vuzagbayin va aza a Isaraila.
\q1 
\v 17 A na me neke ɗa̱ viyum vi shili yaꞋan n kucukpa n neke ɗa̱ azurufa,
\q2 n azanariya o okpo una̱ u vuyum.
\q1 Ka̱ta̱ n neke ɗa̱ viyum vi shili a̱ una̱ wu nɗanga,
\q2 vuyum tamkpamu vo okpo una̱ wa atali.
\q1 Ka̱ta̱ n zuwa ma̱ta̱na̱ mo okpo vuzagbayin vu ɗa̱,
\q2 usuɓi tamkpamu wo okpo mogono ma̱ ɗa̱.
\q1 
\v 18 Ibori i vishili yo kudoku ya yaꞋan a iɗika i nu ba,
\q2 babu kula̱nga̱su ko moɓosu mu ubuta̱ a uteku wi iɗika i ɗa̱,
\q1 ama yi ta̱ e kuɗeke nshilya n ɗa̱ nshilya mu wishi,
\q2 i ɗeke utsutsu u ɗa̱ kpamu ucikpi.
\q1 
\v 19 Kanna ki o kudoku kuneke ɗa̱ kutashi n kanna ba,
\q2 ko kutashi ku wotoi ku akana ɗa̱,
\q1 adama a na Vuzavaguɗu wi ta̱ kokpo kutashi ku ɗa̱ ku na ko kukotso ba,
\q2 ka̱ta̱ Ka̱shile ka̱ ɗa̱ kpamu kokpo tsugbayin tsu ɗa̱.
\q1 
\v 20 Kanna ka̱ ɗa̱ ko kudoku kuta̱ ba,
\q2 ka̱ta̱ wotoi feu u kpa̱ɗa̱ kuta̱,
\q1 Vuzavaguɗu wi ta̱ o kokpo kutashi ku ɗa̱ ku ko wannai,
\q2 ka̱ta̱ ayin a̱ una̱mgbuka̱tsuma̱ a̱ ɗa̱ a zuwa uteku.
\q1 
\v 21 Ka̱ta̱ uma a̱ nu dem o bono a̱ suɓa̱,
\q2 ka̱ta̱ a̱ ka̱na̱ iɗika ya ali a kubana uteku n uteku.
\q1 Ele ɗa utopi u na n ca̱Ꞌi,
\q2 n ulinga we ekiye a̱ va̱,
\q2 adama a na n ciya̱ ucikpi.
\q1 
\v 22 KpaꞋa ku na ku laꞋi n kenu a̱ ka̱tsuma̱ ka̱ ɗa̱ ku ɗa ko kokpo ku gbayin,
\q2 iɗika i kenu moco yo okpo aduniyan a̱ a̱bunda̱i,
\q1 Mpa ɗa Vuzavaguɗu,
\q2 makyan ma yawa baci mi ta̱ a kuzuwa i ɗa i yaꞋan.>>
\c 61
\s1 Ka̱ya̱ ka wishi ka Vuzavaguɗu
\q1 
\v 1 Ayinviki a Vuzavaguɗu Ka̱shile i ta̱ koɓolo nu mpa,
\q2 adama a na Vuzavaguɗu u zagba mu ta̱
\q2 n tuka̱ n kadanshi ka singai wa aza a yali.
\q1 U suku mu ta̱ kpamu adama a na m bana n neke aza a na i n a̱ɗu una̱mgbi kadanshi ka singai,
\q2 ka̱ta̱ kpamu n neke aza a na i ugbashi uba̱ruwi,
\q2 ka̱ta̱ kpamu n ɓa̱yuwa̱ aza na a̱ ɓa̱ya̱ngi a̱ kunu kugbashi,
\q1 
\v 2 ka̱ta̱ n sala ukuna u ka̱ya̱ ka wishi ka Vuzavaguɗu,
\q2 n kanna ka na Ka̱shile ka̱ tsu ka kutsupa le n wupa u ni,
\q1 u neke kpamu aza a na i a̱ɗu una̱mgbi kadanshi ku uremi wa̱ a̱ɗu,
\q2 
\v 3 ali n aza a na i ida̱shi a Sihiyona,
\q1 ka̱ta̱ u zuwaka le oroliko o tsuloboi
\q2 a na wa̱ tsuwa̱nka̱ le kokomo,
\q1 m maniꞋin ma̱ ma̱za̱nga̱,
\q2 a na a yaꞋan n una̱mgbuka̱tsuma̱,
\q1 kucukpa u uka le motogu ma tsugbayin
\q2 a na wo kokpo una̱mgbuka̱tsuma̱.
\q1 Adama a ulinga wu usuɓi u le, uma i ta̱ e kuɗeke le maɗanga ma oku,
\q2 ma na Vuzavaguɗu u shikpa̱i
\q2 adama a na u yotsongu ugaꞋin u ni.
\q1 
\v 4 I ta̱ a kumaꞋasuka likuci i cau i na yo okpoi ɗe agali
\q2 ka̱ta̱ maꞋasaka ubuta̱ u na a̱ la̱nga̱sa̱i m megeshe ma ɗe
\q1 i ta̱ a kumaꞋasuka likuci i na yo okpoi ɗe gali
\q2 i na i ɓosoi ɗe ali n tsukaya n a̱bunda̱i tsu na tsu lazai.
\q1 
\v 5 Omoci i ta̱ a kuguɓa kuzuwa ku ɗa̱,
\q2 omoci i ta̱ kpamu o kokpo aza a na a kuyaꞋanka ɗa̱ kunima n aza a na a̱ kula̱na̱ka̱ ɗa̱ kashina ki itacishi ka̱ ɗa̱.
\q1 
\v 6 I ta̱ e kuɗeke ɗa̱ anan ganu a Vuzavaguɗu,
\q2 ka̱ta̱ kpamu a yaꞋan kadanshi n a̱ɗa̱ tsu anan ganu vu Ka̱shile.
\q1 Yi ta̱ a kulyaꞋa ilikulya punu a uciyi wa aduniyan wa,
\q2 n uciyi u le u ɗa i kuyaꞋanka a̱ra̱ɗi.
\b
\q1 
\v 7 Ana ya yaꞋan wono
\q2 yi ta̱ a kukucikpa ya kisa una̱singai wa̱ a̱bunda̱i,
\q1 adama o tsugoyi
\q2 i ta̱ a kuyaꞋan ma̱za̱nga̱ n ili i na yi i ka̱ci ke le,
\q1 nannai ɗa ta na a kisa udariki u re wi ili i na yi i le punu a iɗika i le,
\q2 i ta̱ a̱ kuciya̱ ma̱za̱nga̱ ma babu uteku.
\b
\q1 
\v 8 <<Adama a na mpa Vuzavaguɗu n ciga ta̱ kasingai,
\q2 n iwan ta̱ uboki n unushi.
\q1 N uneki u ka̱ɗu u va̱ mi ta̱ a kutsupa le
\q2 ka̱ta̱ kpamu n yaꞋan uzuwakpani n le u na u kukotso ba.
\q1 
\v 9 I ta̱ kpamu e kuyeve ntsukaya n le a aduniyan ra̱ka̱,
\q2 muku n le kpamu e mere ma uma dem.
\q1 Aza a na e enei le ra̱ka̱ i ta̱ e kuyeve
\q2 a na ele ɗa uma a na Vuzavaguɗu u zuwakai una̱singai.>>
\b
\q1 
\v 10 Mi ta̱ a kuyaꞋan ma̱za̱nga̱ ma gbayin u Vuzavaguɗu,
\q2 wuma u va̱ wi ta̱ a kucikpa Ka̱shile,
\q1 Adama a na u uka mu ta̱ aminya a̱ wishi,
\q2 ɗa kpamu u palai mu n kuminya ku usuɓi,
\q1 tsu na vuza vu yolo i savu u tsu kala ka̱ci ka̱ ni n oroliko a kaci tsu mogono,
\q2 n tsu na kpamu vuka vu savu u tsu kala ka̱ci ka̱ ni n tsuzogu.
\q1 
\v 11 Tsu na iɗika i tsu zuwa ili i ɓuka̱,
\q2 ko kashina ki ishiꞋwan ka tsu zuwa icuꞋu i ɓuka̱ ka̱ta̱ i gbonguro,
\q1 ta kpamu nanannai Vuzavaguɗu Ka̱shile u kuzuwa kasingai n ucikpi
\q2 u ta̱wa̱ a aduniyan ra̱ka̱.
\c 62
\s1 Kula ku savu ku Sihiyona
\q1 
\v 1 Adama a Sihiyona mpa ma kupaɗa bini ba,
\q2 adama a Urushelima kpamu mpa mo kokpo bini feu ba,
\q1 sai ayin a na kasingai ka̱ ni ka akanai tsu kutashi,
\q2 wishi u ni kpamu tsu ma̱kuni ma na mi utasiki.
\q1 
\v 2 Aduniyan i ta̱ e kene kasingai ka̱ nu,
\q2 ka̱ta̱ ngono dem me ene tsugbayin tsu nu,
\q1 i ta̱ kpamu e kuɗeke wu n kula ku savu
\q2 kula ku na Vuzavaguɗu n ka̱ci ka̱ ni u kuneꞋe wu.
\q1 
\v 3 Vi ta̱ o kokpo oroliko o tsuloboi a̱ ubuta̱ we ekiye a Vuzavaguɗu,
\q2 koɓolo m ma̱kun mo tsugono e ekiye a̱ Ka̱shile ka̱ nu.
\q1 
\v 4 O kudoku e ɗeke wu Kagali ba ko iɗika i na i na̱mgba̱i ba,
\q2 Ama kula ku savu ku nu ku ɗaɗa iɗika i ma̱za̱nga̱ i Ka̱shile
\q1 n vuka vu savu vu Ka̱shile
\q2 adama a na Vuzavaguɗu wi ta̱ a kupana uyo n avu,
\q1 ka̱ta̱ u bonoko wu,
\q2 vuka vu savu vu Ka̱shile.
\q1 
\v 5 Tsu na maku ma vali ma tsu zuwa ka̱ɗu ka̱ ni a̱ ubuta̱ u vuka vu savu vi ni,
\q2 tsu nanlo tsu ɗa muku n nu n kutono wu,
\q1 tsu na vuza vu vuka vu savu u ci yaꞋan ma̱za̱nga̱ adama a vuka vu savu vu ni,
\q2 nannai ɗa Ka̱shile ka̱ ɗa̱ ka kuyaꞋan ma̱za̱nga̱ n avu.
\q1 
\v 6 N zuwa ta̱ aza a kindi a nshilya n ɗa̱, avu Urushelima,
\q2 a kupaɗa bini n kanna ko n kayi ba.
\q1 A̱ɗa̱ vu na i zuwai Vuzavaguɗu wi a kuciɓasa n a̱ɗa̱,
\q2 ka̱ta̱ yu uvuka ba,
\q1 
\v 7 ka̱ta̱ i neke Vuzavaguɗu wuvuki ba, sai ayin a na u zuwai Urushelima u shamgbai,
\q2 ali u zuwa wo okpo ubuta̱ u kucikpa punu a aduniyan dem.
\b
\q1 
\v 8 Vuzavaguɗu u kucina ta̱ n kukiye ku usingai ku ni
\q2 koɓolo n kubolu ku gbayin ku ni,
\q1 <<Mi o kudoku me neke ili i kashina
\q2 wa aza na i a tsurala n a̱ɗa̱ ba,
\q1 omoci o kudoku kusoꞋo ma̱ra̱
\q2 ma na a̱ɗa̱ i yaꞋin ba,
\q1 
\v 9 ama aza a na a kyaꞋi va i ta̱ a a kulyaꞋa i ɗa
\q2 ka̱ta̱ a cikpa Vuzavaguɗu,
\q1 aza na kpamu o ɓolongi umaci wu nɗanga u na u geꞋwei va i ta̱ a kulyaꞋa u ɗa,
\q2 punu a ulanga u ma̱va̱li ma̱ va̱.>>
\b
\q1 
\v 10 Walai punu, walai punu n utsutsu wa,
\q2 lapulakai uma uye.
\q1 Zamai, zamai uye u gbayin,
\q2 takpai atali a.
\q1 Zuwai akashi a urotu adama a na aduniyan ra̱ka̱ e ene.
\b
\q1 
\v 11 Vuzavaguɗu u dansa ta̱ ɗe
\q2 a̱ ubuta̱ wa aduniyan ra̱ka̱.
\q1 <<Dana uma a Sihiyona,
\q2 <Indanai, Kishi ka̱ ɗa̱ ki ta̱ lo a̱ kuta̱wa̱,
\q1 wi ta̱ koɓolo n katsupu ka̱ ni a̱ kuta̱wa̱.> >>
\q1 
\v 12 I ta̱ e kuɗeke le uma a ciɗa,
\q2 aza a na Vuzavaguɗu u shiba̱i,
\q1 i ta̱ e kuɗeke Urushelima, ubuta̱ u mali
\q2 likuci i na a iwain ba.
\c 63
\s1 Kanna ka kutsupa ka̱ Ka̱shile n kushiba̱
\q1 
\v 1 Yayi a̱yi na wu uta̱i a Edom,
\q2 wu uta̱i a Bozura n kuminya ku ni utaɗanki m mini ma shili?
\q1 Yayi tamkpamu nannai n aminya o tsugono,
\q2 a kudasa n utsura ka̱u?
\q1 <<Mpa ɗa Vuzavaguɗu a kusala ukuna wu wishi u ɗa̱.
\q2 Mpa ɗa Vuzavaguɗu vu na mi n utsura u na mi isa vuma.>>
\b
\q1 
\v 2 Yiɗa̱i i zuwai ɗa aminya a̱ nu i ushili,
\q2 tsu uma a na e ci kpete umaci wu nɗanga n kuyaꞋanka ma̱kya̱n?
\b
\q1 
\v 3 <<M kpete ta̱ umaci wu nɗanga wa mpa endeꞋen,
\q2 a iɗika kakau babu vuza na wi koɓolo nu mpa.
\q1 N dasasai le n wupa u va̱
\q2 ɗa kpamu m kpetei le n wupa wa,
\q1 mpasa n le n taɗanki
\q2 aminya a̱ va̱ ɗa a̱ la̱nga̱sa̱i mu ntogu.
\q1 
\v 4 Adama a na kanna ka kutsupa ki ishi ta̱ a̱ ka̱ɗu ka̱ va̱,
\q2 ɗa kpamu ka̱ya̱ ka na n kisa uma ka yawai ɗe.
\q1 
\v 5 Mi indanai, ama babu vuza na n kuɓa̱nka̱,
\q2 o goyoi mu ama babu vuza na u ɓa̱nka̱i mu,
\q1 ɗa kubolu ku va̱ ku la̱nsa̱ka̱i mu wishi,
\q2 wupa u va̱ u ɓa̱na̱i mu.
\q1 
\v 6 N dasasai iɗika kakau
\q2 n wupa u va̱ n zuwai le o soꞋi ali ma makai le adama a wupa u va̱,
\q1 ɗa n tsuwa̱in mpasa n le a iɗika.>>
\s1 Ucikpi n Avasa
\q1 
\v 7 Mi ta̱ a kudansa ukuna wu ugaꞋin u Vuzavaguɗu,
\q2 ili i na u yaꞋin i na u yawai a cikpa yi,
\q2 a̱ ka̱tsuma̱ ki ili i na u yaꞋankai tsu dem,
\q1 mayu, ili i singai-singai n a̱bunda̱i i na u yaꞋankai
\q2 kpaꞋa ka aza a Isaraila,
\q2 adama a̱ ma̱ta̱na̱ ma̱ ni n kasingai ka̱ ni.
\q1 
\v 8 U danai, <<Mayun ele uma a̱ va̱ a ɗa,
\q2 muku n na n kudoro mu ba,>>
\q2 Nannai ɗa wo okpoi Kishi ke le.
\q1 
\v 9 N atakaci a na o soꞋi dem a̱yi feu u soꞋo ta̱ a ɗa,
\q2 ɗa kalingata ka na ki a kinda yi kisai le.
\q1 N ucigi u ni n kasingai ka̱ ni ɗa u tsulai le,
\q2 u ɗengusa̱i le gaɗi ɗa u ɗikai le
\q2 ali n a̱ya̱ a na a lazai ɗe.
\q1 
\v 10 Ama n nannai dem
\q2 a yaꞋin ugbamukaci ɗa a nusakai Ayinviki a Ciɗa.
\q1 Ɗaɗa kucukpa Ka̱shile ka zuwakai le kucina̱,
\q2 ɗa u bonoi wo okpoi vurala vi le ɗa u shilika̱i n ele.
\b
\q1 
\v 11 Uma a̱ ni a ciɓai n ayin a cau,
\q2 a ayin a Musa n uma a̱ ni,
\q1 te ɗai vuza na wu uta̱i n ele n kalangu ka kaguɓa ka̱ ni ali ɗa a walai m mala,
\q2 m maguɓi mu ushiga wa?
\q1 Te ɗai vuza na u zuwai vuza
\q2 na u nekei le Ayinviki a Ciɗa a,
\q1 
\v 12 a̱yi na u suki utsura u gbayin u kubolu u ni
\q2 u yongo e kukiye ku usingai ku Musa,
\q1 vuza na u pecei mini ele lo e kene
\q2 adama a na u ciya̱ka̱ ka̱ci ka̱ ni kula ku singai ku na ko kukotso ba,
\q1 
\v 13 vuza na u walai n ele a̱ mini mu uga̱vi?
\q2 An kodoku ka na ka tsu suma a̱ likuci i na yi babu keteri,
\q1 ko kenu a̱ ta̱ɗa̱tsa̱ ba,
\q1 
\v 14 tsu kanaka ka na ka tsu bana a̱ ka̱ra̱Ꞌa̱ ka na ki n ijanu adama a na wu uvuka ɗe,
\q2 Ayinviki a Vuzavaguɗu e nekei le kuvuka.
\q1 Tsu nampa tsu ɗa vu tonoi n uma a̱ nu
\q2 ciya̱ vi ciya̱ka̱ ka̱ci ka̱ nu kula ku tsugbayin.
\b
\q1 
\v 15 Indana a iɗika avu na ɗe zuva ka̱ta̱ ve ene,
\q2 a̱ ubuta̱ u ciɗa u nu n ubuta̱ u singai wi ida̱shi i nu.
\q1 Te ɗai kataci ka̱ nu n utsura u nu wi?
\q2 Ili i na i tsu ɗengusa̱ wu asuvu koɓolo n kuneke wu asuvayali vu takpa ta̱ i ɗa wa̱ tsu.
\q1 
\v 16 Ama avu ɗa Esheku a̱ tsu,
\q2 n nannai ta na Ibirahi u yeve tsu ba
\q2 ko Isaraila u zuka n a̱ tsu ba, avu Vuzavaguɗu,
\q1 avu ɗa Esheku a̱ tsu, kula ku nu ku ɗa
\q2 Kishi ka̱ tsu ali n ayin a cau a ɗe.
\q1 
\v 17 Vuzavaguɗu yiɗa̱i i zuwai ɗa vu ka̱sukpa̱i tsu a̱ ka̱ka̱ra̱sa̱ tsu ka̱sukpa̱i uye u nu
\q2 ɗa vu zuwai a̱ɗu a̱ tsu a gbamai ali ɗa tsu kpa̱ɗa̱i kupanaka wu?
\q1 Bono adama a agbashi a̱ nu,
\q2 kumaci ku nu ele ɗa aza na a kulyaꞋa agadu a̱ nu.
\q1 
\v 18 A̱ ka̱tsuma̱ ka ayin kenu uma a̱ nu e remei ubuta̱ u ciɗa u nu,
\q2 ama gogo na irala i tsu i kpete ta̱ ubuta̱ u ciɗa u nu.
\q1 
\v 19 A̱ tsu uma a̱ nu a ɗa ali n ayin a ɗe,
\q2 ama vu lyaꞋaka le tsugono ba,
\q2 a saꞋwa kuɗeke le n kula ku nu ba.
\c 64
\q1 
\v 1 Vuzavaguɗu, ɓoso gaɗi ka̱ta̱ vi cipa̱ a iɗika,
\q2 adama a na vu zuwa nsasan m gba̱ɗa̱ kelime ka̱ nu.
\q1 
\v 2 Tsu na akina a tsu tasa ali a
\q2 zuwa mini ma̱ punu,
\q1 cipa̱ adama a na vu zuwa irala i nu e yeve n kula ku nu
\q2 ka̱ta̱ kpamu vu zuwa aduniyan ra̱ka̱ o voɗotso e kelime ka̱ nu.
\q1 
\v 3 Ana vi yaꞋin ili i mereve i na ci sheshei va kufuɗa kuyaꞋan ba,
\q2 ɗa vu cipa̱i a iɗika, ɗa nsasan n jeꞋi avu e kene.
\q1 
\v 4 Ali n ayin a cau babu vuza na u saꞋwai kene,
\q2 babu kpamu kutsuvu ku na ku saꞋwai kupana,
\q1 babu ka̱shi ka na ka saꞋwai kene Ka̱shile ka na ka laꞋi nu,
\q2 vuza na u ci yaꞋanka aza na i a kuvana yi ulinga.
\q1 
\v 5 Vi isai vuza na u ci yaꞋan kasingai m ma̱za̱nga̱,
\q2 vuza na kpamu u tsu ciɓa n a̱ɗa̱ a uye u ni.
\q2 Ɗa kpamu tsu geshei punu a̱ ka̱tsuma̱ ku unushi,
\q1 ɗa kpamu i yaꞋin wupa,
\q2 Nini ɗai tsa̱ kuciya̱ wishi?
\q1 
\v 6 Ra̱ka̱ vu tsu tso okpoi an aza a na i nu nshinda̱,
\q2 ulinga wu usuɓi u tsu ra̱ka̱ wi ta̱ tsa akashi a na a karasai,
\q1 ɗa tsu lumbai ra̱ka̱ tsa̱ a̱vuku,
\q2 ɗa unushi u tsu wo okpoi tsu wunla̱i, ɗa u ɗikai tsu ra̱ka̱.
\q1 
\v 7 Babu vuza na u tsu ɗeke kula ku nu,
\q2 ko u dakaka u ciya̱ u ka̱na̱ wu,
\q1 adama a na vu sokongu ta̱ a̱shi a̱ nu a̱ tsu,
\q2 ɗa vu ka̱sukpa̱i tsu derekpei adama a̱ unushi u tsu.
\q1 
\v 8 Ama gogo na, Vuzavaguɗu, avu ɗa Esheku a̱ tsu.
\q2 A̱ tsu ɗa ciꞋin, avu ɗa kamaꞋi,
\q1 a̱ tsu ra̱ka̱ dem ulinga we ekiye u nu u ɗa.
\q1 
\v 9 Ka̱ta̱ vi yaꞋan wupa u na u laꞋi kugisanku ba, Vuzavaguɗu,
\q2 ka̱ta̱ vu ciɓasa n unushi u tsu ko wannai ba.
\q1 La̱nuku, n folono wu ta̱ indana,
\q2 a̱ tsu ra̱ka̱ uma a̱ nu a ɗa ci.
\q1 
\v 10 Likuci i ciɗa i nu yo okpo ta̱ kakamba,
\q2 Sihiyona feu wo okpo ta̱ kakamba, Urushelima tamkpamu wo okpoi agali.
\q1 
\v 11 A̱Ꞌisa̱ a singai n a ciɗa a̱ tsu, ubuta̱ u na isheku i tsu i cikpai nu,
\q2 u ɗa u kula̱ ta̱ n akina,
\q2 ɗa ubuta̱ u singai u tsu ra̱ka̱ wo okpoi agali.
\q1 
\v 12 Ili i nampa ra̱ka̱ i kotso baci, Vuzavaguɗu, vi ta̱ o kubono n ka̱ca̱pa̱?
\q2 Vi ta̱ a kupaɗa bini ka̱ta̱ vu takacika tsu gbani-gbani nannai?
\c 65
\s1 Afada n Wishi
\q1 
\v 1 <<Mu uta̱ka̱i ka̱ci ka̱ va̱ wa aza a na e ecei mu ba,
\q2 Mpa mu uta̱i e keteshe wa aza a na a̱ la̱nsa̱i mu ba.
\q1 M banai a̱ likuci i na i ɗekei kula ku va̱ ba,
\q2 n danai, <Mpa ɗa na, mpa ɗa na.>
\q1 
\v 2 Mo oɓongi ekiye a̱ va̱ a kanna gbaga
\q2 adama a aza a ugbamukaci,
\q1 aza a na i a kuyaꞋan ukuna u na u gaꞋin ba,
\q2 a̱ kula̱nsa̱ka̱ ka̱ci ke le i na i kuyokpo le,
\q1 
\v 3 Uma a na a tsu shika mu
\q2 a̱shi n a̱shi ayin dem,
\q1 a kuyaꞋansa alyuka a ashina
\q2 koɓolo n kusongu ili i ma̱gula̱ni a atalyalyuka a na a maꞋi n iputa̱,
\q1 
\v 4 ele na a̱ tsu da̱sa̱ngu a̱ ubuta̱ wa asaun
\q2 ka̱ta̱ kpamu a una kayin gbaga a̱ ubuta̱ u na a kucikpa a̱ma̱li o yoku,
\q1 ele na a tsu takuma inyama yi ngurusunu,
\q2 ele na mgbodo n le n ci yongo n inyama i na yi ni nshinda̱.
\q1 
\v 5 Ele na a tsu dana, <Ɗenga̱ lo, ka̱ta̱ vi yawa ɗevu nu mpa ba,
\q2 adama a na ugaꞋin u ka̱ɗu u va̱ u laꞋa ta̱ utsura u nu.
\q1 Uma a nanlo i ta̱ an ka̱nga̱ a̱ vunu vu va̱,
\q2 a zuwai wupa u va̱ a̱ kukula̱ tsa akina a na a̱ tsu kula̱ a kanna gbaga.
\b
\q1 
\v 6 <<Indanai, ɗa na uɗani kelime ka̱ va̱,
\q2 mi a kupaɗa bini ba, ama mi ta̱ a kutsupa derere,
\q1 mi ta̱ a kutsupa i ɗa tsu na u gaꞋin a yaꞋanka le,
\q1 
\v 7 unushi u nu koɓolo n unushi wi isheku i nu,>>
\q2 Vuzavaguɗu u danai, <<Adama a na o songu ta̱ alyuka a nsasan
\q1 ɗa kpamu a ukai mu nshinda̱ a aginda,
\q2 mi ta̱ a kugisanku a̱ nkuta̱ n le
\q1 katsupu ka derere adama a ili i na a yaꞋin cau va ɗe.>>
\b
\q1 
\v 8 Ili i na Vuzavaguɗu u danai i ɗaɗa na,
\q1 <<Ci ili i kusoꞋo i na ka̱ta̱ a pishai a umaci u ni ba,
\q2 ɗa uma a danai, <Ka̱ta̱ i la̱nga̱sa̱ u ɗa ba,
\q2 ka̱ta̱ u kotso kugeꞋwe ba,>
\q1 ta n kuyaꞋan n agbashi a̱ va̱ nannai,
\q2 n kuna le ra̱ka̱ ba.
\q1 
\v 9 Mi ta̱ a̱ kutuka̱ nu ntsukaya mu ugboku u na̱shi u Yakubu,
\q2 n aza o yoku kpamu a Yahuda ele na a̱ kuka̱na̱ uɓon wu nsasan wo okpo u le,
\q1 uma a̱ va̱ a na n zagbai a̱ kuka̱na̱ ta̱ u ɗa wo okpo u le,
\q2 ta ɗe agbashi a̱ va̱ o kuyongo.
\q1 
\v 10 Ka̱ra̱ ka Sharon ki ta̱ o kokpo ubuta̱ u kalina wi nkyon,
\q2 ka̱ta̱ Ka̱ra̱ ka Ako kokpo tamkpamu ubuta̱ u kuvuka wa anaka
\q2 a uma a̱ va̱ a na a̱ la̱nsa̱i mu.
\b
\q1 
\v 11 <<Ama a̱ɗa̱ na i ka̱sukpa̱i Vuzavaguɗu
\q2 ɗa kpamu i cinukpai nu nsasan n ciɗa n ni,
\q1 aza a na e nekei alyuka a ilikulya u ka̱ma̱li ka Gadu, a̱yi na u tsu tuka̱ m ma̱ta̱na̱
\q2 ɗa kpamu a shatangi nko m ma̱ra̱ kakau ma na a satarai ɗa e nekei ka̱ma̱li ka na e ci ɗeke Uzuwi.
\q1 
\v 12 N yaꞋanka wu ta̱ ɗe uzuwi u na va kubana ukpa̱ u kotokobi,
\q2 ra̱ka̱ vu ɗa̱ yi ta̱ a kuyaꞋan ukiɗi,
\q1 adama a na n ɗeke ta̱ ama yu ushuku ba,
\q2 n yaꞋin kadanshi ama i pana ba.
\q1 I yaꞋin ili i gbani-gbani a̱ a̱shi a̱ va̱,
\q2 ɗa kpamu i zagbai i na i kukpa̱ɗa̱ kuneke mu ma̱za̱nga̱.>>
\b
\p 
\v 13 Adama a nannai ili i na Vuzavaguɗu Uba̱nga̱ri u danai i ɗaɗa na,
\q1 <<Agbashi a̱ va̱ i ta̱ a kulyaꞋa ilikulya,
\q2 ama a̱ɗa̱ yi ta̱ o kuyongo n kambulu,
\q1 agbashi a̱ va̱ i ta̱ o kusoꞋo,
\q2 ama a̱ɗa̱ yi ta̱ o kuyongo n kakuli,
\q1 agbashi a̱ va̱ i ta̱ o kuyongo m ma̱za̱nga̱,
\q2 ama a̱ɗa̱ yi ta̱ o kokpo n wono.
\q1 
\v 14 Agbashi a̱ va̱ i ta̱ a kucanana ishipa
\q2 adama a̱ ma̱za̱nga̱,
\q1 ama a̱ɗa̱ yi ta̱ a̱ kushika̱
\q2 adama a una̱mgbuka̱tsuma̱
\q2 ma na ma̱ kula̱nga̱sa̱ ɗa̱ a̱ɗu.
\q1 
\v 15 Mpa Vuzavaguɗu n danai,
\q2 uma a na n zagbai i ta̱ a kuyaꞋan ulinga n ula̱ a̱ ɗa̱ wo okpo le tsu una̱ u wuya,
\q1 Vuzavaguɗu Uba̱nga̱ri wi ta̱ a kuna ɗa̱,
\q2 ama wi ta̱ e kuneke uma a̱ ni ula a savu.
\q1 
\v 16 Vuza na baci de dem a iɗika ya u ciɓalai una̱singai
\q2 wi ta̱ a kuyaꞋan nannai n kula ku Ka̱shile ka mayun,
\q1 vuza na baci u yaꞋin akucina punu a iɗika ya
\q2 wi ta̱ kpamu a kukucina n kula ku Ka̱shile ka mayun.
\q1 Adama a na mi ta̱ a kuzuwa wupa u va̱ paki ka̱ta̱ n cinukpa n u ɗa
\q2 ka̱ta̱ kpamu n sheɗeku n a̱shi a̱ va̱ wa̱ ni.
\s1 Gaɗi vu savu n iɗika i savu
\q1 
\v 17 <<Indanai, mi ta̱ a kuyaꞋan
\q2 gaɗi vu savu n iɗika i savu.
\q1 Ili i cau i kuyaꞋan kpamu uciɓi ba,
\q2 vuza wo kudoku we sheshe le a̱ ka̱ɗu ba.
\q1 
\v 18 Ama yaꞋin ma̱za̱nga̱ ko wannai
\q2 mi ili i na n kuyaꞋan,
\q1 adama a na mi ta̱ a kuyaꞋan Urishelima wo okpo ubuta̱ u ma̱za̱nga̱
\q2 n uma a̱ ni feu m ma̱za̱nga̱.
\q1 
\v 19 Mi ta̱ a kuyaꞋan ma̱za̱nga̱ adama a Urushelima
\q2 koɓolo kpamu n uma a̱ va̱,
\q1 vuza wo kudoku wa pana kacaꞋa ka̱ ma̱shi
\q2 n izumgbi i kusa̱ka̱ɗa̱ngusu ba.
\b
\q1 
\v 20 <<Babu kpamu punu
\q2 mereɓu ma na mo kuyongo n wuma punu ayin kenu koci,
\q2 ko mokoshi ma na ma̱ kukuwa̱ babu ayin a̱ ni a yawa.
\q1 Vuza na baci u kuwa̱i babu u laza a̱ya̱ amangatawun (100)
\q2 i ta̱ a kuɗika yi biꞋi ka̱ɗa̱nga̱ni,
\q1 vuza na baci u yawai a̱ya̱ amangatawun (1,000) ba,
\q2 i ta̱ a kuɗika yi tsu vuza vu unushi.
\q1 
\v 21 I ta̱ a kumaꞋa iꞋuwa ka̱ta̱ o yongo punu,
\q2 ka̱ta̱ kpamu a cimba kashina ki itacishi ali a lyaꞋa umaci u le.
\q1 
\v 22 O kudoku a maꞋa iꞋuwa ka̱ta̱ kpamu aza o yoku kau a uwa o yongo punu ba,
\q2 ko a̱ ca̱Ꞌa̱ ka̱ta̱ aza o yoku a lyaꞋa ba.
\q1 Tsu na maɗanga matsu yongo n ayin,
\q2 ta feu uma a̱ va̱ e kugeshe nannai,
\q1 aza na mpa n zagbai o kuyongo n ayin n a̱bunda̱i a kupana uyoꞋo wi ili i na
\q2 a yaꞋin ne ekiye e le.
\q1 
\v 23 A kuyaꞋan ulinga u gbani ba,
\q2 ko muku n le mokpo agulani ka̱ta̱ wo okpo le uta̱ɗa̱ci ba,
\q1 adama a na i ta̱ o kokpo uma a na Vuzavaguɗu u zuwakai una̱singai,
\q2 ele koɓolo nu ntsukaya n le n na n kuta̱wa̱.
\q1 
\v 24 Kafu e ɗeke mi ta̱ a̱ kushuku,
\q2 ele biꞋi a̱ ka̱tsuma̱ ka kadanshi mi ta̱ e kuyeve i na a̱ ciya̱i.
\q1 
\v 25 Vuzavaguɗu u danai, ma̱kunzukunzu m malala i ta̱ a kulyaꞋa ilikulya a̱ ubuta̱ u te,
\q2 kawu wi ta̱ a kutakuma kalu an kanaka,
\q2 ama kubuta̱ ku ɗaɗa ilikulya i koko,
\q1 a kuluma ko a una kusan ku ciɗa ku va̱ ba.>>
\c 66
\s1 Afada koɓolo n ukeɗi wa̱ a̱pa̱
\p 
\v 1 Ili i na Vuzavaguɗu u danai i ɗa na,
\q1 <<Gaɗi ɗa kakuba ko tsugono ka̱ va̱,
\q2 aduniyan ta ɗe n tsu zuwa ene a̱ va̱.
\q1 To, gogo na icuꞋu i kpaꞋa ku ne ku ɗai i kumaꞋaka mu?
\q2 Te ɗai kpamu ubuta̱ u kuvuka u va̱ wi?
\q1 
\v 2 Vuzavaguɗu u danai, <<Ili i nampa ya ra̱ka̱ ba ekiye a̱ va̱ a ɗa a yaꞋin i ɗa,
\q2 ali ɗa yo okpoi nannai ba?>>
\b
\q1 <<Ama vicuꞋu vu vuma vu nampa ɗa mi a̱ kula̱nsa̱,
\q2 vuza na u ka̱na̱i ka̱ci ka̱ ni ɗa kpamu ayinviki i koɓolo n a̱yi
\q2 ɗa kpamu wi a kuyaꞋan nwalu n kadanshi ka̱ va̱.
\q1 
\v 3 Uma a ci yaꞋan ta̱ tsu na a cigai, we le derere ɗa,
\q2 ko a lyuka n koɓonburom ko a lyuka n vuma,
\q1 ko a lyuka m malala,
\q2 ko a lyuka m mesheꞋe,
\q1 ko a̱ tuka̱ n kuneꞋe ki ili kashina,
\q2 ko a yaꞋan kuneꞋe ku mpasa m ma̱gurusunu,
\q1 ko a yaꞋan kuneꞋe ku kpalu ki ili i ma̱gula̱ni,
\q2 ko a cikpa a̱ ma̱li.
\q1 Aza na a zagbai uye u le,
\q2 ɗa wuma u le u panai ma̱za̱nga̱,
\q1 
\v 4 mpa feu n sheshe ta̱ n kuneke le atakaci
\q2 ka̱ta̱ n tuka̱ le n ili i na i a kupana wovon dem,
\q1 adama a na ana n ɗekushei, babu vuza na wu ushuki mu,
\q2 ana kpamu n yaꞋin kadanshi babu vuza na u paniki mu,
\q1 ɗa a yaꞋin ili i gbani-gbani a̱ a̱shi a̱ va
\q2 ɗa kpamu a yaꞋin ili i na n cigai ba.>>
\b
\q1 
\v 5 Panai kadanshi ka Vuzavaguɗu,
\q2 a̱ɗa̱ aza na yi ugulani n kadanshi ka̱ ni,
\q1 <<Aza a̱ ɗa̱ a na a iwain ɗa̱
\q2 ɗa kpamu o lokoi ɗa̱ adama a kula ku va̱,
\q1 m ma̱ka̱n a danai, <YaꞋan Vuzavaguɗu u ta̱wa̱ n tsugbayin ci ni,
\q2 adama a na ce ene ma̱za̱nga̱ ma̱ ɗa̱.>
\q1 Ama ele ɗa aza na a kupana wono.
\q1 
\v 6 Panai izumgbi ɗe a̱ likuci ya,
\q2 panai kacaꞋa a̱ ma̱va̱li ma Vuzavaguɗu ma,
\q1 Izumgbi i Vuzavaguɗu i ɗa
\q2 a kuyaꞋan katsupu wi irala i ni derere tsu na wuntsai le.
\b
\q1 
\v 7 <<Kafu u gita̱ a̱ga̱nda̱ a limata,
\q2 ɗa tana u matsai,
\q1 kafu u gita̱ kupana mɓa̱la̱ n limata,
\q2 ɗa tana u matsai maku mo kolobo.
\q1 
\v 8 Yayi u saꞋwai kupana ili tsu nampa?
\q2 Yayi kpamu u sawai kene i nampa ya?
\q1 I ta̱ a kumatsa aduniyan a kanna ke te?
\q2 Ko ta na feu aduniyan a ci yimkpa ta̱ a kanna ke te?
\q1 Makyan ma na Sihiyona u gita̱i a̱ga̱nda̱ a limata a̱ ni
\q2 ɗa ta na u matsai muku mo olobo.
\q1 
\v 9 Mpa Vuzavaguɗu n danai, <<N kuyawaka n uma a̱ va̱ a ayin a kumatsa
\q2 ka̱ta̱ m kpa̱ɗa̱ kuzuwa a matsa le ba.
\q1 Mpa vu na n tsu tuka̱ n limata, n kushiya kamatsatsu ba,
\q2 wannai ɗai n gita̱ a̱ga̱nda̱ a limata.>>
\q1 
\v 10 YaꞋin ma̱za̱nga̱ n Urushelima ka̱ta̱ kpamu i yaꞋan ma̱za̱nga̱ adama a̱ ni,
\q2 a̱ɗa̱ vu na i cigai ni,
\q1 yaꞋin ma̱za̱nga̱ ma gbayin n a̱yi,
\q2 n a̱ɗa̱ na kpamu yi n una̱mgbuka̱tsuma̱ n a̱yi.
\q1 
\v 11 Ciya̱ vu apa ka̱ta̱ vi cuwa̱
\q2 m mani ma singai ma̱ ni,
\q1 vi ta̱ kpamu o kusoꞋo ka̱u
\q2 ka̱ta̱ vi yaꞋan ma̱za̱nga̱ n tsu na mani mi n a̱bunda̱i.>>
\q1 
\v 12 Adama a na na ɗa ili i na Vuzavaguɗu u danai,
\q1 <<Mi ta̱ a̱ kutuka̱ m ma̱ta̱na̱ a kubana wa̱ ni tsu mala,
\q2 ka̱ta̱ uciyi wa aduniyan u yaꞋan tsu na mini me ci yene,
\q1 u teku tsu kuyene, yi ta̱ kpamu a kapa, ka̱ta̱ kpamu e keɓe ɗa̱ gaɗi n ekiye a̱ ni,
\q2 ka̱ta̱ vu yongo e kujeꞋe ɗe a̱ nkuta̱ n ni.
\v 13 Tsu na kamaci ka tsu kparusa maku ma̱ ni,
\q2 ta feu mi a kukparusa ɗa̱ nannai,
\q2 yi ta̱ a̱ kuciya̱ uremi wa̱ a̱ɗu n Urishelima.>>
\b
\q1 
\v 14 Ayin a na baci ve enei ili i nampa, ka̱ta̱ ka̱ɗu ka̱ nu ka shana m ma̱za̱nga̱
\q2 ka̱ta̱ kpamu vo okpo lenwu an mita̱.
\q1 Ka̱ta̱ kpamu uma e yeve utsura u Vuzavaguɗu,
\q2 ama wi ta̱ o kuyotsongu wupa u ni a̱ ubuta̱ wi irala i ni.
\q1 
\v 15 La̱nuki, Vuzavaguɗu wi ta̱ lo a̱ kuta̱wa̱ n akina,
\q2 ekeke o odoku a̱ ni i ta̱ tsu kabatalikpau,
\q1 wi ta̱ a katika wupa ka̱u,
\q2 wi ta̱ a kuyaꞋan kuɓarangu ku ni m melentsu ma akina.
\q1 
\v 16 Adama a na n akina a ɗa koɓolo n kotokobi ka̱ ni
\q2 Vuzavaguɗu wi a kuyaꞋanka uma ra̱ka̱ afada,
\q2 aza na Vuzavaguɗu u kuna i ta̱ n a̱bunɗai.
\p 
\v 17 Vuzavaguɗu u danai <<Aza a na a takpai nshinda̱ n le adama a na a bana a asuvu a ubaru, ɗa wi o kutono aza na a tsu wala n kayin, ɗa kpamu i a kutakuma inyama i ma̱gurusunu n a̱yu, ra̱ka̱ vi le i ta̱ a kuzuwaka uteku.>>
\p 
\v 18 <<Adama a na mpa n yeve ta̱ ulinga u le n kusheshe ku le, ayin i ta̱ lo a̱ kuta̱wa̱ a na wo ɓolongu aduniyan n kelentsu ra̱ka̱, i ta̱ a̱ kuta̱wa̱ kene tsugbayin tsu va̱.
\p 
\v 19 <<Mi ta̱ a kuzuwa urotu e mere me le, a̱ ka̱tsuma̱ ke le mi ta̱ a̱ kusuku aza a na a buwai n wuma a kubana a iɗika kakau, n aza a Tarishi, n aza a Libiya, n aza a Lidiya, n aza a Tubalu, koɓolo n aza e Helene, n kotogu ka na ki daꞋin ka̱u ka na ka̱ta̱ ka saꞋwai kupana ukuna u mereve u va̱ ba, i ta̱ a kusala tsugbayin tsu va̱ a aduniyan ra̱ka̱.
\v 20 Vuzavaguɗu u danai, i ta̱ a̱ kutuka̱ n aza a̱ ɗa̱ ra̱ka̱ a aduniyan tsu kuneꞋe u Vuzavaguɗu, n odoku n ekeke o odoku ni njaki, a kubana a kusan ku ciɗa ku va̱ Urushelima, Vuzavaguɗu u danai, ɗa derere n tsu na aza a Isaraila a̱ tuka̱i n kuneꞋe ki ili i kashina a kasasu a kpaꞋa ku Vuzavaguɗu.
\v 21 Vuzavaguɗu u danai, mi ta̱ kpamu a kuzagba aza yoku okpo anan ganu aza yoku kpamu okpo anan Levi.>>
\p 
\v 22 <<Tsu gaɗi vu savu n iɗika i savu i na mi a kuciga kuyaꞋan, yi ta̱ o kokpo i ɗa̱, Vuzavaguɗu u danai, tsu nanlo tsu ɗa kula ku ɗa̱ ki o kuyongo koɓolo nu ntsukaya n ɗa̱.
\v 23 Vuzavaguɗu u danai, a̱ ka̱ɗiva̱ ko wotoi u savu a kubana wotoi savu u yoku, Ashibi a nampa a kubana Ashibi o yoku, uma ra̱ka̱ i ta̱ a̱ kuta̱wa̱ a̱ kuɗa̱nku mu.>>
\v 24 <<I ta̱ a̱ kuta̱ a bana pulai a inda even a ikyamba a aza a na a yaꞋankai mu ugbamukaci. Azun a na i o kusovo le a̱ kukuwa̱ ba, akina a na i o kusongu le feu i a̱ kukima̱sa̱ ba, i ta̱ o kokpo ili yu unata u uma a aduniyan dem.>>
