\id ISA
\h Isaia
\toc1 Isaia
\toc2 Isaia
\toc3 Isaia
\mt1 Isaia
\c 1
\s1 KA WANANA
\q1 
\v 1 KA wanana a Isaia, ke keiki a Amosa, ka mea ana i ike ai no ka Iuda, a no ka Ierusalema, i na la o Uzia, a me Iotama, a me Ahaza, a me Hezekia, o na'lii o ka Iuda.
\q1 
\v 2 E hoolohe, e na lani, e haliu mai hoi, e ka honua,
\q1 No ka mea, o Iehova ka i olelo mai:
\q1 Ua hanai au i na keiki, a ua malama hoi,
\q1 Aka, ua kipi mai lakou ia'u.
\q1 
\v 3 Ua ike no ka bipi i kona haku,
\q1 A o ka hoki hoi i kahi hanai o kona kahu:
\q1 O ka Iseraela, aole ia i ike mai,
\q1 Aole i malama ko'u poe kanaka.
\b
\q1 
\v 4 Auwe ka lahuikanaka hewa! he poe kanaka kaumaha i ka hala,
\q1 He hanauna hana ino, he poe hoohaumia:
\q1 Ua haalele lakou ia Iehova,
\q1 Ua hoowahawaha i ka Mea Hemolele o ka Iseraela;
\q1 Ua hoi ihope lakou.
\b
\q1 
\v 5 Ma kahi hea oukou e hahau hou ia'i?
\q1 A e kui hou aku anei oukou i ke kipi?
\q1 Ua puni ke poo i ka mai, ua maule hoi ka naau a pau.
\q1 
\v 6 Mai ka poli wawae, a hiki i ke poo,
\q1 Aohe wahi ola maloko olaila:
\q1 He palapu me ka ali, a me ka eha hou,
\q1 Aole i hoopiliia, aole i paa i ka wahi,
\q1 Aole i hooluoluia i ka aila.
\b
\q1 
\v 7 Ua neoneo ko oukou aina,
\q1 Ua puhiia ko oukou mau kulanakauhale i ke ahi:
\q1 Ua pau ko oukou aina i na malihini ma ko oukou alo;
\q1 Ua neoneo hoi, e like me kahi i anaiia e na malihini.
\q1 
\v 8 Ke waiho wale la no ke kaikamahine o Ziona,
\q1 Me he hale kamala la ma ka pawaina,
\q1 Me he hale pupupu la iloko o ka pakaukama;
\q1 E like hoi me ke kulanakauhale i hoopilikiaia i ke kaua.
\q1 
\v 9 Ina aole o Iehova o na kaua i waiho mai i koena uuku no kakou,
\q1 Ina ua like kakou me Sodoma,
\q1 Ina ua like no me Gomora.
\b
\q1 
\v 10 E hoolohe i ka olelo a Iehova, e na lunakanawai o Sodoma.
\q1 E haliu mai hoi i ke kanawai o ko kakou Akua, e na kanaka o Gomora.
\q1 
\v 11 No ke aha ka oukou mohai nui ia'u? wahi a Iehova;
\q1 Ua liliha au i na mohaikuni hipakane,
\q1 A me ka momona o na mea i kupaluia;
\q1 Aole o'u oluolu i ke koko o na bipi, a me na keikihipa, a me na kao.
\q1 
\v 12 Ia oukou e hele mai ai, e hoike imua o'u,
\q1 Nawai i imi i keia ma ko oukou lima, e hahi ma ko'u pahale?
\q1 
\v 13 Mai lawe hou mai i na mohai oiaio ole;
\q1 O ka mea ala, ea, he mea hoopailua ia ia'u;
\q1 O ka mahina hou, ka Sabati, a me ka aha i hoakoakoaia,
\q1 Aole hiki ia'u ke hoomanawanui,
\q1 He hewa no ia, o ia halawai ahaaina ana.
\q1 
\v 14 Ua ukiuki ko'u naau i ko oukou mau mahina hou, a me ko oukou halawai ana;
\q1 He mau mea kaumaha ia ia'u,
\q1 Ua luhi au i ka halihali ana.
\q1 
\v 15 Ia oukou e hohola mai ai i ko oukou mau lima,
\q1 E huna no wau i ko'u mau maka ia oukou;
\q1 A ia oukou e hoomahuahua i ka pule, aole au e hoolohe aku:
\q1 No ka mea, ua piha ko oukou lima i ke koko.
\b
\q1 
\v 16 E holoi oukou, e hoomaemae hoi;
\q1 E waiho aku i ka oukou hana hewa ana, mai ko'u alo aku;
\q1 Ua oki ka hana hewa ana;
\q1 
\v 17 E ao i ka hana maikai,
\q1 E imi i ka hoopono,
\q1 E alakai pololei i ka mea i hookaumahaia;
\q1 E hoopono i na keiki makua ole,
\q1 E kokua i ka wahinekanemake.
\b
\q1 
\v 18 E hele mai hoi, e kike kakou, wahi a Iehova:
\q1 Ina paha i like ko oukou hewa me na kapa ula,
\q1 E keokeo auanei ia me he hau la;
\q1 Ina paha i ula loa e like me ka mea ulaula,
\q1 E like auanei ia me he hulu hipa la.
\q1 
\v 19 Ina e ae mai oukou e hoolohe,
\q1 E ai no oukou i ka maikai o ka aina.
\q1 
\v 20 Aka, ina e hoole mai oukou, a e hoopaakiki,
\q1 E pau auanei oukou i ka pahikaua;
\q1 Na ka waha o Iehova i olelo mai.
\b
\q1 
\v 21 Auwe, ua lilo ke kulanakauhale pono i wahine moekolohe!
\q1 I kela wa, piha no i ka hoopono,
\q1 A noho no ka maikai maloko;
\q1 I keia wa hoi, he poe pepehi kanaka,
\q1 
\v 22 Ua lilo kou kala i oka,
\q1 Ua pai pu ia kou waina me ka wai.
\q1 
\v 23 He poe hookekee kou poe alii,
\q1 He poe hoa no na aihue;
\q1 Ua makemake lakou a pau i ka waiwai kipe,
\q1 Ua imi no i ka ukuia mai;
\q1 Aole lakou i hoopono i na keiki makua ole,
\q1 Aole hoi i hiki imua o lakou ka mea hooponoia o ka wahinekanemake.
\b
\q1 
\v 24 Nolaila, ke i mai nei ka Haku, o Iehova o na kaua,
\q1 Ka mea mana hoi o ka Iseraela,
\q1 Auwe! E hoomaha au ia'u iho i ko'u poe enemi,
\q1 E hoopai aku au i ka poe i inaina mai ia'u.
\b
\q1 
\v 25 E hoihoi aku au i ko'u lima maluna ou,
\q1 E hoomaemae loa au i kou ino,
\q1 E lawe aku hoi au i kou oka a pau.
\q1 
\v 26 E hoihoi hou no wau i kou mau lunakanawai, e like me ka wa i kinohi,
\q1 A me kou poe kakaolelo, e like me ka wa kahiko;
\q1 A mahope aku o keia, e kapaia oe,
\q1 Ke kulanakauhale o ka pono,
\q1 Ke kulanakauhale oiaio.
\b
\q1 
\v 27 E hoolaia no o Ziona i ka hoopono ana,
\q1 A me kona poe pio hoi i ka hoopololei.
\b
\q1 
\v 28 E luku pu ia ka poe kipi a me ka poe hewa,
\q1 A e hoopauia auanei ka poe haalele ia Iehova.
\q1 
\v 29 No ka mea, e hilahila auanei lakou i na laau oka a oukou I makemake ai,
\q1 E hilahila no i na pakanu a oukou i koho ai.
\q1 
\v 30 E like auanei oukou me ka laau oka i mae ka lau,
\q1 E like hoi me ka pakanu wai ole.
\q1 
\v 31 E lilo no ka mea ikaika, i huna olona,
\q1 A o kana hana hoi, i huna ahi,
\q1 E wela pu no ia mau mea elua,
\q1 Aohe mea nana e kinai.
\c 2
\b
\q1 
\v 1 KA olelo i hoikeia mai ia Isaia, ke keiki a Amosa, no ka Iuda, a me ko Ierusalema.
\b
\q1 
\v 2 E hiki mai no keia i na la mahope, E kukulu paa ia ka puu o ka hale o Iehova maluna o na mauna, A e hookiekieia maluna o na puu; A e holo no iloko ona na lahuikanaka a pau.
\q1 
\v 3 A e nui loa na kanaka e hele me ka olelo, E hele mai e pii kakou i ka mauna o Iehova, I ka hale hoi o ke Akua o Iakoba; Nana no e ao mai ia kakou i kona mau aoao, I hele ai kakou ma kona mau alanui. No ka mea, mai Ziona aku e laha aku ai ke kanawai, A o ka olelo a Iehova hoi, mai Ierusalema aku.
\q1 
\v 4 Nana no e hooponopono mawaena o ko na aina, E ao mai hoi i na lahuikanaka he nui loa. E kui lakou i ko lakou mau pahikaua i oo palau, A me ko lakou mau ihe hoi, i pahi paipai; Aole e hapai ko kekahi aina i ka pahikaua, e ka e i ko kekahi aina, Aole hoi lakou e ao hou i ke kaua.
\b
\q1 
\v 5 E ko ka hale o Iehova, e hele mai, E hele kakou ma ka malamalama o Iehova.
\b
\q1 
\v 6 He oiaio no, ua haalele oe i kou poe kanaka, I ko ka hale hoi o Iakoba; No ka mea, ua piha lakou i na mea mai ka hikina mai, I ka poe nana ao, e like me ko Pilisetia: A launa no hoi lakou i na keiki a na malihini.
\q1 
\v 7 Ua piha ko lakou aina i ke kala, a me ke gula, Aole e pau i ka heluia ko lakou waiwai; Ua piha hoi ko lakou aina i na lio, Aole e pau i ka heluia na kaakaua o lakou.
\q1 
\v 8 Ua piha ko lakou aina i na'kua lapuwale; Kulou no lakou ilalo imua o ka hana a ko lakou mau lima, Imua hoi o ka mea a ko lakou mau manamana lima i hana'i.
\q1 
\v 9 Nolaila, e kulou no ke kanaka uuku, E hoohaahaaia no hoi ke kanaka nui; Aole nae oe e kala mai ia lakou.
\b
\q1 
\v 10 E komo oe iloko o ka pohaku, e pee hoi iloko o ka lepo, No ka makau ia Iehova, a no ka nani hoi o kona hanohano.
\q1 
\v 11 E kulou auanei na maka kiekie o kanaka, A e hoohaahaaia ko kanaka lana haakei, O Iehova wale no ke hookiekieia i kela la.
\b
\q1 
\v 12 E kau mai no ka la o Iehova o na kaua, Maluna o na mea hanohano a kehakeha a pau, Maluna hoi o kela mea keia mea i hookiekieia, a e hoohaahaaia no oia;
\q1 
\v 13 Maluna o na laau kedera a pau o Lebanona, na mea loloa a kiekie, A maluna hoi o na laau oka a pau o Basana;
\q1 
\v 14 Maluna o na kuahiwi kiekie a pau, A me na puu a pau i hookiekieia:
\q1 
\v 15 Maluna o na halekiai kiekie a pau, A me na pa kaua kiekie a pau:
\q1 
\v 16 Maluna o na moku a pau o Taresisa, A me na mea milimili a pau i mahaloia.
\q1 
\v 17 E kulou no ilalo ko ke kanaka haaheo, E hoohaahaaia hoi ka manao kiekie o ke kanaka; O Iehova wale no ke hookiekieia i kela la.
\q1 
\v 18 A e nalowale loa na akua lapuwale.
\q1 
\v 19 E komo hoi na kanaka iloko o na ana pohaku a me na lua o ka lepo, No ka makau ia Iehova, a no ka nani hoi o kona hanohano. Ia ia e ku ai iluna, e hoonaueue ai i ka honua.
\q1 
\v 20 Ia la la e kiola aku no ke kanaka i kona mau akua kala, A me kona mau akua gula, ana i hana'i i mea hoomana, E lilo i na iole a me na opeapea.
\q1 
\v 21 A hele lakou iloko o na ana pohaku, Iloko hoi o na lua ma ka pali paa, No ka makau ia Iehova, A no ka nani hoi o kona hanohano, Ia ia e ku ai iluna e hoonaueue ai i ka honua.
\q1 
\v 22 Mai hilinai aku oukou i ke kanaka, Nona ka hanu ma kona mau pukaihu, No ka mea, heaha ia, i manaoia'i oia?
\c 3
\b
\q1 
\v 1 A IA hoi, o Iehova, ka Haku o na kaua, E lawe ana ia i na kookoo a pau, Mai ko Ierusalema, a mai ka Iuda aku, I ke kookoo a pau ma ka ai, i ke kookoo a pau ma ka wai,
\q1 
\v 2 I ka mea ikaika, a me ke kanaka koa, I ka lunakanawai, a me ke kaula. I ka mea kilokilo, a me ka mea kahiko;
\q1 
\v 3 I ka lunakanalima, a me ke kanaka koikoi, I ke kakaolelo, a me ka mea ike i na hana, I ka mea no hoi i akamai i ka hoowalewale moo.
\q1 
\v 4 E haawi aku no hoi au, e noho na kamalii maluna o lakou, E noho alii no na keiki uuku maluna o lakou.
\q1 
\v 5 E hookaumahaia na kanaka, kekahi e kekahi, A me ke kanaka hoi e kona hoa; A e hookiekie no ka mea opiopio maluna o ka mea kahiko, A me ka mea i hoowahawahaia maluna o ka mea hanohano.
\q1 
\v 6 E lalau no ke kanaka i kona hoahanau o ka hale o kona makuakane, me ka olelo iho, Ea, he aahu no kou, e noho alii oe maluna o makou, Malalo hoi o kou lima keia pilikia.
\q1 
\v 7 Ia la la, e hookiekie no kela i kona leo, me ka olelo mai, Aole au e noho hooponopono maluna o oukou, No ka mea, aohe ai ma ko'u hale, aole hoi he mea aahu; Mai hoonoho ia'u i alii maluna o kanaka;
\q1 
\v 8 No ka mea, ua kulanalana o Ierusalema, ua haule hoi o Iuda; No ke ku e o ko lakou elelo a me ka lakou hana ia Iehova, E hoonaukiuki aku i kona mau maka hanohano.
\b
\q1 
\v 9 O ka ike ana i ko lakou helehelena ka i hoike no lakou; Ke hai nei hoi lakou i ko lakou hewa e like me Sodoma, Aole lakou i hoole. Auwe ko lakou poe uhane! No ka mea, ua lawe mai lakou i ka hewa maluna o lakou iho.
\q1 
\v 10 E olelo aku oukou i na mea i pono, e pomaikai lakou, No ka mea, e ai no lakou i ka hua o ka lakou hana ana.
\q1 
\v 11 Auwe hoi ka mea i hewa! e poino no ia; E haawiia'ku nana ka uku o kona mau lima.
\b
\q1 
\v 12 O ko'u poe kanaka, o na kamal i ko lakou poe luna alunu, O na wahine hoi ka i noho alii maluna o lakou. E kuu poe kanaka, he poe hoolalau kou poe alakai, A ke hoopau nei lakou i ko oukou mau alanui.
\b
\q1 
\v 13 Ke ku nei no o Iehova e hoakaka mai, Ua ku no ia iluna e hooponopono i na kanaka.
\q1 
\v 14 E hele mai ana no o Iehova e hoopai, I na lunakahiko o kona poe kanaka, a me ko lakou poe alii: Ua hoopau oukou i na pawaina; Aia hoi ma ko oukou hale ka waiwai kaili wale ia o ka poe hune.
\q1 
\v 15 No ke aha la oukou e hookaumaha nei i ko'u poe kanaka? A e anai i na maka o ka poe hune? Wahi a ka Haku, o Iehova o na kaua.
\b
\q1 
\v 16 Ua olelo mai no hoi o Iehova, No ka laua haakei o na kaikamahine o Ziona, A hele me ka oeoe o na a-i, A me ka makaleho hilahila ole; He hele hooioi ko lakou hele, A kanikani na kupee o ko lakou wawae:
\q1 
\v 17 E hooolohelohe no ka Haku i ka pikopoo o na kaikamahine o Ziona, E hoike no o Iehova i ko lakou wahi hilahila,
\q1 
\v 18 Ia la la, e lawe aku no ka Haku i ko lakou mea e nani ai, I na kupee wawae, A me na upena papale oho, A me na lei o ka a i;
\q1 
\v 19 I na gula pepeiao, a me na kupee lima, A me na pale kalukalu;
\q1 
\v 20 I na papale hainaka, a me na kaula kupee wawae, I na kaei, a me na hue laau ala, A me na mea pale akua;
\q1 
\v 21 I na komolima, a me na gula ihu,
\q1 
\v 22 I na aahu kuai nui, a me na holoku, I na kalukalu nui, a me na hipuu kala;
\q1 
\v 23 I na aniani nana, a me na palule, I na ribina lei o ke poo, A me na aahu nui.
\q1 
\v 24 Ma kahi i aala, e pilau ana no, Ma kahi kaei, he kaula, Ma ke oho owili e ohule ana no, Ma kahi o ka pa-u hanohano, he kaei inoino, Ma kahi maikai e paawela ana no.
\q1 
\v 25 E haule no kou poe kanaka i ka pahikaua, A me kou poe koa hoi ma ke kaua.
\q1 
\v 26 E uwe, a e u hoi kona mau pukapa, A e noho neoneo oia ma ka lepo.
\c 4
\b
\q1 
\v 1 I A la la, e lalau aku no na wahine ehiku i ke kanaka hookahi, me ka olelo aku, E ai no makou i ka makou ai iho, A e komo no i ko makou lole; Ina e kapaia mai makou ma kou inoa, I mea e pau ai ko makou hoinoia.
\b
\q1 
\v 2 Ia la la, e puka mai ai ka Laia o Iehova, He hanohano, a he nani no hoi, E nani io no ka hua o ka aina, a me ka maikai, No ka poe i pakele o ka Iseraela.
\q1 
\v 3 A o ka mea i koe ma Ziona, A o ka mea i waihoia ma Ierusalema, E kapaia oia he hemolele, O na mea a pau i kakau pu ia me ka poe e ola ana ma Ierusalema;
\q1 
\v 4 A pau ka pelapela o na kaikamahine a Ziona i ka holoiia e ka Haku, A pau no hoi ke koko o Ierusalema i ka hemo, mai ona aku la, Ma ka mana o ka hoopono, A me ka mana o ke aa ana.
\q1 
\v 5 Alaila, na Iehova no e hana, Maluna o na wahi a pau o ka mauna Ziona, A maluna hoi o na aha halawai ona, I ao i ka la, a me ka uwahi, A i malamalama o ke ahi lapalapa i ka po; No ka mea, e kau mai no ka malu maluna o na mea nani a pau.
\q1 
\v 6 He halelewa no e malu ai i ke ao, no ka wela, He puuhonua, a he wahi malu hoi, No ka ino, a me ka ua.
\c 5
\b
\q1 
\v 1 E MELE aku au no kuu hiwahiwa, I ke mele o kuu hiwahiwa no kona pawaina. He pawaina ko kuu hiwahiwa, Aia ma ka puu hua nui.
\q1 
\v 2 Kohi iho la ia a puni i na makalua, A hoolei aku la i na pohaku ona, A malaila ia i kanu ai i kumu waina maikai, A kukulu no hoi i hale kiai maloko, A kalai iho la i lua kaomi waina malaila; A kakali iho la no ka hua ana mai i huawaina, Aka, hua mai la ia i ka haakea.
\b
\q1 
\v 3 Ano hoi, e ka poe e noho ana ma Ierusalema, A me na kanaka o ka Iuda, E hooponopono oukou iwaena o'u, a me ko'u pawaina.
\q1 
\v 4 Heaha ka mea hou e hiki ia'u ke hana no ko'u pawaina, I hana ole ia e au iloko ona? Ia'u i kakali ai no ka hua ana mai i na huawaina, No ke aha la ia i hua mai ai i ka haakea?
\q1 
\v 5 Ano hoi, e hai aku no wau ia oukou, I ko'u mea e hana'i i ko'u pawaina. E wawahi au i kona pa e ulu ana, a e pau no ia i ka aiia; E hoohiolo no hoi au i kona pa pohaku, a e pau no ia i ka hahiia:
\q1 
\v 6 E anai loa no wau ia wahi; Aole ia e paipaiia, aole hoi e olaolaoia: Aka, e ulu no ke kakalaioa malaila, a me ka laaukalakala; A na'u no e kauoha aku i na ao, I ua ole mai lakou i ka ua maluna ona.
\b
\q1 
\v 7 No ka mea, o ka pawaina o Iehova o na kaua, Oia ka ohana o ka Iseraela, O na kanaka hoi o ka Iuda kana mea kanu i olioli ai. Kakali iho la oia i ka hoopono, aia ka! he hookahe koko ana, Kakali no i ka maikai, aia ka! He nwe ana.
\b
\q1 
\v 8 Auwe ka poe i hoopili i kekahi hale i kekahi hale, A me ka poe i hui i kekahi mahinaai i kekahi mahinaai, A koe ole kahi kaawale, I noho o oukou wale no iwaena konu o ka aina!
\q1 
\v 9 Ma kuu pepeiao i hai mai nei o Iehova o na kaua, He oiaio no, e lilo ana na hale he nui loa i neoneo, A kanaka ole hoi na hale nui, a maikai.
\q1 
\v 10 E hua mai ana na eka pawaina he umi, i hookahi bata: A o ka omera hua e hua mai ia i hookahi epa.
\b
\q1 
\v 11 Auwe ka poe e ala ana i kakahiaka nui, e inu i ka mea awaawa, A kakali hoi a malehulehu, i wela ai lakou i ka waina!
\q1 
\v 12 O ka mea kani, a me ka lira, O ka pahu kani, a me ka hokiokio, O ka waina kekahi ma ka lakou ahaaina: Aole o lakou manao i ka hana a Iehova; A o ka hana hoi a kona mau lima, aole lakou i ike.
\b
\q1 
\v 13 Nolaila, hele pio aku la ko'u poe kanaka, no ka ike ole; A make no ko lakou poe hanohano i ka pololi, A maloo ko lakou lehulehu i ka makewai.
\q1 
\v 14 Nolaila i hoomahuahua ai ka po i kona makemake, A i hamama nui loa hoi i kona waha; E poho no ilalo kona nani, a me kona hooho ana, A me kona lehulehu, a me ka hauoli iloko ona.
\q1 
\v 15 E kulou no ilalo ke kanaka uuku, E hoohaahaaia ke kanaka nui, A e hoohaahaaia na maka o ka poe haaheo;
\q1 
\v 16 E hapai nui ia o Iehova o na kaua no ka hoopono, A e hoanoia ke Akua, ka Mea Hemolele, no ka pololei.
\q1 
\v 17 E ai no na keikihipa malaila, e like me ko lakou kula iho, A o hoopau no na malihini i na mea i koe o ka poe waiwai.
\b
\q1 
\v 18 Auwe ka poe kauo i ka poino maluna o lakou iho, me na kaula o ka hewa, A me ka hewa hoi, me he kaula la o ke kaa;
\q1 
\v 19 Ka poe i olelo, E hana wikiwiki oia i kana hana, I ike makou: E neenee hoi a hookoia mai ka manao paa o ka Mea hemolele o ka Iseraela, I hoomaopopo makou!
\b
\q1 
\v 20 Auwe ka poe kapa aku i ka hewa, he maikai; A i ka maikai hoi, he hewa; Ka poe i hoolilo i ka pouli, i malamalama, A i ka malamalama hoi, i pouli; A kapa i ka mea awaawa, he ono, A i ka mea ono hoi, he awaawa!
\q1 
\v 21 Auwe ka poe i akamai i ko lakou mau maka iho, A naauao hoi i ko lakou manao iho!
\q1 
\v 22 Auwe ka poe ikaika i ka inu waina, A me na kanaka ikaika i ke kawili i wai awaawa e inu ai:
\q1 
\v 23 Ka poe i hoapono aku i ka mea hewa no ke kipeia, A kaili aku i ka hoapono o ka mea i pono, mai ona aku la!
\b
\q1 
\v 24 Nolaila, e like me ka ai ana o ka lapalapa ahi i ka opala, A me ka pau ana o ka mauu i puhiia i ke ahi, Pela e lilo ai ko lakou kumu i ka popopo, A e lele hoi iluna ko lakou pua, e like me ka huna lepo: No ka mea; ua haalele lakou i ke kanawai o Iehova o na kaua, Ua hoowahawaha hoi i ka olelo a ka Mea hemolele o ka Iseraela.
\q1 
\v 25 Nolaila i hoaaia'i ka inaina o Iehova i kona poe kanaka, A ua o aku no oia i kona lima e ku e ia lakou, A ua hahau no oia ia lakou, a e haalulu na mauna: A e like auanei ko lakou kupapau me ka opala ma na alanui: Aole nae i huli aku kona huhu no keia mau mea a pau, Aka, ke o mai nei no kona lima i keia manawa.
\b
\q1 
\v 26 E kau no nae oia i ka hae, no na aina ma kahi loihi, A pio aku no oia ia lakou ma na welau o ka honua; Aia hoi! me ka wikiwiki loa lakou e hele mai ai.
\q1 
\v 27 Aohe mea o lakou e maloeloe, aohe mea kulanalana; Aohe mea i luluhi na maka, aohe mea hiamoe; Aohe mea i wehe i ke kaei o kona puhaka, Aole e moku ke kaula o kona kamaa.
\q1 
\v 28 Ua hookalaia ko lakou pua, Ua lena ko lakou kakaka a pau; Ua like na maiuu o ko lakou lio, me ka pohaku, A me ko lakou kaa, me ka puahiohio.
\q1 
\v 29 E like auanei ko lakou uwo ana me ko ka liona, E uwo no lakou e like me na liona hou; E nunulu lakou, a hopu aku i ka mea pio, A e lawe aku, aohe mea e pakele ai.
\q1 
\v 30 Ia la la, e halulu ku e no oia ia lakou, E like me ka halulu ana o ke kai; Alaila, e nana lakou ma ka aina, Aia hoi, he pouli ino! Ua lilo ka malamalama i pouli, no na ao eleele ona!
\c 6
\b
\q1 
\v 1 I KA makahiki i make ai ke alii, o Uzia, ike aku la au i ka Haku, e noho ana ma ka nohoalii kiekie, i hapaiia, a piha ka luakini i kona hua lole.
\q1 
\v 2 Ku mai la maluna, ma o na la, na Serapima; he paono, he paono na eheu ia lakou a pau. Me na mea elua ia i uhi ai i kona maka, me na mea elua ia i uhi ai i kona mau wawae, a me na mea elua ia i lele ai.
\q1 
\v 3 A hea ae la kekahi i kekahi, Ihiihi, ihiihi, ihiihi no o Iehova o na kaua. Ua piha ka honua i kona nani.
\q1 
\v 4 Haalulu na paepaepuka, i ka leo o ka mea nana i hea, a piha iho la ka hale i ka uwahi.
\b
\q1 
\v 5 Alaila, olelo iho la au, Auwe au! ua make au; no ka mea, he kanaka lehelehe haumia au, a ke noho nei au iwaena o ka lahuikanaka lehelehe haumia; no ka mea, na ike ko'u mau maka i ke alii, ia Iehova o na kaua.
\b
\q1 
\v 6 A lele mai la kekahi o na Serapima io'u nei, aia ma kona lima ka pohaku enaena, ana i lawe ai, mai ke kuahu mai, me na upa ahi.
\q1 
\v 7 A hoopa mai la ma kuu waha, i mai la, Aia hoi, ua hoopa keia ma kou mau lehelehe, ua laweia kou hewa, ua kalaia kou hala.
\q1 
\v 8 A lohe iho la no hoi au i ka leo o ka Haku, i ka i ana mai, Iawai la wau e hoouna aku ai? A owai ka mea nana e hele no kakou? Alaila, i aku la au, Eia no wau, e hoouna ia'u.
\b
\q1 
\v 9 I mai la ia, O hele, e olelo aku i keia poe kanaka,
\q1 I ka lohe ana, e lohe no oukou, aole nae e hoomaopopo,
\q1 I ka ike ana, e ike no, aole nae e akaka ka ike ana.
\q1 
\v 10 E hoopalaka i ka naau o keia poe kanaka,
\q1 E hookuli i ko lakou pepeiao,
\q1 A e hoopaa i ko lakou maka;
\q1 O ike ko lakou mau maka,
\q1 A lohe hoi ko lakou mau pepeiao,
\q1 A hoomaopopo ko lakou naau,
\q1 A huli lakou, a hoolaia mai lakou.
\q1 
\v 11 Alaila, i aku la au, E ka Haku, pehea ka loihi?
\q1 I mai la ia, A neoneo na kulanakauhale, aohe mea noho iloko,
\q1 A kanaka ole ko lakou hale,
\q1 A anai loa ia'ku ka aina,
\q1 
\v 12 A lawe loihi aku o Iehova i na kanaka,
\q1 A mahuahua ka olohelohe ana mawaenakonu o ka aina;
\b
\q1 
\v 13 Ina i koe kekahi hapaumi o na mea,
\q1 E anai loa ia'ku no ia.
\q1 Aka, e like me ka laau hukaa, a me ka oka,
\q1 I ka wa i kuaia, ua koe no ke kumu;
\q1 Pela no e lilo ai kekahi mamo hemolele,
\q1 I kumu hoolaha no lakou.
\c 7
\b
\q1 
\v 1 I KE kau ia Ahaza, ke keiki a Iotama, ke keiki a Uzia, ke alii o ka Iuda, hele mai o Rezina, ke alii o Suria, a me Peka, ke keiki a Remalia, ke alii o ka Iseraela, e ku e ia Ierusalema, kaua mai, aole nae i hiki ia lakou ke lanakila maluna o ia wahi.
\q1 
\v 2 A haiia mai la i ko ka hale o Davida, i ka i ana mai, Ke hoomoana nei ko Suria maloko o ko Eperaima. Alaila, haalulu ka naau o ke alii, a me ka naau o kona poo kanaka, o like me ka haalulu ana o na laau o ka ululaau imua o ka makani.
\b
\q1 
\v 3 I mai la o Iehova ia Isaia, O hele, ano, e halawai me Ahaza, o oe, a me Seariasuba, kau keiki, ma ka welau o ka auwai o ka waipuna luna, ma ke ala e hiki aku ai ke kula holoi lole;
\q1 
\v 4 A e i aku oe ia ia,
\q1 E ao oe, e noho malie;
\q1 Mai makau hoi, mai maule kou naau,
\q1 No na welowelo alua o keia mau momoku ahi,
\q1 O ka huhu o Rezina, a me ko Suria, a me ko keiki a Remalia.
\q1 
\v 5 No ka imi hala o ko Suria ia oe,
\q1 A me Eperaima, a me ke keiki a Remalia, i ka i ana ae,
\q1 
\v 6 E pii ku e kakou i ka Iuda, e hoopilikia aku hoi,
\q1 A e mahele ia wahi no kakou,
\q1 A e hoonoho i ke keiki a Tabeala, i alii maloko ona.
\q1 
\v 7 Ke i mai nei ka Haku, o Iehova penei,
\q1 Aole e ku keia, aole ia e hanaia.
\q1 
\v 8 O ke poo o Suria, o Damaseko ia,
\q1 A o ke poo o Damaseko, o Rezina no;
\q1 He kanaonokumamalima makahiki i koe,
\q1 Alaila, kahuli o Eperaima, a lilo i aupuni ole.
\q1 
\v 9 O Samaria no ke poo o Eperaima,
\q1 A o ke poo hoi o Samaria, oia ke keiki a Remalia.
\q1 I ole oukou e manaoio i keia, aole oukou e malu.
\b
\q1 
\v 10 Olelo hou mai o Iehova ia Ahaza, i mai la,
\q1 
\v 11 E nonoi oe i hoailona nou, mai Iehova, mai kou Akua mai;
\q1 E nonoi ma ka hohonu, a ma kahi kiekie paha.
\q1 
\v 12 I aku la o Ahaza, Aole au e nonoi,
\q1 Aole hoi au e aa aku ia Iehova.
\q1 
\v 13 Alaila, i mai la ia, E hoolohe oukou, e ka ohana a Davida,
\q1 He mea uuku anei ia oukou ke hoopaupauaho i kanaka?
\q1 E hoopaupauaho pu anei oukou i ko'u Akua?
\q1 
\v 14 Nolaila, na ka Haku ponoi no e haawi mai ia oukou i hoailona;
\q1 Aia hoi! e hapai ana no kekahi wahine puupaa,
\q1 A e hanau mai hoi ia i keiki,
\q1 A e kapa aku no oia i kona inoa, o IMANUELA.
\q1 
\v 15 O ka waiu paa a me ka mele kana e ai ai,
\q1 A ike oia i ka hoole i ka hewa, a e koho hoi i ka pono.
\q1 
\v 16 No ka mea, mamua o ka ike ana o ke keiki e hoole i ka hewa,
\q1 A e koho hoi i ka pono,
\q1 E neoneo e no ka aina o ua mau alii la elua au e makau nei.
\b
\q1 
\v 17 Na Iehova no e hoopuka mai maluna ou,
\q1 A maluna hoi o kou poe kanaka,
\q1 A maluna o ka hale o kou makuakane,
\q1 I na la i hiki ole mai ai mamua,
\q1 Mai ka wa mai o ko Eperaima haalele ana i ka Iuda;
\q1 I ke alii no Asuria.
\q1 
\v 18 A hiki aku i kela la,
\q1 Na Iehova no e pio aku i ka nalo,
\q1 E noho ana ma na welau o na muliwai o Aigupita,
\q1 A i ka nalo-hope-eha, ma ka aina o Asuria;
\q1 
\v 19 A e hele mai hoi lakou, a e kau mai lakou a pau,
\q1 Ma na kahawai olohelohe, a ma na lua o na pohaku,
\q1 A ma ka nahele ooi a pau,
\q1 A ma na kula holoholona a pau.
\b
\q1 
\v 20 Ia la la, na ka Haku no e kahi, me ka pahi-kahi i hoolimalimaia, ma kela aoao o ka muliwai,
\q1 Me ke alii hoi o Asuria,
\q1 I ke poo, a me ke oho o na kapuwai;
\q1 A e kahiia no hoi ka umiumi.
\b
\q1 
\v 21 A hiki aku i kela la,
\q1 E hanai no ke kanaka i ka bipi ohi, a me na hipa elua;
\q1 
\v 22 A no ka nui loa mai o ka waiu,
\q1 E ai no ia i ka waiupaa;
\q1 E ai io no i ka waiupaa a me ka meli,
\q1 O ka poe a pau i koe ma ka aina.
\q1 
\v 23 A hiki aku i kela la,
\q1 O kahi a pau i ulu ai na kumuwaina, he tausani,
\q1 I kuaiia no na hapalua he tausani,
\q1 E paapu ia wahi i ka nahele ooi, a me ka laau kalakala.
\q1 
\v 24 Me na pua a me na kakaka lakou e hele ai ilaila,
\q1 No ka mea, e nahelehele ana no ka aina a pau,
\q1 I ka laau kalakala a me ka nahele ooi.
\q1 
\v 25 Ma na mauna a pau i olaolaoia i ka oo,
\q1 Aohe mea hele ilaila,
\q1 No ka makau i ka laau kalakala, a me ka nahele ooi:
\q1 He wahi ia e hoouna aku ai i ka bipi,
\q1 He wahi hoi e hahi ai na hipa.
\c 8
\b
\q1 
\v 1 I MAI la o Iehova ia'u, E lawe oe i ka papa palapala nui nou, a e kahakaha maluna olaila me ka peni kahakaha, no Mahera-sala-hasaba.
\q1 
\v 2 Alaila, lawe iho la au i kekahi mau mea pono, i poe hoike, ia Uria hoi i ke kahuna, a me Zekaria ke keiki a Ieberekia.
\q1 
\v 3 A ua hookokoke au i ke kaula wahine, a ua hapai no ia, a ua hanau, he keikikane. I mai la o Iehova ia'u, E kapa aku i kona inoa, Mahera-sala-hasaba.
\q1 
\v 4 No ka mea, mamua o ka ike ana o ke keiki e hea aku, E ko'u makuakane, e ko'u makuwahine, e laweia'ku no ka waiwai o Damaseko, a me ka waiwaipio o Samaria, imus o ke alii o Asuria.
\b
\q1 
\v 5 Aka, olelo hou mai la o Iehova ia'u, i mai la,
\q1 
\v 6 No ka hoowahawaha aua o keia poe kanaka i ka wai o Siloa e kahe malie ana,
\q1 A hauoli hoi ma Rezina, a me ke keiki a Remalia;
\q1 
\v 7 Nolaila, aia hoi! e lawe mai no ka Haku maluna o lakou,
\q1 I na wai he ikaika a he nui, o ka muliwai,
\q1 I ke alii hoi o Asuria, a me kona hanohano alii a pao,
\q1 A e hu no ia mawaho o kona manowai a pau,
\q1 A e kahe hoi maluna o koua mau kapa a pau.
\q1 
\v 8 E hu no ia maluna o Iuda, a holo moku hoi,
\q1 E pii no a hiki i ka a-i;
\q1 A o ka hohola ana o kona mau eheu,
\q1 O ka palahalaha ia o kou aina, e Imanuela.
\b
\q1 
\v 9 E hana ino oukou, e na kanaka, a e mokuahana hoi;
\q1 E holohe mai, e na aina a pau o kahi loihi;
\q1 E kaei oukou ia oukou iho, e mokuahana no;
\q1 E kaei oukou ia oukou iho, e mokuahana no.
\q1 
\v 10 E ohumn pu oukou, a e hookahuliia ka ohuma ana,
\q1 E kau oukou i ka olelo, aole nae ia e paa:
\q1 No ka mea, o ke Akua pu me makou.
\b
\q1 
\v 11 Olelo o Iehova ia'u peuei, ma ke koi ana mai o ka lima,
\q1 A ao mai la oia ia'u aole e hele ma ka aoao o keia poe kanaka, i mai la,
\q1 
\v 12 Mai olelo oukou. He kipi.
\q1 Ma na wahi a pau i olelo ai keia poe kanaka. He kipi;
\q1 Mai makau oukou i ko laku mea e makau ai,
\q1 Mai hopohopo hoi oukou.
\q1 
\v 13 O Iehova o na kaua, oia ka oukou e hoolaa ai,
\q1 Oia hoi ka oukou e makau ai, a e hopohopo hoi oukou ia ia.
\q1 
\v 14 A e lilo ia i puuhonua,
\q1 I pohaku no hoi kekahi e kuia'i,
\q1 A i puu no hoi e hina'i
\q1 No na ohana elua o ka Iseraela,
\q1 I pahele, a i upiki no ka poe e noho ana ma Ierusalema.
\q1 
\v 15 He nui ko lakou poe e kuia'i,
\q1 A me ka poe e bina ana, a eha,
\q1 A me ka poe e boopaheleia, a paa hoi.
\b
\q1 
\v 16 E opeope i ka hoike ana,
\q1 E hoopaa hoi i ka wanana, imua o ka'u poe haumana.
\q1 
\v 17 Aka, e kakali no au ia Iehova,
\q1 Ka mea i huna i kona maka mai ka ohana a Iakoba aku,
\q1 A ia ia no wau e hilinai ai.
\q1 
\v 18 Eia hoi au, a me na keiki a Iehova i haawi mai ai na'u,
\q1 I mau hoailona, a i mau ouli hoi maloko o ka Iseraels,
\q1 Mai Iehova o na kaua mai,
\q1 Ka mea e noho la ma ka mauna o Ziona.
\b
\q1 
\v 19 A olelo mai lakou ia oukou,
\q1 E hele i ka poe ninau kupapau, a i na kupua hoi,
\q1 I ka poe muki, a me ka mea namu liilii;
\q1 Aole anei e hele na kanaka i ko lakou Akua?
\q1 E hele anei i ka poe make no na mea e ola ana?
\q1 
\v 20 Ma ke kanawai, a ma ka hoike ana hoi;
\q1 Ina olelo ole lakou e like me ia olelo,
\q1 Aole e puka mai ke ao maluna o lakou.
\q1 
\v 21 E kuewa wale lakou malaila,
\q1 Me ke kaumaha a me ka pololi;
\q1 A hiki i ka wa e pololi ai lakou,
\q1 Ia lakou iho no lakou e huhu ai,
\q1 Alaila, e olelo hoino no lakou,
\q1 I ko lakou alii, a me ko lakou Akua,
\q1 Alaila, e nana no iluna.
\q1 
\v 22 E nana hoi lakou ma ka aina;
\q1 Aia hoi! he popilikia, a me ka pouli,
\q1 He pouli ino hoi;
\q1 Ua kipakuia iloko o ka poeleele.
\c 9
\b
\q1 
\v 1 I ka wa i hoowahawahaia'i ka aina o Zebuluna, a me ka aina o Napetali, A mahope iho, hoonani oia i kahi maikai, Ma kela aoao o Ioredane, o Galilaia no na kanaka e.
\q1 
\v 2 O na kanaka i hele ma ka pouli, E ike auanei lakou i ka malamalama nui; O ka poe i noho ma ka aina o ke aka o ka make, E alohi mai auanei ka malamalama maluna o lakou.
\q1 
\v 3 Ua hoonui oe i ka lahuikanaka, Ua hoomahuahua oe i ko lakou olioli; Ke olioli nei lakou imua ou, E like me ka olioli ana i ka hooiliili ai ana, E like hoi me ka hauoli ana o ka poe puunauwe i ka waiwai pio.
\q1 
\v 4 No ka mea, o kona auamo kaumaha, O ka laau i hahau i kona kua, A me ke kookoo o ka mea hookaumaha ia ia, Ua haki oe ia mau mea me ia i ka la o Midiana.
\q1 
\v 5 No ka mea, o na palewawae a pau o ka mea i kahikoia i ka palewawae e wawalo ana, A me na aahu i opeope pu ia me ke koko, E lilo no ia mau mea i mea e puhiia, I wahie hoi no ke ahi.
\q1 
\v 6 No ka mea, ua hanauia mai, he keiki no kakou, No kakou i haawiia mai ai, he keikikane, Maluna o kona poohiwi ke aupuni; A e kapaia kona inoa, o Kupaianaha, O Kakaolelo, o Keakuamana, O Kamakuamauloa, o Kealiiokamalu.
\b
\q1 
\v 7 Aole e pau ka mahuahua ana o kona aupuni, a me ka malu; Ma ka nohoalii o Davida ia, A ma kona aupuni no hoi, E hoala hou ia mea, a e hookupaa ia ia, Me ka hooponopono, a me ka maikai, Mai keia wa aku, a i ke ao pau ole. Na ka ikaika o Iehova o na kaua e hana i keia.
\b
\q1 
\v 8 Ka olelo a ka Haku i hoouna aku ai no Iakoba, A haule hoi ia maluna o ka Iseraela.
\q1 
\v 9 E ike auanei na kanaka a pau o Eperaima, A me ka poe noho ma Samaria, Ka poe i olelo me ka hookiekie, a me ka hookano o ka naau,
\q1 
\v 10 Ua hiolo na pohaka lepo, A na makou e kukulu, he pohaka i kalaiia; Ua kuaia ilalo na laau sukomorea, A na makou no e kanu i na laau kedera.
\q1 
\v 11 Na Iehova no e hoala mai i na enemi o Rezina, e ku e ia ia, E paipai oia i kona poe enemi:
\b
\q1 
\v 12 O na Suria ma ka hikina, a ma ke komohana hoi o na Pilisetia, A e hoopaa no i ka Iseraela me ka waha hamama: Aole nae i huli aka kona huhu no keia mau mea a pau, Ke o mai nei no oia i kona lima i keia manawa.
\b
\q1 
\v 13 Aole nae i hoi hou na kanaka, I ka mea nana lakou i hahau, Aole lakou i imi ia Iehova o na kaua.
\q1 
\v 14 Nolaila e oki ai o Iehova, mai ka Iseraela aku, I ke poo, a me ka huelo, I ka lala pama, a me ke naku, ma ka la hookahi.
\q1 
\v 15 O ka lunakahiko a me ka mea koikoi, oia ke poo, O ke kaula i ao mai i ka wahahee, oia ka huelo.
\q1 
\v 16 O na alakai o keia poe kanaka, he poe alakai hewa lakou; A o ka poe i alakai hewa ia, e lukuia no lakou.
\q1 
\v 17 Nolaila, aole olioli ka Haku maluna o ko lakou poe ui. Aole hoi ia e aloha i na keiki makua ole o lakou, A me ko lakou wahinekanemake; No ka mea, ua haumia lakou a pau, a ua hewa, Olelo no na waha a pau ma ka lapawale. Aole nae i hali aku kona huhu no keia maa mea a pau, Aka, ke o mai nei no kona lima i keia manawa.
\b
\q1 
\v 18 No ka mea, e a ana ka hewa e like me ke ahi, E hoopaa no ia i ka nahele ooi, a me ka laau kalakala, A e a no hoi ia maloko o ka ululaau paapu; A e punohn iluna, he punohu u wahi.
\q1 
\v 19 Ua hoaia ka aina, no ka ukiuki o Iehova o na kaua, A ua lilo hoi na kanaka i wahie no ke ahi; Aohe kanaka i aloha i kona hoa.
\q1 
\v 20 E ai no ia ma ka lima akau, a e pololi nae, E ai no hoi ia ma ka lima hema, aole nae e maona; E ai no ke kanaka i ka io o kona lima iho.
\q1 
\v 21 O Manase ia Eperaima, a o Eperaima hoi ia Manase, A e hui no hoi laua e ku e ia Iuda; Aole nae i huli aku kona huhu no keia mau mea a pau, Aka, ke o mai nei no kona lima i keia manawa.
\c 10
\b
\q1 
\v 1 A UWE ka poe kau i na kanawai hewa, A me ka poe kakauolelo, i kakau i na mea kekee;
\q1 
\v 2 I kipaku i ka poe kaumaha, mai ka hooponoia'ku, A kaili aku hoi i ka pono o ko'u poe kanaka poino, I pio ia lakou na wahinekanemake, A hao wale hoi i na keiki makua ole!
\q1 
\v 3 Pehea la oukou e hana'i i ka la o ka hoopui ana, Ke hiki mai ka make mai kahi loihi mai? Ia wai oukou e holo ai no ke kokuaia mai? Mahea oukou e waiho ai i ko oukou waiwai?
\q1 
\v 4 I haaleleia e au, e kulou no lakou malalo me na mea pio, A e hina hoi malalo me na mea i lukuia. Aole nae i huli aku kona huhu no keia mau mea a pau, Aka, ke o mai nei no kona lima i keia manawa.
\b
\q1 
\v 5 Auwe ko Asuria! ka laau hahau o kuu ukiuki, A o ua laau hahau la, aia no ia ma ko lakou lima, Oia hoi kuu inaina.
\q1 
\v 6 E hoouna aku au ia ia, e ku e i ka lahuikanaka aia, E kauoha aku no wau ia ia, E ku e i ka poe kanaka a'u i huhu ai; E hao aku i ka waiwaipio, a e lawe aku hoi i ka mea i paa; A e hahi ia lakou ilalo, e like me ka lepo o ke alanui.
\q1 
\v 7 Aole pela kona manao, Aole i noonoo kona naau pela; O ka luku no ka mea iloko o kona naau, A e anai aku i na aina he nui loa.
\q1 
\v 8 I mai la ia, aole anei he poe alii nui ko'u poe alii?
\q1 
\v 9 Aole anei i like o Kaleno me Karekemisa? A o Hamata hoi me Arepada? A o Samaria me Damaseko?
\q1 
\v 10 E like me ka loaa i kuu lima na aupuni o na'kua kii, Ua oi aku ko lakou akua kii mamua o ko Ierusalema, A mamua hoi o ko Samaria;
\q1 
\v 11 Me au i hana aku ai ia Samaria a me kona poe akua kii, Aole anei au e hana pela ia Ierusalema a me kona mau akua?
\b
\q1 
\v 12 A hiki aku i ka wa, e hooki ai ka Haku i kana hana a pau, Maluna o ka mauna o Ziona, a me Ierusalema, Alaila wau e hoopai aku ai i ka hua o ka naau kiekie o ke alii o Asuria, A me ka hookano ana o kona maka hookiekie.
\q1 
\v 13 No ka mea, ua olelo mai ia, Ua hana au i keia, i ka ikaika o ko'u lima iho, A i kuu akamai hoi, no ka mea, ua maalea au. Na'u no i hooneenee i na mokuna o na aina, A ua hao aku au i ko lakou waiwai, A e like hoi me ke kanaka koa, ua hoohaahaa wau i ka poe e noho ana.
\q1 
\v 14 Me he punana la i loaa'i i kuu lima ka waiwai o na lakuikanaka; A e like me ka hoiliili ana o na hua manu i haaleleia, Pela no wau i hoiliili ai i ko na aina a pau; Aohe mea i upoi ka eheu, Aohe mea i hamama ka waha a ioio.
\b
\q1 
\v 15 E hookiekie anei ke koilipi maluna o ka mea nana e kalai me ia? E haanui anei ka pahiolo maluna o ka mea nana ia e oloolo? Me he laau la i wiliwili i kona mea nana e hapai, E like me ke kookoo hoi i hoala ia ia iho me he mea laau ole la.
\q1 
\v 16 Nolaila e hoouna mai ai ka Haku, ka Haku o na kaua, I ka wiwi maluna o kona poe puipui; A malalo iho o kona nani e puhi ai oia i ka mea aa, E like me ke aa ana o ke ahi.
\q1 
\v 17 E lilo no ka malamalama o Iseraela i ahi, A o kona Mea Hemolele hoi i lapalapa ahi; A e puhi no ia, a e hoopau ma ka la hookahi, I kona nahele ooi, a me kona laau kalakala.
\q1 
\v 18 E hoopau loa no ia i ka nani o kona ululaau, A me ka mahinaai hua nui, mai ka uhane a ke kino; A e like auanei ia me ka mea mai hokii loa.
\q1 
\v 19 E uuku ana no ke koena o kona ululaau, E hiki no i ke keiki uuku ke palapala ia lakou.
\b
\q1 
\v 20 A hiki aku i kela la, O ke koena o ka Iseraela, O ka poe hoi i pakele o ka ohana a Iakoba, Aole lakou e hilinai hou maluna o ka mea nana lakou i pepehi; Aka, e hilinai io no maluna o Iehova, A maluna hoi o ka Mea Hemolele o ka Iseraela.
\q1 
\v 21 He koena no ke hoi mai, he koena no Iakoba, I ke Akua mana loa.
\q1 
\v 22 Ina paha i like kou poe kanaka o Iseraela, Me ke one o ke kai, He koena wale no o lakou ke hoi mai; Ua holo ka olelo no ka hoopau ana, E hiki wawe mai ia, me ka pololei hoi.
\q1 
\v 23 He oiaio no, ua holo ka olelo no ka hoopau ana, A na ka Haku no, na Iehova o na kaua e hana mai, Mawaena konu o ka aina a pau.
\b
\q1 
\v 24 Nolaila i olelo mai ai ka Haku, o Iehova o na kaua, peneia, E ko'u poe kanaka e noho la ma Ziona, Mai makau oukou i ko Asuria; E hahau mai no lakou me ka laau hahau, A e hapai no hoi i ke kookoo maluna ou, E like me ka hana ana o Aigupita.
\q1 
\v 25 Aka, he wahi manawa uuku no e koe, Alaila, e kaa no kuu inaina, a me ko'u ukiuki hoi. Ma ke anaiia'ku o lakou.
\q1 
\v 26 Na Iehova o na kaua e hapai i laau hahau maluna o lakou, E like me ka hahau ana i ko Midiana ma ka pohaka o Oreba: A me ka laau ana i hapai ai maluna o ke kai, E hapai no oia ia e like me kana hana ana i ko Aigupita.
\q1 
\v 27 A hiki mai ia la, E laweia'ka kona mea kanmaha, mai koa poohiwi ako, A me kona auamo maluna ako o kou a-i, E hakiia auanei imua o ka mea puipui
\b
\q1 
\v 28 Ua hele mai ia i Aiata, ua hala loa aku i Migerona, Ua waiho no i kana ukana ma Mikemasa:
\q1 
\v 29 Ua hele mai lakou ma keia aoao o ke ahua; Aia ma Geba ko lakou wahi moe i ka po: Ua makau ko Rama; ua holo ko Gibea Saula.
\q1 
\v 30 E hookiekie i koa leo, e ke kaikamahine a Galima; E hoolohe oe, e Laisa; Auwe Anatota poino!
\q1 
\v 31 Ua holo o Mademena: Ua hee ka poe i noho ma Gebima.
\q1 
\v 32 Hookahi no la e koe o kona noho ana ma Noba, A e lulu ia i kona lima e ku e i ka mauna o ke kaikamahine o Ziona, I ka puu hoi o Ierusalema.
\b
\q1 
\v 33 Aia hoi, na ka Haku, na Iehova o na kaua, E okioki i na lala me ka weliweli, A e kuaia ilalo na mea kiekie loa, A e hoohaahaaia na mea hookano.
\q1 
\v 34 E kuaia ilalo me ka hao i na ululaau paapu, A e haule hoi o Lebanona imua o ka mea mana.
\c 11
\b
\q1 
\v 1 E KUPU mai no ka lala mailoko mai o ke kumu o Iese, A e hua nui mai hoi kekahi oha o kana aa:
\q1 
\v 2 Maluna ona e kau ai ka Uhane o Iehova, Ka uhane akamai, a me ka ike, Ka uhane kakaolelo, me ka mana, Ka uhane e ike ai, a e makau ai hoi ia Iehova.
\q1 
\v 3 Ma ka makau ia Iehova kona olioli, Aole ia e hoopono ma ka nana ana o kona maka, Aole ka hoi hoopai ma ka lohe pepeiao.
\q1 
\v 4 E hoopono oia i ka poe nawaliwali, ma ka pololei, Ma ka pono no hoi ia e kokua ai i ka mea popilikia o ka honua; E hahau no oia i ka honua i ka laau o kona waha, A e luku no hoi ia i ka poe hewa, i ka ha ana o kona mau lehelehe.
\q1 
\v 5 O ka pono no ke kaei o kona puhaka, A o ka oiaio hoi ke kakoo o kona kikala.
\b
\q1 
\v 6 Alaila, e noho pu no ka iliohae me ke keikihipa, A e moe pu no ka leopadi, me ke keikikao; O ke keikibipi, a me ka liona hou, a me ka bipi i kupaluia, E kuikahi no lakou; A na ke keiki uuku lakou e alakai.
\q1 
\v 7 E ai pu no ka bipi wahine, a me ka bea, E moe pu ka lakou mau keiki; A e ai no hoi ka liona i ka mauu maloo, me he bipi la.
\q1 
\v 8 E paani no ke keiki ai wain ma ka lua o ka moomake, A e kau no ke keiki i ukubiia i kona lima ma ka lua moopepeiaohao.
\q1 
\v 9 Aohe mea hana hewa, aohe mea luku ma ko'u mau kuahiwi hoano a pau; No ka mea, e piha auanei ka honua i ka ike ia Iehova, E like me ka moana i uhiia i ke kai.
\b
\q1 
\v 10 A hiki aku ia la, E puka mai no kekahi lala no Iese, A e ku no ia, i hae no na lahuikanaka, A e imi no ko na aina ma ona la; A he nani hoi kona wahi hoomaha.
\b
\q1 
\v 11 A hiki aku i? kela la, E hohola hou mai ka Haku i kona lima, E hoola i ke koena o kona poe kanaka, I ka poe e koe ma Asuria, a ma Aigupita, a me Paterosa. Ma Kusa a me Elama, ma Sinara a me Hamata, A ma na mokupuni o ke kai.
\q1 
\v 12 E kau no hoi ia i ka hae no na aina, A e hooiliili hoi i ka poe aea o ka Iseraela, A e hoakoakoa mai i na mea puehu o ka Iuda, Mai na kihi eha mai o ka honua.
\q1 
\v 13 Alaila, e oki no ka huahua o ka Eperaima, A e pau no hoi na enemi o ka Iuda; Aole huahua ka Eperaima i ka Iuda, Aole hoi e hoomaau ka Iuda i ka Eperaima.
\q1 
\v 14 E lele lakou ma na palena o ko Pilisetia ma ke komohana, Na lakou pu no e hao i na keiki o ka hikina; E kau no lakou i ko lakou lima maluna o Edoma, a me Moaba, A e hookauwa ka Amona na lakou.
\q1 
\v 15 E hoomaloo no o Iehova i ke kaikuono o ke kai o Aigupita; A e hohola aku hoi kona lima maluna o ka muliwai me kona makani ikaika; E hahau no hoi oia, a e lilo ia i ehiku kahawai, I hele lakou ma kela aoao me na kamaa.
\q1 
\v 16 A e hoomakaukauia he alanui no ke koena o kona poe kanaka, Ka poe i koe ma Asuria; E like hoi me ka mea o ka Iseraela, I ko lakou wa i hele mai ai, Mai ka aina o Aigupita mai.
\c 12
\b
\q1 
\v 1 I A la la, e olelo aku no oe, E hoolea aku au ia oe, e Iehova, No ka mea, i huhu mai oe ia'u mamua, Aka, ua huli aku kou huhu, A ua hoomaha mai oe ia'u.
\q1 
\v 2 Aia hoi, o ke Akua ko'u ola, E hoolana wau, aole au e makau; No ka mea, o ka Haku, o IEHOVA ko'u ikaika a me kuu oli, Ua lilo mai ia i ola no'u.
\q1 
\v 3 E huki no oukou i ka wai me ka olioli, Mailoko mai o na punawai ola.
\q1 
\v 4 A i kela la, e olelo ana no oukou, E hoolea ia Iehova, E hookaulana i kona inoa, E hoike aku iwaena o na kanaka, i kana mau hana, E hoomanao aku, no ka mea, na hapaiia kona inoa.
\q1 
\v 5 E oli aku ia Iehova, no ka mea, na hana oia i na mea nani; He mea ikea keia ma ka honua a pau.
\q1 
\v 6 E hooho aku, e hookani hoi, e ka mea noho ma Ziona, No ka mea, ua mana maloko ou, ka Mea Hemolele o ka Iseraela.
\c 13
\b
\q1 
\v 1 KA wanana no Babulona, ka mea a Isaia, ke keiki a Amosa i ike ai.
\q1 
\v 2 E kau i ka hae ma ka mauna olohelohe, E hookiekie i ka leo io lakou la, e peahi ka lima, I komo lakou maloko o na pukapa o na'lii.
\q1 
\v 3 Ua kauoha aku au i ko'u poe i hookaawaleia no ke kaua, A no ka ukiuki, ua hea aku au i ko'u poe koa, Kuu poe olioli me ka hookiekie.
\q1 
\v 4 Ka hooho ka a ka poe nui muluna o na mauna, E like me ko ka lahuikanaka nui; Ka hooho o ka hui ana o na aupuni, A me na aina i hoakoakoaia. O Iehova o na kaua, e hoolalelale ana ia i ke kaua no ka hoouka.
\q1 
\v 5 Hele mai no lakou, mai ka aina mamao aku, A mai ka welau mai o ka lani; O Iehova, a me na mea hoopai o kona ukiuki, E anai i ka aina a pau.
\b
\q1 
\v 6 E aoa oukou, no ka mea, ua kokoke mai ka la o Iehova; E hiki mai no ia, e like me ka puahiohio, mai ka Mea Mana mai.
\q1 
\v 7 Nolaila, e lewa wale ilalo na lima a pau, A e maule hoi na naau a pau o kanaka:
\q1 
\v 8 E makau ananet lakou; E loohia lakou i ka eha nui, a me ka nahu kuakoko, E nui loa auanei ko lakou eha, e like me ke kuakoko o ka wahine hanau keiki; E haka pono no kekahi i kekahi me ka makau, E like ana ko lakou maka me ka lapalapa ahi.
\q1 
\v 9 Aia hoi! ka la o Iehova, ke hele mai la, He weliweli loa no ka ukiuki, a me ka inaina nui, E hoolilo i ka aina i auakua, A e anai aku i ka poe hewa.
\q1 
\v 10 O na hoku o ka lani a me na huihui ona, Aole lakou e haawi mai i ka malamalama; E poeleele no ka la i kona hele ana, Aole hoi e hoomalamalama mai ka mahina.
\q1 
\v 11 A e hoopai aku au i ka hewa maluna o ka aina, A i ko lakou hala hoi maluna o ka poe lawehala. E hooki no wau i ka manao kiekie o ka poe hookano, A e hoohaahaa hoi au i ka manao haakei o ka poe hookaumaha.
\q1 
\v 12 E hana aku au, a e uuku na kanaka, he nui ke gula, He uuku kanaka, he nui na gula o Opira.
\q1 
\v 13 No ka mea, e hoonaueue au i na lani, A e kulanalana ka honua mai kona wahi aku, No ka inaina o Iehova o na kaua, Ke hiki aku ka la o kona ukiuki wela.
\q1 
\v 14 E like ana hoi ia me ka dia i hahaiia, Me na hipa hoi, aohe mea nana lakou e hoiliili. E huli no kela mea keia mea i kona poe kanaka iho, E holo no kela mea keia mea i kona aina iho.
\q1 
\v 15 E houia na mea a pau i loaa; A o ka poe a pau i huiia'ku, e haule lakou i ka pahikaua.
\q1 
\v 16 A e ulupaia ka la kou keiki imua o ko lakou mau maka; E haoia ko lakou hale, A e moe wale ia ka lakou mau wahine.
\b
\q1 
\v 17 Aia hoi! e hoala no wau i ko Media e ku e ia lakou, I ka poe i manao ole i ke kala; A o ke gula hoi, aole lakou makemake ia mea.
\q1 
\v 18 Na ko lakou kakaka e kulai i na kanaka ui, Aole lakou e aloha i ka hua o ka opu; Aole e menemene ko lakou maka i na keiki uuku.
\b
\q1 
\v 19 O Babulona, ka mea nani o na aupuni, Ka mea e hanohano ai, a e kaena ai hoi o Kaledea, E like auanei ia me Sodoma a me Gomora, Na mea a ke Akua i hookahuli ai.
\q1 
\v 20 E kanaka ole ana ia mai ia wa aku, Aole e noho hou ia, mai ia hanauna, a ia hanauna aku; Aole e kukulu hou ka Arabia i kona halelewa malaila, A malaila hoi, aole e hoomoe hou na kahuhipa i ka lakou hipa.
\q1 
\v 21 Malaila no e moe ai na holoholona o ka waonahele; A e piha no hoi ko lakou hale i na aoa; E noho no malaila ka iana, A e haa wale na kao hihiu malaila.
\q1 
\v 22 E hae no na iliohae ma ko lakou halealii, A me na ilio hihiu ma ko lakou mau halelewa. Ua kokoke mai no kona manawa, Aole hoi e hooloihiia kona mau la.
\c 14
\b
\q1 
\v 1 A LAILA, e aloha mai no o Iehova i ka Iakoba, E olioli hou no ia i ka Iseraela, A e hoomaha ia lakou ma ko lakou aina iho; A e hui pu ia na malihini me lakou, A e hoopili lakou i ko ka hale o Iakoba.
\q1 
\v 2 E lawe na lahuikanaka ia lakou, A e hoihoi ia lakou i ko lakou wahi iho; A e noho no lakou mamuli o ko ka hale o ka Iseraela, I kauwakane, a i kauwawahine, ma ka aina o Iehova; A e lawe pio lakou i ka poe i hoopio ai ia lakou, A e noho alii lakou maluna o ka poe nana lakou i hookaumaha.
\b
\q1 
\v 3 A i ka la e hoomaha mai ai o Iehova ia oe, Mai kou pilikia, a me kou poino, A mai ka hana kaumaha i kauia maluna ou,
\b
\q1 
\v 4 Alaila oe e haku ai i keia mele no ke alii o Babulona, I ka i ana iho, Nani ka pau ana o ka mea nana i hookaumaha, Ka pau ana hoi o ka mea auhau i ke gula!
\q1 
\v 5 Ua uhaki o Iehova i ke kookoo o ka poo hewa, I ke kookoo alii hoi o ka poe hookaumaha.
\q1 
\v 6 O ka mea i hahau i na kanaka me ka huhu, He hahau ana me ka hoomaha ole; Hahi no oia maluna o ko na aina me ka ukiuki, He hoomaau hooki ole.
\q1 
\v 7 A ua malu ka honua a pau, na maha no; Hookani olioli lakou.
\q1 
\v 8 Hoaikola no hoi na laau kaa maluna ou, A me na kedera o Lebanona, i ae la, Mai kou wa i moe ai ilalo, Aohe mea e pii mai e kua ia makou.
\q1 
\v 9 Ua pihoihoi ka po malalo ia oe, E halawai me oe i kou hiki ana aku. Nou no ia i hoea mai ai i na mea lapu, I na mea mana hoi a pau o ka honua: Hooku ae la hoi ia iluna, i na'lii a pau o na aina, mai ko lakou nohoalii mai.
\q1 
\v 10 A olelo mai no lakou a pau ia oe, i ka i ana, Ua lilo anei oe i nawaliwali, e like me makou? Ua hoohalikeia anei oe me makou?
\q1 
\v 11 Ua hoopohoia kou hanohano ilalo i ka po, A me ke kani ana o kou mau lira; O kahi moe malalo ou he ilo ia, A uhi mai no hoi ka ilo ia oe,
\q1 
\v 12 Auwe kou haule ana mai ka lani mai, E ka Hokuloa, ke keiki a ke kakahiaka! Ua kuaia oe ilalo i ka honua, O oe, ka mea i hooauhee i ko na aina.
\q1 
\v 13 Aka, ua olelo no oe iloko o kou naau, E pii aku no wau i ka lani, E hookiekie no wau i ko'u nohoalii, Maluna o na hoku o ke Akua; E noho no wau ma ka mauna o ka halawai ana, Ma na aina loihi aku o ke kukulu akau.
\q1 
\v 14 E pii aku no wau maluna o kahi kiekie o na ao, E like ana au me ka Mea kiekie loa.
\q1 
\v 15 Ua hoohaahaaia ka oe, ilalo o ka po, A i kahi hohonu hoi o ka lun!
\q1 
\v 16 O ka poe ike aku ia oe, e haka pono aku no lakou ia oe, E makaikai aku no ia oe, a e olelo iho, O keia anei ke kanaka nana i hoonaueue ka honua? A hooluliluli hoi na aupuni?
\q1 
\v 17 Nana i hoolilo ka honua nei, i waonahele, A anai hoi i kona poe kulanakauhale? Ka mea i kuu ole i kona mea pio, e hoi hou i ko lakou wahi?
\q1 
\v 18 O na'lii a pau o na aina, maloko o ka nani lakou a pau e moe nei, O kela mea keia mea ma kona wahi iho.
\q1 
\v 19 Ua hooleiia'ku ka oe mawaho o kou lua, Me he oha la i hoopailuaia, Me he aahu la o ka poe i pepehiia, Ka poe hoi i houia i ka pahikaua, Me he kupapau la i hahiia.
\q1 
\v 20 Aole oe e huipuia me lakou ma ke kanu ana, No ka mea, ua hooki loa oe i kou aina iho, Ua luku no oe i kou poe kanaka; Aole e hea hou ia ka hanauna o ka poe hewa a i ke ao pau ole,
\q1 
\v 21 E hoomakaukau oukou i ka make no kana mau keiki, No ka hewa o na makua o lakou; I ole lakou e ku mai, a komo i ka aina, I hoopiha ole hoi lakou i ka aina i na kulanakauhale.
\q1 
\v 22 Na'u no e ala'e iluna e ku e ia lakou, Wahi a Iehova o na kaua; E hooki loa no wau i ka inoa o Babulona, A me ke koena, a me na keiki, a me na mamo, Wahi a Iehova.
\q1 
\v 23 E hooili aku au ia wahi no ke kipoda, A e lilo hoi ia i kiowai; A e kahili aku au ia me ke kahili o ka make, Wahi a Iehova o na kaua.
\b
\q1 
\v 24 Ua hoohiki mai o Iehova o na kaua, i mai la, Me ka'u i manao ai, pela io no ia: O ka'u i noonoo ai, oia ke kupaa.
\q1 
\v 25 E lukuia auanei ko Asuria ma kuu aina, E hahi no wau ia ia maluna o ko'u kuahiwi; E laweia kana auamo mai o lakou aku, E haule hoi kona mea kaumaha mai luna mai o ko lakou poohiwi.
\q1 
\v 26 Oia ka manao i manaoia'i no ka honua a pau; Oia ka lima i oia mai maluna ona lahuikanaka a pau.
\q1 
\v 27 No ka mea, ua paa ka manao o Iehova o na kaua, Owai la hoi ka mea hiki ke hoole? Ua oia mai kona lima, Owai la ka mea e hoihoi aku ia?
\b
\q1 
\v 28 I ka makahiki i make ai o ke alii, o Ahaza, keia wanana.
\b
\q1 
\v 29 Mai olioli oe, e Pelisetia a pau, No ka hakiia o ka laau i hahau ia oe; No ka mea, mai ke aa o ka nahesa e laha mai ai ka moo pepeiaohao, A o kana hua hoi, he moo lele.
\q1 
\v 30 E ai no ka poe hune loa, A e moe no ilalo ka poe ehaeha me ka maluhia; Aka, e hooki loa au i kou aa i ka wi, A e luku aku oia i kou poe i koe.
\q1 
\v 31 E aoa, e ka pukapa, e uwe aku, e ke kulanakauhale, Ua maule oe, e Pilisetia a pau. No ka mea, ke punohu mai nei ka uwahi mai ka akau mai, Aohe mea helelei o kona poe kaua.
\q1 
\v 32 Pehea la e olelo aku ai i na elele o ka aina? Ua hookumu o Iehova ia Ziona, E loaa auanei ka puuhonua no kona poe kanaka poino.
\c 15
\b
\q1 
\v 1 KA wanana no Moaba. A lukuia Ara-Moaba i ka po, ua anaiia; He oiaio, i ka po i lukuia'i o Kira-Moaba, Ua anai loa ia no.
\q1 
\v 2 Pii aku no ia i ka heiau, ma Dibona hoi, Ma na wahi kiekie e uwe ai. E aoa no o Moaba, no Nebo a me Medeba; E ohule no ko lakou poo a pau, E pau no ka umiumi i ke kahiia.
\q1 
\v 3 Ma kona alanui e kaei no lakou ia lakou iho i ke hapa ino: Maluna o kona mau hale, a ma kona wahi akea, E aoa no na mea a pau me ka waimaka e kahe ana.
\q1 
\v 4 E uwe hamama no o Hesebona a me Eleale; E loheia ko lakou leo ma Iahaza; No ka mea, e uwe aku no ka poe kaua o Moaba, E ehaeha no kona naau maloko ona.
\q1 
\v 5 E uwe nui no ko'u naau no Moaba, O kona poe i pee, aia no ma Zoara, ma Egelaselesia: I ka pii ana i Luhita, pii lakou me ka uwe iho; Oiaio, ma ke ala o Horonaima lakou e uwe at ai no ka make.
\q1 
\v 6 No ka mea, e mehameha auanei na wai o Nimerima, Ua maloo hoi ka mauu, ua pau ka launahele, aohe mea uliuli.
\q1 
\v 7 Nolaila, ua laweia'ku ka waiwai i loaa ia ia, A me ka lakou ukana hoi, a i ke kahawai o na wilou.
\q1 
\v 8 Ua poai kona uwe ana i na mokuna o Moaba; Ua hiki kona aoa i Egelaima, a me kona kaniuhu i Beer-Elima.
\q1 
\v 9 No ka mea, ua piha na wai o Dimona i ke koko: A e kau hou no wau maluna o Dimona, I na liona hoi maluna o ka poe i pakele o Moaba, A me ka poe o ka aina i koe.
\c 16
\b
\q1 
\v 1 E HOOKUPU oukou i keiki hipa na ke alii o ka aina, Mai Sela o ka waonahele mai, A i ka mauna o ke kaikamahine a Ziona.
\q1 
\v 2 E like me ka manu lele, i kipakuia mai kona punana aku, Pela auanei na kaikamahine o Moaba, Ma na ahua o Arenona.
\q1 
\v 3 E kuka, e hana i ka mea i pono; E hoohalike i kou aka me ka po iwaena konu o ke ao; E huna i ka poe i kipakuia, Mai kumakaia i ka mea auwana.
\q1 
\v 4 E ae aku i kuu poe i kipakuia, e Moaba, e noho me oe, I puuhonua hoi oe no lakou, mai ke alo o ka mea luku; No ka mea, e pau auanei ka hookaumaha, A e oki loa hoi ka mea luku, A me ka mea hookaumaha, mai ka aina aku.
\q1 
\v 5 Alaila, ma ka pono e hoopaaia'i ka nohoalii, A e noho no kekahi maluna o ia me ka pono, ma ka hale hoi o Davida; He lunakanawai e imi ana i ka pololei, e hooponopono koke ana no hoi.
\b
\q1 
\v 6 Ua lohe no kakou i ka haaheo o Moaba, ka hookiekie loa: A me kona haakei a me kona hookano a me kona huhu; Aole e holo kona wahahee ana.
\q1 
\v 7 Nolaila e uwe ai o ko Moaba, No Moaba e uwe ai na mea a pau; E kaniuhu oukou no Kira Haresa, E kaumaha io no.
\q1 
\v 8 No ka mea, ua mae wale na mahinaai o Hesebona, O ke kumuwaina hoi o Sibema; Ua uhai na haku o na aina i kona mau lala maikai, Hiki no lakou i Iazera, Auwana lakou ma ka waonahele: Palahalaha ae la kona mau lala, A hala i kela aoao o ke kai.
\b
\q1 
\v 9 Nolaila, me au i uwe ai no Iazera, Pela no wau e uwe ai no ke kumuwaina o Sibema; E hoopulu aku au ia oe i kuu waimaka, e Hesebona, a me Eleale; No ka mea, ua haule ka hooho kaua maluna o kou kau ai a me kou ohi ai ana.
\q1 
\v 10 Ua laweia'ku la ka lealea, a me ka hauoli, Mai ka mahinaai hua nui aku; Aole hooho ma na pawaina, aole hoi he hauoli: Aohe mea hahi waina ma na lua kaomi waina, Ua hooki loa aku au i ka hooho olioli ana.
\q1 
\v 11 Nolaila e kani ai ko'u opu no Moaba, Me he mea kani la, A me ko'u naau hoi, no Kira-Haresa.
\b
\q1 
\v 12 E hiki mai auanei, a e ikeia no, Ka luhi ana o ko Moaba maluna o na wahi kiekie, E hele no oia i kona wahi kapu e nonoi ai, Aole nae e loaa.
\b
\q1 
\v 13 Oia ka olelo a Iehova i olelo ai no Moaba i ka wa mamua.
\q1 
\v 14 Ke olelo nei o Iehova i keia wa, me ka i ana mai, Ekolu makahiki i koe, E like me na makahiki o ka mea i hoolimalimaia, E hoowahawahaia ka nani o Moaba, A me kona poe lehulehu loa; E uuku auanei ke koena, aole e nui.
\c 17
\b
\q1 
\v 1 KA wanana no Damaseko. Aia hoi! Ua hookiia o Damaseko, aole ia he kulanakauhale, E lilo no ia i puu opala.
\q1 
\v 2 Ua haaleleia na kulanakauhale o Aroera; E lilo lakou no na ohana hipa, Malaila lakou e moe ai, aoho mea nana lakou e hoomakau.
\q1 
\v 3 E hookiia auanei na wahi i paa i ka pa o Eperaima, A me ke aupuni o Damaseko, a me ke koena o Suria: E like me ka nani o na mamo a Iseraela, pela auanei lakou, Wahi a Iehova o na kaua.
\b
\q1 
\v 4 A hiki aku ia la, e hoopauia ka nani o Iakoba, A e olala no hoi ke kelekele o kona io.
\q1 
\v 5 A e like no hoi ia me ka mea okioki i ka hua palaoa, Na kona lima e okioki i na huhui palaoa; A e like no hoi ia me ka mea hoiliili i na huhui palaoa ma ke awawa o Repaima.
\b
\q1 
\v 6 E waihoia no kekahi koena ai nana, E like me na oliva i luluia, A koe elua, a ekolu paha hua ma na welau o na lala luna; Eha, a elima paha, ma na lala waho hua nui, Wahi a Iehova ke Akua o ka Iseraela.
\q1 
\v 7 Ia la la, e hilinai aku no ke kanaka ma ka mea nana i hana, E kau no kona mau maka maluna o ka mea Hemolele o ka Iseraela.
\q1 
\v 8 Aole ia e hilinai aku ma na kuahu a kona mau lima i hana'i, Aole hoi e manao i na mea i hanaia e kona mau manamana lima, I na kii o Aseterota, a me na'kua kii.
\b
\q1 
\v 9 Ia la la, e like ana na kulanakauhale o kona pakaua, Me ka ululaau i haaleleia, Me na lala maluna i haaleleia no na mamo a Iseraela; E olohelohe ana no ia.
\q1 
\v 10 No ka mea, ua hoopoina oe i ke Akua nana oe i hoopakele, Aole i hoomanao i ka Pohaku o kou ikaika; Nolaila oe e kanu ai i na mea kanu maikai, A e pohuli i na lala waina o ka malihini.
\q1 
\v 11 I ka la o kou kanu ana hoopaa no oe ia i ka pa, A i ke kakahiaka no oe i hooulu i kau hua; Aka, e laweia ka puu ai i ka la o ka loaa ana, Aole e ole ke kaumaha.
\b
\q1 
\v 12 Auwe ke kupikipikio o na lahuikanaka he nui; Ua like ko lakou kupikipikio ana, me ka halulu ana o na kai, Ka halulu o ko na aina: Halulu no lakou e like me ka halulu ana o na wai.
\q1 
\v 13 Halulu ko na aina, e like me ka halulu ana o na wai he nui; Aka, e papa no oia ia lakou, A e pee no lakou i kahi loihi; E hahaiia no lakou, e like me ka opala o na kuahiwi imua o ka makani, E like hoi me ka lepo imua o ka puahiohio.
\q1 
\v 14 I ke ahiahi, aia hoi he weliweli, A mamua o ke kakahiaka, aole lakou. Oia ka hope o ka poe i hao i ka kakou, O ka poe hoi i lawe wale i ka kakou.
\c 18
\b
\q1 
\v 1 A UWE ka aina eheu kani, Ka mea ma kela aoao o na kahawai o Aitiopa:
\q1 
\v 2 Ka mea i hoouna i na elele ma ke kai, Ma na moku kome maluna o na wai. O hele, e na luna mama, I ka lahuikanaka ikaika, a koa hoi, I ka lahuikanaka weliweli, mai ka wa kahiko mai, I ka lahuikanaka mana i ka luku aku, A halanaia ko lakou aina e na muliwai.
\q1 
\v 3 E ka poe a pau e noho la ma ka honua, A me na mea a pau e noho ana ma ke ao nei, A hapaiia ka hae ma na mauna, e nana oukou, A kani ka pu, e hoolohe hoi.
\q1 
\v 4 No ka mea, penei i olelo mai ai o Iehova ia'u, E hoomaha ana au, a me ka nana aku maloko o ko'u wahi e noho ai, E like me ka mehana olu maluna o na mea ulu, Me he ao hau la hoi i ka wa wela o ka hoiliili ai.
\q1 
\v 5 No ka mea, mamua o ka hoiliili ai ana, I ka mohala ana o ka pua, A lilo ka pua i huawaina oo, Alaila, e paipai oia i na lala i na pahi paipai, A e lawe aku no oia i na lala, e paipai aku no.
\q1 
\v 6 E waiho pu ia no lakou no na manu o na mauna, A no na holoholona o ka honua; E kau no na manu maluna olaila, a pau ke kau, E noho no malaila na holoholona a pau o ka aina, a pau ka hoilo.
\b
\q1 
\v 7 Ia manawa, e laweia mai na makana no Iehova o na kaua, He lahuikanaka ikaika, a koa hoi, He poe weliweli hoi, mai ka wa kakiko mai, He lahuikanaka mana i ka luku aku, Ua halanaia ko lakou aina e na muliwai, A i kahi o ka inoa o Iehova o na kaua, I ka mauna hoi o Ziona.
\c 19
\b
\q1 
\v 1 KA wanana no Aigupita. Aia hoi, ke holo la o Iehova maluna o ke ao mama, A hele mai koi ia i Aigupita. E haalulu auanei na akua kii o Aigupita imua o kona alo, E maule hoi ka naau o ko Aigupita iloko o lakou.
\q1 
\v 2 E kahiko aku no wau i ko Aigupita, e kaua i ko Aigupita; E kaua no lakou, o kela mea keia mea i kona hoahanau iho, O kela mea keia mea i kona makamaka iho, O kekahi kulanakauhale i kekahi kulanakauhale, O kekahi aupuni i kekahi aupuni.
\q1 
\v 3 E pau auanei ke aho o ko Aigupita iloko o lakou; E kookahuli au i ko lakou manao; Alaila, e huli lakou i ko lakou akuakii, I na mea namunamu, a me na mea ninau kupapau, a me na kupua.
\q1 
\v 4 E haawi aku no wau i ko Aigupita, i ka lima o ka haku oolea; A noho no kekahi alii oolea maluna o lakou, Wahi a ka Haku, o Iehova o na kaua.
\b
\q1 
\v 5 E pau auanei ka wai o ka muliwai, E pio no hoi a maloo ke kahawai.
\q1 
\v 6 E pilau auanei na muliwai, E pio, a maloo na auwai o Aigupita, A e mae wale no hoi ka naku a me ke kaluha.
\q1 
\v 7 O na papu ma kapa muliwai, a me ka waha o ka muliwai, A me na mea hua a pau ma ka muliwai, e maloo no ia mau mea, E puehu liilii ia no, a e nalowale.
\q1 
\v 8 E kauiuhu no na lawaia, a me ka uwe iho, O ka poe a pau i kuu i ka makau ma ka muliwai, Ka poe i hohola i na upena maluna o na wai, E u auanei lakou.
\q1 
\v 9 O ka poe i hana i ke olona i kahiia, A me ka poe ulana i ka lole keokeo, E hilahila auanei lakou.
\q1 
\v 10 E hehiia no na mea koikoi, A e kaumaha no hoi ka naau o ka poe paaua a pau.
\b
\q1 
\v 11 He oiaio, ua naaupo na'lii o Zoana; O ka oleloao o na kakaolelo akamai o Parao, He olelo lapuwale ia. Pehea la oukou e olelo ai ia Parao, He keiki au na ka poe akamai, He keiki na na'lii kahiko?
\q1 
\v 12 Auhea lakou? Auhea kou poe akamai? Na lakou e hai mai ia oe, A e ike lakou i ka mea a Iehova o na kaua, E manao ai no Aigupita.
\q1 
\v 13 Ua naaupo no na'lii o Zoana, Ua puni na'lii o Nopa; Ua alakai hewa lakou i ko Aigupita, o na luna hoi o na ohana ona.
\q1 
\v 14 Ua ninini mai o Iehova iwaena o lakou, i ka manao pihoihoi; A alakai hewa lakou i ko Aigupita ma kana mau hana a pau, Ua like me ka mea i ona, e hikaka ana maloko o kona luai.
\q1 
\v 15 Aole e hanaia ka hana ma Aigupita, Ka mea a ke poo e hiki ai ke hana, a me ka huelo; Ka lala pama, a me ka naku.
\b
\q1 
\v 16 Ia la la, e like auanei ko Aigupita me na wahine, E makau no lakou a haalulu, No ke ka ana o ka lima o Iehova o na kaua, Ka mea ana e hooka mai ai maluna o lakou.
\q1 
\v 17 E lilo no ka aina o ka Iuda, i mea e makau ai ko Aigupita, O na mea a pau o lakou i hoomanao ia wahi, e makau loa auanei, No ka manao ana o Iehova o na kaua, Ka mea ana i manao ai no lakou.
\b
\q1 
\v 18 Ia la la, elima no kulanakauhale ma ka aina o Aigupita, E olelo ana i ka olelo o Kanaana; A ma ka inoa o Iehova o na kaua lakou e hoohiki ai; A e kapaia kekahi o lakou, ke kulanakauhale o Heresa.
\b
\q1 
\v 19 Ia la la e hanaia ke kuahu no Iehova, Iwaenakonu o ka aina o Aigupita, He puu no Iehova ma kolaila mau palena:
\q1 
\v 20 He hoailona no ia, a he mea hoike hoi, No Iehova o na kaua, ma ka aina o Aigupita; No ko lakou hea ana ia Iehova i ko lakou hookaumahaia, A e hoouna mai oia no lakou i mea hoola, I mea mana hoi, nana lakou e hoopakele.
\q1 
\v 21 Alaila, e ikeia o Iehova e ko Aigupita, A e hoomaopopo no ko Aigupita ia Iehova i kela la, A e malama lakou ia ia i ka mohai, a me ka alana; A e hoohiki lakou i ka hoohiki ana no Iehova, A e hooko io aku lakou.
\q1 
\v 22 E hahau aku no o Iehova i ko Aigupita, E hahau aku no, a e hoola aku: A e huli no lakou ia Iehova, A e noiia oia e lakou, a e hoola mai oia ia lakou.
\b
\q1 
\v 23 Ia la la, e loaa no ke alanui, mai Aigupita aku a Asuria, A e hele no ko Asuria i Aigupita, A me ko Aigupita hoi i Asuria; A e malama pu no ko Aigupita me ko Asuria.
\b
\q1 
\v 24 Ia la la, o ka Iseraela ke kolu, o Aigupita pu, a me Asuria, O ka pomaikai hoi iwaena o ka honua:
\q1 
\v 25 Ka mea a Iehova o na kaua i hoopomaikai ai, I ka i ana mai, Pomaikai ko'u poe kanaka, o ko Aigupita, A me ko Asuria hoi ka hana a ko'u mau lima, A me ka Iseraela ko'u hooilina.
\c 20
\b
\q1 
\v 1 I KA makahiki i hele mai ai o Taretana i Asedoda, kahi ana i hoounaia mai ai e Saregona, ke alii o Asuria, a kaua mai oia ia Asedoda, a hoopio hoi ia;
\q1 
\v 2 Ia manawa, olelo mai la o Iehova ma o Isaia la, o ke keiki a Amosa, i mai la, O hele, e wehe i ke kapa ino mai kou puhaka aku, A e wehe hoi i kou kamaa mai kou kapuwai aku. Hana no oia pela, a hele iho la, he kapa ole, a he kamaa ole.
\q1 
\v 3 I mai la o Iehova, Me Isaia ka'u kauwa i hele ai, he kapa ole, a he kamaa ole, I hoailona, a i ouli hoi no na makahiki ekolu, Maluna o Aigupita, a maluna o Aitiopa;
\q1 
\v 4 Pela no ke alii o Asuria e alakai ai I ka poe paa o Aigupita, a me ka poe pio o Aitiopa, I ka poe opiopio, a me ka poe elemakule, Me ke kapa ole, a me ke kamaa ole, E waiho wale ana na hope o lakou, I mea e hilahila ai ko Aigupita.
\q1 
\v 5 A e makau hoi lakou nei, a e hilahila hoi ia Aitiopa, I ka mea a lakou i hilinai ai: A ia Aigupita hoi, I ka mea a lakou i kaeua ai.
\q1 
\v 6 A o ka mea e noho ana ma ia aina, e olelo no ia, ia la, Aia hoi, pela ka mea a makou i hilinai ai, Ka poe a makou i kii aku, i mea e kokua mai, I hoopakeleia mai makou i ke alii o Asuria: Pehea hoi makou e pakele ai?
\c 21
\b
\q1 
\v 1 KA wanana no ka waonahele o ka moana. Like me ka holo ana o ka puahiohio ma ke kukulu hema, Pela no kona hele ana, mai ka waonahele mai, Mai ka aina weliweli mai hoi.
\q1 
\v 2 He wanana weliweli ka i hoikeia mai ia'u; O ka mea e luku aku, e luku aku no ia, O ka mea i anai aku, e anai aku no ia. O pii, e Elama; e hoopuni aku, e Media: Ua hoopau wau i kona uwe ana a pau.
\q1 
\v 3 Nolaila i piha ai ko'u puhaka i ka eha, Ua loohia au i ke nahu kuakoko, E like me ke kuakoko o ka wahine hanau keiki; Kupaka au i kuu lohe ana, Makau no hoi au i kuu ike ana.
\q1 
\v 4 Ua kulanalana ko'u naau, Pihoihoi au i ka makau; Ua hoolilo oia i ka po o kuu olioli, I mea weliweli no'u.
\q1 
\v 5 E hoomakaukau i ka papaaina, E kiai ka poe kiai, e ai, a inu hoi; E ala oukou, e na'lii, e kahinu i ka palekaua.
\q1 
\v 6 No ka mea, penei i olelo mai ai ka Haku ia'u, O hele, e hoonoho i ke kiai ma ka hale kiai, E hai mai oia i kona mea e ike ai.
\q1 
\v 7 A ike iho la oia, he mau hololio kaua palua, He holo hoki, a he holo kamelo; Hooikaika loa iho la oia e hoolohe aku:
\q1 
\v 8 A hea mai la hoi ia, me he liona la, E kuu haku, ua ku mau no wau ma ka halekiai i ke ao, Ua hoonohoia no hoi au ma kuu wahi kiai, i na po a pau:
\q1 
\v 9 Aia hoi, hele mai kekahi mau hololio kaua, o na hololio papalua. Olelo mai la, i mai, Ua haule o Bahulona, ua haule; Ua hoohiolo oia i kona poe akua kii ilalo i ka honua.
\q1 
\v 10 Auwe kuu mea i hahiia, ke keiki hoi o ko'u kahua hahi! O ka mea a'u i lohe ai, no Iehova o na kaua mai, Ke Akua o ka Iseraela, Oia ka'u e hai aku nei ia oukou.
\b
\q1 
\v 11 Ka wanana no Duma. Hea mai no oia ia'u mai Seira mai, E ke kiai, heaha ko ka po? E ke kiai, heaha ko ka po?
\q1 
\v 12 Hai mai ke kiai, Ke hiki mai la ke kakahiaka, a me ka po hoi! Ina makemake oukou e ninau, e ninau no; E hoi hou mai.
\b
\q1 
\v 13 Ka wanana no Arabia. Ma ka ululaau o Arabia oukou e moe ai, E na huakaihele o Dedana!
\q1 
\v 14 E ka poe noho ma ka aina o Tema, e lawe mai i ka wai, E halawai me ka poe makewai, Me ka berena e kakali ai i ka mea auwana.
\q1 
\v 15 Mai ka maka aku o ka pahikaua lakou e hee ai, Mai ke alo aku o na pahikaua i unuhiia, Mai ke alo aku o ke kakaka i lena, A mai ke alo aku o ke kaua ikaika.
\q1 
\v 16 No ka mea, penei i olelo mai ai ka Haku ia'u, Hookahi makahiki e koe, e like me ka makahiki o ka paaua, E pau no ka nani a pau o Kedara.
\q1 
\v 17 O ke koena o ka poe i heluia o ka poe akamai i ka pana, O na koa hoi o Kedara, e emi no lakou: No ka mea, ua olelo mai no o Iehova, ke Akua o ka Iseraela.
\c 22
\b
\q1 
\v 1 KA wanana no ke awawa o ka ikeana, Heaha kau i keia wa, I pii ai oukou a pau iluna o na kaupaku hale?
\q1 
\v 2 O oe ka mea i walaau no ka lako, Ke kulanakauhale wawa nui, Ke kulanakauhale olioli; O kou poe i lukuia, aole lakou i lakuia i ka pahikaua, Aole lakou i make i ka hoouka ana.
\q1 
\v 3 Ua auhee pu aku no kou poe luna a pau, Ua pio lakou i ka poe pana; O ka poe a pau i loaa maloko ou, ua pio lakou, Ua hee no hoi, mai kahi loihi mai.
\q1 
\v 4 Nolaila au i olelo ai, E huli ae oukou mai o'u aku nei, e uwe nui loa ana au: Mai hooikaika e hoomaha mai ia'u, No ka lukuia o ke kaikamahine o ko'u poe kanaka.
\q1 
\v 5 No ka mea, he la haunaele keia, A me ka hahi ana, a me ka pilikia, Na ka Haku, na Iehova o na kaua ma ke awawa o ka ikeana, Ua wawahiia ka pa, olo ae la ka pihe a kuahiwi.
\q1 
\v 6 Ke amo nei o Elama i ke aapua, Me na kanaka iloko o ke kaakaua a me na hololio, A unuhi o Kira i ka palekaua.
\q1 
\v 7 E piha auanei i na kaakaua kou mau awawa i makemakeia, A e hoomakaukau na hololio e hoouka ma ka pukapa.
\b
\q1 
\v 8 Wehe ae la oia i ka mea i uhi ai i ka Iuda, A ia la nana aku la oe ma ka hale kahikokaua o ka ululaau,
\q1 
\v 9 A ike no hoi oukou i na wahi naha o ke kulanakauhale o Davida, ua nui; A hoohui oukou i na wai o ka waipuna lalo,
\q1 
\v 10 Ua helu oukou i na hale o Ierusalema, Ua wawahi oukou i na hale i mea e hoopaa ai i ka papohaku.
\q1 
\v 11 A hana no oukou i lokowai mawaena o na pa elua, No ka wai o ka waipuna kahiko; Aole oukou i nana aku ma ka Mea nana ia i hana. Aole oukou i manao aku i ka Mea nana ia i hooponopono i ka wa kahiko.
\b
\q1 
\v 12 Ia la, hea mai no ka Haku, o Iehova o na kaua, E uwe, a e kumakena, I ka ohule ana, a me ke kaei kapa inoino.
\q1 
\v 13 Aia hoi, he olioli, a me ka hauoli, E kalua ana i na bipi, e pepehi ana hoi i na hipa, E ai ana i ka io, e inu ana hoi i ka waina: E ai kakou, e inu hoi, no ka mea, apopo e make ana kakou.
\q1 
\v 14 Na Iehova o na kaua i hoike mai maloko o ko'u mau pepeiao, Aole e kalaia keia hewa o oukou, a make oukou, Wahi a ka Haku, o Iehova o na kaua,
\b
\q1 
\v 15 Olelo mai ka Haku, o Iehova o na kaua, penei, O hele, a hiki aku oe i keia puuku ia Sebena i ka mea maluna o ka hale, a e olelo aku,
\q1 
\v 16 Heaha kau ia nei, a owai hoi kou poe maanei, I kalai ai oe i hale kupapau nou maanei? Ua kalai no oia i hale kupapau nona ma kahi kiekie, Ua pao hoi oia i hale nona maloko o ka pohaku.
\q1 
\v 17 Aia hoi e kipaku no o Iehova ia oe, He kipaku ino loa ana, E oiaio no e uhi mai oia ia oe.
\q1 
\v 18 E olokaa no oia ia oe me he mea poepoe la, E kaa aku ana i ka aina palahalaha ma na aoao; Malaila oe e make ai, A malaila e lilo ai kou mau kaakaua nani, i mea e hilahila ai ka hale o kou haku.
\q1 
\v 19 E kipaku aku wau ia oe mai kou wahi aku, Mai kou wahi aku oia e kaili aku ai ia oe.
\b
\q1 
\v 20 A hiki aku ia la, E hea aku wau i ka'u kauwa, ia Eliakima i ke keiki a Hilekia;
\q1 
\v 21 A e hoaahu aku wau ia ia i kou aahu, A e kaei aku wau ia ia me kou kaei, A e haawi aku wau i kou alii ana iloko o kona lima, A e lilo ia i makua no ka poe e noho la ma Ierusalema, A no ko ka hale o ka Iuda.
\q1 
\v 22 E kau no wau i ke ki o ka hale o Davida ma kona poohiwi, A nana no e wehe, aohe mea nana e pani, A nana no e pani, aohe mea nana e wehe.
\q1 
\v 23 A e hoopaa aku au ia ia me he makia la ma kahi paa, A e lilo ia i nohoalii nani loa no ko ka hale o kona makua.
\q1 
\v 24 A e kau no lakou maluna ona i ka nani a pau o ka hale o kona makua; O na mamo, a me na pua, o na kiaha uuku a pau, Mai na kiaha bola maikai a pau, a i na kiaha lepo a pau.
\q1 
\v 25 A hiki aku ia la, wahi a Iehova o na kaua, E unuhiia ka makia i hoopaaia ma kahi paa, E kuaia ia ilalo a e hina hoi; A e hoopauia auanei ka mea i kauia maluna ona, No ka mea, ua olelo mai o Iehova.
\c 23
\b
\q1 
\v 1 KA wanana no Turo. E aoa oukou, e na moku o Taresisa, No ka mea, ua anaiia oia, aohe hale, aole wahi e komo ai; Ua haiia mai ia lakou, mai ka aina o Kitima mai.
\q1 
\v 2 E noho malie, e ka poe noho ma kahakai; Holo ae la ka mea kalepa o Zidona, mai kela aoao ae o ke kai, a hoopiha no ia ia oe.
\q1 
\v 3 O ka hua o ka Nile, i ulu ma na wai nui, A me ka ai o ka muliwai, oia kona waiwai; A lilo ia i wahi kuai no na aina.
\q1 
\v 4 E hilahila oe, e Zidona, No ka mea, ua olelo mai ko kai, o kahi paa hoi o ke kai, I mai, Aole au i kuakoko, aole au i hanau keiki, Aole au i hanai i kanaka ui, Aole hoi au i malama i na wahine puupaa.
\q1 
\v 5 A hiki aku ka lohe i Aigupita, E nahu hookina lakou, no ka lohe ana ia Turo.
\q1 
\v 6 E hele ae oukou i Taresisa, E aoa oukou, e ka poe noho ma kahakai.
\q1 
\v 7 O keia anei ko oukou wahi i hauoli ai, Ka mea i hookumuia i ka wa kahiko loa? Na kona wawae e lawe aku ia ia i kahi loihi e noho ai.
\b
\q1 
\v 8 Owai ka mea i manao mua i keia ia Turo, I ka mea i hoalii aku ia hai? He poe alii no kona poe kalepa, A o kona poe kuai, he poe koikoi no o ka aina.
\q1 
\v 9 Ua manao mai o Iehova o na kaua ia mea, I hoohaumia oia i ka hanohano o na mea nani a pau, A e hoohaahaa hoi i na mea koikoi a pau o ka honua.
\q1 
\v 10 E hele oe maluna o kou aina e like me ka wai kahe, E ke kaikamahine o Taresisa, aole kaei i koe.
\q1 
\v 11 O aku no oia i kona lima maluna o ke kai, Hoonaueue no oia i na aupuni: Ua kauoha mai o Iehova no Poinike, E hooki loa aku i kona mau pakaua.
\q1 
\v 12 A ua olelo mai ia, Aole oe e hooho lanakila hou, E ka wahine puupaa i pue wale ia, ke kaikamahine a Zidona; E ku iluna, e hele i kela aoao, i Kitima; Aole nae e loaa ia oe ka maha malaila.
\q1 
\v 13 Aia hoi ko ka aina o Kaledea; He mea ole keia poe kanaka, A hookumu ko Asuria ia wahi no ka poe i noho ma ka waonahele; Na lakou i kukulu i kolaila mau halekiai, A hana no hoi i kolaila mau halealii; A nana i hoohiolo i na kauhale.
\q1 
\v 14 E aoa oukou, e na moku o Taresisa, No ka mea, ua hoohioloia kou pakaua,
\q1 
\v 15 A hiki aku i kela la, E hoopoinaia no o Turo i na makahiki he kanahiku, E like me na makahiki o ke alii hookahi: A pau na makahiki he kanahiku, Alaila, e olioli no o Turo me ka ka wahine hookamakama.
\q1 
\v 16 E lawe oe i ka lira, e poai i ke kulanakauhale, E ka wahine hookamakama i hoopoinaia: E hookanikani maikai, e hoonui i ka olioli, I hoomanao hou ia'i oe.
\b
\q1 
\v 17 A hiki i ka pau ana o na makahiki he kanahiku, Alaila e nana mai no o Iehova ia Turo, A e hoi hou no ia i kana hana e waiwai ai, A e moe kolohe no oia me ko na aupuni a pau o keia ao, Maluna o ka honua nei.
\q1 
\v 18 Aka, o kona waiwai loaa, a me kona uku, E laa no ia no Iehova, Aole ia e hoahuia, aole e malamaia ma kahi e; No ka mea, o kona waiwai kuai, no ka poe ia e noho ana imua o Iehova, I mea e ai ai a maona, a i mea aahu nani.
\c 24
\b
\q1 
\v 1 A IA hoi, e hooneoneo ana o Iehova i ka aina, E anai ana oia ia ia; E hookahuli no oia ia ia, a e hoopuehu i kona poe e noho ana.
\q1 
\v 2 E hiki mai auanei keia, E like me kanaka, pela no ke kahuna; E like me ka kauwa kane, pela no kona haku kane; E like me ke kauwa wahine, pela no kona haku wahine; E like me ka mea kuai mai, pela no ka mea kuai aku; E like me ka mea noi, pela no ka mea haawi; E like me ka mea loaa ka ukuhoopanee, Pela no ka mea haawi i ka ukuhoopanee.
\q1 
\v 3 E hooneoneo loa ia ka aina, e anai loa ia'ku no, No ka mea, na Iehova i olelo mai ia olelo.
\q1 
\v 4 Ke kanikau nei ka aina, ua mae wale, Ua nawaliwali ka honua, ua mimino loa; Ua nawaliwali ka poe haaheo o ka aina.
\q1 
\v 5 Ua hoohaumiaia ka aina malalo o ka poe i noho; No ka mea, ua ae lakou maluna o na kanawai, Ua hoololi i na olelopaa, Ua uhai lakou i ka berita mau loa.
\q1 
\v 6 Nolaila i pau ai ka aina i ka hooinoia, A ua hoopaiia ka poe e noho ana maluna ona; Nolaila e pau ai na kanaka o ka aina me he ahi la, Uuku hoi na kanaka e koe iho.
\b
\q1 
\v 7 Ke waiho wale la no ka waina hou, Ua mae wale na kumu waina, O ka poe a pau i olioli ka naau, ua kaniuhu.
\q1 
\v 8 Ua oki ke kanikani olioli o na pahukani, Ua pau hoi ka olioli o ka poe olioli ana, Ua oki pu no hoi ke kanikani olioli o ka lira.
\q1 
\v 9 Aole lakou e inu hou i ka waina me ke oli; A e lilo ka wai ona i mea awaawa i ka poe nana e inu.
\q1 
\v 10 Ua wawahiia ke kulanakauhale neoneo; Ua paniia na hale a pau, aohe mea komo iloko.
\q1 
\v 11 He hooho no ka waina ma na alanui, Ua nalowale ka lealea a pau, Ua oki hoi ka olioli ana o ka aina.
\q1 
\v 12 E waiho ana no ke kulanakauhale me ka neoneo, Ua kani no ka wawahi ana o ka pukapa.
\b
\q1 
\v 13 Pela no auanei mawaenakonu o ka aina, Mawaena hoi o na kanaka, E like me ka laau oliva i luluia, E like hoi me ka hooiliili hope ana, I ka wa i pau ai ka hua waina i ka ohiia.
\q1 
\v 14 Aka, e hookiekie no keia poe i ko lakou leo iluna, A e olioli aku, E hauoli lakou i ka nani o Iehova mai ke kai mai.
\q1 
\v 15 Nolaila, e hoomana oukou ia Iehova, ma ka hikina, I ka inoa hoi o Iehova, ke Akua o ka Iseraela, ma na moku puni o ke kai.
\b
\q1 
\v 16 Ua lohe kakou i ke oli ana, mai ke kihi o ka honua mai, He nani ka poe i pono! I aku la no hoi au, Kuu make e, kuu make e! Auwe hoi au! Ke luku nei ka poe luku, O ka poe luku, ke luku nei, he luku ino.
\q1 
\v 17 E ka mea e noho la ma ka aina, Aia maluna ou ka makau, a me ka lua, a me ka upiki.
\q1 
\v 18 O ka mea e holo, mai ka uwalaau o ka makau aku. E haule no ia ilalo i ka lua; A o ka mea e pii mai, mai loko mai o ka lua, E paa no ia iloko o ka upiki; No ka mea, ua hamama na puka wai o kulanihakoi, A ua naueue hoi na kumu o ka honua.
\q1 
\v 19 Ua hoonaueue ino ia ka aina, Ua hoohelelei loa ia ka aina, Ua haalulu loa hoi ka aina.
\q1 
\v 20 Ua hikaka loa no ka aina, e like me ka mea i ona, Ua luliluli e like me ka moe lewa; Ua kaumaha no hoi kona hewa maluna ona, A hina no hoi ia, aole ala hou mai.
\q1 
\v 21 A hiki aku ia la, E hoopai no o Iehova ma kahi kiekie i ka hewa o ka poe kiekie, A maluna o ka honua i ka hewa o na'lii o ka honua.
\q1 
\v 22 A e hoakoakoa pu ia lakou e like me ka poe paahao, no ka halepaahao; A e hoopaa loa ia lakou maloko o ka halepaahao; A mahope o na la he nui, e hoopaiia no lakou.
\q1 
\v 23 E hilahila no ka mahina, a e hilahila pu no me ka la; No ka mea, na Iehova o na kaua e noho alii, Maluna o ka mauna o Ziona, a ma Ierusalema, A ma ke alo o kona poe kahiko oia e hooleaia'i.
\c 25
\b
\q1 
\v 1 E IEHOVA, o oe no ko'u Akua, E hapai aku no wau ia oe, E hoolea aku no wau i kou inoa; No ka mea, ua hana oe i na mea kupanaha; Mai ka wa kahiko mai kou manao, He paa a he oiaio.
\q1 
\v 2 No ka mea, ua hana mai oe i ke kulanakauhale, he puu, I ke kulanakauhale i paa i ka pakaua, he puu opala; I ka halealii o na malihini, i ole ia he kulanakauhale; Aole hoi ia e hana hou ia, a i ka manawa pau ole.
\q1 
\v 3 Nolaila, e hoomana'i ka lahuikanaka ikaika ia oe, A e makau no hoi ia oe ke kulanakauhale o na lahuikanaka weliweli.
\q1 
\v 4 No ka mea, ua noho oe i puuhonua no ka poe hune, I puuhonua hoi no ka mea poino maloko o kona pilikia, He puuhonua no ka ino, he malu hoi no ka wela, I ka wa e ikaika ai ka makani o ka poe hooweliweli e like me ka ino ma ka paia.
\q1 
\v 5 E like me ka piao ana o ka aina maloo, Pela no oe e hoohaahaa'i i ka walaau o na kanaka e, E like me ka wela i pau i ke ao eleele, Pela no e hoopauia'i ke oli ana o ka poe ikaika.
\b
\q1 
\v 6 Na Iehova o na kaua e hana maluna o keia mauna, I ahaaina mea ono, no na kanaka a pau, he aha inu waina kahiko, He mau mea maikai ono loa, he waina kahiko i hanaia a maikai.
\q1 
\v 7 Maluna o keia mauna e lawe lilo ai oia i ka pale, I ka mea i uhi ai i ka maka o na lahuikanaka a pau, A me ka pale i uhi ai maluna o ko na aina a pau.
\q1 
\v 8 E hoopau no hoi oia i ka make no ka manawa pau ole; A na ka Haku o Iehova, e holoi i ka waimaka, Mai na maka a pau aku; E lawe aku no hoi ia i ka hilahila o kona poe kanaka, Mai ka honua a pau aku; No ka mea, o Iehova ka i olelo mai.
\b
\q1 
\v 9 Ia la la, e olelo no lakou, Aia hoi, o ko makou Akua keia; Ua kakali makou ia ia, a ua hoola mai oia ia makou; O Iehova no keia, ua kakali makou ia ia, E olioli no makou, a e hauoli hoi ma kona ola.
\q1 
\v 10 No ka mea, ma keia mauna e hoomaha ai ka lima o Iehova, A e hahiia o Moaba malalo iho ona, E like me ka hahiia o ka mauu maloo ma ka puu opala.
\q1 
\v 11 E hohola aku no oia i kona mau lima mawaena konu o ia wahi, E like me ka mea auau, i halo aku i na lima e au: E hoohaahaa no ia i kona hookiekie, A me ka maalea o kona mau lima.
\q1 
\v 12 E hoohiolo no oia i ka pakaua o kou pa kiekie, E hana no oia a haahaa, E hoohaahaa no ma ka honua, ilalo hoi ma ka lepo.
\c 26
\b
\q1 
\v 1 A HIKI aku ia la, e oliia no keia oli ana, Ma ka aina o ka Iuda; He kulanakauhale paa ko makou; O ke ola no kana e hoonoho ai, i pa, i pakaua no hoi.
\q1 
\v 2 E wehe i na pukapa, i komo iloko ka lahuikanaka pono, Ka poe hoi i malama i ka oiaio.
\q1 
\v 3 Ka mea i kupaa ka manao, E malama ana oe ia ia me ka malu loa, No ka mea, ua hilinai aku oia ia oe.
\q1 
\v 4 E hilinai aku oukou ia Iehova a i ka manawa pau ole; No ka mea, ma ka Haku, ma o IEHOVA la ka hoomalu, a i ka manawa pau ole.
\b
\q1 
\v 5 No ka mea, ua hoohaahaa oia i ka poe i noho ma kahi kiekie; Ua hoohaahaa oia i ke kulanakauhale kiekie, Ua hoohaahaa oia ia ia ma ka honua, Ua hoopili oia ia wahi ilalo i ka lepo.
\q1 
\v 6 E hahi ana no ka wawae maluna ona, O na wawae o ka poe i hune, a me na kapuwai o ka poe i nele.
\b
\q1 
\v 7 O ka aoao o ka poe i pono, ua pololei ia. O oe ka mea pololei e hoopololei i ke ala o ka poe pono.
\q1 
\v 8 Ma ke ala o kou mau kanawai, e Iehova, Ua hilinai aku makou ia oe, O ka makemake o ko makou naau, i kou inoa ia a me ka hoomanao aku ia oe.
\q1 
\v 9 Me ko'u naau au i makemake aku ai ia oe i ka po; He oiaio, ua imi aku au ia oe i kakahiaka me ko'u uhane iloko o'u; No ka mea, i ka wa e hooponopono ai oe ma ka honua, E ao no na kanaka o keia ao i ka pono.
\q1 
\v 10 E lokomaikaiia ka poe hewa, Aole nae ia e ao i ka pono; Ma ka aina o ka pololei, e hana kekee no ia, Aole hoi e manao aku i ka nani o Iehova.
\b
\q1 
\v 11 Ua hapaiia kou lima, e Iehova, Aole nae lakou i nana; E ike no nae lakou me ka hilahila, I kou aloha nui i na kanaka ou, E oiaio no, e ai no ke ahi i kou poe enemi.
\b
\q1 
\v 12 E Iehova, e haawi mai ana no oe i ka malu no makou; No ka mea, ua hana no oe i ka makou hana a pau no makou.
\q1 
\v 13 E Iehova, ko makou Akua, Ua noho mai na haku e, i alii maluna o makou, aole oe; Aka, ia oe wale no a me kou inoa makou e hookaulana aku ai.
\q1 
\v 14 Ua make ia poe, aole lakou e ola; Ua nawaliwali lakou, aole lakou e ku hou mai: Nolaila oe i hoopai mai, a luku mai ia lakou, A ua hooki loa oe i ka manao ana ia lakou.
\q1 
\v 15 Ua hoomahuahua oe i ka lahuikanaka, e Iehova, Ua hoomahuahua oe i ka lahuikanaka, ua hoonaniia oe; Ua hoopalahalaha ae oe i na mokuna a pau o ka aina.
\q1 
\v 16 E Iehova, maloko o ke kaumaha, ua imi aku lakou ia oe, I ka wa i hookaumaha ai oe ia lakou, nonoi ikaika loa aku lakou.
\q1 
\v 17 E like me ka wahine hapai, a kokoke mai kona manawa e hanau ai, Ua nui kona eha, a uwe iho oia no ke kuakoko ana; Pela no makou imua ou, e Iehova.
\q1 
\v 18 Ua hapai no makou, ua nahu kuakoko, Ua hanau hoi makou, he mea me he makani la; Aole i hanaia ka mea e ola'i ma ka aina, Aole hoi i haule na kanaka o keia ao.
\q1 
\v 19 E ola auanei kou poe i make, O ko'u poe i make, e ala mai no lakou: E ala mai, e oli oukou, e ka poe e noho ana ma ka lepo, No ka mea, o kou hau, o ka hau ia maluna o na mea ulu, E hoolei aku no ka aina i ka poe i make.
\b
\q1 
\v 20 E hele mai, e ko'u poe kanaka, E komo oukou iloko o ko oukou keena malu, E pani hoi i ko oukou puka mahope o oukou; E huna ia oe iho no ka manawa uuku, A hala aku ka inaina.
\q1 
\v 21 No ka mea, aia hoi, o Iehova, ke puka mai la, mai kona wahi mai, E hoopai i ka hewa o na kanaka maluna o ka honua; A e hoike aku no ka honua i ke koko iloko ona, Aole e uhi hou i kona poe i pepehiia,
\c 27
\b
\q1 
\v 1 I KELA la, me kona pahikaua kaumaha, a nui, a ikaika, E hoopai mai ai o Iehova i leviatana, i ka nahesa lele hoi, I leviatana, i nahesa kekee hoi, A e pepehi no oia i ka moo nui maloko o ke kai.
\b
\q1 
\v 2 I kela la, e hookani oukou no ka pawaina.
\q1 
\v 3 Owau, o Iehova, ke malama aku nei au ia, E hoomau aku au ia ia i ka wai i na manawa a pau. O hoeha mai kekahi ia ia i ka po, a i ke ao paha, E kiai aku no wau ia ia.
\q1 
\v 4 Aohe huhu iloko o'u, Owai ka mea nana e hoonoho i ke kakalaioa, a me ka puakala, E ku e mai ia'u ma ke kaua ana? E hele ku e no wau ia lakou, E puhi no wau ia lakou pu.
\q1 
\v 5 Ina e pili mai oia i ko'u ikaika, A hana mai ia'u ma ka mea e malu ai, E malu io no oia ia'u.
\q1 
\v 6 E hookumu no oia i ka poe i laha mai, mai o Iakoba mai, E hoomaka no ka Iseraela, a e mohala hoi, A e hoopiha no ia i keia ao i ka hua.
\b
\q1 
\v 7 Ua hahau mai anei oia ia ia, E like me kona hahau ana mai i ka poe i hahau aku ia ia? Ua pepehiia anei oia, e like me ka pepehiia o ka poe i pepehi aku ia ia?
\q1 
\v 8 I kou kipaku ana, e hahau liilii ana no oe ia ia; Ke hoopuehu nae no oia ia ia me ka makani ikaika, i ka la o ka makani mai ka hikina mai.
\q1 
\v 9 Penei hoi e kalaia'i ka hewa o Iakoba, A he hua no keia a pau e kala'i i ka hala; I kona hoolilo ana i na pohaku a pau o ke kuahu, E like me na pohaku puna i ulupaia, I ala ole mai hoi na kii o Aseterota, a me na'kua kii.
\q1 
\v 10 Aka, e neoneo auanei ke kulanakauhale i paa i ka pakaua, A lilo hoi i hale haaleleia, a waihoia no hoi e like me ka waonahele. Malaila no e ai ai ka bipi, Malaila no hoi ia e moe ai, A e ai no ia i kolaila muo hou.
\q1 
\v 11 A maloo kona mau lala, alaila, e uhaiia no lakou; E hele mai no na wahine, a e puhi ia mau mea i ke ahi. No ka mea, he lahuikanaka noonoo ole ia; Nolaila, o ka mea nana ia i hana, aole ia e aloha mai ia ia, A o ka mea nana ia i kukulu, aole ia e hana lokomaikai mai ia ia.
\b
\q1 
\v 12 A hiki aku ia la, E uhai o Iehova, mai ka wai o kahawai mai, A hiki aku i ka muliwai o Aigupita, A e hoiliili pakahi ia oukou, E na mamo a Iseraela.
\q1 
\v 13 A hiki aku ia la, E puhiia ka pu nui, A e hele mai ka poe aneane make ma ka aina o Asuria, A o ka poe i puenuia ma ka aina o Aigupita, A e hoomana lakou ia Iehova, Ma ka mauna hoano ma Ierusalema.
\c 28
\b
\q1 
\v 1 A UWE ka lei hookiekie o na mea ona ma Eperaima, Ka pua mae wale o kona nani maikai, Ka mea ma ko poo o ka papu momona, O na mea i ona i ka waina!
\q1 
\v 2 Aia hoi, ka mea ikaika, ka mea i hooikaikaia e ka Haku, Nana no e hoohiolo ia lakou ilalo i ka lepo me kona lima, E like me ka huahekili e haule ana, E like hoi me ka ino nui e make ai, A me ka wai kahe he nui e holo moku ana.
\q1 
\v 3 Malalo o na wawae e hahiia'i Na lei hookiekie o na mea ona ma Eperaima.
\q1 
\v 4 Ka pua mae wale o kona nani maikai, Ka mea ma ke poo o ka papu momona, E like auanei ia me ka hua mua o ke kau, O ka mea nana aku a ike ia mea, Moni koke no ia i ka loaa ana i kona lima.
\b
\q1 
\v 5 A hiki aku i kela la, E lilo no o Iehova i lei alii maikai, A i papale alii nani, no ka poe i koe o kona poe kanaka,
\q1 
\v 6 A i uhane hooponopono maloko o ka poe hooponopono, A i ikaika hoi iloko o ka poe i hoohuli i ke kaua ana i ka pukapa.
\b
\q1 
\v 7 Ua kunewanewa lakou nei, no ka waina, Ua hikaka lakou no ka inu awaawa, Ua kunewanewa ke kahunapule, a me ke kaula no ka inu awaawa, Ua oki loa lakou i ka waina, Ua hikaka lakou no ka inu awaawa, Ua kunewanewa lakou ma ka hihio, Ua kulanalana ko lakou hooponopono ana.
\q1 
\v 8 No ka mea, ua paapu na papaaina a pau i ka luai, I ka paumaele hoi, aohe wahi kaawale.
\b
\q1 
\v 9 Ia wai la ia e ao mai ai i ka ike? E hoike mai oia i ka naauao ia wai? I ka poe anei i ukuhiia i ka waiu? I ka poe anei i auaia i ka u?
\q1 
\v 10 No ka mea, he rula maluna o ka rula, He rula maluna o ka rula; He loina maluna o ka loina, He loina maluna o ka loina; He uuku ma keia wahi. He uuku ma kela wahi.
\q1 
\v 11 He oiaio no me ka lehelehe namu a me ka olelo o ka malihini, E olelo mai ai oia i keia poe kanaka.
\q1 
\v 12 Ia ia i olelo aku ai ia lakou, Eia ka maha e hoomaha oukou i ka poe maloeloe, Eia ka hooluolu; aole nae lakou i hoolohe.
\q1 
\v 13 Nolaila i hiki ai ka olelo a Iehova ia lakou, He rula maluna o ka rula, He rula maluna o ka rula; He loina maluna o ka loina, He loina maluna o ka loina; He uuku ma keia wahi, He uuku ma kela wahi; I hele ai lakou a hina ihope, a lukuia, I hoopaheleia hoi, a paa.
\b
\q1 
\v 14 Nolaila, e hoolohe oukou i ka olelo a Iehova, e na kanaka hoowahawaha, Ka poe e noho alii ana maluna o keia poe kanaka ma Ierusalema.
\q1 
\v 15 No ka mea, ua olelo oukou, Ua hana makou i berita me ka make, Ua hookuikahi makou me ko ka po; A hiki mai ka hahau ana a mahuahua, Aole ia e hiki mai io makou nei; No ia mea, ua hoolilo makou i ka wahahee i puuhonua no makou, Ua huna makou ia makou iho iloko o ka hoopunipuni.
\b
\q1 
\v 16 No ia mea, peneia ka olelo ana mai a ka Haku, a Iehova, Aia hoi, ke hoonoho nei au ma Ziona, He pohaku, he pohaku i hoaoia, He pohaku kihi, ua maikai, He poliaku kumu i hoonoho paa ia: O ka mea i hilinai aku ia ia, aole ia e hee.
\q1 
\v 17 E hoopai pololei aku au ma ke kaula, A e hooponopono aku au ma ka hoailona kupono; A na ka huahekili e hoopau aku i ka puuhonua wahahee, A e halanaia i ka wai, kahi e pee aku ai.
\b
\q1 
\v 18 E hoopauia auanei ko oukou berita me ka make, Aole e kupaa ka oukou kuikahi ana me ka po; I ka wa e hiki mai ai ka hahau ana a mahuahua, E hahiia oukou ilalo e ia.
\q1 
\v 19 I ka wa e puka mai ai ia, e hoopaa mai no ia ia oukou; He oiaio no e hiki mai ia i kela kakahiaka i keia kakahiaka, A i ke ao no hoi a me ka po; A e lilo no ka lohe wale i mea e makau ai.
\q1 
\v 20 No ka mea, ua pokole kahi moe, aole hiki ke hoomoe loa malaila; Ua ololi kahi kapa moe, aole hiki ke uhi ia ia iho.
\q1 
\v 21 No ka mea, e like me ia ma ka mauna o Perazima, Pela no e ala mai ai o Iehova; E like me ia ma ke kahawai o Gibeona, Pela no ia e huhu mai ai, I hana'i oia i kana hana, i kana hana kupanaha hoi; I hoopaa hoi oia i kana hana, kana hana ano e.
\q1 
\v 22 Ano hoi, mai hoowahawaha oukou, O hoopaa loa ia ko oukou mau kupee; No ka mea, ua lohe au i ka hoopau ana, i hooholoia, Na ka Haku na Iehova o na kaua, i ka aina a pau.
\b
\q1 
\v 23 E haliu mai oukou, a e hoolohe i ko'u leo, E haliu mai oukou, a e hoolohe i ka'u olelo ana.
\q1 
\v 24 O ka mea hana me ka oopalau, E hana anei ia i na la a pau e kanu ai? E wawahi ana, a e kuikui ana ia i puupuu lepo o kona aina?
\q1 
\v 25 A hana aku oia i ka lepo a maniania, Aole anei ia i lulu iho i ke kumino eleele, A kanu no hoi i ke kumino? A lulu i ka hua palaoa maikai, A me ka bale, a me ka palaoa eleele, Ma kona wahi iho?
\q1 
\v 26 Ao mai no kona Akua ia ia ma ka hooponopono, A hoike mai no hoi ia ia.
\q1 
\v 27 Aole i kuiia ke kumino eleele i ka mea kui, Aole i hookaaia ka mea kaa maluna o ke kumino; Aka, ua kuiia ke kumino eleele i ka laau, A me ke kumino hoi i ka laau kui.
\q1 
\v 28 Kuiia no ka palaoa a wali, No ka mea, aole makemake ia i ka hahi loihi ana, Aole hoi e hookaa aku i ke kaa o kona kaa, Aole hoi e hahi aku na lio ona ia mea.
\q1 
\v 29 I puka mai no keia mai o Iehova o na kaua mai, Ka mea kupanaha ma ka noonoo ana, A nui loa no hoi kona ike.
\c 29
\b
\q1 
\v 1 A UWE o Ariela, o Ariela, ke kulanakauhale, Kahi a Davida i noho ai! E hookui aku oukou i kekahi makahiki me kekahi makahiki; E hoomau hoi i ka ahaaina ana.
\q1 
\v 2 E hookaumaha aku no wau ia Ariela, A e nui auanei ka ehneha a me ke kaniuhu, A e like auanei ia ia'u me Ariela.
\q1 
\v 3 E hoomoana ku e aku au ia oe a puni, E hoopilikia aku au ia oe i na mea kaua, A e hana au i pakaua imua ou.
\q1 
\v 4 A e hoohaahaaia auanei oe, A e kamailio mai no oe, mailoko mai o ka honua, A mai ka lepo mai e hooliiliiia kau olelo ana; E like auanei kou leo me ko ka poe ninau kupapau mailoko mai o ka honua, E like no hoi kau olelo ana, me ka ioio ana, mai ka lepo mai.
\b
\q1 
\v 5 E like auanei ka lehulehu o kou poe malahini, Me na huna uuku o ka lepo, E like no hoi ka lehulehu o ka poe ikaika me ka opala lele, E hiki wawe ia, ma ke sekona.
\q1 
\v 6 E hele hoohikilele mai o Iehova o na kaua ia oe, Me ka hekili a me ke olai, Me ka uwalaau nui, a me ka puahiohio, Me ka ino, a me ka lapalapa ahi e hoopau ana.
\b
\q1 
\v 7 E like me ka moe uhane, i ka wa e hihio ai i ka po, Pela auanei ka lehulehu o na lahuikanaka a pau, I kaua aku ia Ariela. Ka poe hoi i kaua aku i kona pakaua, A hookaumaha aku ia ia.
\q1 
\v 8 E like mo ka moe uhane ana o ka mea pololi, Aia hoi, ke ai la; aka i kona hikilele ana, Ua hakahaka kona naau; E like hoi me ka moe uhane ana o ka mea makewai, Aia hoi, ke inu la; aka i kona hikilele ana, Aia hoi, ua nawaliwali, a ua ikaika loa ka makemake o kona naau: Pela auanei ka lehulehu o na lahuikanaka a pau, E kaua ana i ka mauna o Ziona.
\b
\q1 
\v 9 E pihoihoi oukou, e kahaha hoi, E olioli no, a e makapo, Ua ona lakou, aole nae i ka waina, Ke hikaka nei, aole nae i ka wai ona.
\q1 
\v 10 Ua ninini mai o Iehova maluna o oukou i ka manao hiamoe loa, A ua hoopili hoi i ko oukou mau maka; Ua uhi no oia i na kahuna, a me ko oukou poe alii a me na kaula.
\q1 
\v 11 I like ka hoike ana a pau ia oukou Me na olelo o ka buke i hoopaaia i ka wepa, A i haawiia ia i ka mea ike i ka palapala, me ka olelo aku, E heluhelu i keia, ke noi aku nei au ia oe; A i mai kela, Aole hiki ia'u, no ka mea, ua paa i ka wepa.
\q1 
\v 12 A haawiia ka buke i ka mea ike ole i ka palapala, me ka olelo aku, Ke nonoi aku nei au ia oe, e heluhelu i keia; A i mai hoi oia, Aole au i ike i ka palapala.
\b
\q1 
\v 13 Nolaila i olelo mai ai ka Haku, No ka hookokoke ana mai o keia poe kanaka ia'u me ko lakou waha, A hoomaikai mai ia'u ma ko lakou lehelehe, A ua mamao aku ko lakou naau mai o'u aku nei, A mamuli o ke kauoha a kanaka lakou e ao ai i ka makau ia'u;
\q1 
\v 14 Nolaila au e hana aku ai i keia poe kanaka i ka mea kupanaha, I ka mea kupanaha a mana hoi; A e pau auanei ko akamai o ko lakou poe akamai, A e pee wale aku ka naauao o ka poe naauao.
\b
\q1 
\v 15 Auwe ka poe imi e huna i ka ohumu ana mai o Iehova aku, A aia ma ka pouli ka lakou hana ana, A olelo mai no hoi lakou, Owai la ka mea nana mai ia makou? Owai la hoi ka mea ike mai ia makou?
\q1 
\v 16 Auwe ko oukou lauwili! E manaoia anei ka lepo me ka mea nana i kawili: E olelo anei ka mea i hanaia i ka mea nana ia i hana, Aole ia i hana mai ia'u? E olelo anei ka mea i kapiliia i ka mea nana ia i kapili, Aole ia i ike?
\b
\q1 
\v 17 Aole anei he manawa uuku e koe, A lilo o Lebanona i mahinaai hua nui? A lilo hoi ka mahinaai hua nui, i ululaau?
\b
\q1 
\v 18 A ia la, e lohe no ka mea kuli i na huaolelo o ka buke, A mailoko mai o ka pouli, a mailoko mai o ka poeleele, E nana mai ai na maka o ka poe makapo.
\q1 
\v 19 E hoomahuahua no ka poe hoohaahaa i ka olioli ia Iehova, A e hauoli hoi ka poe hune o na kanaka i ka Mea Hemolele o ka Iseraela.
\q1 
\v 20 No ka mea, ua oki loa ka mea oolea, Ua pau hoi ka mea hoowahawaha, Ua lakuia ka poe a pau i makaala i ka hewa:
\q1 
\v 21 Ka poe i hoohewa mai i ke kanaka no ka olelo hookahi, A hoopahele hoi i ka mea hooponopono ma na pukapa, Aole hoi he kumu no ka lakou hana paewaewa ana i ka poe i pono.
\b
\q1 
\v 22 Nolaila, no ka hale o Iakoba i olelo mai ai o Iehova, Ka mea i hoola ia Aberahama, Aole Iakoba o hilahila hou, Aole e nananakea hou kona maka.
\q1 
\v 23 A i kona ike ana i kana mau keiki, i ka hana a kuu lima, E hoolaa no lakou i ko'u inoa iwaenakonu ona, E hoolaa no lakou i ka Mea Hemolele o ka Iakoba, A e makau no hoi i ke Akua o ka Iseraela.
\q1 
\v 24 E naauao auanei ka poe i lalau ma ka naau, E ao no hoi ka poe ku e, a o loaa ia lakou ka ike.
\c 30
\b
\q1 
\v 1 A UWE na keiki kipi, wahi a Iehova, Ka poe i hooholo manao, aole nae ma o'u nei; Ka poe i ninini i na mohai ninini, aole nae ma ko'u uhane, I kui aku ai lakou i kekahi hewa mo kekahi hewa;
\q1 
\v 2 Ka poe i hele ilalo i Aigupita, Aole nae i ninau ma kuu waha; A hooikaika lakou ia lakou iho ma ka ikaika o Parao, A hilinai aku ma ke aka o Aigupita.
\q1 
\v 3 E lilo no ka ikaika o Parao i mea e hilahila ai oukou, A me ka hilinai ana i ke aka o Aigupita, oia kekahi mea hilahila.
\q1 
\v 4 No ka mea, aia ma Zoana kona poe alii, A hiki ae la kona poe luna i Hanesa.
\q1 
\v 5 Hilahila no lakou a pau i ka lahuikanaka hiki ole ke kokua ia lakou, Aole alu pu, aole kokua, Aka, he mea hilahila, he mea hoi e hoowahawahaia'i.
\b
\q1 
\v 6 Ua kaumaha na holoholona o ke kukulu hema, O na mea hali, no ka aina e kaniuhu ai, a e eha ai hoi, Ma kahi o ka liona wahine, a me ka liona kane, Ka moonihoawa, a me ka moolele; Lawe no lakou i ko lakou waiwai ma ke kua o na hoki opiopio, A me ko lakou ukana hoi, ma na puu o na kamelo, E lilo i na kanaka kokua ole ia lakou.
\q1 
\v 7 Ua lapuwale ko Aigupita, make hewa ko lakou hooikaika ana, Nolaila au i kapa aku ai ia ia, o Huhuahoopalaleha.
\b
\q1 
\v 8 O hele hoi, e palapala ia mea ma ka papa imua o lakou, A e kahakaha hoi ma ka buke, I mea no na la mahope, no na manawa, mau loa aku:
\q1 
\v 9 No ka mea, he poe kanaka kipi keia, He poe keiki wahahee, He poe kamalii hoolohe ole i ke kanawai o Iehova:
\q1 
\v 10 He poe olelo i na mea ike, Mai ike oukou; A i na kaula hoi, Mai wanana mai oukou ia makou i na mea pono, E hai mai ia makou i na mea oluolu, E wanana mai i na mea hoopunipuni:
\q1 
\v 11 E kapae ae iwaho o ke alanui, E huli ae mawaho o ke kuamoo, E hoihoi aku i ka Mea Hemolele o ka Iseraela, mai ko makou alo aku.
\q1 
\v 12 Nolaila, ke olelo mai nei ka Mea Hemolele o ka Iseraela peneia, No ko oukou hoowahawaha ana i keia olelo, A ua hilinai aku i ka alunu, a me ke kekee, A ua hio ma ia mau mea;
\q1 
\v 13 No ia mea, e lilo ai keia hewa ia oukou, E like me kahi i naha o ka pa e hiolo ana, He wahi hio o ka pa kiekie, E hiolo hiki wawe, ma ke sekona no.
\q1 
\v 14 E naha no ia e like me ka naha ana o ka ipulepo o na potera, E nahaha io no, aole ia e aloha mai; Maloko o na mea naha, aole e loaa kekahi apana, E lawe ai i ko ahi enaena, A e huki hoi i ka wai o ka luawai.
\q1 
\v 15 No ka mea, penei i olelo mai ai ka Haku, O Iehova, ka Mea Hemolele o ka Iseraela, Ma ka huli ana mai a me ka hoomaha oukou e ola'i; Ma ka noho malie, a ma ka hilinai mai, malaila ko oukou ikaika; Aole nae oukou i ae mai.
\q1 
\v 16 A olelo mai no oukou, Aole; Aka, e holo no makou maluna o na lio; Nolaila, e holo io no oukou; E holo makou maluna o na mea mama; Nolaila, e mama'i ka poe hahai ia oukou.
\q1 
\v 17 E hee no kekahi tausani o oukou, No ka papa ana o ka mea hookahi; No ka papa ana o na mea elima e hee ai oukou; A waihoia oukou, e like me ke kia ma ka piko o ke kuahiwi, Me he hae la hoi maluna o ka puu.
\b
\q1 
\v 18 Nolaila, e kakali no o Iehova, i lokomaikai oia ia oukou, Nolaila, e hiilaniia oia, ma ka hana maikai aku ia oukou: No ka mea, he Akua hooponopono o Iehova; Pomaikai ka poe a pau i hilinai aku ia ia.
\q1 
\v 19 No ka mea, e noho no na kanaka o Ziona ma Ierusalema; Aole loa hoi oukou e uwe hou aku; E lokomaikai loa aku oia i ka leo o kou kahea ana, A lohe oia, e ae mai no ia oe.
\q1 
\v 20 Ua haawi mai no ka Haku ia oukou i ka berena o ka popilikia, A me ka wai o ke kaumaha, Aka, aole e lawe hou ia'ku kau poe kumuao, E ike aku no kou mau maka i na kumuao:
\q1 
\v 21 E lohe no kou mau pepeiao i ka olelo mahope ou, i ka i ana mai, Eia ke ala, e hele maloko olaila, Ina paha oukou e huli ma ka akau, A ina paha oukou e huli ma ka hema,
\q1 
\v 22 E hoohaumia no hoi oukou i ke poi kala o ko oukou mau kii i kalaiia, A me ka wahi gula o kou mau kii hooheheeia; E kiola ana oukou ia, e like me ka welu pea, A e olelo ana no oe ia ia, Hele pela,
\b
\q1 
\v 23 Alaila e haawi mai no oia i ka ua no kau hua, Ka mea au e kanu ai ma ka lepo; A me ka berena hoi no ka hua ana mai o ka lepo, A e momona no ia, a mahuahua ka maikai; E ai no kou mau holoholona ia la ma na kula palahalaha.
\q1 
\v 24 O na bipi kauo hoi, a me na hoki opiopio, Na mea i hana ma ka aina, E ai no lakou i ka ai i miko i ka paakai, Ka mea i peahiia i ka peahi a me ke kanana.
\q1 
\v 25 A maluna o na kuahiwi kiekie a pau, A maluna hoi o na puu kiekie a pau, E loaa no na kahawai, a me ka wai e kahe ana, I ka la o ka make nui, I ka haule ana o na halekiai.
\q1 
\v 26 A e like auanei ka malamalama o ka mahina, Me ka malamalama o ka la, A e pahiku no ka malamalama o ka la, E like me ka malamalama o na la ekiku, I ka la e wahi ai o Iehova i ka eha o kona poe kanaka, A hoola hoi i ka eha o ko lakou hahauia.
\b
\q1 
\v 27 Aia hoi, ke hele mai nei ka inoa o Iehova mai kahi loihi mai, Ua wela kona ukiuki, a nui loa ke a ana; Ua piha kona mau lehelehe i ka inaina, A ua like no kona elelo me ke ahi e hoopau ana.
\q1 
\v 28 Ua like kona hanu me ka waikahe e holo moku ana, E pii no ia a waenakonu o ka a-i, E kanana i na lahuikanaka i ko kanana o ka make; Aia ma na iwia o na kanaka he kaulawaha e alakai hewa ana.
\q1 
\v 29 He mele no ko oukou, E like me ko ka po i ka wa e malama ai i ka ahaaina; He olioli o ka naau, e like me ka mea hele mamuli o ka hokiokio, A hiki aku i ka mauna o Iehova, i ka pohaku hoi o ka Iseraela.
\q1 
\v 30 O Iehova ka mea e loheia'i kona leo nani, E hoike aku no oia i ka iho ana o kona lima, Me ka ukiuki o ka inaina, A me ka lapalapa o ke ahi e hoopau ana, O ka ua nui, a me ka ino, a me ka huahekili.
\q1 
\v 31 No ka mea, ma ka leo o Iehova, E moku loa auanei ko Asuria, Me ka laau e hahau no ia.
\q1 
\v 32 Ma na wahi a pau e hiki aku ai ka laau hoopai, Ka mea a Iehova e kau ai maluna ona, O na pahu kani no kekahi, a me na mea kani; A e kaua no oia ia ia me ke kaua weliweli.
\q1 
\v 33 No ka mea, ua hoomakaukau kahiko ia o Topeta, No ko alii hoi ia i hoomakaukauia'i; Ua hana oia ia wahi a hohonu, a ua nui hoi; He wahi ahi, a ua nui hoi ka wahie, Na ka hanu no o Iehova e hoa iho, E like me ka luaipele e kahe ana.
\c 31
\b
\q1 
\v 1 A UWE ka poe iho ilalo i Aigupita no ke kokuaia mai. Ka poe i paulele i na lio, a hilinai ma na kaakaua, No ka nui o ia mau mea; A ma na hololio hoi, no ko lakou ikaika nui: Aole hoi e nana aku i ka Mea Hemolele o ka Iseraela, Aole imi aku ma o Iehova la!
\q1 
\v 2 He akamai no hoi oia, A e hoopuka mai no ia i ka hewa, Aole ia e kapae i kana mau olelo; Aka, e ala mai no oia iluna e ku e i ka hale o ka poe hana hewa, E ku e hoi i ka poe kokua i na mea hana hewa.
\q1 
\v 3 No ka mea, he poe kanaka wale no ko Aigupita, aohe akua; He io no ko lakou mau lio, aohe uhane; E hohola mai no o Iehova i kona lima, A e kulanalana auanei ka mea kokua, E hina no hoi ka mea e kokuaia, A e make pu no lakou a pau.
\b
\q1 
\v 4 No ka mea, penei i olelo mai ai o Iehova ia'u, E like me ka uwo ana o ka liona, A me ka liona hou hoi maluna o ka mea ana i pepehi ai, Ina i akoakoa na kahuhipa he nui loa, e ku e ia ia, Aole ia e makau i ko lakou leo, Aole hoi e kulou ilalo no ka lehulehu o lakou: Pela no o Iehova o na kaua e iho mai ai, E kaua mamuli o ka mauna o Ziona, Mamuli hoi o ko laila puu.
\q1 
\v 5 E like me na manu lele, pela no o Iehova o na kaua e malama mai ai ia Ierusalema; I kona malama ana, e hoopakele no oia ia wahi, I kona hele ana ae, e hoola mai no oia.
\b
\q1 
\v 6 E huli oukou i ka mea a ua mamo a Iseraela i haalele ino ai:
\q1 
\v 7 No ka mea, i kela la, E kiola aku no ke kanaka i kona mau akuakii kala, A me kona mau akuakii gula, I na mea a ko oukou mau lima i hana hewa ai no oukou.
\b
\q1 
\v 8 A e haule no ko Asuria i ka pahikaua, aole nae i ko ke kanaka, E ai no ka pahikaua ia ia, aole nae o ko ke kanaka; E auhee no ia, mai ke alo aku o ka pahikaua, A e auhauia kona poe kanaka ui.
\q1 
\v 9 E hele aku no ia i kona pohaku, no ka makau. A e makau no kona poe alii no ka hae, Wahi a Iehova, ka mea nana ke ahi ma Ziona, A nana hoi ke kapuahi ma Ierusalema.
\c 32
\b
\q1 
\v 1 A IA hoi, ma ka pono no e malama aupuni ai ke alii nui, A ma ka pololei hoi e noho alii ai na'lii.
\q1 
\v 2 E like auanei ke kanaka me kahi lulu o ka makani, Me ka mamalu hoi no ka ua; E like me na auwai ma kahi maloo, E like hoi me ka malu o ka pohaku nui ma ka aina maluhiluhi.
\q1 
\v 3 Aole e hoopiliia na maka o ka poe ike, A e hoolohe no na pepeiao o ka poe lohe.
\q1 
\v 4 E ike no hoi ka naau o ka poe noonoo ole i ke akamai, A o ke alelo o ka poe uuu, E makaukau no ia e olelo akaka mai.
\q1 
\v 5 Aole e kapa hou ia ka mea lapuwale, he maikai nui, Aole hoi e iia ka mea alunu, he lokomaikai.
\q1 
\v 6 No ka mea, e olelo no ke kanaka lapuwale i ka mea lapuwale, A e ohumu no kona naau i ka hewa, Ma ka aia kana hana ana, a olelo ino ku e ia Iehova, E hoonele i ka naau o ka poe pololi. A e hoopau i ka wai o ka mea makewai.
\q1 
\v 7 He hewa na mea hana o ka mea alunu; Imi no oia i na manao hewa, E hookaumaha i ka poe poino i na olelo wahahee, I ka poe popilikia hoi e olelo ana ma ka pololei.
\q1 
\v 8 Aka, o ka mea lokomaikai, imi no oia i ka lokomaikai, A ma ka lokomaikai oia e kupaa ai.
\b
\q1 
\v 9 E na wahine e noho nanea ana, E ku mai iluna, e hoolohe hoi i ko'u leo; E na kaikamahine makau ole, e haliu pepeiao mai i ka'u olelo.
\q1 
\v 10 No ka makahiki a keu ko oukou haalulu ana, E na wahine makau ole; No ka mea, e pau auanei ka ohi hua waina ana, Aole e hiki mai ka hooiliili ai ana.
\q1 
\v 11 E haalulu oukou, e ka poe e noho nanea ana, E weliweli hoi oukou, ka poe makau ole; E wehe i ko oukou lole, a e ku kohana, a e kaei i na puhaka.
\q1 
\v 12 E nui auanei ka uwe ana no na waiu, A no na mahinaai maikai, a no ke kumuwaina hua nui.
\q1 
\v 13 Ma ka aina o ko'u poe kanaka, E ulu mai no ke kakalaioa, a me ka laau ooi, Maluna hoi o na hale olioli a pau, Iloko o ke kulanakauhale e olioli ana.
\q1 
\v 14 No ka mea, e haaleleia auanei na halealii, A e neoneo no hoi ke kulanakauhale o na kanaka lehulehu; O ka puu a me ka halekiai e lilo no i ana mau loa, I mea hoi e olioli ai na hoki hihiu, I wahi hoi e hanai ai i na holoholona;
\q1 
\v 15 A nininiia ka Uhane mailuna mai maluna o kakou, A lilo ka waonahele i mahinaai hua nui, A manaoia hoi ka mahinaai hua nui, he ululaau.
\q1 
\v 16 Alaila, e noho no ka pono ma ka waonahele, A e hoomau no hoi ka maikai ma ka mahinaai hua nui.
\q1 
\v 17 E lilo no ka hana pono ana i mea e malu ai, A o ka hope o ka maikai, he kuapapanui mau loa, a me ka malu.
\q1 
\v 18 E noho no ko'u poe kanaka ma na wahi kuapapanui, A ma na hale hoi i hoomaluia, A ma na wahi hoomaha o ka malu.
\q1 
\v 19 Aka, e haule mai no ka hua hekili, I ke kuaia ilalo o ka ululaau; A i kahi haahaa e hoohaahaaia'i ke kulanakauhale.
\q1 
\v 20 E pomaikai auanei oukou, ka poe lulu hua ma na wahi wai nui, Ma kahi i hoounaia'i ka bipi kaulua a me ka hoki.
\c 33
\b
\q1 
\v 1 A UWE oe ka mea anai aku, Aole hoi oe i anaiia mai; Ka mea hao wale aku, aole nae lakou i hao mai ia oe! A pau kau anai ana aku, alaila e anaiia mai oe; A pau kou hao ana aku, alaila lakou e hao mai ai ia oe.
\q1 
\v 2 E Iehova, e maliu mai oe ia makou, Ua kakali makou ia oe, E lilo no oe i mea kokua ia lakou i kakahiaka, I mea hoi e ola'i makou i ka manawa popilikia.
\q1 
\v 3 I ka leo o ka lehulehu, hee aku la na kanaka, Ia oe i ala'i iluna, hoopuehuia'ku la na lahuikanaka.
\q1 
\v 4 E hoiliiliia no ko oukou waiwai pio, Me ko ka enuhe hoiliiliia; A e like me ka holo ana o na uhini io ia nei, Pela no ia e holo ai maluna ona,
\q1 
\v 5 Ua hapaiia o Iehova, no ka mea, maluna no oia e noho ana; Ua hoopiha no oia ia Ziona i ka pono a me ka maikai.
\q1 
\v 6 E lilo ana ke akamai a me ka ike, I kumu paa o kou manawa, i mea kokua ikaika hoi; O ka makau ia Iehova, oia kona waiwai malama.
\q1 
\v 7 Aia, e uwe ana ko lakou poe ikaika mawaho; E uwe walania no hoi na luna imi malu.
\q1 
\v 8 Ua haaleleia na alanui, Ua oki ka mea hele; Ua uhai oia i ka berita, Ua hoowahawaha oia i na kulanakauhale; Aole ia i manao i ke kanaka.
\q1 
\v 9 Ua uwe ka aina, ua kanikau hoi; Ua hilahila o Lebanona, ua mae wale; Ua like o Sarona me ka waonahele; Lulu iho o Basana, a me Karemela i na lau.
\q1 
\v 10 Ano, e ku no owau iluna, wahi a Iehova, Ano, e hapaiia no wau, Ano la wau e hookiekieia.
\q1 
\v 11 E hapai auanei oukou, i mauu maloo, E hanau mai no hoi oukou, i opala. Na ko oukou hanu no e hoopau ia oukou iho me he ahi la.
\q1 
\v 12 E like auanei ua lahuikanaka me ke kahu ana i ka puna: E puhiia no i ke ahi, e like me na kakalaioa i okiia.
\b
\q1 
\v 13 E ka poe ma kahi mamao aku, E hoolohe mai oukou i ka'u hana ana; A me ka poe e kokoke mai hoi, E hoomaopopo oukou i ko'u mana.
\q1 
\v 14 Ua makau ka poe hewa ma Ziona, Ua loohia ka poe aia i ka haalulu. Owai la ka mea o kakou e hiki ke noho me ke ahi e hoopau ana? Owai la ka mea o kakou e hiki ke noho me ka wela mau loa?
\q1 
\v 15 O ka mea hele ma ka pono, a olelo hoi ma ka pololei; O ka mea hoowahawaha i ka waiwai o ka hookaumaha ana, O ka mea lulu mawaho aku o kona lima i ka waiwai i loaa ma ke kipe ana; O ka mea pani i kona mau pepeiao o lohe i ke koko, O ka mea hoopili i kona mau maka, i ike ole ia i ka hewa;
\q1 
\v 16 Oia ka mea e noho ana ma kahi kiekie; O na pa pohaka kona puuhonua: E haawiia no ka ai nana, a e mau ana hoi kona wai inu.
\b
\q1 
\v 17 E ike aku no kou mau maka i ke alii i kona nani; E ike no hoi lakou i ka aina ma kahi loihi aku.
\q1 
\v 18 E hoomanao ana no kou naau i ka makau i hala. Auhea ke kakauolelo? auhea hoi ka lunakaupaona? Auhea ka mea helu i na halekiai?
\q1 
\v 19 Aole oe e ike hou aku i ka lahuikanaka ikaika, I ka lahuikanaka olelo ike ole ia, ma ka lohe ana, I ke alelo namu hoi au i hoomaopopo ole ai.
\q1 
\v 20 E ike auanei oe ia Ziona, I ke kulanakauhale o ka kakou ahaaina ana; E ike auanei kou mau maka ia Ierusalema. He wahi noho i hoomaluia, He halelewa hoi, aole e lawe hou ia'ku; Aole e unuhiia kona mau makia a i ka manawa pau ole, Aole hoi e moku kekahi o kona mau kaula.
\q1 
\v 21 Malaila io no ka nani o Iehova no kakou, He wahi muliwai nui, a akea ma na aoao a pau, Aole moku holo maloko olaila me ka hoe, Aole moku nui e holo ae a kela aoao.
\q1 
\v 22 No ka mea, o Iehova no ko kakou lunakanawai, O Iehova ka mea kau i ke kanawai maluna o kakou, O Iehova ko kakou alii; Oia ka mea e hoola mai ai ia kakou.
\q1 
\v 23 Ua weheia kou mau kaula, Aole hiki ia lakou ke hoopaa i ka papakukia, Aole hoi e hiki ke kau i ka hae; Alaila puunaueia ka waiwai pio nui; E hiki no i ka poe oopa ke hopu iho i ka waiwai pio.
\q1 
\v 24 Aole e olelo ka mea e noho ana, Ua mai au; O na kanaka E noho ana maloko, Ua kalaia ko lakou hewa.
\c 34
\b
\q1 
\v 1 E HOOKOKOKE mai, e ko na aina, i lohe oukou, E hoolohe mai hoi, e na lahuikanaka, E haliu mai hoi ko ka honua, A me kolaila mea a pau e piha ai, O ke ao nei, a me kona mea ulu a pau.
\q1 
\v 2 No ka mea, maluna o na lahuikanaka a pau ka inaina o Iehova, A o kona ukiuki hoi maluna o ko lakou lehulehu a pau; Ua molia oia ia lakou, Ua haawi oia ia lakou i ka make.
\q1 
\v 3 E kiolaia'ku no ko lakou poe i houia, A e pii aku no ka pilau o ko lakou kupapau, A e hooheheeia na kuahiwi i ko lakou koko.
\q1 
\v 4 E hookii loa aku no na mea a pau o ka lani, A e owili pu ia na lani me he pepa la; E haule no kolaila mau mea a pau ilalo, E like me ka haule ana o ka lau o ke kumuwaina, E like hoi me ka haule ana o ka hua mimino o ka laau fiku.
\q1 
\v 5 No ka mea, ua inu no ka'u pahikaua ma ka lani a ona; Aia hoi, e iho ana ia maluna o Edoma, Maluna hoi o ka lahuikanaka a'u i hoolilo ai no ka hoopaiia.
\q1 
\v 6 Ua ana ka pahikaua o Iehova i ke koko, Ua hapalaia i ke kaikea, I ke koko hoi o na keikihipa momona, a me na kaokane, I ke kaikea hoi ma na puupaa o na hipakane, No ka mea, he mohai ko Iehova ma Bozera, A he luku nui hoi ma ka aina o Edoma.
\q1 
\v 7 E haule pu na reema me lakou, A me na bipikane, a me na mea ikaika; A e ona no ko lakou aina i ke koko, A momona no hoi ko lakou lepo i ke kaikea.
\q1 
\v 8 No ka mea, o ka la no ia o ko Iehova koopai ana, O ka makahiki hoi o ka hoouku ana no na hakaka o Ziona.
\q1 
\v 9 E lilo no kolaila muliwai i kepau, A o kolaila lepo hoi i luaipele; A e lilo no kolaila aina i kepau e a ana.
\q1 
\v 10 Aole ia e hoopioia i ka po, aole i ko ao; A e punohu mau loa aku no kona uwahi; E waiho kaha wale ia no ia, mai keia hanauna, a ia hanaua aku, Aohe mea e hele mawaena olaila a hiki i ka manawa pau ole.
\b
\q1 
\v 11 E komo no malaila ka pelikana, a me ke kipoda; A malaila no hoi e noho ai ka pueo, a me ke koraka; A e hoomoe oia maluna ona i kaula o ka neoneo; A me na pohaku o ka olohelohe.
\q1 
\v 12 Aole e hea hou ia na'lii malaila no ko aupuni, A e lilo no kona poe luna a pau i mea ole.
\q1 
\v 13 E ulu no ke kakalaioa maloko o kona mau halealii; O ka nahelemaneo, a me ka laau ooi ma kona mau pakaua, A e lilo no ia i wahi no na ilio hihiu, I wahi noho hoi no na iana.
\q1 
\v 14 E halawai no na ilio hihiu o ka waonahele me na iliohae, A malaila no o hea aku ai ke kao hihiu i kona hoa, A malaila no hoi e noho ai ka lapu o ka po, A e loaa hoi kahi hoomaha nona.
\q1 
\v 15 Malaila no e hana'i ka moolele i kona punana, A hanau, a hoomoe, a hoopunana malalo o kona malu; Malaila no hoi e akoakoa ai na vuletura, O kela mea keia mea, me kona hoa.
\b
\q1 
\v 16 E imi oukou ma ka palapala a Iehova, a e heluhelu no hoi; Aole e haule kekahi o keia mau mea, Aole e nele kekahi i kona hoa; No ka mea, ua olelo no ko'u waha, A na kona Uhane no lakou i hoiliili.
\q1 
\v 17 Ua hailona oia no lakou, A ua puunaue aku oia ia wahi ma ke kaula no lakou; E lilo loa aku no ia aina no lakou, E noho no lakou malaila, ia hanauna aku, a ia hanauna aku.
\c 35
\b
\q1 
\v 1 E OLIOLI auanei ka waonahele, a me kahi maloo no ia mau mea; E hauoli hoi ka waoakua, a e pua mai hoi, e like me ka lilia.
\q1 
\v 2 E pua nui no ia, a e hauoli hoi me ka olioli, a me ka hauoli; E haawiia'ku ka nani o Lebanona ia ia, A me ka maikai o Karemela, a me Sarona; E ike auanei lakou i ka nani o Iehova, A me ka hanohano o ko kakou Akua.
\b
\q1 
\v 3 E hooikaika oukou i na lima nawaliwali, A e hookupaa i na kuli kulanalana.
\q1 
\v 4 E olelo aku oukou i ka poe makau o ka naau, I nui ka ikaika, mai makau oukou; Aia hoi ko oukou Akua! E hele mai no ia e hoopai, o ke Akua hoi me ka hoouku; E hele mai no oia, a e hoola ia oukou.
\q1 
\v 5 Alaila, e hookaakaaia na maka o ka poe makapo, A e hoohakahakaia na pepeiao o ka poe kuli.
\q1 
\v 6 Alaila, e lelele no ka oopa me he dia la, A e oli hoi ke alelo o ka leo paa: No ka mea, e puka mai no ka wai ma ka waonahele, A me na muliwai hoi ma ka waoakua.
\q1 
\v 7 E lilo no ka lepo olinolino i waiauau, A me kahi maloo, i waipuna; Ma ka hale o ka ilio hihiu, kahi ana i moe ai, He wahi ia no ka ohe, a me ke kome.
\q1 
\v 8 A malaila no ke kuamoo, he alanui hoi, A e kapaia no ia, Ke alanui o ka pono. Aole hele malaila ka mea haumia; E hele pu no oia me lakou ma ke ala, Aole lalau ka poe naaupo malaila.
\q1 
\v 9 Aole liona ma ia wahi, Aole pii aku malaila kekahi holoholona hae, Aole e loaa ia ma ia wahi; Aka, malaila no e hele ai ka poe i hoolapanaiia.
\q1 
\v 10 A e hoi mai no ko Iehova poe i kuai hoolaia, E hele mai no lakou i Ziona me ke oli, A me ka hauoli mau maluna o ko lakou mau poo; E loaa no ia lakou ka olioli, a me ka hauoli, A e auhee aku no ke kaumaha, a me ke kaniuhu.
\c 36
\b
\q1 
\v 1 I KA makahiki umikumamaha o ke alii, o Hezekia, pii ku e mai la Sanekariba ke alii o Asuria, i na kulanakauhale a pau i paa i ka pa o ka Iuda, a hoopio iho la ia lakou.
\q1 
\v 2 A hoouna ae la ke alii o Asuria ia Rabesake, mai Lakisa ae, a i Ierusalema, i ke alii io Hezekia la, me na koa he nui loa. A ku iho la oia ma ka auwai o ka waipuna luna, ma ke ala e hiki aku ai i ke kula o ka mea holoi lole.
\q1 
\v 3 Alaila, hele aku la io na la, o Eliakima, ke keiki a Hilekia, o ka mea maluna o ko ka hale, a me Sebena, ke kakauolelo, a me Ioa, ke keiki a Asana, ke kakaumooolelo.
\b
\q1 
\v 4 I mai la o Rabesake ia lakou, E i aku oukou ia Hezekia, ke olelo mai nei ke alii nui, ke alii o Asuria penei, Heaha keia hilinai ana au e hilinai nei?
\q1 
\v 5 Ke olelo nei au, he olelo lapuwale kou akamai a me kou ikaika i ke kaua. Ke hilinai aku nei oe ia wai, i kipi mai ai oe ia'u?
\q1 
\v 6 Aia ka! ke hilinai nei oe i ke kookoo o keia ohe naha, o Aigupita, ka mea e komo ai i ka lima a puka, ke hilinai ke kanaka maluna ona. Pela o Parao, ke alii o Aigupita i ka poe a pau i hilinai maluna ona.
\q1 
\v 7 Aka, ina olelo mai oe ia'u. Ke hilinai aku nei makou ia Iehova, i ko makou Akua; aole anei oia ka mea nona na wahi kiekie, a nona hoi na kuahu a Hezekia i wawahi ai, a ua olelo no hoi i ka Iuda, a i ko Ierusalema, Mamua o keia kuahu oukou e hoomana'i?
\q1 
\v 8 Ano la, ea, e hoolimalima oe me kuu haku, me ke alii o Asuria, a e haawi aku no au ia oe i elua tausani lio, ina paha e hiki ia oe ke hoonoho i na hololio maluna o lakou.
\q1 
\v 9 Pehea hoi oe e hoohuli aku ai i ka maka o kekahi luna uuku o na kauwa a kuu haku, a hilinai hoi maluna o Aigupita, no na kaakaua, a no na hololio?
\q1 
\v 10 Ano hoi, aole anei o Iehova kekahi pu me au i pii mai nei i keia aina, e luku ia? Ua olelo mai no o Iehova ia'u, E pii ae oe i keia aina, a e luku iho ia.
\b
\q1 
\v 11 Alaila, olelo aku la o Eliakima, a me Sebena, a me Ioa, ia Rabesake, Ke noi aku nei au ia oe, e olelo mai oe i kau mau kauwa nei ma ka olelo Suria, no ka mea, ua ike makou ia. Mai olelo mai ma ka olelo Iudaio, ma na pepeiao o na kanaka maluna o ka pa.
\b
\q1 
\v 12 Aka, olelo mai la o Rabesake, Ua hoouna mai nei anei ko'u haku ia'u i kou haku, a iou la, e olelo i keia mau olelo? Aole anei i ka poe kanaka e noho ana ma ka pa, i ai lakou i ko lakou lepo iho, a inu hoi i ko lakou mimi iho me oukou?
\b
\q1 
\v 13 Alaila, ku mai la o Rabesake, a hea ae la me ka leo nui, ma ka olelo Iudaio, i ae la, E hoolohe mai oukou i na olelo a ke alii nui, ke alii o Asuria.
\q1 
\v 14 Ke i mai nei ke alii penei, Mai walewale oukou ia Hezekia, no ka mea, aole e hiki ia ia ke hoopakele ia oukou.
\q1 
\v 15 Mai ae aku i ko Hezekia hooikaika ana ia oukou e hilinai ia Iehova, i ka i ana iho, E oiaio no e hoopakele o Iehova ia kakou; aole e haawiia keia kulanakauhale iloko o ka lima o ke alii o Asuria.
\q1 
\v 16 Mai hoolohe i ka Hezekia; no ka mea, ke olelo mai nei ke alii o Asuria penei, E hana oukou me au i kuikahi, a e puka mai iwaho io'u nei; a e ai kela mea keia mea o oukou i ko kona kumu waina, a i ko kona laau fiku, a e inu hoi keia mea, keia mea o oukou i ka wai o kona luawai iho;
\q1 
\v 17 A hiki aku au, a lawe aku ia oukou i ka aina e like me ko oukou aina iho, he aina ai, a waina hoi, he aina berena, a me na pawaina.
\q1 
\v 18 E ao oukou, o hoowalewale mai o Hezekia ia oukou, i ka i ana mai, E hoopakele mai no o Iehova ia kakou. Ua hoopakele anei na akua o kekahi lahuikanaka i ko lakou aina iho, mai ka lima aku o ke alii o Asuria?
\q1 
\v 19 Aia la ihea na'kua o Hamata a me Arepada? Auhea hoi na'kua o Separevaima? Ua hoopakele anei lakou ia Samaria mai ko'u lima aku?
\q1 
\v 20 Owai la ka mea o na'kua o ia mau aina a pau nana i hoopakele i kona aina iho, mai ko'u lima aku, i hoopakele ai o Iehova ia Ierusalema, mai ko'u lima aku?
\b
\q1 
\v 21 Ekemu ole lakou, aole i olelo aku ia ia i kekahi huaolelo; no ka mea, oia ke kauoha a ke alii, i mai la, Mai olelo aku ia ia.
\b
\q1 
\v 22 Alaila, hele mai la o Eliakima, ke keiki a Hilekia, ka mea maluna o ko ka hale, a me Sebena, ke kakauolelo, a me Ioa, ke keiki a Asapa, ke kakaumooolelo, io Hezekia la, me ka haehaeia o ka lole, a hai ae la ia ia i na olelo a Rabesake.
\c 37
\b
\q1 
\v 1 A LOHE o Hezekia, ke alii, haehae iho la oia i kona lole, a uhi iho la ia ia iho i ke kapa ino, a komo aku la iloko o ka hale o Iehova.
\q1 
\v 2 A hoouna ae la oia ia Eliakima, i ka mea maluna o ko ka hale, a me Sebena, i ke kakauolelo, a me na luna o na kahuna me ka uhiia i ke kapa ino, io Isaia la, i ke kaula, i ke keiki a Amosa.
\q1 
\v 3 I ae la lakou ia ia, Ke i mai nei o Hezekia penei, He la popilikia keia, he la no ka hoopai ana, a me ka olelo hoino; no ka mea, ua hiki na keiki i ke kokoke hemo, aole nae he ikaika e hanau ai.
\q1 
\v 4 Malia paha e lohe o Iehova, kou Akua, i na olelo a Rabesake, ka mea a ke alii o Asuria, a kona haku i hoouna'i e hoino ai i ke Akua ola, a e hoopai hoi i na olelo a Iehova a kou Akua i lohe ai. Nolaila, e pule aku oe no ke koena o na kanaka i ikeia.
\q1 
\v 5 A hiki ae la na kauwa a ke alii, a Hezekia io Isaia la.
\b
\q1 
\v 6 I mai la o Isaia ia lakou, Penei oukou e olelo aku ai i ko oukou haku, Ke olelo mai nei o Iehova penei. Mai makau oe i na olelo au i lohe ai, i na olelo a na kauwa a ke alii o Asuria i olelo hoino mai ai ia'u.
\q1 
\v 7 Aia hoi, e haawi aku no au ia ia i manao, a e lohe no oia i ka lono, a e hoi aku i kona aina iho: a na'u no ia e hookulai i ka pahikaua ma kona aina iho.
\b
\q1 
\v 8 Hoi aku la o Rabesake, a loaa ia ia ke alii o Asuria, e kaua ana ia Libena; ua lohe mua no hoi oia, ua haalele ia ia Lakisa.
\q1 
\v 9 Alaila, lohe ae la oia ia Tirehaka, i ke alii o Aitiopa, i ka i ana mai, Ke hele mai nei ia e kana ia oe. A i kona lohe ana, hoouna mai la ia i mau elele ia Hezekia, i mai la,
\q1 
\v 10 Penei oukou e olelo aku ai ia Hezekia, i ke alii o ka Iuda, e i aku, Mai walewale oe i kou Akua au e hilinai nei, i kana olelo ana, Aole e haawiia o Ierusalema iloko o ka lima o ke alii o Asuria.
\q1 
\v 11 Aia hoi, ua lohe no oe i ka mea a na alii o Asuria i hana'i i na aina a pau, i ka luku loa ana ia lakou; a e hoopakeleia anei oe?
\q1 
\v 12 Ua hoopakele anei na'kua o na aina i ka poe a ko'u mau makuakane i luku ai; ia Gozana, a me Harana, a me Rezepa, a me na keiki a Edena, ka poe ma Telasara?
\q1 
\v 13 Auhea ke alii o Hamata, a me ke alii o Arepada, a me ke alii o ke kulanakauhale o Separevaima, a me Hena, a me Iva?
\b
\q1 
\v 14 Loaa ia Hezekia ia mau palapala ma ka lima o na elele, a heluhelu iho la. Pii aku la o Hezekia i ka hale o Iehova, a haalii aku la imua o Iehova.
\q1 
\v 15 Pule aku la o Hezekia ia Iehova, i aku la,
\q1 
\v 16 E Iehova o na kaua, e ke Akua o ka Iseraela, ka mea noho ma na kerubima, o oe no ke Akua, o oe wale no, no na aupuni a pau o ka honua; nau no i hana i ka lani, a me ka honua.
\q1 
\v 17 E haliu mai kou pepeiao, e Iehova, a e hoolohe mai hoi; E wehe oe i kou mau maka, e Iehova, a e naua mai; e hoolohe hoi i na olelo a pau a Sanekariba, na mea ana i hoouka mai ai e hoino i ke Akua ola.
\q1 
\v 18 He oiaio, e Iehova, ua luku aku no na'lii o Asuria i na lahuikanaka a pau, a me ko lakou aina;
\q1 
\v 19 A ua kiola aku no i ko lakou akua iloko o ke ahi, no ka mea, he mau akua ole lakou, he hana na na lima o kanaka, he laau, a he pohaku; nolaila lakou i luku aku ai ia mau mea.
\q1 
\v 20 Ano la, e Iehova ko makou Akua, e hoola mai oe ia makou mai kona lima ae, i ike na aupuni a pau o ka honua, o oe no o Iehova, o oe wale no.
\b
\q1 
\v 21 Alaila, hoouna ae la o Isaia, ke keiki a Amosa io Hezekia la, i ae la, Ke i mai nei o Iehova. ke A kua o ka Iseraela penei, No kau pule ana mai ia'u no Sanekariba, ke alii o Asuria;
\q1 
\v 22 Eia ka olelo a Iehova i olelo mai ai nona;
\q1 Ua hoowahawaha ke kaikamahine puupaa o Ziona ia oe,
\q1 Ua henehene aku ia oe;
\q1 O ke kaikamahine hoi o Ierusalema,
\q1 Ua luliluli oia i kona poo ia oe.
\q1 
\v 23 Owai kou mea i hoowahawaha ai,
\q1 A olelo hoino aku ai no hoi?
\q1 Ua hookiekie oe i kou leo maluna owai,
\q1 A alawa hoi i kou mau maka iluna lilo,
\q1 Maluna no o ka Mea Hoano o ka Iseraela?
\q1 
\v 24 Ua hoowahawaha oe i ka Haku ma kau mau kauwa, i ka i ana mai,
\q1 No ka lehulehu o na kaakaua o'u,
\q1 Ua pii aku no wau i kahi kiekie o na mauna,
\q1 I na aoao hoi o Lebanona;
\q1 E kua aku no wau i kolaila mau laau kedera kiekie,
\q1 A me kolaila mau laau kaa maikai;
\q1 A e komo aku no wau i kona wahi kiekie,
\q1 A i ka welau o kahi nahelehele o kona mahinaai.
\q1 
\v 25 Ua kohi no wau a ua inu hoi i ka wai;
\q1 A i ke kapuwai o ko'u mau wawae, ua hoomaloo aku no wau i na auwai o Aigupita.
\q1 
\v 26 Aole anei oe i lohe kahiko na'u ia i manao,
\q1 A na'u hoi ia i hana i na la mamua?
\q1 A i keia manawa, ua hooko no wau,
\q1 I lilo oe i mea e hookahuli ai i na kulanakauhale paa i ka pa, i puu pohaku.
\q1 
\v 27 Nolaila i uuku ai ka ikaika o ka poe e noho ana,
\q1 Ua makau hoi lakou a pilihua.
\q1 Like no lakou me ka mauu o ke kula,
\q1 Ua like hoi me ka nahele uliuli;
\q1 Me ka mauu maluna o na hale,
\q1 Me ka hua palaoa malili i kona wa e ku ana.
\q1 
\v 28 Aka, ua ike no wau i kou noho ana,
\q1 A me kou puka ana iwaho, a me kou komo ana iloko, a me kou ukiuki ana ia'u.
\q1 
\v 29 No ka mea, o kou ukiuki mai ia'u, a me kou hookiekie,
\q1 Ua pii mai no, a iloko o ko'u mau pepeiao;
\q1 Nolaila, e hookomo no wau i ko'u lou iloko o kou ihu,
\q1 A me ko'u kaulawaha ma kou mau lehelehe.
\q1 A e hoohuli aku no au ia oe ma ke ala au i hele mai ai.
\b
\q1 
\v 30 E lilo no hoi keia i hoailona nou;
\q1 E ai no oukou i keia makahiki i na mea ulu wale,
\q1 A i ka lua o ka makahiki, i na mea i ulu ae mai ia mau mea mai:
\q1 A i ke kolu o ka makahiki, e lulu hua oukou, a e hoiliili hua hoi,
\q1 E kanu no hoi oukou i na pawaina, a e ai iho i kolaila hua.
\q1 
\v 31 A o ke koena i pakele o ka hale o ka Iuda,
\q1 E komo no kona aa ilalo,
\q1 A e hua mai i ka hua maluna.
\q1 
\v 32 No ka mea, mai loko aku o Ierusalema e puka aku ke koena,
\q1 A o ka poe pakele hoi, mai loko aku o ka mauna Ziona:
\q1 Na ka ikaika o Iehova o na kaua e hana i keia,
\q1 
\v 33 Nolaila, ke olelo mai nei o Iehova no ke alii o Asuria,
\q1 Aole ia e komo iloko o keia kulanakauhale,
\q1 Aole ia e pana mai i kekahi pua malaila,
\q1 Aole hoi e hoike i na palekaua imua ona,
\q1 Aole hoi e hana i puukaua ma kona alo.
\q1 
\v 34 Ma ke ala ana i hele mai ai, malaila no ia e hoi aku,
\q1 Aole ia e komo iloko o keia kulanakauhale, wahi a Iehova.
\q1 
\v 35 Na'u no e malama i keia kulanakauhale, e hoola aku no'u iho,
\q1 A no ka'u kauwa, no Davida.
\b
\q1 
\v 36 Hele ae la ka anela o Iehova, a laku aku la maloko o kahi hoomoana o ko Asuria, hookahi haneri me kanawalu kumamalima tausani. A ala ae la lakou i kakahiaka nui, aia hoi! he poe kupapau make lakou a pau.
\b
\q1 
\v 37 Alaila, hele aku la o Sanekariba, ke alii o Asura, a haalele ae la ia wahi, a hoi aku la, a noho iho la ma Nineva.
\q1 
\v 38 A i kona hoomana ana maloko o ka hale o Niseroka, o kona akua, alaila, pepehi iho la kana mau keikikane, o Aderameleka a me Sarezera ia ia i ka pahikaua; a pakele aku la laua maloko o ka aina o Ararata, a noho alii iho la kana keiki, o Esarehadona ma kona wahi.
\c 38
\b
\q1 
\v 1 I A mau la, he mai make ko Hezekia; a hele mai la o Isaia, ke kaula, ke keiki a Amosa io na la, i mai la ia ia, Ke i mai nei o Iehova penei, E kauoha oe i ko kou hale, no ka mea, e make ana oe, aole oe e ola.
\q1 
\v 2 Alaila, huli ae la o Hezekia i kona maka ma ka paia, a pule aku la ia Iehova,
\q1 
\v 3 I aku la ia, Ke noi aku nei au ia oe, e Iehova, ano la e hoomanao oe i ko'u hele ana imua ou ma ka oiaio, me ka naau pono, a ua hana i ka maikai ma kou alo. A uwe iho la o Hezekia, he uwe nui loa.
\b
\q1 
\v 4 Alaila, hiki mai ka olelo a Iehova io lsaia la, i mai la,
\q1 
\v 5 O hele, e olelo aku ia Hezekia, Ke i mai nei o Iehova, ke Akua o Davida, kou kupuna, penei, Ua lohe au i kau pule, a ua ike no wau i kou waimaka; aia hoi, e hooloihi aku au i kou mau la, i umikumamalima makahiki.
\q1 
\v 6 A e hoopakele no wau ia oe, a me keia kulanakauhale mai ka lima aku o ke alii o Asuria, a na'u no e malama i keia kulanakauhale.
\q1 
\v 7 Eia hoi ka hoailona nou, mai Iehova mai, e hana io mai no o Iehova i ka mea ana i olelo mai ai;
\q1 
\v 8 Aia hoi, e hoihoi ihope no au i ke aka o na degere ana i iho ai ma ka mea ana hora o Ahaza, he umi degere ka hoi hope ana. A hoi hope io no ka la i umi degere, o na degere hoi ana i iho ai ilalo.
\b
\q1 
\v 9 Ke mele a Hezekia ke alii o ka Iuda, mahope iho o kona mai ana, a ua ola hoi i kona mai.
\q1 
\v 10 Olelo iho la au, E komo ana au i na puka o ka malumake,
\q1 Mawaena konu o ko'u mau la;
\q1 Ua hooneleia mai au i ke koena o ko'u mau makahiki.
\q1 
\v 11 I iho la au, aole au e ike aku ia Iehova,
\q1 Ia Iehova hoi, ma ka aina o ka poe e ola ana;
\q1 Aole au e ike hou i ke kanaka mawaena o ka poe e noho la ma ka malumake.
\q1 
\v 12 Ua laweia ko'u wahi noho,
\q1 Ua kaikaiia'ku la, mai o'u aku nei, e like me ka halelewa o ke kahuhipa,
\q1 Ua hooki au i ko'u ola ana, e like me ka mea ulana lole,
\q1 Ua oki mai oia ia'u mai ka omau ana;
\q1 Mai ke ao a po, e hooki mai ana oe ia'u.
\q1 
\v 13 Hoomaha ino la au a kakahiaka,
\q1 E like me ka liona, pela no oia i uhaki ai i ko'u mau iwi a pau;
\q1 Mai ke ao a po, e hooki mai ana no oe ia'u.
\q1 
\v 14 E like me ka manu u, a me ka manu ioio,
\q1 Pela no wau i ioio ai.
\q1 Kaniuhu no wau e like me ka manu nunu;
\q1 Maule hoi ko'u mau maka i ka nana ana iluna;
\q1 E ka Haku, ua pilikia au, e kokua mai oe ia'u.
\b
\q1 
\v 15 Heaha ka'u e olelo aku ai?
\q1 No ka mea, ua olelo mai oia ia'u, a ua hana io mai no oia:
\q1 E hele malie no wau i ko'u mau makahiki a pau,
\q1 No ke kaumaha loa o kuu uhane.
\q1 
\v 16 E ka Haku, no keia mau mea i ola'i na kanaka,
\q1 Maloko o ka popilikia a pau, ua ola no kuu uhane;
\q1 Ua hoopau oe i ko'u mai, ua hoola mai oe ia'u
\q1 
\v 17 Aia hoi, ua hoololi mai oia i ko'u kaumaha loa i oluolu,
\q1 Aloha mai no oe, a hoopakele mai ia'u, mai ka lua mai o ka make;
\q1 No ka mea, ua kiola aku oe i ko'u hewa a pau mahope o kou kua.
\q1 
\v 18 Aole hiki i ko ka po ke hoomaikai aku ia oe,
\q1 Aole hoi e hoolea aku ka poe make ia oe;
\q1 O ka poe iho ilalo i ka lua,
\q1 Aole hiki ia lakou ke manaolana.
\q1 
\v 19 O ka mea ola, ka mea ola,
\q1 Nana no e hoomaikai aku ia oe, me au nei i keia la;
\q1 E hoike no ka makua i na keiki i kou oiaio.
\q1 
\v 20 Malaila no o Iehova, e hoola mai ai ia'u,
\q1 Nolaila kakou e hookanikani ai i ko'u mau viola,
\q1 I na la a pau o ko kakou ola ana, maloko o ka hale o Iehova.
\b
\q1 
\v 21 No ka mea, ua olelo no o Isaia, e lawe lakou i pai fiku maloo, a e kau maluna o ka eha, a e ola no ia.
\q1 
\v 22 Ua ninau no hoi o Hezekia, Heaha ka hoailona e maopopo ai ko'u pii ana i ka hale o Iehova?
\c 39
\b
\q1 
\v 1 I A manawa, hoouka mai la o Merodaka-Baladana, ke keiki a Baladana, ke alii o Babulona, i mau palapala, a i makana hoi, na Hezekia, no ka mea, ua lohe oia i kona mai ana, a ua ola.
\q1 
\v 2 Olioli iho la o Hezekia ia lakou, a hoike aku la ia lakou i ka hale o kona waiwai, i ke kala, a me ke gula, a me na mea ala, a me ka mea hamo maikai, a me ka hale a pau o kona mea kaua, a me na mea a pau i loaa maloko o kona waiwai: aohe hoi mea maloko o kona hale, aole hoi ma kona aupuni a pau a Hezekia i hoike ole ai ia lakou.
\b
\q1 
\v 3 Alaila, hele mai la o Isaia, ke kaula i ke alii, ia Hezekia, i mai la ia ia, Heaha ka keia poe kanaka i olelo mai ai? Maihea mai hoi lakou i hele mai ai iou la? I aku la o Hezekia, Mai ka aina mamao aku lakou i hele mai ai io'u nei, mai Babulona mai hoi.
\q1 
\v 4 Ninau mai la no hoi ia, Heaha ka lakou i ike ai iloko o kou hale? I aku la o Hezekia, O na mea a pau iloko o ko'u hale, ua ike no lakou. Aohe mea iloko o ko'u waiwai i hoike ole ia ia lakou e au.
\q1 
\v 5 Alaila, i mai la o Isaia ia Hezekia, E hoolohe mai oe i ka olelo a Iehova o na kaua:
\q1 
\v 6 Aia hoi, e hiki mai ana na la e laweia'ku ai i Babulona na mea a pau iloko o kou hale, a me na mea a kou mau kupuna i hoahu ai, a hiki mai i keia la; aole e koe kekahi mea, wahi a Iehova.
\q1 
\v 7 A e lawe aku no lakou i kekahi o na keiki au, na mea i puka mai loko mai ou, na mea hoi au e hoohanau ai, a e lilo lakou i mea poaia ma ka halealii o ke alii o Babulona.
\q1 
\v 8 I aku la o Hezekia ia Isaia, Maikai no ka olelo a Iehova, au e olelo mai nei. I aku la hoi ia, E oia mau ana no ke kuapapanui a me ka pono i ko'u mau la.
\c 40
\b
\q1 
\v 1 E HOOMAHA aku, e hoomaha aku oukou i ko'u poe kanaka, Wahi a ke Akua o oukou.
\q1 
\v 2 E olelo hoomaha aku i ko Ierusalema, E kahea aku hoi ia ia, ua pau kona kaua ana, Ua kalaia hoi kona hala; No ka mea, ma ka lima o Iehova, Ua loaa papalua ia ia no na hewa ona a pau.
\b
\q1 
\v 3 Ka leo o ka mea e kala ana, ma ka waonahele, E hoomakaukau oukou i alanui no Iehova, E hoopololei hoi ma ka waoakua, I kuamoo no ko kakou Akua.
\q1 
\v 4 E hoopihaia'na na awawa a pau, A e hoohaahaaia'na na mauna a pau, a me na puu; E lilo no ka mea kekee i pololei, A me kahi puupuu i laumania.
\q1 
\v 5 E hoikeia mai no ka nani o Iehova, A e ike pu aku no na kanaka a pau; No ka mea, na ka waha o Iehova i olelo mai.
\q1 
\v 6 I mai la ka leo, E kala aku. I aku la ia, Heaha ka'u o kala'i? He mauu no na kanaka a pau, Ua like hoi kona nani a pau me ka pua o ke kula;
\q1 
\v 7 Mimino ka mauu, a mae wale ka pua, Ke pa mai ka makani o Iehova maluna ona; He oiaio no, he mauu keia poe kanaka.
\q1 
\v 8 Mimino ka mauu, a mae wale ka pua; Aka, o ka olelo a ko kakou Akua, e kupaa mau loa no ia.
\b
\q1 
\v 9 E ka mea hai i ka olelo maikai no Ziona, E pii aku oe iluna o ka mauna kiekie; E ka mea hai i ka olelo maikai no Ierusalema, E hookiekie oe i kou leo me ka ikaika; E hookiekie hoi, mai makau; E olelo ae i na kulanakauhale o ka Iuda, Aia hoi ko oukou Akua!
\q1 
\v 10 Aia hoi, e hele mai ana ka Haku, o Iehova me ka ikaika, Na kona lima no e malama ia; Aia hoi, me ia pu no kana uku mai, A o kana ukuhuna hoi ma kona alo.
\q1 
\v 11 E hanai no oia i kana ohana me he kahuhipa la; E hoiliili no hoi i na keikihipa i kona lima, A hiipoi hoi ia lakou ma kona poli, A alakai i ka poe hanai waiu.
\b
\q1 
\v 12 Owai ka mea i ana i na wai maloko o ka poho o kona lima? A ana aku hoi i na lani ma ke kikoo, A ana no hoi i ka lepo o ka honua iloko o ka mea ana, A kaupaona i na kuahiwi ma na mea kaupaona, A me na mauna hoi maloko o na paonakaulike?
\q1 
\v 13 Owai ka mea i alakai i ka Uhane o Iehova, A noho i kakaolelo nona, a ao aku ia ia?
\q1 
\v 14 Me wai la oia i kukakuka pu ai? Nawai hoi i ao aku ia ia, A kuhikuhi hoi ia ia i ke ia ala o ka pono, A hoike aku ia ia i ke ala o ka naauao?
\q1 
\v 15 Aia hoi, ua like na lahuikanaka, me ke kulu hookahi o ka bakeke, A ua manaoia hoi o like me ka huna lepo uuku maloko o na mea kaulike; Kaikai oia i na aina me he mea uuku la.
\q1 
\v 16 Aole i nui o Lebanona i mea puhi, Aole hoi i nui kolaila holoholona, i mea mohaikuni.
\q1 
\v 17 Me he mea ole la na lahuikanaka a pau imua ona, A ua manaoia lakou e ia ua uuku iho i ka ole, He mea lapuwale loa hoi.
\b
\q1 
\v 18 Me wai oukou e hoohalike ai i ke Akua? Heaha ka mea like, e hoohalike ai oukou me ia?
\q1 
\v 19 O ka mea hana, hoohehee no oia i akuakii, A o ka mea hana gula, hohola ae la oia i ke gula maluna o ia mea, A hana hoi i na kaula kala.
\q1 
\v 20 A o ka mea loaa ole ka mohai no ka hune, Wae no oia i wahi laau popo ole; A imi aku la i kahuna akamai i ka hana, Nana e hoomakaukau i akuakii kalaiia naueue ole.
\b
\q1 
\v 21 Aole anei oukou i ike, aole hoi i lohe? Aole anei i haiia mai ia oukou mai kinohi mai? Aole anei oukou i hoomaopopo, mai ka hookumu ana o ka honua?
\q1 
\v 22 Oia no ke noho ma ka poai o ka honua, A ua like hoi kolaila poe e noho ana me na uhini; Nana no e hoopalahalaha aku na lani me he paku la, A hohola no hoi lakou me he hale lole la, kahi e noho ai.
\q1 
\v 23 Oia ke hoolilo i na'lii i mea ole, A me na lunakanawai o ka honua, me he mea lapuwale la.
\q1 
\v 24 He oiaio, aole lakou e kanuia, Ho oiaio, aole lakou e luluia, He oiaio, aole e paa ka lakou kumu maloko o ka honua; A e puhi mai Oia maluna o lakou, a e mae wale lakou, A e lawe no ka puahiohio ia lakou me he opala la.
\q1 
\v 25 Me wai la hoi oukou e hoohalike ai ia'u? A e like au me wai? wahi a ka Mea Hemolele.
\q1 
\v 26 E alawa ae i ko oukou mau maka iluna, E nana hoi i ka Mea nana i hana i kela mau mea, Alakai aku no oia i ko lakou lehulehu a pau ma ka helu ana. Hea aku no oia ia lakou a pau ma ka iuoa, No ka nui loa o kona mana, a me ka mana loa o kona ikaika; Aohe mea o lakou i nalowale.
\b
\q1 
\v 27 No ke aha la oe e olelo ai, o Iakoba, A kamailio iho, e ka Iseraela, Ua hunaia ko'u ala, mai o Iehova aku, Ua hoaloia ko'u hoaponoia mai ko'u Akua aku?
\b
\q1 
\v 28 Aole anei oe i ike, aole anei oe i lohe? O ke Akua mau loa o Iehova, O ka mea nana i hana i na kukulu o ka honua; Aole ia e maule, aole hoi e luhi; Aohe mea e hiki ke hoomaopopo i kona ike.
\q1 
\v 29 Nana no i haawi i ka ikaika i ka mea i maule; A o ka mea ikaika ole, hoomahuahua no ia i ka ikaika.
\q1 
\v 30 E maule auanei ka poe ui, a e maloeloe hoi, E kulanalana loa no na kanaka hou:
\q1 
\v 31 Aka, o ka poe hilinai aku ia Iehova, e ulu hou no ko lakou ikaika; E pii eheu aku no lakou iluna, e liko me na aito; E holo no lakou, aole hoi e maloeloe, E hele mua no lakou, aole hoi e maule.
\c 41
\b
\q1 
\v 1 E NOHO ekemu ole oukou, e na aina, imua o'u, E hoomahua aku na kanaka i ka ikaika: E hookokoke mai lakou, alaila e olelo mai lakou; E hookokoke pu kakou i ka hookolokolo ana.
\q1 
\v 2 Na wai i hoala mai i ka mea pono, mai ka hikina mai, A kauoha hoi ia ia e hele ma kona wawae? A haawi ae la ia i na lahuikanaka imua ona, A hoonoho ia ia maluna o na'lii? A haawi hoi ia lakou e like me ka lepo imua o kana pahikana, E like hoi me ka opala lele imua o kona kakaka?
\q1 
\v 3 Alualu oia ia lakou, a maluhia hoi kona hele ana; Ma ke ala hoi i hahi ole ia mamua e kona mau wawae.
\q1 
\v 4 Nawai ia i hoomakaukau, a hana hoi, Me ka hea ae i na hanauna kanaka, mai kinohi mai? Owau no o Iehova, o ka mea mua, A o ka mea hope hoi, owau no ia.
\b
\q1 
\v 5 Ike mai la na aina, a makau iho la, Weliweli no na kukulu o ka honua, Hookokoke mai lakou, a hele mai la.
\q1 
\v 6 Kokua no kela mea keia mea i kona hoa, A olelo ae la i kona hoahanau, E ikaika oe.
\q1 
\v 7 Pela i hooikaika'i ke kahuna kalai i ka mea hana gula, A me ka mea anaanai me ka hamare i ka mea kuihao ma ke kua, I ae la, Ua makaukau ia no ke kapili ana; A hoopaa no oia ia mea i ke kui, i ole ia e naueue.
\q1 
\v 8 Aka, o oe, e Iseraela, ka'u kauwa, O Iakoba, ka mea a'u i wae ai, Ka pua a Aberahama, ko'u hoaaloha,
\q1 
\v 9 Ka mea a'u i lalau aku ai, mai na kihi mai o ka honua nei, A hea aku no ia oe, mai kona mau kukulu mai, A i aku no hoi ia oe, O oe no ka'u kauwa, Ua wae aku no wau ia oe, aole au i haalele aku ia oe.
\b
\q1 
\v 10 Mai makau oe, no ka mea, owau pu no me oe; Mai weliweli hoi, no ka mea, owau no kou Akua. Na'u no i hooikaika aku ia oe, A na'u hoi oe i kokua aku; Ua hookupaa aku au ia oe i ka lima akau o ko'u pono.
\q1 
\v 11 Aia hoi e hilahila auanei, a e hoopalaimaka hoi ka poe a pau i inaina aku ia oe; E like auanei lakou me he mea ole la, A e make no hoi ka poe kanaka e hakaka me oe.
\q1 
\v 12 E imi no oe ia lakou, aole loaa lakou ia oe, O na kanaka hoi e hakaka me oe; E like ana lakou me ka mea ole, me he mea ole loa hoi, O na kanaka hoi e kaua aku ia oe.
\q1 
\v 13 No ka mea, owau o Iehova, o kou Akua, ka mea i hoopaa i kou lima akau, Ka mea olelo aku ia oe, Mai makau; owau no kou mea nana e kokua.
\q1 
\v 14 Mai makau, e ka enuhe, e Iakoba e, O oukou no hoi, e na kanaka o ka Iseraela; Na'u no oe e kokua aku, wahi a Iehova, kou Hoolapanai, Ka Mea Hemolele hoi o ka Iseraela.
\q1 
\v 15 Aia hoi, e hana no wau ia oe i mea kaapalaoa hou oioi, mea niho; A e hookaa no oe maluna o na kuahiwi, a e kui hoi ia lakou a wali, A e hoolilo no oe i na puu, i mea like me ka opala,
\q1 
\v 16 E lulu ana no oe ia lakou, a na ka makani lakou e lawe aku, A na ka puahiohio e hoopuehu aku ia lakou; Aka, e olioli no oe ia Iehova, A e hauoli hoi i ka Mea Hemolele o ka Iseraela.
\b
\q1 
\v 17 Imi ka poe hune, a me ka poe nele, i ka wai, a loaa ole, Ua paapaa ko lakou alelo i ka makewai, Alaila, e hoolohe au, o Iehova, i ka lakou, Owau, ke Akua o ka Iseraela, aole au e haalele ia lakou.
\q1 
\v 18 E wahi au i muliwai ma na puu, I wai puna hoi maloko o na awawa; E hoolilo au i ka waonahele i kiowai, A me ka aina maloo, i wahi e huai mai ai na wai.
\q1 
\v 19 Ma ka waonahele, e haawi no au i ka laau kedera, I ka laau sitima hoi, a me ka hadasa, a me ka oliva; A na'u no e kanu, ma ka waoakua, i laau kaa, I tidara no hoi, a me ke teasura:
\q1 
\v 20 I ike lakou, a hoomaopopo hoi, A noonoo, me ka ike lea pu, Na ka lima o Iehova i hana i keia, Na ka Mea Hemolele o ka Iseraela ia i hoopaa.
\b
\q1 
\v 21 E hoopii mai oukou i ko oukou mea hookolokolo, wahi a Iehova; E hoike mai i ko oukou mea e akaka ai, wahi a ke Alii o ka Iakoba.
\q1 
\v 22 E hookokoke mai lakou, a e hoike mai hoi ia kakou i na mea e hiki mai ana; I na mea kahiko hoi, e hai mai lakou ia mau mea, I noonoo kakou ia mau mea, a ike hoi i ko lakou hope; E hai mai hoi ia kakou i na mea e hiki mai ana.
\q1 
\v 23 A e hoomaopopo mai hoi i na mea o keia hope e hiki mai ana, Alaila e ike no makou, he mau akua no oukou: Oia e hana hoi i ka maikai, a i ka hewa paha, Alaila, makou e weliweli, a e ike pu no hoi.
\q1 
\v 24 Aia hoi, no ka ole mai oukou, A me ka oukou hana hoi, noloko mai ia o ka ole; O ka mea makemake aku ia oukou he mea hoopailua ia.
\b
\q1 
\v 25 Ua hoala aku au i kekahi, mai ka akau mai, a e hele io mai no ia; E kahea mai no oia i ko'u inoa, mai kahi e puka mai ai ka la; A e hele mai no oia maluna o na'lii e like me ka lepo, E like hoi me ko ka potera hahi ana i ka lepo kawili.
\q1 
\v 26 Nawai i hoike mai, mai kinohi mai, i ike kakou? I ka wa mamua hoi, i olelo kakou, Ua pololei? Aohe mea nana i hoike, he oiaio, aohe mea nana e hoakaka mai, He oiaio no, aohe mea i lohe i ka oukou mau olelo.
\q1 
\v 27 Na'u ka mea mua e olelo ia Ziona, Aia hoi, e nana aku ia lakou; A na'u hoi e haawi aku ia Ierusalema i ka mea hai i ka olelo maikai.
\q1 
\v 28 Aka, nana aku la au, aohe hoi kanaka, A iwaena hoi o ia poe, aohe kakaolelo, A i ko'u ninau ana ia lakou, aohe mea o lakou i olelo mai.
\q1 
\v 29 Aia hoi, he mea ole lakou a pau, He mea ole hoi ka lakou hana; He makani, he lapuwale hoi ko lakou akuakii i hooheheeia.
\c 42
\b
\q1 
\v 1 A IA hoi ka'u kauwa, ka mea a'u i malama'i, O kuu mea i waeia, a ua olioli ko'u naau ia ia; E haawi aku no au i ko'u Uhane maluna ona; A nana no e hoolaha ae ka pono no na lahuikanaka.
\q1 
\v 2 Aole ia e kahea, aole hoi e hoowalaau aku, Aole hana aku a loheia kona leo ma ke alanui.
\q1 
\v 3 Aole ia e uhai i ka ohe pepe, Aole hoi ia e kinai i ka uiki e pipi ana; A hoolaha aku oia i ka pono oiaio.
\q1 
\v 4 Aole ia e pio, aole hoi ia e uhaiia, A hookumu oia i ka pono ma ka honua nei: A e kakali no na mokupuni i kona kanawai.
\b
\q1 
\v 5 Ke i mai nei ke Akua, o Iehova, penei, Ka mea nana i hana na lani, a hohola ae la ia lakou; Ka mea i hoopalahalaha ae i ka honua, a me kona mau mea ulu; Ka mea haawi i ka hanu no na kanaka maluna ona, A me ke ea hoi i ka poe e hele ana maluna ona:
\q1 
\v 6 Owau, o Iehova, ua hea aku au ia oe i mea e pono ai, A na'u no e hoopaa aku i kou lima, a e malama no hoi au ia oe, A e haawi no wau ia oe i berita no na kanaka, I malamalama hoi no ko na aina e;
\q1 
\v 7 E hookaakaa i na maka o ka poe makapo, E lawe mai hoi i ka poe pio, mailoko mai o kahi paa, A me ka poe e noho ana iloko o ka pouli, mailoko mai o ka halepaahao.
\q1 
\v 8 Owau no Iehova, oia ko'u inoa; Aole au e haawi i ko'u nani ia hai, Aole hoi ko'u hanohano i na kiikalaiia.
\q1 
\v 9 Aia hoi, ua ko na mea i olelo kahiko ia, A ke hai aku nei au i na mea hou: Mamua o ko lakou hiki ana mai, ke hai aku nei au ia mau mea ia oukou.
\b
\q1 
\v 10 E oli aku ia Iehova i ke oli hou, I kona nani hoi mai ka welau mai o ka honua: Ka poe iho ilalo ma ka moana, a me kona mea i piha'i, O na mokupuni, a me ko lakou poe e noho ana.
\q1 
\v 11 E hookiekie no ka waonahele i kona leo, A me na kulanakauhale ona, O na kauhale kahi e noho ai o Kedara; E oli hoi ka poe e noho ana ma Sela, E hooho hoi ka poe ma ka piko o na kuahiwi.
\q1 
\v 12 E haawi aku lakou i ka hanohano no Iehova, E hoolaha hoi i kona nani ma na aina e.
\b
\q1 
\v 13 E puka aku no o Iehova iwaho, me he koa la, E hoa no oia i ka inaina, e like me ke kanaka kaua; E hea ikaika aku no ia, a e hooho hoi; E lanakila no oia maluna o kona poe enemi.
\b
\q1 
\v 14 Ua noho ekemu ole au, mai kahiko loa mai; Ua noho malie au, ua uumi au i ka olelo: Aka, ano, e kahea aku no wau, e like me ka wahine hanau keiki; E luku aku no au, e hoopau pu no hoi.
\q1 
\v 15 E anai aku au i na kuahiwi, a me na puu, A e hoomaloo aku no au i ko lakou launahele a pau; E hoolilo wau i ko lakou muliwai i wahi maloo, A e hoomaloo no hoi au i ko lakou loko.
\q1 
\v 16 A e kai aku no au i ka poe makapo, ma ke ala a lakou i ike ole ai: E alakai no au ia lakou ma na kuamoo a lakou i ike ole ai; E hoolilo au i ka pouli i malamalama imua o lakou, A me na ala kekee i pololei. E hana no wau i keia mau mea no lakou, Aole hoi au e haalele ia lakou.
\b
\q1 
\v 17 E hoopalaimaka, a e hilahila loa hoi ka poe a pau i hilinai i na kiikalaiia, Ka poe i olelo i na kii i hooheheeia, O oukou no ko makou mau akua.
\b
\q1 
\v 18 E hoolohe mai oukou, e na kuli, E nana hoi oukou, e ka poe makapo, i ike oukou.
\q1 
\v 19 Owai ka mea makapo, ke ole ka'u kauwa, A kuli hoi, e like me ko'u elele a'u i hoouna aku ai? Owai ka mea makapo, e like me ka mea haipule, Ka mea makapo hoi, e like me ke kauwa a Iehova?
\q1 
\v 20 Ua ike no oe i na mea he nui, aole nae oe i malama; Ua hakahaka na pepeiao, aole nae oia i lohe.
\q1 
\v 21 Ua lealea no o Iehova no kona pono iho, E hoohanohano no oia i kona kanawai, a e hoonani hoi oia ia mea.
\q1 
\v 22 Aka, ua powaia keia poe kanaka, a ua haoia; Ua hoopaheleia lakou a pau maloko o na lua, Ua hunaia hoi maloko o na halepaahao; Ua lilo lakou i pio, aohe mea nana lakou e hoopakele; He mea i haoia, aohe mea i olelo mai, E hoihoi aku.
\b
\q1 
\v 23 Owai ka mea o oukou e haliu mai i ka pepeiao i keia? A hoolohe, a malama hoi, no ka manawa mahope?
\q1 
\v 24 Nawai i haawi ia Iakoba i pio, A i ka Iseraela hoi no ka poe powa? Aole anei na Iehova, ka mea a kakou i hana ino aku ai? No ka mea, aole lakou i hele i kona mau alanui, Aole lakou i hoolohe i kona kanawai.
\q1 
\v 25 Nolaila ia i ninini aku ai maluna ona, i ka wela o kona inaina, A me ka ikaika o ke kaua; A ua hoa oia ia ia i ke ahi a puni, aole nae ia i ike; Wela no oia i ke ahi, aole i manao i kona naau.
\c 43
\b
\q1 
\v 1 A NO, penei ka olelo ana mai a Iehova, ka mea nana oe i hana, e Iakoba, Ka mea nana oe i hookumu, e Iseraela; Mai makau, no ka mea, ua hoola au ia oe; Ua hea aku au ia oe ma ka inoa; no'u no oe.
\q1 
\v 2 Ia oe e hele mawaena o na wai, owau pu no me oe; A maloko hoi o na muliwai, aole oe e halanaia ia lakou; Ia oe e hele ae maloko o ke ahi, aole oe e wela; Aole hoi e ai aku ka lapalapa ahi ia oe.
\q1 
\v 3 No ka mea, owau no Iehova kou Akua, Ka Mea Hemolele o ka Iseraela, kou mea e ola'i; Ua haawi au ia Aigupita, i panai nou, Ia Aitiopa, a me Seba hoi, i uku panai nou;
\q1 
\v 4 No ka mea, ua makamae oe ma ko'u mau maka, Ua hoomaikaiia hoi oe, a ua aloha aku au ia oe; Nolaila au e panai aku ai i na kanaka nou, A e lilo no na lahuikanaka i panai no kou ola.
\q1 
\v 5 Mai makau oe, no ka mea, owau pu no me oe; Na'u no e lawe mai i kau poe mamo, mai ka hikina mai, A e hoakoakoa no au i kau, mai ke komohana mai.
\q1 
\v 6 E olelo aku no au i ke kukulu akau, E haawi mai; A i ke kukulu hema hoi. Mai aua oe; E kai mai i ka'u mau keiki kane, mai kahi loihi mai, A me ka'u mau kaikamahine, mai na kihi o ka honua;
\q1 
\v 7 O na mea hoi a pau i heaia ma ko'u inoa, A no ko'u nani i hana aku ai au ia lakou; Na'u no i hookumu, na'u hoi i hana.
\b
\q1 
\v 8 E kai mai i ka poe kanaka makapo, he mau maka no nae ko lakou, A me na mea kuli hoi, he mau pepeiao no nae ko lakou.
\q1 
\v 9 E hoakoakoaia mai ko na aina a pau, E hoiliiliia mai hoi na lahuikanaka a pau; Owai ka mea o lakou e hiki ia ia ke hai i keia, A hoiko mai hoi i na mea kahiko? E kai mai lakou i ko lakou poe ike maka, i hoaponoia'i lakou: A o lakou kekahi e hoolohe mai, a olelo, Ua oiaio.
\q1 
\v 10 O oukou no ko'u poe ike maka, wahi a Iehova, O ka'u kauwa hoi ka mea a'u i wae ai, I ike mai oukou, a manaoio mai ia'u; A hoomaopopo hoi, owau no Ia, Mamua o'u, aohe akua i hanaia, Aole hoi auanei mahope o'u.
\q1 
\v 11 Owau, owau no o Iehova, Aole hoi mea hoola e ae, owau wale no.
\q1 
\v 12 Ua olelo aku no au, ua hoola aku hoi, A ua hoikeike aku hoi, i ka wa aole akua malihini iwaena o oukou: O oukou no ko'u poe ike maka, wahi a Iehova, Owau no ke Akua,
\q1 
\v 13 Mamua aku o ka manawa, owau no Ia; Aohe mea hiki ke hoopakele, mai ko'u lima aku; Hana no au, a owai la ka mea hiki ke hooki mai?
\b
\q1 
\v 14 Ke olelo mai nei o Iehova, ke oukou Hoolapanai, Ka Mea Hemolele hoi o ka Iseraela, penei; Ua hoouna aku au i Babulona no oukou, A ua kiola au ilalo i ko lakou poe auhee a pau, A me ko Kaledea, ka poe e olioli ana i na moku.
\q1 
\v 15 Owau no Iehova, ko oukou Mea Hemolele, Ka mea nana i hana ka Iseraela, o ko oukou Alii.
\q1 
\v 16 Penei i olelo mai ai o Iehova, Ka mea nana i hana i alanui ma ke kai, I kuamoo hoi maloko o na wai nui;
\q1 
\v 17 Ka mea i hoopuka mai i ke kaakaua, a me ka lio, I ka poe koa, a me ka mea ikaika; Moe pu no lakou ilalo, aole ala hou, Ua kinaiia lakou, ua pio hoi, e like me ka uiki.
\b
\q1 
\v 18 Mai hoomanao oukou i na mea mamua, Mai manao hoi i na mea kahiko.
\q1 
\v 19 Aia hoi, e hana ana au i mea hou; I keia manawa no ia e puka mai ai; Aole anei oukou e ike mai? He oiaio no, e hana no wau i alanui ma ka waonahele, A i kahawai hoi ma ka waoakua.
\q1 
\v 20 E hoomaikai mai no ia'u ka holoholona o ke kula, O na iliohae a me na keiki iana; No ka mea, ua haawi au i ka wai ma ka waonahele, A me na muliwai ma ka waoakua, I mea e hoohainu ai i ko'u poe kanaka, i ko'u poe hoi i waeia.
\q1 
\v 21 I keia poe kanaka no a'u i hana'i no'u iho; Na lakou no e hai aku i ko'u nani.
\b
\q1 
\v 22 Aka, aole oe i hea mai ia'u, e ka Iakoba, Ua uluhua oe ia'u, e ka Iseraela.
\q1 
\v 23 Aole oe i lawe mai ia'u i ka hipa o kou mau mohaikuni; Aole hoi oe i hoomaikai mai ia'u i kau mau mohai. Aole au i hookaumaha aku ia oe i ka alana, Aole hoi au i hooluhiluhi aku ia oe ma na mea ala.
\q1 
\v 24 Aole oe i kuai i oheala na'u, i ke kala, Aole hoi oe i hoomaona mai ia'u i ke kelekele o kau mau mohai; Aka, ua hookaumaha mai oe ia'u, i kou mau hewa, Ua hooluhiluhi mai oe ia'u i kou mau hala,
\b
\q1 
\v 25 Owau, owau no ka mea nana e holoi i kou mau hewa, no'u iho; Aole hoi au e hoomanao i kou mau hala.
\q1 
\v 26 E hooeueu mai oe i ko'u manao; E hooponopono pu kakou; E hai mai hoi oe, i hoaponoia mai ai oe.
\q1 
\v 27 Hewa no kou makuakane makamua, A ua kipi mai no hoi ia'u kau mau luna.
\q1 
\v 28 A e hoohaumia aku au i na luna hoano, A e haawi aku au i ka Iakoba no ka poino, A me ka Iseraela no ka hoinoia.
\c 44
\b
\q1 
\v 1 E HOOLOHE mai oe ano, e Iakoba, ka'u kauwa, A me ka Iseraela, ka mea a'u i wae ai:
\q1 
\v 2 Penei i olelo mai ai o Iehova, ka mea nana oe i hana, A hana ia oe ma ka opu, ka mea o kokua ana ia oe; Mai makau oe, e Iakoba, ka'u kauwa, A o oe hoi, e Iesuruna, ka mea a'u i wae ai.
\q1 
\v 3 No ka mea, e ninini aku au i ka wai maluna o ku mea i makewai, A me na waikahe maluna o na aina maloo: E ninini aku au i ko'u Uhane maluna o kau pua, A me ko'u hoopomaikai maluna o kau poe mamo.
\q1 
\v 4 A ulu no lakou iwaena o ka mauu, E like me na wilou ma na wai kahe.
\q1 
\v 5 E olelo no kekahi, No Iehova au; A e kapaia kekahi ma ka inoa o Iakoba; A e kakau kekahi ma kona lima, No Iehova au, A hea aka ia ma ka inoa o ka Iseraela.
\b
\q1 
\v 6 Penei o Iehova i olelo mai ai, o ke alii hoi o ka Iseraela, A o kona Hoolapanai, o Iehova o na kaua; Owau no ka mea mua, owau no ka mea hope, Aohe Akua e ae, owau wale no.
\q1 
\v 7 Owai hoi ka mea like me au nei, e kala aku, A hai mua, a hoonohonoho pono no'u, Mai ka wa mai o ko'u hoonoho ana i ka lahuikanaka kahiko? I na mea hoi e kokoke mai ana, a me na mea e hiki mai ana mahope, E hai mai lakou ia mau mea ia lakou.
\q1 
\v 8 Mai makau oukou, mai hopohopo hoi; Aole anei au i hai aku ia oe, mai ia manawa mai, Aole anei au i hooikeike aku? O oukou no ko'u poe hoike. He Akua e anei kekahi, ke kaawale au? Aohe Pohaku, aohe mea a'u i ike ai.
\b
\q1 
\v 9 O ka poe hana i ke kiikalaiia, ua lapuwale lakou a pau, Aole lakou e pomaikai ma ko lakou mea i manao nui ia. O lakou no ko lakou mau hoike iho; Aole lakou i nana, aole hoi i ike, i hilabila lakou,
\q1 
\v 10 Owai ka mea i hana i akua, a hoohehee hoi i kiikalaiia, I ka mea ole hoi?
\q1 
\v 11 Aia hoi, e hilahila auanei kona poe hoa a pau; A o ka poe paahana, no kanaka lakou; E akoakoa mai lakou a pau, e ku hoi iluna, E makau no lakou, a e hoopalaimaka pu.
\b
\q1 
\v 12 Lalau aku no ka amara i ka mea hana, A hana oia maloko o ka lanahu, A hooponopono me na hamare, A hana oia ia mea me ka ikaika o kona lima; Pau kona ikaika no ka pololi, aole ikaika, Aole ia i inu i ka wai, a ua maloeloe.
\q1 
\v 13 Huki ae la ke kamana i ke kaula a hailona iho la i ka alaea; A hana no hoi oia ia mea me na koikahi, A hailona no hoi i ka upa, A hana no hoi oia ia mea, e like me ke kii kanaka, Ma ko ke kanaka nani, i mea e noho mau ai iloko o ka hale.
\q1 
\v 14 Kua no oia ilalo i na laau kedera nona, A lalau no oia i ke tireza, a me ka oka, A lawe iho la nona iho, noloko mai o na laau o ka ululaau; Kanu no oia i ka paina, a na ka ua no e hooulu.
\q1 
\v 15 A lilo no ia no ke kanaka e puhi ai, A lawe no oia ia, a hoomahanahana ia ia iho; Oia, hoa no oia i ke ahi, a pulehu i ka palaoa; Oia, hana no oia i akua, a hoomana aku la! Hana no oia ia mea, i kiikalaiia, a moe iho la imua ona!
\q1 
\v 16 Puhi no oia i kauwahi ma ke ahi, A maluna o kauwahi, ai no oia i ka io, Ohinu no oia i ka mea ohinu, a ua maona hoi; Oia, hoomahanahana no oia ia ia iho, a olelo ae la, Ka! ua mahana au, ua ike au i ke ahi!
\q1 
\v 17 A i ke koena o ia mea, hana no oia i akua, i kona kiikalaiia hoi! A moe iho no imua ona, a hoomana aku la, A pule aku no ia ia la, me ka olelo aku, E hoopakele mai oe ia'u, no ka mea, o oe no ko'u akua.
\b
\q1 
\v 18 Aole lakou i ike, aole hoi i hoomaopopo; Ua hoopili oia i ko lakou mau maka, i ike ole lakou, A me ko lakou mau naau, i hoomaopopo ole lakou.
\q1 
\v 19 Aole ia i noonoo ma kona naau, Aohe hoi ona ike, a me ka naauao e olelo ai, Ua puhi au i kauwahi maloko o ke ahi; Oia no, ua pulehu au i ka palaoa ma na lanahu ona, Ua ohinu au i ka io, a ua ai iho; A e hoolilo anei au i ke koena o ia mea, i mea hoopailua? A e kulou anei au i ka pauku laau?
\q1 
\v 20 Ai no oia i ka lehu; Alakai hewa ka naau walewale ia ia, Aole hiki ia ia ke hoopakele i kona uhane, aole hoi e olelo, Aole anei he wahahee ma ko'u lima akau?
\b
\q1 
\v 21 E hoomanao i keia mau men, e ka Iakoba, a me ka Iseraela, No ka mea, o oe no ka'u kauwa; Na'u no oe i hana, o oe no ka'u kauwa; E ka Iseruela, aole oe e hoopoinaia e au.
\q1 
\v 22 E hoopau no wau i kou hewa e like me ke ao eleele, A me kou hala hoi, me he ohu la; E hoi mai oe ia'u, no ka mea, ua hoolapanai aku au ia oe.
\q1 
\v 23 E oli oukou, e na lani, no ka mea, na Iehova i hana; E hauoli hoi oukou, e na wahi haahaa o ka honua, E hookani i ke oli, e na mauna, E ka ululaau, a me na laau a pau maloko; No ka mea, ua hoolapanai o Iehova i ka Iakoba, Ua hoonani hoi ia ia iho ma o ka Iseraela la.
\b
\q1 
\v 24 Ke i mai nei o Iehova, kou Hoolapanai, Ka mea hoi nana oe i hana ma ka opu, Owau, o Iehova, ka mea nana i hana na mea a pau; Ka mea nana i hohola na lani, owau wale; A hoopalahalaha hoi i ka honua, owau wale no;
\q1 
\v 25 Ka mea hookahuli i na ouli o ka poe wahahee, A hoohilahila hoi i ka poe kilokilo; Ka mea alakai hope i ka poe akamai, A hoolapuwale i ko lakou naauao:
\q1 
\v 26 Ka mea hookupaa i ka olelo a kana kauwa, A hooko hoi i ka manao ao o kona poe elele; Ka mea olelo ia Ierusalema, E noho hou ia oe, A i na kulanakauhale o ka Iuda, E hana hou ia no oukou, A na'u no e hoala hou i kolaila mau wahi i hooneoneoia;
\q1 
\v 27 Ka mea i olelo i ka hohonu, E maloo oe, A e hoomaloo no wau i kou mau muliwai;
\q1 
\v 28 Ka mea olelo no Kuro, Oia ka'u kahuhipa, Nana no e hana i ko'u makemake a pau; Ka mea i olelo ia Ierusalema, e hana hou ia no oe, A i ka luakini hoi, E hookumuia hoi oe.
\c 45
\b
\q1 
\v 1 PENEI o Iehova i olelo mai ai no kona mea i poniia, No Kuro, nona ka lima akau a'u i hooikaika ai, E hoopio i na lahuikanaka imua ona; A e kala no hoi au i ko na puhaka o na'lii, I hamama na puka imua ona, Aole hoi e paniia na pukapa.
\q1 
\v 2 E hele no wau imua ou, a e hoolaumania i na wahi apuupuu, E wawahi no au i na pani puka keleawe, A e uhaki ia'u na kaola hao.
\q1 
\v 3 E haawi aku no au ia oe i ka waiwai o ka pouli, A me ka ukana i hunaia ma kahi nalowale, I ike ai oe, owau no Iehova, ka mea i hea aku ia oe ma ka inoa, Ke Akua hoi o ka Iseraela.
\q1 
\v 4 No ka'u kauwa, no Iakoba, No ka Iseraela hoi, ka mea a'u i wae ai, Ua hea aku no au ia oe; Ma kou inoa ua hea aku au ia oe, Aole nae oe i ike mai ia'u.
\b
\q1 
\v 5 Owau no Iehova, aohe mea e ae, Aohe Akua e ae, ke kaawale au; Na'u no e kaei aku ia oe, aole nae oe i ike mai ia'u;
\q1 
\v 6 I ike lakou, mai ka puka ana a ka la mai, A mai ke komohana mai hoi, Aohe mea e ae, ke kaawale au; Owau no o Iehova, aohe mea e ae.
\q1 
\v 7 Ka mea nana i hana ka malamalama, A nana hoi i hana ka pouli, Nana i hana ka pomaikai, Nana hoi i hana ka poino, Owau no Iehova, ka mea nana e hana keia mau mea a pau.
\b
\q1 
\v 8 E hoonakulukulu oukou, e na lani, mai luna mai, E hanini hoi na aouli i ka pono; E hamama hoi ka honua, a e hua mai i ke ola, E ulu pu mai no me ka pono; Na'u, na Iehova ia i hana.
\b
\q1 
\v 9 Auwe ke kanaka paio aku i kona mea nana ia i hana? Na mea lepo me na mea lepo o ka honua! E olelo anei ka lepokiaha, i ka mea nana ia e hooponopono, Heaha kau e hana nei? A o ka mea au i hana'i, Aole ona lima?
\q1 
\v 10 Auwe ka mea olelo i ka makuakane, Heaha kau e hoohanau ai? A i ka makuwahine hoi, Ua hanau oe i ke aha?
\b
\q1 
\v 11 Ke olelo mai nei o Iehova, ka Mea Hemolele o ka Iseraela, penei, O ka Mea hoi nana ia i hana, E ninau mai oukou ia'u i na mea e hiki mai ana no ka'u mau keiki, A e kauoha mai oukou ia'u ma ka hana a kuu mau lima.
\q1 
\v 12 Na'u no i hana ka honua nei, A hana no hoi au i na kanaka maluna iho; Na kuu mau lima no i hohola aku i na lani, A na'u hoi i kauoha aku i ko lakou lehulehu a pau.
\q1 
\v 13 Ua hoala no au ia ia, no ka pono, Na'u no e hoopololei i kona mau aoao, Nana no e hana i ko'u kulanakauhale, A nana no e hookuu aku i ko'u poe pio; Aole no ka uku, a me ka waiwai kipe, Wahi a Iehova o na kaua.
\b
\q1 
\v 14 Ke i mai nei o Iehova penei, E hele mai no ianei, iou la, Ka waiwai o Aigupita, a me ka mea kuai o Aitiopa, A me ko Seba, ka poe kanaka nunui, a e lilo lakou nou. E hahai no lakou ia oe; me ka paa ana i na kaula hao lakou e hele mai ai, A e moe no lakou ilalo imua ou, E nonoi aku no lakou ia oe, me ka olelo iho, He oiaio no, me oe no ke Akua, aohe Akua e ae.
\q1 
\v 15 He oiaio no, o ke Akua no oe nana i huna ia oe iho, E ke Akua o ka Iseraela, ka mea e ola'i.
\q1 
\v 16 Ua hilahila, a ua hoopalaimaka lakou a pau; Holo pu no iloko o ka hilahila, ka poe hana akuakii.
\q1 
\v 17 E hoolaia no o ka Iseraela maloko o Iehova, me ke ola mau loa; Aole oukou e hilahila, aole hoi e hoopalaimaka, ia ao aku, ia ao aku.
\b
\q1 
\v 18 No ka mea, penei ka olelo ana mai a Iehova, Ka mea nana i hana na lani; Oia ke Akua, ka mea nana i hana ka honua, a kukulu hoi, Ka mea nana ia i hoopaa, aole hoi ia i hana makehewa ia mea, Hana no oia ia i wahi e nohoia'i; Owau no Iehova, aohe mea e ae,
\q1 
\v 19 Aole au i olelo ma kahi malu, ma kahi pouli o ka honua; Aole au i olelo aku i na pua a Iakoba, E imi makehewa oukou ia'u. Owau o Iehova, ka mea e olelo ana ma ka pono, Ka mea e hai. aku ana i na mea pololei.
\b
\q1 
\v 20 E hoakoakoa oukou, a hele mai, E houluulu pu oukou, e ka poe i pakele o na aina. He poe ike ole ka poe kukulu i ka laau o ko lakou akua kalaiia, A pule aku i ke akua hiki ole ke hoola.
\q1 
\v 21 E hai aku, e lawe mai hoi ia lakou; Oia, e kukakuka pa lakou. Nawai i hai i keia, mai kahiko mai, A hoikeike hoi ia, mai kela wa mai? Aole anei owau. o Iehova? Aole hoi he Akua e ae, ke Kaawale au; O ke Akua pono, ka mea e ola'i, aohe mea e ae.
\b
\q1 
\v 22 E haliu mai oukou ia'u a e hoolaia no oukou, E na kukulu o ka honua; No ka mea, owau no ke Akua, aohe mea e ae.
\q1 
\v 23 Ua hoohiki au ia'u iho, Ua puka aku hoi ka olelo, mai ko'u waha aku ma ka pono, Aole ia i hoi hou, no ka mea, la'u no e kukuli ai na kuli a pau, a e hoohiki no hoi na elelo a pau.
\q1 
\v 24 He oiaio, e olelo mai ia'u, maloko o Iehova na mea pono, a me ka ikaika, Ia ia no lakou e hele mai ai; A e hilahila auanei ka poe a pau i inaina aku ia ia.
\q1 
\v 25 Maloko o Iehova e hoaponoia'i na pua a pau o ka Iseraela, A malaila hoi e hoonani ai.
\c 46
\b
\q1 
\v 1 KE kukuli nei o Bela, ke kulou nei o Nebo, Aia hoi ko lakou akuakii maluna o na holoholona a me na mea laka; Ua kaumaha loa ko oukou mea lawe, He ukana kaumaha i ka mea i maloeloe.
\q1 
\v 2 Kulou no lakou, a kukuli pu no hoi ilalo; Aole hiki ia lakou ke hookuu i ka ukana, Ua hele no lakou iloko o ke pio ana.
\b
\q1 
\v 3 E hoolohe mai oukou ia'u, e ko ka hale o Iakoba, A me ke koena a pau o ko ka hale o ka Iseraela, Ka poe i laweia e au mai ka opu mai, A kaikaiia hoi mai ka hanau ana mai.
\q1 
\v 4 A hiki i kou wa elemakule, owau no ia, A i ka wa e poohina'i, na'u no oe e lawe. Ua hana no owau, a na'a hoi e halihali; Na'u no e lawe, a na'u hoi e hoopakele.
\b
\q1 
\v 5 Me wai oukou e hoohalike ai ia'u, a me ka hoopili ia'u? Me wai hoi maua e like ai?
\q1 
\v 6 Ninini aku lakou i ke gula mawaho o ka eke, A kaupaona hoi i ke kala ma ka mea kaulike, A hoolimalima hoi i ka mea hana gula, A hana iho la oia ia mea, i akuakii; Kulou no lakou, a moe hoomana aku la,
\q1 
\v 7 Kaikai no lakou ia ia ma ka poohiwi, Lawe lakou ia ia, a hooku ia ia ma kona wahi, a ku no ia; Aole ia e neenee, mai kona wahi ae: Oia, kahea aku kekahi ia ia, aole nae ia e ekemu mai, Aole hoi e hoopakele ia ia i kona popilikia.
\b
\q1 
\v 8 E hoomanao oukou i keia, a e hookanaka hoi; E hooeueu i ka manao, e ka poe hana hewa.
\q1 
\v 9 E hoomanao i na mea kahiko o kela wa mamua; No ka mea, owau no ke Akua, aohe mea e ae, Owau no ke Akua, aohe mea like me au,
\q1 
\v 10 E hai ana i ka hope, mai kinohi mai, E hai ana hoi, mai kahiko loa mai, i na mea i hana ole ia, Me ka olelo iho, E kupaa ana ko'u manao, A e hana no hoi au i ko'u makemake a pau.
\q1 
\v 11 Hea aku no wau i ka manu huhu, mai ka hikina mai, I ke kanaka hoi a'u i manao ai, mai ka aina mamao aku; Oia, ua olelo no wau, a na'u hoi ia e hana; Ua manao no wau, a e hana io no hoi au ia.
\b
\q1 
\v 12 E hoolohe mai oukou ia'u, e na mea i paakiki ka naau, Ka poe mamao loa aku i ka pono.
\q1 
\v 13 Ke lawe aku nei au i ko'u pono a kokoke, Aole ia e mamao aku, aole hoi e hookaulua iho ko'u hoola: E haawi aku no au i ke ola ma Ziona, me ka Iseraela, ko'u mea e nani ai.
\c 47
\b
\q1 
\v 1 E IHO ilalo, a e noho ma ka lepo, e ke kaikamahine puupaa o Babulona, E noho ma ka honua, aoho noho alii, e ke kaikamahine o Kaledea; No ka mea, aole oe e hea hou ia he puloku, a palupalu.
\q1 
\v 2 E lawe i ka mea kaapalaoa, a e kaa hoi i ka palaoa, E wehe i kou pale maka, e waiho aku ka huakapu, E wehe i ka uha, a e hele ae i kela aoao o na muliwai.
\q1 
\v 3 E weheia auanei kou hena, a e ikeia hoi kou wahi hilahila; E hoopai io no wau, aole e pakele kekahi kanaka ia'u.
\q1 
\v 4 O ko kakou Hoolapanai, o Iehova o na kaua kona inoa, O ka Mea Hemolele hoi o ka Iseraela.
\q1 
\v 5 E noho ekemu ole oe, a e hele aku hoi, a iloko o ka pouli, E ke kaikamahine o ko Kaledea; No ka mea, aole oe e kapa hou ia. He haku wahine o na aupuni.
\b
\q1 
\v 6 Ukiuki aku la au i ko'u poe kanaka, Ua hoohaumia au i ko'u poe hooilina, Ua haawi hoi au ia lakou iloko o kou lima; Aole oe i hoike aku i ke aloha ia lakou, Ua hookaumaha oe i kau auamo maluna o ka mea elemakule.
\b
\q1 
\v 7 Ua olelo no oe, E mau loa no ko'u noho haku wahine ana; Aole hoi oe i manao i keia mau mea ma kou naau, Aole i noonoo i kona hope.
\b
\q1 
\v 8 Nolaila, e hoolohe mai oe i keia, e ka mea olioli, Ka mea e noho makau ole ana; Ka mea olelo ma kou naau, Owau ana no, aohe mea e ae, ke kaawale au; Aole au e noho wahine kanemake ana, Aole hoi au e ike i ka lilo keiki ana,
\q1 
\v 9 Aka, e kau hoohikilele mai no keia mau mea elua maluna ou, ma ka la hookahi, O ka lilo keiki ana, a me ka wahinekanemake ana: E kau loa mai no ia mau mea maluna ou ma ka oiaio maoli, No ka nui o kou kilokilo ana, a no ka nui loa o kou hoopiopio ana.
\b
\q1 
\v 10 Ua hilinai no hoi oe ma kou hewa; A ua olelo no oe, Aohe mea ike mai ia'u. O kou akamai, a me kou ike, ua hookahuli ia ia oe; A ua olelo no oe maloko o kou naau, Owau ana no, aohe mea e ae, ke kaawale au.
\b
\q1 
\v 11 Nolaila, e hiki mai no ka hewa maluna ou, Aole oe e ike i kahi e hiki mai ai; E haule mai no ka popilikia maluna ou, Aole hiki ia oe ke kala aku ia. E hele hoohikilele mai no ka make maluna ou, Aole oe e ike aku.
\b
\q1 
\v 12 E ku mai hoi oe me kou hoopiopio ana, A me kou kilokilo ana, he nui loa, Me ka mea au i hooikaika'i, mai kou wa opiopio mai; Ina paha e hiki ia oe ke hoopomaikaiia, Ina paha e ku lanakila oe.
\q1 
\v 13 Ua luhi no oe i ka nui loa o kou kukakuka ana: E ku mai ano na kilolani, a me na kilokilohoku, a me na mea haiouli ma ka malama, A e hoola hoi ia oe, mai ka mea e hiki mai ana maluna ou.
\q1 
\v 14 Aia hoi, e like auanei lakou me ka opala, Na ke ahi no lakou e hoopau; Aole lakou e hoopakele ia lakou iho, mai ka mana o ka lapalapa ahi; Aole e koe ana ka lanahu ahi i mea e mahaua'i, Aole ahi e koe, i noho kekahi imua o ia.
\q1 
\v 15 Pela auanei ia oe, ka poe au i hana pu ai, Kou poe kalepa hoi, mai kou wa opiopio mai: E auwana no kela mea keia mea i kona aoao iho, Aohe mea e hoola ia oe.
\c 48
\b
\q1 
\v 1 E HOOLOHE oukou i keia, e ko ka hale o Iakoba, Ka poe i kapaia ma ka inoa o ka Iseraela, Ka poe hoi i laha mai, mai na wai o Iuda mai; Ka poe hoohiki ma ka inoa o Iehova, Ka poe hookaulana i ke Akua o ka Iseraela, Aole nae me ka oiaio, aole me ka pono.
\q1 
\v 2 No ka mea, ua kapaia lakou mamulio ke kulanakauhale hoano, A hilinai lakou ma ke Akua o ka Iseraela, O Iehova o na kaua kona inoa.
\q1 
\v 3 Ua hoike aku no wau i na mea kahiko, mai kinohi mai, Mai ko'u waha i puka aku ai lakou; A na'u i hoike aku ia mau mea, Hana hoohikilele au, a hiki io mai no lakou.
\q1 
\v 4 No ka mea, ike mua no au, ua paakiki oe, A o kou a-i hoi, he olona hao, A o kou lae hoi, he keleawe.
\q1 
\v 5 Nolaila, hai aku au ia oe i kela mea i kinohi; Mamau o kona hiki ana mai, hoikeike aku au ia oe, O olelo auanei oe, Na kuu kii i hana i keia mau mea, Na kuu kiikalaiia, a na kuu kiihooheheeia lakou i kauoha aku.
\q1 
\v 6 Ua lohe no oe, e nana hoi oe ia mea a pau; Aole anei oukou e hai aku? I keia manawa, ua hai aku au ia oe i mea hou, I na mea hoi i hunaia, na mea au i ike ole ai
\q1 
\v 7 I keia manawa lakou i hanaia'i, aole mai kela wa mai, I ka la hoi au i lohe ole ai ia mau mea, O olelo auanei oe, Aia, ike no wau ia.
\q1 
\v 8 Oia, aole oe i lohe, aole hoi oe i ike; Oia, mai ia manawa mai, aole i hoohakahakaia kou pepeiao; No ka mea, ike mua no wau e hana aua oe me ka hoopunipuni nui loa, A mai ka opu mai, ua kapaia hoi oe o Kipi.
\b
\q1 
\v 9 No ko'u inoa no wau e hoopanee aku ai i ko'u iuaina, A no kuu nani, e hoomanawanui au ia oe, I mea e anai ole aku ai au ia oe.
\q1 
\v 10 Aia hoi, ua hoohehee hoomaikai aku au ia oe, aole nae me ke kala; Ua hoao aku au ia oe ma ka umu o ka popilikia.
\q1 
\v 11 No'u iho, no'u iho no wau e hana aku ai ia; No ka mea, e hoohaumiaia anei ko'u? Aole au e haawi i ko'u nani ia hai.
\b
\q1 
\v 12 E hoolohe mai oe ia'u, e ka Iakoba, a me ka Iseraela hoi, ko'u mea i heaia; Owau no ia, owau ka mua, owau hoi ka hope.
\q1 
\v 13 Oia, na ko'u lima no i hookumu i ka honua, Na kuu lima akau no i hoopalahalaha i na lani, Hea aku no au ia lakou, a ku pu mai la no lakou.
\q1 
\v 14 E akoakoa oukou a pau loa, a e hoolohe: Owai ka mea o lakou i hai i keia mau mea? O ka mea a Iehova i aloha aku ai, Nana no e hana kona makemake maluna o Babulona, A e kau no kona lima maluna o ko Kaledea.
\q1 
\v 15 Owau hoi, ua olelo no owau, Oia, ua hea aku no au ia ia; A na'u hoi ia i lawe mai nei, A e hoopomaikai oia i kona hele ana.
\b
\q1 
\v 16 E hookokoke mai oukou ia'u, e hoolohe i keia; Mai kinohi mai, aole au i olelo malu, Mai kona wa i hanaia'i, malaila no au; Ano hoi, ua hoouna mai ia'u o Iehova, ka Haku, a me kona Uhane.
\b
\q1 
\v 17 Penei hoi ka olelo ana mai a Iehova, a kou Hoolapanai, Ka Mea Hemolele hoi o ka Iseraela; Owau no Iehova, kou Akua, Ka mea ao aku ia oe i ka mea e pono ai, Ka mea alakai ia oe ma kahi e pono ai oe ke hele.
\q1 
\v 18 Ina i hoolohe mai oe i ka'u mau kauoha, Ina ua like kou malu me ka muliwai, A o kou pono hoi, me na aui o ka moana:
\q1 
\v 19 Ina ua like kau poe mamo me ke one, A me na keiki o kou opu me kona iliili; Aole hoi e hookiia kona inoa, aole hoi e hookaia'ku imua o'u.
\b
\q1 
\v 20 O haele oukou mawaho o Babulona, E holo oukou, mai ko Kaledea aku, Me ka leo o ke oli, e hai aku, e hookaulana i keia, E hoolaha aku a i na kukulu o ka honua; E i aku, Ua hoolapanai o Iehova i ka Iakoba, kana kauwa.
\q1 
\v 21 Ia lakou i hele ai ma na wahi maloo, aole lakou i make wai: Hookahe oia i ka wai, mai loko mai o ka pohaku no lakou; Wawahi no oia i ka pohaku, a huai mai la na wai.
\q1 
\v 22 Aole malu no ka poe hewa, wahi a Iehova.
\c 49
\b
\q1 
\v 1 E HALIU mai oukou ia'u, e na aina e, E hoolohe hoi oukou, e na lahuikanaka, ma kahi mamao aku; Hea mai o Iehova ia'u mai ka opu mai, Mai ka opu mai hoi o ko'u makuwahine, ua hoike oia i ko'u inoa.
\q1 
\v 2 Ua hana oia i ko'u waha a like me ka pahikaua oi, Ua huna mai oia ia'u ma ke aka o kona lima, Ua hana mai oia ia'u, a like me ka pua i anaiia, Ua huna mai oia ia'u iloko o kona aapua,
\q1 
\v 3 Ua olelo mai oia ia'u, O oe no ka'u kauwa, O Iseraela hoi oe, ka mea a'u e hoonaniia'i.
\q1 
\v 4 Alaila, i iho la au, Ua hooikaika makehewa au, No ka ole, a no ka lapuwale au i hoopau ai i ko'u ikaika; Me Iehova nae ko'u aponoia. Me ko'u Akua hoi ka'u hana ana.
\b
\q1 
\v 5 Ano ke olelo mai nei o Iehova, Ka mea i hana mai ia'u i kauwa nana, mai ka opu mai, I mea hoi e hoihoi mai i ka Iakoba ia ia, Ina e hoakoakoa ole ia ka Iseraela, E nani io no nae au ma na maka o Iehova, O ko'u Akua hoi oia ko'u ikaika.
\q1 
\v 6 I mai la ia, He mea uuku ia e lilo oe i kauwa na'u, E hooku mai i na ohana o ka Iakoba, A e hoihoi i ka poe i malamaia o ka Iseraela; E haawi no hoi au ia oe i malamalama no ko na aina e, I lilo oe i mea hoola aku no'u, ma na kukulu o ka honua,
\q1 
\v 7 Penei ka olelo ana mai a Iehova, Ka Hoolapanai o ka Iseraela, kona mea Hemolele hoi, I ka mea i hoowahawahaia e na kanaka, I ka mea a ka lahuikanaka i hoopailua ai, I ke kauwa hoi na ka poe e noho alii ana, E ike aku na'lii a e ku iluna, E kulou aku no hoi na luna, No Iehova, ka mea oiaio, ka Mea Hemolele o ka Iseraela, Nana no e makemake aku ia oe.
\b
\q1 
\v 8 Ke olelo mai nei o Iehova penei, I ka manawa aloha, ua hoolohe aku au ia oe, A i ka la hoola, ua kokua aku no au ia oe; A na'u hoi e malama aku ia oe, A e haawi no hoi ia oe i berita no na kanaka, I mea e paa ai ka aina, e hooili aku no hoi i na hooilina neoneo;
\q1 
\v 9 I olelo no hoi oe i ka poe i paa, E hele iwaho, A i ka poe ma ka pouli, E hoike ia oukou iho. E ai no lakou ma na alanui, A ma na puu a pau ka lakou ai.
\q1 
\v 10 Aole lakou e pololi, aole e makewai; Aole e hahau mai ka wela, a me ka la ia lakou; No ka mea, o ka mea aloha ia lakou, nana lakou e alakai, E alakai aku no oia ia lakou i na waipuna.
\q1 
\v 11 E hoolilo ana no au i ko'u mau kuahiwi a pau, i alanui, A e hookiekieia hoi ko'u mau kuamoo.
\q1 
\v 12 Aia hoi, e hele mai no keia poe, ma kahi loihi mai; Aia hoi, o keia poe, mai ke kukulu akau, a mai ke komohana mai; A o keia poe hoi, mai ka aina o Sinima mai.
\b
\q1 
\v 13 E oli oukou, e na lani, e hauoli hoi, e ka honua; E hookani i ke oli, e na mauna; No ka mea, ua hoomaha mai o Iehova i kona poe kanaka, A e aloha mai no hoi ia i kona poe i hoopilikiaia.
\b
\q1 
\v 14 Aka, ua olelo mai o Ziona, Ua haalele o Iehova ia'u, Ua hoopoina hoi ko'u Haku ia'u.
\q1 
\v 15 E hiki anei i ka wahine ke hoopoina i kana keiki aiwaiu, I ole ia e aloha aku i ke keiki a kona opu? Oia, e hiki no ia lakou ke hoopoina. Aka, aole au e hoopoina ia oe.
\q1 
\v 16 Aia hoi, ua kahakaha au ia oe ma na poho lima o'u; Ua mau loa no kou mau papohaku ma ko'u alo.
\q1 
\v 17 E hiki wawe no kau mau keiki; O ka poe nana oe i pepehi, A me ka poe i hooneoneo ia oe, e puka aku no lakou mawaho ou.
\b
\q1 
\v 18 E alawa ae oe i kou mau maka mao, a mao, e nana hoi; Akoakoa mai lakou a pau, a hele mai iou la. Me au e ola nei, wahi a Iehova, E aahu io no oe ia lakou a pau me he kahiko la, A e kakoo hoi ia lakou, e like me ka wahine mare.
\q1 
\v 19 No ka mea, o kou mau wahi mehameha, a neoneo, A me ka aina o kou luku ana, E pilikia ana no ia, no ka nui o ka poe e noho ana; A e loihi lilo aku no hoi ka poe i ale ia oe.
\q1 
\v 20 O na keiki o kou pa ana, e olelo no lakou ma kou mau pepeiao, Ua pilikia au i keia wahi, E haawi mai ia'u i wahi e noho ai au.
\q1 
\v 21 Alaila, e olelo iho no oe ma kou naau, Nawai i hoohanau mai i keia poe na'u? Nele au i ka'u mau keiki, a mehameha, He pio no. e kuewa aku ana; Nawai i hoonui mai i keia poe? Aia hoi, ua waiho wale ia au, mahea hoi lakou nei?
\b
\q1 
\v 22 Ke olelo mai nei o Iehova, ka Haku penei, Aia hoi, e hapai no wau i ko'u lima no ko na aina e, A e kau no wau i ko'u hae no na lahuikanaka; A e lawe mai no lakou i kau poe keikikane ma ka poli, A e kaikaiia kau mau kaikamahine, ma na poohiwi.
\q1 
\v 23 A e lilo na'lii i poe makuakane hanai nou, A o na wahine alii a lakou, i poe makuwahine hanai nou; A e kulou ilalo i ka honua ko lakou maka imua ou, A e palu iho lakou i ka lepo o kou mau wawae; A e ike auanei oe, owau no Iehova; No ka mea, o ka poe e kali ia'u, aole lakou e hilahila.
\b
\q1 
\v 24 E kailiia'ku anei ka waiwai pio, mai ka poe ikaika aku? E hoopakeleia'nei ke pio i lawe pono ia?
\q1 
\v 25 Aka, ke olelo mai nei o Iehova penei, E kailiia'ku no na pio o ka poe ikaika, A e hoopakeleia ka waiwai i pio, mai ka poe hooweliweli mai; No ka mea, e paio aku au i ka mea i paio pu me oe, A e hoola no wau i kau poe keiki.
\q1 
\v 26 O ka poe hooluhi aku ia oe, E hanai aku au ia lakou i ko lakou io iho, A e ona auanei lakou i ko lakou koko iho, e like me ka waina hou; A e ike no na mea io a pau, owau no Iehova, O kou Ola, a me kou Hoolapanai, Ka Mea mana hoi o ka Iakoba.
\c 50
\b
\q1 
\v 1 KE ninau mai nei o Iehova penei, Auhea ka palapala hoohemo na ko oukou makuwahine? Ka mea a'u i hoohemo ai? Ua kuai lilo aku au ia oukou no wai o ka poe a'u i aie ai? Aia hoi, ua kuai lilo aku oukou ia oukou iho no ko oukou hewa, A no ko oukou hala, ua hoohemoia ko oukou makuwahine.
\q1 
\v 2 Ia'u i hele mai ai, heaha ka mea i kanaka ole ai? A ia'u i hea aku ai, aohe mea nana i o mai? Ua hoopokole loa ia anei ko'u lima, i ole au e hoola aku? Aole anei o'u mana e hoopakele ai? Aia hoi, i kuu papa ana, hoomaloo no wau i ke kai, A hoolilo no wau i na muliwai, i waonahele; Pilau mai la ko lakou ia, no ka mea, aohe wai, e make hoi, no ka makewai.
\q1 
\v 3 Hoaahu no au i na lani i ka pouli, A kau aku au i ke kapa makena, i uhi no lakou.
\b
\q1 
\v 4 Ua haawi mai o Iehova ka Haku i ke alelo o ka poe akamai na'u, I ike au i ka hooikaika aku i ka mea luhi me ka olelo, Hoala mai no oia i kela kakahiaka i keia kakahiaka, Hoala mai no oia i ko'u pepeiao, e lohe, e like me ka mea i aoia.
\b
\q1 
\v 5 Ua hoohakahaka o Iehova, ka Haku, i ko'u pepeiao, Aole hoi au i kipi aku, aole au i hoi hope.
\q1 
\v 6 Haawi no au i ko'u kua i ka poe hahau, A me ko'u mau papalina i ka poe i uhuki lauoho: Aole au i huna i ko'u maka, mai ka hilahila, a me ke kuha ana.
\b
\q1 
\v 7 Na Iehova, ka Haku e kokua mai ia'u, Nolaila, aole au e hoopalaimaka; Nolaila hoi au i kau ai i ko'u maka, me he pohaku paea la, A ua ike no au, aole au e hilahila ana.
\q1 
\v 8 Ua kokoke mai no ka mea nana au e hoapono; Owai hoi ka mea hakaka me au? E ku pu aku maua: Owai ko'u hoapaio? E hookokoke mai oia ia'u.
\q1 
\v 9 Aia hoi e kokua mai no o Iehova ka Haku ia'u; Owai hoi ka mea nana e hoahewa mai ia'u? Aia hoi, e lilo no lakou a pau i mea kahiko, me he lole la, E ai no ka mu ia lakou.
\b
\q1 
\v 10 Owai la ka mea iwaena o oukou i makau aku ia Iehova, E hoolohe ana hoi i ka leo o kana kauwa, Ka mea e hele ana ma ka pouli, aole ona malamalama? E hilinai aku oia ma ka inoa o Iehova, A e hoomaha hoi ma kona Akua.
\q1 
\v 11 Aia hoi, o oukou a pau, ka poe hoa i ke ahi, Ka poe i kakoo ia oukou iho i na lamaku; E hele oukou ma ka malamalama o ko oukou ahi, A me na lamaku a oukou i kuni ai. E loaa no keia ia oukou ma kuu lima, E moe ana no oukou ilalo iloko o ka eha.
\c 51
\b
\q1 
\v 1 E HOOLOHE mai oukou ia'u, e ka poe hahai i ka pono, Ka poe hoi e imi ana ia Iehova; E nana oukou ma ka pohaku, kahi a oukou i kalaiia'i, A i ka lua hoi maloko o ke ana, kahi a oukou kohiia'i.
\q1 
\v 2 E nana hoi ma o Aberahama la, ko oukou kupuna, Ia Sara hoi i ka mea nana oukou i hanau; No ka mea, oia hookahi ka'u i hea aku ai, A hoopomaikai aku ia ia, a hoonui aku i kana.
\q1 
\v 3 Pela no o Iehova e hoomaha mai ai ia Ziona, E hoomaha mai no i kona mau wahi neoneo a pau; A e hana no oia i kona waonahele, a like me Edena, A me kona waoakua e like me ka mahinaai a Iehova; Maloko olaila, e loaa no ka olioli a me ka hauoli, Ka hoolea ana, me ka leo o ke oli.
\b
\q1 
\v 4 E hoolohe mai ia'u, e ko'u poe kanaka, E haliu mai ka pepeiao ia u, e ka lahuikanaka o'u; No ka mea, e laha aku no ke kanawai, mai o'u aku nei, A e hoolilo no wau i ko'u pono, i malamalama no na kanaka.
\q1 
\v 5 Ua kokoke mai no ko'u pono, ua hele aku hoi ko'u ola, Na kuu lima no e hooponopono i kanaka; E kali no na mokupuni ia'u, a ma ko'u lima lakou e hilinai ai.
\q1 
\v 6 E alawa ae i ko oukou maka iluna a i ka lani, E nana hoi ma ka honua malalo; E holo aku auanei na lani, e like me ka uwahi, A e apulu no hoi ka honua, me he lole la, Pela no e make ai ka poe e noho ana maluna iho; Aka, e oia mau ana no ko'u ola, Aole hoi e pau ana ko'u pono.
\b
\q1 
\v 7 E hoolohe mai oukou ia'u, e ka poe ike i ka pono, E na kanaka hoi i loaa ko'u kanawai ma ko lakou naau; Mai makau oukou i ka hoowahawaha o kanaka, Mai weliweli hoi i ka lakou olelo hoino ana.
\q1 
\v 8 No ka mea, e ai no ka mu ia lakou, me he lole la, E ai no hoi ka huhu ia lakou e like me ka hulu hipa: Aka, e mau loa ana no ko'u pono, a i ke ao pau ole, A me ko'u ola hoi, mai keia hanauna, a ia hanauna aku.
\b
\q1 
\v 9 E ala, e ala, e aahu i ka ikaika, e ka lima o Iehova; E ala, e like me ia i na la mamua, I na hanauna kahiko loa aku hoi. Aole anei oe ka mea nana i okioki ia Rahaba? A hou iho no hoi i ka moonui?
\q1 
\v 10 Aole anei oe ka mea nana i hoomaloo i ke kai? I na wai hoi o ka hohonu nui? A hoolilo hoi i na wahi hohonu o ke kai, I alanui e hele ai ka poe i hoolapanaiia?
\q1 
\v 11 E hoi mai no hoi ko Iehova poe i hoolapanaiia, E hele mai no lakou i Ziona me ke oli; He hauoli mau loa maluna o ko lakou mau poo: E loaa no ia lakou ka olioli, a me ka hauoli, A e hee loa aku no ke kaumaha, a me ke kaniuhu.
\b
\q1 
\v 12 Owau, owau no ka mea nana oukou e hoomaha aku; Owai hoi oe, i makau aku ai oe i ke kanaka, i ka mea e make ana, A i ke keiki a ke kanaka hoi, i ka mea e lilo ana i mauu?
\q1 
\v 13 A hoopoina hoi ia Iehova, i ka Mea nana oe i hana, A hohola ae la hoi i na lani, a hookumu i ka honua, A makau mau loa no hoi oe i na la a pau, No ka inaina o ka mea hooluhi, Ina paha ia e makaukau e luku iho? Auhea hoi ka inaina o ka mea hooluhi?
\q1 
\v 14 Wikiwiki ae la ke pio kulou, i weheia'i oia, I ole ia o make maloko o ka lua, I pau ole hoi kana berena.
\q1 
\v 15 Aka, owau no Iehova, kou Akua, Ka mea nana i hookupikipikio ke kai, A halulu mai la kona mau ale, O Iehova o na kaua kona inoa.
\q1 
\v 16 Ua hahao no wau i ko'u mau huaolelo iloko o kou waha, A ua uhi aku ia oe i ke aka o ko'u lima, Me ka makia aku i na lani, a me ka hookumu i ka honua, I olelo aku au ia Ziona, O oe no ko'u poe kanaka.
\b
\q1 
\v 17 E ala e ala, e ku iluna, e Ierusalema, Ka mea i inu ma ka lima o Iehova, i ke kiaha o kona inaina; Ua inu no oe i ke kiaha bola e hikaka ai, Ua inu oe a moni loa hoi ilalo.
\q1 
\v 18 Aole mea e alakai ia ia o na keikikane a pau ana i hanau ai; Aohe mea lalau i kona lima o na keikikane a pau ana i hanai ai a nui.
\q1 
\v 19 Ua hiki mai keia mau mea elua maluna ou; Owai hoi ka mea minamina ia oe? O ka neoneo a me ka make, O ka wi a me ka pahikaua; Ma owai la hoi au e hoomaha aku ai ia oe?
\q1 
\v 20 Ua maule kau mau keikikane, Ke kaa nei no ma na poo o na alanui a pau, E like me ka bipi hihiu maloko o ka upena; Ua hoopihaia lakou i ka inaina o Iehova, I ka paipai ana hoi o kou Akua.
\b
\q1 
\v 21 Nolaila, e hoolohe mai oe i keia, e ka mea popilikia, A ona hoi, aole nae i ka waina:
\q1 
\v 22 Penei ka olelo ana mai a Iehova, kou Haku, O kou Akua hoi, nana e kokua i kona poe kanaka: Aia hoi, ua lawe au i ke kiaha e hikaka ai, mai kou lima aku, I ke kiaha bola hoi o ko'u inaina, Aole oe e inu hou.
\q1 
\v 23 Aka, e waiho aku au ia mea iloko o ka lima o ka poe hookaumaha ia oe, O ka poe i olelo ia oe, E moe ilalo, i hele aku makou maluna ae; A ua hoomoe oe i kou kua e like me ka lepo, Me he alanui la hoi, no ka poe i hele ae.
\c 52
\b
\q1 
\v 1 E ALA, e ala, e aahu i kou ikaika, e Ziona; E komo i kou mau lole nani, e Ierusalema, Ke kulanakauhale laa; No ka mea, ma keia wa aku, aole e hele hou iloko ou, ka mea i okipoepoe ole ia, a me ka haumia.
\q1 
\v 2 E lulu oe ia oe iho no ka lepo, E ku iluna, a e noho ilalo, e Ierusalema; E wehe oe i na mea paa o kau a-i, e ke kaikamahine pio o Ziona.
\q1 
\v 3 No ka mea, ke olelo mai nei o Iehova penei, Ua kuai make hewa aku oukou ia oukou iho; A e hoolapauaiia oukou, aole nae i ke kala.
\q1 
\v 4 No ka mea, ke i mai nei o Iehova, ka Haku, penei, I kinohi, iho no ko'u poe kanaka ilalo i Aigupita, e noho iki malaila, A hookaumaha kumu ole ko Asuria ia lakou.
\q1 
\v 5 Heaha hoi ka'u ianei i keia wa, wahi a Iehova, I lawe make hewa ia'ku ko'u poe kanaka? E aoa auanei ko lakou poe luna, wahi a Iehova; Ua hoowahawaha mau ia ko'u inoa i na la a pau.
\q1 
\v 6 Nolaila, e ike auanei ko'u poe kanaka i ko'u inoa; Nolaila hoi, e ike no lakou i kela la, Owau no ka mea nana e olelo; aia hoi, owau no.
\b
\q1 
\v 7 Nani wale hoi ma na mauna, na wawae o ka mea hai i ka euanelio, Ka mea hoolaha i ka malu, Ka mea hai i ka euanelio maikai, Ka mea hoikeike i ke ola, Ka mea olelo ia Ziona, Ke malama aupuni nei kou Akua!
\q1 
\v 8 O kou poe kiai, hookiekie lakou i ka leo, Hookani pu no ka leo o lakou; No ka mea, e ike auanei lakou, he maka no, he maka, Ke hoihoi mai o Iehova ia Ziona.
\b
\q1 
\v 9 E hookani olioli oukou, e olioli pu, E na wahi neoneo o Ierusalema; No ka mea, ua hoomaha mai o Iehova i kona poe kanaka, Ua hoolapanai oia ia Ierusalema.
\q1 
\v 10 Ua hoike o Iehova i kona lima hemolele imua o na maka o na lahuikanaka a pau; A e ike auanei na kukulu a pau o ka honua i ka hoola ana o ko kakou Akua.
\b
\q1 
\v 11 E hele oukou mawaho, e hele oukou mawaho, e puka aku mawaho olaila, Mai pa aku i ka mea haumia; E puka aku mai loko aku ona; E hoohuikala oukou ia oukou, e ka poe halihali i na ipu o Iehova.
\q1 
\v 12 No ka mea, aole oukou e puka aku me ka holo, Aole hoi oukou e hele me ke auhee; No ka mea, e hele no o Iehova imua o oukou, A o ke Akua o ka Iseraela auanei ka mea hele mahope o oukou.
\b
\q1 
\v 13 Aia hoi e pomaikai ana ka'u kauwa, E hapaiia no hoi ia, a e hookiekieia, A e kiekie loa auanei oia.
\q1 
\v 14 Nui no ka poe i haohao ia oe, No ka mea, ua oi aku ka mainoino o kona helehelena mamua o ko ke kanaka, A me kona hiona hoi mamna o ko na keiki a kanaka.
\q1 
\v 15 Pela no oia e pipi ai i na lahuikanaka, he nui loa; E hoopaa na'lii i ko lakou waha imua ona; No ka mea, e ike auanei lakou i ka mea i hai ole ia ia lakou, A e noonoo pono lakou i ka mea a lakou i lohe ole ai.
\c 53
\b
\q1 
\v 1 O WAI ka mea i manaoio i ka makou hoike ana? Iawai la hoi i hoikeia'ku ai ka lima o Iehova?
\q1 
\v 2 E ulu mai no oia imua ona me he oha la, E like hoi me ke aa kupu mai loko mai o ka Iepo maloo, Aole ona maikai o ke kino, aole ona hanohano; A ia kakou e ike aku ai ia ia, aole ona helehelena maikai i makemake aku ai kakou ia ia.
\q1 
\v 3 Ua hoowahawahaia oia, a ua haaleleia hoi ia e na kanaka; He kanaka eha, a ua ike hoi oia i ka popilikia; E like me ka huna ana o na maka, mai o kakou aku, Pela no ia i hoowahawahaia'i, a manao ole hoi kakou ia ia.
\b
\q1 
\v 4 He oiaio no, ua kaikai no oia i ko kakou popilikia, Ua halihali no oia i ko kakou eha: Aka, manao aku kakou ia ia, ua paipaiia, Ua hahauia hoi, a ua hookaumahaia e ke Akua.
\q1 
\v 5 Aka, ua hou a oia no ko kakou hewa, Ua paopaoia oia no ko kakou hala; Maluna ona ka hoopai ana e malu ai kakou, Ma kona mau palapu, ua hoolaia mai kakou.
\q1 
\v 6 Ua hele hewa kakou a pau e like me na hipa; Ua huli kela mea keia mea o kakou i kona aoao iho; A ua kau no o Iehova maluna oua i ka hewa o kakou a pau.
\b
\q1 
\v 7 Ua hookaumahaia oia, ua hoopilikiaia hoi, Aole nae i ekemu ae kona waha. E like me ke keikihipa, ua alakaiia oia i ka make, E like hoi me ka hipa i pane ole imua o ka mea nana ia e ako, Pela no oia, aole i ekemu ae kona waha.
\q1 
\v 8 Ua laweia'ku la oia, mai ka paa ana, a mai ka hookolokolo ana hoi; A owai la ka mea e hai i kona hanauna? No ka mea, ua kipakuia oia mai ka aina o ka poe ola aku; No ka hewa o ko'u poe kanaka ia i hahauia'i.
\q1 
\v 9 Haawi ae la oia i kona lua me ka poe hewa, Me ka poe mea waiwai hoi iloko o kona make; Aole nae ia i hana i ka mea hewa, Aohe hoopunipuni ma kona waha.
\b
\q1 
\v 10 Aka, manao no o Iehova e paopao ia ia, Ua hoeha oia ia ia: A i ka wa e haawi aku ai oe i kona uhane i mohai hala, E ike no oia i kana mau keiki, a e hooloihi no hoi i kona mau la, A e pomaikai auanei ka makemake o Iehova ma kona mau lima.
\q1 
\v 11 E ike aku no oia i ka hope o ka luhi ana o kona uhane, A e oluolu oia; Ma ka ike ana ia ia, e hoapono no ka'u kauwa hemolele i na mea he nui, No ka mea, nana no e amo i ko lakou hewa.
\q1 
\v 12 Nolaila, e mahele aku au nana, me ka poe koikoi, A nana no e mahele i ka waiwai pio me ka poe ikaika; Ua ninini aku oia i kona uhane i ka make; A ua helu pu ia oia me ka poe lawehala; A halihali no oia i ka hewa o na mea he nui, A e nouoi aku la oia no ka poe i lawehala.
\c 54
\b
\q1 
\v 1 E OLI oe, e ka mea pa, ka mea i hanau ole hoi; E oli i ke oli, a e hauoli hoi, e ka mea kuakoko ole; No ka mea, ua nui aku na keiki a ka mea i neoneo, i na keiki a ka wahine i mareia, wahi a Iehova.
\q1 
\v 2 A hoakea i kahi o kou halelewa, E hoopalahalaha hoi lakou i na paku o kou wahi e noho ai; Mai aua, e hooloihi i kou mau kaula, E hoopaa loa hoi i kou mau makia;
\q1 
\v 3 No ka mea, e poha aku auanei oe, ma ka lima akau, a ma ka lima hema; A e ili mai ko na aina na kau poe mamo, A ia lakou no e hoonohoia na kulanakauhale neoneo.
\b
\q1 
\v 4 Mai makau oe, no ka mea, aole oe e hilahila, Mai hoopalaimaka, no ka mea, aole oe hoohilahilaia; E hoopoina no hoi oe i ka hilahila o kou wa opiopio, Aole hoi e mauao hou i ka hoowahawahaia o kou noho wahine kane make ana.
\q1 
\v 5 No ka mea, o ka mea nana oe i hana, oia kau kane, O Iehova o na kaua kona inoa; A o kou Hoolapanai, o ka Mea Hemolele ia o ka Iseraela; E kapaia no hoi oia, ke Akua o ka honua a pau.
\q1 
\v 6 No ka mea, ua hea aku o Iehova ia oe, E like me ka wahine i haaleleia, a kaumaha hoi ma ka naau, Ka wahine hoi i ka wa opiopio; No ka mea, e hooleia oia, wahi a ke Akua ou.
\q1 
\v 7 No ka manawa uuku, ua haalele aku au ia oe; Aka, me ka lokomaikai he nui loa, e hoiliili au ia oe.
\q1 
\v 8 I ka hu ana o ka huhu, huna no wau i ko'u maka ia oe i kekahi minute; Aka, me ke aloha mau loa, e lokomaikai aku ai au ia oe, Wahi a Iehova, kou Hoolapanai.
\b
\q1 
\v 9 No ka mea, e like me na wai o Noa, pela no keia ia'u; Me au i hoohiki ai, aole e hoohalana hou na wai o Noa i ka honua, Pela no wau i hoohiki ai, aole au e huhu aku ia oe, Aole hoi au e paipai ikaika aku ia oe.
\q1 
\v 10 No ka mea, e lilo auanei na kuahiwi, A e hooneeneeia na mauna; Aka, aole e lilo aku ko'u lokomaikai, Aole hoi e hooneeneeia ka berita o ko'u malu, Wahi a Iehova, ka mea i aloha mai ia oe.
\b
\q1 
\v 11 E ka mea popilikia i hooalealeia, Aole hoi i alohaia! E hoonoho wau i kou mau pohaku maloko o ka pena, A e hookumu wau ia oe ma ua pohaku sapeiro.
\q1 
\v 12 A hana no wau i kou mau puupuu kaua i pohaku paea, A me kou mau pukapa i pohaku ula, A me kou mau mokuna a pau i pohaku maikai.
\q1 
\v 13 E aoia no hoi kau mau keiki a pau e Iehova, A e nui loa auanei ka pomaikai o kau mau keiki.
\q1 
\v 14 Ma ka pono no oe e hookumuia'i: E mamao aku oe i ka hookaumaha, No ka mea, aole oe e makau ana; A i ka weliweli hoi, no ka mea, aole ia e hookokoke mai ia oe.
\b
\q1 
\v 15 Aia hoi, e hookipikipi no lakou, aole nae mamuli o ka'u olelo ana, O ka mea kipi aku ia oe, e haule no ia mamuli ou.
\q1 
\v 16 Aia hoi, na'u no i hana i ka amara nana e puhi i ka lanahu i ke ahi, A hoopuka mai la oia i mea hana no kana hana; A na'u hoi i hana i ka mea make e make ai.
\b
\q1 
\v 17 O na mea hoeha a pau i hanaia e ku e ia oe, aole lakou e lanakila, A o na elelo a pau e ala mai e ku e ia oe, nau no ia e hoahewa aku. Oia ka hooilina o na kanwa a Iehova, A na'u hoi ko lakou pono, wahi a Iehova.
\c 55
\b
\q1 
\v 1 E A! na mea a pau e makewai, E hele mai oukou i na wai, A o ka mea kala ole, e hele mai hoi oukou, e kuai no, a e ai iho; Oia, e hele mai, e kuai i ka waina, a me ka waiu, me ke kala ole, a me ke kumu ole.
\q1 
\v 2 No ke aha la oukou i kaupaona aku ai i ka oukou kala i ka mea, aole ia he berena? A i ko oukou waiwai hoi, i ka mea hoomaona ole mai? E hoolohe pono mai oukou ia'u, a e ai hoi i ka mea i maikai io, A e olioli hoi ko oukou uhane ma ka momona.
\q1 
\v 3 E haliu mai i ko oukou pepeiao, a e hele mai ia'u; A hoolohe mai, a e ola no ko oukou uhane; A e hana no au me oukou i berita mau loa, I ka lokomaikai oiaio hoi o Davida.
\q1 
\v 4 Aia hoi, ua haawi aku au ia ia i mea hoike no na kanaka, I alakai hoi, a i luna no na lahuikanaka.
\q1 
\v 5 Aia hoi, e kahea aku no oe i ka lahuikanaka au i ike ole ai; A o ka lahuikanaka i ike ole ia oe, e holo aku no lakou iou la, No Iehova, kou Akua, a no ka Mea Hemolele o ka Iseraela; No ka mea, ua hoonani mai oia ia oe.
\b
\q1 
\v 6 E imi oukou ia Iehova, oiai oia ma kahi e loaa'i, E hea aku ia ia, oiai oia ma kahi kokoke.
\q1 
\v 7 E haalele ke kanaka hewa i kona aoao, A me ke kanaka lawehala, i kona mau manao; A e hoi mai hoi oia io Iehova la, a e lokomaikai no oia ia ia, A i ko kakou Akua hoi, no ka mea, e kala nui loa auanei oia.
\b
\q1 
\v 8 No ka mea, o ko'u mau manao, aole ia o ko oukou mau manao, A o ko oukou mau aoao, aole ia o ko'u mau aoao, wahi a Iehova.
\q1 
\v 9 No ka mea, e like me ke kiekie o na lani maluna o ka honua, Pela no ke kiekie o ko'u mau aoao maluna o ko oukou mau aoao, A me ko'u mau manao, maluna o ko oukou mau manao.
\q1 
\v 10 No ka mea, e like me ka ua, a me ka hau i iho mai, mai na lani mai, Aole hoi e hoi hou ilaila, aka, e hoomau mai no i ka honua, A hoohua iho la ia ia, e hoomuo no hoi, I haawi mai ia i ka hua na ka mea lulu hua, A i berena hoi na ka mea ai;
\q1 
\v 11 Pela auanei ka'u olelo, ka mea i puka aku, mai ko'u waha aku, Aole ia e hoi nele mai ia'u; Aka, e hana no ia i ka mea a'u e makemake ai, A e hooko io ia i ka mea a'u e hoouna aku ai ia ia.
\q1 
\v 12 No ka mea, e puka aku auanei oukou me ka olioli, A e alakaiia'ku oukou me ka malu: E hookani i ke oli na kuahiwi, a me na mauna imua o oukou, A e paipailima hoi na laau a pau o ke kula.
\q1 
\v 13 Ma kahi o ke kakalaioa e ulu mai auanei ka laau kaa, A ma kahi o ka laau ooi, ka hadasa hoi; A e lilo ia i mea kaulana no Iehova, I ouli mau loa no hoi e hooki ole ia'i.
\c 56
\b
\q1 
\v 1 KE i mai nei o Iehova penei, E malama oukou i ka pono, a e hana hoi i ka maikai; No ka mea, kokoke no e hiki mai ko'u ola, A me ko'u pono i ka hoikeia.
\q1 
\v 2 Pomaikai ke kanaka hana i keia, A me ke keiki a ke kanaka i hoopaa iho ia mea; Ka mea malama i ka la sabati, aole hoohaumia ia, Ka mea malama i kona lima, aole hana i kekahi mea hewa.
\b
\q1 
\v 3 Mai olelo nae ke keiki a ka malihini, Ka mea i hoopili ia ia iho ia Iehova, me ka i iho, Ua hookaawale loa o Iehova ia'u mai kona poe kanaka aku: Mai olelo hoi ka mea i poaia, Aia hoi! he laau maloo no wau.
\q1 
\v 4 No ka mea, penei i olelo mai ai o Iehova i na mea i poaia, I ka poe malama i ko'u la sabati, A makemake hoi i na mea a'u i olioli ai, A hoopaa hoi i ka'u berita;
\q1 
\v 5 Ia lakou no wau e haawi aku ai, Maloko o ko'u hale, a maloko o ko'u mau pa, I kuleana, a i inoa hoi i oi aku ka maikai mamua o na keikikane, a me na kaikamahine; A e haawi no wau ia lakou i inoa mau loa e hooki ole ia'i.
\b
\q1 
\v 6 A o na keikikane hoi a ka malihini, Ka poe hoopili ia lakou iho ia Iehova, E malama ia ia, a e aloha aku i ka inoa o Iehova, I lilo lakou i poe kauwa nana, O kela mea keia mea i malama i ka la sabati, aole hoohaumia ia, A hoopaa hoi i ka'u berita;
\q1 
\v 7 O lakou no ka'u e lawe ai i ko'u mauna hoano, A e hoohauoli au ia lakou maloko o ko'u hale pule: E maliuia ko lakou mohaikuni, a me ko lakou alana maluna o ko'u kuahu; No ka mea, e kapaia ko'u hale, He hale pule no na lahuikanaka a pau.
\q1 
\v 8 Ke i mai nei o Iehova, ka Haku, Ka mea hooiliili i ka mea aea o ka Iseraela, E hooiliili au i kekahi poe e ae, io na la, Okoa ka poe i hooiliiliia.
\b
\q1 
\v 9 E na holoholona a pau o ke kula, e hele mai oukou e ai; O na holoholona hoi a pau o ka ululaau.
\q1 
\v 10 Ua makapo kona poe kiai, ua naaupo no lakou a pau; O lakou a pau, he poe ilio walaau ole, Aole hiki ia lakou ke hae; E hiamoe ana, e moe ana ilalo no hoi, e makemake ana i ka hiamoe.
\q1 
\v 11 Oia, he poe ilio pololi wale, Aole i ike lakou i ka maona; He poe kahuhipa lakou hiki ole ke hoomaopopo; Huli no lakou a pau i ko lakou aoao iho, O kela mea keia mea i kona waiwai panee, ma kona wahi iho.
\q1 
\v 12 E hele mai, a na'u no e lawe mai i ka waina, [wahi a lakou,] A e inu kakou i ka mea awaawa a ona; A e like pu ana ka la apopo mo keia la, a e oi nui aku no hoi.
\c 57
\b
\q1 
\v 1 MAKE no ke kanaka pono, aohe nae kanaka i hoomanao ia mea; Ua laweia'ku la na kanaka lokomaikai, Aole nae kanaka i noonoo, Ua laweia'ku ka mea i pono, mai ke alo aku o ka hewa.
\q1 
\v 2 E hele aku no oia me ka malu, E hoomaha lakou ma ko lakou wahi moe, O ka mea hoi i hele ma kona pololei.
\b
\q1 
\v 3 E hookokoke mai oukou ianei, e na keiki a ke kilo wahine, Na keiki hoi a ke kane moe kolohe, a me ka wahine hookamakama.
\q1 
\v 4 Ia wai oukou e olioli ewaewa ai? A hoohamama oukou i ka waha iawai? A hooloihi ae i ke alelo? Aole anei oukou he poe keiki na ka poe hewa? A he hanauna hoi na ka wahahee?
\q1 
\v 5 A ua wela hoi i na'kuakii malalo o na laau uliuli a pau, A ua luku aku hoi i na keiki ma na awawa, A malalo hoi ma na ana o na pohaku?
\q1 
\v 6 Aia no kou kuleana, ma na pohaku olohelohe o ke awawa, O lakou, o lakou no kou lihi. Oia, ua ninini aku oe i ka mohaiinu no lakou; Ua kaumaha aku no hoi i ka mohai ai. E olioli anei au i keia mau mea?
\q1 
\v 7 Maluna o ka mauna kiekie, malaila no oe i kaikai ai i kou wahi moe, Malaila no oe i pii aku ai, e kaumaha aku i ka mohai.
\q1 
\v 8 Mahope o na puka, a me na lapauwila, Ua kukulu oe i kou mea e hoomanao ai; No ka mea, ua hoike aku oe ia oe iho i ka mea e, aole ia'u, A ua pii aku hoi, a ua hoakea oe i kou wahi moe, A ua hana oe i mea ike nou me lakou; Makemake no oe i ko lakou wahi moe, ua hoomakaukau oe i wahi nona.
\q1 
\v 9 Hele aku no oe i ke alii me ka aila ala, A ua hoomahuahua oe i kou mau mea manoi, A ua hoouna aku oe i kou poe elele i kahi loihi, A ua hoopoho no oe ia oe iho, a lilo i ka po.
\q1 
\v 10 I ka loihi o kou hele ana, ua maloeloe oe, Aole nae oe i olelo, ua make hewa; Ua loaa ia oe ke ola ana o kou lima, Nolaila, aole oe i paupauaho.
\b
\q1 
\v 11 Ua hopohopo oe ia wai, a makau hoi, I wahahee ai oe, aole hoi i hoomanao mai ia'u, Aole hoi i aloha mai ma kou naau? Aole anei au i noho ekemu ole, mai ka wa kahiko loa mai, A makau ole hoi oe ia'u?
\q1 
\v 12 E hai aku no au i kou pono, a me kau mau hana, Aole oe e pomaikai ia mau mea.
\b
\q1 
\v 13 Ia oe e kahea aku ai, na kou poe oe e hoopakele; E kaikai aku no ka makani ia lakou a pau; Na ka onini lakou e lawe aku; Aka, o ka mea hilinai mai ia'u, nana no e noho i ka aina, A e ili mai no ko'u mauna hoano ia ia.
\b
\q1 
\v 14 Olelo iho la ia, E hoouka i ke ala, e hoouka i ke ala. E koomakaukau i ke kuamoo, E kaikai aku i na mea e hina'i, mai ke ala aku o ko'u poe kanaka.
\q1 
\v 15 No ka mea, penei ka olelo ana mai a ka Mea i hapaiia, Ka Mea i hookiekie hoi, e noho ana ma ke ao pau ole, O Hemolele kona inoa; E noho no au ma kahi kiekie, a hemolele hoi, Me ka mea hoi i mihi, a haahaa hoi ka uhane, E hoomaha i ka uhane o ka mea haahaa, A e hoomaha hoi i ka naau o ka poe mihi.
\q1 
\v 16 No ka mea, aole au e paio mau loa, Aole hoi au e huhu aku i na manawa a pau; O maule imua o'u ka naau, A me na uhane a'u i hana'i.
\q1 
\v 17 No ka hewa o kona alunu i huhu aku ai au, a hahau aku la ia ia; Huna no wau i ko'u maka, a huhu aku no; Aka, hele no oia ma ke kolohe, ma ka aoao no o kona naau.
\q1 
\v 18 Ua ike no au i kona mau aoao, a e hoola aku no au ia ia; A e alakai no hoi au ia ia, A e hoihoi aku i ka maha ia ia, a i kona poe kumakena no hoi.
\q1 
\v 19 Na'u no e hana i ka hua o na lehelehe; Ua malu, ua malu ka mea mamao aku, a me ka mea kokoke mai, Wahi a Iehova, a na'u no ia e hoola aku.
\q1 
\v 20 Ua like ka poe hewa me ke kai kupikipikio, A hiki ole ke lana malie, a ua hooleilei na wai ona i ka wai eka, a me ka lepo.
\q1 
\v 21 Aohe malu no ka poe hewa, wahi a ke Akua o'u.
\c 58
\b
\q1 
\v 1 E KAHEA nui aku, mai uumi, E hookiekie i kou leo me he pu la, E hoike i ko'u poe kanaka i ko lakou hewa, A i ko ka hale o Iakoba i ko lakou hala.
\q1 
\v 2 Aka, imi no lakou ia'u i kela la i keia la, A olioli lakou i ka ike ana i ko'u mau aoao, Me he lahuikanaka la i hana i ka pono, A haalele ole i ke kanawai o ko lakou Akua. Ninau mai no lakou ia'u i ka hooponopono pololei ana, A olioli lakou i ka hookokoke ana i ke Akua.
\b
\q1 
\v 3 No ke aha la makou i hookeai ai, a ike ole mai oe, wahi a lakou? A hookaumaha makou i ko makou uhane, A ua hoomaopopo ole mai oe? Aia hoi, i ka la o ko oukou hookeai ana, Loaa no ia oukou ka lealea, Koi aku oukou i ka oukou hana a pau.
\q1 
\v 4 Aia hoi, hookeai no oukou no ka paio, a me ka hakaka, I kuikui aku me ka lima hana ino: Aole hookeai oukou e like me ko keia la, I mea e loheia'i ko oukou leo maluna.
\q1 
\v 5 O ka hookeai anei me ia ka'u i makemake ai? He la e hookaumaha ai ke kanaka i kona uhane? E hookulou hoi i kona poo ilalo, me he kaluha la? A haalii i ke kapa ino, a me ka lehu ahi? E kapa aku anei oe i keia, he hookeai, A he la oluolu no Iehova?
\q1 
\v 6 Aole anei penei, ka hookeai a'u i makemake ai? O ka wehe i na mea paa o ka hookaumaha, E hookuu iho i na haawe kaumaha, A e kuu aku hoi e hele ka poe i hookaumahain, A i uhaki no hoi oukou i na auamo a pau?
\q1 
\v 7 Aole anei, o ka haawi aku i kau berena no ka poe pololi, A i lawe mai hoi oe ma kou hale i ka poe hune i hana ino ia? Ia oe hoi e ike ai i ka mea ku kohana, i uhi oe ia ia? I huna ole hoi oe ia oe, i kou io iho?
\b
\q1 
\v 8 Alaila, e poha aku no kou malamalama, e like me ko ke kakahiaka, A e puka koke mai no kou ola; A e hele no kou pono ma kou alo, A o ka nani o Iehova auanei ka mea hele mahope ou.
\q1 
\v 9 Alaila, e hea aku no oe, a e olelo mai no o Iehova; A ina e uwe aku oe, e i mai no oia, Eia no wau. Ina e hoolei aku oe, mai ou aku, i ka auamo, A me ka o ana aku o ka manamana lima, a me ka olelo ana i ka lapuwale;
\q1 
\v 10 Ina hu aku kou uhane i ka poe pololi, A hoomaona hoi oe i ka uhane o ka poe popilikia; Alaila, e puka mai no kou malamalama maloko o ka pouli, A e like auanei kou pouli me ke awakea:
\q1 
\v 11 A na Iehova no e alakai mau loa ia oe, A nana no hoi e hoomaona ia oe maloko o na aina maloo, A nana no hoi e hooikaika i kou mau iwi; A e like auanei oe me ka mahinaai i hoomau maikai ia, E like hoi me ka waipuna i maloo ole na wai.
\q1 
\v 12 O ka poe mai loko aku ou, na lakou no e hana hou i na wahi neoneo kahiko, A e kukulu hou hoi maluna o na kumu o na hanauna he nui loa; A e kapaia no hoi oe, Ka mea hana hou i kahi naha, Ka mea hoihoi mai i na alanui, i wahi e noho ai.
\b
\q1 
\v 13 Ina e malama oe i kou wawae i ko'u la Sabati, Aole hoi e hana i kou lealea i ko'u la hoano; A kapa aku hoi i ka la Sabati, ho olioli, Ka mea hemolele o Iehova, a me ka nani; A hoomaikai hoi oe ia, me ka hana ole i kou mau aoao, Aole me ka imi i kou lealea iho, Aole hoi me ka olelo i kau mau olelo iho;
\q1 
\v 14 Alaila, e olioli no oe ia Iehova; A na'u no e hooholo ia oe ma na wahi kiekie o ka honua, A e hanai aku au ia oe i ka hooilina a Iakoba, a kou kupunakane; No ka mea, na ka waha o Iehova i olelo mai.
\c 59
\b
\q1 
\v 1 A IA hoi, aole i pokole ka lima o Iehova, I mea e ole ai ia e hoola; Aole hoi i kaumaha kona pepeiao, I mea e ole ai ia e hoolohe;
\q1 
\v 2 Aka, ua kaupale no ko oukou mau hewa mawaena o oukou, a me ko oukou Akua, A ua huna ko oukou mau hala i kona maka, mai o oukou aku, I ole oia e hoolohe mai.
\q1 
\v 3 No ka mea, ua paumaele ko oukou mau lima i ke koko, A me ko oukou manamana lima i ka hewa; Ua olelo no ko oukou mau lehelehe i ka wahahee, A ua olelo ko oukou alelo i ka hewa.
\q1 
\v 4 Aohe mea i hea aku ma ka pono, Aohe mea hooponopono ma ka oiaio. Hilinai no lakou ma ka lapuwale, a olelo no hoi i ka wahahee; Hapai no lakou, he kolohe, a hanau mai hoi, he hewa.
\q1 
\v 5 Hoomoe no lakou i na hua o na moopepeiaohao, A ulana lakou i ka punawelewele o ka lanalana: O ka mea ai i ka lakou hua, make no ia, A i ka wa i hoopepeia'i ia, puka mai no he moonihoawa.
\q1 
\v 6 Aole e lilo ana ko lakou punawelewele i aahu, Aole hoi lakou e uhi ia lakou iho i ka lakou hana. O ka lakou mau hana, he mau hana ia no ka hewa, Aia ma ko lakou lima ka hana hookaumaha.
\q1 
\v 7 Holo no ko lakou wawae i ka hewa, A hoowikiwiki lakou i ka hookahe koko hala ole; O ko lakou mau kuka, he mau kuka no ka hewa; Aia no ka luku, a me ka make ma ko lakou kuamoo.
\q1 
\v 8 Aole lakou ike i ka aoao o ka malu, Aole hoi ho pono ma ko lakou hele ana; Ua hana lakou i ala kekee no lakou; O ka mea hele malaila, aole ia e ike i ka malu.
\b
\q1 
\v 9 Nolaila, ua loihi ka pono mai o makou aku, Aole hahai ka hooponopono ia makou a loaa; Kakali no makou i ka malamalama, aia hoi, he pouli; A i ke alohilohi hoi, aka, ke hele nei makou ma ka poeleele.
\q1 
\v 10 Ke kolo nei makou e hana i ka pa, me he makapo la, Ke kolo nei no makou, me he mea maka ole la, Kulanalana makou i ke awakea, e like me ka po; Me he poe make la, maloko o na wahi momona.
\q1 
\v 11 Uwo no makou a pau, e like me na bea, A kaniuhu nui no hoi, e like me na manu nunu. Kakali no makou i ka hoopono, aole hoi, A i ke ola hoi, a ua mamao aku ia mai o makou aku.
\q1 
\v 12 No ka mea, ua hoonuia ko makou hewa imua ou, A o ko makou hewa ka mea hoike ku e ia makou; No ka mea, me makou no ko makou hewa, A ua ike hoi makou i ko makou hala;
\q1 
\v 13 I ke kipi ana, a i ka hoole ana ia Iehova, I ka huli ana hoi, mai ka hahai ana i ko makou Akua, E kamailio ana i ka alunu, a me ka hoi hope, E manao ana a e hai ana hoi, mai loko aku o ka naau i na olelo wahahee.
\q1 
\v 14 A ua hoohuli hope ia ka hoopono, Ua ku mamao aku ka pono: No ka mea, ua hina ka oiaio ma ke alanui, Aole hoi e hiki i ka pololei ke komo mai.
\q1 
\v 15 Oia, ua nele i ka oiaio; A o ka mea haalele i ka hewa, ua hoopioia; Ike mai no o Iehova, a huhu mai la ia, no ka mea, aohe pono.
\b
\q1 
\v 16 Ike iho la ia, aohe kanaka, A haohao mai la ia, no ka mea, aohe mea nana e uwao: Nolaila, no kona lima no i hoola mai nona iho, Na kona pono hoi i hookupaa ia ia.
\q1 
\v 17 No ka mea, hookomo ia i ka pono me he paleumauma la, A me ka mahiole o ke ola ma kona poo; A hookomo no hoi oia i ka lole o ka hoopai ana, i aahu nona, A aahuia oia i ka manao ikaika, me he holoku la.
\q1 
\v 18 E like me na hana, pela no oia e hoouku ai, O ka inaina i ka poe ku e ia ia; E hoopai no oia i kona poe enemi; E hoouku no oia i ko na aina e.
\q1 
\v 19 A e makau no lakou i ka inoa o Iehova, mai ke komohana mai, A i kona nani hoi, mai ka puka ana a ka la mai; I ka wa e komo mai ai ia e like me ke kahawai haiki, Na ka Uhane o Iehova e kau ana i ka hae ku e.
\b
\q1 
\v 20 A e hele mai no ka Hoolapanai i Ziona, A i ka poe no hoi i huli, mai ka hewa mai, mawaena o ka Iakoba, wahi a Iehova.
\q1 
\v 21 Owau hoi, eia ka'u berita me lakou, wahi a Iehova; O kuu Uhane, ka mea maluna ou, A me ka'u mau olelo, a'u i waiho ai iloko o kou waha, Aole e haalele ia mau mea i kou waha, Aole hoi i ka waha o kau mau keiki, Aole hoi i ka waha o na keiki a kau mau keiki, Mai keia wa aku, a i ke ao pau ole, Wahi a Iehova.
\c 60
\b
\q1 
\v 1 E KU iluna, i malamalama, No ka mea, ua hiki mai kou malamalama, A ua puka mai no ka nani o Iehova maluna ou.
\q1 
\v 2 No ka mea, aia hoi, e uhi mai no ka poeleele i ka honua, A o ka pouli loa hoi i na kanaka; Aka, e puka mai no o Iehova maluna ou, A ikeia hoi kona nani maluna ou.
\q1 
\v 3 A e hele mai no ko na aina e i kou malamalama, A o na'lii hoi i ka alohilohi o kou puka ana iluna.
\b
\q1 
\v 4 E alawa ae i kou mau maka iluna, e nana mai o a o; Ua akoakoa mai nei lakou a pau, ua hele mai iou la: E hele mai no kau mau keikikane mai kahi loihi mai, A e halihaliia kau mau kaikamahine ma ka aoao.
\q1 
\v 5 Alaila, e ike aku oe, a e olioli hoi, A e lelele kou houpo i ka olioli, a e hoakeaia kou naau, I ka wa e hoohuliia mai iou la ka waiwai o ka moana, A hele mai hoi ia oe na mea ikaika o na aina e.
\q1 
\v 6 E uhi mai no ka lehulehu o na kamelo ia oe, O na kamelo mama hoi o Midiana, a me Epa, E hele mai no hoi na mea a pau o Seba; E lawe mai no lakou i ke gula a me ka libano, A e hoikeike lakou i na mea nani o Iehova.
\q1 
\v 7 E hoakoakoaia mai iou la na holoholona a pau o Kedara, E lawelawe na hipakane o Nebaiota nau; E pii mai no lakou maluna o ko'u kuahu me ka oluoluia'ku, A e hoonani no au i ko'u hale nani.
\q1 
\v 8 Owai keia poe e lele nei, me he ao la, E like hoi me na manu nunu i ko lakou mau pukahale?
\q1 
\v 9 He oiaio no, e kakali ko na aina ia'u, A o na moku o Taresisa na mea mua, E lawe mai i kau mau keikikane, mai kahi mamao aku, I ko lakou kala, a me ko lakou gula pu me lakou, No ka inoa o Iehova, o kou Akua, A no ka Mea Hemolele o ka Iseraela, No ka mea, ua hoonani mai oia ia oe.
\b
\q1 
\v 10 Na na keiki a ka malihini e hana i kou mau pa, A na ko lakou alii e lawelawe nau; No ka mea, i ko'u ukiuki, hahau aku no au ia oe, Aka, i ko'u lokomaikai, ua aloha aku au ia oe.
\q1 
\v 11 Nolaila, e hamama mau no kou mau pukapa, Aole lakou e paniia i ke ao, aole i ka po, I lawe mai ai na kanaka iou la i ka waiwai o ko na aina e, I alakaiia mai ai hoi ko lakou poe alii.
\q1 
\v 12 No ka mea, o ka lahuikanaka, a me ke aupuni hookauwa ole nau, e make ia; Oia, e anai loa ia kela mau lahuikanaka.
\q1 
\v 13 E hele mai no iou la ka nani o Lebanona, O ka laau kaa, o ka tidara, a me ka tiasura pu, E hoonani ai i kahi o ko'u keenakapu, A e hoohanohano wau i kahi o kou mau wawae.
\q1 
\v 14 O na keiki hoi a ka poe i hookaumaha ia oe, E hele kulou mai no lakou imua ou; A o ka poe a pau i hoowahawaha ia oe, E kulou no lakou ma na kapuwai o kou mau wawae; A e kapa aku no lakou ia oe, O ke kulanakauhale o Iehova, O ka Ziona hoi o ka Mea Hemolele o ka Iseraela.
\b
\q1 
\v 15 No kou haaleleia, a no kou huhuia, I hele ole ai ke kanaka mawaena ou, E hoolilo no wau ia oe i mea hanohano mau loa, He mea olioli hoi, ia hanauna aku, ia hanauna aku.
\q1 
\v 16 E omo no oe i ka waiu o ko na aina e, Ma ka u o na'lii kau e omo ai, A e ike auanei oe, owau, o Iehova kou Ola, A o kou Hoolapanai, oia ka Mea Mana o ka Iakoba.
\q1 
\v 17 No ke keleawe, e lawe mai au i ke gula, A no ka hao, e lawe mai au i ke kala, A no ka laau, he keleawe, a no na pohaku, he hao; E hoolilo no hoi au i kou poe kiai, i poo hoomalu, A me kou poe luna, i poe hoopono.
\q1 
\v 18 Aole e lohe hou ia ka hao wale ana ma kou aina, Aole hoi ka hookaumaha, a me ka anai ana, ma kou mau mokuna; Aka, e kapa iho no oe i kou mau pa, He ola, A me kou mau pukapa hoi, He hoonani.
\q1 
\v 19 O ka la, aole ia o kou malamalama hou aku ma ke ao, Aole hoi e hoomalamalama mai ka mahina ia oe, no ka alohilohi; Aka, o Iehova auanei kou malamalama mau loa, A o kou Akua hoi kou hanohano.
\q1 
\v 20 Aole e napoo hou kou la, Aole hoi e laweia'ku kou mahina: No ka mea, o Iehova auanei kou malamalama mau loa, A e pau auanei na la o kou kumakena ana.
\q1 
\v 21 A e lilo auanei kou poe kanaka, i poe pono; A e noho mau loa no hoi lakou ma ka aina, O ka lala a'u i kanu ai, o ka hana hoi a kuu mau lima, I hoomaikaiia mai ai au.
\q1 
\v 22 E lilo auanei ka mea uuku i hookahi tausani, A o ka mea liilii i lahuikanaka ikaika: Owau, o Iehova, e hoowikiwiki no au ia i kona manawa.
\c 61
\b
\q1 
\v 1 EIA no maluna o'u ka Uhane o Iehova, ka Haku, No ka mea, ua poni mai o Iehova ia'u, E hai i ka olelo maikai i ka poe hoohaahaa; Ua hoouna mai oia ia'u e wahi i ha naau ehaeha, E hai aku i ke kuu ana no ka poe i pio, A me ka wehe ana o ka halepaahao no ka poe i paa;
\q1 
\v 2 E hai aku hoi i ka makahiki oluolu no Iehova, A me ka la o ka inaina o ko kakou Akua; E hoomaha hoi i ka poe i kaniuhu;
\q1 
\v 3 A e kokua aku i ka poe i u ma Ziona, E haawi i kahiko ma kahi o ka lehu, A me ka manoi o ka olioli no ke kaniuhu ana; A me ka aahu o ka hauoli hoi no ka naau kaumaha: I kapaia lakou, He mau oka no ka pono, O ke kanu ana hoi a Iehova, i hoonaniia'i oia.
\b
\q1 
\v 4 E hana hou no lakou i na wahi i anaiia mamua, A e hoala hou no lakou i na mea i hoohiolo kahiko ia, A e kukulu hou lakou i na kulanakauhale i wawahiia, I na mea neoneo hoi o na hanauna he nui loa.
\q1 
\v 5 A e ku mai no na malihini, a e hanai i ka oukou poe holoholona, A e lilo na keiki a ke kanaka e, i poe mahiai, a i poe paipai waina na oukou.
\q1 
\v 6 Aka, e kapaia oukou, Na kahuna o Iehova, E olelo no lakou ia oukou, He poe lawelawe na ko kakou Akua; E ai no oukou i ka waiwai o ko na aina e, A ma ko lakou nani oukou e kaena'i.
\b
\q1 
\v 7 No ko oukou hilahila, a e uku palua ia oukou, A no ka hoopalaimaka e olioli lakou i ko lakou kuleana; Nolaila, ma ko lakou aina, e loaa palua lakou, E loaa no ia lakou ka olioli mau loa.
\q1 
\v 8 No ka mea, owau o Iehova, ke makemake nei au i ka hoopono, Ua wahawaha aku au i ka mea i haoia, Ma ka oiaio, e haawi no wau i ka uku no ka lakou hana; A e hana no wau i berita mau loa me lakou.
\q1 
\v 9 A e kaulana auanei ka lakou hanauna iwaena o ko na aina e, A me ka lakou poe keiki, iwaena o na lahuikanaka; O ka poe a pau e ike ia lakou, e hoomaopopo no ia lakou, O lakou ka hanauna a Iehova i hoopomaikai ai.
\b
\q1 
\v 10 E olioli nui au ia Iehova, E hauoli no ko'u uhane ma ko'u Akua; No ka mea, ua hoaahu mai oia ia'u i na aahu o ke ola, Ua uhi mai oia ia'u i ka holoku o ka pono, E like me ka hoonani ana o ke kanemare ia ia iho i na kahiko, E like hoi me ka wahinemare i kahikoia i kona mea gula.
\q1 
\v 11 No ka mea, e like me ka honua i hoopuka mai ai i kona muo, E like hoi me ka mahinaai i houlu i na mea i luluia maloko ona, Pela no o Iehova ka Haku e hoopuka mai ai i ka pono, a me ka nani, imua o ko na aina a pau.
\c 62
\b
\q1 
\v 1 NO Ziona, aole au e noho ekemu ole, A no Ierusalema, aole au e noho hoomaha, A puka aku la kona pono, e like me ka malamalama, A me kona ola, e like me ka lama e a ana.
\q1 
\v 2 A e ike auanei ko na aina e i kou pono, A o na'lii a pau i kou nani; A e kapaia no hoi oe ma ka inoa hou, Ka mea a ka waha o Iehova e kapa ai.
\q1 
\v 3 E lilo no oe i papale alii nani loa, ma ka lima o Iehova, A i lei alii maikai, ma ka lima o kou Akua.
\q1 
\v 4 Aole oe e i hou ia, o Azuba; Aole hoi e kapa hou ia kou aina, o Semama; Aka, e kapaia no oe, o Hepeziba, A o kou aina hoi, o Beula; No ka mea, ua aloha mai o Iehova ia oe, A e mareia hoi kou aina.
\b
\q1 
\v 5 No ka mea, e like me ka mare ana o ke kanaka opiopio i ka wahine puupaa, Pela no e mare ai kau mau keikikane ia oe. E like hoi me ka olioli ana o ke kanemare i ka wahine i mare hou ia, Pela no e olioli ai kou Akua ia oe.
\b
\q1 
\v 6 Ua hoonoho wau i poe kiai, maluna o kou mau papohaku, e Ierusalema. A po ka la, a ao ka po, aole lakou e noho ekemu ole; O oukou hoi, ka poe hookaulana ia Iehova, Mai hoomaha oukou ia oukou iho;
\q1 
\v 7 Aole hoi e haawi ia ia i ka hoomaha, A hoala hou oia ia Ierusalema, A hoolilo ia ia i mea nani ma ka honua.
\q1 
\v 8 Ua hoohiki no o Iehova ma kona lima akau, ma ka lima o kona ikaika hoi; He oiaio, aole au e haawi hou i kau palaoa i mea ai na kou poe enemi, Aole e inu na keiki a ka malihini i kou waina, Ka mea au i hooikaika ai.
\q1 
\v 9 Aka, o ka poe i hooiliili i ka ai, na lakou ia e ai, A e hoomaikai aku hoi ia Iehova; A o ka poe nana i houluulu i ka waina, Na lakou ia e inu ma ko'u mau pa hoano.
\b
\q1 
\v 10 E hele ae, e hele ae, a iloko o na pukapa, E hoomakaukau i ke ala no na kanaka; E hoouka, e hoouka i ke kuamoo, E hoopau i na pohaku; E kau hoi i ka hae no na kanaka.
\q1 
\v 11 Aia hoi, ua hoolaha aku o Iehova a i na kukulu o ka honua, E i aku oukou i ke kaikamahine o Ziona, Aia hoi, ke hele mai nei kou Ola; Aia hoi, me ia pu no kana uku mai, A o kana ukuhana hoi ma kona alo.
\q1 
\v 12 A e kapa aku lakou ia poe, He poe kanaka hoano, Ka poe i hoolapanaiia e Iehova; A e kapaia no hoi oe, o Imiia, He kulanakauhale haalele ole ia.
\c 63
\b
\q1 
\v 1 O WAI keia e hele mai nei, mai Edoma mai? Me ka aahu i hooluuulaia, mai Bozera mai? O keia mea hoi i nani kona lole komo, E hele ana me ka manomano o kona ikaika? Owau, ka mea hai i ka pono, ka mea mana loa i ka hoola.
\q1 
\v 2 No ke aha la i ulaula ai kou lole komo, A like hoi kou lole komo, me ka mea hahi maloko o kahi kaomi waina?
\q1 
\v 3 Ua hahi no wau i kahi kaomi waina, owau wale, Aohe mea o na kanaka pu me au. E hehi no wau ia lakou i ko'u ukiuki, E hahahi no wau ia lakou i ko'u inaina. E kapipi no ko lakou koko i ko'u mau lole komo, A hoopalahea no wau i ko'u aahu a pau.
\q1 
\v 4 No ka mea, aia no iloko o ko'u naau ka la o ka hoopai ana, Ua hiki mai hoi ka makahiki o ko'u poe hoolapanaiia.
\q1 
\v 5 Nana aku la au, aohe mea nana e kokua; A haohao iho la au, no ka mea ole nana e koo: Nolaila, na ko'u lima no i hoola no'u iho, A o kuu inaina, oia ka i koo mai ia'u.
\q1 
\v 6 Ua hahi no au i na kanaka ilalo i kuu ukiuki, Ua haawi aku no au e ona lakou i ko'u inaina, A hoohaahaa au i ko lakou koko ilalo a ka honua.
\b
\q1 
\v 7 O ke aloha o Iehova ka'u o hoikeike aku ai, O na mea nani hoi o Iehova, E like me na mea a pau a Iehova i hana mai ai ia makou, A me ka lokomaikai nui i ko ka hale o Iseraela, Ka mea ana i hana mai ai, ma kona lokomaikai, A ma ka nui loa hoi o kona aloha.
\q1 
\v 8 No ka mea, olelo mai no oia, He oiaio, o ko'u poe kanaka lakou, he poe keiki wahahee ole; Nolaila oia i lilo ai i mea hoola no lakou.
\b
\q1 
\v 9 I ko lakou popilikia a pau, aole ia he enemi, Aka, na ka anela o kona alo lakou i hoola; A no kona aloha, a no kona lokomaikai, hoolapanai oia ia lakou; A hapai ae la oia, a kaikai aku la ia lakou, i na la a pau o ka wa kahiko.
\b
\q1 
\v 10 Aka, kipi no lakou, a hoeha aku la i kona Uhane Hemolele; Nolaila oia i huli ai i enemi no lakou, A kaua mai no hoi ia lakou.
\q1 
\v 11 Alaila, hoomanao iho la kona poe kanaka i na la kahiko ia Mose, Auhea ka mea nana lakou i lawe, mai loko mai o ke kai, Me ke kahu ohana hipa? Auhea hoi ka mea nana i waiho i kona Uhane Hemolele iwaenakonu ona?
\q1 
\v 12 Ka mea i alakai ia lakou me ka lima akau o Mose, O ka lima no ia o kona nani, Ka mea i hookaawale i ka wai imua o ko lakou alo, I mea e hookaulana mau loa ia'i kona inoa?
\q1 
\v 13 E alakai ana ia lakou maloko o ka hohonu, E like me ka lio ma ka waoakua, I ole lakou e kulanalana?
\q1 
\v 14 E like me ka bipi, i iho ilalo i kahawai, Pela no i hoomaha ai ka Uhane o Iehova ia ia; Pela hoi kau i alakai ai i kou poe kanaka, I mea e hana'i i inoa kaulana loa nou.
\b
\q1 
\v 15 E nana mai oe, mai ka lani mai, E ike mai hoi, mai kahi noho ai o kou pono, a me kou hanohano; Auhea kou manao nui ana, a me kou ikaika? Ke kani ana o kou opu, a me kou aloha ia'u? Ua uumiia anei ia?
\q1 
\v 16 He oiaio no, o oe no ko makou Makua, Aole nae i ike mai o Aberahama ia makou, Aole hoomaopopo mai o Iseraela ia makou; O oe, o Iehova no ko makou Makua, a me ko makou Hoolapanai, Mai ka wa kahiko loa mai no kou inoa.
\b
\q1 
\v 17 E Iehova, no ke aha la oe i hooauwana ia makou mai kou mau aoao aku? A ua hoopaakiki hoi i ko makou naau, i makau ole aku ai ia oe? E hoi mai oe, no kau mau kauwa, A no na ohana o kou hooilina.
\q1 
\v 18 Ua noho iki wale no kou poe kanaka laa, Ua hahi ko makou poe enemi maluna o kou wahi hoano.
\q1 
\v 19 Mai ka wa kahiko mai makou; Aole noho alii oe maluna o lakou, Ka poe i kapa ole ia ma kou inoa.
\c 64
\b
\q1 
\v 1 I NA oe e wahi i na lani, a iho hoi ilalo, I hehee na mauna imua o kou alo,
\q1 
\v 2 E like me ke ahi i hoa i ka laau liilii, A me ke ahi i hoolapalapa ai i ka wai, I mea e hookaulana'i i kou inoa iwaena o kou poe enemi, I haalulu hoi na lahuikanaka imua o kou alo!
\q1 
\v 3 Me kau i hana'i i na mea weliweli a makou i manao ole ai, No ka mea, iho mai no oe, i hehee na mauna imua o kou alo.
\q1 
\v 4 Mai ka wa kahiko loa mai, aole i lohe lakou, aole i komo i ka pepeiao, Aole hoi i ike aku ka maka i ke Akua e ae, ke kaawale oe, I hana pela i ka mea kakali ia ia.
\q1 
\v 5 Ua kuikahi no oe me ka mea olioli i ka hana i ka pono, Ka mea e hoomanao ia oe ma kou mau aoao; Aia hoi, ua huhu mai no oe, no ka mea, ua hana hewa makou; Maloko o kela mau mea, ua oia mau no, A e hoolaia no hoi makou.
\q1 
\v 6 Aka, ua like no makou a pau me ka mea haumia, Ua like hoi ko makou pono a pau me ke kapa pea; A mae wale no hoi makou a pau, e like me ka lau; A ua kaikai aku no ko makou hewa ia makou, e like me ka makani.
\q1 
\v 7 Aohe mea i hea aku i kou inoa, A hoala ia ia iho e hooikaika aku ma ou la; No ka mea, ua huna oe i kou maka, mai o makou aku, A ua hoomaule hoi ia makou no ko makou mau hewa.
\b
\q1 
\v 8 Ano la, o oe, e Iehova, ko makou Makua, O makou no ka lepo, o oe ko makou potera; A o makou no a pau ka hana a kou lima.
\b
\q1 
\v 9 Mai ukiuki nui mai oe, e Iehova, Mai hoomanao mau loa hoi i ka hewa: Aia hoi, ke nonoi aku nei makou ia oe, e nana mai, O makou no a pau kou poe kanaka.
\q1 
\v 10 Ua lilo no kou mau kulanakauhale laa i waonahele, He waonahele o Ziona, He wahi neoneo o Ierusalema.
\q1 
\v 11 O ko makou hale laa, a nani hoi, Kahi a ko makou poe makua i hoonani ai ia oe, Ua pau ia i ke ahi; A ua anaiia hoi ko makou mau mea maikai a pau.
\q1 
\v 12 E uumi anei oe ia oe no keia mau mea, e Iehova? E noho ekemu ole anei oe, a e hoopilikia loa mai ia makou?
\c 65
\b
\q1 
\v 1 U A haliu au i ka ka poe nonoi ole mai ia'u, Ua loaa no wau i ka poe imi ole ia'u: I ko ka aina i hea ole ia ma ko'u inoa, ua olelo no au, E nana mai ia'u, e nana mai ia'u.
\b
\q1 
\v 2 A po ka la, ua hohola aku au i ko'u mau lima i ka poe kanaka kipi, I ka poe i hele ma ka aoao pono ole, mamuli o ko lakou manao iho.
\q1 
\v 3 He poe kanaka hoonaukiuki mau loa mai ia'u ma ko'u alo, He poe mohai aku ma na mahinaai, A kuni hoi i ka mea ala, maluna o na pohaku lepo:
\q1 
\v 4 He poe noho iwaena o na ilina, A moe hoi ma na wahi i hoonaloia, He poe ai i ka io puaa, a me ka supa o na mea haumia, maloko o ko lakou kiaha:
\q1 
\v 5 He poe olelo, E hookaawale oe ia oe ihe, mai hoopili mai ia'u, No ka mea, ua oi aku ko'u pono i kou. He uwahi no keia poe ma kuu ihu, He ahi no o a ana, a po ka la.
\q1 
\v 6 Aia hoi, ua palapalaia imua o ko'u alo; Aole au e noho ekema ole, e uku aku no wau, E uku aku no wau, maloko o ko lakou poli,
\q1 
\v 7 I ko oukou mau hewa, a me na hewa o ko oukou poe makua pu, wahi a Iehova, I ka poe i kuni i ka mea ala, maluna o na mauna, A olelo hoino mai ia'u, maluna o na puu; Nolaila, e ana aku au i ka lakou hana kahiko, maloko o ko lakou poli.
\b
\q1 
\v 8 Ke olelo mai nei o Iehova penei, E like me ka waina hou i loaa maloko o ka huhuiwaina, A olelo kekahi, Mai kiola ia, no ka mea, maloko ona ka mea e pomaikai ai, Pela no wau e hana'i no ka'u poe kauwa, I ole ai au e luku ia lakou a pau.
\q1 
\v 9 A e hoopuka no wau i ka hua, mailoko mai o Iakoba, A mai loko mai hoi o Iuda, i hooilina no ko'u mau kuahiwi, Na ko'u poe i waeia e komo ia, A na ka'u poe kauwa e noho malaila.
\q1 
\v 10 A e lilo no o Sarona i pa no na hipa, A o ke kahawai o Akora i wahi moe no na bipi, No ko'u poe kanaka i imi mai ai ia'u.
\b
\q1 
\v 11 Aka, o oukou ka poe haalele ia Iehova, A hoopoina hoi i ko'u mauna hoano, Ka poe hoomakaukau i ka papaaina no Gada, A hoomakaukau hoi i ka waina ala no Meni.
\q1 
\v 12 O oukou ka'u e helu aku ai no ka pahikaua, A e kulou oukou a pau i ka make; No ka mea, ia'u i hea aku ai, aole oukou i o mai, Ia'u i olelo ai, aole oukou i hoolohe; Aka, hana hewa no oukou imua o ko'u mau maka, A koho oukou i ka mea a'u i makemake ole ai.
\b
\q1 
\v 13 Nolaila, ke olelo mai nei o Iehova, ka Haku, Aia hoi, e ai no ka'u poe kauwa, aka, e pololi ana oukou; Aia hoi, e inu no ka'u poe kauwa, aka, e makewai ana oukou; Aia hoi, e olioli no ka'u poe kauwa, aka, e hilahila ana oukou:
\q1 
\v 14 Aia hoi, e oli no ka'u poe kauwa no ka hauoli o ka naau, Aka, e uwe ana oukou no ke kaumaha o ka naau, A e aoa ana no hoi no ka nahaehae ana o ka uhane.
\q1 
\v 15 A e hooili aku oukou no ko'u poe i waeia i ko oukou inoa i mea e poino ai; No ka mea, e pepehi mai no o Iehova, ka Haku, ia oe, A e kapa iho i kana poe kauwa ma ka inoa e.
\q1 
\v 16 O ka mea hoopomaikai ia ia iho ma ka honua, E hoopomaikai oia ia ia ma ke Akua oiaio; A o ka mea hoohiki ma ka honua, E hoohiki oia ma ke Akua oiaio; No ka mea, ua poinaia na kaumaha kahiko, A no ka mea hoi, ua hunaia lakou mai ko'u mau maka aku.
\b
\q1 
\v 17 No ka mea, aia hoi, e hana ana au i lani hou, a i honua hou, Aole hoi e hoomanao hou ia ua mau mea kahiko la, Aole no e komo iloko o ka manao.
\q1 
\v 18 E olioli hoi oukou, a e hauoli mau loa i kela mea a'u e hana'i; No ka mea, aia hoi, e hana ana au ia Ierusalema i mea e olioli ai, A i kona poe kanaka hoi, i mea e hauoli ai.
\q1 
\v 19 A e olioli no wau ia Ierusalema, A e hauoli hoi i ko'u poe kanaka: Aole e lohe hou ia maloko ona, ka leo o ka uwe ana, A me ka leo o ke kumakena.
\q1 
\v 20 Aole e loaa hou malaila ke keiki hoopiha ole i na la, Aohe hoi kanaka elemakule i hoopiha ole i kona mau la: No ka mea, e make no ke keiki, hookahi haneri makahiki, Aka, o ka mea i hana hewa, hookahi haneri ona mau makahiki, E poino ana ia.
\q1 
\v 21 E kukulu hale no lakou, a e noho iloko, A e kanu no lakou i na pawaina, A e ai no hoi i ka hua o lakou.
\q1 
\v 22 Aole lakou e kukulu, a na hai e noho, Aole lakou e kanu, a na hai e ai; No ka mea, e like me na la o ka laau, Pela no na la o ko'u poe kanaka, A e noho no ko'u poe i waeia ma ka hana a ko lakou lima.
\q1 
\v 23 Aole e make hewa ka lakou hana ana, Aole hoi lakou e hanau no ka make; No ka mea, o lakou ka hua a ka poe pomaikai ia Iehova, A me ka lakou poe keiki pu me lakou.
\q1 
\v 24 Eia hoi, mamua o ko lakou hea ana, e ae aku no wau; A ia lakou e olelo ana, e hoolohe no au.
\q1 
\v 25 E ai pu no ka iliohae me ke keikihipa, A e ai no ka liona i ka mauu maloo e like me ka bipi; A o ka lepo auanei ka ai a ka nahesa. Aohe mea hana ino, aohe mea pepehi ma ko'u mauna hoano a pau, wahi a Iehova.
\c 66
\b
\q1 
\v 1 PEIA ka Iehova e olelo mai nei, O ka lani no ko'u noho alii, a o ka honua hoi ko'u keehana wawae: Auhea ka hale a oukou e hana mai ai no'u? Auhea hoi ko'u wahi e hoomaha'i?
\q1 
\v 2 No ka mea, na ko'u lima no i hana ia mau mea a pau, A eia no hoi lakou a pau e noho la, wahi a Iehova; Aka, e nana aku au i keia, i ka mea i haahaa, a mihi hoi ma ka naau, A haalulu i ka'u olelo.
\b
\q1 
\v 3 O ka mea kalua i ka bipi, he pepehi kanaka ia, O ka mea mohai i ka hipa, hai no oia i ka a-i o ka ilio: O ka mohai makana, he koko puaa no ia; O ka mea kuni i ka mea ala, hoomaikai no oia i ke akuakii; Oia, ua koho lakou i ko lakou aoao iho, A olioli no ko lakou naau i ko lakou mea hoopailua.
\q1 
\v 4 E koho no hoi au i ko lakou poino, A na'u hoi e hooili aku maluna o lakou, i ko lakou mea e weliweli ai; No ka mea, ia'u i hea aku ai, aohe mea i o mai, Ia'u i olelo aku ai, aole lakou i hoolohe: Aka, hana hewa no lakou imua o ko'u mau maka, A koho no hoi i ka mea a'u i makemake ole ai.
\b
\q1 
\v 5 E hoolohe oukou i ka olelo a Iehova, E ka poe haalulu i kana olelo; O ko oukou poe koahanau, ka poe i ukiuki mai ia oukou, Ka poe i kipaku aku ia oukou iwaho, no ko'u inoa, I ae la lakou, E hoonaniia o Iehova: A e ikeia no ia, i mea e hauoli ai oukou, Aka, e hilahila auanei lakou.
\q1 
\v 6 He leo no ka walaau, mai ke kulanakauhale mai. He leo mai ka luakini mai, ka leo o Iehova e hoopai ana i kona poe enemi.
\b
\q1 
\v 7 Mamua o kona kuakoko ana, hanau mai la oia, Mamua o ka hiki ana mai o kona nahu, Hanau mai la oia, he keikikane.
\q1 
\v 8 Owai ka mea i lohe i ka mea o like me ia? Owai ka mea i ike i na mea o like me ia? E hoohanauia mai anei ka honua i ka la hookahi? E hanau anei ka lahuikanaka ma ka minute? No ka mea, ia Ziona i kuakoko mua ai, hanau mai la no kana mau keiki.
\q1 
\v 9 E hookokoke anei au i ka hanau, aole hoi e hoohanau mai? wahi a Iehova: E hoohanau anei au, alaila papani aku? wahi a ke Akua ou.
\q1 
\v 10 E olioli pu no oukou me Ierusalema, A e hauoli pu no hoi me ia, e ka poe a pau i aloha aku ia ia: E olioli nui loa ia ia, e ka poe a pau i kanikau ia ia.
\q1 
\v 11 I omo oukou, a maona hoi ma ka puu waiu o kona hoomaha ana, I uwi aku oukou, a olioli i ka nui o kona nani.
\q1 
\v 12 No ka mea, ke olelo mai nei o Iehova penei, Aia hoi, e hohola aku no au i ka malu maluna ona, me he muliwai la, A i ka nani o ko na aina, e like me ka wai kahe e halana ana; Alaila, e omo no oukou, e kaikaiia hoi ma ka aoao, A e hiiia hoi ma na kuli.
\q1 
\v 13 E like me ka mea a kona makuwahine i hoomaha ai, Pela no wau e hoomaha aku ai ia oukou, A e hoomahaia oukou ma o Ierusalema la.
\q1 
\v 14 A ike oukou ia, e olioli no ko oukou naau, A e ulu no ko oukou mau iwi, e like me ka laalaau: A e ikeia auanei ka lima o Iehova, maluna o kana poe kauwa, A me kona ukiuki maluna o kona poe enemi.
\b
\q1 
\v 15 No ka mea, aia hoi, e hele mai no o Iehova me ke ahi, A me kona mau kaakaua, e like me ka puahiohio, E hoihoi mai i kona huhu me ka ukiuki, A me kona papa ana, me na lapalapa o ke ahi.
\q1 
\v 16 No ka mea, me ke ahi no, a me kana pahikaua, E hakaka'i o Iehova me na mea io a pau: A e nui loa auanei ka poe a Iehova e pepehi ai.
\q1 
\v 17 O ka poe hoano ia lakou iho, a hoomaemae ia lakou iho ma na mahinaai, Mahope o kekahi mawaena, e ai ana i ka io o ka puaa, a me ka mea e hoopailua ai a me ka iole; E make pu no lakou, wahi a Iehova.
\q1 
\v 18 A e ike auanei au i ka lakou hana, a me ko lakou manao; No ka mea, e hoakoakoaia ko na aina a pau, a me ka poe olelo e, A e hele mai no lakou, a e ike i ko'u nani.
\q1 
\v 19 A e kau no wau i ka ouli no lakou, A o ka poe o lakou e pakele, e hoouna aku au ia lakou i na aina e, I Taresisa, i Pula, a i Luda, na mea i lena i ke kakaka; I Tubala hoi, a i Iavana, a i na aina loihi e aku, Ka poe i lohe ole i kuu kaulana, aole hoi i ike i ko'u nani; A na lakou no e hai i ko'u nani iwaena o ko na aina e.
\q1 
\v 20 A e lawe mai no lakou i ko oukou poe hoahanau a pau, Mai loko mai o na aina a pau, i mohai no Iehova, Maluna o na lio, a maloko o na kaakaua, a ma na manele, A ma na hoki, a me na kamelo mama, a i ko'u mauna hoano i Ierusalema, wahi a Iehova; E like me na mamo a Iseraela i lawe mai ai i ka mohai maloko o ka ipu maemae, A i ka hale o Iehova.
\q1 
\v 21 A e lawe no wau, noloko o lakou, i mau kahuna, a i poe lawelawe, e like me na Levi, wahi a Iehova.
\q1 
\v 22 No ka mea, e like me na lani hou, a me ka houna hou a'u e hana'i, e mau lakou imua o'u, wahi a Iehova, Pela no e mau ai ka oukou poe keiki, a me ko oukou inoa.
\q1 
\v 23 A mai kekahi mahina hou, a i kekahi mahina hou, A mai kekahi sabati, a i kekahi sabati, E hele mai no na mea io a pau e hoomana imua o'u, wahi a Iehova.
\q1 
\v 24 A e puka aku no lakou iwaho, a e nana iho i na kupapau o na kanaka i kipi mai ia'u: No ka mea, aole e make ko lakou ilo, Aole e pio ko lakou ahi, A e lilo no lakou i mea hoopailua no na mea io a pau. 
