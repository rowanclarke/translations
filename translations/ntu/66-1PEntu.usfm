\id 1PE stc-611PE-Nat.sfm, 1 Peter, Natqgu (Santa Cruz) STC, Daniel Boerger, 11/07/2007 
\ide UTF-8
\h 1 Pita 
\toc3 1 Pita 
\toc1 Nzryrkr Pita Kx Ayrnrngr 
\toc2 1 Pita 
\mt1 Nzryrkr Pita Kx Ayrnrngr  
\imt1 Natq Ngr Nzaplxtqngr Mz Nzryrkr Pita Kx Ayrnrngr  
\ip Aposol Pita yrle letz lc mz mzlir yiz 62—64 AD mz nibr nzrmcngr mz Jiszs, mzli kc tqmnc-ngrde Rom. Zbz mz yiz 67 AD sc tztqlvztrpe nide mz kros. Mzli lc Niro nide king kxetu kc Rom, x leplz kxtrnzrlxngitiung nzpibqtilr x nzaetqbzlr drtq kxnzvz-nqblqlr Jiszs.  
\ip Pita ryrbz mz lrJiu x kxtrngiulrJiu kcng tzrlxngiting mz provins kcng Pontzs, Galesia, Kapadosia, Esia x Bitinia, mz kandre kc Trki mzli ka. Pita krlzle kx leplz nzatrkatilr nidr x nzaetqbzlr drtqdr. X ryrbz badr mz nzapqtr-krbzle drtwrdr x mz nzrpi-krbzle badr kx namnclzbzng mz zmatq ngr kxetu rdrng x navz-nqblq-zvzlr me pnz drtwr Gct, kxmule-esz' da kx prtz. X rpi-kzpzle badr kx Gct rlr-ngrbzle da kxtrka nzprtilz-krdr nigu, mz nzaxplr-krde nzbrtikr drtwrgu nide.  
\c 1  
\p
\v 1 Ninge Pita, aposol ne Jiszs Kxnzmcpx. Ryrbo bamu nimu leplz kcng tqmcpx Gct mz nzngini-krmu lr mrkzbleng mz nrlc ka, murde mrnyzmu angidr Heven. Nimu kcng tzakiting nrlc mz provins kcng Pontzs, Galesia, Kapadosia, Esia x Bitinia.  
\v 2 Yrlq pnz Gct Trte drtwr kx namcpxle nimu mz nzngini-krmu doa kxnztr nedeng. X Mqngrkxtr atrle nimu x okatrle nimu mz nzvz-nqblq-krmu Jiszs Kxnzmcpx. Murde suti drtwr Gct kx naipqpxbzle alwx ngrmung mz mepyr ngr nzbzkr Jiszs. Krka'-ngrne kx Gct sa navz zvz nzkao-krbzle bamu zmrlz ngrde kxmyalz x nzmnc-zpwxngr.   
\s1 Drtwrgu Elalzm Mz Nzobqtipx-krgu Nzlungr Kxboi  
\p
\v 3-4 Na-awibzku mz Gct kc tqngi Trte Kxetu rgu Jiszs Kxnzmcpx. Murde mz zmrlz ngrde kxmyalz batrple bagu nzprtr-krgu mz nzlungr kxmrna. Lxngitiku Jiszs Kxnzmcpx kc tqatulz-mop Gct mz nzbzngr x prtr-kzku mz nzlungr kxboi. X obqtipxku da kxmrlzting amrlx kx nzyrlq-bekapxlr mz nzka-krmlrleng bagu Heven. Murde da lcng trnayrkrpxu x trnatekqtru, a' sa nayc-along.  
\v 5 A' mzli ka mz nrlc ka, zmatq ngr Gct o-ngalelvzpele nimu murde abrtrpzmu drtwrmu bade mz nzarlapx-krde nimu. X sa na-aclve-angidrle nimu navz nakrlzbzle nzyzlu-krm Jiszs. X mzli lcde, sa na-aelwapx-ate-ngrbzle bamu da kxmrlzting amrlx lcng tzvzpxmqng mz nzarlapxpe-krde nimu.   
\p
\v 6 Delc kxmule-esz' prtramu mz da kxtrka kxnzkqlung mzli kxmrbcne, a' sc tqabrtzpe-ngrnamu da lcng.  
\v 7 X da kxtrka lcng nzokatr-kzlr nimu, mz nzapu-krdr nyr kc tqayrleni-ebirngr gol, mz nzrkatx-krde zblqki rde. Murde nztu-amqngi-krmu axplrle nzrlxngiti-krmu x Gct rlr-ngrbzle nzprtzkr da lcng mz nzaxplrngr nzrlxngiti-krmu. Murde mz drtwrde nzrlxngiti-angidr-krmu myaszpx-zlwzle gol kxlqngi kx trnayc-alou. X mzli kc nayzlu-ngrm Jiszs Kxnzmcpx mz nrlc, nzrlxngiti-angidr-krmu lc nabatrpzle mz Gct nzabrtzlvz-krde nimu, nzglqpx-krde nimu, x nzamatq-krde nimu.  
\v 8 Murde kxmule-esz' trmcwamuu Kxnzmcpx, a' mrlztiamu nide x brti drtwrmu nide, mz nzelalz-zlwz-krm drtwrmu. X rblx nzrpingr nzetukr nzabrtz-krmu lc.  
\v 9 Murde kalr mrkc Heven, sa naprtramu mz bz ngr nzlxngiti-krmu Jiszs, mzli kc tqarlapx-alo-ngrde nimu.   
\p
\v 10 Profet kcng bqnc, nzpipx-pnzlr kx Gct naokatrle nimu mz zmrlz ngrde kxmyalz. Kxmule-esz' nzsuti zlwz drtwrdr nzkrlz-krdr drtwr ngr nzarlapxngr lc, a' trnzkrlzlru drtwr ngr da amrlx kcng tzpipxlr.  
\v 11 Mqngr Kraes kc tqmncpxm badr pipx-zvzle nzetqkr drtq Kxnzmcpx x da kxmrlz-esz'ngr kcng naprtzting mz nibrde. X profet lcng nasuti drtwrdr nzkrlz-krdr ncblo kznike kx nanginide Kxnzmcpx lc x myx mzli kx naprtzngr da lcdeng x nike naprtzm mz nrlc ka mzli lcde.  
\v 12 X aelwapx-ngrbz Gct badr kx natq kcng tzpipxlr trngiu dalr nzokatr-krde nidr esz'-krdr, a' ngi dalr nzokatr-krde nimu lcng tzvzmqng mz nibr nzngidatikr natqdr. Murde Mqngrkxtr kc tqatwzlro-ngrm Gct Heven rpibzle bamu kx natq profet lcng nzngidatipeng mz Jiszs Kxnzmcpx, kc tzyapwxtipxbzlr bamu mz Nrpakxmrlz. X mzli boipe enjrl nzsuti-kzngr drtwrdr nztwz-krdr drtwr ngr da lcdeng.   
\s1 Gct Kqlele Nigu Mz Nzmncngr Kxtr  
\p
\v 13 Mz nzmu-krde lcde, oliqtiamu drtwrmu mz nzvz-nqblqngr me pnz drtwrde x aclve-lzbqamu. X na-aoti txpwz drtwrmu da kxmrlzting kcng tqobqtipxamu nzrka-ngrbz bamu mzli kc nayzlu-ngrm Jiszs Kxnzmcpx.  
\v 14 X mz nzngini-krmu doa neng Gct kx nzvz-nqblqlr natqdeng, bzkq vz-nqblqamu nqmq nr nabzmu kxtrka kcng tqaleamu ena, mzli kc trkrlzkalamu nzalvztrngr angidr.  
\v 15 A' mzli ka, nzmnc-krmu natr, da kc tqwai nztrkr Gct kc tqkqlele nimu.  
\v 16 Murde rpile mz Nzryrngrkxtr kx, \qt “Nzmnc-krmu natr, murde nzmnc-krnge tr.”\qt* \x + \xo 1:16 \xt Livae 11:44-45; 19:2; 20:7\x*   
\p
\v 17 Na-aoti drtwrmu kx Gct Trtemu kc tqkrka'bzmu bade, nzmc-krde leplz rsakrlrngr. Murde sa na-ayzlubzle bam nike aleq mz nrlc ka. Mz nzmu-krde lcde, namyatitramu nide mz da amrlx kcng tqaleamu mz nzngini-krmu lr mrkzble mz nzmnc-krmu mz nrlc ka. \f + \fr 1:17 \ft Nzamatq-krgu Gct namyaszpxle nzamatq-krgu da x leplz, kxmule-esz' mrnyzgu o lr mrnyzgu. Murde mz nzngini-krgu doa nedeng, apuku lr mrkzbleng mz nrlc ka. X na-aoti zvz drtwrgu kx mrnyzgu angidr Heven. \f*   
\m
\v 18 Na-aoti kz drtwrmu kx trngiu trau o silvz o gol kc tqxpengr Gct nimu mz nzkapx-krmle nimu mz nqmq kx trmatqu kc tzaprcbz melrmqmung bamu. Murde trau x silvz x gol nzkrlzlr nztrkangr.  
\v 19 A' xpetrle nimu mz da kx myapx-esz'ngr, krlcde mepyr ngr Kxnzmcpx. Murde bz-ngrde nimu mz nzngini-krde blz kxmyapx-esz'ngr x nei sip kx lqngipx-esz'ngr.  
\v 20 Kxnzmcpx lc tqngi nei sip kx nangi blz kc tqmcpx pnz Gct mzli kc nrlc trnzwzka-ngrde. X mzli ka, sc tqaelwapxpe-ngrbz Gct bamu kx Jiszs nide lrpzki r nzarlapxngr nimu.  
\v 21 X mz nzaxvctr-krbzmu mz Jiszs, brtipe drtwrmu Gct kc tqatulz-mople nide mz nzbzngr x kabzle bade me matq-esz'ngr Heven. Mz nzmu-krde lcde, Gct txpwz kc tqabrtrpzmu drtwrmu bade x tqobqtipxamu mz nzatutr-krde da amrlx kcng tqesalz-ngrbzle bamu.   
\p
\v 22 Mz nzlxngiti-krmu Nrpa Angidr, katxpxbzle da amrlx kcng tzrpwa'-ngrdr nzmrlzti-lzbq-krmu mz nzapupe-krmu mzle-lzbqng x ile-lzbqng. X mzli ka, na-aelwapx-zvz-ngrbzmu nivz angidr lc mz kztemung mz nabzmu atwrnrngr.  
\v 23 Murde prtrpeamu mz nzlungr kxmrna, kx trpnzngr nzyrkrpx-krde. Murde vzpxm mz Jiszs Kxnzmcpx kc tqngi Natq Gct kc tqlu-alo. \x + \xo 1:23 \xt Jon 1:1-14\x*  
\v 24 Da kc tqwai, nzpikr Nzryrngrkxtr le kx, \qt “Leplz amrlx sa nayrkrpxng mz nzapu-krdr nabr kxglr. X zluli rdr apule nrpq nounc kcng tzplclqtiong.\qt*  
\v 25 \qt A' natq Kxetu yctx alo.”\qt* \x + \xo 1:25 \xt Asaea 40:6-8\x* X natq lcde ngi Nrpa ngr Kxnzmcpx kc tzyapwxtipxpebz bamu.   
\c 2  
\p
\v 1 Mz nzmu-krde lcde, yrlqpx-lzbqamu mz drtwr kx mwa, nzpokiangr, nzrkcmnzngr x nzrpibqtingr.  
\v 2 A' nasutitx zlwz drtwrmu nztwz-krmu drtwr ngr natq Gct, mz nzapu-krmu itoto kx suti txpwz drtwrde nei pqde. Murde dekc nzbrtikr drtwrmu kx rlapx-angidrpeamu naetunepx zvz.  
\v 3 X krlzpeamu kx Kxetu rgu mrlz-esz'ngr.   
\s1 Kxnzmcpx Badr Leplz Nedeng Nidr Mrkc Tqtr Nyz Gct  
\p
\v 4-5 Namnc-aepztr-zvzbzmu mz Kxnzmcpx kc tqngi Nou Rplz kc tqlu-alo. Murde apu-kzamu rplz kcng tqbatrpzle nzmwitr-lxblr-krdr mz drkq ngr ma nyzde kc tqtr, mrkc tqmncpx-ngrm Gct. A' nimu rplz kcng tzlung. X nimu kz pris kxnztr nede kcng tzwztrpzng bade, mz nzrlrpx-krbzmu bade blz ngr nzrglqlzngr nide, nzawi-ngrbz bade, nzangiongr nide x nzmnclz-ngrbz bade. X blz lcng nzmrlzng mz nzobqkr Gct murde nzaxvctrpzmu mz Jiszs Kxnzmcpx. \x + \xo 2:4-5 \xt Asaea 61:6; Rom 12:1; Filipae 4:18; Hibru 13:15-16\x* X kxmule-esz' Jiszs nide rplz kx myatxpx-zlwzbz kc tqmcpx Gct, a' kzdung leplz nzpxtxpx-ngrdr nide. \x + \xo 2:4-5 \xt Matiu 21:42; Mak 12:10; Luk 20:17; Aposol 4:11; 2 Korint 6:16; Efiszs 2:20-22\x*  
\v 6 Gct ycmnetr-ngrde Mrlxde mz Nzryrngrkxtr mz nzrpi-krde kx, \qt “Obqmamu! Murde yrlqpex kc doa mrkc Jerusalem kx apule rplz kx myatxpx-zlwzbz, murde nide kc tqngi rplz kc tzatuo kai, tqngi nou bute' kc tqmcpxx. Doa kx lxngitile nide drtqde trnamyau mz nzbrtikr drtwrde nide.”\qt* \x + \xo 2:6 \xt Asaea 28:16\x*  
\v 7 Delc, nimu kcng tzrlxngiting tqkrlzamu kx nide kxmyapxbz. A' Nzryrngrkxtr rpibzle mz leplz kcng trnzrlxngitiung kx, \qt “Rplz kc etu tzpxtxpx-ngrdr ncblo kcng tzrwz-ngrng ma, nzaelwapxngr kx nide nou rplz kc tqmyatxpx-zlwzbz.”\qt* \x + \xo 2:7 \xt Sam 118:22\x* \f + \fr 2:7 \ft Rplz lc drtwr ngrde Jiszs Kxnzmcpx. X kxnzpxtxpx-ngrdr nide drtwr ngrde ncblo kx nzmailzlr lr Israel. [Asaea 28:14] \f*   
\m
\v 8 X rpi-kzle kx, \qt “Nide rplz kx nayrputrngr leplz mz nzobqszo-krdr nide.”\qt* \x + \xo 2:8 \xt Asaea 8:14; Rom 9:33\x* X nztaong murde nzpxtxpx-ngrdr nrpa kc tqycmnetr-ngrde nide mz Nzryrngrkxtr. Krlc vz-nqblqle drtwr kc tqyrlq pnz Gct mz leplz lcng mzli kc bqnc.   
\p
\v 9 A' nimu \qt “nqvi kc tqmcpx Gct,”\qt* x \qt “pris kcng tzwztrpzng mz King rgu”\qt* Jiszs. X ni-kzpu' \qt “dzbede kxtr kc tzamnc-bekapx Gct,”\qt* murde nanginimu \qt “angidr leplz ne Gct esz'-krde.”\qt* X kqlele nimu mz nzyapwxtipx-krbzmu mz leplz zmrlz ngrde kxmyalz. X kapxmle nimu mz zmatq ngr alwx, murde naprtramu mz nzkrlz-angidr-krmu nide. \x + \xo 2:9 \xt Nzrlaszngr 19:5-6; Asaea 43:21; Jeremaea 13:11; Malakai 3:17\x*  
\v 10 Murde Nzryrngrkxtr alvztr-ngrde nigu kx \qt “mzli kc trnginipwa'muu leplz nedeng,”\qt* a' mzli ka \qt “nipemu leplz neng Gct.”\qt* X mzli kc \qt “trprtrwamuu mz nivz lrde,”\qt* a' mzli ka \qt “mrlzti-zlwzpele nimu.”\qt* \x + \xo 2:10 \xt Hosia 1:10; 2:23\x*   
\s1 Navz-nqblqku Nqmq Kr Gct Mz Nzmnc-krgu Mz Mzlir Kxtrnzrlxngitiung  
\p
\v 11 Mzlengeng x inwengeng, na-apuamu lr narnrlc x lr mrkzbleng mz nzmnc-krmu mz nrlc ka, murde mrnyzmu angidr Heven. Mz nzmu-krde lcde, bzkq rlr-lzbq-ngrbzmu mz da kxtrka kx suti drtwr nrkrdrtqmu, murde ma tzaovxiolr nimu.  
\v 12 A' nqmq krmu natubq zvz mz nzmnc-krmu mz mzlir leplz kxtrnzrlxngitiung. Murde kxmule-esz' nzycmne-atrkatilr nimu, a' sa namclr nztubqkr nqmq krmu. X kzdung nidr mwx sa nalxngiti-kzlr Jiszs x naglqpxlr Gct mzli kc nayzlu-ngrm Jiszs. \x + \xo 2:12 \xt Matiu 5:16\x*   
\s1 Namnclzbzmu Mz Zmatq Ngr Kxnzetung  
\p
\v 13 X mz nzamatq-krmu Kxetu rgu Jiszs, namnclzbzmu mz zmatq amrlx kcng tzyrlqbz bamu. Abzo mz king o gzpman kc tqaclvele nimu,  
\v 14 nakrlzbzle leplz kznike nzatwzlr-ngrdr mz nzayrplapx-krdr kxnzvz-rbrng x mz nzamatq-krdr kxnzaleng da kxmrlz.  
\v 15 Murde nzale-krmu da kxmrlz awx-nabule leplz kxdrka'ngr kcng tzpibqtilr nimu. X krlc me pnz drtwr Gct.  
\v 16 Kxnzmcpx arlapxle nimu mz nzmnclz-krbzmu mz zmatq kxtrka amrlx. Mz nzmu-krde lcde, bzkq ale-mouamu da kxdrka'ngr, a' rlrpx-lzbqamu mz nzwztr-krbzmu mz Gct.  
\v 17 Amrlueamu leplz amrlx. Mrlztiamu kztemung kxnzrlxngiting. Myatitramu Gct. X amatqamu king.   
\p
\v 18 Nimu kcng tzawz-nrbalqng, namnclzbzmu mz zmatq ngr kxetu rmung mz nzamatq-krmu nidr, kxmule-esz' nzaclve-zpwxlr nimu o nzatrkatilr nimu.  
\v 19-20 Trabrtzlvzu Gct nimu mz nzetqkr drtqmu mzli kc kxetu rmung nzayrplapx-ngrdr nimu mz nzvz-rbr-krmung. Murde takitrde nzale-krdr da lc. A' Gct sa na-abrtzlvzle nimu mz nzamatq-zvz-krmu kxetu rmung murde mrlztiamu Gct. Myapxbz mz nzetqkr drtqmu kxmule-esz' nzatrkati-krdr nimu trpnzngr noude.   
\p
\v 21 Murde suti drtwr Gct kx navz-nqblqamu Kxnzmcpx kc drtqde tqetq mz nzarlapx-krde nimu.  
\v 22 Murde Profet Asaea ycmnetr-ngrde nide mz nzrpi-krde kx, \qt “Trpnzngr alwx ngrde. X trpnzngr nzpokia-krde.”\qt* \x + \xo 2:22 \xt Asaea 53:9\x*  
\v 23 A' mzli kc tzpibqti-ngrde, trpnzngr natq kx ayzlubzle badr. \x + \xo 2:23 \xt Asaea 53:7\x* X mzli kc tzaetq-ngrbz drtqde, trpnzngr natq ngr nzamwxlrngr kx pi-mopwzle badr, a' abrtr-zvzbzle drtwrde mz Gct kc tqtubq mz nzayzlu-krbzle da mz leplz.  
\v 24 X tekqtrle nigu mz nzxpe-krde alwx rgung mz nzrtqlvztrngr nrkrdrtqde mz kros. X arlapxle nigu mz zmatq ngr alwx, murde nzmnc-krgu natubq-esz'ngr. Delc nzatakingr nide tqamrlzpe-ngrde nigu. \x + \xo 2:24 \xt Asaea 53:4-5\x*  
\v 25 Mzli kc apuamu sip kx nzmrbrng kcng tzmnc-rlrubzng mz kxetu rdr. A' mzli ka yzlupebzmu mz Kxetu kc tqaclve-angidrle nimu mz nznginipe-krmu sip nedeng. \x + \xo 2:25 \xt Asaea 53:6\x*   
\s1 Olvz Kxnzyrlzng X Ncblo Ngrdrng  
\c 3  
\p
\v 1-2 Mz nqmq lcpwz, nimu olvz kxnzyrlzng namnclzbzmu mz ncblo ngrmung. Murde kzdung nimu kcng ncblo ngrdrng trnzlxngitikalr natq Gct, kxmule-esz' tryapwxtipxpwzmuu Nrpakxmrlz badr, a' mwx nzmc-krdr nzmrlzkr nqmq krmung x nztubq-krdr, sa navectrple nidr mz Gct.  
\v 3 Bzkq angrlo-txpwzmu nrkrdrtqmu kx nalxngipx-esz'ngr, mz nzrbx-krmu nqngi narmu, nzrluti-krmu da kx ngi gol x nzpxi-krmu lrpz kx mzte luli. Murde da lcng trnzmyapxpwzung.  
\v 4 A' nzlxngipx-krmu navzpxm mz nabzmu. Murde nzlxngipxkr nabz rblx nzyrkrpx-krde mzli kc nanginipe-ngrmu blang. A' nzlxngipxngr kx vzpxm mz nabz kx vz-nabu x avzo-lzbq ngi da kx myapx-esz'ngr mz nzobqkr Gct.  
\v 5 Krlc nqmq krdr olvz kxnztrng kcng bqnc tzabrtrpzlr drtwrdr mz Gct. Murde nzlxngipx-krdr vzpxm mz nzmnclz-krbzlr mz ncblo ngrdrng.  
\v 6 Da kc tqwai Sera mz nzvz-nqblq-angidr-krde natq Ebraam, x mz nzamatq-krde nide mz nzrpi-krbzle bade nide kxetu rde. X sa na-apuamu Sera, nzmu trnamwxlrwamuu nzatrkatingr nimu mz nzale-krmu da kxmrlz.   
\p
\v 7 X mz nqmq lcpwz, nimu ncblo kxnzyrlzng namnc-zpwxamu badr olvz ngrmung, mz nzkrlz-krmu kx nzxplrkr ncblo myaszpxle nzxplrkr olvz. A' na-amatq-kzamu nidr mz nzngini-krdr kztemung kcng tzprtr-kzng mz nzlungr kxboi. Nzmnc-krmu nakxmule lc, murde Gct na-ayzlubzle nzkrka'-krmung.   
\s1 Kzdung Mzli Drtqgu Nzaetq Mz Nzale-krgu Da Kxmrlz  
\p
\v 8 X mou, nimu amrlx ngrmu namnc-zpwx-lxblramu, naycngr drtwrmu kztemung, namrlztiamu kztemung na-apulr kx mzlemung angidr, na-avzo-lzbqbzmu badr, x naokatramu nidr.  
\v 9 Bzkq ayzlubzmu da kxtrka mz da kxtrka. X bzkq pibqtiamu krkcng tzpibqtilr nimu. A' rlxtibzmu mz Gct nzamrlz-krde nidr. Murde krlc me pnz drtwrde x sa na-amrlz-kzle nimu mz nzale-krmule.  
\v 10 Murde Nzryrngrkxtr rpile kx, \qt “?Nike suti drtwrm? ?Nzlungr kxmrlz kxboi? Obq-angidr x bzkq ycmne-atrkatiq leplz. X bzkq pokiaq.\qt*  
\v 11  \qt Prszpx nqmq kxtrka. X ale zvz da kxmrlz. X nasuti drtwrm nzmnc-zpwx-krmu badr leplz mz nrwx.\qt*  
\v 12  \qt Rlxtibz ncblo kxtubq mz Yawe nzokatr-krde nide. X Yawe sa naxlrbzle nzkrka'-krde mz nzaclve-krde nide. Sa napnanatile leplz kxnzale-zvzng da kxtrka.”\qt* \x + \xo 3:12 \xt Sam 34:12-16\x*   
\p
\v 13 Nzmu kx tqvqti drtqmu nzalengr da kxmrlz, mwx trpnzngr kx na-aetqbzle drtqmu.  
\v 14 A' nzmu kx tzaetqngr drtqmu mz nzale-krmu da kxmrlz, sa namrlzbz bamu kalr. \x + \xo 3:14 \xt Matiu 5:10; Luk 6:22\x* Murde Nzryrngrkxtr rpile kx, \qt “Bzkq kxne drtqmu natq ngr nzamwxlrkr leplz nimu.”\qt* \x + \xo 3:14 \xt Asaea 8:12-13\x*  
\v 15 A' abrtrpzmu drtwrmu mz Jiszs Kxnzmcpx mz nzngini-krde Kxetu rmu. X oliq-zvzamu nzayzlu-krbzmu natq krkcng tzveatibzlr kx memule tqlxngiti-ngrnamu Jiszs x nike tqobqtipx-ngrnamu nzlungr kxboi. A' amatqamu nidr x ayzlu-ngrbzmu natqdr mz nivz.  
\v 16 Na-ale-zvzamu da kxtubq, murde narmu naopx angidr mz da amrlx. Mz nzmu-krde lcde, nzmu leplz kx tzpibqtilr nimu mz nqmq krmu kxmrlz mz nzvz-nqblq-krmu Kxnzmcpx, bzkq da kx nakxne drtqmu, murde sa na-amyatibz Gct drtqdr kalr.  
\v 17 Nzaetqngr drtqmu mz nzale-krmu da kxmrlz kx pnz drtwr Gct myaszpxle nzaetqngr drtqmu mz nzale-krmu da kxtrka.  
\v 18 Murde Kxnzmcpx kc tqtubq nzaetq-ngrbz drtqde nzwrde esz'txu mz nzxpe-krde alwx rgu, nigu leplz kxtrnztubqung, murde navzmibzle nigu mz Gct. Nrkrdrtqde nznibq, a' lu-mop mz zmatq ngr Mqngrkxtr.   
\p
\v 19-20 X mz zmatq ngr Mqngrkxtr lc, Kxnzmcpx sc tqycmnekipxpele Noa mz nzyapwxtipx-krbzle mz leplz kx suti drtwr Gct nzplzpx-krdr alwx ngrdr. A' nzpxtxpx-ngrdr nzvz-nqblq-krdr Gct. Krlc mzli kc bqnc tqwzngr Noa lcsu kc etu. Mzli lcde Gct kabzle badr mzli r nztekqtr-krdr nqmq nr drtwrdr. A' trtingr, x mzli ka mqngr leplz lcng nzatolvape-ngrng mrnyz mqngr kxnzbzpeng. X leplz nzrtqmzng kx nzrlatxpxpwzng mz nubla ngr lue. \f + \fr 3:19-20 \ft Ngalrde lcng 19-20 nzalvztr-ngrdr nigu kx nayapwxtipxbzku Nrpakxmrlz mz leplz, kxmule-esz' nzpxtxpx-ngrdr nigu, da kc tzwai-kzpzlr mz Noa. X kxmule-esz' nigu kcng tzvz-nqblqlr Gct pipzku, a' krlzle nzarlapx-krde nigu, da kc tqwaibzle mz Noa badr lr ma nyzdeng. X mou, Kxnzmcpx sa na-aovxiole enqmi rdeng amrlx x sa na-ayrplapxle krkcng tzpxtxpx-ngrdr nide, da kc tqwaibzle mz leplz kcng tzbzng mz nubla. \f*   
\m
\v 21 Leplz lcng nzrlapxng mz nubla ngr lue, da kc tqwai-kzku mz nzrlapx-krgu mz lue ngr nzwrkxtrngr, murde mzli lc brti drtwrgu nztulz-kr-mop Kxnzmcpx mz nzbzngr. Nzwrkxtrngr trngiu dalr nzrwztipxngr zblqki mz nrkrdrtqgu. A' ngi dalr nzkrka'-krbzku mz Gct nzatubqti-krde nigu x nzaopx-krbzle nargu, mz nike alem Jiszs bagu.  
\v 22 Mzli ka sc tqwxbupe me matq-esz'ngr Heven mz nrlar Gct kxrtc. X krkcng amrlx Heven, tzmnclzbzng bade, kxmule-esz' enjrl, o kxnzetung, o kxnzmatqng.   
\s1 Vz-nqblqamu Lrpzki R Kxnzmcpx  
\c 4  
\p
\v 1 Mz nzmu-krde lcde, navz-nqblqamu lrpzki r Kxnzmcpx mz nzmnc-krmu. X drtwrmu badr naesz'ti mz nzrlrpx-lzbq-krbzmu mz nzaetqngr drtqmu, da kc tqwaile. Murde krkc tzaetq-zlwzpebz drtqde mz nzvz-nqblq-krde Kraes, aovxiopele nzatalzngr nide mz alwx.  
\v 2 X mrlx lc, krlzle nzma-nqblq-krde me pnz drtwr Gct vz-krlzbzle nzbz-krde. X trpengr nzvz-nqblq-krde drtwr kxdrka'ngr.  
\v 3 Mzli kc ena trlxngitika-ngrnamu Jiszs, mzli kang kqlu prtramu mz drtwr kxdrka'ngr sc kxtrnzrlxngitiung. Murde rmwimiamu doa kx trngiu krnalzmu, vz-nqblqamu drtwr kxtrka, rmnq-zlwzamu, trcluwamuu mz da kx myangr drtqmu, x angioamu mqngr drka' kxnzlz kxkqlu.  
\v 4 A' kztemu kcng tqprtrpzmu badr mzli kc, nzpikitipelr nimu murde trnzkrlzlru nike trprtrpe-ngrpwzmuu badr mz nqmq kxdrka'ngr lcng mzli ka.  
\v 5 Kxmule-esz' a' mz Mzli Kxmatq kc navzm, sa natutrpzng mz mz Kxnzmcpx. X sa napibzle mz leplz amrlx kxnztubqng o trtingr, kxmule-esz' kxnzlubeng o kxnzbzpeng. X sa napipxbzlr bade drtwr ngr da amrlx kcng tzalelr mz nzlu-krdr.  
\v 6 A' kztemung kcng tzbzpeng, mzli kc tzlube-ngrdr nzlxngitilr Nrpakxmrlz kc tzyapwxtipxbz badr. Krlc drtwr ngrde kx kxmule-esz' nzprtrng mz nzayrplapxngr mz nzbzkr nrkrdrtqdr, da kc tzwai leplz amrlx, a' mqngrdr nzlu-alobzng mz Gct, mz nzvz-nqblq-krde me pnz drtwrde. \f + \fr 4:6 \ft Mz nibr nzbz-krdr, kxnzrlxngiting trnzprtrpeung mz nzaryplapxkr Gct nidr. \f*   
\s1 Nqmq Krmu Natubq Mzli Ka Tqaenzli-ngrnamu Nzyzlu-krm Jiszs  
\p
\v 7 Ycpe pipz nzyrkrpx-krbz nrlc ka. Mz nzmu-krde lcde, aclvetio-lzbqamu murde nzkrka'-krmu nawz-angidrng.  
\v 8 X da kx myapxbz mz da amrlx, namrlzti-lzbqamu. Murde Nzryrngrkxtr rpile kx, \qt “Nivz batrple mz nabzgu nzipq-krgu leplz mz nzkqlukr alwx ngrdr.”\qt* \x + \xo 4:8 \xt Nzyrplapxngr 10:12\x*  
\v 9 Abrtzlvzamu nzadwatr-krm kztemung ma nyzmung.  
\v 10 Doa kxesz' mz nimu, nawztrpz mz kztedeng mz zmatq kxmyapxbz kc tqkabz Gct bade. Murde zmatq kxmyapxbz kx bletipx lxblr lcng nawz-lxblrng mz nzaelwapx-krdr zmrlz ngrde kxmyalz.  
\v 11 Nzmu kx tqkabzle bam zmatq ngr nzryapwxtipxngr natqde, ryapwxpxbz mz leplz mz nzkrlz-krm kx Gct kc tqrkabz natq kcng tqpiq. X nzmu kx tqngi nzwztr-ngrbz mz leplz le, wztrpz badr mz nzkrlz-krm kx Gct kc tqrkabz nzxplrngr bam. Aleamu da lcng murde leplz naglqlz-zvz-ngrdr Gct mz da kx wzngr Jiszs mz nimu. Murde mz nzngini-krde king kc tqmatq takitrde nzrglqlzngr nide tqyc tqyc. Eu, angida.   
\s1 Na-abrtzlvzamu Nzaetq-ngrbz Drtqmu Da Kc Tqwai Nzaetq-ngrbz Drtq Kxnzmcpx  
\p
\v 12 Mzlengeng x inwengeng, bzkq kctipxamu nzprtr-krmu mz nzkxpu-zlwzngr mzli ka, murde da kxtrka nzprtz-zvzng. X Gct rlr-ngrbzle da lcng mz nzaxplrngr nzrlxngiti-krmu.  
\v 13 A' na-abrtzlvzamu nzaetq-ngrbz drtqmu murde vzpxm mz nzvz-nqblq-krmu me pnz drtwrde, da kc tqwai nzaetq-ngrbz drtq Jiszs Kxnzmcpx. Murde mzli kc nayzlu-ngrm Jiszs mz nzmyalz-krde, na-abrtzlvz-kzamu nzprtr-krmu mz nzmyalz-krde lc.  
\v 14 Nzmu kx tzpikiti leplz nimu murde vz-nqblqamu Kxnzmcpx, mrlz nzabrtzlvz-krmu da lc. Murde aelwapx-ngrde kx Mqngr kxmatq kc tqvzpxm mz Gct sc tqmncbz bamu.  
\v 15 A' trmrlzu nzmu nzaetq-ngrbz drtqmu mz nzngini-krmu ncblo kxayo, kxpna da, kxale da kxdrka'ngr, x kxrpikiti leplz.  
\v 16 A' nzmu nzaetqbz drtqmu mz nzngini-krmu Kristin, naglqpx-ngrnamu Gct nzngini-krmu nabolr Kraes, mz nztwz-krmu drtqde. X bzkq myangr drtqmu.  
\v 17 Murde mz nzayrplapxkr Gct lr nrlc, yzutrpele mz nzayrplapx-krde nigu leplz nedeng. Murde suti drtwrde nzatubqti-krde nigu mz da kxtrka kcng tzprtzmqng bagu. X opx angidr kx nzmu na-ayrplapxle leplz nedeng, sa na-ayrplapx-zlwzle krkcng trnzlxngitilru Nrpa ngrde.  
\v 18 Murde Nzryrngrkxtr rpile kx, \qt “?Nzmu kx rblxtx-zlwzbz mz leplz kxnztubqng nzrlapx-krdr, a' myx kxnamu-alzule mz leplz kxnztrkang kxnzale-zvzng alwx?”\qt* \x + \xo 4:18 \xt Nzyrplapxngr 11:31\x* \f + \fr 4:18 \ft Gct atubqti-kaile leplz nedeng mz nzrlr-krbzle nzprtr-krdr mz nzetqkr drtqdr, x sc tzprtr-ateng Heven. A' kxnzpxtxpx-ngrdr nide, trnztubqung mz nzobq-krde. X dekc trnaprtr-ngrdru Heven. \f*   
\m
\v 19 Mz nzmu-krde lcde, nimu kcng tzaetqbz drtqdr mz nzvz-nqblq-krde me pnz drtwr Gct, navz zvz nzale-krmu da kxtubq, mz nzabrtr-zvz-krbzmu drtwrmu mz Kxrpalz kc tqwz-ngrde nrlc x na-angidatile natqdeng amrlx.   
\s1 Da Kx Na-ale Kxnzaclvelr Dzbe Leplz Neng Gct  
\c 5  
\p
\v 1 Napibo du da bamu, nimu kxnzaclvelr dzbe leplz neng Gct, mz nzngini-kz-krnge kxaclve. Murde krlc tqyapwxtipxx nzmc-krnge nzetqkr drtq Kxnzmcpx mz kros. X sa naprtr-kzx mz nzmyalz-krde mzli kc nayzlu-ngrmle.  
\v 2 Na-aclve-angidramu leplz neng Gct kcng tqkatrpzle mz mqmu, mz nzvz-nqblq-krde me pnz drtwrde. Drtwr ngrde kx nzaclve-krmu nidr navzpxm mz nabzmu, a' trngiu da kx nzrtulrtr-ngrbz bamu. X navqti drtqmu nzwztr-krbzmu mz Gct, a' trngiu dalr nzngini-krmu bcnyr o mz nzamatqngr nimu.  
\v 3 X bzkq glqpx-lzbqbzmu badr, a' nangini-zvzbzmu lrpzki mz leplz nemung. \x + \xo 5:3 \xt Matiu 20:25-27; 23:8-12; Mak 9:35; 10:42-44; Luk 22:25-26\x*  
\v 4 Murde Jiszs nide kxetu r kxnzaclvelr sip nedeng. X mzli kc nayzlu-ngrmle, sa nakabzle bamu da kxmrlz kx nayc alo mz nzprtr-krmu mz nzmyalz-krde.   
\s1 Da Kx Na-ale Kxnzrlxngiting  
\p
\v 5 Mz nqmq lcpwz, nimu obla x olvi namnclzbzmu mz kxnzaclvelr nimu mz makxtr. X nimu amrlx ngrmu na-avzo-lzbqbzmu mz kztemung kxnzrlxngiting. Murde Nzryrngrkxtr rpile kx, \qt “Gct esablqtile kxnzglqpx-lzbqng, a' tubz mz nibr kxnzavzo-lzbqng.”\qt* \x + \xo 5:5 \xt Nzyrplapxngr 3:34; Jemes 4:6\x*   
\p
\v 6 Mz nzmu-krde lcde, avzo-lzbqbzmu mz Gct kc tqmyalz-esz'ngr, murde na-avzdzle nimu nzkrlz-krbzle mzli kc tqyrlqle.  
\v 7 X twzbzmu mz Gct nikeng nzatalvzobzlr nabzmu, murde sa tqaclve-angidrle nimu.   
\p
\v 8 Aclvetio-lzbqamu x oliq-zvzamu, murde enqmi rmu Setzn kc tqotaamu badr apule laion kc tqamwxlr-ngrde leplz mz nztukr natqde. X sc tqvz zvz nzrtangrti-krde doa mz nzatrkati-krde nide. \fig Setzn apule laion kc tqamwxlr-ngrde leplz mz nztukr natqde.|alt="135 lion looking down on shepherds & sheep" src="135-CO01485b.tif" size="SPAN" loc="1PE 5:8" copy="David C. Cook" ref="5:8" \fig*  
\v 9 A' esablqtiamu nide x tu-amqngiamu mz nzbrtikr drtwrmu Jiszs. Murde nakrlz-kzamu kx kztemung kxnzrlxngiting amrlx mz nrlc nzprtr-kzng mz nzetqkr drtq mz nzvz-nqblq-krdr Jiszs, da kc tqwaiamu.   
\p
\v 10 A' mz nibr mzli kxmrbc kcng tqetqti drtqmu, Gct esz'-krde sa na-amrlz-moule nimu, sa na-amqngile nzbrtikr drtwrmu nide, x sa na-axplrle nabzmu, murde navz zvz nzyatr-krbzmu. Murde zmrlz x nzokatrngr amrlx nzvzpxmqng bade. X kqlele nimu mz nzaxvctr-krbzle nimu mz Kxnzmcpx, murde rpile naprtr-alo-kzamu mz nzmyalz-krde.  
\v 11 Murde nide king kc tqmatq tqvzpe tqvzpe. Eu, angida.   
\s1 Natq Ngr Nzarlr-lzbqngr  
\p
\v 12 Saelas okatrple ninge mz nzryr-krbo bamu letz lc mrbcne. Krlz-angidrx nzngini-krde mzlegu kx nzbrti drtwr leplz. Yrbo letz lc mz nzapqtr-krbo drtwrmu x mz nzrpi-krbo bamu kx kxmule-esz' nike prtzbz bamu, a' suti zvz drtwr Gct nzokatr-krde nimu mz zmrlz ngrde kxmyalz. Lolvz-amqngiamu nzbrtikr drtwrmu nide.   
\p
\v 13 Lr makxtr kztemung kcng tzmncng Rom, tqmcpx-kzng Gct, nzrpibzlr bamu kx, “Nimu la.” X Mak kz kc tqapubo bade trtede, rpibzle bamu kx, “Nimu la.”  
\v 14 Male-lxblramu mqmu mz nivz mzli kc tqrmcti-lzbq-ngrnamu. Krka'-ngrne kx nimu leplz neng Jiszs Kxnzmcpx amrlx namnc-zpwxng mz nrwx.  
\cls Delape. Ninge \sig Pita. \sig*   