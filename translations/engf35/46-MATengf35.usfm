\v 11 \w If|strong="G1487"\w* \w you|strong="G5210"\w* \w then|strong="G3767"\w*, \w being|strong="G1510"\w* \w evil|strong="G4190"\w*, \w know|strong="G1492"\w* \w to|strong="G1722"\w* \w give|strong="G1325"\w* \w good|strong="G3588"\w* \w gifts|strong="G1390"\w* \w to|strong="G1722"\w* \w your|strong="G1487"\w* \w children|strong="G5043"\w*, \w how|strong="G4214"\w* \w much|strong="G4214"\w* \w more|strong="G3123"\w* \w will|strong="G1510"\w* \w your|strong="G1487"\w* \w Father|strong="G3962"\w* \w who|strong="G3588"\w* \w is|strong="G1510"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w heavens|strong="G3772"\w* \w give|strong="G1325"\w* \w good|strong="G3588"\w* \w things|strong="G3588"\w* \w to|strong="G1722"\w* \w those|strong="G3588"\w* \w who|strong="G3588"\w* ask \w Him|strong="G3588"\w*!\f + \fr 7:11 \ft I take it that we are authorized to ask!\f*  
\v 12 \w So|strong="G3779"\w* \w then|strong="G3767"\w*, \w whatever|strong="G3745"\w* \w you|strong="G5210"\w* \w want|strong="G2309"\w* \w people|strong="G3956"\w* \w to|strong="G2443"\w* \w do|strong="G4160"\w* \w to|strong="G2443"\w* \w you|strong="G5210"\w*, \w do|strong="G4160"\w* \w also|strong="G2532"\w* \w to|strong="G2443"\w* \w them|strong="G3588"\w*, \w for|strong="G1063"\w* \w this|strong="G3778"\w* \w is|strong="G1510"\w* \w the|strong="G2532"\w* \w Law|strong="G3551"\w* \w and|strong="G2532"\w* \w the|strong="G2532"\w* \w Prophets|strong="G4396"\w*.\f + \fr 7:12 \ft This is the so-called ‘golden rule’—if everyone did this the world would be a better place.\f*   
\s1 Eternal destiny  
\p
\v 13 “\w Go|strong="G1525"\w* \w in|strong="G1519"\w* \w through|strong="G1223"\w* \w the|strong="G2532"\w* \w narrow|strong="G4728"\w* \w gate|strong="G4439"\w*; \w because|strong="G3754"\w* \w wide|strong="G4116"\w* \w is|strong="G1510"\w* \w the|strong="G2532"\w* \w gate|strong="G4439"\w* \w and|strong="G2532"\w* \w broad|strong="G2149"\w* \w is|strong="G1510"\w* \w the|strong="G2532"\w* \w way|strong="G3598"\w* \w which|strong="G3588"\w* \w leads|strong="G1519"\w* away \w into|strong="G1519"\w* perdition, \w and|strong="G2532"\w* \w those|strong="G3588"\w* \w who|strong="G3588"\w* \w are|strong="G1510"\w* \w going|strong="G2532"\w* \w in|strong="G1519"\w* \w through|strong="G1223"\w* \w it|strong="G2532"\w* \w are|strong="G1510"\w* \w many|strong="G4183"\w*.  
