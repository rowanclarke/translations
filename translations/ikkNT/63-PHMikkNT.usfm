\id PHM Ika New Testament 2009 
\h Filemọnụ 
\toc1 Ẹhụhụọ-Ozi Pọlụ Dejẹnni Filemọnụ 
\toc2 Filemọnụ 
\toc3 Fimo 
\mt2 Ẹhụhụọ-Ozi Pọlụ Dejẹnni 
\mt1 Filemọnụ 
\c 1  
\p  
\v 1 Mmẹ wụ Pọlụ de ẹhụhụọ-ozini. M wụ onyẹ-ngan makẹ ufiri Jizọs Kraịstị. Mmẹ lẹ Timoti nwẹnẹ-ẹnyi gba de ẹ. Ịyụ wụ Filemọnụ ezi onyẹ-ọrụn ibe ẹnyi kẹ ẹnyi rị e dejẹnn'ẹ—ịyụ  
\v 2 lẹ ụka hụn a nọ iwe i e zu lẹ Afịa nwẹnẹ-ẹnyi-okpoho lẹ Akịpọsị onyẹ-agha ibe ẹnyi.  
\v 3 Ẹfọma lẹ udọn hụn gha ẹka Chuku Nẹdi ẹnyi lẹ Di-nwọnni-ẹnyi wụ Jesu Kristi bịa ya rịnị ọnụ. 
\s1 Ihiẹn-ọsụsụọ Lẹ Okukwe Filemọnụ Nwẹ 
\p  
\v 4 Filemọnụ, m'a kpanmịn Osolobuẹ m ogẹn ile m gi a nyanhan ị imẹ ekpere m.  
\v 5 Makẹni, m hụ a nụ n'i nwẹ ihiẹn-ọsụsụọ jẹnni ndị nsọ ile lẹ ni i kwerichanrịn nị Di-nwọnni-ẹnyi wụ Jizọsị.  
\v 6 Ekpere m wụ nị okweri ẹnyi lẹ 'yụ kweri ni Jesu jẹnkọ d'e duzi i nị y'a ghọtawaye ihiẹn ile wụ nke ẹnyi imẹ Kristi. 
\p  
\v 7 Ezigbo nwẹnẹ m, ihiẹn-ọsụsụọ i nwọn e mẹgụọ m ghọghọ ọda-ọda, ọ gbagụọzị m umẹ ọda-ọda—makẹni Osolobuẹ e gigụọ ị gba ndị nsọ umẹ. 
\s1 Pọlụ A Rịọdọnni Onesimọsị 
\p  
\v 8 Makẹ ufiri ọnwan, ọsụọn'a nị imẹ Kraịstị nị m nwọn ikẹn ye i iwu n'ị mẹ ihiẹn furu n'i mẹ,  
\v 9 ọ ka m mma nị m gi ufiri ihiẹn-ọsụsụọ rịọ ị a rịọ. Mmẹ wụ Pọlụ, hụn wụ ẹgẹdi, hụn rị a nọkin ẹnya Jizọs' Kraịstị, hụn rịzịkwọ imẹ ngan makẹ ifiri Jizọs' Kraịstị, rị nwan a rịọ ị.  
\v 10 M rị a rịọ ị makẹ nwa m wụ Onesimọsị, hụn m wụrụ nẹdi ẹ imẹ ngannị m rị. 
\p  
\v 11 O nwọnni erere ọ ban n'ị mbụ. Kanị ọ bangụọ nwan erere nke-esi—ban n'ị, banzịkwọ nị m. 
\p  
\v 12 M zikinla n'ị ịya azụụn—ya wụ, mkpụrụ obi m kẹ m zila n'ị.  
\v 13 O te rị m nị m sị a nọdị ebeni m rị, kẹni ọ nọkin ẹnya ụnụ, e jẹnni m ozi hụnnị m rị ngan makẹ ufiri oziọma.  
\v 14 Kanị, achọnị m nị m mẹ ihiẹn ọwụlẹ bụ a gwanị m'ị—kẹni ọhụnma ị wụrụ ihiẹn gha akpakalị obi i pụha, ẹlẹ ni wẹ wa a ye i olu. 
\p  
\v 15 Ikẹnkwọ wẹ napụ ị ya ẹkẹrẹ kẹni i nwẹhẹnzi ẹ, ọ wụrụ nke i jẹnrin ejẹn—  
\v 16 ẹlẹzi nọkẹ igbọn, kanị nọkẹ nwẹnẹ i, hụn rị ị obi—hụn ka igbọn. Ọhụn k'ọ wụ, tụmadụ ebe m rị; kanị, ebe ị rị k'ọ kad'a wụ—kẹ ebe anụ-ẹhụ rị kẹ imẹ Di-nwọnni-ẹnyi. 
\p  
\v 17 Ya wụ, omẹni y'e werighọ m nọkẹ onyẹ 'yụ lẹ ịya gba a rụn, nabanhan a nọkẹ sị mmẹ rọ. 
\p  
\v 18 Omẹni o nwẹ eje-ihiẹn o mẹ i mọbụ n'o gi i ihiẹn ọwụlẹ, gụn a yeni m—m k'a kụ a.  
\v 19 Mmẹ wụ Pọlụ gi ẹka m e de ọnwan: \it ẹghẹẹ, gụn a yeni m; m k'a kụ a\it*. Ẹlẹ mmẹ nwọn gwazị ị nị i gi m ụgwọ enwẹn i. 
\p  
\v 20 Ẹghẹẹ nwẹnẹ m, nị m gidẹ ẹfan Di-nwọnni-ẹnyi ri ọghọnị ẹka ị. Gi ifiri Kraịstị gba m umẹ. 
\p  
\v 21 M rị e deni i ihiẹnni makẹni a manrịnghọ m n'i k'e humẹ-isi—a manrịnghọ m n'i k'e mẹkarịdẹ ihiẹn m gwa ị. 
\p  
\v 22 Ọzọzị, kwademẹ ni m mmughẹ ọbịa a nọdị, makẹni m rị a tụ ẹnya nị Osolobuẹ k'a za ekpere ọnụ, mmẹ lẹ ụnụ a hụn ụzọ nọdịzị. 
\s1 Ekele Ịkpazụụn 
\p  
\v 23 Epafrasị e kele i. Mmẹ lẹ Epafrasị gba rị nwan ngannị makẹ ifiri Kraịst wụ Jizọsị.  
\v 24 Ndị ọrụn ibe m wụ Makị lẹ Arịstakọsị lẹ Dẹmasị lẹ Luku e kelezikwọ ị.  
\v 25 Ẹfọma Di-nwọnni-ẹnyi wụ Jesu Kristi ya nọyeni mmọn ụnụ.