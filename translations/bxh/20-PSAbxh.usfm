\id PSA
\h Samsi 
\toc1 Samsi 
\toc2 Samsi 
\toc3 Samsi 
\mt2 Diusi edi Wana Bukana  
\mt1 Samsi  
\c 1
\s1 \nd Guyau\nd* Famuli Watanina ya Fanuwa Kwadekwade  
\q1
\v 1 Salumadi hige dodoga heyaheyayadi edi nuwanuwatuhu ti lau watanidi,  
\q2 yo tau heyaya edi miyamiya hige ti miyamiyaꞌedi,  
\q2 e Yaubada tau ꞌwaiyoꞌoꞌenna hige ti modeꞌedi mate,  
\q2 nuwadi ti amna.   
\q1
\v 2 Lisina yai, Yaubada ena laugagayo awaꞌabina kwadena sa lobahi,  
\q2 be sa fatili, na sa fadosi iꞌipa yo lahai.   
\q1
\v 3 Iti doha oyagi sa umahi hoꞌowa bubuna yai  
\q1 be adi fuya yai sa fuwa, siuhwalo fuyana,  
\q2 ibege ti hohoya edi maliyaho aniyona ya taumahata.   
\q1
\v 4 Dodoga heyaheyayadi edi laulau hige doha ite;  
\q2 iti doha hawahawa wenuna hwayahwayau ya yofohi.   
\q1
\v 5 Tau heyaya mate Yaubada haba ya fakasadi.  
\q2 Yaubada ena dodoga ibege maꞌedi ti miya esega.   
\q1
\v 6 Dodoga dudulaidi mate Yaubada ya ita watanidi  
\q2 yo ya bobodiyedi,  
\q1 na tau heyaya mate Yaubada haba ya fakamkamnadi.   
\c 8
\s1 Deiwidi Wana ya Uli  
\sr Samsi 8:1-2  
\q1
\v 1 Aee–, \nd Guyau,\nd* ema Yaubada, dodoga mahudoꞌidi tanoꞌubu yai sa sibai,  
\q2 mate um wa hasai wananaha.  
\q1 Em namanamali ya mala wananaha,  
\q2 habahim galewa malana.   
\q1
\v 2 Wawaya nom haꞌa sa dabu, yo ma nomnomdi haba sa fadebasaen.  
\q1 Ami waiyunu lisidi yai haba ya ita watanimiu,  
\q2 yo ya bobodiyemiu;  
\q1 Sai haba ya fakamkamnamiu.   
\c 23
\s1 \nd Guyau\nd* ya Itaꞌita Watanigu  
\q1
\v 1 Ibege ya gogo gesagesa,  
\q2 paꞌana fuya ouꞌouli,  
\q2 \nd Guyau\nd* ya itaꞌita watanigu, doha sipi tau ita wata.\fig |alt="Sipi tau ita watanina" src="hk00009c.tif" size="span" loc="Psalm 23:1-2" ref="23:1" \fig*   
\q1
\v 2 1 Ya faꞌanyawasigu hawahawa idaꞌidahedi yai  
\q2 yo ya foya lauwegu hoꞌowa daudaumwalina yai.   
\q1
\v 3 Yaluwagu ya fafwaufwau fuyoi.  
\q2 Hesana yai edaꞌeda dudulaina yai ya foyahigu.   
\q1
\v 4 Yena E lau hobohobo kamukamumuna yai  
\q2 ibege heyaheyaya laꞌi ya ꞌwasabuwen,  
\q2 paꞌana um maꞌegu.  
\q2 Em pidipidili yo em tuꞌe sa bobodiyegu.   
\q1
\v 5 Agu waiyunu matadi yai,  
\q2 agu anꞌangogo wa abi nonohai.  
\q1 Kulugu wa famaꞌi.  
\q2 Agu kapu wa famohafu tabutabuliwa.   
\q1
\v 6 Wananaha, egu miya mahudoꞌina yai,  
\q2 wa faloholohogu yo wa gadogadosisiyegu.  
\q1 Na yau haba \nd Guyau\nd* ena ai luma E gogo ee–,  
\q2 hige anadan.   
\c 27
\s1 Deiwidi ana Wana ya Uli  
\q1
\v 1 \nd Guyau\nd* mate egu mala yo tau fafamwahuli.  
\q2 In egu mwahuli tau faꞌadidilina  
\q2 be sai haba E ꞌwasabuwen?   
\q1
\v 2 Yena agu waiyunu, heyaya dodogadi sa duhu mahanoꞌigu  
\q2 bena sa faheyayagu,  
\q1 iti moho haba sa faꞌalu betibeti be sa beꞌu.   
\q1
\v 3 Ibe sa fataꞌiꞌiligu;  
\q2 ibege ya ꞌwasabu.  
\q1 Yo yena agu halulu sa laoma,  
\q2 haba nuwagu ya adidili.   
\q1
\v 4 \nd Guyau\nd* lisina yai ginauli esega E anꞌetai  
\q2 yo E fanuha wananahai mate,  
\q1 bena \nd Guyau\nd*, ena luma yai E miya,  
\q2 fuya ouꞌouli, egu mwahuli ganahewana yai  
\q1 be nenena loholohona E itaꞌitai  
\q2 yo E laulauꞌuꞌula lau lisina ena Dubu Tabuna yai.   
\q1
\v 5 Yena pilipili E fahoina  
\q2 haba ya bobodiyegu.  
\q1 Haba ena palai fafatabuna yai ya simogu,  
\q2 yo umeꞌehu hewa wananahana yai haba ya tolegu.   
\q1
\v 6 Habahim, E tamahiti,  
\q2 be agu waiyunu sa fataꞌiꞌiligu E tiꞌe tawaidi be ibege ti lei hafihafitigu.  
\q1 Em luma fatabuna yai haba egu antalasam E ginauli ma wowogu;  
\q1 Haba E wana yo dagugu loholohona E ginauli be \nd Guyau\nd* E fadebasae.   
\q1
\v 7 Aee–, \nd Guyau\nd*, u nuwatohatohaegu,  
\q2 yena E yoga laꞌilaꞌi alinagu u atahi be u bui.   
\q1
\v 8 Wa liba uwen, “U laoma u fadebasaegu!”  
\q2 Logena e laoma.   
\q1
\v 9 Yau em tau lau fayofayo! Tabu u manabalaꞌegu  
\q2 be u taꞌai mulimuliyegu.  
\q1 Um tau sagusaguhigu,  
\q2 Yaubada, um tau famwahuligu;  
\q1 tabu u nuwa afulegu.   
\q1
\v 10 Ibe tamagu yo tinagu sa lau afulegu.  
\q2 \nd Guyau\nd* haba ya abi komakomanigu.   
\q1
\v 11 Aee–, \nd Guyau\nd*! Agu waiyunu debadi yai em miyamiya, u faꞌatagu,  
\q2 be laulau dudulaidi, ya miyamiyaꞌedi.   
\q1
\v 12 Agu waiyunu liba bwalabwaladi sa libaedi,  
\q2 sa fanuha bena sa faheyayagu  
\q1 be tabu u fele afulegu lebedi yai.   
\q1
\v 13 E sunumaꞌen mate \nd Guyau\nd* ena loholoho haba E ita,  
\q2 hola ma mwahuligu.   
\q1
\v 14 Be \nd Guyau\nd* u sunumaꞌen yo nuwam i adidili.   
\c 34
\s1 Yaubada Tau Sunumaena ya Saguhidi  
\d Fuya hesa Abimeleki matana yai Deiwidi doha yauyaule be ya fatamali ya lau. Muli yai, Yaubada sidohana Deiwidi ena sagusaguhina lahaina yai, mate lilina Deiwidi ya uli.  
\q1
\v 1 Fuya ouꞌouli haba \nd Guyau\nd* E fafadebasae,  
\q2 fadebasaena sopagu yai ibege ya fatautau.   
\q1
\v 2 \nd Guyau\nd* haba E toletole hitin,  
\q2 safalumadi sa abi faheyayadi, ti ataꞌatahi be ti kwade.   
\q1
\v 3 Mahudoꞌida \nd Guyau\nd* te fadebasae,  
\q2 yo hesana te lau hitin gogo.   
\q1
\v 4 E lauꞌuꞌula lau \nd Guyau\nd* lisina be ya atahi;  
\q2 yo egu ꞌwasabu mahudoꞌidi yai ya fasagu fahigu.   
\q1
\v 5 Salumadi \nd Guyau\nd* sa sunumaꞌen bena ya saguhidi,  
\q2 mate nuwadi ti kwade,  
\q1 paꞌana fuya ouꞌouli haba ya sagusaguhidi.   
\q1
\v 6 Tau gogo gesagesa te, sa lauꞌuꞌula lau \nd Guyau\nd* lisina,  
\q2 be \nd Guyau\nd* ya atahi,  
\q2 edi pilipili mahudoꞌidi yai, ya fasagu fahidi.   
\q1
\v 7 Salumadi \nd Guyau\nd* sa fafadebasae mate  
\q2 Yaubada ena anelu ya bobodiyedi yo  
\q2 heyaya yai ya fafasagufahidi.   
\q1
\v 8 Haga au lau dadai, haba ami ita lobahi, \nd Guyau\nd* ya loholoho,  
\q2 Tau sunusunumaꞌenna haba nuwadi sa amna.   
\q1
\v 9 Umi ena dodoga fafatabudi, \nd Guyau\nd* au faꞌatitiyen  
\q2 paꞌana salumadi sa fafaꞌatitiyen ibege ti kuꞌu.   
\q1
\v 10 Laiyon gonowana adi anꞌan ya ofi be haba sa guliyam,  
\q2 na salumadi \nd Guyau\nd* sa sunusunumaꞌen mate,  
\q2 ibege ginauli loholohodi hesa lisina yai ti kuꞌu.   
\q1
\v 11 Nanatugu, au laoma be au ataꞌatahi;  
\q2 \nd Guyau\nd* fafaꞌatitina haba E fatalahamiu.   
\q1
\v 12 Sai ya fanuha ya miya lofalofa,  
\q2 yo loholoho ya fahoina,   
\q1
\v 13 lelona yo sopana bena ya komanidi,  
\q2 tabu i fapaisowa faheyayadi  
\q2 yo tabu i laulau bwalabwala.   
\q1
\v 14 Heyaheyaya yai bena wa nuwabui,  
\q2 yo bena wa anpate adidili,  
\q2 be miyamiya daudaumwalina wa miyamiyaꞌedi.   
\q1
\v 15 \nd Guyau\nd* tau laulau dudulai ya bobodiyedi,  
\q2 na yena edi tan ya atahiyedi haba ya fasagufahidi;   
\q1
\v 16 na nenena ya fasana hudoꞌiyen, tau heyaya lisidi yai;  
\q2 yo sa peꞌi, haba ya nuwa fuiyedi.   
\q1
\v 17 \nd Guyau,\nd* tau laulau dudulai edi tan ya atahi.  
\q2 Haba ya saguhidi,  
\q1 edi pilipili mahudoꞌidi yai haba ya fasagu fahidi.   
\q1
\v 18 \nd Guyau\nd* mate fadidi yai,  
\q2 salumadi sa nuwa belubelu ya fasagu fahidi.   
\q1
\v 19 Tau laulau dudulai, pilipili boludi ya fahoinadi,  
\q2 in moho \nd Guyau\nd* ya fasagufahi pilipili lisidi yai.   
\q1
\v 20 \nd Guyau\nd* ya ita watan komakomaniꞌi  
\q2 be hige siyadana laꞌi i tapwai.   
\q1
\v 21 Heyaya tau ginaulina haba ya faheyaya fuyoi.  
\q2 Na tau laulau dudulai adi waiyunu haba sa fakamkamnadi.   
\q1
\v 22 \nd Guyau\nd* haba ena tau lau fayofayo ya sagu fahidi;  
\q2 yo salumadi sa sunumaꞌen bena In tau saguhidi,  
\q2 ibege heyaya ti fahoina.   
\c 51
\cd Liba Famahata: Samsi 51 Fuya hesa Kin Deiwidi maꞌena taumoho hudoꞌi hesana Ulaiya lahuna sa luma gwaꞌu. Waihinna hesana mate Betesiba. Yaubada ena peloweta hesa hesana Neitan, Deiwidi ya sagasagaliyen. Deiwidi nuwana ya heyaya paꞌana laulau heyayana ya ginauli be ena lauꞌuꞌula Yaubada lisina yai ya uli.  
\s1 Nuwatuhu Afule Lauꞌuꞌulana  
\d Deiwidi ana wana. Fuyanna maꞌena Betesiba heyaya sa ginauli mate Peloweta Neitan ya lau lisina. (2 Samuwela 11 yo 12)  
\q1
\v 1 Aee–, \nd Guyau,\nd* em fanufanuha ya ota esegahi,  
\q2 be u nuwa tohatohaꞌegu. Um tau fanuwatohatoha,  
\q2 be egu heyaya u nuwatuhu afuledi,   
\q1
\v 2 Egu heyaya mahudoꞌidi u kaisu afuledi.   
\q1
\v 3 Egu heyaya E sibaidi  
\q2 na fuya ouꞌouli E nuwanuwatuhuidi.   
\q1
\v 4 Um moho lisim yai heyaheyaya E ginauli,  
\q2 laulau heyayana matam yai E ginauli;  
\q1 be fuyanna wa falibagu uwen, “Heyaya wa ginauli!”  
\q2 Mate, wa liba dudulai.   
\q1
\v 5 Hola tinagu bogana yai ya lau ee–,  
\q2 ena fuya yosigu yai mate haꞌa E heyaya.   
\q1
\v 6 Um wa fanuha wananaha bena ma nuwa ofi fahigu  
\q2 E laowa lisim,  
\q2 tabu ya nuwa luwaluwaga;  
\q1 sibasiba um wa fatalahagu.   
\q1
\v 7 Egu heyaheyaya u nuwa afuledi.  
\q2 Na u kaisugu, haba E aꞌa.   
\q1
\v 8 Nuwagu wa fakamkamna  
\q2 yo yaluwagu wa lau lidiyen,  
\q1 in moho E atahi egu heyaheyaya wa nuwatuhu afuledi  
\q2 be nuwagu ya amna wananaha yo E kwade.   
\q1
\v 9 Tabu egu heyaya u itaꞌita lau lisidi,  
\q2 na mahudoꞌina u nuwatuhu afuledi.   
\q1
\v 10 Aee–, Yaubada, nuwagu  
\q2 yo yaluwagu mahudoꞌina u fafwaufwau fuyoi.   
\q1
\v 11 Tabu u tole hudoꞌiyegu,  
\q2 e Yaluwam Tabuna lisigu yai u lawe hudoꞌiyen.   
\q1
\v 12 U saguhigu be em liba, nuwa amnana i abigu.  
\q2 Doha egu fuya nuwabui bwaꞌibwaꞌina yai.  
\q2 Nuwagu u faloholoho fuyoi.   
\q1
\v 13 Habahim em laulau tau heyaya E faꞌatadi  
\q2 be haba sa timuli bui lisim.   
\q1
\v 14 Aee–, Yaubada, lau pono yai u fofofahigu,  
\q2 yo u bobodiyegu na em laulau dudulai  
\q2 debadi yai haba E wana.   
\q1
\v 15 Aee–, \nd Guyau,\nd* u saguhigu be ya libaliba  
\q2 na haba E fadebasaem.   
\q1
\v 16 Suisui antalasamedi, yo antalasam gabugabudi hinaga  
\q2 hige nuwam ti amnaedi.   
\q1
\v 17 Aee–, Yaubada, nuwagu ya tamo golugolu  
\q2 mate egu antalasamna logena;  
\q2 Yaubada um nuwa lidilidi yo nuwa talu wa fanuha.   
\c 67
\s1 Lautoꞌi Wanana  
\q1
\v 1 Aee–, Yaubada u nuwatohatohaemai,  
\q2 yo u nuwa amnaꞌemai  
\q2 na em loholoho u felemai.   
\q1
\v 2 Be em laulau ai tanoꞌubu ti sibaidi.  
\q2 Tau abiꞌabi famwahuli um, bena sa sibaim.   
\q1
\v 3 Yaubada! Dodoga ti fadebasaem;  
\q2 dodoga mahudoꞌidi ti fadebasaem!   
\q1
\v 4 Dodoga nuꞌu mahudoꞌina yai ti wana ma kwadedi,  
\q2 paꞌana dudulai yai wa fadudulaidi.  
\q2 Yo wa foya fadudulaidi.   
\q1
\v 5 Yaubada! Dodoga ti fadebasaem.  
\q2 Mahudoꞌidi ti fadebasaem!   
\q1
\v 6 Habahim gabu anꞌandi sa anaho;  
\q2 Yaubada Eda Yaubada ya aiꞌainauyaida.   
\q1
\v 7 Yaubada i ainauyaida,  
\q2 be dodoga mahudoꞌidi tanoꞌubu yai  
\q2 haba sa faꞌatitiyen.   
\c 90
\s1 Mose ena Lauꞌuꞌula  
\q1
\v 1 Aee–, Guyau, hitina yo hitina,  
\q2 um tau ita watanimai.   
\q1
\v 2 Tuꞌa yo tanoꞌubu hola hige ti tubu,  
\q2 na um ibom Yaubada ota otafahina.   
\q1
\v 3 Dodoga wa bui fafuyodi afusa.  
\q2 Uwen, “Umi tau peꞌi, au fafuyo afusa!” \rq (Aba Fatubu 3:13, Diyobi 1:21)\rq*   
\q1
\v 4 Boliman tausan-esega um matam yai  
\q2 mate doha bon moho, haꞌa ya ofi,  
\q2 e doha iꞌipa esega tuhulina.   
\q1
\v 5 Dodoga edi mwahuli wa tomo feulaidi  
\q2 doha eno suwai ya ofi.  
\q2 Iti doha hawahawa hesa hwalahwalaladi ya in,   
\q1
\v 6 na maimailafidi ya hohoya be ya peꞌi,   
\q1
\v 7 laulauna doha manabalam ya fadawa wunumai,  
\q2 haba em manabala ꞌe ꞌwasabuwen.   
\q1
\v 8 Ema heyaya wa famahatadi, simosimodi hinaga wa itadi.   
\q1
\v 9 Ema miya lahaidi mahudoꞌidi yai wa manamanabalaꞌemai,  
\q2 ema mwahuli wa tomo feulaidi doha yahafuwa.   
\q1
\v 10 Gonowana te miya boliman 70,  
\q2 na yena te fulufuluga haba 80, in moho ema miya lahaidi yai  
\q2 pilipili yo kamkamna ꞌe fafahoinadi,  
\q2 na hige walolona ꞌe peꞌi.   
\q1
\v 11 Hige sai em manabala laꞌina i sibai,  
\q2 na ibe ꞌe siba haba ꞌe ꞌwasabuwem.   
\q1
\v 12 U fatalahamai be em sibasiba ai abi,  
\q2 ema lahai ya tupo.   
\q1
\v 13 Aee–, Guyau, u feulama.  
\q2 Em tau lau fayofayo ai, u nuwatohatohaimai.   
\q1
\v 14 Hwalahwalaladi em gadogadosisi otaꞌotafahina lisina yai u famohafumai  
\q2 be ema miya lahaidi mahudoꞌidi yai haba ma kwademai ꞌe wana.   
\q1
\v 15 Boliman lofadi somo wa fafapilipilimai  
\q2 mate bolimandi lofadi hinaga nuwamai u fakwadedi.   
\q1
\v 16 Em paisowa gigibwalina u faꞌitamai, ai em tau laufayofayo lisimai yai,  
\q2 yo em gigibwali namanamalina, nanatumai u faꞌitadi.   
\q1
\v 17 \nd Guyau\nd* ema Yaubada, u ainauyaimai;  
\q2 ema paisowa hinaga ti loholoho.   
\c 95
\s1 Yaubada Fadebasaena Wanana  
\q1
\v 1 Au laoma! Te wana lau \nd Guyau\nd* lisina,  
\q2 tau famwahulida te wowoʼen ma kwadeda.   
\q1
\v 2 Te laoma lisina ma lautoꞌida;  
\q2 dagugu laꞌilaꞌi te ginaulidi yo  
\q1 te wana ma kwadeda ya lau lisina.   
\q1
\v 3 \nd Guyau\nd* mate In Hewa Wananaha Yaubadana,  
\q2 yaubada mahudoꞌidi edi wasawasa.   
\q1
\v 4 Tanoꞌubu mahudoꞌina mate in, enehena, gon yai  
\q2 ya hasai be–, oya yai yo.   
\q1
\v 5 Gabogabo yo tanohi pitapitalina ya fatubudi,  
\q2 mate In tanuwagadi.   
\q1
\v 6 Au laoma te tuli bono  
\q2 be \nd Guyau\nd* tau fatubuda te fadebasae.   
\q1
\v 7 Paꞌana in eda Yaubada  
\q2 na ita ena gana ganahewana yai  
\q1 doha sipi tau itaꞌita watanidi ena sipi ya bobodiyedi.  
\q2 Aee–, aho te ibe ami ataꞌatahi lau lisina!   
\q1
\v 8 Tabu nuwamiu au guduguduidi doha afa wahamiu  
\q2 somo sa ginauli Meliba yai,  
\q1 lahaina yai Masa yai, nuꞌu pitapitalina yai. \rq (Auꞌaulaha 17:7; Namba 20:13)\rq*   
\q1
\v 9 Amainiya afa tamamiu sa lau itagu.  
\q2 Ginauli E ginaulidi sa itadi haꞌa. Na hola sa anpateigu.   
\q1
\v 10 Bolima 40 egu manabala hiti ni lisidi yai.  
\q1 Ayawa, “Dodoga ni, nuwadi sa anꞌanloya gaibu,  
\q2 egu laulau hige ti sibaidi.”   
\q1
\v 11 Be manabala yai E angwala  
\q2 bena tabu ti luhulau egu aba anꞌanyawasi yai.   
\c 100
\s1 Lautoꞌi Wanana  
\q1
\v 1 Tanoꞌubu mahudoꞌimiu ma kwademiu,  
\q2 au halabo lau \nd Guyau\nd* lisina.   
\q1
\v 2 \nd Guyau\nd* au fadebasae ma nuwa loholohomiu.  
\q2 Au laoma \nd Guyau\nd* matana yai  
\q2 ma kwademiu yo ma wanawanamiu.   
\q1
\v 3 \nd Guyau\nd* mate Yaubada!  
\q2 In ya ginaulida bena, enehena.  
\q1 Ita ena dodoga doha sipi baiwadi.   
\q1
\v 4 Au luhulau edaꞌedana hafohafona yai, ma laulautoꞌimiu,  
\q2 au luhulau Dubu Tabuna dobidobina yai ma fadebasaemiu!  
\q1 Au lautoꞌiyen yo hesana au fadebasae.   
\q1
\v 5 Paꞌana \nd Guyau\nd* ya loholoho wananaha.  
\q1 Ena gadosisi otaꞌotafahina ya ota esegahi ya lau ee–, hige anadan,  
\q1 yo hitina - hitina ena sunuma ya ota esegahi  
\q2 ya lau ee–, hige anadan.   
\c 103
\s1 Yaubada ena Fanufanuha  
\q1
\v 1 Aee–, Yaluwagu, \nd Guyau\nd* u fadebasae!  
\q2 Ma nuwa ofi fahigu hesana fafatabuna E fadebasae!   
\q1
\v 2 Aee–, yaluwagu, \nd Guyau\nd* u fadebasae.  
\q2 Ena ainauya mahudoꞌidi haba E nuwa nuwatuhuidi,   
\q1
\v 3 in egu heyaheyaya mahudoꞌidi ya nuwatuhu afuledi  
\q2 yo agu asiyebo mahudoꞌidi ya faloholohodi,   
\q1
\v 4 Peꞌi yai ya famwahuli fuyoꞌigu,  
\q2 be ena faloholoho yai,  
\q1 in ya gadogadosisiyegu yo ya fanuwatohatohaegu.   
\q1
\v 5 Egu miya lahaidi ganahewadi yai  
\q2 ginauli loholohodi ya aiꞌainauyaigu,  
\q2 be haba taugu ena adidili ya fafwaufwau fuyoi  
\q1 doha magesubu gubugubufwauna.   
\q1
\v 6 \nd Guyau\nd* laulau dudulaina yai  
\q1 safalumadi sa ita lidilidiyedi ya saguhidi.   
\q1
\v 7 Ena nuwatuhu Mose ya fatalaha,  
\q1 yo ena paipaisowa \w Isalaela\w* dodogadi hinaga ya fatalahadi.   
\q1
\v 8 \nd Guyau\nd* in fafanuwatohatohana yo anꞌansoina,  
\q1 hige i manamanabala feula yo ena gadosisi ya fafatadada.   
\q1
\v 9 In ibege fuya ouꞌouli i laulau fagilu,  
\q2 yo ena manabala ibege i ota esegahi.   
\q1
\v 10 Eda heyaya debadi yai in gonowana ya fakamkamnada,  
\q2 in moho ibege i ginauli.   
\q1
\v 11 Doha galewa tanoꞌubu ya saipwai  
\q1 mate ena gadosisi laꞌina tau fafaꞌatitiyenna lebedi yai.   
\q1
\v 12 Eda heyaheyaya lofana doha  
\q2 tefa saisai yai, na ya lau ee–,  
\q2 tefa leuleu yai mate ya kamfahidi.   
\q1
\v 13 Doha taumoho nanatuna ya fanuwatohatohaedi  
\q1 mate doha \nd Guyau\nd* tau faꞌatitiyenna ena fanuwatohatohaedi.   
\q1
\v 14 Paꞌana ya sibai, ita tanohi moho lisina yai ya ginaulida,  
\q2 be ya nuwatuhui ita hige dodoga adiꞌadidilida.   
\q1
\v 15 Eda miya lahaidi yai doha hawahawa,  
\q2 doha mula inꞌin gaibudi, sa taya be sa peꞌi.   
\q1
\v 16 Hwayahwayau ya towa tawaidi be sa failaulauwidi  
\q2 na hige sai i ita fuyoꞌidi.   
\q1
\v 17 Safalumadi \nd Guyau\nd* sa ita hitiꞌi, ena gadosisi otaꞌota fahidi.  
\q1 Lisidi yai, ena loholoho haba ya ota esegahi ya lau ee–,  
\q2 hitina yo hitina.   
\q1
\v 18 Umi, safalumadi ena liba fasunuma yo laugagayo sa atahiyedi,  
\q2 mate bena sa awaꞌabiyedi.   
\q1
\v 19 \nd Guyau\nd* galewa ya abi ena aba taꞌai,  
\q2 be amainiya ginauli mahudoꞌidi ya tanuwagaidi.   
\q1
\v 20 \nd Guyau\nd* au fadebasae!  
\q1 Umi, ena anelu adiꞌadidilidi yo dididigadi,  
\q2 yo umi ena laugagayo au awaꞌabiyedi,  
\q2 yo au ataꞌatahi lau somo ya libalibaedi.   
\q1
\v 21 Wananaha! \nd Guyau\nd* au fadebasae!  
\q2 Umi, Galewa ena hiyala dodogadi,  
\q2 yo umi, ena tau paisowa,  
\q1 be ena nuwatuhu ami laulau watandi,   
\q1
\v 22 Ginauli mahudoꞌidi ya ginauli ena aba baꞌisa nuꞌuna mahudoꞌina yai,  
\q2 Guyau, au fadebasaen.  
\q1 \nd Guyau\nd* ee–, egu nuwanuwatuhu yai E fadebasaem.   
\c 110
\s1 \nd Guyau\nd* ena Kin ya Tole Hitin  
\q1
\v 1 \nd Guyau\nd* ya libalau egu Guyau lisina;  
\q2 Ai sibagu u taꞌai ya lau ee–, am waiyunu E abidi,  
\q2 be ahem ubuna yai E toledi.   
\q1
\v 2 \nd Guyau!\nd* Em gigibwali ya tadada Saiyon Nuꞌuna yai,  
\q2 be am waiyunu haba wa tanuwagaidi.   
\q1
\v 3 Lahaina ni haba am waiyunu wa hiyalaidi.  
\q2 Haba em dodoga sa faisagusagu.  
\q1 Doha hwahwalala sibudi, tanohi sa faꞌwau,  
\q1 am hewahewali tatau haba sa laoma sa saguhimiu.\f + \fr 110:3 \ft Lausoisoi te ya poꞌi wananaha Buka haisa tiyen: am hewahewali tatau haba sa laoma lisim ai tuꞌa tabudi. Na haisa sa lau hudoꞌi.\f*   
\q1
\v 4 \nd Guyau\nd* haꞌa ya angwala yo ibege nuwana i bui.  
\q1 Um haba tau antalasam hige ana siga,  
\q2 doha Melekisideki ena pele.   
\q1
\v 5 \nd Guyau\nd* mate In nima sibam yai,  
\q1 lahaina ni yena ya manabala haba kin ya faheyayadi.   
\q1
\v 6 Haba ena fakasa ya fatalu ai nuꞌu hesa - hesa,  
\q1 be haba silan yai ya famohafudi,  
\q2 na tanoꞌubu edi kin haba ya sai tawanidi.   
\q1
\v 7 Sagasaga edaꞌeda sadaina yai, haba ainiya Kin hoꞌowa ya nom,  
\q1 be tauna ya faꞌadidilidi.  
\q2 Ana waiyunu haba ya lei hafihafitidi.   
\c 119
\s1 \nd Guyau\nd* ena Laugagayo Awa Abiyenna  
\sr Samsi 119:9-16  
\d Beth  
\q1
\v 9 Haba sidohana taumoho hewahewalina ena mwahuli ya bobodiyei?  
\q2 Bena Em laugagayo ya awa abiyedi.   
\q1
\v 10 Nuwagu ma ofi fahina em laugagayo E awa abiyen.  
\q2 U ita watanigu, be ibege em laugagayo ya lau afuledi.   
\q1
\v 11 Em liba E nuwatuhui nuwagu yai,  
\q2 be ibege heyaheyaya ya ginauli ai lisim.   
\q1
\v 12 \nd Guyau\nd* ee–, E fadebasaem.  
\q2 Em laugagayo u fatalahagu.   
\q1
\v 13 Laugagayo mahudoꞌidi moꞌam yai wa libaedi.  
\q2 E liba fuyoꞌidi.   
\q1
\v 14 E kwade fuyanna em laugagayo E laulau watandi,  
\q2 habahim gogo wasawasadi.   
\q1
\v 15 Em abiꞌabi yo em laulau  
\q2 E nuwatuhu fadosidi.   
\q1
\v 16 Em laugagayo E nuwa amnaedi, ibege nuwagu i fui.   
\c 139
\s1 Yaubada ya Siba Wananahaida  
\d Wana Tau Lau Kulukuluwenna, Deiwidi ana Wana Hesa  
\q1
\v 1 Guyau, wa siba wananahaigu  
\q2 nuwagu ganahewana wa ita faꞌofi.   
\q1
\v 2 Egu taꞌai yo egu obiyo haꞌa wa sibaidi.  
\q2 Edam ya lofa in moho egu nuwanuwatuhu haꞌa wa sibaidi.   
\q1
\v 3 Egu leu, egu sae yo egu anyawasi wa sibaidi.  
\q2 Egu laulau mahudoꞌidi haꞌa wa itadi.   
\q1
\v 4 Guyau, hola hige liba hesa ya libaen  
\q2 na haꞌa wa siba.   
\q1
\v 5 Um egu eda wa bwaꞌiyen yo hinaga muligu yai wa laolaoma,  
\q2 em gigibwali yai wa bobobodiyegu.   
\q1
\v 6 Sibasiba doha ite mate noꞌona hige gonowagu,  
\q2 ya hasai wananaha be hige gonowana somo ya ita lobahi.   
\q1
\v 7 Siya haba E fuyofuyoꞌegu be ibege u itagu?   
\q1
\v 8 Ibe E hasai galewa, um amainiya;  
\q2 ibe E peꞌi be sa boꞌusaigu, um hinaga amainiya.   
\q1
\v 9 Ibe E lofo lau maihala ena aba kepama nuꞌuna yai,  
\q2 e E lau maihala ena aba bulu nuꞌuna yai E miya,   
\q1
\v 10 ai nuꞌudi ni hinaga haba wa foyahigu,  
\q2 na em adidili aba bobodiyegu.   
\q1
\v 11 Yau gonowagu kamumu E faliba ya simogu  
\q2 e mala ya fataꞌiꞌiligu gonowana e faliba ya iꞌipa.   
\q1
\v 12 In moho kamumu yai hige gonowana  
\q2 ya ala simoꞌem hinaga.  
\q1 Iꞌipa lisim yai ya mahata doha lahai.  
\q2 Kamumu yo mahata um lisim yai gonogonowadi.   
\q1
\v 13-15 Tinagu bogana ganahewana yai wa itagu;  
\q2 um ibom moho wa siba yau amainiya,  
\q2 kamumu ganahewana yai.  
\q1 Taugu mahudoꞌidi wa ginaulidi,  
\q2 wa fasusu gogondi tinagu bogana ganahewana yai.  
\q1 E fadebasaem paꞌana wa ginauli loholohoꞌigu  
\q2 yo wa ginauli komakomanigu.  
\q1 E siba wananaha em paisowa sa fanuwa noꞌonoꞌo wananaha.   
\q1
\v 16 Taugu hola hige u fasusu gogondi  
\q2 na hola hige lahai bwaꞌibwaꞌina i tubu,  
\q2 mate haꞌa wa itagu.  
\q1 Na egu mwahuli lofana fisa haꞌa wa uli nonohai em buka yai.   
\q1
\v 17 Aee–, egu Yaubada, hige gonowana em nuwatuhu ya siba ofinidi,  
\q2 paꞌana sa ouli wananaha!   
\q1
\v 18 Hige gonowana hinaga ya fatilidi  
\q2 paꞌana sa ouli wananaha, habahim gelegele fufuꞌadi!  
\q1 Yena bena mahudoꞌina E fatili,  
\q2 mate yena E eno obiyo, um maꞌegu.   
\q1
\v 19 Aee–, egu Yaubada, E fanuha wananaha  
\q2 bena heyaya tau laulau ginauli wa wunuidi!  
\q1 Yo tau aiꞌaiyunu wa falakodi.   
\q1
\v 20 Sa liba fafaheyayam  
\q2 yo hesam hige ti faꞌatitiyen.   
\q1
\v 21-22 Guyau, tau ꞌwaiyoꞌoꞌem hinaga E ꞌwaiyoꞌoꞌedi.  
\q2 Em liba hige ti lau watan be iti agu waiyunu.   
\q1
\v 23 Nuwagu ganahewana u mainene komakomaniꞌi,  
\q2 egu nuwanuwatuhu u sibaidi.   
\q1
\v 24 Laulau heyaheyayadi somo lisigu yai u faꞌitagu  
\q2 na u foya lawegu mwahuli edaꞌedana otaꞌotafahina lisina yai.   