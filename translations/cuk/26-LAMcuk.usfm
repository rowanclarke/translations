\id LAM - Kuna, San Blas - Bible -Panama 2014 (DBL -2014) 
\h Lamentaciones 
\toc1 Naibi-Itoleged-Garda 
\toc2 Lamentatciones 
\toc3 Lm 
\mt1 NAIBI-ITOLEGED-GARDA 
\mt2 LAMENTACIONES 
\imt2 GEBE-SOGLENAID 
\imt1 Garda-nug 
\ip \it Naibi-Itoleged-Garda.\it* We-garda-e-nuga Septuagintaʼgi, Griego-gayabali, \it Zrénoiʼye\it* bileged. We sogleged, “Naibi-itogedgi namaklegedye,” degi, “Wile-itolegedgi namaklegedye.” 
\is1 Naibi-Itoleged-Gardagi weyob sunmaklenaid 
\ip We-gardagi, Jerusalén-neggwebur Babilonia-sordamarse-ibitosadba naibi-itogedgi sunmaknaid. Degi, Israel-dulemar Babilonia-yalase gales-ebipilesadba naibi-itogedgi sunmaknaibalid. Bab-Dummadgi bensulid-nikadgi, degi, yoedse ibagan-nuegan danikoedgi sunmaknaibalid. 
\ip We-gardagine, weyob ilemakar sunmaklenaid: 
\io1 1. Naibi-Itoleged-Garda-gebe-narmaklesad (1:1-22). 
\io1 2. Bab-Jehová Jerusalén-dulemarga wile-itoged uksad (2:1-22). 
\io1 3. Bab-Dummad-dule-wiledakedba yoedse-bendaklegoed edarbileged (3:1-66). 
\io1 4. Sión-neggwebur-sabsur-odurdakleged bergusad (4:1-22). 
\io1 5. Jerusalén-dulemar-wilebukwad Bab-Dummadse-goled (5:1-22). 
\ip Be itogua. 
\c 1  
\ms1 1. NAIBI-ITOLEGED-GARDA-GEBE-NARMAKLESAD 
\mr (1:1-22) 
\s1 Sión-neggwebur-galessiid naibi-itosiid 
\q1  
\v 1 Sión-neggwebur dulemar-bukidar-nikagusanad, 
\q2 emidi, ibiyobi walagwen-ganna sigisa. 
\q1 Jerusalén-neggwebur, neggwebur-bamaladba-bur-nuga-nika-sigisanad, 
\q2 emidi, ome-ei-sui-burgwisadyobi siid. 
\q1 Jerusalén-neggwebur, neggwebur-bamalad-e-dummadga-sigisanad, 
\q2 emidi, neggwebur-bamalad-e-maiga siid. 
\b  
\q1  
\v 2 Mutikidbali, naibid-dummad-itogedbali bela-bela boed, 
\q2 e-wagarbali e-ibyanis suurmakmaid. 
\q1 Dulemar-nue-sabye-sogdimalad-abargi, e-gwage-baisur-ito-imakedi, wargwensaale sated. 
\q2 Bela e-aimar egi aibichamalad, e-isdarmaladga gunonimalad. 
\b  
\q1  
\v 3 Judá-dulemar esgoro-dubgi-atinnale, 
\q2 yar-baidse gales selesmalad. 
\q1 Dule-ainebarmalad-abalagi-gudidimalad, 
\q2 gwen obunnoged amisurmalad. 
\q1 Bela-balegindimalad, Judá-dulemar-bargasmalad, 
\q2 sabsur-odurdaksamalad. 
\b  
\q1  
\v 4 Sión-neggweburse-naega igarmar-mamaidi, wiles dakleged, 
\q2 ar e-itoakwaa-ibagan-onolegedse dulemar bar nanasurmalad. 
\q1 Bela e-yawagakmar bergus gwigwichid. 
\q2 E-dule-irwa-Bab-Dummadse-gormalad bodimalad. 
\q1 E-yagana, wile itodimalad. 
\q2 Jerusalén-neggweburgi bela nunmakedbi neg-nagusad. 
\b  
\q1  
\v 5 E-isdarmalad, e-dummaganga gunonimalad, 
\q2 e-isdar-dakmalad, ibmar bur bule nikudmalad. 
\q1 E-isgued-bukidar-nikad-ulale, Jerusalén-dulemar Bab-Dummadse sabsur-odurdaklenonimalad. 
\q2 E-mimmigan gales aineba selesmalad, e-isdarmaladse ebipilesmalad. 
\b  
\q1  
\v 6 Sión-neggwebur epenne e-yeerdaklesigusadi, bela bergunonikid. 
\q2 E-dummagan, goe-sapur-gagan-maega-amididamaladyob gaamakdimalad. 
\q2 E-balegindimalad-abin geggus wakitemalad. 
\b  
\q1  
\v 7 Jerusalén-neggwebur, e-ibagan-isgana-nasad ebinsaed, 
\q2 e-dulemar-gales-selemamaigusad, ebinsaed. 
\q1 Epenne bela-ibmar-nuegan-bukidar-nikagusad, ebinsaed. 
\q1 E-dulemar, e-isdarmaladse-galesmargua, 
\q2 dule-bamalad gwen bendaksasulid. 
\q1 E-isdarmalad, Jerusalén-dulemar-galakus-daksagua, 
\q2 egi dodonai gusmalad. 
\b  
\q1  
\v 8 Jerusalén-neggwebur bela-bela isgusad. 
\q2 A-ulale, ib-isganaga gunonikid. 
\q1 Jerusalén-neggwebur-ayaris-sii-dakarmargua, dulemar, iduar Jerusalén-nug-odummodimalad, 
\q2 emidi, isdar dakmalad. 
\q1 Jerusalén-dulemar na boed, 
\q2 binge-itogedba na wagar odukued. 
\b  
\q1  
\v 9 Bela e-mor nue-isgusad, 
\q2 na e-berguoedgi binsassulid. 
\q1 Ukiagwar oitolenonikid, 
\q2 dule-bamalad gwen-wile daksasulid. 
\q1 Emidi, soged: “Bab-Jehováʼye, an-wile-itoged be dake. 
\q2 An-isdarmalad angi obichad.” 
\b  
\q1  
\v 10 Jerusalén-neggwebur e-ibmar-nuegan-nikadi, 
\q2 e-isdarad bela e-ibe susad, 
\q1 E-Bab-Dummadse-goled-neggi, dulemar-Bab-Dummad-akudakmalad-ubosmalad 
\q2 Jerusalén-dulemar daksamalad. 
\q1 Bab-Jehová, be a-dulemarga igar-mesisanad, 
\q2 mer an-igar-itoged-negse dogmaloye. 
\b  
\q1  
\v 11 Bela Jerusalén-dulemar bodimalad, masgunned amidimalad. 
\q2 Na dulagudigumalaga, e-ibmar-bur-nuegan masbina ogwaed. 
\q1 Ise-boale sogmalad: 
\q2 “Bab-Jehováʼye, be dake, ibiyobi an-wionanai.” 
\b  
\q1  
\v 12 Sogdebalid: “Bemar-igarba-nadapmalad, be an-dakmala, 
\q2 ¿gwen-bai be an-daksuli? 
\q1 Bab-Dummad-sabsur-an-wionaiyobi, 
\q2 ¿bia be deyob dule-wilenai daksamala? 
\q1 Ar Bab-Jehová na nue-uludgua, 
\q2 we-nunmaked anga barminonikid. 
\b  
\q1  
\v 13 ”Bab-Jehová, nibneg-akale, soo barmialid. 
\q2 A-soo, garmarse-bakale, an-ogumaksad. 
\q1 An-iduale, saki nasiksad, 
\q2 gannar sikirmakega an-imaksad. 
\q1 Walagwen an-meted, 
\q2 bali-bali nunmaked-itogega an-imaksad. 
\b  
\q1  
\v 14 ”Bab-Jehová-sunnad an-isgued oatosad, 
\q2 an-isgued akwa-dummad-aidikuedyob angi naid. 
\q1 An-dukarba anga nasiksad, 
\q2 an-gargangued nolloo imaksad. 
\q1 Bab-Jehová, an-isdarmaladga an-urmaksad, 
\q2 an geg amar-abin-imaked. 
\b  
\q1  
\v 15 ”Bab-Jehová, an-neggweburgi bela sordamar-bulegan onisad. 
\q2 Angi yolemalagala, dule-bamaladse gochad, 
\q2 an-sapingan-oitogegala, dule-baiganse gochad. 
\q1 Igi uva-nis-egurega uva-birgi annaledae, 
\q2 deyobi Bab-Jehová, Judá-e-bunamala imaksad. 
\b  
\q1  
\v 16 ”Bela we-ibmala boega an-imaked, 
\q2 boedba nue an ataksurgusad. 
\q1 Dule-an-gwage-baisur-ito-imaked an-walik gudisulid, 
\q2 dule-wis-gadi-gadi-an-imaked, an daksulid. 
\q1 Ar an-isdarmalad anmargi nakwissoggu, 
\q2 an-mimmigan wargwen melledmarsunnad.” 
\b  
\q1  
\v 17 Sión-dulemar, bendaklegegala gornanaid, 
\q2 ar dule-e-gwage-baisur-ito-imaked sated. 
\q1 Bab-Jehová-igar-mesnonikidba, Jacob-yar-naid-dikarba-neggwebur-bukmalad, 
\q2 emidi, Jacob-e-isdarmaladga gunonikid. 
\q1 Jerusalén-neggwebur ibmar-durwaga gunonikid, 
\q2 ibmar-isganaga gunonikid. 
\b  
\q1  
\v 18 “Bab-Jehová, innikigwadba ibmar-imakedid, 
\q2 ar andi, e-igar-mamaidgi aibichad. 
\q1 Bemar bela dulemar, nue an-itomala, 
\q2 an-wile-itonaid be nue dakmala. 
\q1 An-sapingana, bela-gales aineba selesmalad, 
\q2 an-bunamala, bela-gales aineba selesmalad. 
\b  
\q1  
\v 19 ”An-aimarse, an iseedi gornai gusanad, 
\q2 aka bur angi aibichamalad. 
\q1 An-dule-irwa-Bab-Dummadse-gormalad, an-girmar-dummagan, na dulagudigumalaga mas-amidigu, 
\q2 neggweburgi burgwismalad. 
\b  
\q1  
\v 20 ”Bab-Jehová, an-nunmak-itonaid, be dake. 
\q2 An burgwe itoged. 
\q1 An beba bela-bela ibsassursoggu, an-gwage suli-suli-ito naded. 
\q2 Neg-magabali, an-mimmigan, es-suidgi oburgwilenanaid, 
\q2 wegi negyabali, burgwed neg-gasa naid. 
\b  
\q1  
\v 21 ”Dulemar an-gormaknaid itosmalad, 
\q2 ar dule-an-gwage-baisur-ito-imaked sated. 
\q1 Bela an-isdarmaladi, an-wilenaid wismalad, 
\q2 be igi-an-imaksadgi wergumalad. 
\q1 An igi-wilesa, deyobi wilemarmosun. 
\q2 Be sabsur-odurdaklemaloye-sogsagusadi, 
\q2 an-isdarmaladgi gwae be barmidasun. 
\b  
\q1  
\v 22 ”Bab-Jehová, bela an-isdarad-e-isgumalad be dake. 
\q2 An-isgusad-ular, igi be sabsur-an-odurdaksagusa, 
\q2 deyobi be an-isdarmalad imakmoga. 
\q1 Bato an bukidargus nunmaked-itodanikid, 
\q2 nue-angi obin an itogusad.” 
\c 2  
\ms1 2. BAB-JEHOVÁ JERUSALÉN-DULEMARGA WILE-ITOGED UKSAD 
\mr (2:1-22) 
\s1 Bab-Jehová, Israel-dulemar-ogilosad 
\q1  
\v 1 Bab-Jehová na e-uludedbali, ibiyobi Sión-neggwebur-yeerdaklegedgi negsichid nasiksa. 
\q2 Bab-Jehová nibneg-akale, Jerusalén-neggwebur-yeerdakle-siid omukusad. 
\q2 Bab-Jehová e-iba-uludedgi na ese-goled-neg, we-napneggi-siideeye binsassulid. 
\b  
\q1  
\v 2 Bab-Jehová bela Jacob-wagan-e-negmar-bukwadi, gwen-wile-daksasuli obelosad. 
\q2 Bab-Jehová na e-uludedbali, Judá-yar-yeerdakleged-e-neg-gandikmalad bibichisad. 
\q1 Bab-Jehová, Judá-e-rey-dummadga-maid-egwachadba, Judá-yar-nug bipii imaksad. 
\q2 Judá-e-dummaganga-mamaid-egwachadba, Judá-yar-nug bipii imaksad. 
\b  
\q1  
\v 3 Bab-Jehová, uludgua, bela Israel-e-gargangued obelosad. 
\q2 Anmar an-isdarmaladbo-urwenaigua, Bab-Jehová anmar-bendaksasulid. 
\q1 Soo-dummad-bela-ibmar-obelogedyobi, 
\q2 Jacob-e-yar-naidgi soo ogasad. 
\b  
\q1  
\v 4 Bab-Jehová anmar-isdaradyob warsi guagwar gasad, 
\q2 e-swida-nuedsikid guagwar oyosgwichid. 
\q1 Bab-Jehová anmar-isdaradyob, anmar-gwenadgan-ogilosad. 
\q2 Bab-Jehová na e-urwedi, sooyobi Sión-yeerdakleged-e-negmargi odesad. 
\b  
\q1  
\v 5 Bab-Jehová anmar-isdaradyob na imaked: 
\q2 Israel-yar obelosad. 
\q1 Bela Israel-e-reynegmar bibichisad, Israel-e-neg-gandikmalad omukusad. 
\q2 Bab-Jehová Judá-yar-yeerdaklegedgi boedbi, wile-itolegedbi, neg nasiksad. 
\b  
\q1  
\v 6 Bab-Jehová e-maid-neg sosganeg-siiyobi earisad, 
\q2 e-onmakedneg-siidi omukusad. 
\q1 Bab-Jehová, Sión-dulemar na e-iba-itoakwaa-onoleged-iegega imaksad, 
\q2 e-obunnoged-iba-iegega imaksad. 
\q1 Bab-Jehová nue-uludedbali, rey-maid obachad. 
\q2 Dule-irwa-ese-goled obachad. 
\b  
\q1  
\v 7 Bab-Jehová, na e-ibmar-ogumakar-ukleged-aila obachad, 
\q2 na e-neg-islidikid isdar daksad. 
\q1 E-reynegmar-e-galumar, e-isdarmaladga urmaksad. 
\q2 E-isdarmalad, iba-dummad-nonaiyob, Bab-Jehová-neggi oimakdemalad, 
\b  
\q1  
\v 8 Bab-Jehová, Sión-neggwebur-yeerdakleged-e-galu-matusur-ebirmaidi, omukuedgi binsasad. 
\q2 Obeloged-igar ilemakar mesisad, 
\q2 gwen-wile-daksasuli galu-matusur-maid obelosad. 
\q1 E-arsanyob-maidgi, e-galumar-birgi nunmak-itoged nagusad, 
\q2 bela we-ibmarmar malusad. 
\b  
\q1  
\v 9 Jerusalén-neggwebur-e-yawagakmar bela aimukusad, 
\q2 Bab-Jehová bela yawagak-edimalad bibichisad. 
\q1 Jerusalén-e-rey yar-baidsik yoggus gudiid, 
\q2 e-sapin-dummagan, yar-baidsik yoggus gudidimalad. 
\q1 Bab-Dummad-igar bergusad, 
\q2 Bab-Jehová, e-gayaburba-barsogmaladga bar negburgan oyossulid. 
\b  
\q1  
\v 10 Sión-neggwebur-yeerdaklegedgi girmar-dummagan, napayala bogidik sigismalad. 
\q2 Girmar-dummagan, nunmak-itogedba na e-nonogine, sogun-buru eosmalad, 
\q1 wile-itoleged-mor yosmalad. 
\q2 Bunamala-Jerusalénʼginmalad, bingedbali, napase dulluu nono imaksamalad. 
\b  
\q1  
\v 11 Boedbali, bar an nue ataksurgusad, 
\q2 an bela-bela gwage nunmak itoged. 
\q1 An-neggwebur-ibitosadbali, an-niga bela argwachad. 
\q2 Burwigana, degi, goemala, neg-imbabali, burgwemamaid. 
\b  
\q1  
\v 12 Burwigana e-nanganse egichardamalad: 
\q2 “¿Bia masde? ¿Bia gobedde?” 
\q1 Mas-satedbali, burwigana neg-imbabali, binna-binna burgwiddamalad. 
\q2 E-nan-nukugi napi-bunnomai burgwiddamalad. 
\b  
\q1  
\v 13 Jerusalén-yeerdakleged, ¿ibu an begi obarosunna? 
\q2 ¿Doabogwa an be-wilubsaosunna? 
\q1 Jerusalén-neggwebur-swilidikid, be-gwage-baisur-itogega, ¿ibu an bega oyogergebe? 
\q2 Be-naibi-gusad, demar-wiladyob gued. 
\q2 ¿Doa gannar be-nudakoe? 
\b  
\q1  
\v 14 Be-Bab-Dummad-gayaburba-barsogmalad, gakansaale negburgan-daksad bega sogsamalad, 
\q2 be-yardakale bega sogsamalad. 
\q1 Be-isgued gwen barsogsasurmalad, 
\q2 melle be-gamalaga gwen be-bendaksasurmalad. 
\q1 Bemarga gayaburba-gakansaaled sogsamalad, 
\q2 a-gayaburbagi, melle be bensuliguega be-imaksamalad. 
\b  
\q1  
\v 15 Dulemar-igarba-nadapmalad, 
\q2 be-dakarmalale, begi dodoar argan ogotedamalad. 
\q1 Jerusalén-neggwebur-yeerdakleged, be-asabin akar-akar gunanadaed. 
\q2 Wigoar-wigoar sognanaidaed: 
\q1 “¿Ar we-neggwebur nue-yeerdaklegedye sogmaladi? 
\q2 ¿Ar we-neggwebur, bela napneg-yeer-ito-imakedye sogmaladi?” 
\b  
\q1  
\v 16 Jerusalén-dulemar, bela be-isdarmalad begi-sunmakdemalale, 
\q2 begi isdar sunmakdedamalad. 
\q1 Nue-sae-be-dake, dodoar weyob sognanaid: 
\q2 “Anmarse dula dolesad. 
\q1 Anmar bela-bela-iba-edarbediid nonikid, 
\q2 anmar-sunnad daksasunnad.” 
\b  
\q1  
\v 17 Bab-Jehová ibmar-imakega na igar-amisadi, sogedba imaksad, 
\q2 na dikasurgus ibmar-sogsadi, bela imaksad. 
\q1 Bab-Jehová be-wiledaksasuli, be-obelosad, 
\q2 be-isdarmalad begi-dodogega imaksad, 
\q2 begi-yolenanaid-e-gangued ogannosad. 
\b  
\q1  
\v 18 Sión-dulemar, Bab-Dummadse, ise-wilegar gornanaid. 
\q2 Sión-neggwebur-yeerdakleged-galu-matusulid-nika-siid, 
\q1 mutikidbali, ibginedbali, diwaryobi be-ibyanis aryomai be imake. 
\q2 Mer be boed bogigue, mer be be-ibyanis-aryomaid bogiguega imake. 
\b  
\q1  
\v 19 Be gwisgue, mutikidbali be ise-gollar imake, 
\q2 wachi-iliba be ise-gollar imake. 
\q1 Bab-Jehová-asabin ibmar-ukleged-uknaiyob, gwage-nunmaked-itogedbali na be bosii imake. 
\q2 Be-mimmigan-mer-burgwegala, Bab-Dummadse argan-onakwar be gorsii imake. 
\q1 Be-mimmigan ukudbali burgwemamaid, 
\q2 neg-imbaba burgwis mellemamaid. 
\b  
\q1  
\v 20 “Bab-Jehováʼye, be dake, nue be itogena: 
\q2 ¿Doa-dule be weyob imaksagusa? 
\q1 ¿Ar omegan na e-mimmigan gunmarsunnode? 
\q2 ¿Na e-mimmigan-egi-danimalad gunmarsunnode? 
\q1 Bab-Jehováʼse-goled-neggi, ¿ar dule-irwa-Bab-Dummadse-gormalad oburgwilemalode? 
\q2 ¿Ar Bab-Dummad-gayaburba-barsogmalad oburgwilemalode? 
\b  
\q1  
\v 21 ”Sapingana, degi, dule-serganse-bakale, neg-imbaba burgwar mellemamaid. 
\q2 An-sapingana, degi, an-yagana, es-suidgi oburgwilesmalad. 
\q1 Be-uludedbali, be wemar oburgwisad, 
\q2 bela-bela-wiledaksuli, be wemar oburgwisad. 
\b  
\q1  
\v 22 ”Iba-dummad-onolegedse-danimalayob bela bonigan angi dagega be imaksad. 
\q2 Bab-Jehová-Ulusad-ibagi, dule-wargwensaale, san-onossulid, bela burgwismalad. 
\q1 An-gwenadgan an odummosadi, an ibmargi-odurdaksagusadi, 
\q2 an-isdarmalad, bela an-ibe ogilosad.” 
\c 3  
\ms1 3. BAB-DUMMAD-DULE-WILEDAKEDBA YOEDSE-BENDAKLEGOED EDARBILEGED 
\mr (3:1-66) 
\s1 Ollorgued-igar Bab-Dummadgi edarbileged 
\q1  
\v 1 An-sunnagwad, Bab-Jehová-uludedbali sabsur-dule-odurdaked an itosad. 
\q2  
\v 2 Negsichiganaba an-nimai gusad, 
\q1 neg-meegwadba an-nimai gussulid. 
\q2  
\v 3 Bali-bali, wachi-iliba, sabsur-an-odurdaknai gusad. 
\b  
\q1  
\v 4 Bab-Jehová, an-san, degi, an-uka-dunnumakega imaksad, 
\q2 an-ibe an-garmar bibichisad. 
\q1  
\v 5 Bab-Jehová angi bonigan ebiris nasiksad, 
\q2 angi wileged-dummad ebiris nasiksad. 
\q1  
\v 6 Dulemar-undargus-burgwismaladyob, 
\q2 negsichigangi-gudiguega an-imaked. 
\b  
\q1  
\v 7 Bab-Jehová negyaba-mellesii an-imaksad, 
\q2 gege an wakinned, 
\q2 esgoro-dub-dummagangi an-edichad. 
\q1  
\v 8 An-bendakegala, an binnasuli gornai-inigwele, 
\q2 Bab-Jehová an-ese-gornaid budar an-itoged. 
\q1  
\v 9 An-iduar, an-igargi akwamar misad, 
\q2 an-ibe an-igar oburusad. 
\b  
\q1  
\v 10 Bab-Jehová, wiob mas-gaega matarmakdiidyobi anbina gudiid, 
\q2 achumigur-nono-wawaad masbina matarmakdiidyobi anbina gudiid. 
\q1  
\v 11 An-san-oichimakega igargi an-obachad, 
\q2 mer bendakleged-amiega, walagwen an-obesad. 
\q1  
\v 12 Guagwar warsi-gasad, 
\q2 e-sigumar an-makega imaksad. 
\b  
\q1  
\v 13 E-saboged-yaba sigumar-onosadgi gwagegi an-maksad. 
\q2  
\v 14 Bela an-dulemarga an dodoedga gunonikid, 
\q2 bane-bane angi-dodolegar namakmalad. 
\q1  
\v 15 Bab-Jehová nunmaked-dummad anga uksad, 
\q2 ina-gagbidgi an-ogobsad. 
\b  
\q1  
\v 16 Bab-Jehová napagi an-omukusad, 
\q2 olli-maega an-imaksad. 
\q1  
\v 17 Gwage-bogidikid an-ibe obelosad, 
\q2 weligwar-itoleged bar an ebinsasulid. 
\q1  
\v 18 A-ulale, an soged: “An-gargangued bergusad, 
\q2 Bab-Dummadgi an ibmar-edarbediid bar an dakosulid.” 
\b  
\q1  
\v 19 An-wile-itodiid, an-neg-sate-gaamakdiid, be ebinsao. 
\q2 Ar we-ibmarmar, naibid-dummad anga uked. 
\q1  
\v 20 Bane-bane an we-ibmargi binsadiid, 
\q2 a-ulale, bar an ibmar imakbisuli itoged. 
\q1  
\v 21 Degi-inigwele, an ibmar-soggwendi ebinsaed, 
\q2 we, mer suli-suli-itogega an-imaked. 
\q1  
\v 22 Bab-Jehová-sabgued-dummad-nikad-ular, anmar bergussulid, 
\q2 e-wile-emar-daked gege bergued. 
\q1  
\v 23 Bab-Jehová-e-wile-emar-daked bane-bane binoleged. 
\q2 Bab-Jehová-sogedba-ibmar-imaked dummarba gued. 
\q1  
\v 24 Degisoggu, an soged: 
\q2 “Bab-Jehováʼbi anga unni gued, 
\q2 agala, an egi bensulid.” 
\b  
\q1  
\v 25 Bab-Jehová, dule-egi-bensur-gudimaladgi nued daed, 
\q2 bela dule-e-amidimaladgi nued daed. 
\q1  
\v 26 Bur-nuedid, anmar doga-doga-itosulidgi, Bab-Jehová-anmar-bendakdagoed edarbed. 
\q2  
\v 27 Bur-nuedid, dule sapingwagwad-akale, bonigan-abalagi ganna-gudigued durdaked. 
\b  
\q1  
\v 28 Melle ese be gole, itoba bogidik sigoed, 
\q2 ar Bab-Jehová deyob ega igar mesisad. 
\q1  
\v 29 Nue-bingegusa, wagar napase dulluu imakoed, 
\q2 abakale, amba Bab-Dummad e-bendakalile. 
\q1  
\v 30 Dule-e-ibe-wagar-bibyonaidga, baid-wagar oyobalo, 
\q2 deyobi, nue bingeguoed. 
\b  
\q1  
\v 31 Bab-Jehová anmar-obachad, degi-inigwele, deyob-anmar-imakmai sadeguosulid. 
\q2  
\v 32 Nunmak-itoge anmar-imaked, degi-inigwele, anmar-wile dakbalid, 
\q2 ar e-sabgued dummarba gued. 
\q1  
\v 33 Bab-Jehová anmar-naibi imaked, anmar-wile-ito imaked, 
\q2 ar deyob-anmar-imakedgi wergudeeye soglesulid. 
\b  
\q1  
\v 34 Bab-Jehová weyob-ibmar-imaklemalad abemaisulid: 
\q2 We-napneggi bela-dulemar-esgaryagi-mellebukwad sabsur-imakleged, abemaisulid. 
\q1  
\v 35 Bab-Dummad-Bur-Birigined-asabin dulega-igar-nabolesulid, abemaisulid. 
\q2  
\v 36 Bab-Dummad-Bur-Birigined-asabin dulega-innikigwadba-igar-itolesulid, abemaisulid. 
\b  
\q1  
\v 37 ¿Doa Bab-Dummad-ega-igar-uksuli ibmar-soged nabir imakoe? 
\q2  
\v 38 ¿Ar Bab-Dummad-Bur-Birigined-igar-ukedbali ibmar-nuegan, degi, ibmar-isgana gusursi? 
\q1  
\v 39 ¿Ar ibiga dule na e-isgusadba sabsur-odurdaklealir 
\q2 urwedii guoe? 
\b  
\q1  
\v 40 Anmar na anmar-daedgi nue-binsasii imakmala, 
\q2 anmar Bab-Jehová-amimala, gannar ese dagmala. 
\q1  
\v 41 Anmar, Bab-Dummad-nibneggi-maidse-golega argan onakwe. 
\q2 Anmar, Bab-Dummad-nibneggi-maidga anmar-binsaed soge. 
\q1  
\v 42 Anmar isgusad, anmar uayasuli nanadii gusad, 
\q2 Bab-Jehová, be anmarga anmar-isgued elissulid. 
\b  
\q1  
\v 43 Bab-Jehová, be nue-urwedbali be anmar-baleginned, 
\q2 wile-be-anmar-daksuli, 
\q2 be anmar-obeloged. 
\q1  
\v 44 Anmar-bese-goled mer be itogegala, be mogir-imbaba dukusad. 
\q2  
\v 45 Dulemar-yar-baid-baid-bukwamalad-abargine, ibmar-isganayob be anmar-barmeted. 
\b  
\q1  
\v 46 Bela-anmar-isdarmalad sunmakdemalale, 
\q2 anmargi ichakwaa sunmakdedamalad. 
\q1  
\v 47 Anmar, dobgued-dummad itosmalad. 
\q2 Anmar, omukulesmalad. 
\q1 Anmar, ibmar-sate gusmalad. 
\q2 Anmar, nunmaked-dummad itosad. 
\q1  
\v 48 An-neggwebur-e-saila-gusiid-nue-ibitosadbali, 
\q2 an-wagarba diwar-aryomaiyob ibyanis aryomaid. 
\b  
\q1  
\v 49 An-ibyanis gwen bogigusuli aryomaid, 
\q2 dule-an-gwage-baisur-ito-imaked sated. 
\q1  
\v 50 Bab-Jehová nibneggi-maid-akale, geb anmar-dakedse an gadi-gadi itononikoed. 
\q2  
\v 51 An-neggweburgi-omegan-gudidiid sabsur-odurdaklenaid-ulale, bela-bela an-gwage an nunmak itoged. 
\b  
\q1  
\v 52 An ibmar-akar-imaksasuli an-isdarmalad binsa an-baleginnanaid, 
\q2 nuuyobi an-gasmalad. 
\q1  
\v 53 Dula napa-urba an-odosmalad, 
\q2 an-iduar noed akwa-dummadgi edismalad. 
\q1  
\v 54 Bela diiba an-nono-dogdegua, 
\q2 an na belaye sogded. 
\b  
\q1  
\v 55 Bab-Jehová, an dia-dummadgi gulluyaa mellesigua, 
\q2 an bese gochagusad. 
\q1  
\v 56 An-bese-wilesagwa-gornaid be itosad, 
\q2 an-ise-gollar-gornaid be itononikid. 
\q1  
\v 57 An bese gochad, be anse nonikid, 
\q2 be anga sognonikid: “Mer be dobguye.” 
\b  
\q1  
\v 58 Bab-Jehová, bee be anbali nagusad, 
\q2 be an-bendaksad. 
\q1  
\v 59 Bab-Jehová, nue-an-wiosmalad be daksad, 
\q2 be anga innikigwadba igar nudake. 
\q1  
\v 60 Buged-mai angi-imakbimalad be daksad, 
\q2 an-oakalobimalad be daksad. 
\b  
\q1  
\v 61 Bab-Jehová, dule-angi-urwe-nanaid be itosad, 
\q2 an-oakalobimalad be daksad. 
\q1  
\v 62 Bab-Jehová, an-isdarmalad angi-sunmaknanai-osedoddaed be wisid, 
\q2 angi-gwisgumalaga igar-aminanaid be wisid. 
\q1  
\v 63 Bab-Jehová, be dake, na ibu imaknanadibe, angi dodonanadamalad, 
\q2 e-namakedgi angi-dodoar namakmalad. 
\b  
\q1  
\v 64 Bab-Jehová, wemar na bela e-ibmar-isgana-imaksad-ulale, 
\q2 be sabsur-odurdake. 
\q1  
\v 65 Ibmar-aku-itogega be imake, 
\q2 be ukabsasunna. 
\q1  
\v 66 Bab-Jehová, be-sae-itogedbali be wemar baleginne, 
\q2 we-napneggi be bela obeloge. 
\c 4  
\ms1 4. SIÓN-NEGGWEBUR-SABSUR-ODURDAKLEGED BERGUSAD 
\mr (4:1-22) 
\s1 Sión-neggwebur-sabsur-odurdaklesad 
\q1  
\v 1 ¡Or gudure daklegusad! 
\q2 ¡Or-nued e-gaed bar nue dakarmaksulid! 
\q1 Bab-Dummadse-goled-neggi ormar-bukwadi, 
\q2 bela negmar-imbaba omileded. 
\b  
\q1  
\v 2 Sión-dulemar bur bule epenne olo-nueganba e-bina soglegenad, 
\q2 emidi, napsa-nogyob daklemalad, 
\q2 dule-napsagi-arbaed e-ibmar-imakedyob dakleged. 
\b  
\q1  
\v 3 Achu-sapurmarbela na e-mimmigan-onuegala ega mam uked. 
\q2 Ar Jerusalén-omegandina, igi nuu-dummad-dukar-suidmar dule-negasulidganba na e-mimmigan-mete-naddamala, 
\q2 deyobi, e-mimmigan metemalad. 
\b  
\q1  
\v 4 Burwigana ukudmaad-itogedbali, 
\q2 e-gwabinmar achaa gayagi nagusad. 
\q1 Burwigana aisaar mas egisenad, 
\q2 degi-inigwele, dule gwen ega uksulid. 
\b  
\q1  
\v 5 Dulemar iduar mas-nuegan gundidamalanad, 
\q2 emidi, igarbali ukudba burgwemamaid. 
\q1 Dulemar iduar mor-nuegan-gargerbamalad yodamalanad, 
\q2 emidi, ibmar-isgana-abargine gudimalad. 
\b  
\q1  
\v 6 Jerusalén-dulemar-e-isguedi, bur bule Sodoma-dulemar-e-isgusadba gued. 
\q2 Sodoma-neggwebur yog-berguar gusad, 
\q2 gwen dule bendaksasulid. 
\b  
\q1  
\v 7 Jerusalén-e-dummagan, boobali bur sibudik daklenanaenad, 
\q2 moli-nunisba bur sibudik daklenanaenad. 
\q1 E-abagan akwa-bisgi-ginnigwadba bur bule gisii daklenanaenad, 
\q2 akwa-nued-zafiroʼyob daklemalanad. 
\b  
\q1  
\v 8 Emidi, e-daklegedi negsichidba bur gudure daklemalad, 
\q2 igarbali aku daklemalad. 
\q1 E-uka, sapanyobi dinnaa dakleged. 
\q2 E-uka-dinnagwadbali e-garmar buus-buus dakleged. 
\b  
\q1  
\v 9 Dulemar-es-suidgi-burgwismalad bur nuedid, 
\q2 dulemar-ukudba-burgwismaladba. 
\q1 Ar wemala, napaneg ega ibmar-gwag-osanmaksasulid-ulale, 
\q2 binna-binna ukudba burgwemamai gusmalad. 
\b  
\q1  
\v 10 Nangan-sabed-nikamalad, na dukin e-mimmigan-dunanai gusmalad. 
\q2 Jerusalén-neggwebur-ibitonaigua, we-nangan na e-mimmigan masga imaksamalad. 
\b  
\q1  
\v 11 Bab-Jehová bela-bela e-sae-itoged bar bargassulid, 
\q2 bela-bela e-sabsur-urwed oyosad. 
\q1 Sión-neggwebur ogumaksad, 
\q2 bela Sión-neggwebur-e-neg-sailase-bakar, ogumaksad. 
\b  
\q1  
\v 12 Reymar-we-napneggi-negsemamaidi, 
\q2 Jerusalén-e-isdarmalad, Jerusalén-e-yawagakgi dognonimaloye-soglesad, bengusmalad. 
\q1 Dulemar-we-napneggi-gudidimaladi, Jerusalénʼgi-gwisgudidimalad, 
\q2 Jerusalén-e-yawagakgi dognonimaloye-soglesad, bengusmarmogad. 
\b  
\q1  
\v 13 Neg-gunonikidi, Bab-Dummad-gayaburba-barsogmalad-e-isgusad-ulale, deyob neg-gunonikid. 
\q2 Dule-irwa-Bab-Dummadse-gormalad-e-isgusad-ulale, deyob neg-gunonikid. 
\q1 Neggwebur-neg-imbaba dule-ibmar-oakalossurmalad-e-ablis-eosmalad-ulale, 
\q2 deyob neg-gunonikid. 
\b  
\q1  
\v 14 We-dulemar ibyasuliyob igarba gudidimalad, 
\q2 e-argan ablis-sunnabi gudidimalad. 
\q1 Deyob-gudimaladbali, 
\q2 dule-wargwensaale, e-morse-bakale, gwen e-ibe ebubisulid. 
\b  
\q1  
\v 15 Dulemar iseed ega sogmalad: “Dule-swilidiksurmalad, wegi be namala. 
\q2 Be nomala, be nomala. Mer be anmarse achamala.” 
\q1 Dulemar-Bab-Dummad-akudakmalad yar-baid-baid-bukwamaladi sogmalad: 
\q2 “We-dulemar neg-sate gaamakdidimaladid, wakindimaladid. 
\q2 Wegi geg bar gudii gumalad.” 
\b  
\q1  
\v 16 Bab-Jehová uludedba wemar-obachad, 
\q2 bar we-dulemargi binsassulid. 
\q1 Dule-irwa-Bab-Dummadse-gormaladdeeye bar egi binsalesulid, 
\q2 dule-selebagusmalad bar wile daksurmarbalid. 
\b  
\q1  
\v 17 Anmar binsarsunna bendakleged-edarbediidbali, geg nue atakgusad. 
\q2 Aisaale, anmar, anmar-neg-matusulid-birgi dule-gwen-anmar-bendakmalosulidsik atakgwis damalanad. 
\b  
\q1  
\v 18 Ar anmargi nakuledidii nanaed, 
\q2 geg bar anmar galimbaba nanaed. 
\q1 Anmar-bergued modanikid, 
\q2 anmar-bergued-wachi bato nonikid, 
\q2 anmar-ibagan bato belad. 
\b  
\q1  
\v 19 Anmar-balegindimalad, sulubagimarba bur bule nanamalad. 
\q2 Yalaganba anmar-balegichamalad, 
\q2 nega-dulesulidganba anmar-iduar dukuar bukus gusmalad. 
\b  
\q1  
\v 20 Dule-Bab-Jehováʼse-nug-imaklesad, 
\q2 a-dule-isganamar-e-sakigi galesmogad. 
\q1 We-dule, anmar-bendakoedinad. 
\q2 Ar anmar we-dulegi sogdimalanad: 
\q1 “Dulemar-yar-baid-baidgi-bukmaladgi, 
\q2 we-dule, anmar-bendakdii guoye.” 
\b  
\q1  
\v 21 Edom-dulemar, Uz-yargi rey-bundoryob be gudimalad, 
\q2 be yeer-itomala, be wergumala. 
\q1 Ar bemar sabsur-odurdaklegedsemarmogad. 
\q2 Be-ibmar-nikadi bela be-ibe surgunonikoed. 
\b  
\q1  
\v 22 Sión-neggwebur-yeerdakleged, be-sabsur-odurdakleged bergunonisunnad. 
\q2 Bab-Dummad aineba gales-selemai bar be-imakosulid. 
\q1 Bedina, Edom-dulemar, Bab-Dummad, be-isgusadbali sabsur-be-odurdaknonikoed, 
\q2 bela be-isgusad magar-daklege imaknonikoed. 
\c 5  
\ms1 5. JERUSALÉN-DULEMAR-WILEBUKWAD BAB-DUMMADSE-GOLED 
\mr (5:1-22) 
\s1 Dulemar-wilebukwad Bab-Dummadse-goled 
\q1  
\v 1 Bab-Jehováʼye, anmar-gusadi be ebinsae, 
\q2 anmar-wiolenaid nue be dake. 
\b  
\q1  
\v 2 Anmarga-ibmar-uklegoye-soglesadi, dule-bamalad anmar-ibe susad. 
\q2 Anmar-negmar, dule-anmar-yarginsurmalad anmar-ibe susad. 
\b  
\q1  
\v 3 Anmar bab-sated, anmar dule-sergan-satedga gunonikid. 
\q2 Anmar-nangan suisuli gunonimalad. 
\b  
\q1  
\v 4 Anmar dii-gobedi bennukergebed, 
\q2 anmar sapanmar bakergebed. 
\b  
\q1  
\v 5 Anmar-balegindimaladi, bato anmar-bargadanikid. 
\q2 Anmar nue-geggus gudidimalad, anmar obunnoged sated. 
\b  
\q1  
\v 6 Anmar mas-gunned-amiegala, Egipto-dulemarse argan-oyonai gualid. 
\q2 Anmar mas-gunned-amiegala, Asiria-dulemarse argan-oyonai gualid. 
\b  
\q1  
\v 7 Anmar-babgan isgusmaladba burgwismalad. 
\q2 Anmardi, amar-isgusad-ulale, Bab-Dummadse sabsur-odurdaklesmalad. 
\b  
\q1  
\v 8 Emide, maiga-gudidimalad, anmar-dummadga gunonimalad. 
\q2 Amargi anmar-onogega dule sated. 
\b  
\q1  
\v 9 Anmar mas-amiegala, 
\q2 nega-dulesulidganba burgwednaga gudii gusmalad. 
\b  
\q1  
\v 10 Anmar ukudmaad-itogedbali, uelledmalad. 
\q2 Anmar-abagan diopi-diopisur itoleged. 
\b  
\q1  
\v 11 Sión-neggweburgi omegangi nue-dodolesad, 
\q2 Judá-neggweburmargi yagangi nue-dodolesbalid. 
\b  
\q1  
\v 12 Anmar-dummagan argangi-atinnar bannu-bannu nasiklesmalad, 
\q2 anmar-dadormargi dadormardeeye gwen binsalessulid. 
\b  
\q1  
\v 13 Anmar-sapingan ibmar-gwag-nagega imaksamalad. 
\q2 Burwigana sapan-gwaad-seedbali ibitodii guarmalad. 
\b  
\q1  
\v 14 Neggwebur-yawagak-noedgi sapin-dummagan bar ambikusurmalad. 
\q2 Sapingan bar namaksurmalad. 
\b  
\q1  
\v 15 Anmar bar weligwar itosulid, 
\q2 anmar-weligwaledgi-gwiled wile-itogedga binyenonikid. 
\b  
\q1  
\v 16 Anmar ologurgin bar sisurgusad. 
\q2 ¡Anmar duledar-wiles! ¡Anmar isgusad! 
\b  
\q1  
\v 17 Anmar gargangued bergumaid, 
\q2 a-ulale, anmar nolloo atakgusad. 
\b  
\q1  
\v 18 Ar Sión-yargi bar dule gudisulid, 
\q2 Sión-yargine, unnila ibdurgan-sapurbarmaladbi gudinanaed. 
\b  
\q1  
\v 19 Degi-inigwele, be Bab-Jehová, degisadegu negsemaid, 
\q2 be reyga degisadegu maid. 
\b  
\q1  
\v 20 Bab-Dummad, ¿ibiga be anmar-iesdae? 
\q2 ¿Ibiga be undar anmar-iege? 
\b  
\q1  
\v 21 Bab-Jehová, gannar anmar bese-dagega be anmar-imake, 
\q2 geb gannar anmar bese dagoed. 
\q1 Anmar iduar igi-gudigusa, 
\q2 deyob be gannar anmar-imake. 
\b  
\q1  
\v 22 Innikigwadba be anmar-obachad, 
\q2 bela-bela be anmar-isdar daksad. 
\b