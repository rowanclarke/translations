\c 2  
\s1 Falsos profetas  
\p
\v 1 \w Sin|strong="G2532"\w* embargo, \w hubo|strong="G1096"\w* falsos profetas \w entre|strong="G1722"\w* \w el|strong="G3588"\w* \w pueblo|strong="G2992"\w* \w como|strong="G5613"\w* \w también|strong="G2532"\w* \w habrá|strong="G1096"\w* falsos maestros \w entre|strong="G1722"\w* ustedes quienes \w introducirán|strong="G3919"\w* herejías destructivas \w de|strong="G1722"\w* \w manera|strong="G1096"\w* encubierta. \w Aun|strong="G2532"\w* \w se|strong="G1438"\w* negarán \w a|strong="G1722"\w* reconocer \w al|strong="G3588"\w* Soberano \w que|strong="G3588"\w* \w los|strong="G3588"\w* compró \w y|strong="G2532"\w* traerán destrucción repentina \w sobre|strong="G1722"\w* \w ellos|strong="G3588"\w*.  
\v 2 \w Muchos|strong="G4183"\w* \w seguirán|strong="G1811"\w* \w sus|strong="G3588"\w* inclinaciones excesivas \w a|strong="G1223"\w* \w los|strong="G3588"\w* placeres. \w El|strong="G3588"\w* \w camino|strong="G3598"\w* \w de|strong="G1223"\w* \w la|strong="G3588"\w* verdad será difamado \w por|strong="G1223"\w* \w causa|strong="G1223"\w* \w de|strong="G1223"\w* \w sus|strong="G3588"\w* inclinaciones excesivas.  
\v 3 Esos \add falsos maestros\add* \w los|strong="G3588"\w* explotarán \w con|strong="G1722"\w* \w palabras|strong="G3056"\w* \w fingidas|strong="G4112"\w* \w por|strong="G1722"\w* \w avaricia|strong="G4124"\w*. \w La|strong="G3588"\w* \w sentencia|strong="G3056"\w* pronunciada \w sobre|strong="G1722"\w* \w ellos|strong="G3588"\w* desde tiempo antiguo \w no|strong="G3756"\w* \w está|strong="G3588"\w* ociosa. \w Su|strong="G3588"\w* perdición \w no|strong="G3756"\w* \w se|strong="G2532"\w* duerme.   
\p
\v 4 \w Porque|strong="G1063"\w* \w si|strong="G1487"\w* \w Dios|strong="G2316"\w* \w no|strong="G3756"\w* \w perdonó|strong="G5339"\w* \w a|strong="G1519"\w* \add los\add* ángeles \w que|strong="G3588"\w* pecaron, \w sino|strong="G1487"\w* \w los|strong="G3588"\w* arrojó \w al|strong="G3588"\w* infierno \w y|strong="G1063"\w* \add los\add* \w entregó|strong="G3860"\w* \w a|strong="G1519"\w* cadenas \w de|strong="G1519"\w* \w oscuridad|strong="G2217"\w*, reservados \w para|strong="G1519"\w* \w juicio|strong="G2920"\w*;  
\v 5 \w si|strong="G2532"\w* \w no|strong="G3756"\w* \w perdonó|strong="G5339"\w* al \w mundo|strong="G2889"\w* antiguo, \w pero|strong="G2532"\w* cuando \add Dios\add* envió \add el\add* \w diluvio|strong="G2627"\w* sobre el \w mundo|strong="G2889"\w* de impíos, \w guardó|strong="G5442"\w* a \w Noé|strong="G3575"\w*, el \w octavo|strong="G3590"\w* \add patriarca\add*, \w pregonero|strong="G2783"\w* de \w justicia|strong="G1343"\w*;  
\v 6 \w si|strong="G2532"\w* \w condenó|strong="G2632"\w* \add las\add* \w ciudades|strong="G4172"\w* de \w Sodoma|strong="G4670"\w* \w y|strong="G2532"\w* \w Gomorra|strong="G1116"\w*, las redujo a cenizas \w y|strong="G2532"\w* las \w puso|strong="G5087"\w* \w como|strong="G2532"\w* \w ejemplo|strong="G5262"\w* \w para|strong="G3195"\w* \w los|strong="G2532"\w* impíos;  
\v 7 \w si|strong="G2532"\w* \w libró|strong="G4506"\w* \w al|strong="G3588"\w* \w justo|strong="G1342"\w* \w Lot|strong="G3091"\w* \w cuando|strong="G1722"\w* estaba afligido \w por|strong="G1722"\w* \w la|strong="G3588"\w* conducta \w de|strong="G1722"\w* \w los|strong="G3588"\w* perversos,  
\v 8 \w porque|strong="G1063"\w* \w este|strong="G3588"\w* \w justo|strong="G1342"\w* \w que|strong="G3588"\w* vivía \w entre|strong="G1722"\w* \w ellos|strong="G3588"\w* atormentaba \add su\add* \w alma|strong="G5590"\w* \w justa|strong="G1342"\w* \w por|strong="G1722"\w* \w las|strong="G3588"\w* acciones inicuas \w de|strong="G1537"\w* \w ellos|strong="G3588"\w* \w con|strong="G1722"\w* \w lo|strong="G3588"\w* \w que|strong="G3588"\w* \w se|strong="G2532"\w* veía \w y|strong="G2532"\w* escuchaba \w día|strong="G2250"\w* tras \w día|strong="G2250"\w*,  
\v 9 \w sabe|strong="G1492"\w* \add el\add* \w Señor|strong="G2962"\w* \w librar|strong="G4506"\w* \w de|strong="G1537"\w* \w tentación|strong="G3986"\w* \w a|strong="G1519"\w* \add los \add*piadosos \w y|strong="G1161"\w* \w reservar|strong="G5083"\w* \w a|strong="G1519"\w* \add los\add* injustos \w para|strong="G1519"\w* ser castigados \w en|strong="G1519"\w* \add el\add* \w día|strong="G2250"\w* \w de|strong="G1537"\w* \w juicio|strong="G2920"\w*,  
\v 10 especialmente \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* van \w detrás|strong="G3694"\w* \w de|strong="G1722"\w* \add la \add*naturaleza \w humana|strong="G4561"\w* \w con|strong="G1722"\w* \w el|strong="G3588"\w* \w deseo|strong="G1939"\w* ardiente \w de|strong="G1722"\w* \w la|strong="G3588"\w* impureza \w y|strong="G2532"\w* \w desprecian|strong="G2706"\w* \add la \add*autoridad.  
\p \add Estos\add* \w atrevidos|strong="G5113"\w* \w y|strong="G2532"\w* arrogantes \w no|strong="G3756"\w* \w temen|strong="G5141"\w* blasfemar \w a|strong="G1722"\w* \w los|strong="G3588"\w* \add seres \add*gloriosos,  
\v 11 mientras \add los\add* ángeles, \w que|strong="G3844"\w* \w son|strong="G1510"\w* \w mayores|strong="G3173"\w* \w en|strong="G2596"\w* \w fuerza|strong="G1411"\w* \w y|strong="G2532"\w* \w poder|strong="G1411"\w*, \w no|strong="G3756"\w* presentan \w juicio|strong="G2920"\w* difamante \w ante|strong="G2596"\w* el \w Señor|strong="G2962"\w* \w contra|strong="G2596"\w* ellos.  
\v 12 \w Pero|strong="G1161"\w* \w éstos|strong="G3778"\w*, \w como|strong="G5613"\w* \w animales|strong="G2226"\w* irracionales, nacidos \w por|strong="G1722"\w* instinto \w natural|strong="G5446"\w* \w para|strong="G1519"\w* presa \w y|strong="G2532"\w* \w destrucción|strong="G5356"\w*, \w que|strong="G3588"\w* hablan mal \w de|strong="G1722"\w* \w las|strong="G3588"\w* \w cosas|strong="G3739"\w* \w que|strong="G3588"\w* no entienden, \w también|strong="G2532"\w* perecerán \w en|strong="G1722"\w* \w su|strong="G3588"\w* \w perdición|strong="G5356"\w*  
\v 13 \w y|strong="G2532"\w* recibirán \add el\add* \w galardón|strong="G3408"\w* \w de|strong="G1722"\w* \add su\add* injusticia. \w Se|strong="G2532"\w* complacen \w en|strong="G1722"\w* \w los|strong="G3588"\w* placeres sensuales \w en|strong="G1722"\w* pleno \w día|strong="G2250"\w*. Son inmundicias \w y|strong="G2532"\w* \w manchas|strong="G3470"\w*. \w Cuando|strong="G1722"\w* festejan mientras comen \w con|strong="G1722"\w* ustedes, \w se|strong="G2532"\w* deleitan \w en|strong="G1722"\w* \w sus|strong="G3588"\w* errores.  
\v 14 \w Como|strong="G2532"\w* \w tienen|strong="G2192"\w* \w ojos|strong="G3788"\w* \w llenos|strong="G3324"\w* de adulterio, son insaciables de pecado \w y|strong="G2532"\w* \add tienen\add* un \w corazón|strong="G2588"\w* \w lleno|strong="G3324"\w* de codicia, seducen \w almas|strong="G5590"\w* inestables. Son \w hijos|strong="G5043"\w* de \w maldición|strong="G2671"\w*.  
\v 15 Siguieron \w el|strong="G3588"\w* \w camino|strong="G3598"\w* \w de|strong="G3588"\w* Balaam \w de|strong="G3588"\w* Bosor, \w quien|strong="G3739"\w* amó \w el|strong="G3588"\w* \w pago|strong="G3408"\w* \w por|strong="G3739"\w* \w la|strong="G3588"\w* maldad,  
\v 16 \w y|strong="G1161"\w* fue reprendido \w por|strong="G1722"\w* \w su|strong="G3588"\w* \w iniquidad|strong="G3892"\w*. \w Una|strong="G3588"\w* muda \w bestia|strong="G5268"\w* \w de|strong="G1722"\w* \w carga|strong="G1722"\w* \w que|strong="G3588"\w* habló \w con|strong="G1722"\w* \w voz|strong="G5456"\w* \w de|strong="G1722"\w* hombre \w refrenó|strong="G2967"\w* \w la|strong="G3588"\w* \w locura|strong="G3913"\w* \w del|strong="G3588"\w* \w profeta|strong="G4396"\w*.   
