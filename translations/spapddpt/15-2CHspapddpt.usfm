\c 30  
\s1 Celebración extraordinaria de la Pascua  
\p
\v 1 Ezequías \w envió|strong="H7971"\w* \add aviso\add* \w por|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w y|strong="H1571"\w* \w Judá|strong="H3063"\w*, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w escribió|strong="H3789"\w* cartas \w a|strong="H3068"\w* Efraín \w y|strong="H1571"\w* \w a|strong="H3068"\w* \w Manasés|strong="H4519"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* fueran \w a|strong="H3068"\w* Jerusalén, \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w a|strong="H3068"\w* \w celebrar|strong="H6213"\w* \w la|strong="H5921"\w* \w Pascua|strong="H6453"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 2 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* \w tomó|strong="H3289"\w* \w consejo|strong="H3289"\w* con sus \w jefes|strong="H8269"\w* y \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w congregación|strong="H6951"\w* en Jerusalén para \w celebrar|strong="H6213"\w* \w la|strong="H3605"\w* \w Pascua|strong="H6453"\w* \w el|strong="H3605"\w* \w mes|strong="H2320"\w* \w segundo|strong="H8145"\w*,  
\v 3 \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w la|strong="H1931"\w* \w pudieron|strong="H3201"\w* \w celebrar|strong="H6213"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* debido \w tiempo|strong="H6256"\w*, \w pues|strong="H3588"\w* \w no|strong="H3808"\w* \w había|strong="H6942"\w* suficientes \w sacerdotes|strong="H3548"\w* \w santificados|strong="H6942"\w*, \w ni|strong="H3808"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w pudo|strong="H3201"\w* reunirse \w en|strong="H3588"\w* Jerusalén.  
\v 4 \w Esto|strong="H1697"\w* les \w pareció|strong="H3474"\w* \w bien|strong="H3474"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* y \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w congregación|strong="H6951"\w*.   
\p
\v 5 Resolvieron \w hacer|strong="H6213"\w* una proclama \w por|strong="H3588"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w desde|strong="H5704"\w* Beerseba \w hasta|strong="H5704"\w* \w Dan|strong="H1835"\w*, \w para|strong="H5704"\w* \w que|strong="H3588"\w* fueran \w a|strong="H3068"\w* \w celebrar|strong="H6213"\w* \w en|strong="H5704"\w* Jerusalén \w la|strong="H3588"\w* \w Pascua|strong="H6453"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w el|strong="H3588"\w* \nd ʼElohim\nd* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w porque|strong="H3588"\w* \w en|strong="H5704"\w* \w mucho|strong="H7230"\w* tiempo \w no|strong="H3808"\w* \w la|strong="H3588"\w* habían celebrado \w como|strong="H3588"\w* \w estaba|strong="H5975"\w* \w escrito|strong="H3789"\w*.   
\p
\v 6 \w Los|strong="H1121"\w* mensajeros recorrieron \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* y \w Judá|strong="H3063"\w*. Llevaban las cartas del \w rey|strong="H4428"\w* y sus magistrados. Proclamaron como mandó \w el|strong="H3605"\w* \w rey|strong="H4428"\w*: \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, regresen \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w al|strong="H4428"\w* \nd ʼElohim\nd* \w de|strong="H1121"\w* Abraham, \w Isaac|strong="H3327"\w* \w e|strong="H3068"\w* \w Israel|strong="H3478"\w*. \w Y|strong="H3068"\w* \w Él|strong="H3605"\w* se \w volverá|strong="H7725"\w* \w al|strong="H4428"\w* remanente \w que|strong="H1121"\w* \w quedó|strong="H7604"\w* \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w de|strong="H1121"\w* Asiria.   
\p
\v 7 \w No|strong="H1961"\w* \w sean|strong="H1961"\w* \w como|strong="H1961"\w* sus antepasados y \w como|strong="H1961"\w* sus hermanos \w que|strong="H1961"\w* \w fueron|strong="H1961"\w* infieles \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w de|strong="H5414"\w* sus antepasados, Quien \w los|strong="H1961"\w* \w entregó|strong="H5414"\w* \w a|strong="H3068"\w* desolación, \w como|strong="H1961"\w* ustedes \w ven|strong="H7200"\w*.   
\p
