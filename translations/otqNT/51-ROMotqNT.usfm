\id ROM
\h AR ROMANU
\toc1 AR ROMANU Ar he̱ꞌmi bi ꞌyotꞌa ar Pablo bi me̱mpa ya me Nroma
\toc2 AR ROMANU
\toc3 Ro.
\mt1 AR ROMANU
\mt2 Ar he̱ꞌmi bi ꞌyotꞌa ar Pablo bi me̱mpa ya me Nroma
\c 1
\s1 Ar nze̱ngwa
\p 
\v 1 Nuga dar Pablo, ár ꞌbe̱gogi ar tsi Hmu Hesukristo. Xi tsꞌonkagi ngu ár mpo̱te, ne xi tꞌexkagi ga mömba ár hoga mhö Jö.
\p 
\v 2 Nuna xki ñötkagihu̱ mamꞌe̱tꞌo ha yá jöpa Tꞌofo bi ꞌyotꞌa yá mꞌe̱hniꞌö.
\p 
\v 3 Ja no̱mpꞌu̱ ár Tꞌu̱, nuna ma tsi Hmuhu̱ Hesukristo. Bi mꞌu̱ ngu nꞌar jöꞌi ndi ꞌñe ha yá ma̱ngaꞌbe̱to ar Dabi.
\p 
\v 4 Ne ár Hñö Jö xintꞌaxi bi ñꞌu gehnu̱ ár Tꞌu̱ Jö pe̱ꞌsa ár tsꞌe̱di, núꞌmu̱ mi menga ár te manꞌagi xki wadi xki du.
\p 
\v 5 Gese̱ xi hwëgagihu̱ ga po̱thu̱ ga zohu̱ ya jöꞌi ꞌbu̱ ha ya ha̱i gatho ár nxidi ar ximha̱i, ne da ñꞌemu̱i da de̱ni, njapꞌu̱ da tꞌeꞌspa ár nsu ár thuhu.
\p 
\v 6 Jange gi nthöskwihu̱yu̱ nꞌehe, xi tsꞌoñꞌahu̱ ngu yá me̱tiꞌihu̱ ar tsi Hmu Hesukristo.
\p 
\v 7 Di pe̱ñꞌahu̱ nunar he̱ꞌminu̱ gatho nuꞌahu̱ gi ꞌbu̱hu̱ Nroma, xa möꞌahu̱ Jö ne xi zoꞌahu̱ gi ꞌbu̱hu̱ xintꞌaxi. Jö ma Dadahu̱ ne ar tsi Hmu Hesukristo da ꞌraꞌahu̱ nꞌar hogamꞌu̱i, ne da hwëkꞌahu̱ yá ñho.
\s1 Ar Pablo ne da ntso̱nte Nroma
\p 
\v 8 Di ne ga xiꞌahu̱ mꞌe̱tꞌo, di umba njamödi Jö hár thuhu ar tsi Hmu Hesukristo, xka ñꞌemu̱ihu̱ xiñho, ne hagatho nho̱ni gar gamfihu̱.
\p 
\v 9 Ar tsi Dada togo xa di umba ma mu̱i di pe̱pabi, di mömba ár hoga mhö no̱nga ár Tꞌu̱, gehnu̱ pödi hindi tsa̱ya̱ di matꞌahu̱ Jö.
\p 
\v 10 Di a̱pa Jö da neꞌö da ꞌrakar se̱ki ga tso̱ñꞌahu̱, ngetho pe̱ꞌsa ya pa di to̱ꞌmi ga mapꞌu̱.
\p 
\v 11 Ngetho di ne ga hantꞌahu̱ ne ga fa̱xꞌahu̱ gi hñöñhu̱ nꞌar ñho di ꞌñe mhetsꞌi, ne njapꞌu̱ da ze̱ta ri ñꞌemu̱ihu̱.
\p 
\v 12 Njanu̱ mahye̱gi da te ma ñꞌemu̱ihu̱, ngetho nꞌadar jamfi di pe̱ꞌsu̱.
\p 
\v 13 Tsi kuhu̱, di ne gi pöhu̱, hinge nꞌagitho xta ne xta mapꞌu̱, ne hinxi kꞌatꞌi te xi kꞌaski. Di ne ga fa̱xꞌahu̱ da te ri ñꞌemu̱ihu̱, ngu xta fa̱xa maꞌra hingya xodyo nꞌehe.
\p 
\v 14 Di beni gatho di tupabi ma ga zofo, ya bötꞌofo ne hingya bötꞌofo, nuꞌu̱ xa te gatho pödi, ne nuꞌu̱ hinte pödi.
\p 
\v 15 Jange xa di nemhö ma ga kꞌösꞌahu̱ gar me Nromahu̱, ne ga xiꞌahu̱ ar hoga mhö nꞌehe.
\s1 Ár tsꞌe̱di ar hoga mhö
\p 
\v 16 Hindi ntsa̱ga ga mönga ar hoga mhö, ngetho ka nhekinu̱ ár tsꞌe̱di Jö da po̱ gatho nuꞌu̱ da ñꞌemu̱i, mꞌe̱tꞌo ya xodyo, mꞌe̱fa nuꞌu̱ hingya xodyo nꞌehe.
\p 
\v 17 Ngetho har hoga mhö, ka nhekipꞌu̱ hanja ga ꞌbu̱hwihu̱ xiñho Jö ngetho di ñꞌemu̱ibihu̱. Ne ga ꞌbu̱hu̱ di ñꞌemu̱ihu̱, ngu enga har Tꞌofo: Nöꞌö togo ñꞌemu̱i, ꞌbu̱i xiñho hár nthandi Jö, ne pe̱ꞌsa ar te hiñhamꞌu̱ da götsꞌi.
\s1 Ya tsꞌoki xi duxa ya meximha̱i
\p 
\v 18 Jö ñꞌu ár kwe̱ di ꞌñe mhetsꞌi, da umba ár mfe̱i ya tsꞌojöꞌi. Nuyá tsꞌoꞌmu̱iyu̱ kꞌaꞌsa nöꞌö majöni.
\p 
\v 19 Nuyu̱ xi bö nöꞌö tsa̱ da fötwa Jö, ngetho Jö xi utwabiyu̱.
\p 
\v 20 Ngetho nöꞌö hingi tsa̱ ga handwabihu̱, ngu ár tsꞌe̱di hingi thege ne ár nsunda, bi nheki núꞌmu̱ bi hyokar ximha̱i, ha gathoyu̱ födi togoꞌö. Jange hiñꞌotho te da dödi.
\p 
\v 21 Bi böꞌu̱ Jö, ha himbi nsundabi ngu ndi ꞌñepi, himbi umpꞌu̱ njamödi. Te gatho bi bentꞌu̱ ne bi me̱ꞌsku, jange bi tsꞌoka yá mfeni.
\p 
\v 22 Mi o̱tꞌu̱ xa mi pödi, bi ꞌbe̱ yá mfeniꞌu̱.
\p 
\v 23 Bi hye̱gi bi nsunda Jö hiñhamꞌu̱ da göxa ár te. Ne bi ndu̱i bi nsundabi ár ꞌba̱i ya jöꞌi the yá te, ya tsꞌintsꞌu̱, ya me̱ti ne ya zuꞌwe ju̱tꞌa yá mu̱i.
\p 
\v 24 Jange Jö bi hye̱gi bi ꞌyo̱tꞌa gatho nuya tsꞌoki mi neꞌu̱. Njapꞌu̱ bi ꞌbe̱twa ár tsa̱ yá ndoꞌyose̱ꞌu̱.
\p 
\v 25 Ngetho bi hye̱ꞌu̱ nöꞌö majöni xi zogagihu̱ Jö, ne bi de̱nga nöꞌö hinga majöni. Bi ndönga mꞌe̱tꞌo ya nthojtho, hinge nöꞌö togo bi hyoki, togo di ꞌñepi hinda the ar nsunda tꞌumbabi. Dá njapꞌu̱.
\p 
\v 26 Jange Jö bi hye̱gi bi ꞌyo̱tꞌa gatho nuya tsꞌomfeni ndi ꞌñepabi. Njapꞌu̱ bi ꞌbe̱se̱ yá tsa̱. Nuya ꞌbe̱hñö bi hye̱ nöꞌö ngu xki tꞌumbabi nda ꞌyo̱tꞌe, ne bi ꞌyo̱tꞌa nöꞌö hinxi tꞌumbabi nda ꞌyo̱tꞌe.
\p 
\v 27 Njapꞌu̱tho ya ñꞌo̱ho̱ nꞌehe, bi hye̱pꞌu̱ yá ꞌbe̱hñö, bi nhese̱ yá mindo̱wi, ne bi ꞌyo̱tꞌu̱ nöꞌö ar mꞌe̱tsa̱. Jange bi hñöñꞌu̱ ár njutꞌi yá tsꞌoki ha yá ndoꞌyose̱.
\p 
\v 28 Ne himbi ne bi beñꞌu̱ Jö. Jange Jö bi hye̱gi nda tsꞌoka yá mfeni, ne nda ꞌyo̱tꞌa gatho nöꞌö xi ntsꞌotho.
\p 
\v 29 Xa bi ñꞌe̱ntꞌi nda ntsꞌojöꞌi, ya mꞌe̱ngwi jöꞌi, ya tsꞌomꞌu̱i, ya ne mꞌe̱tsꞌi, ya ñö tsꞌate. ꞌBe̱ntebi yá me̱ti maꞌra, ya hyote, ya tuhni, ya nemhñö, ya tsꞌokte;
\p 
\v 30 ya ñömañꞌu̱, hingi ne da ꞌyo̱de, u̱tsa Jö, ya tsate, ya ñꞌetsꞌi, ya gese̱, nuꞌu̱ togo honi hanja da ntsꞌokte, hingi o̱ta yá dada;
\p 
\v 31 ya me̱ꞌsku, hingi o̱tꞌa nöꞌö möñꞌu̱, hinte ja yá mhöte, hinto hwëki.
\p 
\v 32 Nuya jöꞌiyu̱ pötwabi tengu ár njutꞌi Jö, pöꞌu̱ nuꞌu̱ togo o̱tꞌa njapꞌu̱ di ꞌñepi da du. Mödi pöhyu̱, hinge ho̱nse̱ o̱tꞌe, johya da hyanda togo o̱tꞌe.
\c 2
\s1 Ár hoga tsꞌu̱tꞌwi Jö
\p 
\v 1 Jange nuꞌahu̱ gi ꞌyomfu̱ ár ꞌbede maꞌra, hinda tsa̱ gi kꞌonthu̱. Ngetho nuꞌmu̱ gi mömfu̱ ár mfe̱i di ꞌñepabi, gi ku̱tꞌase̱hu̱ har tsibi, ngetho gi njahu̱pꞌu̱ nꞌehe.
\p 
\v 2 Ne di pöhu̱ o̱tꞌa nꞌar hoga tsꞌu̱tꞌwi Jö, núꞌmu̱ xta umba yá mfe̱i togo o̱tꞌa nuya tsꞌokiyu̱.
\p 
\v 3 Nuꞌahu̱ gi theñhu̱ nuꞌu̱ togo hingi o̱tꞌa xiñho, ha gi beni gi kꞌonthu̱ hinda zu̱ꞌahu̱ ár kwe̱ Jö gi ñhe̱xkwihu̱ nꞌehe.
\p 
\v 4 Yoꞌö gi u̱tsabihu̱ ár döta ñhogajöꞌi Jö, ár tsꞌe̱ti, ne ár mhöte. Ha hingi pöhu̱, gehnu̱ ár ñhogajöꞌi da ma̱xꞌahu̱ gi ꞌyo̱thwu̱ ár ntso̱ꞌmi.
\p 
\v 5 Ngetho xa gar me̱ꞌskuhu̱, hinxka ne xka ꞌyo̱thwu̱ ár ntso̱ꞌmi. Njapꞌu̱ xka hñuꞌsu̱ ár mfe̱i ma da tꞌaꞌahu̱ nor pa da ñꞌu ár döta kwe̱ ne ár hoga tsꞌu̱tꞌwi Jö.
\p 
\v 6 Gehnu̱ ma da umba ár njutꞌi nꞌa ngu nꞌa ngu yá ꞌbe̱fi xi ꞌyo̱tꞌe.
\p 
\v 7 Ma da tꞌumba ar te hinda götsꞌi nuꞌu̱ xi umba yá mu̱i xi ꞌyo̱tꞌa nöꞌö xiñho, xi hyonga da mꞌu̱ hár nsunda Jö, ne da tꞌeꞌspa ár nsu, ne xi hyonga nöꞌö di ꞌñe mhetsꞌi.
\p 
\v 8 Ha ma da nto̱xkwi ár kwe̱ ne ár nzo̱tꞌamu̱i Jö nuꞌu̱ ya hyonga tuhni, ne hingi ne da de̱nga nöꞌö majöni. Ho̱nse̱ ne da ꞌyo̱tꞌa nöꞌö hingi ho.
\p 
\v 9 Ma da mfe̱i ne da tho ar tsꞌoni gatho nuꞌu̱ bi ꞌyo̱tꞌa nöꞌö xi ntsꞌotho, ya xodyo mꞌe̱tꞌo, ne mꞌe̱fa nuꞌu̱ hingya xodyo.
\p 
\v 10 Ha ma da mꞌu̱ nsunda, da tꞌeꞌspa ár nsu, ne da mꞌu̱ nꞌar hogamꞌu̱i gatho nuꞌu̱ togo da ꞌyo̱tꞌa ar ñho, ya xodyo mꞌe̱tꞌo, mꞌe̱fa nuꞌu̱ hingya xodyo.
\p 
\v 11 Ngetho Jö handa gatho ya jöꞌi mahye̱tho.
\p 
\v 12 Gatho nuꞌu̱ togo himi pötwa yá ꞌbe̱pate ar Moise, ne bi ꞌyo̱tꞌa ya tsꞌoki, núꞌmu̱ xta thöꞌspa majöni, hinda ma nda nho̱mba ya ꞌbe̱pate. Ha nuꞌu̱ togo mi pötwa yá ꞌbe̱pate ar Moise, ne bi ꞌyo̱tꞌa ya tsꞌoki, núꞌmu̱ xta thöꞌspa majöni, ma da tꞌa̱pa ngu mönga ya ꞌbe̱pate.
\p 
\v 13 Hingi ꞌbu̱hwi xiñho Jö nuꞌu̱ togo ho̱nse̱ xi ꞌyo̱ꞌspa ya ꞌbe̱pate, mahyoni da ꞌyo̱tꞌa ngu möñꞌu̱. Gehyu̱ ma da nhu hinte ma tsꞌoki tuꞌu̱.
\p 
\v 14 Ngetho nuꞌmu̱ nuꞌu̱ hingya xodyo o̱tꞌa ngu mönga ya ꞌbe̱pate, mödi hingi pödi teme̱ꞌu̱, o̱tꞌa njapꞌu̱ ngetho gese̱ꞌu̱ pödi tema xiñho ne tema hingi ho.
\p 
\v 15 Njapꞌu̱ nheki o̱tꞌa ya hoga ꞌbe̱fi huxa ha ya ꞌbe̱pate ne xi thuꞌspa ha yá mu̱i, ne nuꞌmu̱ da hñudi da beni wa ja te tsu̱pa yá mfeni, wa hinte tsu̱i.
\p 
\v 16 Njapꞌu̱tho nu xta hñöxa majöni Jö hár ꞌye̱ ar tsi Hmu Hesukristo, ma da xetꞌwa yá mfeni nuꞌu̱ togo xi kwati ho̱nse̱ pöꞌu̱. Njapꞌu̱ mönga ar hoga mhö di mönga.
\s1 Ya xodyo ne yá ꞌbe̱pate ar Moise
\p 
\v 17 Ha nuꞌahu̱, xi thusꞌahu̱ gar xodyohu̱, ne gi hu ri mu̱ihu̱ gi ꞌbu̱hu̱ xiñho, ngetho gi pe̱ꞌsfu̱ yá ꞌbe̱pate ar Moise. Xa gi exa ri nsuhu̱ gi ndöñhu̱ ri Jöhu̱.
\p 
\v 18 Gi pöhu̱ teme neꞌö, ne xi tꞌutꞌahu̱ ha ya ꞌbe̱pate, gi ꞌñethu̱ ri mu̱ihu̱ nöꞌö xiñho.
\p 
\v 19 Gi ka̱xmbenihu̱ gar gu̱hnihu̱ ya goda̱, ne yá ñotꞌi nuꞌu̱ togo ꞌbu̱ har ꞌbe̱xui.
\p 
\v 20 Gi hu ri mu̱ihu̱ gi uthu̱ nuꞌu̱ hinte pödi, gar utatehu̱ ya bötsi, xka hñuxa ri mfenihu̱ har mfödi majöni mönga ha ya ꞌbe̱pate.
\p 
\v 21 Nuꞌahu̱ gi uthu̱ maꞌra, yoꞌö hingi ñꞌutase̱hu̱. Gi uthu̱ maꞌra hinda mpë, yoꞌö gi mpëhu̱.
\p 
\v 22 Gi möñhu̱ hingi ho da tsꞌimba ár nthöti maꞌra, yoꞌö gar tsinganthötihu̱. Gi u̱tsahu̱ ya tsita, yoꞌö gi pëfu̱ yá nijö ꞌmu̱.
\p 
\v 23 Nuꞌahu̱ gi exu̱ ri nsuhu̱ gi pe̱ꞌsfu̱ yá ꞌbe̱pate ar Moise, yoꞌö gi tsꞌojwu̱ Jö, hingi o̱thu̱ nöꞌö mönga ha ya ꞌbe̱pate ꞌmu̱.
\p 
\v 24 Ngetho ngu enga hár tꞌofo Jö: Go ri tsꞌokihu̱ tsamba ár thuhu Jö nuꞌu̱ hingya xodyo.
\p 
\v 25 Nunar nse̱gi gi tuthu̱ ri ndoꞌyohu̱, fa̱xꞌahu̱ nuꞌmu̱ gi ꞌyo̱thu̱ ngu mönga ha yá ꞌbe̱pate ar Moise. Ha nuꞌmu̱ hingi ꞌyo̱thu̱, po̱ntho hinte ma nse̱gi gi pe̱ꞌsu̱.
\p 
\v 26 Ha nuꞌmu̱ togo hinxi thuꞌspa ar nse̱gi, ne da ꞌyo̱tꞌa ngu mönga ha yá ꞌbe̱pate ar Moise, ma da nhuꞌmbabi wande xi thuꞌspabi.
\p 
\v 27 Nöꞌö togo hinxi thuꞌspa ar nse̱gi hár ndoꞌyo ne o̱tꞌa ngu mönga yá ꞌbe̱pate ar Moise, ma da xiꞌa ri mfe̱ihu̱. Ngetho gi pe̱ꞌsu̱ ya ꞌbe̱pate ntꞌotꞌi ne ar nse̱gi, ha hingi te̱ñhu̱.
\p 
\v 28 Hinge gehnu̱ ar xodyo majöni nöꞌö oxta mañö, wa nunar nse̱gi thutwa hár ndoꞌyo.
\p 
\v 29 Majöni ar xodyo togo di ꞌñe mbo hár mu̱i. Ne ar hoga nse̱gi nöꞌö ꞌbe̱ꞌsa hár mu̱i unga ár Hñö Jö, hinge ar tꞌofo. Ne nunar nsu go eskagihu̱ Jö, hinge ya jöꞌi.
\c 3
\p 
\v 1 Nuꞌmú̱, hage töte ár mfa̱tsꞌi pe̱ꞌsa nꞌar xodyo. Wa tema ñho japabi da tuta ar nse̱gi hár ndoꞌyo.
\p 
\v 2 Nze̱ye̱ ya mfa̱tsꞌi pe̱ꞌsa ya xodyo, ne töte ár hño. Gehyu̱ mꞌe̱tꞌo bi tꞌe̱ntꞌwa ha yá ꞌye̱ ár mhö Jö.
\p 
\v 3 Nuꞌmu̱ ꞌrayu̱ hinxi ñꞌemu̱i, hage njapꞌu̱ Jö hinda ꞌyo̱tꞌa nöꞌö xi mö.
\p 
\v 4 Hö, da ꞌyo̱tꞌe. Mödi gatho ya jöꞌi da mönga ya nhemhñö, Jö hinꞌö. Ngu enga har tꞌofo:
\q1 Ma da födi gi mönge majöni,
\q1 ne ma gi ntöte núꞌmu̱ theñꞌa ya jöꞌi.
\p 
\v 5 Nuꞌmu̱ ma tsꞌokihu̱ japi da nheki ár hogajöꞌi Jö, hage hingi njapꞌu̱ nöꞌö o̱tꞌa Jö ꞌrakagihu̱ ar mfe̱i ꞌmu̱. (Di te̱nda nöꞌö mönga ya jöꞌi.)
\p 
\v 6 Hinꞌö, hinda njapꞌu̱. Ngetho hanja da hñöꞌspa majöni ya meximha̱i ꞌmu̱.
\p 
\v 7 Tsa̱ da ꞌñenga ya jöꞌi nꞌehe, nuꞌmu̱ ma nhemhñö japi da nheki nöꞌö majöni mönga Jö, ne njapꞌu̱ da tꞌeꞌspa ár nsu, yoꞌö ma da tꞌaka ar mfe̱i ngu nꞌar ꞌyo̱tꞌatsꞌoki ꞌmu̱.
\p 
\v 8 Ha nuꞌmu̱ njapꞌu̱, yoꞌö hinga eñhu̱ ꞌmu̱ nꞌehe: Ma ga o̱thu̱ ar tsꞌoki ga to̱ꞌmhu̱ ar ñho, ngu ho̱xkagihe ꞌra, thengagihe eñꞌu̱ di uthe njapꞌu̱. Nuya xi mönga njapꞌu̱, to̱ꞌma yá mfe̱i di ꞌñepabi.
\s1 Gatho dar tsꞌoktehu̱
\p 
\v 9 Te ga möñhu̱pya. Hage nuju̱ dar xodyohu̱ di tötehu̱ di ꞌbu̱hu̱ xiñho. Hinꞌö, hingi njapꞌu̱, ngetho xta möñhu̱, mahye̱gi di ohu̱ hár ꞌye̱ ar tsꞌoki, ya xodyo ne nuꞌu̱ hingya xodyo.
\p 
\v 10 Ngu enga har tꞌofo:
\q1 Hinjoꞌo nꞌar hogajöꞌi, hinjoꞌo nꞌamhö.
\q1 
\v 11 Hinjoꞌo togo o̱de,
\q1 hinjoꞌo togo honga Jö.
\q1 
\v 12 Gatho bi hye̱pꞌu̱ ar hoga ꞌñu, nꞌatꞌwu̱ bi ntsꞌoki.
\q1 Hinjoꞌo togo da ꞌyo̱tꞌa ar ñho, hinjoꞌo nꞌamhö.
\q1 
\v 13 Ngu nꞌar tꞌa̱gi xoxtho, njapꞌu̱ yá neꞌu̱.
\q1 Nuyá jöhne kate, ha yá ne thente, ñhe̱hwi ár ngi nꞌar kꞌeñö po ha yá ne.
\q1 
\v 14 Nuyá ne odar tsꞌate ne ar tso̱tꞌamu̱i.
\q1 
\v 15 Nuyá wa ntihi ma da xangar ji.
\q1 
\v 16 Habu̱ gatho thogi, tso ar dumu̱i ne ar tsꞌoni;
\q1 
\v 17 ne hinxi böꞌu̱ tengu ar hogamꞌu̱i.
\q1 
\v 18 Hingi tsupa Jö.
\p 
\v 19 Ne di pöhu̱, gatho nöꞌö mönga yá ꞌbe̱pate ar Moise, xipa nuꞌu̱ togo te̱ni. Njapꞌu̱ gatho hinte da tsa̱ te da dödi núꞌmu̱ xta thöꞌspa majöni.
\p 
\v 20 Hinto tsa̱ da tꞌembabi, hinte ma tsꞌoki tu hár nthandi Jö ngetho o̱tꞌa ngu mönga yá ꞌbe̱pate ar Moise. Nuya ꞌbe̱pate ho̱nse̱ jakagihu̱ ga pöhu̱ ma tsꞌokihu̱.
\s1 Di ꞌbu̱hwihu̱ xiñho Jö ngetho di ñꞌemu̱ihu̱
\p 
\v 21 Ha nupya xi tꞌutkagihu̱ hanja ga ꞌbu̱hwihu̱ xiñho Jö. Hinge ga ꞌbu̱hu̱ ga o̱thwu̱ yá ꞌbe̱pate ar Moise, mödi ja mönu̱, ne ha ya he̱ꞌmi bi ꞌyotꞌa maꞌra yá mꞌe̱hni Jö.
\p 
\v 22 Gatho nuꞌu̱ xi ñꞌemu̱i ar tsi Hmu Hesukristo, ꞌbu̱i xiñho hár nthandi Jö. Nöꞌö handgagihu̱ mahye̱gi di gathohu̱.
\p 
\v 23 Ngetho gatho xi ntsꞌokte ne hindi ꞌñepi da hyandwa ár nsunda Jö.
\p 
\v 24 Ha Jö xi ñꞌu ár nhwëki, ne bi nhugagihu̱ hinte ma tsꞌoki di tuhu̱. Gehnu̱ bi tꞌakthogihu̱, ngetho ar tsi Hmu Hesukristo bi zimgagihu̱ ha yá ꞌye̱ ar tsꞌoki.
\p 
\v 25 Gehnu̱ Jö bi ꞌye̱ntꞌa ngu nꞌar mꞌo̱ñho̱, da gutꞌwa yá tsꞌoki ya meximha̱i nuꞌmu̱ da jamfibi ár ñho ungár ji bi nöꞌmi. Njapꞌu̱ bi ñꞌu ár ñhogajöꞌi ne ár tsꞌe̱ti, himbi umbár mfe̱i ya jöꞌi xki ꞌyo̱tꞌa ya tsꞌoki mamꞌe̱tꞌo.
\p 
\v 26 Xki beñꞌö nda ñꞌudi nuya payu̱ ár hoga tsꞌu̱tꞌwi. Njapꞌu̱ xi nheki ár hogajöꞌinu̱, ne embabi hinte ma tsꞌoki tu gatho nuꞌu̱ ñꞌemu̱i ar tsi Hmu Hesukristo.
\p 
\v 27 Hage da tsa̱ ga ñꞌexu̱ ꞌmu̱ handgagihu̱ xiñho Jö ngetho xta o̱thu̱ ya hoga ꞌbe̱fi. Hinꞌö, hinda tsa̱. Jö numañhogihu̱, ho̱nse̱ nuya xta ñꞌemu̱ihu̱.
\p 
\v 28 Jange di pöhu̱, nunar meximha̱i nhu hinte ma tsꞌoki tu ngetho ñꞌemu̱i. Hingi nhumañho ngetho te̱mba yá ꞌbe̱pate ar Moise.
\p 
\v 29 Hage Jö ho̱nse̱ ár Jö ya xodyo. Hage hinge ár Jö nuꞌu̱ togo hingya xodyo nꞌehe. Hö, majöni yá me̱ti nuꞌu̱ hingya xodyo nꞌehe.
\p 
\v 30 Ngetho Jö nꞌase̱, ne ma da nu hinte ma tsꞌoki tu nuꞌu̱ togo pe̱ꞌsa ar nse̱gi ne ñꞌemu̱i. Njapꞌu̱tho ma da numañho nuꞌu̱ hinte pe̱ꞌsa ar nse̱gi ne da ñꞌemu̱i nꞌehe.
\p 
\v 31 Hage nuꞌmu̱ di ñꞌemu̱ihu̱, hinte di nuhu̱ ya ꞌbe̱pate. Hinꞌö, di ñꞌuhu̱ pe̱ꞌsa yá nsu.
\c 4
\s1 Tema ne da utkagihu̱ ar Abra
\p 
\v 1 Te ga beñhu̱ bi dinga ar Abra ꞌmu̱, ma palehu̱ mi ꞌbu̱ mamꞌe̱tꞌo.
\p 
\v 2 Nuꞌmu̱ ar Abra bi nhu hinte ma tsꞌoki mi tu ngetho bi ꞌyo̱tꞌa ya hoga ꞌbe̱fi, tsa̱ da ꞌñexhmö ár nsu, ha nunu̱ hingi tsa̱ te da netebi Jö.
\p 
\v 3 Ngetho te mönga har Tꞌofo. Ar Abra bi ñꞌemu̱ibi Jö, ne njapꞌu̱ bi nhu hinte ma tsꞌoki mi tu.
\p 
\v 4 Ha nuꞌu̱ togo o̱tꞌa ya hoga ꞌbe̱fi, nunar nthöhö tꞌumbabi, hinge ntꞌuntho ꞌmu̱, ngetho xi döhö, ne da njutꞌwabi ngu nꞌar tha̱i.
\p 
\v 5 Ha nuꞌu̱ togo ñꞌemu̱ibi Jö togo hökwa yá tsꞌoki ya tsꞌokte, nunar ñꞌemu̱inu̱ ma da japi da nhu hinte ma tsꞌoki tu, mödi hinte ma hoga ꞌbe̱fi xi ꞌyo̱tꞌe.
\p 
\v 6 Jangu ar Dabi bi no̱nga yá nza̱thomꞌu̱i nuꞌu̱ bi numañhobi Jö, mödi hinte ma hoga ꞌbe̱fi xi ꞌyo̱tꞌe.
\p 
\v 7 Bi ꞌñenö njawa:
\q1 Nza̱thomꞌu̱i pe̱ꞌsa nuꞌu̱ togo xi mpumbabi yá tsꞌoki,
\q1 ne xi njutꞌwabi yá tsꞌomꞌu̱i.
\q1 
\v 8 Nza̱tho nuꞌu̱ togo ar tsi Hmu hinte ma tsꞌoki ho̱tsꞌe.
\p 
\v 9 Hage nunar nza̱thomꞌu̱inu̱ ho̱nse̱ xi tꞌe̱kwa ya xodyo togo xi thuꞌspa ar nse̱gi, wa da tsa̱ da hñönga nu maꞌra hingya xodyo nꞌehe. Jangu xta eñhu̱, ar Abra bi ñꞌemu̱ibi Jö, jange bi nhu hinte ma tsꞌoki mi tu.
\p 
\v 10 Hanja bi nhumañho ꞌmu̱. Hage bi nhumañho ngetho xki thuꞌspa ar nse̱gi wa hinꞌö. Bi nhumañho hinxki thuꞌspatho.
\p 
\v 11 Ar Abra mꞌe̱tꞌo bi gamfi, mꞌe̱fa bi hñönga ar nse̱gi. Gehnu̱ nꞌar ntꞌudi da̱majöni xki nhu hinte ma tsꞌoki mi tu ngetho xki ñꞌemu̱i núꞌmu̱ hinxki thuꞌspatho ar nse̱gi. Njapꞌu̱ ar Abra bi tꞌembabi ár dada gatho nuꞌu̱ hinxki thuꞌspa ar nse̱gi xta ñꞌemu̱i, ne nunar ñꞌemu̱inu̱ japi da nhu hinte ma tsꞌoki tu nꞌehe.
\p 
\v 12 Njapꞌu̱ ár dada nꞌehe gatho nuꞌu̱ hinge ho̱nse̱ xi thuꞌspa ar nse̱gi, te̱mba ár mꞌu̱i xa mi ñꞌemu̱i ndu ma dadahu̱ ar Abra núꞌmu̱ hinxki thuꞌspathobi ar nse̱gi.
\s1 Ga höñhu̱ ar ñhötꞌi núꞌmu̱ ga ñꞌemu̱ihu̱
\p 
\v 13 Himbi ñhötꞌwabi ar Abra ne yá ꞌbe̱to nda hñönga ar ximha̱i nuꞌmu̱ nda de̱nga ya ꞌbe̱pate. Bi ñhötꞌwabi núꞌmu̱ mi nhumañhobi ár ñꞌemu̱i.
\p 
\v 14 Ngetho nuꞌmu̱ ma da tꞌumba ar ximha̱i nuꞌu̱ te̱nga ya ꞌbe̱pate, hinter me̱ꞌö ar ñꞌemu̱i ꞌmu̱, ne xi ꞌbe̱ ár tsꞌe̱di ár ñhötꞌi Jö.
\p 
\v 15 Nu habu̱ ja ya ꞌbe̱pate, ja bi ehnu̱ ár kwe̱ Jö. Ne habu̱ hiñꞌotho ya ꞌbe̱pate, hiñꞌotho hanja da me̱ꞌsku.
\p 
\v 16 Jange gatho nuꞌu̱ togo ñꞌemu̱i, ma da tꞌumba nöꞌö xi hwëkwa Jö, ne njapꞌu̱ gatho yá ꞌbe̱to ar Abra da zu̱ ar ñhötꞌi. Nunar ñhötꞌinu̱ ma da hñönga nuꞌu̱ yá ꞌbe̱to te̱nga ya ꞌbe̱pate, ne nuꞌu̱ te̱mba ár ñꞌemu̱i ar Abra togo ár dada nꞌa ne manꞌa.
\p 
\v 17 Ngu xi ntꞌotꞌi: Nuga xta exꞌaꞌi ngu ár dada nze̱ye̱ ya jöꞌi. Jange nuju̱ yá bötsigihu̱ ar Abra hár nthandi Jö togo bi ñꞌemu̱iꞌö. Gehnu̱ ju̱xa nuꞌu̱ xi du, ne handa nöꞌö hinxi thoktho wande xi thoki.
\p 
\v 18 Mödi mar ñhembi nda ñꞌemu̱i, ar Abra bi do̱ꞌmi nda tho ngu xki ñhötꞌwabi. Njapꞌu̱ bi thutsꞌi ár dada nze̱ye̱ ya jöꞌi. Bi tꞌembabi: Ma da njapꞌu̱ ár nze̱ye̱ ri ꞌbe̱to.
\p 
\v 19 Ne himbi wentꞌa ár ñꞌemu̱i núꞌmu̱ mi hyandi bi za̱ ár ndoꞌyo, mi pe̱ꞌsa ngu nꞌanthebe nje̱ye̱, ne mi pödi himi tsa̱ nda ñꞌo̱nte ar Sara.
\p 
\v 20 Himbi tsꞌoka ár mfeni nda ꞌñenö hinge nda ꞌyo̱tꞌa Jö ngu xki ñötꞌwabi. Nöꞌö bi me̱ꞌö, bi no̱xka ár ñꞌemu̱i, ne njapꞌu̱ bi nsundabi Jö.
\p 
\v 21 Xa xki zo hár mu̱i xiñho, mi pe̱ꞌsa ar tsꞌe̱di Jö nda ꞌyo̱tꞌa gatho nöꞌö xki ñötꞌwabi.
\p 
\v 22 Jange bi nhu hinte ma tsꞌoki mi tu, ngetho mi pe̱ꞌsa nunar ñꞌemu̱inu̱.
\p 
\v 23 Hinge ho̱nse̱ nda zu̱ ar Abra nöꞌö xi tꞌotꞌi bi nhu hinte ma tsꞌoki mi tu.
\p 
\v 24 Da nhugagihu̱ hinte ma tsꞌoki di tuhu̱ nꞌehe, núꞌmu̱ di ñꞌemu̱ihu̱ togo bi koꞌspa ár te ar Hesu ma tsi Hmuhu̱.
\p 
\v 25 Gehnu̱ bi nda̱, ne njapꞌu̱ bi gutꞌa ma tsꞌokihu̱. Ne bi mengi bi nte, njapꞌu̱ bi nhugagihu̱ hinte ma tsꞌoki di tuhu̱.
\c 5
\s1 Tema to̱ꞌmi nuꞌu̱ thandi hinte ma tsꞌoki tu
\p 
\v 1 Xi nhugagihu̱ hinte ma tsꞌoki di tuhu̱ ngetho di ñꞌemu̱ihu̱. Jange di ꞌbu̱hwihu̱ xiñho Jö, ngetho bi mꞌa̱ made ma tsi Hmuhu̱ Hesukristo.
\p 
\v 2 Númꞌu̱ nda ñꞌemu̱ihu̱, ba tsigagihu̱ nda zu̱kagihu̱ ár nhwëki Jö. Ne xa xta mꞌa̱thu̱, ne di johyahu̱ di to̱ꞌmhu̱ ga ꞌbu̱hu̱ hár nsunda.
\p 
\v 3 Hinge ho̱nse̱ꞌö. Di johyahu̱ núꞌmu̱ di thohu̱ ya thogi nꞌehe, ngetho di pöhu̱ ar thogi fa̱xkagihu̱ ga pe̱ꞌsu̱ ar tsꞌe̱ti.
\p 
\v 4 Ar tsꞌe̱ti fa̱xkagihu̱ ga thohu̱ xiñho xta tsꞌa̱tkagihu̱, ha nunar tsꞌa̱ti fa̱xkagihu̱ ga pe̱ꞌsu̱ ar ndo̱ꞌmi.
\p 
\v 5 Ha nunar ndo̱ꞌmi hinda ꞌbe̱tka ma tsa̱hu̱, ngetho ár Hñö Jö xi tꞌakagihu̱ xi ñuska ma mu̱ihu̱ ár mhöte Jö.
\p 
\v 6 Ar tsi Hmu Hesukristo núꞌmu̱ xki wentkathogihu̱, mi zo̱nga ar pa bi unga ár te bi po̱kagihu̱ ndar tsꞌoktehu̱.
\p 
\v 7 Xi ñhembi da thinga nꞌa togo ne da unga ár te da po̱ta nꞌar jöꞌi ꞌbu̱i xiñho. Ha nuꞌmu̱ di ꞌbu̱hmö nꞌa di ñꞌe̱ntꞌi da ne da po̱ta nꞌa xa dar hogajöꞌi.
\p 
\v 8 Ha Jö bi ñꞌuse̱ hangu mökagihu̱, ngetho núꞌmu̱ ndar tsꞌoktehu̱, ar tsi Hmu Hesukristo bi unga ár te bi po̱kagihu̱.
\p 
\v 9 Xipyahmö, xi nhugagihu̱ hinte ma tsꞌoki di tuhu̱ ngetho bi nöꞌma ár ji, ne gatho nöꞌö bi me̱fi da jaju̱ ga kꞌonthu̱ ár kwe̱ Jö xi ꞌñepꞌu̱.
\p 
\v 10 Ngetho núꞌmu̱ ndar ñꞌu̱nihu̱ Jö, bi ñhogamu̱igihu̱ ár Tꞌu̱ núꞌmu̱ mi du. Xipyahmö, xta jwahu̱ xta ñhogamu̱iwihu̱, hage hinda po̱kagihu̱ ár te.
\p 
\v 11 Hinge ho̱nse̱ꞌö, di johyahu̱ di ꞌbu̱hwihu̱ Jö. Numa tsi Hmuhu̱ Hesukristo go bi mꞌa̱ madeꞌö, ne njapꞌu̱ da ñhogamu̱iwihu̱.
\s1 Ar Adan ne ar Kristo
\p 
\v 12 Nuꞌmú̱, nꞌadar ñꞌo̱ho̱ bi ku̱tꞌa ar tsꞌoki har ximha̱i, ne har tsꞌoki bi yu̱tꞌa ar ndöte. Ne ar ndöte bi nexa gatho ya jöꞌi, ngetho gatho bi ntsꞌokte.
\p 
\v 13 Númꞌu̱ hinxki tꞌunda yá ꞌbe̱pate ar Moise, mi jar tsꞌoki har ximha̱i. Ho̱nse̱ nu habu̱ hiñꞌotho ya ꞌbe̱pate, hinte ma tsꞌoki tho̱xa nꞌa.
\p 
\v 14 Mödi njapꞌu̱, ar ndöte xki ntöte mi tsixa gatho nuꞌu̱ xki ntsꞌokte, mödi nuyu̱ hinxki de̱mbahmö ár mhe̱ꞌsku ar Adan. Bi ndu̱i nuya pa mi ꞌbu̱ ar Adan, ne mi njapꞌu̱tho nuya pa mi ꞌbu̱ ar Moise. Ha nunar Adan nu̱, gehnu̱ ngu nꞌar ntꞌudi nöꞌö togo ma nda e mꞌe̱fa.
\p 
\v 15 Nuna ár mhe̱ꞌsku ar Adan himi tsa̱ nda ñhuxkwi ár ntꞌuni hwëgagihu̱ Jö. Ngetho ár njutꞌi ar mhe̱ꞌsku, ba e ar ndöte bi zu̱ nze̱ye̱. Ha nunár nhwëki ne ár ntꞌuni Jö bi hyexta nuya nze̱ye̱yu̱, gehnu̱ ár nhwëki nuna nꞌadar ñꞌo̱ho̱nu̱, ar tsi Hmu Hesukristo.
\p 
\v 16 Nunár tsꞌoki nꞌadar ñꞌo̱ho̱, hingi tsa̱ da ñhe̱xkwi ár nhwëki Jö. Ngetho nunar nꞌadar tsꞌokinu̱, ba tsimpar mfe̱i bi zu̱ ya meximha̱i. Ha nuna ár nhwëki Jö ba e bi zu̱ ya meximha̱i, ne bi tꞌembi hinte ma tsꞌoki tu, mödi xi ꞌyo̱tꞌa nze̱ye̱ ya tsꞌoki.
\p 
\v 17 Nunár tsꞌoki nuna nꞌadar ñꞌo̱ho̱, bi japi bi ntöte ar ndöte. Ha nunár ꞌbe̱fi nuna manꞌa nꞌase̱ ar ñꞌo̱ho̱, japi da mꞌu̱ xiñho ya meximha̱i, nuꞌu̱ togo xi hyexta ár nhwëki Jö ne ár ntꞌuni, gehyu̱ xi numañho Jö. Nuna nꞌase̱ ar ñꞌo̱ho̱nu̱, gehnu̱ ar Hesukristo.
\p 
\v 18 Nunár tsꞌoki nꞌadar ñꞌo̱ho̱ bi ku̱tꞌa ar mfe̱i, bi zu̱ gatho ya meximha̱i. Njapꞌu̱tho nꞌehe, nunár hogamꞌu̱i nꞌadar ñꞌo̱ho̱, nda nhu hinte ma tsꞌoki tu gatho ya meximha̱i nꞌehe, ne da me̱ꞌsyu̱ ar te.
\p 
\v 19 Ngetho njangu ár mhe̱ꞌsku nꞌadar ñꞌo̱ho̱, gatho ya jöꞌi bi tꞌembabi ya tsꞌokte. Njapꞌu̱tho nꞌehe nunár ntꞌo̱de nꞌar ñꞌo̱ho̱, gatho bi nhu hinte ma tsꞌoki mi tu.
\p 
\v 20 Nuya ꞌbe̱pate bi tꞌuni, ne njapꞌu̱ nda xönda ar tsꞌoki. Ha núꞌmu̱ mi xönda ar tsꞌoki, xa bi ntöte bi xu ár nze̱ye̱ ár nhwëki Jö.
\p 
\v 21 Njangu ar tsꞌoki bi ntöte, bi nja ar ndöte, njapꞌu̱ ár nhwëki Jö bi ntöte, bi nhu hinte ma tsꞌoki tu ya jöꞌi. Ne da me̱ꞌsa ar te hiñhamꞌu̱ da götsꞌi har ꞌbe̱fi bi ꞌyo̱tꞌa ma tsi Hmuhu̱ ar Hesukristo.
\c 6
\s1 Nupya hindi ꞌbu̱hu̱ ga o̱thu̱ ar tsꞌoki, ꞌbu̱tho xta tuhu̱
\p 
\v 1 Te ga möñhu̱ ꞌmu̱. Hage ga ꞌbu̱hu̱ har tsꞌoki, ga to̱ꞌmhu̱ da hyexkathogihu̱ ár nhwëki Jö.
\p 
\v 2 Hinꞌö, hinga njahu̱pꞌu̱. Ngetho ar tsꞌoki handgagihu̱ wande xta tuhu̱, hage ma ga ꞌbu̱thu̱ ga o̱thu̱ nöꞌö hingi ho ꞌmu̱.
\p 
\v 3 Wa hingi pöhu̱, gatho nuꞌu̱ xi xixthegihu̱, di nꞌatꞌwihu̱ ar tsi Hmu Hesukristo. Po̱ntho da nxixthewihu̱ núꞌmu̱ mi du, ne da tuhu̱ nꞌehe.
\p 
\v 4 Ngetho núꞌmu̱ da nxixthehu̱, po̱ntho bi thogagihu̱ mahye̱giwi ar Kristo. Ha núꞌmu̱ mi mengi bi nte manꞌagi, bi gu̱xa ár tsꞌe̱di ár Dada, njapꞌu̱ nuju̱ nꞌehe, ga ꞌbu̱hu̱ nꞌar ꞌraꞌyo mꞌu̱i.
\p 
\v 5 Ngetho núꞌmu̱ ndi hñöxkagihu̱ hár ndöte, njapꞌu̱ ndi hñöxkagihu̱ hár menga nte nꞌehe.
\p 
\v 6 Di pöhu̱ ꞌmu̱, numa ꞌbe̱tꞌo mꞌu̱ihu̱ bi tsꞌu̱ta har pontꞌi mahye̱giwiꞌö. Ne njapꞌu̱ nunar mꞌu̱inu̱ bi nhwati, hinda mengi da me̱pa ar tsꞌoki.
\p 
\v 7 Jangu nuꞌu̱ xi du, hinte tsa̱ te da japabi ar tsꞌoki.
\p 
\v 8 Ha nuꞌmu̱ xta tuwihu̱ mahye̱gi ar tsi Hmu Hesukristo, di ñꞌemu̱ihu̱ ma ga ꞌbu̱hwihu̱ nꞌehe.
\p 
\v 9 Di pöhu̱, ar Kristo mi nte manꞌagi, hinda mengi da du. Ha nunar ndöte hinte tsa̱ te da japabi.
\p 
\v 10 Ngetho nunár ndöte bi hwata ar tsꞌoki nꞌagitho. Ha nupya te, ꞌbu̱hwi Jö.
\p 
\v 11 Njapꞌu̱ nuꞌahu̱, beñhu̱ nunar tsꞌoki hantꞌaꞌihu̱ wande xka tuhu̱. Ne gi tehu̱ gi pe̱fu̱ Jö, gi ꞌbu̱hwihu̱ ma tsi Hmuhu̱ Hesukristo.
\p 
\v 12 Yo ma gi ñhe̱hu̱ da dö ar tsꞌoki ri ndoꞌyohu̱ tso̱nga ár ngötsꞌi. Jange yo gi o̱thwu̱ ya tsꞌoki ne.
\p 
\v 13 Hingi ꞌye̱nthu̱ ri ndoꞌyohu̱ da me̱pabi ar tsꞌoki. ꞌYe̱ntꞌase̱ ri tehu̱ hár ꞌye̱ Jö, ngu nꞌa xi mengi xi nte, ne japi da me̱ nöꞌö xiñho.
\p 
\v 14 Ngetho ar tsꞌoki hinda hyo̱pꞌahu̱ ha̱i. Hingi gu̱ñꞌahu̱pya yá ꞌbe̱pate ar Moise. Nupya tsixꞌahu̱ ár nhwëki Jö.
\s1 Ár ꞌbe̱gogihu̱ ar ñho
\p 
\v 15 Xiꞌmu̱, hage ga o̱thu̱ ya tsꞌoki ngetho hindi ꞌbu̱hu̱ ha yá ꞌbe̱pate ar Moise, di ꞌbu̱hu̱ hár nhwëki Jö. Hinꞌö, hingi njapꞌu̱.
\p 
\v 16 Hage hingi pöhu̱, nuꞌmu̱ gi ñhe̱hu̱ gi mꞌe̱gohu̱ gi pe̱fu̱ nꞌa, go ár ꞌbe̱goꞌihu̱ togo gi o̱thu̱. Wa ar tsꞌoki tsixꞌahu̱ har ndöte, wa Jö da ma̱xꞌahu̱ gi ꞌbu̱hu̱ xiñho.
\p 
\v 17 Jamödi Jö, mödi ngar ꞌbe̱goꞌihu̱hmö ar tsꞌoki, xka umba ri mu̱ihu̱ xka te̱ñhu̱ nunar mhönu̱ xi tꞌaꞌahu̱.
\p 
\v 18 Ne bi nju̱kꞌahu̱ har tsꞌoki, ne gi pe̱fu̱ ar ñhopya.
\p 
\v 19 Xta he̱kwa nöꞌö gi hanthu̱ hyaxꞌmu̱, ne njapꞌu̱ da zo ri mfenihu̱. Mahamꞌu̱ ngi e̱ntꞌa ri ndoꞌyohu̱ nda me̱pa nöꞌö hingi ho ne nöꞌö xintsꞌotho. ꞌYe̱nthu̱pya da me̱pa nöꞌö xiñho, ne njapꞌu̱ gi ꞌbu̱hu̱ nꞌar mꞌu̱i xintꞌaxi.
\p 
\v 20 Ngetho núꞌmu̱ ngi pe̱fu̱ ar tsꞌoki, hinge ngi pe̱fu̱ ar ñho.
\p 
\v 21 Tema ñho ga ju̱jwu̱ nöꞌö ngi pe̱hu̱ ꞌbe̱tꞌa ri tsa̱hu̱pya. Ngetho nunar njutꞌi ngi to̱ꞌmhu̱, gehnu̱ ar ndöte.
\p 
\v 22 Ha nupya xi nju̱kꞌahu̱ har tsꞌoki, ne ár ꞌbe̱goꞌihu̱ Jö, gi pe̱ꞌsu̱ ar mꞌu̱i xintꞌaxi ngu ri nthöhöhu̱. Ne ár ngötsꞌi gi to̱ꞌmhu̱ ar te hiñhamꞌu̱ da thege.
\p 
\v 23 Nunár njutꞌi ar tsꞌoki, ar ndöte. Ha nor ntꞌuni Jö, ar te hiñhamꞌu̱ da götsꞌi, ngetho di ꞌbu̱hwihu̱ ma tsi Hmuhu̱ Hesukristo.
\c 7
\s1 Tema ne da utkagihu̱ ar nthöti
\p 
\v 1 Tsi kuhu̱, gi pöhu̱ ya ꞌbe̱pate, jange gi pöhu̱ nuya ꞌbe̱pateyu̱ ho̱nse̱ pe̱ꞌsa ar tsꞌe̱di ha nꞌar jöꞌi tetho.
\p 
\v 2 Njangu nꞌar ꞌbe̱hñö, nuya ꞌbe̱pate hingi umba ar se̱ki da hye̱ ár döme núꞌmu̱ tetho. Ha nuꞌmu̱ da du ár döme, da mꞌe̱ ár tsꞌe̱di nunar nkohi mi te̱tꞌö.
\p 
\v 3 Jange nuꞌmu̱ ꞌbu̱ta ár döme, ne da me̱wi manꞌar ñꞌo̱ho̱, da nhu ngu nꞌar zinganthöti. Ha nuꞌmu̱ da du ár döme, ne da me̱wi manꞌar ñꞌo̱ho̱, njapꞌu̱ hingi tsꞌoka nor nkohiꞌö, hinda nhu ngu nꞌar zinganthöti.
\p 
\v 4 Njapꞌu̱pya tsi kuhu̱, núꞌmu̱ nga tuwihu̱ ár ndoꞌyo ar tsi Hmu Hesukristo, ga hye̱hu̱pꞌu̱ ngi te̱ñhu̱ ya ꞌbe̱pate. Gi ꞌbu̱hwihu̱pya manꞌa nunu̱ togo bi mengi bi nte, ne da tsa̱ gi ꞌyo̱thu̱ ya hoga ꞌbe̱fi gi e̱nthwu̱ Jö.
\p 
\v 5 Ngetho núꞌmu̱ ndi ꞌbu̱hu̱ nga o̱thu̱ gatho nöꞌö ndi nehu̱, ar tsꞌoꞌyotsꞌoki mi jakagihu̱ nga o̱thu̱ nöꞌö mi högagihu̱ ya ꞌbe̱pate. Ne nuya tsꞌoꞌbe̱fiyu̱ ndi o̱thu̱, ho̱nse̱ ndi to̱ꞌmhu̱ ar ndöte nda tꞌakagihu̱ ngu ma njutꞌihu̱.
\p 
\v 6 Ha nupya hindi ohu̱ hár ꞌye̱ ya ꞌbe̱pate, ngetho po̱ntho xta tuhu̱, ne hinte tsa̱ te da jakagihu̱. Jange di pe̱fu̱ Jö ha nunar ꞌraꞌyo mꞌu̱i bi ꞌrakagihu̱ ár Hñö Jö, ne hindi te̱nthu̱ nuya ꞌbe̱pate xi tꞌotꞌi xi ndönziatho.
\s1 Nor tsꞌoki di pe̱ꞌsa mbo
\p 
\v 7 Te da tsa̱ ga möñhu̱ ꞌmu̱. Hage nꞌar tsꞌoki da tꞌo̱tꞌa ya ꞌbe̱pate ꞌmu̱. Hinꞌö, hingi njapꞌu̱. Ho̱nse̱ nuga, nuya ꞌbe̱pate bi utkar tsꞌoki. Ngetho hinga pöhmö ga ꞌbe̱nte nuꞌmu̱ hinxi xika ya ꞌbe̱pate: Yo ma gi ꞌbe̱nte.
\p 
\v 8 Ha nor tsꞌoki bi gu̱ ar ꞌbe̱pate ne bi jakagi da ꞌbe̱nte. Ngetho nuꞌmu̱ hindi othohmö ar ꞌbe̱pate, ar tsꞌoki xi mꞌe̱tho.
\p 
\v 9 Nuga ndi tehmö ꞌra ya tsi pa, hinge ndi pöta ya ꞌbe̱pate. Ha mi zo̱ ya ꞌbe̱pate, da pödi tema ar tsꞌoki. Ne po̱ntho da tuga, ngetho da tsꞌoka ya ꞌbe̱pateyu̱.
\p 
\v 10 Ne da timbi nunar ꞌbe̱pate xki ñötkagi ar te, bi jakagi da tu.
\p 
\v 11 Ngetho ar tsꞌoki bi gu̱ ar ꞌbe̱pate bi kakagi, ne njapꞌu̱ bi hyogagi.
\p 
\v 12 Xa majöni ar tꞌofo ne ya ꞌbe̱pate xintꞌaxi, o̱tꞌar ñho ne fa̱xkagihu̱.
\p 
\v 13 Hage nöꞌö mar ñhomhö bi jakagi da tu ꞌmu̱. Hinꞌö, hingi njapꞌu̱. Nunar tsꞌoki bi ñꞌudi tenguꞌö, bi gu̱ nöꞌö mar ñho, bi jakagi da tu. Ne njapꞌu̱ nunar ꞌbe̱pate bi utkagi hangu ár ntsꞌotho ar tsꞌoki.
\p 
\v 14 Ngetho di pöhu̱, nuya ꞌbe̱pate xpa e mhetsꞌi, ha nuga dar meximha̱i, di pe̱par tsꞌoki.
\p 
\v 15 Hindi pödi tema di pe̱fi. Ngetho hindi o̱tꞌa nöꞌö di ne, ne di o̱tꞌa nöꞌö di u̱tsa ga o̱tꞌe.
\p 
\v 16 Nuꞌmu̱ nöꞌö hindi ne ga o̱tꞌe, go di pe̱ꞌö, di etꞌa ma mu̱i xiñho ya ꞌbe̱pate.
\p 
\v 17 Hingo geke togo te gatho o̱tꞌmu̱, go o̱tꞌa ar tsꞌoki di pe̱ꞌsa mbo.
\p 
\v 18 Ne di pödi hingi ꞌbu̱ ar ñho ha ma ndoꞌyo, ngetho di bemhö ga o̱tꞌa xiñho, ne hindi o̱tꞌa njapꞌu̱.
\p 
\v 19 Ngetho hindi o̱tꞌa nöꞌö ar ñho di nemhö ga o̱tꞌe. Ha xa di o̱tꞌa nöꞌö hingi ho, hindi nemhö ga o̱tꞌe.
\p 
\v 20 Nuꞌmu̱ di o̱tꞌa nöꞌö hindi ne, hingo di o̱tga ꞌmu̱, go o̱tꞌa ar tsꞌoki di pe̱ꞌsa mbo.
\p 
\v 21 Ngetho di nemhö ga o̱tꞌa nöꞌö xiñho, ne di handi ꞌyoda ar tsꞌoki ha ma mu̱i.
\p 
\v 22 Ngetho mbo ha ma mu̱i xa di johya di ne ga te̱mba ár ꞌñu Jö.
\p 
\v 23 Ne di handi nꞌehe, nuna ma ndoꞌyo nto̱xkwi ma mfeni, ne tsixkagi hár ꞌye̱ ar tsꞌoki di ꞌbu̱ꞌbe.
\p 
\v 24 Hwëkategi. Togo da gu̱gagi ga he̱ nunar ndoꞌyonu̱ tsixka har ndöte.
\p 
\v 25 Di umba njamödi Jö, bi ñöngagi har ꞌbe̱fi bi me̱ ma tsi Hmuhu̱ Hesukristo. Gekase̱, ha ma mfeni di pe̱pa Jö, mödi ma ndoꞌyo pe̱pa ar tsꞌoki.
\c 8
\s1 Ga ꞌbu̱hu̱ ngu xikagihu̱ ár Hñö Jö
\p 
\v 1 Nupya hinte ma mfe̱i to̱ꞌma nuꞌu̱ togo ꞌbu̱hwi ar tsi Hmu Hesukristo, ne o̱tꞌa ngu xipa ár Hñö Jö, hinge ngu nese̱ꞌu̱.
\p 
\v 2 Ngetho di ꞌbu̱hwihu̱ ar tsi Hmu Hesukristo, nu ár Hñö Jö togo unga ar te, xi gu̱gagihu̱ ndi ohu̱ hár ꞌye̱ ar tsꞌoki ne ar ndöte.
\p 
\v 3 Nöꞌö himbi tsa̱ bi ꞌyo̱tꞌa ya ꞌbe̱pate, ngetho ya meximha̱i himi otho yá tsꞌe̱di nda ꞌyo̱tꞌe, jange gese̱ Jö ba pe̱hna ár Tꞌu̱, jangutho nꞌar meximha̱i mi tsa̱hmö nda ꞌyo̱tꞌa ar tsꞌoki. Nunu̱ bi unga ár te bi hñömba ár tsꞌe̱di ar tsꞌoki.
\p 
\v 4 Njapꞌu̱ bi tsa̱ ndar hogajöꞌihu̱ ngu a̱kagihu̱ ya ꞌbe̱pate. Ngetho hindi ꞌyohu̱ ngu di nese̱hu̱, di ꞌyohu̱ ngu ne ár Hñö Jö.
\p 
\v 5 Ngetho nuꞌu̱ togo ꞌbu̱ ngu ne yá mfenise̱, ho̱nse̱nu̱ beni. Ha nuꞌu̱ togo da̱twa yá mfeni ár Hñö Jö, ho̱nse̱nu̱ beñꞌu̱ nꞌehe.
\p 
\v 6 Nuꞌu̱ togo pe̱pa yá mfenise̱, ma da dinga ar ndöte. Ha nuꞌu̱ togo pe̱pa ár Hñö Jö, ma da dinga ar te ne ar hogamꞌu̱i.
\p 
\v 7 Nuꞌu̱ ꞌbu̱ ngu ne yá mfenise̱, nto̱xkwi Jö, ngetho hingi ne, ne hingi tsa̱ da ꞌyo̱twa yá ꞌbe̱pate möñꞌö.
\p 
\v 8 Ne nuꞌu̱ togo ꞌbu̱ ngu neꞌu̱, Jö hinda tsa̱ da numañhobi yá teꞌu̱.
\p 
\v 9 Ha nuꞌahu̱ hingi pe̱fu̱ ri mfenise̱hu̱, gi pe̱fu̱ ár Hñö Jö ꞌbu̱ ha ri mu̱ihu̱, nuꞌmu̱ majöni ꞌbu̱hnu̱. Ha nuꞌmu̱ nꞌa hingi pe̱ꞌspa ár Hñö ar tsi Hmu Hesukristo, hingo ár me̱tiꞌö.
\p 
\v 10 Ha nuꞌmu̱ ar tsi Hmu Hesukristo ꞌbu̱ ha ri mu̱ihu̱, mödi ri ndoꞌyohu̱ ꞌbu̱tho xi du har tsꞌoki, nuri hñöhu̱ te, ngetho gi ꞌbu̱hwihu̱ xiñho Jö.
\p 
\v 11 Nuꞌmu̱ ꞌbu̱ ha ri mu̱ihu̱ ár Hñö Jö togo bi koꞌspa ár te ar tsi Hmu Hesukristo, Jö, ngu bi gu̱xa ar tsi Hmu, njapꞌu̱ da umba nꞌar ꞌraꞌyo te ri ndoꞌyohu̱ xi du. Da njapꞌu̱ ngetho gi ꞌbu̱hwihu̱ ár Hñö.
\p 
\v 12 Jange tsi kuhu̱, hindi ꞌñepi ga pe̱fu̱ gatho nöꞌö ne ma ndoꞌyohu̱.
\p 
\v 13 Ngetho nuꞌmu̱ gi ꞌbu̱hu̱ ngu xiꞌahu̱ ri mfenise̱hu̱, ma gi tuhu̱. Ha nuꞌmu̱ gi ꞌbu̱hu̱ ngu utꞌahu̱ ár Hñö Jö, gi jafu̱ da mꞌe̱ nöꞌö ne ar ndoꞌyo, ne gi pe̱ꞌsu̱ ar te.
\p 
\v 14 Ngetho nuꞌu̱ togo tsixa ár Hñö Jö, go yá bötsi Jöꞌu̱.
\p 
\v 15 Hinxta höñhu̱ ár Hñö Jö ne ga penju̱ ga ntsuhu̱. Xta höñhu̱ ár Hñö Jö xi jakagihu̱ yá tedegihu̱ Jö. Jange di emfu̱pya: Ma tsi Dadaꞌi.
\p 
\v 16 Ár Hñö Jö da̱twa majöni ma hñöse̱hu̱, ne embabi yá bötsigihu̱ Jö.
\p 
\v 17 Ha nuꞌmu̱ yá bötsigihu̱, ma da ꞌraju̱ nuya ñho xi ñötkagihu̱, ne ga ñhehwihu̱ ar tsi Hmu Hesukristo. Ngetho nuꞌmu̱ ga thohu̱ ya thogi ngu bi thoꞌö, ma ga ꞌbu̱hwihu̱ hár nsunda.
\p 
\v 18 Di pöka xiñho, nuya thogi di thohu̱pya, hinter me̱ꞌö nuꞌmu̱ ga he̱jwu̱ ar nsunda di to̱ꞌmhu̱ ga hanthu̱ mꞌe̱fa.
\p 
\v 19 Gatho nöꞌö xi hyoka ár ꞌye̱ Jö, to̱ꞌma ar pa da hyanda ar tsi Dada da ñꞌu yá bötsi.
\p 
\v 20 Ngetho gatho nöꞌö bi hyoka ár ꞌye̱ Jö, bi ꞌbe̱ ar ꞌñu nöꞌö nda me̱fi. Hingo bi nese̱ nda njapꞌu̱, bi ne Jö togo bi umba ar ndo̱ꞌmi nꞌehe.
\p 
\v 21 Gatho nöꞌö bi hyoka ár ꞌye̱ Jö, ma da thökwabi nunar tsꞌe̱di japabi da nhwati, ne da njohyawi xta hñönga ár nsunda yá bötsi Jö.
\p 
\v 22 Ngetho di pöhu̱, gatho nöꞌö bi hyoka Jö, ꞌrangutho xa hu̱ ár ñö hinxi ntsa̱ya̱ xi nzoñꞌu̱, ntsa̱wi ar u̱gi ngu nꞌar ꞌbe̱hñö ma da da̱ ár bötsi.
\p 
\v 23 Ne hinge ho̱nse̱ꞌu̱. Gese̱gihu̱ nꞌehe, togo xi tꞌakagihu̱ ár Hñö Jö ngu nꞌar nkohi nöꞌö da tꞌakagihu̱ mꞌe̱fa. Ne di zoñhu̱ tu ma mu̱ihu̱ di to̱ꞌmhu̱ da tekagihu̱ Jö, ne da ꞌrakagihu̱ nꞌar ꞌraꞌyo ndoꞌyo hinda du.
\p 
\v 24 Ngetho núꞌmu̱ nda mpo̱hu̱, gehnu̱ di to̱ꞌmhu̱. Ha nuꞌmu̱ gar hanthu̱hmö, hingar ndo̱ꞌmi. Hinto to̱ꞌma nöꞌö pe̱tsꞌi.
\p 
\v 25 Ha nuꞌmu̱ di to̱ꞌmhu̱ nöꞌö hindi hanthu̱, ga tse̱thu̱ ga to̱ꞌmhu̱.
\p 
\v 26 Njapꞌu̱tho ár Hñö Jö togo fa̱xkagihu̱ hinte ja ma tsꞌe̱dihu̱. Ngetho hindi pöhu̱ ga a̱hu̱ ngu di ꞌñepi. Gese̱ꞌö xa hu̱ ár ñö zoni, ꞌba̱ made a̱pkagihu̱ tema di hoñhu̱.
\p 
\v 27 Ne Jö togo hetꞌwa yá mu̱i ya jöꞌi, pödi tema ne ár Hñö Jö. Ngetho nunu̱ a̱pkagihu̱ ngu benga Jö xiñho da umba yá bötsi xi ñꞌemu̱i.
\s1 Hyaxꞌmu̱ xa di tötehu̱
\p 
\v 28 Di pöhu̱, nuꞌu̱ togo mö Jö, gatho nöꞌö te thogi fa̱tsꞌi di ꞌñepa ar ñho, gehyu̱ togo xi tsꞌofo ngu xi benga Jö.
\p 
\v 29 Nuꞌu̱ xki bödi nda mpo̱ho̱ núꞌmu̱ hinxki thokta ar ximha̱i, gehyu̱ bi hñutsꞌi nda ñhe̱hwi ár Tꞌu̱, togo nda ñöxhmu gatho ya ku.
\p 
\v 30 Ha nuꞌu̱ togo xki hñutsꞌi, gehyu̱ bi zohni. Ha nuꞌu̱ togo bi zohni, gehyu̱ bi nu hinte ma tsꞌoki mi tu. Ha nuꞌu̱ togo bi nu hinte ma tsꞌoki mi tu, gehyu̱ togo bi umbi nda mꞌu̱ hár nsunda.
\p 
\v 31 Tema da tsa̱ ga möñhu̱ ꞌmu̱. Nuꞌmu̱ di ꞌbu̱hwihu̱ Jö, togo tsa̱ te da jakagihu̱ ꞌmu̱.
\p 
\v 32 Jö togo himbi ꞌyo̱tꞌa ár ꞌñöngi bi da̱ ár Tꞌu̱ bi po̱kagihu̱, hage hinda ꞌrakagihu̱ mahye̱giwi ár Tꞌu̱ gatho nöꞌö di hoñhu̱.
\p 
\v 33 Togo tsa̱ te da hyo̱xa nuꞌu̱ togo xi hwahna Jö, nuꞌmu̱ gese̱ Jö xi nu hinte ma tsꞌoki mi tu.
\p 
\v 34 Hage ꞌbu̱ manꞌa togo da hñuxhmö ar mfe̱i. Ar tsi Hmu Hesukristo bi unga ár te. Hinge ho̱nse̱ꞌö, getꞌö togo bi mengi bi nte, ne bi huxkwi ár Dada hár ñꞌe̱i, habu̱ bi ꞌba̱ made a̱pkagihu̱ Jö.
\p 
\v 35 Hiñꞌotho te da japa ma tsi Hmuhu̱ Hesukristo da hye̱gi da mökagihu̱. Wa di thohu̱ ar thogi, ar dumu̱i, ar ntꞌu̱tsa, ar thuhu, ar kꞌatꞌa he. Núꞌmu̱ ꞌbu̱tho da thöga ma tehu̱, wa ñhötju̱ ar jwai.
\p 
\v 36 Ngu enga har Tꞌofo:
\q1 Ngetho di te̱ñꞌahe, hyaxꞌmu̱ ꞌbu̱tho xta tuhe.
\q1 Nhugagihe ngu ar tsi de̱ti xi tꞌe̱ntꞌi da tho.
\p 
\v 37 Ha nuju̱ di töhu̱ gatho nuya thogiyu̱, ngetho fa̱xkagihu̱ togo xi mökagihu̱.
\p 
\v 38 Jange xa di ka̱xmbeni, nunar ndöte, ar te, nuya e̱nxe̱, ya ndö, nuꞌu̱ ja yá tsꞌe̱di, nöꞌö te japya, nöꞌö te di ꞌñepꞌu̱,
\p 
\v 39 nöꞌö te bi ja mañö, nöꞌö te bi ja ha̱i, wa manꞌa tema xi hyoka Jö, hinda tsa̱ da ꞌwegagihu̱ hár mhöte Jö, bi utkagihu̱ mba pe̱nkagihu̱ ar tsi Hmu Hesukristo.
\c 9
\s1 Jö bi hwahna ya me Israel
\p 
\v 1 Nuga, nöꞌö di mö majöni, ngetho di nꞌatꞌbe ar tsi Hmu Hesukristo. Ne hinte di pe̱tsꞌi te ga ntsa̱, ngetho ár Hñö Jö da̱tka majöni.
\p 
\v 2 Xa tu ma mu̱i, ne xa di tsa̱mañꞌu̱.
\p 
\v 3 Nuga di ne nuꞌmu̱ da tsa̱hmö, go ga mꞌe̱ka, hinga ꞌbu̱ꞌbe ar tsi Hmu Hesukristo, nuꞌmu̱ njapꞌu̱ da tsa̱ da mpo̱ nuꞌu̱ ma mixodyoꞌbe. Gehyu̱ ma ku di pe̱sꞌbe nꞌadar ji.
\p 
\v 4 Nuya me Israel gehyu̱ yá tede Jö, bi utwa ár nsunda. Bi umbabi ya nkohi ne ya ꞌbe̱pate. Bi xipa hanja nda nsundabi, ne bi umba yá ñhötꞌi.
\p 
\v 5 Ka ba ehnu̱ yá pale mi te̱nga Jö, ne ha yá ꞌbe̱toyu̱, ka ba mꞌu̱hnu̱ ngu nꞌar ñꞌo̱ho̱ ar tsi Hmu Hesukristo. Gese̱nu̱ Jö, go ár me̱ti gatho tema ja, hindi tsa̱ya̱ di tꞌumba ar nsunda. Dá njapꞌu̱.
\p 
\v 6 Hinge xi njapꞌu̱tho ár mhö Jö. Ho̱nse̱ hinga gatho nuꞌu̱ yá ꞌbe̱to ar Hakob gehyu̱ ár hnini Jö.
\p 
\v 7 Hinda tsa̱ ga eñhu̱ gatho nuꞌu̱ yá ꞌbe̱to ar Abra yá bötsi Jö nꞌehe. Hinꞌö, ngetho bi xipabi: Ho̱nse̱ yá ꞌbe̱to ar Isa gi ꞌñembabi ri ꞌbe̱to.
\p 
\v 8 Nuꞌmú̱, hinge gatho yá bötsi ar Abra yá bötsi Jö nꞌehe. Ho̱nse̱ nuꞌu̱ xi zu̱ ár ñhötꞌi Jö, gehyu̱ xi tꞌembabi yá bötsi ne yá ꞌbe̱to ar Abra.
\p 
\v 9 Ngetho njanu̱ enga ár ñhötꞌi ar tsi Dada: Ga penga ri je̱ye̱ ngu nuya payu̱, ne ar Sara ma da ꞌyo̱nga ár bötsi.
\p 
\v 10 Hinge ho̱nse̱ꞌö, manꞌa te bi thogi. Númꞌu̱ mi dinga yoho yá bötsi ar Rebeka, nꞌase̱ ár dada, gehnu̱ ar Isa ma palehu̱.
\p 
\v 11 Númꞌu̱ hinxki mꞌu̱ta nuya yoho yá bötsi, ne hinxki ꞌyo̱tꞌatho ar ñho wa ar tsꞌoki, Jö xki hwahna nꞌaꞌu̱. Hinxki hyandwa yá hoga ꞌbe̱fi, ngetho njapꞌu̱ xki beñꞌö nda ꞌyo̱tꞌe.
\p 
\v 12 Bi ꞌñembabi ar Rebeka: Ri ꞌbe̱tꞌo tꞌu̱ ma da me̱pa ar ꞌbe̱fa.
\p 
\v 13 Ngu enga har Tꞌofo: Nuga da mö ar Hakob, ne da u̱tsa ar Esau.
\p 
\v 14 Tema tsa̱ ga möñhu̱ ꞌmu̱. Hage hingi o̱tꞌa xiñho Jö. Hinꞌö, hingi njapꞌu̱.
\p 
\v 15 Ngu bi ꞌñemba ar Moise: Nuga ga hwëka togo di nega, ne ga pe̱ꞌspa ar tsꞌe̱ti togo di nega nꞌehe.
\p 
\v 16 Hinge nuꞌmu̱ da nese̱ ar jöꞌi, wa núꞌmu̱ xa umbár mu̱i da thahni. Jö go da möñꞌö togo da me̱ꞌspa ar tsꞌe̱ti.
\p 
\v 17 Har Tꞌofo huxa tema nsipabi ar ndö Ehipto: Nuga xta ju̱xꞌaꞌi ga ñꞌu ma tsꞌe̱di, ne da nu̱nga ma thuhu gatho ár nxidi ar ximha̱i.
\p 
\v 18 Nuꞌmú̱, Jö pe̱ꞌspa ar tsꞌe̱ti togo neꞌö, ne nöꞌö togo ne da japabi da nme̱ꞌsku, tsa̱ da ꞌyo̱tꞌe.
\p 
\v 19 Nuꞌmú̱, da tsa̱ gi ꞌñengagihu̱: Hanja Jö umba ár mfe̱i ya jöꞌi ꞌmu̱. Ngetho hinjoꞌo togo da do̱spa ár mfeni Jö.
\p 
\v 20 Ha nuga ga thötꞌahu̱ njawa: Tsi jöꞌiꞌi, togoꞌi gi ne gi ntsa̱wi Jö. Hage nꞌar ꞌbada tsa̱ da ꞌñemba ar gö, yoꞌö xka hyogagi njawa.
\p 
\v 21 Hage hingi pe̱ꞌsa ár tsꞌe̱di ar gö da hyoka nor ꞌbada neꞌö. Nꞌadar xe̱ni ar bo̱ha̱i, da tsa̱ da hyoka ya ꞌbada di ꞌbo̱xa habu̱ jar nsu, ne ya ꞌbada di hö har ꞌbe̱fi hyaxꞌmu̱.
\p 
\v 22 Hage hingi njapꞌu̱tho Jö nꞌehe. Mi nemhö nda ñꞌu ár kwe̱, ne nda ñꞌu ár tsꞌe̱di, ha bi me̱ꞌspatho ar tsꞌe̱ti nuꞌu̱ xki hñutsꞌi nda hwati.
\p 
\v 23 Bi ꞌyo̱tꞌa njapꞌu̱ nda utwabi tengu ár döta ár nsunda nuꞌu̱ togo xi zu̱twa ár nhwëki, ne xi hñuxꞌö da mꞌu̱hwi hár nsunda.
\p 
\v 24 Ngetho Jö xi zonkagihu̱ ga po̱ñhu̱ madeda ya xodyo ne nuꞌu̱ hingya xodyo.
\p 
\v 25 Jangu enga har tꞌofo bi ꞌyotꞌa ar mꞌe̱hni Osea, habu̱ enö njawa:
\q1 Ma ga embabi ma hnini nuꞌu̱ hingo ma hninihmö,
\q1 Ne nöꞌö ar hnini hingi ndi mödi, ma ga möpya.
\q1 
\v 26 Ne habu̱ xki tꞌembabi:
\q1 Nuꞌahu̱ hingo ma hniniꞌihu̱,
\q1 ja ma da tꞌembabinu̱,
\q1 gehyu̱ yá bötsi Jö hö ar te.
\p 
\v 27 Ar Isaia mi enö nꞌehe, núꞌmu̱ mi no̱nga ya me Israel: Mödi mar nze̱ye̱ ngu ar ꞌbomu ꞌbonga har ñönthe, ho̱nse̱ nꞌa tsi tu̱i xi bongi ma da mpo̱ho̱.
\p 
\v 28 Ngetho ar tsi Hmu ngutꞌa ma da japi da thokwa har ximha̱i ngu xi möñꞌö.
\p 
\v 29 Ngu bi ꞌñenga mamꞌe̱tꞌo ar Isaia nꞌehe:
\q1 Nuꞌmu̱ ar tsi Dada togo pe̱ꞌsa ar tsꞌe̱di hinxi ꞌye̱gagihu̱ ꞌra ma ꞌbe̱tohu̱,
\q1 xta ñhe̱hwihu̱ ar hnini Sodoma, ne ndi hñöxkagihu̱ ar hnini Gomora.
\s1 Jö numañho nuꞌu̱ ñꞌemu̱i
\p 
\v 30 Te da tsa̱ ga möñhu̱pya. Nuꞌu̱ hingya xodyo himi honi nda mꞌu̱ xintꞌaxi hár nthandi Jö, gehyu̱ xi nhu hinte ma tsꞌoki tupya ngetho ñꞌemu̱i.
\p 
\v 31 Ha nu ar hnini Israel togo mi umba ár mu̱i bi de̱mba yá ꞌbe̱pate ar Moise, ne njapꞌu̱ nda nhu hinte ma tsꞌoki mi tuhmö, himbi zu̱di.
\p 
\v 32 Yoꞌö. Ngetho mi umbyá mu̱i mi honi nda tꞌaxki hinge har ñꞌemu̱i. Mi hoñꞌu̱ nda tꞌaxka ha ya hoga ꞌbe̱fi mönga ya ꞌbe̱pate, ne bi nto̱xkwi ar do mfetsꞌe.
\p 
\v 33 Ngu enga har Tꞌofo:
\q1 Pöhu̱, nuga di po̱ nꞌar do mfetsꞌe ne ntꞌentꞌi núnu̱ Sion.
\q1 Ha nöꞌö togo da ñꞌemu̱ibiꞌö, hinda ma da ꞌbe̱ ár tsa̱.
\c 10
\p 
\v 1 Tsi kuhu̱, xa majöni di xiꞌahu̱, di umba ma mu̱i di a̱pa Jö da mpo̱ ya me Israel.
\p 
\v 2 Nuga di da̱majöni, nuyu̱ xa umbyá mu̱i honga Jö, mödi hingi pödi xiñho nöꞌö o̱tꞌu̱.
\p 
\v 3 Ngetho hinxi böꞌu̱ ar hogamꞌu̱i ungar tsi Dada. Xi umbyá mu̱i da nhumañhobi nöꞌö o̱tꞌu̱, ne njapꞌu̱ hingi japamasu nöꞌö xi ꞌyo̱tꞌa Jö nda nhumañhogihu̱.
\p 
\v 4 Nuyá ꞌbe̱pate ar Moise bi göxa ár tsꞌe̱di núꞌmu̱ ba e ar tsi Hmu Hesukristo, ne njapꞌu̱ nda nhu hinte ma tsꞌoki tu gatho nuꞌu̱ da ñꞌemu̱ibi.
\p 
\v 5 Ngetho nöꞌö togo ne da mꞌu̱i xiñho hár nthandi Jö di te̱nga nöꞌö bi ꞌyotꞌa ar Moise, enga njawa: Nöꞌö togo da ꞌyo̱tꞌa gatho nuya ꞌbe̱pateyu̱, ma da me̱ꞌsa ar te.
\p 
\v 6 Ha nunar nhumañho bi e har ñꞌemu̱i, engagihu̱ njawa: Yo ma gi beñhu̱ togo ma da bo̱xa mhetsꞌi da tsiwa ar tsi Hmu Hesu.
\p 
\v 7 Wa gi ꞌñeñhu̱: Togo da gö har ꞌbe̱xui da gu̱xa ar tsi Hmu Hesu habu̱ bi ku̱ nuꞌu̱ xi du.
\p 
\v 8 Ne te mönga har Tꞌofo: Gi pe̱ꞌspꞌu̱ getꞌu̱tho ar mhö, oda ha ri ne, ne ha ri mu̱i. Gehnu̱ ar mhö ñꞌemu̱i di da̱he majöni.
\p 
\v 9 Nuꞌmu̱ nuna ri ne da̱majöni ar Hesukristo gehnu̱ ar Hmuꞌö, ne gi jamfi ha ri mu̱i Jö bi gu̱xa manꞌagi har ndöte, ma gi mpo̱ho̱.
\p 
\v 10 Ngetho ha ma mu̱ihu̱ di ñꞌemu̱ihu̱, ne njapꞌu̱ nhugagihu̱ hinte ma tsꞌoki di tuhu̱. Ha numa nehu̱ da̱majöni nöꞌö di ñꞌemu̱ihu̱, ne njapꞌu̱ ga mpo̱hu̱.
\p 
\v 11 Ngetho har Tꞌofo enga njawa: Gatho nuꞌu̱ togo da ñꞌemu̱ibi, hinda ma da ꞌbe̱ ár tsa̱.
\p 
\v 12 Mahye̱tho ya xodyo ne nuꞌu̱ hingya xodyo, nꞌadár Hmu gathoꞌu̱, ne umbabi da bongwatho gatho nuꞌu̱ togo matꞌi.
\p 
\v 13 Ne enga ar Tꞌofo nꞌehe: Gatho nuꞌu̱ togo da matꞌwa ár thuhu ar tsi Hmu, ma da mpo̱ho̱.
\p 
\v 14 Ha nuꞌmu̱ hinxi ñꞌemu̱i, hinda tsa̱ da matꞌi. Ha nuꞌmu̱ hinxi ꞌyo̱de, hanja ma da ñꞌemu̱i. Ha nuꞌmu̱ hinto höꞌspa ar hoga mhö, hinda ma da ꞌyo̱ꞌu̱.
\p 
\v 15 Ne nuꞌmu̱ hinto xi mꞌe̱hni, hanja da mhönga ar hoga mhö. Jangu enga har Tꞌofo: Nza̱da ár nzo̱ho̱ nöꞌö togo mönga ar hogamꞌu̱i ne ar hoga mhö.
\p 
\v 16 Mödi hinga gatho xi ꞌyo̱ta ar hoga mhö xi ꞌyo̱de. Ngu xi ꞌñenga ar mꞌe̱hni Isaia: Tsi Hmu, hinto xi ñꞌemu̱i ar hoga mhö xta möñhe.
\p 
\v 17 Da thinga ar ñꞌemu̱i nuꞌmu̱ da tꞌo̱xa ar hoga mhö, ne nunar mhönu̱ no̱nga ar tsi Hmu.
\p 
\v 18 Ha di a̱ñꞌaꞌihu̱pya: Hage hinxi ꞌyo̱ꞌu̱ ꞌmu̱. Hö, xi ꞌyo̱de, ngetho enga har Tꞌofo:
\q1 Gatho ár nxidi ar ximha̱i xi nu̱nga yá mhöꞌu̱,
\q1 ne habu̱ gatho xi zo̱nga nöꞌö möñꞌu̱.
\p 
\v 19 Di enga nꞌehe: Hage hinxi bö ya me Israel. Hö, xi bödi, ngetho ar Moise bi ꞌñenö mꞌe̱tꞌo:
\q1 Nuga ar tsi Dada di enga: Ma ga tso̱tꞌahu̱ ri mu̱ihu̱, ga honga manꞌar hnini nöꞌö hingo ma hnini.
\q1 Ne ma ga po̱ñꞌahu̱ ri kwe̱hu̱, ga muntsꞌa ꞌra ya jöꞌi te gatho bentho.
\p 
\v 20 Mꞌe̱fa ar mꞌe̱hni Isaia himbi ntsu bi ꞌñenö:
\q1 Ar tsi Dada enö: Bi dingagi nuꞌu̱ togo himi hongagi.
\q1 Da ñꞌudi bi hyandga nuꞌu̱ himi a̱ngagi.
\p 
\v 21 Har tsi Hmu emba ya me Israel: Gatho ar pa da tu̱ngwa ma ꞌye̱ ꞌra ya jöꞌi xa ya me̱ꞌsku ne ya to̱xte.
\c 11
\s1 Nöꞌö nꞌa tsi tu̱i ya me Israel xi bongi
\p 
\v 1 Jange di a̱ñꞌahu̱: Hage Jö xi hye̱pꞌu̱ ár hnini ꞌmu̱. Hinꞌö, ngetho nuga dar me Israel nꞌehe, ár ꞌbe̱togi ar Abra, ne ár bötsigi ar Benjamin.
\p 
\v 2 Jö hinxi hye̱ ár hnini yanu̱ mamꞌe̱tꞌo xi bödi. Ha hinxka nehu̱ tema mönga ar Tꞌofo habu̱ no̱nga ar mꞌe̱hni Elia, núꞌmu̱ mi ka̱xa Jö tema mi o̱tꞌa ya me Israel. Mi enga njawa:
\p 
\v 3 Tsi Hmuꞌi, xi thoꞌa gatho ri mꞌe̱hni, xi thextꞌa gatho ri ꞌbo̱xmꞌo̱ñho̱. Ho̱nse̱ di koka, ne thongagi da thogi nꞌehe.
\p 
\v 4 Ne bi dötwa Jö bi ꞌñenö: Xta hwahna hñunꞌa̱temaꞌre̱tꞌa ya nthebe togo hinxi nda̱ndihmö xi ndönga ar tsita ár thuhu Bal.
\p 
\v 5 Njapꞌu̱ nuya payu̱, ꞌbu̱ ꞌra ya tsi tu̱i xi bongi togo xi hwahna Jö xi hwëkwa ár ntꞌuni.
\p 
\v 6 Ha nuꞌmu̱ xi nhwëkwabi, hinxi döꞌu̱ o̱tꞌa ya hoga ꞌbe̱fi. Ngetho nuꞌmu̱ xi döꞌu̱ di o̱tꞌa ya hoga ꞌbe̱fi, hingar nthekate ꞌmu̱ ár ntꞌuni xi unga ar tsi Dada.
\p 
\v 7 Xiꞌmu̱, te ga beñhu̱. Nuya me Israel himbi dinga nöꞌö tema mi honi. Ho̱nse̱ nuꞌu̱ tsi tu̱i xki thahni bi diñꞌu̱. Ha nu maꞌra bi njapi bi me yá mfeni hinge nda diñꞌu̱.
\p 
\v 8 Ngu enga har Tꞌofo: Jö bi ꞌñökwa yá mfeni, ne bi gotwa yá da̱ ne yá gu. Njapꞌu̱tho ꞌbu̱ nuya payu̱.
\p 
\v 9 Ne ar Dabi bi ꞌñenö njawa:
\q1 Nuyá ñhuni, dá japi da ntsꞌokse̱,
\q1 ngu nꞌar xögu wa nꞌar ntꞌa̱tsꞌi habu̱ da zose̱ꞌu̱, gehnu̱ ár mfe̱iꞌu̱.
\q1 
\v 10 Dá mꞌe̱xui yá da̱, hinda hyantꞌu̱,
\q1 ne hindi tsa̱ya̱ yá xu̱tha di muxa yá ꞌbe̱ni.
\s1 Ár mpo̱ho̱ nuꞌu̱ hingya xodyo
\p 
\v 11 Di a̱ñꞌahu̱ nꞌehe: Hage xi mfeꞌsa ya me Israel ne xi nhwati ꞌmu̱. Hinꞌö, hingi njapꞌu̱. Ngetho xa ya me̱ꞌsku, bi tꞌumba ar mpo̱ho̱ nuꞌu̱ hingya xodyo, ne njapꞌu̱ nda tsꞌo̱tꞌwa yá mu̱i.
\p 
\v 12 Ha nuꞌmu̱ nuyá tsꞌokiꞌu̱ bi ma̱tsꞌi da me̱ꞌsa ya ñho gatho ya meximha̱i, ne núꞌmu̱ bi da̱hyu̱ bi ma̱xa nuꞌu̱ hingya xodyo nda zu̱ ar ñho, tenguhmö núꞌmu̱ xta mengi da mꞌu̱hwi Jö manꞌagi.
\p 
\v 13 Nuga di zoꞌahu̱ hingar xodyohu̱, ngetho dar mpo̱te ar tsi Hmu, xi me̱nkagi ga zo nuꞌu̱ hingya xodyo, ne di numansu ma ꞌbe̱fi.
\p 
\v 14 Xömhö njanu̱ ga tso̱tꞌwa yá mu̱i nuya ma mixodyoꞌbe, ne da mpo̱ ꞌraꞌu̱.
\p 
\v 15 Ngetho núꞌmu̱ mi the̱ꞌu̱, bi ñhogamu̱iwi Jö gatho nu maꞌra ꞌbu̱ maꞌra ya ha̱i, nu xta mengi da tsꞌihi, po̱ntho da mengi da me̱ꞌsa yá teꞌu̱.
\p 
\v 16 Njangu nuꞌmu̱ nor ꞌbe̱tꞌo xe̱niju̱ni xi nda̱twa Jö, gatho nöꞌö manꞌa xe̱ni nꞌehe. Ha nuꞌmu̱ yá ꞌyu̱ nꞌar za ár me̱ti Jö, gatho yá ꞌye̱za nꞌehe.
\p 
\v 17 Nuꞌmu̱ nꞌar hoga ꞌba̱i ar njömdo̱ni bi mfe̱kwa ꞌra yá ꞌye̱za, ne bi thuxꞌaꞌi nuꞌge gar ꞌye̱za ar ma̱nga njömdo̱ni, ne gi tsipa ár ngi ar hoga ꞌba̱i,
\p 
\v 18 yo gi exa ri nsu gi ne gi hyo̱maha̱i nuya ꞌbe̱tꞌo ꞌye̱za. Ngetho gi pödi hingi to̱xke ar ꞌyu̱za, go to̱xꞌaꞌi.
\p 
\v 19 Tsa̱ gi ꞌñemhö: Nuya ꞌye̱za bi mfe̱ki ne bi thuxkagiga.
\p 
\v 20 Nuyu̱ bi mfe̱ki ngetho ma ya me̱ꞌsku, ha nuꞌge ngetho gi ñꞌemu̱i bi thuxꞌaꞌi. Jange yo gi exa ri nsu, tsupa Jö.
\p 
\v 21 Ngetho nuꞌmu̱ Jö himbi pumbabi nuya ꞌye̱za xki bo̱hnu̱, hanja ma da pumpꞌaꞌige.
\p 
\v 22 Jange hyandwa xiñho ár tsꞌe̱ti ne ár kwe̱ Jö. Hö, ár kwe̱ pe̱ꞌspa nuꞌu̱ xi da̱gi. Ha nuꞌge, pe̱sꞌa ar tsꞌe̱ti nuꞌmu̱ gi pödi gi su nunar tsꞌe̱tinu̱. Nuꞌmu̱ hinꞌö, ma da me̱kꞌaꞌi ngu bi japa nuyu̱ maꞌra ya ꞌye̱za.
\p 
\v 23 Njapꞌu̱ nuꞌu̱ xi mfe̱ki, nuꞌmu̱ da hye̱pꞌu̱ yá me̱ꞌsku, da mengi da thuta manꞌagi, ngetho Jö pe̱ꞌsa ar tsꞌe̱di da mengi da tuta har ꞌba̱i manꞌagi.
\p 
\v 24 Ngetho nuꞌge, ngu nꞌar ma̱nga njömdo̱ni bi tsꞌe̱kꞌaꞌi ne bi thutꞌaꞌi har hoga njömdo̱ni, ter ñhembibi ꞌmu̱ da mhenga da thuta manꞌagi nuꞌu̱ xki bo̱hnu̱ mꞌe̱tꞌo.
\s1 Ya me Israel bi njoꞌspa yá ñho
\p 
\v 25 Tsi kuhu̱, di ne gi pöhu̱ nöꞌö himi fö mamꞌe̱tꞌo, ne hingi ꞌñexa ri nsuhu̱: Nuya me Israel bi gotꞌa yá mfeni ꞌra ya tsi pa, da do̱ꞌmi da yu̱tꞌa gatho nuꞌu̱ hingya xodyo ꞌbu̱ maꞌra ya ha̱i xi zu̱ ár nhwëki Jö.
\p 
\v 26 Mꞌe̱fa gatho ya me Israel ma da mpo̱ho̱, ngu enga har Tꞌofo:
\q1 Ma da zo̱ nꞌar ñönte di ꞌñe Sion,
\q1 ne da paxtꞌa nöꞌö xi ntsꞌotho ha yá ꞌbe̱to ar Hakob.
\q1 
\v 27 Njapꞌu̱ xta nkoꞌbe ma ga hökwa yá tsꞌoki,
\q1 ngu xta ñötꞌwabi.
\p 
\v 28 Nuyu̱, yá ñꞌu̱ni ar hoga mhö, njapu̱ xokꞌahu̱ ar goxthi da tsa̱ gi mpo̱hu̱. Ha Jö mödi, ngetho xki hwampa yá dada mamꞌe̱tꞌo.
\p 
\v 29 Ha nuyá ntꞌuni ne yá nzote o̱tꞌa Jö, hinda njapꞌu̱tho. Jö hingi pa̱ta ár ne.
\p 
\v 30 Nguꞌahu̱ mahamꞌu̱ hinge ngi o̱thu̱ Jö, ha nupya xka tsu̱hu̱ ár nhwëki, ngetho himbi ꞌyo̱tꞌu̱ Jö.
\p 
\v 31 Njanu̱pya ya me Israel hinxi ꞌyo̱ta Jöꞌu̱, njanu̱ da zu̱ꞌu̱ nunar nhwëki xi zu̱ꞌahu̱ nꞌehe.
\p 
\v 32 Ngetho Jö bi ꞌye̱ntꞌa gatho nda nme̱ꞌsku, ne mꞌe̱fa nda me̱ꞌspa ar nhwëki xo̱ge.
\p 
\v 33 Xa nze̱ye̱tho ár mfeni ne ár mfödi Jö. Hinjoꞌo togo da bödi tema ne da ꞌyo̱tꞌe. Hinjoꞌo togo da xetꞌwa yá ꞌñuꞌö.
\p 
\v 34 Ngetho, togo xi bötwa ár mfeni Jö, wa togo xi uta Jö tema da me̱fi.
\p 
\v 35 Hage ꞌbu̱ nꞌa togo te xi umba Jö mꞌe̱tꞌo, ne da koꞌspya.
\p 
\v 36 Ngetho gatho nöꞌö te ja, go ár me̱tiꞌö, go bi hyokꞌö ne ꞌbu̱i da me̱pabiꞌö. Go di ꞌñepabi hinda ntsa̱ya̱ da tꞌumba ar nsunda. Dá njapꞌu̱.
\c 12
\s1 Gehnu̱ xiñho da me̱ ya gamfi
\p 
\v 1 Jange tsi kuhu̱, di a̱ꞌahu̱ gi umfu̱ Jö xo̱ge ri ndoꞌyohu̱, ngu nꞌar mꞌo̱ñho̱ tetho, xintꞌaxi ne numañho Jö. Gehnu̱ ar mhatꞌajö di ꞌñepi gi ꞌyo̱thu̱, ngetho Jö xa xi utkagihu̱ ár nhwëki.
\p 
\v 2 Yo gi ñhogamu̱ihu̱ nöꞌö te ꞌraꞌahu̱ ar ximha̱i. Mahyoni gi nꞌaꞌyohu̱ ri ꞌraꞌyo mfenihu̱, ne njapꞌu̱ gi tsa̱se̱hu̱ tema ne Jö embi nza̱tho, numañho ne handi xiñho.
\p 
\v 3 Nuga xi hwëgagi ga pe̱pa ar tsi Hmu, jange di xiꞌahu̱, hinge xa di thotho gi ꞌñexa ri nsuhu̱. Nuhu̱ xiñho tema gi bense̱hu̱, ngu ár nze̱ye̱ ar ñꞌemu̱i xi hyeni xi ꞌraꞌahu̱ Jö, ngu ár ntꞌe̱niꞌö.
\p 
\v 4 Ngetho jangu ma ndoꞌyohu̱ pe̱ꞌsa nze̱ye̱ yá xe̱ni, ne hinga gatho getꞌar ꞌbe̱fi pe̱tsꞌi,
\p 
\v 5 di njahu̱pꞌu̱ nꞌehe. Mödi di nze̱ye̱hu̱, ꞌrangugihu̱ dár ndoꞌyohu̱ ar Hesukristo, ne di mfa̱xu̱ nꞌa ngu nꞌa.
\p 
\v 6 Nꞌañꞌo nꞌa ngu nꞌa ya hogantꞌuni xi hwëgagihu̱ Jö. Nuꞌmu̱ nꞌa xi tꞌumbabi ngu ár mꞌe̱hni Jö, dá me̱pabi ngu ár nze̱ye̱ ár ñꞌemu̱i pe̱tsꞌi.
\p 
\v 7 Ha nuꞌmu̱ xi thembabi da mꞌe̱go, dá ma̱xa maꞌra. Wa xi tꞌumbabi da ñꞌutate, dá uta maꞌra.
\p 
\v 8 Nöꞌö togo xi tꞌumbabi da hñuꞌmba yá mu̱i maꞌra, dá hñuꞌmba yá mu̱i. Wa xi tꞌumbabi da hyeni, dá me̱ꞌsa nꞌar hogamu̱i da ꞌyo̱tꞌe. Wa xi tꞌumbabi da ndö, dá umba ár mu̱i da ꞌyo̱tꞌe. Ha nöꞌö xi tꞌumbabi da ma̱xa togo honga ar mfa̱tsꞌi, di johya da ꞌyo̱tꞌe.
\p 
\v 9 Nöꞌö ar mhöte gi pe̱ꞌsu̱, xa majöni di ꞌñe ha ri mu̱ihu̱, hindi oxta mañö. U̱tsahu̱ nöꞌö hingi ho, te̱ñhu̱ nöꞌö xiñho.
\p 
\v 10 Mhöhu̱ nꞌa ngu nꞌa, gi pe̱ꞌsu̱ nꞌar hoga mhöte gar kuhu̱. Ne di ꞌbe̱nga ntꞌekꞌei gi zohu̱ maꞌra.
\p 
\v 11 Mpe̱hu̱ ntsꞌe̱di, yo gar döhñehu̱. Umba ri mu̱ihu̱ pe̱fu̱ ar tsi Hmu.
\p 
\v 12 Njohyahu̱ gi ndo̱ꞌmhu̱, tse̱thu̱ ya thogi, hingi hye̱hu̱ gi ꞌya̱fu̱ Jö.
\p 
\v 13 Ñhehwihu̱ maꞌra ya gamfi tho ar kꞌatꞌi, ne nzöihu̱ gi uñhu̱ ar se̱ki ha ri nguhu̱ da ñꞌoxa maꞌra.
\p 
\v 14 Mathwu̱ Jö nuꞌu̱ togo u̱tsaꞌihu̱. ꞌYa̱fu̱ ár ñho, yo gi a̱fu̱ nöꞌö hingi ho.
\p 
\v 15 Njohyawihu̱ nuꞌu̱ togo johya, ne nzongwihu̱ nuꞌu̱ togo zoni.
\p 
\v 16 Nꞌadar mfeni gi pe̱ꞌsu̱. Yo gar ñꞌetsꞌihu̱, ntsixkwihu̱ nuya tsi hyoya. Yo gi ꞌñexa ri nsuhu̱ xa gi pöhu̱.
\p 
\v 17 Yo gi koꞌspabihu̱ ár ñöni togo o̱tꞌahu̱ ar tsꞌoki. Umba ri mu̱ihu̱ da hyantꞌahu̱ ya jöꞌi gi o̱thu̱ ar ñho.
\p 
\v 18 Nöꞌö ꞌba̱ ri ñöni, umba ri mu̱ihu̱ gi ntsixkwi gatho ya jöꞌi nuꞌmu̱ da tsa̱.
\p 
\v 19 Tsi kuhu̱, yo gi ja ri ꞌye̱se̱ gi koꞌspa ár ñöni togo xi ꞌyo̱tꞌa nꞌar tsꞌoki. Tsokwabihu̱ ár tsi kwe̱ Jö, ngetho enga har Tꞌofo: Go ma me̱tiga ar nkoꞌsñöni, go di unga ar njutꞌi, enga ar tsi Hmu.
\p 
\v 20 Di xiꞌahu̱, nuꞌmu̱ ri ñꞌu̱nihu̱ tunthu, umbabihu̱ te da zi, ha nuꞌmu̱ tuthe, umfu̱ ar dehe. Nuꞌmu̱ gi japabihu̱ njapꞌu̱ ri ñꞌu̱nihu̱, hindi pödi ha da hwiꞌsa ár ñö di ntsa̱.
\p 
\v 21 Yo gi ñhe̱hu̱ da döꞌahu̱ ar tsꞌoki. Ju̱hu̱ ar ñho gi töhu̱.
\c 13
\p 
\v 1 Gatho ya jöꞌi dá ꞌyo̱ta ya tsꞌu̱tꞌwi, ngetho Jö go xi umbár nsu gatho nuꞌu̱ togo pe̱ꞌsar tsꞌe̱di. Gatho nuya jöꞌi pe̱ꞌsa yá nsu go xi ꞌñexꞌö.
\p 
\v 2 Jange gatho nuꞌu̱ hingi o̱ta ya tsꞌu̱tꞌwi, to̱xa nöꞌö xi hñuxa Jö, ne njapꞌu̱ muntsꞌase̱ ár mfe̱i da zu̱di.
\p 
\v 3 Ngetho nuya tsꞌu̱tꞌwi hinxi tꞌetsꞌi da pi nuꞌu̱ togo o̱tꞌa ar ñho, tsu nuꞌu̱ togo hingi o̱tꞌe xiñho. Nuꞌmu̱ hingi ne gi ꞌbu̱hu̱ gi tsuhu̱ ya tsꞌu̱tꞌwi, ꞌyo̱thu̱ nöꞌö xiñho, ne da tꞌesꞌa ri nsuhu̱.
\p 
\v 4 Ngetho yá ꞌbe̱go Jöꞌu̱, hoñꞌa ri ñhohu̱. Ha nuꞌmu̱ hingi o̱thu̱ nöꞌö xiñho, nuꞌmú̱ hö, gi ntsuhu̱. Ngetho hinga mꞌe̱tho hö ár ndo̱jwai, gehnu̱ ár ꞌbe̱go Jö da koꞌspa yá tsꞌoki ne da umbár mfe̱i ya tsꞌokte.
\p 
\v 5 Jange ꞌyo̱thu̱ ya tsꞌu̱tꞌwi, ne hinda mfe̱pꞌahu̱, ne hinte di tsu̱ꞌa ri mfenihu̱ nꞌehe.
\p 
\v 6 Jange gi juthu̱ ar bojö jotꞌa ya ndö, ngetho yá ꞌbe̱goyu̱ Jö, xi ꞌye̱ntyá te da me̱ nunar ꞌbe̱finu̱.
\p 
\v 7 Juthwu̱ gatho nuꞌu̱ togo gi tufu̱: nöꞌö ar bojö jotꞌa ya ndö, ne gatho maꞌra di ꞌñepꞌahu̱ gi juthwu̱. Togo mahyoni gi numañhohu̱, jahu̱pꞌu̱, ne togo di za̱ gi ꞌñeꞌsfu̱ ár nsu, ꞌyo̱thu̱ nꞌehe.
\p 
\v 8 Yo gi ñho̱xu̱ ya tha̱i. Nöꞌö gi ꞌyo̱thu̱, gi mhöhu̱ nꞌa ngu nꞌa. Ngetho nuꞌmu̱ gi möhu̱ ri ñꞌohu̱, gi o̱thu̱ ya ꞌbe̱pate mönga har Tꞌofo.
\p 
\v 9 Ngetho nu habu̱ enö: Hingi tsimba ár nthöti maꞌra, hingi mpë, hingi pe ya nhemhñö, hingi hyo̱kwa yá ñho ri ñꞌohu̱, ne maꞌra ya ꞌbe̱pate; gathoyu̱ da tsa̱ da txꞌu̱ki ho̱nse̱ da tꞌenö: Mö ri ñꞌohu̱ ngu gi mhöse̱.
\p 
\v 10 Nöꞌö togo möte, hingi tsꞌokwa yá ñꞌohu̱. Jange gatho ya ꞌbe̱pate go o̱tꞌa nöꞌö to möte.
\p 
\v 11 Jahu̱ njapꞌu̱, ne nuhu̱ ya pa di ꞌbu̱hu̱. Ma ga zo̱tꞌa ma da̱hu̱ ga he̱hu̱ ar tꞌöhö. Ngetho nupya hintsꞌu̱ yapꞌu̱ ꞌbu̱ ma mpo̱ho̱hu̱, ngu mi ꞌbu̱ núꞌmu̱ nda ñꞌemu̱ihu̱.
\p 
\v 12 Ya ꞌbu̱tho da göxar xui, ne xi ꞌñepꞌu̱tho ar hyatsꞌi. Jange ma ga he̱hu̱pꞌu̱ yá ꞌbe̱fi ar ꞌbe̱xui, ne ga hehu̱ ar he di bꞌu̱hu̱ har hyatsꞌi, ngu xi ñhoka nꞌar ndogu di ma har tuhni.
\p 
\v 13 Ma ga ꞌbu̱hu̱ di nheki di ꞌyohu̱ har hyatsꞌi, ga o̱thu̱ xiñho gatho. Hinga ꞌbu̱hu̱ hinte di ju̱ju̱ ha ya da̱ngo habu̱ xa ñuntho ne ntitho. Hinga ꞌbu̱hu̱ har hyo̱ka ꞌbe̱hñö ne nöꞌö xi ntsꞌotho. Hinga ntuñhu̱, ne hinga hyo̱kwabihu̱ yá ñho ma ñꞌohu̱.
\p 
\v 14 Ga ñhexu̱ ár tsꞌe̱di ar tsi Hmu Hesukristo, ne hinga ñhe̱hu̱ da kakagihu̱ nöꞌö te gatho bi e ha ma mfenihu̱.
\c 14
\s1 Nuꞌu̱ hingi tse̱di yá ñꞌemu̱i
\p 
\v 1 Yo gi ꞌweju̱ nuꞌu̱ ya ku hingi tse̱di yá ñꞌemu̱i, ne yo gi ñöniwi tema gi beñhu̱.
\p 
\v 2 Ngetho ꞌra beni tsa̱ da zi gatho, ha maꞌra hingi tse̱ yá ñꞌemu̱i, ho̱nse̱ tsi ya tsi kꞌani.
\p 
\v 3 Nöꞌö togo tsi gatho, yo ma da denga nöꞌö togo hingi tsi xo̱ge. Ha nunu̱, yo di thenga nöꞌö togo tsi, ngetho Jö go xi numañhoꞌö.
\p 
\v 4 Xi nuꞌge, ter me̱ꞌage gi themba ár ꞌbe̱go manꞌa. Ar hmu go da möñꞌö ha da nangi wa da da̱gi. Ha ma da nangi, ngetho döta ár tsꞌe̱di ar tsi Hmu togo da gu̱tsꞌi, ne hinda hye̱gi da da̱gi.
\p 
\v 5 ꞌRa handi xiñho da nhumansu ꞌra ya pa da me̱pa Jö, ha maꞌra handa gatho ya pa mahye̱tho. Nꞌa ngu nꞌa mahyoni da bödi tema pe̱fi.
\p 
\v 6 Nöꞌö togo hwahna ꞌra ya pa, e̱ntꞌwa ar tsi Hmu. Ha nöꞌö handa gatho ya pa mahye̱tho, njapꞌu̱tho nꞌehe. Nöꞌö tsi gatho, e̱ntꞌwa ar tsi Hmu ne umba njamödi. Ha nöꞌö hinga gatho tsi, njapꞌu̱tho nꞌehe umba njamödi Jö.
\p 
\v 7 Ngetho hinto di ꞌbu̱hu̱ ga pe̱pase̱ ma tehu̱, ha hinga tuhu̱ di honga ma ñhose̱hu̱.
\p 
\v 8 Nuꞌmu̱ di tehu̱, di e̱nthwu̱ ma tehu̱ ar tsi Hmu, ha nuꞌmu̱ ga tuhu̱, go di e̱ntꞌwabihu̱ꞌö nꞌehe. Jange nuꞌmu̱ di ꞌbu̱hu̱, wa xta tuhu̱, ár me̱tigihu̱ ar tsi Hmu.
\p 
\v 9 Jange bi du ar tsi Hmu ne bi nanga manꞌagi. Bi mengi bi nte, ne njapꞌu̱ bi hñutsꞌi ngu ár Hmu nuꞌu̱ te ne nuꞌu̱ xi du.
\p 
\v 10 Xi nuꞌge ꞌmu̱, yoꞌö gi thenga ri ku. Wa hinte gi nuge nöꞌö o̱tꞌö. Ha hingi pöhu̱, gatho ma ga ꞌba̱hu̱ da hñöskagihu̱ majöni ar tsi Hmu Hesukristo.
\p 
\v 11 Ngetho enga har Tꞌofo:
\q1 Nuga di ꞌbu̱i, enga njapꞌu̱ ar tsi Hmu, ne gatho ya jöꞌi ma da nda̱ndihmö da nsundagi,
\q1 ne da da̱majöniyu̱ dar Jöga.
\p 
\v 12 Nuꞌmú̱, nꞌa ngu nꞌa ma ga da̱thwu̱ majöni Jö gatho nöꞌö xta o̱thu̱.
\p 
\v 13 Jange hinga ma ga ntheñhu̱ nꞌa ngu nꞌa. Ma ga nkohu̱ ha ma mu̱ihu̱ hinga po̱jwu̱ ya mfetsꞌe da japi da da̱ ma kuhu̱.
\p 
\v 14 Nuga di pödi ne di ka̱xmbeni njapꞌu̱ benga ar tsi Hmu Hesukristo, ngetho hinte xintsꞌothose̱. Ha nuꞌmu̱ nꞌa beni xintsꞌotho, hö njapꞌu̱ hár mfeniꞌö.
\p 
\v 15 Ha nuꞌmu̱ nuna ri ñhuni tso̱tꞌwa ár mu̱i ri ku, hingi pe̱ꞌsa ar mhöte ꞌmu̱. Nuna ri ñhuni, yo ma da japa da mꞌe̱ ri ku, togo ar tsi Hmu Hesukristo bi ungár te bi po̱ho̱.
\p 
\v 16 Yo gi xoju̱ ar goxthi da nthenga nöꞌö gi beñhu̱ xiñho.
\p 
\v 17 Ngetho har tsꞌu̱tꞌwi Jö, hinge mꞌe̱tꞌo ya ñhuni wa ya tsꞌithe. Mꞌe̱tꞌo ar mꞌu̱i xintꞌaxi, ar hogamꞌu̱i, ne ar johya. Gathoyu̱ unga ár Hñö Jö.
\p 
\v 18 Nöꞌö togo pe̱pa ar tsi Hmu Hesukristo njanu̱, numañho Jö ne ya jöꞌi.
\p 
\v 19 Jange ma ga te̱ñhu̱ nor ñho unga ar hogamꞌu̱i, ne fa̱xkagihu̱ nꞌa ngu nꞌa da te ma ñꞌemu̱ihu̱.
\p 
\v 20 Yo gi jafu̱ ar ñhuni da hwatwa ár ꞌbe̱fi Jö. Mödi gatho nöꞌö te jawa xiñho da tsꞌi, nöꞌö hingi ho, nꞌar ku da japa ár ñꞌohu̱ da da̱gi ngetho te gatho tsi.
\p 
\v 21 Xiñho hingi tsa ar ngo̱, wa gi tsi ar ixkatꞌafi, nuꞌmu̱ gi japi da mfeꞌsa ri ku, gi tso̱tꞌwa ár mu̱i, wa da wentꞌa ár ñꞌemu̱i.
\p 
\v 22 Nuꞌmu̱ gi ñꞌemu̱i xiñho nöꞌö gi o̱tꞌe, ho̱nse̱ gi pöhwi Jö. Nza̱tho nöꞌö togo hinte tsu̱ ár mu̱i ngetho pödi xiñho nöꞌö o̱tꞌe.
\p 
\v 23 Ha nöꞌö yomi ha xiñho nöꞌö tsi, tuxar tsꞌoki, ngetho hingi ñꞌemu̱i xiñho nöꞌö o̱tꞌe. Ne gatho nöꞌö o̱tꞌe hingi ñꞌemu̱i, nunu̱ o̱tꞌar tsꞌoki.
\c 15
\p 
\v 1 Jange nuju̱ xi nze̱di ma ñꞌemu̱ihu̱, mahyoni ga pe̱ꞌsfu̱ ar tsꞌe̱ti ga fa̱xu̱ nuꞌu̱ togo hingi tse̱ yá ñꞌemu̱i, ne hinga honse̱ ma ñhohu̱.
\p 
\v 2 Ma ga hoñhu̱ nꞌa ngu nꞌa ár ñho ma ñꞌohu̱, ga fa̱xu̱ da no̱xka ár ñꞌemu̱i.
\p 
\v 3 Nunar tsi Hmu Hesukristo himbi hyonga ár ñhose̱, jange bi thoꞌö ngu enga har Tꞌofo: Go da nthe̱xꞌbe ya ntsꞌani mi tho̱xꞌaꞌi.
\p 
\v 4 Ngetho nuya Tꞌofo bi tꞌotꞌa mahamꞌu̱, xi tꞌotꞌi nda utkagihu̱ nda hñuxa ma ndo̱ꞌmihu̱, ga pe̱ꞌsu̱ ar humamu̱i ne ar tsꞌe̱ti mönga har Tꞌofo.
\p 
\v 5 Jö togo ár me̱ti ar tsꞌe̱ti ne ar humamu̱i, nꞌatꞌwu̱ da ꞌraꞌahu̱ nꞌadar mfeni nꞌa ngu nꞌa gi ꞌbu̱hu̱ xiñho, ngu benga ar tsi Hmu Hesukristo.
\p 
\v 6 Njapꞌu̱ nꞌadar mfeni ne nꞌadar mhö gi nsundabihu̱ Jö ár Dada ma tsi Hmuhu̱ Hesukristo.
\s1 Nuꞌu̱ hingya xodyo bi nsipa ar hoga mhö
\p 
\v 7 Uñhu̱ ar tsa̱ya̱ nꞌa ngu nꞌa, ngu ar tsi Hmu Hesukristo bi ꞌrakagihu̱ nꞌar hoga tsa̱ya̱, ne njapꞌu̱ da tꞌeꞌspa ár nsu Jö.
\p 
\v 8 Di xiꞌahu̱, nunar tsi Hmu Hesukristo ba e da me̱pa ya xodyo, ne njapꞌu̱ bi ñꞌudi mönga majöni Jö, ne o̱tꞌa gatho ngu xki ñötꞌwa ma palehu̱.
\p 
\v 9 Ne nuꞌu̱ hingya xodyo da nsundabi Jö da bötwa ár döta nhwëki, jangu enga har Tꞌofo:
\q1 Ga da̱twa majöni togoꞌi nuꞌu̱ hingya xodyo ꞌmu̱,
\q1 ne ga tútꞌa ri thuhu.
\p 
\v 10 Ne enö nꞌehe:
\q1 Nuꞌahu̱ hingya xodyohu̱, njohyawihu̱ ár hnini Jö.
\p 
\v 11 Ne pengi enö njawa:
\q1 Gathoꞌihu̱ hingya xodyohu̱, nsundahu̱ ar tsi Hmu.
\q1 Hö, nuꞌahu̱ gi ꞌbu̱hu̱ maꞌra ya ha̱i, ꞌñeꞌsfu̱ ár nsu.
\p 
\v 12 Ar mꞌe̱hni Isaia bi ꞌyotꞌa njawa nꞌehe.
\q1 Ar Isai ngu nꞌár ꞌba̱i nꞌar za ma da ꞌro nꞌár ꞌyu̱,
\q1 gehnu̱ di o hár ꞌye̱ nuꞌu̱ hingya xodyo.
\q1 Ja gehnu̱ togo ma da hñuxyá da̱.
\p 
\v 13 Ha nunar Jö togo unga ar ndo̱ꞌmi, xa da ꞌraꞌahu̱ ar johya ne ar hogamꞌu̱i ngetho gi ñꞌemu̱ihu̱. Ne da hñusꞌa ri ndo̱ꞌmihu̱ tsixꞌahu̱ ár tsꞌe̱di ár Hñö Jö.
\p 
\v 14 Ha nuga di ka̱xmbeni tsi kuhu̱, xa gi pe̱ꞌsu̱ ar hogamu̱i, ne hingi kꞌathu̱ ar mfödi gi hñuꞌmfu̱ ár mu̱i nꞌa ngu nꞌa ri kuhu̱.
\p 
\v 15 Tsi kuhu̱, xta otꞌahu̱ nunar he̱ꞌminu̱, jar xe̱ni xta topꞌahu̱, ngetho hindi ne gi pumhnihu̱. Xta otꞌa njapꞌu̱ ngu xi hwëga Jö ga o̱tꞌe.
\p 
\v 16 Dar ꞌbe̱go ar tsi Hmu Hesukristo, di xipa nuꞌu̱ hingya xodyo ár hoga mhö Jö. Di höꞌspa nunar hoga mhönu̱, ne njapꞌu̱ ga da̱twa Jö nuꞌu̱ hingya xodyo, ngu nꞌar mꞌo̱ñho̱ thandi xiñho xi xu̱ka ár Hñö Jö.
\p 
\v 17 Tsa̱hmö ga exa ma nsu, ngetho xi ma̱xkagi ar tsi Hmu Hesukristo xta mpe̱ hár ꞌbe̱fi Jö.
\p 
\v 18 Ngetho hinte manꞌa di ne ga mö, ho̱nse̱ nöꞌö xi ꞌyo̱tꞌa ar tsi Hmu ha ma ꞌye̱, njapꞌu̱ da tsꞌi nuꞌu̱ hingya xodyo da ꞌyo̱twa ár mhö. Gathoyu̱ xi njapꞌu̱ xi ꞌyo̱xꞌu̱ ar mhö xta xipabi, ne xi hyantꞌu̱ ar hogamꞌu̱i xta utwabi.
\p 
\v 19 Xi nheki ya döta ntꞌudi, ne ár tsꞌe̱di ár Hñö Jö, xi ma̱xkagi xi ꞌyo̱ ya me Herusalen ne gatho ár nthetꞌi. Da tso̱nga Iliriko habu̱ xa mi yapꞌu̱, gathonu̱ xta mömba ár hoga mhö ar tsi Hmu Hesukristo.
\p 
\v 20 Njanu̱ xa da umba ma mu̱i da mönga ar hoga mhö, hinge habu̱ xki mhömba ár thuhu ar tsi Hmu Hesukristo, ne hinge nga mfisꞌbe̱fiꞌbe maꞌra.
\p 
\v 21 Nöꞌö da pe̱fi, ngu enga har Tꞌofo:
\q1 Nuꞌu̱ togo hiñhamꞌu̱ xki nsipabi togoꞌö, ma da bödi.
\q1 Ha nuꞌu̱ hiñhamꞌu̱ xi ꞌyo̱de, ma da zo yá mfeni.
\s1 Ar Pablo ne da ma Nroma
\p 
\v 22 Hangu xta nemhö ma ga kꞌösꞌahu̱, ha nuya ꞌbe̱fiyu̱ xi kꞌaskagi ga mapꞌu̱.
\p 
\v 23 Ne nupya hindi pe̱ꞌsa maꞌra ya ꞌbe̱fi ha ya ha̱iyu̱, ha xta to̱ꞌma nze̱ye̱ ya je̱ye̱ di ne ga ꞌbu̱hwihu̱.
\p 
\v 24 Jange núꞌmu̱ xka ma España, ma ga thopꞌu̱tho. Di ne ga nuꞌahu̱, ne gi fa̱xkagihu̱ ga ju̱ ma ꞌñu manꞌagi xka jwahu̱ ga njohyahu̱.
\p 
\v 25 Nupya gar ma Herusalen, ma ga höꞌspa ár mfa̱tsꞌi mꞌe̱mpa ya gamfi bi ꞌbu̱hnu̱.
\p 
\v 26 Ngetho nuya ku me Nmasedonia ne Akaya, bi beñꞌu̱ xiñho nda me̱mpa nꞌar mfa̱tsꞌi nuꞌu̱ ya gamfi hyoya ꞌbu̱hnu̱ Herusalen.
\p 
\v 27 Nuya kuyu̱ bi numañho nda ꞌyo̱tꞌa njapꞌu̱, ne xiñho, ngetho po̱ntho tupabiꞌu̱. Nuꞌmu̱ ya xodyo bi mfa̱xkwi yá ñho umba Jö di ꞌñe mhetsꞌi, xiñho nuya hingya xodyo da ñhehwi yá ñho pe̱ꞌskwa har ximha̱i nꞌehe.
\p 
\v 28 Di xiꞌaꞌihu̱ ꞌmu̱, nu xka jwadi ga tso nunar mfa̱tsꞌinu̱, ga tso̱ñꞌahu̱ xka ma España.
\p 
\v 29 Di beni xka mapꞌu̱, ma ga hösꞌahu̱ ár ñho ár hoga mhö ar tsi Hmu Hesukristo, ne xa ga höñhu̱ ar njöpi.
\p 
\v 30 Di a̱ꞌahu̱ tsi kuhu̱, hár thuhu ar tsi Hmu Hesukristo ne hár mhöte ár Hñö Jö, gi fa̱xju̱ ga a̱fu̱ Jö da zixkagi xiñho,
\p 
\v 31 hinte da jakagi nuya hingi ñꞌemu̱i ꞌbu̱hnu̱ Nhudea. Ne nunar mfa̱tsꞌinu̱ bi tꞌakagi ga hötsꞌi, da numañho ya gamfi me Herusalen.
\p 
\v 32 Ne xa ga njohya ga tso̱ñꞌahu̱ nuꞌmu̱ njapꞌu̱ ne Jö, ne ga tsa̱ya̱wihu̱ mahye̱gi.
\p 
\v 33 Jö togo unga ar hogamꞌu̱i, gi ꞌbu̱hwihu̱ hyaxꞌmu̱. Da njapꞌu̱.
\c 16
\s1 Ar nze̱ngwa pe̱mpa nꞌa ngu nꞌa
\p 
\v 1 Di xiꞌahu̱, nunar ku Febe nꞌar hoga ku togo fa̱xte har nijö Nsenkrea.
\p 
\v 2 Umfu̱ nꞌar hoga tsa̱ya̱ ngu nꞌar gamfi xi ñꞌemu̱i ar tsi Hmu Hesukristo, ngetho njapꞌu̱ xiñho da ꞌyo̱tꞌa ya ku. Fa̱xu̱ ne umfu̱ gatho te kꞌatꞌi, ngetho nunu̱ xi ma̱xa nze̱ye̱. Gese̱gi xi ma̱xkagi nꞌehe.
\p 
\v 3 Ze̱ngwagihu̱pꞌu̱ ar ku Prisila ne ar ku Akila, togo xi ma̱xkagi hár ꞌbe̱fi ar tsi Hmu Hesukristo.
\p 
\v 4 Nuyu̱ bi ꞌye̱ntꞌa yá te bi ma̱xkagi, jange di umba njamödi. Hinge ho̱nse̱gi, gatho nuya nijö hingya xodyo umba njamödi nꞌehe.
\p 
\v 5 Ze̱ngwagihu̱ ya ku mhuntsꞌa ha yá nguyu̱, ne ma tsi hmöka ku Epeneto. Gehnu̱ mꞌe̱tꞌo bi ñꞌemu̱i ar tsi Hmu Hesukristo núnu̱ Akaya.
\p 
\v 6 Ze̱ngwagihu̱ ar ku Maria togo xa xi umba ár mu̱i xi ma̱xꞌahu̱.
\p 
\v 7 Ze̱ngwagihu̱ ar ku Androniko ne ar ku Hunias, po̱ntho ma mëni ne ma ñꞌohu̱ har fa̱di. Gehyu̱ xi nu xiñho ya mpo̱te, ne bi dökagi mꞌe̱tꞌo bi ñꞌemu̱iyu̱ ar tsi Hmu Hesukristo.
\p 
\v 8 Ze̱ngwagihu̱ ar Amplia, ma tsi hmöka ku xta jamfihe ar tsi Hmu.
\p 
\v 9 Ze̱ngwagihu̱ ar ku Urbano ma ma̱xte hár ꞌbe̱fi ar tsi Hmu Hesukristo, ne ze̱ngwagihu̱ ma hmöka ku Estaki.
\p 
\v 10 Ze̱ngwagihu̱ ar Apele togo bi ze̱ta ya thogi te̱nga ar tsi Hmu Hesukristo. Ze̱ngwagihu̱ nuꞌu̱ ꞌbu̱ hár ngu ar Aristobulo.
\p 
\v 11 Ze̱ngwagihu̱ ar Erodion togo po̱ni ma mëni. Ze̱ngwagihu̱ nuꞌu̱ ꞌbu̱ hár ngu ar Xixo xi ñꞌemu̱i ar tsi Hmu.
\p 
\v 12 Ze̱ngwagihu̱ ar ku Trifena ne ar ku Trifosa, togo mpe̱ hár ꞌbe̱fi ar tsi Dada. Ze̱ngwagihu̱ ar hmöka ku Persida togo xa xi me̱pabi ar tsi Hmu.
\p 
\v 13 Ze̱ngwagihu̱ ar ku Rufo, nza̱da ár mꞌu̱i ñꞌowi ar tsi Hmu. Ze̱ngwabihu̱ ár nönö, po̱ntho ma nönöga nꞌehe.
\p 
\v 14 Ze̱ngwagihu̱ ar ku Asinkrito, ar ku Fregonte, ar ku Herma, ar ku Patroba, ar ku Herme ne gatho ya ku ꞌbu̱hwinu̱.
\p 
\v 15 Ze̱ngwagihu̱ ar ku Filologo, ar ku Hulia, ar ku Nereo ne ár njupꞌu̱, ar ku Olimpa ne gatho ya ku mhuskwinu̱.
\p 
\v 16 Ne uñhu̱ nꞌar ñhu̱fi nꞌa ngu nꞌa dar ntꞌaxi ri mfenihu̱. Di ze̱ngwaꞌihe gatho nuyá nijögihu̱ ar tsi Hmu Hesukristo.
\p 
\v 17 Tsi kuhu̱, di a̱ꞌahu̱ gi hyanthu̱ xiñho togo heka ya ku, ne japi da da̱gi uta maꞌra ya mfeni, tsꞌoka ar hoga ntꞌuti xka pöhu̱. Nu xki pöhu̱ togoꞌu̱, ꞌwehu̱.
\p 
\v 18 Ngetho nuya jöꞌiyu̱ hingi pe̱pa ar tsi Hmu Hesukristo. Pe̱pase̱ yá mu̱i, ne xa nza̱da yá ne ka nuꞌu̱ o̱xa gatho nöꞌö nsipabi.
\p 
\v 19 Gatho pödi xa gi o̱thwu̱ ár mhö Jö, jange xa di johya. Ne di ne gi pöhu̱ xiñho gi te̱ñhu̱ ar ñho, ne hingi jafu̱masu nöꞌö xintsꞌotho.
\p 
\v 20 Jö togo unga ar hogamꞌu̱i, ngutꞌa ma da ze̱ꞌma ar tsꞌondöhi ha ri wahu̱. Ar tsi Hmu Hesukristo da hwëkꞌahu̱ ár ntꞌuni.
\p 
\v 21 Pe̱ñꞌaꞌihu̱ ar nze̱ngwa ar ku Timoteo ma ma̱xte, ne nuya po̱ntho ma mëni, ar ku Lusio, ar ku Hason, ne ar ku Sosipater.
\p 
\v 22 Nuga, ar ku Tersio togo di fa̱xa ar ku Pablo, di otꞌa nunar he̱ꞌminu̱, di ze̱ngwaꞌihu̱ ngetho xta ñꞌemu̱i ar tsi Hmu nꞌehe.
\p 
\v 23 Ze̱ngwaꞌihu̱ ar ku Gayo togo ꞌraka ar se̱ki di kokwa hár ngu, ne ka mhunskwa ar nijö nꞌehe. Ze̱ngwaꞌihu̱ ar ku Erasto togo tsixa ár bojö ar hnini. Ar ku Kuarto ze̱ngwaꞌihu̱ nꞌehe.
\p 
\v 24 Dá hwëkꞌahu̱ gathoꞌihu̱ ár ntꞌuni ar tsi Hmu Hesukristo. Dá njapꞌu̱.
\s1 Ya ngöxa mhö tꞌeꞌspa ár nsu Jö
\p 
\v 25 Nsunda Jö togo tsa̱ da ze̱ta ri ñꞌemu̱ihu̱, ngu enga ar hoga mhö di mönga, ne nunar ntꞌuti no̱nga ar tsi Hmu Hesukristo. Xi tꞌutkagihu̱pya nöꞌö mi ꞌbu̱i xki joꞌmtho núꞌmu̱ hinxki thokta ar ximha̱i.
\p 
\v 26 Ha nupya xi zu̱kagihu̱ nöꞌö xi ꞌyotꞌa ya mꞌe̱hni nda thogi, ngu xki mönga Jö togo hö ar te. Ne njapꞌu̱ xi nu̱nga ha gatho ya ha̱i, ne nda e ya jöꞌi nda ñꞌemu̱i ne nda ꞌyo̱te.
\p 
\v 27 Nöꞌö ho̱nse̱ nꞌa Jö ꞌbu̱i, ne ár me̱ti ar mfödi. Hinda ntsa̱ya̱ da hñönga ar nsunda xi döpa ar tsi Hmu Hesukristo. Dá njapꞌu̱.
