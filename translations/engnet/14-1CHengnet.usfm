\v 35 \w son|strong="H1121"\w* \w of|strong="H1121"\w* Zuph, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Elkanah, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Mahath, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Amasai,
\v 36 \w son|strong="H1121"\w* \w of|strong="H1121"\w* Elkanah, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Joel, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Azariah, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Zephaniah,
\v 37 \w son|strong="H1121"\w* \w of|strong="H1121"\w* Tahath, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Assir, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Ebiasaph, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Korah,
\v 38 \w son|strong="H1121"\w* \w of|strong="H1121"\w* Izhar, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Kohath, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Levi, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Israel.
\p 
\v 39 Serving beside \w him|strong="H1121"\w* \w was|strong="H1961"\w* \w his|strong="H1961"\w* \w fellow|strong="H1121"\w* Levite Asaph, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Berechiah, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Shimea,
\v 40 son \w of|strong="H5439"\w* Michael, son \w of|strong="H5439"\w* Baaseiah, son \w of|strong="H5439"\w* Malkijah,
\v 41 \w son|strong="H1121"\w* \w of|strong="H1121"\w* Ethni, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Zerah, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Adaiah,
\v 42 \w son|strong="H1121"\w* \w of|strong="H1121"\w* Ethan, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Zimmah, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Shimei,
\v 43 son \w of|strong="H4054"\w* Jahath, son \w of|strong="H4054"\w* Gershom, son \w of|strong="H4054"\w* Levi.
\p 
\v 44 Serving beside them \w were|strong="H1053"\w* their fellow Levites, the descendants \w of|strong="H4054"\w* Merari, led by Ethan, son \w of|strong="H4054"\w* Kishi, son \w of|strong="H4054"\w* Abdi, son \w of|strong="H4054"\w* Malluch,
\v 45 son \w of|strong="H4294"\w* Hashabiah, son \w of|strong="H4294"\w* Amaziah, son \w of|strong="H4294"\w* Hilkiah,
\v 46 \w son|strong="H1121"\w* \w of|strong="H1121"\w* Amzi, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Bani, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Shemer,
\v 47 \w son|strong="H1121"\w* \w of|strong="H1121"\w* Mahli, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Mushi, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Merari, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Levi.
\p 
\v 48 \w The|strong="H1121"\w* rest \w of|strong="H1121"\w* \w their|strong="H8147"\w* \w fellow|strong="H1121"\w* \w Levites|strong="H1121"\w* \w were|strong="H1121"\w* assigned \w to|strong="H1121"\w* perform \w the|strong="H1121"\w* remaining tasks \w at|strong="H1121"\w* God’s sanctuary.
\v 49 \w But|strong="H3881"\w* Aaron \w and|strong="H1121"\w* \w his|strong="H5414"\w* \w descendants|strong="H1121"\w* \w offered|strong="H5414"\w* sacrifices \w on|strong="H5892"\w* \w the|strong="H5414"\w* altar \w for|strong="H1121"\w* burnt \w offerings|strong="H3478"\w* \w and|strong="H1121"\w* \w on|strong="H5892"\w* \w the|strong="H5414"\w* altar \w for|strong="H1121"\w* incense \w as|strong="H5892"\w* \w they|strong="H3478"\w* \w had|strong="H3478"\w* been \w assigned|strong="H5414"\w* \w to|strong="H3478"\w* do \w in|strong="H3478"\w* \w the|strong="H5414"\w* most holy sanctuary. \w They|strong="H3478"\w* \w made|strong="H5414"\w* atonement \w for|strong="H1121"\w* \w Israel|strong="H3478"\w*, just \w as|strong="H5892"\w* \w God|strong="H5414"\w*’s servant \w Moses|strong="H5414"\w* \w had|strong="H3478"\w* ordered.
\p 
\v 50 \w These|strong="H7121"\w* \w were|strong="H1121"\w* \w the|strong="H5414"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* Aaron:
\p \w His|strong="H5414"\w* \w son|strong="H1121"\w* Eleazar, \w his|strong="H5414"\w* \w son|strong="H1121"\w* Phinehas, \w his|strong="H5414"\w* \w son|strong="H1121"\w* Abishua,
\v 51 \w his|strong="H1961"\w* \w son|strong="H1121"\w* Bukki, \w his|strong="H1961"\w* \w son|strong="H1121"\w* Uzzi, \w his|strong="H1961"\w* \w son|strong="H1121"\w* Zerahiah,
\v 52 \w his|strong="H5414"\w* son Meraioth, \w his|strong="H5414"\w* son Amariah, \w his|strong="H5414"\w* son Ahitub,
\v 53 his son Zadok, \w and|strong="H4054"\w* his son Ahimaaz.
\p 
\v 54 These were the \w areas|strong="H4054"\w* where Aaron’s descendants lived:
\p The following belonged to the Kohathite clan, for they received the first allotment:
\p 
\v 55 They \w were|strong="H1121"\w* allotted Hebron \w in|strong="H1121"\w* \w the|strong="H1121"\w* territory \w of|strong="H1121"\w* Judah, \w as|strong="H1121"\w* well \w as|strong="H1121"\w* its surrounding \w pasturelands|strong="H4054"\w*.
\v 56 (But \w the|strong="H2677"\w* city’s \w land|strong="H4940"\w* \w and|strong="H1121"\w* nearby towns \w were|strong="H1121"\w* allotted \w to|strong="H1121"\w* Caleb \w son|strong="H1121"\w* \w of|strong="H1121"\w* Jephunneh.)
\v 57 \w The|strong="H3485"\w* descendants \w of|strong="H4294"\w* Aaron \w were|strong="H4294"\w* also allotted as cities \w of|strong="H4294"\w* refuge Hebron, Libnah \w and|strong="H4054"\w* its \w pasturelands|strong="H4054"\w*, Jattir, Eshtemoa \w and|strong="H4054"\w* its \w pasturelands|strong="H4054"\w*,
\v 58 Hilez \w and|strong="H4054"\w* its \w pasturelands|strong="H4054"\w*, Debir \w and|strong="H4054"\w* its \w pasturelands|strong="H4054"\w*,
\v 59 Ashan \w and|strong="H4054"\w* its \w pasturelands|strong="H4054"\w*, \w and|strong="H4054"\w* Beth Shemesh \w and|strong="H4054"\w* its \w pasturelands|strong="H4054"\w*.
\p 
\v 60 Within the territory \w of|strong="H4054"\w* the tribe \w of|strong="H4054"\w* Benjamin they were allotted Geba \w and|strong="H4054"\w* its \w pasturelands|strong="H4054"\w*, Alemeth \w and|strong="H4054"\w* its \w pasturelands|strong="H4054"\w*, \w and|strong="H4054"\w* Anathoth \w and|strong="H4054"\w* its \w pasturelands|strong="H4054"\w*. Their clans were allotted thirteen cities \w in|strong="H4054"\w* all.
\v 61 \w The|strong="H4294"\w* rest \w of|strong="H4294"\w* Kohath’s descendants \w were|strong="H4294"\w* allotted ten cities \w in|strong="H6943"\w* \w the|strong="H4294"\w* territory \w of|strong="H4294"\w* \w the|strong="H4294"\w* half-tribe \w of|strong="H4294"\w* Manasseh.
\p 
\v 62 \w The|strong="H1121"\w* clans \w of|strong="H1121"\w* Gershom’s \w descendants|strong="H1121"\w* \w received|strong="H3498"\w* thirteen cities within \w the|strong="H1121"\w* territory \w of|strong="H1121"\w* \w the|strong="H1121"\w* \w tribes|strong="H4294"\w* \w of|strong="H1121"\w* Issachar, Asher, Naphtali, \w and|strong="H1121"\w* Manasseh (\w in|strong="H1121"\w* Bashan).
\p 
\v 63 \w The|strong="H5676"\w* clans \w of|strong="H4294"\w* Merari’s descendants \w were|strong="H3383"\w* allotted twelve cities within \w the|strong="H5676"\w* territory \w of|strong="H4294"\w* \w the|strong="H5676"\w* \w tribes|strong="H4294"\w* \w of|strong="H4294"\w* \w Reuben|strong="H7205"\w*, Gad, \w and|strong="H4054"\w* Zebulun.
\p 
\v 64 So the Israelites gave \w to|strong="H6932"\w* the Levites these cities \w and|strong="H4054"\w* their \w pasturelands|strong="H4054"\w*.
\v 65 They allotted these previously named cities \w from|strong="H4294"\w* \w the|strong="H1410"\w* territory \w of|strong="H4294"\w* \w the|strong="H1410"\w* \w tribes|strong="H4294"\w* \w of|strong="H4294"\w* Judah, Simeon, \w and|strong="H4054"\w* Benjamin.
\p 
\v 66 \w The|strong="H3270"\w* clans \w of|strong="H4054"\w* Kohath’s descendants also received territory within \w the|strong="H3270"\w* tribe \w of|strong="H4054"\w* Ephraim.
\v 67 They were allotted as cities of refuge Shechem and its pasturelands (in the hill country of Ephraim), Gezer and its pasturelands,
\v 68 Jokmeam and its pasturelands, Beth Horon and its pasturelands,
\v 69 Aijalon and its pasturelands, and Gath Rimmon and its pasturelands.
\p 
\v 70 Within the territory of the half-tribe of Manasseh, the rest of Kohath’s descendants received Aner and its pasturelands and Bileam and its pasturelands.
\p 
\v 71 The following belonged to Gershom’s descendants:
\p Within the territory of the half-tribe of Manasseh: Golan in Bashan and its pasturelands and Ashtaroth and its pasturelands.
\p 
\v 72 Within the territory of the tribe of Issachar: Kedesh and its pasturelands, Daberath and its pasturelands,
\v 73 Ramoth and its pasturelands, and Anem and its pasturelands.
\p 
\v 74 Within the territory of the tribe of Asher: Mashal and its pasturelands, Abdon and its pasturelands,
\v 75 Hukok and its pasturelands, and Rehob and its pasturelands.
\p 
\v 76 Within the territory of the tribe of Naphtali: Kedesh in Galilee and its pasturelands, Hammon and its pasturelands, and Kiriathaim and its pasturelands.
\p 
\v 77 The following belonged to the rest of Merari’s descendants:
\p Within the territory of the tribe of Zebulun: Rimmono and its pasturelands, and Tabor and its pasturelands.
\p 
\v 78 Within the territory of the tribe of Reuben across the Jordan River east of Jericho: Bezer in the desert and its pasturelands, Jahzah and its pasturelands,
\v 79 Kedemoth and its pasturelands, and Mephaath and its pasturelands.
\p 
\v 80 Within the territory of the tribe of Gad: Ramoth in Gilead and its pasturelands, Mahanaim and its pasturelands,
\v 81 Heshbon and its pasturelands, and Jazer and its pasturelands.
\c 7
\p 
\v 1 \w The|strong="H1121"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Issachar|strong="H3485"\w*:
\p \w Tola|strong="H8439"\w*, \w Puah|strong="H6312"\w*, \w Jashub|strong="H3437"\w*, \w and|strong="H1121"\w* \w Shimron|strong="H8110"\w* – four \w in|strong="H1121"\w* all.
\p 
\v 2 \w The|strong="H3117"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Tola|strong="H8439"\w*:
\p \w Uzzi|strong="H5813"\w*, \w Rephaiah|strong="H7509"\w*, \w Jeriel|strong="H3400"\w*, \w Jahmai|strong="H3181"\w*, \w Jibsam|strong="H3005"\w*, \w and|strong="H3967"\w* \w Samuel|strong="H8050"\w*. \w They|strong="H3117"\w* \w were|strong="H1121"\w* \w leaders|strong="H7218"\w* \w of|strong="H1121"\w* \w their|strong="H3117"\w* \w families|strong="H1004"\w*. \w In|strong="H1004"\w* \w the|strong="H3117"\w* \w time|strong="H3117"\w* \w of|strong="H1121"\w* \w David|strong="H1732"\w* \w there|strong="H3117"\w* \w were|strong="H1121"\w* 22,600 \w warriors|strong="H1368"\w* \w listed|strong="H4557"\w* \w in|strong="H1004"\w* \w Tola|strong="H8439"\w*’s \w genealogical|strong="H8435"\w* records.
\p 
\v 3 \w The|strong="H3605"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Uzzi|strong="H5813"\w*:
\p \w Izrachiah|strong="H3156"\w*.
\p \w The|strong="H3605"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Izrahiah|strong="H3156"\w*:
\p \w Michael|strong="H4317"\w*, \w Obadiah|strong="H5662"\w*, \w Joel|strong="H3100"\w*, \w and|strong="H1121"\w* \w Isshiah|strong="H3449"\w*. \w All|strong="H3605"\w* \w five|strong="H2568"\w* \w were|strong="H1121"\w* \w leaders|strong="H7218"\w*.
\p 
\v 4 \w According|strong="H5921"\w* \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w genealogical|strong="H8435"\w* records \w of|strong="H1121"\w* \w their|strong="H5921"\w* \w families|strong="H1004"\w*, \w they|strong="H3588"\w* \w had|strong="H3588"\w* 36,000 \w warriors|strong="H4421"\w* available \w for|strong="H3588"\w* \w battle|strong="H4421"\w*, \w for|strong="H3588"\w* \w they|strong="H3588"\w* \w had|strong="H3588"\w* \w numerous|strong="H7235"\w* wives \w and|strong="H1121"\w* \w sons|strong="H1121"\w*.
\v 5 \w Altogether|strong="H3605"\w* \w the|strong="H3605"\w* \w genealogical|strong="H3187"\w* records \w of|strong="H1368"\w* \w the|strong="H3605"\w* \w clans|strong="H4940"\w* \w of|strong="H1368"\w* \w Issachar|strong="H3485"\w* \w listed|strong="H3187"\w* 87,000 \w warriors|strong="H1368"\w*.
\s1 Benjamin’s Descendants
\p 
\v 6 \w The|strong="H3043"\w* sons \w of|strong="H1144"\w* \w Benjamin|strong="H1144"\w*:
\p \w Bela|strong="H1106"\w*, \w Beker|strong="H1071"\w*, \w and|strong="H1144"\w* \w Jediael|strong="H3043"\w* – \w three|strong="H7969"\w* \w in|strong="H1144"\w* all.
\p 
\v 7 \w The|strong="H1121"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Bela|strong="H1106"\w*:
\p Ezbon, \w Uzzi|strong="H5813"\w*, \w Uzziel|strong="H5816"\w*, \w Jerimoth|strong="H3406"\w*, \w and|strong="H1121"\w* \w Iri|strong="H5901"\w*. \w The|strong="H1121"\w* \w five|strong="H2568"\w* \w of|strong="H1121"\w* \w them|strong="H8147"\w* \w were|strong="H1121"\w* \w leaders|strong="H7218"\w* \w of|strong="H1121"\w* \w their|strong="H8147"\w* \w families|strong="H1004"\w*. There \w were|strong="H1121"\w* 22,034 \w warriors|strong="H1368"\w* \w listed|strong="H3187"\w* \w in|strong="H1004"\w* \w their|strong="H8147"\w* \w genealogical|strong="H3187"\w* records.
\p 
\v 8 \w The|strong="H3605"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Beker|strong="H1071"\w*:
\p \w Zemirah|strong="H2160"\w*, \w Joash|strong="H3135"\w*, Eliezer, Elioenai, \w Omri|strong="H6018"\w*, \w Jeremoth|strong="H3406"\w*, Abijah, \w Anathoth|strong="H6068"\w*, \w and|strong="H1121"\w* \w Alameth|strong="H5964"\w*. \w All|strong="H3605"\w* \w these|strong="H3605"\w* \w were|strong="H1121"\w* \w the|strong="H3605"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Beker|strong="H1071"\w*.
\v 9 There \w were|strong="H2428"\w* 20,200 \w family|strong="H1004"\w* \w leaders|strong="H7218"\w* \w and|strong="H3967"\w* \w warriors|strong="H1368"\w* \w listed|strong="H3187"\w* \w in|strong="H1004"\w* their \w genealogical|strong="H8435"\w* records.
\p 
\v 10 \w The|strong="H1121"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jediael|strong="H3043"\w*:
\p \w Bilhan|strong="H1092"\w*.
\p \w The|strong="H1121"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Bilhan|strong="H1092"\w*:
\p \w Jeush|strong="H3266"\w*, \w Benjamin|strong="H1144"\w*, Ehud, \w Kenaanah|strong="H3668"\w*, \w Zethan|strong="H2133"\w*, \w Tarshish|strong="H8659"\w*, \w and|strong="H1121"\w* Ahishahar.
\v 11 \w All|strong="H3605"\w* \w these|strong="H3605"\w* \w were|strong="H1121"\w* \w the|strong="H3605"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Jediael|strong="H3043"\w*. Listed \w in|strong="H4421"\w* \w their|strong="H3605"\w* genealogical records \w were|strong="H1121"\w* 17,200 family \w leaders|strong="H7218"\w* \w and|strong="H3967"\w* \w warriors|strong="H1368"\w* \w who|strong="H3605"\w* \w were|strong="H1121"\w* \w capable|strong="H2428"\w* \w of|strong="H1121"\w* marching \w out|strong="H3318"\w* \w to|strong="H3318"\w* \w battle|strong="H4421"\w*.
\p 
\v 12 \w The|strong="H1121"\w* Shuppites \w and|strong="H1121"\w* Huppites \w were|strong="H1121"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Ir|strong="H5893"\w*; \w the|strong="H1121"\w* Hushites \w were|strong="H1121"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* Aher.
\s1 Naphtali’s Descendants
\p 
\v 13 \w The|strong="H7967"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Naphtali|strong="H5321"\w*:
\p \w Jahziel|strong="H3185"\w*, \w Guni|strong="H1476"\w*, \w Jezer|strong="H3337"\w*, \w and|strong="H1121"\w* \w Shallum|strong="H7967"\w* – \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Bilhah|strong="H1090"\w*.
\s1 Manasseh’s Descendants
\p 
\v 14 \w The|strong="H3205"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Manasseh|strong="H4519"\w*:
\p Asriel, \w who|strong="H1121"\w* \w was|strong="H1121"\w* \w born|strong="H3205"\w* \w to|strong="H3205"\w* \w Manasseh|strong="H4519"\w*’s Aramean \w concubine|strong="H6370"\w*. She \w also|strong="H3205"\w* \w gave|strong="H3205"\w* \w birth|strong="H3205"\w* \w to|strong="H3205"\w* \w Makir|strong="H4353"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H1121"\w* \w Gilead|strong="H1568"\w*.
\v 15 \w Now|strong="H1961"\w* \w Makir|strong="H4353"\w* \w married|strong="H3947"\w* \w a|strong="H3068"\w* wife \w from|strong="H3947"\w* \w the|strong="H3947"\w* Huppites \w and|strong="H1323"\w* Shuppites. (\w His|strong="H3947"\w* sister’s \w name|strong="H8034"\w* \w was|strong="H8034"\w* \w Maacah|strong="H4601"\w*.)
\p \w Zelophehad|strong="H6765"\w* \w was|strong="H8034"\w* Manasseh’s \w second|strong="H8145"\w* son; \w he|strong="H3947"\w* \w had|strong="H1961"\w* only \w daughters|strong="H1323"\w*.
\p 
\v 16 \w Maacah|strong="H4601"\w*, \w Makir|strong="H4353"\w*’s wife, \w gave|strong="H3205"\w* \w birth|strong="H3205"\w* \w to|strong="H3205"\w* \w a|strong="H3068"\w* \w son|strong="H1121"\w*, \w whom|strong="H7121"\w* \w she|strong="H7121"\w* \w named|strong="H7121"\w* \w Peresh|strong="H6570"\w*. \w His|strong="H7121"\w* brother \w was|strong="H8034"\w* \w Sheresh|strong="H8329"\w*, \w and|strong="H1121"\w* \w his|strong="H7121"\w* \w sons|strong="H1121"\w* \w were|strong="H1121"\w* Ulam \w and|strong="H1121"\w* \w Rekem|strong="H7552"\w*.
\p 
\v 17 \w The|strong="H4353"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Ulam:
\p Bedan.
\p These \w were|strong="H1121"\w* \w the|strong="H4353"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Gilead|strong="H1568"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Makir|strong="H4353"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Manasseh|strong="H4519"\w*.
\v 18 \w His|strong="H3205"\w* sister \w Hammoleketh|strong="H4447"\w* \w gave|strong="H3205"\w* \w birth|strong="H3205"\w* \w to|strong="H3205"\w* Ishhod, Abiezer, \w and|strong="H3205"\w* \w Mahlah|strong="H4244"\w*.
\p 
\v 19 \w The|strong="H1961"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Shemida|strong="H8061"\w* \w were|strong="H1961"\w* Ahian, \w Shechem|strong="H7928"\w*, \w Likhi|strong="H3949"\w*, \w and|strong="H1121"\w* Aniam.
\s1 Ephraim’s Descendants
