\toc1 Nehemías
\mt1 Nehemías
\c 1
\s1 Oración de Nehemías
\p 
\v 1 \w Palabras|strong="H1697"\w* \w de|strong="H1121"\w* \w Nehemías|strong="H5166"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Hacalías.
\p \w Aconteció|strong="H1961"\w* \w el|strong="H1121"\w* \w mes|strong="H2320"\w* \w de|strong="H1121"\w* Kislev del \w año|strong="H8141"\w* 20, \w que|strong="H1697"\w* \w cuando|strong="H1961"\w* yo \w estaba|strong="H1961"\w* en Susa, la ciudadela,
\v 2 llegó \w Hanani|strong="H2607"\w*, uno \w de|strong="H4480"\w* mis hermanos, \w con|strong="H5921"\w* algunos hombres \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*.
\p \w Les|strong="H5921"\w* \w pregunté|strong="H7592"\w* \w acerca|strong="H5921"\w* \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w judíos|strong="H3064"\w* \w que|strong="H4480"\w* escaparon, sobrevivientes \w del|strong="H4480"\w* \w cautiverio|strong="H7628"\w*, \w y|strong="H5921"\w* \w acerca|strong="H5921"\w* \w de|strong="H4480"\w* Jerusalén.
\p 
\v 3 \w Me|strong="H4480"\w* dijeron: Los \w del|strong="H4480"\w* remanente \w que|strong="H4480"\w* quedan \w de|strong="H4480"\w* la cautividad \w allí|strong="H8033"\w* \w en|strong="H4480"\w* la \w provincia|strong="H4082"\w* están \w en|strong="H4480"\w* \w gran|strong="H1419"\w* angustia y humillación. El \w muro|strong="H2346"\w* \w de|strong="H4480"\w* Jerusalén \w está|strong="H8033"\w* lleno \w de|strong="H4480"\w* brechas y sus \w puertas|strong="H8179"\w* fueron devastadas \w por|strong="H4480"\w* el fuego.
\p 
\v 4 \w Cuando|strong="H3117"\w* \w oí|strong="H8085"\w* estas \w palabras|strong="H1697"\w* me senté, \w lloré|strong="H1058"\w* \w e|strong="H3068"\w* hice duelo \w por|strong="H1697"\w* algunos \w días|strong="H3117"\w*. Ayuné y \w oré|strong="H6419"\w* \w ante|strong="H6440"\w* \w el|strong="H3427"\w* \nd ʼElohim\nd* del \w cielo|strong="H8064"\w*.
\p 
\v 5 Exclamé: ¡Ay \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* del \w cielo|strong="H8064"\w*! \w Grande|strong="H1419"\w* y \w terrible|strong="H3372"\w* \nd ʼElohim\nd*, Quien \w guarda|strong="H8104"\w* el \w Pacto|strong="H1285"\w* y \w la|strong="H8104"\w* \w misericordia|strong="H2617"\w* \w a|strong="H3068"\w* los que lo aman y \w guardan|strong="H8104"\w* sus \w Mandamientos|strong="H4687"\w*:
\v 6 \w Esté|strong="H1961"\w* \w ahora|strong="H4994"\w* \w atento|strong="H7183"\w* tu \w oído|strong="H8085"\w* \w y|strong="H5921"\w* tus \w ojos|strong="H5869"\w* \w abiertos|strong="H6605"\w*, \w para|strong="H5921"\w* \w escuchar|strong="H8085"\w* \w la|strong="H5921"\w* \w oración|strong="H8605"\w* \w de|strong="H5921"\w* tu esclavo, \w que|strong="H4994"\w* \w hago|strong="H6419"\w* \w día|strong="H3117"\w* \w y|strong="H5921"\w* \w noche|strong="H3915"\w* \w ante|strong="H6440"\w* \w Ti|strong="H5921"\w* \w por|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, tus esclavos, \w y|strong="H5921"\w* \w confieso|strong="H3034"\w* \w los|strong="H1121"\w* \w pecados|strong="H2403"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w que|strong="H4994"\w* cometimos \w contra|strong="H5921"\w* \w Ti|strong="H5921"\w*. ¡\w Sí|strong="H6440"\w*, \w yo|strong="H4994"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* padre \w pecamos|strong="H2398"\w*!
\v 7 Nos corrompimos en extremo ante Ti, al \w no|strong="H3808"\w* \w guardar|strong="H8104"\w* los \w Mandamientos|strong="H4687"\w*, \w ni|strong="H3808"\w* los \w Estatutos|strong="H2706"\w* \w ni|strong="H3808"\w* los Preceptos \w que|strong="H3808"\w* Tú dictaste \w a|strong="H3068"\w* tu esclavo \w Moisés|strong="H4872"\w*.
\p 
\v 8 Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* te acuerdes \w de|strong="H5971"\w* la \w Palabra|strong="H1697"\w* \w que|strong="H4994"\w* Tú \w ordenaste|strong="H6680"\w* \w a|strong="H3068"\w* tu esclavo \w Moisés|strong="H4872"\w*, al decir: \wj \w Si|strong="H4994"\w* ustedes me son infieles, \w Yo|strong="H6680"\w* los dispersaré entre los \w pueblos|strong="H5971"\w*,\wj*
\v 9 \wj pero \w si|strong="H1961"\w* \w se|strong="H1961"\w* \w vuelven|strong="H7725"\w* \w a|strong="H3068"\w* \w Mí|strong="H1961"\w*, observan mis \w Mandamientos|strong="H4687"\w* y \w los|strong="H1961"\w* cumplen, \w aunque|strong="H8033"\w* sus exiliados \w estén|strong="H1961"\w* en \w el|strong="H6213"\w* \w extremo|strong="H7097"\w* del \w cielo|strong="H8064"\w*, de \w allí|strong="H8033"\w* \w Yo|strong="H6213"\w* \w los|strong="H1961"\w* \w recogeré|strong="H6908"\w* y \w los|strong="H1961"\w* conduciré \w otra|strong="H6213"\w* vez al \w lugar|strong="H4725"\w* \w que|strong="H1961"\w* escogí \w para|strong="H1961"\w* \w que|strong="H1961"\w* \w mi|strong="H1961"\w* \w Nombre|strong="H8034"\w* \w esté|strong="H1961"\w* \w allí|strong="H8033"\w*.\wj*
\p 
\v 10 \w Ellos|strong="H1992"\w* son tus esclavos y tu \w pueblo|strong="H5971"\w*, \w los|strong="H1992"\w* cuales rescataste con tu \w gran|strong="H1419"\w* \w poder|strong="H3581"\w* y con tu \w mano|strong="H3027"\w* \w poderosa|strong="H2389"\w*.
\v 11 Te \w ruego|strong="H4994"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd*, \w que|strong="H4994"\w* \w esté|strong="H2088"\w* \w atento|strong="H7183"\w* \w ahora|strong="H4994"\w* tu oído \w a|strong="H3068"\w* la \w oración|strong="H8605"\w* \w de|strong="H6440"\w* tu esclavo y \w de|strong="H6440"\w* tus esclavos \w que|strong="H4994"\w* \w se|strong="H1961"\w* complacen en reverenciar tu \w Nombre|strong="H8034"\w*. Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* tu esclavo prospere \w hoy|strong="H3117"\w*. Concédele misericordia \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w este|strong="H2088"\w* hombre. \w Entonces|strong="H3117"\w* \w yo|strong="H4994"\w* \w era|strong="H1961"\w* el copero del \w rey|strong="H4428"\w*.
\c 2
\s1 Autorización de Artajerjes
\p 
\v 1 El \w año|strong="H8141"\w* 20 del \w rey|strong="H4428"\w* Artajerjes, el \w mes|strong="H2320"\w* \w de|strong="H6440"\w* Nisán, \w aconteció|strong="H1961"\w* \w que|strong="H3808"\w* \w cuando|strong="H1961"\w* \w estaba|strong="H1961"\w* el \w vino|strong="H3196"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* él, yo \w tomé|strong="H5375"\w* el \w vino|strong="H3196"\w* y \w se|strong="H1961"\w* \w lo|strong="H3808"\w* serví \w al|strong="H4428"\w* \w rey|strong="H4428"\w*. \w Y|strong="H3068"\w* \w como|strong="H1961"\w* yo \w nunca|strong="H3808"\w* \w antes|strong="H6440"\w* \w estuve|strong="H1961"\w* \w triste|strong="H7451"\w* en su \w presencia|strong="H6440"\w*,
\v 2 \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w me|strong="H3588"\w* dijo: \w Puesto|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w estás|strong="H2088"\w* \w enfermo|strong="H2470"\w*, ¿\w por|strong="H3588"\w* \w qué|strong="H3588"\w* \w está|strong="H2088"\w* \w triste|strong="H7451"\w* tu semblante? ¿\w No|strong="H3588"\w* \w es|strong="H2088"\w* \w esto|strong="H2088"\w* aflicción \w de|strong="H3588"\w* \w corazón|strong="H3820"\w*?
\p \w Entonces|strong="H3588"\w* \w temí|strong="H3372"\w* muchísimo
\v 3 y respondí \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: ¡\w Viva|strong="H2421"\w* el \w rey|strong="H4428"\w* para \w siempre|strong="H5769"\w*! ¿\w Cómo|strong="H4069"\w* \w no|strong="H3808"\w* debe estar triste mi semblante cuando la \w ciudad|strong="H5892"\w* donde están los \w sepulcros|strong="H6913"\w* \w de|strong="H6440"\w* mis antepasados está en ruinas y sus \w puertas|strong="H8179"\w* consumidas \w por|strong="H4069"\w* el fuego?
\p 
\v 4 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w me|strong="H5921"\w* preguntó: ¿\w Qué|strong="H4100"\w* \w pides|strong="H1245"\w*?
\p Entonces \w oré|strong="H6419"\w* \w al|strong="H5921"\w* \nd ʼElohim\nd* \w del|strong="H5921"\w* \w cielo|strong="H8064"\w*
\v 5 \w y|strong="H5921"\w* contesté \w al|strong="H5921"\w* \w rey|strong="H4428"\w*: \w Si|strong="H6440"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w le|strong="H5921"\w* \w place|strong="H2895"\w* \w y|strong="H5921"\w* \w si|strong="H6440"\w* tu esclavo halló gracia \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*, \w te|strong="H5921"\w* ruego \w que|strong="H5921"\w* \w me|strong="H5921"\w* envíes \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*, \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w sepulcros|strong="H6913"\w* \w de|strong="H5921"\w* mis antepasados, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* reedifique.
\p 
\v 6 \w Y|strong="H3068"\w* \w el|strong="H3427"\w* \w rey|strong="H4428"\w* me preguntó (\w y|strong="H5704"\w* la \w reina|strong="H4428"\w* \w estaba|strong="H1961"\w* sentada junto \w a|strong="H3068"\w* \w él|strong="H3427"\w*): ¿Cuánto durará tu viaje \w y|strong="H5704"\w* \w cuándo|strong="H4970"\w* \w volverás|strong="H7725"\w*? \w Como|strong="H1961"\w* \w al|strong="H5704"\w* \w rey|strong="H4428"\w* le pareció \w bien|strong="H3190"\w* \w enviarme|strong="H7971"\w*, yo le definí \w el|strong="H3427"\w* plazo.
\p 
\v 7 \w Además|strong="H5921"\w* dije \w al|strong="H5921"\w* \w rey|strong="H4428"\w*: \w Si|strong="H5921"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w le|strong="H5921"\w* parece \w bien|strong="H2895"\w*, \w que|strong="H5921"\w* \w se|strong="H5921"\w* \w me|strong="H5921"\w* den cartas \w para|strong="H5704"\w* \w los|strong="H5921"\w* \w gobernadores|strong="H6346"\w* \w de|strong="H5921"\w* \w Más|strong="H5921"\w* Allá \w del|strong="H5921"\w* \w Río|strong="H5104"\w* Éufrates \w para|strong="H5704"\w* \w que|strong="H5921"\w* \w me|strong="H5921"\w* dejen \w pasar|strong="H5674"\w* \w hasta|strong="H5704"\w* \w que|strong="H5921"\w* llegue \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*,
\v 8 \w y|strong="H5921"\w* también una carta \w para|strong="H5921"\w* Asaf, \w guarda|strong="H8104"\w* \w del|strong="H5921"\w* bosque \w del|strong="H5921"\w* \w rey|strong="H4428"\w*, \w con|strong="H5921"\w* \w el|strong="H5921"\w* propósito \w de|strong="H5921"\w* \w que|strong="H5921"\w* \w me|strong="H5921"\w* \w dé|strong="H5921"\w* \w madera|strong="H6086"\w* \w para|strong="H5921"\w* enmaderar \w las|strong="H5921"\w* \w puertas|strong="H8179"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* ciudadela \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w Templo|strong="H1004"\w*, \w el|strong="H5921"\w* \w muro|strong="H2346"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* cual yo estaré. \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w me|strong="H5921"\w* \w lo|strong="H5921"\w* concedió, \w de|strong="H5921"\w* acuerdo \w con|strong="H5921"\w* \w la|strong="H5921"\w* benéfica \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \nd ʼElohim\nd*.
\v 9 \w El|strong="H5973"\w* \w rey|strong="H4428"\w* \w envió|strong="H7971"\w* \w capitanes|strong="H8269"\w* \w del|strong="H5973"\w* \w ejército|strong="H2428"\w* y \w jinetes|strong="H6571"\w* \w conmigo|strong="H5973"\w*. Cuando llegué \w a|strong="H3068"\w* \w los|strong="H5973"\w* \w gobernadores|strong="H6346"\w* \w de|strong="H5973"\w* Mas Allá \w del|strong="H5973"\w* \w Río|strong="H5104"\w*, \w les|strong="H5973"\w* \w entregué|strong="H5414"\w* las cartas \w reales|strong="H4428"\w*.
\p 
\v 10 Pero \w cuando|strong="H5650"\w* Sanbalat \w horonita|strong="H2772"\w* y \w Tobías|strong="H2900"\w*, \w el|strong="H1121"\w* esclavo amonita, \w lo|strong="H1992"\w* \w oyeron|strong="H8085"\w*, \w se|strong="H1992"\w* disgustaron muchísimo \w de|strong="H1121"\w* \w que|strong="H1121"\w* alguien llegara \w a|strong="H3068"\w* procurar \w el|strong="H1121"\w* \w bien|strong="H2896"\w* \w de|strong="H1121"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.
\s1 Llegada a Jerusalén
\p 
\v 11 Llegué \w a|strong="H3068"\w* Jerusalén y \w estuve|strong="H1961"\w* \w allí|strong="H8033"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w*.
\v 12 \w Me|strong="H3588"\w* levanté \w de|strong="H3588"\w* \w noche|strong="H3915"\w* \w y|strong="H3588"\w* tomé \w a|strong="H3068"\w* unos \w pocos|strong="H4592"\w* hombres. \w A|strong="H3068"\w* \w nadie|strong="H3808"\w* \w declaré|strong="H5046"\w* \w lo|strong="H4100"\w* \w que|strong="H3588"\w* \w mi|strong="H3389"\w* \nd ʼElohim\nd* \w puso|strong="H5414"\w* \w en|strong="H5973"\w* \w mi|strong="H3389"\w* \w corazón|strong="H3820"\w* \w para|strong="H3588"\w* \w hacer|strong="H6213"\w* \w por|strong="H3588"\w* Jerusalén. \w No|strong="H3808"\w* \w había|strong="H3588"\w* alguna bestia \w conmigo|strong="H5973"\w*, excepto \w el|strong="H5973"\w* animal \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w cual|strong="H4100"\w* \w cabalgaba|strong="H7392"\w*.
\p 
\v 13 \w Salí|strong="H3318"\w* \w de|strong="H6440"\w* \w noche|strong="H3915"\w* \w por|strong="H6440"\w* la \w puerta|strong="H8179"\w* del \w Valle|strong="H1516"\w*. Pasé \w por|strong="H6440"\w* la \w fuente|strong="H5869"\w* del \w Dragón|strong="H8577"\w* y \w por|strong="H6440"\w* la \w puerta|strong="H8179"\w* del Muladar. Inspeccioné \w los|strong="H1961"\w* \w muros|strong="H2346"\w* \w de|strong="H6440"\w* Jerusalén \w que|strong="H1961"\w* \w estaban|strong="H1961"\w* destruidos y sus \w puertas|strong="H8179"\w* consumidas \w por|strong="H6440"\w* el fuego.
\v 14 \w Luego|strong="H5674"\w* \w pasé|strong="H5674"\w* \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w* \w de|strong="H8478"\w* la \w Fuente|strong="H5869"\w* y fui hasta \w el|strong="H5674"\w* \w estanque|strong="H1295"\w* del \w Rey|strong="H4428"\w*, pero no había espacio para que \w pasara|strong="H5674"\w* la bestia \w en|strong="H8478"\w* la cual iba.
\v 15 Subí de \w noche|strong="H3915"\w* por el \w torrente|strong="H5158"\w* \w e|strong="H3068"\w* inspeccioné el \w muro|strong="H2346"\w*. \w Cuando|strong="H1961"\w* regresé, entré otra vez por la \w puerta|strong="H8179"\w* del \w Valle|strong="H1516"\w*.
\v 16 Los oficiales \w no|strong="H3808"\w* \w sabían|strong="H3045"\w* \w a|strong="H3068"\w* dónde \w fui|strong="H3808"\w*, \w ni|strong="H3808"\w* \w qué|strong="H4100"\w* \w hice|strong="H6213"\w*, \w pues|strong="H3651"\w* \w hasta|strong="H5704"\w* \w entonces|strong="H3651"\w* \w no|strong="H3808"\w* \w había|strong="H6213"\w* informado \w a|strong="H3068"\w* los \w judíos|strong="H3064"\w*, los \w sacerdotes|strong="H3548"\w*, los jefes, los oficiales \w ni|strong="H3808"\w* \w a|strong="H3068"\w* los demás \w que|strong="H4100"\w* \w hacían|strong="H6213"\w* \w el|strong="H6213"\w* trabajo.
\p 
\v 17 Entonces les dije: Ustedes \w ven|strong="H3212"\w* el \w mal|strong="H7451"\w* \w en|strong="H5750"\w* el cual estamos, \w cómo|strong="H1961"\w* Jerusalén \w está|strong="H1961"\w* destruida y sus \w puertas|strong="H8179"\w* devastadas \w por|strong="H5750"\w* el fuego. ¡Vengan y reedifiquemos el \w muro|strong="H2346"\w* \w de|strong="H5750"\w* Jerusalén, \w para|strong="H1961"\w* \w que|strong="H3808"\w* ya \w no|strong="H3808"\w* estemos \w en|strong="H5750"\w* \w oprobio|strong="H2781"\w*!
\v 18 \w Les|strong="H5921"\w* \w declaré|strong="H5046"\w* \w cómo|strong="H5921"\w* \w la|strong="H1931"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \nd ʼElohim\nd* \w fue|strong="H1931"\w* \w buena|strong="H2896"\w* \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H5921"\w* también \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w que|strong="H1931"\w* \w me|strong="H5921"\w* \w dijo|strong="H5046"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w*.
\p Entonces respondieron: ¡\w Levantémonos|strong="H6965"\w* \w y|strong="H5921"\w* reedifiquemos! \w De|strong="H5921"\w* \w este|strong="H1931"\w* modo dispusieron \w sus|strong="H1931"\w* \w manos|strong="H3027"\w* \w para|strong="H5921"\w* \w lo|strong="H1931"\w* \w bueno|strong="H2896"\w*.
\p 
\v 19 Pero \w cuando|strong="H4100"\w* Sanbalat \w horonita|strong="H2772"\w*, \w Tobías|strong="H2900"\w*, \w el|strong="H5921"\w* esclavo amonita \w y|strong="H5921"\w* Gesem, \w el|strong="H5921"\w* árabe, \w lo|strong="H1697"\w* \w oyeron|strong="H8085"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* burlaron \w de|strong="H5921"\w* \w nosotros|strong="H5921"\w*. \w Nos|strong="H5921"\w* \w dijeron|strong="H1697"\w* despectivamente: ¿\w Qué|strong="H4100"\w* \w están|strong="H2088"\w* \w haciendo|strong="H6213"\w* ustedes? ¿\w Se|strong="H5921"\w* rebelan \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w*?
\p 
\v 20 \w Y|strong="H3068"\w* les respondí: \w El|strong="H1931"\w* \nd ʼElohim\nd* del \w cielo|strong="H8064"\w* nos \w prosperará|strong="H6743"\w*. \w Por|strong="H1697"\w* tanto, \w nosotros|strong="H1931"\w*, \w sus|strong="H1931"\w* esclavos, nos levantamos y \w edificamos|strong="H1129"\w*, pero ustedes no tienen \w parte|strong="H2506"\w*, ni \w derecho|strong="H6666"\w*, ni \w memoria|strong="H2146"\w* en Jerusalén.
\c 3
\s1 Reconstrucción del muro
\p 
\v 1 Entonces \w el|strong="H1992"\w* \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w* Eliasib \w se|strong="H1992"\w* \w levantó|strong="H6965"\w* \w con|strong="H5704"\w* \w sus|strong="H1992"\w* hermanos \w sacerdotes|strong="H3548"\w*. Reedificaron la \w puerta|strong="H1817"\w* \w de|strong="H5704"\w* \w las|strong="H1992"\w* \w Ovejas|strong="H6629"\w*, \w pusieron|strong="H5975"\w* \w las|strong="H1992"\w* hojas \w de|strong="H5704"\w* la \w puerta|strong="H1817"\w* \w y|strong="H5704"\w* la consagraron. Reedificaron la \w torre|strong="H4026"\w* \w de|strong="H5704"\w* \w los|strong="H1992"\w* Cien \w y|strong="H5704"\w* consagraron \add el muro\add* \w hasta|strong="H5704"\w* la \w torre|strong="H4026"\w* Hanan-ʼEl.
\v 2 \w Junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ellos|strong="H3027"\w* \w los|strong="H1121"\w* varones \w de|strong="H5921"\w* \w Jericó|strong="H3405"\w* reedificaron, \w y|strong="H5921"\w* \w a|strong="H3068"\w* su \w lado|strong="H3027"\w* Zacur, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Imri, también \w reedificó|strong="H1129"\w*.
\p 
\v 3 \w Los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Senaa reedificaron la \w puerta|strong="H1817"\w* \w de|strong="H1121"\w* \w los|strong="H1992"\w* Peces. \w Ellos|strong="H1992"\w* la enmaderaron y \w pusieron|strong="H5975"\w* \w las|strong="H1992"\w* hojas \w de|strong="H1121"\w* \w su|strong="H1992"\w* \w puerta|strong="H1817"\w*, con \w sus|strong="H1992"\w* \w cerraduras|strong="H4514"\w* y \w cerrojos|strong="H1280"\w*.
\v 4 \w Junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ellos|strong="H3027"\w* Meremot, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Urías, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Cos|strong="H6976"\w*, reedificó. \w Junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w restauró|strong="H2388"\w* Mesulam, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Berequías, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Mesezabeel|strong="H4898"\w*, \w y|strong="H5921"\w* \w a|strong="H3068"\w* su \w lado|strong="H3027"\w* reparó \w Sadoc|strong="H6659"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Baana.
\v 5 \w Los|strong="H5921"\w* tecoítas \w repararon|strong="H2388"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ellos|strong="H3027"\w*, pero sus nobles \w no|strong="H3808"\w* apoyaron \w el|strong="H5921"\w* trabajo \w de|strong="H5921"\w* sus señores.
\p 
\v 6 La \w puerta|strong="H1817"\w* Antigua fue reparada por Joiada, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Pasea, y Mesulam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Besodías. \w Ellos|strong="H1992"\w* \w mismos|strong="H1992"\w* la enmaderaron, \w pusieron|strong="H5975"\w* \w las|strong="H1992"\w* hojas \w de|strong="H1121"\w* \w su|strong="H1992"\w* \w puerta|strong="H1817"\w*, \w sus|strong="H1992"\w* \w cerraduras|strong="H4514"\w* y \w sus|strong="H1992"\w* \w cerrojos|strong="H1280"\w*.
\v 7 \w Junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ellos|strong="H3027"\w* \w repararon|strong="H2388"\w* \w Melatías|strong="H4424"\w* \w gabaonita|strong="H1393"\w* \w y|strong="H5921"\w* Jadón meronotita, hombres \w de|strong="H5921"\w* \w Gabaón|strong="H1391"\w* \w y|strong="H5921"\w* \w Mizpa|strong="H4709"\w*, \w según|strong="H5921"\w* \w la|strong="H5921"\w* autoridad \w del|strong="H5921"\w* \w gobernador|strong="H6346"\w* \w de|strong="H5921"\w* \w Más|strong="H5921"\w* Allá \w del|strong="H5921"\w* \w Río|strong="H5104"\w*.
\v 8 \w Al|strong="H5921"\w* \w lado|strong="H3027"\w* \w de|strong="H5921"\w* \w ellos|strong="H3027"\w* reparó Uziel, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Harhaía, uno \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w que|strong="H5921"\w* trabajaban \w con|strong="H5921"\w* objetos \w de|strong="H5921"\w* metales preciosos. \w Junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w restauró|strong="H2388"\w* \w Hananías|strong="H2608"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* un perfumista. \w Así|strong="H2388"\w* \w restauraron|strong="H2388"\w* \add el muro de\add* Jerusalén \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w muro|strong="H2346"\w* \w ancho|strong="H7342"\w*.
\v 9 \w Junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ellos|strong="H3027"\w* reparó Refaías, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Hur|strong="H2354"\w*, \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* mitad \w del|strong="H5921"\w* distrito Jerusalén.
\v 10 \w Y|strong="H3068"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w Jedaías|strong="H3042"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Harumaf, reparó \w al|strong="H5921"\w* \w frente|strong="H5048"\w* \w de|strong="H5921"\w* su \w casa|strong="H1004"\w*. \w A|strong="H3068"\w* su \w lado|strong="H3027"\w* reparó Hatús, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Hasabnías.
\v 11 Malquías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Harim|strong="H2766"\w*, y Hasub, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Pajat-moab, \w repararon|strong="H2388"\w* \w el|strong="H1121"\w* \w otro|strong="H8145"\w* tramo y la \w torre|strong="H4026"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* Hornos.
\v 12 \w Junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ellos|strong="H3027"\w* reparó Salum, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Halohes, \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* otra mitad \w del|strong="H5921"\w* distrito Jerusalén, \w él|strong="H1931"\w* \w con|strong="H5921"\w* \w sus|strong="H1931"\w* \w hijas|strong="H1323"\w*.
\p 
\v 13 \w Hanún|strong="H2586"\w* \w reparó|strong="H1129"\w* la \w puerta|strong="H1817"\w* del \w Valle|strong="H1516"\w* \w con|strong="H5704"\w* \w los|strong="H1992"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5704"\w* Zanoa. \w Ellos|strong="H1992"\w* la reedificaron \w y|strong="H5704"\w* \w pusieron|strong="H5975"\w* \w las|strong="H1992"\w* hojas \w de|strong="H5704"\w* \w su|strong="H1992"\w* \w puerta|strong="H1817"\w*, \w sus|strong="H1992"\w* \w cerraduras|strong="H4514"\w* \w y|strong="H5704"\w* \w sus|strong="H1992"\w* \w cerrojos|strong="H1280"\w*, \w y|strong="H5704"\w* además 450 metros del \w muro|strong="H2346"\w* \w hasta|strong="H5704"\w* la \w puerta|strong="H1817"\w* del Muladar.
\p 
\v 14 Malquías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Recab, \w jefe|strong="H8269"\w* del distrito Bet-haquerem, \w reparó|strong="H1129"\w* \w la|strong="H1931"\w* \w puerta|strong="H1817"\w* del Muladar. \w Él|strong="H1931"\w* \w mismo|strong="H1931"\w* \w la|strong="H1931"\w* \w reedificó|strong="H1129"\w* y \w puso|strong="H5975"\w* las hojas \w de|strong="H1121"\w* \w su|strong="H1931"\w* \w puerta|strong="H1817"\w*, \w sus|strong="H1931"\w* \w cerraduras|strong="H4514"\w* y \w sus|strong="H1931"\w* \w cerrojos|strong="H1280"\w*.
\p 
\v 15 Salum, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* Colhoze, \w jefe|strong="H8269"\w* \w de|strong="H5704"\w* \w la|strong="H1931"\w* región \w de|strong="H5704"\w* \w Mizpa|strong="H4709"\w*, \w reparó|strong="H1129"\w* \w la|strong="H1931"\w* \w puerta|strong="H1817"\w* \w de|strong="H5704"\w* \w la|strong="H1931"\w* \w Fuente|strong="H5869"\w*. \w Él|strong="H1931"\w* \w la|strong="H1931"\w* \w reedificó|strong="H1129"\w*, \w la|strong="H1931"\w* \w enmaderó|strong="H2926"\w* \w y|strong="H5704"\w* \w puso|strong="H5975"\w* \w sus|strong="H1931"\w* hojas, \w sus|strong="H1931"\w* \w cerraduras|strong="H4514"\w* \w y|strong="H5704"\w* \w sus|strong="H1931"\w* \w cerrojos|strong="H1280"\w*. También \w edificó|strong="H1129"\w* \w el|strong="H1931"\w* \w muro|strong="H2346"\w* junto \w al|strong="H5704"\w* \w estanque|strong="H1295"\w* \w de|strong="H5704"\w* Siloé, hacia \w el|strong="H1931"\w* jardín del \w Rey|strong="H4428"\w*, \w hasta|strong="H5704"\w* las \w gradas|strong="H4609"\w* \w que|strong="H1931"\w* \w descienden|strong="H3381"\w* \w de|strong="H5704"\w* \w la|strong="H1931"\w* \w Ciudad|strong="H5892"\w* \w de|strong="H5704"\w* \w David|strong="H1732"\w*.
\v 16 \w Después|strong="H5704"\w* \w de|strong="H5048"\w* \w él|strong="H1121"\w*, \w Nehemías|strong="H5166"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* Azbuc, \w jefe|strong="H8269"\w* \w de|strong="H5048"\w* la mitad \w del|strong="H2677"\w* distrito Bet-sur, reparó \w hasta|strong="H5704"\w* \w frente|strong="H5048"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w Sepulcros|strong="H6913"\w* \w de|strong="H5048"\w* \w David|strong="H1732"\w*, \w el|strong="H1121"\w* \w estanque|strong="H1295"\w* artificial \w y|strong="H5704"\w* la \w casa|strong="H1004"\w* \w de|strong="H5048"\w* \w los|strong="H1121"\w* \w Valientes|strong="H1368"\w*.
\p 
\v 17 Tras \w él|strong="H5921"\w* \w repararon|strong="H2388"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \add dirigidos por\add* Reum, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Bani|strong="H1137"\w*, \w junto|strong="H5921"\w* \w al|strong="H5921"\w* cual reparó \w Hasabías|strong="H2811"\w*, \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* mitad \w del|strong="H5921"\w* distrito Queila, \w por|strong="H5921"\w* cuenta \w de|strong="H5921"\w* su distrito.
\v 18 Después \w de|strong="H1121"\w* \w él|strong="H1121"\w* \w repararon|strong="H2388"\w* sus hermanos y Bavay, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Henadad, \w jefe|strong="H8269"\w* \w de|strong="H1121"\w* la otra mitad \w del|strong="H2677"\w* distrito Queila.
\v 19 \w Junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*, \w Ezer|strong="H5829"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Jesuá|strong="H3442"\w*, \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w Mizpa|strong="H4709"\w*, reparó \w el|strong="H5921"\w* \w otro|strong="H8145"\w* tramo, \w frente|strong="H5048"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* subida \w del|strong="H5921"\w* Arsenal \w del|strong="H5921"\w* ángulo.
\v 20 \w Después|strong="H8145"\w* \w de|strong="H4480"\w* \w él|strong="H1121"\w*, Baruc, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Zaba, reparó \w con|strong="H4480"\w* \w gran|strong="H1419"\w* fervor \w el|strong="H1121"\w* tramo \w que|strong="H4480"\w* \w va|strong="H3068"\w* \w desde|strong="H4480"\w* este ángulo \w hasta|strong="H5704"\w* la \w puerta|strong="H6607"\w* \w de|strong="H4480"\w* la \w casa|strong="H1004"\w* \w de|strong="H4480"\w* Eliasib, \w el|strong="H1121"\w* \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w*.
\v 21 \w Después|strong="H8145"\w* \w de|strong="H5704"\w* \w él|strong="H1121"\w*, Meremot, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* Urías, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* \w Cos|strong="H6976"\w*, reparó \w otro|strong="H8145"\w* tramo \w desde|strong="H5704"\w* la entrada \w hasta|strong="H5704"\w* \w el|strong="H1121"\w* extremo \w de|strong="H5704"\w* la \w casa|strong="H1004"\w* \w de|strong="H5704"\w* Eliasib.
\p 
\v 22 Detrás de él \w repararon|strong="H2388"\w* los \w sacerdotes|strong="H3548"\w* procedentes de la llanura.
\v 23 \w A|strong="H3068"\w* continuación \w de|strong="H5048"\w* ellos, \w Benjamín|strong="H1144"\w* y Jasub \w repararon|strong="H2388"\w* \w frente|strong="H5048"\w* \w a|strong="H3068"\w* su \w casa|strong="H1004"\w*, y después \w de|strong="H5048"\w* éstos, \w Azarías|strong="H5838"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* \w Maasías|strong="H4641"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* Ananías, reparó junto \w a|strong="H3068"\w* su \w casa|strong="H1004"\w*.
\v 24 \w A|strong="H3068"\w* continuación, Binúi, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* Henadad, reparó \w otro|strong="H8145"\w* tramo \w desde|strong="H5704"\w* la \w casa|strong="H1004"\w* \w de|strong="H5704"\w* \w Azarías|strong="H5838"\w* \w hasta|strong="H5704"\w* \w el|strong="H1121"\w* ángulo \w y|strong="H5704"\w* la esquina.
\v 25 Palal, \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* Uzay, reparó \w frente|strong="H5048"\w* \w a|strong="H3068"\w* la esquina y la \w torre|strong="H4026"\w* elevada \w que|strong="H1121"\w* sobresale \w de|strong="H5048"\w* la \w casa|strong="H1004"\w* del \w Rey|strong="H4428"\w*, \w que|strong="H1121"\w* está \w en|strong="H3318"\w* \w el|strong="H1121"\w* \w patio|strong="H2691"\w* \w de|strong="H5048"\w* la cárcel, y después \w de|strong="H5048"\w* \w él|strong="H1121"\w*, Pedaías, \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* Faros.
\v 26 \w También|strong="H3318"\w* \w los|strong="H3427"\w* servidores establecidos \w en|strong="H5704"\w* Ofel repararon \w hasta|strong="H5704"\w* \w enfrente|strong="H5048"\w* \w de|strong="H5048"\w* la \w puerta|strong="H8179"\w* \w de|strong="H5048"\w* las \w Aguas|strong="H4325"\w*, \w al|strong="H5704"\w* \w oriente|strong="H4217"\w* \w de|strong="H5048"\w* la \w torre|strong="H4026"\w* \w que|strong="H5704"\w* sobresale.
\v 27 \w Después|strong="H8145"\w* \w de|strong="H5048"\w* ellos los tecoítas \w repararon|strong="H2388"\w* \w otro|strong="H8145"\w* tramo, \w desde|strong="H5704"\w* \w frente|strong="H5048"\w* \w a|strong="H3068"\w* la \w torre|strong="H4026"\w* \w grande|strong="H1419"\w* \w que|strong="H5704"\w* sobresale \w hasta|strong="H5704"\w* el \w muro|strong="H2346"\w* \w de|strong="H5048"\w* Ofel.
\p 
\v 28 \w Los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w repararon|strong="H2388"\w* adelante \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Caballos|strong="H5483"\w*, cada uno \w frente|strong="H5048"\w* \w a|strong="H3068"\w* su \w casa|strong="H1004"\w*.
\v 29 Detrás \w de|strong="H5048"\w* ellos \w Sadoc|strong="H6659"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* Imer, reparó \w frente|strong="H5048"\w* \w a|strong="H3068"\w* su \w casa|strong="H1004"\w*, y después \w de|strong="H5048"\w* \w él|strong="H1121"\w* reparó \w Semaías|strong="H8098"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* Secanías, \w guarda|strong="H8104"\w* \w de|strong="H5048"\w* \w la|strong="H8104"\w* \w puerta|strong="H8179"\w* \w Oriental|strong="H4217"\w*.
\v 30 En seguida \w de|strong="H5048"\w* \w él|strong="H1121"\w*, \w Hananías|strong="H2608"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* Selemías, reparó \w otro|strong="H8145"\w* tramo junto con \w Hanún|strong="H2586"\w*, \w sexto|strong="H8345"\w* \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* Salaf. Tras éste Mesulam, \w hijo|strong="H1121"\w* \w de|strong="H5048"\w* Berequías, reparó \w frente|strong="H5048"\w* \w a|strong="H3068"\w* su casa.
\v 31 Tras \w él|strong="H1121"\w*, Malquías, \w hijo|strong="H1121"\w* del platero, reparó \w hasta|strong="H5704"\w* las \w casas|strong="H1004"\w* \w de|strong="H5048"\w* \w los|strong="H1121"\w* servidores del \w Templo|strong="H1004"\w* \w y|strong="H5704"\w* \w los|strong="H1121"\w* mercaderes, \w enfrente|strong="H5048"\w* \w de|strong="H5048"\w* la \w puerta|strong="H8179"\w* del Juicio \w y|strong="H5704"\w* \w hasta|strong="H5704"\w* \w el|strong="H1121"\w* \w aposento|strong="H1004"\w* alto \w de|strong="H5048"\w* la esquina.
\p 
\v 32 Los orífices y los mercaderes \w repararon|strong="H2388"\w* entre el aposento alto de la esquina y la \w puerta|strong="H8179"\w* de las \w Ovejas|strong="H6629"\w*.
\c 4
\s1 Oposición de los samaritanos
\p 
\v 1 \w Pero|strong="H3588"\w* \w cuando|strong="H3588"\w* Sanbalat \w supo|strong="H8085"\w* \w que|strong="H3588"\w* reconstruíamos \w el|strong="H3588"\w* \w muro|strong="H2346"\w*, \w se|strong="H1961"\w* airó muchísimo. Al burlarse \w de|strong="H3588"\w* \w los|strong="H1961"\w* judíos,
\v 2 habló ante sus hermanos y \w el|strong="H3605"\w* ejército \w de|strong="H3898"\w* Samaria: ¿\w Qué|strong="H3605"\w* pretenden \w estos|strong="H3605"\w* miserables judíos? ¿\w La|strong="H3605"\w* van \w a|strong="H3068"\w* restaurar para \w ellos|strong="H3605"\w*? ¿\w Sacrificarán|strong="H6213"\w*? ¿Acabarán en \w un|strong="H3162"\w* día? ¿\w Harán|strong="H6213"\w* revivir las piedras \w de|strong="H3898"\w* \w los|strong="H3605"\w* montones \w de|strong="H3898"\w* escombros, aunque ven \w que|strong="H3605"\w* están consumidas?
\p 
\v 3 Tobías amonita, \w que|strong="H5921"\w* \w estaba|strong="H5975"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*, dijo: ¡\w Hasta|strong="H5921"\w* una zorra, \w si|strong="H6440"\w* sube allí, podría derribar \w el|strong="H5921"\w* muro \w de|strong="H5921"\w* piedra \w que|strong="H5921"\w* construyen!
\p 
\v 4 ¡Oye, oh \nd ʼElohim\nd* nuestro, cómo somos menospreciados! ¡Haz recaer sus ofensas sobre su propia cabeza y entrégalos al despojo en \w tierra|strong="H6083"\w* de cautiverio!
\v 5 ¡\w No|strong="H3808"\w* cubras su iniquidad, \w ni|strong="H3808"\w* sea borrado su pecado \w delante|strong="H5704"\w* \w de|strong="H5704"\w* tu Presencia, \w porque|strong="H3808"\w* te provocaron \w a|strong="H3068"\w* ira \w delante|strong="H5704"\w* \w de|strong="H5704"\w* los \w que|strong="H3808"\w* edifican!
\v 6 Así reconstruimos \w el|strong="H5921"\w* muro \w y|strong="H5921"\w* unimos \w todos|strong="H3605"\w* \w los|strong="H3427"\w* tramos \w hasta|strong="H5921"\w* \w la|strong="H5921"\w* mitad \w de|strong="H5921"\w* su altura. \w El|strong="H5921"\w* pueblo \w tuvo|strong="H1961"\w* ánimo \w para|strong="H5921"\w* trabajar.
\p 
\v 7 Pero cuando Sanbalat, Tobías, \w los|strong="H5973"\w* árabes, \w los|strong="H5973"\w* amonitas y \w los|strong="H5973"\w* \w de|strong="H5973"\w* Asdod oyeron \w que|strong="H5971"\w* la reparación \w de|strong="H5973"\w* \w los|strong="H5973"\w* \w muros|strong="H2346"\w* \w de|strong="H5973"\w* Jerusalén avanzaba y las brechas comenzaban \w a|strong="H3068"\w* cerrarse, \w se|strong="H5971"\w* enfurecieron muchísimo.
\p 
\v 8 Todos \w a|strong="H3068"\w* una \w se|strong="H5921"\w* confabularon \w para|strong="H5921"\w* venir \w a|strong="H3068"\w* atacar Jerusalén \w y|strong="H5921"\w* causarle daño.
\p 
\v 9 \w Pero|strong="H3588"\w* \w nosotros|strong="H3605"\w* oramos \w a|strong="H3068"\w* nuestro \nd ʼElohim\nd* \w y|strong="H3588"\w* nos colocamos \w en|strong="H3588"\w* guardia \w contra|strong="H1961"\w* \w ellos|strong="H3605"\w* día \w y|strong="H3588"\w* noche.
\p 
\v 10 \w Los|strong="H3605"\w* \w de|strong="H4480"\w* \w Judá|strong="H3063"\w* dijeron: \w Ya|strong="H3068"\w* desfallecen las fuerzas \w de|strong="H4480"\w* \w los|strong="H3605"\w* cargadores y \w los|strong="H3605"\w* escombros \w son|strong="H1961"\w* muchos. \w Por|strong="H4480"\w* tanto, \w no|strong="H6213"\w* \w podremos|strong="H1961"\w* reedificar \w el|strong="H1931"\w* muro.
\p 
\v 11 Nuestros enemigos se decían: \w Ellos|strong="H3027"\w* \w no|strong="H6213"\w* \w lo|strong="H6213"\w* sabrán ni \w lo|strong="H6213"\w* verán hasta \w que|strong="H3027"\w* caigamos sobre \w ellos|strong="H3027"\w*, los matemos y \w hagamos|strong="H6213"\w* cesar la \w obra|strong="H4399"\w*.
\p 
\v 12 Pero cuando llegaron \w los|strong="H5921"\w* judíos \w que|strong="H5921"\w* vivían \w cerca|strong="H5921"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w nos|strong="H5921"\w* decían \w hasta|strong="H5921"\w* diez veces: \w De|strong="H5921"\w* todos \w los|strong="H5921"\w* lugares \w hacia|strong="H5921"\w* \w los|strong="H5921"\w* cuales ustedes miren, caerán \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*.
\p 
\v 13 Entonces distribuí \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w por|strong="H5921"\w* familias, \w con|strong="H5921"\w* sus espadas, lanzas \w y|strong="H5921"\w* arcos, detrás \w del|strong="H5921"\w* \w muro|strong="H2346"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* partes \w más|strong="H5921"\w* bajas \w y|strong="H5921"\w* \w en|strong="H5921"\w* sus partes desprotegidas.
\v 14 Después que inspeccioné, me levanté y dije \w a|strong="H3068"\w* los jefes, los oficiales y el resto del pueblo: ¡No teman ante ellos! ¡Acuérdense \w de|strong="H3898"\w* \nd ʼAdonay\nd*, grande y maravilloso! ¡Luchen por sus hermanos, hijos \w e|strong="H3068"\w* hijas, esposas y por sus casas!
\p 
\v 15 Sucedió \w que|strong="H5704"\w* \w cuando|strong="H5704"\w* nuestros enemigos supieron \w que|strong="H5704"\w* fuimos advertidos, \nd ʼElohim\nd* desbarató sus planes. \w Y|strong="H3068"\w* todos nosotros pudimos regresar \w al|strong="H5704"\w* muro, cada uno \w a|strong="H3068"\w* su trabajo.
\p 
\v 16 Desde \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*, \w aconteció|strong="H1961"\w* \w que|strong="H1931"\w* \w la|strong="H1931"\w* \w mitad|strong="H8432"\w* \w de|strong="H5971"\w* mis hombres trabajaba \w en|strong="H8432"\w* \w la|strong="H1931"\w* \w obra|strong="H4399"\w* \w y|strong="H1571"\w* \w la|strong="H1931"\w* otra \w mitad|strong="H8432"\w* sostenía las lanzas, \w los|strong="H1931"\w* escudos, \w los|strong="H1931"\w* arcos \w y|strong="H1571"\w* las corazas. \w Los|strong="H1931"\w* jefes \w estaban|strong="H1961"\w* detrás \w de|strong="H5971"\w* toda \w la|strong="H1931"\w* casa \w de|strong="H5971"\w* Judá.
\v 17 Los \w que|strong="H4325"\w* trabajaban en el muro y los \w que|strong="H4325"\w* acarreaban las cargas, con una mano trabajaban en la obra y con la otra empuñaban la lanza.
\v 18 En cuanto \w a|strong="H3068"\w* los constructores, cada uno llevaba su espada atada \w a|strong="H3068"\w* su cintura, y así edificaban. El que soplaba la corneta estaba junto \w a|strong="H3068"\w* mí.
\p 
\v 19 Pues yo dije \w a|strong="H3068"\w* los jefes, los oficiales y al resto del pueblo: La obra es mucha y extensa, y nosotros estamos esparcidos por el muro, lejos los unos de los otros.
\v 20 Dondequiera que oigan el sonido de la corneta, reúnanse desde allí junto \w a|strong="H3068"\w* nosotros. ¡Nuestro \nd ʼElohim\nd* peleará por nosotros!
\p 
\v 21 Así trabajábamos en la obra: la mitad de ellos empuñaban las lanzas, desde la aurora hasta que salían las estrellas.
\v 22 También hablé al pueblo en ese tiempo: Cada uno pernocte con su esclavo dentro de Jerusalén, para que nos sirvan de guardia de noche y de día en la obra.
\v 23 Ni yo, ni mis compañeros, ni mis hombres, ni la guardia que me seguía, nos quitamos nuestra ropa. Cada uno tenía su lanza \w a|strong="H3068"\w* su mano derecha.
\c 5
\s1 Eliminación de la usura
\p 
\v 1 Entonces \w hubo|strong="H1961"\w* un \w gran|strong="H1419"\w* \w clamor|strong="H6818"\w* del \w pueblo|strong="H5971"\w* y \w de|strong="H5971"\w* sus mujeres \w contra|strong="H1961"\w* sus hermanos \w judíos|strong="H3064"\w*,
\v 2 porque algunos decían: Nosotros, nuestros \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w* somos \w muchos|strong="H7227"\w*, y necesitamos \w grano|strong="H1715"\w* para comer y \w vivir|strong="H2421"\w*.
\p 
\v 3 \w Y|strong="H3068"\w* algunos decían: Empeñamos nuestros \w campos|strong="H7704"\w*, \w viñas|strong="H3754"\w* y \w casas|strong="H1004"\w* \w para|strong="H6148"\w* obtener \w grano|strong="H1715"\w* durante la hambruna.
\p 
\v 4 Otros decían: Tomamos \w dinero|strong="H3701"\w* prestado para el tributo del \w rey|strong="H4428"\w* y ofrecimos la garantía de nuestros \w campos|strong="H7704"\w* y viñedos.
\v 5 \w Ahora|strong="H6258"\w* bien, nuestra \w carne|strong="H1320"\w* \w es|strong="H3027"\w* como la \w carne|strong="H1320"\w* \w de|strong="H1121"\w* nuestros hermanos, sus \w hijos|strong="H1121"\w* como nuestros \w hijos|strong="H1121"\w*, y \w así|strong="H6258"\w* sometemos \w a|strong="H3068"\w* esclavitud \w a|strong="H3068"\w* nuestros \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*. \w Hay|strong="H3426"\w* \w hijas|strong="H1323"\w* nuestras \w ya|strong="H6258"\w* esclavizadas, sin \w que|strong="H6258"\w* nosotros podamos rescatarlas, puesto \w que|strong="H6258"\w* nuestros \w campos|strong="H7704"\w* y \w viñas|strong="H3754"\w* \w ya|strong="H6258"\w* son \w de|strong="H1121"\w* otros.
\p 
\v 6 Cuando \w escuché|strong="H8085"\w* su \w clamor|strong="H2201"\w* y esas \w palabras|strong="H1697"\w* me airé muchísimo.
\v 7 \w Mi|strong="H5921"\w* \w corazón|strong="H3820"\w* \w se|strong="H5921"\w* turbó \w dentro|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*. Reprendí \w a|strong="H3068"\w* \w los|strong="H5921"\w* jefes \w y|strong="H5921"\w* \w los|strong="H5921"\w* oficiales: ¿Ustedes cobran interés, cada uno \w a|strong="H3068"\w* su hermano? \w Y|strong="H3068"\w* convoqué \w a|strong="H3068"\w* una \w gran|strong="H1419"\w* asamblea \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*
\v 8 \w y|strong="H1571"\w* les dije: Nosotros, \w según|strong="H1767"\w* nuestras posibilidades, \w rescatamos|strong="H7069"\w* \w a|strong="H3068"\w* nuestros hermanos \w judíos|strong="H3064"\w* \w que|strong="H3808"\w* \w tuvieron|strong="H4672"\w* \w que|strong="H3808"\w* venderse \w a|strong="H3068"\w* los gentiles, \w y|strong="H1571"\w* ustedes, ¿\w venderán|strong="H4376"\w* \w a|strong="H3068"\w* sus hermanos después \w de|strong="H1697"\w* ser rescatados \w por|strong="H1697"\w* nosotros? \w Y|strong="H3068"\w* \w ellos|strong="H1571"\w* callaron, \w porque|strong="H3808"\w* \w no|strong="H3808"\w* \w hallaron|strong="H4672"\w* \w respuesta|strong="H1697"\w*.
\p 
\v 9 \w Y|strong="H3068"\w* agregué: \w No|strong="H3808"\w* \w es|strong="H1697"\w* \w bueno|strong="H2896"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* \w hacen|strong="H6213"\w*. ¿\w No|strong="H3808"\w* deberían \w andar|strong="H3212"\w* con \w el|strong="H6213"\w* \w temor|strong="H3374"\w* \w de|strong="H1697"\w* nuestro \nd ʼElohim\nd*, \w a|strong="H3068"\w* \w causa|strong="H1697"\w* del \w oprobio|strong="H2781"\w* \w de|strong="H1697"\w* nuestros enemigos gentiles?
\v 10 \w También|strong="H1571"\w* \w yo|strong="H4994"\w*, mis hermanos \w y|strong="H1571"\w* mis esclavos les prestamos \w dinero|strong="H3701"\w* \w y|strong="H1571"\w* \w grano|strong="H1715"\w*. ¡Renunciamos \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* \w esta|strong="H2088"\w* usura!
\v 11 Les \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* les devuelvan \w hoy|strong="H3117"\w* sus \w campos|strong="H7704"\w*, \w viñas|strong="H3754"\w*, \w olivares|strong="H2132"\w* y \w casas|strong="H1004"\w*. Renuncien al interés \w que|strong="H4994"\w* les demandan por el \w dinero|strong="H3701"\w*, el \w grano|strong="H1715"\w*, el \w vino|strong="H8492"\w* nuevo y el \w aceite|strong="H3323"\w*.
\p 
\v 12 \w Entonces|strong="H3651"\w* \w respondieron|strong="H7725"\w*: \w Lo|strong="H1697"\w* \w devolveremos|strong="H7725"\w* y \w ya|strong="H2088"\w* \w no|strong="H3808"\w* \w lo|strong="H1697"\w* requeriremos. \w Haremos|strong="H6213"\w* \w así|strong="H3651"\w* \w como|strong="H3651"\w* \w tú|strong="H6213"\w* \w dices|strong="H1697"\w*.
\p \w Entonces|strong="H3651"\w* convoqué \w a|strong="H3068"\w* \w los|strong="H1992"\w* \w sacerdotes|strong="H3548"\w* y \w les|strong="H1992"\w* \w hice|strong="H6213"\w* jurar \w que|strong="H3808"\w* harían según \w esta|strong="H2088"\w* promesa.
\v 13 \w Sacudí|strong="H5287"\w* \w mi|strong="H1961"\w* ropa \w y|strong="H1571"\w* dije: ¡\w Así|strong="H3602"\w* \w sacuda|strong="H5287"\w* \nd ʼElohim\nd* \w de|strong="H5971"\w* su \w Templo|strong="H1004"\w* \w y|strong="H1571"\w* \w de|strong="H5971"\w* su beneficio \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w aquel|strong="H2088"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w cumpla|strong="H6965"\w* \w esta|strong="H2088"\w* promesa! ¡\w Así|strong="H3602"\w* \w sea|strong="H1961"\w* \w sacudido|strong="H5287"\w* \w y|strong="H1571"\w* vaciado! \w Y|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H1571"\w* \w congregación|strong="H6951"\w* respondió: ¡Amén! \w Y|strong="H3068"\w* alabaron \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p \w El|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w hizo|strong="H6213"\w* según \w esta|strong="H2088"\w* promesa.
\p 
\v 14 \w Además|strong="H1571"\w*, \w desde|strong="H5704"\w* \w el|strong="H1571"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w fui|strong="H1961"\w* designado \w gobernador|strong="H6346"\w* \w de|strong="H5704"\w* \w ellos|strong="H1571"\w* \w en|strong="H5704"\w* \w la|strong="H1571"\w* tierra \w de|strong="H5704"\w* \w Judá|strong="H3063"\w*, \w desde|strong="H5704"\w* \w el|strong="H1571"\w* \w año|strong="H8141"\w* 20 \w hasta|strong="H5704"\w* \w el|strong="H1571"\w* \w año|strong="H8141"\w* 32 del \w rey|strong="H4428"\w* Artajerjes, esto \w es|strong="H1961"\w*, 12 \w años|strong="H8141"\w*, \w ni|strong="H3808"\w* \w yo|strong="H6680"\w* \w ni|strong="H3808"\w* mis hermanos comimos \w el|strong="H1571"\w* \w pan|strong="H3899"\w* correspondiente \w al|strong="H5704"\w* \w gobernador|strong="H6346"\w*.
\v 15 \w Y|strong="H3068"\w* \w aunque|strong="H1571"\w* \w los|strong="H1992"\w* \w gobernadores|strong="H6346"\w* \w que|strong="H3808"\w* fueron \w antes|strong="H6440"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* subyugaban \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w y|strong="H1571"\w* \w les|strong="H1992"\w* cobraban \w más|strong="H1571"\w* \w de|strong="H5921"\w* 4,4 kilogramos \w de|strong="H5921"\w* \w plata|strong="H3701"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w pan|strong="H3899"\w* \w y|strong="H1571"\w* \w el|strong="H5921"\w* \w vino|strong="H3196"\w*, \w y|strong="H1571"\w* \w aun|strong="H1571"\w* \w sus|strong="H1992"\w* esclavos oprimían \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w yo|strong="H6213"\w* \w no|strong="H3808"\w* \w hice|strong="H6213"\w* \w así|strong="H3651"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w del|strong="H5921"\w* \w temor|strong="H3374"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd*.
\v 16 \w En|strong="H5921"\w* cambio, \w tomé|strong="H2388"\w* parte \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w obra|strong="H4399"\w* \w de|strong="H5921"\w* \w este|strong="H2063"\w* \w muro|strong="H2346"\w*. \w No|strong="H3808"\w* adquirí algún \w campo|strong="H7704"\w*, \w y|strong="H1571"\w* \w todos|strong="H3605"\w* mis esclavos estuvieron reunidos \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w obra|strong="H4399"\w*.
\p 
\v 17 \w Además|strong="H5921"\w* \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w judíos|strong="H3064"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* oficiales, había \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w mesa|strong="H7979"\w* 150 hombres, sin contar \w los|strong="H5921"\w* \w que|strong="H4480"\w* venían \w a|strong="H3068"\w* \w nosotros|strong="H5921"\w* \w de|strong="H4480"\w* \w los|strong="H5921"\w* países vecinos.
\v 18 \w Lo|strong="H2088"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* preparaba \w para|strong="H5921"\w* un solo \w día|strong="H3117"\w* \w era|strong="H1961"\w* un \w buey|strong="H7794"\w* \w y|strong="H3588"\w* \w seis|strong="H8337"\w* \w ovejas|strong="H6629"\w* \w escogidas|strong="H1305"\w*. \w También|strong="H2088"\w* \w me|strong="H5921"\w* preparaban aves, \w y|strong="H3588"\w* una vez \w cada|strong="H3605"\w* \w diez|strong="H6235"\w* \w días|strong="H3117"\w* \w toda|strong="H3605"\w* clase \w de|strong="H5921"\w* vinos. \w A|strong="H3068"\w* pesar \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w esto|strong="H2088"\w*, \w nunca|strong="H3808"\w* exigí \w el|strong="H5921"\w* \w pan|strong="H3899"\w* correspondiente \w al|strong="H5921"\w* \w gobernador|strong="H6346"\w*, \w porque|strong="H3588"\w* \w el|strong="H5921"\w* trabajo \w era|strong="H1961"\w* pesado \w para|strong="H5921"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*.
\p 
\v 19 \w Acuérdate|strong="H2142"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w para|strong="H5921"\w* \w bien|strong="H2896"\w*, oh \nd ʼElohim\nd* \w mío|strong="H5921"\w*, \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w hice|strong="H6213"\w* \w por|strong="H5921"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*.
\c 6
\s1 Trampas de los enemigos
\p 
\v 1 \w Sucedió|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* Sanbalat, \w Tobías|strong="H2900"\w*, Gesem \w el|strong="H1931"\w* árabe \w y|strong="H1571"\w* \w el|strong="H1931"\w* \w resto|strong="H3499"\w* \w de|strong="H3588"\w* nuestros enemigos \w oyeron|strong="H8085"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* reconstruí \w el|strong="H1931"\w* \w muro|strong="H2346"\w* \w y|strong="H1571"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w quedó|strong="H3498"\w* alguna brecha \w en|strong="H5704"\w* \w él|strong="H1931"\w*, \w aunque|strong="H3588"\w* \w hasta|strong="H5704"\w* \w ese|strong="H1931"\w* momento \w no|strong="H3808"\w* \w habían|strong="H1961"\w* colocado las hojas \w de|strong="H3588"\w* las \w puertas|strong="H1817"\w*,
\v 2 Sanbalat y Gesem mandaron \w a|strong="H3068"\w* decirme: \w Ven|strong="H3212"\w* y reunámonos \w en|strong="H3259"\w* Kefirim, \w en|strong="H3259"\w* \w el|strong="H6213"\w* valle \w de|strong="H7451"\w* Ono. Pero \w ellos|strong="H1992"\w* pensaban \w hacerme|strong="H6213"\w* daño.
\p 
\v 3 \w Les|strong="H5921"\w* \w envié|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w para|strong="H5921"\w* decirles: \w Yo|strong="H6213"\w* \w hago|strong="H6213"\w* una \w gran|strong="H1419"\w* \w obra|strong="H4399"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w puedo|strong="H3201"\w* \w ir|strong="H7971"\w*. ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* debe cesar \w la|strong="H5921"\w* \w obra|strong="H4399"\w* \w al|strong="H5921"\w* dejarla \w yo|strong="H6213"\w* \w para|strong="H5921"\w* \w ir|strong="H7971"\w* \w a|strong="H3068"\w* ustedes?
\v 4 Insistieron cuatro \w veces|strong="H6471"\w* sobre \w este|strong="H2088"\w* \w asunto|strong="H1697"\w*, pero yo les respondí \w de|strong="H1697"\w* la misma \w manera|strong="H1697"\w*.
\p 
\v 5 Entonces Sanbalat me \w envió|strong="H7971"\w* \w a|strong="H3068"\w* su esclavo con \w este|strong="H2088"\w* \w asunto|strong="H1697"\w* \w por|strong="H1697"\w* quinta \w vez|strong="H6471"\w* con \w una|strong="H6471"\w* carta \w abierta|strong="H6605"\w* en la \w mano|strong="H3027"\w*,
\v 6 \w en|strong="H5921"\w* \w la|strong="H5921"\w* cual estaba \w escrito|strong="H3789"\w*: \w Se|strong="H5921"\w* rumora \w entre|strong="H5921"\w* \w los|strong="H5921"\w* \w pueblos|strong="H1471"\w*, \w y|strong="H5921"\w* Gasmú \w lo|strong="H1697"\w* \w dice|strong="H1697"\w*, \w que|strong="H5921"\w* tú \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w judíos|strong="H3064"\w* \w piensan|strong="H2803"\w* rebelarse. \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, reconstruyes \w el|strong="H5921"\w* \w muro|strong="H2346"\w*, \w y|strong="H5921"\w* \w según|strong="H5921"\w* esos rumores, tú vas \w a|strong="H3068"\w* ser \w su|strong="H1933"\w* \w rey|strong="H4428"\w*.
\v 7 \w Y|strong="H3068"\w* \w que|strong="H6258"\w* \w además|strong="H5921"\w* designaste \w profetas|strong="H5030"\w* \w para|strong="H5921"\w* \w que|strong="H6258"\w* \w te|strong="H5921"\w* proclamen \w en|strong="H5921"\w* Jerusalén \w y|strong="H1571"\w* digan: ¡Hay \w rey|strong="H4428"\w* \w en|strong="H5921"\w* \w Judá|strong="H3063"\w*! \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, \w estas|strong="H5975"\w* \w palabras|strong="H1697"\w* serán oídas \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w*. \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, \w ven|strong="H3212"\w* \w y|strong="H1571"\w* consultemos \w juntos|strong="H3162"\w*.
\p 
\v 8 \w Entonces|strong="H3588"\w* \w envié|strong="H7971"\w* \w a|strong="H3068"\w* decirle: \w No|strong="H3808"\w* \w hay|strong="H1961"\w* \w tal|strong="H1697"\w* \w cosa|strong="H1697"\w* \w como|strong="H3588"\w* \w dices|strong="H1697"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* las inventas \w por|strong="H3588"\w* iniciativa propia.
\p 
\v 9 \w Porque|strong="H3588"\w* \w ellos|strong="H3027"\w* querían atemorizarnos. Pensaban \w que|strong="H3588"\w* nuestras \w manos|strong="H3027"\w* estarían debilitadas \w por|strong="H3588"\w* \w la|strong="H3588"\w* \w obra|strong="H4399"\w* \w y|strong="H3588"\w* \w que|strong="H3588"\w* desistiríamos \w de|strong="H4480"\w* \w ella|strong="H3605"\w*. \w Pero|strong="H3588"\w* \w ahora|strong="H6258"\w*, ¡fortalece \w Tú|strong="H6213"\w* mis \w manos|strong="H3027"\w*!
\p 
\v 10 \w En|strong="H8432"\w* \w cuanto|strong="H3588"\w* \w a|strong="H3068"\w* mí, fui \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Semaías|strong="H8098"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Delaía, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Mehe-tabel, \w porque|strong="H3588"\w* \w él|strong="H1931"\w* \w estaba|strong="H1004"\w* \w encerrado|strong="H6113"\w*. \w Y|strong="H3068"\w* \w él|strong="H1931"\w* dijo: Reunámonos \w dentro|strong="H8432"\w* del \w Templo|strong="H1964"\w* \w de|strong="H3588"\w* \nd ʼElohim\nd* \w y|strong="H3588"\w* cerremos las \w puertas|strong="H1817"\w* del Santuario, \w porque|strong="H3588"\w* vienen \w a|strong="H3068"\w* matarte. \w Sí|strong="H3588"\w*, \w esta|strong="H1931"\w* \w noche|strong="H3915"\w* vienen \w a|strong="H3068"\w* matarte.
\p 
\v 11 Pero respondí: ¿Un hombre \w como|strong="H3644"\w* yo debe huir? ¿\w Y|strong="H3068"\w* podría un hombre \w como|strong="H3644"\w* yo entrar en \w el|strong="H4310"\w* \w Templo|strong="H1964"\w* para salvar su vida? \w No|strong="H3808"\w* entraré.
\v 12 \w Y|strong="H3068"\w* percibí \w que|strong="H3588"\w* \nd ʼElohim\nd* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w envió|strong="H7971"\w*, \w pero|strong="H3588"\w* pronunciaba esa profecía \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w porque|strong="H3588"\w* \w Tobías|strong="H2900"\w* \w y|strong="H3588"\w* Sanbalat \w lo|strong="H3808"\w* sobornaron.
\v 13 \w Porque|strong="H4616"\w* \w él|strong="H1931"\w* \w fue|strong="H1961"\w* sobornado \w para|strong="H4616"\w* atemorizarme, con \w el|strong="H1931"\w* propósito \w de|strong="H3372"\w* \w que|strong="H1931"\w* \w yo|strong="H6213"\w* actuara \w de|strong="H3372"\w* \w ese|strong="H1931"\w* modo y pecara, y \w así|strong="H3651"\w* \w tener|strong="H1961"\w* motivo \w para|strong="H4616"\w* difamarme.
\p 
\v 14 ¡\w Acuérdate|strong="H2142"\w*, oh \nd ʼElohim\nd* mío, \w de|strong="H3372"\w* \w Tobías|strong="H2900"\w* \w y|strong="H1571"\w* Sanbalat, en conformidad \w con|strong="H1571"\w* sus palabras, \w y|strong="H1571"\w* \w de|strong="H3372"\w* \w la|strong="H1571"\w* \w profetisa|strong="H5031"\w* Noadías \w y|strong="H1571"\w* \w los|strong="H1961"\w* \w demás|strong="H1571"\w* \w profetas|strong="H5030"\w* \w que|strong="H1571"\w* trataban \w de|strong="H3372"\w* atemorizarme!
\v 15 El \w muro|strong="H2346"\w* fue terminado el 25 \w de|strong="H2568"\w* Elul, en 52 \w días|strong="H3117"\w*.
\p 
\v 16 \w Cuando|strong="H3588"\w* \w todos|strong="H3605"\w* nuestros enemigos \w lo|strong="H6213"\w* \w oyeron|strong="H8085"\w*, \w sucedió|strong="H1961"\w* \w que|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H1471"\w* vecinos \w tuvieron|strong="H1961"\w* temor. \w Se|strong="H3045"\w* sintieron humillados, \w porque|strong="H3588"\w* reconocieron \w que|strong="H3588"\w* \w este|strong="H2063"\w* trabajo \w fue|strong="H1961"\w* \w hecho|strong="H6213"\w* \w por|strong="H3588"\w* nuestro \nd ʼElohim\nd*.
\p 
\v 17 \w En|strong="H5921"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* \w iban|strong="H1980"\w* \w muchas|strong="H7235"\w* cartas \w de|strong="H5921"\w* \w los|strong="H1992"\w* jefes \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w a|strong="H3068"\w* \w Tobías|strong="H2900"\w*, \w y|strong="H1571"\w* \w las|strong="H1992"\w* \w de|strong="H5921"\w* \w Tobías|strong="H2900"\w* llegaban \w a|strong="H3068"\w* \w ellos|strong="H1992"\w*.
\v 18 \w Porque|strong="H3588"\w* \w muchos|strong="H7227"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w se|strong="H1931"\w* conjuraron \w con|strong="H3588"\w* \w él|strong="H1931"\w*, \w pues|strong="H3588"\w* \w era|strong="H1931"\w* \w yerno|strong="H2860"\w* \w de|strong="H3588"\w* Secanías, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Ara, \w y|strong="H3588"\w* \w su|strong="H1931"\w* \w hijo|strong="H1121"\w* \w Johanán|strong="H3076"\w* \w tomó|strong="H3947"\w* \w como|strong="H3588"\w* esposa \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w hija|strong="H1323"\w* \w de|strong="H3588"\w* Mesulam, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Berequías.
\v 19 \w Asimismo|strong="H1571"\w* me \w contaban|strong="H1961"\w* las \w buenas|strong="H2896"\w* obras \w de|strong="H6440"\w* \w él|strong="H1571"\w*, \w y|strong="H1571"\w* le referían mis \w palabras|strong="H1697"\w*. \w Y|strong="H3068"\w* \w Tobías|strong="H2900"\w* \w enviaba|strong="H7971"\w* cartas \w para|strong="H1961"\w* atemorizarme.
\c 7
\s1 Previsiones de seguridad
\p 
\v 1 \w Cuando|strong="H1961"\w* el \w muro|strong="H2346"\w* \w quedó|strong="H1961"\w* reconstruido y coloqué las hojas de las \w puertas|strong="H1817"\w*, \w los|strong="H1961"\w* \w porteros|strong="H7778"\w*, \w los|strong="H1961"\w* \w cantores|strong="H7891"\w* y \w los|strong="H1961"\w* \w levitas|strong="H3881"\w* \w se|strong="H1961"\w* encargaron de sus funciones.
\v 2 \w Entonces|strong="H3588"\w* \w puse|strong="H6680"\w* \w al|strong="H5921"\w* frente \w de|strong="H5921"\w* Jerusalén \w a|strong="H3068"\w* \w mi|strong="H5921"\w* hermano \w Hanani|strong="H2607"\w*, \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w Hananías|strong="H2608"\w*, \w jefe|strong="H8269"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* ciudadela, \w pues|strong="H3588"\w* \w éste|strong="H1931"\w* \w era|strong="H1931"\w* un hombre fiel \w y|strong="H3588"\w* \w temía|strong="H3372"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd* \w más|strong="H3588"\w* \w que|strong="H3588"\w* \w muchos|strong="H7227"\w*.
\v 3 \w Les|strong="H1992"\w* dije: \w Las|strong="H1992"\w* \w puertas|strong="H1817"\w* \w de|strong="H5048"\w* Jerusalén \w no|strong="H3808"\w* \w serán|strong="H1992"\w* \w abiertas|strong="H6605"\w* \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* caliente \w el|strong="H3427"\w* \w sol|strong="H8121"\w*. \w Aunque|strong="H5704"\w* \w los|strong="H1992"\w* porteros estén \w presentes|strong="H5975"\w*, \w las|strong="H1992"\w* \w puertas|strong="H1817"\w* permanecerán cerradas \w y|strong="H5704"\w* trancadas. Sean designados vigías \w de|strong="H5048"\w* \w entre|strong="H3808"\w* \w los|strong="H1992"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5048"\w* Jerusalén, cada cual \w en|strong="H5704"\w* \w su|strong="H1992"\w* vigilia, \w y|strong="H5704"\w* cada uno \w frente|strong="H5048"\w* \w a|strong="H3068"\w* \w su|strong="H1992"\w* propia \w casa|strong="H1004"\w*.
\p 
\v 4 Porque la \w ciudad|strong="H5892"\w* era \w espaciosa|strong="H7342"\w* y \w grande|strong="H1419"\w*, pero la \w gente|strong="H5971"\w* \w que|strong="H5971"\w* vivía allí era \w poca|strong="H4592"\w*, y las \w casas|strong="H1004"\w* aún no \w estaban|strong="H5971"\w* reconstruidas.
\s1 Censo de los repatriados
\p 
