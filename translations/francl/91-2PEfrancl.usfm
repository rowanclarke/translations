\v 14 \w car|strong="G3754"\w* \w je|strong="G1473"\w* \w sais|strong="G1492"\w* \w que|strong="G3754"\w* \w je|strong="G1473"\w* \w la|strong="G2532"\w* \w quitterai|strong="G2532"\w* \w bientôt|strong="G2532"\w*, \w ainsi|strong="G2532"\w* \w que|strong="G3754"\w* Notre-Seigneur \w Jésus-Christ|strong="G2532"\w* \w me|strong="G1473"\w* \w l|strong="G2532"\w*’\w a|strong="G2532"\w* \w fait|strong="G2532"\w* \w connaître|strong="G1213"\w*.
