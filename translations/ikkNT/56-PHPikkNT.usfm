\id PHP Ika New Testament 2009 
\h Ndị Filipi 
\toc1 Ẹhụhụọ-Ozi Pọlụ Dejẹnni Ndị Filipi 
\toc2 Ndị Filipi 
\toc3 Fili 
\mt2 Ẹhụhụọ-Ozi Pọlụ Dejẹnni 
\mt1 Ndị Filipi 
\c 1  
\cl Isi Nke Ohu 
\p  
\v 1 Pọlụ lẹ Timoti de ẹkụkwọ-ozini. Ẹnyi wụ igbọn Kraịstị wụ Jizọsị. Ẹnyi rị e dejẹnni ndị ile rị imẹ Kraịstị wụ Jizọsị, ndị nke Osolobuẹ, hụn rị Filipi ya—uwẹ lẹ ndị-isi wẹ lẹ ndị-ọrụn ụka wẹ.  
\v 2 Ẹfọma lẹ udọn hụn gha ẹka Osolobuẹ Nẹdi ẹnyi lẹ Nna ẹnyi wụ Jesu Kristi bịa ya rịnị ụnụ. 
\s1 Pọlụ E Mẹ Ni Wẹ Ekpere 
\p  
\v 3 M'e ye Osolobuẹ m ekele ogẹn ile m gi a nyanhan ụnụ;  
\v 4 ogẹn ile m gi e mẹ ni ụnụ ile ekpere, m'e gi ịghọghọ e mẹ ẹ,  
\v 5 makẹni ọnụ hụ e yeni m ẹka imẹ ọrụn oziọma—ghakwọrị ụhụọhịn-ibuzọ hụ ọnụ nụ a d'e ru nwan ogẹnni.  
\v 6 O weghọ m ẹnya nị Onyẹ hụ hụn bidọn ọrụn-ọmanị imẹ ụnụ, k'a gha e mẹ ẹ e zu oke d'e ru Ụhụọhịn Kraịstị wụ Jizọsị k'e gi bịa.  
\v 7 O furughọ nị oku ụnụ a rị m ẹnịna, makẹni ụnụ rị m obi ogẹn ile! Ẹghẹẹ, makẹni mmẹ lẹ ụnụ e keyetarị ibe ẹnyi ihiẹn Osolobuẹ gi gọzi ẹnyi—kẹ ebe m rị imẹ ngan, kẹ ebe m rị a kwandọn oziọma, e mẹ ihiẹn o gi e werichanrịn ọnọdị.  
\v 8 Osolobuẹ wụ ọshẹri m nị ụnụ a da m ọda-ọda—ụdị ọdịda hụn gha ẹka Kraịstị wụ Jizọsị bịa. 
\p  
\v 9 Ekpere m wụ nị ihiẹn-ọsụsụọ ụnụ nwẹ k'a gha e mẹ ụnụ e nwẹ amamihiẹn lẹ nghọha, e nwẹ, e nwẹwaye—  
\v 10 kẹni ụnụ hụn ụzọ sa ẹka a họrị ihiẹn ka mma sụọ—ụnụ a wụrụ ndị nwọnlẹni ntụpọ mọbụ nkọrịanị Ụhụọhịn Kristi k'e gi bịa,  
\v 11 makẹni o ru a hụn w'a nị ndụn ụnụ a mịjungụọ mkpụrụ rị mma Chuku chọ, hụn gha ẹka Jesu Kristi a bịa. Ọnwan k'e wẹhẹ ni Osolobuẹ ọghọ lẹ ọjịja-mma. 
\s1 Jesu Rị Imẹ M E Bi 
\p  
\v 12 Umunẹ m, m chọ nị ụnụ marịn nị ihiẹn mẹni m e yegụọ nị oziọma ẹka ghagbarị nke-esi.  
\v 13 O mẹgụọdẹ ndị ile rị ọgwa eze-kanị wụ Siza lẹ ndị ọzọ ile marịn nị ifiri Kraịstị kẹ m gi rị ngan. 
\p  
\v 14 Ngan m rị e mẹgụọzị obi rukẹnmẹ ndị itu-Kraịstị ibe ẹnyi bu ọda anị imẹ Di-nwọnni-ẹnyi, w'e kushi nwan oku-Osolobuẹ ikẹn karị kẹ w'e ku ẹ mbụ—egun arịzị wẹ ẹnya. 
\p  
\v 15 Ndị hụ imẹ wẹ gi iwe-ẹnya e zi ozi Kristi—e gi ẹ a dọ ọnụ. Kanị, ndị ọzọ bu ihiẹn rị mma obi e zi ẹ.  
\v 16 Ndị hụ bu ihiẹn rị mma obi e zi ẹ gi ihiẹn-ọsụsụọ e zi ya wụ ozi Kraịstị, makẹni a marịngụọ wẹ nị Osolobuẹ mẹ wẹ bu m che imẹ ngannị makẹ ichẹdọn lẹ ịkwadọn oziọma.  
\v 17 Ndị hụ gi iwe-ẹnya e zi ẹ gi ozi wẹ rị e zini Kristi a chọ nke wẹ, ọ rịnị a gha wẹ akpakalị obi a pụha; wẹ rị a chọhụ nị wẹ we afụnfụn cheni afụnfụn m rị a ta imẹ ngannị m rị. 
\p  
\v 18 Kanị o nwọnni ihiẹn ọ wụ! Hụn ka m mkpa, hụn m gi a ghọghọ, wụ nị wẹ hụ e gi ụzọ ile e zi ozi Kraịstị, kẹ wẹ bu ihiẹn rị mma obi e zi ẹ kẹ wẹ bu eje-ihiẹn obi. 
\p Ẹghẹẹ, m k'a gha a ghọghọ,  
\v 19 makẹni a marịngụọ m nị wẹ k'a hatu m—ghahanị ekpere ụnụ lẹ eyemẹka Mmọn\it -nsọ\it* Jesu Kristi.  
\v 20 M nwẹkẹnmẹ olile-ẹnya nị egikọ m egun mẹ ihiẹn ifẹnrẹn e gi mẹ m; kama, nị m k'e kuzi oku ẹ kikẹnni, kushizi ẹ ikẹn—kẹ m dọn e ku ẹ mbụ—gi ẹhụ m buli Kristi elu—kẹ ghahanị ịrịn'a ndụn, kẹ ghahanị ịnwụnn'a ọnwụn. 
\p  
\v 21 O mẹ nke m, m rị ndụn, m rị nị Kraịstị; m nwụnhụn, erere rọ.  
\v 22 Kanị, m rị ndụn imẹ ẹhụnị, a rụnpụha nị m Kraịstị mkpụrụ: amarịnzị m nwan hụn m k'a hanrịn!  
\v 23 M ri e roshi azụụnnị, e roshi azụụnnị: k'ọ rị m, a la m ụwanị tọ d'e du Kristi nọdị—makẹni ọhụn ka mma.  
\v 24 Kanị, m rị ndụn, ịya k'a ka ụnụ ẹka e yeni. 
\p  
\v 25 Makẹni o wegụọ m ẹnya nị m rị ndụn k'a ka ụnụ ẹka e yeni, a marịngụọ m nị m k'a nọdị, rụnsọnmẹ ihiẹn m rị a rụn ebe ụnụ ile rị, kẹni ụnụ hụn ụzọ a gha ihun imẹ okukwe, a ghọghọ imẹ okukwe.  
\v 26 Ya wụ nị wẹ k'a hatu m, a bịazị m d'e kunrun ụnụ—ọbịbịa m a wụrụ nị ụnụ ihiẹn ụnụ e gi nyankẹnmẹ isi ọda-ọda imẹ Kristi wụ Jesu. 
\p  
\v 27 Ka bisọnmẹ ni obibi furu oziọma Kristi, kẹni ọ wụrụ nị, kẹ m bịa d'a hụn ụnụ kẹ abịanị m—nị ntịn kẹ m gihụ nụ ukwere ụnụ, e gi m'ẹ dọn nị ụnụ gi mmọn ohu wuzo, lẹ ni ọnụ gi obi ohu a lụnị ụzọ-Kraịstị hụn rị imẹ oziọma ọgụn;  
\v 28 e gizịkwọ m'a dọn nị ụnụ egini egun ndị-iṅẹnrẹn ụnụ belụa okukwe ụnụ kaka akp'ohu. Ọhụn k'a ghọsị wẹ nị wẹ k'a la ntikpọ, ghọsịzịkwọ wẹ nị ụnụ nwẹn k'e nwẹ nzụọfụha. Osolobuẹ ya jẹnkọ d'a han a mẹ ẹrịra.  
\v 29 Makẹni, Osolobuẹ e yegụọ ụnụ ezigbo oghere ife Kraịstị, ẹlẹ ghahanị ikwerini n'ẹ sụọ, kanị ghahazịkwọnị ịta n'a afụnfụn. Ịya kẹ ụnụ rị nwan a ta n'a—  
\v 30 makẹni ụnụ e shimẹgụọ nwan ọnwụn ohu hụ ụnụ hụn kẹ m rị e shi mbụ—ụnụ a nụgụọzị nị m rịkwọ nwan e shi ẹ. 
\c 2  
\cl Isi Nke Ẹbụọ 
\s1 Welụa Nị Enwẹn Ụnụ Alị Kẹ Kraịstị 
\p  
\v 1 Omẹni ịwụ ndị nke Kristi a gba umẹ; omẹni ihiẹn-ọsụsụọ e mẹ ịhịan a rọkọ ibe ẹ obi; omẹni ẹnyi ile hụ e mẹkọ imẹ Mmọn-nsọ; omẹni ịhịan e mẹ ni ibe ẹ ẹfọma, a nị k'ọ rị ibe ẹ e mẹtụ a obi—  
\v 2 mẹ ni nwan nị ịghọghọ m zu oke. Mẹ n'ẹ ghahanị iro ihiẹn ohu, inwọntarị ihiẹn-ọsụsụọ, ikwerigbamanị, ịchụ ihiẹn ohu.  
\v 3 Emẹkwọlẹ ihiẹn ọwụlẹ n'i gi ẹ chọrị nke i sụọ mọbụ nị wẹ hụn ị. Ka e welụa nị enwẹn ụnụ alị, e ye ibe ụnụ ọghọ karị enwẹn ụnụ.  
\v 4 Onyẹ-onyẹ imẹ ụnụ k'a rịzịkwọ a chọ ọrịnịmma ibe ẹ, ẹlẹ nke ya lẹ enwẹn ẹ sụọ. 
\p  
\v 5 A gụn nị agụngụn ohu hụ Kraịstị wụ Jizọsị gụn: 
\q1  
\v 6 Ọsụọn'a nị Osolobuẹ k'ọ wụchanrịn, 
\q2 o mẹdẹni ni 'ya lẹ Osolobuẹ han. 
\q1  
\v 7 Kama, 
\q2 ọ nọ bu ihiẹn ọ wụ che ụsụọ, 
\q2 wụrụ odibo; 
\q1 wẹ nọ mụ a ịhịan. 
\q1 Ọ wụrụgụụ nwan ịhịan, 
\q2  
\v 8 ọ nọ wenụa enwẹn ẹ alị, e humẹ isi, 
\q2 d'e ru ebe ọ nọ kweri ni wẹ gbu ẹ— 
\q2 kweridẹ hụn wẹ gi kpọgbudẹ ẹ enu obe! 
\q1  
\v 9 Ifiri ọnwan, 
\q1 Osolobuẹ nọ weli ẹ, bushichanrịn a elu, 
\q2 bu ẹ che ọnọdị kachanrịnnị, 
\q1 ye ẹ ẹfan 
\q2 hụn kachanrịn ẹfan ile. 
\q2  
\v 10 Nke wụnị, 
\q2 wẹ kpọhụ ẹfan Jesu/Jizọsị, 
\q2 ihiẹn ile rị enu-igwee lẹ elu-ụwa lẹ okpuru ụwa 
\q1 k'e gbu osekpu. 
\q1  
\v 11 Ọnụ ile k'e ku ẹ 
\q2 nị Jesu Kristi wụ Nna— 
\q1 ọghọ e gi ẹ bịanị Chuku-Nẹdi. 
\s1 Chuku Rị Ọrụn Imẹ I, Rụnma Nwan 
\p  
\v 12 Ifiri ẹ, ndị rị m obi, kẹ ụnụ dọn a gbaye m ogẹn ile, e mẹ ihiẹn m gwa ụnụ, ogẹn mmẹ lẹ ụnụ gi rị ụzọ ohu, e mẹkẹnmẹzidẹ ẹ hụnnị m rịlẹn'a, mẹsọnmẹ ni nwan ẹrịra: e gi ni egun lẹ ẹhụ-ọmụma-nni e bi, e mẹ ihiẹn ile Osolobuẹ e gi zụọpụha ụnụ.  
\v 13 Makẹni Osolobuẹ ya rị ọrụn imẹ ọnụ ogẹn ile, e mẹ ọnụ a sa ẹka a họrị nị uche ẹ kẹ ụnụ k'e mẹ, e mẹzikwọ ụnụ e mẹ ya wụ uche ẹ. 
\p  
\v 14 E mẹ ni ihiẹn ile wẹ sị ụnụ mẹ—edẹnwịnnwịnlẹ ni; adọlẹ ni,  
\v 15 kẹni ụnụ wụrụ ndị nwọnlẹni nkọrianị, ndị ẹka wẹ rị ọchan, ụmụ Osolobuẹ obibi wẹ nwẹlẹni ntụpọ—ọsụọn'a nị wẹ bi imẹ igunrun eje-agbọ rụnị ẹnya rịlẹni ụzọ ohu; nọ nị imẹ igunrun wẹ e nwun, e ke imẹ ụwanị kẹ kokisẹ.  
\v 16 Makẹni, ụnụ kwọnkẹnmẹ oku hụn e ye ndụn, a hụn m ihiẹn m'e gi nyan isi Ụhụọhịn Kraịstị k'a bịa, nị ọsọ m gba lẹ ọrụn m rụn alanị iwi. 
\p  
\v 17 Ya wụ, ọsụọn'a nị wẹ rị nwan e hupụ ndụn m kẹ manya, e hu ẹ e kpu okukwe ụnụ hụn wụ ẹjan ụnụ chụyeni Osolobuẹ, ẹfọ rị a sụọ m ụsụọ; m rị e sọn ụnụ a ghọghọ!  
\v 18 Ẹfọ ya sụọzịkwọ ụnụ ụsụọ, ụnụ e sọn m ghọghọ. 
\s1 Nyemẹka Timoti Lẹ Ẹpafrọditọsị 
\p  
\v 19 M rị e lee ẹnya nị Di-nwọnni-ẹnyi wụ Jizọsị k'a nị m zihẹ ni ụnụ Timoti ẹgwa, kẹni m nụ ozi ụnụ, ndụn a ban m.  
\v 20 Enwọn m onyẹ ọzọ hụn rị kẹ Timoti, hụn gichanrịn akpakalị obi ẹ a chọ ọrịnịmma ụnụ.  
\v 21 Ndị ile họdụnị e ro nke-wẹ, nke-wẹ, ẹlẹ nke Jesu Kristi!  
\v 22 Kanị, o mẹ nke Timoti, ụnụ lẹ enwẹn ụnụ a marịngụọ mkpa ọ rị; ụnụ a marịngụọ nị o sọn m a rụn ọrụn oziọma kẹ nwa dọn e sọn nẹdi ẹ a rụn.  
\v 23 M bu ẹ nwan obi nị m zihẹni ụnụ ịya ẹgwa—m marịngụhụ kẹ ihiẹn k'a rị nị m ebeni.  
\v 24 Obi ru m anị imẹ Di-nwọnni-ẹnyi nị mmẹ lẹ enwẹn m k'a bịazịkwọ ẹgwa. 
\p  
\v 25 K'osilẹrị, e rogụọ m n'ọ rị mkpa nị m zihẹni ụnụ Ẹpafrọditọsị. Nwẹnẹ m k'ọ wụ imẹ Nna-ẹnyi; ọ wụzịkwọ onyẹ-ọrụn lẹ onyẹ-agha ibe m. Onyẹ-ozi ụnụ rọ, hụn ụnụ zihẹ, hụn rị a rụnnị ụnụ ghahanị iyeni m ẹka.  
\v 26 M zila a makẹni ụnụ rị a da a ọda-ọda, ọ fụka a nị ọnụ nụ nị emu kụ a.  
\v 27 Ezioku-ezioku, emu kụ a ọda-ọda, o te d'a nwụndẹ! Kanị, Osolobuẹ nọ mẹ omikẹn ẹ—kanị ẹlẹ ịya sụọ k'o mẹ n'ẹ, o mẹzikwọ nị mmẹ nwẹn ya, amamgbe ẹkwan m a waye. 
\p  
\v 28 Ọ rị nwan a dụkẹnmẹ m nị m zihẹzi ẹ, kẹni ụnụ hụn a, ẹfọ a sụọ ụnụ ụsụọ—uhue m e belụa.  
\v 29 Gi ni nwan ịghọghọ nabanhan a kẹ ẹnyi e mẹ imẹ Di-nwọnni-ẹnyi; a gbaye ni ndị nọ kẹ ịya—  
\v 30 makẹni ọrụn Kraịstị e d'a napụ a ndụn a, o buzidẹ ndụn a che ọb'ẹka ebe ọ rị e yeni m ẹka ụnụ salẹni ẹka yeni m makẹni ebe ụnụ rị e tekẹ. 
\c 3  
\cl Isi Nke Ẹtọ 
\p  
\v 1 Umunẹ m, m gini d'e mẹkin, m sị ụnụ, e nwọn ni anwịnrịn imẹ Di-nwọnni-ẹnyi. 
\p Ndụn idezini ụnụ ihiẹn m degụnị ụnụ mbụ agụkọ m—makẹni o k'e chemẹ ụnụ. 
\s1 Natọ Ihiẹn I Gi E Dọn Ẹnya Ogẹn Mbụ 
\p  
\v 2 Kpachanfụ nị ẹnya ebe nkitẹ ndị hụ rị! Kpachanfụ nị ẹnya ebe wẹ rị makẹni eje-ihiẹn kẹ wẹ rị e mẹ; ẹghẹẹ, kpachanfụ nị ẹnya ebe ndị hụ e bekịka ịhịan ẹhụ nị wẹ rị a kwa ugun rị!  
\v 3 Makẹni, ẹnyi wụ ndị hụn kwa ezigbo ugun: ẹnyi ndị rị e fe Osolobuẹ ofufe imẹ-mmọn ghahanị Mmọn-nsọ; ndị gi Kraịstị wụ Jizọsị e dọn ẹnya, a nyan isi; ndị ghalẹni e gi ihiẹn ẹnya e legha e dọn ẹnya—  
\v 4 ọsụọn'a nị mmẹ nwẹn e nwẹghọzikwọ ihiẹn ẹnya e legha hụn nkẹ m'e gi dọn ẹnya, gi ẹ nyan isi. Ẹghẹẹ, emẹni ndị ọzọ enwọnghọ ihiẹn wẹ wụ rịkẹ ịhịan hụn w'e gi nyan isi, mmẹ ka wẹ e nwẹ:  
\v 5 Wẹ kwa m ugun kẹ m rị nwa akp'ọhịn ẹsatọ; m wụ nwa-di-alị Izrẹlụ—onyẹ ikpun-ụlọ Bẹnjamini; onyẹ Hibru kẹti-kẹti—onyẹ-Hibru ndị-Hibru mụ. Ọ mẹ nke idọnmẹ Iwu Mozizi, m te wụ onyẹ-Farisi,  
\v 6 o mẹ nke adụdụ, m kpokpo ụka Kraịstị; nke ịrị-ọchan ghahanị idọnmẹ Iwu Mozizi, ahụnnị wẹ ihiẹn ọwụlẹ w'e gi kọrịanị m. 
\s1 Ihiẹn Ahụn Kachanrịn Mma W'e Nwẹ 
\p  
\v 7 Kanị, e gigụọ m nwan ifiri Kristi gụn ihiẹn ile te wụ erere ebe m rị ye ihiẹn la iwi.  
\v 8 Ẹlẹdẹ ihiẹn ndị hụ sụọ—e werigụọ m ihiẹn ile nọkẹ ihiẹn na iwi, makẹni onwẹni ihiẹn wẹ wụ ebe ihiẹn kachanrịn wẹ ile mkpa rị, hụn wụ ịmarịn Kraịst' Jizọsị wụ Di-nwọnni-m—hụn m gigụụ ifiri ẹ nị ihiẹn ile la. Kanị, m weri wẹ ile kẹ nsịn, kẹni m kwọnkẹnmẹ Kraịstị,  
\v 9 rịsọnmẹ imẹ ẹ. Ẹlẹ nke onyẹ rị ọchan ẹnya enwẹn ẹ makẹni ọ n'e dọnmẹ Iwu Mozizi, kama, rịkẹ onyẹ rị ọchan makẹni o kwerigụọnị Kraịstị, e gi Kraịst' e dọn ẹnya—ịrị-ọchan ahụn gha ẹka Osolobuẹ a bịa, hụn wẹ gi okukwe e nwẹhẹn.  
\v 10 M chọ nị m marịn Kraịstị lẹ ikẹn hụ o gi gha ọnwụn lihi, sọn ẹ ta afụnfụn ọ ta, sọn ẹ nwụn ọnwụn ọ nwụn,  
\v 11 kẹn'o nwẹdẹ kẹ m'e mẹ rị ndị k'a gha ọnwụn lihi. 
\s1 Lịlịma Nị 
\p  
\v 12 Ẹlẹni e nwọnhẹngụọlẹ m ihiẹn ndịnị mọbụ nị e zuchanrịngụọlẹ m oke. Kama, m'a lịlịma a chụ a, kẹni m nwẹhẹn ẹ—kẹni m nwụndọn ihiẹn hụ Kristi wụ Jesu gi ufiri ẹ nwụndọn m, gi m hẹnrin nke ẹ.  
\v 13 Umunẹ, arị m'e ro ni e rugụọ m'a. Mba! Kama, ihiẹn ohuni kẹ m'e mẹ: m'a zọ ihiẹn ndị hụn m rụngụụ mbụ—nu wẹ ye azụụn, a nwankẹnmẹ nị m kunrun ihiẹn rị ihun.  
\v 14 M'a lịlịma, e buchanrịn ihun e zimẹ ebe m gbakọ, kẹni m nwọnhẹn ihiẹn hụn Osolobuẹ jẹnkọ d'e ye ẹnyi, hụn o gi ifiri ẹ kpọ ẹnyi oku elu-igwee ọ kpọ ẹnyi ghahanị Kraịstị. 
\p  
\v 15 Ya wụ, ẹnyi ile ka-ẹhụ imẹ mmọn furu nwan nị ẹnyi e nwọn ụdị agụngụnnị. Kanị, omẹni ịhịan rị e ro ichẹn, Osolobuẹ k'e mẹ ẹ n'ọ ghọta ihiẹnni.  
\v 16 Ka nị ẹnyi kwọnkẹnmẹ hụn ẹnyi nwẹhẹngụụ. 
\s1 Ndị Wẹ K'e Leri 
\p  
\v 17 Umunẹ m, sọn ni ndị ọzọ a kịnrịn m; leri ni obibi ndị hụ e lerini ẹnyi.  
\v 18 Makẹni, ndị bu ọda e bi kẹ ndị-iṅẹnrẹn obe Kraịstị. A gwaọlẹ m ụnụ ya mgbe ole-lẹ-ole mbụ; m gi nwan ẹnya-mirin a gwazị ụnụ ya.  
\v 19 Wẹ shikọ ntikpọ; ẹfọ wẹ wụ Chuku wẹ; ihiẹn nkẹ e mẹ wẹ ifẹnrẹn k'e wẹ gi a nyan isi; ihiẹn-ụwa ihiẹn-ụwa kẹ wẹ e ro. 
\p  
\v 20 Kanị, o mẹ nke ẹnyi, ẹnyi wụ ụmụ-di-alị enu-igwee; ẹnyi rị nwan a tụ ẹnya Onyẹ-nzụọpụha wụ Nna-ẹnyi wụ Jesu Kristi, hụn gha ebẹhụ lala.  
\v 21 O k'e nwọnhutọ ẹhụ ẹnyi ndịnị zelẹni, hụn a nwụnnị, mẹmẹ wẹ nị wẹ nọ kẹ ẹhụ a hụn nwẹ ọghọ; o k'e mẹ ẹ ghahanị ikẹn hụ o gi saẹka e bu ihiẹn ile e che okpuru ẹ. 
\c 4  
\cl Isi Nke Ẹnọ 
\p  
\v 1 Umunẹ m rị m obi, hụn rị a danị m, ụnụ wụ ịghọghọ m lẹ ihiẹn wẹ k'e gi tu m ugọn! Ndị ihiẹn wẹ a sụọ m, wuzo ni nwan imẹ Di-nwọnni-ẹnyi ẹrịra! 
\s1 Ndụnmọdụn 
\p  
\v 2 Yodia, dodo! Sintike, dodo! Ụnụ ẹbụọ, dodo ni, e gi ni obi ohu e bi—nọkẹ ndị rị imẹ Di-nwọnni-ẹnyi.  
\v 3 Ẹghẹẹ, 'yụ wụ onyẹ-ọrụn ibe m furu wẹ gi e dọn ẹnya, m rị a rịọ ị n'ị yeni ikpoho ndịnị ẹka, makẹni e sọngụọ wẹ m lụnị oziọma ọgụn—uwẹ lẹ Klemẹnti lẹ ndị ọzọ ile mmẹ lẹ wẹ gba a rụn ọrụn—hụn ẹfan wẹ rị imẹ Ẹhụhụọ nke ndụn. 
\p  
\v 4 A ghọghọ nị imẹ Di-nwọnni-ẹnyi ogẹn ile! E kuzi m'ẹ: a ghọghọ nị! 
\p  
\v 5 Ịhịan ile wẹ gi ẹka rị mma ụnụ gi e sọn ịhịan marịn ụnụ; Di-nwọnni-ẹnyi lala ẹgwa.  
\v 6 Ehuelẹ ni uhue ihiẹn ọwụlẹ, ka e mẹ ni ekpere imẹ ọnọdị ọwụlẹ; e gi ni arịrịọ lẹ ekele a gwa Osolobuẹ ihiẹn rị ụnụ mkpa.  
\v 7 Ogẹn hụ, udọn Osolobuẹ k'a banhan obi ụnụ—udọn ẹ, hụn ịhịan ghalẹni a ghọta—o k'e chemẹ obi ụnụ lẹ uche ụnụ imẹ Kristi wụ Jesu. 
\p  
\v 8 Umunẹ m, igi mẹkin, m sị ụnụ, e bu ni obi e che ihiẹn ọwụlẹ wụ ezioku, ihiẹn ọwụlẹ w'a gbaye, ihiẹn ọwụlẹ furuni; ihiẹn ọwụlẹ nwẹlẹni nkọrịanị, ihiẹn ọwụlẹ a sụọ ịhịan ụsụọ ẹfọ, ihiẹn ọwụlẹ wẹ gi a ja ịhịan; omumẹ ọwụlẹ rịchanrịn mma, ihiẹn ọwụlẹ furu w'a ja mma.  
\v 9 E mẹsọnmẹ ni ihiẹn ndị hụn ụnụ mụnarịn m, ihiẹn ndị hụ ụnụ gha ẹka m nwẹhẹn, ihiẹn ndị ụnụ nụ ọnụ m lẹ ihiẹn ndị ụnụ hụn m ẹka. Ụnụ mẹ wẹ, Osolobuẹ udọn k'a nọyeni ụnụ. 
\s1 Ụnụ E Mẹkẹ! 
\p  
\v 10 A ghọghọkakwọ m imẹ Onyẹ-nwọnni-ẹnyi ni ụnụ e gigụọ nwan ogẹnni nyanhan, ghọsịzị nị ụnụ hụ e ro m. Eziẹ, ụnụ hụ a chọ nị ụnụ yeni m ẹka, kanị ụnụ ahụnnị oghere ụnụ e gi mẹ ẹ.  
\v 11 Ẹlẹ ni ihiẹn rị a fụ m ọrụn kẹ m gi rị e ku ihiẹnni. Mba, makẹni a mụrụngụọ m kẹ m dọn a nị ihiẹn m nwẹ e jun m ẹfọ.  
\v 12 A marịnghọ m ihiẹn ọ wụ nị ihiẹn rị a kọ ịhịan, marịnzịkwọ ihiẹn ọ wụ nị ịhịan nwẹ ọda. A mụgụọ m ihiẹn rịn'a—nke wụ nị obi e ru m alị ebe ọwụlẹ lẹ ogẹn ọwụlẹ: kẹ m rijun ẹfọ kẹ m bu ẹgụn; kẹ e nwọnkẹ m kẹ enwẹ m enwẹ.  
\v 13 M k'a saẹka mẹ ihiẹn ile ghahanị Kraịstị, Onyẹ hụn e ye m ikẹn. 
\p  
\v 14 K'osilẹrị, ụnụ e mẹkẹ ụnụ gi yeni m ẹka buru nsọngbu m. 
\p  
\v 15 Ụnụ ndị Filipi a marịnchanrịngụọ k'o mẹ ogẹn hụ ẹnyi gi zimẹ oziọma ebe ụnụ rị—nị o nwọnni ụka ọzọ gi ihiẹn wẹ nwẹ yeni m ẹka gi sọn m rụn ogẹn m gi gha Masẹdonia pụ karị ụnụ sụọ.  
\v 16 Kẹ ogẹn m gidẹ rị Tẹsalonika, ẹlẹdẹ mgbe ohu sụọ kẹ ụnụ zihẹ ni m ihiẹn ogẹn mkpa gi kwọndọn m. 
\p  
\v 17 Ẹlẹni m chọkọ ihiẹn ụnụ k'e ye m. Kaka akp'ohu! M rị a chọ nị wẹ gụn ọrụn-ọma ụnụ yeni ụnụ kẹni o wẹhẹ ni ụnụ erere.  
\v 18 Osolobuẹ a kụchanrịngụọ m ihiẹn ile furu ni m! E nwọnchanrịngụọ m ihiẹn ile rị m mkpa—nwọnkarịdẹ! Hụnnị Ẹpafrọditọsị wẹhẹgụụ nị m ihiẹn ile ụnụ ye ẹ bịanị m, ẹfọ e jungụọ m. Oyiye e shintụ Osolobuẹ ọhụnma k'ọ wụ! Ẹjan Osolobuẹ a nabanhan rọ, ẹjan hụn a sụọ a ụsụọ.  
\v 19 Ezioku-ezioku, Osolobuẹ m jẹnkọ d'e yechanrịn ụnụ ihiẹn ọwụlẹ rị ụnụ mkpa. O k'e yehan ụnụ ya kẹ akụ-lẹ-ụba o gi nwẹ ọghọ han imẹ Kristi wụ Jesu.  
\v 20 Ọghọ ya rịnị Osolobuẹ wụ Nẹdi ẹnyi jẹnrin ejẹn. Isẹẹ! 
\s1 Ekele Ịkpazụụn Lẹ Ngọzi 
\p  
\v 21 Kele ni ndị-nsọ Kraịst' Jizọs' ile. Umunẹ ẹnyi imẹ Kraịstị hụn mmẹ lẹ wẹ rị ebeni e zi ekele ụnụ.  
\v 22 Ndị-nsọ ile e zi ekele, tụmadụ ndị rị ọgwa eze-kanị wụ Siza. 
\p  
\v 23 Ẹfọma Di-nwọnni-ẹnyi wụ Jesu Kristi mẹ ya nọyeni mmọn ụnụ.