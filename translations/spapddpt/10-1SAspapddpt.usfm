\v 27 Pero Jonatán \w no|strong="H3808"\w* \w oyó|strong="H8085"\w* cuando su padre \w conjuró|strong="H7650"\w* al \w pueblo|strong="H5971"\w*, \w por|strong="H3027"\w* \w lo|strong="H3808"\w* cual \w extendió|strong="H7971"\w* la punta \w de|strong="H5971"\w* una \w vara|strong="H4294"\w* \w que|strong="H3808"\w* tenía en la \w mano|strong="H3027"\w*, la \w metió|strong="H7971"\w* en un panal \w de|strong="H5971"\w* \w miel|strong="H1706"\w*, \w se|strong="H3808"\w* llevó la \w mano|strong="H3027"\w* \w a|strong="H3068"\w* la \w boca|strong="H6310"\w* y \w fueron|strong="H5869"\w* aclarados sus \w ojos|strong="H5869"\w*.
\p 
\v 28 \w Entonces|strong="H3117"\w* uno del \w pueblo|strong="H5971"\w* le \w habló|strong="H6030"\w*: Tu padre \w conjuró|strong="H7650"\w* expresamente al \w pueblo|strong="H5971"\w*: Maldito el hombre \w que|strong="H5971"\w* \w hoy|strong="H3117"\w* coma alimento. \w Y|strong="H3068"\w* el \w pueblo|strong="H5971"\w* estaba débil.
\p 
\v 29 \w Y|strong="H3068"\w* Jonatán respondió: \w Mi|strong="H4994"\w* padre turbó \w la|strong="H3588"\w* tierra. ¡Miren \w cómo|strong="H3588"\w* brillan mis \w ojos|strong="H5869"\w* \w por|strong="H3588"\w* probar un \w poco|strong="H4592"\w* \w de|strong="H3588"\w* \w esta|strong="H2088"\w* \w miel|strong="H1706"\w*!
\v 30 ¡\w Cuánto|strong="H3588"\w* \w más|strong="H3588"\w* \w si|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* come \w hoy|strong="H3117"\w* libremente del \w despojo|strong="H7998"\w* tomado \w de|strong="H3588"\w* sus enemigos! \w Porque|strong="H3588"\w* \w ahora|strong="H6258"\w* \w la|strong="H3588"\w* matanza \w entre|strong="H3808"\w* \w los|strong="H3588"\w* \w filisteos|strong="H6430"\w* \w no|strong="H3808"\w* \w fue|strong="H3808"\w* \w grande|strong="H7235"\w*.
\p 
\v 31 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* destruyeron \w a|strong="H3068"\w* \w los|strong="H1931"\w* \w filisteos|strong="H6430"\w* desde Micmás \w hasta|strong="H3117"\w* Ajalón. Pero \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* estaba \w muy|strong="H3966"\w* cansado.
\v 32 \w El|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5921"\w* lanzó \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w despojo|strong="H7998"\w*. \w Tomaron|strong="H3947"\w* \w ovejas|strong="H6629"\w*, \w vacas|strong="H1241"\w* \w y|strong="H5921"\w* becerros. \w Los|strong="H1121"\w* degollaron \w en|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w los|strong="H1121"\w* comió \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w*.
\v 33 Avisaron \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* \w y|strong="H5921"\w* \w le|strong="H5921"\w* dijeron: \w Mira|strong="H2009"\w*, \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w peca|strong="H2398"\w* \w contra|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w al|strong="H5921"\w* comer \w la|strong="H5921"\w* carne \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w*.
\p \w Y|strong="H3068"\w* \w él|strong="H5921"\w* respondió: Ustedes fueron infieles. Ruédenme \w ahora|strong="H3117"\w* \w hacia|strong="H5921"\w* acá una piedra \w grande|strong="H1419"\w*.
\v 34 Además \w Saúl|strong="H7586"\w* dijo: Dispérsense \w entre|strong="H3808"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w y|strong="H7794"\w* díganles \w que|strong="H3808"\w* \w cada|strong="H3605"\w* uno me traiga su \w buey|strong="H7794"\w* \w o|strong="H3068"\w* su \w oveja|strong="H7716"\w*. Degüéllenlo \w aquí|strong="H2088"\w* \w y|strong="H7794"\w* coman, \w para|strong="H5971"\w* \w que|strong="H3808"\w* coman \w y|strong="H7794"\w* \w no|strong="H3808"\w* pequen contra \nd \w Yavé|strong="H3068"\w*\nd* al comer \w la|strong="H3605"\w* carne con \w la|strong="H3605"\w* \w sangre|strong="H1818"\w*. \w Así|strong="H2088"\w* \w que|strong="H3808"\w* aquella \w noche|strong="H3915"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, \w cada|strong="H3605"\w* uno llevó su \w buey|strong="H7794"\w* en su \w mano|strong="H3027"\w* \w y|strong="H7794"\w* \w los|strong="H3605"\w* degollaron \w allí|strong="H8033"\w*.
\v 35 \w Saúl|strong="H7586"\w* \w edificó|strong="H1129"\w* un \w altar|strong="H4196"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, el cual fue el primero que él \w edificó|strong="H1129"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 36 \w Luego|strong="H5704"\w* \w Saúl|strong="H7586"\w* dijo: Bajemos \w de|strong="H5704"\w* \w noche|strong="H3915"\w* contra \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w*. Tomemos despojos \w de|strong="H5704"\w* \w ellos|strong="H3605"\w* \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* amanecer \w y|strong="H5704"\w* \w no|strong="H3808"\w* dejemos \w ni|strong="H3808"\w* un hombre \w de|strong="H5704"\w* \w ellos|strong="H3605"\w*.
\p \w Y|strong="H3068"\w* \w ellos|strong="H3605"\w* respondieron: \w Haz|strong="H6213"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w te|strong="H5869"\w* parezca \w bueno|strong="H2896"\w*. Entonces \w el|strong="H3605"\w* \w sacerdote|strong="H3548"\w* dijo: Acerquémonos \w aquí|strong="H1988"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd*.
\p 
\v 37 \w Saúl|strong="H7586"\w* \w consultó|strong="H7592"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd*: ¿Debo bajar \w contra|strong="H3478"\w* \w los|strong="H1931"\w* \w filisteos|strong="H6430"\w*? ¿\w Los|strong="H1931"\w* entregarás en \w mano|strong="H3027"\w* \w de|strong="H5414"\w* \w Israel|strong="H3478"\w*? Pero \w no|strong="H3808"\w* \w le|strong="H1931"\w* \w dio|strong="H5414"\w* respuesta \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*.
\p 
\v 38 \w Entonces|strong="H3117"\w* \w Saúl|strong="H7586"\w* dijo: Vengan \w todos|strong="H3605"\w* ustedes \w los|strong="H3605"\w* jefes del \w pueblo|strong="H5971"\w*, \w e|strong="H3068"\w* investiguen y \w vean|strong="H7200"\w* \w por|strong="H4100"\w* \w quién|strong="H4100"\w* ocurrió \w este|strong="H2063"\w* \w pecado|strong="H2403"\w* \w hoy|strong="H3117"\w*,
\v 39 \w porque|strong="H3588"\w* ¡\w vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w Quien|strong="H3605"\w* \w salva|strong="H3467"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w que|strong="H3588"\w* \w aunque|strong="H3588"\w* sea \w mi|strong="H6030"\w* \w hijo|strong="H1121"\w* Jonatán, \w de|strong="H3588"\w* seguro \w morirá|strong="H4191"\w*! \w Pero|strong="H3588"\w* \w ninguno|strong="H3605"\w* del \w pueblo|strong="H5971"\w* le \w respondió|strong="H6030"\w*.
\p 
\v 40 Dijo luego \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*: Ustedes \w estarán|strong="H1961"\w* en un \w lado|strong="H5676"\w*, y \w yo|strong="H6213"\w* y \w mi|strong="H1961"\w* \w hijo|strong="H1121"\w* Jonatán \w estaremos|strong="H1961"\w* en \w el|strong="H3605"\w* otro \w lado|strong="H5676"\w*.
\p \w Y|strong="H3068"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* respondió \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*: \w Haz|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H5971"\w* \w te|strong="H5869"\w* parezca \w bien|strong="H2896"\w*.
\p 
\v 41 \w Y|strong="H3068"\w* \w Saúl|strong="H7586"\w* dijo \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, el \nd ʼElohim\nd* \w de|strong="H5971"\w* \w Israel|strong="H3478"\w*: Da \add respuesta\add* \w perfecta|strong="H8549"\w*. \w Y|strong="H3068"\w* fueron tomados por suertes Jonatán y \w Saúl|strong="H7586"\w*, pero escapó el \w pueblo|strong="H5971"\w*.
\v 42 \w Saúl|strong="H7586"\w* dijo: Echen suertes entre mí y mi \w hijo|strong="H1121"\w* Jonatán, y Jonatán fue tomado.
\p 
\v 43 Entonces \w Saúl|strong="H7586"\w* \w dijo|strong="H5046"\w* \w a|strong="H3068"\w* Jonatán: \w Declárame|strong="H5046"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* \w hiciste|strong="H6213"\w*.
\p \w Y|strong="H3068"\w* Jonatán \w se|strong="H4100"\w* \w lo|strong="H4100"\w* \w declaró|strong="H5046"\w*: \w Ciertamente|strong="H4191"\w* \w gusté|strong="H2938"\w* un \w poco|strong="H4592"\w* de \w miel|strong="H1706"\w* con la punta de la \w vara|strong="H4294"\w* \w que|strong="H4100"\w* llevaba en mi \w mano|strong="H3027"\w*. ¿\w Y|strong="H3068"\w* voy \w a|strong="H3068"\w* \w morir|strong="H4191"\w*?
\p 
\v 44 \w Saúl|strong="H7586"\w* respondió: ¡\w Así|strong="H3541"\w* \w me|strong="H3588"\w* \w haga|strong="H6213"\w* \nd ʼElohim\nd* \w y|strong="H3588"\w* \w aún|strong="H3254"\w* \w me|strong="H3588"\w* \w añada|strong="H3254"\w*, sin duda \w morirás|strong="H4191"\w*, Jonatán!
\p 
\v 45 \w Pero|strong="H3588"\w* \w el|strong="H5973"\w* \w pueblo|strong="H5971"\w* dijo \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*: ¿Tiene \w que|strong="H3588"\w* \w morir|strong="H4191"\w* Jonatán, \w quien|strong="H6213"\w* produjo \w esta|strong="H2063"\w* \w gran|strong="H1419"\w* liberación \w en|strong="H5973"\w* \w Israel|strong="H3478"\w*? ¡\w Lejos|strong="H2486"\w* \w esté|strong="H2088"\w* \w eso|strong="H2063"\w*! ¡\w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w caerá|strong="H5307"\w* \w a|strong="H3068"\w* tierra \w ni|strong="H3808"\w* un cabello \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w cabeza|strong="H7218"\w*, \w pues|strong="H3588"\w* \w él|strong="H5973"\w* trabajó \w hoy|strong="H3117"\w* \w con|strong="H5973"\w* \nd ʼElohim\nd*! \w Así|strong="H2063"\w* \w el|strong="H5973"\w* \w pueblo|strong="H5971"\w* \w libró|strong="H6299"\w* \w a|strong="H3068"\w* Jonatán, \w y|strong="H3588"\w* \w éste|strong="H2088"\w* \w no|strong="H3808"\w* \w murió|strong="H4191"\w*.
\p 
\v 46 Entonces \w Saúl|strong="H7586"\w* \w dejó|strong="H5927"\w* de perseguir \w a|strong="H3068"\w* los \w filisteos|strong="H6430"\w*, y los \w filisteos|strong="H6430"\w* se \w fueron|strong="H1980"\w* \w a|strong="H3068"\w* su \w lugar|strong="H4725"\w*.
\p 
\v 47 Así \w Saúl|strong="H7586"\w* asumió \w el|strong="H5921"\w* \w reinado|strong="H4428"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* combatió \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus enemigos \w alrededor|strong="H5439"\w*: \w contra|strong="H5921"\w* \w Moab|strong="H4124"\w*, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón, Edom, \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* Sobá \w y|strong="H5921"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w*. Dondequiera \w que|strong="H5921"\w* iba \w los|strong="H1121"\w* hostigaba.
\v 48 \w Formó|strong="H6213"\w* un \w ejército|strong="H2428"\w*, derrotó \w a|strong="H3068"\w* \w Amalec|strong="H6002"\w* y \w libró|strong="H5337"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* de \w mano|strong="H3027"\w* de los \w que|strong="H3027"\w* \w lo|strong="H6213"\w* despojaban.
\p 
\v 49 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w* \w fueron|strong="H1961"\w* Jonatán, \w Isúi|strong="H3440"\w* y Malquisúa. \w Los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H1121"\w* sus \w dos|strong="H8147"\w* \w hijas|strong="H1323"\w* \w eran|strong="H1961"\w*: \w el|strong="H1121"\w* \w de|strong="H1121"\w* \w la|strong="H4324"\w* mayor, \w Merab|strong="H4764"\w*, y \w el|strong="H1121"\w* \w de|strong="H1121"\w* \w la|strong="H4324"\w* \w menor|strong="H6996"\w*, Mical.
\v 50 \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* la esposa \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w* \w era|strong="H1121"\w* Ahinoam, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Aimaas. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* del \w general|strong="H8269"\w* \w de|strong="H1121"\w* su \w ejército|strong="H6635"\w* \w era|strong="H1121"\w* Abner, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Ner|strong="H5369"\w*, \w tío|strong="H1730"\w* \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w*,
\v 51 porque \w Cis|strong="H7027"\w*, padre \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w*, y \w Ner|strong="H5369"\w*, padre \w de|strong="H1121"\w* Abner, eran \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Abiel.
\p 
\v 52 \w Todos|strong="H3605"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w Saúl|strong="H7586"\w* \w hubo|strong="H1961"\w* \w guerra|strong="H4421"\w* encarnizada \w contra|strong="H5921"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w*. \w Cuando|strong="H3117"\w* \w Saúl|strong="H7586"\w* \w veía|strong="H7200"\w* algún \w hombre|strong="H1368"\w* \w fuerte|strong="H2389"\w* \w y|strong="H5921"\w* \w valiente|strong="H1368"\w* \w lo|strong="H5921"\w* incorporaba.
\c 15
\s1 Desobediencia de Saúl
\p 
\v 1 \w Samuel|strong="H8050"\w* dijo \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*: \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H5921"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w que|strong="H6258"\w* \w te|strong="H5921"\w* ungiera \w como|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* su \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*. \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, \w escucha|strong="H8085"\w* \w ahora|strong="H6258"\w* \w la|strong="H5921"\w* \w voz|strong="H6963"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w Palabras|strong="H1697"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 2 \nd \w Yavé|strong="H3068"\w*\nd* de las huestes dice: \wj \w Me|strong="H3541"\w* acuerdo de \w lo|strong="H6213"\w* \w que|strong="H3541"\w* \w Amalec|strong="H6002"\w* \w hizo|strong="H6213"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* al interponerse en \w el|strong="H6213"\w* \w camino|strong="H1870"\w* cuando \w salieron|strong="H5927"\w* de \w Egipto|strong="H4714"\w*.\wj*
\v 3 \wj \w Vé|strong="H3212"\w* \w ahora|strong="H6258"\w* \w y|strong="H5921"\w* ataca \w a|strong="H3068"\w* \w Amalec|strong="H6002"\w*. Destruye \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* tiene, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w le|strong="H5921"\w* tengas compasión. \w Mata|strong="H4191"\w* \w a|strong="H3068"\w* hombres, \w mujeres|strong="H5704"\w*, \w niños|strong="H5768"\w* \w y|strong="H5921"\w* \w aun|strong="H5704"\w* \w los|strong="H5921"\w* lactantes, \w bueyes|strong="H7794"\w*, ovejas, \w camellos|strong="H1581"\w* \w y|strong="H5921"\w* \w asnos|strong="H2543"\w*.\wj*
\p 
\v 4 \w Saúl|strong="H7586"\w* \w convocó|strong="H8085"\w* al \w pueblo|strong="H5971"\w* y le pasó revista en Telaim: 200.000 guerreros y 10.000 hombres \w de|strong="H5971"\w* \w Judá|strong="H3063"\w*.
\v 5 \w Saúl|strong="H7586"\w* fue \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w* \w de|strong="H5704"\w* \w Amalec|strong="H6002"\w* \w y|strong="H5704"\w* puso una emboscada \w en|strong="H5704"\w* el valle.
\v 6 \w Y|strong="H3068"\w* \w Saúl|strong="H7586"\w* dijo \w a|strong="H3068"\w* \w los|strong="H1121"\w* ceneos: Salgan \w de|strong="H5973"\w* \w entre|strong="H8432"\w* \w los|strong="H1121"\w* amalecitas \w para|strong="H5973"\w* \w que|strong="H6435"\w* \w no|strong="H6435"\w* \w los|strong="H1121"\w* destruya \w juntamente|strong="H5973"\w* \w con|strong="H5973"\w* \w ellos|strong="H3605"\w*, \w porque|strong="H6435"\w* ustedes mostraron \w misericordia|strong="H2617"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w* cuando \w salieron|strong="H5927"\w* \w de|strong="H5973"\w* \w Egipto|strong="H4714"\w*. \w Así|strong="H5973"\w* \w que|strong="H6435"\w* \w los|strong="H1121"\w* ceneos \w salieron|strong="H5927"\w* \w de|strong="H5973"\w* \w entre|strong="H8432"\w* \w los|strong="H1121"\w* amalecitas.
\p 
\v 7 \w Saúl|strong="H7586"\w* derrotó \w a|strong="H3068"\w* \w los|strong="H5921"\w* amalecitas \w desde|strong="H5921"\w* \w Havilá|strong="H2341"\w* \w hasta|strong="H5921"\w* llegar \w a|strong="H3068"\w* \w Shur|strong="H7793"\w*, \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w al|strong="H5921"\w* oriente \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*.
\v 8 Capturó \w vivo|strong="H2416"\w* \w a|strong="H3068"\w* Agag, \w rey|strong="H4428"\w* \w de|strong="H5971"\w* \w Amalec|strong="H6002"\w*, y exterminó \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w a|strong="H3068"\w* filo \w de|strong="H5971"\w* \w espada|strong="H2719"\w*.
