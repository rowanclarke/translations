\v 21 \w Herod|strong="G2264"\w* loh \w cunnah|strong="G1077"\w* \w khohnin|strong="G2250"\w* \w tapkhoeh|strong="G2121"\w* a \w pha|strong="G1096"\w* \w vaengah|strong="G3753"\w* \w a|strong="G0846"\w* \w hlanglen|strong="G3175"\w* rhoek, \w rhalboeipa|strong="G5506"\w* rhoek, \w Galilee|strong="G1056"\w* kah a \w congkhang|strong="G4413"\w* rhoek \w ham|strong="G3588"\w* \w te|strong="G3588"\w* \w hlaembuh|strong="G1173"\w* a \w saii|strong="G4160"\w* pah.  
\v 22 Te \w vaengah|strong="G2532"\w* \w Herodias|strong="G2266"\w* \w canu|strong="G2364"\w* \w te|strong="G3588"\w* \w kun|strong="G1525"\w* \w tih|strong="G2532"\w* a \w lam|strong="G3738"\w* hatah \w Herod|strong="G2264"\w* \w neh|strong="G2532"\w* aka \w ngol|strong="G4873"\w* \w rhoek|strong="G3588"\w* \w te|strong="G3588"\w* a ko a \w hoe|strong="G0700"\w* sak. \w Manghai|strong="G0935"\w* \w loh|strong="G3588"\w* \w hula|strong="G2877"\w* \w te|strong="G3588"\w*, “Na \w ngaih|strong="G2309"\w* \w te|strong="G3739"\w* \w tah|strong="G1437"\w* \w kai|strong="G3165"\w* taengah ham \w bih|strong="G0154"\w* \w lamtah|strong="G2532"\w* \w nang|strong="G4671"\w* kan \w pae|strong="G1325"\w* eh?,” a \w ti|strong="G2036"\w* nah.   
