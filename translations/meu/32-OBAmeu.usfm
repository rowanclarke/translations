\id OBA .01, Obadiah 1, Motu, PNG, RTWP 12/92
\h OBADIA
\toc1 OBADlA
\toc2 OBADIA
\mt1 OBADlA
\c 1
\s1 Edom ihahemaraina
\p 
\v 1 Obadia ena mata-hanai binai. Ḡaubada Iehova ese Edom na ini e herevalaia tomamu:
\q1 Hari na Iehova ena amo vada a kamonai.
\q2 bona gwaukau tauna na bese idau-idau bogaragidiai vada e siaia, eto:
\q2 A tore isi, baita tuari henia.
\q1 
\v 2 A itaia, lau ese bese idau-idau bogaragidiai baina hamaraḡimu,
\q2 idia ese bae dadaraimu vaitani.
\q1 
\v 3 Lalomu hekokorokuna ese vada e dibaḡanimu,
\q2 hagahaga kohuadia ai o nohomu taumu;
\q1 emu noho gabuna na atai ai, bona lalomu ai o tomu
\q2 “Daika ese baine verigu dobi tano ai?”
\q1 
\v 4 Ena be atai ai o rohomu ugava na heto,
\q2 ena be emu ruma na hisiu bogaragidiai e miamu.
\q1 to unu amo baina verimu dobi.
\q2 Iehova na e herevamu.
\b
\q1 
\v 5 Henao taudia bema vasi,
\q2 eiava dadidadi taudia hanuaboi ai bema kau,
\q1 daka hahebua-tarina!
\q2 To edia dabu heḡereḡerena mo bema henao ani?
\q1 Vine huahuadia igogodia taudia bema vasi,
\q2 to vine momorudia bema rakatani ani?
\q1 
\v 6 Esau madi vada e dadihaia,
\q2 ena taḡa vada e dadia.
\q1 
\v 7 Idurumu taudia iboudiai ese vada e koimu,
\q2 vada e lulumu lao ela bona tano hetoana;
\q1 bamomu ese vada e hadareremu,
\q2 turamu, o abidadama henidia taudia, ese vada e idoamu;
\q2 tau ta ese basine lalo-pararalaia diba.
\q1 
\v 8 Iehova na e tomu: Una dina ai
\q2 aonega taudia Edom lalona amo baina habuadia tari,
\q2 bona lalo-parara na Esau ororona amo danu, ani?
\q1 
\v 9 Teman e, emu goada taudia kudoudia bae hetaha,
\q2 Bena Esau ororona amo baema taudia iboudiai na bae aladia ore.
\q1 
\v 10 Tadimu Iakob o daḡedaḡe henia dainai,
\q2 hemarai ese baine ḡovamu ahu,
\q2 bona ba henege daure hanaihanai.
\q1 
\v 11 Oi o gini edea dinana ai,
\q2 idau taudia ese ena taḡa e huaia lao
\q1 bona idau gabu taudia ese ia iduarana ai e raka vareai
\q2 bona Ierusalem iabilaina maridia e kara dinana ai,
\q2 oi na idia heḡereḡeredia ta.
\q1 
\v 12 A tadimu ena dina, ena hisihisi dinana,
\q2 basioma kirikirilaia;
\q1 bona Iuda taudia na e hebua tari dinana
\q2 basioma moalelaia;
\q1 hahehisi dinana ai
\q2 basioma hekokoroku.
\q1 
\v 13 Egu bese ena ikoukou ai basioma raka vareai,
\q2 hahehisi na ienai e kau dinana ai;
\q1 ia ihadikana basioma kirikirilaia,
\q2 hahehisi na ienai e kau dinana ai;
\q1 ena kohu basioma dadia,
\q2 hahehisi na ienai e kau dinana ai.
\q1 
\v 14 Dala katakata ai basioma gini,
\q2 ena heau taudia iala-masedia totona;
\q1 ena roho-mauri taudia na inaidia imadia ai basioma atodia,
\q2 hisihisi dinana ai.
\b
\q1 
\v 15 Badina be Iehova ena dina vada eme kahikahi,
\q2 bese idau-idau iboudiai latadiai.
\q1 Vada o kara heḡereḡerena ai bae kara henimu;
\q2 emu kara na oi sibomu kwaramu ai ma baine kau.
\q1 
\v 16 Badina be egu ororo helaḡana ai vada o inuinu heḡereḡerena ai
\q2 e noho hetabiramu besedia iboudiai na bae inuinu;
\q1 bae inuinu, bae raraga,
\q2 bena basiema mauri heḡereḡerena ai baela.
\s1 Israel iabi-daena
\q1 
\v 17 A Siona ororona ai haida do bae roho mauri,
\q2 bena ororo na baine helaga;
\q1 bona Iakob ena iduhu taudia ese
\q2 sibodia edia kohu bae abidia.
\q1 
\v 18 Iakob iduhuna na lahi ai bainela,
\q2 bona Iosef iduhuna na lahi hururu-hururuna ai bainela,
\q2 bona Esau iduhuna na rei kakoro ai bainela;
\q1 bena bae aradia, bae aradia ore,
\q2 Esau iduhuna lalona amo tau ta basine roho mauri;
\q2 badina be Iehova vada e hereva.
\q1 
\v 19 Diho kahana taudia ese Esau ororona bae abia,
\q2 bona Sefela taudia ese Filistia taudia edia tano bae abia;
\q1 Efraim tanona bona Samaria tanona bae abidia,
\q2 bona Beniamina ese Gilead baine abia.
\q1 
\v 20 Hala ai e hanohodia taudia hahidaosi Israel besena amo ese
\q2 Foenikia bae abia ela bona Sarefata;
\q1 bona Ierusalem amo e abidia oho, Sefarad ai e hanohodia, taudia ese
\q2 diho kahana hanuadia bae abidia.
\q1 
\v 21 Hahemauri taudia na Siona ororona ai bae dara dae,
\q2 Esau ororona ilohiana totona;
\q1 bona basileia na
\q2 Iehova ena basileia ai bainela. 
