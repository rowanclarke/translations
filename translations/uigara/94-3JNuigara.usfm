\id 3JN
\h يۇھاننا «3» 
\toc1 يۇھاننا «3» 
\toc2 يۇھاننا «3» 
\toc3 3يۇھ. 
\mt1 يۇھاننا «3»  
\c 1
\s1 «روسۇل يۇهاننا يازغان ئۈچىنچى مەكتۇپ»  
\m
\v 1 مەنكى ئاقساقال ئۆزۈم ھەقىقەتتە سۆيگەن سۆيۈملۈك گايۇسقا سالام!  
\v 2 ئى سۆيۈمكۈك \add دوستۇم\add*، جېنىڭ گۈللەنگەندەك، ھەممە ئىشلىرىڭنىڭ گۈللىنىشىگە ۋە تېنىڭنىڭ سالامەت بولۇشىغا تىلەكداشمەن. \f ◼ \fr 1:2 \ft \+bd «ئى سۆيۈمكۈك (دوستۇم)، جېنىڭ گۈللەنگەندەك، ھەممە ئىشلىرىڭنىڭ گۈللىنىشىگە ۋە تېنىڭنىڭ سالامەت بولۇشىغا تىلەكداشمەن»\+bd* ــ «جېنىڭنىڭ گۈللەنگەندەك...»: ــ دېمەك، گايۇسنىڭ ئىچكى دۇنياسى ئىنتايىن باي، روھىي بايلىقلىرى ناھايىتى كۆپ. 
\fp  بۇ ئايەتكە قارىغاندا، خۇدانىڭ ئۆز پەرزەنتلىرىگە بولغان ئىرادىسىنى ئومۇمەن ئېيتقاندا ئۇلارنىڭ تېنىنىڭ ساغلام بولۇشى، دېگىلى بولىدۇ.\f*  
\v 3 قېرىنداشلار كېلىپ، سەندە بولغان ھەقىقەت توغرۇلۇق گۇۋاھلىق بەرگەندە، مەن ئىنتايىن بەك خۇشاللاندىم؛ چۈنكى سەن ھەقىقەتتە داۋاملىق مېڭىۋاتىسەن. \f ◼ \fr 1:3 \ft \+bd «سەندە بولغان ھەقىقەت توغرۇلۇق گۇۋاھلىق بەرگەندە،...»\+bd* ــ ياكى «سېنىڭ توغراڭدە ھەقىقەت بويىچە گۇۋاھلىق بەرگەندە،...».\f*  
\v 4 ماڭا نىسبەتەن، ئەزىز بالىلىرىمنىڭ ھەقىقەتتە مېڭىۋاتقانلىقىنى ئاڭلاشتىنمۇ چوڭ خۇشاللىق يوقتۇر. \f ◼ \fr 1:4 \ft \+bd «ماڭا نىسبەتەن، ئەزىز بالىلىرىمنىڭ ھەقىقەتتە مېڭىۋاتقانلىقىنى ئاڭلاشتىنمۇ چوڭ خۇشاللىق يوقتۇر»\+bd* ــ «ئەزىز بالىلىرىم»: ــ بۇ ئايەتتىن بىزگە روشەنكى، گايۇس (بەلكىم خېلى بۇرۇنلا) روسۇل يۇھاننا ئارقىلىق خۇش خەۋەرنى قوبۇل قىلغان ۋە شۇنداقلا ئۇنىڭ «ئەزىز بالىلىرى»دىن بىرى بولۇپ قالغان.\f*   
\b  
\m  
\s1 خۇش خەۋەر خىزمىتىدە بولىدىغانلارغا ياردەم بېرىش  
\m
\v 5 سۆيۈملۈك \add دوستۇم\add*، يېنىڭغا بارغان قېرىنداشلارغا (گەرچە ئۇلار ساڭا ناتونۇش بولسىمۇ) قىلغانلىرىڭنىڭ ھەممىسىدە ئىخلاسمەنلىكىڭ ئىسپاتلىنىدۇ. \f ◼ \fr 1:5 \ft \+bd «سۆيۈملۈك دوستۇم، يېنىڭغا بارغان قېرىنداشلارغا (گەرچە ئۇلار ساڭا ناتونۇش بولسىمۇ) قىلغانلىرىڭنىڭ ھەممىسىدە ئىخلاسمەنلىكىڭ ئىسپاتلىنىدۇ»\+bd* ــ بۇ قېرىنداشلار جامائەتلەرگە تەسەللى-رىغبەت يەتكۈزۈش، تەلىم بېرىش ۋە خۇش خەۋەرنى تارقىتىش ئۈچۈن ياقا يۇرتلارغا چىققان. 7-ئايەتنى كۆرۈڭ.\f*  
\v 6 ئۇلار جامائەت ئالدىدا سېنىڭ بۇ مېھىر-مۇھەببىتىڭ توغرىسىدا گۇۋاھلىق بەردى. ئۇلارنى يەنە خۇدانىڭ يولىغا لايىق سەپىرىگە ئۇزىتىپ قويساڭ، ياخشى قىلغان بولىسەن. \f ◼ \fr 1:6 \ft \+bd «ئۇلار جامائەت ئالدىدا سېنىڭ بۇ مېھىر-مۇھەببىتىڭ توغرىسىدا گۇۋاھلىق بەردى»\+bd* ــ «جامائەت» مۇشۇ يەردە مۇئەللىپنىڭ ئۆز جامائىتىنى كۆرسەتسە كېرەك. \+bd «ئۇلارنى يەنە خۇدانىڭ يولىغا لايىق سەپىرىگە ئۇزىتىپ قويساڭ، ياخشى قىلغان بولىسەن»\+bd* ــ «ئۇلارنى ... سەپىرىگە ئۇزىتىپ قويساڭ...»: ــ بۇ ئايەتنىڭ خەۋىرىگە قارىغاندا، بۇ قېرىنداشلار خۇش خەۋەرنى تارقىتىشقا چىققاندا، بۇرۇن بىر قېتىم گايۇس تەرىپىدىن كۈتۈۋېلىنغان. شۇنىڭدىن كېيىن ئۇلار يۇھاننانىڭ، شۇنداقلا ئۆز جامائىتىنىڭ يېنىغا قايتىپ كەلدى، گايۇس توغرۇلۇق گۇۋاھلىق بەردى. ئۇلار ھازىر قايتىدىن سەپەرگە چىققان، يۇھاننا گايۇسقا يازغان ئۇشبۇ خەتنى بەلكىم سەپەرگە چىققانلار گايۇسقا تاپشۇرۇشقا ئېلىپ بارىدۇ.\f*  
\v 7 چۈنكى ئۇلار \add سەپەردە\add* يات ئەللىك \add ئېتىقادسىزلاردىن\add* ھېچ نېمە ئالماي، شۇ مۇبارەك نام ئۈچۈن يولغا چىقتى. \f ◼ \fr 1:7 \ft \+bd «چۈنكى ئۇلار (سەپەردە) يات ئەللىك (ئېتىقادسىزلاردىن) ھېچ نېمە ئالماي، شۇ مۇبارەك نام ئۈچۈن يولغا چىقتى»\+bd* ــ «يات ئەللىك ئېتىقادسىزلار» مۇشۇ يەردە «يات ئەللىكلەر» ياكى «يات ئەللەر» دېگەن سۆز بىلەن ئىپادىلىنىدۇ. ئادەتتە بۇ سۆز «يەھۇدىي بولمىغان ئەللەر»نى كۆرسىتىدۇ، لېكىن مۇشۇ يەردە «ئېتىقادسىزلار» دېگەن كۆچمە مەنىدە ئىشلىتىلىدۇ. 
\fp  «شۇ مۇبارەك نام ئۈچۈن» ــ گرېك تىلىدا پەقەت «نام» بىلەن ئىپادىلىنىدۇ؛ چۈنكى يۇھاننا ۋە شۇ قېرىنداشلار ئۈچۈن پەقەت بىرلا نام مەۋجۇت ئىدى (يەنى بىردىنبىر مەسىھنىڭ نامىدۇر). مەسىلەن، «1يۇھ.» 12:2نىمۇ كۆرۈڭ).\f*  
\v 8 شۇڭا، ھەقىقەت بىلەن خىزمەتداش بولۇپ تەڭ ئىشلىگۈچى بولۇش ئۈچۈن بىز شۇنداقلارنى قوللاپ-قۇۋۋەتلىشىمىزگە توغرا كېلىدۇ. \f ◼ \fr 1:8 \ft \+bd «شۇڭا، ھەقىقەت بىلەن خىزمەتداش بولۇپ تەڭ ئىشلىگۈچى بولۇش ئۈچۈن بىز شۇنداقلارنى قوللاپ-قۇۋۋەتلىشىمىزگە توغرا كېلىدۇ.»\+bd* ــ «ھەقىقەت بىلەن خىزمەتداش بولۇپ تەڭ ئىشلىگۈچى بولۇش ئۈچۈن» ــ بۇنىڭغا قارىغاندا «ھەقىقەت» دېگەن ئىبارە «ھەقىقەتنىڭ روھى»، يەنى مۇقەددەس روھنىڭ ئۆزىنى كۆرسىتىدۇ. 
\fp  «قوللاپ-قۇۋۋەتلەش» ــ گرېك تىلىدا «قوبۇل قىلىش» دېگەن پېئىل بىلەن ئىپادىلىنىدۇ ۋە ئۆيدە كۈتۈۋېلىشىنى چوقۇم ئۆز ئىچىگە ئالىدۇ. 
\fp  «بىز شۇنداقلارنى قوللاپ-قۇۋۋەتلىشىمىزگە توغرا كېلىدۇ» ــ بۇ ئايەتتىكى «بىز» شۈبھىسىزكى، بارلىق ئېتىقادچىلارنى ئۆز ئىچىگە ئالىدۇ.\f*   
\m
\v 9 بۇ توغرۇلۇق جامائەتكە مەكتۈپ يازدىم. لېكىن ئۇلارنىڭ ئارىسىدا ئۆزىنى چوڭ تۇتۇپ، جامائەتكە باش بولۇش تەمەسىدە بولغان دىئوترەپەس بىزنى قوبۇل قىلمايدۇ. \f ◼ \fr 1:9 \ft \+bd «بۇ توغرۇلۇق جامائەتكە مەكتۈپ يازدىم. لېكىن ئۇلارنىڭ ئارىسىدا ئۆزىنى چوڭ تۇتۇپ، جامائەتكە باش بولۇش تەمەسىدە بولغان دىئوترەپەس بىزنى قوبۇل قىلمايدۇ»\+bd* ــ روشەنكى، بۇ ئايەتتە تىلغا ئېلىنغان «جامائەت» يۇھاننا ياكى گايۇس بىلەن مۇناسىۋەتلىك جامائەت ئەمەس، بەلكى گايۇس تۇرغان يۇرتقا يېقىن جايلاشقان بىر جامائەت ئىدى.\f*  
\v 10 شۇنىڭ ئۈچۈن مەن بارغاندا، ئۇنىڭ قىلغان ئەسكىلىكلىرىنى، يەنى ئۇنىڭ بىزنىڭ ئۈستىمىزدىن قىلغان رەزىل سۆزلىرى بىلەن غەيۋىتىنى يۈزىگە سالىمەن؛ ئۇ ئۇنىڭلىق بىلەنلا توختاپ قالمايدۇ، يەنە \add سەپەردىكى\add* قېرىنداشلارنى قوبۇل قىلمايلا قالماي، قوبۇل قىلماقچى بولغانلارنىمۇ توسىدۇ ۋە ھەتتا ئۇلارنى جامائەتتىن قوغلاپ چىقىرىۋاتىدۇ. \f ◼ \fr 1:10 \ft \+bd «شۇنىڭ ئۈچۈن مەن بارغاندا، ئۇنىڭ قىلغان ئەسكىلىكلىرىنى، يەنى ئۇنىڭ بىزنىڭ ئۈستىمىزدىن قىلغان رەزىل سۆزلىرى بىلەن غەيۋىتىنى يۈزىگە سالىمەن»\+bd* ــ «يۈزىگە سالىمەن» گرېك تىلىدا «ئەسلىتىمەن» بىلەن ئىپادىلىنىدۇ. يۇھاننا بۇ يامانلىقنى دىئوترەپەستىن باشقا ھېچكىمگە ئەسلەتمەيدۇ! \+bd «ئۇ ئۇنىڭلىق بىلەنلا توختاپ قالمايدۇ، يەنە (سەپەردىكى) قېرىنداشلارنى قوبۇل قىلمايلا قالماي...»\+bd* ــ بۇ «قېرىنداشلار» يۇقىرىدا تىلغا ئېلىنغان خۇش خەۋەرنى تارقىتىش ئۈچۈن يولغا چىققان قېرىنداشلاردۇر. \+bd «... قېرىنداشلارنى قوبۇل قىلمايلا قالماي، قوبۇل قىلماقچى بولغانلارنىمۇ توسىدۇ ۋە ھەتتا ئۇلارنى جامائەتتىن قوغلاپ چىقىرىۋاتىدۇ»\+bd* ــ دىئوترەپەسنىڭ جامائەتكە ئاقساقال بولغان-بولمىغانلىقى ئېنىق ئەمەس، ئىشقىلىپ جامائەت ئىچىدە خېلى تەسىرى بار ئادەم بولسا كېرەك.\f*   
\m
\v 11 ئى سۆيۈملۈك \add دوستۇم\add*، يامانلىقتىن ئەمەس، ياخشىلىقتىن ئۈلگە ئالغىن. ياخشىلىق قىلغۇچى خۇدادىندۇر. يامانلىق قىلغۇچى خۇدانى ھېچ كۆرمىگەندۇر. \x ◘ \xo 1:11 \xt زەب. 37‏:27؛ يەش. 1‏:16؛ 1پېت. 3‏:11؛ 1يۇھ. 3‏:6. \x*   
\m
\v 12 دېمىترىئۇسنى بولسا ھەممەيلەن، ھەتتا ھەقىقەتنىڭ ئۆزى ياخشى گۇۋاھلىق بېرىپ تەرىپلەيدۇ. بىزمۇ ئۇنىڭغا گۇۋاھلىق بېرىمىز ۋە گۇۋاھلىقىمىزنىڭ ھەقىقەت ئىكەنلىكىنى سەنمۇ بىلىسەن. \f ◼ \fr 1:12 \ft \+bd «دېمىترىئۇسنى بولسا ھەممەيلەن، ھەتتا ھەقىقەتنىڭ ئۆزى ياخشى گۇۋاھلىق بېرىپ تەرىپلەيدۇ»\+bd* ــ مۇمكىنچىلىكى باركى، دېمىترىئۇسنىڭ ئۆزى يۇھاننانىڭ يېنىدىن يولغا چىققان «خۇش خەۋەرچى قېرىنداشلار»نىڭ بىرى (ھەتتا ئۇلارنىڭ باشلىقى) ئىدى. 
\fp  «ھەقىقەتنىڭ ئۆزى... گۇۋاھلىق بېرىدۇ» ــ بىزنىڭچە مۇشۇ يەردە «ھەقىقەت» شۈبھىسىزكى، «ھەقىقەتنىڭ روھى»، يەنى مۇقەددەس روھنىڭ ئۆزىنى كۆرسىتىدۇ. دېمەك، مۇقەددەس روھ بىلەن تولغان ھەربىر كىشى دېمىترىئۇس بىلەن ئۇچراشقاندا، ئۆزىنىڭ روھىدا دېمىترىئۇسنىڭ قانداق ئادەم ئىكەنلىكى توغرۇلۇق مۇقەددەس روھتىن بولغان گۇۋاھلىقى بولىدۇ. «قوشۇمچە سۆز»ىمىزنى كۆرۈڭ. 
\fp  «ھەقىقەت ئىكەنلىكىنى سەنمۇ بىلىسەن» ياكى «ھەقىقەت ئىكەنلىكىنى سىلەرنمۇ بىلىسىلەر».\f*   
\b  
\m
\v 13 ساڭا يازىدىغان يەنە كۆپ سۆزلىرىم بار ئىدى؛ لېكىن قەلەم بىلەن سىياھنى ئىشلەتكەندىن كۆرە، \f ◼ \fr 1:13 \ft \+bd «لېكىن قەلەم بىلەن سىياھنى ئىشلەتكەندىن كۆرە، ...»\+bd* ــ گرېك تىلىدا «لېكىن سىياھ ۋە قەلەمنى ئىشلەتكەندىن كۆرە، ...» دېيىلىدۇ.\f*  \x ◘ \xo 1:13 \xt 2يۇھ. 12. \x*  
\v 14 سەن بىلەن پات ئارىدا دىدار كۆرۈشۈشنى ئارزۇ قىلىمەن؛ شۇ چاغدا دەرقەمدە سۆزلىشىمىز.  
\v 15 ساڭا خاتىرجەملىك يار بولغاي! دوستلاردىن ساڭا سالام. سەنمۇ \add ئۇ يەردىكى\add* دوستلارغا ئىسىم-فامىلىلىرى بويىچە مەندىن سالام ئېيتقايسەن. \f ◼ \fr 1:15 \ft \+bd «ساڭا خاتىرجەملىك يار بولغاي! دوستلاردىن ساڭا سالام»\+bd* ــ «دوستلار» يۇھاننانىڭ يېنىدىكى بارلىق قېرىنداشلارنى كۆرسەتسە كېرەك. يۇھاننا «سېنىڭ دوستىلىرىڭ» ياكى «مېنىڭ دوستلىرىم» دېمەيدۇ. ھەقىقىي قېرىنداش بولسا ھەربىر باشقا قېرىنداشقا، يەنى خۇدانى سۆيگۈچىلەرنىڭ ھەممىسىگە دوستتۇر. \+bd سەنمۇ ئۇ يەردىكى دوستلارغا ئىسىم-فامىلىلىرى بويىچە مەندىن سالام ئېيتقايسەن»\+bd* ــ يۇقىرىدا ئېيتقىنىمىزدەك، «دوستلار» مۇشۇ يەردە گايۇسنىڭ يېنىدىكى بارلىق قېرىنداشلارنى كۆرسىتىدۇ.\f*   