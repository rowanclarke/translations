\p
\v 19 “\w All|strong="H3605"\w* \w insects|strong="H8318"\w* \w with|strong="H3605"\w* \w wings|strong="H5775"\w* \add and which walk on the ground\add* \w are|strong="H5775"\w* unacceptable \add to Yahweh\add*; \w do|strong="H3605"\w* \w not|strong="H3808"\w* eat \w them|strong="H1931"\w*.  
\v 20 \w But|strong="H3605"\w* \w other|strong="H3605"\w* insects \w with|strong="H3605"\w* \w wings|strong="H5775"\w* \add and which hop along the ground\add* \w are|strong="H5775"\w* acceptable \w to|strong="H3605"\w* eat.   
\p
\v 21 “\w Do|strong="H3068"\w* \w not|strong="H3808"\w* eat \w any|strong="H3605"\w* animal \w that|strong="H3588"\w* \w has|strong="H3068"\w* \w died|strong="H5038"\w* naturally, \add because its blood has not been drained out\add*. \w You|strong="H5414"\w* \w may|strong="H3068"\w* \w allow|strong="H5414"\w* \w foreigners|strong="H5237"\w* \w who|strong="H3605"\w* live \w among|strong="H5971"\w* \w you|strong="H5414"\w* \w to|strong="H3068"\w* eat \w those|strong="H3605"\w* \w things|strong="H3605"\w* \w or|strong="H3808"\w* \w you|strong="H5414"\w* \w may|strong="H3068"\w* \w sell|strong="H4376"\w* \w them|strong="H5414"\w* \w to|strong="H3068"\w* \w other|strong="H3605"\w* \w foreigners|strong="H5237"\w*. \w But|strong="H3588"\w* \w you|strong="H5414"\w* belong \w to|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w*; \add and those who belong to him are not permitted to eat the meat of animals whose blood has not been drained out\add*.  
\p “\w You|strong="H5414"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* \w cook|strong="H1310"\w* \w a|strong="H3068"\w* \w young|strong="H1423"\w* sheep \w or|strong="H3808"\w* \w goat|strong="H1423"\w* \w in|strong="H3068"\w* \w its|strong="H3605"\w* mother’s \w milk|strong="H2461"\w*.”   
\s1 Giving tithes  
\p
\v 22 “Once \w each|strong="H3605"\w* \w year|strong="H8141"\w* \w you|strong="H3605"\w* must \w set|strong="H3318"\w* apart ◄\w a|strong="H3068"\w* \w tithe|strong="H6237"\w*/10 percent► \w of|strong="H8141"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w crops|strong="H8393"\w* \w that|strong="H3605"\w* \w are|strong="H8141"\w* \w produced|strong="H3318"\w*/harvested \w in|strong="H8141"\w* \w your|strong="H3605"\w* \w fields|strong="H7704"\w*.  
\v 23 \w Take|strong="H8492"\w* \w those|strong="H3605"\w* \w things|strong="H3605"\w* \w to|strong="H3068"\w* \w the|strong="H3605"\w* \w place|strong="H4725"\w* \w that|strong="H3605"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w will|strong="H3068"\w* choose \add for you to worship him\add*. \w There|strong="H8033"\w* eat \w the|strong="H3605"\w* \w tithes|strong="H4643"\w* \w of|strong="H3068"\w* \w your|strong="H3068"\w* \w grain|strong="H1715"\w*, \w your|strong="H3068"\w* \w wine|strong="H8492"\w*, \w your|strong="H3068"\w* \add olive\add* \w oil|strong="H3323"\w*, \w and|strong="H3068"\w* \w the|strong="H3605"\w* meat \w of|strong="H3068"\w* \w the|strong="H3605"\w* \w firstborn|strong="H1062"\w* male animals \w of|strong="H3068"\w* \w your|strong="H3068"\w* \w cattle|strong="H1241"\w* \w and|strong="H3068"\w* \w your|strong="H3068"\w* \w sheep|strong="H6629"\w*. \w Do|strong="H3068"\w* \w this|strong="H6440"\w* \w in|strong="H3068"\w* \w order|strong="H4616"\w* \w that|strong="H3605"\w* \w you|strong="H6440"\w* \w may|strong="H3068"\w* \w learn|strong="H3925"\w* \w to|strong="H3068"\w* \w always|strong="H3605"\w* \w revere|strong="H3372"\w* \w Yahweh|strong="H3068"\w*, \add the one who has blessed you by giving you these things\add*.  
\v 24 \w If|strong="H3588"\w* \w the|strong="H3588"\w* \w place|strong="H4725"\w* \w that|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* chosen \add for you to worship him\add* \w is|strong="H3068"\w* \w very|strong="H7235"\w* \w far|strong="H7368"\w* \w from|strong="H4480"\w* \w your|strong="H3068"\w* \w home|strong="H4725"\w*, \w with|strong="H3068"\w* \w the|strong="H3588"\w* \w result|strong="H4480"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w are|strong="H3068"\w* \w not|strong="H3808"\w* \w able|strong="H3201"\w* \w to|strong="H3201"\w* \w take|strong="H5375"\w* \w there|strong="H8033"\w* \w the|strong="H3588"\w* tithes \add of your crops\add* \w with|strong="H3068"\w* \w which|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* \w blessed|strong="H1288"\w* \w you|strong="H3588"\w*, \w do|strong="H3068"\w* \w this|strong="H3588"\w*:  
\v 25 \w Sell|strong="H5414"\w* [IDM] \w the|strong="H5414"\w* tithes \w of|strong="H3068"\w* \w your|strong="H3068"\w* crops, wrap \w the|strong="H5414"\w* \w money|strong="H3701"\w* carefully \add in a cloth\add*, \w and|strong="H1980"\w* \w take|strong="H1980"\w* \w it|strong="H5414"\w* \w with|strong="H1980"\w* \w you|strong="H5414"\w* \w to|strong="H1980"\w* \w the|strong="H5414"\w* \w place|strong="H4725"\w* \w of|strong="H3068"\w* worship \w that|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* chosen.  
\v 26 \w There|strong="H8033"\w*, \add with that money\add*, \w you|strong="H5414"\w* \w may|strong="H3068"\w* buy \w whatever|strong="H3605"\w* \w you|strong="H5414"\w* \w want|strong="H5315"\w* \w to|strong="H3068"\w*—\w beef|strong="H1241"\w* \w or|strong="H3701"\w* \w lamb|strong="H6629"\w* \w or|strong="H3701"\w* \w wine|strong="H3196"\w* \w or|strong="H3701"\w* fermented drinks. \w And|strong="H3068"\w* \w there|strong="H8033"\w*, \w in|strong="H3068"\w* \w the|strong="H3605"\w* \w presence|strong="H6440"\w* \w of|strong="H1004"\w* \w Yahweh|strong="H3068"\w*, \w you|strong="H5414"\w* \w and|strong="H3068"\w* \w your|strong="H3068"\w* \w families|strong="H1004"\w* \w should|strong="H3068"\w* eat \add and drink\add* \w those|strong="H3605"\w* \w things|strong="H3605"\w* \w and|strong="H3068"\w* \w be|strong="H3068"\w* \w happy|strong="H8055"\w*.  
\v 27 \w But|strong="H3588"\w* \w be|strong="H3808"\w* sure \w to|strong="H5973"\w* \w not|strong="H3808"\w* \w neglect|strong="H5800"\w*/forget \add to help\add* \w the|strong="H3588"\w* descendants \w of|strong="H8179"\w* \w Levi|strong="H3881"\w* \w who|strong="H3881"\w* live \w in|strong="H2506"\w* \w your|strong="H3588"\w* \w towns|strong="H8179"\w*, \w because|strong="H3588"\w* \w they|strong="H3588"\w* \w will|strong="H3808"\w* \w not|strong="H3808"\w* \w own|strong="H5973"\w* \w any|strong="H3808"\w* \w land|strong="H5159"\w*.   
\p
\v 28 “\w At|strong="H3318"\w* \w the|strong="H3605"\w* \w end|strong="H7097"\w* \w of|strong="H8141"\w* \w every|strong="H3605"\w* \w three|strong="H7969"\w* \w years|strong="H8141"\w*, \w bring|strong="H3318"\w* \w a|strong="H3068"\w* \w tithe|strong="H4643"\w* \w of|strong="H8141"\w* \w all|strong="H3605"\w* \w your|strong="H3605"\w* \w crops|strong="H8393"\w* \w that|strong="H3605"\w* \w have|strong="H3605"\w* \w been|strong="H3605"\w* \w produced|strong="H3318"\w*/harvested \w in|strong="H8141"\w* \w that|strong="H3605"\w* \w year|strong="H8141"\w* \w and|strong="H8141"\w* store \w it|strong="H1931"\w* \w in|strong="H8141"\w* \w your|strong="H3605"\w* \w towns|strong="H8179"\w*.  
\v 29 \w That|strong="H3588"\w* food \w is|strong="H3068"\w* \w for|strong="H3588"\w* \w the|strong="H3605"\w* descendants \w of|strong="H3068"\w* \w Levi|strong="H3881"\w*, \w because|strong="H3588"\w* \w they|strong="H3588"\w* \w do|strong="H6213"\w* \w not|strong="H6213"\w* \w have|strong="H3068"\w* \w their|strong="H3605"\w* \w own|strong="H3027"\w* \w land|strong="H5159"\w*, \w and|strong="H3068"\w* \w for|strong="H3588"\w* \w foreigners|strong="H1616"\w* \add who live among you\add*, \w and|strong="H3068"\w* \w for|strong="H3588"\w* \w orphans|strong="H3490"\w* \w and|strong="H3068"\w* widows \w who|strong="H3605"\w* live \w in|strong="H3068"\w* \w your|strong="H3068"\w* \w towns|strong="H8179"\w*. \w They|strong="H3588"\w* \w are|strong="H3027"\w* permitted \w to|strong="H3068"\w* come \add to where the food is stored\add* \w and|strong="H3068"\w* \w take|strong="H6213"\w* \w what|strong="H4639"\w* \w they|strong="H3588"\w* need. \w Do|strong="H6213"\w* \w that|strong="H3588"\w* \w in|strong="H3068"\w* \w order|strong="H4616"\w* \w that|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w will|strong="H3068"\w* \w bless|strong="H1288"\w* \w you|strong="H3588"\w* \w in|strong="H3068"\w* \w everything|strong="H3605"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w do|strong="H6213"\w*.”   
\c 15  
\s1 The year for canceling debts  
\p
\v 1 “\w At|strong="H6213"\w* \w the|strong="H6213"\w* \w end|strong="H7093"\w* \w of|strong="H8141"\w* \w every|strong="H6213"\w* \w seven|strong="H7651"\w* \w years|strong="H8141"\w*, \w you|strong="H6213"\w* must ◄cancel \w all|strong="H6213"\w* debts/tell people \w who|strong="H6213"\w* owe \w you|strong="H6213"\w* money \w that|strong="H8141"\w* \w they|strong="H8141"\w* \w do|strong="H6213"\w* \w not|strong="H6213"\w* need \w to|strong="H6213"\w* pay \w it|strong="H6213"\w* back►.  
\v 2 \w Do|strong="H3068"\w* \w it|strong="H7121"\w* \w like|strong="H3808"\w* \w this|strong="H2088"\w*: \w Each|strong="H3605"\w* \w of|strong="H3068"\w* \w you|strong="H3588"\w* \w who|strong="H3605"\w* \w has|strong="H3068"\w* \w lent|strong="H5383"\w* money \w to|strong="H3068"\w* \w a|strong="H3068"\w* \w fellow|strong="H7453"\w* Israeli \w must|strong="H3808"\w* cancel \w that|strong="H3588"\w* \w debt|strong="H3027"\w*. \w You|strong="H3588"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* insist \w that|strong="H3588"\w* \w he|strong="H3588"\w* pay \w it|strong="H7121"\w* back. \w You|strong="H3588"\w* \w must|strong="H3808"\w* \w do|strong="H3068"\w* \w that|strong="H3588"\w* \w because|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* declared \w that|strong="H3588"\w* \w the|strong="H3605"\w* debts \w must|strong="H3808"\w* \w be|strong="H3808"\w* canceled \add every seven years\add*.  
\v 3  \add During that year\add* \w you|strong="H3027"\w* \w may|strong="H1961"\w* require \w foreigners|strong="H5237"\w* \add who live among you\add* \w to|strong="H1961"\w* pay what \w they|strong="H3027"\w* owe \w you|strong="H3027"\w*, \w but|strong="H1961"\w* \w you|strong="H3027"\w* must \w not|strong="H1961"\w* try \w to|strong="H1961"\w* require \w that|strong="H3027"\w* \w any|strong="H1961"\w* fellow Israeli pay \w you|strong="H3027"\w* what \w he|strong="H3027"\w* owes \w you|strong="H3027"\w*.  
\v 4-5 \w Yahweh|strong="H3068"\w* our God will bless you in the land that he is giving to you. If you obey \w Yahweh|strong="H3068"\w* our God and obey all the commandments that I am giving to you today, there will not be any poor people among you.  
\v 6 \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w will|strong="H3068"\w* \w bless|strong="H1288"\w* \w you|strong="H3588"\w* \w like|strong="H3808"\w* \w he|strong="H3588"\w* \w has|strong="H3068"\w* \w promised|strong="H1696"\w* \w to|strong="H1696"\w* \w do|strong="H3068"\w*, \w and|strong="H3068"\w* \w you|strong="H3588"\w* \w will|strong="H3068"\w* \add be able to\add* \w lend|strong="H5670"\w* money \w to|strong="H1696"\w* \w people|strong="H1471"\w* \w of|strong="H3068"\w* other people-groups, \w but|strong="H3588"\w* \w you|strong="H3588"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \add need to\add* \w borrow|strong="H5670"\w* \w from|strong="H1471"\w* \w any|strong="H3588"\w* \w of|strong="H3068"\w* \w them|strong="H3588"\w*. \w You|strong="H3588"\w* \w will|strong="H3068"\w* \w control|strong="H4910"\w* \add the finances of\add* \w many|strong="H7227"\w* people-groups, \w but|strong="H3588"\w* \w they|strong="H3588"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w control|strong="H4910"\w* \w your|strong="H3068"\w* \add finances\add*.   
\p
\v 7 “\w In|strong="H3068"\w* \w the|strong="H3588"\w* \w towns|strong="H8179"\w* \w that|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w is|strong="H3068"\w* \w giving|strong="H5414"\w* \w to|strong="H3068"\w* \w you|strong="H5414"\w*, \w if|strong="H3588"\w* \w there|strong="H1961"\w* \w are|strong="H3027"\w* \w any|strong="H5414"\w* Israelis \w who|strong="H3068"\w* \w are|strong="H3027"\w* poor, \w do|strong="H3068"\w* \w not|strong="H3808"\w* \w be|strong="H1961"\w* selfish [IDM] \w and|strong="H3068"\w* \w refuse|strong="H3808"\w* [IDM] \w to|strong="H3068"\w* \w help|strong="H1961"\w* \w them|strong="H5414"\w*.  
\v 8 \w Instead|strong="H3588"\w*, \w be|strong="H3027"\w* generous [IDM] \w and|strong="H3027"\w* \w lend|strong="H5670"\w* \w to|strong="H3027"\w* \w them|strong="H3027"\w* \w the|strong="H3588"\w* money \w that|strong="H3588"\w* \w they|strong="H3588"\w* \w need|strong="H4270"\w*.  
\v 9 \w Be|strong="H1961"\w* \w sure|strong="H8104"\w* \w that|strong="H3068"\w* \w you|strong="H5414"\w* \w do|strong="H7489"\w* \w not|strong="H3808"\w* \w say|strong="H1697"\w* \w to|strong="H3068"\w* \w yourself|strong="H5973"\w*, ‘\w The|strong="H5921"\w* \w year|strong="H8141"\w* \w when|strong="H1961"\w* debts \w will|strong="H3068"\w* \w be|strong="H1961"\w* canceled \w is|strong="H3068"\w* \w near|strong="H7126"\w*, \add so I do not want to lend anyone any money now, because he will not need to pay it back when that year comes\add*.’ \w It|strong="H5414"\w* \w would|strong="H3068"\w* \w be|strong="H1961"\w* \w evil|strong="H7489"\w* \w to|strong="H3068"\w* \w even|strong="H3808"\w* \w think|strong="H5869"\w* \w that|strong="H3068"\w*. \w If|strong="H1961"\w* \w you|strong="H5414"\w* \w act|strong="H7489"\w* \w in|strong="H5921"\w* \w an|strong="H7126"\w* unfriendly \w way|strong="H1697"\w* \w toward|strong="H5921"\w* \w a|strong="H3068"\w* needy fellow Israeli, \w and|strong="H3068"\w* \w give|strong="H5414"\w* \w him|strong="H5414"\w* \w nothing|strong="H3808"\w*, \w he|strong="H3068"\w* \w will|strong="H3068"\w* \w cry|strong="H7121"\w* \w out|strong="H5414"\w* \w to|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w about|strong="H1961"\w* \w you|strong="H5414"\w*, \w and|strong="H3068"\w* \add Yahweh will say that\add* \w you|strong="H5414"\w* \w have|strong="H1961"\w* sinned \add by not helping that person\add*.  
\v 10 \w Give|strong="H5414"\w* freely \w to|strong="H3068"\w* poor \w people|strong="H3808"\w* \w and|strong="H3068"\w* \w give|strong="H5414"\w* \w generously|strong="H5414"\w* [IDM].  
\v 11 \w If|strong="H3588"\w* \w you|strong="H3588"\w* \w do|strong="H6680"\w* \w that|strong="H3588"\w*, \w Yahweh|strong="H3068"\w* \w will|strong="H3027"\w* bless \w you|strong="H3588"\w* \w in|strong="H5921"\w* everything \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w do|strong="H6680"\w*. There \w will|strong="H3027"\w* always \w be|strong="H3808"\w* \w some|strong="H3027"\w* \w poor|strong="H6041"\w* \w people|strong="H3808"\w* \w in|strong="H5921"\w* \w your|strong="H5921"\w* \w land|strong="H7130"\w*, \w so|strong="H3651"\w* \w I|strong="H3588"\w* \w command|strong="H6680"\w* \w you|strong="H3588"\w* \w to|strong="H5921"\w* \w give|strong="H6680"\w* generously \w to|strong="H5921"\w* \w poor|strong="H6041"\w* [DOU] \w people|strong="H3808"\w*.”   
\s1 Freeing slaves  
\p
\v 12 “\w If|strong="H3588"\w* \w any|strong="H3588"\w* \w of|strong="H8141"\w* \w your|strong="H3588"\w* fellow Israeli men \w or|strong="H4376"\w* \w women|strong="H5680"\w* \w sell|strong="H4376"\w* themselves \w to|strong="H7971"\w* \w one|strong="H3588"\w* \w of|strong="H8141"\w* \w you|strong="H3588"\w* \add to become your slave\add*, \w you|strong="H3588"\w* must \w free|strong="H2670"\w* \w them|strong="H7971"\w* \w after|strong="H3588"\w* \w they|strong="H3588"\w* \w have|strong="H3588"\w* \w worked|strong="H5647"\w* \w for|strong="H3588"\w* \w you|strong="H3588"\w* \w for|strong="H3588"\w* \w six|strong="H8337"\w* \w years|strong="H8141"\w*. \w When|strong="H3588"\w* \w the|strong="H3588"\w* \w seventh|strong="H7637"\w* \w year|strong="H8141"\w* \w comes|strong="H5973"\w*, \w you|strong="H3588"\w* must \w free|strong="H2670"\w* \w them|strong="H7971"\w*.  
\v 13 \w When|strong="H3588"\w* \w you|strong="H3588"\w* \w free|strong="H2670"\w* \w them|strong="H7971"\w*, do \w not|strong="H3808"\w* allow \w them|strong="H7971"\w* \w to|strong="H7971"\w* \w go|strong="H7971"\w* ◄\w empty-handed|strong="H7387"\w*/\w without|strong="H3808"\w* giving \w them|strong="H7971"\w* \w anything|strong="H3808"\w*►.  
\v 14 \w Give|strong="H5414"\w* \w to|strong="H3068"\w* \w them|strong="H5414"\w* \w generously|strong="H5414"\w* \w from|strong="H3068"\w* \w the|strong="H5414"\w* things \w with|strong="H3068"\w* \w which|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* \w blessed|strong="H1288"\w* \w you|strong="H5414"\w*—\w sheep|strong="H6629"\w*, grain, \w and|strong="H3068"\w* \w wine|strong="H3342"\w*.  
\v 15 \w Do|strong="H3068"\w* \w not|strong="H2088"\w* forget \w that|strong="H3588"\w* \w your|strong="H3068"\w* ancestors \w were|strong="H1961"\w* \w once|strong="H3117"\w* \w slaves|strong="H5650"\w* \w in|strong="H5921"\w* \w Egypt|strong="H4714"\w*, \w and|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* freed \w them|strong="H5921"\w*. \w That|strong="H3588"\w* \w is|strong="H3068"\w* \w the|strong="H5921"\w* \w reason|strong="H1697"\w* \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w am|strong="H1961"\w* \w now|strong="H1961"\w* \w commanding|strong="H6680"\w* \w you|strong="H3588"\w* \w to|strong="H3068"\w* \w do|strong="H3068"\w* \w this|strong="H2088"\w*.   
\p
\v 16 “\w But|strong="H3588"\w* \w one|strong="H3808"\w* \w of|strong="H1004"\w* \w your|strong="H3588"\w* slaves \w may|strong="H1961"\w* say, ‘\w I|strong="H3588"\w* \w do|strong="H3318"\w* \w not|strong="H3808"\w* \w want|strong="H3808"\w* \w to|strong="H3318"\w* \w leave|strong="H3318"\w* \w you|strong="H3588"\w*.’ \w He|strong="H3588"\w* loves \w you|strong="H3588"\w* \w and|strong="H1004"\w* \w your|strong="H3588"\w* \w family|strong="H1004"\w*, \w because|strong="H3588"\w* \w you|strong="H3588"\w* \w have|strong="H1961"\w* treated \w him|strong="H5973"\w* \w well|strong="H2895"\w*.  
\v 17 \w If|strong="H1961"\w* \w he|strong="H6213"\w* says \w that|strong="H3651"\w*, \w take|strong="H3947"\w* \w him|strong="H5414"\w* \w to|strong="H1961"\w* \w the|strong="H5414"\w* \w door|strong="H1817"\w* \w of|strong="H5650"\w* \w your|strong="H5414"\w* house \w and|strong="H5650"\w*, \add while he stands against the doorway\add*, \w pierce|strong="H5414"\w* \w one|strong="H1961"\w* \w of|strong="H5650"\w* \w his|strong="H5414"\w* earlobes \w with|strong="H6213"\w* ◄\w an|strong="H6213"\w* \w awl|strong="H4836"\w*/\w a|strong="H3068"\w* sharp pointed tool►. \w That|strong="H3651"\w* \w will|strong="H1961"\w* indicate \w that|strong="H3651"\w* \w he|strong="H6213"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w your|strong="H5414"\w* \w slave|strong="H5650"\w* \w for|strong="H6213"\w* \w the|strong="H5414"\w* \w rest|strong="H1961"\w* \w of|strong="H5650"\w* \w his|strong="H5414"\w* life. \w Do|strong="H6213"\w* \w the|strong="H5414"\w* \w same|strong="H3651"\w* \w thing|strong="H3651"\w* \w to|strong="H1961"\w* \w any|strong="H6213"\w* female \w slave|strong="H5650"\w* \add who does not want to leave you\add*.   
\p
\v 18 “\w Do|strong="H6213"\w* \w not|strong="H3808"\w* complain \w when|strong="H3588"\w* \w you|strong="H3588"\w* \w are|strong="H5869"\w* required \w to|strong="H3068"\w* \w free|strong="H2670"\w* \w your|strong="H3068"\w* \w slaves|strong="H5647"\w*. \add Keep in mind that\add* \w they|strong="H3588"\w* \w served|strong="H5647"\w* \w you|strong="H3588"\w* \w for|strong="H3588"\w* \w six|strong="H8337"\w* \w years|strong="H8141"\w*, \w and|strong="H3068"\w* \w you|strong="H3588"\w* paid \w them|strong="H7971"\w* \w only|strong="H3588"\w* half \w as|strong="H6213"\w* \w much|strong="H4932"\w* \w as|strong="H6213"\w* \w you|strong="H3588"\w* pay \w the|strong="H3605"\w* \w servants|strong="H5647"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w hire|strong="H7939"\w*. \add If you free them,\add* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w will|strong="H3068"\w* \w bless|strong="H1288"\w* \w you|strong="H3588"\w* \w in|strong="H8141"\w* \w everything|strong="H3605"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w do|strong="H6213"\w*.”   
\s1 Rules about sacrificing firstborn animals  
\p
\v 19 “◄\w Set|strong="H6942"\w* aside \w for|strong="H3068"\w*/\w Dedicate|strong="H6942"\w* \w to|strong="H3068"\w*► \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w the|strong="H3605"\w* \w firstborn|strong="H1060"\w* \w male|strong="H2145"\w* animals \w from|strong="H3068"\w* \w your|strong="H3068"\w* \w cattle|strong="H1241"\w* \w and|strong="H3068"\w* \w sheep|strong="H6629"\w*. \w Do|strong="H5647"\w* \w not|strong="H3808"\w* force \w them|strong="H3205"\w* \w to|strong="H3068"\w* \w do|strong="H5647"\w* \w any|strong="H3605"\w* \w work|strong="H5647"\w* \w for|strong="H3068"\w* \w you|strong="H3605"\w*, \w and|strong="H3068"\w* \w do|strong="H5647"\w* \w not|strong="H3808"\w* ◄\w shear|strong="H1494"\w*/\w cut|strong="H1494"\w* \w off|strong="H1494"\w*► \w the|strong="H3605"\w* wool \add of the firstborn animals to sell the wool\add*.  
\v 20 \w You|strong="H6440"\w* \w and|strong="H3068"\w* \w your|strong="H3068"\w* \w family|strong="H1004"\w* \w may|strong="H3068"\w* \add kill them and\add* eat \w their|strong="H3068"\w* meat \w in|strong="H8141"\w* \w the|strong="H6440"\w* \w presence|strong="H6440"\w* \w of|strong="H1004"\w* \w Yahweh|strong="H3068"\w* \w at|strong="H3068"\w* \w the|strong="H6440"\w* \w place|strong="H4725"\w* \w that|strong="H3068"\w* \w Yahweh|strong="H3068"\w* chooses \add for you to worship him\add*.  
\v 21 \w But|strong="H3588"\w* \w if|strong="H3588"\w* \w the|strong="H3605"\w* \w animals|strong="H1961"\w* \w have|strong="H1961"\w* \w any|strong="H3605"\w* defects, \w if|strong="H3588"\w* \w they|strong="H3588"\w* \w are|strong="H3068"\w* \w lame|strong="H6455"\w* \w or|strong="H3808"\w* \w blind|strong="H5787"\w*, \w or|strong="H3808"\w* \w if|strong="H3588"\w* \w they|strong="H3588"\w* \w have|strong="H1961"\w* \w any|strong="H3605"\w* \w other|strong="H3605"\w* \w serious|strong="H7451"\w* \w defect|strong="H3971"\w*, \w you|strong="H3588"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* \w sacrifice|strong="H2076"\w* \w them|strong="H1961"\w* \w to|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w*.  
\v 22 You \w may|strong="H2889"\w* \add kill and\add* eat \add the meat of those animals\add* \w at|strong="H8179"\w* your homes. Those \w who|strong="H2931"\w* \w have|strong="H8179"\w* done things \w that|strong="H8179"\w* cause \w them|strong="H3162"\w* \w to|strong="H8179"\w* \w become|strong="H3162"\w* unacceptable \w to|strong="H8179"\w* God \w and|strong="H8179"\w* those \w who|strong="H2931"\w* \w have|strong="H8179"\w* not done such things \w are|strong="H8179"\w* permitted \w to|strong="H8179"\w* eat \w that|strong="H8179"\w* meat, just \w like|strong="H3162"\w* anyone \w is|strong="H8179"\w* permitted \w to|strong="H8179"\w* eat \w the|strong="H8179"\w* meat \w of|strong="H8179"\w* \w a|strong="H3068"\w* deer or \w an|strong="H8179"\w* antelope.  
\v 23 \w But|strong="H7535"\w* \w you|strong="H5921"\w* \w must|strong="H1818"\w* \w not|strong="H3808"\w* eat \w any|strong="H3808"\w* \w of|strong="H4325"\w* \w the|strong="H5921"\w* \w blood|strong="H1818"\w*; \w you|strong="H5921"\w* \w must|strong="H1818"\w* drain \w all|strong="H5921"\w* \w the|strong="H5921"\w* \w blood|strong="H1818"\w* \w on|strong="H5921"\w* \w the|strong="H5921"\w* ground \add when you kill those animals\add*.”   
\c 16  
\s1 The Passover Festival  
\p
\v 1 “\add Each year\add* honor \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w by|strong="H3068"\w* celebrating \w the|strong="H3588"\w* \w Passover|strong="H6453"\w* \add Festival\add* \w in|strong="H3068"\w* \w the|strong="H3588"\w* \w month|strong="H2320"\w* \w of|strong="H3068"\w* Abib \add in early spring\add*. \w It|strong="H6213"\w* \w was|strong="H3068"\w* \w on|strong="H3068"\w* \w a|strong="H3068"\w* \w night|strong="H3915"\w* \w in|strong="H3068"\w* \w that|strong="H3588"\w* \w month|strong="H2320"\w* \w that|strong="H3588"\w* \w Yahweh|strong="H3068"\w* rescued \w your|strong="H3068"\w* ancestors \w from|strong="H3318"\w* \w Egypt|strong="H4714"\w*.  
\v 2  \add In order to celebrate that festival\add*, \w go|strong="H3068"\w* \w to|strong="H3068"\w* \w the|strong="H3068"\w* \w place|strong="H4725"\w* \w that|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w will|strong="H3068"\w* choose \add for you to worship him\add*, \w and|strong="H3068"\w* \w offer|strong="H2076"\w* \add there one young animal\add* \w from|strong="H3068"\w* \w your|strong="H3068"\w* \w cattle|strong="H1241"\w* \w or|strong="H1241"\w* \w your|strong="H3068"\w* \w sheep|strong="H6629"\w* \w to|strong="H3068"\w* \w be|strong="H3068"\w* \w the|strong="H3068"\w* \w Passover|strong="H6453"\w* \w sacrifice|strong="H2076"\w*, \w to|strong="H3068"\w* \w honor|strong="H8034"\w* \w Yahweh|strong="H3068"\w* [MTY].  
\v 3  \add When you eat the Passover meal\add*, \w the|strong="H3605"\w* \w bread|strong="H3899"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w eat|strong="H3899"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* \w have|strong="H3117"\w* yeast \w in|strong="H5921"\w* \w it|strong="H5921"\w*. \w You|strong="H3588"\w* \w must|strong="H3808"\w* \w eat|strong="H3899"\w* \w this|strong="H3588"\w* kind \w of|strong="H3117"\w* \w bread|strong="H3899"\w*, \w which|strong="H2557"\w* \w will|strong="H4714"\w* \w be|strong="H3808"\w* called \w the|strong="H3605"\w* \w bread|strong="H3899"\w* \w of|strong="H3117"\w* \w suffering|strong="H6040"\w*/\w misery|strong="H6040"\w*, \w for|strong="H3588"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w*. \w This|strong="H3588"\w* \w is|strong="H3117"\w* \w to|strong="H3318"\w* help \w you|strong="H3588"\w* \w to|strong="H3318"\w* \w remember|strong="H2142"\w* \w all|strong="H3605"\w* \w during|strong="H3117"\w* \w the|strong="H3605"\w* \w time|strong="H3117"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w are|strong="H3117"\w* \w alive|strong="H2416"\w* \w that|strong="H3588"\w* \w when|strong="H3588"\w* \w your|strong="H3605"\w* ancestors \w left|strong="H3318"\w* \w Egypt|strong="H4714"\w*, \add where they were suffering because they were slaves\add*, \w they|strong="H3588"\w* \w left|strong="H3318"\w* very \w quickly|strong="H2649"\w*. \add They did not put in yeast and wait for the dough to swell up\add*.  
\v 4  \add During that festival\add*, \w you|strong="H3605"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* \w have|strong="H3117"\w* \w any|strong="H3605"\w* \w yeast|strong="H7603"\w* \w in|strong="H3117"\w* \w any|strong="H3605"\w* house \w in|strong="H3117"\w* \w your|strong="H3605"\w* \w land|strong="H1366"\w* \w for|strong="H3117"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w*. Furthermore, \w the|strong="H3605"\w* \w meat|strong="H1320"\w* \add of the animals\add* \w that|strong="H7200"\w* \w you|strong="H3605"\w* \w sacrifice|strong="H2076"\w* \w on|strong="H3117"\w* \w the|strong="H3605"\w* \w evening|strong="H6153"\w* \w of|strong="H3117"\w* \w the|strong="H3605"\w* \w first|strong="H7223"\w* \w day|strong="H3117"\w* \add of the Passover Festival must be eaten during that night\add*; \w do|strong="H3605"\w* \w not|strong="H3808"\w* allow \w any|strong="H3605"\w* \w of|strong="H3117"\w* \w it|strong="H7200"\w* \w to|strong="H3117"\w* \w remain|strong="H3885"\w* \w until|strong="H3885"\w* \w the|strong="H3605"\w* \w next|strong="H7200"\w* \w day|strong="H3117"\w*.   
\p
\v 5-6 “To honor \w Yahweh|strong="H3068"\w* our God, you must offer the Passover sacrifice only at the place that he chooses for you \add to worship him\add*; do not offer that sacrifice in any other town in the land that \w Yahweh|strong="H3068"\w* is giving to you. Offer that sacrifice when the sun is setting, at the same time of day that your ancestors \add started to\add* leave Egypt.  
\v 7 \w Boil|strong="H1310"\w* \add the meat\add* \w and|strong="H1980"\w* eat \w it|strong="H1242"\w* \w at|strong="H3068"\w* \w the|strong="H3068"\w* \w place|strong="H4725"\w* \add of worship\add* \w that|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* chooses. \w The|strong="H3068"\w* \w next|strong="H6437"\w* \w morning|strong="H1242"\w*, \w you|strong="H6437"\w* \w may|strong="H3068"\w* \w return|strong="H6437"\w* \w to|strong="H1980"\w* \w your|strong="H3068"\w* tents.  
\v 8 \w Each|strong="H3117"\w* \w day|strong="H3117"\w* \w for|strong="H6213"\w* \w six|strong="H8337"\w* \w days|strong="H3117"\w* \w the|strong="H6213"\w* \w bread|strong="H4682"\w* \w that|strong="H3117"\w* \w you|strong="H3117"\w* eat \w must|strong="H3808"\w* \w have|strong="H3068"\w* \w no|strong="H3808"\w* yeast \w in|strong="H3068"\w* \w it|strong="H6213"\w*. \w On|strong="H3117"\w* \w the|strong="H6213"\w* \w seventh|strong="H7637"\w* \w day|strong="H3117"\w*, \w you|strong="H3117"\w* \w must|strong="H3808"\w* \w all|strong="H6213"\w* \w gather|strong="H6213"\w* \w to|strong="H3068"\w* worship \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w*. \add It will be a day of rest\add*; \w you|strong="H3117"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* \w do|strong="H6213"\w* \w any|strong="H6213"\w* \w work|strong="H4399"\w* \w on|strong="H3117"\w* \w that|strong="H3117"\w* \w day|strong="H3117"\w*.”   
\s1 The festival for harvesting grain  
\p
\v 9 “\add Each year\add*, \w from|strong="H7620"\w* \w the|strong="H5608"\w* day that \w you|strong="H7651"\w* \w start|strong="H2490"\w* \w to|strong="H2490"\w* harvest \w your|strong="H2490"\w* \w grain|strong="H7054"\w*, \w count|strong="H5608"\w* \w seven|strong="H7651"\w* \w weeks|strong="H7620"\w*.  
\v 10 \w Then|strong="H6213"\w*, \w to|strong="H3068"\w* honor \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w*, \w celebrate|strong="H6213"\w* \w the|strong="H5414"\w* Harvest \w Festival|strong="H2282"\w*. \w Do|strong="H6213"\w* \w that|strong="H3068"\w* \w by|strong="H3027"\w* \w bringing|strong="H5414"\w* \w to|strong="H3068"\w* \w him|strong="H5414"\w* \w an|strong="H6213"\w* \w offering|strong="H5071"\w* \add of grain\add*. \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* \w blessed|strong="H1288"\w* \w you|strong="H5414"\w* \add by causing it to grow in your fields during that year\add*. \w If|strong="H1288"\w* \w you|strong="H5414"\w* \w had|strong="H3068"\w* \w a|strong="H3068"\w* big harvest, \w bring|strong="H5414"\w* \w a|strong="H3068"\w* big \w offering|strong="H5071"\w*. \w If|strong="H1288"\w* \w you|strong="H5414"\w* \w had|strong="H3068"\w* \w a|strong="H3068"\w* small harvest, \w bring|strong="H5414"\w* \w a|strong="H3068"\w* small \w offering|strong="H5071"\w*.  
\v 11  \add Each married couple\add* \w should|strong="H3068"\w* \w be|strong="H3068"\w* \w joyful|strong="H8055"\w* \w in|strong="H3068"\w* \w the|strong="H6440"\w* \w presence|strong="H6440"\w* \w of|strong="H1121"\w* \w Yahweh|strong="H3068"\w*. \w Their|strong="H3068"\w* \w children|strong="H1121"\w*, \w their|strong="H3068"\w* \w servants|strong="H5650"\w*, \w the|strong="H6440"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Levi|strong="H3881"\w* \add who are in that town\add*, \w and|strong="H1121"\w* \w the|strong="H6440"\w* \w foreigners|strong="H1121"\w*, \w orphans|strong="H3490"\w*, \w and|strong="H1121"\w* widows \add who are living among you\add*, \w should|strong="H3068"\w* \w also|strong="H3068"\w* \w be|strong="H3068"\w* \w joyful|strong="H8055"\w*. \w Bring|strong="H3881"\w* \w those|strong="H1121"\w* \w offerings|strong="H3068"\w* \w to|strong="H3068"\w* \w the|strong="H6440"\w* \w place|strong="H4725"\w* \w of|strong="H1121"\w* worship \w that|strong="H1616"\w* \w Yahweh|strong="H3068"\w* \w will|strong="H3068"\w* choose.   
\p
\v 12  \add “When you celebrate these festivals\add* \w by|strong="H1961"\w* \w obeying|strong="H8104"\w* \w these|strong="H6213"\w* commands, \w remember|strong="H2142"\w* \w that|strong="H3588"\w* \w your|strong="H8104"\w* ancestors \w were|strong="H1961"\w* previously \w slaves|strong="H5650"\w* \w in|strong="H6213"\w* \w Egypt|strong="H4714"\w*.”   
\s1 The Festival of Living in Shelters  
\p
\v 13 “\add Each year\add*, \w after|strong="H3117"\w* \w you|strong="H3117"\w* \w have|strong="H3117"\w* threshed \w all|strong="H6213"\w* \w your|strong="H6213"\w* grain \w and|strong="H3117"\w* pressed \add the juice from\add* \w all|strong="H6213"\w* \w your|strong="H6213"\w* grapes, \w you|strong="H3117"\w* \w must|strong="H2282"\w* \w celebrate|strong="H6213"\w* \w the|strong="H6213"\w* \w Festival|strong="H2282"\w* \w of|strong="H3117"\w* \add Living in Temporary\add* \w Shelters|strong="H5521"\w* \w for|strong="H6213"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w*.  
\v 14  \add Each married couple\add* along \w with|strong="H8055"\w* \w their|strong="H3881"\w* \w children|strong="H1121"\w*, \w their|strong="H3881"\w* \w servants|strong="H5650"\w*, \w the|strong="H5650"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Levi|strong="H3881"\w* \add who are in that town\add*, \w and|strong="H1121"\w* \w the|strong="H5650"\w* \w foreigners|strong="H1121"\w*, \w orphans|strong="H3490"\w*, \w and|strong="H1121"\w* widows \add who are living among you\add*, \w should|strong="H1323"\w* \w be|strong="H1121"\w* \w joyful|strong="H8055"\w* \w in|strong="H1121"\w* \w the|strong="H5650"\w* presence \w of|strong="H1121"\w* \w Yahweh|strong="H3068"\w*.  
\v 15 Honor \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w by|strong="H3027"\w* celebrating \w this|strong="H3588"\w* \w festival|strong="H2287"\w* \w for|strong="H3588"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w* \w in|strong="H3068"\w* \w the|strong="H3605"\w* \w place|strong="H4725"\w* \w that|strong="H3588"\w* \w Yahweh|strong="H3068"\w* chooses \add for you to worship him\add*. \w You|strong="H3588"\w* \w should|strong="H3068"\w* \w all|strong="H3605"\w* \w be|strong="H1961"\w* \w joyful|strong="H8056"\w*, \w because|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w will|strong="H3068"\w* \w have|strong="H1961"\w* \w blessed|strong="H1288"\w* \w your|strong="H3068"\w* \w harvest|strong="H8393"\w* \w and|strong="H3068"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w other|strong="H3605"\w* \w work|strong="H4639"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w have|strong="H1961"\w* \w done|strong="H1961"\w*.   
\p
\v 16 “\w So|strong="H3808"\w*, \w each|strong="H3605"\w* \w year|strong="H8141"\w* \w all|strong="H3605"\w* \w of|strong="H3068"\w* \w you|strong="H6440"\w* Israeli \w men|strong="H3605"\w* \w must|strong="H2282"\w* gather \add with your families\add* \w to|strong="H3068"\w* worship \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w at|strong="H3068"\w* \w the|strong="H3605"\w* \w place|strong="H4725"\w* \w that|strong="H7200"\w* \w he|strong="H3068"\w* \w will|strong="H3068"\w* choose, \add to celebrate three festivals\add*: \w The|strong="H3605"\w* Passover \w Festival|strong="H2282"\w*, \w the|strong="H3605"\w* Harvest \w Festival|strong="H2282"\w*, \w and|strong="H3068"\w* \w the|strong="H3605"\w* \w Festival|strong="H2282"\w* \w of|strong="H3068"\w* \w Living|strong="H3605"\w* \w in|strong="H8141"\w* \w Temporary|strong="H5521"\w* \w Shelters|strong="H5521"\w*. \w Each|strong="H3605"\w* \w of|strong="H3068"\w* \w you|strong="H6440"\w* \w men|strong="H3605"\w* \w must|strong="H2282"\w* bring [LIT] \w an|strong="H7200"\w* \w offering|strong="H3068"\w* \add for Yahweh to these festivals\add*  
