\id JAS - Ikwerre 
\h Jemisi 
\toc1 Ọkwukwo izi Jemisi 
\toc2 Jemisi 
\toc3 Jem 
\mt2 Ọkwukwo izi 
\mt1 Jemisi 
\imt1 Nhne gbasịri ọkwukwo izi ka 
\im \bk Ọkwukwo izi Jemisi\bk* jihịaru n'agịda ezni o nyernu kpakara rụmu Chiokike gbasarụ nụ “rime kpakara ọwa.” Jemisi ji agịda nhne anya nọowhnu n'ọbochi neezni nhne ke enine, neegesi kpa nye Karaịsi kwesiri o ji akọniche wu bụdnu n'ọwa. Jemisi kwuru ọka gbasịri ọba eze, ọwa, ọrnurna, agwa ọma, okewa, ọkwnata mkpọma, riro, akọniche, okno ọka, oknomokno, ọzi wọhnernerne, okpe ele berere ikpe, nganga, ndidi nụ okpukpe. 
\ip Ọkwukwo izi ka nookwu mkpa ọ zị nụ badnụ nwernu ọkwnata mkpọma nụ nhne ọbula o neeme, lele kpa o kwesiri nye neekpenu Chiokike. 
\iot Nhne zị n'ọkwukwo izi ka 
\io1 Ọpanizo \ior (1:1)\ior* 
\io1 Ọkwnata mkpọma nụ akọniche \ior (1:2-8)\ior* 
\io1 Ọdna ọwa nụ eze \ior (1:9-11)\ior* 
\io1 Ọrnurna \ior (1:12-18)\ior* 
\io1 Ọnurnu nụ omume \ior (1:19-27)\ior* 
\io1 Ọdo aka nụ nsnị gbasịri okewa \ior (2:1-13)\ior* 
\io1 Ọkwnata mkpọma nụ ẹrnu \ior (2:14-26)\ior* 
\io1 Nye Karaịsi nụ riro a \ior (3:1-18)\ior* 
\io1 Nye Karaịsi nụ ọwa \ior (4:1---5:6)\ior* 
\io1 Ezni zị ọdo nụ ọdo \ior (5:7-20)\ior* 
\c 1  
\p  
\v 1 Mawa, Jemisi, nye izi ke Chiokike nụ ke Nyenwe aị Jizọsi Karaịsi, neebekwu kpakara ele ke Chiokike, ke bụ avnụrnu nri nụ ẹbo ele Chiokike zị nụ rime kpakara ọwa. 
\s1 Ọkwnata ovu n'ige ọrnurna 
\p  
\v 2 Rụmu nda m, ọ bụru nhne snarnịma ige ọbula anụ dnabnarnụ nụ nhne ọrnurna zị ọdo n'ọdo.  
\v 3 Kwnornu nụ ọ bụ ọkpa ọkwnata ovu iru jeegweya ndidi.  
\v 4 Ndidi rnụzu ẹrnu a, ma anụ bụru ele zuru ozu, ọ zá nhne kọgwu.  
\v 5 Ọ bụru nụ o zị nye nwée akọniche, nye wam rịo n'aka Chiokike, nye neenye kpakara badnụ hite nụ mkpọma ọma a, ọ zá naakpasị iwhnerne. O jeenye a.  
\v 6 Nye wam jeeji ọkwnata ovu nọorio, o nwékọ mkpọma lawụru. Nye nwernu mkpọma lawụru nụ lele abaka-mini osimini, nga ruwhere neewhe, ọ nọotulizo a olu.  
\v 7 Nye kị chékọ nụ o jeenwehịa nhne ọbula n'aka Nyenwe aị.  
\v 8 Ọ bụ nye mkpọma lawụru, o gwúzole kwem nụ kpakara apna a. 
\s1 Ọdna ọwa nụ eze 
\p  
\v 9 Nnwọ nda ke bụ nye mboni nwụdna nga Chiokike gwelizọru a olu.  
\v 10 Nnwọ nda ke bụ nye kwu nwụdna nga Chiokike gwednarnụ a ẹli. Kwnornu nụ nye kwu jaagawhe lele igwugwere ọhia.  
\v 11 Nga ẹhnam wasịri n'orne bẹkwnu a, ọ chnagbu achara, igwugwere a dnahnala, mma a kwome masị. Kpam masị, nye eze jaagawhe nụ kpakara ẹrnu a. 
\s1 Ọrnurna 
\p  
\v 12 Ngọzi jaazịnu nye wam ovu a siri rikne nụ ige ọrnurna, kwnornu nụ o megbu ọrnurna, o jeenwehịa bụdnu kwó okwo ke Chiokike kweru ele whnụrnu a n'anya mkwna.  
\v 13 Nga be naarna anụ ọrnurna, nye wam kákwadia, “Chiokike naarna m ọrnurna,” kwnornu nụ ọ zá nye nwernu rikne rna Chiokike ọrnurna, Chiokike rná badnụ ọrnurna.  
\v 14 Kọvu be naarna badnụ ọrnurna nga nhne ọjo ke mkpọma nọoto a, ma o duwhu a.  
\v 15 Nga nhne ọjo ke mkpọma wam tụru rime, ọ mụhia mmehie, mmehie masị sopiya, ọ mụhia ẹnwu. 
\p  
\v 16 Rụmu nda m me whnụrnu n'anya, anụ kwé be duwhu anụ.  
\v 17 Kpakara nkesi ọma nụ nhne bụru ọma neehi n'oligwe naava, n'aka Nda ke keru iwhne, nye zá naagbanwo lele kpa enine naagbanwo.  
\v 18 Chiokike pioru o gweru ikwu-ọnu ke ezi ọka a mụhia aị, ma a bụru mkpụru mbọm ke kpakara nhne o keru eke. 
\s1 Ọnurnu nụ omume 
\p  
\v 19 Rụmu nda m me whnụrnu n'anya, anụ mahịa ka, kpakara badnụ zịri gnarnagnarna n'ọnurnu, kọvu ọ bụ́o n'okwu ọka. O wé masị ẹhni wara wara.  
\v 20 Nye ovu owe ẹhni nwée rikne mee nhne jaamasị Chiokike.  
\v 21 Kwnornu nụ ka, anụ gweme kpakara rune nụ kpakara agwa ọjo ke jipihịaru mkpọma anụ. Anụ gweru ẹhni anụ bịta nụ mkpururu Chiokike, nahọru ọka wam ke nwernu rikne ọ znọhia mkpụru mkpọma anụ. 
\p  
\v 22 Anụ bụru ele neeme nhne ọka wam kwuru, anụ bụ́ko ele nọonu ọnu kpọi, needuwhu ẹhni anụ.  
\v 23 Nye ọbula ke nọonu ikwu-ọnu wam kpọi, kọvu ọ zá neeme eme, nụ lele badnụ ke neelekiri ruwhnu a nụ nyno, whnụ ruwhnu a kpa ọ nụ,  
\v 24 o lekirikwo ẹhni a, ngangam, ọ whọga, chezume ọkpa badnụ ọ bụ.  
\v 25 Kọvu nye ọbula ke neelegidne anya n'iwu wam zuru ozu ke neeme badnụ nwernu ẹhni a, ke naadazịgidne nụ rime a, ọ bụ́o nye nọonu ọnu neechezu masị, kọvu nye neeme nhne iwu wam kwuru, Chiokike jọogozi nye wam n'ẹrnu a. 
\p  
\v 26 Ọ bụru nụ nye ọbula bụ nye neekpenu Chiokike, kọvu o knésige riro a eriri, ọ nọoghonu mkpọma a aghịgho, okpenu Chiokike a bụ nhne etekne.  
\v 27 Okpenu Chiokike ke zị snam, ke be mérula emeru nụ ruwhnu Chiokike bụ Nda aị, bụ ka, o chenwanya rụmu nwée nda nụ nne, nụ ele rinya nzi be nwụrnu nụ mmekpẹhni be, nụ badnụ ọ bịta ẹhni a rịchna hite nụ nhne ọjo k'ọwa ka. 
\c 2  
\s1 Ole badnụ anya nụ ruwhnu 
\p  
\v 1 Rụmu nda m, lele ele kweru nụ Nyenwe aị Jizọsi Karaịsi, nyenwe igwugwu, anụ lékọ badnụ anya nụ ruwhnu hite nụ ya naakpa ike.  
\v 2 Ọ bụru nụ nye kwu ke gbagwụ arị mkpaka golu, woru iwo marnụ mma va n'ọgbako anụ, nye mboni ke wogwu nkụkara iwo va masị,  
\v 3 ọ bụru nụ anụ sọbisinu nye wam wogwu iwo marnụ mma, kanụ a, “Dazịri nụ ngadna ka,” kọvu kanụ wọmboni wam, “Gwuzoru hna, mọbu dazịri n'ẹli etekne n'ọchi m,”  
\v 4 anụ kpála ike, bụru masị ele ikpe ọriri ọjo marnụ? 
\p  
\v 5 Anụ bnote nsnị, rụmu nda m me whnụrnu n'anya, Chiokike họrulam ele mboni ke ọwa ka, mee be bụru ele kwu n'ọkwnata ovu be, be bụru masị ele o jeenye ẹli-eze wam o kweru ele whnụrnu a n'anya mkwna.  
\v 6 Kọvu anụ lednarnụ wọmboni anya. Ọ bụ́o ele kwu wam neemegbu anụ? Ọ bụ́o be nọopnurnu anụ zne ọro ikpe?  
\v 7 O bụ́o ele kwu noolulu rẹwhna ọma nye wam nwe anụ? 
\p  
\v 8 Ọ bụru anụ bịta iwu Eze aị ke oligwe ke be gbarụ n'ọkwukwo nsọ, “Whnụ nye agbatibi i n'anya lele ẹhni ị,” anụ mekwarụ nkarị.  
\v 9 Kọvu ọ bụru nụ anụ le badnụ anya nụ ruwhnu, anụ mehielem. Iwu jeegesi nụ anụ dnarnụ iwu.  
\v 10 Nye ọbula ke jaabịta kpakara iwu, kọvu dna otu kpọi, ọ dnanam kpakara iwu wam.  
\v 11 Kwnornu nụ nye wam karụ, “I mékọ ọyi,” kamasịri, “I gbúkọ badnụ.” Ọ bụru nụ i méne ọyi, kọvu i gburu badnụ, i bụ nye dnarnụ iwu.  
\v 12 Anụ kwu, mee masị lele ele Chiokike jeeji iwu ke neeme badnụ nwernu ẹhni a kpe ikpe.  
\v 13 Kwnornu nụ nye nwée mkpọma obirizi, Chiokike jọ́odonu a obirizi nga o jeekpe a ikpe. Obirizi nọonwudna n'ikpe ọmuma. 
\s1 Ọkwnata ovu nwée ẹrnu  //  bụ nhne etekne 
\p  
\v 14 Rụmu nda m, ndaa mbnarna ọbnarnu ọ bụru nụ nye ọbula kaa, “M nwernu m ọkwnata ovu,” kọvu ẹrnu a gésile a? Ọkwnata ovu kpọi ọ jọoznohia a?  
\v 15 Ọ bụru nụ rụmu nne rukna mọbu rụmu nne rinya nwée iwo, mọbu wiri oriri,  
\v 16 mbnarna kịni bụ nhne ọ bnarnụ, ọ bụru nụ otu badnụ n'esilawụru anụ kanụ a, “Lekwarụ anya, o nyee i iwo i joowo, chị ị iyi, nụ wiri i jeeji riji rụwho,” kọvu o nyéne a nhne ke zị anọ-ẹhni mkpa.  
\v 17 Ọ bụ masị kpa ọkwnata ovu ke nwée ẹrnu bụ nhne nwụrnu ọnwu. 
\p  
\v 18 Kọvu otu nyenum jaakaa, “Otu badnụ nwernu ọkwnata ovu, nye berere nwernu ẹrnu ọma.” Gesi m ọkwnata ovu i ke nwée ẹrnu, m jeegesi i ẹrnu ọma m hite nụ ọkwnata ovu m.  
\v 19 I kweru nụ otu Chiokike, ọ bụru ọma. Ele rẹnwu ọjo kwe masịri, be naama rụruru tụ ogwu.  
\v 20 Jị nye iwhnirniwhno! I pioru ọ mahịa nụ ọkwnata ovu ke nwée ẹrnu bụ nhne etekne?  
\v 21 Gweru Ebereham nda aị nụ nhne atụ. Be gwnụsiri a nụ nye mee mma hite n'ẹrnu ọma a, nga o jiri Aziki nnwọ a rukna kwa arịohna n'olu ojo arịohna.  
\v 22 Ị whnụrnu nụ ọkwnata ovu a nụ ẹrnu a rnụkotaru ẹrnu. Ọkwnata ovu a zuru ozu hite n'ẹrnu ọma a.  
\v 23 Nhne be gbarụ n'ọkwukwo nsọ mezuru ke kwuru, “Ebereham kweruru Chiokike, Chiokike gwnụsinu a nụ ọ bụ nye mee mma.” Be sukwu a enyi ke Chiokike.  
\v 24 Anụ whnụrnu nụ be gwnụrnu badnụ nụ nye mee mma hite n'ẹrnu ọma a, ọ bụ́o hite nụ ọkwnata ovu kpọi. 
\p  
\v 25 Kpam masị, gweru Rehabụ nwerinya ewhere nụ nhne atụ. Be gwnụrnu a nụ nye mee mma hite n'ẹrnu ọma, nga o kwubnanyarnụ ele varụ ọ dna ndịdna hi n'ẹli Izirẹli, zihala be n'apna berere.  
\v 26 Lele kpa anọ-ẹhni bụ nhne nwụrnu ọnwu hne enine zị́la, kpam masị, ọkwnata ovu bụ nhne nwụrnu ọnwu hne ẹrnu zị́la. 
\c 3  
\s1 Ledu riro i anya 
\p  
\v 1 Rụmu nda m, kpakara anụ bụ́ko ele zni nhne. Kwnornu nụ anụ magwụ nụ ele zni nhne jeenwe agịda ikpe kakwo ele berere.  
\v 2 Kpakara aị naadnahie n'agịda nhne. Nye zá naadnahie nụ ikwu-ọnu bụ nye zuru ozu, nwe masịri rikne ọ chịkota kpakara ẹhni a.  
\v 3 A neekne ọnu ịyinya eriri ma be mee nhne a pioru be mee, zne masị hne a pioru be zne.  
\v 4 A gweru ọgbo mini lele nhne atụ, ọ bụ n'ezi nụ o zị okpotokpo, okne ruwhere noovughari a, kọvu nụ nye risi ọgbo ji amarna matị nọotughari ọgbo penupe ọbula nye risi ọgbo pioru.  
\v 5 Kpam masị, riro bụ nhne matị zị n'ẹhni aị, ọ nọotu ọka k'agịda. Le kpa igbogo hna ezi bụ ke bẹkwnu matị mernu o nwuzọ bẹkwnu.  
\v 6 Riro bụ bẹkwnu. O jihịaru nụ agịda nhne ọjo n'esilawụru nhne zị aị n'ẹhni. Riro bụ nhne neemeru badnụ, nọomusi bụdnu bẹkwnu hite nụ bẹkwnu ẹli rẹnwu. 
\p  
\v 7 Badnụ nwernu rikne znụ, znụ masịlam kpakara nhne be keru eke, mọbu anọhia ke zị ogwnu zị ichne ichne, nụ ọnunu ọbula, mọbu aznụ zị nụ mini, nhne ọbula nọopnu ọpnu.  
\v 8 Kọvu nụ ọ zá nye nwernu rikne znụ riro. Ọ bụ nhne ọjo ke zá naadazị bidim. Nhne gbu badnụ zị nụ rime a.  
\v 9 A ji riro naaznarnị Nyenwe aị nụ Nda aị Chiokike. A ji masị a nọovu badnụ ọnu bụ nye be kpuru n'oyiyi ke Chiokike.  
\v 10 Ọtu mmamma nụ ọvu ọnu neehi nụ otu ọnu wam nọowhuya. Rụmu nda m, o bụ́o ọma ọ zị kpam.  
\v 11 Be tụhia mini sọ n'ọnu nụ mini lu nlulu n'otu ọmi?  
\v 12 Rụmu nda m, isisi figi o nwernu rikne mịnya mkpụru isisi olivu? Mọbu isisi vaịni o nwernu rikne mịnya mkpụru isisi figi? Mini arụa, o nwernu rikne gbahịa mini so n'ọnu? 
\s1 Akọniche zị ichne ichne 
\p  
\v 13 Ọ bụru nụ o nwernu nye zị n'esilawụru anụ ke nwernu akọniche nụ ọghohia, o gesi a hite nụ bụdnu a, hite masị nụ agwa ọma nụ ogwedna ẹhni a ẹli ke hi n'akọniche.  
\v 14 Kọvu ọ bụru nụ mkpọma anụ jihịaru nụ okwno-awụwa, nụ ovu nlulu, nụ aka-nchnị, anụ kpá nganga. Anụ mée ezi ọka ghọ aghalaghala.  
\v 15 Akọniche ke nụ kpam híge n'oligwe va, ọ bụ ke ọwa. Enine Chiokike zị́la nụ rime a. Ọ bụ nhne ke rẹnwu ọjo neezni.  
\v 16 Hne okwno-awụwa nụ okewa zị, ọgba aghara ghara jaazịri.  
\v 17 Kọvu akọniche ke hi n'oligwe va, beru ọsno zịri rịchna, omekwo, o nwe udno, o nwernu mkpọma ọma, naadnakọta n'otu, o nwernu obirizi nụ ẹrnu ọma, o nwée aghịgho, ọ kwu ezi ọka.  
\v 18 Ele neeme udno naakpa mkpụru udno. Be jọoghohia mkpụru ke imerne ọma. 
\c 4  
\s1 Enyi ke ọwa 
\p  
\v 1 Ọ bụ kịni noovuya ọlu ogwnu nụ ọdogbuta n'esilawụru anụ? Be hi nụ nhne ọjo ke nọogwnu mkpọma anụ, ke nọolu ọgwnu nụ rime anụ.  
\v 2 Anụ pioru nhne, kọvu anụ nwéhịala a, anụ jiknernu o gbu badnụ. Anụ piosi nhne rikne, anụ nwée rikne nwehịa be, anụ jiknernu nọodogbuta, nọolu ọgwnu. Anụ nwée nhne anụ pioga kwnornu nụ anụ rị́ola n'aka Chiokike.  
\v 3 Anụ nọorio, kọvu anụ zá nanahịa kwnornu n'ọriri ọjo ke mkpọma anụ, ma anụ gweru a mee kpa o jiri masị anụ. 
\p  
\v 4 Anụ ele kwé be tụkwasi anụ ovu! Anụ máa nụ nye ọbula ke whnụrnu nhne ọwa n'anya k'agịda nye wam bụ nye irno ke Chiokike? Nye ọbula ke pioru ọ bụ enyi ke ọwa neeme ẹhni a nye irno ke Chiokike.  
\v 5 Anụ chékọ nụ nhne be gbarụ n'ọkwukwo nsọ bụ etekne, “Chiokike neelegidne Enine Nsọ a o yisiri nụ rime anụ anya k'agịda.”  
\v 6 Kọvu Chiokike neenye aị oru k'agịda. Lele kpa be gbarụ a n'ọkwukwo nsọ, “Chiokike noogwuzogidne ele oknomokno, kọvu o neenye rụmu mboni oru.” 
\p  
\v 7 Anụ bịta ẹhni anụ nụ mkpururu Chiokike. Anụ nyịgidne Ekwensu, ọ jaagbawhu hne anụ zị.  
\v 8 Anụ kpayabetụ Chiokike ndụndu, ọ jaakpayabetụ anụ ndụndu. Anụ kwnosnama aka anụ, anụ ele arụru-ẹli. Anụ snụsnama mkpọma anụ, anụ ele mkpọma lawụru.  
\v 9 O gbu anụ igbugbu, anụ ru ọwa, anụ gba mkpe! Rụmu anụ ghọ ẹkwna. Snarnịma anụ ghọ ọ gbarụ ruwhnu.  
\v 10 Anụ gwedna ẹhni anụ nụ ruwhnu Chiokike, o jeegwelizọ anụ olu. 
\s1 Anụ kpékọ ibne anụ ikpe 
\p  
\v 11 Rụmu nda m, anụ kája ibne anụ. Nye ọbula ke naakaja nnwọ nda a, mọbu neekpe a ikpe, ọ naakaja iwu, neekpe masị iwu ikpe. Ọ bụru nụ ị bụ nye neekpe iwu ikpe, ngam, ị bụ́o nye naabịta iwu, kọvu nye ikpe iwu.  
\v 12 Chiokike kpọi bụ nye neenye iwu nụ nye ikpe. Ya nụ nsnụnu a nwernu rikne znọhia aị mọbu gbumekwo aị. Ị bụ nyele ke neekpe badnụ ibne i ikpe? 
\s1 Anụ lúu ọnu nhne  //  ekile jọobu 
\p  
\v 13 Anụ bnote nsnị, anụ ele naakaa, “Tna mọbu ekile, a jeezne mba ka mọbu mba kịyari dazịri pịi otu awha, gba mgbama ahịa, kpa agịda ịwai.”  
\v 14 Anụ máa nhne jeeme ekile. Ndaa nhne bụdnu anụ bụ? Bụdnu anụ nụ lele iknorno-mini ke whụyaru, dazị ige matị, omekwo, o whume n'anya.  
\v 15 Ka bụ nhne anụ znernu okwu, “Ọ bụru ọ masị Nyenwe aị, a jaazị bụdnu mee ka mọbu mee kịyari.”  
\v 16 Kọvu kịtna, anụ noolu ọnu, neeme oknomokno. Kpakara o luu ọnu ka bụ́o ọma.  
\v 17 Nye mahịaru nhne bụru ọma o mee a, o méne a, ọ bụnnu a mmehie. 
\c 5  
\s1 Be dọru ele eze aka  //  nụ nsnị 
\p  
\v 1 Anụ bnote nsnị, anụ ele eze. Anụ kwna ẹkwna, si okokoba kwnornu nụ nhne igbugbu ke jaadnakwasị anụ.  
\v 2 Ẹkwnu anụ roru oro, akịka takwolem iwo anụ.  
\v 3 Kpakara golu nụ siliva anụ tụlam ajarị, ajarị a jọobu nhne akebne megidne anụ. O jeerne anọ-ẹhni anụ lele bẹkwnu, anụ ele kpabịtaru ẹkwnu n'ọbochi ipne-aznụ ka.  
\v 4 Anụ bno nsnị, anụ kwụ́la ele anụ gnornu ẹrnu n'ẹkwu anụ ọgwo ẹrnu be. Ọgwo ẹrnu be naakwna, nhne ọ nọokpokwu anụ dụlam nsnị Nyenwe aị Chiokike ke Meli Nhne Dum.  
\v 5 Anụ wuru bụdnu oriri nụ ọnwunwo n'ọwa, anụ mee lele kpa ọ masịri anụ. Kịtna, ẹhni anụ ke gbarụ ọto jiknernunem, neese ikpe naava ava.  
\v 6 Ele aka be zị rịchna bụ ele anụ marnụ ikpe, anụ gbu be. Be ménne anụ risi rikne. 
\s1 Ọsnuta mkpọma  //  nụ mmekpẹhni 
\p  
\v 7 Rụmu nda m, anụ knata mkpọma tem Nyenwe aị va. Nye ẹrnu ẹkwu ji naaknata mkpọma nụ mkpụru zị okne ọnu ahịa ke ẹkwu a mịi, tem mini ozuzo mbọm nụ ke ipne-aznụ zo.  
\v 8 Anụwa masị, anụ knata mkpọma, dazịsi rikne, kwnornu nụ ọvuva ke Nyenwe aị zị ndụndu.  
\v 9 Rụmu nda m, anụ nwéma mkpọma ọjo n'ẹhni ibne anụ, ma Chiokike gharụ o kpe anụ ikpe. Nye ikpe gwuzogwu n'ọnu-mgbo jiknernu ọ va.  
\v 10 Rụmu nda m, anụ chenwanya nhne ele ọwhnurninya kwuru nụ rẹwhna Nyenwe aị. Anụ gweru be lele nhne atụ nụ ọknata mkpọma nụ rime mmekpẹhni.  
\v 11 Anụ maam nụ a nookwu ele wam ele ọwa ọma kwnornu nụ be knatarụ mkpọma. Anụ nụrnu ọknata mkpọma Jobu, anụ maam nụ Nyenwe aị dọnnu a obirizi n'ipne-aznụ, kwnornu nụ Nyenwe aị bụ nye obirizi nụ nye imerne ọma. 
\p  
\v 12 Rụmu nda m, anụ jí oligwe mọbu ọwa mọbu nhne berere dụ risi. Ọka anụ bụru owe, owe, mọbu ọ́za, ọ́za, ọ zị Chiokike kpe anụ ikpe. 
\s1 Okpukpe be kperu  //  n'ọkwnata ovu 
\p  
\v 13 Ọ zị nye ọbula n'esilawụru anụ ke zị nụ mmekpẹhni? O kpe okpukpe. Ọ zị nye ovu nọoso n'ọnu? Ọ gwnụ eri ọznarni.  
\v 14 Ọ zị nye ọbula ke naarịa ẹhni igbugbu? O sukwu ele okno badnụ ọgbako Chiokike, be kpenu a okpukpe, te a mọno olivu nụ rẹwhna Nyenwe aị.  
\v 15 Okpukpe be jiri ọkwnata mkpọma kpe jọogwo nye nrịria wam. Nyenwe aị jeeme ẹhni si a rikne. Ọ bụru nụ o mehieru, Chiokike jaagbarụnu a.  
\v 16 Kam kpayarụ, anụ kwuhịanu ibne anụ mmehie anụ, anụ kpenu ibne anụ okpukpe ma be gwọ anụ ẹhni igbugbu anụ. Okpukpe nye mee ọma nọornusi ẹrnu rikne.  
\v 17 Ẹlaija bụ badnụ etekne lele aịwa. O kpesiri okpukpe rikne ma mini gharụ o zo, mini zóle dụ awha ẹto nụ ẹnwa isunu.  
\v 18 O kpe kwno okpukpe, oligwe gweya mini ozuzo, ẹli mịnya mkpụru.  
\v 19 Rụmu nda m, ọ bụru nụ otu badnụ n'esilawụru anụ kpahalarụ n'apna ezi ọka, nye berere kwuhnahie a,  
\v 20 anụ mahịa nụ nye mernu nye ọjo tụhnasna n'apna ọjo a, znọhiaru mkpọma a n'ẹnwu. Nye wam kpusnirni agịda mmehie.