\id 2TH
\h 2 إِثِيسَّالُونِيكِييّنْ
\toc1 2 إِثِيسَّالُونِيكِييّنْ
\toc2 2 إِثِيسَّالُونِيكِييّنْ
\toc3 2 تس.
\mt1 2 إِثِيسَّالُونِيكِييّنْ
\c 1
\s1 أَسدْجمْ غَارْ ؤُمزْوَارُو ذ ثْژَادْجِيثْ ن ؤُقَاذِي
\m 
\v 1 بُولُوسْ ذ سِيلْوَانُوسْ ذ ثِيمُوثِييُو، إِ ثْمسْمُونْثْ ن إِثِيسَّالُونِيكِييّنْ، ثنِّي إِدْجَانْ ذِي أَربِّي، بَابَاثْنغْ، ؤُ ذِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.
\v 2 أَرْضَا ذ ڒهْنَا زِي أَربِّي، بَابَاثْنغْ، ؤُ زِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ أَذْ كِيومْ إِڒِينْ. \x ◘ \xo 1:‏2 \xt 1 كُور. 1‏:‏3؛ 1 تس. 1‏:‏1؛ 1 بُط. 1‏:‏2. \x*
\b
\m 
\v 3 إِشُووَّارْ أَذْ نْقَاذَا أَربِّي إِ كنِّيوْ ڒبْذَا، \add أَ\add* أَيْثْمَا، أَمْ مَامّشْ إِتّْڒِيقْ، مِينْزِي لْ-إِيمَانْ نْومْ إِمقَّارْ أَطَّاسْ، أَمْ مَامّشْ ؤُڒَا ذ ثَايْرِي ن كُوڒْ إِجّنْ زَّايْومْ مَارَّا إِ ونِّي ذ أَسْ يُوذْسنْ ثَارنِّي ثْمقَّارْ كْثَارْ، \x ◘ \xo 1:‏3 \xt أَفا. 1‏:‏15؛ فِيل. 1‏:‏3؛ كُول. 1‏:‏3؛ 1 تس. 1‏:‏2. \x*
\v 4 أَڒْ نتّْفيّشْ خَاومْ ذِي ثْمسْمُونِينْ ن أَربِّي خْ سِّيبّثْ ن لْ-إِيمَانْ نْومْ ذ صّْبَارْ نْومْ ذِي مَارَّا أَذَارّشْ نْومْ ذ ڒمْحَايمْ نْومْ نِّي ثكْسِيمْ. \x ◘ \xo 1:‏4 \xt 1 تس. 2‏:‏19. \x*
\v 5 مَانْ أَيَا ذ لْبُورْهَانْ ن ڒْحُوكْمْ إِسّڭّْذنْ ن أَربِّي، أَقَا ثتّْوَاحَاسْبمْ ثسْذَاهدْجمْ ثَاڭلْذِيثْ، ثنِّي خفْ ثكْسِيمْ أَمَارّثْ. \f ◼ \fr 1:‏5 \ft \bd ’لْپُورْهَانْ‘\bd* - نِيغْ: ’دَّالِيلْ‘.\f*  \x ◘ \xo 1:‏5 \xt 1 تس. 2‏:‏14؛ يَاه. 6. \x*
\v 6 ؤُ مَاڒَا خنِّي ذ ڒْحقّْ زَّاثْ إِ أَربِّي ؤُمِي غَا إِخدْجصْ س ڒْمحْنثْ إِ يِينِّي كنِّيوْ إِحصَّارنْ، \x ◘ \xo 1:‏6 \xt زَاك. 2‏:‏12. \x*
\v 7 \add خنِّي\add* نتَّا أَذْ كِيذْنغْ إِسّدَّارْ ؤُڒَا ذ كنِّيوْ إِنِّي إِتّْوَاحْصَارنْ، \add وَاهْ أَذْ أَنغْ إِسّدَّارْ أَكِيذْومْ\add* غَارْ ؤُسَارْڭبْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ زڭْ ؤُجنَّا أَكْ-ذ ڒْعسْكَارَاثْ ن لْمَالَاكَاثْ نّسْ، \x ◘ \xo 1:‏7 \xt 1 تس. 4‏:‏16. \x*
\v 8 خْ مِينِّي إِ غَا إِنْثَاقمْ ذِي ثْمسِّي إِتّحْذُوذُوقنْ خْ يِينِّي وَارْ إِسِّيننْ شَا أَربِّي ؤُ خْ يِينِّي وَارْ خْسنْ أَذْ شهْذنْ س ڒخْبَارْ أَصبْحَانْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏8 \xt رُوم. 2‏:‏8؛ 2 بُط. 3‏:‏7. \x*
\v 9 مِينْزِي إِنَا أَذْ تّْوَاعَاقْبنْ ذِي ڒْحُوكْمْ س ؤُهلّكْ إِ ڒبْذَا أَمْ يَاڭّْوجنْ خْ وُوذمْ ن سِيذِيثْنغْ ؤُ خْ ؤُعُودْجِي ن جّهْذْ نّسْ، \x ◘ \xo 1:‏9 \xt إِشا. 2‏:‏19. \x*
\v 10 خْمِي د غَا يَاسْ نتَّا حِيمَا أَذْ إِتّْوَاعُودْجِي ذڭْ وَاسّْ نِّي ذِي مَارَّا إِمْقدَّاسنْ نّسْ، ؤُ حِيمَا أَذْ إِسّْشنْ ڒعْجَايبْ نّسْ س يِينِّي ذَايسْ يُومْننْ، مِينْزِي ثُومْنمْ زِي شّْهَاذثْ نّغْ إِ كنِّيوْ ذڭْ وَاسّْ نِّي. \x ◘ \xo 1:‏10 \xt ڒخ. 1‏:‏11؛ 1 تس. 1‏:‏10؛ أَسَا. 1‏:‏7. \x*
\m 
\v 11 س ؤُينِّي نْكسِّي أَومْ ڒْمعْرُوفْ ڒبْذَا، حِيمَا أَربِّي نّغْ أَذْ كنِّيوْ يڭّْ أَذْ ثسْذَاهدْجمْ ثَاڒَاغِيثْ نْومْ، ؤُ \add حِيمَا\add* أَذْ كنِّيوْ إِشُّورْ س جّهْذْ مَاحنْذْ أَذْ ثِيڒِيمْ ثْوجْذمْ قَاعْ إِ \add ثْمڭَّا ن\add* ثْشُونِي ؤُ إِ ڒخْذَايمْ ن لْ-إِيمَانْ،
\v 12 حِيمَا أَذْ ذَايْومْ إِتّْوَاعُودْجِي إِسمْ ن سِيذِيثْنغْ يَاسُوع، ؤُشَا ؤُڒَا ذ كنِّيوْ ذَايسْ، عْلَاحْسَابْ أَرْضَا ن أَربِّي نّغْ ذ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.
\b
\b
\c 2
\s1 بْنَاذمْ ن دّْنُوبْ
\m 
\v 1 أَقَا نتّْزَاوڭْ كنِّيوْ، \add أَ\add* أَيْثْمَا، زِي جِّيهثْ ن ثْوَاسِيثْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ ذ وسْمُونِي نّغْ غَارسْ،
\v 2 أَقَا وَارْ ثتّْنخْڒِيعمْ نِيغْ ثسْحِيسّْفمْ شَا ذغْيَا، وَارْ إِدْجِي س إِجّْ ن وَاوَاڒْ نِيغْ س شَا ن أَرُّوحْ نِيغْ س إِشْثْ ن ثبْرَاثْ أَخْمِي زَّايْنغْ، \add إِ إِقَّارنْ\add*: ”خْزَارْ، أَسّْ ن سِيذِيثْنغْ يُوسَا-د!“ \x ◘ \xo 2:‏2 \xt إِرْم. 29‏:‏8؛ مت. 24‏:‏4؛ أَفا. 5‏:‏6؛ كُول. 2‏:‏18؛ 1 يُوح. 4‏:‏1. \x*
\v 3 وَارْ تّجِّي ؤُڒَا ذ إِجّْ أَذْ كنِّيوْ إِغْوَا س شَا ن وبْرِيذْ، مِينْزِي \add أَسّْ\add* نِّي وَارْ د-إِتِّيسْ قْبڒْ  إِ د غَا يَاسْ ؤُغوّغْ ؤُشَا أَذْ د-إِبَانْ بْنَاذمْ ن دّْنُوبْ، أَقَا-ث ذ مِّيسْ ن ثهْلِيكثْ. \f ◼ \fr 2:‏3 \ft \bd ’مِّيسْ ن ثهْلِيكثْ‘\bd* - نِيغْ: ’مِّيسْ ن ڒخْصَارثْ‘ نِيغْ ’مِّيسْ ن ڒفْنَا‘.\f*  \x ◘ \xo 2:‏3 \xt مت. 24‏:‏23؛ 1 تِيم. 4‏:‏1؛ 1 يُوح. 2‏:‏18. \x*
\v 4 نتَّا إِتّمْعَاڒَا ؤُ إِسّْعُودْجْ إِخفْ نّسْ خْ مَارَّا مِينْ إِتّْوَاسمَّانْ ’أَربِّي‘ نِيغْ ’أَعْبَاذْ‘، أَڒْ غَا إِقِّيمْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ ن أَربِّي أَمشْنَاوْ نتَّا ذ أَربِّي إِ يدْجَا، ؤُشَا أَذْ إِسّْشنْ إِ يِيخفْ نّسْ، أَقَا نتَّا أَخْمِي أَربِّي. \x ◘ \xo 2:‏4 \xt دَان. 11‏:‏36. \x*
\m 
\v 5 مَا وَارْ ثعْقِيڒمْ شَا ؤُمِي ثُوغَا أَيِي كِيومْ، أَقَا نِّيغْ أَومْ-ث؟
\v 6 مَاشَا ڒخُّو ثِيوْضمْ ثسّْنمْ مِينْ ذ أَسْ إِبدّنْ عَاذْ ذڭْ وبْرِيذْ، حِيمَا أَذْ د-إِبَانْ ذِي ڒْوقْثْ نّسْ.
\v 7 سِّيرّْ ن ڒْمُوعْصِييّثْ أَقَا إِخدّمْ \add ڒخُّو\add*. مَاشَا مَاڒَا إِمّكْسِي زِي ڒْوسْطْ مِينْ ذ أَسْ إِسّْبدّنْ عَاذْ ذڭْ وبْرِيذْ ڒخُّو،
\v 8 أَذْ د-إِضْهَارْ بَابْ ن ڒْمُوعْصِييّثْ، ونِّي غَا إِسّْهلّكْ سِيذِيثْنغْ يَاسُوع س ثْوَارِّيثْ ن نّفْسْ زڭْ ؤُقمُّومْ نّسْ، أَذْ ث إِسّبْضڒْ خْمِي د غَا ثْبَانْ ثْوَاسِيثْ نّسْ. \x ◘ \xo 2:‏8 \xt أَيُوبْ 4‏:‏9؛ إِشا. 11‏:‏4. \x*
\v 9 مَاغَارْ ثَاوَاسِيثْ ن \add بَابْ نِّي ن ڒْمُوعْصِييّثْ\add* أَذْ ثْرَاحْ \add جْمِيعْ\add* أَكْ-ذ ڒْخذْمثْ ن شِّيطَانْ س مَارَّا جّهْذْ ذ ڒعْڒَامَاثْ ذ لْمُوعْجِيزَاثْ إِسّْخَارِّيقنْ، \x ◘ \xo 2:‏9 \xt أَعَوذ. 13‏:‏2؛ يُوح. 8‏:‏41؛ 2 كُور. 4‏:‏4؛ أَفا. 2‏:‏2؛ أَسَا. 13‏:‏13. \x*
\v 10 ؤُ س مَارَّا ڒْغشّْ ن ڒْمُوعْصِييّثْ ذڭْ يِينِّي إِ غَا إِهلّْكنْ، مِينْزِي نِيثْنِي وَارْ قْبِيڒنْ شَا ثَايْرِي ن ثِيذتّْ حِيمَا أَذْ زَّايسْ أَفنْ ثُوذَارْثْ. \x ◘ \xo 2:‏10 \xt 2 كُور. 2‏:‏15؛ 4‏:‏3. \x*
\v 11 س ؤُينِّي أَربِّي أَذْ غَارْسنْ د-إِسّكّْ مِينْ ثنْ غَا يَارّْ س جّهْذْ غَارْ ؤُودَّارْ، أَڒْ غَا يَامْننْ ذڭْ ؤُخَارِّيقْ. \x ◘ \xo 2:‏11 \xt رُوم. 1‏:‏24؛ 1 تِيم. 4‏:‏1. \x*
\v 12 مَارَّا إِنِّي وَارْ يُومِيننْ شَا ذِي ثِيذتّْ، مَاشَا إِخْسنْ ڒْمُوعْصِييّثْ كْثَارْ، أَذْ تّْوَاحَاكْمنْ.
\b
\s1 أَبذِّي إِمْثمْ ذِي لْ-إِيمَانْ
\m 
\v 13 مَاشَا إِشُووَّارْ أَنغْ أَذْ نْقَاذَا أَربِّي ڒبْذَا خَاومْ، \add أَ\add* أَوْمَاثنْ نّغْ، إِنِّي خفْ إِعِيزّْ سِيذِيثْنغْ، أَقَا أَربِّي إِخْضَارْ إِ كنِّيوْ زڭْ ؤُمزْوَارُو إِ ثُوذَارْثْ، س ثْقدَّاسْثْ زِي أَرُّوحْ ؤُ س لْ-إِيمَانْ ن ثِيذتّْ.
\v 14 أَقَا إِڒَاغَا-د خَاومْ إِ مَانْ أَيَا س ؤُبَارّحْ نّغْ س ڒخْبَارْ أَصبْحَانْ، حِيمَا أَذْ ثِيڒِيمْ إِ ؤُعُودْجِي ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.
\m 
\v 15 س ؤُينِّي، \add أَ\add* أَيْثْمَا، بدّمْ نِيشَانْ ؤُشَا طّْفمْ ذِي ثْوصَّا إِ ذ أَومْ إِتّْوَاسّْڒمْذنْ زَّايْنغْ، مَا س وَاوَاڒْ نِيغْ س ثبْرَاثْ نّغْ. \x ◘ \xo 2:‏15 \xt 2 تس. 3‏:‏6. \x*
\m 
\v 16 مَاشَا نتَّا، سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، ؤُ أَربِّي، بَابَاثْنغْ، ونِّي ذ أَنغْ إِخْسنْ ذ ونِّي ذ أَنغْ إِوْشنْ أَفوّجْ إِتّْذُومَانْ ذ ؤُسِيثمْ إِشْنَانْ س أَرْضَا نّسْ،
\v 17 أَذْ إِسّْفوّجْ ؤُڒَاونْ نْومْ ؤُشَا أَذْ كنِّيوْ إِسّجْهذْ ذِي مَارَّا أَوَاڒْ ؤُ ذِي مَارَّا ڒْخذْمثْ ثَاصبْحَانْثْ. \x ◘ \xo 2:‏17 \xt 1 تس. 3‏:‏13. \x*
\b
\b
\c 3
\s1 أَوَاڒنْ ن بُولُوسْ غَارْ أَنڭَّارُو ذ ؤُسدْجمْ
\m 
\v 1 \add أَ كنِّيوْ،\add* أَوْمَاثنْ نّغْ، زِي سَّا ذ ثْسَاونْثْ كْسِيمْ أَنغْ ڒْمعْرُوفْ حِيمَا أَوَاڒْ ن سِيذِيثْنغْ أَذْ د-إِفّغْ ذغْيَا ؤُ أَذْ إِتّْوَاسّْعُودْجْ، أَمْ مَامّشْ ثُوغَا إِمْسَارْ جَارْ أَومْ عَاوذْ، \x ◘ \xo 3:‏1 \xt مت. 9‏:‏38؛ أَفا. 6‏:‏19؛ كُول. 4‏:‏3. \x*
\v 2 حِيمَا أَذْ نتّْوَافكّْ زڭْ إِوْذَانْ وَارْ إِحْڒِينْ، إِعفَّاننْ، مِينْزِي لْ-إِيمَانْ وَارْ إِدْجِي غَارْ مَارَّا. \x ◘ \xo 3:‏2 \xt يُوح. 6‏:‏44؛ رُوم. 15‏:‏31. \x*
\m 
\v 3 مَاشَا سِيذِي ذ أَمْثِيقِّي. نتَّا أَذْ خَاومْ إِحْضَا ؤُشَا أَذْ كنِّيوْ إِفكّْ زڭْ ؤُمْعفَّانْ. \x ◘ \xo 3:‏3 \xt يُوح. 17‏:‏15؛ 1 تس. 5‏:‏24. \x*
\v 4 مَاشَا نشِّينْ نتِّيقّْ ذَايْومْ ذِي سِيذِيثْنغْ، بلِّي مِينْ خفْ نْوصَّا كنِّيوْ، أَقَا ثتّڭّمْ ث ؤُشَا أَذْ ثقِّيممْ ثتّڭّمْ ث.
\v 5 أَذْ إِنْذهْ سِيذِيثْنغْ ؤُڒَاونْ نْومْ غَارْ ثَايْرِي ن أَربِّي ؤُ غَارْ ؤُبَارّحْ س ڒخْبَارْ أَصبْحَانْ ن لْمَاسِيحْ.
\b
\m 
\v 6 نْوصَّا كنِّيوْ، \add أَ\add* أَيْثْمَا، ذڭْ يِيسمْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، أَذْ ثْحيّْذمْ إِ كُوڒْ ؤُمَا إِ إِڭُّورنْ ذِي مِينْ وَارْ إِحْڒِينْ، وَارْ إِدْجِي عْلَاحْسَابْ ثِيوصَّا إِ زَّايْنغْ إِكْسِي. \x ◘ \xo 3:‏6 \xt 1 كُور. 5‏:‏11؛ 2 تس. 2‏:‏15؛ 3‏:‏14؛ ثِيث. 3‏:‏10. \x*
\v 7 أَقَا كنِّيوْ ثسّْنمْ مَامّشْ إِشُووَّارْ أَذْ أَنغْ ثضْفَارمْ، مِينْزِي نشِّينْ وَارْ نُويُورْ جَارْ أَومْ ذِي مِينْ وَارْ إِحْڒِينْ. \x ◘ \xo 3:‏7 \xt 1 كُور. 11‏:‏1؛ 1 تس. 1‏:‏6، 7؛ 2 تس. 2‏:‏10. \x*
\v 8 وَارْ نشِّي أَغْرُومْ أَكْ-ذ حذْ بَاطڒْ، مَاشَا س ڒْخذْمثْ ذ ثَامَارَا ثُوغَا أَنغْ نْخدّمْ دْجِيڒثْ ذ وَاسّْ، حِيمَا وَارْ د-نتِّيسْ نذْقڒْ خْ شَا ن إِجّنْ زَّايْومْ. \x ◘ \xo 3:‏8 \xt ڒخ. 18‏:‏3؛ 20‏:‏34؛ 1 كُور. 4‏:‏12؛ 2 كُور. 11‏:‏9؛ 12‏:‏13؛ 1 تس. 2‏:‏9. \x*
\v 9 وَارْ إِدْجِي مِينْزِي وَارْ غَارْنغْ تّسْرِيحْ إِ مَانْ أَيَا، مَاشَا حِيمَا أَذْ نڭّْ إِخفْ نّغْ ذ لْمِيثَالْ إِ غَا ثضْفَارمْ. \x ◘ \xo 3:‏9 \xt 1 كُور. 4‏:‏16؛ 9‏:‏3، 6؛ 11‏:‏1؛ فِيل. 3‏:‏17؛ 1 تس. 1‏:‏6؛ 2‏:‏9. \x*
\v 10 مِينْزِي ڒَامِي ثُوغَا أَنغْ ندْجْ أَكِيذْومْ، أَقَا نْوصَّا أَمُّو: مَاڒَا حذْ وَارْ إِخْسْ أَذْ إِخْذمْ، وَارْ إِتّتّْ عَاوذْ.
\v 11 مِينْزِي نسْڒَا أَقَا ذِينْ شَا جَارْ أَومْ إِنِّي إِڭُّورنْ ذِي مِينْ إِعفّْننْ، وَارْ خدّْمنْ قَاعْ، مَاشَا تّڭّنْ \add مْغِيرْ\add* مِينْ وَارْ إِسكّْوِينْ.
\v 12 أَقَا نُومُورْ ؤُ نْزِييَّارْ إِ-ثنْ ذِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ حِيمَا أَذْ خذْمنْ ذِي ڒْهُوذْنثْ، أَذْ شّنْ أَغْرُومْ نْسنْ. \x ◘ \xo 3:‏12 \xt أَفا. 4‏:‏28؛ 1 تس. 4‏:‏11. \x*
\m 
\v 13 مَاشَا كنِّيوْ، \add أَ\add* أَيْثْمَا، وَارْ تُّوحِيڒمْ شَا مَاحنْذْ أَذْ ثڭّمْ مِينْ إِشْنَانْ. \x ◘ \xo 3:‏13 \xt ڭال. 6‏:‏9. \x*
\v 14 مَاشَا مَاڒَا شَا ن إِجّنْ وَارْ إِطَاعْ إِ وَاوَاڒنْ إِ يُورَانْ ذِي ثبْرَاثْ-أَ، بْضَامْ خَاسْ، وَارْ تّْخدْجَاضمْ شَا أَكِيذسْ، حِيمَا أَذْ إِذْوڒْ إِتّْسضْحَا، \x ◘ \xo 3:‏14 \xt مت. 18‏:‏17؛ 1 كُور. 5‏:‏9؛ 2 تس. 3‏:‏6. \x*
\v 15 مَاشَا وَارْ ث ثتّْحسّْبمْ ذ ڒعْذُو مَاشَا نذْهمْ ث غَارْ وبْرِيذْ أَمْ يِيجّْ ن ثَاوْمَاثْ.
\b
\m 
\v 16 مَاشَا سِيذِي ن ڒهْنَا أَذْ أَومْ إِوْشْ ڒهْنَا إِ ڒبْذَا خْ مَارَّا إِغزْذِيسنْ. سِيذِيثْنغْ أَذْ يِيڒِي أَكِيذْومْ مَارَّا. \x ◘ \xo 3:‏16 \xt رُوم. 15‏:‏33؛ 16‏:‏20؛ 1 كُور. 14‏:‏33؛ 2 كُور. 13‏:‏11؛ فِيل. 4‏:‏9؛ 1 تس. 5‏:‏23. \x*
\m 
\v 17 إِجّْ ن ؤُسدْجمْ س ؤُفُوسْ إِنُو. نشّْ، بُولُوسْ، ؤُرِيغْ أَيَا. ثَا ذ ڒعْڒَامثْ ذِي مَارَّا ثِيبْرَاثِينْ إِنُو. أَمُّو إِ ذ ؤُرِيغْ. \x ◘ \xo 3:‏17 \xt 1 كُور. 16‏:‏21؛ كُول. 4‏:‏18. \x*
\m 
\v 18 أَرْضَا ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ أَذْ أَكِيذْومْ يِيڒِي مَارَّا، \add أَ أَوْمَاثنْ إِنُو\add*. أَمِينْ. 
