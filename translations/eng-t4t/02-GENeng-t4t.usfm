\v 11 \w So|strong="H6213"\w* \w now|strong="H6258"\w* \w I|strong="H3588"\w* pray \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w will|strong="H1961"\w* rescue \w me|strong="H6213"\w* \w from|strong="H1961"\w* [MTY] \w my|strong="H3605"\w* \add older \add* brother Esau, \w because|strong="H3588"\w* \w I|strong="H3588"\w* \w am|strong="H1961"\w* afraid \w that|strong="H3588"\w* \w he|strong="H3588"\w* \w and|strong="H5650"\w* \w his|strong="H3605"\w* \w men|strong="H5650"\w* \w will|strong="H1961"\w* \w come|strong="H1961"\w* \w and|strong="H5650"\w* attack \w and|strong="H5650"\w* kill \w me|strong="H6213"\w* \w and|strong="H5650"\w* \w the|strong="H3605"\w* children \w and|strong="H5650"\w* \w their|strong="H3605"\w* mothers.
