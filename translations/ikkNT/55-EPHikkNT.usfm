\id EPH Ika New Testament 2009
\h Ndị Ẹfẹsọsị
\toc1 Ẹhụhụọ-Ozi Pọlụ Dejẹnni Ndị Ẹfẹsọsị
\toc2 Ndị Ẹfẹsọsị
\toc3 Ẹfẹ
\mt2 Ẹhụhụọ-Ozi Pọlụ Dejẹnni
\mt1 Ndị Ẹfẹsọsị
\c 1
\cl Isi Nke Ohu
\s1 Ekele
\p 
\v 1 Mmẹ wụ Pọlụ de Ẹkụkwọ-ozini. M wụ onyẹ ozi pụ-ichẹn Kraịstị wụ Jizọsị ghahanị uche Osolobuẹ. M rị e dejẹnni ndị nke Osolobuẹ rị Ẹfẹsọsị, ndị wẹ gi e dọn-ẹnya imẹ Kraịstị wụ Jizọsị.
\v 2 Ẹfọma lẹ udọn, hụn gha ẹka Osolobuẹ Nẹdi ẹnyi lẹ Onyẹ-nwọnni-ẹnyi wụ Jesu Kristi bịa, ya nọyeni ụnụ.
\s1 Ngọzi Ẹnyi Nwọn Imẹ Kraịstị
\p 
\v 3 Ekele ya rị nị Osolobuẹ, onyẹ hụ wụ Osolobuẹ lẹ Nẹdi Onyẹ-nwọnni-ẹnyi wụ Jesu Kristi, n'o yeọlẹ ẹnyi ngọzi imẹ-mmọn ile rị elu-igwee makẹni ẹnyi rị imẹ Kraịstị.
\p 
\v 4 Nị Osolobuẹ d'e kedẹ ụwa, ọ họtọgụọlẹ ẹnyi imẹ Kraịstị, makẹni ọ nwẹ ihiẹn-ọsụsụọ ebe ẹnyi rị—kẹni ẹnyi wụrụ ndị rị nsọ, nwọnlẹni nkọrịanị ẹnya Osolobuẹ.
\v 5 Ọ nọ kwademẹ nị, o ru, ọ mụnrụn ẹnyi ye ikpun-ụlọ a ghahanị Jesu Kristi—makẹni ọ sụọghọ a, makẹni uche ẹ rọ.
\v 6 O mẹ ẹ kẹni wẹ gi ẹ ja Osolobuẹ mma makẹ okẹn ẹfọma o mẹ, hụn o hukpu ẹnyi ghahanị ezi Nwa a!
\v 7 Makẹni ẹnyi rị imẹ Kraịstị, ẹnyi a wụrụọlẹ ndị wẹ gi ẹdeke ẹ gbarị—ya wụ nị Chuku a gbagharịgụọ ẹnyi njọ; ifiri okẹn ẹfọma a k'o gi mẹ ẹ.
\v 8 O gi amamihiẹn lẹ nghọta a ile mẹ ni ẹnyi okẹn ẹfọmanị.
\v 9 Ọ nọ nwan mẹ ẹnyi marịn ihiẹn o bu obi, hụn o te zuemẹ; ihiẹn hụn ọ kwademẹ ketekete n'o jẹnkọ d'a rụnfụha imẹ Kraịstị. O mẹgụọ ẹnyi marịn a makẹni ọ sụọghọ a n'o mẹ ẹrịra.
\v 10 Ihiẹnni o bu obi wụ nị, ogẹn zu, o wegbama ihiẹn ile che okpuru Kraịstị—kẹ ihiẹn rị elu-igwee kẹ ihiẹn rị enu-ụwa.
\p 
\v 11 Makẹni ẹnyi rị imẹ Kraịstị, ihiẹn Osolobuẹ e rugụọ ẹnyi ẹka—makẹni Osolobuẹ, hụn e mẹ ihiẹn ile hụn o mẹ n'o gi ẹ mẹzu uche ẹ, gi ẹka a họtọ ẹnyi ketekete n'o gi ẹnyi mẹzu uche ẹ.
\v 12 O mẹ ẹ kẹni ẹnyi ndị ibuzọ tụkwasị Kraịstị obi hụn ụzọ wụrụ ihiẹn wẹ gi ifiri ẹ a ja Osolobuẹ mma n'o nwẹkẹ ọghọ.
\p 
\v 13 Kẹ ụnụ lẹ enwẹn ọnụ, ọnụ hẹnrinzikwọ ndị nke Kraịstị ogẹn ọnụ gi nụ oku hụ wụ ezioku, kweri—oku ahụn wụ oziọma ahụn ụnụ gi nwẹhẹn nzụọpụha. Ụnụ e kwerigụụ nị Jesu, Osolobuẹ nọ bu Mmọn-nsọ o kwe nkwa a che imẹ ndụn ụnụ, gi ẹ ye ụnụ ahịma a—gi ghọsị nị ụnụ wụ nke ẹ.
\v 14 Mmọn-nsọ kẹ Osolobuẹ e bu ụzọ e ye; ịya kẹ Osolobuẹ gi a ghọsị nị ẹnyi jẹnkọ d'e nwọnhẹnchanrịn ihiẹn ile o kwe nkwa—o ru ogẹn ahụn Osolobuẹ k'e gi werichanrịn ẹnyi—ẹnyi ndị ọ gbarịgụụ. Ọnwan k'e wẹhẹ ni Osolobuẹ ọjịja-mma n'o nwẹkẹ ọghọ.
\s1 Ekpere Pọlụ Mẹ Ni Ndị Kwerini
\p 
\v 15 Ịya haịn o gi mẹ ni, kete m'a nụlẹ oku okweri ụnụ kwerini Di-nwọnni-ẹnyi wụ Jesu lẹ ihiẹn-ọsụsụọ ụnụ nwọn ebe ndị nke Osolobuẹ ile rị,
\v 16 akụsịtuni m iye Osolobuẹ ekele makẹ ufiri ụnụ. M hụ a nyanhan ụnụ ogẹn ile m gha e mẹ ekpere.
\v 17 M'a rịọ Nẹdi hụn nwẹ ọghọ, hụn wụ Osolobuẹ Onyẹ-nwọnni-ẹnyi wụ Jesu Kristi, n'o ye ụnụ mmọn ịmarịn-ihiẹn; ya ghọsịsọnmẹ ụnụ ihiẹn—kẹ ụnụ dọn rị a marịnwaye ẹ ọhụnma.
\v 18 M'a rịọ a ọnwan kẹni ẹnya imẹ-mmọn ụnụ shịapụ, ụnụ a hụn ụzọ marịn ihiẹn ahụn o butọ o gi ifiri ẹ kpọ ụnụ, marịn kẹ ihiẹn o kwademẹ o jẹnkọ d'e ye ndị-nsọ a hihan ogbe, marịnzịkwọ k'o nwẹhan ọghọ;
\v 19 ọnụ a ghọtazị kẹ ikẹn o gi a rụn ọrụn imẹ ẹnyi ndị kwerini han, ikẹn hụn wẹ ghalẹni a sa ẹka e ku k'ọ han, hụn han kẹ ikẹn o gi wụrụ Osolobuẹ.
\v 20 Ya wụ ikẹn k'ọ ghọsị ogẹn o gi gha ọnwụn weli Kraịstị, m'ẹ nọdị anị ẹka-nni ẹ imẹ elu-igwee;
\v 21 nke wụnị Kraịstị kachanrịn ọkịkị ile lẹ ikẹn ile rị ichẹn-ichẹn lẹ ihiẹn ile w'a gbaye agbaye lẹ ẹfan lẹ nzere ile—ẹlẹdẹ ndị rị ogẹnni sụọ, kanị kẹzị ndị rịdẹ ogẹn hụn lalanị.
\v 22 Osolobuẹ e wegụọ ihiẹn ile che ẹ okpuru ụkụ, tumẹ ẹ Onyẹ-isi ụka, Onyẹ ihiẹn ile rị okpuru ẹ.
\v 23 Ụka wụ ẹhụ a; imẹ ụka kẹ ihiẹn ile banyen'ẹ rị; ya lẹ enwẹn ẹ wụ onyẹ hụn rị ebe ile, hụn e mẹ ihiẹn ile e zu oke.
\c 2
\cl Isi Nke Ẹbụọ
\s1 Wẹ Gha Ọnwụn Wepụha Ẹnyi Shi Ndụn
\p 
\v 1 Ogẹn mbụ, ọnụ wụ ndị nwụnnị, makẹ njọ lẹ mmẹfie
\v 2 ụnụ rị e mẹsọnmẹ. Ogẹn hụ, ụnụ e sọn eje-ụzọ ndị ụwa, e sọn onyẹ hụn ikẹn eje-mmọn rị elu rị okpuru ẹ, mmọn hụ hụn rị nwan ọrụn imẹ igunrun ndị hụ e nupụ-isi okpuru Osolobuẹ.
\v 3 Eziẹ, ẹnyi ile te rị e bi kẹ wẹ, e mẹ ihiẹn ọwụlẹ a sụọ ẹhụ ẹnyi lẹ obi ẹnyi, e bi k'ọ rị ẹnyi; e mẹ ihiẹn ọwụlẹ gụnnị ẹnyi lẹ ihiẹn ọwụlẹ la ẹnyi ẹnya. Iwe-lẹ-ọnụma Osolobuẹ te rịzịkwọ e che ẹnyi nọkẹ ndị ọzọ ile.
\v 4 Kanị, makẹni Osolobuẹ e mẹkẹ onyẹ-omikẹn, makẹni o nwẹ okẹn ihiẹn-ọsụsụọ ebe ẹnyi rị—
\v 5 kẹ ogẹn hụ ẹnyi te gidẹ wụ ndị nwụnnị makẹ njọ ẹnyi, ọ nọ gha ọnwụn wefụha ẹnyi, mẹ ẹnyi sọn Kraịstị rịzị ndụn.
\p Ẹfọma Osolobuẹ kẹ ụnụ gha nwẹ nzụọpụha.
\p 
\v 6 Ọ ghagụụ ọnwụn weli ẹnyi, ọ nọ wesi ẹnyi elu k'o dọn weshi Kraịstị, mẹ ẹnyi sọn Kraịstị nọdị anị imẹ elu-igwee—makẹni ẹnyi rị imẹ Kraịstị.
\v 7 Osolobuẹ mẹ ọnwan n'o gi ẹfọma hụn o mẹ ni ẹnyi imẹ Kraịstị mẹ elu ile lalanị marịn ẹfọma a—hụn wẹ ghalẹni a sa ẹka e kuchanrịn k'ọ han.
\v 8 Makẹni, ẹfọma kẹ Osolobuẹ mẹ ni ụnụ zụọpụha ụnụ ghahanị okukwe ụnụ, ẹlẹ ụnụ gi ẹka ụnụ mẹ ẹ, ihiẹn Osolobuẹ ye ụnụ ọfẹ rọ—
\v 9 ẹlẹ makẹ ihiẹn ịhịan rụn, amamgbe ịhịan e gi ẹ nyan isi.
\v 10 Ihiẹn Osolobuẹ mẹ ẹnyi wụrụ kẹ ẹnyi wụ. Osolobuẹ ya ke ẹnyi ye imẹ Kraịstị wụ Jizọsị, kẹni ẹnyi hụn ụzọ e mẹsọnmẹ ihiẹn ọma ndị hụ ọ kwademẹtọ nị ẹnyi ketekete nị uwẹ kẹ ẹnyi k'a gha e mẹsọnmẹ.
\s1 Ẹnyi Ile Wụ Ohu Imẹ Kraịstị
\p 
\v 11 Nyanhan nị nị ogẹn mbụ ụnụ wụ ndị alị ọzọ—ebe ẹhụ rị; ụnụ, hụn ndị Ju a kpọ “ndị kwalẹni ugun,” a kpọ enwẹn wẹ “ndị kwa ugun”—ọ sụọ n'a nị ugun wẹ rị e ku oku ẹ wụhụ nke ẹhụ sụọ, ihiẹn ẹka ịhịan e mẹmẹ.
\v 12 Nyanhan nị nị, ogẹn hụ, ụnụ enwọn Kraịstị; ogẹn ahụn, itumunyẹ kẹ ụnụ wụ ebe ikpun-ụlọ ile rị Izrẹlụ rị. Ụnụ e te rị imẹ nkwerigbama Osolobuẹ tumẹ ẹgbata ya lẹ ndị nke ẹ lẹ nkwa ndị o kwesọnmẹ imẹ ẹ. Ogẹn hụ, ụnụ bi enu ụwa bụ ụnụ e nwọn olil'ẹnya, ụnụ enwọn Osolobuẹ imẹ ndụn ụnụ.
\p 
\v 13 Kanị, makẹni ụnụ rị imẹ Kraịstị wụ Jizọsị, e gigụọ wẹ nwan ẹdeke Kraịstị, ya wụ ndụn a, wezụhan ụnụ hụn te rị ebe teni.
\v 14 Makẹni, Kraịstị lẹ enwẹn ẹ wụ udọn ẹnyi—makẹni o mẹgụọ ndị Ju lẹ ndị alị ndị ọzọ wụrụ ohu, o gigụọ ẹhụ a lẹ ọnwụn a titu mgbọn hụn te rị ẹgbata wẹ, ihiẹn hụ te rị ẹgbata wẹ, e buhẹ eṅẹnrẹn.
\v 15 O gigụọ ọnwụn ahụn ọ nwụn kagbu Iwu lẹ ụmụ-iwu lẹ ọdịnalị rịn'a. O mẹ ẹ kẹni o ke agbọ ọhụn, wẹ ile a wụrụ ohu imẹ ẹ, o gi wẹ nọkin ẹnya azụụn ẹbụbụọ hụn te rịnị, gi ụzọ ahụn wẹhẹ udọn ẹgbata wẹ—o mẹkọzị ndị Ju lẹ ndị wụlẹni ndị Ju, kanị ndị kwerini Kraịstị.
\p 
\v 16 Kraịstị mẹ ẹ kẹni o gizi ẹrịra wekinhẹnni Osolobuẹ azụụn ẹbụbụọ hụ imẹ ẹhụ ohu, ghahanị ọnwụn ọ nwụn elu obe; o gi ụzọ nị gbupụ iwe rị ẹgbata wẹ, wẹhẹ udọn.
\p 
\v 17 Ya Kraịstị nọ bịa d'e zi ịhịan ile ozi udọn hụ—kẹ ụnụ ndị anị ndị ọzọ hụn rị ebe teni kẹ ndị Ju hụn rị nsue.
\v 18 Ghahanị Kraịstị, ẹnyi ile a sa nwan ẹka a gha Mmọn-nsọ ohu a banhan ebe Nẹdi ẹnyi wụ Osolobuẹ rị, kẹ ndị Ju kẹ ndị alị ọzọ.
\p 
\v 19 Ya wụ, ụnụ ndị kwerini hụn wụlẹni ndị Ju ẹlẹzi itumunyẹ; ụnụ ẹlẹzi ndị alị ọzọ. Ụnụ e sọngụọ ndị nke Osolobuẹ, ndị nsọ, wụrụ ụmụ di-alị Alị-eze, wụrụzịkwọ ndị ikpun-ụlọ Osolobuẹ.
\v 20 Osolobuẹ a tụngụọ ụnụ rịkẹ ụlọ ye elu iyetọ hụn wụ ndị-ozi pụ-ichẹn lẹ ndị-amụma. Adansụ hụn gi ya wụ ụlọ wụ Jesu Kristi lẹ enwẹn ẹ.
\v 21 Ịya gi azụụn ile rị ụnọ hụ; ghahan'a kẹ ụlọ gi rị e jẹnwaye elu d'a wụrụ Ụlọ-ofufe rị nsọ imẹ Di-nwọnni-ẹnyi.
\v 22 Imẹ Kraịstị, wẹ hụ a tụn ọnụ lẹ enwẹn ọnụ, a tụnshi ụnụ enu imẹ-mmọn d'a wụrụ ebe obibi imẹ-mmọn hụn Osolobuẹ e bi ghahanị Mmọn-nsọ.
\c 3
\cl Isi Nke Ẹtọ
\s1 Ọrụn Pọlụ Imẹ Ndị Alị Ọzọ
\p 
\v 1 Oziọma Kraịstị wụ Jizọsịnị m rị e zi ụnụ ndị wụlẹni ndị Ju hụn wẹ gi beye ni ụnụ oghere kẹ mmẹ wụ Pọlụ gi rị imẹ ngan.
\v 2 A marịnghọ m nị ụnụ a nụgụọ nị Osolobuẹ ye m ọrụnnị o gi a ghọsị ẹfọma a rụn makẹ ọrịnịmma ụnụ;
\v 3 ụnụ a nụgụọzị k'o dọn ghọsị m ya wụ ihiẹn, hụn te zuerini, mẹ m ghọta a. Ịya kẹ m benitan ụnụ nke-nke imẹ ẹhụhụọ-ozini.
\v 4 Ụnụ gụn a, ụnụ k'a hụn kẹ m ghọtahan ihiẹnni mini, kẹ m ghọtahan Kraịstị.
\v 5 Osolobuẹ aghọsịnị ndị mbụ ya k'o dọn nwan ghọsị ndị-ozi pụ-ichẹn nsọ a lẹ ndị-amụma nsọ a ya ogẹnni ghahanị Mmọn-nsọ.
\v 6 Ihiẹn nzuzueni wụ nị, ghahanị ikweri oziọma, ndị anị ndị ọzọ a rịgụọzị ndị ihiẹn Osolobuẹ e ru ẹka, wụrụzịkwọ mkpamkpa imẹ ẹhụ ohu ahụn, rịzịkwọ ndị wẹ ile gba nwẹ ihiẹn Osolobuẹ kwe nkwa n'o k'e mẹ ni ndị rị imẹ Kraịstị wụ Jizọsị.
\p 
\v 7 E hẹnringụọ m onyẹ-ọrụn oziọmanị ghahanị oyiye hụn Osolobuẹ mẹ ẹfọma ye m, hụn ikẹn ẹ gi rị ọrụn imẹ ndụn m.
\v 8 Ọsụọn'a nị ahandẹni m kẹ onyẹ hụn kachanrịn ntịn e mẹ imẹ ndị-nke Osolobuẹ, Osolobuẹ e ye m oyiyeni kẹni m wejẹnni ndị alị ndị ọzọ ozi ihiẹn ndị ahụn jun imẹ Kraịstị, hụn nwọnlẹni okẹn,
\v 9 lẹni m ghọsị ịhịan ile kẹ Osolobuẹ hụn ke ihiẹn ile dọn a rụnpụha ihiẹn ahụn o rotọ ketekete, zuemẹ.
\p 
\v 10 Ihiẹn Osolobuẹ bu obi wụ n'o gi ụka mẹ amamihiẹn Osolobuẹ hụn nwẹ ihun rị ichẹn-ichẹn fọn ndị-ọkịkị lẹ ndị ile nwẹ ikẹn hụn rị enu-igwere ẹnya.
\p 
\v 11 Ịya wụ ihiẹn kẹ Osolobuẹ bu obi ẹdẹi; o mẹzugụọ a nwan ghahanị Kristi wụ Jesu Onyẹ-nwọnni-ẹnyi.
\v 12 Makẹni ẹnyi rị nwan imẹ Kraịstị wụ Jizọsị, egun arị a tụ ẹnyi ịbanye ebe Osolobuẹ rị—ebe o mẹ ni ẹnyi kwerini Jizọsị.
\s1 Dikẹnmẹ Ni Nwan
\p 
\v 13 Ya wụ, m rị nwan a rịọ ụnụ: anịkwọlẹ afụnfụn m rị e gi ifiri ọrịnịmma ụnụ a ta gụụ ụnụ ndụn; eziẹ, ihiẹn k'e wẹhẹ ni ụnụ ọghọ rọ.
\s1 Ịghọta Ihiẹn-ọsụsụọ Kraịstị
\p 
\v 14 Makẹ ọnwan, m rị e gbu nwan osekpu ihun Nẹdi ẹnyi,
\v 15 onyẹ hụn ezi-lẹ-ụlọ ile rị elu-igwee lẹ ụwa gha ẹka a nwẹhẹn ẹfan wẹ.
\v 16 M rị a rịọ a n'o gi ihiẹn ile o nwọn, hụn o gi nwẹ ọghọ, ye ụnụ ikẹn, hụn k'e mẹ ụnụ zekẹnmẹ imẹ obi ụnụ ghahanị Mmọn-nsọ a.
\v 17 M rịzị a rịọ a nị ụnụ wụrụ ndị Kraịstị birichanrịn imẹ obi wẹ makẹni ụnụ hụ e gi oku ẹ e dọn, ụnụ a gbasọnmẹ nkpọgụn, e wuzowaye imẹ ihiẹn-ọsụsụọ—
\v 18 kẹni ụnụ saẹka sọn ndị nke Osolobuẹ ile ghọta kẹ ihiẹn-ọsụsụọ Kraịstị shịahan, k'o suehan, k'o jẹnhan elu lẹ k'o mihan;
\v 19 ụnụ a ghọta ya wụ ihiẹn-ọsụsụọ a, hụn wẹ ghalẹni a ghọtachanrịn—kẹni ihiẹn ile rị imẹ Osolobuẹ hụn ụzọ jun imẹ ọnụ.
\p 
\v 20 Nke Osolobuẹ, Onyẹ hụn k'e ri-ẹka gi ikẹn ẹ rị ọrụn imẹ ẹnyi rụnkarị ihiẹn ile ẹnyi k'a saẹka rịọ mọbụ ro, rụnkarị a ọhụnma-ọhụnma,
\v 21 ọghọ ya rịn'a—kẹ imẹ ụka a kẹ ghahanị Kraịstị wụ Jizọsị d'e ru agbọ ile, jẹnrin ejẹn. Isẹẹ.
\c 4
\cl Isi Nke Ẹnọ
\s1 Kẹ Mkpamkpa Ẹhụ Ile Dọn Wụrụ Ẹhụ Ohu
\p 
\v 1 Mmẹ, hụn wụ onyẹ-ngan makẹni m rị e jẹnni Di-nwọnni-ẹnyi ozi, rị nwan a rịọ ụnụ nị ụnụ bi obibi furu ọkpụkpọ Osolobuẹ kpọ ọnụ.
\v 2 E wenụachanrịn nị enwẹn ụnụ alị ogẹn ile; e mẹ ni jụụ; e gi ni ndidi e sọn ibe ụnụ. E gi ni ụzọnị a ghọsị ihiẹn-ọsụsụọ ọnụ nwẹ.
\v 3 Lịlịma nị ụzọ ile nị udọn rịsọnmẹ ẹgbata ọnụ, e kẹngbama ụnụ, kẹni ụnụ e gi ẹ e chedọn ịrị-ohu hụ hụn gha ẹka Mmọn-nsọ a bịa.
\v 4 Ẹhụ ohu lẹ Mmọn-nsọ ohu rị, nọkẹ k'o dọn mẹ ni olile-ẹnya ohu kẹ Osolobuẹ kpọ ụnụ d'e nwọn.
\v 5 Nna ohu rọ; okukwe ohu rọ; mirin-Chuku ohu rọ.
\v 6 Osolobuẹ ohu rọ—hụn wụ Nẹdi ịhịan ile, hụn wụ Nna ịhịan ile, hụn gi ịhịan ile a rụn, hụn rịzịkwọ imẹ ịhịan ile.
\p 
\v 7 Kanị wẹ yesọnmẹ onyẹ-onyẹ imẹ ẹnyi oyiye ichẹn-ichẹn nọkẹ kẹ Kraịstị dọn chọ n'o ye ẹ.
\v 8 Ya kẹ Ẹkụkwọ-nsọ gi sị,
\q1 “Ogẹn o gi lashi elu,
\q2 o weri ihiẹn hụ kẹn ịhịan ẹgbụn che imẹ ẹgbụn,
\q2 ọ nọ ye ndị ịhịan oyiye ichẹn-ichẹn.”
\p 
\v 9 (Ogẹn Ẹkụkwọ-nsọ gi sị, “Ọ lashi elu,” k'o gi nwan “Ọ lashi enu” e ku? Ya wụ n'o buzọ hidangụụ, shi ebẹhụ kachanrịn e mi imẹ anị.
\v 10 Ya wụ nị onyẹ ohu hụ hidannị wụzịkwọ onyẹ hụn lashi elu, ghafechanrịn elu-igwere, kẹni ọ hụn ụzọ gi enwẹn ẹ mẹjunkwama ihiẹn ile.)
\v 11 Ịya yesọnmẹ oyiye ndịnị: o nwẹ ndị o ye oyiye ịwụ ndị-ozi pụ-ichẹn, ye ndị ọzọ oyiye ịwụ ndị-amụma lẹ ndị e zi ozi Osolobuẹ sị wẹ zi, ye ndị ọzọ oyiye ịwụ ndị e jẹnhunmẹni e zi oziọma, ye ndị ọzọ oyiye ịwụ ndị ụkọ-Chuku lẹ ndị-nkuzi.
\v 12 O yesọnmẹ oyiye ndịnị n'o gi wẹ a zụn ndị-nke Osolobuẹ ile nị wẹ d'a rụn ọrụn Kraịstị lẹni o gi wẹ e mẹ ẹhụ Kraịstị wụ ụka a gha ihun rịkẹ ụlọ wẹ n'a tụnshi elu.
\v 13 O mẹ ẹ d'e ru ni ẹnyi ile a wụrụ ohu ebe okukwe lẹ ịmarịn Nwa Osolobuẹ rị, wụrụ ndị ka ẹhụ, sueruchanrịn ogo Kraịstị, nọchanrịn kẹ 'ya.
\v 14 O mẹ ẹ makẹ ẹnyi gha a wụzị ụmụẹka, ndị ẹbi e bushi ihun-lẹ-azụụn, ndị nkuzi ọwụlẹ e buhunmẹ kẹ ufere e buhunmẹsọnmẹ ihiẹn, ndị ịhịan gi nkuzi ẹro lẹ aghịghọ e dufie.
\v 15 Kama, nị ẹnyi a wụrụ ndị a gwa ibe ẹnyi ezioku, e gi ihiẹn-ọsụsụọ e mẹ ẹ, ẹnyi ile e gi ẹ e sue; ẹnyi e gi ẹrịra suekunrun Kraịstị, hụn wụ isi ẹhụnị, rịchanrịn kẹ 'ya.
\v 16 Ịya wụ Kraịstị gi ẹhụ. Makẹni, ịya mẹ ẹhụ ile gi nyangbamachanrịn ọhụnma-ọhụnma ghahanị akwanran ile rịn'a. Ịya rịzị e mẹ mkpamkpa ọwụlẹ a sa ẹka a rụn ọrụn run'ẹ ọhụnma, hụn ẹhụ ile gi a rị ikẹn, e sue, e nwẹwaye ihiẹn-ọsụsụọ.
\s1 Obibi Ọhụn Hụn Rị Imẹ Kraịstị
\p 
\v 17 Ya wụ, m rị e gi ẹfan Di-nwọnni-ẹnyi a gba ụnụ mkpịnsịn ẹka, a gbashi ụnụ 'ya ikẹn: ebizilẹ ni kẹ ndị hụn ghalẹni e fe Osolobuẹ, ndị iroro wẹ nwọnlẹni isi.
\v 18 Uche wẹ a gbagụọ ishi. Enwọn wẹ ndụn Osolobuẹ makẹni o nwọnni ihiẹn wẹ marịn ebe ezioku rị, obi wẹ kpọkinzịkwọ akpọkin.
\v 19 Makẹni, ifẹnrẹn arịzị wẹ ẹnya; e wechanrịngụọ wẹ enwẹn wẹ ye ihiẹn-ifẹnrẹn lẹ ihiẹn ile ru unyin rị ichẹn-ichẹn, a rịzị wẹ a sa ẹka e kwọndọn enwẹn wẹ.
\p 
\v 20 Kanị, ẹlẹkwọ ẹrịra kẹ wẹ kuzi ọnụ banyeni Kraịstị!
\v 21 Ẹghẹẹ, ụnụ a nụgụọ banyen'ẹ, ụnụ a mụgụọ ezioku hụn rị imẹ Jesu.
\p 
\v 22 Ụnụ a mụgụọ nị ụnụ jẹnkọ nwan d'a ma eje-obibi hụ ụnụ te rị e bi tuhu—onyẹ hụ ụnụ wụ mbụ hụn rehigụụ ihun lẹ azụụn, hụn ihiẹn ọlịla-ẹnya dufiegụụ.
\v 23 Mmọn ọnụ lẹ uche ụnụ k'a wụrịrị nke ọhụn;
\v 24 ụnụ e yiri onyẹ ọhụn hụ, hụn wẹ gi ụdị Osolobuẹ ke—hụn rị kẹ Osolobuẹ dọn chọ nke-esi, rị nsọ nke-esi.
\v 25 Ya wụ, atụzịlẹ ni ntụ! Kama, a gwa nị ibe ụnụ ezioku, makẹni ẹnyi lẹ ibe ẹnyi wụ ẹhụ ohu.
\v 26 Olulu nwẹ ikẹn bu i, ka anịl'a han ị mẹ njọ. Olulu y'e bulẹ i nị eki gi.
\v 27 Eyelẹ ni Ekwensụ efe.
\p 
\v 28 Onyẹ e zun ohin y'e zunzilẹ. Kama, ya rụnma ọrụn nwọnlẹni nkọrịanị, e gi ẹ e bi, e yezikwọ nị ndị mkpa kwọndọn ẹka.
\v 29 Anịlẹ ni eje-oku pụha ụnụ ọnụ, kanị, oku hụn a gba ịhịan umẹ, ban n'a erere imẹ ọnọdị ọ rị—kẹni oku ụnụ hụn ụzọ e yeni ndị hụn rị e gọn ntịn ẹka.
\v 30 Emẹkwọlẹ ni ihiẹn k'a fụ Mmọn-nsọ Osolobuẹ, makẹni ịya kẹ wẹ gi yimẹ ọnụ ahịma Osolobuẹ, makẹ ụhụọhịn hụ Osolobuẹ k'a gbafụha ndị nke ẹ.
\v 31 Wepụ nị iwe ile, olulu ile, ọnụma ile, oro ile, nkutọ ile lẹ eje-ihiẹn ile ịhịan gi e sọn ibe ẹ.
\v 32 Kama, e gi ni ẹfọma lẹ omikẹn e sọn ibe ọnụ, a gbagharị ibe ụnụ kẹ Osolobuẹ dọn nwan gbagharị ụnụ ghahanị Kraịstị.
\c 5
\cl Isi Nke Isẹn
\s1 Obibi Ụmụ Ukpẹ
\p 
\v 1 Ebe o mẹ ni ụnụ wụ ụmụ Osolobuẹ hụn rị a obi, kịnrịn n'a nwan—e bi ni nwan kẹ ịya.
\v 2 E gi ni ihiẹn-ọsụsụọ e bi—nọkẹ kẹ Kraịstị dọn nwẹ ihiẹn-ọsụsụọ ẹnyi, gi ifiri ẹnyi we ndụn a ye, nọkẹ oyiye lẹ ẹjan hụn e shin ọhụnma hụn Osolobuẹ nabanhan.
\p 
\v 3 Nọkẹ ndị nke Osolobuẹ, anịkwọlẹ ni wẹ nụdẹ oku ughẹrẹ mọbụ ihiẹn ọwụlẹ ru unyin mọbụ ẹnya-uku imẹ igunrun ụnụ.
\v 4 Anịlẹ ni oku ihiẹn-ifẹnrẹn mọbụ oku-nzuzu mọbụ oku ọwụlẹ ru unyin pụha ụnụ ọnụ. Kama, e gi ni ọnụ ụnụ e yesọnmẹ Osolobuẹ ekele.
\v 5 Marịnkwọ nị nị o nwọnni onyẹ ọwụlẹ hụn a ghẹrẹni mọbụ onyẹ rịlẹni ọchan mọbụ onyẹ ẹnya-uku (hụn wụzị ịrụa-mmọn) jẹnkọ d'a ban Alị-eze Kraịstị lẹ Osolobuẹ!
\v 6 Anịkwọlẹ ni onyẹ ọwụlẹ gi oku nwọnlẹni isi dufie ụnụ, makẹni, ufiri ihiẹn ndịnị kẹ iwe-lẹ-ọnụma Osolobuẹ gi a bịanị ndị nnufụ-isi.
\v 7 Ya wụ, esọnkwọlẹ ni wẹ mẹkọ kaka!
\p 
\v 8 Makẹni ụnụ te rị imẹ ishi, kanị hụnnị ụnụ wụrụgụụ nwan nke Di-nwọnni-ẹnyi, ọnụ wụ ukpẹ. E bi ni nwan kẹ ụmụ ukpẹ—
\v 9 makẹni mkpụrụ ukpẹ a mị wụ ihiẹn ile rị mma, ihiẹn ile kụrụ-ọtọ lẹ ihiẹn ile wụ ezioku.
\p 
\v 10 Lịlịma nị nị ọnụ a chọpụha ihiẹn hụn k'a sụọ Di-nwọnni-ẹnyi ụsụọ.
\p 
\v 11 Esọnlẹ ni wẹ e mẹ ihiẹn ndị hụ w'e mẹ hụn wụ nke ishi, hụn ghalẹni a ban erere, ka e kpu ni wẹ oro.
\v 12 Ihiẹn ndị nnufụ-isi e mẹ nzuzue e mẹdẹ ifẹnrẹn okuku!
\v 13 Kanị, wẹ wepụha ihiẹn ọwụlẹ ebe ukpẹ rị, a hụn wẹ k'ọ nọ—
\v 14 makẹni ukpẹ nwunkpuhụ ihiẹn, o hẹnrin ukpẹ. Ya haịn Ẹhụhụọ-nsọ gi sị,
\q1 “Onyẹ-ụran, tẹnhin!
\q2 Gha ọnwụn lihi,
\q1 kẹni Kraịstị nwunkpu i.”
\p 
\v 15 Kpachanpụ nị nwan ẹnya kẹ ụnụ dọn e bi; ebilẹ ni kẹ ndị marịnlẹni ihiẹn, ka e bi ni kẹ ndị marịn ihiẹn.
\v 16 Egilẹ ni oghere ọwụlẹ ụnụ nwẹ gupụ egu, makẹni ogẹnni jọ njọ.
\v 17 Awụkwọlẹ ni nwan ndị-nzuzu, ka ghọta nị ihiẹn wụ uche Di-nwọnni-ẹnyi.
\v 18 Arakwọlẹ ni manya tụ, makẹni ihiẹn-ifẹnrẹn rọ nị manya rị a kị ịhịan; ka a nị nị Mmọn-nsọ e jun imẹ ndụn ụnụ, a kị ụnụ ogẹn ile—
\v 19 ụnụ e gi ẹbụ rị imẹ ẹkụkwọ Ẹbụ-ọma lẹ ẹbụ-ofufe lẹ ẹbụ ndị ọzọ rị nsọ a gwa enwẹn ụnụ oku, a bụ nị Di-nwọnni-ẹnyi ẹbụ a sụọ ụsụọ imẹ obi ụnụ;
\v 20 e gi ẹfan Di-nwọnni-ẹnyi wụ Jesu Kristi e ye Chuku-Nẹdi ekele ogẹn ile makẹ ihiẹn ile.
\s1 Ẹgbata Di Lẹ Nwunyẹ
\p 
\v 21 E welụa nị nị ibe ụnụ isi alị, e gi ẹ a gbaye Kraịstị.
\v 22 Nwunyẹ, e welụa nị di i isi alị kẹ y'e mẹ ni Di-nwọnni-ẹnyi.
\v 23 Makẹni, di wụ isi nwunyẹ ẹ nọkẹ kẹ Kraịstị dọn wụ isi ụka—ụka, hụn wụ ẹhụ Kraịstị—hụn Kraịstị wụ onyẹ-nzụọpụha a.
\v 24 Ya wụ, nwunyẹ k'e welụarịrị nị di ẹ isi anị imẹ ihiẹn ile kẹ ụka dọn e wenụa nị Kraịstị isi alị.
\p 
\v 25 Di, nwẹ ihiẹn-ọsụsụọ nwunyẹ i kẹ Kraịstị dọn nwẹ ihiẹn-ọsụsụọ ụka, gi ifiri ẹ we ndụn a ye—
\v 26 kẹn'o gi mirin hụ wụ oku-Osolobuẹ chanchan a, dọn ẹ nsọ,
\v 27 kẹni o gi ẹnịna wefụha nị enwẹn ẹ ụka hụn nwọn ọghọ, hụn nwọnlẹni ntụpọ, hụn selẹni alịlị—hụn nwọnlẹni ihiẹn ọwụlẹ nọ ẹrịra, ụka rị nsọ, nwọnlẹni ihiẹn wẹ gi kọrịan'a.
\v 28 Ẹrịrazịkwọ, di furu n'o nwẹ ihiẹn-ọsụsụọ nwunyẹ ẹ kẹ o dọn nwẹ ihiẹn-ọsụsụọ ẹhụ ya lẹ enwẹn ẹ. Onyẹ nwẹ ihiẹn-ọsụsụọ nwunyẹ ẹ nwẹ ihiẹn-ọsụsụọ enwẹn ẹ.
\v 29 Makẹni, o nwọnni onyẹ ize ẹhụ a e ze. Mba. Kama, ịhịan a zụn ẹhụ a, e mẹmẹ ẹ ọhụnma—nọkẹ kẹ Kraịstị dọn e mẹ ụka—
\v 30 makẹni ẹnyi wụ ụka wụ mkpamkpa ẹhụ a.
\v 31 “Ọnwan haịn okẹnnyẹ k'e gi latọ nẹdi ẹ lẹ nnẹ ẹ, bannị nwunyẹ, wẹ ẹbụọ e hẹnrin ẹhụ ohu.”
\v 32 Ihiẹnni e mikẹ; m gi ẹ e ku banyeni Kraịstị lẹ ụka.
\v 33 K'osịlẹrị, di ọwụlẹ ya nwẹ ihiẹn-ọsụsụọ nwunyẹ ẹ k'o dọn nwẹ ihiẹn-ọsụsụọ enwẹn ẹ; nwunyẹ ọwụlẹ y'a gbaye di ẹ.
\c 6
\cl Isi Nke Isin
\s1 Ụmụ Lẹ Ndị Mụ Nị Wẹ
\p 
\v 1 Ụmụ, e humẹni ni ndị mụnị ụnụ isi kẹ Onyẹ-nwọnni-ẹnyi dọn ku ẹ, makẹni ọnwan wụ ihiẹn furu nị ụnụ mẹ.
\v 2 “Gbaye nẹdi i lẹ nnẹ i.” Ọnwan wụ iwu ibuzọ wẹ kwe nkwa chen'ẹ, sị,
\v 3 “kẹni ọ rị n'ị mma, y'e nwọn isi-nka elu ụwa.”
\p 
\v 4 Nẹdi lẹ nnẹ, akpasulẹ ni ụmụ ọnụ iwe, amamgbe ndụn a gụụ wẹ, ka e gi ni ọzụnzụn lẹ nkuzi Di-nwọnni-ẹnyi kwadọn a zụn wẹ.
\s1 Ndị Idibo Lẹ Ndị Wẹ Rị Okpuru Wẹ
\p 
\v 5 Ndị wụ idibo mọbụ igbọn, e gi ni egun lẹ ẹhụ ọmụma-nni e humẹni ndị ọnụ rị okpuru wẹ isi. E gichanrịn nị obi ụnụ ile e mẹ ẹ, nọkẹ sị Kraịstị kẹ ụnụ rị a gbaye.
\v 6 Ẹlẹkwọ id'ẹnya wẹ sụọ—ebe ụnụ n'a chọ nị wẹ ja ụnụ—kama, e gi ni akpakalị obi ụnụ e mẹ ya wụ uche Osolobuẹ—rịkẹ igbọn Kraịstị.
\v 7 A shịapụnị ẹfọ a rụn ọrụn ụnụ—nọkẹ sị ụnụ rị a rụnnị Di-nwọnni-ẹnyi ya, ẹlẹ ịhịan.
\v 8 Makẹni ụnụ a marịnghọ nị Di-nwọnni-ẹnyi jẹnkọ d'a kụ onyẹ-onyẹ ụgwọ ihiẹn-ọma ọwụlẹ o mẹ—kẹ igbọn rọ kẹ onyẹ nwọn enwẹn ẹ rọ.
\p 
\v 9 Ndị ịhịan rị okpuru wẹ, e mẹzikwọ nị wẹ ẹrịra. Erọnzilẹ ni wẹ egun. Ụnụ a marịnghọ nị ụnụ lẹ wẹ nwọn Nna ohu hụn rị enu-igwee—bụ ara gbeyeni ịhịan.
\s1 Ekikẹn-agha Onyẹ Nke Osolobuẹ
\p 
\v 10 Nke ịkpazụụn, zekẹnmẹ ni imẹ ihiẹn Di-nwọnni-ẹnyi; nwẹnkẹnmẹ ni ikẹn ẹ ahụn hi ogbe.
\v 11 Yiri ni ihiẹn-agha Osolobuẹ ile, kẹni ụnụ saẹka turu, gbọndọn ẹro Ekwensụ ile.
\p 
\v 12 Makẹni, ẹlẹ ịhịan (nwẹ ẹhụ lẹ ẹdeke) kẹ ẹnyi lẹ wẹ rị a dọ, eje-mmọn ichẹn-ichẹn kẹ ẹnyi lẹ wẹ rị a dọ: ndị-isi wẹ lẹ ndị-ọkịkị wẹ lẹ eje-mmọn ndị hụn a kị ishini gba elu-ụwa lẹ eje-ikẹn imẹ-mmọn ndị rị elu-igwere.
\p 
\v 13 Kọnrin ni nwan agha! Weri ni nwan ihiẹn-agha Osolobuẹ ile, kẹni ụnụ hụn ụzọ saẹka turu ogẹn eje-ụhụọhịn e gi bịa; kẹni ụnụ saẹka mẹchanrịn ihiẹn ile furuni, bụ ụnụ turuhụkwọ ebe ụnụ turu. \fig Ekikẹn onyẹ-agha|src="WA04009b.jpg" size="col" loc="EPH 6" copy="Graham Wade; United Bible Societies" ref="6.13"\fig*
\p 
\v 14 Turukẹnmẹ ni nwan! Ụnụ e gi ezioku kẹnmẹ ukun nọkẹ akpụkpọ onyẹ-agha gi e kẹnmẹ ukun; ụnụ e yiri imẹ-ihiẹn-Chuku-chọ nọkẹ ẹwuru igwe ahụn onyẹ-agha gi e chedọn obi.
\v 15 Yiri ni adụdụ izi-oziọma hụn e wẹhẹ udọn ụkụ, gi n'ẹ hẹnrin akp'ụkụ, nọkẹ akp'ụkụ onyẹ-agha;
\v 16 imẹ ihiẹnni ile, buru ni okukwe, nọkẹ ịkpan onyẹ-agha, hụn ọnụ e gi saẹka e gbọndọn ụta ile rị e nwụn ọkụn hụn Eje-onyẹ hụ rị a gba;
\v 17 weri ni nzụọpụha Osolobuẹ zụọpụha ụnụ kpuru rịkẹ okpu onyẹ-agha, gi gbọndọn isi ọnụ; ụnụ e weri oku-Chuku hụn wụ ọpịa-agha Mmọn-nsọ, kwọndọn.
\p 
\v 18 E mẹ ni ekpere nọkẹ kẹ Mmọn-nsọ dọn chọ ogẹn ile; ụnụ e gi ụdị ekpere lẹ arịrịọ ọwụlẹ e sọn ihiẹn ile. Mụnrụn nị ẹnya ebe ekpere rị, anịlẹni ndụn gụụ ụnụ; e mẹ ni ni ndị nke Osolobuẹ ile ekpere.
\v 19 E mẹzikwọ nị nị mmẹ nwẹn ekpere, kẹni m shịapụ ọnụ nị m zi oziọma, Osolobuẹ e ye m ihiẹn m sikọ d'e ku; o wepụ m egun ẹnya, e kusi m'ẹ ikẹn; e mẹ m wẹ marịn ihiẹn rị imẹ oziọma—
\v 20 m yi nwan ẹgan makẹni m rị e zi ya wụ oziọma rịkẹ onyẹ-nnọkin ẹnya Kraịstị. E mẹ ni ni m ekpere nị m hụn ụzọ e kushi ẹ ikẹn k'o furu nị m'e ku ẹ.
\s1 Ekele Ịkpazụụn
\p 
\v 21 Ezi nwẹnẹ ẹnyi wụ Taịkikọsị, hụn wụzịkwọ onyẹ-ọrụn wẹ gi e dọn ẹnya imẹ Nna-ẹnyi k'a gwachanrịn ụnụ ihiẹn ile, kẹni ụnụ marịn k'ọ rị m lẹ ihiẹn m rị e mẹ.
\v 22 Ịya kẹ m zilanị nị ụnụ ya—nị ụnụ marịn kẹ ẹnyi ile nọ, kẹn'ọ hụn ụzọ kasịzịkwọ ụnụ obi.
\v 23 Udọn Chuku-Nẹdi lẹ Di-nwọnni-ẹnyi wụ Jesu Kristi ya rịnị ndị nke Kraịstị ile—'ya lẹ ihiẹn-ọsụsụọ hụn okukwe rị imẹ ẹ.
\v 24 Ẹfọma Osolobuẹ ya rịnị kẹ wẹ han nwẹ ihiẹn-ọsụsụọ ghalẹni a nwụn anwụn jẹnni Onyẹ-nwọnni-ẹnyi wụ Jesu Kristi.
