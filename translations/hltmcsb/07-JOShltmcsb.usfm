\v 2 Te \w dongah|strong="H9999"\w*, “\w Khohmuen|strong="H0776"\w* \w hip|strong="H2658"\w* \w hamla|strong="H9997"\w* \w Israel|strong="H3478"\w* \w ca|strong="H1121"\w* khui \w lamkah|strong="H4480"\w* \w khoyin|strong="H3915"\w* ah \w hlang|strong="H0376"\w* \w tarha|strong="H2009"\w* \w halo|strong="H0935"\w*,” a \w ti|strong="H0559"\w* nah tih \w Jerikho|strong="H3405"\w* \w manghai|strong="H4428"\w* \w taengah|strong="H9997"\w* \w a\w* \w puen|strong="H0559"\w* pah.  
