\id JOL
\h عَننَبِ يٌوٍلِ
\toc1 عَلَ شَ مَسٍنيِ عَننَبِ يٌوٍلِ بّ
\toc2 عَننَبِ يٌوٍلِ
\toc3 يٌو
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ يٌوٍلِ بّ
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ
\ip يِ كِتَابُي كُي عَلَ مَسٍنيِ ندٍ تِمَ عِسِرَيِلَ حَمَ بّ عَننَبِ يٌوٍلِ سَابُي رَ. عَ نَشّ عِسِرَيِلَكَيٍ شَ يُنُبِيٍ بَرَ عَ نِيَ عَلَ شَ حَشَنكَتّ حَاشِ دْشْ عٍ مَ. يِ حَشَنكَتّ مِسَالِشِ سْورِ فَلِ مَفَاشُي نَن نَ، كْنْ عَ قِندِشِ كَامّ شُنفبٍ نَن نَ عَلَتَلَ نَشَن نَدِنشِ عِسِرَيِلَ بْشِ رَ. كَتٌي تٌ شّ بِرِن كَنَ، عِسِرَيِلَ نَشَ لُ كَامّ كُي، عَلَ قَ عَ مَسٍن عٍ بّ نَ قَتَنشِ عٍ شَ يُنُبِيٍ نَن مَ.
\ip كْنْ عَلَتَلَ تٌ مُ تِن عَ شَ حَمَ شُن نَكَنَدٍ تُن عٍ شَ يُنُبِيٍ شَ قٍ رَ، عَ مَن نَشَ لَايِدِ تٌنفٌ عٍ بّ عَ قَمَ عٍ مَلِدٍ. عَ نَ رَبَ عَ شَشِلِ سّنِيّنشِ نَن سَابُي رَ عَ نَشَن نَفٌرٌ مَ مِشِ مْولِ بِرِن مَ نَشَن وَ مَ بِرَقٍ عَ قْشْ رَ. كِسِ نَن نَ كِ عَلَ نُ وَ مَ نَشَن قِقٍ عَ شَ حَمَ مَ.
\ip نَ مَسٍنيِ دَنفِ شَنبِ، عَلَ وْيّنيِ مْولِ فبّتّ نَن مَسٍنمَ دُنِحَ سِيٍ بّ نَشٍيٍ نُ بَرَ عِسِرَيِلَ تْورْ عَ حَاشِ رَ. عَ نَشّ عَ قَمَ عٍ مَكِيتِدٍ عٍ شَ يُنُبِيٍ شَ قٍ رَ، عٍ قَ حَشَنكَتّ شْرْشْي سْتْدٍ.
\ip يِ مَسٍنيِ سَشَنيِ قِندِ مَ نْندِ هَفِفّ نَن نَ عِبُنَدَ مَ بِرِن بّ. عَلَتَلَ بَرَ عَ شَ سّرِيّ رَفٌرٌ دُنِحَ مَ عَ شَ نَمِحْنمّيٍ سَابُي رَ. شَ مِشِ تٌندِ بِرَدٍ عَلَ وَشْنقٍ قْشْ رَ، نَ قِندِ مَ قٍ شْرْشْي نَن نَ عٍ بّ. كْنْ شَ عٍ فبِلٍنمَ عَلَ مَ، عَ مُ تٌندِ مَ عٍ كِدٍ، عَ عٍ شَ يُنُبِ شَقَرِ. نَ كِسِ قِندِشِ كَابَنَكٌي بٍلٍبٍلٍ نَن نَ عَلَ نَشَن نَبَمَ مِشِيٍ بّ نَشٍيٍ بْحّ وَ مَ مَكْرّقٍ عَلَ رَ. عَلَ شَ وٌن مَلِ نَ كِسِ سْتْقٍ! عَمِنَ.
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ يٌوٍلِ بّ
\c 1
\s1 عِسِرَيِلَ شَ بْشِ شَ كَنَرِ
\p 
\v 1 مَسٍنيِ نَن يِ كِ عَلَتَلَ نَشَن مَسٍن ثٍتُوٍلِ شَ دِ يٌوٍلِ بّ؛
\q1 
\v 2 قٌرِيٍ، وٌ يِ قٍ رَ مّ،
\q1 بْشِكَيٍ، وٌ وٌ تُلِ مَتِ.
\q1 يِ قٍ مْولِ بَرَ رَبَ نُ وٌ شَ وَشَتِ،
\q1 شَ نَ مُ وٌ بٍنبَيٍ شَ وَشَتِ؟
\q1 
\v 3 وٌ يِ يَ مَشَرَن وٌ شَ دِيٍ بّ،
\q1 وٌ شَ دِيٍ قَن شَ عَ يَ مَشَرَن عٍ فبٍ دِيٍ بّ،
\q1 عٍ فبٍ دِيٍ قَن شَ عَ يَ مَشَرَن عٍ فبٍ دِيٍ بّ عٍ قَمَ نَشٍيٍ بَرِدٍ.
\q1 
\v 4 كُلِيٍ نَشَن لُ، كَتٌي شُنشُرِيٍ بَرَ نَ دٌن.
\q1 كَتٌي شُنشُرِيٍ نَشَن لُ، كَتٌي شُنفبٍيٍ بَرَ نَ دٌن.
\q1 كَتٌي شُنفبٍيٍ نَشَن لُ، كَتٌي مْولِ فبّتّيٍ قَن بَرَ نَ دٌن.
\b
\q1 
\v 5 وٌ تَن سِيسِلَيٍ، وٌ شُنُ، وٌ شَ وَ.
\q1 بٍيرٍ مِنيِيٍ، وٌ شَ وٌ شُي عِتٍ،
\q1 بَرِ مَ وٌ مُ قَمَ وّنِ نّينّ سْتْدٍ سْنْن.
\q1 
\v 6 حَمَنّ سّنبّمَ ندٍ نَشَن شَ مِشِ كْنتِ مُ كٌلٌن،
\q1 نَ بَرَ دِن ﭑ مَ بْشِ رَ.
\q1 عَ حِنيِيٍ لُشِ نّ عَلْ يّتّ حِنيِ،
\q1 عَ بَنفَنيِيٍ لُشِ نّ عَلْ يّتّ فِنّ بَنفَنيِيٍ.
\q1 
\v 7 عَ بَرَ ﭑ مَ وّنِ شّيٍ كَنَ،
\q1 عَ ﭑ مَ شْرّ بِلِيٍ عِبٌلٌن.
\q1 عَ بَرَ عٍ كٌبٌلٍ بَ هَن عٍ سَلٌنيِ بَرَ قِيشّ قْين.
\b
\q1 
\v 8 وٌ شَ وَ عَلْ سُنفبُتُنيِ نَشَن شَ شّمّ بَرَ قَشَ.
\q1 
\v 9 عَلَتَلَ شَ سّرّشّدُبّيٍ سُننُنشِ،
\q1 بَرِ مَ هَدِيَ دٌنسٍ مُ نَ عَلَتَلَ شَ بَنشِ كُي سْنْن.
\q1 
\v 10 شّيٍ بَرَ كَنَ، بْشِ قَن نَ سُننُنيِ كُي،
\q1 بَرِ مَ دٌنسٍ شُن بَرَ رَكَنَ، وّنِ نُن تُرٍ مُ نَ.
\q1 
\v 11 شّ سَيٍ وَ مَ نّ، وّنِ سَنسِ سِيٍ سُننُنمَ نّ،
\q1 بَرِ مَ نَشَن بِرِن بٌفِشِ شّيٍ مَ، نَ بِرِن بَرَ كَسَرَ.
\q1 
\v 12 وّنِ بِلِيٍ بَرَ شَرَ، شْرّ بِلِيٍ بَرَ لْشْسِن.
\q1 وّنِ بِلِيٍ، تُفِ بِلِيٍ، مَنفٌي بِلِيٍ، نٍيٍ بِرِن بَرَ شَرَ.
\q1 مِشِيٍ شَ حّلّشِنيِ بَرَ حْن.
\b
\q1 
\v 13 نَ كُي عَ لَنمَ وٌ تَن سّرّشّدُبّيٍ،
\q1 وٌ شَ سُننُنيِ دُفِ رَفٌرٌ وٌ مَ.
\q1 وٌ تَن نَشٍيٍ سّرّشّ فَنمَ سّرّشّبَدٍ قَرِ، وٌ شَ وَ.
\q1 وٌ شَ كْي رَدَنفِ نِمِسّ كُي، وٌ تَن نَشٍيٍ وَلِمَ ﭑ مَرِفِ عَلَ بّ،
\q1 بَرِ مَ هَدِيَ دٌنسٍ بَرَ حْن عَلَ شَ بَنشِ كُي.
\q1 
\v 14 وٌ شَ سُنيِ سُشُ، وٌ شَ سَلِ رَبَ.
\q1 وٌ شَ قٌرِيٍ نُن حَمَ مَلَن وٌ مَرِفِ عَلَتَلَ شَ بَنشِ كُي،
\q1 وٌ قَ عَ مَشَندِ وٌ بْحّ بِرِن نَ.
\b
\q1 
\v 15 عَلَتَلَ شَ لْشْي شْرْشْي بَرَ مَكْرّ.
\q1 عَ قَمَ نّ كَنَرِ بٍلٍبٍلٍ تِدٍ عَلَ سّنبّمَ شِلِ رَ.
\b
\q1 
\v 16 وٌ مُ عَ تٌشِ وٌن مَ دٌنسٍ بَرَ حْن،
\q1 سّيوّ نُن حّلّشِنيِ مُ نَ عَلَ شَ بَنشِ يِرٍ سْنْن؟
\q1 
\v 17 سَنسِ شْرِيٍ بَرَ شَرَ بّندّ بُن مَ.
\q1 سَنسِ شْرِيٍ رَفَتَدٍيٍ بَرَ بِرَ، دٌنسٍ بَرَ حْن.
\q1 
\v 18 شُرُ سٍيٍ وَ مَ دٌنسٍ قٍ رَ.
\q1 يّشّي تْورْ مَ بَرِ مَ حٌوفٍ مُ نَ.
\q1 
\v 19 عَلَتَلَ، ﭑ عِ تَن نَن مَشَندِ مَ،
\q1 بَرِ مَ تّ بَرَ قِيلِيٍ نُن بُرُنيِ فَن.
\q1 
\v 20 هَلِ بُرُنيِ سُبٍيٍ يَ تِشِ عِ رَ،
\q1 بَرِ مَ شُرٍيٍ بَرَ شْرِ، تّ بَرَ قِيلِيٍ فَن.
\c 2
\s1 مَرِفِ شَ لْشْي بَرَ مَكْرّ
\q1 
\v 1 وٌ سَرَيٍ قٍ ﭑ مَ فٍيَ سّنِيّنشِ سِيٌنِ قَرِ!
\q1 بْشِكَيٍ بِرِن شَ سّرّن فَاشُي رَ،
\q1 بَرِ مَ عَلَتَلَ شَ لْشْي نَ قَقٍ، عَ بَرَ مَكْرّ.
\q1 
\v 2 دِ مِ نُن كُيٍ عِقْورّ لْشْي نَن عَ رَ.
\q1 عَ لُشِ نّ عَلْ كُندَ نُن نُشُي عِقْورّ نَشَن دِنمَ فٍيَ رَ،
\q1 عَلْ سُبَشّ نَءِيَلَنيِ يٍنسٍنمَ كِ نَشّ.
\q1 حَمَ سّنبّمَ بٍلٍبٍلٍ قَمَ نّ،
\q1 نَشَن مَنِيّ مُ تٌشِ تّمُي دَنفِشِ،
\q1 عَ مَن مُ تٌمَ تّمُي نَشَن سَ قَمَ.
\q1 
\v 3 تّ سَشِ عٍ يَ رَ، تّ سَشِ عٍ شَنبِ رَ.
\q1 بْشِ نَشَن نَ عٍ يَ رَ، عَ تٌقَن عَلْ سَنسِ يِرٍ عَلَ نَشَن دَاشِ عَدَ مَ بّ،
\q1 كْنْ عٍ نَ دَنفِ، نَ بْشِ قَ قِندِ فبٍنفبٍرٍنيِ مَفَاشُشِ يِرٍ رَ.
\q1 عٍ عَ بِرِن كَنَ!
\b
\q1 
\v 4 عٍ لُشِ عَلْ سٌي فَلِيٍ، سْورِيٍ دْشْشِ نَشٍيٍ قَرِ.
\q1 
\v 5 عٍ تُفَنمَ نّ عَلْ سْورِ رَفِسٍيٍ نَشٍيٍ فٌرٌ مَ فٍيَيٍ تَفِ.
\q1 عٍ شُي مَنِيَ تّ وُندُي شُي رَ نَشَن سّشّ فَنمَ.
\q1 عٍ مَنِيَ سْورِ فَلِ سّنبّمَ رَ نَشَن تِشِ فٍرٍ كِ مَ.
\q1 
\v 6 مِشِيٍ نَ عٍ تٌ، فَاشُي لُمَ نّ عٍ سُشُ رَ، عٍ يَتَفِيٍ بِرِن عِقْورْ.
\q1 
\v 7 عٍ عٍ فِمَ نّ عَلْ حَلَمَيٍ،
\q1 عٍ تٍمَ تَا تّتّ مَ عَلْ كٌرٌفبَيٍ.
\q1 كَنكَن سِفَ عَ شَ كِرَ رَ، عٍ مُ عٍ بَمَ كِرَ مَ قٍوٌ.
\q1 
\v 8 عٍ مُ دِنمَ عٍ بٌورٍ رَ،
\q1 كَنكَن بِرَشِ عَ شَ كِرَ نَن قْشْ رَ.
\q1 هَلِ عٍ فٍرٍقَيٍ تِ عٍ يَ رَ، عٍ سٌمَ نّ نٍيٍ رَ عٍ شَ سَقّ مُ كَنَ.
\q1 
\v 9 عٍ دِنمَ نّ تَا رَ، عٍ عٍ فِمَ نّ تّتّ قَرِ.
\q1 عٍ تٍمَ نّ بَنشِيٍ قَرِ، عٍ سٌ وُندّرِيٍ رَ عَلْ مُحّتِيٍ.
\b
\q1 
\v 10 بْشِ سّرّنمَ نّ عٍ يَ رَ، كٌورٍ عَ عِمَشَ.
\q1 سٌفٍ نُن كِكٍ عِقْورْ مَ نّ، تُنبُييٍ مُ يَنبَمَ سْنْن.
\q1 
\v 11 عَلَتَلَ عَ شُي رَ مِنِمَ نّ عَ شَ فٍرٍ سٌي يَ رَ.
\q1 عٍ وُيَ، عٍ عَ شَ يَامَرِ سُشُ سّنبّ رَ.
\q1 عَلَتَلَ شَ لْشْي شُنفبٍ مَفَاشُ.
\q1 ندٍ نْمَ نَ لْشْي رَشَندٍ؟
\b
\q1 
\v 12 عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 «وٌ شَ وٌ يّتّ رَفبِلٍن ﭑ مَ يَكْسِ.
\q1 وٌ شَ نَ رَبَ وٌ حَنِفٍ قِيشّ رَ،
\q1 سُنيِ رَ، وَ رَ، نُن مَيَندِ رَ!
\q1 
\v 13 وٌ نَشَ وٌ شَ دُفِيٍ عِبْو سُننُنيِ كُي،
\q1 وٌ شَ وٌ بْحّ نَن مَسَرَ.
\q1 وٌ شَ وٌ يّتّ رَفبِلٍن وٌ مَرِفِ عَلَتَلَ مَ،
\q1 بَرِ مَ عَ هِننّمَ نّ وٌ رَ، عَ كِنِكِنِ وٌ مَ،
\q1 عَ مُ شْنْمَ مَقُرٍن، عَ شَ مِشِ شَنُي فبٌ،
\q1 عَ فبِلٍنمَ عَ شَ فبَلٌي قْشْ رَ.
\q1 
\v 14 ندٍ عَ كٌلٌن شَ عَ مُ عَ شَ نَتّ مَسَرَ مَ،
\q1 شَ عَ مُ دِحّمَ، عَ قٍ قَنيِ رَبَ وٌ بّ؟
\q1 نَ تّمُي وٌ قَمَ نّ دٌنسٍ نُن مِنسٍ هَدِيَ رَ وٌ مَرِفِ عَلَتَلَ بّ.
\q1 
\v 15 وٌ شَ سَرَيٍ قٍ سِيٌنِ!
\q1 وٌ شَ سُنيِ سُشُ، وٌ سَلِ شُنفبٍ رَبَ.
\q1 
\v 16 وٌ شَ حَمَ مَلَن سّنِيّنيِ كُي.
\q1 وٌ شَ قٌرِيٍ، دِ مّيٍ، نُن دِيْرّيٍ شِلِ.
\q1 شّمّ نَشَن بَرَ فِنّ دْشْ، عَ تَن نُن عَ شَ فِنّ شَ لُ نَ مَلَنيِ كُي.
\q1 
\v 17 سّرّشّدُبّيٍ، وٌ تَن نَشٍيٍ وَلِمَ عَلَتَلَ بّ،
\q1 وٌ شَ وٌ مَوَ عَلَ بّ سّرّشّبَدٍ نُن هْرْ مْبَنشِ تَفِ،
\q1 عَ قَلَقٍ رَ، ‹عَلَتَلَ، عِ شَ عِ شَ حَمَ رَتَنفَ.
\q1 عِ نَشَ عِ كّ تٌنفٌمَيٍ رَيَافِ،
\q1 عٍ شَ قِندِ مَيٍلٍ سٍ رَ حَمَنّيٍ بّ،
\q1 مِشِ قَ عَ قَلَ، عٍ مَرِفِ عَلَ نَ مِندٍن؟›»
\b
\q1 
\v 18 عَلَتَلَ وَ مَ عَ شَ حَمَ شَ لُ عَ يِ رَ.
\q1 عَ كِنِكِنِمَ عٍ مَ.
\q1 
\v 19 عَلَتَلَ بَرَ عَ شَ حَمَ يَابِ،
\q1 عَ بَرَ عَ مَسٍن عَ شَ حَمَ بّ؛
\q1 «ﭑ دٌنسٍ، وّنِ، نُن تُرٍ قِمَ نّ وٌ مَ هَن وٌ وَ سَ.
\q1 ﭑ مُ لُمَ سِيٍ شَ وٌ رَيَافِ سْنْن.
\q1 
\v 20 ﭑ وٌ يَشُييٍ مَكُيَمَ نّ وٌ رَ، نَشٍيٍ كٍلِمَ كْولَ مَ،
\q1 ﭑ عٍ رَدِن فبٍنفبٍرٍن يِرٍ دّننَشّ كَنَشِ.
\q1 عٍ شَ فٍرٍ سٌي نَشٍيٍ تِمَ يَرٍ، ﭑ نٍيٍ مَدُلَمَ سٌفٍتٍدٍ بَا نَن شْورَ،
\q1 نَشٍيٍ تِمَ شَنبِ، ﭑ نٍيٍ تَن مَدُلَمَ سٌفٍفٌرٌدٍ بَا نَن شْورَ.
\q1 عٍ بْرْ شِرِ مِنِ، عَ دِن يِرٍ بِرِن نَ.»
\b
\q1 عَلَتَلَ بَرَ كَابَنَكٌي رَبَ!
\q1 
\v 21 عِسِرَيِلَ بْشِ، هَلِ عِ مُ فَاشُ!
\q1 عِ شَ حّلّشِن، عِ شَ لُ سّيوّ كُي،
\q1 بَرِ مَ عَلَتَلَ قٍ شُنفبٍيٍ رَبَمَ.
\q1 
\v 22 بُرُنيِ سُبٍيٍ، هَلِ وٌ مُ فَاشُ،
\q1 بَرِ مَ حٌوفٍ مَن فبِلٍنمَ نّ قِيلِ مَ،
\q1 سَنسِ بِلِيٍ مَن بٌفِمَ نّ،
\q1 شْرّ بِلِيٍ نُن وّنِ بِلِيٍ قَن دَشَمُي رَ مِنِمَ نّ.
\q1 
\v 23 وٌ تَن سِيٌنِ حَمَ، وٌ شَ سّيوَ،
\q1 وٌ شَ حّلّشِن وٌ مَرِفِ عَلَتَلَ شِلِ رَ،
\q1 بَرِ مَ عَ تُنّ قَنيِ رَقَمَ نّ وٌ بّ،
\q1 عَ تُنّ فبٍفبٍ رَفٌرٌ مَ نّ وٌ بّ عَ وَشَتِ مَ،
\q1 عَلْ عَ نُ عَ رَبَمَ كِ نَشّ عَ سِنفٍ.
\q1 
\v 24 لٌنيِيٍ رَقٍمَ نّ سَنسِ شْرِ رَ،
\q1 قِقَيٍ رَقٍمَ نّ وّنِ نّينّ نُن تُرٍ رَ.
\b
\q1 
\v 25 ﭑ وٌ شَ دَشَمُي حْشْي قِمَ نّ،
\q1 ﭑ مَ فٍرٍ سٌي سّنبّمَيٍ نَشَن كَنَ،
\q1 ﭑ مَ فٍرٍ سٌي نَشٍيٍ لَنشِ كُلِيٍ، كَتٌي، نُن كَتٌي مَنِيّيٍ مَ،
\q1 ﭑ نَشٍيٍ رَ سَنبَ وٌ شِلِ مَ.
\q1 
\v 26 وٌ قَمَ نّ وٌ دّفٍدٍ هَن وٌ لُفَ.
\q1 وٌ ﭑ مَتْشْمَ نّ، ﭑ تَن وٌ مَرِفِ عَلَ،
\q1 نَشَن بَرَ كَابَنَكٌي رَبَ وٌ بّ.
\q1 ﭑ مَ حَمَ مُ رَيَرَبِمَ سْنْن.
\q1 
\v 27 نَ كُي وٌ عَ كٌلٌنمَ نّ عَ ﭑ نَ عِسِرَيِلَ قْشْ رَ،
\q1 عَ ﭑ تَن نَن نَ وٌ مَرِفِ عَلَتَلَ رَ،
\q1 عَ عَلَ فبّتّ مُ نَ.
\q1 ﭑ مَ حَمَ مُ رَيَرَبِمَ سْنْن.
\c 3
\s1 عَلَتَلَ شَشِلِ رَفٌرٌقٍ دُنِحَ مَ
\q1 
\v 1 نَ دَنفِ شَنبِ، ﭑ نَ ﭑ شَشِلِ رَفٌرٌ مَ نّ مِشِ بِرِن مَ.
\q1 وٌ شَ دِ شّمّيٍ نُن دِ فِنّيٍ نَمِحْنمّحَ رَبَمَ نّ،
\q1 وٌ شَ قٌرِيٍ شِيٍيٍ سَمَ نّ،
\q1 لَامَتُنيِيٍ فٌرٌ مَ نّ وٌ شَ قٌنِكٍيٍ مَ.
\q1 
\v 2 ﭑ نَ ﭑ شَشِلِ رَفٌرٌ مَ نّ كٌنيِ شّمّيٍ نُن كٌنيِ فِنّيٍ مَ.
\q1 
\v 3 ﭑ تْنشُمَيٍ رَ مِنِمَ نّ كٌورٍ نُن بْشِ مَ،
\q1 نَشٍيٍ قِندِ مَ وُلِ، تّ، نُن تُورِ رَ.
\q1 
\v 4 سٌفٍ دِ مِمَ نّ، كِكٍ مَسَرَ مَ نّ عَ قِندِ وُلِ رَ،
\q1 بٍينُن مَرِفِ شَ لْشْي شُنفبٍ مَفَاشُشِ شَ عَ لِ.
\q1 
\v 5 نَ كُي، نَشَن يٌ نَ عَلَتَلَ شِلِ، نَ كَنيِ كِسِمَ نّ.
\q1 مِشِ كِسِشِيٍ لُمَ نّ سِيٌنِ نُن دَرِ سَلَمُ،
\q1 عَلْ عَلَتَلَ عَ مَسٍنشِ كِ نَشّ.
\q1 عَلَتَلَ كِسِ رَفِرِشِ نَشٍيٍ مَ، نٍيٍ لُمَ نّ كِسِ مِشِيٍ دْنشْي يَ مَ.
\c 4
\s1 عَلَ سِيٍ مَكِيتِمَ نّ
\q1 
\v 1 نَ تّمُي، ﭑ نَ يُدَ نُن دَرِ سَلَمُ رَفبِلٍن عٍ شْنيِ،
\q1 
\v 2 ﭑ سِ بِرِن مَلَنمَ نّ يٍهٌسَقَتِ فُلُنبَ كُي.
\q1 مّننِ ﭑ عٍ مَكِيتِمَ نّ ﭑ مَ حَمَ عِسِرَيِلَ شَ قٍ رَ،
\q1 نَشٍيٍ قِندِشِ ﭑ كّ تٌنفٌمَيٍ رَ.
\q1 دُنِحَ سِ نَشٍيٍ رَيٍنسٍن يّ حَمَنّيٍ مَ،
\q1 عٍ ﭑ مَ بْشِ عِتَشُن عٍ بٌورٍ مَ،
\q1 
\v 3 عٍ ﭑ مَ حَمَ رَبَ عٍ سَفٌ رَ.
\q1 عٍ شّمّ دِ مّيٍ مَتِ لَنفٌيحَ سَرٍ رَ،
\q1 عٍ فِنّ دِ مّيٍ مَتِ بٍيرٍ سَرٍ رَ عَلَكٌ عٍ شَ سِيسِ.
\p 
\v 4 «وٌ تَن تِرٍكَيٍ، سِدْنكَيٍ، نُن قِلِسِتَكَيٍ، وٌ وَ مَ مُنسٍ شْن مَ ﭑ بّ؟ وٌ وَ مَ وٌ فبٍ نَن حْشْقٍ ﭑ مَ؟ شَ نَ نَ عَ رَ، ﭑ وٌ سَرٍ قِمَ نّ وٌ شَ وَلِ رَ مَقُرٍن مَقُرٍن.
\v 5 وٌ بَرَ ﭑ مَ شّيمَ نُن ﭑ مَ فبٍتِ تٌنفٌ ﭑ مَ هْرْ مْبَنشِ كُي، وٌ قَ عَ رَ سٌ وٌ شَ كُيٍ بَنشِيٍ كُي.
\v 6 وٌ بَرَ يُدَكَيٍ نُن دَرِ سَلَمُكَيٍ مَتِ فِرّكِكَيٍ مَ، عَلَكٌ عٍ شَ مَكُيَ عٍ شْنيِ رَ.»
\p 
\v 7 «ﭑ عٍ رَ مَشَمَ نّ عَلَكٌ عٍ شَ كٍلِ يِرٍ وٌ عٍ مَتِشِ دّننَشّ، ﭑ قَ وٌ سَرٍ قِ وٌ شَ وَلِ حَاشِ رَ.
\v 8 ﭑ وٌ شَ دِ شّمّيٍ نُن دِ فِنّيٍ مَتِمَ نّ يُدَكَيٍ مَ، عَلَكٌ عٍ قَن شَ عٍ مَتِ سٍبَكَيٍ مَ نَشٍيٍ مَكُيَ وٌ رَ.» عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.
\b
\q1 
\v 9 «وٌ يِ قَلَ دُنِحَ سِيٍ بّ؛
\q1 ‹وٌ شَ قٍ يَءِلَن فٍرٍ شِلِ مَ،
\q1 وٌ شَ وٌ شَ سْورِيٍ مَلَن.
\q1 فٍرٍ سٌي بِرِن شَ عٍ مَسٌ، عٍ شَ فٍرٍ رَكٍلِ!
\q1 
\v 10 وٌ شَ وٌ شَ كٍرِيٍ يَءِلَن سَنتِدّفّمَيٍ رَ،
\q1 وٌ شَ وٌ شَ وْرْتّيٍ قَن يَءِلَن تَنبّيٍ رَ.
\q1 سّنبّتَرٍ شَ عَ قَلَ، «ﭑ سّنبّ فبٌ!»
\q1 
\v 11 وٌ شَ قَ بٍ،
\q1 وٌ تَن سِ نَشٍيٍ نَ مُشُ رَبِلِنيِ.›»
\b
\q1 عَلَتَلَ، عِ شَ سْورِيٍ رَفٌرٌ مّننِ قَ!
\b
\q1 
\v 12 سِيٍ شَ كٍلِ، عٍ شَ مَلَن يٍهٌسَقَتِ فُلُنبَ كُي،
\q1 بَرِ مَ ﭑ عٍ بِرِن مَكِيتِمَ نّ.
\q1 
\v 13 وٌ شَ وْرْتّيٍ تٌنفٌ، بَرِ مَ شّ بَرَ مْ!
\q1 وٌ شَ وّنِ بٌفِ بُندُ، بَرِ مَ عٍ بَرَ فبٌ يّ،
\q1 مِشِيٍ شَ حَاشُحَ شَ قٍ رَ.
\b
\q1 
\v 14 حَمَيٍ، وٌ شَ فٌرٌ كِيتِسَ فُلُنبَ كُي،
\q1 بَرِ مَ عَلَتَلَ شَ لْشْي بَرَ مَكْرّ نَا.
\q1 
\v 15 سٌفٍ نُن كِكٍ دِ مِمَ نّ،
\q1 تُنبُييٍ مُ يَنبَمَ سْنْن.
\q1 
\v 16 عَلَتَلَ قَمَ نّ عَ شَاحّ شُي رَ مِنِدٍ كٍلِقٍ سِيٌنِ،
\q1 عَ شُي مَفَاشُشِ مِنِمَ نّ كٍلِقٍ دَرِ سَلَمُ.
\q1 كٌورٍ نُن بْشِ سّرّنمَ نّ،
\q1 كْنْ عَلَتَلَ قِندِشِ كَنتَرِ نَن نَ عَ شَ حَمَ بّ،
\q1 عَ قِندِ يِرٍ مَكَنتَشِ رَ عِسِرَيِلَ بّ.
\q1 
\v 17 نَ كُي، وٌ عَ كٌلٌنمَ عَ ﭑ تَن نَن وٌ مَرِفِ عَلَتَلَ رَ،
\q1 نَشَن يِفِيَشِ ﭑ مَ فٍيَ سّنِيّنشِ سِيٌنِ قَرِ.
\q1 دَرِ سَلَمُ قِندِ مَ يِرٍ سّنِيّنشِ نَن نَ،
\q1 سِ فبّتّيٍ مُ مّننِ فٍرٍ مَ سْنْن.
\b
\q1 
\v 18 نَ لْشْي، وّنِ نّينّ نُن شِحّ فبٌمَ نّ فٍيَيٍ مَ.
\q1 يٍ تٌمَ نّ يُدَيَ بِرِن مَ،
\q1 يٍ دُلٌنيِ بُلَمَ نّ عَلَتَلَ شَ بَنشِ كُي،
\q1 عَ فٌرٌ كَسِيَ فُلُنبَ كُي.
\q1 
\v 19 كْنْ مِسِرَ بْشِ لُمَ نّ كَنَ رَ،
\q1 عٍدٌن قِندِ فبٍنفبٍرٍنيِ رَ فبَلٌي شَ قٍ رَ،
\q1 عٍ نَشَن دْشْ يُدَكَيٍ مَ عٍ قَشَقٍ رَ قُقَقُ.
\q1 
\v 20 كْنْ حَمَ سَبَتِمَ نّ يُدَيَ نُن دَرِ سَلَمُ وَشَتِ بِرِن.
\q1 
\v 21 ﭑ عٍ شَ يُنُبِ شَقَرِ مَ نّ عٍ نُ بَرَ نَشَن نَبَ.
\q1 ﭑ تَن عَلَتَلَ، ﭑ يِفِيَمَ سِيٌنِ نّ.
