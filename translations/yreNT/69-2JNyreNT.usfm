\id 2JN - Yaouré NT [yre] -Côte d'Ivoire 1999 (web version -2013 bd) 
\h 2 Zan 
\toc1 'Fluba "flizan nɛn Zan -a crɛn -tɛ 
\toc2 2 Zan 
\toc3 2 Zan 
\mt2 'Fluba "flizan nɛn 
\mt1 Zan 
\mt2 -a crɛn -tɛ 
\c 1  
\p  
\v 1 'An 'bɔ 'gʋɛ, an ya -leglizi min ceje -tʋ -a, mɛɛn 'fluba 'gʋɛ -a crɛn -tɛ -leglizi nɛn, Bali -a 'si "va "bɛ, -yrɛ. Maan crɛn -tɛ -a 'bɔ 'lee 'e 'jinɔn lɛ. An 'ka ye "yi 'kpa, 'pian 'an 'saza "cɛɛ dɩ, minnun pɛɛnɔn nɛn o -si tɩglɩ -tɔa "bɛ "o 'ka ye "yi "nyian.  
\v 2 Kɔɔ Bali wei tɩglɩ a -kaa 'ji, ɛn -a -cin yra -kaa 'ji 'li 'trilii. 
\p  
\v 3 -Kaa "tɩ Bali 'lee 'e 'pɩ Zozi Crizi bɛ, o "yi "dra -cɛɛ, o -kaa nyrinda "sia, ɛn o -fʋdɩ -trɔɔ -nɔan -cɛɛ. -Te -kaa ya -tʋwli 'wɩ tɩglɩ -sru, ɛn -kaa cin ye "yi "bɛ, -a pɛɛnɔn zɩɛ, waa -nɔan -cɛɛ -kpɔ. 
\s1 'Ka cin yɩ "yi! 
\p  
\v 4 'An 'ci nran 'kpa, kɔɔ an 'ka -mienun 'yɩ, te o 'ta wʋla 'wɩ tɩglɩ -sru, "le zɩ -kaa "tɩ a 'vɩ bɛ, -yee 'wɩ 'zʋ.  
\v 5 Ɛn 'bɛ nɛn 'gʋɛ, 'an "bʋɩ Zozinɔn, an 'wɩ "paala 'cɛɛ 'nan, -kaa cin yɩ "yi! -Pei -trɛ "cɛɛ an cɩ -a crɛn -tɛnan dɩ, 'pian -pei ceje nɛn -a pou sianan -kaa 'man bɛ, -nyrɛn.  
\v 6 Yɩdɩ "yi "nɛn maan ve bɛ, -nyrɛn 'nan, -kaa 'ta wʋla Bali wei da. -Pei ceje nɛn -a pou sianan kaa 'man bɛ, -nyrɛn. 'Ka 'ta wʋla "da! 
\s1 'Ka drɛ "yi minnun nɛn o Bali 'lewei ve 'wlu 'a bɛ o va 
\p  
\v 7 Minnun nɛn o min see "paaman -e min 'e 'si 'wɩ tɩglɩ -sru "bɛ, o ya "kaga, ɛn o fuila "man 'trɛda. Minnun zɩɛ, o 'ka "vale 'o "we "man 'nan Zozi Crizi nɛn e -ta 'trɛda bɛ blamin nɛn dɩ. Min nɛn yaa dra zɩɛ, Zozi Crizi 'nanmanzan nɛn, ɛn min nɛn 'e min see "paaman bɛ -nyrɛn.  
\v 8 'Ka yiɛ 'tɔ 'ka 'fli -va, -e 'ka 'ka -kopa yɩ 'e 'ciɩla "da. -Te ka'a drɛlɛ dɩɛ, 'wɩ pɛɛnɔn nɛn -kaa drɛ bɛ, -a "nɛn "fo 'e "tun.  
\v 9 'Wɩ nɛn Crizi 'a paa minnun ji bɛ, min nɛn ya'a 'bɛ "paalɛ minnun ji dɩɛ, 'pian "e pee 'pa "da "bɛ, te -a san 'lee Bali 'ka min -tʋwli "a dɩ. 'Wɩ nɛn Crizi 'a paa minnun ji bɛ, min nɛn yaa 'lein "paaman minnun ji bɛ, te -a san a min -tʋwli "a 'o 'vale -kaa "tɩ 'lee 'e 'pɩ -a.  
\v 10 -Te min -ta 'ka 'va 'nan, ɛn -yee 'wɩ "paadɩ a 'e 'pee Crizi 'le vɛ man bɛ, te 'ka 'wɩ "man -e 'e 'fʋ 'cee "kɔnnɛn "dɩ, ɛn te 'ka 'bɔ 'tɔ bʋ "fo "dɩ.  
\v 11 Kɔɔ min nɛn yaa 'tɔ 'bʋ bɛ, 'wɩ 'wlidɩ "nɛn min zɩɛ yaa drɛ bɛ, te e drɛ o "fli "le vɛ -a. 
\p  
\v 12 'Wɩ "kaga "a 'an 'ji -e 'an vɩ 'cɛɛ, 'pian an 'ka "vale 'an crɛn -tɛa "dɩ. An ya "vale 'an "lo 'ka 'va -e 'an 'wɩ tin 'ba 'cɛɛ 'an 'bɔ 'a, 'dʋ -e -kaa ci 'e "nran 'kpa. 
\p  
\v 13 'Ka "bʋɩ Zozinɔn nɛn Bali o 'si "va "nyian 'gʋɛ, o "we 'ka 'va.