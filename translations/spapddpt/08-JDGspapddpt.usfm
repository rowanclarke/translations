\p 
\v 44 Abimelec \w y|strong="H5921"\w* \w la|strong="H5921"\w* tropa \w que|strong="H5921"\w* \w estaba|strong="H5975"\w* \w con|strong="H5973"\w* \w él|strong="H5921"\w* \w se|strong="H5921"\w* desplegaron \w y|strong="H5921"\w* \w se|strong="H5921"\w* pararon \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w y|strong="H5921"\w* \w las|strong="H5921"\w* otras \w dos|strong="H8147"\w* \w compañías|strong="H7218"\w* \w se|strong="H5921"\w* lanzaron \w contra|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w estaban|strong="H5975"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w campo|strong="H7704"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w mataron|strong="H5221"\w*.
\v 45 Abimelec combatió contra \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w todo|strong="H3605"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*, \w la|strong="H1931"\w* capturó y \w mató|strong="H2026"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w gente|strong="H5971"\w* \w que|strong="H1931"\w* estaba en \w ella|strong="H1931"\w*. Arrasó \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* y \w la|strong="H1931"\w* sembró \w de|strong="H5971"\w* \w sal|strong="H4417"\w*.
