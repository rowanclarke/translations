\p
\v 1 “\w If|strong="H1961"\w* \w you|strong="H5414"\w* \w indeed|strong="H8085"\w* \w obey|strong="H8085"\w* \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w your|strong="H3068"\w* \w God|strong="H3068"\w* \w and|strong="H3068"\w* \w are|strong="H3117"\w* \w careful|strong="H8104"\w* \w to|strong="H3068"\w* \w observe|strong="H8104"\w* \w all|strong="H3605"\w* \w his|strong="H3605"\w* \w commandments|strong="H4687"\w* \w I|strong="H3117"\w* \w am|strong="H1961"\w* \w giving|strong="H5414"\w* \w you|strong="H5414"\w* \w today|strong="H3117"\w*, \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w your|strong="H3068"\w* \w God|strong="H3068"\w* \w will|strong="H3068"\w* elevate \w you|strong="H5414"\w* \w above|strong="H5921"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w nations|strong="H1471"\w* \w of|strong="H3068"\w* \w the|strong="H3605"\w* earth.  
