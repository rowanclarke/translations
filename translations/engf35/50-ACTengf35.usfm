\v 2 \w So|strong="G2532"\w* \w when|strong="G1161"\w* \w he|strong="G2532"\w* \w had|strong="G2532"\w* \w been|strong="G1096"\w* \w called|strong="G2564"\w* \w in|strong="G2532"\w*, \w Tertullus|strong="G5061"\w* \w began|strong="G1096"\w* \w his|strong="G1223"\w* \w accusation|strong="G2723"\w*, \w saying|strong="G3004"\w*: “\w Seeing|strong="G1223"\w* \w that|strong="G3588"\w* \w by|strong="G1223"\w* \w you|strong="G4771"\w* \w we|strong="G2532"\w* \w enjoy|strong="G5177"\w* \w much|strong="G4183"\w* \w peace|strong="G1515"\w*, \w and|strong="G2532"\w* \w your|strong="G4674"\w* \w foresight|strong="G4307"\w* \w has|strong="G1096"\w* \w brought|strong="G1096"\w* prosperity \w to|strong="G2532"\w* \w this|strong="G3588"\w* \w nation|strong="G1484"\w*,
