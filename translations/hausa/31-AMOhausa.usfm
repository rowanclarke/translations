\id AMO - Biblica¬Æ Open Hausa Contemporary Bible‚Ñ¢
\h Amos
\toc1 Amos
\toc2 Amos
\toc3 Amos
\mt1 Amos
\c 1
\p 
\v 1 Kalmomin Amos, …óaya daga cikin makiyayan Tekowa, abubuwan da ya gani game da Isra‚Äôila shekaru biyu kafin a yi girgizar ∆ôasa, a lokacin da Uzziya yake sarkin Yahuda, Yerobowam …óan Yowash kuma yake sarkin Isra‚Äôila.
\b
\b
\p 
\v 2 Ya ce,
\q1 ‚Äú\nd Ubangiji\nd* ya yi ruri daga Sihiyona
\q2 ya kuma yi tsawa daga Urushalima;
\q1 wuraren kiwo duk sun bushe,
\q2 dutsen Karmel kuma ya yi yaushi.‚Äù
\s1 Hukunci a kan ma∆ôwabtan Isra‚Äôila
\p 
\v 3 Ga abin da \nd Ubangiji\nd* ya ce,
\q1 ‚ÄúSaboda zunubai uku na Damaskus,
\q2 har guda hu…óu ma, ba zan fasa hukunta su ba.
\q1 Domin sun ci zalunci Gileyad
\q2 zalunci mai tsanani,
\q1 
\v 4 zan sa wuta a gidan Hazayel,
\q2 da za tƒÉ ∆ôona kagarun Ben-Hadad.
\q1 
\v 5 Zan kakkarye ∆ôofofin Bet-Damaskus;
\q2 zan hallaka sarkin da yake cikin\f + \fr 1:5 \ft Ko kuwa \fqa mazaunan\f* Kwarin Awen\f + \fr 1:5 \fq Awen \ft yana nufin \fqa mugunta.\f*
\q1 da kuma mai ri∆ôe da sandar mulkin Bet-Eden.
\q2 Mutanen Aram za su je bauta a ∆ôasar Kir,‚Äù
\q2 in ji \nd Ubangiji\nd*.
\p 
\v 6 Ga abin da \nd Ubangiji\nd* ya ce,
\q1 ‚ÄúSaboda zunubai uku na Gaza,
\q2 har guda hu…óu ma, ba zan fasa hukunta su ba.
\q1 Don sun kwashe al‚Äôumma gaba …óaya
\q2 sun sayar wa Edom,
\q1 
\v 7 Zan aika da wuta a katangar Gaza
\q2 ta ∆ôone duk kagarunta.
\q1 
\v 8 Zan hallaka sarkin\f + \fr 1:8 \ft Ko kuwa \fqa mazaunan\f* Ashdod
\q2 da kuma mai ri∆ôe da sandar mulki na Ashkelon.
\q1 Zan hukunta Ekron,
\q2 har sai dukan Filistiyawa sun mutu,‚Äù
\q2 in ji \nd Ubangiji\nd* Mai Iko Duka.
\p 
\v 9 Ga abin da \nd Ubangiji\nd* ya ce,
\q1 ‚ÄúSaboda zunubai uku na Taya,
\q2 har guda hu…óu ma, ba zan fasa hukunta su ba.
\q1 Don sun kwashe al‚Äôumma gaba …óaya sun kai su bauta a Edom,
\q2 ba su kula da yarjejjeniyar da aka yi ta zama kamar ‚Äôyan‚Äôuwa ba,
\q1 
\v 10 zan aika da wuta a Taya,
\q2 da za tƒÉ ∆ôone kagarunta.‚Äù
\p 
\v 11 Ga abin da \nd Ubangiji\nd* ya ce,
\q1 ‚ÄúSaboda zunubai uku na Edom,
\q2 har guda hu…óu ma, ba zan fasa hukunta shi ba.
\q1 Don ya fafari …óan‚Äôuwansa da takobi,
\q2 babu tausayi,
\q1 domin ya ci gaba da fusata
\q2 bai yarda yƒÉ huce daga fushinsa ba.
\q1 
\v 12 Zan aika wuta a Teman
\q2 da za tƒÉ ∆ôone kagarun Bozra.‚Äù
\p 
\v 13 Ga abin da \nd Ubangiji\nd* ya ce,
\q1 ‚ÄúSaboda zunubai uku na Ammon,
\q2 har guda hu…óu ma, ba zan fasa hukunta shi ba.
\q1 Don ya tsaga cikin matan Gileyad masu juna biyu
\q2 don kawai yƒÉ ∆ôwace ∆ôasar.
\q1 
\v 14 Zan sa wuta a katangar Rabba
\q2 da za tƒÉ ∆ôone kagarunta
\q1 za a yi kururuwa a ranar ya∆ôi,
\q2 fa…óan kuwa zai yi rugugi kamar hadiri.
\q1 
\v 15 Sarkinta\f + \fr 1:15 \ft Ko kuwa \fqa Molek; \ft Ibraniyawa \fqa malkam\f* zai je bauta,
\q2 shi da ma‚Äôaikatansa,‚Äù
\q2 in ji \nd Ubangiji\nd*.
\c 2
\p 
\v 1 Ga abin da \nd Ubangiji\nd* ya ce,
\q1 ‚ÄúSaboda zunubai uku na Mowab,
\q2 har guda hu…óu ma, ba zan fasa hukunta su ba.
\q1 Gama ya ∆ôone ∆ôasusuwan sarkin Edom
\q2 suka zama sai ka ce toka.
\q1 
\v 2 Zan sa wuta a Mowab
\q2 da za tƒÉ ∆ôone kagarun Keriyot\f + \fr 2:2 \ft Ko kuwa \fqa na biranenta\f*
\q1 Mowab za tƒÉ gangara cikin hayaniya mai girma
\q2 cikin kururuwar ya∆ôi da kuma ∆ôarar ∆ôaho.
\q1 
\v 3 Zan hallaka mai mulkinta
\q2 zan kuma kashe shugabanninta.‚Äù
\p 
\v 4 Ga abin da \nd Ubangiji\nd* ya ce,
\q1 ‚ÄúSaboda zunubai uku na Yahuda,
\q2 har guda hu…óu ma, ba zan fasa hukunta su ba.
\q1 Gama sun ∆ôi bin dokar \nd Ubangiji\nd*
\q2 ba su kuma yi biyayya da ∆ôa‚Äôidodinsa ba,
\q1 domin allolin ∆ôarya sun ru…óe su,
\q2 allolin da kakanninsu suka bauta.
\q1 
\v 5 Zan sa wuta a Yahuda
\q2 da za tƒÉ ∆ôone kagarun Urushalima.‚Äù
\s1 Hukunci a kan Isra‚Äôila
\p 
\v 6 Ga abin da \nd Ubangiji\nd* ya ce,
\q1 ‚ÄúSaboda zunubai uku na Isra‚Äôila,
\q2 har guda hu…óu ma, ba zan fasa hukunta su ba.
\q1 Don sun sayar da adalai wa…óanda
\q2 suka kƒÅsa biyan bashinsu.
\q1 Sun kuma sayar da matalauta
\q2 wa…óanda bashinsu bai ma kai ko ku…óin bi-labi ba.
\q1 
\v 7 Sun tattake kawunan matalauta
\q2 kamar yadda suke taka laka
\q2 suka kuma danne wa marasa galihu gaskiya.
\q1 Uba da …óa su na kwana da yarinya guda,
\q2 suna kuma …ìata sunana mai tsarki.
\q1 
\v 8 Suna kwanciya kurkusa da kowane bagade
\q2 a kan tufafin da suka kar…ìe jingina.
\q1 A gidajen allolinsu
\q2 sukan sha ruwan inabin da suka kar…ìo daga wurin wa…óanda suka ci wa tara.
\b
\q1 
\v 9 ‚ÄúNa hallaka mutumin Amoriyawa a gabansu,
\q2 ko da yake ya yi dogo kamar itacen al‚Äôul
\q2 kuma mai ∆ôarfi kamar itacen oak.
\q1 Na hallaka ‚Äôya‚Äôyan itatuwansa daga sama,
\q2 da kuma jijiyoyinsa daga ∆ôasa.
\q1 
\v 10 Na fitar da ku daga ∆ôasar Masar,
\q2 na kuma bishe ku tsawon shekaru arba‚Äôin a cikin hamada
\q2 don in ba ku ∆ôasar Amoriyawa.
\b
\q1 
\v 11 ‚ÄúNa kuma tƒÅ da annabawa daga cikin ‚Äôya‚Äôyanku maza
\q2 wa…óansu kuma su zama ke…ìa…ì…ìu daga cikin samarinku.
\q1 Ba haka ba ne, mutanen Isra‚Äôila?‚Äù
\q2 In ji \nd Ubangiji\nd*.
\q1 
\v 12 ‚ÄúAmma kuka sa ke…ìa…ì…ìun suka sha ruwan inabi
\q2 kuka kuma umarci annabawa kada su yi annabci.
\b
\q1 
\v 13 ‚ÄúSaboda haka, yanzu zan mur∆ôushe ku
\q2 kamar yadda amalanke yakan mur∆ôushe sa‚Äôad da aka yi masa labtun hatsi.
\q1 
\v 14 Masu gudu da sauri ba za su tsira ba,
\q2 masu ∆ôarfi ba za su iya yin amfani da ∆ôarfinsu ba,
\q2 jarumi kuma ba zai iya ceton ransa ba.
\q1 
\v 15 ‚ÄôYan baka ba za su iya dƒÅgewa ba,
\q2 masu saurin gudu ba za su tsira ba
\q2 mahayin dawakai kuma ba zai tsere da ransa ba.
\q1 
\v 16 Ko jarumawa mafi jaruntaka
\q2 za su gudu tsirara a ranan nan,‚Äù
\q2 in ji \nd Ubangiji\nd*.
\c 3
\s1 An kira shaidu a kan Isra‚Äôila
\p 
\v 1 Ku ji wannan maganar da \nd Ubangiji\nd* ya yi game da ku, ya ku jama‚Äôar Isra‚Äôila, a kan dukan iyalin da na fitar daga Masar.
\q1 
\v 2 ‚ÄúKu ne ka…óai na za…ìa
\q2 cikin dukan al‚Äôumman duniya;
\q1 saboda haka zan hukunta ku
\q2 saboda dukan zunubanku.‚Äù
\b
\q1 
\v 3 Mutum biyu za su iya yin tafiya tare
\q2 in ba su yarda su yi haka ba?
\q1 
\v 4 Zaki yakan yi ruri a jeji
\q2 in bai sami kama nama ba?
\q1 Zai yi gurnani a cikin kogonsa
\q2 in bai kama kome ba?
\q1 
\v 5 Tsuntsu yakan fƒÅ…óa a tarko a ∆ôasa
\q2 inda ba a sa tarko ba,
\q1 ko tarko yakan zargu daga ∆ôasa
\q2 in ba abin da ya ta…ìa shi?
\q1 
\v 6 Idan aka busa ∆ôaho a ciki birni
\q2 mutane ba sa yin rawar jiki?
\q1 Sa‚Äôad da bala‚Äôi ya auko wa birni,
\q2 ba \nd Ubangiji\nd* ne ya sa a kawo shi ba?
\b
\q1 
\v 7 Ba shakka, \nd Ubangiji\nd* Mai Iko Duka ba ya yin wani abu
\q2 ba tare da ya sanar wa bayinsa annabawa ba.
\b
\q1 
\v 8 Zaki ya yi ruri,
\q2 wa ba zai tsorata ba?
\q1 \nd Ubangiji\nd* Mai Iko Duka ya yi magana,
\q2 wa ba zai yi annabci ba?
\b
\q1 
\v 9 Ku yi shela ga kagarun Ashdod
\q2 da kuma ga kagarun Masar.
\q1 ‚ÄúKu tara kanku a tuddan Samariya;
\q2 ku ga rashin jituwar da take a cikinta,
\q2 da kuma zaluncin da ake yi a cikin mutanenta.‚Äù
\b
\q1 
\v 10 ‚ÄúBa su ma san yadda za su yi abin da yake daidai ba,‚Äù
\q2 in ji \nd Ubangiji\nd*,
\q2 ‚Äúsun …ìoye ganima da abubuwan da suka washe a cikin kagarunsu.‚Äù
\p 
\v 11 Saboda haka ga abin da \nd Ubangiji\nd* Mai Iko Duka ya ce,
\q1 ‚ÄúAbokin gƒÅba zai ∆ôwace ∆ôasar,
\q2 zai saukar da mafakarku,
\q2 zai washe kagarunku.‚Äù
\p 
\v 12 Ga abin da \nd Ubangiji\nd* ya ce,
\q1 ‚ÄúKamar yadda makiyayi yakan ceci daga bakin zaki
\q2 ∆ôasusuwa ∆ôafafu biyu kawai ko kunne …óaya,
\q2 haka za a ceci Isra‚Äôilawa,
\q1 masu zama a Samariya
\q2 da kan gado kawai
\q2 da kuma a …óan ∆ôyalle\f + \fr 3:12 \ft Ma‚Äôanar kalmar Ibraniyancin nan babu tabbas.\f* a kan dogayen kujerunsu.\f + \fr 3:12 \ft Ko kuwa \fqa Za a ceci Isra‚Äôilawa / wa…óanda suke zama a Samariya / a gefen gadajensu / da kuma a Damaskus kan kujerunsu\f*‚Äù
\p 
\v 13 ‚ÄúKu ji wannan ku kuma yi wa gidan Ya∆ôub garga…ói,‚Äù in ji \nd Ubangiji\nd*, \nd Ubangiji\nd* Allah Ma…óaukaki.
\q1 
\v 14 ‚ÄúA ranar da zan hukunta Isra‚Äôila saboda zunubanta,
\q2 zan hallaka bagadan Betel;
\q1 za a yayyanka ∆ôahonin bagadan
\q2 za su fƒÅ…óa ∆ôasa
\q1 
\v 15 Zan rushe gidan rani
\q2 da na damina;
\q2 gidajen da aka yi musu ado da hauren giwa za a rushe su
\q2 haka ma duk za a rurrushe manyan gidaje,‚Äù
\q2 in ji \nd Ubangiji\nd*.
\c 4
\s1 Isra‚Äôila ba ta koma ga Allah ba
\q1 
\v 1 Ku kasa kunne ga wannan, ya ku shanun Bashan a kan Dutsen Samariya,
\q2 ku matan da kuke cin zalin matalauta, kuke kuma danne matalauta,
\q2 kuna kuma ce wa mazanku, ‚ÄúKu kawo mana abin sha!‚Äù
\q1 
\v 2 \nd Ubangiji\nd* Mai Iko Duka ya rantse da tsarkinsa.
\q2 ‚ÄúTabbatacce lokaci yana zuwa
\q1 da za a jawo ku da ∆ôugiyoyi,
\q2 na ∆ôarshenku za a kama da ∆ôugiyar kifi.
\q1 
\v 3 Dukanku za ku wuce ta kai tsaye
\q2 ta inda katangar ta tsage,
\q2 za a jefar da ku a Harmon,‚Äù\f + \fr 4:3 \ft Rubuce-rubucen hannu na Masoretik; da …ìangare dabam na kalmar Ibraniyanci (dubi Seftuwajin) \fqa waje, ya dutsen danniya\f*
\q2 in ji \nd Ubangiji\nd*.
\q1 
\v 4 ‚ÄúKu tafi Betel ku yi ta aikata zunubi;
\q2 ku je Gilgal ku ∆ôara yin zunubi.
\q1 Ku kawo hadayunku kowace safiya,
\q2 zakkarku kowace shekara uku.\f + \fr 4:4 \ft Ko kuwa \fqa zakka a rana ta uku\f*
\q1 
\v 5 Ku ∆ôona burodinku mai yisti kamar hadaya ta godiya,
\q2 ku yi fariya game da hadayunku na yarda rai,
\q1 ku yi ta∆ôama game da su, ya ku Isra‚Äôilawa,
\q1 gama abin da kuke jin da…óin aikata ke nan,‚Äù
\q2 in ji \nd Ubangiji\nd* Mai Iko Duka.
\b
\q1 
\v 6 ‚ÄúNa bar ku da yunwa\f + \fr 4:6 \ft Ibraniyanci \fqa ku da tsabtar ha∆ôora\f* a kowace birni,
\q2 da kuma rashin abinci a kowane gari,
\q2 duk da haka ba ku juyo gare ni ba,‚Äù
\q2 in ji \nd Ubangiji\nd*.
\b
\q1 
\v 7 ‚ÄúNa kuma hana muku ruwan sama
\q2 tun shuke-shuken suna wata uku kafin lokacin girbi.
\q1 Na sa aka yi ruwan sama a wani gari,
\q2 sai na hana a yi a wani gari.
\q1 Wata gona ta sami ruwan sama;
\q2 wata gona kuma ta bushe.
\q1 
\v 8 Mutane suna tanga…ói daga gari zuwa gari suna neman ruwa
\q2 amma ba su sami isashen ruwan sha ba,
\q2 duk da haka ba ku juyo gare ni ba,‚Äù
\q2 in ji \nd Ubangiji\nd*.
\b
\q1 
\v 9 ‚ÄúSau da yawa na …ìata gonakinku
\q2 da fumfuna da kuma cuta.
\q2 FƒÅri suka cinye itatuwanku na inabi da na …ìaure, da na zaitun
\q1 duk da haka ba ku juyo gare ni ba,‚Äù
\q2 in ji \nd Ubangiji\nd*.
\b
\q1 
\v 10 ‚ÄúNa aiko muku annoba
\q2 yadda na yi a Masar.
\q1 Na karkashe samarinku da takobi,
\q2 tare da kamammun dawakanku.
\q1 Na cika hancinku da warin sansaninku,
\q2 duk da haka ba ku juyo gare ni ba‚Äù
\q2 in ji \nd Ubangiji\nd*.
\b
\q1 
\v 11 ‚ÄúNa hallaka wa…óansunku
\q2 kamar\f + \fr 4:11 \ft Ibraniyanci \fqa Allah\f* yadda na hallaka Sodom da Gomorra.
\q1 Kuna kama da itace mai cin wutar da na cire daga cikin wuta,
\q2 duk da haka ba ku juyo gare ni ba,‚Äù
\q2 in ji \nd Ubangiji\nd*.
\b
\q1 
\v 12 ‚ÄúSaboda haka ga abin da zan yi da ku, ya Isra‚Äôila,
\q2 don kuwa zan yi muku haka,
\q2 sai ku yi shirin gamuwa da Allahnku, ya Isra‚Äôila.‚Äù
\b
\q1 
\v 13 Shi wanda ya yi duwatsu,
\q2 ya halicci iska,
\q2 ya kuma bayyana wa mutum tunaninsa,
\q1 shi wanda ya juya safiya ta zama duhu
\q2 yana takawa a wurare masu tsawo na duniya,
\q2 \nd Ubangiji\nd* Allah Ma…óaukaki ne sunansa.
\c 5
\s1 Makoki da kuma kira ga tuba
\p 
\v 1 Ku ji wannan magana, ya gidan Isra‚Äôila, ina makokin nan dominku.
\q1 
\v 2 ‚ÄúBudurwa Isra‚Äôila ta fƒÅ…ói,
\q2 ba za tƒÉ ∆ôara tashi ba,
\q1 an yashe ta a ∆ôasarta,
\q2 ba wanda zai …óaga ta.‚Äù
\p 
\v 3 Ga abin da \nd Ubangiji\nd* Mai Iko Duka ya ce,
\q1 ‚ÄúBirnin da ta fitar da masu ∆ôarfi dubbai don Isra‚Äôila
\q2 guda …óari ka…óai za su dawo;
\q1 garin da ya fitar da masu ∆ôarfi …óari kuwa
\q2 goma ka…óai za su dawo.‚Äù
\p 
\v 4 Ga abin da \nd Ubangiji\nd* ya ce wa gidan Isra‚Äôila.
\q1 ‚ÄúKu neme ni ku rayu;
\q2 
\v 5 kada ku nemi Betel,
\q1 kada ku je Gilgal,
\q2 kada ku yi tafiya zuwa Beyersheba.
\q1 Gama ba shakka Gilgal za tƒÉ tafi bauta,
\q2 za a kuwa mai da Betel ba kome ba.‚Äù\f + \fr 5:5 \ft Ko kuwa \fqa ba∆ôin cikin; \ft Ko kuwa \fqa mugunta; \ft Da Ibraniyanci \fqa awen, \ft kwatanci ga Bet Awen (wani sunan reni don Betel).\f*
\q1 
\v 6 Ku nemi \nd Ubangiji\nd* ku kuma rayu,
\q2 ko kuwa zai ratsa yƒÉ share gidan Yusuf kamar wuta;
\q1 zai cinye
\q2 Betel kuwa ba zai sami wanda zai kashe ta ba.
\b
\q1 
\v 7 Ku ne masu mai da gaskiya ta koma …óaci
\q2 ku kuma zubar da adalci.
\b
\q1 
\v 8 (Shi wanda ya yi Taurarin nan da ake ce Kaza da ‚ÄôYa‚Äôyanta da kuma Mai Farauta da Kare,
\q2 wanda ya mai da duhu ya zama haske
\q2 ya kuma ba∆ôanta rana ta zama dare,
\q1 yakan kwashe ruwan teku
\q2 ya zubar a ∆ôasa,
\q2 \nd Ubangiji\nd* ne sunansa,
\q1 
\v 9 yakan kawo hallaka a mafaka mai ∆ôarfi
\q2 yakan kuma mai da birnin mai katanga ya zama kufai).
\b
\q1 
\v 10 Ba ku son mai yin gaskiya a …óakin shari‚Äôa
\q2 kuna ∆ôin mai fa…óar gaskiya.
\b
\q1 
\v 11 Kuna matsa wa matalauta
\q2 kuna sa su dole su ba ku hatsi.
\q1 Saboda haka, ko da yake kun gina gidajen duwatsu,
\q2 ba za ku zauna a cikinsu ba;
\q1 ko da yake kun nome gonaki masu kyau,
\q2 ba za ku sha ruwan inabinsu ba.
\q1 
\v 12 Gama na san yawan laifofinku
\q2 da kuma girman zunubanku.
\b
\q1 Kuna danne masu adalci kuna kuma cin hanci
\q2 kuna kuma hana a yi wa matalauta shari‚Äôar adalci a majalisa.
\q1 
\v 13 Saboda haka mai hankali yakan yi shiru a lokuta kamar haka,
\q2 gama lokutan mugaye ne.
\b
\q1 
\v 14 Ku yi nagarta, ba mugunta ba;
\q2 don ku rayu
\q1 sa‚Äôan nan \nd Ubangiji\nd* Allah Ma…óaukaki zai kasance da ku,
\q2 kamar yadda kuka ce zai yi.
\q1 
\v 15 Ku ∆ôi mugunta, ku ∆ôaunaci nagarta;
\q2 ku dinga yin shari‚Äôar gaskiya a …óakunan shari‚Äôa.
\q1 Mai yiwuwa \nd Ubangiji\nd* Allah Ma…óaukaki zai ji tausayin
\q2 raguwar Yusuf.
\p 
\v 16 Saboda haka ga abin da Ubangiji, \nd Ubangiji\nd* Allah Ma…óaukaki yana cewa,
\q1 ‚ÄúZa a yi kururuwa a dukan tituna
\q2 a kuma yi kuka don azaba a dukan wuraren da jama‚Äôa sukan taru.
\q1 Za a yi kira ga manoma su yi kuka
\q2 masu makoki kuma su yi kuka.
\q1 
\v 17 Za a yi kuka a dukan gonakin inabi,
\q2 gama zan ratsa a cikinku,‚Äù
\q2 in ji \nd Ubangiji\nd*.
\s1 Ranar \nd Ubangiji\nd*
\q1 
\v 18 Kaitonku masu son
\q2 ganin ranar \nd Ubangiji\nd*!
\q1 Don me kuke son ganin ranar \nd Ubangiji\nd*?
\q2 Za a duhunta ranan nan, ba haske ba.
\q1 
\v 19 Za ku zama kamar mutanen da suka guje wa zaki
\q2 sai suka fƒÅ…óa a hannun beyar,
\q1 ko kuma kamar wanda ya shiga gida
\q2 ya dƒÅfa hannu a bango
\q2 sai maciji ya sare shi.
\q1 
\v 20 Ashe, ranar \nd Ubangiji\nd* ba duhu ba ce, a maimakon haske,
\q2 duhu wuluk, ba tare da ko …óan haske ba.
\b
\q1 
\v 21 ‚ÄúNa ∆ôi, ina kuma ∆ôyamar bukukkuwanku na addini;
\q2 ba na son ganin tarurrukanku.
\q1 
\v 22 Ko da kun kawo mini hadayu na ∆ôonawa da kuma hadayu na hatsi,
\q2 ba zan kar…ìa ba.
\q1 Ko da kun kawo za…ìa…ì…ìun hadayu na zumunta,
\q2 ba zan …óauke su a bakin kome ba.
\q1 
\v 23 Ku tashi daga nan da surutan wa∆ôo∆ôinku!
\q2 Ba zan saurari ka…óe-ka…óe da bushe bushenku ba.
\q1 
\v 24 Amma bari gaskiya ta kwararo kamar kogi,
\q2 adalci kuma kamar rafin da ba ya ta…ìa bushewa!
\b
\q1 
\v 25 ‚ÄúKun kawo mini hadayu da sadakoki
\q2 shekaru arba‚Äôin a cikin jeji, ya ku gidan Isra‚Äôila?
\q1 
\v 26 Kun …óaga masujadar sarkinku,
\q2 siffofin gumakanku,
\q2 tauraron allahnku,\f + \fr 5:26 \ft Ko kuwa \fqa …óaga Sakkut sarkinku da Kaiwan gumakanku, tauraron da suke allolinku; \ft Seftuwajin \fqa …óaga masujadar Molek da tauraro allahnku Refan, gumakansu\f*
\q2 wanda kuka yi wa kanku.
\q1 
\v 27 Saboda haka zan tura ku zaman bauta gaba da Damaskus,‚Äù
\q2 in ji \nd Ubangiji\nd*, wanda sunansa ne Allah Mai Iko.
\c 6
\s1 Kaito ga zaman sakewa
\q1 
\v 1 Taku ta ∆ôare, ku da kuke zaman sakewa a Sihiyona,
\q2 da ku wa…óanda kuke ji zama a Dutsen Samariya lafiya ne,
\q1 ku manyan mutanen ∆ôasar da take sananniya,
\q2 wa…óanda mutanen Isra‚Äôila suke zuwa!
\q1 
\v 2 Ku je Kalne ku dube ta;
\q2 ku wuce daga can zuwa Hamat-rabba,
\q2 sa‚Äôan nan ku gangara zuwa Gat a Filistiya.
\q1 Sun fi masarautunku biyu ne?
\q2 ∆òasarsu ta fi taku girma?
\q1 
\v 3 Kuna ∆ôo∆ôari ku kauce wa wannan muguwar rana
\q2 kuna kuma jawo mulkin tashin hankali kusa.
\q1 
\v 4 Kuna kwanciya a kan gadajen da aka yi musu shimfi…óar hauren giwa
\q2 kuna mimmi∆ôe a kan kujerunku.
\q1 Kuna cin naman ∆ôibabbun raguna
\q2 da na ∆ôosassun ‚Äôyan maru∆ôa.
\q1 
\v 5 Kuna ka…óa molayenku yadda Dawuda ya yi
\q2 kuna ∆ôir∆ôiro wa∆ôo∆ôi a kan kayan ka…óe-ka…óe.
\q1 
\v 6 Da manyan kwanoni kuke shan ruwan inabi
\q2 kuna kuma shafa mai mafi kyau,
\q2 amma ba kwa ba∆ôin ciki game da kangon da Yusuf ya zama.
\q1 
\v 7 Saboda haka za ku zama na farkon da za su tafi zaman bauta;
\q2 bukukkuwanku da shagulgulanku za su ∆ôare.
\s1 \nd Ubangiji\nd* yana ∆ôyamar girmankan Isra‚Äôila
\p 
\v 8 \nd Ubangiji\nd* Mai Iko Duka da kansa ya rantse, \nd Ubangiji\nd* Allah Ma…óaukaki ya furta,
\q1 ‚ÄúIna ∆ôyamar girman kan Ya∆ôub,
\q2 ba na kuma son kagarunsa;
\q1 zan ba da birnin
\q2 da duk abin da yake cikinta.‚Äù
\p 
\v 9 Ko da mutum goma ne suka ragu a gida guda, su ma za su mutu.
\v 10 In kuma wani dangi ya shiga don yƒÉ fitar da gawawwakin yƒÉ ∆ôone ya kuwa tambayi wani wanda yake …ìoye a can, yana cewa, ‚ÄúAkwai wani tare da kai?‚Äù Ya kuwa ce, ‚ÄúBabu,‚Äù sai yƒÉ ce, ‚ÄúKul! Kada mu ambaci sunan \nd Ubangiji\nd*.‚Äù
\q1 
\v 11 Gama \nd Ubangiji\nd* ya ba da umarni,
\q2 zai kuma ragargaza babban gidan nan kucu-kucu
\q2 ∆ôaramin gidan kuwa zai yi rugu-rugu da shi.
\b
\q1 
\v 12 Dawakai sukan yi gudu a kan duwatsu?
\q2 Wani yana iya yin noma a teku da shanun noma?
\q1 Amma ga shi kun mai da gaskiya ta zama dafi
\q2 amfanin adalci kuma ya zama …óaci,
\q1 
\v 13 ku da kuke murna saboda an ci Lo Debar\f + \fr 6:13 \fq Lo Debar \ft yana nufin \fqa wofi.\f* da ya∆ôi
\q2 kuka kuma ce, ‚ÄúBa da ∆ôarfinmu ne muka ∆ôwace Karnayim\f + \fr 6:13 \fq Karnayim \ft yana nufin \fqa ∆ôahoni; \fqa ∆ôaho \ft a nan yana a matsayin ∆ôarfi.\f* ba?‚Äù
\b
\q1 
\v 14 Gama \nd Ubangiji\nd* Allah Ma…óaukaki ya ce,
\q2 ‚ÄúZan sa wata ∆ôasa ta tayar muku, ya ku gidan Isra‚Äôila,
\q1 wadda za tƒÉ matsa muku tun
\q2 daga Lebo\f + \fr 6:14 \ft Ko kuwa \fqa daga mashigi zuwa\f* Hamat zuwa kwarin Araba.‚Äù
\c 7
\s1 FƒÅri, wuta, da igiyar gwaji
\p 
\v 1 Ga abin da \nd Ubangiji\nd* Mai Iko Duka ya nuna mini. \nd Ubangiji\nd* yana shirya cincirindon fƒÅri bayan da aka ∆ôarasa yankan rabon hatsin da yake na sarki, hatsi na biyu kuma yake tohuwa.
\v 2 Sa‚Äôad da suka cinye kome, sai na yi kira, na ce, ‚Äú\nd Ubangiji\nd* Mai Iko Duka, ka gafarta! Ta yaya Ya∆ôub zai tsira? Ga shi …óan ∆ôarami ne!‚Äù
\p 
\v 3 Saboda haka sai \nd Ubangiji\nd* ya dakatar da nufinsa.
\p ‚ÄúWannan ba zai faru ba,‚Äù in ji \nd Ubangiji\nd*.
\p 
\v 4 Ga abin da \nd Ubangiji\nd* Mai Iko Duka ya nuna mini. \nd Ubangiji\nd* Mai Iko Duka yana shirin hukunta da wuta; wutar ta ∆ôone teku ta kuma ∆ôone ∆ôasa.
\v 5 Sai na yi kira, na ce, ‚Äú\nd Ubangiji\nd* Mai Iko Duka, ina ro∆ôonka ka dakata! Ta yaya Ya∆ôub zai tsira? Ga shi …óan ∆ôarami ne!‚Äù
\p 
\v 6 Saboda haka sai \nd Ubangiji\nd* ya dakatar da nufinsa.
\p ‚ÄúWannan ma ba zai faru ba,‚Äù in ji \nd Ubangiji\nd* Mai Iko Duka.
\b
\p 
\v 7 Ga abin da ya nuna mini. Ubangiji yana tsaye kusa da bangon da aka gina, bisa ga awon igiyar gwada gini, da kuma magwaji a hannunsa.
\v 8 Sai \nd Ubangiji\nd* ya tambaye ni, ‚ÄúMe kake gani, Amos?‚Äù
\p Sai na amsa, ‚ÄúIgiyar gwada gini.‚Äù
\p Sa‚Äôan nan Ubangiji ya ce, ‚ÄúDuba, zan sa igiyan nan a cikin mutanena Isra‚Äôila; ba zan ∆ôara barinsu ba.
\q1 
\v 9 ‚ÄúZa a hallakar da wuraren sujada na Ishaku
\q2 kuma tsarkakan wurare na Isra‚Äôila za su zama kango;
\q2 da takobina zan tayar wa gidan Yerobowam.‚Äù
\s1 Amos da Amaziya
\p 
\v 10 Sai Amaziya firist na Betel ya aika da sa∆ôo zuwa wurin Yerobowam sarkin Isra‚Äôila. ‚ÄúAmos yana shirya maka ma∆ôar∆ôashiya a tsakiyar Isra‚Äôila. ∆òasar ba za tƒÉ iya …óauka abubuwan da yake fa…ói ba.
\v 11 Gama ga abin da Amos yake cewa,
\q1 ‚Äú ‚ÄòYerobowam zai mutu ta wurin takobi,
\q2 kuma tabbatacce Isra‚Äôila za su tafi zaman bauta,
\q2 nesa da ainihin ∆ôasarsu.‚Äô ‚Äù
\p 
\v 12 Sai Amaziya ya ce wa Amos, ‚ÄúTafi daga nan, mai duba kawai! Koma ∆ôasar Yahuda. Ka nemi abin zaman garinka a can ka kuma yi annabcinka a can.
\v 13 Kada ka ∆ôara yin annabci a Betel, gama nan wuri mai tsarki ne na sarki da kuma haikalin ∆ôasar.‚Äù
\p 
\v 14 Amos ya amsa wa Amaziya, ‚ÄúNi ba annabi ba ne ko …óan annabi, amma ni makiyayi ne, kuma ina lura da itatuwan al‚Äôul.
\v 15 Amma \nd Ubangiji\nd* ya …óauke ni daga kiwon dabbobi ya ce mini, ‚ÄòJe ka, ka yi wa mutanena Isra‚Äôila annabci.‚Äô
\v 16 Yanzu fa, sai ka ji maganar \nd Ubangiji\nd*. Ka ce,
\q1 ‚Äú ‚ÄòKada in yi annabci a kan Isra‚Äôila,
\q2 kuma in daina yin wa‚Äôazi a kan gidan Ishaku.‚Äô
\p 
\v 17 ‚ÄúSaboda haka ga abin da \nd Ubangiji\nd* ya ce,
\q1 ‚Äú ‚ÄòMatarka za tƒÉ zama karuwa a cikin birni,
\q2 kuma da takobi za a kashe ‚Äôya‚Äôyanka maza da mata.
\q1 Za a auna ∆ôasarka a kuma raba ta,
\q2 kai kuma za ka mutu a ∆ôasar arna.\f + \fr 7:17 \ft Da Ibraniyanci \fqa marasa tsabta\f*
\q1 Ba shakka Isra‚Äôila za su tafi zaman bauta,
\q2 nesa da ainihin ∆ôasarsu.‚Äô ‚Äù
\c 8
\s1 Kwandon nunannun ‚Äôya‚Äôyan itace
\p 
\v 1 Ga abin da \nd Ubangiji\nd* Mai Iko Duka ya nuna mini. \nd Ubangiji\nd* ya nuna mini kwandon nunannun ‚Äôya‚Äôyan itace.
\v 2 Ya yi tambaya ya ce, ‚ÄúMe ka gani Amos?‚Äù
\p Sai na amsa na ce, ‚ÄúKwandon nunannun ‚Äôya‚Äôyan itace.‚Äù
\p Sai \nd Ubangiji\nd* ya ce mini, ‚ÄúLokaci ya yi wa mutanena Isra‚Äôila da ba zan ∆ôara barinsu ba.
\p 
\v 3 ‚ÄúA ranan nan,‚Äù in ji \nd Ubangiji\nd* Mai Iko Duka, ‚ÄúWa∆ôo∆ôin a haikali za su koma makoki.\f + \fr 8:3 \ft Ko kuwa \fqa ‚Äúmawa∆ôar haikali za su yi makoki‚Äù\f* Za a ga gawawwaki a ko‚Äôina! Shiru!‚Äù
\q1 
\v 4 Ku ji wannan, ku da kuke tattake masu bukata
\q2 kuka kori matalautan ∆ôasar.
\p 
\v 5 Kuna cewa,
\q1 ‚ÄúYaushe Sabon Wata zai wuce
\q2 don mu sayar da hatsi,
\q1 Asabbaci ta wuce,
\q2 don mu sayar da alkama?‚Äù
\q1 Mu yi awo da ma‚Äôaunin zalunci
\q2 mu ∆ôara ku…óin kaya
\q2 mu kuma cutar da mai saya,
\q1 
\v 6 mu sayi matalauta da azurfa
\q2 masu bukata kuma da takalmi,
\q2 mu sayar da alkamar ha…óe da yayi.
\p 
\v 7 \nd Ubangiji\nd* ya rantse da Girman Ya∆ôub, ‚ÄúBa zan ta…ìa mantawa da duk wani abin da suka yi ba.
\q1 
\v 8 ‚ÄúShin, ∆ôasar ba za tƒÉ yi rawan jiki saboda wannan ba,
\q2 kuma duk masu zama a cikinta ba za su yi makoki ba?
\q1 ∆òasar duka za tƒÉ hau ta sauka kamar Nilu;
\q2 za a dama ta sa‚Äôan nan ta nutse
\q2 kamar kogin Masar.
\p 
\v 9 ‚ÄúA wannan rana,‚Äù in ji \nd Ubangiji\nd* Mai Iko Duka,
\q1 ‚ÄúZan sa rana ta fƒÅ…ói da tsakar rana
\q2 in kuma duhunta duniya da rana tsaka.
\q1 
\v 10 Zan mai da bukukkuwanku na addini su zama makoki
\q2 kuma dukan wa∆ôo∆ôinku su zama kuka.
\q1 Zan sa dukanku ku sa rigunan makoki
\q2 za ku kuma aske kawunanku.
\q1 Zan sa wannan lokaci yƒÉ zama kamar lokacin da ake makokin …óan tilon da ake da shi
\q2 kuma ∆ôarshenta kamar rana mai …óaci.
\b
\q1 
\v 11 ‚ÄúRanakun suna zuwa,‚Äù in ji \nd Ubangiji\nd* Mai Iko Duka,
\q2 ‚Äúsa‚Äôad da zan aika da yunwa cikin ∆ôasar,
\q1 ba yunwar abinci ko ta ∆ôishirwa ba,
\q2 sai dai yunwa ta jin maganar \nd Ubangiji\nd*.
\q1 
\v 12 Mutane za su yi ta tanga…ói daga teku zuwa teku
\q2 suna yawo daga arewa zuwa kudu,
\q1 suna neman maganar \nd Ubangiji\nd*,
\q2 amma ba za su samu ba.
\p 
\v 13 ‚ÄúA wannan rana
\q1 ‚Äúkyawawan ‚Äôyan mata da kuma samari masu ji da ∆ôarfi
\q2 za su suma don ∆ôishirwa.
\q1 
\v 14 Wa…óanda suka yi rantsuwa da abin kunya\f + \fr 8:14 \ft Ko kuwa \fqa da Ashima; \ft ko \fqa da gunki\f* na Samariya,
\q2 ko kuma su ce, ‚ÄòMuddin allahnku yana a raye, ya Dan,‚Äô
\q2 ko kuwa, ‚ÄòMuddin allahn\f + \fr 8:14 \ft Ko kuwa \fqa iko\f* Beyersheba yana a raye,‚Äô
\q1 za su fƒÅ…ói,
\q2 ba kuwa za su ∆ôara tashi ba.‚Äù
\c 9
\s1 Za a hallaka Isra‚Äôila
\p 
\v 1 Na ga Ubangiji yana tsaye a gaban bagade, ya kuma ce,
\q1 ‚ÄúBugi kan ginshi∆ôan
\q2 don madogaran ∆ôofa su girgiza.
\q1 Saukar da su a kan dukan mutane;
\q2 wa…óanda ba su mutu ba zan kashe su da takobi.
\q1 Ba mutum guda da zai tsere,
\q2 babu wani da zai tsira.
\q1 
\v 2 Ko da sun tona rami kamar zurfin kabari,
\q2 daga can hannuna zai fitar da su.
\q1 Ko da sun hau can sama
\q2 daga can zan sauko da su.
\q1 
\v 3 Ko da sun …ìuya a bisa Karmel,
\q2 a can zan farauce su in cafko.
\q1 Ko da sun …ìuya can ∆ôar∆ôashin teku,
\q2 a can zan umarci maciji yƒÉ sare su.
\q1 
\v 4 Ko da abokan gƒÅbansu sun kore su zuwa zaman bauta,
\q2 a can zan umarci takobi yƒÉ kashe su.
\b
\q1 ‚ÄúZan sa musu ido
\q2 don mugunta ba don alheri ba.‚Äù
\b
\q1 
\v 5 Ubangiji, \nd Ubangiji\nd* Ma…óaukaki,
\q2 shi da yakan ta…ìa ∆ôasa sai ta narke,
\q2 kuma dukan mazauna cikinta suna makoki,
\q1 ∆ôasar gaba …óaya takan hau ta kuma sauka kamar Nilu,
\q2 sa‚Äôan nan ta nutse kamar kogin Masar,
\q1 
\v 6 shi da ya gina kyakkyawar fadarsa\f + \fr 9:6 \ft Ma‚Äôanar Ibraniyanci don wannan zance babu tabbas.\f* a cikin sammai
\q2 ya kuma kafa harsashenta\f + \fr 9:6 \ft Ma‚Äôanar Ibraniyanci don wannan kalma babu tabbas.\f* a duniya,
\q1 shi da yakan kira ruwan teku
\q2 yƒÉ kuma kwarara su a bisa duniya,
\q2 \nd Ubangiji\nd* ne sunansa.
\b
\q1 
\v 7 ‚ÄúKu ba Isra‚Äôilawa ba ne,
\q2 daidai gare ni kamar yadda Kushawa suke?‚Äù\f + \fr 9:7 \ft Wato, mutane daga yankin bisa na Nilu\f*
\q2 In ji \nd Ubangiji\nd*.
\q1 ‚ÄúBan fito da Isra‚Äôila daga Masar ba,
\q2 Filistiyawa kuma daga Kaftor\f + \fr 9:7 \ft Wato, Kirit\f*
\q2 Arameyawa kuma daga Kir ba?
\b
\q1 
\v 8 ‚ÄúTabbatacce idanun \nd Ubangiji\nd* Mai Iko Duka
\q2 suna a kan mulkin nan mai zunubi.
\q1 Zan hallaka shi
\q2 daga fuskar duniya,
\q1 duk da haka ba zan hallaka
\q2 gidan Ya∆ôub ∆ôa∆ôaf ba,‚Äù
\q2 in ji \nd Ubangiji\nd*.
\q1 
\v 9 ‚ÄúGama zan ba da umarni,
\q2 zan kuma tanka…óe gidan Isra‚Äôila
\q2 a cikin dukan ∆ôasashe
\q1 kamar yadda ake tanka…óe hatsi a cikin matanka…ói
\q2 kuma ko ∆ôwaya …óaya ba za tƒÉ fƒÅ…ói a ∆ôasa ba.
\q1 
\v 10 Dukan masu zunubi a cikin mutanena
\q2 za su mutu ta wurin takobi,
\q1 wato, su masu cewa,
\q2 ‚ÄòMasifa ba za tƒÉ fƒÅ…óo ko ta same mu ba.‚Äô
\s1 Maidowar Isra‚Äôila
\q1 
\v 11 ‚ÄúA wannan rana zan maido
\q2 da tentin Dawuda da ya fƒÅ…ói.
\q1 Zan gyaggyara wuraren da suka yayyage,
\q2 in kuma maido da kufansa
\q2 in gina shi kamar yadda yake a dƒÅ,
\q1 
\v 12 domin su mallaki raguwar Edom
\q2 da duk al‚Äôummai da suke amsa sunana,‚Äù\f + \fr 9:12 \ft Da Ibraniyanci; Seftuwajin \fqa don raguwar mutane / da kuma dukan al‚Äôumman da ake kira da sunana za su nemi Ubangiji\f*
\q2 in ji \nd Ubangiji\nd* shi wanda zai yi wa…óannan abubuwa.
\p 
\v 13 ‚ÄúRanaku suna zuwa, in ji \nd Ubangiji\nd*,
\q1 ‚Äúsa‚Äôad da mai hu…óa zai sha gaban mai girbi
\q2 mai shuki kuma yƒÉ bi bayan mai matsin inabi.
\q1 Sabon ruwan inabi zai …óiga daga duwatsu
\q2 yƒÉ kuma kwararo daga tuddai.
\q2 
\v 14 Zan dawo da wa…óanda aka kai zaman bauta\f + \fr 9:14 \ft Ko kuwa \fqa zan maido da nasarar\f* mutanena Isra‚Äôila.
\b
\q1 ‚ÄúZa su sƒÅke gina biranen da suke kango su kuma zauna a cikinsu.
\q2 Za su shuka gonakin inabi su kuma sha ruwan inabinsu;
\q2 za su yi lambuna su kuma ci amfaninsu.
\q1 
\v 15 Zan dasa Isra‚Äôila a ∆ôasarsu,
\q2 ba kuwa za a ∆ôara tum…ìuke su
\q2 daga ∆ôasar da na ba su ba,‚Äù
\m in ji \nd Ubangiji\nd* Allahnku.
