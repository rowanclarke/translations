\id 2TI - Central Carrier NT -Canada 2011 (DBL -2013)
\h 2 Timothy
\toc1 Paul Bulh Nanki 'Udustl'us Timothy Ts'ó K'eyanguz-i
\toc2 2 Timothy
\toc3 2 Ti
\mt1 Paul Bulh Nanki 'Udustl'us Timothy Ts'ó K'eyanguz-i
\c 1
\s1 Paul Timothy hadih yulhni
\p 
\v 1 Si Paul, Sizi Gri ba whél'a'-un usdli. Ndi 'ilhiz be ts'úkhuna-i, 'i Christ, Sizi ts'utni-un, 'en yut'i 'ink'ez 'ilhiz wheni 'unt'oh nedáni'. 'I gha la Yak'usda ndet la sts'u hukwa' ninzun 'et huwa whél'a'-un susdli'.
\p 
\v 2 Nyun Timothy sye' ook'esi'-un inli 'ink'ez ndi 'udustl'us nts'o tl'as'aih-i. Yak'usda neBá 'ink'ez Christ, Sizi ts'utni-un, 'en neMoodihti, 'en gha ye unzoo-i cha, be úgha te'nudzun-i cha, 'ink'ez be nedzi dizghel-i cha, 'i ont'e' hukwa' nuszun.
\s1 Paul Timothy yuba whunalni nts'en'a la Sizi Gri ts'u nalh'a-un
\p 
\v 3 'Et Yak'usda ts'un musi dusni. Stsoda'ne k'un'a, syo ts'e oogha t'ets'oninzun-i, lubeshi ooghu hooloh whe Yak'usda ooba' ne'ust'en. Dzin 'ink'ez 'ulhdzis-i bulh, ndet la tenadusdli totsuk nghu ni zástan.
\p 
\v 4 Nyunats'ultoo' nus'en 'et whunaznih 'ink'ez 'on nus nyutis'elh hukwa' nuszun, 'et de la hóst'e'.
\p 
\v 5 Ndi soo be 'alha' hoont'oh-i, 'i nyulh 'unt'oh, 'i oonaznih. Ntsoo Lois, 'en 'udechoo ndi be 'alha' hoont'oh-i yulh 'unt'oh inle', 'ink'ez nloo, Eunice 'en cha. 'Ink'ez nyun cha 'et whuz un'a za 'int'oh, 'et sba 'alha' hoont'oh.
\p 
\v 6 'Et huwa mba whunazni ndet da' ntsi k'et duznih whe Yak'usda huwa yú'aih-i, 'i ntl'aídan'ai. 'I 'ants'i bulh ne'hilhnah le'ilh'en, 'et la 'on nus ulhtus oole'.
\p 
\v 7 Soo cho whunaoolni, Yak'usda Ndoni neyídan'ai whe 'aw lhts'uníljut. K'us Ndoni gha be ts'ílhtus be lhk'ets'utsi'-i, 'i cha ts'ut'i, 'ink'ez ne-eni be whunih ts'inli.
\s1 Khuni unzoo-i khun hukwaya onle' junih
\p 
\v 8 'Et huwa 'uyoonne neMoodihti ghun bubulh yailhduk de, khun hukwaya onle' junih. 'Ink'ez si cha 'adus'ai-un, 'et cha khun hukwaya onle' junih. K'us 'uyoonne khuni unzoo-i be bubulh yaílhduk whe dzoh ninzut de, 'et de Yak'usda ye ulhtus-i, 'i gha 'ínt'en.
\p 
\v 9 'En 'uja neulhyih. Nedzi lubeshi ooghu hootáloh 'et whuz un'a za neka' ninzun. 'Aw neye 'ut'en k'oh gha iloh neka' dani'. Dich'oh ye unzoo-i, 'i gha uzdutijih ha neka' dani', 'et whuz un'a za hukwa' ninzun. 'Ink'ez ndi ye unzoo-i, 'i Christ, Sizi ts'utni-un, 'en oots'u hayílts'ut whe neghalts'ut. 'Et 'udechoo whe' whudutát'elh, 'et whutso da' 'uhoonla.
\p 
\v 10 'Et 'awet Sizi Gri netaninya. 'Et whuz un'a Yak'usda ndet la dich'oh hukwa' ninzun-un 'ink'ez ye unzoo-i cha, 'i yunénilhtan. Wheni bé dáztitsah-i, 'i Sizi Gri neba gak yulhtsi 'ink'ez khuni unzoo-i, 'i be 'ilhiz be ts'úkhuna-i negha ínin'ai. Ndi 'aw dálhts'utisa-un, 'et neba whusahón'ai, 'et whe whunénilhtan.
\p 
\v 11 'Et wheni si 'udun yun k'ut whut'enne, 'enne buts'u tisyalh. 'Enne butoh ubulh yátisduk, 'ink'ez whubodutis'eh, 'et whuba buts'u whel'a'-un tisdleh.
\p 
\v 12 'Et huwa si cha dzoh nuszut, 'et hoonts'i 'aw hukwaya lhusdloh. Mbe sba 'alha' 'unt'oh-un t'enuszun 'et huwa. 'Ink'ez ndet la ootl'ahoos'ai-un, 'udek'ez dzin whuts'un soo 'ultus whe sba hootatun, 'et sba 'alha' hoont'oh.
\s1 Ndi khuni unzoo-i soo cho oontun
\p 
\v 13 Ndi khuni ulhtus-i oogha 'uts'ut'en-i le'unt'oh-i, si sts'un dants'o, 'i duts'o cho oontun. Ndi be 'alha' hoont'oh-i 'ink'ez be lhk'ets'utsi'-i, 'i Christ, Sizi ts'utni-un, 'en oots'u hayande 'et huwa.
\p 
\v 14 Ndai la unzoo-i ntl'álya-i, 'i ts'iyawh Ndoni be ulhtus-i, 'i be soo cho hoontun. 'En 'unt'oh neyudínda.
\p 
\v 15 Njan t'eooninzun ts'iyanne Asia whut'enne sch'az nahulhya. Phygellus 'ink'ez Hermogenes 'enne cha.
\p 
\v 16 Onesiphorus 'en lhat sdzi dona' yulh'ih. 'Ink'ez ndi lhuztih tl'ool be whe dust'i-i, 'aw yukaya lhiloh whe sunalh'en. 'Et huwa 'en ooyoh dilhts'ine neMoodihti bugha te'nozeh.
\p 
\v 17 'Et keyoh Rome ninya whe soo cho skunúta whe nasilhti.
\p 
\v 18 'Et dzin neMoodihti\f + \fr 1:18 \ft 'Et ndi boozi' neMoodihti, 'i 'ilhoghun Yak'usda 'unt'oh 'ink'ez 'ilhoghun Sizi Gri 'unt'oh ni whe 'utni.\f* yugha te'nozeh. 'Ink'ez keyoh Ephesus ts'e lhat whe sla 'uja ínle', 'et cha soo t'eooninzun.
\c 2
\s1 Ndi Sizi Gri ye unzoo-i, 'i be soo ilhtus ónle'
\p 
\v 1 'Et huwa sye' nyun Sizi Gri ye unzoo-i, 'i be soo ilhtus ónle'.
\p 
\v 2 'Ink'ez lhane nalh daja nyudásni'-un 'enne ndi khun Sizi Gri ts'u ditnine tl'adínle, 'on 'un 'uyoonne huye hódoolh'eh ha.
\p 
\v 3 'Et huwa Sizi Gri oosalda unzoo-un k'un'a, nyun cha whuz howu whúlna'-un hoonts'i whulh ónyin.
\p 
\v 4 Dune salda unli-un, 'en dumoodih ba za 'ut'en. 'Aw 'udun 'ut'en-i gha lhasnoh.
\p 
\v 5 'Ink'ez cha, mbe la noye toh whuch'a' 'ulhdeh-un, ts'ih'un un'a whuch'a' nilhde de, 'et de za hiba k'elha whulhtsih.
\p 
\v 6 Mbe la tube 'ut'en-un ha' nulhyeh-un, 'en ndi naínalhyai-i, 'en cho yuloh yolhchoot huba' hoont'oh.
\p 
\v 7 Ndet la nyudúsni-un howu nuní ninzut. 'Ink'ez neMoodihti, 'en nla 'ut'en whe ts'iyantsuk t'eoononzeh.
\p 
\v 8 Soo whunailnih, Sizi Gri yaidlanne butoh dunadija. David oots'u haínzut-un cha 'unt'oh. 'Et whuz un'a ndi sghuni unzoo-i 'unt'oh whe nyudásni'.
\p 
\v 9 'Et huwa dune untsi'-un k'un'a 'adus'ai whe dzoh nuszut. 'Et hoonts'i Yak'usda ooghuni 'i 'aw lhilghel whe 'unt'oh.
\p 
\v 10 'Et huwa 'utahályanne, 'enne buba whulh susyin. 'Et de la 'utahályane, 'enne cha Christ, Sizi ts'utni-un, 'en ye néulhyis-i, 'i huyóolhchoot 'ink'ez 'ilhiz huhót'e'.
\p 
\v 11 Ndi khuni 'i soo cho oot'aniuznootan 'et ndutni,
\q1 “'En bulh dats'uzsai de,
\q2 'et de 'ilhiz wheni bulh úztit'elh cha 'uztit'elh.
\q1 
\v 12 Nts'oh dawhut'en hoonts'i whulh ts'úzyin de,
\q2 'et de 'en bulh lerwe uztileh.
\q1 Ooch'az nats'ulh'a de,
\q2 didut cha nech'az nátil'a.
\q1 
\v 13 Oolazditni de,
\q2 'et hoonts'i 'aw didut nela dootnih ait'oh,
\q2 'ink'ez 'aw 'ats'un un'a na'ootneh ait'oh 'et huwa.”
\s1 Sizi Gri ba ne'ut'enne, 'enne whulohne hinzoo 'ink'ez whulohne cha hintsi'
\p 
\v 14 'Et ndi khuni 'i buba oonailnih. NeMoodihti nalh budutánelh, 'et khun 'i khuni gha hukwa lhdulhyoh 'uhudootni' junih. Ts'iyawh buba lhe'yízoo'. 'Ants'i mbe la yudánts'one ts'iyawh ninta' butálh'elh.
\p 
\v 15 'Et Yak'usda ba dune unzoo-un onle', whuz un'a hukwa 'int'en. Nye 'ut'en 'aw la hukwa yálhuzonle'. Ndi khuni 'alha' 'unt'oh-i ts'ih'un un'a dune hubodilh'eh.
\p 
\v 16 'Et hoonts'i 'ants'i 'oh nuyálhdukne 'ink'ez Yak'usda ghudlóhne, 'enne buzih nónya' junih. Ndunt'ohne, 'enne 'uyoonne 'on nus Yak'usda ch'az yalhdukne ubuhutilhtselh la.
\p 
\v 17 Bughuni, dada k'un'a la butaidózit. Nyoonne Hymenaeus 'ink'ez Philetus cha, 'enne ndunt'ohne hinli.
\p 
\v 18 'Et ndunt'ohne dune ndi khuni 'alha' 'unt'oh-i tank'us 'uhint'oh huwa hich'a súdil. 'Enne 'uhutni, ndi dunahudutádulh-un, 'uda' 'uhooja hutni. 'Et whu la gha ts'e whulohne be 'alha' hoont'oh-i, ts'iyawh buba musai suli'.
\p 
\v 19 'Et hoonts'i Yak'usda ooyoh ook'uwhuz'ai-i whuduts'o. 'Aw gak hóle' ait'oh. 'I k'ut ndi khuni 'uk'eyánguz-i whe ndutni, “Mbene la neMoodihti ooch'e' hinline, 'enne ts'iyawh t'ebunínzun.” 'Ink'ez cha, “Mbene la 'uhutni, Christ oodune'ne ts'inli de, 'enne 'ut'en utsi'-i ts'u nínt'ine, 'et ndoohoont'oh-un, 'et ts'iyawh whuch'az náhoolyeh huba' hoont'oh.”
\p 
\v 20 Njan yoh whucho whambez ts'e ts'iyaitsuk 'et usdla. Be' ts'utnai-i 'ink'ez bé uzut'alh-i, whulohkhi gold cha, 'ink'ez silver cha, 'i be 'ulya. Whulohkhi duchun 'ink'ez whutl'us be 'ulya, 'i cha 'et usdla. Whulohkhi unzoo 'ink'ez whulohki 'aw lhízoo'.
\p 
\v 21 'Et whuz un'a, mbe la dich'oh lubeshi yuch'az nálh'a de, 'et de la duMoodihti ba 'udune'ududulti 'ink'ez ooMoodihti ye' tit'elh, 'ut'en unzoo-i ts'iyawh yeni lhadínt'oh whe 'unt'oh.
\p 
\v 22 'Ink'ez nyun cha chilke ntsi'-i buyust'e oots'i nint'i-i, 'i ooch'a tilgaih. K'us ts'ih'un 'uhoont'oh-un, be 'alha' hoont'oh-i, be lhk'ets'utsi'-i be nedzi soo óot'e'-i cha, ndi 'i ts'iyawh bunanyalh. Nyoonne budzi yo lubeshi ooghu hooloh whe neMoodihti ts'u dedudline, 'enne bubulh ín'us.
\p 
\v 23 'Et hoonts'i whusni ghuni 'ink'ez khuni t'enusdzun-i, 'i hoonts'i be yáhalhduk, 'i ts'iyawh ooch'oh onle'. T'eoonínzun ndi khuni ndunt'oh-i, 'i dune huyé lhdulhyoh 'utni-i, 'i 'unt'oh.
\p 
\v 24 'Et neMoodihti be 'ulhna-un, 'en 'aw dune élhdoosyaih. K'us ts'iyanne dune dach'e núlhe'ust'en 'ink'ez soo dune hodulh'eh-un tileh. Ts'iyanne nanilhtsulyaz ne'bulh'en.
\p 
\v 25 Yo 'údudildzun 'ink'ez buch'az ditnine ts'ih'un bubulh nenáhoho'alh. 'Et tilah Yak'usda dudeni nahundunizdla uboolhtselh. 'Et de la khuni 'alha' 'unt'oh-i t'ehinoozeh.
\p 
\v 26 'Ink'ez 'et de la bubeni bugha nádolts'it, 'ink'ez netsudule hubilhchoot inle' hik'une' 'oot'en ha, 'et la nts'oh te whe tank'us unint'i-un whuch'a nahooja'. 'Et 'udek'ez dzin whenghoh de, tube howa whútilna'
\c 3
\p 
\v 1 'Et njan t'eoononzin, 'et 'udek'ez dzin whenghoh de, tube howa whútilna'.
\p 
\v 2 'Et nilhdukw suli' de, dune dich'oh k'enahutitsi', sooneya ka dáhadatni, ts'iyantsuk whe hududílti', 'uhududílti', Yak'usda 'ink'ez oodune'ne', 'enne buch'az yahatilhduk, dudusneke cha k'únulhe'hutist'en, 'aw musi lhontiszin, 'ink'ez Yak'usda ghudlohne cha hutileh.
\p 
\v 3 Dudulh dune k'elhihítsi', 'aw hoonli lhba whunalhnohodulhnoh. Dudulh dune dzoh ne'huduni' hukwa' huninzun te za ne'hut'en. 'Ants'et 'uyoonne dzoh nuhulhdeh, 'ink'ez ndet hoonzoo-un hukwa lhe'huntiszil.
\p 
\v 4 'Uyoonne k'ehintsi' nahoohoolh'i 'ink'ez yoo yoh whe dune hundulhda, 'inkez butsi dunuts'un. Duba na'hutidzoo', Yak'usda k'elhuhítsi', 'ink'ez ndet la whuníni-un, 'et za hukwa' huntizilh.
\p 
\v 5 'Et Yak'usda ba ndi yun k'ut hudólts'i' na'hududil'i' 'et hoonts'i Yak'usda yé ulhtus-i hits'oodidlai. Timothy ndunt'ohne, 'enne buch'a nasindaih.
\p 
\v 6 Ndunt'ohne 'uyoonne yoh ts'e dahánul'ih 'ink'ez ts'ekoo whusnine, lubeshi be dizbunne, 'enne 'ilhiz ubihilhchuk. Ndunne lhelhdowh 'ut'en dutsun-i, 'ohwhi za hits'u nint'i.
\p 
\v 7 'Ahoolhyiz hohodul'eh 'et hoonts'i khuni 'alha' 'unt'oh-i daja ni 'aw t'ehonoozeh ait'oh.
\p 
\v 8 'Et nyoonne Jannes 'ink'ez Jambres bulh Moses hich'az nínt'i inle'. 'Et whuz un'a ndunne khuni 'alha' 'unt'oh-i, hich'az nint'i. 'Enne bubeni soo 'uk'enus untsi' suli'. 'Ink'ez ndi be 'alha' hoont'oh-i ghun buba 'ants'i hoont'oh.
\p 
\v 9 'Et hoonts'i 'aw 'on 'un hutooya' ait'oh. Whe ninta' hunt'en-un ts'iyanne t'ewhuntázin. Nts'en'a la Jannes 'ink'ez Jambres bubulh dahooja la, 'enne buk'un'a hiye whusni-i, ts'iyanne bughun t'ewhuntizilh.
\s1 Yak'usda uniyalhne dune bube túzilalh
\p 
\v 10 'Et hoonts'i huwa 'óonli whe khuni bunyodis'e'-i ook'un'a 'ant'en. Timothy nyunch'oh njan t'ewhunínzun. Nts'en'a dune usdli-un, nts'e la hukwa 'ust'en-un, 'ink'ez Yak'usda sba 'alha' 'unt'oh. Howa whúlna'-un whulh susyin, 'ink'ez ts'iyanne be k'ési' 'i cha, 'aw hoonli talhódusni.
\p 
\v 11 Dune sezula inle', 'ink'ez dzoh nusuhulhdzut. 'Et whuz yun k'ut Antioch, Iconium, 'ink'ez Lystra, whuz sulh 'et 'úhooja inle', 'i soo ts'iyawh t'eoonanzin. Dune sezula whulh susyin, 'ink'ez neMoodihti ts'iyawh whuch'a sla 'uja.
\p 
\v 12 'Alha' hoont'oh mbene la Christ, Sizi ts'utni-un, 'en gha Yak'usda ba khutinalh hukwa 'ut'enne, 'enne dune bube hútuzilalh whe' hoont'oh.
\p 
\v 13 'Et dune ntsi'ne, 'uyoon na'dudil'íne, 'enne 'on nus hintsi' tileh 'ink'ez 'on 'un cha hintsi' hutileh. 'Et 'uyoonne nahunti'ah 'ink'ez dich'oh cha na'hunduntit'ah.
\p 
\v 14 'Et hoonts'i nyun ndet la hodal'e'-un whe 'i ts'iyawh 'alha' 'unt'oh t'enínzun whuz un'a za 'int'oh. 'Ink'ez mbene la oogha hodal'e'ne, 'enne t'ebuninzun.
\p 
\v 15 'Et nyun ts'oodun inli da' whuts'un ndi Yak'usda ooghuni lubeshi ooghu hooloh whe 'uk'éguz-i t'enanzin. 'I gha be whutnih-i int'i whe dinjih, Christ, Sizi ts'utni-un, 'en mba 'alha' 'unt'oh 'et huwa.
\p 
\v 16 Yak'usda ooghuni 'i ts'iyawh Yak'usda ye sjiz-i bulh 'únt'oh. 'Ink'ez oogha whúts'odul'eh huba unzoo, ninta' ts'ut'ih-un whunénulhtun, neba ts'ih'un newhu'aih cha, 'ink'ez 'et whuneodulh'eh ts'ih'un un'a yinka uzdólts'i ha.
\p 
\v 17 'I be Yak'usda oodune'ne lhadúlyane hutileh, 'ut'en unzoo-i wheni lhahúdint'oh.
\c 4
\s1 Yak'usda ooghuni bé bubulh yaílhduk
\p 
\v 1 'Et huwa Yak'usda 'ink'ez neMoodihti Sizi Gri 'en oobut nyudutásnelh, 'en 'utinelh ts'iyanne nalh be hóodutaltsilh, ndai la k'úne' yul'en-i, 'i bulh. 'Oh de khunane 'ink'ez yaidlanne cha, 'enne buba nahutiyeh.
\p 
\v 2 'Ahoolhyiz lhadínt'oh Yak'usda ooghuni bé bubulh yaílhduk. Whúbunilhtun ndet whe ninta' hut'ih-un, 'ink'ez tank'us 'uhut'en-un hukwa budíni, 'ink'ez budzi do ná'inleh. Howa whúlna'-un whulh sinyin, 'ink'ez dune hodilh'eh.
\p 
\v 3 Whuz de whúdizulh, ndi khuni ts'ih'un un'a 'unt'oh-i, 'i 'aw huyodool'eh hukwa lhe'huntiszin. K'us dich'oh hukwa' huninzun k'un'a, 'et za 'uhodutats'o hukwa' huninzun. Mbene la didutch'oh hukwa' huninzun te za whuz un'a dune hodulh'ehne, 'enne za uboohootuzálhts'ilh hukwa' huntizilh.
\p 
\v 4 Khuni 'alha' 'unt'oh-i, 'i 'aw hidóts'o hukwa lhe'huntiszil. 'Et k'us khuni 'ants'i unli-i, 'ohwhi za hika' ntizilh.
\p 
\v 5 'Et hoonts'i Timothy nyun ts'iyantsuk whunih-i be whuch'a soo cho khinli. Ndi Yak'usda be 'ut'en k'oh whulukhun mba howa whulna' 'et hoonts'i nilht'i za 'ilhdzun. 'Ink'ez Yak'usda ooghuni be yailhduk whe dune ilhyís-un, 'et za ndónt'en. 'Ink'ez Yak'usda be ooba 'int'en-i, 'i ts'iyawh lhadónleh.
\s1 Paul datítsah-un howu yalhduk
\p 
\v 6 Si 'awet be khusna-i Yak'usda ba huwa t'aih k'un'a nadusjulh le'usneh.\f + \fr 4:6 \ft Ndai la ts'ekootoo' dizti'-i loodel oozih nahidiyulh-i inle', 'i Lizwifne bube 'ut'en 'unt'oh. 'Ink'ez ndi nahidiyulh-i, 'i Paul khuna le'unt'oh ni whe 'utni.\f* 'Ink'ez ndo tisyalh-un 'awet nilhdukw suli'.
\p 
\v 7 Hoonzoo whe ts'ih'un un'a lhisgan. 'Awet Yak'usda be 'ut'en k'oh 'uwhus'en-un ts'iyantsuk lhaoodusdla. Ts'ih'un un'a be 'alha' hoont'oh-i hostun.
\p 
\v 8 'Udek'ez khuni be' dusni, ndet ts'ih'un un'a hoont'oh whe whuch'a oonusde-un, 'et sba us'ai. NeMoodihti ts'ih'un nahiyilh-un, 'en yutilhtselh-i, 'i 'oh de dzin sgha íta'alh. 'Ink'ez 'aw si za iloh. Mbene la dudzi ndulcho-i be bunalh be hóodutalhtsilh 'ink'ez yuti'elh hukwa' ninzunne, 'enne 'ilhoghun hinli whe ts'iyawh si sk'un'a za 'úbutilelh.
\s1 Ts'iyanne sla ditni
\p 
\v 9 'A cho sts'u tónya'.
\p 
\v 10 Demas sla ditni. Ndi yun k'ut núkat-i 'on nus yuka' ninzun. 'Et huwa keyoh Thessalonica whuz whinya. Crescens 'en yun k'ut Galatia ts'e whinya 'ink'ez Titus 'en cha yun k'ut Dalmatia whuz whinya.
\p 
\v 11 Luke 'en za szih usda. Mark 'en ookunainda 'ink'ez ndiz nyulh tóo'as, 'en sba 'ut'en huba unzoo 'et huwa.
\p 
\v 12 'Ink'ez Tychicus 'en keyoh Ephesus ts'e whes'a'.
\p 
\v 13 Ndiz tanyalh de, sdzoot sba tolhchoos. 'I Carpus keyoh Troas ts'e 'en da' oozih neínuschooz. Nyoo khuni úk'éguz-i, 'i cha ton'a', 'ink'ez ndai la ndi khuna-i zuz ook'une'úsguz-i, 'i oonaoodolnoh junih. 'I soo ooka' nuszun.\f + \fr 4:13 \ft Paul khuna whe 'oh da' khuna-i zuz lhahidulh'ih-i, lhts'enuhuyut'az 'ink'ez 'i hik'une'uguz inle'.\f*
\p 
\v 14 Nyoon lhuztih 'ultl'uz 'ut'en-un, Alexander huyulhni, 'en tube lhat-un whe sundílhda'. Be 'ut'en k'oh huwa uncha neMoodihti yuba 'uk'elha whulhtsi.
\p 
\v 15 Nyun cha ookwa huwonle'. 'En dune ulhtus-i be neghuni dulhyoh 'it'elh-un 'unt'oh 'et huwa.
\s1 NeMoodihti 'aw neladootnih ait'oh
\p 
\v 16 'Et 'udechoo ooduzkut da', 'aw 'ilhoghun hoonts'i st'anélhiyal. K'us ts'iyanne sla huditni, 'et hoonts'i 'aw buk'eholts'it hukwa lhe'núszun.
\p 
\v 17 'Et hoonts'i neMoodihti szih inyin 'ink'ez 'en ye ulhtus-i, 'i gha ustus inle'. 'Et ndi ulhtus-i, 'i be si sgha la ndi Yak'usda be ba yaduk-i, 'i ts'iyawh ts'ih'un un'a huyoozálhts'ai'. 'Et de la 'uyoonne 'udun yun k'ut whut'enne cha ts'iyawh huyoozólhts'ai'. 'Ink'ez cha neMoodihti 'en khuna-iti sutuzilhghelh-i yuch'á sulhyih.\f + \fr 4:17 \ft Ndi khuna-iti sutuzilhghelh-i 'et whuz un'a Lerwe Caesar lhane Sizi Gri yulh 'ut'enne, 'enne cha ubuhanghan, ni whe 'utni.\f*
\p 
\v 18 'Et yak'uz neMoodihti 'en lerwe unli, 'et wheni sghunli, 'ink'ez oozih tisdalh whuts'un, 'ut'en untsi'-i ts'iyawh yuch'a sutálhtelh. 'Et huwa 'en 'ilhiz wheni 'ink'ez 'on 'un cha uzdólhti'. 'Et ndo honeh.
\s1 Khit whutso whusaóonya'
\p 
\v 19 Ndunne Prisca 'ink'ez Aquila, 'ink'ez cha Onesiphorus ooyoh dilhts'ine, ts'iyawh hadih sba budóni'.
\p 
\v 20 Erastus 'en keyoh Corinth 'et usda. Trophimus 'en nduda 'inka keyoh Miletus ts'uwhútni, 'et nenústi.
\p 
\v 21 'Et khit tileh whuts'o, 'et soo 'int'oh whe sts'u tonya'. Eubulus, 'en cha hadih nyulhni, 'ink'ez Pudens, Linus, Claudia, ts'iyawh lhulhutsinke, 'enne cha hadih nyuhútni.
\s1 Ye unzoo-i nyulh 'óot'e'
\p 
\v 22 NeMoodihti Sizi Gri 'en ndzi yo ooda' 'ink'ez ye unzoo-i, 'i nyulh 'óot'e'. 'Et ndo honeh.
