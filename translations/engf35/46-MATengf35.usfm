\v 37 \w For|strong="G1063"\w* \w by|strong="G1537"\w* \w your|strong="G2532"\w* \w words|strong="G3056"\w* \w you|strong="G4771"\w* \w will|strong="G2532"\w* \w be|strong="G2532"\w* \w justified|strong="G1344"\w*, \w and|strong="G2532"\w* \w by|strong="G1537"\w* \w your|strong="G2532"\w* \w words|strong="G3056"\w* \w you|strong="G4771"\w* \w will|strong="G2532"\w* \w be|strong="G2532"\w* \w condemned|strong="G2613"\w*.”\f + \fr 12:37 \ft “Every useless word whatever”—do we really believe that? This may be why certain orders of monks took an oath of silence (but how can you be ‘justified’ by your words if you never say anything?).\f*   
\s2 The sign of the prophet Jonah  
\p
\v 38 \w Then|strong="G2532"\w* \w some|strong="G5100"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w scribes|strong="G1122"\w* \w and|strong="G2532"\w* \w Pharisees|strong="G5330"\w* reacted \w saying|strong="G3004"\w*, “\w Teacher|strong="G1320"\w*, \w we|strong="G2532"\w* \w want|strong="G2309"\w* \w to|strong="G2532"\w* \w see|strong="G3708"\w* \w a|strong="G2532"\w* \w sign|strong="G4592"\w* \w from|strong="G2532"\w* \w you|strong="G4771"\w*.”\f + \fr 12:38 \ft Jesus had already performed hundreds of signs, and doubtless they had seen some of them. Their request was not honest.\f*  
\v 39 \w But|strong="G1161"\w* \w in|strong="G2532"\w* answer \w He|strong="G2532"\w* \w said|strong="G3004"\w* \w to|strong="G2532"\w* \w them|strong="G3588"\w*: “\w A|strong="G2532"\w* \w malignant|strong="G4190"\w* \w and|strong="G2532"\w* \w adulterous|strong="G3428"\w* \w generation|strong="G1074"\w* \w seeks|strong="G1934"\w* \w a|strong="G2532"\w* \w sign|strong="G4592"\w*, \w and|strong="G2532"\w* \w no|strong="G3756"\w* \w sign|strong="G4592"\w* \w will|strong="G2532"\w* \w be|strong="G2532"\w* \w given|strong="G1325"\w* \w to|strong="G2532"\w* \w it|strong="G2532"\w* \w except|strong="G1487"\w* \w the|strong="G2532"\w* \w sign|strong="G4592"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w prophet|strong="G4396"\w* \w Jonah|strong="G2495"\w*.  
\v 40 \w For|strong="G1063"\w* \w just|strong="G5618"\w* \w as|strong="G5618"\w* \w Jonah|strong="G2495"\w* \w was|strong="G1510"\w* \w three|strong="G5140"\w* \w days|strong="G2250"\w* \w and|strong="G2532"\w* \w three|strong="G5140"\w* \w nights|strong="G3571"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w stomach|strong="G2836"\w* \w of|strong="G5207"\w* \w the|strong="G1722"\w* \w sea|strong="G2785"\w* \w monster|strong="G2785"\w*, \w so|strong="G3779"\w* \w will|strong="G1510"\w* \w the|strong="G1722"\w* \w Son|strong="G5207"\w* \w of|strong="G5207"\w* \w the|strong="G1722"\w* \w Man|strong="G2588"\w* \w be|strong="G1510"\w* \w three|strong="G5140"\w* \w days|strong="G2250"\w* \w and|strong="G2532"\w* \w three|strong="G5140"\w* \w nights|strong="G3571"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w heart|strong="G2588"\w* \w of|strong="G5207"\w* \w the|strong="G1722"\w* \w earth|strong="G1093"\w*.\f + \fr 12:40 \ft “In the heart of the earth”—here we seem to have instruction from the Lord on the location of Hades—it is inside the earth, somehow. Compare 1 Samuel 28:13 where Samuel (literally), returning from Hades/Sheol, comes up from inside the earth.\f*  
\v 41 Ninevite \w men|strong="G3778"\w* \w will|strong="G2532"\w* arise \w with|strong="G3326"\w* \w this|strong="G3778"\w* \w generation|strong="G1074"\w* \w at|strong="G1722"\w* \w the|strong="G1722"\w* \w judgment|strong="G2920"\w* \w and|strong="G2532"\w* \w will|strong="G2532"\w* \w condemn|strong="G2632"\w* \w it|strong="G2532"\w*, \w because|strong="G3754"\w* \w they|strong="G2532"\w* \w repented|strong="G3340"\w* \w at|strong="G1722"\w* \w the|strong="G1722"\w* \w preaching|strong="G2782"\w* \w of|strong="G2532"\w* \w Jonah|strong="G2495"\w*; \w and|strong="G2532"\w* really, \w a|strong="G2532"\w* \w greater|strong="G4183"\w* \w than|strong="G4183"\w* \w Jonah|strong="G2495"\w* \w is|strong="G3588"\w* \w here|strong="G5602"\w*.  
\v 42 \w The|strong="G1722"\w* queen \w of|strong="G1537"\w* \w the|strong="G1722"\w* \w South|strong="G3558"\w* \w will|strong="G2532"\w* \w be|strong="G2532"\w* \w raised|strong="G1453"\w* \w with|strong="G3326"\w* \w this|strong="G3778"\w* \w generation|strong="G1074"\w* \w at|strong="G1722"\w* \w the|strong="G1722"\w* \w judgment|strong="G2920"\w* \w and|strong="G2532"\w* \w she|strong="G2532"\w* \w will|strong="G2532"\w* \w condemn|strong="G2632"\w* \w it|strong="G2532"\w*, \w because|strong="G3754"\w* \w she|strong="G2532"\w* \w came|strong="G2064"\w* \w from|strong="G1537"\w* \w the|strong="G1722"\w* \w ends|strong="G4009"\w* \w of|strong="G1537"\w* \w the|strong="G1722"\w* \w earth|strong="G1093"\w* \w to|strong="G2532"\w* hear \w the|strong="G1722"\w* \w wisdom|strong="G4678"\w* \w of|strong="G1537"\w* \w Solomon|strong="G4672"\w*; \w and|strong="G2532"\w* really, \w a|strong="G2532"\w* \w greater|strong="G4183"\w* \w than|strong="G4183"\w* \w Solomon|strong="G4672"\w* \w is|strong="G3588"\w* \w here|strong="G5602"\w*.\f + \fr 12:42 \ft Jonah, and the sea monster, are just as historical as Solomon, the queen of Sheba, Nineveh—we have it on the authority of the Lord Jesus Christ.\f*   
\s2 An empty ‘house’ is bad  
\p
\v 43 “\w Now|strong="G1161"\w* \w when|strong="G3752"\w* \w an|strong="G2532"\w* unclean \w spirit|strong="G4151"\w* [demon] \w goes|strong="G1831"\w* \w out|strong="G1831"\w* \w from|strong="G2532"\w* \w a|strong="G2532"\w* \w man|strong="G3756"\w*, \w it|strong="G2532"\w* \w goes|strong="G1831"\w* \w through|strong="G1223"\w* arid \w places|strong="G5117"\w* \w looking|strong="G2212"\w* \w for|strong="G1223"\w* rest, \w but|strong="G1161"\w* \w finds|strong="G2147"\w* \w none|strong="G3756"\w*.  
\v 44 \w Then|strong="G2532"\w* \w it|strong="G2532"\w* \w says|strong="G3004"\w*, ‘\w I|strong="G1473"\w* \w will|strong="G2532"\w* \w return|strong="G1994"\w* \w to|strong="G1519"\w* \w my|strong="G1473"\w* \w house|strong="G3624"\w* \w from|strong="G2064"\w* \w where|strong="G3606"\w* \w I|strong="G1473"\w* \w came|strong="G2064"\w*.’ \w And|strong="G2532"\w* \w coming|strong="G2064"\w* \w it|strong="G2532"\w* \w finds|strong="G2147"\w* \w it|strong="G2532"\w* \w unoccupied|strong="G4980"\w*, \w swept|strong="G4563"\w* \w and|strong="G2532"\w* \w put|strong="G2532"\w* \w in|strong="G1519"\w* \w order|strong="G2885"\w*.  
