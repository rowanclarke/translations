\id 2TI - Biblica® Open Kurdi Sorani Standard Version
\h دووەم تیمۆساوس
\toc1 دووەم نامەی پۆڵس بۆ تیمۆساوس
\toc2 دووەم تیمۆساوس
\toc3 دووەم تیمۆساوس
\mt1 دووەم نامەی پۆڵس بۆ تیمۆساوس
\c 1
\p 
\v 1 لە پۆڵسەوە کە بە خواستی خودا نێردراوی عیسای مەسیحە، بەگوێرەی بەڵێنی ژیان کە بە یەکبوون لەگەڵ عیسای مەسیحدا بەدەستدێت،
\b
\p 
\v 2 بۆ کوڕی خۆشەویستم تیمۆساوس:
\b
\p با نیعمەت\f + \fr 1:2 \ft نیعمەت بەخشینێکی خودایە بە مرۆڤ بەبێ شایستەبوونی پێی دەبەخشێت.\f* و بەزەیی و ئاشتی لە خودای باوک و عیسای مەسیحی خاوەن شکۆمانەوە لەگەڵت بێت.
\b
\s1 هاندان بۆ ئازارچێژتن
\p 
\v 3 سوپاسی خودا دەکەم، ئەوەی هەروەک باوباپیرانم بە ویژدانێکی پاک دەیپەرستم، کاتێک بە شەو و ڕۆژ بێ بڕانەوە لە پاڕانەوەکانمدا یادت دەکەم.
\v 4 کاتێک یادی فرمێسکەکانت دەکەمەوە، پەرۆشی بینینت دەبم تاکو پڕبم لە خۆشی.
\v 5 باوەڕی بێ دووڕوویی تۆم وەبیر دێتەوە کە یەکەم جار لە ناخی لوئیسی داپیرەت و یونیکی دایکتدا نیشتەجێ بوو، دڵنیام لە تۆشدایە.
\p 
\v 6 لەبەر ئەمە وەبیرت دەهێنمەوە ئەو بەهرەیە دابگیرسێنیت کە لەدوای ئەوەی من دەستم لەسەرت دانا خودا پێی بەخشیت،
\v 7 چونکە خودا ڕۆحی ترسی پێمان نەبەخشیوە، بەڵکو ڕۆحی هێز و خۆشەویستی و خۆڕاگریی پێ بەخشیوین.
\v 8 بۆیە نە لە بەرامبەر پەیامەکە سەبارەت بە مەسیحی خاوەن شکۆمان و نە بەرامبەر بە من کە لە پێناوی ئەودا بەند کراوم هەست بە شەرمەزاری مەکە، بەڵکو لەگەڵ من و بە پشتبەستن بە هێزی خودا بەشداری لەو ئازارەدا بکە کە بەهۆی مزگێنییەوە دەیچێژیت.
\v 9 خودا ڕزگاری کردین و بە بانگەوازێکی پیرۆز بانگی کردین، نەک بەگوێرەی کردارمان، بەڵکو بەگوێرەی خواست و نیعمەتی خۆی کە پێش دەستپێکی زەمانە بەهۆی یەکبوونمان لەگەڵ عیسای مەسیحدا پێمان دراوە،
\v 10 ئێستاش ئاشکرا بوو بە دەرکەوتنی عیسای مەسیحی ڕزگارکەرمان، ئەوەی مردنی لەناو برد و لە ڕێگەی پەیامی ئینجیلەوە ژیان و نەمریی ڕووناک کردەوە.
\v 11 بۆ ئەم مزگێنییە بە مزگێنیدەر و نێردراو و مامۆستا دەستنیشان کرام.
\v 12 لەبەر ئەم هۆیەش ئەم ئازارانە دەچێژم، بەڵام شەرمی پێوە ناکەم، چونکە دەزانم باوەڕم بە کێ هێناوە، دڵنیام مەسیح دەتوانێ پارێزگاری سپاردەکەم\f + \fr 1:12 \ft مەبەستی لە ئینجیلە.‏\f* بکات هەتا ئەو ڕۆژە.
\s1 سپاردە چاکەکە بپارێزە
\p 
\v 13 بەدوای ئەو فێرکردنە دروستە بکەوە کە لە منت بیستووە، بیکە سەرمەشقی ژیانت، لەگەڵ ئەو باوەڕ و خۆشەویستییەی کە لە یەکبوون لەگەڵ عیسای مەسیحدا هەیە.
\v 14 سپاردە\f + \fr 1:14 \ft مەبەستی لە ئینجیلە.‏\f* چاکەکە بە ڕۆحی پیرۆز بپارێزە کە تیاماندا نیشتەجێیە.
\p 
\v 15 ئەمە دەزانی، هەموو ئەوانەی لە ئاسیادان وازیان لێ هێنام، لەوانە فیگەلۆس و هەرمۆگینیس.
\p 
\v 16 با مەسیحی باڵادەست بەزەیی بە خێزانی ئۆنیسیفۆرۆسدا بێتەوە، چونکە زۆر جار ورەی بەرز کردومەتەوە و شەرمی بە کۆت و زنجیرم نەبووە،
\v 17 بەڵکو کاتێک لە ڕۆما بوو، بە پەرۆشییەوە بەدوامدا گەڕا و منی دۆزییەوە.
\v 18 با لە‏ ڕۆژی لێپرسینەوەدا بەهۆی مەسیحی باڵادەستەوە بەزەیی خودای باوک بەدەستبهێنێت. تۆ باش دەزانیت کە لە ئەفەسۆس بە چەندین شێوە خزمەتی کردم.
\c 2
\s1 بەشداری ئازار بکە
\p 
\v 1 بۆیە کوڕی خۆم، تۆ بەهێز بە بەو نیعمەتەی کە لە عیسای مەسیحدایە.
\v 2 ئەوەی لەبەردەم چەندین شایەتدا لە منت بیستووە، بە خەڵکی دڵسۆزی بسپێرە کە لێهاتوو بن بۆ ئەوەی خەڵکی دیکەش فێربکەن.
\v 3 وەک سەربازێکی چاک بۆ عیسای مەسیح، لەگەڵمان بەشداری لە ئازار بکە.
\v 4 هیچ سەربازێک خۆی بە کاروباری ڕۆژگارەوە خەریک ناکات تاکو فەرماندەکەی ڕازی بکات.
\v 5 ئەگەر یەکێک پێشبڕکێ بکات، خەڵات ناکرێت ئەگەر شوێن یاسای پێشبڕکێکە نەکەوێت.
\v 6 جوتیاری ڕەنجدەر دەبێ یەکەم کەس بێت بەشی خۆی لە بەرهەمەکە ببات.
\v 7 بیربکەوە لەوەی دەیڵێم، مەسیحی خاوەن شکۆ یارمەتیت دەدات لە هەموو شتێک تێبگەیت.
\p 
\v 8 یادی عیسای مەسیح بکە، کە لەنێو مردووان هەستایەوە و لە نەوەی داود بوو. ئەمە پەیامی ئینجیلەکەمە،
\v 9 کە لە پێناویدا ئازار دەچێژم و وەک تاوانبارێک کۆت و زنجیر کراوم، بەڵام وشەی خودا کۆت ناکرێت.
\v 10 بۆیە بەرگەی هەموو شتێک دەگرم لەبەر ئەوانەی خودا هەڵیبژاردن، تاکو ئەوانیش ئەو ڕزگارییە بەدەستبهێنن کە بەهۆی عیسای مەسیحەوەیە، لەگەڵ شکۆی هەتاهەتایی.
\p 
\v 11 ئەم قسەیە ڕاستە:
\q1 «ئەگەر لەگەڵیدا مردبین،
\q2 لەگەڵیشی دەژین،
\q1 
\v 12 ئەگەر دانبەخۆدا بگرین،
\q2 لەگەڵیدا پاشایەتی دەکەین.
\q1 ئەگەر نکۆڵی لێ بکەین،
\q2 ئەویش نکۆڵیمان لێدەکات.
\q1 
\v 13 ئەگەر دڵسۆز نەبین،
\q2 ئەو هەر بە دڵسۆزی دەمێنێتەوە،
\q2 چونکە ناتوانێت نکۆڵی لە خۆی بکات.»
\s1 کارگەری وشەی ڕاست
\p 
\v 14 ئەمانەیان بیربخەوە و لە شەڕەقسە ئاگاداریان بکەوە لەبەردەم خودا، چونکە سوودی نییە، بەڵکو بیسەران دەڕووخێنێت.
\v 15 کۆشش بکە وەک کارگەرێکی بێ شەرمەزاری خۆت بسەلمێنی بۆ خودا، بە ڕێگای ڕاست وشەی ڕاستی لێک بدەیتەوە.
\v 16 خۆت لە قسەی هیچوپووچ بپارێزە، چونکە زیاتر و زیاتر مرۆڤ بەرەو خوانەناسی دەبات.
\v 17 وشەکانیان وەک لاڕەشەیە\f + \fr 2:17 \ft یۆنانی: \tl گانگرین‏\tl*، نەخۆشییەکی کوشندەیە.‏\f* تەشەنە دەکات. لەوانە هیمینایۆس و فیلێتۆس،
\v 18 کە لە ڕاستی دەرچوون و دەڵێن هەستانەوە ڕوویداوە، ئیتر باوەڕی هەندێک هەڵدەگێڕنەوە.
\v 19 بەڵام بناغە توندەکەی خودا چەسپاوە، ئەم مۆرەی لەسەرە: ﴿یەزدان ئەوانەی هی خۆیەتی دەیانناسێت،﴾\f + \fr 2:19 \ft \xt سەرژمێری 16‏:5‏\xt*\ft ‏\f* هەروەها «ئەوەی ناوی یەزدانی لەسەرە، با لە بەدکاری دووربکەوێتەوە.»
\p 
\v 20 بەڵام لە ماڵێکی گەورەدا تەنها قاپوقاچاغی زێڕ و زیو نییە، بەڵکو دارینە و گڵینیش هەیە کە هەندێکیان بۆ ڕێزلێنانن و هەندێکی دیکەشیان بۆ کاروباری ئاسایین.
\v 21 بۆیە ئەگەر یەکێک خۆی لەمانە پاک بکاتەوە، ئەوا دەبێتە جامێک بۆ ڕێزلێنان، پیرۆز\f + \fr 2:21 \ft تەرخانکراو‏\f* و سوودبەخش بۆ گەورەکەی، ئامادە بۆ هەموو کارێکی چاک.
\p 
\v 22 لە هەوەسەکانی گەنجییەتی ڕابکە، کۆشش بکە بۆ ڕاستودروستی و باوەڕ و خۆشەویستی و ئاشتی لەگەڵ ئەوانەی بە دڵێکی پاک لە مەسیحی باڵادەست دەپاڕێنەوە.
\v 23 لە گفتوگۆی پووچ و نەزان دووربکەوە، بزانە شەڕی لێ دەکەوێتەوە.
\v 24 بەندەی مەسیحی خاوەن شکۆ نابێت شەڕفرۆش بێت، بەڵکو دەبێت لەگەڵ هەمووان میهرەبان بێت، توانای فێرکردنی هەبێت، هەروەها پێویستە لە کاتی تەنگانەدا دان بەخۆیدا بگرێت.
\v 25 ئەوانەی بەربەرەکانێی دەکەن بە دڵنەرمی ڕاستیان بکاتەوە، بە هیوای ئەوەی خودا تۆبەکردنی ڕاستی ناسینیان بداتێ
\v 26 و لە داوی شەیتان هۆشیان بەخۆیاندا بێتەوە، ئەوەی بۆ ئەنجامدانی خواستی خۆی بەندی کردن.
\c 3
\s1 نیشانەکانی ڕۆژانی دوایی
\p 
\v 1 ئەوە بزانە کە لە ڕۆژانی کۆتاییدا کاتێکی تەنگانە دادێت،
\v 2 چونکە خەڵکی خۆیان خۆشدەوێ، پارەیان خۆشدەوێ، لووتبەرزن، خۆهەڵکێشن، زمانپیسن، گوێڕایەڵی دایک و باوک نابن، سوپاسگوزار نین، گڵاون،
\v 3 بێ خۆشەویستین، گەردن ئازاد ناکەن، بوختانکەرن، بەسەرخۆدا زاڵنەبوون، دڕندەن، حەز لە چاکە ناکەن،
\v 4 ناپاکن، سەرەڕۆ و لەخۆبایین، زیاتر حەزیان لە چێژە نەک خۆشەویستی خودا،
\v 5 ڕواڵەتی خواترسییان هەیە، بەڵام نکۆڵی لە هێزەکەی دەکەن. جا لەوانە دوور بکەونەوە.
\p 
\v 6 ئەوانە لەو جۆرە کەسانەن کە بە ماڵاندا دەگەڕێن، ژنە لاوازەکان دەستەمۆ دەکەن، کە بە بارگرانی گوناهەوە شوێنی هەموو جۆرە هەوەسێک کەوتوون،
\v 7 هەردەم فێر دەبن، بەڵام هەرگیز ناتوانن ڕاستی بناسن.
\v 8 وەک چۆن یەنیس و یەمبریس\f + \fr 3:8 \ft دوو جادووگەری میسری بوون کە لە کۆشکی فیرعەون بەربەرەکانێی موسایان کرد، بڕوانە \xt دەرچوون 7‏:11‏\xt*\ft ‏.‏\f* بەربەرەکانێی موسایان کرد، ئەوانەش بەربەرەکانێی ڕاستی دەکەن. ئەو پیاوانە مێشکیان گەندەڵ بووە و لەلایەن باوەڕەکەوە ڕەتکراونەتەوە.
\v 9 بەڵام زیاتر پێش ناکەون، چونکە گێلایەتییان بۆ هەمووان دەردەکەوێت، وەک گێلایەتی ئەوانی لێهات.
\s1 لەسەر باوەڕت بمێنەوە
\p 
\v 10 بەڵام تۆ، فێرکردن و شێوازی ژیان، ئامانج و باوەڕ، ئارامگرتن و خۆشەویستی و دانبەخۆداگرتن،
\v 11 چەوسانەوە و ئازاری منت زانی، ئەوەی لە ئەنتاکیا و کۆنیا و لیسترا بەسەرم هات و بەرگەی چ چەوسانەوەیەکم گرت، بەڵام مەسیحی باڵادەست لە هەموویان دەربازی کردم.
\v 12 هەموو ئەوانەی دەیانەوێ بە لەخواترسییەوە بە یەکبوون لەگەڵ عیسای مەسیح بژین، دەچەوسێنرێنەوە،
\v 13 بەڵام خراپەکار و فێڵبازان بەرەو خراپتر دەڕۆن کە چەواشەکار و چەواشەکراون.
\v 14 بەڵام تۆ، لەسەر ئەوە بمێنەوە کە فێری بوویت و دڵنیابوویت، چونکە زانیت لە کێ فێربوویت،
\v 15 هەروەها لە منداڵییەوە لە نووسراوە پیرۆزەکانەوە دەزانیت کە دەتوانن لە ڕێگەی باوەڕ بە عیسای مەسیح بتکەنە دانا بۆ بەدەستهێنانی ڕزگاری.
\v 16 هەموو نووسراوە پیرۆزەکان لە سروشی خودان\f + \fr 3:16 \ft یۆنانی: فووی خودا.‏\f*، سوودبەخشن بۆ فێرکردن و سەرزەنشت و ڕاستەڕێکردن و لێڕاهێنان لە ڕاستودروستی،
\v 17 تاکو پیاوی خودا تەواو ئامادە بێت بۆ هەموو کارێکی باش.
\c 4
\s1 وشەی خودا ڕابگەیەنە
\p 
\v 1 لەبەردەم خودا و عیسای مەسیح، ئەوەی لە داهاتوودا زیندووان و مردووان حوکم دەدات، لەبەر دەرکەوتنی خۆی و شانشینەکەی ڕاتدەسپێرم:
\v 2 وشەی خودا ڕابگەیەنە، ئامادە بە لە کاتی گونجاو و نەگونجاو، خەڵکی ڕاستەڕێ بکە، سەرزەنشت بکە و ورەیان بەرز بکەرەوە، بەوپەڕی پشوودرێژی و هەوڵی فێرکردن،
\v 3 چونکە کاتێک دێت خەڵک بەرگەی فێرکردنی دروست ناگرن، بەڵکو بەگوێرەی ئارەزووی تایبەتی خۆیان مامۆستا کۆدەکەنەوە تاکو ختووکەی گوێیان بدات.
\v 4 بۆ ڕاستی گوێیان دادەخەن، بۆ ئەفسانە لادەدەن.
\v 5 بەڵام تۆ، لە هەموو شتێکدا وریابە، لە ئازاردا دان بە خۆتدا بگرە، بە کاری مزگێنیدەری هەستە، خزمەتی خۆت تەواو بکە.
\p 
\v 6 سەبارەت بە من، وا وەک شەرابی پێشکەشکراو دەڕژێم\f + \fr 4:6 \ft مەبەستی نووسەر لێرەدا واتا من وا دەمرم، نەریت و باو بووە کە خواردنەوەی گرنگ وەک قوربانی ڕژێنراوە، \xt لێڤییەکان 23‏:18‏\xt*\ft ‏.‏\f* و کاتی کۆچکردنم هاتووە.
\v 7 تێکۆشانێکی باش تێکۆشاوم، پێشبڕکێکەم تەواو کرد و باوەڕەکەم پاراست.
\v 8 ئێستا تاجی ڕاستودروستیم بۆ دانراوە، ئەوەی مەسیحی خاوەن شکۆ کە دادوەری ڕاستودروستە لەو ڕۆژەدا دەمداتێ، تەنها بۆ من نییە، بەڵکو بۆ هەموو ئەوانەشە کە پەرۆشی دەرکەوتنین.
\s1 دوا ڕاسپاردە
\p 
\v 9 کۆشش بکە زوو بێیتە لام،
\v 10 چونکە دیماس بەجێی هێشتم، ئەم جیهانەی خۆشویست و چوو بۆ سالۆنیکی، کریسکینیش بۆ گەلاتیا و تیتۆس بۆ دەلماتیا.
\v 11 بە تەنها لۆقام لەلایە. مەرقۆس لەگەڵ خۆت بهێنە، چونکە لە خزمەتکردندا سوودی بۆم هەیە.
\v 12 تیخیکۆسم ناردووە بۆ ئەفەسۆس.
\v 13 کاتێک هاتیت، ئەو کەوایە لەگەڵ خۆت بهێنە کە لە ترۆئاس لەلای کارپۆس بەجێم هێشت، تۆمارەکانیش\f + \fr 4:13 \ft پەڕتووکی نووسراو لەسەر پێست یان کاغەز و پێچراوەتەوە.‏\f* بهێنە، بە تایبەت دەستنووسەکان.
\p 
\v 14 ئەسکەندەری مسگەر زۆر خراپەی لەگەڵ کردم، مەسیحی خاوەن شکۆ تۆڵەی لێدەکاتەوە لەسەر کردارەکانی.
\v 15 خۆتی لێ بپارێزە، چونکە زۆر بەرهەڵستی پەیامەکەمانی کرد.
\p 
\v 16 لە بەرگری یەکەمم کەس لەگەڵم نەهات، بەڵکو هەموو بەجێیان هێشتم. خودایە، لەسەریان هەژمارد مەکە.
\v 17 بەڵام مەسیحی خاوەن شکۆ لەگەڵم وەستا و بەهێزی کردم، تاکو بە منەوە جاڕدانەکە بە تەواوی بدرێت و هەموو گەلان بیبیستن. ئیتر لە دەمی شێر دەرباز بووم.
\v 18 مەسیحی خاوەن شکۆ لە هەموو خراپەیەک دەربازم دەکات و ڕزگارم دەکات بۆ شانشینە ئاسمانییەکەی. با هەتاهەتایە مەسیح شکۆدار بێت! ئامین.
\s1 سڵاوی کۆتایی
\p 
\v 19 سڵاو لە پریسکیلا و ئەکیلا و خێزانی ئۆنیسیفۆرۆس بکە.
\b
\p 
\v 20 ئەراستۆس لە کۆرنسۆس مایەوە، بەڵام تروفیمۆسم بە نەخۆشی لە میلیتۆس بەجێهێشت.
\v 21 کۆشش بکە پێش زستان بێی.
\b
\p یۆبۆلۆس و پودیس و لینۆس و کڵاودیا و هەموو خوشکان و برایان سڵاوت لێدەکەن.
\b
\p 
\v 22 مەسیحی خاوەن شکۆ لەگەڵ ڕۆحت بێت. با نیعمەتتان لەگەڵ بێت.
