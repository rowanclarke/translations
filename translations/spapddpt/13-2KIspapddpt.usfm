\v 14 Llevó en \w cautiverio|strong="H1473"\w* \w a|strong="H3068"\w* \w toda|strong="H3605"\w* Jerusalén, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* gobernantes y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*: 10.000 \w cautivos|strong="H1473"\w* y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* artesanos y herreros. \w No|strong="H3808"\w* \w quedaron|strong="H7604"\w* \w sino|strong="H2108"\w* \w los|strong="H3605"\w* \w más|strong="H3808"\w* pobres \w de|strong="H5971"\w* \w la|strong="H3605"\w* tierra.
\p 
\v 15 También llevó cautivo \w a|strong="H3068"\w* Babilonia \w a|strong="H3068"\w* Joaquín, la madre del \w rey|strong="H4428"\w*, las mujeres del \w rey|strong="H4428"\w*, sus funcionarios y los nobles del país. Los llevó \w cautivos|strong="H1473"\w* de Jerusalén \w a|strong="H3068"\w* Babilonia.
\v 16 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* de Babilonia llevó \w cautivos|strong="H1473"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* 7.000 \w hombres|strong="H1368"\w* de \w guerra|strong="H4421"\w*, \w a|strong="H3068"\w* \w los|strong="H3605"\w* artesanos y herreros, \w que|strong="H7651"\w* fueron 1.000, y \w todos|strong="H3605"\w* \w valientes|strong="H1368"\w* \w guerreros|strong="H6213"\w*.
\v 17 El \w rey|strong="H4428"\w* \w de|strong="H8478"\w* Babilonia colocó \w a|strong="H3068"\w* Matanías, \w tío|strong="H1730"\w* \w de|strong="H8478"\w* Joaquín, \w como|strong="H8478"\w* \w rey|strong="H4428"\w* \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* Joaquín y le cambió el \w nombre|strong="H8034"\w* \w por|strong="H8478"\w* Sedequías.
\s1 Reinado de Sedequías en Judá
\p 
\v 18 Cuando Sedequías comenzó \w a|strong="H3068"\w* reinar tenía 21 \w años|strong="H8141"\w*, y \w reinó|strong="H4427"\w* 11 \w años|strong="H8141"\w* en Jerusalén. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* su madre fue \w Hamutal|strong="H2537"\w*, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* \w Jeremías|strong="H3414"\w* \w de|strong="H1121"\w* \w Libna|strong="H3841"\w*.
\v 19 \w Hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*, conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* \w hizo|strong="H6213"\w* \w Joacim|strong="H3079"\w*,
\v 20 \w porque|strong="H3588"\w* Sedequías \w se|strong="H1961"\w* rebeló \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia \w por|strong="H5921"\w* \w causa|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* ira \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w tenía|strong="H1961"\w* \w contra|strong="H5921"\w* Jerusalén \w y|strong="H3588"\w* \w Judá|strong="H3063"\w* \w para|strong="H5704"\w* echarlas \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w Presencia|strong="H6440"\w*.
\c 25
\s1 Segunda deportación
\p 
\v 1 \w El|strong="H1931"\w* \w décimo|strong="H6224"\w* día \w del|strong="H5921"\w* \w décimo|strong="H6224"\w* \w mes|strong="H2320"\w* \w del|strong="H5921"\w* \w año|strong="H8141"\w* \w noveno|strong="H8671"\w* \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w reinado|strong="H4427"\w*, \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, llegó \w con|strong="H5921"\w* \w todo|strong="H3605"\w* \w su|strong="H1931"\w* \w ejército|strong="H2428"\w* \w contra|strong="H5921"\w* Jerusalén, acampó \w contra|strong="H5921"\w* \w ella|strong="H1931"\w*, \w y|strong="H5921"\w* construyó una empalizada \w alrededor|strong="H5439"\w* \w de|strong="H5921"\w* \w ella|strong="H1931"\w*.
\v 2 Así \w que|strong="H5704"\w* la \w ciudad|strong="H5892"\w* estuvo sitiada \w hasta|strong="H5704"\w* el \w año|strong="H8141"\w* 11 del \w rey|strong="H4428"\w* Sedequías.
\p 
\v 3 En el noveno día del \w mes|strong="H2320"\w* cuarto, el \w hambre|strong="H7458"\w* prevalecía en la \w ciudad|strong="H5892"\w*, y \w no|strong="H3808"\w* \w había|strong="H1961"\w* \w pan|strong="H3899"\w* \w para|strong="H1961"\w* el \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* la tierra.
\v 4 Entonces \w se|strong="H5921"\w* abrió una brecha \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w muro|strong="H2346"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w mientras|strong="H3605"\w* \w los|strong="H5921"\w* \w caldeos|strong="H3778"\w* estaban \w alrededor|strong="H5439"\w* \w de|strong="H5921"\w* \w ella|strong="H5921"\w*. Huyeron \w de|strong="H5921"\w* \w noche|strong="H3915"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* hombres \w de|strong="H5921"\w* \w guerra|strong="H4421"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w que|strong="H5921"\w* estaba \w entre|strong="H5921"\w* \w los|strong="H5921"\w* dos \w muros|strong="H2346"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w huerto|strong="H1588"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*, \w y|strong="H5921"\w* salieron \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w del|strong="H5921"\w* Arabá.
\v 5 Pero \w el|strong="H5921"\w* \w ejército|strong="H2428"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w caldeos|strong="H3778"\w* \w persiguió|strong="H7291"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w alcanzó|strong="H5381"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* llanura \w de|strong="H5921"\w* \w Jericó|strong="H3405"\w*. \w Todo|strong="H3605"\w* su \w ejército|strong="H2428"\w* fue dispersado \w de|strong="H5921"\w* su lado.
\p 
\v 6 Entonces capturaron \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, lo llevaron ante el \w rey|strong="H4428"\w* de Babilonia en Ribla, y éste dictó \w sentencia|strong="H4941"\w* contra él.
\v 7 Degollaron \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Sedequías en su presencia. Luego \w le|strong="H5869"\w* \w sacaron|strong="H5786"\w* \w los|strong="H1121"\w* \w ojos|strong="H5869"\w* \w a|strong="H3068"\w* Sedequías, lo ataron con cadenas \w de|strong="H1121"\w* bronce y lo llevaron \w a|strong="H3068"\w* Babilonia.
\p 
\v 8 \w A|strong="H3068"\w* \w los|strong="H1931"\w* \w siete|strong="H7651"\w* días del \w mes|strong="H2320"\w* \w quinto|strong="H2549"\w* del \w año|strong="H8141"\w* 19 de \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* de Babilonia, llegó \w a|strong="H3068"\w* Jerusalén \w Nabuzaradán|strong="H5018"\w*, \w el|strong="H1931"\w* \w capitán|strong="H7227"\w* de \w la|strong="H1931"\w* guardia, esclavo del \w rey|strong="H4428"\w* de Babilonia,
\v 9 y \w quemó|strong="H8313"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \nd \w Yavé|strong="H3068"\w*\nd*, \w el|strong="H3605"\w* palacio \w real|strong="H4428"\w*, y \w todas|strong="H3605"\w* las \w casas|strong="H1004"\w* de Jerusalén. También \w quemó|strong="H8313"\w* \w todas|strong="H3605"\w* las \w casas|strong="H1004"\w* de \w los|strong="H3605"\w* nobles.
\v 10 \w El|strong="H3605"\w* \w ejército|strong="H2428"\w* de \w los|strong="H3605"\w* \w caldeos|strong="H3778"\w* \w que|strong="H3605"\w* estaba con \w el|strong="H3605"\w* \w capitán|strong="H7227"\w* de \w la|strong="H3605"\w* guardia \w derribó|strong="H5422"\w* \w los|strong="H3605"\w* \w muros|strong="H2346"\w* de \w alrededor|strong="H5439"\w* de Jerusalén.
\v 11 \w Al|strong="H5921"\w* \w resto|strong="H3499"\w* \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5921"\w* quedaba \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w los|strong="H5921"\w* desertores \w que|strong="H5921"\w* \w se|strong="H5921"\w* pasaron \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* quedaban \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w gente|strong="H5971"\w* común, \w Nabuzaradán|strong="H5018"\w*, \w capitán|strong="H7227"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* guardia \w los|strong="H5921"\w* llevó \w cautivos|strong="H1540"\w*.
\v 12 Pero el \w capitán|strong="H7227"\w* de la guardia \w dejó|strong="H7604"\w* algunos de los \w más|strong="H7227"\w* pobres de la tierra como viñadores y labradores.
\p 
\v 13 Los \w caldeos|strong="H3778"\w* destrozaron las \w columnas|strong="H5982"\w* de bronce que estaban en la \w Casa|strong="H1004"\w* de \nd \w Yavé|strong="H3068"\w*\nd*, así como las \w basas|strong="H4350"\w* y el \w mar|strong="H3220"\w* de bronce que \w estaba|strong="H1004"\w* en la \w Casa|strong="H1004"\w* de \nd \w Yavé|strong="H3068"\w*\nd*, y \w llevaron|strong="H5375"\w* el bronce \w a|strong="H3068"\w* Babilonia.
\v 14 También \w tomaron|strong="H3947"\w* \w los|strong="H3605"\w* \w calderos|strong="H5518"\w*, las paletas, las despabiladeras, las \w cucharas|strong="H3709"\w* y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios de bronce con \w los|strong="H3605"\w* cuales \w ministraban|strong="H8334"\w*.
\p 
\v 15 El \w capitán|strong="H7227"\w* de la guardia se \w llevó|strong="H3947"\w* los \w incensarios|strong="H4289"\w*, los \w tazones|strong="H4219"\w*, todo lo que era de \w oro|strong="H2091"\w*, todo lo que era de \w plata|strong="H3701"\w*,
\v 16 las \w dos|strong="H8147"\w* \w columnas|strong="H5982"\w*, \w el|strong="H3605"\w* \w mar|strong="H3220"\w* y las \w basas|strong="H4350"\w* \w que|strong="H3808"\w* \w hizo|strong="H6213"\w* \w Salomón|strong="H8010"\w* \w para|strong="H4948"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \nd \w Yavé|strong="H3068"\w*\nd*. \w No|strong="H3808"\w* \w fue|strong="H1961"\w* posible calcular \w el|strong="H3605"\w* \w peso|strong="H4948"\w* del bronce de \w todos|strong="H3605"\w* esos utensilios.
\v 17 \w La|strong="H5921"\w* \w altura|strong="H6967"\w* \w de|strong="H5921"\w* \w cada|strong="H3605"\w* \w columna|strong="H5982"\w* tenía 18,1 metros. \w Sobre|strong="H5921"\w* \w ella|strong="H5921"\w* \w había|strong="H3805"\w* un \w capitel|strong="H3805"\w* \w de|strong="H5921"\w* bronce, cuya \w altura|strong="H6967"\w* tenía 1,35 metros, \w con|strong="H5921"\w* obra \w de|strong="H5921"\w* malla \w y|strong="H5921"\w* \w granadas|strong="H7416"\w* talladas \w alrededor|strong="H5439"\w* \w del|strong="H5921"\w* \w capitel|strong="H3805"\w*, \w todo|strong="H3605"\w* \w de|strong="H5921"\w* bronce. \w La|strong="H5921"\w* \w segunda|strong="H8145"\w* \w columna|strong="H5982"\w* era igual \w a|strong="H3068"\w* \w ésta|strong="H5921"\w*, \w con|strong="H5921"\w* su obra \w de|strong="H5921"\w* malla.
\p 
