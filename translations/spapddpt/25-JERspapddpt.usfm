\v 23 \wj \+w No|strong="H3808"\+w* les \+w quedará|strong="H1961"\+w* remanente, \+w porque|strong="H3588"\+w* traeré aflicción \+w sobre|strong="H1961"\+w* \+w los|strong="H1961"\+w* hombres \+w de|strong="H3588"\+w* Anatot \+w el|strong="H3588"\+w* \+w año|strong="H8141"\+w* \+w de|strong="H3588"\+w* \+w su|strong="H3588"\+w* \+w castigo|strong="H7451"\+w*.\wj*   
\c 12  
\s1 Queja de Jeremías ante \nd Yavé\nd*  
\p
\v 1 \w Justo|strong="H6662"\w* eres Tú, oh \nd \+w Yavé|strong="H3068"\+w*\nd*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w contienda|strong="H7378"\w* contigo. Sin embargo, defenderé mi \w causa|strong="H7378"\w* ante Ti: ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* prospera \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w de|strong="H3588"\w* \w los|strong="H3605"\w* perversos, \w y|strong="H3588"\w* \w los|strong="H3605"\w* traidores \w viven|strong="H7563"\w* \w en|strong="H3588"\w* paz?  
\v 2 Los \w plantas|strong="H5193"\w* \w y|strong="H1571"\w* echan raíces. Crecen \w y|strong="H1571"\w* dan \w fruto|strong="H6529"\w*. \w Cercano|strong="H7138"\w* \w estás|strong="H6213"\w* de sus \w bocas|strong="H6310"\w*, pero \w lejos|strong="H7350"\w* de su pensamiento.  
\v 3 Pero Tú, oh \nd \+w Yavé|strong="H3068"\+w*\nd*, Tú me \w conoces|strong="H3045"\w*. Me miras y pruebas mi \w corazón|strong="H3820"\w*, cómo es hacia Ti. Sepáralos como \w a|strong="H3068"\w* \w ovejas|strong="H6629"\w* para el matadero. Apártalos para el \w día|strong="H3117"\w* de la matanza.  
\v 4 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H3588"\w* lamenta \w la|strong="H3588"\w* tierra \w y|strong="H3588"\w* \w se|strong="H3808"\w* marchita \w la|strong="H3588"\w* \w hierba|strong="H6212"\w* \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w campo|strong="H7704"\w*? \w Por|strong="H3588"\w* \w la|strong="H3588"\w* perversidad \w de|strong="H3588"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w habitan|strong="H3427"\w* \w perecieron|strong="H3588"\w* \w los|strong="H3427"\w* animales \w y|strong="H3588"\w* las \w aves|strong="H5775"\w*. \w Porque|strong="H3588"\w* dicen: \w Él|strong="H3588"\w* \w no|strong="H3808"\w* \w verá|strong="H7200"\w* nuestro último fin.   
\p
\v 5 \add Respuesta de\add* \nd \+w Yavé|strong="H3068"\+w*\nd*: \wj \+w Si|strong="H3588"\+w* \+w te|strong="H3588"\+w* cansaste al correr \+w con|strong="H3588"\+w* \+w la|strong="H3588"\+w* infantería, ¿\+w cómo|strong="H3588"\+w* puedes competir \+w con|strong="H3588"\+w* \+w la|strong="H3588"\+w* caballería? \+w Si|strong="H3588"\+w* caes \+w en|strong="H3588"\+w* una tierra \+w de|strong="H3588"\+w* \+w paz|strong="H7965"\+w*, \+w entonces|strong="H3588"\+w* ¿\+w qué|strong="H3588"\+w* \+w harás|strong="H6213"\+w* \+w en|strong="H3588"\+w* \+w la|strong="H3588"\+w* selva del \+w Jordán|strong="H3383"\+w*?\wj*  
\v 6 \wj \+w Porque|strong="H3588"\+w* \+w aun|strong="H1571"\+w* tus hermanos \+w y|strong="H1571"\+w* \+w la|strong="H1571"\+w* \+w casa|strong="H1004"\+w* \+w de|strong="H3588"\+w* tu padre \+w te|strong="H3588"\+w* traicionaron. \+w Aun|strong="H1571"\+w* \+w ellos|strong="H1992"\+w* gritan \+w con|strong="H3588"\+w* voz fuerte detrás \+w de|strong="H3588"\+w* ti. \+w No|strong="H3588"\+w* \+w les|strong="H1992"\+w* creas \+w aunque|strong="H3588"\+w* \+w te|strong="H3588"\+w* digan \+w cosas|strong="H1992"\+w* agradables.\wj*   
\p
\v 7 \wj Abandoné \+w mi|strong="H5315"\+w* \+w casa|strong="H1004"\+w*. \+w Desamparé|strong="H5800"\+w* \+w mi|strong="H5315"\+w* \+w heredad|strong="H5159"\+w*. \+w Entregué|strong="H5414"\+w* en \+w manos|strong="H3709"\+w* \+w de|strong="H5414"\+w* \+w mis|strong="H5414"\+w* enemigos lo que \+w mi|strong="H5315"\+w* \+w alma|strong="H5315"\+w* ama.\wj*  
