\id 3JN
\ide UTF-8
\h 3 IOANE
\toc1 IOANE ENA URIURI HEHAIONANA
\toc2 3 Ioane
\toc3 3Io.
\mt1 IOANE ENA URIURI HEHAIONANA
\c 1
\s1 Ehana ena lautoi, eo abi‐ponori, abi‐lolo, itasipoina eo ribahesanapuena.
\p 
\v 1 Am taubaguna wa, Gaia enana ea uriuri, ia se gadosisiei wa, eau hinage ea gadosisiei, mamohoina boeana eai.
\p 
\v 2 Egu nuanuai tauna e, uura eai ea aiboda bena ginauri gamagaridi arim eai se lau lolo, eo bena taum se adidiri gonogonoana doha earuam i adidiri.
\v 3 Huia ne eda tataoyao wa se laoma arigu eai se wasawasaem oa mamohoina eai u laulau, ea kode ariariri.
\v 4 Nige egu kode esau i lai doha ina kode ta, ena wasa ea ataiei nanatuguyao mamohoina se laulauwatai.
\p 
\v 5 Egu nuanuai e, paisoa saesaena u ginaginauri ena eda tataoyao u heayaiedi, eo headi u hekaudi taiede u saguidi mo.
\v 6-7 Isi ede em gadosisi se wasawasaei ekalesia matadi eai. Em abi se lolo edi adau eai u healatudi, doha Eaubada ena heaheari paisoa se abi, heasisina.
\v 8 I lolo tatao doha ina ta saguidi, paana heledi tatao paisoa ita, mamohoina boeana eai.
\p 
\v 9 Doha ina ea uuri ekalesia aridi eai; na Diatorepe, ia i henua iabom i ribatausaeuioi, egu tanutanuaga eai nige i awaabiegu.
\v 10 Sora ena ea laowa abo ena paipaisoa ea hemasaraha, ribariba baaea arinai i alaliuliuaigu. Temeta nige anasiga, eda tataoyao headi taba nige i oiyamidi eo headi se henua bena se hailobaidi i guduguduidi eo ekalesia boeadi eai i aiduiedi.
\p 
\v 11 Egu nuanuai e, tabu baaea u heaheawatotoei, na lolo mo. Esau lolo i ginauri, ia Eaubada enana; esau baaea i ginauri, ia Eaubada nige i ita.
\v 12 Demeterio iilana tatao gamagaridi se itayao, ena abilolo se ribaribaei mamohoina eai ena laulau se masaraha; eau hinage ia ea ribahemasaraha, na omi au nuatuiyao egu riba ede riba mamohoi.
\p 
\v 13 Ginauri se gamagari ariri bena ea uridiwa, na nige ea henua \tl ink\tl* eo \tl pen\tl* eai ea uridi;
\v 14 egu sunusunuma ede nige baeaona abo ea itam, eau matam eai oa matagu eai, abo ta oiriba.
\p 
\v 15 Loni bena arim eai. Ehamyao se lautoiem. Ehaguyao ea lautoiedi, esau esau, esadi u ataidi. Amen. 
