\id PSA  
\h Halelu 
\toc1 Halelu 
\toc2 Halelu 
\toc3 Halelu 
\mt1 Halelu  
\c 1  
\s1 KA BUKE  
\q1
\v 1 POMAIKAI ke kanaka i hele ole ma ke aoia o ka poe aia. I ku ole hoi ma ka aoao o ka poe hewa, I noho ole hoi ma ka noho o ka poe haakei.   
\q1
\v 2 Aka, ma ke kanawai o Iehova kona olioli; A ma kona kanawai oia i manao ai i ke ao a me ka po.   
\q1
\v 3 E like no ia me ka laau i kanuia ma na kahawai, I hoohua mai i kona hua i kona manawa; A o kona lau hoi aole e mae; A o kona mea e hana'i e pono ana no ia.   
\b  
\q1
\v 4 Aole hoi e like me neia ka poe aia; Aka, ua like ia me ka opala i puehu i ka makani.   
\q1
\v 5 Nolaila, aole e ku ana ka poe aia ma ka hookolokolo ana, Aole hoi ka poe hewa iloko o ka ka poe pono anaina.   
\q1
\v 6 No ka mea, ua ike mai la o Iehova i ka aoao o ka poe maikai; Aka hoi, o ka aoao o ka poe hewa, e make ana no ia.   
\c 2  
\b  
\q1
\v 1 NO ke aha la e kupikipikio ai ko ka aina e? A e noonoo ai ka poe kanaka i ka mea lapuwale?   
\q1
\v 2 Ua ku e aku na'lii o ka honua, Ua ohumu pu aku no hoi na luna, Ia Iehova, a i kona Mea i poniia,   
\q1
\v 3 E moku aku kakou i ka laua mau mea paa, A e hoolei aku hoi mai o kakou aku nei i ka laua mau kaula.   
\b  
\q1
\v 4 O ka Mea e noho ana ma ka lani, e aka mai no ia: A e hoomahua mai no hoi o ka Haku ia lakou.   
\q1
\v 5 Alaila e olelo mai oia ia lakou i kona inaina, A e hoomakaua mai hoi ia lakou i kona huhu nui.   
\q1
\v 6 Ua poni ae nei au i ka'u Alii maluna o Ziona, Maluna iho o ko'u mauna hoano.   
\b  
\q1
\v 7 E hai aku au i ke kauoha: Ua olelo mai la o Iehova ia'u, O oe no ka'u Keiki; I keia la no, ua hoohanau aku wau ia oe.   
\q1
\v 8 E noi mai oe ia'u, a e haawi aku au ia oe I na lahuikanaka i hooilina nou, A i waiwai hoi nou na welelau o ka honua.   
\q1
\v 9 E uhai oe ia lakou me ke kookoo hao: E ulupa hoi oe ia lakou me he ipulepo la.   
\b  
\q1
\v 10 No ia hoi, e hoonaauao oukou, e na alii; E aoia'ku no hoi oukou, e na lunakanawai o ka honua.   
\q1
\v 11 E malama ia Iehova me ka weliweli, E hauoli hoi oukou me ka haalulu.   
\q1
\v 12 E honi aku i ke Keiki, o huhu mai ia, O make hoi oukou ia aoao, ke hoa iki ia mai kona inaina. Pomaikai wale ka poe a pau i hilinai aku ia ia.   
\c 3  
\b  
\q1
\v 1 E IEHOVA, ua mahuahua ae nei ko'u poe enemi; Ua nui no hoi ka poe i ku e mai ia'u.   
\q1
\v 2 Lehulehu na mea i olelo mai no ko'u uhane, Aole ona kokua iloko o ke Akua. Sila.   
\b  
\q1
\v 3 Aka, o oe, e Iehova, ka paku no'u; O ko'u nani, ka mea nana kuu poo e hapai.   
\q1
\v 4 Ua kahea aku wau ia Iehova me ka'u leo; Ua hoolohe mai no ia ia'u ma kona mauna hoano. Sila.   
\q1
\v 5 Ua moe iho la au ilalo a hiamoe; Ua ala ae la hoi, no ko Iehova malama ana mai ia'u.   
\q1
\v 6 Aole au e makau aku i na umi tausani o kanaka, O ka poe e ku e mai ia'u a puni.   
\b  
\q1
\v 7 E ku mai oe, e Iehova, e hoola mai ia'u, e kuu Akua; Ua pepehi oe i ko'u poe enemi a pau ma ke a; Ua uhai oe i na niho o ka poe aia.   
\q1
\v 8 No Iehova ke ola; O kou hoomaikai ana maluna iho o kou poe ohua. Sila.   
\c 4  
\b  
\q1
\v 1 I KA'U uolo ana'ku e lohe mai ia'u, e ke Akua o'u e pono ai: Ua hoakea mai oe ia'u i ko'u popilikia; E aloha mai oe ia'u, e hoolohe mai hoi i ka'u pule.   
\b  
\q1
\v 2 E na keiki a kanaka, pehea la ka loihi O ko oukou hoolilo ana i ko'u nani i me a hilahila? No ke aha la e aloha ai oukou i ka lapuwale, A imi hoi i wahahee? Sila.   
\q1
\v 3 E ike hoi oukou na hoana e o Iehova i ka mea haipulo nona; E lohe mai no o Iehova i ko'u kahea ana'ku ia ia.   
\b  
\q1
\v 4 E haalulu oukou, mai hana hewa; E kukakuka me ko oukou naau iho, Ma ko oukou wahi moe e noho malie ai. Sila.   
\q1
\v 5 E kaumaha aku oukou i ka mohai pono, E lelepau ko oukou manao ia Iehova.   
\b  
\q1
\v 6 He nui no ka poe i olelo mai, Owai ka mea o hoike mai i ka pono ia kakou? E Iehova, e hoomalamalama mai kou maka ia makou.   
\q1
\v 7 Ua hookomo mai oe i ka olioli iloko o ko'u naau, A oi aku ko'u i ko lakou i ka mahuahua ana'e o ka palaoa a me ka waina.   
\q1
\v 8 E moe au ilalo me ka maluhia, a hiamoe: No ka mea, o oe wale no, e Iehova, ka i hoomalu mai i ko'u noho ana.   
\c 5  
\b  
\q1
\v 1 E IEHOVA, e hoolohe mai kou pepeiao i ka'u olelo, E manao mai hoi oe i ka'u ulono ana.   
\q1
\v 2 E hoolohe i ka leo o kuu hea ana'ku, e kuu Alii, a me kuu Akua; No ka mea, e pule aku no au ia oe.   
\q1
\v 3 E Iehova, i ke kakahiaka e hoolohe mai ai no oe i ko'u leo, I ke kakahiaka au e hoopololei ai i ko'u manao ia oe, a e nana aku ai iluna.   
\b  
\q1
\v 4 No ka mea, aole oe he Akua olioli i ka hewa; Aole hoi e noho pu ka ino me oe.   
\q1
\v 5 Aole hoi e ku ka poe lalau imua o kou alo; Ua inaina mai no oe i ka poe hana ino a pau.   
\q1
\v 6 E luku mai ana no oe i ka poe i olelo i ka mea wahahee; E hoowahawaha mai ana o Iehova i ke kanaka koko a me ka hoopunipuni.   
\q1
\v 7 Aka, owau nei la, e komo au i kou hale i ka nui o kou lokomaikai; Me ka makau ia oe e hoomana aku ai au ma kou luakini hoano.   
\b  
\q1
\v 8 E Iehova. e alakai oe ia'u ma kou pono no ko'u poe enemi; E hoopololei hoi i kou alanui imua o ko'u alo.   
\q1
\v 9 No ka mea, aole he oiaio iloko o ko lakou waha: He hewa io ko loko o lakou; A o ko lakou kaniai he halelua hamama; Ua malimali mai lakou me ko lakou alelo.   
\q1
\v 10 E hoohewa mai oe ia lakou, e ke Akua; E haule lakou i ko lakou manao iho: E kipaku hoi oe ia lakou i ka nui o ko lakou hewa: No ka mea, ua kipi wale aku lakou ia oe.   
\b  
\q1
\v 11 E hauoli ka poe a pau i hilinai aku ia oe; E hoolioli mau no hoi no kou malama ana mai ia lakou; A e olioli io hoi ia oe ka poe i makemake i kou inoa.   
\q1
\v 12 No ka mea, e hoomaikai ana no oe i ka mea pono, e Iehova; Me ke aloha e hoopuni mai ai oe ia ia me he palekaua la.   
\c 6  
\b  
\q1
\v 1 E IEHOVA, mai hoohewa mai oe ia'u me kou huhu; Mai hahau mai oe ia'u, me kou inaina nui.   
\q1
\v 2 E aloha mai oe ia'u, e Iehova, no ka mea, ua nawaliwali au; E Iehova, e lapaau mai oe ia'u, no ka mea, ua haalulu ko'u mau iwi.   
\q1
\v 3 Ua pioloke loa ko'u uhane, Aka o oe, e Iehova, pehea la hoi ka loihi?   
\b  
\q1
\v 4 E hoi mai, e Iehova, e hoopakele mai i ko'u uhane: E hoola mai oe ia'u no ka pono o kou aloha.   
\q1
\v 5 No ka mea, maloko o ka make aohe manao ia oe: Maloko o ka malu o ka make, owai la ka mea e hoolea aku ia oe?   
\b  
\q1
\v 6 Ua luhi au i ko'u auwe ana; I ka po a pau i hoolana ai au i ko'u moena: Ua hoopulu au i ko'u wahi moe me ko'u waimaka.   
\q1
\v 7 Ua pau e kuu maka no ko'u ehaeha; Ua kahiko e no ia no ko'u poe enemi a pau.   
\b  
\q1
\v 8 E hele aku mai o'u aku nei, e ka poe hana ino a pau; No ka mea, ua lohe mai o Iehova i ka leo o ko'u uwe ana.   
\q1
\v 9 Ua lohe mai o Iehova i ko'u nonoi ana; E ae mai ana no o Iehova i ka'u pule.   
\q1
\v 10 E pioloke ko'u poe enemi a pau me ka haalulu loa; E hoi no lakou me ka hilahila koke.   
\c 7  
\b  
\q1
\v 1 E IEHOVA e ko'u Akua, ke hilinai aku nei au ia oe: E hoopakele oe ia'u i ka poe a pau nana au i hoomaau mai; E hoola mai hoi oe ia'u;   
\q1
\v 2 O haehae mai oia i ko'u uhane me he liona la, A mokumoku au, aohe mea e ola'i.   
\b  
\q1
\v 3 E Iehova e ko'u Akua, iua i hana au i keia; Ina he hewa iloko o ko'u mau lima;   
\q1
\v 4 Ina i hoihoi aku au i ka hewa i ko'u hoaaloha; A i lawe wale i ka ka mea i huhu hala ole mai ia'u;   
\q1
\v 5 E pono e alualu mai ka enemi i ko'u uhane, a e hopu mai ia'u; A e hehi mai hoi ia i ko'u ola ilalo i ka honua, A e waiho iho hoi i ko'u uani malalo o ka lepo. Sila.   
\b  
\q1
\v 6 E ku oe iluna, e Iehova, i kou huhu, E hookiekie ae ia oe iho no ka hookano o ko'u poe enemi: E ala'e oe no'u i ka hookolokolo au i olelo mai ai.   
\q1
\v 7 Oia, e hoopuni ai ke anainakanaka ia oe: Nolaila e hoi oe i kahi kiekie no lakou.   
\q1
\v 8 E hookolokolo o Iehova i na kanaka; E hoopono mai oe ia'u, e Iehova, E like me ko'u pono, a me ko'u oiaio iloko o'u.   
\q1
\v 9 Ke pule nei au e oki ka hana hewa o ka poe hewa; Aka, e hookupaa oe i ka poe pono; No ka mea, na ke Akua pono i hoao na naau a me na puupaa.   
\q1
\v 10 O ko'u paku, aia no i ke Akua, Nana i hoola ka poe naau kupono.   
\q1
\v 11 Ua malama mai ke Akua i ka poe pono, Ua huhu mai ke Akua i ka hewa i na la a pau.   
\b  
\q1
\v 12 Ina i huli ole ia, e hookala no ia i kana pahikaua; Ua lena oia i kana kakaka, ua hooponopono no ia.   
\q1
\v 13 Ua hoomakaukau no hoi ia i na mea e make ai nona; Ke pana iho la oia i na pua ahi.   
\q1
\v 14 Aia hoi, ua nahunahu ia i ka hewa, Ua hookauhua no ia i ka ino, A ua hanau mai no hoi ia i ka wahahee.   
\q1
\v 15 Ua eli iho la oia i ka lua a poopoo, Ua haule iho la no ia ilalo o ka auwaha ana i hana'i.   
\q1
\v 16 E huli hou iho kana hana hewa ana maluna ona iho, A e haule iho hoi kona kolohe ana maluna o kona poo iho.   
\b  
\q1
\v 17 E hoomaikai aku au ia Iehova no kona pono, E hoolea aku au i ka inoa o Iehova ke Kiekie loa.   
\c 8  
\b  
\q1
\v 1 E IEHOVA, e ko makou Haku, Kai ka hemolele o kou inoa ma ka honua a pau! Ua hohola oe i kou nani maluna o na lani.   
\q1
\v 2 Noloko ae o ka waha o na keiki hou a me na mea omo, I hoomakaukau ai oe i ka hoolea no kou poe enemi, I pilipu ia oe ka enemi, a me ka mea hoomaau.   
\b  
\q1
\v 3 I ko'u manao ana'ku i kou mau lani, ka hana o kou mau lima, I ka mahina a me na hoku au i hooponopono mai ai;   
\q1
\v 4 Heaha ke kanaka i manao mai ai oe ia ia? A o ke keiki a ke kanaka hoi i ike mai ai oe ia ia?   
\q1
\v 5 Ua hana iho oe ia ia malalo iho o ka poe anela, Ua kau mai oe ia ia i ka nani a me ka mahalo i lei nona;   
\q1
\v 6 Ua hoolilo oe ia ia i haku no na mea a kou mau lima i hana'i; Nau no i waiho na mea a pau malalo ae o kona mau wawae:   
\q1
\v 7 O na hipa, a me na bipi a pau, Oia, me na holoholona o ke kula;   
\q1
\v 8 O na manu o ka lewa, a me na ia o ke kai, A me na mea a pau e holo ana ma na ala o ka moana.   
\b  
\q1
\v 9 E IEHOVA, e ko makou Haku, Kai ka hemolele o kou inoa ma ka honua a pau!   
\c 9  
\b  
\q1
\v 1 E HOONANI aku au ia oe, e Iehova, me ko'u naau a pau; E heluhelu aku au i kau mau hana kupaianaha a pau.   
\q1
\v 2 E olioli no au, a e hauoli no hoi ia oe: E hoolea aku hoi au i kou inoa, e ke Mea Kiekie loa.   
\b  
\q1
\v 3 I ka hoi hope ana o ko'u poe enemi, E haule no lakou a make ma kou alo.   
\q1
\v 4 Ua hoopono mai oe ia'u, ua hooko mai oe i ko'u, Ua noho oe ma ka nohoalii e hoopai pololei ana.   
\q1
\v 5 Ua papa oe i na lahuikanaka e; Ua luku iho no hoi oe i ka poe hewa; Ua hokai mau loa oe i ko lakou inoa i ka wa pau ole.   
\q1
\v 6 A o ka enemi, ua pau ia i ka make mau loa; Ua pau ua kulanakauhale ia oe i ka lukuia; Ua lilo hoi ko lakou kaulana i ka make.   
\b  
\q1
\v 7 Aka, o mau loa ana no o Iehova: Ua hoomakaukau oia i kona nohoalii no ka hookolokolo ana.   
\q1
\v 8 E hookolokolo mai no ia i ko ke ao nei ma ka pono; E hoopai mai no ia i kanaka me ka ewaewa ole.   
\q1
\v 9 E lilo ana no o Iehova i puuhonua no ka poe i hooluhihewaia, I mea e pakele ai i ka manawa popilikia.   
\q1
\v 10 O ka poe i ike i kou inoa e hilinai aku lakou ia oe; O ka poe i imi aku ia oe, aole oe, e Iehova, i haalele ia lakou.   
\b  
\q1
\v 11 E hoolea aku ia Iehova i ka mea e noho ana ma Ziona: E hai aku iwaena o na kanaka i kana mau hana.   
\q1
\v 12 A i imi mai oia i ke koko e hoopai mai, E manao mai no ia ia lakou; Aole oia i hoopoina i ka ulono ana a ka poe haahaa.   
\q1
\v 13 E aloha mai oe ia'u, e Iehova; E manao oe i ka hoino ana mai o ka poe inaina mai ia'u, O oe ka mea nana i hoala au mai ka puka mai o ka make;   
\q1
\v 14 I hoike aku au i kou nani a pau, Ma na pukapahale o ke kaikamahine a Ziona; E hauoli no hoi au i kou ola.   
\q1
\v 15 Ua poho ilalo ko na aina e i ka lua a lakou i hana'i, I ka upena a lakou i huna ai i hei ai ko lakou wawae.   
\q1
\v 16 Ua ikea o Iehova, ua hana mai ia i ka pono; Ua punihei ka mea kolohe i ka hana a kona mau lima iho. Hikaiona. Sila.   
\b  
\q1
\v 17 E auhulihia ka poe hewa ilalo i ka malu o ka make, A me na lahuikanaka a pau i hoopoina i ke Akua.   
\q1
\v 18 Aka, aole e hoopoina mau ia mai ka poe i hooluhiia, A o ka manaolana o ka ilihune aole loa ia e hoka.   
\q1
\v 19 E ku ae oe, e Iehova; mai lanakila kanaka; E hookolokoloia mai na lahuikanaka imua o kou alo.   
\q1
\v 20 E hooweliweli mai oe ia lakou, e Iehova: I ike pono ko na aina, he mau kanaka wale no lakou. Sila.   
\c 10  
\b  
\q1
\v 1 NO ke aha la oe e ku ai i kahi loihi aku, e Iehova? A e huna ai ia oe iho i ka manawa popilikia?   
\q1
\v 2 O ka mea hewa, i kona hookano, Ua hoomaau mai oia i ka mea ilihune: E puni lakou i ka manao a lakou i noonoo ai.   
\b  
\q1
\v 3 No ka mea, ua hookelakela ka mea hewa i ka makemake o kona naau, A i ke ko ana, ua hoomaikai, a ua hoowahawaha aku ia Iehova.   
\q1
\v 4 O ka mea hewa, aole ia e pule, no ka haaheo o kona maka; Aole ke Akua i kona manao a pau.   
\b  
\q1
\v 5 Ua hewa mau kona mau aoao; O kau mau oihana, maluna lilo no ia aole ikea ia ia; A o kona mau enemi, ua puhi aku oia ia lakou.   
\q1
\v 6 Ua olelo oia iloko o kona naau, Aole loa au e hoonaueia; Aole au e popilikia ia hanauna aku ia hanauna aku.   
\q1
\v 7 Ua piha kona waha i ke amuamu, ka wahahee, a me ka hoopunipuni; Malalo ae o kona alelo ke kolohe a me ka mea lapuwale.   
\q1
\v 8 Ua noho ia ma kahi hoomakaakiu o na kauhale; A i kahi nalowale i pepehi wale ai ia i ka mea hala ole; Ua haka malu aku kona mau maka i ka mea ilihune.   
\q1
\v 9 Kali malu iho la ia me he liona la iloko o kona lua: Moemoe malu ia e hopu i ka mea ilihune: Ua hoohei no oia ia ia i kona alakai ana ia ia iloko o kana upena.   
\q1
\v 10 Ua kolo iho la ia, ua hoohaahaa ia ia iho, I haule iho ka poe ilihune i kona mea ikaika.   
\q1
\v 11 Ua olelo iho la ia iloko o kona naau, Ua hoopoina ke Akua; Ua huna oia i kona maka, aole loa ia e ike mai.   
\b  
\q1
\v 12 E ku mai oe, e Iehova; E hapai oe i kou lima, e ke Akua; Mai hoopoina mai i ka poe haahaa.   
\q1
\v 13 No ke aha la ka mea ino i hoowahawaha ai i ke Akua? Ua olelo no oia iloko o kona naau, Aole oe e hoopai mai.   
\q1
\v 14 Ua ike mai no oe, ua nana mai i ke kolohe a me ka huhu, I hoopai mai ia mea me kou lima; O ka mea ilihune ua waiho aku oia ia ia iho ia oe; O oe no ka mea nana ka mea makua ole i kokua mai.   
\q1
\v 15 E uhai oe i ka lima o ke kanaka hewa ke kolohe; E hoopai i kona hewa a pau ia i ka nalo ia oe.   
\b  
\q1
\v 16 O Iehova, oia ke Alii mau loa: Ua make aku ko na aina e mailoko aku o kona aina.   
\q1
\v 17 E Iehova, ua lohe oe i ka makemake o ka poe haahaa: E hoomakaukau ana oe i ko lakou naau, E hoolohe mai ana no kou pepeiao;   
\q1
\v 18 E hoopono mai i ka mea makua ole a me ka mea i hooluhihewaia, I hooluhihewa hou ole mai ke kauaka o ka honua.   
\c 11  
\b  
\q1
\v 1 KE hilinai aku nei au ia Iehova; Pehea oukou e i mai ai i ko'u uhane, E lele i ko oukou mauna me he manu la?   
\q1
\v 2 Aia hoi ka poe hewa ke lena la i ka lakou kakaka, Ke hoomakaukau la i ka lakou pua ma ke kaula, E pana malu aku lakou i ka poe naau kupono.   
\q1
\v 3 Ina e hoohioloia na kumu, Heaha la hoi ka ka mea pono e hana'i?   
\b  
\q1
\v 4 Ina no o Iehova iloko o kona luakini hoano; Ina no o ka nohoalii o Iehova maluna o ka lani: Ke nana mai la kona mau maka; Ke hoao mai la kona mau lihilihi i na keiki a kanaka.   
\q1
\v 5 Ke hoao la o Iehova i ka mea pono, Aka, ke inaina la kona Uhane i ka mea hewa, A me ka mea i makemake i ke kolohe.   
\q1
\v 6 Maluna iho o ka poe hewa oia e hooua mai ai i na kaula uila, A me ke ahi, ka luaipele, a me ka ino huhu: Oia ka piha o ko lakou kiaha.   
\q1
\v 7 No ka mea, ke aloha mai la ka Haku pono i ka pono; Ke haliu mai la kona maka i ka mea pololei.   
\c 12  
\b  
\q1
\v 1 E KOKUA mai, e Iehova; no ka mea, ua oki ke kanaka lokomaikai; Ua pau hoi ka poe hoopono iwaena o na keiki a kanaka.   
\q1
\v 2 Ke kamailio nei kekahi i kekahi i ka mea lapuwale, Me na lehelehe malimali a me ka naau lua e olelo nei lakou.   
\q1
\v 3 E oki ana no o Iehova i na lehelehe malimali a pau, A me ke alelo e haanui ana i na mea nui;   
\q1
\v 4 Ka i olelo iho, Me ko kakou alelo e lanakila ai kakou; No kakou no ko kakou mau lehelehe: Owai la ka Haku maluna o kakou?   
\q1
\v 5 No ka luhihewa ana o ka poe ilihune, No ka auwe ana o ka poe kaniuhu, E ku ai au iluna ano, wahi a Iehova, E hoonoho au ia ia i kahi ola, ke puhiia mai ia.   
\b  
\q1
\v 6 O na olelo a Iehova, he mau olelo maemae no ia, Me he kala la i hoaoia i ka umulepo, ehiku ka hoomaemae ana.   
\q1
\v 7 Nau no lakou e malama mai, e Iehova, Nau no lakou e hoola, mai keia hanauna aku a i ka manawa pau ole.   
\q1
\v 8 E hele ana no ka poe hewa i kela aoao a i keia aoao, I ka manawa i hookiekieia'i na kanaka ino loa.   
\c 13  
\b  
\q1
\v 1 PEHEA la ka loihi o kou hoopoina ana mai ia'u, e Iehova? I ka manawa pau ole anei? Pehea la ka loihi o kou hoonalo ana i kou maka ia'u?   
\q1
\v 2 Pehea la hoi ka loihi o ko'u kaukau ana iloko o ko'u uhane, Me ke kaniuhu iloko o ko'u naau i kela la a i keia la? Pehea la hoi ka loihi o ka hookiekie ana o ko'u enemi maluna o'u?   
\b  
\q1
\v 3 E manao mai, e Iehova, e ko'u Akua, e hoolohe mai ia'u, E hoomalamalama i ko'u mau maka, o hiamoe au i ka make;   
\q1
\v 4 O olelo mai paha kuu enemi, Ua lanakila au maluna ona; A hauoli no hoi ka poe i hana ino mai ia'u, ke haalulu au.   
\b  
\q1
\v 5 Aka hoi, ua hilinai aku au i kou aloha; E hauoli no hoi ko'u naau i kou ola.   
\q1
\v 6 E oli aku no au ia Iehova, No kona lokomaikai ana mai nei ia'u.   
\c 14  
\b  
\q1
\v 1 I IHO la ka aia iloko o kona naau, Aohe Akua. Ua pau lakou i ka hewa; Ua hana lakou i na hana ino; Aohe mea nana e hana maikai.   
\q1
\v 2 Ua nana mai la o Iehova mai ka lani mai i na keiki a kanaka, I ike mai i kekahi mea naauao paha i imi i ke Akua.   
\q1
\v 3 Ua pau lakou i ke kapae. Ua pau pu lakou i ka paumaele; Aohe mea nana i hana pono, aole akahi.   
\b  
\q1
\v 4 Aole anei i ike iki ka poe hana hewa a pau? Ka poe i pau ai ko'u poe kanaka i ka aiia, E like me ko lakou ai ana i ka berena, Aole nae i kahea i ka inoa o Iehova.   
\q1
\v 5 Makau iho la lakou me ka weliweli; No ka mea, ina no ke Akua mawaena o ka hanauna pono.   
\q1
\v 6 Ua hoohilahila oukou i ka manao o ka mea ilihune; No ka mea, o Iehova kona puuhonua.   
\b  
\q1
\v 7 Nawai ke ola e haawi mai no ka Iseraela mailoko mai o Ziona? Aia hoihoi mai o Iehova i ke pio ana o kona poe kanaka, E hauoli no o Iakoba, e olioli no hoi o Iseraela.   
\c 15  
\b  
\q1
\v 1 E IEHOVA, owai ka mea o noho iloko o kou halelewa? Owai hoi ka mea e noho ma kou mauna hoano?   
\q1
\v 2 O ka mea i hele ma ka pololei a i hana ma ka pono; A i olelo hoi ma ka oiaio iloko o kona naau:   
\q1
\v 3 Aole i aki me kona alelo, aole hoi i hana hewa i kona hoapili, Aole hoi i lawe i ka mea e hoinoia'i kona hoalauna.   
\q1
\v 4 A imua o kona maka i hoowahawahaia'i ke kanaka ino; Aka, ua mahalo no oia i ka poe e makau ia Iehova; A hoohiki no kona pono iho aole nae i lole hou ae:   
\q1
\v 5 Aole i ho aku i kana moni no ka uku hoopanee; Aole hoi i lawe i ke kipe i hewa'i ka mea pono. O ka mea i hana ia mau mea, aole loa oia e kulanalana.   
\c 16  
\b  
\q1
\v 1 E HOOLA mai oe ia'u, e ke Akua: Ke hilinai aku nei au ia oe.   
\q1
\v 2 E kuu uhane, ua i aku oe ia Iehova, O oe no ko'u Haku; Aole i hiki aku ko'u maikai ia oe;   
\q1
\v 3 Aka, i ka poe haipule ma ka honua, A me ka poe maikai a'u e hauoli nei.   
\q1
\v 4 E hoonuiia'na ka eha o ka poe e hahai i ka mea e; Aole au e mohai aku i ko lakou mohaiinu koko, Aole hoi e hapai i ko lakou inoa i kou mau Iehelehe.   
\b  
\q1
\v 5 O Iehova ka io o ko'u hooilina a me ko'u kiaha; Ke hoomau mai nei oe i ko'u pauku.   
\q1
\v 6 Ua lilo mai na palena ia'u i kahi e mahalo ai; Oiaio, ua ili mai ia'u ka aina maikai.   
\b  
\q1
\v 7 E hoomaikai aku au ia Iehova, nana ka olelo i haawi mai ia'u, Ua ao mai hoi ia'u ko'u mau puupaa i na po.   
\q1
\v 8 Ke waiho mau nei no au ia Iehova imua o ko'u alo: Oia ma ko'u lima akau, nolaila au e kulanalana ole ai.   
\q1
\v 9 Nolaila ko'u naau o hauoli nei, a e olioli nei ko'u nani, Oiaio, e hoomaha hoi ko'u kino me ka manaolana.   
\q1
\v 10 No ka mea, aole oe e haalele i ko'u uhane i ka malu o ka make, Aole hoi oe e waiho iho i kou mea hoano a ike i ka palaho.   
\q1
\v 11 E hoike mai no oe ia'u i ke kuamoo e ola'i; Ina no ma kou alo ka nui wale o ka olioli; Ma kou lima akau ka hauoli mau loa.   
\c 17  
\b  
\q1
\v 1 E HOOLOHE mai i ka pono, e Iehova; E manao mai oe i ka'u ulono ana'ku; E maliu mai hoi kou pepeiao i ka'u pule, Mai loko ae o na lehelehe hookamani ole.   
\q1
\v 2 Mai kou alo pono mai e puka mai ai ka olelo no'u; E nana mai kou mau maka i na mea ewaewa ole.   
\q1
\v 3 Ua hoao mai nei oe i ko'u naau; Ua ike mai nei oe ia'u i ka po; Ua hoao mai nei oe ia'u, aohe e loaa ia oe: Ua paa kuu manao aole e hoohala kuu waha.   
\q1
\v 4 I na hana a kanaka, no ka olelo pono mai a kou mau lehelehe, Ua malama au ia'u iho i na aoao o ka mea e make ai.   
\q1
\v 5 E hookupono mai oe i ko'u hele ana ma kou mau alanui, I ole ai ko'u mou kapuwai e pahee.   
\b  
\q1
\v 6 Ua kahea aku au ia oe, no ka mea, e lohe mai no oe ia'u, e ke Akua; E haliu mai ia'u kou pepeiao, e lono mai i ka'u olelo.   
\q1
\v 7 E hoike mai oe i kou lokomaikai kupaianaha, E ka mea nana ka poe hilinai e hoopakele me kou lima akau i ka poe i ku e mai.   
\q1
\v 8 E malama mai oe ia'u e like me ke kii onohi o ka maka, E huna oe ia'u malalo ae o ka malu o kou mau eheu,   
\q1
\v 9 Mai ke alo mai o ka poe hewa i hooluhi mai ai ia'u, O ko'u poe enemi e make ai i hoopuni mai ia'u.   
\q1
\v 10 Ua puni lakou i ko lakou momona: Ua olelo haaheo lakou me ko lakou waha.   
\q1
\v 11 Ua hoopuni iho nei lakou ia makou i ko makou hele ana, Ua haka ko lakou maka me ke kulou ana ma ka lepo;   
\q1
\v 12 Me he liona pololi la e kuko ana i kana pio. Me he liona opiopio la, e moemoe malu ana ma na wahi anoano.   
\b  
\q1
\v 13 E ku ae, e Iehova, e hoolapuwale ia ia, e kiola oe ia ia ilalo: E hoopakele oe i ko'u uhane i ka mea ino, i kau pahikaua;   
\q1
\v 14 I na kanaka, i ka lima on, e Iehova, I ka poe ma keia ao, i loaa ko lakou waiwai i keia ola ana, Ua hoopihaia mai e oe ko lakou opu me kou waiwai i hunaia: Ua maona ko lakou mau kamalii, A waiho no lakou i ke koena na ka lakou mau keiki hou.   
\q1
\v 15 A owau hoi la, e ike auanei au i kou maka me ka pono; Aia e ala hou au me kou ano, alaila au e maha io ai.   
\c 18  
\b  
\q1
\v 1 E ALOHA aku no au ia oe, e Iehova, e ko'u ikaika.   
\q1
\v 2 O Iehova ko'u pohaku, kuu pakaua, a me ko'u mea e ola'i; O ko'u Akua, ko'u oolea, a'u e hilinai ai; O ko'u paku, o ko'u hao e ola'i, o ko'u halepukaua kiekie.   
\q1
\v 3 E kahea aku au ia Iehova, ia ia ka hoolea, Pela au e hoopakeleia'i i ko'u mau enemi.   
\b  
\q1
\v 4 Ua puni au i ka ehaeha o ka make; Ua hooweliweli mai ia'u na ale o ka poe aia.   
\q1
\v 5 Ua puni au i na kaei o ka malu o ka make; Ua paa au i ko ka make upena.   
\q1
\v 6 I ko u popilikia ana, ua kahea aku au ia Iehova, Ua auwe aku au i ko'u Akua; Ua lohe mai no ia ia'u ma kona luakini, Ua hiki aku kuu ulono imua ona, a i kona mau pepeiao.   
\b  
\q1
\v 7 Alaila nauwe iho la ka honua a me ka haalulu; Nauweuwe iho la ua kumu o na mauna, Ua hoonauweia mai ia no kona inaina.   
\q1
\v 8 Ua pukoa ae la ka uahi mai loko ae o kona mau puka ihu. Mai loko mai o kona waha ke ahi e ai ana; Ua kukuniia ka lanahu e ia.   
\q1
\v 9 Ua hoohaahaa iho la oia i na lani, a iho mai la; Malalo hoi o kona mau wawae ka pouli.   
\q1
\v 10 Ua holo ia ma ke keruba, ua lele no hoi ia: Oiaio, ua lele oia ma na eheu o ka makani.   
\q1
\v 11 Ua hoolilo oia i ka pouli i wahi mehameha nona: O kona halelowa i hoopuni ia ia, a o na wai pouli a me na a eleele o ka lani.   
\q1
\v 12 No ka olinolino imua ona, ua lele ae la kona mau ao eleele, O na hua hekili, a me na lanahu ahi.   
\q1
\v 13 Ua hoohekili mai la o Iehova ma ka lani; Ua hoopuka mai la ka Mea kiekie loa i kona leo: O na hua hekili, a me na lanahu ahi.   
\q1
\v 14 Ua pehi iho la i kana mau pua, e hoopuehu ia lakou; Ua pana iho la i na uwila, a ua auhee lakou ia ia.   
\q1
\v 15 Alaila, ua ikea na kaha o na wai, Ua hoikeia mai na kumu o ka honua, I kau papa ana mai, e Iehova, i ka nou ana hoi o ka hanu o kou mau puka ihu.   
\b  
\q1
\v 16 Ua kii mai la oia mai luna mai, ua lawe ae hoi ia'u, Ua unuhi aku la oia ia'u mai loko o na wai nui.   
\q1
\v 17 Ua hoopakele oia ia'u i ko'u mau enemi ikaika, A me ka poe inaina mai ia'u: No ka mea, ua oi aku ko lakou ikaika i ko'u.   
\q1
\v 18 Ua hoopaa mai lakou ia'u i ko'u la popilikia: Aka, ua lilo mai o Iehova i kokua no'u.   
\q1
\v 19 Ua lawe ae la oia ia'u i kahi akea; Ua hoopakele mai no ia ia'u, no kona makemake ana mai ia'u.   
\b  
\q1
\v 20 Ua uku mai la o Iehova ia'u e like me ko'u pono; Ua hoopai mai no ia ia'u e like me ka maemae o ko'u mau lima.   
\q1
\v 21 No ka mea, ua malama aku au i na aoao o Iehova, Aole hoi au i hele hewa aku mai ko'u Akua aku.   
\q1
\v 22 Mamua hoi o ko'u alo kana mau olelo hoopono a pau; Aole hoi au e pale aku i kana mau kauoha.   
\q1
\v 23 Ua kupono hoi au imua ona; Ua hookaawale mai au ia'u iho mai ko'u hewa mai.   
\q1
\v 24 Nolaila, i hoopai mai ai o Iehova ia'u e like me ko'u pono. E like me ka maemae o ko'u mau lima imua o kona alo.   
\b  
\q1
\v 25 Me ka mea lokomaikai e hoike ana oe ia oe iho he lokomaikai, Me ke kanaka hoopono e hoike aua oe ia oe iho he pono;   
\q1
\v 26 Me ka mea maemae, e hoike ana oe ia oe iho he maemae; Me ka mea hooolea, e hoike ana oe ia oe iho ho oolea.   
\q1
\v 27 No ka mea, e hoola ana oe i ka poe i hooluhiia; Aka, e hoohaahaa oe i na maka kiekie.   
\q1
\v 28 No ka mea, e kuni no oe i ko'u kukui, E koomalamalama mai no o Iehova o ko'u Akua i ko'u pouli.   
\q1
\v 29 Nou no wau i wahi ae ai i ka poe kaua; No ko'u Akua i lehai aku ai au maluna o ka pa.   
\b  
\q1
\v 30 A o ke Akua, ua hemolele kona aoao: Ua hoaoia ka olelo a Iehova; He paku oia no na mea a pau i paulele aku ia ia.   
\q1
\v 31 Owai ke Akua, ina aole o Iehova; Owai ka pohaku, ina aole ko kakou Akua?   
\q1
\v 32 O ke Akua ka i kakoo mai ia'u me ka ikaika; Nana no i hoopololei mai i ko'u hele ana.   
\q1
\v 33 Ua hoolilo no oia i kuu mau wawae e like me na wawae dia: Ua hoonoho oia ia'u ma ko'u mau wahi kiekie.   
\q1
\v 34 Ua ao mai no oia i ko'u mau lima e kaua; I haki ai i ko'u lima ke kikoo keleawe.   
\q1
\v 35 Ua haawi mai oe ia'u i kou paku e ola'i: Ua hookupaa mai ia'u kou lima akau? A o kou ahonui ka i hoomakua mai nei ia'u.   
\q1
\v 36 Ua hoakea oe i ko'u mau kapuwai malalo iho o'u; Aole hoi i pahee kuu mau wawae.   
\b  
\q1
\v 37 Ua alualu aku au i kuu mau enemi a loaa lakou; Ua pau e hoi lakou ia'u mamua o ko'u hoi ana mai.   
\q1
\v 38 Ua pepehi aku au ia lakou. aole e hiki ia lakou ke ku ae iluna; Ua pau lakou i ka hina malalo ae o ko'u mau wawae.   
\q1
\v 39 Ua kakoo mai no oe ia'u me ka ikaika i ke kaua; Ua hoohaahaa iho oe malalo iho o'u i ka poe i ku e mai ia'u.   
\q1
\v 40 Ua haawi mai no oe ia'u i ka a-i o ko'u mau enemi; I luku aku ai au i ka poe inaina mai ia'u.   
\q1
\v 41 Ua kabea aku la lakou, aohe hoi mea e ola'i; Ia Iehova hoi, aole no hoi ia i ae mai.   
\q1
\v 42 Alaila, ua pakuikui au ia lakou a okaoka me he lepo la imua o a makani: Ua kiola aku au ia lakou e like me ka lepo ma ke alanui.   
\b  
\q1
\v 43 Ua hoopakele oe ia'u i ka paio ana o na kanaka; Ua hoolilo oe ia'u i poo no na lahuikanaka e; E malama mai ana no ia'u ka poe kanaka a'u i ike ole ai.   
\q1
\v 44 A kui ka lono o'u, e malama koke mai no lakou ia'u; E hooloho mai no ia'u na keiki a kanaka e.   
\q1
\v 45 E mae aku ana no na kanaka e: E makau ana lakou ma ko lakou wahi paa.   
\b  
\q1
\v 46 Ke ola mau nei no Iehova, e hoomaikaiia ko'u pohaku, E hapaiia'ku ko'u Akua e ola'i.   
\q1
\v 47 O ke Akua ka i haawi mai na'u e hoopai aku: Oia ka i hoolilo i Kanaka malalo iho o'u:   
\q1
\v 48 Oia ka i hoopakele ia'u i ko'u mau enemi: Nau no wau i hookiekie ae maluna o ka poe i ku o mai ia'u; Nau no wau i hoola i ke kanaka pepehi wale mai.   
\q1
\v 49 Nolaila au e hoomaikai aku ai ia oe, e Iehova, mawaena o ko na aina e: E hoolea aku hoi au i kou inoa.   
\q1
\v 50 Nani no kona hoola ana i kana alii; Ua aloha mau mai no ia i kona mea poui, ia Davida, a me kana mamo.   
\c 19  
\b  
\q1
\v 1 KE hoakaka mai net na lani i ka nani o ke Akua; Ke hoike mai nei ke aouli i kana hana io.   
\q1
\v 2 Ko hai mai nei kela la i keia la i ka olelo, Ke ao mai nei kela po i keia po i ka ike.   
\q1
\v 3 Aohe leo, aohe olelo; Aohe i lohea ko lakou leo.   
\q1
\v 4 Ua pae aku la ka lakou ao ana i na aina a pau. Ua hiki aku la ka lakou olelo i na welau o ka honua: Maloko o lakou i kukulu ai oia i halelewa no ka la;   
\q1
\v 5 Ua like no ia me ke kane mare e puka mai ana mai kona keena: Ua olioli ia me he kanaka ikaika la e heihei ana.   
\q1
\v 6 Mai ka welau mai o ka lani kona hele ana; A ua hiki kona poai ana i na welelau o ke ao: Aole mea i hunaia i kona wela.   
\b  
\q1
\v 7 O ko kanawai o Iehova, he hemolele no ia, e hoohuli ana i ka uhane: O ka olelo a Iehova, he oiaio no ia, e hoonaauao ana i ka mea naaupo.   
\q1
\v 8 O na kapu o Iehova, he maikai no ia, e hoohauoli ana i ka naau; O ke kauoha a Iehova, he laelae no ia, e hoomalamalama ana i na maka.   
\q1
\v 9 O ka makau ia Iehova, he maemae no ia, e oia mau ana no; O na oihana a Iehova, he pololei no ia, a me ka pono wale io no.   
\q1
\v 10 He mau mea ia e makemake nui ia, aole ke gula, aole hoi ke gula maikai he nui wale; Ua oi aku ko lakou ono i ko ka meli a me ka waihona meli.   
\q1
\v 11 A, ua aoia mai no hoi kau kauwa e lakou; No ka malama ana ia lakou he nui wale ka waiwai.   
\q1
\v 12 Owai ka mea i helu pono i kona lalau ana? E hoomaemae oe ia'u i na hewa i nalo.   
\q1
\v 13 E kaohi mai oe i kau kauwa mai na hewa nui, i pio ole ai au ia lakou; Alaila e kupono au, a e kaawale hoi au i ka hewa loa.   
\q1
\v 14 I maikai ka olelo a ko'u waha, a me ka manao o ko'u naau, Imua o kou alo, e Iehova, e ko'u Ikaika, a me ko'u Hoola.   
\c 20  
\b  
\q1
\v 1 E HOOLOHE mai o Iehova ia oe i ka la popilikia; I ola oe i ka inoa o ke Akua no Iakoba.   
\q1
\v 2 Mai kona keenakapu mai e hoouna mai ai oia i kou mea nana e alu; Mai Ziona mai e kokua mai ai oia ia oe.   
\q1
\v 3 E hoomanao mai hoi i kau mau mohai a pau; A e hoopono mai hoi i kau mohai kuni. Sila.   
\b  
\q1
\v 4 E haawi mai hoi e like me kou naau iho, E hooko mai hoi i kou manao a pau.   
\q1
\v 5 I kou ola e hauoli ai makou, A i ka inoa o ko kakou Akua e kau ai kakou i ka hae: E ae mai hoi o Iehova i kau pule a pau.   
\b  
\q1
\v 6 Ano ua ike au, ua hoola o Iehova i kona mea i poniia; Ma kona lani hoano no ia e hoolohe mai ai ia ia, Me ka mana o kona lima akau e ola'i.   
\q1
\v 7 Ma na kaakaua kekahi poe, ma na lio kekahi i manao ai; Aka, e hoomanao kakou i ka inoa o Iehova o ko kakou Akua.   
\q1
\v 8 Ua emi lakou, ua haule ilalo; Aka, ua ala mai nei makou a ku pono iluna.   
\q1
\v 9 E hoola mai, e Iehova; E hoolohe mai ke alii ia makou i ko makou kahea ana.   
\c 21  
\b  
\q1
\v 1 E IEHOVA, e hauoli aku ke alii i kou mana; Nani hoi kona olioli ana i kou ola.   
\q1
\v 2 Ua haawi mai oe ia ia i ka mea a kona naau i makemake ai; Aole oe i hoole i ka mea a kona lehelehe i noi aku ai. Sila.   
\q1
\v 3 A, ua haawi e mai oe ia ia i pomaikai i ka pono; Ua kau mai oe i ka lei gula maemae maluna iho o kona poo.   
\q1
\v 4 Ua noi aku oia ia oe i ola, nau no ia i haawi mai nona; O ke ola loa i ka manawa pau ole.   
\q1
\v 5 He nui wale kona nani i kou ola; O ka mahalo, a me ka hanohano kau i kau mai ai maluna iho ona.   
\q1
\v 6 Ua hoopomaikai io mau loa oe ia ia; Ua hoohauoli loa oe ia ia i kou maka.   
\b  
\q1
\v 7 No ka mea, na hilinai aku ke alii ia Iehova, No ka lokomaikai o ka Mea kiekie loa e kulanalana ole ai ia.   
\q1
\v 8 E loaa no i kou lima kou mau enemi a pau; E loaa no i kou lima akau ka poe inaina ia oe.   
\q1
\v 9 E hoohalike no oe ia lakou me he umu ahi la i kou wa e huhu ai; E ale no Iehova ia lakou i kona inaina, e pau hoi lakou i ke ahi.   
\q1
\v 10 Nau no ka lakou hua e luku aku, mai ka honua aku, A me ka lakou mamo, mai waena aku o na keiki a kanaka.   
\q1
\v 11 No ka mea, ua hoopalahalaha lakou i ka ino nou; Ua kuka lakou i ka manao hewa, aole hoi i hiki.   
\q1
\v 12 Nolaila, e hoohuli mai oe i ko lakou kua; Ke hoomakaukau oe i na pua i kau mau kaula, i ku pono i ko lakou alo.   
\q1
\v 13 E hapaiia'ku oe, e Iehova, i kou ikaika; E oli no hoi makou me ka hoolea aku i kou mana.   
\c 22  
\b  
\q1
\v 1 E KO'U Akua, e ko'u Akua, no ke aha la oe i haalele mai ia'u? A i ole ai e kokua iki mai ia'u i ka leo o ko'u ulono ana?   
\q1
\v 2 E ko'u Akua e, ua kahea au i ke ao, aole nae oe i lohe mai; A i ka po hoi, aole i hoomaha iki.   
\q1
\v 3 Aka, o oe ka mea hemolele, E noho ana iloko o ka Iseraela hoolea ana.   
\q1
\v 4 Ua hilinai aku ko makou mau makua ia oe; Ua manaoio lakou, a nau no lakou i hoola   
\q1
\v 5 Ua kahea lakou ia oe, a ua hoolaia no hoi; Ua paulele lakou ia oe, aole hoi lakou i hoka,   
\b  
\q1
\v 6 Aka, he enuhe au, aole he kanaka; He mea hoinoia e ko ke ao nei, A i hoowahawahaia e na kanaka.   
\q1
\v 7 Ua hoomauakala mai ka poe a pau ke ike mai ia'u; Ua hooioi mai lakou i ka lehelehe me ka hooluli i ke poo,   
\q1
\v 8 I iho la, ua paulele aku la oia ia Iehova i ola oia ia ia, Nana no ia e hoola ke olioli mai oia ia ia.   
\b  
\q1
\v 9 Nau no wau i hookaawale mai ka opu mai; Ua hoolana oe i ko'u manao ma na u o ko'u makuwahine.   
\q1
\v 10 Ua waihoia'ku au maluna ou mai ka opu mai; Mai ka opu mai o ko'u makuwahine, o oe no ko'u Akua.   
\b  
\q1
\v 11 Mai hoomamao aku oe ia'u, ke kokoke mai nei ka popilikia; Aohe mea nana e kokua mai.   
\q1
\v 12 He nui na bipi kane i hoopuni mai ia'u; Ua puni au i na mea ikaika no Basana.   
\q1
\v 13 Ua hamama mai la ko lakou mau waha ia'u E like me ka liona hae e uwo ana.   
\q1
\v 14 Ua nininiia'ku au me he wai la, Ua pau ko'u mau iwi i ka haihai; Ua like ko'u puuwai me he pilali la: Ua hooheeia ia iwaena konu o ko'u mau naau.   
\q1
\v 15 Ua pau ko'u ikaika i ka maloo me he apana ipu lepo la; Ua pipili ko'u alelo i ko'u mau a; Ua hookomo oe ia'u iloko o ka lepo o ka make.   
\q1
\v 16 Ua hoopuni mai na ilio ia'u; Ua poaiia mai au e ke anaina kanaka hewa; Ua o mai lakou i ko'u mau lima a me ko'u mau wawae.   
\q1
\v 17 E hiki no ia'u ke helu i ko'u mau iwi a pau; Ua haka mai lakou ia'u me ka makahahi.   
\q1
\v 18 Ua puunaue lakou i ko'u mau kapa no lakou; A o ko'u aahu ka lakou i hailona ai.   
\b  
\q1
\v 19 Aka, mai hoomamao aku oe ia'u, e Iehova; E ko'u Ikaika, e papaana mai oe e kokua mai ia'u.   
\q1
\v 20 E hoopakele oe i ko'u uhane i ka pahikaua, I ko'u makamae hoi i ka lima o ka ilio.   
\q1
\v 21 E hoola mai oe ia'u i ka waha o ka liona; Ua lohe mai oe ia'u ma na hao o na reema.   
\b  
\q1
\v 22 E hai aku no wau i kou inoa i ko'u mau hoahanau; E hoolea hoi au ia oe mawaena o ke anaina kanaka.   
\q1
\v 23 E ka poe makau ia Iehova, e hoolea oukou ia ia; E hoonani oukou ia ia, e na pua a pau a Iakoba; E hoomana imua ona, e na mamo a pau a Iseraela.   
\q1
\v 24 No ka mea, aole ia i hoowahawaha, aole hoi i hoaikola i ka poino o ka mea i hooluhiia; Aole ia i huna aku i kona maka ia ia; Aka, i kona kahea ana aku ia ia, ua hoolohe mai no ia.   
\b  
\q1
\v 25 Ia oe ko'u hoolea ana iwaena o ke anaina nui; E hooko aku au i ka'u i hoohiki ai, imua o ka poe weliweli ia ia.   
\q1
\v 26 E ai no ka poe akahai a maona: E hoolea aku no ia Iehova ka poe e imi ia ia; E ola mau loa ko oukou naau.   
\q1
\v 27 E hoomanao iho, a e huli mai no ia Iehova, na welelau a pau o ka honua; E pau no na ohana o na lahuikanaka i ka hoomana imua ou:   
\q1
\v 28 No ka mea, no Iehova ke aupuni; Oia hoi ke Alii iwaena o na lahuikanaka.   
\q1
\v 29 E ai no me ka hoomana ka poe waiwai a pau ma ka honua: O ka poe a pau e iho ana i ka lepo, e kulou lakou imua ona: Aohe mea e hoola i kona uhane iho.   
\q1
\v 30 E malama no kekahi mau mamo ia ia; E kapaia lakou he hanauna no ka Haku.   
\q1
\v 31 E hele mai no lakou, e hai ana i kona pono I ka lahuikanaka e hanau ana, oia kana i hana'i.   
\c 23  
\b  
\q1
\v 1 O IEHOVA ko'u Kahuhipa; Aole o'u mea e nele ai.   
\q1
\v 2 Nana no wau i hoomoe iho ma na aina uliuli: Ua alakai oia ia'u ma kapa wai lana malie.   
\q1
\v 3 Ke hoala mai nei oia i ko'u uhane: Ke alakai nei no oia ia'u ma na ala maikai no kona inoa.   
\b  
\q1
\v 4 Oiaio, ina e hele au ma ke awawa malu o ka make, Aole au e weliweli i ka poina: no ka mea, o oe pu kekahi me au; O kou mana, a me kou kookoo, o ko'u mau mea ia e oluolu ai.   
\q1
\v 5 Ke hoomakaukau mai nei oe i ka papaaina na'u ma ke alo o ko'u mau enemi: Ua kahinu mai oe i kuu poo me ka aila; Ua piha a hu ko'u kiaha.   
\q1
\v 6 Oiaio, e hahai mau ana ia'u ka pono a me ke aloha i na la a pau o ko'u ola ana; A maloko o ka hale o Iehova owau e noho mau loa aku ai.   
\c 24  
\b  
\q1
\v 1 NO Iehova ka honua a me kona mea e piha ai; O ke ao nei, a me ka poe e noho ana maloko ona.   
\q1
\v 2 No ka mea, nana no ia i hookumu maluna iho o na kai, A i hoopaa hoi maluna iho o na wai.   
\q1
\v 3 Owai la ka mea e pii i ka mauna o Iehova? Owai la hoi ke ku ma kona wahi hoano?   
\q1
\v 4 O ka mea lima paumaele ole a me ka naau maemae; O ka mea i paulele ole kona uhane i ka mea lapuwale; Aole hoi i hoohiki i ke Akua me ka wahahee:   
\q1
\v 5 Oia ka mea e hoomaikaiia mai e Iehova, A e hooponoia mai hoi e kona Akua e ola'i.   
\q1
\v 6 Oia ka hanauna o ka poe i imi ia ia, I huli hoi i kou alo, e ke Akua o Iakoba. Sila.   
\b  
\q1
\v 7 E hapai ae, e na pani, i ko oukou mau poo; E hookiekieia'e hoi oukou, e na ipuka mau loa; A e komo no hoi ke Alii nani.   
\q1
\v 8 Owai la ia Alii nani? O Iehova ka ikaika a me ka mana; O Iehova ka mea mana i ke kaua.   
\q1
\v 9 E hapai ae, e na pani, i ko oukou mau poo, E hookiekieia'e oukou, e na ipuka mau loa; A e komo no hoi ke Alii nani.   
\q1
\v 10 Owai la ia Alii nani? O Iehova Sabaota, oia ke Alii nani. Sila.   
\c 25  
\b  
\q1
\v 1 E IEHOVA, ke hapai nei au i ko'u uhane ia oe.   
\q1
\v 2 E kuu Akua, maluna ou e hilinai aku nei au; Aole au e hoka; Mai noho a lanakila mai ko'u poe enemi maluna o'u.   
\q1
\v 3 Oia hoi, e hoka ole ka poe manaolana ia oe; E hoka no nae ka poe lawehala wale.   
\b  
\q1
\v 4 E hoike mai, e Iehova, i kou mau alanui ia'u: E ao mai oe ia'u i kou mau kuamoo.   
\q1
\v 5 E alakai oe ia'u ma kau olelo oiaio, E ao mai hoi oe ia'u; No ka mea, o oe no ko'u Akua e ola'i: He manaolana ko'u ia oe a po ka la.   
\q1
\v 6 E hoomanao oe, e Iehova, i kou aloha a me kou lokomaikai; No ka mea, he mau mea kahiko loa mai no ia.   
\q1
\v 7 Mai manao mai oe i na hewa o ko'u wa opiopio, me na hala o'u. E hoomanao mai oe ia'u e like me kou aloha, no kou lokomaikai   
\b  
\q1
\v 8 He maikai a he pololei no ko Iehova; Nolaila ia e ao mai ai i ka poe lawehala i kona alanui.   
\q1
\v 9 E alakai oia i ka poe akahai ma ka pono: E ao mai no hoi oia i ka poe hoohaahaa i kona aoao.   
\q1
\v 10 O na aoao a pau o Iehova he aloha no ia me ka oiaio, I ka poe i malama i kona berita a me kana mau kauoha.   
\q1
\v 11 No kou inoa, e Iehova, e kala mai ai oe i ko'u hewa; No ka mea, he nui no ia.   
\b  
\q1
\v 12 Owai la ke kanaka i weliweli aku ia Iehova? Oia kana e ao mai ai i ka aoao ana e koho ai.   
\q1
\v 13 E noho kona uhane ma ka maikai. E ili hoi ka honua i kana mau keiki.   
\q1
\v 14 O ka manao paa o Iehova aia no ia me ka poe weliweli ia ia: E hoike mai no hoi oia i kona berita ia lakou.   
\q1
\v 15 E kau mau ana ko'u mau maka ia Iehova; No ka mea, e kaili ae oia i ko'u mau wawae mailoko ae o ka upena.   
\b  
\q1
\v 16 E maliu mai oe ia'u a e aloha mai ia'u. No ka mea, ua mehameha au a ua popilikia.   
\q1
\v 17 Ua nui ae nei ka ehaeha o ko'u naau: E lawe ae oe ia'u mailoko ae o ko'u popilikia.   
\q1
\v 18 E nana mai i ko'u pilikia a me ko'u eha; A e kala mai i ko'u hewa a pau.   
\q1
\v 19 E manao mai oe i kuu mau enemi, No ka mea, he nui no lakou; A ua inaina mai lakou ia'u me ka huhu awahia.   
\q1
\v 20 E malama mai oe i kuu uhane, a e hoola mai ia'u; E hoka ole au, no ka mea, e hilinai aku au ia oe.   
\q1
\v 21 E hoomalu ka pono me ka pololei ia'u, No ka mea, ke manao laua aku nei au ia oe.   
\q1
\v 22 E hoola ae oe, e ke Akua, ia Iseraela, Mai loko ae o kona mau popilikia a pau.   
\c 26  
\b  
\q1
\v 1 E HOOPONO mai oe ia'u, e Iehova, no ka mea, ua hele au me ko'u pono: Ua hilinai au ia Iehova, aole au e pahee.   
\q1
\v 2 E huli oe ia'u, e Iehova, a e hoike ia'u; E hoao mai oe i kuu puupaa a me kuu naau.   
\q1
\v 3 No ka mea, imua o ko'u mau maka kou lokomaikai; A ma kau olelo oiaio i hele ai au.   
\q1
\v 4 Aole au i noho pu me ka poe hookano; Aole hoi e komo pu me ka poe hookamani wale.   
\q1
\v 5 Ua hoowahawaha au i ke anaina o ka poe hana ino; Aole hoi e noho pu au me ka poe hewa.   
\q1
\v 6 E holoi au i kuu mau lima me ka hala ole; Pela hoi au e hoopuni ai i kou kuahu, e Iehova;   
\q1
\v 7 E hoike aku au me ka leo hoomaikai, A e hai aku hoi i kau mau hana kupaianaha a pau.   
\b  
\q1
\v 8 E Iehova, ua makemake au i ka noho ana o kou hale, A me ka wahi e noho ai kou nani.   
\q1
\v 9 Mai houluulu oe i ko'u uhane me ka poe hewa; Aole hoi i kuu ola me na kanaka koko:   
\q1
\v 10 Maloko o ko lakou mau lima ke kolohe; A ua piha i na kipe ko lakou mau lima akau.   
\q1
\v 11 A owau nei la, e hele au me kuu pono; E hoola mai oe ia'u, a e aloha mai ia'u.   
\q1
\v 12 Ke ku nei kuu wawae ma kahi maniania; Maloko o na anaina e hoomaikai aku ai au ia Iehova.   
\c 27  
\b  
\q1
\v 1 O Iehova ka ikaika o kuu ola nei; Ia wai la au e weliweli aku ai?   
\q1
\v 2 I ka lele ana mai o ka poe hewa ia'u, O kuu mau enemi ka poe ku e mai ia'u, e ai i kuu io, Kuia iho la lakou a hina ilalo.   
\q1
\v 3 Ina e hoomoana ku e mai ka poe kaua ia'u, aole e makau ko'u naau; Ina e eu ku e mai ke kaua ia'u, ma keia no wau e hilinai ai.   
\b  
\q1
\v 4 Hookahi no mea a'u i noi aku ai ia Iehova, oia ka'u e imi aku ai; E noho au maloko o ka hale o Iehova i na la a pau o ko'u ola ana. E nana aku i ka nani o Iehova, a e ninaninau iloko o kona luakini.   
\q1
\v 5 No ka mea, i ka wa popilikia e huna mai oia ia'u i kona malu: Ma kahi mehameha o kona halelewa e huna mai ai oia ia'u; E hoonoho no hoi oia ia'u maluna o ka pohaku.   
\q1
\v 6 Ano e hookiekieia'e kuu poo maluna o kuu mau enemi i hoopuni mai ia'u; Nolaila e kaumaha aku ai au iloko o kona halelewa i na mohai olioli: E oli aku au, oiaio, e hoolea aku wau ia Iehova.   
\b  
\q1
\v 7 E hoolohe mai, e Iehova, i kuu hea ana'ku me kuu leo; E aloha mai hoi oe ia'u, e ae mai i ka'u.   
\q1
\v 8 I kau olelo ana, E imi mai oukou i kuu alo; I aku la kuu naau ia oe, O kou alo, e Iehova, ka'u e imi ai   
\q1
\v 9 Mai huna i kou maka ia'u; Mai hoohemo i kau kauwa nei me ka huhu. Ua kokua mai no hoi oe ia'u; Mai hookuu wale ia'u, Mai haalele hoi oe ia'u, e kuu Akua e ola'i.   
\q1
\v 10 Aia haalele ko'u makuakane a me ko'u makuwahine ia'u, Alaila e ohi mai no hoi o Iehova ia'u.   
\b  
\q1
\v 11 E ao mai ia'u, e Iehova, i kou alanui; A e alakai ia'u ma ke ala maniania no kuu poe enemi.   
\q1
\v 12 Mai haawi oe ia'u i ka makemake o kuu poe enemi, No ka mea, ua ku e mai ia'u na mea hoike wahahee, A me ka poe e ha ana'e i ka huhu hewa.   
\q1
\v 13 Ina i manao ole au e ike i ka maikai o Iehova, i ka aina o ka poe ola, Ina ua maule e au.   
\q1
\v 14 E manaolana ia Iehova; i nui ka ikaika, A e hooikaika mai oia i kou naau; E hilinai aku hoi ia Iehova.   
\c 28  
\b  
\q1
\v 1 I A oe, e Iehova, e kahea aku ai au e kuu pohaku, mai hookuli mai oe ia'u; O like auanei au me ka poe iho ilalo o ka Iua, ke hookuli mai oe ia'u.   
\q1
\v 2 E hoolohe mai i ka leo o ka'u pule, i ko'u kahea ana'ku ia oe, I ka hapai ana o kuu mau lima i kou wahi hoano.   
\q1
\v 3 Mai alako ae ia'u me ka poe aia, me ka poe hana hewa, Ka poe olelo aloha i ko lakou mau hoalauna, He hewa no nae maloko o ko lakou mau naau.   
\q1
\v 4 E haawi ia lakou e like me ka lakou mau hana; A mamuli o ka hewa o ko lakou hooikaika ana; E haawi ia lakou mamuli o ka hana o ko lakou mau lima; E uku ia lakou no ka lakou hana.   
\q1
\v 5 No ka mea, aole lakou i manao i na hana a Iehova, Aole hoi i ka hana ana o kona mau lima, E wawahi oia ia lakou, aole e kukulu ia lakou iluna.   
\b  
\q1
\v 6 E hoomaikaiia'ku o Iehova, No ka mea, ua hoolohe mai no ia i ka leo a ka'u mau pule.   
\q1
\v 7 O Iehova kuu ikaika a me kuu palekaua; Ia ia i hilinai ai kun naau, a ua kokuaia mai au; Nolaila i hauoli nui ai kuu naau, A ma kuu mele e hoolea aku ai au ia ia.   
\q1
\v 8 O Iehova ko lakou ikaika; Oia hoi ka ikaika e ola'i kona mea i poniia.   
\q1
\v 9 E hoola i kou poe kanaka, a e hoomaikai i kou hooilina: E hanai ia lakou, a e kaikai ia lakou a mau loa.   
\c 29  
\b  
\q1
\v 1 E HAAWI aku ia Iehova, e ka poe ikaika, E haawi aku ia Iehova i ka nani a me ka mana.   
\q1
\v 2 E haawi aku ia Iehova i ka nani o kona inoa: E hoomana aku ia Iehova me na mea nani hoano.   
\b  
\q1
\v 3 Aia ka leo o Iehova maluna o na kai: Ke hekili mai nei ke Akua nani: Aia no Iehova maluna iho o na wai he nui no.   
\q1
\v 4 O ka leo o Iehova he mea mana no ia: O ka leo o Iehova he nani loa no ia.   
\q1
\v 5 O ka leo o Iehova ua uhai i na laau Kedera: Oiaio ua uhai no o Iehova i na Kedera o Lebanona.   
\q1
\v 6 Ua hoolelele oia ia lakou me he keiki bipi la; Ia Lebanona a me Siriona e like me ka reema opiopio.   
\q1
\v 7 O ka leo o Iehova ua mahele i na lapalapa o ke ahi.   
\q1
\v 8 O ka leo o Iehova ua hoohaalulu i ka waonahele; Ke hoohaalulu nei o Iehova i ka waonahele o Kadesa.   
\q1
\v 9 O ka leo o Iehova ua hoohanau i na dia wahine, A ua wehewehe mai ia i na ululaau: A iloko o kona Luakini i olelo ai na mea a pau i kona nani.   
\b  
\q1
\v 10 Ke noho nei no Iehova maluna o ka moana; Oiaio, e noho alii mau loa ana o Iehova.   
\q1
\v 11 E haawi mai no hoi o Iehova i ka ikaika i kona poe kanaka: E hoopomaikai mai no hoi o Iehova i kona poe ohua me ka maluhia.   
\c 30  
\b  
\q1
\v 1 E HAPAI aku au ia oe, e Iehova, no kou hoopakelo ana ia'u; Aole oe i hoohauoli i ko'u poe enemi maluna iho o'u.   
\q1
\v 2 E Iehova ko'u Akua, ua ulono aku au ia oe, A ua hoola mai nei oe ia'u.   
\q1
\v 3 E Iehova, ua lawe mai oe i kuu uhane mai ka luakupapau: Ua hoomau oe i kuu ola i ole au e iho ilalo i ka lua.   
\q1
\v 4 E himeni aku ia Iehova, e kona poe haipule; E hoomaikai hoi i ka hoomanao ana i kona hoano.   
\q1
\v 5 No ka mea, hookahi sekona kona huhu: He ola no nae iloko o kona lokomaikai. He uwe ana paha i ka po hookahi; Aka, hiki mai no ka hauoli i ke kakahiaka.   
\b  
\q1
\v 6 I iho la au i kuu pomaikai ana, Aole loa au e hoonauweweia.   
\q1
\v 7 E Iehova, ma kou lokomaikai, ua, hookupaa oe i kuu mauna: Huna aku la oe i kou maka, pilikia iho la au.   
\q1
\v 8 Kahea aku la au ia oe, e Iehova; Pule aku la hoi au i ka Haku.   
\q1
\v 9 Heaha ka waiwai o kuu koko i kuu iho ana i ka lua? E hoolea anei ka lepo ia oe? E hai aku anei oia i kou oiaio?   
\b  
\q1
\v 10 E hoolohe mai, e Iehova, a e aloha mai oe ia'u: E Iehova, e lilo mai oe i kokua no'u.   
\q1
\v 11 Ua hoolilo oe i kuu uwe ana i haa ana no'u: Ua kala oe i kuu kapa iuo; A ua kakoo mai oe ia'u me ka hauoli;   
\q1
\v 12 I hoolea ko'u nani ia oe, aole o mumule. E Iehova ko'u Akua, e hoomaikai mau loa aku au ia oe.   
\c 31  
\b  
\q1
\v 1 KE hilinai aku nei au ia oe, e Iehova, aole loa au o hoka; Ma kou pono e hoola mai oe ia'u.   
\q1
\v 2 E haliu mai kou pepeiao ia'u, e hoola koke mai ia'u; E lilo oe i pohaku paa no'u, i hale e malu ai e ola'i au.   
\q1
\v 3 No ka mea, o oe no ko'u pohaku a me kuu pakaua; Nolaila, no kou inoa e alakai oe ia'u, a e malama mai ia'u.   
\q1
\v 4 E kaili oe ia'u mailoko o ka upena a lakou i waiho malu ai no'u; No ka mea, o oe no ko'u ikaika.   
\q1
\v 5 Ke haawi aku nei au i kuu uhane iloko o kou lima; Ua hoopakele mai oe ia'u, e Iehova ke Akua oiaio.   
\b  
\q1
\v 6 Ua hoowahawaha au i ka poe manao ma na mea lapuwale hoopunipuni; Aka, ke hilinai aku nei au ia Iehova.   
\q1
\v 7 E olioli au, a e hauoli hoi i kou aloha; No ka mea, ua manao mai oe i kuu kaumaha; Ua ike hoi oe i ko'u uhane iloko o ka popilikia;   
\q1
\v 8 Aole oe i hoopaa ia'u iloko o ka lima o ka enemi; Ua hooku oe i kuu mau wawae ma kahi akea.   
\b  
\q1
\v 9 E aloha mai oe ia'u, e Iehova, no ka mea, ua pilikia au: Ua pau e kuu maka i ke kaumaha, a me kuu uhane a me kuu opu.   
\q1
\v 10 No ka mea, ua pau kuu ola nei i ke kaumaha, A me kuu mau makahiki i ka u ana: Ua pau e kuu ikaika no kuu hewa, Ua pauhia hoi ko'u mau iwi.   
\q1
\v 11 Lilo aku la au i mea hoinoia iwaena o ko'u poe enemi a pau, He mea hoino nui ia iwaena o ko'u mau hoauoho, He mea weliweli no hoi no ko'u mau hoalauna: O ka poe ike mai ia'u mawaho, holo aka lakou mai o'u aku nei.   
\q1
\v 12 Ua poina hoi au me he kanaka make la i nalo iho: Ua like no hoi au me ka ipu nahaha.   
\q1
\v 13 No ka mea, ua lohe no au i ka hoino ana o na mea he nui: He makau no ma na aoao a puni; I ka wa i ohumu ku e mai ai lakou ia'u, Kukakuka lakou e kaili wale aku i kuu ola,   
\b  
\q1
\v 14 Aka, i hilinai aku au ia oe, e Iehova; I aku la au, o oe no ko'u Akua.   
\q1
\v 15 Aia no i kou lima kuu mau manawa; E hoopakele oe ia'u i ka lima o ko'u poe enemi, A me ka poe alualu hewa mai ia'u.   
\q1
\v 16 E hoomalamalama mai kou maka i kau kauwa nei: E hoola mai oe ia'u no ko'u aloha.   
\q1
\v 17 E Iehova, aole au e hoka, No ka mea, ua kahea aku au ia oe: E hoka ka poe hewa, A e waiho leo ole lakou iloko o ka luakupapau.   
\q1
\v 18 E hoopaaia na lehelehe hoopunipuni; Na mea olelo hookano me ka haakei, I na mea kaumaha i ku e i ka mea pono.   
\b  
\q1
\v 19 Nani ka mea maikai au i hoahu ai no ka poe weliweli ia oe; Au i hana'i hoi no ka poe hilinai ia oe imua o na keiki a kanaka!   
\q1
\v 20 E huna oe ia lakou ma kahi malu o kou alo mai ka ohumu ana o kanaka; E malama malu oe ia lakou maloko o ka halelewa mai ka paio ana o na elelo.   
\q1
\v 21 E hoomaikaiia'ku o Iehova: No ka mea, ua hookupanaha oia i kona aloha ia'u iloko o ke kulanakauhale paa.   
\q1
\v 22 A i kuu wikiwiki, i iho la an, Ua okiia'e no au mai mua'e o kou mau maka; Aka, ua hoolohe mai no hoi oe i ka leo o ka'u pule ana, I kuu kahea ana'ku ia oe.   
\b  
\q1
\v 23 E aloha aku ia Iehova, e kona poe haipule a pau; No ka mea, ua malama mai o Iehova i ka poe hoopono, A ua uku nui mai no ia i ka mea hana hookano.   
\q1
\v 24 E hoolana oukou, a e hooikaika mai oia i ko oukou naau, E ka poe a pau e hilinai ana ia Iehova.   
\c 32  
\b  
\q1
\v 1 POMAIKAI ka mea i kalaia kona hala, I uhiia hoi koua hewa.   
\q1
\v 2 Pomaikai ke kanaka, maluna ona ka hoili ole ia o ka hewa e Iehova. Iloko hoi o kona uhane aohe hookamani.   
\b  
\q1
\v 3 I ko'u mumule ana ua elemakule ae la kuu mau iwi, I kuu auwe ana a po ka la.   
\q1
\v 4 No ka mea, i ke ao a me ka po, kaumaha mai la kou lima maluna iho o'u: Ua hooliloia ko'u ma-u ana i maloo o ka makalii. Sila.   
\q1
\v 5 Ua hai aku au i ko'u hewa ia oe; Aole au i huna i ko'u lawehala ana. I iho la an, E hai aku au i ko'u hala ia Iehova; A ua kala mai oe i ka hewa o ka'u lawehala ana. Sila.   
\q1
\v 6 No ia mea, e pule aku ia oe na haipule i ka wa e loaa ai oe; Oiaio, i ke kahe aua o na wai nui, aole ia e kokoke ia ia.   
\q1
\v 7 O oe no kuu wahi e pee ai; E hoopakele no oe ia'u i ka popilikia: E hoopuni no oe ia'u me na mele no ke ola. Sila.   
\b  
\q1
\v 8 E ao aku au ia oe, a hoike ia oe i kou ala e hele ai; E alakai au ia oe me ko'u maka.   
\q1
\v 9 Mai hoohalike oukou me ka lio a me ka hoki, na mea ike ole; E pono ke kaohiia kona waha me ka haowaha, a me ke kaula waha, o hele kokoke ia ia oe.   
\q1
\v 10 E nui auanei ka ehaeha o ka mea hewa; Aka, o ka mea hilinai ia Iehova. e hoopuniia no ia me ke aloha.   
\q1
\v 11 E olioli ia Iehova, a e hauoli, e ka poe pono: E hooho no ka hauoli, e ka poe a pau i kupono ka naau.   
\c 33  
\b  
\q1
\v 1 E HAUOLI ia Iehova, e ka poe pono; O ka hoolea, he nani ia no ka poe maikai   
\q1
\v 2 E hoolea aku ia Iehova me ka lira; E hookani ia ia me ka violaumi, ka mea kani kaula umi.   
\q1
\v 3 E oli aku ia ia i ke mele hou; E hula akamai me ke kani nui.   
\q1
\v 4 No ka mea, he pono ka olelo a Iehova; A ma ka oiaio kana mau hana a pau.   
\q1
\v 5 Makemake no oia i ka pono a me ka hoopono ana: Paapu ka honua i ka lokomaikai o Iehova.   
\b  
\q1
\v 6 Ma ka olelo a Iehova i hanaia'i na lani; O ko laila lehulehu no hoi ma ka ha ana o kona waha.   
\q1
\v 7 Ke houluulu nei oia i na wai o ka moana me he puu la: Ke hoahu nei no hoi oia i ka hohonu iloko o na halepapaa.   
\q1
\v 8 E makau aku ka honua a pau ia Iehova; E weliweli aku ia ia ka poe a pau e noho ana i ke ao nei:   
\q1
\v 9 No ka mea, i iho la ia, a o ka hanaia no ia; Kauoha iho la ia, a o ke ku paa mai la no ia.   
\q1
\v 10 Ke hoolilo nei o Iehova i ka manao o na kanaka i mea ole; Ke hoolilo nei oia i ka noonoo o na lahuikanaka i mea lapuwale.   
\q1
\v 11 O ka manao o Iehova e kupaa mau loa ia; A o ka noonoo o kona naau i na hanauna a pau.   
\q1
\v 12 Pomaikai ka lahuikanaka o Iehova kona Akua; Ka poe kanaka hoi ana i koho ai i hooilina nona.   
\b  
\q1
\v 13 Ke nana mai nei o Iehova mai luna mai o ka lani; Ke ike mai nei no ia i na keiki a pau a kanaka.   
\q1
\v 14 Mai kona wahi i noho ai, Ke nana mai nei oia i ka poe a pau e noho ana ma ka honua.   
\q1
\v 15 Ko hana nei oia i ko lakou mau naau a like; Ke hoomanao mai nei no ia i ka lakou mau hana a pau.   
\q1
\v 16 Aole alii i ola i ka lehulehu o ka poe kaua; Aole ke kanaka ikaika i hoolaia e ka ikaika nui.   
\q1
\v 17 O ka lio he mea lapuwale ia e malu ai: Aohe mea e hoolaia e ia ma kona ikaika nui.   
\b  
\q1
\v 18 Aia hoi ka maka o Iehova maluna o ka poe weliweli ia ia. Maluna o ka poe i manaolana i kona aloha;   
\q1
\v 19 E hoopakele i ko lakou uhane i ka make, A e hoomau i ko lakou ola nei i ka pololi aua.   
\q1
\v 20 Ke kali nei ko kakou uhane ia Iehova; Oia ko kakou kokua a me ko kakou palekaua.   
\q1
\v 21 No ka mea, e hauoli auanei ko kakou naau ia ia, No ko kakou hilinai ana i kona inoa hoano.   
\q1
\v 22 E aloha mai ia makou, e Iehova, E like me ko makou manaolana ana ia oe.   
\c 34  
\b  
\q1
\v 1 E HOOMAIKAI aku au ia Iehova i na manawa a pau; E mau ana i kuu waha ka hoolea nona.   
\q1
\v 2 E hauoli kuu uhane ia Iehova; E lohe mai ka poe hoohaahaa a e olioli no hoi.   
\q1
\v 3 E hoonui hoi oukou ia Iehova me au nei, A e hapai pu kakou i kona inoa.   
\b  
\q1
\v 4 Ua imi aku au ia Iehova a ua hoolohe mai ia ia'u; Ua hoopakele mai oia ia'u i ka'u mau mea e makau ai a pau.   
\q1
\v 5 Nana aku la lakou ia ia a malamalama iho la lakou; Aole hilahila ko lakou mau maka.   
\q1
\v 6 Kahea aku la keia kanaka ilihune, A hoolohe mai la o Iehova ia ia, A hoopakele oia i kona popilikia a pau.   
\q1
\v 7 Hoomoana mai ka anela o Iehova a puni ka poe weliweli ia ia, A ua hoopakele hoi ia lakou.   
\b  
\q1
\v 8 E hoao oukou a e ike hoi he maikai no Iehova; Pomaikai ke kanaka i paulele ia ia.   
\q1
\v 9 E weliweli aku ia Iehova, e ka poe haipule a pau; No ka mea, aole e nele ka poe weliweli ia ia.   
\q1
\v 10 Ua nele a ua pololi na liona opiopio; Aka, o ka poe imi ia Iehova, aole e nele i ka mea maikai.   
\q1
\v 11 E hele mai, e na kamalii, e hoolohe mai ia'u; A e ao aku au ia oukou i ka weliweli ia Iehova:   
\q1
\v 12 Owai ke kanaka i makemake i ke ola, I makemake hoi i na la he nui i ike ai oia i ka maikai?   
\q1
\v 13 E kaohi i kou alelo mai ka hewa, A me kou mau lehelehe i ole e olelo ino.   
\q1
\v 14 E haalele i ka hewa a e haua ma ka pono; E imi i ka maluhia, a malaila e hahai ai.   
\b  
\q1
\v 15 Kau pono na maka o Iehova i ka poe pono, A me kona mau pepeiao i ko lakou kahea ana.   
\q1
\v 16 Ku e ka maka o Iehova i ka poe hewa, E hoonalo loa ia lakou mai ka honua aku.   
\q1
\v 17 Kahea na mea pono, a hoolohe mai no hoi o Iehova; A hoakea mai no oia ia lakou i ko lakou popilikia a pau.   
\q1
\v 18 Kokoke mai no o Iehova i ka poe naau palupalu; A hoola no hoi oia i na mea uhane mihi.   
\b  
\q1
\v 19 He nui no ka pilikia ana o ka mea pono: A hoakea mai no hoi o Iehova ia ia, mai ia mea a pau.   
\q1
\v 20 Malama no hoi oia i kona mau iwi, Aohe mea o lakou i haki.   
\q1
\v 21 E hoomake no ka hewa i ke kanaka aia; A e hoopaiia ka poe inaina i ka poe pono.   
\q1
\v 22 Hoola o Iehova i ka uhane o kana poe kauwa: Aohe mea paulele ia ia o lilo i ka hoopaiia.   
\c 35  
\b  
\q1
\v 1 E HAKAKA, e Iehova, me na mea i hakaka me au: E paio oe me ka poe i paio mai ia'u,   
\q1
\v 2 E lalau i ka palekaua a me ka uhikino, A e ku mai oe iluna i kokua no'u   
\q1
\v 3 Unuhi ae hoi oe i ka ihe a e keakea i ka poe alualu hewa mai ia'u: E olelo mai i kuu uhane, Owau no kou ola.   
\q1
\v 4 E hoka a e hoohilahilaia ka poe i kii mai i ko'u uhane; E hoohuliia'ku lakou i hope, a e hoohokaia hoi na mea i kukakuka i ka ino no'u.   
\q1
\v 5 E like lakou me ka opala imua o ka makani, A e alualu ka anela o Iehova.   
\q1
\v 6 A pouli mai, a pahee hoi ko lakou alanui, A e alualu hoi ka anela a Iehova ia lakou.   
\q1
\v 7 No ka mea, i ka hala ole, huua lakou i ka lakou upena no'u, Iloko o ka lua a lakou i eli ai no kuu uhane, i ka hala ole.   
\q1
\v 8 E kau mai ka make ike ole ia maluna ona; A e hoohei ia ia iho kana upena i huna ai; Iloko o ua make la e haule iho ai oia.   
\b  
\q1
\v 9 E hauoli ko'u uhane ia Iehova; E olioli no hoi i kona hoola ana.   
\q1
\v 10 E olelo aku no hoi ka'u mau iwi a pau, E Iehova, owai la ka mea like me oe? Ka mea i hoopakele i ka mea haahaa i ka mea i oi ka ikaika i kona, Oia hoi, o ka mea ilihune me ka nele i ka mea hao wale ia ia?   
\q1
\v 11 Ua ku iluna na hoike wahahee; Ua hookolokolo mai lakou ia'u ma na mea a'u i ike ole ai.   
\q1
\v 12 Ua uku mai lakou ia'u me ka hewa no ka pono, I haalele loa ia ko'u uhane.   
\q1
\v 13 Aka, owau nei la, i ko lakou mai ana, O ke kapa ino ka'u i aahu ai: A hookaumaha au i kuu uhane me ka hookeai, A ua hoi mai ka'u pule iloko o kuu poli iho.   
\q1
\v 14 Ua hele au me he mea la o ko'u hoaaloha, a o ko'u hoahanau paha ia: Ua kulou iho au me ke kaumaha, E like me ka mea kanikau no kona makuwahine.   
\q1
\v 15 Aka, i kuu oopa ana, olioli lakou, a akoakoa hoi, Oia hoi ua akoakoa ku e ia ia'u ka poe aki, aole hoi au i ike, Ua haehae mai lakou ia'u aole i noho malie.   
\q1
\v 16 Iwaena o na aia hoakaaka ma na ahaaina, Nau mai lakou i ko lakou mau niho ia'u.   
\b  
\q1
\v 17 E ka Haku, pehea ka loihi o kou nana ana mai? E hoopakele i kuu uhane i ko lakou luku ana, A i ko'u makamae i na liona.   
\q1
\v 18 E hoomaikai aku au ia oe iloko o ke anaina nui; E hoolea aku au ia oe iwaena o na kanaka lehulehu.   
\q1
\v 19 Mai noho a hauoli hewa mai ko'u mau enemi maluna o'u: A imo me ka maka ka poe inaina wale mai ia'u.   
\q1
\v 20 No ka mea, aole lakou i olelo ma ke kuikahi; Ua kukakuka lakou i na mea hoopunipuni ku e i na mea noho malie ma ka aina.   
\q1
\v 21 Oiaio, ua hoohamama loa lakou i ko lakou waha ia'u; I iho la lakou, Aia la! aia la! ua ike ko makou maka ia.   
\b  
\q1
\v 22 Oia kau i ike mai ai, e Iehova, mai hakanu oe, E ka Haku, mai noho a mamao aku ia'u.   
\q1
\v 23 E paipai ia oe iho, e ala'e hoi e hoopono ia'u; Ma kuu mea e hakaka ai, e kuu Akua, e kuu Haku hoi.   
\q1
\v 24 E hoopono mai ia'u, e Iehova kuu Akua, mamuli o kou pono; Mai noho a hauoli lakou maluna o'u.   
\q1
\v 25 Mai noho a olelo lakou iloko o ko lakou naau, Aia la! O ko makou makemake no ia: Mai noho a olelo lakou, Ua ale kakou ia ia.   
\q1
\v 26 E hoka a e hoohilahila pu ia no hoi ka poe hauoli i ko'u poino; E hoaahuia me ka hilahila a me ka hoinoia ka poe haanui ku e mai ia'u.   
\b  
\q1
\v 27 E hooho i ka olioli a e hauoli hoi ka poe kokua i kuu pono; A e olelo mau lakou, E mahaloia'ku o Iehova, Ka mea i oluolu i ka pomaikai o kana kauwa nei.   
\q1
\v 28 A e hai aku kuu alelo i kou hoopono ana, A i ka hoolea nou a po ka la.   
\c 36  
\b  
\q1
\v 1 O KA lawehala ana o ka mea hewa, oia ke olelo iloko o ko'u naau, Aohe weliweli i ke Akua imua o kona alo.   
\q1
\v 2 No ka mea, malimali oia ia ia iho imua o kona mau maka iho, A ikeia kona hewa he mea e hoowahawahaia.   
\q1
\v 3 O na olelo a kona waha he hewa ia a me ka hoopunipuni: Ua haalele oia i ka naauao a me ka hana maikai.   
\q1
\v 4 Kukakuka oia i ka hewa maluna o kona wahi moe; Ke ku nei no hoi ia ma ka aoao pono ole: Aole ia i hoowahawaha i ka hewa.   
\b  
\q1
\v 5 O kou aloha, e Iehova, aia no i ka lani; A o kou oiaio, e hiki aku no ia i ke ao.   
\q1
\v 6 O kou pono na like ia me na kuahiwi o ke Akua; A o kou hooponopono ana he moana nui no ia; Ua malama oe i ke kanaka a me ka holoholona.   
\q1
\v 7 Nani ka hemolele o kou lokomaikai, e ke Akua! Nolaila, e kanaho ai na keiki a kanaka i ka malu o kou mau eheu.   
\q1
\v 8 E oluolu loa lalkou i ka mea momona o kou hale; A e hoohainu oe ia lakou i ko ka muliwai o ka olioli nou.   
\q1
\v 9 No ka mea, aia no ia oe ke kumuwai o ke ola: A iloko o kou malamalama e ike ai makou i malamalama.   
\b  
\q1
\v 10 E hoomau oe i kou lokomaikai i ka poe ike ia oe, A me kou pono i ka poe naau pololei.   
\q1
\v 11 Mai noho a pa mai ke kapuwai o ka haaheo ia'u; Aole hoi o lawe aku ka lima o ka mea hewa ia'u.   
\q1
\v 12 Aia ka poe hana hewa ua hina; Ua hoohioloia lakou ilalo, aole e hiki ia lakou ke ku iluna.   
\c 37  
\b  
\q1
\v 1 MAI ukiuki oe no ka poe hana hewa; Aole hoi e huahua i na mea lawehala.   
\q1
\v 2 No ka mea, e oki koke ia lakou e like me ka mauu, A e mae hoi e like me ka laauikiai maka.   
\q1
\v 3 E hilinai aku ia Iehova, a e hana i ka pono; A e noho no oe ma ka aina, a e hanai io ia'ku oe.   
\q1
\v 4 E hauoli hoi oe ia Iehova, A e haawi mai no ia nou i ka makemake o kou naau:   
\q1
\v 5 Hookaa aku i kou aoao ia Iehova; E hilinai aku hoi ia ia. a nana no hoi e hana.   
\q1
\v 6 A e hoopuka mai hoi oia i kou pono e like me ka malamalama, A me kou hooponoponoia e like me ka la ku pono.   
\b  
\q1
\v 7 E noho malie ia Iehova, a e kali ahonui ia ia; Mai noho a ukiuki no ke kanaka e pookeokeo ana i kona aoao iho, No ke kanaka e hana ana ma na manao hewa.   
\q1
\v 8 E waiho i ka huhu, e haalele hoi i ka inaina; Mai nauki iki e hana hewa ai.   
\q1
\v 9 No ka mea, e okiia'ku ka poe hana hewa; Aka, o ka poe manaolana ia Iehova, e loaa ia lakou ka honua.   
\q1
\v 10 A liuliu iki aku, aole ka mea lawehala; Oiaio, e hoomanao ikaika oe i kona wahi, aole hoi ia.   
\q1
\v 11 Aka, e loaa ka honua i ka poe hoohaahaa; He hauoli lakou i ka pomaikai nui wale.   
\b  
\q1
\v 12 Kukakuka ku e ka mea hewa i ka mea pono, A nau iho la me kona mau niho ia ia.   
\q1
\v 13 E akaaka mai no nae ka Haku ia ia; No ka mea, ua ike oia i ke kokoke ana mai o kona la.   
\q1
\v 14 Ua unuhi ae la ka poe hewa i ka pahikaua, Ua lena hoi i ka lakou kakaka, E hoolilo i ka poe ilihune a me ka poe haahaa, A e hoomake hoi i ka poe e hele pono ana.   
\q1
\v 15 E komo no ko lakou pahikaua i ko lakou naau iho; A e uhakiia ka lakou kakaka.   
\b  
\q1
\v 16 Ua oi aku ka waiwai uuku o ke kanaka pono Mamna o ka waiwai nui o ka poe hewa he nui.   
\q1
\v 17 No ka mea, e uhakiia na lima o ka poe hewa; Aka, e hookupaa iho o Iehova i ka poe pono.   
\q1
\v 18 Ua ike o Iehova i na la o ka poe ku pono; A e mau loa ana no hoi ko lakou hooilina.   
\q1
\v 19 Aole lakou e hoka i ka manawa ino; A i ke kau wi e maona no lakou.   
\q1
\v 20 Aka, e make no ka poe hewa, A e like auanei oa enemi o Iehova me'ka momona o na keikihipa; E pau lakou i ke ahi, e lilo lakou i uahi.   
\q1
\v 21 Ua noi e lawe iki ka mea hewa i ka hai. aole nae i hoihoi mai: Aka e lokomaikai aka ka mea pono, a haawi wale aku no.   
\q1
\v 22 Nolaila o ka poe hoomaikaiia e ia e loaa ia lakou ka honua; Aka, o ka poe i hoinoia e ia e okiia lakou.   
\b  
\q1
\v 23 Ua hooku pono ia e Iehova na kapuwai o ke kanaka pono; Oluolu mai no oia i kona hele ana.   
\q1
\v 24 Ina e hina ia aole ia e hoohiolo loa ia: No ka mea, ua hookupaa o Iehova ia ia me kona lima.   
\q1
\v 25 Opiopio aku la au, a ua elemakule ae nei, Aole hoi au i ike i ka mea pono i haaleleia, Aole hoi i kana hua e makilo berena ana.   
\q1
\v 26 He aloha mau kona, a ua haawi aka no; Pomaikai no hoi kana hua.   
\b  
\q1
\v 27 E haalele i ka hewa, a e hana i ka pono; A e noho mau loa aku.   
\q1
\v 28 No ka mea, ua makemake no Iehova i ka hoopono ana: Aole ia i haalele i kona poe haipule; E hoomalu mau loa ia hoi lakou; Aka, e okiia ka hua a ka poe hewa.   
\q1
\v 29 E loaa ka aina i ka poe pono, A e noho mau lakou ilaila.   
\q1
\v 30 Ua olelo ka waha o ka mea pono ma ka naauao; A ua kamailio kona alelo ma ka hoopono ana.   
\q1
\v 31 Maloko o kona naau ke kanawai o kona Akua; Aole kapuwai ona e kapeke ai.   
\q1
\v 32 Kiai ka mea hewa i ka mea pono, A imi hoi ia e hoomake ia ia.   
\q1
\v 33 Aole e waiho mai o Iehova ia ia iloko o kona lima, Aole hoi e hoahewa ia ia i kona wa e hookolokoloia'i.   
\q1
\v 34 E hilinai aku ia Iehova, a e malama i kona aoao: A e hookiekie oia ia oe e komo i ka aina; Aia okiia ka poe hewa, e ike ako no oe ia.   
\b  
\q1
\v 35 Ua ike aku au i ke kanaka hewa e weliweli ai, E hoopalahalaha ana ia ia iho e like me ka laau uliuli i kona wahi iho.   
\q1
\v 36 Aka, ua hala aku la ia aia hoi, aole iho la ia; Oiaio, imi aku la au ia ia, aole hoi ia i loaa.   
\q1
\v 37 E noonoo i ke kanaka hemolele, E nana hoi i ka mea kupono: No ka mea, o ka hope o ua kanaka la, he pomaikai no ia.   
\q1
\v 38 Aka, e luku pu ia ka poe lawehala; A o ka hope o ka poe hewa, e okiia no ia.   
\q1
\v 39 Aka, no Iehova mai ke ola o ka poe pono: Oia ko lakou ikaika i ka wa popilikia.   
\q1
\v 40 A e kokua mai o Iehova ia lakou, a e hoakea mai ia lakou, E hoopakele oia ia lakou i ka poe hewa, A e hoola ia lakou. no ko lakou hilinai ana ia ia.   
\c 38  
\b  
\q1
\v 1 E IEHOVA, mai hoopai mai oe ia'u me kou huhu; Mai hahau mai ia'u me kou inaina nui.   
\q1
\v 2 No ka mea, ua haule mai kou mau pua maluna o'u, A ua kaomi ikaika mai kou lima ia'u.   
\q1
\v 3 Aole maikai ko'u io no kou huhu; Aole maha iloko o ko'u mau iwi no ko'u hewa.   
\q1
\v 4 No ka mea, ua kaa ae kuu mau hewa maluna o kuu poo; Me he mea kaumaha la, ua kaumaha loa ia ia'u.   
\q1
\v 5 Ua pilau ko'u mau eha, ua palahehe, No ko'u naaupo ana.   
\q1
\v 6 Ua pilikia au, ua kulou loa au ilalo; E u hele ana a po ka la.   
\q1
\v 7 Ua paapu ko'u mau puhaka i ka wela; Aohe wahi ola iloko o ko'u io.   
\q1
\v 8 Nawaliwali au, ua pope loa: Auwe aku la au no ka ikiki o ko'u naau.   
\b  
\q1
\v 9 E ka Haku, imua o kou alo ko'u makemake a pau; Aole i hunaia ia oe kuu auwe ana.   
\q1
\v 10 Ua naenae ko'u naau, ua maule kuu ikaika; O ka malamalama o kuu mau maka, ua haalele hoi ia ia'u.   
\q1
\v 11 O ko'u poe hoaaloha a me ko'u mau makamaka, ua ku mamao aku lakou i ka'u pilikia; A ua ku aku ko'u mau hoahanau ma kahi loihi.   
\q1
\v 12 O ka poe kii mai i kuu uhane, hoomoe lakou i na pahele: A o ka poe imi i mea e poino ai au, ke olelo nei lakou i na mea hewa; Noonoo hoi lakou ma ka hoopunipuni a po ka la,   
\b  
\q1
\v 13 Aka, me he kuli la, aole au i hoolohe aku; E like hoi me ke kanaka leo ole, i ekemu ole kona waha.   
\q1
\v 14 Pela hoi au e like me ke kanaka lohe ole, A iloko o kona waha aole ka hoopaapaa ana.   
\q1
\v 15 No ka mea, ke manaolana aku nei au ia oe, e Iehova; E hoolohe no hoi oe, e ka Haku ko'u Akua:   
\q1
\v 16 No ka mea, ua olelo au, O hauoli mai lakou maluna o'u: I ke kapeke ana o kuu wawae, haanui ku e lakou ia'u.   
\q1
\v 17 No ka mea, kokoke au e hina, Ke waiho mau nei ko'u kaumaha imua o'u.   
\q1
\v 18 No ka mea, e hai aku no au i kuu hewa, A e ehaeha hoi au no ko'u lawehala ana.   
\q1
\v 19 A o ko'u mau enemi e ola ana ua ikaika lakou; A ua lehulehu mai la ka poe inaina hewa mai ia'u.   
\q1
\v 20 O ka poe hoihoi i ka hewa no ka pono ua ku e mai lakou ia'u, No ko'u hahai ana i ka pono.   
\q1
\v 21 Mai noho a haalele mai ia'u, e Iehova; E kuu Akua, mai noho a mamao aku ia'u.   
\q1
\v 22 E wiki mai i ke kokua ia'u, E kuu Moi kuu mea e ola'i.   
\c 39  
\b  
\q1
\v 1 I IHO ia au, e malama au i ko'u hele ana, O hana hewa au me kuu alelo: E malama au i kuu waha me ka paawaha, I ka wa o ka mea lawehala imua o'u.   
\q1
\v 2 Ua mumule loa au me ka leo ole, Aole au i pane aku, aole i ka maikai; A ua hoola hou ia kuu kaumaha.   
\q1
\v 3 Wela mai kuu naau maloko o'u; I kuu noonoo ana aa iho la ke ahi; Olelo aku la hoi au me kuu alelo,   
\q1
\v 4 E hoiko mai ia'u, o Iehova, i ko'u hopena; A me ke ano o ka ana ana o kuu mau la, I ike au i ko'u palupalu ana.   
\q1
\v 5 Eia hoi, ua hoohalike oe i kuu mau la me ka palahalaha o ka peahilima; A me kuu mau makahiki me he mea ole la imua ou; He oiaio, he hanu wale no kela kanaka keia kanaka i kona hoonoho paa ia. Sila.   
\q1
\v 6 Oiaio, ke hele nei kela kanaka keia kanaka me he aka oiaio ole la: He oiaio, ma ka mea lapuwale i pihoihoi ai lakou: Hoahu ae la ia i ka waiwai aole hoi i ike i ka mea nana ia e ohi.   
\b  
\q1
\v 7 Ano hoi, heaha ka'u e kali nei, e ka Haku? O ko'u manao lana aia no maluna o'u.   
\q1
\v 8 E hookaawale aku i ko'u mau hewa a pau; Mai noho a hoolilo ia'u i mea e hoinoin'i e ka poe naaupo.   
\q1
\v 9 Ua mumule loa au, aole hoi o ekemu kuu waha; No ka mea, nau no i hana mai.   
\q1
\v 10 E lawe aku i kou hahau ana mai o'u aku nei: Ua pau e au i ka hahau ana mai o kou lima.   
\q1
\v 11 Aia hahau oe i ke kanaka me ka papa ana mai no kona hewa, Ua hoopau oe i kona nani me he mu la; Oiaio, he hanu wale no na kanaka a pau. Sila.   
\b  
\q1
\v 12 E hoolohe mai i ka'u pule, e Iehova, E haliu mai i ka pepeiao i ko'u kahea ana; Mai noho a hookuli i ko'u waimaka: No ka mea, he malihini au me oe, He mea noho iki e like me ko'u mau makua a pau.   
\q1
\v 13 E hookoe mai ia'u, i loaa hou mai ka ikaika ia'u. Mamua o ko'u hele ana aku, a e ole loa hoi.   
\c 40  
\b  
\q1
\v 1 U A kali ahonui aku la au ia Iehova, A maliu mai ia me ka hoolohe i ko'u hea ana.   
\q1
\v 2 Ua lawe mai oia ia'u mai loko mai o ka lua weliweli, Mai loko mai o ka lepo poho, A ua hooku i ko'u mau kapuwai maluna o ka pohaku, A ua hooku pono oia i kuu hele ana.   
\q1
\v 3 Ua haawi mai oia i ka mele hou iloko o kuu waha, I ka hoolea i ko kakou Akua: E ike auanei na mea he nui, a e weliweli hoi, A e hilinai aku hoi ia Iehova.   
\b  
\q1
\v 4 Pomaikai ke kanaka i hoolilo ia Iehova i mea e hilinai ai nona: Aole hoi i mahalo i ka poe haaheo, Aole hoi i ka poe kapae ma ka wahahee.   
\q1
\v 5 He nui na mea kupaianaha au i hana'i, e Iehova kuu Akua, A me ou manao ia makou; Aole ia e helu pololei ia'ku ia oe: Ina makemake au e hai heluhelu aku, Ua nui loa ia, aole e pau i ka heluia.   
\b  
\q1
\v 6 O ka mohai a me ka alana kau i makemake ole ai; O ko'u mau pepeiao kau i hoohakahaka mai ai; O ka mohalkuni a me ka mohailawehala kau i kauoha ole mai ai.   
\q1
\v 7 Alaila i aku la au, Eia, ke hele mai nei au; Ma ka buke palapala i kakauia'i no'u,   
\q1
\v 8 Ke hauoli nei au i ka hana aku i kou makemake, e ko'u Akua: Oiaio, o kou kanawai hoi eia iloko o ko'u naau.   
\b  
\q1
\v 9 Ua hai aku au i ka pono i ke anaina nui: Eia hoi, aole au i hoopaa i kuu mau lehelehe, E Iehova, ua ike no hoi oe.   
\q1
\v 10 Aole au i huna i kou pono iloko o ko'u naau; Ua hai aku no hoi au i kou oiaio a me kou ola: Aole au i huna i kou lokomaikai, a me kou oiaio, i ke anaina nui.   
\b  
\q1
\v 11 Mai aua mai oe i kou aloha ia'u, e Iehova; E hoomalu mau mai kou lokomaikai me kou oiaio ia'u.   
\q1
\v 12 No ka mea, ua hoopuni mai ia'u na mea ino, aole e pau i ka heluia: Ua lalau mai ko'u mau hewa ia'u, Aole hiki ia'u ke nana iluna: Ua oi aku lakou mamua o na lauoho o kuu poo: Nolaila i haalele ai ko'u naau ia'u.   
\b  
\q1
\v 13 E oluolu hoi oe, e Iehova, e hoola ia'u: E wiki mai, e Iehova, e kokua mai ia'u.   
\q1
\v 14 E hoohilahilaia, a e hoka pu ka poe imi mai i ko'u uhane e hoomake mai ia; E kipakuia'ku i hope ka poe i makemake e poino au.   
\q1
\v 15 E hooneoneoia hoi lakou i uku no ka hilahila o lakou, Ka poe i olelo mai ia'u, Aia la, aia la!   
\q1
\v 16 E hauoli aku a e olioli no hoi ia oe, Na mea a pau i imi aku ia oe: A e olelo mau ka poe makemake i kou ola, E hoonaniia'ku o Iehova.   
\q1
\v 17 Aka, ua haahaa au a me ka nele; Hoomanao mai no nae ka Haku ia'u: O oe no ko'u kokua a me ko'u Hoola; Mai hookaulua iki oe, e ko'u Akua.   
\c 41  
\b  
\q1
\v 1 POMAIKAI ke kanaka i manao i ka popilikia: E hoakea mai o Iehova ia ia i ka wa ino.   
\q1
\v 2 E hoomalu mai o Iehova a e hoomau i kona ola; A e hoopomaikaiia no ia maluna o ka honua; Aole hoi oe e haawi ia ia i ka makemake o kona poe enemi.   
\q1
\v 3 E hooikaika mai no hoi o Iehova ia ia maluna o kahi moe e nawaliwali ai: E pau no hoi ia oe kona moena i ka koomakaukauia i kona mai ana.   
\b  
\q1
\v 4 I aku la au, E Iehova, e aloha mai ia'u; E hoola i kuu uhane, no ka mea, ua hana hewa aku au ia oe.   
\q1
\v 5 Ke olelo hewa nei ko'u poe enemi no'u; Ahea la e make ia, a e lilo kona inoa?   
\q1
\v 6 Ina i hele mai ia e ike mai, Ua olelo no ia ma ka lapuwale; Houluulu hoi kona naau i ka hewa nona iho; A puka ia iwaho, hai aku la no ia.   
\q1
\v 7 Hawanawana ku e pu mai ia'u na mea a pau i inaina mai ia'u; Kukakuka ku e mai lakou i ka hewa no'u.   
\q1
\v 8 He mea ino ka i pili loa ia ia: A ke moe ia ia, aole e ala hou ae.   
\q1
\v 9 Oiaio, o ko'u hoaaloha a'u i hilinai aku ai, Ka mea i ai i ka'u berena, Oia ka i hapai ku e i kona kuekue wawae ia'u.   
\b  
\q1
\v 10 Aka, e aloha mai oe, e Iehova, ia'u; E hooku hou ia'u iluna e uku aku au ia lakou.   
\q1
\v 11 Ma keia mea i ike ai au i kou lokomaikai ana mai ia'u: No ka mea, aole i hooho olioli ko'u enemi maluna o'u.   
\q1
\v 12 A owau nei la, ke hooku paa nei oe ia'u i ko'u pono, Ke hoonoho mau ia'u imua o ko'u alo.   
\b  
\q1
\v 13 E hoomaikai mau ia'ku o Iehova ke Akua o Iseraela, Mai ke ao kumu ole, a i ke ao pau ole. Amene, Amene.   
\c 42  
\b  
\q1
\v 1 E LIKE me ka dia e makemake ana i ka wai kahe, Pela e makemake nei ko'u uhane ia oe, e ke Akua.   
\q1
\v 2 Ke makewai nei ko'u uhane i ke Akua, i ke Akua ola; Ahea la hiki aku au, a ikeia mai imua o ke Akua?   
\q1
\v 3 Ua lilo ko'u mau waimaka i ai na'u i ke ao a me ka po, Ia lakou i olelo mau mai ai ia'u, Auhea kou Akua?   
\q1
\v 4 A hoomanao aku au ia mau mea, ninini iho au i ko'u uhane iloko o'u: No ka mea, ua hele au me ka lehulehu, Hele pu no wau me lakou i ka hale o ke Akua, Me ka leo o ka olioli, a me ka hoolea, Me ke anaina malama i ka ahaaina.   
\b  
\q1
\v 5 No ke aha la oe e hoohaahaaia, e kuu uhane? No ke aha la oe i paumako ai iloko o'u? E manao laua aku oe i ke Akua; No ka mea, e hoolea auanei au ia ia, No ke kokua ana mai o kona maka.   
\q1
\v 6 E ko'u Akua, ua hoohaahaa ko'u uhane iloko o'u: Nolaila e hoomanao aku ai au ia oe ma ka aina Ioredane, A ma na Heremona a me ka mauna Mizara.   
\q1
\v 7 Ke kahea nei kekahi hohonu i kekahi hohonu, I ka halulu mau ana o kou waipuilani; Ua popoi mai na ale me na nalu maluna'e o'u.   
\q1
\v 8 Aka, i ke ao e kauoha mai o Iehova i kona lokomaikai, A i ka po, eia auanei me au ka mele nona, A me ka'u pule i ke Akua o ko'u ola nei.   
\b  
\q1
\v 9 E olelo aku au i ke Akua i ko'u Pohaku, No ke aha la oe e hoopoina mai ai ia'u? No ke aha la e u hele ai au no ka hooluhihewa ana mai o ka enemi?   
\q1
\v 10 Me he pahikaua la iloko o ko'u mau iwi, Ke hoino mai nei ko'u poe enemi ia'u; I ka lakou olelo ana mai ia'u i kela la i keia la, Auhea la kou Akua.   
\q1
\v 11 No ke aha la oe i hooliaahaaia'i, e ko'u uhane? No ke aha la oe i paumako ai iloko o'u? E hoolana i ka manao i ke Akua; No ka mea, e hoolea auanei au ia ia; Oia ke ola o ko'u maka, a me kuu Akua.   
\c 43  
\b  
\q1
\v 1 E HOOPONO mai oe ia'u, e ke Akua, No'u nei hoi e hakaka'i i ka lahuikanaka aloha ole: E hoopakele ia'u i ke kanaka hooopunipuni, me ka hoopono ole.   
\q1
\v 2 No ka mea, o oe no ko'u Akua e ikaika ai: No ke aha la oe e hoopailua mai ia'u? No ka aha la e u hele ai au no ka hooluhihewa ana mai o ka enemi?   
\b  
\q1
\v 3 E hoopnka i kou malamalama a me kou oiaio: E alakai ia mau mea ia'u; A e lawe hoi ia'u i kou mauna hoano, a i kou mau halelewa.   
\q1
\v 4 Alaila e hele au i ke kuahu o ke Akua, I ke Akua ko'u olioli nui: Oiaio, ma ka lira e hoolea aku ai au ia oe, e ke Akua ko'u Akua.   
\b  
\q1
\v 5 No ke aha la oe i hoohaahaaia'i, e kuu uhane? No ke aha la oe i paumako ai iloko o'u? E hoolana i ka manao i ke Akua; No ka mea, e hoolea auanei au ia ia: Oia ke ola o ko'u maka, a me kuu Akua.   
\c 44  
\b  
\q1
\v 1 E KE Akua, ua lohe makou me ko makou mau pepeiao, Ua hai mai ko makou mau makua ia makou, I na hana au i hana'i i ko lakou mau la, i na wa kahiko.   
\q1
\v 2 Kipaku aku la oe i na lahuikanaka me kou lima, a hookomo mai ia lakou la; Hoopilikia iho la oe i na kanaka a kiola aku la:   
\q1
\v 3 No ka mea, aole me ka lakou pahikaua iho i loaa ai ia lakou ka aina; Aole hoi no ko lakou lima ponoi i hoola iho ia lakou iho: Aka, o kou peahi akau, a me kou lima, a me ka malamalama o kou maka; No ka mea, ua lokomaikai mai oe ia lakou.   
\b  
\q1
\v 4 O oe no ko'u Alii, e ke Akua; E kauoha mai i ka hoola ana ia Iakoba.   
\q1
\v 5 Ma ou la e pahu aku ai makou i ko makou poe enemi: Ma kou inoa e hehi iho ai makou i ka poe ku e iluna ia makou.   
\q1
\v 6 No ka mea, aole ma kuu kakaka e hilinai aku ai au: Aole hoi e hoola mai ka'u pahikaua ia'u.   
\q1
\v 7 Aka, nau no makou i hoopakele i ko makou poe enemi, A ua hoohoka oe i ka poe i inaina mai ia makou.   
\q1
\v 8 Iloko o ke Akua e kaena ai makou a po ka la, A e hoomaikai mau loa aku i kou inoa. Sila.   
\b  
\q1
\v 9 Aka, ua haalele ae nei oe a ua hoohilahila ia makou; Aole hoi oe i hele pu me ko makou poe kaua.   
\q1
\v 10 A ua hoohuli oe ia makou i hope mai ka enemi mai; A o ka poe hoowahawaha ia makou, ua hao mai lakou no lakou iho.   
\q1
\v 11 Ua haawi oe ia makou me he mau hipa la e lilo i ai; Ua hoopuehu hoi ia makou iwaena o na lahuikanaka.   
\q1
\v 12 Ua kuai hoolilo aku oe i kou poe kanaka no ka mea ole, Aole hoi i hoomahuahua ma ka uku no lakou.   
\q1
\v 13 Ua waiho oe ia makou he mea e hoinoia iwaena o ko makou poe hoanoho, He mea e hoowahawaha ai a e henehene ai no ka poe e hoopuni ana ia makou.   
\q1
\v 14 Ua hoolilo oe ia makou i huaolelo ino, A i luli poo ana iwaena o na lahuikanaka.   
\q1
\v 15 E mau ana ko'u hoinoia imua o ko'u maka; A ua uhi mai ka hilahila o ko'u maka ia'u:   
\q1
\v 16 No ka leo o ka mea i hailiili a i hoino wale mai; No ka enemi hoi a me ka mea hoopai.   
\b  
\q1
\v 17 Ua pau ia mea i ke kau mai maluna o makou, Aole hoi makou i hoopoina ia oe; Aole hoi i hoopunipuni makou ma kou berita.   
\q1
\v 18 Aole i hoohuliia ko makou naau, Aole hoi i kapae ae ko makou mau kapuwai mai kou aoao ae;   
\q1
\v 19 Ua hanapepe loa oe ia makou ma kahi nahesa; A ua hoouhi mai oe ia makou me ka malu o ka make.   
\b  
\q1
\v 20 Ina i hoopoina makou i ka inoa o ko makou Akua, Ina i kikoo aku ko makou mau lima i kahi akua wahahee;   
\q1
\v 21 Aole anei i imi ke Akua ia mea? No ka mea, ua ike oia i na mea huna o ka naau.   
\q1
\v 22 Oiaio, nou makou i pepehiia'i a po ka la; Ua manaoia makou me he mau hipa la e hoomakeia.   
\q1
\v 23 E ala'e, o ke aha kou mea e hiamoe ai, e ka Haku? E ku mai hoi iluna, mai haalele mai ia makou a mau loa.   
\q1
\v 24 No ke aha la i huna ai oe i kou maka? A i hoopoina hoi i ko makou popilikia, a me ko makou hooluhihewaia?   
\q1
\v 25 No ka mea, ua kulou iho ko makou uhane i ka lepo; Ua pili ko makou opu i ka honua.   
\q1
\v 26 E ku mai oe e kokua no makou, A e hoola ia makou no kou aloha.   
\c 45  
\b  
\q1
\v 1 KE hoohu mai nei ko'u naau i ke mele maikai; Ke hai aku nei au i na mea a'u i hana'i no ke Alii; O ko'u alelo ka peni a me ka mea kakau wikiwiki.   
\q1
\v 2 Ua oi kou nani mamua o na keiki a kanaka: Ua nininiia ka maikai iloko o kou mau lehelehe; Nolaila, ua hoomaikai mau loa ke Akua ia oe.   
\b  
\q1
\v 3 E kaei oe i kau pahikaua ma kou uha, e ka Mea mana, Me kou nani a me kou hanohano.   
\q1
\v 4 A iloko o kou hanohano e holokaa pomaikai ai, No ka oiaio a me ke akahai, a me ka pono; A a ao iho kou lima akau ia oe i na mea weliweli   
\q1
\v 5 Ua oi aku kou mau pua iloko o ka naau o ko ke alii poe enemi; Hina iho na kanaka malalo iho ou.   
\b  
\q1
\v 6 O kou nohoalii, e ke Akua, e mau loa ana no ia: O ka hoailonamoi o kou aupuni. he hoailonamoi pono no ia.   
\q1
\v 7 Makemake no oe i ka pono, A hoowahawaha no oe i ka hewa: Nolaila ke Akua, kou Akua i poni ai ia oe, Ma ka aila olioli maluna o kou mau hoa.   
\q1
\v 8 Ke aala pu mai nei kou mau kapa a pau i ka mura, a me ka aloe, a me ke kasia; Noloko mai o na halealii nihoelepani i hoohauoli ai lakou ia oe.   
\q1
\v 9 O na kaikamahine a na'lii kekahi iwaena o kou mau wahine hanohano; Ma kou lima akau i ku mai ai ke alii wahine me ke gula noopira.   
\b  
\q1
\v 10 E hoolohe mai, e ke kaikamahine, a e hoomanao, A e haliu mai i kou pepeiao; E hoopoina hoi i kou poe kanaka, a me ka hale o kou makuakane;   
\q1
\v 11 Pela hoi, e makemake nui ai ke alii i kou nani: No ka mea, oia kou Haku; E hoomana aku hoi oe ia ia.   
\q1
\v 12 O ke kaikamahine o Turo me ka makana; A o ka poe waiwai o na kanaka e imi i ka hooluolu ia oe.   
\b  
\q1
\v 13 He nani loa maloko ke kaikamahine a ke alii; O kona kapa he gula i ulanaia no ia.   
\q1
\v 14 E laweia mai oia i ke alii iloko o na kapa hoonionioia; O na kaikamahine kona mau hoanoho, e hahai ana mamuli ona, E lawe pu ia mai lakou ia oe.   
\q1
\v 15 Me ka olioli, a me ka hauoli ana e laweia mai lakou: E komo no hoi lakou iloko o ko ke alii halealii:   
\b  
\q1
\v 16 Ma ka hakahaka o kou mau makua, malaila auanei kau mau keiki, Au e hoolilo ai i alii ma ka honua a pau.   
\q1
\v 17 E hoomaikai mau aku au i kou inoa i na hanauna a pau; Nolaila e hoolea na kanaka ia oe a mau loa.   
\c 46  
\b  
\q1
\v 1 O KE Akua ka puuhonua a me ka ikaika o kakou, He kokua kokoke loa i ka popilikia ana.   
\q1
\v 2 Nolaila, aole makou e makau ke laweia'ku ka honua, A ke haliia'ku na mauna iwaena konu o ka moana;   
\q1
\v 3 Ke halulu hoi kona mau wai me ke kupikipikio, Ke haalulu hoi na mauna i kona hookiekie ana. Sila.   
\b  
\q1
\v 4 He muliwai nae i hoohauoli ai kona mau waikahe i ke kulanakauhale o ke Akua, I kahi hoano o na halelewa o ka mea kiekie loa.   
\q1
\v 5 O ke Akua ka iwaena konu ona, Aole ia e hoonauweweia: E kokua mai ke Akua ia ia i ka wehe ana'e o ke alaula.   
\q1
\v 6 Kupikipikio ae la na lahuikanaka, Nauwewe ae la na aupuni: Haawi mai la oia i kona leo, Hehee iho la ka honua.   
\q1
\v 7 O Iehova Sabaota, oia me kakou: O ko Iakoba Akua ko kakou wahi e malu ai. Sila.   
\b  
\q1
\v 8 E hele mai e nana i na hana a Iehova, I kona hooneoneo ana ma ka honua.   
\q1
\v 9 Ke hooki mai nei oia i na kaua a i ka welau o ka honua; Uhaki oia i ke kakaka, Oki pu hoi oia i ka ihe a kaawale; Hoopau hoi oia i ke kaakaua i ke ahi.   
\q1
\v 10 E noho malie, a e ike hoi e, Owau no ke Akua. E hapaiia au iwaena o na lahuikanaka; E hookiekieia hoi au ma ka honua.   
\q1
\v 11 O Iehova Sabaota oia me kakou; O ko Iakoba Akua ko kakou wahi e malu ai. Sila.   
\c 47  
\b  
\q1
\v 1 E PAIPAI i ko oukou mau lima, e na lahuikanaka a pau; E hooho i ke Akua me ka leo olioli.   
\q1
\v 2 No ka mea, he mea e weliweli ai o Iehova ka mea kiekie loa: He Alii nui ia maluna o ka honua a pau.   
\q1
\v 3 E hoohaahaa iho oia i ka poe kanaka malalo iho o kakou, A me na lahuikanaka malalo iho o ko kakou mau kapuwai.   
\q1
\v 4 E koho mai no hoi oia i hooilina no kakou, I ka nani o Iakoba ana i aloha mai ai. Sila.   
\b  
\q1
\v 5 Ua pii ae nei ke Akua me ka hooho, O Iehova me ke kani ana o ka pu.   
\q1
\v 6 E hoolea aku i ke Akua, e hoolea oukou: E hoolea aku i ko kakou Alii, e hoolea oukou.   
\q1
\v 7 No ka mea, o ke Akua ke Alii o ka honua a pau; E hoolea aku oukou me ka naauao.   
\q1
\v 8 E alii ana no hoi ke Akua maluna o na lahuikanaka; Ke nobo mai la ke Akua maluna o kona nohoalii hoano.   
\q1
\v 9 Ua akoakoa na'lii o na kanaka, O na kanaka o ke Akua no Aberahama; No ke Akua na palekaua o ka honua; Ua hapai nui ia'ku no hoi ia.   
\c 48  
\b  
\q1
\v 1 HE nui no Iehova, e hoomaikai nui ia'ku, Iloko o ke kulanakauhale o ko kakou Akua i kona mauna hoano.   
\q1
\v 2 He nani no ke kiekie ana, he mea olioli no ka honua a pau, O Mauna Ziona ma na aoao kukuluakau, ke kulanakauhale o ke Alii nui.   
\q1
\v 3 Iloko o kona mau halealii, I ikeia'i ke Akua he puuhonua.   
\b  
\q1
\v 4 No ka mea, aia hoi, ua akoakoa na'lii, Maalo pu ae la lakou.   
\q1
\v 5 Ike iho la lakou a mahalo iho la; I makau lakou, a holo aku la.   
\q1
\v 6 Loohia lakou e ka makau malaila, A me ka eha e like me ko ka wahine haakokohi.   
\q1
\v 7 Me ka makani hikina i wawahi ai oe i na moku o Taresisa.   
\q1
\v 8 E like me ko kakou lohe, pela kakou i ike ai, Ma ke kulanakauhale o Iehova Sabaota, Ma ke kulanakauhale o ko kakou Akua: E hoonoho paa loa ke Akua ia ia a mau loa. Sila.   
\b  
\q1
\v 9 Ua noonoo makou i kou lokomaikai, e ke Akua, Iwaena konu o kou luakini.   
\q1
\v 10 E like me kou inoa, e ke Akua, Pela ka hoolea nou a hiki i na welelau o ka honua; Ua piha kou lima akau i ka pono.   
\q1
\v 11 E hauoli o mauna Ziona, E olioli pu na kaikamahine a Iuda, No kou hooponopono ana.   
\q1
\v 12 E kaahele oukou ia Ziona, E hele poai ia ia a puni; E helu i kona mau halekaua.   
\q1
\v 13 E hoomaopopo ko oukou naau i kona mau pakaua; E noonoo hoi i kona mau halealii, I hiki ia oukou ke hai aku i ka hanauna mahope aku.   
\q1
\v 14 No ka mea, o ke Akua nei oia ko kakou Akua i ke ao pau ole; He alakai auanei ia no kakou a i ka make.   
\c 49  
\b  
\q1
\v 1 E HOOLOHE mai i keia, e na kanaka a pau: E haliu maikai i ka pepeiao, e ka poe a pau e noho ana ma ke ao nei:   
\q1
\v 2 Na mea haahaa a me na mea kiekie, Pau pu hoi ka poe waiwai, a me ka poe waiwai ole.   
\q1
\v 3 E olelo aku kuu waha i ke akamai; A ma ka naauao ka manao ana o ko'u naau.   
\q1
\v 4 E haliu aku au i kuu pepeiao i ka olelo nane; E hoomaka au i kuu mele ma ka lira.   
\b  
\q1
\v 5 O ke aha kuu mea e makau ai, i na la ino, E hoopuni mai ai ka poe ku e malu mai ia'u?   
\q1
\v 6 O ka poe hilinai i ko lakou ikaika iho, A i hoomaikai ia lakou iho no ka nui o ko lakou waiwai;   
\q1
\v 7 Aohe mea o lakou e hiki ia ia ke hoopakele i kona hoahanau; Aole hoi e haawi i ka uku hoola i ke Akua nona;   
\q1
\v 8 (No ka mea, o ka hoola ana i ko lakou uhane, he nui ke kumukuai; A ua oki mau loa no ia;)   
\q1
\v 9 I ola mau loa oia, a i ole hoi e ike i ka palaho.   
\b  
\q1
\v 10 No ka mea, ua ike no ia ua make na kanaka naauao, Pela hoi ua make ka mea naaupo a me ka mea manao ole, A waiho hoi lakou i ko lakou waiwai no na mea e.   
\q1
\v 11 O ko lakou manao oloko e mau loa ko lakou mau hale, A me ko lakou mau wahi e noho ai ia hanauna aku ia hanauna aku: Mamuli o ko lakou inoa iho i kapa ai lakou i ko lakou mau aina.   
\q1
\v 12 Aka, o ke kanaka iloko o ka hanohano, aole i mau; Ua like ia me na holoholona i hoopauia.   
\b  
\q1
\v 13 O keia aoao o lakou o ko lakou lapuwale no ia: Aka, ua hoopono ko lakou mau hope i ko lakou mau olelo. Sila.   
\q1
\v 14 Me he mau hipa la ua waihoia lakou i ka luakupapau: E ai no ka make ia lakou; E lanakila ka poe pono maluna o lakou i ke kakahiaka; A e pau e ko lakou nani iloko o ka luakupapau, mai kona wahi i noho ai.   
\q1
\v 15 Aka, e hoopakele ke Akua i kuu uhane i ka lima o ka malu o ka make; No ka mea, e hookipa no oia ia'u. Sila.   
\b  
\q1
\v 16 Mai makau oe i ka waiwai nui ana o kekahi, I ka wa e mahuahua ai ka nani o kona hale;   
\q1
\v 17 No ka mea, i kona make ana, aohe mea kana e lawe pu ai; Aole e iho kona nani mamuli ona.   
\q1
\v 18 Aka hoi, i kona ola ana, ua hoomaikai oia i kona uhane; A e mahalo ae na kanaka ia oe i kou wa e hana maikai ai ia oe iho.   
\q1
\v 19 E hele no oia i ka hanauna o kona mau makua; Aole lakou e ike i ka malamalama.   
\q1
\v 20 O ke kanaka iloko o ka hanohano, me ka naauao ole, Ua like ia me na holoholona i hookiia.   
\c 50  
\b  
\q1
\v 1 U A olelo mai no ke Akua mana, o Iehova, Ua kahea mai oia i ka honua mai ka hikina a ka la a i ke komohana.   
\q1
\v 2 Mai loko mai o Ziona ka hemolele o ka nani, I hoomalamalama mai ai ke Akua.   
\q1
\v 3 E hele mai ana no ko kakou Akua, aole e noho wale: E ai no hoi ke ahi imua ona. A e ikaika mai ka ino a puni ia.   
\q1
\v 4 E kahea oia i ka lani mai luna mai, A i ka honua hoi, e hooponopono oia i kona poe kanaka.   
\q1
\v 5 E houluulu mai oukou i ko'u mau haipule io'u nei, I ka poe i berita mai me au nei ma ka mohai.   
\q1
\v 6 E hoike hoi ka lani i kona pono; No ka mea, o ke Akua oia ka Lunakanawai. Sila.   
\b  
\q1
\v 7 E hoolohe mai, e ko'u poe kanaka, a e olelo aku au; E Iseraela, a e hoike ku e au ia oe; Owau no ke Akua, kou Akua no.   
\q1
\v 8 Aole au e hoahewa ia oe no kou mau alana, A me kou mau mohaikuni i mau imua o ko'u alo.   
\q1
\v 9 Aohe bipi kane ka'u e lawe ai mai loko mai o kou hale; Aole hoi kao kane mai loko mai o kou mau pa holoholona:   
\q1
\v 10 No ka mea, na'u no na holoholona a pau o ka ululaan, A me na holoholona laka maluna o na puu he tausani.   
\q1
\v 11 Ua ike au i na manu a pau o na mauna; No'u no hoi na holoholona o ke kula.   
\q1
\v 12 Ina i pololi au, aole au e hai aku ia oe; No ka mea, no'u no ke ao nei a me kona mea e piha ai.   
\q1
\v 13 E ai anei au i ka io o na bipikane? E inu anei au i ke koko o na hipa kane?   
\q1
\v 14 E mohai i ka hoomaikai ana i ke Akua; A e haawi i ka mea kiekie loa i kau mea i hoohiki ai nona:   
\q1
\v 15 A e kahea mai ia'u i ka la popilikia; A e hoopakele au ia oe, a e hoonani mai no hoi oe ia'u.   
\b  
\q1
\v 16 Aka, ke olelo nei ke Akua i ka mea hewa, Heaha kau e hai aku ai i ko'u mau kanawai? A e lawe ai i kuu berita ma kou waha?   
\q1
\v 17 No ka mea, he hoowahawaha kou i ke aoia'na; A ke kiola nei oe i ka'u olelo mahope aku ou.   
\q1
\v 18 A i kou wa i ike ai i ka aihue, ua ae pu oe me ia: Ua lawe pu oe me na mea moe kolohe.   
\q1
\v 19 Ke haawi nei oe i kou waha i ka ino, A ke hookui nei kou alelo i ka hoopunipuni.   
\q1
\v 20 Ke noho nei oe me ka hoino i kou hoahanou; Ke aki wale nei oe i ke keiki a kou makuwahine.   
\q1
\v 21 Oia na mea au i hana'i, a hookuli hoi au; Manao iho la oe, he mea like loa au me oe; Aka, e hoahewa au ia oe, a e hoonohonoho pono imua o kou alo.   
\b  
\q1
\v 22 E hoomanao oukou i keia, ano, e ka poe hoopoina i ke Akua, O haehae aku au, aole hoi he mea e ola'i.   
\q1
\v 23 O ka mea mohai i ka hoolea no'u oia ke hoonani mai ia'u: O ka mea hoopono i kona hele ana o ka'u ia e hoike ai i ke ola o ke Akua.   
\c 51  
\b  
\q1
\v 1 E ALOHA mai oe ia'u, e ke Akua, e like me kou lokomaikai; Mamuli o ka nui loa o kou aloha e hoopau i ko'u mau hala.   
\q1
\v 2 E holoi lea mai ia'u i pau kuu hewa; A e hoomaemae mai hoi ia'u i ko'u lawehala ana.   
\q1
\v 3 No ka mea, ke hoike aku nei au i ko'u mau hala; Mau no hoi ko'u hewa imua o kuu alo.   
\q1
\v 4 O oe, oe wale no ka'u i lawehala ai, A i hana hewa hoi imua o kou mau maka: I pono oe i kau olelo ana, I hemolele hoi i kuu hoahewa ana mai.   
\b  
\q1
\v 5 Eia hoi, ua hanaia au maloko o ka hewa; Maloko o ka lawehala ana i hapai ai ko'u makuwahine ia'u.   
\q1
\v 6 Eia hoi, makemake oe i oiaio ko loko; A maloko o na wahi nalo e hoikeike mai oe ia'u i ka naauao.   
\q1
\v 7 E huikala mai oe ia'u me ka husopa, a e maemae no wau: E holoi mai ia'u, a e oi aku kuu keokeo i ko ka hau.   
\q1
\v 8 E haawi mai e lohe au i ka hauoli a me ka olioli; I hauoli hoi na iwi au i uhaki mai ai.   
\q1
\v 9 E huna oe i kou maka i ko'u mau lawehala ana, A e hoopau i ko'u mau hewa a pau.   
\b  
\q1
\v 10 E haawi mai i naau maemae no'u, e ke Akua; E hana hou mai hoi i uhane kupono iloko o'u.   
\q1
\v 11 Mai kiola ae oe ia'u mai kou alo ae; Aole hoi e lawe aku i kou Uhane Hemolele mai o'u aku nei.   
\q1
\v 12 E hoihoi mai ia'u i ka hauoli no kou ola; A e kokua mai ia'u me kou Uhane lokomaikai.   
\q1
\v 13 Alaila, e ao aku au i na lawehala i kou mau aoao; A e hoohuliia na kanaka hewa ia oe.   
\b  
\q1
\v 14 E hoopakele ae ia'u i na koko, e ke Akua, e ko'u Akua e ola'i; A e himeni leo nui aku au i kou pono.   
\q1
\v 15 E ka Haku, e wehe mai oe i ko'u lebelehe; A e hoike aku ko'u waha i kou hoolea.   
\q1
\v 16 No ka mea, aole oe i makemake i ka alana; Alaila, e haawi aku no wau ia; Aole oe i oluolu mai i na mohaikuni.   
\q1
\v 17 O na mohai no ke Akua oia ka uhane mihi: O ka naau mihi me ka pepe, o kau ia, e ke Akua e hoowahawaha ole ai.   
\b  
\q1
\v 18 E hana maikai mai oe ia Ziona i kou lokomaikai: E kukulu hoi oe i na pa o Ierusalema.   
\q1
\v 19 Alaila, e oluolu mai oe i na mohai o ka pono, I na mohaikuni, na mohaikuni okoa hoi; Alaila e kaumaha aku lakou i na bipi maluna o kou kuahu.   
\c 52  
\b  
\q1
\v 1 NO ke aha la e hoonui ai oe ma ka hewa, e ke kanaka ikaika? E mau loa ana no ka lokomaikai o ke Akua.   
\q1
\v 2 Ua hoomakaukau kou alelo i na mea hewa; Me he pahi umiumi la, e hana malu ana.   
\q1
\v 3 Makemake no oe i ka ino, aole i ka maikai; A i ka hoopunipuni ana hoi, aole i ka olelo i ka pono. Sila.   
\q1
\v 4 Makemake no oe i na olelo a pau e pau ai, E ke alelo kumakaia.   
\b  
\q1
\v 5 E hoohiolo mai no hoi ke Akua ia oe a mau loa, E kiola aku oia ia oe, a kaili aku mai loko aku o kou wahi i noho ai, A e uhuki ae hoi oia ia oe mailoko ae o ka aina o ka poe ola. Sila.   
\q1
\v 6 E ike no hoi ka poe pono, a e weliweli, A e akaaka lakou ia ia.   
\q1
\v 7 Aia hoi, oia ke kanaka i lawe ole i ke Akua i ikaika nona; Aka, ua hilinai i ka nui o kona waiwai iho, A ua hooikaika ia ia iho iloko o kona hewa.   
\b  
\q1
\v 8 Aka, he mea like au me ka laauoliva uliuli iloko a ka hale o ke Akua; E hilinai mau aku wau i ke aloha o ke Akua a mau loa aku.   
\q1
\v 9 E hoolea mau loa aku au ia oe, No ka mea, nau no ia i hana; E hilinai hoi au i kou inoa; No ka mea, he pono ia imua o kou poe haipule.   
\c 53  
\b  
\q1
\v 1 U A olelo ka aia iloko o kona naau, Aohe Akua. Ua hewa pu lakou, ua hana hoi lakou i na mea e inainaia; Aohe mea i hana ma ka pono.   
\q1
\v 2 Nana mai la ke Akua mai luna mai o ka lani i na keiki a kanaka, I ike mai i kekahi mea naauao paha e imi ana i ke Akua.   
\q1
\v 3 Pau lakou i ka hoi hope pu; Pau pu lakou i ka haumia; Aohe mea hana maikai, aole loa hookahi.   
\b  
\q1
\v 4 Aole anei naauao iki ko ka poe hana hewa? Ka poe e pau ai ko'u poe kanaka i ka aiia, E like me ko lakou ai ana i ka berena: Aole lakou i kahea i ke Akua.   
\q1
\v 5 Malaila makau loa lakou ma kahi makau ole; No ka mea, ua hoohelelei ke Akua i na iwi o ka mea hoomoana ku e ia oe: Ua hoohilahila oe ia lakou, No ka mea, ua hoowahawaha mai ke Akua ia lakou.   
\q1
\v 6 Nawai la ke ola e haawi mai i ka Iseraela mailoko mai o Ziona? Aia hoihoi mai ke Akua i ke pio ana o kona poe kanaka, E hauoli no o Iakoba, e olioli no hoi o Iseraela.   
\c 54  
\b  
\q1
\v 1 E KE Akua, e hoola mai oe ia'u ma kou inoa; A e hoopono mai ia'u ma kou ikaika.   
\q1
\v 2 E ke Akua, e hoolohe mai i ka'u pule; E haliu mai i ka pepeiao i na olelo a kuu waha:   
\q1
\v 3 No ka mea, ua ku e mai ia'u na kanaka e, A ke imi nei i kuu uhane na mea hooluhihewa; Aole lakou i hoonoho i ke Akua i mua o ko lakou alo. Sila.   
\b  
\q1
\v 4 Eia hoi, o ke Akua ko'u kokua; O ka Haku oia pu me ka poe kokua i ko'u uhane.   
\q1
\v 5 E uku auanei oia i ka ino maluna o ka poe ku e ia'u; E oki iho oe ia lakou i kou oiaio.   
\b  
\q1
\v 6 E mohai oluolu aku au nou; E hoelea aku au ia oe, e Iehova, no ka mea, he pono ia.   
\q1
\v 7 No ka mea, ua hoopakele oia ia'u i ka popilikia a pau; A ua nana ae nei ko'u maka i ko'u poe enemi.   
\c 55  
\b  
\q1
\v 1 E HALIU mai i ka pepeiao i ka'u pule, e ke Akua, Mai hoonalo ia oe iho mai ka'u nonoi ana aku.   
\q1
\v 2 E nana mai ia'u a e hoolohe mai ia'u; Ke u nei au i ko'u manao ana, me ka auwe;   
\q1
\v 3 No ka leo o ka enemi, No ka hooluhi hewa ana mai o ka mea hewa: No ka mea, ua hooili mai lakou i ka hewa maluna o'u, A i ka ukiuki ua inaina mai lakou ia'u.   
\b  
\q1
\v 4 Ua ehaeha loa ko'u naau iloko o'u; A ua haule mai ko ka make mau mea weliweli maluna o'u.   
\q1
\v 5 Ua kau mai maluna o'u ka makau a me ka haalulu; Ua popoiia mai au e ka weliweli.   
\q1
\v 6 A olelo iho la au, Owai ka mea e haawi ia'u i mau eheu me he manu nunu la? E lele aku au i kahi e, a e hoomaha iho.   
\q1
\v 7 Aia hoi e hele kaawale loa aku au, A e noho ma ka waonahele. Sila.   
\q1
\v 8 Alaila e hoolalelale au i kuu pakele ana, I ka makani nui o ka ino.   
\b  
\q1
\v 9 E hookae, e Iehova, a hoomokuahana i ka lakou mau alelo: No ka mea, ua ike au i ka hooluhi wale a me ka hakaka ana malok'o o ke kulanakauhale.   
\q1
\v 10 I ke ao, a me ka po, i holoholo ai lakou maluna o kona mau pa; He kolohe, a he pioloke ka iwaena konu ona.   
\q1
\v 11 Iwaena konu ona ka hana hewa ana; Aole haalele ka hoopunipuni a me ka wahahee i kona mau alanui.   
\b  
\q1
\v 12 No ka mea, aole he enemi, ka i hoino mai ia'u; Ina pela hiki no ia'u ke hoomanawanui: Aole ka mea inaina mai ia'u ka i hookiekie ku e mai ia'u; Ilaila i pee aku ai au mai ona aku la:   
\q1
\v 13 Aka, o oe no ia, he kanaka e ku like ana me au, Ka'u punahele, a o ko'u hoalauna hoi.   
\q1
\v 14 Ua kamailio oluolu pu kaua, A ua hele pu i ka hale o ke Akua me ka lehulehu.   
\q1
\v 15 E lalau mai ka make ia lakou, E iho koke lakou ilalo i ka malu o ka make; No ka mea, he hewa ko loko o ko lakou mau hale, a iwaena o lakou.   
\b  
\q1
\v 16 Aka, owau nei la, e kahea aku au i ke Akua; A e hoola mai no o Iehova ia'u.   
\q1
\v 17 I ke ahiahi, i ke kakahiaka, i ke awakea, e pule aku ai au, A e kahea nui aku au; a e hoolohe mai oia i ko'u leo.   
\q1
\v 18 Me ka maluhia e hoopakele oia i ko'u uhane i ke kaua mai ia'u; No ka mea, ua nui ka poe me au.   
\q1
\v 19 E hoolohe mai no ke Akua, a e hoohaahaa ia lakou, O ka mea mai kahiko mai. Sila. No ka mea, aohe o lakou luli ana; Nolaila, aole o lakou makau i ke Akua.   
\q1
\v 20 Ua kikoo oia i kona lima i ka mea e kuikahi ana me ia; Ua uhai oia i kana berita.   
\q1
\v 21 Ua oi aku ka pahee o kana mau olelo mamua o ko ka bata, Aka, he kaua ko loko o kona naau: Ua oi aku ka oluolu o kana mau olelo i ko ka aila; Aka, he mau pahikaua unuhiia lakou.   
\b  
\q1
\v 22 E waiho aku i kau mea kaumaha maluna o Iehova, A e Kokua mai oia ia oe: Aole loa ia e waiho mai i ka mea pono e hoonauweia.   
\q1
\v 23 Aka, e ke Akua, e hoohaahaa iho oe ia lakou i ka lua o ka make: O na kanaka koko a me ka hoopunipuni, aole lakou e ola a pau ka hapalua o ko lakou mau la; Aka, e hilinai aku au ia oe.   
\c 56  
\b  
\q1
\v 1 E ALOHA mai ia'u, e ke Akua; No ka mea, e ale mai paha na kanaka ia'u; E paio aua i kela la i keia la, ua hooluhihewa mai oia ia'u.   
\q1
\v 2 E ake ko'u mau enemi e ale ia'u i kela la i keia la; No ka mea, he nui no ka poe e kaua ana ia'u, e ka Mea kiekie loa.   
\q1
\v 3 I ko'u manawa e makau ai, E hilinai aku au ia oe.   
\q1
\v 4 Iloko o ke Akua e mahalo au i kana olelo; O ke Akua ka'u i hilinai aku ai, aole au e makau; Heaha ka ka io o hana mai ai ia'u?   
\q1
\v 5 I kela la i keia la, ua hookahuli lakou i ka'u mau olelo; Pau ko lakou mau manao i ke ku e ia'u no ka hewa.   
\q1
\v 6 Ua akoakoa lakou, ua pee iho la hoi, Ua nana mai lakou i ko u mau kapuwai, I ko lakou kakali ana i ko'u uhane.   
\q1
\v 7 He pakele anei ko lakou ma ka hewa? I ka huhu, e kiola iho ai i na kanaka, e ke Akua,   
\b  
\q1
\v 8 Ua helu oe i ko'u auwana ana: E ukuki oe i ko'u waimaka i kou omole: Aole anei ia iloko o kau buke?   
\q1
\v 9 Aia kahea aku au, alaila e hoi ihope ko'u enemi: Ua ike au ia mea, no ka mea, mamuli o'u ke Akua.   
\q1
\v 10 Iloko o ke Akua e mahalo mau au i ka olelo: Iloko o Iehova e hoomaikai au i ka olelo:   
\q1
\v 11 Maluna o ke Akua i hilinai aku ai au, aole e makau; Heaha ka ke kanaka e hana mai ai ia'u?   
\q1
\v 12 Maluna o'u ka berita ana nou, e ke Akua: E haawi aku au i ka hoolea ia oe.   
\q1
\v 13 No ka mea, ua hoopakele oe i ko'u uhane i ka make: Aole anei e hoopakele i ko'u mau kapuwai i ka hina ana? I hele au imua o ke Akua ma ka malamalama o ka poe ola.   
\c 57  
\b  
\q1
\v 1 E ALOHA mai ia'u, e ke Akua, e aloha mai oe ia'u: No ka mea, ke hilinai aku nei ko'u uhane ia oe: Oiaio ma ka malu o kou mau eheu e kanaho ai au, A hala loa aku keia mau mea e poino ai.   
\q1
\v 2 E kahea aku au i ke Akua kiekie loa, I ke Akua nana i hana mai no'u.   
\q1
\v 3 E hoouna mai no oia mai ka laui mai, A e hoopakele mai ia'u i ka nuku ana o na mea manao e ale mai ia'u. Sila. E hoouna no ke Akua i kona aloha a me kona oiaio.   
\b  
\q1
\v 4 Eia ko'u uhane iwaena o na liona; Ke moe nei au me ka poe i hoaia, Na keiki a kanaka o ko lakou mau niho he mau ihe me na pua; A he pahikaua oi ko lakou alelo.   
\q1
\v 5 E hapaiia'ku oe, e ke Akua, maluna o na lani: A o kou nani hoi maluna o ka honua a pau.   
\q1
\v 6 Ua hoomakaukau lakou i ka upena no ko'u mau kapuwai; Ua kulou iho ko'u uhane: Ua eli lakou i ka lua mamua o'u, A iwaena konu ona i haule ai lakou. Sila.   
\b  
\q1
\v 7 Ua paa ko'u naau, e ke Akua, ua paa ko'u naau, E oli aku au, a e hoolea hoi.   
\q1
\v 8 E ala'e, e kuu nani, e ala, e ka violaumi a me ke kinora; Owau nei hoi kekahi e ala'e i ka wanaao.   
\q1
\v 9 E hoolea aku au ia oe iwaena o na kanaka, e ka Haku; E himeni aku au ia oe iwaena o na lahuikanaka.   
\q1
\v 10 No ka mea, he nui kou aloha a hala i na lani, A me kou oiaio a hiki i na ao.   
\q1
\v 11 E hapaiia'ku oe, e ke Akua, maluna o na lani; A me kou nani maluna o ka honua a pau.   
\c 58  
\b  
\q1
\v 1 KE olelo nei auei oukou i ka pono, e ke anaina? Ke hooponopono pololei anei oukou, e na keiki a kanaka?   
\q1
\v 2 Ua hana io nae oukou i ka hewa maloko o ko oukou naau: Ke kaupaona nei hoi oukou i ka lawe wale ana o ko oukou mau lima ma ka honua.   
\q1
\v 3 Ua aea wale ka poe hewa mai ka opu mai; Ua auwana lakou mai ka hanau ana, e olelo wahahee ana.   
\q1
\v 4 O ko lakou aa make, ua like ia me ka awaawa make o ka nahesa; Ua like lakou me ka moopetena kuli i papani i kona pepeiao;   
\q1
\v 5 Ka mea e lohe ole no i ka leo o ka poe hoowalewale, E hoowale wale ana me ke akamai loa.   
\b  
\q1
\v 6 E uhai ae i ko lakou mau niho, e ke Akua, iloko o ko lakou waha; E uhai oe i na niho o na liona opiopio, e Iehova.   
\q1
\v 7 E hehee lakou, me he mau wai la e kahe mau ana, Aia lena oia no kana mau pua, E lilo lakou me he mau mea la i okiokiia.   
\q1
\v 8 Me he pupu la e hehee ana, e hele e aku lakou a pau; Me he mea hanau e la ka wahine, e ike ole lakou i ka la.   
\q1
\v 9 Mamua o ka wela ana o ka oukou mau ipuhao i ke kakalaioa, E lawe aku oia ia lakou me ka ino makani, I ko lakou ola ana, a i kona huhu.   
\b  
\q1
\v 10 E hauoli ka mea pono i kona ike ana i ka hoopai ana; E holoi oia i kona mau kapuwai i ke koko o ka mea hewa.   
\q1
\v 11 Pela, e olelo ke kanaka, Oiaio, he uku no hoi no ka mea pono: Oiaio hoi, he Akua no e hoopai ana ma ka honua.   
\c 59  
\b  
\q1
\v 1 E HOOPAKELE ia'u i ko'u mau enemi, e ko'u Akua; E hookiekie oe ia'u i ka poe ku e mai iluna ia'u.   
\q1
\v 2 E hoopakele ia'u i ka poe hana hewa; A e hoola mai ia'u i na kanaka koko.   
\q1
\v 3 No ka mea, aia hoi, ke hoohalua nei lakou no ko'u uhane: Ua akoakoa ku e mai ka poe ikaika; Aole no ko'u hewa, aole hoi no ko'u lawehala ana, e Iehova.   
\q1
\v 4 Me ko'u hala ole, holo lakou a hoomakaukau; E ala ae e hoohalawai me au, a e nana mai.   
\q1
\v 5 O oe, e Iehova ke Akua Sabaota, ke Akua o Iseraela, E ala, e hoopai i na lahuikanaka a pau: Mai hoomanawanui mai i na mea lawehala nui. Sila.   
\q1
\v 6 Ua hoi mai lakou i ke ahiahi: Ua uwo lakou me he ilio la; Ke kaapuni nei lakou i ke kulanakauhale.   
\q1
\v 7 Aia hoi, ua hoolei mai me ko lakou waha: He mau pahikaua maloko o ko lakou mau leheleho: No ka mea, owai ka mea hoolohe?   
\q1
\v 8 Aka, e Iehova, o akaaka mai no oe ia lakou; E henehene mai no hoi oe i na lahuikanaka a pau.   
\b  
\q1
\v 9 No kona ikaika, e malama aku au ia oe; No ka mea, o ke Akua ko'u wahi e malu ai.   
\q1
\v 10 E hele no hoi imua o'u ko'u Akua aloha mai; E haawi mai ke Akua ia'u e nana aku i ko'u poe enemi.   
\q1
\v 11 Mai luku mai oe ia lakou, o poina i ko'u poe Kanaka: E hoauwana oe ia lakou me kou mana; E hoohaahaa oe ia lakou, e ka Haku, ko makou palekaua.   
\q1
\v 12 No ka hewa o ko lakou waha, A me na olelo a ko lakou mau lehelehe, E hooheiia lakou iloko o ko lakou hookiekie ana; A no ke kuamuamu a me ka wahahee a lakou e pane nei.   
\q1
\v 13 E hoopau oe me kon huhu, e hoopau, i ole lakou; I ike lakou o ke Akua ke alii iloko o Iakoba a hiki i na welau o ka honua,   
\q1
\v 14 A i ke ahiahi o hoi mai ai lakou; A e uwo lakou me he ilio la, A e kaapuni i ke kulanakauhale.   
\q1
\v 15 E auwana lakou i o ia nei, i ai, A e uwo lakou ke maona ole.   
\b  
\q1
\v 16 Aka, e oli aku au i kou mana; Oia hoi, e himeni leo nui aku au i kou aloha i ke kakahiaka; No ka mea, he wahi malu ae nei oe no'u, He puuhonua i ko'u la i popilikia'i.   
\q1
\v 17 E ko'u Ikaika, ia oe no wau e mele aku ai: No ka mea, o oe no ko'u wahi e malu ai, e ko'u Akua aloha mai.   
\c 60  
\b  
\q1
\v 1 E KE Akua, ua haalele mai oe ia makou; Ua hooanhee liilii oe ia makou; Ua huhu ae nei oe; e maliu hou mai ia makou.   
\q1
\v 2 Ua hoonauweuwe mai oe i ka honua, a wawahi hoi ia; E hoola i kona nahaha ana, no ka mea, ke nauweuwe nei no ia.   
\q1
\v 3 Ua hoike mai oe i kou poe kanaka i na mea paakiki; Ua hoohainu mai oe ia makou i ka waina o ka haalulu.   
\q1
\v 4 Ua haawi mai oe i ka hae i ka poe weliweli ia oe, I hookiekieia'e no ia no ka oiaio. Sila.   
\q1
\v 5 I hoopakeleia kou mea aloha; E hoola mai me kou lima akau, a e hooloho mai ia'u.   
\b  
\q1
\v 6 Olelo iho la ke Akua ma kona hoano; E hauoli au, e puunane au ia Sekema; A o ke awawa o Sukota ka'u e ana aku ai.   
\q1
\v 7 No'u no Gileada; no'u no hoi o Manase; O Eperaima ka ikaika o kuu poo; O Iuda ko'u hoailona moi;   
\q1
\v 8 O Moaba ko'u ipu holoi; Maluna o Edoma e hoohemo aku ai au i kuu kamaa: E hauoli oe, e Pilisetia maluna o'u.   
\b  
\q1
\v 9 Owai la ka mea nana wau e lawe i ke kulanakauhale pakaua? Owai la ka mea nana wau e alakai i Edoma?   
\q1
\v 10 Aole anei o oe, ke Akua, ka mea i haalele mai ia makou? A o oe, e ke Akua, ka i hele pu ole me ko makou poe kaua?   
\q1
\v 11 E kokua mai oe ia makou i ka popilikia; No ka mea, he lapuwale ke kokua ana o ke kanaka.   
\q1
\v 12 Iloko o ke Akua e koa aku ai kakou; Oia ke hehi iho i ko kakou poe enemi.   
\c 61  
\b  
\q1
\v 1 E HOOLOHE mai, e ke Akua, i ko'u kahea ana; E maliu pono mai i ka'u pule.   
\q1
\v 2 Mai ka welau o ka honua e kahea aku ai au ia oe, I ka paumako o ko'u naau; E alakai oe ia'u i ka pohaku kiekie maluna o'u.   
\q1
\v 3 No ka mea, ua lilo mai oe i paku no'u; He halekaua paa imua o ka enemi.   
\q1
\v 4 E noho wau maloko o kou halelewa a mau loa: E kanaho au ma ka hoomalu ana o kou mau eheu. Sila.   
\b  
\q1
\v 5 No ka mea, ua lohe oe, e ke Akua, i ka'u mau mea i hoohiki ai: Ua haawi mai hoi oe ia'u i ka hooilina o ka poe weliweli i kou inoa.   
\q1
\v 6 E hooloihi no oe i na la o ke alii: A i kona mau makahiki ia hanauna aku ia hanauna aku.   
\q1
\v 7 E noho ia imua o ke Akua a mau loa; E hoomakaukau mai oe i ke aloha a me ka oiaio, e ola'i ia.   
\q1
\v 8 Pela, e himeni mau loa aku au i kou inoa, E hooko aku i kela la i keia la i ka'u mau mea i berita ai.   
\c 62  
\b  
\q1
\v 1 OIAIO, ke hilinai nei ko'u uhane i ke Akua; Nona mai no hoi ke ola no'u.   
\q1
\v 2 Oia wale no ko'u pohaku a me kuu ola; Oia ko'u wahi e malu ai, aole au e nauweuwe nui.   
\q1
\v 3 Pehea la ka loihi o ko oukou kukakuka hewa ku e i ke kanaka? E lukuia auanei oukou a pau, Me he pa hina la, me ka pa haalulu.   
\q1
\v 4 Oiaio, ua ohumu lakou e kiola iho ia ia mai kona pono iho; Hauoli lakou i ka wahahee; Hoomaikai hoi lakou me ko lakou waha, Aka, maloko, ua hoino wale lakou. Sila.   
\b  
\q1
\v 5 E kuu uhane, e hilinai aku oe i ke Akua wale no; No ka mea, nona mai ka'u mea e kali nei.   
\q1
\v 6 Oia wale no ko'u pohaku a me kuu ola; Oia hoi ko'u wahi e malu ai, aole au e kulanalana.   
\q1
\v 7 Iloko o ke Akua ko'u ola a me ko'u nani: O ko'u pohaku paa, a o ko'u wahi malu, aia no i ke Akua.   
\q1
\v 8 E hilinai aku ia ia i na manawa a pau, e na kanaka; E ninini aku i ko oukou naau imua ona: O ke Akua kahi e malu ai no kakou. Sila.   
\b  
\q1
\v 9 Oiaio, he mea lapuwale na makaainana, He mea oiaio ole na kanaka koikoi; Aia waihoia ma ka mea kaupaona, Pau pu lakou i ka mama, aole ka ha.   
\q1
\v 10 Mai noho a hilinai i ka hooluhihewa ana: Mai noho a laua lapuwale ko oukou manao ma ka lawe wale ana. I ka wa e mahuahua ai ka waiwai, mai paulele ko oukou naau ilaila.   
\b  
\q1
\v 11 Hookahi olelo ana a ke Akua; Elua ko'u hoolohe ana i keia, no ke Akua ka mana.   
\q1
\v 12 Nou no hoi, e ka Haku, e aloha mai; No ka mea, ua uku mai oe i kela kanaka i keia kanaka, e like me kana hana.   
\c 63  
\b  
\q1
\v 1 E KE Akua, o oe no ko'u Akua, e imi koke no au ia oe; Ke makewai nei no hoi ko'u uhane nou, Ke iini nei ko'u kino ia oe i ka aina maloo, Me ka makewai, ma kahi wai ole;   
\q1
\v 2 I ike au i kou mana a me kou nani, Me a'u i ike ai ia oe maloko o kahi hoano.   
\q1
\v 3 No ka mea, ua oi aku ka pono o kou lokomaikai mamua o ke ola nei, E hoolea aku ko'u mau lehelehe ia oe.   
\q1
\v 4 Pela e hoomaikai aku ai au ia oe i ko'u ola nei; I kou inoa, e hapai ai au i ko'u mau lima.   
\q1
\v 5 E maona auanei ko'u uhane me he mea la he ono loa a me ka momona; Me na lehelehe olioli e hoolea aku ai ko'u waha;   
\b  
\q1
\v 6 I ko'u hoomanao ana ia oe ma kuu wahi moe, Me ka manaonao ia oe i na wati o ka po.   
\q1
\v 7 No ka mea, ua lilo oe i kokua no'u; Nolaila, ma ka malu o kou mau eheu, e hauoli aku ai au.   
\q1
\v 8 Ke hahai ikaika nei ko'u uhane mamuli ou; Ke kokua paa mai nei kou lima akau ia'u.   
\b  
\q1
\v 9 Aka, o ka poe imi mai i kuu uhane e pepehi mai, E komo lakou i ko lalo mau wahi o ka honua.   
\q1
\v 10 E haule lakou i ka pahikaua; E lilo lakou i waiwai kaili no na alopeke.   
\q1
\v 11 Aka, e olioli ke alii ike Akua; E hauoli hoi na mea a pau i hoohiki ma o na la, Aka, e hoopaaia ka waha o ka poe olelo wahahee.   
\c 64  
\b  
\q1
\v 1 E HOOLOHE mai, e ke Akua, i ko'u leo, i ka'u kamailio ana'ku: E hoomalu i kuu ola nei, i ka makau ana i ka enemi.   
\q1
\v 2 E huna mai ia'u mai ka ohumu malu ana o ka poe hewa; Mai ka hoohaunaele ana hoi o ka poe lawehala:   
\q1
\v 3 Ka poe i hookala i ko lakou alelo me he pahikaua la; A i lena no hoi ko lakou mau pua, he mau olelo awahia;   
\q1
\v 4 I pana malu lakou i ka mea pono: Pana wawe no hoi lakou ia ia, aole hoi makau.   
\q1
\v 5 Hooikaika lakou ia lakou iho ma ka mea ino; Kukakuka lakou e waiho malu i na pahele; Olelo no hoi lakou, Owai la na mea e ike ia lakou?   
\q1
\v 6 Imi no hoi lakou i na mea hewa; Huli lakou me ka imi ikaika: O ka manao a me ka naau o lakou he hohonu ia.   
\b  
\q1
\v 7 Aka, e paua mai no ke Akua ia lakou me ka pua; E hiki wawe no ko lakou ku ana.   
\q1
\v 8 Pela e hoohaule iho lakou i ko lakou alelo maluna o lakou iho; E holo aku no hoi ka poe a pau i ike ia lakou.   
\q1
\v 9 E pau no hoi na kanaka i ka makau, A e hai aku i ka hana a ke Akua; No ka mea, e noonoo naauao lakou i kana hana ana.   
\q1
\v 10 E olioli ka mea pono ia Iehova, a e hilinai hoi ia ia; A e hauoli no hoi ka poe naau kupono a pau.   
\c 65  
\b  
\q1
\v 1 NOU, e ke Akua, ka hilinai me ka hoolea iloko o Ziona: Nou no hoi e hookoia'ku ai ka mea i hoohikiia.   
\q1
\v 2 E ka mea lohe i ka pule, I ou la e hele aku ai ka io a pau.   
\q1
\v 3 Lanakila mai na hewa maluna o'u: A o ko makou mau lawehala ana, o kau ia e hoopau ai.   
\q1
\v 4 Pomaikai ke kanaka au i koho mai ai, A e hookokoke ai hoi, i noho ia ma kou mau pahale: E maona auanei makou i ka pono o kou hale, o kou luakini hoano.   
\b  
\q1
\v 5 Ma na mea kupanaha iloko o ka pono, E ae mai i ka makou, e ko makou Akua e ola'i; E ka mea e manaolanaia'i no na welelau a pau o ka honua, A me ka poe loihi aku ma ke kai:   
\q1
\v 6 Ka mea i hoonoho paa i na mauna me kona mana; I kakooia me ka ikaika;   
\q1
\v 7 Ka mea i hoomalielie i ka halulu ana o na kai, Ka halulu ana o na ale o lakou, a me ka wawa ana o kanaka.   
\q1
\v 8 O ka poe e noho ana ma kahi loihi loa aku, ua makau no i kou mau hoailona: Ke hauoli mai nei oe i na puka ana o ke kakahiaka a me ke ahiahi.   
\b  
\q1
\v 9 Ke kipa mai nei oe i ka honua, a hoopiha ia ia a hu iwaho: Ke hoonui wale nei oe i kona waiwai me ko ke Akua kahawai i piha i ka wai: Ke hoomakaukau nei oe i palaoa na lakou; No ka mea, pela no oe i hooponopono ai ia.   
\q1
\v 10 Ke hoohainu nui mai nei oe i kona mau lapalapa; Me ka hoomaniania i kona mau kaha; Ke hoopalupalu mai nei oe ia ia me na ua: A o kona ulu ana'e kau e hoomaikai nei.   
\q1
\v 11 Ke hoolei mai nei oe i ka makahiki me kou lokomaikai: Ke hookulukulu nei kou mau kaa i ka momona;   
\q1
\v 12 Ke hookulukulu nei lakou ma na kula o ka waonahele; A ua kaeiia na puu me ka hauoli.   
\q1
\v 13 Ua aahuia na kula i ohana holoholona, Ua uhiia hoi na awawa i ka palaoa: Ke hooho nei lakou no ka olioli; Ke mele mai nei no hoi lakou.   
\c 66  
\b  
\q1
\v 1 E HOOKANI olioli i ke Akua, e na aina a pau:   
\q1
\v 2 E himeni aku i ka nani o kona inoa: E hoolilo i ka hoolea nona i mea nani.   
\q1
\v 3 E olelo aku i ke Akua, Nani kou kupaianaha i kau hana aua! No ka nui o kou mana e hoolohe ai kou mau enemi ia oe.   
\q1
\v 4 E pau ka honua i ka hoomana aku ia oe, me ke mele aku ia oe; E himeni aku lakou i kou inoa. Sila.   
\b  
\q1
\v 5 E hele mai oukou e ike i na hana a ke Akua; He kupaianaha ia i kana hana ana no na keiki a kanaka.   
\q1
\v 6 Hoolilo mai la oia i ke kai i aina maloo: Hele wawae ae la lakou iwaena o ka muliwai: Malaila kakou i hauoli aku ai ia ia.   
\q1
\v 7 Ma kona mana ua hoomalu mau loa oia; Ke nana mai nei kona mau maka i na lahuikanaka: Aole e hookiekie ae ka poe kipikipi. Sila.   
\b  
\q1
\v 8 E hoomaikai i ko kakou Akua, e na kanaka, E hooloheia'ku ka leo o ka hoolea nona:   
\q1
\v 9 Ka mea i hoomau i ko kakou uhane ma ke ola nei; Aole i kuu mai e kapeke ko kakou mau wawae.   
\q1
\v 10 No ka mea, ua hoao mai oe, e ke Akua, ia makou; Ua hoao mai oe ia makou me he kala la i hoaoia.   
\q1
\v 11 Ua hookomo oe ia makou i ka upena; Ua waiho mai oe i ka mea kaumaha ma ko makou mau puhaka.   
\q1
\v 12 Ua haawi mai oe, e hooholo na kanaka maluna o ko makou mau poo: Hele ae la makou iwaena o ke ahi a me ka wai: Aka, ua lawe mai oe ia makou ma kahi waiwai.   
\q1
\v 13 E hele au iloko o kou hale me na mohaikuni: E hooko aku au nou i ka'u mau mea i hoohiki aku ai,   
\q1
\v 14 Ka mea a ko'u mau lehelehe i hoopuka aku ai; A me ko'u waha i olelo ai i kuu popilikia ana.   
\q1
\v 15 E kaumaha aku au nou i na mohaikuni momona, Me ka mea ala o na hipa kane; E alana aku au i na bipi me na kao. Sila.   
\b  
\q1
\v 16 E hele mai e hoolohe, e ka poe a pau i weliweli i ke Akua, A e hai aku au i ka mea ana i hana mai ai no kuu uhane.   
\q1
\v 17 Ua kahea aku au ia ia me kuu waha, A ua hapaiia'ku hoi ia e ko'u alelo.   
\q1
\v 18 Ina malama au i ka hewa ma ko'u naau, Aole e hoolohe mai ka Haku ia'u:   
\q1
\v 19 Aka, ua hoolohe io mai no ke Akua; Ua maliu mai i ka leo o ka'u pule.   
\q1
\v 20 E hoomaikaiia'ku ke Akua, Ka mea i hookapae ole i ka'u pule, A me kona aloha, mai o'u aku nei.   
\c 67  
\b  
\q1
\v 1 E ALOHA mai ke Akua ia makou, A e hoomaikai mai hoi ia makou; A e hoomalamalama mai kona maka ia makou; Sila.   
\q1
\v 2 I ikeia kou aoao ma ka honua, A me kou hoola ana ma na lahuikanaka a pau.   
\q1
\v 3 E hoolea aku na kanaka ia oe, e ke Akua; E pau hoi na kanaka i ka hoolea aku ia oe,   
\q1
\v 4 E hauoli na lahuikanaka, a e oli no ka olioli: No ka mea e hooponopono oe i na kanaka ma ka pololei, A ma ka honua e alakai ai oe ia lakou. Sila.   
\q1
\v 5 E hoolea aku na kanaka ia oe, e ke Akua; E pau na kanaka i ka hoolea aku ia oe.   
\q1
\v 6 Alaila e haawi mai ka honua i kona hua; A e hoomaikai mai ke Akua ko kakou Akua ia kakou.   
\q1
\v 7 E hoomaikai mai ke Akua ia kakou; A e makau aku ia ia na welelau a pau o ka honua.   
\c 68  
\b  
\q1
\v 1 E KU iluna ke Akua, e hooauhee liilii i kona mau enemi: E auhee hoi imua ona ka poe i hoowahawaha ia ia.   
\q1
\v 2 Me he uahi la i puhiia'ku, pela e hoopuehu ai oe ia lakou; Me ka pilali i hehee ai imua o ke ahi, Pela e make ai ka poe hewa imua o ke Akua.   
\q1
\v 3 Aka, e olioli ka poe pono, e hauoli hoi imua o ke Akua; Oiaio, e hauoli loa lakou.   
\q1
\v 4 E himeni aku oukou i ke Akua; E hoolea aku hoi i kona inoa: E hapai aku hoi i ka mea holokaa maluna o na lani, Ma koua inoa, o IA, a e hauoli imua ona.   
\b  
\q1
\v 5 O ka Makua no ka poe makua ole, O ka Lunakanawai no na wahinekanemake, Oia ke Akua i kona wahi hoano e noho ai.   
\q1
\v 6 Ua hoonoho ke Akua i na mea mehameha iloko o na ohana; O ka poe i paa i na kaula hao, kana i hoopuka mai nei; Aka, e noho no ka poe kipikipi ma kahi panoa.   
\b  
\q1
\v 7 E ke Akua, i kou hele ana imua o kou poe kanaka, I kou eu ana'e iwaena o ka waonahele; Sila.   
\q1
\v 8 Haalulu ae la ka honua, Hookulukulu mai la ka lani, ma ke alo o ke Akua: O Sinai hoi kekahi ma ke alo o ke Akua, ke Akua o Iseraela.   
\q1
\v 9 Hoohelelei iho la oe, e ke Akua, i ka ua nui, I hoomau ai oe i kou hooilina i kona nawaliwali ana.   
\q1
\v 10 Malaila i noho ai kou ekalesia; No kou maikai, e ke Akua, ua hoomakaukau oe no ka poe ilihune.   
\b  
\q1
\v 11 Haawi mai la ka Haku i ka olelo; He lehulehu loa ka poe i hoolaha.   
\q1
\v 12 O na'lii o na poe kaua ua auhee wawe lakou: A o ka mea i noho ma ka hale ua puunaue no ia i ka waiwai pio.   
\q1
\v 13 A i moe ae oukou mawaena o na ipuhao, E like auanei oukou me na eheu o ka manu ku i paapu i ke kala; A me kona mau hulu, i ke gula lenalena.   
\q1
\v 14 I ka wa i hoopuehu ai ka Mea mana loa i na'lii iloko ona, Ua like ia me ka hau ma Salemona;   
\b  
\q1
\v 15 O ka mauna o ke Akua, ka mauna Basana: He mauna kiekie, ka mauna Basana.   
\q1
\v 16 O ke aha la ka oukou mea e kiei malu ai, e na maunakiekie? Eia ka mauna a ke Akua i makemake ai e noho, Oiaio, e noho mau loa o Iehova ma neia.   
\q1
\v 17 O na kaa o ke Akua elua umi tausani i papaluaia; O ka Haku ka iwaena o lakou, Pela ma Sinai, a ma kahi hoano.   
\q1
\v 18 Ua pii ae oe iluna, ua lawe pio oe i ke pio ana; Ua loaa no ia oe na haawina no na kanaka, Oia, no ka poe kipikipi kekahi i noho pu mai ai ke Akua ka Haku.   
\b  
\q1
\v 19 E hoomaikaiia'ku ka Haku, ka mea i hooili ukana maluna o kakou i kela la i keia la, O ko kakou Akua e ola'i. Sila.   
\q1
\v 20 O ko kakou Akua, oia ke Akua e ola'i; A no Iehova ka Haku ka puka ana ae no ka make.   
\q1
\v 21 E hana pepe ke Akua i ke poo o kona poe enemi, A me ka pua lauoho o ka mea e hele ana'e ma kona mau hewa.   
\q1
\v 22 I mai la ke Akua, Mai Basana mai e alakai hou mai au; E hoihoi mai no hoi au mailoko mai o na hohonu o ke kai.   
\q1
\v 23 I komo kou kapuwai iloko o ke koko o na enemi, A me ke alelo o kau mau ilio iloko o ia mea no.   
\b  
\q1
\v 24 Ua ike lakou i kou hele ana, e ke Akua, Na hele ana o ko'u Akua, kuu Alii, ma kahi hoano.   
\q1
\v 25 Ua hele mua ae ka poe mele himeni, A mahope iho ka poe hookanikani i na kaula: A iwaena na kaikamahine e hookani timerela ana.   
\q1
\v 26 E hoomaikai aku oukou i ke Akua iloko o na auaina, A i ka Haku mai ke kumuwai o ka Iseraela.   
\q1
\v 27 Malaila o Beniamina ka mea uuku, o ko lakou alii kekahi, Na'lii o Iuda, ko lakou poe ahaolelo, Na'lii o Zebuluna, a me na'lii o Napetali.   
\b  
\q1
\v 28 Ua kauoha mai kou Akua i kou ikaika: E hookupaa mai, e ke Akua, i ka mea au i hana'i no makou.   
\q1
\v 29 No kou luakini ma Ierusalema, E lawe ai na'lii i na makana ia oe.   
\q1
\v 30 E papa mai oe i ka holoholona o na ohe, Ke anaina o na mea ikaika, iwaena o na bipi o na lahuikanaka; A hoohaahaa iho kela keia ia ia iho me na apana kala: E hooauhee liilii oe i na kanaka puni kaua.   
\q1
\v 31 E hele mai na luna mailoko mai o Aigupita; E kikoo wawe aku o Aitiopa i kona mau lima i ke Akua.   
\b  
\q1
\v 32 E oli aku i ke Akua, e na aupuni o ka honua, E himeni hoomaikai aku oukou i ka Haku; Sila.   
\q1
\v 33 I ka mea e holokaa ana ma na lani o na lani kahiko; Aia, ke hoopuka mai la oia i kona leo, he leo mana.   
\q1
\v 34 E haawi oukou no ke Akua ka mana; Maluna o ka Iseraela kona nani; O kona mana hoi, aia no i na ao.   
\q1
\v 35 He mea weliweli oe, e ke Akua, mailoko mai o kou wahi hoano: O ke Akua o ka Iseraela, oia ka mea i haawi mai i ka ikaika a me ka mana i kona poe kanaka. E hoomaikaiia'ku ke Akua.   
\c 69  
\b  
\q1
\v 1 E HOOLA mai ia'u, e ke Akua; No ka mea, ua komo mai na wai i ko'u uhane.   
\q1
\v 2 Ke palemo nei au i ka lepo poho hohonu, kahi e ku ole ai: Ua hiki mai nei au i na wai hohonu; Ke kahe nei no hoi na muliwai maluna o'u.   
\q1
\v 3 Ua luhi au i kuu kahea ana aku, ua maloo kuu puu: Pau e kuu mau maka i ko'u kali ana no kuu Akua.   
\q1
\v 4 Ua lehulehu aku i na lauoho o kuu poo ka poe huhu hala ole mai ia'u; Ua ikaika hoi ka poe manao e pepehi mai ia'u, e ku e hewa mai ana ia'u: Alaila hoihoi aku au i ka mea a'u i kaili ole ai.   
\b  
\q1
\v 5 E ke Akua, ua ike mai oe i ko'u naaupo: Aole hoi i nalo ko'u mau hewa ia oe.   
\q1
\v 6 Mai noho a hoohilahilaia no'u nei ka poe hilinai ia oe, e ka Haku, Iehova Sabaota. Mai noho a hoohokaia no'u nei ka poe imi ia oe, e ke Akua o ka Iseraela.   
\q1
\v 7 No ka mea, nou la i halihali ai au i ka hoinoia; Ua uhi mai ka hilahila i ko'u maka.   
\q1
\v 8 Ua lilo au i malihini i ko'u mau hoahanau, He kanaka e hoi i na keiki a ko'u makuwahine.   
\q1
\v 9 No ka mea, ua hoopauia au e ka manao ikaika no kou hale: A o na hoino ana o ka poe hoino ia oe, ua haule mai ia maluna iho o'u.   
\q1
\v 10 A uwe au, a hahau hoi i kuu uhane me ka hookeai ana, Oia ka'u mea i hoinoia mai ai.   
\q1
\v 11 A aahu iho la au i ke kapa ino; Lilo au i mea hoohiki wale ia.   
\q1
\v 12 Ua olelo ku e mai ia'u ka poe noho ma ka ipuka; A lilo hoi au i mele na ka poe inu i ka mea ona.   
\b  
\q1
\v 13 Aka, owau nei la, aia ia oe ka'u pule, o Iehova, I ka wa maliuia; E ke Akua, ma ka nui o kou aloha, e hoolohe mai ia'u, I ka oiaio o kou ola.   
\q1
\v 14 E hoopakele ia'u i ka lepo poho, aole hoi au e palemo: E hoopakeleia au i ka poe inaina mai ia'u, a i na wai hohonu.   
\q1
\v 15 Mai noho a kahe ka waikahe maluna o'u; Mai noho a ale mai ka hohonu ia'u; Aole hoi e pani ka lua i kona waha maluna o'u.   
\b  
\q1
\v 16 E hoolohe mai ia'u, e Iehova, no ka mea, he pono kou lokomaikai; Mamuli o ka nui loa o kou aloha, e maliu mai ia'u.   
\q1
\v 17 Mai hoonalo i kou maka i kau kauwa; No ka mea, ua pilikia au: E hoolohe koke mai oe ia'u.   
\q1
\v 18 E hookokoke mai i kuu uhane, a e hoola mai ia ia: E hoopakele ia'u no ko'u poe enemi.   
\q1
\v 19 Ua ike ae nei oe i ko'u hoinoia, ko'u hoohilahilaia, a me ko'u heneheneia: Imua no hoi ou ko'u mau enemi a pau.   
\b  
\q1
\v 20 Ua haehae ko'u naau i ka hoinoia mai, a kaumaha loa au; Kali aku la au i mea e menemene mai, aole hoi; A i mau mea hooluolu mai, aole i loaa ia'u.   
\q1
\v 21 Ua haawi mai la lakou i ka mea awahia i ai na'u; A i kuu makewai ana ua hoohainu mai lakou ia'u i ka vinega.   
\b  
\q1
\v 22 E lilo no ko lakou papaaina i pahele imua o lakou: A o ko lakou uku i mea e hihia ai.   
\q1
\v 23 E hoopouliia ko lakou mau maka i ike ole lakou; A e hoohaalulu mau no hoi oe i ko lakou mau puhaka.   
\q1
\v 24 E ninini iho no oe i kou inaina maluna o lakou; A e loohia lakou i kou huhu wela.   
\q1
\v 25 E neoneo no hoi ko lakou hale; Aohe mea e noho iloko o ko lakou mau halelewa.   
\q1
\v 26 No ka mea, ua alualu hewa lakou i ka mea au i hahau ai; A kamailio lakou he mea kaumaha no na mea au e hoeha mai.   
\q1
\v 27 E hookui i ka hewa maluna o ko lakou hewa: Aole hoi lakou e komo iloko o kou hoaponoia.   
\q1
\v 28 E hoonaloia lakou mailoko aku o ka buke a ka poe ola, Aole lakou e kakau pu ia me ka poe pono.   
\b  
\q1
\v 29 Aka, ua ilihune au a ua kaumaha no hoi; E hookiekie kou ola ia'u, e ke Akua.   
\q1
\v 30 E hoolea aku au i ka inoa o ke Akua, ma ka himeni; A e hoonui aku ia ia me ka hoomaikai ana.   
\q1
\v 31 Ua oi aku ka pono o keia ia Iehova mamua o ka bipi kane, A o ka bipi opiopio mea pepeiaohao me na maiuu.   
\q1
\v 32 E ike hoi ka poe hoohaahaa, a e hauoli hoi: E imi ana i ke Akua, e ola ko oukou naau.   
\q1
\v 33 No ka mea, ua hoolohe mai o Iehova i ka poe ilihune; Aole hoi ia i hoowahawaha i kona poe i hoopaaia.   
\b  
\q1
\v 34 E hoomaikai ka lani a me ka honua ia ia; O na kai, a me na mea a pau e holo ana maloko olaila.   
\q1
\v 35 No ka mea, e hoola no ke Akua ia Ziona, A e kukulu hoi i na kulanakauhale o Iuda; I noho lakou ilaila, a e lilo ia no lakou.   
\q1
\v 36 E loaa mai no hoi ia i na hua a kana mau kauwa: A malaila e noho ai ka poe makemake i kona inoa.   
\c 70  
\b  
\q1
\v 1 I OLA au, e ke Akua, E wikiwiki mai, e Iehova, e kokua mai ia'u.   
\q1
\v 2 E hoohilahilaia, e hoohokaia hoi ka poe e imi ana i ko'u uhane: E hoohuliia ihope, a hoka ka poe makemake i ka hewa no'u.   
\q1
\v 3 E hoihoiia ihope i uku no ko lakou hilahila, Ka poe i olelo mai, Aia la! Aia la!   
\b  
\q1
\v 4 Aka, e olioli a e hauoli hoi ka poe a pau i imi aku ia oe: A e olelo mau ka poe a pau i makemake i kou ola, E hoonuiia ke Akua.   
\q1
\v 5 Aka, ua ilihune au a ua nele hoi; E holo koke mai ia'u, e ke Akua: O oe no ko'u Kokua a me ko'u Hoola; E Iehova, mai hookaulua aku oe.   
\c 71  
\b  
\q1
\v 1 O OE, e Iehova, ka'u mea e hilinai ai: Aole au e hoohokaia mai.   
\q1
\v 2 E hoola mai ia'u, ma kou pono, E hoopakele hoi oe ia'u: E haliu mai i kou pepeiao ia'u a e hoola ia'u.   
\q1
\v 3 E lilo mai oe i pohaku e noho ai no'u, Kahi e holo mau ai au; Ua kauoha ae nei oe e hoola ia'u; No ka mea, o oe no ko'u pohaku me ko'u pakaua.   
\q1
\v 4 E ko'u Akua, e hoopakele mai oe ia'u i ka lima o ka poe aia, Mai loko aku o ka poho lima o ka mea hewa aloha ole.   
\q1
\v 5 No ka mea, o oe no ko'u mea e manaolana ai, e ka Haku; E Iehova, ka mea au i hilinai ai, mai ko'u wa opiopio.   
\q1
\v 6 Nau no wau i hookupaa, mai ka opu mai; O oe no ka i lawe ia'u mai loko mai o na naau o ko'u makuwahine: Nou mau aku no hoi ko'u hoolea ana.   
\b  
\q1
\v 7 Me he mea kupanaha la au i ka lehulehu; Aka, o oe ko'u wahi paa e malu ai.   
\q1
\v 8 E piha ko'u waha i ka hoolea nou, A me kou nani a po ka la.   
\q1
\v 9 Mai kiola ae oe ia'u i ka wa elemakule; Aole hoi e haalele mai ia'u i ka pau ana o ko'u ikaika.   
\q1
\v 10 No ka mea, ke olelo ku e mai nei ko'u poe enemi ia'u; A ua ohumu pu ka poe hoohalua no kuu uhane,   
\q1
\v 11 I mai la, Ua haalele mai ke Akua ia ia: E alualu oukou ia ia, a e hopu ia ia; No ka mea, aohe mea hoola.   
\b  
\q1
\v 12 E ke Akua, mai hoomamao aku ia'u; E ko'u Akua, e wikiwiki mai e kokua ia'u.   
\q1
\v 13 E hoohilahilaia, a e pau e hoi ka poe ku e mai i kuu uhane; E uhiia me ka hoinoia a me ka hoahewaia ka poe imi i hewa no'u.   
\q1
\v 14 Aka, e lana mau ko'u naau, A e hoomahuahua'e au i ko'u hoolea ana ia oe.   
\q1
\v 15 E hoike aku ko'u waha i kou pono, a me kou ola a po ka la: No ka mea, aole au i ike i ko laila helu'na.   
\q1
\v 16 E hele no wau ma ka ikaika o ka Haku Iehova; E hoolea au i kou pono, o kou wale no.   
\b  
\q1
\v 17 E ke Akua, ua ao mai oe ia'u mai ko'u wa opiopio: A ua hai aku au i kau mau hana kupanaha a hiki i keia wa.   
\q1
\v 18 Ano hoi i ko'u elemakule ana me ka poohina, E ke Akua, mai haalele mai ia'u; A hoike e aku au i kou ikaika i keia hanauna, A i kou mana hoi, i na mea a pau e hiki mai ana.   
\q1
\v 19 He kiekie loa kou pono, e ke Akua, Ka mea i hana i na mea nui; E ke Akua, owai la ka mea like me oe?   
\q1
\v 20 E ka mea i hoike iho nei ia'u i ka pilikia ana he nui wale, E hooikaika hou mai no oe ia'u, A e hoopuka ia'u mailoko o na wahi hohonu o ka honua.   
\q1
\v 21 E hoomahuahua ae oe i ko'u nui ana, A e hooluolu mai ia'u ma kela aoao, ma keia aoao.   
\b  
\q1
\v 22 E hula aku au ia oe me ka violaumi, I kou oiaio hoi, e ko'u Akua; E himeni aku hoi au ia oe me ka lira, E ka mea hoano o ka Iseraela.   
\q1
\v 23 E hauoli nui ko'u mau lehelehe i ko'u oli ana ia oe; A me ko'u uhane au i hoola mai nei.   
\q1
\v 24 Eia hoi, e kamailio aku kuu alelo i kou pono a po ka la; No ka mea, ua hoka, ua hoohilahilaia ka poe imi i hewa no'u.   
\c 72  
\b  
\q1
\v 1 E HAAWI i kou mau kanawai i ke alii, e ke Akua, A i kau pono hoi i ke keiki a ke alii.   
\q1
\v 2 E hooponopono oia i kou poe kanaka ma ka pololei. A i kou poe haahaa ma ka pono.   
\q1
\v 3 A e halihali mai no na mauna i ka pomaikai i kanaka, A me na puu liilii hoi, ma ka pono.   
\q1
\v 4 E hooponopono oia i ka poe kaumaha o na kanaka, E hoola oia i na keiki a ka poe ilihune, E hana pepe i ka mea hooluhihewa.   
\b  
\q1
\v 5 E weliweli mau lakou ia oe i ka wa o ka la, A i ka luli ana o ka mahina, i na hanauna a pau.   
\q1
\v 6 E iho mai no ia e like me ka ua maluna o ka aina mauu i okiia; Me na kulu ua hoi i hoopulu iho i ka honua.   
\q1
\v 7 E mohala ae ka poe pono i kona mau la, A me ka pomaikai nui a e ole loa ka mahina.   
\b  
\q1
\v 8 E hoomalu aupuni oia mai ke kai a i ke kai, A mai ka muliwai hoi a i na welelau o ka honua.   
\q1
\v 9 A imua o kona alo e kulou iho ai ko ka waonahele; A e palu no hoi kona poe enemi i ka lepo.   
\q1
\v 10 E halihali mai na'lii o Taresisa a o na mokupuni i na makana; A e haawi mai no hoi na'lii o Seheba a me Seba i ko lakou mau haawina.   
\q1
\v 11 Oia, e moe iho hoi na'lii a pau imua o kona alo; E pau hoi na lahuikanaka i ka malama ia ia.   
\b  
\q1
\v 12 No ka mea, hoopakele no oia i ka mea waiwai ole i kona kahea ana; I ka mea ilihune hoi, a me ka mea nele i ke kokua ole.   
\q1
\v 13 E hookoe mai no oia i ka mea haahaa, a me ka nele, A e hoola hoi i na uhane o ka poe hemahema.   
\q1
\v 14 E hoopakele oia i ko lakou uhane i ka wahahee a me ka lalau wale: A he mea minamina ko lakou koko i kona mau maka.   
\q1
\v 15 E ola no ia, a e haawiia nona ke gula no Seheba: E mau ana no ka pule nona; A e hoomaikai no ia i kela la i keia la.   
\b  
\q1
\v 16 E nui auanei ka palaoa ma ka honua, ma ka piko o na mauna; A e luliluli kona hua e like me Lebanona: A e mohala ae ko ke kulanakauhale me he mauu la o ka honua.   
\q1
\v 17 E mau ana no hoi kona inoa; E ulu no kona inoa, a e ole loa ka la: A e pomaikai na kanaka ia ia: E pau hoi na lahuikanaka i ke kapa aku ia ia he pomaikai.   
\b  
\q1
\v 18 E hoomaikaiia o Iehova ke Akua, ko Iseraela Akua, Ka mea nana wale no i hana na mea kupaianaha.   
\q1
\v 19 E hoonani mau loa ia'ku kona inoa ihi, E hoopaapuia ka honua a pau i kona nani; Amene, a Amene.   
\b  
\q1
\v 20 Pau na pule a Davida ke keiki a Iese.   
\c 73  
\b  
\q1
\v 1 O IAIO, he lokomaikai ke Akua ia Iseraela, I ka poe naau maemae.   
\q1
\v 2 A owau nei la, aneane haule ko'u mau wawae; Mai pahee io ko'u mau kapuwai.   
\q1
\v 3 No ka mea, ua huahua au i ka poe naaupo, I kuu ike ana i ka pookeokeo ana o ka poe hewa:   
\q1
\v 4 No ka mea, aohe mea e paa ai i ko lakou make ana; Ua mae ole ko lakou ikaika.   
\q1
\v 5 Aohe o lakou popilikia e like me na kanaka e ae; Aole lilo lakou e like me na kanaka e ae, i ka lauwiliia.   
\q1
\v 6 Nolaila i hoopuni ai ka haaheo ia lakou me he kaula hao la; A o ke kolohe ka i uhi mai ia lakou me he kapa komo la.   
\q1
\v 7 Ua puka ko lakou mau maka i ka momona; A oi aku ko lakou waiwai, mamua o ko ka naau makemake.   
\q1
\v 8 Ua henehene lakou, a ua kamailio hewa: No ka hooluhi hewa ana, ua olelo hookiekie lakou:   
\q1
\v 9 Ua hooku e lakou i ko lakou waha i ka lani, A ua holoholo ko lakou alelo ma ka honua.   
\b  
\q1
\v 10 Nolaila i hoi ai kona poe kanaka ilaila; A ua kowiia na wai o ke kiaha piha no lakou.   
\q1
\v 11 A olelo lakou, Pehea la e ike ai ke Akua? He ike anei hoi ko loko o ka Mea kiekie loa?   
\q1
\v 12 Eia hoi, oia ka poe aia e maluhia ana ma ke ao nei; Ua mahuahua ko lakou waiwai ana.   
\q1
\v 13 Oiaio, hoomaemae mea ole au i kuu naau; Ua holoi hoi au i kuu mau lima me ka pono:   
\q1
\v 14 No ka mea, ua lauwiliia au a po ka la; A ua hahauia mai au i na kakahiaka a pau.   
\b  
\q1
\v 15 Ina e i iho au, E olelo aku wau peneia: Eia hoi, e kumakaia paha au i ka hanauna o kau poe keiki.   
\q1
\v 16 A, i kuu noonoo ana e ike ia mea, He hana luhi no ia no'u;   
\q1
\v 17 A komo aku au i kahi hoano o ke Akua, Alaila maopopo ia'u ko lakou hope.   
\q1
\v 18 Oiaio, ua hooku oe ia lakou ma na wahi paheehee, Ua hoohaule iho oe ia lakou ilalo i ka hoopaiia'na.   
\q1
\v 19 Ua hookae koke ia lakou me he imo ana la o ka maka! Ua hoopau loa ia hoi lakou i na mea makau.   
\q1
\v 20 Me he moe la i ke ala ana'e o kekahi; Pela, e ka Haku, i kou ala ana, e hoowahawaha ai oe i ko lakou ano.   
\b  
\q1
\v 21 No ka mea, ua pono ole ko'u naau, A walania ae la ko'u mau puupaa.   
\q1
\v 22 A ua naaupo hoi au, me ka ike ole; Ua like au me ka holoholona imua ou.   
\q1
\v 23 Aka, ke noho mau nei no hoi au me oe; Ua paa mai oe ia'u ma kuu lima akau.   
\q1
\v 24 E alakai no oe ia'u ma kau oleloao, A mahope aku, e hookipa ia'u i ka nani.   
\b  
\q1
\v 25 Owai la ko'u ma ka lani? Aohe hoi mea ma ka honua nei a'u e makemake nei mamua ou.   
\q1
\v 26 Ke maule nei ko'u kino a me ko'u naau, Aka, o ke Akua ka ikaika o ko'u naau; A me ko'u kuleana a mau loa.   
\q1
\v 27 No ka mea, aia hoi, o ka poe mamao e ia oe, e make lakou; E luku mai hoi oe i ka poe a pau e hele moekolohe ana mai ou aku la.   
\q1
\v 28 Aka, he pono no'u e hookokoke aku i ke Akua; Ua hilinai aku au i ka Haku, ia Iehova, I hai aku ai au i kau hana a pau.   
\c 74  
\b  
\q1
\v 1 E KE Akua, o ke aha kau mea e mamao mau loa aku ai? No ke aha la e wela mai ai kou huhu i na hipa o kou aina?   
\q1
\v 2 E hoomanao oe i kou ekalesia au i kuai kahiko loa ai, Ka ohana o kou hooilina au i kuai ai; O keia mauna Ziona kahi i noho ai oe.   
\q1
\v 3 E hoeu i kou wawae i ka neoneo mau ana; I na mea a pau a ka enemi i hana hewa ai iloko e kou wahi hoano.   
\q1
\v 4 Ua uwo kou poe enemi iloko o na anaina; Ua kau lakou i ko lakou mau hae i hoailona.   
\q1
\v 5 Kaulana aku la ke kanaka, E like me kona hapai ana i na koi i na laau paapu.   
\q1
\v 6 Aka ano, ke wawahi nei lakou i kona mea i kalaiia, Me na koi a me na hamare.   
\q1
\v 7 Ua hoolei lakou i ke ahi iloko o kou wahi hoano, Ua hoohaumia lakou ilalo i ka lepo i ka halelewa o kou inoa.   
\q1
\v 8 I iho la lakou ma ko lakou naau, E luku pu kakou ia lakou; Ua hoopau i ke ahi i na halehalawai a pau o ke Akua ma ka aina.   
\q1
\v 9 Aole kakou i ike i ko kakou mau hoailona; Aole he kaula hou ae; Aohe mea iwaena o kakou i ike i ka loihi ana.   
\q1
\v 10 E ke Akua, pehea ka loihi o ko ka enemi hoino ana mai? E hoino wale anei ka enemi i kou inoa i ka manawa pau ole?   
\q1
\v 11 No ke aha la oe i hoihoi aku ai i kou lima, i kou lima akau? E unuhi ae ia mai loko ae o kou poli.   
\b  
\q1
\v 12 No ka mea, o ke Akua ko'u Alii mai kinohi mai, E hana ana ma ke ola iwaena o ka honua.   
\q1
\v 13 Hookaawale ae la oe i ke kai me kou ikaika: Wawahi iho la oe i na poo o na kerokodila ma na wai.   
\q1
\v 14 Ulupa iho la oe i na poo o ka leviatana, A haawi ia ia i ai na na kanaka o ka waonahele.   
\q1
\v 15 Hookaawale ae la oe i ke kumuwai me ka muliwai: Hoomaloo iho la oe i na waikahe ikaika.   
\q1
\v 16 Nou no ke ao, nou no hoi ka po: Ua hoomakaukau oe i ka malamalama a me ka la.   
\q1
\v 17 Ua hoonohonoho oe i na palena a pau o ka honua; Ua hana hoi oe i ka hoilo a me ka makalii.   
\b  
\q1
\v 18 E hoomanao oe i keia, ua hoino wale ka enemi, e Iehova, A ua kuamuamu wale na kanaka naaupo i kou inoa.   
\q1
\v 19 Mai noho a haawi i ka uhane o kau manu nunu i ka poe ino: Mai hoopoina mau loa i ke anaina o kou poe ilihune.   
\q1
\v 20 E manao mai oe i ka berita; No ka mea, ua paapu na wahi pouli o ka honua i na wahi e noho ai ka lalauwale.   
\q1
\v 21 Mai noho a hoi hou ka poe i hooluhihewaia me ka hilahila; Aka, e hoolea aku i kou inoa ka poe ilihune a me ka haahaa.   
\b  
\q1
\v 22 E ku iluna, e ko Akua, e hakaka i ko'u hakaka: E hoomanao i ko ke kanaka naaupo hoino wale ana ia oe i na la a pau.   
\q1
\v 23 Mai hoopoina i ka leo o kou poe enemi: Ke mahuahua mai nei ka haunaele ana o ka poe ku e ia oe.   
\c 75  
\b  
\q1
\v 1 KE hoomaikai aku nei makou ia oe, e ke Akua, Ke hoomaikai aku nei makou; No ka mea, o ke kokoke ana mai o kou inoa, Ua hoakakaia e kau mau hana kupanaha.   
\q1
\v 2 Aia loaa ia'u ke anaina, Alaila, e hooponopono au ma ka pololei.   
\q1
\v 3 Hehee iho la ka honua me ko ka honua a pau: Na'u no i hookupaa i kona mau kia. Sila.   
\q1
\v 4 I aku la au i ka poe naaupo, Mai hana naaupo oukou; A i ka poe aia, Mai hookiekie i ka pepeiaohao.   
\q1
\v 5 Mai hookiekie i ko oukou mau pepeiaohao iluna: Mai olelo me ka a-i oolea;   
\b  
\q1
\v 6 No ka mea, aole mai ka hikina, aole hoi mai ke komohana, Aole hoi mai ke kukuluhema, ka hoomaikaiia.   
\q1
\v 7 No ka mea, o ke Akua ka Lunakanawai: Ua hoohaahaa oia i kekahi, a ua hookiekie hoi i kekahi.   
\q1
\v 8 No ka mea, he kiaha ka iloko o ka lima o Iehova, He ulaula ka waina, a ua piha i ka mea anoninoniia; Ke ninini nei oia i koloko; Aka, o kona okaoka, oia ka ka poe hewa a pau o ka honua e kowi ai, a e inu.   
\b  
\q1
\v 9 Aka, e hai mau loa aku no wau; E hemeni aku au i ke Akua o Iakoba.   
\q1
\v 10 O na pepeiaohao a pau o ka poe hewa ka'u e oki aku ai: Aka, e hookiekieia'e na pepeiaohao o ka mea pono.   
\c 76  
\b  
\q1
\v 1 U A ikeia ke Akua ma ka Iuda: Ua kaulana hoi kona inoa ma ka Iseraela.   
\q1
\v 2 Aia ma Salema kona halelewa, A ma Ziona hoi kona wahi e noho ai.   
\q1
\v 3 Malaila ia i hakihaki ai i na pua o ke kakaka, O ka palekaua hoi, a me ka pahikaua, a me ke koi kaua. Sila.   
\b  
\q1
\v 4 Ua oi aku ka hanohano o kou nani mamua o na mauna uliuli.   
\q1
\v 5 Ua haoia ka poe ikaika o ka naau, A ua moe nui no hoi lakou; Aole i hiki ka lima o ka poe ikaika ke lawelawe.   
\q1
\v 6 No kau papa ana, e ke Akua o Iakoba, Moe iho no ka ke kaakaua a me ka lio.   
\q1
\v 7 O oe, o oe no, ka mea e makauia'i: Owai hoi ka mea e ku ma kou alo, i kou wa e huhu mai ai?   
\b  
\q1
\v 8 I loheia no ia oe ka hooponopono ana mai ka lani mai; Makau ae la ka honua, a noho malie iho la,   
\q1
\v 9 I ke ku ana o ke Akua iluna, e hooponopono, E hoola mai hoi i ka poe akahai a pau o ka honua. Sila.   
\q1
\v 10 E hoonani aku no ka huhu o kanaka ia oe; A e liki no hoi oe i ke koena o ka huhu.   
\b  
\q1
\v 11 E hoohiki, a e haawi io aku oukou ia Iehova, i ko oukou Akua: A lawe mai hoi na mea a pau i makana na ka mea e makauia'i.   
\q1
\v 12 Nana no e hooki ae i ka ikaika o na'lii: He mea weliweli hoi ia no na'lii o ka honua.   
\c 77  
\b  
\q1
\v 1 KAHEA aku la au i ke Akua ma ko'u leo, Ma ko'u leo i ke Akua, a hoolohe mai la ia ia'u.   
\q1
\v 2 I ko'u la i popilikia ai, nonoi aku la au i ka Haku: Kikoo aku la kuu lima i ka po, aole i haule: Hoole iho la kuu naau, aole ia e hoomahaia.   
\q1
\v 3 Hoomanao aku la au i ke Akua, a kupikipikio iho la; Noonoo aku la au, a maule iho la kuu naau. Sila.   
\q1
\v 4 Ua paa ia oe na alu o ko'u mau maka: Ua lauwiliia hoi au, aole hiki ke olelo aku.   
\q1
\v 5 Noonoo no au i na la kahiko, I na makahiki hoi o ka wa mamua loa aku.   
\q1
\v 6 Hoomanao iho la au i kuu mele i ka po: Me kuu naau wau i kukakuka iho ai; Huli ikaika hoi ko'u manao.   
\b  
\q1
\v 7 E kipaku anei ka Haku i ka manawa pau ole? Aole anei ia e maliu hou mai?   
\q1
\v 8 Ua pauhia anei kona lokomaikai? Ua hala mau loa aku anei kana olelo?   
\q1
\v 9 Ua hoopoina anei ke Akua i ka lokomaikai? Ua puliki anei oia i kona aloha iloko o ka huhu? Sila.   
\q1
\v 10 I aku la au, o ko'u nawaliwali keia, O na makahiki o ka lima akau o ka Mea kiekie loa.   
\b  
\q1
\v 11 E hoomanao aku au i na hana mana a Iehova: E hoomanaoio no hoi au i na mea kupanaha au, i ka wa kahiko.   
\q1
\v 12 E noonoo aku au i kau hana a pau, A e manao nui hoi i kau mau haua mana.   
\q1
\v 13 Aia kou aoao, e ke Akua, ma kahi hoano, Owai la ke Akua nui e like me ke Akua?   
\q1
\v 14 O oe ke Akua nana i hana na mea mana: Ua hoike mai no hoi oe i kou ikaika mawaena o na kanaka.   
\q1
\v 15 I kou lima iho no oe i panai ai i kou poe kanaka, I na mamo a Iseraela, a me Iosepa. Sila.   
\b  
\q1
\v 16 Ike aku la na wai ia oe, e ke Akua; Ike aku la na wai ia oe, a haalulu iho la: Kupikipikio no hoi na hohonu.   
\q1
\v 17 Ninini mai la hoi na ao i ka wai: Hoohekili mai la hoi na ao; Hoholo ae la na uila ou.   
\q1
\v 18 Maloko o ka puahiohio ka leo o kou hekili: Hoomalamalama mai la na uila i ka honua: Naue iho la ka honua me ka haalulu.   
\q1
\v 19 Aia kou kuamoo ma ka moana, A o kou alanui hoi ma na wai nui; Aole i ikeia kou mau kapuwai.   
\q1
\v 20 Alakai aku no oe i kou poe me he ohana hipa la, Ma ka lima o Mose, ma laua o Aarona.   
\c 78  
\b  
\q1
\v 1 E NA kanaka o'u, e hoolohe mai oukou i ko'u kanawai; E haliu mai hoi i ko oukou pepeiao i na olelo a ko'u waha.   
\q1
\v 2 E hooaka ae au i kuu waha ma na himeni, A e hai aku hoi i na mele kahiko;   
\q1
\v 3 I na mea a kakou i lohe ai, a i ike ai hoi, A ua hai mai no ko kakou poe makua ia kakou.   
\q1
\v 4 Aole kakou e huna, mai ka lakou poe keiki, A hiki aku i ka hanauna hope loa, I ka hoike ana aku i na halelu no Iehova, A me kona ikaika, a me na mea kupanaha ana i hana'i.   
\b  
\q1
\v 5 Hoopaa oia i mea hoike no ka Iakoba, A kau no hoi oia i kanawai no ka Iseraela, A kauoha mai la i na kupuna o kakou, E ao ae lakou ia mea i ka lakou poe keiki:   
\q1
\v 6 I ike ka hanauna hope loa aku, E ku mai hoi na keiki i hanau mai a hoike i ka lakou mau keiki;   
\q1
\v 7 I kau aku ko lakou manaolana i ke Akua, Aole hoi e poina na hana a ke Akua, Aka, e malama i kana mau kauoha:   
\q1
\v 8 I like ole lakou me ko lakou poe kupuna, He hanauna ku e, a kipi hoi; He hanauna hooponopono ole i ko lakou naau, A hilinai ole hoi ko lakou naau i ke Akua.   
\b  
\q1
\v 9 O na mamo a Eperaima i kahikoia i ke kakaka, Huli hope no lakou i ka la i kaua'i.   
\q1
\v 10 Aole lakou i malama i ka berita o ke Akua, A hoole lakou i ka hele ma kona kanawai:   
\q1
\v 11 Poina ia lakou kana mau hana. Na mea kupanaha hoi ana i hoike mai ai.   
\q1
\v 12 Hana iho la no oia i na mea kupanaha imua o ko lakou poe makua, Ma ka aina o Aigupita, ma ke kula hoi o Zoana.   
\q1
\v 13 Mahele ae la oia i ke kai, a alakai mai la ia lakou; Hooku ae la oia i na wai me he puu la.   
\q1
\v 14 Ma ke ao oia i alakai mai ai ia lakou i ke ao, Ma ka malamalama o ke ahi hoi i na po a pau.   
\q1
\v 15 Wahi ae la oia i na pohaku ma ka waonahele, Hoohainu mai oia, e like me na ale nui.   
\q1
\v 16 Hoopuka ae la oia i na wai kahe mailoko mai o ka pohaku, A kahe mai la na wai e like me na muliwai.   
\b  
\q1
\v 17 Hana hewa hou aku la lakou ia ia, I ke ku e ana i ka Mea kiekie ma ka waoakua.   
\q1
\v 18 Hoao aku la lakou i ke Akua ma ko lakou naau, I ka nonoi ana i ai, no ko lakou kuko iho.   
\q1
\v 19 Hoowahawaha aku la lakou i ke Akua, i iho la, E hiki anei i ke Akua ke halii i papaaina ma ka waonahele?   
\q1
\v 20 Aia hoi! hahau ae la oia i ka pohaku, a kahe iho la na wai, A huliamahi mai la na wai kahe; E hiki anei ia ia ke haawi mai i ka ai? A e hoomakaukau hoi i ia no kona poe kanaka?   
\b  
\q1
\v 21 Nolaila, lohe mai la o Iehova a huhu iho la; A hoaia ke ahi maloko o ka Iakoba, A pii ae la ka huhu maluna o ka Iseraela:   
\q1
\v 22 No ka mea, aole lakou i manaoio i ke Akua; Aole hoi i paulele i kona kokua ana.   
\q1
\v 23 Ua kauoha nae oia i na ao, mailuna mai, A ua wahi no hoi i puka ma ka lani,   
\q1
\v 24 A ua hooua mai oia maluna o lakou, i mane e ai ai, A ua haawi mai i ka hua palaoa o ka lani na lakou.   
\q1
\v 25 Ai iho la na kanaka i ka ai a ka poe kiekie: Hoouka mai la oia i io na lakou a nui.   
\q1
\v 26 Hoopa mai la oia i ko ka hikina makani ma ka lani: A i kona ikaika, kai mai la oia i ka makani o ke kukuluhema.   
\q1
\v 27 A hooua mai oia i ka io maluna o lakou me he lepo la, A me na manu hulu, e like me ke one o ke kai.   
\q1
\v 28 Hoohaule iho la oia ia mea ma ke kahua hoomoana, A puni hoi ko lakou wahi i noho ai.   
\q1
\v 29 A ai iho la lakou, a maona loa ae la: Hoopuka mai no oia na lakou i ka mea a lakou i kuko ai.   
\q1
\v 30 Aole nae lakou i huli, mai ko lakou kuko ana; I ka wa e waiho ana ka ai i ko lakou waha,   
\q1
\v 31 Kau mai la ka huhu o ke Akua maluna o lakou, A luku iho la oia i ko lakou poe ikaika; A hookulou no hoi i ka poe i waeia o ka Iseraela.   
\q1
\v 32 Aka, ma ia mau mea a pau, hana hewa hou iho la no lakou, Aole i manaoio i kana mau hana kupanaha.   
\q1
\v 33 Nolaila, haawi oia i ka noho makehewa ana i ko lakou mau la, A me ka wiwo wale, i ko lakou mau makahiki.   
\b  
\q1
\v 34 Ina luku oia ia lakou, alaila, nonoi aku lakou ia ia, Huli ae la no hoi, a imi i ke Akua.   
\q1
\v 35 Hoomanao iho la lakou, o ke Akua ko lakou Pohaku, A o ke Akua kiekie hoi ko lakou Hoolapanai.   
\q1
\v 36 Aka, hoomalimali aku lakou ia ia ma ko lakou waha A wahahee aku no hoi ia ia ma ko lakou alelo.   
\q1
\v 37 Aole i kupaa ko lakou naau ma ke Akua, Aole hoi i hilinai i kona berita.   
\q1
\v 38 Lokomaikai mai no nae oia, a kala mai i ka hala, Aole i anai mai ia lakou: Hoohuli pinepine aku oia i kona huhu, Aole i hoala i kona inaina a pau.   
\q1
\v 39 No ka mea, hoomanao oia, he palupalu lakou, He ea hele wale aku, aole hoi mai.   
\b  
\q1
\v 40 Me he aha la la ko lakou kipikipi ana ia ia ma ka waonahele? A hoonaukiuki ia ia ma ka waoakua?   
\q1
\v 41 A huli ihope lakou a hoao i ke Akua, Hoehaeha no hoi i ka Mea Hemolele o ka Iseraela.   
\q1
\v 42 Aole lakou i hoomanao i kona lima, I ka la ana i hoopakele ai ia lakou i ka pilikia,   
\q1
\v 43 I ka manawa ana i kau ai i kona mau hoailona ma Aigupita, A me kana hana kupanaha ma ke kula o Zoana:   
\q1
\v 44 Hoolilo oia i ko lakou muliwai i koko, A me na kahawai hoi, a hiki ole ia lakou ke inu.   
\q1
\v 45 Hoouka ae la oia i ka makika maluna o lakou, A nahu iho la oia ia lakou; A me na rana hoi, a hooki loa oia mau mea ia lakou.   
\q1
\v 46 Haawi ae la oia i ka lakou ai na ke poko, A me ka mea a lakou i hooikaika'i na ka uhini.   
\q1
\v 47 Pepehi mai la oia i ka lakou kumuwaina i ka huahekili, A me ka lakou sukamora i ka hau.   
\q1
\v 48 Hoolilo ae la oia i na bipi a lakou i ka huahekili, A me na holoholona a lakou i ka uila.   
\q1
\v 49 Hoouka ae la oia maluna o lakou, i ka wela o kona huhu, A me ka ukiuki, a me ka inaina, a me ka popilikia, A hoouna mai no hoi i na elele ino.   
\q1
\v 50 Hoomakaukau iho la oia i ke ala no kona huhu, Aole ia i kaohi i ko lakou uhane mai ka make mai; Aka, haawi no oia i ko lakou ola i ka mai ahulan;   
\q1
\v 51 A pepehi no hoi i na hiapo a pau o Aigupita, O na poo ikaika ma na halelewa o Hama.   
\q1
\v 52 Kai mai la oia i kona poe kanaka me he poe hipa la, A alakai no hoi ia lakou ma ka waonahele me he ohana la.   
\q1
\v 53 Alakai oia ia lakou i ka malu, i ole ai lakou e makau: Aka, poi mai ke kai maluna o ko lakou poe enemi.   
\b  
\q1
\v 54 Hoohele oia ia lakou i kona aina hoano, I keia mauna hoi a kona lima akau i hookumu ai.   
\q1
\v 55 Kipaku aku la oia i ko na aina e, mai ko lakou alo aku, Mahele ae la oia ma ke kaula-ana i ka ilina no lakou, A hoonoho iho la i na ohana o ka Iseraela iloko o ko lakou mau halelewa.   
\q1
\v 56 Aka, hoao lakou i ke Akua kiekie, a kipi aku la, Aole hoi i malama i kana mau kauoha:   
\q1
\v 57 Huli hope lakou, a hoopunipuni e like me na makua o lakou; Ua huli lakou ihope, e like me ke kakaka lauwili.   
\q1
\v 58 Hoonaukiuki lakou ia ia i ko lakou wahi kiekie, A hoolili no hoi ia ia i ko lakou poe kii kalaiia.   
\q1
\v 59 A lohe ke Akua alaila, huhu mai la ia, A hoopailua loa no hoi i ka Iseraela.   
\q1
\v 60 Nolaila, haalele iho la oia i ka halelewa o Silo, I ka halelole hoi kahi ana i noho ai iwaena o na kanaka,   
\q1
\v 61 A haawi no hoi i kona mea hanohano i ke pio ana, A me kona mea nani iloko o ka lima o ka enemi.   
\q1
\v 62 Hoolilo no oia i kona poe kanaka i ka pahikaua, A huhu mai la i kona hooilina.   
\q1
\v 63 Hoopau no ke ahi i kona poe kanaka ui; Aole nae i kanikau na wahine puupaa.   
\q1
\v 64 Haule no hoi kona poe kahuna i ka pahikaua; Aole nae i kanikau kona poe wahiue kanemake.   
\b  
\q1
\v 65 Alaila ala ae la ka Haku me he mea la mai kona hiamoe ana, Me he kanaka ikaika la hoi i ona i ka waina.   
\q1
\v 66 Alaila, pehi ae la oia i kona poe enemi ma ko lakou hope; Haawi no ia i hilahila mau loa lakou.   
\q1
\v 67 Hoowahawaha oia i ka halelewa o Iosepa, Aole hoi i wae i ka ohana o Eperaima:   
\q1
\v 68 Aka, wae no ia i ka ohana o Iuda, I ka mauna hoi o Ziona ana i aloha'i.   
\q1
\v 69 Hana oia i kona wahi hoano e like me na wahi kiekie, E like hoi me ka honua ana i hookumu mau loa'i.   
\q1
\v 70 Wae mai la oia ia Davida i kana kauwa, A lawe ae la ia ia, mai na pahipa ae:   
\q1
\v 71 Mai ka hahai ana i na hipa mea keiki, ua lawe oia ia ia, E hanai i ka Iakoba, i na kanaka ona, I ka Iseraela hoi, i kona hooilina.   
\q1
\v 72 Hanai mai la oia ia lakou e like me ka pono o kona naau; A alakai ae la ia lakou ma ke akamai o kona mau lima.   
\c 79  
\b  
\q1
\v 1 E KE Akua e, ua komo mai ko na aina e iloko o kou hooilina; Ua hoohaumia lakou i kou luakini hoano; A ua hoolilo no hoi ia Ierusalema, i ahu opala.   
\q1
\v 2 Ua haawi lakou i na kupapau o kau poe kauwa, I ai na na manu o ka lewa; A me ke kino no hoi o kou poe haipule, Na na holoholona o ka honua.   
\q1
\v 3 Ua hookahe lakou i ko lakou nei koko me he wai la, A puni o Ierusalema; aohe mea nana e kanu iho.   
\q1
\v 4 Ua lilo makou i mea hoowahawahaia e ka poe e noho kokoke mai ana ia makou, He mea hoaikola, a akaaka hoi i ka poe e noho mai la a puni makou.   
\q1
\v 5 Pehea la ka loihi, e Iehova? E huhu mau loa mai anei oe? E a anei kou lili me he ahi la?   
\q1
\v 6 E ninini mai oe i kou huhu maluna o ko na aina e, Ka poe i ike ole ia oe, Maluna hoi o na aupuni i kahea ole aku i kou inoa.   
\q1
\v 7 No ka mea, ua hoopau lakou ia Iakoba, A ua hooneoneo hoi i kona wahi i noho ai.   
\b  
\q1
\v 8 Mai hoomanao mai oe i na hala o ka makou poe kupuna, I mea e hewa'i makou: E hoowikiwiki mai oe i kou lokomaikai, No ka mea, ua pilikia loa makou.   
\q1
\v 9 E kokua mai oe ia makou, e ke Akua o ko makou ola, I mea e hoonaniia'i kou inoa: E hoopakele mai oe ia makou, E kala mai hoi i ko makou hewa, no kou inoa iho.   
\q1
\v 10 No ke aha la e olelo mai ai ko na aina e, Auhea la ko lakou Akua? Ina e ikeia oia e ko na aina e imua o ko makou mau maka, E hoopai ana i ke koko o kau poe kauwa i hookaheia.   
\q1
\v 11 Ina e hiki aku imua ou ke kaniuhu ana o ke pio; E like me ka nui o kou mana, e hoopakele mai oe i na keiki o ka make.   
\q1
\v 12 Maluna o ka poe e noho kokoke mai ana ia makou, E hoihoi pahiku oe iloko o ko lakou umauma, I ka hoino a lakou i hoino aku ai ia oe, e ka Haku e.   
\q1
\v 13 Alaila, o makou, na kanaka ou, a me na hipa au i hanai ai, E mililaui mau aku no makou ia oe; A e hookani makou i kou nani i na hanauna a pau.   
\c 80  
\b  
\q1
\v 1 E HALIU mai kou pepeiao, e ke Kahuhipa o ka Iseraela, Ka mea alakai ia Iosepa me he ohana hipa la; E ka mea e noho la mawaena o na Kerubima, e hoomalamalama mai.   
\q1
\v 2 Imua o Eperaima a me Beniamina, a me Manase, E hoala ai oe i kou ikaika, E hele mai hoi e hoola ia makou.   
\q1
\v 3 E ke Akua e, e hoohuli mai oe ia makou, Na kou maka e hoomalamalama mai, alaila ola no makou.   
\b  
\q1
\v 4 E Iehova, ke Akua o na kaua, Pehea la ka loihi o kou huhu ana i ka pule a kou poe kanaka?   
\q1
\v 5 Ke hanai mai nei oe ia lakou i ka ai, he waimaka; Ke hoohainu mai nei oe ia lakou i na waimaka, a piha ke ana.   
\q1
\v 6 Ua hoolilo oe ia makou i mea e hakaka'i na mea e noho kokoke ana ia makou; A ua akaaka hoi ko makou poe enemi iwaena o lakou.   
\q1
\v 7 E ke Akua o na kaua, e hoohuli mai oe ia makou; Na kou maka e hoomalamalama mai, alaila, ola no makou.   
\b  
\q1
\v 8 Ua lawe mai oe i ke kumuwaina mai Aigupita mai; Kipaku aku no oe i ko na aina e, a kanu iho la.   
\q1
\v 9 Hoomakaukau no oe imua ona, Kokolo ae la kona aa, a piha ka aina.   
\q1
\v 10 Uhiia na mauna i kona malu, A me na kedera nui e kona mau lala.   
\q1
\v 11 Hoopuka ae la ia i kona mau lala a hiki i ke kai, A me kona mau manamana hoi, a hiki i ka muliwai.   
\q1
\v 12 No keaha la oe i hoohiolo ai i kona mau pa, I ako ai i kona ka poe a pau e hele ae ma ke ala?   
\q1
\v 13 Oki loa iho la ia i ka puaa o ka nahelehele, Pau hoi ia i ka aiia e na holoholona o ke kula.   
\b  
\q1
\v 14 E ke Akua o na kaua, e hoi mai oe; E nana mai oe mai ka lani mai, a e ike hoi, A e kokua mai i keia kumuwaina.   
\q1
\v 15 E kiai mai oe i ka mea a kou lima akau i kanu ai, A me ke keiki au i hooikaika'i nou iho.   
\q1
\v 16 Ua pau ia i ke ahi, ua kua ia ilalo; I kou papa ana make no lakou.   
\q1
\v 17 E kauia kou lima maluna o ke kanaka o kou lima akau, A maluna hoi o ke keiki a ke kanaka au i hooikaika'i nou iho.   
\q1
\v 18 Alaila, aole makou e haalele ia oe; E hoala mai oe ia makou, a e hea aku no makou i kou inoa.   
\q1
\v 19 E Iehova, ke Akua o na kaua, e hoohuli mai oe ia makou, Na kou maka e hoomalamalama mai, alaila, ola no makou.   
\c 81  
\b  
\q1
\v 1 E HOOKANI olioli oukou i ke Akua, i ko kakou ikaika: E hooho hauoli i ke Akua o Iakoba.   
\q1
\v 2 E hookiekie i ke mele ana, a e ho mai hoi i ka pahu kani, A me ka lira oluolu, a me ka violaumi.   
\q1
\v 3 E puhi oukou i ka pu i ka mahina hou, A i ka mahina poepoe hoi no ka la ahaaina.   
\q1
\v 4 No ka mea, he olelo paa keia no ka Iseraela, O ke kanawai hoi o ke Akua o ka Iakoba.   
\q1
\v 5 Kau no oia i keia i kanawai no ka Iosepa, Ia ia i hele aku ai iwaena o Aigupita; A lohe no hoi au i ka olelo maopopo ole ia'u.   
\b  
\q1
\v 6 Hoopakele ae la au i kona poohiwi i ke kaumaha; Hoopakeleia no hoi kona mau lima i na ipu.   
\q1
\v 7 I ka popilikia, kahea mai oe, a hoopakele aku ai ia oe; A pane aku la au ma kahi malu o ka hekili: Hoao aku au ia oe ma na wai o Meriba.   
\q1
\v 8 E hoolohe mai, e ko'u poe kanaka, a e ao aku au ia oe; Ina e hoolohe mai oe ia'u, e ka Iseraela;   
\q1
\v 9 Mai noho ke akua e ae me oe, Mai kulou hoi imua o ke akua e ae.   
\q1
\v 10 Owau no o Iehova, kou Akua, Nana oe i lawe mai nei mai ka aina o Aigupita mai; E hoohamama i kou waha, a na'u ia e hoopiha ai.   
\b  
\q1
\v 11 Aole nae i hoolohe ko'u poe kanaka i ko'u leo; Aole hoi i makemake mai o ka Iseraela ia'u.   
\q1
\v 12 Alaila, haawi aku la au ia lakou i ka paakiki o ko lakou naau; A hele hoi lakou ma ko lakou manao iho.   
\q1
\v 13 Ina i hoolohe ko'u poe kanaka ia'u, Ina i hele o ka Iseraela ma ko'u aoao!   
\q1
\v 14 Ina ua hoohaahaa koke aku au i ko lakou poe enemi, A ua huli ku e hoi kou lima i ka poe i huhu mai ia lakou:   
\q1
\v 15 Ina ua huli mai hoi ka poe i huhu ia Iehova, A ua mau loa no ko lakou manawa.   
\q1
\v 16 Ina ua hanai aku oia ia lakou i ka palaoa maikai; A ua hoomaona hoi au ia oe i ka meli mailoko mai o ka pohaku.   
\c 82  
\b  
\q1
\v 1 KE ku mai nei ke Akua iwnena o ke anaina alii; Oia ka i hooponopono iwaena o na akua.   
\q1
\v 2 Pehea la ka loihi o ko oukou apono ana i ka hewa, A hoolana hoi i ka maka o ka poe lawehala? Sila.   
\q1
\v 3 E hoopono oukou i ka mea nawaliwali, a me na keiki makua ole; E hoopololei hoi mamuli o ka poe pilikia, a me ka mea ilihune.   
\q1
\v 4 E hoopakele oukou i ka mea nawaliwali, a me ka mea nele; E kaili mai hoi ia lakou, mai ka lima mai o ka poe hewa.   
\b  
\q1
\v 5 Aole e ike lakou, aole hoi e hooponopono iho; Holoholo lakou ma ka pouli; Naueue hoi na kumu a pau o ka honua.   
\q1
\v 6 Olelo aku la au, He poe akua oukou, He poe keiki no hoi oukou na ka Mea kiekie loa.   
\q1
\v 7 Aka, e make no oukou e like me na kanaka, A e hina hoi e like me kekahi o na'lii.   
\q1
\v 8 E ku mai oe, e ke Akua, e hooponopono i ko ka honua; No ka mea, e loaa ana no ia oe, iwaena o ko na aina a pau.   
\c 83  
\b  
\q1
\v 1 E KE Akua e, mai noho wale oe; Mai hookuli iho, aole hoi e noho leo ole, e ke Akua.   
\q1
\v 2 No ka mea, aia hoi, ua hoohaunaelo kou poe enemi, A o ka poe inaina aku ia oe, ua hookiekie lakou i ke poo.   
\q1
\v 3 Ua imi maalea lakou e ku e i kou poe kanaka, Ua kukakuka lakou e ku e i ka poe au i huna'i.   
\q1
\v 4 I ae la lakou, E hele mai, e hooki kakou i ko lakou noho aupuni ana, I hoomanao hou ole ia ka inoa o ka Iseraela.   
\q1
\v 5 No ka mea, ua kukakuka lokahi pu lakou; Ua hana no lakou i berita ku e ia oe.   
\q1
\v 6 O ko ka halelewa o Edoma, a me ko Isemaela; O ko Moaba, a me ko Hagara;   
\q1
\v 7 O ko Gebela, a me ko Amona, a me ko Amaleka; O ko Pilisetia pu, a me ka poe e noho ma Turo;   
\q1
\v 8 Ua hui pu hoi ko Asuria me lakou; O lakou ka i hooikaika i na moopuna a Lota. Sila.   
\b  
\q1
\v 9 E hana aku oe ia lakou, e like me ko Midiana; E like hoi me Sisera, a me Iabina, Ma ke kahawai o Kisona:   
\q1
\v 10 Na mea i lukuia ma Enedora, A lilo lakou i kipulu no ka aina.   
\q1
\v 11 E hoohalike oe i ko lakou poe koikoi me Oreba, a me Zeeba; I ko lakou poe alii hoi, me Zeba a me Zalemuna:   
\q1
\v 12 Na mea i olelo, E lawe kakou no kakou iho Na wahi noho o ke Akua.   
\b  
\q1
\v 13 E ko'u Akua e, e hoohalike oe ia lakou me ka opala, Me ke oka palaoa hoi imua o ka makani.   
\q1
\v 14 E like me ke ahi i hoopau i na ululaau, A me ka lapalapa ahi i hoa i na kuahiwi;   
\q1
\v 15 Pela oe e hahai ia lakou i kou ino, A e hooweliweli ia lakou i kou puahiohio.   
\q1
\v 16 E hoopiha oe i ko lakou maka i ka hilahila; Alaila, e imi lakou i kou inoa, e Iehova.   
\q1
\v 17 E hoohilahilaia mai lakou, me ka hoopilikia mau loa ia; E hoohilahilaia mai lakou, a make hoi:   
\q1
\v 18 I ike lakou, o oe, ka mea wale no nona ka inoa o IEHOVA; O oe no ka Mea kiekie loa maluna o ka honua a pau.   
\c 84  
\b  
\q1
\v 1 NANI wale kou wahi noho ai, e Iehova o na kaua!   
\q1
\v 2 Iini ko'u uhane, no na hale o Iehova; Kahea aku no ko'u naau a me ko'u kino i ke Akua, i ke Akua ola.   
\q1
\v 3 Ua loaa i ka manu liilii ka hale, A i ka derora hoi, ka punana, Aia ma kou mau kuahu, e Iehova o na kaua, Kahi e waiho ai i kana mau keiki, E kuu alii a me ko'u Akua.   
\q1
\v 4 Ua pomaikai ka poe e noho la ma kou hale; Ua mau loa no ko lakou halelu ana ia oe. Sila.   
\b  
\q1
\v 5 Pomaikai ke kanaka i loaa ka ikaika ia oe, A me ka poe i paa na alanui maikai iloko o ko lakou naau.   
\q1
\v 6 Ia lakou e hele ae ma ke kahawai o Baka, Hoolilo lakou ia ia i waipuna; Na ka ua hoi e hoopiha i na punawai.   
\q1
\v 7 Hele no lakou, mai kela ikaika, a i keia ikaika aku, E ikeia mai lakou e ke Akua ma Ziona.   
\b  
\q1
\v 8 E Iehova ke Akua o na kaua, E hoolohe mai oe i ka'u pule; E haliu mai kou pepeiao, e ke Akua o Iakoba. Sila.   
\q1
\v 9 E ke Akua, e nana oe i ko makou palekaua, E ike hoi i ka maka o ka Mea au i poni ai.   
\q1
\v 10 No ka mea, ua oi aku ka maikai o ka la hookahi ma kou hale mamua o ka tausani. Ua oi aku ko'u makemake i ke kiai puka ma ka hale o ko'u Akua, Mamua o ka noho ana ma na halelewa o ka poe hewa.   
\q1
\v 11 No ka mea, o Iehova, ke Akua, he la no ia, a he palekaua; E haawi mai no o Iehova i ka lokomaikai, a me ka hanohano; Aole ia e aua i kekahi mea maikai i ka poe hele ma ka pololei.   
\q1
\v 12 E Iehova o na kaua, Ua pomaikai ke kanaka hilinai aku ia oe.   
\c 85  
\b  
\q1
\v 1 U A lokomaikai mai oe, e Iehova, i kou aina; Ua hoihoi mai oe i ke pio ana o ka Iakoba.   
\q1
\v 2 Ua kala mai oe i ka hewa o kou poe kanaka, Ua uhi mai oe i ko lakou hala a pau. Sila.   
\q1
\v 3 Ua lawe aku oe i kou inaina a pau, Ua huli aku no hoi oe, mai ka wela o kou huhu aku.   
\b  
\q1
\v 4 E hoohuli mai oe ia makou, e ke Akua o ko makou ola, A e hooki hoi oe i kou huhu mai ia makou.   
\q1
\v 5 E huhu mau loa mai anei oe ia makou? E hooloihi aku anei oe i kou huhu ia hanauna aku, ia hanauna aku?   
\q1
\v 6 Aole anei oe e hoihoi mai i ko makou ola ana? I hauoli ai kou poe kanaka ia oe.   
\q1
\v 7 E hoike mai oe, e Iehova, i kou lokomaikai ia makou, A e haawi mai hoi kou hoola ana na makou.   
\b  
\q1
\v 8 E hoolohe aku no au i ka mea a ke Akua a Iehova e olelo mai ai; No ka mea, e hai mai no oia i ka malu no kona poe kanaka, a me kona poe haipule: Mai hoi hou nae lakou i ka mea lapuwale.   
\q1
\v 9 Oiaio, ua kokoke mai no kona hoola ana i ka poe makau aku ia ia; I noho ka hanohano ma ko kakou aina.   
\q1
\v 10 Ua halawai pu ke aloha me ka oiaio; Ua honi pu no hoi ka pono me ka maluhia.   
\q1
\v 11 E ulu mai no ka oiaio mailoko mai o ka honua, A mai ka lani mai hoi e nana mai ai ka pono.   
\q1
\v 12 E haawi mai no o Iehova i ka maikai; A e haawi mai no hoi ko kakou aina i kona hua iho.   
\q1
\v 13 E hele ae no ka pono imua o kona alo; A e alakai hoi oia ia kakou ma ke ala o kona mau kapuwai.   
\c 86  
\b  
\q1
\v 1 E HALIU mai kou pepeiao, e Iehova, a e hoolohe mai ia'u; No ka mea, ua pilikia au, a ua ilihune hoi.   
\q1
\v 2 E malama mai oe i ko'u uhane, no ka mea, he haipule au: E kuu Akua, e hoola mai oe i kau kauwa i hilinai aku ia oe.   
\q1
\v 3 E aloha mai oe ia'u, e kuu Haku; No ka mea, ke kahea aku nei au ia oe i na la a pau.   
\q1
\v 4 E hoohauoli mai oe i ka uhane o kau kauwa; No ka mea, ia oe no wau e hapai nei i ko'u uhane, e ka Haku.   
\q1
\v 5 A, no ka mea hoi, ua maikai oe, e ka Haku, a ua maliu koke mai hoi: Manomano kou lokomaikai ka poe a pau i hea aku ia oe.   
\q1
\v 6 E haliu mai kou pepeiao i ka'u pule, e Iehova; A e hoolohe i ka leo o ko'u nonoi ana.   
\q1
\v 7 I ka la o ko'u popilikia e kahea aku no au ia oe; No ka mea, e ae mai no oe ia'u.   
\q1
\v 8 Aohe mea like me oe iwaena o na'kua, e ka Haku e, Aole hoi he hana e like me kau.   
\q1
\v 9 E hele mai no ko na aina a pau au i hana'i, A e kulou hoomana imua o kou alo, e ka Haku, A e hoonani aku i kou inoa.   
\q1
\v 10 No ka mea, ua nui loa oe, a ua hana hoi i na mea kupanaha; O oe wale no ke Akua.   
\b  
\q1
\v 11 E kuhikuhi mai oe i kou alanui, e Iehova, a e hele no wau ma kou oiaio; E hoolokahi mai oe i kou naau e makau aku i kou inoa.   
\q1
\v 12 E hoolea aku no au ia oe, e ka Haku, ko'u Akua, me ko'u naau a pau; A e hoonani mau loa aku i kou inoa.   
\q1
\v 13 No ka mea, nui loa kou lokomaikai mai ia'u; Ua hoopakele mai oe i ko'u uhane i ka malu o ka make.   
\b  
\q1
\v 14 E ke Akua e, ua ala ku e mai ia'u ka poe hookiekie, A o ke anaina hookaumaha, ua imi mai lakou i ko'u uhane; Aole hoi lakou i hoonoho ia oe imua o lakou.   
\q1
\v 15 Aka, o oe no ke Akua aloha, a me ka lokomaikai, e ka Haku, E hookaulua ana i ka huhu, A ua nui hoi ka lokomaikai, a me ka oiaio.   
\q1
\v 16 E maliu mai oe, a e aloha mai hoi ia'u; E haawi mai oe i kou ikaika na kau kauwa nei, A e hoola mai hoi i ke keiki a kau kauwawahine.   
\q1
\v 17 E haawi mai oe i hoailona no ka maikai, I ike mai ka poe i huhu ia'u, a hilahila; No ka mea, ua kokua mai oe ia'u, e Iehova, A ua hooluolu mai no hoi ia'u.   
\c 87  
\b  
\q1
\v 1 A IA no kona mau kumu ma na mauna hoano.   
\q1
\v 2 Ua oi aku ka makemake o Iehova i na pukapa o Ziona, Mamua o na wahi noho ai a pau o ka Iakoba.   
\q1
\v 3 Ua oleloia mai na mea nani nou, E ke kulanakauhale o ke Akua Sila.   
\q1
\v 4 I ka poe ike mai ia'u, e kamailio aku au no Rahaba, a me Babulona: Aia o Pilisetia, a me Turo, a me Aitiopa, Oia ka i hanauia malaila.   
\q1
\v 5 E oleloia mai no hoi no Ziona, Ua hanauia kela kanaka keia kanaka maloko ona; A na ka Mea kiekie e hookumu paa ia wahi.   
\q1
\v 6 Ia Iehova e kakau ai i na kanaka, E hoike mai no oia, Ua hanauia oia nei malaila. Sila.   
\q1
\v 7 O ka poe mele, a me ka poe hookiokio, Aia la iloko ou, kou mau punawai a pau.   
\c 88  
\b  
\q1
\v 1 E IEHOVA, ke Akua o ko'u ola, Ua kahea aku no au imua ou i ke ao a me ka po.   
\q1
\v 2 E hookomo aku i ka'u pule imua ou; E haliu mai hoi kou pepeiao i ka'u kahea ana.   
\q1
\v 3 No ka mea, ua ana ko'u uhane i na popilikia; Ke hookokoke nei ko'u ola i ka luapo.   
\q1
\v 4 Ua helu pu ia no wau me ka poe iho ilalo i ka lua; Ua like hoi au me ke kanaka, aohe ona ikaika:   
\q1
\v 5 Ua waiho wale ia iwaena o ka poe make, Ua like hoi me ka poe i houia e moe ana ma ka lua, Aole oe e hoomanao hou ia lakou; Ua hookiia lakou, mai kou lima aku.   
\q1
\v 6 Ua hoomoe oe ia'u iloko o ka lua hohonu loa, Maloko o ka pouli, a me ua hohonu.   
\q1
\v 7 Ua kaumaha mai kou huhu maluna o'u, Ua hoopilikia mai oe ia'u i kou mau ale a pau. Sila.   
\q1
\v 8 Ua hookaawale loa aku oe i ko'u makamaka mai o'u aku, Ua hoolilo mai oe ia'u i mea hoopailua no lakou: Ua paa no hoi au, aole e hiki ia'u ke hele aku.   
\q1
\v 9 Ua hokii ko'u mau maka no ka popilikia; Ua kahea aku no wau ia oe, e Iehova, i na la a pau, Ua kikoo aku no hoi au i ko'u lima ia oe.   
\b  
\q1
\v 10 E hoike anei oe i na hana mana no ka poe i make? E ala mai anei na lapu e hoolea aku ia oe? Sila.   
\q1
\v 11 E haiia anei kou lokomaikai ma ka luakupapau? A me kou oiaio hoi maloko o ka po?   
\q1
\v 12 E ikea anei kau hana mana maloko o ka pouli? A me kou pono hoi maloko o ka aina meki?   
\b  
\q1
\v 13 E kahea aku nae au ia oe, e Iehova; I ke kakahiaka hoi e halawai no ka'u pule me oe.   
\q1
\v 14 E Iehova, no ke aha la oe e hoopailua mai i ko'u uhane? A huna hoi i kou maka ia'u?   
\q1
\v 15 Ua pilikia au, a kokoke no i ka make, mai ko'u wa uuku mai; Ia'u i loohia'i i kou mea makau, ua kupikipikio au.   
\q1
\v 16 Ua hele ae maluna o'u kou huhu wela; Ua hooki loa hoi kou mau mea makau ia'u.   
\q1
\v 17 Hele poai mai la lakou ia'u, me he wai la; Hoopuni mai la lakou ia'u.   
\q1
\v 18 Ua hookaawale loa oe i ko'u mea aloha, a me ko'u makamaka, mai o'u aku, Aia hoi ko'u hoalauna ma ka pouli.   
\c 89  
\b  
\q1
\v 1 E HOOKANI mau loa aku au i ka lokomaikai o Iehova; Ma ko'u waha e hoike aku at au i kou oiaio i kela hanauna, i keia hanauna.   
\q1
\v 2 No ka mea, ua olelo no wau, e hoopaa mau loa ia kou lokomaikai; A e hookumu no hoi oe i kou oiaio ma ka lani.   
\q1
\v 3 Ua hana au i berita me kou poe i waeia, Ua hoohiki aku au no Davida, ka'u kauwa,   
\q1
\v 4 E hoonoho paa loa wau i kau poe mamo, A e hana no hoi au i nohoalii nou no na hanauna a pau. Sila.   
\b  
\q1
\v 5 Na ka lani no e hoolea i kou mau mea mana, e Iehova, I kou oiaio kekahi, ma ke anaina o ka poe pono.   
\q1
\v 6 No ka mea, owai la ka mea ma ke aonli e ku like me Iehova? Iwaena hoi o na keiki a ka poe kiekie, e hoohalikeia me Iehova?   
\q1
\v 7 He Akua woliweli loa hoi ia ma ke anaina o ka poe pono; A he mea ia e hopohopo ai no ka poe a pau e noho hoopuni ana ia ia.   
\q1
\v 8 E Iehova, ke Akua o na kaua, Owai la kekahi Iehova e like me oe? Me kou oiaio hoi e hoopuni ana ia oe?   
\q1
\v 9 O oe no ka i hookouopono i ke kupikipikio ana o ke kai; A pii nui ae kona mau ale, nau ia e hoomalielie.   
\q1
\v 10 Ua paopao no oe ia Rahaba, me he mea la i pepehiia; I ka ikaika o kou lima, na hooauhee oe i kou poe enemi.   
\b  
\q1
\v 11 Nau no ka lani, nau no hoi ka honua; Ua hookumu no oe i ke ao, a me kona mau mea e piha'i.   
\q1
\v 12 O ke kukulu akau, a me ke kukuluhema, nau no i hana ia mau mea; E olioli no o Tabora a me Heremona i kou inoa.   
\q1
\v 13 He lima no kou i lako i ka ikaika: Ua ikaika no kou lima, ua kiekie hoi kou lima akau.   
\q1
\v 14 O ka pono, a me ka hoopono, oia ke kumu o kou nohoalii: E hele ae no imua o kou maka ka lokomaikai, a me ka oiaio.   
\q1
\v 15 Pomaikai ka poe kanaka ike ia leo hauoli: E Iehova, e hele no lakou ma ka malamalama o kou maka.   
\q1
\v 16 E hauoli no lakou i kou inoa a po ka la; A ma kou pono hoi e hookiekieia'i lakou.   
\q1
\v 17 No ka mea, o oe no ka nani o ko lakou ikaika; A ma kou lokomaikai e hookiekieia'i ko makou pepeiaohao.   
\q1
\v 18 No ka mea, aia no ia Iehova ko makou paku, A i ka Mea Hemolele hoi o ka Iseraela, ko makou alii.   
\b  
\q1
\v 19 Alaila, olelo iho no oe i kou mea hemolele ma ke akaku, I mai la. Ua kau aku au i ka mana maluna o ka mea ikaika; Ua hookiekie au i ka mea i waeia mai o na kanaka.   
\q1
\v 20 Ua loaa ia'u o Davida, o ka'u kauwa; Ua poni aku no au ia ia me kuu aila laa.   
\q1
\v 21 E paa mau no ko'u lima me ia, A e hooikaika aku no ko'u lima ia ia.   
\q1
\v 22 Aole e kii mai ka enemi i kana, Aole hoi e hookaumaha ke keiki a ka hewa ia ia.   
\q1
\v 23 Na'u no e hooauhee i kona poe enemi imua ona, A e luku aku hoi i ka poe inaina mai ia ia,   
\q1
\v 24 E noho no ko'u oiaio a me ko'u lokomaikai me ia; A ma ko'u inoa e hookiekieia'i kona pepeiaohao.   
\q1
\v 25 E hookau aku au i kona lima ma ke kai, A me kona lima akau hoi ma na muliwai.   
\q1
\v 26 E hea mai no oia ia'u, O oe no ko'u Makua, O ko'u Akua hoi, a me ka Pohaku o ko'u hoolaia.   
\q1
\v 27 E hoolilo no wau ia ia i ko'u makahiapo, I mea kiekie maluna o na'lii o ka honua.   
\q1
\v 28 E malama mau loa no wau i ko'u lokomaikai ia ia, A e ku paa loa no ko'u berita me ia.   
\q1
\v 29 E hoomau loa no wau i kona poe mamo, A me kona nohoalii hoi, e like me na la o ka lani.   
\b  
\q1
\v 30 Ina haalele kana poe keiki i ko'u kanawai, Aole hoi e hele ma kou hoopono ana.   
\q1
\v 31 Ina kuu aku lakou i ka'u olelo pau, Aole hoi e malama i ka'u mau kauoha;   
\q1
\v 32 Alaila e hoopai aku au i ko lakou hewa i ka laau hahau, A me ko lakou hala hoi i ke kaula.   
\q1
\v 33 Aole nae o lawe loa aku au i ko'u lokomaikai mai ona aku. Aole hoi au e hoole i ko'u lokomaikai.   
\q1
\v 34 Aole au e ae maluna o ka'u berita, Aole hoi e hoololi i ka olelo i puka aku ma ko'u lehelehe.   
\q1
\v 35 Hookahi no ko'u hoohiki ana i ko'u hemolele, Aole au e wahahee aku ia Davida.   
\q1
\v 36 E mau loa ana no kana poe mamo, A me kona nohoalii, e like me ka la imua o'u.   
\q1
\v 37 E hoopaa mau loa ia no hoi ia, e like me ka mahina, Me he mea hoike oiaio la ma ke aouli. Sila.   
\b  
\q1
\v 38 Aka, ua hooki mai oe, a ua hoopailua mai, A ua huhu mai no hoi oe i kau mea i poni ai.   
\q1
\v 39 Ua hoole mai no hoi oe i ka berita o kau kauwa: Ua hoolei oe i kona leialii i lalo i ka lepo.   
\q1
\v 40 Ua wawahi no hoi oe i kona mau pa a pau, Ua haawi mai no hoi oe i kona mau pakaua i ka lukuia.   
\q1
\v 41 Hao wale ia ia ka poe a pau e maalo ana ae malaila: He mea hoomaewaowa ia i kona poe hoalauna.   
\q1
\v 42 Ua hookiekio oe i ka lima akau o kona poe enemi; Ua hoohauoli oe i ka poe a pau i inaina mai ia ia.   
\q1
\v 43 Ua hoohuli ae no hoi oe i ka maka o kana pahikaua, Aole hoi oe i hookupaa ia ia ma ke kaua.   
\q1
\v 44 Ua hooki mai oe i kona nani, A ua hoolei i kona nohoalii ilalo i ka lepo.   
\q1
\v 45 Ua hoopokole mai oe i na la o kona wa opiopio; Ua uhi mai no hoi oe ia ia i ka hilahila. Sila.   
\b  
\q1
\v 46 Pehea la ka loihi o kou hoonalo ana ia oe iho, e Iehova? E mau loa anei? E a mai nei anei kou huhu me he ahi la?   
\q1
\v 47 E hoomanao mai oe ia'u, pehea la ka loihi o ke ola ana? No ke aha la oe i hana makehewa ai i na kanaka a pau?   
\q1
\v 48 Owai ke kanaka e ola nei, aole oia e ike i ka make? E hoopakele anei oia i kona ola, mai ka lima aku o ka mea make? Sila.   
\b  
\q1
\v 49 Auhea la kou lokomaikai o na manawa kahiko, e ka Haku? Ka mea au i hoohiki ai ia Davida ma ka oiaio?   
\q1
\v 50 E hoomanao mai oe, e ka Haku, i ka hoinoia o kau kauwa; Ua lawe no wau ma kou umauma i na lehulehu a pau o kou poe kanaka.   
\q1
\v 51 No ka mea, ua hoino wale mai kou poe enemi, e Iehova, Ua hoino wale mai hoi i na kapuwai o kou mea i poniia.   
\b  
\q1
\v 52 E hoomaikaiia o Iehova, a i ka manawa pau ole. Amene, Amene.   
\c 90  
\b  
\q1
\v 1 E KA Haku, he puuhonua no oe no makou i kela hanauna i keia hanauna.   
\q1
\v 2 Mamua aku o ka hanau ana o na mauna, A me kou hoomaka ana i ka honua a me ke ao nei, O oe no ke Akua, mai kahiko loa mai, a mau loa aku no.   
\b  
\q1
\v 3 Ke hoihoi aku nei oe i ke kanaka i ka lepo; A olelo mai no hoi, E hoi oukou, e na keiki a kanaka.   
\q1
\v 4 No ka mea, o na makahiki he tausani imua o kou mau maka, Ua like no me ka la inehinei i hala aku la, Me he kiai la hoi o ka po.   
\q1
\v 5 Hookahe aku no oe ia lakou, he hiamoe no lakou; I ke kakahiaka kupu mai no ia me he mauu la.   
\q1
\v 6 Pua mai no ia i ke kakahiaka a mohala iho, A i ke ahiahi ua okiia ia ilalo a mae wale iho la.   
\b  
\q1
\v 7 No ka mea, ua hoopauia makou i kou huhu, Ua oki loa hoi makou i kou inaina.   
\q1
\v 8 Ua kau no oe i ko makou hewa imua ou, A mo ka makou mea malu, ma ka malamalama o kou maka.   
\q1
\v 9 No ka mea, i kou huhu, ua hala'e ko makou mau la a pau; Ke hoopau nei makou i ko makou mau makahiki me he manao la.   
\q1
\v 10 O na la o ko makou mau makahiki. He kanahiku, makahiki iloko o laila; Aka, ina no ka ikaika he kanawalu makahiki lakou, Alaila, o ko lakou ikaika, he luhi wale no ia, a me ke kaumaha; No ka mea, hooki koke ia ia, a lele aku la makou.   
\q1
\v 11 Owai ka mea i ike i ka ikaika o kou huhu? No ka mea, e like me ka makau ia oe, pela no kou ukiuki mai.   
\q1
\v 12 E ao mai oe i ka helu i ko makou mau la, I komo mai ai ke akamai iloko o ko makou naau.   
\b  
\q1
\v 13 E hoi mai oe, e Iehova, pehea la ka loihi? A e minamina mai hoi i kau poe kauwa.   
\q1
\v 14 E hoomaona koke mai oe ia makou i ka lokomaikai, I hauoli ai makou, a olioli hoi i ko makou mau la a pau.   
\q1
\v 15 E hoohauoli mai oe ia makou, e like me na la o kou hoopilikia ana ia makou, A me na makahiki hoi a makou i ike ai i ka hewa.   
\q1
\v 16 E hoike mai oe i kau hana i kau poe kauwa, A me kou hanohano hoi i ka lakou poe keiki.   
\q1
\v 17 E hoonoho mai maluna o makou i ke aloha o Iehova ko makou Akua: E hoopaa mai oe i ka hana a ko makou lima me makou; Oia, o ka hana a ko makou mau lima, e hoopaa mai oe ia.   
\c 91  
\b  
\q1
\v 1 O KA mea noho iho ma kahi malu o ka Mea kiekie loa, E moe oia ma ke aka o ka Mea mana loa.   
\q1
\v 2 E olelo aku au ia Iehova, Kuu puuhonua, kuu puukaua hoi; Kuu Akua, e paulele aku au ia ia.   
\q1
\v 3 Oiaio no, e hoopakele mai no oia ia'u i ka hei o ka mea hoohei, A me ka mai make ahulau.   
\q1
\v 4 E uhi mai no oia ia oe i kona mau hulu, A e holo no oe malalo iho o kona mau ehen; No ka mea, o kona oiaio, he palekaua ia, a he paku no hoi.   
\b  
\q1
\v 5 Aole oe e makau i ka mea hooweliweli i ka po; Aole hoi i ka pua e lele ana i ke ao;   
\q1
\v 6 Aole hoi i ka mai make e holoholo ana maloko o ka pouli; Aole no hoi i ka mai luku e hooneoneo ana i ke awakea.   
\q1
\v 7 E hina no ka tausani ma kou aoao, A me na legeona ma kou aoao akau; Aole nae e bookokoke aku ia oe.   
\q1
\v 8 E nana wale aku no kou mau maka, A e ike no oe i ka hoopaiia o ka poe hewa.   
\q1
\v 9 No ka mea, ua hoolilo no oe ia Iehova, kuu puuhonua, I ka Mea kiekie hoi, i wahi noho ai nou;   
\q1
\v 10 Aole oe e loohia i ka hewa, Aole e hookokoke mai ka mea ino i kou halelewa.   
\b  
\q1
\v 11 No ka mea, e kauoha mai no ia i kona poe anela nou, E malama ia oe ma kou mau aoao a pau.   
\q1
\v 12 E kaikai lakou ia oe, ma ko lakou mau lima, O kuia kou wawae i ka pohaku.   
\q1
\v 13 E hehi no hoi oe maluna o ka liona a me ka moomake; A e hahahi no hoi oe i ka liona opiopio a me ka moonui.   
\b  
\q1
\v 14 No kona hoopili ana mai ia'u, e hoopakele aku wau ia ia; E hookiekie aku no hoi au ia ia, no ka mea, ua ike mai oia i ko'u inoa.   
\q1
\v 15 E kabea mai no oia ia'u, a e pane aku au ia ia; Owau pu me ia maloko o ka popilikia; Na'u no ia e hoopakele ae, a e hoohanohano no hoi ia ia.   
\q1
\v 16 E hoonui aku au i kona mau la, A e hoike aku no hoi au ia ia, i kou hoola.   
\c 92  
\b  
\q1
\v 1 HE mea maikai ke mililani aku ia Iehova, A e hilinai hoi i kou inoa, e ka Mea kiekie loa;   
\q1
\v 2 E hoike aku i kou lokomaikai i ke kakahiaka, A me kou oiaio i kela po, i keia po,   
\q1
\v 3 Ma ka violaumi a me ke kuolo kani, A ma ka lira kanikani hoi.   
\q1
\v 4 No ka mea, ua hoohauoli mai oe ia'u, e Iehova, i kau hana mana: E olioli no hoi au i na hana a kou mau lima.   
\b  
\q1
\v 5 Nani ka nui o kau mau haua, e Iehova! Ua hohonu loa hoi kou mau manao.   
\q1
\v 6 Aole e ike ke kanaka noonoo ole, Aole hoi e hoomaopopo ka lapuwale i keia.   
\q1
\v 7 Kupu mai no ka poe hewa me he mauu la, A pua mai no hoi ka poe hana hewa a pau, I luku mau loa ia mai lakou.   
\q1
\v 8 O oe, e Iehova, o oe ka Mea kiekie mau loa.   
\q1
\v 9 No ka mea, aia hoi! e Iehova, o kou poe enemi, Aia hoi! e pau auanei kou poe enemi i ka make; E hoopuehu wale ia ka poe hana hewa a pau.   
\b  
\q1
\v 10 E hookiekie nae oe i ko'u pepeiaohao, e like me ko ka laehaokela; E kahinuia mai no wau i ka aila hou.   
\q1
\v 11 E nana no ko'u mau maka maluna o ko'u poe enemi, A e lohe wale ko'u pepeiao I ke ala ku e ana mai o ka poe hewa ia'u.   
\q1
\v 12 E ulu no ka poe pono e like me ka laau pama; E mahuahua ae no hoi ia, e like me ke kedera ma Lebanona.   
\q1
\v 13 O ka poe i kanuia ma ka hale o Iehova, E ulu no lakou ma na kahua o ko kakou Akua.   
\q1
\v 14 E muo hou no lakou i ko lakou wa elemakule; E puipui no lakou a mo ka pomaikai.   
\q1
\v 15 E hoiko aku, he pololei no o Iehova; O ko'u pohaku ia, aole mea hewa iloko ona.   
\c 93  
\b  
\q1
\v 1 KE noho aupuni nei o Iehova, Ua kahikoia oia i ka hanohano; Ua kahikoia o Iehova i ka ikaika, Ua kakoo no oia ia ia iho: Ua hookumu paa loa ia ke ao nei, Aole ia e hoonaueueia.   
\q1
\v 2 Ua hookumu paa ia kou nohoalii mai kahiko mai, Mai ka mau loa mai a ka mau loa aku no oe.   
\b  
\q1
\v 3 Ua hookiekie na ale, e Iehova, Ua hookiekie na ale i ko lakou leo, Ua kookiekie na ale i ka halulu ana.   
\q1
\v 4 Maluna o ka leo o na wai he nui loa, Maluna hoi o ke poi ana mai o na nalu o ke kai, Aia no o Iehova maluna o kahi kiekie loa aku.   
\q1
\v 5 He oiaio maoli kau mau kauoha; Ku pono i kou hale ka mea i hoanoia, E Iehova, a mau loa aku no.   
\c 94  
\b  
\q1
\v 1 E KE Akua nona ka hoopai ana, e Iehova; E ke Akua nona ka hoopai ana, e hoomalamalama mai.   
\q1
\v 2 E ku mai hoi oe, e ka lunakanawai o ka honua; E hoopai oe i ka poe hookiekie.   
\q1
\v 3 Pehea la ka loihi, e Iehova, o ka poe hewa? Pehea la ka loihi o ka akola ana mai o ka poe hewa?   
\q1
\v 4 Pane mai no lakou me ka olelo iho i na mea howa, Kaena wale ka poe hana hewa a pau.   
\q1
\v 5 Ua paopao mai no lakou i kou poo kanaka, e Iehova. A ua hookaumaha hoi i kou hooilina.   
\q1
\v 6 Pepehi no lakou i ka wahinekanemake, a me ka malihini, A ulupa hoi i na keiki makua ole.   
\q1
\v 7 Olelo no hoi lakou, Aole e ike mai o Iehova, Aole e manao mai ke Akua o Iakoba.   
\b  
\q1
\v 8 E hoomaopopo oukou, e ka poe manao ole iwaena o na kanaka; O oukou hoi ka poe naaupo, Pehea la ka loihi a lilo oukou i poe naauao?   
\q1
\v 9 O ka mea i hana mai i ka pepeiao, Aole anei e lohe mai ia? O ka mea i hooponopono i ka maka, Aole anei oia e ike mai?   
\q1
\v 10 O ka mea hahau i ko na aina e, Aole auei oia e hoopai mai? O ka mea hoi i ao mai i kanaka i ka ike?   
\q1
\v 11 Ua ike mai no o Iehova i ka manao o kanaka, He lapuwale ia.   
\b  
\q1
\v 12 Pomaikai ke kanaka au e ao mai ai, e Iehova, A hoonaauao hoi ma kou kanawai;   
\q1
\v 13 I hoomaha'i oe ia ia mai na la o ka ino, A eliia ka lua no ka poe hewa.   
\q1
\v 14 Aole haalele o Iehova i kona poe kanaka, Aole hoi e kuu wale aku i kona hooilina iho.   
\q1
\v 15 E hiki hou mai no ka hooponopono ana ma ka pololei; A malaila no e hahai aku ai ka poe a pau i pono ma ka naau.   
\q1
\v 16 Owai la ka mea e ala mai no'u e ku e i ka poe hewa? Owai hoi ka mea e ku mai iluna nou, e ku e i ka poe lawehala?   
\b  
\q1
\v 17 Ina aole o Iehova i kokua mai ia'u, Ina ua kokoke e noho kuu uhane ma kahi ekemu ole.   
\q1
\v 18 Ia'u i olelo ai, Ua pahee ko'u wawae. Alaila, na kou lokomaikai, e Iehova, i hooikaika ia'u.   
\q1
\v 19 I ka nui loa o ko'u mau manao iloko o'u, O kou aloha ka mea e hoohauoli ai i ko'u uhane.   
\q1
\v 20 E kukakuka pa anei ka nohoalii o ka hewa me oe? Ka mea hoi i hana i ke kolohe ma ke kanawai?   
\q1
\v 21 Alu mai la lakou i ka uhane o ka poe pono, A hoohewa lakou i ke koko hala ole.   
\q1
\v 22 O Iehova no ko'u wahi kiekie, a me ko'u Akua, O ko'u pohaku puuhonua hoi.   
\q1
\v 23 E hoopai mai oia i ko lakou hewa maluna o lakou, A e hooki hoi oia ia lakou maloko o ko lakou hewa; Na Iehova, ko kakou Akua, e hooki ia lakou.   
\c 95  
\b  
\q1
\v 1 I NA kakou, e kahea olioli aku ia Iehova; A e hooho hauoli hoi i ka pohaku o ko kakou hoola.   
\q1
\v 2 E hele kakou imua o kona alo me ka hoalohaloha aku, E kahea olioli aku kakou ia ia ma na himeni.   
\q1
\v 3 No ka mea, he Akua nui o Iehova, He alii nui hoi maluna o na'kua a pau.   
\q1
\v 4 Aia ma kona lima na wahi hohonu o ka honua; Nana hoi na waiwai o na kuahiwi.   
\q1
\v 5 Nana no ka moana, a nana ia i hana; A na kona lima hoi i hooponopono i ka aina maloo.   
\b  
\q1
\v 6 E hele mai kakou, e kulou hoomana, a e moe hoi; A e kukuli iho imua o Iehova nana kakou i hana.   
\q1
\v 7 No ka mea, oia no ko kakou Akua, A o kakou na kanaka ana i hanai ai, A me na hipa hoi o kona lima; i keia la, Ke hoolohe oukou i kona leo,   
\q1
\v 8 Mai hoopaakiki i ko oukou naau, me ia ka hoonaukiuki ana, I ka la i hoaoia'i ma ka waonahele;   
\q1
\v 9 I ka wa i hoao mai ai ko oukou kupuna ia'u, A hoao mai hoi ia'u, a ike iho la i Ka'u hana.   
\q1
\v 10 Hookahi kanaha makahiki o ia hanauna i hoehaeha mai ai ia'u, A i iho la au, he poe kanaka keia i lalau ma ka naau, Aole hoi lakou i ike i ko'u mau aoao.   
\q1
\v 11 Nolaila hoohiki iho la au i ko'u huhu, Aole lakou e komo iloko o ko'u wahi e hoomaha'i.   
\c 96  
\b  
\q1
\v 1 E OLI aku ia Iehova i ke oli hou; E oli aku ia Iehova, e ka honua a pau.   
\q1
\v 2 E oli aku ia Iehova, a e hoomaikai i kona inoa; E hoike olioli aku i kona hoola ana mai kehahi la, a i kekahi la.   
\q1
\v 3 E hai aku i kona nani iwaena o ko na aina e, A me kana mau hana mana, iwnena o na kanaka a pau.   
\q1
\v 4 No ka mea, ua nui o Iehova, a ua pono ke hoonani nui ia oia; A e makauia hoi oia mamua o na'kua a pau.   
\q1
\v 5 Ua pau loa na'kua o na kanaka i ka lapuwale; Aka, na Iehova no i hana i ka lani.   
\q1
\v 6 Aia no imua ona ka nani, a me ka ihiihi; He hanohano, a me ka maikai iloko o kona wahi hoano.   
\b  
\q1
\v 7 E haawi oukou ia Iehova, e na ohana o na kanaka, E haawi aku oukou ia Iehova i ka hoomaikai a me ka hoonam.   
\q1
\v 8 E haawi oukou ia Iehova i ka hoonani i kona inoa; E lalau i ka mohai, a e komo iloko o kona mau kahua.   
\q1
\v 9 E kulou hoomana ia Iehova me ka mea nani hoano; E makau hoi imua ona ko ka honua a pau.   
\q1
\v 10 E olelo ae oukou mawaena o ko na aina e, Ke noho aupuni nei o Iehova; Ua hookumu paa ia keia ao, i ole ia e hoonaueueia; Nana no hoi e hoopai mai i na lahuikanaka ma ka pololei.   
\b  
\q1
\v 11 E olioli mai ka lani, E hauoli hoi ka honua; E halulu mai ka moana a me kona mea e piha'i.   
\q1
\v 12 E hooho mai na kula a me na mea a pau iloko olaila; Alaila e hauoli mai na laau a pau o ka ululaau.   
\q1
\v 13 Imua o Iehova; no ka mea, ke hele mai nei oia, No ka mea hoi, ke hele mai nei oia, E hooponopono mai i ka honua. E hooponopono mai nei oia i keia ao ma ka pololei, A me na kanaka hoi ma kona oiaio.   
\c 97  
\b  
\q1
\v 1 KE noho aupuni nei o Iehova, e hauoli mai ka honua; E olioli hoi ka lehulehu o kona mau mokupuni.   
\q1
\v 2 Ua puni oia i na ao, a me ka pouli; O ka pono, a me ka hooponoponoia, oia ke kumu o kona nohoalii.   
\q1
\v 3 Ke hele aku nei ke ahi ma kona alo, A hoopau no oia koua poe enemi a puni.   
\q1
\v 4 Hoomalamalama mai la kona mau uwila i ke ao nei; Ike aku la ka honua, a haalulu iho la.   
\q1
\v 5 Hehee wale na mauna me he kepau la i ke alo o Iehova, I ke alo o ka Haku hoi o ka honua a pau.   
\q1
\v 6 Ua hoike mai na lani i kona pono, Ua ike aku no hoi na lahuikanaka i kona nani   
\b  
\q1
\v 7 E hoohilahilaia ka poe a pau i malama i na kiikalaiia, Ka poe a pau i kaena ma na'kua wahahee: E hoomana oukou ia ia, e na'kua a pau.   
\q1
\v 8 Lohe ae la o Ziona, a hauoli mai la; Olioli no hoi na kaikamahine o ka Iuda, No kou hoopopono ana, e Iehova.   
\q1
\v 9 No ka mea, o oe, o Iehova, ka mea kiekie maluna o ka honua a pau; Ua hookiekieia oe maluna loa o na'kua a pau.   
\b  
\q1
\v 10 E ka poe aloha ia Iehova, e inaina aku oukou i ka hewa; E malama no oia i ka uhane o kona poe haipule, Hoopakele no oia ia lakou i ka lima o ka poe hewa.   
\q1
\v 11 Ua luluia ka malamalama no ka poe pono, A me ka olioli hoi no ka poe pololei ma ka naau.   
\q1
\v 12 E ka poe pono, e hauoli oukou ia Iehova; A e hooho hauoli hoi i ka hoomanao aua i kona pono.   
\c 98  
\b  
\q1
\v 1 E OLI aku ia Iehova i ka oli hou, No ka mea, ua hana oia i na haua kupanaha; Na kona lima akau, a me kona lima hemolele i hoolanakila ia ia iho.   
\q1
\v 2 Ua hoike mai o Iehova i kona hoola; Ua hooponopono loa mai hoi i kona pono imua o ko na aina e.   
\q1
\v 3 Ua hoomanao mai oia i kona lokomaikai, A me kona oiaio i ko ka hale o ka Iseraela; Ua ike no ua kihi a pau o ka honua I ka hoola ana o ko kakou Akua.   
\b  
\q1
\v 4 E kahea olioli aku ia Iehova, e ka honua a pau; E hooho aku oukou, a e hauoli, a me ka hoolea aku hoi.   
\q1
\v 5 E hoolea aku oukou ia Iehova ma ka mea kani, A ma ka mea kani a me ka leo o ka himeni.   
\q1
\v 6 Ma na pu a ma ka leo o na pepeiaohao, E hooho olioli oukou imua o ke alii, o Iehova hoi.   
\b  
\q1
\v 7 E halulu mai hoi ka moana, a me kona mea e piha'i; O keia ao kekahi a me ka poe e noho la maloko.   
\q1
\v 8 E paipai ua muliwai i na lima: E hauoli pu hoi na mauna   
\q1
\v 9 Imua o Iehova; No ka mea, ua hele mai ia e hooponopono i ka honua; E hooponopono mai no oia i keia ao ma ka pono, A me na kanaka hoi ma ka pololei.   
\c 99  
\b  
\q1
\v 1 KE noho alii nei o Iehova, e haalulu mai na kanaka; ke noho nei oia iwaena o na kerubima, e naueue ka honua.   
\q1
\v 2 He nui o Iehova ma Ziona; Ua kiekie hoi oia maluna o na kanaka a pau.   
\q1
\v 3 E hiilani lakou i kou inoa nui e weliweli ai, No ka mea, ua hemolele ia.   
\q1
\v 4 Ua makemake no hoi ka ikaika o ko alii i ka hooponopono; Ua hookumupaa oe i ka pono, Ua hana mai no oe ma ka hoopono, a ma ka pololei maloko o ka Iakoba.   
\q1
\v 5 E hapai oukou ia Iehova i ko kakou Akua, A e kulou hoomana ma kona keehana wawae; No ka mea, ua hoano oia.   
\b  
\q1
\v 6 O Mose, a me Aarona, iwnena o na kahuna pule, A o Samuela hoi iwaena o ka poe i hea aku i kona inoa; Kahea aku lakou ia Iehova, a ae mai oia i ka lakou.   
\q1
\v 7 Olelo mai la oia ia lakou ma ke kia ao; A malama aku la lakou i kana mau kauoha, A me ka olelopaa ana i haawi mai ai ia lakou.   
\q1
\v 8 E Iehova, ko makou Akua, pane mai no oe ia lakou; O oe no ke Akua nana i kala i ko lakou hala, Hoopai mai no nae i ka lakou mau hana.   
\q1
\v 9 E hapai oukou ia Iehova, i ko kakou Akua, A e hoomana aku hoi ma kona mauna hoano; No ka mea, he hoano o Iehova, ko kakou Akua.   
\c 100  
\b  
\q1
\v 1 E HOOHO olioli oukou, ia Iehova, e na aina a pau.   
\q1
\v 2 E malama ia Iehova me ka kauoli: E hele aku imua ona me ka oli ana.   
\q1
\v 3 E ike hoi oukou, o Iehova, oia no ke Akua, Nana kakou i hana, aole na kakou iho: O kona poe kanaka hoi kakou, A me na hipa ana i hanai ai.   
\b  
\q1
\v 4 E komo oukou iloko o kona ipuka me ka mililani, A iloko hoi o kona kahua me ka halelu; E mililani aku ia ia, a e hoomaikai aku hoi i kona inoa.   
\q1
\v 5 No ka mea, ua maikai o Iehova; Ua mau loa kona lokomaikai, A me kona oiaio hoi i na hanauna a pau.   
\c 101  
\b  
\q1
\v 1 E OLI no wau i ka lokomaikai, a me ka hoopono; Ia oe no wau, e Iehova, e hoolea aku ai.   
\q1
\v 2 E hana naauno no wau ma ka aoao o ka pono. Ahea la oe e hele mai ai ia'u? E holoholo no wau maloko o ko'u hale, Me ka pono o ko'u naau.   
\q1
\v 3 Aole au e kau i ka hewa imua o ko'u mau maka; Ua inaina aku au i ka mea hana ino, Aole ia e pili mai ia'u.   
\q1
\v 4 E haalele anauei ka naau kekee ia'u, Aole au e ike aku i ke kanaka hewa.   
\q1
\v 5 O ka mea ahiahi malu i kona hoalauna, Oia ka'u e hooki aku; O ka mea maka hookiekie, a naau hookano hoi, Aole au e hoomanawanui ia ia.   
\b  
\q1
\v 6 Aia uo ko'u mau maka ma ka poe oiaio o ka aina, I noho mai ai lakou me au. O ka mea hele ma ka aoao o ka pono, Nana no e hookauwa mai na'u.   
\q1
\v 7 Aole e noho iloko o ko'u hale ka mea hana hoopunipuni; Aole e noho ma ko'u alo, ka mea olelo wahahee.   
\q1
\v 8 E hooki koke no wau i ka poe hewa a pau o ka aina, I hoopau wau i ka poe hana hewa a pau, Mai ke kulanakauhale o Iehova aku.   
\c 102  
\b  
\q1
\v 1 E HOOLOHE mai oe i ka'u pule, e Iehova, A e hookomo aku i ko'u kahea ana imua ou.   
\q1
\v 2 Mai huna oe i ko'u maka ia'u, I ka la o'u e pilikia'i e haliu mai kou pepeiao; I ka la a'u e hea aku ai, e ae koke mai oe ia'u.   
\q1
\v 3 Ua hoopauia ko'u mau la me he uwahi la, Ua pau i ke ahi ko'u mau iwi me he pihaa la.   
\q1
\v 4 Ua moku ko'u naau, a ua mae hoi me he mauu la; Nolaila, ua poina ia'u ke ai i ka'u ai.   
\q1
\v 5 No ka leo o ko'u kaniuhu ana, Ua pilipu ko'u mau iwi me ko'u io.   
\q1
\v 6 Ua like no au me ka pelikana o ka waonahele; Ua like no hoi au me ka pueo o ka waoakua.   
\q1
\v 7 Ua makaala no wau, A ua like hoi me na manuliilii noho mehameha maluna o ka hale.   
\b  
\q1
\v 8 Hoowahawaha mai ko'u poe enemi ia'u i na la a pau; O ka poe inaina mai ia'u, ua hoohiki lakou no'u.   
\q1
\v 9 Ua ai aku no au i ka lehu, e like me ka berena, A ua kawili pu au i ko'u mea inu me kuu waimaka,   
\q1
\v 10 No kou huhu, a me kou inaina; No ka mea, ua hapai mai oe ia'u iluna, A ua ulupa mai oe ia'u ilalo,   
\q1
\v 11 Ua auwi ae ko'u mau la, me he aka la; A ua mae hoi au me he mauu la.   
\b  
\q1
\v 12 Aka, e mau loa ana no kou noho ana, e Iehova, A me kou hoomanao ana hoi, ia hanauna aku ia hanauna aku.   
\q1
\v 13 E ku mai auanei oe, a e aloha mai ia Ziona; No ka mea, o ka manawa e aloha'i, Ua hiki mai no ia manawa i oleloia.   
\q1
\v 14 Ua lealea kau poe kauwa ma kona mau pohaku, A ua aloha hoi i kona lepo.   
\q1
\v 15 E makau aku no ko na aina e i ka inoa o Iehova, A me na'lii a pau o ka honua i kou nani.   
\q1
\v 16 I ka wa e hooku ai o Iehova ia Ziona, Alaila, e ikeia'ku no oia maloko o kona nani.   
\q1
\v 17 E haliu mai no oia i ka pule a ka poe nele, Aole ia e hoowahawaha i ka lakou pule ana.   
\b  
\q1
\v 18 E kakauia no keia no na hanauna o keia hope aku; I halelu aku ia Iehova ka poe kanaka e hanau mai la.   
\q1
\v 19 No ka mea, ua nana mai no oia, mai luna mai o kona wahi hoano; Mai ka lani mai hoi i nana mai o Iehova i ka honua;   
\q1
\v 20 E hoolohe mai i ke kaniuhu ana o ka poe pio; A e hookuu hoi i na keiki o ka make:   
\q1
\v 21 E hoike hoi ma Ziona, i ka inoa o Iehova, A me kona mau halelu hoi ma Ierusalema;   
\q1
\v 22 I ka wa e akoakoa pu ai na kanaka, A me na aupuni hoi, e hookauwa aku na Iehova.   
\b  
\q1
\v 23 Ua hoonawaliwali mai oia i ko'u ikaika ma ke ala; Ua hoopokole mai hoi i ko'u mau la.   
\q1
\v 24 I iho la au. E kuu Akua e, Mai lawe aku ia'u maiwaena konu o ko'u mau la: Mai kela hanauna kou makahiki, a ia hanauna aku.   
\q1
\v 25 I ka wa kahiko hookumu no oe i ka honua; A o ka lani hoi ka hana a kou mau lima.   
\q1
\v 26 E pau auanei lakou, aka, e mau loa ana no oe; E elemakule no lakou me he kapa la; Aka, e hoomalule no oe ia lakou me he kapa hou la.   
\q1
\v 27 Aka, ua oia mau no oe pela, Aole loa e pau kou mau makahiki.   
\q1
\v 28 E mau ana no hoi na keiki o kau poe kauwa, A e hoonoho paa loa ia ka lakou poe mamo imua ou.   
\c 103  
\b  
\q1
\v 1 E HOOMAIKAI ia Iehova, e kuu uhane, A me kona inoa hoano hoi, e ko loko o'u a pau.   
\q1
\v 2 E hoomaikai ia Iehova, e kuu uhane, Aole hoi e hoopoina i kona lokomaikai a pau;   
\q1
\v 3 Ka mea i kala mai i ko'u hala a pau, Ka mea i hoola i kou mau mai a pau;   
\q1
\v 4 Ka mea i hoola panai i kou ola mai ka lua mai; Ka mea i kau maluna ou i ka leialii o ka lokomaikai, a me ke aloha:   
\q1
\v 5 Ka mea hoomaona i kou uhane i ka maikai; A hoihoiia mai kou wa opiopio, me he aito la.   
\b  
\q1
\v 6 Ke hana mai nei o Iehova i ka pololei, A me ka hoopono no ka poe a pau i hooluhiia.   
\q1
\v 7 Hoike mai la oia i kona mau aoao ia Mose, A me kana mau hana mana i na mamo a lseraela.   
\q1
\v 8 He lokomaikai o Iehova, he aloha hoi, He lohi ka huhu, a ua nui hoi ke aloha.   
\q1
\v 9 Aole ia e hoomau i ka huhu mai; Aole hoi ia e hookaulua mau loa.   
\q1
\v 10 Aole ia i hana mai ia kakou e like me ko kakou hewa. Aole hoi i hoopai mai ia kakou e like me ko kakou hala.   
\q1
\v 11 No ka mea, e like me ke kiekie o ka lani maluna o ka honua, Pela no ka nui o kona lokomaikai i ka poe i makau aku ia ia.   
\q1
\v 12 E like me ka loihi, mai ka hikina a i ke komohana, Ua hookaawale aku oia i ko kakou hewa mai o kakou aku.   
\q1
\v 13 Me ka makua e aloha ana i kana keiki, Pela no o Iehova e aloha'i i ka poe e makau aku ia ia.   
\q1
\v 14 No ka mea, ua ike mai oia i ko kakou ano; Ke hoomanao nei no hoi he lepo kakou.   
\b  
\q1
\v 15 O na kanaka, ua like ko lakou mau la me ka mauu; Me ka pua hoi o ke kula, pela no kona pua ana.   
\q1
\v 16 No ka mea, pa mai la ka makani maluna ona, a ua ole ia; Aole e manao hou mai kona wahi ia ia.   
\q1
\v 17 Aka, o ka lokomaikai o Iehova, mai kahiko loa mai ia, a mau loa aku no, Maluna o ka poe i makau aku ia ia, A me kona pono hoi, maluna o na keiki a na keiki:   
\q1
\v 18 Maluna hoi o ka poe e malama i kona berita, A me ka poe hoomanao i kana mau kauoha, e hana malaila.   
\b  
\q1
\v 19 Ua hoonoho paa o Iehova i kona nohoalii ma ka lani; A noho alii hoi kona aupuni maluna o na mea a pau.   
\q1
\v 20 E hoomaikai oukou ia Iehova, e kona poe anela, Na mea ikaika loa, a ua hana hoi ma kana mau kauoha, A ua hoolohe i ka leo o kana olelo.   
\q1
\v 21 E hoomaikai oukou ia Iehova, e kona poe kauwa a pau, Na mea lawelawe nana, a hana hoi i kona makemake.   
\q1
\v 22 E hoomaikai oukou ia Iehova, e na mea a pau ana i hana'i. Ma na wahi a pau o kona aupuni: E hoomaikai ia Iehova, e kuu uhane.   
\c 104  
\b  
\q1
\v 1 E Iehova, e kuu Akua e, ua nui loa no oe; Ua kahikoia no oe i ka nani a me ka hanohano.   
\q1
\v 2 Ua uhiia no oe i ka malamalama me he kapa la; Ua hohola no oe i na lani me he paku la.   
\q1
\v 3 Ua haua no oia i kona mau keena kiekie ma na wai; Ua kau aku no hoi i na ao maluna i kaa mau nona: A ua holoholo me na eheu o ka makani.   
\q1
\v 4 Ua hana oia i kona poe elele, he makani; A i kona poe kahuns hoi, he lapalapa ahi;   
\b  
\q1
\v 5 Ua hoopaa oia i ka honua maluna o kona kumu, I ole ia e nauweuwe, a mau loa aku.   
\q1
\v 6 A ua uhi no oe ia i ka hohonu, me he kapa la: Ku mai la na wai, maluna o na mauna.   
\q1
\v 7 I kou papa ana, holo no lakou; I ka leo o kou hekili, auhee aku la lakou.   
\q1
\v 8 Ea mai la no maluna o na mauna; A emi iho la ma na awawa ilalo, A i kahi au i hookumu ai no lakou.   
\q1
\v 9 Ua kau pale oe i mokuna no lakou. I ole lakou e hala'e; I ole hoi e hoi hou mai, a uhi i ka honua.   
\b  
\q1
\v 10 Kuu mai la oia i na waipuna ma na awawa, I kahe mai lakou, mawaena o na mauna.   
\q1
\v 11 Hoohainu no lakou i na holoholona a pau o ke kula; A hooana no hoi na hoki hihiu i ko lakou makewai.   
\q1
\v 12 Maluna olaila na manu o ka lewa e hoopunana'i, A kani hoi ko lakou leo iwaena o na lala.   
\q1
\v 13 Ua hoomauu mai no oia i ua mauna, mailoko mai o kona waihonawai; Ua maona hoi ka aina i ka hua o kau hana ana.   
\b  
\q1
\v 14 Nana no i hooulu mai ka mauu no na holoholona, A me ka mea uli hoi i pono ai na kanaka: I hoopuka mai ai oia i ka ai mailoko mai o ka honua,   
\q1
\v 15 A me ka waina hoi i mea e olioli ai ko na kanaka naau, A me ka aila hoi, i mea e hinuhinu ai kana maka, A me ka berena, ka mea e hooikaika ai ka naau o na kanaka.   
\q1
\v 16 Ua kena no na laau o Iehova, Na kedera hoi o Lebanona, na mea ana i kanu ai;   
\q1
\v 17 Malaila no e hoopunana'i na manu; O ke kikonia, o na laau kaa kona hale.   
\b  
\q1
\v 18 O na mauna kiekie ka puuhonua o na kao hihiu; A o na pohaku hoi ko na rabita.   
\q1
\v 19 Nana no i hana i na mahina no na kau; Ua ike no ka la i kona napoo ana.   
\q1
\v 20 Lawe mai no oe i ka pouli, a ua po; Ia manawa, kolo mai na mea kolo a pau o ka nahelehele.   
\q1
\v 21 Uwo mai la hoi na liona opiopio i ko lakou wahi, A imi hoi i ka ai, mai ke Akua mai.   
\q1
\v 22 Puka mai la ka la, alaila, akoakoa lakou, A moe no lakou, ma ko lakou ana.   
\q1
\v 23 Hele aku no ke kanaka i kana hana, A i kona hooikaika hoi, a ahiahi.   
\b  
\q1
\v 24 Nani ka nui o kau mau hana, e Iehova! Ma ke akamai i hana mai ai oe ia mau mea a pau: Ua piha hoi ka honua i kau waiwai.   
\q1
\v 25 A me keia moana nui hoi, a palahalaha, Malaila no na mea kolo, pau ole i ka heluia, A me na mea ola, he liilii, a he nui no hoi.   
\q1
\v 26 Malaila no na moku e holo ae; Aia hoi kela leviatana au i hana'i, e paani ilaila.   
\b  
\q1
\v 27 Kakali no keia poe a pau ia oe, I haawi mai ai oe i ka lakou ai i ka wa pono.   
\q1
\v 28 O ka mea au e haawi mai ai na lakou, oia ka lakou e hooiliili iho; Wehe no oe i kou lima, a lako iho la lakou i ka maikai.   
\q1
\v 29 I huna oe i kou maka, make koke iho la lakou; Lawe oe i ko lakou ea, make no lakou, a hoi hou i ka lepo.   
\q1
\v 30 Hoouna mai oe i kou ea, ua hanaia iho la lakou; A nau no hoi i hoano hou i ka mnka o ka honua.   
\b  
\q1
\v 31 E mau loa ana no ka nani o Iehova; E lealea mai no o Iehova i kana mau hana.   
\q1
\v 32 Nana mai no oia i ka honua, a haalulu iho la ia; Hoopa mai oia i na mauna, uwahi ae la lakou.   
\q1
\v 33 E oli aku au ia Iehova i ka manawa o ko'u ola ana; E hoolea no hoi au i ke Akua, a i ko'u hopena,   
\q1
\v 34 He mea ono ko'u noonoo ana ia ia; A ma Iehova no wau e lealea ai.   
\q1
\v 35 E hookiia'e ka poe hewa mai ka honua aku, O ka poe lawehala hoi, aole e koe lakou. E hoomaikai aku ia Iehova, e kuu uhane: E halelu aku oukou ia Iehova.   
\c 105  
\b  
\q1
\v 1 E MILILANI aku ia Iehova, e kahea aku hoi i kona inoa: E hoike aku hoi i kana mau hana iwaena o na kanaka.   
\q1
\v 2 E oli aku ia ia, e hoolea aku ia ia; E hookaulana aku i kana mau hana a pau.   
\q1
\v 3 E kaena oukou ma kona inoa hoano, E lealea hoi ka naau o ka poe imi ia Iehova.   
\q1
\v 4 E huli oukou ia Iehova, a me kona ikaika; E imi mau loa aku hoi i kona maka.   
\q1
\v 5 E hoomanao i na hana mana ana i hana'i, A me kana mau mea kupanaha, A me ka hooponopono ana o kona waha:   
\q1
\v 6 E na pua a Aberahama, a kana kauwa, E na mamo a Iakoba, kona mea i wae ai.   
\q1
\v 7 Oia no o Iehova, ko kakou Akua: Aia ma ka honua a pau kana hoopononono ana.   
\b  
\q1
\v 8 Ua hoomanao mau mai oia i kona berita, I ka olelo hoi ana i kauoha mai ai i na hanauna he tausani;   
\q1
\v 9 Ka mea ana i hana mai ai ia Aberahama, A me kana hoohiki ana ia Isaaka;   
\q1
\v 10 A hoopaa mai no hoi oia ia mea ia Iakoba i kanawai nona, A ia Iseraela hoi, i berita mau loa.   
\q1
\v 11 I mai la, E haawi aku no wau ia oe i ka aina o Kanaana, I moku no oukou e nobo hooilina ai;   
\q1
\v 12 I ko lakou noho kanaka ole ana, na uuku; A he poe uuku a malihini hoi malaila.   
\q1
\v 13 Ia lakou i hele ai, mai kekahi aina, a i kekahi aina, A mai kekahi aupuni aku, a i kekahi lahuikanaka e;   
\q1
\v 14 Aole ia i kuu mai i kekahi kanaka a hana ino ia lakou; Papa mai no oia i na'lii no lakou:   
\q1
\v 15 Mai hoopa oukou i ko'u poe i poniia, A mai hana ino hoi i ko'u poe kaula.   
\b  
\q1
\v 16 Kahea ae no hoi ia, i wi ma ia aina, Uhai no hoi oia i ko kookoo berena a pau.   
\q1
\v 17 Hoouna ae la oia i ke kanaka mamua o lakou, A kuaiia o Iosepa i kauwa;   
\q1
\v 18 A hoeha lakou i kona mau wawae i ke kupee; A komo no hoi kona ola iloko o ka paahao;   
\q1
\v 19 A hiki i ka manawa o kana olelo ana; Alaila, hoao ae la ka olelo a Iehova ia ia.   
\q1
\v 20 Hoouna ae la ke alii, a hookuu iho la ia ia; Na ka luna o na kanaka i wehe ae ia ia.   
\q1
\v 21 Hoonoho iho la oia ia ia i haku maluna o kona bale, A i luna hoi maluua o kona waiwai a pau;   
\q1
\v 22 E nakinaki i kona poo alii, ma kona manao iho, A e hoonaauao hoi i kana poe luna kahiko.   
\q1
\v 23 Hele ae la o Iseraela i Aigupita; Noho malihini iho la o Iakoba ma ka aina o Hama.   
\q1
\v 24 Hookawowo nui iho la kela i kona poe kanaka, A hoomahuahua ae la i ko lakou ikaika imua o ko lakou poe enemi.   
\b  
\q1
\v 25 Hoohuli aku la oia i ko lakou naau, I inaina mai ai i kona poe kanaka, A e hana maalea hoi i kana poe kanwa,   
\q1
\v 26 Hoouna mai la oia ia Mose, i kana kanwa, Ia Aarona hoi, ka mea ana i wae mai ai   
\q1
\v 27 Hoike mai la laua i kona hoailona no lakou, A me kana mau hana kupanaha ma ka aina o Hama.   
\q1
\v 28 Hoouna mai la oia i ka pouli, a ua pouli iho la, Aole hoi laua i kipi aku i kana olelo.   
\q1
\v 29 Hoolilo mai la oia i ko lakou wai i koko, A hoopau hoi i ka lakou ia i ka make.   
\q1
\v 30 Hookawowo mai la ko lakou aina i na rana, Aia no iloko o na keena o ko lakou poe alii.   
\q1
\v 31 Olelo mai oia a hiki mai la na makika, O na uku hoi kekahi ma ko lakou mokuna a pau.   
\q1
\v 32 Haawi mai la oia i ko lakou ua, he huahekili, I ke ahi hoi, e lapalapa ana ma ko lakou aina,   
\q1
\v 33 Hahau mai la oia i ko lakou mau kumu waina, a me na laau fiku, o lakou; A uhai mai la hoi i na laau o ko, lakou mokuna.   
\q1
\v 34 Olelo mai la oia, a hiki mai la na uhini, A me na enuhe huluhulu pau ole i ka helu.   
\q1
\v 35 A ai iho la lakou i na mea uliuli a pau o ko lakou aina, A hoopau no hoi i ka hua o ka lakou mahinaai.   
\q1
\v 36 Pepehi no hoi oia i na makahiapo a pau o ko lakou aina, I ke pookela hoi o ko lakou ikaika a pau.   
\b  
\q1
\v 37 Hoopuka mai la oia ia lakou iwaho, me ke kala a me ke gula; Aohe mea nawaliwali mawaena o ko lakou mau ohana.   
\q1
\v 38 Olioli no ko Aigupita i ko lakou puka ana iwaho; No ka mea, kau mai la ka makau ia lakou maluna o ia poe.   
\q1
\v 39 Hohola ae la oia i ke ao e uhi ai ia lakou, I ke ahi hoi, e hoomalamalama mai i ka po.   
\q1
\v 40 Nonoi aku la lakou, a lawe mai la ia i na silo, A hoomaona mai la oia ia lakou i ka berena o ka lani.   
\q1
\v 41 Wahi ae la oia i ka pohaku, a poha mai la na wai; Kahe ae la lakou ma kahi maloo, he muliwai.   
\q1
\v 42 No ka mea, hoomanao ae la ia i kana olelo hoano, A me Aberahama hoi, i kana kauwa.   
\q1
\v 43 Hoopuka mai oia i kona poe kanaka me ka olioli, A me kona poe i waeia me ka hauoli.   
\q1
\v 44 Haawi mai la oia i ka aina o ko na aina e no lakou, A loaa mai ia lakou ka mea a na kanaka i hooikaika'i:   
\q1
\v 45 I mea e malama'i lakou i kana mau kauoha, A e hana pono hoi i kona mau kanawai. E halelu aku oukou ia Iehova.   
\c 106  
\b  
\q1
\v 1 E HALELU aku ia Iehova. E mililani aku ia Iehova, no ka mea ua maikai ia; Ua mau loa hoi kona lokomaikai.   
\q1
\v 2 Owai la ka mea e hai mai i na mea nui a Iehova? A e hoike mai hoi i kona hanohano a pau?   
\q1
\v 3 Pomaikai ka poe malama i ka hoopono, A hana i ka pololei i na manawa a pau.   
\b  
\q1
\v 4 E hoomanao mai oe ia'u, e Iehova, Me au e aloha'i i kou poe kanaka; E haawi mai no hoi ia'u i kou hoola ana.   
\q1
\v 5 I ike aku au i ka maikai o kou poe i waeia, I lealea hoi au ma ka lealea ana o kou lahuikanaka, I kaena hoi au ma kou poe hooilina.   
\b  
\q1
\v 6 Ua hewa pu no makou me ko makou poe kupuna, Ua lawehala hoi, a ua hana kolohe.   
\q1
\v 7 O ko makou poe kupuna ma Aigupita, Aole lakou i hoomaopopo i kau mau hana mana; Aole hoi lakou i hoomanao i ka nui o kou lokomaikai; A hoonaukiuki aku la ma ke kai, ma ke Kaiula hoi.   
\q1
\v 8 Aka, no kona inoa, hoola mai oia ia lakou, I hoike mai ai oia i kona mana.   
\q1
\v 9 Papa mai la oia i ke Kaiula, a maloo iho la ia; Alakai ae la oia ia lakou ma ka hohonu me he nahelehele la.   
\q1
\v 10 Hoola mai la oia ia lakou mai ka lima mai o ka poe inaina, A hoola panai hoi ia lakou mai ka lima mai o ka enemi.   
\q1
\v 11 Popoi mai la na wai i ko lakou poe enemi; Aole i hookoeia kekahi o lakou.   
\q1
\v 12 Alaila, hooiaio lakou i kana mau olelo, A oli iho la i mau halelu nona.   
\b  
\q1
\v 13 Poina koke ia lakou kana mau hana, Aole lakou i kakali i kana ao ana.   
\q1
\v 14 Kuko nui no lakou ma ka waonahele, A hoao lakou i ke Akua, ma ka waoakua.   
\q1
\v 15 Haawi mai la oia ia lakou i ka mea a lakou i noi aku ai; A haawi mai nae i ka hookii iloko o ko lakou uhane.   
\b  
\q1
\v 16 Huahua lakou ia Mose ma kahi hoomoana'i, A me Aarona hoi ka haipule a Iehova.   
\q1
\v 17 Wahi ae la ka honua, a moni iho la ia Datana, A poi mai la hoi maluna o ke anaina o Abirama,   
\q1
\v 18 Hoaaia ke ahi ma ko lakou anaina, A pau iho la ka poe hewa i ka lapalapa ahi.   
\b  
\q1
\v 19 Hana no lakou i keiki bipi ma Horeba, A kulou hoomana lakou ia kii hooheheeia.   
\q1
\v 20 Hoololi lakou i ko lakou nani I ke ano o ka bipi e ai ana i ka mauu.   
\q1
\v 21 Poina ia lakou ke Akua, ko lakou Hoola, Ka mea i hana i na mea nui ma Aigupita;   
\q1
\v 22 Na mea kupanaha hoi ma ka aina o Hama, Na mea weliweli hoi ma ke Kaiula.   
\q1
\v 23 Alaila, olelo no oia e luku ia lakou, Ina i ku ole o Mose, kona mea i waeia ma ka hakahaka imua ona. E pale aku i kona huhu i ole ia e luku mai.   
\q1
\v 24 A hoowahawaha no hoi lakou i ka aina aloha, Aole hoi i hooiaio i kana olelo.   
\q1
\v 25 Ohumu iho lakou ma ko lakou mau halelewa. Aole hoi i hoolohe i ka leo o Iehova.   
\q1
\v 26 Alaila, hoana ae la oia i kona lima, E hoohina ia lakou ma ka waonahele;   
\q1
\v 27 E hoohina hoi i ka lakou poe mamo mawaena o ko na aina e, A e hooauhee ia lakou maluna o ka honua.   
\b  
\q1
\v 28 Hoopili ae la lakou ia Baalapeora, A ai no hoi lakou i na mohai o ka poe i make.   
\q1
\v 29 Hoonaukiuki aku lakou ma ka lakou hana ana; A puka mai la ka mai make iwaena o lakou.   
\q1
\v 30 Alaila ku ae la o Pinehasa iluna, a hoopai iho la, A hookiia ua mai make la.   
\q1
\v 31 Manaoia'e la ia, he pono nona, I kela hanauna, i keia hanauna, a mau loa aku.   
\b  
\q1
\v 32 Hoonaukiuki aku lakou ia ia ma na wai o Meriba, A hewa o Mose, no lakou la.   
\q1
\v 33 No ka mea, hookuee lakou i ka manao ana, A olelo pono ole mai la oia ma kona mau lehelehe.   
\b  
\q1
\v 34 Aole lakou i luku ae i na lahuikanaka, A Iehova i kauoha mai ai ia lakou.   
\q1
\v 35 Ua huiia no lakou me ko na aina e, A ao mai la lakou i ka lakou mau hana.   
\q1
\v 36 Malama aku no hoi i ko lakou poe akua kii, A lilo ia i pahele na lakou.   
\q1
\v 37 Alaila, mohai aku la lakou i ka lakou poe keikikane, A me ka lakou poe kaikamahine no na daimonio.   
\q1
\v 38 Hookahe ae la lakou i ke koko hala ole, I ke koko hoi o ka lakou poe keikikane, a me ka lakou poe kaikamahine, Na mea a lakou i mohai aku ai i na'kua kii o Kanaana; A hoohaumiaia ka aina i ke koko.   
\q1
\v 39 A haumia no hoi lakou i ka lakou mau hana, A moe kolohe lakou me na mea a lakou i hana'i.   
\b  
\q1
\v 40 Nolaila, hoaaia ka inaina o Iehova i kona poe kanaka, A hoopailua mai la oia i kona hooilina iho.   
\q1
\v 41 A haawi ae la ia ia lakou i ka lima o ko na aina e; A noho alii maluna o lakou ka poe inaina mai ia lakou.   
\q1
\v 42 Hookaumaha mai no hoi ko lakou poe enemi ia lakou, A hoohaahaaia mai no hoi malalo iho o ko lakou lima.   
\q1
\v 43 Hoopakele pinepine mai la oia ia lakou; Aka, hoonaukiuki aku lakou ia ia, ma ko lakou manao, A hokii iho la lakou no ko lakou hewa.   
\b  
\q1
\v 44 Alaila, ike mai la oia i ko lakou pilikia, Ia ia i lohe ai i ko lakou olo pihe ana.   
\q1
\v 45 A hoomanao mai la oia i kona berita me lakou, A minamina iho la oia, e like me ka nui o kona lokomaikai ana.   
\q1
\v 46 Alaila, haawi mai la oia ia lakou I ke alohaia imua o ka poe a pau i lawe pio ia lakou.   
\b  
\q1
\v 47 E hoola mai oe ia makou, e Iehova, e ko makou Akua, E hoiliili mai ia makou, maiwaena mai o ko na aina e, I mililani aku makou i ka inoa hoano, A e hiilani aku hoi ma kou halelu.   
\q1
\v 48 E hoomaikaiia o Iehova, ke Akua o ka Iseraela, Mai kahiko loa mai, a mau loa aku no: E i mai no hoi na kanaka a pau, Amene. E halelu aku ia Iehova.   
\c 107  
\b  
\q1
\v 1 E MILILANI aku ia Iehova, no ka mea, ua maikai ia; Ua mau loa no hoi kona lokomaikai.   
\q1
\v 2 E olelo mai no ka poe i hoolapanaiia e Iehova, Ka poe hoi ana i hoolapanai ai, mai ka lima mai o ka enemi.   
\q1
\v 3 No ka mea, ua hooili mai oia ia lakou mai na aina mai, Mai ka hikina, a me ke komohana mai, E mai ke kukulu akau, a mai ke kai mai.   
\b  
\q1
\v 4 Kuewa wale lakou ma ka waonahele, Ma ke ala waoakua hoi; Aole i loaa ia lakou ke kulanakauhale kahi e noho ai.   
\q1
\v 5 Pololi iho la lakou, a makewai hoi, A maule ko lakou uhane iloko o lakou.   
\q1
\v 6 Alaila, kahea aku lakou ia Iehova iloko o ko lakou pilikia, A hoopakele mai oia ia lakou i ko lakou popilikia ana.   
\q1
\v 7 Alakai mai la oia ia lakou ma ke ala pono, I hiki ai lakou i ke kulanakauhale, kahi e noho ai.   
\q1
\v 8 E mililani aku na kanaka ia Iehova no kona lokomaikai, A no kana mau hana kupanaha i na keiki a kanaka!   
\q1
\v 9 No ka mea, nana no i hookena i ka uhane makewai, A nana hoi i hoomaona i ka uhane pololi i ka maikai.   
\b  
\q1
\v 10 O ka poe i noho ma ka pouli, ma ka malu hoi o ka make, A paa no hoi i ka popilikia a me ka hao;   
\q1
\v 11 No ka mea, ua kipi lakou i na olelo a ke Akua, A ua hoowahawaha i ke ao ana mai o ka Mea kiekie;   
\q1
\v 12 Alaila hookulou oia i ko lakou naau i ka luhi, Hina iho la lakou ilalo, aohe mea nana e kokua.   
\q1
\v 13 Alaila, hea aku lakou ia Iehova i ko lakou pilikia ana, A hoola mai oia ia lakou i ko lakou popilikia ana.   
\q1
\v 14 Hoopuka mai la oia ia lakou mailoko mai o ka pouli a me ka malu o ka make, A uhai hoi i ko lakou mea i paa ai.   
\q1
\v 15 E hoalohaloha aku na kanaka ia Iehova, no kona lokomaikai, A no kana mau hana kupanaha i na keiki a kanaka!   
\q1
\v 16 No ka mea, ua wawahi oia i na pani keleawe o na pukapa A ua uhai no hoi oia i na kaola kipuka hao.   
\b  
\q1
\v 17 O ka poe i lalau ma ka aoao o ka poe hewa, A me ka lawehala, ua hoopilikiaia lakou.   
\q1
\v 18 Hoopailua no ko lakou uhane i na mea ai a pau; A hookokoke no lakou i na pukapa o ka make.   
\q1
\v 19 Alaila, hea aku no lakou ia Iehova i ko lakou pilikia ana, A hoola mai no oia ia lakou i ko lakou popilikia.   
\q1
\v 20 Haawi mai la oia i kana olelo, a hoala iho la ia lakou, A hoopakele no hoi ia lakou, mai ko lakou lua aku.   
\q1
\v 21 E hoalohaloha aku na kanaka ia Iehova no kona lokomaikai, A no kana mau hana kupanaha i na keiki a kanaka!   
\q1
\v 22 E mohai aku no hoi lakou i ka mohai o ke aloha, A e hoike aku i kana mau hana me ka hauoli.   
\b  
\q1
\v 23 O ka poe iho ilalo i ka moana, ma na moku, A hana i ka hana ma na moana nui;   
\q1
\v 24 Ua ike no keia poe i na hana o Iehova, A mo kana mau mea kupanaha ma ka hohonu.   
\q1
\v 25 No ka mea, olelo wale mai oia, a hoala i ka makani kupikipikio, A piipii aku la na ale.   
\q1
\v 26 Pii aku la lakou i ka lani, a iho ilalo i ka hohonu: A hehee ko lakou uhane i ka ino.   
\q1
\v 27 Hikaka lakou i o, a ia nei, a kunewanewa hoi e like me ke kanaka ona, A pau wale aku no ko lakou akamai.   
\q1
\v 28 Alaila, hea aku lakou ia Iehova i ko lakou pilikia ana, A hoopakele mai oia ia lakou, mailoko mai o ko lakou popilikia.   
\q1
\v 29 Hoolilo no oia i ka ino i pohu, A malie loa iho la na ale.   
\q1
\v 30 Alaila, lealea lakou, no ka mea, ua malie; A hoopae no oia ia lakou ma ke awa a lakou e makemake ai.   
\q1
\v 31 E mililani aku na kanaka ia Iehova no kona lokomaikai, A no kana mau hana kupanaha i na keiki a kanaka!   
\q1
\v 32 E hapai no hoi ia ia ma ka ahakanaka, A e halelu aku ia ia ma ke anaina o ka poe kahiko.   
\b  
\q1
\v 33 Hoolilo no oia i na muliwai i waonahele, A me na waipuna i aina maloo;   
\q1
\v 34 A me ka aina hua nui, i aina hua ole, No ka hewa o ka poe e noho ana malaila.   
\q1
\v 35 A hoolilo no hoi oia i ka waonahele, i wai lana, A me ka aina maloo hoi i wai puna.   
\q1
\v 36 Malaila no oia e hoonoho ai i ka poe pololi, A hoomakaukau no hoi lakou i kulanakauhale, kahi e noho ai;   
\q1
\v 37 A lulu no hoi lakou ma na mahinaai, A kauu iho no i na mala waina, A haawiia mai ka hua i hoohuaia'i.   
\q1
\v 38 Hoomaikai mai la oia ia lakou, a kawowo nui ae la; Aole ia i hoemi i ka lakou poe holoholona.   
\b  
\q1
\v 39 A mahope, hooemiia lakou, a hoohaahania no hoi, No ka hookaumahaia, a me ka hewa, a me ka pilikia.   
\q1
\v 40 Ninini mai oia i ka hoomaau maluna o na'lii, A alakai no hoi oia ia lakou ma kahi mehameha, ala ole.   
\q1
\v 41 Hookiekie nae oia i ka poe hune mailoko aku o ka pilikia, A hoolilo i kona mau ohana, me he ohana hipa la.   
\q1
\v 42 E ike aku no ka poe pono, a e lealea lakou; A e paa no ka nuku o ka hewa a pau.   
\q1
\v 43 Owai la ka mea akamai, a malama i keia mau mea! O lakou ka i hoomaopopo i ka lokomaikai o Iehova.   
\c 108  
\b  
\q1
\v 1 U A paa kuu naau, e ke Akua; E oli aku no au, a e hoolea aku hoi, a me ko'u nani.   
\q1
\v 2 E ala mai, e ke kuolokani, a me ka mea kani; E ala no hoi au i ka wanaao.   
\q1
\v 3 E mililani aku au ia oe, e Iehova, iwaena o na kanaka; A e hoolea aku ia oe iwaena o na lahuikanaka.   
\q1
\v 4 No ka mea, ua nui kou lokomaikai maluna o ka lani, A me kou oiaio maluna o na ao.   
\q1
\v 5 Ua kiekie loa no oe, e ke Akua, maluna o ka lani, A me kou nani hoi maluna o ka honua a pau.   
\q1
\v 6 I hoopakeleia kou poe aloha, E hoola mai oe me kou lima akau, a e hoolohe ia makou.   
\b  
\q1
\v 7 I mai la ke Akua ma kona mea hemolele, E hooho aku au, e mahele au ia Sekema, A e ana aku au i ke awawa o Sukota.   
\q1
\v 8 Na'u o Gileada, na'u o Manase, o Eperaima ka pale o kuu poo, A o Iuda hoi ka'u kakaolelo;   
\q1
\v 9 O Moaba ko'u ipu holoi, e hoolei au i ko'u kamaa maluna o Edoma, E kahea olioli no wau maluna o Pilisetia.   
\b  
\q1
\v 10 Owai la ka mea e alakai ia'u i ke kulanakauhale paa? Owai ka mea alako ia'u a hiki i Edoma?   
\q1
\v 11 Aole anei oe, e ke Akua, ka mea i kipaku mai ia makou? E ke Akua, aole anei oe e hele pu me ko makou mau kaua?   
\q1
\v 12 E haawi mai oe i ke kokuaia mai no ka pilikia; No ka mea, makehewa ke kokua ana o ke kanaka.   
\q1
\v 13 Ma ke Akua kakou e loaa'i ka ikaika, Nana no e hahi i ko kakou poe enemi.   
\c 109  
\b  
\q1
\v 1 E KE Akua a'u i halelu ai, mai hookuli mai oe;   
\q1
\v 2 No ka mea, o ka waha o ka mea hewa, A me ka waha wahahee, ua hamama mai laua e ku e ia'u; Ua olelo ku e mai lakou ia'u, me ke elelo wahahee.   
\q1
\v 3 Hoopuni mai lakou ia'u i na olelo huhu; A hakaka mai lakou ia'u me ka hala ole o'u.   
\q1
\v 4 No ko'u aloha enemi mai lakou ia'u; E pule aku no nae au.   
\q1
\v 5 Hookau mai lakou i ka hewa maluna o'u no ka maikai, A me ka inaina no ko'u aloha.   
\b  
\q1
\v 6 E hoonoho oe i ka mea hewa maluna ona; A e hooku mai ia Satana ma kona lima akau.   
\q1
\v 7 Ia ia e hookolokoloia'i, E puka mai no kona hewa, A e lilo no kana pule i mea e hewa'i.   
\q1
\v 8 E uuku no kona mau la, E lawe hoi kekahi i kana oihana.   
\q1
\v 9 E makua ole auanei kana poe keiki, A e lilo auanei kana wahine i wahinekanemake.   
\q1
\v 10 E kuewa, e kuewa wale aku no kana poe keiki, a e nonoi wale; E imi wale lakou ma ko lakou wahi neoneo.   
\q1
\v 11 Na ka makee waiwai e kaili wale i kana mau mea a pau, A na na malihini e hao wale i kona waiwai.   
\q1
\v 12 Aohe mea nana e hoomau i ka lokomaikai ia ia; Aohe hoi mea aloha i kana mau huahaule.   
\q1
\v 13 E hookiia kana poe mamo; A ia hanauna aku e holoiia ko lakou inoa.   
\b  
\q1
\v 14 E hoomanaoia ka hewa o kona poe kupuna imua o Iehova; Aole hoi e kalaia na hewa o kona makuwahine.   
\q1
\v 15 E mau loa ana no lakou imua o Iehova; I hookiia ka manao ana ia lakou mai ka honua aku.   
\q1
\v 16 No ka mea, aole ia i hoomanao e hana i ka lokomaikai, A hoomaau oia i ke kanaka nele, a ilihune hoi, I pepehi oia i ka mea naau ehaeha.   
\q1
\v 17 Me ia i makemake ai i ka hailiili, pela no e hiki mai ai ia maluna ona; Me ia i makemake ole ai i ka hoomaikai, e mamao loa ia mai ona aku.   
\q1
\v 18 Kahiko no oia ia ia iho i ka hailiili me he kapa la, E komo no hoi ia iloko o kona opu me he wai la, A e like hoi me ka aila iloko o kona mau iwi.   
\q1
\v 19 A e like no auanei ia me he kapa la ia ia, A me ke kaei hoi ana e kaei mau ai.   
\q1
\v 20 O keia no ka uku o ko'u poe enemi mai o Iehova mai, A me ko ka poe hoi e olelo ino mai i ko'u uhane.   
\b  
\q1
\v 21 Aka, e hana mai oe mamuli o'u, e Iehova ka Haku, no kou inoa iho: No ka mea, ua maikai kou lokomaikai, e hoopakele mai ia'u.   
\q1
\v 22 No ka mea, ua nele, a ua ilihune hoi au, A ua houia ko'u naau iloko ou.   
\q1
\v 23 Ua hele aku au e like me ke aka i kona auwi ana, Ua kuehuehuia au me he uhini la.   
\q1
\v 24 Kulanalana ko'u mau kuli no ka hookeai, A hookii no hoi ko'u kino ma ke kelekele.   
\q1
\v 25 Ua lilo wau i mea hoomaewaewa no lakou; Nana mai lakou ia'u, a kunokunou i ko lakou poo.   
\b  
\q1
\v 26 E kokua mai oe ia'u, e Iehova, ko'u Akua; E hoola mai oe ia'u e like me kou lokomaikai ana.   
\q1
\v 27 I ike mai hoi lakou, o kou lima keia; O oe hoi e Iehova, ka mea nana i hana ia mea.   
\q1
\v 28 Na lakou e hailiili mai, aka, e hoomaikai mai oe, A ku mai lakou iluna, e hoohilahilaia lakou; Aka, e hoohauoli mai oe i kau kauwa.   
\q1
\v 29 E kahikoia ko'u poe enemi i ka hoopalaimaka, A e uhi no lakou ia lakou iho i ka hilahila me he holoku la.   
\b  
\q1
\v 30 E mililani nui aka au ia Iehova, ma ko'u waha; A e halelu aku ia ia mawaena o ka lehulehu.   
\q1
\v 31 No ka mea, e ku mai auanei oia ma ka lima akau o ka mea hune, E hoopakele i kona uhane mai ka poe hoohewa ia ia.   
\c 110  
\b  
\q1
\v 1 OLELO mai la o Iehova i kuu Haku, E noho mai oe ma ko'u lima akau, A hoolilo iho ai au i kou poe enemi I keehana wawae nou.   
\q1
\v 2 E hoouna mai no o Iehova i ke kookoo o kou ikaika, mai Ziona mai; E noho aupuni hoi oe mawaena o kou poe enemi.   
\q1
\v 3 E ae oluolu mai no kou poe kanaka ke hiki ka la o kou ikaika, Me ka mea nani hoano, Mai ka opu mai o ka wanaao, Ia oe ka hau o kou poe opiopio.   
\b  
\q1
\v 4 Ua hoohiki mai la o Iehova, aole hoi oia e luli ae, He kahuna mau loa no oe, mamuli o ke ano o Melekizedeka.   
\q1
\v 5 Ma kou lima akau ka Haku, E paopao ai i na'lii i kona la e huhu ai.   
\q1
\v 6 Nana no e hoopai iwaena o ko na aina e, A e hoopiha i na wahi i na kupapau; A nana no e paopao i na poo maluna o na aina he nui loa.   
\q1
\v 7 Ma ke ala no oia e inu ai i ka muliwai; Nolaila, e hookiekie oia i ke poo.   
\c 111  
\b  
\q1
\v 1 E HALELU aku ia Iehova: E mililani aku au ia Iehova me kuu naau a pau, Ma ke anaina o ka poe pono, a me ka ahakanaka no hoi.   
\q1
\v 2 He mana no na hana a Iehova, A ua imiia hoi e ka poe a pau i makemake aku ia mau mea.   
\q1
\v 3 He nani, a he hanohano hoi kana hana; E mau loa ana no kona pono.   
\q1
\v 4 Ua hana oia i mea e hoomanaoia'i kana mau hana mana: He aloha, a he lokomaikai o Iehova.   
\q1
\v 5 Ua haawi mai oia i ka ai na ka poe makau aku ia ia: E hoomanao mau loa no oia i kona berita.   
\q1
\v 6 Ua hoike mai oia i kona poe kanaka i ka mana o kana mau hana, I ka haawi ana mai ia lakou e noho ma na hooilina o ko na aina e.   
\b  
\q1
\v 7 O na hana a kona mau lima, he oiaio, a he hoopono, He oiaio no kana mau kauoha a pau.   
\q1
\v 8 Onipaa loa lakou, a i ka manawa pau ole, Ua hanaia ma ka oiaio, a ma ka pololei.   
\q1
\v 9 Hoouna mai oia i ka hoolapanai no kona poe kanaka: Ua kauoha mai oia, e mau loa kona berita: He hoano, a he mea weliweli hoi kona inoa.   
\q1
\v 10 O ka makau aku ia Iehova, oia ke kumu o ke akamai; He naauao maikai ka poe a pau o hana malaila; E mau loa ana no kona hoonaniia.   
\c 112  
\b  
\q1
\v 1 E HALELU aku ia Iehova. Pomaikai ke kanaka i makau aku ia Iehova, A lealea nui hoi ma kana mau kauoha.   
\q1
\v 2 E nui ana auanei kana poe mamo ma ka honua; E pomaikai auanei ka hanauna o ka poe pololei.   
\q1
\v 3 Aia ma kona hale ka waiwai a me ka ukana; A e mau loa ana no kona pono.   
\q1
\v 4 No ka poe pono, puka mai no ka malamalama mailoko mai o ka pouli; He aloha, he lokomaikai, a he pono kona.   
\q1
\v 5 O ke kanaka maikai, aloha ae la ia a haawi ae no hoi: Hooponopono no oia i kona mau mea, me ka naauao.   
\q1
\v 6 Aole ia e kulanalana, a i ke ao pau ole; E hoomanao mau loa ia no hoi ka poe pono.   
\b  
\q1
\v 7 Aole ia e makau i ka lono ana i na mea hewa; Ua onipaa kona naau, me ka hilinai aku ia Iehova.   
\q1
\v 8 Ua kooia kona naau, aole ia e makau, A ike aku oia i ka mea maluna o kona poe enemi.   
\q1
\v 9 Ua lulu aku oia, ua haawi wale i ka poe ilihune, E mau loa ana no kona pono; E hookiekieia kona pepeiaohao me ka hanohano.   
\b  
\q1
\v 10 E ike mai no ka poe hewa, a huahua; E uwi no kona mau niho a e hehee wale oia: E pau auanei ka mea a ka poe hewa i makemake ai.   
\c 113  
\b  
\q1
\v 1 E HALELU aku ia Iehova: E halelu, e na kauwa a Iehova, E halelu aku oukou i ka inoa o Iehova.   
\q1
\v 2 E hoomaikaiia ka inoa o Iehova, Mai keia wa aku a i ka manawa pau ole.   
\q1
\v 3 Mai ka puka ana a ka la, a hiki i kona komo ana, E haleluia ka inoa o Iehova.   
\q1
\v 4 Ua kiekie o Iehova, maluna o ko na aina a pau, A me kona hanohano hoi maluna o ka lani.   
\b  
\q1
\v 5 Owai la ka i like me Iehova, ko kakou Akua? Ka mea hookiekie i kona wahi nobo ai;   
\q1
\v 6 Ka mea hoohaahaa, e ike i ka lani, A i ka honua no hoi:   
\q1
\v 7 Ka mea i hapai i ka mea ilihune, mai ka lepo mai, A hookiekie hoi i ka mea pilikia, mai ke kiona aku;   
\q1
\v 8 I hoonoho ai oia ia ia me na'lii, Me na'lii hoi o kona poe kanaka.   
\q1
\v 9 A hoonoho hoi oia i ka wahine pa ma ka hale, I makuwahine, e lealea ana i na keiki ana. E halelu aku oukou ia Iehova.   
\c 114  
\b  
\q1
\v 1 KA hale o Iakoha hoi, mai waena aku o na kanaka olelo e;   
\q1
\v 2 O Iuda no kona keenakapu, A o Iseraela kona aupuni.   
\b  
\q1
\v 3 Ike mai la ke kai, a holo aku la; A huli hope o Ioredane.   
\q1
\v 4 Lelele ae la na mauna e like me na hipakane, A me na puu hoi e like me na keikihipa.   
\q1
\v 5 Heaha kau, e ke kai, i holo aku ai oe? E Ioredane hoi, i hoohuliia'i oe ihope?   
\q1
\v 6 E na mauna, i lelele ai oukou e like me na hipakane? A me na puu hoi e like me na keikihipa?   
\b  
\q1
\v 7 E naueue oe, e ka honua, imua o ka Haku, Imua hoi o ke Akua o Iakoha.   
\q1
\v 8 Ka mea i hoolilo i ka pohaku, i wai lana, A me ka pohaku paea, i punawai.   
\c 115  
\b  
\q1
\v 1 A OLE ia makou, e Iehova, aole ia makou, Aka. i kou inoa no e haawiia'ka ai ka hoonani. No kou lokomaikai, a me kou oiaio.   
\q1
\v 2 No ke aha la i olelo mai ai ko na aina e, Aubea ko lakou Akua?   
\q1
\v 3 Aia no i ka lani ko makou Akua; Ua haua no oia i na mea a pau ana i makemake ai.   
\q1
\v 4 O ko lakou poe akua, he kala, a he gula hoi, O ka haua a na lima o kanaka.   
\q1
\v 5 He waha no ko lakou, aole nae e olelo mai; He maka no ko lakou, aole nae e ike mai:   
\q1
\v 6 He pepeiao no ko lakou, aole nae e lohe; He ihu no hoi ko lakou, aole nae e honi:   
\q1
\v 7 He mau lima no ko lakou, aole nae e lawelawe; He mau wawae no ko lakou, aole nae e hele; Aole hoi e olelo lakou, ma ko lakou kania-i.   
\q1
\v 8 Me ia poe akua, pela no ka poe i hana ia lakou, A me ka poe a pau e hilinai ia lakou.   
\b  
\q1
\v 9 E ka Iseraela, e hilinai oukou ia Iehova; Oia ko lakou kokua a me ko lakou palekaua.   
\q1
\v 10 E ka ohana a Aarona, e hilinai oukou ia Iehova; Oia ko lakou kokua, a me ko lakou palekaua.   
\q1
\v 11 E ka poe makau ia Iehova, e hilinai oukou ia Iehova; Oia ko lakou kokua, a me ko lakou palekaua.   
\q1
\v 12 Ua hoomanao mai o Iehova ia kakou, e hoomaikai no oia; E hoomaikai mai no oia i ka ohana a Iseraela, E hoomaikai mai no oia i ka ohana a Aarona.   
\q1
\v 13 E hoomaikai mai no oia i ka poe e makau aku ia Iehova, I na mea uuku, a me na mea nui.   
\q1
\v 14 E hoomahuahua mai no o Iehova ia oukou, Ia oukou no, a me ka oukou poe keiki.   
\q1
\v 15 Ua hoopomaikaiia oukou e Iehova, Ka mea nana i hana ka lani, a me ka honua.   
\b  
\q1
\v 16 Na Iehova no na lani o na lani; Ua haawi mai nae oia i ka honua no na keiki a kanaka.   
\q1
\v 17 Aole ka poe make e halelu aku ia Iehova, Aole hoi ka poe a pau e iho ilalo i kahi ekemu ole.   
\q1
\v 18 Aka, o kakou, e hoomaikai aku no kakou ia Iehova, Mai keia wa aku, a i ka manawa pau ole. E halelu aku oukou ia Iehova,   
\c 116  
\b  
\q1
\v 1 KE aloha aku nei au ia Iehova, No ka mea, ua hoolohe mai oia i ka leo o ko'u nonoi ana.   
\q1
\v 2 No ka mea hoi, ua haliu mai kona pepeiao ia'u, Nolaila, e kahea aku au ia ia i ko'u mau la.   
\q1
\v 3 Hoopuni mai na hei o ka make ia'u, A loaa ia'u ka pilikia o ka malu o ka make, A loaa no hoi ia'u ka popilikia, a me ka ehaeha.   
\q1
\v 4 Alaila, kahea aku la au i ka inoa o Iehova; Ke nonoi aku nei au ia oe, e Iehova, E hoopakele mai oe i ko'u uhane.   
\b  
\q1
\v 5 He aloha ko Iehova, a he pono no; Ua lokomaikai no hoi ko kakou Akua.   
\q1
\v 6 Ke malama mai nei o Iehova i ka mea oluolu: Maule no wau, a nana no i hoola mai ia'u.   
\q1
\v 7 E kuu uhane, e hoi oe i kou wahi e hoomaha'i, No ka mea, hana maikai mai o Iehova ia oe.   
\q1
\v 8 No ka mea, ua hoopakele mai oe i ko'u uhane i ka make, A me ko'u mau maka, i ka waimaka, A me ko'u mau wawae, i ka hina ana.   
\q1
\v 9 E holoholo no wau imua o Iehova, Ma ka honua, kahi o ka poe ola.   
\q1
\v 10 Manaoio no wau, nolaila au i olelo aku ai; Pilikia loa no nae au;   
\q1
\v 11 I ko'u pioloke ana, olelo ae la au, He poe wahahee na kanaka a pau.   
\b  
\q1
\v 12 Heaha ka'u e haawi aku ai ia oe, e Iehova, No kou lokomaikai mai a pau ia'u?   
\q1
\v 13 E hapai no wau i ke kiaha o ke ola, A e kahea aku i ka inoa o Iehova.   
\q1
\v 14 E haawi no wau ia Iehova i ko'u mea i hoohiki ai, Imua o kona poe kanaka a pau.   
\q1
\v 15 He mea minamina ia imua o Iehova, Ka make ana o kona poe haipule.   
\q1
\v 16 Aia hoi, e Iehova, owau no kau kauwa, O kau kauwa no wan, a o ke keiki hoi a kau kauwa wahine; Ua wehe mai oe i ko'u mau mea i paa ai.   
\q1
\v 17 E kaunmaha aku au ia oe i ka mohai mililani, A e kahea aku hoi i ka inoa o Iehova.   
\q1
\v 18 E haawi no wau ia Iehova i ko'u mea i hoohiki ai, Imua o kona poe kanaka a pau,   
\q1
\v 19 Ma na kahua o ka hale o Iehova, Mawaena konu ou, e Ierusalema. E halelu aku oukou ia Iehova.   
\c 117  
\b  
\q1
\v 1 E HALELU aku oukou ia Iehova, e ko na aina a pau; E hiilani aku ia ia, e na lahuikanaka a pau.   
\q1
\v 2 No ka mea, ua nui loa kona lokomaikai mai ia kakou; A o ka oiaio o Iehova, ua mau loa no ia. E halelu aku oukou ia Iehova.   
\c 118  
\b  
\q1
\v 1 E MILILANI aku ia Iehova; no ka mea, he maikai ia; A ua mau loa hoi kona lokomaikai.   
\q1
\v 2 E olelo mai o ka Iseraela, Ua mau loa kona lokomaikai.   
\q1
\v 3 E olelo mai ka ohana a Aarona, Ua mau loa kona lokomaikai.   
\q1
\v 4 E olelo mai no ka poe e makau aku ia Iehova, Ua mau loa kona lokomaikai.   
\b  
\q1
\v 5 Maloko o ka pilikia, kahea aku au ia Iehova; A ae mai o Iehova ia'u ma kahi akea.   
\q1
\v 6 O Iehova pu no me a'u, aole au e makau: Heaha ka mea a ke kanaka e hana mai ai ia'u?   
\q1
\v 7 O Iehova pu no me au, a me ka mea i kokua ia'u; A e nana ae au i ka poe inaina mai ia'u.   
\q1
\v 8 Ua oi aku ka maikai o ka hilinai aku ia Iehova, Mamua o ka manao ana i ke kanaka.   
\q1
\v 9 Ua oi aku ka maikai o ka hilinai aku ia Iehova, Mamua o ka manao ana i na'lii.   
\b  
\q1
\v 10 Hoopuni mai ko na aina a pau ia'u, Aka, ma ka inoa o Iehova, e luku aku ai au ia lakou.   
\q1
\v 11 Hoopuni mai no lakou ia'u, Oia, hoopuni mai no lakou ia'u; Aka, ma ka inoa o Iehova, e luku aku ai au ia lakou.   
\q1
\v 12 Hoopuni mai lakou ia'u, me he poe nalomeli la, Ua pio wale lakou, e like me ke ahi kakalaioa; No ka mea, ma ka inoa o Iehova wau e luku aku ai ia lakou.   
\q1
\v 13 Ua hooke ikaika mai oe ia'u, i hina au; Aka, ua kokua mai o Iehova ia'u.   
\q1
\v 14 O Iehova no ko'u ikaika, a me ko'u mea e hoolea ai, Ua lilo mai oia i Hoola no'u.   
\b  
\q1
\v 15 Aia ka leo o ka hanoli, a me ka hoola, Ma na halelewa o ka poe pono: Ke hana koa nei ka lima akau o Iehova.   
\q1
\v 16 Ua hapaiia ka lima akau o Iehova a kiekie; Ke hana koa nei ka lima akau o Iehova.   
\q1
\v 17 Aole au e make, aka e ola aku no au, A e hoike aku au i ka hana a Iehova.   
\q1
\v 18 Ua hahau nui mai o Iehova ia'u, Aole nae oia i haawi mai ia'u i ka make.   
\b  
\q1
\v 19 E wehe mai oe i na pukapa o ka pono no'u, E komo aku no wau iloko olaila, A e mililani aku au ia Iehova.   
\q1
\v 20 O keia no ka pukapa o Iehova, E komo aku hoi ka poe pono iloko olaila.   
\q1
\v 21 E mililani aku au ia oe, no ka mea, ua hoolohe mai oe ia'u, A ua lilo mai oe i hoola no'u.   
\b  
\q1
\v 22 O ka pohaku a ka poe hana hale i haalele ai, Ua lilo ia i pohaku kumu no ke kihi.   
\q1
\v 23 Na Iehova mai no keia, A he mea mahaloia no hoi ia i ko kakou mau maka.   
\q1
\v 24 O keia no ka la a Iehova i hana'i, E hauoli kakou, a e lealea ilaila.   
\q1
\v 25 Ke noi aku nei au ia oe, e Iehova, E hoola mai oe ano; Ke noi aku nei au ia oe, e Iehova, Ano oe e hoopomaikai mai.   
\q1
\v 26 E hoomaikaiia ka mea e hele mai ana ma ka inoa o Iehova; Ua hoomaikai aku makou ia oukou mailoko aku o ka hale o Iehova.   
\q1
\v 27 O ke Akua no o Iehova, ua hoomalamalama mai oia ia kakou; E nakinaki i ka mohai i na kaula, Ma na pepeiaohao o ke kuahu.   
\q1
\v 28 O oe no ko'u Akua, e mililani aku au ia oe; O ko'u Akua no, e hapai aku au ia oe.   
\q1
\v 29 E mililani aku ia Iehova, no ka mea, ua maikai oia; Ua mau loa hoi kona lokomaikai.   
\c 119  
\b  
\q1
\v 1 POMAIKAI ka poe i pono ka noho ana, A hele hoi ma ke kanawai o Iehova.   
\q1
\v 2 Pomaikai ka poe malama i kana mau kauoha, E imi aku no lakou ia ia me ka naau a pau.   
\q1
\v 3 Aole lakou e hana hewa, Ma kona aoao no lakou e hele ai.   
\q1
\v 4 Ua kauoha mai oe, E malama loa i kau mau olelo ao.   
\q1
\v 5 Ina i hoomakaukauia ko'u mau aoao, E malama i kau mau kauoha!   
\q1
\v 6 Alaila, aole au e hilahila, I ko'u nana pono ana i kau mau kanoha a pau.   
\q1
\v 7 E mililani aku au ia oe, me ko kupono o ka naau, Ia'u e hoomaopopo ai i kou hooponopono pololei ana.   
\q1
\v 8 E malama no wau i kau mau kauoha: Mai haalele mai oe ia'u, aole loa.   
\b  
\q1
\v 9 Pehea la e hoomaemae ai ke kanaka ui i kona aoao? I ka malama ana, e like me kau olelo.   
\q1
\v 10 Ua imi aku au ia oe me kuu naau a pau; Mai kuu mai oe ia'u, e ae maluna o kau mau kauoha.   
\q1
\v 11 Ua huna no wau i kau olelo iloko o ko'u naau, I ole au e hana hewa aku ia oe.   
\q1
\v 12 E hoomaikaiia oe, e Iehova; E ao mai oe ia'u i kau mau olelopaa.   
\q1
\v 13 Ua hoike aku au, ma ko'u mau Iehelehe, I na olelo hoopono a kou waha.   
\q1
\v 14 Ua olioli no wau ma ka aoao o kau mau kauoha, Mamua o ko ka waiwai a pau.   
\q1
\v 15 Ma kou mau kanawai wau e noonoo ai, A e haliu hoi i kou mau kuamoo.   
\q1
\v 16 E hauoli no wau i kau mau kauoha, Aole hoi e hoopoina i kau olelo.   
\b  
\q1
\v 17 E hana maikai mai oe ia'u, i ola au, A e malama hoi i kau olelo.   
\q1
\v 18 E hookaakaa mai oe i ko'u mau maka, Alaila, e ike aku au i na mea kupanaha noloko mai o kou mau kanawai.   
\q1
\v 19 He malihini au ma ka honua; Mai huna oe i kau mau kauoha ia'u.   
\q1
\v 20 Ua haehae ko'u uhane i ka iini aku I kou hooponopono ana i na manawa a pau.   
\q1
\v 21 Ua papa mai no oe i ka poe kaena wale, a poino, Ka poe i hele hewa mai kou mau kauoha aku.   
\q1
\v 22 E lawe aku oe i ka hoinoia, a me ka hoowahawahaia, mai o'u aku; No ka mea, ua malama au i kou mau kanawai.   
\q1
\v 23 Noho mai la na'lii e olelo ku e ia'u; Ua noonoo nae kau kauwa i kau mau olelopaa.   
\q1
\v 24 O kou mau kanawai ka'u e hauoli nei, A o ko'u poe kanaka ia nana wau e ao mai.   
\b  
\q1
\v 25 Ua pipili ae ko'u uhane i ka lepo; E hoola mai oe ia'u, e like me kau olelo.   
\q1
\v 26 Ua hai aku au i ko'u aoao, a ua ae mai oe ia'u; E ao mai hoi oe i kau mau olelopaa.   
\q1
\v 27 E hoike mai oe ia'u i ke ano o kau mau kauoha; A e hookaulana au i kau mau hana kupanaha.   
\q1
\v 28 Uwe no kuu uhane no ke kaumaha; E hoala mai oe ia'u, e like me kau olelo.   
\q1
\v 29 E hookaawale oe i ka aoao o ka wahahee mai o'u aku, A e hoike lokomaikai mai ia'u i kou mau kanawai.   
\q1
\v 30 Ua wae au ma ka aoao o ka oiaio, Ua kau wau i kou hoopono ana imua o'u.   
\q1
\v 31 Ua hoopili aku au me kou mau kanawai; E Iehova, mai hoohilahila mai oe ia'u.   
\q1
\v 32 E holo no wau ma ke ala o kau mau kauoha; No ka mea, e hoomahuahua mai no oe i ko'u manao.   
\b  
\q1
\v 33 E ao mai oe ia'u, e Iehova, i ka aoao o kau mau kauoha, A e malama no wau, a hiki i ka hopena.   
\q1
\v 34 E hoonaauao mai oe ia'u, a e malama no au i kou kanawai; E malama no au ia me ko'u naau a pau.   
\q1
\v 35 E alakai oe ia'u ma ke alanui o kau mau kauoha; No ka mea, malaila no wau e lealea nei.   
\q1
\v 36 E hoohuli oe i ko'u naau mamuli o kou mau kanawai, Aole mamuli o ka makee waiwai.   
\q1
\v 37 E hoohuli oe i ko'u mau maka, mai ka ike ana i ka mea lapuwale; A e hoola mai oe ia'u ma kou aoao.   
\q1
\v 38 E hooko oe i kau olelo, i kau kauwa nei, Ka mea i makau aku ia oe.   
\q1
\v 39 E pale ae oe i ko'u hoinoia, a'u e makau nei; No ka mea, he maikai kou hoopono ana.   
\q1
\v 40 Aia hoi, ua iini au i kau mau kauoha; E hooikaika mai oe ia'u ma kou pono.   
\b  
\q1
\v 41 E hookau mai i kou lokomaikai maluna o'u, e Iehova, I kou hoola ana hoi e like me kau olelo.   
\q1
\v 42 Alaila e pane aku au i kekahi olelo i ka mea hoowahawaha mai ia'u: No ka mea, ke hilinai aku nei au ia oe.   
\q1
\v 43 Mai kaili oe i ka olelo o kou oiaio, mai ko'u waha aku, a i ka manawa pau ole; No ka mea, ke kakali nei au i kou hoopono ana.   
\q1
\v 44 Alaila, e malama mau no wau i kou kanawai, A hiki a kau a mau loa aku.   
\q1
\v 45 E holoholo no wau, maloko o kahi akea, No ka mea, ke imi nei au i kau olelo.   
\q1
\v 46 E kamakamailio no wau ma kou mau kanawai imua o na'lii, Aole hoi au e hilahila.   
\q1
\v 47 E hauoli no wau ma kou mau kanawai, Na mea au i makemake ai.   
\q1
\v 48 E hapai no wau i ko'u mau lima i kau mau kauoha, I na mea a'u i makemake ai: A e noonoo wau ma kau mau kauoha.   
\b  
\q1
\v 49 E hoomanao oe i ka olelo au i kau kauwa, Malaila no oe i hoolana'i i kou manao ia'u.   
\q1
\v 50 Eia ko'u mea e maha'i, iloko o ko'u pilikia; No ka mea, ua hoola kau olelo ia'u.   
\q1
\v 51 Ua hoowahawaha nui loa mai ka poe hookiekie ia'u; Aole nae au i haalele i kou kanawai.   
\q1
\v 52 Hoomanao no wau i kou hoopono ana, e Iehova, mai kahiko loa mai, A ua hoomaha hoi au.   
\q1
\v 53 Lohia au i ka wewela nui, no ka poe hewa, I haalele i kou kanawai.   
\q1
\v 54 Ua lilo kau mau kauoha i mea na'u e hoolea aku ai, Ma ka hale o ko'u malihini ana.   
\q1
\v 55 Hoomanao no wau i kou inoa i ka po, e Iehova, A malama hoi i kou kanawai.   
\q1
\v 56 Loaa o keia ia'u, No ka mea, malama no wau i kau mau kauoha.   
\b  
\q1
\v 57 O ko'u puu no, e Iehova, Ua olelo no wau, e malama aku au i kau mau olelo.   
\q1
\v 58 Ua nonoi aku au imua o kou maka me ko'u naau a pau; E lokomaikai mai oe ia'u, e like me kau olelo.   
\q1
\v 59 Noonoo ae la au i ko'u mau aoao, A hoohuli aku la i ko'u mau wawae i kau hoike ana.   
\q1
\v 60 Wikiwiki aku la au, aole hoi i hookaulua, I ko'u malama ana i kau mau kauoha.   
\q1
\v 61 Ua hoopani mai na kaula o ka poe hewa ia'u; Aole nae au i hoopoina i kou kanawai.   
\q1
\v 62 Iwaena konu o ka po, e ala no wau e mililani aku ia oe, No kou hoopono pololei ana.   
\q1
\v 63 He makamaka au no ka poe a pau i makau aku ia oe, A no ka poe malama i kau mau kauoha.   
\q1
\v 64 Ua piha ka honua, e Iehova, i kou lokomaikai; E ao mai oe i kau mau olelopaa.   
\b  
\q1
\v 65 Ua hana maikai mai oe i kau kauwa, E Iehova, e like me kau olelo.   
\q1
\v 66 E ao mai oe ia'u i ke akamai maikai, a me ka ike; No ka mea, ua hooiaio wau i kau mau kauoha.   
\q1
\v 67 Mamua o ko'u hoopilikiaia, hele hewa au; I keia wa, ke malama nei au i kau olelo.   
\q1
\v 68 He maikai no oe, a ke hana maikai mai nei; E ao mai oe i kau mau olelopaa.   
\q1
\v 69 O ka poe hookiekie, ua epa wahahee mai lakou ia'u; Aka, e malama au i kau mau kauoha me ko'u naau a pau.   
\q1
\v 70 Ua momona ko lakou naau me he kelekele la; Aka, ke hauolioli nei au ma kou kanawai.   
\q1
\v 71 He mea maikai ia'u ko'u hoopilikiaia, I mea e ao ai au i kau mau olelopaa.   
\q1
\v 72 He mea maikai ia'u ke kanawai o ko'u waha, Mamua o na tausani gula, a me ke kala.   
\b  
\q1
\v 73 Na kou mau lima wau i hana'i, a hooponopono mai hoi ia'u; E hoonaauao mai oe ia'u, i ao wau i kau mau kauoha.   
\q1
\v 74 E ike mai no ia'u, ka poe makau aku ia oe, a e lealea mai; No ka mea, ua hoolana au ma kau olelo.   
\q1
\v 75 Ua ike no wau, e Iehova, he pololei no kou hoopono ana, A ma ka oiaio no kou hoopilikia ana mai ia'u.   
\q1
\v 76 Ke noi aku nei au ia oe e hoolilo i kou lokomaikai i mea e maha'i au, Me kau i olelo mai ai i kau kauwa.   
\q1
\v 77 I hiki mai kou aloha ia'u, i ola au; No ka mea, o kou kanawai ka'u e hauolioli nei.   
\q1
\v 78 E hoohilahilaia ka poe hookiekie, no ka mea, ua hana kekee wahahee mai lakou ia'u; Aka, e noonoo no wau i kau mau olelopaa.   
\q1
\v 79 E huli mai mamuli o'u, ka poe e makau aku ia oe, A e ike no lakou i kau hoike ana.   
\q1
\v 80 E hoolilo oe i ko'u naau i pono ma kau mau olelopaa; Alaila, aole au e hilahila.   
\b  
\q1
\v 81 Ua maule ko'u uhane no ka iini i kau hoola ana; Ua hoolana hoi au ma kau olelo.   
\q1
\v 82 Ua poopoo ko'u mau maka no kau olelo, I ae la hoi, I ka wa hea e hoomaha mai ai oe ia'u?   
\q1
\v 83 No ka mea, ua like au me ka hueili ma kahi uwahi; Aole au i hoopoina i kau mau olelopaa.   
\q1
\v 84 Ehia na la o kau kauwa? I ka manawa hea, e hoopai ai oe i ka poe hoomaau mai ia'u?   
\q1
\v 85 Ua eli ka poe hookiekie i mau lua no'u, Aole hoi e like me kou mau kanawai.   
\q1
\v 86 Ma ka oiaio no kau mau kauoha a pau: Hoomaau wahahee mai lakou ia'u; e kokua mai oe ia'u.   
\q1
\v 87 Aneane lakou i hoopau ia'u ma ka honua, Aole nae au i haalele i kau mau olelopaa.   
\q1
\v 88 E hooikaika mai oe ia'u e like me kou lokomaikai; Alaila, e malama no wau i ka hoike ana o kou waha.   
\b  
\q1
\v 89 Ua paa mau loa no kau olelo, E Iehova, ma ka lani.   
\q1
\v 90 Mai kekahi hanauna a i kekahi hanauna kou oiaio: Ua hookumu oe i ka honua, a ua kupaa ia.   
\q1
\v 91 Ua kupaa no a hiki i keia la, ma kou hooponopono; No ka mea, o kau poe kauwa lakou a pau.   
\q1
\v 92 Iua i lealea ole au ma kou kanawai, Ina ua make au iloko o ko'u pilikia.   
\q1
\v 93 Aole loa au e hoopoina i kau mau olelopaa, No ka mea, ma ia mau mea no oe i hooikaika mai ia'u.   
\q1
\v 94 Nou no wau, e hoola mai oe ia'u, No ka mea, ua imi no au i kau mau olelopaa.   
\q1
\v 95 Ua hoohalua mai ka poe hewa ia'u, e pepehi ia'u: Aka, e noonoo no wau i kou mau kanawai.   
\q1
\v 96 Ua ike no au i ka hope o na mea maikai a pau: Aka, ua palahalaha loa kou kanawai.   
\b  
\q1
\v 97 Nani wale ko'u aloha i kou kanawai! Oia ko'u mea e noonoo ai i na la a pau.   
\q1
\v 98 Ma kau mau kauoha, ua hookela aku oe i ko'u akamai mamua o ko ko'u poe enemi; No ka mea, ua mau loa no lakou mo a'u.   
\q1
\v 99 Ua oi aku ko'u akamai, mamua o ko ka'u poe kumu a pau; No ka mea, o kou hoike ana ka'u e noonoo ai.   
\q1
\v 100 Ua kela aku ko'u naauao mamua o ko ka poe kahiko; No ka mea, ke malama nei au i kau mau olelopaa.   
\q1
\v 101 Ua kaohi no au i ko'u mau wawae, mai na ala hewa a pau, I malama aku ai au i kau olelo.   
\q1
\v 102 Aole au i haalele i kou hoopono ana; No ka mea, ua ao mai oe ia'u.   
\q1
\v 103 Nani ka ono o kau mau olelo i ko'u puu! Ua oi aku mamua o ko ka meli i ko'u waha.   
\q1
\v 104 Ma kau mau olelo ao, ua loaa ia'u ka naauao; Nolaila, inaina aku au i na ala wahahee a pau.   
\b  
\q1
\v 105 He kukui no kau olelo no ko'u mau wawae, A he malamalama hoi ia ma ko'u alanui.   
\q1
\v 106 Ua koohiki no wau, a e hooko no wau, E malama no wau i kau hoopono pololei ana.   
\q1
\v 107 Ua pilikia loa no wau; E Iehova, e hooikaika mai oe ia'u, e like me kau olelo.   
\q1
\v 108 E Iehova, ke nonoi aku nei au e lealea mai oe i ka mea a kuu waha e haawi wale nei, A e ao mai hoi oe i kou hoopono ana.   
\q1
\v 109 Ua mau no ko'u uhane iloko o ko'u lima: Aole nae au e hoopoina i kou kanawai.   
\q1
\v 110 Ua kau no ka poe hewa i ka mea hei no'u; Aole nae au i haalele i kau mau kauoha.   
\q1
\v 111 Ua loaa ia'u kou mau kanawai i hooilina mau loa no'u: No ka mea, oia ka mea e lealea ai ko'u naau.   
\q1
\v 112 Ua hoohuli au i ko'u naau e hana i kau mau olelopaa, A i ke ao pau ole.   
\b  
\q1
\v 113 Ua ukiuki au i ka poe manao lua; A ua makemake hoi au i kou kanawai.   
\q1
\v 114 O oe no ko'u paku, a me ko'u palekaua; Ua hoolana wau ma kau olelo.   
\q1
\v 115 E hele aku oukou, e ka poe hewa, mai o'u aku; No ka mea, e malama no wau i kou kanawai. e Iehova,   
\q1
\v 116 E hookupaa mai oe ia'u, e like me kau olelo, alaila ola au; A mai hoohilahila mai ia'u i ko'u manaolana.   
\q1
\v 117 E hooikaika mai oe ia'u, alaila palekana wau, A e haliu wau i kau mau olelopaa, a mau loa.   
\q1
\v 118 Ua hoowahawaha no oe i ka poe a pau i haalele i kou kanawai; No ka mea, he wahahee ko lakou hoopunipuni ana.   
\q1
\v 119 Ke hoolilo nei oe i ka poe hewa a pau o ka honua i opala; No ia mea ke makemake nei au i kou mau kanawai.   
\q1
\v 120 Haalulu ko'u io i ka makau ia oe; Ua hopohopo no hoi au i kou hooponopono ana.   
\b  
\q1
\v 121 Ua hana no wau i ka hoopono, a me ka pololei; Mai hookuu mai oe ia'u i ka poe hookaumaha mai ia'u.   
\q1
\v 122 E haawi mai oe i hoailona ia'u no ka maikai; Mai ao oe i ka hookaumaha ana o ka poe hewa ia'u.   
\q1
\v 123 Ua poopoo ko'u mau maka no ka iini i kou hoola ana mai, A no na olelo o kou pono.   
\q1
\v 124 E hana mai oe i kau kauwa, e like me kou lokomaikai, A e ao mai hoi ia'u i kau mau olelopaa.   
\q1
\v 125 Owau no kau kauwa, e hoonaauao mai oe ia'u, I ike au i kou mau kanawai.   
\q1
\v 126 O ka manawa keia no Iehova e nana mai ai; Ua uhai lakou i kou kanawai.   
\q1
\v 127 No ia mea, ua makemake au i kau mau kauoha, Mamua o ke gula, a me ke gula maikai.   
\q1
\v 128 Nolaila, manao ae la au i na olelopaa a pau, ua pololei lakou a pau; Ua inaina no hoi au i na aoao wahahee a pau.   
\b  
\q1
\v 129 He kupanaha no kau ao ana mai; Nolaila ke malama nei ko'u uhane ia lakou.   
\q1
\v 130 O ka wehewehe ana i kau olelo, oia ka i hoomalamalama mai; Hoonaauao mai no ia i ka poe hupo.   
\q1
\v 131 Hamama ae la ko'u waha, a hanu ae; No ka mea, iini aku au i kau mau kauoha.   
\q1
\v 132 E haliu mai oe ia'u, e lokomaikai mai hoi. E like me kou hoopono ana i ka poe i aloha i kou inoa.   
\q1
\v 133 E kuhikuhi mai oe i ko'u mau wawae mamuli o kau olelo; Mai hoolanakila i kekahi hewa maluna o'u.   
\q1
\v 134 E hoopakele mai oe ia'u i ka hoopilikiaia e na kanaka, Alaila, e malama no wau i kau mau kauoha.   
\q1
\v 135 E hoomalamalama mai kou maka i kau kauwa, A e ao mai oe ia'u i kau olelopaa.   
\q1
\v 136 Kahe no na muliwai malalo iho o ko'u mau maka, No ko lakou malama ole ana i kou kanawai.   
\b  
\q1
\v 137 He pono no oe, e Iehova, A ua pololei hoi kou hoopono ana.   
\q1
\v 138 Ua pono no na kauoha au i hoike mai ai, A ua oiaio loa hoi.   
\q1
\v 139 Na ko'u manao ikaika i hooki loa mai ia'u, No ka mea, ua hoopoina kou poe enemi i kau mau olelo.   
\q1
\v 140 He maemae loa kau olelo, Nolaila ua makemake kau kauwa ia mea.   
\q1
\v 141 He mea liilii au, a ua hoowahawahaia, Aole nae au i hoopoina i kau mau olelo ao.   
\q1
\v 142 O kou pono, he pono mau loa no ia, A he oiaio kou kanawai.   
\q1
\v 143 Ua loaa ia'u ka poino, a me ka popilikia; Aka, o kau mau kauoha ka'u e lealea nei.   
\q1
\v 144 Ua mau loa no ka pono o kau mau kauoha; E hoonaauao mai oe ia'u, alaila, ola au.   
\b  
\q1
\v 145 Kahea aku au me ko'u naau a pau, E hoolohe mai, e Iehova: E malama no wau i kau mau olelopaa.   
\q1
\v 146 Kahea aku au ia oe e hoola mai oe ia'u; Alaila, e malama no wau i kou mau kanawai.   
\q1
\v 147 Manao e no wau mamua o ka wanaao, a hea aku la; Hoolana no hoi au ma kau olelo.   
\q1
\v 148 Manao e no ko'u mau maka mamua o na wati kiai, E noonoo ma kau olelo.   
\q1
\v 149 E hoolohe mai oe i ko'u leo, e like me kou lokomaikai; E Iehova, e hoola mai oe ia'u, e like me ko'u hoopono ana.   
\q1
\v 150 Ke hookokoke mai nei ka poe hahai i ka hewa; Ua loihi lakou, mai kou kanawai aku.   
\q1
\v 151 Ua kokoke mai oe, e Iehova, A ua oiaio hoi kau mau kauoha a pau.   
\q1
\v 152 Mai mua mai ko'u ike ana i kou mau kanawai, Nau no lakou i hookumu paa loa.   
\b  
\q1
\v 153 E nana mai oe i ko'u pilikia, a e hookuu mai ia'u, No ka mea, aole au i hoopoina i kou kanawai.   
\q1
\v 154 E hooponopono mai oe i ko'u hoopiiia, a e hoolapanai mai oe ia'u: E hooikaika mai oe ia'u, e like me kau olelo.   
\q1
\v 155 Ua loihi aku ke ola, mai ka poe hewa aku; No ka mea, aole lakou e imi i kau mau olelopaa.   
\q1
\v 156 Nui loa no kou lokomaikai, e Iehova, E hooikaika mai oe ia'u, e like me ka kau hoopono ana.   
\q1
\v 157 Ua nui no ka poe hoomaau mai ia'u, a me ko'u poe enemi; Aole nae au i haalele i kau hoike ana.   
\q1
\v 158 Nana aku la au i ka poe hana me ka hoopunipuni, a hoopailua iho la; No ka mea, aole lakou i malama i kau mau olelo.   
\q1
\v 159 E nana mai, no ka mea, ua aloha au i kau mau kauoha; E Iehova, e hooikaika mai oe ia'u, e like me kau olelo.   
\q1
\v 160 Ua oiaio no ke poo o kau olelo; A ua mau loa ka hemolele ana o kou hoopono ana.   
\b  
\q1
\v 161 Ua hoomaau hala ole mai na'lii ia'u; Aka, ua weliweli ko'u naau i kau mau olelo.   
\q1
\v 162 Olioli no wau ma kau olelo, E like me ka mea loaa ka waiwai pio a nui.   
\q1
\v 163 Ke inaina nei au, a hoopailua no hoi i ka wahahee; Aka, ke aloha nei au i kou kanawai.   
\q1
\v 164 Ehiku no ko'u halelu ana ia oe i ka la hookahi, No kou hoopono pololei ana.   
\q1
\v 165 Ua nui loa ka maluhia o ka poe i makemake i kou kanawai, Aohe mea e hina'i lakou.   
\q1
\v 166 Ua hoolana au ma kou hoola ana, e Iehova, A ua hana hoi i kau mau kauoha.   
\q1
\v 167 Ua malama no ko'u uhane i kou hoike ana, A ua nui loa ko'u makemake ia mea.   
\q1
\v 168 Ua malama no wau i kau mau kauoha, a me kou mau kanawai; No ka mea, mamua ou no ko'u mau aoao a pau.   
\b  
\q1
\v 169 E hookokoke aku no ko'u kahea ana imua o kou alo, e Iehova; E hoonaauao mai oe ia'u, e like me kau olelo.   
\q1
\v 170 E hiki aku no kau pule imua o kou alo; E hoopakele mai oe ia'u e like me kau olelo.   
\q1
\v 171 E hoike aku no ko'u mau lehelehe i ka halelu, Ke ao mai oe ia'u i kau mau olelopaa.   
\q1
\v 172 E hai aku no ko'u elelo i kau olelo; No ka mea, ua hemolele kau mau kauoha a pau.   
\q1
\v 173 E haawi mai oe i ko'u lima, i mea kokua no'u; No ka mea, ua wae au ma kau mau olelo ao.   
\q1
\v 174 Ua iini aku au i kou hoola ana, e Iehova, O kou kanawai, ka'u e hauoli nei.   
\q1
\v 175 E hoola mai i ko'u uhane, alaila, e halelu aku no au ia oe; A na kou hoopono ana, e kokua mai ia'u.   
\q1
\v 176 Ua hele hewa au, e like me ka hipa nalowale, E kii mai oe i kau kauwa; No ka mea, aole au i hoopoina i kau mau kauoha.   
\c 120  
\b  
\q1
\v 1 I LOKO o ko'u pilikia, kahea aku la au ia Iehova, A hoolohe mai la oia ia'u.   
\q1
\v 2 E Iehova, e hoopakele mai oe i ko'u uhane i na lehelehe wahahee, A me ke elelo hoopunipuni.   
\q1
\v 3 Heaha ka mea e haawiia'ku ai ia oe, A e hoopili hou ia mai ai ia oe, E ke elelo hoopunipuni?   
\q1
\v 4 Na pua oi o ka mea ikaika, A me na lanahu rotema.   
\b  
\q1
\v 5 Auwe hoi au'i ko'u noho malihini ana ma Meseka, I ko'u noho ana hoi ma na halelewa o Kedera!   
\q1
\v 6 Ua noho loihi ko'u uhane, Me ka mea i inaina mai i ka maluhia.   
\q1
\v 7 Ma ka maluhia no wau; a ia'u e olelo aku ai, Ma ke kaua no lakou la.   
\c 121  
\b  
\q1
\v 1 E LEHA aku au i ko'u mau maka i na mauna, Mailaila mai ko'u kokua e hiki mai ai.   
\q1
\v 2 Mai Iehova mai ko'u kokua, Nana no i hana i ka lani, a me ka honua.   
\q1
\v 3 Aole ia e haawi i kou wawae i ke kulanalana; O ka mea malama ia oe, aole ia e maluhiluhi.   
\q1
\v 4 Aia hoi, o ka mea malama i ka Iseraela, Aole ia e maluhiluhi, aole ia e hiamoe.   
\b  
\q1
\v 5 O Iehova no kou kiai; O Iehova no kou malu, ma kou lima akau.   
\q1
\v 6 Aole e hahau mai ka la ia oe i ke ao, Aole hoi o ka mahina i ka po.   
\q1
\v 7 E malama mai no o Iehova ia oe i ka ino a pau; Nana no e malama i kou uhane.   
\q1
\v 8 E kiai no o Iehova i kou puka ana iwaho a me kou komo ana iloko, Mai keia wa a ka manawa pau ole.   
\c 122  
\b  
\q1
\v 1 O LIOLI aku la au, ia lakou i olelo mai ai ia'u, E hele kakou iloko o ka hale o Iehova.   
\q1
\v 2 E ku no ko kakou mau wawae, Maloko o kou mau pukapa, e Ierusalema.   
\q1
\v 3 Ua hoonohonohoia o Ierusalema, E like me ke kulanakauhale i kapiliia.   
\q1
\v 4 Pii aku no na ohana malaila, Na ohana hoi o Iehova, me kana i kauoha ai i ka Iseraela, E hoolea aku i ka inoa o Iehova.   
\q1
\v 5 No ka mea, ua hoonohoia malaila na nohoalii no ka hoopono, Na nohoalii no ka ohana a Davida.   
\b  
\q1
\v 6 E noi aku oukou i maluhia o Ierusalema; E pomaikai auanei ka poe e aloha aku ia oe.   
\q1
\v 7 I noho ka maluhia iloko o kou mau pa, A me ka pomaikai iloko o kou halealii.   
\q1
\v 8 No ko'u poe hoahanau, a no ko'u poe makamaka, E olelo aku no wau, ano la, i maluhia maloko ou.   
\q1
\v 9 No ka hale o Iehova, o ko kakou Akua, E imi aku no wau, i ka pono nou.   
\c 123  
\b  
\q1
\v 1 I A oe no wau e leha aku nei i ko'u mau maka, E ka mea e noho la ma ka lani.   
\q1
\v 2 Aia hoi, e like me na maka o na kauwakane, I ka lima o ko lakou haku, E like hoi me na maka o ke kauwawahine, I ka lima o kona haku wahine; Pela no ko kakou maka ia Iehova i ko kakou Akua, A aloha mai oia ia makou.   
\b  
\q1
\v 3 E aloha mai oe ia makou, o Iehova, E aloha mai oe ia makou; No ka mea, ua ana loa makou i ka hoowahawahaia.   
\q1
\v 4 Ua ana loa ko makou uhane i ka hoomaewaewa ana o ka poe hookano, A me ka hoowahawaha ana o ka poe hookiekie.   
\c 124  
\b  
\q1
\v 1 I NA aole i noho pu o Iehova me kakou, Wahi a ka Iseraela,   
\q1
\v 2 Ina aole i noho pu o Iehova me kakou, I ka wa i ala ku e mai ai na kanaka ia kakou,   
\q1
\v 3 Ina ua moni koke mai lakou ia kakou, I ka wela ana o ko lakou huhu ia kakou.   
\q1
\v 4 Ina ua poipu hoi na wai maluna o kakou, A ua hiki mai ka waikahe maluna o ko kakou uhane:   
\q1
\v 5 Ina ua kahe no hoi ka waiholomoku maluna o ko kakou uhane.   
\b  
\q1
\v 6 E hoomaikaiia o Iehova, Ka mea haawi ole ia kakou i waiwai pio i ko lakou niho.   
\q1
\v 7 Ua hoopakeleia no ko kakou uhane, Me he manu la, mai ka hei ana aku i ka poe lawaiamanu; Ua moku ka upena a ua hoopakeleia kakou.   
\q1
\v 8 Aia no ko kakou kokua, maloko o ka inoa o Iehova, Ka mea nana i hana ka lani me ka honua.   
\c 125  
\b  
\q1
\v 1 O KA poe hilinai aku ia Iehova, E like no lakou me ka mauna o Ziona, Aole ia e naue, e noho mau loa no.   
\q1
\v 2 Ua puni o Ierusalema i na mauna, Pela o Iehova e hoopuni ai i kona poe kanaka, Mai keia wa aku, a i ka manawa pau ole.   
\q1
\v 3 Aole e waihoia ke kookoo o ka poe hewa, Ma ka puu o ka poe pono; O kau aku ka poe pono i ko lakou lima ma ka hewa.   
\b  
\q1
\v 4 E hana maikai mai oe, e Iehova, i ka poe maikai, A i ka poe hoi i pololei ma ko lakou naau.   
\q1
\v 5 O ka poe kapae ma ko lakou ala keekee, E alakai pu aku no o Iehova ia lakou me ka poe hana lapuwale; A he malu no maluna o ka Iseraela.   
\c 126  
\b  
\q1
\v 1 I A Iehova i hoihoi mai ai i ka pio ana o Ziona, Like no kakou me ka poe moe uhane.   
\q1
\v 2 Alaila, piha no ko kakou waha i ka akaaka, A me ko kakou alelo i ka hauoli; Alaila, olelo no lakou iwaena o ko na aina e, Nani na mea a Iehova i hana mai ai no lakou la.   
\q1
\v 3 Ua nani no na mea a Iehova i hana mai ai no kakou; A ua lealea kakou malaila.   
\b  
\q1
\v 4 E Iehova, e hoihoi oe i ko makou pio ana, E like me na kahawai, ma ke kukuluhema.   
\q1
\v 5 O ka poe lulu me na waimaka, E hoiliili lakou me ka hauoli.   
\q1
\v 6 He oiaio, o ka mea hele, a uwe, I kona lawe ana i ka hua e lulu ai, He oiaio no, e hoi mai oia me ka hauoli, E amo pu ana i kona mau pua.   
\c 127  
\b  
\q1
\v 1 I NA aole o Iehova e kukulu i ka hale, Hooikaika make hewa ka poe nana e kukulu: Ina aole o Iehova e malama i ke kulanakauhale, Make hewa ka makaala ana o ka poe malama.   
\q1
\v 2 He mea wale ia oukou ke ala i kakahiaka nui Mahope o ka hoomaha ana, E ai i ka ai o ka hookaumahaia; No ka mea, pela oia e hoomoe ai i kona poe aloha.   
\b  
\q1
\v 3 Aia hoi! o na keiki, he hooilina lakou no Iehova mai; A o ka hua o ka opu, he uku no ia.   
\q1
\v 4 E like me na pua ma ka lima o ke kanaka ikaika, Pela no na keiki a ka poe opiopio.   
\q1
\v 5 Pomaikai ke kanaka ke piha kana aapua ia lakou; Aole lakou e hilahila, No ka mea, e olelo no lakou i na enemi ma ka puka pa.   
\c 128  
\b  
\q1
\v 1 POMAIKAI ka poe a pau i makau aku ia Iehova, A hele hoi ma kona mau alanui.   
\q1
\v 2 E ai no oe i ka waiwai o kou mau lima, He pomaikai no kou, a he pono no hoi.   
\q1
\v 3 E like no kau wahine me na kumuwaina hua nui, Ma na aoao o kou hale; E like no hoi kau mau keiki me na laau oliva, E ku puni ana i kou papaaina.   
\q1
\v 4 Aia hoi! pela e hoopomaikaiia mai ai ke kanaka, Nana e makau aku ia Iehova.   
\b  
\q1
\v 5 E hoomaikai mai o Iehova ia oe mai Ziona mai; A e ike no oe i ka pono o Ierusalema, I na la a pau o kou ola ana.   
\q1
\v 6 E ike no hoi oe i na keiki o kau poe keiki, A me ka maluhia maluna o ka Iseraela.   
\c 129  
\b  
\q1
\v 1 U A hoopilikia pinepine mai lakou ia'u, Mai ko'u wa opiopio mai, wahi a ka Iseraela;   
\q1
\v 2 Ua hoopilikia pinepine mai lakou ia'u, mai ko'u wa opiopio mai; Aole nae lakou i lanakila mai maluna o'u.   
\q1
\v 3 Ma ko'u kua i kahakaha ai ka poe kahakaha; A hana lakou i ko lakou kaha a loihi.   
\q1
\v 4 Ua pono no o Iehova; Ua oki mai oia i na kaula o ka poe hewa.   
\b  
\q1
\v 5 E hoohilahilaia a e hoihoi hope ia mai, Ka poe a pau e inaina mai ia Ziona.   
\q1
\v 6 E like auanei lakou, me ka mauu maluna o na hale, Mae wale, ia mamua o ka liko ana.   
\q1
\v 7 Aole e piha ka lima o ka mea i oki iho, Aole hoi ka umauma o ka mea hoopua i na pua.   
\q1
\v 8 Aole hoi e olelo mai ka poe e hele ae, Maluna o oukou auanei ka hoomaikai ana o Iehova: Ke hoomaikai aku nei makou ia oukou ma ka inoa o Iehova.   
\c 130  
\b  
\q1
\v 1 MAILOKO o na wahi hohonu, ua kahea aku au i oe, e Iehova.   
\q1
\v 2 E ka Haku e, e hoolohe mai oe i ko'u leo; E haliu mai kou pepeiao i ka leo o ko'u nonoi ana.   
\q1
\v 3 Ina ma ka hala oe e haka pono mai ai, e Iehova, E ka Haku, owai la ka mea e ku.   
\q1
\v 4 Aka, ma ou la ke kala ana o ka hala, I makauia'ku ai oe.   
\b  
\q1
\v 5 Ke kakali nei au, ke kakali nei ko'u uhane ia Iehova, A ke hoolana nei au ma kana olelo.   
\q1
\v 6 Ua oi aku ke kakali ana o ko'u uhane i ka Haku, Mamua o ko ka poe kiai kakali ana i ke ao.   
\q1
\v 7 E kakali o ka Iseraela ia Iehova, no ka mea, Me Iehova no ka lokomaikai, a me ia no hoi ka hoolapanai nui wale.   
\q1
\v 8 Nana no e hoolapanai i ka Iseraela, Mailoko aku o ko lakou hewa a pau.   
\c 131  
\b  
\q1
\v 1 E IEHOVA, aole i hookiekie ko'u naau, Aole hookano ko'u mau maka; Aole au i hele mamuli o ua mea nunui, A me na mea hakalia ia'u.   
\q1
\v 2 A i ole ia, ua hoona wau ia'u iho, a ua hoomalielie au i ko'u uhane, E like me ke keiki i ukuhiia e kona makuwahine; Ua like no ko'u uhane me ke keiki i ukuhiia.   
\q1
\v 3 E hoolana o ka Iseraela ma Iehova, Mai keia wa aku. a i ke ao pau ole.   
\c 132  
\b  
\q1
\v 1 E IEHOVA, e hoomanao mai oe ia Davida, A me na pilikia ona a pau:   
\q1
\v 2 I ka mea ana i hoohiki ai ia Iehova, Hoohiki no oia i ka Mea ikaika o Iakoba;   
\q1
\v 3 Aole loa au e komo iloko o ka hale lewa o ko'u hale, Aole hoi au i ea maluna o ko'u wahi moe;   
\q1
\v 4 Aole au e haawi i ka hiamoe ma ko'u mau maka, Aole hoi i ka maluhiluhi na ko'u mau lihilihi,   
\q1
\v 5 A loaa ia'u, he wahi no Iehova, A me kahi e noho ai no ka Mea mana o Iakoha.   
\b  
\q1
\v 6 Aia hoi, ua lohe no kakou ia ma Eperata; Ua loaa ia kakou ia ma Papuululaau.   
\q1
\v 7 E komo no kakou iloko o kona mau wahi e noho ai; A e moe hoomana kakou ma kona keehana wawae.   
\q1
\v 8 E ku mai oe, e Iehova, iloko o kou wahi e maha'i; O oe, a me ka pahu o kou nani.   
\q1
\v 9 A kahikoia kou poe kahuna i ka pono, A e hauoli hoi kau poe haipule.   
\b  
\q1
\v 10 No Davida, no kau kauwa, Mai hoohuli aku i ka maka o kou mea i poniia.   
\q1
\v 11 Hoohiki mai la o Iehova ia Davida ma ka oiaio, Aole loa oia i huli, mai ia mea aku, O ka hua a kou kino ka'u e hoonoho ai maluna o kou nohoalii.   
\q1
\v 12 Ina e malama kau poe keiki i ko'u berita, A me na kanawai a'u e ao aku ai ia lakou, Alaila, o ka lakou keiki o na manawa a pau, E noho no lakou ma kou noho alii.   
\b  
\q1
\v 13 No ka mea, ua wae mai o Iehova ia Ziona, A ua makemake oia ia, i wahi noho ai nona,   
\q1
\v 14 Eia ko'u wahi e hoomaha'i, a hiki i ka manawa pau ole; Maanei no wau e noho ai, no ka mea, Ua makemake no au ia.   
\q1
\v 15 Oiaio no e hoomaikai no wau i kana ai; E hoomaona aku au i kona poe nele i ka berena.   
\q1
\v 16 E kahiko no wau i kona poe kahuna i ka hoola, A e hauoli loa hoi kona poe haipule.   
\q1
\v 17 Malaila no wau e hookupu ai i ka pepeiaohao o Davida; Ua hoomakaukau no wau i lamaku no ko'u mea i poniia.   
\q1
\v 18 E hooaahu au i kona poe enemi i ka hilahila; Maluna ona e pua ai kona leialii.   
\c 133  
\b  
\q1
\v 1 A IA hoi, nani ka maikai a me ka oluolu, O ka noho lokahi pu ana o na hoahanau!   
\q1
\v 2 Ua like ia me ka poni maikai ma ke poo, Ka mea i kahe ilalo ma ka umiumi, Ma ka umiumi hoi o Aarona, A hiki hoi ilalo i na kihi o kona mau aahu.   
\q1
\v 3 Ua like ia me ka hau o Heremona, Ka mea i haule mai maluna o na mauna o Ziona; No ka mea, malaila no i kauoha mai ai o Iehova i ka hoomaikaiia, I ke ola hoi, a hiki i ka manawa pau ole.   
\c 134  
\b  
\q1
\v 1 A IA hoi! e hoomaikai ia Iehova, e na kauwa a pau a Iehova, Na mea e ku ana iloko o ka hale o Iehova i ka po.   
\q1
\v 2 E hapai oukou i ko oukou mau lima ma kahi hemolele, A e hoomaikai aku ia Iehova.   
\q1
\v 3 E hoopomaikai mai o Iehova ia oe mai Ziona mai, Nana i hana ka lani a me ka honua.   
\c 135  
\b  
\q1
\v 1 E HALELU aku ia Iehova, e halelu aku i ka inoa o Iehova; E halelu aku hoi oukou, e na kauwa a Iehova.   
\q1
\v 2 Ka poe e ku ana ma ka hale o Iehova, Ma na kahua hoi o ka hale o ko kakou Akua,   
\q1
\v 3 E halelu aku ia Iehova, no ka mea, ua maikai o Iehova; E hoolea aku i kona inoa, no ka mea, he mea lealea ia.   
\q1
\v 4 No ka mea, ua wae mai o Iehova i ka Iakoba nona, A i ka Iseraela hoi i waiwai nona.   
\b  
\q1
\v 5 No ka mea, ua ike au, he nui o Iehova, A o ko kakou Haku hoi maluna o na akua a pau;   
\q1
\v 6 O na mea a pau a Iehova i makemake ai, Ua hana oia ma ka lani, a ma ka honua, A ma na moana, a ma na wahi hohonu a pau.   
\q1
\v 7 Nana no e hoopii ka ohu mai na kihi aku o ka honua; Nana no e hana na uwila no ka ua, A hoopuka mai la oia i ka makani mailoko mai o kona waihona.   
\b  
\q1
\v 8 Nana no i pepehi ka makahiapo o ko Aigupita, Ka ke kanaka, a me ka ka holoholona hoi.   
\q1
\v 9 Hoouna mai la oia i na hoailona a me na hana mana, Iwaena konu ou, e Aigupita; Imua o Parao, a imua o kana poe kauwa a pau.   
\q1
\v 10 Pepehi no oia i ko na aina, he nui loa, A luku mai i na'lii he koa loa;   
\q1
\v 11 Ia Sihona ke alii o ko Amora, ia Oga hoi ke alii o Basana, A me ko na aupuni a pau o Kanaana.   
\q1
\v 12 A haawi mai la oia i ko lakou aina i hooilina, I hooilina hoi no ka Iseraela no kona poe kanaka.   
\q1
\v 13 E Iehova, e mau loa ana no kou inoa; E Iehova, e hoomanaoia no oe i na hanauna a pau.   
\q1
\v 14 No ka mea, e hoapono mai o Iehova i kona poe kanaka, E minamina mai no oia i kana poe kauwa.   
\q1
\v 15 O na akua o ko na aina e, he kala, a he gula, O ka hana o ko kanaka lima.   
\q1
\v 16 He waha no ko lakou, aole nae e olelo mai; He mau maka no ko lakou, aole nae e ike mai;   
\q1
\v 17 He mau pepeiao no hoi ko lakou, aole nae e lohe mai; Aohe hoi ea maloko o ko lakou waha.   
\q1
\v 18 O ka poe i hana mai ia lakou, ua like kela poe me lakou: A me na mea a pau e hilinai ai ia lakou.   
\b  
\q1
\v 19 E ka ohana a ka Iseraela, e hoomaikai aku oukou ia Iehova; E ka ohana a Aarona, e hoomaikai aku oukou ia Iehova;   
\q1
\v 20 E ka ohana a Levi, e hoomaikai aku oukou ia Iehova; E ka poe i makau ia Iehova, e hoomaikai aku oukou ia Iehova.   
\q1
\v 21 Mai Ziona mai e hoomaikaiia'i o Iehova, Ka mea e noho la ma Ierusalema. E halelu aku oukou ia Iehova.   
\c 136  
\b  
\q1
\v 1 E MILILANI aku ia Iehova, no ka mea, ua maikai oia; No ka mea hoi, ua mau loa kona lokomaikai.   
\q1
\v 2 E mililani aku i ke Akua o na akua; No ka mea, ua mau loa kona lokomaikai.   
\q1
\v 3 E mililani aku i ka Haku o na haku; No ka mea, ua mau loa kona lokomaikai.   
\q1
\v 4 I ka mea nana wale no i hana na hana mana nui; No ka mea, ua mau loa kona lokomaikai:   
\q1
\v 5 I ka mea nana i hana ka lani ma ke akamai; No ka mea, ua mau loa kona lokomaikai.   
\q1
\v 6 I ka mea nana i kukulu ka honua maluna o ka wai, No ka mea, ua mau loa no kona lokomaikai;   
\q1
\v 7 I ka mea nana i hana na malamalama nui; No ka mea, ua mau loa no kona lokomaikai;   
\q1
\v 8 I ka la e alii ai maluna o ke ao, No ka mea, ua mau loa kona lokomaikai:   
\q1
\v 9 I ka mahina hoi, a me na hoku e alii ai maluna o ka po, No ka mea, ua mau loa kona lokomaikai;   
\b  
\q1
\v 10 I ka mea nana i luku ko Aigupita, ma ko lakou makahiapo, No ka mea, ua mau loa kona lokomaikai:   
\q1
\v 11 A hoopuka mai la i ka Iseraela, maiwaena mai o lakou, No ka mea, ua mau loa kona lokomaikai:   
\q1
\v 12 Me ka lima ikaika, a me ka lima kakauha no noi, No ka mea, ua mau loa kona lokomaikai:   
\q1
\v 13 I ka mea i mahele i ke Kaiula i mau puu, No ka mea, ua mau loa kona lokomaikai;   
\q1
\v 14 A hoohele ae i ka Iseraela mawaena konu ona, No ka mea, ua mau loa kona lokomaikai;   
\q1
\v 15 A luku aku la ia Parao, a me kona kaua iloko o ke Kaiula, No ka mea, ua mau loa kona lokomaikai:   
\q1
\v 16 I ka mea alakai i kona poe kanaka ma ka waonahele, No ka mea, ua mau loa kona lokomaikai.   
\q1
\v 17 I ka mea pepehi i na'lii nui loa, No ka mea, ua mau loa kona lokomaikai;   
\q1
\v 18 A luku hoi i na'lii ikaika, No ka mea, ua mau loa kona lokomaikai:   
\q1
\v 19 Ia Sihona, ke alii o ka Amora, No ka mea, ua mau loa kona lokomaikai;   
\q1
\v 20 Ia Oga hoi, ke alii o Basana, No ka mea, ua mau loa kona lokomaikai:   
\q1
\v 21 A haawi mai la oia i ko lakou aina, i hooilina, No ka mea, ua mau loa kona lokomaikai:   
\q1
\v 22 I hooilina na ka Iseraela, na kana poe kauwa, No ka mea, ua mau loa kona lokomaikai;   
\b  
\q1
\v 23 I ka mea hoomanao ia kakou, ia kakou i hoohaahaaia'i, No ka mea, ua mau loa kona lokomaikai:   
\q1
\v 24 I ka mea i hoopakele ia kakou mai ko kakou poe enemi mai, No ka mea, ua mau loa kona lokomaikai:   
\q1
\v 25 I ka mea haawi mai i ka ai na na mea ola a pau, No ka mea, ua mau loa kona lokomaikai;   
\q1
\v 26 E mililani aku i ke Akua o ka lani, No ka mea, ua mau loa kona lokomaikai.   
\c 137  
\b  
\q1
\v 1 MA na muliwai o Babulona, malaila kakou i noho iho ai, A uwe aku la i ko kakou hoomanao ana ia Ziona.   
\q1
\v 2 Ma na wilou maloko olaila, I kaulai ai makou i ko makou mea kani.   
\q1
\v 3 No ka mea, malaila, noi mai ka poe i lawe pio ia makou, I na olelo o ke oli; A o ka poe hoinoino ia makou, noi mai lakou e lealea makou, I mai, E oli mai oukou i ka oli o Ziona.   
\b  
\q1
\v 4 Pehea la makou e oli ai i ka oli o Iehova, Ma ka aina malihini?   
\q1
\v 5 Ina e hoopoina au ia oe, e Ierusalema, E poina pu no ko'u lima akua i ka hana,   
\q1
\v 6 I ole au e hoomanao ia oe, E pipili hoi kuu aleio i ka aluna o ko'u waha; I ole hoi e kela aku ko'u makemake ia Ierusalema, Mamua o ko'u mea lealea mai.   
\q1
\v 7 E Iehova, e hoomanao oe i na keiki o Edoma, I ka la o Ierusalema; I ka poe i olelo mai, E wawahi, e wawahi, A ilalo i ke kumu ona.   
\q1
\v 8 E ke kaikamahine o Babulona, ka mea e anaiia auanei, E pomaikai auanei ka mea hoopai aku ia oe, i ka hewa, Au i hana hewa mai ai ia makou.   
\q1
\v 9 E pomaikai no hoi ka mea lalau aku i kau mau keiki, A ulupa ia lakou ilalo i na pohaku.   
\c 138  
\b  
\q1
\v 1 E MILILANI aku au ia oe me kuu naau a pau, Imua o na'kua e hoolea aku ai au ia oe.   
\q1
\v 2 E kulou hoomana au ma kou luakini hoano, A e mililani aku i kou inoa, No kou lokomaikai a me ka oiaio; No ka mea, ua hookaulana oe i kau olelo mamua o kou inoa a pau.   
\q1
\v 3 I ka la a'u i kahea aku ai ia oe, Alaila, hoolohe mai no oe ia'u, Ua hooikaika mai oe ia'u, me ka ikaika ma kuu uhane.   
\b  
\q1
\v 4 E mililani aku na'lii a pau o ka honua ia oe, e Iehova, Ia lakou e lohe ai i na huaolelo a kou waha.   
\q1
\v 5 E oli no lakou i na aoao o Iehova, No ka mea, nui no ka nani o Iehova.   
\q1
\v 6 Ua kiekie loa o Iehova, ua nana mai nei i ka poe haahaa; Aka, ua ike no oia i ka poe hookiekie ma kahi loihi.   
\b  
\q1
\v 7 Ina paha e hele wau iloko o ka pilikia, Nau no wau e hoola mai. Maluna o ka huhu o kou poe enemi, e o mai ai oe i kou lima, A me kou lima akau oe e hoopakele mai ai ia'u.   
\q1
\v 8 E hoopaa no o Iehova i na mea e pili mai ai ia'u; Ua mau loa no kou lokomaikai, e Iehova, Mai haalele oe i na hana a kou mau lima.   
\c 139  
\b  
\q1
\v 1 E IEHOVA, ua haka pono mai oe ia'u, a ua ike hoi.   
\q1
\v 2 Ua ike no oe i ko'u noho ana ilalo, a me ko'u ala ana iluna, Ua maopopo hoi ko'u manao ia oe ma kahi loihi e aku.   
\q1
\v 3 Ua hoao mai oe i ko'u ala ana, a me ko'u moe ana, A ua ikea no ko'u mau aoao a pau ia oe.   
\q1
\v 4 No ka mea, aohe olelo ma ko'u alelo, Aia hoi, e Iehova, ua ike no oe ia mau mea a pau.   
\q1
\v 5 Ua hooke mai oe ia'u, ma hope, a mamua, A ua kau mai i kou lima maluna o'u.   
\q1
\v 6 Ua oi aku ke kupanaha o ia ike ana mamua o ko'u, Ua kiekie loa, aole au e hiki aku ilaila.   
\b  
\q1
\v 7 Mahea la wau e hele ai, mai ko'u uhane aku? Mahea la wau e pee aku ai, mai kou alo aku?   
\q1
\v 8 Ina pii aku au i ka lani malaila no oe, Inaehalii au i kahi moe ma ka malu o ka make, aia no oe;   
\q1
\v 9 Ina lawe au i na eheu o ke kakahiaka, A noho hoi ma na kihi o ka moana;   
\q1
\v 10 Malaila no kou lima e alakai ai ia'u, A na kou lima akua hoi e hoopaa ia'u.   
\q1
\v 11 A ina olelo au, Oiaio, e haule mai ka pouli maluna o'u, Alaila, e lilo no ka po i malamalama a puni au.   
\q1
\v 12 Aole hoi e hoonalo ka pouli i kekahi mea ia oe, Hoomalamalama mai ka po me he ao la: Ua like no ka pouli, ua like hoi ka malamalama.   
\b  
\q1
\v 13 No ka mea, nau no i hooponopono i ko'u naau; A nau hoi i malama mai ia'u, ma ka opu o ko'u makuwahine.   
\q1
\v 14 E mililani aku au ia oe, No ka mea, o kau hana kupanaha no wau a me ka makau; He kupanaha hoi kau mau hana, Ua ike pono no ko'u uhane.   
\q1
\v 15 Aole i nalo ko'u kino ia oe, Ia'u i hanaia'i ma kahi malu, A kapili akamai ia malalo i ka honua.   
\q1
\v 16 Ike mai no kou mau maka i ko'u opuu ana; A pau no hoi i ke kakauia iloko o kau buke, Na mea o'u i hooponoponoia'i mahope, Ia manawa, aole kekahi o ia mau mea.   
\b  
\q1
\v 17 A ia'u hoi, nani ka waiwai o kou mau manao, e ke Akua! Nani hoi ka lehulehu o ko lakou mau haina!   
\q1
\v 18 Ina e helu wau, ua oi aku ko lakou kinikini mamua o ke one: Ia'u e ala'i, ua mau loa no au me oe.   
\b  
\q1
\v 19 E pepehi io mai no oe i ka poe hewa, e ke Akua; E na kanaka koko, e hele aku oukou, mai o'u aku nei.   
\q1
\v 20 Ka poe olelo hewa aku ia oe, Ua hookieide kou poe enemi ma ka lapuwale.   
\q1
\v 21 E Iehova, aole anei au i inaina aku i ka poe inaina ia oe? A hoopailua hoi i ka poe ala ku e ia oe?   
\q1
\v 22 Ua inaina aku au ia lakou, me ka inaina hemolele; He poe enemi lakou no'u.   
\b  
\q1
\v 23 E huli mai oe ia'u, e ke Akua, a e ike i ko'u naau; E hoao mai oe ia'u, a e ike i ko'u manao.   
\q1
\v 24 E nana mai hoi ina paha he aoao hewa iloko o'u, A e alakai ia'u ma ka aoao ola loa.   
\c 140  
\b  
\q1
\v 1 E HOOPAKELE mai oe ia'u, e Iehova, i ke kanaka hewa; E malama mai hoi ia'u no ke kanaka kolohe:   
\q1
\v 2 Ka poe i imi hewa ma ka naau; Akoakoa no lakou i na la a pau, e kaua.   
\q1
\v 3 Hookala no lakou i ko lakou alelo me he nahesa la; A aia malalo o ko lakou mau lehelehe ka mea make o ka moonihoawa. Sila.   
\b  
\q1
\v 4 E malama mai oe ia'u, e Iehova, i na lima o ka poe hewa. E kiai mai ia'u no ke kanaka kolohe; No ka mea, manao mai oia e hoohiolo i kuu mau kapuwai.   
\q1
\v 5 Na ka poe hookiekie i hana i ka mea hei a me na kaula no'u; A ua uhola lakou i ka upena ma kapa alanui; Ua kau lakou i pahele no'u. Sila.   
\b  
\q1
\v 6 Olelo aku la au ia Iehova, O oe no ko'u Akua; E hoolohe mai oe, e Iehova, i ka leo o ko'u nonoi ana.   
\q1
\v 7 E Iehova, ka Haku ikaika o ko'u ola, Ua uhi mai no oe i ko'u poo i ka la o ke kaua.   
\q1
\v 8 Mai haawi mai oe, e Iehova, i na mea a ka poe hewa i makemake ai; Mai kokua mai oe mamuli o kona manao; Ua hookiekie no lakou. Sila.   
\b  
\q1
\v 9 O ke poo o ka poe hoopani mai ia'u, E uhiia lakou i ka luhi o ko lakou mau lehelehe.   
\q1
\v 10 E haule mai na lanahu maluna o lakou; E kiolaia lakou iloko o ke ahi, Iloko hoi o na lua hohonu, I olo ai lakou e ku hou mai iluna.   
\q1
\v 11 Aole e onipaa ma ka honua ke kanaka olelo wahahee; A e hahai koke no ka hewa i ke kanaka kolohe.   
\b  
\q1
\v 12 Ua ike no wau, e kokua mau no o Iehova i ka poe pilikia, A e hoapono hoi i ka poe ilihune.   
\q1
\v 13 Oiaio e mililani aku no ka poe pono i kou inoa; E noho no hoi ka poe hoopololei ma kou alo.   
\c 141  
\b  
\q1
\v 1 E IEHOVA, ke kahea aku nei au ia oe, E wikiwiki mai oe ia'u, E hooloho hoi i ka leo o ko'u kahea ana aku ia oe.   
\q1
\v 2 E hooliloia ka'u pule i mohai ala imua ou; A o ka hapai ana hoi o ko'u mau lima i mohai ahiahi.   
\q1
\v 3 E hoonoho mai oe, e Iehova, i mea kiai ma kuu waha, A e malama mai hoi oe i ke pani o ko'u mau lehelehe.   
\q1
\v 4 Mai hoohuli ae oe i ko'u naau i kekahi mea hewa, E hana i ka hana o ka poe lawelawe, Me ka poe hana kolohe; Aole hoi au e ai i ko lakou mea ono.   
\b  
\q1
\v 5 Na ka poe pono e hahau mai ia'u, he aloha ia: E ao mai oia ia'u he mea hamo maikai ia, A olo ia e wahi ai i kuu poo; No ka mea, e mau ana no ka'u pule no lakou, iloko o ko lakou pilikia.   
\q1
\v 6 Ua haule ko lakou lunakanawai ma na wahi pohaku, Ua lohe mai nae lakou i ka'u pule, no ka mea, he oluolu ia.   
\q1
\v 7 E like me ka mea kohi a hoauauwaha i ka honua, Pela i hooheleleiia'i ko makou iwi ma ke kae o ka lua kupapau.   
\b  
\q1
\v 8 Aia no ia oe ko'u mau maka, o Iehova ka Haku, Ia oe no wau e hilinai aku ai; Mai waiho pu mai oe i ko'u uhane me ko ka poe nele.   
\q1
\v 9 E malama mai oe ia'u i ka hei a lakou i kaukau ai no'u, A me ka upena o ka poe hana hewa.   
\q1
\v 10 E haule ka poe hewa iloko o ko lakou hei iho, A e pakele wale aku no wau.   
\c 142  
\b  
\q1
\v 1 KAHEA aku la au ia Iehova, i ko'u leo, Me ko'u leo hoi i nonoi aku ai au ia Iehova.   
\q1
\v 2 Ninini aku la au i ko'u kaniuhu imua ona, A hoike aku la no hoi i ko'u pilikia ma kona alo.   
\q1
\v 3 I ka maule ana o ko'u uhane iloko o'u, Alaila ike pono no oe i ko'u alanui. Ma ke ala a'u i hele aku ai, hana lakou i hei no'u.   
\q1
\v 4 Nana aku la au ma ka lima akau, a ike hoi, Aohe mea i ike mai ia'u; Ua pau na wahi e pakele ai; Aohe mea i manao mai i ko'u uhane.   
\b  
\q1
\v 5 Kahea aku la au ia oe, e Iehova, I aku la, O oe no ko'u paku, O kuu puu waiwai hoi ma ka aina o ka poe ola.   
\q1
\v 6 E hoolohe mai oe i ko'u uwe ana, no ka mea, ua hoopilikia loa ia au: E hoopakele mai oe ia'u i ka poe hoomaau mai, No ka mea, na oi aku ko lakou ikaika i ko'u.   
\q1
\v 7 E hoopuka aku oe i ko'u uhane iwaho o ka hale paahao, I hoomililani aku au i kou inoa; E kaapuni mai ka poe pono ia'u, No ka mea, e hana maikai mai oe ia'u.   
\c 143  
\b  
\q1
\v 1 E HOOLOHE mai oe i ka'u pule, o Iehova, E haliu mai hoi i ko'u nonoi ana; A ma koa oiaio, a ma kou pono, e ae mai ia'u.   
\q1
\v 2 Mai hookolokolo mai oe i kau kauwa, No ka mea, aole o aponoia kekahi mea ola imua ou.   
\q1
\v 3 Ua hoomaau mai ka enemi i ko'u uhane; Ua ulupa oia i ko'u ola ilalo i ka honua; Ua hoonoho mai oia ia'u ma ka pouli, E like me ka poe i loihi ka make ana.   
\q1
\v 4 Ua maule no ko'u ea iloko o'u; Ua neoneo hoi ko'u naau maloko ia'u.   
\b  
\q1
\v 5 Ua hoomanao no wau i na la o ka wa kahiko; Ua noonoo no wau ma kau mau hana a pau; Ma ka hana o kou lima ua noonoo nui wau.   
\q1
\v 6 Hohola aku au i ko'u mau lima ia oe; Me he aina maloo la, ko'u uhane, i ka iini ia oe. Sila.   
\b  
\q1
\v 7 E hoolohe koke mai oe ia'u e Iehova, Ua maule ko'u uhane; Mai huna oe i kou maka ia'u, O like auanei au me ka poe iho ilalo i ka lua.   
\q1
\v 8 E haawi mai oe ia'u i ka hoolohe i kou lokomaikai i ke kakahiaka, No ka mea, ke hilinai aku nei au ia oe: E hoike mai oe ia'u i ke ala au e hele ai, No ka mea, ke hapai aku nei au i ko'u uhane ia oe.   
\q1
\v 9 E hoopakele mai oe ia'u i ko'u poe enemi, e Iehova; Ia oe no wau e holo ai, e huna mai oe ia'u.   
\b  
\q1
\v 10 E ao mai oe ia'u e hana i kou makemake, No ka mea, o oe no ko'u Akua, ua maikai no kou uhane; E alakai oe ia'u a iloko o ka aina pololei.   
\q1
\v 11 E hooikaika mai oe ia'u, e Iehova, no kou inoa; No kou pono hoi e hoopuka aku oe i ko'u uhane mawaho o ka pilikia.   
\q1
\v 12 Ma kou lokomaikai, e hooki ae oe i ko'u poe enemi, A e anai mai hoi i ka poe a pau i hoomaau mai ia'u; No ka mea, owau no kau kauwa.   
\c 144  
\b  
\q1
\v 1 E HOOMAIKAIIA o Iehova, ko'u pohaku, Ka mea i ao mai i ko'u mau lima e hoouka, A me ko'u mau manamana lima e kana.   
\q1
\v 2 O ko'u mea aloha, a me ko'u puukaua; O ko'u puuhonua, a me ko'u mea e pakele ai; O ko'u palekaua, ka mea a'u e hiliuai ai; Ka mea i hoopio mai i ko'u poe kanaka malalo iho o'u.   
\q1
\v 3 E Iehova, heaha ke kanaka, i ike mai ai oe ia ia? A me ke keiki a ke kanaka i manao ai oe la ia?   
\q1
\v 4 Ua like ke kanaka me ka mahu; A o kona mau la hoi me he aka la i hele aku.   
\b  
\q1
\v 5 E Iehova, e hookulou mai oe i na lani a iho mai ilalo; E hoopa i na kuahiwi, a e pii aku ka uwahi.   
\q1
\v 6 E hooanapu mai i ka uwila, a e hoopuehu ia lakou: E pana aku i kou mau pua, a e luku ia lakou.   
\q1
\v 7 E kikoo mai oe i kou lima mai luna mai; A e unuhi mai ia'u a e hoopakele hoi ia'u maloko aku o na wai nui, Mai ka lima aku hoi o na keiki malihini;   
\q1
\v 8 Ka poe olelo wahahee ma ka lakou waha, A o ko lakou lima akau, he lima akau hoopunipuni.   
\b  
\q1
\v 9 E ke Akua, e oli aku au i ke oli hou ia oe, Ma ka violaumi he umi na kaula, e hoolea aku ai au ia oe.   
\q1
\v 10 Nana no e haawi mai i ke ola no na'lii; Nana no i hoopakele ia Davida i kana kauwa, I ka pahi kaua o ka hewa.   
\q1
\v 11 E unuhi mai oe ia'u, a e hoopakele mai hoi ia'u, I ka lima o na keiki malihini, Ka poe mea waha olelo wahahee, A o ko lakou lima akau, he lima akau hoopunipuni;   
\b  
\q1
\v 12 I like ka kakou poe keikikane me na mea kanu, I ulu a nui i ko lakou manawa opiopio: I like hoi ka kakou poe kaikamahine me na pohaku kihi, I anaiia ma ke ano o ka luakini;   
\q1
\v 13 I piha hoi ko lakou halepapaa, E haawi mai ana i mea o kela ano, keia ano; I hanau mai ai ka kakou poe hipa ma na tausani, Ma ka umi tausani hoi ma na alanui.   
\q1
\v 14 I hapai hoi ka kakou poe bipi; I komo ole kekahi iloko, aole hoi e puka iwaho, A i ole hoi he mea ohumu, ma ko lakou mau alanui,   
\q1
\v 15 Pomaikai ka lahuikanaka i noho pela; Pomaikai no ka lahuikanaka mamuli o Iehova, ko kakou Akua.   
\c 145  
\b  
\q1
\v 1 E HIILANI aku no au ia oe, e ko'u Akua, e ke Alii, E hoomaikai aku no wau i kou inoa, A hiki a kau, a mau loa aku no.   
\q1
\v 2 I na la a pau, e hoomaikai aku no au ia oe; A e halelu aku i kou inoa, A hiki a kau, a mau loa aku no.   
\q1
\v 3 He nui no o Iehova, a ua pono ke halelu nui ia'ku oia; Aole e pau kona nui i ka ikeia ma ka huli ana.   
\q1
\v 4 E hookaulana aku kekahi hanauna i kau mau hana a i kekahi hanauna, A e hoike aku hoi i kou mau mea nui.   
\q1
\v 5 E hoike aku no wau i ka nani ihiihi o kou hanohano, A me na mea o kau mau hana kupanaha.   
\q1
\v 6 E hai aku no hoi lakou i ka mana o kau mau hana weliweli; A e hoike aku no wau i kou nui.   
\q1
\v 7 E hoikeike no lakou i ka hoomanao i kou maikai nui, A e hauoli no lakou i kou pono.   
\b  
\q1
\v 8 He aloha, a he lokomaikai o Iehova; He lohi ma ka huhu, a nui wale hoi kona aloha.   
\q1
\v 9 He maikai no o Iehova i na mea a pau; A aia hoi kona lokomaikai maluna o kana mau hana a pau.   
\q1
\v 10 E mililani aku kau mau hana a pau ia oe, e Iehova, A e hoomaikai aku kou poe haipule ia oe.   
\q1
\v 11 E olelo no lakou i ka nani o kou aupuni, A e kamailio no hoi i kou mana;   
\q1
\v 12 E hoikeike aku i kona mau mea nui i na keiki a kanaka, A me ka nani hanohano o kona aupuni.   
\q1
\v 13 He aupuni mau loa no kou aupuni, A ua mau hoi kou alii ana, a i na hanauna a pau.   
\b  
\q1
\v 14 Ua kokua no o Iehova i ka poe hina a pau, A hoala mai no hoi oia i ka poe a pau i kulou ilalo.   
\q1
\v 15 Kakali no na maka o na mea a pau ia oe, A haawi mai oe i ka lakou ai i ka wa pono.   
\q1
\v 16 Hohola aku oe i kou poholima, A hoomaona mai i ka makemake o na mea ola a pau.   
\b  
\q1
\v 17 He pono no o Iehova i kona mau aoao a pau, A ua lokomaikai hoi ma na hana ana a pau.   
\q1
\v 18 Ua kokoke mai o Iehova i ka poe a pau e kahea aku ia ia, I ka poe hoi i kahea aku ia ia ma ka oiaio.   
\q1
\v 19 E hana mai no o Iehova i ka makemake o ka poe i makau aku ia ia, E hoolohe mai no hoi oia i ka lakou pule a e hoola ia lakou.   
\q1
\v 20 Malama mai no o Iehova i ka poe a pau i aloha aku ia ia; Aka, e luku mai no oia i ka poe hewa a pau.   
\q1
\v 21 E hai aku no ko'u waha i na halelu o Iehova; A e hoomaikai aku hoi na mea ola a pau i kona inoa hoano, A hiki a kau, a mau loa aku no.   
\c 146  
\b  
\q1
\v 1 E HALELU aku ia Iehova; E kuu uhane, e halelu aku ia Iehova.   
\q1
\v 2 E halelu aku au ia Iehova i ko'u ola ana; E hoolea aku no wau i ko'u Akua i ko'u manawa a pau.   
\q1
\v 3 Mai hilinai oukou i na'lii, I ke keiki a ke kanaka hoi, ka mea hiki ole ke hoola mai.   
\q1
\v 4 Puka aku no kona ea, a hoi oia i ka lepo; I ua la la no, make kona mau manao.   
\q1
\v 5 Pomaikai ka mea, ia ia ke Akua o Iakoba, i kokua nona, Ka mea hoi i hoolana ma Iehova, kona Akua:   
\q1
\v 6 Ka Mea nana i hana ka lani a me ka honua, Ka moana hoi, a me na mea a pau iloko ona, Ka Mea i malama mau loa mai i ka oiaio;   
\q1
\v 7 Ka Mea i hooponopono i ka poe i hookaumahaia; Ka Mea i haawi mai i ka ai na ka poe pololi. Na Iehova no ka hookuu ana o ka poe paa.   
\b  
\q1
\v 8 Hookaakaa mai no o Iehova i na maka o ka poe makapo; Hoala mai no o Iehova i ka poe kulou, i hookulouia: Aloha mai na hoi o Iehova i ka poe pono.   
\q1
\v 9 Malama mai no o Iehova i na malihini, Hoolako hou mai no oia i ka poe makua ole, a me na wahinekanemake; Hookahuli wale oia i ka aoao o ka poe hewa.   
\q1
\v 10 E noho aupuni no o Iehova, a i ke ao pau ole, O kou Akua hoi, e Ziona, a i na hanauna a pau. E halelu aku oukou ia Iehova.   
\c 147  
\b  
\q1
\v 1 E HALELU aku oukou ia Iehova: No ka mea, he mea maikai ke hoolea aku i ko kakou Akua; No ka mea, he lealea ia, a he mea ku pono ka halelu.   
\q1
\v 2 Kukulu no o Iehova ia Ierusalema; Hoiliili mai no oia i ka poe aea o ka Iseraela.   
\q1
\v 3 Hoomaha mai no oia i ka poe naau haehae, A wahi no hoi oia i ko lakou mau eha.   
\q1
\v 4 Hoike mai no oia i ka heluna o na hoku; Hea ae no hoi oia ia lakou a pau ma ka inoa.   
\q1
\v 5 He nui no ko kakou Haku, a na nui hoi kona ikaika; A he mea hiki ole ke hai aku i kona ike.   
\q1
\v 6 Hookiekie no o Iehova i ka poe hoohaahaa; A hoohaahaa no oia i ka poe hewa ilalo i ka lepo.   
\b  
\q1
\v 7 E olioli aku ia Iehova, me ka mililani aku, E hoolea aku i ko kakou Akua ma ka mea kani.   
\q1
\v 8 Ka Mea i uhi i ka lani i na ao, Ka Mea i hoomakaukau i ka ua no ka honua, Ka Mea i hooulu mai i ka mauu, maluna o na mauna.   
\q1
\v 9 Haawi mai no oia i ka ai na ka holoholona, Na ka poe koraka hoi, na ka mea kahea aku ia ia.   
\q1
\v 10 Aole ia e lealea i ka ikaika o ka lio, Aole ia e hauoli hoi i na wawae o ke kanaka.   
\q1
\v 11 E lealea no o Iehova i ka poe makau aku ia ia, I ka poe hoi e hoolana ma kona lokomaikai.   
\b  
\q1
\v 12 E hiilani ia Iehova, e Ierusalema, E halelu aku i kou Akua, e Ziona.   
\q1
\v 13 No ka mea, hoopaa no oia i na kaola o kou mau pukapa; Hoomaikai no hoi oia i kau mau keiki iloko ou.   
\q1
\v 14 Haawi mai no oia i ka malu ma kou mau mokuna, A hoomaona mai ia oe i ka palaoa maikai.   
\q1
\v 15 Hoouna mai oia i kana mau olelo i ka honua, Holo kiki no kana mau olelo.   
\q1
\v 16 Haawi mai no oia i ka hau, me he hulu hipa la, Hoohelelei mai oia i ka hau paa, e like me ka lehu ahi.   
\q1
\v 17 Hoohelelei mai oia i kona mau huahekili e like me na huna ai: Owai hoi ka mea hiki ke ku imua o kona anuanu?   
\q1
\v 18 Hoouna mai oia i kana olelo, a hoohehee ia lakou; Hoohuai mai oia i kona makani, a kahe iho la na wai.   
\q1
\v 19 Hoike mai no oia i kana olelo i ka Iakoba, I kana mau olelopaa hoi, a me kana hooponopono ana i ka Iseraela.   
\q1
\v 20 Aole ia i hana pela i ko na aina e a pau; O kana hooponopono ana, aole lakou i ike mai ia. E halelu aku oukou ia Iehova.   
\c 148  
\b  
\q1
\v 1 E HALELU aku oukou ia Iehova, E halelu aku oukou ia Iehova, e na mea mai ka lani mai; E halelu aku ia ia ma na wahi kiekie.   
\q1
\v 2 E halelu aku ia ia, e kona poe anela a pau; E halelu aku oukou ia ia, e kona mau kaua a pau.   
\q1
\v 3 E halelu aku ia ia, o ka la, a me ka mahina; E halelu aku ia ia, e na hoku malamalama a pau.   
\q1
\v 4 E halelu aku ia ia, e ka lani o na lani, E oukou hoi, na wai maluna o ka lani.   
\q1
\v 5 E halelu aku lakou ia Iehova; No ka mea, kauoha mai la ia, a hanaia iho la lakou.   
\q1
\v 6 Ua hookumu paa mai oia ia lakou, a i ka manawa pau ole: Ua haawi mai oe i ka mokuna, aole lakou hele ae ma ia aoao aku.   
\b  
\q1
\v 7 E halelu aku oukou ia Iehova, mai ka honua ae, E na moonui, a me na wahi hohonu a pau:   
\q1
\v 8 Ke ahi, ka huahekili, ka hau, a me ka mahu, Ka makani ino, e hooko ana i kana olelo;   
\q1
\v 9 Na kuahiwi, me na mauna a pau; Na laau hua, a me na kedera a pau;   
\q1
\v 10 Na holoholona hihiu, a me na holoholona laka a pau; Na mea kolo, a me na manu lele;   
\q1
\v 11 Na'lii o ka honua, a me na lahuikanaka a pau; Na kaukaualii, a me na lunakanawai a pau o ka honua;   
\q1
\v 12 Na kanaka opiopio, a me na kaikamahine; Ka poe kahiko, a me na keiki;   
\b  
\q1
\v 13 E halelu aku lakou i ka inoa o Iehova; No ka mea, o kona inoa wale no ka i hookiekieia: Ua kiekie hoi kona nani maluna o ka honua a me ka lani.   
\q1
\v 14 Ua hookiekie oia i ka pepeiaohao o kona poe kanaka, Oia ka nani o kona poe haipule a pau; O na mamo hoi o ka Iseraela, He poe kanaka e noho kokoke ana ia ia. E halelu aku oukou ia Iehova.   
\c 149  
\b  
\q1
\v 1 E HALELU aku oukou ia Iehova, E oli aku ia Iehova, i ke mele hou, I kona mau halelu hoi ma ke anaina o ka poe haipule.   
\q1
\v 2 E lealea o ka Iseraela i ka mea nana ia i hana; E hauoli hoi na keiki a Ziona i ko lakou alii.   
\q1
\v 3 E halelu aku lakou i kona inoa ma ka haa ana; E hoolea aku lakou ia ia ma ka pahukani, a me ka lira.   
\q1
\v 4 No ka mea, ua lealea o Ivhova i kona poe kanaka; E hoonani mai no oia ia lakou i ke ola.   
\b  
\q1
\v 5 E hooho olioli no ka poe haipule maloko o ka nani: E hauoli no lakou ma ko lakou wahi moe.   
\q1
\v 6 Ma ko lakou waha, ka hapai i ke Akua, A ma ko lakou lima hoi, he pahikaua maka lua;   
\q1
\v 7 E hana me ka hoopai aku i ko na aina e, A me ka paipai aku i na kanaka:   
\q1
\v 8 E hoopaa i na'lii i na kaula, A me ko lakou kaukaualii, i na kupee hao.   
\q1
\v 9 E hana aku ia lakou i ka hoopai i palapalaia; Oia ka nani o kona poe haipule a pau. E halelu aku oukou ia Iehova.   
\c 150  
\b  
\q1
\v 1 E HALELU aku oukou ia Iehova: E halelu aku i ke Akua, ma kona wahi hoano; E halelu aku ia ia, ma ke aouli o kona hanohano.   
\q1
\v 2 E halelu aku ia ia, no kana mau hana mana; E halelu aku ia ia, e like me ka manomano o kona nui;   
\b  
\q1
\v 3 E halelu aku ia ia, me ke kani ana o ka pu; E halelu aku ia ia, me ka Violaumi a me ka Lira;   
\q1
\v 4 E halelu aku ia ia, me ka pahukani, a me ka haa ana; E halelu aku ia ia, me ka pahu kaula, a me ka ohe.   
\q1
\v 5 E halelu aku ia ia, me na kimebala kani nui; E halelu aku ia ia, me na kimebala kani kiekie.   
\q1
\v 6 E halelu aku ia Iehova, na mea hanu a pau; E halelu aku oukou ia Iehova.   