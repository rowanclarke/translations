\v 13 Te \w dongah|strong="H9999"\w* \w Gad|strong="H1410"\w* te \w David|strong="H1732"\w* \w taengah|strong="H0413"\w* \w cet|strong="H0935"\w* \w tih|strong="H9999"\w* a \w puen|strong="H5046"\w* pah. Te \w vaengah|strong="H9999"\w* \w David|strong="H9909"\w* \w te|strong="H9997"\w*, “\w Na|strong="H9905"\w* \w khohmuen|strong="H0776"\w* \w ah|strong="H9996"\w* \w khokha|strong="H7458"\w* \w kum|strong="H8141"\w* \w rhih|strong="H7651"\w* ha \w pai|strong="H0935"\w* saeh \w a|strong="H9994"\w*? \w Na|strong="H9905"\w* \w rhal|strong="H6862"\w* rhoek \w mikhmuh|strong="H6440"\w* \w ah|strong="H9997"\w* \w hla|strong="H2320"\w* \w thum|strong="H7969"\w* \w na|strong="H9905"\w* \w rhaelrham|strong="H5127"\w* \w vetih|strong="H9999"\w* \w nang|strong="H9905"\w* n'\w hloem|strong="H7291"\w* saeh a? \w Na|strong="H9905"\w* \w khohmuen|strong="H0776"\w* he \w hnin|strong="H3117"\w* \w thum|strong="H7969"\w* \w khuiah|strong="H9996"\w* \w duektahaw|strong="H1698"\w* \w om|strong="H1961"\w* \w koinih|strong="H0518"\w* ta. \w Ming|strong="H3045"\w* \w lamtah|strong="H9999"\w* \w hmu|strong="H7200"\w* \w laeh|strong="H6258"\w*. \w Mebang|strong="H4100"\w* kan \w tueih|strong="H7725"\w* ham khaw \w kamah|strong="H9901"\w* taengla \w ol|strong="H1697"\w* ham \w voei|strong="H7971"\w*,” a \w ti|strong="H0559"\w* nah.
\p 
\v 14 \w David|strong="H1732"\w* loh \w Gad|strong="H1410"\w* \w taengah|strong="H0413"\w*, “\w Kai|strong="H9901"\w* puen ka \w cak|strong="H6887"\w* \w tangkik|strong="H3966"\w* coeng. \w A|strong="H9909"\w* \w haidamnah|strong="H7356"\w* tah aka \w len|strong="H7227"\w* koek \w haidamnah|strong="H7356"\w* la a om \w dongah|strong="H3588"\w* \w BOEIPA|strong="H3068"\w* kah \w kut|strong="H3027"\w* \w dongah|strong="H9996"\w* \w tla|strong="H5307"\w* uh \w mai|strong="H4994"\w* saeh \w lamtah|strong="H9999"\w* \w hlang|strong="H0120"\w* \w kut|strong="H3027"\w* \w dongah|strong="H9996"\w* ka \w tla|strong="H5307"\w* \w boel|strong="H0408"\w* mai eh,” a ti.
