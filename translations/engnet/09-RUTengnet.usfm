\v 9 \w Take|strong="H1980"\w* note \w of|strong="H3627"\w* \w the|strong="H6680"\w* \w field|strong="H7704"\w* \w where|strong="H3808"\w* \w the|strong="H6680"\w* \w men|strong="H5288"\w* \w are|strong="H5869"\w* harvesting \w and|strong="H1980"\w* \w follow|strong="H1980"\w* \w behind|strong="H1980"\w* \w with|strong="H1980"\w* \w the|strong="H6680"\w* female workers. \w I|strong="H6680"\w* \w will|strong="H5869"\w* tell \w the|strong="H6680"\w* \w men|strong="H5288"\w* \w to|strong="H1980"\w* \w leave|strong="H1980"\w* \w you|strong="H6680"\w* alone. \w When|strong="H1980"\w* \w you|strong="H6680"\w* \w are|strong="H5869"\w* \w thirsty|strong="H6770"\w*, \w you|strong="H6680"\w* \w may|strong="H5288"\w* \w go|strong="H1980"\w* \w to|strong="H1980"\w* \w the|strong="H6680"\w* \w water|strong="H7579"\w* \w jars|strong="H3627"\w* \w and|strong="H1980"\w* \w drink|strong="H8354"\w* some \w of|strong="H3627"\w* \w the|strong="H6680"\w* \w water|strong="H7579"\w* \w the|strong="H6680"\w* \w servants|strong="H5288"\w* \w draw|strong="H7579"\w*.”
