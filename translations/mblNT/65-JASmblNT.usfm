\id JAS - Maxakal'i NT -Brazil 2011 (DBL -2013)
\h TIAK
\toc1 Tiak Te Kax'ãmi'
\toc2 Tiak
\toc3 Tk
\mt1 TIAK TE KAX'ÃMI'
\c 1
\p 
\v 1 'Ũgmũn Tiak. Topa pu 'ãte hãpxopmãhã', xix yũmũg xuxyã Yeyox Kunnix pu 'ãte hãpxopmãhã', tu Topa yõg tikmũ'ũn te hãpxexka xohix tu' pip xop pu 'ãneo.
\s1 'Ãkuxa yũm ka'ok, nũy tu hãmyũmmũg
\p 
\v 2 'Ũkxape xop, 'ãkuxa hittup 'ĩhã 'ãxũy xexka',
\v 3 yã 'ãkuxa mãm ka'ok, hu' xũy'ax hã' tot, nũy Topa yõg putat xak hok,
\v 4 nũy 'ãmõg kuma 'ãmõg, nũy Topa hã 'ãxiptap xop, nũy tu hãpxopmã max xe'e'.
\v 5 Tikmũ'ũn te hãmyũmmũg hok, puxix Topa tu' xax, pu tu hãmyũmmũgã', ha Topa hittup, tu hãmyũmmũgã punethok, tu mõktu xohix, yã Topa mũn max, tu' hok hã tikmũ'ũn xohix pu hãmyũmmũgãhã',
\v 6 yĩy ta tu' xax, 'ĩhã 'ãkuxa yũm ka'ok 'õm kopah, tu 'ĩkopit hok. Tikmũ'ũn kuxa yũm hok te kõnãg xexka mahap'ax putuk, tu' kuxa kopa mahapnãm, tu' yũm 'ohnãg.
\v 7 Topa te nõm xop pu hãmyũmmũgã 'ohnãg,
\v 8 'ũpu'uk hah, 'ap-tox puxet'ah Kunnix putox mũtik, 'ap hãpxopmã'ax yũmmũg'ah.
\s1 'Ũp-texop xexka xi' hok xop
\p 
\v 9 Pũyãk xape hok hittup, 'ĩhã Topa te nõm ha hãmmaxnãhã'.
\v 10 Pũyãk xape tup-texop hittup kamah, 'ihã Topa te hãmhõgnãgãhã'. Yã' yõg tayũmak yãyxaogã'ax, tu mõktu' xok, tu mĩnnut puxet putuk, 'ũhok tu'.
\v 11 Mãyõn ka'ok, tu mĩxux mõ'hap, ha' nak, tu tapmãhã', yĩy mĩnnut nãhã hãm tu', tu' mãm, tu' nõg, ha kaxĩy 'ũp-texop xexka xok.
\s1 Hãpkummugã'ax
\p 
\v 12 Tikmũ'ũn xũy, puxix Topa yõg putat xax hok, pãyã' kuxa hittup. Yã Topa te hãpxopmã'ax xohix kopit, tu' kopit kux, 'ĩhã 'ũhĩnnã xe'ẽgnãg, tu ta tu hãm'ãktux xex, nũy hĩnnã', Topap-tup pax hah.
\v 13 Pũyã tikmũ'ũn Topa kupex hok, 'ĩhã hãpkummuk mĩy putup, 'ĩhã' xũy'ax hã' tot putup'ah, hu: “Topa tek xapit, 'ũ hãpkummuk mĩy,” kaxĩy. Yã' koit. Topa te hãpkummuk mĩy 'ohnãg, tu tikmũ'ũn xapit 'ohnãg, puyĩy hãpkummuk mĩy.
\v 14 Pa tikmũ'ũn te hãpkummuk mĩy, 'ũp-tup tu' mĩy, tu yã mõ'ãmã', nũy mĩy.
\v 15 Tu hãpkummuk pe'paxex, tu' mĩy putup, hu hãpkummuk mĩy, tu' mĩy pax, tu mõktu' xok, tu Topa hã' puknõg xe'e'.
\p 
\v 16 'Ũkxape xop, yãy pu koit hok.
\v 17 Topa te mãyõn xop xohix mĩy, tu' mãynãg mĩy pexkox tu', yã pexkox yõg hãpxop xohix mãynãg. Yã hãmmax xohix Topa te' mĩy, tu pexkox tu yũmũ'ã hãmmaxnãhã'. Yã Topa mũn max xe'ẽgnãg, tu yã yĩnmũn, tu yãy yãnãn 'ohnãg, xix yãyhã' nõy 'ohnãg kamah.
\v 18 tu yũmũg putup, hu' xat, pu yũmũg tut yũmũg put, tu hãpxe'e 'ãktux, ha yũmũg kuxa mãm ka'ok nõm hãm'ãktux kopah, ha yũmũg xe xanãhã', 'ũyĩy yũmũg yãyhã Topak-tok xop te mãxap, pu hãpxop nõy xohix Topa hãk-nãy tu' xop.
\s1 Hãm'ãpax, nũy hãpxopmã max
\p 
\v 19 'Ũkxape xop, 'ũxaxok hok: 'Ãnõy yõg hãm'ãktux 'ãpax punethok, nũy hãm'ãktux kutõgnãg, yã 'ãgãy hok.
\v 20 Tikmũ'ũn gãy, puxix hãpxopmã kummuk, ha Topa tep-tup nõg, hãmyok mĩy'ax putup tu'.
\v 21 Yĩy hãpkummuk mĩy hok, xix hãpxopmã kummuk hok, yãy mũn kutõgnãg pe'ãpaxeh, yã Topa yõg hãm'ãktux te 'ãkopa' xip, yĩy 'ĩpkox pi', nũy 'ãkuxa hi xe'e'.
\p 
\v 22 Yãyhã 'ãmõ'ãmã hok. Topa yõg hãm'ãktux 'ãpax, xa 'ĩpkox pi', nũy hãpxopmã max.
\v 23 Tikmũ'ũn te nõm hãm'ãktux 'ãpak, tu' yĩpkox hok, puxix tikmũ'ũn hãmyũmmũg 'ohnãg putuk, ha 'ĩypex hã tute yãy pẽnãhã', tu yãy pa pẽnãhã', tu hãmyũmmũg: Yã yãy pa xe'e',
\v 24 pa putpu' mõg, tu yãy pa xaxok, ha' kux. Ha kaxĩy tikmũ'ũn te hãmyũmmũg hok te Topa yõg hãm'ãktux xaxok.
\v 25 Pa tikmũ'ũn te hãmyũmmũg, tu' xat'ax max xe'ẽgnãg 'ãpak, nũy hãmyũmmũg max, puyi' mãynãg mĩy, puxi' xat'ax hãmyũmmũgã', puyĩy tu' hi' xe'e. Topa te nõm tikmũ'ũn ha hãmmaxnãp-tup.
\p 
\v 26 Tikmũ'ũn te: “'Ũgkuxa te Topa xak,” kaxĩy, pãyã' yĩy kummuk pax, puxix tu Topa xak 'ohnãg, tu yã yãyhã mõ'ãmã',
\v 27 Pa tikmũ'ũn te Topa yũmũg Tak xak xe'e', puxix 'ũn hok mãm xop hã tu tehet, xix kakxop yãy tak pip hok xop hã tu tehet, nũy nõm ha hãmmaxnã', tu Topa hã' puknõg xop yõg putat kummuk xak, nũy Topa yõg putat hã' mõg kuma' mõg.
\c 2
\s1 'Ũxohix yã yãy putuk
\p 
\v 1 'Ũkxape xop, 'ãkuxa mãm ka'ok yũmũg xuxyã Yeyox Kunnix kopah, ha' max xe'ẽgnãg, yĩ' hok xop xix 'ũp-texop xexka putup pax, yã' nõy putuk yũmũg xuxyã pu'.
\v 2 Pa tikmũ'ũn yãg te' hok xop putup nõg, tup-texop xexka putup pax, hap-texop te 'ãxop mũtik yãy tu nũ'nãhã' tu' xax max mõ'tat, tu pipkup kõnãmõg tat yĩpkutok hã', ha tik hok nũn, kamah, tu' xax kummuk mõ'tat.
\v 3 Pe 'ãxop tep-texop pu: “Yũhũm, nũy nũ mĩpe max yĩmũ yũm,” kaxĩy. Tu' hok pu: Pe yĩy 'ãknĩhã xihip 'õnte', pe yã hãm tu yũhũm,” kaxĩy.
\v 4 Puxi', 'ãp-tox 2 'ãnõy hã, yã 'ãxop hã yãy putuk 'ohnãg.
\p 
\v 5 'Ũkxape xop, 'ũg'ãpax: Topa te' hok xop yĩmõgãtux, pu' kuxa mãm ka'ok hamũn kopah, nũy yĩpkox pi', 'ĩhã Topa te' xat, Topap-tup pax tu', yã Topa te hãm'ãktux xex nõm xop mũtik,
\v 6 ha 'ãxop te' hok xop putup nõg, pãyã putexop xexka te xa hãpkummugãhã', tu tik pa te hãmyũmmũg ha 'ãmõgãhã', nũy 'ãkupeh,
\v 7 tu Yeyox Kunnix 'ãktux kummuk, ha xa' hõm yãy'ãxet'ax. Hap-texop te xa 'ãktux kummuk, ha Topa te xa hãmmaxnaha'.
\p 
\v 8 'Ãxat'ax pu yĩpkox pi', puxix hãpxopmã max, ha' xat, hu: “'Ãnõy putup pax, xate yãy mũn putup pax putuk,” kaxĩy.
\v 9 'Ãxop te hãmhok xop putup nõg, xip-texop putup pax, 'ũxax pẽnã tu', puxix Topa yõg xat'ax pu 'ãyĩpkox pip hok, tu hãpkummuk mĩy, ha Topa te' kummuk 'ãktux.
\v 10 Tikmũ'ũn te Topa yõg xat'ax puxehnãg pu' yĩpkox hok, puxix tu xat'ax xohix pu' yĩpkox 'ohnãg. Yã Topa te' xat, pu' xat'ax xohix pu' yĩpkox pi'.
\v 11 Ha' xat, hu: 'Ãxonnix hok,” kaxĩy. Tu xe: “'Ũp-tex hok,” kaxĩy. 'Ap xatep-tex'ah, pãyã' xonnix, puxix 'ãyĩpkox hok, tu' xat'ax koxyõy.
\v 12 Topa te 'õg hãpxopmã'ax kopit'ax, yĩ' xat'ax pu 'ãyĩpkox pi'. Yã' xat'ax te yũmũ'ã hãmyũmmũgãhã', 'ũyĩy yũmũg hi xe'e', nũy hãpxopmã max.
\v 13 Topa te tikmũ'ũn yõg hãpxopmã'ax xohix kopit putup, ha tikmũ'ũn te' nõy kuxa ka hok, puxix Topa' ka hok xop kuxa ka hok 'ũyãnãn tu', pa tikmũ'ũn te' nõy kuxa ka', puxix Topa te nõm xop pu hãpkummugã hok.
\s1 'Ãkuxa yũm ka'ok nũy hãpxopmã max
\p 
\v 14 'Ũkxape xop, 'ã' max'ah, yãy kuxa yũm'ax 'ãktux, 'ĩhã 'ãnõy te 'õg hãpxopmã max pẽnã 'ohnãg. Yã 'ãkuxa yũm pu'uk, 'ap 'ãkuxa yũm xe'e'ah.
\v 15 'Ãxape xax kummuk, ha putup tep-tex,
\v 16 ha tu hãpxop hõm 'ohnãg, xix topixxax hõm 'ohnãg, pa: “Pũyã Topa xa hãmmaxnã', xayĩy 'ãxit max, nũy 'ãxax max tat kamah,” kaxĩy,
\v 17 puxix 'ãkuxa yũm pu'uk, 'ĩhã 'ãnõy pu hãpxopmã 'ohnãg, 'ap 'ãkuxa yũm xe'e'ah.
\p 
\v 18 Tikmũ'ũn te: “'Ãkuxa yũm ka'ok, ha 'ãte hãpxopmã max,” kaxĩy. Yĩy 'ãte: Tikmũ'ũn te 'ãkuxa yũm'ax pẽnã hok, 'ĩhã xate hãpxopmã 'ohnãg. Pãyã 'ãte hãpxopmã max'ax hã xa' mũg, xayĩy pẽnã', nũy tuk kuxa yũm ka'ok yũmmũg. Yã hãpxopmã'ax max hã tikmũ'ũn te' pẽnã'ax,” kaxĩy.
\v 19 'Ok 'ãkuxa yũm ka'ok Topap-xehnãg kopah? Yã' max. Yãmĩy kummuk xop kuxa mãm ka'ok kamah, tu Topa yĩpkutuk, tu yãy nuhuknãm 'ũkuxãnõg tu'.
\v 20 'Ãptox ka'ok, tu hãmyũmmũg 'ohnãg! 'Ãkuxa yũm ka'ok, 'ĩhã hãpxopmã max 'ohnãg, tu' hitop hã 'ãkuxa yũm, 'ap puxi'ah.
\v 21 Tep te xĩy Topa te mõnãyxop hittap 'Amanãm max 'ãktux? 'Amanãm tek-tok 'Iyak hõm'ax, nũy kuxap hã mõ'hap Topa pu', hu Topa te 'Amanãm max 'ãktux, 'ũyĩpkox xip hah.
\v 22 Yũmmũg. 'Amanãm kuxa yũm ka'ok Topa kopah, tu' yĩpkox xip, tu hãpxopmãhã kamah.
\v 23 Yĩy Topa yõg tappet te: 'Amanãm kuxa yũm ka'ok Topa kopah, yĩ' kuxa tupmãhã', pu tu max,” kaxĩy. Ha Topa te 'Amanãm hã' xape'.
\v 24 Yĩ' yũmmũg. Yã Topa te tikmũ'ũn putup pax, 'ũyõg hãxopmã'ax hãp-tup pax, 'ũkuxa yũm ka'ok ha hãpxopmãhã', ha' kuxa tupmãhã'.
\p 
\v 25 Xotit Ha'ap te 'Iyaet yõg tik xop hã tu tehet, nõm xop te' puknõg yõg hãm pẽnã'ax, ha putat nõy ha' mõgãhã', puyĩy tu nũmãn, yĩy hãpxopmã max, ha Topa tep-tup pax.
\p 
\v 26 Tikmũ'ũn koxuk te' yĩn nĩm, puxix tikmũ'ũn tu xok, hã kaxĩy tikmũ'ũn kuxa yũm ka'ok, tu hãpxopmã hok, puxi' hi xe'e hok.
\c 3
\s1 Tikmũ'un yõyxõg
\p 
\v 1 'Ũkxape xop: 'Ap max'ah, tikmũ'ũn punethok te' nõy xop pu hãmyũmmũgã', 'ĩhã yãy kotĩnnãhã' pip. 'Ũyũmmũgã'ax, puxix Topa' yĩkopit putup, nũy yũmmũg, pẽyã hãmyũmmũgã max, pẽyã hãmyũmmũgã kummuk.
\v 2 Yũmũg xohix te hãpkummuk mĩy, ha tikmũ'ũn yãy yĩy'ax hã hãpkummuk 'ãktux hok, puxix 'ũmax xe'ẽgnãg, tu yãy mõgã max.
\v 3 Tikmũ'ũn te kãmãnok mõgãhã', tu pipkup kohe te kamãnok yĩkox kopa' xip hã mõgãhã', pu mõg, ha yũmũ'ãte yĩmũ' mãm, nũy nõ mõg.
\v 4 Kamah mĩpkox xexka te kõnãg yĩmũ mõg, ha 'ãmuuh ka'ok te' mõgãhã', pa tikmũ'ũn te mĩm kutõgnãg hã' mõgãhã, nũy nõ hãpkux xuhmĩy yĩmũ 'ãpep hãmnak hah.
\v 5 Ha tikmũ'ũn yõyxõg kaxĩy, 'ũk-tõgnãg, pãyã 'ũyĩy'ax te hãpxopmã xexka'. Kuxap kup kutĩgnãg, pãyã hãmhipak xexka mõ'xut xexka',
\v 6 hã kaxĩy 'ũyõyxõg kutĩgnãg, pãyã' yĩy'ax te hãpkummugã xexka', tu Hãmgãyãygnãg yõg kuxap gãy putuk, tu' nõy kuxa tuknõgãhã', tu mõktu kummugã xexka', 'ũxupmãhĩy kummuk tu'.
\v 7 Tikmũ'ũn te xokxop xohix mũg'ax xix putuxnãg, xix xokxop yãy hi xip mũg'ax, xix xokxop yĩkũy mũg'ax, xix mãm xohix mũg'ax,
\v 8 pa tikmũ'ũn te' yõyxõg 'ũm mũg hok, puyĩy tu yĩy kux, 'ũkummuk hah, tu kãyã gãy yõyxõg putuk, tu' yĩy'ax hã' mõy putex.
\v 9 Yũmũ'ãte yãy yĩy'ax hã yũmũg Tak Topa max 'ãktux, xiknõy mãnõg, hu: “Pũyã Topa xa hãpkummugã',” kaxĩy, tu' mãnõg, yã Topa te' hep xop xohix mĩy yãymũn putuk, ha yũmũ'ãte' xaxok.
\p 
\v 10 Tikmũ'ũn yĩy'ax 2, tu Topa pu hãm'ãktux max, 'ĩhã' nõy pu hãm'ãktux kummuk. 'Ũkxape xop, kaxĩy 'ãktux hok!
\v 11 Kõnãg xupup kox puxet te kõnãg xut, ha kõnãg puxet, pẽyã' xuxpex, 'ok pẽyã' kohãgnãg, tu kõnãg 2 'ohnãg, pap-xet.
\v 12 Tikmũ'ũn te xupxak xut hok tepta kup tu', tu gõyap xut hok nanũy kup tu'. 'Ãmhok! Yã kaxĩy kõnãg kox kummuk tu kõnãg xuxpex tat 'ohnãg.
\s1 Hãmyũmmũg xe'e'
\p 
\v 13 Piyã' xip tikmũ'ũn te hãmyũmmũg? 'Ok xip 'ãxop kopa'? Pũyã hãpxopmã max, tu yãy mũn kutõgnãg pe'paxeh, nũy hãmyũmmũg xexka'.
\v 14 Pa 'ãyĩpkumĩy hok, tu yãy mũn xexka pe'ãpaxex hok, xi' koit hok, nũy mõ'ãmã hok, puyĩ' nõy 'ãpe'paxex, hu: “Yã 'õhõm te hãmyũmmũg!” kaxĩy.
\v 15 Yã hãpxopmã'ax kummuk te yãmĩy xop kummuk yõg hãmyũmmũg'ax putuk, xix xokxop yõg, xix Topa hã' puknõg xop yõg hãmyũmmũg'ax putuk. Yã' kummuk.
\v 16 Tikmũ'ũn kummuk te yãy mũn pe'paxex xexka', tu' yĩpkũmĩy, tu tikmũ'ũn xohix kummugãhã', tu' mõgã kummuk, yĩy hãpxopmã kummuk punethok.
\v 17 Topa te pexkox tu' xip, tu hãmyũmmũg xe'ẽgnãg, tu yãy yõg tikmũ'ũn pu hãmyũmmũgãhã', puyĩy tikmũ'ũn kuxa tu tup, puyĩy yãytuk-mĩy kuxyã', puyĩ' kuxa yũm, ha Topa te hãmyũmmũgãhã', nũy hãmmaxnã', nũy tikmũ'ũn hã' xape', tu' kuxa ka', puyĩy hãpxopmã max 'ũyãnãn tu',
\v 18 ha' kuxa yũmmãhã', puyĩy hãmyok mĩy pax.
\c 4
\s1 Topa hã' puknõg xop yã 'ãxape hok
\p 
\v 1 Teptu yãy tuk-mĩy 'ãnõy mũtik? 'Ãxop te yãy putup'ax kummuk mĩy, tu yãykix.
\v 2 Tu hãpxop putup xũy, pãyã' pa hok, hup-tex putup, nũy nõm hãpxop pa', tu 'ãnõy yõg hãpxop putup, 'ap pa yũmmũg'ah, hu yãykix, tu Topa tu' xak 'ohnãg, pu xa' hõm.
\v 3 Xate Topa tu' xak, tu' pa 'ohnãg, 'ũxak kummuk tu'. Tu' xak, nũy yãy putup'ax mĩy.
\v 4 'Ãxop te Topa nĩm'ax. Topa hã' puknõg xop te Topap-tup nõg. 'Ok yũmmũg hok xate'? 'Ãxop te nõm puknõg xop hã 'ãxape', hu ta Topa hã 'ãpuknõg kamah.
\v 5 Topa yõg tappet te tikmũ'ũn kuxa 'ãktux, tu' hitop tu' xuktux 'ohnãg, hu: “Topa te tikmũ'ũn kuxa mĩy, ha' yĩpkũmĩy, tup-tex,” kaxĩy,
\v 6 Pa Topa ka'ok xe'ẽgnãg, tu tikmũ'ũn kuxa ka'ogãhã', yã Topa yõg tappet te xe: “Tikmũ'ũn yãy mũn xexka pe'paxex, puxix Topa putup nõg, pak-tõgnãg xop pu hãmmaxnãhã', nõm xop yãymũn kutõgnãg pe'paxex ha hãmmaxnãhã',” kaxĩy.
\v 7 Yĩy 'ĩpkox pi Topa pu', nũy Hãmgãyãgnãg yĩpkutuk hok, nũy nõm mũtik kumĩy, ha' xupap-tup.
\v 8 'Ãxop yã hãpxopmã kummuk xop, 'ãpu Topa hã mõg, nũy yĩka hã' pip, ha 'ãha' nũn putup, nũy 'ãkuxa kummuk xit, nũy kuxa max mõ'tat 'ũyãnãn tu'. Hãpkummuk mĩy kux, 'ãyĩm pix putuk, nũy 'ãkuxa tup, nũy 'ãmax, nũy 'ãp-xet Topa kuxa mũtik,
\v 9 'Ãkuxa hittup hok, nũy pota punethok, nũy hãpkummuk mĩy kux,
\v 10 tu Topa tu' xax, pu mõ'ãnĩynãm, nũy 'ãka'ogã', ha 'ãxexkanãp-tup.
\s1 'Ãnõy 'ãktux kummuk hok
\p 
\v 11 'Ũkxape xop, 'ãnõy 'ãktux kummuk hok, 'ũxuktux kummuk, puxix 'ãxop 'ãnõy yĩkopit, tu Topa yõg xat'ax kopit kamah, yã 'ãkummuk. Tikmũ'ũn te Topa yõg xat'ax kopit, puxix Topa tu' yĩpkox 'ohnãg.
\v 12 Topap-xet te 'ãxat, 'ũpa te hãmyũmmũg, tup-xehnãg hã 'ũhep xop xohix yõg hãpxopmã'ax kopit putup, tu tikmũ'ũn kuxa kummuk xit'ax, nũy yãnãn tu' kuxa max tat, tu' kummuk mĩy pax xop kix'ax. Yãy 'ãpe'ãpaxeh hok, nũy 'ãxape yõg hãpxopmã'ax kopit, nũy Kunnix yõg xop yĩkopit. Kunnix yãp-xet te hãpxopmã'ax xohix kopit, nũy tu hãmyũmmũg, pe yã' max, pe yã' kummuk.
\s1 Hãptup pe'ãpaxek-tõgnãg
\p 
\v 13 'Ãxop te: “Pe hõnhã, pa hãptup, kopxik mõg kõmẽn tu', nũy nox xihip, nũy hãpxop hãmenex, 'ũyĩy tayũmak xexka punethok pop,” kaxĩy. Nãy. 'Ũg'ãpax:
\v 14 'Ãxop te hãptup yõg hãpxopmã'ax yũmmũg 'ohnãg! Tu hãmgõy putuk, yã hõnhã' xip, tu hãpxip kutõgnãg 'ĩhã yãyxaxogãhã', ha hãpxip kutõgnãg 'ĩhã 'ãxop xakix putup, ha kama yãy xaxogãp-tup.
\v 15 'Ãpu hãm'ãktux kaxĩy, hu: “Topa tek putup, kopxik mũg mĩy,” kaxĩy.
\v 16 Pa 'ãxop te yãy mũn xexka pe'ãpaxex, tu yãy mũn xexka 'ãktux. 'Ap max'ah.
\v 17 Tikmũ'ũn te hãpxopmã'ax yũmmũg, tu' mĩy hok, puxix hãpxopmã kummuk.
\c 5
\s1 'Ũp-texop xexka pu hãm'ãktux
\p 
\v 1 'Ãp-texop, 'ũg'ãpax nõmhã: 'Ãpota punethok putup, 'ãxũy tu'.
\v 2 'Õg tayũmak kunox, ha' kut te 'ãxax kunoxyãhã'.
\v 3 'Õg tayũmak kutut te yãy koxyõy, 'ãxupkũmĩy hah, ha tikmũ'ũn te' pẽnãhã', tu 'ãkummuk 'ãktux putup, 'ãxop te tayũmak punethok pop, tu yãy tu' xex.
\v 4 'A 'ãxop te 'õg kãmãnat xop pu' pago'ah, 'ũhãm'ax yãnãn tu' pago 'ohnãg, yĩy 'ãxop kummuk 'ãktux, tu Topa xe'ẽgnãg pu hãm'ãktux, ha' xupak. 'Ok 'ãxop te' xupak hok?
\v 5 'Ãxop te hãpkute'ex, tu 'ãmuk xexka punethok mĩy hãm tu', tu yãy topmãhã', nũy xok, mũnũytut top putuk 'ãxok putup, ha Topa te xa hãpkummugãp-tup 'ũyãnãn tu'.
\v 6 Yã 'ãxop te' hok xop kix, ha hãpkummuk mĩy 'ohnãg, pãyã' pu'uk, 'ũhok tu', hu' xakix.
\s1 Yũmũg xuxyã nũn'ax hip
\p 
\v 7 'Ũkxape xop, yũmũg xuxyã pu yũmũg hip, put nũ', 'ũxuxyã xop te yãy yõg hãpxop hip, puyĩy hãpxop ta punethok nũnnã yãy pet hah, hu tex hip, xix tex ti hip.
\v 8 'Ãpu 'ũhip kamah, nũy yũmũg xuxyã hip, ha' nũn putup mõ'ka'ok, yĩy 'ãkuxa tuknõg hok.
\p 
\v 9 'Ũkxape xop, 'ãxupmãhĩy kummuk hok, ka Topa 'ãyĩy'ax kummuk 'ãktux, 'ũpa te hãmyũmmũg tu yũmũg yĩka' xip, yã hãpxip kutõgnãg 'ĩhã' nũn putup.
\v 10 Topa yõg tik xop pe'ãpaxeh, nõm xop te Topa pupi hãm'ãktux, tu tikmũ'ũn pu' xuktux, ha Topa te tu yãy 'ãxet'ax hõm, ha' xũy'ax hã' tot.
\v 11 Yũmũ'ãte nõm xop 'ãktux max, 'ũxũy'ax hã' tot hah, xix mõnãyxop hittap Yo 'ãktux, yã nõã'tot punethok, yĩy Topa te hamũn ha hãmmaxnãhã', yã Topa mũn max xe'ẽgnãg, tu tikmũ'ũn kuxa ka', nũy nõm pu hãmmaxnã'.
\p 
\v 12 'Ũkxape xop, 'ãte xa hãpxe'e 'ãktux. Topa 'ãxet'ax 'ãktux hok, 'ĩhã hãm'ãktux xex, xix pexkox 'ãktux hok, xix hãm 'ãktux hok 'ĩhã hãm'ãktux xex. 'Ãpu hãm'ãktux kutõgnãg, hu: “Hamũn,” kaxĩy, xix: “'Ãmhok,” kaxĩy. Yã' puxi', ka Topa 'ãkummugã', xate hãm'ãktux kummuk hah.
\p 
\v 13 'Ãxũy, 'ãpu mõg, nũy Topa pu hãm'ãktux. 'Ãhittup, 'ãpu 'ãkteh, nũy Topa max 'ãktux.
\v 14 Tikmũ'ũn pakut, puxix tik te 'ãpẽnã max xop xãnã', pu Topa pu hãm'ãktux, nũy tu hep tox pux, 'ũpakut putox tu' pux, puyĩy Topa 'ũhittupmã', yã yũmũg xuxyã te' hõm yãy 'ãxet'ax, pu tikmũ'ũn hittupmã'.
\v 15 Topa pu hãm'ãktux, 'ĩhã' kuxa mãm ka'ok Yeyox kopah, puxix Topa' hittupmã', tu hãpkummuk mĩy'ax xaxogã'ax, pu tu kux.
\v 16 'Ãpu yãy pu 'õg hãpkummuk mĩ'ax 'ãktux, nũy tu yãy pupi hãm'ãktux, puyĩy Topa 'ãhittupmã'. Pũyã' kuxa mãm xop xohix yãy xape xop pupi hãm'ãktux Topa pu'. Ha Topa te tikmŨ'ũn yõg hãm'ãktux 'ãpak, ha 'ãxape kuxa te Topa xak, puxix Topa hãm'ãktux 'ãpax.
\v 17 Mõnãyxop hittap 'Enit te Topa pupi hãm'ãktux, tu yũmũg putuk, tu Topa xak, tu nõm mũtik hãm'ãktux ka'ok, tu tu' xak, pu tex hok, ha hãmyãxatamuk 3 hã xi' xahix tex ti 'ohnãg, ha hãmnak mõ'nãhã'.
\v 18 Ha xe Topa tu' xak, ha tex xat, ha' tihi', ha hãpxop punethok nũnnãhã'.
\p 
\v 19 'ũkxape xop, 'ãxop te Topa yõg putat xak, ha ta 'ãnõy te putpu 'ãmõgãhã', xayĩy Topa yõg putat hã mõg 'ũxexheh, puxix 'ãnõy xa ha hãmmaxnã'.
\v 20 'Ũxaxok hok: Tikmũ'ũn te' nõy mõ'nĩynãm, puyĩy hãpkummuk mĩy kux, ha ta hãpxopmã max, ha nõm mõgã max Topa yõg pũtat hã, puyĩy hi xe'ẽgnãg. Ha Topa te' yõg hãpkummuk mĩy'ax xaxogãp-tup, pu tu kux. 'Ap Hãmgãyãgnãg Pet ha' mõg putup'ah 'õhõm. Tu ta tu' kux.
