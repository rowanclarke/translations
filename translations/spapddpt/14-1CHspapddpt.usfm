\v 31 El \w año|strong="H8141"\w* 40 del \w reinado|strong="H4438"\w* de \w David|strong="H1732"\w* \w Jerías|strong="H3404"\w* \w era|strong="H8141"\w* el \w jefe|strong="H7218"\w* de los hebronitas según sus generaciones por sus casas paternas. Entre ellos \w fueron|strong="H1732"\w* hallados \w hombres|strong="H1368"\w* de extraordinario valor en \w Jazer|strong="H3270"\w* de \w Galaad|strong="H1568"\w*.  
\v 32 Sus hermanos, \w hombres|strong="H1121"\w* \w valientes|strong="H2428"\w*, eran 2.700 \w jefes|strong="H7218"\w* \w de|strong="H5921"\w* casas paternas. \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w los|strong="H1121"\w* \w constituyó|strong="H6485"\w* \add como\add* oficiales \w de|strong="H5921"\w* \w los|strong="H1121"\w* rubenitas, \w los|strong="H1121"\w* \w gaditas|strong="H1425"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* media \w tribu|strong="H7626"\w* \w de|strong="H5921"\w* Manasés, \w para|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w cosas|strong="H1697"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd* \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w asunto|strong="H1697"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*.   
\c 27  
