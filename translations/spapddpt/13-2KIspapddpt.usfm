\v 20 \w En|strong="H5921"\w* sus \w días|strong="H3117"\w* Edom \w se|strong="H5921"\w* rebeló \w contra|strong="H5921"\w* \w el|strong="H5921"\w* dominio \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* decidieron \w que|strong="H5921"\w* un \w rey|strong="H4428"\w* \w reinara|strong="H4427"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H3027"\w*.
