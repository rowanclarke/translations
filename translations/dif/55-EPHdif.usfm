\id EPH  
\ide UTF8
\h Ephesalani 
\toc1 Pauluni Dakani jaura Ephesalani 
\toc2 Ephesalani 
\toc3 Eph 
\mt1 Pauluni Dakani jaura Ephesalani.  
\c 1  
\p
\v 1 Paululu Jesuni Christuni Apostel Godaia jertapaterinandru, kulikirilani, tana Ephesungu ngamai, ja tanali Christungu Jesungu morlalu ngundrai.   
\p
\v 2 Manju jurangunto nganaiatimai, ja murla Goda ngaianani Ngaperandru, ja Kapara Jesu Christungundru.   
\lit (Dakani jaura Thomas ditjini.)  
\p
\v 3 Jurakokana nganaiatimai Godani ja ngaiananaia Kaparaia Jesuni Christuni Ngaperani, Nulia ngaianana murlali ngankana wonti Jaolaia murlalali pratjanali pariwilpani Christungundru,   
\p
\v 4 Worderu Nulia ngaianana nunkangu kalkalkana wonti, windrila mita pantjimanani, ngaiana kulikiri ja madlentji pani nganananto nunkangu mudlani:   
\p
\v 5 Ja Nulia ngaianana ngantjanali ngopera kurana wonti nunkani kupaia Jesu Christungundru nunkangu, nunkanaia jertapaterinaia ngantjanandru,   
\p
\v 6 Nunkani manjula pirnalaia jurakokanaia, nunkanali Nulia ngaianana manju ngankana wonti Ngantjaluni;  
\b  
\p
\v 7 Nunkangundru ngaiana kulkani ngamalkai kumarali nunkanali, jenia nganai madlentjaia kalingana, nunkani manjulaia poto pirnandru,   
\p
\v 8 Ninaia Nulia ngaianangu pirna nangana wonti kirilani ja ngujamanani pilki ja pilkini;   
\p
\v 9 Ja Nulia ngaianangu nunkanaia jertapaterinaia kurukurula tinkari ngankana wonti nunkani ngantjanandru, ninaia Nauja munta kuraterina wonti,   
\p
\v 10 Tanali ninaia kaukaubananto, miljaru matja manamiri pantjina, ngangau Nulia warupoto Christungu mangatandra kulnuni ngokananto, mina pariwilpani ja mina mitani nganai nunkangu.   
\p
\v 11 Nunkangundru ngaiana maratunka poto manina wonti, ngangau Nulia ngaianana ngopera kurana wonti nunkani kuraterinandru, Nulia warupoto ngankai nunkanaia jertapaterinaia ngundranandru,   
\p
\v 12 Ngaiana nganananto nunkanaia pirnalaia jurakokanaia; ngaiana ngopera kalkana wonti Christungu,   
\p
\v 13 Nunkangundru bakana jura jaura morlalu matja ngarana, jurani kulkanaia ngantjani jaura, nunkangundru bakana jura morlalu ngundrana wonti, ja talpadakani jauraia Jaola kulikirieli malka morlalu manina wonti,   
\p
\v 14 Naupini ngaiananaia maratunkaia mindrani poto nganai potuja kupaia kulkanaia, nunkani pirnalaia jurakokanaia.   
\p
\v 15 Jendrangundruja bakana ngato, ngato matja ngarana jurani morlalu ngundranandru Kapara Jesungu, ja jurani ngantjanandru kulikiri pratjanani,   
\p
\v 16 Wata mudai jurangundru jurakokala, ja ngato jurana ngundrai ngakani ngatjinani,   
\p
\v 17 Ngaiananaia Kaparaia Jesuni Christuni Godali, pirnalaia Ngaperali jurangu kirilaia ja tinkari ngankanaia Jaola jinkinanto, ninaia munta ngujamala,   
\p
\v 18 Jurani ngaraia milki tjenmara nganananto, jura ngujamananto, mina nunkanina karkanaia kalkana nganai, ja mina nunkanina maratunka poto pirnaia pirnalaia kulikirini nganai;   
\p
\v 19 Ja mina nunkanina ngurulaia pirnala pirna nganai ngaianangu, ngaiana morlalu ngundrai, nunkanina ngurulaia pirnalaia ngankanandru,   
\p
\v 20 Ninaia Nulia ngankana wonti Christungu, Nulia ninaia narindru jiritjibana wonti, ja ninaia nunkangu ngunarani ngamipana ngarina wonti pariwilpani,   
\p
\v 21 Kapara pratjanani, ja ngurulani ja pirnalani ja kaparani, ja tala pratjanani, tanali tanana dikai, wata windri nunkangupini mitani, a‐ai, bakana nunkangu, nau wokarananto.   
\p
\v 22 Ja warupoto Nulia nunkangu tidna ngalpani kurana wonti, ja ninaia warupotuja mangatandra kurana wonti mili wolarani,   
\p
\v 23 Tanapini nunkani palku nganai nunkanaia manamirila, Nulia warupoto warupotuni manamiri ngankai.   
\c 2  
\p
\v 1 Bakana jurana, jura nari nganana wonti dankaranali ja madlentjali juranali,   
\p
\v 2 Tanangupini jura warula wirarina wonti nunkangupini mitaia miljarani, ja ngaralanaia ngurulaia kaparani pankinani, nunkanaia jaolani, nulia karari ngankai delkinietjaia ngatamurani,   
\p
\v 3 Tanangupini bakana ngaiana warula wirarina wonti kana womalaia milkirinani, jeruja ngaiana kana womalaia ja ngundranaia jertapaterina ngankana wonti, ja tiria kupa dankanandru nganana wonti nguruni jeribaka,   
\p
\v 4 Windri Godali, Nauja poto pirna nganai kalumiltjamiltjarinani, nunkani ngantjana pirnandru, minalinunkanali Nulia ngaianana ngantjana wonti,   
\p
\v 5 Ngaianana, ngaiana dankaranali matja nari, Christungu jela tepi ngankana wonti. (Manjulali jura tepi pantjina warai),   
\p
\v 6 Ja Nulia ngaianana nunkangu jela jiritjibana wonti ja jela pariwilpani kurana wonti Jesungu Christungu,   
\p
\v 7 Nulia miljarani, nau wokarai, nunkanaia manjulaia poto pirna manamiri ngaianangu wondrananto maltieli Jesungu Christungu.   
\p
\v 8 Manjulali jura tepi pantjina warai morlalu ngundranali, ja jenia wata jurangundru, a‐ai, Godaia jinkini poto nauja nganai,   
\p
\v 9 Wata ngankanandru, ngangau wata kulno jurakokaterinanto.   
\p
\v 10 Ngangau ngankani nunkani ngaiana nganai, Nulia ngaianana pantjimana wonti Christungu Jesungu ngankana ngumuja, tanana Godali ngopera ngankingana wonti, ngaiana tanangu wirarinanto.   
\p
\v 11 Jendrangundruja mangatandra wilparianau, jura warula kana ko palkujeli nganana wonti, ja karuwalila, marali matja pantjina, jurana karuwalila pani dikana wonti,   
\p
\v 12 Jura jendranguka miljarani Christus pani nganana wonti, Israelalani nguralani worita ja talpadakanaia Testamenlani tula, kalkani pani ja Goda pani mitani ngamana wonti.   
\p
\v 13 Karari jura, warula matja worita nganana, Christungu Jesungu karakara wokarana warai Christuni kumarali.   
\p
\v 14 Ngangau Nauja murla ngaianani nganai, Nulia wulana kulnuni ngankana wonti, ja wondiri terti wokaribana wonti,   
\p
\v 15 Ngangau Nulia nunkani palkujeli talpala walto ngankana wonti, jenia nganai jirijiribani jaura, Nulia wulangundru kana marra kulno nunkangu pantjimananto, ja murla ngankananto;   
\p
\v 16 Ja Nulia wulana murlali ngankananto Godangu palku kulnujeli kunarkujeli, ja talpala nari ngankana wonti nunkangu;   
\p
\v 17 Ja Nauja wokarana wonti ja murla kaukaubana wonti, jurangu worita ja murla tanangu karakara;   
\p
\v 18 Ngangau nunkangundru ngaiana mana walto ngamalkai Ngaperaia Jaola kulnuni.   
\lit (Dakani janra Philippuni ja Jakobuni ditjini.)  
\p
\v 19 Jeruja jura wata morla tula ja ngandrani nganai, a‐ai, kulikiria jelangurala ja Godaia pungala,   
\p
\v 20 Matja wotina Apostelaia ja Prophetaia wondirani, nunkani marda kapara Jesus Christus munta nganai,   
\p
\v 21 Nunkangupini wotini pratjana matja ngokana, ja punkai Godaia punga kulnuja, nauja kulikiri nganai, Kaparani,   
\p
\v 22 Nunkangu Nulia bakana jurana wotina ngokai Godaia pungaia Jaolani.   
\b  
\c 3  
\p
\v 1 Jendrangundruja ngato Paululu Jesuni Christuni kanjangarila nganai, jurangu kana koni.   
\p
\v 2 Jura matja ngaranani Godaia manjulaia ngamalkijiribanandru, ninaia Nulia ngakangu jinkina wonti jurangu.   
\p
\v 3 Worderu Nulia ngakangu ngaramarlali tinkari ngankana wonti kurukurula, worderu ngato ngopera ngalje dakana warai;   
\p
\v 4 Jura jenia warapanani, jura ngujamananto ngakani ngujamana Christuni kurukurulani.   
\p
\v 5 Ninaia Nulia kanaia witta pilkini wata tinkari ngankana wonti kanaia ngatamura worangu, worderu Nulia ninaia karari tinkari ngankana warai nunkani Apostel ja Propheta kulikirini Jaolali:   
\p
\v 6 Kana ko jelamaratunkaia maninietja nganai, ja palku kulnurina ja talpadakanaia jelali maninietja Christungu Jesungu ngantjani jaurali.   
\p
\v 7 Nunkanipini mili ngani pantjina wonti Godaia manjulaia jinkini potundru, ninaia Nulia ngakangu jinkina wonti nunkanaia ngurulaia ngankanandru.   
\p
\v 8 Ngakangu, ngani morla waka nganai kulikiri pratjanani, Nulia ninapini manjula jinkina wonti, kana koni Christuni poto pirna manamiri kaukaubala;   
\p
\v 9 Warupoto tjenmara ngankala, mina kurukurulaia ngamalkijiribani nganai, nauja kurukuru nganana wonti nguralindru nunkangupini Godani, Nulia warupoto pantjimana wonti Jesu Christujeli.   
\p
\v 10 Ngangau karari kaparali ja ngurulali pariwilpaia ngalpani ngujamananto mili wolarali Godaia kirila pilki ja pilki,   
\p
\v 11 Worderu Nulia ngurali jertapaterina wonti, ninaia Nulia kantji ngankana wonti Christungu Jesungu ngaianani Kaparani;   
\p
\v 12 Nunkangupini ngaiana mankina ngamalkai, ja mana walto murlali morlalu ngundranali nunkangu.   
\lit (Dakani jaura G. D. 16 Trinitatis.)  
\p
\v 13 Jendrangundruja ngani ngatjiai, ngani wata walturinanto ketjaketjanani ngakanani jurangu, ngangau jenia jurangu pirnala nganai.   
\p
\v 14 Jendrangundruja ngani pantja ngakani ngarila wapaia ngaiananaia Kaparaia Jesuni Christuni Ngaperani,   
\p
\v 15 Nunkangundru warupoto, mina ngaperi ngamalkai pariwilpani ja mitani tala ngamalkai,   
\p
\v 16 Nulia jurangu nunkani pirnalaia poto pirnandru jinkinanto ngurulani ngurunguru pantjila Jaolali nunkanali kanani mandrani,   
\p
\v 17 Christus morlalu ngundranali jurangu ngarani ngamananto, jura ngantjanani kapararinanto ja ngurungururinanto,   
\p
\v 18 Jura kulikiri pratjaterinani jela ngurunguru pantjinanto patala, mina maru ja wirdi ja mikari ja miri nganai,   
\p
\v 19 Ngujamala Christuni ngantjana, nauja morla pirna nganai ngujamanani warupotuni, jura Godaia manamirieli pratjanali manamiri pantjinanto.   
\p
\v 20 Ja nunkangu, Nauja ngurunguru nganai morla pirna ngankala warupotuni, mina ngaiana ngatjiai kara ngundrai kara nunkangupini ngurujeli, nunkanali Nulia ngaianangu ngankai.   
\p
\v 21 Nunkangu pirnala nganaiatimai mili wolarani Christungu Jesungu nguja warupotuja nguralindru nguralia! Amen.  
\b  
\c 4  
\lit (Dakani jaura G. D. 17 Trinitatis.)  
\p
\v 1 Ngato kanjangarilali Kaparani, jurana kurukurubala wapaia, jura talku wirarinanto jurani karkanani, minalinunkanali Nulia jurana matja karkana,   
\p
\v 2 Waka ngundraterinali ja malti pratjanali, ja manjujeli jura mandramalinanto ngantjanani.   
\p
\v 3 Ja jigleri ngananau Jaolaia kulnuni ngamalkala murlaia karanali.   
\p
\v 4 Palku kulno ja Jaola kulno, worderu Nulia jurana bakana karkana wonti jurani karkanaia kalkani kulnuja;   
\p
\v 5 Kapara kulno, morlalu ngundrana kulno, multibanila kulno;   
\p
\v 6 Goda kulno ja Ngaperi warupotuja, Nauja warupotuni miri ja warupotuni jela ja warupotuni nganai.  
\b  
\p
\v 7 Pratjanani ngaianangu Nulia jinkina wonti manjula, worderu Christuni jinkini kurana wonti.   
\p
\v 8 Jendrangundruja Nauja jatai: „Nauja miri tarana wonti ja kanjangarila dupudupu wapalkana wonti ja kanani poto jinkina wonti.“   
\p
\v 9 Jenia: „Nauja tarana wonti“ wondrai, Nauja bakana ngarina wonti mita pirini ngarinalu.   
\p
\v 10 Nauja matja ngarina Naupini nganai, Nauja bakana tarana wonti morla miri pariwilpa pratjanani, Nulia warupoto manamiri ngankananto.   
\p
\v 11 Ja Nulia muntali jinkina wonti palpa Apostel, palpa Propheta, palpa ngantjani jaura kaukaubanietja, palpa ngamalkanietja, palpa ngujangujara jinkinietja nganala,   
\p
\v 12 Kana kulikiri ngankingala ngankani ngamalkijiribanaia, Christuni palkuni wotinaia.   
\p
\v 13 Ngaiana pratjana wokaranantulu morlalu ngundrana kulnuja ja Godaia Ngatamuraia ngujamanaia, ja materi pirnaia, ja Christuni manamirila pirnaia.   
\p
\v 14 Ngaiana wata morla kupa jeribaka nganananto, tanana ngujangujara watarali pratjanali wijawijabai ja tertabai kanaia jedibanali ja tjautjauja kirieli karkarkanaia.   
\p
\v 15 A‐ai, ngaiana morlalu nganananto ngantjanani ja poto warupotuni punkananto nunkangu, Nauja mangatandra nganai, Christus;   
\p
\v 16 Nunkangundru palku warupoto ngumu ngokana ja manduribana warai marangokijiribamalini pratjanali, worderu buru pilki ja pilkieli ngankai palku pirnarinanto nunkani wotinaia ngantjanali.   
\p
\v 17 Jenia ngani jatai, ja Kaparani morlalu kurai, jura wata morla wirarinanto kana koni jeribaka tanani tjuru tjautjauni;   
\p
\v 18 Tanani tjuru ngalpuru nganai, tana Godaia tepini worita nganai kondru, nauja tanangu parai, ja tanani ngara ngurungurundru.   
\p
\v 19 Tana burka pani pantjina wonti, ja tjikatjikani jinkiterina wonti murumuru pratjana ngankala ngukingukipaterinani.   
\p
\v 20 Jura wata jeruja Christus kiririna wonti.   
\p
\v 21 Jura nunkangundru matja ngarana ja nunkangundru matja ngujangujara manina, worderu morlalula Jesungu nganai.   
\lit (Dakani jaura G. D. 19 Trinitatis.)  
\p
\v 22 Jura dukaraterianau, worderu jura warula wirarina wonti, kana womala, nauja jedibanaia milkirinali munta taripateriai;   
\p
\v 23 Ja marraribaterianau Jaolali jurani tjuru,   
\p
\v 24 Ja kana marra widmaterianau, ninaia Godali nunkangu jeribaka pantjimana wonti talkuni ja kulikirini morlalulaia.   
\p
\v 25 Jendrangundruja jedi jaura woranau, ja jaura morlalu jinkimalianimai pratjanani ngurulani, ngangau ngaiana pratjaterina palku buru nganai.   
\p
\v 26 Wata kuterianau, ja wata madlentji ngankanau; jura wata kuterinanto ditji wirinantulu.   
\p
\v 27 Bakana wata piri jinkianau kutjini.   
\p
\v 28 Warle ngopera kurieli maninala, wata morla kurieli maninanto, a‐ai, nulu marali nunkanali ngumu ngankananto, nulu muntali ngamalkananto wangiwangini jinkila.  
\b  
\p
\v 29 Jaura tunka wata jurani manandru dunkananto, a‐ai, windri wotinaia mina ngumu nganai, nulu manjula jinkinanto ngaranietja worangu.   
\p
\v 30 Ja wata Jaola kulikiri ngaurongauro ngankanau, nunkanali jura matja dantjamana kulkani ditjia.   
\p
\v 31 Kaldri, ja tirijiritjina, ja tiri, ja maritjina, ja ngirkibana pratjana jurangundru woranau madlentji pratjanani jela.   
\p
\v 32 Murlali ngamangamaranau, kalumiltjamiltjarilkijiribamalianimai, madlentji worijiribamalianimai, worderu bakana Godali jurangu Christungu kalingana wonti.   
\c 5  
\lit (Dakani jaura G. D. Oculi.)  
\p
\v 1 Jeruja Godangu karipaterini pantjianau kupa ngantjalu jeribaka.   
\p
\v 2 Ja ngantjanani wirarianau, worderu bakana Christulu jurana ngantjana wonti, ja munta jinkiterina wonti ngaianangundru jinkiterini poto ja poto ngumu Godani kuli ngumuja.   
\p
\v 3 Palakantji ja murumuru pratjana ja ngukingukibaterina jurangu wata talarinanto, worderu jenia kana kulikirini talku nganai.   
\p
\v 4 Jeruja bakana wata ninta pani ja jildini ja kangirini, jenia wata ngumu nganai, a ai, morla ngumu jurakokana.   
\p
\v 5 Ngangau jenia jura milkila, palakantjieli kara, murumurujeli kara ngukingukibaterinietjali kara, nau muramurani wodatarana ngamai, wata maratunka ngamalkai Christuja ja Godaia mililani.   
\p
\v 6 Wata kulnujeli jurana jedibananto jaura bakujeli; ngangau jendrangundruja Godaia tirila delkinietjaia ngatamurani wokarai.   
\p
\v 7 Wata tanani kamaneli pantjianau!   
\p
\v 8 Jura warula ngalpuru nganana wonti, ja karari jura praitji nganai Kaparani.   
\p
\v 9 Praitjaia kupa wirarianau! Ngangau praitjaia tandra ngumu pilkipilki ja talku ja morlalu nganai.   
\b  
\p
\v 10 Ja wontjanau mina Kaparali ngantjai.   
\p
\v 11 Ja wata jelarianau ngalpuraia ngankanani, tanali tandra pani mandrai, a‐ai, tanangu kalakalarianau!   
\p
\v 12 Ngangau mina tanali kurukuru ngankai, jenia bakana ninta nganai jatala.   
\p
\v 13 Jenia pratjana, minani dikidikibani parai, praitjali tinkari ngankai; ngangau pratjana, mina tinkari nganai, praitji nganai.   
\p
\v 14 Jendrangundruja dakanala parai: „Tepiriau jidni mukaetja, ja narindru jiritjiau, jeruja Christus jinkangu mintjila nganai.“   
\lit (Dakani jaura G. D. 20 Trinitatis.)  
\p
\v 15 Jeruja najianau, worderu jura talku wirarinanto, wata kana patipatini, a‐ai, kana kirini jeribaka.   
\p
\v 16 Ja ditjini juranani jigleri ngananau, ngangau ditji madlentji nganai.   
\p
\v 17 Jendrangundruja wata ko, a‐ai, kiri pantjianau, mina Kaparaia jertapaterina nganai.   
\p
\v 18 Ja wata wainali parawaranau, jura tjikatjika pantjiati, a‐ai, manamiri pantjianau Jaolali.   
\p
\v 19 Ja ngankamalianau psalmali ja jurakokani wimali ja Jaolaia wimali, ja wonkanau ja jadijadibanau Kaparani jurani ngarani;   
\p
\v 20 Ja milingeru jurakokanau warupotundru Goda ja Ngaperi, ngaiananaia Kaparaia Jesuni Christuni talani.   
\p
\v 21 Ja wodatarana ngamalkijiribamalianimai Christungundru japali.   
\b  
\p
\v 22 Jura widla, jurani materani wodatarana ngamanau Kaparani jeribaka.   
\p
\v 23 Ngangau materi widlaia mangatandra nganai, worderu bakana Christus mili woloraia mangatandra nganai, ja Nauja palkuja Kulkanipirna nganai.   
\p
\v 24 Worderu mili wolara Christungu wodatarana ngamai, jeruja bakana widla tanani materani, warupotuni.   
\p
\v 25 Jura materi, jurani widla ngantjanau, worderu bakana Christulu mili wolara ngantjana wonti ja munta tanangu jinkiterina wonti.   
\p
\v 26 Nulia tanana kulikiri ngankananto, Nulia tanana matja kulirkana warai multibani ngapali jaurani.   
\p
\v 27 Nulia nunkangu munta mili wolara ngumu terkibananto murumuru pani ja karpakarpa pani, ja jenipara pilki kara pani, a‐ai, tana kulikiri ja madlentji pani ngamananto.   
\p
\v 28 Jeruja bakana materi wilpa nganai tanani widla ngantjala, tanani palku munta jeribaka. Warle widla nunkani ngantjai, nau munta ngantjateriai.   
\p
\v 29 Wata kulnujeli pota kulno nunkani palkuni kalakalarina wonti, a‐ai, nulu nunkangu buka jinkiai ja ngumu ngamalkai, worderu bakana Christulu mili wolara,   
\p
\v 30 Ngangau ngaiana nunkanaia palkuja buru nganai, nunkani palkundru ja nunkani mokundru.   
\p
\v 31 Jendrangundruja kana kulnujeli ngaperi nunkani ja ngandri nunkani worarala nganai ja widlani nunkanani ngokala nganai, ja pudla palku kulno nganala nganai.   
\p
\v 32 Naupini kurukurula pirna nganai; ngani jenia jatai Christungundru ja mili wolarandru.   
\p
\v 33 Bakana jura pratjana pilki ja pilkieli, widla nunkani jeruja ngantjananto munta jeribaka. Widla materandru japali nganananto.   
\c 6  
\p
\v 1 Jura kupa worajai, jurani ngaperani ja ngandrini pankianau Kaparani; ngangau jenia talku nganai.   
\p
\v 2 Ngaperi jinkani ja ngandri jinkani pirna ngundramai, nauja jirijiribani jaura ngopera nganai talpadakani jaurali:   
\p
\v 3 Jidni tepi ngumu ngamananto, ja jidni juri mitani ngamananto.   
\p
\v 4 Ja jura ngaperi worajai, jurani kupa wata dilpanau tiria, a‐ai, tanana kiri ngankanali ja Kaparaia kurukurubanali pirna ngankanau.   
\p
\v 5 Jura mili worajai, palkuja kaparani juranani pankianau japali ja ngaranali juranaia ngaraia kulnongundranali Christungu jeribaka,   
\p
\v 6 Wata windri milkini ngankanau kana murlali ngankala jeribaka, a‐ai, Christuni milieli jeribaka Godaia jertapaterina ngankanau ngarali,   
\p
\v 7 Ja manjujeli mili ngananau Kaparani jeribaka, ja wata kanani,   
\p
\v 8 Ngangau jura milkila, minakulno kulnujeli ngumu ngankanani kara, nulu ninaia nakaldra manila nganai Kaparandru, nau mili nganai kara kurakanila kara.   
\p
\v 9 Ja jura kapara worajai, jenia bakana jura tanangu ngankanau, ja dikidikibani jaura woraranau, ngangau jura milkila, jurani ja tanani Kapara pariwilpani nganai, ja Nulia wata kana mudla ngundrai.   
\lit (Dakani jaura G. D. 21 Trinitatis.)  
\p
\v 10 Ngatata ngakani worajai, ngurungururianau Kaparani ja ngurulani nunkanani.   
\p
\v 11 Godaia tirimalini poto widmaterianau, jura tataura terkananto kutjia tampanani;   
\p
\v 12 Ngangau ngaiana wata windri palkuni ja kumarani tirimalinanto, a‐ai, kaparani ja ngurulani, nunkangupini ngalpuraia mita kaparani, tjikatjikaia kutji worani ngaranani.   
\p
\v 13 Jendrangundruja Godaia tirimalini poto patanau, jura ditjini madlentjani ngurunguru terkananto, ja pratjana kalalu ngankananto ja terkananto.   
\p
\v 14 Jeruja terkanau, jurani kapa matja ngampina morlalulali, ja matja widmaterina talkulaia marda katieli,   
\p
\v 15 Ja tidnani tidnaputa murlaia ngantjani jaurali matja ngankingana,   
\p
\v 16 Tanangu marapuni morlalu ngundranaia piramara patanau, nunkanali jura ngurunguru nganananto kutjia turukalti palimala,   
\p
\v 17 Ja tepia kapuluru patanau, ja Jaolaia mardakirra, naupini Godaia jaura nganai.  
\b  
\p
\v 18 Ja milingeru ngatjianau warupotuja ngatjinali ja karkanali Jaolani, ja tepi ngamanau wonki pirnali ja ngatjinali kana kulikirini pratjanandru.   
\p
\v 19 Ja ngakangundru, Nulia ngakangu jaura jinkinanto ngani mana piririnani manubakujeli kaukaubala ngantjani jauraia kurukurula,   
\p
\v 20 Nunkanipini mandra ngani nganai kanjangarini, ngato nunkangu manubakujeli kaukaubananto, worderu ngani jatananto.   
\p
\v 21 Jura ngujamananto, worderu ngani ngamala wapaia, ja mina ngato ngankala wapaia, jenia pratjana jurangu Tychikulu kaukaubala nganai, nauja ngatata ngantjalu ja mili talku nganai Kaparani.   
\p
\v 22 Ninaia ngato jendrania jurangu jinpana warai, jura ngujamananto worderu ngaiani ngamai, ja nulia jurana ngara ngankalkananto.   
\p
\v 23 Murla ngatata worani ja ngantjana morlalu ngundranali Goda Ngaperandru ja Kapara Jesu Christungundru.   
\p
\v 24 Manjula tanangu pratjanani nganaiatimai, tanali Kapara ngaianani Jesus Christus ngurali ngantjai! Amen.   