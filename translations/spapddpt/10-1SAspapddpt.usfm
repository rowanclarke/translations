\v 51 \w Entonces|strong="H3588"\w* \w David|strong="H1732"\w* \w corrió|strong="H7323"\w*, se \w puso|strong="H5975"\w* \w en|strong="H3588"\w* \w pie|strong="H5975"\w* sobre \w el|strong="H3588"\w* \w filisteo|strong="H6430"\w*, \w tomó|strong="H3947"\w* \w la|strong="H3588"\w* \w espada|strong="H2719"\w* \w de|strong="H3588"\w* \w éste|strong="H5975"\w*, \w la|strong="H3588"\w* \w sacó|strong="H8025"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* vaina \w y|strong="H3588"\w* lo remató. \w Con|strong="H3588"\w* ella le \w cortó|strong="H3772"\w* \w la|strong="H3588"\w* \w cabeza|strong="H7218"\w*.
\p \w Los|strong="H3588"\w* \w filisteos|strong="H6430"\w*, al \w ver|strong="H7200"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w caudillo|strong="H7218"\w* \w muerto|strong="H4191"\w*, \w huyeron|strong="H5127"\w*.
\v 52 Entonces \w los|strong="H7291"\w* hombres \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* \w y|strong="H5704"\w* \w de|strong="H5704"\w* \w Judá|strong="H3063"\w* se \w levantaron|strong="H6965"\w*, gritaron \w y|strong="H5704"\w* \w persiguieron|strong="H7291"\w* \w a|strong="H3068"\w* \w los|strong="H7291"\w* \w filisteos|strong="H6430"\w* \w hasta|strong="H5704"\w* llegar \w al|strong="H5704"\w* \w valle|strong="H1516"\w* \w y|strong="H5704"\w* las \w puertas|strong="H8179"\w* \w de|strong="H5704"\w* \w Ecrón|strong="H6138"\w*. \w Los|strong="H7291"\w* \w muertos|strong="H2491"\w* \w de|strong="H5704"\w* entre \w los|strong="H7291"\w* \w filisteos|strong="H6430"\w* estaban \w tendidos|strong="H5307"\w* \w por|strong="H1870"\w* \w el|strong="H5307"\w* \w camino|strong="H1870"\w* \w de|strong="H5704"\w* Saraim, \w hasta|strong="H5704"\w* Gat \w y|strong="H5704"\w* \w Ecrón|strong="H6138"\w*.
\v 53 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* se \w volvieron|strong="H7725"\w* \w de|strong="H1121"\w* perseguir \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* y saquearon su \w campamento|strong="H4264"\w*.
\p 
\v 54 \w David|strong="H1732"\w* \w tomó|strong="H3947"\w* la \w cabeza|strong="H7218"\w* del \w filisteo|strong="H6430"\w* y la \w llevó|strong="H3947"\w* \w a|strong="H3068"\w* Jerusalén, pero las \w armas|strong="H3627"\w* de él las \w puso|strong="H7760"\w* en su tienda.
\p 
\v 55 Cuando \w Saúl|strong="H7586"\w* \w vio|strong="H7200"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w que|strong="H4310"\w* \w salía|strong="H3318"\w* \w a|strong="H3068"\w* encontrarse con \w el|strong="H4310"\w* \w filisteo|strong="H6430"\w*, preguntó \w a|strong="H3068"\w* Abner, \w jefe|strong="H8269"\w* del \w ejército|strong="H6635"\w*: Abner, ¿\w de|strong="H1121"\w* \w quién|strong="H4310"\w* \w es|strong="H2088"\w* \w hijo|strong="H1121"\w* \w ese|strong="H2088"\w* \w muchacho|strong="H5288"\w*?
\p \w Y|strong="H3068"\w* Abner respondió:
\v 56 ¡Vive tu alma, \w oh|strong="H4310"\w* \w rey|strong="H4428"\w*, no sé! \w Y|strong="H3068"\w* \w el|strong="H4310"\w* \w rey|strong="H4428"\w* dijo: Averigua tú \w de|strong="H1121"\w* \w quién|strong="H4310"\w* \w es|strong="H2088"\w* \w hijo|strong="H1121"\w* \w ese|strong="H2088"\w* muchacho.
\p 
\v 57 Al \w volver|strong="H7725"\w* \w David|strong="H1732"\w* \w de|strong="H6440"\w* matar al \w filisteo|strong="H6430"\w*, Abner lo \w tomó|strong="H3947"\w* y lo \w llevó|strong="H3947"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Saúl|strong="H7586"\w*, con la \w cabeza|strong="H7218"\w* del \w filisteo|strong="H6430"\w* \w en|strong="H5221"\w* su \w mano|strong="H3027"\w*.
\p 
\v 58 \w Saúl|strong="H7586"\w* \w le|strong="H4310"\w* preguntó: Joven, ¿\w de|strong="H1121"\w* \w quién|strong="H4310"\w* eres \w hijo|strong="H1121"\w*?
\p \w Y|strong="H3068"\w* \w David|strong="H1732"\w* respondió: Soy \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* tu esclavo \w Isaí|strong="H3448"\w* \w de|strong="H1121"\w* Belén.
\c 18
\s1 Jonatán, David y Saúl
\p 
\v 1 \w Cuando|strong="H1961"\w* \w acabó|strong="H3615"\w* de \w hablar|strong="H1696"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*, \w aconteció|strong="H1961"\w* \w que|strong="H1961"\w* el \w alma|strong="H5315"\w* de Jonatán \w quedó|strong="H1961"\w* ligada al \w alma|strong="H5315"\w* de \w David|strong="H1732"\w*, y Jonatán lo amó \w como|strong="H1961"\w* \w a|strong="H3068"\w* él mismo.
\v 2 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w Saúl|strong="H7586"\w* \w lo|strong="H1931"\w* retuvo y \w no|strong="H3808"\w* \w lo|strong="H1931"\w* \w dejó|strong="H5414"\w* \w volver|strong="H7725"\w* \w a|strong="H3068"\w* \w casa|strong="H1004"\w* \w de|strong="H5414"\w* \w su|strong="H1931"\w* padre.
\v 3 Jonatán \w hizo|strong="H3772"\w* un \w pacto|strong="H1285"\w* con \w David|strong="H1732"\w* \w porque|strong="H1732"\w* lo amaba como \w a|strong="H3068"\w* él mismo.
\v 4 Jonatán \w se|strong="H5921"\w* quitó \w la|strong="H5921"\w* ropa \w que|strong="H5921"\w* llevaba \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w la|strong="H5921"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w junto|strong="H5921"\w* \w con|strong="H5921"\w* otras \w ropas|strong="H4055"\w* suyas, incluso su \w espada|strong="H2719"\w*, su \w arco|strong="H7198"\w* \w y|strong="H5921"\w* su cinturón.
\p 
\v 5 \w David|strong="H1732"\w* \w salía|strong="H3318"\w* adondequiera \w que|strong="H5921"\w* \w Saúl|strong="H7586"\w* \w lo|strong="H5921"\w* \w enviaba|strong="H7971"\w*, \w y|strong="H1571"\w* \w se|strong="H5921"\w* portaba \w con|strong="H5921"\w* prudencia. \w Saúl|strong="H7586"\w* \w lo|strong="H5921"\w* ascendió \w al|strong="H5921"\w* \w mando|strong="H7971"\w* \w de|strong="H5921"\w* \w gente|strong="H5971"\w* \w de|strong="H5921"\w* \w guerra|strong="H4421"\w*. \w Fue|strong="H1571"\w* acepto \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w ojos|strong="H5869"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w y|strong="H1571"\w* ante \w los|strong="H5921"\w* \w ojos|strong="H5869"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* esclavos \w de|strong="H5921"\w* \w Saúl|strong="H7586"\w*.
\p 
\v 6 Pero \w sucedió|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* \w ellos|strong="H3605"\w* regresaban, \w al|strong="H4428"\w* \w volver|strong="H7725"\w* \w David|strong="H1732"\w* de \w la|strong="H3605"\w* matanza de \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w*, las mujeres de \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* de \w Israel|strong="H3478"\w* \w salían|strong="H3318"\w* con cantos y danzas \w a|strong="H3068"\w* recibir \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w Saúl|strong="H7586"\w* con cánticos de júbilo, panderos \w e|strong="H3068"\w* instrumentos musicales.
\p 
\v 7 \w Y|strong="H3068"\w* mientras danzaban, las mujeres cantaban y decían:
\q1 \w Saúl|strong="H7586"\w* \w mató|strong="H5221"\w* \w a|strong="H3068"\w* sus miles,
\q1 \w Y|strong="H3068"\w* \w David|strong="H1732"\w* \w a|strong="H3068"\w* sus diez miles.
\p 
\v 8 \w Saúl|strong="H7586"\w* se enojó muchísimo, \w pues|strong="H2088"\w* \w ese|strong="H2088"\w* \w dicho|strong="H1697"\w* \w le|strong="H5869"\w* \w pareció|strong="H7489"\w* malo, y dijo: \w A|strong="H3068"\w* \w David|strong="H1732"\w* \w le|strong="H5869"\w* \w dan|strong="H5414"\w* diez miles y \w a|strong="H3068"\w* mí me \w dan|strong="H5414"\w* miles. ¿\w Qué|strong="H1697"\w* \w más|strong="H5750"\w* puede tener sino el \w reino|strong="H4410"\w*?
\v 9 Desde \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w Saúl|strong="H7586"\w* \w no|strong="H1961"\w* miró con buenos ojos \w a|strong="H3068"\w* \w David|strong="H1732"\w*.
\p 
\v 10 Al \w día|strong="H3117"\w* \w siguiente|strong="H4283"\w*, \w aconteció|strong="H1961"\w* \w que|strong="H3117"\w* un \w espíritu|strong="H7307"\w* \w malo|strong="H7451"\w* \w de|strong="H7451"\w* parte \w de|strong="H7451"\w* \nd ʼElohim\nd* \w se|strong="H1961"\w* apoderó \w de|strong="H7451"\w* \w Saúl|strong="H7586"\w*, quien deliraba furioso \w en|strong="H8432"\w* su \w casa|strong="H1004"\w*. \w David|strong="H1732"\w* \w tañía|strong="H5059"\w* con su \w mano|strong="H3027"\w*, \w como|strong="H1961"\w* otras \w veces|strong="H3027"\w*, y \w Saúl|strong="H7586"\w* \w tenía|strong="H1961"\w* su \w lanza|strong="H2595"\w* \w en|strong="H8432"\w* su \w mano|strong="H3027"\w*.
\v 11 \w Saúl|strong="H7586"\w* tiró la \w lanza|strong="H2595"\w* mientras se decía: ¡Clavaré \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w contra|strong="H6440"\w* la \w pared|strong="H7023"\w*! Pero \w David|strong="H1732"\w* la esquivó \w dos|strong="H6471"\w* \w veces|strong="H6471"\w*.
\p 
\v 12 \w Saúl|strong="H7586"\w* \w tuvo|strong="H1961"\w* \w temor|strong="H3372"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w estaba|strong="H1961"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w*. \add David\add* \w se|strong="H1961"\w* apartó \w de|strong="H3588"\w* \w Saúl|strong="H7586"\w*.
\v 13 \w Por|strong="H6440"\w* tanto \w Saúl|strong="H7586"\w* lo apartó \w de|strong="H6440"\w* \w él|strong="H5973"\w* y lo designó \w jefe|strong="H8269"\w* \w de|strong="H6440"\w* 1.000 hombres. \w Él|strong="H5973"\w* \w salía|strong="H3318"\w* y entraba al frente \w de|strong="H6440"\w* la tropa.
\v 14 \w En|strong="H5973"\w* \w todos|strong="H3605"\w* sus asuntos \w David|strong="H1732"\w* \w se|strong="H1961"\w* conducía \w con|strong="H5973"\w* prudencia, y \nd \w Yavé|strong="H3068"\w*\nd* \w estaba|strong="H1961"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w*.
\v 15 Al \w ver|strong="H7200"\w* \w Saúl|strong="H7586"\w* \w que|strong="H1931"\w* \w él|strong="H1931"\w* procedía con tanta prudencia, \w tenía|strong="H1931"\w* temor \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H1931"\w*.
\v 16 \w Pero|strong="H3588"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w Judá|strong="H3063"\w* amaban \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w porque|strong="H3588"\w* \w él|strong="H1931"\w* \w salía|strong="H3318"\w* \w y|strong="H3588"\w* entraba al frente \w de|strong="H3588"\w* \w ellos|strong="H1931"\w*.
\p 
\v 17 \w Saúl|strong="H7586"\w* dijo \w a|strong="H3068"\w* \w David|strong="H1732"\w*: Ahí \w está|strong="H1961"\w* \w Merab|strong="H4764"\w*, \w mi|strong="H2009"\w* \w hija|strong="H1323"\w* \w mayor|strong="H1419"\w*. \w A|strong="H3068"\w* ella te la \w daré|strong="H5414"\w* \w como|strong="H1961"\w* esposa, con tal \w que|strong="H1121"\w* me \w seas|strong="H1961"\w* un guerrero \w valiente|strong="H2428"\w* y pelees las \w batallas|strong="H4421"\w* \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w Porque|strong="H1732"\w* \w Saúl|strong="H7586"\w* \w se|strong="H1961"\w* decía: \w Que|strong="H1121"\w* \w mi|strong="H2009"\w* \w mano|strong="H3027"\w* \w no|strong="H1961"\w* \w se|strong="H1961"\w* levante \w contra|strong="H1961"\w* \w él|strong="H1121"\w*, sino \w que|strong="H1121"\w* la \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w se|strong="H1961"\w* levante \w contra|strong="H1961"\w* \w él|strong="H1121"\w*.
\p 
\v 18 Respondió \w David|strong="H1732"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*: ¿\w Quién|strong="H4310"\w* \w soy|strong="H1961"\w* \w yo|strong="H3588"\w*? ¿\w Qué|strong="H3588"\w* \w es|strong="H1961"\w* \w mi|strong="H1961"\w* \w vida|strong="H2416"\w*, \w o|strong="H3068"\w* \w la|strong="H3588"\w* \w familia|strong="H4940"\w* \w de|strong="H3588"\w* \w mi|strong="H1961"\w* padre \w en|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* \w sea|strong="H1961"\w* \w yerno|strong="H2860"\w* del \w rey|strong="H4428"\w*?
\v 19 Pero \w sucedió|strong="H1961"\w* \w que|strong="H1931"\w* \w al|strong="H6256"\w* llegar \w el|strong="H1931"\w* momento \w de|strong="H5414"\w* entregar \w a|strong="H3068"\w* \w Merab|strong="H4764"\w*, \w hija|strong="H1323"\w* \w de|strong="H5414"\w* \w Saúl|strong="H7586"\w*, \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w ella|strong="H1931"\w* \w fue|strong="H1961"\w* \w entregada|strong="H5414"\w* \w como|strong="H1961"\w* esposa \w a|strong="H3068"\w* Adriel \w meholatita|strong="H4259"\w*.
\p 
\v 20 Mical, \w hija|strong="H1323"\w* \w de|strong="H1697"\w* \w Saúl|strong="H7586"\w*, amaba \w a|strong="H3068"\w* \w David|strong="H1732"\w*. Se \w lo|strong="H1697"\w* informaron \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*, y \w le|strong="H5869"\w* \w pareció|strong="H3474"\w* \w bien|strong="H5869"\w* el \w asunto|strong="H1697"\w*.
\v 21 \w Saúl|strong="H7586"\w* \w se|strong="H1961"\w* dijo: \w Se|strong="H1961"\w* la \w daré|strong="H5414"\w*, \w para|strong="H5414"\w* \w que|strong="H3117"\w* ella le sirva \w de|strong="H5414"\w* trampa, y la \w mano|strong="H3027"\w* \w de|strong="H5414"\w* \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w* \w se|strong="H1961"\w* levante \w contra|strong="H1961"\w* él. \w Y|strong="H3068"\w* \w Saúl|strong="H7586"\w* dijo \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w por|strong="H3027"\w* segunda vez: \w Hoy|strong="H3117"\w* \w serás|strong="H1961"\w* \w mi|strong="H1961"\w* yerno.
\p 
\v 22 \w Saúl|strong="H7586"\w* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* sus esclavos: \w Hablen|strong="H1696"\w* en secreto \w a|strong="H3068"\w* \w David|strong="H1732"\w*, y díganle: \w Mira|strong="H2009"\w*, \w el|strong="H3605"\w* \w rey|strong="H4428"\w* se complace en ti, y \w todos|strong="H3605"\w* sus esclavos te aman. ¡Sé, \w pues|strong="H6258"\w*, yerno del \w rey|strong="H4428"\w*!
\p 
\v 23 Los esclavos \w de|strong="H1697"\w* \w Saúl|strong="H7586"\w* \w hablaron|strong="H1696"\w* estas \w palabras|strong="H1697"\w* \w a|strong="H3068"\w* oídos \w de|strong="H1697"\w* \w David|strong="H1732"\w*. \w Y|strong="H3068"\w* \w David|strong="H1732"\w* respondió: ¿Les parece \w a|strong="H3068"\w* ustedes \w cosa|strong="H1697"\w* sencilla ser yerno del \w rey|strong="H4428"\w*? Yo soy un hombre \w pobre|strong="H7326"\w* y \w de|strong="H1697"\w* baja estima.
\p 
\v 24 Sus esclavos le informaron eso \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* y le \w dijeron|strong="H1697"\w*: \w David|strong="H1732"\w* \w habló|strong="H1696"\w* estas \w palabras|strong="H1697"\w*.
\v 25 \w Y|strong="H3068"\w* \w Saúl|strong="H7586"\w* contestó: Digan \w esto|strong="H3541"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*: \w El|strong="H3588"\w* \w rey|strong="H4428"\w* \w no|strong="H3588"\w* desea alguna dote, \w sino|strong="H3588"\w* 100 \w prepucios|strong="H6190"\w* \w de|strong="H3588"\w* \w filisteos|strong="H6430"\w*, \w para|strong="H3588"\w* vengarse \w de|strong="H3588"\w* \w los|strong="H3588"\w* enemigos del \w rey|strong="H4428"\w*. \w Pero|strong="H3588"\w* \w Saúl|strong="H7586"\w* deseaba \w que|strong="H3588"\w* \w David|strong="H1732"\w* cayera \w en|strong="H3588"\w* \w manos|strong="H3027"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w filisteos|strong="H6430"\w*.
\p 
\v 26 \w Cuando|strong="H3117"\w* sus esclavos \w dijeron|strong="H1697"\w* esas \w palabras|strong="H1697"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w agradó|strong="H3474"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* ser yerno del \w rey|strong="H4428"\w*. Antes \w que|strong="H3808"\w* el plazo \w se|strong="H3808"\w* cumpliera,
\v 27 \w David|strong="H1732"\w* \w se|strong="H1931"\w* \w levantó|strong="H6965"\w*, \w salió|strong="H3212"\w* con \w sus|strong="H1931"\w* hombres y \w mató|strong="H5221"\w* \w a|strong="H3068"\w* 200 varones \w de|strong="H5414"\w* \w los|strong="H1931"\w* \w filisteos|strong="H6430"\w*. \w Luego|strong="H1931"\w* \w David|strong="H1732"\w* llevó \w sus|strong="H1931"\w* \w prepucios|strong="H6190"\w* y \w los|strong="H1931"\w* \w entregó|strong="H5414"\w* todos \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w para|strong="H5414"\w* ser yerno del \w rey|strong="H4428"\w*. \w Y|strong="H3068"\w* \w Saúl|strong="H7586"\w* \w le|strong="H1931"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w hija|strong="H1323"\w* Mical \w como|strong="H1931"\w* esposa.
\p 
\v 28 Al \w ver|strong="H7200"\w* esto, \w Saúl|strong="H7586"\w* comprendió \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* estaba \w con|strong="H5973"\w* \w David|strong="H1732"\w*, \w y|strong="H3588"\w* Mical, \w hija|strong="H1323"\w* \w de|strong="H3588"\w* \w Saúl|strong="H7586"\w*, lo amaba.
\v 29 \w El|strong="H3605"\w* \w temor|strong="H3372"\w* \w de|strong="H6440"\w* \w Saúl|strong="H7586"\w* \w le|strong="H3254"\w* aumentó \w a|strong="H3068"\w* \w David|strong="H1732"\w*, y \w éste|strong="H1961"\w* \w fue|strong="H1961"\w* hostil \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w*.
\p 
\v 30 Entonces \w los|strong="H3605"\w* \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w* \w salían|strong="H3318"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* guerra. \w Sucedía|strong="H1961"\w* \w que|strong="H1961"\w* \w cada|strong="H3605"\w* vez \w que|strong="H1961"\w* \w salían|strong="H3318"\w*, \w David|strong="H1732"\w* actuaba \w en|strong="H3318"\w* las batallas mejor \w que|strong="H1961"\w* \w cualquiera|strong="H3605"\w* \w de|strong="H8269"\w* \w los|strong="H3605"\w* esclavos \w de|strong="H8269"\w* \w Saúl|strong="H7586"\w*, \w de|strong="H8269"\w* modo \w que|strong="H1961"\w* su \w nombre|strong="H8034"\w* adquirió mucha \w fama|strong="H8034"\w*.
\c 19
\s1 Atentado de Saúl contra David
\p 
\v 1 \w Saúl|strong="H7586"\w* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* Jonatán y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus esclavos \w que|strong="H1121"\w* \w mataran|strong="H4191"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*, pero Jonatán, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w*, \w amaba|strong="H2654"\w* \w mucho|strong="H3966"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*.
\v 2 Jonatán habló \w a|strong="H3068"\w* \w David|strong="H1732"\w*: \w Mi|strong="H4994"\w* padre \w Saúl|strong="H7586"\w* \w procura|strong="H1245"\w* \w matarte|strong="H4191"\w*. Te \w ruego|strong="H4994"\w* \w que|strong="H6258"\w* tengas cuidado por \w la|strong="H8104"\w* \w mañana|strong="H1242"\w*. \w Quédate|strong="H3427"\w* en un lugar secreto y escóndete.
\v 3 Yo \w saldré|strong="H3318"\w* del \w campo|strong="H7704"\w* \w donde|strong="H8033"\w* tú \w estés|strong="H5975"\w*. Me pondré \w junto|strong="H3027"\w* \w a|strong="H3068"\w* mi padre y le \w hablaré|strong="H1696"\w* de ti. \w Veré|strong="H7200"\w* \w qué|strong="H4100"\w* responde y te \w lo|strong="H4100"\w* informaré.
\p 
\v 4 Jonatán \w habló|strong="H1696"\w* \w bien|strong="H2896"\w* \w de|strong="H3588"\w* \w David|strong="H1732"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* padre \w Saúl|strong="H7586"\w*: \w No|strong="H3808"\w* \w peque|strong="H2398"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* contra \w su|strong="H3588"\w* esclavo \w David|strong="H1732"\w*, \w pues|strong="H3588"\w* \w él|strong="H3588"\w* \w no|strong="H3808"\w* \w pecó|strong="H2398"\w* contra ti. Sus \w obras|strong="H4639"\w* \w son|strong="H3588"\w* \w muy|strong="H3966"\w* \w buenas|strong="H2896"\w* \w para|strong="H3588"\w* ti,
\v 5 \w porque|strong="H4100"\w* \w él|strong="H3605"\w* \w puso|strong="H7760"\w* su \w vida|strong="H5315"\w* \w en|strong="H5221"\w* \w la|strong="H3605"\w* palma \w de|strong="H1818"\w* su \w mano|strong="H3709"\w* \w y|strong="H5355"\w* \w mató|strong="H5221"\w* al \w filisteo|strong="H6430"\w*. \w Y|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* otorgó una \w gran|strong="H1419"\w* victoria \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*. \w Tú|strong="H6213"\w* \w lo|strong="H4100"\w* \w viste|strong="H7200"\w* \w y|strong="H5355"\w* \w te|strong="H5315"\w* alegraste \w de|strong="H1818"\w* ello. ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* entonces quieres \w pecar|strong="H2398"\w* \w contra|strong="H3478"\w* \w sangre|strong="H1818"\w* \w inocente|strong="H5355"\w* al matar \w a|strong="H3068"\w* \w David|strong="H1732"\w* sin causa?
\p 
\v 6 \w Saúl|strong="H7586"\w* \w escuchó|strong="H8085"\w* la \w voz|strong="H6963"\w* de Jonatán y \w juró|strong="H7650"\w*: ¡\w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd* que no \w morirá|strong="H4191"\w*!
\v 7 Jonatán \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* y le \w contó|strong="H5046"\w* \w todas|strong="H3605"\w* esas \w cosas|strong="H1697"\w*. \w Él|strong="H3605"\w* \w mismo|strong="H3605"\w* llevó \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w ante|strong="H6440"\w* \w Saúl|strong="H7586"\w*, y \w estuvo|strong="H1961"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H3605"\w* \w como|strong="H1961"\w* en tiempos \w pasados|strong="H1961"\w*.
\p 
\v 8 \w Después|strong="H1961"\w* \w hubo|strong="H1961"\w* \w guerras|strong="H4421"\w* otra vez, y \w David|strong="H1732"\w* \w salió|strong="H3318"\w* y combatió \w contra|strong="H6440"\w* \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w*. \w Los|strong="H1961"\w* derrotó con \w gran|strong="H1419"\w* matanza, y \w huyeron|strong="H5127"\w* \w de|strong="H6440"\w* él.
\p 
\v 9 Pero \w el|strong="H1931"\w* \w espíritu|strong="H7307"\w* \w malo|strong="H7451"\w* \w de|strong="H7451"\w* parte \w de|strong="H7451"\w* \nd \w Yavé|strong="H3068"\w*\nd* llegó otra vez \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* \w cuando|strong="H1961"\w* \w él|strong="H1931"\w* \w estaba|strong="H1961"\w* \w sentado|strong="H3427"\w* en \w su|strong="H1931"\w* \w casa|strong="H1004"\w* con \w su|strong="H1931"\w* \w lanza|strong="H2595"\w* en \w la|strong="H1931"\w* \w mano|strong="H3027"\w*, mientras \w David|strong="H1732"\w* \w tañía|strong="H5059"\w*.
\v 10 \w Saúl|strong="H7586"\w* \w procuró|strong="H1245"\w* clavar \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w en|strong="H5221"\w* \w la|strong="H1931"\w* \w pared|strong="H7023"\w* con \w la|strong="H1931"\w* \w lanza|strong="H2595"\w*, pero \w él|strong="H1931"\w* \w se|strong="H1931"\w* apartó \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Saúl|strong="H7586"\w*, y \w la|strong="H1931"\w* \w lanza|strong="H2595"\w* \w se|strong="H1931"\w* clavó \w en|strong="H5221"\w* \w la|strong="H1931"\w* \w pared|strong="H7023"\w*. \w David|strong="H1732"\w* \w huyó|strong="H5127"\w* \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w*.
\p 
\v 11 Pero \w Saúl|strong="H7586"\w* \w envió|strong="H7971"\w* emisarios \w a|strong="H3068"\w* \w la|strong="H8104"\w* \w casa|strong="H1004"\w* de \w David|strong="H1732"\w* para que lo vigilaran y lo \w mataran|strong="H4191"\w* por \w la|strong="H8104"\w* \w mañana|strong="H4279"\w*. Mical, \w la|strong="H8104"\w* esposa de \w David|strong="H1732"\w*, \w le|strong="H1242"\w* advirtió y \w le|strong="H1242"\w* \w dijo|strong="H5046"\w*: \w Si|strong="H5315"\w* no salvas tu \w vida|strong="H5315"\w* esta \w noche|strong="H3915"\w*, \w mañana|strong="H4279"\w* estarás \w muerto|strong="H4191"\w*.
\v 12 Mical descolgó \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w por|strong="H1157"\w* una ventana, y él \w salió|strong="H3212"\w*, \w huyó|strong="H1272"\w* y \w escapó|strong="H4422"\w*.
\v 13 Mical \w tomó|strong="H3947"\w* un ídolo doméstico y lo \w puso|strong="H7760"\w* en \w la|strong="H4324"\w* \w cama|strong="H4296"\w*. Colocó una sábana de pelo de \w cabra|strong="H5795"\w* en \w la|strong="H4324"\w* \w cabecera|strong="H4763"\w* y lo \w cubrió|strong="H3680"\w* con ropas.
\p 
\v 14 Cuando \w Saúl|strong="H7586"\w* \w envió|strong="H7971"\w* emisarios para agarrar \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w ella|strong="H1931"\w* dijo: \w Está|strong="H1931"\w* \w enfermo|strong="H2470"\w*.
\p 
\v 15 \w Saúl|strong="H7586"\w* volvió \w a|strong="H3068"\w* enviar emisarios para que vieran \w a|strong="H3068"\w* \w David|strong="H1732"\w* y les dijo: ¡Tráiganmelo en la misma \w cama|strong="H4296"\w* para que lo \w mate|strong="H4191"\w*!
\v 16 Pero cuando entraron los emisarios, ¡ahí en la \w cama|strong="H4296"\w* \w estaba|strong="H2009"\w* el ídolo doméstico con la sábana de pelo de \w cabra|strong="H5795"\w* en la \w cabecera|strong="H4763"\w*!
\p 
\v 17 \w Y|strong="H3068"\w* \w Saúl|strong="H7586"\w* preguntó \w a|strong="H3068"\w* Mical: ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* me engañaste y dejaste \w ir|strong="H7971"\w* \w a|strong="H3068"\w* mi enemigo para \w que|strong="H4100"\w* \w se|strong="H1931"\w* \w escapara|strong="H4422"\w*?
\p Mical respondió \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*: \w Porque|strong="H4100"\w* \w él|strong="H1931"\w* me dijo: \w Déjame|strong="H7971"\w* \w escapar|strong="H4422"\w*. ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* debo \w matarte|strong="H4191"\w*?
\p 
\v 18 \w Así|strong="H1931"\w* \w pues|strong="H1931"\w*, \w David|strong="H1732"\w* \w escapó|strong="H4422"\w* y \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w Samuel|strong="H8050"\w* \w en|strong="H3212"\w* \w Ramá|strong="H7414"\w*. \w Le|strong="H1931"\w* informó \w todo|strong="H3605"\w* cuanto \w Saúl|strong="H7586"\w* \w le|strong="H1931"\w* \w hizo|strong="H6213"\w*. \w Luego|strong="H1931"\w* \w él|strong="H1931"\w* \w salió|strong="H3212"\w* con \w Samuel|strong="H8050"\w* y vivieron \w en|strong="H3212"\w* Nayot.
\p 
\v 19 Fue dado \w aviso|strong="H5046"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*: \w Ciertamente|strong="H2009"\w* \w David|strong="H1732"\w* está en Nayot de \w Ramá|strong="H7414"\w*.
\v 20 \w Entonces|strong="H1571"\w* \w Saúl|strong="H7586"\w* \w envió|strong="H7971"\w* emisarios \w para|strong="H5921"\w* \w que|strong="H5921"\w* detuvieran \w a|strong="H3068"\w* \w David|strong="H1732"\w*, \w los|strong="H1992"\w* cuales \w vieron|strong="H7200"\w* \w a|strong="H3068"\w* un grupo \w de|strong="H5921"\w* \w profetas|strong="H5030"\w* \w que|strong="H5921"\w* \w profetizaban|strong="H5012"\w*, \w y|strong="H1571"\w* \w a|strong="H3068"\w* \w Samuel|strong="H8050"\w* \w que|strong="H5921"\w* \w estaba|strong="H1961"\w* \w entre|strong="H5921"\w* \w ellos|strong="H1992"\w* \w y|strong="H1571"\w* \w los|strong="H1992"\w* presidía. \w El|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd* llegó \w sobre|strong="H5921"\w* \w los|strong="H1992"\w* emisarios \w de|strong="H5921"\w* \w Saúl|strong="H7586"\w*, \w y|strong="H1571"\w* \w ellos|strong="H1992"\w* \w también|strong="H1571"\w* \w profetizaron|strong="H5012"\w*.
\v 21 Informaron \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*, quien \w envió|strong="H7971"\w* otros emisarios. \w También|strong="H1571"\w* \w ellos|strong="H1992"\w* \w profetizaron|strong="H5012"\w*. \w Saúl|strong="H7586"\w* \w volvió|strong="H3254"\w* \w a|strong="H3068"\w* enviar emisarios por \w tercera|strong="H7992"\w* vez, \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w éstos|strong="H1992"\w* \w profetizaron|strong="H5012"\w*.
\v 22 \w Así|strong="H1571"\w* \w que|strong="H1931"\w* \w él|strong="H1931"\w* \w mismo|strong="H1931"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* Nayot \w de|strong="H5704"\w* \w Ramá|strong="H7414"\w*. \w Al|strong="H5704"\w* llegar \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w gran|strong="H1419"\w* cisterna \w que|strong="H1931"\w* \w está|strong="H1931"\w* \w en|strong="H5704"\w* Secú, \w preguntó|strong="H7592"\w*: ¿\w Dónde|strong="H1931"\w* \w están|strong="H2009"\w* \w Samuel|strong="H8050"\w* \w y|strong="H1571"\w* \w David|strong="H1732"\w*?
\p Uno contestó: \w Ciertamente|strong="H1571"\w* \w están|strong="H2009"\w* \w en|strong="H5704"\w* Nayot \w de|strong="H5704"\w* \w Ramá|strong="H7414"\w*.
\p 
\v 23 \w Fue|strong="H1961"\w* \w a|strong="H3068"\w* Nayot \w de|strong="H5921"\w* \w Ramá|strong="H7414"\w*. \w El|strong="H1931"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd* \w llegó|strong="H3212"\w* \w sobre|strong="H5921"\w* \w él|strong="H1931"\w*, \w y|strong="H1571"\w* \w andaba|strong="H1980"\w* \w y|strong="H1571"\w* profetizaba \w hasta|strong="H5704"\w* \w que|strong="H1931"\w* \w llegó|strong="H3212"\w* \w a|strong="H3068"\w* Nayot \w de|strong="H5921"\w* \w Ramá|strong="H7414"\w*.
\v 24 \w Él|strong="H1931"\w* \w también|strong="H1571"\w* \w se|strong="H1931"\w* despojó \w de|strong="H5921"\w* \w sus|strong="H1931"\w* ropas \w y|strong="H1571"\w* \w profetizó|strong="H5012"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w misma|strong="H1931"\w* manera \w en|strong="H5921"\w* \w presencia|strong="H6440"\w* \w de|strong="H5921"\w* \w Samuel|strong="H8050"\w*. \w Todo|strong="H3605"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w y|strong="H1571"\w* \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w* quedó \w desnudo|strong="H6174"\w* \w en|strong="H5921"\w* tierra. \w Por|strong="H5921"\w* \w esto|strong="H3651"\w* \w se|strong="H1931"\w* suele decir: ¿\w También|strong="H1571"\w* \w Saúl|strong="H7586"\w* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* \w profetas|strong="H5030"\w*?
\c 20
\s1 Pacto de David y Jonatán
\p 
\v 1 \w David|strong="H1732"\w* \w huyó|strong="H1272"\w* \w de|strong="H3588"\w* Nayot \w de|strong="H3588"\w* \w Ramá|strong="H7414"\w*. Fue \w a|strong="H3068"\w* Jonatán \w y|strong="H3588"\w* le dijo: ¿\w Qué|strong="H3588"\w* \w hice|strong="H6213"\w*? ¿\w Cuál|strong="H4100"\w* \w es|strong="H3588"\w* \w mi|strong="H5315"\w* \w iniquidad|strong="H5771"\w*? ¿\w Cuál|strong="H4100"\w* \w es|strong="H3588"\w* \w mi|strong="H5315"\w* \w pecado|strong="H2403"\w* \w contra|strong="H6440"\w* \w tu|strong="H6213"\w* padre \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w busque|strong="H1245"\w* \w mi|strong="H5315"\w* \w vida|strong="H5315"\w*?
\p 
\v 2 \w Y|strong="H3068"\w* \w él|strong="H6213"\w* le contestó: ¡\w Nada|strong="H3808"\w* \w de|strong="H4480"\w* \w eso|strong="H2063"\w*! ¡\w No|strong="H3808"\w* \w morirás|strong="H4191"\w*! \w Mira|strong="H2009"\w*, \w mi|strong="H2009"\w* padre \w no|strong="H3808"\w* \w hace|strong="H6213"\w* \w cosa|strong="H1697"\w* \w grande|strong="H1419"\w* \w o|strong="H3068"\w* \w pequeña|strong="H6996"\w* \w sin|strong="H3808"\w* decírmela. ¿\w Por|strong="H4480"\w* \w qué|strong="H4480"\w* \w mi|strong="H2009"\w* padre \w me|strong="H4480"\w* ocultará \w esto|strong="H2063"\w*? ¡\w Es|strong="H2088"\w* imposible!
\p 
\v 3 \w Pero|strong="H3588"\w* \w David|strong="H1732"\w* \w volvió|strong="H5750"\w* \w a|strong="H3068"\w* jurárselo: Tu padre \w sabe|strong="H3045"\w* claramente \w que|strong="H3588"\w* \w hallé|strong="H4672"\w* \w gracia|strong="H2580"\w* ante ti, \w y|strong="H3588"\w* \w se|strong="H3045"\w* dijo: \w Que|strong="H3588"\w* Jonatán \w no|strong="H6435"\w* \w sepa|strong="H3045"\w* \w esto|strong="H2063"\w*, \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H3588"\w* \w se|strong="H3045"\w* disguste. \w Pero|strong="H3588"\w* tan \w cierto|strong="H3588"\w* \w como|strong="H3588"\w* \w vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w y|strong="H3588"\w* \w vive|strong="H2416"\w* tu \w alma|strong="H5315"\w*, escasamente \w hay|strong="H5750"\w* un paso \w entre|strong="H3588"\w* \w mí|strong="H5315"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w*.
\p 
\v 4 Jonatán dijo \w a|strong="H3068"\w* \w David|strong="H1732"\w*: \w Haré|strong="H6213"\w* \w por|strong="H4100"\w* ti \w lo|strong="H4100"\w* \w que|strong="H4100"\w* desees.
\p 
\v 5 \w David|strong="H1732"\w* respondió: \w Mira|strong="H2009"\w*, \w mañana|strong="H4279"\w* es luna nueva, \w y|strong="H5704"\w* \w yo|strong="H2009"\w* debo \w sentarme|strong="H3427"\w* \w a|strong="H3068"\w* comer \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w*. Pero \w déjame|strong="H7971"\w* salir \w y|strong="H5704"\w* ocultarme \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w campo|strong="H7704"\w* \w hasta|strong="H5704"\w* la noche \w del|strong="H5973"\w* tercer día.
\v 6 \w Si|strong="H3588"\w* tu padre advierte mi ausencia, dirás: \w David|strong="H1732"\w* \w me|strong="H4480"\w* \w pidió|strong="H7592"\w* insistentemente permiso \w para|strong="H3588"\w* una rápida escapada \w a|strong="H3068"\w* Belén, \w su|strong="H3588"\w* \w ciudad|strong="H5892"\w*, \w porque|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* \w familia|strong="H4940"\w* celebra \w allí|strong="H8033"\w* \w el|strong="H3588"\w* \w sacrificio|strong="H2077"\w* anual.
\v 7 \w Si|strong="H3588"\w* \w él|strong="H5973"\w* dice: ¡\w Bien|strong="H2896"\w*! Tu esclavo puede estar \w en|strong="H5973"\w* \w paz|strong="H7965"\w*. \w Pero|strong="H3588"\w* \w si|strong="H3588"\w* \w se|strong="H3045"\w* enardece, \w entiende|strong="H3045"\w* \w que|strong="H3588"\w* \w el|strong="H5973"\w* \w mal|strong="H7451"\w* está decidido \w de|strong="H3588"\w* parte \w de|strong="H3588"\w* \w él|strong="H5973"\w*.
