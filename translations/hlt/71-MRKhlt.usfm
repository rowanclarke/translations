\p
\v 29 Te \w vaengah|strong="G2532"\w* \w anih|strong="G0846"\w* te, \wj “ \+w Hekah|strong="G5126"\+w* \+w ol|strong="G3056"\+w* \+w dongah|strong="G1223"\+w* \+w cet|strong="G5217"\+w* laeh, \+w rhaithae|strong="G1140"\+w* \+w te|strong="G3588"\+w* \+w na|strong="G4675"\+w* \+w canu|strong="G2364"\+w* taeng \+w lamkah|strong="G1537"\+w* \+w cet|strong="G1831"\+w* coeng,” \wj* a \w ti|strong="G2036"\w* nah.   
