\c 14
\s1 Joab cleverly arranged for Absalom to return
\p 
\v 1 \w Joab|strong="H3097"\w* \w realized|strong="H3045"\w* \w that|strong="H3588"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w* yearned [IDM] \w to|strong="H5921"\w* \w see|strong="H3045"\w* Absalom.
\v 2 \w So|strong="H3947"\w* \w Joab|strong="H3097"\w* \w sent|strong="H7971"\w* \w someone|strong="H4191"\w* \w to|strong="H4191"\w* \w Tekoa|strong="H8620"\w* \add town\add* \w to|strong="H4191"\w* \w bring|strong="H3947"\w* \w back|strong="H3947"\w* \w a|strong="H3068"\w* \w woman|strong="H2088"\w* \w who|strong="H7227"\w* \w was|strong="H1961"\w* \w very|strong="H2088"\w* clever. \add When she arrived,\add* \w Joab|strong="H3097"\w* said \w to|strong="H4191"\w* \w her|strong="H7971"\w*, “Pretend \w that|strong="H3117"\w* \w you|strong="H7971"\w* \w are|strong="H3117"\w* grieving \w because|strong="H5921"\w* \w someone|strong="H4191"\w* \w has|strong="H1961"\w* \w died|strong="H4191"\w*. \w Put|strong="H4191"\w* \w on|strong="H5921"\w* \w clothes|strong="H3847"\w* \w that|strong="H3117"\w* \w show|strong="H4994"\w* \w that|strong="H3117"\w* \w you|strong="H7971"\w* \w are|strong="H3117"\w* mourning. \w Do|strong="H4994"\w* \w not|strong="H2088"\w* \w put|strong="H4191"\w* \w any|strong="H1961"\w* lotion/\w ointment|strong="H8081"\w* \w on|strong="H5921"\w* \w your|strong="H3947"\w* \w body|strong="H4191"\w*. \w Act|strong="H4994"\w* \w as|strong="H3117"\w* \w if|strong="H1961"\w* \w you|strong="H7971"\w* \w are|strong="H3117"\w* \w a|strong="H3068"\w* \w woman|strong="H2088"\w* \w who|strong="H7227"\w* \w has|strong="H1961"\w* \w been|strong="H1961"\w* mourning \w for|strong="H5921"\w* \w a|strong="H3068"\w* \w long|strong="H3117"\w* \w time|strong="H3117"\w*.
\v 3 \w And|strong="H4428"\w* \w go|strong="H4428"\w* \w to|strong="H1696"\w* \w the|strong="H7760"\w* \w king|strong="H4428"\w*, \w and|strong="H4428"\w* \w tell|strong="H1696"\w* \w him|strong="H7760"\w* \w what|strong="H1697"\w* \w I|strong="H7760"\w* \w tell|strong="H1696"\w* \w you|strong="H7760"\w* \w to|strong="H1696"\w* \w say|strong="H1696"\w*.” \w Then|strong="H1696"\w* \w Joab|strong="H3097"\w* \w told|strong="H1696"\w* \w her|strong="H7760"\w* \w what|strong="H1697"\w* \w to|strong="H1696"\w* \w say|strong="H1696"\w* [MTY] \add to the king\add*.
\p 
\v 4 \w So|strong="H5921"\w* \w the|strong="H5921"\w* woman \w from|strong="H5921"\w* \w Tekoa|strong="H8621"\w* \w went|strong="H4428"\w* \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w*. \w She|strong="H5921"\w* \w prostrated|strong="H7812"\w* \w herself|strong="H7812"\w* \w in|strong="H5921"\w* front \w of|strong="H4428"\w* \w him|strong="H5921"\w* \w and|strong="H4428"\w* \w then|strong="H5307"\w* \w bowed|strong="H7812"\w* \w down|strong="H5307"\w* \w to|strong="H5921"\w* \w him|strong="H5921"\w*, \w and|strong="H4428"\w* said, “\w Your|strong="H5921"\w* Majesty, \w help|strong="H3467"\w* \w me|strong="H5921"\w*!”
\p 
\v 5 \w The|strong="H4191"\w* \w king|strong="H4428"\w* replied, “\w What|strong="H4100"\w* \w is|strong="H4100"\w* \w your|strong="H4100"\w* problem?” \w She|strong="H4100"\w* replied, “Please, sir, \w I|strong="H4100"\w* am \w a|strong="H3068"\w* widow. \w My|strong="H4191"\w* husband \w died|strong="H4191"\w* \add some time ago\add*.
\v 6 \w I|strong="H1121"\w* \w had|strong="H1121"\w* \w two|strong="H8147"\w* \w sons|strong="H1121"\w*. \w But|strong="H5221"\w* \w one|strong="H1121"\w* day \w they|strong="H5221"\w* quarreled \w with|strong="H4191"\w* \w each|strong="H8147"\w* \w other|strong="H8147"\w* \w out|strong="H5337"\w* \w in|strong="H4191"\w* \w the|strong="H5221"\w* \w fields|strong="H7704"\w*. There \w was|strong="H1121"\w* no \w one|strong="H1121"\w* \w to|strong="H4191"\w* \w separate|strong="H5337"\w* \w them|strong="H5221"\w*, \w and|strong="H1121"\w* \w one|strong="H1121"\w* \w of|strong="H1121"\w* \w them|strong="H5221"\w* \w struck|strong="H5221"\w* \w the|strong="H5221"\w* \w other|strong="H8147"\w* \w one|strong="H1121"\w* \w and|strong="H1121"\w* \w killed|strong="H5221"\w* \w him|strong="H5221"\w*.
\v 7 \w Now|strong="H2009"\w*, \w all|strong="H3605"\w* \w my|strong="H5414"\w* \w family|strong="H4940"\w* oppose \w me|strong="H5414"\w*. \w They|strong="H5921"\w* \w are|strong="H1571"\w* insisting \w that|strong="H3605"\w* \w I|strong="H5414"\w* \w allow|strong="H5414"\w* \w them|strong="H5414"\w* \w to|strong="H4191"\w* \w kill|strong="H2026"\w* \w my|strong="H5414"\w* son \w who|strong="H3605"\w* \w is|strong="H5315"\w* \w still|strong="H1571"\w* \w alive|strong="H7604"\w* [MTY], \w in|strong="H5921"\w* order \w that|strong="H3605"\w* \w they|strong="H5921"\w* \w may|strong="H5315"\w* \w get|strong="H6965"\w* revenge \w for|strong="H5921"\w* \w his|strong="H3605"\w* \w killing|strong="H2026"\w* \w his|strong="H3605"\w* brother. \w But|strong="H2009"\w* \w if|strong="H2009"\w* \w they|strong="H5921"\w* \w do|strong="H3605"\w* \w that|strong="H3605"\w*, \w I|strong="H5414"\w* \w will|strong="H1571"\w* \w not|strong="H1115"\w* \w have|strong="H1571"\w* \w any|strong="H3605"\w* son \w to|strong="H4191"\w* \w inherit|strong="H3423"\w* \add my husband’s possessions\add*. \w That|strong="H3605"\w* \w would|strong="H5315"\w* \w be|strong="H4191"\w* \w like|strong="H4191"\w* [MET] extinguishing \w the|strong="H3605"\w* \w last|strong="H6965"\w* \w coals|strong="H1513"\w* \w of|strong="H6440"\w* \w a|strong="H3068"\w* \w fire|strong="H1513"\w*, \w and|strong="H6965"\w* \w my|strong="H5414"\w* husband \w would|strong="H5315"\w* \w not|strong="H1115"\w* \w have|strong="H1571"\w* \w a|strong="H3068"\w* son \w to|strong="H4191"\w* \w preserve|strong="H7760"\w* \w our|strong="H3605"\w* \w family|strong="H4940"\w*’s \w name|strong="H8034"\w*. [DOU]”
\p 
\v 8 \w Then|strong="H4428"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w* said \w to|strong="H3212"\w* \w the|strong="H5921"\w* \w woman|strong="H1004"\w*, “\w Go|strong="H3212"\w* \w back|strong="H3212"\w* \w home|strong="H1004"\w*; \w I|strong="H5921"\w* \w will|strong="H4428"\w* \w take|strong="H3212"\w* \w care|strong="H5921"\w* \w of|strong="H4428"\w* \w this|strong="H1004"\w* matter \w for|strong="H5921"\w* \w you|strong="H6680"\w*.”
\p 
\v 9 \w The|strong="H5921"\w* \w woman|strong="H1004"\w* \w from|strong="H5921"\w* \w Tekoa|strong="H8621"\w* replied \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w*, “\w Your|strong="H5921"\w* Majesty, if \w you|strong="H5921"\w* \w are|strong="H4428"\w* criticized \add for helping me\add*, \w my|strong="H5921"\w* \w family|strong="H1004"\w* \w and|strong="H4428"\w* \w I|strong="H5921"\w* \w will|strong="H4428"\w* accept \w the|strong="H5921"\w* \w blame|strong="H5771"\w*. \w You|strong="H5921"\w* \w and|strong="H4428"\w* \w the|strong="H5921"\w* \w royal|strong="H4428"\w* \w family|strong="H1004"\w* \w will|strong="H4428"\w* ◄\w be|strong="H4428"\w* \w innocent|strong="H5355"\w*/not \w have|strong="H5771"\w* done \w what|strong="H5921"\w* \w is|strong="H5771"\w* \w wrong|strong="H5771"\w*►.”
\p 
\v 10 \w The|strong="H5060"\w* \w king|strong="H4428"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w her|strong="H5060"\w*, “If anyone \w says|strong="H1696"\w* \w anything|strong="H3808"\w* \add to threaten you/cause you trouble\add* \w you|strong="H3808"\w*, \w bring|strong="H5060"\w* \w that|strong="H4428"\w* \w person|strong="H1696"\w* \w to|strong="H1696"\w* \w me|strong="H1696"\w*, \w and|strong="H4428"\w* \add I will make sure that\add* \w he|strong="H3808"\w* \w will|strong="H4428"\w* \w never|strong="H3808"\w* cause \w you|strong="H3808"\w* trouble \w again|strong="H5750"\w*.”
\p 
\v 11 \w Then|strong="H5307"\w* \w the|strong="H3068"\w* woman said, “\w Your|strong="H3068"\w* Majesty, \w please|strong="H4994"\w* \w pray|strong="H4994"\w* \w that|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w your|strong="H3068"\w* \w God|strong="H3068"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w allow|strong="H4994"\w* \w my|strong="H3068"\w* \w relative|strong="H1350"\w*, \w who|strong="H3068"\w* \add wants to get\add* revenge \w on|strong="H5307"\w* \w my|strong="H3068"\w* \w son|strong="H1121"\w* \w for|strong="H3068"\w* \w killing|strong="H1818"\w* [MTY] \w his|strong="H3068"\w* brother, \w to|strong="H3068"\w* \w be|strong="H3808"\w* able \w to|strong="H3068"\w* \w do|strong="H3068"\w* \w that|strong="H3068"\w*.”
\p David replied, “\w As|strong="H3068"\w* \w surely|strong="H5307"\w* \w as|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w lives|strong="H2416"\w*, \w your|strong="H3068"\w* \w son|strong="H1121"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w be|strong="H3808"\w* harmed \w at|strong="H3068"\w* \w all|strong="H7843"\w*. [IDM]”
\v 12 \w Then|strong="H1696"\w* \w the|strong="H1697"\w* woman \w said|strong="H1696"\w*, “\w Your|strong="H4994"\w* Majesty, \w please|strong="H4994"\w* \w allow|strong="H4994"\w* \w me|strong="H4994"\w* \w to|strong="H1696"\w* \w say|strong="H1696"\w* \w one|strong="H4428"\w* more \w thing|strong="H1697"\w* \w to|strong="H1696"\w* \w you|strong="H1696"\w*.” \w He|strong="H1696"\w* \w replied|strong="H1696"\w*, “\w Speak|strong="H1696"\w*!”
\p 
\v 13 \w The|strong="H5921"\w* \w woman|strong="H2088"\w* \w said|strong="H1696"\w*, “\w Why|strong="H4100"\w* \w have|strong="H5971"\w* \w you|strong="H5921"\w* \w done|strong="H1697"\w* \w this|strong="H2088"\w* bad \w thing|strong="H1697"\w* \w to|strong="H1696"\w* God’s \w people|strong="H5971"\w*? \w You|strong="H5921"\w* \w have|strong="H5971"\w* \w not|strong="H1115"\w* allowed \w your|strong="H5921"\w* son Absalom \w to|strong="H1696"\w* \w return|strong="H7725"\w* \w home|strong="H7725"\w*. \w By|strong="H5921"\w* \w saying|strong="H1697"\w* \w what|strong="H4100"\w* \w you|strong="H5921"\w* \w have|strong="H5971"\w* \w just|strong="H1697"\w* \w said|strong="H1696"\w*, \w you|strong="H5921"\w* \w have|strong="H5971"\w* \w certainly|strong="H7725"\w* \w declared|strong="H1696"\w* [RHQ] \w that|strong="H5971"\w* \w what|strong="H4100"\w* \w you|strong="H5921"\w* \w have|strong="H5971"\w* \w done|strong="H1697"\w* \w is|strong="H2088"\w* wrong.
\v 14 \w We|strong="H3588"\w* \w all|strong="H4480"\w* \w die|strong="H4191"\w*; \w we|strong="H3068"\w* \w are|strong="H4284"\w* \w like|strong="H3808"\w* [SIM] \w water|strong="H4325"\w* \w that|strong="H3588"\w* \w cannot|strong="H3808"\w* \w be|strong="H4191"\w* \w picked|strong="H5375"\w* \w up|strong="H5375"\w* \w after|strong="H4480"\w* \w it|strong="H3588"\w* \w is|strong="H5315"\w* \w spilled|strong="H5064"\w* \w on|strong="H4191"\w* \w the|strong="H3588"\w* ground. \w But|strong="H3588"\w* \w God|strong="H3808"\w* \w does|strong="H3808"\w* \w not|strong="H3808"\w* just cause \w us|strong="H3588"\w* \w to|strong="H4191"\w* \w die|strong="H4191"\w*; \w he|strong="H3588"\w* creates \w ways|strong="H4284"\w* \w to|strong="H4191"\w* \w bring|strong="H5375"\w* \w us|strong="H3588"\w* back \w when|strong="H3588"\w* \w we|strong="H3068"\w* \w become|strong="H5375"\w* separated \w from|strong="H4480"\w* \w him|strong="H4191"\w*.
\p 
\v 15 “\w Now|strong="H6258"\w*, \w Your|strong="H6213"\w* Majesty, \w I|strong="H3588"\w* \w have|strong="H5971"\w* \w come|strong="H4994"\w* \w to|strong="H1696"\w* \w you|strong="H3588"\w* \w because|strong="H3588"\w* \w others|strong="H5971"\w* \w have|strong="H5971"\w* \w threatened|strong="H1696"\w* \w me|strong="H4994"\w*. \w So|strong="H6213"\w* \w I|strong="H3588"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* myself, ‘\w I|strong="H3588"\w* \w will|strong="H4428"\w* \w go|strong="H5971"\w* \w and|strong="H4428"\w* \w talk|strong="H1696"\w* \w to|strong="H1696"\w* \w the|strong="H3588"\w* \w king|strong="H4428"\w*, \w and|strong="H4428"\w* \w perhaps|strong="H3588"\w* \w he|strong="H3588"\w* \w will|strong="H4428"\w* \w do|strong="H6213"\w* \w what|strong="H1697"\w* \w I|strong="H3588"\w* \w request|strong="H1697"\w* \w him|strong="H6213"\w* \w to|strong="H1696"\w* \w do|strong="H6213"\w*.
\v 16 \w Perhaps|strong="H3588"\w* \w he|strong="H3588"\w* \w will|strong="H4428"\w* \w listen|strong="H8085"\w* \w to|strong="H8085"\w* \w me|strong="H5337"\w*, \w and|strong="H1121"\w* \w save|strong="H5337"\w* \w me|strong="H5337"\w* \w from|strong="H1121"\w* \w the|strong="H8085"\w* \w man|strong="H1121"\w* \w who|strong="H1121"\w* \w is|strong="H4428"\w* trying \w to|strong="H8085"\w* kill \w my|strong="H8085"\w* \w son|strong="H1121"\w*. \w If|strong="H3588"\w* \w my|strong="H8085"\w* \w son|strong="H1121"\w* \w is|strong="H4428"\w* killed, \w it|strong="H3588"\w* \w would|strong="H4428"\w* result \w in|strong="H4428"\w* \w us|strong="H3588"\w* disappearing \w from|strong="H1121"\w* \w the|strong="H8085"\w* \w land|strong="H5159"\w* \w that|strong="H3588"\w* God \w gave|strong="H8085"\w* \w to|strong="H8085"\w* \w us|strong="H3588"\w*.’
\p 
\v 17 “\w And|strong="H3068"\w* \w I|strong="H3588"\w* \w thought|strong="H1697"\w*, ‘\w What|strong="H1697"\w* \w the|strong="H8085"\w* \w king|strong="H4428"\w* \w says|strong="H1697"\w* \w will|strong="H3068"\w* comfort/encourage \w me|strong="H4994"\w*, \w because|strong="H3588"\w* \w the|strong="H8085"\w* \w king|strong="H4428"\w* \w is|strong="H3068"\w* \w like|strong="H1961"\w* [SIM] \w an|strong="H1961"\w* \w angel|strong="H4397"\w* \w of|strong="H4428"\w* \w God|strong="H3068"\w*. \w He|strong="H3588"\w* knows \w what|strong="H1697"\w* \w is|strong="H3068"\w* \w good|strong="H2896"\w* \w and|strong="H3068"\w* \w what|strong="H1697"\w* \w is|strong="H3068"\w* \w evil|strong="H7451"\w*.’ \w I|strong="H3588"\w* \w pray|strong="H4994"\w*/desire \w that|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w will|strong="H3068"\w* ◄\w be|strong="H1961"\w* \w with|strong="H5973"\w*/direct► \w you|strong="H3588"\w*.”
\p 
\v 18 \w Then|strong="H6030"\w* \w the|strong="H4480"\w* \w king|strong="H4428"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w the|strong="H4480"\w* woman, “\w I|strong="H1697"\w* \w will|strong="H4428"\w* \w now|strong="H4994"\w* \w ask|strong="H7592"\w* \w you|strong="H4480"\w* \w a|strong="H3068"\w* \w question|strong="H1697"\w*. \w Answer|strong="H6030"\w* \w it|strong="H1696"\w*, \w and|strong="H6030"\w* \w tell|strong="H1696"\w* \w me|strong="H4994"\w* \w the|strong="H4480"\w* truth. [LIT]” \w The|strong="H4480"\w* woman \w replied|strong="H6030"\w*, “\w Your|strong="H4480"\w* majesty, \w ask|strong="H7592"\w* \w your|strong="H4480"\w* \w question|strong="H1697"\w*.”
\p 
\v 19 \w The|strong="H3605"\w* \w king|strong="H4428"\w* \w said|strong="H1696"\w*, “\w Was|strong="H1931"\w* \w Joab|strong="H3097"\w* \w the|strong="H3605"\w* \w one|strong="H3605"\w* \w who|strong="H3605"\w* \w told|strong="H1696"\w* \w you|strong="H3588"\w* \w to|strong="H1696"\w* \w do|strong="H6680"\w* \w this|strong="H2063"\w*?” \w She|strong="H1931"\w* \w replied|strong="H6030"\w*, “\w Yes|strong="H3588"\w*, \w Your|strong="H3605"\w* Majesty, \w as|strong="H1697"\w* \w surely|strong="H3588"\w* \w as|strong="H1697"\w* \w you|strong="H3588"\w* \w live|strong="H2416"\w*, \w I|strong="H3588"\w* \w cannot|strong="H3027"\w* avoid \w telling|strong="H1696"\w* \w you|strong="H3588"\w* \w what|strong="H1697"\w* \w is|strong="H1931"\w* true. \w Yes|strong="H3588"\w*, \w indeed|strong="H3588"\w*, \w it|strong="H7760"\w* \w was|strong="H1931"\w* \w Joab|strong="H3097"\w* \w who|strong="H3605"\w* \w told|strong="H1696"\w* \w me|strong="H5315"\w* \w to|strong="H1696"\w* come \w here|strong="H2063"\w*, \w and|strong="H6030"\w* \w who|strong="H3605"\w* \w told|strong="H1696"\w* \w me|strong="H5315"\w* \w what|strong="H1697"\w* \w to|strong="H1696"\w* \w say|strong="H1696"\w*.
\v 20 \w He|strong="H6213"\w* \w did|strong="H6213"\w* \w it|strong="H6213"\w* \w in|strong="H6213"\w* \w order|strong="H5668"\w* \w to|strong="H6213"\w* \w cause|strong="H1697"\w* \w you|strong="H6440"\w* \w to|strong="H6213"\w* think differently \w about|strong="H5437"\w* \w this|strong="H2088"\w* \w matter|strong="H1697"\w*. \w Your|strong="H3605"\w* Majesty, \w you|strong="H6440"\w* \w are|strong="H1697"\w* \w as|strong="H1697"\w* \w wise|strong="H2450"\w* \w as|strong="H1697"\w* \w God|strong="H2451"\w*’s \w angels|strong="H4397"\w*, \w and|strong="H5650"\w* \add it seems that\add* \w you|strong="H6440"\w* \w know|strong="H3045"\w* \w everything|strong="H3605"\w* \add that happens\add* \w on|strong="H6213"\w* \w the|strong="H3605"\w* earth, \add so you know why Joab sent me here\add*.”
\p 
