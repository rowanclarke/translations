\c 2
\p 
\v 1 \w Solomon|strong="H8010"\w* ordered \w a|strong="H3068"\w* temple \w to|strong="H5921"\w* \w be|strong="H2022"\w* built \w to|strong="H5921"\w* honor \w the|strong="H5921"\w* \nd Lord\nd*, \w as|strong="H2022"\w* well \w as|strong="H2022"\w* \w a|strong="H3068"\w* royal palace \w for|strong="H5921"\w* himself.
\v 2 \w Solomon|strong="H8010"\w* \w had|strong="H1732"\w* 70,000 common \w laborers|strong="H6213"\w* \w and|strong="H7971"\w* 80,000 stonecutters \w in|strong="H3427"\w* \w the|strong="H6213"\w* hills, \w in|strong="H3427"\w* addition \w to|strong="H7971"\w* 3,600 supervisors.
\p 
\v 3 Solomon \w sent|strong="H3068"\w* \w a|strong="H3068"\w* \w message|strong="H3068"\w* \w to|strong="H3478"\w* \w King|strong="H5921"\w* Huram \w of|strong="H1004"\w* Tyre: “Help \w me|strong="H6440"\w* \w as|strong="H3068"\w* \w you|strong="H6440"\w* \w did|strong="H3478"\w* \w my|strong="H3068"\w* father David, \w when|strong="H3068"\w* \w you|strong="H6440"\w* \w sent|strong="H3068"\w* \w him|strong="H6440"\w* cedar \w logs|strong="H1129"\w* \w for|strong="H5921"\w* \w the|strong="H6440"\w* \w construction|strong="H1129"\w* \w of|strong="H1004"\w* \w his|strong="H3068"\w* \w palace|strong="H1004"\w*.
\v 4 Look, \w I|strong="H3588"\w* am ready \w to|strong="H1004"\w* \w build|strong="H1129"\w* \w a|strong="H3068"\w* \w temple|strong="H1004"\w* \w to|strong="H1004"\w* honor \w the|strong="H3605"\w* \nd Lord\nd* \w my|strong="H3605"\w* God \w and|strong="H1419"\w* \w to|strong="H1004"\w* dedicate \w it|strong="H3588"\w* \w to|strong="H1004"\w* \w him|strong="H3605"\w* \w in|strong="H1004"\w* order \w to|strong="H1004"\w* burn fragrant incense before \w him|strong="H3605"\w*, \w to|strong="H1004"\w* \w set|strong="H1129"\w* \w out|strong="H3605"\w* \w the|strong="H3605"\w* bread \w that|strong="H3588"\w* \w is|strong="H3605"\w* regularly displayed, \w and|strong="H1419"\w* \w to|strong="H1004"\w* offer burnt sacrifices \w each|strong="H3605"\w* morning \w and|strong="H1419"\w* evening, \w and|strong="H1419"\w* \w on|strong="H1004"\w* Sabbaths, new moon festivals, \w and|strong="H1419"\w* \w at|strong="H1004"\w* \w other|strong="H3605"\w* times appointed \w by|strong="H3605"\w* \w the|strong="H3605"\w* \nd Lord\nd* \w our|strong="H3605"\w* God. \w This|strong="H3588"\w* \w is|strong="H3605"\w* \w something|strong="H3605"\w* Israel must \w do|strong="H3605"\w* \w on|strong="H1004"\w* \w a|strong="H3068"\w* permanent basis.
\v 5 \w I|strong="H3588"\w* \w will|strong="H4310"\w* \w build|strong="H1129"\w* \w a|strong="H3068"\w* \w great|strong="H6440"\w* \w temple|strong="H1004"\w*, \w for|strong="H3588"\w* \w our|strong="H3588"\w* \w God|strong="H3808"\w* \w is|strong="H4310"\w* greater \w than|strong="H3808"\w* \w all|strong="H6440"\w* gods.
\v 6 \w Of|strong="H6213"\w* course, \w who|strong="H3063"\w* \w can|strong="H6213"\w* really \w build|strong="H6213"\w* \w a|strong="H3068"\w* temple \w for|strong="H6213"\w* \w him|strong="H7971"\w*, \w since|strong="H6258"\w* \w the|strong="H6213"\w* sky \w and|strong="H3063"\w* \w the|strong="H6213"\w* highest heavens \w cannot|strong="H3045"\w* contain \w him|strong="H7971"\w*? \w Who|strong="H3063"\w* am \w I|strong="H3045"\w* \w that|strong="H3045"\w* \w I|strong="H3045"\w* \w should|strong="H6213"\w* \w build|strong="H6213"\w* \w him|strong="H7971"\w* \w a|strong="H3068"\w* temple! \w It|strong="H6213"\w* \w will|strong="H3063"\w* really \w be|strong="H3389"\w* only \w a|strong="H3068"\w* \w place|strong="H3559"\w* \w to|strong="H7971"\w* \w offer|strong="H6213"\w* sacrifices \w before|strong="H5973"\w* \w him|strong="H7971"\w*.
\p 
\v 7 “\w Now|strong="H2009"\w* \w send|strong="H7971"\w* \w me|strong="H7971"\w* \w a|strong="H3068"\w* \w man|strong="H3045"\w* \w who|strong="H5650"\w* \w is|strong="H2009"\w* skilled \w in|strong="H5650"\w* working \w with|strong="H5973"\w* gold, silver, bronze, \w and|strong="H7971"\w* iron, \w as|strong="H3588"\w* \w well|strong="H3045"\w* \w as|strong="H3588"\w* purple, crimson, \w and|strong="H7971"\w* violet colored fabrics, \w and|strong="H7971"\w* \w who|strong="H5650"\w* \w knows|strong="H3045"\w* \w how|strong="H3588"\w* \w to|strong="H7971"\w* engrave. \w He|strong="H3588"\w* \w will|strong="H5650"\w* work \w with|strong="H5973"\w* \w my|strong="H3045"\w* skilled craftsmen \w here|strong="H2009"\w* \w in|strong="H5650"\w* Jerusalem \w and|strong="H7971"\w* Judah, \w whom|strong="H3588"\w* \w my|strong="H3045"\w* father \w David|strong="H7971"\w* \w provided|strong="H3045"\w*.
\v 8 Send \w me|strong="H1129"\w* cedars, evergreens, \w and|strong="H1419"\w* algum \w trees|strong="H6086"\w* \w from|strong="H6086"\w* Lebanon, \w for|strong="H3588"\w* \w I|strong="H3588"\w* know \w your|strong="H3588"\w* servants \w are|strong="H1004"\w* adept \w at|strong="H1004"\w* cutting \w down|strong="H3588"\w* \w trees|strong="H6086"\w* \w in|strong="H1004"\w* Lebanon. \w My|strong="H3588"\w* servants \w will|strong="H1004"\w* \w work|strong="H6381"\w* \w with|strong="H1004"\w* \w your|strong="H3588"\w* servants
\v 9 \w to|strong="H5414"\w* supply \w me|strong="H5414"\w* \w with|strong="H3772"\w* large quantities \w of|strong="H5650"\w* \w timber|strong="H6086"\w*, \w for|strong="H6086"\w* \w I|strong="H5414"\w* am building \w a|strong="H3068"\w* great, magnificent temple.
\v 10 \w Look|strong="H3068"\w*, \w I|strong="H5414"\w* \w will|strong="H3068"\w* \w pay|strong="H5414"\w* \w your|strong="H3068"\w* servants \w who|strong="H5971"\w* cut \w the|strong="H5921"\w* timber 20,000 kors \w of|strong="H4428"\w* ground wheat, 20,000 kors \w of|strong="H4428"\w* barley, 120,000 gallons \w of|strong="H4428"\w* wine, \w and|strong="H3068"\w* 120,000 gallons \w of|strong="H4428"\w* olive oil.”
\p 
\v 11 \w King|strong="H4428"\w* \w Huram|strong="H2361"\w* \w of|strong="H1121"\w* Tyre \w sent|strong="H5414"\w* \w this|strong="H6213"\w* letter \w to|strong="H3478"\w* Solomon: “\w Because|strong="H3068"\w* \w the|strong="H5414"\w* \nd \w Lord|strong="H3068"\w*\nd* loves \w his|strong="H5414"\w* \w people|strong="H1121"\w*, \w he|strong="H6213"\w* \w has|strong="H3068"\w* \w made|strong="H6213"\w* \w you|strong="H5414"\w* \w their|strong="H3068"\w* \w king|strong="H4428"\w*.”
