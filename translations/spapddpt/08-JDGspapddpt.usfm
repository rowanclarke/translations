\p 
\v 23 \w Ahora|strong="H6258"\w* cuando \nd \w Yavé|strong="H3068"\w*\nd*, el \nd ʼElohim\nd* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w echó|strong="H3423"\w* \w a|strong="H3068"\w* los amorreos \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* su \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, ¿pretendes tú apoderarte \w de|strong="H6440"\w* él?
\v 24 ¿\w No|strong="H3808"\w* posees tú \w lo|strong="H3808"\w* \w que|strong="H3808"\w* tenían \w aquellos|strong="H3605"\w* \w que|strong="H3808"\w* Quemos, tu \tl ʼelohim\tl*, \w echó|strong="H3423"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti? Así \w nosotros|strong="H3605"\w* desposeeremos \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w aquel|strong="H3605"\w* \w que|strong="H3808"\w* \nd \w Yavé|strong="H3068"\w*\nd*, nuestro \nd ʼElohim\nd*, eche \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w nosotros|strong="H3605"\w*.
\v 25 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, ¿vales tú \w más|strong="H6258"\w* \w que|strong="H6258"\w* \w Balac|strong="H1111"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Sipor, \w rey|strong="H4428"\w* \w de|strong="H5973"\w* \w Moab|strong="H4124"\w*? ¿\w Él|strong="H5973"\w* tuvo alguna \w disputa|strong="H7378"\w* \w con|strong="H5973"\w* \w Israel|strong="H3478"\w* \w o|strong="H3068"\w* \w hizo|strong="H3898"\w* \w guerra|strong="H3898"\w* \w contra|strong="H5973"\w* ellos?
\v 26 \w Mientras|strong="H3605"\w* \w Israel|strong="H3478"\w* vivió \w en|strong="H5921"\w* \w Hesbón|strong="H2809"\w* \w y|strong="H5921"\w* \w sus|strong="H1931"\w* \w aldeas|strong="H1323"\w*, \w en|strong="H5921"\w* \w Aroer|strong="H6177"\w* \w y|strong="H5921"\w* \w sus|strong="H1931"\w* \w aldeas|strong="H1323"\w*, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w que|strong="H1931"\w* \w están|strong="H3427"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* riberas \w del|strong="H5921"\w* Arnón 300 \w años|strong="H8141"\w*, ¿\w por|strong="H5921"\w* \w qué|strong="H1931"\w* \w no|strong="H3808"\w* \w las|strong="H5921"\w* recuperaron \w en|strong="H5921"\w* \w ese|strong="H1931"\w* \w tiempo|strong="H6256"\w*?
\v 27 Así \w que|strong="H3808"\w* \w yo|strong="H6213"\w* \w no|strong="H3808"\w* \w pequé|strong="H2398"\w* \w contra|strong="H3478"\w* ti, pero \w tú|strong="H8199"\w* \w haces|strong="H6213"\w* \w mal|strong="H7451"\w* \w conmigo|strong="H6213"\w* al combatir \w contra|strong="H3478"\w* mí. ¡\nd \w Yavé|strong="H3068"\w*\nd*, \w el|strong="H1121"\w* \w Juez|strong="H8199"\w*, \w juzgue|strong="H8199"\w* \w hoy|strong="H3117"\w* \w entre|strong="H3808"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón!
\p 
\v 28 Pero \w el|strong="H1121"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón \w no|strong="H3808"\w* \w escuchó|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w que|strong="H3808"\w* Jefté le \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w decir|strong="H8085"\w*.
\p 
\v 29 Entonces \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w vino|strong="H1961"\w* \w sobre|strong="H5921"\w* Jefté, quien atravesó \w Galaad|strong="H1568"\w* \w y|strong="H5921"\w* \w Manasés|strong="H4519"\w*. \w Pasó|strong="H5674"\w* \w a|strong="H3068"\w* Mizpa \w de|strong="H5921"\w* \w Galaad|strong="H1568"\w*, \w y|strong="H5921"\w* \w de|strong="H5921"\w* allí \w salió|strong="H5674"\w* \w hacia|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón.
\v 30 Jefté \w hizo|strong="H5088"\w* un \w voto|strong="H5087"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: Si en verdad entregas \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón en mi \w mano|strong="H3027"\w*,
\v 31 \w cualquiera|strong="H3318"\w* \w que|strong="H1121"\w* \w salga|strong="H3318"\w* \w a|strong="H3068"\w* encontrarme por las \w puertas|strong="H1817"\w* \w de|strong="H1121"\w* \w mi|strong="H1961"\w* \w casa|strong="H1004"\w* \w cuando|strong="H1961"\w* yo regrese \w en|strong="H3318"\w* \w paz|strong="H7965"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón, \w será|strong="H1961"\w* \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* y yo lo \w ofreceré|strong="H5927"\w* \w en|strong="H3318"\w* \w holocausto|strong="H5930"\w*.
\p 
\v 32 Jefté fue hacia \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón \w para|strong="H5414"\w* pelear contra \w ellos|strong="H3027"\w*, y \nd \w Yavé|strong="H3068"\w*\nd* \w los|strong="H1121"\w* \w entregó|strong="H5414"\w* en su \w mano|strong="H3027"\w*.
\v 33 \w Los|strong="H1121"\w* derrotó \w con|strong="H5704"\w* una matanza \w muy|strong="H3966"\w* \w grande|strong="H1419"\w* \w desde|strong="H5704"\w* \w Aroer|strong="H6177"\w* \w hasta|strong="H5704"\w* la vega \w de|strong="H6440"\w* Las Viñas, 20 aldeas. Así \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* Amón fueron sometidos \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*.
\p 
\v 34 Jefté regresó \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w casa|strong="H1004"\w* \w en|strong="H4480"\w* \w Mizpa|strong="H4709"\w*, ¡y ahí \w salía|strong="H3318"\w* \w su|strong="H1931"\w* \w hija|strong="H1323"\w* \w a|strong="H3068"\w* recibirlo \w con|strong="H4480"\w* panderos y danzas! \w Y|strong="H3068"\w* \w ella|strong="H1931"\w* \w era|strong="H1931"\w* \w la|strong="H1931"\w* única \w hija|strong="H1323"\w*. \w Fuera|strong="H4480"\w* \w de|strong="H4480"\w* \w ella|strong="H1931"\w* no \w tenía|strong="H1931"\w* \w hijo|strong="H1121"\w* ni \w hija|strong="H1323"\w*.
\v 35 \w Aconteció|strong="H1961"\w* \w que|strong="H3808"\w*, al verla, él \w rasgó|strong="H7167"\w* las ropas y dijo: ¡Ay, \w hija|strong="H1323"\w* mía! Me destrozaste. Estás \w entre|strong="H3808"\w* \w los|strong="H1961"\w* \w que|strong="H3808"\w* me atribulan, \w porque|strong="H3808"\w* abrí \w mi|strong="H1961"\w* \w boca|strong="H6310"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* y \w no|strong="H3808"\w* \w podré|strong="H3201"\w* \w retractarme|strong="H7725"\w*.
\p 
\v 36 Ella entonces le respondió: Padre mío, si diste \w palabra|strong="H6310"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w haz|strong="H6213"\w* \w conmigo|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H1121"\w* dijiste, ya \w que|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* te vengó \w de|strong="H1121"\w* tus enemigos, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón.
\v 37 Dijo \w además|strong="H5921"\w* \w a|strong="H3068"\w* su padre: \w Que|strong="H4480"\w* \w se|strong="H5921"\w* \w me|strong="H4480"\w* \w haga|strong="H6213"\w* \w esto|strong="H2088"\w*: \w Déjame|strong="H7503"\w* solo \w dos|strong="H8147"\w* \w meses|strong="H2320"\w* \w para|strong="H5921"\w* \w que|strong="H4480"\w* \w vaya|strong="H3212"\w* \w a|strong="H3068"\w* \w las|strong="H5921"\w* montañas \w y|strong="H5921"\w* \w llore|strong="H1058"\w* \w por|strong="H5921"\w* \w causa|strong="H1697"\w* \w de|strong="H4480"\w* \w mi|strong="H5921"\w* virginidad \w junto|strong="H5921"\w* \w con|strong="H5921"\w* mis compañeras.
\p 
\v 38 \w Él|strong="H1931"\w* entonces respondió: \w Vé|strong="H3212"\w*. \w Y|strong="H3068"\w* \w la|strong="H1931"\w* \w dejó|strong="H7971"\w* \w ir|strong="H3212"\w* \w por|strong="H5921"\w* \w dos|strong="H8147"\w* \w meses|strong="H2320"\w*.
\p \w Ella|strong="H1931"\w* \w fue|strong="H3212"\w* \w con|strong="H5921"\w* \w sus|strong="H1931"\w* compañeras \w y|strong="H5921"\w* \w lloró|strong="H1058"\w* \w su|strong="H1931"\w* virginidad \w por|strong="H5921"\w* \w las|strong="H5921"\w* montañas.
\v 39 \w Sucedió|strong="H1961"\w* \w que|strong="H1931"\w* \w pasados|strong="H1961"\w* \w los|strong="H1931"\w* \w dos|strong="H8147"\w* \w meses|strong="H2320"\w* \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* padre, \w quien|strong="H6213"\w* cumplió con \w ella|strong="H1931"\w* \w el|strong="H1931"\w* \w voto|strong="H5087"\w* \w que|strong="H1931"\w* \w hizo|strong="H6213"\w*. \w Ella|strong="H1931"\w* \w nunca|strong="H3808"\w* \w se|strong="H3045"\w* unió \w a|strong="H3068"\w* varón.
\p \w Se|strong="H3045"\w* \w volvió|strong="H7725"\w* una costumbre en \w Israel|strong="H3478"\w*,
\v 40 \w que|strong="H3117"\w* \w cada|strong="H3117"\w* \w año|strong="H8141"\w* las doncellas de \w Israel|strong="H3478"\w* \w vayan|strong="H3212"\w* \w a|strong="H3068"\w* endechar \w a|strong="H3068"\w* la \w hija|strong="H1323"\w* de Jefté \w galaadita|strong="H1569"\w*, cuatro \w días|strong="H3117"\w* al \w año|strong="H8141"\w*.
\c 12
\s1 Los jueces Ibzán, Elón y Abdón
\p 
\v 1 Entonces \w los|strong="H1121"\w* varones \w de|strong="H5921"\w* Efraín \w fueron|strong="H3212"\w* convocados, \w cruzaron|strong="H3212"\w* \w hacia|strong="H5921"\w* Safón \w y|strong="H5921"\w* dijeron \w a|strong="H3068"\w* Jefté: ¿\w Por|strong="H5921"\w* \w qué|strong="H3808"\w* \w fuiste|strong="H5674"\w* \w a|strong="H3068"\w* luchar \w contra|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w nos|strong="H5921"\w* llamaste \w para|strong="H5921"\w* \w ir|strong="H3212"\w* \w contigo|strong="H5973"\w*? ¡Incendiaremos tu \w casa|strong="H1004"\w* \w contigo|strong="H5973"\w* \w dentro|strong="H5921"\w*!
\p 
\v 2 Jefté les \w respondió|strong="H3316"\w*: Yo y \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w* tuvimos una \w gran|strong="H3966"\w* \w contienda|strong="H7379"\w* \w contra|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Amón. \w Los|strong="H1121"\w* convoqué \w a|strong="H3068"\w* ustedes, pero \w no|strong="H3808"\w* me \add auxiliaron para\add* librarnos \w de|strong="H1121"\w* su \w mano|strong="H3027"\w*.
\v 3 \w Cuando|strong="H3588"\w* \w vi|strong="H7200"\w* \w que|strong="H3588"\w* ustedes \w no|strong="H3588"\w* \w me|strong="H3588"\w* defenderían, arriesgué \w mi|strong="H5315"\w* \w vida|strong="H5315"\w* \w y|strong="H3588"\w* \w pasé|strong="H5674"\w* contra \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Amón. \nd \w Yavé|strong="H3068"\w*\nd* \w los|strong="H1121"\w* \w entregó|strong="H5414"\w* \w en|strong="H3588"\w* \w mi|strong="H5315"\w* \w mano|strong="H3027"\w*. ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* \w se|strong="H4100"\w* levantan \w hoy|strong="H3117"\w* \w a|strong="H3068"\w* pelear contra \w mí|strong="H5315"\w*?
\p 
\v 4 \w Entonces|strong="H3588"\w* Jefté reunió \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w varones|strong="H3588"\w* \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w* \w y|strong="H3588"\w* \w peleó|strong="H3898"\w* contra Efraín. \w Y|strong="H3068"\w* \w los|strong="H3605"\w* hombres \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w* derrotaron \w a|strong="H3068"\w* Efraín, \w porque|strong="H3588"\w* \add éstos\add* dijeron: ¡Ustedes, \w los|strong="H3605"\w* galaaditas, \w son|strong="H3588"\w* fugitivos \w de|strong="H3588"\w* Efraín, \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* Efraín \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w Manasés|strong="H4519"\w*!
\v 5 \w Los|strong="H1961"\w* galaaditas capturaron \w los|strong="H1961"\w* vados del \w Jordán|strong="H3383"\w* \w que|strong="H3588"\w* \w están|strong="H1961"\w* frente \w a|strong="H3068"\w* Efraín. \w Y|strong="H3068"\w* \w sucedía|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* cualquiera \w de|strong="H3588"\w* \w los|strong="H1961"\w* fugitivos \w de|strong="H3588"\w* Efraín decía: Voy \w a|strong="H3068"\w* \w pasar|strong="H5674"\w*, \w los|strong="H1961"\w* hombres \w de|strong="H3588"\w* \w Galaad|strong="H1568"\w* le preguntaban: ¿\w Eres|strong="H1961"\w* tú efrateo? \w Y|strong="H3068"\w* \w si|strong="H3588"\w* \w él|strong="H3588"\w* respondía: \w No|strong="H3808"\w*,
\v 6 \w entonces|strong="H6256"\w* \w le|strong="H1931"\w* decían: \w Dí|strong="H1696"\w* \w ahora|strong="H4994"\w*, Shibolet. \w Y|strong="H3068"\w* \w él|strong="H1931"\w* decía Sibolet, \w porque|strong="H3808"\w* \w no|strong="H3808"\w* \w podía|strong="H3559"\w* pronunciar \w así|strong="H3651"\w*. \w Entonces|strong="H6256"\w* \w le|strong="H1931"\w* echaban \w mano|strong="H1931"\w* y \w lo|strong="H1931"\w* \w degollaban|strong="H7819"\w* en \w los|strong="H1931"\w* vados del \w Jordán|strong="H3383"\w*. \w Y|strong="H3068"\w* en \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w cayeron|strong="H5307"\w* 42.000 \w de|strong="H6256"\w* Efraín.
\p 
\v 7 Jefté \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w seis|strong="H8337"\w* \w años|strong="H8141"\w*. Jefté \w galaadita|strong="H1569"\w* \w murió|strong="H4191"\w* y fue \w sepultado|strong="H6912"\w* \w en|strong="H6912"\w* una de las \w ciudades|strong="H5892"\w* de \w Galaad|strong="H1568"\w*.
\p 
\v 8 Después de él, Ibzán, de Belén, \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*.
\v 9 \w Tenía|strong="H1961"\w* 30 \w hijos|strong="H1121"\w* y 30 \w hijas|strong="H1323"\w* \w a|strong="H3068"\w* las cuales casó \w afuera|strong="H2351"\w*. Tomó \w de|strong="H4480"\w* \w afuera|strong="H2351"\w* 30 \w mujeres|strong="H1323"\w* \w para|strong="H4480"\w* sus \w hijos|strong="H1121"\w*. \w Y|strong="H3068"\w* \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w*.
\v 10 Ibzán \w murió|strong="H4191"\w* y fue \w sepultado|strong="H6912"\w* \w en|strong="H6912"\w* Belén.
\p 
\v 11 Después de él Elón \w zabulonita|strong="H2075"\w* \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, y \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w diez|strong="H6235"\w* \w años|strong="H8141"\w*.
\v 12 Elón \w zabulonita|strong="H2075"\w* \w murió|strong="H4191"\w* y fue \w sepultado|strong="H6912"\w* \w en|strong="H6912"\w* Ajalón, \w en|strong="H6912"\w* la tierra de \w Zabulón|strong="H2074"\w*.
\p 
\v 13 Después \w de|strong="H1121"\w* \w él|strong="H1121"\w* \w Abdón|strong="H5658"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Hilel, \w piratonita|strong="H6553"\w*, \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*.
\v 14 \w Éste|strong="H1961"\w* \w tuvo|strong="H1961"\w* 40 \w hijos|strong="H1121"\w* \w y|strong="H5921"\w* 30 \w nietos|strong="H1121"\w*, \w que|strong="H5921"\w* cabalgaban \w sobre|strong="H5921"\w* 70 \w asnos|strong="H5895"\w*. \w Y|strong="H3068"\w* \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* 8 \w años|strong="H8141"\w*.
\v 15 \w Abdón|strong="H5658"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Hilel \w piratonita|strong="H6553"\w*, \w murió|strong="H4191"\w* y fue \w sepultado|strong="H6912"\w* \w en|strong="H6912"\w* Piratón \w en|strong="H6912"\w* la tierra \w de|strong="H1121"\w* Efraín, \w en|strong="H6912"\w* la región montañosa \w de|strong="H1121"\w* \w los|strong="H1121"\w* amalecitas.
\c 13
\s1 El juez Sansón
\p 
\v 1 Pero \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* volvieron \w a|strong="H3068"\w* \w hacer|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*, y \w Él|strong="H1121"\w* \w los|strong="H1121"\w* \w entregó|strong="H5414"\w* en \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* 40 \w años|strong="H8141"\w*.
\p 
\v 2 \w Hubo|strong="H1961"\w* entonces un hombre de \w Sora|strong="H6881"\w*, de la tribu de \w Dan|strong="H1839"\w*, \w llamado|strong="H8034"\w* \w Manoa|strong="H4495"\w*. Su esposa \w era|strong="H1961"\w* estéril y \w no|strong="H3808"\w* \w tenía|strong="H1961"\w* descendencia.
\p 
\v 3 Pero \w el|strong="H1121"\w* \w Ángel|strong="H4397"\w* \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w apareció|strong="H7200"\w* \w a|strong="H3068"\w* aquella mujer y le dijo: \wj \w Mira|strong="H7200"\w*, eres estéril y \w no|strong="H3808"\w* tienes descendencia, pero concebirás y darás \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*.\wj*
