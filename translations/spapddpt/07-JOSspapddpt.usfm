\v 4 \wj \+w A|strong="H3068"\+w* \+w Isaac|strong="H3327"\+w* le \+w di|strong="H5414"\+w* \+w a|strong="H3068"\+w* \+w Jacob|strong="H3290"\+w* y \+w a|strong="H3068"\+w* \+w Esaú|strong="H6215"\+w*. \+w A|strong="H3068"\+w* \+w Esaú|strong="H6215"\+w* le \+w di|strong="H5414"\+w* la región montañosa \+w de|strong="H1121"\+w* \+w Seír|strong="H8165"\+w* \+w para|strong="H5414"\+w* \+w que|strong="H1121"\+w* la poseyera, pero \+w Jacob|strong="H3290"\+w* y sus \+w hijos|strong="H1121"\+w* \+w bajaron|strong="H3381"\+w* \+w a|strong="H3068"\+w* \+w Egipto|strong="H4714"\+w*.\wj*   
