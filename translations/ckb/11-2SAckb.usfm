\id 2SA - Biblica® Open Kurdi Sorani Standard Version
\h دووەم ساموئێل
\toc1 دووەم ساموئێل
\toc2 دووەم ساموئێل
\toc3 دووەم ساموئێل
\mt1 دووەم ساموئێل
\c 1
\s1 گەیشتنی هەواڵی مردنی شاول
\p 
\v 1 ئەوە بوو پاش مردنی شاول و گەڕانەوەی داود لە لێدانی عەمالێقییەکان، داود دوو ڕۆژ لە چیقلەگ مایەوە.
\v 2 لە ڕۆژی سێیەمدا بینی گەنجێک لە ئۆردوگاکەی شاولەوە بە جلی دڕاو و سەری تۆزاوییەوە هات، کاتێک گەیشتە لای داود کەوتە سەر زەوی و کڕنۆشی برد.
\p 
\v 3 داود لێی پرسی: «لەکوێوە هاتوویت؟»
\p ئەویش وەڵامی دایەوە: «لە ئۆردوگای ئیسرائیلەوە دەرباز بووم.»
\p 
\v 4 داودیش پێی گوت: «ڕووداوەکە چۆن بوو؟ تکایە پێم ڕابگەیەنە.»
\p ئەویش گوتی:\f + \fr 1:4 \ft ئەو گەنجە هەواڵەکەی شێواندووە، بۆ ڕاستی ڕووداوەکە بڕوانە یەکەم ساموئێل بەشی 31.‏\f* «جەنگاوەران لە جەنگەکەدا هەڵاتن، زۆربەی جەنگاوەران کەوتن و مردن، شاول و یۆناتانی کوڕیشی مردن.»
\p 
\v 5 داودیش بەو گەنجەی گوت کە هەواڵەکەی پێی ڕاگەیاندبوو: «چۆن زانیت شاول و یۆناتانی کوڕی مردوون؟»
\p 
\v 6 گەنجەکەش پێی گوت: «وا ڕێککەوت من لە کێوی گلبۆع بووم، بینیم شاول بەسەر ڕمەکەیدا دەچەمایەوە، گالیسکە و سوارەکانیش بە توندی بەدوایەوە بوون.
\v 7 ئاوڕی لەدوای خۆی دایەوە و منی بینی، بانگی کردم، منیش گوتم: ”ئەوەتام.“
\p 
\v 8 «لێی پرسیم: ”تۆ کێیت؟“
\p «منیش وەڵامم دایەوە: ”من عەمالێقیم.“
\p 
\v 9 «ئینجا پێی گوتم: ”تکایە، وەرە سەرم و بمکوژە! لە سەرەمەرگدام، بەڵام هێشتا ژیانم تێدا ماوە.“
\p 
\v 10 «منیش چوومە سەری و کوشتم، چونکە زانیم پاش کەوتنەکەی ناژیێت، ئیتر تاجەکەی سەر سەری و بازنەکەی کە بە قۆڵییەوە بوو بردم و ئەوانەم بۆ لای گەورەم هێناوە.»
\p 
\v 11 داود جلەکانی لەبەرخۆی دادڕی، بە هەمان شێوە هەموو ئەو پیاوانەی کە لەگەڵی بوون.
\v 12 لاوانەوە و گریان، هەتا ئێوارە بەڕۆژوو بوون، بۆ شاول و یۆناتانی کوڕی و هەموو سوپای یەزدان و بنەماڵەی ئیسرائیل، چونکە بە شمشێر کەوتن.
\p 
\v 13 ئیتر داود بە گەنجەکەی گوت: «تۆ خەڵکی کوێیت؟»
\p ئەویش گوتی: «من کوڕی پیاوێکی عەمالێقی نامۆم.»
\p 
\v 14 داودیش پێی گوت: «چۆن سڵت نەکردەوە لەوەی دەستت درێژ بکەیت هەتا دەستنیشانکراوی یەزدان لەناو ببەیت؟»
\p 
\v 15 ئینجا داود یەکێک لە خزمەتکارەکانی بانگکرد و گوتی: «وەرە پێشەوە و بیکوژە!» ئەویش لێیدا و مرد.
\v 16 لەبەر ئەوەی داود پێی گوتبوو: «خوێنی خۆت لە ملی خۆتە، چونکە دەمت شایەتی لەسەر دایت و گوتت: ”من دەستنیشانکراوی یەزدانم کوشت.“»
\s1 لاواندنەوەی داود بۆ شاول و یۆناتان
\p 
\v 17 داود بەم لاوانەوەیە بۆ شاول و یۆناتانی کوڕی لاواندییەوە و
\v 18 فەرمانی دا کە نەوەی یەهودا ئەم لاواندنەوەیەی کەوان فێر بن. ئەوە لە پەڕتووکی یاشاردا\f + \fr 1:18 \ft پەڕتووکی یاشار: بڕوانە \xt یەشوع 10‏:13‏\xt*\ft ‏.‏\f* نووسراوە:
\q1 
\v 19 «ئەی ئیسرائیل! ئای چۆن قارەمانان کەوتن!
\q2 شکۆمەندییەکەت لەسەر بەرزاییەکانت کوژراوە.
\b
\q1 
\v 20 «لە گەت ڕایمەگەیەنن،
\q2 لە شەقامەکانی ئەسقەلان مژدە مەدەن،
\q1 نەوەک کچانی فەلەستییەکان دڵخۆش بن،
\q2 نەوەک کچانی خەتەنەنەکراوان پێمان خۆش بن.
\b
\q1 
\v 21 «ئەی چیاکانی گلبۆع،
\q2 با شەونم و بارانتان بەسەرەوە نەبێت،
\q2 نە کێڵگەکانت پێشکەشکراوی دانەوێڵە،
\q1 چونکە لەوێ قەڵغانی پاڵەوانان گڵاو بووە،
\q2 قەڵغانەکەی شاول، بێ چەورکردنی بە ڕۆن.
\b
\q1 
\v 22 «لە خوێنی کوژراوان و
\q2 لە جەستەی پاڵەوانان
\q1 کەوانەکەی یۆناتان نەهاتەوە دواوە و
\q2 شمشێرەکەی شاولیش بە بەتاڵی نەگەڕایەوە.
\q1 
\v 23 شاول و یۆناتان،
\q2 لە ژیانیاندا خۆشەویست و شیرین بوون،
\q2 لە مەرگیشدا لە یەکتر جیا نەبوونەوە.
\q1 لە هەڵۆ تیژڕەوتر و
\q2 لە شێر بەهێزتر بوون.
\b
\q1 
\v 24 «ئەی کچانی ئیسرائیل،
\q2 بۆ شاول بگریێن،
\q1 ئەوەی بەرگی سوور و نەرمی لەبەرکردن،
\q2 ئەوەی خشڵی زێڕی بە کراسەکانتانەوە کرد.
\b
\q1 
\v 25 «ئای چۆن قارەمانان لەناو جەرگەی جەنگدا کەوتن!
\q2 یۆناتان لەسەر بەرزاییەکانتدا کوژرا.
\q1 
\v 26 یۆناتانی برام، دڵم بۆت گوشرا،
\q2 زۆر شیرین بوویت لەلام،
\q1 خۆشەویستی تۆ بۆ من
\q2 لە خۆشەویستی خانمان سەیرتر بوو.
\b
\q1 
\v 27 «ئای چۆن قارەمانان کەوتن!
\q2 چەکەکانی جەنگ\f + \fr 1:27 \fq چەکەکانی جەنگ \ft مەبەستی لە شاول و یۆناتانە.‏\f* لەناوچوون!»
\c 2
\s1 دەستنیشانکردنی داود وەک پاشای یەهودا
\p 
\v 1 ئەوە بوو پاش ئەمە، داود لە یەزدانی پرسی و گوتی: «سەربکەوم بۆ یەکێک لە شارۆچکەکانی یەهودا؟»
\p یەزدانیش پێی فەرموو: «سەربکەوە.»
\p داودیش گوتی: «بۆ کوێ سەربکەوم؟»
\p ئەویش فەرمووی: «بۆ حەبرۆن.»
\p 
\v 2 ئینجا داود بۆ ئەوێ سەرکەوت، خۆی و هەردوو ژنەکەی، ئەحینۆعەمی یەزرەعیلی و ئەبیگایل کە بێوەژنی نابالی کارمەلی بوو.
\v 3 هەروەها داود ئەو پیاوانەی لەگەڵیدا بوون هەریەکە و لەگەڵ خێزانەکەی برد و لە شاری حەبرۆن و شارۆچکەکانی نیشتەجێ بوون.
\v 4 پاشان پیاوانی یەهودا هاتن و لەوێ داودیان بە پاشای بنەماڵەی یەهودا دەستنیشان کرد.
\p کاتێک بە داود ڕاگەیەنرا و گوترا کە پیاوانی یاڤێش گلعاد شاولیان ناشتووە،
\v 5 داودیش چەند نێردراوێکی بۆ لای پیاوانی یاڤێش گلعاد نارد بۆ ئەوەی پێیان بڵێن: «با یەزدان بەرەکەتدارتان بکات، کە ئەم چاکەیەتان لەگەڵ گەورەتان، لەگەڵ شاولدا کردووە و ناشتووتانە.
\v 6 ئێستاش با یەزدان خۆشەویستی نەگۆڕ و دڵسۆزیتان پیشان بدات، هەروەها منیش ئەم چاکەیەتان لەگەڵدا دەکەم، چونکە ئێوە ئەم کارەتان کرد.
\v 7 ئێستاش بازووتان بەهێز بکەن و ئازابن، چونکە شاولی گەورەتان مردووە و بنەماڵەی یەهودا منیان بە پاشای خۆیان دەستنیشان کردووە.»
\s1 جەنگی نێوان بنەماڵەکانی داود و شاول
\p 
\v 8 لەو کاتەدا ئەبنێری کوڕی نێری فەرماندەی گشتی سوپاکەی شاول، ئیشبۆشەتی کوڕی شاولی بردبوو و پەڕاندبوویەوە بۆ مەحەنەیم و
\v 9 کردبووی بە پاشای گلعاد و ئەشوری\f + \fr 2:9 \ft لەوانەیە مەبەستی لە هۆزی ئاشێر بێت.‏\f* و یەزرەعیل و ئەفرایم و بنیامین و هەموو ئیسرائیل.
\p 
\v 10 ئیشبۆشەتی کوڕی شاول تەمەنی چل ساڵ بوو کاتێک بوو بە پاشای ئیسرائیل، دوو ساڵ پاشایەتی کرد، تەنها بنەماڵەی یەهودا دوای داود کەوتن.
\v 11 ئەو ماوەیەش کە داود تێیدا لە حەبرۆن پاشایەتی کرد لەسەر بنەماڵەی یەهودا، حەوت ساڵ و شەش مانگ بوو.
\p 
\v 12 ئەبنێری کوڕی نێر و پیاوانی ئیشبۆشەتی کوڕی شاول مەحەنەیمیان بەجێهێشت و چوون بۆ گبعۆن.
\v 13 هەروەها یۆئابی کوڕی چەرویا و پیاوانی داودیش چوونە دەرەوە و لەلای گۆمەکەی گبعۆن بەیەکگەیشتن، جا ئەمان لەسەر گۆمەکە لەم لا و ئەوانیش لەسەر گۆمەکە لەو لا دانیشتن.
\p 
\v 14 ئینجا ئەبنێر بە یۆئابی گوت: «با هەندێک لە گەنجەکان هەستن و لەبەردەمماندا دەستەویەخە بەرەنگاری یەکتری ببنەوە.»
\p یۆئابیش گوتی: «با هەستن.»
\p 
\v 15 جا هەستان بە هەڵبژاردنی دوازدە پیاو بۆ بنیامین و ئیشبۆشەتی کوڕی شاول و دوازدە پیاویش بۆ داود.
\v 16 ئینجا هەریەکە و سەری بەرامبەرەکەی خۆی گرت و شمشێرەکەی کرد بە قەبرغەی دا و هەموویان کوژران. لەبەر ئەوە ئەو شوێنە لە گبعۆن بە حەلقەت هەچوڕیم\f + \fr 2:16 \ft حەلقەت هەچوڕیم: واتا کێڵگەی شمشێرە تیژەکان.‏\f* ناونرا.
\p 
\v 17 جا لەو ڕۆژەدا شەڕەکە زۆر توند بوو، ئەبنێر و پیاوانی ئیسرائیل لە بەرامبەر پیاوانی داود تێکشکان.
\p 
\v 18 هەر سێ کوڕەکەی چەرویاش، یۆئاب و ئەبیشەی و عەساهێل لەوێ بوون. عەساهێلیش پێیەکانی سووک بوون وەک مامزی کێوی.
\v 19 جا عەساهێل دوای ئەبنێر کەوت و لە ڕاونانی ئەبنێردا نە بەلای ڕاست و نە بەلای چەپدا لاینەدا و
\v 20 ئەبنێریش ئاوڕی لە دواوە دایەوە و گوتی: «ئەمە تۆی، عەساهێل؟»
\p ئەویش گوتی: «منم.»
\p 
\v 21 ئەبنێریش پێی گوت: «بەلای ڕاست یان چەپدا لابدە و یەکێک لە گەنجەکان بگرە و بۆ خۆت تاڵانی بکە.» بەڵام عەساهێل نەیویست وازی لێ بهێنێت.
\p 
\v 22 دیسان ئەبنێر بە عەساهێلی گوت: «بەدوای منەوە مەبە، بۆچی لەگەڵ زەوی تەختت بکەم؟ پاشان چۆن ڕووم بێت لەلای یۆئابی برات سەر بەرز بکەمەوە؟»
\p 
\v 23 بەڵام عەساهێل قایل نەبوو وازی لێ بهێنێت، لەبەر ئەوە ئەبنێر لێیدا و ڕمەکەی کرد بە سکیدا و ڕمەکە لە پشتییەوە دەرچوو. جا لەوێدا کەوت و لە شوێنی خۆیدا مرد، بۆیە هەرکەسێک دەهاتە ئەو شوێنەی کە عەساهێل تێیدا کەوت و مرد، ڕادەوەستا.
\p 
\v 24 بەڵام یۆئاب و ئەبیشەی دوای ئەبنێر کەوتن و خۆرئاوا بوو کاتێک گەیشتنە گردی ئەمما ئەوەی نزیکی گییەحە لەسەر ڕێگای چۆڵەوانی گبعۆن.
\v 25 جا نەوەی بنیامین لەدوای ئەبنێر کۆبوونەوە و بوون بە یەک کۆمەڵ و لەسەر گردێک ڕاوەستان.
\p 
\v 26 ئەبنێر هاواری لە یۆئاب کرد و گوتی: «ئایا هەتاهەتایە شمشێر خوێن دەڕێژێت؟ ئایا نازانیت کۆتاییەکەی تاڵ دەبێت؟ هەتا کەی بە جەنگاوەران ناڵێیت: ”واز لە ڕاونانی براکانتان بهێنن“؟»
\p 
\v 27 یۆئابیش گوتی: «بە خودای زیندوو، ئەگەر قسەت نەدەکرد، هەتا بەیانی هیچ پیاوێک وازی لە ڕاونانی براکەی نەدەهێنا.»
\p 
\v 28 پاشان یۆئاب فووی بە کەڕەنادا کرد و هەموو جەنگاوەران ڕاوەستان، ئیتر دوای ئیسرائیل نەکەوتن و نەگەڕانەوە بۆ جەنگ.
\p 
\v 29 ئینجا ئەبنێر و پیاوەکانی بە درێژایی ئەو شەوە بەناو عەراڤادا\f + \fr 2:29 \ft شیوێک بوو لە دەریاچەی جەلیلەوە هەتا دەریای مردوو.‏\f* ڕۆیشتن و لە ڕووباری ئوردون پەڕینەوە و بەناو بیترۆندا ڕۆیشتن و هاتن بۆ مەحەنەیم.
\p 
\v 30 یۆئابیش لە ڕاونانی ئەبنێر گەڕایەوە و هەموو جەنگاوەرانی کۆکردەوە. بێجگە لە عەساهێل، نۆزدە پیاو لە خزمەتکارەکانی داود ون بوون،
\v 31 بەڵام پیاوەکانی داود لەو بنیامینییانەی کە لەگەڵ ئەبنێر بوون سێ سەد و شەست کەسیان لێ کوشتبوون.
\v 32 ئینجا عەساهێلیان هەڵگرت و لە گۆڕەکەی باوکی کە لە بێت‌لەحمە ناشتیان و یۆئاب و پیاوەکانیشی بە درێژایی ئەو شەوە ڕۆیشتن و لە بەرەبەیان گەیشتنە حەبرۆن.
\c 3
\p 
\v 1 جەنگ لەنێوان بنەماڵەی شاول و ماڵی داود درێژەی کێشا، هەتا دەهات داود بەهێزتر دەبوو، بنەماڵەی شاولیش هەتا دەهات لاوازتر دەبوون.
\b
\li4 
\v 2 داود لە حەبرۆن چەند کوڕێکی بوو:
\b
\li1 کوڕە نۆبەرەکەی ئەمنۆن بوو کە لە ئەحینۆعەمی یەزرەعیلی بوو؛
\li1 
\v 3 دووەمیان کیلئیاڤ لە ئەبیگایل بوو کە بێوەژنەکەی نابالی کارمەلی بوو؛
\li1 سێیەمیان ئەبشالۆمی\f + \fr 3:3 \ft ئەبشالۆم: ناوێکی عیبرییە بە واتای باوکی ئاشتی، بەڵام ناکۆکی لەگەڵ داودی باوکی هەبوو و سەرکردایەتی یاخیبوونێکی کرد لە دژی. بۆ زانیاری زیاتر بڕوانە بەشەکانی 13‏–18 و زەبوورەکان 3.‏\f* کوڕی مەعکای کچی تەلمەی پاشای گەشوور بوو؛
\li1 
\v 4 چوارەمیان ئەدۆنیای کوڕی حەگیس بوو؛
\li1 پێنجەمیان شەفەتیای کوڕی ئەبیتەل بوو؛
\li1 
\v 5 شەشەمیان یەترعام لە عەگلای ژنی داود بوو.
\b
\li4 ئەمانە لە حەبرۆن بۆ داود لەدایک بوون.
\s1 ئەبنێر دەچێتە پاڵ داود
\p 
\v 6 ئەوە بوو کاتێک جەنگ لەنێوان بنەماڵەی شاول و ماڵی داود بەرپا بوو، ئەبنێر پێگەی خۆی لەناو بنەماڵەی شاول بەهێز دەکرد.
\v 7 شاول کەنیزەیەکی هەبوو ناوی ڕیچپای کچی ئەییا بوو، ئیشبۆشەتیش بە ئەبنێری گوت: «بۆچی لەگەڵ کەنیزەکەی باوکم جووتبوویت؟»
\p 
\v 8 ئەبنێر بە قسەکەی ئیشبۆشەت زۆر تووڕە بوو و گوتی: «ئایا من سەگێکم لە خزمەتی یەهودا؟ هەتا ئەمڕۆ من دڵسۆز بووم لەگەڵ ماڵی شاولی باوکت و لەگەڵ براکانی و هاوڕێیەکانی، هەروەها تۆم نەداوەتە دەست داودەوە. تۆش بەهۆی پەیوەندیم بەو ژنەوە گوناهبارم دەکەیت؟
\v 9 با خودا توندترین سزای ئەبنێر بدات، ئەگەر من پاڵپشتی داود نەکەم و سوێندەکەی یەزدان نەهێنمە دی،
\v 10 بۆ گواستنەوەی پاشایەتییەکە لە بنەماڵەی شاولەوە، هەروەها دامەزراندنی تەختی داود لە ئیسرائیل و یەهودا، لە دانەوە هەتا بیری شابەع\f + \fr 3:10 \ft واتا لە باکووری ئیسرائیل هەتا باشوور.‏\f*.»
\v 11 ئیتر ئیشبۆشەتیش نەیتوانی بە یەک وشە وەڵامی ئەبنێر بداتەوە، چونکە لێی دەترسا.
\p 
\v 12 ئینجا ئەبنێر نێردراوی بۆ لای داود نارد بۆ ئەوەی بە ناوی ئەوەوە بڵێن: «ئەم خاکە هی کێیە؟» هەروەها بڵێن: «پەیمانی خۆتم لەگەڵدا ببەستە، ئەوەتا منیش دەستم لەگەڵتدایە بۆ ئەوەی هەموو ئیسرائیل بۆ خۆت بگەڕێنیتەوە.»
\p 
\v 13 داودیش گوتی: «باشە، من پەیمانی خۆمت لەگەڵدا دەبەستم، بەڵام یەک شتت لێ داوا دەکەم، ئەویش ئەوەیە: کاتێک دێیت بۆ ئەوەی بمبینیت، ئەگەر میخەلی کچی شاول لەگەڵ خۆتدا نەهێنیت، ئەوا ڕووی من نابینیت.»
\v 14 ئینجا داود نێردراوی بۆ لای ئیشبۆشەتی کوڕی شاول نارد و گوتی: «میخەلی ژنم بدەوە کە بە سەد پێستی سەری ئەندامی نێرینەی فەلەستییەکان لە خۆمم مارە کردووە.»
\p 
\v 15 لەبەر ئەوە ئیشبۆشەت ناردی و لە مێردەکەی وەریگرتەوە، لە پەلتیێلی کوڕی لایش.
\v 16 مێردەکەی لەگەڵی دەڕۆیشت و بەدوایدا دەگریا هەتا گەیشتە بەحوریم. ئینجا ئەبنێر پێی گوت: «بڕۆ، بگەڕێوە!» ئەویش گەڕایەوە.
\p 
\v 17 پاشان ئەبنێر لەگەڵ پیرانی ئیسرائیل قسەی کرد و گوتی: «ئێوە لەمێژە داوای داودتان دەکرد ببێتە پاشاتان،
\v 18 کەواتە ئێستا ئەوە بکەن! لەبەر ئەوەی یەزدان بە داودی فەرمووە: ”من بە دەستی داودی بەندەم ئیسرائیلی گەلم لە دەست فەلەستییەکان و سەرجەم دوژمنەکانیان ڕزگار دەکەم.“»
\p 
\v 19 هەروەها ئەبنێر لەگەڵ بنیامینییەکان قسەی کرد. پاشان ئەبنێر چوو بۆ ئەوەی لە حەبرۆن لەگەڵ داود قسە بکات دەربارەی هەموو ئەوەی ئیسرائیل و هەموو بنەماڵەی بنیامین پەسەندیان کردووە.
\v 20 کاتێک ئەبنێر لەگەڵ بیست پیاو هاتە حەبرۆن بۆ لای داود، داود خوانێکی ساز کرد بۆ ئەبنێر و ئەو پیاوانەی لەگەڵیدا بوون.
\v 21 ئەبنێر بە داودی گوت: «هەڵدەستم و دەڕۆم، تاکو هەموو ئیسرائیل بۆ پاشای گەورەم کۆبکەمەوە، بۆ ئەوەی پەیمانت لەگەڵدا ببەستن و تۆش بەپێی هەموو ئەوانەی کە دڵت ئارەزووی دەکات فەرمانڕەوایی بکەیت.» داودیش ئەبنێری بەڕێکرد و ئەویش بە سەلامەتی ڕۆیشت.
\s1 کوشتنی ئەبنێر لەلایەن یۆئابەوە
\p 
\v 22 لەو کاتەدا یۆئاب و پیاوانی داود لە پەلامارێک دەگەڕانەوە و دەستکەوتێکی زۆریان لەگەڵ خۆیاندا هێنابوو. بەڵام ئەبنێر لە حەبرۆن لەگەڵ داود نەبوو، چونکە بەڕێی کردبوو و بە سەلامەتی ڕۆیشتبوو.
\v 23 کاتێک یۆئاب و هەموو ئەو لەشکرەی لەگەڵی بوو هاتن، بە یۆئابیان ڕاگەیاند و گوتیان: «ئەبنێری کوڕی نێر هات بۆ لای پاشا و ئەویش بەڕێی کرد و بە سەلامەتی ڕۆیشت.»
\p 
\v 24 لەبەر ئەوە یۆئاب بۆ لای پاشا چووە ژوورەوە و گوتی: «چیت کرد؟ ئەبنێر هات بۆ لات، بۆچی بەڕێت کرد بڕوات؟ ئێستا ڕۆیشتووە!
\v 25 تۆ ئەبنێری کوڕی نێر دەناسیت؛ تەنها بۆ ئەوە هاتووە فریوت بدات و چاودێریی جوڵانەوەت بکات و بە هەموو کارەکانت بزانێت.»
\p 
\v 26 کاتێک یۆئاب داودی بەجێهێشت، چەند نێردراوێکی بەدوای ئەبنێردا نارد و لە ئەمباراوی سیرادا گەڕاندیانەوە، بەڵام داود ئاگای لەمە نەبوو.
\v 27 کاتێک ئەبنێر گەڕایەوە حەبرۆن، یۆئاب بۆ ئەوەی بە نهێنی قسەی لەگەڵدا بکات بردییە کەناری دەروازەکەوە و لەوێدا لە تۆڵەی خوێنی عەساهێلی برای سکی هەڵدڕی و کوشتی.
\p 
\v 28 پاشان داود ئەمەی بیستەوە و گوتی: «من خۆم و پاشایەتییەکەم هەتاهەتایە لای یەزدان لە خوێنی ئەبنێری کوڕی نێر بێبەرین.
\v 29 با لە ملی یۆئاب و هەموو ماڵی باوکی بێت! با لە ماڵی یۆئاب زامی درێژخایەن و گەڕوگولی\f + \fr 3:29 \ft گەڕوگول: نەک تەنها گولی، بەڵام ئەم وشەیە بۆ چەند نەخۆشییەکی جیاوازی پێست بەکارهاتووە.‏\f* و دارشەقە بەدەست و بە شمشێر کوژراو و برسی نان نەبڕێتەوە.»
\p 
\v 30 (یۆئاب و ئەبیشەی برای، ئەبنێریان کوشت، چونکە ئەو عەساهێلی برایانی لە گبعۆن لە جەنگدا کوشتبوو.)
\p 
\v 31 ئینجا داود بە یۆئاب و هەموو گەل و ئەوانەی لەگەڵیدا بوون، پێی گوتن: «جلەکانتان لەبەر خۆتان دابدڕن و جلوبەرگی گوش\f + \fr 3:31 \ft لە کاتی ماتەمگێڕان و تۆبەکردندا جلوبەرگی لە گوش دروستکراویان لەبەرکردووە کە ئەزیەتی پێستیانی داوە.‏\f* بپۆشن و لەبەردەم ئەبنێردا شیوەن بگێڕن.» داودی پاشاش لەدوای دارەمەیتەکە\f + \fr 3:31 \ft یان دارەبازەکە.‏\f* دەڕۆیشت.
\v 32 ئەبنێریان لە حەبرۆن ناشت و پاشاش بە دەنگی بەرز لەسەر گۆڕی ئەبنێر گریا. هەموو گەلیش گریان.
\p 
\v 33 هەروەها پاشا بۆ ئەبنێر لاواندییەوە و گوتی:
\q1 «ئایا دەبێت ئەبنێر وەک چۆن گێلێک دەمرێت ئاوا بمرێت؟
\q2 
\v 34 دەستەکانت نەبەسترابوونەوە و
\q2 پێیەکانت بە زنجیر کۆت نەکرابوون.
\q1 کەوتی، هەروەک یەکێک لەبەردەم بەدکاران کەوتبێت.»
\p جا هەموو گەل دەستیان بە گریان کردەوە بۆی.
\p 
\v 35 ئیتر هەموو گەل هاتن بۆ ئەوەی نان بدەنە داود و بیخوات. هێشتا ڕۆژ بوو، بەڵام داود سوێندی خوارد: «با خودا توندترین سزام بدات، ئەگەر پێش خۆرئاوابوون نان یان هەر شتێکی دیکە بخۆم.»
\p 
\v 36 هەموو گەل زانییان و لەلایان پەسەند بوو، هەروەها هەموو ئەو شتانەی کە پاشا کردی لەلایەن هەموو گەلەوە پەسەند بوو.
\v 37 ئینجا لەو ڕۆژەدا هەموو گەل و هەموو ئیسرائیل زانییان کە کوشتنی ئەبنێری کوڕی نێر لەلایەن پاشاوە نەبوو.
\p 
\v 38 پاشا بە خزمەتکارەکانی گوت: «ئایا نازانن ئەمڕۆ لە ئیسرائیلدا میرێک و گەورە پیاوێک کەوتووە؟
\v 39 ئەمڕۆش، هەرچەندە من پاشا دەستنیشانکراوەکەم، بەڵام لاوازم و ئەم کوڕانەی چەرویا لە من بەهێزترن. یەزدان خراپەکار بەپێی خراپەکەی سزا دەدات!»
\c 4
\s1 کوشتنی ئیشبۆشەت
\p 
\v 1 کاتێک ئیشبۆشەتی کوڕی شاول بیستییەوە کە ئەبنێر لە حەبرۆن کوژراوە، دەستی شل بوو و هەموو ئیسرائیل ترسیان لێ نیشت.
\v 2 کوڕەکەی شاول دوو پیاوی هەبوو کە سەردەستەی چەتەکان بوون، یەکێکیان ناوی بەعەنا و ئەوی دیکەیان ناوی ڕێکاب بوو، هەردووکیان کوڕی ڕیمۆنی بئێرۆتی بوون کە لە نەوەی بنیامین بوو. بئێرۆت لەسەر بنیامین دادەنرێت،
\v 3 چونکە بئێرۆتییەکان بۆ گیتەیم هەڵاتبوون و ئاوارەی ئەوێ بوون، هەتا ئەمڕۆ لەوێن.
\p 
\v 4 (یۆناتانی کوڕی شاولیش کوڕێکی هەبوو کە هەردوو قاچی شەل بوون. کاتێک هەواڵی شاول و یۆناتان لە یەزرەعیلەوە گەیشت تەمەنی پێنج ساڵان بوو، ئیتر دایەنەکەی هەڵیگرت و هەڵات، بەڵام لەبەر ئەوەی بە پەلە بوو بۆ هەڵاتن، منداڵەکە کەوت و شەل بوو، ناویشی مەفیبۆشەت بوو.)
\p 
\v 5 کوڕەکانی ڕیمۆنی بئێرۆتی ڕێکاب و بەعەنا ڕۆیشتن و لە گەرمەی ڕۆژدا خۆیان بە ماڵی ئیشبۆشەتدا کرد کە سەرخەوی نیوەڕۆی دەشکاند.
\v 6 چوونە ناو ماڵەکەوە بە بیانووی ئەوەی بارە گەنم ببەن، شمشێرێکیان لە سکی دا. پاشان ڕێکاب و بەعەنای برای دەرباز بوون.
\p 
\v 7 لە کاتی هاتنە ژوورەوەیان بۆ ناو ماڵەکە ئەو لەسەر قەرەوێڵەکەی لە ژووری نوستنەکەی پاڵکەوتبوو، جا لێیاندا و کوشتیان، سەریان بڕی و سەرەکەیان برد، بە درێژایی ئەو شەوە بەناو عەراڤادا ڕۆیشتن.
\v 8 سەری ئیشبۆشەتیان هێنایە حەبرۆن، بۆ لای داودی پاشا، پێیان گوت: «ئەوەتا ئەوە سەری ئیشبۆشەتی کوڕی شاولی دوژمنی تۆیە ئەوەی دەیویست بتکوژێت. یەزدانیش ئەمڕۆ تۆڵەی پاشای گەورەی منی لە شاول و نەوەکەی کردووەتەوە.»
\p 
\v 9 داودیش وەڵامی ڕێکاب و بەعەنای برای دایەوە کە کوڕەکانی ڕیمۆنی بئێرۆتین و پێی گوتن: «بە یەزدانی زیندوو، ئەوەی ژیانی منی لە هەموو تەنگانەیەک دەرباز کرد،
\v 10 کاتێک یەکێک هەواڵی پێدام و گوتی: ”شاول مردووە“ و خۆی بە مزگێنیدەر دەزانی، گرتم و لە چیقلەگ کوشتم، بەوە موژدانەکەیم دایەوە.
\v 11 ئەی دەبێت ئەمەیان چەند زۆرتر بێت ئەگەر دوو پیاوی بەدکار پیاوێکی ڕاستودروست لەناو ماڵەکەی خۆیدا و لەسەر قەرەوێڵەکەی بکوژن. ئێستاش ئایا داوای خوێنەکەی ئەوتان لێ نەکەم و لەسەر زەوی نەتانسڕمەوە؟»
\p 
\v 12 جا داود فەرمانی بە خزمەتکارەکان کرد و ئەوانیان کوشت، دەست و پێیان بڕین، لەلای گۆمەکەی حەبرۆن هەڵیانواسین. بەڵام سەری ئیشبۆشەتیان بردە حەبرۆن و لە گۆڕەکەی ئەبنێردا ناشتیان.
\c 5
\s1 دەستنیشانکردنی پاشای هەموو ئیسرائیل
\p 
\v 1 هەموو هۆزەکانی ئیسرائیل هاتنە حەبرۆن بۆ لای داود و گوتیان: «ئەوەتا ئێمە لە گۆشت و خوێنی تۆین.
\v 2 لە ڕابردوودا کاتێک شاول پاشامان بوو، تۆ ڕابەرایەتی سوپای ئیسرائیلت دەکرد، یەزدانیش پێی فەرموویت: ”تۆ شوانایەتی ئیسرائیلی گەلەکەم دەکەیت و دەبیتە فەرمانڕەوایان.“»
\p 
\v 3 هەروەها هەموو پیرانی ئیسرائیل هاتنە حەبرۆن بۆ لای پاشا، داودی پاشاش لەبەردەم یەزدان لە حەبرۆن پەیمانی لەگەڵدا بەستن، داودیان بە پاشای ئیسرائیل دەستنیشان کرد.
\p 
\v 4 داود تەمەنی سی ساڵ بوو کاتێک بوو بە پاشا، چل ساڵ پاشایەتی کرد.
\v 5 حەوت ساڵ و شەش مانگ لە حەبرۆن پاشایەتی یەهودای کرد، سی و سێ ساڵیش لە ئۆرشەلیم پاشایەتی هەموو ئیسرائیل و یەهودای کرد.
\s1 داگیرکردنی ئۆرشەلیم
\p 
\v 6 پاشا و پیاوەکانی چوونە ئۆرشەلیم بۆ شەڕکردن لە دژی یەبوسییەکانی دانیشتووانی خاکەکە. ئەوانیش بە داودیان گوت: «تۆ نایەیتە ژوورەوە بۆ ئێرە، تەنانەت نابینا و شەلەکان ڕێگات لێ دەگرن.» وا بیریان کردەوە: «داود ناتوانێت بێت بۆ ئێرە.»
\v 7 بەڵام داود دەستی بەسەر قەڵای سییۆندا\f + \fr 5:7 \ft مەبەستی لە شاری ئۆرشەلیم (قودس)ە. هەروەها ناوی دیکەشی هەیە: سییۆن، زایۆن.‏\f* گرت، کە ئێستا بە شاری داود ناسراوە.
\p 
\v 8 جا لەو ڕۆژەدا داود گوتی: «هەرکەسێک سەربکەوێت بۆ بەزاندنی یەبوسییەکان، دەبێت بگاتە کارێزەکە و ئەو شەل و کوێرانە بکوژێت کە ناحەزی داودن\f + \fr 5:8 \ft بڕوانە \xt یەکەم پوختەی مێژوو 11‏:6‏\xt*\ft ‏.‏\f*.» هەر لەبەر ئەوە دەڵێن: «”نابینا و شەل“ نایەنە ناو کۆشکەکەوە.»
\p 
\v 9 پاشان داود لە قەڵاکە نیشتەجێ بوو، ناوی لێنا شاری داود، چواردەورەکەی بنیاد نا، لە تەلانەکانەوە\f + \fr 5:9 \ft تەلان: بەرازاییەکانیان لە شێوەی پایە ڕێکخستووە، بۆ پاڵپشتی کۆشکی پاشا سوودی لێ وەرگیراوە.‏\f* بەرەو ناوەوە.
\v 10 هەروەها داود هەتا دەهات مەزنتر دەبوو، یەزدانی پەروەردگاری سوپاسالاریش لەگەڵی بوو.
\p 
\v 11 پاشان حیرامی پاشای هەرێمی سور چەند نێردراوێکی بۆ لای داود نارد لەگەڵ داری ئورز و دارتاش و نەقاڕ، کۆشکێکیان بۆ داود دروستکرد.
\v 12 ئینجا داود زانی کە یەزدان وەک پاشای ئیسرائیل جێگیری کردووە، پاشایەتییەکەشی لە پێناوی ئیسرائیلی گەلەکەیدا پایەدار کردووە.
\p 
\v 13 هەروەها داود پاش ئەوەی لە حەبرۆنەوە هاتە ئۆرشەلیم چەند کەنیزە و ژنێکی دیکەی هێنا، ئینجا کوڕ و کچی دیکەی داود لەدایک بوون.
\v 14 ئەمەش ناوی ئەو منداڵانەیەتی کە لە ئۆرشەلیم لەدایک بوون: شەموع، شۆڤاڤ، ناتان، سلێمان،
\v 15 ئیڤحار، ئەلیشوع، نەفەگ، یافیع،
\v 16 ئەلیشاماع، ئەلیاداع و ئەلیفەلەت.
\s1 بەزاندنی فەلەستییەکان
\p 
\v 17 کاتێک فەلەستییەکان بیستیانەوە کە داود بە پاشای ئیسرائیل دەستنیشان کراوە، هەموویان هاتن بۆ ئەوەی بەدوای داوددا بگەڕێن، بەڵام داود ئەمەی بیستەوە و دابەزی بۆ ناو قەڵاکە.
\v 18 فەلەستییەکان هاتبوون و لە دۆڵی ڕفایم بڵاو ببوونەوە.
\v 19 داودیش پرسیاری لە یەزدان کرد و گوتی: «ئایا بچم بۆ پەلاماردانی فەلەستییەکان؟ ئایا دەیاندەیتە دەستم؟»
\p یەزدانیش بە داودی فەرموو: «بڕۆ، چونکە بێگومان دەیاندەمە دەستت.»
\p 
\v 20 داود چوو بۆ بەعل‌پراچیم و لەوێ ئەوانی بەزاند و گوتی: «یەزدان دڕی بە دوژمنەکانم دا، وەک دڕپێدادانی ئاو.» لەبەر ئەوە ئەو شوێنە بە بەعل‌پراچیم ناو برا.\f + \fr 5:20 \ft بەعل‌پراچیم: لە عیبری بە واتای ئەو خوداوەندەی دڕپێدەدات.‏\f*
\v 21 هەروەها فەلەستییەکان لەوێدا بتەکانیان بەجێهێشت، داود و پیاوەکانیشی لایان بردن.
\p 
\v 22 ئینجا دووبارە فەلەستییەکان سەرکەوتنەوە و لە دۆڵی ڕفایم بڵاو بوونەوە.
\v 23 داودیش پرسیاری لە یەزدان کرد، ئەویش فەرمووی: «سەرمەکەوە، بەڵکو بسووڕێوە بۆ پشتیان و بەرامبەر بە دار بەلسەمەکان پەلاماریان بدە.
\v 24 کاتێک لەسەر دار بەلسەمەکانەوە گوێت لە دەنگی پێ بوو، لەو کاتەدا وریابە، چونکە یەزدان بۆ لێدانی ئۆردوگای فەلەستییەکان لەپێشتەوە ڕۆیشتووە.»
\v 25 داودیش هەروەک یەزدان فەرمانی پێ کرد ئاوای کرد، لە گبعۆنەوە هەتا گەزەر لە فەلەستییەکانی دا.
\c 6
\s1 هێنانی سندوقی خودا بۆ ئۆرشەلیم
\p 
\v 1 دووبارە داود هەموو پیاوە هەڵبژاردەکانی ناو ئیسرائیلی کۆکردەوە، سی هەزار کەس بوون.
\v 2 ئینجا داود و هەموو ئەو پیاوانەی لەگەڵیدا بوون لە بەعلەی\f + \fr 6:2 \ft بەعلەی قیریەت یەعاریمە، بڕوانە \xt یەشوع 15‏:9‏\xt*\ft ‏.‏\f* یەهوداوە بەڕێکەوتن بۆ ئەوەی لەوێوە سندوقی خودا بهێننەوە، ئەو سندوقە کە ناوی لێنراوە «ناوەکە»، ناوی یەزدانی سوپاسالار، ئەوەی لەنێوان کەڕوبەکان\f + \fr 6:2 \ft لەنێوان کەڕوبەکان: جووتێک پەیکەری بوونەوەری ئاسمانی باڵدارە، لە شێوەی ئاژەڵ و مرۆڤدایە، بۆ پارێزگاریکردن لە سندوقی پەیمان دانرابوو، بڕوانە \xt دەرچوون 25‏:22 و عیبرانییەکان 9‏:5‏\xt*\ft ‏.‏\f* لەسەر تەخت دانیشتووە.
\v 3 سندوقی خودایان لە عەرەبانەیەکی نوێ بارکرد، لە ماڵی ئەبینادابەوە هەڵیانگرت، ئەوەی لە گردەکەیە. کوڕەکانی ئەبینادابیش، عوزا و ئەحیۆ عەرەبانە نوێیەکەیان لێدەخوڕی و
\v 4 لە ماڵی ئەبینادابەوە لەگەڵ سندوقی خودا بردیان. ئەحیۆ لەبەردەم سندوقەکەوە دەڕۆیشت،
\v 5 داود و هەموو بنەماڵەی ئیسرائیلیش بە هەموو توانایانەوە لەبەردەم یەزداندا ئاهەنگیان دەگێڕا، بە سروود و قیسارە و ساز و دەف و شەقشەقە و سەنج.
\p 
\v 6 کاتێک گەیشتنە سەر جۆخینەکەی\f + \fr 6:6 \ft جۆخین یان سەرخەرمان ئەو زەوییە تەرخانکراوەیە کە لەلایەن وەرزێر و جوتیارەوە بەکارهێنراوە بۆ کوتانی دانەوێڵە لەسەری لەدوای کۆکردنەوەی لە کێڵگە.‏\f* ناخون، عوزا دەستی بۆ سندوقی خودا درێژکرد و گرتی، چونکە گایەکان سەرسمیان دا.
\v 7 ئەو ساتە تووڕەیی یەزدان بەسەر عوزادا جۆشا و خودا لەوێ لەسەر هەڵەکەی لێیدا و هەر لەوێ لەلای سندوقی خودا مرد.
\p 
\v 8 داودیش تووڕە بوو، چونکە یەزدان بە تەواوی عوزای لەناوبرد، ئەو شوێنەش هەتا ئەمڕۆ بە پێرێز عوزا\f + \fr 6:8 \ft واتا هەڵکوتانە سەر عوزا.‏\f* ناودەبردرێت.
\p 
\v 9 ئەو ڕۆژە داود لە یەزدان ترسا و گوتی: «چۆن سندوقی یەزدان لەلای من بێت؟»
\v 10 لەبەر ئەوە داود نەیویست سندوقی یەزدان بگوازێتەوە بۆ شاری داود، بەڵکو بردییە ماڵی عوبێد ئەدۆمی گەتی.
\v 11 سێ مانگ سندوقی یەزدان لە ماڵی عوبێد ئەدۆمی گەتی مایەوە، یەزدانیش عوبێد ئەدۆم و هەموو ماڵەکەی بەرەکەتدار کرد.
\p 
\v 12 ئەوە بوو بە داودی پاشا ڕاگەیەنرا و گوترا: «بەهۆی سندوقی خوداوە یەزدان ماڵی عوبێد ئەدۆم و هەرچی هەیەتی بەرەکەتداری کردووە.» لەبەر ئەوە داود چوو بە خۆشییەوە سندوقی خودای لە ماڵی عوبێد ئەدۆمەوە هێنا بۆ شاری داود.
\v 13 لەدوای ئەوەی هەڵگرانی سندوقی یەزدان شەش هەنگاویان هەڵهێنا، گایەک و گوێرەکەیەکی قەڵەوی سەربڕی.
\v 14 داودیش ئێفۆدێکی کەتانی لەبەردا بوو، بە هەموو هێزییەوە لەبەردەم یەزداندا سەمای دەکرد.
\v 15 هەروەها داود و هەموو بنەماڵەی ئیسرائیل بە هوتاف و بە دەنگی کەڕەناوە سندوقی یەزدانیان سەرخست.
\p 
\v 16 کاتێک سندوقی یەزدان هاتە ناو شاری داود، میخەلی کچی شاول لە پەنجەرەکەوە سەیری کرد و بینی داودی پاشا لەبەردەم یەزدان هەڵدەبەزێتەوە و سەما دەکات، لە دڵی خۆیدا بە سووکی زانی.
\p 
\v 17 ئیتر سندوقی یەزدانیان هێنایە ژوورەوە، لە ناوەڕاستی ئەو چادرەی داود بۆی دامەزراندبوو لە شوێنی خۆی دایاننا، داود قوربانی سووتاندن و قوربانی هاوبەشی\f + \fr 6:17 \ft قوربانی هاوبەشی: ئەم قوربانییە هاودەمی قوربانی سووتاندن بوو. تەنها یەک کەس هەڵدەستا بە دابینکردنی ئەم قوربانییە، بەڵام لەگەڵ خەڵکی دیکە بەشی زۆری ئەم قوربانییەیان لەبەردەم خودا دەخوارد وەک هێمایەک بۆ پێکەوە ژیان. بڕوانە \xt لێڤییەکان 7‏:11‏-15.‏\xt*\ft ‏\f* لەبەردەم یەزداندا سەرخست.
\v 18 پاش ئەوەی داود لە پێشکەشکردنی قوربانی سووتاندنەکان و قوربانییەکانی هاوبەشی بووەوە، بە ناوی یەزدانی سوپاسالارەوە داوای بەرەکەتی بۆ گەل کرد.
\v 19 هەر یەکێک لە هەموو گەل، واتا تەواوی ئامادەبووانی کۆمەڵی ئیسرائیل، بە پیاو و بە ئافرەتەوە، کولێرەیەک و نانە خورمایەک و نانە کشمیشێکی بەسەریاندا دابەش کرد. ئینجا هەموو گەل هەریەکە و بۆ ماڵی خۆی گەڕایەوە.
\p 
\v 20 داودیش بۆ ئەوەی داوای بەرەکەت بۆ ماڵەکەی بکات گەڕایەوە ماڵەوە. میخەلی کچی شاول چووە پێشوازی داود و گوتی: «ئەمڕۆ پاشای ئیسرائیل چەند گەورە بوو کە بێ ئەوەی خۆی بپۆشێت لەبەردەم کەنیزەکانی خزمەتکارەکانی دەرکەوت، وەک ناکەس بەچەیەک کە خۆی نەپۆشێت!»
\p 
\v 21 داودیش بە میخەلی گوت: «ئەمە لەبەردەم یەزدان بوو، ئەوەی لە جێگای باوکت و هەموو ماڵەکەی هەڵیبژاردم بۆ ئەوەی بمکاتە فەرمانڕەوای ئیسرائیلی گەلی یەزدان. لەبەر ئەوە لەبەردەم یەزدان ئاهەنگ دەگێڕم.
\v 22 لەوەش زیاتر لە پایەی خۆم دێنمە خوارەوە و خۆم نزم دەکەمەوە، بەڵام لەلای ئەو کەنیزانەی باست کردن، ئەوا ڕێزدار دەبم.»
\p 
\v 23 میخەلی کچی شاولیش هەتا ئەو ڕۆژەی مرد منداڵی نەبوو.
\c 7
\s1 بەڵێنی خودا بۆ داود
\p 
\v 1 پاش ئەوەی پاشا لە کۆشکەکەیدا نیشتەجێ بوو، هەروەها یەزدانیش لە هەموو دوژمنەکانی چواردەوری حەواندییەوە،
\v 2 پاشا بە ناتانی پێغەمبەری گوت: «من لێرە لە کۆشکێکی دروستکراو بە داری ئورز نیشتەجێم و سندوقی خوداش لەناو چادرێکدا نیشتەجێیە.»
\p 
\v 3 ناتانیش بە پاشای گوت: «بڕۆ هەموو ئەوەی لە دڵتدایە بیکە، چونکە یەزدانت لەگەڵە.»
\p 
\v 4 بەڵام هەر لەو شەوەدا فەرمایشتی یەزدان بۆ ناتان هات:
\pm 
\v 5 «بڕۆ بە داودی بەندەم بڵێ: ”یەزدان ئەمە دەفەرموێت: ئایا تۆ ئەو کەسەی کە ماڵێک بۆ نیشتەجێبوونم بنیاد دەنێت؟
\v 6 لەو ڕۆژەوەی کە نەوەی ئیسرائیلم لە میسر دەرهێناوە هەتا ئەمڕۆ لە ماڵدا نیشتەجێ نەبووم، بەڵکو هاتوچۆم لەناو چادر و نشینگەدا بووە.
\v 7 لە هەموو هاتوچۆکردنەکانم لەگەڵ هەموو نەوەی ئیسرائیل، ئایا هیچ قسەیەکم کرد لەگەڵ یەکێک لە ڕابەرەکانی ئیسرائیل، ئەوانەی فەرمانم پێکردن بۆ ئەوەی شوانایەتی گەلی ئیسرائیلم بکەن، ’بۆچی ماڵێکتان لە داری ئورز بۆ دروستنەکردووم؟‘ “
\pm 
\v 8 «ئێستاش ئاوا بە داودی بەندەم بڵێ: ”یەزدانی سوپاسالار ئەمە دەفەرموێت: من تۆم لە شوانایەتی مەڕەوە برد و تۆم کردە فەرمانڕەوای ئیسرائیلی گەلەکەی خۆم.
\v 9 لەگەڵتدا بووم بۆ هەر شوێنێک چووبیت و هەموو دوژمنەکانی تۆم لەبەردەمت بڕیوەتەوە. ئێستا ناوێکی گەورەت بۆ دروستدەکەم وەک ناوی گەورەکان کە لەسەر زەوین.
\v 10 شوێنێکیش بۆ ئیسرائیلی گەلەکەم دیاری دەکەم و دەیچێنم و لە جێی خۆی نیشتەجێی دەکەم، ئیتر وەک پێشوو بێزار ناکرێن و خەڵکانی ناڕەوا نایانچەوسێننەوە،
\v 11 وەک ئەو سەردەمانەی ڕابەرم لەسەر ئیسرائیلی گەلەکەم دادەنا. منیش تۆ لە دەستی هەموو دوژمنەکانت دەحەوێنمەوە.
\pm «”یەزدان پێت ڕادەگەیەنێت کە یەزدان خۆی ماڵەکەت جێگیر دەکات.
\v 12 کاتێک ژیانت تەواو دەبێت و دەچیتە پاڵ باوباپیرانت، من وەچەکەت دادەمەزرێنم، ئەوەی لەدوای خۆت لە پشتی تۆوە دێت، پاشایەتییەکەی جێگیر دەکەم.
\v 13 ئەو ماڵێک بۆ ناوی من بنیاد دەنێت و منیش بۆ هەتاهەتایە تەختی پاشایەتییەکەی جێگیر دەکەم.
\v 14 من دەبمە باوکی ئەو و ئەویش دەبێتە کوڕی من. ئەگەر ستەم بکات، ئەوا بە گۆچانی خەڵک و لێدانی نەوەی ئادەم تەمبێی دەکەم.\f + \fr 7:14 \ft مەبەستی لەوەیە کە نەتەوەی دیکە بەسەریدا زاڵ دەکات و لەلایەن ئەوانەوە دەچەوسێنرێتەوە.‏\f*
\v 15 بەڵام خۆشەویستییە نەگۆڕەکەم بۆ ئەو داناماڵرێت وەک چۆن بۆ شاول داماڵرا، ئەوەی لەپێش تۆ ڕامماڵی.
\v 16 بۆ هەتاهەتایەش ماڵەکەت و پاشایەتییەکەت لەبەردەممدا ئاسوودە دەبن، هەتاهەتایە تەختەکەت جێگیر دەبێت.“»
\p 
\v 17 ئینجا ناتان بەپێی وشەکانی ئەم سروشە\f + \fr 7:17 \ft ‏فەرموودەیەکی خودایە کە لە ڕێگای ڕۆحی پیرۆزەوە بۆ مرۆڤ هاتبێت.‏\f* قسەی لەگەڵ داود کرد.
\s1 نزای داود
\p 
\v 18 ئەوسا داودی پاشا چوو و لەبەردەم یەزدان دانیشت و گوتی:
\pm «ئەی یەزدانی باڵادەست، من کێم و بنەماڵەکەی من کێیە کە تۆ بەم پایەیەت گەیاندووم؟
\v 19 ئەی یەزدانی باڵادەست، تۆ هێشتا ئەمەت بە کەم زانی، هەر لەبەر ئەوە هاتیت بۆ ئەوەی سەبارەت بە ئاییندەی ماڵی ئەم بەندەیەت بەڵێنی گەورەتر بدەیت؟ ئەی یەزدانی باڵادەست، ئایا بە گشتی لەگەڵ مرۆڤ بەم شێوەیە هەڵسوکەوت دەکەیت؟
\pm 
\v 20 «ئیتر داود چی زیاتر بە تۆ بڵێت؟ ئەی یەزدانی باڵادەست، چونکە تۆ بەندەکەی خۆت دەناسیت.
\v 21 تۆ لە پێناوی بەڵێنەکەت و بە خواستی دڵی خۆت ئەم کارە گەورەیەت کردووە بۆ ئەوەی لەلای بەندەکەت بزانرێت.
\pm 
\v 22 «ئەی یەزدانی باڵادەست، لەبەر ئەمە، چەند مەزنیت! کوا هاوتای تۆ؟ بێجگە لە تۆ خودایەک نییە لە هەموو ئەوەی بە گوێی خۆمان گوێمان لێبووە.
\v 23 هەروەها کێ وەک ئیسرائیلی گەلەکەی تۆیە؟ ئەم گەلە تاکە نەتەوەیەکە لە زەویدا کە خودا هات بۆ ئەوەی گەلێک بۆ خۆی بکڕێتەوە، بۆ ئەوەی ناوێک بۆ خۆی دابنێت و کاری مەزن و سامناک بکات، بە دەرکردنی نەتەوەکان و خوداوەندەکانیان لەبەردەم گەلەکەت، ئەوەی لە میسر بۆ خۆت کڕیتەوە.
\v 24 ئەی یەزدان، تۆ گەلی ئیسرائیلت جێگیر کردووە کە بۆ هەتاهەتایە ببنە گەلی خۆت و تۆش بوویتە خودایان.
\pm 
\v 25 «ئەی یەزدانی پەروەردگار، ئێستاش ئەو بەڵێنەی سەبارەت بە بەندەکەت و بە ماڵەکەی فەرمووت، بۆ هەتاهەتایە بیهێنە دی. هەروەک فەرمووت ئاوا بکە.
\v 26 با ناوت هەتاهەتایە مەزن بێت و بگوترێت: ”یەزدانی سوپاسالار خودای ئیسرائیلە!“ با ماڵی داودی بەندەشت لەبەردەمتدا جێگیر بێت.
\pm 
\v 27 «ئەی یەزدانی سوپاسالار، خودای ئیسرائیل، بۆ بەندەکەی خۆتت ئاشکرا کرد و فەرمووت: ”ماڵێکت بۆ بنیاد دەنێم.“ لەبەر ئەمە بەندەکەت ئازایەتی لە خۆیدا بینی ئەم نزایەت بۆ بکات.
\v 28 ئەی یەزدانی باڵادەست، تۆ خودایت و بەڵێنەکانت متمانەپێکراون، بەڵێنی ئەم چاکەیەت بە بەندەکەت داوە.
\v 29 ئێستاش ڕەزامەندی بفەرموو بۆ ئەوەی ماڵی بەندەکەت بەرەکەتدار بکەیت، تاوەکو بۆ هەتاهەتایە لەبەردەمت بێت، ئەی یەزدانی باڵادەست چونکە تۆ فەرمووت، ئینجا با لە بەرەکەتی تۆوە بۆ هەتاهەتایە بنەماڵەی بەندەکەت بەرەکەتدار بێت.»
\c 8
\s1 سەرکەوتنەکانی داود\f + \fr 8:0 \ft بڕوانە \xt زەبوورەکان 60‏:11‏-12‏\xt*\ft ‏.‏\f*
\p 
\v 1 ئەوە بوو پاش ئەمە داود فەلەستییەکانی بەزاند و زەلیلی کردن، مەسەگ ئەممای لە فەلەستییەکان سەند.
\p 
\v 2 هەروەها داود مۆئابییەکانیشی بەزاند. ئەوانی لەسەر زەوی پاڵخست و بە گوریس پێوانەی کردن، بە پێوانەی دوو گوریس خەڵکەکەی کوشت و بە پێوانەی گوریسێکیش خەڵکی بە زیندوویی هێشتەوە.\f + \fr 8:2 \ft داود بە هەڕەمەکی دوو لەسەر سێی مۆئابییەکان کوشت و یەک لەسەر سێی لێ هێشتنەوە.‏\f* ئینجا مۆئابییەکان هاتنە ژێر دەسەڵاتی داود و سەرانەیان بۆ دەهێنا.
\p 
\v 3 هەروەها داود هەدەدعەزەری کوڕی ڕەحۆڤی پاشای چۆڤای بەزاند، کاتێک چوو بۆ ئەوەی تاشەبەردەکەی یادەوەری لە کەناری ڕووباری فورات نۆژەن بکاتەوە.
\v 4 داود هەزار گالیسکە و حەوت هەزار گالیسکەسوار و بیست هەزار پیادەی بە دیل گرت، ئینجا داود جومگە پێی ئەسپی گالیسکەکانیانی بڕییەوە و تەنها سەد ئەسپی گالیسکەی هێشتەوە.
\p 
\v 5 کاتێک ئارامییەکانی دیمەشق بۆ یارمەتیدانی هەدەدعەزەری پاشای چۆڤا هاتن، داود بیست و دوو هەزار پیاوی لە ئارامییەکان کوشت.
\v 6 ئیتر داود لە شانشینی ئارامییەکانی دیمەشق سەربازگەی دانا، ئارامییەکانیش هاتنە ژێر دەسەڵاتی داود و سەرانەیان بۆ دەهێنا. داودیش ڕووی لە هەرکوێ دەکرد، یەزدان سەرکەوتووی دەکرد.
\p 
\v 7 پاشان داود قەڵغانە زێڕینەکانی ئەفسەرەکانی هەدەدعەزەری برد و هێنایە ئۆرشەلیم.
\v 8 هەروەها داودی پاشا بڕۆنزێکی زۆریشی لە تەڤەح و بێرۆتەی برد کە شارۆچکەی هەدەدعەزەر بوون.
\p 
\v 9 کاتێک تۆعوی پاشای حەمات بیستی کە داود هەموو سوپاکەی هەدەدعەزەری بەزاندووە،
\v 10 یۆرامی کوڕی نارد بۆ لای داودی پاشا بۆ ئەوەی لە سەلامەتی بپرسێت و پیرۆزبایی لێ بکات کە لەگەڵ هەدەدعەزەر جەنگاوە و بەزاندوویەتی، چونکە هەدەدعەزەر لە جەنگدا بوو لە دژی تۆعو. یۆرامیش لەگەڵ دەستی خۆیدا کەلوپەلی زێڕ و زیو و بڕۆنزی هێنابوو.
\p 
\v 11 داودی پاشا ئەمانەشی بۆ یەزدان تەرخان کرد لەگەڵ ئەو زێڕ و زیوانەی کە دەستی کەوتبوو لە هەموو ئەو نەتەوانەی ژێردەستەی کردبوون:
\v 12 لە ئەدۆم، مۆئاب، عەمۆن، فەلەستی و عەمالێق. هەروەها ئەو دەستکەوتەشی تەرخان کرد کە لە هەدەدعەزەری کوڕی ڕەحۆڤی پاشای چۆڤا دەستی کەوت.
\p 
\v 13 داود پاش گەڕانەوەی لە کوشتنی هەژدە هەزار ئەدۆمی لە دۆڵی خوێ\f + \fr 8:13 \ft دۆڵی خوێ: دەکەوێتە باشووری دەریای مردوو. بڕوانە زەبوورەکان 60.‏\f*، ناوبانگی بڵاو بووەوە.
\p 
\v 14 لە هەموو خاکی ئەدۆم سەربازگەی دانا و هەموو ئەدۆمییەکان هاتنە ژێر دەسەڵاتی داود. داود ڕووی لە هەرکوێ دەکرد، یەزدان سەرکەوتووی دەکرد.
\s1 کاربەدەستەکانی داود
\p 
\v 15 داود پاشایەتی هەموو ئیسرائیلی کرد، دادپەروەری و ڕاستودروستی بۆ هەموو گەلەکەی پەیڕەو کرد.
\v 16 یۆئابی کوڕی چەرویاش سوپاسالار بوو؛ یەهۆشافاتی کوڕی ئەحیلودیش تۆمارکار بوو؛
\v 17 سادۆقی کوڕی ئەحیتوڤ و ئەحیمەلەخی کوڕی ئەبیاتار کاهین بوون؛ سەرایا خامەی نهێنی\f + \fr 8:17 \ft ڕازپۆش.‏\f* بوو؛
\v 18 بەنایای کوڕی یەهۆیاداع فەرماندەی کریتی و پەلەتییەکان\f + \fr 8:18 \ft کریتییەکان و پەلەتییەکان دوو لەشکری ڕاهێنراو بوون لەسەر مەشقی سەربازی.‏\f* بوو؛ کوڕەکانی داودیش ڕاوێژکاری پاشا بوون.
\c 9
\s1 داود و مەفیبۆشەت
\p 
\v 1 داود پرسی: «ئایا کەسێک هەیە لە بنەماڵەی شاول هێشتا لە ژیاندا مابێت، بۆ ئەوەی لە پێناوی یۆناتاندا چاکەیەکی\f + \fr 9:1 \ft لە زۆر شوێنی کتێبی پیرۆزدا ئەم وشەیە بە «خۆشەویستی نەگۆڕ» وەرگێڕانی بۆ کراوە. بڕوانە دواوتار 5‏:10‏\f* لەگەڵدا بکەم؟»
\p 
\v 2 بەندەیەکی ماڵی شاول هەبوو ناوی چیڤا بوو، بانگیان کرد بۆ لای داود، ئیتر پاشا پێی گوت: «تۆ چیڤایت؟»
\p ئەویش گوتی: «بەڵێ، منی خزمەتکارتم.»
\p 
\v 3 پاشاش گوتی: «ئایا کەسێک نییە لە بنەماڵەی شاول هێشتا مابێت، بۆ ئەوەی چاکەی خودای لەگەڵدا بکەم؟»
\p چیڤاش بە پاشای گوت: «کوڕێکی یۆناتان هەیە کە هەردوو قاچی شەلە.»
\p 
\v 4 پاشاش پێی گوت: «لەکوێیە؟»
\p چیڤاش بە پاشای گوت: «لە ماڵی ماکیری کوڕی عەمیێلە لە لۆدەڤار.»
\p 
\v 5 ئینجا داودی پاشا ناردی و لە ماڵی ماکیری کوڕی عەمیێلەوە لە لۆدەڤار هێنایەوە.
\p 
\v 6 کاتێک مەفیبۆشەتی کوڕی یۆناتانی کوڕی شاول هات بۆ لای داود، بە ڕوودا کەوت و کڕنۆشی برد.
\p داودیش گوتی: «مەفیبۆشەت؟»
\p ئەویش وەڵامی دایەوە: «بەڵێ، لە خزمەتدام.»
\p 
\v 7 داودیش پێی گوت: «مەترسە، چونکە بە دڵنیاییەوە لە پێناوی یۆناتانی باوکت چاکەت لەگەڵدا دەکەم و هەموو زەوییەکانی شاولی باپیرت بۆ دەگەڕێنمەوە، تۆش هەمیشە لەسەر خوانەکەی من نان دەخۆیت.»
\p 
\v 8 مەفیبۆشەتیش کڕنۆشی برد و گوتی: «بەندەکەی تۆ چییە هەتا ئاوڕ لە سەگێکی تۆپیوی وەک من بدەیتەوە؟»
\p 
\v 9 ئیتر پاشا چیڤای بەندەی شاولی بانگکرد و پێی گوت: «هەموو ئەوەی هی شاول و بنەماڵەکەی بوو، بە کوڕەزای گەورەکەتم داوە.
\v 10 خۆت و کوڕ و خزمەتکارەکانت لە زەوییەکەی کار دەکەن و بەروبوومەکەی دەهێنن هەتا نان بۆ کوڕەزای گەورەکەت دابین بکرێت بۆ خواردن. مەفیبۆشەتی کوڕەزای گەورەکەشت هەمیشە لەسەر خوانەکەم نان دەخوات.» چیڤا پازدە کوڕ و بیست خزمەتکاری هەبوو.
\p 
\v 11 چیڤاش بە پاشای گوت: «بەپێی هەموو ئەوەی پاشای گەورەم فەرمان بە خزمەتکارەکەی دەکات، خزمەتکارەکەت بەو جۆرە دەکات.» ئیتر مەفیبۆشەت وەک شازادەیەک لەسەر خوانەکەی داود نانی دەخوارد.
\p 
\v 12 مەفیبۆشەت کوڕێکی بچووکی هەبوو ناوی میکا بوو. هەروەها هەموو ئەوانەی لە ماڵی چیڤادا دەژیان خزمەتکاری مەفیبۆشەت بوون.
\v 13 مەفیبۆشەت لە ئۆرشەلیم نیشتەجێ بوو، چونکە هەمیشە لەسەر خوانی پاشا نانی دەخوارد و هەردوو قاچیشی شەل بوون.
\c 10
\s1 بەزاندنی عەمۆنییەکان
\p 
\v 1 دوای ماوەیەک پاشای عەمۆنییەکان مرد و حانوونی کوڕی لەدوای ئەو بوو بە پاشا.
\v 2 داود گوتی: «لەگەڵ حانوونی کوڕی ناحاش دڵسۆز دەبم، هەروەک چۆن باوکی لەگەڵم دڵسۆز بوو.» لەبەر ئەوە داود شاندێکی نارد بۆ ئەوەی سەرەخۆشی لە حانوون بکەن سەبارەت بە باوکی.
\p کاتێک خزمەتکارەکانی داود هاتنە خاکی عەمۆنییەکان،
\v 3 میرەکانی عەمۆنییەکان بە حانوونی گەورەیان گوت: «تۆ لەو باوەڕەدایت کە داود لەبەر ڕێزگرتن لە باوکت نێردراوی ناردووە بۆ ئەوەی سەرەخۆشیت لێ بکات؟ ئایا داود بۆ پشکنین و سەرەوژێرکردن و سیخوڕیکردن بەسەر شارەکەوە خزمەتکارەکانی خۆی نەناردووە بۆ لات؟»
\v 4 ئیتر حانوون خزمەتکارەکانی داودی گرت و نیوەی ڕیشی تاشین، جلەکانیشیان لە نیوەوە هەتا پاشەڵیانی دادڕی و بەڕەڵای کردن.
\p 
\v 5 کاتێک بە داود ڕاگەیەنرا، ئەویش چەند کەسێکی نارد بۆ پێشوازییان، چونکە پیاوەکان زۆر شەرمیان دەکرد، پاشاش گوتی: «هەتا ڕیشتان دێتەوە لە ئەریحا بمێننەوە، ئینجا بگەڕێنەوە.»
\p 
\v 6 کاتێک عەمۆنییەکان بینییان لەلایەن داودەوە قێزەون بوون، ناردیان و لە ئارامییەکانی بێت‌ڕەحۆڤ و چۆڤا بیست هەزار پیادەیان بەکرێ گرت، هەروەها پاشای مەعکا لەگەڵ هەزار پیاو و لە تۆڤ دوازدە هەزار پیاویان بەکرێ گرت.
\p 
\v 7 کاتێک داود ئەمەی بیستەوە، یۆئاب و هەموو سوپا شەڕکەرەکانی نارد.
\v 8 عەمۆنییەکان هاتنە دەرەوە و لە دەمی دەروازەی شارەکەیان بۆ جەنگ ڕیزیان بەست، بەڵام ئارامییەکانی چۆڤا و ڕەحۆڤ، لەگەڵ پیاوەکانی تۆڤ و مەعکا بە جیا لە دەشتودەر بوون.
\p 
\v 9 کاتێک یۆئاب بینی کە بەرەکانی جەنگ لەپێشی و لەپاشییەوەن، لە باشترین جەنگاوەرانی ئیسرائیل چەند هێزێکی هەڵبژارد، بۆ بەرەنگاربوونەوەی ئارامییەکان ڕیزی کردن.
\v 10 ئەو پیاوانەی کە مانەوە دایە دەست ئەبیشەیی برای و ئەویش بۆ بەرەنگاربوونەوەی عەمۆنییەکان ڕیزی کردن.
\v 11 یۆئاب گوتی: «ئەگەر ئارامییەکان لە من بەهێزتر بوون، ئەوا تۆ بەهانامەوە دێیت؛ بەڵام ئەگەر عەمۆنییەکان لە تۆ بەهێزتر بوون، ئەوا من بەهاناتەوە دێم.
\v 12 ئازابە و با بەهێز بین لە پێناوی گەلەکەمان و لە پێناوی شارەکانی خوداکەمان، یەزدانیش چی پێ باشە ئەوە دەکات.»
\p 
\v 13 ئینجا یۆئاب و ئەو لەشکرەی لەگەڵی بوون بۆ جەنگ، لە دژی ئارامییەکان چوونە پێشەوە، ئەوانیش لەبەردەمیدا هەڵاتن.
\v 14 کاتێک عەمۆنییەکان بینییان ئارامییەکان هەڵدەهاتن، ئەوانیش لەبەردەم ئەبیشەی هەڵاتن و چوونە ناو شارەکە. ئیتر یۆئاب لە شەڕی نەوەی عەمون گەڕایەوە و چوو بۆ ئۆرشەلیم.
\p 
\v 15 کاتێک ئارامییەکان بینییان لە بەرامبەر ئیسرائیل تێکشکاون، پێکەوە کۆمەڵیان بەست.
\v 16 ئینجا هەدەدعەزەر ناردی و ئارامییەکانی ئەوبەری ڕووباری فوراتی هێنا، ئەوانیش هاتن بۆ حێلام و شۆڤەخی سەرکردەی سوپاکەی هەدەدعەزەریش لەپێشیانەوە بوو.
\p 
\v 17 کاتێک بە داود ڕاگەیەنرا، ئەویش هەموو ئیسرائیلی کۆکردەوە و لە ڕووباری ئوردونەوە پەڕییەوە و چوو بۆ حێلام، ئارامییەکانیش بۆ بەرەنگاربوونەوەی داود ڕیزیان بەست و لە دژی جەنگان.
\v 18 بەڵام ئارامییەکان لەبەردەم ئیسرائیلدا هەڵاتن، داودیش حەوت سەد گالیسکەسوار و چل هەزار سەربازی پیادەی لە ئارامییەکان کوشت، هەروەها لە شۆڤەخی سەرکردەی سوپاکەی دا و هەر لەوێدا مرد.
\v 19 کاتێک هەموو پاشاکانی ژێردەستەی هەدەدعەزەر بینییان کە ئەوان لە بەرامبەر ئیسرائیل تێکشکاون، لەگەڵ ئیسرائیل ئاشت بوونەوە و بوونە ژێردەستەی ئیسرائیل.
\p ئیتر ئارامییەکان نەیانوێرا بەهانای عەمۆنییەکانەوە بچن.
\c 11
\s1 داود و بەتشەبەع
\p 
\v 1 لە بەهاری ساڵ، لە کاتی ڕۆیشتنی پاشاکان بۆ جەنگ، داود یۆئابی لەگەڵ هەموو خزمەتکارەکانی و هەموو سوپای ئیسرائیلدا نارد و عەمۆنییەکانیان تێکشکاند و ڕەبەیان گەمارۆ دا، بەڵام داود لە ئۆرشەلیم مایەوە.
\p 
\v 2 ئەوە بوو دەمەو ئێوارە داود لەسەر قەرەوێڵەکەی هەستا و لە سەربانی کۆشکی پاشا پیاسەی دەکرد، لە سەربانەوە ژنێکی بینی خۆی دەشوات، ژنێکی زۆر جوان بوو.
\v 3 داودیش پیاوێکی نارد بۆ سۆراغی ژنەکە و ئەویش پێی گوت: «ئەمە بەتشەبەعی کچی ئەلیعامە و ژنی ئوریای حیتییە.»
\v 4 ئینجا داود چەند نێردراوێکی نارد بۆ هێنانی، ژنەکەش لە خوێنلێچوونی مانگانەی پاک ببووەوە و هاتە لای داود، ئەویش لەگەڵی جووت بوو، پاشان ژنەکە گەڕایەوە بۆ ماڵەکەی خۆی.
\v 5 ژنەکە سکی پڕ بوو، ناردی و بە داودی ڕاگەیاند و گوتی: «سکم پڕە.»
\p 
\v 6 داودیش نێردراوی بۆ لای یۆئاب نارد و گوتی: «ئوریای حیتیم بۆ بنێرە.» یۆئابیش ئوریای بۆ لای داود نارد.
\v 7 کاتێک ئوریا هاتە لای، داود لە هەواڵی سەلامەتی یۆئاب و سوپا و چۆنیەتی سەرکەوتنی جەنگی پرسی.
\v 8 پاشان داود بە ئوریای گوت: «بگەڕێوە ماڵەکەت و قاچەکانت بشۆ.» جا ئوریا لە کۆشکی پاشا چووە دەرەوە، دوابەدوای ئەویش دیارییەک لەلایەن پاشاوە نێردرا بۆی.
\v 9 بەڵام ئوریا لە دەروازەی کۆشکی پاشادا لەگەڵ هەموو خزمەتکارەکانی گەورەکەیدا خەوت و نەگەڕایەوە ماڵەکەی خۆی.
\p 
\v 10 ئینجا بە داود ڕاگەیەنرا کە ئوریا نەگەڕاوەتەوە ماڵەوە. داودیش بە ئوریای گوت: «تۆ لە ڕێوە نەهاتوویت؟ ئەی بۆچی نەگەڕایتەوە ماڵەوە؟»
\p 
\v 11 ئوریاش بە داودی گوت: «سندوقەکە و ئیسرائیل و یەهودا لەناو چادردا نیشتەجێن، یۆئابی گەورەم لەگەڵ پیاوەکانی پاشام لە دەشتودەر چادریان هەڵداوە. ئایا منیش بچمەوە ماڵەکەم بخۆم و بخۆمەوە و لەگەڵ ژنەکەمدا پاڵ بکەوم؟ بە گیانی تۆ، دڵنیابە، من کاری وا ناکەم!»
\p 
\v 12 ئینجا داود بە ئوریای گوت: «ئەمڕۆش لێرە بمێنەرەوە و سبەینێ دەتنێرمەوە.» ئیتر ئوریا بۆ ئەو ڕۆژە و ڕۆژی دواتریش لە ئۆرشەلیمدا مایەوە.
\v 13 داود بانگی کرد، ئەویش لەگەڵیدا خواردی و خواردیەوە هەتا ئەوەی داود ئەوی مەست کرد، بەڵام ئوریا بۆ ئێوارە ڕۆیشت تاوەکو لەگەڵ خزمەتکارەکانی گەورەکەیدا لە جێگاکەی بنووێت و نەچێتەوە ماڵەکەی خۆی.
\p 
\v 14 بۆ بەیانی داود نووسراوێکی بۆ یۆئاب نووسی و بە دەستی ئوریادا ناردی.
\v 15 لە نووسراوەکەشدا نووسیبووی و دەیگوت: «ئوریا بخەنە ناو گەرمەی شەڕەکەوە و لە پشتی بکشێنەوە هەتا لێی دەدرێت و دەکوژرێت.»
\p 
\v 16 جا کاتێک یۆئاب گەمارۆی شارەکەی دابوو، ئوریای لەو شوێنە دانا کە دەیزانی پیاوە بەهێزەکان لەوێن.
\v 17 لەو کاتەدا پیاوانی شارەکە هاتنە دەرەوە و لە دژی یۆئاب جەنگان، ژمارەیەک لە خزمەتکارەکانی داود کەوتن و ئوریای حیتیش کوژرا.
\p 
\v 18 یۆئابیش نێردراوێکی نارد و هەموو کاروبارەکانی جەنگی بە داود ڕاگەیاند.
\v 19 فەرمانیشی بە نێردراوەکە کرد و گوتی: «پاش ئەوەی وردەکارییەکانی جەنگەکە بۆ پاشا باس دەکەیت،
\v 20 ئەگەر تووڕەیی پاشا جۆشا و گوتی: ”بۆچی لە شارەکە نزیک کەوتنەوە بۆ جەنگ؟ ئەی نەتانزانی ئەوان لەسەر شووراکەوە تیرتان تێدەگرن؟
\v 21 کێ ئەبیمەلەخی کوڕی یەروبەشەتی\f + \fr 11:21 \ft یەروبەشەت: کە یەروبەعل، کە گدعۆن.‏\f* کوشت؟ ئایا ژنێک لەسەر شووراوە بەرداشی سەرەوەی دەستاڕێکی تێنەگرت و لە تێڤێچ کوژرا؟ بۆ لە شووراکە نزیک کەوتنەوە؟“ تۆش ئەو کاتە بڵێ: ”هەروەها ئوریای حیتی خزمەتکاریشت کوژراوە.“»
\p 
\v 22 نێردراوەکە ڕۆیشت، کاتێک هاتە لای داود هەموو ئەو شتانەی پێ ڕاگەیاند کە یۆئاب پێی ڕاسپاردبوو.
\v 23 هەروەها نێردراوەکە بە داودی گوت: «پیاوانی شارەکە بەسەرماندا زاڵ بوون، هاتن لە دەشتودەر لەگەڵمان بجەنگن، بەڵام هەتا دەمی دەروازەکە پاشەکشەمان پێکردن.
\v 24 ئینجا تیرهاوێژەکان لەسەر شووراکەوە تیربارانیان کردین و ژمارەیەک لە خزمەتکارەکانی پاشا کوژران، ئوریای حیتی خزمەتکاریشت کوژرا.»
\p 
\v 25 داودیش بە نێردراوەکەی گوت: «ئاوا بە یۆئاب دەڵێیت: ”ئەم کارەت پێ خراپ نەبێت، چونکە شمشێر جارێ ئەم و جارێ ئەو دەخوات. شەڕەکەت لەسەر شارەکە بەتین بکە و کاولی بکە.“ ئەمە بۆ هاندانی یۆئاب بڵێ.»
\p 
\v 26 کاتێک ژنەکەی ئوریا بیستی کە ئوریای مێردی کوژراوە، شیوەنی بۆ پیاوەکەی گێڕا.
\v 27 پاش تێپەڕبوونی ڕۆژانی پرسە، داود بەدوایدا نارد و خستییە پاڵ ماڵەکەی خۆیەوە، ئیتر بوو بە ژنی و کوڕێکی لێی بوو. بەڵام یەزدان ئەم کارەی داودی پێ ناخۆش بوو.
\c 12
\s1 سەرزەنشتی داود لەلایەن ناتانەوە
\p 
\v 1 یەزدان ناتانی نارد بۆ لای داود، ئەویش هاتە لای و پێی گوت: «دوو پیاو لە شارێکدا هەبوون، یەکێکیان دەوڵەمەند و ئەوی دیکەیان هەژار.
\v 2 پیاوە دەوڵەمەندەکە مەڕ و مانگایەکی زۆری هەبوو.
\v 3 بەڵام هەژارەکە هیچی نەبوو، جگە لە بەرخێکی مێی بچووک کە کڕیبووی و بەخێوی کردبوو. لەگەڵ خۆی و هەموو منداڵەکانیدا گەورە ببوو. بەرخەکە لە پارووەکەی ئەو دەیخوارد و لە جامەکەی ئەو دەیخواردەوە، لە باوەشیدا دەنوست و وەک کچی ئەوی لێهاتبوو.
\p 
\v 4 «ئەوە بوو ڕێبوارێک بووە میوانی پیاوە دەوڵەمەندەکە، بەڵام دەوڵەمەندەکە ڕازی نەبوو مەڕێک یان مانگایەکی خۆی بکاتە ژەمێک بۆ میوانەکە کە ڕووی تێکردبوو. لە جیاتی ئەوە کاوڕەمێیەکەی هەژارەکەی برد و ئامادەی کرد بۆ ئەو پیاوەی کە ڕووی تێکردبوو.»
\p 
\v 5 داود زۆر لەو پیاوە تووڕە بوو، بە ناتانی گوت: «بە یەزدانی زیندوو، ئەو پیاوەی ئەمەی کردووە شایانی سزای مردنە!
\v 6 لە جیاتی کاوڕەمێیەکەش چوار قات دەداتەوە، لە دەرئەنجامی ئەوەی ئەم کارەی کردووە، لەبەر ئەوەی بەزەیی نەبووە.»
\p 
\v 7 ناتانیش بە داودی گوت: «ئەو پیاوە تۆیت! یەزدانی پەروەردگاری ئیسرائیل ئەمە دەفەرموێت: ”من دەستنیشانم کردیت ببیتە پاشای ئیسرائیل، من لە دەستی شاول دەربازم کردیت.
\v 8 ماڵی گەورەکەتم پێدایت و ژنەکانی ئەوم خستە باوەشتەوە، بنەماڵەی ئیسرائیل و یەهودام پێدایت. ئەگەر هەموو ئەمەش کەم بووایە، ئەوا زیاترم پێدەدایت.
\v 9 ئیتر بۆچی فەرمایشتی یەزدانت بە سووک زانی، هەتا ئەم خراپەیە لەبەرچاوی یەزدان بکەیت؟ ئوریای حیتیت بە شمشێر کوشت و ژنەکەی ئەوت کردە ژنی خۆت، بە شمشێری عەمۆنییەکان کوشتت.
\v 10 ئێستاش، بۆ هەتاهەتایە شمشێر لەسەر بنەماڵەکەت نابڕێتەوە، چونکە سووکایەتیت بە من کرد، ژنەکەی ئوریای حیتیت برد و کردتە ژنی خۆت.“
\p 
\v 11 «یەزدان ئەمە دەفەرموێت: ”ئەوەتا من لەناو ماڵەکەی خۆتدا خراپەت بەسەردا دەهێنم، لەبەرچاوت ژنەکانت دەبەم و دەیاندەمە ئەو کەسەی کە لێت نزیکە، لە ژێر ڕووناکی ئەم خۆرە لەگەڵ ژنەکانت جووت دەبێت.
\v 12 تۆ بە نهێنی ئەو کارەت کرد، بەڵام من لەبەردەم هەموو ئیسرائیل و لەژێر ڕووناکی خۆر ئەم کارەت پێدەکەم.“»
\p 
\v 13 داودیش بە ناتانی گوت: «گوناهم دەرهەق بە یەزدان کرد.»
\p ناتان وەڵامی دایەوە: «یەزدان لە گوناهەکەت خۆشبووە، نامریت.
\v 14 بەڵام لەبەر ئەوەی بەم کارەت بوویتە هۆی ئەوەی دوژمنانی یەزدان تەواو سووکایەتی بە یەزدان بکەن، ئەوا ئەو منداڵەی بۆت لەدایک دەبێت دەمرێت.»
\p 
\v 15 هەر لەدوای ئەوەی ناتان چووەوە ماڵەکەی خۆی، یەزدان لەو منداڵەی داودی دا کە لە ژنەکەی ئوریاوە لەدایک بوو، ئینجا نەخۆش کەوت.
\v 16 داود بۆ منداڵەکەی لە خودا پاڕایەوە و ڕۆژووی گرت، چووە ژوورەکەی خۆی، شەوانە بە درێژایی شەو لەسەر زەوی ڕادەکشا و هەر بەو جۆرە دەمایەوە.
\v 17 پیرانی ماڵەکەی لەتەنیشتی وەستابوون بۆ ئەوەی لەسەر زەوییەکە هەڵیبستێننەوە، بەڵام نەیویست و نانی لەگەڵیان نەخوارد.
\p 
\v 18 ئەوە بوو لە ڕۆژی حەوتەم منداڵەکە مرد. خزمەتکارەکانی داود ترسان پێی ڕابگەیەنن کە منداڵەکە مردووە، چونکە گوتیان: «هێشتا منداڵەکە زیندوو بوو قسەمان لەگەڵی کرد و گوێی لێ نەگرتین، ئیتر چۆن پێی بڵێین منداڵەکە مردووە؟ خراپتر دەکات.»
\p 
\v 19 کاتێک داود بینی خزمەتکارەکانی چرپەچرپ دەکەن، زانی کە منداڵەکە مردووە. ئینجا داود لە خزمەتکارەکانی پرسی: «ئەرێ منداڵەکە مردووە؟»
\p ئەوانیش وەڵامیان دایەوە: «بەڵێ، مردووە.»
\p 
\v 20 ئینجا داود لەسەر زەوییەکە هەستایەوە، خۆی شوشت و بۆنی لە خۆی دا، جلەکانی گۆڕی، چووە ناو ماڵی یەزدان و کڕنۆشی برد. پاشان گەڕایەوە بۆ ماڵەکەی خۆی و داوای کرد نانی بۆ دابنێن و خواردی.
\p 
\v 21 خزمەتکارەکانی پێیان گوت: «ئەم کارە چی بوو کردت؟ لە کاتێکدا منداڵەکە زیندوو بوو، بەڕۆژوو دەبوویت و دەگریایت، بەڵام کاتێک کە مرد هەستایت و نانت خوارد!»
\p 
\v 22 ئەویش گوتی: «کاتێک منداڵەکە زیندوو بوو بەڕۆژوو دەبووم و دەگریام و دەمگوت: ”کێ دەزانێت؟ بەڵکو یەزدان لەگەڵم میهرەبان بێت و منداڵەکە بژیێت.“
\v 23 بەڵام ئێستا ئەو مرد، ئیتر بۆچی ڕۆژوو بگرم؟ ئایا دەتوانم بیگەڕێنمەوە؟ من دەچم بۆ لای ئەو، بەڵام ئەو ناگەڕێتەوە بۆ لای من.»
\p 
\v 24 ئینجا داود دڵنەوایی بەتشەبەعی ژنی دایەوە، چووە ژوورەوە بۆ لای و لەگەڵی جووت بوو، منداڵێکی بوو ناوی لێنا سلێمان. یەزدانیش خۆشیویست،
\v 25 هەر لەبەر ئەوە لە ڕێگەی ناتانی پێغەمبەرەوە پەیامی نارد و ناوی لێنا یەدیدەیا\f + \fr 12:25 \ft بە واتای لەلایەن یەزدانەوە خۆشەویستە.‏\f*.
\p 
\v 26 لەو ماوەیە یۆئاب لە دژی شاری ڕەبەی عەمۆنییەکان دەجەنگا و قەڵای شاهانەی گرت.
\v 27 ئینجا یۆئاب چەند نێردراوێکی بۆ لای داود نارد و گوتی: «لە دژی ڕەبە جەنگام و سەرچاوەی ئاوی شارەکەم گرت.
\v 28 ئێستا پاشماوەی سوپا کۆبکەرەوە و بەسەر شارەکەدا بدە و دەستی بەسەردا بگرە، نەوەک من دەستی بەسەردا بگرم و بە ناوی منەوە ناوی لێ بنرێت.»
\p 
\v 29 ئیتر داود هەموو سوپای کۆکردەوە و چوو بۆ ڕەبە و لە دژی جەنگا و گرتی.
\v 30 تاجی سەری پاشاکەی برد، کێشەکەی نزیکەی تالنتێک\f + \fr 12:30 \ft تالنت: نزیکەی 34 کیلۆگرامە. بڕوانە \xt دەرچوون 25‏:39‏\xt*\ft ‏.‏\f* زێڕ بوو، بەردی گرانبەهاشی تێدابوو، ئینجا لەسەر سەری داود دانرا. دەستکەوتێکی زۆریشی لە شارەکە دەرهێنا،
\v 31 ئەو گەلەشی کە تێیدا بوو هێنایە دەرەوە و بێگاری پێکردن بە ئیشکردن بە مشار و پاچی ئاسنین و تەوری ئاسنین، فەرمانی پێ کردن لە کوورەی خشتدا کار بکەن، ئەم کارەی بە هەموو شارۆچکەکانی عەمۆنییەکان کرد. پاشان داود و هەموو سوپا گەڕانەوە ئۆرشەلیم.
\c 13
\s1 ئەمنۆن و تامار
\p 
\v 1 ئەوە بوو پاش ئەمانە ئەمنۆنی کوڕی داود کەوتە خۆشەویستی تاماری خوشکە جوانەکەی ئەبشالۆمی کوڕی داود.\f + \fr 13:1 \ft ئەمنۆن لە ئەحینۆعەم و تاماری لە مەعکا هەردووکیان منداڵی داود بوون. بڕوانە بەشی 3‏:2‏، 3.‏\f*
\p 
\v 2 ئەمنۆن لە تاو تاماری زڕخوشکی نەخۆش کەوت، لەبەر ئەوەی تامار پاکیزە بوو، ئەمنۆن پێی وابوو کە نەیدەتوانی بە هیچ شێوەیەک دەستی بۆ ببات.
\p 
\v 3 ئەمنۆن هاوڕێیەتی ئامۆزایەکی دەکرد بە ناوی یۆنادابی کوڕی شیمەعا کە برای داود بوو، یۆناداب پیاوێکی تەڵەکەباز بوو.
\v 4 لە ئەمنۆنی پرسی: «شازادە، بۆچی تۆ ڕۆژ لەدوای ڕۆژ لاوازتر دەبیت؟ ئایا پێم ناڵێیت؟»
\p ئەمنۆنیش پێی گوت: «من تاماری خوشکی ئەبشالۆمی برام خۆشدەوێت.»
\p 
\v 5 یۆنادابیش پێی گوت: «لەناو جێگا پاڵبکەوە و خۆت نەخۆش بخە، ئەگەر باوکت بۆ بینینت هات پێی بڵێ: ”با تاماری خوشکم بێتە لام و نانم پێبدات، با خواردنەکە لەبەرچاوم سازبکات، بۆ ئەوەی بیبینم و بە دەستی ئەو نان بخۆم.“»
\p 
\v 6 ئینجا ئەمنۆن پاڵکەوت و خۆی نەخۆش خست، پاشا هات بۆ بینینی، ئەمنۆن بە پاشای گوت: «تکایە با تاماری خوشکم بێتە لام و لەبەرچاوم دوو ناسکەنان دروستبکات، بە دەستی ئەو دەیخۆم.»
\p 
\v 7 داود بەدوای تاماردا ناردییە ماڵەوە و گوتی: «تکایە بڕۆ ماڵی ئەمنۆنی برات و خواردنێکی بۆ دروستبکە.»
\v 8 تاماریش چووە ماڵی ئەمنۆنی برای، ئەو پاڵکەوتبوو. ئینجا هەویری برد و شێلای و لەبەرچاوی ناسکەنانی کرد و برژاندی.
\v 9 ئینجا تاوەکەی بۆ بەردەمی برد، بەڵام ئەو ڕازی نەبوو بیخوات.
\p ئەمنۆن گوتی: «هەمووتان بڕۆنە دەرەوە.» ئەوانیش هەموویان چوونە دەرەوە.
\v 10 ئینجا ئەمنۆن بە تاماری گوت: «خواردنەکە بهێنە شوێنی نوستنەکەم بۆ ئەوەی بە دەستی تۆ بیخۆم.» تاماریش ناسکەنانەکەی کە دروستی کردبوو هەڵیگرت و بۆ ئەمنۆنی برای بردییە ژوورەوە بۆ شوێنی نوستنەکەی.
\v 11 بۆی بردە پێشەوە تاوەکو بیخوات، ئەویش تاماری گرت و پێی گوت: «خوشکەکەم، وەرە لەگەڵم پاڵبکەوە.»
\p 
\v 12 ئەویش پێی گوت: «نا، برام نا! سەرم شۆڕ مەکە! لە ئیسرائیلدا شتی وا ناکرێت! ئەم بێ ئابڕووییە مەکە.
\v 13 من بەم ئابڕووچوونەوە ڕوو لەکوێ بکەم؟ ئەی تۆ؟ تۆش لەناو ئیسرائیلدا وەک نەفامێکی بەدڕەوشتت لێدێت. ئێستاش تکایە لەگەڵ پاشا قسە بکە بۆ ئەوەی بمدا بە تۆ، چونکە ئەو پێی ناخۆش نییە.»
\v 14 بەڵام ئەمنۆن نەیویست گوێی لێ بگرێت و بەسەریدا زاڵ بوو، سەری شۆڕکرد و لاقەی کرد.
\p 
\v 15 پاشان ئەمنۆن زۆر ڕقی لێی بووەوە، تەنانەت ڕقەکەی زۆر زیاتر بوو لەو خۆشەویستییەی کە بۆی هەبوو. ئینجا ئەمنۆن پێی گوت: «هەستە و بڕۆ!»
\p 
\v 16 ئەویش پێی گوت: «نەخێر! ئەگەر دەرمبکەیت خراپەیەکی گەورەترە لەوەی کە پێت کردم.»
\p بەڵام ئەمنۆن نەیویست گوێی لێ بگرێت.
\v 17 خزمەتکارە تایبەتەکەی بانگکرد و گوتی: «ئەمە دەربکە و دەرگاکە لەدوایەوە دابخە.»
\v 18 خزمەتکارەکەش دەریکرد و دەرگاکەی لەدوایەوە داخست. تاماریش کەوایەکی درێژی ڕەنگاوڕەنگی لەبەردا بوو، چونکە کچە پاکیزەکانی پاشا جلی ئاوایان لەبەر دەکرد.
\v 19 تامار خۆڵەمێشی بەسەر سەری خۆیدا کرد، جلە ڕەنگاوڕەنگەکەی لەبەرخۆی دادڕی. دەستی بەسەرییەوە گرت و بە ڕێگادا دەڕۆیشت، بە دەنگی بەرز دەگریا.
\p 
\v 20 ئەبشالۆمی برای پێی گوت: «ئەمنۆنی زڕبرات لەگەڵت بوو؟ خوشکم، ئێستاش بێدەنگ بە، ئەو زڕبراتە و ئەم کارە لە دڵ مەگرە.» ئیتر تامار بە پەرێشانی لە ماڵی ئەبشالۆمی برای مایەوە و ژیا.
\p 
\v 21 کاتێک داودی پاشا ئەم هەموو شتانەی بیستەوە، زۆر تووڕە بوو.
\v 22 ئەبشالۆمیش نە بە چاک و نە بە خراپ قسەی لەگەڵ ئەمنۆنی زڕبرای نەکرد، لەبەر ئەوەی سەری تاماری خوشکی شۆڕکرد، زۆر ڕقی لە ئەمنۆن بووەوە.
\s1 کوشتنی ئەمنۆن لەلایەن ئەبشالۆمەوە
\p 
\v 23 دوو ساڵ دوای ئەوە، ئەبشالۆم هەموو کوڕەکانی پاشای بانگهێشت کرد، کاتێک خزمەتکارەکانی لە بەعل‌حاچۆر ئەوەی نزیک ئەفرایمە مەڕەکانی ئەویان دەبڕییەوە.
\v 24 ئینجا ئەبشالۆم چوو بۆ لای پاشا و گوتی: «ئێستا بەندەکەت مەڕەکانی دەبڕێتەوە، تکایە پاشا و کاربەدەستەکانی با لەگەڵ بەندەکەت بێن.»
\p 
\v 25 پاشاش بە ئەبشالۆمی گوت: «نەخێر کوڕم، با هەموومان نەبین و بارگرانی نەخەینە سەرت.» جا ئەبشالۆم زۆری لێکرد، بەڵام ئەو نەیویست بچێت، بەڵکو داوای بەرەکەتی بۆ کرد.
\p 
\v 26 ئەبشالۆمیش گوتی: «ئەگەر نا، تکایە با ئەمنۆنی برام لەگەڵمان بێت.»
\p پاشاش لێی پرسی: «بۆچی لەگەڵت بێت؟»
\v 27 بەڵام ئەبشالۆم زۆری لێکرد و ئەویش ئەمنۆن و هەموو کوڕەکانی پاشای لەگەڵ نارد.
\p 
\v 28 ئەبشالۆمیش فەرمانی بە خزمەتکارەکانی کرد و گوتی: «ئاگاداربن! کاتێک کە ئەمنۆن بە شەراب مەست بوو، پێتان دەڵێم: ”لە ئەمنۆن بدەن،“ بیکوژن و مەترسن. ئەی من خۆم فەرمانم پێ نەکردوون؟ لەبەر ئەوە بەهێزبن و ئازابن.»
\v 29 ئیتر خزمەتکارەکانی ئەبشالۆم ئەوەیان بە ئەمنۆن کرد کە ئەبشالۆم فەرمانی پێ کردبوون، هەموو کوڕەکانی پاشا هەستان، هەریەکە و سواری هێسترەکەی خۆی بوو و هەڵات.
\p 
\v 30 لە کاتێکدا ئەوان بەڕێوە بوون، هەواڵ گەیشتە داود و گوترا: «ئەبشالۆم هەموو کوڕەکانی پاشای کوشتووە و کەسیانی نەهێشتووەتەوە.»
\v 31 پاشا هەستا و جلەکانی لەبەرخۆی دادڕی و لەسەر زەوی پاڵکەوت، هەموو خزمەتکارەکانیشی بە جلی دڕاوەوە لەلای پاشا ڕاوەستا بوون.
\p 
\v 32 بەڵام یۆنادابی کوڕی شیمەعای برای داود گوتی: «با گەورەم وانەزانێت کە هەموو شازادە لاوەکانیان کوشتووە، بەڵکو تەنها ئەمنۆن کوژراوە، چونکە لەو ڕۆژەوەی کە لاقەی تاماری خوشکی کرد، ئەبشالۆم ئەو بڕیارەی دا.
\v 33 ئێستاش با پاشای گەورەم شتێکی وا نەخاتە دڵییەوە و بڵێت هەموو کوڕەکانی پاشا کوژراون. بەڵکو بە تەنها ئەمنۆن کوژراوە.»
\p 
\v 34 ئەبشالۆم پێشتر هەڵاتبوو.
\p خزمەتکارە ئێشکگرەکە چاوی هەڵبڕی و بینی خەڵکێکی زۆر لە لاشانی کێوەکە بە ڕێگاوە بوون. ئێشکگرەکە چوو بۆ لای پاشا و پێی گوت: «خەڵکێک دەبینم لە حۆرۆنەیمەوە بە لاشانی کێوەکەدا دێن.»
\p 
\v 35 ئینجا یۆناداب بە پاشای گوت: «ئەوەتا شازادەکان هاتن و خزمەتکارەکەت چی گوت، بەو جۆرە بوو.»
\p 
\v 36 هەر دوای ئەوەی لە قسەکردن بووەوە شازادەکان هاتن و بە گریانەوە دەنگیان هەڵبڕی، هەروەها پاشا و هەموو خزمەتکارەکانیش گریانێکی زۆر بەکوڵ گریان.
\p 
\v 37 ئەبشالۆمیش هەڵات و چوو بۆ لای تەلمەی کوڕی عەمیهودی پاشای گەشوور، داودیش هەموو ئەو ڕۆژانە بۆ کوڕەکەی لاواندییەوە.
\p 
\v 38 دوای ئەوەی ئەبشالۆم هەڵات و چوو بۆ گەشوور سێ ساڵ لەوێدا مایەوە.
\v 39 داودی پاشا خەمی کوژرانی ئەمنۆنی لە دڵ دامرکایەوە، ئارەزووی کرد بچێتە لای ئەبشالۆم.
\c 14
\s1 گەڕانەوەی ئەبشالۆم بۆ ئۆرشەلیم
\p 
\v 1 یۆئابی کوڕی چەرویا زانی کە دڵی پاشا ئارەزووی بینینی ئەبشالۆمی دەکرد.
\v 2 لەبەر ئەوە یۆئاب کەسێکی ناردە تەقۆعە و لەوێوە ژنێکی دانای هێنا و پێی گوت: «تکایە خۆت وەک ماتەمدار نیشان بدە، جلی ماتەم لەبەر بکە و بۆن لە خۆت مەدە، بەڵکو وەک ژنێک دەربکەوە کە ماوەیەکی درێژە ماتەمدارە،
\v 3 بڕۆ ژوورەوە بۆ لای پاشا و ئەم قسەیەی پێ بڵێ.» جا یۆئاب قسەکەی خستە سەر زاری.
\p 
\v 4 کاتێک ژنە تەقۆعییەکە چوو بۆ لای پاشا، خۆی خستە سەر زەوی و کڕنۆشی برد و گوتی: «ئەی پاشا، ڕزگارم بکە!»
\p 
\v 5 پاشاش پێی گوت: «چیت دەوێ؟»
\p ئەویش گوتی: «من بێوەژنم و پیاوەکەم مردووە،
\v 6 کارەکەرەکەت دوو کوڕی هەبوو کە لە کێڵگەدا بە شەڕ هاتن و کەس نەبوو لێکیان بکاتەوە، یەکێکیان لەوی دیکەیانی دا و کوشتی.
\v 7 ئەوەتا هەموو خێڵەکە لە کارەکەرەکەت هەستاون و دەڵێن: ”ئەوەمان ڕادەست بکە کە براکەی خۆی کوشتووە، بۆ ئەوەی لە جیاتی گیانی براکەی کە کوشتوویەتی بیکوژینەوە، هەروەها میراتگرەکە لەناو ببەین.“ ئەو پشکۆیەم دەکوژێننەوە کە ماوەتەوە، ناو و پاشماوەی پیاوەکەم لەسەر ڕووی زەوی ناهێڵنەوە.»
\p 
\v 8 پاشاش بە ژنەکەی گوت: «بگەڕێوە ماڵەکەت و من بڕیارێک لەبارەی تۆوە دەردەکەم.»
\p 
\v 9 ژنە تەقۆعییەکەش بە پاشای گوت: «ئەی پاشای گەورەم، با تاوانەکە لە ئەستۆی خۆم و ماڵی باوکم بێت، پاشا و تەختەکەی پاک و بێتاوان بن.»
\p 
\v 10 پاشاش گوتی: «ئەگەر کەسێک قسەی لەگەڵ کردیت، بیهێنە لام بۆ ئەوەی دیسان بێزارت نەکات.»
\p 
\v 11 ژنەکەش گوتی: «ئەی پاشا، تکایە ناوی یەزدانی پەروەردگارت بهێنە، هەتا خوێنگری تۆڵەسێنەر زۆر نەبن بۆ کوشتنەوە و کوڕەکەم نەفەوتێت.»
\p ئەویش گوتی: «بە یەزدانی زیندوو، تاڵە مووێکی کوڕەکەت ناکەوێتە سەر زەوی.»
\p 
\v 12 ئینجا ژنەکەش گوتی: «تکایە با کارەکەرەکەت قسەیەکی دیکە بۆ پاشای گەورەی بکات.»
\p ئەویش گوتی: «قسە بکە.»
\p 
\v 13 ژنەکەش گوتی: «ئەی بۆچی بیرت لە کارێکی وا کردووەتەوە لە دژی گەلی خودا؟ کە پاشا ئەمە دەڵێت خۆی تاوانبار دەکات، لەبەر ئەوەی پاشا کوڕە دوورخراوەکەی خۆی نەگەڕاندووەتەوە!
\v 14 وەک ئاوێکی ڕژاو لەسەر زەوی کە کۆناکرێنەوە، بێگومان دەمرین. بەڵام خودا گیان ناکێشێت، بەڵکو چەند ڕێگایەک دادەڕژێت هەتا ئەوەی لێی دوورخراوەتەوە بە دوورخراوەیی نەمێنێتەوە.
\p 
\v 15 «ئێستاش من هاتم هەتا لەو بارەیەوە قسە لەگەڵ پاشای گەورەم بکەم، چونکە گەل منیان ترساند. کارەکەرەکەت گوتی: ”قسە لەگەڵ پاشا دەکەم، بەڵکو پاشا بە گوێی کارەکەرەکەی بکات.
\v 16 لەوانەیە پاشا گوێ بگرێت بۆ ئەوەی کارەکەرەکەی لە دەست ئەو پیاوە دەرباز بکات کە دەیەوێت خۆم و کوڕەکەم پێکەوە لە میراتی خودا بسڕێتەوە.“
\p 
\v 17 «هەروەها کارەکەرەکەت دەڵێت: ”بەڵکو وتەی پاشای گەورەم دڵنەوایی بێت بۆم، چونکە پاشای گەورەم وەک فریشتەی خودایە لە تێگەیشتنی چاکە و خراپە، با یەزدانی پەروەردگارت لەگەڵت بێت.“»
\p 
\v 18 پاشا وەڵامی دایەوە و بە ژنەکەی گوت: «شتێکت لێ دەپرسم، لێم مەشارەوە.»
\p ژنەکەش گوتی: «تکایە، با پاشای گەورەم بفەرموێت.»
\p 
\v 19 ئەوسا پاشا گوتی: «ئایا لە هەموو ئەمانەدا دەستی یۆئاب لەگەڵتدایە؟»
\p ژنەکەش وەڵامی دایەوە و گوتی: «پاشای گەورەم، بە گیانی تۆ هیچ کەس ناتوانێت نە بەلای ڕاست و نە بەلای چەپدا لابدات لە هەموو ئەو شتانەی کە پاشای گەورەم فەرموویەتی، چونکە یۆئابی خزمەتکارت فەرمانی پێ کردم و هەر ئەو هەموو ئەم قسانەی خستە سەر زاری کارەکەرەکەتەوە.
\v 20 یۆئابی خزمەتکارت ئەم کارەی کرد بۆ ئەوەی دۆخەکە بگۆڕێت. دانایی گەورەم وەک دانایی فریشتەی خودایە هەتا هەموو ئەو شتانەش بزانێت کە لە خاکەکە هەیە.»
\p 
\v 21 ئیتر پاشا بە یۆئابی گوت: «ئێستا من بڕیارم دا و بڕۆ ئەو کوڕە گەنجە، ئەبشالۆم بهێنەرەوە.»
\p 
\v 22 یۆئابیش کەوتە سەر زەوی و کڕنۆشی برد و داوای بەرەکەتی بۆ پاشای کرد، یۆئاب گوتی: «ئەی پاشای گەورەم، ئەمڕۆ خزمەتکارەکەت دەزانێت کە لەلای تۆ پەسەندە، چونکە پاشا بە قسەی خزمەتکاری خۆی کرد.»
\p 
\v 23 ئینجا یۆئاب هەستا و چوو بۆ گەشوور و ئەبشالۆمی هێنایەوە ئۆرشەلیم.
\v 24 بەڵام پاشاش گوتی: «با بچێتە ماڵەکەی خۆی و ڕووم نەبینێت.» لەبەر ئەوە ئەبشالۆم چووە ماڵەکەی خۆی و ڕووی پاشای نەبینی.
\p 
\v 25 لە هەموو ئیسرائیلدا لە قۆزی کەس نەبوو وەک ئەبشالۆم بە شانوباڵیدا هەڵبدرێت، لە بنی پێیەوە هەتا تەپڵی سەری بێ کەموکوڕی بوو.
\v 26 لە کۆتایی هەموو ساڵێک سەری دەتاشی، چونکە سەری قورس دەبوو، کێشی مووی سەری بەپێی کێشی پاشایەتی دوو سەد شاقل\f + \fr 14:26 \ft دوو سەد شاقل: نزیکەی 2,3 کیلۆگرام.‏\f* دەبوو.
\p 
\v 27 هەروەها ئەبشالۆم سێ کوڕ و کچێکی بوو، ناوی کچەکەش تامار بوو، بووە ئافرەتێکی زۆر جوان.
\p 
\v 28 ئەبشالۆم دوو ساڵ لە ئۆرشەلیم مایەوە، بەبێ ئەوەی ڕووی پاشا ببینێت.
\v 29 لەبەر ئەوە ئەبشالۆم بەدوای یۆئابدا ناردی تاکو بینێرێتە لای پاشا، بەڵام ئەو نەیویست بێتە لای. دووبارە بەدوایدا ناردییەوە، بەڵام ئەو نەیویست بێت.
\v 30 لەبەر ئەوە بە خزمەتکارەکانی گوت: «تەماشا بکەن، کێڵگەکەی یۆئاب لەتەنیشت ئەوەی منەوەیە و جۆ لەوێ هەیە. بڕۆن و ئاگری تێبەردەن.» ئینجا خزمەتکارەکانی ئەبشالۆم ئاگریان لە کێڵگەکە بەردا.
\p 
\v 31 ئیتر یۆئاب هەستا و چوو بۆ لای ئەبشالۆم بۆ ماڵەوە و پێی گوت: «بۆچی خزمەتکارەکانت ئاگریان لە کێڵگەکەی من بەردا؟»
\p 
\v 32 ئەبشالۆمیش بە یۆئابی گوت: «من بەدوای تۆدا ناردم و گوتم: ”وەرە ئێرە، هەتا بتنێرمە لای پاشا و بڵێیت، ’من بۆچی لە گەشوورەوە هاتمەوە؟ بۆ من چاکتر بوو لەوێ بمێنمەوە!‘ “ ئێستاش دەمەوێت چاوم بە پاشا بکەوێت، ئەگەر تاوانێکی تێمدا بەدیی کرد، با بمکوژێت.»
\p 
\v 33 ئیتر یۆئاب چوو بۆ لای پاشا و پێی ڕاگەیاند. ئەویش ئەبشالۆمی بانگکرد و هاتە لای پاشا، لەبەردەم ئەودا کڕنۆشی برد و سەری خستە سەر زەوی، پاشاش ئەبشالۆمی ماچکرد.
\c 15
\s1 پیلانگێڕانی ئەبشالۆم
\p 
\v 1 لەدوای ماوەیەک ئەبشالۆم گالیسکە و ئەسپی بۆ خۆی دانا، پەنجا پیاویش لەپێشیەوە ڕایاندەکرد.
\v 2 هەروەها ئەبشالۆم بەیانییان زوو هەڵدەستا و لە قەراغ ڕێگای دەروازەی شارەکە ڕادەوەستا. هەر خاوەن کێشەیەک دەهاتە لای پاشا بۆ بڕیاردان، ئەبشالۆم بانگی دەکرد و لێی دەپرسی: «خەڵکی چ شارێکیت؟» ئەویش وەڵامی دەدایەوە: «خزمەتکارەکەت خەڵکی یەکێک لە هۆزەکانی ئیسرائیلە.»
\v 3 ئەبشالۆمیش پێی دەگوت: «تەماشا بکە، داواکەی تۆ دروستە و ڕاستە، بەڵام کەس نییە لەلایەن پاشاوە گوێت لێ بگرێت.»
\v 4 هەروەها ئەبشالۆم دەیگوت: «ئەگەر لەم ناوچەیە من بکەنە دادوەر، ئەوا هەرکەسێک سکاڵا یان داوای هەبێت، دادوەریی بۆ دابین دەکەم.»
\p 
\v 5 هەرکەسێک دەهاتە پێشەوە بۆ ئەوەی کڕنۆشی بۆ ببات، ئەبشالۆم دەستی بۆ درێژ دەکرد، دەیگرت و ماچی دەکرد.
\v 6 ئەو ئەم کارەی لەگەڵ هەموو ئیسرائیلدا دەکرد، ئەوانەی بۆ دادوەری دەهاتنە لای پاشا. بەم شێوەیە ئەبشالۆم دڵی گەلی ئیسرائیلی بۆ خۆی ڕاکێشا.
\p 
\v 7 پاش تێپەڕبوونی چوار ساڵ ئەبشالۆم بە پاشای گوت: «تکایە ڕێگام بدە بچمە حەبرۆن بۆ ئەوەی نەزرەکەم\f + \fr 15:7 \ft واتا پابەندکردنی مرۆڤ خۆیەتی بە مەرجێکەوە، لە کاتێکدا کە داخوازییەک بەرز دەکاتەوە بۆ خودا و بە ئەرێ وەڵام دەدرێتەوە لەلایەن خوداوە. بڕوانە \xt سەرژمێری 21‏:2‏\xt*\ft ‏.‏\f* بەجێبهێنم کە بۆ یەزدان نەزرم کردبوو.
\v 8 خزمەتکارەکەت لە کاتی نیشتەجێبوونی لە گەشووری خاکی ئارام، نەزری کردووە، گوتم: ”ئەگەر یەزدان بە تەواوی بمگەڕێنێتەوە ئۆرشەلیم ئەوا لە حەبرۆن یەزدان دەپەرستم.“»
\p 
\v 9 پاشاش گوتی: «بە سەلامەتی بڕۆ.» ئەویش هەستا و چوو بۆ حەبرۆن.
\p 
\v 10 ئینجا ئەبشالۆم سیخوڕی بەناو هەموو هۆزەکانی ئیسرائیلدا بڵاو کردەوە و گوتی: «ئەگەر گوێتان لە دەنگی کەڕەنا بوو، بڵێن: ”ئەبشالۆم لە حەبرۆن بووە بە پاشا.“»
\v 11 دوو سەد پیاویش لە ئۆرشەلیمەوە لەگەڵ ئەبشالۆم بەڕێکەوتن کە بانگهێشت کرابوون، بێ ئەوەی هیچ شتێک بزانن بە ساویلکەییەوە ڕۆیشتن.
\v 12 کاتێک ئەبشالۆم قوربانییەکانی پێشکەش دەکرد، ناردی بەدوای ئەحیتۆفەلی گیلۆنیی ڕاوێژکاری داود بۆ ئەوەی لە گیلۆی شارۆچکەکەی خۆیەوە بێتە ئەوێ. جا پیلانەکە بەهێزتر بوو، هەتا دەهات خەڵکەکە زیاتر شوێنی ئەبشالۆم دەکەوتن.
\s1 هەڵاتنی داود
\p 
\v 13 هەواڵدەرێک هاتە لای داود و گوتی: «هەموو پیاوانی ئیسرائیل دڵیان لەگەڵ ئەبشالۆمە.»
\p 
\v 14 داودیش بە هەموو ئەو کاربەدەستانەی گوت کە لە ئۆرشەلیم لەگەڵی بوون: «هەستن! با هەڵبێین، ئەگینا لە دەست ئەبشالۆم دەربازمان نابێت. پەلە بکەن لە ڕۆیشتن، نەوەک دەستپێشخەری بکات، پێمان بگات و خراپەمان بەسەردا بهێنێت، بە زەبری شمشێریش لە شارەکە بدات.»
\p 
\v 15 کاربەدەستانی پاشاش بە پاشایان گوت: «ئێمە ئامادەین بۆ هەر بڕیارێکی پاشای گەورەمان.»
\p 
\v 16 پاشا و هەموو ماڵەکەی بەدوایەوە هاتنە دەرەوە، پاشا دە ژنە کەنیزەی بۆ پاراستنی کۆشکەکە بەجێهێشت.
\v 17 ئیتر پاشا ڕۆیشت و هەموو گەلیش لەدوای ئەو چوون، لەلای دوایین ماڵی قەراغی شار خۆیان ڕێکخستەوە.
\v 18 جا هەموو پیاوەکانی لەگەڵ کریتی و پەلەتییەکان و هەموو گەتییەکانیش کە شەش سەد پیاو بوون و لە گەتەوە بەدوایەوە هاتبوون لەپێشیەوە پەڕینەوە، لەپێش پاشا دەپەڕینەوە.
\p 
\v 19 پاشا بە ئیتتای گەتی گوت: «بۆچی تۆش لەگەڵمان دەڕۆیت؟ بگەڕێوە و لەگەڵ ئەبشالۆمی پاشادا بمێنەرەوە، چونکە تۆ بیانیت و لە نیشتیمانەکەت دوور کەوتوویتەوە.
\v 20 تۆ دوێنێ هاتوویت، ئایا من ئەمڕۆ بە ڕۆیشتنت لەگەڵماندا ئاوارەت بکەم، چونکە من خۆم نازانم بەرەو کۆی دەچم؟ بگەڕێوە و هاونیشتیمانییەکانیشت بگەڕێنەوە. با یەزدان خۆشەویستی نەگۆڕ و دڵسۆزیت پیشان بدات.»
\p 
\v 21 بەڵام ئیتتای وەڵامی پاشای دایەوە و گوتی: «بە یەزدانی زیندوو، بە گیانی پاشای گەورەم، پاشای گەورەم لە هەرکوێ بێت، بۆ مردن بێت یان بۆ ژیان، خزمەتکارەکەشت لەوێ دەبێت.»
\p 
\v 22 داود بە ئیتتایی گوت: «بڕۆ و بپەڕەوە.» ئینجا ئیتتای گەتی و هەموو پیاوەکانی و هەموو ئەو منداڵانەی کە لەگەڵی بوون پەڕینەوە.
\p 
\v 23 هەموو دانیشتووانی خاکەکە بە دەنگێکی بەرز دەگریان، هەموو گەل دەپەڕینەوە، پاشاش لە دۆڵی قدرۆن پەڕییەوە و هەموو گەلیش بەرەو ڕێگای چۆڵەوانی چوون.
\p 
\v 24 سادۆق و هەموو لێڤییەکانیش لەگەڵی بوون و سندوقی پەیمانی خودایان هەڵگرتبوو، ئیتر سندوقەکەی خودایان دانا و ئەبیاتار قوربانی پێشکەش دەکرد، هەتا هەموو گەل لە شارەکە هاتنە دەرەوە.
\p 
\v 25 ئینجا پاشا بە سادۆقی گوت: «سندوقی خودا بگەڕێنەوە شارەکە. ئەگەر لەبەرچاوی یەزدان پەسەند بم، ئەوا دەمگەڕێنێتەوە و ڕێگام دەدات سندوقەکە و نشینگەکەشی ببینم.
\v 26 ئەگەر یەزدانیش فەرمووی: ”من پێت دڵشاد نەبووم،“ من ئەوەتام، با خۆی چی بەلاوە باشە ئەوە بکات.»
\p 
\v 27 هەروەها پاشا بە سادۆقی کاهینی گوت: «ئایا تۆ پێشبینیکەر نیت؟ بە سەلامەتی بگەڕێوە شارەکە، خۆت و ئەحیمەعەچی کوڕت و یۆناتانی کوڕی ئەبیاتاریش، هەردوو کوڕەکانتان لەگەڵتاندا.
\v 28 تەماشا بکەن، من لە تەنکاوەکە بەرەو چۆڵەوانی ناپەڕمەوە و ئۆقرە دەگرم، هەتا پەیامێک لەلای ئێوەوە دێت و پێم ڕادەگەیەنن.»
\v 29 ئیتر سادۆق و ئەبیاتار سندوقی خودایان گەڕاندەوە ئۆرشەلیم و لەوێ مانەوە.
\p 
\v 30 بەڵام داود بە هەورازەکەی کێوی زەیتووندا سەرکەوت، سەردەکەوت و دەگریا، سەری داپۆشی بوو و بەپێی پەتی دەڕۆیشت، هەموو گەلیش کە لەگەڵی بوون هەرکەسە و سەری خۆی داپۆشی بوو، بە گریانەوە سەردەکەوتن.
\v 31 پێشتر بە داود ڕاگەیەنرابوو: «ئەحیتۆفەل لەگەڵ ئەبشالۆم لەنێو پیلانگێڕەکاندایە.» ئیتر داودیش لە یەزدان پاڕایەوە: «ئەی یەزدان، تکایە ڕاوێژی ئەحیتۆفەل بکە بە گێلایەتی.»
\p 
\v 32 کاتێک داود گەیشتە سەر لووتکەکە، شوێنی خواپەرستی، بینی وا حوشەی ئەرکی چاوەڕێی دەکات. جلەکەی دڕاوە و سەری تۆزاوییە.
\v 33 داودیش پێی گوت: «ئەگەر لەگەڵم بپەڕیتەوە بەسەرمەوە دەبیتە بار.
\v 34 بەڵام ئەگەر بگەڕێیتەوە شار و بە ئەبشالۆم بڵێیت: ”ئەی پاشا، من دەبمە خزمەتکاری تۆ، لەمێژە خزمەتکاری باوکت بوومە، ئێستاش دەبمە خزمەتکاری تۆ،“ بەوە یارمەتیم دەدەی لە پووچەڵکردنەوەی ڕاوێژی ئەحیتۆفەل.
\v 35 ئایا هەردوو کاهینەکە، سادۆق و ئەبیاتار لەوێ لەگەڵتدا نابن؟ ئەوەی لە کۆشکی پاشا دەیبیستیتەوە بە هەردوو کاهینەکە ڕابگەیەنە، سادۆق و ئەبیاتار.
\v 36 هەردوو کوڕەکەیان لەوێ لەگەڵیاندان، ئەحیمەعەچی سادۆق و یۆناتانی ئەبیاتار، هەموو ئەو شتانەی گوێتان لێی دەبێت بەواندا بۆ منی بنێرن.»
\p 
\v 37 ئینجا حوشەی هاوڕێی داود هاتە شارەکە، لەو کاتەی ئەبشالۆم دەهاتە ناو ئۆرشەلیم.
\c 16
\s1 داود و چیڤا
\p 
\v 1 کاتێک کە داود تۆزێک لە لووتکەکە ڕەت بوو، بینی چیڤای بریکاری مەفیبۆشەت بە دوو گوێدرێژی کورتانکراوەوە چاوەڕێی دەکات، دوو سەد کولێرە و سەد هێشووە کشمیش و سەد نانە هەنجیر و مەشکەیەک شەرابی بارکردبوو.
\p 
\v 2 پاشا بە چیڤای گوت: «ئەمانەت بۆ چییە؟»
\p چیڤاش گوتی: «دوو گوێدرێژەکە بۆ ماڵی پاشا بۆ سواربوونە، کولێرە و هەنجیرەکەش بۆ پیاوەکانتە با بیخۆن، شەرابەکەش با ئەوانە بیخۆنەوە کە لە چۆڵەوانیدا شەکەت بوون.»
\p 
\v 3 پاشاش لێی پرسی: «ئەی کوڕەزای گەورەکەت لەکوێیە؟»
\p چیڤاش بە پاشای گوت: «ئەوەتا ئەو لە ئۆرشەلیم ماوەتەوە، چونکە گوتی: ”ئەمڕۆ بنەماڵەی ئیسرائیل پاشایەتییەکەی باپیرم بۆ دەگەڕێننەوە.“»
\p 
\v 4 ئینجا پاشا بە چیڤای گوت: «وا هەموو ئەوانەی هی مەفیبۆشەتن بۆ تۆیە.»
\p چیڤاش گوتی: «کڕنۆش دەبەم. هیوادارم پاشای گەورەم لێم ڕازی بێت.»
\s1 نەفرەتکردنی شیمعی لە داود
\p 
\v 5 کاتێک داودی پاشا لە بەحوریم نزیک بووەوە، پیاوێک لەوێوە هات کە لە خێڵی شاول بوو، ناوی شیمعیی کوڕی گێرا بوو، دەهاتە دەرەوە و نەفرەتی دەکرد.
\v 6 داودی پاشا و هەموو کاربەدەستانی بەردباران دەکرد، هەرچەندە هەموو سوپا و پاڵەوانەکانیش لەلای ڕاست و چەپی بوون.
\v 7 شیمعی کە نەفرەتی دەکرد دەیگوت: «بڕۆ دەرەوە! بڕۆ دەرەوە، ئەی پیاوی خوێنڕێژ، ئەی پیاوی سووکوچروک!
\v 8 یەزدان تۆڵەی هەموو خوێنی ماڵی شاولی لێکردیتەوە کە لە جێی ئەو بوویت بە پاشا. یەزدان پاشایەتییەکەی دایە دەست ئەبشالۆمی کوڕت، تۆ بە خراپەی خۆت لەناودەچیت، چونکە تۆ پیاوێکی خوێنڕێژیت!»
\p 
\v 9 ئەبیشەی کوڕی چەرویاش بە پاشای گوت: «بۆچی ئەم سەگە تۆپیوە نەفرەت لە پاشای گەورەم دەکات؟ لێمگەڕێ با بۆی بچم و سەری لێ بکەمەوە.»
\p 
\v 10 بەڵام پاشا گوتی: «ئەی کوڕانی چەرویا، چی لەنێوان من و ئێوە هەیە؟ لێیگەڕێن با نەفرەت بکات، ئەگەر یەزدان پێی فەرمووبێت نەفرەت لە داود بکە، کێ هەیە بتوانێت بڵێت: ”بۆ ئەمە دەکەیت؟“»
\p 
\v 11 ئینجا داود بە ئەبیشەی و بە هەموو کاربەدەستەکانی گوت: «ئەوەتا من کوڕەکەی خۆم، ئەوەی لە پشتی خۆمەوە هاتووە دەیەوێت بمکوژێت، چ جای بنیامینییەک! لێیگەڕێن با نەفرەت بکات، چونکە یەزدان پێی فەرمووە.
\v 12 بەڵکو یەزدان بڕوانێتە زەلیلییەکەم و لە جیاتی ئەو نەفرەتەی ئەمڕۆ، بە چاکە پاداشتم بداتەوە.»
\p 
\v 13 ئیتر داود و پیاوەکانی بە ڕێگادا دەڕۆیشتن و شیمعییش بە قەراغ چیاکەدا لە بەرامبەری دەڕۆیشت، بە ڕێگاوە نەفرەتی دەکرد و لە بەرامبەری بەردی تێدەگرت و خۆڵی بە بادا دەکرد.
\v 14 پاشا و هەموو ئەو گەلەی لەگەڵی بوون گەیشتنە تەنکاوەکە، ماندوو بوون، لەوێ حەوانەوە.
\s1 ڕاوێژی ئەحیتۆفەل و حوشەی
\p 
\v 15 هەر لەو کاتەدا، ئەبشالۆم و هەموو سوپای ئیسرائیل هاتنە ئۆرشەلیم و ئەحیتۆفەلیشیان لەگەڵ بوو.
\v 16 ئینجا حوشەی ئەرکی هاوڕێی داود هاتە لای ئەبشالۆم، حوشەی بە ئەبشالۆمی گوت: «بژی پاشا، بژی پاشا!»
\p 
\v 17 ئەبشالۆمیش بە حوشەی گوت: «ئەمە خۆشەویستییەکەتە بۆ هاوڕێکەت؟ بۆچی لەگەڵ برادەرەکەت نەڕۆیشتیت؟»
\p 
\v 18 حوشەیش بە ئەبشالۆمی گوت: «نەخێر، بەڵکو ئەوەی یەزدان و ئەم گەلە و هەموو پیاوانی ئیسرائیل هەڵیانبژاردووە، من لایەنگری ئەو دەبم و لەگەڵ ئەودا دەمێنمەوە.
\v 19 پاشان، من خزمەتی کێ دەکەم؟ ئایا لەبەردەم کوڕەکەی نییە؟ هەروەک چۆن لەبەردەم باوکت خزمەتم کرد، ئاواش لەبەردەم تۆدا خزمەت دەکەم.»
\p 
\v 20 ئەبشالۆم بە ئەحیتۆفەلی گوت: «تەگبیر بکەن، چی بکەین؟»
\p 
\v 21 ئەحیتۆفەلیش بە ئەبشالۆمی گوت: «لەگەڵ کەنیزەکانی باوکت جووتبە، ئەوانەی بۆ پاراستنی کۆشکەکە بەجێی هێشتن. ئینجا هەموو ئیسرائیل دەیبیستێتەوە کە لەبەرچاوی باوکت کەوتوویت، بەو شێوەیە دەستی هەموو ئەوانە بەهێزتر دەبێت کە لەگەڵتدان.»
\v 22 لە سەربان چادرێکیان بۆ ئەبشالۆم دامەزراند و لەبەرچاوی هەموو ئیسرائیل لەگەڵ کەنیزەکانی باوکی جووتبوو.
\p 
\v 23 لەو سەردەمەدا ڕاوێژی ئەحیتۆفەل کە ڕاوێژی پێ دەکرا، وەک ئەوەی لە خوداوە بێت. هەموو ڕاوێژەکانی ئەحیتۆفەل ئاوا بوون بۆ داود و بۆ ئەبشالۆمیش.
\c 17
\p 
\v 1 ئەحیتۆفەل بە ئەبشالۆمی گوت: «پێم باشە دوازدە هەزار پیاو هەڵبژێریت و هەستیت و هەر ئەمشەو بەدوای داود بکەویت.
\v 2 کە هێشتا ماندووە و دەستی شلە بەسەریدا بدە، ئینجا بیتۆقێنە، ئیتر هەموو ئەو گەلەی لەگەڵیدان هەڵدێن. بە تەنها لە پاشا بدە،
\v 3 هەموو گەلت بۆ دەگەڕێتەوە. مەرگی ئەو پیاوەی داوای دەکەیت، واتای گەڕانەوەی هەمووانە، جا هەموو گەل لە ئاشتیدا دەبن.»
\v 4 ئەم تەگبیرەی لەلایەن ئەبشالۆم و هەموو پیرانی ئیسرائیلەوە پەسەند کرا.
\p 
\v 5 بەڵام ئەبشالۆم گوتی: «حوشەی ئەرکیش بانگ بکەن، با بزانین ئەویش چی دەڵێت.»
\v 6 ئیتر حوشەی هاتە لای، ئەبشالۆم پێی گوت: «ئەحیتۆفەل ئەم قسەیەی کردووە، ئایا بە قسەی بکەین؟ ئەگەر نا، تۆ چی دەڵێت؟»
\p 
\v 7 حوشەیش بە ئەبشالۆمی گوت: «ڕاوێژەکەی ئەم جارەی ئەحیتۆفەل باش نییە.
\v 8 تۆ باوکت و پیاوەکانی دەناسیت، پاڵەوانن، وەک دەڵەورچێک کە لە دەشتودەرە بەچکەکانی ڕاوکرابێت تووڕەن. جگە لەوەش باوکت پیاوی جەنگە و لەگەڵ لەشکر شەو بەسەرنابات.
\v 9 ئێستا ئەو لە ئەشکەوتێک یان لە شوێنێکدا خۆی شاردووەتەوە. ئەگەر لە سەرەتادا هەندێکتان لێ بکوژرێت و خەڵکی بیبیستنەوە و بڵێن، ”ئەو لەشکرەی لەگەڵ ئەبشالۆم بوو، تێکشکاوە،“
\v 10 ئەوا تەنانەت ئەو پاڵەوانەی دڵی وەک شێر وایە دڵی دەتوێتەوە، چونکە هەموو ئیسرائیل دەزانن کە باوکت پاڵەوانە و ئەوانەی لەگەڵیدان قارەمانن.
\p 
\v 11 «لەبەر ئەوە من ئامۆژگاریت دەکەم کە هەموو ئیسرائیل لە دانەوە هەتا بیری شابەع، وەک لمی سەر دەریا لێت کۆببنەوە لە زۆریدا، بەڕێزیشت سەرکردایەتی جەنگەکە بکە.
\v 12 ئینجا بۆی دەچینە یەکێک لەو شوێنانەی کە ئەوی لێیە، وەک شەونمی سەر زەوی بەسەریدا دادەبارین. هیچ کەسیان لێ ناهێڵینەوە، نە خۆی و نە هەموو ئەو پیاوانەی لەگەڵیدان.
\v 13 ئەگەر بۆ شارێک پاشەکشەی کرد، با هەموو ئیسرائیل گوریس بۆ ئەو شارە ببەن و دیوارەکانی شارەکە بۆ ناو دۆڵەکە ڕادەکێشین بۆ ئەوەی تەنانەت بەردێکیشی لەوێ نەبینرێتەوە.»
\p 
\v 14 ئینجا ئەبشالۆم و هەموو پیاوانی ئیسرائیل گوتیان: «ئامۆژگارییەکەی حوشەی ئەرکی لە ڕاوێژەکەی ئەحیتۆفەل باشترە.» ئیتر پووچەڵکردنەوەی ڕاوێژە باشەکەی ئەحیتۆفەل بە فەرمانی یەزدان بوو، بۆ ئەوەی یەزدان بەڵا بەسەر ئەبشالۆمدا بهێنێت.
\p 
\v 15 حوشەی بە سادۆق و بە ئەبیاتاری گوت، هەردوو کاهینەکە: «ئەحیتۆفەل بەو شێوەیە ئامۆژگاری بۆ ئەبشالۆم و پیرانی ئیسرائیل کردووە، منیش بەم شێوەیە ڕاوێژم کردووە.
\v 16 ئێستاش بە پەلە بنێرن و بە داود ڕابگەیەنن و بڵێن: ”ئەمشەو لەسەر تەنکاوەکەی بەرەو چۆڵەوانی بەسەرمەبە، لە ڕووبارەکە بپەڕەوە، نەوەک پاشا و ئەو گەلەی لەگەڵیدان هەڵبلووشرێن.“»
\p 
\v 17 یۆناتان و ئەحیمەعەچ نەیاندەویست بچنە ناو شارەکە و ببینرێن، لەلای کانی ڕۆگێل چاوەڕێی کارەکەرێک بوون پەیامێکیان پێ ڕابگەیەنێت، ئەوانیش بچن و بە داودی پاشای ڕابگەیەنن.
\v 18 بەڵام گەنجێک هەردووکیانی بینی و بە ئەبشالۆمی ڕاگەیاند، لەبەر ئەوە هەردووکیان بە پەلە ڕۆیشتن و چوونە ناو ماڵی پیاوێک لە بەحوریم، بیرێک لەناو حەوشەکەیدا هەبوو، هەردووکیان شۆڕ بوونەوە ناوی.
\v 19 ژنەکەی دەمی بیرەکەی بە ڕووپۆشێک داپۆشی و دانەوێڵەی بەسەردا بڵاوکردەوە، کەس پێی نەزانی.
\p 
\v 20 ئیتر خزمەتکارەکانی ئەبشالۆم هاتن بۆ لای ژنەکە بۆ ماڵەکە و گوتیان: «ئەحیمەعەچ و یۆناتان لەکوێن؟»
\p ژنەکەش وەڵامی دانەوە: «لە جۆگەی ئاوەکە پەڕینەوە.» جا پاش ئەوەی بەدوایاندا گەڕان و نەیاندۆزینەوە، گەڕانەوە ئۆرشەلیم.
\p 
\v 21 پاش ئەوەی خزمەتکارەکانی ئەبشالۆم ڕۆیشتن، ئەحیمەعەچ و یۆناتان لە بیرەکە هاتنە دەرەوە و ڕۆیشتن و بە داود پاشایان ڕاگەیاند و بە داودیان گوت: «هەستن و بە پەلە لە تەنکاوەکە بپەڕنەوە، چونکە ئەحیتۆفەل ئاوا ئامۆژگاری کردوون.»
\v 22 لەبەر ئەوە داود و هەموو ئەو گەلەی لەگەڵیدا بوون هەستان و لە ڕووباری ئوردون پەڕینەوە و لە بەرەبەیاندا کەس نەمابوو لە ڕووباری ئوردون نەپەڕیبێتەوە.
\p 
\v 23 بەڵام کاتێک ئەحیتۆفەل بینی کار بە ڕاوێژەکەی نەکراوە، گوێدرێژەکەی کورتان کرد و هەستا، بەرەو ماڵەکەی لە شارەکەی خۆیدا بەڕێکەوت و وەسیەتی بۆ ماڵەکەی کرد و خۆی خنکاند و مرد، جا لە گۆڕەکەی باوکی ناشتیان.
\p 
\v 24 ئینجا داود هات بۆ مەحەنەیم و ئەبشالۆمیش خۆی و هەموو ئەو پیاوانەی ئیسرائیل کە لەگەڵیدا بوون لە ڕووباری ئوردونەوە پەڕینەوە.
\v 25 ئەبشالۆم لە جیاتی یۆئاب عەماسای کردبوو بە سوپاسالار و عەماساش کوڕی پیاوێک بوو ناوی یەتەری ئیسرائیلی بوو، کە ئەبیگایلی کچی ناحاش، خوشکی چەرویا، دایکی یۆئاب خێزانی بوو.
\v 26 ئیسرائیل و ئەبشالۆم لە خاکی گلعاددا چادریان هەڵدا.
\p 
\v 27 کاتێک داود گەیشتە مەحەنەیم، شۆڤیی کوڕی ناحاش لە شاری ڕەبەی عەمۆنییەکان و ماکیری کوڕی عەمیێل لە لۆدەڤار و بەرزیلەیی گلعادی لە ڕۆگەلیمەوە
\v 28 ڕاخەر و تەشت و قاپوقاچاغی گڵین، گەنم و جۆ و ئارد، دانەوێڵەی برژاو و پاقلە و نیسک و نۆکی برژاو،
\v 29 هەنگوین و دەڵەمە\f + \fr 17:29 \ft یان دەرەمە، قۆناغی پێش دروستبوونی پەنیر.‏\f* و مەڕ و پەنیری مانگایان پێشکەشی داود و ئەو گەلەی لەگەڵیدا بوون کرد هەتا بیخۆن، چونکە گوتیان: «گەل لە چۆڵەوانیدا برسی و ماندوو و تینوون.»
\c 18
\s1 مەرگی ئەبشالۆم
\p 
\v 1 داود سەرژمێری ئەو پیاوانەی کرد کە لەگەڵیدا بوون، فەرماندەی هەزاران و سەدانی بەسەرەوە دانان.
\v 2 ئینجا داود سێیەکی سەربازەکانی بە دەستی یۆئابدا نارد، سێیەکیش بە دەستی ئەبیشەی کوڕی چەرویای برای یۆئاب، سێیەکیش بە دەستی ئیتتایی گەتی. پاشا بە سوپاکەی گوت: «هەروەها بە دڵنیاییەوە منیش لەگەڵتان دێمە دەرەوە.»
\p 
\v 3 بەڵام سەربازەکان گوتیان: «مەچۆ دەرەوە، چونکە ئەگەر ئێمە هەڵبێین گوێمان پێ نادەن، ئەگەر نیوەشمان لێ بمرێت هەر گوێمان پێ نادەن، بەڵام تۆ هێندەی دە هەزار کەسی لە ئێمە، ئێستاش باشترە کە تۆ بۆ یارمەتیدانمان لە شارەکە بیت.»
\p 
\v 4 پاشاش وەڵامی دانەوە: «ئەوەی پێتان باشە دەیکەم.»
\p ئیتر پاشا لەلای دەروازەکەوە وەستا و هەموو پیاوان بە یەکەی سەدان و بە هەزاران چوونە دەرەوە.
\v 5 پاشا فەرمانی بە یۆئاب و ئەبیشەی و ئیتتای کرد و گوتی: «لەبەر من، لەگەڵ ئەو گەنجە نەرم بن، لەگەڵ ئەبشالۆم.» هەموو سەربازەکانیش گوێیان لێبوو کاتێک پاشا سەبارەت بە ئەبشالۆم فەرمانی بە سەرکردەکان کرد.
\p 
\v 6 سوپای داود چوونە دەرەوە بۆ بەرەنگاربوونەوەی ئیسرائیل لە دەشتودەر، شەڕەکەش لە دارستانی ئەفرایم ڕوویدا.
\v 7 لەوێ سوپای ئیسرائیل لەبەردەم خزمەتکارەکانی داود شکان، لەو ڕۆژەدا کوشتارێکی گەورە ڕوویدا، بیست هەزار پیاو کوژرا.
\v 8 شەڕەکە لە هەموو ناوچەکەدا بڵاو بووەوە، لەو ڕۆژەدا ئەوانەی لەناو دارستانەکەدا لەناوچوون زیاتر بوون لەوانەی بە شمشێر لەناوچوون.
\p 
\v 9 ئەبشالۆم بە سواری هێسترەکەیەوە بەڕێکەوت تووشی خزمەتکارەکانی داود بوو. هێسترەکە چووە ژێر لقەکانی دار بەڕووێکی گەورە و سەری ئەبشالۆم لەنێوان لقەکانی دار بەڕووەکەدا گیربوو، لەنێوان ئاسمان و زەویدا هەڵواسرا، هێسترەکەی ژێریشی ڕۆیشت.
\p 
\v 10 پیاوێک بینی و بە یۆئابی ڕاگەیاند: «هەر ئێستا ئەبشالۆمم بینی بە دار بەڕووەکەوە هەڵواسرابوو.»
\p 
\v 11 یۆئابیش بەو پیاوەی گوت کە پێی ڕاگەیاند: «هەر ئێستا بینیت؟ ئەی بۆچی لەوێ بە زەویتدا نەدا، هەتا دە شاقل\f + \fr 18:11 \ft نزیکەی 115 گرام.‏\f* زیو و پشتێنێکت بدەمێ؟»
\p 
\v 12 بەڵام پیاوەکە بە یۆئابی گوت: «تەنانەت ئەگەر هەزار شاقل\f + \fr 18:12 \ft نزیکەی 12 کیلۆگرام.‏\f* زیویش بکێشن و بە دەستم بگات، بە هیچ جۆرێک دەستم بۆ کوڕی پاشا درێژ ناکەم، چونکە پاشا لەبەردەمی ئێمە فەرمانی بە تۆ و ئەبیشەی و ئیتتای کرد و گوتی: ”لەبەر من ئەو گەنجە، ئەبشالۆم بپارێزن و دەستی لێ مەدەن.“
\v 13 ئەگەر نا ستەمم لەگەڵ خۆم دەکرد، پاشاش هیچی لێ ناشاردرێتەوە، تۆش لە دژم دەوەستایت.»
\p 
\v 14 یۆئابیش گوتی: «من بەم شێوەیە لەبەردەمتدا ئارام ناگرم.» جا سێ ڕمی گرت بە دەستیەوە و لە دڵی ئەبشالۆمی گرت کە هێشتا لەناو دار بەڕووەکەدا زیندوو بوو.
\v 15 دە خزمەتکار کە هەڵگرانی تفاقەکانی یۆئاب بوون چواردەوریان دا، لە ئەبشالۆمیان دا و کوشتیان.
\p 
\v 16 ئەوسا یۆئاب فووی بە کەڕەنادا کرد و ڕێگای لەسەر سەربازەکان گرت، سەربازەکانیش لە ڕاونانی ئیسرائیل گەڕانەوە.
\v 17 ئیتر ئەبشالۆمیان هەڵگرت و لە دارستانەکەدا فڕێیاندایە ناو چاڵێکی گەورە، بەردێکی زۆریان لەسەری کەڵەکە کرد. هەموو ئیسرائیلیش هەریەکە و بۆ شوێنی خۆی هەڵات.
\p 
\v 18 پێشتر ئەبشالۆم کە هێشتا زیندوو بوو، ئەو کۆڵەکەیەی کە لە دۆڵی پاشادا بوو بردبووی و بۆ خۆی دایمەزراندبوو، چونکە گوتبووی: «کوڕێکم نییە بۆ یادکردنەوەی ناوەکەم.» کۆڵەکەکەشی بە ناوی خۆیەوە ناو نا، هەتا ئەمڕۆش پێ دەگوترێت «یادەوەری ئەبشالۆم».
\s1 گریانی داود بۆ ئەبشالۆم
\p 
\v 19 ئەوە بوو ئەحیمەعەچی کوڕی سادۆق گوتی: «با ڕابکەم و مژدە بدەمە پاشا: ”یەزدان حەقی بۆ سەندیتەوە و لە دوژمنەکانت ڕزگاری کردیت.“»
\p 
\v 20 یۆئابیش پێی گوت: «تۆ ئەمڕۆ خاوەن مژدە نیت، لە ڕۆژێکی دیکەدا مژدە بدە و ئەمڕۆ مژدە مەدە، چونکە کوڕی پاشا مردووە.»
\p 
\v 21 یۆئاب بە کوشییەکی\f + \fr 18:21 \ft لە وڵاتێکە لە سەرووی ڕووباری نیل.‏\f* گوت: «بڕۆ و ئەوەی بینیت بە پاشای ڕابگەیەنە.» کوشییەکەش کڕنۆشی بۆ یۆئاب برد و ڕایکرد.
\p 
\v 22 ئەحیمەعەچی کوڕی سادۆق دووبارە بە یۆئابی گوت: «هەرچییەک بووە لێمگەڕێ با منیش بەدوای کوشییەکەدا ڕابکەم.»
\p یۆئابیش گوتی: «کوڕم، تۆ بۆ ڕادەکەیت، لە کاتێکدا مژدەیەکت نییە شایانی پاداشت بێت؟»
\p 
\v 23 ئەویش گوتی: «هەرچی بێت، ڕادەکەم.»
\p یۆئابیش پێی گوت: «ڕابکە!» ئەوسا ئەحیمەعەچ بە ڕێگای پێدەشتەکەدا ڕایکرد و بە پێش کوشییەکە کەوت.
\p 
\v 24 کاتێک داود لەنێوان دەروازەکانی ژوورەوە و دەرەوە دانیشتبوو، ئێشکگرەکە سەرکەوتە سەربانی دەرگاکە بۆ سەر شووراکە، چاوی هەڵبڕی و بینی پیاوێک بە تەنها ڕادەکات.
\v 25 ئێشکگرەکە هاواری کرد و بە پاشای ڕاگەیاند.
\p پاشاش گوتی: «ئەگەر بە تەنها بێت مژدەی پێیە.» پیاوەکەش ڕایدەکرد و نزیک دەبووەوە.
\p 
\v 26 ئینجا ئێشکگرەکە پیاوێکی دیکەی بینی ڕادەکات، بانگی دەرگاوانەکەی کرد و پێی گوت: «ئەوەتا پیاوێکی دیکەش بە تەنها ڕادەکات.»
\p پاشاش گوتی: «ئەمەش هەر مژدەی پێیە.»
\p 
\v 27 ئێشکگرەکە گوتی: «من دەبینم کە ڕاکردنی یەکەم وەک ڕاکردنی ئەحیمەعەچی کوڕی سادۆق وایە.»
\p پاشاش گوتی: «ئەمە پیاوچاکە و مژدەیەکی چاکیش دەهێنێت.»
\p 
\v 28 ئەحیمەعەچ هاواری کرد و بە پاشای گوت: «سڵاو، هەموو شتێک باشە!» کڕنۆشی بۆ پاشا برد و سەری خستە سەر زەوی و گوتی: «ستایش بۆ یەزدانی پەروەردگارت، ئەوەی ئەو خەڵکەی ڕادەست کرد کە لە پاشای گەورەم هەستابوون!»
\p 
\v 29 پاشاش گوتی: «ئەو گەنجە، ئەبشالۆم سەلامەتە؟»
\p ئەحیمەعەچیش گوتی: «گەورەم، کاتێک کە یۆئابی بەردەستی تایبەتی تۆ منی دەنارد، شڵەژانێکی گەورەم بینی، بەڵام نەمزانی چی بوو.»
\p 
\v 30 پاشاش گوتی: «بسووڕێوە و لێرە ڕابوەستە.» ئەویش سووڕایەوە و ڕاوەستا.
\p 
\v 31 لەو کاتەدا کوشییەکەش هات، کوشییەکە گوتی: «پاشای گەورەم مژدەم بدەرێ، چونکە یەزدان ئەمڕۆ حەقی بۆ سەندیتەوە و لە هەموو ئەوانەی لێت ڕاست بوونەوە ڕزگاری کردیت!»
\p 
\v 32 پاشاش بە کوشییەکەی گوت: «ئەو گەنجە، ئەبشالۆم سەلامەتە؟»
\p کوشییەکەش گوتی: «با دوژمنەکانی پاشای گەورەم و هەموو ئەوانەی بۆ خراپە لە دژی تۆ سەرهەڵدەدەن وەک ئەو گەنجەیان لێ بێت.»
\p 
\v 33 جا پاشا نیگەران بوو، دەگریا و سەرکەوتە ژووری سەر دەروازەکە، بە دەم ڕۆیشتنەوە ئاوای دەگوت: «کوڕەکەم ئەبشالۆم! کوڕەکەم، کوڕەکەم ئەبشالۆم! خۆزگە لە جێی تۆ بمردبامایە، کوڕەکەم ئەبشالۆم! کوڕەکەم!»
\c 19
\p 
\v 1 پاشان بە یۆئاب ڕاگەیەنرا: «پاشا دەگریێت و شیوەن بۆ ئەبشالۆم دەگێڕێت.»
\v 2 ئەو ڕۆژە سەرکەوتنەکە لەلای هەموو سوپا بووە شیوەن، چونکە سەربازەکان لەو ڕۆژەدا گوێیان لێبوو گوترا: «پاشا بۆ کوڕەکەی دڵتەنگ بووە.»
\v 3 جا لەو ڕۆژەدا سەربازەکان وەک سوپایەکی شەرمەزاری هەڵاتوو لە جەنگدا بەدزییەوە گەڕانەوە ناو شارەکە.
\v 4 پاشاش ڕووی خۆی داپۆشی و بە دەنگێکی بەرز هاواری کرد: «کوڕەکەم ئەبشالۆم! ئەبشالۆم کوڕەکەم، کوڕەکەم!»
\p 
\v 5 ئینجا یۆئاب لە ماڵی پاشا چووە ژوورەوە و گوتی: «ئەمڕۆ ڕووی هەموو خزمەتکارەکانت شەرمەزار کرد، ئەوانەی لەم ڕۆژەدا دەربازکەری ژیانی خۆت و ژیانی کوڕ و کچ و ژن و کەنیزەکانت بوون.
\v 6 ئەوانەی ڕقیان لێت دەبێتەوە خۆشت دەوێن، ئەوانەش کە تۆیان خۆشدەوێت ڕقت لێیان دەبێتەوە. ئەمڕۆ دەرتخست کە تۆ سەرکردە و خزمەتکارەکانت بەلاوە هیچ نییە، لەبەر ئەوەی ئەمڕۆ زانیم ئەگەر ئەبشالۆم زیندوو بووایە و ئێمە هەموومان بمردبووینایە ئەوسا کارەکەت بە دڵ دەبوو.
\v 7 ئێستاش هەستە و بڕۆ دەرەوە دڵی خزمەتکارەکانت بدەوە، چونکە بە یەزدانی زیندوو، ئەگەر نەچیتە دەرەوە، ئەمشەو کەس لەگەڵت نامێنێتەوە، ئەوەش لە هەموو ئەو خراپانەی لە گەنجییەوە هەتا ئێستا تووشت بوون خراپتر دەبێت لەسەرت.»
\p 
\v 8 ئیتر پاشا هەستا و لە دەروازەکەدا دانیشت، بە هەموو گەل ڕاگەیەنرا: «ئەوەتا پاشا لە دەروازەکەدا دانیشتووە.»
\p جا هەموو گەل هاتنە بەردەم پاشا.
\s1 گەڕانەوەی داود بۆ ئۆرشەلیم
\p ئیسرائیلییەکانیش هەریەکە و بۆ چادرەکەی خۆی هەڵاتبوون.
\v 9 لەناو هەموو هۆزەکانی ئیسرائیلدا گەل مشتومڕیان بوو و دەیانگوت: «پاشا لە دەست دوژمنەکانمان فریامان کەوت، ئەو بوو کە لە دەست فەلەستییەکان دەربازی کردین، ئێستاش ئەو بەهۆی ئەبشالۆمەوە لە خاکەکەوە هەڵاتووە.
\v 10 ئەبشالۆمیش ئەوەی بەسەر خۆمانەوە دەستنیشانمان کرد لە جەنگدا مرد، بۆچی سەبارەت بە هێنانەوەی پاشا بێدەنگن؟»
\p 
\v 11 داودی پاشا پەیامی بۆ هەردوو کاهینەکە، سادۆق و ئەبیاتار نارد و گوتی: «لەگەڵ پیرانی یەهودا بدوێن و بڵێن: ”بۆچی دواهەمین کەس دەبن لە گەڕاندنەوەی پاشا بۆ کۆشکەکەی، چونکە هەموو ئەوەی ئیسرائیل گوتیان گەیشتە پاشا کە لە ئۆردوگاکەی بوو؟
\v 12 ئێوە برای منن و لە گۆشت و خوێنی منن، ئیتر بۆچی لە گەڕاندنەوەی پاشا دواهەمین کەس دەبن؟“
\v 13 هەروەها بە عەماسا بڵێن: ”ئایا تۆ لە گۆشت و خوێنی من نیت؟ با خودا توندترین سزام بدات، ئەگەر لەمەودوا لەلای من لە جێی یۆئاب نەبیتە فەرماندەی گشتی سوپا.“»
\p 
\v 14 جا دڵی هەموو پیاوانی یەهودای وەک یەک پیاو بەلای خۆیدا ڕاکێشا، ئەوانیش بەدوای پاشادا ناردیان و گوتیان: «خۆت و هەموو خزمەتکارەکانت بگەڕێنەوە.»
\v 15 لەبەر ئەوە پاشا گەڕایەوە و هاتە ڕووباری ئوردون.
\p پیاوانی یەهوداش هاتنە گلگال و چوونە پێشوازی پاشا، بۆ ئەوەی لە ڕووباری ئوردون بپەڕێتەوە.
\v 16 شیمعی کوڕی گێرای بنیامینی کە خەڵکی بەحوریمە، دەستپێشخەری کرد و لەگەڵ پیاوانی یەهودا بۆ پێشوازی داودی پاشا دابەزین،
\v 17 هەزار پیاویش لە بنیامین لەگەڵیدا بوون، لەگەڵ چیڤای خزمەتکاری ماڵی شاول، هەر پازدە کوڕەکەی و بیست خزمەتکارەکەی لەگەڵیدا بوون، هەموویان بە پەلە چوونە سەر ڕووباری ئوردون، بۆ لای پاشا.
\v 18 ئینجا لە تەنکاییەکە پەڕینەوە بۆ ئەوەی ماڵی پاشا بپەڕێننەوە و هەرچییەک پاشا بەلایەوە پەسەند بوو ئەنجامی بدەن.
\p شیمعی کوڕی گێراش کاتێک لە ڕووباری ئوردون پەڕییەوە لەبەردەم پاشادا بە ڕوودا کەوت،
\v 19 بە پاشای گوت: «با گەورەم تاوانم لەسەر نەژمێرێت. ئەو هەڵە گەورەیەی خزمەتکارەکەت بە یاد مەهێنەرەوە کە لە ڕۆژی چوونەدەرەوەی پاشای گەورەم لە ئۆرشەلیم کردی. با پاشا ئەوە لە دڵی خۆی نەگرێت.
\v 20 لەبەر ئەوەی خزمەتکارەکەت دەزانێت کە گوناهی کردووە، هەر بۆیە من ئەمڕۆ یەکەم کەسم لە هەموو بنەماڵەی یوسف کە بۆ پێشوازی پاشای گەورەم دابەزیوم.»
\p 
\v 21 ئەبیشەی کوڕی چەرویاش وەڵامی دایەوە و گوتی: «ئایا لەبەر ئەمە نابێت شیمعی بکوژرێت کە نەفرەتی لە دەستنیشانکراوی یەزدان کردووە؟»
\p 
\v 22 داودیش گوتی: «کوڕانی چەرویا، ئەمە چ پەیوەندییەکی بە ئێوەوە هەیە؟ بە چ مافێک دەست لە کاروبارم وەردەدەن؟ ئایا ئەمڕۆ کەسێک لە ئیسرائیل بکوژرێت؟ ئایا نازانن من ئەمڕۆ پاشای ئیسرائیلم؟»
\v 23 ئینجا پاشا بە شیمعی گوت: «تۆ نامریت.» پاشا سوێندی بۆ خوارد.
\p 
\v 24 هەروەها مەفیبۆشەتی کوڕەزای شاول بۆ پێشوازی پاشا دابەزی، لەو ڕۆژەی پاشا تێیدا ڕۆیشت هەتا ئەو ڕۆژەی بە سەلامەتی هاتەوە، بایەخی بە قاچەکانی و ڕیشی نەدابوو، جلەکانی نەشوشتبوو.
\v 25 ئەوە بوو کاتێک لە ئۆرشەلیم هاتە پێشوازی پاشا، پاشا پێی گوت: «مەفیبۆشەت، بۆچی لەگەڵمدا نەڕۆیشتیت؟»
\p 
\v 26 ئەویش گوتی: «گەورەم، پاشا، چیڤای خزمەتکارەکەم هەڵیخەڵەتاندم، لەبەر ئەوەی خزمەتکارەکەت گوتی: ”گوێدرێژێکم بۆ کورتان بکرێت تاوەکو سواری بم و لەگەڵ پاشادا بچم.“ بەڵام چیڤای خزمەتکارەکەم هەڵیخەڵەتاندم و
\v 27 لەلای پاشای گەورەم بوختانی بەدەم خزمەتکارەکەتەوە کرد. پاشای گەورەشم وەک فریشتەی خودا وایە، جا چیت پێ باشە ئەوە بکە.
\v 28 هەموو بنەماڵەی ئێمە خەڵکانێک بوون شایانی ئەوە بوون کە پاشای گەورەم بیانکوژێت، تۆش خزمەتکارەکەتت خستە نێو ئەو کەسانەی کە لەسەر خوانەکەت دەخۆن، ئیتر بە چ مافێکەوە داواکاریی زیاتر پێشکەش پاشا بکەم؟»
\p 
\v 29 پاشاش پێی گوت: «بۆچی قسەی زیاد دەکەیت؟ من گوتم تۆ و چیڤا کێڵگەکە لەنێوانتاندا دابەش بکەن.»
\p 
\v 30 مەفیبۆشەتیش بە پاشای گوت: «دوای ئەوەی پاشای گەورەم بە سەلامەتی گەڕاوەتەوە ماڵەکەی با چیڤا هەمووی بۆ خۆی ببات.»
\p 
\v 31 هەروەها بەرزیلەیی گلعادی لە ڕۆگەلیمەوە دابەزی و لە ڕووباری ئوردون لەگەڵ پاشادا پەڕییەوە، بۆ ئەوەی لەلای ڕووباری ئوردون بەڕێی بکات.
\v 32 بەرزیلەی زۆر پیر ببوو، تەمەنی هەشتا ساڵ بوو، لە ماوەی مانەوەی پاشا لە مەحەنەیم ئەو ئازووقەی بۆ دابین کردبوو، چونکە پیاوێکی زۆر دەوڵەمەند بوو.
\v 33 لەبەر ئەوە پاشا بە بەرزیلەیی گوت: «تۆش بپەڕەوە و لەگەڵم وەرە ئۆرشەلیم، ئازووقەت بۆ دابین دەکەم.»
\p 
\v 34 بەرزیلەییش بە پاشای گوت: «چەند ساڵ لە تەمەنم ماوە تاوەکو لەگەڵ پاشادا سەربکەومە ئۆرشەلیم؟
\v 35 من ئەمڕۆ تەمەنم هەشتا ساڵە، ئایا دەتوانم چاک و خراپ لە یەک جیا بکەمەوە، ئایا خزمەتکارەکەت چێژ وەردەگرێت لەوەی کە دەیخوات و دەیخواتەوە؟ ئایا گوێم لە دەنگی ژن و پیاوە گۆرانیبێژەکان دەبێت؟ ئیتر بۆچی خزمەتکارەکەت ببێت بە بارگرانی بەسەر پاشای گەورەمەوە؟
\v 36 خزمەتکارەکەت تەنها کەمێک لە ڕووباری ئوردون بەڕێت دەکات، ئیتر بۆچی پاشا بەم خەڵاتە پاداشتم دەداتەوە؟
\v 37 لێگەڕێ با خزمەتکارەکەت بگەڕێتەوە، بۆ ئەوەی لە شارۆچکەکەی خۆمدا لە نزیک گۆڕی دایک و باوکمەوە بمرم، وا کیمهامی خزمەتکارت لەگەڵ پاشای گەورەمدا دەپەڕێتەوە، تۆش چیت پێ باشە ئەوەی لەگەڵدا بکە.»
\p 
\v 38 پاشاش گوتی: «کیمهام لەگەڵمدا دەپەڕێتەوە و ئەوەی تۆ پێت باش بێت لەگەڵیدا دەکەم، ئەوەشی لێم دەخوازیت بۆت دەکەم.»
\p 
\v 39 هەموو گەل لە ڕووباری ئوردون پەڕینەوە، ئینجا پاشاش پەڕییەوە، پاشا بەرزیلەیی ماچکرد و داوای بەرەکەتی بۆ کرد، ئەویش گەڕایەوە شوێنەکەی خۆی.
\p 
\v 40 کاتێک پاشا پەڕییەوە گلگال، کیمهامیش لەگەڵیدا پەڕییەوە، هەموو سوپای یەهودا و نیوەی سوپای ئیسرائیل پاشایان پەڕاندەوە.
\p 
\v 41 ئیتر هەموو پیاوانی ئیسرائیل دەهاتنە لای پاشا، بە پاشایان دەگوت: «بۆچی براکانمان، پیاوانی یەهودا تۆیان دزی، پاشا و ماڵەکەیان لە ڕووباری ئوردون پەڕاندەوە، هەموو پیاوانی داودیش لەگەڵیدا بوون؟»
\p 
\v 42 هەموو پیاوانی یەهوداش وەڵامی پیاوانی ئیسرائیلیان دایەوە و گوتیان: «لەبەر ئەوەی پاشا لە خزمی نزیکی ئێمەیە، ئێوە بەم کارە بەغیلی دەبەن؟ ئایا هیچمان لە پاشا خواردووە، یان هیچی پێ بەخشیوین؟»
\p 
\v 43 پیاوانی ئیسرائیلیش وەڵامی پیاوانی یەهودایان دایەوە و گوتیان: «ئێمە دە ئەوەندەی ئێوە بەشمان لەلای پاشا هەیە، ئێمە لە ئێوە زیاتر مافمان بەسەر داودەوە هەیە. ئیتر بۆچی بە سووکایەتییەوە هەڵسوکەوتمان لەگەڵدا دەکەن؟ ئێمە نەبووین یەکەم جار سەبارەت بە گەڕاندنەوەی پاشاکەمان قسەمان کرد؟»
\p بەڵام قسەی پیاوانی یەهودا لە قسەی پیاوانی ئیسرائیل ڕەقتر بوو.
\c 20
\s1 یاخیبوونی شەڤەع لە دژی داود
\p 
\v 1 وا ڕێککەوت پیاوێکی گێرەشێوێن لەوێدا بوو، ناوی شەڤەعی کوڕی بیکری بوو، پیاوێکی بنیامینی بوو، فووی بە کەڕەنادا کرد و هاواری کرد:
\q1 «ئەی ئیسرائیل، هیچ نزیکایەتییەکمان لەگەڵ داود نییە،
\q2 هیچ میراتێکمان لە کوڕی یەسادا نییە!
\q1 هەرکەسە و بۆ چادرەکەی خۆی!»
\p 
\v 2 لەبەر ئەوە هەموو پیاوانی ئیسرائیل وازیان لە داود هێنا و بەدوای شەڤەعی کوڕی بیکریدا ڕۆیشتن. بەڵام پیاوانی یەهودا لە ڕووباری ئوردونەوە هەتا ئۆرشەلیم لەگەڵ پاشایاندا مانەوە.
\p 
\v 3 کاتێک داود هاتەوە بۆ کۆشکەکەی خۆی لە ئۆرشەلیم، ئەو دە کەنیزەیەی بۆ پاراستنی کۆشکەکە بەجێی هێشتبوون، بردنی و لە ماڵی دەستبەسەریدا داینان و بەخێوی دەکردن، بەڵام لەگەڵیاندا پاڵ نەکەوت، بەڵکو هەتا ڕۆژی مردنیان بە تەنهایی دەستبەسەر کرابوون.
\p 
\v 4 ئینجا پاشا بە عەماسای گوت: «لە سێ ڕۆژدا پیاوانی یەهودام بۆ کۆبکەرەوە و تۆش وەرە ئێرە.»
\v 5 عەماساش بۆ کۆکردنەوەی پیاوانی یەهودا چوو، بەڵام لەو کاتە دواکەوت کە بۆی دیاری کردبوو.
\p 
\v 6 داود بە ئەبیشەی گوت: «ئێستا شەڤەعی کوڕی بیکری لە ئەبشالۆم خراپتر دەبێت بۆمان. لەبەر ئەوە تۆ خزمەتکارەکانی گەورەت ببە و دوای بکەوە، نەوەک چەند شارێکی قەڵابەند بۆ خۆی پەیدا بکات و لەبەرچاومان ون بێت.»
\v 7 ئیتر پیاوەکانی یۆئاب و کریتی و پەلەتی و هەموو پاڵەوانەکان بە فەرماندەیی ئەبیشەی بۆ ڕاونانی شەڤەعی کوڕی بیکری لە ئۆرشەلیمەوە هاتنە دەرەوە.
\p 
\v 8 کاتێک لەلای بەردە گەورەکەی گبعۆن بوون، عەماسا بەرەو ڕوویان هات، یۆئابیش زرێیەکەی\f + \fr 20:8 \ft زرێ: بەڕگێکی کانزاییە کە لە کاتی شەڕ دەپۆشرێت.‏\f* پۆشیبوو و پشتێنێکیشی لەسەری بەستبوو، خەنجەرەکەشی لەناو کێلانەکەی\f + \fr 20:8 \ft کالانەکەی.‏\f* بوو، لە ناوقەدیەوە بەستبووی. ئینجا کە هاتە پێش، خەنجەرەکەی کەوتە خوارەوە.
\p 
\v 9 یۆئاب بە عەماسای گوت: «برام، چۆنی؟» جا یۆئاب بە دەستی ڕاستی ڕیشی عەماسای گرت بۆ ئەوەی ماچی بکات.
\v 10 عەماساش ئاگای لەو خەنجەرە نەبوو کە لە دەستەکەی دیکەی یۆئابدا بوو، یۆئاب خەنجەرەکەی کرد بە سکیدا و هەناوی ڕژایە سەر زەوی. پێویستی نەکرد کە جارێکی دیکە خەنجەر بکاتەوە بە سکیدا، چونکە دەستبەجێ مرد. ئینجا یۆئاب و ئەبیشەی براشی لەدوای شەڤەعی کوڕی بیکری ڕۆیشتن.
\p 
\v 11 یەکێک لە خزمەتکارەکانی یۆئاب لەلای عەماسا ڕاوەستا و گوتی: «ئەوەی یۆئابی دەوێت و ئەوەی سەر بە داودە با لەدوای یۆئابدا بێت!»
\v 12 عەماساش لە ناوەڕاستی ڕێگاکەدا لەناو خوێندا گەوزابوو، جا کاتێک خزمەتکارەکە بینی هەموو گەل ڕادەوەستن، عەماسای لەسەر ڕێگاکە گواستەوە بۆ ناو کێڵگەکە و پارچە جلێکی بەسەریدا دا، چونکە بینی هەرکەسێک بگاتە سەری ڕادەوەستێت.
\v 13 کاتێک عەماسا لە ڕێگاکە گواسترایەوە، هەموو پیاوێک دوای یۆئاب کەوت بۆ ڕاونانی شەڤەعی کوڕی بیکری.
\p 
\v 14 شەڤەعیش بەناو هەموو هۆزەکانی ئیسرائیلدا تێپەڕی، هەتا ئابێلی بێت‌مەعکا و هەموو ناوچەی بیرییەکان، ئەوانیش هەمووان کۆبوونەوە و شوێنی کەوتن.
\v 15 ئینجا ئەو لەشکرەی کە لەگەڵ یۆئاب بوو هاتن و لە ئابێلی بێت‌مەعکادا شەڤەعییان گەمارۆ دا، سەنگەریان لە دەوری شارەکە لێدا. شارەکە گەمارۆ درا، هەموو ئەو گەلەش کە لەگەڵ یۆئاب بوون سەرگەرمی ڕووخان بوون بۆ ڕووخاندنی شووراکە،
\v 16 لەو کاتەدا ژنێکی دانا لە شارەکەوە هاواری کرد: «گوێ بگرن! گوێ بگرن! بە یۆئاب بڵێن، وەرە پێشەوە بۆ ئێرە، هەتا قسەی لەگەڵدا بکەم.»
\v 17 ئەویش چووە پێشەوە بۆ لای، ژنەکەش پرسی: «تۆ یۆئابی؟»
\p ئەویش وەڵامی دایەوە: «من ئەوم.»
\p ژنەکە پێی گوت: «گوێ لە قسەی کارەکەرەکەت بگرە.»
\p ئەویش گوتی: «گوێم گرتووە.»
\p 
\v 18 ژنەکە گوتی: «پێشینان ئاوایان دەگوت: ”لە ئابێل دەپرسن،“ بەو شێوەیە کۆتاییان بە کێشەکە دەهێنا.
\v 19 ئێمە لەنێو شارەکانی ئیسرائیلدا ئاشتیخواز و دڵسۆزین، تۆش هەوڵی لەناوبردنی شارێک دەدەیت کە لە ئیسرائیلدا دایکانەیە؟ بۆچی میراتی یەزدان هەڵدەلووشیت؟»
\p 
\v 20 یۆئابیش وەڵامی دایەوە و گوتی: «لە من بەدوور بێت! لە من بەدوور بێت هەڵیبلوشم و تێکی بدەم!
\v 21 شتەکە بەو شێوەیە نییە، چونکە پیاوێک لە ناوچە شاخاوییەکانی ئەفرایمەوە کە ناوی شەڤەعی کوڕی بیکرییە دەستی لە داودی پاشا بەرز کردووەتەوە، بە تەنها ئەو بدەن بەدەستەوە و لە شارەکە دوور دەکەومەوە.»
\p ژنەکەش بە یۆئابی گوت: «سەری ئەو لە شووراکەوە بۆت هەڵدەدرێت.»
\p 
\v 22 ئینجا ئافرەتەکە بە داناییەکەی خۆی چوو بۆ لای هەموو گەل و ئەوانیش سەری شەڤەعی کوڕی بیکرییان لێکردەوە و بۆ یۆئابیان فڕێدا. ئەویش فووی بە کەڕەنادا کرد و لە شارەکە دوور کەوتنەوە، هەرکەسە و بۆ چادرەکەی. یۆئابیش گەڕایەوە بۆ ئۆرشەلیم بۆ لای پاشا.
\li1 
\v 23 یۆئابیش سەرکردەی هەموو سوپای ئیسرائیل بوو؛
\li1 بەنایای کوڕی یەهۆیاداعیش فەرماندەی کریتییەکان\f + \fr 20:23 \ft بڕوانە \xt یەکەم ساموئێل 30‏:14‏\xt*\ft ‏.‏\f* و پەلەتییەکان بوو؛
\li1 
\v 24 ئەدۆنیرام سەرپەرشتیاری بێگاری بوو؛
\li1 یەهۆشافاتی کوڕی ئەحیلودیش تۆمارکار بوو؛
\li1 
\v 25 شێڤا خامەی نهێنی بوو؛
\li1 سادۆق و ئەبیاتاریش کاهین بوون،
\li1 
\v 26 هەروەها عیرای یائیریش کاهینی داود بوو.
\c 21
\s1 تۆڵەسەندنەوەی داود بۆ گبعۆنییەکان
\p 
\v 1 لە سەردەمی پاشایەتی داود سێ ساڵ لەدوای یەک قاتوقڕی هەبوو، داودیش پرسیاری لە یەزدان کرد و یەزدانیش فەرمووی: «بەهۆی شاول و ماڵە خوێنڕێژەکەیەتی، لەبەر ئەوەی گبعۆنییەکانی کوشت.»
\p 
\v 2 پاشا گبعۆنییەکانی بانگکرد و لەگەڵیاندا دوا. گبعۆنییەکان لە نەوەی ئیسرائیل نەبوون، بەڵکو لە پاشماوەی ئەمۆرییەکان بوون و نەوەی ئیسرائیل سوێندیان بۆ پەیمانی ئاشتی خواردبوو، بەڵام شاول بەهۆی دڵگەرمی بۆ ئیسرائیل و یەهودا هەوڵی لەناوبردنی دان.
\v 3 جا داود بە گبعۆنییەکانی گوت: «چیتان بۆ بکەم و بە چی کەفارەت بکەم تاوەکو داوای بەرەکەت بۆ میراتی یەزدان بکەن؟»
\p 
\v 4 گبعۆنییەکانیش وەڵامیان دایەوە: «بۆمان نییە داوای زێڕ و زیو لە شاول و ماڵەکەی بکەین، هەروەها بۆشمان نییە کەس لە ئیسرائیلدا بکوژین.»
\p داودیش گوتی: «هەرچی بڵێن بۆتان دەکەم.»
\p 
\v 5 ئەوانیش بە پاشایان گوت: «ئەو پیاوەی کە قڕی کردین و پیلانی لە دژمان گێڕا بۆ ئەوەی لەناومان ببات و لە هەموو سنوورەکانی ئیسرائیلدا نەمێنینەوە،
\v 6 با حەوت پیاومان لە کوڕەکانی پێبدرێت، تاوەکو بۆ یەزدان هەڵیانواسین، لە گیڤعای شاولی هەڵبژێردراوی یەزدان.»
\p پاشاش گوتی: «من پێتان دەدەم.»
\p 
\v 7 پاشا دەستی لە مەفیبۆشەتی کوڕی یۆناتانی کوڕی شاول پاراست، لەبەر ئەو سوێندەی یەزدان کە لەنێوان داود و یۆناتانی کوڕی شاول هەبوو.
\v 8 بەڵام پاشا ئەمانەی برد: ئەرمۆنی و مەفیبۆشەت، هەردوو کوڕەکەی ڕیچپای کچی ئەییا کە لە شاول ببووی، لەگەڵ هەر پێنج کوڕەکەی مێرەڤی کچی شاول کە لە عەدرئێلی کوڕی بەرزیلەیی مەحۆلاتی ببووی.
\v 9 کوڕەکانی دایە دەست گبعۆنییەکان، ئەوانیش لەسەر چیا لەبەردەم یەزداندا بە کوژراوی هەڵیانواسین، هەر حەوتیان پێکەوە کەوتن، لە ڕۆژانی دروێنە لە سەرەتای دەستپێکردنی دروێنەی جۆ کوژران.
\p 
\v 10 ڕیچپای کچی ئەییا گوشێکی\f + \fr 21:10 \ft ڕیشاڵێکی ڕووەکییە کە لەو سەردەمەدا بەرگی ماتەمی لێ دروستدەکرا.‏\f* برد و لەسەر بەردێک بۆ خۆی ڕایخست. هەر لە سەرەتای دروێنەدا هەتا ئەو کاتەی باران لە ئاسمان باری نەیهێشت نە باڵندەی ئاسمان لە ڕۆژ و نە ئاژەڵی کێوی لە شەو دابەزنە سەر تەرمەکانیان.
\v 11 ئیتر ئەوەی ڕیچپای کچی ئەییا کەنیزەکەی شاول کردی بە داود ڕاگەیەنرا،
\v 12 داودیش چوو و ئێسکەکانی شاول و ئێسکەکانی یۆناتانی کوڕی لەلای دانیشتووانی یاڤێش گلعاد هێنا، ئەوانەی لە گۆڕەپانی بێت‌شانەوە دزیبوویان، لەو شوێنەدا کە فەلەستییەکان ئەو ڕۆژەی کە لە شاولیان دا لە گلبۆع هەڵیانواسیبوون.
\v 13 داود لەوێوە ئێسکەکانی شاول و یۆناتانی کوڕی هێنا و ئێسکی هەڵواسراوەکانیشی کۆکردەوە.
\p 
\v 14 ئینجا ئێسکەکانی شاول و یۆناتانی کوڕیان لە زەوی بنیامین لە چێلاع لەناو گۆڕەکەی قیشی باوکی ناشت و هەموو ئەو شتانەی پاشا فەرمانی پێدابوو کردیان. پاش ئەوە خودا وەڵامی ئەو پاڕانەوەی دایەوە کە لە پێناوی زەوییەکە کرا.
\s1 جەنگی دیکە لەگەڵ فەلەستییەکان
\p 
\v 15 جارێکی دیکە جەنگ لەنێوان فەلەستییەکان و ئیسرائیلدا بەرپابوو، داود لەگەڵ خزمەتکارەکانی دابەزین و لە دژی فەلەستییەکان جەنگان، داود شەکەت بوو.
\v 16 جا یەشبی بەنۆڤ کە یەکێک بوو لە نەوەی ڕافا و کێشی ڕمەکەی سێ سەد شاقل بڕۆنز\f + \fr 21:16 \ft سێ سەد شاقل بڕۆنز: نزیکەی 3,5 کیلۆگرام.‏\f* بوو، شمشێرێکی نوێی لە کەمەری بەستبوو، گوتی کە داود دەکوژێت.
\v 17 بەڵام ئەبیشەی کوڕی چەرویا بە هانایەوە هات و لە فەلەستییەکەی دا و کوشتی. ئینجا پیاوەکانی داود سوێندیان بۆ خوارد و گوتیان: «نابێت جارێکی دیکە بۆ جەنگ لەگەڵمان بێیتە دەرەوە، نەوەک چرای ئیسرائیل بکوژێنرێتەوە.»
\p 
\v 18 پاش ئەمانە جەنگێکی دیکە لەگەڵ فەلەستییەکان لە گۆڤ هەڵگیرسا، لەو کاتەدا سیبەخەیی حوشاتی سەفی کوشت کە یەکێک بوو لە نەوەی ڕافا.
\p 
\v 19 جارێکی دیکەش لەگەڵ فەلەستییەکان لە گۆڤ جەنگ هەڵگیرسایەوە، ئێلحانانی کوڕی یاعیری بێت‌لەحمی برای گۆلیاتی گەتی\f + \fr 21:19 \ft هەرچەندە لە 1 پوختەی مێژوو 20‏:5 نووسراوە کە ئێلحانان (لەحمی)ی برای گۆلیاتی کوشت، بەڵام دەشێت چەند جەنگاوەرێکی فەلەستی هەبێت کە ناویان گۆلیات بووبێت.‏\f* کوشت، دەسکی ڕمەکەی وەک نۆردی جۆڵاکان بوو.
\p 
\v 20 دیسان لە گەت جەنگ هەڵگیرسایەوە، پیاوێکی زەبەلاح هەبوو هەر پەلێکی شەش پەنجەی هەبوو، واتا بیست و چوار پەنجەی هەبوو. ئەویش هەر لە نەوەی ڕافا بوو.
\v 21 کاتێک سووکایەتی بە ئیسرائیل کرد، یۆناتانی کوڕی شیمەعای برای داود کوشتی.
\p 
\v 22 ئەو چوارە لە نەوەی ڕافا بوون لە گەت، بە دەستی داود و خزمەتکارەکانی کوژران.
\c 22
\s1 سروودی داود بۆ ستایشی خودا
\p 
\v 1 داود ئەم سروودەی بۆ یەزدان گوت، دوای ئەوەی یەزدان لە دەستی هەموو دوژمنەکانی و لە دەستی شاول ڕزگاری کرد.
\v 2 گوتی:
\q1 «یەزدان تاشەبەردی منە، قەڵا و دەربازکەرمە،
\q2 
\v 3 خودام ئەو تاشەبەردەیە کە پەنای بۆ دەبەم،
\q2 قەڵغان و هێزی ڕزگاریمە،
\q1 پەناگا و حەشارگەمە، ڕزگارکەری منە،
\q2 لە ستەم ڕزگارم دەکات.
\b
\q1 
\v 4 «لە یەزدان دەپاڕێمەوە، ئەوەی کە شایانی ستایشە،
\q2 لە دوژمنەکانم ڕزگار دەبم،
\q1 
\v 5 چونکە شەپۆلی مەرگ منی پێچایەوە،
\q2 لێشاوی لەناوچوون زەندەقی بردم،
\q1 
\v 6 پەتی جیهانی مردووان بە دەورمدا تەنراوە،
\q2 داوی مردن لەبەردەمم دانراوە.
\b
\q1 
\v 7 «لە تەنگانەمدا لە یەزدان پاڕامەوە،
\q2 هاوارم بردە بەر خودام،
\q1 لە پەرستگاکەیەوە گوێی لە دەنگی من بوو،
\q2 گوێی لە هاوارم بوو.
\q1 
\v 8 ئینجا زەوی لەرزی و هەژا،
\q2 بناغەکانی ئاسمان ڕاژەنین،
\q2 لە تووڕەیی ئەو لەرزین.
\q1 
\v 9 دووکەڵ لە لووتی بەرزبووەوە،
\q2 ئاگرێکی لووشدەر لە دەمی هاتە دەرەوە،
\q2 وەک ژیلەمۆی پشکۆی داگیرساو بوو.
\q1 
\v 10 ئاسمانی شەقکرد و دابەزییە خوارەوە،
\q2 هەوری تاریک لەژێر پێی بوو.
\q1 
\v 11 سواری کەڕوب\f + \fr 22:11 \ft کەڕوب: بوونەوەرێکی ئاسمانی باڵدارە. بڕوانە \xt حزقیێل 10‏:5‏\xt*\ft ‏.‏\f* بوو و فڕی،
\q2 بەسەر باڵی بادا بەرزبووەوە.
\q1 
\v 12 تاریکی کردە ڕەشماڵ لە دەوری خۆی،
\q2 هەوری تاریکی پڕ بارانی ئاسمان.
\q1 
\v 13 لە ڕۆشنایی ئامادەبوونی ئەو
\q2 پشکۆ ئاگرەکان داگیرسان.
\q1 
\v 14 یەزدان لە ئاسمانەوە گرماندی،
\q2 ئەو خودایەی هەرەبەرزە دەنگی خۆی لەرزاندەوە.
\q1 
\v 15 تیرەکانی هاویشت و بڵاوەی بە دوژمنەکانی کرد،
\q2 بە بروسکەی گەورە پەرێشانی کردن.
\q1 
\v 16 بنی دەریا دەرکەوت،
\q2 بناغەکانی زەوی ئاشکرا بوون،
\q1 لە سەرزەنشتی یەزدان،
\q2 لە گەرمی هەناسەی لووتی.
\b
\q1 
\v 17 «لە بەرزاییەوە دەستی درێژکرد و منی گرت،
\q2 لەناو ئاوە قووڵەکانەوە دەریهێنام.
\q1 
\v 18 لە دوژمنە بە تواناکەم ڕزگاری کردم،
\q2 لە ناحەزەکانم کە زۆر لە من بەهێزتر بوون.
\q1 
\v 19 لە ڕۆژی لێقەومانم هاتنە سەرم،
\q2 بەڵام یەزدان پشت و پەنام بوو.
\q1 
\v 20 منی هێنایە دەرەوە بۆ جێگایەکی پان و بەرین،
\q2 ڕزگاری کردم، چونکە دڵخۆشە پێم.
\b
\q1 
\v 21 «یەزدان بەگوێرەی ڕاستودروستیم پاداشتی داومەتەوە،
\q2 بەگوێرەی دەستپاکیم ڕێزداری کردووم،
\q1 
\v 22 چونکە من ڕێچکەی یەزدانم گرتووەتەبەر،
\q2 لە خودای خۆم یاخی نەبووم.
\q1 
\v 23 هەموو حوکمەکانی لەبەرچاومدان،
\q2 لە فەرزەکانی لام نەداوە.
\q1 
\v 24 لەبەردەمی ئەو بێ کەموکوڕی بووم و
\q2 خۆم لە گوناه پاراستووە.
\q1 
\v 25 یەزدان بەگوێرەی ڕاستودروستیم پاداشتی داومەتەوە،
\q2 بەگوێرەی دەستپاکیم لەبەردەمی.
\b
\q1 
\v 26 «لەگەڵ دڵسۆزەکان دڵسۆزی دەنوێنیت،
\q2 لەگەڵ ئەوانەی بێ کەموکوڕین چاکی دەنوێنیت،
\q1 
\v 27 لەگەڵ پاکەکان پاکی دەنوێنیت،
\q2 بەڵام لەگەڵ خوارەکان زیرەکی دەنوێنیت.
\q1 
\v 28 تۆ خەڵکی بێفیز ڕزگار دەکەیت،
\q2 بەڵام چاوەکانت لەسەر لووتبەرزانە، دەیانشکێنیت.
\q1 
\v 29 ئەی یەزدان، تۆ چرای منیت،
\q2 یەزدان تاریکیم ڕووناک دەکاتەوە.
\q1 
\v 30 بە یارمەتی تۆ دەتوانم لەشکرێک تێکبشکێنم،
\q2 لەگەڵ خودای خۆم دەتوانم بەسەر شووراکاندا سەربکەوم.
\b
\q1 
\v 31 «ڕێبازی خودا تەواوە،
\q2 بەڵێنی یەزدان بێگەردە،
\q2 ئەو قەڵغانە بۆ هەموو ئەوانەی پەنای بۆ دەبەن.
\q1 
\v 32 لە یەزدان بەولاوە کێ خودایە؟
\q2 لە خودامان بەولاوە کێ تاشەبەردەکەیە؟
\q1 
\v 33 خودایە ئەوەی بە هێز پاڵپشتیم دەکات،
\q2 بە تەواوی ڕێگام لەبەردەمدا دەکاتەوە.
\q1 
\v 34 پێیەکانم وەک پێی ئاسک لێ دەکات،
\q2 لەسەر بەرزایی ڕامدەگرێت.
\q1 
\v 35 مەشق بە دەستەکانم دەکات بۆ جەنگ،
\q2 تاکو بتوانم بە بازووم کەوانی بڕۆنز بچەمێنمەوە.
\q1 
\v 36 تۆ قەڵغانی ڕزگاریی خۆتت پێ بەخشیوم،
\q2 هاوکاریت گەورەم دەکات.
\q1 
\v 37 جێی هەنگاوەکانم تەخت و فراوان دەکەیت،
\q2 تاکو پێم نەخلیسکێت.
\b
\q1 
\v 38 «دوژمنەکانم ڕاونا و وردوخاشم کردن،
\q2 هەتا لەناوم نەبردن نەگەڕامەوە.
\q1 
\v 39 لەناوم بردن و وردوخاشم کردن، ئیتر نەیانتوانی هەستنەوە،
\q2 لەژێر پێم کەوتن.
\q1 
\v 40 کەمەری منت توند کرد بۆ جەنگ،
\q2 وات لە بەرهەڵستکارانی من کرد لەبەر پێم کڕنۆش ببەن.
\q1 
\v 41 دوژمنەکانم پشتیان تێ کردم و ڕایانکرد،
\q2 من ناحەزەکانی خۆمم لەناوبرد.
\q1 
\v 42 هاواریان هێنا، بەڵام ڕزگارکەر نەبوو،
\q2 هاواریان بۆ یەزدان برد، بەڵام بە دەنگیانەوە نەچوو.
\q1 
\v 43 وەک تۆزی زەوی ئەوانم هاڕی،
\q2 وەک قوڕی سەر ڕێگا پێم خستە سەریان و پێشێلم کردن.
\b
\q1 
\v 44 «لە هێرشی گەلان ڕزگارت کردم،
\q2 تۆ منت بە سەرۆکی نەتەوەکان هێشتەوە.
\q1 گەلێک کە نەمدەناسین خزمەتم دەکەن،
\q2 
\v 45 بێگانەکان ملکەچیم بۆ دەنوێنن،
\q2 هەرکە دەنگم دەبیستن گوێڕایەڵم دەبن.
\q1 
\v 46 بێگانەکان ورە بەر دەدەن و
\q2 بە لەرزەوە لە قەڵاکانیان دێنە دەرەوە.
\b
\q1 
\v 47 «یەزدان زیندووە، ستایش بۆ تاشەبەردەکەم!
\q2 خودای ڕزگارکەرم تاشەبەردەکەیە، پایەبەرزە!
\q1 
\v 48 خودایە کە تۆڵەم بۆ دەکاتەوە،
\q2 گەلان ملکەچی من دەکات،
\q2 
\v 49 لە چنگی دوژمنەکانم دەرمدەهێنێت.
\q1 پایەبەرزی کردم بەسەر ناحەزانم،
\q2 لە دەست پیاوێکی توندوتیژ ڕزگارت کردم.
\q1 
\v 50 لەبەر ئەوە ئەی یەزدان، لەنێو نەتەوەکاندا ستایشت دەکەم،
\q2 گۆرانی ستایش بۆ ناوت دەڵێم.
\b
\q1 
\v 51 «سەرکەوتنی گەورە بە پاشای خۆی دەبەخشێت،
\q2 خۆشەویستی نەگۆڕ بەسەر دەستنیشانکراوەکەیدا دەبارێنێت،
\q2 بۆ سەر داود و نەوەکانی بۆ هەتاهەتایە.»
\c 23
\s1 دواهەمین وشەکانی داود
\p 
\v 1 ئەمانەش دواهەمین وشەکانی داودن:
\q1 «ئەمە وەک سروش درا بە داودی کوڕی یەسا،
\q2 ئەو پیاوەی کە لەلایەن خودای هەرەبەرز پایەبەرز بووە،
\q1 دەستنیشانکراوەکەی خودای یاقوب و
\q2 زەبووربێژە دەنگ خۆشەکەی ئیسرائیل:
\b
\q1 
\v 2 «ڕۆحی یەزدان لە ڕێگەی منەوە دوا،
\q2 وشەکەشی لەسەر زمانم بوو.
\q1 
\v 3 خودای ئیسرائیل فەرمووی،
\q2 تاشەبەردەکەی ئیسرائیل\f + \fr 23:3 \ft ناوێکی تایبەتە بە خودای ئیسرائیل کە دڵسۆزی خودا دەردەخات. بڕوانە \xt دواوتار 32‏:4‏-31‏\xt*\ft ‏.‏\f* لەگەڵ من دوا:
\q1 ”کاتێک کەسێک بە ڕاستودروستی فەرمانڕەوایەتی خەڵک دەکات،
\q2 کاتێک بە لەخواترسییەوە فەرمانڕەوایەتی دەکات،
\q1 
\v 4 ئەوا وەک ڕووناکی بەیانە لە کاتی خۆرهەڵاتن
\q2 لە بەیانییەکی ساماڵ،
\q1 وەک ڕووناکی بێگەردی پاش بارانە
\q2 کە گیای تازە لە زەوییەوە دەهێنێتە دەرەوە.“
\b
\q1 
\v 5 «ئایا ماڵەکەم لەلای خودا بەم جۆرە نییە؟
\q2 پەیمانێکی هەتاهەتایی لەگەڵ بەستووم،
\q2 کە لە هەموو ڕووێکەوە ڕێکوپێک و مسۆگەرە.
\q1 ئەی هەموو ڕزگاری و
\q2 ئارەزووێکم ناهێنێتە دی؟
\q1 
\v 6 بەڵام بەدکاران هەموویان وەک دڕک فڕێدەدرێن،
\q2 کە بە دەست کۆناکرێنەوە.
\q1 
\v 7 هەرکەسێک کە خۆی لە دڕکەکان بدات،
\q2 ئامێری ئاسن و داری ڕم بەکاردەهێنێت؛
\q2 ئەمانە لە شوێنی خۆیاندا بە ئاگر دەسووتێنرێن.»
\s1 پاڵەوانەکانی داود
\p 
\v 8 ئەمانەش ناوی پاڵەوانەکانی داودن:
\p یۆشێڤ بەشەڤەتی تەحکەمۆنی یەکێک بوو لە سێ پاڵەوانەکەی نێو هێزی تایبەت. ئەو بوو بە ڕمەکەی لە شەڕێکدا هەشت سەد کەسی کوشت.
\p 
\v 9 پاش یۆشێڤ، ئەلعازاری کوڕی دۆدایی ئەحۆحی هەبوو، کە یەکێک بوو لە سێ پاڵەوانەکە. ئەو لە پەس دەممیم\f + \fr 23:9 \ft بڕوانە \xt یەکەم پوختەی مێژوو 11‏:13‏\xt*\ft ‏.‏\f* لەگەڵ داود بوو، کاتێک گاڵتەی بەو فەلەستییانە کرد کە بۆ جەنگ کۆببوونەوە، پیاوانی ئیسرائیلیش پاشەکشەیان کرد.
\v 10 ئەو هەستا و هەتا دەستی شل بوو لە فەلەستییەکانی دا، دەستی بە شمشێرەکەیەوە نووسا و یەزدانیش لەو ڕۆژەدا ڕزگارییەکی گەورەی ئەنجام دا. کاتێک لەشکرەکەشی بۆ لای ئەلعازار گەڕانەوە هیچ نەمابوو تەنها تاڵانکردن نەبێت.
\p 
\v 11 پاش ئەلعازاریش، شەممای کوڕی ئاگێی هاراری دێت. کاتێک فەلەستییەکان لەشکریان لە شوێنی پەڵە نیسکێکدا کۆکردەوە، لەشکری ئیسرائیل لەبەردەم فەلەستییەکاندا هەڵات.
\v 12 بەڵام شەمما لە ناوەڕاستی پەڵە نیسکەکەدا ڕاوەستا و بەرگری کرد و لە فەلەستییەکانی دا، یەزدانیش سەرکەوتنێکی گەورەی پێ بەخشی.
\p 
\v 13 سێ پاڵەوانی هەڵبژاردە لە ڕیزی سی پاڵەوانەکەی هێزی تایبەت لە وەرزی دروێنەدا دابەزین بۆ لای داود لە ئەشکەوتی عەدولام، لەشکری فەلەستییەکانیش لە دۆڵی ڕفایم دامەزرابوون.
\v 14 لەو کاتەدا داود لە قەڵاکە بوو، سەربازگەی فەلەستییەکانیش لە بێت‌لەحم بوو.
\v 15 داود ئاهی هەڵکێشا و گوتی: «خۆزگە کەسێک لە بیرەکەی لای دەروازەکەی بێت‌لەحم ئاوی بۆ دەهێنام!»
\v 16 ئیتر سێ پاڵەوانەکە هێڵی ئۆردوگای فەلەستییەکانیان بەزاند و لە بیرەکەی بێت‌لەحمەوە ئەوەی لەلای دەروازەکەیە ئاویان هەڵکێشا و هەڵیانگرت، هێنایان بۆ داود، ئەویش نەیویست بیخواتەوە، بەڵکو وەک پێشکەشکراوێک بۆ یەزدان ڕشتی.
\v 17 گوتی: «ئەی یەزدان، لە من بەدوور بێت ئەمە بکەم. ئەمە خوێنی ئەو پیاوانەیە کە ژیانی خۆیان خستە مەترسییەوە.» لەبەر ئەوە داود نەیویست بیخواتەوە.
\p ئەمانە چەند نموونەیەک بوون لە ئازایەتییەکانی سێ پاڵەوانەکە.
\p 
\v 18 ئەبیشەی برای یۆئاب، کوڕی چەرویاش ڕابەری سێ پاڵەوانەکەی هێزی تایبەت بوو. ئەو بە ڕمەکەی لەگەڵ سێ سەد کەس جەنگا و کوشتنی، وەک سێ پاڵەوانەکە ناوبانگی هەبوو.
\v 19 ئایا ئەو زیاتر لە سێ پاڵەوانەکە ڕێزی لێ نەدەگیرا؟ ئەو بوو بە فەرماندەیان، بەڵام ناوبانگی نەدەگەیشتە سێیەکەی یەکەم.
\p 
\v 20 بەنایای کوڕی یەهۆیاداعی خەڵکی قەڤچەئێل کوڕێکی بەجەرگ بوو، زۆر قارەمانیێتی نواندبوو. هەر ئەو لە دوو شێرە پیاوەکەی مۆئابی دا، هەروەها لە ڕۆژێکی بەفردا دابەزییە ناو چاڵێک و شێرێکی کوشت.
\v 21 ئەویش بوو کە لە پیاوێکی میسری زەبەلاحی دا، پیاوە میسرییەکە ڕمێکی بەدەستەوە بوو، بەنایاش بە گۆچانێکەوە بۆی دابەزی. ڕمەکەی لە دەستی میسرییەکە ڕفاند و بە ڕمەکەی خۆی کوشتی.
\v 22 ئەمانە چەند نموونەیەک بوون لە ئازایەتییەکانی بەنایای کوڕی یەهۆیاداع، وەک سێ پاڵەوانەکە ناوبانگی پەیدا کرد.
\v 23 لە سی پاڵەوانەکە زیاتر ڕێزی لێ دەگیرا، بەڵام ناوبانگی نەگەیشتە سێیەکە، ئیتر داود کردییە بەرپرسی پاسەوانەکانی خۆی.
\b
\li4 
\v 24 ئەمانە لە ڕیزی سی پاڵەوانەکە بوون:
\b
\li1 عەساهێلی برای یۆئاب،
\li1 ئێلحانانی کوڕی دۆدۆی بێت‌لەحمی،
\li1 
\v 25 شەممای حەرۆدی،
\li1 ئەلیقای حەرۆدی،
\li1 
\v 26 حەلەچی پەلتیی،
\li1 عیرای کوڕی عیقێشی تەقۆعی،
\li1 
\v 27 ئەبیعەزەری عەناتۆتی،
\li1 مەڤونەیی حوشاتی،
\li1 
\v 28 چەلمۆنی ئەحۆحی،
\li1 مەهەرەیی نەتۆفایی،
\li1 
\v 29 حێلەدی کوڕی بەعەنای نەتۆفایی،
\li1 ئیتەیی کوڕی ڕیڤەی کە خەڵکی گیڤعای بنیامین،
\li1 
\v 30 بەنایای پیرعاتۆنی،
\li1 هیدەی لە شیوەکانی گاعەشەوە،
\li1 
\v 31 ئەبی‌عەلڤۆنی عەرڤاتی،
\li1 عەزماڤێتی بەرحومی،
\li1 
\v 32 ئەلیەحبای شەعەلڤۆنی،
\li1 کوڕەکانی یاشێن،
\li1 یۆناتانی کوڕی
\v 33 شەممای هاراری،
\li1 ئەحیامی کوڕی شاراری هاراری،
\li1 
\v 34 ئەلیفەلەتی کوڕی ئەحەسبەیی مەعکاتی،
\li1 ئەلیعامی کوڕی ئەحیتۆفەلی گیلۆنی،
\li1 
\v 35 حەسرۆی کارمەلی،
\li1 پەعەرەیی ئەربی،
\li1 
\v 36 یەگالی کوڕی ناتانی چۆڤائی،
\li1 کوڕی هەگری،
\li1 
\v 37 چەلەقی عەمۆنی،
\li1 نەحەرەیی بئێرۆتی کە هەڵگری تفاقەکانی یۆئابی کوڕی چەرویا بوو،
\li1 
\v 38 عیرای یەتری،
\li1 گارێڤی یەتری و
\li1 
\v 39 ئوریای حیتی.
\b
\li4 هەموویان سی و حەوت کەس بوون.
\c 24
\s1 سەرژمێری بۆ پێکهێنانی سوپا
\p 
\v 1 دووبارە تووڕەیی یەزدان لە ئیسرائیل جۆشا و داودی لێ هاندان و فەرمووی: «بڕۆ سەرژمێری ئیسرائیل و یەهودا بکە.»
\p 
\v 2 پاشا بە یۆئاب و بەو فەرماندانەی سوپای گوت کە لەلای بوون: «ئێستا بەناو هەموو هۆزەکانی ئیسرائیلدا بگەڕێن، لە دانەوە هەتا بیری شابەع، جەنگاوەران تۆمار بکەن بۆ ئەوەی ژمارەیان بزانم.»
\p 
\v 3 یۆئابیش بە پاشای گوت: «با یەزدانی پەروەردگارت جەنگاوەران سەد ئەوەندە زیاتر بکات و پاشای گەورەم بە چاوی خۆی ئەوە ببینێت، بەڵام بۆچی پاشای گەورەم ئەم کارەی پێ باشە؟»
\p 
\v 4 لەگەڵ ئەوەشدا پاشا بڕیارەکەی خۆی بەسەر یۆئاب و سەرکردەکانی سوپادا سەپاند، ئیتر ئەوان لەبەردەم پاشا چوونە دەرەوە تاوەکو جەنگاوەرانی ئیسرائیل تۆمار بکەن.
\p 
\v 5 دوای ئەوەی لە ڕووباری ئوردون پەڕینەوە، لە نزیکی عەرۆعێر لەلای باشووری شارۆچکەکە کە لەناو دەربەندەکەیە چادریان هەڵدا. پاشان چوونە ناو خاکی گاد و دوای ئەوەش بەردەوام بوون هەتا شارۆچکەی یەعزێر.
\v 6 پاشان چوونە گلعاد و ناوچەی تەحتیم حۆدشی و ئینجا چوونە دان یەعەن و سووڕانەوە بۆ سەیدا.
\v 7 دوای ئەوە چوونە قەڵای سور و هەموو شارۆچکەکانی حیڤی و کەنعانییەکان. لە کۆتاییدا چوونە نەقەبی یەهودا بۆ بیری شابەع.
\p 
\v 8 بەناو هەموو خاکەکەدا گەڕان و دوای نۆ مانگ و بیست ڕۆژ گەڕانەوە ئۆرشەلیم.
\p 
\v 9 یۆئاب ئەنجامی سەرژمێرییەکەی دایە پاشا: لە ئیسرائیل هەشت سەد هەزار پیاوی بە توانا لە بەکارهێنانی شمشێر هەبوون، لە یەهوداش پێنج سەد هەزار هەبوون.
\p 
\v 10 پاش سەرژمێریکردنی گەل، داود تووشی ئازاری ویژدان بوو، بە یەزدانی گوت: «زۆر گوناهم کرد لەوەی کە کردم. ئێستاش ئەی یەزدان، لە تاوانی خزمەتکارەکەت خۆشبە، چونکە ڕەفتارێکی زۆر گێلانەم کرد.»
\p 
\v 11 پێش ئەوەی داود بەیانی لە خەو هەستێت، فەرمایشتی یەزدان بۆ گادی پێغەمبەر هاتبوو، ئەوەی پەیامی خودای بە داود ڕادەگەیاند، پێی فەرمووبوو:
\v 12 «بڕۆ بە داود بڵێ: ”یەزدان ئەمە دەفەرموێت: من سێ هەڵبژاردە دەخەمە بەردەمت و تۆش یەکێکیان هەڵبژێرە بۆ ئەوەی جێبەجێی بکەم لەسەرت.“»
\p 
\v 13 ئیتر گاد چوو بۆ لای داود و پێی گوت: «ئایا لە خاکەکەتدا سێ ساڵ\f + \fr 24:13 \ft سێ ساڵ: بڕوانە \xt یەکەم پوختەی مێژوو 21‏:11‏،12‏\xt*\ft ‏.‏\f* قاتوقڕیت بەسەربێت؟ یان سێ مانگ لەبەردەم دوژمنەکانت هەڵبێیت و ئەوانیش ڕاوت بنێن؟ یان سێ ڕۆژ دەرد لە خاکەکەتدا بڵاو ببێتەوە؟ ئێستا بزانە و ببینە، چی وەڵامی خودا بدەمەوە کە منی ناردووە.»
\p 
\v 14 داودیش بە گادی گوت: «زۆر لە تەنگانەدام، با بکەوینە دەستی یەزدان، چونکە ئەو بەزەیی زۆرە، بەڵام با نەکەوینە ژێر دەستی مرۆڤەوە.»
\p 
\v 15 لەبەر ئەوە یەزدان لە بەیانییەوە هەتا کاتی دیاریکراو دەردی خستە ناو ئیسرائیلەوە، ئیتر لە دانەوە هەتا بیری شابەع حەفتا هەزار پیاو مردن.
\v 16 فریشتەکە دەستی بۆ ئۆرشەلیم درێژکرد بۆ ئەوەی وێرانی بکات، بەڵام یەزدان کارەساتەکەی ڕاگرت، بەو فریشتەیەی فەرموو کە گەلی لەناودەبرد: «بەسە! ئێستا دەست هەڵبگرە!» لەو کاتەدا فریشتەکەی یەزدان لەسەر جۆخینەکەی ئەرەونای یەبوسی بوو.
\p 
\v 17 کاتێک داود فریشتە لەناوبەرەکەی گەلی بینی، بە یەزدانی گوت: «من گوناه و تاوانم کردووە، بەڵام ئەم مەڕانە چییان کردووە؟ تکایە با سزاکەت بۆ من و بنەماڵەکەم بێت.»
\s1 بنیادنانی قوربانگایەک لەلایەن داودەوە
\p 
\v 18 لەو ڕۆژەدا گاد چوو بۆ لای داود و پێی گوت: «سەربکەوە و لەسەر جۆخینەکەی ئەرەونای یەبوسی قوربانگایەک بۆ یەزدان دابمەزرێنە.»
\v 19 داودیش بەپێی قسەکەی گاد، هەروەک یەزدان فەرمانی دابوو سەرکەوت.
\v 20 کاتێک ئەرەونا تەماشای کرد و بینی وا پاشا و خزمەتکارەکانی دێنە لای، ئەرەونا چووە دەرەوە، کڕنۆشی بۆ پاشا برد و سەری خستە سەر زەوی.
\p 
\v 21 ئەرەونا گوتی: «پاشای گەورەم بۆچی هاتووە بۆ لای خزمەتکارەکەی؟»
\p داودیش گوتی: «بۆ ئەوەی جۆخینەکەت لێ بکڕم تاکو قوربانگایەک بۆ یەزدان بنیاد بنێم و دەردەکە لە کۆڵ گەل ببێتەوە.»
\p 
\v 22 ئەرەوناش بە داودی گوت: «با پاشای گەورەم ئەوەی بەلایەوە باشە بیبات و بیکاتە قوربانی. تەماشا بکە. ئەوە گا بۆ قوربانی سووتاندن و جەنجەڕ و نیری گایەکان بۆ دار.
\v 23 ئەی پاشا، ئەرەونای خاوەنیان هەمووی دەداتە پاشا.» هەروەها ئەرەونا بە پاشای گوت: «یەزدانی پەروەردگارت لێت ڕازی بێت.»
\p 
\v 24 بەڵام پاشا بە ئەرەونای گوت: «نەخێر، بەڵکو بە نرخ لە تۆی دەکڕم و قوربانی سووتاندنی بە خۆڕایی بۆ یەزدانی پەروەردگارم سەر ناخەم.»
\p لەبەر ئەوە داود جۆخینەکە و گایەکانی بە پەنجا شاقل زیو\f + \fr 24:24 \ft پەنجا شاقل زیو: نزیکەی 0,6 کیلۆگرام.‏\f* کڕی.
\v 25 داود لەوێ قوربانگایەکی بۆ یەزدان بنیاد نا و قوربانی سووتاندن و قوربانی هاوبەشی سەرخست. ئیتر یەزدانیش لەبەر خاکەکە وەڵامی دایەوە و دەردەکە لە ئیسرائیل دوور کەوتەوە.
