\id MAT - Waja Scripture 
\h Matayo 
\toc2 Matayo 
\toc1 Ci̱ye̱i̱ du teng a bo̱nggo̱ Matayo 
\mt2 Ci̱ye̱i̱ du teng a bo̱nggo̱ 
\mt1 Matayo 
\imt1 Tosugu 
\im Ne̱re̱ wu bala ci̱ye̱i̱ du teng di̱na wii Matayo, yo̱ twii ne̱re̱ wu Yudaya, wu wiino a cu̱di̱ kwati̱mba Yesu wa. 
\ip \bk Ci̱ye̱i̱ du teng a wai Matayo \bk*a ju̱ki̱ya ki̱n Yesu wii Masiya wu nu̱wa ce̱ ci̱ye̱i̱ ye̱i̱ a mi̱ri̱nggi̱ lakargari̱ndi̱ su dooi, wii yo̱ wu nu̱wa bu Yudaya wa man ni̱i̱ ki̱n baa we̱i̱. A jo̱ro̱ndi̱ tum \bk Ci̱ye̱i̱ du teng a wai Matayo\bk* a pero a ju̱ku̱ nyindi su Yesu twanga ce̱wi̱ tu banabi̱ndi̱ ce̱i̱ a lakargari̱ndi̱ su dooi. A ju̱ku̱ya ki̱n Yesu twii ne̱re̱ wu duu Ibrahim. A jo̱ro̱ndi̱ tum a ce̱ ki̱n Yesu twii <<Bo̱l Dawud.>> Yesu a ba yi̱ gi̱ru̱ Masiya, ci̱maci̱ma yi̱ ku nu̱wa bu Yudaya wa le̱e̱ ji̱re̱. Anda kana yi̱to̱ ci̱ye̱i̱ du teng di̱na ki̱ngga bu yi̱gi̱ bu̱ru̱ wang a bo̱nggo̱ nu̱wa bu Yudaya wa. \bk Ci̱ye̱i̱ du teng a wai Matayo \bk* ju̱ki̱ya ki̱n, Yesu Masiya baa di̱ngi̱n nu̱wa bu si̱ma wa mwa mwa, nu̱wa bu Yudaya wa yi̱ pma bu yaa yo̱o̱gi̱ nu̱wa bu Yudaya wa.\bk Ci̱ye̱i̱ du teng a bo̱nggo̱ Matayo\bk* a ba ju̱ki̱ya dak ki̱n Yesu twii ku̱lu̱m wu gi̱ra wu kangge̱ wu ju̱ku̱gu̱ yi̱ri̱ yo̱u̱ yi̱ ce̱wi̱ ye̱i̱ a ju̱ki̱ya ki̱n wo̱o̱ yi̱ di̱mbi̱r wang, a gwala Musa. 
\ip A mi̱ri̱nggi̱ \bk Ci̱ye̱i̱ du teng a wai Matayo \bk* nu̱wa cwaanga yi̱ri̱ng tu Yesu ju̱ki̱ya yi̱ tu ni̱ngai̱ a nuwo. Tu gawu̱ri̱ ye̱i̱, Yesu a ju̱ki̱ yi̱ri̱ a dwii ci̱ngu̱, a dwii nyindi su daa ye̱i̱ nu̱wa Yamba ba ni̱nga so̱ngma yi̱ to̱no̱i̱ (Pe̱ndi̱ 5-7). Ju̱ku̱gi̱ yi̱ri̱ a dwii ne̱re̱ wu de̱e̱ ci̱ye̱i̱ a dwii Yesu ni̱ng we̱i̱ wu̱rai̱ ye̱i̱ (Pe̱ndi̱ 8-12). Go̱ro̱ yi̱to̱ wo̱o̱ yi̱ balanggu̱ ci̱ye̱i̱ wundu wundu a dwii Lau̱ Yambau̱ (Pe̱ndi̱ 13-17). Tu ni̱i̱ ye̱i̱ do̱ng a ju̱ki̱ ni̱nga wu daaya nu̱wa bu po̱nggu̱wa ba ni̱nga (Pe̱ndi̱ 18-23). Tu cwata go̱ro̱i̱ a ju̱ki̱ tu ni̱ngdu̱ we̱i̱ a daandi su cwata go̱ro̱i̱. (Pe̱ndi̱ 24-25.) 
\iot Yi̱ri̱ng tu mi̱ri̱nggi̱ ye̱i̱ 
\io1 Bir Yesu yi̱ pu twiiwe 1:1-2:23 
\io1 Wasi̱gu̱ ci̱ye̱i̱ Yohanna wu Ni̱ng Bati̱si̱ma 3:1-2 
\io1 Bati̱si̱ma Yesu yi̱ cu̱u̱gu̱ yo̱u̱ 3:13-4:11 
\io1 Wu̱rangi̱ Yesu a si̱ma Galili 4:12-8:35. 
\io1 Yesu du̱we̱ si̱ma Galili a baa si̱ma Wurcalima. 19:1-20:34 
\io1 Wu̱rangi̱ Yesu tu cwata go̱ro̱i̱ a Wurcalima 21:1-27:31 
\io1 Pi̱i̱nggu̱ Yesu a ye̱u̱ yi̱ bo̱o̱ri̱ Ye̱i̱ 27:32-66 
\io1 Wunggu Yesu bo̱o̱re̱ yi̱ ju̱ku̱ bu̱ri̱ ye̱i̱ nu̱wa 28:1-20 
\ib  
\c 1  
\s1 Dinendi kakaa Yesu wa 
\p  
\v 1 21Ti̱na ku̱ci̱ kakaa Yesu Masiya wa, \f + \fr 1:1 \ft Masiya: Din Masiya nu̱wa yi̱ri̱ mwaasi̱ ki̱n Kristo. Kristo to̱o̱ nyan Elina wa, pi̱ti̱ndi̱ din ye̱i̱ twii ne̱re̱ wu nu̱wa parman yo̱ nunggu a dwii. Nang a bo̱nggo̱ nu̱wa bu Yudaya wa pma parman ne̱re̱ wii nunggu a dwii di̱ngi̱n ba ju̱ku̱ya ki̱n twii ne̱re̱ wu Yamba se̱ka di̱ngi̱n ba yo̱ balaa. A jo̱r du Yamba ni̱nga alkawal ki̱n yo̱ tu̱mo̱ we̱i̱ ne̱re̱ mi̱ri̱ma, di̱ngi̱n ba baa, ba mi̱ra nu̱wa ya, pero ba de̱ pma lau̱ Yambau̱, ne̱re̱ wu Yamba tu̱mo̱ we̱i̱ wii nu̱wa yi̱ri̱ ki̱n Masiya. Pero din ye̱i̱ Kristo. A ju̱ku̱ya Yamba se̱ka yo̱, pero tu̱mwe̱.\f* wu twii kaka Dawud, wu yo̱o̱gi̱ kaka Ibrahim. 
\b  
\li1  
\v 2 Ibrahim twii mbaa Icaku, 
\li2 Icaku mbaa Yakubu, 
\li2 Yakubu mbaa Yahuda yi̱ ci̱yamba ya, 
\li2  
\v 3 Yahuda mbaa Perisa yi̱ Serah wu njaa pmo wii Tamar, 
\li2 Perisa mbaa Esruna, 
\li2 Esruna mbaa Aram. 
\li2  
\v 4 Aram mbaa Amminadab, 
\li2 Amminadab mbaa Nacon, 
\li2 Nacon mbaa Salmon, 
\li2  
\v 5 Salmon mbaa Boasa wu njaa yo̱ wii Rahab, 
\li2 Boasa mbaa Obed wu njaa yo̱ wii Rut, 
\li2 Obed mbaa Jesse, 
\li2  
\v 6 Jesse mbaa balaa Dawud. 
\li1 Dawud twii mbaa Solomon, wu njaa yo̱ nang twii nu̱re̱ Uriya, 
\li2  
\v 7 Solomon mbaa Rehoboam, 
\li2 Rehoboam mbaa Abija, 
\li2 Abija mbaa Asa, 
\li2  
\v 8 Asa mbaa Jehocapat, 
\li2 Jehocapat mbaa Joram, 
\li2 Joram mbaa, Ussiya, 
\li2  
\v 9 Ussiya mbaa Jotam, 
\li2 Jotam mbaa Ahas, 
\li2 Ahas mbaa Hesekiya, 
\li2  
\v 10 Hesekiya mbaa Manassa, 
\li2 Manassa mbaa Amon, 
\li2 Amon mbaa Josiya 
\li2  
\v 11 Josiya mbaa Jekoniya yi̱ ci̱yamba ya, a jo̱r du nu̱wa ku̱ra pma ke̱wu̱ri̱ Babila. 
\li1  
\v 12 Go̱ro̱ ke̱wu̱ri̱ pmai a Babila, 
\li2 Jekoniya mbaa Ceyaltiyal, 
\li2 Ceyaltiyal mbaa, Serubabel, 
\li2  
\v 13 Serubabel mbaa Abiud, 
\li2 Abiud mbaa Eliyakim, 
\li2 Eliyakim mbaa Asor, 
\li2  
\v 14 Asor mbaa Sadok, 
\li2 Sadok mbaa Acim, 
\li2 Acim mbaa Eliyud, 
\li2  
\v 15 Eliyud mbaa Eliyasar, 
\li2 Eliyasar mbaa Matan, 
\li2 Matan mbaa Yakubu, 
\li2  
\v 16 Yakubu mbaa Yusupu bwi̱ya Maryamu, wu bi Yesu wu nu̱wa yi̱ri̱ ki̱n Masiya. 
\p  
\v 17 Di̱ngi̱n to̱no̱ toso bo̱nggo̱ Ibrahim be̱e̱ bo̱nggo̱ Dawud twii kakaa kwap su̱r ni̱i̱, pero toso bo̱nggo̱ Dawud be̱e̱ jo̱r du mwatanga Babila twii kakaa kwap su̱r ni̱i̱, pero toso jo̱r mwatangu Babila be̱e̱ jo̱r Masiya twii kakaa kwap su̱r ni̱i̱. 
\s1 Bir Yesu Masiya 
\p  
\v 18 Ti̱na nyinou wu nu̱wa bi Yesu Masiya. Njaa yo̱ Maryam ni̱nga le̱e̱ngi̱ laabwiya yi̱ Yusupu, pu bo̱o̱ de̱ bu yo̱ a nyi̱ngga wo̱o̱ yi̱ rwii a bo̱nggo̱ Bawei du Walwal.  
\v 19 Anda Yusupu twii ne̱re̱ wu nyaa yaa kasi̱ ba dwiiyanga yo̱ me̱lma cu̱du̱ nu̱wai̱, a kasa ba man yo̱ tukugi. 
\p  
\v 20 Anda pu wo̱o̱ danggu̱ yi̱to̱, bacama Mbaa Wu Gi̱ra a bammanu̱we̱ yo̱ a mi̱ri̱nggi̱ dweendi ki̱n, <<Yusupu bo̱l Dawud, nu̱u̱ yaa gwasi̱ de̱gu̱ Maryam ba yo̱o̱ nu̱re̱ mo̱, di̱ngi̱n tu mi̱ri̱nggi̱ pwii ye̱i̱ to̱o̱ a baa bo̱nggo̱ Bawei du Walwal.  
\v 21 Yo̱ biru we̱i̱ bwi̱ya, ma je̱e̱ ru we̱i̱ din mi̱n Yesu,\f + \fr 1:21 \ft Yesu to̱o̱ din Elina wa ci̱ka Jocuwa yi̱ nyan Yudaya wa pi̱ti̱ndi̱ ye̱i̱ twii Mbaa Wu Gi̱ra wu yi̱ mi̱rma \f* di̱ngi̱n yo̱ mi̱ru̱ we̱i̱ nu̱wa ya bo̱nggo̱ we̱le̱mdi̱ pmai.>> 
\p  
\v 22 Mwa mwa to̱o̱ a ni̱ngwa palaka ba twanga tu Mbaa Wu Gi̱ra ce̱ a bo̱nggo̱ banabi̱ ki̱n,  
\v 23 <<Bwe̱e̱canga ni̱ng we̱i̱ rwii, pero biru we̱i̱ bwi̱ya, nu̱wa yi̱ri̱ we̱i̱ din ye̱i̱ ki̱n Immanuwel,>> pi̱ti̱ndi̱ ye̱i̱ ki̱n, <<Yamba wo̱o̱ kem yi̱ yo.>> 
\p  
\v 24 Pu Yusupu romwa, a ni̱nga tu bacama Mbaa Wu Gi̱ra sa yo̱, a de̱e̱ Maryam ba yo̱ nu̱re̱ yo̱.  
\v 25 Anda yaa ku daa yi̱ yo̱, ko̱po̱ jo̱r du bi bo̱l ye̱i̱. Pero a je̱e̱ din ki̱n Yesu. 
\c 2  
\s1 Bagu̱ ku̱lu̱mba bu so̱m yi̱ri̱ a dwii bajwari wa 
\p  
\v 1 Go̱ro̱ pu nu̱wa bi Yesu a Baitalami a si̱ma Yudaya wa a jo̱r du Balaa Hiridus je̱e̱gi̱ lau̱, nu̱wa bu kangga twiyongo do̱no̱me̱ bu so̱m yi̱ri̱ngi̱ a dwii bajwari a baanga Wurcalima  
\v 2 a pi̱ra ki̱n, <<Pu nu̱wa bi balaa wu nu̱wa bu Yudaya wa a pi̱i̱yau̱? Yi ko̱ bajwali̱ yo̱ a do̱no̱me̱ yi̱ baanga di̱ngi̱n yi ku̱raman yo̱ si̱ma.>> \fig Nu̱wa bu so̱m yi̱ri̱ dwii bajwari wa|src="WA03806b.tif" size="col" ref="2:2" \fig* 
\p  
\v 3 Pu balaa Hiridus nu̱wa yi̱to̱, gaanggu̱ yo̱u̱ bwi̱i̱wa kem yi̱ nu̱wa bu Wurcalima wa mwa mwa.  
\v 4 A yi̱we̱ bagi̱raa kuruwa wa yi̱ ku̱lu̱mba te̱e̱ri̱ngi̱ wa, a pi̱ra pma pu nu̱wa bi̱ru̱ we̱i̱ Masiya.  
\v 5 Pma le̱e̱man yo̱ ki̱n, <<A Baitalami si̱ma Yudaya wa, di̱ngi̱n ti̱na tu balgi̱ mi̱ri̱nggi̱ lakargar banabi̱ ki̱n,>> 
\q1  
\v 6 <<Anda mo̱ Baitalami bu si̱ma Yahuda wa, 
\q2 ma yaa yo̱o̱gi̱ wu banyi̱na mi̱ri̱nggi̱ lau̱ri̱ tu Yahuda, 
\q1 a mi̱ri̱nggi̱ mai balaa twiiwe we̱i̱, 
\q2 wu yo̱o̱ we̱i̱ taage̱ nu̱wa muwa Israila.>> 
\p  
\v 7 Anda Hiridus yi̱we̱ ku̱lu̱mba bwii tukugi ba pi̱ra jo̱r du bajwale wii twiiwe.  
\v 8 A tu̱m pma Baitalami a sa pma ki̱n, <<Ambi̱ra bu kasa pu nu̱wa bi bwi̱ya wii. Ka bu nyi̱nggi̱ ba bu sangge̱ palaka mi mwa n angge̱ n ku̱raman yo̱ si̱ma.>> 
\p  
\v 9 Go̱ro̱ pu pma nu̱u̱ balaau, pma taa nyinou, bajwale wu pma ko̱ a do̱no̱me̱ wii a so̱ngma gawu̱r pmai ba ti̱n ti̱yei̱ pu nu̱wa bi bwi̱ya wii.  
\v 10 Pu pma ko̱ bajwale wii pma twangwa yi̱ bu̱ri̱ de̱gde̱g.  
\v 11 Pma teendo laa wii a ko̱ bwi̱ya wii kem yi̱ njaa yo̱ Maryam, anda pma kundi kwiyei ku̱raman yo̱ si̱ma. Pero pma pe̱ra swari̱ndi̱ pmai a nyi̱i̱ ni̱i̱ sinariya yi̱ tu̱rale̱ wu teng yi̱ nyinou ku nu̱wa yi̱ri̱ ki̱n mirr.  
\v 12 Nu̱wa ni̱ngaman pma di̱kace̱ne̱ a mi̱ri̱nggi̱ dweendi ba po̱ng yaa bo̱nggo̱ Hiridus, pma po̱ng nyinou wu kanggu̱ a waatanga bu̱ri̱ si̱ma pma. 
\s1 Yusupu yi̱ nu̱r yo̱ ceendo Masar 
\p  
\v 13 Pu pma mwatangu, bacama Mbaa Wu Gi̱ra baa bo̱nggo̱ Yusupu mi̱ri̱nggu̱ dweendi, a se̱e̱ ki̱n. <<Wuni ma de̱ bwi̱ya wo̱o̱ kem yi̱ njaa yo̱ ma amna Masar. Ma si̱n si̱ye̱i̱ pwii ko̱po̱ jo̱r du sa mi̱nai̱, di̱ngi̱n Hiridus kasi̱ we̱i̱ bwi̱ya wo̱o̱ ba ji yo̱.>>  
\v 14 Bur a wuni a de̱ bwi̱ya wii yi̱ njaa yo̱ yi̱ ku̱m wii a mwati̱ Masar,  
\v 15 a si̱n si̱ye̱i̱ pwii ko̱po̱ jo̱r du Hiridus bwaa. A ni̱ngwa yi̱to̱ palaka ba twanga tu Mbaa Wu Gi̱ra a ce̱ nyan banabi̱ ki̱n, <<N yi̱we̱ bo̱l mi a Masar.>> 
\p  
\v 16 Pu Hiridus ku̱ranga ku̱lu̱mba bwii we̱le̱nga yo̱, a suko kwang kwang, a diina nu̱wa ba laca bako̱r nambi̱rmba bu Baitalami yi̱ go̱ro̱ndi̱ tu wo̱ri̱gi̱ yo̱ bu mi̱la ro̱p yi̱ bu mi̱ldi̱ pmai dwalna wa, cu̱u̱ngi̱ jo̱r du ku̱lu̱mba sa yo̱ labar wii.  
\v 17 A jo̱r dwii yi̱ri̱ tu banabi̱ Irmiya ce̱i̱ a twangwa. 
\q1  
\v 18 <<Nu̱wa nu̱u̱ miu a Rama, 
\q2 wiindi yi̱ bwiyang gaanggu̱ wang 
\q1 Rahila wiindi di̱ngi̱n kwaraa ya 
\q2 a kwaa ki̱n nu̱wa ba do̱ro̱mi̱ni̱ ya 
\q2 di̱ngi̱n pma yaa me̱re̱.>> \f + \fr 2:18 \ft Irm. 31:15 \f* 
\s1 Yusupu yi̱ nu̱r yo̱ waatanga Nasaret 
\p  
\v 19 Go̱ro̱ pu Hiridus bwaa bacama Mbaa Wu Gi̱ra bammanu̱we̱ Yusupu mi̱ri̱nggi̱ dweendi a Masar  
\v 20 a ce̱ ki̱n, <<Wuni ma de̱ bwi̱ya wo̱o̱ kem yi̱ njaa yo̱, ma amna si̱ma Israila, di̱ngi̱n nu̱wa bu kasi̱gu̱ jigu bwi̱ya wo̱o̱ wa, a bwaanga.>>  
\v 21 Di̱ngi̱n to̱no̱ a wuni, a de̱ bwi̱ya wii kem yi̱ njaa yo̱ a aara si̱ma Israila.  
\v 22 Anda ku nu̱wa ki̱n Arkilawus je̱e̱gi̱ lau̱ a Yudaya a candu̱ mbaa yo̱ Hiridus, a nu̱u̱ gwasi̱ ba aara pwii. A aara si̱ma Galili yake̱ ku nu̱wa ni̱ngaman yo̱ di̱kace̱ne̱ a dwe̱e̱ndi̱.  
\v 23 Anda a aara si̱n si̱ye̱i̱ a gwe̱i̱ du nu̱wa yi̱ri̱ ki̱n Nasaret. To̱o̱ a ni̱ngwa yi̱to̱ di̱ngi̱n ba twanga tu banabi̱ndi̱ ce̱ ki̱n, <<Nu̱wa yi̱ru̱ we̱i̱ ki̱n Nasarin.>> 
\c 3  
\s1 Yohanna wu Ni̱ngi̱ Bati̱si̱ma me̱ne̱nga nyinou 
\p  
\v 1 A swii daandi Yohanna wu Ni̱ngi̱ Bati̱si̱ma a baa, a wasi̱gu̱ ci̱ye̱i̱ a gu̱lai̱ Yudaya,  
\v 2 a ce̱gu̱ ki̱n, <<Bu ni̱nga bwiiwa bo̱nggo̱ we̱le̱mdi̱ mbi̱ri̱, di̱ngi̱n lau̱ ku diyou a ni̱nga ne̱m.>>  
\v 3 Yohanna wii yo̱ wu banabi̱ Icaya ce̱ ci̱ye̱i̱ a dwii ye̱i̱, pu ce̱ ki̱n, 
\q1 <<Miu ku yi̱gu̱ yi̱ru̱ a mi̱ri̱nggi̱ gu̱lai̱, 
\q1 Bu carman nyinou Mbaa Wu Gi̱ra, 
\q2 Bu cu̱rman nyindi ye̱i̱ te̱k!>> 
\p  
\v 4 Se̱e̱ Yohanna me̱ne̱nggi̱ yi̱ ku̱ri̱ nggelai, bo̱gi̱ pi̱i̱ yi̱ bi̱yau̱, je̱e̱ndi̱ ye̱i̱ twii juwai yi̱ niyari.  
\v 5 Nu̱wa tum a twiyongo Wurcalima, yi̱ Yudaya, yi̱ go̱ro̱ndi̱ mwa mwa tu ne̱m yi̱ you ku Urdun a aanda bo̱nggo̱ yo̱u̱.  
\v 6 Pma ni̱nggu̱ bwiiwa bo̱nggo̱ we̱le̱mdi̱ pmai, a ni̱ngaman pma bati̱si̱ma a you Urdun. 
\p  
\v 7 Pu Yohanna ko̱ Parisayo yi̱ Sadukayo bagu̱ bo̱nggo̱ yo̱u̱ di̱ngi̱n ba ni̱ngaman pma bati̱si̱ma, a sa pma ki̱n, <<Mba co̱o̱gi̱ndi̱ su bwi̱i̱ wu sambi̱ra ki̱n bu cembir bal Yambai̱ su so̱o̱ baa we̱?>>  
\v 8 Bu ni̱nga ni̱ngandi̱ tu ju̱ku̱ru̱ we̱i̱ ki̱n bu ni̱nga bwiiwa a bo̱nggo̱ we̱le̱mdi̱ mbi̱ri̱.  
\v 9 Anda bu danggi̱ ya a gaanggu̱ mbi̱ru̱ mi̱n Ibrahim twii mbaa mbi̱re̱. N wo̱o̱ sagu̱mbi̱ru̱ Yamba wo̱o̱ yi̱ di̱mbi̱re̱ ba waata swari̱ngi̱ ti̱na ba yo̱ kwaraa Ibrahim!  
\v 10 Nu̱wa gi̱ci̱la ce̱nni̱ nyan cunau a pi̱i̱ sou, kana ko̱no̱ sou ku twiya bu tutwiyari tu nyaayi bu̱ri̱ nu̱wa ba kaca ba manna bwalau. 
\p  
\v 11 <<N ni̱ngambi̱ri̱ bati̱si̱ma yi̱ gundu ba ju̱ku̱ya ki̱n bu ni̱nga bwiiwa, anda wu kangge̱ wo̱o̱ baa go̱ro̱ mu ni̱nga mbi̱ru̱ we̱i̱ bati̱si̱ma yi̱ Bawei du Walwal yi̱ bwalau. Yo̱ gwalangge̱ yi̱ gi̱ru̱, n yinnibu kana paari̱ ye̱i̱ n de̱.  
\v 12 Yo̱ tagi̱ kaa te̱na yo̱ ye̱tu̱ we̱i̱ jama ya, pero ba ku̱ranga go̱ma ya, ba te̱na bindou yo̱u̱, anda taaru we̱i̱ pudi ye̱i̱ yi̱ bwalau ku̱ yaa dumdu.>> 
\s1 Yohanna ni̱ngaman Yesu Bati̱si̱ma 
\p  
\v 13 A dwii jo̱re̱ Yesu du̱we̱ si̱ma Galili a baa you Urdun di̱ngi̱n Yohanna ba ni̱ngaman yo̱ bati̱si̱ma.  
\v 14 Anda Yohanna kwaa, a se̱e̱ ki̱n, <<A daaya mo̱, ma ni̱ngangi̱n bati̱si̱ma, di̱ngi̱n ca ma bagu̱ bo̱nggo̱ mu?>> 
\p  
\v 15 Yesu le̱e̱man yo̱ ki̱n, <<Yama ba ni̱ngwa yi̱to̱. Di̱ngi̱n tagi̱ yi twanga tu Yamba kasi̱.>> Bur Yohanna a le̱e̱.  
\v 16 Pu nu̱wa ni̱ngaman Yesu bati̱si̱ma, twiigu gundu kwii, ki̱nangu̱, bur diyou wum bu̱ri̱, a ko̱ Bawei Yambai̱ julomanuwe ci̱ka bamolo a ti̱na dwii ye̱i̱.  
\v 17 Bur miu twiiwe diyou ki̱n, <<Ma Bo̱l mi, wu n kangne̱, n ni̱ngi̱ bu̱ri̱ de̱gde̱g yi̱ mo̱.>> 
\c 4  
\s1 Cu̱u̱gu̱ Yesu 
\p  
\v 1 A dwii jo̱re̱ Bawei du Walwal a de̱ Yesu gu̱lai̱ palaka Balaa Buwai ba cu̱u̱ yo̱.  
\v 2 Go̱ro̱ pu ni̱nga daa kun ni̱i̱ ku̱me̱ yi̱ nyanggu̱ yaa tu je̱i̱, Yesu nu̱u̱ ju̱ne̱.  
\v 3 Bur Balaa Buwai baa bo̱nggo̱ yo̱u̱ a se̱e̱ ki̱n, <<Ka ma yo̱o̱gi̱ Bo̱l Yamba we̱i̱ diin swari̱ngi̱ to̱o̱ ba waka bu̱ri̱, ba yo̱o̱ ku̱maa.>>  
\v 4 Anda Yesu le̱e̱man yo̱ ki̱n, <<Lakargar Yamba ce̱ ki̱n, <Ne̱re̱ na yi̱li̱ yi̱ ku̱maa yi̱ wundu, anda yi̱ kana do̱no̱ ci̱ye̱i̱ du baa bo̱nggo̱ Yamba.>>>  
\v 5 Pero Balaa Buwai a de̱ Yesu Wurcalima, gwe̱i̱ du walwal, a ce̱nna pu de̱ke̱rge̱r Laa Yambau̱,  
\v 6 a sa yo̱ ki̱n, <<Ka ma yo̱o̱gi̱ Bo̱l Yamba we̱i̱, yarwe̱ po̱o̱, di̱ngi̱n balgi̱ mi̱ri̱nggi̱ lakargar Yamba ki̱n, 
\q1 <Yamba nyi̱i̱ we̱i̱ bacamandi ye̱i̱ te̱e̱re̱ a dwii mai, 
\q2 pma kangami̱nu̱ we̱i̱ a war pmai, 
\q1 di̱ngi̱n ma buni ya kana namau a swe̱le̱i̱.>>> 
\p  
\v 7 Yesu le̱e̱man yo̱ ki̱n, <<Lakargar Yamba a ce̱ ki̱n, <Ma cu̱u̱ ya Mbaa Wu Gi̱ra Yamba mo̱.>>>  
\v 8 Bambang Balaa Buwai de̱ Yesu a ci̱ngu̱ ku getengteng a ju̱ku̱ yo̱ lau̱ri̱ tu si̱mai̱ yi̱ yi̱lau̱ yau̱ mwa mwa.  
\v 9 Balaa Buwai se̱e̱ ki̱n, <<N nyi̱i̱mi̱nu̱ we̱i̱ ti̱na yi̱ri̱ngi̱ mwa mwa ka ma kun kwiyei ma ku̱rangi̱n si̱ma.>> 
\p  
\v 10 Yesu le̱e̱man yo̱ ki̱n, <<Mwati̱ po̱o̱ Balaa Buwai! Lakargar Yamba ce̱ ki̱n, <Ma nyi̱i̱ gi̱ru̱ Mbaa Wu Gi̱ra Yamba mo̱, ma ku̱raman yo̱ si̱ma yo̱ wundu.>>>  
\v 11 Bur Balaa Buwai a du Yesu, anda bacamandi baanga pma kalanga yo̱. 
\s1 Yesu toso wu̱rai̱ ye̱i̱ a Galili 
\p  
\v 12 Pu Yesu nu̱wa ki̱n nu̱wa manni̱ Yohanna a jaru̱m, a aara si̱ma Galili wa. 
\p  
\v 13 Yo̱ yaa ku si̱ si̱ye̱i̱ Nasaret anda a mwati̱ si̱ si̱ye̱i̱ a gwe̱i̱ Kaparnahum, gwe̱i̱ du ne̱m yi̱ kali̱nggu̱ ku Galili, a si̱ma Sabulun yi̱ Naptali. 
\p  
\v 14 To̱o̱ yi̱ri̱ ni̱ngwa yi̱to̱ palaka ba twanga tu banabi̱ Icaya ce̱i̱. 
\q1  
\v 15 <<Si̱ma Sabulun yi̱ si̱ma Naptali, 
\q2 a nyinou wu aari kali̱nggu̱, ku yero you Urdun, 
\q2 yi̱ Galili, si̱ma nu̱wa bu yaa yo̱o̱gi̱ nu̱wa bu Yudaya wa! 
\q1  
\v 16 Nu̱wa bu pi̱si̱ndi̱ pu ri̱m wa 
\q2 kwe̱e̱ we̱i̱ rangu̱ wu gi̱ra̱u̱. 
\q1 Pma bu pi̱si̱ndi̱ si̱ma bu yi̱ ku̱mji̱la bo̱o̱ru̱ wa, 
\q2 Rang swi̱i̱ pma.>> 
\p  
\v 17 Toso dwii jo̱re̱ Yesu toso wasi̱gu̱ ci̱ye̱i̱ ye̱i̱, <<Bu ni̱nga bwiiwa bo̱nggo̱ we̱le̱mdi̱ mbi̱ri̱ di̱ngi̱n lau̱ ku diyou ni̱nga ne̱m!>> 
\s1 Yesu yi̱ kwati̱mba ya bu gawu̱ri̱yo̱ wa 
\p  
\v 18 Pu Yesu wo̱o̱ so̱ngma gi̱ng kali̱nggu̱ ku Galili, a ko̱ nu̱wa ro̱p ci̱yamba bu̱ri̱ twii nu̱wa bu re̱e̱ jindu wa, Simon wu nu̱wa yi̱ri̱ ki̱n Bitrus yi̱ ci̱ya yo̱ Andarawus, a re̱gu̱ jindi a kali̱nggu̱ yi̱ le̱mu̱.  
\v 19 Yesu sa pma ki̱n, <<Bambe̱ bu po̱ngge̱, n ju̱ku̱ mbi̱ri̱ we̱i̱ re̱gu̱ nu̱wau̱.>>  
\v 20 Yo̱ko̱ yo̱ko̱ pma du le̱mdi̱ pmai, a po̱ng yo̱.  
\v 21 Yo̱ je̱e̱ gawu̱re̱ a ko̱ bu kangga ro̱p ci̱yamba bu̱ri̱, Yakubu yi̱ Yohanna, kwaraa Sabadi wa. Pma mi̱ri̱nggi̱ konggoru kem yi̱ mbaa pmo Sabadi, pma me̱ne̱nggu̱ le̱mdi̱ pmai. Yesu yi̱we̱ pma,  
\v 22 pma du̱u̱ konggoru wii mbaa pmo, yo̱ko̱ yo̱ko̱ pma po̱ng yo̱. 
\s1 Yesu mi̱ra nu̱wa bu yi̱ bu̱wangi̱ wa 
\p  
\v 23 Yesu wo̱ra Galili, a ju̱ku̱gu̱ yi̱ri̱ngi̱ nu̱wa a gi̱ri̱ndi̱ ku̱ri̱ pmai, a wasi̱gu̱ ci̱ye̱i̱ du teng a dwii lau̱ Yambau̱, pero a mi̱ra nu̱wa bu yi̱ buwangi wundu wundu yi̱ bu̱ri̱ wulok wa pma yi̱langa.  
\v 24 Labar yo̱ wasi̱ bu̱ri̱ si̱ma Siriya wa mwa mwa, di̱ngi̱n to̱no̱ nu̱wa ni̱nga pu de̱mu̱we̱ yo̱ nu̱wa mwa mwa bu yi̱ buwangi wundu wundu wa bu cu̱sanggu̱ bo̱nggo̱ buwangi wundu wundu yi̱ bu bu̱ri̱ mwaanga bu̱ru̱ wa, nu̱wa bu yi̱ wuturindi wa yi̱ bu yi̱ to̱ki̱ wa, yi̱ bu bu̱ri̱ bo̱rgi̱ wa Yesu mi̱ra pma mwa mwa a yi̱langa.  
\v 25 Nu̱wa tum po̱ng yo̱, toso si̱ma Galili yi̱ si̱ma bu yi̱ Go̱ro̱ndi̱ Kwap wa, yake̱ Wurcalima, yi̱ Yudaya yi̱ si̱ma bu do̱no̱me̱ yi̱ Urdun wa. 
\c 5  
\s1 Wasi̱gu̱ ci̱ye̱u̱ a ci̱ngu̱ 
\p  
\v 1 Pu Yesu ko̱ nu̱wa tum ku̱ranga bu̱ri̱ a geero ci̱ngu̱, a si̱n si̱ye̱i̱. Kwati̱mba ya ku̱ranga bu̱ri̱ wo̱ri̱gi̱ yo̱,  
\v 2 anda a toso pi̱rgu̱ pmau. 
\q1  
\v 3 <<Wuure bo̱nggo̱ pma bu so̱m dwal pmai du bawei, 
\q2 lau̱ ku diyou kwii ko̱pi̱nau̱! 
\q1  
\v 4 Wuure bo̱nggo̱ pma bu yi̱ bwiyanggu gaanggu̱ wa, 
\q2 Yamba di̱ramanu̱ we̱i̱ pma gaanggu̱! 
\q1  
\v 5 Wuure bo̱nggo̱ pma bu yi̱ ci̱ngo̱n dwiu wa, 
\q2 pma ki̱nggu̱ we̱i̱ si̱ma! 
\q1  
\v 6 Wuure bo̱nggo̱ pma bu nu̱u̱ ju̱n ni̱nggu̱ pi̱su̱ wu nyaau a gawu̱ri̱ Yambai̱, 
\q2 Yamba yami̱nu̱ we̱i̱ pma biiki pmo ge̱kre̱k! 
\q1  
\v 7 Wuure bo̱nggo̱ pma bu nu̱u̱ bunam bu kangga, 
\q2 Yamba nu̱u̱ we̱i̱ bunam pmau! 
\q1  
\v 8 Wuure bo̱nggo̱ pma bu yi̱ gaanggu̱ walwal, 
\q2 pma kwe̱e̱ we̱i̱ Yamba! 
\q1  
\v 9 Wuure bo̱nggo̱ pma bu te̱ci̱ naapu wa, 
\q2 Yamba yi̱ru̱ we̱i̱ pma ki̱n kwaraa ya! 
\q1  
\v 10 Wuure bo̱nggo̱ pma bu nu̱wa turongo pma di̱ngi̱n ni̱ngu̱ pi̱su̱ wu nyaau a gawu̱ri̱ Yambai̱, 
\q2 lau̱ ku diyou kwii ko̱ pmau! 
\p  
\v 11 <<Wuure bo̱nggo̱ mbi̱ru̱ ka nu̱wa rwe̱e̱mbi̱ri̱, turo mbi̱ri̱ pero ci̱ye̱i̱ kana ko̱no̱ duu yi̱ri̱ tu bwi̱i̱ a dwii mbi̱ri̱ ki̱n di̱ngi̱n bu po̱nggu̱ mu.  
\v 12 Bu ni̱nga bu̱ri̱ de̱gde̱g yi̱ di̱rang gaanggu̱, di̱ngi̱n wo̱ri̱ri̱ mbi̱ri̱ tum a pwii diyou. To̱o̱ tu ni̱ngaman banabi̱ndi̱ su gawu̱ri̱ yi̱ mba. 
\s1 Bi̱makwana yi̱ rangu̱ 
\p  
\v 13 <<Bu yo̱o̱gi̱ bi̱makwanaa nu̱wa mwa mwa. Anda ka bi̱makwanaa cwaani bu̱ri̱ yi̱ teng yo̱u̱, nu̱wa puunu we̱i̱ teng yo̱u̱ kwii nye̱? Yo̱ ni̱nga kwe̱ce̱kwe̱ce̱, bur nu̱wa ba par si̱yau̱ si̱ma ba pe̱e̱nga. 
\p  
\v 14 <<Bu yo̱o̱gi̱ rangu̱ wu si̱ma mwa mwa. Gwe̱i̱ du mo̱gi̱ dwii ci̱ngu̱ yaa tukuri.  
\v 15 Yaa ne̱re̱ wu ku̱ci̱n bwalau ke̱ndabwala ba summo yi̱ takale̱, anda nu̱wa ce̱nni̱ pu de̱ke̱rge̱r, di̱ngi̱n ba nyi̱i̱ rangu̱ kana we̱ wu laa wii.  
\v 16 Yi̱to̱ mwaasi̱ rang mbi̱ru̱ ba swii bu̱ri̱ bo̱nggo̱ nu̱wau̱, palaka ba ko̱ wu̱rangi̱ mbi̱ri̱ tu nyaayi tu bu ni̱ngi̱, ba te̱re̱nga Mbaa mbi̱re̱ wu diyou. 
\s1 Pi̱rgu̱ yi̱ri̱ngi̱ a dwii te̱e̱re̱ 
\p  
\v 17 <<Bu dangani̱ ya mi̱n n baa palaka n wo̱o̱ si̱ye̱i̱ Te̱e̱re̱ Musa yi̱ yi̱ri̱ng tu banabi̱ndi̱ balai. N baa bu n wo̱o̱ si̱ye̱i̱, anda n twanga.  
\v 18 N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱ ko̱po̱ ka diyou yi̱ si̱ma wo̱o̱ri̱ bu̱ri̱, kana go̱n ci̱ye̱i̱ diino, kana jo̱ku̱gu̱ ku banyi̱nau̱, yaa ku wo̱o̱ we̱i̱ bu̱ri̱ mi̱ri̱nggi̱ Te̱e̱ri̱ngi̱ Yambai̱ ko̱po̱ ka yi̱ri̱ngi̱ to̱o̱ mwa mwa ni̱ngdi̱ bu̱ri̱.  
\v 19 Di̱ngi̱n to̱no̱ kana we̱ wu paa te̱e̱re̱ diino du banyi̱nai̱ a mi̱ri̱nggi̱ te̱e̱ri̱ngi̱, pero pi̱r bu kangga ba ni̱nga yi̱to̱, yo̱o̱ we̱i̱ wu banyi̱na a lau̱ ku diyou, anda kana we̱ wu po̱nga pero pi̱ryo̱ yo̱o̱ we̱i̱ wu gi̱ra a lau̱ ku diyou.  
\v 20 N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱, ka pi̱su̱ mbi̱r wu nyaau a gawu̱ri̱ Yambau̱ gwala bu ku̱lu̱mba te̱e̱ri̱ngi̱ wa yi̱ Parisayo ne̱, bu te̱mbi̱r lau̱ ku diyou. 
\s1 Pi̱rgu̱ yi̱ri̱ngi̱ a dwii sukom 
\p  
\v 21 <<Bu nu̱u̱ tu Yamba sa kakaa yiwa nang ki̱n, <Ma ji̱ri̱ ya ne̱re̱, kana we̱ wu ni̱nga, nu̱wa ni̱ngamanu̱ we̱i̱ yo̱ bali̱.>  
\v 22 Anda n wo̱o̱ sagu̱mbi̱ru̱ mi̱n: Kana we̱ wu suko yi̱ bago̱n yo̱ nu̱wa ni̱ngamanu̱ we̱i̱ yo̱ bali̱, kana we̱ wu yi̱ bago̱n yo̱ ki̱n, <Ne̱r wu nyo,> nu̱wa de̱r we̱i̱ gawu̱ri̱ bagi̱raa nu̱wa bu Yudaya wa, pero kana we̱ wu yi̱ bago̱n yo̱ ki̱n bapi̱me̱ yannu̱ we̱i̱ par bwalau.  
\v 23 Ka ma wuni nyi̱i̱gu̱ ni̱i̱ Yamba a kwaare̱ anda ma danggi̱ mi̱n bago̱n mo̱ wo̱o̱ yi̱ yi̱ri̱ yi̱ mo̱,  
\v 24 ma du ni̱i̱ mai a gawu̱ri̱ kwaare̱, ma mwati̱ ma nu̱wanga bago̱n mo̱ anda ma waata ba ma nyi̱i̱ ni̱i̱ mai Yamba. 
\p  
\v 25 <<Ka bace̱n mo̱ de̱r kwaram mo̱ a gi̱re̱ng balu, kasa bu nu̱wanga jo̱r du bu bo̱o̱ nyinou, pu bo̱ bu laman bu laa balu. Ka yi̱to̱ ne̱ de̱mi̱nu̱ we̱i̱ bo̱nggo̱ ne̱re̱ wu ni̱ng bali̱, wii yo̱ wu de̱mi̱nu̱ we̱i̱ bo̱nggo̱ bagi̱raa, pero nu̱wa manmi̱nu̱ we̱i̱ jaru̱m.  
\v 26 N wo̱o̱ sagu̱mbi̱ru̱, yaa ku̱ ma twii we̱i̱ pwii, ko̱po̱ ka mo̱ yar kana ca tu nu̱wa mwar mi̱nai̱. 
\s1 Pi̱rgu̱ yi̱ri̱ a dwii taari̱ 
\p  
\v 27 <<Bu nu̱u̱ tu Yamba ce̱ ki̱n, <Ma ni̱ngi̱ ya taari̱.>  
\v 28 Anda n sagu̱mbi̱ru̱ mi̱n, kana we̱ wu su̱wa nu̱re̱ yi̱ miyam a gaci̱la ni̱nga taari̱ yi̱ yo̱ a gaanggu̱.  
\v 29 Ka nung mo̱ wu je̱u̱ diimini we̱i̱ we̱le̱m we̱i̱, ma yikiyo ma man si̱ye̱i̱! Kujang ma yaa bo̱nggo̱ wu kangge̱ a bu̱ri̱ mai yiku bu̱ri̱ mai mwa mwa nu̱wa manmi̱nu̱ we̱i̱ bwalau ku yaa dumdu.  
\v 30 Ka wai mau wu je̱u̱ diimini we̱i̱ we̱le̱m we̱i̱, ma mwari̱ya ma man si̱ye̱i̱! Kujang ma yaa bo̱nggo̱ wu kangge̱ a bu̱ri̱ mai yiku bu̱ri̱ mai mwa mwa nu̱wa mannu̱ we̱i̱ bwalau ku yaa dumdu. 
\s1 Pi̱rgu̱ yi̱ri̱ngi̱ a dwii ji̱gu̱ laabwiya. 
\p  
\v 31 <<Ce̱gi̱ ki̱n, <Kana we̱ ka man nu̱re̱ yo̱ ko̱po̱ ka nyi̱i̱ lakargar jigu laabwiya.>  
\v 32 Anda yo̱ko̱ n wo̱o̱ sagu̱mbi̱ru̱ mi̱n, kana we̱ wu man nu̱re̱ yo̱, yaa dwii taari̱ ne̱, a diina nu̱re̱ yo̱ ba ni̱nga we̱le̱m taari̱, pero kana we̱ wu yiki nu̱re̱ wu nu̱wa mana a ni̱nga taari̱. 
\s1 Pi̱rgu̱ yi̱ri̱ngi̱ a dwii we̱ra 
\p  
\v 33 <<Pero bu nu̱u̱ tu Yamba sa kakaa yiwa nang ki̱n, <Ma ki̱yani̱ ya we̱ra mo̱, anda ma ni̱nga tu ma we̱ranga gawu̱ri̱ Mbaa Wu Gi̱ra.>  
\v 34 Yo̱ko̱ n sagu̱mbi̱ru̱, bu ni̱ngi̱ ya we̱ra a dwii kana ca. Bu we̱re̱ni̱ ya yi̱ diyou, di̱ngi̱n twii candu̱ Lau̱ Yambau̱  
\v 35 kana yi̱ si̱ma pu ce̱nni̱ mwar ye̱i̱, kana yi̱ Wurcalima, di̱ngi̱n twii gwe̱i̱ Balaa wu Gi̱ra.  
\v 36 Bu ni̱ngi̱ ya we̱ra kana yi̱ dwii mai, di̱ngi̱n bu puwi waku̱gu̱ kana ku̱u̱ ku̱ri̱ kiino po̱lo̱ po̱lo̱ kana pitipiti.  
\v 37 Yama <O̱ng,> mbi̱re̱ ba yo̱o̱ <O̱ng,> pero <<Ang Ang,>> mbi̱r ba yo̱o̱ Ang Ang.> Kana ca tu bu ce̱ ka gwal yi̱to̱ a baa bo̱nggo̱ wu bwi̱i̱ye̱ wii. 
\s1 Pi̱rgu̱ yi̱ri̱ngi̱ a dwii yagu gerou 
\p  
\v 38 <<Bu nu̱wa ce̱gi̱ ki̱n, <Nunge nyan nunge, pero nwii nyan nwii.>  
\v 39 Anda yo̱ko̱ n sagu̱mbi̱ru̱ mi̱n, ma yari ya gerou bo̱nggo̱ ne̱re̱ ni̱ng tu bwi̱i̱. Ka wu kangge̱ kapa mini dwang mo̱ wu je̱u̱ ma wakaman yo̱ wu kanggi̱ wii mwaasi̱.  
\v 40 Ka ne̱re̱ wu kangge̱ kasi̱ de̱r kwaram mo̱ a laa balu palaka ba yi̱ya mi̱n cacuwe mau, ma mu̱rman yo̱ gatangamau mwa.  
\v 41 Ka kana we̱ ki̱ca mi̱n so̱ngma nyan mel wiino ma amna nyan mel ro̱p.  
\v 42 Ka kana we̱ ka senggi yi̱ri̱ bo̱nggo̱ mo̱u̱, ma puwa yo̱, ma jari ya ne̱re̱ wu baa kasi̱gu̱ ci̱ne̱ bo̱nggo̱ mo̱u̱. 
\s1 Ma kangman bace̱mba ma 
\p  
\v 43 <<Bu nu̱wa ce̱gi̱ ki̱n, <Ma kangman bapun mo̱, ma kwaa bace̱n mo̱.>  
\v 44 Anda yo̱ko̱ n sagu̱mbi̱ru̱ mi̱n, bu kangman bace̱mba mba, bu ce̱man pma ku̱ru̱ pma bu turo mbi̱r wa,  
\v 45 palaka bu yo̱ kwaraa Mbaa mbi̱r wu diyou. Di̱ngi̱n yo̱ diini nyanggu̱ swiiri ne̱re̱ wu bwi̱i̱ye̱ yi̱ ne̱re̱ wu nyaa, pero diini gundu yar man ne̱re̱ wu ni̱ng pi̱su̱ wu nyaau a gawu̱ri̱ Yambai̱ yi̱ pma bu yaa ni̱ng pi̱su̱ wu nyaau a gawu̱ri̱ Yambai̱.  
\v 46 Ka bu kangman nu̱wa bu kang mbi̱ri̱ wa ti̱bak, wo̱ri̱ri̱ ye̱i̱ ca tu bu ki̱ng we̱i̱? Kana nu̱wa bu yi̱ri̱ janggal wa mwa, ni̱ng yi̱to̱!  
\v 47 Anda ka bu ci̱r basi̱mba mba ti̱bak, tu bu ni̱nga twe̱e̱ye̱i̱ ca? Kana nu̱wa bu so̱m bu Yamba wa ni̱ng yi̱to̱!  
\v 48 Tagi̱ bu si̱ya ci̱maci̱ma ci̱ka ku Mbaa mbi̱re̱ wu diyou ci̱maci̱ma. 
\c 6  
\s1 Nyi̱i̱gu̱ ni̱i̱ bu yaa to̱no̱ wa 
\p  
\v 1 <<Bu ruun tu̱we̱, bu ni̱ngi̱ ya wu̱rangi̱ tu nyaayi mi̱n palaka nu̱wa ba ko̱. Ka bu ni̱ng yi̱to̱ yaa ku bu nyi̱ngu̱ we̱i̱ wo̱ri̱ri̱ bo̱nggo̱ Mbaa mbi̱re̱ wu diyou.  
\v 2 <<Di̱ngi̱n yi̱to̱ ka bu nyi̱i̱ yi̱ri̱ ne̱re̱ wu yaa to̱no̱ bu te̱e̱ri̱ ya, ci̱ka ku nu̱wa bu yi̱ batal wa ni̱ngu̱ a mi̱ri̱nggu̱ gi̱ri̱ndi̱ ku̱ri̱ yi̱ nyindi. Pma ni̱ngi̱ yi̱to̱ palaka nu̱wa ba wandi̱ pma. N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱ pma nyi̱ngga wo̱ri̱ri̱ pmai.  
\v 3 Anda ka bu kalan ne̱re̱ wu yaa to̱no̱, kana basi̱n mo̱ wu ne̱m ba so̱m ya,  
\v 4 palaka ni̱i̱ mai ba yo̱o̱ tukugi. Mbaa mo̱ wu kwe̱e̱yi̱ tu tukugi nyi̱i̱mi̱nu̱ we̱i̱ wo̱ri̱ri̱. 
\s1 Pi̱rgu̱ yi̱ri̱ngi̱ a dwii ce̱gu̱ ku̱ru̱ 
\p  
\v 5 <<Ka bu wuni ce̱gu̱ ku̱ru̱ bu ni̱ngi̱ yaa ci̱ka nu̱wa bu yi̱ batal wa! Pma kasi̱ ba ce̱ ku̱ru̱ a pi̱ti̱ndi̱ a gi̱ri̱ndi̱ ku̱ru̱ yi̱ ge̱nge̱lte̱ nyindi, palaka kana we̱ ba ko̱ pma. N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱, pma gi̱ci̱la nyi̱ngga wo̱ri̱ri̱ pmai mwa mwa.  
\v 6 Anda mo̱, ka ma wunni ce̱gu̱ ku̱ru̱, ma dimno kane̱, ma laka nyinou, ma ce̱ ku̱ru̱ bo̱nggo̱ Mbaa mo̱ wu nu̱wa yaa kwe̱e̱yi̱. Mbaa mo̱ wu kwe̱e̱yi̱ tu tukugi nyi̱i̱mi̱nu̱ we̱i̱ wo̱ri̱ri̱. 
\p  
\v 7 <<Ka bu wunni ce̱gu̱ ku̱ru̱ bu ni̱ngi̱ ya pu perenggu, ci̱ka ku nu̱wa bu so̱m bu Yamba wa ni̱ngu̱, pma nu̱u̱ ci̱ka Yamba nu̱u̱ we̱i̱ pma di̱ngi̱n ce̱wi̱ pmai tu co̱ku̱ro̱k.  
\v 8 Bu ni̱ng ya yi̱to̱ di̱ngi̱n Mbaa mbi̱re̱ a so̱m tu bu kasi̱gi̱ yake̱ pu bo̱ bu senggo bu yo̱.  
\v 9 Ti̱na nyinou wu bu ce̱ we̱i̱ ku̱ru̱: 
\q1 <<Mbaa yire wu wo̱o̱ diyou, 
\q1 nu̱wa ba nyi̱i̱ gi̱ru̱ din mai. 
\q1  
\v 10 Lau̱ mo̱u̱ ba baa, 
\q1 dangandi̱ mai ba ni̱ngwa si̱ma, 
\q2 ci̱ka ku ni̱ngu̱ bu̱ru̱ a diyou. 
\q1  
\v 11 Ma puu yir je̱e̱ndi̱ tu reni. 
\q1  
\v 12 Ma para sukom we̱le̱m yiru, 
\q2 ci̱ka ku yo mwa yi paraman sukom 
\q2 pma bu we̱le̱ yiru wa. 
\q1  
\v 13 Ma de̱ yiri ya bo̱nggo̱ miyam, 
\q2 anda ma mi̱ra yiro bo̱nggo̱ wu bwi̱i̱ wii. 
\p  
\v 14 <<Ka bu par sukom pma bu ni̱nga mbi̱r we̱le̱m wa, Mbaa mbi̱re̱ wu diyou yika mwaasi̱ para mbi̱r we̱i̱ sukom we̱le̱m mbi̱ru̱.  
\v 15 Anda ka bu kwaa pargu̱ sukom pma bu we̱la mbi̱r wa, yi̱to̱ mwaasi̱ Mbaa mbi̱re̱ yaa ku para mbi̱ru̱ we̱i̱ sukom we̱le̱m mbi̱ru̱. 
\s1 Pi̱rgu̱ yi̱ri̱ a dwii de̱gu̱ cooji 
\p  
\v 16 <<Anda ka bu de̱r cooji, bu bwiyani ya gaanggu̱ ci̱ka nu̱wa bu yi̱ batal wa. Pma caari̱ kau palaka kana we̱ ba ko̱ ki̱n pmai de̱gi̱ cooji. N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱ pma gi̱ci̱la nyi̱ngga wo̱ri̱ri̱ pmai mwa mwa.  
\v 17 Anda ka ma de̱r cooji ma car kau mau, ma swati̱ dwii mai,  
\v 18 di̱ngi̱n nu̱wa ba so̱m ya ki̱n ma de̱gi̱ cooji bu̱ri̱ Mbaa mo̱, wu nu̱wa yaa kwe̱e̱yi̱, yo̱ so̱m we̱i̱. Anda Mbaa mo̱, wu kwe̱e̱yi̱ tu tukugi nyi̱i̱mi̱nu̱ we̱i̱ wo̱ri̱ri̱. 
\s1 Nyaau ku diyou Yambau̱ 
\p  
\v 19 Ma ruumani ya bu̱ri̱ mbi̱ri̱ gi̱na a si̱ma, pu bo̱bo̱ yi̱ saasa bwi̱yanu̱ we̱i̱, pero kuuwa ki̱nggu̱ we̱i̱ nyinou ba ji̱nda.  
\v 20 Anda bu ruu man bu̱ri̱ mbi̱ri̱ gi̱na diyou Yambau̱, pu bo̱bo̱ yi̱ saasa na bwiyani, pero kana kuuwa na pu re̱pu̱gu̱ ba ji̱nda.  
\v 21 Di̱ngi̱n pu gi̱na mo̱ wo̱o̱ mi̱ru̱, gaanggu̱ mo̱u̱ ko̱o̱ pwii. 
\s1 Rangu̱ bu̱ru̱ 
\p  
\v 22 <<Nundi twii ke̱ndabwala bu̱ru̱. Ka nundi mai kundi wang, mwa mwa bu̱ri̱ mai twanggi yi̱ rangu̱.  
\v 23 Anda ka nundi yaa kundi ne̱, bu̱ri̱ mai mwa mwa si̱ we̱i̱ yi̱ ku̱mji̱la. Di̱ngi̱n to̱no̱ ka rang wu bu̱ri̱ mai twii ku̱mji̱la we̱i̱, ku̱mji̱la wu ma mi̱ri̱ wang! 
\s1 Yamba yi̱ gi̱na 
\p  
\v 24 <<Yaa ne̱re̱ wu ku̱ramanu̱ we̱i̱ si̱ma nu̱wa bu gi̱rawa ro̱p, ma kangmanu we̱i̱ wiino, ma kwaa wu kangge̱. Ma ce̱do̱ wu wiino, ma po̱ng wu kangge̱. Yaa ku ma ku̱ramanu̱ we̱i̱ si̱ma Yamba bambang ma ku̱raman si̱ma ke̱ne̱. 
\p  
\v 25 Di̱ngi̱n to̱no̱ n wo̱o̱ sagu̱mbi̱ru̱, bu miyani ya bu̱ri̱ yi̱ pi̱i̱ma mba, yi̱ yi̱ri̱ tu bu je̱e̱ we̱i̱ yi̱ tu bu naa we̱i̱, kana se̱e̱ wu bu te̱e̱ru̱ we̱i̱ a bu̱ri̱. Pi̱i̱ma gwala bu je̱e̱ndi̱ ru? Bu̱ri̱ gwala bu se̱e̱ ru?  
\v 26 Bu su̱wa yidi, pma yaa pi̱ri̱ yaa kaci̱, pero yaa gamani ba parna bindou, anda Mbaa mbi̱re̱ wu diyou pu pma je̱e̱ndi̱! Bu gwala bu yidi kwaara ru?  
\v 27 Wii we̱ a cu̱du̱ mbi̱ri̱ di̱ngi̱n miyanggu bu̱ru̱ puu we̱i̱ cwatugu kana daa kiino a mi̱ri̱nggi̱ daa yo̱? 
\p  
\v 28 <<Anda di̱ngi̱n ca bu miyani bu̱ru̱ di̱ngi̱n se̱e̱? Bu su̱wa pundi tu gu̱lai̱ gi̱ri̱, yaa pu ni̱nggu̱ kana ca di̱ngi̱n bu̱ri̱ pmai, yaa pu ba ni̱nga waandi di̱ngi̱n bu̱ri̱ pmai.  
\v 29 Anda n wo̱o̱ sagu̱mbi̱ru̱ kana Balaa Solomon yi̱ gi̱r yo̱u̱ mwa ni̱nga bu waandi si̱i̱ yi̱lau̱ ci̱ka to̱no̱.  
\v 30 Ka ce̱mbe̱re̱ Yamba pu ni̱ngaman si̱i̱ tu gu̱lai̱ waandi tu to̱o̱ reni anda pu̱nge̱ nu̱wa parnu we̱i̱ bwalau, dwiyaman mba te̱e̱ mbi̱ru̱ we̱i̱ se̱e̱, mba bu yi̱ dwal le̱e̱gu̱ ji̱re̱. 
\p  
\v 31 <<Di̱ngi̱n to̱no̱, bu miyani ya bu̱ri̱, bu ce̱gu̱ mi̱n, <Tu yi je̱e̱ we̱i̱ ca? Tu yi naa we̱i̱ ca? Tu yi te̱e̱ru̱ we̱i̱ ca?>  
\v 32 Nu̱wa bu pma so̱m bu Yamba wa, a kasanggu̱ to̱o̱ yi̱ri̱ngi̱ mwa mwa, Mbaa mbi̱re̱ wu diyou a so̱m biiki mbi̱re̱.  
\v 33 Anda tu gawu̱ri̱yo̱, bu kasa lau̱ yo̱u̱ yi̱ pi̱su̱ wu nyaau a gawu̱ri̱ ye̱i̱, anda yo̱ nyi̱i̱mbi̱ri̱ we̱i̱ to̱o̱ yi̱ri̱ngi̱ mwa mwa.  
\v 34 Di̱ngi̱n to̱no̱ bu miyani ya bu̱ri̱ yi̱ punge, punge a yi̱ biiki yo̱. Kana ko̱no̱ nyanggu̱ yi̱ biiki yo̱. 
\c 7  
\s1 Bu ni̱ngamani̱ ya nu̱wa bali̱ 
\p  
\v 1 <<Bu ni̱ngamani̱ ya bali̱ nu̱wa, palaka Yamba ba ni̱nga mbi̱r ya bali̱,  
\v 2 di̱ngi̱n Yamba ni̱ng mbi̱r we̱i̱ bali̱ yi̱to̱ ci̱ka ku bu ni̱ngaman bali̱ nu̱wa. Yi̱ bo̱so̱ro̱ wu bu cu̱u̱man nu̱wa yi̱ to̱no̱, Yamba cu̱u̱ mbi̱ri̱ we̱i̱ yi̱ to̱no̱.>>  
\v 3 Di̱ngi̱n ca mo̱ su̱u̱gu̱ bo̱si̱yau̱ ku̱ nung bago̱n mo̱u̱, anda ma yaa ko̱gu̱ gulsou wu nung mo̱u̱?  
\v 4 Ni̱ngdu̱ we̱i̱ nye̱ ma sa bago̱n mo̱ mi̱n, <Yama n de̱man bo̱si̱yau̱ ku̱ nung mo̱u̱,> anda mo̱ yi̱ri̱ mai ma wo̱o̱ yi̱ gulsou a nung mo̱?  
\v 5 Mo̱ wii batal, ma toso de̱manggu̱ gulsou wu nung mo̱u̱ bati̱, palaka mo̱ kwe̱e̱ we̱i̱ si̱ma kundi, ma podoman bago̱n mo̱ bo̱si̱yau̱ ku̱ nung yo̱u̱. 
\p  
\v 6 <<Bu nyi̱i̱ ya baindi yi̱ri̱ tu walwal. Ma mandi̱ ya si̱ye̱i̱ gi̱si̱ tu yi̱ pi̱rcu̱ a gawu̱r bakambi̱ su lai̱, pma pe̱nu̱ we̱i̱ yi̱ mwari pmai! Anda ba waata bo̱nggo̱ mo̱u̱ ba pwara mi̱na. 
\s1 Ma celo, ma kasa, ma kupo 
\p  
\v 7 Bu ni̱nga pu celo, nu̱wa nyi̱i̱mbi̱ri̱ we̱i̱. Bu ni̱nga pu kasi̱gu̱, bu nyi̱nggu̱ we̱i̱. Bu ni̱nga pu kupugu, nu̱wa wunmbi̱ru̱ we̱i̱.  
\v 8 Di̱ngi̱n kana we̱ wu celo, nu̱wa nyi̱i̱ we̱i̱. Kana we̱ wu kasa, nyi̱nggu̱ we̱i̱, pero do̱ng kana we̱ wu kupo, nu̱wa wunmanu we̱i̱ yo̱. 
\p  
\v 9 Mba kwiimba, wii we̱ a cu̱du̱ mbi̱ri̱ wu ka bo̱l yo̱ cel yo̱ ku̱maa, nyi̱i̱ we̱i̱ swe̱l?  
\v 10 Pero ka cel yo̱ jingne, nyi̱i̱ we̱i̱ co̱o̱gu̱ we̱?  
\v 11 Ka mba bu bwi̱i̱wa bu so̱m nyi̱i̱gu̱ tu nyaayi kwaraa mba we̱i̱, dwiyamin Mbaa mbi̱re̱ wu diyou, yo nyi̱i̱ we̱i̱ yi̱ri̱ngi̱ tu nyaayi nu̱wa bu senggu yo̱ wa!  
\v 12 Di̱ngi̱n to̱no̱, ci̱ka ku̱ bu kasi̱ nu̱wa ba ni̱ngambi̱ra, yi̱to̱ mwa bu ni̱ngaman pma, to̱o̱ pi̱ti̱ndi̱ te̱e̱ri̱ng Musa yi̱ banabi̱ndi̱. 
\s1 Nyinou wu le̱pe̱k yi̱ wu gu̱rci̱k 
\p  
\v 13 <<Bu tembiro nyinou wu gu̱rci̱k. Di̱ngi̱n nyinou wu le̱pe̱k de̱r ne̱re̱ par bwalau, pero nu̱wa tum teendi.  
\v 14 Anda nyinou wu banyi̱nau̱ pero gu̱rci̱k twii nyinou wu de̱r ne̱re̱ pi̱i̱ma, anda nu̱wa banyi̱na ti̱bak ki̱nggi̱. 
\s1 Bu so̱m we̱i̱ nu̱wa bo̱nggo̱ wu̱rangi̱ pmai 
\p  
\v 15 <<Bu ruun tu̱we̱ bo̱nggo̱ banabi̱ndi̱ leendi wa. Pma baanga we̱i̱ bo̱nggo̱ mbi̱ru̱ a mi̱ri̱nggi̱ biyau ci̱ka puuri, anda a mi̱ri̱nggi̱ pmai twii geppindi.  
\v 16 Bu ku̱ranu̱ we̱i̱ pma bo̱nggo̱ tutwiyari pmai. Yaa ku̱ nu̱wa war we̱i̱ tutwiyari inabi a bo̱nggo̱ ku̱ri̱lle̱, yi̱to̱ mwa yi̱ pwaari̱ pwalgu̱ a bo̱nggo̱ sou calau.  
\v 17 Yi̱to̱ mwaasi̱ yi̱ kana ko̱no̱ sou ku nyaau nyi̱i̱ tutwiyari ye̱i̱, anda sou ku bwi̱u̱ nyi̱i̱ tutwiyari tu bwi̱i̱.  
\v 18 Sou ku nyaau yaa nyi̱i̱ tutwiyari tu bwi̱i̱. Yi̱to̱ mwa sou ku bwi̱u̱ yaa nyi̱i̱ tutwiyari tu nyaayi.  
\v 19 Kana ko̱no̱ sou ku yaa nyi̱i̱ tutwiyari tu nyaayi nu̱wa kaci̱nu̱ we̱i̱ si̱ma ba manna bwalau.  
\v 20 Yi̱to̱ mwaasi̱, bu ku̱ranu̱ we̱i̱ pma bo̱nggo̱ tutwiyari pmai. 
\p  
\v 21 <<Yaa kana we̱ wu yi̱nggi̱ ki̱n, <Mbaa Wu Gi̱ra, Mbaa Wu Gi̱ra,> diiru we̱i̱ lau̱ ku diyou, anda bu̱ri̱ ne̱re̱ wu tu̱m dangandi̱ Mbaa mi wu diyou.  
\v 22 A nyanggu̱ balu, nu̱wa tum sanggu̱ we̱i̱ ki̱n, <Mbaa Wu Gi̱ra, Mbaa Wu Gi̱ra, yi ce̱ tu ni̱ngdu̱ we̱i̱ pi̱na yi̱ gawu̱ri̱ a mi̱ri̱nggi̱ din mai, yi̱ din mai yi yikongo wuturindi, yi ni̱nga yi̱ri̱ngi̱ ri̱yandi̱ bu̱ri̱ tum.>  
\v 23 N saru we̱i̱ pma ge̱mbe̱l mi̱n, <N ti̱i̱ bu so̱nggu̱mbi̱ru̱. Bu laanga po̱o̱ bo̱nggo̱ mu, mba nu̱wa bu tu̱m tu bwi̱i̱ wa.> 
\s1 Ba mwe̱me̱ wu pwi̱yagi̱ yi̱ wu yaa pwi̱yagi̱. 
\p  
\v 24 <<Di̱ngi̱n to̱no̱ kana we̱ wu nu̱u̱ ci̱ye̱i̱ mi pero ni̱ngi̱ wu̱rai̱ yi̱ to̱no̱ ci̱ka ne̱re̱ wu pwi̱yagi̱ wu mo̱nni̱ laa yo̱u̱ dwii swe̱li̱.  
\v 25 Pu gundu toso yarugu, youri twanganga, wutur baa a buu laa wii anda yaa ku yarau, di̱ngi̱n nu̱wa man taayau̱ dwii swe̱li̱.  
\v 26 Anda kana we̱ wu nu̱u̱ ci̱ye̱i̱ mi anda yaa ku ni̱nga wu̱rai̱ yi̱ to̱no̱ ci̱ka ne̱re̱ wu yi̱ cini wu mo̱nni̱ laa yo̱u̱ a swai.  
\v 27 Pu gundu toso yarugu, youri twanganga, pero wuture ni̱nga, a buu laa wii, a yara, yaranggu̱ yo̱u̱ a ni̱nga wang.>> 
\p  
\v 28 Pu Yesu mata ce̱gu̱ to̱ yi̱ri̱ngi̱, nu̱wa bwii riyanga bu̱ri̱ yi̱ yi̱ri̱ngi̱ tu ju̱ku̱gu̱,  
\v 29 di̱ngi̱n a ju̱ku̱gu̱ yi̱ri̱ngi̱ ci̱ka ne̱re̱ wu yi̱ di̱mbi̱re̱, yaa ci̱ka ku̱lu̱mba te̱e̱ri̱ngi̱ pma wa. 
\c 8  
\s1 Ne̱re̱ wu yi̱ butangi 
\p  
\v 1 Go̱ro̱ pu Yesu julo ci̱ngu̱ kwii, nu̱wa tum po̱ngwe̱ yo̱.  
\v 2 Ne̱re̱ wu kangge̱ wu yi̱ butangi baa bo̱nggo̱ yo̱u̱ a kun kwiyou a ce̱ ki̱n, <<Mbaa Wu Gi̱ra, ka ma le̱e̱i̱, ma mi̱rangge̱ n yi̱la a bo̱nggo̱ butangi mi.>> 
\p  
\v 3 Yesu a yaku wai a ce̱rman yo̱, a se̱e̱ ki̱n, <<N le̱e̱, yi̱la!>> Yo̱ko̱ yo̱ko̱ butangi twii a du ne̱re̱ wii.>>  
\v 4 Yesu sa yo̱ ki̱n, <<Ma sari̱ ya kana we̱ to̱o̱ yi̱ri̱. Anda ma amna ma ju̱ku̱ bu̱ri̱ mai kuru Yamba ba su̱wa mi̱na, pero ma nyi̱i̱ ni̱i̱ du Musa ce̱ ki̱n nu̱wa ba nyi̱i̱ya, di̱ngi̱n ni̱nggu̱ walwal. Ma ni̱nga yi̱to̱ di̱ngi̱n nu̱wa ba so̱ma ki̱n ma yi̱la.>> 
\s1 Le̱e̱gu̱ ji̱re̱ bagi̱ra kacaraa wu Roma 
\p  
\v 5 Pu Yesu diiro Kaparnahum, kacala Roma wa wu kangge̱ baa ki̱nga yo̱ a senggo yo̱ ki̱n,  
\v 6 <<Ne̱re̱ wu gi̱ra, ke̱we̱ mi wo̱o̱ pi̱dau̱ lai̱, bu̱ri̱ ye̱i̱ bo̱rgi̱ a cu̱su̱gu̱ wang.>> 
\p  
\v 7 Yesu se̱e̱ ki̱n, <<N anggu̱ we̱i̱ n mi̱ra yo̱.>> 
\p  
\v 8 Bagi̱ra kacaraa wii ce̱ ki̱n, <<Ang ang yaa yi̱to̱ Mbaa Wu Gi̱ra, mi yinnibu ma baa laa mu, anda mo̱ ce̱ ci̱ye̱i̱ ti̱bak, ke̱we̱ mi yi̱l we̱i̱.  
\v 9 Di̱ngi̱n mi mwa n wo̱o̱ ku̱u̱ ne̱re̱ wu kangge̱, pero do̱ng n wo̱o̱ yi̱ kacara ku̱u̱ mu̱, ka n sar wuna mi̱n, <Amna,> yo̱ ba aara, wu kangge̱ do̱ng n se̱e̱ mi̱n, <Bame̱!> bur ba baa, pero ka n sar ke̱we̱ mi mi̱n, <Ni̱nga yi̱ri̱ nyo!> Bur ba ni̱nga.>> 
\p  
\v 10 Pu Yesu nu̱wa yi̱to̱, a riyanga bu̱ri̱, a sa nu̱wa bu po̱nggu̱ yo̱ wa ki̱n, <<N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱i̱ yaa ku n nyi̱ngga ne̱re̱ wu le̱e̱gu̱ ji̱re̱ ku yi̱ di̱mbi̱re̱ ci̱ka ki̱naa a Israila.  
\v 11 N wo̱o̱ sagu̱mbi̱ru̱ nu̱wa tum baanga we̱i̱ bo̱nggo̱ do̱no̱me̱ yi̱ nyambi̱ranggu̱ ba si̱ndi̱ si̱yau̱, a je̱gu̱ a naagu kem yi̱ Ibrahim yi̱ Icaku yi̱ Yakubu a lau̱ ku diyou.  
\v 12 Anda pma bu daaya ba teendo lau̱ ku diyou nu̱wa parnu we̱i̱ pma ku̱mji̱la, pu pma jii we̱i̱ wiindi yi̱ dumonggu nyi̱yau̱.>> 
\p  
\v 13 Anda Yesu sa bagi̱ra kacaraa wii ki̱n, <<Mwati̱ lai̱, ci̱ka ku ma pu ji̱re̱ ni̱ndu̱ we̱i̱ yi̱to̱.>> Anda ke̱we̱ bagi̱ra kacaraa wii a yi̱la ki̱nangu̱. 
\s1 Yesu mi̱ra nu̱wa tum 
\p  
\v 14 Yesu aara laa Bitrus, a ki̱ngga sii Bitrus wu nu̱re̱ a pi̱dau̱ yi̱ bu̱ri̱ wulok.  
\v 15 A mwaanga wai yau̱, bur bu̱ri̱ wulok swii man yo̱, a wuni, a ni̱ngaman yo̱ je̱e̱ndi̱. 
\p  
\v 16 Ku lam nyambi̱ranggu̱ nu̱wa de̱mu̱we̱ Yesu nu̱wa bu yi̱ wuturindi wa tum. Yesu yikongo wuturindi yi̱ ci̱ye̱i̱ ti̱bak, a mi̱ra pma bu yaa cingcing wa pma yi̱langa mwa mwa.  
\v 17 To̱o̱ ni̱ngwa yi̱to̱ palaka ba twanga tu banabi̱ Icaya ce̱ ki̱n, 
\q1 <<A de̱ dwal bu̱ri̱ cingcing yiru 
\q1 yi̱ buwangi yiri.>> 
\s1 Po̱nggu̱ Yesu yi̱ buu 
\p  
\v 18 Pu Yesu ku̱ranga ki̱n nu̱wa tum wo̱ra yo̱, a sa kwati̱mba ya ki̱n ba yerongo gi̱ngu̱ kali̱nggi̱ kwii.  
\v 19 Ku̱lu̱m te̱e̱ri̱ngi̱ a baa bo̱nggo̱ yau̱ a ce̱ ki̱n, <<Ku̱lu̱me̱, mi po̱ngmi̱nu̱ we̱i̱ kana pi̱yau̱ pu mo̱ amnu̱ wau.>> 
\p  
\v 20 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Bapi̱rmi̱si̱ndi̱ bo̱o̱ yi̱ bo̱ri̱ng pmai, yidi mwa yi̱ cwaaringi pmai, anda Bo̱l Ne̱re̱ yaa pu daa mi̱ru̱.>> 
\p  
\v 21 Wu kangge̱ cu̱di̱ kwati̱mba ya a ce̱ ki̱n, <<Mbaa Wu Gi̱ra, du̱ngge̱ bati̱ n angge̱ n tingwe mbaa mi.>> 
\p  
\v 22 Yesu se̱e̱ ki̱n, <<Po̱nggu̱we̱ du nu̱wa bu bwanggi̱ wa ba tingi kappi̱ma bu bwaanggi̱ wa.>> 
\s1 Yesu ye̱ra wuture yi̱ gwe̱rai̱ gundi 
\p  
\v 23 Yesu diiro konggoru anda kwati̱mba ya po̱ng yo̱.  
\v 24 Yaa te̱mandi̱ bur wutur gundu a wunuwe. Gwe̱rai̱ gundi a paringgu gundu a mi̱ri̱nggu̱ konggoru, anda Yesu a diima.  
\v 25 Kwati̱mba ya aanda bo̱nggo̱ yo̱u̱ a romya pma ce̱ ki̱n, <<Mbaa Wu Gi̱ra, mi̱ra yiro, yi bwanu we̱i̱.>> 
\p  
\v 26 <<Yesu sa pma ki̱n, <<Di̱ngi̱n ca bu nu̱u̱gu̱ gwasi̱, mba bu le̱e̱gu̱ ji̱re̱ mbi̱ru̱ banyi̱na wa?>> Bur a wuni a ye̱ra wuture yi̱ gwe̱re̱ gundu dwii, bur a si̱n si̱ye̱i̱ to̱k. 
\p  
\v 27 Kana we̱ riyanga bu̱ri̱ ki̱n, <<Ki̱naa ko̱no̱ duu ne̱ru̱? Wu kana wuture yi̱ gwe̱rai̱ gundi ni̱ngi̱ po̱ngo̱ndi̱ yi̱ yo̱!>> 
\s1 Yesu yil nu̱wa ro̱p bu yi̱ wutur wa 
\p  
\v 28 Pu Yesu aara bo̱nggo̱ si̱ma Gadara\f + \fr 8:28 \ft Lakargari̱ndi̱ su kanggi̱ a bala ki̱n si̱ma Gargasinawa bu kangga bala ki̱n si̱ma Garasinawa\f* a gi̱ng kali̱nggi̱ kwii, a kaanga yi̱ nu̱wa ro̱p bu twiyongo dwiiyongi puringi, nu̱wa bwii yi̱ wuturindi. Pma yi̱ kwe̱i̱ wang di̱ngi̱n to̱no̱ yaa ne̱re̱ wu po̱ng wii nyinou.  
\v 29 Pma ni̱nga duwai ki̱nangu̱ ki̱n, <<Bo̱l Yamba ma kasi̱gu̱ ca yi̱ yo? Ma baa pi̱na ma turo yiro bo̱ jo̱r lam bu ru?>> 
\p  
\v 30 Kan bakambi̱ su lai̱ so̱o̱ ne̱m yi̱ po̱o̱ wii, a taagu̱ taawu̱.  
\v 31 Wuturindi swii senggo Yesu ki̱n, <<Ka ma yiki yire ma su̱ka yiro yi teendo mi̱ri̱nggi̱ bakambi̱ su lai̱ swii. 
\p  
\v 32 Yesu sa pma ki̱n, <<Bu ambi̱ra>> Pma twiyongo, teendo bakambi̱ su lai̱ swii. Mwa mwa kan bakambi̱ swii a mwatanga ki̱lang ki̱lang a julomana ce̱rau̱ a yaramana gundu a bwaamana a mi̱ri̱nggi̱.  
\v 33 Nu̱wa bu taagu̱ bakambi̱ su laa swii pma ceendo gwe̱i̱, pma nyi̱i̱ nu̱wa labar yi̱ri̱ngi̱ tu ni̱ngwai̱ yi̱ nu̱wa bu yi̱ wuturindi bwii.  
\v 34 Kana we̱ a mi̱ri̱nggi̱ gwe̱i̱ dwii, a mwati̱ di̱ngi̱n ba kanga yi̱ Yesu, anda pu ko̱ yo̱ a senggo yo̱ ba du si̱ma pma. 
\c 9  
\s1 Yesu mi̱ra ne̱re̱ wu bu̱ri̱ bo̱ri̱gi̱ 
\p  
\v 1 Yesu geero konggoru a waata bu̱ri̱, a yeri bo̱nggo̱ kali̱nggi̱ a aara gwe̱i̱ ye̱i̱.  
\v 2 Nu̱wa de̱mu̱we̱ yo̱ ne̱re̱ wu bu̱ri̱ bo̱rgi̱ a pi̱dau̱ yu̱u̱. Pu Yesu ko̱ le̱e̱gu̱ ji̱re̱ pmau, a sa ne̱re̱ wu bu̱ri̱ bo̱rgi̱ wii ki̱n, <<Ci̱ko̱ gaanggu̱ bo̱l mi, nu̱wa parami̱n sukom we̱le̱mdi̱ mai.>> 
\p  
\v 3 Ku̱lu̱mba te̱e̱ri̱ngi̱ wa bu kangga yanna ce̱gu̱ ci̱ye̱i̱ yi̱ bu̱ri̱ pmai ki̱n, <<Ne̱re̱ wo̱o̱ bwiyanggu din Yambai̱!>> 
\p  
\v 4 Yesu ku̱ranga tu pma danganggi̱ a ce̱ ki̱n, <<Di̱ngi̱n ca bu danganggu̱ yi̱ri̱ngi̱ tu bwi̱i̱ a gaanggi̱ri̱ mbi̱ri̱ yi̱to̱?  
\v 5 Tu le̱e̱le̱e̱ to̱no̱, yiku n sa ne̱re̱ wo̱ mi̱n, <N parami̱n sukom we̱le̱m mau,> yi̱ ku n se̱e̱ mi̱n, <Wuni ma ni̱nga so̱ngma>?  
\v 6 Anda n kasi̱ bu so̱ma mi̱n, Bo̱l Ne̱re̱ wo̱o̱ yi̱ di̱mbi̱re̱ a si̱ma ba para sukom we̱le̱m.>> Anda a sa ne̱re̱ wu bu̱ri̱ bo̱ri̱gi̱ wii ki̱n, <<Wuni, ma de̱ yu̱u̱ mau, ma mwati̱ lai̱.>>  
\v 7 Ne̱re̱ wii wuni, a mwati̱ laa yo̱u̱.  
\v 8 Pu nu̱wa bu ku̱ranggi̱ bu̱ri̱ ko̱ yo̱, pma nu̱u̱ gwasi̱, pma te̱ranga Yamba di̱ngi̱n wo̱o̱ di̱mbi̱re̱ wu nyi̱i̱ nu̱wa. 
\s1 Yesu yi̱ Matayo 
\p  
\v 9 Yesu du po̱o̱ wii, anda pu so̱ngmau̱, a ko̱ ne̱re̱ wu yi̱ri̱ janggal wu din ye̱i̱ Matayo, a pi̱su̱ pu nu̱wa yi̱ri̱ janggal. A se̱e̱ ki̱n, <<Po̱nggu̱we̱.>> 
\p Matayo wuni, a po̱ng yo̱. 
\p  
\v 10 Pu Yesu wo̱o̱ je̱gu̱ je̱e̱ndi̱ laa Matayo, nu̱wa bu yi̱ri̱ janggal wa tum yi̱ nu̱wa bu kangga bu yi̱ we̱le̱m wa pma baanga je̱ je̱e̱ndi̱ kem yi̱ yo̱ yi̱ kwati̱mba ya.  
\v 11 Parisayo bu kangga ku ko̱ yi̱to̱ pma pi̱ra kwati̱mba ya ki̱n, <<Di̱ngi̱n ca ku̱lu̱m mbi̱re̱ a je̱gu̱ je̱e̱ndi̱ yi̱ nu̱wa yi̱r janggal yi̱ bu yi̱ we̱le̱m wa?>> 
\p  
\v 12 Pu Yesu nu̱wa, a sa pma ki̱n, <<Nu̱wa bu cingcing wa yaa kasi̱ ku̱lu̱me̱, bu̱r nu̱wa bu yaa cingcing wa.  
\v 13 Ambi̱ra bu ye̱sa tu lakargar Yamba ce̱i̱, <Tu n kasi̱ twii nu̱wa ba ju̱ki̱ bunam, twii nyi̱i̱gu̱ ni̱i̱ ne̱.> N baa bu di̱ngi̱n nu̱wa bu ni̱ngi̱ pi̱su̱ wu nyaau a gawu̱ri̱ Yambai̱ anda n baa di̱ngi̱n nu̱wa bu yi̱ we̱le̱m wa.>> 
\s1 Pi̱ra dwii de̱gu̱ cooji 
\p  
\v 14 Kwati̱mba Yohanna wu Ni̱ngi̱ Bati̱si̱ma baanga bo̱nggo̱ Yesu a pi̱ra ki̱n, <<Di̱ngi̱n ca yo yi̱ Parisayo yi ni̱ng cooji nyi̱ki̱ri̱k anda kwati̱mba ma yaa ni̱ngi̱?>> 
\p  
\v 15 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Ni̱ngdu̱we̱ nye̱ basi̱nba laabwiya wa ba de̱ cooji pu bo̱ wo̱o̱ kem yi̱ bwiyaka wu laabwiya we̱yo̱ ru?>> Anda daandi so̱o̱ baayi su nu̱wa de̱manu̱ we̱i̱ bwiyaka wu laabwiya we̱yo̱ a bo̱nggo̱ pmau̱, bur pma ni̱ngi̱ we̱i̱ cooji. 
\p  
\v 16 <<Yaa wu cwaki̱nu̱ we̱i̱ se̱e̱ wu pu̱ce̱ a dwii wu mi̱lga, ka ni̱ndi̱ yi̱to̱ wu nu̱wa cwaki̱na wii kwaci̱ranu̱ we̱i̱ se̱e̱ wii ba diina ba pwarwa wang.  
\v 17 Pero yaa ne̱re̱ wu de̱ru̱ we̱i̱ gundu inabi ku pu̱cu̱ ba parna cwe̱i̱ndi̱ bi̱yari̱ tu mi̱lgai̱, ka ni̱ndi̱ yi̱to̱ gundu inabi ku̱ pu̱ci̱ kwii, re̱panu̱ we̱i̱ cwe̱i̱ndi̱ bi̱yari̱ twii, pero gundu inabi kwii ba par si̱yau̱. Anda nu̱wa ba parna a cwe̱i̱ndi̱ bi̱yari̱ tu pu̱ci̱, mwa mwa pmau ba ni̱ngga kundi. 
\s1 Bwe̱e̱canga ne̱re̱ wu gi̱ra yi̱ nu̱r wu mwaanga gatangamau Yesu 
\p  
\v 18 Pu Yesu wo̱o̱ ce̱gu̱ ti̱na yi̱ri̱ngi̱, ne̱re̱ wu gi̱ra wu gi̱re̱ng ku̱ru̱ a baa bo̱nggo̱ yo̱u̱ a kun kwiyou gawu̱ri̱ ye̱i̱, a ce̱ ki̱n, <<Bwe̱e̱canga mi a bwaa yo̱ko̱ ki̱na, bame̱ ma ce̱nni̱ wai wuni we̱i̱ yi̱ pi̱i̱ma.>> 
\p  
\v 19 Yesu wuni a po̱ng yo̱, kem yi̱ kwati̱mba ya. 
\p  
\v 20 Nu̱r wu kangge̱ wu ti̱i̱gu̱ ku̱u̱lu̱ yi̱ buwai pargu̱ si̱ye̱i̱ ti̱i̱mau̱ nyan mi̱ldi̱ kwap su̱r ro̱p, a baa go̱ro̱u̱ Yesu a pilo nyan gatangamau yo̱u̱.  
\v 21 A sa bu̱ri̱ ye̱i̱ ki̱n, <<Ka n pili kana gatangamau yo̱u̱, n yi̱lu̱ we̱i̱.>> 
\p  
\v 22 Yesu waka kau a ko̱ yo̱, a ce̱ ki̱n, <<Bwe̱e̱canga mi ci̱ko̱ gaanggu̱, le̱e̱gu̱ ji̱re̱ mau a mi̱rami̱na.>> A dwii jo̱re̱ nu̱re̱ wii ni̱nga cingcing. 
\p  
\v 23 Pu Yesu lama laa ne̱re̱ wu gi̱ra wu gi̱re̱ng ku̱ru̱, ku ko̱ nu̱wa kwari̱ndi̱ yi̱ bu kangga wuugu bagaati̱ bo̱o̱re̱,  
\v 24 a ce̱ ki̱n, Kana we̱ ba twiyo. <<Bwe̱e̱canga wo̱o̱ yaa bwaagi̱, a diima!>> Pma rii yo̱.  
\v 25 Ku nu̱wa yiku nu̱wa bwii twalange̱, Yesu te̱e̱ wai, a wuni.  
\v 26 Labar yo̱ wasi̱ bu̱ri̱ kana pi̱yau̱ a si̱ma bwii. 
\s1 Yesu mi̱ra kerma ro̱p 
\p  
\v 27 Pu Yesu du po̱o̱ wii, kerma ro̱p po̱ngu̱ yo̱ pma ni̱ngu̱ duwau a ce̱gu̱ ki̱n, <<Bo̱l Dawud, nu̱u̱ bunam yiru!>> 
\p  
\v 28 Pu Yesu diiro laa wu pi̱su̱ mi̱ri̱, kerma bu ro̱p bwii baanga bo̱nggo̱ yo̱u̱ anda a pi̱ra pma ki̱n, <<Bu le̱e̱ ji̱re̱i̱ n puu we̱i̱ kalanggi̱ mbi̱r du?>> 
\p Pma le̱e̱man yo̱ ki̱n, <<O̱ng ne̱re̱ wu gi̱ra.>> 
\p  
\v 29 Yesu mwaanga nundu pmai a ce̱ ki̱n, <<Yama ba ni̱ngwa ci̱ka ku̱ bu le̱e̱ ji̱re̱i̱!>>  
\v 30 Nundi pmai toso ko̱gu̱. Yesu sa pma ki̱n, <<Bu sari ya kana we̱!>>  
\v 31 Anda pma mwatanga a wasi̱ ci̱ye̱i̱ dwii Yesu kana pi̱yau̱ a si̱ma bwii. 
\s1 Yesu mi̱ra ne̱re̱ wu yaa ce̱ ci̱yei̱ 
\p  
\v 32 Pu pma twiyongo, nu̱wa bu kangga de̱e̱ ne̱re̱ wu yaa ce̱ ci̱ye̱i̱ di̱ngi̱n yi̱ wuturindi a bo̱nggo̱ Yesu.  
\v 33 Anda ku Yesu yiki wutur wii, ne̱re̱ wii toso ce̱gu̱ ci̱ye̱u̱, kana we̱ riyanga bu̱ri̱ pma ce̱ ki̱n, <<Yaa ku yi ti̱i̱ ko̱gu̱ yi̱ri̱ ci̱ka ti̱na a Israila!>> 
\p  
\v 34 Anda Parisayo ce̱ ki̱n, <<Twii bagi̱ra wuturindi a nyi̱i̱ yo̱ di̱mbi̱re̱ ba yiki wuturindi.>> 
\s1 Yesu nu̱u̱ bunam nu̱wau̱ 
\p  
\v 35 Yesu wo̱ra go̱ro̱ndi̱ tu gi̱rai̱ yi̱ tu nyi̱ti̱ti̱. A ju̱ku̱gu̱ yi̱ri̱ngi̱ a gi̱ri̱ndi̱ ku̱ri̱ pmai, a wasi̱gu̱ ci̱ye̱i̱ du teng a dwii lau̱ Yambau̱ pero a mi̱ra nu̱wa tum yi̱ buwangi wundu wundu yi̱ bu̱ri̱ wulok pma yi̱langa. 
\p  
\v 36 Ku ko̱ nu̱wa ku̱ranggi̱ bu̱ri̱ tum, a nu̱u̱ bunam pmau di̱ngi̱n pma ti̱i̱gu̱ ku̱u̱lu̱ pero tetenggi, yaa ne̱re̱ wu kalanu̱ we̱i̱ pma, ci̱ka puuri su yaa taage̱.  
\v 37 A sa kwati̱mba ya ki̱n, <<Jama bu biya wa a ni̱nga tum, anda nu̱wa bu kaci̱ wa ni̱nga banyi̱na.  
\v 38 Di̱ngi̱n to̱no̱, bu senggo Ne̱re̱ wu ko̱ndo̱ wa yau̱ ba tu̱mu̱we̱ nu̱wa wu̱ra wa a ko̱ndo̱ yo̱u̱.>> 
\c 10  
\s1 Yesu tu̱m kwati̱mba kwap su̱r ro̱p 
\p  
\v 1 Yesu yi̱we̱ kwati̱mba ya kwap su̱r ro̱p pwe̱yau̱ piinou, a nyi̱i̱ pma di̱mbi̱re̱ ba yiki wuturindi pero ba mi̱ra kana ko̱no̱ du buwai. 
\p  
\v 2 Ti̱naa dinendi nu̱wa tu̱mandi̱ wa Yesu wa bu kwap su̱r ro̱p wu gawu̱ri̱yo̱ wii Simon, (wu nu̱wa yi̱ri̱ ki̱n Bitrus) yi̱ ci̱ya yo̱ Andarawus, Yakubu bo̱l Sabadi yi̱ ci̱ya yo̱ Yohanna,  
\v 3 Pilibus yi̱ Bartalamawus yi̱ Toma yi̱ Matayo wu yi̱ri̱ janggal, yi̱ Yakubu bo̱l Alpayo, yi̱ Tadawus,  
\v 4 yi̱ Simon wu yi̱ bwiu di̱ngi̱n si̱ma ya yi̱ Yahuda Iskariyoti wu cuu Yesu. 
\p  
\v 5 Nu̱wa bu kwap su̱r ro̱p bu Yesu tu̱ma bwii a nyi̱i̱ pma di̱kace̱ne̱ ki̱n, <<Bu ambi̱r ya bo̱nggo̱ nu̱wa bu yaa yo̱o̱gi̱ nu̱wa bu Yudaya wa, yi̱ go̱ro̱ndi̱ nu̱wa bu Samariya wa.  
\v 6 Bu ambi̱ra bo̱nggo̱ nu̱wa bu Israila wa bu li̱yanga ci̱ka puuri su yaa taage̱.  
\v 7 Ambi̱ra bu wasi̱ ci̱ye̱i̱ mi̱n, <Lau̱ ku diyou ni̱nga ne̱m!>  
\v 8 Bu mi̱ra bu yaa cingcing wa, bu wumongo bu bwaanga wa, bu mi̱ra babutanga, pero bu yikongo wuturindi. Nu̱wa nyi̱i̱mbi̱ra nyo bu nyi̱i̱ya nyo.  
\v 9 Bu de̱ri̱ ya sinariya yi̱ asurpa, yi̱ kana ke̱ne̱ a swari̱ mbi̱re̱,  
\v 10 bu de̱ri̱ ya swari̱ so̱ngmai̱ kana landari̱ ro̱p yi̱ paari̱, yi̱ jwalu di̱ngi̱n ne̱re̱ wu̱rai̱ a yinno nu̱wa ba nyi̱i̱ je̱e̱ndi̱. 
\p  
\v 11 <<Ka bu tembiro gwe̱i̱ du gi̱rai̱ yi̱ du banyi̱nai̱ bu kasa ne̱re̱ wu yi̱ mbi̱r we̱i̱ bu si̱ndi̱ si̱ye̱i̱ a pwii ko̱po̱ nyanggu̱ ku bu duru we̱i̱ po̱o̱ wii.  
\v 12 Ka bu te̱mbi̱r laa wii bu ci̱ pma.  
\v 13 Ka nu̱wa bu laa wii yo̱o̱ bu nyaa wa, yama pi̱dau̱ gaanggu̱ mbi̱ru̱ ba si̱ya bo̱nggo̱ pmau, ka kwaai yama pi̱dau̱ gaanggu̱ ba waata bu̱ri̱ bo̱nggo̱ mbi̱ru̱.  
\v 14 Anda kana pi̱yau̱ pu nu̱wa kwaa yi̱gu̱ mbi̱ru̱ pero kwaa ba ka twiyau yi̱ mba, bu kapa gur du mwar mbi̱ri̱, ka bu du̱r gwe̱i̱ dwii.  
\v 15 N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱, a nyanggu̱ balu, Yamba nu̱u̱ we̱i̱ bunam nu̱wa bu Sodom yi̱ Gomora yiku ba nu̱u̱ bunam gwe̱i̱ dwii! 
\s1 Ti̱i̱gu̱ ku̱u̱le̱ ku ko̱ baawu 
\p  
\v 16 N wo̱o̱ tu̱mgu̱ mbi̱ru̱ ci̱ka puuri a cu̱di̱ geppindi. Bu yo̱o̱ pwi̱yangi̱ ci̱ka co̱o̱gi̱ndi̱ pero to̱k ci̱ka bamori. 
\p  
\v 17 Bu si̱ndi̱ si̱ye̱i̱ ci̱pi̱gi̱ bu̱ri̱, nu̱wa re̱mbi̱ru̱ we̱i̱, ba de̱mbi̱ra laa balu pero ba wacambi̱ra we̱i̱ a gi̱ri̱ndi̱ ku̱ru̱.  
\v 18 Nu̱wa de̱mbi̱ru̱ we̱i̱ gawu̱ri̱ gomnandi yi̱ balamba di̱ngi̱n mi. Anda to̱o̱ yo̱o̱ mbi̱ru̱ we̱i̱ nyinou wu bu wasi̱ri̱ we̱i̱ ci̱ye̱i̱ du teng a dwii mi a bo̱nggo̱ balamba yi̱ nu̱wa bu yaa yo̱o̱gi̱ nu̱wa bu Yudaya wa.  
\v 19 Ka re̱mbi̱ri̱ bo̱nggo̱ balu bu do̱mi̱ ya bu̱ri̱ mi̱n tu bu ce̱ we̱i̱ ca yi̱ kanda ku bu ce̱ wau, ka jo̱ri̱ ye̱i̱ lami̱ Yamba nyi̱i̱mbi̱ri̱ we̱i̱ tu bu ce̱ we̱i̱,  
\v 20 di̱ngi̱n bwii mba bu ce̱gu̱ ci̱ye̱i̱ ne̱ anda twii Bawei Mbaa mbi̱ri̱ a ce̱gu̱ ci̱ye̱i̱ a mi̱ri̱nggi̱ mbi̱ru̱. 
\p  
\v 21 <<Ci̱yate̱ nyi̱i̱ we̱i̱ ci̱ya yo̱ nu̱wa ba jiyo, yi̱to̱ mwa mbaate̱ yi̱ bo̱l yo̱. Kwaraa wunmanu we̱i̱ kwiimba diinu we̱i̱ nu̱wa ba laca pma.>>  
\v 22 Nu̱wa mwa mwa kwaambi̱ri̱ we̱i̱ di̱ngi̱n mi. Anda kana we̱ wu bo̱o̱ gaanggu̱ lam nyanggu̱ ku pungu nyi̱nggu̱ we̱i̱ mi̱rma.  
\v 23 Ka pma turo mbi̱ri̱ di̱na gwe̱i̱ bu cembiro du kanggi̱. N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱ yaa ku bu mati̱ we̱i̱ wo̱ru̱gu̱ go̱ro̱ndi̱ Israila Bo̱l ne̱re̱ baa we̱i̱. 
\p  
\v 24 <<Ne̱re̱ wu ti̱langgu̱ yi̱ru̱ yaa gwali̱ ku̱lu̱m yo̱, ke̱we̱ yaa gwali̱ ne̱re̱ wu gi̱ra yo̱.  
\v 25 Nu̱wa bu ti̱langgu̱ yi̱ri̱ngi̱ wa a daaya ba ni̱nga ci̱ka ku̱lu̱m pmo yi̱to̱ mwa ke̱waa a daaya ba ni̱nga ci̱ka ne̱re̱ wu gi̱ra pmo. Ka nu̱wa yi̱ri̱ ne̱re̱ wu gi̱ra wu laa ki̱n, Baalsabul, gwalanga nu̱wa bu laa wii wa, nu̱wa yi̱ru̱ we̱i̱ pma yi̱ din du gwala do̱o̱! 
\s1 Wu daaya yi gwasa 
\p  
\v 26 <<Bu nu̱u̱ ya gwasi̱ nu̱wai̱. Yaa yi̱ri̱ tu sumgi tu nu̱wa na wumdi, pero yaa yi̱ri̱ tu tukugi tu nu̱wa na so̱ni̱.  
\v 27 Yi̱ri̱ tu n sa mbi̱ru̱ ku̱me̱, bu wasi̱ri̱ we̱i̱ yi̱ nyanggu̱. Pero yi̱ri̱ tu bu se̱wai̱ a twe̱e̱ndi̱ mbi̱ri̱, bu te̱e̱ru̱ we̱i̱ dwii kani.  
\v 28 Bu nu̱u̱ ya gwasi̱ nu̱wa bu ji̱ri̱ bu̱ri̱ wa anda yaa ku puu ji̱gu̱ bawei, waka bu nu̱u̱ gwasi̱ Yambai̱, yo̱ wu puu bwiyanggu mwa mwa bu̱ri̱ yi̱ bawei a pari̱ bwalai.  
\v 29 Nu̱wa yaa cuuri banyi̱li̱ nyan kobo ro̱p ru? Anda yaa banyi̱li̱ su yari̱ si̱ma yaa kem yi̱ so̱mgu̱ Mbaa mbi̱ru̱.  
\v 30 Kana ku̱ri̱ mbi̱ri̱ tu dwii a so̱m ku̱ci̱ ye̱i̱.  
\v 31 Di̱ngi̱n to̱no̱, bu nu̱u̱ ya gwasi̱ di̱ngi̱n bu gwala banyi̱li̱ wang. 
\p  
\v 32 <<Di̱ngi̱n kana we̱ wu ce̱ cu̱du̱ nu̱wa ki̱n yo̱ wongge, mi mwa n ni̱ngi̱ we̱i̱ yi̱to̱ a gawu̱r Mbaa mi wu diyou.  
\v 33 Anda kana we̱ wu gwe̱le̱ngge̱ a gawu̱ri̱ nu̱wai̱, mi mwa n gwe̱lu̱ we̱i̱ yo̱ a gawu̱ri̱ Mbaa mi wu diyou. 
\s1 N de̱e̱ bu pi̱dau̱ gaanggu̱, anda bu̱ri̱ kasi̱gar 
\p  
\v 34 Bu dangani̱ ya mi̱n n baa di̱ngi̱n n de̱e̱ pi̱dau̱ gaanggu̱ a si̱ma. Ang ang, n baa bu n de̱e̱ pi̱dau̱ gaanggu̱, anda n de̱e̱ kasi̱gar.  
\v 35 N baa n din ce̱re̱ 
\q1 <Cu̱du̱ ne̱re̱ yi̱ mbaa yo̱, 
\q2 bwe̱e̱canga yi̱ njaa yo̱, 
\q1 siite wu nu̱re̱, ni̱ng we̱i̱ ce̱re̱ yi̱ sii yo̱ wu nu̱re̱ 
\q2  
\v 36 bace̱n mo̱ wu bwi̱i̱ye̱ yo̱ we̱i̱ a mi̱ri̱nggi̱ laa mau.> 
\p  
\v 37 <<Kana we̱ wu kangman mbaa yo̱ yi̱ njaa yo̱ gwalanggi̱ yaa ku yinno yo̱o̱gu̱ kwaa mi, ka kangman bo̱l yo̱ wu nambare̱ yi̱ wu nu̱re̱ gwalanggi̱ yaa ku yinno ba yo̱o̱ kwaa mi.  
\v 38 Anda kana we̱ wu de̱ bu ye̱u̱ yo̱u̱, ba po̱nggu̱we̱ yinnibu yo̱o̱gu̱ kwaa mi.  
\v 39 Kana we̱ wu nyi̱ngga pi̱i̱ma ya mandu̱ we̱i̱ si̱yau̱, kana we̱ wu mansi̱ ye̱i̱ pi̱i̱ma ya di̱ngi̱n mi nyi̱nggu̱ we̱i̱. 
\s1 Yi̱gu̱ wo̱ri̱ri̱ 
\p  
\v 40 <<Kana we̱ wu yi̱mbi̱ra a yi̱ngge̱, kana we̱ wu yi̱ngge̱ a yi̱ wu tu̱mgu̱we̱.  
\v 41 Kana we̱ wu yi̱ banabi̱, di̱ngi̱n twii banabi̱, yo̱ yi̱ri̱ we̱i̱ wo̱ri̱ri̱ banabi̱. Pero kana we̱ wu yi̱ ne̱re̱ wu nyaa di̱ngi̱n twii ne̱re̱ wu nyaa yi̱ri̱ we̱i̱ wo̱ri̱ri̱ ne̱re̱ wu nyaa.  
\v 42 Kana we̱ wu puu gundu naagu wu wiino wu banyi̱na a mi̱ri̱nggi̱ bu yo̱o̱gi̱ kwati̱mba muwa, n wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱, yi̱ru̱ we̱i̱ wo̱ri̱ri̱ ye̱i̱.>> 
\c 11  
\s1 Yohanna tu̱m nu̱wa bo̱nggo̱ Yesu 
\p  
\v 1 Go̱ro̱ pu Yesu mata nyi̱i̱gu̱ kwati̱mba ya di̱kace̱ne̱, a du po̱o̱ wii a mwati̱ go̱ro̱ndi̱ tu ne̱m a wasi̱gu̱ ci̱ye̱u̱ yi̱ ju̱ku̱gu̱ yi̱ri̱ngi̱. 
\p  
\v 2 Pu Yohanna wo̱o̱ jaru̱m a nu̱u̱ yi̱ri̱ngi̱ tu Masiya ni̱nggu̱, a tu̱m kwati̱mba ya,  
\v 3 ba pi̱ra Yesu ki̱n, <<Wo̱o̱ mo̱ wu bagu̱ wii ru? Yikwii yi yam wu kanggu̱ ru?>> 
\p  
\v 4 Yesu sa pma ki̱n, <<Bu waatanga bu sa Yohanna yi̱ri̱ngi̱ tu bu nu̱u̱ wai yi̱ yi̱ri̱ngi̱ tu bu ko̱i̱,  
\v 5 kerma bo̱o̱ ko̱gu̱ si̱mau̱, gu̱wo̱ngi̱ bo̱o̱ ni̱nggu̱ so̱ngmau̱, babutanga bo̱o̱ yi̱langgu̱, bapi̱mba bo̱o̱ nu̱u̱gu̱ si̱mau̱, nu̱wa bu bwaanggi̱ wa a wunonggu yi̱ pi̱i̱ma, pero nu̱wa bo̱o̱ wasi̱man ci̱ye̱i̱ du teng baku̱u̱lu̱wa.  
\v 6 Yamba diiman wuure pma bu waatan bu yi̱ go̱ro̱u̱ di̱ngi̱n mi wa.>> 
\p  
\v 7 Pu kwati̱mba Yohanna wa mwatanga, Yesu toso sagu̱ ci̱ye̱i̱ nu̱wa bu ku̱ranggi̱ bu̱ri̱ wa a dwii Yohanna, <<Bu ambi̱ra su̱gu̱ ca a gu̱lai̱? Bu ambi̱ra su̱gu̱ si̱yang tu co̱ku̱ro̱k tu wutur mwangu ru?  
\v 8 Ka yaa yi̱to̱ ne̱ bu twiyongo bu ko̱ ca ki̱? Ne̱re̱ wu pargi̱ se̱e̱ wu nyaa ru? Yaa yi̱to̱ nu̱wa bu pari̱ se̱e̱ wu nyaa bo̱o̱ caame̱ balambai.  
\v 9 Mi̱n na, bu twiyongo bu ambi̱ra su̱gu̱ cau? Banabi̱ ru? N wo̱o̱ sagu̱mbi̱ru̱, yo̱ a gwala banabi̱.  
\v 10 Wunaa yo̱ Yohanna wu Lakargar Yamba ce̱ ci̱ye̱i̱ dwii ye̱i̱ ki̱n, 
\q1 <N tu̱mmo̱ we̱i̱ ne̱re̱ tu̱mandi̱ mi gawu̱ri̱yo̱ yi̱ mo̱, 
\q2 wii yo̱ cardu we̱i̱ nyinou di̱ngi̱n bagu̱ mo̱u̱.> 
\m  
\v 11 N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱ a mi̱ri̱nggu̱ nu̱wa bu nu̱ru̱mba bi pma wa, yaa wu gwala Yohanna wu Ni̱ng Bati̱si̱ma yi̱ gi̱ru̱. Anda wu banyi̱na a lau̱ ku diyou Yambau̱ a gwala Yohanna yi̱ gi̱ru̱.  
\v 12 Toso jo̱r du Yohanna wu Ni̱ng Bati̱si̱ma wasi̱ ci̱ye̱i̱, baa di̱na jo̱re̱ lau̱ ku diyou a ti̱i̱ ku̱u̱le̱, nu̱wa bu bwi̱i̱ wa kasa ba je̱e̱ yi̱ di̱mbi̱re̱.  
\v 13 Mwa mwa banabi̱ndi̱ yi̱ te̱e̱ri̱ngi̱ Musa a ce̱ ci̱ye̱i̱ dwii lau̱ ku diyou ko̱po̱ jo̱r Yohanna,  
\v 14 ka bu kasi̱ bu yi̱ ci̱ye̱i̱ dwii we̱i̱, Yohanna wo̱o̱ Iliya, wu banabi̱ndi̱ ce̱ bagu̱ yo̱u̱.  
\v 15 Yama ne̱re̱ wii twendi di̱ngi̱n nu̱u̱gu̱, ba ka twiyau. 
\p  
\v 16 Anda Yesu je̱ gawu̱re̱ yi̱ ci̱ye̱i̱ ki̱n, <<N ci̱pi̱ranu̱ we̱i̱ nu̱wa bu si̱na daandi yi̱ ca? Pma ci̱ka bakwara pi̱si̱ndi̱ nyan lummou. A yi̱yanggu̱ bu̱ri̱ pmai a ce̱gu̱ ki̱n, 
\q1  
\v 17 <Yi wuu mbi̱ri̱ bagaati, bu kwa sigu ko̱lo̱u̱! 
\q2 Yi pi̱i̱ mbi̱ri̱ pi̱i̱ bo̱o̱ri̱, bu kwaa wiye.> 
\m  
\v 18 Pu Yohanna baa yaa je̱e̱ je̱e̱ndi̱, yaa naa gundu inabi, anda bu ce̱gu̱ mi̱n, yo̱ wo̱o̱ yi̱ wuture.  
\v 19 Bo̱l Ne̱re̱ a ba a je̱gu̱ a naagu, bu ce̱gu̱ mi̱n, <Su̱wa yo̱ wo̱o̱ yi̱ swawu a je̱gu̱, a naagu, yo̱ yo̱o̱gi̱ basi̱n nu̱wa bu yi̱ri̱ janggal wa, yi̱ nu̱wa bu yi̱ we̱le̱m wa.> Anda pwi̱i̱ Yambai̱ ju̱ku̱r ki̱n twii ji̱re̱ a bo̱nggo̱ wu̱rang ye̱i̱. 
\s1 Gwe̱i̱ du kwaa le̱e̱gu̱ ji̱re̱u̱ 
\p  
\v 20 Nu̱wa bu go̱ro̱ndi̱ tu Yesu ni̱nga yi̱ri̱ngi̱ ri̱yandi̱ bu̱ri̱ tum dwii yaa ku ni̱nga bwiiwau, di̱ngi̱n to̱no̱ a ye̱re̱nga gwe̱i̱ dwii.  
\v 21 <<Ai mba! Nu̱wa bu Korasin. Ai mba! Nu̱wa bu Betsaida! Di̱ngi̱n wu̱rang ri̱yandi̱ bu̱ri̱ tu nu̱wa ni̱nga a mi̱ri̱nggi̱ mbi̱ri̱, ka nu̱wa na ni̱nga a Taya yi̱ Sidon we̱i̱, pma na ni̱nga bwiiwa ki̱lang, na te̱e̱ gusuringi pero na parni̱ buro dwii pmai!  
\v 22 N wo̱o̱ sagu̱mbi̱ru̱, a nyanggu̱ balu, Yamba nu̱u̱ we̱i̱ bunam nu̱wa bu Taya yi̱ Sidon yiku ba nu̱u̱ bunam mbi̱ru̱.  
\v 23 Bi̱ka nu̱wa bu Kaparnahum, bu dangani̱ mi̱n nu̱wa de̱mbi̱ri̱ we̱i̱ diyou ru? Kana banyi̱na, waka nu̱wa julumbiri we̱i̱ Hades!\f + \fr 11:23 \ft Hades pwii pu nu̱wa bu bwaanggi̱ wa si̱i̱ mi̱ru̱\f* Ka yi̱ri̱ngi̱ ri̱yandi̱ bu̱ri̱ tu nu̱wa ni̱ngai̱ a bo̱nggo̱ mo̱, ka na ni̱ngwa Sodom wai, reni pma na bo̱o̱!  
\v 24 N wo̱o̱ sagu̱mbi̱ru̱ a nyanggu̱ balu, Yamba nu̱u̱ we̱i̱ bunam gwe̱i̱ Sodom yiku ba nu̱u̱ bunam mbi̱ru̱. 
\s1 Bambe̱ bo̱nggo̱ mu bu yo̱ro̱nga 
\p  
\v 25 A dwii jo̱re̱ Yesu ce̱ ku̱ru̱ ki̱n, <<Mbaa, mo̱ Mbaa Wu Gi̱ra wu yi̱ diyou yi̱ si̱ma, n wanami̱na, di̱ngi̱n mo̱ tuko ti̱na yi̱ri̱ngi̱ a bo̱nggo̱ pma bu pwi̱yanggi̱ wa yi̱ bu yi̱ so̱mandi̱, anda mo̱ ju̱ku̱ bakwara bu nyi̱ti̱ti̱ wa.  
\v 26 Yi̱to̱ Mbaa, to̱o̱ yi̱ri̱ngi̱ ni̱ngwa ci̱ka ku̱ mo̱ kasu̱. 
\p  
\v 27 Mbaa mi nyi̱i̱nggi̱ yi̱ri̱ngi̱ mwa mwa. Yaa ne̱re̱ wu so̱m Bwi̱ya wii bu̱r Mbaate̱, pero yaa wu so̱m Mbaate̱ bu̱r Bwi̱ya wii yi̱ bu Bwi̱ya wii kasa ba ju̱ku̱ pma Mbaa yo̱. 
\p  
\v 28 <<Bambe̱ bo̱nggo̱ mu, mba bu janganga pero de̱e̱gi̱ se̱e̱ ko̱mbu̱ro̱m wa, n nyi̱i̱ mbi̱r we̱i̱ yo̱ro̱nggu̱.  
\v 29 Bu de̱e̱ sou garama mu pero bu ti̱langa bo̱nggo̱ mu di̱ngi̱n n bu̱bu̱k yi̱ dwii du ci̱nggai̱, pero bu nyi̱nggu̱ we̱i̱ yo̱ro̱nggu̱ bo̱nggo̱ bawei.  
\v 30 Di̱ngi̱n sou garama mu yaa ko̱mbu̱ro̱m, se̱e̱ wu n ce̱ri̱ mbi̱ri̱ we̱i̱ saki̱rak.>> 
\c 12  
\s1 Pi̱ra dwii nyanggu̱ sabadu 
\p  
\v 1 A dwii jo̱re̱ Yesu so̱ngma a ko̱o̱ndi̱ alkama nyanggu̱ sabadu, kwati̱mba ya nu̱u̱ ju̱ne̱ pma co̱ra alkama a woo.  
\v 2 Ku Parisayo ko̱, pma sa Yesu ki̱n, <<Su̱wa! Kwati̱mba ma ni̱nggu̱ yi̱ri̱ tu te̱e̱ri̱ yiri je̱e̱ ki̱n nu̱wa ba ni̱ng ya nyanggu̱ sabadu!>> 
\p  
\v 3 A le̱e̱man pma ki̱n, <<Celeke bu tii bu ce̱gu̱ yi̱ri̱ tu Dawud ni̱nga pu yo̱ nu̱u̱ ju̱ne̱ yi̱ basi̱nba so̱ngma ya wa ru?  
\v 4 Yo̱ diiro Laa Yambau̱, yo̱ yi̱ barauwa ya pma je̱e̱ ku̱maa wu co̱o̱gi̱, kana ku te̱e̱re̱ je̱u̱ pma ba je̱e̱ ya, bu̱r kuruwa Yamba wa ba je̱e̱.  
\v 5 Pero yaa ku bu tii bu ce̱gu̱ mi̱ri̱nggi̱ te̱e̱re̱ Musa ki̱n kuruwa Yamba wa pma pari̱ te̱e̱re̱ a laa Yambau̱ nyanggu̱ sabadu anda kana yi̱to̱ pma yaa we̱le̱m.  
\v 6 N wo̱o̱ sagu̱mbi̱ru̱ wo̱o̱ yi̱ wu kangge̱ a pi̱na wu gwala Laa Yambau̱ yi̱ gi̱ru̱.  
\v 7 Lakargar Yamba ce̱ ki̱n, <Tu n kasi̱ twii nu̱wa ba ju̱ki̱ bunam, twii nyi̱i̱gu̱ ni̱i̱ ne̱,> ka bu so̱m to̱o̱ yi̱ri̱ngi̱ yaa ku bu ni̱ngamanu̱ we̱i̱ nu̱wa bali̱ mi̱n yi̱ we̱le̱m anda yaa we̱le̱m.  
\v 8 Di̱ngi̱n Bo̱l Ne̱re̱ twii Mbaa Wu Gi̱ra nyanggu̱ sabadu.>> 
\s1 Yesu mi̱ra ne̱re̱ wu wai bo̱rgi̱ nyanggu̱ sabadu 
\p  
\v 9 Pu Yesu du po̱o̱ wii, a aara diiro gi̱re̱ng ku̱ru̱ pma,  
\v 10 wo̱o̱ yi̱ ne̱re̱ wu wai bo̱rgi̱ pwii. Pma dwaagu ba nyi̱ngga yo̱ yi̱ we̱le̱m. Pma pi̱ra yo̱ ki̱n, <<Te̱e̱re̱ yiri je̱e̱ nu̱wa ba mi̱ri̱ ya ne̱re̱ nyanggu̱ Sabadu ru?>> 
\p  
\v 11 Anda a le̱e̱ man pma ki̱n, <<Yikwii wii we̱ a cu̱du̱ mbi̱ri̱ ka puuri yo̱ yanni̱ bo̱u̱ nyanggu̱ sabadu na taa ba yiki we̱?  
\v 12 Anda ne̱re̱ gwala bu puure kwaara ru? O̱ng te̱e̱re̱ le̱e̱ ne̱re̱ ba ni̱nga yi̱ri̱ngi̱ tu nyaayi nyanggu̱ sabadu.>> 
\p  
\v 13 Bur a sa ne̱re̱ wii ki̱n, <<Tari̱ wai mo̱u̱.>> Ne̱re̱ wii tari̱ wai yo̱u̱, bur wai yo̱u̱ waata bu̱ri̱ cingcing ci̱ka wu kanggu̱ wii!  
\v 14 Anda Parisayo a twiyongo twalange̱ palaka ba kasa nyindi su pmai jiru we̱i̱ Yesu. 
\s1 Yesu ke̱we̱ wu Yamba se̱ka 
\p  
\v 15 Yesu so̱m tu pma kasi̱gu̱ ni̱nggi̱. Di̱ngi̱n to̱no̱ a du po̱o̱ wii, nu̱wa tum po̱ng yo̱. A mi̱ra pma bu yaa cingcing wa mwa mwa, pma yi̱langa.  
\v 16 A nyi̱i̱ pma di̱kace̱ne̱ ki̱n, ba ce̱ ya ka yo̱ we̱ we̱i̱.  
\v 17 To̱o̱ a twanga yi̱ri̱ tu banabi̱ Icaya ce̱ a dwii ye̱i̱ ki̱n, 
\q1  
\v 18 <<Su̱wa ke̱we̱ mi wu n se̱ka. 
\q2 Wii yo̱ wu n kangman yo̱, 
\q2 wu di̱rangi̱n gaanggu̱. 
\q1 N diinu we̱i̱ Bawei mi a mi̱ri̱nggi̱ ye̱i̱, 
\q2 anda yo̱ sar we̱i̱ ji̱re̱ nu̱wa bu si̱ma wa. 
\q1  
\v 19 Yaa ku ni̱ngu̱ we̱i̱ gwe̱la 
\q2 kana ba wun miu yo̱u̱ a nyindi. 
\q1  
\v 20 Yaa ku pe̱nu̱ we̱i̱ bu yaa cingcing wa, 
\q2 kana ba nu̱u̱ bu̱u̱ nu̱wa bu yaa di̱mbi̱re̱ wa, 
\q1 ko̱po̱ ka diini ji̱re̱i̱ je̱ gawu̱re̱. 
\q1  
\v 21 Anda mi̱ri̱nggi̱ din ye̱i̱ nu̱wa bu si̱ma wa mannu̱ we̱i̱ ni̱i̱. 
\s1 Yesu yi̱ Baalsabul 
\p  
\v 22 A dwii jo̱re̱ pma de̱mu̱we̱ Yesu ne̱re̱ wu kangge̱ wu yi̱ wuturindi twii kermo pero yaa ce̱ ci̱ye̱i̱. Yesu mi̱ra ne̱re̱ wii palaka ba ko̱ pero ba nu̱u̱ si̱ma.  
\v 23 Nu̱wa bwii riyanga bu̱ri̱ a pi̱ra ki̱n, <<Yikwii wo̱o̱ Yesu Bo̱l Dawud ru?>> 
\p  
\v 24 Anda ku Parisayo nu̱wa yi̱to̱ pma ce̱ ki̱n, <<Mwe̱le̱, ne̱re̱ wo̱, wo̱o̱ Baalsabul ti̱bak, bagi̱ra wuturindi, a nyi̱i̱ yo̱ di̱mbi̱re̱ ba yiki wuturindi.>> 
\p  
\v 25 Anda Yesu ku̱ranga dangandi̱ pmai, yo̱ sa pma ki̱n, <<Kana ko̱no̱ lau̱ ku̱ cwaanga bu̱ri̱ ro̱p bagu̱ ce̱re̱ yi̱ bu̱ri̱ pmai, ko̱ lau̱ bwi̱i̱ru̱ we̱i̱, yi̱to̱ mwa yi̱ kana do̱no̱ gwe̱i̱ kana laa ka cwaani bu̱ri̱ bagu̱ ce̱re̱ yi̱ bu̱ri̱ pmai wo̱ laa na ti̱n ti̱ye̱i̱.  
\v 26 Anda ka Balaa Buwai yikir Balaa Buwai, a cwaanga bu̱ri̱ ye̱i̱, a bagu̱ ce̱re̱ yi̱ dwii ye̱i̱. Lau̱ yo̱u̱ ni̱ng we̱i̱ nye̱ ba ti̱n ti̱yau̱?  
\v 27 Ka n yikigu wuturindi yi̱ di̱mbi̱re̱ Baalsabul we̱i̱, nu̱wa mba re̱i̱? Pma yikiri yi̱ di̱mbi̱r we̱? Di̱ngi̱n to̱no̱, pma ni̱ngi̱ mbi̱ru̱ we̱i̱ bali̱.  
\v 28 Anda ka n yikiri wuturindi yi̱ di̱mbi̱ri̱ Bawei Yamba wai, lau̱ Yambau̱ baa dwii mbi̱ri̱.  
\v 29 Bang bang, yaa ne̱ru̱ wu puu we̱i̱ dimma laa ne̱re̱ wu yi̱ di̱mbi̱re̱ ba de̱e̱ se̱e̱ yo̱, ko̱po̱ ka twali ne̱ru̱ wu di̱mbi̱r wii bati̱, anda ba puu de̱gu̱ se̱e̱ yo̱. 
\p  
\v 30 Ne̱re̱ wu yaa kem yi̱ mi, yo̱ bagu̱ ce̱re̱ yi̱ mi, ne̱re̱ wu kalanggu̱ bu ku̱ranggu̱, yo̱ we̱e̱nggu̱ si̱yau̱.  
\v 31 <<Di̱ngi̱n to̱no̱ n sagu̱mbi̱ru̱, Yamba paramanu we̱i̱ sukom we̱le̱mdi̱ nu̱wa yi̱ kana ca tu bwi̱i̱ tu pma ce̱ we̱i̱, anda kana we̱ wu ce̱ ci̱ye̱i̱ du bwi̱i̱ a dwii Bawei du Walwal, Yamba na paraman yo̱ sukom we̱le̱m yo̱u̱.  
\v 32 Kana we̱ wu ce̱ ci̱ye̱i̱ du bwi̱i̱ a dwii Bo̱l Ne̱re̱ Yamba paramanu we̱i̱ yo̱ sukom we̱le̱m yo̱u̱, anda kana we̱ wu ce̱ ci̱ye̱i̱ du bwi̱i̱ a dwii Bawei du Walwal Yamba na paraman yo̱ sukom we̱le̱m yo̱u̱, kana si̱na daandi kana daandi su baai̱. 
\p  
\v 33 <<Nu̱wa ku̱ran sou bo̱nggo̱ tutwiyari ye̱i̱. Ka sou kundi tutwiyari ye̱i̱ ni̱ngu̱ we̱i̱ kundi. Ka sou yaa kundi ne̱, tutwiyari ye̱i̱ na ni̱ngi̱ kundi.  
\v 34 Mba co̱o̱gi̱ndi̱ su bwi̱i̱! Ni̱ndu̱ we̱i̱ nye̱ nu̱wa bu bwi̱i̱wa ci̱ka mba ba ce̱ tu kundi? Yi̱ri̱ng tu ne̱re̱ ci̱ye̱i̱ twiiwei mi̱ri̱nggu̱ gaanggu̱ yo̱u̱.  
\v 35 Ne̱re̱ wu nyaa ni̱ng wu̱rang tu nyaayi, di̱ngi̱n wu̱rang tu nyaayi twiiwei mi̱ri̱nggu̱ gaanggu̱ yo̱u̱. Ne̱re̱ wu bwi̱i̱ye̱ ni̱ng wu̱rang tu bwi̱i̱, di̱ngi̱n wu̱rang tu bwi̱i̱ twiiwei mi̱ri̱nggu̱ gaanggu̱ yo̱u̱ ku̱ bwi̱u̱.  
\v 36 Anda n wo̱o̱ sagu̱mbi̱ru̱, a nyanggu̱ balu nu̱wa nyi̱i̱ we̱i̱ le̱e̱ a dwii kana do̱no̱ ci̱ye̱i̱ du nyoi du pma ce̱i̱.  
\v 37 Di̱ngi̱n go̱n ci̱ye̱i̱ du bu ce̱i̱ pe̱ra mbi̱r we̱i̱ bo̱nggo̱ bali̱ pero twala mbi̱r we̱i̱ bo̱nggo̱ balu.>> 
\s1 Somdi Yunana 
\p  
\v 38 Nyanggu̱ ku kanggu̱ ku̱lu̱mba te̱e̱ri̱ngi̱ wa yi̱ Parisayo pma baanga bo̱nggo̱ Yesu a ce̱ ki̱n, <<Ku̱lu̱me̱, yi kasi̱ ma ju̱ku̱ yir somdi yi̱ri̱ ri̱yandi̱ bu̱ri̱.>> 
\p  
\v 39 Yesu nyi̱i̱ pma le̱e̱ ki̱n, <<Mba nu̱wa bu bwi̱i̱ wa bu si̱naa daandi wa, bu yaa gwasi̱ Yamba wa, bu kasi̱ yi̱ri̱ somdi ri̱yandi̱ bu̱ri̱, yaa ku n ni̱ngambi̱ri̱ somdi ri̱yandi̱ bu̱ri̱ ka gwal tu banabi̱ Yunana.  
\v 40 Di̱ngi̱n ci̱ka ku Yunana wo̱o̱ pwii jingne wu dudu yo̱ nyan daa kunong yi̱ ku̱m kunong, yi̱to̱ Bo̱l Ne̱re̱ ni̱ngu̱ we̱i̱ daa kunong mi̱ri̱nggu̱ si̱ma nyanggu̱ yi̱ ku̱me̱. 
\p  
\v 41 Nu̱wa bu Ninebe wa baa ti̱ndi̱ ti̱yandi̱ kem yi̱ mba nu̱wa bu si̱na daandi wa a nyanggu̱ ku̱ Yamba ni̱ngamanu̱ we̱i̱ bali̱ nu̱wa, pma sambi̱ri̱ we̱i̱ ki̱n be̱e̱ we̱le̱m, di̱ngi̱n pma ni̱nga bwiiwa a jo̱r du Yunana wasi̱man pma ci̱ye̱i̱ Yambai̱, ne̱re̱ wu gwala Yunana wo̱o̱ pi̱na.  
\v 42 Balaa wu nu̱re̱ wu si̱ma bu taadi wa, ba ti̱ro̱ ti̱ye̱i̱ kem yi̱ mba nu̱wa bu si̱na daandi a nyanggu̱ ku̱ Yamba ni̱ngamanu̱ we̱i̱ bali̱ nu̱wa, yo̱ sambi̱ri̱ we̱i̱ ki̱n be̱e̱ we̱le̱m, di̱ngi̱n yo̱ du̱we̱ si̱ma ya kwaara di̱ngi̱n ba baa nu̱u̱ pwi̱i̱ Balaa Solomon, anda ne̱re̱ wu gwala Solomon wo̱o̱ pi̱na. 
\p  
\v 43 <<Ka wutur twii bu̱ri̱ ne̱ri̱, mwatir pu yaa gundu a kasanggu̱ pu yo̱ro̱nu̱. Ka yo̱ ki̱ngga bu ne̱,  
\v 44 yo̱ ba ce̱ ki̱n, <N waatu we̱i̱ bu̱ri̱ a laa mu wu n twiiwe mi̱ru̱.> Ka baa ki̱nggi̱ laa wii candi̱gi̱, pero me̱ne̱ngi̱ yaa tu kanggi̱,  
\v 45 bur yo̱ ba waata ba de̱ kapi̱na wuturindi a nibiyo su gwala yo̱ yi̱ tu̱we̱ baa ba si̱ndi̱ si̱yau̱ a pwii. Cwata go̱ro̱ yo̱u̱, pi̱su̱ ne̱re̱ wii gwalu we̱i̱ pi̱su̱ yo̱u̱ wu gawu̱ri̱yo̱ yi̱ bwi̱i̱ge̱. Ti̱naa kanda ku ni̱ndi̱ we̱i̱ yi̱ pma nu̱wa bu bwi̱i̱wa bu si̱na daandi wa.>> 
\s1 Njaa Yesu yi̱ ci̱yamba ya 
\p  
\v 46 Pu Yesu wo̱o̱ ce̱gu̱ ci̱ye̱i̱ yi̱ nu̱wa tum njaa yo̱ yi̱ ci̱yamba ya bo̱o̱ pi̱ti̱ndi̱ twalange̱, kasi̱ ba sa ci̱ye̱i̱.  
\v 47 Wu kangge̱ cu̱du̱ pmai sa Yesu ki̱n <<Njaa mo̱ yi̱ ci̱yamba ma bo̱o̱ pi̱ti̱ndi̱ twalange̱ kasi̱gu̱ ba ce̱ ci̱ye̱i̱ yi̱ mo̱.>> 
\p  
\v 48 Yesu pi̱ra ki̱n, <<Njaa mi wii we̱? Ci̱yamba muwa bwii bu we̱?  
\v 49 Bur a juka kwati̱mba ya a ce̱ ki̱n, <<Bu su̱wa ti̱na njaa mi yi̱ ci̱yamba muwa.  
\v 50 Kana we̱ wu tu̱m dangandi̱ Mbaa mi wu diyou twii ci̱ya mi wu nu̱re̱ yi̱ wu nambare̱ yi̱ njaa mi!>> 
\c 13  
\s1 Balanggu̱ ce̱u̱ a dwii bajo̱me̱ wu waci̱ duu 
\p  
\v 1 A nyanggu̱ kwii Yesu duu laa wii a mwati̱ a si̱n si̱yau̱ gi̱ng kali̱nggu̱.  
\v 2 Nu̱wa tum ku̱ranga bu̱ri̱ bo̱nggo̱ yo̱u̱, di̱ngi̱n to̱no̱ a geero konggoru, a si̱n si̱yau̱ pwii. Nu̱wa pma ka pi̱ti̱ndi̱ gi̱ngu̱.  
\v 3 A sa pma yi̱ri̱ngi̱ tum yi̱ balanggu̱ ci̱ye̱u̱ ki̱n, <<Bu ka twiyau! Ne̱re̱ wu kangge̱ a de̱ duu aara waci̱gu̱ ko̱ndo̱ yo̱u̱.  
\v 4 Pu wo̱o̱ waci̱gu̱ duu kwii, go̱ma bu kangga yaramana dwii nyinou, yidi baa kwama.  
\v 5 Bu kangga yaramana pu yi̱ swari̱ngi̱, pu yi̱ swai banyi̱na. A boro ki̱lang ki̱lang di̱ngi̱n swai dwii yaa tum.  
\v 6 Anda pu nyanggu̱ biya a ku̱su̱wa di̱ngi̱n yaa swandi.  
\v 7 Go̱ma bu kangga yaramana pu yi̱ tu̱ri̱, tu̱ri̱ twii gi̱ra, a ki̱canga pma.  
\v 8 Go̱ma bu kangga do̱ng yaramana si̱ma bu nyaa wa, a biyo a gwala tu nu̱wa waci̱ daa kuno kunong yi̱ kun no̱ko̱no̱, yi̱ wo̱o̱n wo̱o̱n.  
\v 9 Yama ne̱re̱ wii twendi di̱ngi̱n nu̱u̱gu̱, ba ka twiyau.>> 
\p  
\v 10 Kwati̱mba ya baanga pi̱ra yo̱ ki̱n, <<Di̱ngi̱n ca ma ce̱e̱ ci̱ye̱i̱ yi̱ balanggu̱ ci̱ye̱u̱ ka ma pi̱rgu̱ yi̱ri̱ nu̱wa?>> 
\p  
\v 11 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Mba, Yamba le̱e̱mbi̱ra, bu so̱m tu tukugi tu lau̱ ku diyou, anda bu kangga yaa yi̱to̱.  
\v 12 Kana we̱ wu wo̱o̱ yi̱ to̱no̱ nu̱wa cwatamanu we̱i̱ yo̱ ba ni̱nga tum. Kana we̱ wu yaa yi̱ri̱ do̱ng, kana tu wo̱o̱ yi̱ to̱no̱i̱ nu̱wa yi̱yamanu̱ we̱i̱ yo̱.  
\v 13 To̱o̱ tu diinai n ni̱ndi̱ wu̱rai̱ yi̱ ci̱ye̱i̱ du balanggai̱, 
\q1 Di̱ngi̱n pma su̱wi̱, anda pma yaa kwe̱e̱yi̱. 
\q2 Pma nu̱wi̱, anda yaa kar twiyau kana ba ku̱ranga. 
\m  
\v 14 A twanga tu banabi̱ Icaya ce̱ a dwii pma ki̱n, 
\q1 Bu ni̱ng we̱i̱ pu nu̱u̱gu̱ anda bu ku̱rani̱, 
\q2 Bu ni̱ng we̱i̱ pu su̱u̱gu̱ anda bu kwe̱i̱. 
\q1  
\v 15 Di̱ngi̱n nu̱wa bo̱o̱ gaanggi̱ri̱ pmai cingcing 
\q2 pero twendi pmai yaa nu̱u̱ si̱ma, 
\q2 pma lakanga nundu pmai. 
\q1 Ka yi̱to̱ ne̱ pma kwe̱e̱ we̱i̱ si̱ma yi̱ nundi pmai, 
\q2 pero nu̱u̱ we̱i̱ si̱ma yi̱ twendi pmai, 
\q2 ba ku̱ranga yi̱ gaanggi̱ri̱ pmai, 
\q1 ba waatanga bo̱nggo̱ mu 
\q2 palaka n mi̱ra pma.> 
\p  
\v 16 <<Anda wuure bo̱nggo̱ nundi mbi̱ri̱ di̱ngi̱n bu kwe̱e̱yi̱ pero twendi mbi̱ri̱ nu̱u̱wi̱.  
\v 17 N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱i̱, banabi̱ndi̱ tum yi̱ nu̱wa bu nyaa wa tum kasa ko̱gu̱ yi̱ri̱ngi̱ tu bu ko̱gu̱ ti̱na anda pma ko̱ bu, a kasa pmai nu̱u̱ yi̱ri̱ngi̱ tu bu nu̱u̱gu̱, anda pma nu̱u̱ bu. 
\p  
\v 18 <<Yo̱ko̱ bu ka twiyau pi̱ti̱ndi̱ ci̱ye̱i̱ du balanggai̱ dwii bajo̱o̱me̱ a pi̱gu̱ yi̱ru̱.  
\v 19 Go̱ma bu yaramana a nyinou wa twii nu̱wa bu nu̱u̱ ci̱ye̱i̱ lau̱ diyou anda yaa ku ku̱rangau̱ . Bur Balaa Buwai ba a yi̱yaman si̱ye̱i̱ a mi̱ri̱nggi̱ gaanggu̱ pma.  
\v 20 Go̱ma bu dwii swari̱ngi̱ wa twii nu̱wa bu nu̱u̱ ci̱ye̱i̱ dwii, a yi̱ya yo̱ko̱ yo̱ko̱ yi̱ bu̱ri̱ de̱gde̱g.  
\v 21 Anda yake̱ ku yaa swandi ko̱, yaa ku si̱ya wang. Pu ku̱u̱lu̱ yi̱ cu̱su̱gu̱ bammanu̱we̱ pma di̱ngi̱n ci̱ye̱i̱ dwii, yo̱ko̱ yo̱ko̱ pma ba yaranga.  
\v 22 Go̱ma bu yaramana mi̱ri̱nggi̱ tu̱ri̱ wa twii nu̱wa bu nu̱u̱ ci̱ye̱i̱ Yambai̱, anda dangandi̱ se̱e̱ wu si̱ma yi̱ gi̱na a we̱le̱nga, a gwala di̱mbi̱ri̱ ci̱ye̱i̱ dwii a ja ni̱nggu̱ go̱mau̱.  
\v 23 Go̱ma bu yaramana swai du nyaayi twii nu̱wa bu nu̱u̱ ci̱ye̱i̱ Yambai̱ a ku̱ranga. Wii wu bi go̱ma kuno kunong yi̱ kun no̱ko̱no̱, yi̱ wo̱o̱ndi̱ a gwala ku nu̱wa pi̱yau̱!>> 
\s1 Ci̱ye̱i̱ du balanggai̱ a dwii alkama yi̱ ku̱le̱ 
\p  
\v 24 Yesu nyi̱i̱ balanggu̱ ci̱ye̱u̱ ku kanggu̱ ki̱n, <<Lau̱ ku diyou ci̱ka bajo̱me̱ wu pi̱i̱ duu ku nyaau a ko̱ndo̱u̱ yo̱u̱.  
\v 25 Anda ku nu̱wa bo̱o̱ diima yi̱ ku̱me̱, bace̱n yo̱ ba pi̱i̱ ku̱le̱ a mi̱ri̱nggi̱ alkama wii a li̱ya mwati̱.  
\v 26 Pu gi̱ra̱u̱ a te̱e̱n go̱ma, ku̱le̱ dwii mwaasi̱ a twiyo. 
\p  
\v 27 Ke̱waa ne̱re̱ wu ko̱ndo̱u̱ we̱ yo̱u̱ anda sa yo̱ ki̱n, <Ne̱re̱ wu gi̱ra, tu ma pi̱ya twii duu ku nyaau ne̱ ru? Anda na ku̱le̱ wuna twiiwe pi̱yau̱?> 
\p  
\v 28 <<Bajo̱me̱ wii ce̱ ki̱n, <Twii bace̱nte̱ ni̱nga yi̱to̱!> Pma ce̱ ki̱n, <Yi aanda yi podo ru?> 
\p  
\v 29 A sa pma ki̱n, <Ka bu ni̱ngi̱ yi̱to̱, bu podo we̱i̱ alkama.  
\v 30 Bu du pma ba gi̱ranga kem ko̱po̱ nyanggu̱ kaci̱gi̱. N saru we̱i̱ nu̱wa wu̱rai̱ wa a jo̱r kaci̱gi̱ dwii pma ba se̱ka ku̱le̱ wii, ba bwe̱e̱nga gwe̱le̱ndi̱ gwe̱le̱ndi̱ ba taa, ba te̱e̱ni̱ alkama mi a bindou.>>> 
\s1 Ci̱ye̱i̱ du balanggai̱ a dwii go̱n mustad 
\p  
\v 31 Pero Yesu sa pma balanggu̱ ce̱u̱ du kanggu̱ ki̱n, <<Lau̱ ku diyou ci̱ka go̱n mustad du ne̱re̱ wu kangge̱ de̱ aara pi̱ya a ko̱ndo̱u̱ yo̱u̱.  
\v 32 Kana ku to̱o̱ go̱n duu du banyi̱nai̱ a mi̱ri̱nggi̱ duu mwa mwa, anda ka gi̱ri̱ gwali̱ kana ko̱no̱ duu wandi̱ ali̱, pero ba yo̱o̱ sou. Yidi baangai̱ ba cwaani cwaaringi pmai a be̱ti̱ndi̱ ye̱i̱.>> 
\s1 Ci̱ye̱i̱ du balanggai̱ a dwii yisti 
\p  
\v 33 Yesu pero sagu̱ pma balanggu̱ ce̱u̱ du kanggu̱ ki̱n, <<Lau̱ ku diyou ci̱ka yisti wu nu̱re̱ wu kangge̱ de̱e̱ tuura yi̱ lemine kunong ku miima alkama wa, miima bwii mwa mwa yo̱o̱ yisti.>> 
\p  
\v 34 Yesu ni̱ng wu̱rai̱ yi̱ balanggi̱ ci̱ye̱i̱, pu sagu̱ mwa mwa to̱o̱ yi̱ri̱ngi̱ nu̱wa bu tum bwii. Manggu yaa sar pma ci̱ye̱i̱ ko̱po̱ yi̱ balanggu̱ ci̱ye̱u̱.  
\v 35 A twanga tu banabi̱ ci̱ye̱i̱ ki̱n: 
\q1 <<N sa mbi̱ru̱ we̱i̱ ci̱ye̱i̱ yi̱ ci̱ye̱i̱ du balanggai̱. 
\q2 N ye̱sa mbi̱ru̱ we̱i̱ yi̱ri̱ngi̱ tu tukugai yake̱ toson taa ruugu si̱mau̱. 
\s1 Pi̱ti̱ndi̱ ci̱ye̱i̱ du balanggai̱ a dwii alkama yi̱ ku̱le̱ 
\p  
\v 36 Bur Yesu du nu̱wa twalange̱, a diiro laa wii. Kwati̱mba ya baanga bo̱nggo̱ yo̱ pma ce̱ ki̱n, <<Kam kam sa yir pi̱ti̱ndi̱ balanggi̱ ci̱ye̱i̱ a dwii ku̱le̱ du ko̱ndo̱u̱ dwii.>> 
\p  
\v 37 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Bo̱l Ne̱re̱ twii bajo̱me̱, wu pi̱i̱ duu ku nyaa kwii.  
\v 38 Ko̱ndo̱u̱ twii si̱ma, mwa mwa, pero duu ku nyaau kwii twii nu̱wa bu lau̱ ku diyou wa. Ku̱le̱ wii, twii kwaraa Balaa Buwai.  
\v 39 Bace̱nte̱ wu pi̱i̱ ku̱le̱ mi̱ri̱nggi̱ alkama wii Balaa Buwai. Nyanggu̱ kaci̱gu̱ twii nyanggu̱ ku cwata go̱ro̱u̱, nu̱wa bu kacu̱gu̱ wa twii bacamandi. 
\p  
\v 40 <<Ci̱ka ku nu̱wa yikiri ku̱le̱ ba taa, ni̱ndu̱ we̱i̱ yi̱to̱ nyanggu̱ ku cwata go̱ro̱u̱.  
\v 41 Bo̱l Ne̱re̱ tu̱mo̱ we̱i̱ bacamandi, pma de̱manu̱ we̱i̱ kana we̱ wu diini nu̱wa ba ni̱nga we̱le̱m wa, yi̱ wu ni̱ng tu bwi̱i̱ a lau̱ yo̱u̱.  
\v 42 Pero bacamandi swii parnu we̱i̱ pma par bwalai, pu pma jii we̱i̱ wiindi yi̱ dumonggu nyi̱yau̱.  
\v 43 Anda nu̱wa bu ni̱ngi̱ pi̱su̱ wu nyaau a gawu̱ri̱ Yambai̱ nyi̱lanu̱ we̱i̱ ci̱ka nyanggu̱ a lau̱ Mbaa pmau. Yama ne̱re̱ wii twendi di̱ngi̱n nu̱u̱gu̱, ba ka twiyau. 
\s1 Balanggu̱ ci̱ye̱i̱ a dwii gi̱na wu tukugi 
\p  
\v 44 <<Lau̱ ku diyou ci̱ka gi̱na wu tukugi a ko̱ndo̱u̱. Pu ne̱re̱ wu kanggi̱ ki̱nggau̱ a pero tukugu, a ni̱nga bu̱ri̱ de̱gde̱g a aara cuu kana ca tu wo̱o̱ yi̱ to̱no̱i̱ a te̱n kodou wii. 
\s1 Ci̱ye̱i̱ du balanggai̱ dwii gi̱so̱u̱ 
\p  
\v 45 <<Lau̱ ku diyou ci̱ka, ne̱re̱ wu kasanggu̱ gi̱si̱ tu nyaai,  
\v 46 anda ku nyi̱ngga gi̱so̱u̱ kiino ku yi̱ pi̱rcu̱ wang, a aara cuu kana ca tu wo̱o̱ yi̱ to̱no̱i̱ a te̱na. 
\s1 Balanggu̱ ci̱ye̱i̱ a dwii le̱mu̱ 
\p  
\v 47 <<Mwaasi̱, lau̱ ku diyou ci̱ka, le̱mdi̱ su nu̱wa parna you re̱e̱ kana ko̱no̱ du jindu.  
\v 48 Pu le̱m wii twangwa, pma yikuwe a gi̱ngu̱ a si̱n si̱yandi̱ a se̱ka jindi su nyaayi a parna taci̱ngi̱ pmai, su yaa kundi a par si̱ye̱i̱.  
\v 49 Ni̱ndu̱ we̱i̱ yi̱to̱ nyanggu̱ ku cwata go̱ro̱u̱. Bacamandi cwanu we̱i̱ nu̱wa bu ni̱ngi̱ pi̱su̱ wu nyaau gawu̱ri̱ Yamba wa yi̱ nu̱wa bu bwi̱i̱ wa.  
\v 50 Parnu we̱i̱ pma par bwalai pu pma jii we̱i̱ wiindi yi̱ dumonggu nyi̱yau̱. 
\s1 Ji̱re̱ wu pu̱ce̱ yi̱ wu mi̱lga 
\p  
\v 51 Yesu pi̱ra ki̱n, <<Bu ku̱ranga to̱o̱ yi̱ri̱ngi̱ ru?>> 
\p Pma le̱e̱ ki̱n, <<O̱ng.>>  
\v 52 Anda a sa pma ki̱n, <<To̱o̱ yi̱ri̱ pi̱ti̱ndi̱ twii, kana wo̱no̱ ku̱lu̱m te̱e̱re̱ wu yo̱o̱ bwiyaka wu lau̱ ku diyou, yo̱ ci̱ka ne̱re̱ wu laa wayau, wu yikiwe gi̱na wu pu̱ci̱ yi̱ wu mi̱lgai̱ mi̱ri̱nggi̱ kandi̱ du ruuni se̱e̱ ye̱i̱.>> 
\s1 Nu̱wa kwaa Yesu a gwe̱i̱ ye̱i̱ 
\p  
\v 53 Pu Yesu mata sagu̱ pma ci̱ye̱i̱ du balanggai̱, a du po̱o̱ wii.  
\v 54 A waata bu̱ri̱ gwe̱i̱ ye̱i̱. A toso ju̱ku̱gu̱ yi̱ri̱ngi̱ nu̱wa a gi̱re̱ng ku̱ru̱, nu̱wa bu nu̱u̱gu̱ yo̱ wa pma riyanga bu̱ri̱. Pma ni̱nga pi̱ra ki̱n, <<Ne̱re̱ wo̱o̱ nyi̱ngga to̱o̱ so̱mandi̱ yi̱ yi̱ri̱ngi̱ ri̱yandi̱ bu̱ri̱ to̱o̱ pi̱yau̱?  
\v 55 To̱o̱ bo̱l kapinta wo̱o̱ ne̱ ru? Njaa yo̱ wii Maryam yi̱ ci̱yamba ya Yakubu yi̱ Yusupu yi̱ Simon yi̱ Yahuda ne̱ ru?  
\v 56 Ci̱yamba ya bu nu̱ru̱mba wa yaa pi̱si̱ndi̱ pi̱na mwa mwa kem yi̱ yo ru? Ne̱re̱ wo̱o̱ nyi̱ngga to̱o̱ yi̱ri̱ngi̱ pi̱yau̱?>>  
\v 57 Pma bwiyanga gaanggu̱ a kwaa yo̱. 
\p Yesu sa pma ki̱n, <<Banabi̱ ki̱nggi̱ nyi̱i̱gu̱ gi̱ru̱ kana pi̱yau̱, anda yaa ki̱nggi̱ gwe̱i̱ ye̱i̱, yi̱ laa yo̱u̱.>> 
\p  
\v 58 Yaa ku ni̱nga yi̱ri̱ngi̱ ri̱yandi̱ bu̱ri̱ tum a pwii, di̱ngi̱n pma le̱e̱ bu ji̱re̱. 
\c 14  
\s1 Bo̱o̱ri̱ Yohanna wu Ni̱ngi̱ Bati̱si̱ma 
\p  
\v 1 A dwii jo̱re̱ Hiridus balaa wu Galili, a nu̱u̱ labar Yesu.  
\v 2 A sa wula ya ki̱n, <<Wii Yohanna wu Ni̱ngi̱ Bati̱si̱ma, a wuni bo̱o̱re̱, twii to̱no̱ a ni̱nggu̱ to̱o̱ yi̱ri̱ngi̱ ri̱yandi̱ bu̱ri̱.>> 
\p  
\v 3 Di̱ngi̱n co̱nggo̱ yo̱u̱ a din nu̱wa twala Yohanna, cala yi̱ cali a manna jaru̱m. A ni̱nga yi̱to̱ di̱ngi̱n Hirudiya twii nu̱re̱ ci̱ya yo̱ Pilibus, wu yo̱ yiki yo̱.  
\v 4 Di̱ngi̱n Yohanna ni̱nga pu sagu̱ Hiridus ki̱n, <<Yaa ci̱maci̱ma yi̱ te̱e̱ri̱ Yambai̱ ma yiki nu̱re̱ ci̱ya mo̱!>>  
\v 5 Hiridus kasa ba ji yo̱, anda a nu̱u̱ gwasi̱ nu̱wa bu Yudaya wa, di̱ngi̱n pma de̱e̱ Yohanna twii banabi̱. 
\p  
\v 6 Nyanggu̱ danggu̱gu̱ yi̱ bir Hiridus bo̱l Hirudiya wu nu̱re̱ sii ko̱lo̱ gawu̱ri̱ ru̱nggu̱wa ya mwa mwa. A bwalaman dwii Hiridus  
\v 7 a ni̱ngaman yo̱ alkawal ki̱n, <<N we̱re̱nga n nyi̱i̱mi̱nu̱ we̱i̱ kana ca tu ma senggoi!>>  
\v 8 Njaa yo̱ saa, ba sa Hiridus ki̱n, <<Nyi̱i̱nggi̱ dwii Yohanna wu Ni̱ngi̱ Bati̱si̱ma yo̱ko̱ yo̱ko̱ a pi̱lai̱!>>  
\v 9 Balaa gaanggu̱ yo̱u̱ bwiiwa, anda yake̱ ku ni̱nga alkawal yi̱ we̱ra a gawu̱r ru̱nggu̱wa ya a diin nu̱wa nyi̱i̱ tu kasai̱.  
\v 10 Di̱ngi̱n to̱no̱ a sa nu̱wa ba mwarwe̱ dwii Yohanna wu Ni̱ngi̱ Bati̱si̱ma a jaru̱m.  
\v 11 Nu̱wa de̱e̱ dwii ye̱i̱ a pi̱lai̱ nu̱wa nyi̱i̱ bwe̱e̱canga wii, a de̱man njaa yo̱.  
\v 12 Kwati̱mba Yohanna wu Ni̱ngi̱ Bati̱si̱ma wa baanga ba de̱ bu̱ri̱ ye̱i̱ aanda tingo, pma mwatanga sa Yesu. 
\s1 Yesu puu je̱e̱ndi̱ nu̱wa tedu nuwo 
\p  
\v 13 Pu Yesu nu̱u̱ labar Yohanna, a geero konggoru, a aara pu yaa nu̱wau̱ yo̱ wundu. Ku nu̱wa nu̱u̱ tu ni̱ngi̱ wa pma twiyo go̱ro̱ndi̱ pma a pe̱e̱ yi̱ mwari po̱ng yo̱.  
\v 14 Yesu julo konggoru a ko̱ nu̱wa tum a nu̱u̱ bunam pmau a mi̱ra pma bu yaa cingcing wa pma yi̱langa. 
\p  
\v 15 Pu nyambi̱ranggu̱ ni̱nga kwati̱mba ya baanga bo̱nggo̱ yo̱u̱ a se̱e̱ ki̱n, <<Po̱o̱ wuna ti̱na gu̱lai̱, yo̱ko̱ nyambi̱ranggu̱ ni̱nga. Sa nu̱wa bo̱o̱ ba aanda go̱ro̱ndi̱ tu ne̱m, palaka ba te̱nmanu̱we̱ bu̱ri̱ pmai je̱e̱ndi̱.>> 
\p  
\v 16 Yesu nyi̱i̱ pma le̱e̱ ki̱n, <Ko̱po̱ ba mwatanga ne̱, anda mba bu nyi̱i̱ pma yi̱ri̱ ba je̱!>> 
\p  
\v 17 Pma se̱e̱ ki̱n, <<Tu yi bo̱o̱ yi̱ to̱no̱i̱ mwa mwa ti̱na ku̱maa nuwo yi̱ jindi ro̱p ti̱bak.>> 
\p  
\v 18 Yesu sa pma ki̱n, <<Bu de̱ngu̱we̱ pi̱na.>>  
\v 19 A sa nu̱wa bwii ba si̱ndi̱ si̱ye̱i̱, a dwii si̱yangi̱. A de̱e̱ ku̱maa wu nuwo wii yi̱ jindi su ro̱p swii, a wun dwii diyou, a ni̱nga wandi̱ma a ge̱le̱nga ku̱maa wii. A nyi̱i̱ kwati̱mba ya ba cwaanga, pma cwaanga nu̱wa bwii.  
\v 20 Anda mwa mwa pmau je̱ riyanga. Kwati̱mba ya gamanga buburingi tu nyonai, a twanga taci̱ngi̱ kwap su̱r ro̱p.  
\v 21 Ku̱ci̱ nu̱wa bu je̱ je̱e̱ndu̱ wa bwii twii nambi̱rmba tedu nuwo yaa mu̱ri̱nggi̱ nu̱ru̱mba yi̱ bakwara. 
\s1 Yesu aari so̱ngma a dwii gundu 
\p  
\v 22 Yo̱ko̱ yo̱ko̱ Yesu sa kwati̱mba ya ba teendo konggoru ba cwiyongo yerou you, pma du yo̱ anda a sa nu̱wa bwii ba mwatanga.  
\v 23 Pu nu̱wa bwii mwatanga, Yesu geero ci̱ngu̱ yo̱ wundu di̱ngi̱n ba ce̱ ku̱ru̱. Kum ni̱nga wo̱o̱ pwii yo̱ wundu.  
\v 24 Anda a do̱o̱ jo̱re̱ konggoru wii ni̱nga kwaara yi̱ gi̱ngu̱ yo̱u̱, gwe̱re̱ gundu turonggu pma di̱ngi̱n wuture wii jagu̱ pma so̱ngma. 
\p  
\v 25 Pu kacu ni̱nga, Yesu aara bo̱nggo̱ pmau yi̱ nau a dwii gundi.  
\v 26 Pu kwati̱mba ya ko̱ yo̱ so̱ngma dwii gundui pma nu̱u̱ gwasi̱, pma ni̱nga duwai ki̱n <<Twii pi̱ti̱ngga!>> Pma nu̱u̱ gwasi̱ wang. 
\p  
\v 27 Yo̱ko̱ yo̱ko̱, Yesu sa pma ci̱ye̱i̱ ki̱n, <<Bu bo̱ gaanggu̱, bu nu̱u̱ya gwasi̱, wuna mi!>> 
\p  
\v 28 Anda Bitrus se̱e̱ ki̱n, <<Mbaa Wu Gi̱ra ka wo̱o̱ mo̱ we̱i̱ sangge̱ n baa bo̱nggo̱ mo̱u̱ n ni̱nga so̱ngma gundu.>> 
\p  
\v 29 Yesu le̱e̱man yo̱ ki̱n. <<Bame̱.>> 
\p Bur Bitrus twiyo mi̱ri̱nggi̱ konggoru a yanna so̱ngma a dwii gundu aara bo̱nggo̱ Yesu.  
\v 30 Anda pu ko̱ wutur gundu wii yi̱ di̱mbi̱re̱ a nu̱u̱ gwasi̱ a toso ji̱mti̱gu̱ a gundu. A ba kwarame̱ ki̱n, <<Mbaa Wu Gi̱ra, mi̱rangge̱.>> 
\p  
\v 31 Yesu yaki wai yo̱u̱ a taa yo̱ ce̱ ki̱n, <<Ma yaa le̱e̱gu̱ ji̱re̱u̱. Di̱ngi̱n ca ma cwaanga gaanggi̱r ro̱p?>> 
\p  
\v 32 Pu pma teendo mi̱ri̱nggu̱ konggoru wii, bur wutur wii gwata.  
\v 33 Nu̱wa bu mi̱ri̱nggi̱ konggoru bwii ku̱raman si̱ma Yesu a ce̱gu̱ ki̱n, <<Manggu ma Bo̱l Yamba.>> 
\s1 Yesu mi̱ra nu̱wa bu yaa cingcing a Jenesarata 
\p  
\v 34 Pu pma yerongo kali̱nggu̱ kwii, pma julongo a Jenesarata.  
\v 35 Pu nu̱wa bu gwe̱i̱ dwii ku̱ranga Yesu, pma tu̱mami̱n si̱ma bwii mwa mwa. Pma ni̱nga pu de̱gu̱ nu̱wa bu bu̱ri̱ yaa cingcing wa bo̱nggo̱ Yesu.  
\v 36 Pma senggo yo̱ ba du nu̱wa bu yaa cingcing wa ba mwaanga nyan landa yo̱u̱, anda kana we̱ wu mwaanga nyan landa yo̱u̱ a yi̱la. 
\c 15  
\s1 Pi̱rgu̱ ni̱ngandi̱ kakai̱ 
\p  
\v 1 Parisayo bu kangga kem yi̱ ku̱lu̱mba te̱e̱ri̱ngi̱ wa bu baanga Wurcalima wa, pma baanga bo̱nggo̱ Yesu a pi̱ra ki̱n,  
\v 2 <<Di̱ngi̱n ca kwati̱mba ma yaa po̱ng tu kakaa pi̱r ye̱i̱? Pma yaa cardi wari̱ ka wunni je̱gu̱ je̱e̱ndi̱!>> 
\p  
\v 3 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Di̱ngi̱n ca mba bu par te̱e̱ri̱ Yambai̱ di̱ngi̱n pu po̱ng ni̱ngandi̱ mbi̱ri̱?  
\v 4 Di̱ngi̱n Yamba ce̱ ki̱n, <Ma nyi̱i̱ gi̱ru̱ mbaa mo̱ yi̱ njaa mo̱,> anda <Kana we̱ wu se̱mtanga mbaa yo̱ yi̱ njaa yo̱, nu̱wa ba jiyo.>  
\v 5 Anda mba bu ju̱ku̱ri̱ mi̱n ne̱re̱ ba kwaa kalanggu̱ mbaa yo̱ yi̱ njaa yo̱ jo̱r du bo̱o̱ yi̱ biiki, ba ce̱ ki̱n, kana ca tu n wo̱o̱ yi̱ to̱no̱i̱ n nyi̱i̱ Yamba.  
\v 6 Di̱ngi̱n to̱no̱ bu ju̱ki̱ya mi̱n ne̱re̱ ba nyi̱i̱ ya gi̱ru̱ mbaa yo̱, bu kwaa te̱e̱ri̱ Yambai̱ palaka bu po̱ng ni̱ngandi̱ mbi̱ri̱.  
\v 7 Mbaa bu yi̱ batal wa! Icaya ce̱ ci̱maci̱ma pu ci̱ye̱i̱ du baa bo̱nggo̱ Yambai̱ a dwii mbi̱ri̱, a ce̱ ki̱n, 
\b  
\q1  
\v 8 <Nu̱wa bo̱o̱ nyi̱i̱nggi̱ gi̱ru̱ yi̱ nyandi pmai ti̱bak 
\q2 anda gaanggi̱ri̱ pmai kwaara yi̱ mi. 
\q1  
\v 9 Pma ku̱rangi̱n si̱ma nyo, 
\q2 yi̱ri̱ngi̱ tu pma ju̱ku̱gu̱, twii te̱e̱ri̱ngi̱ nu̱wa ti̱bak!>>> 
\s1 Yi̱ri̱ tu bwiyani ne̱re̱ ba ni̱nga yaa walwal 
\p  
\v 10 Yesu yi̱we̱ nu̱wa bu ku̱ranggi̱ bu̱ri̱ wa bwii ba baanga bo̱nggo̱ yo̱u̱, a sa pma ki̱n, <<Bu ka twiyau bu ku̱ranga!  
\v 11 Yi̱ri̱ngi̱ tu diiri nyan ne̱ru̱ twii tu diini ne̱re̱ ba ni̱nga yaa walwal ne̱ anda yi̱ri̱ngi̱ tu twiiwei nyi̱yau̱ ne̱ru̱ bwiyani ne̱re̱ ba ni̱nga yaa walwal.>> 
\p  
\v 12 Kwati̱mba ya baanga bo̱nggo̱ yo̱ ce̱ ki̱n, <<Ma so̱ma mi̱n tu ma ce̱ to̱o̱ a bwiyaman gaanggu̱ Parisayo ru?>> 
\p  
\v 13 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Kana ca tu Mbaa mi wu diyou pi̱ bu, nu̱wa podu we̱i̱.  
\v 14 Bu du pma, to̱o̱ nu̱wa bu taman jwalu kermo wa, anda kermo yaa taman jwalu kermo, di̱ngi̱n mwa pmau yaraman we̱i̱ bo̱o̱wu̱.>> 
\p  
\v 15 Bitrus ce̱ ki̱n, <<Sa yiri pi̱ti̱ndi̱ balanggu̱ ci̱ye̱i̱ du ma ce̱ do̱o̱.>> 
\p  
\v 16 Yesu sa pma ki̱n, <<Karai kwii bu ku̱ran bu ru?  
\v 17 Bu so̱m bu mi̱n kana ca tu diiro nyi̱yau̱ aari pwii pero ba twii bu̱ri̱ du?  
\v 18 Anda yi̱ri̱ngi̱ tu twiiwe nyi̱yau̱ twiiwe mi̱ri̱nggu̱ gaanggu̱, to̱o̱ tu diini ne̱re̱ ba ni̱nga yaa walwal.  
\v 19 Di̱ngi̱n a mi̱ri̱nggi̱ gaanggu̱ dangandi̱ tu bwi̱i̱ twiiwei, jigu ne̱ru̱, taari̱, taari̱ yi̱ nu̱ru̱mba bu̱ru̱ wa, kuwi, se̱e̱daki̱ leendi, yi̱ bwiyanggu dinu.  
\v 20 To̱o̱ yi̱ri̱ngi̱ diin ne̱re̱ ni̱ng yaa walwal. Anda je̱gu̱ je̱e̱ndi̱ wari̱ yaa cargi, yaa diini ne̱re̱ ba ni̱nga yaa walwal.>> 
\s1 Le̱e̱gu̱ ji̱re̱ nu̱ru̱ wu Kanana 
\p  
\v 21 Yesu du po̱o̱ wii a mwati̱ si̱ma Taya yi̱ Sidon.  
\v 22 Nu̱r Kananiya wa wu bo̱nggo̱ndi̱ swii baa bo̱nggo̱ yo̱u̱ a wun miu yi̱ duwai ki̱n, <<Mbaa Wu Gi̱ra, Bo̱l Dawud, nu̱u̱ bunam mu, bwe̱e̱canga mi wo̱o̱ yi̱ wuturindi a cu̱su̱gu̱.>> 
\p  
\v 23 Anda Yesu yaa ku sa yo̱ ci̱ye̱i̱. Kwati̱mba ya baanga bo̱nggo̱ yo̱u̱ senggo a ce̱ ki̱n, <<Ke̱e̱ ba mwati̱! A po̱nggu̱ yiru ni̱nggu̱ duwau!>> 
\p  
\v 24 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Nu̱wa tu̱mgu̱we̱ bo̱nggo̱ nu̱wa bu Israila yi̱ wundu bu ci̱ka puuri su li̱yangai̱ wa.>> 
\p  
\v 25 Nu̱re̱ wii baa kun kwiyei gawu̱ri̱ ye̱i̱ ce̱ ki̱n, <<Mbaa Wu Gi̱ra kalangge̱.>> 
\p  
\v 26 Yesu le̱e̱ ki̱n <<Yaa kundi nu̱wa ba de̱ je̱e̱ndi̱ bakwarai ba nyi̱i̱ baindi.>> 
\p  
\v 27 A nyi̱i̱ le̱e̱ ki̱n, <<Mbaa Wu Gi̱ra, to̱o̱ ji̱re̱, kana baindi je̱e̱ tu ywiyongo bo̱nggo̱ ne̱re̱ yo̱.>> 
\p  
\v 28 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Ma yo̱o̱gi̱ nu̱re̱ wu yi̱ le̱e̱gu̱ ji̱rau̱! Nu̱wa ni̱ngami̱nu̱ we̱i̱ tu ma kasu̱gu̱.>> Ki̱nangu̱ kwii bwe̱e̱canga yo̱ yi̱la. 
\s1 Yesu mi̱ra nu̱wa tum 
\p  
\v 29 Yesu du po̱o̱ wii a mwati̱ kali̱nggu̱ ku Galili. A ge̱ro̱ ci̱ngu̱ si̱n si̱ye̱i̱.  
\v 30 Nu̱wa tum baa bo̱nggo̱ yo̱u̱ de̱e̱ gu̱wo̱ngi̱ yi̱ kermo yi̱ ne̱re̱ wu mwar bo̱rgi̱, yi̱ bapi̱me̱ yi̱ nu̱wa bu bu̱ri̱ pmai yaa cingcing a bo̱nggo̱ Yesu, a mi̱ra pma, pma yi̱langa.  
\v 31 Nu̱wa bwii riyanga bu̱ri̱ pu pma ko̱ bapi̱me̱ ce̱gu̱ ci̱ye̱u̱, gu̱wo̱ngi̱ a yi̱la, ne̱re̱ wu mwar bo̱rgi̱ a so̱ngma, kermo ko̱gu̱ si̱ma. Bu̱ri̱ pma te̱re̱nga Yamba wu Israila. 
\s1 Yesu puu je̱e̱ndi̱ nu̱wa te̱du̱ ni̱i̱ 
\p  
\v 32 Yesu yi̱we̱ kwati̱mba ya a sa pma ki̱n, <<N nu̱u̱gu̱ bunam nu̱wa bo̱o̱, di̱ngi̱n pma ni̱nga daa kunong kem yi̱ mi anda yi yaa je̱e̱ndi̱ tu yi je̱i̱, n yaa kasi̱ baa mwatanga yi̱ ju̱ne̱, ko̱ mwa ba jaanga so̱ngma nyinou ka wuni mwatangu.>> 
\p  
\v 33 Kwati̱mba ya pi̱ra ki̱n, <<Yi nyi̱ngga we̱i̱ je̱e̱ndi̱ tum pi̱yau̱ pi̱na gu̱lai̱ tu yirmanu we̱i̱ nu̱wa bu tum bo̱o̱?>> 
\p  
\v 34 Yesu pi̱ra pma ki̱n, <<Bu bo̱o̱ yi̱ ku̱maa so̱no̱?>> 
\p Pma nyi̱i̱ le̱e̱ ki̱n, <<Yi bo̱o̱ yi̱ ku̱maa a nibiyo yi̱ jindi banyi̱na.>> 
\p  
\v 35 Yesu sa nu̱wa bu tum bwii ki̱n ba si̱ndi̱ si̱ye̱ndi̱ si̱ma.  
\v 36 A de̱ ku̱maa wu nibiyo wii yi̱ jindi swii a wananga Yamba, a ge̱le̱nga nyi̱i̱ kwati̱mba ya, kwati̱mba ya cwaanga nu̱wa bwii.  
\v 37 Pma je̱e̱ riyanga mwa mwa. Kwati̱mba ya ku̱ranga bubiringi tu nyonai a twanga taci̱ngi̱ nibiyo.  
\v 38 Ku̱ci̱ nu̱wa bu je̱ je̱e̱ndi̱ wa lam tedu ni̱i̱, yaa mu̱ri̱nggi̱ nu̱ru̱mba yi̱ bakwara. 
\p  
\v 39 Go̱ro̱ pu Yesu tu̱m pma mwatanga, a diiro konggoru a yeri bo̱nggo̱ndi̱ Magadan. 
\c 16  
\s1 Nu̱wa Kasi̱gu̱ somdi yi̱ri̱ngi̱ ri̱yandi̱ bu̱ri̱ 
\p  
\v 1 Parisayo bu kangga yi̱ Sadukayo pma baanga bo̱nggo̱ Yesu palaka ba cu̱u̱ yo̱, pma se̱e̱ ki̱n, <<Ju̱ku̱ yiri somdi yi̱ri̱ ri̱yandi̱ bu̱ri̱, ka ma baa diyou Yamba wai.>> 
\p  
\v 2 Anda Yesu nyi̱i̱ pma le̱e̱ ki̱n, <<Ka nyambi̱ranggu̱ ni̱ngi̱, bu ce̱ mi̱n, <Si̱ma ni̱ngu̱ we̱i̱ teng di̱ngi̱n diyou ni̱nga wing.>  
\v 3 Pero yi̱ pinu bu ce̱e̱ mi̱n, <Gundu yaru we̱i̱, di̱ngi̱n diyou ni̱ngi̱ wing pero ni̱nga pitipiti!> Bu ku̱rani̱ tu ni̱ngdu̱ we̱i̱ diyou, anda bu jaanga ku̱ranggu̱ tu ni̱ngdu̱ we̱i̱ a daandi su yo̱ko̱i̱.  
\v 4 Mba nu̱wa bu bwi̱i̱ wa bu si̱naa daandi wa, bu yaa gwasi̱ Yamba wa, bu kasi̱ yi̱ri̱ somdi ri̱yandi̱ bu̱ri̱, yaa ku n ni̱ngambi̱ri̱ somdi ri̱yandi̱ bu̱ri̱ ka gwal tu banabi̱ Yunana.>> 
\p Bur Yesu a du pma mwati̱. 
\s1 Yisti Parisayo yi̱ Sadukayo 
\p  
\v 5 Pu kwati̱mba ya yerongo kali̱nggu̱ kwii, pma mondo ba de̱ ku̱maa.  
\v 6 Yesu sa pma ki̱n, <<Bu ruun tu̱we̱, yi̱ yisti Parisayo yi̱ Sadukayo.>> 
\p  
\v 7 Pma toso gwe̱la yi̱ bu̱ri̱ pmai ki̱n, <<A ce̱ yi̱to̱ di̱ngi̱n yi de̱e̱ bu ku̱maa kana banyi̱na.>> 
\p  
\v 8 Yesu so̱m tu pma ce̱gi̱, di̱ngi̱n to̱no̱ a pi̱ra pma ki̱n, <<Di̱ngi̱n ca bu ni̱nggu̱ gwe̱la yi̱ bu̱ri̱ mbi̱ri̱ mi̱n bu yaa ku̱maa? Le̱e̱gu̱ ji̱rau̱ mbi̱ru̱ banyi̱na!  
\v 9 Lama yo̱ko̱ bu ku̱ran bu ru? Bu dangga bu yi̱ ku̱maa nuwo wu n je̱e̱ nu̱wa tedu nuwo wo̱ ru? Bu ku̱ranga taci̱ngi̱ twangi so̱no̱?  
\v 10 Ku̱maa nibiyo wu n je̱e̱ nu̱wa tedu ni̱i̱ wo̱o̱ do̱ng de̱i̱? Bu twanga taci̱ngi̱ so̱no̱?>>  
\v 11 Di̱ngi̱n ca bu yaa ku̱rani̱ mi̱n n yaa ce̱gu̱ ku̱maa? Bu swe̱ra bu̱ri̱ mbi̱ri̱ bo̱nggo̱ yisti Parisayo yi̱ Sadukayo.>>  
\v 12 Kwati̱mba ya bwii ku̱ranga ki̱n yaa ce̱gu̱ ki̱n ba swe̱ra bu̱ri̱ pmai bo̱nggo̱ yisti wu mi̱ri̱nggi̱ ku̱maa anda bo̱nggo̱ yi̱ri̱ngi̱ tu Parisayo yi̱ Sadukayo ju̱ku̱ri̱. 
\s1 Ci̱ye̱i̱ Bitrus a dwii Yesu 
\p  
\v 13 Pu Yesu mwati̱ gwe̱i̱ Kaisariya du Pilipi, a pi̱ra kwati̱mba ya ki̱n, <<Nu̱wa ci̱ye̱i̱ ki̱n Bo̱l Ne̱re̱ we̱?>> 
\p  
\v 14 Pma le̱e̱ ki̱n <<Bu kangga ce̱e̱ ki̱n ma yo̱o̱gi̱ Yohanna wu Ni̱ngi̱ Bati̱si̱ma, bu kangga ki̱n ma Iliya, bu kangga ki̱n ma Irmiya yikwii ma wu wiino mi̱ri̱nggi̱ banabi̱ndi̱.>> 
\p  
\v 15 A pi̱ra pma ki̱n <<Anda mba, bu ce̱ mi̱n, mi we̱?>> 
\p  
\v 16 Simon Bitrus le̱e̱ ki̱n, <<Ma Masiya, Bo̱l Yamba wu yi̱ pi̱i̱ma.>> 
\p  
\v 17 Yesu le̱e̱man yo̱ ki̱n, <<Ma yo̱o̱gi̱ wu yi̱ wuure Simon bo̱l Yunana, di̱ngi̱n wo̱o̱ ji̱re̱ yaa ku baa bo̱nggo̱ ne̱ru̱. Mbaa mi wu diyou a ju̱ku̱ mi̱na.  
\v 18 Yo̱ko̱ n sagu̱ mo̱u̱, ma Bitrus, (pi̱ti̱ndi̱ ye̱i̱ twii swe̱li̱.) \f + \fr 16:18 \ft Pi̱ti̱ndi̱ din Bitrus twii swe̱li̱\f* Ma yo̱o̱gi̱ swe̱li̱ du n mo̱ru̱ we̱i̱ ikkilisiya mi, kana bo̱o̱re̱ na gwali̱.  
\v 19 N nyi̱i̱mi̱nu̱ we̱i̱ tu wundi nyinoi lau̱ ku diyou, kana ca tu ma kwe̱e̱ a si̱ma, a kwauwa a diyou, tu ma pe̱ra a si̱ma, a pe̱rwa a diyou.>> 
\p  
\v 20 Go̱ro̱ yi̱to̱ Yesu sa kwati̱mba ya ki̱n, ba sari̱ ya kana we̱ ki̱n yo̱ Masiya. 
\s1 Yesu ce̱ bo̱o̱ru̱ ye̱i̱ 
\p  
\v 21 A toso dwii jo̱re̱ Yesu toso sagu̱ kwati̱mba ya dak ki̱n, <<Tagi̱ n angge̱ Wurcalima n tii ku̱u̱le̱ wundu wundu bo̱nggo̱ bagi̱raa Yudaya wa yi̱ bagi̱raa kuruwa wa yi̱ ku̱lu̱mba te̱e̱ri̱ngi̱ wa. Tagi̱ nu̱wa jinggu we̱i̱, anda nyanggu̱ ku kunong, yo̱ wuni we̱i̱ yi̱ pi̱i̱ma.>> 
\p  
\v 22 Bitrus wu̱u̱ yo̱ bo̱nggo̱ a toso ye̱re̱nggu̱ ki̱n, <<Mbaa Wu Gi̱ra! To̱o̱ na ni̱ndi̱ yi̱ mo̱!>> 
\p  
\v 23 Yesu waka kau sa Bitrus ki̱n, <<Lamana bo̱nggo̱ mu Balaa buwai! Ma yo̱o̱gi̱ swe̱li̱ pu̱ti̱, to̱o̱ dangandi̱ baa bu bo̱nggo̱ Yambau̱, anda bo̱nggo̱ ne̱ru̱.>> 
\p  
\v 24 Yesu sa kwati̱mba ya ki̱n, <<Kana we̱ ka kasi̱ ba po̱ngge̱, tagi̱ ba kwaa bu̱ri̱ ye̱i̱, ba de̱ ye̱u̱ yo̱u̱ ba po̱ngge̱.  
\v 25 Kana we̱ wu kasi̱ ba mi̱ra pi̱i̱ma ya mandu̱ we̱i̱ si̱yau̱, anda kana we̱ wu mansi̱ ye̱i̱ pi̱i̱ma ya di̱ngi̱n mi nyi̱nggu̱ we̱i̱.  
\v 26 Tu ne̱re̱ pulu we̱i̱ ca ka nyi̱nggi̱ yi̱ri̱ngi̱ tu si̱ma mwa mwa anda nyi̱ngga bu pi̱i̱ma ne̱? Tu ne̱re̱ nyi̱i̱ we̱i̱ ca ba waka pi̱i̱ma ya.  
\v 27 Di̱ngi̱n Bo̱l Ne̱re̱ baa we̱i̱ yi̱ yi̱lau̱ Mbaa yo̱ yi̱ bacamandi ye̱i̱, pero nyi̱i̱ we̱i̱ kana we̱ wo̱ri̱ri̱ ci̱maci̱ma yi̱ yi̱ri̱ tu ni̱ngai̱.  
\v 28 N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱ bu kangga bo̱o̱ pi̱ti̱ndi̱ pi̱na, yaa ku bwaanu wau ko̱po̱ ka kwe̱e̱ Bo̱l Ne̱re̱ bagu̱ yi̱ lau̱ yo̱u̱. 
\c 17  
\s1 Bu̱ri̱ Yesu waku wa 
\p  
\v 1 Go̱ro̱ daa no̱ko̱no̱ Yesu de̱ Bitrus yi̱ Yakubu yi̱ ci̱ya yo̱ Yohanna a geendo ci̱ngu̱ ku getenteng pma yi̱ wundu pmau.  
\v 2 Pu pma bo̱o̱ pwii Yesu wakuwa, kau yo̱u̱ a nyi̱langgu̱ ci̱ka nyanggu̱, se̱e̱ yo̱ ni̱nga po̱pu̱lo̱k rang.  
\v 3 Bur kwati̱mba Yesu wa bu kunong wa bwii ko̱ Iliya yi̱ Musa baanga toso ce̱gu̱ ci̱ye̱i̱ yi̱ Yesu. 
\p  
\v 4 Bitrus sa Yesu ki̱n, <<Mbaa Wu Gi̱ra a ni̱nga yiro kundi ku̱ yi bo̱o̱ pi̱na! Ka ma le̱i̱ n me̱ne̱nu̱ we̱i̱ cukuringi kunong, diino di̱ngi̱n mo̱, diino di̱ngi̱n Musa, diino di̱ngi̱n Iliya.>> 
\p  
\v 5 Pu wo̱o̱ ce̱gu̱ ci̱ye̱i̱, bu̱ri̱ tinene du nyi̱lani̱ baa summo pma, pero miu twiiwe tinene dwii ki̱n, <<Ti̱na Bo̱l mi wu n kangni̱, wu di̱rangi̱n gaanggu̱. Bu nu̱u̱ yo̱!>> 
\p  
\v 6 Pu kwati̱mba ya bwii nu̱u̱ miu kwii pma nu̱u̱ gwasi̱ wang pma gonjo kau si̱ma.  
\v 7 Yesu baa bo̱nggo̱ pmau a mwaanga pma a ce̱ ki̱n, <<Bu wunongo, Bu nu̱u̱ yaa gwasi̱!>>  
\v 8 Pu pma wun dwiiyongi pma ko̱ bu kana we̱ bur Yesu. 
\p  
\v 9 Pu pma julonggu ci̱ngu̱ kwii Yesu sa pma ki̱n, <<Bu sar ya kana we̱ tu bu ko̱i̱ ko̱po̱ ka Bo̱l Ne̱re̱ wuni bo̱o̱re̱.>> 
\p  
\v 10 Kwati̱mba ya pi̱ra yo̱ ki̱n, <<Di̱ngi̱n ca ku̱lu̱mba te̱e̱ri̱ngi̱ wa ce̱ ki̱n tagi̱ ko̱po̱ ka Iliya waatai bati̱ anda Masiya ba baa?>> 
\p  
\v 11 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Manggu Iliya baa we̱i̱, pero waata we̱i̱ kana ca mwa mwa.  
\v 12 Anda n wo̱o̱ sagu̱mbi̱ru̱ Iliya gi̱ci̱la baa, nu̱wa yaa ku ku̱ranga yo̱, pma ni̱ngaman yo̱ kana ca tu pma kasai̱. Yi̱to̱ mwaa Bo̱l Ne̱re̱ aari ti̱i̱gu̱ ku̱u̱lu̱ a wari̱ pmai.>>  
\v 13 Bu̱ri̱ kwati̱mba ya ku̱ranga ki̱n a ce̱gu̱ ci̱ye̱i̱ dwii Yohanna wu Ni̱ng Bati̱si̱ma. 
\s1 Yesu yiki wuture a bu̱ri̱ babwiyai 
\p  
\v 14 Pu pma waatanga bu̱ri̱ bo̱nggo̱ nu̱wau̱, ne̱re̱ wu kangge̱ baa bo̱nggo̱ Yesu, a kun kwiyou bo̱nggo̱ yo̱u̱.  
\v 15 A ce̱ ki̱n, Mbaa Wu Gi̱ra, nu̱u̱ bunam bo̱l mu! Yi̱ to̱ki̱ pero a ti̱i̱gu̱ ku̱u̱li̱ wang, sii yari̱nggu̱ bwalau yi̱ gundu.  
\v 16 N de̱mu̱we̱ kwati̱mba ma anda pma jaanga mi̱rgu̱.>> 
\p  
\v 17 Yesu nyi̱i̱ pma le̱e̱ ki̱n, <<Mba nu̱wa bu yaa le̱e̱gu̱ ji̱re̱ wa yi̱ nu̱wa bu bwi̱i̱wa! N si̱nggu̱ we̱i̱ si̱ye̱i̱ yi̱ mba ko̱po̱ pe̱ne̱? N tari̱ we̱i̱ kanadi yi̱ mba ko̱po̱ pe̱ne̱? Bu nyi̱i̱ngu̱ we̱i̱ bwi̱ya wo̱o̱ pi̱na!>>  
\v 18 Yesu ye̱ra wutur wii, a twiyo bu̱ri̱ bwi̱ya wii swii ki̱nangu̱ a yi̱la. 
\p  
\v 19 Bur kwati̱mba Yesu baanga wu̱lak pi̱ra yo̱ ki̱n, <<Di̱ngi̱n ca yi jaanga yikugu wutur wii?>> 
\p  
\v 20 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Di̱ngi̱n le̱e̱gu̱ ji̱re̱ mbi̱ru̱ banyi̱na, n sagu̱mbi̱ru̱ ji̱re̱ ka bu bo̱o̱ yi̱ le̱e̱gu̱ ji̱re̱ banyi̱na ci̱ka go̱n mustad, bu saru we̱i̱ ci̱ngu̱ ki̱na mi̱n, <Mwati̱ pi̱na ma amna pwii!> Mwati̱r we̱i̱. Yaa tu bu puu ni̱nggi̱.  
\v 21 Ko̱o̱ duu wutur yaa twii ko̱po̱ yi̱ ku̱ru̱ yi̱ cooji.>>\f + \fr 17:21 \ft Yaa kana wo̱no̱ lakargar wu murni bo̱nggo̱ ci̱ye̱i̱ 21.\f* 
\s1 Yesu ce̱ ci̱yei̱ dwii bo̱o̱ri̱ ye̱i̱ do̱ng 
\p  
\v 22 Pu mwa mwa kwati̱mba ya ku̱ranga bu̱ri̱ Galili, Yesu sa pma ki̱n, <<Nu̱wa curu we̱i̱ Bo̱l Ne̱re̱ a war nu̱wai̱.  
\v 23 Nu̱wa jiru we̱i̱, anda go̱ro̱ daa kunong wunu we̱i̱ bo̱o̱re̱.>> Anda kwati̱mba bwiyanga gaanggu̱ wang. 
\s1 Yagu janggal a Laa Yambau̱ 
\p  
\v 24 Pu Yesu yi̱ kwati̱mba ya baanga Kaparnahum, nu̱wa bu yi̱ri̱ janggal Laa Yambau̱ baanga bo̱nggo̱ Bitrus pi̱ra ki̱n, <<Ku̱lu̱m mbi̱r yar janggal wu Laa Yambau̱ ru?>> 
\p  
\v 25 Bitrus le̱e̱ ki̱n, <<O̱ng.>> 
\p Pu Bitrus waata mi̱ri̱nggi̱ lai̱, Yesu ni̱nga pi̱ra ki̱n., <<Wu yar janggal balamba we̱? Nu̱wa bu si̱ma bwii ru? Ru̱nggu̱wa ru? Ma ce̱ mi̱n ca Bitrus?>> 
\p  
\v 26 Bitrus nyi̱i̱ le̱e̱ ki̱n, <<Tu yar Ru̱nggu̱wa.>> Yesu le̱e̱ ki̱n, <<Kundi, ma ce̱gu̱ mi̱n nu̱wa bu si̱ma bo̱o̱ pma yaa yari.  
\v 27 Anda n yaa kasi̱ yi we̱laman nu̱wa bo̱o̱. Di̱ngi̱n to̱no̱ mwati̱ you ma manni̱ godim. Ma wu̱we̱, jinde wu ma taa, a nyi̱yau̱ yau̱ ma nyi̱nggu̱ we̱i̱ ke̱ne̱ du yinno yagu janggal, ma de̱e̱, ma ya pma janggal yire.>> 
\c 18  
\s1 Wu gwala yi̱ gi̱ru̱ a lau̱ ku diyou we̱? 
\p  
\v 1 A dwii jo̱re̱ kwati̱mba Yesu wa baanga bo̱nggo̱ yo̱u̱ a pi̱rgu̱ ki̱n, <<Wu gwala yi̱ gi̱ra we̱ a lau̱ ku diyou?>> 
\p  
\v 2 Yesu yi̱we̱ babwiya wu banyi̱na a ruwo cu̱di̱ pma  
\v 3 a ce̱ ki̱n, <<N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱ ko̱po̱ ka bu waka bu̱ri̱ bu yo̱o̱ ci̱ka babwiya wu banyi̱na, ka yi̱to̱ ne̱, yaa wu diru we̱i̱ lau̱ ku diyou.  
\v 4 Di̱ngi̱n to̱no̱ kana we̱ wu cingo dwii ye̱i̱ ci̱ka babwiya wu banyi̱na, yo̱o̱ we̱i̱ wu gwala yi̱ gi̱ra a lau̱ ku diyou.  
\v 5 Kana we̱ wu yi̱ babwiya banyi̱na ci̱ka wuna di̱ngi̱n din mi, a yi̱ngge̱. 
\s1 Yi̱ri̱ngi̱ tu de̱e̱ we̱le̱m 
\p  
\v 6 <<Anda kana we̱ wu diini wu wiino mi̱ri̱nggi̱ bu nyi̱ti̱ti̱, bu puu ji̱re̱ yi̱ mi wa ba yaranga a we̱le̱m, kujang nu̱wa ba kwangman yo̱ ni̱i̱ du duuyi a kwii ba manna mi̱ri̱nggi̱ kali̱nggu̱ ba bwaa.  
\v 7 To̱o̱ yi̱ri̱ bunam a si̱ma, di̱ngi̱n nyindi we̱le̱m tagi̱ ba baa, anda yo̱o̱ we̱i̱ yi̱ri̱ bunam a bo̱nggo̱ ne̱re̱ wu de̱ yari. 
\p  
\v 8 <<Ka wai mau yi̱ naa mau diiminu we̱i̱ we̱le̱m wai, ma mwar ya, ma man si̱ye̱i̱! Kujang ma nyi̱ngga pi̱i̱ma bu yaa mati̱gu̱ wa, yaa wari yi̱ mwari yi̱ ku nu̱wa manu we̱i̱ mwa mwa wari mai yi̱ mwar mai mi̱ri̱nggu̱ bwalau ku yaa dumdu.  
\v 9 Ka nung mo̱ diimini we̱i̱ we̱le̱m wai, podo ma man si̱ye̱i̱! Kujang ma nyi̱ngga pi̱i̱ma yi̱ nung wiino yi̱ ku nu̱wa manmi̱nu̱ we̱i̱ yi̱ nundi ro̱p a bwalau ku yaa dumdu. 
\s1 Balanggu̱ ci̱ye̱i̱ a dwii puure wu li̱ya 
\p  
\v 10 <<Su̱wa kii, bu cedi ya kana we̱ cu̱du̱ bu nyi̱ti̱ti̱ bo̱o̱. N wo̱o̱ sagu̱mbi̱ru̱ bacamandi pmai su diyou kana pe̱ne̱ pe̱ne̱ bo̱o̱ gawu̱ri̱ Mbaa mi wu diyou. 
\p  
\v 11 \f + \fr 18:11 \ft Yaa kana wo̱no̱ lakargar wu mu̱rni̱ bo̱nggo̱ ci̱ye̱i̱ 11. Ci̱ka Luka 19:10\f* Bo̱l Ne̱re̱ baa di̱ngi̱n ba mi̱ra pma bu li̱yanggi̱ wa.  
\v 12 Bu dangani̱ mi̱n? Ka ne̱re̱ wu kangge̱ wo̱o̱ yi̱ puuri wo̱o̱n anda wu wiino li̱yari̱, na du̱r su kun to̱ro̱ su̱r to̱ro̱ swii a taagu̱ taawu̱ a ci̱ngu̱, ba mwati̱ ba kasanga puure wu wiino wu li̱ya wii ru?  
\v 13 Ka nyi̱ngai̱, n sagu̱mbi̱ru̱ ji̱re̱ ni̱nggu̱ we̱i̱ bu̱ri̱ de̱gde̱g a dwii puure wiino wii gwalu we̱i̱ su kun to̱ro̱ su̱r to̱ro̱ su li̱yani̱ bu swii.  
\v 14 Yi̱to̱ mwaasi̱, Mbaa mbi̱re̱ wu diyou yaa kasi̱ kana wiino mi̱ri̱nggi̱ bu nyi̱ti̱ti̱ bo̱o̱ ba li̱yanga. 
\s1 Bago̱n mo̱ wu ni̱ngami̱n we̱le̱m 
\p  
\v 15 Ka bago̱n mo̱ ni̱ngami̱n we̱le̱m, ma amna bo̱nggo̱ yo̱u̱ ma ju̱ku̱ yo̱ li̱yari̱ ye̱i̱, dwii mbi̱r ro̱p ti̱bak. Ka kar twiyau ma mi̱ra bago̱n mo̱.  
\v 16 Anda ka, ka bu twiyau ne̱ ma de̱ ne̱re̱ wiino kana nu̱wa ro̱p kem yi̱ mo̱, palaka kana ca tu ma se̱e̱ ba yo̱o̱ ji̱re̱ a cu̱du̱ nu̱wa ro̱p kana kunong bu twii se̱e̱daki̱ bwii.  
\v 17 Pero ka kwa kagu twiyau ma de̱e̱ bo̱nggo̱ ikkilisiya, ka kwaa kagu twiyau ikkilisiya, bu de̱e̱ twii ne̱re̱ wu so̱m bu Yamba yi̱ ne̱re̱ wu yi̱ri̱ janggal. 
\s1 Tu nu̱wa kwe̱e̱ yi̱ tu nu̱wa pe̱ra 
\p  
\v 18 <<Pero n wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱ kana ca tu bu kwe̱e̱ a si̱ma a kwauwa a diyou tu bu pe̱ra a si̱ma a pe̱rwa a diyou. 
\p  
\v 19 <<Bambang n cwatugu sagu̱mbi̱ru̱, kana pe̱ne̱ pe̱ne̱ ka nu̱wa ro̱p cu̱du̱ mbi̱ri̱ ne̱ci̱ dwii a pi̱naa si̱ma, ce̱ ku̱ru̱ a dwii kana ca Mbaa mi wu diyou ni̱nga mbi̱ru̱ we̱i̱.  
\v 20 Di̱ngi̱n pu nu̱wa ro̱p kana kunong ku̱ranga bu̱ri̱ yi̱ din mi, n wo̱o̱ kem yi̱ pma.>> 
\s1 Balanggu̱ ci̱ye̱i̱ a dwii ke̱we̱ wu yaa par sukom 
\p  
\v 21 Bur Bitrus baa bo̱nggo̱ Yesu a pi̱ra ki̱n, <<Mbaa Wu gi̱ra, n paramanu we̱i̱ bago̱n mi sukom daa so̱no̱, ka ni̱nga ngin we̱le̱m? Daa nibiyo ru? 
\p  
\v 22 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Yaa yi̱to̱, yaa daa nibiyo, anda kun nibiyo daa nibiyo.  
\v 23 Di̱ngi̱n to̱no̱ lau̱ ku diyou ci̱ka balaa wu kangge̱ wu kasi̱ ba su̱wa gi̱na yo̱ wu bo̱nggo̱ ke̱waa ya.  
\v 24 Pu toso su̱gu̱, nu̱wa de̱mu̱we̱ yo̱ ke̱we̱ yo̱ wu po̱ng tale̱nti̱ tedu kwap.\f + \fr 18:24 \ft Tale̱nti̱ te̱du̱ kwap, tum yo̱u̱ lam ke̱n wu̱rai̱ ne̱ri̱, nyan mi̱la kuna ro̱p a dwii jo̱re̱\f* 
\v 25 Ke̱we̱ wii yaa ku pu bu yagu ci̱n dwii, di̱ngi̱n to̱no̱ ne̱re̱ wu gi̱ra yo̱ wii a diina nu̱wa ba te̱e̱ ba cuu yo̱ kem yi̱ nu̱ru̱ yo̱ yi̱ kwaraya yi̱ mwa mwa yi̱ri̱ngi̱ tu wo̱o̱ yi̱ to̱no̱i̱ ba ya ci̱ne̱ dwii. 
\p  
\v 26 Ke̱we̱ wii a yara kun kwiyou yi̱ dinendi a gawu̱ri̱ balaa a ce̱ ki̱n, <Ni̱nga kanadi yi̱ mi, n senggu mau, n yami̱nu̱ we̱i̱ kana ca!>  
\v 27 Ne̱re̱ wu gi̱ra yo̱ wii nu̱u̱ bunam yo̱u̱, a duu ci̱n dwii, a dwiya mwati̱. 
\p  
\v 28 Bur ne̱re̱ wii baa kaanga yi̱ basi̱n wu̱rai̱ yo̱ wu kangge̱ wu po̱ng yo̱ dinari wo̱o̱n. A te̱e̱ kwi̱i̱ a ce̱gu̱ ki̱n, <Yangge̱ ci̱ne̱ mi!> \f + \fr 18:28 \ft Dinari twii ke̱n wu̱rai̱ ne̱ri̱ a nyan kiino a dwii jo̱re̱\f* 
\p  
\v 29 Basi̱n wu̱rai̱ yo̱ a kun kwiyou yi̱ dinendi a gawu̱ri̱ ye̱i̱ a senggo ki̱n, <Ni̱nga kanadi yi̱ mi, n yami̱nu̱ we̱i̱!> 
\p  
\v 30 Anda a kwaa, waka a de̱e̱ manna jaru̱m ko̱po̱ ku ya yo̱ ci̱ne̱ ye̱i̱.  
\v 31 Ku ke̱waa bu kangga bwii ko̱ tu ni̱ng wai gaanggi̱r pmai bwiiwa, pma aanda sa ne̱re̱ wu gi̱ra pma kana ca tu ni̱ng wai. 
\p  
\v 32 Ne̱re̱ wu gi̱ra wii yi̱we̱ ke̱we̱ wii a se̱e̱ ki̱n, <Ma ke̱we̱ wu yi̱ tu̱we̱, n yapa mi̱n cine mai̱ mwa mwa, di̱ngi̱n ma sengangge.  
\v 33 Daabu na ma nu̱u̱ bunam bago̱n mo̱ ke̱we̱ ci̱ka ku n nu̱u̱ bunam mau ru?>  
\v 34 Ne̱re̱ wu gi̱ra yo̱ wii suko wang, a manni̱ ke̱we̱ wii jaru̱m, nu̱wa ba turongo ko̱po̱ ka yar ci̱ne̱ dwii mwa mwa.>> 
\p  
\v 35 <<To̱o̱ tu n Mbaa mi wu diyou ni̱nga manu we̱i̱ kana wo̱no̱ mbi̱re̱ ko̱po̱ ka bu paraman sukom kambaa yi̱ gaanggu̱ kiino. 
\c 19  
\s1 Ji̱gu̱ laabwiya 
\p  
\v 1 Pu Yesu mata ce̱gu̱ to̱o̱ yi̱ri̱ngi̱, a du Galili mwati̱ si̱ma Yudaya bo̱nggo̱ wu kangge̱ wu you ku Urdun.  
\v 2 Nu̱wa tum po̱ng yo̱ pwii a mi̱ra pma yi̱langa. 
\p  
\v 3 Parisayo bu kangga baanga bo̱nggo̱ yo̱u̱ ba cu̱u̱ yo̱, pma pi̱ra ki̱n, <<Te̱e̱re̱ le̱e̱ ki̱n ne̱re̱ ba ji laabwiya nu̱re̱ yo̱ dwii kana ca ru?>>  
\v 4 A nyi̱i̱ le̱e̱ ki̱n, <<Bu ce̱ bu tu balgi̱ ru? <Yake̱ toson taawu̱ Yamba ruu pma nambare̱ yi̱ nu̱re̱,>  
\v 5 pero a ce̱ ki̱n, <Di̱ngi̱n to̱no̱ ne̱re̱ du̱r we̱i̱ mbaa yo̱ yi̱ njaa yo̱ ba ne̱ca bu̱ri̱ yi̱ nu̱re̱ yo̱ pma bu ro̱p bo̱o̱ yo̱o̱ we̱i̱ bu̱ri̱ kiino.>  
\v 6 Pma yaa ro̱p me̱re̱ anda bu̱ri̱ wiino. Di̱ngi̱n to̱no̱ tu Yamba ne̱ca ne̱re̱ ba cwaani ya.>> 
\p  
\v 7 Pma pi̱ra ki̱n, <<Di̱ngi̱n ca Musa sa pma ki̱n ne̱re̱ ba nyi̱i̱ nu̱re̱ yo̱ lakargar jigu laabwiya anda ba mana?>> 
\p  
\v 8 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Musa le̱e̱mbi̱ra bu ji laabwiya nu̱ru̱mba mba di̱ngi̱n gaanggi̱r mbi̱ri̱ cingcing. Anda gwak yaa yi̱to̱ yake̱ taa yo̱u̱.  
\v 9 N wo̱o̱ sagu̱mbi̱ru̱ mi̱n, kana we̱ wu man nu̱re̱ yo̱ ka yaa dwii taari̱ ne̱, ka yikir nu̱re̱ wu kangge̱ a ni̱nggu̱ taari̱ yi̱ yo̱.>> 
\p  
\v 10 Kwati̱mba ya se̱e̱ ki̱n, <<Ka cu̱du̱ nu̱re̱ yi̱ bwi̱yate̱ yi̱to̱ we̱i̱, kujang ne̱re̱ ba ni̱ngi̱ yaa laabwiya.>> 
\p  
\v 11 Yesu sa pma ki̱n, <<Yaa kana we̱ wu le̱e̱ we̱i̱ yi̱ do̱o̱ ci̱ye̱i̱, ko̱po̱ pma bu Yamba kalanga pma wa.  
\v 12 Bu kangga ni̱nga bu laabwiya di̱ngi̱n twii po̱le̱, nu̱wa bi pma yi twii, bu kangga nu̱wa diin pma, pero bu kangga di̱ngi̱n lau̱ ku diyou. Anda kana we̱ wu le̱e̱ we̱i̱ yi̱ do̱ ci̱ye̱i̱, ba le̱e̱ yi̱ to̱no̱.>> 
\s1 Bakwaraa yi̱ Yesu 
\p  
\v 13 Nu̱wa bu kangga de̱e̱ bakwaraa bu nyi̱ti̱ti̱ wa bo̱nggo̱ Yesu ba ce̱rman pma wari ba ce̱man pma ku̱ru̱. Anda kwati̱mba ya ye̱ra pma bu de̱e̱ bwii. 
\p  
\v 14 Yesu ce̱ ki̱n, <<Bu du bakwaraa bu nyi̱ti̱ti̱ wa ba baanga bo̱nggo̱ mu bu jari ya pma, di̱ngi̱n lau̱ ku diyou kwii ku pma bu ci̱ka bakwaraa wa.>>  
\v 15 Pu ce̱rman pma wari, a mwati̱. 
\s1 Bwiyaka wu yi̱ gi̱na 
\p  
\v 16 Ne̱re̱ wu kangge̱ baa bo̱nggo̱ Yesu a pi̱ra ki̱n, <<Ku̱lu̱me̱, tu nyaayi ye̱i̱ ca tu ni̱ngu̱ we̱i̱ palaka n nyi̱ngga pi̱i̱ma bu yaa mati̱gu̱ wa?>> 
\p  
\v 17 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Di̱ngi̱n ca ma pi̱rangge̱ tu nyaayi? Wu nyaa wiino ti̱bak, ka ma kasi̱ pi̱i̱ma bu yaa mati̱gu̱, ma ni̱nga po̱ngo̱ndi̱ yi̱ te̱e̱ri̱ngi̱.>> 
\p  
\v 18 Ne̱re̱ wii pi̱ra ki̱n, <<Twii, to̱no̱?>> 
\p Yesu nyi̱i̱ le̱e̱ ki̱n, <<Ma ji̱ri̱ ya ne̱re̱, ma ni̱ngi̱ ya taari̱, ma ni̱ngi̱ ya kuwii, ma nyi̱i̱ ya se̱e̱daki̱ leendi,  
\v 19 ma nyi̱i̱ gi̱ru̱ mbaa mo̱ yi̱ njaa mo̱, pero ma kangman bapun mo̱ ci̱ka bu̱ri̱ mai.>> 
\p  
\v 20 Ne̱re̱ wii ce̱ ki̱n, <<N po̱ng to̱o̱ te̱e̱ri̱ngi̱ mwa mwa, tu nyona ca?>> 
\p  
\v 21 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Ka ma kasi̱ ma yo̱o̱ ne̱re̱ wu twanga we̱i̱, mwati̱ ma cuu gi̱na mo̱ ma cwaanga baku̱u̱lu̱wa, ma nyi̱nggu̱ we̱i̱ gi̱na a pwii diyou Yambau̱. Anda ma baa ma po̱nggu̱we̱.>> 
\p  
\v 22 Pu bwiyaka wii nu̱wa yi̱to̱, a mwati̱ yi̱ bwiyang gaanggu̱, di̱ngi̱n yi̱ gi̱na wang. 
\p  
\v 23 Yesu sa kwati̱mba ya ki̱n, <<N sagu̱mbu̱ru̱ ji̱re̱, ni̱ng we̱i̱ bu̱u̱ wang ne̱re̱ wu yi̱ gi̱na ba diiro lau̱ ku diyou.  
\v 24 Pero n sagu̱mbu̱ru̱, ni̱ng we̱i̱ le̱e̱le̱e̱ nggela ba diiro bo̱u̱ li̱ppi̱rau̱, yi̱ ku̱ bagi̱na ba diiro lau̱ Yambau̱.>> 
\p  
\v 25 Pu kwati̱mba ya nu̱wa yi̱to̱, pma riyanga bu̱ri̱ wang pero a pi̱ra ki̱n, <<Ka yi̱to̱ we̱i̱ wu nyi̱nggu̱ we̱i̱ mi̱rma we̱?>> 
\p  
\v 26 Yesu su̱wa pma a ce̱ ki̱n, <<To̱o̱ gwala di̱mbi̱ri̱ ne̱ri̱, anda yaa tu gwala di̱mbi̱ri̱ Yambai̱.>>  
\v 27 Bitrus le̱e̱ ki̱n, <<Yi du kana ca yi po̱ngmi̱na. Tu yi ki̱nggu̱ we̱i̱ ca?>>  
\v 28 Yesu sa pma ki̱n, <<N sagu̱mbu̱ru̱ ji̱re̱i̱, jo̱r du kana ca waatu̱ we̱i̱ bu̱ri̱ pu̱ci̱, pero pu Bo̱l Ne̱re̱ si̱i̱nu̱ we̱i̱ candu̱ lau̱ yo̱u̱ ku yi̱ yi̱lau̱, mba bu po̱nggu̱ wa bu si̱i̱nu̱ we̱i̱ canni̱ndi̱ lau̱ri̱ kwap su̱r ro̱p bu ni̱ngamanu̱ we̱i̱ bali̱ duuri kwap su̱r ro̱p tu Israila.  
\v 29 Anda kana we̱ wu du laandi kana ci̱yamba bu nambi̱rmba kana nu̱ru̱mba wa, kana mbaate̱ kana njaate̱ kana kwaraa kana ko̱o̱ndi̱ di̱ngi̱n mi nyi̱nggu̱ we̱i̱ tum yo̱u̱ daa wo̱o̱n pero nyi̱nggu̱ we̱i̱ pi̱i̱ma bu yaa mati̱gu̱ wa.  
\v 30 Anda nu̱wa tum bu gawu̱ri̱yo̱ wa, yo̱o̱ we̱i̱ bu go̱ro̱yo̱ wa, pero nu̱wa tum bu go̱ro̱yo̱ wa yo̱o̱ we̱i̱ bu gawu̱ri̱yo̱ wa. 
\c 20  
\s1 Balanggu̱ ci̱ye̱i̱ a dwii bawura 
\p  
\v 1 <<Lau̱ ku diyou ci̱ka ne̱re̱ wu yi̱ ko̱ndo̱u̱ wu twiyo yi̱ pinu ki̱lang a nyi̱i̱ nu̱wa wu̱rai̱ a ko̱ndo̱u̱ yo̱u̱.  
\v 2 A nu̱wanga yaru̱ we̱i̱ pma dinari a nyanggu̱, a te̱ni̱ pma ko̱ndo̱u̱ yo̱u̱. 
\p  
\v 3 <<Ku jo̱r du to̱ro̱ ni̱nga a twiyo a ko̱ bu kangga pi̱si̱ndi̱ lummo yaa tu ni̱nggi̱.  
\v 4 A sa pma, <Mba mwa bu ambi̱ra bu ni̱nga wu̱rai̱ a ko̱ndo̱u̱ mu, n ya mbi̱ru̱ we̱i̱ tu daayai.>  
\v 5 Di̱ngi̱n to̱no̱ pma aanda ba ni̱nga wu̱rai̱ a ko̱ndo̱u̱ wii. 
\p <<Yo̱ pero mwati̱ yi̱ cu̱di̱ nyanggu̱ yi̱ jo̱r du kunong do̱ng, a ni̱nga ci̱ka ku co̱nggo̱ nu̱wanga.  
\v 6 Pu jo̱r du nu̱wo̱ wu nyambi̱ranggu̱ ni̱ngau̱, pero a twiyo a nyi̱ngga bu kangga pi̱ti̱ndi̱. A pi̱ra pma ki̱n, <Di̱ngi̱n ca bu pi̱ti̱ndi̱ pi̱na yaa tu bu ni̱nggi̱ nyanggu̱ mwa mwa?> 
\p  
\v 7 <<Pma nyi̱i̱ le̱e̱ ki̱n, <Yaa ne̱re̱ wu de̱e̱ yiro wu̱rai̱.> 
\p <<A sa pma ki̱n, <Mba mwaasi̱ bu ambi̱ra bu ni̱nga wu̱rai̱ a ko̱ndo̱u̱ mu.> 
\p  
\v 8 <<Pu nyambi̱ranggu̱ ni̱ngau̱ ne̱re̱ wu ko̱ndo̱u̱ we̱yo̱u̱ yi̱we̱ ne̱re̱ wu su̱gu̱ ko̱ndo̱u̱ a se̱e̱ ki̱n, ba yi̱we̱ nu̱wa bu ni̱nggu̱ wu̱rai̱ bwi̱i̱, toso bu baa yi̱ go̱ro̱u̱ wa a be̱e̱ bu gawu̱ri̱yo̱ wa.> 
\p  
\v 9 <<Nu̱wa bu toso wu̱rai̱ jo̱r du nu̱wo̱ wu nyambi̱ranggu̱ pma baanga nu̱wa nyi̱i̱ pma dinari.  
\v 10 Di̱ngi̱n to̱no̱ bu nu̱wa nyi̱i̱ wu̱rai̱ gawu̱ri̱yo̱ wa, pma baanga dangani̱ ki̱n nu̱wa yaru we̱i̱ pma tum gwala we̱i̱ bu go̱ro̱yo̱ wa. Anda kana wo̱no̱ pmo nu̱wa nyi̱i̱ dinari.  
\v 11 Pu nu̱wa nyi̱i̱ pma nyi̱na, pma toso jangga ce̱u̱ bo̱nggo̱ ne̱re̱ wu si̱ma bo̱o̱ ya.  
\v 12 Pma ce̱ ki̱n, nu̱wa bu baa yi̱ go̱ro̱ bo̱o̱ pma ni̱nga wu̱rai̱ nyan jo̱r du wiino anda bu ya yiro kiino yi̱ pma yo bu yar nyanggu̱ wu̱rai̱ wa.> 
\p  
\v 13 <<A sa wu kanggi̱ pma ki̱n, <Basi̱n mi, yaa ku n ni̱nga dwal ji̱re̱. Ma le̱e̱ bu mi̱n ma ni̱nggu̱ we̱i̱ wu̱rai̱ nyan dinari ru?  
\v 14 Ma yi̱ tu nu̱wa ya mi̱na ma mwatanga. N kasi̱ n ya ne̱re̱ wu baa yi̱ go̱ro̱ yi̱to̱ mwaasi̱ ci̱ka ku n ya mi̱na.  
\v 15 N puu ni̱nggu̱ tu n kasi̱ yi̱ ke̱n mi ru? Ma ni̱nggu̱ bwiu di̱ngi̱n mi ni̱i̱ ru? 
\p  
\v 16 <<Di̱ngi̱n to̱no̱, nu̱wa bu go̱ro̱yo̱ wa, yo̱o̱ we̱i̱ bu gawu̱ri̱yo̱ wa, pero nu̱wa bu gawu̱ri̱yo̱ wa yo̱o̱ we̱i̱ bu go̱ro̱yo̱ wa.>> 
\s1 Yesu ce̱ ci̱ye̱i̱ a dwii bo̱o̱ri̱ ye̱i̱ ku kunong 
\p  
\v 17 Pu Yesu wo̱o̱ mwatugu Wurcalima, a de̱ kwati̱mba ya bu kwap su̱r ro̱p bwii a bo̱nggo̱ a sa pma ki̱n,  
\v 18 <<Yi mwatangu Wurcalima anda nu̱wa cuuru we̱i̱ Bo̱l Ne̱re̱ bo̱nggo̱ bagi̱raa kuruwa yi̱ ku̱lu̱mba te̱e̱ri̱ngi̱ wa. Pma mwarmanu̱ we̱i̱ yo̱ bal bo̱o̱ri̱,  
\v 19 ba nyi̱i̱ yo̱ war nu̱wa bu yaa yo̱o̱gi̱ nu̱wa bu Yudaya wa, pma ni̱ngamanu̱ we̱i̱ yo̱ nyasi̱, waci̱ru̱ we̱i̱ pero pi̱i̱ni̱ we̱i̱ ye̱u̱. Nyanggu̱ ku kunong wuni we̱i̱ yi̱ pi̱i̱ma.>> 
\s1 Senggo njaa Yakubu yi̱ Yohanna 
\p  
\v 20 Go̱ro̱ yi̱to̱ njaa kwaraa Sabadi baa gawu̱r Yesu kem yi̱ kwaraa ya a kun kwiyei a senggo yo̱ ba ni̱ngaman yo̱ yi̱ri̱ tu kanggi̱. 
\p  
\v 21 Yesu pi̱ra ki̱n, <<Tu ma kasi̱gu̱ ca?>> 
\p A se̱e̱ ki̱n, <<Ma nyi̱i̱ kwaraa muwa bu ro̱p bi̱naa pi̱su̱ wu nyaayi a lau̱ mau, wu wiino a wai mau wu je̱u̱ wu kangge̱ a wai mau wu miyu.>> 
\p  
\v 22 Yesu sa pma ki̱n, <<Bu so̱m bu tu bu senggu. Bu puu we̱i̱ ti̱i̱gu̱ ku̱u̱le̱ wu n ti̱i̱ we̱i̱ ru?>> 
\p Pma le̱e̱man yo̱ ki̱n, <<Yi puu we̱i̱.>> 
\p  
\v 23 Yesu sa pma ki̱n, <<Bu ti̱i̱ we̱i̱ ku̱u̱le̱ wu n ti̱i̱ we̱i̱. Anda n yaa di̱mbi̱re̱ n se̱ka wu si̱nu̱ we̱i̱ wai wu je̱u̱ mu kana wai wu miyu mu. So̱o̱ pi̱si̱ndi̱ ko̱po̱ bu Mbaa mi me̱ne̱man pma wa.>> 
\p  
\v 24 Ku kwati̱mba bu kwap bwii nu̱wa yi̱to̱ pma sukongo yi̱ ci̱yamba bu ro̱p bwii.  
\v 25 Yesu yi̱we̱ pma mwa mwa a ce̱ ki̱n, <<Bu so̱ma nu̱wa bu je̱e̱gi̱ lau̱ dwii nu̱wa bu yaa yo̱o̱gi̱ nu̱wa bu Yudaya wa ju̱ku̱r nu̱wa pma lau̱ pero bagi̱raa pma je̱e̱ lau̱ dwii pmai.>>  
\v 26 Anda yaa yi̱to̱ yi̱ mba. Wu kasi̱ ba yo̱ wu gi̱ra a cu̱di̱ mbi̱ri̱, ba yo̱o̱ ke̱we̱ mbi̱re̱.  
\v 27 Kana we̱ wu kasi̱ ba yo̱o̱ wu gawu̱ri̱yo̱ tagi̱ ba yo̱o̱ ke̱we̱ mbi̱re̱,  
\v 28 ci̱ka ku Bo̱l Ne̱re̱ baa bu nu̱wa ba yo̱o̱ ke̱waa ya anda a baa ba yo̱o̱ ke̱we̱ nu̱wa pero ba nyi̱i̱ pi̱i̱ma ya, palaka ba mi̱ra nu̱wa tum. 
\s1 Kerma ro̱p ko̱ si̱ma 
\p  
\v 29 Pu Yesu yi̱ kwati̱mba ya dugu Yeriko, nu̱wa tum po̱ng pma.  
\v 30 Kerma ro̱p pi̱si̱ndi̱ gi̱ngu̱ nyinou, pu nu̱wa ki̱n Yesu cwiigu, pma ni̱nga duwai ki̱n, <<Mbaa Wu Gi̱ra, Bo̱l Dawud, nu̱u̱ bunam yiru!>> 
\p  
\v 31 Nu̱wa bu ku̱ranggi̱ bu̱ri̱ bwii a ye̱ra pma ba si̱n si̱ye̱ndi̱ to̱k, anda pma cwata duwai ki̱n, <<Mbaa Wu Gi̱ra, Bo̱l Dawud nu̱u̱ bunam mu.  
\v 32 Yesu a ti̱n ti̱yau̱ a yi̱ pma, a sa pma ki̱n, <<Tu bu kasi̱ n ni̱ngambi̱ra ca?>>  
\v 33 Pma le̱e̱man yo̱ ki̱n, <<Mbaa Wu Gi̱ra yi kasi̱ yi ko̱ si̱ma.>>  
\v 34 Yesu nu̱u̱ bunam pmau, a mwaanga nundi pmai. Yo̱ko̱ yo̱ko̱ pma ko̱ si̱ma, pma po̱ng yo̱. 
\c 21  
\s1 Yesu aara Wurcalima 
\p  
\v 1 Pu Yesu yi̱ kwati̱mbaya ni̱nga ne̱m Wurcalima pma baanga gwe̱i̱ Betpaji a dwii Cing Souri Setun, Yesu tum kwati̱mba ya ro̱p,  
\v 2 a sa pma ki̱n, <<Bu ambi̱ra gwe̱i̱ du gawu̱ri̱ mbi̱ri̱, ka bu tengma bu kwe̱e̱ we̱i̱ bako̱ro̱ twalgi pwii, yi̱ twiyaa yo̱ bo̱nggo̱ yo̱u̱. Bu pe̱ra bu de̱nggu̱we̱.  
\v 3 Ka kana we̱ sambi̱r ci̱ye̱i̱, bu se̱e̱ mi̱n, <Mbaa Wu Gi̱ra kasi̱gu̱,> dumbiri we̱i̱ bu de̱e̱ yo̱ko̱ yo̱ko̱. 
\p  
\v 4 To̱o̱ yi̱ri̱ngi̱ ni̱ngwa, palaka ba twanga tu banabi̱ ce̱i̱, 
\q1  
\v 5 <<Bu sa nu̱wa bu Wurcalima mi̱n, 
\q2 <Bu ko̱, balaa mbi̱re̱ baaggu 
\q1 yi̱ dwii du ci̱nggai̱ geenggi a dwii bako̱ro̱, 
\q2 a dwii twiyaa bako̱ro̱.>>> 
\p  
\v 6 Kwati̱mba ya bwii mwatanga ni̱nga ci̱ka ku Yesu sa pma.  
\v 7 Pma de̱e̱ bako̱ro̱ yi̱ twiyaa bako̱ro̱, pma ke̱naman gatanggamandi pmai dwii bako̱ri̱ swii, Yesu si̱i̱na dwii gatanggamandi twii.  
\v 8 Nu̱wa tum ni̱nga pu ke̱ne̱nggu̱ gatanggamandi pmai a nyinou a gawu̱ri̱ ye̱i̱, anda bu kangga pma kaca ye̱ndi̱ souri a ke̱namana nyinou.  
\v 9 Nu̱wa tum bu gawu̱ri̱ ye̱i̱ wa yi̱ bu po̱nggu̱ yo̱ go̱ro̱ wa, pma ni̱nggu̱ duwai ki̱n, 
\q1 <<Yi te̱ranga bo̱l Dawud! 
\q1 Wuure bo̱nggo̱ yo̱ wu bagu̱ mi̱ri̱nggi̱ din Mbaa Wu Gi̱rai̱. 
\q1 Yi te̱ranga Yamba wu wo̱o̱ diyou.>> 
\p  
\v 10 Pu Yesu diiro Wurcalima, mwa mwa gwe̱i̱ dwii pi̱ro̱, a ni̱nggu̱ pi̱ra ki̱n, <<Wo̱o̱ we̱?>> 
\p  
\v 11 Nu̱wa bu tum bwii nyi̱i̱ le̱e̱ ki̱n, <<Wo̱o̱ Yesu banabi̱ wu baa Nasaret du Galili.>> 
\s1 Yesu mi̱ri̱nggi̱ Laa Yambau̱ 
\p  
\v 12 Yesu diiro Laa Yambau̱ a ke̱ke̱nga nu̱wa bu cuugu yi̱ te̱nggu̱ yi̱ri̱ngi̱ wa a pwii. A su̱kaman si̱yau̱ tebur nu̱wa bu waki̱ ke̱n wa, yi̱ pi̱si̱ndi̱ nu̱wa bu cuugu bamori Masar wa.  
\v 13 A sa pma ki̱n, <<Balgi̱, laa mu nu̱wa yi̱ri̱ we̱i̱ ki̱n, laa ku̱ru̱, anda mba bu de̱e̱ bu yo̱o̱ laa kuuwau.>> 
\p  
\v 14 Kermo yi̱ gu̱wo̱ngi̱ baanga bo̱nggo̱ yo̱ a laa Yambau̱, a mi̱ra pma yi̱langa.  
\v 15 Pu bagi̱ra kuruwa yi̱ ku̱lu̱mba te̱e̱ri̱ngi̱ wa ko̱ yi̱ri̱ngi̱ ri̱yandi̱ bu̱ri̱ tu ni̱ngai̱ pero nu̱u̱ tu bakwara bu ni̱nggu̱ bu̱ri̱ de̱gde̱g a mi̱ri̱nggi̱ laa Yambau̱ ce̱gu̱ ki̱n, <<Yi te̱ranga Bo̱l Dawud, Hossana!>> Pma sukongo. 
\p  
\v 16 Pma pi̱ra ki̱n, <<Ma nu̱gu̱ tu bakwara bo̱o̱ ce̱gu̱ ri̱?>> Yesu nyi̱i̱ le̱e̱ ki̱n, <<O̱ng, yaa ku bu ce̱ mi̱ri̱nggu̱ lakargar ru? <Wii mo̱ ma ju̱ku̱ bakwaraa bu nyi̱ti̱ti̱ wa yi̱ bweegaa ba te̱ra mi̱na.>>> 
\p  
\v 17 A du pma mwati̱ gwe̱i̱ Betani a daa pwii. 
\s1 Yesu se̱mtanga sou pwalgu̱ 
\p  
\v 18 Yi̱ pinu ki̱lang, pu waati̱gu̱ gwe̱i̱ Yesu nu̱u̱ ju̱ne̱.  
\v 19 A ko̱ sou pwalgu̱ ku kanggu̱ a nyinou a aara bo̱nggo̱ yo̱u̱ anda yaa tu nyi̱nggai̱ bur wandi̱. Bur a ce̱ ki̱n, <<Yama ma peri ya twiyagu me̱re̱!>> Bu̱ri̱ sou kwii ku̱su̱wa ki̱nangu̱. 
\p  
\v 20 Pu kwati̱mba ya ko̱ yi̱to̱ pma ri̱yanga bu̱ri̱. Pma ni̱nga pi̱ra ki̱n, <<A ni̱ngwa nye̱ sou pwalgu̱ ko̱o̱ ku̱su̱wa ki̱ne̱ngu̱ yi̱to̱? 
\p  
\v 21 Yesu nyi̱i̱ pma le̱e̱ ki̱n, <<N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱i̱, ka bu le̱e̱ ji̱re̱, bu ni̱nga bu gaanggi̱r ro̱p ne̱, bu ni̱ng we̱i̱ tu ni̱ngwa yi̱ sou pwalgu̱ ko̱o̱, anda bu̱ri̱ to̱o̱ yi̱ wundu ne̱, bu saru we̱i̱ ci̱ngu̱ ki̱na mi̱n, <Mwati̱, ma manni̱ bu̱ri̱ mai kali̱nggu̱,> ni̱ngdu̱ we̱i̱.  
\v 22 Ka bu le̱e̱ ji̱re̱, kana ca tu bu senggo mi̱ri̱nggu̱ ku̱ru̱ bu ki̱nggu̱ we̱i̱. 
\s1 Pi̱ra dwii di̱mbi̱re̱ Yesu 
\p  
\v 23 Yesu diiro laa Yambau̱, pu wo̱o̱ ju̱ku̱gu̱ yi̱ri̱ngi̱ nu̱wa, bagi̱raa kuruwa wa yi̱ bagi̱raa nu̱wa wa a baanga bo̱nggo̱ yo̱u̱, pma pi̱ra ki̱n, <<Ma ni̱nggu̱ to̱o̱ yi̱ri̱ngi̱ yi̱ di̱mbi̱re̱ we̱? Pero wu nyi̱i̱mi̱n wo̱o̱ di̱mbi̱re̱ we̱? 
\p  
\v 24 Yesu nyi̱i̱ pma le̱e̱ ki̱n, <<Mi mwa n pi̱rambi̱ri̱ we̱i̱ pi̱ra wiino, ka bu nyi̱i̱nggi̱ le̱e̱ n sambi̱ri̱ we̱i̱, ka ni̱nggu̱ ti̱na yi̱ri̱ngi̱ yi̱ di̱mbi̱re̱ we̱ we̱i̱.  
\v 25 Di̱mbi̱re̱ wu Yohanna Ni̱ngi̱ Bati̱si̱ma yi̱ to̱no̱, a baa pi̱yau̱, a baa diyou ru? A baa bo̱nggo̱ ne̱re̱ ru?>> 
\p Pma ni̱nga pu dangandi̱ a cu̱du̱ pmai ki̱n, <<Ka yi ce̱ mi̱n, a baa diyou, pi̱rayi̱ri̱ we̱i̱ ki̱n, <Di̱ngi̱n ca bu kwaa le̱e̱gu̱ ji̱re̱ yi̱ yo̱?>  
\v 26 Anda ka yi ce̱ mi̱n, <A baa bo̱nggo̱ ne̱ru̱,> yi nu̱gu̱ gwasi̱ nu̱wa di̱ngi̱n pma mwa mwa le̱e̱ ki̱n Yohanna twii banabi̱.>> 
\p  
\v 27 Di̱ngi̱n to̱no̱ pma nyi̱i̱ le̱e̱ Yesu ki̱n, <<Yi so̱m bu.>> 
\p A sa pma ki̱n, <<Mi mwa n sambi̱re̱ ka n ni̱nggu̱ to̱o̱ wo̱o̱ yi̱ di̱mbi̱re̱ we̱ we̱i̱.>> 
\s1 Balanggu̱ ci̱ye̱i̱ a dwii bakwara ro̱p 
\p  
\v 28 <<Bu danggu̱ we̱i̱ mi̱n ca, a dwii ci̱ye̱i̱ di̱na? Wo̱o̱ yi̱ ne̱re̱ wu yi̱ ba kwaraa ro̱p. A aara bo̱nggo̱ wu gawu̱ri̱yo̱ a se̱e̱ ki̱n, <Amna ma ni̱nga wu̱rai̱ a ko̱ndo̱u̱.> 
\p  
\v 29 A nyi̱i̱ le̱e̱ ki̱n, <N anggi̱.> Anda cwata go̱ro̱u̱ a waka dangandi̱ ye̱i̱ a aara. 
\p  
\v 30 <<Mbaate̱ wii aara bo̱nggo̱ wu kanggi̱ wii a se̱e̱ ci̱ka ku co̱nggo̱ ce̱u̱, a le̱e̱ man yo̱ ki̱n, <N anggu we̱i̱ mbaa,> anda yaa ku aarau. 
\p  
\v 31 <<Wu ni̱nga tu mbaa pma kasi̱gu̱ we̱ cu̱du̱ pmai?>> 
\p Pma nyi̱i̱ le̱e̱ ki̱n, <<Wu gawu̱ri̱yo̱ wii.>> 
\p Yesu sa pma ki̱n, <<N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱ nu̱wa bu yi̱ri̱ janggal yi̱ karmaji̱ndi̱ gi̱ci̱la mbi̱r we̱i̱ tengma lau̱ Yambau̱.  
\v 32 Di̱ngi̱n Yohanna baa ba ju̱ku̱ mbi̱r nyinou ni̱nggu̱ pi̱su̱ wu nyaau a gawu̱ri̱ Yambai̱, bu kwaa le̱e̱gu̱ ji̱re̱, anda nu̱wa bu yi̱ri̱ janggal wa yi̱ karmaji̱ndi̱ pma le̱e̱. Pero kana pu bu ko̱ to̱o̱ yi̱ri̱ngi̱ bu kwaanga bwiiwa yi̱ le̱e̱gu̱ ji̱re̱ yi̱ yo̱. 
\s1 Balanggu̱ ci̱ye̱i̱ a dwii ne̱re̱ wu nyi̱i̱ ko̱ndo̱u̱ inabi 
\p  
\v 33 <<Bu ka twiyau ci̱ye̱i̱ du balanggai̱ du kanggi̱. Wo̱o̱ yi̱ ne̱re̱ wu kangge̱ wu yi̱ ko̱ndo̱u̱, a ruu souri inabi. A wo̱ra yi̱ garu. A wul bo̱u̱ dudu a swe̱li̱ du karkar pu nu̱wa yamnu we̱i̱ gundu inabi pero a mo̱o̱ cire. Bur a du̱u̱ bajo̱mba bu kangga a ni̱nga so̱ngma.  
\v 34 Pu jo̱r wagu̱ inabi ni̱ngau̱, a tu̱m ke̱waa ya a bo̱nggo̱ bajo̱mba bwii, ba yi̱mu̱we̱ yo̱ tutwiyari inabi. 
\p  
\v 35 Bajo̱mba bwii ta ke̱waa bwii, pma buwanga wiino, a ji wu kangge̱ pero bacanga wu kunong.  
\v 36 Bambang a tu̱m ke̱waa bu kangga bo̱nggo̱ pmau gwala bu gawu̱ri̱yo̱ wa, bajo̱mba bwii ni̱nga ci̱ka ku co̱nggo̱ ni̱ngau̱,  
\v 37 Cwata go̱ro̱u̱ a tu̱m bo̱l yo̱ bo̱nggo̱ pmau. A ce̱ ki̱n, <Pma nyi̱i̱ we̱i̱ gi̱ru̱ yake̱ ku twii bo̱l mi ko̱.> 
\p  
\v 38 <<Pu bajo̱mba bwii ko̱ bwi̱ya wii bagu̱, sa bu̱ri̱ pmai ki̱n, <Su̱wa ne̱re̱ wu ko̱ndo̱u̱ wuna yo̱o̱ we̱i̱ weyau wo̱o̱ baayi, yama yi jiyo palaka gina yo̱ ba yo̱o̱ woyire.>  
\v 39 Di̱ngi̱n to̱no̱ pma ta yo̱, a baci̱we̱ si̱ye̱i̱ go̱ro̱ ko̱ndo̱u̱ wii, a jiyo. 
\p  
\v 40 Di̱ngi̱n yi̱to̱ ka ne̱re̱ wu ko̱ndo̱u̱ wayau̱ baayi, ni̱ngu̱ we̱i̱ nye̱ yi̱ bajo̱mba bwii?>> 
\p  
\v 41 Pma ce̱ ki̱n, <<Ne̱re̱ wii baa lacu̱we̱i̱ bajo̱mba bu bwiiwa bwii yi̱ bo̱o̱ri̱ du yi̱ buwi, ba nyi̱i̱ ko̱ndo̱u̱ wii bajo̱mba bu kangga bu nyi̱i̱ we̱i̱ yo̱ tutwiyari ko̱ndo̱u̱ wa ka jo̱r wagu̱ ni̱ngi̱.>> 
\p  
\v 42 Yesu sa pma ki̱n, <<Bu ce̱ bu mi̱ri̱nggu̱ Lakargar Yamba ru? 
\q1 <Swe̱li̱ du mwe̱e̱mba kwaanga, 
\q2 a yo̱o̱ swe̱li̱ du nyaayi du mwe̱e̱mba ce̱nna ge̱nge̱lte̱. 
\q1 To̱o̱ ni̱nggu̱ Mbaa Wu Gi̱ra, 
\q2 to̱o̱ yi̱ri̱ngi̱ ri̱yandi̱ bu̱ri̱ a nundi yiri.> 
\p  
\v 43 Di̱ngi̱n to̱no̱, n sagu̱mbi̱ru̱ nu̱wa de̱manu̱ we̱i̱ lau̱ Yambau̱ bo̱nggo̱ mbi̱ru̱, ba nyi̱i̱ nu̱wa bu twiya we̱i̱ tutwiyari ye̱i̱.  
\v 44 Kana we̱ wu yaramana swe̱le̱ dwii re̱pu̱ru̱ we̱i̱ cuk cuk, pero ka swe̱le̱ dwii yarman kana we̱, ko̱o̱ we̱i̱ pwangge̱ li̱ngli̱ng ci̱ka miima.>> 
\p  
\v 45 Pu bagi̱raa kuruwa yi̱ Parisayo nu̱u̱ ci̱ye̱i̱ du balanggai̱ du Yesu ce̱i̱, pma ku̱ranga ki̱n a ce̱gu̱ pma.  
\v 46 Pma kasa ba ta yo̱, anda pma nu̱u̱ gwasi̱ nu̱wa di̱ngi̱n pma de̱e̱ twii banabi̱. 
\c 22  
\s1 Balanggu̱ ci̱ye̱u̱ a dwii waandi laabwiya 
\p  
\v 1 Yesu sa pma ci̱ye̱i̱ du balanggai̱ do̱ng ki̱n,  
\v 2 <<Lau̱ ku diyou ci̱ka balaa wu ni̱nga waandi laabwiya bo̱l yo̱.  
\v 3 A tu̱m ke̱waa ya ba sa ci̱ye̱i̱ nu̱wa bu yo̱ yi̱we̱ wa ba baanga waandi swii anda pma kwaanga baaggu. 
\p  
\v 4 <<A pero tu̱m ke̱waa bu kangga a ce̱ ki̱n, Bu sa pma bu nu̱wa sa pma ci̱ye̱i̱ wa mi̱n n mata me̱ne̱nggu̱ je̱e̱ndi̱. N laca go̱mto̱ro̱ngi̱ yi̱ tanggi mi su mwalanggi̱, kana ca me̱ne̱nggi̱. Bambe̱ waandi laabwiya.> 
\p  
\v 5 <<Anda pma yaa ku ka twiyau, pma mwatanga, bu kangga aanda ko̱ndo̱u̱, bu kangga aanda lummo.  
\v 6 Bu kangga taa ke̱waa bwii a turongo pma, a laca pma.  
\v 7 Balaa wii suko wang. A tu̱m kacara ya laca nu̱wa bu laca ke̱waa bwii, a taa gwe̱i̱ dwii mwa mwa. 
\p  
\v 8 <<Pero a sa ke̱waa ya bu tu̱ma bwii ki̱n, <Waandi laabwiya si̱na ci̱pi̱gi̱ anda nu̱wa bu n gi̱ci̱la n tu̱m man pma wa pma yinnibu ba baanga.  
\v 9 Ambi̱ra nyindi su mi̱ri̱nggi̱ gwe̱i̱ bu sa ci̱ye̱i̱ kana we̱ wu bu nyi̱ngga ba baa waandi si̱na.>  
\v 10 Di̱ngi̱n to̱no̱ ke̱waa bwii mwati̱ a po̱nggu̱ nyindi a ku̱ranga nu̱wa mwa mwa bu nyi̱ngga wa, bu nyaa wa yi̱ bu bwi̱i̱ wa, laa laabwiya twangwa yi̱ ru̱nggu̱wa. 
\p  
\v 11 <<Pu balaa diiro ba ko̱ ru̱nggu̱wa, a ko̱ ne̱re̱ wu kangge̱ wu yaa se̱e̱ laabwiya.  
\v 12 A pi̱ra ki̱n, <Basi̱nte̱, a ni̱ng we̱i̱ nye̱ ma dimmuwe pi̱na yaa se̱e̱ laabwiya?> Ne̱re̱ wii yaa pu̱u̱na. 
\p  
\v 13 <<Balaa wii sa ke̱waa ya bu su̱gu̱ pma bwii ki̱n, <Twala wari yi̱ mwari ma yikiyo twalange̱ ma manna pu yi̱ ku̱mji̱la, pma jii we̱i̱ wiindi yi̱ dumonggu nyi̱yau̱.> 
\p  
\v 14 <<Nu̱wa bu nu̱wa yi̱yanga wa tum, anda bu nu̱wa se̱ka wa banyi̱na.>> 
\s1 Yagu janggal Balaa Kaisar 
\p  
\v 15 Bu̱ri̱ Parisayo twiyongo twalange̱ a kasa nyindi, ba ciman Yesu tandau a bo̱nggo̱ ce̱u̱ ye̱i̱.  
\v 16 Pma suka kwati̱mba pma kem yi̱ nu̱wa Hiridus wa pma ce̱ ki̱n, <<Ku̱lu̱me̱, yi so̱ma mai ji̱re̱. Pero ma ju̱ku̱r nyinou Yambau̱ yi̱ ji̱re̱, ma yaa se̱ki̱ nu̱wa, ma de̱ nu̱wa mwa mwa wai̱yo̱u̱ wiino.>>  
\v 17 Yo̱ko̱ sa yiro, a ko̱gu̱ mo̱u̱ ci̱maci̱ma yi ya janggal Balaa Kaisar ru, ba yari̱ ya ru?>> 
\p  
\v 18 Yesu so̱m dangandi̱ pmai tu bwi̱i̱, a ce̱ ki̱n, <<Mba nu̱wa bu yi̱ batal wa, di̱ngi̱n ca bu kasi̱ bu ciingin mu tandau?  
\v 19 Bu ju̱ku̱nggi̱ ke̱n du nu̱wa yari̱ janggal dwii.>> Pma de̱ nyi̱i̱ya,  
\v 20 a ce̱ ki̱n, <<Wekilei yi̱ din di̱naa du we̱i̱?  
\v 21 Pma ce̱ ki̱n, <<Do̱o̱ du Balaa Kaisar.>> A sa pma ki̱n, <<Bu nyi̱i̱ Balaa Kaisar tu yo̱o̱gi̱ tu Balaa Kaisar, pero bu nyi̱i̱ Yamba tu yo̱o̱gi̱ tu Yambai̱.>>  
\v 22 Pu pma nu̱wa yi̱to̱ pma ri̱yanga bu̱ri̱. Di̱ngi̱n to̱no̱ pma mwatanga. 
\s1 Pi̱ra dwii wunonggu bo̱o̱re̱ 
\p  
\v 23 A dwii nyanggi̱ Sadukayo pma bu ce̱ ki̱n, wunonggu bo̱o̱ru̱ ya, pma baanga bo̱nggo̱ yo̱u̱ yi̱ pi̱ra.  
\v 24 Pma ce̱ ki̱n, <<Ku̱lu̱me̱, Musa sa yiro ki̱n ka ne̱re̱ bo̱o̱ri̱ yaa kwaraa ne̱, tagi̱ ci̱ya yo̱ ba yiki wu̱tu̱ko̱lo̱ wii palaka ba bi̱man kwaraa ci̱ya yo̱.  
\v 25 Bo̱o̱ yi̱ nu̱wa bu kangga nibiyo twii ci̱yamba bu̱ri̱ a cu̱du̱ yi̱ri̱. Wu gi̱ra pmo ni̱nga laabwiya a bwaa, yake̱ ku yaa kwaraa a du nu̱re̱ yo̱ ci̱ya yo̱.  
\v 26 Yi̱to̱ mwaasi̱ a ni̱ngi̱ wa yi̱ wu ro̱p yi̱ kunong be̱ wu nibiyo ye̱i̱.  
\v 27 Cwata go̱ro̱u̱ yo̱u̱, nu̱re̱ wii bwaa.  
\v 28 Yo̱ko̱ sa yiro, yake̱ ku ni̱ng pma mwa mwa pmau nibiyo ko̱, a nyanggu̱ wunggu bo̱o̱re̱, yo̱o̱ we̱i̱ nu̱re̱ we̱?>> 
\p  
\v 29 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Bu li̱yanga di̱ngi̱n bu so̱m bu tu De̱mte̱e̱re̱ ci̱ye̱i̱, pero bu so̱m bu di̱mbi̱r Yamba.  
\v 30 Nyanggu̱ wunonggi bo̱o̱re̱, nu̱wa na ni̱ngi̱ laabwiya, kana ba nyi̱i̱ laabwiya, pma yo̱o̱ we̱i̱ ci̱ka bacamandi a diyou Yambau̱.  
\v 31 Anda dwii wunggu bo̱o̱re̱, bu ce̱ bu tu Yamba sambi̱ra ru? Yamba sambi̱ra ki̱n,  
\v 32 <Mi n Yamba wu Ibrahim, Yamba wu Icaku, Yamba wu Yakubu.> Yo̱ yaa yo̱o̱gi̱ Yamba wu nu̱wa bu bwaanggi̱ wa, yo̱ yo̱o̱gi̱ Yamba nu̱wa bu yi̱ pi̱i̱ma wa.>> 
\p  
\v 33 Pu nu̱wa tum nu̱wa yi̱to̱ pma ri̱yanga bu̱ri̱ yi̱ yi̱ri̱ngi̱ tu ju̱ku̱ya. 
\s1 Te̱e̱re̱ du gwala yi̱ gi̱ru̱ 
\p  
\v 34 Pu Parisayo nu̱wa ki̱n Yesu diini Sadukayo si̱ndi̱ si̱ye̱i̱ to̱k, pma ku̱ranga bu̱ri̱.  
\v 35 Wu wiino pmo wu so̱m te̱e̱ri̱ngi̱ wang, a cu̱u̱ yo yi̱ wuna pi̱ra. 
\p  
\v 36 <<Ku̱lu̱me̱, mi̱ri̱nggi̱ te̱e̱ri̱ngi̱ du gwala yi̱ gi̱ru̱ do̱no̱?>>  
\v 37 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Ma kangman Mbaa Wu Gi̱ra Yamba mo̱ yi̱ gaanggu̱ mo̱u̱ mwa mwa, yi̱ bawei mai mwa mwa yi̱ dangandi̱ mai mwa mwa.  
\v 38 To̱o̱ te̱e̱re̱ du gawu̱ri̱yo̱ yi̱ du gwala yi̱ gi̱ru̱.  
\v 39 Du ro̱p ye̱i̱ ci̱ka do̱o̱ mwaasi̱, <Ma kangman bapun mo̱ ci̱ka bu̱ri̱ mai.  
\v 40 Te̱e̱ri̱ngi̱ yi̱ yi̱ri̱ngi̱ tu banabi̱ndi̱ ju̱ku̱ri̱ mwa mwa daangi̱ laa te̱e̱ri̱ngi̱ tu ro̱p to̱o̱. 
\s1 Kristo to̱o̱ bo̱l we̱ 
\p  
\v 41 Pu bo̱o̱ Parisayo bo̱o̱ ku̱ranggi̱ bu̱ru̱, Yesu pi̱ra pma ki̱n,  
\v 42 <<Bu dangani̱ ca dwii Masiya? Yo̱o̱gi̱ bo̱l we̱?>> 
\p Pma nyi̱i̱ le̱e̱ ki̱n, <<To̱o̱ bo̱l Dawud.>> 
\p  
\v 43 A sa pma ki̱n, <<Di̱ngi̱n ca ki̱, Dawud ce̱ ci̱ye̱i̱ yi̱ di̱mbi̱re̱ Bawei du Walwal, a yi̱gu̱ Masiya ki̱n Mbaa Wu Gi̱ra? Di̱ngi̱n a ce̱ ki̱n, 
\q1  
\v 44 <<Mbaa Wu Gi̱ra sa Mbaa Wu Gi̱ra mi 
\q2 <Si̱n si̱ye̱i̱ wai mu wu je̱u̱ 
\q1 ko̱po̱ ka n diini bace̱mba ma ku̱u̱ mo̱u̱.>>> 
\m  
\v 45 Ka Dawud yi̱ Masiya ki̱n, Mbaa Wu Gi̱ra wai, <<A ni̱ngwa nye̱ ba yo̱o̱ bo̱l yo̱?>>  
\v 46 Yaa wu pu̱n ci̱ye̱i̱, yake̱ kwii nyanggu̱ yaa wu pero ni̱nggu̱ ma yo̱ pi̱randi̱. 
\c 23  
\s1 Yesu tukulanga ku̱lu̱mba te̱e̱ri̱ng wa yi̱ Parisayo 
\p  
\v 1 Yesu sa nu̱wa tum yi̱ kwati̱mba ya ki̱n,  
\v 2 <<Ku̱lu̱mba te̱e̱ri̱ngi̱ wa yi̱ Parisayo bwii pma bu ju̱ku̱ri̱ pi̱ti̱ndi̱ te̱e̱ri̱ngi̱ Musa.  
\v 3 Di̱ngi̱n to̱no̱ bu ni̱nga po̱ngo̱ndi̱ yi̱ kana ca tu sa mbi̱rai̱, bu ni̱ngi̱ ya tu pma ni̱nggi̱, di̱ngi̱n pma yaa po̱ngi̱ tu pma wasi̱gi̱.  
\v 4 Pma de̱r se̱e̱ wu ko̱mbu̱ro̱m ba ce̱rman nu̱wa, anda pma yi̱ri̱ pmai yaa le̱e̱ mwanggu̱ yi̱ wai. 
\p  
\v 5 Pma ni̱ngi̱ kana ca palaka nu̱wa ba ko̱. Pma bali̱ ci̱ye̱i̱ Yambai̱ ba cwaki̱ balayandi gembirendi yi̱ to̱no̱ ba bo̱ngna dwii, pero cwaki̱ nyandi gatanggamandi pmai co̱ku̱ro̱ndi̱.  
\v 6 Pma kasi̱ pi̱si̱ndi̱ bagi̱rai̱ a jo̱r waandi, yi̱ pi̱si̱ndi̱ su kundi wang a gi̱ri̱ndi̱ ku̱ru̱.  
\v 7 Pma kasi̱ nu̱wa ba ci̱ pma a lummondi pero nu̱wa ba yi̱ pma ki̱n ku̱lu̱mba. 
\p  
\v 8 <<Anda mba, bu le̱e̱ ya nu̱wa ba yi̱ mbi̱ra ki̱n, <Ku̱lu̱me̱,> di̱ngi̱n bu bo̱o̱ ku̱lu̱m wiino ti̱bak pero bu yo̱o̱gi̱ ci̱yamba bu̱ri̱.  
\v 9 Pero bu yi̱rya kana we̱ a si̱ma mi̱n, <<Mbaa,> di̱ngi̱n bu bo̱o̱ yi̱ Mbaate̱ wiino ti̱bak a diyou.  
\v 10 Kana mba, bu le̱e̱ ya nu̱wa ba yi̱ mbi̱ra ki̱n, <Ku̱lu̱me̱,> di̱ngi̱n bu wo̱o̱ yi̱ ku̱lu̱m wiino ti̱bak, wii Masiya.  
\v 11 Wu gwala yi̱ gi̱ra cu̱du̱ mbi̱ri̱ ba yo̱ ke̱we̱.  
\v 12 Di̱ngi̱n kana we̱ wu wun dwii ye̱i̱ nu̱wa cingo we̱i̱ anda kana we̱ wu cingo dwii ye̱i̱ nu̱wa nyi̱i̱ we̱i̱ gi̱ru̱. 
\p  
\v 13 <<Bu yo̱o̱gi̱ yi̱ri̱ bunam, mba ku̱lu̱mba te̱e̱ri̱ngi̱ wa yi̱ Parisayo, mba bu yi̱ batal wa! Bu laka nyinou lau̱ ku diyou a bo̱nggo̱ nu̱wau̱, mba yir mbi̱ri̱ do̱ng bu teembiri bu pero bu du pma bu teendu we̱i̱ wa ba teendo. [ 
\v 14 Bu yo̱o̱gi̱ yi̱ri̱ bunam, mba ku̱lu̱mba te̱e̱ri̱ngi̱ wa yi̱ Parisayo, mba bu yi̱ batal wa! Bu ni̱ngaman wu̱tu̱ko̱la lelu, ba yi̱ se̱e̱ wu laandi pmai, pero ce̱ ku̱ru̱ co̱ku̱ro̱k ci̱ka nu̱wa bu nyaa wa. Bo̱o̱ nu̱wa tii we̱i̱ ku̱u̱lu̱ wang.]\f + \fr 23:14 \ft Lakargari̱ndi̱ su kanggi̱ yaa ku bala bo̱nggo̱ ci̱ye̱i̱ kwap su̱r ni̱i̱!\f* 
\p  
\v 15 <<Bu yo̱o̱gi̱ yi̱ri̱ bunam, mba ku̱lu̱mba te̱e̱ri̱ngi̱ wa yi̱ Parisayo mba bu batal wa, bu ke̱re̱ni̱ kana pi̱yau̱ a si̱ma yi̱ you ku piu palaka bu wuu ne̱re̱ wiino ba po̱ng mbi̱ra, pero ka baayi, bu di̱na ba yo̱ bo̱l bwalau gwala mbi̱ra daa ro̱p. 
\p  
\v 16 <<Bu yo̱o̱gi̱ yi̱ri̱ bunam, mba kerma bu taagu̱ nu̱wa wa! Bu ce̱ mi̱n, <Kana we̱ ka we̱re̱ni̱ yi̱ laa Yambau̱ to̱o̱ yi̱ri̱ tu kanggi̱ ne̱ anda ka kana we̱ we̱re̱ni̱ yi̱ sinariya wu laa Yambau̱, ti̱i̱ni̱ we̱ra yo̱.>  
\v 17 Mba bacinba kerma wa, tu gwala yi̱ gi̱ru̱ to̱no̱? Sinariya ru, laa Yambau̱ yo̱ wu diini sinariya ba ni̱nga walwal ru?  
\v 18 Bambang bu ce̱ mi̱n, <Kana we̱ wu we̱re̱nga yi̱ kwaare̱ Yamba to̱o̱ yi̱ri̱ tu kanggi̱ ne̱, anda kana we̱ wu we̱re̱nga yi̱ ni̱i̱ du mi̱ri̱, ti̱i̱ni̱ we̱ra yo̱.>  
\v 19 Mba nu̱wa bu yo̱o̱gi̱ kerma, tu gwala yi̱ gi̱ru̱ to̱no̱? Ni̱i̱ ru, kwaare̱ du diini ni̱i̱ ba ni̱nga walwal ru?  
\v 20 Di̱ngi̱n to̱no̱ kana we̱ wu we̱re̱nga yi̱ kwaare̱ we̱re̱nga yi̱ kana ca tu mi̱ri̱.  
\v 21 Kana we̱ wu we̱re̱nga yi̱ laa Yambau̱ a we̱re̱nga yi̱ to̱no̱ yi̱ wu si̱i̱ mi̱ri̱.  
\v 22 Kana we̱ wu we̱re̱nga yi̱ diyou Yambau̱ a we̱re̱nga yi̱ candu̱ Lau̱ Yambau̱ yi̱ wu si̱i̱ni̱ mi̱ri̱. 
\p  
\v 23 <<Bu yo̱o̱gi̱ yi̱ri̱ bunam, mba ku̱lu̱mba te̱e̱ri̱ngi̱ wa yi̱ Parisayo mba bu batal wa. Bu nyi̱i̱ tiino mi̱ri̱nggi̱ kwap wu se̱e̱ ali̱ mbi̱re̱, baabu, dauri, yi̱ waasa yi̱ bunggul, anda bu kwaa tu gwala yi̱ kundi yo̱u̱, bu tu̱mgu̱ ji̱re̱i̱ yi̱ bunam yi̱ ni̱nggu̱ yi̱ri̱ngi̱ ci̱maci̱ma. To̱o̱ tu daa ye̱i̱ na bu ni̱nga, bu du̱r ya tu co̱nggo̱i̱.  
\v 24 Mba kerma bu taagu̱ nu̱wa wa, bu tosi gundu di̱ngi̱n bu yiki gu̱mpi̱ su ki̱ti̱ndi̱ anda bu mi̱i̱ nggela. 
\p  
\v 25 <<Bu yo̱o̱gi̱ yi̱ri̱ bunam, mba ku̱lu̱mba te̱e̱ri̱ngi̱ wa yi̱ Parisayo, mba bu batal wa. Bu cardi go̱ro̱ kaagu̱ yi̱ go̱ro̱u̱ panane̱ anda mi̱ri̱nggi̱ ye̱i̱ twangi yi̱ yawo yi̱ ni̱nggu̱ tu gaanggu̱ mo̱u̱ kasi̱.  
\v 26 Kerma Parisayo wa! Bu car mi̱ri̱nggi̱ kaage̱ yi̱ panane̱ bati, palaka go̱ro̱ yo̱u̱ ba ni̱ngi̱ we̱i̱ walwal mwaasi̱. 
\p  
\v 27 <<Bu yo̱o̱gi̱ yi̱ri̱ bunam, mba ku̱lu̱mba te̱e̱ri̱ngi̱ wa yi̱ Parisayo mba bu batal wa! Bu ci̱ka purongi tu nu̱wa banni to̱ne̱ du po̱pu̱lo̱k, ko̱gu̱ yo̱u̱ kundi a twalange̱ anda mi̱ri̱nggi̱ ye̱i̱ twanggi yi̱ kuri nu̱wa bu bwaanga wa, pero kana ca yaa walwal.\f + \fr 23:27 \ft Nu̱wa bu Yudaya wa banni to̱ne̱ du po̱pu̱lo̱k a purongi a Wurcalima palaka ru̱nggu̱wa ba mwani ya ba ni̱nga yaa walwal.\f* 
\v 28 Bu yi̱to̱, a twalanga bu ci̱ka nu̱wa bu ni̱nggu̱ pi̱su̱ wu nyaau wa bo̱nggo̱ nu̱wau̱ anda mi̱ri̱nggi̱ mbi̱ri̱ twanggi yi̱ batal yi̱ tu̱we̱. 
\p  
\v 29 <<Bu yo̱o̱gi̱ yi̱ri̱ bunam, mba ku̱lu̱mba te̱e̱ri̱ngi̱ wa yi̱ Parisayo mba bu batal wa, bu mwe̱e̱n dwiiyongi puringi banabi̱ndi̱, pero bu ye̱ki̱ri̱ purongi nu̱wa bu nyaa wa.  
\v 30 Pero bu ce̱ mi̱n, <Ka na yi bo̱o̱ jo̱r kwiimba yuwa we̱i̱, na yaa ku yi ne̱cu̱ we̱i̱ dwii yi̱ pma yi laca banabi̱ndi̱.>  
\v 31 Yi̱to̱ mwa bu ju̱ku̱ya mi̱n bu yo̱o̱gi̱ kakaa pma bu laca banabi̱ndi̱ wa.  
\v 32 Bu je̱e̱ gawu̱re̱ bu twanga wu̱rai̱ du kakaa mba toso. 
\p  
\v 33 <<Mba co̱o̱gi̱ndi̱, mba kwaraa bage̱ci̱ wa! Ni̱ndu̱ we̱i̱ nye̱ bu ce̱ mbi̱r bali̱ par bwalai?  
\v 34 Di̱ngi̱n to̱no̱, n wo̱o̱ tum mbi̱r banabi̱ndi̱ yi̱ nu̱wa bu pwi̱yanggi̱ wa yi̱ ku̱lu̱mba. Bu jiru we̱i̱ bu kangga, bu pi̱i̱ni̱ bu kangga ye̱u̱, bu wacanu̱ we̱i̱ bu kangga a gi̱ri̱ndi̱ ku̱ru̱ pero bu ke̱ke̱nu̱ we̱i̱ pma gwe̱i̱ yi̱ gwe̱i̱.  
\v 35 Nu̱wa ni̱nga mbi̱ru̱ we̱i̱ bali̱ dwii ti̱i̱ma nu̱wa bu ni̱ng pi̱su̱ wu nyaa a gawu̱ri̱ Yamba bu nu̱wa par si̱ye̱i̱ a si̱ma, toso dwii ti̱i̱ma Abila ne̱re̱ wu ni̱nga pi̱su̱ wu nyaau be̱e̱ bu Sakariya bo̱l Berekaya wu bu jiyo cu̱du̱ laa Yambau̱ yi̱ kwaare̱.  
\v 36 N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱ mwa mwa to̱o̱ yi̱ri̱ngi̱ julo we̱i̱ dwii nu̱wa bu si̱naa daandi wa. 
\p  
\v 37 <<Aing! Wurcalima! Mba bu laci banabi̱ndi̱ wa, pero bu bacanga nu̱wa bu Yamba tu̱mu̱we̱ bo̱nggo̱ mbi̱ru̱ wa! Daa so̱no̱ n kasi̱ n ku̱ra mbi̱ra ci̱ka ku̱ cwiyo ku̱ran kwaraa ya mi̱ri̱nggi̱ ko̱ngo̱ndi̱ ye̱i̱, anda bu kwaanga!  
\v 38 Su̱wa, nu̱wa duu mbi̱ri̱ laa mbi̱ru̱ ko̱ni̱!  
\v 39 N wo̱o̱ sagu̱mbi̱ru̱, bu peri ko̱gu̱ mu̱, ko̱po̱ nyanggu̱ ku̱ bu ce̱ mi̱n, <Wuure, a bo̱nggo̱ yo̱, wu bagu̱ a mi̱ri̱nggi̱ din Mbaa Wu Gi̱ra!> >> 
\c 24  
\s1 Somdi daandi su cwata go̱rai̱ 
\p  
\v 1 Yesu du laa Yambau̱, a mwatugu, kwati̱mba ya baanga bo̱nggo̱ yo̱u̱ pma ju̱ku̱gu̱ yo̱ mwe̱e̱ndi̱ twii.  
\v 2 A sa pma ki̱n, <<Bu ko̱gu̱ ti̱na yi̱ri̱ngi̱ mwa mwa, n sagu̱mbi̱ru̱ ji̱re̱ Yaa swe̱li̱ du nu̱wa duru we̱i̱ a dwii bago̱n yo̱, kana do̱no̱ nu̱wa kwiyanu we̱i̱.>> 
\p  
\v 3 Pu bo̱o̱ Yesu wo̱o̱ pi̱su̱ dwii Ci̱ngu̱ Souri Setun, kwati̱mba ya baanga bo̱nggo̱ yo̱u̱ wu̱lak pma ce̱ ki̱n, <<Sayiro, to̱o̱ yi̱ri̱ ni̱ngdu̱ we̱i̱ pe̱ne̱ pero somdi bagu̱ mai ca, yi̱ daandi su cwata go̱ro̱i̱?>> 
\p  
\v 4 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Bu ruun tu̱we̱ kana we̱ ba ciye mbi̱ri̱ ya.  
\v 5 Di̱ngi̱n nu̱wa tum baanga we̱i̱ yi̱ din mi, a ce̱gu̱ ki̱n, <N yo̱o̱gi̱ Masiya,> pero pma ciyonu we̱i̱ nu̱wa tum.  
\v 6 Ka bu nu̱u̱ ce̱wi̱ kwai wundu wundu, anda bu nu̱u̱ ya gwasi̱, tagi̱ to̱o̱ yi̱ri̱ngi̱ ba ni̱ngi̱ wa, anda bo̱o̱ nyanggu̱ ku cwata go̱ro̱u̱ baa bu.  
\v 7 Si̱ma wunmanu we̱i̱ si̱ma, lau̱ wunmanu we̱i̱ lau̱. Ju̱ne̱ yari we̱i̱ pero si̱ma si̱ktu̱ we̱i̱ bu̱ri̱ pe̱ndi̱ wundu wundu.  
\v 8 To̱o̱ mwa mwa to̱o̱ toson taa ku̱u̱lu̱. 
\p  
\v 9 <<Nu̱wa diinu we̱i̱ nu̱wa ba pumbiri ku̱u̱le̱, pero ba lacambi̱ra, bambam nu̱wa bu si̱ma mwa mwa kwaambi̱ri̱ we̱i̱ di̱ngi̱n mi.  
\v 10 A dwii jo̱re̱ nu̱wa tum yaranu̱ we̱i̱ mi̱ri̱nggi̱ le̱e̱gu̱ ji̱re̱i̱, cuuru we̱i̱ bu̱ri̱ pmai pero kwaa we̱i̱ bu̱ri̱.  
\v 11 Pero banabi̱ndi̱ leendi twiyongo we̱i̱ tum, pero ciyonu we̱i̱ nu̱wa tum.  
\v 12 Tu̱we̱ cwatu we̱i̱ bu̱ri̱ di̱ngi̱n to̱no̱ kangam nu̱wa tum ni̱ngu̱ we̱i̱ yu̱tu̱tu̱.  
\v 13 Anda kana we̱ wu bo̱o̱ gaanggu̱ lam nyanggu̱ ku pungu nyi̱i̱nggu̱ we̱i̱ mi̱rma.  
\v 14 Anda ko̱po̱ ka nu̱wa wasi̱r ci̱ye̱i̱ du teng du lau̱ Yambau̱ kana pi̱yau̱ a si̱ma mwa mwa di̱ngi̱n nu̱wa mwa mwa ba nu̱wa, anda nyanggu̱ cwata go̱ro̱ baa. 
\p  
\v 15 <<Ka bu kwe̱yi̱ yi̱ri̱ngi̱ pu̱si̱ twii tu de̱e̱ se̱ntanggi̱, pi̱ti̱ndi̱ pu walwal a Laa Yambau̱ ci̱ka tu banabi̱ Daniel bala ki̱n, yama kana we̱ wu ce̱gu̱ di̱naa ci̱ye̱i̱ ba ku̱ranga to̱o̱.  
\v 16 A dwii jo̱re̱, yama pma bu mi̱ri̱nggi̱ Yudaya wa ba ceendo cingiri.  
\v 17 Kana we̱ wu dwii kani ba julo ya di̱ngi̱n ba de̱e̱ kana ca a lai̱.  
\v 18 Kana we̱ wu wo̱o̱ ko̱ndo̱u̱ ba waata ya lai̱ de̱gu̱ gatangamau.  
\v 19 A kwii nyanggu̱, nu̱ru̱mba bu yi̱ rwiiyengi wa yi̱ bu pu̱u̱gu̱ nyi̱i̱ kwaraa wa, ni̱ngamanu̱ we̱i̱ pma yi̱ buu.  
\v 20 Bu ce̱ ku̱ru̱ cuu mbi̱ru̱ ba yo̱o̱ ya yi̱ jundu kana nyanggu̱ Sabadu.  
\v 21 Di̱ngi̱n a dwii jo̱re̱ nu̱wa ti̱i̱ we̱i̱ ku̱u̱lu̱ wang, wu bo̱o̱ nu̱wa ti̱i̱ bu ti̱i̱gu̱ yake̱ toson taa si̱mau̱ ko̱po̱ yo̱ko̱, pero yaa ku perdu we̱i̱.  
\v 22 Ka na nu̱wa gwandi̱la bu daandi swii ne̱ yaa wu yi̱lu̱ we̱i̱, anda di̱ngi̱n pma bu Yamba se̱ka wa, nu̱wa gwandi̱la daandi swii.  
\v 23 A dwii jo̱re̱ kana we̱ ka ce̱e̱ ki̱n, <Ko̱, Masiya yo̱ wuna!> kana ce̱ ki̱n, <Yo̱ wii!> bu le̱e̱ ya ji̱re̱ yi̱ to̱no̱.  
\v 24 Di̱ngi̱n Masiya wu leendi yi̱ banabi̱ndi̱ leendi twiyongo we̱i̱, pero ni̱nggu̱ we̱i̱ yi̱ri̱ngi̱ ri̱yandi̱ bu̱ri̱ ba we̱le̱nga kana bu nu̱wa Yamba se̱ka pma wa, ka pma puu we̱i̱ wai.  
\v 25 Bu su̱wa, n sambi̱ra ki̱lang, bo̱o̱ jo̱r ni̱nga bu. 
\p  
\v 26 <<Di̱ngi̱n to̱no̱ kana we̱ wu sambi̱ra ki̱n, <Yo̱ wii a gu̱lai̱,> bu twiyoni ya, kana ce̱ ki̱n, <Yo̱ wuna mi̱ri̱nggi̱ kani̱,> bu le̱e̱ ya ji̱re̱ yi̱ to̱no̱.  
\v 27 Di̱ngi̱n ci̱ka ku nyi̱l gundu nyi̱ldi̱ do̱no̱me̱ nu̱wa kwe̱i̱ nyambi̱ranggu̱, yi̱to̱ yi̱ bagu̱ Bo̱l Ne̱re̱.  
\v 28 Pu ko̱mdi̱ so̱o̱ mi̱ru̱, baperi ku̱rani̱ bu̱ri̱ pwii. 
\p  
\v 29 <<Go̱ro̱ ku̱u̱li̱ wu daandi swii, a ki̱nangu̱, 
\q1 <Nyanggu̱ yo̱ we̱i̱ ku̱mji̱la, 
\q2 pero pwalau na swiiri bu̱ri̱, 
\q1 bajwari yaranga we̱i̱ diyou, 
\q2 pero yi̱ri̱ngi̱ tu diyou si̱ktu̱ we̱i̱ bu̱ri̱.> 
\p  
\v 30 <<A dwii jo̱re̱ somdi Bo̱l Ne̱re̱ twii we̱i̱ a diyou, pero mwa mwa duuri tu si̱ma bwi̱yanu̱ we̱i̱ gaanggu̱, ka pma kwe̱e̱ we̱i̱ Bo̱l Ne̱re̱ bagu̱ mi̱ri̱nggu̱ tinendi a diyou yi̱ di̱mbi̱re̱ yi̱ yi̱lau̱ wang.  
\v 31 Yo̱ diinu we̱i̱ nu̱wa ba wuu jume yi̱ mi̱u̱ ba tu̱mmu̱ we̱i̱ bacamandi ye̱i̱, kana pi̱yau̱ ba ku̱ranga bu yo̱ se̱ka wa a mi̱ri̱nggi̱ ke̱ngandi̱ ni̱i̱ su si̱mai̱. 
\p  
\v 32 <<Yo̱ko̱ n kasi̱ bu ti̱langa to̱o̱ yi̱ri̱ bo̱nggo̱ sou pwalgu̱. Ka bu kwe̱e̱ tosi bulugu, wandi̱ ye̱i̱ to̱ri̱ bu so̱ma mi̱n jundu ni̱nga ne̱m.  
\v 33 Yi̱to̱ mwaasi̱, ka bu kwe̱e̱ to̱o̱ yi̱ri̱ngi̱ mwa mwa, bu so̱ma mi̱n a ni̱nga ne̱m, wo̱o̱ nyinou.  
\v 34 N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱ nu̱wa bu si̱na daandi wa pma na bwaani̱ ko̱po̱ ka yi̱ri̱ngi̱ to̱o̱ mwa mwa ni̱ngdi̱ bu̱ri̱.  
\v 35 Diyou yi̱ si̱ma wo̱ru̱ we̱i̱ anda ci̱ye̱i̱ mi yaa ku̱ wo̱ru̱ we̱i̱ kana banyi̱na. 
\s1 Yaa wu so̱m nyanggu̱ yi̱ jo̱r ye̱i̱. 
\p  
\v 36 <<Yaa wu so̱m nyanggu̱ kwii kana jo̱r ye̱i̱, kana bacamandi su diyou, kana Bwi̱ya, bu̱ri̱ Mbaate̱.  
\v 37 Ci̱ka ku ni̱ngi̱ wa a daandi Nuhu, yi̱to̱ mwaasi̱ ni̱ndu̱ we̱i̱ a jo̱r bagu̱ Bo̱l Ne̱re̱.  
\v 38 Ci̱ka ku ni̱ngi̱ wa kami̱n daandi su jame̱ de̱e̱, nu̱wa je̱gu̱ yi̱ naagu, nu̱wa ni̱nggu̱ laabwiya yi̱ nyi̱i̱gu̱ laabwiya ko̱po̱ nyanggu̱ ku Nuhu diiro konggoru.  
\v 39 Yaa ku pma so̱m tu ni̱ndu̱ we̱i̱, ko̱po̱ ku jame̱ baa de̱e̱ pma. Yo̱o̱ we̱i̱ yi̱to̱ a jo̱r du Bo̱l Ne̱re̱ baa we̱i̱.  
\v 40 Nu̱wa ki̱nggu̱ we̱i̱ nu̱wa ro̱p ko̱ndo̱u̱ nu̱wa de̱ru̱ we̱i̱ wiino, ba du wu wiino.  
\v 41 Nu̱wa nyi̱nggu̱ we̱i̱ nu̱ru̱mba ro̱p ko̱gu̱ yi̱ri̱ ni̱i̱ nu̱wa de̱ru̱ we̱i̱ wiino ba du wu wiino. 
\p  
\v 42 <<Di̱ngi̱n to̱no̱, bu ni̱nga pu swe̱ri̱gu̱ di̱ngi̱n bu so̱m bu nyanggu̱ ku Mbaa Wu Gi̱ra mbi̱ri̱ baa we̱i̱.  
\v 43 Anda n kasi̱ bu ku̱ranga mi̱n, ka ne̱re̱ wu laa wayau̱, na so̱m jo̱r du kuwe baa we̱i̱ yi̱ ku̱me̱ na swe̱ru̱ we̱i̱, yaa ku duru we̱i̱ kuwe ba diiwe laa yo̱u̱.  
\v 44 Di̱ngi̱n to̱no̱ bu si̱ya ci̱pi̱gi̱ bu̱ri̱, di̱ngi̱n Bo̱l Ne̱re̱ baa we̱i̱ a jo̱r du bu yaa te̱mandi̱. 
\p  
\v 45 <<Wii ke̱we̱ yo̱ we̱ wu yi̱ ji̱re̱ yi̱ pwi̱i̱, wu ne̱re̱ wu gi̱ra yo̱ diin yo̱ ba su̱wa ke̱waa bu laa yo̱u̱ wa, ba nyi̱i̱ pma je̱e̱ndi̱ pmai ci̱maci̱ma a jo̱r du daa ye̱i̱?  
\v 46 Wuure bo̱nggo̱ wo̱o̱ ne̱re̱, wu ne̱re̱ wu gi̱ra yo̱ ka waatai ba ki̱nggi̱ we̱i̱ a ni̱nggu̱ wu̱rai̱ ye̱i̱ ci̱maci̱ma.  
\v 47 N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱, yo̱ cernu we̱i̱ ne̱re̱ wii a dwii gi̱na yo̱ mwa mwa.  
\v 48 Ka ci̱ka ke̱we̱ wii yi̱ tu̱we̱ we̱i̱ pero sar bu̱ri̱ ye̱i̱ ki̱n, <Ne̱re̱ wu gi̱ra mi daawe̱ tum,>  
\v 49 pero tosi buwanggu kapi̱ma ke̱waa, pero yo̱ wun je̱gu̱ a naagu kem yi̱ ba naamba nyi̱nma.  
\v 50 Ne̱re̱ wu gi̱ra ke̱we̱ wii waata we̱i̱ a jo̱r du ne̱re̱ wii te̱man bu, pero a jo̱r du yo̱ so̱m bu,  
\v 51 baa pu̱u̱ we̱i̱ ku̱u̱le̱ wang, ba ne̱ca yo̱ yi̱ nu̱wa bu yi̱ batal wa, pu ji we̱i̱ wiindi yi̱ dumonggu nyi̱yau̱. 
\c 25  
\s1 Balanggu̱ ci̱ye̱i̱ a dwii bako̱rcanga kwap 
\p  
\v 1 <<A dwii jo̱re̱, lau̱ diyou ni̱ngi̱ we̱i̱ ci̱ka bako̱rcanga kwap bu de̱e̱ pi̱ti̱lari̱ pmai aanda di̱ngi̱n ba te̱re̱nga bwiyakaa wu laabwiya wa yo̱.  
\v 2 Bu nuwo wa twii bacinba anda bu nuwo wa pwi̱yanggi̱.  
\v 3 Bacinba bwii de̱e̱ pi̱ti̱lari̱ pmai yaa nunggu.  
\v 4 Bu pwi̱yanggi̱ bwii pma de̱e̱ nunggu a pi̱ti̱lari̱ pmai yi̱ cwe̱i̱ndi̱ pmai.  
\v 5 Bwiyakaa wii si̱i̱we̱ yaa ku baa ki̱lang, mwa mwa pmau toso jusonggu dimau. 
\p  
\v 6 <<Yi̱ cu̱du̱ kumdi, nu̱wa nu̱u̱ duwai ki̱n, <Bwiyakaa laabwiya yo̱ wuna bu twiyongo bu de̱ rau.> 
\p  
\v 7 <<Bu̱ri̱ bako̱rcanga bwii wunongo, a me̱ne̱nga pi̱ti̱lari̱ pmai.  
\v 8 Bacinba bwii sa bu pwi̱yanggi̱ bwii ki̱n, <Bu pu yir nunggu mbi̱ru̱ pi̱ti̱lari̱ yiri a bwanggu.> 
\p  
\v 9 <<Pma nyi̱i̱ le̱e̱ ki̱n, <Ang ang yaa ku yiri yiri we̱i̱ kem yi̱ mbaa, kujang bu ambi̱ra bu te̱nmanu̱we̱ bu̱ri̱ mbi̱ri̱ bo̱nggo̱ nu̱wa bu cuugu wa.> 
\p  
\v 10 <<Anda pu pma mwatanga te̱nggu̱ nunggu, bwiyakaa laabwiya lamuwe. Bako̱rcanga bu ci̱pi̱gi̱ bu̱ri̱ wa bwii de̱ rau kem yi̱ yo̱ a waandi laabwiya. Pero nu̱wa laka nyinou. 
\p  
\v 11 Go̱ro̱u̱ yo̱u̱, bu kangga bwii baanga, pma ce̱ ki̱n, <Ne̱re̱ wu gi̱ra, Ne̱re̱ wu gi̱ra, wun yiri nyinou!> 
\p  
\v 12 <<A nyi̱i̱ le̱e̱ ki̱n, <N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱ n so̱mmbi̱ru̱ bu.> 
\p  
\v 13 <<Di̱ngi̱n to̱no̱ bu ci̱pa bu̱ri̱, di̱ngi̱n bu so̱m bu nyanggi̱ ye̱i̱ kana jo̱r ye̱i̱. 
\s1 Balanggu̱ ci̱ye̱i̱ a dwii ke̱waa kunong 
\p  
\v 14 <<Bambang, ci̱ka ne̱re̱ wu kangge̱ wu ni̱nggu̱ so̱ngmau̱, a yi̱we̱ ke̱waa ya nyi̱i̱ pma gi̱na yo̱ ba su̱wa yi̱ to̱no̱.  
\v 15 Wu wiino a nyi̱i̱ ke̱n tale̱nti̱ nuwo, wu kangge̱ tale̱nti̱ ro̱p, pero wu kangge̱ tale̱nti̱ wiino, kana wo̱no̱ cu̱u̱nggi̱ di̱mbi̱r yo̱, a ni̱nga so̱ngma ya.\f + \fr 25:15 \ft Tale̱nti̱ wiino tum yo̱u̱ lam ke̱n wu̱rai̱ ne̱ri̱ nyan mi̱la kuna ro̱p a dwii jo̱re̱\f* 
\v 16 Ne̱re̱ wu nu̱wa nyi̱i̱ tale̱nti̱ nuwo, a mwati̱ yo̱ko̱ yo̱ko̱ a ni̱nga duu yi̱ to̱no̱ a nyi̱ngga cwata tale̱nti̱ nuwo wu kangge̱.  
\v 17 Yi̱to̱ mwaasi̱, wu nu̱wa nyi̱i̱ tale̱nti̱ ro̱p a nyi̱ngga cwata tale̱nti̱ ro̱p wu kangge̱.  
\v 18 Anda wu nu̱wa nyi̱i̱ tale̱nti̱ wiino wii a mwati̱ wul bo̱u̱ a si̱ma ting ke̱n ne̱re̱ wu gi̱ra yo̱. 
\p  
\v 19 <<Go̱ro̱ daandi tum ne̱re̱ wu gi̱ra ke̱waa bwii waata bu̱ri̱ so̱ngma ya a kasa ba su̱wa gi̱na yo̱ wu bo̱nggo̱ ke̱waa ya.  
\v 20 Ne̱re̱ wu nu̱wa nyi̱i̱ tale̱nti̱ nuwo a de̱e̱ tale̱nti̱ wu kangge̱ a nuwo a ce̱ ki̱n, <Ne̱re̱ wu gi̱ra, ma nyi̱i̱ngge̱ tale̱nti̱ nuwo ko̱, n nyi̱ngga cwata wu kangge̱ nuwo.> 
\p  
\v 21 <<Ne̱re̱ wu gi̱ra yo̱ se̱e̱ ki̱n, <Wusa, ma yo̱o̱gi̱ ke̱we̱ wu nyaa wu yi̱ ji̱re̱i̱! Ma ni̱nga ji̱re̱i̱ dwii yi̱ri̱ngi̱ banyi̱na, n diiminu we̱i̱ su̱gu̱ yi̱ri̱ngi̱ tu tum. Bame̱ ma ni̱nga bu̱ri̱ de̱gde̱g kem yi̱ ne̱re̱ wu gi̱ra mo̱!> 
\p  
\v 22 <<Ne̱re̱ wu tale̱nti̱ ro̱p wii mwaasi̱ a baa a ce̱ ki̱n, <Ne̱re̱ wu gi̱ra ma nyi̱i̱ngge̱ tale̱nti̱ ro̱p n nyi̱ngga cwata tale̱nti̱ ro̱p.> 
\p  
\v 23 <<Ne̱re̱ wu gi̱ra yo̱ nyi̱i̱ le̱e̱ ki̱n, <Wusa, ma yo̱o̱gi̱ ke̱we̱ wu nyaa wu yi̱ ji̱re̱i̱! Ma ni̱nga ji̱re̱i̱ dwii yi̱ri̱ngi̱ banyi̱na, n diiminu we̱i̱ su̱gu̱ yi̱ri̱ngi̱ tu tum. Bame̱ ma ni̱nga bu̱ri̱ de̱gde̱g kem yi̱ ne̱re̱ wu gi̱ra mo̱!> 
\p  
\v 24 <<Bur ne̱re̱ wu yi̱ tale̱nti̱ wiino wii baa, a ce̱ ki̱n, <Ne̱re̱ wu gi̱ra n so̱ma ma yo̱o̱gi̱ du̱u̱ ne̱re̱ ku̱ ni̱ngandi̱ ye̱i̱ yi̱ bu̱u̱, ma kaci pu ma pi̱ bu, pero ma ku̱rani̱ pu ma wasi̱ bu go̱ma.>  
\v 25 Di̱ngi̱n to̱no̱ n nu̱u̱ gwasi̱, n mwati̱ngge̱, n tuko tale̱nti̱ mo̱ mi̱ri̱nggi̱ si̱ma. Ko̱! Yi̱ri̱ mai yo̱ ti̱na.> 
\p  
\v 26 <<Ne̱re̱ wu gi̱ra yo̱ nyi̱i̱ le̱e̱ ki̱n, <Mo̱, ke̱we̱ wu yi̱ tu̱we̱ yi̱ ku̱u̱le̱! Ma so̱ma mi̱n n kaci pu n pi̱ bu pero n ku̱rani̱ pu n wasi̱ bu go̱ma?  
\v 27 Na ni̱nga kundi, na ma ruu ke̱n mi a betal ke̱ne̱, palaka ka n waata bu̱ri̱ n nyi̱ngga a cwata bu̱ri̱.  
\v 28 Bu yi̱ tale̱nti̱ wo̱o̱ bo̱nggo̱ yo̱u̱ bu nyi̱i̱ wu yi̱ tale̱nti̱ kwap.  
\v 29 Di̱ngi̱n kana we̱ wu wo̱o̱ yi̱ to̱no̱ nu̱wa cwatamanu we̱i̱ yo̱, ba ni̱nga tum. Kana we̱ wu yaa to̱no̱ kana tu yi̱ to̱no̱i̱ nu̱wa yi̱yamanu̱ we̱i̱ yo̱.  
\v 30 Bu manni̱ wo̱o̱ ke̱we̱ wu bwi̱i̱ wo̱o̱ twalange̱, mi̱ri̱nggi̱ ku̱me̱, pu ni̱ngu̱ we̱i̱ pu windi yi̱ dumonggu nyi̱yau̱.> 
\s1 Nyanggu̱ balu 
\p  
\v 31 <<A jo̱r du Bo̱l Ne̱re̱ baa we̱i̱ yi̱ yi̱lau̱ yo̱u̱, kem yi̱ bacamandi ye̱i̱ mwa mwa, yo̱ si̱nu̱ we̱i̱ candu̱ lau̱ yo̱u̱ wu yi̱ yi̱lau̱.  
\v 32 Nu̱wa bu si̱ma mwa mwa ku̱ranu̱ we̱i̱ bu̱ri̱ gawu̱ri̱ ye̱i̱, yo̱ ke̱nu̱ we̱i̱ nu̱wa wundu wundu, ci̱ka ku taage̱ kari̱ puuri bo̱nggo̱ kwamali.  
\v 33 Yo̱ ruu we̱i̱ puuri a wai yo̱u̱ wu je̱u̱, kwamali a wai yo̱u̱ wu miu. 
\p  
\v 34 <<A dwii jo̱re̱ Balaa wii sar we̱i̱ pma bu wai yo̱u̱ wu je̱u̱ ki̱n, <Bambe̱, mba bu yi̱ wuuri wa bo̱nggo̱ Mbaa mi, bu je̱ lau̱ ku nu̱wa ruwo di̱ngi̱n mba yake̱ taawu̱ si̱ma.  
\v 35 Di̱ngi̱n n nu̱u̱ ju̱ne̱ bu nyi̱i̱nggi̱ je̱e̱ndi̱, n nu̱u̱ jii bu pu̱nggu̱ gundu, n yo̱o̱ ru̱ngge̱ bu julunggi bu,  
\v 36 n yaa se̱e̱ bu pari̱ngi̱n se̱e̱, n yaa cingcing bu su̱wangge̱, n wo̱o̱ jaru̱m bu kacanggu̱we̱.> 
\p  
\v 37 <<Nu̱wa bu ni̱ng pi̱su̱ wu nyaa wa bwii le̱e̱ we̱i̱ ki̱n, <Mbaa Wu Gi̱ra, yi ko̱ mi̱na pe̱ne̱ yi̱ ju̱ne̱ yi̱ je̱e̱ mi̱na, yi̱ jii yi pu̱u̱ mi̱n gundu ma naa?  
\v 38 Yi ko̱ mi̱na pe̱ne̱ ma ru̱ngge̱, yi yi̱ mi̱na, pero ma yaa se̱e̱, yi pari̱ mi̱n se̱e̱?  
\v 39 Yi ko̱ mi̱na pe̱ne̱ yaa cingcing kana a jaru̱m yi kaca mi̱na?> 
\p  
\v 40 <<Balaa wii nyi̱i̱ we̱i̱ le̱e̱ ki̱n, <N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱, kana ca tu bu ni̱ngaman wu wiino wu banyi̱na a cu̱du̱ ci̱yamba muwa bi̱na, bu ni̱ngangi̱na.> 
\p  
\v 41 <<Pero sa ru we̱i̱ pma bu wai yo̱u̱ wu miu ki̱n, <Bu lamanga po̱o̱ bo̱nggo̱ mu, mba bu se̱ntanggi̱ wa, bu tembiro bwalau ku yaa dumdu, ku nu̱wa me̱ne̱nga di̱ngi̱n balaa buwai wa kem yi̱ bacamandi ye̱i̱.  
\v 42 Di̱ngi̱n n nu̱u̱ ju̱ne̱ yaa ku bu nyi̱i̱nggi̱ je̱e̱ndi̱, n nu̱u̱ jii yaa ku bu pu̱nggu̱ gundu.  
\v 43 N ru̱ngge̱ yaa ku bu julungge, n yaa se̱e̱ yaa ku bu pari̱ngi̱n se̱e̱, n yaa cingcing pero n wo̱o̱ jaru̱m yaa ku bu su̱wangge̱.> 
\p  
\v 44 <<Pma mwaasi̱ nyi̱i̱ we̱i̱ le̱e̱ ki̱n, <Mbaa Wu Gi̱ra, yi ko̱ mi̱na pe̱ne̱ yi̱ ju̱ne̱, yi̱ jii, ma ru̱ngge̱, ma yaa se̱e̱, ma yaa cingcing pero ma jaru̱m anda yi kala mi̱n bu?> 
\p  
\v 45 <<Yo̱ nyi̱i̱ we̱i̱ le̱e̱ ki̱n, <N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱, kana ca tu bu ni̱ngaman bu wu wiino wu banyi̱na a cu̱du̱ pmai, bu ni̱ngangi̱n bu.>  
\v 46 <<Nu̱wa bwii teendu we̱i̱ ku̱u̱le̱ wu yaa mati̱gu̱ anda nu̱wa bu ni̱ng pi̱su̱ wu nyaau a gawu̱ri̱ Yamba wa, aandi we̱i̱ pu yi̱ pi̱i̱ma bu yaa mati̱gu̱ wa.>> 
\c 26  
\s1 Bagi̱raa ciiman Yesu tandau 
\p  
\v 1 Pu Yesu mata ce̱gu̱ to̱o̱ yi̱ri̱ngi̱ mwa mwa, a sa kwati̱mba ya ki̱n,  
\v 2 <<Bu so̱ma mi̱n Waandi Yerigu a du daa ro̱p, nu̱wa nyi̱i̱ we̱i̱ Bo̱l Ne̱re̱ nu̱wa ba pi̱i̱na ye̱u̱.>> 
\p  
\v 3 A dwii jo̱re̱ bagi̱raa kuruwa yi̱ bagi̱raa nu̱wa wa, pma ku̱ranga bu̱ri̱ caame̱ bagi̱ra kuruwa, wu dini ye̱i̱ Kayapa,  
\v 4 pma ci̱pa bu̱ri̱ di̱ngi̱n ba taa Yesu tukugi ba ji yo̱.  
\v 5 Anda pma ce̱ ki̱n, <<Yaa jo̱r Waandi Yerigi, daakal nu̱wa ba wun kwai.>> 
\s1 Nu̱r parman Yesu nunggu a Betani 
\p  
\v 6 Pu Yesu wo̱o̱ Betani a mi̱ri̱nggi̱ laa Simon wu wo̱o̱ yi̱ butangi nang,  
\v 7 nu̱re̱ wu kangge̱ baa yi̱ kukulo\f + \fr 26:7 \ft Kukulo wii nu̱wa me̱ne̱ni̱ yi̱ swe̱l du yi̱ yi̱lau̱, du nu̱wa yi̱ri̱ ki̱n alabasta.\f* wu yi̱ nunggu ku yi̱ pi̱rcu̱ wang ku run teng, a parman yo̱ dwii pu wo̱o̱ je̱gu̱ je̱e̱ndi̱. 
\p  
\v 8 Pu kwati̱mba ya ko̱ to̱o̱ yi̱to̱, pma bwiyanga gaanggu̱, pma ce̱ ki̱n, <<Wo̱o̱ kwala yo̱ ca?  
\v 9 Nunggu ko̱o̱ nu̱wa na cuu yo̱ yi̱ ke̱n tum ba nyi̱i̱ baku̱u̱lu̱wa.>> 
\p  
\v 10 Yesu so̱m tu pma ce̱gu̱, a sa pma ki̱n, <<Di̱ngi̱n ca bu do̱ma yi̱ nu̱re̱ wo̱o̱ a dwii yi̱ri̱ tu nyaayi tu ni̱ngangi̱nai̱?  
\v 11 Bu bo̱o̱ yi̱ baku̱u̱lu̱wa kem yi̱ mba kana pe̱ne̱, anda yaa ku n si̱i̱ we̱i̱ kem yi̱ mba kana pe̱ne̱.  
\v 12 Pari̱nggu̱ nunggu ku run teng ku pari̱ngi̱na bu̱ri̱ ko̱o̱, a ci̱pi̱gu̱ mu bo̱nggo̱ bo̱o̱re̱.  
\v 13 N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱, kana pi̱yau̱ pu nu̱wa wasi̱ru̱ we̱i̱ ci̱ye̱i̱ du teng di̱na a si̱ma mwa mwa, nu̱wa ce̱ we̱i̱ tu ni̱ngai̱ di̱ngi̱n danggi̱gu̱ yi̱ yo̱.>> 
\s1 Yahuda le̱e̱ ba cuu Yesu 
\p  
\v 14 A dwii jo̱re̱ wu wiino cu̱du̱ bu kwati̱mba ya bu kwap su̱r ro̱p bwii, wu dini ye̱i̱ Yahuda Iskariyoti a aara bo̱nggo̱ bagi̱raa kuruwa wa,  
\v 15 a sa pma ki̱n, <<Tu bu nyi̱i̱nggu̱ we̱i̱ ca ka n di̱n yo̱ war mbi̱ri̱?>> Pma ce̱ ke̱n asurpa kuna kunong nyi̱i̱ yo̱.  
\v 16 Yake̱ do̱o̱ jo̱re̱, Yahuda kasa nyindi su yo̱ cuuru we̱i̱ yo̱. 
\s1 Yesu je̱ je̱e̱ndi̱ Waandi Yerigi kem yi̱ kwati̱mba ya 
\p  
\v 17 A nyanggu̱ ku gawu̱ri̱yo̱ a Waandi Burodi wu yaa Yisti, kwati̱mba Yesu wa baanga pi̱ra ki̱n, <<Ma kasi̱ yi me̱ne̱nga je̱e̱ndi̱ Waandi Yerigi pi̱yau̱ di̱ngi̱n mo̱?>> 
\p  
\v 18 A nyi̱i̱ le̱e̱ ki̱n, <<Bu ambi̱ra gwe̱i̱ bo̱nggo̱ ne̱re̱ wu kangge̱ bu se̱e̱ mi̱n, <Ku̱lu̱m ce̱ ki̱n: Jo̱r mi ni̱nga ne̱m. N je̱ we̱i̱ Waandi Yerigi kem yi̱ kwati̱mba mu wa a laa mau.>>  
\v 19 Kwati̱mba ya bwii ni̱nga ci̱ka ku Yesu sa pma ba ni̱nga, pma me̱ne̱nga Waandi Yerigi. 
\p  
\v 20 Pu nyambi̱ranggu̱ ni̱nga, Yesu si̱ si̱yau̱ aari̱ je̱gu̱ je̱e̱ndi̱ kem yi̱ kwati̱mba ya kwap su̱r ro̱p.  
\v 21 Pu pma bo̱o̱ je̱gu̱ je̱e̱ndi̱, a ce̱ ki̱n, <<N wo̱o̱ sagu̱mbi̱ru̱ ji̱re̱, wu wiino cu̱du̱ mbi̱ri̱ cuunggu we̱i̱.>> 
\p  
\v 22 Pma bwiyanga gaanggu̱, pma toso sagu̱ yo̱ wiino, wiino ki̱n, <<Mbaa Wu Gi̱ra, wii mi ne̱?>> 
\p  
\v 23 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Wu diini wai yo̱u̱ mi̱ri̱nggi̱ panane̱ kem yi̱ mi cuunggu we̱i̱.  
\v 24 Bo̱l Ne̱re̱ bwaaru̱ we̱i̱ ci̱ka ku balgi̱ a dwii ye̱i̱, anda to̱o̱ yi̱ri̱ bunam bo̱nggo̱ ne̱re̱ wu cuu Bo̱l Ne̱re̱, kujang ku nu̱wa na bi bu yo̱.>> 
\p  
\v 25 Yahuda wu yo̱ cuuru we̱i̱ yo̱ a ce̱ ki̱n, <<Ku̱lu̱me̱, wii mi ru?>> Yesu nyi̱i̱ le̱e̱ ki̱n, <<O̱ng ma ce̱.>> 
\p  
\v 26 Pu pma bo̱o̱ je̱gu̱ je̱e̱ndi̱, Yesu de̱e̱ ku̱maa, a wananga Yamba, a ge̱le̱nga, a nyi̱i̱ kwati̱mba ya, a ce̱ ki̱n, <<Bu yi̱ya bu je̱e̱, to̱o̱ bu̱ri̱ mi.>> 
\p  
\v 27 Pero a de̱e̱ bo̱so̱ro̱ gundu inabi, a wananga Yamba, a nyi̱i̱ pma, a ce̱ ki̱n, <<Mwa mwa bu naa mi̱ri̱.  
\v 28 To̱o̱ ti̱i̱ma muwa, bu twanga tu Yamba kwe̱e̱ yi̱ nu̱wa ya, bu pardu̱ we̱i̱ si̱ye̱i̱ bu̱ri̱ di̱ngi̱n pargu̱ sukom we̱le̱mdi̱ nu̱wa tum.  
\v 29 N wo̱o̱ sagu̱mbi̱ru̱, yaa ku n peru we̱i̱ naagu gundu inabi ko̱po̱ kwii nyanggu̱ ku n naa we̱i̱ ku pu̱cu̱ kem yi̱ mba a Lau̱ Mbaa mu.>> 
\p  
\v 30 Go̱ro̱ pu pma pi̱i̱ pi̱i̱ pma mwatanga Ci̱ngu̱ Souri Setun. 
\s1 Yesu ce̱ ki̱n Bitrus gwe̱lu̱ we̱i̱ yo̱ 
\p  
\v 31 Go̱ro̱ yi̱to̱ Yesu sa pma ki̱n, <<Yi̱ kum wunaa mwa mwa mbi̱ru̱ bu nyi̱nggu̱ we̱i̱ go̱ro̱u̱, di̱ngi̱n balgi̱ mi̱ri̱nggi̱ lakargar Yamba ki̱n, 
\q1 <N buu we̱i̱ taage̱, n jiyo, 
\q2 kan puuri we̱e̱nu̱ we̱i̱. 
\m  
\v 32 Anda go̱ro̱ pu n wuni n cwii we̱i̱ gawu̱r mbi̱ri̱ n anggi̱ Galili.>> 
\p  
\v 33 Bitrus nyi̱i̱ le̱e̱ ki̱n, <<Kana, kana we̱ waatu̱ we̱i̱ bu̱ri̱ yi̱ go̱ro̱u̱ di̱ngi̱n mo̱, mi yaa ku n waatu̱ we̱i̱.>> 
\p  
\v 34 Yesu se̱e̱ ki̱n, <<Bitrus, n wo̱o̱ sagu̱mo̱u̱ ji̱re̱, a kum wunaa kami̱n ko̱lo̱o̱ ba te̱e̱ te̱e̱re̱ ma gwe̱le̱nggu̱ we̱i̱ daa kunong.>>  
\v 35 Anda Bitrus ce̱ ki̱n, <<Kana n bo̱o̱ru̱ we̱i̱ kem yi̱ mo̱, yaa ku n gwe̱le̱mi̱nu̱ we̱i̱>> Pero mwa mwa kwati̱mba ya bu kangga bwii mwaasi̱ ce̱ yi̱to̱. 
\s1 Yesu ce̱ ku̱ru̱ yi̱ kwati̱mba ya a Gesimani 
\p  
\v 36 Go̱ro̱ yi̱to̱ Yesu mwati̱ kem yi̱ kwati̱mba ya a pu nu̱wa yi̱ri̱ ki̱n, Gesimani, a sa pma ki̱n, <<Bu si̱ndi̱ si̱ye̱i̱ pi̱na mi n ko̱ n songge gawu̱re̱ n ce̱ ku̱ru̱.>>  
\v 37 A de̱e̱ Bitrus yi̱ kwaraa Sabadi bu ro̱p kem yi̱ yo̱, a toso bwiyang gaanggu̱ yi̱ mi̱yanggu̱ bu̱ru̱.  
\v 38 A sa pma ki̱n, <<Bawei mi twangi yi̱ bwiyang gaanggu̱ ci̱ka n bwaa. Bu si̱ndi̱ si̱yandi̱ pi̱na bu si̱ya ci̱pi̱gi̱ bu̱ri̱ kem yi̱ mi.>> 
\p  
\v 39 A kosuro banyi̱na a yara, a suni kau si̱ma, a ce̱ ku̱ru̱ ki̱n, <<Mbaa mi, ka ni̱ndu̱ wai we̱i̱ mo̱ de̱mangi̱n ki̱na cu̱su̱gu̱. Anda dangandi̱ mi ne̱, anda to̱o̱ mai.>> 
\p  
\v 40 A waata bo̱nggo̱ kwati̱mba ya baa nyi̱ngga pma diimandi, a pi̱ra Bitrus ki̱n, <<Yaa ku bu puu we̱i̱ bu si̱ya ci̱pi̱gi̱ bu̱ri̱ kem yi̱ mi nyan jo̱r banyi̱na ru?  
\v 41 Bu si̱ya ci̱pi̱gi̱ bu̱ri̱, bu ce̱ ku̱ru̱ daakal bu yanna miyam. Bawei kasi̱gu̱ anda bu̱ri̱ yaa di̱mbi̱re̱.>> 
\p  
\v 42 A mwati̱ ku ro̱p a ce̱ ku̱ru̱ ki̱n, <<Mbaa mi, ka yaa ku ni̱ndu̱ we̱i̱ ko̱o̱ cu̱su̱gu̱ ba lamana ko̱po̱ ka n cu̱si̱, yama dangandi̱ mai ba ni̱ngwa.>> 
\p  
\v 43 Pu waatau a nyi̱ngga pma diimandi do̱ng, di̱ngi̱n nundi pma ni̱nga ko̱mbi̱ro̱m.  
\v 44 A du pma a waata bu̱ri̱ do̱ng, a ce̱ ku̱ru̱ ku kunong a pero tu co̱nggo̱ ci̱ye̱i̱. 
\p  
\v 45 Pero a waata bu̱ri̱ bo̱nggo̱ kwati̱mba ya a sa pma ki̱n, <<Bo̱o̱ bu bo̱o̱ diimandi ru? Bu yo̱ro̱nggu̱ ru? Su̱wa jo̱r ni̱nga nu̱wa cuu Bo̱l Ne̱re̱ a war nu̱wa bu yi̱ we̱le̱mdi̱ wa.  
\v 46 Bu wunongo yi mwatanga! Ne̱re̱ wu cuugu mu wii wo̱o̱ bagu̱!>> 
\s1 Nu̱wa ta Yesu 
\p  
\v 47 Pu bo̱o̱ Yesu wo̱o̱ ce̱gu̱ ci̱ye̱u̱, Yahuda wu wiino cu̱du̱ bu kwap su̱r ro̱p bwii lamuwe kem yi̱ nu̱wa tum yi̱ do̱mpo̱u̱ri̱ yi̱ gu̱mo̱ngi̱, bu bagi̱raa kuruwa wa yi̱ bagi̱raa nu̱wa wa tu̱mu̱we̱.  
\v 48 Yo̱ wu ne̱re̱ wu cuuru we̱i̱ a ru somdi tu pma ku̱ranu̱ we̱i̱ ki̱n, <<Ne̱re̱ wu ku̱u̱na bu̱ri̱ wii yo̱, bu te̱e̱.>>  
\v 49 Ku pma lama, yo̱ko̱ yo̱ko̱ Yahuda aara bo̱nggo̱ Yesu se̱e̱ ki̱n, <<N ci̱ mi̱na ku̱lu̱me̱,>> pero a ku̱u̱nu̱ yo̱ bu̱ri̱. 
\p  
\v 50 Yesu nyi̱i̱ le̱e̱ ki̱n, <<Basi̱n mi, ni̱nga tu de̱mu̱we̱.>> 
\p Nu̱wa bwii twiyongo parnu̱ wari̱ taa Yesu.  
\v 51 Ku ni̱ngwa yi̱to̱, wu wiino cu̱du̱ barauwa Yesu a yaku wai a podo do̱mpo̱u̱ yo̱u̱ a kaca twiyau ke̱we̱ bagi̱ra kuruwa a mwari̱ya. 
\p  
\v 52 Yesu se̱ ki̱n, <<Pu̱n do̱mpo̱u̱ mo̱u̱ mi̱ri̱nggi̱ laa yo̱u̱, di̱ngi̱n wu podo do̱mpo̱u̱ bo̱o̱ri̱ do̱mpo̱u̱.  
\v 53 Ma nu̱u̱ mi̱n n pu yi̱gu̱ Mbaa mi, ba suka bacamandi tum yo̱ko̱ ki̱na ru?  
\v 54 Anda ka n ni̱ng yi̱to̱, ci̱ye̱i̱ De̱mte̱e̱re̱ du ce̱ ki̱n, tagi̱ ba ni̱ngwa yi̱to̱, ni̱ndu̱ we̱i̱ nye̱ ba twangwa?>> 
\p  
\v 55 A dwii jo̱re̱ Yesu sa nu̱wa bu tum bwii ki̱n, <<Di̱ngi̱n ca bu baanga yi̱ do̱mpo̱u̱ri̱ yi̱ gu̱mo̱ngi̱ bu tangge̱ ci̱ka n kuwe? Kana ko̱no̱ nyanggu̱ n si̱i̱ laa Yambau̱ n pi̱rgu̱ yi̱ri̱ nu̱wa anda bu tanggu̱ bu.  
\v 56 Anda to̱o̱ mwa mwa a ni̱ngwa palaka ba twanga tu banabi̱ndi̱ bala ki̱n ni̱ndu̱ we̱i̱.>> Kwati̱mba ya mwa mwa du yo̱ a ceendo. 
\s1 Yesu gawu̱r bagi̱raa nu̱wa bu Yudaya wa 
\p  
\v 57 Nu̱wa bu ta Yesu wa a de̱e̱ yo̱ bo̱nggo̱ Kayapa kuru wu gi̱ra pu ku̱lu̱mba te̱e̱ri̱ngi̱ wa yi̱ bagi̱raa Yudaya wa ku̱ranga bu̱ri̱.  
\v 58 Anda Bitrus po̱ng yo̱ gantin, a lama bo̱nggo̱ laa kuru wu gi̱ra . A diiro si̱n si̱ye̱i̱ kem yi̱ nu̱wa bu swe̱ri̱gu̱ yo̱ wa ba ko̱ tu ni̱ndu̱ we̱i̱ bu̱ri̱. 
\p  
\v 59 Bagi̱ra kuruwa yi̱ bagi̱raa nu̱wa bu Yudaya wa mwa mwa pma kasi̱gu̱ se̱e̱daki̱ leendu a dwii Yesu palaka pma ba ji yo̱.  
\v 60 Anda pma nyi̱ngga bu kana ca, kana ku baleenda twiyongo. 
\p Cwata go̱ro̱ yo̱u̱ nu̱wa ro̱p twiyongo,  
\v 61 a ce̱ ki̱n, <<Ne̱re̱ wo̱o̱ ce̱ ki̱n, <N puu we̱i̱ bwiyanggu laa Yambau̱ n mwe̱ nyan daa kunong.>>> 
\p  
\v 62 Bur bagi̱ra kuruwa wii wuni a sa Yesu ki̱n, <<Yaa ku ma nyi̱i̱ we̱i̱ le̱e̱ a dwii we̱le̱ce̱u̱ wu nu̱wa bo̱o̱ ce̱gu̱ a dwii ru?>>  
\v 63 Yesu si̱n si̱ye̱i̱ to̱k. 
\p Bagi̱ra kuruwa wii sa yo̱ ki̱n, <<N ne̱ca mi̱na yi̱ Yamba wii yi̱ pi̱i̱ma yi̱ we̱ra sa yiro ka ma Masiya Bo̱l Yamba wai.>> 
\p  
\v 64 Yesu nyi̱i̱ le̱e̱ ki̱n, <<O̱ng ci̱ka ku ma ce̱ ko̱o̱, anda n wo̱o̱ sagu̱mbi̱ru̱ pi̱na yi̱ gawu̱re̱ bu kwe̱e̱ we̱i̱ Bo̱l Ne̱re̱ pi̱su̱ a wai wu je̱u̱ Yambau̱ wu yi̱ Di̱mbi̱re̱ a bagu̱ mi̱ri̱nggu̱ tinendi a diyou.>> 
\p  
\v 65 Bagi̱ra kuruwa wii pwaranga se̱e̱ yo̱ di̱ngi̱n ba ju̱ku̱ bwiyan gaanggu̱ yo̱u̱, a ce̱ ki̱n, <<A ce̱ ce̱wi̱ bwiyangi din Yambai̱! Di̱ngi̱n ca yi kasi̱gu̱ se̱e̱daki̱ wu kangge̱ do̱ng? Su̱wa, yo̱ko̱ bu nu̱u̱ ko̱o̱ bwiyangu din Yambau̱.  
\v 66 Bu ce̱ mi̱n ca? Pma le̱e̱man yo̱ ki̱n, <<A yinno bo̱o̱re̱!>> 
\p  
\v 67 Bur pma tuuman yo̱ ti̱i̱ma kau, pero cumongo. Bu kangga kapanga yo̱.  
\v 68 A ce̱ ki̱n, <<Masiya, ka ma banabi̱ wai, sa yiro, wu buu mi̱na we̱?>> 
\s1 Bitrus gwe̱la Yesu 
\p  
\v 69 Bitrus wo̱o̱ pi̱su̱ mi̱ri̱nggi̱ laa kuru wu bagi̱ra , bur bwe̱e̱canga wu kangge̱ wu twii ke̱we̱ baa bo̱nggo̱ yo̱ ce̱ ki̱n, <<Mo̱ mwaasi̱ ma wo̱o̱ kem yi̱ Yesu ne̱re̱ wu Galili.>> 
\p  
\v 70 Anda a gwe̱la yo̱ a gawu̱ru̱ pmai mwa mwa ki̱n, <<N so̱m bu tu ma ce̱gi̱.>> 
\p  
\v 71 Pu twiyo nyinou, bwe̱e̱canga wu kangge̱ wu twii ke̱we̱ ko̱ yo̱, a sa nu̱wa bu pwii bwii ki̱n, <<Wuna ne̱re̱ wo̱o̱ kem yi̱ Yesu wu Nasaret.>> 
\p  
\v 72 A gwe̱la do̱ng, a we̱re̱nga ce̱ ki̱n, <<N so̱m bu wo̱o̱ ne̱re̱.>> 
\p  
\v 73 Go̱ro̱u̱ banyi̱na pma bu pi̱ti̱ndi̱ pwii bwii aanda bo̱nggo̱ Bitrus a ce̱ ki̱n, <<Manggu, ma wo̱o̱ cu̱du̱ pmai, di̱ngi̱n miu ce̱ mo̱u̱ a ju̱ku̱ya.>> 
\p  
\v 74 A toso we̱re̱nggu̱ ki̱n, <<Bwi̱i̱ge̱ ba tangge̱ ka n ce̱gu̱ leendi wai, n so̱m bu ne̱re̱ wo̱o̱.>> 
\p Ki̱no̱ngu̱ ko̱lo̱o̱ te̱e̱ te̱e̱re̱. 
\p  
\v 75 Bitrus dangga tu Yesu sa yo̱, <<Kami̱n ko̱lo̱o̱ ba te̱e̱ te̱e̱re̱, ma gwe̱le̱nggu̱ we̱i̱ daa kunong mi̱n ma so̱nggu̱ bu.>> A twiyo twalange̱, a ji windi wang. 
\c 27  
\s1 Yahuda yaka bu̱ri̱ ye̱i̱ 
\p  
\v 1 Yi̱ pinu ki̱lang, bagi̱raa kuruwa yi̱ bagi̱raa nu̱wa wa mwa mwa pma su̱wa tu pma ni̱ngu̱ we̱i̱ ba ji Yesu.  
\v 2 Pma twala yo̱, mwatanga yi̱ yo̱ de̱ bo̱nggo̱ Bilatus wu twii gomna. 
\p  
\v 3 Pu Yahuda wu cuu yo̱ ko̱ nu̱wa mwar man Yesu bali̱ bo̱o̱ri̱. A ni̱nga mondo mondo, a puu ke̱n asurpa kuna kunong dwii bagi̱raa kuruwa wa wii yi̱ bagi̱raa nu̱wa bwii.  
\v 4 A ce̱ ki̱n, <<N ni̱nga we̱le̱m, n cuu ne̱re̱ wu yaa we̱le̱ce̱u̱.>> 
\p Pma ce̱ ki̱n, Do̱ yiri do̱no̱, to̱o̱ biiki mo̱.>> 
\p  
\v 5 Yahuda para ke̱n dwii mi̱ri̱nggi̱ laa Yambau̱, a mwati̱ yaka bu̱ri̱ ye̱i̱. 
\p  
\v 6 Bagi̱raa kuruwa wa wii de̱e̱ ke̱n dwii a ce̱ ki̱n, <Te̱e̱ri̱ le̱e̱ bu nu̱wa ba parni̱ do̱o̱ ke̱n a betal, di̱ngi̱n to̱o̱ ke̱n ti̱i̱mai̱.>>  
\v 7 Pma le̱e̱ ba de̱e̱ ke̱n dwii ba te̱n si̱ma ne̱re̱ wu mwe̱e̱ni̱ dinendi, di̱ngi̱n ba yo̱ pu nu̱wa ting ru̱nggu̱wa.  
\v 8 Twii to̱no̱ nu̱wa yi̱ri̱ ki̱n, Si̱ma Ti̱i̱ma wa lama yo̱ko̱.  
\v 9 To̱o̱ twang tu banabi̱ Irmiya ce̱i̱, <<Pma de̱e̱ asurpa kuna kunong, to̱o̱ duu wu nu̱wa bu Israila wa ru woo ki̱n nu̱wa ba cuu yo̱.  
\v 10 Pma de̱e̱ te̱n si̱ma ne̱re̱ wu mwe̱e̱ni̱ dinendi ci̱ka ku Mbaa Wu Gi̱ra sangge̱.>> 
\s1 Bilatus ni̱ngaman Yesu bali̱ 
\p  
\v 11 Yesu ti̱n ti̱ye̱i̱ gawu̱r gomna, gomna pi̱ra ki̱n, <<Ma yo̱o̱gi̱ balaa wu Yudaya ru?>> 
\p A le̱e̱ ki̱n, <<O̱ng ci̱ka ku ma ce̱ ko̱o̱.>> 
\p  
\v 12 Pu bagi̱raa kuruwa wa yi̱ bagi̱raa nu̱wa wa ce̱ we̱le̱mdi̱ a dwii ye̱i̱, yaa ku nyi̱i̱ le̱e̱. 
\p  
\v 13 Bilatus pi̱ra ki̱n, <<Ma yaa nu̱u̱gu̱ se̱e̱daki̱ wu pma ce̱gu̱ dwii ma ru?>>  
\v 14 Anda Yesu yaa ku sa pma ci̱ye̱i̱, a dwii ce̱wi̱ tu pma ce̱ dwii ye̱i̱ kana banyi̱na, gomna riyanga bu̱ri̱ wang. 
\p  
\v 15 Ci̱ka ku gomna me̱e̱ ni̱ngu̱, kana so̱no̱ Waandi Yerigu yo̱ man ne̱re̱ wiino wu jaru̱m wu nu̱wa kasa.  
\v 16 A dwii jo̱re̱ wo̱o̱ ne̱re̱ wu jaru̱m wu nu̱wa so̱ma wang yi̱ ni̱nga wu bwi̱i̱ye̱, dini ye̱i̱ Barabas.  
\v 17 Di̱ngi̱n to̱no̱ pu nu̱wa ku̱ranga bu̱ri̱, Bilatus pi̱ra pma ki̱n, <<Wu bu kasi̱ n man mbi̱ra we̱ Barabas ru, Yesu wu nu̱wa yi̱ri̱ ki̱n Masiya ru?>>  
\v 18 Di̱ngi̱n a so̱ma ki̱n pma taa Yesu bo̱nggo̱ yo̱u̱ di̱ngi̱n bwiu. 
\p  
\v 19 Pu Bilatus wo̱o̱ pi̱su̱ a pi̱su̱ wu yo̱ ni̱ng balu, nu̱re̱ yo̱ ni̱nga man yo̱ tu̱ne̱ ki̱n, <<Ma ni̱ngamani̱ ya ne̱re̱ wu yaa we̱le̱ce̱u̱ wo̱o̱ kana ca di̱ngi̱n reni n turuwa yi̱ dweendi di̱ngi̱n yo̱.>> 
\p  
\v 20 Anda kuruwa bu bagi̱raa wa yi̱ bagi̱raa nu̱wa wa pma ciyongo nu̱wa ba ce̱ ki̱n nu̱wa ba man Barabas, nu̱wa ba ji Yesu. 
\p  
\v 21 Gomna pi̱ra ki̱n, <<Cu̱du̱ pmai bu ro̱p, n man mbu̱we̱ we̱? 
\p Pma nyi̱i̱ le̱e̱ ki̱n, <<Barabas.>> 
\p  
\v 22 Bilatus pi̱ra pma ki̱n, <<N ni̱ng ca yi̱ Yesu wu nu̱wa yi̱ri̱ ki̱n Masiya?>> 
\p Mwa mwa pma nyi̱i̱ le̱e̱ ki̱n, <<Pi̱i̱na ye̱u̱ ba bwaa.>> 
\p  
\v 23 Bilatus pi̱ra ki̱n, <<Di̱ngi̱n ca? A ni̱nga we̱le̱ce̱u̱ yo̱u̱ ca?>> 
\p Anda nu̱wa bwii cwata kwari̱ndi̱ ki̱n, <<Bu pi̱i̱na ye̱u̱!>> 
\p  
\v 24 Pu Bilatus ko̱ yaa tu yo̱ puu we̱i̱, anda pma toso kasi̱gu̱ ruuni, di̱ngi̱n to̱no̱ a de̱e̱ gundu a car wari ye̱i̱ gawu̱r nu̱wa bwii a ce̱ ki̱n, <<N yaa wai dwii bo̱o̱re̱ ne̱re̱ wo̱o̱, yama ti̱i̱ma yo̱u̱ ba si̱ya dwii mbi̱ri̱!>> 
\p  
\v 25 Nu̱wa bwii mwa mwa le̱e̱ ki̱n, <<Yama ti̱i̱ma ya ba si̱ya dwii yiri yi̱ kwaraa yuwa!>> 
\p  
\v 26 A man manu̱we̱ pma Barabas, a din nu̱wa waci̱ Yesu, a nyi̱i̱ Yesu kacara bu Roma wa ba pi̱i̱na ye̱u̱. 
\s1 Kacara ni̱nga man Yesu nyasi̱ 
\p  
\v 27 Kacara Bilatus de̱ Yesu mi̱ri̱nggi̱ caame̱ gomna, pma yi̱we̱ kacara mwa mwa ku̱ranga bu̱ri̱ bo̱nggo̱ yo̱u̱.  
\v 28 Pma wuroman yo̱ se̱e̱ a te̱e̱man yo̱ gatangamau ku wu̱ci̱ci̱ ci̱ka balaa,  
\v 29 pma me̱ne̱nga me̱tu̱wal tu̱ri̱ a diiman yo̱ dwii. Pma de̱e̱ jwalu nyi̱i̱ya a wai wu je̱u̱, pma kun kwiyei gawu̱r ye̱i̱, pma ni̱ngaman yo̱ nyasi̱ ce̱gu̱ ki̱n, <<Bundi, balaa wu Yudaya>>  
\v 30 Pma tuuman yo̱ ti̱i̱ma, pero pma de̱e̱ jwalu ku wai yo̱ kwii a ni̱nga pu buwanggu dwii.  
\v 31 Go̱ro̱ pu pma mata ni̱nga man yo̱ nyasi̱, pma te̱e̱man yo̱ se̱e̱ yo̱, pma de̱ yo̱ ba pi̱i̱na ye̱u̱. 
\s1 Pi̱i̱nggu̱ Yesu ye̱u̱ 
\p  
\v 32 Pu pma twiyonggu, pma kaanga yi̱ ne̱re̱ wu kangge̱ wu gwe̱i̱ Sayirin din ye̱i̱ Simon. Kacara bwii ki̱canga ba de̱ ye̱u̱ wii.  
\v 33 Pma baanga pu nu̱wa yi̱ri̱ ki̱n, Golgota, pi̱ti̱ndi̱ ye̱i̱ ki̱n, <<Ko̱ko̱ Dwii.>>  
\v 34 Pma nyi̱i̱ Yesu gundu inabi casi̱nggi̱ tu kwe̱re̱k ba naa, anda go̱ro̱ pu ti̱yau̱, a kwaa naagu.  
\v 35 Pu pma pi̱i̱na ye̱u̱, pma cwaanga se̱e̱ yo̱ bo̱nggo̱ ke̱e̱gu̱ lato̱mbale̱.  
\v 36 Pma si̱n si̱ye̱ndi̱, ni̱nga pu swe̱ri̱gu̱ yo̱.  
\v 37 Nu̱wa bala we̱le̱ce̱u̱ yo̱u̱ a pi̱i̱na dwii ye̱u̱ wii ne̱m yi̱ dwii ye̱i̱ ki̱n, <<Wunaa Yesu, balaa nu̱wa bu Yudaya wa.>>  
\v 38 Nu̱wa pi̱i̱ni̱ kuuwa ro̱p kem yi̱ yo̱ wu wiino wai yo̱u̱ je̱u̱, wu kangge̱ wai wu miu.  
\v 39 Nu̱wa bu cwiyongu wa ni̱nga pu rwe̱e̱nggu̱ a ge̱pu̱gu̱ dwii a ni̱nggu̱ yo̱ nyasi̱,  
\v 40 ce̱gu̱ ki̱n, <<Ma ce̱ mi̱n ma re̱pu̱ we̱i̱ Laa Yambau̱ ma mo̱ru̱ we̱i̱ nyan daa kunong, mi̱ra bu̱ri̱ mai, ma julo ye̱u̱ wo̱o̱, ka ma Bo̱l Yamba wai!>> 
\p  
\v 41 Yi̱to̱ mwaasi̱ yi̱ bagi̱raa kuruwa wa yi̱ ku̱lu̱mba te̱e̱ri̱ngi̱ wa yi̱ bagi̱raa nu̱wa wa pma ni̱nga man yo̱ nyasi̱.  
\v 42 Pma ce̱gu̱ ki̱n, <<Yo̱ mi̱ra bu kangga anda jaanga mi̱ri̱gu̱ bu̱ri̱ ye̱i̱! Balaa wu Israila! Yama ba julo dwii ye̱u̱ wo̱o̱, yo mwa yi̱ le̱e̱ we̱i̱ ji̱re̱ yi̱ yo̱.  
\v 43 Yo̱ le̱e̱ ji̱re̱ yi̱ Yamba. Yama Yamba ba mi̱ra yo̱ ka kasi̱ yo̱ we̱i̱, di̱ngi̱n a ce̱ ki̱n, <Yo̱ Bo̱l Yamba>>>  
\v 44 Ban kuuwa bu nu̱wa pi̱i̱na ye̱u̱ kem yi̱ yo̱ wa rwe̱e̱nga yo̱ mwaasi̱. 
\s1 Bo̱o̱ri̱ Yesu 
\p  
\v 45 Yake̱ cu̱du̱ nyanggi̱, ku̱mji̱la laka si̱ma bwii mwa mwa ko̱po̱ yi̱ nyambi̱ranggu̱ jo̱r du kunong.  
\v 46 A jo̱r du kunong Yesu yi̱ yi̱re̱ yi̱ du̱we̱i̱ ki̱n, <<Elo̱i̱, Elo̱i̱, lama sabaktani?>> Pi̱ti̱ndi̱ ye̱i̱ ki̱n, <<Yamba mi, Yamba mi, di̱ngi̱n ca ma manggi̱ si̱ye̱i̱?>> 
\p  
\v 47 Pu pma bu pi̱ti̱ndi̱ pwii wa nu̱wa yi̱to̱ pma ce̱ ki̱n, <<A yi̱gu̱ Iliya.>> 
\p  
\v 48 Ki̱no̱ngu̱ wu kangge̱ ceero a diini soso gundu inabi ku jo̱mbu̱ro̱m a diina jwalu a diiman Yesu nyi̱yau̱ ba naa.  
\v 49 Bu kangga bwii ce̱ ki̱n, <<Bu dwiya po̱o̱ yi ko̱ ka yikwii Iliya ba mi̱ra we̱i̱ yo̱ wai.>> 
\p  
\v 50 Pu Yesu pero yi̱gu̱ yi̱ru̱ yi̱ duwai, pi̱i̱ma ya twiyo. 
\p  
\v 51 A dwii jo̱re̱ ko̱we̱ wu laa Yambau̱ nge̱re̱nga bu̱ri̱ ro̱p toso diyou be̱e̱ si̱ma. Si̱ma sikto bu̱ri̱ swari̱ngi̱ ge̱le̱nga bu̱ri̱.  
\v 52 Purongi wumongo bu̱ri̱ nu̱wa bu walwal bu bwaanga wa wunongo yi̱ pi̱i̱ma.  
\v 53 Pma twiyongo a purongi go̱ro̱ wungu Yesu bo̱o̱re̱, pma mwatanga gwe̱i̱ du walwal, pma ju̱ku̱ bu̱ri̱ pmai nu̱wa tum. 
\p  
\v 54 Pu bagi̱ra kacara yi̱ pma bu kem swe̱ri̱gu̱ Yesu wa ko̱ si̱ma sikto bu̱ri̱ yi̱ mwa mwa tu ni̱ngi̱ wa, pma nu̱u̱ gwasi̱ wang, pma ce̱ ki̱n, <<Manggu to̱o̱ Bo̱l Yamba!>> 
\p  
\v 55 Nu̱ru̱mba tum bo̱o̱ pwii pma su̱gu̱ kwaara. Pma po̱ng Yesu yake̱ Galili pma kalanggu̱ yo̱ wu̱rai̱.  
\v 56 A cu̱du̱ bu bo̱o̱ pwii wa, bo̱o̱ yi̱ bu Maryamu wu Magadaliya yi̱ Maryamu njaa Yakubu yi̱ Yusupu yi̱ njaa kwaraa Sabadi wa. 
\s1 Tinggu Yesu 
\p  
\v 57 Pu nyambi̱ranggu̱ ni̱nga ne̱m, bagi̱na wu kangge̱ wu gwe̱i̱ Arimatiya a baa, din ye̱i̱ Yusupu, yo̱ yi̱ri̱ ye̱i̱ wo̱o̱ cu̱du̱ kwati̱mba Yesu wa.  
\v 58 A aara bo̱nggo̱ Bilatus, a senggo ko̱mo̱u̱ Yesu, Bilatus sa nu̱wa ba nyi̱i̱ya.  
\v 59 Yusupu diin nu̱wa cikumanuwe yo̱ bu̱ri̱ Yesu a ye̱u̱, a kumbulo yi̱ lawan wu walwal.  
\v 60 A diin yo̱ a puri ye̱i̱ du pu̱ci̱ du wu̱li̱ dwii swe̱li̱. A ce̱nni̱ swe̱li̱ du duwi nyan puri dwii a mwati̱.  
\v 61 Maryamu Magadaliya yi̱ Maryamu wu kangge̱ wii pma pi̱si̱ndi̱ puri dwii. 
\s1 Nu̱wa bu swe̱ri̱gu̱ puri Yesu wa 
\p  
\v 62 Ku lam pinu nyanggu̱ sabadu, bagi̱raa kuruwa wa yi̱ Parisayo aanda bo̱nggo̱ Bilatus.  
\v 63 Pma ce̱ ki̱n, <<Ne̱re̱ wu gi̱ra, yi dangga tu ne̱re̱ wu ciyeni nu̱wa wo̱o̱ ce̱i̱ pu bo̱o̱ wo̱o̱ yo̱ pi̱i̱mau̱ ki̱n, <Go̱ro̱ daa kunong n wuni we̱i̱ yi̱ pi̱i̱ma do̱ng.>  
\v 64 Di̱ngi̱n to̱no̱ diin nu̱wa ba swe̱ra puri dwii nyan daa kunong, dakali, kwati̱mba ya ba ji̱nda bu̱ri̱ ye̱i̱, ba sa nu̱wa ki̱n a wuni bo̱nggo̱ bo̱o̱re̱. Ka ni̱ngdi̱ yi̱to̱ ciyeni tu go̱ro̱ yo̱ gwalu we̱i̱ tu gawu̱ri̱yo̱.>> 
\p  
\v 65 Bilatus nyi̱i̱ le̱e̱ ki̱n, <<Bu de̱e̱ kacara bu swe̱ru̱ we̱i̱ wa bu ambi̱ra puri dwii bu swe̱ra nyan di̱mbi̱ri̱ mbi̱re̱.>>  
\v 66 Pma aanda puri dwii, pma dii mwali̱nggi̱ dwii swe̱li̱ dwii, diini kacara ba swe̱ra. 
\c 28  
\s1 Wunggu Yesu bo̱o̱re̱ 
\p  
\v 1 Go̱ro̱ nyanggu̱ Sabadu yi̱ pi̱n ki̱lang a nyanggu̱ Laadi, Maryamu wu gwe̱i̱ Magadaliya yi̱ Maryamu wu kangge̱ wii pma mwatanga ba su̱wa puri dwii. 
\p  
\v 2 Si̱ma sikto bu̱ri̱ wang, di̱ngi̱n bacama Mbaa Wu Gi̱ra a julo diyou Yambau̱, a aara puri dwii, a gumbulo swe̱l dwii a si̱i̱na dwii ye̱i̱.  
\v 3 A nyi̱langgu̱, se̱e̱ yo̱ po̱pu̱lo̱k ci̱ka cankar.  
\v 4 Nu̱wa bu swe̱ri̱gu̱ wa pma nu̱u̱ gwasi̱ ye̱i̱ pma remcuwa yaranga ci̱ka nu̱wa bu bwaanggi̱ wa. 
\p  
\v 5 Bacama wii sa nu̱ru̱mba wii ki̱n, <<Bu nu̱u̱ ya gwasi̱, di̱ngi̱n n so̱ma bu kasi̱gu̱ Yesu wu nu̱wa pi̱i̱na ye̱u̱.  
\v 6 Yaa po̱o̱, a wuni ci̱ka ku ce̱u̱, bambe̱ bu ko̱ pu nu̱wa ke̱ndau̱.  
\v 7 Bu ambi̱ra ki̱lang ki̱lang bu sa kwati̱mba ya, <A wuni bo̱nggo̱ bo̱o̱re̱, anda wo̱o̱ so̱ngma Galili a gawu̱r mbi̱ri̱. Bu kwe̱e̱ we̱i̱ yo̱ pwii.> Yo̱ko̱ n sambi̱ra.>> 
\p  
\v 8 Di̱ngi̱n to̱no̱ nu̱ru̱mba bwii yala bu̱ri̱ du̱ puri dwii yi̱ gwasi̱, yi̱ bu̱ri̱ de̱gde̱g, pma ceendo ba sa kwati̱mba ya.  
\v 9 Ki̱nangu̱ kwii Yesu baa bo̱nggo̱ pmau ce̱ ki̱n, <<N ci̱gu̱ mbi̱ru̱.>> Pma baanga bo̱nggo̱ yo̱u̱ kwiino mwar ye̱i̱ a ku̱raman yo̱ si̱ma.  
\v 10 Yesu sa pma ki̱n, <<Bu nu̱u̱ ya gwasi̱, bu ambi̱ra bu sa ci̱yamba muwa ba aanda Galili, pma ko̱nggu̱ we̱i̱ pwii.>> 
\s1 Ci̱ye̱i̱ du nu̱wa bu swe̱ri̱gu̱ puri Yesu de̱e̱ 
\p  
\v 11 Pu nu̱ru̱mba bwii bo̱o̱ nyinou, bu kangga cu̱du̱ nu̱wa bu swe̱ri̱gu̱ puri Yesu wa mwatanga mi̱ri̱nggu̱ gwe̱i̱ a sa bagi̱raa kuruwa wa kana ca tu ni̱ngwa.  
\v 12 Pu bagi̱raa kuruwa wa kaanga yi̱ bagi̱raa nu̱wa wa, pma sedo pwi̱i̱, pma nyi̱i̱ kacara bwii ke̱n tum.  
\v 13 Pma ba sa pma ki̱n, <<Bu sa nu̱wa mi̱n, <Kwati̱mba ya baanga yi̱ ku̱me̱ ba ji̱nda yo̱ pu yi bo̱o̱ diimandu.>>>  
\v 14 Ka do̱o̱ ci̱ye̱i̱ lam bo̱nggo̱ gomna, yo nyan dwii yiri yi di̱ramanu̱ we̱i̱ yo̱ gaanggu̱ pero yi yiki mbi̱ri̱ we̱i̱ a ku̱u̱le̱.>>  
\v 15 Di̱ngi̱n to̱no̱ pma de̱e̱ ke̱n dwii ni̱nga tu nu̱wa sa pmai. Wo̱o̱ labar wasi̱ bu̱ri̱ kwaara bo̱nggo̱ nu̱wa bu Yudaya wa a baa ki̱na nyanggu̱. 
\s1 Te̱e̱ri̱ du gi̱rai̱ 
\p  
\v 16 Kwati̱mba ya bu kwap su̱r wiino bwii a aanda Galili, a ci̱ngu̱ ku Yesu sa pmau.  
\v 17 Pu ko̱ yo̱, pma ku̱raman yo̱ si̱ma anda bu kangga le̱e̱ bu ki̱n wii Yesu.  
\v 18 Yesu baa bo̱nggo̱ pmau a ce̱ ki̱n, <<Mwa mwa di̱mbi̱re̱ wu diyou yi̱ si̱ma nu̱wa nyi̱ngge̱  
\v 19 Di̱ngi̱n to̱no̱ bu ambi̱ra a kana pi̱yau̱ mi̱ri̱nggi̱ si̱ma bu yi̱we̱ nu̱wa mwa mwa ba yo̱o̱ kwati̱mba muwa, bu ni̱ngaman pma bati̱si̱ma mi̱ri̱nggi̱ din Mbaate̱ yi̱ du Bwi̱ya yi̱ du Bawei du Walwal.  
\v 20 Bu pi̱r pma ba ni̱nga po̱ngo̱ndi̱ yi̱ kana ca tu n sa mbi̱rai̱. Ji̱re̱, n wo̱o̱ kem yi̱ mba kana pe̱ne̱ pe̱ne̱, ko̱po̱ nyanggu̱ gwatu̱gu̱ si̱mai̱.>> 