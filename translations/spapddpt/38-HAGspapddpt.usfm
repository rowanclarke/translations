\c 2  
\s1 El nuevo templo  
\p
\v 1 \w El|strong="H5030"\w* 21 del \w mes|strong="H2320"\w* \w sûˋptimo|strong="H7637"\w*, la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd* \w vino|strong="H1961"\w* \w por|strong="H1697"\w* \w medio|strong="H3027"\w* del \w profeta|strong="H5030"\w* Hageo:  
\v 2 \wj Habla \+w ahora|strong="H4994"\+w* \+w a|strong="H3068"\+w* \+w Zorobabel|strong="H2216"\+w*, \+w hijo|strong="H1121"\+w* \+w de|strong="H1121"\+w* Salatiel, \+w gobernador|strong="H6346"\+w* \+w de|strong="H1121"\+w* \+w JudûÀ|strong="H3063"\+w*, y \+w a|strong="H3068"\+w* \+w Josuûˋ|strong="H3091"\+w*, \+w hijo|strong="H1121"\+w* del \+w sumo|strong="H1419"\+w* \+w sacerdote|strong="H3548"\+w* Josadac, y al \+w resto|strong="H7611"\+w* del \+w pueblo|strong="H5971"\+w*: \wj*  
\v 3 \wj ô¢\+w Quiûˋn|strong="H4310"\+w* \+w de|strong="H5869"\+w* ustedes \+w vio|strong="H7200"\+w* \+w esta|strong="H2088"\+w* \+w Casa|strong="H1004"\+w* en su \+w primer|strong="H7223"\+w* esplendor? ô¢\+w Y|strong="H3068"\+w* \+w cû°mo|strong="H4100"\+w* la \+w ve|strong="H7200"\+w* \+w ahora|strong="H6258"\+w*? ô¢\+w No|strong="H3808"\+w* les parece \+w como|strong="H4100"\+w* \+w nada|strong="H3808"\+w* en comparaciû°n?\wj*  
\v 4 \wj \+w Ahora|strong="H6258"\+w* \+w pues|strong="H3588"\+w*, \+w esfuûˋrzate|strong="H2388"\+w*, \+w Zorobabel|strong="H2216"\+w*,\wj* \w dice|strong="H5002"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd*. \wj \+w Esfuûˋrzate|strong="H2388"\+w* \+w tû¤|strong="H6213"\+w* tambiûˋn, \+w Josuûˋ|strong="H3091"\+w*, \+w hijo|strong="H1121"\+w* del \+w sumo|strong="H1419"\+w* \+w sacerdote|strong="H3548"\+w* Josadac, \+w y|strong="H3588"\+w* esfuûˋrcese \+w todo|strong="H3605"\+w* \+w el|strong="H3588"\+w* \+w pueblo|strong="H5971"\+w* \+w de|strong="H3588"\+w* esta tierra. Actû¤en, \+w porque|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* estoy \+w con|strong="H3588"\+w* ustedes,\wj* \w dice|strong="H5002"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd* \w de|strong="H3588"\w* las huestes.  
\v 5 \wj Segû¤n el Pacto \+w que|strong="H1697"\+w* \+w hice|strong="H3772"\+w* con ustedes cuando \+w salieron|strong="H3318"\+w* \+w de|strong="H1697"\+w* \+w Egipto|strong="H4714"\+w*, mi \+w EspûÙritu|strong="H7307"\+w* \+w estarûÀ|strong="H5975"\+w* \+w en|strong="H8432"\+w* \+w medio|strong="H8432"\+w* \+w de|strong="H1697"\+w* ustedes. No \+w teman|strong="H3372"\+w*.\wj*   
\p
\v 6 \w Porque|strong="H3588"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd* \w de|strong="H3588"\w* las huestes dice: \wj \+w Dentro|strong="H5750"\+w* \+w de|strong="H3588"\+w* \+w poco|strong="H4592"\+w* \+w Yo|strong="H3588"\+w* estremecerûˋ \+w el|strong="H1931"\+w* \+w cielo|strong="H8064"\+w* \+w y|strong="H3588"\+w* \+w la|strong="H1931"\+w* tierra, \+w el|strong="H1931"\+w* \+w mar|strong="H3220"\+w* \+w y|strong="H3588"\+w* \+w la|strong="H1931"\+w* tierra seca.\wj*  
\v 7 \wj Estremecerûˋ \+w a|strong="H3068"\+w* \+w todas|strong="H3605"\+w* las \+w naciones|strong="H1471"\+w* \+w y|strong="H3519"\+w* vendrûÀn al Deseado de \+w todas|strong="H3605"\+w* las \+w naciones|strong="H1471"\+w*. \+w Y|strong="H3068"\+w* Yo llenarûˋ de \+w gloria|strong="H3519"\+w* \+w este|strong="H2088"\+w* \+w Templo|strong="H1004"\+w*,\wj* dice \nd \+w Yavûˋ|strong="H3068"\+w*\nd* de las huestes.  
\v 8 \wj MûÙa es la \+w plata|strong="H3701"\+w* y mûÙo es el \+w oro|strong="H2091"\+w*,\wj* \w dice|strong="H5002"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd* de las huestes.  
\v 9 \wj La \+w gloria|strong="H3519"\+w* final \+w de|strong="H4480"\+w* \+w este|strong="H2088"\+w* \+w Templo|strong="H1004"\+w* \+w serûÀ|strong="H1961"\+w* \+w mayor|strong="H1419"\+w* \+w que|strong="H4480"\+w* la \+w del|strong="H4480"\+w* \+w primero|strong="H7223"\+w*. \+w En|strong="H4480"\+w* \+w este|strong="H2088"\+w* \+w lugar|strong="H4725"\+w* \+w darûˋ|strong="H5414"\+w* \+w paz|strong="H7965"\+w*,\wj* \w dice|strong="H5002"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd* \w de|strong="H4480"\w* las huestes.   
\s1 Recordatorio  
\p
\v 10 \w El|strong="H5030"\w* dûÙa 24 del \w noveno|strong="H8671"\w* mes, en \w el|strong="H5030"\w* \w segundo|strong="H8147"\w* \w aûÝo|strong="H8141"\w* \w de|strong="H1697"\w* \w DarûÙo|strong="H1867"\w*, \w vino|strong="H1961"\w* la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd* \w por|strong="H1697"\w* medio del \w profeta|strong="H5030"\w* Hageo:  
\v 11 \nd \+w Yavûˋ|strong="H3068"\+w*\nd* de la huestes dice: \wj \+w Pregunta|strong="H7592"\+w* \+w ahora|strong="H4994"\+w* \+w a|strong="H3068"\+w* los \+w sacerdotes|strong="H3548"\+w* con respecto \+w a|strong="H3068"\+w* la \+w Ley|strong="H8451"\+w*: \wj*  
\v 12 \wj \+w Si|strong="H2005"\+w* \+w alguno|strong="H3605"\+w* \+w lleva|strong="H5375"\+w* \+w carne|strong="H1320"\+w* \+w consagrada|strong="H6944"\+w* en \+w la|strong="H3605"\+w* falda de su ropa, y \+w con|strong="H5060"\+w* \+w ella|strong="H3605"\+w* \+w toca|strong="H5060"\+w* algû¤n \+w pan|strong="H3899"\+w*, \+w vianda|strong="H3899"\+w*, \+w vino|strong="H3196"\+w*, \+w aceite|strong="H8081"\+w* \+w o|strong="H3068"\+w* \+w cualquier|strong="H3605"\+w* alimento, ô¢\+w son|strong="H3808"\+w* \+w santificados|strong="H6942"\+w*?\wj*  
\p \w Y|strong="H3068"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w respondieron|strong="H6030"\w*: \w No|strong="H3808"\w*.   
\p
\v 13 Hageo dijo: \w Si|strong="H5315"\w* un impuro \w a|strong="H3068"\w* causa de un cadûÀver, \w toca|strong="H5060"\w* \w cualquiera|strong="H3605"\w* de estas cosas, ô¢\w serûÀ|strong="H2930"\w* impuro?  
\p \w Y|strong="H3068"\w* contestaron \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w*: \w SerûÀ|strong="H2930"\w* impuro.   
\p
\v 14 \w Y|strong="H3068"\w* Hageo \w respondiû°|strong="H6030"\w*: \wj \+w AsûÙ|strong="H3651"\+w* \+w es|strong="H1931"\+w* \+w este|strong="H2088"\+w* \+w pueblo|strong="H5971"\+w* y \+w esta|strong="H2088"\+w* \+w naciû°n|strong="H1471"\+w* \+w delante|strong="H6440"\+w* \+w de|strong="H6440"\+w* \+w MûÙ|strong="H6030"\+w*, \wj*\w dice|strong="H5002"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd*. \wj \+w Toda|strong="H3605"\+w* \+w obra|strong="H4639"\+w* \+w de|strong="H6440"\+w* \+w sus|strong="H1931"\+w* \+w manos|strong="H3027"\+w* y \+w todo|strong="H3605"\+w* \+w lo|strong="H1931"\+w* \+w que|strong="H1931"\+w* \+w ofrecen|strong="H7126"\+w* \+w allûÙ|strong="H8033"\+w* \+w es|strong="H1931"\+w* impuro.\wj*  
\v 15 \wj \+w Ahora|strong="H6258"\+w* \+w pues|strong="H4994"\+w*, \+w desde|strong="H4480"\+w* \+w hoy|strong="H3117"\+w* \+w en|strong="H4480"\+w* adelante, reflexionen \+w antes|strong="H2962"\+w* \+w que|strong="H4480"\+w* coloquen piedra \+w sobre|strong="H4605"\+w* piedra \+w en|strong="H4480"\+w* la Casa \+w de|strong="H4480"\+w* \+nd \+w Yavûˋ|strong="H3068"\+w*\+nd*.\wj*  
\v 16 \wj En aquel tiempo, \+w cuando|strong="H1961"\+w* alguien iba \+w a|strong="H3068"\+w* una pila de 20 medidas, solo hallaba \+w diez|strong="H6235"\+w*, \+w o|strong="H3068"\+w* \+w cuando|strong="H1961"\+w* iba al \+w lagar|strong="H3342"\+w* \+w para|strong="H1961"\+w* sacar 50 cubos, solo \+w habûÙa|strong="H1961"\+w* 20.\wj*  
\v 17 \wj \+w Los|strong="H3605"\+w* golpeûˋ con honguillo, parûÀsito y \+w granizo|strong="H1259"\+w* \+w en|strong="H5221"\+w* \+w toda|strong="H3605"\+w* \+w obra|strong="H4639"\+w* de sus \+w manos|strong="H3027"\+w*, pero \+w ninguno|strong="H3605"\+w* de ustedes se volviû° \+w a|strong="H3068"\+w* mûÙ,\wj* \w dice|strong="H5002"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd*.  
\v 18 \wj Reflexionen, \+w pues|strong="H4994"\+w*, \+w desde|strong="H4480"\+w* \+w hoy|strong="H3117"\+w* \+w en|strong="H4480"\+w* adelante, \+w desde|strong="H4480"\+w* el \+w dûÙa|strong="H3117"\+w* 24 \+w del|strong="H4480"\+w* mes \+w noveno|strong="H8671"\+w*, \+w a|strong="H3068"\+w* partir \+w del|strong="H4480"\+w* \+w dûÙa|strong="H3117"\+w* \+w cuando|strong="H3117"\+w* \+w se|strong="H4480"\+w* echû° el \+w cimiento|strong="H3245"\+w* \+w de|strong="H4480"\+w* la Casa \+w de|strong="H4480"\+w* \+nd \+w Yavûˋ|strong="H3068"\+w*\+nd*. Reflexionen: \wj*  
\v 19 \wj ô¢\+w EstûÀ|strong="H2088"\+w* \+w aû¤n|strong="H5750"\+w* la semilla \+w en|strong="H4480"\+w* el granero? \+w Ni|strong="H3808"\+w* la \+w vid|strong="H1612"\+w*, \+w ni|strong="H3808"\+w* la higuera, \+w ni|strong="H3808"\+w* el granado, \+w ni|strong="H3808"\+w* el olivo produjeron, pero \+w desde|strong="H4480"\+w* \+w hoy|strong="H3117"\+w* \+w en|strong="H4480"\+w* \+w adelante|strong="H5750"\+w* los \+w bendecirûˋ|strong="H1288"\+w*.\wj*   
\s1 Contra los gentiles  
\p
