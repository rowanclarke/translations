\id 1CH
\h I. Oihanaalii
\toc1 I. Oihanaalii
\toc2 I. Oihanaalii
\toc3 I. Oihanaalii
\mt1 I. Oihanaalii
\c 1
\s1 KA BUKE MUA
\q1 
\v 1 O ADAMU, o Seta, o Enosa,
\q1 
\v 2 O Kainana, o Mahalaleela, o Iereda,
\q1 
\v 3 O Enoka, o Metusala, o Lameka,
\q1 
\v 4 O Noa, o Sema, o Hama, a o Iapeta.
\b
\q1 
\v 5 Eia na keikikane a Iapeta; o Gomera, o Magoga, o Madai, o Iavana, o Tubala, o Meseka, a o Tirasa.
\q1 
\v 6 A o na keikikane a Gomera; o Asekenaza, o Ripata, a o Togarema.
\q1 
\v 7 A o na keikikane a Iavana; o Elisa, o Tarehisa, o Kitima, a o Dodanima.
\b
\q1 
\v 8 Eia na keikikane a Hama; o Kusa, o Mizeraima, o Puta, a o Kanaana.
\q1 
\v 9 A o na keikikane a Kusa; o Seba, o Havila, o Sabeta, o Raama, a o Sabeteka. A o na keikikane a Raama; o Seba, a o Dedana.
\q1 
\v 10 Na Kusa o Nimeroda; oia ka i lilo i mea ikaika maluna o ka honua.
\q1 
\v 11 Na Mizeraima o ka Luda, o ka Anama, o ka Lehaba, o ka Napetuha,
\q1 
\v 12 O ka Paterusa, o ka Kaselusa, (nana mai ko Pilisetia,) a o ka Kapetora.
\b
\q1 
\v 13 Na Kanaana o Zidona kana hiapo, a o Heta,
\q1 
\v 14 A o ka Iebusa, a o ka Amora, a o ka Giregasa,
\q1 
\v 15 A o ka Hivi, a o ka Areki, a me ka Sini,
\q1 
\v 16 A o ka Arevadi, a o ka Zemari, a o ka Hamati.
\b
\q1 
\v 17 Eia na keikikane a Sema, o Elama, o Asura, o Arepakada, o Luda, o Arama, o Uza, o Hula, o Getera, a o Meseka.
\q1 
\v 18 Na Arepakada o Sela, na Sela o Ebera.
\q1 
\v 19 Na Ebera i hanau na keikikane elua: o Pelega ka inoa o kekahi; no ka mea, ua mokuhia ka honua i kona manawa; a o Ioketana ka inoa o kona kaikaina.
\q1 
\v 20 Na Ioketana o Alemodada, a o Selepa, o Hazemaveta, a o Iera,
\q1 
\v 21 O Hadorama hoi, o Uzala, a o Dikela,
\q1 
\v 22 A o Ebala, o Abimaela a me Seba,
\q1 
\v 23 O Opira, o Havila, a o Iobaba. O lakou nei a pau na keikikane a Ioketana,
\b
\q1 
\v 24 O Sema, o Arepakada, o Sela,
\q1 
\v 25 O Ebera, o Pelega, o Reu,
\q1 
\v 26 Seruga, o Nahora, o Tera,
\q1 
\v 27 O Aberama, oia hoi o Aberahama,
\b
\q1 
\v 28 Eia na keikikane a Aberahama, o Isaaka a me Isemaela.
\b
\q1 
\v 29 Eia na hanauna o lakou: o ka makahiapo a Isemaela, oia o Nebaiota; alaila o Kedara, o Adebeela, o Mibesama,
\q1 
\v 30 O Misama, o Duma, o Masa, o Hadada, a o Tema;
\q1 
\v 31 O Ietura, o Napisa, a o Kedema: oia na keikikane a Isemaela.
\b
\q1 
\v 32 Eia na keikikane a Ketura, a ka haiawahine a Aberahama: hanau ae la oia ia Zimerana, ia Iokesana, ia Medana, ia Midiana, ia Isebaka, a me Sua. A eia na keikikane a lokesana, o Seba a o Dedana.
\q1 
\v 33 Eia na keikikane a Midiana; o Epa, o Ebera, o Henoka, o Abida, a o Eledaa. O lakou nei a pau na keikikane a Ketura.
\b
\q1 
\v 34 Na Aberahama o Isaaka. O na keikikane a Isaaka, oia o Esau a o Iseraela.
\b
\q1 
\v 35 Eia na keikikane a Esau; o Elipaza, o Reuela, o Ieusa, o Iaalama, a o Kora.
\q1 
\v 36 Eia na keikikane a Elipaza; o Temaua, o Omara, o Zepi, o Gatama, o Kenaza, o Timena, a o Amaleka.
\q1 
\v 37 Eia na keikikane a Reuela; o Nahata, o Zera, o Sama, a o Miza:
\b
\q1 
\v 38 A eia na keikikane a Seira; o Lotana, o Sobala, o Zibeona, o Ana, o Disehona, o Ezara, a o Disana.
\q1 
\v 39 Eia na keikikane a Lotana; o Hori, a o Homama: a o Timena ke kaikuwahine o Lotana.
\q1 
\v 40 O na keikikane a Sobala; o Aliana, o Manahata, o Ebala, o Sepi, a o Onama. O na keikikane a Zibeona; o Aia a o Ana.
\q1 
\v 41 O ke keikikane a Ana; o Disona. A o na keikikane a Disona; o Amerama, o Esebana, o Iterana, a o Kerana.
\q1 
\v 42 Eia na keikikane a Ezera; o Bilehana, o Zavana, a o Iakana. O na keikikane a Disana; o Uza, a o Arana.
\b
\q1 
\v 43 Eia hoi na alii i nohoalii ai ma ka aina ma Edoma, mamua aku o ka nohoalii ana o kekahi alii maluna o na mamo a Iseraela; o Bela ke keiki a Beora; a o Dinehaba ka inoa o kona kulanakauhale.
\q1 
\v 44 A make iho o Bela, alaila alii iho la o Iobaba ke keiki a Zera no Bozera, ma kona hakahaka.
\q1 
\v 45 A make iho o Iobaba, alii iho la o Husama no ka aina o ka Temaui, ma koua hakahaka.
\q1 
\v 46 A make iho o Husama, alii iho la ma kona hakahaka o Hadada ke keikikane a Bedada, nana i pepehi i ka Midiana ma ke kula o Moaba; a o Avita ka inoa o kona kulanakauhale.
\q1 
\v 47 A make iho o Hadada, alii ae la o Samela, no Masereka, ma kona hakahaka.
\q1 
\v 48 A make iho o Samela, alii ae la ma kona hakahaka o Sanla, no Rehobota ma ka muliwai.
\q1 
\v 49 A make iho o Saula, alii ae la ma kona hakahaka o Baalahanana, ke keiki a Akebora.
\q1 
\v 50 A make iho o Baalahanana, alii ae la o Hadada ma kona hakahaka: a o Pai ka inoa o kona kulanakauhale; a o Mehetabela ka inoa o kana wahine, oia ke kaikamahine a Matereda, ke kaikamahine a Mezahaba.
\b
\q1 
\v 51 Make iho la o Hadada. Eia na makualii o Edoma: o Timena he makualii, o Alia he makualii, o Ieteta he makualii,
\q1 
\v 52 O Aholibama he makualii, o Ela he makualii, o Pinona he makualii,
\q1 
\v 53 O Kenaza he makualii, o Temana he makualii, o Mibeza he makualii,
\q1 
\v 54 O Magediela he makualii, o Irama he makualii. O lakou nei na makualii no Edoma.
\c 2
\b
\q1 
\v 1 EIA na keikikane a Iseraela; o Reubena, o Simeona, o Levi, o Iuda, o Isakara, a o Zebuluna,
\q1 
\v 2 O Dana, o Iosepa, a o Beniamina, o Napetali, o Gada, a o Asera.
\b
\q1 
\v 3 O na keikikane a Iuda; o Era, o Onana, a o Sela: ua hanau nana ia mau mea ekolu na ke kaikamahine a Sua no Kanaana. A ua hewa o Era ka hanau mua a Iuda imua o na maka o Iehova; a pepehi mai la oia ia ia.
\q1 
\v 4 Na Tamara na kana hunonawahine i hanau nana o Pareza laua o Zara. O na keikikane a pau a Iuda, elima lakou.
\b
\q1 
\v 5 O na keikikane a Pareza; o Hezerona a o Hamula.
\q1 
\v 6 O na keikikane a Zara; o Zimeri, o Etana, o Hemaua, o Kalekola, a o Dara: he elima o lakou a pau.
\q1 
\v 7 O na keiki a Karemi; o Akana, ka mea hoopilikia i ka Iseraela, nana i lawehala i ka mea i laa.
\q1 
\v 8 O ke keikikane a Etana; o Azaria.
\b
\q1 
\v 9 O na keikikane hoi a Hezerona, i hanau nana; o Ierameela, o Rama, a o Kelubai.
\q1 
\v 10 Na Rama o Aminadaba, na Aminadaba o Nahasona, ka luna o na mamo a Iuda:
\q1 
\v 11 Na Nahasona o Salemona, na Salemona o Boaza,
\q1 
\v 12 Na Boaza o Obeda, na Obeda o Iese.
\b
\q1 
\v 13 Na Iese o Eliaba kana hanau mua, o Abinadaba hoi ka lua, a o Sima ke kolu,
\q1 
\v 14 O Netaneela ka ha, o Radai ka lima,
\q1 
\v 15 O Ozema ke ono, o Davida ka hiku.
\q1 
\v 16 O ko lakou mau kaikuwahine, o Zeruia a o Abigaila. A o na keikikane a Zeruia, ekolu lakou; o Abisai, o Ioaba, a o Asahela.
\q1 
\v 17 Na Abigaila i hanau o Amasa: a o ka makuakane o Amasa, oia o Ietera no ka Isemaela.
\b
\q1 
\v 18 Na Kaleba na ke keiki a Hezerona, na laua o Azaba kana wahine a me Ieriota: eia na keikikane ana; o Iesera, o Sobaba, a o Aredona,
\q1 
\v 19 A make iho o Azuba, lawe ae la o Kaleba nana ia Eperata, a hanau mai la oia ia Hura nana.
\q1 
\v 20 Na Hura o Uri, a na Uri o Bezeleela.
\b
\q1 
\v 21 A mahope iho, komo aku la o Hezerona iloko i ke kaikamahine a Makira a ka makuakane o Gileada, a lawe ae la oia ia ia i kona makahiki he kanaono, a hanau mai la nana o Seguba.
\q1 
\v 22 Na Seguba o Iaira, ia ia na kulanakauhale he iwakaluakumamalua ma ka aina o Gileada.
\q1 
\v 23 A lawe ae la oia ia Gesura a me Arama a me na kulanakauhale o Iaira mai o lakou aku, a me Kenata a me na kulanakauhale olaila, na kulanakauhale he kanaono: no na keikikane a Makira a ka makuakane o Gileada keia mau wahi a pau.
\q1 
\v 24 A mahope iho o ka make ana o Hezerona ma Kalebeperata, alaila hanau mai la o Abia ka wahine a Hezerona ia Asura nana, o ka makuakane ia o Tekoa.
\b
\q1 
\v 25 Eia na keikikane a Ieramulae a ka makahiapo a Hezerona, o Rama ka hanau mua, o Buna, o Orena, o Ozema, o Ahiia.
\q1 
\v 26 Na Ierameela kekahi wahine e ae, o Atara kona inoa; oia ka makuwahine o Onama.
\q1 
\v 27 O na keikikane a Rama a ka Ieramula makahiapo; o Maaza, o Iamina, a o Ekera.
\q1 
\v 28 A o Samai laua o Iada na keikikane a Onama. O na keikikane a Samai; o Nadaba a o Abisura.
\q1 
\v 29 A o Abihaila ka inoa o ka wahine a Abisura: a hanau mai la oia nana ia Abana a me Molida.
\q1 
\v 30 O na keikikane a Nadaba; o Seleda, a o Apaima: a make keiki ole o Seleda.
\q1 
\v 31 O ke keikikane a Apaima; o Isi. A o ke keikikane a Isi; o Sesana. A o ke keikikane a Sesana; o Ahelai.
\q1 
\v 32 A o na keikikane a Iada a ke kaikaina o Samai; o Ietura a o Ionatana: a make keiki ole o Ietura.
\q1 
\v 33 A o na keikikane a Ionatana: o Peleta a o Zaza. O laua na keiki a Ierahemeela.
\b
\q1 
\v 34 Aohe keikikane a Sesana, he mau kaikamahine no nae. A he kauwakane ia Sesana, he Aigupita, o Iareha kona inoa.
\q1 
\v 35 A haawi aku la o Sesana i kana kaikamahine i wahine na Iareha na kana kauwa, a hanau mai la ia nana o Atai.
\q1 
\v 36 Na Atai o Natana, na Natana o Zabada.
\q1 
\v 37 Na Zabada o Epelala, na Epelala o obeda,
\q1 
\v 38 Na Obeda o Iehu, na Iehu o Azaria,
\q1 
\v 39 Na Azaria o Heleza, na Heleza o Eleasa.
\q1 
\v 40 Na Eleasa o Sisamai, na Sisamai o Saluma,
\q1 
\v 41 Na Saluma o Iekamia, na Iekamia o Elisama.
\b
\q1 
\v 42 A o na keikikane a Kaleba a ke kaikaina o Ierahemeela; o Mesa kona makahiapo, oia ka makuakane o Zipa: a o na keikikane a Maresa ka makuakane o Heberona.
\q1 
\v 43 A o na keikikane a Heberona; o Kora, o Tapua, o Rekema a o Sema.
\q1 
\v 44 Na Sema o Rahama ka makuakane o Iorekoama; na Rekema hoi o Samai.
\q1 
\v 45 A o ke keikikane a Samai; o Maona: a o Maona ka makuakane o Betezura.
\q1 
\v 46 Na Epa, na ka haiawahine a Kaleba i hanau o Harana, o Moza, a o Gazeze: a na Harana o Gazeze.
\q1 
\v 47 O na keikikane a Iadai, o Regema, o Iotama, o Gesana, o Peleta, o Epa, a o Saapa.
\q1 
\v 48 Na Maaka, na ka haiawahine a Kaleba i hanau o Sebera a o Tirana.
\q1 
\v 49 Nana hoi i hanau o Saapa ka makuakane o Mademaua, a o Seva ka makuakane o Makebeua, a o ka makuakane o Gibea: a o Akesa ke kaikamahine a Kaleba.
\b
\q1 
\v 50 Eia na keikikane a Kaleba ke keiki a Hura, a ka makahiapo a Eperata; o Sobala ka makualeane o Kiriatiarima;
\q1 
\v 51 O Salema ka makuakane o Betelehema, o Hareta ka makuakane o Betegadera.
\q1 
\v 52 Ia Sobala hoi ka makuakane o Kiriatiarima na keikikane; o Haroka, a o Hatesihamenuti.
\q1 
\v 53 Eia na ohana a Kiriatiarima; ka poe Iteri, ka poe Puhi, ka poe Sumati, a me ka poe Miserai: na lakou i puka mai ai ka poe Zareati, a me ka poe Esetauli.
\q1 
\v 54 O na keikikane a Salema; o Betelehema, a me ka poe Netopati, o Atarota o Betaioaba, o Hatesihamenuti, a o ka poe Zori.
\q1 
\v 55 A o na ohana o ka poe kakauolelo i noho ma Iabeza, ka poe Tireti, ka poe Simeati, a o ka poe Sukati. O lakou ka poe Keni i puka mai mai Hemata mai, ka makuakane o ka ohana o Rekaba.
\c 3
\b
\q1 
\v 1 EIA hoi na keikikane a Davida, i hanau nana ma Heberona; o Amenona ka makahiapo, na Ahinoama no Iezereela; o Daniela ka lua, na Abigaila no Karamela;
\q1 
\v 2 A o ke kolu o Abesaloma ke keiki a Maaka a ke kaikamahine a Talemai ke alii o Gasura; o ka ha, o Adoniia ke keiki a Hagita;
\q1 
\v 3 O ka lima, o Sepatia na Abitala; o ke ono, o Itereama na Egela ka Davida wahine.
\q1 
\v 4 Ua hanau nana keia poe eono ma Heberona; ilaila oia i alii ai i na makahiki ehiku a me na malama keu eono: a ma Ierusalema hoi oia i alii iho ai i na makahiki he kanakolu a me kumamakolu.
\q1 
\v 5 Eia hoi ka poe i hanau nana ma Ierusalema; o Simea, o Sobaba, o Natana, a o Solomona, eha, na Batesua na ke kaikamahine a Amiela.
\q1 
\v 6 O Ibehara hoi, o Elisama, o Elipeleta,
\q1 
\v 7 O Noga, o Nepega, o Iapia.
\q1 
\v 8 O Elisama, o Eliada, a o Elipeleta, eiwa.
\q1 
\v 9 O lakou na keiki a pau a Davida, he okoa na keikikane a na haiawahine, a o Tamara ko lakou kaikuwahine.
\b
\q1 
\v 10 A o ke keikikane a Solomona, oia o Rehoboama, o Abia kana keiki, o Asa kana keiki, o Iehosapata kana keiki,
\q1 
\v 11 O Iorama kana keiki, o Ahazia kana keiki, o Ioasa kana keiki,
\q1 
\v 12 O Amazia kana keiki, o Azaria kana keiki, o Iotama kana keiki,
\q1 
\v 13 O Ahaza kana keiki, o Hezekia kana keiki, o Manase kana keiki,
\q1 
\v 14 O Amona kana keiki, o Iosia kana keiki
\q1 
\v 15 Eia na keikikane a Iosia; o Iohanana ka hanau mua, o Iehoiakima ka lua, o Zedekia ke kolu; a o Saluma ka ha.
\q1 
\v 16 Eia na keikikane a Iehoiakima, o Iekonia kana keiki, o Zedekia kana keiki.
\b
\q1 
\v 17 O na keikikane a Iekonia, o Asira; o Salatiela kana keiki
\q1 
\v 18 O Malekirama hoi, o Pedaia, o Senazara, o Iekamia, o Hosama, a o Nedabia.
\q1 
\v 19 A o na keikikane a Pedaia, o Zerubabela, a o Simei; o na keikikane a Zerubabela, o Mesulama, a o Hanania; a o Selomita, ko laua kaikuwahine.
\q1 
\v 20 O Hasuba hoi, o Ohela, o Berekia, o Hasadia, a o Iusabaheseda, elima.
\q1 
\v 21 A na keikikane a Hanania; o Peletia, a o Iesaia; a o na keikikane a Repaia, o na keikikane a Arenana, o na keikikane a Obadia, o na keikikane a Sekania.
\q1 
\v 22 O ke keikikane a Sekania; o Semaia; a o na keikikane a Semaia; o Hatusa, o Igeala, o Baria, o Nearia, a o Sapata, eono.
\q1 
\v 23 A o na keikikane a Nearia; o Elioenai, o Hezekia, a o Azarikama, ekolu.
\q1 
\v 24 A o na keikikane a Elioenai; o Hodaia, o Eliasiba, o Pelaia, o Akuba, o Iohanana, o Delaia, a o Anani, ehiku.
\c 4
\b
\q1 
\v 1 EIA na keikikane a Iuda; o Pareza, o Hezerona, o Karemi, o Hura, a o Sobala.
\q1 
\v 2 Na Reaia na ke keiki a Sobala o Iahata, a na Iahata o Ahumai laua o Lahada. O lakou na ohana o ka Zorari.
\q1 
\v 3 O lakou nei, na ka makuakano o Etama: o Iezereela, o Isema, a o Idebasa: a o Hazeleleponi ka inoa o ko lakou kaikuwahine.
\q1 
\v 4 A o Penuela ka makuakane o Gedora, a o Ezera ka makuakane a Husa. O laua na keikikane a Hura, a ka hanau mua na Eperata, na ka makuakane o Betelehema.
\b
\q1 
\v 5 Na Asura na ka makuakane o Tekoa he mau wahine elua, o Hela, a o Naara.
\q1 
\v 6 Na Naara i hanau nana o Ahuzama, o Hepera, o Temeni a o Haahasetari. O lakou na keikikane na Naara.
\q1 
\v 7 O na keikikane a Hela; o Zereta, o Iezoara, a o Etenana.
\q1 
\v 8 Na Koza o Anuba, a o Zobeba, a me na ohana a Ahahela ke keikikane a Haruma.
\b
\q1 
\v 9 Ua oi aku ka maikai o Iabeza imua o ko na hoahanau ona; a kapa iho la kona makuwahine ia ia o Iabeza, me ka i ana, No ka mea, hoohanau iho la au ia ia me ka eha.
\q1 
\v 10 A kahea aku la o Iabeza i ke Akua o ka Iseraela, me ka i ana, Ina oe e hoopomaikai mai ia'u, a e hoonee aku i kuu palena aina, a me au pu hoi kou lima, a e malama mai oe ia'u i ka hewa, i hoeha ole mai ia ia'u i A haawi mai la ke Akua i kana mea i noi aku ai.
\b
\q1 
\v 11 Na Keluba ka hoahanau o Sua nana o Mehira, oia ka makuakane o Esetona.
\q1 
\v 12 Na Esetona o Beterapa, o Pasea, a o Tehina ka makuakane o Irenahasa. o lakou na kanaka o Reka.
\b
\q1 
\v 13 O na keikikane a Kenaza; o Oteniela a o Seraia: o ke keikikane a Oteniela; o Hatata.
\q1 
\v 14 Na Meonotai o Opera; na Seraia o Ioaba ka makuakane o ko ke awawa o Karasima, no ka mea, he poe paahana lakou.
\q1 
\v 15 O na keiki a Kaleba a ke keiki a Iepune; o Iru, o Ela, a o Naama; a o ke keikikane a Ela, oia o Kenaza.
\q1 
\v 16 O na keikikane a Iehaleleela: o Zipa, o Zipaha, o Tiria, a o Asareela.
\q1 
\v 17 O na keikikane a Ezera; o Ietera, o Mereda, o Epera, a o Ialona: a nana no i hanau o Miriama, o Samai, a o Iseba ka makuakane o Esetemoa.
\q1 
\v 18 A na kana wahine, na Iehudiia i hanau o Iereda ka makuakane o Gedora, a o Hebera ka makuakane o Soko, a o Iekutiela ka makuakane o Zanoa. O lakou na keikikane a Bitia a ke kaikamahine a Parao i laweia e Mereda.
\q1 
\v 19 A o na keikikane a Hodia ke kaikuwahine o Nahama ka makuakane o Keila no Garemi, a o Esetemoa no Maakata.
\q1 
\v 20 A o na keikikane a Simona, o Amenona, a o Rina, o Benehauana a o Tilona. A o na keikikane a Isehi, o Zoheta, a o Benezoheta.
\b
\q1 
\v 21 Eia na keikikane a Sela a ke keiki a Iuda, o Era ka makuakane o Leka, a o Laada ka makuakane o Maresa, a me na ohana o ka hale o lakou i hana i ka loleie nani, no ka hale o Asebea,
\q1 
\v 22 A o Iokima, a o na kanaka o Kozeba, a o Ioasa, a o Sarapa, ia ia ke alii ana o ka Moaba, a o Iasubi-lehema. A he mau meu kahiko keia.
\q1 
\v 23 O lakou na potera, a me ka poe i noho iwaena o na mea kanu a o na ululaau; ilaila lakou i noho ai mamuli o ke alii no kana hana.
\b
\q1 
\v 24 Eia na keikikane a Simeona; o Nemuela, e Iamina, o Iariba, o Zora, a o Saula:
\q1 
\v 25 O Saluma kana keiki, o Mibesama kana keiki, o Misema kana keiki.
\q1 
\v 26 O na keikikane a Misema; o Hamuela kana keiki, o Zakura kana keiki, o Simei kana keiki.
\q1 
\v 27 He umikumamaono na keikikane a Simei a me na kaikamahine eono; aole nae he nui na keiki a kona mau hoahanau, aole hoi i hoomahuahua ae na ohana a lakou a pau e like me na keiki a Iuda.
\q1 
\v 28 A noho iho la lakou i Beereseba a i Molada, a i Hazeresuala,
\q1 
\v 29 A i Bileha, a i Ezema, a i Tolada,
\q1 
\v 30 A i Betuela, a i Horema, a i Zikelaga,
\q1 
\v 31 A i Betamarekaba, a i Hazarasusa, a i Betebirei, a i Saaraima. Oia na kulanakauhale o lakou a hiki i ke au ia Davida.
\q1 
\v 32 A o ko lakou mau kauhale, o Etama, o Aina, o Rimona, o Tokena, a o Asana, elima na kulanakauhale:
\q1 
\v 33 A me na kauhale a pau a puni ia mau kulanakauhale a hiki i Baala. Oia na wahi noho o lakou, a me ko lakou anainakanaka.
\q1 
\v 34 A o Mesobaba, o Iameleka, a o Ioseha ke keiki a Amazia,
\q1 
\v 35 A o Ioela, a o Iehu ke keiki a Iosibia, ke keiki a Seraia, ke keiki a Asiela.
\q1 
\v 36 A o Elioenai, o Iaakoba, o Iesohaia, o Asaia, o Adiela, o Iesimiela, a o Benaia.
\q1 
\v 37 O Ziza ke keiki a Sipi, ke keiki a Alona, ke keiki a Iedaia, ke keiki a Simeri, ke keiki a Semaia:
\q1 
\v 38 O keia poe i kapaia ma ko lakou inoa, he poe alii lakou iloko o ko lakou mau ohana: a mahuahua nui ae la ka ohana a ko lakou mau makua.
\b
\q1 
\v 39 A hele aku la lakou ma ke komo ana o Gedora, ma ka aoao hikina o ke awawa, e imi ana i wahi e hanai ai i na holoholona no lakou.
\q1 
\v 40 A loaa iho la ia lakou kahi hanai momona a maikai, a he akea ka aina, a he maluhia me ka oluolu; no ka mea, ua noho kahiko ka Hama malaila.
\q1 
\v 41 A hele aku la keia poe i kakauia ma ka inoa, i ka wa o Hezekia ke alii o ka Iuda, a hahau iho la i ko lakou mau halelewa, a me na hale i loaa ilaila, a hokai loa ia lakou a hiki i keia manawa, a noho iho la ma ko lakou wahi; no ka mea, he wahi hanai ia no ko lakou holoholona.
\q1 
\v 42 A o kekahi poe o lakou, o na mamo a Simeona, he elima haneri kanaka i hele aku i ka mauna Seira, o Pelatia, o Nearia, o Repaia, a o Uziela, na keiki a Isi, ko lakou mau lunakoa.
\q1 
\v 43 A pepehi aku la lakou i ke koena o ka Ameleka i pakele, a noho iho la ilaila a hiki i keia manawa.
\c 5
\b
\q1 
\v 1 A O na keikikane a Reubena, a ka makahiapo a Iseraela, (no ka mea, oia ka makahiapo, aka, no kona hoohaumia ana i ka moe o kona makuakane, ua haawiia ka ka hanau mua ona no na keiki a Iosepa ke keiki a Iseraela; aole e heluia ke kuauhau mamuli o ko ka hanau mua;
\q1 
\v 2 No ka mea, ua oi aku o Iuda maluna o kona poe hoahanau, a nana mai ke alii nui; aka, no Iosepa ko ka hanau mua:)
\q1 
\v 3 O na keikikane a Reubena, o ka makahiapo a Iseraela, o Hanoka, o Palu, o Hezerona, a o Karemi.
\q1 
\v 4 O na keikikane a Ioela; o Semaia kana keiki, o Goga kana keiki, o Simei kana keiki,
\q1 
\v 5 O Mika kana keiki, o Reaia kana keiki, o Baala kana keiki,
\q1 
\v 6 O Beera kana keiki, oia ka Tilegatapilesera ke alii o Asuria i lawe aku ai: oia ka luna o ko Reubena.
\q1 
\v 7 Aia heluia ke kuauhau o ko lakou hanauna, o kona poe hoahanau ma ka lakou mau ohana, o ka luna, o Ieiela, a o Zekaria;
\q1 
\v 8 A o Bela ke keiki a Azaza, ke keiki a Sema, ke keiki a Ioela, oia ka i noho i Aroera, a hiki i Nebo, a i Baalameona.
\q1 
\v 9 A noho aku la ia ma ka hikina a hiki i ka palena o ka waoakua mai ka muliwai Euperate aku: no ka mea, ua nui loa ko lakou poe holoholona ma ka aina o Gileada.
\q1 
\v 10 A i ka wa ia Saula, kaua aku la lakou me ka Hagara, a hina iho lakou i ko lakou lima: a noho lakou i ko lakou mau halelewa ma ka aina hikina a pau o Gileada.
\b
\q1 
\v 11 A noho kupono mai la ia lakou na mamo a Gada, ma ka aina o Basana, a hiki i Saleka.
\q1 
\v 12 O Ioela ka luna, o Sapama malalo iho, o Iaanai, a o Sapata i Baasana.
\q1 
\v 13 O ka lakou poe hoahanau, no ka ohana o ko lakou mau makua, o Mikaela, o Mesulama, o Seba, o Iorai, o Iakana, o Zia, a o Hebera, ehiku.
\q1 
\v 14 Eia na keikikane a Abihaila ke keiki a Huri, ke keiki a Iaroa, ke keiki a Gileada, ke keiki a Mikaela, ke keiki a Iesisai, ke keiki a Iahedo, ke keiki a Buza:
\q1 
\v 15 O Ahi ke keiki a Abediela, ke keiki a Guni, ka luna o ka ohana o ko lakou mau makuakane.
\q1 
\v 16 A noho lakou i Gileada i Basana, iloko o kona mau kulanakauhale, a i na kula a pau o Sarona, a ma na mokuna o lakou.
\q1 
\v 17 Ua heluia lakou a pau ma na hanauna i na la o Iotama ke alii o ka luda, a i na la o Ieroboama ke alii o ka Iseraela.
\b
\q1 
\v 18 O na mamo a Reubena a me ka Gada, a me ka ohana hapa a Manase, na kanaka koa, na kanaka hiki ke lawe i ka palekaua a me ka pahikaua, a ke pana aku me ke kakaka, a he akamai i ke kaua, he kanahakumamaha tausani, ehiku haneri a me ke kanaono, i hele aku i ke kaua.
\q1 
\v 19 A kaua aku la lakou me ka Hagara, me Ietura, me Nepisa, a me Nodaba.
\q1 
\v 20 A ua kokuaia mai lakou i ke ku e i kela poe, a ua haawiia mai ka Hagara iloko o ko lakou lima, a me na mea a pau o lakou: no ka mea, kahea aku la lakou i ke Akua i ke kaua ana, a maliu mai la oia ia lakou; no ka mea, paulele no lakou maluna ona.
\q1 
\v 21 Kai pio aku la lakou i ka lakou holoholona, he kanalima tausani kamelo, a o na hipa elua haneri me kanalima tausani, a he poe miula elua tausani, a he poe kanaka hookahi haneri tausani.
\q1 
\v 22 No ka mea, hina iho la ka poe make he nui loa, no ka mea, no ke Akua ke kaua. A noho iho la lakou ma ko lakou wahi, a hiki i ka lawe ana aku.
\b
\q1 
\v 23 A noho iho la na keiki o ka ohana hapa a Manase ma ia aina; hoomahuahua ae la lakou mai Basana aku a Baala-heremona a Senira, a hiki aku i ka mauna Heremona.
\q1 
\v 24 Eia na luna o ka ohana o ko lakou mau makuakane, o Epera, o Isi, o Eliela, o Azeriela, o Ieremia, o Hodavia, a o Iadiela, na kanaka koa ikaika, na kanaka kaulana, he poeluna ohana o ko lakou mau makuakane.
\b
\q1 
\v 25 A ua lawehala lakou i ke Akua o ko lakou poe kupuna, a hele aku la e moe kolohe mamuli o na akua o na kanaka o ka aina, ka poe a ke Akua i luku ai imua o lakou.
\q1 
\v 26 A hoala ae la ke Akua o ka Iseraela i ka naau o Pula ke alii o Asuria, a me ka naau o Tilegatapilesera ke alii o Asuria, a lawe pio aku la oia ia lakou, i ka Reubena, i ka Gada, a me ka ohana hapa a Manase, a kai aku la ia lakou i Hala, i Habora, a i Hara, a i ka muliwai Gozana, a hiki i keia manawa.
\c 6
\b
\q1 
\v 1 EIA na keikikane a Levi; o Geresoma, o Kohata, a o Merari.
\q1 
\v 2 O na keikikane a Kohata; o Amerama, o Izehara, o Heberona, a o Uziela.
\q1 
\v 3 A o na keiki a Amerama; o Aarona, o Mose, a o Miriama. O na keikikane hoi a Aarona; o Nadaba, o Abihu, o Eleazara, a o Itamara.
\b
\q1 
\v 4 Na Eleazara o Pinehasa, na Pinehasa o Abisua,
\q1 
\v 5 Na Abisua o Buki, na Buki o Uzi,
\q1 
\v 6 Na Uzi o Zerahia, na Zerahia o Meraiota,
\q1 
\v 7 Na Meraiota o Amaria, na Amaria o Ahituha,
\q1 
\v 8 Na Ahituba o Zadoka, na Zadoka o Ahimaaza,
\q1 
\v 9 Na Ahimaaza o Azaria, na Azaria o Iohanana,
\q1 
\v 10 Na Iohanana o Azaria, (ka mea ia ia ka oihana kahuna ma ka luakini a Solomona i hana'i i Ierusalema;)
\q1 
\v 11 Na Azaria o Amaria, na Amaria o Ahituba,
\q1 
\v 12 Na Ahituba o Zadoka, na Zadoka o Saluma,
\q1 
\v 13 Na Saluma o Hilekia, na Hilekia o Azaria,
\q1 
\v 14 Na Azaria o Seraia, na Seraia o Iehozadaka.
\q1 
\v 15 A hele aku la o Iehozadaka, i ka wa a Iehova i lawe pio aku ai i ka Iuda, a me ko Ierusalema ma ka lima o Nebukaneza.
\b
\q1 
\v 16 Eia na keikikane a Levi; o Geresoma, o Kohata, a o Merari.
\q1 
\v 17 Eia na inoa o na keiki o Geresoma; o Libeni a o Simei.
\q1 
\v 18 A o na keikikane a Kohata, o Amerama, o Izihara, o Heberona, a o Uziela.
\q1 
\v 19 O na keikikane a Merari; o Meheli, a o Musi O lakou na ohana a ka poe Levi, mamuli o ko lakou mau kupuna.
\q1 
\v 20 Na Geresoma; o Libeni kana keiki, o Iahata kana keiki, o Zima kana keiki,
\q1 
\v 21 O Ioa kana keiki, o Ido kana keiki, o Zera kana keiki, o Ieaterai kana keiki.
\q1 
\v 22 O na keikikane a Kohata; o Aminadaba kana keiki, o Kora kana keiki, o Asira kana keiki,
\q1 
\v 23 O Elekana kana keiki, o Ebiasapa kana keiki, o Asira kana keiki,
\q1 
\v 24 O Tahata kana keiki, o Uriela kana keiki, o Uzia kana keiki, o Saula kana keiki.
\q1 
\v 25 A o na keikikane a Elekana, o Amasai, a o Ahimota;
\q1 
\v 26 O laua ka Elekana: o na keikikane a Elekana; o Zopai kana keiki, o Nahata kana keiki,
\q1 
\v 27 O Eliaba kana keiki, o Ierohama kana keiki, o Elekana kana keiki.
\q1 
\v 28 O na keikikane a Samuela; o Vaseni ka makahiapo, a o Abia.
\q1 
\v 29 O na keiki a Merari; o Maheli, o Libeni kana keiki, o Simei kana keiki, o Uza kana keiki,
\q1 
\v 30 O Simea kana keiki, o Hagia kana keiki, a o Asaia kana keiki.
\b
\q1 
\v 31 O lakou ka poe a Davida i hoonoho ai maluna o ka oihana hoolea ma ka hale o Iehova, mahope mai o ka manawa i kau malie ai ka pahuberita.
\q1 
\v 32 A hookauwa aku la lakou imua o kahi i ku ai ka halelewa anaina, me ka hoolea ana, a hiki i ka manawa a Solomona i hana'i ka hale o Iehova i Ierusalema: alaila ku iho la lakou i ka lakou oihana ma ko lakou mau papa.
\q1 
\v 33 Eia ka poe nana i ku me ka lakou poe keiki. O na keiki a ka Kohata; o Hemana he mea hoolea, ke keiki a Ioela, ke keiki a Samuela,
\q1 
\v 34 Ke keiki a Elekana, ke keiki a Iehorama, ke keiki a Eliela, ke keiki a Toa.
\q1 
\v 35 Ke keiki a Zupa, ke keiki a Elekana, ke keiki a Mahata, ke keiki a Amasai,
\q1 
\v 36 Ke keiki a Elekana, ke keiki a Ioela, ke keiki a Azaria, ke keiki a Zepania,
\q1 
\v 37 Ke keiki a Tahata, ke keiki a Asira, ke keiki a Ebiasapa, ke keiki a Kora,
\q1 
\v 38 Ke keiki a Izahara, ke keiki a Kohata, ke keiki a Levi, ke keiki a Iseraela.
\q1 
\v 39 A o kona hoahanau o Asapa, ka mea i ku ma kona lima akau, o Asapa ke keiki a Berakia, ke keiki a Simea,
\q1 
\v 40 Ke keiki a Mikaela, ke keiki a Baaseia, ke keiki a Malekia,
\q1 
\v 41 Ke keiki a Eteni, ke keiki a Zera, ke keiki a Adaia,
\q1 
\v 42 Ke keiki a Etana, ke keiki a Zima, ke keiki a Simei,
\q1 
\v 43 Ke keiki a Iahata, ke keiki a Geresoma, ke keiki a Levi.
\q1 
\v 44 A ma ka lima hema ko lakou poe hoahanau, na mamo a Merari. O Etana ke keiki a Kisi, ke keiki a Abedia, ke keiki a Maluka,
\q1 
\v 45 Ke keiki a Hasabia, ke keiki a Amazia, ke keiki a Hilekia,
\q1 
\v 46 Ke keiki a Amezi, ke keiki a Bani, ke keiki a Samera,
\q1 
\v 47 Ke keiki a Maheli, ke keiki a Musi, ke keiki a Merari, ke keiki a Levi.
\q1 
\v 48 Ua hoonohoia hoi ko lakou poe hoahanau o ka Levi i kela hana keia hana a pau o ka halelewa, ka hale o ke Akua.
\b
\q1 
\v 49 Aka, o Aarona a me kana mau keiki, mohai aku la lakou mala na o ke kuahu no ka mohaikuni, a maluna o ke kuahu no ka mea ala, a no ka hana a pau o ke keena kapu, a e mohai kalahala no ka Iseraela, e like me na mea a pau a Mose ke kauwa na ke Akua i kauoha ai.
\q1 
\v 50 Aia na keikikane a Aarona; o Eleazara kana keiki, o Pinehasa kana keiki, o Abisua kana keiki,
\q1 
\v 51 O Buki kana keiki, o Uzi kana keiki, o Zerahia kana keiki,
\q1 
\v 52 O Meraiota kana keiki, o Amaria kana keiki, o Ahituba kana keiki,
\q1 
\v 53 O Zadoka kana keiki, o Ahimaaza kana keiki
\b
\q1 
\v 54 Eia ko lakou mau wahi noho, ma ko lakou mau halelewa, iloko o ko lakou mau aina, ko na mamo a Aarona, ko na ohana a Kohata; no ka mea, no lakou ka haawina.
\q1 
\v 55 A haawi aku la lakou ia Heberona no lakou, ma ka aina o ka Iuda, a me na kula o ia wahi a puni.
\q1 
\v 56 Aka, o na aina mahiai o ke kulanakauhale, a me na kauhale ilaila, haawi aku la lakou ia mau mea no Kaleba ke keiki a Iepune.
\q1 
\v 57 A haawi aku la lakou i na kulanakauhale o ka Iuda no na mamo a Aarona, o Heberona ka puuhonua, o Libena me na kula ilaila, o Iatira, a o Esetemoa me ko lakou mau kula,
\q1 
\v 58 O Hilena me kona kula, o Debira a me kona kula,
\q1 
\v 59 O Asana a me kona kula, a o Betesemesa a me kona kula:
\q1 
\v 60 A ma ko ka ohana a Beniamina; o Geba me kona kula o Alemeta me kona kula, a o Anatota me kona kula. O na kulanakauhale a pau ma ko lakou mau ohana he umikumamakolu na kulanakauhale.
\b
\q1 
\v 61 No na mamo a Kohata i koe o ka ohana ma ia lahuikanaka, i kaa no lakou he umi mau kulanakauhale o ka ohana hapa, oia ka ohana hapa a Manase.
\q1 
\v 62 A no ka poe mamo a Geresoma, ma ka lakou mau ohana, he umikumamakolu na kulanakauhale o ka ohana a Isekara, a o ka ohana a Asera, a o ka ohana a Napetali, a o ka ohana a Manase i Basana.
\q1 
\v 63 A kaa aku no na mamo a Merari, ma ka lakou mau ohana, he umikumamalua na kulanakauhale o ka ohana a Reubena, a o ka ohana a Gada, a o ka ohana a Zebuluna.
\q1 
\v 64 Na ka poe mamo a Iseraela i haawi aku no ka Levi ia mau kulanakauhale a me ko lakou mau kula.
\q1 
\v 65 A haawi aku la lakou ma ka puu ana ia mau kulanakauhale i kapaia ma na inoa, noloko o ka ohana o na mamo a Iuda, a noloko o ka ohana o na mamo a Simeona, a noloko o ka ohana o na mamo a Beniamina.
\b
\q1 
\v 66 A i kekahi mau ohana o na mamo a Kohata, ia lakou na kulanakauhale o na mokuna o lakou ma ko ka ohana a Eperaima.
\q1 
\v 67 A haawi aku la lakou i na kulanakauhale puuhonua, o Sekema ma ka mauna Eperaima me kona kula, a o Gezera hoi me kona kula,
\q1 
\v 68 A o Iokemeama me kona kula, a o Betehorona me kona kula,
\q1 
\v 69 A o Aialona me kona kula, a o Gatarimona me kona kula:
\q1 
\v 70 A noloko o ka ohana hapa a Manase; o Anera me kona kula, a o Ibeleama me kona kula no ke koena o ka ohana mamo a Kohata.
\b
\q1 
\v 71 A no na mamo a Geresoma, o Golana i Basana me kona kula, a o Asetarota me kona kula, noloko o ko ka ohana hapa a Manase:
\q1 
\v 72 A noloko o ko ka ohana o Isekara; o Kedesa me kona kula, o Daberata me kona kula,
\q1 
\v 73 O Ramota me kona kula, a o Anema me kona kula:
\q1 
\v 74 A noloko o ko ka ohana a Asera; o Masala me kona kula, a o Abedona me kona kula,
\q1 
\v 75 O Hukoka me kona kula, a o Rehoba me kona kula.
\q1 
\v 76 A noloko o ko ka ohana a Napetali: o Kedesa i Galilaia me kona kula, a o Hamona me kona kula, a o Kiriataima me kona kula,
\b
\q1 
\v 77 A no ke koena o na mamo a Merari, noloko o ka ohana a Zebuluna, o Rimona me kona kula, a o Tabora me kona kula:
\q1 
\v 78 A ma kela kapa o Ioredane e kupono ana i Ieriko, ma ka aoao hikina o Ioredane, noloko o ko ka ohana a Reubena, o Bezera ma ka waoakua me kona kula, a o Iahaza me kona kula,
\q1 
\v 79 O Kedemota hoi me kona kula, a o Mepaata me kona kula:
\q1 
\v 80 Noloko hoi o ko ka ohana a Gada; o Ramota i Gileada me kona kula, a o Mahanaima me kona kula,
\q1 
\v 81 A o Hesebona me kona kula, a o Iazera me kona kula.
\c 7
\b
\q1 
\v 1 EIA na keikikane a Isakara; o Tola, o Pua, o Iasuba, a o Simerona, eha.
\q1 
\v 2 A o na keikikane a Tola; o Uzi, o Repaia, o Ieriela, o Iahemai, o libesama, a o Semuela, na luna o ka ohana a ko lakou makuakane, a Tola: he poe kanaka koa ma ko lakou hanauna; a ua heluia lakou i ka wa ia Davida, he iwakaluakumamalua tausani, a me na haneri keu eono.
\q1 
\v 3 A o ke keiki a Uzi; o Izerahia; a o na keiki a Izerahia; o Mikaela, o Obadia, o Ioela, o Isia, elima: he poe luna lakou a pau.
\q1 
\v 4 A me lakou pu, ma ko lakou mau hanauna, a mamuli o ka ohana a ko lakou mau makua, na poe koa no ke kaua, he kanakolukumamaono tausani: no ka mea, he nui na wahine a lakou, a me na keiki.
\q1 
\v 5 A o ko lakou poe hoahanau iwaena o na ohana a pau a Isekara, he poe kanaka koa ikaika lakou, a i heluia lakou a pau ma ko lakou mau hanauna, he kanawalukumamahiku tausani.
\b
\q1 
\v 6 Na Beniamina o Bela, o Bekera, a o Iediaela, ekolu.
\q1 
\v 7 O na keikikane a Bela; o Ezebona, o Uzi, o Uziela, o Ierimota, a o Iri, elima; na luna o ka ohana a ko lakou makuakane, he poe koa ikaika; ua heluia ma ko lakou mau hanauna, he iwakaluakumamalua tausani, a me ke kanakolukumamaha.
\q1 
\v 8 O na keikikane a Bekera; o Zemira, o Ioasa, o Eliezera, o Elioenai, o Omeri, o Ierimota, o Abia, o Anatota, a o Alameta. O lakou nei a pau na keikikane a Bekera.
\q1 
\v 9 A o ka helu ana o lakou mamuli o ko lakou kuauhau, ma ko lakou mau hanauna, na luna o ka ohana a ko lakou poe kupuna, he poe koa ikaika, he iwakalua tausani a me na haneri keu elua.
\q1 
\v 10 O ke keikikane hoi a Iediaela; o Bdehana; a o na keikikane a Bilehana; o Ieusa, o Beniamina, o Ehuda, o Kenaana, o Zetana, o Taresisa, a o Ahisahara.
\q1 
\v 11 O keia poe a pau na keiki a Iediaela; ma na poo o ko lakou mau kupuna, he poe kanaka koa ikaika, he umikumamabiku tausani a me na haneri keu elua, ua makaukau e hele aku i ke kaua e kaua aku.
\q1 
\v 12 O Supima hoi, a o Hupima, na keiki a Ira laua o Husima, na keiki a Ahera.
\b
\q1 
\v 13 O na keikikane a Napetali; o Iaziela, o Guni, o Iezera, o Saluma; na keiki a Bileha.
\b
\q1 
\v 14 O na keikikane a Manase; o Aseriela, oia ka kana wahine i hanau ai: (na kana haiawahine na ka Arama i hanau o Makira, o ka makuakane o Gileada:
\q1 
\v 15 Lawe ae la o Makira i ke kaikuwahine o Hupima a me Supima i wahine nana, a o Maaka ka inoa o ko laua kaikuwahine;) a Zelopehada ka inoa o ka lua; a he mau kaikamahine na Zelopehada.
\q1 
\v 16 Na Maaka na ka wahine a Makira i hanau he Keikikane, a kapa iho la ia i kona inoa o Peresa; a o Seresa ka inoa o kona kaikaina; a o Ulama laua o Rakema, na keikikane ana.
\q1 
\v 17 A o ke keikikane a Ulama, o Bedana. O lakou na keiki a Gileada, ke keiki a Makira, ke keiki a Manase.
\q1 
\v 18 Na kona kaikuwahine na Hamoleketa i hanau o Isoda, o Abiezera, a o Mahala.
\q1 
\v 19 O na keikikane a Semida, o Ahiana, o Sekema, o Likehi, a o Aniama.
\b
\q1 
\v 20 A o na keikikane a Eperaima; o Sutela, a o Bereda kana keiki, a o Tahata kana keiki, a o Elada kana. keiki, a o Tahata kana keiki,
\b
\q1 
\v 21 O Zabada kana keiki, o Sutela kana keiki, a o Ezera laua o Eleada, na mea a ka poe kanaka o Gata i hanau ma ia aina i pepehi ai, no ka mea, iho mai la lakou e lawe aku i ko lakou poe holoholona.
\q1 
\v 22 Kanikau iho la o Eperaima ko laua makuakane i na la he nui loa, a hele mai la kona poe hoahanau e hooluolu ia ia.
\b
\q1 
\v 23 Ia ia i komo aku ai iloko i kana wahine, hapai iho la oia, a hanau mai la he keikikane, kapa iho la kela ia ia o Beria, no ka poino i hiki mai i kana ohana.
\q1 
\v 24 (A o kana kaikamahine o Sera, nana i kukulu ia Betehorona lalo, a me luna, a me Uzenesera.)
\q1 
\v 25 A o Repa kana keiki, a o Resepa hoi, o Tela kana keiki, o Tahana kana keiki,
\q1 
\v 26 O Laadana kana keiki, o Amihuda kana keiki, o Elisama kana keiki,
\q1 
\v 27 O Nona kana keiki, o Iehosua kana keiki.
\b
\q1 
\v 28 A o ko lakou mau aina a me na noho ana, o Betela a me kolaila mau kulanahale; a ma ka hikina, o Naarana, a ma ke komohana o Gezera me na kulanahale olaila; o Sekema hoi, a me kolaila mau kulanahale, a hiki i Gaza me na kulanahale olaila:
\q1 
\v 29 A ma na palena o na mamo a Manase, o Beteseana a me kona mau kulanahale, o Taanaka a me kona mau kulanahale, o Megido a me kona mau kulanahale, o Dora a me kona mau kulanahale. Ma neia mau wahi i noho ai na mamo a Iosepa ke keiki a Iseraela.
\b
\q1 
\v 30 Eia na keikikane a Asera; o Imena, o Isua, o Isuai, o Beria; a o Sera ko lakou kaikawahine.
\q1 
\v 31 O na keikikane a Beria; o Hebera, a o Malekiela ka makuakane o Birezavita.
\q1 
\v 32 Na Hebera o Iapeleta, o Somera, o Hotama; a o Sua ko lakou kaikuwahine.
\q1 
\v 33 O na keikikane a Iapeleta; o Pasaka, o Bimehala, a o Asevata: o lakou nei na keiki a Iapeleta.
\q1 
\v 34 A o na keikikane a Samera; o Ahi a Rohega, o Iehuba, a o Arama.
\q1 
\v 35 A o na keikikane o kona hoahanau, o Helema; o Zopeha, o Imera, o Selesa, a o Amala.
\q1 
\v 36 O na keikikane a Zopa; o Sua, a o Harenepera, o Suala, o Beri, a o Imera,
\q1 
\v 37 O Bezera, o Hoda, o Sama, o Silisa o Iterana, a o Beera.
\q1 
\v 38 A o na keikikane a Ietera; o Iepune, o Pisepa, a o Ara.
\q1 
\v 39 A o na keikikane a Ula; o Ara, o Haniela, a o Rezia.
\q1 
\v 40 O lakou nei a pau na keiki a i Asera, na luna o ka ohana o ko lakou makuakane, na kanaka koa ikaika i waeia, he poe pookela o na luna. A o ko lakou helu ana ma ka hanauna o lakou, ka poe i makaukau no ke kaua, a no ka hooukakaua, he iwakaluakumamaono tausani kanaka.
\c 8
\b
\q1 
\v 1 NA Beniamina o Bela kana makahiapo, o Asebela ka lua, o Ahara ke kolu.
\q1 
\v 2 O Noha ka ha, a o Rapa ka lima.
\q1 
\v 3 O na keikikane a Bela; o Adara, o Gera a o Abihuda,
\q1 
\v 4 O Abisua, o Naamana, o Ahoa,
\q1 
\v 5 O Gera, o Sepupana, a o Hurama
\q1 
\v 6 Eia hoi na keikikane a Ehuda; eia na lunaohana o na kanaka o Geba; a ua laweia'ku lakou ma Manahata:
\q1 
\v 7 O Naamana, o Ahia, a o Gera; lawe aku la oia ia lakou, a nana mai o Uza, a o Ahihuda.
\q1 
\v 8 Na Saharaima na keiki ma ka aina o Moaba, mahope iho o kona hookuu ana aku ia lakou: o Husima laua o Baara na wahine ana.
\q1 
\v 9 Nana laua o Hodesa kana wahine, o Iobaba, o Zibia, o Mesa, o Malekama,
\q1 
\v 10 O Ieuza, o Sakia, a o Mirema. O lakou kana mau keikikane, he mau lunaohana.
\q1 
\v 11 Na laua o Husima, o Ahituba, a o Elepaala.
\q1 
\v 12 O na keikikane a Elepaala; o Ebera, o Misama, o Sameda, nana i kukulu ia Ono a me Loda, a me na kulanahale olaila.
\q1 
\v 13 O Beria hoi, a o Sema na lunaohana o na kanaka no Aiialona, o ka poe i hoopuehu aku i na kanaka o Gata:
\q1 
\v 14 A o Ahio, o Sasaka, a Ierimota,
\q1 
\v 15 O Zebadia, o Arada, o Adera,
\q1 
\v 16 0 Mikaela, o Isepa, a o Ioka, na keikikane a Beria;
\q1 
\v 17 A o Zebadia, o Mesulama, o Hezeki, o Hebera,
\q1 
\v 18 O Isemerai hoi, o lezelia, o Iobaba, na keikikane a Elepaala
\q1 
\v 19 O Iakima, o Zikeri, a o Zabedi,
\q1 
\v 20 O Elienai, o Ziletai, a o Eliela,
\q1 
\v 21 O Adaia, o Beraia, a o Simerata, na keikikane a Simehi:
\q1 
\v 22 O Isepana, o Hebera, a o Eliela,
\q1 
\v 23 O Abedona, o Zikeri, a o Hanana,
\q1 
\v 24 O Hanania, o Elama, o a Anetohiia,
\q1 
\v 25 O Ipedeia, o Penuela, na keikikane a Sasaka;
\q1 
\v 26 O Sameserai, o Seharia, a o Atalia.
\q1 
\v 27 O Iaresia, o Elia, a o Zekeri, na keikikane a Ierohama.
\q1 
\v 28 O lakou na lunaohana, ma ko lakou mau hanauna, na'lii. A noho lakou ma Ierusalema.
\b
\q1 
\v 29 A ma Gibeona i noho ai ka makuakane o Gibeona; a o Maaka ka inoa o kana wahine.
\q1 
\v 30 O Abedona kana makahiapo, a o Zura, o Kisa, o Baala, a o Nadaba,
\q1 
\v 31 A o Gedora, o Ahio, a o Zakera.
\q1 
\v 32 Na Mikelota o Simea. A noho hoi lakou me ko lakou poe hoahanau ma Ierusalema, kahi e ku pono ana ia lakou.
\b
\q1 
\v 33 Na Nera o Kisa, na Kisa o Saula, na Saula o Ionatana, o Malekisua, o Abinadaba, a o Esebaala.
\q1 
\v 34 A o Meribaala ke keikikane a Ionatana; a na Meribaala o Mika.
\q1 
\v 35 O na keikikane a Mika; o Pitona, o Meleka, o Tarea, a o Ahaza.
\q1 
\v 36 Na Ahaza o Iehoada, na Iehoada o Alemeta, o Azemaveta, a o Zimeri; na Zimeri o Moza;
\q1 
\v 37 Na Moza o Binea: o Rapa kana keiki, o Eleasa kana keiki, o Azela kana keiki.
\q1 
\v 38 Ia Azela na keikikane eono, eia na inoa o lakou, o Azerikama, Bokeru, o Isemaela, o Searia, o Obadia, a o Hanana. O lakou nei a pau na keikikane a Azela.
\q1 
\v 39 A o na keikikane a Eseka kona kaikaina, o Ulama kana makahiapo, o Iehusa ka lua, a o Elipeleta ke kolu.
\q1 
\v 40 He poe kanaka koa ikaika na keiki a Ulama, he poe pana i ke kakaka, a na lakou na keikikane he nui loa, a me na moopuna, hookahi haneri a me ke kanalima. O lakou nei a pau na mamo a Beniamina.
\c 9
\b
\q1 
\v 1 PELA o ka Iseraela a pau i heluia'i ma na hanauna: aia hoi, ua kakauia lakou iloko o ka buke a na alii o ka Iseraela a o ka Iuda, ka poe i laweia aku i Babulona no na lawehala o lakou.
\b
\q1 
\v 2 A o na kanaka mua i noho ma ko lakou mau wahi noho i na kulanakauhale o lakou, o lakou ka Iseraela, o na kahuna, a o na Levi, a me ka poe Netini.
\q1 
\v 3 A ma Ierusaiema i noho ai kekahi poe mamo a Iuda, a o kekahi poe mamo a Beniamina, a o kekahi poe mamo a Eperaima laua o Manase;
\q1 
\v 4 O Utai ke keiki a Amihuda, ke keiki a Omeri, ke keiki a Imeri, ke keiki a Bani, no na mamo a Pareza ke keiki a Iuda.
\q1 
\v 5 A no ka poe Siloni; o Asaia ka hanau mua, a me kana mau keikikane.
\q1 
\v 6 A no na mamo a Zera; o Ieuela, a o ko lakou poe hoahanau, eono haneri a me kanaiwa.
\q1 
\v 7 A no na mamo a Beniamina; o Salu ke keiki a Mesulama, ke keiki a Hodavia, ke keiki a Hasenua.
\q1 
\v 8 A o Ibeneia ke keiki a Ierohama, a o Ela ke keiki a Uzi, ke keiki a Mikeri, a o Mesulama ke keiki a Sepatia, ke keiki a Reuela, ke keiki a Ibeuiia.
\q1 
\v 9 A o ko lakou poe hoahanau, ma ko lakou mau hanauna, he eiwa haneri a me ke kanalimakumamaono. He poe lunaohana lakou nei a pau, ma ka ohana o ko lakou mau makuakane.
\b
\q1 
\v 10 A no na kahuna; o Iedaia, o Iehoiariba, a o Iakina.
\q1 
\v 11 A o Azaria keiki a Hilekia, ke keiki a Mesulama, ke keiki a Zadoka, ke keiki a Meraiota, ke keiki a Ahituba, a ka luna no ka hale o ke Akua;
\q1 
\v 12 A o Adaia ke keiki a Ierohama, ke keiki a Pasura, ke keiki a Malekiia; a o Masia ke keiki a Adiela, ke keiki a Iahezera, ke keiki a Mesulama, ke keiki a Mesilemita, ke keiki a Imera;
\q1 
\v 13 A o ke lakou poe hoahanau, na lunaohana o ko lakou mau makua, hookahi tausani me na haneri ehiku a me ke kanaono: he poe kanaka ikaika loa e hana i ka hana o ka hale o ke Akua.
\b
\q1 
\v 14 A no ka Levi: o Semaia ke keiki a Hasuba, ke keiki a Azerikama, ke keiki a Hasabia, no na mamo a Merari;
\q1 
\v 15 A o Bakebaka, o Heresa, o Galala, o Matania ke keiki a Mika, ke keiki a Zikeri, ke keiki a Asapa;
\q1 
\v 16 A o Obadia ke keiki a Semaia, ke keiki a Galala, ke keiki a Iedu. tuna; a o Berekia ke keiki a Asa, ke keiki a Elekana, ka mea i noho ma na kulanahale o ka Netopata.
\b
\q1 
\v 17 A o ka poe kiaipuka, o Saluma, o Akuba, o Talemona, o Ahimana, a me ko lakou poe hoahanau: a o Saluma ka luna:
\q1 
\v 18 Mamua, noho lakou ma ka ipuka o ke alii, ma ka aoao hikina; he poe kiaipuka lakou iwaena o na poe mamo a Levi.
\q1 
\v 19 A o Saluma ke keiki a Kore, ke keiki a Ebiasapa, ke keiki a Kora, a o kona poe hoahanau, no ka ohana o kona makuakane, ko Kora, maluna lakou o ka oihana hoomana, na kiaipuka hoi o ka halelewa: a o ko lakou poe makuakane maluna o ke anainakanaka o Iehova, he poe malama lakou i kahi komo.
\q1 
\v 20 A o Pinehasa ke keiki a Eleazara ka luna o lakou, i ka manawa mamua, a me ia pu no o Iehova.
\q1 
\v 21 A o Zekaria ke keiki a Meselemia ke kiaipuka ma ka puka o ka halelewa anaina.
\q1 
\v 22 O keia poe a pau i waeia he poe kiaipuka, elua haneri a me ka umikumamalua. Ua heluia lakou ma ko lakou hanauna, iloko o ko lakou mau kulanahale; o ka poe a Davida laua o Samuela ke kaula i hoonoho ai ma ka lakou oihana.
\q1 
\v 23 Pela no ia lakou a me na keiki a lakou ke kiai ana o na ipuka o ka hale o Iehova, o ka halelewa, ma na papa.
\q1 
\v 24 Ma na aoao eha i noho ai na kiaipuka, ma ka hikina, ma ke komohana, ma ke kukuluakau, a ma ke kukuluhema.
\q1 
\v 25 A hala ae la na la ehiku, hele mai la na hoahanau o lakou, mai na kulanahale o lakou mai, i kela manawa i keia manawa me lakou.
\q1 
\v 26 No ka mea, o keia poe Levi, o na luna kiaipuka eha, i noho ma ka lakou oihana, a maluna o na hale ahuwaiwai a me na waihonakala o ka hale o ke Akua.
\b
\q1 
\v 27 A moe iho la lakou a puni i ka hale o ke Akua, no ka mea, maluna o lakou ke kiai ana, a ia lakou hoi ka wehe ana o ka hale ia kakahiaka ae ia kakahiaka ae.
\b
\q1 
\v 28 A i kekahi poe o lakou ka malama ana i na ipu mea lawelawe, i lawe mai ai lakou ia mau mea iloko, a e lawe aku hoi lakou ia mau mea iwaho, ma ka helu ana.
\q1 
\v 29 Ua hoonohoia hoi kekahi poe o lakou e kiai i na ipu, a me na mea paahana a pau o ka luakini, i ka paiaoa, i ka waina, me ka aila, me ka libano, a me ka mea ala.
\q1 
\v 30 A na kekahi poe keiki a na kahuna i hana i ka mea poni ala.
\q1 
\v 31 A o Matitia o ka Levi, o ka hiapo a Saluma ka Kora, ia ia ke kauoha maluna o na mea i hanaia maloko o na pa.
\q1 
\v 32 A o kekahi poe hoahanau o lakou, o na keiki a ka Kohata, maluna lakou o ka berena hoike, e hoomakaukau ia mea no kela Sabati keia Sabati.
\b
\q1 
\v 33 O keia ka poe mele, na pookela o na makua o na Levi, i noho hana ole ma na keena: no ka mea, ua mau lakou ma ia hana i ka po a me ke ao.
\q1 
\v 34 O keia poe lunaohana o na Levi, he poe pookela ma ko lakou mau hanauna; a noho iho lakou ma Ierusalema.
\b
\q1 
\v 35 A ma Gibeona i noho ai ka makuakane o Gibeona, o Iehiela, O Maaka ka inoa o kana wahine.
\q1 
\v 36 O Abedona kana keiki hiapo, alaila o Zura, o Kisa, o Baala, o Nera, o Nadaba.
\q1 
\v 37 O Gedora, o Ahio, o Zekaria a o Mikelota.
\q1 
\v 38 Na Mikelota, o Simeama; a noho iho la hoi lakou i Ierusalema me ko lakou poe hoahanau, i kahi ku pono aku i ko lakou poe hoahanau.
\q1 
\v 39 Na Nera o Kisa, na Kisa o Saula, na Saula o Ionatana, o Malikisua, o Abinadaba, a o Esebaala.
\q1 
\v 40 A o Meribaala ke keikikane a Ionatana: na Meribaala o Mika.
\q1 
\v 41 O na keikikane a Mika, o Pitono, o Meleka, o Taherea, [a o Ahaza.]
\q1 
\v 42 Na Abaza o Iara, na Iara o Alemeta, o Azemaveta, o Zimeri; a na Zimeri o Moza.
\q1 
\v 43 Na Moza o Binea; a o Repaia kana keiki, o Eleasa kana keiki, a o Azela kana keiki.
\q1 
\v 44 Na Azela na keikikane eono; eia ko lakou mau inoa, o Azerikama, o Bokeru, o Isemaela, o Searia, o Obadia, a o Hanana: o lakou na keikikane a Azela.
\c 10
\b
\q1 
\v 1 A KAUA mai la ko Pilisetia i ka Iseraela; auhee ae la na kanaka o ka Iseraela imua o ko Pilisetia, a haule iho la lakou me ka pepehiia ma ka mauna o Gileboa.
\q1 
\v 2 A hahai ikaika mai la ko Pilisetia mahope o Saula, a mahope o kana mau keiki; a pepehi iho la ko Pilisetia ia Ionatana, a ia Abitiadaba, a ia Malekisua, na keiki a Saula.
\q1 
\v 3 A ikaika mai la ke kaua ana ia Saula, a loaa oia i na kanaka pana pua, a ua ku oia i ka poe pana pua.
\q1 
\v 4 Alaila, i aku la o Saula i ke kanaka hali i kana mea kaua, E unuhi oe i kau pahikaua, a e hou mai ia'u me ia, o hele mai keia poe okipoepoe ole, a e hoomaewaewa mai ia'u. Aka, aole i makemake ka mea hali i kana mea kaua; no ka mea, ua makau loa ia. Nolaila, lalau aku la o Saula i ka pahikaua, a haule iho la iluna.
\q1 
\v 5 A ike iho la ka mea hali i kana mea kaua, ua make o Saula, haule iho la hoi oia maluna o ka pahikaua, a make iho la.
\q1 
\v 6 Pela i make ai o Saula, me kana mau keikikane ekolu, a o kona poe ohua ua pau pu i ka make.
\b
\q1 
\v 7 A ike ae la na kanaka a pau o ka Iseraela, ma ke awawa, hee aku la lakou; a ua make hoi o Saula a me kana mau keikikane, alaila haalele lakou i ko lakou mau kulanakauhale, a holo aku la; a hele mai la ko Pilisetia a noho iho la malaila.
\b
\q1 
\v 8 A ia la ae, a hele mai la ko Pilisetia e hao i ka poe make, loaa iho la ia lakou o Saula a me kana mau keiki i haule ma ka mauna o Gileboa.
\q1 
\v 9 A pau ko lakou hao ana ia ia, lawe ae la lakou i kona poo, a me kana mau mea kaua, hoouna aku la lakou ma ka aina o ko Pilisetia a puni, e hai aku i ko lakou mau kii, a i na kanaka.
\q1 
\v 10 A waiho iho la lakou i kana mau mea kaua iloko o ka hale o ko lakou mau akua, a hoopaa aku la i kona poo ma ka heiau o Dagona.
\b
\q1 
\v 11 A lohe ae la ko Iabesa gileada a pau i na mea a pau a ko Pilisetia i hana'i ia Saula,
\q1 
\v 12 Ku ae la lakou, o ka poe kanaka koa a pau, a lawe aku la i ke kino o Saula, a me na kino o na keiki ana, a hali mai la i Iabesa, a kanu iho la i ko lakou mau iwi malalo o ka laau oka, aia ma labesa, a hookeai lakou i na la ehiku.
\b
\q1 
\v 13 Pela o Saula i make ai no kona hala, i ka mea ana i hoohala ai ia Iehova, i ku e i ka olelo a Iehova ana i malama ole ai, a no ka imi ana i uhane ino, e ninau aku;
\q1 
\v 14 A ninau ole aku oia ia Iehova; nolaila, pepehi iho la oia ia ia, a hoohuli ae la i ke aupuni no Davida ke keiki a Iese.
\c 11
\b
\q1 
\v 1 A LAILA akoakoa ae la ka Iseraela a pau io Davida la i Heberona, i mai la, Eia hoi, hookahi no ko kakou iwi a me ka io.
\q1 
\v 2 I ka wa mamua no hoi, ia Saula i alii ai, o oe no ka mea nana i alakai aku a i alakai mai i ka Iseraela: i mai la hoi o Iehova o kou Akua ia oe, E hanai oe i ko'u poe kanaka i ka Iseraela; a e lilo oe i alii no ko'u poe kanaka no ka Iseraela.
\q1 
\v 3 Nolaila, i hele mai na lunakahiko a pau o ka Iseraela i ke alii ma Heberona; a hoopaa iho la o Davida i berita me lakou ma Heberona, imua o Iehova: a poni iho la lakou ia Davida i alii no ka Iseraela, e like me ka olelo a Iehova ma o Samuela la.
\b
\q1 
\v 4 Hele aku la o Davida me ka Iseraela a pau i Ierusalema, oia o Iebusa. kahi i noho ai ka Iebusa, na kanaka o ia aina.
\q1 
\v 5 Olelo mai la na kanaka o Iebusa ia Davida, Aole oe e hele mai ia nei. Aka, lawe lilo o Davida i ka pakaua o Ziona, oia ke kulanakauhale o Davida.
\q1 
\v 6 I mai la o Davida, O ka mea pepehi mua i ka Iebusi, e lilo ia i pookela a i lunakoa. A o Ioaba, o ke keiki a Zeruia i pii mua aku la, a lilo ae la ia i pookela.
\q1 
\v 7 A noho iho la o Davida ma ka pakaua; nolaila, kapa aku la lakou ia wahi, O ke kulanakauhale o Davida.
\q1 
\v 8 Kukulu iho la ia i ke kulanakauhale a puni, mai Milo aku a puni: a kukulu hou iho la o Ioaba i na wahi i koe o ke kulanakauhale.
\q1 
\v 9 Mahuahua ae la o Davida a nui loa: no ka mea, me ia pu o Iehova sabaota.
\b
\q1 
\v 10 Eia hoi na pookela o na kanaka ikaika ia Davida, ka poe i hooikaika pu me ia iloko o kona aupuni a me ka Iseraela a pau, e hooalii ia ia, e like me ka olelo a Iehova no ka Iseraela.
\q1 
\v 11 Eia ka helu ana o na kanaka ikaika ia Davida: o Iasobeama ka Hakemoni, ke pookela o na lunakoa: hoaka ae la ia i kana ihe e ku e i na haneri kanaka ekolu, a make lakou i ka manawa hookahi.
\q1 
\v 12 Mahope iho ona o Eleazara ke keiki a Dodo ka Ahohi, kekahi o na kanaka ikaika loa ekolu.
\q1 
\v 13 Aia no ia me Davida ma Padamima, ilaila i akoakoa ai ko Pilisetia i ke kaua, i kahi i paa pu ai ka honua i ka bale: a naholo aku la na kanaka imua o ko pilisetia.
\q1 
\v 14 A ku iho la lakou iwaena konu o ua aina la, a hoomalu iho la ia wahi, a pepehi iho la i ko Pilisetia; a hoola ae la o Iehova ia lakou i ke ola nui.
\b
\q1 
\v 15 Iho aku la na mea ekolu o ka poe luna he kanakolu i kahi paa io Davida la iloko o ke ana o Adulama: a hoomoana iho la ka poe kauwa o Pilisetia ma ke awawa i Repaima.
\q1 
\v 16 Haila o Davida iloko o kahi paa, a ma Betolehema ka pakaua o ko Pilisetia ia manawa.
\q1 
\v 17 Makewai iho la o Davida, i mai la, Nani ino kuu makemake e haawi mai kekahi i wai e inu no ka luawai mai o Betelehema, aia ma ka ipuka!
\q1 
\v 18 Wahi ae la aa mau kanaka ekolu la i ka poe kaua o ko Pilisetia, a huki mai la i ka wai, mailoko o ka luawai o Betelehema ma ka ipuka, lalau aku la, a lawe mai la io Davida la: aka, aole o Davida i manao e inu ia mea, a ninini aku no ia mea no Iehova.
\q1 
\v 19 I aku la ia, E papa mai ko'u Akua ia'u. i ole au e hana ia mea: e inu no auei au i ke koko o keia mau kanaka, me ko lakou ola? no ka mea, me ke ola wale no lakou i lawe mai nei ia mea: nolaila, aole ia i make inu. Pela i hana'i ia mau kanaka ikaika loa ekolu.
\b
\q1 
\v 20 A o Abisai ke kaikaina o Ioaba, oia ke pookela o na mea ekolu: no ka mea, hoaka ae la ia i kona ihe e ku e i na kanaka ekolu haneri, a pepehi iho la ia ia lakou, a loaa ia ia ka inoa iwaena o ua mau kanaka ikaika la ekolu.
\q1 
\v 21 No na mea ekolu, ua oi aku kona koikoi imua o na mea elua, nolaila, oia ko laua luna: aka, aole i hiki aku kona e like me ko kela poe ekolu.
\b
\q1 
\v 22 O Benaia ke keiki a Iehoiada, ke keiki a kekahi kanaka ikaika no Kabezeela, he nui kana hana kupanaha: pepehi iho la ia i elua kanaka ikaika loa o Moaba: iho iho la hoi ia iloko o ka lua, a pepehi iho la i ka liona i ka la e haule ana ka hau.
\q1 
\v 23 Pepehi iho la hoi oia i kekahi kanaka Aigupita, he kanaka nunui, he elima hailima ke kiekie: a he ihe no ma ka lima o ka Aigupita, e like me ka laau o ka mea ulana lole: a iho aku la kela io na la me ke kookoo, a kaili ae la i ka ihe mailoko ae o ka lima o ka Aigupita, a pepehi iho la ia ia me kana ihe.
\q1 
\v 24 O na mea keia a Benaia a ke keiki a Iehoiada i hana'i, a loaa ia ia ka inoa iwaena o ka poe kanaka ikaika ekolu.
\q1 
\v 25 Aia hoi, he koikoi no ia iwaena o ke kanakolu, aole hoi i hiki aku kona i ko kela poe ekolu. A hoonoho aku la o Davida ia ia i kuhina nona.
\b
\q1 
\v 26 Eia hoi na kanaka koa o na kaua: o Asahela ke kaikaina o loaba, o Elehanana ke keiki a Dodo no Betelehema,
\q1 
\v 27 O Samota no Harora, o Heleza no Pelona.
\q1 
\v 28 O Ira ke keiki a Ikesa no Tekoa, o Abiezera no Anetota,
\q1 
\v 29 O Sibekai no Husata, o Hai no Ahota.
\q1 
\v 30 O Maharai no Netopa, o Heleda ke keiki a Baana no Netopa,
\q1 
\v 31 O Itai ke keiki a Ribai no Gibea, no na mamo a Beniamina, o Benaia no Piratona,
\q1 
\v 32 O Hurai no na awawa o Gaasa, o Abiela, no Arabata,
\q1 
\v 33 O Azemaveta no Baharuma, o Eliaba no Saalebo,
\q1 
\v 34 O na keiki a Hasema no Gilo, o Ionatana ke keiki a Sage no Harara.
\q1 
\v 35 O Ahiama ke keiki a Sakara no Harara, o Elipala ke keiki a Ura,
\q1 
\v 36 O Hepera no Mekerata, o Ahiia no Pelona,
\q1 
\v 37 O Hezero no Karemela, o Naarai ke keiki a Ezebai,
\q1 
\v 38 O Ioela ka hoahanau o Natana, o Mibehara ke keiki a Hageri,
\q1 
\v 39 O Zeleka ka Amona, o Naharai no Berota, ka mea lawe i na mea kaua a Ioaba ke keiki a Zeruia,
\q1 
\v 40 O Ira no Itera, o Gareba no Itera,
\q1 
\v 41 O Auria ka Heta, o Zabada ke keiki a Ahelai,
\q1 
\v 42 O Adina ke keiki a Siza a ka Reubena, he luna ia o ka Reubena, a he kanakolu no me ia,
\q1 
\v 43 O Hanana ke keiki a Maaka, o Iosapata no Mitana,
\q1 
\v 44 O Uzia no Aseterata, o Sama, a o Iehiela, na keiki a Hotana no Aroera,
\q1 
\v 45 O Idiaela ke keiki a Simeri, a o Ioha kona kaikaina, no Tiza,
\q1 
\v 46 O Eliela no Mahava, o Ieribai, a o Iosavia, na keiki a Elenaama, o Itema ka Moaba,
\q1 
\v 47 O Eliela, o Obeda, a o Iasiela ka Mesoba.
\c 12
\b
\q1 
\v 1 A IA hoi ka poe i hele mai io Davida la ma Zikelaga, i kona manawa i noho paa ai no Saula ke keiki a Kisa; iwaena lakou o na kanaka ikaika, ka poe i kokua i ke kaua.
\q1 
\v 2 Ua makaukau lakou i na kakaka, a ua hiki no ia lakou ke nou aku i na pohaku, a me ka pana pua mailoko aku o ke kakaka, me ka lima akau a me ka lima hema, no ka hanauna lakou o Saula, no ka Beniamina.
\q1 
\v 3 O Ahiezera ka luna, alaila o Ioasa, na keiki laua a Hasemaa no Gibea: o Ieziela hoi, a o Peleta, nakeiki a Azemavota; o Beraka hoi, a o Iehu no Anetota.
\q1 
\v 4 A o Isemaia no Gibeona, he kanaka ikaika iwaena o ke kanakolu; a o Ieremia, o Iahaziela, o Iohanana, a o Iosabada, no Gederata,
\q1 
\v 5 O Eluzai, o Ierimota, o Bealia o Semaria, a o Sepatia no Harupa,
\q1 
\v 6 O Elekana, o Iesia, o Azareela, o Ioezera, o Iasobeama, no ka Kora;
\q1 
\v 7 O loela, o Zebadia, na keiki a Ierohama no Gedora.
\b
\q1 
\v 8 A hookaawale mai la kekahi poe Gada ia lakou iho no Davida ma kahi paa ma ka waonahele, he poe kanaka ikaika, kanaka kaua e kaua ai; e hiki ia lakou ke lawe i palekaua a me ka ihe, a o na helehelena o lakou, me he helehelena liona la, a ua like lakou me ka dia o na mauna ka mama:
\q1 
\v 9 O Ezera ka mua, o Obadia ka lua, o Eliaba ke kolu,
\q1 
\v 10 O Misemana ka ha, o Ieremia ka lima,
\q1 
\v 11 O Atai ke ono, o Eliela ka hiku,
\q1 
\v 12 O Iohanana ka walu, o Elezabada ka iwa,
\q1 
\v 13 O Ieremia ka umi, a o Makebanai ka umikumamakahi.
\q1 
\v 14 O lakou he poe mamo a Gada, na luna o ka poe kaua: o kekahi mea uuku iho, maluna ia o ka haneri; a o ka mea nui loa, maluna ia o ka tausani.
\q1 
\v 15 O lakou ka poe i hele ma kela kapa o Ioredane i ka malama mua, i ka manawa i hoopiha ai ia maluna o kona mau kapa a pan: a hoopuehu aku la lakou i na mea a pau o na awawa ma ka hikina a ma ke komohana.
\b
\q1 
\v 16 A hele mai la kekahi poe mamo a Beniamina a me Iuda i kahi paa io Davida la.
\q1 
\v 17 Hele aku la o Davida iwaho e halawai me lakou; olelo aku la ia, i aku la ia lakou, Ina e hele aloha mai no oukou io'u nei e kokua mai ia'u, e hookahi ana ko'u naau me ko oukou: aka, ina no ka haawi aku ia'u i ko'u poe enemi, na ke Akua o ko kakou poe kupuna e nana mai, a e papa mai; no ka mea, aole i loaa ka hewa ma ko'u mau lima.
\q1 
\v 18 Alaila kau mai la ka Uhane maluna iho o Amasai, ke pookela o na lunakoa, Nou no makou, e Davida, a ma kou aoao hoi, e ke keiki a Iese, aloha, aloha ia oe, aloha hoi i na kokua mahope ou; no ka mea, o kou Akua ke kokua mai ia oe. Alaila, hookipa ae la o Davida ia lakou, a hoonoho ia lakou i mau luna o na koa.
\b
\q1 
\v 19 A kaana mai la kekahi poe o Manase ia Davida, ia ia i hele pu ai me ko Pilisetia i ke kaua ia Saula: aka, aole i kokua aku lakou nei mamuli o lakou, no ka mea, na na 'lii o ko Pilisetia i kukakuka pu, a hoihoi aku ia ia, me ka i ana, E kaa aku auanei ia i kona haku ia Saula, maluna o ko kakou mau poo.
\q1 
\v 20 I kona hele ana i Zikelaga, kaana mai la kekahi poe o ka Manase ia ia, o Adena, o Iozabada, o Iediaela, o Mikaela, o Iozabada, o Elihu, a o Ziletai, na luna tausani o ka Manase.
\q1 
\v 21 A kokua mai la lakou mamuli o Davida me kekahi poe koa; no ka mea, he poe kanaka koa ikaika lakou a pau, a he mau luna iwaena o ka poe koa.
\q1 
\v 22 Ia manawa no, ia la ae, ia la ae, haele mai la [na kanaka] io Davida la, a lilo ae la lakou i poe koa nui, e like me ka puali o ke Akua.
\b
\q1 
\v 23 Eia ka helu ana i na poe i makaukau no ke kaua, i hele mai io Davida la ma Heberona, e hoohuli ae i ke aupuni o Saula io na la, e like me ka olelo ana a Iehova,
\q1 
\v 24 O na mamo a Iuda i lawe i ka palekaua a me ka ihe, he eono tausani lakou a me na haneri keu ewalu, i makaukau no ke kaua.
\q1 
\v 25 O na mamo a Simeona, na kanaka koa ikaika no ke kaua, ehiku tausani lakou, a me ka haneri keu.
\q1 
\v 26 O na mamo a Levi, eha tausani a me na haneri keu eono.
\q1 
\v 27 O Iehoiada ke alakai o ka poe mamo a Aarona, a me ia pu na tausani ekolu a me na haneri keu ehiku.
\q1 
\v 28 A o Zadoka, he kanaka hou, he koa ikaika, a he iwakaluakumamalua na luna koa o ka ohana a kona makuakane.
\q1 
\v 29 A o na mamo a Beniamina, na hoahanau o Saula, ekolu tausani; no ka mea, mamua he poe kiai ka nui o lakou i ka hale o Saula.
\q1 
\v 30 A o na mamo a Eperaima, he iwakalua tausani a me na haneri keu ewalu, na kanaka koa ikaika, ua kaulana mawaena o ka ohana o ko lakou mau kupuna.
\q1 
\v 31 A o ka ohana hapa a Manase, he umikumamawalu tausani, i kaheaia ma ka inoa e hele mai e hooalii ia Davida.
\q1 
\v 32 A o na mamo a Isakara, ka poe hoomaopopo i na ouli o na manawa, e ike ai i na mea pono a ka Iseraela e hana'i: elua haneri na pookela o lakou; a nana ae la ko lakou poe hoahanau a pau i ka lakou olelo.
\q1 
\v 33 O ka Zebuluna, ka poe hele aku i ke kaua, i makaukau i ke kaua me na mea kaua a pan, he kanalima tausani o lakou i ike i ka hoouka kaua, aole he naau lua.
\q1 
\v 34 A o ka Napetali, hookahi tausani luna koa, a me lakou he kanakolukumamahiku tausani, me na palekaua a me na ihe.
\q1 
\v 35 A o ka Dana i makaukau i ke kaua, he iawakaluakumamawalu tausani, a me na haneri keu eono.
\q1 
\v 36 A o ka Asera, ka poe hele aku i ke kaua, i makaukau i ke kaua, he kanaha tausani.
\q1 
\v 37 A ma kela aoao o Ioredane, o ka Reubena, a o ka Gada, a o ka ohana hapa a Manase, me na mea kaua a pau e kaua ai, he haneri a me ka iwakalua tausani.
\b
\q1 
\v 38 O keia poe kanaka kaua a pau, i ike i ka hoouka i ke kaua, i hele mai me ka naau lokahi ma Heberona, e hoalii ia Davida maluna o ka Iseraela a pau: a ua lokahi hoi ka naau o ka Iseraela a pau i koe e hoalii ia Davida.
\q1 
\v 39 Ilaila lakou me Davida, ekolu la, e ai ana a e inu ana: no ka mea, ua hoomakaukau ko lakou poe hoahanau na lakou.
\q1 
\v 40 Oia hoi, o ka poe o kokoke ana me lakou, a hiki aku i ka Isakara, a i ka Zebuluna, a i ka Napetali, lawe mai la lakou i ka berena maluna o na miula, a o na kamelo, a o na hoki, a o na bipi; me ka ai a me ka palaoa, me na pai huafiku, a me na pai huawaina, me ka waina, ka aila, na bipi a me na hipa he nui loa: no ka mea, he olioli iloko o ka Iseraela.
\c 13
\b
\q1 
\v 1 KUKA ae la o Davida me na luna tausani a me na luna haneri, a me na luna a pau.
\q1 
\v 2 Olelo mai o Davida i ke anaina kanaka a pau o ka Iseraela, Ina he maikai keia ia oukou, a ina na Iehova mai o ko kakou Akua ia mea, e hoouna aku kakou a i na hoahanau o kakou ma na wahi a pau, e waiho ana ma na aina a pau o ka Iseraela, a me lakou pu i na kahuna a me ka Levi iloko o ko lakou mau kulanakauhale a me na kula, e akoakoa mai ai lakou io kakou nei:
\q1 
\v 3 A e lawe mai kakou i ka pahu o ko kakou Akua io kakou nei: no ka mea, aole kakou i ninau aku ma ia mea i na la o Saula.
\q1 
\v 4 Olelo aku la ke anaina kanaka a pau, e hana lakou pela: no ka mea, he maikai ia mea imua o na kanaka a pau.
\q1 
\v 5 Pela i houluulu ai o Davida i ka Iseraela a pau i kahi hookahi, mai Sihora o Aigupita a hiki aku i ke komo ana aku i Hemata, e lawe i ka pahu o ko Akua mai Kiriataiearima mai.
\q1 
\v 6 Pii aku la o Davida, a me ka Iseraela a pau a Baala, oia o Kiriataiearima, no ka Iuda, mailaila mai e lawe i ka pahu o ke Akua o Iehova, e noho ana mawaena o na keruba, kahi i heaia'i kona inoa.
\q1 
\v 7 Hooholo ae la lakou i ka pahu o ke Akua maluna o ko kaa hou, mai ka hale mai o Abinadaba; a kai aku la o Uza laua o Ahio i ke kaa.
\q1 
\v 8 Hookani aku la o Davida a me ka Iseraela a pau imua o ke Akua me ka ikaika a pau, i na mele, me na lira, na pesaleteria, na timeberela, na kimebala, a me na pukani.
\b
\q1 
\v 9 A hiki aku lakou i kahi hehi-palaoa no Kidona, hoo aku la o Uza i kona lima a hoopaa i ka pahu: no ka mea, okupe iho la na bipikauo.
\q1 
\v 10 Ua hoaia ka inaina o Iehova ia Uza, a hahau mai la oia ia ia, no ka mea, ua lalau kona lima i ka pahu; a make iho la ia ilaila imua o ko Akua.
\q1 
\v 11 Ukiuki iho la o Davida i ko Iehova hahau ana ia Uza; nolaila ua kapaia ka inoa o ia wahi o Perezuza a hiki i keia la.
\q1 
\v 12 Makau iho la o Davida i ke Akua ia la, i iho la, Pehea la ka'u e lawe mai ai i ka pahu o ke Akua io'u nei?
\q1 
\v 13 Nolaila, aole i lawe mai o Davida i ka pahu berita io na la i ke kulanakauhale o Davida: aka, lawe ae la oia ia mea maloko o ka hale o Obededoma ka Gata.
\q1 
\v 14 A waiho iho la ka pahu o ke Akua me ka ohana a Obededoma iloko o kona hale i na malama ekolu. A hoopomaikai o Iehova i ko ka hale o Obededoma, a me kona mau mea a pau.
\c 14
\b
\q1 
\v 1 NO Hirama ke alii o Turo, hoouna mai la ia i na elele io Davida la, me na laau kedera, me na kalaipohaku a me na kamana, e hana lakou i hale nona.
\q1 
\v 2 A ike iho la o Davida, na Iehova ia i hoopaa i alii maluna o ka Iseraela, no ka mea, ua hookiekieia kona aupuni iluna, no kona poe kanaka, o ka Iseraela.
\b
\q1 
\v 3 Lawe ae la O Davida i na wahine hou ma Ierusalema: a na Davida mai na keikikane a me na kaikamahine hou.
\q1 
\v 4 Eia na inoa o na keiki i loaa ia ia ma Ierusalema; o Samua, o Sobaba, o Natana, a o Solomona,
\q1 
\v 5 O Ibehara, o Elisua, o Elipeleta,
\q1 
\v 6 O Noga, o Nepega, o Iapia,
\q1 
\v 7 O Elisama, o Beeliada, a o Elipeleta.
\b
\q1 
\v 8 A lohe ae la na Pilisetia, ua poniia o Davida i alii maluna o ka Iseraela a pau, pii mai la na Pilisetia a pau e imi ia Davida. A lohe aku la o Davida, a hele aku la ia a ku e ia lakou.
\q1 
\v 9 Hele mai la na Pilisetia, a hoomoana iho la ma ke awawa o Repaima.
\q1 
\v 10 Ninau aku la o Davida i ke Akua, i aku la, E pii aku anei au e ku e i na Pilisetia? E hoolilo anei hoi oe ia lakou i kuu lima? I mai la hoi o Iehova ia ia, E pii aku oe, no ka mea, e hoolilo aku no wau ia lakou i kou lima.
\q1 
\v 11 Hele mai la lakou i Baala-perazima, a luku aku la o Davida ia lakou malaila. Alaila, i aku la o Davida, Ua poha aku la o Iehova maluna o ko'u poe enemi, e like me ka poha ana o ka wai. Nolaila, kapa aku la lakou i ka inoa o ia wahi, o Baala-perazima.
\q1 
\v 12 A haalele mai lakou i na kii akua o lakou ilaila, kauoha aku la o Davida, a ua puhiia lakou i ke ahi.
\b
\q1 
\v 13 A hoomoana hou aku la na Pilisetia ma ke awawa.
\q1 
\v 14 Nolaila, ninau hou aku la o Davida i ke Akua; a olelo mai la ke Akua ia ia, Mai pii aku oe mahope o lakou: e huli ae mai o lakou aku, a e hoi mai maluna o lakou la ma kahi e ku pono ana i na laau silika.
\q1 
\v 15 Ala lohe oe i ka halulu o ka hele ana ma na welau o na laau silika, alaila e hele aku oe e hoouka i ke kaua: no ka mea, ua hala aku ke Akua imua ou e pepehi i ka poe kaua o na Pilisetia.
\q1 
\v 16 Nolaila, hana aku la o Davida e like me ka ke Akua i kauoha ai ia ia: a pepehi aku la lakou i na Pilisetia mai Gibeona aku a hiki i Gazera.
\q1 
\v 17 Kui aku la ka lono no Davida i na aina a Pau; a hookau aku la o Iehova i ka makau ia ia maluna o na lahuikanaka a pau.
\c 15
\b
\q1 
\v 1 HANA iho la ia i na hale nona maloko o ke kulanakauhale o Davida, a hoomakaukau iho la hoi oia i wahi no ka pahu o ke Akua, a kukulu iho la i halelewa nona.
\q1 
\v 2 Alaila, olelo mai la o Davida, Aohe mea e ae nana e amo i ka pahu o ke Akua, o na Levi wale; no: no ka mea, ua koho o Iehova ia lakou e amo i ka pahu o ke Akua, a e lawelawe nana a mau loa no.
\q1 
\v 3 Houluulu mai la o Davida i ka Iseraela a pau i Ierusalema, e lawe mai i ka Pahu o Iehova i kona wahi, kahi ana i hoomakaukau ai nona.
\q1 
\v 4 Houluulu ae la o Davida i na mamo a Aarona, a me na Levi:
\q1 
\v 5 O na mamo a Kohata; o Uriela ka luna, a o kona poe hoahanau hookahi haneri a me ka iwakalua:
\q1 
\v 6 O na mamo a Merari; o Asaia ka luna, a o kona poe hoahanau he elua haneri a me ka iwakalua:
\q1 
\v 7 O na mamo a Geresoma; o Ioela ka luna, a o kona poe hoahanau he haneri a me ke kanakolu;
\q1 
\v 8 O na mamo a Elizapana; o Semaia ka luna, a o kona poe hoahanau he elua haneri:
\q1 
\v 9 O na mamo a Heberona; o Eliela ka luna, a o kona poe hoahanau he kanawalu:
\q1 
\v 10 O na keikikane a Uziela; o Aminadaba ka luna, a o kona poe hoahanau he haneri a me ka umikumamalua.
\q1 
\v 11 Kahea aku la o Davida ia Zadoka laua o Abiatara na kahuna, a i na Levi hoi, ia Uriela, Asaia, Ioela, Semaia, Eliela, a me Aminadaba,
\q1 
\v 12 I aku la oia ia lakou, O oukou na luna ohana o na Levi; e huikala ia oukou iho, oukou a me na hoahanau o oukou, i lawe mai ai oukou i ka pahu o Iehova ke Akua o ka Iseraela i kahi a'u i hoomakaukau ai nona.
\q1 
\v 13 No ka mea, no ka oukou hana ole ana ia me. mamua, i hookae mai ai o Iehova ko kakou Akua maluna o kakou, no ko kakou imi ole ana ia ia ma ka pololei maoli.
\q1 
\v 14 Nolaila, i huikala ai na kahuna a me na Levi ia lakou iho, i mea e lawe mai ai i ka pahu o Iehova ke Akua o ka Iseraela.
\q1 
\v 15 A amo mai la na mamo a Levi i ka pahu o ke Akua maluna o ko lakou poohiwi, ma na auamo o luna, me ka Mose i kauoha mai ai, e like me ka olelo a Iehova.
\b
\q1 
\v 16 Olelo mai la o Davida i na luna o na Levi, e hoonoho i ko lakou poe hoahanau, i poe hoolea, me na mea kani, na pesaleteria, na lira, na kimebala, e hookani ana me ka hookiekie ana i ka leo me ka olioli.
\q1 
\v 17 A hoonoho aku la na Levi ia Hemana ke keiki a Ioela; a no kona poe hoahanau, ia Asapa ke keiki a Berekia; a no na mamo a Merari o ko lakou poe hoahanau, o Etana ke keiki a Kusaia;
\q1 
\v 18 A me lakou pu ko lakou mau hoahanau mamuli iho, o Zekaria, o Bena, o Iaaziela, o Semiramota, o Iehiela, o Uni o Eliaba, o Benaia, o Maaseia, o Matitia, o Elipele, o Mikeneia, o Obededoma, a o Ieiala na kiaipuka.
\q1 
\v 19 Pela na mea hoolea, o Hemana, o Asapa, a o Etana, e hookani lakou me na kimebala keleawe:
\q1 
\v 20 A o Zekaria, o Aziela, o Semiramota, o Iehiela, o Uni, o Eliaba, o Maaseia, a o Benaia, me na pesaleteria ma ka Ieo kiekie;
\q1 
\v 21 A o Matitia, o Elipele, o Mikeneia, o Obededoma, o Ieiela, o Azazia, me na lira ma ka leo haahaa e alakai ai.
\q1 
\v 22 A o Kenania, ka luna o ka Levi, no ka leo mele no ia; ao aku la ia i ka leomele, no ka mea, he akamai kona.
\q1 
\v 23 A o Berekia laua o Elekana na kiaipuka no ka pahu.
\q1 
\v 24 A o Sebenia, o Iehosapata, o Netaneela, o Amasai, o Zekerta, o Benaia, a o Eliezera, na kahuna i puhi i na pu imua o ka pahu o ke Akua: a o Obededoma laua o Iehia na kiaipuka no ka pahu.
\b
\q1 
\v 25 Pela o Davida me na lunakahiko o ka Iseraela a me na luna tausani i hele aku ai, e lawe mai i ka pahuberita o Iehova, mai ka hale o Obededoma mai me ka olioli.
\q1 
\v 26 A i ka manawa a ke Akua i kokua mai ai i na Levi e amo ana i ka pahuberita o Iehova, alaila mohai aku la lakou i na bipikane ehiku, a me na hipakane ehiku.
\q1 
\v 27 Ua aahuia o Davida i ka aahu makue, a me na Levi e amo ana i ka pahu a me ka poe memele, a o Kenania ke kumu ao i ka mele, a me ka poe memele: maluna hoi o Davida kekahi epoda olona.
\q1 
\v 28 Pela ka Iseraela a pau i lawe mai ai i ka pahuberita o Iehova me ka hooho ana, a me ke kani ana o ke koreneta, a o na pu, a mo na kimebala, e hookani ana hoi i na pesaleteria a me na lira.
\b
\q1 
\v 29 A hiki mai la ka pahuberita o Iehova i ke kulanakauhale o Davida, nana mai la o Mikala ke kaikamahine a Saula ma ka pukamakani, a ike mai la i ke alii ia Davida e haa ana a e hookani ana: hoowahawaha iho la oia ia ia maloko o kona naau.
\c 16
\b
\q1 
\v 1 PELA lakou i lawe mai ai i ka pahu o ke Akua, a hookau iho la ia ia iwaena konu o ka halelewa a Davida i kukulu ai nona: a mohai aku la lakou i na mohaikuni a me na mohai hoomalu imua o ke Akua.
\q1 
\v 2 I ka wa i hoopau ai o Davida i ka mohai aku i na mohaikuni a me na mohaihoomalu, hoomaikai mai la ia i na kanaka ma ka inoa o Iehova.
\q1 
\v 3 A haawi pakahi mai la ia i ka Iseraela a pau, i na kane a me na wahine, i kela mea i keia mea, i ka popoberena a me kauwahi ia, a me kekahi pai huawaina.
\b
\q1 
\v 4 A hoonoho iho la ia i kekahi poe o na Levi e lawelawe imua o ka pahu o Iehova e hoohiki, e hoomaikai, a e hoolea aku ia Iehova i ke Akua no ka Iseraela.
\q1 
\v 5 O Asapa ka luna, a malalo iho o Zekaria, o Ieiela, o Semiramota, o Iehiela, o Matitia, o Eliaba, o Benaia a o Obededoma: a o Ieiela me na pesaleteria a me na lira: aka, hookani ae la o Asapa me na kimebala:
\q1 
\v 6 O Benaia hoi a o Iehaziela na kahuna, me na pu e mau ana imua o ka pahuberita o ke Akua.
\b
\q1 
\v 7 Ia la iho no, haawi mua mai la o Davida i ka mililani ia Iehova, maloko o ka lima o Asapa a o kona poe hoahanau.
\q1 
\v 8 E mililani aku ia Iehova, e kahea aku i kona inoa.
\q1 E hoike aku i kana mau hana iwaena o kanaka.
\q1 
\v 9 E mele aku ia ia, e mele halelu aku ia ia,
\q1 E kamailio oukou i na hana kupanaha ana a pau.
\q1 
\v 10 E kaena oukou no kona inoa hoano:
\q1 E olioli ka naau o ka poe imi aku ia Iehova.
\q1 
\v 11 E imi aku oukou ia Iehova a me kona ikaika,
\q1 E imi mau aku i kona maka.
\q1 
\v 12 E hoomanao i na hana mana ana i hana'i,
\q1 I na mea kupanaha ana, a me na olelo hoopono a kona waha;
\q1 
\v 13 E na hua a Iseraela a kana kauwa,
\q1 Na mamo hoi a Iakoba, o kona poe i waeia.
\q1 
\v 14 Oia o Iehova ko kakou Akua;
\q1 Aia ma ka honua a pau kana mau olelo hoopono.
\q1 
\v 15 E malama mau oukou i kana berita,
\q1 I ka olelo ana i kauoha mai ai i na hanauna he tausani;
\q1 
\v 16 Ana i hana'i me Aberahama,
\q1 A me kana hoohiki ana ia Isaaka:
\q1 
\v 17 Ua hookupaa oia ia mea hookahi i kanawai ia Iakoba,
\q1 A i berita mau loa ia Iseraela,
\q1 
\v 18 E i mai ana, No oukou e haawi aku ai au i ka aina o Kanaana,
\q1 I kuleana no ko oukou noho hooilina ana;
\q1 
\v 19 I ko oukou manawa i uuku ai,
\q1 He uuku nae, a he poe malihini ilaila.
\q1 
\v 20 I ka manawa i hele ai lakou mai kekahi lahuikanaka a kekahi lahuikanaka,
\q1 A mai kahi aupuni a hiki i kela aupuni;
\q1 
\v 21 Aole ia i ae mai i kekahi kanaka e hana ino mai ia lakou,
\q1 Oiaio no, ao mai la oia i na'lii no lakou,
\q1 
\v 22 Mai hoopa aku i kuu poe i poniia,
\q1 Mai hoino hoi i kuu mau kaula.
\q1 
\v 23 E mele aku ia Iehova, e ko ka honua a pau;
\q1 E hoike aku i kona ola, ia la aku ia la aku.
\q1 
\v 24 E hai aku i kona nani i na lahuikanaka,
\q1 I kana mau hana kupanaha i ko na aina a pau.
\q1 
\v 25 No ka mea, he nui no o Iehova, a e hoomaikai nui ia:
\q1 E weliweliia hoi oia maluna o na akua a pau.
\q1 
\v 26 No ka mea, o na akua a pau o na kanaka, he poe kii lakou:
\q1 Aka, na Iehova i hana na lani.
\q1 
\v 27 Ma kona alo ka nani a me ka mahalo;
\q1 Ma kona wahi hoi ka ikaika a me ka olioli.
\q1 
\v 28 E haawi aku no Iehova, e na hanauna kanaka,
\q1 E haawi aku no Iehova i ka nani a me ka mana.
\q1 
\v 29 E haawi aku ia Iehova i ka nani no kona inoa:
\q1 E ho mai i ka mohai, a e hele mai imua ona:
\q1 E hoomana ia Iehova ma ka nani o ka hemolele.
\q1 
\v 30 E weliweli imua ona, e ko ka honua a pau:
\q1 E ku paa auanei hoi ke ao nei, i hoouaue ole ia'i.
\q1 
\v 31 E hauoli ko na lani, e olioli ko ka honua:
\q1 E oleloia hoi iwaena o na lahuikanaka,
\q1 O Iehova e alii ana.
\q1 
\v 32 E halulu mai ke kai, a me na mea i piha ai:
\q1 E olioli na mahinaai me na mea a pau oloko.
\q1 
\v 33 Alaila e kani aku ai na laau o ka nahele,
\q1 I ka hiki ana mai o Iehova;
\q1 No ka mea, ke hele mai la ia e hooponopono i ko ka honua.
\q1 
\v 34 E mililani aku ia Iehova, no ka mea, he maikai kona;
\q1 A he mau loa kona aloha.
\q1 
\v 35 E i aku hoi oukou, E hoola mai ia makou,
\q1 E ke Akua nona ko kakou ola,
\q1 E houluulu ia makou, a e hoopakele ia makou i ko na aina e,
\q1 I aloha aku ai makou i kou inoa hoano,
\q1 A e kaena aku ai i kou maikai.
\q1 
\v 36 E hoomaikaiia ke Akua o ka Iseraela, a mau loa a mau loa aku. Olelo aku la na kanaka a pan, Amene, a hoomaikai aku la lakou ia Iehova.
\b
\q1 
\v 37 A hoonoho aku la oia imua o ka pahuberita o Iehova ia Asapa a me kona poe hoahanau, e lawelawe mau imua o ka pahu, e like me ka mea pono e hanaia'i i kela la i keia la:
\q1 
\v 38 A me Obededoma, me ko lakou poe hoahanau, he kanaonokumamawalu; o Obededoma hoi he keiki a Iedutuna a o Hosa na kiaipuka:
\q1 
\v 39 A o Zadoka ke kahuna, a me kona poe hoahanau na kahuna, imua o ka halelewa o Iehova, ma ka wahi kiekie, aia ma Gibeona,
\q1 
\v 40 E mohai mau aku ai i na mohaikuni ia Iehova maluna o ke kuahu, i kakahiaka, a i ke ahiahi, e like me ka mea a pau i kakauia ma ke kanawai o Iehova, ana i kauoha mai ai i ka Iseraela:
\q1 
\v 41 Me lakou pu o Hemana, o Iedutuna, a o na mea i waeia e koe, o ka poe i kaheaia ma ka inoa, no ka mililani aku ia Iehova, no ka mea, he mau loa kona aloha:
\q1 
\v 42 A me lakou pu o Hemana a o Iedutuna, me na pu kani a me na kimebala, no ka poe e pono ke hookani, me na mea kani a ke Akua A o na keikikane a Iedutuna na kiaipuka.
\q1 
\v 43 A hele aku la na kanaka a pau o kela kanaka keia kanaka i kona hale iho: a hoi hou aku la o Davida e hoomaikai i ko ka hale ona.
\c 17
\b
\q1 
\v 1 A IA i ko Davida noho ana iloko o kona hale, olelo mai la o Davida ia Natana ke kaula, Eia au ke noho nei iloko o ka hale kedera, aka, o ka pahuberita o Iehova, aia no ia malalo o na paku.
\q1 
\v 2 Alaila, i aku la o Natana ia Davida, E hana oe i ka mea a pau maloko o kou naau; no ka mea, me oe pu no ke Akua.
\b
\q1 
\v 3 A ia po iho no, hiki mai la ka olelo a ke Akua ia Natana, i mai
\q1 
\v 4 E hele aku oe, e hai ia Davida i kuu kauwa, Penei ka Iehova i olelo mai nei, Mai hana oe i hale no'u e noho ai:
\q1 
\v 5 No ka mea, aole au i noho iloko o ka hale maoli, mai ka manawa mai a'u i kai mai nei i ka Iseraela a hiki i keia manawa: aka, ua hele au mai kekahi halelole, a hiki i kekahi halelole, a mai kekahi halelewa a kekahi halelewa.
\q1 
\v 6 I na wahi a'u i hele pu ai me ka Iseraela a pau, i olelo anei au i kekahi lunakanawai o ka Iseraela, a'u i kauoha aku ai e hanai i ko'u poe kanaka, i ka i ana aku, No ke aha la oukou i hana ole ai i hale kedera no'u!
\q1 
\v 7 Nolaila la, e olelo aku oe i kuu kauwa ia Davida, Eia ka Iehova o na kaua i olelo mai nei, I lawe mai no wau ia oe mai ka pahipa mai, mamuli mai hoi o ka poe hipa, i alii oe maluna o ko'u poe kanaka o ka Iseraela;
\q1 
\v 8 Owau no kekahi pu me oe i na wahi a pau au i hele ai, a ua hooki iho no wau i na enemi ou a pau mai kou maka aku, a ua hookaulana au i kou inoa, e like me ka inoa o na kanaka nui ma ka honua nei.
\q1 
\v 9 Na'u hoi e hoike aku i wahi no ko'u poe kanaka no ka Iseraela, a e kanu iho no au ia lakou, a e noho iho lakou ma ko lakou wahi, aole e nee hou aku lakou; aole hoi e hoopoino hou mai ka poe keiki na ka hewa ia lakou, e like mamua,
\q1 
\v 10 A mai ka manawa mai a'u i hoonoho ai i na lunakanawai maluna o ko'u poe kanaka o ka Iseraela. Eia hoi, na'u no e hoopau auanei i kou poe enemi a pau. A eia hoi kekahi, ke, hai aku nei au ia oe, na Iehova no e hana i hale nou.
\b
\q1 
\v 11 A i ka manawa i hala ae kou mau la, a hele oe me ou mau makua, na'u no e hooku ae i kau hua mahope ou, no na keiki au; a e hookupaa auanei au i kona aupuni.
\q1 
\v 12 Nana no e hana i hale no'u, a e hookupaa mau loa auanei au i kona nohoalii.
\q1 
\v 13 Owau auanei kona makua, a e lilo oia i keiki na'u: aole au e lawe aku i kuu aloha mai ona aku, me a'u i lawe aku ai ia mai kou mua aku.
\q1 
\v 14 Aka, e hoonoho au ia ia maloko o kuu hale a iloko o kuu aupuni a mau loa aku; a e hookupaa mau loa ia kona nohoalii.
\q1 
\v 15 Ma neia mau huaolelo a pau, a ma keia hihio a pau, ka Natana i olelo aku ai ia Davida.
\b
\q1 
\v 16 A hele aku la o Davida ke alii, a noho aku la imua o Iehova, olelo aku la, Owai la wau, e Iehova ke Akua, heaha hoi ka'u ohana i malama mai ai oe ia'u a hiki i neia wa?
\q1 
\v 17 He mea uuku hoi keia imua o kou maka, e ke Akua: a ua olelo mai hoi oe no ka ohana a kau kauwa a liuliu aku mahope; a ua hoomanao mai oe ia'u ma ka ke kanaka kiekie, e Iehova ke Akua.
\q1 
\v 18 Heaha ka mea hou aku e hiki ia Davida ke olelo aku ia oe no ka pono o kau kauwa? no ka mea, ua ike oe i kau kauwa.
\q1 
\v 19 E Iehova, no ka pono o kau kauwa, a e like me ko loko o kou naau, ua hana mai oe i keia mea nui a pau, ma ka hoike ana mai i na mea nui a pau.
\q1 
\v 20 E Iehova e, aohe ou mea like, aohe Akua e ae, o oe wale no, ma ka mea a pau a makou i lohe ai ma ko makou pepeiao.
\q1 
\v 21 Auhea la kekahi lahuikanaka ma ka honua nei e like me kou poe kanaka o ka Iseraela, ka poe a ke Akua i kii aku ai e hoola i poe kanaka nona, i mea e kaulana ai kou inoa i nui ia, a i weliweli, ma ka hookuke ana aku i na lahuikanaka mai ke alo aku o kou poe kanaka au i hoola ai mai Aigupita mai?
\q1 
\v 22 No ka mea, ua hoolilo oe i kou poe kanaka ka Iseraela i poe kanaka nou, a mau loa aku: a ua lilo mai oe, e Iehova, i Akua no lakou.
\q1 
\v 23 Nolaila hoi, e Iehova, e hookupaa mau loa oe i ka olelo au i olelo mai ai no kau kauwa, a me kana ohana, a e hana mai e like me kau i olelo ai.
\q1 
\v 24 Oiaio, e hookupaa oe, i hoonui mau loa ia kou inoa, i ka i ana, O Iehova o na kana, oia ke Akua o ka Iseraela, ke Akua ia i ka Iseraela: a e hookupaaia ka ohana a kau kauwa a Davida imua ou.
\q1 
\v 25 No ka mea, ua hoike mai oe, e kuu Akua, i ka pepeiao o kau kauwa, e hana oe i hale nona; nolaila, ua manao iho kau kauwa e pule aku imua ou.
\q1 
\v 26 Ano hoi, e Iehova, o oe no ke Akua, a ua hai mai oe i keia lokomaikai i kau kauwa:
\q1 
\v 27 Nolaila hoi, ua lealea oe e hoopomaikai mai i ka ohana a kau kauwa, i mau loa ia imua ou: no ka mea, ke hoopomaikai mai nei oe, e Iehova, a e pomaikai mau loa no ia.
\c 18
\b
\q1 
\v 1 MAHOPE mai o keia mea, pepehi aku la o Davida i na Pilisetia, a hoopau ia lakou; a lawe ae la oia ia Gata, a me na kulanahale ona mailoko ae o ka lima o na Pilisetia.
\q1 
\v 2 Pepehi aku hoi oia i ka Moaba: a lilo mai la na Moaba i poe kauwa na Davida, a lawe mai la hoi lakou i ka waiwai hookupu.
\b
\q1 
\v 3 Pepehi aku la hoi o Davida ia Hadarezera ke alii o Zoba, a hiki i Hamata, ia ia i hele aku ai e hoopaa i kona aupuni ma ka muliwai o Euperate.
\q1 
\v 4 Lawe ae la o Davida mai ona aku i na halekaa he tausani, me na hoohololio ehiku tausani, a me na tausani kanaka kani wawae he iwakalua: oki iho la hoi o Davida i ke olona wawae o na lio a pau o na halekaa; aka, hookoe iho la ia i hookahi haneri o na lio halekaa.
\b
\q1 
\v 5 A i ka hele ana mai o ko Suria no Damaseko e kokua mamuli o Hadarezera, ke alii o Zoba, pepehi aku la o Davida i ko Suria he iwakaluakumamalua na tausani kanaka.
\q1 
\v 6 A hana iho la o Davida i na pakaua ma Suria no Damaseko, a lilo ae la ko Suria i poe kauwa na Davida, a lawe mai la i ka waiwai hookupu. Pela o Iehova i malama mai ai ia Davida i na wahi a pau ana i hele ai.
\q1 
\v 7 Lawe ae la hoi o Davida i na palekaua gula maluna o na kauwa a Hadarezera ke alii o Zoba, a lawe mai la ia mau mea i Ierusalema.
\q1 
\v 8 Lawe mai la hoi o Davida i ke keleawe he nui loa, mai Tibehata mai. a mai Kuna hoi, o na kulanakaubale ia o Hadarezera; ka mea keia i hanaia'i e Solomona ke kai keleawe, me na pau a me na ipu keleawe.
\b
\q1 
\v 9 A lohe ae la o Tou ke alii o Hamata, ua pepehi o Davida i ka poe kaua a pau o Hadarezera, o ke alii no Zoba;
\q1 
\v 10 Hoouna mai la oia i kana keiki ia Hadorama io Davida la, e hooaloha ia ia, a e hoomaikai ia ia, no kona kaua ana ia Hadarezera, a ua pepehi ia ia; (no ka mea, he kanaka o Hadarezera i kaua aku me Tou;) a me ia no na ipu gula, na ipu kala a me na ipu keleawe he nui loa.
\b
\q1 
\v 11 Hoolaa aku la o Davida ke alii ia mau mea no Iehova, me ke kala a me ke gula ana i lawe mai ai no na lahuikanaka a pau; mai ka Edoma mai, mai ka Moaba mai, a mai ka poe mamo mai a Amona, a mai ko Pilisetia, a mai ka Amaleka mai.
\b
\q1 
\v 12 A pepehi aku la o Abisai ke keiki a Zeruia i na kanaka o Edoma he umikumamawalu tausani, ma ke awawa paakai.
\b
\q1 
\v 13 Hana iho la hoi oia i na pakaua ma Edoma: a lilo ae la ka Edoma a pau i poe kauwa na Davida. Pela o Iehova i malama mai ai ia Davida i na wahi a pau ana i hele aku ai.
\b
\q1 
\v 14 A nohoalii iho la o Davida maluna o ka Iseraela a pau, a hooko aku la i ke kanawai me ka hoopono aku iwaena o kona poe kanaka a pau.
\q1 
\v 15 A o Ioaba ke keiki a Zeruia, oia ka lunakaua; a o Iehosapata ke keiki a Ahiluda ke kakaolelo.
\q1 
\v 16 A o Zadoka ke keiki a Ahituba, a me Abimeleka ke keiki a Abiatara na kahuna; a o Savasa ke kakauolelo;
\q1 
\v 17 A o Benaia ke keiki a Iehoiada, maluna ia o ka poe Kereti a me ka poe Peleti: a o na keikikane a Davida, he mau luna lakou me ke alii.
\c 19
\b
\q1 
\v 1 MAHOPE mai o ia mea, make iho la o Nahasa ke alii o na mamo a Amona, a nohoalii iho la o Hanuna ma kona wahi.
\q1 
\v 2 Olelo iho la o Davida, E lokomaikai no wau ia Hanuna ke keiki a Nahasa; no ka mea, i lokomaikai mai kona makuakane ia'u. Hoouna aku la o Davida i na elele e hooluolu aku ia ia no kona makuakane. A hiki aku la na elele o Davida i ka aina o na mamo a Amona, io Hanuna la, e hooluolu ia ia.
\q1 
\v 3 Aka, o na alii o na mamo a Amona, i aku la lakou ia Hanuna, Ke manao nei anei oe, e hoomaikai mai o Davida i kou makuakane i kona hoouna ana mai iou la i na mea hooluolu? Aole anei i hele mai kana mau kauwa iou nei e makaikai, a e hookahuli, a e hoomakakiu mai i ka aina?
\q1 
\v 4 Nolaila, lalau mai la o Hanuna i na kauwa a Davida, a kahi ae la i ko lakou umiumi, a okioki iho la i ko lakou mau aahu mawaena, ma ko lakou kikala, a kipaku mai la ia lakou.
\q1 
\v 5 Hele mai la kekahi, a hai aku la ia Davida i ka mea i hanaia mai i ua mau kanaka la. Hoouna aku ia ia e halawai me lakou: no ka mea, ua hilahila loa lakou. I aku la ke alii, E noho oukou ma Ieriko, a ulu ae ko oukou umiumi, alaila e hoi mai
\b
\q1 
\v 6 A ike iho la na mamo a Amona, ua pilau lakou imua o Davida, hoouka aku la o Hanuna me na mamo a Amona i na talena kala he tausani e hoolimalima no lakou i na halekaa a me na hoohololio mai Mesopotamia, a mai Suria-maaka, a mai Zoba mai.
\q1 
\v 7 Hoolimalima ae la lakou i na kaa he kanakolukumamalua tausani, a me ke alii o Maaka, a me kona poe kanaka; a hele mai lakou a hoomoana imua o Medeba. Akoakoa mai la na mamo a Amona mailoko mai o ko lakou mau kulanakauhale, a hele mai i ke kaua.
\q1 
\v 8 A lohe ae la o Davida, hoouna aku la oia ia Ioaba, me ka puali a pau o ka poe ikaika.
\q1 
\v 9 Hele mai la ka poe mamo a Amona iwaho, a hoonohonoho i ke kaua ma ke alo o ka puka e komo ai iloko o ke kulanakauhale: a ku okoa ae la na alii i hiki mai ma ke kola.
\b
\q1 
\v 10 A ike aku la o Ioaba i ke alo o na kaua, mamua kekahi, a mahope kekahi, wae aku la oia i ka poe ui a pau o ka Iseraela, a hoonohonoho aku la ia lakou e ku e i ko Suria
\q1 
\v 11 A haawi aku la ia i ka poe i koe ma ka lima o Abisai kona kaikaina, a hoonohonoho aku oia ia lakou e ku e i na mamo a Amona.
\q1 
\v 12 I aku la oia, Ina e oi aku ka ikaika o ko Suria i ko'u, alaila e kokua mai oe ia'u: aka, ina e oi aku ka ikaika o na mamo a Amona i kou, alaila au e kokua aku ia oe.
\q1 
\v 13 I nui ka ikaika, a e koa hoi kakou no ko kakou lahuikanaka, a me na kulanakauhale no ko kakou Akua: a e hana mai o Iehova i ka mea pono imua o kona maka.
\q1 
\v 14 Neenee aku la o Ioaba me na kanaka me ia imua o ko Suria, i ke kaua ana; a hee aku la lakou imua ona.
\q1 
\v 15 A ike aku la na mamo a Amona, ua hee aku la ko Suria, alaila hee aku la hoi lakou imua o Abisai kona kaikaina, a komo aku la iloko o ke kulanakauhale. Alaila hele mai la o Ioaba i Ierusalema.
\b
\q1 
\v 16 A ike ae la ko Suria, ua pepehiia lakou imua o ka Iseraela, hoouna aku la lakou i na elele, a kai mai la lakou i ko Suria e noho ana ma kela aoao o ka muliwai: a imua o lakou o Sopaka ka lunakoa no Hadarezera.
\q1 
\v 17 A hai aku la kekahi ia Davida: a hoakoakoa ae la oia i ka Iseraela a pau, a hele aku la ma kela aoao o Ioredane, a hiki aku la io lakou la, a hoonohonoho aku la i ke kaua ku e ia lakou. Aia hoonohonoho aku ai o Davida i ke kaua ku e ia lakou, alaila lakou i kaua mai me ia.
\q1 
\v 18 A hee aku la ko Suria imua o ka Iseraela; a pepehi aku la o Davida i na kanaka o na halekaa ehiku tausani, a me na kanaka kaniwawae he kanaha tausani, a make iho la o Sopaka ka lunakaua.
\q1 
\v 19 A ike iho la na kauwa a Hadarezera, ua pepehiia lakou imua o ka Iseraela, hookuikahi mai la lakou me Davida, a lilo iho la i poe kauwa nana Aole hoi i manao ko Suria e kokua hou aku i na mamo a Amona.
\c 20
\b
\q1 
\v 1 A I ka makahiki hou, i ka manawa e hele aku ai na alii, alakai aku la o Ioaba i ka poe ikaika o na koa, a luku iho la i ka aina o na mamo a Amona, a hele aku la, a hoopilikia aku la ia Raba: aka, noho iho la o Davida i Ierusalema A pepehi aku la o Ioaba ia Raba, a luku iho la ia wahi.
\q1 
\v 2 Lawe ae la o Davida i ka papalealii o ko lakou alii mailuna o kona poo, he talena gula ia i ke kaupaona ana, a me na pohaku makamae maloko; a ua kauia oia maluna o ke poo o Davida: a lawe mai la ia i ka waiwai pio he nui loa mailoko mai o ua kulanakauhale la.
\q1 
\v 3 Lawe mai la hoi oia iwaho i na kanaka oloko: a okioki iho la ia lakou i na pahiolo, a i na mea hao oioi, a i na koilipi. Pela i hana aku ai o Davida i na kulanakauhale a pau o na mamo a Amona. A hoi hou mai la o Davida me na kanaka a pau i Ierusalema.
\b
\q1 
\v 4 A mahope mai o ia mea, ku ae la ke kaua ma Gezera me na Pilisetia; ia manawa, pepehi iho la o Sibekai no Husata ia Sipai no na keiki a ke kanaka nunui: a ua hoopioia lakou.
\q1 
\v 5 A he kaua hou no hoi me na Pilisetia; a pepehi iho la o Elehanana ke keiki a Iaira ia Lahemi ke kaikaina o Golia no Gata, o ke au o kaua ihe, ua like ia me ka laau o ka mea ulana lole.
\q1 
\v 6 A he kaua hou ma Gata, ilaila he kanaka nunui, he iwakaluakumamaha na manamanalima a me na manamanawawae ona, he paono a he paono, a he keiki no hoi ia na ke kanaka nunui.
\q1 
\v 7 Aka i ka wa i hoino mai ai oia i ka Iseraela, pepehi iho la o lonatana ke keiki a Simea a ke kaikuaana o Davida, ia ia.
\q1 
\v 8 Ua hanau keia poe na ke kanaka nunui ma Gata; a haule lakou ma ka lima o Davida, a me ka lima o kana mau kauwa
\c 21
\b
\q1 
\v 1 KU e mai la o Satana i ka Iseraela, a hoowalewale mai la ia Davida e helu aku i ka Iseraela.
\q1 
\v 2 Olelo aku la o Davida ia Ioaba a i na luna o kanaka, Ou haele, e helu i ka Iseraela, mai Beereseba a hiki i Dana: a e lawe mai i ko lakou helu ana io'u nei, i ike au.
\q1 
\v 3 Ekemu mai la o Ioaba, E hoonui o Iehova i kona poe kanaka, a pahaneri hou aku: aka, e kuu haku, e ke alii, aole anei lakou a pau na kauwa a kuu haku? No ke aha la hoi e makemake nei kuu haku ia mea? No ke aha la oia e lilo ai i kumu e lawehala ai o ka Iseraela?
\q1 
\v 4 Aka, ua ikaika ka olelo a ke alii maluna o Ioaba. Nolaila, hele aku la o Ioaba, a kaahele mawaena o Iseraela a pau, a hoi mai la i Ierusalema.
\b
\q1 
\v 5 Haawi aku la o Ioaba i ka huina o ka helu ana i na kanaka ia Davida. A o ka helu ana i ka Iseraela a pau, he tausani tausani a me ka haneri tausani keu ka poe i unuhi i ka pahikaua: a no ka Iuda eha haneri a me kanahiku tausani kanaka ka i unuhi i ka pahikaua.
\q1 
\v 6 Aka, aole ia i helu i ka Levi a me ka Beniamina, no ka mea, ua hoowahawahaia ka olelo a ke alii e Ioaba.
\q1 
\v 7 A he hewa no ia mea imua o na maka o Iehova; nolaila ia i hahau ai i ka Iseraela.
\q1 
\v 8 Olelo aku la o Davida i ke Akua, Ua hana lapuwale iho nei au i kuu hana ana ia mea: a ke noi aku nei au ia oe, e kala ae oe i ka hewa o kau kauwa; no ka mea, ua hana lapuwale loa no wau.
\b
\q1 
\v 9 Olelo mai la o Iehova ia Gada i ko Davida kaula, i mai la,
\q1 
\v 10 O hele e hai ia Davida, i ka i ana aku, Eia ka Iehova e olelo mai nei, Ke hoike aku nei au nou i ekolu mau mea; e koho oe i kekahi o lakou, i hana aku ai au ia ia oe.
\q1 
\v 11 A hele mai la o Gada, i mai la ia ia, Eia ka Iehova e olelo mai nei, e koho oe nou,
\q1 
\v 12 I na makahiki wi ekolu paha; a ekolu na malama paha e hee ai imua o kou poe enemi, a loaa mai oukou i ka pahikaua o kou poe enemi; a eia paha, ekolu la o ka pahikaua o Iehova, oia ke ahulau ma ka aina, a o ka anela o Iehova e luku mai ana ma na palena a pau o ka Iseraela. Nolaila hoi, e kuka iho oe i ka olelo na'u e hoihoi aku i ka mea nana au i hoouna mai.
\q1 
\v 13 Olelo mai la o Davida ia Gada, He pilikia nui ko'u: e aho e haule iho au ano iloko o ka lima o Iehova; no ka mea, he nui loa kona aloha: aole au make haule iloko o ka lima o kanaka.
\b
\q1 
\v 14 A hoouna mai la o Iehova i ke ahulau iluna o ka Iseraela; a make iho la na kanaka o ka Iseraela he kanahiku tausani.
\q1 
\v 15 A hoouna mai la ke Akua i kekahi anela i Ierusalema e luku iho ia wahi: a i kona luku ana, nana mai la o Iehova, a hoololi iho la i kona manao hoino mai; a i mai la ia i ka anela nana i luku mai, U'oki, e alia kou lima ano. A ku iho la ka anela o Iehova ma kahi hehi palaoa o Orenana ka Iebusa.
\q1 
\v 16 Nana ae la na maka o Davida iluna, a ike aku la i ka anela o Iehova e ku ana mawaena o ka honua a o ka lani, a he pahikaua i unuhiia ma kona lima i oia'ku maluna o Ierusalema. Alaila, o Davida a me na lunakahiko i aahuia i ke kapa inoino, haule iho la lakou ilalo ke alo.
\q1 
\v 17 Olelo aku la o Davida i ke Akua, Aole anei owau ka mea i kauoha aku e heluia'i na kanaka? Owau io no ka mea i hewa, a i hana i keia mea ino maoli. Aka, o keia poe hipa, heaha ka lakou i hana'i? Ke noi aku nei au ia oe, e Iehova kuu Akua, e kau mai i kou lima maluna iho o'u a o ka ohana a ko'u makuakane; aole maluna o kou poe kanaka, e make ai lakou.
\b
\q1 
\v 18 Alaila, kauoha mai la ka anela o Iehova ia Gada, e olelo aku ia Davida, e pii aku o Davida, a e kukulu i kuahu no Iehova ma kahi hehi palaoa o Orenana ka Iebusa.
\q1 
\v 19 Pii aku la o Davida no ka olelo ana a Gada, ana i olelo ai ma ka inoa o Iehova.
\q1 
\v 20 Haliu ae la o Orenana ihope, a ike aku la i ka anela, alaila pee iho la oia a me kana mau keikikane eha me ia. E hehi palaoa ana o Orenana.
\q1 
\v 21 A i ka hele ana mai o Davida io Orenana la, nana ae la o Orenana, a ike aku la ia Davida, a hele aku la ia iwaho o kahi hehi palaoa, a kulou iho la ia imua o Davida, ilalo ke alo ma ka honua.
\q1 
\v 22 Alaila, i mai la o Davida ia Orenana, E haawi mai oe i ka wahi hehi palaoa, i kukulu iho ai au ilaila i kuahu no Iehova: e haawi mai oe ia'u ia no ke kumukuai maoli: i hookiia'i ke ahulau mai na kanaka aku.
\q1 
\v 23 I aku la o Orenana ia Davida, E lawe oe nou, a e hana iho kuu haku ke alii i ka mea pono imua o kona maka. Aia hoi, ke haawi aku nei au i na bipi no na mohaikuni, a me na laau kaa palaoa i wahie, a me ka palaoa i mohaiai: ke haawi aku nei au ia a pau loa.
\q1 
\v 24 Olelo mai la o Davida ke alii ia Orenana, Aole, aka, he oiaio no, e kuai no au ia wahi no ke kumukuai maoli: no ka mea, aole au e lawe i kau no Iehova, aole hoi e kaumaha aku i na mohaikuni i kuai ole ia.
\q1 
\v 25 A uku aku o Davida ia Orenana i eono haneri sekela gula ma ke kaupaona ana, no ia wahi.
\q1 
\v 26 A hana iho la o Davida i kuahu no Iehova malaila, a kaumaha aku la i na mohaikuni, a me na mohai hoomalu, a kahea aku la oia ia Iehova; a maliu mai la oia ia ia mai ka lani mai i ke ahi maluna o ke kuahu mohaikuni.
\q1 
\v 27 Kauoha mai la o Iehova i ka anela; a hoihoi ae la ia i ka pahikaua maloko o kona wahi.
\b
\q1 
\v 28 Ia manawa no, a ike aku la o Davida ua maliu mai o Iehova ia ia ma kahi hehi palaoa o Orenana ka Iebusa, alaila mohai aku la ia ma ia wahi.
\q1 
\v 29 No ka mea, o ka halelewa o Iehova, a Mose i hana'i iloko o ka waoakua, a me ke kuahu mohaikuni, aia no ia i kela manawa ma kahi kiekie o Gibeona.
\q1 
\v 30 Aka, aole i hiki ia Davida ke hele ilaila e ninau i ke Akua imua ona: no ka mea, ua makau oia i ka pahikaua o ka anela o Iehova.
\c 22
\b
\q1 
\v 1 A LAILA olelo mai la o Davida, Eia ka hale o Iehova ke Akua; eia hoi ke kuahu o ka mohaikuni no ka Iseraela.
\b
\q1 
\v 2 Kauoha mai la o Davida, e houluulu mai i na kanaka e noho ana i ka aina o ka Iseraela: a hoonoho iho la ia i na kalaipohaku e kalai i na pohaku i mea e hana'i i ka hale o ke Akua.
\q1 
\v 3 Hoomakaukau iho la o Davida i ka hao he nui loa no na kui o na pani puka o ka pa, a no na louhao: a me ke keleawe he nui loa aole i kaupaonaia.
\q1 
\v 4 A me na laau kedera he nui loa: no ka mea, na ko Zidona a me ko Turo i lawe mai i ka laau kedera he nui ia Davida.
\q1 
\v 5 I mai la o Davida, He opiopio kuu keiki o Solomona, a he palupalu hoi; a o ka hale e hanaia ana no Iehova, he mea nani nui loa ia, he mea kaulana ma na aina a pau no kona maikai: e hoomakaukau no wau i na mea nona. Nolaila, i hoomakaukau nui loa o Davida mamua o kona make ana.
\b
\q1 
\v 6 Alaila, hea aku la ia i kana keiki ia Solomona, a kauoha aku la ia ia e hana i hale no Iehova ke Akua o ka Iseraela.
\q1 
\v 7 Olelo aku la o Davida ia Solomona, E kuu keiki e, owau nei la, aia no iloko o kuu naau ka manao e hana i hale no ka inoa o Iehova kuu Akua:
\q1 
\v 8 Aka, hiki mai la ka olelo a Iehova io'u nei, i mai la, Ua hookahe oe i ke koko a nui loa, a ua kaua hoi oe i na kaua nui: mai hana oe i hale no kuu inoa, no ka mea, he nui loa ke koko au i hookahe ai ma ka honua imua o ko'u mau maka.
\q1 
\v 9 Aia hoi, e hanau ke keikikane nau, he kanaka hoomaha no ia; a e hoomaha auanei au ia ia mai kona poe enemi a pau e noho ana a puni: no ka mea, o Solomona kona inoa, a e haawi auanei au i ka maluhia a me ka maha no ka Iseraela i kona mau la.
\q1 
\v 10 Nana no e hana ka hale no ko'u inoa, a e lilo auanei ia i keiki na'u, a owau auanei kona makua, a e hookupaa no wau i ka nohoalii o kona aupuni maluna o ka Iseraela, a mau loa aku.
\q1 
\v 11 Ano hoi, e kuu keiki, me oe pu o Iehova: a e pomaikai auanei oe; a e hana oe i ka hale o Iehova o kou Akua, e like me kana i olelo mai ai nou.
\q1 
\v 12 E haawi io mai o Iehova nou i ke akamai a me ka naauao, a e kauoha mai ia oe no ka Iseraela, i malama aku ai oe i ke kanawai o Iehova o kou Akua.
\q1 
\v 13 Alaila oe e pomaikai, ina oe e hoomanao e hooko i na kanawai a me na kauoha a Iehova i haawi mai ai ia Mose no ka Iseraela: e hooikaika oe, a e koa hoi; mai makau oe, aole hoi e pauaho.
\q1 
\v 14 Ano hoi, i kuu ilihune ana, ua hoomakaukau iho no wau no ka hale o Iehova, i hookahi haneri tausani talena gula, a me ka tausani tausani talena kala: a o ke keleawe a me ka hao, aole i kaupaonaia; no ka mea, he nui loa: ua hoomakaukau hoi au i ka laau a me na pohaku, a nau no e hoomahuahua ae ilaila.
\q1 
\v 15 He nui no hoi na paahana ia oe, na mea kalai a me na mea kapili pohaku a me ka laau, a me na kanaka akamai he nui i ka hana i na hana a pau.
\q1 
\v 16 O ke gula a me ke kala, o ke keleawe a me ka hao, aole i heluia. E ku ae oe, a e hana aku, a me oe pu no o Iehova.
\b
\q1 
\v 17 Kauoha mai la hoi o Davida i na alii a pau o ka Iseraela, e kokua ia Solomona kana keiki:
\q1 
\v 18 Aole anei o Iehova o ko oukou Akua me oukou? Aole anei i hoomaha mai oia ia oukou ma kela aoao a ma keia aoao? No ka mea, ua haawi mai la ia i na kanaka o ka aina iloko o ko'u lima; a ua hoopioia ka aina imua o Iehova a imua o kona poe kanaka.
\q1 
\v 19 Ano e hoopapau oukou i ko oukou naau a me ko oukou uhane e imi aku ia Iehova i ko oukou Akua: e ku ae hoi oukou, a e hana i ka luakini o Iehova ke Akua: i laweia'ku ai ka pahuberita o Iehova, a me na ipu laa no ke Akua, iloko o ka hale e hanaia'na no ka inoa o Iehova.
\c 23
\b
\q1 
\v 1 I KA wa i elemakule ai o Davida, a he nui kona mau la, hoolilo iho la oia ia Solomona i alii no ka Iseraela.
\b
\q1 
\v 2 Houluulu ae la ia i na'lii a pau o ka Iseraela, me na kahuna a me ka Levi.
\q1 
\v 3 A ua heluia na Levi mai ka makahiki he kanakolu a maluna ae: a o ko lakou helu ana ma ko lakou poo, i pakahiia kela kanaka keia kanaka, he kanakolukumamawalu tausani.
\q1 
\v 4 He iwakaluakumamaha tausani o keia poe, he kokua ka lakou i ka hana o ko Iehova hale: a eono tausani, he poe ilamuku a me na lunakanawai lakou.
\q1 
\v 5 A he poe kiaipuka na tausani eha: a eha tausani hoi i hoolea ia Iehova me na mea kani a'u i hana'i, i mea hoolea, [wahi a Davida.]
\q1 
\v 6 Puunaue mai la o Davida ia lakou i na papa mamuli o na keikikane a Levi, o Geresona, o Kohata, a o Merari.
\b
\q1 
\v 7 No ka Geresona, o Laadana a o Simei.
\q1 
\v 8 O na keikikane a Laadana; o ka luna, o Iehiela, o Zetama, a o Ioela, ekolu.
\q1 
\v 9 O na keikikane a Simei; o Selomita, o Haziela, a o Harana, ekolu. O lakou na luna o na makuakane na Laadana mai.
\q1 
\v 10 A o na keikikane a Simei; o Iahata, o Zina, o Ieusa, a o Beria. O lakou eha na keikikane a Zimei.
\q1 
\v 11 A o Iahata ka luna, o Ziza ka lua: aka, aohe nui o na keikikane a Ieusa laua o Beria; nolaila, hookahi o ko laua helu pu ia'na, mamuli o ka ohana o ko laua makuakane.
\b
\q1 
\v 12 O na keikikane a Kohata; o Amerama, o Izehara, o Heberona, a o Uziela, eha.
\q1 
\v 13 O na keikikane a Amerama; o Aarona a o Mose; ua hookaawaleia ae o Aarona, e hoolaa oia i na mea hoano loa, oia a me kona poe keikikane a mau loa aku, e kuni i ka mea ala imua o Iehova, e lawelawe nana, a e hoomaikai ma kona inoa a mau loa aku.
\q1 
\v 14 A o Mose ke kanaka no ke Akua, ua heluia kana mau keikikane maloko o ka ohana a Levi.
\q1 
\v 15 O na keikikane a Mose, o Geresoma a o Eliezera.
\q1 
\v 16 O na keikikane a Geresoma, o Sebuela ka luna.
\q1 
\v 17 A o na keikikane a Eliezera, o Rehabia ka luna. Aohe keiki e ae a Eliezera: aka, he nui na keikikane a Rehabia.
\q1 
\v 18 O na keikikane a Izehara; o Selomita ka luna.
\q1 
\v 19 O na keikikane a Heberona; o Ieria ka mua, o Amaria ka lua, o Iahaziela ke kolu, a o Iekameama ka ha.
\q1 
\v 20 O na keikikane a Uziela; o Mika ka mua, o Iesia ka lua.
\b
\q1 
\v 21 O na keikikane a Merari; o Maheli a o Musi. O na keikikane a Maheli; o Eleazara, a o Kisa.
\q1 
\v 22 A make iho la o Eleazara, aohe ana keikikane, o na kaikamahine wale no: a o na hoahanaukane o lakou, na keikikane a Kisa ka i lawe ia lakou.
\q1 
\v 23 O na keikikane a Musi; o Maheli, o Edera, a o Ieremota, ekolu.
\b
\q1 
\v 24 O lakou na keikikane a Levi mamuli o ka ohana o ko lakou mau makuakane; oia o na makua'lii, e like me ka helu ana ia lakou ma ko lakou poo, o ka poe nana i malama i ka oihana o ka hale o Iehova, mai ka makahiki he iwakalua mai, a malaila aku.
\q1 
\v 25 No ka mea, olelo mai la o Davida, Ua hoomaha mai o Iehova ke Akua o ka Iseraela i kona poe kanaka, a e noho mau loa aku ma Ierusalema.
\q1 
\v 26 Eia hoi, o na Levi; aole lakou e amo hou i ka halelewa, aole hoi na ipu ona no kolaila oihana.
\q1 
\v 27 No ka mea, ma na olelo hope a Davida, ua heluia na Levi mai ka iwakalua o ka makahiki, a malaila aku.
\q1 
\v 28 No ka mea, o ka lakou hana no ka lawelawe na na keikikane a Aarona, no ka oihana o ka hale o Iehova, ma na pahale, a ma na keena, a i ka huikala ana i na mea laa a pau, a me ka hana ana i ka oihana o ka hale o ke Akua;
\q1 
\v 29 No ka berena hoike, a no ka palaoa, ka mea mohai ai, a no na popo palaoa hu ole, a no ke pa pulehu, a no ka mea i koalaia, a no na mea ana wai a pau, a me na ana loa:
\q1 
\v 30 A no ke ku pono i na kakahiaka a pau, e hooaloha a e hoolea aku ia Iehova; a pela hoi i na ahiahi;
\q1 
\v 31 A no ke kaumaha aku i na mohaikuni a pau no Iehova i na Sabati, a me na mahina hou, a i na ahaaina i kauohaia, e mau ana imua o Iehova, ma ka helu ana, e like me ke kanawai i kauohaia mai ia lakou:
\q1 
\v 32 I malama ai lakou i ke kauoha no ka halelewa o ke anaina, a me ke kauoha no kahi hoano, a me ke kauoha no na keiki a Aarona ko lakou poe hoahanau, ma ka oihana o ka hale o Iehova.
\c 24
\b
\q1 
\v 1 EIA ka puunaue ana i na keikikane a Aarona. O na keikikane a Aarona, o Nadaba, o Abihu, o Eleazara, a o Itamara.
\q1 
\v 2 A make iho o Nadaba laua o Abihu mamua o ko laua makuakane, aole no a laua keiki: nolaila, na Eleazara laua o Itamara i hana ka oihanakahuna.
\q1 
\v 3 A hoonoho iho la o Davida ia laua, o Zadoka no na mamo a Eleazara, a o Ahimeleka no na mamo a Itamara e like me ko laua kuleana iloko o ka oihana a laua.
\q1 
\v 4 A ua oi aku ka nui o na luna i loaa o na mamo a Eleazara imua o na mamo a Itamara: a ua puunaueia hoi lakou. Iwaena o na mamo a Eleazara, he umikumamaono ka poe luna no ka ohana o ko lakou mau kupuna, a he awalu hoi iwaena o na mamo a Itamara, e like me ka ohana a ko lakou mau kupunakane.
\q1 
\v 5 Pela lakou i puunaueia'i ma ka puu ana, o kekahi poe me kekahi poe; no ka mea, o na luna no kahi hoano, a me na luna [o ka hale] o ke Akua, no na keiki lakou a Eleazara, a no na keiki a Itamara.
\q1 
\v 6 A o Semaia ke keiki a Netaneela, ke kakauolelo no na Levi, kakau iho la oia ia lakou imua o ke alii nui a me na alii, a me Zadoka ke kahuna, a me Ahimeleka ke keiki a Abiatara, a me na luna o na ohana kahuna a o na Levi: hookahi ohana kupuna i kakauia no Eleazara, a hookahi hoi no Itamara.
\b
\q1 
\v 7 A puka mai la ka puu mua ia Iehoiariba, o ka lua ia Iedaia,
\q1 
\v 8 O ke kolu ia Harima, o ka ha ia Seorima,
\q1 
\v 9 O ka lima ia Malekiia, o ke ono ia Miiamina,
\q1 
\v 10 O ka hiku ia Hakoza, o ka walu ia Abiia,
\q1 
\v 11 O ka iwa ia Iesua, o ka umi ia Sekania,
\q1 
\v 12 O ka umikumamakahi ia Elisiba, o ka umikumamalua ia Iakima;
\q1 
\v 13 O ka umikumamakolu ia Hupa, o ka umikumamaha ia Iesebeaba;
\q1 
\v 14 O ka umikumamalima ia Bilega, o ka umikumamaono ia Imera,
\q1 
\v 15 O ka umikumamahiku ia Hezira, o ka umikumamawalu ia Apese,
\q1 
\v 16 O ka umikumamaiwa ia Petahia, o ka iwakalua ia Iehezekela,
\q1 
\v 17 O ka iwakaluakumamakahi ia Iakina, o ka iwakaluakumamalua ia Gamula,
\q1 
\v 18 O ka iwakaluakumamakolu ia Delaia, o ka iwakaluakumamaha ia Maazia.
\q1 
\v 19 Oia ka hoonoho papa ana ia lakou no ka lakou hana e hele mai ai iloko o ka hale o Iehova, e like me ka lakou i hana'i mamuli o Aarona o ko lakou makuakane, me ka Iehova ke Akua o Iseraela i kauoha mai ai ia ia.
\b
\q1 
\v 20 No na keikikane a Levi i koe: no na keikikane a Amerama; o Subaela: no na keikikane a Subaela; o Iehedeia.
\q1 
\v 21 No Rehebia: no na keikikane a Rehebia, o Isehia ka mua.
\q1 
\v 22 No ka Izehara; o Selomota: no na keiki a Selomota; o Iahata.
\q1 
\v 23 O na keikikane a Heberona; o Ieria ka mua, o Amaria ka lua, o lahaziela ke kolu a o Iekameama ka ha.
\q1 
\v 24 No na keikikane a Uziela: o Mika: no na keikikane a Mika; o Samira.
\q1 
\v 25 O Isehia ke kaikaina o Mika: no na keikikane a Isehia; o Zekaria.
\b
\q1 
\v 26 O na keikikane a Merari; o Maheli a o Musi: no na keikikane a Iaazia; o Beno.
\b
\q1 
\v 27 O na keikikane a Merari ma o Iaazia la; o Beno, o Sohama, o Zakura, a o Iberi.
\q1 
\v 28 Na Maheli o Eleazara, aohe ana keikikane.
\q1 
\v 29 No Kisa: o Ierahemeela ke keikikane a Kisa:
\q1 
\v 30 O na keikikane hoi a Musi; o Maheli, o Edera, a o Ierimota. O lakou na keikikane a na Levi mamuli o ka ohana o ko lakou mau makuakane.
\q1 
\v 31 Puu iho la no hoi lakou e ku pono aku ana i ko lakou poe hoahanau na mamo a Aarona, imua hoi o ke alii o Davida, a o Zadoka, a o Ahimeleka, a me na makua'lii o na kahuna a me ka Levi, oia hoi, na luna makuakane e ku pono ana i ko lakou poe kaikaina.
\c 25
\b
\q1 
\v 1 EIA hoi kekahi, hookaawale ae la o Davida a me na lunakaua i na keikikane a Asapa me ka Hemana a me ka Iedutuna, no ka oihana; na lakou e wanana mai me na lira, na pesaleteria, a me na kimebala: a eia ka poe lawehana e like me ka lakou hana ana;
\q1 
\v 2 No na keikikane a Asapa; o Zakura, o Iosepa, o Netania, a o Asarela, na keikikane a Asapa, malalo no o na lima o Asapa, nana i wanana mai, e like me ke kauoha a ke alii.
\q1 
\v 3 No Iedutuna: o na keikikane a Iedutuna; o Gedalia, o Zeri, o Iesaia, o Hasabia, a o Matitia, eono, malalo o na lima o ko lakou makuakane o Iedutuna, nana i wanana mai me ka lira, e hooaloha aku a e hoolea ia Iehova.
\q1 
\v 4 No Hemana: o na keikikane a Hemana; o Bukia, o Matania, o Uziela, o Sebuela, o Ierimota, o Hanania, o Hanani, o Eliata, o Gidaleti, o Romameti-ezera, o Iosebekasa, o Maloti, o Hotira a o Mahaziota.
\q1 
\v 5 O lakou nei a pau na keikikane a Hemana, a ke kaula o ke alii ma na mea o ke Akua, e hookiekie ae i ka pu. A haawi mai la ke Akua i na keikikane he umikumamaha, a me na kaikamahine ekolu na Hemana.
\q1 
\v 6 O keia poe a pau, malalo o na lima o ko lakou makuakane no ka mele iloko o ka hale o Iehova, me na kimebala, na pesaleteria, a me na lira, no ka oihana ma ka hale o ke Akua, e like me ke kauoha a ke alii ia Asapa, ia Iedutuna, a me Hemana.
\q1 
\v 7 A o ka huina o lakou a pau, me ko lakou poe hoahanau, i aoia i na mele no Iehova, o ka poe akamai a pau, he alua haneri me ke kanawalukumamawalu.
\b
\q1 
\v 8 A puu iho la lakou, o kekahi papa e ku pono ana i kekahi papa, o na mea nui a me na mea uuku, o ke kumu a me ka haumana.
\b
\q1 
\v 9 A puka mai la ka puu mua no Asapa ia Iosepa: o ka lua ia Gedalia, oia me na hoahanau ona a me na keikikane, he umikumamalua:
\q1 
\v 10 O ke kolu ia Zakura; o na keikikane ana a me kona mau hoahanau, he umikumamalua:
\q1 
\v 11 O ka ha ia Izeri; o na keikikane ana, a me kona mau hoahanau, he umikumamalua:
\q1 
\v 12 O ka lima ia Netania; o na keikikane ana, a me kona mau hoahanau, he umikumamalua:
\q1 
\v 13 O ke ono ia Bukia; o na keikikane ana, a me kona mau hoahanau, he umikumamalua:
\q1 
\v 14 O ka hiku ia Iesarela; o kana mau keikikane, a me na hoahanau ona, he umikumamalua:
\q1 
\v 15 O ka walu ia Iesaia; o kana mau keikikane, a me na hoahanau ona, he umikumamalua:
\q1 
\v 16 O ka iwa ia Matania; o kana mau keikikane, a me na hoahanau ona, he umikumamalua:
\q1 
\v 17 O ka umi ia Simei, o kana mau keikikane, a me na hoahanau ona, he umikumamalua:
\q1 
\v 18 O ka umikumamakahi ia Azareela; o kana mau keikikane a me na hoahanau ona, he umikumamalua:
\q1 
\v 19 O ka umikumamalua ia Hasabia; o kana mau keikikane, a me na hoahanau ona, he umikumamalua:
\q1 
\v 20 O ka umikumamakolu ia Subaela; o kana mau keikikane, a me na hoahanau ona, he umikumamalua:
\q1 
\v 21 O ka umikumamaha ia Matitia; o kana mau keikikane, a me na hoahanau ona, he umikumamalua:
\q1 
\v 22 O ka umikumamalima ia Ieremota; o kana mau keikikane a me na hoahanau ona, he umikumamalua:
\q1 
\v 23 O ka umikumamaono ia Hanania; o kana mau keikikane a me na hoahanau ona, he umikumamalua:
\q1 
\v 24 O ka umikumamahiku ia Iosebekasa; o kana mau keikikane, a me na hoahanau ona, he umikumamalua:
\q1 
\v 25 O ka umikumamawalu ia Hanani; o kana mau keikikane, a me kona mau hoahanau, he umikumamalua:
\q1 
\v 26 O ka umikumamaiwa ia Maloti; o kana mau keikikane, a me na hoahanau ona, he umikumamalua:
\q1 
\v 27 O ka iwakalua ia Eliata; o kana mau keikikane, a me na hoahanau ona, he umikumamalua:
\q1 
\v 28 O ka iwakaluakumamakahi ia Hotira; o kana mau keikikane a me na hoahanau ona, he umikumamalua:
\q1 
\v 29 O ka iwakaluakumamalua ia Gidaleti; o kana mau keikikane a me na hoahanau ona, he umikumamalua:
\q1 
\v 30 O ka iwakaluakumamakolu ia Mahaziota; o kana mau keikikane, a me na hoahanau ona, he umikumamalua:
\q1 
\v 31 O ka iwakaluakumamaha ia Romametiezera: o kana mau keikikane, a me na hoahanau ona, he umikumamalua.
\c 26
\b
\q1 
\v 1 NO na puu ana o na kiaipuka: o na Kora, o Meselemia he keikikane a Kore, no na keiki a Asapa.
\q1 
\v 2 A o na keikikane a Meselemia; o Zekaria ka makahiapo, o Iediaela ka lua, o Zebadia ke kolu, o Iateniela ka ha,
\q1 
\v 3 O Elama ka lima, o Iehohanana ke ono, o Elioenai ka hiku.
\q1 
\v 4 Eia hoi, o na keikikane a Obededoma: o Semaia ka makahiapo, o Iehozabada ka lua, o loa ke kolu, o Sakara ka ha, o Netaneela ka lima,
\q1 
\v 5 O Amiela ke ono, o Isakara ka hiku, a o Peuletai ka walu: no ka mea, hoopomaikai mai la ke Akua ia ia.
\q1 
\v 6 Na Semaia hoi, na kana keikikane, ua hanau na keiki; he mau luna lakou mawaena o ka ohana o ko lakou makuakane: no ka mea, he mau kanaka koa ikaika lakou.
\q1 
\v 7 O na keikikane a Semaia; o Oteni, o Repaela, o Obeda, o Elezabada; o na hoahanau o lakou, he mau kanaka ikaika, o Elihu, a o Semakia.
\q1 
\v 8 O keia poe a pau no na keiki a Obededoma: o lakou, o na keikikane a lakou, a me na hoahanau o lakou, na kanaka ikaika e hiki ai ka oihana, he kanaonokumamalua na Obededoma mai.
\q1 
\v 9 Na Meselemia hoi na keikikane a me na hoahanau, na kanaka ikaika, he umikumamawalu:
\q1 
\v 10 A o Hosa hoi, no na keikikane a Merari, nana mai na keikikane; o Simeri ke pookela, (no ka mea, aole hoi ia o ka hiapo, aka, hoonoho iho la kona makuakane ia ia i pookela;)
\q1 
\v 11 O Hilekia ka lua, o Tebalia ke kolu, o Zekaria ka ha; o na keikikane a pau a me na hoahanau o Hosa, he umikumamakolu.
\b
\q1 
\v 12 Ia lakou i na kanaka pookela, na papa kiaipuka, a he mau puu o lakou e ku pono ana kekahi i kekahi, e lawelawe iloko o ka hale o Iehova.
\b
\q1 
\v 13 A puu iho lakou no ka poe uuku a me ka poe nui, e like me ka ohana o ko lakou mau kupuna, no kela puka, a no keia puka.
\q1 
\v 14 A puka mai la ka puu hikina ia Selemia, Alaila puu iho la lakou no kana keiki no Zekaria, he kakaolelo naauao: a puka mai la ka puu kukulu akau nona.
\q1 
\v 15 Ia Obededoma ke kukuluhema: a i kana mau keikikane, ka hale ahu waiwai.
\q1 
\v 16 Ia Supima laua o Hosa ke komohana, a me ka puka Saleketa, ma ke alanuipapa o ka pii ana, he puu kiai maanei a he puu kiai ma o.
\q1 
\v 17 Ma ka hikina he mau Levi aono; ma ke kukuluakau, eha i ka la hookahi; ma ke kukuluhema, eha i ka la hookahi; a ma ka hale ahuwaiwai, elua a elua.
\q1 
\v 18 Ma Parebara ma ke komohana, eha ma ke alanuipapa, a elua ma Parebara.
\q1 
\v 19 Oia na puu kiaipuka iwaena o na mamo a Kore, a iwaena o na mamo a Merari.
\b
\q1 
\v 20 A no ka Levi, o Ahiia, maluna ia o na waihona waiwai o ka hale o ke Akua, a maluna o ke ahu o na mea laa.
\q1 
\v 21 No na keikikane a Laadana; o na keikikane a Laadana na Geresona, o na makua'lii a Laadana no Geresona; o Iehieli.
\q1 
\v 22 O na keikikane a Iehieli; o Zetama a o Ioela kona kaikaina, maluna laua o na waihona waiwai o ka hale o Iehova.
\q1 
\v 23 No ka Amerama, a no ka Izehara, a no ka Heberona, a no ka Uziela:
\q1 
\v 24 A o Sebuela ke keiki a Geresoma ke keiki a Mose, oia ka luna o na waihona waiwai.
\q1 
\v 25 A o kona poe hoahanau ma Eliezera; o Rehabia kana keiki, o Iesaia kana keiki, o Iorama kana keiki, o Zikeri kana keiki, a o Selomita kana keiki:
\q1 
\v 26 O ua Selomita la a me kona poe hoahanau, o lakou maluna o na ahu a pau o na mea laa, a ke alii a Davida me ka na makua'lii, na lunatausani, na lunahaneri, a mo na lunakaua i hoolaa ai.
\q1 
\v 27 No na waiwaipio i pio i na kaua, ka lakou i hoolaa ai, e kokua i ka hale o Iehova.
\q1 
\v 28 A o na mea a pau a Samuela ke kaula, laua o Saula ke keiki a Kisa, a me ka Abenera ke keiki a Nora, a me ka Ioaba ke keiki a Zeruia, i hoolaa ai: me ka kela mea keia mea i hoolaa ai, malalo ia o ka lima o Selomita, a o na hoahanau ona.
\b
\q1 
\v 29 No na Izehara; o Kenania me kana mau keikikane, no na oihana mawaho lakou maluna o ka Iseraela, no na ilamuku a me na lunakanawai.
\q1 
\v 30 No ka Heberona; o Hasabia me kona poe hoahanau, na kanaka koa, hookahi tausani a me na haneri ehiku, he poe luna lakou iwaena o ka Iseraela, ma keia aoao o ka Ioredane ma ke komohana, i na mea a pau a Iehova, a i ka hana a ke alii.
\q1 
\v 31 Iwaena o ka Heberona, o Ieriia ke pookela iwaena o ka Heberona, mamuli o na hanauna o kona poe kupuna. I ke kanaha o ka makahiki o ko Davida alii ana ua imi ia'ku ai lakou, a ua loaa na kanaka koa ikaika iwaena o lakou ma Iazera o Gileada.
\q1 
\v 32 A o kona poe hoahanau na kanaka koa, elua tausani me na haneri ehiku o na makua'lii, ka poe a Davida i hoonoho ai i poe luna o ka Reubena, ka Gada, a me ka ohana hapa a Manase, no na mea a pau a ke Akua, a me na mea a ke alii.
\c 27
\b
\q1 
\v 1 A O na mamo a Iseraela ma ko lakou heluia'na, o na makua 'lii, na lunatausani, na lunahaneri, a o ko lakou poe ilamuku i hookauwa na ke alii i kekahi mea o na papa, na poe i hele mai iloko a puka aku iwaho ma ka malama, i na malama a pau o ka makahiki; no kela papa keia papa a pau he iwakaluakumamaha tausani lakou.
\q1 
\v 2 Maluna o ka papa mua no ka malama mua, o Iasobeama ke keiki a Zabediela: a ma kona papa he iwakaluakumamaha tausani.
\q1 
\v 3 No na mamo a Pereza ka luna o na luna koa a pau o ko kaua, no ka malama mua.
\q1 
\v 4 Maluna o ka papa no ka lua o ka malama o Dodai ka Ahohi, a maluna hoi o kona papa o Mikelota kekahi luna: a ma kona papa hoi he iwakaluakumamaha tausani.
\q1 
\v 5 O ke kolu o ka lunakaua no ke kolu o ka malama o Benaia ke keiki a Iehoida, he kahuna nui; a ma kona papa he iwakaluakumamaha tausani.
\q1 
\v 6 O ua Benaia la ka mea ikaika iwaena o ka poe kanakolu, a ua oi maluna o ke kanakolu: a ma kona papa o Amizabada kana keiki.
\q1 
\v 7 O ka ha, no ka ha o ka malama, oia o Asahela ko kaikaina o Ioaba, a o Zebadia kana keiki mahope ona: a ma kona papa he iwakaluakumamaha tausani.
\q1 
\v 8 O ka luna alima no ka lima o ka malama, oia o Samuta ka Izera: a ma kona papa he iwakaluakumamaha tausani.
\q1 
\v 9 O ke ono, no ke ono o ka malama, oia o Ira ke keiki a Ikesa no Tekoa: a ma kona papa he iwakaluakumamaha tausani.
\q1 
\v 10 O ka hiku. no ka hiku o ka malama, oia o Heleza ka Pelo, no na mamo a Eperaima; a ma kona papa he iwakaluakumamaha tausani.
\q1 
\v 11 O ka walu, no ka walu o ka malama, oia o Sibekai ka Husata, no ka Zara: a ma kona papa he iwakaluakumamaha tausani.
\q1 
\v 12 O ka iwa, no ka iwa o ka malama, oia o Abiezera no Anetota o ka Beniamina: a ma kona papa he iwakaluakumamaha tausani.
\q1 
\v 13 O ka umi, no ka umi o ka malama, oia o Maharai no Netopata, no ka Zara: a ma kona papa he iwakaluakumamaha tausani.
\q1 
\v 14 O ka umikumamakahi, no ka umikumamakahi o ka malama, oia o Benaia no Piratona, no na mamo a Eperaima: a ma kona papa he iwakaluakumamaha tausani.
\q1 
\v 15 O ka umikumamalua, no ka umikumamalua o ka malama, oia o Heledai no Netopata, na Oteniela: a ma kona papa he iwakaluakumamaha tausani.
\b
\q1 
\v 16 Eia hoi kekahi, no na luna o na ohana a Iseraela: o ka luna o ka Reubena, oia o Eliezera ke keiki a Zikeri: o ka Simeona, o Sepatia ke keiki a Maaka.
\q1 
\v 17 O ka Levi, o Hasabia ke keiki a Kemuela: o ka Aarona, o Zadoka:
\q1 
\v 18 O ka Iuda, o Elihu no na kaikuaana o Davida: o ka Isakara, o Omeri ke keiki a Mikaela:
\q1 
\v 19 O ka Zebuluna, o Isemaia ke keiki a Obadia: o ka Napetali, o Ierimota ke keiki a Azeriela:
\q1 
\v 20 O na mamo a Eperaima, o Hosea ke keiki a Azazia: o ka ohana hapa a Manase, o Ioela ke keiki a Pedaia:
\q1 
\v 21 O ka ohana hapa a Manase i Gileada, o Ido ke keiki a Zekaria: o ka Beniamina, o Iasiela ke koiki a Abenera:
\q1 
\v 22 O ka Dana, o Azareela ke keiki a Ierohama. O lakou no na luna ohana o ka Iseraela.
\b
\q1 
\v 23 Aole no i helu o Davida ia lakou i ka poe o ka makahiki iwakalua a malalo iho: no ka mea, ua olelo mai o Iehova, e hoonui ana oia i ka Iseraela e like me na hoku o ka lani.
\q1 
\v 24 Hoomaka iho la o Ioaba ke keiki a Zeruia e helu, aka, aole ia i hoopau, no ka mea, nolaila i haule mai ai ka inaina i ka Iseraela: aole hoi i kakauia ka huina ma ka buke o ka mooolelo no Davida ke alii
\b
\q1 
\v 25 A maluna o ke ahuwaiwai o ke alii, o Azemaveta ke keiki a Adiela: a maluna o na halepapaa ma na mahinaai, ma na kulanakauhale, a ma na kauhale, a ma na pakaua, o Iehonatana ke keiki a Uzia.
\q1 
\v 26 A maluna o ka poe i hana i ka hana ma ka mahinaai, e mahiai i ka aina, o Ezeri ke keiki a Keluba.
\q1 
\v 27 A maluna o na pawaina o Simei no Ramata: maluna o ka hua o na pawaina no na haleahuwaina o Zabedi no Sipa.
\q1 
\v 28 Maluna noi o na laau oliva, a o na laau sukamora ma na awawa papu, o Baalahana no Gedera: a o Ioasa maluna o na haleahuaila.
\q1 
\v 29 A maluna o na pua bipi i hanaiia ma Sarona, o Siterai no Sarona: a maluna o na pua bipi ma na awawa, o Sapata ke keiki a Adelai:
\q1 
\v 30 Maluna hoi o na kamelo, o Obila ka Isemaela: a maluna o na hoki o Iedeia no Meronota:
\q1 
\v 31 Maluna hoi o na ohana hipa, o Iaziza ka Hagara. O lakou a pau na luna o ka waiwai o Davida ke alii.
\b
\q1 
\v 32 A o Ionatana hoi kekahi makuakane o Davida, he kuhina oia, he kanaka naauao, a he kakaaolelo: a o Iehiela ke keiki a Hakemoni, aia no ia me na keikikane a ke alii.
\q1 
\v 33 A o Ahitopela ke kakaolelo o ke alii: a o Husai no Areka ka hoapili o ke alii.
\q1 
\v 34 A mahope o Ahitopela o Iehoiada ke keiki a Benaia, a me Abiatara: a o Ioaba ka lunakoa o ko ke alii poe kaua.
\c 28
\b
\q1 
\v 1 HOULUULU ae la o Davida i na luna a pau o ka Iseraela, i na luna ohana, a me na luna o na poe i hookauwa na ke alii ma na papa, me na lunatausani, me na lunahaneri, me na luna o na holoholona a me na waiwai a pau o ke alii, me kana mau keikikane, me na ilamuku, me na kanaka koikoi, a me na kanaka koa a pau, i Ierusalema.
\q1 
\v 2 Alaila ku ae la o Davida ke alii ma kona wawae, olelo mai la, E hoolohe mai, e na hoahanau o'u, a me o'u kanaka: iloko no o kuu naau ka hana i hale hoomaha no ka pahu berita o Iehova, a no ka paepae wawae o ko kakou Akua, a ua hoomakaukau no wau no ka hana ana.
\q1 
\v 3 Aka, olelo mai la ke Akua ia'u, Mai hana oe i hale no ko'u, inoa, no ka mea, he kanaka kaua oe, a ua hookahe oe i na koko.
\q1 
\v 4 Aka hoi, i koho mai o Iehova ke Akua o ka Iseraela ia'u imua o ka ohana a pau a ko'u makuakane i alii mau maluna o ka Iseraela: no ka mea, i koho mai oia i ka Iuda i alii; a i ka ohana a ko'u makuakane no ka ohana a Iuda; a iwaena o na keiki a kuu makuakane, i makemake oia ia'u e hoolilo i alii maluna o ka Iseraela a pau:
\q1 
\v 5 A na keikikane a'u a pau, (no ka mea, ua haawi mai ke Akua ia'u i na keikikane he nui,) ua wae mai oia i kuu keiki ia Solomona e noho ia maluna o ka nohoalii o ke aupuni o Iehova, maluna o ka Iseraela.
\q1 
\v 6 I mai la oia ia'u, O Solomona kau keiki, oia no ka mea nana e hana ko'u hale a me ko'u mau pahale: no ka mea, ua wae au ia ia i keiki na'u, a owau auanei kona makua.
\q1 
\v 7 Eia hoi, e hookupaa auanei au i kona aupuni a mau loa aku: ina e ikaika oia ke hana i ka'u mau kauoha, a me ko'u mau kanawai, e like me ia i keia la.
\q1 
\v 8 Ano hoi, imua o na maka o ka Iseraela a pau, o ke anainakanaka o Iehova, imua hoi o na pepeiao o ko kakou Akua, e malama oukou me ka imi aku i na kauoha a pau a Iehova a ko oukou Akua: i noho ai oukou ma keia aina maikai, a e waiho hoi ia i hooilina no na keiki mahope o oukou a mau loa aku.
\b
\q1 
\v 9 O oe hoi, e Solomona kuu keiki, e ike oe i ke Akua o na kupuna ou, a e malama ia ia me ka naau pono, a me ka manao makemake: no ka mea, ke nana mai nei o Iehova i na naau a pau, a ke ike nei i na ano a pau o na manao: ina oe e imi aku ia ia, e loaa auanei oia ia oe: aka, i haalele oe ia ia, e kiola aku oia ia oe a mau loa aku.
\q1 
\v 10 E malama oe ano: no ka mea, ua wae mai o Iehova ia oe e hana i hale no ke keenakapu; e hooikaika oe, a e hana.
\b
\q1 
\v 11 Alaila haawi mai la o Davida ia Solomona kana keiki, i ke kumu no ka lanai, a no na hale olaila, a no na waihonawaiwai olaila, a no na keena luna olaila, a no na keena waena, a no kahi o ka noho aloha,
\q1 
\v 12 A me ke kumu no na mea a pau ia ia na ka Uhane mai, no na pahale o ka hale o Iehova, a no na keena a pau e puni ana, no na waihonawaiwai o ka hale o ke Akua, a no na hale ahu i ka waiwai i hoolaaia:
\q1 
\v 13 A no na papa hoi o na kahuna, a o na Levi, a no ka hana ana a pau i ka oihana o ka hale o Iehova, a no na ipu o ka oihana iloko o ka hale o Iehova.
\q1 
\v 14 A haawi mai la ia i gula i kaupaonaia i mea gula, no na mea hana i na oihana a pau: a o na mea kala a pau ma ke kaupaona ana, no na mea hana i na oihana a pau:
\q1 
\v 15 I ka mea i kaupaonaia no na waihona kukui gula, a me na ipukukui gula o lakou; ma ke kaupaona no na waihonakukui a pau, a no na ipukukui o lakou: a no na waihona kukui kala ma ke kaupaona: no ka waihona kukui, a no na ipukukui ona, e like me ke ano o kela a me keia waihonakukui.
\q1 
\v 16 A i ke gula ma ke kaupaona ana no ka papa berena hoike, no kela papa a no keia papa: a he kala no na papa kala:
\q1 
\v 17 A i ke gula maoli no na lou manamana, no na bola a no na kiaha: a no na pa gula haawi mai la ia i ke gula i kaupaonaia no kela pa a keia pa: a me ke kala i kaupaonaia no kela pa kala a keia pa kala:
\q1 
\v 18 A no ke kuahu kuni mea ala i ke gula maemae ma ke kaupaona: a he gula no ke kumu o ke kaa o I na keruba, i hohola ae a uhi iho i ka pahu berita o Iehova.
\q1 
\v 19 O keia a pau ka Iehova i hoomaopopo mai ai ia'u i ke kakau ana, ma kona lima maluna iho o'u, o na hana a pau o keia kumu.
\b
\q1 
\v 20 Olelo mai la o Davida ia Solomona kana keiki, E ikaika oe, a e koa hoi, a e hana: mai makau oe, aole hoi e pauaho; no ka mea, me oe pu no o Iehova ke Akua, o ko'u Akua: aole oia e hoohoka mai, aole hoi o haalele mai ia oe, a paa ia oe ka hana a pau no ka oihana o ka hale o Iehova.
\q1 
\v 21 Eia hoi o na papa o ka poe kahuna a me na Levi, [o lakou me oe] no na oihana a pau o ka hale o ke Akua: a me oe no na kanaka makemake makaukau a pau no na hana a pau, no kela hana keia hana a pau: a ma kau kauoha wale no hoi na luna a me na kanaka a pau.
\c 29
\b
\q1 
\v 1 OLELO mai la hoi o Davida ke alii i ke anainakanaka a pau, O kuu keiki, o Solomona, ka mea a ke Akua i wae mai ai, he opiopio ia, he palupalu, a he nui ka hana: no ka mea, aole no ke kanaka ka halealii, no Iehova ke Akua no.
\q1 
\v 2 Ua hoomakaukau iho no wau me kuu ikaika a pau no ka hale o kuu Akua i ke gula no na mea gula, i ke kala no ua mea kala, i ke keleawe no na mea keleawe, i ka hao no na mea hao, a i ka laau no na mea laau: i na pohaku onika e kauia'i, na pohaku hinuhinu, a he onionio hoi, a me na pohaku makamae he nui na ano, a me na pohaku mamora he nui loa.
\q1 
\v 3 A no ka mea, ua kau aku no wau i ke aloha o'u ma ka hale o ko'u Akua, ua haawi aku no wau i ke gula a me ke kala o kuu waiwai ponoi, no ka hale o ko'u Akua, he pakela aku ia i na mea a pau a'u i hoomakaukau ai no ka hale hoano;
\q1 
\v 4 Ekolu no tausani talena gula, no ke gula o Opira, a me na tausani talena kala maemae ehiku, i mea e hoouhi ia i na paia o na hale:
\q1 
\v 5 O ke gula no na mea gula, a o ke kala no na mea kala, a no na hana a pau ma na lima o na paahaua. Owai hoi ka mea makemake e hoopiha i kona lima no Iehova i keia la?
\b
\q1 
\v 6 Alaila, mohai oluolu aku la na makua'lii a me na luna ohana o ka Iseraela, me na lunatausani a me na lunahaneri, a me na luna o ka hana a ke alii.
\q1 
\v 7 A haawi aku la lakou no ka oihana o ka hale o ke Akua, i elima tausani talena gula, a me na derama he umi tausani, a me na talena kala he umi tausani, a me na talena keleawe he umikumamawalu tausani, a me na talena hao hookahi haneri tausani.
\q1 
\v 8 A o ka poe i loaa na pohaku [makamae] ia lakou, haawi oluolu aku lakou no ka waihona waiwai o Iehova, ma ka lima o Iehiela ka Geresona.
\q1 
\v 9 Alaila, olioli ae la na kanaka, no ka mea, haawi oluolu aku la lakou; a me ka naau pono lakou i haawi oluolu aku ai no Iehova: a olioli iho la hoi o Davida ke alii me ka olioli nui.
\b
\q1 
\v 10 Nolaila, hoomaikai aku la o Davida ia Iehova imua o ke anaina kanaka a pau: olelo aku la o Davida, E hoomaikaiia oe, e Iehova ke Akua o ka Iseraela, o ko makou makua, a mau loa, a mau loa aku.
\q1 
\v 11 Nou no, e Iehova, ka nui, me ka mana, a me ka nani, a me ka oiaio, a me ka hanohano alii: no ka mea, nou na mea a pau ma ka lani a ma ka honua: nou no ke aupuni, e Iehova, a ua kiekie ae oe ka pookela maluna o na mea a pau.
\q1 
\v 12 Nou mai ka waiwai a me ka maikai, a e alii ana oe maluna o na mea a pau: a maloko o kou lima ka mana a me ka ikaika: a iloko hoi o kou lima ka mea e nui ai a e ikaika ai na kanaka a pau.
\q1 
\v 13 Nolaila hoi, e ko makou Akua, ke aloha aku nei makou ia oe, me ka hoomaikai i kou inoa nani.
\q1 
\v 14 Owai hoi wau, owai hoi ko'u poe kanaka, i hiki ai ia makou ke haawi oluolu aku me keia? No ka mea, nou mai na mea a pau, a o kau ka makou i haawi aku ai ia oe.
\q1 
\v 15 No ka mea, he poe makou no ka aina e imua ou, e noho malihini ana, e like me ko makou poe kupuna a pau; me he aka la ko makou mau la maluna o ka honua, aole no he manaolana.
\q1 
\v 16 E Iehova ko makou Akua, o keia ahu waiwai a pau a makou i hoomakaukau ai e hana i hale no kou inoa hoano, na kou lima mai no ia, a nou wale no ia a pau.
\q1 
\v 17 Ua ike no hoi au, e ko'u Akua, ke hoao mai nei oe i ka naau, a ua oluolu mai i ka pono. A owau nei la, ma ka manao pono o kuu naau ua haawi oluolu aku wau i neia mau mea a pau: a ua ike iho nei hoi au me ka olioli i kou poe kanaka maanei, e haawi oluolu aku ana nou.
\q1 
\v 18 E Iehova, ke Akua o Aberahama, o Isaaka, a o Iseraela, o ko makou poe kupuna, e hoopaa mau loa mai oe i keia iloko o na manao o ka naau o kou poe kanaka, a e hookupaa i ko lakou naau nou.
\q1 
\v 19 A e haawi mai oe i kuu keiki ia Solomona i naau pono, e malama ai i kau mau kauoha, i kau mau olelo, a me kou mau kanawai, a e hana ia mau mea a pau, a e hana hoi ia i ka halealii a'u i hoomakaukau ai.
\b
\q1 
\v 20 Olelo mai la o Davida i ke anainakanaka a pau, Ano, e hoomaikai oukou ia Iehova i ko oukou Akua. A hoomaikai aku la ke anainakanaka a pau ia Iehova i ke Akua o ko lakou poe kupuna, a kulou iho la i ko lakou mau poo, a kulou loa imua o Iehova, a me ke alii.
\q1 
\v 21 A mohai aku la lakou i na mohai na Iehova, a kaumaha aku la i na mohaikuni na Iehova, i ka la mahope mai o ia la, i hookahi tausani bipikane, hookahi tausani hipakane, hookahi tausani hipakeiki, me na mohai inu a lakou, a me na mohai aloha he nui loa no ka Iseraela a pau.
\q1 
\v 22 Ai iho la a inu hoi lakou imua o Iehova ia la me ka olioli nui. A hoalii hou aku la lakou ia Solomona i ke keiki a Davida, a poni iho la ia ia no Iehova, i alii nui, a ia Zadoka hoi i kahuna nui.
\q1 
\v 23 Alaila, noho iho la o Solomona maluna o ka nohoalii o Iehova, i alii ma kahi o Davida o kona makuakane, a he pomaikai kona: a hoolohe mai la ka Iseraela a pau ia ia.
\q1 
\v 24 A o na alii a pau a me na kanaka koikoi, a o na keikikane hoi a pau a Davida ke alii, kau iho ia lakou i ko lakou lima malalo o Solomona ke alii.
\q1 
\v 25 Hoonui iho la o Iehova ia Solomona a nui loa imua o na maka o ka Iseraela a pau, a haawi mai la ia ia i ka hanohano alii, aole i haawiia mai ka mea like maluna o kekahi alii iloko o ka Iseraela mamua ona.
\b
\q1 
\v 26 Pela o Davida ke keiki a Iese i alii ai maluna o ka Iseraela a pau.
\q1 
\v 27 A o ka manawa ana i alii ai maluna o ka Iseraela, he kanaha na makahiki: ehiku makahiki ana i alii ai ma Heberona, a he kanakolukumamakolu ana i alii ai ma Ierusalema.
\q1 
\v 28 A make iho la oia i ka wa elemakule loa, a he nui na la, na waiwai, a me ka maikai ona; a alii iho la o Solomona ma kona wahi.
\q1 
\v 29 A o na hana a Davida ke alii, na hana mua a me na hana hope, ua kakauia lakou iloko o ka mooolelo a Samuela ke kaula, a iloko o ka mooolelo a Natana ke kaula, a iloko o ka mooolelo a Gada ke kaula;
\q1 
\v 30 Me kona alii ana a pau a me kona ikaika, a me na manawa i hiki mai ia ia, a i ka Iseraela, a i na aupuni a pau o na aina. 
