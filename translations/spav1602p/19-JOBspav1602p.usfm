\v 11 \w Y|strong="H3068"\w* vinieron \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w todos|strong="H3605"\w* sus her­manos, \w y|strong="H5921"\w* \w todas|strong="H3605"\w* sus hermanas, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w antes|strong="H6440"\w* \w le|strong="H5921"\w* habían \w conocido|strong="H3045"\w*, \w y|strong="H5921"\w* comieron \w con|strong="H5973"\w* \w él|strong="H5921"\w* \w pan|strong="H3899"\w* \w en|strong="H5921"\w* su \w casa|strong="H1004"\w*, \w y|strong="H5921"\w* condoliéronse \w de|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* consoláronle \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w aquel|strong="H3605"\w* \w mal|strong="H7451"\w* \w que|strong="H5921"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* había \w el|strong="H5921"\w* \w SEÑOR|strong="H3068"\w* tra­ído; \w y|strong="H5921"\w* \w cada|strong="H3605"\w* uno \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w le|strong="H5921"\w* \w dio|strong="H5414"\w* una pieza \w de|strong="H5921"\w* moneda, \w y|strong="H5921"\w* un zarci­llo \w de|strong="H5921"\w* \w oro|strong="H2091"\w*.
\m 
\v 12 \w Y|strong="H3068"\w* \w bendijo|strong="H1288"\w* el \w SEÑOR|strong="H3068"\w* la pos­trimería de Job más \w que|strong="H1961"\w* su prin­cipio; porque \w tuvo|strong="H1961"\w* catorce mil \w ovejas|strong="H6629"\w*, \w y|strong="H1241"\w* \w seis|strong="H8337"\w* mil \w camellos|strong="H1581"\w*, \w y|strong="H1241"\w* mil \w yuntas|strong="H6776"\w* de \w bueyes|strong="H1241"\w*, \w y|strong="H1241"\w* mil asnas.
\m 
\v 13 \w Y|strong="H3068"\w* \w tuvo|strong="H1961"\w* siete \w hijos|strong="H1121"\w* y \w tres|strong="H7969"\w* \w hijas|strong="H1323"\w*.
\m 
\v 14 \w Y|strong="H3068"\w* \w llamó|strong="H7121"\w* el \w nombre|strong="H8034"\w* de la una, \w Jemimah|strong="H3224"\w*, y el \w nombre|strong="H8034"\w* de la \w segunda|strong="H8145"\w*, \w Cesiah|strong="H7103"\w*, y el \w nombre|strong="H8034"\w* de la \w tercera|strong="H7992"\w*, Keren-hapuc.
\m 
\v 15 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w hallaron|strong="H4672"\w* \w mujeres|strong="H1323"\w* tan \w hermosas|strong="H3303"\w* como \w las|strong="H1992"\w* \w hijas|strong="H1323"\w* \w de|strong="H5414"\w* Job \w en|strong="H8432"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra: y \w dióles|strong="H5414"\w* \w su|strong="H1992"\w* padre \w herencia|strong="H5159"\w* \w entre|strong="H8432"\w* \w sus|strong="H1992"\w* hermanos.
