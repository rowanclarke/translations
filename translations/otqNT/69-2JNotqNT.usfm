\id 2JN
\h ÁR ÑOHO AR XUWA
\toc1 ÁR ÑOHO AR XUWA Ár ñoho ar he̱ꞌmi bi ꞌyotꞌa ar Xuwa
\toc2 ÁR ÑOHO AR XUWA
\toc3 2 Jn.
\mt1 ÁR ÑOHO AR XUWA
\mt2 Ár ñoho ar he̱ꞌmi bi ꞌyotꞌa ar Xuwa
\c 1
\s1 Ar nze̱ngwa
\p 
\v 1 Nuga dar Xuwa ar dönzia, di pe̱ñꞌa nunar he̱ꞌminu̱ tsi ꞌbe̱hñö xi hwañꞌa Jö, ne nuya ri bötsi. Xa di möꞌahu̱ ngetho gi te̱ñhu̱ nöꞌö majöni, hinge ho̱nse̱ga, gatho nu maꞌra xi bö nöꞌö majöni nꞌehe.
\p 
\v 2 Di njahepꞌu̱ ngetho di pe̱ꞌsu̱ ha ma mu̱ihu̱ nöꞌö majöni, ne hinda ma da hye̱ju̱.
\p 
\v 3 Jö ar Dada ne ar tsi Hmu Hesukristo ár Tꞌu̱, da ko yá mu̱i da hwëkꞌahu̱ yá ñho ne ar hogamꞌu̱i, ngetho gi jamfihu̱ nöꞌö majöni ne gi pe̱ꞌsu̱ ar mhöte.
\s1 Yo ma gi ꞌwehu̱ gi hye̱hu̱ ár ntꞌuti ar tsi Hmu Hesukristo
\p 
\v 4 Xa xta njohya ngetho xta tinga ꞌra ri bötsi te̱nga nöꞌö majöni, ngu xi zogagihu̱ Jö ar Dada ga o̱thu̱.
\p 
\v 5 Ha nupya di a̱ꞌa ar möte, tsi ꞌbe̱hñö gi nku. Hinge ngu ga ꞌraꞌa nꞌar ꞌraꞌyo ꞌbe̱pate. Di bempꞌatho nöꞌö ndi pe̱ꞌsu̱ mahamꞌu̱, ga nmhöhu̱ nꞌa ngu nꞌa.
\p 
\v 6 Ne go gehnu̱ ar mhöte majöni, ga o̱thu̱ nöꞌö xi ꞌbe̱pkagihu̱ꞌö. Ne njanu̱ xi ꞌbe̱pkagihu̱, ga nmhöhu̱ nꞌa ngu nꞌa, ngu xka ꞌyo̱hu̱ mahamꞌu̱.
\p 
\v 7 Ngetho nze̱ye̱ ya hya̱te xi nxanga har ximha̱i, ko̱ni ar Hesukristo ba e bi njöꞌi. Nöꞌö togo o̱tꞌa njapꞌu̱, ar hya̱te ne ár ñꞌu̱ni ar Hesukristo.
\p 
\v 8 Nsuse̱hu̱ hinto da hya̱ꞌahu̱ ne hinda mꞌe̱ ri ꞌbe̱fihu̱ xka pe̱hu̱, ne gi hñöñhu̱ xo̱ge ri nthöhöhu̱ da ꞌraꞌahu̱ Jö.
\p 
\v 9 Nöꞌö togo da ꞌwege ne hinda ne da de̱mba ár ntꞌuti ar tsi Hmu Hesukristo, hingi pe̱ꞌsa Jö hár mu̱i. Ha nöꞌö togo te̱mba ár ntꞌuti, nöꞌö hö, pe̱ꞌsa ar Dada ne ár Tꞌu̱.
\p 
\v 10 Nuꞌmu̱ da zo̱ñꞌahu̱ nꞌar jöꞌi, ne hingi xiꞌahu̱ nunar ntꞌuti xi zogagihu̱ ar tsi Hmu Hesukristo, yo gi umfu̱ nse̱ki ha ri nguhu̱, ne hingi umfu̱ ar tsa̱ya̱.
\p 
\v 11 Ngetho nöꞌö togo da ꞌñemba nuya jöꞌiyu̱ da thogi da tsa̱ya̱, mfa̱xkwi da ꞌyo̱tꞌa yá tsꞌoꞌbe̱fiyu̱.
\s1 Di beni ma ga tso̱ñꞌahu̱
\p 
\v 12 Mödi xa di pe̱ꞌsa nze̱ye̱ te ga xiꞌahu̱, hindi ne ga pe̱ñꞌahu̱ ha nꞌar he̱ꞌmi xi tꞌotꞌi. Di beni ma ga tso̱ñꞌahu̱ ne ga ñhanthu̱ ga ñöwihu̱, ne xa ga njohyahu̱.
\p 
\v 13 Nuyá bötsi ri juhwe̱ xi hwahna Jö nꞌehe, ze̱ngwaꞌi. Dá njapꞌu̱.
