\c 120  
\s1 Kulanda utanzi 
\d (Lwimbo lwa kuluta kuchanya.) 
\q1  
\v 1 Kuli magazo ga heni nandimchema Mkulu Nguluwi, 
\q1 naye nakanyhidichila. 
\q1  
\v 2 Gwa Mkulu Nguluwi, undohole 
\q1 kulawa kwa wanhu wadesi na wahadi. 
\b  
\q1  
\v 3 Hemwe wanhu wahadi, mopegwa choni? 
\q1 Mozapigwa ndaze? 
\q1  
\v 4 Kowagaza kwa misale jing'ang'ale ja mwamizi, 
\q1 na kwa makala ga chiluli ching'ang'ale. 
\b  
\q1  
\v 5 Ndochona kwa vila ndangikala kota mjenzi aku Mesheki, 
\q1 ama kuli mihema ja Kedali. 
\q1  
\v 6 Nandikala kwa mihela minji ng'hatu 
\q1 hali wanhu walinguzudila kikala goya. 
\q1  
\v 7 Heni nda munhu wa kikala goya, 
\q1 ila hondilonga ahyo, hewo wangugana ngondo. 
\c 121  
\s1 Nguluwi kangutwamila 
\d (Lwimbo lwa kuluta kuchanya.) 
\q1  
\v 1 Ndangulola kuchanya kuli vidunda, 
\q1 utanzi wa heni wolawa kohi? 
\q1  
\v 2 Utanzi wa heni wangulawa kwa Mkulu Nguluwi, 
\q1 yalumbile ulanga na isi. 
\b  
\q1  
\v 3 Hokuleka ugwe, 
\q1 mwamizi wa hegwe hambe yasinzile. 
\q1  
\v 4 Ena, mwamizi wa Isilaeli, 
\q1 hambe yasinzile ne kuwasa. 
\q1  
\v 5 Mkulu Nguluwi ndo mwamizi wa hegwe, 
\q1 ka ubanzi wa hegwe wa kudilo kota lubehelo kukwamila. 
\q1  
\v 6 Nemisi isanya haliweza kukulumiza, 
\q1 ne nyelezi mhela wa nechilo. 
\b  
\q1  
\v 7 Mkulu Nguluwi kokwamila na lihile lyoneche, 
\q1 kowamila goya ukomu wa hegwe. 
\q1  
\v 8 Mkulu Nguluwi kokwamila kuli mbuli za hegwe za chila zuwa, 
\q1 kulawa sambi mbaka mazuwa gose. 
\c 122  
\s1 Lutogo ako Yelusalemu 
\d (Lwimbo lwa kuluta kuchanya. Lwimbo lwa Daudi.) 
\q1  
\v 1 Nasangalala vyowandonjele, 
\q1 “Tulute kaye kwa Mkulu Nguluwi.” 
\q1  
\v 2 Lelo twa hano natwima, 
\q1 mgati mwa lwizi lwa hegwe, gwa Yelusalemu. 
\b  
\q1  
\v 3 Yelusalemu, muji uzenjigwe, 
\q1 leka wanhu weting'hane amo. 
\q1  
\v 4 Amo ndo nhanzi zilinguluta, 
\q1 ena, nhanzi za Mkulu Nguluwi, 
\q1 kulonga malumbo kwa Mkulu Nguluwi kota vyoyalajize. 
\q1  
\v 5 Amo namuwichigwa chitala cha utaguso wa hachi, 
\q1 chitala cha lukolo lwa chiundewa lwa Daudi. 
\b  
\q1  
\v 6 Muulandile kikala goya muji wa Yelusalemu. 
\q1 “Weng'ha walinguugana, mbuli za hewo zilutilile goya. 
\q1  
\v 7 Mgati mwa ng'hanzi za hegwe kuwe na kikala goya, 
\q1 na ngome ya hegwe iwe goya.” 
\q1  
\v 8 Kwa chiwalo cha wanhu wa heni na wang'holozangu, 
\q1 ndangulonga, “Gwa Yelusalemu, ndangukuganila kikala goya. 
\q1  
\v 9 Kwa chiwalo cha ng'handa ya Mkulu Nguluwi, Nguluwi wa hetwe, 
\q1 ndangukulandila ganojile.” 
\c 123  
\s1 Kulanda isungu 
\d (Lwimbo lwa kuluta kuchanya.) 
\q1  
\v 1 Ndangwinula meho ga heni kwa hegwe, 
\q1 ndangukulola hegwe ulingulongoza ako kuchanya kilanga. 
\q1  
\v 2 Kota vitumagwa vyowalingumlola mkulu wa hewo, 
\q1 kota mpogozi vyoyalingitumbila kwa mkulu wa heye, 
\q1 ndo natwe vyotulingitumbila kwa hegwe, 
\q1 gwa Mkulu Nguluwi, Nguluwi wa hetwe, 
\q1 mbaka aho houtonela isungu. 
\b  
\q1  
\v 3 Utonele isungu, gwa Mkulu Nguluwi, utonele isungu, 
\q1 kwa vila natubezigwa lukami. 
\q1  
\v 4 Natiguta kwa mhela winji kubezigwa kwa wawele na lufufu, 
\q1 walingidaya wangutona kota natubezigwa. 
\c 124  
\s1 Mkulu Nguluwi ka ubanzi wa hetwe 
\d (Lwimbo lwa kuluta kuchanya. Lwimbo lwa Daudi.) 
\q1  
\v 1 “Wone Mkulu Nguluwi yahawele haduhu ubanzi wa hetwe.” 
\q1 Mlonje mweng'ha muwele kuli Isilaeli. 
\b  
\q1  
\v 2 “Wone Mkulu Nguluwi yahawele haduhu ubanzi wa hetwe, 
\q1 mhela wula lotutowigwe na wang'honyo, 
\q1  
\v 3 ndangukomya twahawele tumeligwe tung'hali wakomu, 
\q1 mhela ng'halazi ya hewo loitufichile. 
\q1  
\v 4 Twahaholigwe na mazi tendema, 
\q1 twahatowigwe kota mazi ga lwanda, 
\q1  
\v 5 mazi galinguluta himahima gahatuholile.” 
\b  
\q1  
\v 6 Yatogoligwe Mkulu Nguluwi, 
\q1 yawele hatulechile kuli ndole za hewo. 
\q1  
\v 7 Natusulupuka kota chideje kuli idiwa, 
\q1 idiwa nalibenigwa, natwe natuloholigwa. 
\q1  
\v 8 Utanzi wa hetwe wangulawa kwa Mkulu Nguluwi, 
\q1 yalumbile ulanga na isi. 
\c 125  
\s1 Mkulu Nguluwi kanguwazunguluta wanhu wa heye 
\d (Lwimbo lwa kuluta kuchanya.) 
\q1  
\v 1 Walingitumbila kwa Mkulu Nguluwi, wa kota chidunda cha Siyoni, 
\q1 chiwele hambe chitigasiche ila changupona chiwele nzinzili mazuwa gose. 
\q1  
\v 2 Kota Yelusalemu vyoilinguzungulutwa na vidunda, 
\q1 ndo Mkulu Nguluwi vyoyalinguwazunguluta wanhu wa heye, 
\q1 kulawa sambi na mazuwa gose. 
\b  
\q1  
\v 3 Wehile hawolutilila kuilongoza isi ya watanganiche, 
\q1 leka watanganiche waleche kudita gehile kota wala. 
\q1  
\v 4 Gwa Mkulu Nguluwi, uwe unojile kwa wanhu wanojile, 
\q1 kwa wala wagoloche nhumbula. 
\q1  
\v 5 Ila walingugalamka na kuwinza nzila za hewo zihile, 
\q1 Mkulu Nguluwi uwose hamwe na walingudita gehile. 
\b  
\q1 Kikala goya kuwe na Isilaeli. 
\c 126  
\s1 Mkulu Nguluwi utuwiche goya kahi 
\d (Lwimbo lwa kuluta kuchanya.) 
\q1  
\v 1 Mkulu Nguluwi loyatuwichile goya na kutuhilula Siyoni, 
\q1 natwali kota wanhu walingulota. 
\q1  
\v 2 Ahyo natwaluka kuseka, 
\q1 natutowa luchenze kwa usangalalo. 
\q1 Wanhu wa isi zinji nawalonga, 
\q1 “Mkulu Nguluwi nakawaditila mbuli ng'hulu.” 
\q1  
\v 3 Ena, Mkulu Nguluwi nakatuditila mbuli ng'hulu, 
\q1 natusangalala lukami. 
\b  
\q1  
\v 4 Gwa Mkulu Nguluwi, utuwiche goya kahi, 
\q1 kota nhonya vyoilingigala mazi kugunuche. 
\q1  
\v 5 Walingunyala kwa mahozi, 
\q1 wobeta kwa usangalalo. 
\b  
\q1  
\v 6 Walinguluta kunyala nyhadikwa kuno wolila, 
\q1 wohiluka kwa usangalalo wawele na mbena. 
\c 127  
\s1 Ne kuwa na Nguluwi, mijito ja hetwe hajiwele chinhu 
\d (Lwimbo lwa kuluta kuchanya. Lwimbo lwa Solomoni.) 
\q1  
\v 1 Mkulu Nguluwi wone hazenjile ng'handa, 
\q1 walinguzenga wangitunya hela. 
\q1 Wone Mkulu Nguluwi howamila muji, 
\q1 walingwamila wanguwa meho kwa kitunya hela. 
\q1  
\v 2 Mwangitunya hela kulilimka lufuku ng'hatu, 
\q1 na kukawila kuluta kwesela matinazo, 
\q1 mipalile chilyo kwa chituguti cha hemwe. 
\q1 Nguluwi kanguwapaga chilyo wala yalinguwagana, hanga howowasa. 
\b  
\q1  
\v 3 Wana ndo utambichizo kulawa kwa Mkulu Nguluwi, 
\q1 wana ndo ndolendole kulawa kwa heye. 
\q1  
\v 4 Wana wapondigwe kuno wahaza wa hewo wang'hali wawele na mong'ho, 
\q1 woweza kuwatanza wahaza wa hewo howowa walalile. 
\q1  
\v 5 Ahyo, nakatambichizwa munhu yawele na wana wenji. 
\q1 Holemwela hoyowa habehi na mng'honyo hali chitala. 
\c 128  
\s1 Chonolo kwa munhu yalingumdumba Nguluwi 
\d (Lwimbo lwa kuluta kuchanya.) 
\q1  
\v 1 Nawatambichizwa weng'ha walingumdumba Mkulu Nguluwi, 
\q1 walingikala kwa kuwinza nzila za heye. 
\b  
\q1  
\v 2 Kowa na mafuza ga chituguti cha hegwe, 
\q1 kosangalala na mbuli za hegwe zolutilila goya. 
\q1  
\v 3 Mchewako kowa kota mzabibu wa mafuza menji kaye kwa hegwe, 
\q1 wana wa hegwe kota mizuchila ja mizeituni kuzunguluta chisaga cha hegwe. 
\q1  
\v 4 Ena, ndo vyoyotambichizwa, 
\q1 munhu yalingumdumba Mkulu Nguluwi. 
\b  
\q1  
\v 5 Mkulu Nguluwi yakutambichize kulawa Siyoni. 
\q1 Uzone mbuli za Yelusalemu zilutilila goya mazuwa gose ga ukomu wa hegwe. 
\q1  
\v 6 Wikale mbaka uwone wazukulu wa hegwe. 
\b  
\q1 Kikala goya kuwe na Isilaeli. 
\c 129  
\s1 Kulanda kulinguwala wang'honyo wa Isilaeli 
\d (Lwimbo lwa kuluta kuchanya.) 
\q1  
\v 1 “Nawangaza ng'hatu kulawa kuli usongolo wa heni.” 
\q1 Chila munhu kuli Isilaeli yalonje, 
\q1  
\v 2 “Nawangaza ng'hatu kulawa kuli usongolo wa heni, 
\q1 ila hawawezile kusumya heni. 
\q1  
\v 3 Nawanhowa ng'hatu kumgongo kwa heni, 
\q1 kumgongo kwangu nakuwa kota misitali ja kumgunda. 
\q1  
\v 4 Ila Mkulu Nguluwi ndo katanganika, 
\q1 nakandohola kulawa kuli ng'weso za wanhu wehile.” 
\b  
\q1  
\v 5 Wabasigwe soni na kuhiluswa kumbele, 
\q1 wala weng'ha walinguuzudila muji wa Siyoni. 
\q1  
\v 6 Wawe kota misolo jilihela mizabi milefu, 
\q1 jiwele janguswinhaga lojiwa jing'hali kukula, 
\q1  
\v 7 kuduhu munhu yalingukola mijito ja kujikungajiza, 
\q1 ne kuhola kota nyinza. 
\q1  
\v 8 Haduhuli yalingukola habehi hoyolonga, 
\q1 “Mkulu Nguluwi yawatambichize. 
\q1 Twanguwatambichiza kwa itagwa lya Mkulu Nguluwi.” 
\c 130  
\s1 Kulanda utanzi 
\d (Lwimbo lwa kuluta kuchanya.) 
\q1  
\v 1 Kulawa kuli magazo ga heni, 
\q1 ndangukulilila, gwa Mkulu Nguluwi. 
\q1  
\v 2 Gwa Mkulu, uhuliche lizi lya heni, 
\q1 uwiche goya ikutu lya hegwe uhulichize kulanda kwa heni kwa isungu. 
\q1  
\v 3 Gwa Mkulu Nguluwi, wone wahakumbuchile wihe wa hetwe 
\q1 gwa Mkulu, whaani yahawezile kusulupuka kulawa kuli kugazigwa? 
\q1  
\v 4 Ila kwa hegwe twanguwa na kulechelwa, 
\q1 leka hetwe tukudumbe. 
\b  
\q1  
\v 5 Ndangitumbila kwa Mkulu Nguluwi kwa nhumbula ya heni yeng'ha, 
\q1 ndina makundo ng'hatu na ulonzi wa heye. 
\q1  
\v 6 Ndangitumbila kwa Mkulu, 
\q1 kusinda wamizi walingubeteza kubwemwenzuka, 
\q1 kusinda wamizi walingubeteza mitondo. 
\b  
\q1  
\v 7 Gwa Isilaeli, witumbile kwa Mkulu Nguluwi, 
\q1 kwa vila kwa heye Mkulu Nguluwi kuna igano lya kwimilila, 
\q1 kwa heye kuna mong'ho ng'hatu wa kutugombola. 
\q1  
\v 8 Heye kowagombola wanhu wa Isilaeli, 
\q1 kulawa kuli gehile ga hewo geng'ha. 
\c 131  
\s1 Kitumbila kwa Nguluwi kwa kusindamala 
\d (Lwimbo lwa kuluta kuchanya. Lwimbo lwa Daudi.) 
\q1  
\v 1 Gwa Mkulu Nguluwi, ndahela nhumbula ya kidaya, 
\q1 siwele munhu wa kidaya. 
\q1 Hambe ndite mbuli ng'hulu, 
\q1 ama gawele ga vinduzanduza ng'hatu kwa heni. 
\q1  
\v 2 Ila nhumbula ya heni naisindamala na kuwa na kikala goya, 
\q1 kota chali vyochisindamale na mayake, 
\q1 ndo nhumbula ya heni vyoisindamale. 
\q1  
\v 3 Gwa Isilaeli, witumbile kwa Mkulu Nguluwi, 
\q1 kulawa sambi mbaka mazuwa gose. 
\c 132  
\s1 Lutogo lwa ng'handa ya Nguluwi 
\d (Lwimbo lwa kuluta kuchanya.) 
\q1  
\v 1 Gwa Mkulu Nguluwi, mkumbuchile Daudi, 
\q1 ukumbuchile magazo geng'ha goyapatile. 
\q1  
\v 2 Gwa Mkulu Nguluwi, ukumbuchile kulagana koyakupele, 
\q1 chilaho choyakulahile, gwa Nguluwi wa Yakobo, Nguluwi Yawele na Mong'ho, 
\q1  
\v 3 “Sikwinjila mgati mwa ng'handa ya heni, 
\q1 ne kuwasa kuli chinhanda cha heni, 
\q1  
\v 4 sikunda kuwasa, 
\q1 ne kusinzila, 
\q1  
\v 5 mbaka ndikupe hegwe Mkulu Nguluwi honhu ha kikala, 
\q1 haluga ha hegwe, gwa Nguluwi wa Yakobo, Nguluwi Yawele na Mong'ho.” 
\b  
\q1  
\v 6 Ako Efulata natuhulika mbuli za isanduku lya ilagano, 
\q1 natulifika kuli migunda ja Yealimu. 
\q1  
\v 7 “Goya. Tuche kaye kwa Nguluwi, 
\q1 tufugame kumwando mwa chigoda cha heye cha undewa.” 
\b  
\q1  
\v 8 Ndangukulanda winuche, gwa Mkulu Nguluwi, 
\q1 ulute hali honhu ha hegwe ha kwesela, 
\q1 hegwe, hamwe na isanduku lya ilagano lya mong'ho wa hegwe. 
\q1  
\v 9 Watambika wa hegwe wagubikwe na kutanganika, 
\q1 na welile wa hegwe watowe iyowe lya usangalalo. 
\b  
\q1  
\v 10 Kwa chiwalo cha Daudi, chitumagwa wa hegwe, 
\q1 uleche kumlema yabakalizwe mafuta wa hegwe. 
\b  
\q1  
\v 11 Mkulu Nguluwi nakamlahila Daudi chilaho cha kukomya, 
\q1 chilaho chiwele hambe yachigalule. 
\q1 “Ndomuwika yumwe wa walelwa wa hegwe, 
\q1 yakalise kuli chigoda cha hegwe cha undewa. 
\q1  
\v 12 Wone wana wa hegwe webatilile ilagano lya heni, 
\q1 na kibatilila malanguso gondiwapa, 
\q1 wana wa hewo kahi wowa wandewa kota hegwe mazuwa gose.” 
\b  
\q1  
\v 13 Kukomya, Mkulu Nguluwi nakauhagula muji wa Siyoni, 
\q1 nakagana hawe haluga ha heye. 
\q1  
\v 14 “Aha ndo hondichikala mazuwa gose, 
\q1 ndo haluga ha heni kwa vila nandihagana. 
\q1  
\v 15 Ndoutambichiza ng'hatu muji wa Siyoni kwa vinhu vyake, 
\q1 ndowagutiza chilyo wazunwa wake. 
\q1  
\v 16 Ndowavaliza ulohozi watambika wake, 
\q1 na walingukundigwa wake wotowa luchenze lwa usangalalo. 
\q1  
\v 17 Kulawa aha, hemwe mowa na mndewa yazidahe wa lukolo lwa Daudi. 
\q1 Kota chenje chilingwimilila ndomwimiza mndewa yondimbakalize mafuta. 
\q1  
\v 18 Wang'honyo wake ndowavaliza soni, 
\q1 ila heye ndomvaliza kofia ya chiundewa.” 
\c 133  
\s1 Uhamwe hali wanhu 
\d (Lwimbo lwa kuluta kuchanya. Lwimbo lwa Daudi.) 
\q1  
\v 1 Ndo mbuli inojile na ya kunojeza ng'hatu, 
\q1 wenyelukolo kikala hamwe kwa uhamwe. 
\q1  
\v 2 Ndo kota mafuta ganojile kumutwi, 
\q1 mbaka kuli lulevu lwa heye Aluni, 
\q1 mbaka mlupembo lwa ivalo lya heye msingo, 
\q1 kota ulajilo kota Nguluwi nakamhagula leka yawe mtambika. 
\q1  
\v 3 Kota nungwi vyoilingulawila kuli chidunda cha Helimoni, 
\q1 utambichizo wa Nguluwi wokuya mchanya mwa chidunda cha Siyoni. 
\q1 Ako Mkulu Nguluwi nakalonga nakalagana kuwatambichiza wanhu wa heye, 
\q1 kuwegalila ukomu ulihela kuduma. 
\c 134  
\s1 Mumtogole Mkulu Nguluwi 
\d (Lwimbo lwa kuluta kuchanya.) 
\q1  
\v 1 Muye mumtogole Mkulu Nguluwi hemwe vitumagwa wa heye weng'ha, 
\q1 hemwe mweng'ha mlingukola mijito nechilo haluga hake. 
\q1  
\v 2 Mwinule moko kulutila honhu helile, 
\q1 na kumtogola Mkulu Nguluwi. 
\b  
\q1  
\v 3 Mkulu Nguluwi yawatambichize kulawa Siyoni, 
\q1 heye yalumbile ulanga na isi. 
\c 135  
\s1 Lutogo kwa itagwa lya Nguluwi 
\q1  
\v 1 Mumtogole Mkulu Nguluwi. 
\b  
\q1 Mlitogole itagwa lya Mkulu Nguluwi, 
\q1 mumtogole hemwe vitumagwa wa heye. 
\q1  
\v 2 Mumtogole hemwe mlingikala kuli ng'handa ya Mkulu Nguluwi, 
\q1 kuli lugagala lwa ng'handa ya Nguluwi wa hetwe. 
\q1  
\v 3 Mumtogole Mkulu Nguluwi kwa vila ka yanojile, 
\q1 mlitogole kwa nzimbo itagwa lya heye, 
\q1 kwa vila alyo lyangunojeza. 
\q1  
\v 4 Mkulu Nguluwi nakamhagula Yakobo yawe wa heye, 
\q1 hemwe wanhu wa Isilaeli muwe wa heye. 
\b  
\q1  
\v 5 Ndikomya, ndivizela kota Mkulu Nguluwi ndo mkulu, 
\q1 Mkulu wa hetwe ndo mkulu mchanya mwa milungu jeng'ha. 
\q1  
\v 6 Mkulu Nguluwi kanguditaga choneche choyalingugana, 
\q1 kuli kilanga na muisi na mbahali na mgati ng'hatu mwa mazi. 
\q1  
\v 7 Ndo yalingigala ng'hungugu kulawa kuli mbaka ja isi, 
\q1 yalingudita mazi tendema kwa lumwemwesa, 
\q1 na kuputa mbeho ng'hulu kulawa kuli ng'hano za heye. 
\b  
\q1  
\v 8 Ndo yawakopole walelwa wa mwaluko ako Misili, 
\q1 walelwa wa wanhu na migongolo kahi. 
\q1  
\v 9 Ndo yaditile ulajilo na kububuwaza kwa hegwe, gwa Misili, 
\q1 kwa kuwagaza Falao na vitumagwa wa heye weng'ha. 
\q1  
\v 10 Ndo yawadumye wanhu wa isi nyinji, 
\q1 nakawakopola wandewa wawele na mong'ho, 
\q1  
\v 11 wawele ndo Sihoni mndewa wa Waamoli, 
\q1 Ogu mndewa wa Bashani, 
\q1 na wandewa weng'ha wa Kanaani. 
\q1  
\v 12 Nakahola isi za hewo na kuwapa wanhu wa heye, 
\q1 ena, leka ziwe uhalizi kwa wanhu wa heye Isilaeli. 
\b  
\q1  
\v 13 Itagwa lya hegwe, gwa Mkulu Nguluwi, lyangikala mazuwa gose, 
\q1 lyokumbuchilwa kuli lulelo lweng'ha. 
\q1  
\v 14 Mkulu Nguluwi kowalewela wanhu wa heye, 
\q1 na kuwonela isungu vitumagwa wa heye. 
\b  
\q1  
\v 15 Jimalukolo ja wanhu wa isi ndo sendi na zahabu, 
\q1 najigongomanyigwa kwa moko ga wanhu. 
\q1  
\v 16 Jina milomo, ila hajilingulonga, 
\q1 jina meho, ila hajilingona. 
\q1  
\v 17 Jina makutu, ila hajilinguhulika, 
\q1 na jahela ukomu. 
\q1  
\v 18 Weng'ha walingujigongomanya wochiwhana najo, 
\q1 hihyo du na weng'ha walingujitumbila. 
\b  
\q1  
\v 19 Hemwe wanhu wa Isilaeli, mumtogole Mkulu Nguluwi. 
\q1 Hemwe watambika wa ivyazi lya Aluni, mumtogole Mkulu Nguluwi. 
\q1  
\v 20 Hemwe Walawi, mumtogole Mkulu Nguluwi. 
\q1 Hemwe mlingumdumba Mkulu Nguluwi, mumtogole. 
\q1  
\v 21 Yatogoligwe Mkulu Nguluwi kuli Siyoni, 
\q1 yatogoligwe yalingikala Yelusalemu. 
\b  
\q1 Mumtogole Mkulu Nguluwi. 
\c 136  
\s1 Igano lya heye lya kwimilila lyangikala mazuwa gose 
\q1  
\v 1 Mlonje malumbo kwa Mkulu Nguluwi kwa vila ka yanojile, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 2 Mlonje malumbo kwa Nguluwi wa milungu, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 3 Mlonje malumbo kwa Mkulu wa wakulu, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\b  
\q1  
\v 4 Ndo yaliyeka yalingudita makulu ga kububuwaza, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 5 Ndo yaulumbile ulanga kwa luhala, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 6 Ndo yaigongomanyile isi mchanya mwa mazi menji, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 7 Ndo yalumbile isanya na nyelezi na nhondwe, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 8 Isanya lilongoze nemisi, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 9 Nyelezi na nhondwe vilongoze nechilo, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\b  
\q1  
\v 10 Ndo yawakopole walelwa wa mwaluko wa Misili, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 11 Nakawosa wanhu wa Isilaeli kulawa ako, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 12 Kwa moko wa heye uwele na mong'ho na ludali, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 13 Ndo yaigawanule Bahali ya Shamu honhu heli, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose, 
\q1  
\v 14 nakawadita wanhu wa Isilaeli wakole amo, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 15 Ila nakawazibiza Falao na chilundo cha heye cha wamizi kuli Bahali ya Shamu, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 16 Ndo yawalongoze wanhu wa heye kuchiwala, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 17 Ndo yawatowile wandewa wakulu, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 18 Nakawakopola wandewa wawele na mong'ho, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 19 Nakamkopola Sihoni, mndewa wa Waamoli, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose, 
\q1  
\v 20 na Ogu, mndewa wa Bashani, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 21 Nakazihola isi za hewo, nakawapa wanhu wa heye, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose, 
\q1  
\v 22 leka ziwe uhalizi kwa Isilaeli, chitumagwa wa heye, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\b  
\q1  
\v 23 Ndo yatukumbuchile mhela wa ung'hochele wa hetwe, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose, 
\q1  
\v 24 nakatulohola kulawa kwa wang'honyo wa hetwe, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\q1  
\v 25 Ndo yalingigala chilyo kwa chila chilumbigwe chiwele na ukomu, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\b  
\q1  
\v 26 Mlonje malumbo kwa Nguluwi wa kilanga, 
\q1 kwa vila igano lya heye lya kwimilila lyangikala mazuwa gose. 
\c 137  
\s1 Kulombocheza kwa Waisilaeli kuli ujenzi 
\q1  
\v 1 Hafungo ha nzanda za Babuloni, natikalisa 
\q1 natwali tulila vyotukumbuchile Siyoni. 
\q1  
\v 2 Kuli migodi ja isi yila, 
\q1 natupatika migombogombo ja hetwe. 
\q1  
\v 3 Watuholile tuwe wapogozi wa ngondo nawagana tuwembile, 
\q1 walingutugaza nawatugana tuwasangalaze, 
\q1 “Mtwimbile lwimbo lumwe hali nzimbo za Siyoni.” 
\b  
\q1  
\v 4 Toweza ndaze kwimba lwimbo lwa Mkulu Nguluwi, 
\q1 kuli isi ya chijenzi? 
\q1  
\v 5 Gwa Yelusalemu, wone ndikusemwe, 
\q1 moko wa heni wa kudilo usemwe uwanzi wa kutowa igombogombo. 
\q1  
\v 6 Umyango wa heni unanahile na kulemwela kwimba, 
\q1 wone sikukumbuchile hegwe, gwa Yelusalemu, 
\q1 ena, wone ndogana choneche kusinda kusangalala kwa Yelusalemu. 
\b  
\q1  
\v 7 Gwa Mkulu Nguluwi, uleche kusemwa gowaditile Waedomu, 
\q1 zuwa lila Yelusalemu vyoiholigwe kuli upogozi, 
\q1 ukumbuchile gowalonjile, 
\q1 “Mbomole muji wa Yelusalemu. 
\q1 Mng'humbule misisi jake.” 
\b  
\q1  
\v 8 Gwa Babuloni, kodumigwa. 
\q1 Kotambichizwa yula yawele yokuhilusila chibida kwa gehile goutuditile, 
\q1  
\v 9 yula yowahola wana wa hegwe, 
\q1 na kuwahondanga kuli mitalawe. 
\c 138  
\s1 Kulanda kwa kulonga malumbo 
\d (Lwimbo lwa Daudi.) 
\q1  
\v 1 Ndangulonga malumbo, gwa Mkulu Nguluwi, kwa nhumbula ya heni yeng'ha, 
\q1 ndangwimba lutogo lwa hegwe hali milungu. 
\q1  
\v 2 Ndanginamiza kulola kuli ng'handa ya hegwe yelile, 
\q1 ndangulitogola itagwa lya hegwe, 
\q1 kwa chiwalo cha igano lya kwimilila lya hegwe na kukundigwa kwa hegwe, 
\q1 kwa vila nakuwika itagwa lya hegwe na ulonzi wa hegwe 
\q1 mchanya mwa chila chinhu. 
\b  
\q1  
\v 3 Londikulilile, hegwe nakunyidichila, 
\q1 nakunyonjezela mong'ho wa nhumbula. 
\b  
\q1  
\v 4 Gwa Mkulu Nguluwi, wandewa weng'ha muisi wokutogola, 
\q1 kwa vila nawahulika ulonzi wa hegwe. 
\q1  
\v 5 Wokwimba lutogo lwa ndaze vyoulingudita, gwa Mkulu Nguluwi, 
\q1 kwa vila hegwe ndo mkulu ng'hatu. 
\q1  
\v 6 Hanga hegwe, gwa Mkulu Nguluwi kwa mchanya mwa weng'ha, 
\q1 kwanguwalola kwa kunoga wawele ng'hochele, 
\q1 ila walingidaya kwanguwonaga kulawa kutali. 
\b  
\q1  
\v 7 Hala hondifichigwa na magazo, hegwe kwangunyamila, 
\q1 kwangugolola moko wa hegwe kwa chiwalo cha ng'halazi ya wang'honyo wa heni, 
\q1 kwa mong'ho wa hegwe ukulu, kwangundohola. 
\q1  
\v 8 Gwa Mkulu Nguluwi, kokweneza geng'ha goulagane na heni. 
\q1 Igano lya kwimilila lya hegwe, gwa Mkulu Nguluwi, lyangikala mazuwa gose. 
\q1 Uleche kujileka kutali mijito ja moko wa hegwe. 
\c 139  
\s1 Nguluwi kangugazela geng'ha na kangulongoza geng'ha 
\d (Kwa yalingwaluchiza kwimba. Zabuli ya Daudi.) 
\q1  
\v 1 Gwa Mkulu Nguluwi, hegwe nakumhugajiza, 
\q1 hegwe kwangunzela heni mbaka mgati. 
\q1  
\v 2 Kwanguvizela kikalisa na kwima kwa heni, 
\q1 kwanguvizela chila chinhu chondilingijesa kulawa kutali. 
\q1  
\v 3 Kwanguvizela hondijenda ama hondikwesela, 
\q1 kwanguhazela chila honhu hondilinguluta. 
\q1  
\v 4 Nding'hali kulonga ulonzi woneche, 
\q1 gwa Mkulu Nguluwi, nakuuzela ng'hatu. 
\q1  
\v 5 Kwa baho kuli chila ubanzi wa heni, kumwando na kumbele, 
\q1 kwangumbichila moko wa hegwe kunyamila. 
\q1  
\v 6 Uwanzi wa hegwe ndo mzidi wa nyhala za heni, 
\q1 ndo ukulu ng'hatu, siweza kuuzela. 
\b  
\q1  
\v 7 Mbilimile kohi kuwele muhe wa hegwe wa haduhu? 
\q1 Ndute kohi kuwele hegwe kwa haduhu? 
\q1  
\v 8 Wone ng'hwine kilanga, hegwe kwa baho, 
\q1 wone mbase hanyi kuli isi ya wabagame, hegwe kwa baho. 
\q1  
\v 9 Wone nguluche mbaka kolilawilaga isanya, 
\q1 ama mbaka kuli kolizinjilaga isanya, 
\q1  
\v 10 mbaka ako kahi kwa kuko kundongoza, 
\q1 moko wa hegwe wa kudilo wondibata. 
\q1  
\v 11 Wone ndahalandile jiza lingumbiche, 
\q1 jiza linzungulute honhu ha lumuli, 
\q1  
\v 12 kwa hegwe, jiza haliwele jiza ne hado, 
\q1 na nechilo kwangupulika kota nemisi, 
\q1 kwa hegwe jiza na lumuli ndo chinhu chimwe. 
\b  
\q1  
\v 13 Hegwe nakundita heni, nhumbula na muhe, 
\q1 nakungongomanya mmunda mwa mayangu. 
\q1  
\v 14 Ndangukutogola kwa vila nditigwa kwa kububuwaza na vinduzanduza, 
\q1 madito ga hegwe ndo ga kububuwaza, 
\q1 nhumbula ya heni yangugazela ng'hatu. 
\q1  
\v 15 Lukuli lwa heni haluvisigwe kwa hegwe, 
\q1 vyounditile kwa uviso, honhu hawele munhu hawezile kumbona. 
\q1  
\v 16 Hegwe nakumbona lombele nding'hali kupondigwa, 
\q1 nakwandika chila chinhu mchitabu cha hegwe, 
\q1 mazuwa ga heni geng'ha nakugawika goya, 
\q1 mbaka kung'hali kuwa baho zuwa lila lya mwaluko. 
\q1  
\v 17 Gwa Nguluwi, majesa ga hegwe ndo makulu ng'hatu, 
\q1 hambe gaweze kuwalizwa ng'hatu. 
\q1  
\v 18 Wone ndahagawazile gahawele menji kupuluta sangalaza. 
\q1 Hondililimka, nding'hali nda hamwe na hegwe. 
\b  
\q1  
\v 19 Gwa Nguluwi, uwakopole wanhu wehile. 
\q1 Walingukopola woche kwa heni. 
\q1  
\v 20 Wangulonga vibi kwa chiwalo cha hegwe, 
\q1 wangulonga gehile kwa hegwe galinguwala itagwa lya hegwe. 
\q1  
\v 21 Gwa Mkulu Nguluwi, ndanguwazudila walingukuzudila, 
\q1 ndanguwabeza ng'hatu wala walingukubelenhuka. 
\q1  
\v 22 Wang'honyo wa hegwe ndo wang'honyo wa heni, 
\q1 ndanguwazudila ng'hatu. 
\b  
\q1  
\v 23 Umhugajize, gwa Nguluwi, uizele nhumbula ya heni, 
\q1 unjeze, uluzele lunhwinhwi lwa heni. 
\q1  
\v 24 Ugalole, wone gala gondilingudita ndo geha, 
\q1 undongoze kuli nzila ya mazuwa gose. 
\c 140  
\s1 Kulanda kwamilwa na Nguluwi 
\d (Kwa yalingwaluchiza kwimba. Zabuli ya Daudi.) 
\q1  
\v 1 Gwa Mkulu Nguluwi, undohole kulawa kwa wanhu wehile, 
\q1 unyamile na wanhu walingugana kundumiza. 
\q1  
\v 2 Wanhu awo wangiwika goya mnhumbula za hewo kudita gehile, 
\q1 wangwambuza kilewa chila mhela. 
\q1  
\v 3 Myango zawo ziha kota za izoka, 
\q1 kuli milomo jawo muna ulonzi uwele na dunga kota ya izoka. 
\b  
\q1  
\v 4 Gwa Mkulu Nguluwi, unyamile na ndole za wehile, 
\q1 unyamile na wanhu walingugana kundumiza, 
\q1 wawele wewichile goya kungwisa. 
\q1  
\v 5 Walingidaya nawambichila midiwa, 
\q1 nawalambalika ng'weso kota utandawala, 
\q1 nawavisa midiwa mnzila leka wandibate. 
\b  
\q1  
\v 6 Ndangumlonjela Mkulu Nguluwi, “Hegwe ndo Nguluwi wa heni.” 
\q1 Gwa Mkulu Nguluwi, uhulichize lizi lya kulanda kwa heni kwa isungu. 
\q1  
\v 7 Gwa Mkulu Nguluwi, Mkulu wa heni, mlohozi wa heni yawele na mong'ho, 
\q1 nakunyamila goya mhela wa ngondo. 
\q1  
\v 8 Gwa Mkulu Nguluwi, uleche kuwapa wehile gowalingugana, 
\q1 na kiwika goya kwa hewo kwihile kuleche kulutilila goya, 
\q1 ama wokwinula vitwi vya hewo. 
\b  
\q1  
\v 9 Wihe wa ulonzi wa hewo uwafiche hewo wawo. 
\q1  
\v 10 Makala ga chiluli gawagwile, 
\q1 watozwe kuli chiluli, 
\q1 wenjizwe kuli ikulubila, waleche kwinuka kahi. 
\q1  
\v 11 Mbuli za walinguwaheha wanji zileche kulutilila goya kuli isi, 
\q1 wihe uwawinge na kuwadumya wala walingugana kundumiza. 
\b  
\q1  
\v 12 Ndivizela Mkulu Nguluwi kangulewelaga mbuli za wanhu walingubunzwa, 
\q1 na kuwapa hachi wazunwa. 
\q1  
\v 13 Ndikomya, watanganiche wolitogola itagwa lya hegwe, 
\q1 wagoloche nhumbula wochikala hali hegwe. 
\c 141  
\s1 Kulanda kwa kugana kwamilwa 
\d (Zabuli ya Daudi.) 
\q1  
\v 1 Ndangukuchema, gwa Mkulu Nguluwi, 
\q1 uye himahima kunhanza. 
\q1 Uhulichize lizi lya heni mhela hondikuchema. 
\q1  
\v 2 Kulanda kwa heni ukubochele kota ubani, 
\q1 hondikwinula moko ga heni kwa hegwe ung'hunde kota nhambiko ya matinazo. 
\b  
\q1  
\v 3 Gwa Mkulu Nguluwi, uwamile mlomo wa heni, 
\q1 uwiche wamizi kuli lwizi lwa mlomo wa heni. 
\q1  
\v 4 Undemeze ndeche kuluta kudita gehile, 
\q1 ndeche kihanza na madito gehile, 
\q1 ndeche kilumba na wanhu walingudita gehile, 
\q1 ne kuwa hamwe kuli mnvina za hewo. 
\b  
\q1  
\v 5 Munhu yawele na hachi yanhowe, 
\q1 ndo mbuli ya isungu, 
\q1 na yang'hanuchile, ndo mafuta kumutwi kwa heni. 
\q1 Mutwi wa heni hauweza kuilema mbuli ayo. 
\q1 Ila kulanda kwa heni mazuwa gose, ndo kwa chiwalo cha hewo kuleka wihe. 
\q1  
\v 6 Wakulu wa hewo howohondigwa kuli mitalawe, 
\q1 ndo wovizela kota ulonzi wa heni nawali goya. 
\q1  
\v 7 Mizeje jawo josambalulwa kuli mlomo wa chilaga 
\q1 kota munhu vyoyalingulima na kukatula misanga. 
\b  
\q1  
\v 8 Ila heni ndangitumbila kwa hegwe, gwa Mkulu Nguluwi, Mkulu wa heni, 
\q1 ndangubilimila kwa hegwe leka unyamile, uleche kundeka kwihile. 
\q1  
\v 9 Unyamile na midiwa jowambichile, 
\q1 kugwilizwa na wanhu wehile. 
\q1  
\v 10 Wehile wagwilizwe kuli midiwa jawo, 
\q1 mhela hondikola kwa kikala goya. 
\c 142  
\s1 Kulanda kwa munhu yalechigwe mchiwa 
\d (Ilanguso lya Daudi loyawele kuli mhalika. Kulanda.) 
\q1  
\v 1 Ndangumlilila Mkulu Nguluwi kwa lizi, 
\q1 ndangumdedeza Mkulu Nguluwi kwa lizi, leka yambonele isungu. 
\q1  
\v 2 Ndangumuwichila kung'ung'uta kwa heni, 
\q1 ndangumlonjela magazo ga heni. 
\q1  
\v 3 Hondiwa habehi kugozola, 
\q1 hegwe kwa baho, kwangunzela vyombele. 
\q1 Wang'honyo wa heni nawambichila midiwa kuli nzila ya heni. 
\q1  
\v 4 Hondilola ubanzi wa kudilo na kubeteza, 
\q1 ndangona haduhu munhu wa kunhanza, 
\q1 ndahela kahi honhu ha kubilimila, 
\q1 haduhu munhu yalingijesa kwa chiwalo cha heni. 
\b  
\q1  
\v 5 Gwa Mkulu Nguluwi, ndangukulilila. 
\q1 Hegwe ndo honhu ha heni ha kubilimila, 
\q1 hegwe ndo chila chinhu kwa heni kuli isi ya wawele wakomu. 
\q1  
\v 6 Uhulichize chililo cha heni, kwa vila nhoka lukami. 
\q1 Undohole kulawa kwa walingungaza, kwa vila wana mong'ho kusinda heni. 
\q1  
\v 7 Undavye amu mchinweng'ho 
\q1 leka ndonje malumbo kwa hegwe. 
\q1 Wanhu watanganiche wochilumba na heni 
\q1 kwa vila nakunditila ganojile menji. 
\c 143  
\s1 Kulanda utanzi 
\d (Zabuli ya Daudi.) 
\q1  
\v 1 Uhulichize kulanda kwa heni, gwa Mkulu Nguluwi. 
\q1 Uwiche goya ikutu lya hegwe kwa chiwalo cha kulanda kwa heni kwa isungu. 
\q1 Kwa chiwalo cha kukundigwa na kutanganika kwa hegwe, unyidichile. 
\q1  
\v 2 Uleche kunhagusa kwa kung'ang'ala, heni chitumagwa wa hegwe, 
\q1 kwa vila haduhu yoneche yawele mkomu, yawele yatanganiche hali hegwe. 
\b  
\q1  
\v 3 Wang'honyo wa heni nawambinza, 
\q1 nawangwisa ng'hatu, 
\q1 nawambika kuli jiza kota munhu yabagame katali. 
\q1  
\v 4 Ngozola ng'hatu, 
\q1 nhumbula ya heni naizilika kwa chiwalo cha kudumba. 
\b  
\q1  
\v 5 Ndangugakumbuchila mazuwa ga katali, 
\q1 ndangijesa kwa chiwalo cha mijito ja hegwe jeng'ha, 
\q1 ndangulola mijito jikoligwe kwa moko ga hegwe. 
\q1  
\v 6 Ndangugolola moko ga heni kulanda, 
\q1 nhumbula ya heni ina ng'halu na hegwe kota isi ng'havu. 
\b  
\q1  
\v 7 Gwa Mkulu Nguluwi, unyidichile himahima, 
\q1 kwa vila nangozola ng'hatu. 
\q1 Uleche kivisa kutali na heni, 
\q1 leka ndeche kuwa kota wala walingudulika kuli isi ya wabagame. 
\b  
\q1  
\v 8 Mitondo undajile igano lya kwimilila lya hegwe, 
\q1 kwa vila nandikuwichila kitumbila kwa heni. 
\q1 Undanguse vyoilinguganigwa kudita, 
\q1 kwa vila ndangukugalila nhumbula ya heni. 
\b  
\q1  
\v 9 Gwa Mkulu Nguluwi, undohole kulawa kwa wang'honyo wa heni, 
\q1 kwa vila kwa hegwe ndangubilimila kikala goya. 
\q1  
\v 10 Undanguse kweneza vyoulingugana, 
\q1 kwa vila hegwe ndo Nguluwi wa heni. 
\q1 Muhe wa hegwe unojile undongoze kuli nzila inojile. 
\b  
\q1  
\v 11 Kwa chiwalo cha itagwa lya hegwe, Mkulu Nguluwi, uwamile ukomu wa heni, 
\q1 umbuse kuli magazo kwa chiwalo cha kutanganika kwa hegwe. 
\q1  
\v 12 Kwa chiwalo cha igano lya kwimilila lya hegwe, uwakopole wang'honyo wa heni, 
\q1 uwadumye weng'ha walingumbunza, 
\q1 kwa vila heni nda chitumagwa wa hegwe. 
\c 144  
\s1 Malumbo kwa kusumya 
\d (Lwimbo lwa Daudi.) 
\q1  
\v 1 Yatogoligwe Mkulu Nguluwi, italawe lya heni, 
\q1 yalingugadita moko ga heni gazowele kitowa ngondo, 
\q1 na kuvilangusa vidole vya heni kitowa. 
\q1  
\v 2 Heye ndo igano lya kwimilila lya heni na ngome ya heni 
\q1 yalingunyamila na mlohozi wa heni, 
\q1 heye ndo ngawo ya heni na honhu ha heni ha kubilimila, 
\q1 kanguwasumyaga wanhu wa isi zinji na kuwawika hasi ha heni. 
\b  
\q1  
\v 3 Gwa Mkulu Nguluwi, munhu ndo choni mbaka umlolele? 
\q1 Munhu ndo choni mbaka umjese? 
\q1  
\v 4 Munhu ndo kota lweselo hela, 
\q1 mazuwa ga heye ndo kota isisila lilingukola. 
\b  
\q1  
\v 5 Uchumule ulanga wa hegwe, gwa Mkulu Nguluwi, uduliche. 
\q1 Uvidolize vidunda navyo vilavye iyosi. 
\q1  
\v 6 Wambuze lumwemwesa, luwasambalule wang'honyo, 
\q1 utowe misale ja hegwe, leka wabilime. 
\q1  
\v 7 Ugolole moko wa hegwe kulawa kuchanya, 
\q1 undohole na kumbusa kuli mazi aga menji, 
\q1 umbuse kuli moko ga wajenzi, 
\q1  
\v 8 wawele wangulongaga ulonzi wa udesi, 
\q1 wangugololaga moko kwa ulolezi wa udesi. 
\b  
\q1  
\v 9 Gwa Nguluwi, ndokwimbila lwimbo lunyale, 
\q1 ndokutowela ching'weleng'wele cha ng'weso kumi, 
\q1  
\v 10 hegwe ulinguwapa wandewa kusumya, 
\q1 ulingumlohola Daudi chitumagwa wa hegwe. 
\q1  
\v 11 Undohole na ipanga lya mng'honyo yamemile wihe, 
\q1 umbuse kuli moko ga wajenzi, 
\q1 wawele wangulongaga ulonzi wa udesi, 
\q1 wangugololaga moko kwa ulolezi wa udesi. 
\b  
\q1  
\v 12 Wasongolo wa hetwe wakule goya kota mizuchila kuli kagunda, 
\q1 wahinza wa hetwe wawe kota mizengo jihongoligwe kwa kuinoliga ng'handa ya mndewa. 
\q1  
\v 13 Ng'hano za hetwe zimeme mbena. 
\q1 Ming'holo ja hetwe kuli migunda jilele maelufu kwa maelufu. 
\q1  
\v 14 Migongolo ja hetwe jiwe jinenehe na mong'ho, 
\q1 jileche kwajiliza nyinda ne kulela mhela haunafika, 
\q1 ne chililo cha magazo kuli vijiji vya hetwe. 
\b  
\q1  
\v 15 Kukomya, nawatambichizwa wanhu wa isi wawele watambichizwe mbuli azo. 
\q1 Nawatambichizwa wanhu wa isi wawele Nguluwi wa hewo ndo Mkulu Nguluwi. 
\c 145  
\s1 Lwimbo lwa kumtogola Nguluwi 
\d (Lwimbo lwa lutogo lwa Daudi.) 
\q1  
\v 1 Ndokutogola, gwa Nguluwi wa heni na mndewa wa heni, 
\q1 ndolipa ukulu itagwa lya hegwe mazuwa gose na mazuwa gose. 
\q1  
\v 2 Ndokutogola chila zuwa, 
\q1 ndolitogola itagwa lya hegwe mazuwa gose na mazuwa gose. 
\q1  
\v 3 Mkulu Nguluwi ndo mkulu, kanguganigwa kupegwa lutogo lwinji, 
\q1 ukulu wa heye hauweza kupugajizika. 
\b  
\q1  
\v 4 Lulelo mbaka lulelo, lutogo lwa madito ga hegwe lwosimilwa, 
\q1 awo wowikula madito ga hegwe makulu. 
\q1  
\v 5 Wolonga ukulu wa ludali lwa hegwe. 
\q1 Ndogajesa madito ga hegwe ga kububuwaza. 
\q1  
\v 6 Wowikula ukulu wa mong'ho wa madito ga hegwe ga kububuwaza, 
\q1 nani ndowikula ukulu wa hegwe. 
\q1  
\v 7 Wowikula lutogo lwa kunoga kwa hegwe kwinji, 
\q1 na kwimba kwa chiwalo cha kutanganika kwa hegwe. 
\q1  
\v 8 Mkulu Nguluwi kana isungu na uliholile, 
\q1 halinguzudilaga himahima, nakamema igano lya kwimilila. 
\q1  
\v 9 Mkulu Nguluwi ka yanojile kwa weng'ha, 
\q1 ndo yawele na isungu kwa vilumbigwe vya heye vyeng'ha. 
\b  
\q1  
\v 10 Vilumbigwe vya hegwe vyeng'ha vyolonga malumbo kwa hegwe, gwa Mkulu Nguluwi, 
\q1 nawo wa kukundigwa wa hegwe wokutogola. 
\q1  
\v 11 Wolonga ukulu wa undewa wa hegwe, 
\q1 na kuwikula mong'ho wa hegwe ukulu, 
\q1  
\v 12 leka chila munhu yagazele madito ga hegwe makulu, 
\q1 na ukulu wa undewa wa hegwe. 
\q1  
\v 13 Undewa wa hegwe ndo undewa wa mazuwa gose, 
\q1 ludali lwa hegwe lukale lulelo lweng'ha. 
\b  
\q1 Mkulu Nguluwi ka wa kukundigwa kuli kulagana kwa heye kweng'ha, 
\q1 ka yanojile kuli madito ga heye geng'ha. 
\q1  
\v 14 Mkulu Nguluwi kanguwatanzaga weng'ha walingugwa, 
\q1 kanguwenulaga weng'ha walingugazika. 
\b  
\q1  
\v 15 Vilumbigwe vyeng'ha vyangukulola kwa kitumbila ng'hatu, 
\q1 nagwe kwanguvipa chilyo kwa mhela uwichigwe. 
\q1  
\v 16 Kwangugubula moko wa hegwe kwa isungu, 
\q1 kwanguvyenezela chila chovilingugana chila chilumbigwe chiwele na ukomu. 
\b  
\q1  
\v 17 Mkulu Nguluwi ndo yatanganiche kuli nzila za heye zeng'ha, 
\q1 ndo yanojile kuli madito ga heye geng'ha. 
\q1  
\v 18 Mkulu Nguluwi ka habehi na weng'ha walingumlanda, 
\q1 weng'ha walingumlanda kwa nhumbula igoloche. 
\q1  
\v 19 Kanguwagalilaga chowalingugana weng'ha walingumdumba, 
\q1 kanguhulichizaga chililo cha hewo na kuwalohola. 
\q1  
\v 20 Mkulu Nguluwi kanguwamilaga weng'ha walingumgana, 
\q1 ila kowadumya wehile weng'ha. 
\b  
\q1  
\v 21 Ndowikula lutogo lwa Mkulu Nguluwi, 
\q1 vilumbigwe vyeng'ha vilitogole itagwa lya heye lyelile, 
\q1 mazuwa gose na mazuwa gose. 
\c 146  
\s1 Lutogo kwa Nguluwi mlohozi 
\q1  
\v 1 Mumtogole Mkulu Nguluwi. 
\q1 Umtogole Mkulu Nguluwi, gwa nhumbula ya heni. 
\q1  
\v 2 Ndomtogola Mkulu Nguluwi kuli ukomu wa heni weng'ha, 
\q1 ndomwimbila Nguluwi wa heni mhela weng'ha hondichikala. 
\b  
\q1  
\v 3 Mleche kitumbila kuli wakulu wa isi, 
\q1 hewo ndo wanhu hela, hawoweza kulohola. 
\q1  
\v 4 Munhu hoyolavya lweselo lwa heye lwa kuduma, 
\q1 kanguhiluka kuli nhimbwisi nakoyalawile, 
\q1 na aho mijito ja heye jeng'ha joyajiwichile goya jangwajililaga. 
\b  
\q1  
\v 5 Nakatambichizwa munhu yalingutanzigwa na Nguluwi wa Yakobo, 
\q1 munhu yawichile kitumbila kwa heye kwa Mkulu Nguluwi, Nguluwi wa heye, 
\q1  
\v 6 yavilumbile ulanga na isi, 
\q1 bahali na vyeng'ha viwele mumo. 
\q1 Heye kangibatililaga kulagana kwa heye mazuwa gose. 
\q1  
\v 7 Heye kanguwapaga walingubunzwa hachi zawo, 
\q1 Mkulu Nguluwi kanguwapaga chilyo wawele na nzala. 
\b  
\q1 Mkulu Nguluwi kanguwapaga wanweng'hwa kilejeha. 
\q1  
\v 8 Mkulu Nguluwi kanguwagubulaga meho wohambe walole. 
\q1 Mkulu Nguluwi kanguwenulaga walinguduliswa. 
\q1 Mkulu Nguluwi kanguwaganaga wanhu watanganiche. 
\q1  
\v 9 Mkulu Nguluwi kanguwamilaga wajenzi, 
\q1 kanguwatanzaga wadala wafililwe na walume wawo na walekwa, 
\q1 ila kangwajilizaga nzila ya wehile. 
\b  
\q1  
\v 10 Mkulu Nguluwi kangulongoza mazuwa gose, 
\q1 Nguluwi wa hegwe, gwa Siyoni, ka mndewa wa lulelo lweng'ha. 
\q1 Mumtogole Mkulu Nguluwi. 
\c 147  
\s1 Inoga kumtogola Nguluwi 
\q1  
\v 1 Mumtogole Mkulu Nguluwi. 
\b  
\q1 Ndaze vyoiwele goya kumwimbila lutogo Nguluwi wa hetwe. 
\q1 Heye ka yanojile na kanguganigwa kwimbilwa lutogo. 
\q1  
\v 2 Mkulu Nguluwi kanguuzenga kahi muji wa Yelusalemu, 
\q1 kanguwahilula Waisilaeli wawele kuli ujenzi. 
\q1  
\v 3 Kanguwatanza watweguche nhumbula, 
\q1 na kuwopa vilonda vya hewo. 
\b  
\q1  
\v 4 Kangwamula hisabu ya nhondwe, 
\q1 na kuzigalila zeng'ha matagwa gake. 
\q1  
\v 5 Mkulu wa hetwe ka mkulu, kana mong'ho ng'hatu, 
\q1 luhala lwa heye lwahela chipimilo. 
\q1  
\v 6 Mkulu Nguluwi kanguwakwinizaga wala walingunyenyetela, 
\q1 ila kanguwatozaga wehile, wagwe kuli nhimbwisi. 
\b  
\q1  
\v 7 Mumwimbile Mkulu Nguluwi nzimbo za kulonga malumbo, 
\q1 mumtowele ching'weleng'wele Nguluwi wa hetwe. 
\q1  
\v 8 Kangugubikaga ulanga kwa ng'hungugu, 
\q1 kanguigalilaga isi nhonya, 
\q1 na koteza misolo kuli vidunda. 
\q1  
\v 9 Kangujigalilaga migongolo chilyo chawo 
\q1 na mibofu ja mibondwa hojilila. 
\b  
\q1  
\v 10 Hambe yagane mong'ho wa falasi 
\q1 na hambe yanojezwe na uzidahe wa wamizi, 
\q1  
\v 11 ila Mkulu Nguluwi kangunojezwaga na walingumdumba, 
\q1 wanhu walingitumbila igano lya kwimilila lya heye. 
\b  
\q1  
\v 12 Umtogole Mkulu Nguluwi, gwa Yelusalemu. 
\q1 Umtogole Nguluwi wa hegwe, gwa Siyoni. 
\q1  
\v 13 Kwa vila kanguwikaga nzinzili lwizi lwa hegwe, 
\q1 kanguwatambichizaga wanhu wawele mgati mwa hegwe. 
\q1  
\v 14 Kangwamilaga mbaka ja hegwe, 
\q1 kangukugutizaga kwa mhau inojile. 
\b  
\q1  
\v 15 Kanguhilikaga mzilo wa heye muisi, 
\q1 na ulonzi wa heye wangwenezwaga himahima. 
\q1  
\v 16 Kangwanzanza seluji kota igolole lya sufu, 
\q1 kangusambalulaga nungwi kota mivu. 
\q1  
\v 17 Kangigalaga nhonya ya maganga kota maganga madodo. 
\q1 Whaani yoweza kwimilila kung'ang'ala kwa chipute cha heye? 
\q1  
\v 18 Hamba kangulavyaga ulonzi, leka seluji ayo isungulumuche, 
\q1 kangigalaga mbeho ya heye, nayo yanguchililikaga. 
\b  
\q1  
\v 19 Kanguwikulaga usenga wa heye kwa walelwa wa Yakobo, 
\q1 mizilo ja heye na nhaguso zake kwa Isilaeli. 
\q1  
\v 20 Ila haditile ahyo kwa wanhu wa isi zinji, 
\q1 wanhu wanji hawagazelele malajizo ga heye. 
\b  
\q1 Mumtogole Mkulu Nguluwi. 
\c 148  
\s1 Vilumbigwe vyeng'ha vimtogole Nguluwi 
\q1  
\v 1 Mumtogole Mkulu Nguluwi. 
\b  
\q1 Mumtogole Mkulu Nguluwi kulawa kilanga, 
\q1 mumtogole kulawa ako kuchanya ng'hatu. 
\q1  
\v 2 Mumtogole, hemwe wahilisi wa heye weng'ha, 
\q1 mumtogole, hemwe wamizi wa heye weng'ha wa kilanga. 
\b  
\q1  
\v 3 Mumtogole hemwe isanya na nyelezi, 
\q1 mumtogole hemwe nhondwe zeng'ha zilingupulika. 
\q1  
\v 4 Mumtogole hemwe ulanga wa kuchanya, 
\q1 na mazi gawele kuchanya mwa ulanga. 
\b  
\q1  
\v 5 Vyeng'ha vilitogole itagwa lya Mkulu Nguluwi, 
\q1 kwa vila heye nakalajiza na vyeng'ha navilumbigwa. 
\q1  
\v 6 Nakaviwika honhu hawo mazuwa gose, 
\q1 kwa mzilo uwele hauweza kugaluswa. 
\b  
\q1  
\v 7 Mumtogole Mkulu Nguluwi kulawa muisi, 
\q1 hemwe mizoka ja mbahali na mgati ng'hatu mwa bahali, mumtogole. 
\q1  
\v 8 Mumtogole hemwe lumwemwesa na nhonya ya maganga na seluji na ng'hungugu, 
\q1 mbeho ya nhigu ilingweneza mzilo wa heye. 
\b  
\q1  
\v 9 Mumtogole hemwe vidunda vikulu na vidunda vidodo, 
\q1 migodi ja mafuza na vihulo. 
\q1  
\v 10 Mumtogole hemwe migongolo ja kisolo na ja kufujigwa, 
\q1 vilumbigwe vyeng'ha vilingutambala na videje vyeng'ha. 
\b  
\q1  
\v 11 Mumtogole hemwe wandewa na wanhu wa isi zeng'ha, 
\q1 wang'hangala na vilongozi weng'ha muisi. 
\q1  
\v 12 Mumtogole hemwe wasongolo na wahinza, 
\q1 wasekulu weng'ha na wana kahi. 
\b  
\q1  
\v 13 Mweng'ha mlitogole itagwa lya Mkulu Nguluwi, 
\q1 kwa vila itagwa lya heye yaliyeka lyangwinuligwa, 
\q1 ukulu wa heye wa kuchanya ng'hatu mwa isi na ulanga. 
\q1  
\v 14 Nakawagalila mong'ho wanhu wa heye, 
\q1 kuhulichizwa kwa wanhu weng'ha walingukundigwa, 
\q1 wanhu wa Isilaeli yawaganile. 
\b  
\q1 Mumtogole Mkulu Nguluwi. 
\c 149  
\s1 Lwimbo lwa kusumya 
\q1  
\v 1 Mumtogole Mkulu Nguluwi. 
\b  
\q1 Mumwimbile Mkulu Nguluwi lwimbo lunyale, 
\q1 mumtogole kuli nhing'hano ya walingukundigwa. 
\q1  
\v 2 Usangalale, gwa Isilaeli, kwa chiwalo cha yakulumbile hegwe, 
\q1 wenyeng'haye wa Siyoni, mtowe luchenze kwa chiwalo cha mndewa wa hemwe. 
\q1  
\v 3 Mlitogole itagwa lya heye kwa ngoma, 
\q1 mmwimbile na kutowa ngoma na igombogombo. 
\b  
\q1  
\v 4 Kwa vila Mkulu Nguluwi kangunojezwaga na wanhu wa heye, 
\q1 nakawanoliga ulohozi walingunyenyetela. 
\q1  
\v 5 Wanhu walingukundigwa wangusangalala kwa kusumya, 
\q1 wasangalale mbaka howalinguwasa. 
\q1  
\v 6 Wawe na lutogo lukulu lwa Nguluwi, 
\q1 na mipanga jiwele na kunoleche kwili mmoko mwa hewo, 
\q1  
\v 7 wawahilulile chibida wanhu wa isi zinji, 
\q1 wawagaze wanhu wa isi zinji, 
\q1  
\v 8 wawawohe wandewa wa hewo kwa minyololo, 
\q1 na vilongozi wa hewo kwa pingu za chuma, 
\q1  
\v 9 leka weneze magazo gogalajizwe na Nguluwi. 
\q1 Alo ndo lutogo lwa walingukundigwa wa Nguluwi. 
\b  
\q1 Mumtogole Mkulu Nguluwi. 
\c 150  
\s1 Lwimbo lwa kumtogola Nguluwi 
\q1  
\v 1 Mumtogole Mkulu Nguluwi. 
\b  
\q1 Mumtogole Nguluwi kuli ng'handa ya heye, 
\q1 muutogole mong'ho wa heye kuli ulanga. 
\q1  
\v 2 Mumtogole kwa chiwalo cha madito ga heye makulu, 
\q1 mumtogole kwa chiwalo cha winji wa ukulu wa heye. 
\b  
\q1  
\v 3 Mumtogole kwa lizi lya mhalamhanda, 
\q1 mumtogole kwa igombogombo na ching'weleng'wele. 
\q1  
\v 4 Mumtogole kwa kutowa ngoma na kuvina, 
\q1 mumtogole kwa mluli na ching'weleng'wele. 
\q1  
\v 5 Mumtogole kwa kutowa matoazi. 
\q1 Mumtogole kwa matoazi ga lizi likulu. 
\q1  
\v 6 Chila chilumbigwe chiwele chikomu chimtogole Mkulu Nguluwi. 
\b  
\q1 Mumtogole Mkulu Nguluwi.