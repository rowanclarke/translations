\mt1 Éxodo  
\c 1  
\s1 Esclavitud y genocidio  
\p
\v 1 Estos son \w los|strong="H1121"\w* \w nombres|strong="H8034"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w que|strong="H1121"\w* entraron con \w Jacob|strong="H3290"\w* en \w Egipto|strong="H4714"\w*, cada uno con su \w familia|strong="H1004"\w*:  
\v 2 \w Rubén|strong="H7205"\w*, \w Simeón|strong="H8095"\w*, \w Leví|strong="H3878"\w*, \w Judá|strong="H3063"\w*,  
\v 3 Isacar, \w Zabulón|strong="H2074"\w*, \w Benjamín|strong="H1144"\w*,  
\v 4 \w Dan|strong="H1835"\w*, Neftalí, \w Gad|strong="H1410"\w* y Aser.  
\v 5 \w Todas|strong="H3605"\w* las \w personas|strong="H5315"\w* descendientes directos de \w Jacob|strong="H3290"\w* \w fueron|strong="H1961"\w* 70, pero \w José|strong="H3130"\w* \add ya\add* \w estaba|strong="H1961"\w* \w en|strong="H3318"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 6 \w José|strong="H3130"\w* \w murió|strong="H4191"\w*, y \w todos|strong="H3605"\w* \w sus|strong="H1931"\w* hermanos, y \w toda|strong="H3605"\w* \w aquella|strong="H1931"\w* \w generación|strong="H1755"\w*.  
\v 7 Pero \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* fueron fecundos y aumentaron \w grandemente|strong="H3966"\w*. Se \w multiplicaron|strong="H7235"\w*, y fueron aumentados y \w muy|strong="H3966"\w* fortalecidos \w de|strong="H1121"\w* tal \w manera|strong="H7235"\w* \w que|strong="H1121"\w* la tierra se \w llenó|strong="H4390"\w* \w de|strong="H1121"\w* ellos.   
\p
\v 8 Entonces \w se|strong="H3045"\w* \w levantó|strong="H6965"\w* \w en|strong="H5921"\w* \w Egipto|strong="H4714"\w* un \w nuevo|strong="H2319"\w* \w rey|strong="H4428"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w conoció|strong="H3045"\w* \w a|strong="H3068"\w* \w José|strong="H3130"\w*.  
\v 9 \w Él|strong="H1121"\w* dijo \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w*: \w Ciertamente|strong="H2009"\w* \w el|strong="H1121"\w* \w pueblo|strong="H5971"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* es \w más|strong="H4480"\w* \w numeroso|strong="H7227"\w* y \w fuerte|strong="H6099"\w* \w que|strong="H4480"\w* nosotros.  
\v 10 \w Vamos|strong="H5927"\w*, procedamos \w con|strong="H5921"\w* astucia \w contra|strong="H5921"\w* \w ellos|strong="H1931"\w*, \w no|strong="H6435"\w* \w sea|strong="H1961"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* multipliquen, \w y|strong="H1571"\w* \w en|strong="H5921"\w* \w el|strong="H1931"\w* caso \w de|strong="H4480"\w* una \w guerra|strong="H4421"\w*, \w se|strong="H1961"\w* unan \w también|strong="H1571"\w* \w con|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* \w nos|strong="H5921"\w* \w aborrecen|strong="H8130"\w*, luchen \w contra|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w y|strong="H1571"\w* \w se|strong="H1961"\w* vayan \w de|strong="H4480"\w* \w esta|strong="H1931"\w* tierra.   
\p
\v 11 Entonces \w les|strong="H5921"\w* impusieron capataces \w de|strong="H5921"\w* trabajos forzados \w para|strong="H4616"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* oprimieran \w con|strong="H5921"\w* sus cargas. Así \w se|strong="H5921"\w* \w edificaron|strong="H1129"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5921"\w* almacenaje Pitón \w y|strong="H5921"\w* Ramsés \w para|strong="H4616"\w* \w Faraón|strong="H6547"\w*.  
\v 12 Pero \w cuanto|strong="H3651"\w* \w más|strong="H7235"\w* \w los|strong="H1121"\w* oprimían, \w más|strong="H7235"\w* \w se|strong="H3651"\w* multiplicaban y esparcían, hasta \w que|strong="H1121"\w* \add los egipcios\add* sintieron aversión \w hacia|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*.  
\v 13 \w Los|strong="H1121"\w* \w egipcios|strong="H4713"\w* obligaron con dureza \w a|strong="H3068"\w* trabajar \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.  
\v 14 Amargaron su \w vida|strong="H2416"\w* con \w el|strong="H3605"\w* \w duro|strong="H7186"\w* trabajo de preparar arcilla y hacer \w ladrillos|strong="H3843"\w*, con \w toda|strong="H3605"\w* \add clase\add* de \w labores|strong="H5656"\w* del \w campo|strong="H7704"\w* y trabajos \w que|strong="H3605"\w* les imponían con rigor.   
\p
\v 15 Entonces el \w rey|strong="H4428"\w* de \w Egipto|strong="H4714"\w* habló \w a|strong="H3068"\w* las parteras de las \w hebreas|strong="H5680"\w*, una de las cuales se \w llamaba|strong="H8034"\w* Sifra, y la \w otra|strong="H8145"\w* Fúa,  
\v 16 \w y|strong="H5921"\w* dijo: Cuando asistan \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w mujeres|strong="H1323"\w* \w hebreas|strong="H5680"\w* \w en|strong="H5921"\w* \w sus|strong="H1931"\w* partos, \w al|strong="H5921"\w* observar \w en|strong="H5921"\w* \w la|strong="H1931"\w* silla \w de|strong="H5921"\w* parto \w que|strong="H1931"\w* \w es|strong="H1931"\w* un \w hijo|strong="H1121"\w*, mátenlo, \w y|strong="H5921"\w* \w si|strong="H1931"\w* \w es|strong="H1931"\w* una \w hija|strong="H1323"\w*, \w que|strong="H1931"\w* viva.   
\p
\v 17 Pero las parteras \w temieron|strong="H3372"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd*, y \w no|strong="H3808"\w* \w hicieron|strong="H6213"\w* según \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w el|strong="H6213"\w* \w rey|strong="H4428"\w* \w de|strong="H3372"\w* \w Egipto|strong="H4714"\w* les ordenó, \w sino|strong="H3808"\w* dejaron \w vivir|strong="H2421"\w* \w a|strong="H3068"\w* los \w niños|strong="H3206"\w*.   
\p
\v 18 \w El|strong="H6213"\w* \w rey|strong="H4428"\w* egipcio \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* las parteras y les dijo: ¿\w Por|strong="H4069"\w* \w qué|strong="H1697"\w* \w hacen|strong="H6213"\w* \w esto|strong="H2088"\w* \w de|strong="H1697"\w* dejar \w vivir|strong="H2421"\w* \w a|strong="H3068"\w* los \w niños|strong="H3206"\w*?   
\p
\v 19 Las parteras respondieron \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w*: \w Porque|strong="H3588"\w* las mujeres \w hebreas|strong="H5680"\w* \w no|strong="H3808"\w* \w son|strong="H3588"\w* \w como|strong="H3588"\w* las egipcias, \w pues|strong="H3588"\w* \w son|strong="H3588"\w* vigorosas \w y|strong="H3588"\w* dan \w a|strong="H3068"\w* luz \w antes|strong="H3588"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* partera llegue \w a|strong="H3068"\w* \w ellas|strong="H2007"\w*.   
\p
\v 20 El \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* \w multiplicó|strong="H7235"\w* y \w se|strong="H5971"\w* fortaleció muchísimo. \nd ʼElohim\nd* favoreció \w a|strong="H3068"\w* las parteras.  
\v 21 \w Por|strong="H3588"\w* \w haber|strong="H1961"\w* \w temido|strong="H3372"\w* las parteras \w a|strong="H3068"\w* \nd ʼElohim\nd*, \w Él|strong="H3588"\w* les concedió \w familias|strong="H1004"\w* \w a|strong="H3068"\w* ellas.   
\p
\v 22 Entonces \w Faraón|strong="H6547"\w* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* su \w pueblo|strong="H5971"\w*: Echen al Nilo \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w hijo|strong="H1121"\w* \w que|strong="H5971"\w* nazca, pero \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w hija|strong="H1323"\w* sálvenle \w la|strong="H3605"\w* \w vida|strong="H2421"\w*.   
\c 2  
\s1 Moisés  
\p
\v 1 Un varón del linaje de \w Leví|strong="H3878"\w* \w tomó|strong="H3947"\w* como esposa \w a|strong="H3068"\w* una \w hija|strong="H1323"\w* de \w Leví|strong="H3878"\w*.  
\v 2 \w La|strong="H1931"\w* esposa \w concibió|strong="H2029"\w* \w y|strong="H3588"\w* dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*. Al \w ver|strong="H7200"\w* \w que|strong="H3588"\w* \w era|strong="H1121"\w* \w hermoso|strong="H2896"\w* \w lo|strong="H1931"\w* escondió \w tres|strong="H7969"\w* \w meses|strong="H3391"\w*.  
\v 3 Pero cuando \w no|strong="H3808"\w* \w pudo|strong="H3201"\w* ocultarlo \w más|strong="H5750"\w* tiempo, \w tomó|strong="H3947"\w* una cesta \w de|strong="H5921"\w* juncos, \w la|strong="H5921"\w* calafateó \w con|strong="H5921"\w* asfalto \w y|strong="H5921"\w* brea, acostó \w al|strong="H5921"\w* niño \w en|strong="H5921"\w* \w ella|strong="H5921"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* ubicó \w en|strong="H5921"\w* \w el|strong="H5921"\w* juncal \w a|strong="H3068"\w* \w la|strong="H5921"\w* orilla \w del|strong="H5921"\w* Nilo.  
\v 4 Su hermana \w se|strong="H3045"\w* colocó \w a|strong="H3068"\w* \w lo|strong="H4100"\w* \w lejos|strong="H7350"\w* \w para|strong="H3320"\w* ver \w qué|strong="H4100"\w* le sucedería.   
\p
\v 5 Entonces \w la|strong="H5921"\w* \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w* bajó \w al|strong="H5921"\w* Nilo \w para|strong="H5921"\w* bañarse. Mientras sus \w doncellas|strong="H5291"\w* caminaban \w junto|strong="H5921"\w* \w al|strong="H5921"\w* Nilo, \w ella|strong="H5921"\w* \w vio|strong="H7200"\w* \w la|strong="H5921"\w* cesta \w entre|strong="H8432"\w* \w los|strong="H5921"\w* juncos \w y|strong="H5921"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* su esclava \w a|strong="H3068"\w* recogerla.  
\v 6 Cuando \w la|strong="H5921"\w* \w abrió|strong="H6605"\w* ahí \w estaba|strong="H2009"\w* \w el|strong="H5921"\w* \w niño|strong="H5288"\w* \w llorando|strong="H1058"\w*. Tuvo compasión \w de|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* dijo: ¡\w Éste|strong="H2088"\w* \w es|strong="H2088"\w* uno \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w niños|strong="H5288"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w hebreos|strong="H5680"\w*!   
\p
\v 7 Entonces la hermana \add de Moisés\add* le dijo \w a|strong="H3068"\w* la \w hija|strong="H1323"\w* \w de|strong="H4480"\w* \w Faraón|strong="H6547"\w*: ¿Quiere usted \w que|strong="H4480"\w* \w llame|strong="H7121"\w* \w a|strong="H3068"\w* una madre \w de|strong="H4480"\w* crianza \w de|strong="H4480"\w* las \w hebreas|strong="H5680"\w* \w para|strong="H4480"\w* \w que|strong="H4480"\w* le amamante este niño?   
\p
\v 8 \w Y|strong="H3068"\w* la \w hija|strong="H1323"\w* de \w Faraón|strong="H6547"\w* le respondió: \w Vé|strong="H3212"\w*. Entonces la muchacha \w fue|strong="H3212"\w* y \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* la madre del niño.   
\p
\v 9 La \w hija|strong="H1323"\w* \w de|strong="H5414"\w* \w Faraón|strong="H6547"\w* le dijo: \w Lleva|strong="H3212"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* niño, amamántamelo y yo te \w pagaré|strong="H5414"\w* tu \w salario|strong="H7939"\w*.  
\p \w Así|strong="H2088"\w* \w que|strong="H2088"\w* la mujer \w tomó|strong="H3947"\w* al niño y \w lo|strong="H2088"\w* amamantó.  
\v 10 \w El|strong="H3588"\w* niño \w creció|strong="H1431"\w*. \w Ella|strong="H4480"\w* lo llevó \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w hija|strong="H1323"\w* \w de|strong="H4480"\w* \w Faraón|strong="H6547"\w* \w y|strong="H3588"\w* \w fue|strong="H1961"\w* \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w ésta|strong="H1961"\w*. Lo \w llamó|strong="H7121"\w* \w Moisés|strong="H4872"\w*: \w Porque|strong="H3588"\w* lo saqué \w del|strong="H4480"\w* \w agua|strong="H4325"\w*.   
\s1 Huida a Madián  
\p
\v 11 \w Sucedió|strong="H1961"\w* \w en|strong="H3318"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* \w cuando|strong="H3117"\w* \w Moisés|strong="H4872"\w* \w creció|strong="H1431"\w* \w que|strong="H3117"\w* \w salió|strong="H3318"\w* \w a|strong="H3068"\w* \w ver|strong="H7200"\w* \w a|strong="H3068"\w* \w sus|strong="H1992"\w* hermanos y observó \w sus|strong="H1992"\w* duros trabajos. \w Vio|strong="H7200"\w* \w a|strong="H3068"\w* un \w egipcio|strong="H4713"\w* \w que|strong="H3117"\w* azotaba \w a|strong="H3068"\w* uno de \w sus|strong="H1992"\w* hermanos \w hebreos|strong="H5680"\w*.  
\v 12 \w Él|strong="H3588"\w* \w miró|strong="H7200"\w* \w a|strong="H3068"\w* uno \w y|strong="H3588"\w* otro lado, \w y|strong="H3588"\w* al \w ver|strong="H7200"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* estaba alguno, asesinó al \w egipcio|strong="H4713"\w* \w y|strong="H3588"\w* lo \w escondió|strong="H2934"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* arena.   
\p
\v 13 Al \w día|strong="H3117"\w* \w siguiente|strong="H8145"\w* \w salió|strong="H3318"\w*, y ahí estaban \w dos|strong="H8147"\w* \w hebreos|strong="H5680"\w* peleando. Dijo al agresor: ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* golpeas \w a|strong="H3068"\w* tu \w prójimo|strong="H7453"\w*?   
\p
\v 14 \w Él|strong="H5921"\w* respondió: ¿\w Quién|strong="H4310"\w* \w te|strong="H5921"\w* designó \w como|strong="H5921"\w* \w príncipe|strong="H8269"\w* \w y|strong="H5921"\w* \w juez|strong="H8199"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*? ¿Piensas asesinarme \w como|strong="H5921"\w* asesinaste \w al|strong="H5921"\w* \w egipcio|strong="H4713"\w*? Entonces \w Moisés|strong="H4872"\w* \w tuvo|strong="H3372"\w* \w temor|strong="H3372"\w* \w y|strong="H5921"\w* dijo: ¡Ciertamente \w el|strong="H5921"\w* \w asunto|strong="H1697"\w* fue \w conocido|strong="H3045"\w*!   
\p
\v 15 Cuando \w Faraón|strong="H6547"\w* \w oyó|strong="H8085"\w* \w este|strong="H2088"\w* \w asunto|strong="H1697"\w*, \w procuró|strong="H1245"\w* matar \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.  
\p Pero \w Moisés|strong="H4872"\w* \w huyó|strong="H1272"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w presencia|strong="H6440"\w* \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w*. Fue \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Madián|strong="H4080"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* sentó \w junto|strong="H5921"\w* \w a|strong="H3068"\w* un pozo.   
\p
\v 16 El \w sacerdote|strong="H3548"\w* de \w Madián|strong="H4080"\w* tenía \w siete|strong="H7651"\w* \w hijas|strong="H1323"\w*, las cuales llegaron \w a|strong="H3068"\w* sacar agua para llenar las piletas \w a|strong="H3068"\w* fin de dar de \w beber|strong="H8248"\w* al \w rebaño|strong="H6629"\w* de su padre.  
\v 17 Pero llegaron los \w pastores|strong="H7462"\w* y las echaron. Entonces \w Moisés|strong="H4872"\w* se \w levantó|strong="H6965"\w*, las ayudó y abrevó el \w rebaño|strong="H6629"\w* de ellas.   
\p
\v 18 \w Cuando|strong="H3117"\w* ellas regresaron \w a|strong="H3068"\w* su padre \w Reuel|strong="H7467"\w*, éste les preguntó: ¿\w Por|strong="H4069"\w* \w qué|strong="H3117"\w* vinieron tan \w pronto|strong="H4116"\w* \w hoy|strong="H3117"\w*?   
\p
\v 19 Ellas respondieron: Un varón \w egipcio|strong="H4713"\w* nos \w libró|strong="H5337"\w* de \w mano|strong="H3027"\w* de los \w pastores|strong="H7462"\w*, \w y|strong="H1571"\w* \w aun|strong="H1571"\w* \w más|strong="H1571"\w*, nos \w sacó|strong="H1802"\w* \w el|strong="H1571"\w* agua \w y|strong="H1571"\w* abrevó \w el|strong="H1571"\w* \w rebaño|strong="H6629"\w*.   
\p
\v 20 \w Y|strong="H3068"\w* dijo \w a|strong="H3068"\w* sus \w hijas|strong="H1323"\w*: ¿Dónde \w está|strong="H2088"\w* él? ¿\w Por|strong="H2088"\w* \w qué|strong="H4100"\w* abandonaron \w a|strong="H3068"\w* \w ese|strong="H2088"\w* hombre? Llámenlo para \w que|strong="H4100"\w* coma \w pan|strong="H3899"\w*.   
\p
\v 21 \w Moisés|strong="H4872"\w* aceptó vivir con aquel hombre. Éste le \w dio|strong="H5414"\w* \w a|strong="H3068"\w* su \w hija|strong="H1323"\w* Séfora como esposa.   
\p
\v 22 Ella le dio \w a|strong="H3068"\w* luz un \w hijo|strong="H1121"\w*. \w Él|strong="H3588"\w* lo \w llamó|strong="H7121"\w* Gersón, \w pues|strong="H3588"\w* dijo: Vine \w a|strong="H3068"\w* ser \w forastero|strong="H5237"\w* \w en|strong="H3588"\w* tierra \w extraña|strong="H5237"\w*.   
\p
\v 23 \w Después|strong="H1961"\w* \w de|strong="H4480"\w* \w muchos|strong="H7227"\w* \w días|strong="H3117"\w* \w sucedió|strong="H1961"\w* \w que|strong="H4480"\w* \w murió|strong="H4191"\w* \w el|strong="H1121"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w*.  
\p \w Los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* gemían \w a|strong="H3068"\w* causa \w de|strong="H4480"\w* la esclavitud y \w clamaron|strong="H2199"\w*. \w Por|strong="H4480"\w* causa \w de|strong="H4480"\w* \add su\add* esclavitud, \w su|strong="H1992"\w* \w clamor|strong="H7775"\w* \w subió|strong="H5927"\w* delante \w de|strong="H4480"\w* \nd ʼElohim\nd*.   
\p
\v 24 \nd ʼElohim\nd* \w oyó|strong="H8085"\w* su gemido y recordó su \w Pacto|strong="H1285"\w* con Abraham, \w Isaac|strong="H3327"\w* y \w Jacob|strong="H3290"\w*.  
\v 25 \nd ʼElohim\nd* \w miró|strong="H7200"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, y \w los|strong="H1121"\w* \w reconoció|strong="H3045"\w*.   
\c 3  
\s1 Llamamiento y comisión a Moisés  
\p
\v 1 \w Moisés|strong="H4872"\w* \w apacentaba|strong="H7462"\w* el \w rebaño|strong="H6629"\w* de su \w suegro|strong="H2859"\w* Jetro, \w sacerdote|strong="H3548"\w* de \w Madián|strong="H4080"\w*, y condujo el \w rebaño|strong="H6629"\w* al extremo del \w desierto|strong="H4057"\w*. Llegó \w a|strong="H3068"\w* \w Horeb|strong="H2722"\w*, la Montaña de \nd ʼElohim\nd*.   
\p
\v 2 Entonces el \w Ángel|strong="H4397"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd* se le \w apareció|strong="H7200"\w* \w en|strong="H8432"\w* una llama de fuego \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de una zarza. Él \w vio|strong="H7200"\w* que \w la|strong="H1197"\w* zarza \w ardía|strong="H1197"\w* con fuego, pero no se consumía.   
\p
\v 3 \w Y|strong="H3068"\w* \w Moisés|strong="H4872"\w* dijo: Me desviaré \w y|strong="H1197"\w* observaré \w esta|strong="H2088"\w* \w gran|strong="H1419"\w* aparición. \w Por|strong="H4069"\w* \w qué|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* consume \w la|strong="H1197"\w* zarza.   
\p
\v 4 \w Cuando|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w él|strong="H3588"\w* se desviaba \w para|strong="H3588"\w* observar, lo \w llamó|strong="H7121"\w* \w de|strong="H3588"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* zarza \w y|strong="H3588"\w* le dijo: \wj ¡\+w Moisés|strong="H4872"\+w*! ¡\+w Moisés|strong="H4872"\+w*!\wj*  
\p \w Y|strong="H3068"\w* \w él|strong="H3588"\w* respondió: ¡\w Aquí|strong="H2009"\w* estoy!   
\p
\v 5 \w Entonces|strong="H3588"\w* \w Él|strong="H1931"\w* \w le|strong="H1931"\w* dijo: \wj \+w No|strong="H3588"\+w* \+w te|strong="H5921"\+w* acerques \+w acá|strong="H1988"\+w*. \+w Quita|strong="H5394"\+w* \+w las|strong="H5921"\+w* sandalias \+w de|strong="H5921"\+w* tus \+w pies|strong="H7272"\+w*, \+w porque|strong="H3588"\+w* \+w el|strong="H1931"\+w* \+w lugar|strong="H4725"\+w* \+w donde|strong="H5921"\+w* \+w estás|strong="H5975"\+w* parado \+w es|strong="H1931"\+w* suelo \+w santo|strong="H6944"\+w*.\wj*  
\v 6 También le dijo: \wj \+w Yo|strong="H3588"\+w* soy \+w el|strong="H3588"\+w* \+nd ʼElohim\+nd* \+w de|strong="H3588"\+w* tu padre, \+w de|strong="H3588"\+w* Abraham, \+w Isaac|strong="H3327"\+w* \+w y|strong="H3588"\+w* \+w Jacob|strong="H3290"\+w*.\wj*  
\p \w Entonces|strong="H3588"\w* \w Moisés|strong="H4872"\w* \w ocultó|strong="H5641"\w* \w su|strong="H3588"\w* \w rostro|strong="H6440"\w*, \w porque|strong="H3588"\w* \w tuvo|strong="H3372"\w* \w temor|strong="H3372"\w* \w de|strong="H3588"\w* mirar \w a|strong="H3068"\w* \nd ʼElohim\nd*.   
\p
\v 7 \w Y|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* dijo: \wj \+w Ciertamente|strong="H3588"\+w* \+w vi|strong="H7200"\+w* \+w la|strong="H3588"\+w* \+w aflicción|strong="H6040"\+w* \+w de|strong="H3588"\+w* mi \+w pueblo|strong="H5971"\+w* \+w que|strong="H3588"\+w* está \+w en|strong="H3588"\+w* \+w Egipto|strong="H4714"\+w*, \+w y|strong="H3588"\+w* \+w escuché|strong="H8085"\+w* \+w su|strong="H3588"\+w* \+w clamor|strong="H6818"\+w* \+w por|strong="H3588"\+w* \+w causa|strong="H6440"\+w* \+w de|strong="H3588"\+w* sus opresores, \+w porque|strong="H3588"\+w* \+w conozco|strong="H3045"\+w* sus padecimientos.\wj*  
\v 8 \wj \+w Así|strong="H1931"\+w* \+w que|strong="H4480"\+w* \+w descendí|strong="H3381"\+w* \+w para|strong="H4480"\+w* librarlos \+w del|strong="H4480"\+w* \+w poder|strong="H3027"\+w* \+w de|strong="H4480"\+w* \+w los|strong="H1931"\+w* \+w egipcios|strong="H4713"\+w* y llevarlos \+w de|strong="H4480"\+w* \+w esa|strong="H1931"\+w* tierra \+w a|strong="H3068"\+w* una tierra \+w buena|strong="H2896"\+w* y \+w espaciosa|strong="H7342"\+w* \+w que|strong="H4480"\+w* \+w fluye|strong="H2100"\+w* \+w leche|strong="H2461"\+w* y \+w miel|strong="H1706"\+w*, \+w al|strong="H4480"\+w* \+w lugar|strong="H4725"\+w* \+w del|strong="H4480"\+w* \+w cananeo|strong="H3669"\+w*, \+w del|strong="H4480"\+w* heteo, \+w del|strong="H4480"\+w* amorreo, \+w del|strong="H4480"\+w* ferezeo, \+w del|strong="H4480"\+w* \+w heveo|strong="H2340"\+w* y \+w del|strong="H4480"\+w* \+w jebuseo|strong="H2983"\+w*.\wj*  
\v 9 \wj \+w Ahora|strong="H6258"\+w*, \+w mira|strong="H7200"\+w*, \+w el|strong="H1121"\+w* \+w clamor|strong="H6818"\+w* \+w de|strong="H1121"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w* llegó hasta \+w Mí|strong="H2009"\+w*. \+w También|strong="H1571"\+w* \+w vi|strong="H7200"\+w* \+w la|strong="H1571"\+w* \+w opresión|strong="H3906"\+w* \+w de|strong="H1121"\+w* \+w los|strong="H1121"\+w* \+w egipcios|strong="H4713"\+w* \+w contra|strong="H3478"\+w* \+w ellos|strong="H1571"\+w*.\wj*  
\v 10 \wj Por tanto te \+w enviaré|strong="H7971"\+w* \+w a|strong="H3068"\+w* \+w Faraón|strong="H6547"\+w* \+w para|strong="H6258"\+w* \+w que|strong="H6258"\+w* saques \+w de|strong="H1121"\+w* \+w Egipto|strong="H4714"\+w* \+w a|strong="H3068"\+w* mi \+w pueblo|strong="H5971"\+w*, \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*.\wj*   
\p
\v 11 \w Pero|strong="H3588"\w* \w Moisés|strong="H4872"\w* respondió \w a|strong="H3068"\w* \nd ʼElohim\nd*: ¿\w Quién|strong="H4310"\w* soy \w yo|strong="H3588"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w vaya|strong="H3212"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* \w y|strong="H3588"\w* \w saque|strong="H3318"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*?   
\p
\v 12 \w Y|strong="H3068"\w* \w Él|strong="H5921"\w* respondió: \wj \+w Ciertamente|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* estaré \+w contigo|strong="H5973"\+w*. \+w Ésta|strong="H2088"\+w* \+w será|strong="H1961"\+w* \+w la|strong="H5921"\+w* señal \+w de|strong="H5921"\+w* \+w que|strong="H3588"\+w* \+w te|strong="H5921"\+w* \+w envié|strong="H7971"\+w*: \+w Cuando|strong="H3588"\+w* saques \+w al|strong="H5921"\+w* \+w pueblo|strong="H5971"\+w* \+w de|strong="H5921"\+w* \+w Egipto|strong="H4714"\+w*, \+w servirán|strong="H5647"\+w* \+w a|strong="H3068"\+w* \+nd ʼElohim\+nd* \+w sobre|strong="H5921"\+w* \+w esta|strong="H2088"\+w* montaña.\wj*   
\p
\v 13 Entonces \w Moisés|strong="H4872"\w* dijo \w a|strong="H3068"\w* \nd ʼElohim\nd*: \w Cuando|strong="H4100"\w* vaya \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* y les diga: \w El|strong="H1121"\w* \nd ʼElohim\nd* \w de|strong="H1121"\w* sus antepasados me \w envió|strong="H7971"\w* \w a|strong="H3068"\w* ustedes, y ellos me pregunten: ¿\w Cuál|strong="H4100"\w* es su \w Nombre|strong="H8034"\w*? ¿\w Qué|strong="H4100"\w* les diré?   
\p
\v 14 \nd ʼElohim\nd* respondió \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj Yo \+w soy|strong="H1961"\+w* \+w el|strong="H1121"\+w* \+w que|strong="H1121"\+w* \+w soy|strong="H1961"\+w*.\wj* \w Y|strong="H3068"\w* añadió: \wj \+w Así|strong="H3541"\+w* dirás \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*: Yo \+w soy|strong="H1961"\+w* \+w me|strong="H3541"\+w* \+w envió|strong="H7971"\+w* \+w a|strong="H3068"\+w* ustedes.\wj*   
\p
\v 15 \w Además|strong="H5750"\w* \nd ʼElohim\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj \+w Así|strong="H3541"\+w* dirás \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H5750"\+w* \+w Israel|strong="H3478"\+w*: \wj*  
\q1 \wj \+nd \+w Yavé|strong="H3068"\+w*\+nd*, \+w el|strong="H1121"\+w* \+nd ʼElohim\+nd* \+w de|strong="H5750"\+w* sus antepasados, \+w de|strong="H5750"\+w* Abraham, \+w Isaac|strong="H3327"\+w* \+w y|strong="H3541"\+w* \+w Jacob|strong="H3290"\+w*, \+w me|strong="H3541"\+w* \+w envió|strong="H7971"\+w* \+w a|strong="H3068"\+w* ustedes. \wj*  
\q1 \wj \+w Éste|strong="H2088"\+w* \+w es|strong="H2088"\+w* mi \+w Nombre|strong="H8034"\+w* para \+w siempre|strong="H5769"\+w* \+w jamás|strong="H5769"\+w*, \wj*  
\q1 \wj \+w Y|strong="H3068"\+w* \+w éste|strong="H2088"\+w* \+w es|strong="H2088"\+w* mi memorial para \+w todas|strong="H1755"\+w* las \+w generaciones|strong="H1755"\+w*.\wj*   
\p
\v 16 \wj \+w Vé|strong="H3212"\+w*, reúne \+w a|strong="H3068"\+w* los \+w ancianos|strong="H2205"\+w* de \+w Israel|strong="H3478"\+w* y diles: \+nd \+w Yavé|strong="H3068"\+w*, ʼElohim\+nd* de sus antepasados, de Abraham, \+w Isaac|strong="H3327"\+w* y \+w Jacob|strong="H3290"\+w*, me \+w apareció|strong="H7200"\+w* y me dijo: \+w En|strong="H3212"\+w* verdad los visité y \+w vi|strong="H7200"\+w* \+w lo|strong="H6213"\+w* que se les \+w hace|strong="H6213"\+w* \+w en|strong="H3212"\+w* \+w Egipto|strong="H4714"\+w*.\wj*  
\v 17 \wj \+w Y|strong="H3068"\+w* dije: Los sacaré de la \+w aflicción|strong="H6040"\+w* de \+w Egipto|strong="H4714"\+w* \+w a|strong="H3068"\+w* la tierra del \+w cananeo|strong="H3669"\+w*, del heteo, del amorreo, del ferezeo, del \+w heveo|strong="H2340"\+w* y del \+w jebuseo|strong="H2983"\+w*, una tierra \+w que|strong="H2340"\+w* \+w fluye|strong="H2100"\+w* \+w leche|strong="H2461"\+w* y \+w miel|strong="H1706"\+w*.\wj*   
\p
\v 18 \wj \+w Ellos|strong="H5921"\+w* atenderán \+w lo|strong="H5921"\+w* \+w que|strong="H6258"\+w* tú dices. \+w Luego|strong="H4994"\+w* \+w irás|strong="H3212"\+w* tú \+w y|strong="H5921"\+w* \+w los|strong="H5921"\+w* \+w ancianos|strong="H2205"\+w* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w* ante \+w el|strong="H5921"\+w* \+w rey|strong="H4428"\+w* \+w de|strong="H5921"\+w* \+w Egipto|strong="H4714"\+w* \+w y|strong="H5921"\+w* \+w le|strong="H5921"\+w* dirán: \+nd \+w Yavé|strong="H3068"\+w*\+nd*, \+w el|strong="H5921"\+w* \+nd ʼElohim\+nd* \+w de|strong="H5921"\+w* \+w los|strong="H5921"\+w* \+w hebreos|strong="H5680"\+w*, \+w se|strong="H5921"\+w* encontró \+w con|strong="H5921"\+w* \+w nosotros|strong="H5921"\+w*. \+w Así|strong="H6258"\+w* \+w que|strong="H6258"\+w* \+w ahora|strong="H6258"\+w* \+w te|strong="H5921"\+w* rogamos \+w que|strong="H6258"\+w* \+w nos|strong="H5921"\+w* permitas \+w ir|strong="H3212"\+w* una jornada \+w de|strong="H5921"\+w* \+w tres|strong="H7969"\+w* \+w días|strong="H3117"\+w* \+w al|strong="H5921"\+w* \+w desierto|strong="H4057"\+w* \+w para|strong="H5921"\+w* ofrecer \+w sacrificios|strong="H2076"\+w* \+w a|strong="H3068"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* nuestro \+nd ʼElohim\+nd*.\wj*  
\v 19 \wj \+w Sin|strong="H3808"\+w* embargo, \+w Yo|strong="H3588"\+w* \+w sé|strong="H3045"\+w* \+w que|strong="H3588"\+w* \+w el|strong="H3588"\+w* \+w rey|strong="H4428"\+w* \+w de|strong="H3588"\+w* \+w Egipto|strong="H4714"\+w* \+w no|strong="H3808"\+w* \+w los|strong="H3588"\+w* \+w dejará|strong="H5414"\+w* salir, \+w sino|strong="H3588"\+w* forzado \+w por|strong="H3588"\+w* una \+w mano|strong="H3027"\+w* \+w poderosa|strong="H2389"\+w*.\wj*  
\v 20 \wj De manera \+w que|strong="H3605"\+w* \+w Yo|strong="H6213"\+w* extenderé mi \+w mano|strong="H3027"\+w*, golpearé \+w a|strong="H3068"\+w* Egipto con \+w todos|strong="H3605"\+w* mis prodigios \+w que|strong="H3605"\+w* \+w haré|strong="H6213"\+w* \+w en|strong="H5221"\+w* \+w medio|strong="H3027"\+w* de \+w él|strong="H3605"\+w*, y después de \+w esto|strong="H3651"\+w* \+w los|strong="H3605"\+w* dejará \+w ir|strong="H7971"\+w*.\wj*   
\p
\v 21 \wj Concederé \+w que|strong="H3588"\+w* \+w este|strong="H2088"\+w* \+w pueblo|strong="H5971"\+w* halle \+w gracia|strong="H2580"\+w* ante \+w los|strong="H1961"\+w* \+w egipcios|strong="H4713"\+w*. \+w Sucederá|strong="H1961"\+w* \+w que|strong="H3588"\+w* \+w cuando|strong="H3588"\+w* partan, \+w no|strong="H3808"\+w* \+w se|strong="H1961"\+w* \+w irán|strong="H3212"\+w* \+w vacíos|strong="H7387"\+w*,\wj*  
\v 22 \wj sino cada mujer \+w pedirá|strong="H7592"\+w* \+w a|strong="H3068"\+w* su vecina \+w y|strong="H5921"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H5921"\+w* huésped \+w de|strong="H5921"\+w* su \+w casa|strong="H1004"\+w* objetos \+w de|strong="H5921"\+w* \+w plata|strong="H3701"\+w* \+w y|strong="H5921"\+w* \+w de|strong="H5921"\+w* \+w oro|strong="H2091"\+w*, \+w y|strong="H5921"\+w* \+w ropa|strong="H8071"\+w*, \+w y|strong="H5921"\+w* \+w los|strong="H1121"\+w* \+w pondrán|strong="H7760"\+w* \+w sobre|strong="H5921"\+w* sus \+w hijos|strong="H1121"\+w* \+w e|strong="H3068"\+w* \+w hijas|strong="H1323"\+w*. Así despojarán \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* \+w egipcios|strong="H4713"\+w*.\wj*   
\c 4  
\s1 Misión de Moisés  
\p
\v 1 \w Entonces|strong="H3588"\w* \w Moisés|strong="H4872"\w* preguntó: ¿\w Y|strong="H3068"\w* \w qué|strong="H3588"\w* \add haré\add* \w si|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H3588"\w* creen \w ni|strong="H3808"\w* \w escuchan|strong="H8085"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* digo? \w Porque|strong="H3588"\w* ellos pueden \w decir|strong="H8085"\w*: \nd \+w Yavé|strong="H3068"\+w*\nd* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w te|strong="H3588"\w* \w apareció|strong="H7200"\w*.   
\p
\v 2 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* le dijo: \wj ¿\+w Qué|strong="H2088"\+w* \+w es|strong="H2088"\+w* eso \+w que|strong="H2088"\+w* tienes en tu \+w mano|strong="H3027"\+w*?\wj*  
\p \w Y|strong="H3068"\w* él respondió: Una \w vara|strong="H4294"\w*.   
\p
\v 3 \nd \+w Yavé|strong="H3068"\+w*\nd* le dijo: \wj Tírala al suelo.\wj*  
\p \w Y|strong="H3068"\w* él la tiró al suelo, y \w se|strong="H1961"\w* convirtió en una \w serpiente|strong="H5175"\w*. \w Moisés|strong="H4872"\w* \w huyó|strong="H5127"\w* \w de|strong="H6440"\w* ella.   
\p
\v 4 Pero \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj \+w Extiende|strong="H7971"\+w* tu \+w mano|strong="H3027"\+w* y atrápala \+w por|strong="H3027"\+w* la \+w cola|strong="H2180"\+w*. \wj*  
\p Él \w extendió|strong="H7971"\w* su \w mano|strong="H3027"\w* y la atrapó, y \w se|strong="H1961"\w* volvió una \w vara|strong="H4294"\w* en su \w mano|strong="H3027"\w*.   
\p
\v 5 \wj Esto \+w es|strong="H3588"\+w* \+w para|strong="H4616"\+w* \+w que|strong="H3588"\+w* crean \+w que|strong="H3588"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*, \+w el|strong="H3588"\+w* \+nd ʼElohim\+nd* \+w de|strong="H3588"\+w* tus antepasados, \+w de|strong="H3588"\+w* Abraham, \+w Isaac|strong="H3327"\+w* \+w y|strong="H3588"\+w* \+w Jacob|strong="H3290"\+w* se \+w te|strong="H3588"\+w* \+w apareció|strong="H7200"\+w*. \wj*   
\p
\v 6 \w Además|strong="H5750"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* le dijo: \wj Mete \+w ahora|strong="H4994"\+w* tu \+w mano|strong="H3027"\+w* \+w en|strong="H3318"\+w* tu \+w seno|strong="H2436"\+w*. \wj* \w Y|strong="H3068"\w* él metió su \w mano|strong="H3027"\w* \w en|strong="H3318"\w* su \w seno|strong="H2436"\w*, y cuando la \w sacó|strong="H3318"\w*, \w vio|strong="H2009"\w* \w que|strong="H4994"\w* su \w mano|strong="H3027"\w* \w estaba|strong="H2009"\w* leprosa \w como|strong="H5750"\w* la nieve.   
\p
\v 7 \w Entonces|strong="H7725"\w* le dijo: \wj Mete tu \+w mano|strong="H3027"\+w* \+w en|strong="H3318"\+w* tu \+w seno|strong="H2436"\+w* otra vez. \wj* \w Y|strong="H3068"\w* él \w volvió|strong="H7725"\w* \w a|strong="H3068"\w* meter su \w mano|strong="H3027"\w* \w en|strong="H3318"\w* su \w seno|strong="H2436"\w*, y cuando la \w sacó|strong="H3318"\w*, \w vio|strong="H2009"\w* \w que|strong="H3027"\w* \w estaba|strong="H2009"\w* restaurada.   
\p
\v 8 \wj \+w Sucederá|strong="H1961"\+w* \+w que|strong="H3808"\+w* \+w si|strong="H3808"\+w* \+w no|strong="H3808"\+w* te creen, \+w ni|strong="H3808"\+w* \+w obedecen|strong="H8085"\+w* la advertencia de la \+w primera|strong="H7223"\+w* señal, creerán la advertencia de la última. \wj*  
\v 9 \wj Pero \+w si|strong="H1571"\+w* \+w no|strong="H3808"\+w* creen \+w aún|strong="H1571"\+w* \+w a|strong="H3068"\+w* estas \+w dos|strong="H8147"\+w* señales, \+w ni|strong="H3808"\+w* \+w obedecen|strong="H8085"\+w* \+w lo|strong="H3808"\+w* \+w que|strong="H4480"\+w* dices, \+w entonces|strong="H1571"\+w* \+w tomarás|strong="H3947"\+w* \+w agua|strong="H4325"\+w* \+w del|strong="H4480"\+w* Nilo \+w y|strong="H1571"\+w* \+w la|strong="H1571"\+w* derramarás \+w sobre|strong="H4480"\+w* \+w tierra|strong="H3004"\+w* seca. \+w El|strong="H2975"\+w* \+w agua|strong="H4325"\+w* \+w que|strong="H4480"\+w* saques \+w del|strong="H4480"\+w* Nilo \+w se|strong="H1961"\+w* convertirá \+w en|strong="H4480"\+w* \+w sangre|strong="H1818"\+w* \+w sobre|strong="H4480"\+w* \+w la|strong="H1571"\+w* \+w tierra|strong="H3004"\+w* seca. \wj*   
