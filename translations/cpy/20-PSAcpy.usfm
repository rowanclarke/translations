\s1 Mampaantsi
\d Rojankinari David, ikantanaka Kamantantaniri Natán ishintsineentanakiri, tema riyotakoetakirowa rantakiro kaariperori imayempitakiro Betsabé
\q1 
\v 1 ¡Tajorentsi! Eeroka neshironkatantaniri, pikaminthahaena.
\q1 Tema eerokataki etakotantaniri, pipeyakoteenawo okaatzi nantakiri.
\v 2 Pipakaa-kahaenawo okaatzi kariperotakaakinari.
\q1 Poetenteena nokaariperotakira.
\q1 
\v 3 Niyotzi osheki nopiyathawaetakimi.
\q1 Tee omata nomaejantero nokaariperotakira.
\q1 
\v 4 Apatziro nokaariperotzimotakimi eeroka.
\q1 Nantashitakawo okaatzi pipinkakaanari.
\q1 Tema okaate pikanteeri eeroka, kametha otampatzikate,
\q1 Eeroka kiteshireri pimatantawori pipiyakowentantzi.
\q1 
\v 5 Tema kaariperotakina naaka, ari nokantzita owakira notzimapaaki.
\q1 Nokaariperotzita inthomoeki omotziki ashitanari, jaka anteetzirowa kaariperoyitatsiri.
\q1 
\v 6 Pineshironkatziri eeroka kameethashireri,
\q1 Piyo-shiryaakahaa-nawo piyotaninka.
\q1 
\v 7 Pikimitakaena poetetantyeenawomi kaawoshirontsi, eero nopitsiwaetanta.
\q1 Pikaawoshiteena, aritaki nokitamaatanee kameetha, ari nawijanakiro okaatzi okitamaatzi jiriniki.\f + \fr 51.7 \ft kaawoshirontsi = hisopo\f*
\q1 
\v 8 Pikantakaeyaawo nokemanteeyaawori jempe ikimoshireteetzi, eejatzi jempe ithaamenteeta.
\q1 Piwiriintapookiteena powatsinaawaetakina.
\q1 
\v 9 Pomanapithatyaawo nowaariperonka eero piñaantaawo,
\q1 Posheteenawo maawoeni owaariperotakinari.
\q1 
\v 10 ¡Tajorentsí! Poeteshireteena.
\q1 Powakirateenawo noshire, notampatzi-kashiretan-teeyaari.
\q1 
\v 11 Eero pookawentana,
\q1 Eero paapithatanawo Pitajorenka.
\q1 
\v 12 Papiiteero pinintaakahaena pikimitaakiro paerani owakira powawijaakotakina.
\q1 Potapi-shire-tantenawo roopirori Pitajorenka.
\q1 
\v 13 Rootaki niyotaanteeyaariri theenkimawaetzimiri okantakantziro tee ikemijanteemi eeroka,
\q1 Ipiyashitanteemiri eeroka kaariperoripaeni.
\q1 
\v 14 ¡Apaa Tajorentsi, Owawijaakotantaniri! Pipeyakoteenawo okaatzi nompojantaki.
\q1 Ari nomampaawenteemi riyoetantyaari eeroka tampatzikashireri.
\q1 
\v 15 ¡Tajorentsi! Pithaamenta-cheratakaena.
\q1 Nopinkatha-waante-tanteemiro nomampaani.
\q1 
\v 16 Tema te inimoteeme namashiwaetzimiri notayimiri natsipe-takaani.
\q1 Te pikowaeri okatziyeenkata iyachaarinka notaashiwaetzimiri.
\q1 
\v 17 Tema rootaki pikowaperoteeri eeroka Tajorentsi piñiina okatsi-tzimo-shire-teena okaatzi nantzimotzimiri.
\q1 Tema ikaatzi ikemitakaanteetari riiperori ratsipetakaetani itahaetziniriri Tajorentsi, riitaki atziri okatsi-tzimo-shiretziri iyaariperonka.
\q1 
\v 18 Paakameethateeri Kijakowentoni-jatzi, pineshironkateeri.
\q1 Papiiteero pipiriinteero otantopaeni Apatziyaweni.
\q1 
\v 19 Ari rinimoteemiri itahaetziri ratsipe-takaetani kameetha-pero-tatsiri,
\q1 Riitaki mapero-teeroni okatziyeenkate iyachaarinka itahaetemiri, maaroni ikaatzi rashitakaetzimiri itahaetziri.
\q1 Tema itahaeteemiri ipiraetari tahaerontsiki.\f + \fr 51.19 \ft ipiraetari = becerro\f*
