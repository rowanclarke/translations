\v 1 \w Aquel|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w*, \w el|strong="H1931"\w* \w rey|strong="H4428"\w* Asuero \w dio|strong="H5414"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Amán|strong="H2001"\w*, \w el|strong="H1931"\w* adversario \w de|strong="H3588"\w* \w los|strong="H1931"\w* \w judíos|strong="H3064"\w*, \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w reina|strong="H4436"\w* Ester. Mardoqueo \w fue|strong="H1931"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w presencia|strong="H6440"\w* del \w rey|strong="H4428"\w*, \w porque|strong="H3588"\w* Ester \w le|strong="H1931"\w* \w declaró|strong="H5046"\w* \w lo|strong="H1931"\w* \w que|strong="H3588"\w* \w él|strong="H1931"\w* \w era|strong="H1931"\w* \w con|strong="H3588"\w* respecto \w a|strong="H3068"\w* \w ella|strong="H1931"\w*.
