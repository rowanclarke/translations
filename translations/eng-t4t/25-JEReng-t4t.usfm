\v 3 “\w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* \w been|strong="H1961"\w* \w giving|strong="H1696"\w* \w me|strong="H4480"\w* \w messages|strong="H1697"\w* \w for|strong="H5704"\w* 23 \w years|strong="H8141"\w*. \w He|strong="H3117"\w* \w started|strong="H1961"\w* \w giving|strong="H1696"\w* \w me|strong="H4480"\w* \w messages|strong="H1697"\w* \w when|strong="H1961"\w* \w Josiah|strong="H2977"\w*, \w the|strong="H8085"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Amon, \w had|strong="H3068"\w* \w been|strong="H1961"\w* ruling \w Judah|strong="H3063"\w* \w for|strong="H5704"\w* \w almost|strong="H3117"\w* 13 \w years|strong="H8141"\w*. \w And|strong="H1121"\w* \w I|strong="H3117"\w* \w have|strong="H1961"\w* faithfully \w told|strong="H1696"\w* \w you|strong="H3117"\w* \w those|strong="H4480"\w* \w messages|strong="H1697"\w*, \w but|strong="H3808"\w* \w you|strong="H3117"\w* \w have|strong="H1961"\w* \w not|strong="H3808"\w* \w paid|strong="H8085"\w* \w any|strong="H4480"\w* \w attention|strong="H8085"\w* \w to|strong="H1696"\w* \w them|strong="H1961"\w*.   
\p
\v 4 \w Many|strong="H3808"\w* times \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* \w sent|strong="H7971"\w* \w to|strong="H3068"\w* \w you|strong="H3605"\w* \w the|strong="H3605"\w* \w prophets|strong="H5030"\w* \w who|strong="H3605"\w* served \w him|strong="H7971"\w*, \w but|strong="H3808"\w* \w you|strong="H3605"\w* \w have|strong="H3068"\w* \w not|strong="H3808"\w* \w listened|strong="H8085"\w* \w to|strong="H3068"\w* \w them|strong="H7971"\w* \w or|strong="H3808"\w* \w paid|strong="H8085"\w* \w any|strong="H3605"\w* \w attention|strong="H8085"\w* \w to|strong="H3068"\w* \w what|strong="H8085"\w* \w they|strong="H3068"\w* \w said|strong="H8085"\w*.  
\v 5 \w Each|strong="H5414"\w* \w time|strong="H5769"\w* \w their|strong="H3068"\w* \w message|strong="H3068"\w* \w was|strong="H3068"\w* \w this|strong="H5414"\w*: ‘\w Turn|strong="H7725"\w* \w from|strong="H4480"\w* \w all|strong="H5704"\w* \w your|strong="H3068"\w* \w evil|strong="H7451"\w* \w behavior|strong="H1870"\w* [MET], \w from|strong="H4480"\w* \w all|strong="H5704"\w* \w the|strong="H5921"\w* \w evil|strong="H7451"\w* \w things|strong="H7451"\w* \w that|strong="H3068"\w* \w you|strong="H5414"\w* \w have|strong="H3068"\w* \w continually|strong="H5769"\w* \w been|strong="H5769"\w* \w doing|strong="H1870"\w*. If \w you|strong="H5414"\w* \w do|strong="H3068"\w* \w that|strong="H3068"\w*, \w you|strong="H5414"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* able \w to|strong="H5704"\w* \w stay|strong="H3427"\w* \w in|strong="H3427"\w* \w this|strong="H5414"\w* land \w that|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w gave|strong="H5414"\w* \w to|strong="H5704"\w* \w you|strong="H5414"\w* \w and|strong="H3068"\w* \w to|strong="H5704"\w* \w your|strong="H3068"\w* ancestors, \add to belong to you\add* \w forever|strong="H5769"\w*.  
