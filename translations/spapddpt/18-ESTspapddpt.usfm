\c 1
\s1 Un banquete del rey Asuero
\p 
\v 1 \w Aconteció|strong="H1961"\w* \w en|strong="H5704"\w* \w los|strong="H1931"\w* \w días|strong="H3117"\w* \w de|strong="H5704"\w* Asuero, \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w reinó|strong="H4427"\w* \w desde|strong="H5704"\w* India \w hasta|strong="H5704"\w* \w Etiopía|strong="H3568"\w* \w sobre|strong="H1961"\w* 127 \w provincias|strong="H4082"\w*,
\v 2 \w cuando|strong="H3117"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w se|strong="H1992"\w* sentó \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w real|strong="H4428"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w capital|strong="H1002"\w* \w que|strong="H5921"\w* estaba \w en|strong="H5921"\w* Susa,
\v 3 en \w el|strong="H3605"\w* tercer \w año|strong="H8141"\w* \w de|strong="H6440"\w* su \w reinado|strong="H4427"\w*, \w hizo|strong="H6213"\w* un \w banquete|strong="H4960"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus magistrados y servidores. Tenía \w ante|strong="H6440"\w* \w él|strong="H3605"\w* al \w ejército|strong="H2426"\w* \w de|strong="H6440"\w* \w Persia|strong="H6539"\w* y \w Media|strong="H4074"\w*, \w los|strong="H3605"\w* nobles, y las autoridades \w de|strong="H6440"\w* las \w provincias|strong="H4082"\w*.
\p 
\v 4 Exhibió la \w gloria|strong="H3519"\w* de las \w riquezas|strong="H6239"\w* de su \w reino|strong="H4438"\w* \w y|strong="H3519"\w* la magnificencia de su poderío durante 180 \w días|strong="H3117"\w*.
\v 5 \w Cuando|strong="H3117"\w* \w se|strong="H5971"\w* cumplieron esos \w días|strong="H3117"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* brindó un \w banquete|strong="H4960"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5704"\w* estaba \w en|strong="H5704"\w* \w la|strong="H3605"\w* \w capital|strong="H1002"\w* Susa, tanto \w a|strong="H3068"\w* \w los|strong="H3605"\w* encumbrados \w como|strong="H5704"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* humildes, durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w* \w en|strong="H5704"\w* \w el|strong="H3605"\w* \w patio|strong="H2691"\w* del jardín del palacio \w real|strong="H4428"\w*.
\p 
\v 6 Había allí lienzos \w de|strong="H5921"\w* lino \w blanco|strong="H2353"\w* \w y|strong="H5921"\w* azul, colgados \w con|strong="H5921"\w* cordones púrpura \w a|strong="H3068"\w* \w anillos|strong="H1550"\w* \w de|strong="H5921"\w* \w plata|strong="H3701"\w* \w entre|strong="H5921"\w* \w columnas|strong="H5982"\w* \w de|strong="H5921"\w* mármol. \w Los|strong="H5921"\w* \w reclinatorios|strong="H4296"\w* eran \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w y|strong="H5921"\w* \w plata|strong="H3701"\w*, \w y|strong="H5921"\w* estaban \w sobre|strong="H5921"\w* un enlosado \w de|strong="H5921"\w* mosaicos verdes \w y|strong="H5921"\w* blancos \w con|strong="H5921"\w* incrustaciones \w de|strong="H5921"\w* nácar \w y|strong="H5921"\w* \w de|strong="H5921"\w* ónice.
\p 
\v 7 Conforme \w a|strong="H3068"\w* la generosidad del \w rey|strong="H4428"\w*, daban \w a|strong="H3068"\w* \w beber|strong="H8248"\w* \w vino|strong="H3196"\w* \w real|strong="H4428"\w* en abundancia, en copas \w de|strong="H8138"\w* \w oro|strong="H2091"\w* \w de|strong="H8138"\w* distintas clases.
\v 8 \w La|strong="H5921"\w* bebida era brindada \w según|strong="H5921"\w* \w lo|strong="H5921"\w* establecido, sin obligación, \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w dispuso|strong="H6213"\w* \w que|strong="H3588"\w* \w los|strong="H5921"\w* funcionarios \w de|strong="H5921"\w* \w su|strong="H3588"\w* palacio vieran \w que|strong="H3588"\w* \w cada|strong="H3605"\w* \w cual|strong="H3588"\w* hiciera \w según|strong="H5921"\w* \w su|strong="H3588"\w* propio gusto.
\p 
\v 9 \w También|strong="H1571"\w* \w la|strong="H1571"\w* \w reina|strong="H4436"\w* Vasti \w ofreció|strong="H6213"\w* un \w banquete|strong="H4960"\w* para las mujeres del palacio \w real|strong="H4428"\w* del \w rey|strong="H4428"\w* Asuero.
\s1 La reina Vasti
\p 
\v 10 \w Al|strong="H4428"\w* \w séptimo|strong="H7637"\w* \w día|strong="H3117"\w*, \w cuando|strong="H3117"\w* el \w rey|strong="H4428"\w* estaba \w alegre|strong="H2896"\w* \w a|strong="H3068"\w* \w causa|strong="H6440"\w* del \w vino|strong="H3196"\w*, ordenó \w a|strong="H3068"\w* Mehumán, Bizta, \w Harbona|strong="H2726"\w*, Bigta, Abagta, Zetar y Carcas, los \w siete|strong="H7651"\w* servidores del palacio \w que|strong="H3117"\w* servían \w al|strong="H4428"\w* \w rey|strong="H4428"\w* Asuero,
\v 11 \w que|strong="H3588"\w* condujeran \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w reina|strong="H4436"\w* Vasti \w ante|strong="H6440"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w*, adornada \w con|strong="H3588"\w* \w la|strong="H1931"\w* corona \w real|strong="H4428"\w*, \w para|strong="H3588"\w* mostrar \w su|strong="H1931"\w* belleza \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w gente|strong="H5971"\w* \w y|strong="H3588"\w* \w los|strong="H1931"\w* gobernantes, \w porque|strong="H3588"\w* \w ella|strong="H1931"\w* \w tenía|strong="H1931"\w* \w hermosa|strong="H2896"\w* \w apariencia|strong="H4758"\w*.
\v 12 Pero \w la|strong="H1197"\w* \w reina|strong="H4436"\w* Vasti se negó \w a|strong="H3068"\w* cumplir \w la|strong="H1197"\w* orden \w que|strong="H1697"\w* el \w rey|strong="H4428"\w* envió \w por|strong="H1697"\w* \w medio|strong="H3027"\w* \w de|strong="H1697"\w* los servidores del palacio. El \w rey|strong="H4428"\w* se indignó muchísimo \w por|strong="H1697"\w* \w esto|strong="H1697"\w* \w y|strong="H1197"\w* airó.
\p 
\v 13 \w Entonces|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* consultó \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w sabios|strong="H2450"\w* \w que|strong="H3588"\w* \w conocían|strong="H3045"\w* \w los|strong="H3605"\w* \w tiempos|strong="H6256"\w*, \w como|strong="H3588"\w* \w era|strong="H6256"\w* \w su|strong="H3588"\w* costumbre \w con|strong="H3588"\w* \w los|strong="H3605"\w* \w que|strong="H3588"\w* \w conocían|strong="H3045"\w* \w la|strong="H3588"\w* ley \w y|strong="H3588"\w* \w el|strong="H3588"\w* derecho.
\v 14 \w Los|strong="H3427"\w* más \w cercanos|strong="H7138"\w* eran \w Carsena|strong="H3771"\w*, Setar, Admata, \w Tarsis|strong="H8659"\w*, Meres, Marsena y \w Memucán|strong="H4462"\w*, \w los|strong="H3427"\w* \w siete|strong="H7651"\w* magistrados \w de|strong="H6440"\w* \w Persia|strong="H6539"\w* y \w Media|strong="H4074"\w*, quienes \w veían|strong="H7200"\w* \w el|strong="H3427"\w* \w rostro|strong="H6440"\w* del \w rey|strong="H4428"\w* y se sentaban como \w primeros|strong="H7223"\w* en \w el|strong="H3427"\w* \w reino|strong="H4438"\w*.
\p 
\v 15 \w Según|strong="H5921"\w* \w la|strong="H5921"\w* ley, ¿\w qué|strong="H4100"\w* debe hacerse \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w reina|strong="H4436"\w* Vasti \w porque|strong="H5921"\w* \w no|strong="H3808"\w* cumplió \w la|strong="H5921"\w* orden \w del|strong="H5921"\w* \w rey|strong="H4428"\w* Asuero enviada \w por|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* servidores \w del|strong="H5921"\w* palacio?
\p 
\v 16 \w Entonces|strong="H3588"\w* \w Memucán|strong="H4462"\w* respondió \w ante|strong="H6440"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w y|strong="H3588"\w* \w los|strong="H5921"\w* \w príncipes|strong="H8269"\w*: \w La|strong="H5921"\w* \w reina|strong="H4436"\w* Vasti \w no|strong="H3808"\w* faltó \w el|strong="H5921"\w* respeto \w solamente|strong="H3588"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w*, \w sino|strong="H3588"\w* también \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* gobernantes \w y|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w* \w que|strong="H3588"\w* están \w en|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w provincias|strong="H4082"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* Asuero.
\v 17 \w Porque|strong="H3588"\w* \w la|strong="H5921"\w* conducta \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w reina|strong="H4436"\w* llegará \w a|strong="H3068"\w* \w los|strong="H5921"\w* oídos \w de|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* mujeres, quienes podrían menospreciar \w a|strong="H3068"\w* sus esposos \w cuando|strong="H3588"\w* \w se|strong="H5921"\w* diga \w que|strong="H3588"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* Asuero ordenó \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w reina|strong="H4436"\w* Vasti \w que|strong="H3588"\w* \w se|strong="H5921"\w* presentara \w ante|strong="H6440"\w* \w él|strong="H5921"\w*, \w y|strong="H3588"\w* \w ella|strong="H5921"\w* \w no|strong="H3808"\w* quiso.
\p 
\v 18 En \w este|strong="H2088"\w* \w mismo|strong="H3605"\w* \w día|strong="H3117"\w* las princesas \w de|strong="H1697"\w* \w Persia|strong="H6539"\w* y \w de|strong="H1697"\w* \w Media|strong="H4074"\w*, enteradas del proceder \w de|strong="H1697"\w* \w la|strong="H3605"\w* \w reina|strong="H4436"\w*, podrán \w decir|strong="H8085"\w* \w lo|strong="H1697"\w* \w mismo|strong="H3605"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w príncipes|strong="H8269"\w* del \w rey|strong="H4428"\w*, \w de|strong="H1697"\w* modo \w que|strong="H1697"\w* se levantará una gran \w ira|strong="H7110"\w* y desprecio.
\p 
\v 19 \w Si|strong="H3808"\w* parece \w bien|strong="H2896"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w*, proclame un edicto \w real|strong="H4428"\w* \w que|strong="H4480"\w* sea \w escrito|strong="H3789"\w* \w entre|strong="H5921"\w* \w las|strong="H5921"\w* leyes \w de|strong="H4480"\w* \w Persia|strong="H6539"\w* \w y|strong="H5921"\w* \w Media|strong="H4074"\w* \w con|strong="H5921"\w* carácter irrevocable, \w que|strong="H4480"\w* Vasti \w no|strong="H3808"\w* comparezca \w más|strong="H4480"\w* \w ante|strong="H6440"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* Asuero, \w y|strong="H5921"\w* \w que|strong="H4480"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* otorgue su título \w de|strong="H4480"\w* \w reina|strong="H4428"\w* \w a|strong="H3068"\w* otra \w más|strong="H4480"\w* digna \w que|strong="H4480"\w* \w ella|strong="H4480"\w*.
\v 20 \w Cuando|strong="H3588"\w* \w el|strong="H1931"\w* edicto del \w rey|strong="H4428"\w* sea \w oído|strong="H8085"\w* \w en|strong="H5704"\w* \w todo|strong="H3605"\w* \w su|strong="H1931"\w* \w reino|strong="H4438"\w*, ¡\w que|strong="H3588"\w* \w siempre|strong="H3605"\w* sea \w grande|strong="H1419"\w*! \w todas|strong="H3605"\w* las \w mujeres|strong="H5704"\w* \w darán|strong="H5414"\w* \w honra|strong="H3366"\w* \w a|strong="H3068"\w* \w sus|strong="H1931"\w* esposos, tanto \w al|strong="H5704"\w* \w más|strong="H3588"\w* importante \w como|strong="H3588"\w* \w al|strong="H5704"\w* \w más|strong="H3588"\w* humilde.
\p 
\v 21 \w El|strong="H6213"\w* \w consejo|strong="H1697"\w* \w agradó|strong="H3190"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* y \w a|strong="H3068"\w* los magistrados, y \w el|strong="H6213"\w* \w rey|strong="H4428"\w* \w hizo|strong="H6213"\w* conforme \w a|strong="H3068"\w* la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* \w Memucán|strong="H4462"\w*.
\v 22 \w Envió|strong="H7971"\w* \w cartas|strong="H5612"\w* \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las \w provincias|strong="H4082"\w* del \w rey|strong="H4428"\w*, \w a|strong="H3068"\w* \w cada|strong="H3605"\w* \w provincia|strong="H4082"\w* según su escritura y \w a|strong="H3068"\w* \w cada|strong="H3605"\w* \w pueblo|strong="H5971"\w* según su \w lengua|strong="H3956"\w*, \w para|strong="H1961"\w* \w que|strong="H5971"\w* \w cada|strong="H3605"\w* varón \w fuera|strong="H1961"\w* jefe en su \w casa|strong="H1004"\w* y \w lo|strong="H5612"\w* difundiera según \w la|strong="H3605"\w* \w lengua|strong="H3956"\w* \w de|strong="H5971"\w* su \w pueblo|strong="H5971"\w*.
\c 2
\s1 Ester elegida reina
\p 
\v 1 \w Después|strong="H5921"\w* \w de|strong="H5921"\w* \w estas|strong="H6213"\w* \w cosas|strong="H1697"\w*, cuando \w la|strong="H5921"\w* \w ira|strong="H2534"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* Asuero \w se|strong="H5921"\w* aplacó, \w se|strong="H5921"\w* acordó \w de|strong="H5921"\w* Vasti, \w de|strong="H5921"\w* \w lo|strong="H1697"\w* \w que|strong="H5921"\w* \w ella|strong="H5921"\w* \w hizo|strong="H6213"\w* \w y|strong="H5921"\w* \w lo|strong="H1697"\w* \w que|strong="H5921"\w* \w él|strong="H5921"\w* decretó \w contra|strong="H5921"\w* \w ella|strong="H5921"\w*.
\p 
\v 2 Entonces los asistentes personales que servían \w al|strong="H4428"\w* \w rey|strong="H4428"\w* dijeron: Búsquense para el \w rey|strong="H4428"\w* muchachas \w vírgenes|strong="H1330"\w* de \w hermoso|strong="H2896"\w* \w parecer|strong="H4758"\w*.
\v 3 Designe \w el|strong="H3605"\w* \w rey|strong="H4428"\w* funcionarios en \w todas|strong="H3605"\w* las \w provincias|strong="H4082"\w* \w de|strong="H5414"\w* su \w reino|strong="H4438"\w* \w para|strong="H5414"\w* \w que|strong="H4082"\w* reúnan \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las jóvenes \w vírgenes|strong="H1330"\w* \w de|strong="H5414"\w* \w hermosa|strong="H2896"\w* \w apariencia|strong="H4758"\w* en \w la|strong="H8104"\w* \w capital|strong="H1002"\w* Susa, en \w el|strong="H3605"\w* harén, bajo \w la|strong="H8104"\w* custodia \w de|strong="H5414"\w* \w Hegai|strong="H1896"\w*, \w eunuco|strong="H5631"\w* del \w rey|strong="H4428"\w*, guardián \w de|strong="H5414"\w* las mujeres, y \w que|strong="H4082"\w* se les den sus atavíos.
\v 4 La joven \w que|strong="H1697"\w* sea agradable ante \w el|strong="H6213"\w* \w rey|strong="H4428"\w*, \w que|strong="H1697"\w* \w reine|strong="H4427"\w* \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* Vasti. \w El|strong="H6213"\w* \w consejo|strong="H1697"\w* \w agradó|strong="H3190"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, y \w lo|strong="H1697"\w* \w hizo|strong="H6213"\w* \w así|strong="H3651"\w*.
\p 
\v 5 \w Había|strong="H1961"\w* un varón \w judío|strong="H3064"\w* en la \w capital|strong="H1002"\w* Susa, \w llamado|strong="H8034"\w* Mardoqueo, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Jaír|strong="H2971"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Simei, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Cis|strong="H7027"\w*, \w benjamita|strong="H1121"\w*,
\v 6 quien \w fue|strong="H3063"\w* deportado \w de|strong="H5973"\w* Jerusalén \w con|strong="H5973"\w* \w los|strong="H5973"\w* \w cautivos|strong="H1473"\w* deportados \w con|strong="H5973"\w* Jeconías, \w rey|strong="H4428"\w* \w de|strong="H5973"\w* \w Judá|strong="H3063"\w*, \w a|strong="H3068"\w* quien \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5973"\w* Babilonia, llevó cautivo.
\v 7 \w Éste|strong="H1931"\w* crió \w a|strong="H3068"\w* Hadasa, \w que|strong="H3588"\w* \w es|strong="H1931"\w* Ester, \w hija|strong="H1323"\w* \w de|strong="H3588"\w* un \w tío|strong="H1730"\w* \w suyo|strong="H1931"\w*, \w porque|strong="H3588"\w* \w ella|strong="H1931"\w* \w no|strong="H3588"\w* \w tenía|strong="H1961"\w* padre ni madre. \w La|strong="H1931"\w* muchacha \w tenía|strong="H1961"\w* bella figura \w y|strong="H3588"\w* \w hermosa|strong="H3303"\w* \w apariencia|strong="H8389"\w*. \w Cuando|strong="H3588"\w* murieron \w su|strong="H1931"\w* padre \w y|strong="H3588"\w* \w su|strong="H1931"\w* madre, Mardoqueo \w la|strong="H1931"\w* \w tomó|strong="H3947"\w* \w como|strong="H3588"\w* \w hija|strong="H1323"\w* \w suya|strong="H1931"\w*.
\p 
\v 8 \w Cuando|strong="H1961"\w* \w se|strong="H1961"\w* divulgó \w la|strong="H8104"\w* orden del \w rey|strong="H4428"\w* y su edicto, \w aconteció|strong="H1961"\w* \w que|strong="H1697"\w* \w muchas|strong="H7227"\w* \w doncellas|strong="H5291"\w* \w fueron|strong="H1961"\w* reunidas en \w la|strong="H8104"\w* \w capital|strong="H1002"\w* Susa, bajo \w la|strong="H8104"\w* custodia \w de|strong="H1697"\w* \w Hegai|strong="H1896"\w*. Ester también \w fue|strong="H1961"\w* \w llevada|strong="H3947"\w* \w al|strong="H4428"\w* palacio \w real|strong="H4428"\w*, \w al|strong="H4428"\w* \w cuidado|strong="H3027"\w* \w de|strong="H1697"\w* \w Hegai|strong="H1896"\w*, guardián \w de|strong="H1697"\w* las mujeres.
\v 9 La joven halló \w gracia|strong="H2617"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* él, quien fue bondadoso con ella, \w por|strong="H6440"\w* lo cual se apresuró \w a|strong="H3068"\w* \w darle|strong="H5414"\w* sus atavíos y ungüentos. \w Le|strong="H5869"\w* asignó \w siete|strong="H7651"\w* \w doncellas|strong="H5291"\w* del palacio \w real|strong="H4428"\w* \w para|strong="H5414"\w* \w que|strong="H7651"\w* \w le|strong="H5869"\w* sirvieran, y la colocó con sus \w doncellas|strong="H5291"\w* en el \w mejor|strong="H2896"\w* lugar del harén.
\p 
