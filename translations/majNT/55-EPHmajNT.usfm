\id EPH Mazatec of Jalapa de Díaz 
\h Xu̱ju̱n xi kin'ekjíhi̱ xu̱ta̱ ni̱nku̱ Efe̱so̱ 
\toc1 Xu̱ju̱n xi kits'ínkjihi̱ nda̱ postru̱ Pablo̱ xu̱ta̱ ni̱nku̱ Efe̱so̱ 
\toc2 Xu̱ju̱n xi kin'ekjíhi̱ xu̱ta̱ ni̱nku̱ Efe̱so̱ 
\toc3 Ef. 
\mt1 Xu̱ju̱n xi kits'ínkjihi̱ nda̱ postru̱ Pablo̱ xu̱ta̱ ni̱nku̱ Efe̱so̱ 
\c 1  
\s1 B'i̱ ts'ín kikjaniñaha̱ Pablo̱ xu̱ta̱ ni̱nku̱ xi tjín nanki Efe̱so̱ 
\p  
\v 1 An Pablo̱, an xi kama nku nda̱ postru̱hu̱ Jesucristo̱ a̱t'aha̱ Nti̱a̱ná b'a̱ ts'ín kama mjehe̱. Tífaniñanu̱u jun xu̱ta̱ Efe̱so̱ xi kikj'áts'e̱nu̱u Nti̱a̱ná, jun xi s'ejinnu̱u Cristo̱ Jesu. 
\p  
\v 2 Kas'enu̱u kju̱a̱nda ko̱ kju̱a̱jyu xi tsjáná Nti̱a̱ Na̱'miná ko̱ Nda̱ Nti̱a̱ná Jesucristo̱. 
\s1 B'i̱ ts'ín tsakúya Pablo̱ kju̱a̱ndaha̱ Nti̱a̱ná 
\p  
\v 3 Kan'etsjoho̱ Nti̱a̱ná xi Nti̱a̱ha̱ ko̱ Na̱'mihi̱ Nda̱ Nti̱a̱ná Jesucristo̱. Kui xi kits'ín nga a̱jihi̱n Cristo̱ kisakúná ngayje tíkjá ni nda xi nibáha ndji̱o̱jmi ján, ni xi tsjáná Espiri̱tu̱hu̱.  
\v 4 Cristo̱ kits'ínchjén nga j'ájinná kintehe̱ ni nga kits'ínnda a̱sunntee̱ tu̱ xi kju̱áts'e̱he̱ná ko̱ tu̱ xi najmi s'e̱hená jé nginku̱n. Tjoho̱ Nti̱a̱ná ñá.  
\v 5 Kui nga y'énda títjuhun nga Jesucristo̱ ts'i̱ínchjéhen tu̱ xi ntíhi̱ tsichu mahaná. Tsitjusun xi nkú ts'ín kama tsjoho̱ ko̱ kama mjehe̱.  
\v 6 Kui nga kan'etsjoho̱ ra̱ Nti̱a̱ná xi bakúchji kju̱a̱nda chánkaha̱, kju̱a̱nda xi sakújinná Ntíhi̱ xi tu̱ xí tjohó ra̱. 
\p  
\v 7 Kisaténdzjo jníhi̱ Ntíu̱. B'a̱ ts'ín kis'echjíntjaihi jéná ko̱ kin'endyjat'aná ngatitsunná. Kama xi nkú tjín bichú kju̱a̱chánkaha̱ kju̱a̱ndaha̱ Nti̱a̱ná.  
\v 8 Kui kju̱a̱ndoo̱ xi tu̱ ni xí kitsjáháná tu̱ xi s'e̱hená ngayje tíkjá kju̱a̱nkjintak'un ko̱ tu̱ xi ka̱mankjihinná ni xi ts'e̱.  
\v 9 Y'éjña chjiná ni xi kama mjehe̱ nga ts'i̱ín, xi y'éjña 'ma ni̱stjin nk'ie. Kama tsjoho̱ nga y'énda títjun ni xi ts'i̱ín Cristo̱.  
\v 10 Y'énda nga nkuhú ku̱i̱chúk'iekú a̱jihi̱n Cristo̱ ngayjee̱ ni xi tsichuba ndji̱o̱jmi ján ko̱ a̱sunntee̱. B'a̱ ka̱ma nk'ie nga ja ku̱i̱chú chu̱ba̱. Ts'i̱íntjusun ni xi ja y'énda. 
\p  
\v 11 Xi nkú ts'ín y'énda títjun Nti̱a̱ná, b'a̱ ts'ín kits'ínchjén Cristo̱ tu̱ xi j'ájihi̱nni̱ ji̱n xi ntje̱ judio̱ tje̱he̱nni̱ ko̱ kitsjáni̱ ni xi tsjáha̱ ntíhi̱. B'a̱ kits'ín a̱t'aha̱ Nti̱a̱ná ts'íntjusun ngayjee̱ ni xi b'énda.  
\v 12 Ko̱ ji̱n kichuyái̱hi̱ ni nda xi sa̱kújinni̱ Cristo̱. Ji̱n tjun b'a̱ kin'ei̱. Kui nga tín'etsjoho̱ ra̱ Nti̱a̱ná xi tjíhi̱n kju̱a̱chánka. 
\p  
\v 13 Jun bi kinu'yó ko̱ kis'ejinnu̱u én xi na̱xu̱ tjín. Kui xi én nda tsuhu̱ Jesucristo̱ xi kits'ínk'ankinu̱u. Ko̱ Cristo̱ kits'ín nga kin'ekjóho̱on Espiri̱tu̱hu̱ Nti̱a̱ná, Espiri̱tu̱ xi kitsúya títjun nga tsjá. B'a̱ ts'ín kis'ejña chjihi nga Nti̱a̱ná ts'e̱nu̱u.  
\v 14 A̱t'aha̱ tsjá títjun Espiri̱tu̱hu̱ tu̱ xi cha̱ha nga n'e̱kjáíhi̱n ni xi tsjáha̱ ntíhi̱ nk'ie nga ka̱ma nda̱íyjehe̱ xu̱ta̱ xi ja kis'echjíntjai. Kui nga kan'etsjoho̱ ra̱ Nti̱a̱ná xi tjíhi̱n kju̱a̱chánka. 
\s1 B'i̱ ts'ín kinchja̱ntjai Pablo̱ xu̱ta̱ ni̱nku̱ nanki Efe̱so̱ 
\p  
\v 15 Kui b'a̱ maha, nkúhu nga kint'e nga s'ejinnu̱u Nda̱ Nti̱a̱ná Jesu ko̱ nga tjonu̱u ngayjee̱ xu̱ta̱ xi ts'e̱ Nti̱a̱ná,  
\v 16 najmi títs'inkj'áíya nga nchjantjáínu̱u nk'ie nga nchjaka̱ Nti̱a̱ná ko̱ tsjaha̱ máb'a̱chjíhi̱ nga nda tímat'on.  
\v 17 Tíbankihi̱ xi Nti̱a̱ha̱ Nda̱ Nti̱a̱ná Jesucristo̱, Na̱'mi xi tjíhi̱n kju̱a̱chánka, nga Espiri̱tu̱hu̱ katsjánu̱u kju̱a̱nkjintak'un ko̱ k'u̱éjña chjinu̱u ni xi ts'e̱, tu̱ xi ka̱mankjihi̱nnu̱u nkú tjíhi̱n ra̱ nga̱t'a ts'e̱ Nti̱a̱ná. 
\p  
\v 18 Tíbankihi̱ nga kakjex'ájin kju̱a̱nkjink'unnu̱u tu̱ xi cha̱hanu ni xi tíkuyáha̱ xu̱ta̱ xi Nti̱a̱ná j'ájihi̱n ko̱ tu̱ xi cha̱hanu xi nkú ts'ín chánka ni xi ts'i̱ínkjáíhi̱n xu̱ta̱ ts'e̱.  
\v 19 Mjena nga cho̱o xi nkú ts'ín chánka ts'ati nga'yúhu̱n Nti̱a̱ná, nga'yún xi basinko̱ná ñá xi s'ejinná éhe̱n. Kui nga'yún xu'bo̱ bakúchji ni xi ts'ín Nti̱a̱ná.  
\v 20 Kui xi kits'ínxájihi̱n Cristo̱ nk'ie nga Nti̱a̱ná kits'ínkj'áíyaha̱ ngabayoo̱ ko̱ kits'ínk'íéjñat'aha̱ Nti̱a̱ná nk'a ján, yo̱ má batéxuma. 
\p  
\v 21 Kitsjáha̱ a̱nte xi 'yún nk'a a̱jihi̱n ngayjee̱ xi batéxuma a̱sunntei̱ ko̱ xi tjíhi̱n xá, xi yankjún, xi nk'a tje̱n ko̱ xi tjíhi̱n tu̱ mí xáhá ni xi yankjún. Najmi tu̱ nku ni̱stjin xi kich'aá nd'a̱i̱ b'a̱ ts'ín nk'a tje̱n, ko̱ ní ni̱stjin xi kj'u̱a̱í a̱skahan.  
\v 22 Ngayjee̱ ni xi tjín a̱ya ntsja Cristo̱ y'éya Nti̱a̱ná ko̱ y'éjña títjun ya Cristo̱ nga ku̱a̱téxumaha̱ ngayjee̱ ni xi tjín ngandaha̱ xu̱ta̱ ni̱nku̱.  
\v 23 A̱t'aha̱ xu̱ta̱ ni̱nku̱, kui xi yjonintehe̱ Cristo̱ ko̱ Cristo̱ xi ts'ín nga ka̱ma ndju̱ú tu̱ mí nihí ni. Tsa ni xi najmi tjíhin xu̱ta̱ ni̱nku̱, najmi ma ndju̱ú Cristo̱ kai. 
\c 2  
\s1 B'i̱ ts'ín tsakúya Pablo̱ nk'ie nga n'ek'ankiná tu̱ nga̱t'aha̱ ni xi kits'ín Cristo̱ 
\p  
\v 1 Jun bi tu̱ nga̱t'aha̱ ngatitsunnu̱u ko̱ jénu̱u xu̱ta̱k'ien kamo.  
\v 2 Nk'ie tintsu̱ba̱jiun jénu̱u xi nkú ts'ín tíjñaha̱ xu̱ta̱ a̱sunnte xu'bi̱ ko̱ xi nkú ts'ín mjehe̱ nda̱ninda k'aku̱ xi tjíhi̱n nga'yún a̱jihi̱n sée̱n. Kui xi títs'ínxájihi̱n nd'a̱i̱ xu̱ta̱ xi najmi nt'é'éhe̱n Nti̱a̱ná. 
\p  
\v 3 Ngatenteé b'a̱ ta̱ n'e tintsu̱ba̱á ni̱stjin nk'ie xi nkú ts'ín kinchja̱ha̱ ani̱ma̱ná a̱sunntee̱. Kin'eé ni xi kama mjehe̱ ani̱ma̱ ngatitsunná ko̱ ni xi tjínjin kju̱a̱nkjink'unná. Xi nkú k'aán nk'ie, ñá tsuhuná kju̱a̱kjaha̱n Nti̱a̱ná xi nkúhu xu̱ta̱ xingisoo̱.  
\v 4 Tu̱nga tu̱ ni xí ma ni̱ma̱há ra̱ Nti̱a̱ná xu̱ta̱, kui nga 'yún kits'íntjohoná.  
\v 5 Kui kju̱a̱ha kits'ínk'íéntu tík'unko̱honá Cristo̱ nk'ie nga ja tsayaha̱á ngatitsunná. Nga̱t'aha̱ kju̱a̱ndaha̱ tu̱ títs'ínk'ankihínu̱u Nti̱a̱ná. 
\p  
\v 6 Nti̱a̱ná ta̱ ñja kits'ínkj'áíyako̱ná Cristo̱ ngabaya xi tintsu̱ba̱jián kai ko̱ kits'ínk'íéntuko̱ná Cristo̱ ndji̱o̱jmi ján.  
\v 7 B'a̱ kits'ín tu̱ xi ni̱stjin xi nibáha ku̱a̱kúchjihi xi nkú ts'ín chánka tíjña kju̱a̱ndaha̱, kui xi tu̱ xí ndahá, a̱t'aha̱ nda tsasená nga̱t'aha̱ ni xi kits'ín Cristo̱ Jesu.  
\v 8 Nga̱t'aha̱ kju̱a̱ndaha̱ Nti̱a̱ná ts'ankihinu a̱t'aha̱ kis'ejinnu̱u. Nti̱a̱ níná tu̱ kits'ínk'ankihínu̱u. Najmi jun manu̱u n'o ni xu'bi̱.  
\v 9 Najmi nga̱t'aha̱ ni nda xi kin'eé ts'ankihiná, tsa tu̱ xi b'a̱ ts'ín tjín xi nk'a k'u̱a̱sjehe yjoho̱.  
\v 10 Nti̱a̱ná kits'ínndaná. Y'éyaná xi nkúhu Cristo̱ nga kits'ínndaná tu̱ xi n'e̱hená ni xi nda xi y'énda títjun ko̱ tu̱ xi ku̱i̱ntsu̱ba̱jihinná ni xi ndoo̱. 
\s1 B'i̱ ts'ín tsakúya Pablo̱ nk'ie nga Cristo̱ nkuhú ntje̱ kits'ín ma xu̱ta̱ judio̱ ko̱ xi najmi judio̱ 
\p  
\v 11 Kui b'a̱ maha, jun xi najmi ntje̱ judio̱ kich'o nga kitsiun, n'e̱kj'áítsjehennu xi nkú n'e tintsu̱bo̱o ni̱stjin nk'ie. Xu̱ta̱ xi najmi kin'ehe̱ ni circuncision kitsúnu̱u xu̱ta̱ xi ntje̱ judio̱ tje̱he̱n ra̱, a̱t'aha̱ kui xi ts'íhi̱n yjoninintehe̱ ni circuncision.  
\v 12 N'e̱kj'áítsjon nga kui ni̱stjiu̱n tintsu̱ba̱ t'axíhu̱un Cristo̱ ko̱ nga najmi ntje̱he̱ xu̱ta̱ Israel jun. Najmi kama ts'a̱jun ni xi y'éndako̱ títjun Nti̱a̱ná xu̱ta̱ xi ts'e̱, ni xi kitsúya títjuhu̱n nga tsjáha̱. Ndaha nku ni xi tsjáha̱ Nti̱a̱ná xu̱ta̱ xi ts'e̱ najmi tíchuyóho̱o nga sa̱kúnu̱u kai. Chu̱ba̱ tintsu̱ba̱nú a̱sunntee̱ nga najmi yo Nti̱a̱ná.  
\v 13 Kjin tintsu̱bo̱o ni̱stjin nk'ie, tu̱nga nd'a̱i̱ nkuhú ja kamako̱o Cristo̱ Jesu ko̱ ja tintsu̱ba̱ tiño tu̱ nga̱t'aha̱ jní xi tsaténdzjo Cristo̱. 
\p  
\v 14 Nga̱t'aha̱ Cristo̱ tjíhinná kju̱a̱jyu. Kui xi nkuhú ntje̱ kits'ín ma xi ntje̱ judio̱ tje̱he̱n ra̱ ko̱ xi najmi ntje̱ judio̱ tje̱he̱n ra̱. Kikjexuba xjó xi y'échjaha̱ xu̱ta̱ nk'ie tu̱ xi nkuhú ka̱maha. Kikjexín ni xi ngji kontra̱ha̱ ra̱ xinkjín xu̱ta̱. Kitsjá yjonintehe̱  
\v 15 tu̱ xi y'éjña t'axíhin kju̱a̱téxuma xi kin'ekjas'ehe̱n Moise xi nkjin ni tjít'aha̱. B'a̱ ts'ín nkuhú ntje̱ tse̱tse̱ kits'ín maha nga joo̱ ko̱ nkuhú kits'ín mako̱ yjoho̱. Kits'ín nga tsichut'áha̱ xinkjín nga nkúnkú.  
\v 16 K'ient'á kruu̱ tu̱ xi nkuhú ntje̱ ts'i̱ín maha nga joo̱ ko̱ nga ku̱i̱nchja̱ko̱ nda ngáha Nti̱a̱ná. B'a̱ ts'ín kikjexíhin ni xi ngji kontra̱ha̱ ra̱ xinkjín xu̱ta̱. 
\p  
\v 17 Cristo̱ j'ai tsjá én nda tsu, kui xi y'a kju̱a̱jyu. B'a̱ ts'ín kisakúhu̱nu̱u kju̱a̱jyu jun xi kjin tintsu̱bo̱ho̱ Nti̱a̱ná ni̱stjin nk'ie ko̱ ta̱ kisakúhu̱ kju̱a̱jyu xi tiña tjíntu.  
\v 18 Nga̱t'aha̱ Cristo̱ xi ntje̱ judio̱ tje̱he̱n ra̱ ko̱ xi najmi ntje̱ judio̱ tje̱he̱n ra̱ ma bichút'aha̱ Nti̱a̱ná nd'a̱i̱. Nkuhú Espi̱ri̱tu̱hu̱ Nti̱a̱ná xi ts'ín nga bichút'aha̱á. 
\p  
\v 19 Kui b'a̱ maha, najmi ta̱ xu̱ta̱ kj'a̱íhinu ko̱ ta̱ ndaha xu̱ta̱ xi tjímasún. Ja ní tsichumo ko̱ jun xu̱ta̱ xi ts'e̱ Nti̱a̱ná ko̱ nkuhú ja mako̱o xu̱ta̱ xi tjíntunkí nk'íéhe̱n Nti̱a̱ná.  
\v 20 Jun xi nkú joyaha nku ni'ya xi tímanda, xi já postru̱ ko̱ já profeta̱ kik'atuts'i̱hi̱n. Tu̱nga Jesucristo̱hó kitsjá xáha̱ nga b'a̱ i̱ncha ts'i̱ín.  
\v 21 Cristo̱ be xi nkú ts'ín ngju̱a̱i̱ ni'yoo̱. Nk'ie nga ka̱ma ndju̱ú ni'yoo̱, nku ni̱nku̱ xi tsje ka̱maha̱ Nti̱a̱ná.  
\v 22 Jun xi y'aha̱nu̱u Cristo̱ bichúmo ni̱nku̱ xi má nga tíjñaya Espiri̱tu̱hu̱ Nti̱a̱ná. 
\c 3  
\s1 B'i̱ ts'ín kitsúya Pablo̱ xá xi kik'a̱i̱hi̱ 
\p  
\v 1 An Pablo̱ nga̱t'aha̱ Cristo̱ Jesu kjíi̱ya'yúhunna. B'a̱ tímat'an tu̱ nga̱t'aha̱ ngandanu̱u jun xi najmi ntje̱ judio̱ tje̱he̱nnu̱u.  
\v 2 Yo nga kik'a̱i̱na nga k'ueni̱jmínu̱u kju̱a̱ndaha̱ Nti̱a̱ná.  
\v 3 Tsakúchjina ni xi y'éjña 'ma ni̱stjin nk'ie, xi nkú nga ja ta̱ kuak'iet'ánu̱u.  
\v 4 Nk'ie nga n'e̱yo xu̱ju̱i̱n, cho̱o nga be sisian ni xi kis'ejña 'ma nga̱t'a ts'e̱ Cristo̱.  
\v 5 Kui niu̱ xi najmi kik'inyaha̱ xu̱ta̱ xi kis'e nú chá ján nk'ie, tu̱nga nd'a̱i̱ Espiri̱tu̱hu Nti̱a̱ná ja tsakúchjihi̱ já postru̱hu̱ ko̱ já profeta̱ha̱ Nti̱a̱ná  
\v 6 nk'ie nga xu̱ta̱ xi najmi ntje̱ judio̱ tje̱he̱n ra̱ ta̱ ts'i̱ínkjáíhi̱n ni xi tsjáha̱ Nti̱a̱ná ntíhi̱ ko̱ ta̱ ku̱i̱chú ma nku yjonintehe̱ Cristo̱ ko̱ ta̱ sa̱kú yaha̱ ni xi kitsúya títjun Nti̱a̱ná nga tsjáha̱ xu̱ta̱ xi ts'e̱. Én nda tsuhu̱ Cristo̱ xi b'a̱ ts'íu̱n. 
\p  
\v 7 Nti̱a̱ná tu̱ kitsjáhana nga k'ueni̱jmíá én nda tsu xu'bi̱. Kju̱a̱ndaha̱ Nti̱a̱ná xi b'a̱ kits'íu̱n. Kitsjána xi nkú ts'ín tje̱he̱n ra̱ nga'yún chánkaha̱.  
\v 8 An xi 'yún i̱chí sa a̱jihi̱n ngayjee̱ xu̱ta̱ xi ts'e̱ Nti̱a̱ná, tu̱nga kik'a̱i̱hína kju̱a̱ndaha̱ nga tíb'eni̱jmíhi̱ xu̱ta̱ xi najmi ntje̱ judio̱ tje̱he̱n ra̱ kju̱a̱nchi̱náha̱ Cristo̱ xi ndaha nku najmi ch'a mankjinyjehe̱.  
\v 9 Tíb'ejñá chja xi nkú ts'ín tíbitjusun ni xi y'éjña 'ma Nti̱a̱ná ni̱stjin nk'ie, kui xi kits'ínnda ngayjee̱ ni xi tjín.  
\v 10 B'a̱ ts'ín xu̱ta̱ ni̱nku̱ tíb'éjña chji nd'a̱i̱ xi nkú tjín kju̱a̱nkjink'uhu̱n Nti̱a̱ná, kju̱a̱nkjink'un xi kj'a̱í kj'a̱í ts'ín yaha̱. Kui ni xu'bi̱ tís'ejña chji nginku̱n xi tjíhi̱n xá ko̱ xi tjíhi̱n nga'yún nk'a ján. 
\p  
\v 11 Kui niu̱ xi y'énda títjun Nti̱a̱ná nkúhu ni̱stjin nk'ie ko̱ Nda̱ Nti̱a̱ná Jesucristo̱ ja kits'íntjusun niu̱ nd'a̱i̱.  
\v 12 A̱t'aha̱ nkuhú maka̱á Cristo̱ ko̱ a̱t'aha̱ s'ejinná én nda tsuhu̱, kui nga tsuhu̱ ra̱ tak'aán ko̱ najmi binkjaán nga bichúk'un tiñaha̱á Nti̱a̱ná.  
\v 13 Kui b'a̱ maha tíbankihi̱nu̱u nga najmi tu̱ n'ekjehe̱ ru̱u tak'un nga̱t'aha̱ nga un tíbena ngandanu̱u. Nga̱t'aha̱ nga un tíbena, Nti̱a̱ná títs'ín nga tís'ejña chjinu̱u kju̱a̱chánkaha̱. 
\s1 B'i̱ ts'ín kitsúya Pablo̱ xi nkú ts'ín bankintjáí xu̱ta̱ ni̱nku̱ Efe̱so̱ 
\p  
\v 14 Kui kju̱a̱ha báa̱si̱nkúnch'ihinna nginku̱n Nti̱a̱ Na̱'miná.  
\v 15 Kui xi b'éjña nga s'e nga nkúnkú ntje̱ xi tjín ndji̱o̱jmi ján ko̱ a̱sunntee̱.  
\v 16 Bankihi̱ nga Espiri̱tu̱hu̱ Nti̱a̱ná katsjá nga'yúnko̱ho̱nu̱u xi nkú ts'ín tíjña kju̱a̱chánka tsjo tjíhi̱n tu̱ xi s'e̱he̱ ra̱ nga'yún ani̱ma̱nu̱u,  
\v 17 ko̱ nga Cristo̱ kat'ejñajin ani̱ma̱nu̱u tu̱ nga̱t'aha̱ nga s'ejinnu̱u. Katji na̱nka̱ kja̱ma̱nu̱u a̱jihi̱n kju̱a̱tjoo̱ ko̱ ndjá ti̱nchajiun,  
\v 18 tu̱ xi b'a̱ ts'ín jun ko̱ ngayjee̱ xu̱ta̱ xi ts'e̱ Nti̱a̱ná ka̱ma ka̱mankjihi̱nnu̱u xi nkú ts'ín tayá ko̱ ndju ko̱ na̱nka̱ ko̱ nk'a kju̱a̱tjoho̱ Cristo̱.  
\v 19 Mjena nga cho̱o kju̱a̱tjoho̱ Cristo̱ tu̱ xi b'a̱ ts'ín katsejín kikjihi̱nnu̱u Nti̱a̱ná, ndaha tsa 'yún chánka sa kju̱a̱tjoho̱ nga ni xi mankjinná. 
\p  
\v 20 Kan'etsjoho̱ Nti̱a̱ná, kui xi ts'ati ni xi maha̱ ts'ín nga xi nkúhu ni xi binchihi̱í ko̱ tsa xi nkú ts'ín títsu ani̱ma̱ná nga ka̱ma. B'a̱ ma xi nkú ts'ín tíjña nga'yún xi ts'e̱ xi títs'ínxájinná.  
\v 21 Kats'ínkjáíhi̱n Nti̱a̱ná kju̱a̱chánka a̱jihi̱n xu̱ta̱ ni̱nku̱ xi ts'e̱ Cristo̱ Jesu. Tehe̱nte b'a̱ katuma ko̱ santaha tu̱ nk'éhé ni. Joho̱n, b'a̱ katuma. 
\c 4  
\s1 B'i̱ ts'ín tsakúya Pablo̱ nk'ie nga nkuhú tinchajián Cristo̱ 
\p  
\v 1 Kui b'a̱ maha tíbankihi̱nu̱u an xi kjíi̱ya'yán nga̱t'aha̱ Nda̱ Nti̱a̱ná. Kixi̱ tankínko̱o yjonu̱u xi nkú ts'ín tjíhin nga ts'i̱ín xu̱ta̱ xi Nti̱a̱ná j'ájihi̱n. A̱t'aha̱ Nti̱a̱ná j'ájinnu̱u.  
\v 2 Ni̱ma̱kju̱a̱ n'e̱sjo yjonu̱u ko̱ nda kas'eya ani̱ma̱nu̱u. Kas'enu̱u kju̱a̱tsenta ko̱ b'i̱ ngján n'e̱'yún tak'un xinki̱u. B'a̱ n'o̱o tu̱ nga̱t'aha̱ kju̱a̱tjo xi tíjñajinnu̱u.  
\v 3 Tjen nga'yúhu̱un yjonu̱u nga nkuhú katumako̱ tehe̱nto xinki̱u xi nkú ts'ín tsjáni̱yánu̱u Espiri̱tu̱hu̱ Nti̱a̱ná ko̱ xi nkú ts'ín nkuhú ts'ín manu̱u kju̱a̱jyuu̱. 
\p  
\v 4 Nkuhú maha yjonintehe̱ Cristo̱ ko̱ nkuhú maha Espiri̱tu̱hu̱ Nti̱a̱ná xi tíjña. B'a̱ ta̱ ts'ín nkuhú j'ájinnu̱u Nti̱a̱ná, kui nga nkuhú ni xi tíchuyóho̱o.  
\v 5 Nkuhú maha Nda̱ Nti̱a̱ xi tíjña. Nkuhú ni xi s'ejinná ko̱ nkuhú Nda̱ Nti̱a̱ná n'ekjas'ehe̱én xu̱ta̱ nga batentáha̱á.  
\v 6 Nkuhú maha Nti̱a̱ná xi Na̱'miná ngatenteé, kui xi batéxumaha̱, ts'ínchjén ko̱ tíjñajihi̱n ngayjee̱ ni xi tjín. 
\p  
\v 7 Tu̱nga kin'ekjáíhín ra̱á kju̱a̱nda nga nkúnkáá. Xi nkú ts'ín kits'índzjoná Cristo̱, b'a̱ ts'ín kisakúná.  
\v 8 Kui nga b'i̱ ts'ín tjít'aha éhe̱n Nti̱a̱ná: 
\q1 Ngjinji nk'a ján nga ngjiko̱ xi jakj'á, 
\q1 ko̱ tu̱ kitsjáhá ra̱ xu̱ta̱ ni xi nda. 
\m  
\v 9 ¿Nkú tsuhu̱ ra̱ nga ngjinji? Kui xi tsuhu̱ ra̱ nga tjun ngjijen má na̱nka̱ha̱ t'anankiu̱.  
\v 10 Ko̱ xi ngjijee̱n, kui xi ta̱ ngjinji má 'yún nk'aha̱ nk'a ján tu̱ xi ts'i̱íntjusuhun ngayjee̱ ni xi tsichuba. 
\p  
\v 11 Ko̱ kui kikjin xi kitsjá nga tjín xi ka̱ma já postru̱, ko̱ nga tjín xi ka̱ma já profeta̱, ko̱ nga tjín xi k'u̱éni̱jmí én nda tsuhu̱ Nti̱a̱ná, ko̱ nga tjín xi ka̱ma já bastuu̱ ko̱ já maestru̱.  
\v 12 Kui kju̱a̱ndoo̱ kik'a̱i̱hi̱ jóo̱ tu̱ xi ku̱a̱kúyaha̱ ra̱ xu̱ta̱ xi ts'e̱ Nti̱a̱ná xi nkú ts'ín ku̱a̱si̱nko̱ xinkjín ko̱ tu̱ xi b'a̱ ts'ín sa̱kú nga'yúhu̱n ra̱ xu̱ta̱ ni̱nku̱, kui xi yjonintehe̱ Cristo̱.  
\v 13 B'a̱ ts'ín nkuhú s'e̱jihinná ko̱ nkuhú cha̱á yáha Ntíhi̱ Nti̱a̱ná. Yo̱hó ni̱ ma ku̱i̱chú maá xi tjíhin nga ku̱i̱chú maá ko̱ s'e̱yaná xi nkúhu kui. 
\p  
\v 14 Nk'ie nga b'a̱ kamoo̱, najmi s'e̱yaná xi nkúhu jántí xi̱ xi kjit'a kjit'a kj'a̱í ts'ín s'eyaha̱ ko̱ najmi k'u̱a̱i̱nteé tsa tu̱ mí ni tse̱tse̱hé xi sa̱kúyaná, tsa kui niu̱ xi kjé'yúnná nga mjehe̱ k'u̱a̱na̱cha̱ná. A̱t'aha̱ kui niu̱ xi ts'ínchjén já maña̱ xi ni tsank'á bakúya.  
\v 15 Tu̱ sa ní én xi na̱xu̱ chu̱ba̱á a̱t'aha̱ tjoná xi̱nki̱á. B'a̱ ts'ín sájihinná Cristo̱, kui xi nintaku̱ xu̱ta̱ ni̱nku̱.  
\v 16 Cristo̱ ts'ín nga ngayjee̱ yjonintee̱ nkuhú bichú mako̱ xinkjín ko̱ b'a'yún sisihi̱n xinkjín ngatentee̱ ni xi tjíhi̱n yjonintee̱. Tsa ngatentee̱ yjonintee̱ ts'ínxá sisin, ngayjee̱ yjonintee̱ sá sisin ko̱ sakú nga'yúhu̱n nga binchajin kju̱a̱tjo. 
\s1 B'i̱ ts'ín tsakúya Pablo̱ xi nkú ts'ín tjíhin nga ku̱i̱ntsu̱ba̱á nginku̱n Nti̱a̱ná 
\p  
\v 17 Kui nga b'a̱ xíhi̱nnu̱u ko̱ ngajoho̱ Nda̱ Nti̱a̱ná b'a̱ xíhi̱nu̱u ma. Najmi b'a̱ ta̱ n'e bintsu̱ba̱ sahanu xi nkú ts'ín tjíntu xu̱ta̱ xi tjín a̱sunntee̱, xu̱ta̱ xi ni tiya ts'ínnkjink'un.  
\v 18 Kui xi ja kis'ejyún kju̱a̱nkjintak'uhu̱n ko̱ najmi tjíntu tík'un xi nkú ts'ín ts'ínk'íéntu tík'un Nti̱a̱ná xu̱ta̱ xi ts'e̱. A̱t'aha̱ ja kits'ín ndjá ani̱ma̱ha̱ ko̱ najmi ta̱ mankjihi̱n ra̱ ni xi ts'e̱ Nti̱a̱ná.  
\v 19 Ja najmi ta̱ tjíhi̱n ra̱ kju̱a̱suba ko̱ ja kits'ínkjas'ehe̱n yjoho̱ ni ch'onk'uu̱n. Najmi ta̱ b'éch'oho̱ ra̱ yjoho̱ nga ts'ín ngayje tíkjá ni xi chu̱ntí nginku̱n Nti̱a̱ná. 
\p  
\v 20 Jun bi najmi b'a̱ tsu éhe̱n Cristo̱ xi tsakuyái̱hi̱ tsa b'a̱ no̱o.  
\v 21 A̱t'aha̱ ja kinu'yó éhe̱n Cristo̱ ko̱ tsinchiyó ni xi ts'e̱, ko̱ yo nga Jesu tíjñajihi̱n ni xi na̱xu̱ tjín.  
\v 22 Najmi b'a̱ ta̱ ts'ín bintsu̱ba̱hanu xi nkúhu nk'ie. N'e̱k'óntjaiyo ani̱ma̱nu̱u. A̱t'aha̱ ni xi kama mjenu̱u nk'ie ts'ana̱cha̱ha̱ ko̱ kits'ínkatsúhu̱n.  
\v 23 Tjíhin nga n'e̱ tse̱tse̱ ngáhanu ani̱ma̱nu̱u ko̱ kju̱a̱nkjintak'unnu̱u.  
\v 24 N'e̱ tse̱tso̱o yjonu̱u, a̱t'aha̱ Nti̱a̱ná kits'ínnda tse̱tse̱ ngáha ani̱ma̱nu̱u. Xi nkú ts'ín tjíyaha̱ nga kixi̱ ko̱ je, b'a̱ kits'ínk'íé. 
\p  
\v 25 Kui b'a̱ maha, najmi ta̱ ch'ana̱cha̱ha̱ ru̱u xinki̱u. Najmi tu̱ én tsank'á chubo, a̱t'aha̱ nkuhú yjoninte mahaná ngatenteé. 
\p  
\v 26 Nk'ie nga tíma kjannu̱u, najmi tu̱ ngatitsun n'o. Najmi tu̱ bintsu̱ba̱ kjon nku ni̱stjin tantoo̱.  
\v 27 Najmi tu̱ 'ba̱i̱ntoho̱o nda̱nindoo̱. 
\p  
\v 28 Xi ndyjé ts'ín nk'ie, najmi b'a̱ ta̱ kats'íhin. Kats'ínxá ní ko̱ kats'ínchjén ntsja nga kats'ín ni xi nda, tu̱ xi b'a̱ ts'ín ka̱ma ku̱a̱si̱nko̱ho xu̱ta̱ xi machjéhe̱n ra̱ tsa mí nihi. 
\p  
\v 29 Ndaha nku én ch'on tsu najmi tu̱ ku̱i̱tju tsu̱'bo. Én xi nda ní chu̱bo, én xi tsjá nga'yúhu̱n xu̱ta̱, tu̱ xi nda ka̱mat'aihin xu̱ta̱ xi ku̱i̱nt'é énnu̱u.  
\v 30 Najmi tu̱ ni xi ts'i̱ín'uhu̱n Espiri̱tu̱hu̱ Nti̱a̱ná n'o. A̱t'aha̱ kui xi kik'a̱i̱nu̱u tu̱ xi cha̱ha nga jun xi xu̱ta̱ xi ts'e̱ Nti̱a̱ná nk'ie nga ku̱i̱chú ni̱stjin nga ku̱i̱tjusun nga ka̱ma nda̱í kikjinnu̱u. 
\p  
\v 31 Ti̱ch'onsjo̱o ngayjee̱ ni ch'onk'un xi tjíntujín ani̱ma̱nu̱u, kju̱a̱kjoo̱n ko̱ kju̱a̱stintoo̱. Najmi tu̱ ch'íya kjon, ko̱ najmi tu̱ ch'on 'mihi̱u xinki̱u, ko̱ najmi tu̱ nga̱t'aha̱ tu̱ mí nihí ni n'e̱ uncho xinki̱u.  
\v 32 Nda ní cha̱so̱ho̱ xinki̱u ko̱ cha̱se̱ni̱mo̱ho̱ xinki̱u. N'e̱ ndyjat'oho̱o xinki̱u xi nkú ts'ín kisakújinnu̱u kju̱a̱n'endyjat'a a̱jihi̱n Cristo̱. 
\c 5  
\s1 B'i̱ ts'ín tsakúya Pablo̱ nk'ie nga ñá xi ntíhi̱ Nti̱a̱ná 
\p  
\v 1 Ntí tjoho̱ Nti̱a̱ná jun, kui nga b'a̱ ta̱ n'e̱henu xi nkú ts'ín Nti̱a̱ná.  
\v 2 Xi nkú ts'ín y'ejñajin kju̱a̱tjo Cristo̱ nga kits'íntjoná, b'a̱ ts'ín ti̱ntsu̱ba̱jiun kju̱a̱tjo. Kui xi kitsjá yjoho̱ nga k'ienntjáíhiná. Kui xi kama nku chje̱ sinjne̱ xi kin'ekjas'ehe̱n Nti̱a̱ná. 
\p  
\v 3 Ja kikj'áts'e̱nu̱u Nti̱a̱ná. Kui nga ta̱ santaha najmi tjíhin nga chu̱bani̱jmíyahanu xi nkú ts'ín chu̱ba̱ fantuko̱hó xinkjín xu̱ta̱ xi tjín, ko̱ tsa tu̱ mí nihí ni xi chu̱ntí nginku̱n Nti̱a̱ná, ko̱ tsa kjúásihu̱un ni xi tjíhi̱n xu̱ta̱ xingisoo̱.  
\v 4 Ko̱ najmi tu̱ chubo én xi najmi nda tsu, ko̱ tsa én ton ch'on tsu, ko̱ tsa nku én xi najmi nda fane, a̱t'aha̱ najmi chumi ni chjíhi̱ ra̱ ni xu'bo̱. Tu̱ sa ní én xi tsjáha̱ máb'a̱chjíhi̱ Nti̱a̱ná chu̱bo.  
\v 5 A̱t'aha̱ ja yo nga xi chu̱ba̱ fantuko̱hó xinkjín, ko̱ xi ts'ín ni xi chu̱ntí nginku̱n Nti̱a̱ná, ko̱ xi fásihi̱n ni xi tjíhi̱n xu̱ta̱ xingisoo̱, kui xi najmi tsuhu̱ ra̱ nga Cristo̱ ko̱ Nti̱a̱ná ku̱a̱téxumaha̱. Xi tífásihi̱n ni xi tjíhi̱n xu̱ta̱ xingisoo̱, kui xi kj'a̱í nti̱a̱ tje̱nnki. 
\p  
\v 6 Najmi tu̱ 'ba̱i̱nto tsa tjín xi k'u̱a̱na̱cha̱ko̱nu̱u nku én tiya, a̱t'aha̱ nga̱t'aha̱ ni xu'bi̱ kju̱a̱kjaha̱n Nti̱a̱ná nibánehe̱ ra̱ xu̱ta̱ xi najmi nt'é'éhe̱n.  
\v 7 Kui nga najmi tu̱ jun n'engujihi̱n ru̱u yjonu̱u xu̱ta̱ xi b'a̱ tíi̱ncha ts'ín. 
\p  
\v 8 A̱t'aha̱ ni̱stjin nk'ie má jyuu̱n tintsu̱bo̱o, tu̱nga nd'a̱i̱ ja má ndzjee̱n tintsu̱bo̱o nga nkuhú mako̱o Nda̱ Nti̱a̱ná. Kui nga ti̱ntsu̱ba̱hanu xi nkú ts'ín tjíhin nga k'úéntu xi tjíntu má ndzjee̱n.  
\v 9 N'o̱o ni xi nda ko̱ na̱xu̱ ko̱ kixi̱, a̱t'aha̱ kui niu̱ xi bakúchji nga má ndzjee̱n tje̱he̱nná.  
\v 10 Ti̱nchísjo má nihi xi sasíhi̱n Nti̱a̱ná.  
\v 11 Ndaha̱chí najmi tu̱ n'o ni xi najmi chumi ni chjíhi̱ ra̱, ni xi ts'ín xu̱ta̱ xi ts'e̱ má jyuu̱n. Tu̱ sa ní t'e̱jñachiu nga najmi nda niu̱. 
\p  
\v 12 A̱t'aha̱ tu̱ ñáhá xí subahá maná nga n'ekjáá ni xi ts'ín'ma xu̱ta̱ xu'bo̱.  
\v 13 Tu̱nga ma chjihí ngayjee̱ ni xi tjín nk'ie nga s'entuchjí má ndzjee̱n,  
\v 14 a̱t'aha̱ nd'íu̱ b'éjña chji tu̱ mí nihí ni. Kui nga b'a̱ ts'ín tjít'a: 
\q1 N'e̱kj'áíhi̱ yjohi̱, ji xi kisufei. 
\q1 Ti̱síntje̱i̱n a̱jihi̱n xu̱ta̱k'ie̱n. 
\q1 Tsa b'a̱ n'e̱i̱, Cristo̱ ts'i̱ín ndzjehin. 
\p  
\v 15 Kui b'a̱ maha, nda nda cha̱se̱henu xi nkú n'e ku̱i̱ntsu̱bo̱o. Najmi tu̱ ni xi ts'ín xu̱ta̱ stje̱n n'o. N'e̱ nínú xi nkú ts'ín xu̱ta̱ nkjink'un.  
\v 16 N'o̱o ni xi nda tu̱ mí chu̱ba̱há ni nga sa̱kúntenu̱u nga b'a̱ n'o̱o, a̱t'aha̱ ch'on chun ni̱stjin xi kich'aá nd'a̱i̱.  
\v 17 Kui nga najmi tu̱ nchi̱ni n'esjehenu yjonu̱u. Katumankjin nínu̱u mí nihi xi mjehe̱ Nda̱ Nti̱a̱ná nga n'o̱o. 
\p  
\v 18 Najmi tu̱ n'e ch'i̱u, a̱t'aha̱ kui niu̱ xi ts'ín nga n'eé tu̱ mí nihí ni. Tu̱ sa ní Espiri̱tu̱hu̱ Nti̱a̱ná katsejíhi̱nnu̱u.  
\v 19 Salmo̱ ko̱ soho̱n ni̱nku̱ chu̱bani̱jmíyako̱honu xinki̱u ko̱ só xi nkú ts'ín ku̱a̱kúyanu̱u Espiri̱tu̱hu̱ Nti̱a̱ná. Ngayjehe ani̱ma̱nu̱u só ko̱ n'e̱tsjoho̱o Nda̱ Nti̱a̱ná.  
\v 20 Tu̱ mí kju̱a̱há ni tehe̱nte tjoho̱on máb'a̱chjíhi̱ Nti̱a̱ Na̱'miná. B'a̱ n'o̱o a̱t'aha̱ Nda̱ Nti̱a̱ná Jesucristo̱ ts'e̱nu̱u. 
\s1 B'i̱ ts'ín tsakúya Pablo̱ xi nkú ts'ín k'úéntuko̱ xinkjín xu̱ta̱ 
\p  
\v 21 Cha̱nkjún xinki̱u a̱t'aha̱ Cristo̱ tíyankjún.  
\v 22 Jun xi tí'minu̱u chju̱ún, cha̱nkjún x'i̱nnu̱u. B'a̱ n'o̱o xi nkú ts'ín tíyankjún Nda̱ Nti̱a̱ná.  
\v 23 A̱t'aha̱ xi tí'mi x'i̱n, kui xi síjña títjuhu̱n chju̱úhu̱n xi nkú ta̱ ts'ín Cristo̱ síjña títjuhu̱n xu̱ta̱ ni̱nku̱. Xu̱ta̱ ni̱nku̱ kui xi yjonintehe̱ Cristo̱, ko̱ Cristo̱ kui xi kits'ínk'ankihi̱.  
\v 24 Xi nkú ts'ín xu̱ta̱ ni̱nku̱ benkjún Cristo̱, b'a̱ ta̱ ts'ín xi tí'mi chju̱ún tu̱ nkjéhé ni katenkjún x'i̱hi̱n. 
\p  
\v 25 Ko̱ jun xi tí'minu̱u x'i̱n, n'e̱tjó chju̱únnu̱u xi nkú ts'ín Cristo̱ kits'íntjo xu̱ta̱ ni̱nku̱ ko̱ kitsjá yjoho̱ ngandaha̱.  
\v 26 B'a̱ kits'ín tu̱ xi kikj'áts'e̱he. Éhe̱n kits'ín jeko̱ho ko̱ ntánijua tsanéjnuko̱ho  
\v 27 tu̱ xi ja tjíhi̱n ra̱ kju̱a̱chánka xu̱ta̱ ni̱nku̱ nk'ie nga ku̱i̱chú nginku̱n. Najmi s'e̱he̱ ni chu̱ntí, najmi ch'on k'úé, ko̱ najmi s'e̱he̱ tsa mí nihi. Mje níhi̱ Cristo̱ nga je ko̱ nga nda kikjin ka̱ma xu̱ta̱ ni̱nku̱. 
\p  
\v 28 B'a̱ ta̱ ts'ín xi tí'mi x'i̱n tjíhin nga ts'i̱íntjo chju̱úhu̱n. Kats'íntjo xi nkú ts'ín tjoho̱ yjonintehe̱. Xi tjoho̱ chju̱úhu̱n, kui xi tjoho̱ yjoho̱.  
\v 29 A̱t'aha̱ najmi tjín xi unkie yjonintehe̱. Tsjá níhi̱ nichine ko̱ kuhu̱n xi nkú nga ts'íhi̱n Cristo̱ xu̱ta̱ ni̱nku̱.  
\v 30 A̱t'aha̱ ta̱ yjonintehe̱ Cristo̱ tintsu̱ba̱jián. 
\p  
\v 31 B'i̱ ts'ín tjít'a: “Kui nga nku nda̱ k'u̱éjñaha xi cháha̱ nga k'úéjñako̱ chju̱úhu̱n ko̱ nkuhú yjoninte ku̱i̱chú ma nga joo̱.”  
\v 32 'Yún na̱nka̱ ni xu'bi̱, tu̱nga nk'iehé nga nchjani̱jmíya Cristo̱ ko̱ xu̱ta̱ ni̱nku̱ ts'inchjén niu̱.  
\v 33 Jun tjíhin nga n'e̱tjó chju̱únnu̱u xi nkú ts'ín tjonu̱u yjonu̱u. Ko̱ xi tí'mi chju̱ún katenkjún x'i̱hi̱n. 
\c 6  
\p  
\v 1 Ko̱ jun xi tí'minu̱u ntí, ti̱nú'yá'óho̱on xi chánu̱u a̱t'aha̱ Nda̱ Nti̱a̱ná s'ejinnu̱u. A̱t'aha̱ kui niu̱ xi nda tjín nginku̱n Nti̱a̱ná.  
\v 2 A̱jihi̱n kju̱a̱téxuma xi kin'ekjas'ehe̱n Moise kui kju̱a̱téxuma xu'bi̱ xi tjun títsuya ni xi Nti̱a̱ná tsjáha̱ xi ku̱i̱nt'é'éhe̱n. B'a̱ títsu: “Cha̱nkjúín na̱'mihi̱ ko̱ na̱ahi̱  
\v 3 tu̱ xi nda ka̱mat'aihinni ko̱ tse ni̱stjin ka̱maha ri nga ku̱i̱nchin a̱sunntee̱.” 
\p  
\v 4 Ko̱ jun xi tí'minu̱u na̱'mi, najmi tu̱ chu̱ba̱ kjan n'eko̱o ntínu̱u. Tu̱ sa ní tjen ni̱yóho̱o nga n'e̱chó ko̱ ta̱kúyoho̱o ni xi ts'e̱ Nti̱a̱ná. 
\p  
\v 5 Ko̱ jun xi tí'minu̱u xu̱ta̱ musu̱ xi kich'atse, ti̱nú'yá'óho̱on xi já nti̱a̱nu̱u e̱i̱ a̱sunntei̱. Cha̱nkjún ko̱ ti̱nkjún ko̱ ngayjehe ani̱ma̱nu̱u ti̱nú'yá'óho̱on, xi nkú joyaha tsa Cristo̱ tínu'yá'óho̱on.  
\v 6 Najmi tu̱ nku nk'ie nga tíbasenu̱u nga b'a̱ n'o̱o, tsa tu̱ xi b'a̱ ts'ín nda sku̱e̱he̱nu̱u. N'e̱ nínú xi nkúhu xu̱ta̱ musu̱ xi Cristo̱ ts'atse. Ngayjehe ani̱ma̱nu̱u n'o̱o ni xi mjehe̱ Nti̱a̱ná.  
\v 7 Nk'ie nga tín'o nku xá, ngayjehe k'un b'a̱ no̱o. B'a̱ no̱o xi nkúhu tsa nku xáha̱ Nda̱ Nti̱a̱ná tín'o.  
\v 8 A̱t'aha̱ yo nga Nti̱a̱ná tsjá ngajoya ngáha̱ ra̱ ni xi nda kits'ín nga nkúnkú xu̱ta̱, ndaha tsa musu̱ xi kich'atse ko̱ ndaha tsa xi nda̱íhi̱ yjoho̱. 
\p  
\v 9 Jun xi tí'minu̱u já nti̱a̱, b'a̱ ta̱ n'o̱o xi nkú nga tíxihi̱n xu̱ta̱ musu̱. Najmi tu̱ binchankjúhu̱un. Ja yo nga nkuhú maha Nda̱ Nti̱a̱nu̱u xi tíjña ndji̱o̱jmi ján ko̱ nga kui xi najmi ngabi ts'ín a̱jihi̱n xu̱ta̱. 
\s1 B'i̱ ts'ín tsakúya Pablo̱ xi nkú ts'ín k'úéndaá yjoná tu̱ xi najmi ts'i̱ín ngana̱ha̱ná nda̱nindoo̱ 
\p  
\v 10 Ni xi fekuhu xi xínnu̱u, kasakúnu̱u nga'yún a̱jihi̱n nga'yún chánkaha̱ Nda̱ Nti̱a̱ná.  
\v 11 Xi nkú joyaha já jun xi b'énda yjoho̱ nga kján, b'a̱ ts'ín n'e̱ch'oko̱honu yjonu̱u ni xi tsjáná Nti̱a̱ná, tu̱ xi ndjá ka̱ma ku̱i̱nchahanu nga kuankín kontro̱ho̱ kju̱a̱maña̱ha̱ nda̱nindoo̱. 
\p  
\v 12 A̱t'aha̱ najmi xu̱ta̱ a̱sunnte tíbixkjanka̱á. Xi tjín níhi̱ nga'yún tíbixkjanka̱á, xi nk'a xáha̱, xi batéxuma a̱sunnte ngatitsun xu'bi̱. Kui xi jáninda ch'onk'un ṉkjún xi tjín nk'a ján.  
\v 13 Kui nga t'endahanu yjonu̱u xi nkú joyaha já jun xi Nti̱a̱ná kitsjáyjehe̱ ni xi ts'i̱ínch'oko̱ho̱ ra̱ yjoho̱, tu̱ xi ku̱i̱chúkju̱a̱ha̱nu̱u nk'ie nga ku̱i̱chú ni̱stjin xi ndjá ni̱ba. Ko̱ nga ja tjínda sisinnu̱u yjonu̱u, ndjá ti̱ncho. 
\p  
\v 14 Kui b'a̱ maha, ndjá ti̱nchahanu. Ni xi y'éjña Nti̱a̱ná ko̱ ni xi na̱xu̱ nginku̱n, kui xi n'e̱ch'oko̱honu yjonu̱u xi nkúhu já jun xi ts'ínch'oho̱ yjoho̱.  
\v 15 T'endo yjonu̱u nga t'eni̱jmíú én nda tsu xi tsuya kju̱a̱jyuhu̱ Nti̱a̱ná.  
\v 16 Machjéhe̱n nga n'e̱ s'ejiun Nti̱a̱ná, tu̱ xi najmi tjín xi nkú ts'ín ts'i̱ín'uhu̱nnu̱u nda̱nindoo̱.  
\v 17 T'ejin tak'un nga Nti̱a̱ná kits'ínk'ankinu̱u. Chjúbó éhe̱n, kui xi kitsjánu̱u Espiri̱tu̱hu̱ Nti̱a̱ná tu̱ xi ku̱i̱si̱nko̱ko̱honu yjonu̱u. 
\p  
\v 18 Tehe̱nte chu̱bako̱o Nti̱a̱ná xi nkú ts'ín tsjáni̱yánu̱u Espiri̱tu̱hu̱. Chu̱bako̱o ko̱ ti̱nchíhu̱u ni xi machjénnu̱u. Ti̱ntsu̱ba̱ ndo ko̱ najmi tu̱ n'ekjioho̱o tak'un nga chu̱bantjo ngayjee̱ xu̱ta̱ xi ts'e̱ Nti̱a̱ná.  
\v 19 Ko̱ ta̱ chu̱bantjainú nk'ie nga chu̱bako̱o Nti̱a̱ná, tu̱ xi tsjáhana én xi kuinchja, tu̱ xi ndjá kuinchjahana nga k'ueni̱jmíá ni xi kis'ejña 'ma ni̱stjin nk'ie, xi ja tíb'éjña chji én nda tsuhu̱ Nti̱a̱ná nd'a̱i̱.  
\v 20 Kui nga̱t'aha̱ ée̱n kjíi̱ya'yúhunna an xi tsú'ba̱ ngajoho̱ Nda̱ Nti̱a̱ná. Chu̱bantjainú nginku̱n Nti̱a̱ná tu̱ xi kuinchjahana xi nkú ts'ín tjíhin nga kuinchja ko̱ tu̱ xi najmi tsankjuhunna. 
\s1 B'i̱ ts'ín kits'ínkje Pablo̱ xu̱ju̱i̱n 
\p  
\v 21 Ngatentee̱ ni xi tímat'an ko̱ ni xi títs'ian ku̱i̱tsu̱yanu̱u Tiki̱ko̱, nda̱ nts'eé xi tjona ko̱ xi kixi̱ títs'ínxát'aha̱ Nda̱ Nti̱a̱ná.  
\v 22 Kui kju̱a̱ha títs'inkjísehe̱nu̱u tu̱ xi cha̱hanu nkú ts'ín tintsu̱ba̱i̱ ko̱ tu̱ xi tsjá nga'yúhu̱n ra̱ ani̱ma̱nu̱u. 
\p  
\v 23 Nti̱a̱ Na̱'miná ko̱ Nda̱ Nti̱a̱ná Jesucristo̱ katsjáha̱ já nts'eé kju̱a̱jyu ko̱ kju̱a̱tjo, ko̱ kat'éyaha̱ nga 'yún s'e̱jihi̱n.  
\v 24 Kju̱a̱ndaha̱ Nti̱a̱ná kas'ehe̱ ngatentee̱ xi tjoho̱ Nda̱ Nti̱a̱ná Jesucristo̱, kju̱a̱tjo xi najmi maha̱ feya.