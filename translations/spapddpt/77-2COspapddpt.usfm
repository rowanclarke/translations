\v 3 \w Porque|strong="G3754"\w* doy \w testimonio|strong="G3140"\w* \w de|strong="G3844"\w* \w que|strong="G3754"\w* espontáneamente \w según|strong="G2596"\w* su capacidad, \w y|strong="G2532"\w* \w aun|strong="G2532"\w* \w por|strong="G2596"\w* encima \w de|strong="G3844"\w* ella,  
\v 4 nos rogaron \w mucho|strong="G4183"\w* \add que les concediéramos\add* \w el|strong="G3588"\w* privilegio \w de|strong="G1519"\w* participar \w en|strong="G1519"\w* \w el|strong="G3588"\w* sostenimiento\f + \fr 8:4 \ft Lit. \fqa comunión del servicio.\f* \w de|strong="G1519"\w* \w los|strong="G3588"\w* santos.  
\v 5 \w No|strong="G3756"\w* \w como|strong="G2531"\w* \w esperábamos|strong="G1679"\w*,\f + \fr 8:5 \ft Lit. \fqa esperamos.\ft El verbo está en pretérito indefinido.\f* sino \w primeramente|strong="G4412"\w* \w ellos|strong="G3588"\w* mismos \w se|strong="G1438"\w* \w dieron|strong="G1325"\w* \w al|strong="G3588"\w* \w Señor|strong="G2962"\w* \w y|strong="G2532"\w* \w a|strong="G1223"\w* \w nosotros|strong="G2249"\w*, \w por|strong="G1223"\w* \add la\add* \w voluntad|strong="G2307"\w* \w de|strong="G1223"\w* \w Dios|strong="G2316"\w*,  
\v 6 \w a|strong="G1519"\w* fin \w de|strong="G1519"\w* \w que|strong="G3588"\w* rogáramos \w nosotros|strong="G2249"\w* \w a|strong="G1519"\w* \w Tito|strong="G5103"\w* \w para|strong="G1519"\w* \w que|strong="G3588"\w*, \w así|strong="G3779"\w* \w como|strong="G2531"\w* \w se|strong="G3779"\w* inició, \w también|strong="G2532"\w* completara \w para|strong="G1519"\w* ustedes \w este|strong="G3778"\w* privilegio.  
