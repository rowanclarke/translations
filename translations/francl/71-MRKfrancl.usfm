\p 
\v 3 \w Comme|strong="G2532"\w* \w Jésus|strong="G2532"\w* \w était|strong="G3588"\w* \w à|strong="G1722"\w* Béthanie, \w dans|strong="G1722"\w* \w la|strong="G2532"\w* \w maison|strong="G3614"\w* \w de|strong="G2532"\w* \w Simon|strong="G4613"\w* \w le|strong="G2532"\w* \w lépreux|strong="G3015"\w*, \w une|strong="G2532"\w* \w femme|strong="G1135"\w* \w entra|strong="G2064"\w* \w pendant|strong="G1722"\w* \w qu|strong="G2532"\w*’\w il|strong="G2532"\w* \w se|strong="G2532"\w* \w trouvait|strong="G2532"\w* \w à|strong="G1722"\w* \w table|strong="G2621"\w*. \w Elle|strong="G2532"\w* \w tenait|strong="G2192"\w* \w un|strong="G2532"\w* vase \w d|strong="G1722"\w*’albâtre \w plein|strong="G1722"\w* \w d|strong="G1722"\w*’\w un|strong="G2532"\w* \w parfum|strong="G3464"\w* \w de|strong="G2532"\w* \w nard|strong="G4101"\w* \w pur|strong="G4101"\w*\f + \fr 14:3 \ft 3. \fq À Béthanie\ft , le samedi avant les Rameaux. Voy Matth. 26, 6 sv. \qt Nard pur\qt*, litt, \qt authentique, digne de foi\qt* : πιστικῆς. La Vulgate porte \qt spicati\qt*, du nard \qt d’épi\qt*, plus précieux que celui tiré des feuilles. Les tiges du nard, au-dessus de la racine, affectent la forme d’un épi, d’où s’échappent les feuilles et la fleur.\f* \w d|strong="G1722"\w*’\w un|strong="G2532"\w* \w grand|strong="G2532"\w* \w prix|strong="G4185"\w* ; \w et|strong="G2532"\w* \w ayant|strong="G2532"\w* \w brisé|strong="G4937"\w* \w le|strong="G2532"\w* vase, \w elle|strong="G2532"\w* \w répandit|strong="G2708"\w* \w le|strong="G2532"\w* \w parfum|strong="G3464"\w* \w sur|strong="G1722"\w* \w sa|strong="G2532"\w* \w tête|strong="G2776"\w*.
\v 4 \w Plusieurs|strong="G1438"\w* \w de|strong="G3588"\w* \w ceux|strong="G3588"\w* \w qui|strong="G3588"\w* \w étaient|strong="G3588"\w* \w là|strong="G1519"\w* \w en|strong="G1519"\w* témoignaient \w entre|strong="G4314"\w* \w eux|strong="G1438"\w* \w leur|strong="G4314"\w* mécontentement : « \w Pourquoi|strong="G5101"\w* \w perdre|strong="G1096"\w* \w ainsi|strong="G1161"\w* \w ce|strong="G3778"\w* \w parfum|strong="G3464"\w* ?
\v 5 \w On|strong="G2532"\w* \w aurait|strong="G1063"\w* \w pu|strong="G1410"\w* \w le|strong="G2532"\w* \w vendre|strong="G4097"\w* \w plus|strong="G2532"\w* \w de|strong="G2532"\w* \w trois|strong="G3464"\w* \w cents|strong="G5145"\w* \w deniers|strong="G1220"\w*, \w et|strong="G2532"\w* \w les|strong="G2532"\w* \w donner|strong="G1325"\w* \w aux|strong="G2532"\w* \w pauvres|strong="G4434"\w*. » \w Et|strong="G2532"\w* \w ils|strong="G2532"\w* \w se|strong="G2532"\w* fâchaient \w contre|strong="G2532"\w* \w elle|strong="G2532"\w*.
\v 6 \w Mais|strong="G1161"\w* \w Jésus|strong="G2424"\w* \w dit|strong="G3004"\w* : « Laissez-la ; \w pourquoi|strong="G5101"\w* \w lui|strong="G1438"\w* \w faites-vous|strong="G5101"\w* \w de|strong="G1722"\w* \w la|strong="G1722"\w* \w peine|strong="G2873"\w* ? \w C|strong="G1161"\w*’\w est|strong="G3588"\w* \w une|strong="G1722"\w* \w bonne|strong="G2570"\w* \w action|strong="G2041"\w* \w qu|strong="G5101"\w*’\w elle|strong="G1161"\w* \w a|strong="G1722"\w* faite \w à|strong="G1722"\w* \w mon|strong="G1161"\w* \w égard|strong="G1438"\w*.
