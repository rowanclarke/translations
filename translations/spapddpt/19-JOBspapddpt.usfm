\s1 Los hijos y las riquezas de Job
\p 
\v 1 \w Hubo|strong="H1961"\w* un hombre \w en|strong="H5493"\w* \w la|strong="H1931"\w* tierra \w de|strong="H7451"\w* \w Uz|strong="H5780"\w* \w llamado|strong="H8034"\w* Job. \w Aquel|strong="H1931"\w* varón \w era|strong="H1961"\w* intachable, \w recto|strong="H3477"\w*, \w temeroso|strong="H3373"\w* \w de|strong="H7451"\w* \nd ʼElohim\nd* y apartado del \w mal|strong="H7451"\w*.
\v 2 Le \w nacieron|strong="H3205"\w* \w siete|strong="H7651"\w* \w hijos|strong="H1121"\w* y \w tres|strong="H7969"\w* \w hijas|strong="H1323"\w*.
\v 3 \w Su|strong="H1931"\w* \w hacienda|strong="H4735"\w* \w era|strong="H1961"\w*: 6.000 \w ovejas|strong="H6629"\w*, 3.000 \w camellos|strong="H1581"\w*, 500 \w yuntas|strong="H6776"\w* \w de|strong="H2568"\w* \w bueyes|strong="H1241"\w*, 500 asnas \w y|strong="H1241"\w* muchísimos esclavos. \w Aquel|strong="H1931"\w* varón \w era|strong="H1961"\w* \w el|strong="H1931"\w* \w más|strong="H7227"\w* \w grande|strong="H1419"\w* \w de|strong="H2568"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* del \w oriente|strong="H6924"\w*.
\p 
\v 4 Sus \w hijos|strong="H1121"\w* acostumbraban tener \w banquetes|strong="H4960"\w* \w en|strong="H5973"\w* la \w casa|strong="H1004"\w* \w de|strong="H5973"\w* \w cada|strong="H3117"\w* uno \w en|strong="H5973"\w* su \w día|strong="H3117"\w*, \w e|strong="H3068"\w* invitaban \w a|strong="H3068"\w* sus \w tres|strong="H7969"\w* hermanas \w para|strong="H5973"\w* \w que|strong="H3117"\w* comieran y bebieran \w con|strong="H5973"\w* ellos.
\v 5 \w Sucedía|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w* del festín terminaban \w su|strong="H3588"\w* ciclo, Job mandaba \add a buscarlos\add* \w y|strong="H3588"\w* \w los|strong="H1121"\w* purificaba. \w Se|strong="H1961"\w* levantaba \w de|strong="H3588"\w* madrugada \w y|strong="H3588"\w* ofrecía \w holocaustos|strong="H5930"\w* \w por|strong="H3588"\w* \w ellos|strong="H3605"\w*, \w conforme|strong="H5930"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w número|strong="H4557"\w*, \w pues|strong="H3588"\w* Job decía: Tal vez mis \w hijos|strong="H1121"\w* \w pecaron|strong="H2398"\w* \w contra|strong="H1961"\w* \nd ʼElohim\nd* \w y|strong="H3588"\w* blasfemaron \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w corazón|strong="H3824"\w*. Job \w siempre|strong="H3605"\w* \w hacía|strong="H6213"\w* \w esto|strong="H3602"\w*.
\s1 Una reunión de los hijos de ʼElohim
\p 
\v 6 \w Entonces|strong="H3117"\w* \w hubo|strong="H1961"\w* un \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd* llegaron \w a|strong="H3068"\w* presentarse ante \nd \w Yavé|strong="H3068"\w*\nd*, \w y|strong="H1571"\w* \w Satán|strong="H7854"\w* \w también|strong="H1571"\w* llegó \w entre|strong="H8432"\w* \w ellos|strong="H5921"\w*.
\p 
\v 7 \nd \w Yavé|strong="H3068"\w*\nd* preguntó \w a|strong="H3068"\w* \w Satán|strong="H7854"\w*: \wj ¿De dónde vienes?\wj*
\p \w Y|strong="H3068"\w* \w Satán|strong="H7854"\w* \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: De rodear la tierra y \w andar|strong="H1980"\w* por ella.
\p 
\v 8 \w Y|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* dijo \w a|strong="H3068"\w* \w Satán|strong="H7854"\w*: \wj ¿\w No|strong="H3588"\w* has considerado \w a|strong="H3068"\w* \w mi|strong="H5921"\w* esclavo Job, \w que|strong="H3588"\w* \w no|strong="H3588"\w* hay otro \w como|strong="H3588"\w* \w él|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra, varón intachable, \w recto|strong="H3477"\w*, \w temeroso|strong="H3373"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd* \w y|strong="H3588"\w* apartado \w del|strong="H5921"\w* \w mal|strong="H7451"\w*?\wj*
\p 
\v 9 Entonces \w Satán|strong="H7854"\w* \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: ¿\w Teme|strong="H3372"\w* Job \w a|strong="H3068"\w* \nd ʼElohim\nd* sin interés?
\v 10 ¿\w No|strong="H3808"\w* colocaste un cercado \w alrededor|strong="H5439"\w* de \w él|strong="H3605"\w*, su \w casa|strong="H1004"\w* y \w todo|strong="H3605"\w* cuanto posee? \w Porque|strong="H3808"\w* has bendecido \w la|strong="H3605"\w* \w obra|strong="H4639"\w* de sus \w manos|strong="H3027"\w*, y sus posesiones aumentaron en \w la|strong="H3605"\w* tierra.
\v 11 Pero \w extiende|strong="H7971"\w* \w ahora|strong="H4994"\w* tu \w mano|strong="H3027"\w* \w y|strong="H5921"\w* \w toca|strong="H5060"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* tiene \w y|strong="H5921"\w* verás \w si|strong="H3808"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* maldice \w en|strong="H5921"\w* tu propia \w Presencia|strong="H6440"\w*.
\p 
\v 12 Entonces \nd \w Yavé|strong="H3068"\w*\nd* contestó \w a|strong="H3068"\w* \w Satán|strong="H7854"\w*: \wj \w Mira|strong="H2009"\w*, \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* tiene está \w en|strong="H5973"\w* tu \w mano|strong="H3027"\w*, \w solo|strong="H7535"\w* \w que|strong="H3605"\w* \w no|strong="H6440"\w* \w pongas|strong="H7971"\w* tu \w mano|strong="H3027"\w* sobre \w él|strong="H5973"\w*.\wj*
\p \w Y|strong="H3068"\w* \w Satán|strong="H7854"\w* se retiró \w de|strong="H6440"\w* \w la|strong="H3605"\w* \w Presencia|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\s1 Una gran prueba para Job
\p 
\v 13 Llegó \w el|strong="H1121"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* sus \w hijos|strong="H1121"\w* y sus \w hijas|strong="H1323"\w* comían y \w bebían|strong="H8354"\w* \w vino|strong="H3196"\w* en \w casa|strong="H1004"\w* \w del|strong="H8354"\w* hermano \w primogénito|strong="H1060"\w*,
\v 14 \w y|strong="H5921"\w* un \w mensajero|strong="H4397"\w* llegó \w a|strong="H3068"\w* Job \w y|strong="H5921"\w* \w le|strong="H5921"\w* dijo: \w Los|strong="H5921"\w* \w bueyes|strong="H1241"\w* araban \w y|strong="H5921"\w* \w las|strong="H5921"\w* asnas pastaban \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ellos|strong="H3027"\w*.
\v 15 Los sabeos \w cayeron|strong="H5307"\w* violentamente y se los \w llevaron|strong="H3947"\w*. \w Mataron|strong="H5221"\w* \w a|strong="H3068"\w* los esclavos \w a|strong="H3068"\w* filo de \w espada|strong="H2719"\w*. \w Solo|strong="H7535"\w* yo \w escapé|strong="H4422"\w* \w para|strong="H7535"\w* darte la noticia.
\p 
\v 16 \w Aún|strong="H5750"\w* \w hablaba|strong="H1696"\w* \w éste|strong="H2088"\w* cuando \w otro|strong="H2088"\w* llegó, quien \w dijo|strong="H1696"\w*: ¡Fuego \w de|strong="H4480"\w* \nd ʼElohim\nd* \w cayó|strong="H5307"\w* \w del|strong="H4480"\w* \w cielo|strong="H8064"\w* \w que|strong="H4480"\w* quemó las \w ovejas|strong="H6629"\w* \w y|strong="H1197"\w* devoró \w a|strong="H3068"\w* los esclavos! \w Solo|strong="H7535"\w* \w yo|strong="H4480"\w* \w escapé|strong="H4422"\w* \w para|strong="H4480"\w* darte \w la|strong="H1197"\w* noticia.
\p 
\v 17 \w Éste|strong="H2088"\w* \w aún|strong="H5750"\w* \w hablaba|strong="H1696"\w* cuando llegó \w otro|strong="H2088"\w*, quien \w dijo|strong="H1696"\w*: \w Los|strong="H5921"\w* \w caldeos|strong="H3778"\w* formaron \w tres|strong="H7969"\w* cuadrillas. \w Se|strong="H5921"\w* abalanzaron \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w camellos|strong="H1581"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w los|strong="H5921"\w* \w llevaron|strong="H3947"\w*. \w Mataron|strong="H5221"\w* \w a|strong="H3068"\w* filo \w de|strong="H5921"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* esclavos, \w y|strong="H5921"\w* \w solo|strong="H7535"\w* yo \w escapé|strong="H4422"\w* \w para|strong="H5921"\w* darte \w la|strong="H5921"\w* noticia.
\p 
\v 18 \w Aún|strong="H5704"\w* \w hablaba|strong="H1696"\w* \w éste|strong="H2088"\w* \w cuando|strong="H5704"\w* \w otro|strong="H2088"\w* \w vino|strong="H3196"\w*, quien \w dijo|strong="H1696"\w*: Tus \w hijos|strong="H1121"\w* \w y|strong="H5704"\w* tus \w hijas|strong="H1323"\w* comían \w y|strong="H5704"\w* \w bebían|strong="H8354"\w* \w vino|strong="H3196"\w* \w en|strong="H5704"\w* \w casa|strong="H1004"\w* \w de|strong="H5704"\w* su hermano \w primogénito|strong="H1060"\w*,
\v 19 cuando \w ciertamente|strong="H4191"\w* \w llegó|strong="H5060"\w* un remolino \w de|strong="H5921"\w* \w viento|strong="H7307"\w* \w del|strong="H5921"\w* \w desierto|strong="H4057"\w* \w que|strong="H5921"\w* golpeó \w las|strong="H5921"\w* cuatro \w esquinas|strong="H6438"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w*, \w la|strong="H5921"\w* cual \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* jóvenes, \w y|strong="H5921"\w* \w murieron|strong="H4191"\w*. \w Solo|strong="H7535"\w* \w yo|strong="H2009"\w* \w escapé|strong="H4422"\w* \w para|strong="H5921"\w* darte \w la|strong="H5921"\w* noticia.
\p 
\v 20 Entonces Job se \w levantó|strong="H6965"\w*, \w rasgó|strong="H7167"\w* su \w manto|strong="H4598"\w* y se rapó la \w cabeza|strong="H7218"\w*. \w Cayó|strong="H5307"\w* \w a|strong="H3068"\w* la tierra, \w adoró|strong="H7812"\w*
\v 21 y dijo: ¡\w Desnudo|strong="H6174"\w* \w salí|strong="H3318"\w* del vientre \w de|strong="H5414"\w* \w mi|strong="H1961"\w* madre y \w desnudo|strong="H6174"\w* me voy! ¡\nd \w Yavé|strong="H3068"\w*\nd* \w dio|strong="H5414"\w* y \nd \w Yavé|strong="H3068"\w*\nd* \w quitó|strong="H3947"\w*! ¡\w Bendito|strong="H1288"\w* \w sea|strong="H1961"\w* el \w Nombre|strong="H8034"\w* \w de|strong="H5414"\w* \nd \w Yavé|strong="H3068"\w*\nd*!
\p 
\v 22 En \w todo|strong="H3605"\w* \w esto|strong="H2063"\w* Job \w no|strong="H3808"\w* \w pecó|strong="H2398"\w* \w ni|strong="H3808"\w* \w atribuyó|strong="H5414"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd* algún \w despropósito|strong="H8604"\w*.
\c 2
\s1 Prueba para el cuerpo, el hogar y la persona de Job
\p 
\v 1 Otra vez \w hubo|strong="H1961"\w* un \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd* \w se|strong="H1961"\w* presentaron ante \nd \w Yavé|strong="H3068"\w*\nd*, \w y|strong="H1571"\w* \w Satán|strong="H7854"\w* llegó \w con|strong="H5921"\w* \w ellos|strong="H5921"\w* \w a|strong="H3068"\w* presentarse \w delante|strong="H5921"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 2 \nd \w Yavé|strong="H3068"\w*\nd* preguntó \w a|strong="H3068"\w* \w Satán|strong="H7854"\w*: \wj ¿De dónde vienes?\wj*
\p \w Y|strong="H3068"\w* \w Satán|strong="H7854"\w* \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: De rodear la tierra y \w andar|strong="H1980"\w* \w por|strong="H2088"\w* ella.
\p 
\v 3 \nd \w Yavé|strong="H3068"\w*\nd* preguntó \w a|strong="H3068"\w* \w Satán|strong="H7854"\w*: \wj ¿\w No|strong="H3588"\w* has considerado \w a|strong="H3068"\w* mi esclavo Job, \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w hay|strong="H5750"\w* \w otro|strong="H5750"\w* \w como|strong="H3588"\w* \w él|strong="H3588"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra, varón intachable, \w recto|strong="H3477"\w*, \w temeroso|strong="H3373"\w* \w de|strong="H3588"\w* \nd ʼElohim\nd* \w y|strong="H3588"\w* apartado del \w mal|strong="H7451"\w*, quien \w aún|strong="H5750"\w* se aferra \w a|strong="H3068"\w* \w su|strong="H3588"\w* integridad \w a|strong="H3068"\w* pesar \w de|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* incitaste contra \w él|strong="H3588"\w* \w para|strong="H3588"\w* arruinarlo sin causa?\wj*
\p 
\v 4 \w Satán|strong="H7854"\w* \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: ¡\w Piel|strong="H5785"\w* \w por|strong="H1157"\w* \w piel|strong="H5785"\w*! \w Todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1157"\w* \w el|strong="H3605"\w* hombre tiene \w lo|strong="H3605"\w* \w dará|strong="H5414"\w* \w por|strong="H1157"\w* su \w vida|strong="H5315"\w*.
\p 
\v 5 Pero \w extiende|strong="H7971"\w* \w ahora|strong="H4994"\w* tu \w mano|strong="H3027"\w* y \w toca|strong="H5060"\w* sus \w huesos|strong="H6106"\w* y su \w carne|strong="H1320"\w*, y verás \w cómo|strong="H5060"\w* te maldice en tu propia \w Presencia|strong="H6440"\w*.
\p 
\v 6 \nd \w Yavé|strong="H3068"\w*\nd* respondió \w a|strong="H3068"\w* \w Satán|strong="H7854"\w*: \wj Ahí está en tu \w mano|strong="H3027"\w*. Pero no toques su \w vida|strong="H5315"\w*.\wj*
\p 
\v 7 \w Satán|strong="H7854"\w* \w salió|strong="H3318"\w* \w de|strong="H6440"\w* la \w Presencia|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w e|strong="H3068"\w* \w hirió|strong="H5221"\w* \w a|strong="H3068"\w* Job \w con|strong="H5704"\w* una úlcera maligna \w desde|strong="H5704"\w* la planta del \w pie|strong="H7272"\w* \w hasta|strong="H5704"\w* la coronilla.
\v 8 \w Estaba|strong="H3427"\w* \w sentado|strong="H3427"\w* \w en|strong="H8432"\w* ceniza. \w Tomó|strong="H3947"\w* un pedazo de vasija de barro y \w se|strong="H1931"\w* rascaba con \w él|strong="H1931"\w*.
\p 
\v 9 Entonces su esposa le dijo: ¿\w Aún|strong="H5750"\w* te aferras \w a|strong="H3068"\w* tu integridad? ¡Maldice \w a|strong="H3068"\w* \nd ʼElohim\nd* y muérete!
\v 10 Pero \w él|strong="H3605"\w* le respondió: Tú \w hablaste|strong="H1696"\w* \w como|strong="H1571"\w* suelen \w hablar|strong="H1696"\w* las mujeres insensatas. \w Si|strong="H1571"\w* recibimos \w el|strong="H3605"\w* \w bien|strong="H2896"\w* \w de|strong="H7451"\w* \nd ʼElohim\nd*, ¿\w no|strong="H3808"\w* debemos aceptar \w también|strong="H1571"\w* \w el|strong="H3605"\w* \w mal|strong="H7451"\w*? En \w todo|strong="H3605"\w* \w esto|strong="H2063"\w* Job \w no|strong="H3808"\w* \w pecó|strong="H2398"\w* \w con|strong="H1571"\w* sus \w labios|strong="H8193"\w*.
\s1 Los amigos de Job
\p 
\v 11 Entonces \w tres|strong="H7969"\w* \w amigos|strong="H7453"\w* \w de|strong="H5921"\w* Job, Elifaz \w temanita|strong="H8489"\w*, \w Bildad|strong="H1085"\w* \w suhita|strong="H7747"\w* \w y|strong="H5921"\w* Sofar \w naamatita|strong="H5284"\w*, cuando \w oyeron|strong="H8085"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w este|strong="H2063"\w* \w mal|strong="H7451"\w* \w que|strong="H5921"\w* \w le|strong="H5921"\w* llegó, convinieron \w en|strong="H5921"\w* ir \w juntos|strong="H3162"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*, \w cada|strong="H3605"\w* uno \w de|strong="H5921"\w* su \w lugar|strong="H4725"\w*, \w para|strong="H5921"\w* condolerse \w de|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* consolarlo.
\p 
\v 12 Pero cuando levantaron \w los|strong="H5921"\w* \w ojos|strong="H5869"\w* \w desde|strong="H5921"\w* \w lejos|strong="H7350"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* pudieron reconocerlo, \w lloraron|strong="H1058"\w* \w a|strong="H3068"\w* gritos. Cada uno \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w rasgó|strong="H7167"\w* su ropa, \w y|strong="H5921"\w* lanzaron \w polvo|strong="H6083"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w cielo|strong="H8064"\w* \w sobre|strong="H5921"\w* sus \w cabezas|strong="H7218"\w*.
\v 13 \w Estuvieron|strong="H3427"\w* \w sentados|strong="H3427"\w* \w con|strong="H3588"\w* \w él|strong="H3588"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* suelo durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w* \w y|strong="H3588"\w* \w siete|strong="H7651"\w* \w noches|strong="H3915"\w*, sin \w hablarle|strong="H1696"\w* una \w palabra|strong="H1697"\w*, \w porque|strong="H3588"\w* \w veían|strong="H7200"\w* \w que|strong="H3588"\w* \w su|strong="H3588"\w* dolor era \w muy|strong="H3966"\w* \w grande|strong="H3966"\w*.
\c 3
\s1 Imprecación de Job
\p 
\v 1 Después de \w esto|strong="H3651"\w* Job \w abrió|strong="H6605"\w* su \w boca|strong="H6310"\w* y \w maldijo|strong="H7043"\w* su \w día|strong="H3117"\w*.
\p 
\v 2 \w Y|strong="H3068"\w* Job \w habló|strong="H6030"\w*:
\v 3 Perezca el \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w nací|strong="H3205"\w* y la \w noche|strong="H3915"\w* \w cuando|strong="H3117"\w* se dijo: Un \w varón|strong="H1397"\w* fue concebido.
\v 4 \w Sea|strong="H1961"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w oscuridad|strong="H2822"\w*. \w No|strong="H1961"\w* pregunte \nd ʼElohim\nd* \w desde|strong="H5921"\w* \w lo|strong="H1931"\w* \w alto|strong="H4605"\w* \w por|strong="H5921"\w* \w él|strong="H1931"\w*, ni \w claridad|strong="H5105"\w* \w lo|strong="H1931"\w* ilumine.
\v 5 \w Que|strong="H5921"\w* \w la|strong="H5921"\w* \w oscuridad|strong="H2822"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w tinieblas|strong="H2822"\w* reclamen \add ese día\add* \w para|strong="H5921"\w* \w ellas|strong="H5921"\w*, \w repose|strong="H7931"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* una nube, llénelo \w de|strong="H5921"\w* terror \w la|strong="H5921"\w* calina \w del|strong="H5921"\w* \w día|strong="H3117"\w*.
\v 6 \w Que|strong="H1931"\w* \w la|strong="H1931"\w* oscuridad \w se|strong="H1931"\w* apodere de \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w*. No \w se|strong="H1931"\w* cuente entre \w los|strong="H1931"\w* \w días|strong="H3117"\w* del \w año|strong="H8141"\w* ni aparezca en \w el|strong="H1931"\w* \w número|strong="H4557"\w* de \w los|strong="H1931"\w* \w meses|strong="H3391"\w*.
\p 
\v 7 \w Sea|strong="H1961"\w* \w esa|strong="H1931"\w* \w noche|strong="H3915"\w* estéril y \w los|strong="H1931"\w* gritos de júbilo \w no|strong="H1961"\w* penetren en \w ella|strong="H1931"\w*.
\v 8 \w Maldíganla|strong="H5344"\w* los \w que|strong="H3117"\w* maldicen en el \w día|strong="H3117"\w*, los \w que|strong="H3117"\w* se aprestan \w a|strong="H3068"\w* excitar al cocodrilo.
\v 9 \w Oscurézcanse|strong="H2821"\w* las \w estrellas|strong="H3556"\w* de su alborada. \w Espere|strong="H6960"\w* la luz, y no le venga, ni contemple los destellos de la aurora,
\v 10 \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w cerró|strong="H5462"\w* las \w puertas|strong="H1817"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* matriz donde \w yo|strong="H3588"\w* estaba, \w ni|strong="H3808"\w* \w escondió|strong="H5641"\w* \w la|strong="H3588"\w* miseria \w de|strong="H3588"\w* mis \w ojos|strong="H5869"\w*.
\p 
\v 11 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \w no|strong="H3808"\w* \w morí|strong="H4191"\w* yo \w en|strong="H3318"\w* la \w matriz|strong="H7358"\w* \w o|strong="H3068"\w* expiré al \w salir|strong="H3318"\w* del vientre?
\v 12 ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* hallé \w rodillas|strong="H1290"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* acogieron \w y|strong="H3588"\w* \w pechos|strong="H7699"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* amamantaron?
\v 13 \w Pues|strong="H3588"\w* \w ahora|strong="H6258"\w* yacería tranquilo, dormiría \w y|strong="H3588"\w* tendría descanso
\v 14 \w con|strong="H5973"\w* \w reyes|strong="H4428"\w* y \w consejeros|strong="H3289"\w* \w de|strong="H5973"\w* la tierra que reedificaron ruinas \w para|strong="H5973"\w* ellos,
\v 15 \w o|strong="H3068"\w* \w con|strong="H5973"\w* \w príncipes|strong="H8269"\w* \w que|strong="H1992"\w* tuvieron \w oro|strong="H2091"\w*, \w que|strong="H1992"\w* \w llenaron|strong="H4390"\w* \w de|strong="H5973"\w* \w plata|strong="H3701"\w* \w sus|strong="H1992"\w* palacios.
\v 16 ¡Oh! ¿Por \w qué|strong="H3808"\w* \w no|strong="H3808"\w* \w fui|strong="H1961"\w* escondido \w como|strong="H1961"\w* aborto, \w como|strong="H1961"\w* \w los|strong="H1961"\w* fetos \w que|strong="H3808"\w* \w nunca|strong="H3808"\w* \w ven|strong="H7200"\w* la luz?
\p 
\v 17 \w Allí|strong="H8033"\w* \w dejan|strong="H2308"\w* de perturbar los perversos. \w Allí|strong="H8033"\w* \w descansan|strong="H5117"\w* los de agotadas \w fuerzas|strong="H3581"\w*.
\v 18 Allí \w también|strong="H3162"\w* los cautivos gozan del reposo, \w sin|strong="H3808"\w* \w oír|strong="H8085"\w* la \w voz|strong="H6963"\w* del capataz.
\v 19 \w Allí|strong="H8033"\w* están \w el|strong="H1931"\w* \w pequeño|strong="H6996"\w* y \w el|strong="H1931"\w* \w grande|strong="H1419"\w*, y \w el|strong="H1931"\w* esclavo \w está|strong="H1931"\w* \w libre|strong="H2670"\w* de \w su|strong="H1931"\w* amo.
\p 
\v 20 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \w se|strong="H4100"\w* \w da|strong="H5414"\w* luz al desdichado, y \w vida|strong="H5315"\w* \w a|strong="H3068"\w* los \w de|strong="H5414"\w* \w ánimo|strong="H5315"\w* amargado,
\v 21 \w a|strong="H3068"\w* los que ansían la \w muerte|strong="H4194"\w* y no les llega aunque la busquen más que \w tesoros|strong="H4301"\w* escondidos,
\v 22 \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w que|strong="H3588"\w* se \w alegran|strong="H8055"\w* grandemente, \w y|strong="H3588"\w* se regocijan \w cuando|strong="H3588"\w* \w hallan|strong="H4672"\w* \w la|strong="H3588"\w* tumba,
\v 23 \w al|strong="H1157"\w* \w hombre|strong="H1397"\w* para quien su \w camino|strong="H1870"\w* está \w oculto|strong="H5641"\w*, y \w a|strong="H3068"\w* quien \nd ʼElohim\nd* tiene acorralado?
\p 
\v 24 \w Porque|strong="H3588"\w* \w en|strong="H3588"\w* lugar \w de|strong="H3588"\w* mi \w pan|strong="H3899"\w* viene mi suspiro, \w y|strong="H3588"\w* mis gemidos \w corren|strong="H5413"\w* \w como|strong="H3588"\w* \w aguas|strong="H4325"\w*,
\v 25 \w porque|strong="H3588"\w* \w me|strong="H3588"\w* cayó lo \w que|strong="H3588"\w* \w temía|strong="H3025"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w terror|strong="H6343"\w* \w que|strong="H3588"\w* tenía \w me|strong="H3588"\w* aconteció.
\v 26 ¡\w No|strong="H3808"\w* tengo paz, \w ni|strong="H3808"\w* tranquilidad, \w ni|strong="H3808"\w* \w reposo|strong="H8252"\w*, \w sino|strong="H3808"\w* me vino turbación!
\c 4
\s1 Intervención de Elifaz temanita
\p 
\v 1 Entonces intervino Elifaz \w temanita|strong="H8489"\w*:
\v 2 Si intentamos razonar contigo te será molesto. Pero, ¿\w quién|strong="H4310"\w* \w puede|strong="H3201"\w* refrenarse \w de|strong="H3811"\w* \w hablar|strong="H1697"\w*?
\v 3 \w Ciertamente|strong="H2009"\w* tú enseñabas \w a|strong="H3068"\w* \w muchos|strong="H7227"\w* y fortalecías las \w manos|strong="H3027"\w* débiles.
\v 4 Tus \w palabras|strong="H4405"\w* levantaban al que tropezaba y afirmabas las \w rodillas|strong="H1290"\w* decaídas.
\v 5 \w Pero|strong="H3588"\w* \w ahora|strong="H6258"\w* \w te|strong="H3588"\w* \w sucede|strong="H5060"\w* \w a|strong="H3068"\w* ti. \w Te|strong="H3588"\w* desalientas, \w te|strong="H3588"\w* \w tocó|strong="H5060"\w* \w a|strong="H3068"\w* ti \w y|strong="H3588"\w* \w te|strong="H3588"\w* turbas.
\v 6 ¿\w No|strong="H3808"\w* es tu temor \w a|strong="H3068"\w* \nd ʼElohim\nd* tu confianza, y la \w integridad|strong="H8537"\w* de tus procedimientos tu \w esperanza|strong="H8615"\w*?
\p 
\v 7 Te \w ruego|strong="H4994"\w* \w que|strong="H4310"\w* \w recuerdes|strong="H2142"\w*: ¿\w Quién|strong="H4310"\w* pereció jamás por ser \w inocente|strong="H5355"\w*? ¿\w Dónde|strong="H1931"\w* fueron destruidos \w los|strong="H1931"\w* \w rectos|strong="H3477"\w*?
\v 8 Según \w veo|strong="H7200"\w*, los que aran iniquidad y siembran aflicción, las cosechan.
\v 9 Por el aliento \w de|strong="H5397"\w* \nd ʼElohim\nd* perecen, y por el \w soplo|strong="H5397"\w* \w de|strong="H5397"\w* su ira son consumidos.
\v 10 El rugido del \w león|strong="H7826"\w*, la \w voz|strong="H6963"\w* fiera de la leona y los \w dientes|strong="H8127"\w* de sus cachorros son quebrados.
\v 11 \w El|strong="H1121"\w* león viejo perece por falta \w de|strong="H1121"\w* presa, y \w los|strong="H1121"\w* cachorros \w de|strong="H1121"\w* la leona se dispersan.
\p 
\v 12 Entonces un mensaje \w me|strong="H4480"\w* llegó \w a|strong="H3068"\w* hurtadillas, y mi oído percibió un susurro \w de|strong="H4480"\w* él
\v 13 \w en|strong="H5921"\w* inquietantes \w visiones|strong="H2384"\w* \w nocturnas|strong="H3915"\w*, cuando \w el|strong="H5921"\w* sueño profundo \w cae|strong="H5307"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* hombres.
\v 14 Un \w terror|strong="H6343"\w* se apoderó de mí, y \w todos|strong="H7230"\w* mis \w huesos|strong="H6106"\w* se estremecieron.
\v 15 \w Al|strong="H5921"\w* pasar un \w espíritu|strong="H7307"\w* frente \w a|strong="H3068"\w* \w mí|strong="H5921"\w* \w se|strong="H5921"\w* eriza \w el|strong="H5921"\w* pelo \w de|strong="H5921"\w* \w mi|strong="H5921"\w* cuerpo.
\v 16 \w Se|strong="H3808"\w* detiene, pero \w no|strong="H3808"\w* distingo su semblante. Una \w apariencia|strong="H4758"\w* \w está|strong="H5975"\w* \w delante|strong="H5048"\w* \w de|strong="H5048"\w* mis \w ojos|strong="H5869"\w*, hay silencio… y \w oigo|strong="H8085"\w* una \w voz|strong="H6963"\w* reposada:
\v 17 ¿\w Será|strong="H6213"\w* \w el|strong="H6213"\w* \w hombre|strong="H1397"\w* más justo que \nd ʼElohim\nd*? ¿\w El|strong="H6213"\w* \w hombre|strong="H1397"\w*, más puro que su \w Hacedor|strong="H6213"\w*?
\p 
\v 18 \w Ciertamente|strong="H2005"\w* en sus esclavos \w no|strong="H3808"\w* confía, y \w a|strong="H3068"\w* sus \w ángeles|strong="H4397"\w* atribuye insensatez.
\v 19 ¡Cuánto más los que viven en \w casas|strong="H1004"\w* \w de|strong="H6440"\w* \w barro|strong="H2563"\w* cimentadas en el \w polvo|strong="H6083"\w* serán desmenuzados \w por|strong="H6440"\w* la \w polilla|strong="H6211"\w*!
\v 20 \w Entre|strong="H1097"\w* la \w mañana|strong="H1242"\w* y la \w tarde|strong="H6153"\w* son destruidos, y \w sin|strong="H1097"\w* que alguno se dé cuenta, perecen para siempre.
\v 21 ¿\w No|strong="H3808"\w* les \w son|strong="H3808"\w* arrancadas las cuerdas de sus tiendas? En ellas \w mueren|strong="H4191"\w*, pero \w no|strong="H3808"\w* adquirieron \w sabiduría|strong="H2451"\w*.
\c 5
\p 
\v 1 ¡\w Clama|strong="H7121"\w* \w ahora|strong="H4994"\w*! ¿\w Habrá|strong="H3426"\w* \w quién|strong="H4310"\w* te \w responda|strong="H6030"\w*? ¿\w A|strong="H3068"\w* \w cuál|strong="H4310"\w* de los \w santos|strong="H6918"\w* acudirás?
\v 2 \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* ira \w mata|strong="H4191"\w* al necio, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w envidia|strong="H7068"\w* \w mata|strong="H4191"\w* al simple.
\v 3 \w Vi|strong="H7200"\w* al necio que echaba raíces, y al instante \w maldije|strong="H5344"\w* su vivienda.
\v 4 Sus \w hijos|strong="H1121"\w* están \w lejos|strong="H7368"\w* \w de|strong="H1121"\w* toda seguridad. Son aplastados en la \w puerta|strong="H8179"\w* y no habrá quién \w los|strong="H1121"\w* defienda.
\v 5 Su cosecha la devoran los hambrientos y aun la sacan de entre los espinos. Los sedientos sorben su hacienda.
\v 6 \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* aflicción \w no|strong="H3808"\w* \w sale|strong="H3318"\w* del \w polvo|strong="H6083"\w*, \w ni|strong="H3808"\w* \w el|strong="H3588"\w* sufrimiento \w brota|strong="H6779"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w tierra|strong="H6083"\w*,
\v 7 \w sino|strong="H3588"\w* \w el|strong="H3588"\w* \w hombre|strong="H1121"\w* \w nace|strong="H3205"\w* \w para|strong="H3588"\w* \w la|strong="H3588"\w* aflicción, \w como|strong="H3588"\w* las chispas salen hacia \w arriba|strong="H1361"\w*.
\p 
\v 8 \w Ciertamente|strong="H1875"\w* yo \w buscaría|strong="H1875"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd* y encomendaría \w a|strong="H3068"\w* Él mi causa,
\v 9 \w Quien|strong="H6213"\w* \w hace|strong="H6213"\w* cosas \w grandes|strong="H1419"\w* \w e|strong="H3068"\w* inescrutables, \w maravillas|strong="H6381"\w* incontables.
\v 10 \w Él|strong="H5921"\w* \w da|strong="H5414"\w* \w la|strong="H5921"\w* \w lluvia|strong="H4306"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* tierra \w y|strong="H5921"\w* \w envía|strong="H7971"\w* \w el|strong="H5921"\w* \w agua|strong="H4325"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* superficie \w de|strong="H5921"\w* \w los|strong="H5921"\w* campos.
\v 11 Él exalta \w a|strong="H3068"\w* los humildes y levanta \w a|strong="H3068"\w* los enlutados \w a|strong="H3068"\w* la seguridad.
\v 12 Frustra los \w pensamientos|strong="H4284"\w* de los astutos para \w que|strong="H3808"\w* \w nada|strong="H3808"\w* \w hagan|strong="H6213"\w* sus \w manos|strong="H3027"\w* y
\v 13 atrapa \w a|strong="H3068"\w* \w los|strong="H2450"\w* \w sabios|strong="H2450"\w* en su astucia. Frustra \w los|strong="H2450"\w* designios del perverso.
\p 
\v 14 Tropiezan de \w día|strong="H3119"\w* con la \w oscuridad|strong="H2822"\w* y \w a|strong="H3068"\w* mediodía andan \w a|strong="H3068"\w* tientas como de \w noche|strong="H3915"\w*.
\v 15 Así \w libra|strong="H3467"\w* al pobre de la \w espada|strong="H2719"\w*, de la \w boca|strong="H6310"\w* de los poderosos y de su \w mano|strong="H3027"\w*.
\v 16 El necesitado conserva la \w esperanza|strong="H8615"\w*. La perversidad cierra su \w boca|strong="H6310"\w*.
\p 
\v 17 Dichoso el hombre \w a|strong="H3068"\w* quien \nd ʼElohim\nd* disciplina. No menosprecies la \w corrección|strong="H4148"\w* de \nd ʼEL-Shadday\nd*,
\v 18 \w porque|strong="H3588"\w* \w Él|strong="H1931"\w* hace \w la|strong="H1931"\w* herida, \w pero|strong="H3588"\w* también \w la|strong="H1931"\w* venda. \w Hiere|strong="H4272"\w*, \w pero|strong="H3588"\w* \w sus|strong="H1931"\w* \w manos|strong="H3027"\w* sanan.
\v 19 Te \w librará|strong="H5337"\w* \w de|strong="H7451"\w* \w seis|strong="H8337"\w* \w tribulaciones|strong="H6869"\w*, y \w aun|strong="H3808"\w* en la séptima \w no|strong="H3808"\w* te \w tocará|strong="H5060"\w* el \w mal|strong="H7451"\w*.
\v 20 Durante la hambruna te librará de la \w muerte|strong="H4194"\w*, y del \w poder|strong="H3027"\w* de la \w espada|strong="H2719"\w* en la \w guerra|strong="H4421"\w*.
\v 21 Estarás \w escondido|strong="H2244"\w* del \w azote|strong="H7752"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w lengua|strong="H3956"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w temerás|strong="H3372"\w* \w cuando|strong="H3588"\w* venga \w la|strong="H3588"\w* \w destrucción|strong="H7701"\w*.
\v 22 Te reirás \w de|strong="H3372"\w* la \w destrucción|strong="H7701"\w* y \w de|strong="H3372"\w* la hambruna y no \w temerás|strong="H3372"\w* \w a|strong="H3068"\w* las fieras del campo,
\v 23 \w pues|strong="H3588"\w* \w aun|strong="H3588"\w* \w con|strong="H5973"\w* las piedras \w del|strong="H5973"\w* \w campo|strong="H7704"\w* harás \w pacto|strong="H1285"\w*, \w y|strong="H3588"\w* las \w bestias|strong="H2416"\w* \w del|strong="H5973"\w* \w campo|strong="H7704"\w* tendrán \w paz|strong="H7999"\w* \w contigo|strong="H5973"\w*.
\v 24 \w Sabrás|strong="H3045"\w* \w que|strong="H3588"\w* hay \w paz|strong="H7965"\w* \w en|strong="H3588"\w* tu tienda. \w Nada|strong="H3808"\w* \w te|strong="H3588"\w* faltará \w cuando|strong="H3588"\w* revises tu \w morada|strong="H5116"\w*.
\v 25 Verás también \w que|strong="H3588"\w* tu \w descendencia|strong="H2233"\w* \w es|strong="H3588"\w* numerosa \w y|strong="H3588"\w* tu \w prole|strong="H2233"\w* \w como|strong="H3588"\w* \w la|strong="H3588"\w* \w hierba|strong="H6212"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tierra.
\v 26 Irás \w a|strong="H3068"\w* la tumba en la vejez, como la gavilla \w de|strong="H6256"\w* trigo \w que|strong="H6256"\w* se recoge \w a|strong="H3068"\w* su \w tiempo|strong="H6256"\w*.
\p 
\v 27 \w Mira|strong="H2009"\w* \w que|strong="H1931"\w* \w esto|strong="H2063"\w* \w lo|strong="H1931"\w* investigamos, \w es|strong="H1931"\w* \w así|strong="H3651"\w*. Óyelo, y conócelo \w por|strong="H3651"\w* ti \w mismo|strong="H1931"\w*.
\c 6
\s1 Respuesta de Job a Elifaz temanita
\p 
\v 1 Entonces Job \w respondió|strong="H6030"\w*:
\v 2 ¡\w Oh|strong="H3863"\w*, \w si|strong="H3863"\w* se pesara \w mi|strong="H5375"\w* angustia, y se pusiera \w igualmente|strong="H3162"\w* en balanza \w juntamente|strong="H3162"\w* con \w mi|strong="H5375"\w* ruina!
\v 3 ¡Pesarían \w ahora|strong="H6258"\w* \w más|strong="H3588"\w* \w que|strong="H3588"\w* \w la|strong="H5921"\w* arena \w del|strong="H5921"\w* \w mar|strong="H3220"\w*! \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* mis \w palabras|strong="H1697"\w* fueron precipitadas,
\v 4 \w porque|strong="H3588"\w* \w en|strong="H3588"\w* mí están clavadas las flechas \w de|strong="H3588"\w* \nd ʼEL-Shadday\nd*. Mi \w espíritu|strong="H7307"\w* sorbe \w su|strong="H3588"\w* \w veneno|strong="H2534"\w*, \w y|strong="H3588"\w* terrores \w de|strong="H3588"\w* \nd ʼElohim\nd* \w me|strong="H3588"\w* combaten.
\v 5 ¿Rebuzca \w el|strong="H5921"\w* asno \w montés|strong="H6501"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w hierba|strong="H1877"\w*? ¿\w Muge|strong="H1600"\w* \w el|strong="H5921"\w* \w buey|strong="H7794"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* su pasto?
\v 6 ¿Se comerá lo insípido \w sin|strong="H1097"\w* \w sal|strong="H4417"\w*? ¿\w Hay|strong="H3426"\w* \w sabor|strong="H2940"\w* en la clara del huevo?
\v 7 \w Las|strong="H1992"\w* \w cosas|strong="H1992"\w* \w que|strong="H1992"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* \w rehusaba|strong="H3985"\w* \w tocar|strong="H5060"\w* son ahora \w mi|strong="H5315"\w* alimento nauseabundo.
\p 
\v 8 ¡\w Quién|strong="H4310"\w* \w me|strong="H4310"\w* \w diera|strong="H5414"\w* obtener mi \w petición|strong="H7596"\w*, y \w que|strong="H4310"\w* \nd ʼElohim\nd* \w me|strong="H4310"\w* otorgue lo \w que|strong="H4310"\w* tanto anhelo!
\v 9 ¡\w Que|strong="H3027"\w* \nd ʼElohim\nd* se digne aplastarme, \w que|strong="H3027"\w* suelte su \w mano|strong="H3027"\w* y acabe conmigo!
\v 10 Eso \w sería|strong="H1961"\w* \w mi|strong="H1961"\w* consuelo, \w y|strong="H3588"\w* \w aun|strong="H5750"\w* \w en|strong="H3588"\w* medio \w de|strong="H3588"\w* \w mi|strong="H1961"\w* \w dolor|strong="H2427"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* da tregua, saltaría \w de|strong="H3588"\w* gozo, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* negué las Palabras del \w Santo|strong="H6918"\w*.
\v 11 ¿\w Cuál|strong="H4100"\w* \w es|strong="H3588"\w* \w mi|strong="H5315"\w* \w fuerza|strong="H3581"\w* \w para|strong="H3588"\w* seguir \w esperando|strong="H3176"\w*? ¿\w Cuál|strong="H4100"\w* \w es|strong="H3588"\w* \w mi|strong="H5315"\w* propósito \w para|strong="H3588"\w* \w que|strong="H3588"\w* tenga \w aún|strong="H3588"\w* paciencia?
\v 12 ¿Es mi \w fortaleza|strong="H3581"\w* como la de las piedras, \w o|strong="H3068"\w* mi cuerpo es de \w bronce|strong="H5153"\w*?
\v 13 ¿Puedo sostenerme \w sobre|strong="H4480"\w* nada? ¿No fue todo \w auxilio|strong="H5833"\w* alejado \w de|strong="H4480"\w* mí?
\p 
\v 14 Para el hombre desconsolado debe haber bondad de su \w amigo|strong="H7453"\w*, \w a|strong="H3068"\w* fin de que no abandone el \w temor|strong="H3374"\w* \w a|strong="H3068"\w* \nd ʼEL-Shadday\nd*.
\v 15 Mis hermanos me traicionaron \w como|strong="H3644"\w* un \w torrente|strong="H5158"\w*. \w Pasan|strong="H5674"\w* \w como|strong="H3644"\w* corrientes impetuosas
\v 16 \w que|strong="H4480"\w* van turbias \w a|strong="H3068"\w* causa \w del|strong="H4480"\w* deshielo, \w y|strong="H5921"\w* \w la|strong="H5921"\w* nieve \w que|strong="H4480"\w* \w se|strong="H4480"\w* deshace \w en|strong="H5921"\w* \w ellas|strong="H5921"\w*.
\p 
\v 17 En el \w tiempo|strong="H6256"\w* del calor se desvanecen. \w Al|strong="H6256"\w* calentarse \w desaparecen|strong="H1846"\w*, se extinguen \w de|strong="H6256"\w* su \w lugar|strong="H4725"\w*.
\v 18 Se apartan de la senda de su rumbo, \w van|strong="H5927"\w* \w menguando|strong="H8414"\w* y se pierden.
\v 19 Las caravanas de Temán fijan su mirada en ellas, los viajeros de Sabá tienen su esperanza en ellas,
\v 20 \w pero|strong="H3588"\w* \w son|strong="H3588"\w* avergonzados \w en|strong="H5704"\w* \w su|strong="H3588"\w* esperanza, \w pues|strong="H3588"\w* llegan \w hasta|strong="H5704"\w* ellas \w y|strong="H3588"\w* quedan defraudados.
\v 21 \w En|strong="H3588"\w* verdad ustedes \w son|strong="H1961"\w* \w ahora|strong="H6258"\w* \w como|strong="H3588"\w* ellos. \w Ven|strong="H7200"\w* un terror \w y|strong="H3588"\w* \w temen|strong="H3372"\w*.
\v 22 ¿\w Yo|strong="H3588"\w* les dije: Tráiganme algo? ¿\w O|strong="H3068"\w*: Paguen \w de|strong="H3588"\w* \w su|strong="H3588"\w* hacienda \w por|strong="H3588"\w* mí?
\v 23 ¿\w O|strong="H3068"\w*: Líbrenme de la \w mano|strong="H3027"\w* del \w enemigo|strong="H6862"\w*? ¿\w O|strong="H3068"\w*: Rescátenme del \w poder|strong="H3027"\w* del opresor?
\p 
\v 24 Instrúyeme y me \w callaré|strong="H2790"\w*. Hazme entender en \w qué|strong="H4100"\w* erré.
\v 25 ¡\w Cuán|strong="H4100"\w* dolorosas son las palabras honestas! ¿Pero \w qué|strong="H4100"\w* prueba su reprensión?
\v 26 ¿\w Piensan|strong="H2803"\w* ustedes \w censurar|strong="H2803"\w* \w palabras|strong="H4405"\w* y los dichos de un desesperado que son como el \w viento|strong="H7307"\w*?
\p 
\v 27 Ustedes aun echan suertes \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w huérfanos|strong="H3490"\w* \w y|strong="H5921"\w* regatean \w con|strong="H5921"\w* su \w amigo|strong="H7453"\w*.
\v 28 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, dígnense mirarme \w y|strong="H5921"\w* opinen \w si|strong="H6440"\w* \w miento|strong="H3576"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* ustedes.
\v 29 Les \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* desistan. \w Que|strong="H4994"\w* \w no|strong="H1961"\w* \w haya|strong="H1961"\w* \w iniquidad|strong="H5766"\w*. \w Sí|strong="H4994"\w*, \w que|strong="H4994"\w* \w mi|strong="H4994"\w* \w justicia|strong="H6664"\w* \w aún|strong="H5750"\w* permanezca.
\v 30 ¿\w Hay|strong="H3426"\w* \w iniquidad|strong="H5766"\w* en mi \w lengua|strong="H3956"\w*? ¿Mi paladar \w no|strong="H3808"\w* distingue \w lo|strong="H3808"\w* destructivo?
\c 7
\s1 Queja de Job ante \nd ʼElohim\nd*
\p 
\v 1 ¿\w No|strong="H3808"\w* es \w el|strong="H5921"\w* destino \w del|strong="H5921"\w* hombre \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra una lucha? ¿\w No|strong="H3808"\w* \w son|strong="H3808"\w* sus \w días|strong="H3117"\w* \w como|strong="H5921"\w* \w los|strong="H5921"\w* \w de|strong="H5921"\w* un jornalero,
\v 2 Como el esclavo que \w anhela|strong="H7602"\w* la \w sombra|strong="H6738"\w* \w o|strong="H3068"\w* como un jornalero que \w espera|strong="H6960"\w* su pago?
\v 3 \w Así|strong="H3651"\w* yo heredé \w meses|strong="H3391"\w* sin provecho y me fueron asignadas \w noches|strong="H3915"\w* de aflicción.
\v 4 \w Cuando|strong="H4970"\w* estoy \w acostado|strong="H7901"\w* digo: ¿\w Cuándo|strong="H4970"\w* me \w levantaré|strong="H6965"\w*? \w Y|strong="H3068"\w* \w la|strong="H7646"\w* noche se alarga, \w y|strong="H5704"\w* me lleno \w de|strong="H5704"\w* inquietudes \w hasta|strong="H5704"\w* el alba.
\v 5 Mi \w carne|strong="H1320"\w* está cubierta \w de|strong="H3847"\w* \w gusanos|strong="H7415"\w* y \w de|strong="H3847"\w* costras \w de|strong="H3847"\w* \w polvo|strong="H6083"\w*. Mi \w piel|strong="H5785"\w* se agrieta y supura.
\p 
\v 6 Mis \w días|strong="H3117"\w* \w se|strong="H4480"\w* \w me|strong="H4480"\w* van \w más|strong="H4480"\w* veloces \w que|strong="H4480"\w* la lanzadera y \w se|strong="H4480"\w* \w me|strong="H4480"\w* acaban sin \w esperanza|strong="H8615"\w*.
\v 7 \w Acuérdate|strong="H2142"\w* \w que|strong="H3588"\w* mi \w vida|strong="H2416"\w* \w es|strong="H3588"\w* un \w soplo|strong="H7307"\w*. Mis \w ojos|strong="H5869"\w* \w no|strong="H3808"\w* \w volverán|strong="H7725"\w* \w a|strong="H3068"\w* \w ver|strong="H7200"\w* \w el|strong="H3588"\w* \w bien|strong="H2896"\w*.
\v 8 El \w ojo|strong="H5869"\w* del \w que|strong="H3808"\w* me ve ya \w no|strong="H3808"\w* me verán. Tus \w ojos|strong="H5869"\w* \w se|strong="H3808"\w* fijarán en mí, pero \w no|strong="H3808"\w* existiré.
\v 9 \w Como|strong="H3651"\w* la \w nube|strong="H6051"\w* \w se|strong="H3808"\w* deshace y \w se|strong="H3808"\w* \w va|strong="H3068"\w*, \w así|strong="H3651"\w* el \w que|strong="H3808"\w* \w baja|strong="H3381"\w* al \tl Seol\tl*\f + \fr 7:9 \ft \tl Seol\tl*: lugar de los muertos.\f* \w no|strong="H3808"\w* \w subirá|strong="H5927"\w*.
\v 10 \w No|strong="H3808"\w* regresa \w a|strong="H3068"\w* su vivienda y ya \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w reconoce|strong="H5234"\w* su \w lugar|strong="H4725"\w*.
\p 
\v 11 Por tanto, \w no|strong="H3808"\w* refrenaré \w mi|strong="H5315"\w* \w boca|strong="H6310"\w*. \w Hablaré|strong="H1696"\w* en \w la|strong="H1571"\w* \w angustia|strong="H6862"\w* de \w mi|strong="H5315"\w* \w espíritu|strong="H7307"\w*. Me quejaré en \w la|strong="H1571"\w* \w amargura|strong="H4751"\w* de \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*.
\v 12 ¿Soy \w yo|strong="H3588"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w o|strong="H3068"\w* \w el|strong="H5921"\w* monstruo marino \w para|strong="H5921"\w* \w que|strong="H3588"\w* asignes guardia \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*?
\v 13 \w Si|strong="H3588"\w* digo: \w Me|strong="H3588"\w* \w consolará|strong="H5162"\w* \w mi|strong="H5375"\w* lecho, \w mi|strong="H5375"\w* \w cama|strong="H4904"\w* \w aliviará|strong="H5162"\w* \w mi|strong="H5375"\w* queja,
\v 14 entonces me aterras con \w sueños|strong="H2472"\w* y me turbas con \w visiones|strong="H2384"\w*.
\v 15 De manera que \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* prefiere la asfixia, la \w muerte|strong="H4194"\w* más bien que mis \w huesos|strong="H6106"\w*.
\v 16 Repugno \w la|strong="H3588"\w* \w vida|strong="H2421"\w*. \w No|strong="H3808"\w* voy \w a|strong="H3068"\w* \w vivir|strong="H2421"\w* \w para|strong="H3588"\w* \w siempre|strong="H5769"\w*. \w Déjame|strong="H2308"\w*, mis \w días|strong="H3117"\w* \w son|strong="H3588"\w* \w vanidad|strong="H1892"\w*.
\p 
\v 17 ¿\w Qué|strong="H3588"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* hombre \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w lo|strong="H4100"\w* engrandezcas, \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* preocupes \w por|strong="H3588"\w* \w él|strong="H3588"\w*,
\v 18 para que lo examines cada \w mañana|strong="H1242"\w* y lo pruebes en todo \w momento|strong="H7281"\w*?
\v 19 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4100"\w* \w no|strong="H3808"\w* apartarás tu mirada \w de|strong="H4480"\w* mí, \w ni|strong="H3808"\w* \w me|strong="H4480"\w* soltarás \w para|strong="H5704"\w* \w que|strong="H4100"\w* \w trague|strong="H1104"\w* saliva?
\v 20 \w Si|strong="H1961"\w* \w pequé|strong="H2398"\w*, ¿\w cuál|strong="H4100"\w* \add daño\add* \w te|strong="H5921"\w* hago \w a|strong="H3068"\w* \w Ti|strong="H5921"\w*, \w oh|strong="H4100"\w* Guardián \w de|strong="H5921"\w* \w los|strong="H5921"\w* hombres? ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w me|strong="H5921"\w* \w pones|strong="H7760"\w* \w como|strong="H4100"\w* blanco tuyo \w hasta|strong="H5921"\w* convertirme \w en|strong="H5921"\w* una \w carga|strong="H4853"\w* \w para|strong="H5921"\w* \w mí|strong="H5921"\w* mismo?
\v 21 ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* \w no|strong="H3808"\w* \w quitas|strong="H5375"\w* \w mi|strong="H5375"\w* \w rebelión|strong="H6588"\w* \w y|strong="H3588"\w* perdonas \w mi|strong="H5375"\w* \w iniquidad|strong="H5771"\w*? \w Porque|strong="H3588"\w* \w ahora|strong="H6258"\w* \w me|strong="H3588"\w* acostaré \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w polvo|strong="H6083"\w*. Tú \w me|strong="H3588"\w* buscarás, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* estaré.
\c 8
\s1 Intervención de Bildad suhita
\p 
\v 1 Entonces intervino \w Bildad|strong="H1085"\w* \w suhita|strong="H7747"\w*:
\v 2 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H5704"\w* \w hablarás|strong="H4448"\w* esas cosas, \w y|strong="H5704"\w* los dichos \w de|strong="H5704"\w* tu \w boca|strong="H6310"\w* \w serán|strong="H6310"\w* \w como|strong="H5704"\w* \w viento|strong="H7307"\w* impetuoso?
\v 3 ¿Él tuerce lo recto? ¿\nd ʼEL-Shadday\nd* pervierte la \w justicia|strong="H6664"\w*?
\v 4 Si tus \w hijos|strong="H1121"\w* \w pecaron|strong="H2398"\w* contra \w Él|strong="H1121"\w*, \w Él|strong="H1121"\w* \w los|strong="H1121"\w* entregó al \w poder|strong="H3027"\w* \w de|strong="H1121"\w* su transgresión.
\v 5 Si tú buscas \w a|strong="H3068"\w* \nd ʼElohim\nd* por la mañana \w e|strong="H3068"\w* imploras \w a|strong="H3068"\w* \nd ʼEL-Shadday\nd*,
\v 6 \w si|strong="H3588"\w* eres \w puro|strong="H2134"\w* \w y|strong="H3588"\w* \w recto|strong="H3477"\w*, \w ciertamente|strong="H3588"\w* \w ahora|strong="H6258"\w* \w se|strong="H5921"\w* levantará \w y|strong="H3588"\w* restaurará tus \w justos|strong="H6664"\w* bienes.
\v 7 Aunque tu \w principio|strong="H7225"\w* \w sea|strong="H1961"\w* \w pequeño|strong="H4705"\w*, tu final \w será|strong="H1961"\w* \w muy|strong="H3966"\w* \w grande|strong="H3966"\w*.
\p 
\v 8 \w Te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* preguntes \w a|strong="H3068"\w* las \w generaciones|strong="H1755"\w* pasadas \w y|strong="H3588"\w* consideres las cosas investigadas \w por|strong="H3588"\w* \w los|strong="H3588"\w* antepasados \w de|strong="H3588"\w* ellas.
\v 9 \w Porque|strong="H3588"\w* \w nosotros|strong="H5921"\w* somos \w de|strong="H5921"\w* \w ayer|strong="H8543"\w* \w y|strong="H3588"\w* \w nada|strong="H3808"\w* \w sabemos|strong="H3045"\w*. Nuestros \w días|strong="H3117"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w son|strong="H3588"\w* \w como|strong="H3588"\w* una \w sombra|strong="H6738"\w*.
\v 10 ¿\w No|strong="H3808"\w* te instruirán \w ellos|strong="H1992"\w* y te hablarán con \w palabras|strong="H4405"\w* salidas de \w su|strong="H1992"\w* \w corazón|strong="H3820"\w*?
\p 
\v 11 ¿El papiro \w crece|strong="H1342"\w* donde \w no|strong="H3808"\w* hay pantano? ¿\w Crece|strong="H1342"\w* el junco \w sin|strong="H3808"\w* \w agua|strong="H4325"\w*?
\v 12 Cuando \w aún|strong="H5750"\w* están verdes y \w no|strong="H3808"\w* están cortados, \w se|strong="H3808"\w* secan \w antes|strong="H6440"\w* \w que|strong="H3808"\w* las otras hierbas.
\v 13 \w Así|strong="H3651"\w* son las sendas \w de|strong="H7911"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3605"\w* olvidan \w a|strong="H3068"\w* \nd ʼElohim\nd*. \w Así|strong="H3651"\w* \w se|strong="H3651"\w* desvanece \w la|strong="H3605"\w* \w esperanza|strong="H8615"\w* del impío,
\v 14 porque su \w confianza|strong="H4009"\w* es frágil, y su \w seguridad|strong="H4009"\w* como telaraña.
\v 15 \w Si|strong="H3808"\w* \w se|strong="H5921"\w* apoya \w en|strong="H5921"\w* su \w casa|strong="H1004"\w*, \w ésta|strong="H5975"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* sostendrá. \w Si|strong="H3808"\w* \w se|strong="H5921"\w* aferra \w a|strong="H3068"\w* \w ella|strong="H5921"\w*, \w no|strong="H3808"\w* \w lo|strong="H5921"\w* soportará.
\v 16 \w Él|strong="H1931"\w* \w está|strong="H1931"\w* verde \w delante|strong="H6440"\w* \w del|strong="H5921"\w* \w sol|strong="H8121"\w*, \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w su|strong="H1931"\w* huerto brota \w su|strong="H1931"\w* retoño,
\v 17 aunque sus \w raíces|strong="H8328"\w* están entrelazadas \w sobre|strong="H5921"\w* un \w montón|strong="H1530"\w* \w de|strong="H5921"\w* rocas \w y|strong="H5921"\w* buscan un lugar \w entre|strong="H5921"\w* \w las|strong="H5921"\w* piedras.
\v 18 \w Si|strong="H3808"\w* \w se|strong="H3808"\w* arranca de su \w lugar|strong="H4725"\w*, éste \w lo|strong="H3808"\w* negará: ¡\w No|strong="H3808"\w* te \w vi|strong="H7200"\w* \w nunca|strong="H3808"\w*!
\v 19 \w Ciertamente|strong="H2005"\w* \w así|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w gozo|strong="H4885"\w* de \w su|strong="H1931"\w* \w camino|strong="H1870"\w*. Del \w polvo|strong="H6083"\w* brotarán otros.
\p 
\v 20 \w Mira|strong="H2005"\w*, tan \w ciertamente|strong="H2005"\w* como \nd ʼElohim\nd* \w nunca|strong="H3808"\w* sostiene \w a|strong="H3068"\w* los malhechores, \w así|strong="H2388"\w* \w nunca|strong="H3808"\w* \w se|strong="H3808"\w* aparta del hombre intachable.
\v 21 \w Aún|strong="H5704"\w* \w llenará|strong="H4390"\w* tu \w boca|strong="H6310"\w* \w de|strong="H5704"\w* risa \w y|strong="H5704"\w* tus \w labios|strong="H8193"\w* \w con|strong="H5704"\w* un grito \w de|strong="H5704"\w* \w júbilo|strong="H8643"\w*.
\v 22 Los que te \w aborrecen|strong="H8130"\w* serán cubiertos \w de|strong="H3847"\w* vergüenza. La morada \w de|strong="H3847"\w* los \w impíos|strong="H7563"\w* desaparecerá.
\c 9
\s1 La aflicción inexplicable de Job
\p 
\v 1 Entonces Job \w respondió|strong="H6030"\w*:
\v 2 \w Ciertamente|strong="H3588"\w* \w yo|strong="H3588"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \w es|strong="H3588"\w* \w así|strong="H3651"\w*. ¿\w Pero|strong="H3588"\w* \w cómo|strong="H4100"\w* puede un hombre justificarse ante \nd ʼElohim\nd*?
\v 3 \w Aunque|strong="H3808"\w* uno \w quiera|strong="H2654"\w* disputar \w con|strong="H5973"\w* \w Él|strong="H5973"\w*, \w no|strong="H3808"\w* \w le|strong="H5973"\w* podría \w responder|strong="H6030"\w* una vez \w entre|strong="H5973"\w* 1.000.
\v 4 \w Él|strong="H4310"\w* es \w sabio|strong="H2450"\w* de \w corazón|strong="H3824"\w* y poderoso en \w fortaleza|strong="H3581"\w*. ¿\w Quién|strong="H4310"\w* se endureció contra \w Él|strong="H4310"\w* y salió ileso?
\v 5 Arranca las montañas con su furor, y \w no|strong="H3808"\w* \w saben|strong="H3045"\w* quién las \w trastornó|strong="H2015"\w*.
\v 6 Sacude la tierra de su \w lugar|strong="H4725"\w* y estremece sus \w columnas|strong="H5982"\w*.
\v 7 Él manda \w al|strong="H1157"\w* sol, y \w no|strong="H3808"\w* brilla. Coloca sello \w a|strong="H3068"\w* las \w estrellas|strong="H3556"\w*.
\v 8 \w Él|strong="H5921"\w* solo \w extendió|strong="H5186"\w* \w el|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w y|strong="H5921"\w* camina \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* olas \w del|strong="H5921"\w* \w mar|strong="H3220"\w*.
\v 9 \w Él|strong="H6213"\w* \w hizo|strong="H6213"\w* la Osa, \w el|strong="H6213"\w* Orión, las Pléyades y las secretas cámaras del sur.
\v 10 \w Él|strong="H6213"\w* \w hace|strong="H6213"\w* cosas grandiosas, inescrutables, \w y|strong="H5704"\w* \w maravillas|strong="H6381"\w* incontables.
\v 11 \w Ciertamente|strong="H2005"\w* \w pasa|strong="H5674"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w lo|strong="H5921"\w* \w veo|strong="H7200"\w*. \w Si|strong="H2005"\w* \w pasa|strong="H5674"\w* adelante \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w no|strong="H3808"\w* \w lo|strong="H5921"\w* percibo.
\v 12 \w Si|strong="H2005"\w* \w Él|strong="H4310"\w* arrebata, ¿\w quién|strong="H4310"\w* \w lo|strong="H4100"\w* resistirá? ¿\w Quién|strong="H4310"\w* \w le|strong="H4310"\w* dirá: \w Qué|strong="H4100"\w* \w haces|strong="H6213"\w*?
\p 
\v 13 \nd ʼElohim\nd* \w no|strong="H3808"\w* reprime su ira. \w Bajo|strong="H8478"\w* Él \w se|strong="H3808"\w* abaten los \w que|strong="H3808"\w* \w ayudan|strong="H5826"\w* \w a|strong="H3068"\w* los soberbios.
\v 14 ¡\w Cuánto|strong="H3588"\w* \w menos|strong="H3588"\w* \w yo|strong="H3588"\w* puedo replicarle, al rebuscar \w palabras|strong="H1697"\w* frente \w a|strong="H3068"\w* \w Él|strong="H5973"\w*!
\v 15 \w A|strong="H3068"\w* Él yo, \w aunque|strong="H3808"\w* sea recto, \w no|strong="H3808"\w* me atrevo \w a|strong="H3068"\w* \w responder|strong="H6030"\w*. \w Más|strong="H6030"\w* bien imploro la clemencia de \w mi|strong="H6030"\w* \w Juez|strong="H8199"\w*.
\v 16 \w Si|strong="H3588"\w* \w lo|strong="H3808"\w* invoco, \w y|strong="H3588"\w* \w Él|strong="H3588"\w* \w me|strong="H3588"\w* \w responde|strong="H6030"\w*, \w no|strong="H3808"\w* podría creer \w que|strong="H3588"\w* \w me|strong="H3588"\w* oye.
\v 17 Porque me quebranta con una tormenta y \w multiplica|strong="H7235"\w* mis heridas sin causa.
\v 18 \w No|strong="H3808"\w* \w me|strong="H3588"\w* deja recuperar aliento, \w mas|strong="H3588"\w* \w bien|strong="H3588"\w* \w me|strong="H3588"\w* llena \w de|strong="H3588"\w* amarguras.
\v 19 \w Si|strong="H2009"\w* apelo \w a|strong="H3068"\w* la \w fuerza|strong="H3581"\w*, ¡\w ciertamente|strong="H2009"\w* \w Él|strong="H4310"\w* es poderoso! \w Y|strong="H3068"\w* \w si|strong="H2009"\w* acudo al \w juicio|strong="H4941"\w*, ¿\w quién|strong="H4310"\w* lo convocará?
\v 20 Si me declaro justo, mi \w boca|strong="H6310"\w* me condenará. Aunque sea intachable, Él me declarará perverso.
\p 
\v 21 Soy intachable, \w sin|strong="H3808"\w* embargo, \w no|strong="H3808"\w* me \w conozco|strong="H3045"\w* \w a|strong="H3068"\w* \w mí|strong="H5315"\w* mismo. Desprecio \w mi|strong="H5315"\w* \w vida|strong="H5315"\w*.
\p 
\v 22 Todo \w es|strong="H1931"\w* una \w misma|strong="H1931"\w* cosa. \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w* digo: \w Él|strong="H1931"\w* destruye \w al|strong="H5921"\w* intachable \w y|strong="H5921"\w* \w al|strong="H5921"\w* perverso.
\v 23 Si el \w azote|strong="H7752"\w* \w mata|strong="H4191"\w* de repente, Él se burla de la desesperación del \w inocente|strong="H5355"\w*.
\v 24 \w La|strong="H1931"\w* tierra \w es|strong="H1931"\w* \w entregada|strong="H5414"\w* en \w manos|strong="H3027"\w* \w de|strong="H6440"\w* \w los|strong="H1931"\w* perversos. \w Él|strong="H1931"\w* \w cubre|strong="H3680"\w* \w los|strong="H1931"\w* semblantes \w de|strong="H6440"\w* \w sus|strong="H1931"\w* \w jueces|strong="H8199"\w*. \w Si|strong="H3808"\w* \w no|strong="H3808"\w* \w es|strong="H1931"\w* \w así|strong="H1931"\w*, ¿entonces, \w quién|strong="H4310"\w*?
\p 
\v 25 Mis \w días|strong="H3117"\w* \w son|strong="H3808"\w* \w más|strong="H4480"\w* veloces \w que|strong="H4480"\w* un corredor. \w Huyeron|strong="H1272"\w*. \w No|strong="H3808"\w* \w vieron|strong="H7200"\w* el \w bien|strong="H2896"\w*.
\v 26 \w Se|strong="H5921"\w* deslizaron \w como|strong="H5973"\w* botes \w de|strong="H5921"\w* junco, \w como|strong="H5973"\w* \w el|strong="H5921"\w* águila \w que|strong="H5921"\w* \w se|strong="H5921"\w* lanza \w sobre|strong="H5921"\w* su presa.
\v 27 \w Si|strong="H6440"\w* digo: \w Olvidaré|strong="H7911"\w* mi queja, mudaré mi semblante y me alegraré,
\v 28 \w entonces|strong="H3588"\w* \w me|strong="H3588"\w* turban \w todos|strong="H3605"\w* mis dolores. \w Sé|strong="H3045"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H3588"\w* tendrás \w como|strong="H3588"\w* inocente,
\v 29 y \w que|strong="H4100"\w* soy declarado perverso. ¿Para \w qué|strong="H4100"\w* entonces me fatigo en \w vano|strong="H1892"\w*?
\v 30 Aunque me lave con agua de nieve, y limpie mis \w manos|strong="H3709"\w* con lejía,
\v 31 aún me hundirás en el lodo, y mis ropas me repugnarán.
\p 
\v 32 \w Porque|strong="H3588"\w* \w Él|strong="H3588"\w* \w no|strong="H3808"\w* \w es|strong="H3588"\w* hombre \w como|strong="H3588"\w* \w yo|strong="H3588"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* le \w responda|strong="H6030"\w*, \w y|strong="H3588"\w* vayamos \w juntos|strong="H3162"\w* \w a|strong="H3068"\w* \w juicio|strong="H4941"\w*.
\v 33 \w No|strong="H3863"\w* \w hay|strong="H3426"\w* un \w árbitro|strong="H3198"\w* \w entre|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w que|strong="H5921"\w* coloque su \w mano|strong="H3027"\w* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w*,
\v 34 \w que|strong="H5921"\w* \w quite|strong="H5493"\w* su \w vara|strong="H7626"\w* \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w no|strong="H5921"\w* \w me|strong="H5921"\w* espante su terror.
\p 
\v 35 \w Entonces|strong="H3588"\w* \w yo|strong="H3588"\w* \w hablaría|strong="H1696"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* le temería. \w Pero|strong="H3588"\w* \w yo|strong="H3588"\w* mismo \w no|strong="H3808"\w* estoy \w en|strong="H3588"\w* \w esa|strong="H3651"\w* condición.
\c 10
\s1 Reclamo de Job ante \nd ʼElohim\nd*
\p 
\v 1 ¡\w Mi|strong="H5921"\w* \w alma|strong="H5315"\w* \w está|strong="H5921"\w* hastiada \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w vida|strong="H5315"\w*! Daré rienda suelta \w a|strong="H3068"\w* \w mi|strong="H5921"\w* queja. \w Hablaré|strong="H1696"\w* \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w amargura|strong="H4751"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w alma|strong="H5315"\w*.
\v 2 Diré \w a|strong="H3068"\w* \nd ʼElohim\nd*: ¡\w No|strong="H5921"\w* \w me|strong="H5921"\w* condenes! Hazme \w saber|strong="H3045"\w* \w por|strong="H5921"\w* \w qué|strong="H4100"\w* contiendes conmigo.
\v 3 ¿\w En|strong="H5921"\w* verdad, \w es|strong="H3588"\w* \w justo|strong="H7563"\w* \w para|strong="H5921"\w* \w Ti|strong="H5921"\w* oprimir, \w desechar|strong="H3988"\w* \w la|strong="H5921"\w* obra \w de|strong="H5921"\w* tus \w manos|strong="H3709"\w* \w y|strong="H3588"\w* favorecer \w el|strong="H5921"\w* designio \w de|strong="H5921"\w* \w los|strong="H5921"\w* perversos?
\v 4 ¿Tienes \w ojos|strong="H5869"\w* humanos y miras como \w mira|strong="H7200"\w* el hombre?
\v 5 ¿Son tus \w días|strong="H3117"\w* como los \w días|strong="H3117"\w* del \w hombre|strong="H1397"\w* \w o|strong="H3068"\w* tus \w años|strong="H8141"\w* como los \w años|strong="H8141"\w* del \w hombre|strong="H1397"\w*,
\v 6 \w para|strong="H3588"\w* \w que|strong="H3588"\w* indagues \w mi|strong="H1245"\w* \w iniquidad|strong="H5771"\w* \w e|strong="H3068"\w* investigues \w mi|strong="H1245"\w* \w pecado|strong="H2403"\w*?
\v 7 Tú sabes \w que|strong="H3588"\w* \w no|strong="H3808"\w* soy culpable, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* hay quien \w libre|strong="H5337"\w* \w de|strong="H5921"\w* tu \w mano|strong="H3027"\w*.
\p 
\v 8 Tus \w manos|strong="H3027"\w* me \w hicieron|strong="H6213"\w* y me formaron. ¿\w Y|strong="H3068"\w* ahora me \w destruyes|strong="H1104"\w*?
\v 9 Recuerda, \w te|strong="H3588"\w* \w ruego|strong="H4994"\w*, \w que|strong="H3588"\w* del \w barro|strong="H2563"\w* \w me|strong="H3588"\w* moldeaste. ¿\w Y|strong="H3068"\w* al \w polvo|strong="H6083"\w* \w me|strong="H3588"\w* \w harás|strong="H6213"\w* \w volver|strong="H7725"\w*?
\v 10 ¿\w No|strong="H3808"\w* me vertiste como \w leche|strong="H2461"\w* y me cuajaste como queso?
\v 11 Me cubriste \w de|strong="H3847"\w* \w piel|strong="H5785"\w* y \w de|strong="H3847"\w* \w carne|strong="H1320"\w*, con \w huesos|strong="H6106"\w* y tendones me tejiste.
\v 12 Me otorgaste \w vida|strong="H2416"\w* y \w misericordia|strong="H2617"\w*, y \w tu|strong="H6213"\w* cuidado preservó mi \w espíritu|strong="H7307"\w*.
\p 
\v 13 Tenías \w estas|strong="H2063"\w* \w cosas|strong="H3045"\w* ocultas \w en|strong="H5973"\w* tu \w corazón|strong="H3824"\w*. \w Yo|strong="H3588"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \w esto|strong="H2063"\w* estaba \w contigo|strong="H5973"\w*.
\v 14 \w Si|strong="H3808"\w* \w peco|strong="H2398"\w*, Tú me observas, y \w no|strong="H3808"\w* me tendrás \w como|strong="H5771"\w* limpio de mi \w culpa|strong="H5352"\w*.
\v 15 \w Si|strong="H3808"\w* soy malo, ¡ay \w de|strong="H7646"\w* \w mí|strong="H5375"\w*! \w Y|strong="H3068"\w* \w si|strong="H3808"\w* soy justo, \w no|strong="H3808"\w* \w levantaré|strong="H5375"\w* \w mi|strong="H5375"\w* \w cabeza|strong="H7218"\w*. Estoy hastiado \w de|strong="H7646"\w* \w la|strong="H7646"\w* \w afrenta|strong="H7036"\w* y \w de|strong="H7646"\w* ver \w mi|strong="H5375"\w* \w aflicción|strong="H6040"\w*.
\v 16 Si mi cabeza se levanta, me cazas como \w a|strong="H3068"\w* \w león|strong="H7826"\w* y \w vuelves|strong="H7725"\w* \w a|strong="H3068"\w* mostrar tus proezas en mí.
\v 17 \w Renuevas|strong="H2318"\w* tus \w testigos|strong="H5707"\w* \w contra|strong="H5973"\w* mí y aumentas \w contra|strong="H5973"\w* mí tu furor \w como|strong="H5973"\w* tropas \w de|strong="H5048"\w* relevo.
\p 
\v 18 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* entonces me \w sacaste|strong="H3318"\w* \w de|strong="H5869"\w* la \w matriz|strong="H7358"\w*? ¡Hubiera yo expirado \w sin|strong="H3808"\w* \w que|strong="H4100"\w* \w ningún|strong="H3808"\w* \w ojo|strong="H5869"\w* me viera!
\v 19 \w Sería|strong="H1961"\w* \w como|strong="H1961"\w* \w si|strong="H3808"\w* \w nunca|strong="H3808"\w* hubiera existido, \w llevado|strong="H2986"\w* del vientre \w a|strong="H3068"\w* la tumba.
\v 20 ¿\w No|strong="H3808"\w* \w son|strong="H3808"\w* \w pocos|strong="H4592"\w* mis \w días|strong="H3117"\w*? \w Cesa|strong="H2308"\w* \w pues|strong="H4480"\w*, y \w déjame|strong="H2308"\w*, \w para|strong="H4480"\w* \w que|strong="H4480"\w* \w me|strong="H4480"\w* consuele un \w poco|strong="H4592"\w*
\v 21 \w antes|strong="H2962"\w* \w que|strong="H3808"\w* me \w vaya|strong="H3212"\w* \w a|strong="H3068"\w* la región tenebrosa de la \w muerte|strong="H6757"\w* para \w no|strong="H3808"\w* \w volver|strong="H7725"\w*,
\v 22 tierra de \w oscuridad|strong="H5890"\w*, lóbrega, lugar de sombra de \w muerte|strong="H6757"\w*, \w sin|strong="H3808"\w* \w orden|strong="H5468"\w*, donde la \w luz|strong="H6757"\w* es \w como|strong="H3644"\w* densa \w oscuridad|strong="H5890"\w*.
\c 11
\s1 Intervención de Sofar naamatita
\p 
\v 1 Entonces Sofar \w naamatita|strong="H5284"\w* \w respondió|strong="H6030"\w*:
\v 2 ¿\w No|strong="H3808"\w* habrá \w respuesta|strong="H1697"\w* \w a|strong="H3068"\w* la \w abundancia|strong="H7230"\w* \w de|strong="H1697"\w* \w palabras|strong="H1697"\w*? ¿\w Será|strong="H3808"\w* \w justificado|strong="H6663"\w* el \w que|strong="H3808"\w* \w habla|strong="H1697"\w* \w mucho|strong="H7230"\w*?
\v 3 ¿Harán \w callar|strong="H2790"\w* \w a|strong="H3068"\w* los \w hombres|strong="H4962"\w* tus jactancias? ¿Harás escarnio sin que alguno te \w avergüence|strong="H3637"\w*?
\v 4 \w Pues|strong="H1961"\w* dijiste: \w Mi|strong="H1961"\w* \w enseñanza|strong="H3948"\w* \w es|strong="H1961"\w* \w pura|strong="H2134"\w*, y \w soy|strong="H1961"\w* inocente \w delante|strong="H5869"\w* \w de|strong="H5869"\w* Ti.
\v 5 Pero, \w quién|strong="H4310"\w* \w diera|strong="H5414"\w* \w que|strong="H4310"\w* \nd ʼElohim\nd* \w hable|strong="H1696"\w* y abra su \w boca|strong="H8193"\w* hacia \w ti|strong="H5973"\w*.
\v 6 \w Te|strong="H3588"\w* \w declare|strong="H5046"\w* secretos \w de|strong="H3588"\w* \w sabiduría|strong="H2451"\w*, \w porque|strong="H3588"\w* \w Él|strong="H3588"\w* \w es|strong="H3588"\w* \w de|strong="H3588"\w* múltiple entendimiento. \w Así|strong="H3588"\w* entenderías \w que|strong="H3588"\w* \nd ʼElohim\nd*, \w en|strong="H3588"\w* tu favor, \w te|strong="H3588"\w* castiga \w menos|strong="H3588"\w* \w de|strong="H3588"\w* lo \w que|strong="H3588"\w* merece tu \w iniquidad|strong="H5771"\w*.
\p 
\v 7 ¿Descubrirás tú las profundidades \w de|strong="H5704"\w* \nd ʼElohim\nd*? ¿Puedes \w hallar|strong="H4672"\w* los límites \w de|strong="H5704"\w* \nd ʼEL-Shadday\nd*?
\v 8 Es más alto \w que|strong="H4100"\w* los \w cielos|strong="H8064"\w*, ¿\w qué|strong="H4100"\w* puedes tú hacer? Es más \w profundo|strong="H6013"\w* \w que|strong="H4100"\w* el \tl Seol\tl*, ¿\w qué|strong="H4100"\w* puedes tú \w saber|strong="H3045"\w*?
\v 9 Su dimensión es \w más|strong="H4480"\w* extensa \w que|strong="H4480"\w* la tierra y \w más|strong="H4480"\w* ancha \w que|strong="H4480"\w* el \w mar|strong="H3220"\w*.
\p 
\v 10 Si \w Él|strong="H4310"\w* pasa y aprisiona, \w o|strong="H3068"\w* convoca una asamblea, ¿\w quién|strong="H4310"\w* lo puede restringir?
\v 11 \w Porque|strong="H3588"\w* \w Él|strong="H1931"\w* \w conoce|strong="H3045"\w* \w a|strong="H3068"\w* \w los|strong="H1931"\w* \w hombres|strong="H4962"\w* \w vanos|strong="H7723"\w*. \w Ve|strong="H7200"\w* también \w su|strong="H1931"\w* perversidad, ¿\w y|strong="H3588"\w* \w no|strong="H3808"\w* \w la|strong="H1931"\w* considerará?
\v 12 El hombre \w vano|strong="H5014"\w* será entendido cuando un pollino de asno \w montés|strong="H6501"\w* nazca hombre.
\p 
\v 13 Si tú dispones tu \w corazón|strong="H3820"\w* y extiendes \w a|strong="H3068"\w* Él tus \w manos|strong="H3709"\w*,
\v 14 si hay \w iniquidad|strong="H5766"\w* en tus \w manos|strong="H3027"\w*, la alejas de ti y \w no|strong="H5766"\w* permites \w que|strong="H3027"\w* la perversidad more en tus tiendas,
\v 15 \w entonces|strong="H3588"\w* levantarías tu semblante libre \w de|strong="H3588"\w* \w mancha|strong="H3971"\w*, estarías firme \w y|strong="H3588"\w* \w nada|strong="H3808"\w* temerías,
\v 16 olvidarías tu aflicción \w y|strong="H3588"\w* \w la|strong="H3588"\w* recordarías \w como|strong="H3588"\w* \w aguas|strong="H4325"\w* \w que|strong="H3588"\w* \w pasaron|strong="H5674"\w*.
\v 17 Tu existencia \w sería|strong="H1961"\w* más resplandeciente \w que|strong="H1961"\w* el mediodía. Aunque \w haya|strong="H1961"\w* oscuridad, \w sería|strong="H1961"\w* \w como|strong="H1961"\w* la alborada.
\v 18 Estarías confiado, \w porque|strong="H3588"\w* habría \w esperanza|strong="H8615"\w*. Mirarías alrededor \w y|strong="H3588"\w* descansarías seguro,
\v 19 reposarías, sin que alguno te espante. \w Y|strong="H3068"\w* \w muchos|strong="H7227"\w* implorarían tu favor.
\v 20 Pero los \w ojos|strong="H5869"\w* \w de|strong="H4480"\w* los perversos fallarán, y \w no|strong="H7563"\w* habrá escape \w para|strong="H4480"\w* \w ellos|strong="H4480"\w*. Su \w esperanza|strong="H8615"\w* será el último suspiro.
\c 12
\s1 Respuesta de Job a Sofar naamatita
\p 
\v 1 Job \w respondió|strong="H6030"\w*:
\v 2 \w Entonces|strong="H3588"\w* \w ciertamente|strong="H3588"\w* ustedes \w son|strong="H3588"\w* \w el|strong="H5973"\w* \w pueblo|strong="H5971"\w*, \w y|strong="H3588"\w* \w con|strong="H5973"\w* ustedes \w se|strong="H5971"\w* acaba \w la|strong="H3588"\w* \w sabiduría|strong="H2451"\w*.
\v 3 Pero \w yo|strong="H4480"\w* tengo entendimiento \w como|strong="H1571"\w* ustedes. \w No|strong="H3808"\w* soy \w menos|strong="H5307"\w* \w que|strong="H4480"\w* ustedes. ¿\w Quién|strong="H4310"\w* \w no|strong="H3808"\w* sabe tales cosas?
\p 
\v 4 Yo \w soy|strong="H1961"\w* alguien \w que|strong="H1961"\w* \w para|strong="H1961"\w* su \w amigo|strong="H7453"\w* \w es|strong="H1961"\w* motivo \w de|strong="H6662"\w* risa, uno \w que|strong="H1961"\w* \w clamó|strong="H7121"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd* y le \w respondió|strong="H6030"\w*. ¡El \w justo|strong="H6662"\w* \w e|strong="H3068"\w* intachable \w es|strong="H1961"\w* un payaso!
\v 5 El que tiene bienestar desprecia la calamidad \w como|strong="H7272"\w* algo preparado para aquellos que resbalan.
\v 6 \w Prosperan|strong="H7951"\w* las tiendas de los ladrones y los \w que|strong="H3027"\w* provocan \w a|strong="H3068"\w* \nd ʼEL\nd*\f + \fr 12:6 \ft \nd ʼEL \nd*y \nd ʼEloah\nd* son Nombres de \nd ʼElohim\nd*.\f* están seguros, aquellos \w que|strong="H3027"\w* \nd ʼEloah\nd* trae \w a|strong="H3068"\w* su \w poder|strong="H3027"\w*.
\p 
\v 7 En efecto, \w pregunta|strong="H7592"\w* \w ahora|strong="H4994"\w* \w a|strong="H3068"\w* las bestias, y ellas te enseñarán, \w a|strong="H3068"\w* las \w aves|strong="H5775"\w* del \w cielo|strong="H8064"\w*, y ellas te lo dirán.
\v 8 \w O|strong="H3068"\w* \w habla|strong="H7878"\w* \w a|strong="H3068"\w* la tierra, y \w te|strong="H3220"\w* \w enseñará|strong="H3384"\w*. Los peces del \w mar|strong="H3220"\w* también \w te|strong="H3220"\w* lo \w declararán|strong="H5608"\w*.
\v 9 ¿\w Cuál|strong="H4310"\w* \w de|strong="H3588"\w* \w ellos|strong="H3027"\w* \w no|strong="H3808"\w* \w sabe|strong="H3045"\w* \w que|strong="H3588"\w* \w la|strong="H3605"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w hizo|strong="H6213"\w* \w esto|strong="H2063"\w*,
\v 10 \w que|strong="H3605"\w* en su \w mano|strong="H3027"\w* está \w la|strong="H3605"\w* \w vida|strong="H5315"\w* de \w todo|strong="H3605"\w* \w viviente|strong="H2416"\w* y \w el|strong="H3605"\w* \w hálito|strong="H7307"\w* de \w toda|strong="H3605"\w* \w la|strong="H3605"\w* humanidad?
\v 11 ¿\w No|strong="H3808"\w* distingue el oído las \w palabras|strong="H4405"\w* y el paladar prueba la comida?
\v 12 En los ancianos está \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* y en \w la|strong="H2451"\w* larga \w edad|strong="H3117"\w* el \w entendimiento|strong="H8394"\w*.
\p 
\v 13 \w Con|strong="H5973"\w* \w Él|strong="H5973"\w* están \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* y \w el|strong="H5973"\w* poder. Suyos son \w el|strong="H5973"\w* \w consejo|strong="H6098"\w* y \w el|strong="H5973"\w* \w entendimiento|strong="H8394"\w*.
\v 14 \w Si|strong="H2005"\w* \w Él|strong="H5921"\w* derriba, \w no|strong="H3808"\w* \w será|strong="H3808"\w* reedificado. \w Si|strong="H2005"\w* \w Él|strong="H5921"\w* encierra \w al|strong="H5921"\w* hombre, \w no|strong="H3808"\w* hay liberación.
\v 15 \w Si|strong="H2005"\w* Él retiene las \w aguas|strong="H4325"\w*, se secan, y \w si|strong="H2005"\w* las suelta, inundan la tierra.
\p 
\v 16 \w Con|strong="H5973"\w* \w Él|strong="H5973"\w* están la \w fortaleza|strong="H5797"\w* \w y|strong="H5797"\w* la sana \w sabiduría|strong="H8454"\w*. Suyos son \w el|strong="H5973"\w* que yerra \w y|strong="H5797"\w* \w el|strong="H5973"\w* que hace errar.
\p 
\v 17 Hace \w andar|strong="H3212"\w* descalzos \w a|strong="H3068"\w* los \w consejeros|strong="H3289"\w* y entontece \w a|strong="H3068"\w* los \w jueces|strong="H8199"\w*.
\v 18 Suelta las ataduras que imponen los \w reyes|strong="H4428"\w* y ata con una cuerda sus cinturas.
\v 19 Hace \w ir|strong="H3212"\w* descalzos \w a|strong="H3068"\w* los \w sacerdotes|strong="H3548"\w* y derriba \w a|strong="H3068"\w* los poderosos.
\v 20 Priva del \w habla|strong="H8193"\w* \w a|strong="H3068"\w* los de confianza, y del discernimiento \w a|strong="H3068"\w* los \w ancianos|strong="H2205"\w*.
\v 21 \w Derrama|strong="H8210"\w* desprecio \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* nobles \w y|strong="H5921"\w* afloja \w el|strong="H5921"\w* cinturón \w de|strong="H5921"\w* \w los|strong="H5921"\w* fuertes.
\v 22 \w Descubre|strong="H1540"\w* las profundidades \w de|strong="H4480"\w* la \w oscuridad|strong="H2822"\w* y \w saca|strong="H3318"\w* \w a|strong="H3068"\w* la \w luz|strong="H6757"\w* la sombra \w de|strong="H4480"\w* \w muerte|strong="H6757"\w*.
\v 23 Engrandece las \w naciones|strong="H1471"\w* y las destruye. Ensancha los \w pueblos|strong="H1471"\w* y los suprime.
\v 24 Priva \w de|strong="H5971"\w* discreción \w a|strong="H3068"\w* los caudillos \w de|strong="H5971"\w* los \w pueblos|strong="H5971"\w* \w de|strong="H5971"\w* la tierra y los hace deambular \w por|strong="H1870"\w* un desierto \w sin|strong="H3808"\w* \w camino|strong="H1870"\w*.
\v 25 \w No|strong="H3808"\w* tienen luz. Palpan en la \w oscuridad|strong="H2822"\w*, y los hace tambalearse como ebrios.
\c 13
\s1 Defensa de su integridad por parte de Job
\p 
\v 1 \w Ciertamente|strong="H2005"\w* mis \w ojos|strong="H5869"\w* \w vieron|strong="H7200"\w* \w todo|strong="H3605"\w* esto. Mis \w oídos|strong="H8085"\w* \w lo|strong="H3605"\w* \w escucharon|strong="H8085"\w* y entendieron.
\v 2 \w Como|strong="H1571"\w* ustedes \w lo|strong="H3808"\w* \w saben|strong="H3045"\w*, \w yo|strong="H4480"\w* \w también|strong="H1571"\w* \w lo|strong="H3808"\w* \w sé|strong="H3045"\w*. \w En|strong="H4480"\w* \w nada|strong="H3808"\w* soy \w menos|strong="H5307"\w* \w que|strong="H4480"\w* ustedes.
\p 
\v 3 Pero en verdad yo me dirijo \w a|strong="H3068"\w* \nd ʼEL-Shadday\nd*, \w porque|strong="H3198"\w* \w quiero|strong="H2654"\w* disputar con \nd ʼElohim\nd*.
\v 4 Ustedes son forjadores de \w mentiras|strong="H8267"\w*. \w Médicos|strong="H7495"\w* inútiles son \w todos|strong="H3605"\w* ustedes.
\v 5 ¡\w Ojalá|strong="H4310"\w* callaran \w por|strong="H5414"\w* completo! Esto \w sería|strong="H1961"\w* \w sabiduría|strong="H2451"\w*.
\v 6 \w Escuchen|strong="H8085"\w* \w mi|strong="H4994"\w* argumento y atiendan las contenciones de mis \w labios|strong="H8193"\w*.
\p 
\v 7 ¿Dirán ustedes perversidades \w a|strong="H3068"\w* favor de \nd ʼElohim\nd*? ¿\w Hablarán|strong="H1696"\w* \w engaño|strong="H7423"\w* \w a|strong="H3068"\w* favor de Él?
\v 8 ¿Mostrarán parcialidad \w a|strong="H3068"\w* su favor? ¿Contenderán ustedes \w a|strong="H3068"\w* favor \w de|strong="H6440"\w* \nd ʼElohim\nd*?
\v 9 ¿Les irá \w bien|strong="H2896"\w* \w cuando|strong="H3588"\w* \w Él|strong="H3588"\w* \w los|strong="H3588"\w* escudriñe? ¿Se burlarán \w de|strong="H3588"\w* \w Él|strong="H3588"\w* \w como|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* se burla \w de|strong="H3588"\w* un hombre?
\v 10 Ciertamente los \w reprenderá|strong="H3198"\w*, \w si|strong="H6440"\w* en secreto son parciales.
\p 
\v 11 ¿\w No|strong="H3808"\w* \w los|strong="H5921"\w* aterrorizará su majestad, \w y|strong="H5921"\w* \w caerá|strong="H5307"\w* su \w terror|strong="H6343"\w* \w sobre|strong="H5921"\w* ustedes?
\v 12 Sus dichos memorables serán proverbios de polvo, y sus defensas serán de \w barro|strong="H2563"\w*.
\p 
\v 13 Callen \w y|strong="H5921"\w* \w hablaré|strong="H1696"\w* \w yo|strong="H4480"\w*. ¡\w Y|strong="H3068"\w* \w que|strong="H4100"\w* \w me|strong="H4480"\w* venga \w lo|strong="H4100"\w* \w que|strong="H4100"\w* venga!
\v 14 ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* debo tomar \w mi|strong="H5921"\w* \w carne|strong="H1320"\w* \w entre|strong="H5921"\w* \w mis|strong="H5375"\w* \w dientes|strong="H8127"\w*, \w y|strong="H5921"\w* colocar \w mi|strong="H5921"\w* \w vida|strong="H5315"\w* \w en|strong="H5921"\w* \w mis|strong="H5375"\w* \w manos|strong="H3709"\w*?
\v 15 \w Ciertamente|strong="H2005"\w* \w aunque|strong="H3808"\w* me mate, en Él \w esperaré|strong="H3176"\w*, pero defenderé mis \w caminos|strong="H1870"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Él.
\v 16 \w Esto|strong="H1931"\w* \w también|strong="H1571"\w* \w será|strong="H1931"\w* mi salvación, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* llegará \w ante|strong="H6440"\w* \w su|strong="H1931"\w* \w presencia|strong="H6440"\w* \w el|strong="H1931"\w* impío.
\p 
\v 17 \w Escuchen|strong="H8085"\w* con atención \w lo|strong="H4405"\w* que digo. Mi declaración entre en sus \w oídos|strong="H8085"\w*:
\v 18 \w Ciertamente|strong="H3588"\w* preparé \w mi|strong="H2009"\w* defensa. \w Sé|strong="H3045"\w* \w que|strong="H3588"\w* seré declarado justo.
\v 19 ¿Quiere alguno \w contender|strong="H7378"\w* \w conmigo|strong="H5978"\w*? \w Porque|strong="H3588"\w* \w si|strong="H3588"\w* \w ahora|strong="H6258"\w* \w callo|strong="H2790"\w*, moriría.
\p 
\v 20 Solo \w dos|strong="H8147"\w* \w cosas|strong="H8147"\w* \w no|strong="H3808"\w* \w hagas|strong="H6213"\w* \w conmigo|strong="H6213"\w*, y \w no|strong="H3808"\w* me \w esconderé|strong="H5641"\w* \w de|strong="H6440"\w* \w tu|strong="H6213"\w* \w Presencia|strong="H6440"\w*:
\v 21 \w Aparta|strong="H7368"\w* \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w* tu \w mano|strong="H3709"\w*, \w y|strong="H5921"\w* \w no|strong="H5921"\w* \w me|strong="H5921"\w* espante tu terror.
\v 22 \w Llama|strong="H7121"\w* \w luego|strong="H7725"\w* y yo \w responderé|strong="H6030"\w*, \w o|strong="H3068"\w* yo \w hablaré|strong="H1696"\w* y Tú me \w responderás|strong="H6030"\w*.
\p 
\v 23 ¿\w Cuántas|strong="H4100"\w* son mis \w iniquidades|strong="H5771"\w* y \w pecados|strong="H2403"\w*? Hazme \w saber|strong="H3045"\w* mi transgresión y mi \w pecado|strong="H2403"\w*.
\v 24 ¿\w Por|strong="H6440"\w* \w qué|strong="H4100"\w* ocultas tu \w rostro|strong="H6440"\w* y me consideras tu enemigo?
\v 25 ¿Quebrantas una hoja volandera, y \w persigues|strong="H7291"\w* un pasto \w seco|strong="H3002"\w*?
\v 26 Escribes \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* cosas amargas \w y|strong="H3588"\w* \w me|strong="H5921"\w* haces heredar \w las|strong="H5921"\w* \w iniquidades|strong="H5771"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w juventud|strong="H5271"\w*.
\v 27 Colocas mis \w pies|strong="H7272"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* cepo. Vigilas \w todos|strong="H3605"\w* mis caminos. Trazas un límite \w para|strong="H5921"\w* \w las|strong="H5921"\w* plantas \w de|strong="H5921"\w* mis \w pies|strong="H7272"\w*.
\p 
\v 28 Mi cuerpo \w se|strong="H1931"\w* desgasta \w como|strong="H1931"\w* cosa podrida, \w como|strong="H1931"\w* ropa vieja comida de \w polilla|strong="H6211"\w*.
\c 14
\s1 La brevedad de la vida
\p 
\v 1 El hombre \w nacido|strong="H3205"\w* \w de|strong="H7646"\w* mujer es \w corto|strong="H7116"\w* \w de|strong="H7646"\w* \w días|strong="H3117"\w* y lleno \w de|strong="H7646"\w* perturbaciones.
\v 2 Brota como una flor, pero \w es|strong="H5975"\w* cortado. Pasa como una \w sombra|strong="H6738"\w* y desaparece.
\v 3 ¿\w Y|strong="H3068"\w* \w sobre|strong="H5921"\w* \w éste|strong="H2088"\w* \w abres|strong="H6491"\w* tus \w ojos|strong="H5869"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* llevas \w a|strong="H3068"\w* \w juicio|strong="H4941"\w* \w contigo|strong="H5973"\w*?
\v 4 ¿\w Quién|strong="H4310"\w* limpiará \w lo|strong="H3808"\w* impuro? ¡\w Nadie|strong="H3808"\w*!
\v 5 Ciertamente sus \w días|strong="H3117"\w* están determinados, y \w el|strong="H6213"\w* \w número|strong="H4557"\w* de sus \w meses|strong="H2320"\w* depende de Ti. \w Tú|strong="H6213"\w* le fijaste sus límites, de los cuales \w no|strong="H3808"\w* \w pasará|strong="H5674"\w*.
\v 6 Aparta \w de|strong="H5921"\w* \w él|strong="H5921"\w* tu mirada \w y|strong="H5921"\w* \w que|strong="H5921"\w* descanse \w hasta|strong="H5704"\w* \w que|strong="H5921"\w* complete su \w día|strong="H3117"\w* \w como|strong="H5921"\w* un jornalero.
\p 
\v 7 \w Porque|strong="H3588"\w* \w para|strong="H3588"\w* \w el|strong="H3588"\w* \w árbol|strong="H6086"\w* \w hay|strong="H3426"\w* \w esperanza|strong="H8615"\w*: \w Si|strong="H3588"\w* \w es|strong="H3588"\w* \w cortado|strong="H3772"\w*, retoñará, \w y|strong="H3588"\w* sus ramas \w no|strong="H3808"\w* \w cesarán|strong="H2308"\w*.
\v 8 Aunque debajo de la \w tierra|strong="H6083"\w* esté \w muerto|strong="H4191"\w* su tronco, y en la \w tierra|strong="H6083"\w* envejezca su raíz,
\v 9 al recibir \w el|strong="H6213"\w* \w agua|strong="H4325"\w* \w reverdecerá|strong="H6524"\w*, y echará \w ramas|strong="H7105"\w* \w como|strong="H3644"\w* una \w planta|strong="H7105"\w*.
\v 10 Pero el \w hombre|strong="H1397"\w* muere, y queda tendido. Expira el \w hombre|strong="H1397"\w*, ¿y dónde está?
\v 11 Como las \w aguas|strong="H4325"\w* \w se|strong="H4480"\w* van \w al|strong="H4480"\w* \w mar|strong="H3220"\w*, y un \w río|strong="H5104"\w* \w se|strong="H4480"\w* agota y \w se|strong="H4480"\w* \w seca|strong="H3001"\w*,
\v 12 así el hombre queda tendido \w y|strong="H5704"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w levantará|strong="H6965"\w*. \w Hasta|strong="H5704"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* haya \w cielo|strong="H8064"\w*, \w no|strong="H3808"\w* \w será|strong="H3808"\w* despertado, \w ni|strong="H3808"\w* \w lo|strong="H3808"\w* levantarán \w de|strong="H5704"\w* su \w sueño|strong="H8142"\w*.
\p 
\v 13 ¡\w Ojalá|strong="H4310"\w* \w me|strong="H4310"\w* \w escondas|strong="H5641"\w* \w en|strong="H5704"\w* \w el|strong="H4310"\w* \tl Seol\tl* \w mientras|strong="H5704"\w* se aplaca tu ira, \w y|strong="H5704"\w* \w me|strong="H4310"\w* fijes un \w plazo|strong="H2706"\w* \w y|strong="H5704"\w* te acuerdes \w de|strong="H5704"\w* mí!
\v 14 Si \w el|strong="H3605"\w* \w hombre|strong="H1397"\w* muere, ¿volverá \w a|strong="H3068"\w* \w vivir|strong="H2421"\w*? \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w de|strong="H5704"\w* mi lucha \w y|strong="H5704"\w* servicio \w esperaré|strong="H3176"\w* \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* llegue mi liberación.
\v 15 Entonces \w llamarás|strong="H7121"\w* y yo te \w responderé|strong="H6030"\w*. Tendrás afecto \w a|strong="H3068"\w* la hechura de tus \w manos|strong="H3027"\w*.
\v 16 \w Porque|strong="H3588"\w* \w ahora|strong="H6258"\w* \w me|strong="H5921"\w* cuentas \w los|strong="H5921"\w* \w pasos|strong="H6806"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* das tregua \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w pecado|strong="H2403"\w*.
\v 17 Tienes \w mi|strong="H5921"\w* transgresión \w sellada|strong="H2856"\w* \w en|strong="H5921"\w* un saco. Tú cubres \w mi|strong="H5921"\w* \w iniquidad|strong="H5771"\w*.
\p 
\v 18 Pero la montaña \w cae|strong="H5307"\w* y se desmorona. Las rocas cambian de \w lugar|strong="H4725"\w*.
\v 19 Las piedras se desgastan con el \w agua|strong="H4325"\w* \w impetuosa|strong="H7857"\w* \w que|strong="H4325"\w* se lleva el \w polvo|strong="H6083"\w* \w de|strong="H4325"\w* la \w tierra|strong="H6083"\w*. Así destruyes la \w esperanza|strong="H8615"\w* del hombre.
\v 20 Prevaleces para \w siempre|strong="H1980"\w* \w contra|strong="H6440"\w* él, y él se \w va|strong="H3068"\w*. Desfiguras su \w rostro|strong="H6440"\w* y lo despides.
\v 21 Sus \w hijos|strong="H1121"\w* obtendrán honores, pero \w él|strong="H1121"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w sabrá|strong="H3045"\w*. \w Si|strong="H3808"\w* \w son|strong="H3808"\w* humillados, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* percibirá.
\v 22 Pero su \w carne|strong="H1320"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* siente \w el|strong="H5921"\w* tormento, \w y|strong="H5921"\w* su \w alma|strong="H5315"\w* gime \w por|strong="H5921"\w* \w él|strong="H5921"\w*.
\c 15
\s1 Segunda intervención de Elifaz temanita
\p 
\v 1 Elifaz \w temanita|strong="H8489"\w* \w respondió|strong="H6030"\w*:
\v 2 ¿\w Responderá|strong="H6030"\w* el \w sabio|strong="H2450"\w* con \w conocimiento|strong="H1847"\w* vano? ¿\w Llenará|strong="H4390"\w* su vientre de \w viento|strong="H7307"\w* del este?
\v 3 ¿\w Argüirá|strong="H3198"\w* con \w palabras|strong="H1697"\w* \w inútiles|strong="H3808"\w* \w o|strong="H3068"\w* con \w palabras|strong="H1697"\w* \w sin|strong="H3808"\w* \w provecho|strong="H3276"\w*?
\v 4 Tú anulas la reverencia y menosprecias la oración \w ante|strong="H6440"\w* \nd ʼElohim\nd*,
\v 5 \w porque|strong="H3588"\w* tu \w iniquidad|strong="H5771"\w* enseña tu \w boca|strong="H6310"\w*, \w y|strong="H3588"\w* adoptas \w la|strong="H3588"\w* \w lengua|strong="H3956"\w* del astuto.
\v 6 Tu \w boca|strong="H6310"\w* te condena, y \w no|strong="H3808"\w* yo. Tus \w labios|strong="H8193"\w* \w testifican|strong="H6030"\w* contra ti.
\p 
\v 7 ¿Eres tú el \w primer|strong="H7223"\w* hombre que \w nació|strong="H3205"\w*? ¿Fuiste engendrado \w antes|strong="H6440"\w* que las montañas?
\v 8 ¿Escuchaste el secreto de \nd ʼElohim\nd* para que tú solo te apropies de \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*?
\v 9 ¿\w Qué|strong="H4100"\w* \w sabes|strong="H3045"\w* \w que|strong="H4100"\w* \w nosotros|strong="H5973"\w* \w no|strong="H3808"\w* \w sepamos|strong="H3045"\w*? ¿\w Qué|strong="H4100"\w* entiendes \w que|strong="H4100"\w* \w nosotros|strong="H5973"\w* \w no|strong="H3808"\w* entendamos?
\v 10 Cabezas canas \w y|strong="H1571"\w* hombres muy ancianos, de \w más|strong="H1571"\w* larga \w edad|strong="H3117"\w* \w que|strong="H1571"\w* tu padre, hay entre nosotros.
\p 
\v 11 ¿\w En|strong="H4480"\w* tan \w poco|strong="H4592"\w* \w tienes|strong="H4480"\w* \w el|strong="H5973"\w* consuelo \w de|strong="H4480"\w* \nd ʼElohim\nd* y la \w palabra|strong="H1697"\w* \w que|strong="H4480"\w* \w se|strong="H4480"\w* \w te|strong="H4480"\w* \w dice|strong="H1697"\w* \w con|strong="H5973"\w* dulzura?
\v 12 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* tu \w corazón|strong="H3820"\w* \w te|strong="H5869"\w* arrastra y \w por|strong="H4100"\w* \w qué|strong="H4100"\w* \w guiñan|strong="H7335"\w* tus \w ojos|strong="H5869"\w*?
\v 13 ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* \w vuelves|strong="H7725"\w* tu \w espíritu|strong="H7307"\w* contra \nd ʼElohim\nd*, \w y|strong="H3588"\w* dejas \w salir|strong="H3318"\w* esas \w palabras|strong="H4405"\w* \w de|strong="H3588"\w* tu \w boca|strong="H6310"\w*?
\v 14 ¿\w Qué|strong="H3588"\w* \w es|strong="H3588"\w* \w el|strong="H3588"\w* hombre \w para|strong="H3588"\w* \w que|strong="H3588"\w* sea considerado puro, \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w nacido|strong="H3205"\w* \w de|strong="H3588"\w* mujer \w para|strong="H3588"\w* \w que|strong="H3588"\w* sea considerado justo?
\p 
\v 15 \w Mira|strong="H2005"\w*, en sus \w santos|strong="H6918"\w* \w no|strong="H3808"\w* confía. Ante sus \w ojos|strong="H5869"\w* \w ni|strong="H3808"\w* \w aun|strong="H3808"\w* el \w cielo|strong="H8064"\w* es puro.
\v 16 ¡\w Cuánto|strong="H3588"\w* \w menos|strong="H3588"\w* \w el|strong="H3588"\w* hombre repugnante \w y|strong="H3588"\w* corrupto \w que|strong="H3588"\w* \w bebe|strong="H8354"\w* \w la|strong="H3588"\w* \w iniquidad|strong="H5766"\w* \w como|strong="H3588"\w* \w agua|strong="H4325"\w*!
\p 
\v 17 \w Escúchame|strong="H8085"\w*, yo te informaré. \w Óyeme|strong="H8085"\w* y \w lo|strong="H2088"\w* \w que|strong="H2088"\w* vi te \w contaré|strong="H5608"\w*
\v 18 \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w los|strong="H2450"\w* \w sabios|strong="H2450"\w* informaron, \w sin|strong="H3808"\w* ocultar \w lo|strong="H3808"\w* de sus antepasados.
\v 19 Solo \w a|strong="H3068"\w* ellos \w fue|strong="H3808"\w* \w dada|strong="H5414"\w* la tierra, y \w ningún|strong="H3808"\w* \w extraño|strong="H2114"\w* \w pasó|strong="H5674"\w* \w entre|strong="H8432"\w* ellos.
\p 
\v 20 \w Todos|strong="H3605"\w* \w sus|strong="H1931"\w* \w días|strong="H3117"\w* sufre tormento \w el|strong="H1931"\w* perverso, y \w contados|strong="H4557"\w* \w años|strong="H8141"\w* \w le|strong="H1931"\w* están reservados al tirano.
\v 21 \w Voces|strong="H6963"\w* espantosas resuenan en sus oídos. El destructor vendrá sobre él en la \w paz|strong="H7965"\w*.
\v 22 \w No|strong="H3808"\w* cree \w que|strong="H4480"\w* \w volverá|strong="H7725"\w* \w de|strong="H4480"\w* \w la|strong="H1931"\w* \w oscuridad|strong="H2822"\w*. \w Está|strong="H1931"\w* destinado \w para|strong="H4480"\w* \w la|strong="H1931"\w* \w espada|strong="H2719"\w*.
\v 23 Vaga \w en|strong="H3588"\w* busca del \w pan|strong="H3899"\w* \w y|strong="H3588"\w* dice: ¿\w Dónde|strong="H1931"\w* \w está|strong="H1931"\w*? \w Sabe|strong="H3045"\w* \w que|strong="H3588"\w* \w el|strong="H1931"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w la|strong="H1931"\w* \w oscuridad|strong="H2822"\w* \w está|strong="H1931"\w* cerca.
\v 24 La tristeza y la \w aflicción|strong="H6862"\w* lo turban, como un \w rey|strong="H4428"\w* listo para la batalla,
\v 25 \w porque|strong="H3588"\w* \w extendió|strong="H5186"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w* contra \nd \w ʼEL|strong="H3588"\w*\nd*. Se portó \w con|strong="H3588"\w* soberbia contra \nd ʼEL-Shadday\nd*.
\p 
\v 26 Indómito embistió contra Él con la espesa barrera de su \w escudo|strong="H4043"\w*,
\v 27 \w con|strong="H5921"\w* \w su|strong="H3588"\w* \w cara|strong="H6440"\w* cubierta, \w con|strong="H5921"\w* \w los|strong="H5921"\w* \w pliegues|strong="H6371"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* cintura aumentados \w de|strong="H5921"\w* grasa.
\v 28 Vivirá en \w ciudades|strong="H5892"\w* destruidas, en \w casas|strong="H1004"\w* \w no|strong="H3808"\w* \w habitadas|strong="H3427"\w*, destinadas \w a|strong="H3068"\w* ser ruinas.
\v 29 \w No|strong="H3808"\w* \w enriquecerá|strong="H6238"\w*, \w ni|strong="H3808"\w* \w durará|strong="H6965"\w* su hacienda, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* extenderán sus posesiones en la tierra.
\v 30 \w No|strong="H3808"\w* \w escapará|strong="H3808"\w* \w de|strong="H4480"\w* la \w oscuridad|strong="H2822"\w*. La llama consumirá sus ramas. \w Por|strong="H4480"\w* el aliento \w de|strong="H4480"\w* su \w boca|strong="H6310"\w* \w perecerá|strong="H3808"\w*.
\p 
\v 31 \w No|strong="H3588"\w* confíe \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w vanidad|strong="H7723"\w*, ni \w se|strong="H1961"\w* engañe \w a|strong="H3068"\w* \w sí|strong="H3588"\w* mismo, \w porque|strong="H3588"\w* \w la|strong="H3588"\w* \w vanidad|strong="H7723"\w* \w será|strong="H1961"\w* \w su|strong="H3588"\w* recompensa.
\v 32 \w Se|strong="H3808"\w* marchitará antes de su \w tiempo|strong="H3117"\w*, y sus ramas \w no|strong="H3808"\w* \w reverdecerán|strong="H7488"\w*.
\v 33 Será \w vid|strong="H1612"\w* que dejará caer sus uvas no maduras, olivo que \w echa|strong="H7993"\w* de él sus flores.
\p 
\v 34 \w La|strong="H3588"\w* compañía del impío \w es|strong="H3588"\w* estéril, \w y|strong="H3588"\w* \w el|strong="H3588"\w* fuego consume las tiendas del corrupto.
\v 35 \w Conciben|strong="H2029"\w* travesura, dan \w a|strong="H3068"\w* luz iniquidad y su mente \w prepara|strong="H3559"\w* el \w engaño|strong="H4820"\w*.
\c 16
\s1 Respuesta de Job a Elifaz y sus amigos
\p 
\v 1 Entonces Job \w respondió|strong="H6030"\w*:
\v 2 \w Oí|strong="H8085"\w* \w muchas|strong="H7227"\w* \w cosas|strong="H7227"\w* como éstas. \w Consoladores|strong="H5162"\w* \w molestos|strong="H5999"\w* son \w todos|strong="H3605"\w* ustedes.
\v 3 ¿Habrá \w fin|strong="H7093"\w* \w para|strong="H3588"\w* las \w palabras|strong="H1697"\w* vanas? ¿\w Qué|strong="H3588"\w* \w te|strong="H3588"\w* incita \w a|strong="H3068"\w* \w responder|strong="H6030"\w*?
\p 
\v 4 \w Yo|strong="H5315"\w* \w también|strong="H1571"\w* podría \w hablar|strong="H1696"\w* \w como|strong="H1571"\w* ustedes. \w Si|strong="H3863"\w* su \w alma|strong="H5315"\w* \w estuviera|strong="H3426"\w* \w en|strong="H5921"\w* \w lugar|strong="H8478"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* mía, podría hilvanar vocablos \w contra|strong="H5921"\w* ustedes \w y|strong="H1571"\w* menear \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w contra|strong="H5921"\w* ustedes.
\v 5 Pero los alentaría con mis \w palabras|strong="H6310"\w*, y la consolación de mis \w labios|strong="H8193"\w* calmaría su dolor.
\p 
\v 6 \w Si|strong="H3808"\w* \w hablo|strong="H1696"\w*, \w no|strong="H3808"\w* \w cesa|strong="H2308"\w* mi dolor. \w Si|strong="H3808"\w* \w me|strong="H4480"\w* abstengo, ¿\w se|strong="H3808"\w* aleja \w de|strong="H4480"\w* mí?
\v 7 \w Ahora|strong="H6258"\w* me agotó. Desoló \w a|strong="H3068"\w* \w toda|strong="H3605"\w* mi compañía.
\v 8 Colocaste una mano \w firme|strong="H6965"\w* \w contra|strong="H6440"\w* \w mí|strong="H1961"\w* y me llenaste \w de|strong="H6440"\w* arrugas, lo cual \w es|strong="H1961"\w* un \w testigo|strong="H5707"\w* \w contra|strong="H6440"\w* \w mí|strong="H1961"\w*. \w Mi|strong="H1961"\w* flacura \w es|strong="H1961"\w* una evidencia adicional \w que|strong="H1961"\w* testifica en \w mi|strong="H1961"\w* \w cara|strong="H6440"\w*.
\v 9 \w Mi|strong="H5921"\w* adversario lanzó su mirada \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*. \w Me|strong="H5921"\w* odió, \w me|strong="H5921"\w* persiguió, su furor \w me|strong="H5921"\w* destrozó, \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* cruje sus \w dientes|strong="H8127"\w*, fija sus \w ojos|strong="H5869"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*,
\v 10 abren sus \w bocas|strong="H6310"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*, hieren mis mejillas \w con|strong="H5921"\w* \w afrenta|strong="H2781"\w*, \w se|strong="H5921"\w* unieron \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*.
\p 
\v 11 \nd ʼElohim\nd* \w me|strong="H5921"\w* \w entregó|strong="H5462"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* perversos \w y|strong="H5921"\w* \w me|strong="H5921"\w* empujó \w hacia|strong="H5921"\w* \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w impíos|strong="H7563"\w*.
\v 12 Yo \w estaba|strong="H1961"\w* tranquilo, pero Él me quebrantó. Me agarró por el cuello, me destrozó y me colocó \w como|strong="H1961"\w* blanco de sus flechas.
\v 13 Sus arqueros \w me|strong="H5921"\w* rodearon, atraviesan mis \w riñones|strong="H3629"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* perdonan. Derraman \w mi|strong="H5921"\w* hiel \w a|strong="H3068"\w* tierra,
\v 14 abren brecha tras brecha \w en|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* arremeten \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w como|strong="H5921"\w* un guerrero.
\p 
\v 15 Cosí tela áspera \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* piel \w y|strong="H5921"\w* coloqué \w mi|strong="H5921"\w* cabeza \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w*.
\v 16 \w Mi|strong="H5921"\w* \w cara|strong="H6440"\w* \w está|strong="H5921"\w* enrojecida \w de|strong="H4480"\w* \w tanto|strong="H5921"\w* llorar. \w Sobre|strong="H5921"\w* mis \w párpados|strong="H6079"\w* \w se|strong="H4480"\w* afirma \w la|strong="H5921"\w* sombra \w de|strong="H4480"\w* \w la|strong="H5921"\w* \w muerte|strong="H6757"\w*,
\v 17 \w aunque|strong="H3808"\w* \w no|strong="H3808"\w* hubo \w violencia|strong="H2555"\w* \w en|strong="H5921"\w* mis \w manos|strong="H3709"\w*, \w y|strong="H5921"\w* \w fue|strong="H3808"\w* \w pura|strong="H2134"\w* \w mi|strong="H5921"\w* \w oración|strong="H8605"\w*.
\p 
\v 18 ¡Oh tierra, \w no|strong="H1961"\w* encubras \w mi|strong="H1961"\w* \w sangre|strong="H1818"\w*, ni \w haya|strong="H1961"\w* \w lugar|strong="H4725"\w* \w de|strong="H1818"\w* reposo \w para|strong="H1961"\w* \w mi|strong="H1961"\w* \w clamor|strong="H2201"\w*!
\v 19 \w Ciertamente|strong="H1571"\w* \w ahora|strong="H6258"\w* \w mi|strong="H2009"\w* \w testigo|strong="H5707"\w* está en \w el|strong="H1571"\w* \w cielo|strong="H8064"\w*, en las \w alturas|strong="H4791"\w*, \w el|strong="H1571"\w* \w que|strong="H6258"\w* atestigua \w a|strong="H3068"\w* \w mi|strong="H2009"\w* favor.
\v 20 Mis \w amigos|strong="H7453"\w* son mis burladores. Mis \w ojos|strong="H5869"\w* lloran ante \nd ʼElohim\nd*.
\v 21 ¡Ojalá pudiera disputar \w el|strong="H5973"\w* \w hombre|strong="H1397"\w* ante \nd ʼElohim\nd*, \w como|strong="H5973"\w* un \w hombre|strong="H1397"\w* \w con|strong="H5973"\w* su \w prójimo|strong="H7453"\w*!
\p 
\v 22 \w Porque|strong="H3588"\w* \w cuando|strong="H3588"\w* \w pasen|strong="H1980"\w* algunos \w años|strong="H8141"\w*, \w me|strong="H3588"\w* \w iré|strong="H1980"\w* \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w camino|strong="H1980"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* tiene regreso.
\c 17
\p 
\v 1 Mi alma se agota, mis \w días|strong="H3117"\w* se extinguen. El \w sepulcro|strong="H6913"\w* está preparado para mí.
\v 2 \w No|strong="H3808"\w* hay \w conmigo|strong="H5978"\w* \w sino|strong="H3808"\w* burladores, y mis \w ojos|strong="H5869"\w* \w se|strong="H3808"\w* fijan en su provocación.
\p 
\v 3 \w Te|strong="H5973"\w* \w ruego|strong="H4994"\w*, deposita una \w fianza|strong="H6148"\w* ante \w Ti|strong="H5973"\w* \w mismo|strong="H1931"\w*. ¿\w Quién|strong="H4310"\w* quiere ser \w mi|strong="H4994"\w* garante?
\v 4 \w Porque|strong="H3588"\w* cerraste \w su|strong="H3588"\w* \w corazón|strong="H3820"\w* \w al|strong="H5921"\w* \w entendimiento|strong="H3820"\w*. \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w no|strong="H3808"\w* \w los|strong="H5921"\w* exaltarás.
\v 5 Al \w que|strong="H1121"\w* traiciona \w a|strong="H3068"\w* sus \w amigos|strong="H7453"\w* por recompensa, les desfallecerán \w los|strong="H1121"\w* \w ojos|strong="H5869"\w* \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*.
\p 
\v 6 Pero Él me convirtió en un refrán \w de|strong="H6440"\w* la \w gente|strong="H5971"\w*. \w Soy|strong="H1961"\w* uno \w a|strong="H3068"\w* quien \w los|strong="H1961"\w* hombres escupen.
\v 7 Mis \w ojos|strong="H5869"\w* se oscurecieron por \w la|strong="H3605"\w* angustia, y \w todos|strong="H3605"\w* mis miembros son como una \w sombra|strong="H6738"\w*.
\p 
\v 8 \w Los|strong="H5921"\w* \w rectos|strong="H3477"\w* \w se|strong="H5921"\w* asombran \w de|strong="H5921"\w* \w esto|strong="H2063"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w inocente|strong="H5355"\w* \w se|strong="H5921"\w* levanta \w contra|strong="H5921"\w* \w el|strong="H5921"\w* impío.
\v 9 Sin embargo, el \w justo|strong="H6662"\w* se aferra \w a|strong="H3068"\w* su \w camino|strong="H1870"\w*, y el \w limpio|strong="H2891"\w* \w de|strong="H6662"\w* \w manos|strong="H3027"\w* \w aumentará|strong="H3254"\w* sus fuerzas.
\p 
\v 10 Pero \w ahora|strong="H4994"\w*, \w vuelvan|strong="H7725"\w* \w todos|strong="H3605"\w* ustedes y vengan acá. Pero \w entre|strong="H3808"\w* ustedes \w no|strong="H3808"\w* \w hallaré|strong="H4672"\w* algún \w sabio|strong="H2450"\w*.
\p 
\v 11 Mis \w días|strong="H3117"\w* \w pasaron|strong="H5674"\w*. Mis planes se deshicieron, aun los anhelos de mi \w corazón|strong="H3824"\w*
\v 12 \w que|strong="H3117"\w* solían cambiar la \w noche|strong="H3915"\w* en \w día|strong="H3117"\w*. La luz está después \w de|strong="H6440"\w* la \w oscuridad|strong="H2822"\w*.
\p 
\v 13 Si \w espero|strong="H6960"\w*, yo sé que el \tl Seol\tl* es mi habitación. En la tenebrosidad tengo extendida mi cama.
\v 14 \w A|strong="H3068"\w* la descomposición digo: ¡Padre mío! \w Y|strong="H3068"\w* al gusano: ¡Madre mía, hermana mía!
\v 15 ¿Dónde está entonces mi \w esperanza|strong="H8615"\w*? ¿\w Quién|strong="H4310"\w* verá mi bien?
\v 16 \w Descenderá|strong="H3381"\w* \w conmigo|strong="H3162"\w* \w al|strong="H5921"\w* \tl Seol\tl* \w y|strong="H5921"\w* \w juntos|strong="H3162"\w* bajaremos \w al|strong="H5921"\w* \w polvo|strong="H6083"\w*.
\c 18
\s1 Segunda intervención de Bildad suhita
\p 
\v 1 Entonces \w Bildad|strong="H1085"\w* \w suhita|strong="H7747"\w* \w respondió|strong="H6030"\w*:
\v 2 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H5704"\w* tenderás trampa \w con|strong="H5704"\w* \w palabras|strong="H1696"\w*? Recapacita, \w y|strong="H5704"\w* \w después|strong="H5704"\w* \w hablemos|strong="H1696"\w*.
\v 3 ¿\w Por|strong="H4069"\w* qué somos considerados \w como|strong="H4069"\w* animales y \w como|strong="H4069"\w* torpes ante ti?
\v 4 Tú, \w que|strong="H4616"\w* \w te|strong="H5315"\w* desgarras en tu furor, ¿será \w abandonada|strong="H5800"\w* la tierra \w por|strong="H4616"\w* tu causa, \w o|strong="H3068"\w* serán removidas las peñas de su \w sitio|strong="H4725"\w*?
\p 
\v 5 \w Ciertamente|strong="H1571"\w* \w la|strong="H1571"\w* luz de los \w impíos|strong="H7563"\w* es apagada, \w y|strong="H1571"\w* \w la|strong="H1571"\w* luz de su fuego \w no|strong="H3808"\w* resplandece.
\v 6 \w La|strong="H5921"\w* luz \w de|strong="H5921"\w* su vivienda \w está|strong="H5921"\w* \w oscura|strong="H2821"\w*, \w porque|strong="H5921"\w* su \w lámpara|strong="H5216"\w* es apagada.
\v 7 Los \w pasos|strong="H6806"\w* de su vigor son acortados, y su propio designio lo derribará.
\p 
\v 8 \w Porque|strong="H3588"\w* sus propios \w pies|strong="H7272"\w* \w lo|strong="H5921"\w* echarán \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w red|strong="H7568"\w* \w y|strong="H3588"\w* deambula \w en|strong="H5921"\w* \w la|strong="H5921"\w* maraña.
\v 9 Una trampa \w lo|strong="H5921"\w* atrapa \w por|strong="H5921"\w* \w el|strong="H5921"\w* talón, \w y|strong="H5921"\w* \w se|strong="H5921"\w* aferra \w la|strong="H5921"\w* trampa \w contra|strong="H5921"\w* \w él|strong="H5921"\w*.
\v 10 Una trampa \w está|strong="H5921"\w* oculta \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w para|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* una trampa \w lo|strong="H5921"\w* espera \w en|strong="H5921"\w* \w el|strong="H5921"\w* sendero.
\v 11 De \w todas|strong="H5439"\w* \w partes|strong="H5439"\w* lo asaltan los \w terrores|strong="H1091"\w* \w y|strong="H1091"\w* lo hostigan \w a|strong="H3068"\w* cada paso.
\p 
\v 12 Su vigor \w se|strong="H1961"\w* desgasta por el hambre, y la calamidad \w está|strong="H1961"\w* lista \w a|strong="H3068"\w* su \w lado|strong="H6763"\w*.
\v 13 La enfermedad carcome su \w piel|strong="H5785"\w*, y el \w primogénito|strong="H1060"\w* de la \w muerte|strong="H4194"\w* devora sus miembros.
\v 14 Su \w confianza|strong="H4009"\w* será removida de su vivienda, \w y|strong="H1091"\w* él será arrastrado ante el \w rey|strong="H4428"\w* de los espantos.
\p 
\v 15 \w El|strong="H5921"\w* fuego estará \w en|strong="H5921"\w* su casa, \w y|strong="H5921"\w* \w azufre|strong="H1614"\w* será esparcido \w sobre|strong="H5921"\w* su vivienda.
\v 16 Desde \w abajo|strong="H8478"\w* se secan sus \w raíces|strong="H8328"\w*, y desde \w arriba|strong="H4605"\w* se marchita su ramaje.
\v 17 Su recuerdo desaparece \w de|strong="H4480"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* ya \w no|strong="H3808"\w* tendrá \w nombre|strong="H8034"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w calles|strong="H2351"\w*.
\v 18 De la luz es empujado \w a|strong="H3068"\w* la \w oscuridad|strong="H2822"\w*, y es echado fuera del \w mundo|strong="H8398"\w*.
\v 19 \w No|strong="H3808"\w* tiene futuras generaciones \w ni|strong="H3808"\w* descendiente en su \w pueblo|strong="H5971"\w*, \w ni|strong="H3808"\w* sobreviviente en sus viviendas.
\p 
\v 20 \w Los|strong="H5921"\w* \w que|strong="H5921"\w* vienen \w del|strong="H5921"\w* oeste \w se|strong="H5921"\w* asombran \w de|strong="H5921"\w* su destino, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* viven \w en|strong="H5921"\w* \w el|strong="H5921"\w* este \w se|strong="H5921"\w* aterrorizan \w de|strong="H5921"\w* espanto.
\v 21 Ciertamente \w así|strong="H2088"\w* \w son|strong="H3808"\w* las \w moradas|strong="H4908"\w* del perverso, y \w tal|strong="H2088"\w* el \w lugar|strong="H4725"\w* del \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w conoce|strong="H3045"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd*.
\c 19
\s1 La esperanza de Job: el Redentor que vive
\p 
\v 1 Entonces Job \w respondió|strong="H6030"\w*:
\v 2 ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H5704"\w* afligen \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* \w y|strong="H5704"\w* me muelen \w con|strong="H5704"\w* \w palabras|strong="H4405"\w*?
\v 3 \w Ya|strong="H3068"\w* me insultaron \w diez|strong="H6235"\w* \w veces|strong="H6471"\w*. ¿\w No|strong="H3808"\w* \w se|strong="H3808"\w* avergüenzan de ultrajarme?
\v 4 Si en verdad yo erré, mi error recae sobre mí.
\v 5 Pero \w si|strong="H5921"\w* ustedes \w se|strong="H5921"\w* engrandecen \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H5921"\w* alegan \w mi|strong="H5921"\w* \w oprobio|strong="H2781"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*,
\v 6 \w sepan|strong="H3045"\w* \w que|strong="H3588"\w* \nd ʼElohim\nd* \w me|strong="H5921"\w* trastornó \w y|strong="H3588"\w* \w me|strong="H5921"\w* envolvió \w en|strong="H5921"\w* \w su|strong="H3588"\w* \w red|strong="H4686"\w*.
\p 
\v 7 \w Ciertamente|strong="H2005"\w* grito: ¡\w Violencia|strong="H2555"\w*! \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* me escucha. Doy \w voces|strong="H6817"\w*, y \w no|strong="H3808"\w* hay \w justicia|strong="H4941"\w*.
\v 8 \w Él|strong="H5921"\w* bloqueó \w mi|strong="H5921"\w* camino \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w pase|strong="H5674"\w*. \w Puso|strong="H7760"\w* \w oscuridad|strong="H2822"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w senda|strong="H5410"\w*.
\v 9 \w Me|strong="H5921"\w* despojó \w de|strong="H5921"\w* \w mi|strong="H5921"\w* honor \w y|strong="H5921"\w* \w quitó|strong="H5493"\w* \w la|strong="H5921"\w* \w corona|strong="H5850"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w cabeza|strong="H7218"\w*.
\v 10 Me destroza por todos \w lados|strong="H5439"\w* y perezco. \w Arrancó|strong="H5265"\w* mi \w esperanza|strong="H8615"\w* como un \w árbol|strong="H6086"\w*.
\v 11 Su ira \w se|strong="H5921"\w* encendió \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*. \w Me|strong="H5921"\w* considera su \w enemigo|strong="H6862"\w*.
\v 12 Llegaron sus tropas unidas, \w se|strong="H5921"\w* atrincheran \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* acamparon \w alrededor|strong="H5439"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* vivienda.
\p 
\v 13 Alejó \w a|strong="H3068"\w* mis hermanos \w de|strong="H4480"\w* \w mí|strong="H5921"\w*. Mis conocidos, \w como|strong="H5921"\w* extraños, \w se|strong="H3045"\w* apartaron \w de|strong="H4480"\w* \w mí|strong="H5921"\w*.
\v 14 Me fallaron mis parientes, me olvidan mis amigos.
\v 15 \w Los|strong="H1961"\w* \w que|strong="H1961"\w* viven en \w mi|strong="H1961"\w* \w casa|strong="H1004"\w* y mis esclavas me miran \w como|strong="H1961"\w* \w extraño|strong="H2114"\w*. \w Soy|strong="H1961"\w* \w forastero|strong="H5237"\w* ante ellos.
\v 16 \w Llamo|strong="H7121"\w* \w a|strong="H3068"\w* \w mi|strong="H6030"\w* esclavo, y \w no|strong="H3808"\w* \w responde|strong="H6030"\w*. Con \w mi|strong="H6030"\w* propia \w boca|strong="H6310"\w* tengo \w que|strong="H3808"\w* rogarle.
\v 17 Mi aliento fue repulsivo \w a|strong="H3068"\w* mi esposa y odioso ante mis propios hermanos.
\v 18 Hasta los niños me desprecian, \w y|strong="H1571"\w* al \w levantarme|strong="H6965"\w* \w hablan|strong="H1696"\w* contra mí.
\v 19 \w Todos|strong="H3605"\w* mis amigos íntimos me aborrecen. \w Los|strong="H3605"\w* \w que|strong="H2088"\w* yo amaba se \w volvieron|strong="H2015"\w* contra mí.
\p 
\v 20 Mi \w piel|strong="H5785"\w* y mi \w carne|strong="H1320"\w* se pegan \w a|strong="H3068"\w* mis \w huesos|strong="H6106"\w*, y quedé solo con la \w piel|strong="H5785"\w* de mis \w dientes|strong="H8127"\w*.
\v 21 Ustedes, \w amigos|strong="H7453"\w* míos, tengan \w compasión|strong="H2603"\w* \w de|strong="H3588"\w* mí. \w Porque|strong="H3588"\w* \w me|strong="H3588"\w* golpeó \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \nd ʼElohim\nd*.
\v 22 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* me \w persiguen|strong="H7291"\w* \w como|strong="H4100"\w* \nd ʼElohim\nd*, y \w no|strong="H3808"\w* \w se|strong="H3808"\w* sacian \w de|strong="H7646"\w* escarnecerme?
\p 
\v 23 ¡\w Ojalá|strong="H4310"\w* \w mis|strong="H5414"\w* \w palabras|strong="H4405"\w* fueran \w escritas|strong="H3789"\w*! ¡\w Ojalá|strong="H4310"\w* fueran \w escritas|strong="H3789"\w* en un rollo!
\v 24 ¡Que fueran talladas con cincel de \w hierro|strong="H1270"\w* y plomo \w para|strong="H5703"\w* \w siempre|strong="H5703"\w* en la \w roca|strong="H6697"\w*!
\v 25 Yo \w sé|strong="H3045"\w* \w que|strong="H5921"\w* \w mi|strong="H5921"\w* \w Redentor|strong="H1350"\w* \w vive|strong="H2416"\w*, \w y|strong="H5921"\w* \w al|strong="H5921"\w* fin \w se|strong="H3045"\w* \w levantará|strong="H6965"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w*,
\v 26 Después de deshecha mi \w piel|strong="H5785"\w*, en mi \w carne|strong="H1320"\w* \w veré|strong="H2372"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd*,
\v 27 \w a|strong="H3068"\w* Quien \w veré|strong="H7200"\w* por mí mismo. Mis \w ojos|strong="H5869"\w* \w lo|strong="H3808"\w* \w verán|strong="H7200"\w*, y \w no|strong="H3808"\w* los \w de|strong="H5869"\w* otro. Mi corazón \w desfallece|strong="H3615"\w* \w dentro|strong="H2436"\w* \w de|strong="H5869"\w* mí.
\p 
\v 28 \w Porque|strong="H3588"\w* \w si|strong="H3588"\w* \w la|strong="H3588"\w* raíz \w de|strong="H3588"\w* mi situación está \w en|strong="H3588"\w* mí mismo, \w entonces|strong="H3588"\w*, ¿\w por|strong="H3588"\w* \w qué|strong="H3588"\w* dicen ustedes: Persigámoslo?
\v 29 ¡Teman ustedes \w ante|strong="H6440"\w* \w la|strong="H3588"\w* \w espada|strong="H2719"\w*! \w Porque|strong="H3588"\w* llenos \w de|strong="H3588"\w* \w ira|strong="H2534"\w* están \w los|strong="H3588"\w* castigos \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w espada|strong="H2719"\w*, \w para|strong="H4616"\w* \w que|strong="H3588"\w* \w sepan|strong="H3045"\w* \w que|strong="H3588"\w* hay un \w juicio|strong="H1779"\w*.
\c 20
\s1 Segunda intervención de Sofar naamatita
\p 
\v 1 Entonces Sofar \w naamatita|strong="H5284"\w* \w respondió|strong="H6030"\w*:
\v 2 Ciertamente mis \w pensamientos|strong="H5587"\w* me impulsan \w a|strong="H3068"\w* \w responder|strong="H7725"\w*, \w a|strong="H3068"\w* causa de mi agitación interna.
\v 3 \w Oí|strong="H8085"\w* una reprensión que me \w afrenta|strong="H3639"\w*, y el \w espíritu|strong="H7307"\w* de \w mi|strong="H6030"\w* entendimiento hace que \w responda|strong="H6030"\w*.
\p 
\v 4 ¿\w No|strong="H5921"\w* \w sabes|strong="H3045"\w* \w que|strong="H4480"\w* \w desde|strong="H4480"\w* \w la|strong="H5921"\w* antigüedad, \w desde|strong="H4480"\w* cuando \w el|strong="H5921"\w* hombre fue puesto \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra,
\v 5 \w el|strong="H3588"\w* triunfo \w de|strong="H3588"\w* \w los|strong="H3588"\w* perversos \w es|strong="H3588"\w* efímero, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w alegría|strong="H8057"\w* del \w impío|strong="H7563"\w* \w es|strong="H3588"\w* momentánea?
\v 6 Aunque su altivez \w suba|strong="H5927"\w* hasta el \w cielo|strong="H8064"\w*, y su \w cabeza|strong="H7218"\w* toque las \w nubes|strong="H5645"\w*,
\v 7 como su estiércol perecerá para siempre. Los que lo \w veían|strong="H7200"\w* preguntarán: ¿Dónde está?
\v 8 \w Se|strong="H3808"\w* esfumará como un \w sueño|strong="H2472"\w*, y \w no|strong="H3808"\w* \w será|strong="H3808"\w* \w hallado|strong="H4672"\w*. \w Se|strong="H3808"\w* disipará como \w visión|strong="H2384"\w* \w nocturna|strong="H3915"\w*.
\v 9 El \w ojo|strong="H5869"\w* \w que|strong="H3808"\w* \w lo|strong="H3808"\w* \w miraba|strong="H5869"\w* \w ya|strong="H3254"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* verá, \w ni|strong="H3808"\w* su \w lugar|strong="H4725"\w* \w volverá|strong="H3254"\w* \w a|strong="H3068"\w* contemplarlo.
\v 10 Tendrá \w que|strong="H1121"\w* devolver sus riquezas. Sus \w hijos|strong="H1121"\w* pedirán \w el|strong="H1121"\w* favor \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w pobres|strong="H1800"\w*.
\v 11 Sus \w huesos|strong="H6106"\w* aún \w llenos|strong="H4390"\w* \w de|strong="H5921"\w* vigor juvenil \w se|strong="H5921"\w* acostarán \w con|strong="H5973"\w* \w él|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w*.
\p 
\v 12 Aunque la \w maldad|strong="H7451"\w* sea dulce \w en|strong="H8478"\w* su \w boca|strong="H6310"\w*, la \w oculte|strong="H3582"\w* \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* su \w lengua|strong="H3956"\w*,
\v 13 \w la|strong="H5921"\w* retenga \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w la|strong="H5921"\w* quiera soltar, \w y|strong="H5921"\w* \w la|strong="H5921"\w* mantenga \w en|strong="H5921"\w* su paladar,
\v 14 su \w comida|strong="H3899"\w* se pudrirá en sus intestinos. Veneno de víboras hay \w dentro|strong="H7130"\w* de él.
\v 15 \w Devoró|strong="H1104"\w* \w riquezas|strong="H2428"\w*, pero las vomitará. \nd ʼElohim\nd* las sacará de su sistema digestivo.
\v 16 \w Chupará|strong="H3243"\w* el \w veneno|strong="H7219"\w* de la víbora, y la \w lengua|strong="H3956"\w* de la serpiente lo \w matará|strong="H2026"\w*.
\v 17 No \w verá|strong="H7200"\w* los \w arroyos|strong="H5158"\w* que fluyen, los torrentes que fluyen leche y \w miel|strong="H1706"\w*.
\v 18 Devolverá el fruto de su labor \w sin|strong="H3808"\w* tragarlo, y \w no|strong="H3808"\w* disfrutará el lucro de su negocio,
\v 19 \w porque|strong="H3588"\w* oprimió \w y|strong="H3588"\w* desamparó al \w pobre|strong="H1800"\w*, \w y|strong="H3588"\w* \w se|strong="H3808"\w* apoderó \w de|strong="H3588"\w* \w casas|strong="H1004"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* construyó.
\p 
\v 20 \w Porque|strong="H3588"\w* \w su|strong="H3588"\w* sistema digestivo \w no|strong="H3808"\w* \w conoció|strong="H3045"\w* \w la|strong="H3588"\w* tranquilidad, \w nada|strong="H3808"\w* retendrá \w de|strong="H3588"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* \w más|strong="H3588"\w* codiciaba.
\v 21 \w Por|strong="H5921"\w* \w cuanto|strong="H3651"\w* \w nada|strong="H3808"\w* escapó \w a|strong="H3068"\w* su rapacidad, su prosperidad \w no|strong="H3808"\w* \w será|strong="H3808"\w* duradera.
\v 22 En \w la|strong="H3605"\w* plenitud de su abundancia sufrirá estrechez. \w La|strong="H3605"\w* \w mano|strong="H3027"\w* de \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H3605"\w* sufre se levantará contra \w él|strong="H3605"\w*.
\p 
\v 23 \w Cuando|strong="H1961"\w* \w en|strong="H5921"\w* su estómago ya \w no|strong="H1961"\w* \w entre|strong="H5921"\w* \w más|strong="H5921"\w*, \nd ʼElohim\nd* \w enviará|strong="H7971"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w el|strong="H5921"\w* \w furor|strong="H2740"\w* \w de|strong="H5921"\w* su \w ira|strong="H2740"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w hará|strong="H1961"\w* llover \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* mientras come.
\v 24 \w Huirá|strong="H1272"\w* de las \w armas|strong="H5402"\w* de \w hierro|strong="H1270"\w*, pero lo traspasará una flecha de bronce.
\v 25 \w Si|strong="H5921"\w* logra sacarse \w la|strong="H5921"\w* flecha, ciertamente \w le|strong="H5921"\w* \w sale|strong="H3318"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* espalda. ¡Ciertamente, \w la|strong="H5921"\w* punta reluciente \w sale|strong="H3318"\w* \w de|strong="H5921"\w* su \w hiel|strong="H4846"\w*! \w Sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w se|strong="H5921"\w* vienen terrores.
\p 
\v 26 \w Toda|strong="H3605"\w* \w la|strong="H3605"\w* tenebrosidad está reservada para sus tesoros. Un fuego \w no|strong="H3808"\w* atizado \w los|strong="H3605"\w* devorará, y consumirá \w lo|strong="H3808"\w* \w que|strong="H3808"\w* quede en su vivienda.
\v 27 El \w cielo|strong="H8064"\w* revelará su \w iniquidad|strong="H5771"\w*, y la tierra se \w levantará|strong="H6965"\w* contra él.
\v 28 Las riquezas de su \w casa|strong="H1004"\w* se perderán. Serán arrasadas en el \w día|strong="H3117"\w* de su furor.
\p [[
\v 29 ]]\f + \fr 20:29 \ft Este versículo no se halla en los manuscritos más antiguos y confiables.\f*
\c 21
\s1 La decepción de Job ante el éxito de los perversos
\p 
\v 1 Entonces Job \w respondió|strong="H6030"\w*:
\v 2 \w Escuchen|strong="H8085"\w* con atención \w mis|strong="H4405"\w* \w palabras|strong="H4405"\w*, y \w que|strong="H1961"\w* \w sea|strong="H1961"\w* \w esto|strong="H2063"\w* el consuelo \w que|strong="H1961"\w* me den.
\v 3 Tolérenme mientras \w hablo|strong="H1696"\w*, y después que \w hable|strong="H1696"\w*, búrlense.
\p 
\v 4 ¿Me quejo ante un hombre? ¿\w Por|strong="H4069"\w* \w qué|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* debe impacientar mi \w espíritu|strong="H7307"\w*?
\v 5 Mírenme, asómbrense \w y|strong="H5921"\w* coloquen \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* su \w boca|strong="H6310"\w*.
\v 6 Cuando lo recuerdo me asombro, y el horror estremece mi \w carne|strong="H1320"\w*.
\p 
\v 7 ¿\w Por|strong="H4069"\w* \w qué|strong="H1571"\w* \w viven|strong="H7563"\w* los perversos, envejecen \w y|strong="H1571"\w* son poderosos?
\v 8 Sus \w descendientes|strong="H6631"\w* se establecen \w con|strong="H5973"\w* ellos y \w ante|strong="H6440"\w* ellos. Sus \w hijos|strong="H2233"\w* están \w ante|strong="H6440"\w* ellos.
\v 9 Sus \w casas|strong="H1004"\w* están libres \w de|strong="H5921"\w* \w temor|strong="H6343"\w*. \w No|strong="H3808"\w* tienen azote \w de|strong="H5921"\w* \nd ʼElohim\nd* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*.
\v 10 Su toro fecunda \w sin|strong="H3808"\w* fallar, sus \w vacas|strong="H6510"\w* \w paren|strong="H6403"\w* \w y|strong="H7794"\w* \w no|strong="H3808"\w* pierden crías.
\v 11 Sueltan \w a|strong="H3068"\w* sus pequeños como manada y sus \w hijos|strong="H3206"\w* andan saltando.
\v 12 Cantan al son del tamboril y el \w arpa|strong="H3658"\w*. Se regocijan con el \w sonido|strong="H6963"\w* de la flauta.
\v 13 Sus \w días|strong="H3117"\w* transcurren en prosperidad. Con tranquilidad bajan al \tl Seol\tl*.
\p 
\v 14 \w Ellos|strong="H4480"\w* dicen \w a|strong="H3068"\w* \nd ʼElohim\nd*: \w Apártate|strong="H5493"\w* \w de|strong="H4480"\w* nosotros. \w Ni|strong="H3808"\w* siquiera deseamos el \w conocimiento|strong="H1847"\w* \w de|strong="H4480"\w* tus \w caminos|strong="H1870"\w*.
\v 15 ¿\w Quién|strong="H4100"\w* \w es|strong="H3588"\w* \nd ʼEL-Shadday\nd* \w para|strong="H3588"\w* \w que|strong="H3588"\w* le \w sirvamos|strong="H5647"\w*, \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w qué|strong="H3588"\w* \w nos|strong="H4100"\w* \w aprovecha|strong="H3276"\w* \w que|strong="H3588"\w* le supliquemos?
\v 16 \w Ciertamente|strong="H2005"\w*, la prosperidad \w de|strong="H4480"\w* \w ellos|strong="H3027"\w* \w no|strong="H3808"\w* está \w en|strong="H4480"\w* sus propias \w manos|strong="H3027"\w*. El \w consejo|strong="H6098"\w* \w de|strong="H4480"\w* los perversos esté \w lejos|strong="H7368"\w* \w de|strong="H4480"\w* mí.
\p 
\v 17 ¿\w Cuántas|strong="H4100"\w* veces es apagada \w la|strong="H5921"\w* \w lámpara|strong="H5216"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* perversos, \w o|strong="H3068"\w* su calamidad cae \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w o|strong="H3068"\w* \nd ʼElohim\nd* \w les|strong="H5921"\w* reparte destrucción \w en|strong="H5921"\w* su ira?
\v 18 ¿\w Son|strong="H1961"\w* \w como|strong="H1961"\w* concha \w de|strong="H6440"\w* grano trillado llevada \w por|strong="H6440"\w* el \w viento|strong="H7307"\w*, y \w como|strong="H1961"\w* pasto \w que|strong="H1961"\w* arrebata la tormenta?
\v 19 Ustedes dicen: \nd ʼElohim\nd* guarda la perversidad del \w hombre|strong="H1121"\w* para sus \w hijos|strong="H1121"\w*. ¡\w Que|strong="H3045"\w* \nd ʼElohim\nd* le retribuya para \w que|strong="H3045"\w* aprenda!
\v 20 ¡\w Vean|strong="H7200"\w* sus \w ojos|strong="H5869"\w* su ruina, y beba él mismo \w de|strong="H5869"\w* la \w ira|strong="H2534"\w* \w de|strong="H5869"\w* \nd ʼEL-Shadday\nd*!
\v 21 \w Pues|strong="H3588"\w* después \w que|strong="H3588"\w* muera \w y|strong="H3588"\w* acabe \w la|strong="H3588"\w* \w cuenta|strong="H4557"\w* \w de|strong="H3588"\w* sus \w meses|strong="H2320"\w*, ¿\w qué|strong="H3588"\w* le importa \w su|strong="H3588"\w* \w familia|strong="H1004"\w*?
\p 
\v 22 ¿Puede alguno enseñar conocimientos \w a|strong="H3068"\w* \nd ʼElohim\nd*, puesto \w que|strong="H1931"\w* \w Él|strong="H1931"\w* \w juzga|strong="H8199"\w* \w a|strong="H3068"\w* \w los|strong="H1931"\w* \w que|strong="H1931"\w* están en las alturas?
\v 23 Un hombre muere en \w la|strong="H3605"\w* plenitud de su vigor, completamente tranquilo y en paz,
\v 24 con las cavidades internas \w llenas|strong="H4390"\w* de grasa y la médula de sus \w huesos|strong="H6106"\w* bien nutrida.
\v 25 \w Otro|strong="H2088"\w* muere con el \w alma|strong="H5315"\w* amargada, \w sin|strong="H3808"\w* \w comer|strong="H5315"\w* \w jamás|strong="H3808"\w* con gusto.
\v 26 \w Juntamente|strong="H3162"\w* están tendidos \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w*, \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w gusanos|strong="H7415"\w* \w los|strong="H5921"\w* \w cubren|strong="H3680"\w*.
\p 
\v 27 \w Ciertamente|strong="H2005"\w* \w conozco|strong="H3045"\w* \w los|strong="H5921"\w* \w pensamientos|strong="H4284"\w* \w de|strong="H5921"\w* ustedes, \w y|strong="H5921"\w* sus estratagemas \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*.
\v 28 Sé \w que|strong="H3588"\w* dicen: ¿Dónde está \w la|strong="H3588"\w* \w casa|strong="H1004"\w* del \w que|strong="H3588"\w* era poderoso, \w y|strong="H3588"\w* \w la|strong="H3588"\w* vivienda \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w cual|strong="H3588"\w* vivían \w los|strong="H3588"\w* perversos?
\v 29 ¿\w Por|strong="H1870"\w* \w qué|strong="H3808"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* preguntan \w a|strong="H3068"\w* los viajeros, \w ni|strong="H3808"\w* han consultado su respuesta?
\v 30 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* perverso \w es|strong="H3588"\w* preservado \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* calamidad, \w y|strong="H3588"\w* se lo excluye del \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* ira.
\p 
\v 31 ¿\w Quién|strong="H4310"\w* \w le|strong="H1931"\w* denuncia \w en|strong="H5921"\w* \w la|strong="H1931"\w* \w cara|strong="H6440"\w* \w su|strong="H1931"\w* \w camino|strong="H1870"\w*? \w Y|strong="H3068"\w* \w lo|strong="H1931"\w* \w que|strong="H4310"\w* \w hizo|strong="H6213"\w*, ¿\w quién|strong="H4310"\w* \w se|strong="H1931"\w* \w lo|strong="H1931"\w* retribuye?
\v 32 \w Porque|strong="H5921"\w* \w es|strong="H1931"\w* conducido \w al|strong="H5921"\w* \w sepulcro|strong="H6913"\w*, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w su|strong="H1931"\w* tumba \w se|strong="H1931"\w* hará vigilancia,
\v 33 y junto \w a|strong="H3068"\w* \w la|strong="H3605"\w* tumba magnífica se monta guardia. Así, tras \w él|strong="H3605"\w*, \w todo|strong="H3605"\w* \w el|strong="H3605"\w* mundo desfila, y adelante \w de|strong="H6440"\w* \w él|strong="H3605"\w*, otros sinnúmero.
\p 
\v 34 ¿Cómo pueden ustedes \w consolarme|strong="H5162"\w* con palabras vacías y fútiles, puesto que en sus respuestas solo hay falsedad?
\c 22
\s1 Otra acusación odiosa de Elifaz temanita
\p 
\v 1 Elifaz \w temanita|strong="H8489"\w* \w habló|strong="H6030"\w* otra vez:
\v 2 ¿Puede \w el|strong="H5921"\w* \w hombre|strong="H1397"\w* dar \w provecho|strong="H5532"\w* \w a|strong="H3068"\w* \nd ʼElohim\nd*? ¿Puede \w el|strong="H5921"\w* \w hombre|strong="H1397"\w* vigoroso serle útil?
\v 3 ¿\nd ʼEL-Shadday\nd* tiene \w deleite|strong="H2656"\w* \w en|strong="H3588"\w* \w que|strong="H3588"\w* tú seas justo? ¿\w Qué|strong="H3588"\w* gana \w Él|strong="H3588"\w* \w si|strong="H3588"\w* tus \w caminos|strong="H1870"\w* \w son|strong="H3588"\w* rectos?
\p 
\v 4 ¿\w Te|strong="H5973"\w* reprocha \w o|strong="H3068"\w* \w te|strong="H5973"\w* lleva \w a|strong="H3068"\w* \w juicio|strong="H4941"\w* por tu reverencia \w a|strong="H3068"\w* \w Él|strong="H5973"\w*?
\v 5 ¿\w No|strong="H3808"\w* \w son|strong="H3808"\w* \w grandes|strong="H7227"\w* tus perversidades, y tus \w iniquidades|strong="H5771"\w* \w no|strong="H3808"\w* tienen \w fin|strong="H7093"\w*?
\v 6 \w Porque|strong="H3588"\w* sin razón tomaste prendas \w a|strong="H3068"\w* tus hermanos \w y|strong="H3588"\w* al \w desnudo|strong="H6174"\w* despojaste \w de|strong="H3588"\w* sus ropas.
\v 7 \w No|strong="H3808"\w* diste \w de|strong="H4325"\w* \w beber|strong="H8248"\w* al sediento y negaste el \w pan|strong="H3899"\w* al hambriento.
\p 
\v 8 Pero la tierra pertenece al hombre poderoso, honorable que vive en ella.
\v 9 Despediste \w a|strong="H3068"\w* las viudas con las manos \w vacías|strong="H7387"\w*, y los \w brazos|strong="H2220"\w* de los \w huérfanos|strong="H3490"\w* fueron quebrantados.
\v 10 \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* hay trampas \w alrededor|strong="H5439"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*, \w te|strong="H5921"\w* espantan terrores repentinos,
\v 11 \w o|strong="H3068"\w* hay \w oscuridad|strong="H2822"\w* para \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w veas|strong="H7200"\w*, y te \w cubre|strong="H3680"\w* la abundancia \w de|strong="H4325"\w* \w aguas|strong="H4325"\w*.
\p 
\v 12 ¿\w No|strong="H3808"\w* está \nd ʼEloah\nd* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w altura|strong="H1363"\w* del \w cielo|strong="H8064"\w*? ¡\w Mira|strong="H7200"\w* \w cuán|strong="H3588"\w* \w elevadas|strong="H7311"\w* están las \w estrellas|strong="H3556"\w*!
\v 13 \w Y|strong="H3068"\w* dijiste: ¿\w Qué|strong="H4100"\w* \w sabe|strong="H3045"\w* \nd ʼElohim\nd*? ¿Podrá distinguir \w a|strong="H3068"\w* través de la \w oscuridad|strong="H6205"\w*?
\v 14 Las \w nubes|strong="H5645"\w* \w son|strong="H3808"\w* un lugar de escondite para Él, así \w que|strong="H3808"\w* \w no|strong="H3808"\w* puede \w ver|strong="H7200"\w*. Él \w pasea|strong="H1980"\w* por la bóveda celeste.
\p 
\v 15 ¿Seguirás en \w la|strong="H8104"\w* senda \w antigua|strong="H5769"\w* \w que|strong="H1869"\w* \w pisaron|strong="H1869"\w* los \w hombres|strong="H4962"\w* perversos,
\v 16 los cuales fueron arrastrados antes \w de|strong="H6256"\w* \w tiempo|strong="H6256"\w*, cuyos cimientos fueron arrasados por un \w río|strong="H5104"\w*?
\v 17 \w Ellos|strong="H4480"\w* decían \w a|strong="H3068"\w* \nd ʼElohim\nd*: ¡\w Apártate|strong="H5493"\w* \w de|strong="H4480"\w* nosotros! ¿\w Qué|strong="H4100"\w* puede hacernos \nd ʼEL-Shadday\nd*?
\p 
\v 18 Aunque \w Él|strong="H1931"\w* \w llenó|strong="H4390"\w* \w sus|strong="H1931"\w* viviendas \w de|strong="H4480"\w* bienes, \w lejos|strong="H7368"\w* \w esté|strong="H1931"\w* \w de|strong="H4480"\w* mí \w el|strong="H1931"\w* \w consejo|strong="H6098"\w* \w de|strong="H4480"\w* \w los|strong="H1931"\w* perversos.
\v 19 Los \w justos|strong="H6662"\w* lo \w ven|strong="H7200"\w* \w y|strong="H5355"\w* se \w alegran|strong="H8055"\w*. El \w inocente|strong="H5355"\w* se burla \w de|strong="H6662"\w* ellos:
\v 20 ¡En verdad nuestros adversarios fueron destruidos, y \w lo|strong="H3808"\w* \w que|strong="H3808"\w* queda de ellos \w lo|strong="H3808"\w* devora el fuego!
\p 
\v 21 Reconcíliate y tendrás \w paz|strong="H7999"\w* \w con|strong="H5973"\w* \w Él|strong="H5973"\w*, y por ello \w te|strong="H5973"\w* vendrá \w bien|strong="H2896"\w*.
\v 22 Acepta la instrucción de su \w boca|strong="H6310"\w*, y guarda sus dichos en tu \w corazón|strong="H3824"\w*.
\v 23 Si te \w vuelves|strong="H7725"\w* \w a|strong="H3068"\w* \nd ʼEL-Shadday\nd*, serás reedificado. Si alejas la \w iniquidad|strong="H5766"\w* \w de|strong="H5704"\w* tu casa,
\v 24 \w y|strong="H5921"\w* lanzas tu tesoro \w al|strong="H5921"\w* \w polvo|strong="H6083"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w oro|strong="H1220"\w* \w de|strong="H5921"\w* Ofir, \w como|strong="H5921"\w* piedras \w del|strong="H5921"\w* \w arroyo|strong="H5158"\w*.
\p 
\v 25 Entonces \nd ʼEL-Shadday\nd* \w será|strong="H1961"\w* tu \w oro|strong="H1220"\w* y \w plata|strong="H3701"\w* preciosa \w para|strong="H1961"\w* ti.
\v 26 \w Entonces|strong="H3588"\w* \w te|strong="H5921"\w* deleitarás \w en|strong="H5921"\w* \nd ʼEL-Shadday\nd*, \w y|strong="H3588"\w* \w levantarás|strong="H5375"\w* tu \w rostro|strong="H6440"\w* \w hacia|strong="H5921"\w* \nd ʼElohim\nd*.
\p 
\v 27 \w Orarás|strong="H6279"\w* \w a|strong="H3068"\w* Él, y te \w escuchará|strong="H8085"\w*, y tú podrás \w pagar|strong="H7999"\w* tus \w votos|strong="H5088"\w*.
\v 28 Cuando decidas una cosa, \w te|strong="H5921"\w* será establecida \w y|strong="H5921"\w* brillará \w la|strong="H5921"\w* luz \w en|strong="H5921"\w* tus \w caminos|strong="H1870"\w*.
\v 29 \w Cuando|strong="H3588"\w* estés abatido, hablarás \w con|strong="H3588"\w* confianza: ¡\w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* persona humilde \w Él|strong="H3588"\w* \w salvará|strong="H3467"\w*!
\v 30 \w Librará|strong="H4422"\w* al \w inocente|strong="H5355"\w*. \w Escapará|strong="H4422"\w* \w a|strong="H3068"\w* causa de la limpieza de tus \w manos|strong="H3709"\w*.
\c 23
\s1 Respuesta de Job a Elifaz temanita
\p 
\v 1 Job \w respondió|strong="H6030"\w*:
\v 2 \w Aun|strong="H1571"\w* \w hoy|strong="H3117"\w* \w es|strong="H3027"\w* amarga \w mi|strong="H5921"\w* queja, \w pues|strong="H3513"\w* \w mi|strong="H5921"\w* llaga agrava mis gemidos.
\v 3 ¡\w Ojalá|strong="H4310"\w* \w me|strong="H4310"\w* concediera \w saber|strong="H3045"\w* dónde hallarlo! Yo iría \w hasta|strong="H5704"\w* su trono,
\v 4 expondría \w ante|strong="H6440"\w* Él mi \w causa|strong="H6440"\w*, llenaría mi \w boca|strong="H6310"\w* \w de|strong="H6440"\w* argumentos,
\v 5 sabría con cuáles \w palabras|strong="H4405"\w* me replica, y entendería \w lo|strong="H4100"\w* \w que|strong="H4100"\w* me dice.
\p 
\v 6 ¿Contendería \w conmigo|strong="H5978"\w* \w con|strong="H5978"\w* \w la|strong="H1931"\w* grandeza de \w su|strong="H1931"\w* \w fuerza|strong="H3581"\w*? \w No|strong="H3808"\w*, \w más|strong="H7227"\w* bien me atendería.
\v 7 \w Allí|strong="H8033"\w* \w el|strong="H5973"\w* justo podría \w razonar|strong="H3198"\w* \w con|strong="H5973"\w* \w Él|strong="H5973"\w*, y yo quedaría libre \w para|strong="H5973"\w* siempre \w de|strong="H5973"\w* mi \w Juez|strong="H8199"\w*.
\p 
\v 8 Pero \w si|strong="H2005"\w* \w voy|strong="H1980"\w* hacia el \w oriente|strong="H6924"\w*, \w no|strong="H3808"\w* está allí. \w Y|strong="H3068"\w* \w si|strong="H2005"\w* \w voy|strong="H1980"\w* al occidente, \w tampoco|strong="H3808"\w* \w lo|strong="H3808"\w* percibo.
\v 9 \w Si|strong="H3808"\w* muestra su poder en \w el|strong="H6213"\w* norte, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w veré|strong="H7200"\w*, al sur \w se|strong="H3808"\w* esconde y \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w veo|strong="H7200"\w*.
\p 
\v 10 Sin embargo, \w Él|strong="H3588"\w* \w conoce|strong="H3045"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w por|strong="H3588"\w* donde voy. \w Que|strong="H3588"\w* \w me|strong="H3588"\w* pruebe, \w y|strong="H3588"\w* \w saldré|strong="H3318"\w* \w como|strong="H3588"\w* \w oro|strong="H2091"\w*.
\v 11 Mis \w pies|strong="H7272"\w* siguieron fielmente sus huellas. \w Guardé|strong="H8104"\w* su \w camino|strong="H1870"\w* \w sin|strong="H3808"\w* apartarme.
\v 12 \w No|strong="H3808"\w* retrocedí del \w mandato|strong="H6310"\w* de sus \w labios|strong="H8193"\w*, y atesoré las \w Palabras|strong="H6310"\w* de su \w boca|strong="H6310"\w* \w más|strong="H3808"\w* \w que|strong="H3808"\w* mi ración necesaria.
\p 
\v 13 Pero \w Él|strong="H1931"\w* \w es|strong="H1931"\w* único. ¿\w Quién|strong="H4310"\w* podrá disuadirlo? \w Él|strong="H1931"\w* \w hace|strong="H6213"\w* \w lo|strong="H1931"\w* \w que|strong="H4310"\w* desea.
\v 14 \w Él|strong="H5973"\w* ejecutará \w lo|strong="H2007"\w* \w que|strong="H3588"\w* decretó \w para|strong="H3588"\w* mí, \w y|strong="H3588"\w* \w muchas|strong="H7227"\w* otras \w cosas|strong="H2007"\w* \w como|strong="H3588"\w* ésta están \w en|strong="H5973"\w* \w Él|strong="H5973"\w*.
\p 
\v 15 \w Por|strong="H5921"\w* \w lo|strong="H5921"\w* cual \w me|strong="H4480"\w* perturba su \w Presencia|strong="H6440"\w*. \w Al|strong="H5921"\w* pensarlo, \w me|strong="H4480"\w* aterrorizo \w de|strong="H4480"\w* \w Él|strong="H5921"\w*.
\v 16 Porque \nd ʼElohim\nd* hizo desmayar mi \w corazón|strong="H3820"\w*. \nd ʼEL-Shadday\nd* me aterrorizó.
\v 17 \w Pues|strong="H3588"\w* \w no|strong="H3808"\w* \w fui|strong="H3808"\w* cortado \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w presencia|strong="H6440"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* tenebrosidad, \w y|strong="H3588"\w* \w Él|strong="H3588"\w* \w no|strong="H3808"\w* escondió mi semblante \w de|strong="H3588"\w* \w la|strong="H3588"\w* profunda \w oscuridad|strong="H2822"\w*.
\c 24
\s1 Descripción horrible de la perversidad
\p 
\v 1 ¿\w Por|strong="H4069"\w* \w qué|strong="H3808"\w* \w no|strong="H3808"\w* \w son|strong="H3808"\w* reservados los \w tiempos|strong="H6256"\w* oportunos \w por|strong="H4069"\w* \nd ʼEL-Shadday\nd*? ¿\w Por|strong="H4069"\w* \w qué|strong="H3808"\w* los \w que|strong="H3808"\w* \w lo|strong="H3808"\w* \w conocen|strong="H3045"\w* \w no|strong="H3808"\w* vislumbran sus \w días|strong="H3117"\w*?
\p 
\v 2 Hay los que remueven los linderos, \w roban|strong="H1497"\w* los \w rebaños|strong="H5739"\w* y los devoran,
\v 3 se llevan el \w asno|strong="H2543"\w* de los \w huérfanos|strong="H3490"\w*, toman en prenda el \w buey|strong="H7794"\w* de la viuda,
\v 4 apartan del \w camino|strong="H1870"\w* \w a|strong="H3068"\w* los necesitados y hacen que se escondan \w todos|strong="H3162"\w* los pobres de la tierra.
\p 
\v 5 Allí están, como asnos del \w desierto|strong="H4057"\w*. \w Salen|strong="H3318"\w* \w a|strong="H3068"\w* su tarea y buscan con ansia el sustento. La región fría \w es|strong="H6467"\w* la que ofrece \w alimento|strong="H2964"\w* \w a|strong="H3068"\w* sus hijos,
\v 6 cosechan en \w campo|strong="H7704"\w* ajeno, y tienen que rebuscar en la \w viña|strong="H3754"\w* del perverso.
\v 7 Pasan la noche \w desnudos|strong="H6174"\w*, faltos de ropa y \w no|strong="H1097"\w* tienen \w cobertura|strong="H3682"\w* contra \w el|strong="H3885"\w* frío.
\v 8 El aguacero de las montañas los empapa, y se pegan \w a|strong="H3068"\w* las rocas por falta de refugio.
\p 
\v 9 Hay otros que arrancan del pecho al \w huérfano|strong="H3490"\w*, y toman en prenda al bebé del \w pobre|strong="H6041"\w*.
\v 10 Hacen que anden mudos, \w sin|strong="H1097"\w* ropa, y \w quitan|strong="H5375"\w* las gavillas al hambriento,
\v 11 los \w que|strong="H1869"\w* exprimen el aceite en sus molinos, y \w pisan|strong="H1869"\w* sus lagares, pero tienen \w sed|strong="H6770"\w*.
\v 12 Desde la \w ciudad|strong="H5892"\w* \w gimen|strong="H5008"\w* los \w hombres|strong="H4962"\w* y \w claman|strong="H7768"\w* los \w heridos|strong="H2491"\w*, pero \nd ʼElohim\nd* \w no|strong="H3808"\w* atiende sus necedades.
\p 
\v 13 \w Son|strong="H1961"\w* \w los|strong="H1992"\w* \w que|strong="H3808"\w* \w se|strong="H1961"\w* rebelan \w contra|strong="H1961"\w* la luz. \w No|strong="H3808"\w* quieren conocer \w sus|strong="H1992"\w* \w caminos|strong="H1870"\w* \w ni|strong="H3808"\w* \w están|strong="H1961"\w* en \w sus|strong="H1992"\w* sendas.
\v 14 De madrugada \w se|strong="H1961"\w* levanta el asesino, \w mata|strong="H7523"\w* al \w pobre|strong="H6041"\w* y al menesteroso, y de \w noche|strong="H3915"\w* actúa \w como|strong="H1961"\w* \w ladrón|strong="H1590"\w*.
\v 15 El adúltero espera \w la|strong="H8104"\w* llegada \w de|strong="H6440"\w* \w la|strong="H8104"\w* noche y \w se|strong="H3808"\w* dice: \w Nadie|strong="H3808"\w* me verá. \w Y|strong="H3068"\w* cubre su \w cara|strong="H6440"\w*.
\v 16 Mina las \w casas|strong="H1004"\w* en la \w oscuridad|strong="H2822"\w*. Durante el \w día|strong="H3119"\w* \w se|strong="H3045"\w* encierra. \w No|strong="H3808"\w* \w conoce|strong="H3045"\w* la luz del sol.
\v 17 \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* \w mañana|strong="H1242"\w* \w le|strong="H1242"\w* \w es|strong="H3588"\w* lo mismo \w que|strong="H3588"\w* densa oscuridad, \w porque|strong="H3588"\w* está familiarizado \w con|strong="H3588"\w* \w los|strong="H3588"\w* \w terrores|strong="H1091"\w* \w de|strong="H3588"\w* densa oscuridad.
\p 
\v 18 \w Es|strong="H1931"\w* veloz \w sobre|strong="H5921"\w* \w la|strong="H1931"\w* superficie \w del|strong="H5921"\w* \w agua|strong="H4325"\w*. \w Su|strong="H1931"\w* \w parte|strong="H2513"\w* \w es|strong="H1931"\w* maldita \w en|strong="H5921"\w* \w la|strong="H1931"\w* \w tierra|strong="H2513"\w*. \w No|strong="H3808"\w* \w volverá|strong="H6437"\w* \w por|strong="H5921"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w viñas|strong="H3754"\w*.
\v 19 \w Como|strong="H1571"\w* \w la|strong="H1571"\w* sequía \w y|strong="H1571"\w* \w el|strong="H1571"\w* calor le \w roban|strong="H1497"\w* \w el|strong="H1571"\w* \w agua|strong="H4325"\w* \w a|strong="H3068"\w* \w la|strong="H1571"\w* nieve, \w así|strong="H1571"\w* hace \w el|strong="H1571"\w* \tl Seol\tl* \w a|strong="H3068"\w* los \w que|strong="H1571"\w* \w pecaron|strong="H2398"\w*.
\v 20 Los olvidará el seno materno. Dulce \w será|strong="H7665"\w* su sabor \w a|strong="H3068"\w* los \w gusanos|strong="H7415"\w*. \w Nunca|strong="H3808"\w* \w serán|strong="H5766"\w* recordados, y \w como|strong="H5750"\w* un \w árbol|strong="H6086"\w* \w serán|strong="H5766"\w* quebrantados los perversos.
\v 21 \w Porque|strong="H3808"\w* maltrataron \w a|strong="H3068"\w* la estéril, \w a|strong="H3068"\w* la \w que|strong="H3808"\w* \w no|strong="H3808"\w* da \w a|strong="H3068"\w* luz, y \w no|strong="H3808"\w* hacen \w bien|strong="H3190"\w* \w a|strong="H3068"\w* la viuda.
\p 
\v 22 La sequía arruina también \w a|strong="H3068"\w* los \w poderosos|strong="H3581"\w* con su \w poder|strong="H3581"\w*. \w Se|strong="H3808"\w* \w levantan|strong="H6965"\w* y \w no|strong="H3808"\w* creen \w ni|strong="H3808"\w* en su propia \w vida|strong="H2416"\w*.
\v 23 \nd ʼElohim\nd* \w les|strong="H5921"\w* \w da|strong="H5414"\w* seguridad, \w y|strong="H5921"\w* \w ellos|strong="H5921"\w* confían \w en|strong="H5921"\w* \w ella|strong="H5921"\w*. \w Los|strong="H5921"\w* \w ojos|strong="H5869"\w* \w de|strong="H5921"\w* \w Él|strong="H5921"\w* observan sus \w caminos|strong="H1870"\w*.
\v 24 Aunque ensalzados por un tiempo, desaparecen. Son abatidos, marchitados como plantas y cortados como \w espigas|strong="H7641"\w*.
\p 
\v 25 \w Si|strong="H3808"\w* esto \w no|strong="H3808"\w* es así, ¿\w quién|strong="H4310"\w* \w me|strong="H4310"\w* puede probar \w que|strong="H4310"\w* soy un mentiroso, y dejar \w sin|strong="H3808"\w* valor \w mis|strong="H4405"\w* \w palabras|strong="H4405"\w*?
\c 25
\s1 Respuesta de Bildad suhita a Job
\p 
\v 1 Entonces \w Bildad|strong="H1085"\w* \w suhita|strong="H7747"\w* \w respondió|strong="H6030"\w*:
\v 2 ¡\w El|strong="H5973"\w* dominio y \w el|strong="H5973"\w* \w temor|strong="H6343"\w* son \w de|strong="H5973"\w* \nd ʼElohim\nd*, \w Quien|strong="H6213"\w* establece \w paz|strong="H7965"\w* \w en|strong="H5973"\w* sus \w alturas|strong="H4791"\w*!
\p 
\v 3 ¿\w Tienen|strong="H3426"\w* \w número|strong="H4557"\w* sus huestes? ¿\w Sobre|strong="H5921"\w* \w quién|strong="H4310"\w* \w no|strong="H3808"\w* \w está|strong="H3426"\w* su luz?
\v 4 ¿\w Cómo|strong="H4100"\w* puede \w el|strong="H5973"\w* hombre justificarse ante \nd ʼElohim\nd*? ¿\w Y|strong="H3068"\w* \w cómo|strong="H4100"\w* puede ser puro \w el|strong="H5973"\w* \w nacido|strong="H3205"\w* \w de|strong="H5973"\w* mujer?
\p 
\v 5 \w Mira|strong="H2005"\w*, \w ni|strong="H3808"\w* \w aun|strong="H5704"\w* la \w luna|strong="H3394"\w* resplandece, \w ni|strong="H3808"\w* las \w estrellas|strong="H3556"\w* \w son|strong="H3808"\w* puras ante Él.
\v 6 ¡\w Cuánto|strong="H3588"\w* \w menos|strong="H3588"\w* \w el|strong="H3588"\w* \w hombre|strong="H1121"\w* \w que|strong="H3588"\w* \w es|strong="H3588"\w* una larva, \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w hombre|strong="H1121"\w* \w que|strong="H3588"\w* \w es|strong="H3588"\w* un \w gusano|strong="H8438"\w*!
\c 26
\s1 Proclamación de la soberanía divina
\p 
\v 1 Entonces Job \w respondió|strong="H6030"\w*:
\v 2 ¡\w Qué|strong="H4100"\w* bien ayudas al débil \w y|strong="H5797"\w* socorres al \w brazo|strong="H2220"\w* \w que|strong="H4100"\w* \w no|strong="H3808"\w* tiene \w fuerza|strong="H3581"\w*!
\v 3 ¡\w Qué|strong="H4100"\w* útil discernimiento proveíste abundantemente!
\v 4 ¿\w Para|strong="H4480"\w* \w quién|strong="H4310"\w* pronunciaste tus \w palabras|strong="H4405"\w*? ¿\w El|strong="H4310"\w* espíritu \w de|strong="H4480"\w* \w quién|strong="H4310"\w* \w se|strong="H4480"\w* expresó \w por|strong="H4480"\w* medio \w de|strong="H4480"\w* \w ti|strong="H4480"\w*?
\p 
\v 5 La sombra \w de|strong="H8478"\w* los \w muertos|strong="H7496"\w* se estremece \w bajo|strong="H8478"\w* las \w aguas|strong="H4325"\w* y sus habitantes.
\v 6 El \tl Seol\tl* está \w desnudo|strong="H6174"\w* ante \nd ʼElohim\nd*, y el \tl Abadón\tl*\f + \fr 26:6 \ft \tl Seol\tl*: lugar de los muertos. \tl Abadón\tl*: lugar de perdición.\f* no tiene \w cubierta|strong="H3682"\w*.
\p 
\v 7 \w Él|strong="H5921"\w* \w extiende|strong="H5186"\w* \w el|strong="H5921"\w* \w norte|strong="H6828"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* abismo \w y|strong="H5921"\w* \w cuelga|strong="H8518"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w nada|strong="H1099"\w*.
\v 8 Encierra las \w aguas|strong="H4325"\w* \w en|strong="H8478"\w* sus \w nubes|strong="H5645"\w* y las \w nubes|strong="H5645"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* rompen con ellas.
\v 9 Encubre \w la|strong="H5921"\w* \w cara|strong="H6440"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* luna llena \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w* extiende su \w nube|strong="H6051"\w*.
\v 10 Trazó un círculo \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* superficie \w del|strong="H5921"\w* \w agua|strong="H4325"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* límite \w entre|strong="H5921"\w* \w la|strong="H5921"\w* luz \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w oscuridad|strong="H2822"\w*.
\p 
\v 11 Las \w columnas|strong="H5982"\w* del \w cielo|strong="H8064"\w* se estremecen y están pasmadas ante su reprensión.
\v 12 Aquieta el \w mar|strong="H3220"\w* con su \w poder|strong="H3581"\w*, y con su \w entendimiento|strong="H8394"\w* rompe la tormenta.
\v 13 Su \w soplo|strong="H7307"\w* despejó el \w cielo|strong="H8064"\w*, y su \w mano|strong="H3027"\w* traspasó la \w serpiente|strong="H5175"\w* cautelosa.
\p 
\v 14 \w Ciertamente|strong="H2005"\w* estos son solo los bordes \w de|strong="H1697"\w* sus \w caminos|strong="H1870"\w*. ¡\w Cuán|strong="H4100"\w* leve murmullo \w oímos|strong="H8085"\w* \w de|strong="H1697"\w* \w Él|strong="H4310"\w*! Pero \w el|strong="H4310"\w* trueno \w de|strong="H1697"\w* su poder, ¿\w quién|strong="H4310"\w* \w lo|strong="H1697"\w* puede entender?
\c 27
\s1 El castigo para los perversos
\p 
\v 1 Job prosiguió su discurso:
\v 2 ¡\w Vive|strong="H2416"\w* \nd ʼElohim\nd*, Quien \w quitó|strong="H5493"\w* \w mi|strong="H5315"\w* \w derecho|strong="H4941"\w*, y \nd ʼEL-Shadday\nd*, Quien amargó \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*,
\v 3 \w que|strong="H3588"\w* \w mientras|strong="H3588"\w* tenga aliento \w en|strong="H3588"\w* mí, \w el|strong="H3588"\w* \w hálito|strong="H7307"\w* \w de|strong="H3588"\w* \nd ʼElohim\nd* \w en|strong="H3588"\w* mis fosas nasales,
\v 4 mis \w labios|strong="H8193"\w* \w no|strong="H5766"\w* \w hablarán|strong="H1696"\w* perversidad, ni mi \w lengua|strong="H3956"\w* \w pronunciará|strong="H1897"\w* \w engaño|strong="H7423"\w*!
\p 
\v 5 \w Lejos|strong="H2486"\w* \w de|strong="H4480"\w* mí \w que|strong="H4480"\w* les \w dé|strong="H4480"\w* la razón. \w Hasta|strong="H5704"\w* \w que|strong="H4480"\w* expire \w no|strong="H3808"\w* renunciaré \w a|strong="H3068"\w* mi integridad.
\v 6 Me aferraré \w a|strong="H3068"\w* mi rectitud, y \w no|strong="H3808"\w* la soltaré. Mi \w corazón|strong="H3824"\w* \w no|strong="H3808"\w* me \w reprochará|strong="H2778"\w* en todos mis \w días|strong="H3117"\w*.
\p 
\v 7 \w Sea|strong="H1961"\w* \w mi|strong="H1961"\w* enemigo \w como|strong="H1961"\w* el perverso y \w mi|strong="H1961"\w* oponente \w como|strong="H1961"\w* el injusto.
\v 8 \w Porque|strong="H3588"\w* ¿\w cuál|strong="H4100"\w* \w es|strong="H3588"\w* \w la|strong="H3588"\w* \w esperanza|strong="H8615"\w* del impío, \w aunque|strong="H3588"\w* mucho robó, \w cuando|strong="H3588"\w* \nd ʼElohim\nd* le quite \w su|strong="H3588"\w* \w vida|strong="H5315"\w*?
\v 9 ¿\w Escuchará|strong="H8085"\w* \nd ʼElohim\nd* \w su|strong="H3588"\w* \w clamor|strong="H6818"\w* \w cuando|strong="H3588"\w* \w le|strong="H5921"\w* caiga \w la|strong="H5921"\w* \w angustia|strong="H6869"\w*?
\v 10 ¿\w Se|strong="H5921"\w* deleitó \w en|strong="H5921"\w* \nd ʼEL-Shadday\nd*? ¿Invocó \w a|strong="H3068"\w* \nd ʼElohim\nd* \w en|strong="H5921"\w* \w todo|strong="H3605"\w* \w tiempo|strong="H6256"\w*?
\p 
\v 11 \w Los|strong="H5973"\w* instruiré \w a|strong="H3068"\w* ustedes \w en|strong="H5973"\w* cuanto al \w poder|strong="H3027"\w* \w de|strong="H5973"\w* \nd ʼElohim\nd*. \w No|strong="H3808"\w* ocultaré \w lo|strong="H3808"\w* relacionado \w con|strong="H5973"\w* \nd ʼEL-Shadday\nd*.
\v 12 \w Si|strong="H2005"\w* \w todos|strong="H3605"\w* ustedes \w lo|strong="H4100"\w* observaron, ¿\w por|strong="H2088"\w* \w qué|strong="H4100"\w* entonces actúan \w como|strong="H4100"\w* necios?
\p 
\v 13 \w Esta|strong="H2088"\w* \w es|strong="H2088"\w* la \w parte|strong="H2506"\w* \w de|strong="H5973"\w* \nd ʼElohim\nd* \w para|strong="H5973"\w* \w el|strong="H5973"\w* perverso y la \w herencia|strong="H5159"\w* \w que|strong="H2088"\w* \w los|strong="H5973"\w* opresores reciben \w de|strong="H5973"\w* \nd ʼEL-Shadday\nd*:
\v 14 \w Aunque|strong="H3808"\w* sus \w hijos|strong="H1121"\w* \w se|strong="H3808"\w* multipliquen, serán para \w la|strong="H7646"\w* \w espada|strong="H2719"\w*, y sus pequeños \w no|strong="H3808"\w* tendrán suficiente \w pan|strong="H3899"\w*.
\v 15 Los \w que|strong="H3808"\w* le sobrevivan, los sepultará la pestilencia, y sus viudas \w no|strong="H3808"\w* los \w llorarán|strong="H1058"\w*.
\v 16 Aunque amontone \w plata|strong="H3701"\w* como \w polvo|strong="H6083"\w* y apile ropa como \w barro|strong="H6083"\w*,
\v 17 las amontonarás, pero el \w justo|strong="H6662"\w* las \w vestirá|strong="H3847"\w*, \w y|strong="H5355"\w* los inocentes se repartirán la \w plata|strong="H3701"\w*.
\v 18 \w Edificó|strong="H1129"\w* su \w casa|strong="H1004"\w* como la telaraña \w o|strong="H3068"\w* como enramada de guardián.
\p 
\v 19 El perverso \w se|strong="H3808"\w* acuesta \w rico|strong="H6223"\w*, pero \w no|strong="H3808"\w* volverá \w a|strong="H3068"\w* serlo. \w Abre|strong="H6491"\w* sus \w ojos|strong="H5869"\w*, y \w no|strong="H3808"\w* existe su riqueza:
\v 20 \w De|strong="H4325"\w* día lo asaltan los \w terrores|strong="H1091"\w* como \w aguas|strong="H4325"\w*, \w de|strong="H4325"\w* \w noche|strong="H3915"\w* lo arrebata la tormenta.
\v 21 Un viento del este la \w levanta|strong="H5375"\w*. La arranca de su vivienda, y se \w va|strong="H3068"\w*.
\v 22 \w Porque|strong="H5921"\w* \w se|strong="H5921"\w* lanzará \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w perdonará|strong="H2550"\w*, \w lo|strong="H5921"\w* echará \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w lo|strong="H5921"\w* \w perdonará|strong="H2550"\w*, \w aunque|strong="H3808"\w* ciertamente trate \w de|strong="H5921"\w* huir \w de|strong="H5921"\w* su \w poder|strong="H3027"\w*.
\p 
\v 23 \nd ʼElohim\nd* \add hace\add* \w que|strong="H5921"\w* \w los|strong="H5921"\w* hombres batan \w las|strong="H5921"\w* \w manos|strong="H3709"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* saquen \w de|strong="H5921"\w* su \w lugar|strong="H4725"\w* \w con|strong="H5921"\w* silbidos.
\c 28
\s1 Elogio a la sabiduría
\p 
\v 1 \w La|strong="H3588"\w* \w plata|strong="H3701"\w* \w tiene|strong="H3426"\w* sus yacimientos, \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w oro|strong="H2091"\w* un \w lugar|strong="H4725"\w* \w donde|strong="H4725"\w* refinarlo.
\v 2 Se saca el \w hierro|strong="H1270"\w* de la \w tierra|strong="H6083"\w*, y se funde el cobre de la piedra.
\v 3 \w El|strong="H1931"\w* hombre \w da|strong="H7760"\w* \w fin|strong="H7093"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w oscuridad|strong="H2822"\w* y examina \w la|strong="H1931"\w* piedra oscura y opaca \w hasta|strong="H1931"\w* \w el|strong="H1931"\w* último rincón.
\v 4 Lejos \w de|strong="H4480"\w* donde vive la gente, \w en|strong="H4480"\w* lugares donde \w el|strong="H5973"\w* \w pie|strong="H7272"\w* no pasa, abren minas. Son suspendidos y balanceados lejos \w de|strong="H4480"\w* \w los|strong="H5973"\w* demás hombres.
\v 5 La tierra \w de|strong="H4480"\w* la cual \w sale|strong="H3318"\w* el \w pan|strong="H3899"\w*, y \w por|strong="H8478"\w* \w debajo|strong="H8478"\w*, es trastornada \w como|strong="H3644"\w* \w por|strong="H8478"\w* fuego;
\v 6 es \w lugar|strong="H4725"\w* \w donde|strong="H4725"\w* hay piedras de zafiro y \w polvo|strong="H6083"\w* de \w oro|strong="H2091"\w*.
\p 
\v 7 Es una \w senda|strong="H5410"\w* \w que|strong="H3808"\w* el \w ave|strong="H5861"\w* \w de|strong="H5869"\w* rapiña \w no|strong="H3808"\w* \w conoce|strong="H3045"\w*. \w Jamás|strong="H3808"\w* la vio el \w ojo|strong="H5869"\w* del halcón.
\v 8 \w Nunca|strong="H3808"\w* \w fue|strong="H3808"\w* pisoteada \w por|strong="H5921"\w* fieras arrogantes, \w ni|strong="H3808"\w* \w pasó|strong="H5710"\w* \w por|strong="H5921"\w* allí \w el|strong="H5921"\w* \w león|strong="H7826"\w*.
\v 9 El hombre alarga su \w mano|strong="H3027"\w* sobre el pedernal y trastorna la raíz de las montañas.
\v 10 Abre canales en \w la|strong="H3605"\w* \w roca|strong="H6697"\w*, y sus \w ojos|strong="H5869"\w* \w ven|strong="H7200"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w precioso|strong="H3366"\w*.
\v 11 Detiene los ríos \w en|strong="H3318"\w* su nacimiento y hace que \w salga|strong="H3318"\w* \w a|strong="H3068"\w* la luz lo escondido.
\p 
\v 12 Pero ¿\w dónde|strong="H4725"\w* se \w halla|strong="H4672"\w* el entendimiento? ¿\w Dónde|strong="H4725"\w* \w está|strong="H2088"\w* el \w lugar|strong="H4725"\w* de \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*?
\v 13 El hombre \w no|strong="H3808"\w* \w conoce|strong="H3045"\w* el valor de ella. \w No|strong="H3808"\w* \w se|strong="H3045"\w* \w halla|strong="H4672"\w* en la tierra de los \w vivientes|strong="H2416"\w*.
\p 
\v 14 \w El|strong="H1931"\w* océano dice: \w No|strong="H3808"\w* \w está|strong="H1931"\w* en mí. \w El|strong="H1931"\w* \w mar|strong="H3220"\w* dice: \w No|strong="H3808"\w* \w está|strong="H1931"\w* \w conmigo|strong="H5978"\w*.
\p 
\v 15 \w No|strong="H3808"\w* \w se|strong="H3808"\w* puede obtener con oro fino, \w ni|strong="H3808"\w* \w por|strong="H8478"\w* su \w precio|strong="H3701"\w* \w se|strong="H3808"\w* pesa la \w plata|strong="H3701"\w*.
\v 16 \w No|strong="H3808"\w* \w se|strong="H3808"\w* puede evaluar con \w oro|strong="H3800"\w* de Ofir, \w ni|strong="H3808"\w* con ónice \w precioso|strong="H3368"\w* \w o|strong="H3068"\w* con zafiro.
\v 17 El \w oro|strong="H2091"\w* y los diamantes \w no|strong="H3808"\w* \w se|strong="H3808"\w* le igualan, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* puede pagar con objetos de \w oro|strong="H2091"\w* \w fino|strong="H6337"\w*.
\v 18 El coral y el cristal de roca \w ni|strong="H3808"\w* \w se|strong="H3808"\w* mencionen, \w porque|strong="H3808"\w* el valor de \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w* supera al de las perlas.
\v 19 El \w topacio|strong="H6357"\w* de \w Etiopía|strong="H3568"\w* \w no|strong="H3808"\w* la iguala, \w ni|strong="H3808"\w* \w podrá|strong="H3808"\w* ser evaluada en \w oro|strong="H3800"\w* \w puro|strong="H2889"\w*.
\p 
\v 20 ¿De \w dónde|strong="H4725"\w* viene \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*? ¿\w Dónde|strong="H4725"\w* \w está|strong="H2088"\w* el \w lugar|strong="H4725"\w* del entendimiento?
\v 21 Está encubierta \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* \w todo|strong="H3605"\w* \w viviente|strong="H2416"\w*, y oculta \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las \w aves|strong="H5775"\w* del \w cielo|strong="H8064"\w*.
\v 22 El \tl Abadón\tl* y la \w Muerte|strong="H4194"\w* dicen: ¡Su fama escuchamos con nuestros \w oídos|strong="H8085"\w*!
\p 
\v 23 \nd ʼElohim\nd* \w entiende|strong="H3045"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w* de \w ella|strong="H1931"\w* y \w conoce|strong="H3045"\w* \w su|strong="H1931"\w* \w lugar|strong="H4725"\w*,
\v 24 \w porque|strong="H3588"\w* contempla \w los|strong="H3605"\w* confines \w de|strong="H3588"\w* \w la|strong="H1931"\w* tierra \w y|strong="H3588"\w* \w ve|strong="H7200"\w* \w cuanto|strong="H3588"\w* hay \w debajo|strong="H8478"\w* del \w cielo|strong="H8064"\w*
\v 25 cuando da su \w peso|strong="H4948"\w* al \w viento|strong="H7307"\w* y determina la \w medida|strong="H4060"\w* \w de|strong="H4325"\w* las \w aguas|strong="H4325"\w*,
\v 26 cuando dicta una \w ley|strong="H2706"\w* para la \w lluvia|strong="H4306"\w*, y un \w camino|strong="H1870"\w* para \w truenos|strong="H6963"\w* y \w relámpagos|strong="H2385"\w*.
\p 
\v 27 \w Entonces|strong="H1571"\w* \w Él|strong="H1571"\w* \w la|strong="H1571"\w* \w vio|strong="H7200"\w*, \w la|strong="H1571"\w* declaró, \w la|strong="H1571"\w* estableció \w y|strong="H1571"\w* \w también|strong="H1571"\w* \w la|strong="H1571"\w* escudriñó,
\v 28 y dice al hombre: \w Ciertamente|strong="H2005"\w* \w el|strong="H1931"\w* \w temor|strong="H3374"\w* \w a|strong="H3068"\w* \nd ʼAdonay\nd* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w sabiduría|strong="H2451"\w*, y \w el|strong="H1931"\w* \w apartarse|strong="H5493"\w* del \w mal|strong="H7451"\w*, \w el|strong="H1931"\w* entendimiento.
\c 29
\s1 Condición anterior de Job
\p 
\v 1 Entonces Job respondió:
\v 2 \w Ojalá|strong="H4310"\w* volviera \w a|strong="H3068"\w* ser como en \w meses|strong="H3391"\w* \w pasados|strong="H6924"\w*, como en los \w días|strong="H3117"\w* \w cuando|strong="H3117"\w* \nd ʼElohim\nd* \w me|strong="H4310"\w* vigilaba,
\v 3 cuando su \w lámpara|strong="H5216"\w* estaba \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* su luz yo \w caminaba|strong="H3212"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w oscuridad|strong="H2822"\w*,
\v 4 aquellos \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* vigor \w cuando|strong="H3117"\w* \w la|strong="H5921"\w* amistad íntima \w de|strong="H5921"\w* \nd ʼElohim\nd* velaba \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* vivienda,
\v 5 cuando \nd ʼEL-Shadday\nd* \w aún|strong="H5750"\w* estaba \w conmigo|strong="H5978"\w*, y mis hijos \w alrededor|strong="H5439"\w* \w de|strong="H5750"\w* mí,
\v 6 cuando mis pasos eran lavados \w con|strong="H5978"\w* mantequilla y la \w roca|strong="H6697"\w* me derramaba \w ríos|strong="H6388"\w* de \w aceite|strong="H8081"\w*,
\v 7 cuando iba \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* ciudad \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* plaza preparaba \w mi|strong="H5921"\w* asiento.
\p 
\v 8 Los jóvenes me \w veían|strong="H7200"\w* y se escondían. Los ancianos se levantaban y permanecían \w en|strong="H5975"\w* \w pie|strong="H5975"\w*.
\v 9 Los magistrados \w detenían|strong="H6113"\w* sus \w palabras|strong="H4405"\w* y \w ponían|strong="H7760"\w* la \w mano|strong="H3709"\w* sobre sus \w bocas|strong="H6310"\w*.
\v 10 La \w voz|strong="H6963"\w* \w de|strong="H5057"\w* los nobles enmudecía y su \w lengua|strong="H3956"\w* se les pegaba al paladar.
\p 
\v 11 \w Los|strong="H3588"\w* \w oídos|strong="H8085"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w escuchaban|strong="H8085"\w* \w me|strong="H3588"\w* llamaban bienaventurado, \w y|strong="H3588"\w* \w los|strong="H3588"\w* \w ojos|strong="H5869"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* miraban daban testimonio \w a|strong="H3068"\w* mi favor.
\v 12 \w Porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w libraba|strong="H4422"\w* al \w pobre|strong="H6041"\w* \w que|strong="H3588"\w* \w clamaba|strong="H7768"\w* \w y|strong="H3588"\w* al \w huérfano|strong="H3490"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* tenía \w ayudador|strong="H5826"\w*.
\v 13 \w La|strong="H5921"\w* \w bendición|strong="H1293"\w* \w del|strong="H5921"\w* \w que|strong="H5921"\w* iba \w a|strong="H3068"\w* perecer caía \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H5921"\w* daba alegría \w al|strong="H5921"\w* \w corazón|strong="H3820"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* viuda.
\p 
\v 14 Me vestía \w de|strong="H3847"\w* rectitud y con ella me cubría. Mi \w justicia|strong="H6664"\w* era como un \w manto|strong="H4598"\w* y un turbante.
\v 15 Yo \w era|strong="H1961"\w* \w ojos|strong="H5869"\w* \w para|strong="H1961"\w* el \w ciego|strong="H5787"\w* y \w pies|strong="H7272"\w* \w para|strong="H1961"\w* el \w cojo|strong="H6455"\w*.
\v 16 Era padre de los menesterosos. Me informaba con diligencia de la \w causa|strong="H7379"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w entendía|strong="H3045"\w*.
\v 17 Rompía las quijadas del perverso y de sus \w dientes|strong="H8127"\w* arrancaba la presa.
\p 
\v 18 \w Me|strong="H5973"\w* decía: \w En|strong="H5973"\w* mi \w nido|strong="H7064"\w* \w moriré|strong="H1478"\w*, y \w como|strong="H5973"\w* la arena \w multiplicaré|strong="H7235"\w* mis \w días|strong="H3117"\w*.
\v 19 Mi raíz se extendía hacia las \w aguas|strong="H4325"\w*, y \w el|strong="H3885"\w* \w rocío|strong="H2919"\w* pernoctaba en mi ramaje.
\v 20 Mi \w honra|strong="H3519"\w* se renovaba en mí, \w y|strong="H3519"\w* mi \w arco|strong="H7198"\w* se fortalecía en mi \w mano|strong="H3027"\w*.
\p 
\v 21 Me \w escuchaban|strong="H8085"\w*, esperaban y guardaban silencio ante mi \w consejo|strong="H6098"\w*.
\v 22 \w Después|strong="H5921"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w palabra|strong="H1697"\w* \w no|strong="H3808"\w* \w replicaban|strong="H8138"\w*. \w Mi|strong="H5921"\w* razón \w destilaba|strong="H5197"\w* \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*.
\v 23 La esperaban como \w a|strong="H3068"\w* la \w lluvia|strong="H4306"\w* temprana, y abrían su \w boca|strong="H6310"\w* como \w a|strong="H3068"\w* la \w lluvia|strong="H4306"\w* \w tardía|strong="H4456"\w*.
\v 24 \w Si|strong="H3808"\w* me reía con ellos, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* creían, y \w no|strong="H3808"\w* tenían en \w menos|strong="H5307"\w* la luz \w de|strong="H6440"\w* mi semblante.
\p 
\v 25 Yo les escogía \w el|strong="H3427"\w* \w camino|strong="H1870"\w*, y me sentaba entre ellos \w como|strong="H7931"\w* su \w jefe|strong="H7218"\w*. Yo \w vivía|strong="H3427"\w* \w como|strong="H7931"\w* un \w rey|strong="H4428"\w* en medio de su tropa, \w como|strong="H7931"\w* \w el|strong="H3427"\w* \w que|strong="H1416"\w* \w consuela|strong="H5162"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w que|strong="H1416"\w* \w están|strong="H3427"\w* de duelo.
\c 30
\s1 Lamento de Job por su condición
\p 
\v 1 Pero \w ahora|strong="H6258"\w*, \w se|strong="H5921"\w* burlan \w de|strong="H4480"\w* \w mí|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H4480"\w* son \w más|strong="H4480"\w* jóvenes \w que|strong="H4480"\w* \w yo|strong="H4480"\w*, \w a|strong="H3068"\w* \w cuyos|strong="H5921"\w* antepasados \w yo|strong="H4480"\w* rehusé dejar \w con|strong="H5973"\w* \w los|strong="H5921"\w* \w perros|strong="H3611"\w* \w de|strong="H4480"\w* \w mi|strong="H5921"\w* \w rebaño|strong="H6629"\w*,
\v 2 \w pues|strong="H4100"\w* ¿\w para|strong="H5921"\w* \w qué|strong="H4100"\w* \w me|strong="H5921"\w* servía \w la|strong="H5921"\w* \w fuerza|strong="H3581"\w* \w de|strong="H5921"\w* sus \w manos|strong="H3027"\w*, \w si|strong="H1571"\w* su edad madura \w y|strong="H1571"\w* su \w vigor|strong="H3581"\w* perecieron?
\p 
\v 3 Están anémicos \w a|strong="H3068"\w* causa de la miseria y el hambre. Roen la tierra reseca y huyen \w a|strong="H3068"\w* la desolación, al lugar tenebroso y despoblado.
\v 4 Arrancan \w malvas|strong="H4408"\w* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* matorrales \w y|strong="H5921"\w* \w se|strong="H5921"\w* alimentan \w con|strong="H5921"\w* \w raíces|strong="H8328"\w* \w de|strong="H5921"\w* enebro.
\p 
\v 5 Están expulsados \w de|strong="H4480"\w* \w la|strong="H5921"\w* comunidad. \w Contra|strong="H5921"\w* \w ellos|strong="H5921"\w* gritan \w como|strong="H5921"\w* \w a|strong="H3068"\w* \w ladrones|strong="H1590"\w*.
\v 6 Viven en barrancos espantosos, en cuevas de la \w tierra|strong="H6083"\w* y en las peñas.
\v 7 Aúllan \w entre|strong="H8478"\w* los matorrales y se apiñan \w bajo|strong="H8478"\w* las \w ortigas|strong="H2738"\w*.
\v 8 Generación \w de|strong="H4480"\w* necios, generación \w sin|strong="H1097"\w* \w nombre|strong="H8034"\w*, echados \w a|strong="H3068"\w* latigazos \w de|strong="H4480"\w* esta tierra.
\p 
\v 9 ¡\w Y|strong="H3068"\w* \w ahora|strong="H6258"\w* \w soy|strong="H1961"\w* \w su|strong="H1992"\w* motivo de mofa y \w les|strong="H1992"\w* sirvo de \w refrán|strong="H4405"\w*!
\v 10 \w Me|strong="H4480"\w* repugnan y \w se|strong="H4480"\w* alejan \w de|strong="H4480"\w* mí. \w De|strong="H4480"\w* mi \w presencia|strong="H6440"\w* \w no|strong="H3808"\w* refrenan su saliva.
\p 
\v 11 \w Porque|strong="H3588"\w* \w Él|strong="H3588"\w* aflojó \w la|strong="H3588"\w* cuerda \w de|strong="H3588"\w* mi arco \w y|strong="H3588"\w* \w me|strong="H3588"\w* afligió, ellos se quitaron \w el|strong="H3588"\w* freno frente \w a|strong="H3068"\w* mí.
\v 12 \w A|strong="H3068"\w* \w mi|strong="H5921"\w* \w derecha|strong="H3225"\w* \w se|strong="H5921"\w* levanta \w el|strong="H5921"\w* populacho, enredan mis \w pies|strong="H7272"\w*, \w me|strong="H5921"\w* preparan caminos destructivos,
\v 13 desbaratan mi \w senda|strong="H5410"\w*, \w se|strong="H3808"\w* \w aprovechan|strong="H3276"\w* de mi calamidad y \w nadie|strong="H3808"\w* los restringe.
\v 14 Vienen \w como|strong="H8478"\w* abridores \w de|strong="H8478"\w* amplia brecha \add en el muro\add* y \w en|strong="H8478"\w* medio \w de|strong="H8478"\w* la ruinosa tormenta se abalanzan contra mi \w calamidad|strong="H7722"\w*.
\v 15 \w Los|strong="H5921"\w* \w terrores|strong="H1091"\w* \w me|strong="H5921"\w* asaltan \w de|strong="H5921"\w* repente, \w combatieron|strong="H7291"\w* \w mi|strong="H5921"\w* honor \w como|strong="H5921"\w* \w el|strong="H5921"\w* \w viento|strong="H7307"\w* \w y|strong="H5921"\w* \w mi|strong="H5921"\w* prosperidad desapareció \w como|strong="H5921"\w* \w nube|strong="H5645"\w*.
\p 
\v 16 \w Ahora|strong="H6258"\w* \w mi|strong="H5921"\w* \w alma|strong="H5315"\w* \w se|strong="H5921"\w* \w me|strong="H5921"\w* \w derrama|strong="H8210"\w*. \w Los|strong="H5921"\w* \w días|strong="H3117"\w* \w de|strong="H5921"\w* \w aflicción|strong="H6040"\w* \w se|strong="H5921"\w* apoderaron \w de|strong="H5921"\w* \w mí|strong="H5921"\w*.
\v 17 \w La|strong="H5921"\w* \w noche|strong="H3915"\w* \w me|strong="H5921"\w* \w taladra|strong="H5365"\w* \w los|strong="H5921"\w* \w huesos|strong="H6106"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* dolores \w que|strong="H3808"\w* \w me|strong="H5921"\w* corroen \w no|strong="H3808"\w* descansan.
\v 18 Una \w fuerza|strong="H3581"\w* poderosa desfiguró mi ropa y me aprieta como el cuello de mi abrigo.
\v 19 Me derribó en el lodo. Quedé \w como|strong="H4911"\w* el \w polvo|strong="H6083"\w* y la ceniza.
\p 
\v 20 \w Clamo|strong="H7768"\w* \w a|strong="H3068"\w* Ti, y \w no|strong="H3808"\w* me \w respondes|strong="H6030"\w*. Me presento, y Tú \w no|strong="H3808"\w* me atiendes.
\v 21 Te volviste cruel conmigo y me persigues con la fuerza de tu \w mano|strong="H3027"\w*.
\v 22 Me levantas, me haces cabalgar sobre el \w viento|strong="H7307"\w* y me deshaces en la tormenta.
\v 23 \w Porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* conduces \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w*, \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* reunión \w para|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w vivientes|strong="H2416"\w*.
\p 
\v 24 ¿\w Sin|strong="H3808"\w* embargo \w no|strong="H3808"\w* extiendes tu \w mano|strong="H3027"\w* al \w que|strong="H3808"\w* está sobre una pila de ruinas \w o|strong="H3068"\w* en su desastre, y \w por|strong="H3027"\w* tanto pide socorro?
\v 25 ¿\w No|strong="H3808"\w* \w lloré|strong="H1058"\w* por el afligido? ¿\w No|strong="H3808"\w* tuvo compasión \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* del menesteroso?
\p 
\v 26 \w Pero|strong="H3588"\w* \w cuando|strong="H3588"\w* \w esperaba|strong="H6960"\w* \w el|strong="H3588"\w* \w bien|strong="H2896"\w*, \w me|strong="H3588"\w* vino \w el|strong="H3588"\w* \w mal|strong="H7451"\w*. \w Cuando|strong="H3588"\w* \w esperaba|strong="H6960"\w* luz, \w me|strong="H3588"\w* vino oscuridad.
\p 
\v 27 Mis órganos internos \w se|strong="H3808"\w* agitan y \w no|strong="H3808"\w* \w reposan|strong="H1826"\w*. Me confrontan \w días|strong="H3117"\w* de \w aflicción|strong="H6040"\w*.
\v 28 \w Ando|strong="H1980"\w* ennegrecido, y \w no|strong="H3808"\w* por el sol. Me \w levanto|strong="H6965"\w* en la \w congregación|strong="H6951"\w* y pido ayuda.
\v 29 \w Soy|strong="H1961"\w* hermano de chacales y \w compañero|strong="H7453"\w* de avestruces.
\v 30 \w Mi|strong="H5921"\w* \w piel|strong="H5785"\w* ennegrecida \w se|strong="H5921"\w* \w me|strong="H4480"\w* cae, \w y|strong="H5921"\w* mis \w huesos|strong="H6106"\w* arden \w de|strong="H4480"\w* calor.
\p 
\v 31 Por tanto, \w mi|strong="H1961"\w* \w arpa|strong="H3658"\w* \w se|strong="H1961"\w* convirtió en lamento, y \w mi|strong="H1961"\w* flauta \w es|strong="H1961"\w* la \w voz|strong="H6963"\w* de \w los|strong="H1961"\w* \w que|strong="H1961"\w* \w lloran|strong="H1058"\w*.
\c 31
\s1 Reafirmación de su integridad por parte de Job
\p 
\v 1 \w Hice|strong="H3772"\w* un \w pacto|strong="H1285"\w* \w con|strong="H5921"\w* mis \w ojos|strong="H5869"\w*. ¿\w Cómo|strong="H4100"\w* podría entonces fijar \w mi|strong="H5921"\w* mirada \w en|strong="H5921"\w* una doncella?
\v 2 ¿\w Cuál|strong="H4100"\w* sería la recompensa de \nd ʼEloah\nd* desde \w arriba|strong="H4605"\w* \w o|strong="H3068"\w* la \w herencia|strong="H5159"\w* de \nd ʼEL-Shadday\nd* desde las \w alturas|strong="H4791"\w*?
\v 3 ¿\w No|strong="H3808"\w* es la calamidad para el perverso, y el desastre para los \w que|strong="H3808"\w* obran \w iniquidad|strong="H5767"\w*?
\v 4 ¿\w No|strong="H3808"\w* observa \w Él|strong="H1931"\w* mis \w caminos|strong="H1870"\w* y \w cuenta|strong="H5608"\w* \w todos|strong="H3605"\w* mis \w pasos|strong="H6806"\w*?
\p 
\v 5 \w Si|strong="H5921"\w* \w anduve|strong="H1980"\w* \w con|strong="H5973"\w* \w vanidad|strong="H7723"\w* \w y|strong="H5921"\w* \w mi|strong="H5921"\w* \w pie|strong="H7272"\w* \w se|strong="H5921"\w* apresuró \w al|strong="H5921"\w* \w engaño|strong="H4820"\w*,
\v 6 sea yo pesado en balanza justa, y conozca \nd ʼEloah\nd* \w a|strong="H3068"\w* mi integridad.
\v 7 Si mi paso \w se|strong="H4480"\w* apartó \w del|strong="H4480"\w* \w camino|strong="H1870"\w*, mi \w corazón|strong="H3820"\w* \w se|strong="H4480"\w* \w fue|strong="H1980"\w* tras mis \w ojos|strong="H5869"\w* \w o|strong="H3068"\w* si alguna \w mancha|strong="H3971"\w* \w se|strong="H4480"\w* pegó \w a|strong="H3068"\w* mis \w manos|strong="H3709"\w*,
\v 8 \w siembre|strong="H2232"\w* yo y coma otro. Sea arrancada mi cosecha.
\p 
\v 9 \w Si|strong="H5921"\w* \w mi|strong="H5921"\w* \w corazón|strong="H3820"\w* fue seducido \w por|strong="H5921"\w* una mujer \w y|strong="H5921"\w* aceché \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w prójimo|strong="H7453"\w*,
\v 10 \w muela|strong="H2912"\w* \w mi|strong="H5921"\w* esposa \w para|strong="H5921"\w* otro \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w* \w se|strong="H5921"\w* encorven otros.
\v 11 \w Porque|strong="H3588"\w* \w eso|strong="H1931"\w* sería una lujuriosa perversidad \w y|strong="H3588"\w* una \w iniquidad|strong="H5771"\w* castigada \w por|strong="H3588"\w* \w los|strong="H3588"\w* \w jueces|strong="H6414"\w*,
\v 12 un fuego \w que|strong="H3588"\w* consume \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* \tl Abadón\tl*, \w que|strong="H3588"\w* arrancaría \w toda|strong="H3605"\w* mi hacienda.
\p 
\v 13 Si menosprecié el \w derecho|strong="H4941"\w* de mi esclavo \w o|strong="H3068"\w* de mi esclava, \w cuando|strong="H5650"\w* ellos tenían una queja contra mí,
\v 14 ¿\w qué|strong="H3588"\w* \w haré|strong="H6213"\w* \w cuando|strong="H3588"\w* \nd \w ʼEL|strong="H3588"\w*\nd* \w me|strong="H3588"\w* levante? ¿\w Qué|strong="H3588"\w* le responderé \w cuando|strong="H3588"\w* \w me|strong="H3588"\w* llame \w a|strong="H3068"\w* cuentas?
\v 15 \w El|strong="H6213"\w* \w que|strong="H3808"\w* me \w formó|strong="H6213"\w* en \w el|strong="H6213"\w* vientre, ¿\w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w formó|strong="H6213"\w* también \w a|strong="H3068"\w* \w él|strong="H6213"\w*? ¿\w No|strong="H3808"\w* nos \w formó|strong="H6213"\w* \w el|strong="H6213"\w* mismo en la \w matriz|strong="H7358"\w*?
\p 
\v 16 Si \w estorbé|strong="H4513"\w* el anhelo \w de|strong="H5869"\w* los \w pobres|strong="H1800"\w* \w o|strong="H3068"\w* hice desfallecer los \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* la viuda,
\v 17 \w o|strong="H3068"\w* comí mi bocado \w a|strong="H3068"\w* solas y el \w huérfano|strong="H3490"\w* \w no|strong="H3808"\w* comió \w de|strong="H4480"\w* él,
\v 18 \w aunque|strong="H3588"\w* desde \w mi|strong="H1431"\w* \w juventud|strong="H5271"\w* \w creció|strong="H1431"\w* conmigo \w como|strong="H3588"\w* \w con|strong="H3588"\w* un padre \w y|strong="H3588"\w* lo guié desde \w el|strong="H3588"\w* seno materno,
\v 19 si \w vi|strong="H7200"\w* \w a|strong="H3068"\w* algún vagabundo \w sin|strong="H1097"\w* ropas \w o|strong="H3068"\w* algún menesteroso \w sin|strong="H1097"\w* algo con lo cual cubrirse,
\v 20 y sus órganos internos \w no|strong="H3808"\w* me \w bendijeron|strong="H1288"\w* al calentarse con el vellón de mis ovejas,
\v 21 \w si|strong="H3588"\w* alcé \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w huérfano|strong="H3490"\w* \w cuando|strong="H3588"\w* \w me|strong="H5921"\w* \w vi|strong="H7200"\w* apoyado \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w*,
\v 22 despréndase mi \w brazo|strong="H7070"\w* del \w hombro|strong="H3802"\w* y descoyúntese mi \w brazo|strong="H7070"\w* de su hueso.
\v 23 \w Porque|strong="H3588"\w* temo \w el|strong="H3588"\w* castigo \w de|strong="H3588"\w* \nd \w ʼEL|strong="H3588"\w*\nd*, \w pues|strong="H3588"\w* ante \w su|strong="H3588"\w* majestad \w nada|strong="H3808"\w* \w puedo|strong="H3201"\w* hacer.
\p 
\v 24 Si fijé mi \w confianza|strong="H4009"\w* en el \w oro|strong="H2091"\w* y al metal precioso dije: Tú eres mi \w esperanza|strong="H4009"\w*,
\v 25 \w si|strong="H3588"\w* \w me|strong="H3588"\w* complací \w por|strong="H3588"\w* mis \w grandes|strong="H7227"\w* \w riquezas|strong="H2428"\w* \w y|strong="H3588"\w* \w porque|strong="H3588"\w* mi \w mano|strong="H3027"\w* ganó \w mucho|strong="H7227"\w*,
\v 26 \w si|strong="H3588"\w* \w miré|strong="H7200"\w* al sol resplandeciente \w o|strong="H3068"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w luna|strong="H3394"\w* \w que|strong="H3588"\w* se desplazaba \w en|strong="H3588"\w* \w su|strong="H3588"\w* esplendor,
\v 27 si mi \w corazón|strong="H3820"\w* fue seducido en secreto y mi \w boca|strong="H6310"\w* les envió un \w beso|strong="H5401"\w* con la \w mano|strong="H3027"\w*,
\v 28 \w también|strong="H1571"\w* sería \w iniquidad|strong="H5771"\w* digna \w de|strong="H3588"\w* castigo, \w por|strong="H3588"\w* negar al \nd \w ʼEL|strong="H1931"\w*\nd* \w que|strong="H3588"\w* \w está|strong="H1931"\w* \w en|strong="H3588"\w* \w lo|strong="H1931"\w* \w alto|strong="H4605"\w*.
\p 
\v 29 ¿\w Me|strong="H3588"\w* alegré \w de|strong="H3588"\w* \w la|strong="H3588"\w* ruina del \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w aborrecía|strong="H8130"\w* \w o|strong="H3068"\w* salté \w de|strong="H3588"\w* júbilo \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w mal|strong="H7451"\w* cayó sobre \w él|strong="H3588"\w*?
\v 30 ¡\w No|strong="H3808"\w*! \w Nunca|strong="H3808"\w* dejé \w que|strong="H3808"\w* \w mi|strong="H5315"\w* boca pecara, \w ni|strong="H3808"\w* al maldecir al enemigo, \w ni|strong="H3808"\w* al hacer una imprecación \w para|strong="H5414"\w* \w que|strong="H3808"\w* muriera.
\v 31 Decían los esclavos \w de|strong="H5414"\w* mi casa: ¿\w Quién|strong="H4310"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* sació con su \w carne|strong="H1320"\w*?
\v 32 \w El|strong="H3885"\w* forastero \w no|strong="H3808"\w* pasaba la noche en la calle. Yo \w abría|strong="H6605"\w* mis \w puertas|strong="H1817"\w* al viajero.
\v 33 Si \w encubrí|strong="H3680"\w* mis transgresiones \w como|strong="H2934"\w* Adán y oculté la \w iniquidad|strong="H5771"\w* en mi seno
\v 34 \w por|strong="H3588"\w* temor \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w muchedumbre|strong="H1995"\w*, \w o|strong="H3068"\w* \w porque|strong="H3588"\w* \w el|strong="H3588"\w* desprecio \w de|strong="H3588"\w* \w la|strong="H3588"\w* gente \w me|strong="H3588"\w* intimidó \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w salí|strong="H3318"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w puerta|strong="H6607"\w*.
\p 
\v 35 ¡\w Ojalá|strong="H4310"\w* \w me|strong="H4310"\w* \w escuchara|strong="H8085"\w*! ¡\w Ciertamente|strong="H2005"\w* \w aquí|strong="H2005"\w* \w está|strong="H3789"\w* \w mi|strong="H6030"\w* firma! ¡\w Que|strong="H4310"\w* \nd ʼEL-Shadday\nd* \w me|strong="H4310"\w* \w responda|strong="H6030"\w*!
\v 36 Ciertamente \w lo|strong="H3808"\w* llevaría \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w hombro|strong="H7926"\w* \w y|strong="H5921"\w* \w me|strong="H5921"\w* \w lo|strong="H3808"\w* ataría \w a|strong="H3068"\w* \w la|strong="H5921"\w* cabeza \w como|strong="H5921"\w* una \w corona|strong="H5850"\w*.
\v 37 Le rendiría \w cuenta|strong="H4557"\w* \w de|strong="H5057"\w* \w todos|strong="H4557"\w* mis \w pasos|strong="H6806"\w*, y \w como|strong="H3644"\w* \w a|strong="H3068"\w* un \w príncipe|strong="H5057"\w* me acercaría ante Él.
\p 
\v 38 \w Si|strong="H5921"\w* \w mi|strong="H5921"\w* tierra \w clama|strong="H2199"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w lloran|strong="H1058"\w* sus surcos \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ella|strong="H5921"\w*,
\v 39 \w si|strong="H5315"\w* comí su fruto \w sin|strong="H1097"\w* pagar \w o|strong="H3068"\w* afligí \w a|strong="H3068"\w* sus labradores,
\v 40 crezcan \w abrojos|strong="H2336"\w* \w en|strong="H3318"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* \w trigo|strong="H2406"\w* y cizaña \w en|strong="H3318"\w* vez \w de|strong="H8478"\w* \w cebada|strong="H8184"\w*.
\p Aquí terminan las \w palabras|strong="H1697"\w* \w de|strong="H8478"\w* Job.
\c 32
\s1 Intervención de Eliú buzita
\p 
\v 1 Aquellos \w tres|strong="H7969"\w* hombres \w cesaron|strong="H7673"\w* \w de|strong="H3588"\w* replicar \w a|strong="H3068"\w* Job, \w porque|strong="H3588"\w* \w él|strong="H1931"\w* \w era|strong="H1931"\w* \w justo|strong="H6662"\w* ante \w sus|strong="H1931"\w* propios \w ojos|strong="H5869"\w*.
\v 2 Entonces Eliú, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Baraquel, buzita, \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w familia|strong="H4940"\w* \w de|strong="H5921"\w* \w Ram|strong="H7410"\w*, \w se|strong="H5921"\w* encendió \w en|strong="H5921"\w* ira \w contra|strong="H5921"\w* Job, \w porque|strong="H5921"\w* \w él|strong="H5921"\w* \w se|strong="H5921"\w* justificaba \w a|strong="H3068"\w* \w sí|strong="H5921"\w* mismo \w delante|strong="H5921"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd*.
\v 3 También \w se|strong="H5921"\w* enardeció \w contra|strong="H5921"\w* sus \w tres|strong="H7969"\w* \w amigos|strong="H7453"\w*, \w porque|strong="H5921"\w* \w no|strong="H3808"\w* \w hallaron|strong="H4672"\w* \w respuesta|strong="H4617"\w*, \w sin|strong="H3808"\w* embargo condenaron \w a|strong="H3068"\w* Job.
\p 
\v 4 Eliú esperó \w en|strong="H4480"\w* \w la|strong="H3588"\w* disputa \w con|strong="H4480"\w* Job, \w porque|strong="H3588"\w* \w ellos|strong="H1992"\w* eran mayores \w que|strong="H3588"\w* \w él|strong="H3588"\w*.
\v 5 \w Pero|strong="H3588"\w* al \w ver|strong="H7200"\w* Eliú \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w había|strong="H3588"\w* \w respuesta|strong="H4617"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* \w boca|strong="H6310"\w* \w de|strong="H3588"\w* aquellos \w tres|strong="H7969"\w* hombres, se encendió \w en|strong="H3588"\w* ira.
\p 
\v 6 Eliú tomó \w la|strong="H5921"\w* palabra, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Baraquel, buzita: Yo soy \w menor|strong="H6810"\w* \w y|strong="H5921"\w* ustedes son ancianos. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w me|strong="H5921"\w* abstuve \w y|strong="H5921"\w* \w temí|strong="H3372"\w* declararles \w mi|strong="H5921"\w* \w opinión|strong="H1843"\w*.
\v 7 Yo pensé: \w La|strong="H2451"\w* \w edad|strong="H3117"\w* debe \w hablar|strong="H1696"\w*. El número de \w años|strong="H8141"\w* debe enseñar \w sabiduría|strong="H2451"\w*.
\v 8 Pero \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w le|strong="H1931"\w* da entendimiento \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w espíritu|strong="H7307"\w* en \w el|strong="H1931"\w* hombre, \w el|strong="H1931"\w* \w soplo|strong="H7307"\w* del \nd ʼEL-Shadday\nd*.
\v 9 \w No|strong="H3808"\w* \w son|strong="H3808"\w* sabios los de \w mucha|strong="H7227"\w* edad, \w ni|strong="H3808"\w* los \w ancianos|strong="H2205"\w* entienden \w justicia|strong="H4941"\w*.
\v 10 \w Por|strong="H3651"\w* \w eso|strong="H3651"\w* digo: ¡Escúchenme! \w También|strong="H3651"\w* yo \w declararé|strong="H2331"\w* lo que pienso.
\p 
\v 11 \w Ciertamente|strong="H2005"\w* \w esperé|strong="H3176"\w* sus \w palabras|strong="H1697"\w*, escuché sus \w razones|strong="H4405"\w* \w mientras|strong="H5704"\w* buscaban \w qué|strong="H5704"\w* decir.
\v 12 Les presté atención. \w Ciertamente|strong="H2009"\w* no hay alguno \w de|strong="H4480"\w* ustedes \w que|strong="H4480"\w* redarguya \w a|strong="H3068"\w* Job \w y|strong="H5704"\w* \w responda|strong="H6030"\w* sus razonamientos.
\v 13 \w No|strong="H3808"\w* digan: \w Hallamos|strong="H4672"\w* \w la|strong="H2451"\w* \w sabiduría|strong="H2451"\w*. \nd ʼElohim\nd* \w lo|strong="H3808"\w* derrotará de manera aplastante, \w no|strong="H3808"\w* el hombre.
\v 14 Él \w no|strong="H3808"\w* dirigió sus \w palabras|strong="H4405"\w* contra mí, \w ni|strong="H3808"\w* yo le responderé con las \w palabras|strong="H4405"\w* de ustedes.
\p 
\v 15 \w Se|strong="H3808"\w* desconcertaron, ya \w no|strong="H3808"\w* responden. \w Sus|strong="H1992"\w* \w palabras|strong="H4405"\w* \w los|strong="H1992"\w* abandonaron.
\v 16 ¿Debo \w esperar|strong="H3176"\w* \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w hablan|strong="H1696"\w*, \w porque|strong="H3588"\w* cesaron \w y|strong="H3588"\w* ya \w no|strong="H3808"\w* responden?
\v 17 Yo también \w responderé|strong="H6030"\w* \w mi|strong="H6030"\w* \w parte|strong="H2506"\w*. Yo también expresaré \w mi|strong="H6030"\w* \w opinión|strong="H1843"\w*,
\v 18 \w porque|strong="H3588"\w* estoy \w lleno|strong="H4390"\w* \w de|strong="H3588"\w* \w palabras|strong="H4405"\w*, \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w espíritu|strong="H7307"\w* \w me|strong="H3588"\w* obliga dentro \w de|strong="H3588"\w* mí.
\p 
\v 19 \w Ciertamente|strong="H2009"\w* mis órganos internos \w son|strong="H3808"\w* como \w vino|strong="H3196"\w* \w sin|strong="H3808"\w* respiradero y \w están|strong="H2009"\w* \w a|strong="H3068"\w* punto de reventar como odres \w nuevos|strong="H2319"\w*.
\v 20 \w Hablaré|strong="H1696"\w* y me desahogaré. \w Abriré|strong="H6605"\w* \w mi|strong="H6030"\w* \w boca|strong="H8193"\w* y \w responderé|strong="H6030"\w*.
\v 21 \w No|strong="H3808"\w* haré \w ahora|strong="H4994"\w* \w acepción|strong="H5375"\w* \w de|strong="H6440"\w* personas, \w ni|strong="H3808"\w* me permitiré adular \w a|strong="H3068"\w* algún hombre,
\v 22 \w porque|strong="H3588"\w* \w nunca|strong="H3808"\w* \w supe|strong="H3045"\w* adular. \w De|strong="H3588"\w* \w otra|strong="H6213"\w* manera, \w mi|strong="H5375"\w* \w Hacedor|strong="H6213"\w* pronto \w me|strong="H3588"\w* consumiría.
\c 33
\s1 Censura de Eliú a Job
\p 
\v 1 Sin embargo, Job, \w escucha|strong="H8085"\w* \w ahora|strong="H4994"\w* \w mis|strong="H4405"\w* \w razones|strong="H4405"\w* y atiende \w todas|strong="H3605"\w* \w mis|strong="H4405"\w* \w palabras|strong="H1697"\w*.
\v 2 \w Ciertamente|strong="H2009"\w* \w ahora|strong="H4994"\w* \w abro|strong="H6605"\w* \w mi|strong="H2009"\w* \w boca|strong="H6310"\w*. \w Mi|strong="H2009"\w* \w lengua|strong="H3956"\w* \w habla|strong="H1696"\w* en \w mi|strong="H2009"\w* paladar.
\v 3 Mis palabras declararán la rectitud de mi \w corazón|strong="H3820"\w* y lo que saben mis \w labios|strong="H8193"\w* lo dicen con sinceridad:
\v 4 \w El|strong="H6213"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5397"\w* \nd ʼElohim\nd* me \w hizo|strong="H6213"\w* y \w el|strong="H6213"\w* \w soplo|strong="H7307"\w* \w de|strong="H5397"\w* \nd ʼEL-Shadday\nd* me dio \w vida|strong="H2421"\w*.
\v 5 \w Respóndeme|strong="H7725"\w* \w si|strong="H6440"\w* \w puedes|strong="H3201"\w*. Alístate y \w ponte|strong="H3320"\w* en pie \w ante|strong="H6440"\w* mí.
\v 6 \w Ciertamente|strong="H1571"\w* pertenezco \w a|strong="H3068"\w* \nd \w ʼEL|strong="H1571"\w*\nd*, \w como|strong="H1571"\w* tú. Del \w barro|strong="H2563"\w* \w también|strong="H1571"\w* fui \w formado|strong="H7169"\w*.
\v 7 \w Ciertamente|strong="H2009"\w* \w mi|strong="H5921"\w* terror \w no|strong="H3808"\w* \w te|strong="H5921"\w* \w espantará|strong="H1204"\w*, \w ni|strong="H3808"\w* \w mi|strong="H5921"\w* mano \w será|strong="H3808"\w* demasiado pesada \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*.
\p 
\v 8 En verdad tú dijiste \w a|strong="H3068"\w* \w oídos|strong="H8085"\w* míos. Yo \w oí|strong="H8085"\w* el \w sonido|strong="H6963"\w* de tus \w palabras|strong="H4405"\w*:
\v 9 \w Limpio|strong="H2134"\w* soy, \w sin|strong="H3808"\w* transgresión. Soy inocente y \w no|strong="H3808"\w* hay culpa en mí.
\v 10 \w Ciertamente|strong="H2005"\w* \w Él|strong="H5921"\w* inventa pretextos \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w me|strong="H5921"\w* considera su enemigo.
\v 11 \w Puso|strong="H7760"\w* mis \w pies|strong="H7272"\w* en \w el|strong="H3605"\w* cepo y vigila \w todos|strong="H3605"\w* mis pasos.
\p 
\v 12 \w Ciertamente|strong="H3588"\w* \w yo|strong="H3588"\w* \w te|strong="H3588"\w* respondo: \w En|strong="H3588"\w* \w esto|strong="H2063"\w* \w no|strong="H3808"\w* eres justo, \w porque|strong="H3588"\w* \nd ʼElohim\nd* \w es|strong="H3588"\w* \w mayor|strong="H3588"\w* \w que|strong="H3588"\w* \w el|strong="H3588"\w* hombre.
\v 13 ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* contiendes \w con|strong="H3588"\w* \nd \w ʼEL|strong="H3588"\w*\nd*? \w Pues|strong="H3588"\w* \w Él|strong="H3588"\w* \w no|strong="H3808"\w* da \w cuenta|strong="H1697"\w* \w de|strong="H3588"\w* \w ninguna|strong="H3605"\w* \w de|strong="H3588"\w* sus obras.
\v 14 \w Porque|strong="H3588"\w* \nd ʼElohim\nd* \w habla|strong="H1696"\w* \w de|strong="H3588"\w* una manera \w o|strong="H3068"\w* \w de|strong="H3588"\w* otra, \w pero|strong="H3588"\w* \w nadie|strong="H3808"\w* \w lo|strong="H3808"\w* percibe:
\v 15 \w En|strong="H5921"\w* \w sueño|strong="H2472"\w*, \w en|strong="H5921"\w* \w visión|strong="H2384"\w* \w nocturna|strong="H3915"\w*, cuando \w el|strong="H5921"\w* sopor \w cae|strong="H5307"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* hombres, mientras \w se|strong="H5921"\w* adormecen \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cama|strong="H4904"\w*,
\v 16 Él \w abre|strong="H1540"\w* el oído de los hombres y \w sella|strong="H2856"\w* su instrucción para ellos,
\v 17 \w a|strong="H3068"\w* fin de apartar al \w hombre|strong="H1397"\w* de su \w obra|strong="H4639"\w* y destruir la \w soberbia|strong="H1466"\w* del \w varón|strong="H1397"\w*,
\v 18 \w para|strong="H4480"\w* librar su \w alma|strong="H5315"\w* \w del|strong="H4480"\w* \w sepulcro|strong="H7845"\w* y \w que|strong="H4480"\w* su \w vida|strong="H5315"\w* no perezca \w a|strong="H3068"\w* filo \w de|strong="H4480"\w* espada.
\p 
\v 19 También \w sobre|strong="H5921"\w* su \w cama|strong="H4904"\w* es reprendido \w con|strong="H5921"\w* \w dolores|strong="H4341"\w*, \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w dolor|strong="H4341"\w* incesante \w de|strong="H5921"\w* sus \w huesos|strong="H6106"\w*,
\v 20 lo \w cual|strong="H5315"\w* hace que le repugne el \w pan|strong="H3899"\w*, y aun el \w manjar|strong="H3899"\w* \w más|strong="H3899"\w* delicado.
\v 21 Su \w carne|strong="H1320"\w* \w se|strong="H3808"\w* consume hasta \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w ve|strong="H7200"\w*, y sus \w huesos|strong="H6106"\w*, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w veían|strong="H7200"\w*, \w aparecen|strong="H7200"\w*.
\v 22 Su \w alma|strong="H5315"\w* se acerca al \w sepulcro|strong="H7845"\w* y su \w vida|strong="H5315"\w* \w a|strong="H3068"\w* los que causan la \w muerte|strong="H4191"\w*.
\v 23 \w Si|strong="H5921"\w* \w hay|strong="H3426"\w* un \w ángel|strong="H4397"\w* \w que|strong="H4480"\w* sea mediador \w para|strong="H5921"\w* \w él|strong="H5921"\w*, muy escogido \w entre|strong="H5921"\w* 1.000, \w que|strong="H4480"\w* recuerda \w al|strong="H5921"\w* hombre \w lo|strong="H5921"\w* correcto \w para|strong="H5921"\w* \w él|strong="H5921"\w*,
\v 24 tenga \w compasión|strong="H2603"\w* de él y diga: Líbrenlo de bajar al \w sepulcro|strong="H7845"\w*, \w pues|strong="H3381"\w* le \w hallé|strong="H4672"\w* un \w rescate|strong="H3724"\w*.
\v 25 \w Entonces|strong="H3117"\w* su \w carne|strong="H1320"\w* sería más tierna \w que|strong="H3117"\w* la de un joven \w que|strong="H3117"\w* \w vuelve|strong="H7725"\w* al vigor de los \w días|strong="H3117"\w* de su juventud.
\v 26 Invocaría \w a|strong="H3068"\w* \nd ʼEloha\nd*. Él le haría sacrificio que apacigua, para que \w vea|strong="H7200"\w* el semblante \w de|strong="H6440"\w* \nd ʼEL\nd* con gozo y Él le restaure su \w justicia|strong="H6666"\w* al hombre.
\v 27 \w Él|strong="H5921"\w* mira \w a|strong="H3068"\w* \w los|strong="H5921"\w* hombres \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w que|strong="H3808"\w* dice: \w Pequé|strong="H2398"\w* \w y|strong="H5921"\w* pervertí \w lo|strong="H3808"\w* \w recto|strong="H3477"\w*, pero \w nada|strong="H3808"\w* \w me|strong="H5921"\w* aprovechó,
\v 28 \w Él|strong="H5674"\w* le \w redimirá|strong="H6299"\w* su \w alma|strong="H5315"\w* para que no baje al \w sepulcro|strong="H7845"\w*, y su \w vida|strong="H5315"\w* \w verá|strong="H7200"\w* la luz.
\p 
\v 29 \w En|strong="H5973"\w* verdad \nd \w ʼEL|strong="H5973"\w*\nd* hace \w todas|strong="H3605"\w* estas cosas \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w hombre|strong="H1397"\w* \w dos|strong="H6471"\w* \w veces|strong="H6471"\w*, y aun \w tres|strong="H7969"\w*,
\v 30 \w para|strong="H4480"\w* rescatar su \w alma|strong="H5315"\w* \w del|strong="H4480"\w* \w sepulcro|strong="H7845"\w* \w e|strong="H3068"\w* iluminarlo \w con|strong="H4480"\w* la luz \w de|strong="H4480"\w* la \w vida|strong="H5315"\w*.
\p 
\v 31 Presta atención, Job, \w escúchame|strong="H8085"\w*. \w Calla|strong="H2790"\w*, y permíteme \w hablar|strong="H1696"\w*.
\v 32 \w Si|strong="H3588"\w* \w tienes|strong="H3426"\w* \w palabras|strong="H1696"\w*, \w respóndeme|strong="H7725"\w*. \w Habla|strong="H1696"\w*, \w porque|strong="H3588"\w* \w yo|strong="H3588"\w* \w quiero|strong="H2654"\w* declararte justo.
\v 33 Si no, \w escúchame|strong="H8085"\w*. \w Calla|strong="H2790"\w*, y yo te enseñaré \w sabiduría|strong="H2451"\w*.
\c 34
\s1 Palabras de Eliú a favor de \nd ʼElohim\nd*
\p 
\v 1 Eliú continuó:
\v 2 \w Escuchen|strong="H8085"\w*, oh \w sabios|strong="H2450"\w*, \w mis|strong="H4405"\w* \w palabras|strong="H4405"\w*, y ustedes, \w los|strong="H2450"\w* \w que|strong="H3045"\w* \w saben|strong="H3045"\w*, escúchenme.
\v 3 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* oído distingue las \w palabras|strong="H4405"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* paladar prueba \w el|strong="H3588"\w* alimento.
\v 4 Escojamos \w lo|strong="H4100"\w* \w que|strong="H4100"\w* es recto y \w sepamos|strong="H3045"\w* entre nosotros \w lo|strong="H4100"\w* \w que|strong="H4100"\w* es \w bueno|strong="H2896"\w*.
\p 
\v 5 \w Porque|strong="H3588"\w* Job dijo: \w Yo|strong="H3588"\w* soy justo. \nd \w ʼEL|strong="H3588"\w*\nd* \w me|strong="H3588"\w* \w quitó|strong="H5493"\w* mi \w derecho|strong="H4941"\w*.
\v 6 ¿Debo mentir \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w derecho|strong="H4941"\w*? Aunque \w no|strong="H1097"\w* cometí transgresión, \w mi|strong="H5921"\w* herida es incurable.
\v 7 ¿\w Quién|strong="H4310"\w* \w hay|strong="H4310"\w* como Job, \w quien|strong="H4310"\w* \w bebe|strong="H8354"\w* \w el|strong="H4310"\w* desprecio como \w agua|strong="H4325"\w*,
\v 8 quien se \w va|strong="H3068"\w* \w en|strong="H5973"\w* compañía \w con|strong="H5973"\w* \w los|strong="H5973"\w* transgresores y camina \w con|strong="H5973"\w* \w los|strong="H5973"\w* perversos?
\v 9 \w Pues|strong="H3588"\w* afirma: \w De|strong="H3588"\w* \w nada|strong="H3808"\w* \w le|strong="H5973"\w* sirve al \w hombre|strong="H1397"\w* deleitarse \w en|strong="H5973"\w* \nd ʼElohim\nd*.
\p 
\v 10 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, hombres cuerdos, escúchenme: ¡\w Lejos|strong="H2486"\w* esté de \nd ʼElohim\nd* la perversidad, y de \nd ʼEL-Shadday\nd* la injusticia!
\v 11 \w Porque|strong="H3588"\w* \w Él|strong="H3588"\w* \w paga|strong="H7999"\w* al hombre según sus \w obras|strong="H6467"\w* \w y|strong="H3588"\w* hace \w que|strong="H3588"\w* cada uno \w halle|strong="H4672"\w* según \w su|strong="H3588"\w* camino.
\v 12 Ciertamente \nd ʼElohim\nd* \w no|strong="H3808"\w* obra perversamente, \w ni|strong="H3808"\w* \nd ʼEL-Shadday\nd* pervierte la \w justicia|strong="H4941"\w*.
\p 
\v 13 ¿\w Quién|strong="H4310"\w* \w le|strong="H5921"\w* \w dio|strong="H7760"\w* autoridad \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra? ¿\w Quién|strong="H4310"\w* \w le|strong="H5921"\w* confió \w todo|strong="H3605"\w* \w el|strong="H5921"\w* universo?
\v 14 Si Él determina hacer así, retirar para Sí mismo su \w Espíritu|strong="H7307"\w* y su aliento,
\v 15 \w toda|strong="H3605"\w* \w carne|strong="H1320"\w* \w perecería|strong="H1478"\w* \w juntamente|strong="H3162"\w*, \w y|strong="H5921"\w* \w el|strong="H5921"\w* hombre volvería \w al|strong="H5921"\w* \w polvo|strong="H6083"\w*.
\p 
\v 16 Si tienes entendimiento, \w escucha|strong="H8085"\w* \w esto|strong="H2063"\w*, \w escucha|strong="H8085"\w* el \w sonido|strong="H6963"\w* de \w mis|strong="H4405"\w* \w palabras|strong="H4405"\w*:
\v 17 ¿Gobernará el que \w aborrece|strong="H8130"\w* la \w justicia|strong="H4941"\w*? ¿Te atreves \w a|strong="H3068"\w* condenar al \w Justo|strong="H6662"\w* poderoso,
\v 18 \w a|strong="H3068"\w* Aquél que declara \w a|strong="H3068"\w* un \w rey|strong="H4428"\w* inútil y perversos \w a|strong="H3068"\w* los nobles,
\v 19 \w Quien|strong="H3605"\w* \w no|strong="H3808"\w* muestra parcialidad \w con|strong="H3588"\w* \w príncipes|strong="H8269"\w*, \w ni|strong="H3808"\w* considera al rico \w por|strong="H3588"\w* encima del \w pobre|strong="H1800"\w*? \w Porque|strong="H3588"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3027"\w* \w son|strong="H3588"\w* \w la|strong="H3588"\w* \w obra|strong="H4639"\w* \w de|strong="H3588"\w* sus \w manos|strong="H3027"\w*.
\v 20 \w De|strong="H5971"\w* repente \w a|strong="H3068"\w* medianoche \w mueren|strong="H4191"\w*, las gentes \w se|strong="H3808"\w* estremecen y ya \w no|strong="H3808"\w* están. Los poderosos \w son|strong="H3808"\w* derribados y \w no|strong="H3808"\w* \w por|strong="H3027"\w* \w mano|strong="H3027"\w*.
\p 
\v 21 \w Porque|strong="H3588"\w* \w los|strong="H5921"\w* \w ojos|strong="H5869"\w* \w de|strong="H5921"\w* \w Él|strong="H5921"\w* están \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* sendas \w del|strong="H5921"\w* hombre \w y|strong="H3588"\w* observan \w todos|strong="H3605"\w* sus \w pasos|strong="H6806"\w*.
\v 22 No hay \w oscuridad|strong="H2822"\w* ni sombras \w donde|strong="H8033"\w* puedan ocultarse los que \w hacen|strong="H6466"\w* iniquidad.
\v 23 \w Pues|strong="H3588"\w* \w no|strong="H3808"\w* \w le|strong="H5921"\w* impone plazo \w al|strong="H5921"\w* hombre, \w para|strong="H5921"\w* \w que|strong="H3588"\w* comparezca \w a|strong="H3068"\w* \w juicio|strong="H4941"\w* ante \nd \w ʼEL|strong="H5921"\w*\nd*.
\p 
\v 24 Él quebranta \w a|strong="H3068"\w* los poderosos \w sin|strong="H3808"\w* indagar y pone \w a|strong="H3068"\w* otros \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* ellos.
\v 25 \w Por|strong="H3651"\w* \w cuanto|strong="H3651"\w* \w conoce|strong="H5234"\w* las obras de ellos, los trastorna en una \w noche|strong="H3915"\w*, y quedan deshechos.
\v 26 Los azota \w por|strong="H8478"\w* sus perversidades \w en|strong="H8478"\w* un \w lugar|strong="H4725"\w* público,
\v 27 \w porque|strong="H5921"\w* \w se|strong="H5921"\w* apartaron \w de|strong="H5921"\w* seguirlo. \w No|strong="H3808"\w* \w consideraron|strong="H7919"\w* \w alguno|strong="H3605"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w caminos|strong="H1870"\w* \w de|strong="H5921"\w* \w Él|strong="H5921"\w*.
\v 28 Buscaron \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w clamor|strong="H6818"\w* \w del|strong="H5921"\w* \w pobre|strong="H1800"\w* llegara \w a|strong="H3068"\w* \w Él|strong="H5921"\w*, \w y|strong="H5921"\w* \w que|strong="H5921"\w* \w escuchara|strong="H8085"\w* \w el|strong="H5921"\w* \w clamor|strong="H6818"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* afligidos.
\p 
\v 29 Cuando \w Él|strong="H1931"\w* da tranquilidad, ¿\w quién|strong="H4310"\w* entonces \w lo|strong="H1931"\w* inculpará? \w Si|strong="H1931"\w* \w esconde|strong="H5641"\w* \w su|strong="H1931"\w* \w rostro|strong="H6440"\w*, ¿\w quién|strong="H4310"\w* \w lo|strong="H1931"\w* mirará? \w Esto|strong="H1931"\w* ocurre \w tanto|strong="H5921"\w* \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* una \w nación|strong="H1471"\w* \w como|strong="H5921"\w* \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w un|strong="H3162"\w* hombre,
\v 30 \w para|strong="H5971"\w* evitar \w que|strong="H5971"\w* \w reine|strong="H4427"\w* el impío \w e|strong="H3068"\w* imponga trampas al \w pueblo|strong="H5971"\w*.
\p 
\v 31 \w Porque|strong="H3588"\w*, ¿alguno le dijo \w a|strong="H3068"\w* \nd \w ʼEL|strong="H3588"\w*\nd*: Generé \w mi|strong="H5375"\w* castigo, \w no|strong="H3808"\w* pecaré \w más|strong="H3588"\w*,
\v 32 \w enséñame|strong="H3384"\w* Tú \w lo|strong="H3808"\w* \w que|strong="H3808"\w* yo \w no|strong="H3808"\w* veo? ¡\w Si|strong="H3808"\w* obré \w mal|strong="H6466"\w*, \w no|strong="H3808"\w* \w lo|strong="H3808"\w* haré \w más|strong="H3254"\w*!
\v 33 ¿Retribuirá según tus condiciones, \w porque|strong="H3588"\w* tú rechazas las \w de|strong="H3588"\w* \w Él|strong="H5973"\w*? \w Si|strong="H3588"\w* rechazas \w o|strong="H3068"\w* \w si|strong="H3588"\w* aceptas, \w Él|strong="H5973"\w* \w te|strong="H3588"\w* retribuirá, \w no|strong="H3808"\w* \w yo|strong="H3588"\w*. \w Y|strong="H3068"\w* \w si|strong="H3588"\w* \w no|strong="H3808"\w* \w es|strong="H3588"\w* \w así|strong="H3588"\w*, \w dí|strong="H1696"\w* \w lo|strong="H4100"\w* \w que|strong="H3588"\w* \w sabes|strong="H3045"\w*.
\p 
\v 34 \w Los|strong="H2450"\w* \w hombres|strong="H1397"\w* de entendimiento me lo dirán, y el \w hombre|strong="H1397"\w* \w sabio|strong="H2450"\w* que me \w escucha|strong="H8085"\w*:
\v 35 \w Que|strong="H3808"\w* Job \w no|strong="H3808"\w* \w habló|strong="H1696"\w* con \w sabiduría|strong="H1847"\w*, \w que|strong="H3808"\w* sus \w palabras|strong="H1697"\w* fueron \w sin|strong="H3808"\w* discernimiento,
\v 36 \w que|strong="H5921"\w* Job debe ser probado \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* límite, \w porque|strong="H5921"\w* respondió \w como|strong="H5921"\w* \w los|strong="H5921"\w* perversos,
\v 37 \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w pecado|strong="H2403"\w* \w añade|strong="H3254"\w* \w rebelión|strong="H6588"\w*. Bate palmas ante \w nosotros|strong="H5921"\w* \w y|strong="H3588"\w* \w multiplica|strong="H7235"\w* sus palabras \w contra|strong="H5921"\w* \nd \w ʼEL|strong="H5921"\w*\nd*.
\c 35
\s1 Tercera parte de las palabras de Eliú
\p 
\v 1 Eliú continuó:
\v 2 ¿\w Piensas|strong="H2803"\w* que \w es|strong="H2063"\w* correcto decir: Mi \w justicia|strong="H6664"\w* \w es|strong="H2063"\w* mayor que \w la|strong="H2063"\w* de \nd ʼEL\nd*?
\v 3 \w Porque|strong="H3588"\w* dijiste: ¿\w Qué|strong="H3588"\w* \w provecho|strong="H3276"\w* habrá \w para|strong="H3588"\w* Ti? ¿\w Qué|strong="H3588"\w* \w provecho|strong="H3276"\w* tendré, \w más|strong="H3588"\w* \w que|strong="H3588"\w* \w si|strong="H3588"\w* hubiera \w pecado|strong="H2403"\w*?
\v 4 Yo \w te|strong="H5973"\w* responderé, y \w a|strong="H3068"\w* tus \w compañeros|strong="H7453"\w* \w contigo|strong="H5973"\w*:
\v 5 Observa atentamente el \w cielo|strong="H8064"\w* y contempla las nubes \w que|strong="H4480"\w* son \w más|strong="H4480"\w* altas \w que|strong="H4480"\w* tú:
\v 6 Si pecas, ¿\w qué|strong="H4100"\w* \w mal|strong="H6466"\w* le \w haces|strong="H6213"\w* \w a|strong="H3068"\w* \w Él|strong="H6213"\w*? Si tus transgresiones \w se|strong="H4100"\w* multiplican, ¿\w qué|strong="H4100"\w* daño le \w haces|strong="H6213"\w* \w a|strong="H3068"\w* \w Él|strong="H6213"\w*?
\v 7 Si eres justo, ¿\w qué|strong="H4100"\w* obtiene Él \w de|strong="H5414"\w* ti, \w o|strong="H3068"\w* \w qué|strong="H4100"\w* \w recibe|strong="H3947"\w* \w de|strong="H5414"\w* tu \w mano|strong="H3027"\w*?
\v 8 Tu maldad afecta al \w hombre|strong="H1121"\w*, y tu \w justicia|strong="H6666"\w*, al humano \w como|strong="H3644"\w* tú.
\p 
\v 9 \w Claman|strong="H7768"\w* bajo el peso de la opresión y gritan contra los poderosos,
\v 10 pero \w ninguno|strong="H3808"\w* dice: ¿Dónde está nuestro \w Hacedor|strong="H6213"\w* \w Quien|strong="H6213"\w* restaura las fuerzas durante la \w noche|strong="H3915"\w*?
\v 11 ¿Quien nos instruye por medio de las bestias de la tierra, y nos enseña por medio de las \w aves|strong="H5775"\w* del \w cielo|strong="H8064"\w*?
\v 12 Entonces \w claman|strong="H6817"\w*, pero Él \w no|strong="H3808"\w* \w responde|strong="H6030"\w*, \w por|strong="H6440"\w* la arrogancia \w de|strong="H6440"\w* los perversos,
\v 13 \w porque|strong="H3808"\w* \w ciertamente|strong="H8085"\w* \nd ʼEL\nd* \w no|strong="H3808"\w* \w escucha|strong="H8085"\w* el \w falso|strong="H7723"\w* clamor. \nd ʼEL-Shadday\nd* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* tiene en cuenta.
\v 14 ¡\w Cuánto|strong="H3588"\w* \w menos|strong="H3588"\w* \w cuando|strong="H3588"\w* tú dices \w que|strong="H3588"\w* \w aunque|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* veas, tu \w causa|strong="H1779"\w* está \w ante|strong="H6440"\w* \w Él|strong="H3588"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* \w Él|strong="H3588"\w* esperas!
\v 15 \w Pero|strong="H3588"\w* \w ahora|strong="H6258"\w*, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* ira \w no|strong="H3808"\w* castigó, \w ni|strong="H3808"\w* \w reconoció|strong="H6485"\w* \w con|strong="H3588"\w* rigor \w la|strong="H3588"\w* transgresión,
\v 16 Job \w abrió|strong="H6475"\w* \w vanamente|strong="H1892"\w* su \w boca|strong="H6310"\w* y multiplica \w palabras|strong="H4405"\w* \w sin|strong="H1097"\w* entendimiento.
\c 36
\s1 Exaltación de Eliú a la grandeza de \nd ʼElohim\nd*
\p 
\v 1 Entonces Eliú continuó:
\v 2 \w Espérame|strong="H3803"\w* un poco \w y|strong="H3588"\w* \w te|strong="H3588"\w* diré \w más|strong="H5750"\w*, \w porque|strong="H3588"\w* \w aún|strong="H5750"\w* queda algo \w por|strong="H3588"\w* decir \w en|strong="H3588"\w* defensa \w de|strong="H3588"\w* \nd ʼEloha\nd*.
\v 3 Desde \w lejos|strong="H7350"\w* traeré \w mi|strong="H5375"\w* saber y atribuiré \w justicia|strong="H6664"\w* \w a|strong="H3068"\w* \w mi|strong="H5375"\w* Hacedor,
\v 4 \w porque|strong="H3588"\w* \w en|strong="H5973"\w* verdad \w mis|strong="H4405"\w* \w palabras|strong="H4405"\w* \w no|strong="H3808"\w* \w son|strong="H3588"\w* falsas. \w Contigo|strong="H5973"\w* está Uno \w que|strong="H3588"\w* \w es|strong="H3588"\w* \w perfecto|strong="H8549"\w* \w en|strong="H5973"\w* \w conocimiento|strong="H1844"\w*.
\p 
\v 5 \w Ciertamente|strong="H2005"\w* \nd ʼEL\nd* es poderoso, pero \w no|strong="H3808"\w* \w desprecia|strong="H3988"\w* \w a|strong="H3068"\w* \w nadie|strong="H3808"\w*. Es poderoso en la \w fuerza|strong="H3581"\w* del \w entendimiento|strong="H3820"\w*.
\v 6 \w No|strong="H3808"\w* otorga \w vida|strong="H2421"\w* al perverso, pero hace \w justicia|strong="H4941"\w* \w a|strong="H3068"\w* los afligidos.
\p 
\v 7 \w No|strong="H3808"\w* aparta sus \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* \w los|strong="H3427"\w* \w justos|strong="H6662"\w*. \w Los|strong="H3427"\w* hace sentar con \w reyes|strong="H4428"\w* en \w el|strong="H3427"\w* \w trono|strong="H3678"\w* para siempre, y serán exaltados.
\v 8 Si están presos con grilletes y atrapados con cuerdas de \w aflicción|strong="H6040"\w*,
\v 9 \w los|strong="H1992"\w* reprende \w por|strong="H3588"\w* \w su|strong="H1992"\w* \w obra|strong="H6467"\w* \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w sus|strong="H1992"\w* transgresiones, \w porque|strong="H3588"\w* \w se|strong="H1992"\w* exaltaron \w a|strong="H3068"\w* \w sí|strong="H3588"\w* \w mismos|strong="H1992"\w*.
\v 10 Les \w abre|strong="H1540"\w* \w el|strong="H3588"\w* oído \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w corrección|strong="H4148"\w* \w y|strong="H3588"\w* \w los|strong="H3588"\w* exhorta \w a|strong="H3068"\w* devolverse \w de|strong="H3588"\w* \w la|strong="H3588"\w* iniquidad.
\v 11 Si \w escuchan|strong="H8085"\w* y se someten, acaban sus \w días|strong="H3117"\w* en prosperidad, y sus \w años|strong="H8141"\w* en \w deleites|strong="H5273"\w*.
\v 12 Pero \w si|strong="H3808"\w* \w no|strong="H3808"\w* \w escuchan|strong="H8085"\w*, perecen \w a|strong="H3068"\w* filo de espada \w o|strong="H3068"\w* por su ignorancia.
\p 
\v 13 \w Los|strong="H3588"\w* impíos \w de|strong="H3588"\w* \w corazón|strong="H3820"\w* atesoran ira, \w no|strong="H3808"\w* \w claman|strong="H7768"\w* \w cuando|strong="H3588"\w* \w Él|strong="H3588"\w* \w los|strong="H3588"\w* ata \w y|strong="H3588"\w*
\v 14 \w mueren|strong="H4191"\w* en la juventud. Sus \w vidas|strong="H5315"\w* terminan entre los \w sodomitas|strong="H6945"\w* con rituales paganos.
\p 
\v 15 Él \w libra|strong="H2502"\w* \w a|strong="H3068"\w* los afligidos en su \w aflicción|strong="H6040"\w*. \w Abre|strong="H1540"\w* sus oídos en la \w opresión|strong="H3906"\w*.
\p 
\v 16 \w También|strong="H7979"\w* te sacará \w de|strong="H8478"\w* las garras \w de|strong="H8478"\w* la \w angustia|strong="H6862"\w* \w a|strong="H3068"\w* un \w lugar|strong="H8478"\w* espacioso y abierto, para servirte una \w mesa|strong="H7979"\w* \w llena|strong="H4390"\w* \w de|strong="H8478"\w* sustancia.
\p 
\v 17 Pero si tú estás \w lleno|strong="H4390"\w* del \w juicio|strong="H4941"\w* que merece el perverso, el \w juicio|strong="H4941"\w* y la \w justicia|strong="H4941"\w* se apoderan de ti.
\v 18 \w Por|strong="H3588"\w* lo \w cual|strong="H3588"\w*, teme, \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w ira|strong="H2534"\w* \w te|strong="H3588"\w* quite \w de|strong="H3588"\w* un golpe, del \w cual|strong="H3588"\w* \w no|strong="H6435"\w* \w te|strong="H3588"\w* pueda librar \w ni|strong="H6435"\w* un \w gran|strong="H7227"\w* \w rescate|strong="H3724"\w*.
\v 19 ¿\w Será|strong="H3808"\w* suficiente tu clamor para librarte de \w la|strong="H3605"\w* angustia \w o|strong="H3068"\w* \w todas|strong="H3605"\w* las \w fuerzas|strong="H3581"\w* de tu \w poder|strong="H3581"\w*?
\v 20 No \w anheles|strong="H7602"\w* la \w noche|strong="H3915"\w* \w en|strong="H8478"\w* la cual los \w pueblos|strong="H5971"\w* desaparecerán \w de|strong="H8478"\w* su \w lugar|strong="H8478"\w*.
\v 21 Cuídate \w de|strong="H5921"\w* \w no|strong="H3588"\w* volver \w a|strong="H3068"\w* \w la|strong="H5921"\w* iniquidad, \w porque|strong="H3588"\w* escogiste \w ésta|strong="H2088"\w* \w en|strong="H5921"\w* vez \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w aflicción|strong="H6040"\w*.
\p 
\v 22 \w Ciertamente|strong="H2005"\w* \nd \w ʼEL|strong="H4310"\w*\nd* es exaltado en su \w poder|strong="H3581"\w*: ¿\w Quién|strong="H4310"\w* es un Maestro \w como|strong="H3644"\w* \w Él|strong="H4310"\w*?
\v 23 ¿\w Quién|strong="H4310"\w* \w le|strong="H5921"\w* señala \w el|strong="H5921"\w* \w camino|strong="H1870"\w*? ¿\w Quién|strong="H4310"\w* \w le|strong="H5921"\w* dirá jamás: Cometiste injusticia?
\p 
\v 24 \w Acuérdate|strong="H2142"\w* \w de|strong="H3588"\w* \w engrandecer|strong="H7679"\w* \w su|strong="H3588"\w* \w obra|strong="H6467"\w*, \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w cual|strong="H3588"\w* \w los|strong="H3588"\w* hombres \w cantan|strong="H7891"\w*.
\v 25 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w la|strong="H3605"\w* contemplan. \w Los|strong="H3605"\w* humanos \w la|strong="H3605"\w* \w miran|strong="H5027"\w* desde \w lejos|strong="H7350"\w*.
\v 26 \w Mira|strong="H2005"\w*, \nd ʼEL\nd* es exaltado, y nosotros \w no|strong="H3808"\w* \w lo|strong="H3808"\w* conocemos. El \w número|strong="H4557"\w* de sus \w años|strong="H8141"\w* es inescrutable.
\p 
\v 27 \w Él|strong="H3588"\w* atrae las gotas \w de|strong="H3588"\w* \w agua|strong="H4325"\w*, \w y|strong="H3588"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w lluvia|strong="H4306"\w* convierte \w en|strong="H3588"\w* vapor
\v 28 \w que|strong="H5921"\w* \w destilan|strong="H7491"\w* \w las|strong="H5921"\w* nubes, \w y|strong="H5921"\w* vierten \w en|strong="H5921"\w* abundancia \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* hombres.
\v 29 ¿Quién entenderá el despliegue de las \w nubes|strong="H5645"\w* y el estruendo de la bóveda celeste?
\v 30 \w Ciertamente|strong="H2005"\w*, despliega su rayo \w en|strong="H5921"\w* \w ella|strong="H5921"\w* \w y|strong="H5921"\w* \w cubre|strong="H3680"\w* \w las|strong="H5921"\w* profundidades \w del|strong="H5921"\w* \w mar|strong="H3220"\w*.
\p 
\v 31 \w Con|strong="H3588"\w* tales cosas gobierna \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w pueblos|strong="H5971"\w* \w y|strong="H3588"\w* \w da|strong="H5414"\w* alimento \w en|strong="H3588"\w* abundancia.
\v 32 \w Cubre|strong="H3680"\w* \w con|strong="H5921"\w* sus \w manos|strong="H3709"\w* \w el|strong="H5921"\w* rayo \w y|strong="H5921"\w* \w lo|strong="H5921"\w* lanza certero \w hacia|strong="H5921"\w* su blanco.
\v 33 \w El|strong="H5921"\w* trueno anuncia su presencia, \w el|strong="H5921"\w* \w ganado|strong="H4735"\w* también, \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w la|strong="H5921"\w* tormenta \w que|strong="H5921"\w* \w se|strong="H5921"\w* levanta.
\c 37
\p 
\v 1 Por lo cual también se estremece mi \w corazón|strong="H3820"\w* y salta fuera de su \w lugar|strong="H4725"\w*.
\v 2 ¡\w Escuchen|strong="H8085"\w* \w atentamente|strong="H8085"\w* el trueno de su \w voz|strong="H6963"\w* y el \w estruendo|strong="H6963"\w* \w que|strong="H6310"\w* \w sale|strong="H3318"\w* de su \w boca|strong="H6310"\w*!
\v 3 Suelta sus relámpagos \w por|strong="H5921"\w* \w debajo|strong="H8478"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w que|strong="H5921"\w* llegan \w hasta|strong="H5921"\w* \w los|strong="H5921"\w* confines \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.
\v 4 Tras ellos ruge \w su|strong="H3588"\w* \w voz|strong="H6963"\w*. Truena \nd \w ʼEL|strong="H3588"\w*\nd* \w con|strong="H3588"\w* \w voz|strong="H6963"\w* majestuosa, \w y|strong="H3588"\w* \w aunque|strong="H3588"\w* sea oída \w su|strong="H3588"\w* \w voz|strong="H6963"\w*, \w no|strong="H3808"\w* \w los|strong="H3588"\w* detiene.
\v 5 \nd \w ʼEL|strong="H6213"\w*\nd* truena con \w voz|strong="H6963"\w* maravillosa y \w hace|strong="H6213"\w* \w cosas|strong="H3045"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* podemos comprender.
\v 6 \w A|strong="H3068"\w* \w la|strong="H3588"\w* nieve dice: Cae \w a|strong="H3068"\w* \w la|strong="H3588"\w* tierra. También \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w lluvia|strong="H1653"\w* \w y|strong="H3588"\w* al aguacero torrencial.
\p 
\v 7 Así hace \w que|strong="H3045"\w* \w todo|strong="H3605"\w* hombre \w se|strong="H3045"\w* retire, para \w que|strong="H3045"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w reconozcan|strong="H3045"\w* su \w obra|strong="H4639"\w*.
\v 8 Las \w bestias|strong="H2416"\w* se meten en lugar de descanso y permanecen en sus guaridas.
\p 
\v 9 \w De|strong="H4480"\w* su \w cámara|strong="H2315"\w* viene la tormenta y el frío \w de|strong="H4480"\w* los vientos \w del|strong="H4480"\w* norte.
\v 10 \w Por|strong="H5414"\w* el \w soplo|strong="H5397"\w* \w de|strong="H5397"\w* \nd ʼEL\nd* se forma el hielo y se congelan las amplias \w aguas|strong="H4325"\w*.
\v 11 Carga de humedad la densa \w nube|strong="H6051"\w*. Dispersa las \w nubes|strong="H5645"\w* con sus relámpagos,
\v 12 \w que|strong="H1931"\w* giran \w según|strong="H5921"\w* \w su|strong="H1931"\w* designio \w para|strong="H5921"\w* cumplir \w sus|strong="H1931"\w* órdenes \w sobre|strong="H5921"\w* \w la|strong="H1931"\w* superficie \w de|strong="H5921"\w* \w la|strong="H1931"\w* tierra habitada.
\v 13 Las hace venir, unas veces como azote, otras, \w a|strong="H3068"\w* favor de su tierra y otras por \w misericordia|strong="H2617"\w*.
\p 
\v 14 Oh Job, escucha \w esto|strong="H2063"\w*. Detente y considera las \w maravillas|strong="H6381"\w* de \nd ʼEL\nd*.
\p 
\v 15 ¿\w Sabes|strong="H3045"\w* cuándo \nd ʼEloah\nd* \w las|strong="H5921"\w* establece \w y|strong="H5921"\w* hace fulgurar \w la|strong="H5921"\w* luz \w de|strong="H5921"\w* su \w nube|strong="H6051"\w*?
\v 16 ¿\w Conoces|strong="H3045"\w* tú \w el|strong="H5921"\w* equilibrio \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w nubes|strong="H5645"\w*, \w las|strong="H5921"\w* obras prodigiosas \w de|strong="H5921"\w* Aquél \w que|strong="H5921"\w* es \w perfecto|strong="H8549"\w* \w en|strong="H5921"\w* \w conocimiento|strong="H3045"\w*?
\v 17 ¿Por qué están calientes tus ropas cuando la tierra está tranquila \w a|strong="H3068"\w* causa del viento del sur?
\v 18 ¿\w Extendiste|strong="H7554"\w* \w con|strong="H5973"\w* \w Él|strong="H5973"\w* la bóveda celeste, sólida \w como|strong="H5973"\w* un espejo fundido?
\p 
\v 19 \w Muéstranos|strong="H3045"\w* \w qué|strong="H4100"\w* le diremos. \w Porque|strong="H3808"\w* \w no|strong="H3808"\w* podemos ordenar nuestras ideas \w a|strong="H3068"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* las \w tinieblas|strong="H2822"\w*.
\v 20 ¿Será necesario informarle lo \w que|strong="H3588"\w* \w yo|strong="H3588"\w* digo? ¿\w O|strong="H3068"\w* debe un hombre desear \w que|strong="H3588"\w* sea \w tragado|strong="H1104"\w*?
\p 
\v 21 Ciertamente \w no|strong="H3808"\w* \w es|strong="H1931"\w* posible \w mirar|strong="H7200"\w* \w la|strong="H1931"\w* luz oscurecida por las nubes, pero un \w viento|strong="H7307"\w* \w pasa|strong="H5674"\w*, y \w la|strong="H1931"\w* despeja.
\v 22 \w Del|strong="H5921"\w* \w norte|strong="H6828"\w* asoma un dorado resplandor.
\p ¡\w En|strong="H5921"\w* \nd ʼEloha\nd* \w hay|strong="H3372"\w* una asombrosa majestad!
\v 23 ¡\nd ʼEL-Shadday\nd*, \w a|strong="H3068"\w* Quien \w no|strong="H3808"\w* \w alcanzamos|strong="H4672"\w*! Exaltado en \w poder|strong="H3581"\w*, Él \w no|strong="H3808"\w* hará violencia \w a|strong="H3068"\w* la equidad. Es abundante en \w justicia|strong="H6666"\w*.
\p 
\v 24 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w*, \w los|strong="H3605"\w* hombres le \w temen|strong="H3372"\w*. \w Él|strong="H3605"\w* \w no|strong="H3808"\w* estima \w a|strong="H3068"\w* \w alguno|strong="H3605"\w* \w que|strong="H3808"\w* cree en su \w corazón|strong="H3820"\w* ser \w sabio|strong="H2450"\w*.
\c 38
\s1 Intervención de \nd Yavé\nd*
\p 
\v 1 \nd \w Yavé|strong="H3068"\w*\nd* \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* Job \w desde|strong="H4480"\w* un remolino \w de|strong="H4480"\w* viento:
\v 2 \wj ¿\w Quién|strong="H4310"\w* \w es|strong="H2088"\w* \w el|strong="H4310"\w* \w que|strong="H4310"\w* oscurece \w el|strong="H4310"\w* \w consejo|strong="H6098"\w* con \w palabras|strong="H4405"\w* \w sin|strong="H1097"\w* entendimiento?\wj*
\p 
\v 3 \wj Ciñe \w ahora|strong="H4994"\w* tu cintura como \w varón|strong="H1397"\w*. \w Yo|strong="H4994"\w* te \w preguntaré|strong="H7592"\w*, y tú me responderás: \wj*
\v 4 \wj ¿Dónde \w estabas|strong="H1961"\w* tú \w cuando|strong="H1961"\w* Yo fundaba la tierra? Dí, \w si|strong="H1961"\w* \w tienes|strong="H3045"\w* entendimiento.\wj*
\v 5 \wj ¿\w Quién|strong="H4310"\w* determinó sus medidas? \w Con|strong="H5921"\w* seguridad \w lo|strong="H5921"\w* \w sabes|strong="H3045"\w*. ¿\w Quién|strong="H4310"\w* \w extendió|strong="H5186"\w* cordel \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w*?\wj*
\v 6 \wj ¿\w Sobre|strong="H5921"\w* \w qué|strong="H4100"\w* están fundados sus cimientos? ¿\w Quién|strong="H4310"\w* colocó su piedra \w angular|strong="H6438"\w*,\wj*
\v 7 \wj cuando las \w estrellas|strong="H3556"\w* del alba \w alababan|strong="H7442"\w* \w juntas|strong="H3162"\w*, y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \nd ʼElohim\nd* gritaban \w de|strong="H1121"\w* júbilo?\wj*
\p 
\v 8 \wj ¿Quién encerró al \w mar|strong="H3220"\w* con compuertas cuando se \w salía|strong="H3318"\w* de su seno?\wj*
\v 9 \wj Cuando le coloqué \w nubes|strong="H6051"\w* como ropa, y densa \w oscuridad|strong="H6205"\w* como envoltura,\wj*
\v 10 \wj cuando establecí \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w mi|strong="H5921"\w* límite, coloqué barra \w en|strong="H5921"\w* sus \w puertas|strong="H1817"\w*\wj*
\v 11 \wj \w y|strong="H5704"\w* \w le|strong="H3254"\w* dije: \w Hasta|strong="H5704"\w* \w aquí|strong="H6311"\w* llegarás \w y|strong="H5704"\w* \w no|strong="H3808"\w* \w pasarás|strong="H3254"\w*. \w Aquí|strong="H6311"\w* \w se|strong="H3808"\w* detendrá el orgullo \w de|strong="H5704"\w* tus olas.\wj*
\p 
\v 12 \wj ¿Alguna vez en tu \w vida|strong="H3117"\w* diste \w orden|strong="H6680"\w* \w a|strong="H3068"\w* la \w mañana|strong="H1242"\w*? ¿Mostraste \w a|strong="H3068"\w* la aurora su \w lugar|strong="H4725"\w*?\wj*
\v 13 \wj \w A|strong="H3068"\w* fin \w de|strong="H4480"\w* \w que|strong="H4480"\w* tome los confines \w de|strong="H4480"\w* la tierra y \w sacuda|strong="H5287"\w* \w de|strong="H4480"\w* \w ella|strong="H4480"\w* \w a|strong="H3068"\w* los perversos,\wj*
\v 14 \wj sea cambiada \w como|strong="H3644"\w* arcilla modelada por el sello, y adelgazada hasta ser \w como|strong="H3644"\w* una ropa multicolor,\wj*
\v 15 \wj para que se retenga la luz de los perversos y sea quebrado el \w brazo|strong="H2220"\w* \w enaltecido|strong="H7311"\w*.\wj*
\v 16 \wj ¿Penetraste tú \w hasta|strong="H5704"\w* las fuentes del \w mar|strong="H3220"\w* \w o|strong="H3068"\w* caminaste \w en|strong="H5704"\w* las profundidades del \w abismo|strong="H8415"\w*?\wj*
\v 17 \wj ¿Te fueron reveladas las \w puertas|strong="H8179"\w* de la \w muerte|strong="H4194"\w*? ¿\w Viste|strong="H7200"\w* las \w puertas|strong="H8179"\w* de la profunda oscuridad?\wj*
\v 18 \wj ¿Consideraste tú \w la|strong="H3605"\w* anchura \w de|strong="H5704"\w* \w la|strong="H3605"\w* tierra? \w Declara|strong="H5046"\w* si \w sabes|strong="H3045"\w* \w todo|strong="H3605"\w* esto.\wj*
\p 
\v 19 \wj ¿\w Dónde|strong="H4725"\w* \w está|strong="H2088"\w* el \w camino|strong="H1870"\w* \w hacia|strong="H1870"\w* la morada de la luz? ¿\w Dónde|strong="H4725"\w* vive la \w oscuridad|strong="H2822"\w*,\wj*
\v 20 \wj \w para|strong="H3588"\w* \w que|strong="H3588"\w* las conduzcas \w a|strong="H3068"\w* \w su|strong="H3588"\w* territorio \w y|strong="H3588"\w* les muestres las sendas \w a|strong="H3068"\w* \w su|strong="H3588"\w* vivienda?\wj*
\v 21 \wj Tú lo \w sabes|strong="H3045"\w*, \w porque|strong="H3588"\w* \w entonces|strong="H3117"\w* ya habías \w nacido|strong="H3205"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w número|strong="H4557"\w* \w de|strong="H3588"\w* tus \w días|strong="H3117"\w* \w es|strong="H3588"\w* \w grande|strong="H7227"\w*.\wj*
\p 
\v 22 \wj ¿Estuviste en los tesoros de la nieve \w o|strong="H3068"\w* \w viste|strong="H7200"\w* los tesoros del \w granizo|strong="H1259"\w*\wj*
\v 23 \wj \w que|strong="H3117"\w* tengo reservados para el \w tiempo|strong="H6256"\w* \w de|strong="H6256"\w* \w angustia|strong="H6862"\w*, para el \w día|strong="H3117"\w* \w de|strong="H6256"\w* la \w guerra|strong="H4421"\w* y \w de|strong="H6256"\w* la \w batalla|strong="H4421"\w*?\wj*
\v 24 \wj ¿\w Por|strong="H5921"\w* cuál \w camino|strong="H1870"\w* \w se|strong="H5921"\w* reparte \w la|strong="H5921"\w* luz \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w esparce|strong="H6327"\w* \w el|strong="H5921"\w* viento \w del|strong="H5921"\w* \w este|strong="H2088"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* tierra?\wj*
\v 25 \wj ¿\w Quién|strong="H4310"\w* \w le|strong="H4310"\w* abrió cauce al aluvión y \w camino|strong="H1870"\w* \w a|strong="H3068"\w* los \w relámpagos|strong="H2385"\w* y \w truenos|strong="H6963"\w*,\wj*
\v 26 \wj \w para|strong="H5921"\w* saciar \w la|strong="H5921"\w* tierra deshabitada \w y|strong="H5921"\w* desolada, \w para|strong="H5921"\w* \w que|strong="H3808"\w* brote \w la|strong="H5921"\w* hierba,\wj*
\v 27 \wj para saciar las tierras desoladas, y hacer que broten las semillas \w de|strong="H7646"\w* \w la|strong="H7646"\w* \w hierba|strong="H1877"\w*?\wj*
\v 28 \wj ¿La \w lluvia|strong="H4306"\w* \w tiene|strong="H3426"\w* padre? ¿\w Quién|strong="H4310"\w* \w engendró|strong="H3205"\w* las gotas de \w rocío|strong="H2919"\w*?\wj*
\v 29 \wj ¿De \w cuál|strong="H4310"\w* vientre \w salió|strong="H3318"\w* \w el|strong="H4310"\w* hielo? ¿\w Quién|strong="H4310"\w* \w engendró|strong="H3205"\w* la escarcha del \w cielo|strong="H8064"\w*\wj*
\v 30 \wj para \w que|strong="H4325"\w* las \w aguas|strong="H4325"\w* se cubran con una losa, \w que|strong="H4325"\w* aprisiona la superficie del \w abismo|strong="H8415"\w*?\wj*
\p 
\v 31 \wj ¿Podrás anudar las cadenas de las Pléyades \w o|strong="H3068"\w* \w desatar|strong="H6605"\w* las ligaduras de Orión?\wj*
\v 32 \wj ¿\w Sacarás|strong="H3318"\w* \w las|strong="H5921"\w* constelaciones \w del|strong="H5921"\w* cielo \w a|strong="H3068"\w* su \w tiempo|strong="H6256"\w* \w o|strong="H3068"\w* guiarás \w la|strong="H5921"\w* Osa Mayor \w con|strong="H5921"\w* sus \w hijos|strong="H1121"\w*?\wj*
\v 33 \wj ¿\w Conoces|strong="H3045"\w* tú los \w Estatutos|strong="H2708"\w* del \w cielo|strong="H8064"\w*? ¿Puedes establecer su dominio en la tierra?\wj*
\p 
\v 34 \wj ¿\w Alzarás|strong="H7311"\w* tu \w voz|strong="H6963"\w* hacia las \w nubes|strong="H5645"\w* para \w que|strong="H4325"\w* te cubra el chaparrón?\wj*
\v 35 \wj ¿\w Enviarás|strong="H7971"\w* tú los \w relámpagos|strong="H1300"\w* para que vengan y te digan: \w Aquí|strong="H2005"\w* estamos?\wj*
\v 36 \wj ¿\w Quién|strong="H4310"\w* colocó entendimiento en \w el|strong="H4310"\w* ser íntimo? ¿\w Quién|strong="H4310"\w* \w dio|strong="H5414"\w* entendimiento \w a|strong="H3068"\w* \w la|strong="H2451"\w* mente?\wj*
\v 37 \wj ¿\w Quién|strong="H4310"\w* \w cuenta|strong="H5608"\w* las nubes con \w sabiduría|strong="H2451"\w* y voltea los cántaros del \w cielo|strong="H8064"\w*,\wj*
\v 38 \wj cuando el \w polvo|strong="H6083"\w* se convierte en una masa y los terrones se pegan entre sí?\wj*
\p 
\v 39 \wj ¿\w Cazarás|strong="H6679"\w* tú presa para la leona? ¿Saciarás el hambre de sus leoncillos\wj*
\v 40 \wj \w cuando|strong="H3588"\w* \w están|strong="H3427"\w* echados \w en|strong="H3588"\w* sus cuevas \w o|strong="H3068"\w* se agazapan \w en|strong="H3588"\w* sus guaridas \w para|strong="H3588"\w* acechar?\wj*
\v 41 \wj ¿\w Quién|strong="H4310"\w* provee al \w cuervo|strong="H6158"\w* \w su|strong="H3588"\w* comida, \w cuando|strong="H3588"\w* sus pichones \w claman|strong="H7768"\w* \w a|strong="H3068"\w* \nd ʼElohim \nd*\w mientras|strong="H3588"\w* vagan \w sin|strong="H1097"\w* alimento?\wj*
\c 39
\p 
\v 1 \wj ¿\w Sabes|strong="H3045"\w* tú \w cuándo|strong="H6256"\w* paren las cabras \w monteses|strong="H5553"\w*? ¿Asististe \w al|strong="H6256"\w* parto \w de|strong="H6256"\w* las venadas?\wj*
\v 2 \wj ¿Puedes \w contar|strong="H5608"\w* los \w meses|strong="H3391"\w* \w de|strong="H6256"\w* su preñez y \w saber|strong="H3045"\w* el \w tiempo|strong="H6256"\w* \w cuando|strong="H6256"\w* paren?\wj*
\v 3 \wj Se encorvan, expulsan sus crías, se libran de sus \w dolores|strong="H2256"\w* de parto.\wj*
\v 4 \wj Sus crías \w crecen|strong="H7235"\w*, \w se|strong="H3808"\w* fortalecen, \w salen|strong="H3318"\w* \w a|strong="H3068"\w* campo abierto y \w no|strong="H3808"\w* \w vuelven|strong="H7725"\w*.\wj*
\p 
\v 5 \wj ¿\w Quién|strong="H4310"\w* dio al asno \w montés|strong="H6501"\w* su \w libertad|strong="H2670"\w*? ¿\w Quién|strong="H4310"\w* \w soltó|strong="H6605"\w* las \w ataduras|strong="H4147"\w* del rebuznante,\wj*
\v 6 \wj \w a|strong="H3068"\w* cual di el desierto como hogar y tierra salitrosa como vivienda?\wj*
\v 7 \wj \w Se|strong="H3808"\w* burla del bullicio de la \w ciudad|strong="H7151"\w* y \w no|strong="H3808"\w* \w obedece|strong="H8085"\w* los gritos del arriero,\wj*
\v 8 \wj explora las montañas en \w busca|strong="H1875"\w* de su \w pasto|strong="H4829"\w* y rastrea \w toda|strong="H3605"\w* \w cosa|strong="H3605"\w* verde.\wj*
\p 
\v 9 \wj ¿Consentirá \w el|strong="H5921"\w* búfalo \w en|strong="H5921"\w* ser tu esclavo \w o|strong="H3068"\w* pasará \w la|strong="H5921"\w* noche \w en|strong="H5921"\w* tu establo?\wj*
\v 10 \wj ¿\w Atarás|strong="H7194"\w* al búfalo al arado con \w cuerdas|strong="H5688"\w*? ¿Rastrillará los \w valles|strong="H6010"\w* tras ti?\wj*
\v 11 \wj ¿Confiarás \w en|strong="H3588"\w* \w él|strong="H3588"\w* \w porque|strong="H3588"\w* \w es|strong="H3588"\w* robusto \w y|strong="H3588"\w* \w dejarás|strong="H5800"\w* tu labor \w a|strong="H3068"\w* \w su|strong="H3588"\w* cuidado?\wj*
\v 12 \wj ¿Confiarás \w en|strong="H3588"\w* \w él|strong="H3588"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w te|strong="H3588"\w* traiga tu cosecha \w y|strong="H3588"\w* reúna \w el|strong="H3588"\w* grano \w en|strong="H3588"\w* tu era?\wj*
\p 
\v 13 \wj Las \w alas|strong="H3671"\w* del avestruz se agitan alegres, ¿pero son las \w alas|strong="H3671"\w* y el plumaje del amor?\wj*
\v 14 \wj Abandona sus huevos \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w tierra|strong="H6083"\w*, \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w polvo|strong="H6083"\w* \w los|strong="H5921"\w* calienta\wj*
\v 15 \wj \w y|strong="H3588"\w* se olvida \w que|strong="H3588"\w* un \w pie|strong="H7272"\w* puede aplastarlos \w o|strong="H3068"\w* una \w bestia|strong="H2416"\w* salvaje pisotearlos.\wj*
\v 16 \wj Es cruel con sus polluelos como \w si|strong="H3808"\w* \w no|strong="H3808"\w* fueran suyos. \w No|strong="H3808"\w* le importa \w que|strong="H3808"\w* \w se|strong="H3808"\w* pierda su fatiga,\wj*
\v 17 \wj \w porque|strong="H3588"\w* \nd ʼEloah\nd* \w lo|strong="H3808"\w* privó \w de|strong="H3588"\w* \w sabiduría|strong="H2451"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* dotó \w de|strong="H3588"\w* entendimiento.\wj*
\v 18 \wj Pero \w cuando|strong="H6256"\w* se yergue en \w alto|strong="H4791"\w*, se burla del \w caballo|strong="H5483"\w* y su jinete.\wj*
\p 
\v 19 \wj ¿\w Diste|strong="H5414"\w* al \w caballo|strong="H5483"\w* su fuerza? ¿Cubriste tú su \w cuello|strong="H6677"\w* con una melena?\wj*
\v 20 \wj ¿Lo harás brincar como langosta? Su majestuoso resoplido es terrible,\wj*
\v 21 \wj \w escarba|strong="H2658"\w* \w en|strong="H3318"\w* el \w valle|strong="H6010"\w*, se regocija \w en|strong="H3318"\w* su \w fuerza|strong="H3581"\w*, \w sale|strong="H3318"\w* \w a|strong="H3068"\w* encontrarse con las \w armas|strong="H5402"\w*,\wj*
\v 22 \wj \w se|strong="H3808"\w* ríe del \w miedo|strong="H6343"\w* y \w no|strong="H3808"\w* \w se|strong="H3808"\w* espanta \w ni|strong="H3808"\w* retrocede \w ante|strong="H6440"\w* la \w espada|strong="H2719"\w*.\wj*
\v 23 \wj \w La|strong="H5921"\w* flecha resuena \w contra|strong="H5921"\w* \w él|strong="H5921"\w*. Fulguran lanzas \w y|strong="H5921"\w* arma arrojadiza,\wj*
\v 24 \wj \w con|strong="H3588"\w* ímpetu \w y|strong="H3588"\w* furor devora \w la|strong="H3588"\w* distancia, \w sin|strong="H3808"\w* \w que|strong="H3588"\w* le importe \w el|strong="H3588"\w* \w sonido|strong="H6963"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w trompeta|strong="H7782"\w*.\wj*
\v 25 \wj Parece que dice \w entre|strong="H1767"\w* clarines: ¡\w Ea|strong="H1889"\w*! Olfatea \w desde|strong="H1767"\w* \w lejos|strong="H7350"\w* la \w batalla|strong="H4421"\w*, el grito \w de|strong="H8269"\w* los comandantes y el grito \w de|strong="H8269"\w* \w guerra|strong="H4421"\w*.\wj*
\p 
\v 26 \wj ¿Vuela el halcón y \w extiende|strong="H6566"\w* sus \w alas|strong="H3671"\w* hacia el sur por tu sabiduría?\wj*
\v 27 \wj ¿\w Por|strong="H5921"\w* tu \w mandato|strong="H6310"\w* \w se|strong="H5921"\w* remonta \w el|strong="H5921"\w* águila \w y|strong="H3588"\w* pone \w su|strong="H3588"\w* \w nido|strong="H7064"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* altura?\wj*
\v 28 \wj Vive \w y|strong="H5921"\w* tiene su habitación \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w roca|strong="H5553"\w*, \w en|strong="H5921"\w* \w la|strong="H5921"\w* cumbre \w del|strong="H5921"\w* \w peñasco|strong="H5553"\w*, \w en|strong="H5921"\w* lugar inaccesible.\wj*
\v 29 \wj Desde \w allí|strong="H8033"\w* \w acecha|strong="H2658"\w* la presa. Sus \w ojos|strong="H5869"\w* la divisan desde muy \w lejos|strong="H7350"\w*.\wj*
\v 30 \wj \w Sus|strong="H1931"\w* polluelos \w chupan|strong="H5966"\w* \w la|strong="H1931"\w* \w sangre|strong="H1818"\w*. \w Donde|strong="H8033"\w* hay carroña, \w allí|strong="H8033"\w* \w está|strong="H1931"\w* \w ella|strong="H1931"\w*.\wj*
\c 40
\p 
\v 1 Además, \nd \w Yavé|strong="H3068"\w*\nd* \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* Job:
\v 2 \wj ¿\w El|strong="H5973"\w* que contiende \w con|strong="H5973"\w* \nd ʼEL-Shadday\nd* lo \w corrige|strong="H3198"\w*? \w El|strong="H5973"\w* que argumenta \w con|strong="H5973"\w* \nd ʼEloah\nd*, \w responda|strong="H6030"\w*.\wj*
\p 
\v 3 Entonces Job \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*:
\v 4 \w Ciertamente|strong="H2005"\w*, soy insignificante. ¿\w Qué|strong="H4100"\w* puedo responderte? \w Pongo|strong="H7760"\w* mi \w mano|strong="H3027"\w* sobre mi \w boca|strong="H6310"\w*.
\v 5 Una vez \w hablé|strong="H1696"\w*, pero \w no|strong="H3808"\w* \w responderé|strong="H6030"\w* \w más|strong="H3254"\w*. \w Y|strong="H3068"\w* \w aun|strong="H3254"\w* \w dos|strong="H8147"\w* veces, pero \w nada|strong="H3808"\w*.
\p 
\v 6 Entonces \nd \w Yavé|strong="H3068"\w*\nd* \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* Job \w desde|strong="H4480"\w* el remolino \w de|strong="H4480"\w* viento:
\v 7 \wj Cíñete \w ahora|strong="H4994"\w* tu cintura como \w varón|strong="H1397"\w*. \w Yo|strong="H4994"\w* te \w preguntaré|strong="H7592"\w*, y tú me responderás: \wj*
\v 8 \wj ¿\w Invalidarás|strong="H6565"\w* mi \w juicio|strong="H4941"\w*? ¿Me condenarás \w para|strong="H4616"\w* justificarte?\wj*
\p 
\v 9 \wj Si tienes un \w brazo|strong="H2220"\w* \w como|strong="H3644"\w* el de \nd ʼEL\nd*, y tu \w voz|strong="H6963"\w* truena con una \w voz|strong="H6963"\w* \w como|strong="H3644"\w* la suya,\wj*
\v 10 \wj adórnate \w de|strong="H3847"\w* majestad y esplendor. Cúbrete \w de|strong="H3847"\w* \w honra|strong="H1935"\w* y majestad.\wj*
\v 11 \wj Derrama \w el|strong="H3605"\w* ardor de tu ira, y \w abate|strong="H8213"\w* con una mirada al \w soberbio|strong="H1343"\w*.\wj*
\v 12 \wj Observa \w a|strong="H3068"\w* \w todo|strong="H3605"\w* arrogante y humíllalo. Quebranta \w a|strong="H3068"\w* \w los|strong="H3605"\w* perversos \w en|strong="H8478"\w* su sitio,\wj*
\v 13 \wj entiérralos \w juntos|strong="H3162"\w* en el \w polvo|strong="H6083"\w* y véndales los semblantes en la oscuridad.\wj*
\v 14 \wj \w Entonces|strong="H3588"\w* \w Yo|strong="H3588"\w* \w también|strong="H1571"\w* reconoceré \w que|strong="H3588"\w* tu mano \w derecha|strong="H3225"\w* puede salvarte.\wj*
\p 
\v 15 \wj Contempla \w ahora|strong="H4994"\w* al hipopótamo al \w cual|strong="H5973"\w* \w hice|strong="H6213"\w* \w como|strong="H5973"\w* \w a|strong="H3068"\w* \w ti|strong="H5973"\w*. Come \w hierba|strong="H2682"\w* \w como|strong="H5973"\w* un buey.\wj*
\v 16 \wj \w Ciertamente|strong="H2009"\w* la \w fuerza|strong="H3581"\w* está en sus \w lomos|strong="H4975"\w*. Su \w vigor|strong="H3581"\w* en su vientre musculoso\wj*
\v 17 \wj cuando entiesa su \w cola|strong="H2180"\w* \w como|strong="H3644"\w* un cedro, y tensa los tendones de los muslos.\wj*
\v 18 \wj Sus \w huesos|strong="H6106"\w* son como tubos de bronce, su osamenta como barras de \w hierro|strong="H1270"\w*.\wj*
\p 
\v 19 \wj \w Él|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* principal de \w los|strong="H1931"\w* procedimientos de \nd \w ʼEL|strong="H1931"\w*\nd*. \w Solo|strong="H1931"\w* \w su|strong="H1931"\w* \w Hacedor|strong="H6213"\w* puede acercarle \w su|strong="H1931"\w* \w espada|strong="H2719"\w*.\wj*
\v 20 \wj Las montañas \w producen|strong="H5375"\w* hierba \w para|strong="H3588"\w* \w él|strong="H3588"\w*, \w y|strong="H3588"\w* las \w bestias|strong="H2416"\w* del \w campo|strong="H7704"\w* retozan \w allí|strong="H8033"\w*.\wj*
\v 21 \wj Se recuesta \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* las plantas \w de|strong="H8478"\w* loto y se oculta \w entre|strong="H8478"\w* los juncos del pantano.\wj*
\v 22 \wj Lo cubren los lotos con su sombra y lo rodean los sauces del \w arroyo|strong="H5158"\w*.\wj*
\v 23 \wj \w Ciertamente|strong="H3588"\w*, \w cuando|strong="H3588"\w* \w el|strong="H3588"\w* \w río|strong="H5104"\w* \w se|strong="H3808"\w* desborda, \w él|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* alarma. \w Aunque|strong="H3588"\w* \w el|strong="H3588"\w* \w Jordán|strong="H3383"\w* espumee contra \w su|strong="H3588"\w* hocico, queda tranquilo\wj*
\v 24 \wj ¿Puede alguien vigilarlo y capturarlo al perforar sus fosas nasales con un garfio?\wj*
\c 41
\p 
\v 1 \wj ¿Puedes tú sacar \w con|strong="H1571"\w* un anzuelo \w el|strong="H1571"\w* cocodrilo, atar \w con|strong="H1571"\w* una cuerda su lengua?\wj*
\v 2 \wj ¿Pondrás una soga \w en|strong="H3588"\w* \w su|strong="H1931"\w* nariz, \w y|strong="H3588"\w* perforarás \w con|strong="H3588"\w* garfio \w su|strong="H1931"\w* quijada?\wj*
\v 3 \wj ¿\w Se|strong="H1931"\w* acercará \w a|strong="H3068"\w* ti con palabras sumisas \w o|strong="H3068"\w* te hablará con lisonjas?\wj*
\v 4 \wj ¿Hará un pacto contigo para \w que|strong="H3808"\w* \w lo|strong="H1697"\w* tomes como esclavo perpetuo?\wj*
\v 5 \wj ¿Jugarás con \w él|strong="H4310"\w* como con un pájaro? ¿Lo atarás para entretener \w a|strong="H3068"\w* tus niñas?\wj*
\v 6 \wj ¿Los comerciantes harán negocio \w por|strong="H6440"\w* \w él|strong="H4310"\w*? ¿Lo cortarán en trozos entre los mercaderes?\wj*
\v 7 \wj ¿Podrás abrirle el cuero con lancetas, \w o|strong="H3068"\w* su cabeza con arpones?\wj*
\p 
\v 8 \wj Pon tu mano sobre \w él|strong="H5066"\w*. Recuerda la batalla con \w él|strong="H5066"\w*. \w No|strong="H3808"\w* \w lo|strong="H3808"\w* volverás \w a|strong="H3068"\w* hacer.\wj*
\v 9 \wj Ciertamente la esperanza de esta pelea queda frustrada. Un hombre desfallece con solo verlo.\wj*
\v 10 \wj \w Nadie|strong="H5869"\w* se atreve \w a|strong="H3068"\w* despertarlo. \wj*
\p \wj ¿Entonces quién puede estar en pie \w delante|strong="H5869"\w* \w de|strong="H5869"\w* Mí?\wj*
\v 11 \wj ¿Quién me dio primero \w a|strong="H3068"\w* Mí, para \w que|strong="H6310"\w* Yo le restituya? Todo lo \w que|strong="H6310"\w* hay debajo del cielo es mío.\wj*
\p 
\v 12 \wj No guardaré silencio acerca de sus miembros, ni de su gran fuerza ni de su excelente figura.\wj*
\v 13 \wj ¿Quién levanta la primera capa de su envoltura y penetra \w a|strong="H3068"\w* través de su doble coraza?\wj*
\v 14 \wj ¿Quién abre la parte posterior \w de|strong="H6440"\w* su boca rodeada \w de|strong="H6440"\w* dientes espantosos?\wj*
\p 
\v 15 \wj Sus fuertes escamas son su orgullo, cerradas \w entre|strong="H5921"\w* \w sí|strong="H5921"\w* \w como|strong="H5921"\w* firme sello,\wj*
\v 16 \wj tan unidas la una con la \w otra|strong="H3644"\w* que ni el aire pasa entre ellas.\wj*
\v 17 \wj Están soldadas, cada una \w a|strong="H3068"\w* su vecina, trabadas entre sí, no se pueden separar.\wj*
\v 18 \wj Su estornudo \w lanza|strong="H2595"\w* destellos de luz. Sus ojos son como los párpados de la aurora.\wj*
\v 19 \wj De la parte posterior de su boca salen llamaradas y se escapan centellas de fuego.\wj*
\v 20 \wj \w De|strong="H1121"\w* sus fosas nasales sale vapor como \w el|strong="H1121"\w* \w de|strong="H1121"\w* una olla \w que|strong="H3808"\w* hierve al fuego.\wj*
\v 21 \wj Su aliento enciende los carbones. Salen llamaradas de las partes posteriores de su boca.\wj*
\p 
\v 22 \wj \w En|strong="H5921"\w* su nuca \w se|strong="H5921"\w* asienta \w la|strong="H5921"\w* fuerza. Ante \w él|strong="H5921"\w* cunde \w el|strong="H5921"\w* terror.\wj*
\v 23 \wj Los pliegues de su carne son compactos. Están firmes en él y no se mueven.\wj*
\v 24 \wj Su corazón es duro como la piedra, como la piedra inferior de un molino.\wj*
\v 25 \wj Cuando \w se|strong="H5921"\w* levanta, tiemblan \w los|strong="H5921"\w* valientes, \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* quebrantamiento, retroceden.\wj*
\p 
\v 26 \wj \w La|strong="H1931"\w* espada \w no|strong="H5921"\w* \w lo|strong="H1931"\w* alcanza, ni \w la|strong="H1931"\w* lanza, ni \w la|strong="H1931"\w* lanceta, ni \w la|strong="H1931"\w* flecha, ni \w la|strong="H1931"\w* lanza arrojadiza.\wj*
\v 27 \wj Para él el hierro es como pasto, y el bronce, madera carcomida.\wj*
\v 28 \wj No lo ahuyentan las flechas. Las piedras de la honda le son como rastrojo.\wj*
\v 29 \wj Los garrotes le son como hojarasca. Se burla del brillo del arma arrojadiza.\wj*
\p 
\v 30 \wj Por debajo tiene conchas puntiagudas, se extiende como un trillo sobre el lodo.\wj*
\v 31 \wj Hace lo profundo del mar hervir como una olla. Lo convierte como una olla de ungüento.\wj*
\v 32 \wj Detrás de él brilla una estela de agua como barba encanecida.\wj*
\p 
\v 33 \wj Nada hay semejante \w a|strong="H3068"\w* él sobre la tierra. Fue hecho exento de temor.\wj*
\v 34 \wj Menosprecia todo lo elevado. Es rey de todos los hijos del orgullo.\wj*
\c 42
\s1 Arrepentimiento de Job
\p 
\v 1 Entonces Job \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*:
\v 2 \w Reconozco|strong="H3045"\w* \w que|strong="H3588"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w puedes|strong="H3201"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w ningún|strong="H3605"\w* propósito tuyo \w te|strong="H4480"\w* \w puede|strong="H3201"\w* ser estorbado.
\v 3 ¿\w Quién|strong="H4310"\w* \w es|strong="H2088"\w* \w el|strong="H4310"\w* \w que|strong="H4480"\w* oscurece \w el|strong="H4310"\w* \w consejo|strong="H6098"\w* \w sin|strong="H3808"\w* entendimiento? ¡\w Yo|strong="H4480"\w*! \w Porque|strong="H3808"\w* hablaba \w lo|strong="H2088"\w* \w que|strong="H4480"\w* \w no|strong="H3808"\w* \w entendía|strong="H3045"\w*, \w cosas|strong="H3045"\w* demasiado \w maravillosas|strong="H6381"\w* \w para|strong="H4480"\w* mí \w que|strong="H4480"\w* \w no|strong="H3808"\w* \w entendía|strong="H3045"\w*.
\p 
\v 4 \w Escúchame|strong="H8085"\w*, te \w ruego|strong="H4994"\w*, y \w hablaré|strong="H1696"\w*. Te \w preguntaré|strong="H7592"\w*, y Tú me enseñarás:
\v 5 \w De|strong="H5869"\w* oídas \w te|strong="H5869"\w* \w oí|strong="H8085"\w*, pero \w ahora|strong="H6258"\w* cuando mis \w ojos|strong="H5869"\w* \w te|strong="H5869"\w* \w miran|strong="H7200"\w*,
\v 6 \w me|strong="H5921"\w* \w aborrezco|strong="H3988"\w*, \w me|strong="H5921"\w* arrepiento \w y|strong="H5921"\w* \w me|strong="H5921"\w* echo \w en|strong="H5921"\w* \w polvo|strong="H6083"\w* \w y|strong="H5921"\w* ceniza.
\s1 Epílogo
\p 
\v 7 \w Después|strong="H1961"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w habló|strong="H1696"\w* estas \w Palabras|strong="H1697"\w* \w a|strong="H3068"\w* Job, \w aconteció|strong="H1961"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* Elifaz \w temanita|strong="H8489"\w*: \wj \w Mi|strong="H1961"\w* ira \w se|strong="H1961"\w* encendió \w contra|strong="H1961"\w* ti \w y|strong="H3588"\w* \w contra|strong="H1961"\w* tus \w dos|strong="H8147"\w* \w amigos|strong="H7453"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w hablaron|strong="H1696"\w* \w lo|strong="H1697"\w* \w recto|strong="H3559"\w* \w de|strong="H3588"\w* \w Mí|strong="H1961"\w*, \w como|strong="H3588"\w* \w mi|strong="H1961"\w* esclavo Job. \wj*
\p 
\v 8 \wj \w Tomen|strong="H3947"\w*, \w pues|strong="H3588"\w*, \w siete|strong="H7651"\w* \w becerros|strong="H6499"\w* \w y|strong="H3588"\w* \w siete|strong="H7651"\w* carneros, \w y|strong="H3588"\w* \w vayan|strong="H3212"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* esclavo Job \w y|strong="H3588"\w* ofrezcan \w holocausto|strong="H5930"\w* \w por|strong="H5921"\w* ustedes. \w Mi|strong="H5921"\w* esclavo Job intercederá \w por|strong="H5921"\w* ustedes, \w porque|strong="H3588"\w* \w Yo|strong="H3588"\w* \w levantaré|strong="H5375"\w* \w su|strong="H3588"\w* \w rostro|strong="H6440"\w*, \w para|strong="H5921"\w* \w no|strong="H3808"\w* \w hacer|strong="H6213"\w* \w con|strong="H5973"\w* ustedes \w conforme|strong="H5921"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* insensatez, \w pues|strong="H3588"\w* \w no|strong="H3808"\w* \w hablaron|strong="H1696"\w* \w de|strong="H5921"\w* \w Mí|strong="H5921"\w* \w lo|strong="H3808"\w* \w recto|strong="H5973"\w*, \w como|strong="H3588"\w* \w mi|strong="H5921"\w* esclavo Job. \wj*
\p 
\v 9 Elifaz \w temanita|strong="H8489"\w*, \w Bildad|strong="H1085"\w* sujita y Sofar \w naamatita|strong="H5284"\w* \w fueron|strong="H3212"\w* \w e|strong="H3068"\w* \w hicieron|strong="H6213"\w* como \nd \w Yavé|strong="H3068"\w*\nd* les ordenó.
\p \w Y|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w levantó|strong="H5375"\w* \w el|strong="H6213"\w* \w rostro|strong="H6440"\w* \w de|strong="H6440"\w* Job.
\v 10 \w Al|strong="H1157"\w* orar \w por|strong="H1157"\w* sus \w amigos|strong="H7453"\w*, \nd \w Yavé|strong="H3068"\w*\nd* restauró \w a|strong="H3068"\w* Job de su \w cautividad|strong="H7622"\w* y aumentó \w al|strong="H1157"\w* doble \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1157"\w* poseyó.
\v 11 Llegaron \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w todos|strong="H3605"\w* sus hermanos \w y|strong="H5921"\w* hermanas, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* sus antiguos conocidos. Comieron \w con|strong="H5973"\w* \w él|strong="H5921"\w* \w en|strong="H5921"\w* su \w casa|strong="H1004"\w*, \w y|strong="H5921"\w* \w se|strong="H3045"\w* condolieron \w de|strong="H5921"\w* \w él|strong="H5921"\w*. \w Lo|strong="H5921"\w* consolaron \w por|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* desgracia \w que|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* trajo \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*. \w Y|strong="H3068"\w* \w cada|strong="H3605"\w* uno \w le|strong="H5921"\w* \w dio|strong="H5414"\w* una pieza \w de|strong="H5921"\w* plata \w y|strong="H5921"\w* un anillo \w de|strong="H5921"\w* \w oro|strong="H2091"\w*.
\p 
\v 12 \nd \w Yavé|strong="H3068"\w*\nd* \w bendijo|strong="H1288"\w* \w los|strong="H1961"\w* últimos días de Job más \w que|strong="H1961"\w* \w los|strong="H1961"\w* primeros, porque \w tuvo|strong="H1961"\w* 14.000 \w ovejas|strong="H6629"\w*, 6.000 \w camellos|strong="H1581"\w*, 1.000 \w yuntas|strong="H6776"\w* de \w bueyes|strong="H1241"\w*, 1.000 asnas,
\v 13 y siete \w hijos|strong="H1121"\w* y \w tres|strong="H7969"\w* \w hijas|strong="H1323"\w*.
\v 14 \w A|strong="H3068"\w* la primera \w llamó|strong="H7121"\w* Jemima, \w a|strong="H3068"\w* la \w segunda|strong="H8145"\w* Casia y \w a|strong="H3068"\w* la \w tercera|strong="H7992"\w*, Keren-hapuc.
\v 15 \w En|strong="H8432"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w no|strong="H3808"\w* \w había|strong="H4672"\w* \w mujeres|strong="H1323"\w* tan \w hermosas|strong="H3303"\w* como \w las|strong="H1992"\w* \w hijas|strong="H1323"\w* \w de|strong="H5414"\w* Job, y \w su|strong="H1992"\w* padre \w les|strong="H1992"\w* \w dio|strong="H5414"\w* \w herencia|strong="H5159"\w* \w entre|strong="H8432"\w* \w sus|strong="H1992"\w* hermanos.
\p 
\v 16 Después \w de|strong="H1121"\w* \w estas|strong="H2063"\w* cosas, Job \w vivió|strong="H2421"\w* 140 \w años|strong="H8141"\w*, y \w vio|strong="H7200"\w* \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* y \w a|strong="H3068"\w* sus \w nietos|strong="H1121"\w* hasta \w la|strong="H2063"\w* cuarta \w generación|strong="H1755"\w*.
\v 17 \w Murió|strong="H4191"\w* \w anciano|strong="H2205"\w* y \w lleno|strong="H7649"\w* de \w días|strong="H3117"\w*. 
