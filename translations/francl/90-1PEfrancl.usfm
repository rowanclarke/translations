\v 14 \w Si|strong="G1487"\w* \w vous|strong="G5210"\w* \w êtes|strong="G5210"\w* \w outragés|strong="G3679"\w* \w pour|strong="G2532"\w* \w le|strong="G2532"\w* \w nom|strong="G3686"\w* \w du|strong="G2532"\w* \w Christ|strong="G5547"\w*, \w heureux|strong="G3107"\w* \w êtes-vous|strong="G5210"\w*, \w parce|strong="G2532"\w* \w que|strong="G3754"\w* \w l|strong="G2532"\w*’\w Esprit|strong="G4151"\w* \w de|strong="G2532"\w* \w gloire|strong="G1391"\w*\f + \fr 4:14 \ft 14. \fq Esprit de gloire\ft  ; quelques manuscrits ajoutent et de puissance avec la Vulgate, qui de plus traduit deux fois le mot δόξης, \qt honoris et gloriae\qt*.\f* (\w et|strong="G2532"\w* \w de|strong="G2532"\w* \w puissance|strong="G2532"\w*), \w l|strong="G2532"\w*’\w Esprit|strong="G4151"\w* \w de|strong="G2532"\w* \w Dieu|strong="G2316"\w* repose \w sur|strong="G1909"\w* \w vous|strong="G5210"\w*.
\v 15 \w Que|strong="G1063"\w* \w nul|strong="G3361"\w* \w d|strong="G5613"\w*’entre \w vous|strong="G5210"\w* \w ne|strong="G3361"\w* \w souffre|strong="G3958"\w* \w comme|strong="G5613"\w* \w meurtrier|strong="G5406"\w*, \w comme|strong="G5613"\w* \w voleur|strong="G2812"\w* \w ou|strong="G2228"\w* \w malfaiteur|strong="G2555"\w*, \w ou|strong="G2228"\w* \w comme|strong="G5613"\w* avide\f + \fr 4:15 \ft 15. \fq Avide\ft , etc. ; c’est le sens attribué au mot grec par la Vulgate. Ce mot, qui ne se rencontre nulle part ailleurs, signifie étymologiquement : \qt qui s’attribue une surveillance sur des choses étrangères\qt*, qui s’ingère dans les affaires d’autrui.\f* \w du|strong="G5613"\w* \w bien|strong="G2228"\w* \w d|strong="G5613"\w*’\w autrui|strong="G5100"\w*.
\v 16 \w Mais|strong="G1161"\w* \w s|strong="G1487"\w*’\w il|strong="G1161"\w* souffre \w comme|strong="G5613"\w* \w chrétien|strong="G5546"\w*, \w qu|strong="G3588"\w*’\w il|strong="G1161"\w* \w n|strong="G3361"\w*’\w en|strong="G1722"\w* \w ait|strong="G1161"\w* \w pas|strong="G3361"\w* honte ; \w plutôt|strong="G1161"\w*, \w qu|strong="G3588"\w*’\w il|strong="G1161"\w* \w glorifie|strong="G1392"\w* \w Dieu|strong="G2316"\w* \w pour|strong="G1161"\w* \w ce|strong="G3778"\w* \w même|strong="G1161"\w* \w nom|strong="G3686"\w*.
\v 17 \w Car|strong="G3754"\w* \w voici|strong="G1161"\w* \w le|strong="G1161"\w* \w temps|strong="G2540"\w* \w où|strong="G1161"\w* \w le|strong="G1161"\w* \w jugement|strong="G2917"\w*\f + \fr 4:17 \ft 17. \fq Le jugement\ft , les épreuves (verset 12) de la jeune Église chrétienne, la véritable \qt maison de Dieu\qt* (I Tim, 3, 15), destinées à la purifier.\f* \w va|strong="G2917"\w* \w commencer|strong="G2917"\w* \w par|strong="G1161"\w* \w la|strong="G1161"\w* \w maison|strong="G3624"\w* \w de|strong="G3588"\w* \w Dieu|strong="G2316"\w*. \w Et|strong="G1161"\w* \w s|strong="G1487"\w*’\w il|strong="G1161"\w* \w commence|strong="G4412"\w* \w par|strong="G1161"\w* \w nous|strong="G2249"\w*, \w quelle|strong="G5101"\w* \w sera|strong="G3624"\w* \w la|strong="G1161"\w* \w fin|strong="G5056"\w* \w de|strong="G3588"\w* \w ceux|strong="G3588"\w* \w qui|strong="G3588"\w* \w n|strong="G3754"\w*’obéissent \w pas|strong="G1487"\w* \w à|strong="G2316"\w* \w l|strong="G1161"\w*’\w Évangile|strong="G2098"\w* \w de|strong="G3588"\w* \w Dieu|strong="G2316"\w* ?
\v 18 \w Et|strong="G2532"\w* « \w si|strong="G1487"\w* \w le|strong="G2532"\w* \w juste|strong="G1342"\w* \w est|strong="G3588"\w* \w sauvé|strong="G4982"\w* \w avec|strong="G2532"\w* \w peine|strong="G3433"\w*, \w que|strong="G2532"\w* deviendra \w l|strong="G2532"\w*’impie \w et|strong="G2532"\w* \w le|strong="G2532"\w* \w pécheur|strong="G2532"\w* ? »\f + \fr 4:18 \ft 18. Citation libre de Prov. 11, 31.\f*
\v 19 \w Que|strong="G2532"\w* \w ceux|strong="G3588"\w* \w qui|strong="G3588"\w* \w souffrent|strong="G3958"\w* \w selon|strong="G2596"\w* \w la|strong="G2532"\w* \w volonté|strong="G2307"\w* \w de|strong="G2532"\w* \w Dieu|strong="G2316"\w*, \w lui|strong="G2532"\w* confient \w leurs|strong="G2532"\w* \w âmes|strong="G5590"\w* \w comme|strong="G2532"\w* \w au|strong="G1722"\w* \w Créateur|strong="G3588"\w* \w fidèle|strong="G4103"\w*, \w en|strong="G1722"\w* pratiquant \w le|strong="G2532"\w* \w bien|strong="G2532"\w*.\f + \fr 4:19 \ft 19. Comp. 1 Cor. 10, 13.\f*
\c 5
\cp 5
\s1 III. — DERNIERS AVIS À LA COMMUNAUTÉ CHRÉTIENNE.
\s2 Chap. 5, 1-11. — Devoirs des chefs de la communauté (1-4) et des fidèles (4-5a). — Devoirs communs : humilité (5b-7), vigilance (8-9), confiance en Dieu (10-11).
\p 
\v 1 \w J|strong="G2532"\w*’\w exhorte|strong="G3870"\w* \w les|strong="G2532"\w* \w anciens|strong="G4245"\w* \w qui|strong="G3588"\w* \w sont|strong="G3588"\w* \w parmi|strong="G1722"\w* \w vous|strong="G5210"\w*, \w moi|strong="G3588"\w* \w ancien|strong="G4245"\w* \w comme|strong="G2532"\w* \w eux|strong="G2532"\w*, \w témoin|strong="G3144"\w* \w des|strong="G2532"\w* \w souffrances|strong="G3804"\w* \w du|strong="G2532"\w* \w Christ|strong="G5547"\w*, \w et|strong="G2532"\w* \w qui|strong="G3588"\w* \w prendrai|strong="G2532"\w* \w part|strong="G2532"\w* \w avec|strong="G1722"\w* \w eux|strong="G2532"\w* \w à|strong="G1722"\w* \w la|strong="G2532"\w* \w gloire|strong="G1391"\w* \w qui|strong="G3588"\w* \w doit|strong="G3195"\w* \w être|strong="G2532"\w* manifestée :\f + \fr 5:1 \ft 5, 1. πρεσβυτήρους, \fq anciens\ft  : ce mot désignait alors les préposés des diverses communautés, prêtres ou évêques.\f*
\v 2 \w paissez|strong="G4165"\w* \w le|strong="G1722"\w* \w troupeau|strong="G4168"\w* \w de|strong="G1722"\w* \w Dieu|strong="G2316"\w* \w qui|strong="G3588"\w* \w vous|strong="G5210"\w* \w est|strong="G3588"\w* confié, veillant \w sur|strong="G1722"\w* \w lui|strong="G5210"\w*, \w non|strong="G3361"\w* \w par|strong="G1722"\w* \w contrainte|strong="G3361"\w*, mais \w de|strong="G1722"\w* \w bon|strong="G1722"\w* \w gré|strong="G1722"\w* ; \w non|strong="G3361"\w* \w dans|strong="G1722"\w* \w un|strong="G1722"\w* intérêt sordide, mais \w par|strong="G1722"\w* \w dévouement|strong="G4290"\w* ;
