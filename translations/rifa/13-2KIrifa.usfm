\id 2KI
\h 2 إِجدْجِيذنْ 
\toc1 2 إِجدْجِيذنْ 
\toc2 2 إِجدْجِيذنْ 
\toc3 2 إِج. 
\mt1 2 إِجدْجِيذنْ  
\c 1
\s1 إِلِييَا أَكْ-ذ أَخَازْيَا - ڒْموْثْ ن أَخَازْيَا  
\m
\v 1 أَوَارْنِي ڒْموْثْ ن أَخَابْ إِغوّغْ مُوآبَ خْ إِسْرَائِيل. \x ◘ \xo 1:‏1 \xt 2 إِج. 3‏:‏5\x*  
\v 2 إِوْضَا-د أَخَازْيَا س ثْرَاشَّا ن ڒْكَازِي ن ثْغُورْفثْ نّسْ ذِي سَامَارْيَا ؤُشَا إِهْڒشْ. نتَّا إِسّكّْ إِرقَّاسنْ إِنَّا أَسنْ: ”رُوحمْ غَارْ بَاعَالْ-زابُوبْ، أَربِّي نْ عَاقْرُونْ، مَاحنْذْ أَذْ ثسّقْسَامْ مَا وَارْ ذ أَيِي إِنقّْ ڒهْڒَاشْ-أَ.“   
\m
\v 3 مَاشَا لْمَالَاكْ ن سِيذِي إِسِّيوڒْ-د غَارْ إِلِيشَاعْ، أَثِيشْبِي: ”كَّارْ، ڭعّذْ، ڒْقَا إِرقَّاسنْ ن ؤُجدْجِيذْ ن سَامَارْيَا ؤُ سِيوڒْ أَكِيذْسنْ: ’مَا س ثِيذتّْ وَارْ ذِينْ أَربِّي ذِي إِسْرَائِيل، أَڒَامِي كنِّيوْ ثُويُورمْ، حِيمَا أَذْ ثسّقْسَامْ بَاعَالْ-زابُوبْ، أَربِّي ن عَاقْرُونْ؟‘  
\v 4 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي: ’وَارْ د-ثْهكّْوِيذْ شَا زِي ثَاسُّوثْ إِ خْ ثْڭعّْذذْ، مَاشَا أَذْ ثمّْثذْ ڒْموْثْ.‘ “ ؤُشَا \add خنِّي\add* إِفّغْ إِلِييَا.   
\m
\v 5 \add ڒَْامِي\add* د -عقْبنْ إِرقَّاسنْ غَارْ \add أَخَازِييَا\add*، إِنَّا أَسنْ إِ نِيثْنِي: ”مِينْ \add إِخْسْ أَذْ يِينِي\add* مَانْ أَيَا، \add ڒَْامِي\add* د-ثْعقْبمْ عَاوذْ \add ذغْيَا\add*؟“ \f ◼ \fr 1:‏5 \ft \+bd ’\+bdit ڒَامِي\+bdit* د-عقْبنْ إِرقَّاسنْ غَارْ أَحَازْيَا‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒَامِي غَارسْ د-عقْبنْ إِرقَّاسنْ‘.\f*  
\v 6 نِيثْنِي أَرِّينْ-د خَاسْ: ”إِجّْ ن ورْيَازْ إِمْسَاڭَارْ أَكِيذْنغْ، إِنَّا أَنغْ: ’عقْبمْ غَارْ ؤُجدْجِيذْ ونِّي كنِّيوْ د-إِسّكّنْ، أَذْ أَسْ ثِينِيمْ: أَمُّو إِ إِسِّيوڒْ سِيذِي، مَا س ثِيذتّْ وَارْ غَارْومْ زعْمَا أَربِّي ذِي إِسْرَائِيل أَڒَامِي ثسّكّذْ، حِيمَا أَذْ ثسّقْسِيذْ بَاعَالْ-زابُوبْ، أَربِّي نْ عَاقْرُونْ؟ س ؤُيَا وَارْ د-ثْهكّْوِيذْ شَا زِي ثَاسُّوثْ إِ خْ ثْڭعّْذذْ، مَاشَا أَذْ ثمّْثذْ ڒْموْثْ.‘ “  
\v 7 نتَّا إِسِّيوڒْ أَكِيذْسنْ: ”مَامّشْ إِڭَّا وَادُّوذْ ن ورْيَازْ نِّي كِيذْومْ إِمْسَاڭَارنْ ؤُ إِسِّيوڒْ أَكِيذْومْ أَوَاڒنْ-أَ؟“  
\v 8 نِيثْنِي أَرِّينْ-د خَاسْ: ”نتَّا ذ إِجّْ ن ورْيَازْ غَارسْ \add إِجّْ ن ؤُپَارْثسُّو ن\add* ؤُشُوَّافْ، غَارسْ إِجّْ ن وبْيَاسْ ن شَّارْكْ خْ ثجْعِينَّا نّسْ.“ \add خنِّي\add* إِنَّا نتَّا: ”وَا ذ إِلِييَا، أَثِيشْبِي.“ \f ◼ \fr 1:‏8 \ft \+bd ’أَثِيشْبِي‘\+bd* - إِجّْ ن ورْيَازْ زِي ثنْذِينْثْ ن ثِيشْبِي.\f*   
\m
\v 9 نتَّا إِسّكّْ إِجّْ ن ؤُمقّْرَانْ ن خمْسِينْ أَكْ-ذ خمْسِينْ \add ن يرْيَازنْ\add* نّسْ غَارسْ. وَانِيثَا إِڭعّذْ غَارسْ، ؤُ خْزَارْ، إِلِييَا ثُوغَا إِتّْغِيمَا خْ ثْقِيشَّاثْ ن وذْرَارْ. ؤُ نتَّا إِسِّيوڒْ غَارسْ: ”\add شكْ،\add* أَرْيَازْ ن أَربِّي، أَجدْجِيذْ إِنَّا أَشْ: ’هْوَا-د!‘ “  
\v 10 إِلِييَا يَارَّا-د، إِنَّا إِ ؤُمقّْرَانْ ن خمْسِينْ: ”مَاڒَا نشّْ أَقَا ذ أَرْيَازْ ن أَربِّي، أجّْ أَذْ ثوْضَا ثْمسِّي زڭْ ؤُجنَّا، أَذْ شكْ ثشّْ، شكْ ذ خمْسِينْ \add ن يرْيَازنْ\add* نّشْ.“ \add ڒخْذنِّي\add* ثوْضَا-د ثْمسِّي زڭْ ؤُجنَّا، ثشَّا إِ-ث نتَّا ذ خمْسِينْ \add ن يرْيَازنْ\add* نّسْ.   
\m
\v 11 خَاسْ ؤُشَا إِسّكّْ غَارسْ عَاوذْ إِجّْ ن ؤُمقّْرَانْ نّغْنِي ن خمْسِينْ أَكْ-ذ خمْسِينْ \add ن يرْيَازنْ\add* نّسْ. وَانِيثَا إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا أَسْ: ”شكْ، \add أَ\add* أَرْيَازْ ن أَربِّي، أَمُّو إِ إِقَّارْ ؤُجدْجِيذْ: ’هْوَا-د ذغْيَا!‘ “  
\v 12 إِلِييَا يَارَّا-د ؤُشَا إِنَّا أَسنْ: ”مَاڒَا نشّْ ذ أَرْيَازْ ن أَربِّي، أَمُّو إِ د غَا ثوْضَا ثْمسِّي زڭْ ؤُجنَّا، أَذْ شكْ ثشّْ ذ يرْيَازنْ نّشْ،“ \add ڒخْذنِّي\add* ثوْضَا-د ثْمسِّي زڭْ ؤُجنَّا، ثشَّا إِ-ث نتَّا ذ خمْسِينْ \add ن يرْيَازنْ\add* نّسْ.   
\m
\v 13 إِسّكّْ عَاوذْ إِجّْ ن ؤُمقّْرَانْ ن خمْسِينْ إِ ثْوَاڒَا وِيسّْ ثْڒَاثَا، أَكْ-ذ خمْسِينْ \add ن يرْيَازنْ\add* نّسْ. \add ؤُمِي\add* إِڭعّذْ ؤُمقّْرَانْ ن خمْسِينْ وِيسّْ ثْڒَاثَا ؤُشَا يِيوضْ \add غَارسْ\add*، يُوضَارْ نتَّا خْ إِفَادّنْ نّسْ زَّاثْ إِ إِلِييَا ؤُشَا إِحشّمْ إِ-ث، إِنَّا أَسْ: ”\add أَ\add* أَرْيَازْ ن أَربِّي، أجّْ أَذْ ثسْوَا ثُوذَارْثْ إِنُو ذ ثُوذَارْثْ ن إِمْسخَّارنْ نّشْ، ن خمْسِينْ \add ن يرْيَازنْ-أَ\add*، ذِي ثِيطَّاوِينْ نّشْ.  
\v 14 خْزَارْ، ثِيمسِّي ثوْضَا-د زڭْ ؤُجنَّا، ثشَّا ثْنَاينْ ن إِمقّْرَاننْ ن خمْسِينْ أَكْ-ذ خمْسِينْ \add ن يرْيَازنْ\add* نْسنْ. أجّْ أَذْ ثسْوَا ڒخُّو ثُوذَارْثْ إِنُو ذِي ثِيطَّاوِينْ نّشْ!“   
\m
\v 15 ؤُشَا إِنَّا لْمَالَاكْ ن سِيذِي إِ إِلِييَا: ”هْوَا أَكِيذسْ، وَارْ تّڭّْوذْ شَا زَّاثْ إِ وُوذمْ نّسْ!“ إِكَّارْ نتَّا، إِهْوَا أَكِيذسْ غَارْ ؤُجدْجِيذْ.  
\v 16 \add خَاسْ ؤُشَا\add* إِسِّيوڒْ أَكْ-ذ ؤُجدْجِيذْ: ”أَمُّو إِ إِقَّارْ سِيذِي: ’مَاغَارْ شكْ ثسّكّذْ إِرقَّاسنْ نّشْ، حِيمَا أَذْ سّقْسَانْ بَاعَالْ-زابُولْ، أَربِّي ن عَاقْرُونْ، أَخْمِي وَارْ ذِينْ إِدْجِي س ثِيذتّْ أَربِّي ذِي إِسْرَائِيل، حِيمَا أَذْ \add ث\add* ثسّقْسِيذْ خْ وَاوَاڒْ نّسْ، س ؤُيَا وَارْ د-ثْهكّْوِيذْ شَا زِي ثَاسُّوثْ إِ خْ ثْڭعّْذذْ، مَاشَا أَذْ ثمّْثذْ ڒْموْثْ.‘ “  
\v 17 \add أَمُّو\add* إِ إِمُّوثْ عْلَاحْسَابْ أَوَاڒْ ن سِيذِي إِ ثُوغَا إِسِّيوڒْ إِلِييَا. مَاغَارْ نتَّا ثُوغَا وَارْ غَارسْ بُو مِّيسْ، إِذْوڒْ يُورَامْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ ن يَاهُورَامْ، مِّيسْ ن يَاهُوشَافَاطْ، أَجدْجِيذْ ن يَاهُوذَا.   
\m
\v 18 إِمزْرُوينْ إِقِّيمنْ ن أَخَازْيَا، ذ مِينْ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل؟   
\b  
\b  
\m  
\c 2
\s1 إِلِييَا إِتّْوَامّكْسِي غَارْ ؤُجنَّا  
\m
\v 1 إِمْسَارْ غَارْ ثْمكْسِيثْ ن إِلِييَا س \add ؤُفُوسْ ن\add* سِيذِي ذڭْ إِشْثْ ن ثْحَارْيَاضْثْ غَارْ ؤُجنَّا، أَقَا إِفّغْ إِلِييَا أَكْ-ذ إِلِيشَاعْ زِي جِيلْجَالْ.  
\v 2 إِنَّا إِلِييَا إِ إِلِيشَاعْ: ”قِّيمْ ذَا، مَاغَارْ سِيذِي إِسّكّْ أَيِي غَارْ بَايْثْ-إِلْ.“ \add مَاشَا\add* إِلِيشَاعْ إِنَّا:”س ثِيذتّْ أَمْ إِدَّارْ سِيذِي ؤُ إِدَّارْ ڒعْمَارْ نّشْ، نشّْ وَارْ شكْ تّجِّيغْ.“ \add أَمُّو إِ\add* هْوَانْ نِيثْنِي \add س ثْنَاينْ\add* غَارْ بَايْثْ-إِلْ.  
\v 3 فّْغنْ-د أَيْثْ ن إِنَابِييّنْ، إِنِّي \add ثُوغَا إِدْجَانْ\add* ذِي بَايْثْ-إِلْ، غَارْ إِلِيشَاعْ، نَّانْ أَسْ: ”مَا ثسّْنذْ، أَقَا سِيذِي أَسّْ-أَ أَذْ إِكّسْ بَابْ نّشْ ثِيوَا إِ ؤُزدْجِيفْ نّشْ؟“ نتَّا يَارَّا-د: ”ؤُڒَا ذ نشّْ أَقَا سّْنغْ ث. سْقَارمْ!“   
\m
\v 4 إِلِييَا إِنَّا أَسْ: ”قِّيمْ ذَا، إِلِيشَاعْ، مَاغَارْ سِيذِي إِسّكّْ أَيِي غَارْ أَرِيحَا.“ مَاشَا نتَّا إِنَّا: ”س ثِيذتّْ أَمْ إِدَّارْ سِيذِي ؤُ إِدَّارْ ڒعْمَارْ نّشْ، نشّْ وَارْ شكْ تّجِّيغْ شَا!“ \add أَمُّو\add* د-ؤُسِينْ نِيثْنِي غَارْ أَرِيحَا.  
\v 5 \add خنِّي\add* ؤُسِينْ-د أَيْثْ ن إِنَابِييّنْ نِّي \add إِدْجَانْ\add* ذِي أَرِيحَا غَارْ إِلِيشَاعْ، نَّانْ أَسْ: ”مَا ثسّْنذْ، أَقَا سِيذِي أَسّْ-أَ أَذْ إِكّسْ بَابْ نّشْ ثِيوَا إِ ؤُزدْجِيفْ نّشْ؟“ نتَّا يَارَّا-د: ”ؤُڒَا ذ نشّْ أَقَا سّْنغْ ث. سْقَارمْ!“   
\m
\v 6 إِلِييَا مَاشَا إِنَّا أَسْ: ”قِّيمْ ذَا، مَاغَارْ سِيذِي إِسّكّْ أَيِي غَارْ لْ-ؤُرْذُونْ.“ \add مَاشَا\add* نتَّا إِنَّا: ”س ثِيذتّْ أَمْ إِدَّارْ سِيذِي ؤُ أَمْ إِدَّارْ ڒعْمَارْ إِنُو، نشّْ وَارْ شكْ تّجِّيغْ شَا!“ ؤُشَا نِيثْنِي ؤُيُورنْ س ثْنَاينْ إِذْسنْ.  
\v 7 ؤُڒَا ذ خمْسِينْ ن يرْيَازنْ زڭْ أَيْثْ ن إِنَابِييّنْ ؤُيُورنْ، قِّيمنْ بدّنْ أَرنْذَاذْ نْسنْ غَارْ ڒَاڭّْوَاجْ، أَمْ بدّنْ نِيثْنِي س ثْنَاينْ إِذْسنْ غَارْ لْ-ؤُرْذُونْ.  
\v 8 \add خنِّي\add* إِكْسِي إِلِييَا أَسڒْهَامْ نّسْ، إِسُّونّضْ إِ-ث ؤُشَا إِوْثَا زَّايسْ خْ وَامَانْ نِّي تّْوَابْضَانْ خْ ثْنَاينْ ن إِغزْذِيسنْ ؤُ نِيثْنِي ژْوَانْ س ثْنَاينْ إِذْسنْ خْ ڒَاژَاغْ.  
\v 9 ڒَامِي ژْوَانْ نِيثْنِي، إِمْسَارْ، أَقَا إِلِييَا إِنَّا إِ إِلِيشَاعْ: ”تَّارْ إِشْثْ ن ڒْحَاجّثْ إِ ذ أَشْ غَا ڭّغْ، قْبڒْ مَّا خَاكْ إِ غَا مّكْسِيغْ!“ إِلِيشَاعْ يَارَّا-د: ”إِڒِي أَذْ خَافِي د-هْوَانْثْ ثْنَاينْ ن ثْسقَّارْ ن بُوحْبڒْ نّشْ!“  
\v 10 إِلِييَا إِنَّا: ”شكْ ثتَّارذْ إِشْثْ ن ثْمسْڒَاشْثْ ثوْعَارْ. مَاڒَا شكْ ثژْرِيذْ أَيِي ڒَامِي خَاكْ إِ غَا مّكْسِيغْ، أَذْ أَشْ إِمْسَارْ أَمُّو، مَاشَا مَاڒَا وَارْ إِدْجِي أَمنِّي، وَارْ إِتّمْسَارْ شَا.“   
\m
\v 11 ؤُشَا إِمْسَارْ أَمْ نِيثْنِي ڭُّورنْ ؤُ سَّاوَاڒنْ أَكْ-ذ وَايَاوْيَا، خْزَارْ، أَقَا ذِينْ إِشْثْ ن ثْكَارُّوثْ ن ثْمسِّي أَكْ-ذ إِيْسَانْ ن ثْمسِّي ثنِّي ثبْضَا إِ-ثنْ إِجّْ خْ ونّغْنِي. \add أَمُّو\add* إِڭعّذْ إِلِييَا ذِي ثْحَارْيَاضْثْ غَارْ ؤُجنَّا.  
\v 12 إِلِيشَاعْ إِژْرَا ؤُشَا إِڒَاغَا خَاسْ: ”\add أَ\add* بَابَا، \add أَ\add* بَابَا! أَكَارُّو \add ن ؤُمنْغِي\add* ن إِسْرَائِيل ذ إِمْنَاينْ نّسْ!“ \add خنِّي\add* نتَّا وَارْ ث إِثْوِيڒِي عَاذْ ؤُشَا إِكْسِي أَرُّوضْ نّسْ، إِشَارّڭْ إِ-ث خْ ثْنَاينْ. \x ◘ \xo 2:‏12 \xt 2 إِج. 13‏:‏14\x*  
\v 13 خنِّي إِسّْمُونْ-د أَسڒْهَامْ إِ د-يوْضَانْ زَّايسْ نتَّا ؤُشَا إِعْقبْ، إِبدّْ غَارْ ثْمَا ن لْ-ؤُرْذُونْ.  
\v 14 نتَّا إِكْسِي أَسڒْهَامْ ن إِلِييَا إِ د-يوْضَانْ زَّايسْ نتَّا، إِوْثَا زَّايسْ خْ وَامَانْ، إِنَّا: ”مَانِي إِدْجَا سِيذِي أَربِّي ن إِلِييَا؟ وَاهْ، نتَّا!“ ؤُشَا نتَّا إِوْثَا خْ وَامَانْ ؤُشَا مّْسبْضَانْ نِيثْنِي خْ ثْنَاينْ ن إِغزْذِيسنْ ؤُشَا إِژْوَا إِلِيشَاعْ.   
\m
\v 15 \add ؤُمِي\add* أَيْثْ ن إِنَابِييّنْ نِّي \add ذِينْ\add* إِبدّنْ أَرنْذَاذْ ن أَرِيحَا، ژْرِينْ ث، نَّانْ: ”بُوحْبڒْ نْ إِلِييَا يَارْسَا خْ إِلِيشَاعْ.“ نِيثْنِي ؤُسِينْ-د غَارسْ ؤُشَا ؤُضَارنْ زَّاثسْ \add س ؤُغمْبُوبْ نْسنْ\add* غَارْ ثمُّورْثْ.  
\v 16 نِيثْنِي نَّانْ أَسْ: ”خْزَارْ خنِّي، جَارْ إِمْسخَّارنْ نّشْ \add أَقَا ذِينْ\add* خمْسِينْ ن يرْيَازنْ، أَيْثْ ن ؤُمنْغِي. أجّْ إِ-ثنْ أَذْ ؤُيُورنْ، أَذْ أَرْزُونْ خْ سِيذِي نّشْ، أَذْ ثَاغْ سِيذِي إِكْسِي ث ؤُشَا إِنْضَارْ إِ-ث خْ إِجّْ ن وذْرَارْ نِيغْ ذڭْ إِشْثْ زِي ثغْزُورِينْ.“ \add مَاشَا\add* نتَّا إِنَّا: ”وَارْ سكِّيمْ ؤُڒَا ذ إِجّْ!“  
\v 17 ؤُمِي خَاسْعمّْذنْ نِيثْنِي أَڒَامِي ذ أَسْ إِودَّارْ مِينْ غَا يڭّْ، إِنَّا: ”\add إِوَا\add* سكّمْ \add ثنْ ذِينْ\add*!“ نِيثْنِي سّكّنْ خمْسِينْ ن يرْيَازنْ ذ إِنَا أَرْزُونْ ثْڒَاثَا ن وُوسَّانْ، مَاشَا نِيثْنِي وَارْ ث ؤُفِينْ.  
\v 18 ؤُشَاعقْبنْ-د نِيثْنِي غَارسْ، مِينْزِي ثُوغَا إِقِّيمْ ذِي أَرِيحَا. نتَّا إِنَّا أَسنْ: ”مَا وَارْ ذ أَومْ نِّيغْ: ’وَارْ تّْرِيحمْ شَا‘؟“   
\b  
\m  
\s1 إِلِيشَاعْ إِسّْڭنْفَا أَمَانْ ن أَرِيحَا  
\m
\v 19 إِرْيَازنْ ن ثنْذِينْثْ نَّانْ إِ إِلِيشَاعْ: ”خْزَارْ خنِّي، أَدُّوذْ ن ثنْذِينْثْ مْلِيحْ، أَمْ مَامّشْ إِتّْوَاڒَا سِيذِي إِنُو سِيمَانْثْ نّسْ، مَاشَا أَمَانْ وَارْ إِحْڒِينْ ؤُ ثَامُّورْثْ ثِيوِي-د أَڭْرَايْ.“  
\v 20 نتَّا إِنَّا: ”أَوْيمْ أَيِي-د إِجّْ ن طّبْسِي ذ أَمَايْنُو ؤُ ڭّمْ ذَايسْ ثَامدْجَاحْثْ!“ ؤُشَا نِيثْنِي إِوْينْ أَسْ ث-إِ-د.  
\v 21 \add خنِّي\add* إِفّغْ \add زِي ثنْذِينْثْ\add* غَارْ ثَاڒَا ن وَامَانْ ؤُشَا إِنْضَارْ ذَايسْ ثَامدْجَاحْثْ نِّي، إِنَّا: ”أَمُّو إِ إِقَّارْ سِيذِي: ’نشّْ أَرِّيغْ أَمَانْ-أَ صبْحنْ. وَارْ د-تِّيوْينْ ڒْموْثْ نِيغْ ذ أَڭْرَايْ عَاذْ.‘ “  
\v 22 أَمَانْ ذوْڒنْ صبْحنْ عَاوذْ أَڒْ أَسّْ-أَ عْلَاحْسَابْ أَوَاڒْ ن إِلِيشَاعْ إِ إِسِّيوڒْ.   
\b  
\m  
\s1 إِحُوذْرِييّنْ سّحْقَارنْ إِلِيشَاعْ ذِي بَايْثْ-إِلْ  
\m
\v 23 سّنِّي إِڭعّذْ غَارْ بَايْثْ-إِلْ. \add أَمْ\add* إِتّْڭعّذْ أَبْرِيذْ، فّْغنْ-د إِحُوذْرِييّنْ زِي ثنْذِينْثْ، إِنِّي ث إِكّْوَارنْ، نَّانْ أَسْ: ”أَقشَّارْ، ڭعّذْ! أَقشَّارْ، ڭعّذْ!“  
\v 24 نتَّا إِنّقْڒبْ-د أَوَارْنِي أَسْ، إِخْزَارْ ذَايْسنْ ؤُشَا إِخْزَا إِ-ثنْ ذڭْ يِيسمْ ن سِيذِي. ڒخْذنِّي ؤُسِينْ-د ثْنَاينْ ن دُّوبَاثْ زڭْ وزْغَارْ ؤُ مزّْقنْ ثْنَاينْ-ؤُ-ربْعِينْ ن إِحُوذْرِييّنْ. \f ◼ \fr 2:‏24 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  
\v 25 سّنِّي يُويُورْ نتَّا غَارْ وذْرَارْ ن كَارْمِيلْ ؤُشَا سّنِّي إِعْقبْ غَارْ سَامَارْيَا.   
\b  
\b  
\m  
\c 3
\s1 أَمنْغِي ن يُورَامْ، أَجدْجِيذْ ن إِسْرَائِيل أَكْ-ذ مُوآبَ  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْمنْطَاشْ ن يَاهُوشَافَاطْ، أَجدْجِيذْ ن يَاهُوذَا، إِذْوڒْ يُورَامْ، مِّيسْ ن أَخَابْ، ذ أَجدْجِيذْ خْ إِسْرَائِيل ذِي سَامَارْيَا. نتَّا إِحْكمْ ثنْعَاشْ ن إِسڭّْوُوسَا.  
\v 2 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، مَاشَا وَارْ \add ث إِڭِّي\add* أَمُّو \add ذ ثَاعفَّانْثْ\add* أَمْ بَابَاسْ ذ يمَّاسْ، مَاغَارْ إِكّسْ أَمَايْضُو \add إِقدّْسنْ\add* ن بَاعَالْ ونِّي إِڭَّا بَابَاسْ. \x ◘ \xo 3:‏2 \xt 1 إِج. 16‏:‏32\x*  
\v 3 مَاشَا نتَّا إِقِّيمْ إِمنّعْ ذِي دّْنُوبْ ن يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، ونِّي يَارِّينْ إِسْرَائِيل أَذْ إِخْضَا. نتَّا وَارْ إِحيّذْ خْ دّْنُوبْ ن يَارُوبْعَامْ.  
\v 4 مِيشَاعْ، أَجدْجِيذْ ن مُوآبَ، ثُوغَا ذ أَمكْسَاوْ ؤُ ثُوغَا إِتِّيشْ إِ ؤُجدْجِيذْ ن إِسْرَائِيل مْيَاثْ-أَڒفْ ن إِزْمَارنْ ذ ثَاضُوفْثْ ن مْيَاثْ-أَڒفْ ن إِشَارِّييّنْ. \f ◼ \fr 3:‏4 \ft \+bd ’أَمكْسَاوْ‘\+bd* - نِيغْ ’أَنِيتْشيِ‘.\f*  
\v 5 ڒَامِي إِمُّوثْ أَخَابْ، إِمْسَارْ، أَقَا إِغوّغْ ؤُجدْجِيذْ ن مُوآبَ خْ ؤُجدْجِيذْ ن إِسْرَائِيل. \x ◘ \xo 3:‏5 \xt 2 إِج. 1‏:‏1\x*   
\m
\v 6 ذڭْ وَاسّْ نِّي إِفّغْ-د ؤُجدْجِيذْ يُورَامْ زِي سَامَارْيَا ؤُشَا إِسدّْ مَارَّا إِسْرَائِيل.  
\v 7 إِطّفْ أَبْرِيذْ ؤُشَا إِسّكّْ \add إِجّْ ن ؤُرقَّاسْ\add* غَارْ يَاهُوشَافَاطْ، أَجدْجِيذْ ن يَاهُوذَا، إِنَّا: ”أَجدْجِيذْ ن مُوآبَ إِغوّغْ خَافِي. مَا شكْ أَذْ كِيذِي ثفّْغذْ ذڭْ ؤُمنْغِي أَكْ-ذ مُوآبَ؟“ نتَّا إِنَّا: ”نشّْ أَذْ فّْغغْ أَكِيذكْ. نشّْ أَذْ إِڒِيغْ أَمْ شكْ، ڒْڭنْسْ إِنُو أَمْ ڒْڭنْسْ نّشْ ذ إِيْسَانْ إِنُو أَمْ يِييْسَانْ نّشْ.“ \x ◘ \xo 3:‏7 \xt 1 إِج. 22‏:‏4\x*  
\v 8 إِنَّا: ”خْ مَانْ أَبْرِيذْ إِ غَا نْڭعّذْ؟“ نتَّا إِنَّا: ”خْ وبْرِيذْ ن ڒخْڒَا ن إِذُومْ.“   
\m
\v 9 \add ڒخْذنِّي\add* يُويُورْ ؤُجدْجِيذْ ن إِسْرَائِيل ذ ؤُجدْجِيذْ ن يَاهُوذَا ذ ؤُجدْجِيذْ ن إِذُومْ. نِيثْنِي نّْضنْ إِجّْ ن وبْرِيذْ ن سبْعَا ن وُوسَّانْ ؤُشَا وَارْ ثُوغِي ذِينْ أَمَانْ إِ ڒْعسْكَارْ ؤُ إِ ڒبْهَايمْ نِّي ثنْ إِضْفَارنْ.  
\v 10 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ ن إِسْرَائِيل: ”أَخيّبْ إِ نشِّينْ ؤُمِي د-إِڒَاغَا سِيذِي ثْڒَاثَا ن إِجدْجِيذنْ-أَ، حِيمَا أَذْ ثنْ إِوْشْ ذڭْ ؤُفُوسْ ن مُوآبَ!“  
\v 11 ؤُشَا يَاهُوشَافَاطْ إِنَّا: ”مَا وَارْ ذَا إِدْجِي إِجّْ ن ؤُنَابِي ن سِيذِي، ونِّي إِ زِي غَا نسّقْسَا سِيذِي؟“ \add خنِّي\add* يَارَّا-د إِجّنْ زڭْ إِمْسخَّارنْ ن ؤُجدْجِيذْ ن إِسْرَائِيل، إِنَّا: ”إِلِيشَاعْ، مِّيسْ ن شَافَاثْ، ونِّي إِزدْجْعنْ أَمَانْ خْ إِفَاسّنْ ن إِلِييَا، أَقَا-ث ذَانِيثَا!“ \x ◘ \xo 3:‏11 \xt 1 إِج. 22‏:‏7\x*   
\m
\v 12 ؤُشَا إِنَّا يَاهُوشَافَاطْ: ”غَارسْ نتَّا أَوَاڒْ ن سِيذِي.“ ؤُشَا أَجدْجِيذْ ن إِسْرَائِيل ذ يَاهُوشَافَاطْ ذ ؤُجدْجِيذْ ن إِذُومْ هْوَانْ-د غَارسْ.  
\v 13 إِلِيشَاعْ إِنَّا إِ ؤُجدْجِيذْ ن إِسْرَائِيل: ”مِينْ ذِينِّي جَارْ أَيِي-د ذ شكْ؟ ؤُيُورْ غَارْ إِنَابِييّنْ ن بَابَاشْ ؤُ غَارْ إِنَابِييّنْ ن يمَّاشْ!“ مَاشَا أَجدْجِيذْ ن إِسْرَائِيل يَارَّا-د خَاسْ: ”لَّ، مَاغَارْ سِيذِي إِڒَاغَا-د إِ ثْڒَاثَا-يَا ن إِجدْجِيذنْ \add غَارْ ذَا\add*، حِيمَا أَذْ ثنْ إِوْشْ ذڭْ ؤُفُوسْ ن مُوآبَ.“ \x ◘ \xo 3:‏13 \xt 1 إِج. 18‏:‏19\x*  
\v 14 إِلِيشَاعْ يَارَّا-د خَاسْ: ”\add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي ن ڒْعسْكَارَاثْ نِّي ؤُمِي بدّغْ زَّاثْ إِ وُوذمْ نّسْ، مْڒِي نشّْ وَارْ غَارِي بُو ؤُوقَّارْ إِ يَاهُوشَافَاطْ، أَجدْجِيذْ ن يَاهُوذَا، أَذْ يِيڒِي نشّْ وَارْ شكْ حسّْبغْ ؤُ وَارْ ذَايكْ خزَّارغْ! \x ◘ \xo 3:‏14 \xt 1 إِج. 17‏:‏1\x*  
\v 15 \add خنِّي\add* ڒخُّو، أَوِي أَيِي-د إِجّْ إِشَّاثْ خْ إِفِيڒَانْ. ڒَامِي ثُوغَا إِتِّيرَارْ ونِّي إِشَّاثنْ خْ إِفِيڒَانْ، إِمْسَارْ أَقَا أَفُوسْ ن سِيذِي يَارْسَا خَاسْ.  
\v 16 إِنَّا نتَّا: ”أَمُّو إِ إِقَّارْ سِيذِي: ’ڭّمْ ذِي ثغْزُورْثْ-أَ ثَاڒْيِيوِينْ ذ ثڒْيِيوِينْ \add كْثَارْ\add*!‘  
\v 17 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي: ’كنِّيوْ وَارْ ثْژَارّمْ أَسمِّيضْ ؤُڒَا ذ أَنْژَارْ، \add مَاشَا وَاخَّا أَمنِّي\add* ثَاغْزُورْثْ-أَ أَذْ ثشُّورْ س وَامَانْ ؤُشَا كنِّيوْ أَذْ ثسّْومْ، كنِّيوْ ؤُڒَا ذ ڒبْهَايمْ نْومْ ذ زّْوَايڒْ نْومْ.‘  
\v 18 \add مَاشَا\add* مَانْ أَيَا \add عَاذْ\add* ذْرُوسْ ذِي ثِيطَّاوِينْ ن سِيذِي، \add مَاغَارْ\add* نتَّا أَذْ أَومْ إِوْشْ ؤُڒَا ذ مُوآبَ ذڭْ إِفَاسّنْ نْومْ.  
\v 19 كنِّيوْ أَذْ ثوْثمْ كُوڒْ ثَانْذِينْثْ إِفَارْينْ ؤُ كُوڒْ ثَانْذِينْثْ إِشنّْعنْ، ؤُ أَذْ ثْقضْعمْ كُوڒْ ثَاشجَّارْثْ إِصبْحنْ ؤُ أَذْ ثْبلّْعمْ مَارَّا ڒْعُونْصَارَاثْ ن وَامَانْ ؤُ أَذْ ثْضيّْعمْ كُوڒْ إِيَّارْ إِصبْحنْ ن ثمُّورْثْ س يژْرَا.“   
\m
\v 20 ؤُشَا ذِي ثِيوشَّا غَارْ \add ثْسَاعّثْ إِ غَارْ\add* د-تَّاوْينْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*، إِمْسَارْ، أَقَا ؤُسِينْ-د وَامَانْ زِي إِذُومْ ؤُشَا ثْغبَّا ثمُّورْثْ س وَامَانْ.  
\v 21 مُوآبَ أَمْ إِكْمڒْ إِسْڒَا بلِّي إِجدْجِيذنْ فّْغنْ-د إِ ؤُمنْغِي أَكِيذْسنْ. \add خنِّي\add* ڒَاغَانْ-د خْ مَارَّا \add إِرْيَازنْ\add*، إِخْسْ أَذْ يِينِي، زڭْ إِنِّي \add إِزمَّارنْ\add* أَذْ سنّْحنْ س وبْيَاسْ \add ن ڒسْنَاحْ\add* أَڒْ \add كُوڒْ إِجّْ\add* سنّجْ إِ ؤُيَا، ؤُشَا نِيثْنِي ستّْفنْ إِخفْ نْسنْ غَارْ ويْمِيرْ.  
\v 22 نِيثْنِي كَّارنْ غَارْ ثُوفُّوثْ ن صّْبحْ، ؤُ ؤُمِي د-ثنْقَارْ ثْفُوشْثْ خْ وَامَانْ، ژْرِينْ أَيْثْ ن مُوآبَ نِّي خْ ؤُجمَّاضِينْ، أَقَا أَمَانْ ذ إِزڭّْوَاغنْ أَمْ يِيذَامّنْ.  
\v 23 نِيثْنِي نَّانْ: ”إِنَا ذ إِذَامّنْ. إِجدْجِيذنْ نْغِينْ إِخفْ نْسنْ أَمْ مّنْغنْ \add جَارْ أَسنْ\add* س سِّيفْ ؤُشَا إِجّْ إِوْثَا ونّغْنِي. إِوَا \add أَيْثْ ن\add* مُوآبَ، طّْفمْ ثَاكشَّاضْثْ!“ \f ◼ \fr 3:‏23 \ft \+bd ’إِجّْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَرْيَازْ‘.\f*  
\v 24 \add مَاشَا ؤُمِي\add* إِوْضنْ نِيثْنِي غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ ن إِسْرَائِيل، كَّارنْ \add أَيْثْ ن\add* إِسْرَائِيل ؤُشَا وْثِينْ \add أَيْثْ ن\add* مُوآبَ. أَروْڒنْ \add أَيْثْ ن\add* مُوآبَ زَّاثْ إِ وُوذمْ نْسنْ ؤُشَا خنِّي ؤُذْفنْ نِيثْنِي \add غَارْ ثمُّورْثْ\add*، وْثِينْ مُوآبَ.  
\v 25 نِيثْنِي هذْمنْ ثِيندَّامْ ؤُشَا \add كُوڒْ\add* أَرْيَازْ إِنْضَارْ أَژْرُو نّسْ خْ كُوڒْ إِيَّارْ إِصبْحنْ ؤُشَا ذْڒِينْ ث. \add عَاوذْ\add* نثْينْ نِيثْنِي مَارَّا ڒْعُونْصَارَاثْ ن وَامَانْ ؤُشَا قضْعنْ كُوڒْ ثَاشجَّارْثْ إِصبْحنْ أَڒَامِي شطّنْ مْغِيرْ إِژْرَا \add ن ڒْحِيضْ\add* ن قِيرْ-حَارِيسَاثْ. أَيْثْ بُو-إِدْجَاينْ نّْضنْ أَسْ ؤُشَاغضْڒنْ ت.  
\v 26 \add ؤُمِي\add* إِژْرَا ؤُجدْجِيذْ ن مُوآبَ بلِّي أَمنْغِي إِوْعَارْ خَاسْ أَطَّاسْ، إِسّْمُونْ-د غَارسْ سبْعَا مْيَا ن يرْيَازنْ نِّي \add إِزمَّارنْ\add* أَذْ جبْذنْ سِّيفْ، حِيمَا أَذْ إِشُوقْ \add إِسذِّييّنْ ن ڒْعسْكَارْ\add* غَارْ ؤُجدْجِيذْ ن إِذُومْ، \add مَاشَا\add* نِيثْنِي وَارْ زمَّارنْ.  
\v 27 \add خنِّي\add* إِكْسِي نتَّا مِّيسْ أَمنْزُو ونِّي إِ غَا إِذوْڒنْ ذ أَجدْجِيذْ أَوَارْنِي أَسْ، ؤُشَا يِيوْيِي ث خْ ڒْحِيضْ ذ ثَاغَارْصْثْ ن وشْمَاضْ. ؤُشَا يُوسَا-د ؤُذُوقّزْ ذ أَمقّْرَانْ ن وغْضَابْ خْ إِسْرَائِيل. نِيثْنِي فّْغنْ زَّايسْ ؤُشَاعقْبنْ غَارْ ثمُّورْثْ نْسنْ.   
\b  
\b  
\m  
\c 4
\s1 زّشْثْ ن ثَاجَّاتْشْ  
\m
\v 1 إِشْثْ زِي ثمْغَارِينْ ن أَيْثْ ن إِنَابِييّنْ ثْڒَاغَا إِ إِلِيشَاعْ، ثنَّا: ”أَمْسخَّارْ نّشْ، أَرْيَازْ إِنُو، إِمُّوثْ، ؤُشَا شكْ ثسّْنذْ بلِّي أَمْسخَّارْ نّشْ ثُوغَا إِتّڭّْوذْ سِيذِي. \add ڒخُّو مَاشَا\add* يُوسَا-د بَابْ ن وَارطَّاڒْ، حِيمَا أَذْ إِكْسِي أَكِيذسْ ثْنَاينْ ن إِحنْجِيرنْ إِنُو ذ إِسمْغَانْ.“ \x ◘ \xo 4:‏1 \xt لَاوِي 25‏:‏39\x*  
\v 2 إِنَّا أَسْ إِلِيشَاعْ: ”مِينْ زمَّارغْ أَذْ أَمْ ڭّغْ؟ إِنِي أَيِي مِينْ غَارمْ ذِي ثَادَّارْثْ.“ نتَّاثْ ثَارَّا-د خَاسْ: ”ثَايَّا نّشْ وَارْ غَارسْ وَالُو مْغِيرْ إِشْثْ ن ثْغَارَّافْثْ ذَايسْ زّشْثْ.“  
\v 3 \add خنِّي\add* إِنَّا: ”تَّارْ إِ يِيخفْ نّمْ ثِيقْذُوحِينْ بَارَّا إِ ثَادَّارْثْ، ثِيقْذُوحِينْ ن جِّيرَانْ نّمْ خْوَانْثْ، حْضَا وَارْ إِڒِينْثْ ذْرُوسْ.  
\v 4 خنِّي أَذفْ غَارْ ذَاخڒْ ؤُشَا بلّعْ ثَاوَّارْثْ أَوَارْنِي أَمْ ؤُ أَوَارْنِي إِ إِحنْجِيرنْ نّمْ. فَارّغْ \add خنِّي زّشْثْ\add* ذِي مَارَّا ثِيقْذُوحِينْ نِّي، ؤُ مِينْ إِدْجَانْ إِشُّورْ، سَارْسْ إِ-ث غَارْ ؤُغزْذِيسْ!“  
\v 5 \add خَاسْ ؤُشَا\add* ثُويُورْ خَاسْ ؤُشَا ثْبلّعْ ثَاوَّارْثْ أَوَارْنِي أَسْ ؤُ أَوَارْنِي إِ إِحنْجِيرنْ نّسْ. نِيثْنِي إِوْينْ غَارسْ \add ثِيقْذُوحِينْ\add* ؤُ نتَّاثْ ثْفَارّغْ \add ذَايْسنْثْ زّشْثْ\add*.  
\v 6 \add ؤُمِي\add* شُّورنْثْ مَارَّا ثِيقْذُوحِينْ، ثنَّا إِ مِّيسْ: ”أَوِي أَيِي-د عَاذْ إِشْثْ ن ثقْذُوحْثْ!“، \add مَاشَا\add* نتَّا يَارَّا-د خَاسْ: ”وَارْ ذَا ثقِّيمْ شَا ثقْذُوحْثْ \add عَاذْ\add*!“ ؤُ زّشْثْ ثُوغَا ثقْضَا.  
\v 7 نتَّاثْ ثُويُورْ أَذْ ت ثْخبَّارْ إِ ورْيَازْ ن أَربِّي ؤُ وَانِيثَا إِنَّا: ”ؤُيُورْ، زنْزْ زّشْثْ ؤُ خدْجصْ بَابْ ن وَارطَّاڒْ نّمْ ؤُ زِي مِينْ غَا إِقِّيمنْ أَذْ زَّايسْ ثدَّارذْ، شمْ أَكْ-ذ إِحنْجِيرنْ نّمْ.“   
\b  
\m  
\s1 إِلِيشَاعْ ذ مِّيسْ ن ثمْغَارْثْ زِي شُونَامْ  
\m
\v 8 ذڭْ إِجّْ ن وَاسّْ ؤُمِي د-إِكَّا إِلِيشَاعْ خْ شُونَامْ، إِمْسَارْ، أَقَا إِشْثْ ن ثمْغَارْثْ إِشنّْعنْ إِسّْبدّْ إِ-ث ذِينْ، حِيمَا أَذْ \add غَارسْ\add* إِشّْ. ڒبْذَا ؤُمِي ثُوغَا د-إِتّكّْ \add خْ ثنْذِينْثْ نِّي\add*، إِمْسَارْ، أَقَا إِحيّذْ خْ وبْرِيذْ نّسْ غَارْ ذِينْ، حِيمَا أَذْ إِشّْ شَا ن مَاشَّا.  
\v 9 نتَّاثْ مَاشَا ثنَّا إِ ورْيَازْ نّسْ: ”خْزَارْ، نشّْ ؤُشِيغْ أَقَا أَرْيَازْ-أَ إِ غَارْنغْ د-يُوسِينْ ڒبْذَا، أَقَا-ث ذ أَرْيَازْ أَمْقدَّاسْ.  
\v 10 أجّْ أَنغْ أَذْ نبْنَا سنّجْ إِجّْ ن وخَّامْ ذ ثَامژْيَانْثْ س ڒحْيُوضْ، ؤُشَا أَذْ نڭّْ ذِينْ إِجّْ ن قَامَا، إِشْثْ ن طَّابْڒَا، إِجّْ ن ڒْكُورْسِي ذ إِجّْ نْ ڒفْنَارْ إِ نتَّا. مَاڒَا نتَّا خنِّي يُوسَا-د غَارْنغْ، إِزمَّارْ أَذْ ذِينِّي إِعْزڒْ إِخفْ نّسْ.“  
\v 11 ذڭْ إِجّْ ن وَاسّْ إِمْسَارْ أَقَا إِلِيشَاعْ يُوسَا-د ذِينْ ؤُشَا إِعْزڒْ إِخفْ نّسْ ذڭْ وخَّامْ ن نّجْ ؤُشَا إِرُوحْ إِزّڒْ ذِينِّي.  
\v 12 \add خنِّي\add* إِنَّا نتَّا إِ ؤُمْسخَّارْ نّسْ جِيحَازِي: ”ڒَْاغَا-د إِ ثْشُونَامشْثْ ثَانِيثَا!“ نتَّا إِڒَاغَا أَسْ ؤُ نتَّاثْ ثْبدّْ زَّاثْ إِ وُوذمْ نّسْ.  
\v 13 نتَّا ثُوغَا إِ ذ أَسْ إِنَّانْ \add إِ ؤُمْسخَّارْ نّسْ\add*: ”إِنِي أَسْ: ’شمْ ثثْهِيلِّيذْ ذَايْنغْ أَطَّاسْ. مِينْ إِزمَّارْ أَذْ أَمْ إِتّْوَاڭّْ؟ مَا أَذْ ثَاغْ ذِينْ إِشْثْ ن ڒْحَاجّثْ مِينْ خفْ نْزمَّارْ أَذْ نسِّيوڒْ أَكْ-ذ ؤُجدْجِيذْ نِيغْ أَكْ-ذ ؤُكُومَانْذَارْ أَمقّْرَانْ ن ڒْعسْكَارْ ذِي طّْوعْ نّمْ؟‘ “ \add مَاشَا\add* نتَّاثْ ثنَّا: ”نشّْ زدّْغغْ ذِي ڒْوسْطْ ن ڒْڭنْسْ إِنُو.“  
\v 14 \add خنِّي\add* ثُوغَا إِنَّا: ”مِينْ إِزمَّارنْ أَذْ أَسْ إِتّْوَاڭّْ؟“ ؤُشَا إِنَّا جِيحَازِي: ”نتَّاثْ وَارْ غَارسْ أَحنْجِيرْ ؤُ أَرْيَازْ نّسْ إِوْسَارْ.“  
\v 15 \add خنِّي\add* ثُوغَا إِنَّا نتَّا ”ڒَْاغَا-د خَاسْ!“ ؤُ نتَّا إِڒَاغَا-د خَاسْ ؤُشَا ثقِّيمْ نتَّاثْ ثْبدّْ ذِي ثوَّارْثْ،  
\v 16 ؤُشَا نتَّا إِنَّا: ”ذِي ڒْوقْثْ-أَ إِتّْوَاڭّنْ، غَارْ ثْسَاعّثْ ن ثُوذَارْثْ، أَذْ ثكْسِيذْ أَحنْجِيرْ ذڭْ إِغَادْجنْ نّمْ.“ ؤُشَا نتَّاثْ ثنَّا: ”لَّ، أَ سِيذِي إِنُو، \add أَ\add* أَرْيَازْ ن أَربِّي، وَارْ سْخَارِّيقْ \add زعْمَا\add* خْ ثَايَّا نّشْ!“ \x ◘ \xo 4:‏16 \xt أَمز. 18‏:‏10، 14\x*  
\v 17 ثَامْغَارْثْ ثذْوڒْ ثكْسِي س دّيْسثْ ؤُشَا ثُورُووْ-د إِجّْ ن ؤُحنْجِيرْ ذِي ڒْوقْثْ إِتّْوَاڭّنْ، غَارْ ڒْوقْثْ ن ثُوذَارْثْ نِّي خْ ثُوغَا إِسِّيوڒْ إِلِيشَاعْ أَكِيذسْ.   
\m
\v 18 \add ؤُمِي\add* إِمْغَارْ ؤُحنْجِيرْ، إِمْسَارْ ذڭْ إِجّْ ن وَاسّْ، إِفّغْ-د بَارَّا غَارْ بَابَاسْ، غَارْ يِينِّي إِمجَّارنْ.  
\v 19 إِنَّا إِ بَابَاسْ: ”\add أَ\add* أَزدْجِيفْ إِنُو، \add أَ\add* أَزدْجِيفْ إِنُو!“ ؤُشَا بَابَاسْ إِنَّا إِ يِيجّْ ن ؤُمْسخَّارْ: ”أَرْبُو ث غَارْ يمَّاسْ!“ \f ◼ \fr 4:‏19 \ft \+bd ’ؤُشَا بَابَاسْ إِنَّا ...‘\+bd* - س ثْعِيبْرَانِيثْ ’ؤُشَا نتَّا إِنَّا ...‘\f*  
\v 20 نتَّا يَارْبُو ث ؤُشَا يِيوْيِي ث غَارْ يمَّاسْ. نتَّا ثُوغَا إِتّْغِيمَا خْ إِفَادّنْ نّسْ أَڒْ أَزَالْ، \add خنِّي\add* إِمُّوثْ.  
\v 21 نتَّاثْ ثْڭعّذْ سنّجْ، ثسَّارْسْ إِ-ث خْ قَامَا ن ورْيَازْ ن أَربِّي. ثْبلّعْ ثَاوَّارْثْ خَاسْ ؤُشَا ثفّغْ.  
\v 22 ثْڒَاغَا-د خْ ورْيَازْ نّسْ، ثنَّا أَسْ: ”سكّْ أَيِي-د إِجّنْ زڭْ إِمْسخَّارنْ ذ إِجّْ زِي ثغْيَاڒْ، حِيمَا أَذْ ؤُيُورغْ ذغْيَا غَارْ ورْيَازْ ن أَربِّي ؤُ \add خنِّي\add* أَذْعقْبغْ \add عَاوذْ\add*.“  
\v 23 نتَّا إِنَّا: ”مَايمِّي غَا ثُويُورذْ غَارسْ أَسّْ-أَ؟ أَقَا وَارْ إِدْجِي ذ أَبذِّي ن ؤُيُورْ ؤُ وَارْ إِدْجِي ذ سّبْثْ.“ نتَّاثْ ثنَّا: ”كُوڒْشِي أَذْ يِيڒِي مْلِيحْ!“  
\v 24 نتَّاثْ ثْبَارْذعْ إِ ثغْيُوتْشْ ؤُ ثنَّا إِ ؤُمْسخَّارْ نّسْ: ”نْذهْ إِ-ت، قِّيمْ ڭُّورْ. أَمْ ثْنذْهذْ وَارْ ثْبذِّي ذِي طّْوعْ إِنُو مْغِيرْ خْمِي ذ أَشْ ث إِ غَا إِنِيغْ.“   
\m
\v 25 نتَّاثْ ثفّغْ ؤُشَا ثِيوضْ-د غَارْ ورْيَازْ ن أَربِّي، غَارْ وذْرَارْ ن كَارْمِيلْ. ؤُمِي ت إِژْرَا نتَّا زِي ڒَاڭّْوَاجْ، إِنَّا إِ جِيحَازِي، أَمْسخَّارْ نّسْ: ”خْزَارْ، أَقَا ذِينْ ذ ثَاشُونَامشْثْ.“  
\v 26 ڒخُّو، ؤُيُورْ ذغْيَا، ڒْقَا ت ؤُشَا إِنِي أَسْ: ’مَا أَقَا شمْ مْلِيحْ؟ مَا أَرْيَازْ نّمْ أَقَا-ث مْلِيحْ؟ مَا أَحنْجِيرْ نّمْ أَقَا-ث مْلِيحْ؟‘ “ ؤُشَا نتَّاثْ ثنَّا: ”أَقَا-ثنْ مْلِيحْ!“  
\v 27 \add ؤُمِي مَاشَا\add* د-ثُوسَا غَارْ ورْيَازْ ن أَربِّي خْ وذْرَارْ، ثْقبّضْ نتَّاثْ خْ إِضَارنْ نّسْ. جِيحَازِي يُوذفْ-د ذِينْ حِيمَا أَذْ ت إِعَارْنْ غَارْ ؤُغزْذِيسْ، مَاشَا أَرْيَازْ ن أَربِّي إِنَّا: ”أَحْثَا أَسْ، مَاغَارْ ڒعْمَارْ نّسْ إِشْضنْ ذَايسْ ؤُ سِيذِي إِسّْنُوفَّارْ خَافِي مِينْ خفْ ؤُ وَارْ ذ أَيِي إِسَّارْڭبْ شَا.“  
\v 28 ثنَّا نتَّاثْ: ”مَا نشّْ تَّارغْ إِ سِيذِي إِنُو إِجّْ ن مِّي؟ مَا وَارْ نِّيغْ نشّْ: ’وَارْ ذ أَيِي شمّثْ‘؟“ \x ◘ \xo 4:‏28 \xt 2 إِج. 4‏:‏16\x*  
\v 29 إِنَّا نتَّا إِ جِيحَازِي: ”بْيسْ ثَاجْعِينَّا نّشْ، كْسِي ثَاغَّارْشْثْ إِنُو ذڭْ ؤُفُوسْ نّشْ ؤُشَا طّفْ أَبْرِيذْ! مَاڒَا شكْ ثمّڒْقِيذْ شَا ن يِيجّْ، وَارْ خَاسْ تّْسدْجَامْ، ؤُ مَاڒَا إِسدْجمْ خَاكْ حذْ، وَارْ خَاسْ د-تَّارِّي شَا! سَارْسْ ثَاغَّارْشْثْ إِنُو خْ ؤُغمْبُوبْ ن ؤُحنْجِيرْ!“ \x ◘ \xo 4:‏29 \xt لك. 10‏:‏4\x*  
\v 30 \add مَاشَا\add* يمَّاسْ ن ؤُحنْجِيرْ ثنَّا: ”\add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي ؤُ إِدَّارْ ڒعْمَارْ إِنُو، نشّْ وَارْ خَاكْ تّْحيِّيذغْ شَا!“ نتَّا إِكَّارْ، إِضْفَارْ إِ-ت.   
\m
\v 31 ثُوغَا جِيحَازِي إِزْوَارْ ذغْيَا زَّاثْسنْ ؤُ إِسَّارْسْ ثَاغَّارْشْثْ خْ ؤُغمْبُوبْ ن ؤُحنْجِيرْ، مَاشَا نتَّا وَارْ إِڭِّي شَا ڒْحسّْ ؤُڒَا ذ ثْوَارِّيثْ. \add خنِّي\add* إِعْقبْ حِيمَا أَذْ خَاسْ إِڒْقَا، ؤُشَا إِحَاجَا أَسْ ث، إِنَّا: ”أَحنْجِيرْ وَارْ د-إِفِيقْ.“  
\v 32 \add ؤُمِي\add* د-يُوسَا إِلِيشَاعْ غَارْ ثَادَّارْثْ، ثُوغَا إِمُّوثْ ؤُحنْجِيرْ، إِمَّارْسْ خْ قَامَا نّسْ.  
\v 33 يُوذفْ نتَّا غَارْ وخَّامْ، إِبلّعْ ثَاوَّارْثْ أَوَارْنِي أَسنْ س ثْنَاينْ إِذْسنْ ؤُشَا إِژُّودْجْ إِ سِيذِي. \x ◘ \xo 4:‏33 \xt مت. 6‏:‏6\x*  
\v 34 خنِّي إِبدّْ زَّاثْ إِ قَامَا، إِوْضَا ثِيوَا ن ؤُحنْجِيرْ ؤُشَا إِسَّارْسْ نتَّا أَقمُّومْ نّسْ خْ ؤُقمُّومْ نّسْ، ثِيطَّاوِينْ نّسْ خْ ثِيطَّاوِينْ نّسْ، إِفَاسّنْ نّسْ خْ إِفَاسّنْ نّسْ. نتَّا إِسّْبُوزّڒْ \add أَمُّو\add* ثِيوَا نّسْ ؤُشَا ثحْمَا أَرِّيمثْ ن ؤُحنْجِيرْ.  
\v 35 \add خنِّي\add* إِعْقبْ-د، يُويُورْ ذِي ثَادَّارْثْ ذَا ذ ذِيهَا، إِڭعّذْ ثْوَاڒَا نّغْنِيثْ ؤُشَا إِسّْبُوزّڒْ إِخفْ نّسْ ثِيوَا نّسْ. \add ڒخْذنِّي\add* إِعْضسْ ؤُحنْجِيرْ سبْعَا ن ثْوَاڒَاوِينْ ؤُشَا \add خنِّي\add* يَارْزمْ ؤُحنْجِيرْ ثِيطَّاوِينْ نّسْ. \x ◘ \xo 4:‏35 \xt 1 إِج. 17‏:‏21؛ 2 إِج. 8‏:‏1؛ ڒخ. 20‏:‏10\x*  
\v 36 إِڒَاغَا-د نتَّا إِ جِيحَازِي، إِنَّا: ”ڒَْاغَا-د خْ ثْشُونَامشْثْ!“ ؤُشَا نتَّا إِڒَاغَا-د خَاسْ ؤُشَا ثُوسَا-د نتَّاثْ غَارسْ، ؤُشَا إِنَّا \add إِلِيشَاعْ\add*: ”أَرْبُو مِّيمْ!“  
\v 37 ثُوذفْ نتَّاثْ ذِينْ، ثوْضَا غَارْ إِضَارنْ نّسْ ؤُشَا يُوضَارْ \add أَسْ\add* \add س ؤُغمْبُوبْ نّسْ\add* غَارْ ثَامُّورْثْ. \add خنِّي\add* ثكْسِي مِّيسْ ؤُشَا ثفّغْ غَارْ بَارَّا.   
\b  
\m  
\s1 ڒْموْثْ ذِي مَارْمِيثَا ذ لْمُوعْجِيزَا ن ؤُسشِّي  
\m
\v 38 \add ؤُمِي\add* د-إِعْقبْ إِلِيشَاعْ غَارْ جِيلْجَالْ، ثُوغَا ذِينْ ڒَاژْ ذِي ثمُّورْثْ ؤُ أَيْثْ ن إِنَابِييّنْ قِّيمنْ زَّاثسْ. إِنَّا نتَّا إِ ؤُمْسخَّارْ نّسْ: ”أڭّْ مَارْمِيثَا ذ ثَامقّْرَانْثْ ؤُ أڭّْ ثَاحْرِيرْثْ إِ أَيْثْ ن إِنَابِييّنْ.“ \f ◼ \fr 4:‏38 \ft \+bd ’أَيْثْ ن إِنَابِييّنْ‘\+bd* - إِخْسْ أَذْ يِينِي ’إِنِّي إِخْسنْ أَذْ ڒمْذنْ أَذْ ذوْڒنْ ذ إِنَابِييّنْ. أَقَا-ثنْ ذ إِمحْضَارنْ ن إِلِيشَاعْ.\f*  
\v 39 \add خنِّي\add* د-إِفّغْ إِجّنْ \add زَّايْسنْ\add* يُويُورْ غَارْ وحْوِيشْ بَارَّا، حِيمَا أَذْ د-يَاوِي ثِيبِّي. نتَّا يُوفَا إِجّْ ن وزْبِيرْ ن ڒخْڒَا ؤُشَا إِڒْقضْ-د زَّايسْ أَڒَامِي إِشُّورْ \add ؤُبحْرُورْ ن\add* وَارُّوضْ نّسْ س ثخْسَاشْثْ ن ڒخْڒَا. \add خنِّي\add* إِعْقبْ-د ؤُشَا إِقسّْ إِ-ثنْ ذِي مَارْمِيثَا. أَقَا نِيثْنِي وَارْ ت سِّيننْ.  
\v 40 \add خنِّي\add* فَارْغنْ أَيَا إِ إِرْيَازنْ، حِيمَا أَذْ شّنْ. ؤُمِي قَّاسنْ نِيثْنِي زِي ثحْرِيرْثْ-أَ، إِمْسَارْ، أَقَا نِيثْنِي سْغُوينْ ذڭْ ؤُجنَّا، ڒَاغَانْ: ”\add أَ،\add* يرْيَازْ ن أَربِّي، \bd ڒْْموْثْ أَقَا-ت ذِي مَارْمِيثَا!\bd*“ ؤُشَا نِيثْنِي وَارْ زمَّارنْ أَذْ \add زَّايسْ\add* شّنْ.  
\v 41 نتَّا إِنَّا: ”أَوِي أَيِي-د \add ذْرُوسْ ن\add* وَارنْ!“ نتَّا إِسُّويسْ إِ-ث ذِي مَارْمِيثَا، إِنَّا: ”فَارْغمْ \add أَيَا\add* إِ ڒْڭنْسْ، حِيمَا أَذْ شّنْ!“ \add خنِّي\add* إِذْوڒْ وَارْ ذِينِّي شَا وَارْ إِحْڒِي ذِي مَارْمِيثَا. \x ◘ \xo 4:‏41 \xt ؤُف. 15‏:‏25\x*   
\b  
\m
\v 42 يُوسَا-د إِجّْ ن ورْيَازْ زِي بَاعْلْ-شَالِيشَا، يِيوِي-د إِ ورْيَازْ ن أَربِّي أَغْرُومْ زِي \add صَّابثْ\add* ثَامنْزُوثْ، عِيشْرِينْ ن إِغْرُومنْ ن إِمنْذِي ذ ڒْحبّْ إِبَارْينْ \add ن إِمنْذِي\add* ذڭْ إِشْثْ ن ثشْيَارْثْ، ؤُشَا نتَّا إِنَّا: ”أوْشْ \add مَانْ أَيَا\add* إِ ڒْڭنْسْ.“  
\v 43 مَاشَا وَانِيثَا إِنَّا: ”مَامّشْ ث إِ غَا سَّارْسغْ إِ مْيَا ن يرْيَازنْ؟“ نتَّا \add مَاشَا\add* إِنَّا: ”أوْشْ إِ-ث إِ ڒْڭنْسْ أَذْ ث يشّْ، مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي: \bd ’أَذْ شّنْ ؤُ عَاذْ أَذْ إِشطّْ‘\bd*.“ \x ◘ \xo 4:‏43 \xt يُوح. 6‏:‏9، 11\x*  
\v 44 نتَّا إِسَّارْسْ أَسنْ \add ث\add* ؤُشَا شِّينْ نِيثْنِي، ؤُ إِشطّْ خَاسنْ أَمْ مَامّشْ \add ثُوغَا إِنَّا\add* وَاوَاڒْ ن سِيذِي.   
\b  
\b  
\m  
\c 5
\s1 أَسْڭنْفِي ن نُوعْمَانْ  
\m
\v 1 نُوعْمَانْ، أَكُومَانْذَارْ ن ڒْعسْكَارْ ن ؤُجدْجِيذْ ن أَرَامْ، ثُوغَا-ث ذ إِجّْ ن ورْيَازْ غَارسْ سُّومْعثْ زَّاثْ إِ وُوذمْ ن سِيذِيسْ نّسْ ؤُ ثُوغَا غَارسْ شَّانْ أَطَّاسْ، مَاغَارْ زَّايسْ إِ يِيوِي سِيذِي أَسنْجمْ إِ أَرَامْ. أَرْيَازْ \add نِّي\add* ثُوغَا ذ إِجّْ ن بُو-ثغْرُوضْثْ إِمحْضنْ، \add مَاشَا\add* ثُوغَا ذَايسْ ڒْبَارْصْ.  
\v 2 ثُوغَا ذِينْ بَانْذِييَّاثْ زِي أَرَامْ، إِوْينْثْ-د إِشْثْ ن ثبْڒِيغْثْ زِي ثمُّورْثْ ن إِسْرَائِيل ذ ثَامحْبُوسْثْ. ثُوغَا-ت \add ثْخدّمْ\add* إِ ثمْغَارْثْ ن نُوعْمَانْ.  
\v 3 ثنَّا إِ لَالَّاسْ: ”مْڒِي \add ثُوغَا\add* سِيذِي إِنُو غَارْ ؤُنَابِي ذِي سَامَارْيَا، \add خنِّي\add* إِڒِي نتَّا أَذْ ث إِسّْڭنْفَا زِي ڒْبَارْسْ نّسْ.“   
\m
\v 4 \add خنِّي\add* يُويُورْ وَانِيثَا، حِيمَا أَذْ ث إِحَاجَا إِ سِيذِيسْ نّسْ، إِنَّا: ”أَمُّو ذ وَامُّو إِ ثسِّيوڒْ ثبْڒِيغْثْ زِي ثمُّورْثْ ن إِسْرَائِيل.“ \f ◼ \fr 5:‏4 \ft \+bd ’وَانِيثَا‘\+bd* - إِخْسْ أَذْ يِينِي ’نُوعْمَانْ‘.\f*  
\v 5 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ ن أَرَامْ: ”ؤُيُورْ ذِينْ ؤُ نشّْ أَذْ سّكّغْ إِشْثْ ن ثبْرَاثْ إِ ؤُجدْجِيذْ ن إِسْرَائِيل.“ نتَّا يُويُورْ ذڭْ وبْرِيذْ ؤُشَا إِكْسِيعشْرَا ثَالِينْثَاثْ ن نُّوقَارْثْ ذ ستَّا-أَڒَافْ \add شِيقْلُو\add* ن وُورغْ ذعشْرَا ن وَارُّوضْ إِشْنَانْ.  
\v 6 نتَّا إِسِّيوضْ ثَابْرَاثْ إِ ؤُجدْجِيذْ ن إِسْرَائِيل، \add أَمُّو إِ\add* يُورَا: ”ڒخُّو \add خنِّي\add*، خْزَارْ، مَاڒَا ثِيوضْ-د ثبْرَاثْ-أَ غَاركْ، أَقَا نشّْ سّكّغْ-د غَاركْ \add عَاوذْ\add* أَمْسخَّارْ إِنُو نُوعْمَانْ، مَاحنْذْ أَذْ ث ثسّْڭنْفِيذْ زِي ڒْبَارْصْ نّسْ.“  
\v 7 \add ؤُمِي\add* إِغْرَا ؤُجدْجِيذْ ن إِسْرَائِيل ثَابْرَاثْ، إِشَارّڭْ أَرُّوضْ نّسْ، إِڒَاغَا: ”نشّْ مَاغَارْ مَا ذ أَربِّي أَڒَامِي زمَّارغْ أَذْ سّدَّارغْ إِجّْ ن ؤُمتِّينْ أَڒَامِي نتَّا د-إِسّكّْ ورْيَازْ-أَ غَارِي، مَاحنْذْ أَذْ ث سّْڭنْفِيغْ زِي ڒْبَارْصْ نّسْ؟ إِوَا، سّْنمْ، ؤُ خْزَارمْ، أَقَا نتَّا يَارزُّو أَيِي ڒسْبَابْ وَاهَا!“ \x ◘ \xo 5:‏7 \xt أَعَوذ. 32‏:‏39؛ 1 صم. 2‏:‏6\x*   
\m
\v 8 ؤُمِي إِسْڒَا إِلِيشَاعْ، أَرْيَازْ ن أَربِّي، بلِّي أَجدْجِيذْ ن إِسْرَائِيل إِشَارّڭْ أَرُّوضْ نّسْ، إِمْسَارْ أَقَا نتَّا إِسّكّْ \add إِجّْ\add* غَارْ ؤُجدْجِيذْ، حِيمَا أَذْ أَسْ يِينِي: ”مَايمِّي ثْشَارّْڭذْ أَرُّوضْ نّشْ؟ أجّْ إِ-ث أَذْ غَارِي د-يَاسْ، \add حِيمَا\add* خنِّي نتَّا أَذْ إِسّنْ، أَقَا ذِينْ إِجّْ ن ؤُنَابِي ذِي إِسْرَائِيل.“  
\v 9 أَمُّو د-يُوسَا نُوعْمَانْ أَكْ-ذ إِيْسَانْ ذ ؤُكَارُّو نّسْ ؤُشَا إِبدّْ غَارْ ثوَّارْثْ ن ثَادَّارْثْ ن إِلِيشَاعْ.  
\v 10 \add خنِّي\add* إِسّكّْ إِلِيشَاعْ إِجّْ ن ؤُرقَّاسْ غَارسْ، إِقَّارْ: ”ؤُيُورْ ؤُ سِّيرْذْ إِخفْ نّشْ سبْعَا ن ثْوَاڒَاوِينْ ذِي لْ-ؤُرْذُونْ، \add خنِّي\add* أَذْ ثذْوڒْ أَرِّيمثْ نّشْ ثڭّنْفَا ؤُشَا شكْ أَذْ ثِيڒِيذْ ذ أَمزْذَاڭْ.“  
\v 11 إِفُّوڭمْ نُوعْمَانْ، ؤُشَا يُويُورْ، إِقَّارْ: ”خْزَارْ، نشّْ نِّيغْ ذڭْ إِخفْ إِنُو: ’نتَّا أَذْ إِفّغْ غَارْ بَارَّا، أَذْ إِبدّْ \add ذِينْ\add*، مَاحنْذْ أَذْ إِڒَاغَا إِسمْ ن سِيذِي، أَربِّي نّسْ، ؤُشَا أَذْ إِسّكّْ س ؤُفُوسْ نّسْ أَمْشَانْ \add إِ ذَايسْ إِدْجَانْ ڒْبَارْصْ\add* ؤُ أَمُّو إِ غَا إِڭّنْفَا ڒْبَارْصْ.‘  
\v 12 مَا وَارْ إِدْجِي أَبَانَا ذ فَارْفَارْ، إِغزْرَانْ ن ذِيمَاشْقْ، حْسنْ خْ مَارَّا إِغزْرَانْ ن إِسْرَائِيل؟ مَا وَارْ زمَّارغْ أَذْ ذِينِّي سِّيرْذغْ، حِيمَا أَذْ زذْڭغْ؟“ نتَّا إِنّقْڒبْ ؤُشَا يُويُورْ، إِسْعَارْ أَطَّاسْ.   
\m
\v 13 إِمْسخَّارنْ نّسْ ؤُسِينْ-د غَارسْ، سِّيوْڒنْ أَكِيذسْ، نَّانْ: ”بَابَا، \add مْڒِي\add* أَنَابِي نِّي إِتَّارْ زَّايكْ شَا مِينْ إِوْعَارنْ، إِڒِي ثڭِّيذْ ث؟ إِ مَاڒَا إِنَّا خَاكْ عَاذْ: ’سِيرْذْ إِخفْ نّشْ ؤُشَا أَذْ ثْذوْڒذْ شكْ ثِيزْذِيڭذْ؟‘ “  
\v 14 \add خنِّي\add* إِهْوَا-د غَارْ لْ-ؤُرْذُونْ ؤُشَا إِسّغْضصْ إِخفْ نّسْ سبْعَا ن ثْوَاڒَاوِينْ ذِي لْ-ؤُرْذُونْ أَمْ مَامّشْ إِنَّا وَاوَاڒْ ن ؤُنَابِي ن أَربِّي ؤُشَا \add ثذْوڒْ\add* أَرِّيمثْ نّسْ ثڭّنْفَا أَمْ أَرِّيمثْ ن إِجّْ ن ؤُحنْجِيرْ ؤُ نتَّا إِذْوڒْ إِزْذِيڭْ. \x ◘ \xo 5:‏14 \xt لك. 4‏:‏27\x*   
\m
\v 15 \add خنِّي\add* إِعْقبْ غَارْ ورْيَازْ ن أَربِّي أَكْ-ذ مَارَّا ڒْعسْكَارْ نّسْ ؤُشَا يِيوضْ \add ذِينْ\add*، إِبدّْ زَّاثْ إِ وُوذمْ نّسْ، إِنَّا: ”خْزَارْ، ڒخُّو سّْنغْ، أَقَا وَارْ إِدْجِي أَربِّي مَانِي مَا خْ مَارَّا ثَامُّورْثْ مْغِيرْ ذِي إِسْرَائِيل وَاهَا. خنِّي ڒخُّو، عَافكْ، كْسِي إِشْثْ ن ثَارْزفْثْ زڭْ ؤُمْسخَّارْ نّشْ!“  
\v 16 \add مَاشَا\add* نتَّا إِنَّا: ”\add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي ونِّي ؤُمِي بدّغْ زَّاثْ إِ وُوذمْ نّسْ، نشّْ وَارْ كسِّيغْ وَالُو!“ ؤُ نتَّا إِسّْحشّمْ إِ-ث، حِيمَا أَذْ إِكْسِي \add شَا\add*، مَاشَا نتَّا يُوڭِي.  
\v 17 إِنَّا نُوعْمَانْ: ”مَاڒَا لَّا، إِڒِي خنِّي أَذْ إِمّوْشْ إِ ؤُمْسخَّارْ نّشْ أَطَّاسْ ن ؤُشَاڒْ، أَنشْثْ \add زمَّارنْ\add* ثْنَاينْ ن إِسرْذَانْ أَذْ أَرْبُونْ، مَاغَارْ أَمْسخَّارْ نّشْ وَارْ إِتِّيوِي عَاذْ ثَاغَارْصْثْ ن وشْمَاضْ نِيغْ ثَاغَارْصْثْ إِ إِربِّيثنْ إِنّغْنِي مْغِيرْ إِ سِيذِي وَاهَا.  
\v 18 \add مَاشَا\add* إِڒِي أَذْ إِغْفَارْ سِيذِي إِ ؤُمْسخَّارْ نّشْ ثَا \add وَاهَا\add*، مَاڒَا سِيذِي إِنُو أَذْ يَاذفْ غَارْ زَّاوشْثْ ن رِيمُّونْ حِيمَا أَذْ إِبنْذقْ أَمْ إِتّْعمّذْ ذِينِّي خْ ؤُغِيڒْ إِنُو، أَقَا نشّْ خنِّي أَذْ بنْذْقغْ \add أَمُّو\add* ذِي زَّاوشْثْ ن رِيمُّونْ. \add مَاڒَا\add* أَذْ بنْذْقغْ \add أَمُّو\add* ذِي زَّاوشْثْ ن رِيمُّونْ، إِڒِي أَذْ إِغْفَارْ سِيذِي ثَامسْڒَاشْثْ نِّي إِ ؤُمْسخَّارْ نّشْ.“  
\v 19 إِنَّا أَسْ: ”ؤُيُورْ ذِي ڒهْنَا!“ ؤُ نتَّا إِسَافَارْ ثَامُّورْثْ، إِڭّْوجْ خَاسْ \add إِجّْ ن وبْرِيذْ\add*.   
\m
\v 20 إِنَّا جِيحَازِي، أَمْسخَّارْ ن إِلِيشَاعْ، أَرْيَازْ ن أَربِّي: ”خْزَارْ، سِيذِي إِنُو إِسّْعِيزّْ خْ نَاعْمَانْ، أَرَامِييُو، مَاحنْذْ أَذْ إِكْسِي \add شَا\add* زڭْ ؤُفُوسْ نّسْ زِي مِينْ ثُوغَا إِ د-يِيوِي نتَّا. \add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي، نشّْ أَذْ ث أَردّْفغْ ذغْيَا ؤُشَا أَذْ زَّايسْ كْسِيغْ شَا!“  
\v 21 جِيحَازِي يُويُورْ، يَارْذفْ نُوعْمَانْ. \add ؤُمِي\add* نُوعْمَانْ إِژْرَا، أَقَا نتَّا يُوزّڒْ أَوَارْنِي أَسْ، إِضْرَا-د زڭْ ؤُكَارُّو، مَاحنْذْ أَكِيذسْ إِمْسَاڭَارْ، إِنَّا: ”مْلِيحْ؟“  
\v 22 نتَّا يَارَّا-د خَاسْ: ”مْلِيحْ. سِيذِي إِنُو إِسّكّْ أَيِي-د مَاحنْذْ أَذْ يِينِي: ’أَقَا، غَارْ ڒخُّو عَاذْ ؤُسِينْ-د ثْنَاينْ ن إِحُوذْرِييّنْ زڭْ أَيْثْ ن إِنَابِييّنْ زڭْ إِذُورَارْ ن إِفْرَايِيمْ. أوْشْ أَسنْ \add خنِّي\add* إِشْثْ ن ثَالِينْثْ ن نُّوقَارْثْ ذ ثْيُويَا ن وَارُّوضْ إِشْنَانْ.‘ “  
\v 23 إِنَّا نُوعْمَانْ: ”عَافَاكْ، كْسِي زَّايِي ثْنَاينْ ثَالِينْثْ ن نُّوقَارْثْ.“ نتَّا إِحشّمْ إِ-ث ؤُ إِڭَّا ثْنَاينْ ثَالِينْثْ ن نُّوقَارْثْ ذِي ثْنَاينْ ن ثشْيَارِينْ ؤُشَا إِوْشَا ثْنَاينْ ن وَارُّوضْ إِشْنَانْ إِ ثْنَاينْ ن إِمْسخَّارنْ نّسْ، إِنِّي ثنْ يَارْبُونْ غَارْ زَّاثْ نّسْ.  
\v 24 \add ؤُمِي\add* يِيوضْ غَارْ ڒْڭعّْذثْ، إِكْسِي ثنْ زڭْ إِفَاسّنْ نْسنْ ؤُشَا إِنُّوفَّارْ إِ-ثنْ ذِي ثَادَّارْثْ. إِجَّا إِرْيَازنْ أَذْ ؤُيُورنْ ؤُشَا فّْغنْ نِيثْنِي.   
\m
\v 25 \add أَوَارْنِي مَانْ أَيَا\add* يُوذفْ ؤُشَا إِبدّْ زَّاثْ إِ بَابْ نّسْ. إِلِيشَاعْ إِسّقْسَا ث: ”مَانِيسْ د-ثُوسِيذْ، \add أَ\add* جِيحَازِي؟“ ؤُشَا نتَّا يَارَّا-د: ”أَمْسخَّارْ نّشْ وَارْ د-إِفِّيغْ شَا مَانِي.“  
\v 26 \add مَاشَا\add* إِلِيشَاعْ إِنَّا أَسْ: ”مَا وَارْ ثُوغِي ؤُڒْ إِنُو ذِينْ إِحْضَارْ ؤُمِي د-إِضْرَا ورْيَازْ زڭْ ؤُكَارُّو نّسْ إِ ؤُمْسَاڭَارْ أَكِيذكْ؟ مَاغَارْ مَا ذ ڒْحَاڒْ أَذْ ثْمنْعذْ نُّوقَارْثْ ذ وَارُّوضْ ذ ثْشجُّورَا ن زِّيثُونْ ذ إِمَارْجَاعنْ ن ؤُضِيڒْ ذ وُودْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ إِسمْغَانْ ذ ثِييَّا؟  
\v 27 ڒْبَارْصْ ن نُوعْمَانْ أَذْ إِڒْسقْ إِ ڒبْذَا ذَايكْ ؤُ ذِي زَّارِيعثْ نّشْ!“ \add خنِّي\add* إِفّغْ زِي زَّاثْ إِ وُوذمْ نّسْ س ڒْبَارْصْ، ذ أَشمْڒَاڒْ أَمْ وذْفڒْ. \x ◘ \xo 5:‏27 \xt ڒخْڒ. 12‏:‏10؛ 2 إِم. 26‏:‏19، 20\x*   
\b  
\b  
\m  
\c 6
\s1 ثَاشقُّورْثْ إِفتَّاحنْ  
\m
\v 1 أَيْثْ ن إِنَابِييّنْ نَّانْ إِ إِلِيشَاعْ: ”خْزَارْ، أَمْشَانْ مَانِي نْزدّغْ زَّاثْ إِ وُوذمْ نّشْ، إِحْصَارْ إِ نشِّينْ.“  
\v 2 أجّْ أَنغْ أَذْ نُويُورْ غَارْ لْ-ؤُرْذُونْ ؤُ ذِينِّي قَاعْ إِجّْ زَّايْنغْ أَذْ د-يَاوِي إِجّْ ن ؤُكشُّوضْ، مَاحنْذْ أَذْ نڭّْ إِشْثْ ن ثْزذِّيغْثْ إِ نشِّينْ.“ نتَّا إِنَّا: ”ؤُيُورمْ!“  
\v 3 إِجّنْ \add زَّايْسنْ\add* مَاشَا إِنَّا: ”عَافَاكْ، ؤُيُورْ أَكْ-ذ إِمْسخَّارنْ نّشْ.“ نتَّا إِنَّا: ”نشّْ أَكِيذْومْ ؤُيُورغْ.“  
\v 4 \add خنِّي\add* يُويُورْ أَكِيذْسنْ. \add ؤُمِي\add* د-ؤُسِينْ غَارْ لْ-ؤُرْذُونْ، زذْمنْ ثِيشجُّورَا.  
\v 5 ڒَامِي إِزْذمْ إِجّْ إِشْثْ ن ثْشجَّارْثْ، إِمْسَارْ، أَقَا \add ڒقْضعْ ن\add* وُوزَّاڒْ \add ن شَّاقُورْ\add* إِوْضَا ذڭْ وَامَانْ ؤُشَا نتَّا إِڒَاغَا، إِنَّا: ”أَ سِيذِي إِنُو، \add شَّاقُورْ\add* ثُوغَا إِتّْوَارْضڒْ!“  
\v 6 أَرْيَازْ ن أَربِّي إِنَّا: ”مَانِي إِوْضَا؟“ \add ؤُمِي\add* ذ أَسْ إِسّْشنْ أَمْشَانْ، إِقسّْ إِجّْ ن ؤُكشُّوضْ، إِنْضَارْ إِ-ث ذِينْ ؤُ \add أَمُّو\add* يِيوِي-د ؤُزَّاڒْ إِڭُّورْ سنّجْ.  
\v 7 إِنَّا نتَّا: ”سْڭعّذْ إِ-ث-إِ-د غَاركْ!“ \add خنِّي\add* إِسّْوِيژّضْ س ؤُفُوسْ نّسْ ؤُشَا إِطّفْ إِ-ث.   
\b  
\m  
\s1 ثِيمڭَّا ن إِلِيشَاعْ ذڭْ ؤُمنْغِي أَكْ-ذ أَرَامْ  
\m
\v 8 أَجدْجِيذْ ن أَرَامْ إِمّْنغْ أَكْ-ذ إِسْرَائِيل ؤُشَا إِمْشَاوَارْ أَكْ-ذ إِمْسخَّارنْ نّسْ، إِنَّا: ”ذڭْ ومْشَانْ-إِنْ ذ وِينْ أَذْ وْثغْ إِقِيضَانْ إِ ڒْعسْكَارْ إِنُو.“  
\v 9 \add مَاشَا\add* أَرْيَازْ ن أَربِّي إِسّكّْ \add إِجّْ\add* غَارْ ؤُجدْجِيذْ ن إِسْرَائِيل، إِنَّا: ”حْضَا إِخفْ نّشْ أَذْ ثكّذْ خْ ومْشَانْ نِّي، مَاغَارْ ذِينْ هْوَانْ أَيْثْ ن أَرَامْ.“  
\v 10 أَجدْجِيذْ ن إِسْرَائِيل إِسّكّْ \add إِرقَّاسنْ\add* غَارْ ومْشَانْ إِ خْ ثُوغَا أَكِيذسْ إِسِّيوڒْ ورْيَازْ ن أَربِّي ؤُ إِ زِي ثُوغَا إِ ذ أَسْ إِعْڒمْ وَانِيثَا، ؤُشَا إِڭَّا أَذْ حْضَانْ ذِينْ. \add ؤُ مَانْ أَيَا\add* وَارْ \add إِمْسَارْ شَا\add* إِشْثْ ن ثْوَاڒَا نِيغْ ثْنَاينْ ن ثْوَاڒَاوِينْ \add وَاهَا\add*.  
\v 11 ؤُڒْ ن ؤُجدْجِيذْ ن أَرَامْ إِهَاجْ خْ مَانْ أَيَا ؤُ نتَّا إِڒَاغَا إِ إِمْسخَّارنْ نّسْ، إِنَّا أَسنْ: ”مَا وَارْ ثْزمَّارمْ كنِّيوْ أَذْ أَيِي ثِينِيمْ مَانْ ونْ جَارْ أَنغْ إِتّْرَاحْ أَكْ-ذ ؤُجدْجِيذْ ن إِسْرَائِيل؟“  
\v 12 إِجّنْ زڭْ إِمْسخَّارنْ نّسْ إِنَّا: ”لَّ، سِيذِي إِنُو، أَجدْجِيذْ! مَاشَا إِلِيشَاعْ، أَنَابِي ونِّي \add إِدْجَانْ\add* ذِي إِسْرَائِيل، إِسَّارْڭبْ ؤُجدْجِيذْ ن إِسْرَائِيل أَوَاڒنْ إِ ثسَّاوَاڒذْ ذڭْ وخَّامْ نّشْ ن يِيضصْ.“  
\v 13 إِنَّا نتَّا: ”ؤُيُورمْ ؤُشَا خْزَارمْ مَانِي إِتِّيڒِي نتَّا. \add خنِّي\add* أَذْ سّكّغْ \add إِرْيَازنْ إِنُو\add*، أَذْ ث طّْفنْ.“ خبَّارنْ ث، نَّانْ: ”نتَّا أَقَا-ث ذِي ذُوثَانْ.“  
\v 14 \add خنِّي\add* إِسّكّْ نتَّا إِيْسَانْ ذ إِكَارُّوثنْ ذ إِجّْ ن ڒْعسْكَارْ أَمقّْرَانْ. نِيثْنِي إِوْضنْ ذِينْ ذِي دْجِيڒثْ ؤُشَا نّْضنْ-د إِ ثنْذِينْثْ.   
\m
\v 15 أَمْسخَّارْ ن أَربِّي إِكَّارْ غَارْ ثُوفُّوثْ ؤُشَا إِفّغْ غَارْ بَارَّا، ؤُ خْزَارْ، إِجّْ ن ڒْعسْكَارْ ثُوغَا إِنّضْ إِ ثنْذِينْثْ س ييْسَانْ ذ إِكَارُّوثنْ. \add خنِّي\add* إِنَّا أَسْ أَحُوذْرِي: ”أَ سِيذِي إِنُو، مِينْ غَا نڭّْ؟“  
\v 16 نتَّا إِنَّا: ”وَارْ تّڭّْوذْ شَا، مَاغَارْ إِنِّي غَارْنغْ أَطَّاسْ خْ يِينِّي غَارْسنْ.“ \x ◘ \xo 6:‏16 \xt 2 إِم. 32‏:‏7؛ يُوح. 16‏:‏33؛ 1 يُوح. 4‏:‏4\x*  
\v 17 إِلِيشَاعْ إِژُّودْجْ، إِنَّا: ”\add أَ\add* سِيذِي، أَرْزمْ أَسْ ثِيطَّاوِينْ، \add مَاحنْذْ\add* أَذْ إِژَارْ!“ ؤُ سِيذِي يَارْزمْ إِ ؤُمْسخَّارْ ثِيطَّاوِينْ \add أَڒَامِي\add* إِثْوَاڒَا. ؤُ خْزَارْ، أَذْرَارْ إِشُّورْ س ييْسَانْ ذ إِكَارُّوثنْ ن ثْمسِّي إِ د-إِنّْضنْ إِ إِلِيشَاعْ.  
\v 18 \add ؤُمِي\add* غَارسْ د-ؤُسِينْ نِيثْنِي، إِژُّودْجْ إِلِيشَاعْ إِ سِيذِي، إِنَّا: ”وّثْ مَاشَا ڒْڭنْسْ-أَ س ثُودَّارْغتْشْ!“ ؤُشَا نتَّا إِوْثَا ثنْ س ثُودَّارْغتْشْ عْلَاحْسَابْ أَوَاڒْ ن إِلِيشَاعْ.   
\m
\v 19 \add خَاسْ ؤُشَا\add* إِنَّا أَسنْ إِلِيشَاعْ: ”وَا وَارْ إِدْجِي ذ أَبْرِيذْ نِيشَانْ ؤُ وَارْ ثدْجِي ذ ثَانْذِينْثْ نِيشَانْ. ضْفَارمْ أَيِي-د! نشّْ أَذْ كنِّيوْ نذْهغْ غَارْ ورْيَازْ نِّي خْ ثَارزُّومْ!“ ؤُ نتَّا إِنْذهْ إِ-ثنْ غَارْ سَامَارْيَا.  
\v 20 ؤُمِي إِوْضنْ نِيثْنِي غَارْ سَامَارْيَا، إِمْسَارْ، أَقَا إِلِيشَاعْ إِنَّا: ”\add أَ\add* سِيذِي أَرْزمْ ثِيطَّاوِينْ ن إِرْيَازنْ-أَ، \add مَاحنْذْ\add* أَذْ ژَترنْ!“. ؤُشَا يَارْزمْ أَسنْ سِيذِي ثِيطَّاوِينْ أَڒَامِي ژْرِينْ. ؤُ خْزَارْ، أَقَا نِيثْنِي \add ثُوغَا أَثنْ\add* ذِي ڒْوسْطْ ن سَامَارْيَا.  
\v 21 \add ؤُمِي\add* ثنْ إِژْرَا، إِنَّا ؤُجدْجِيذْ ن إِسْرَائِيل إِ إِلِيشَاعْ: ”مَا أَذْ ثنْ نْغغْ، \add أَ\add* بَابَا؟“  
\v 22 \add مَاشَا\add* وَانِيثَا إِنَّا: ”وَارْ ثنْ نقّْ شَا! شكْ س يِيخفْ نّشْ، مَا أَذْ ثنْغذْ إِنِّي ثْحبّْسذْ س سِّيفْ نّشْ ذ ڒْقوْسْ نّشْ؟ سَارْسْ أَسنْ-د أَغْرُومْ ذ وَامَانْ مَاحنْذْ أَذْ شّنْ أَذْ سْونْ، ؤُشَا خنِّي أَذْعقْبنْ غَارْ سِيذِي نْسنْ.“  
\v 23 إِسّوْجذْ أَسنْ إِجّْ ن ؤُمنْسِي ذ أَمقّْرَانْ ؤُشَا نِيثْنِي شِّينْ، سْوِينْ. \add أَوَارْنِي أَيَا\add* يَارْخُو أَسنْ ؤُشَا فّْغنْ غَارْ سِيذِي نْسنْ. \add خنِّي\add* وَارْ د-ؤُسِينْثْ بَانْذِييَّاثْ ن أَرَامْ عَاذْ ذِي ثمُّورْثْ ن إِسْرَائِيل.   
\b  
\m
\v 24 أَوَارْنِي ؤُيَا إِمْسَارْ، أَقَا بِينْهَاذَاذْ، أَجدْجِيذْ ن أَرَامْ، إِسّْمُونْ مَارَّا ڒْعسْكَارْ نّسْ، إِفّغْ، حِيمَا أَذْ إِنّضْ إِ سَامَارْيَا.  
\v 25 إِمْسَارْ إِجّْ ن ڒَاژْ ذ أَمقّْرَانْ ذِي سَامَارْيَا، مَاغَارْ خْزَارْ، نِيثْنِي نّْضنْ أَسْ-د أَڒَامِي إِذْوڒْ إِجّْ ن ؤُزدْجِيفْ ن إِجّْ وغْيُوڒْ إِسكّْوَا ثْمنْيِينْ ن \add ؤُقِييَّاثْ ن\add* نُّوقَارْثْ ذ يِيجّْ ن أَرّْبعْ ن إِجّْ ن ڒقْيَاسْ س ڒغْبَارْ ن وذْبِيرْ \add إِذْوڒْ إِسكّْوَا\add* خمْسَا ن \add ؤُقِييَّاثْ ن\add* نُّوقَارْثْ.  
\v 26 ؤُمِي إِعْذُو ؤُجدْجِيذْ ن إِسْرَائِيل خْ ڒْحِيضْ، إِمْسَارْ، بلِّي ثْڒَاغَا أَسْ-د إِشْثْ ن ثمْغَارْثْ، ثنَّا: ”أوْشْ أَيِي-د أَفُوسْ، أَ سِيذِي إِنُو أَجدْجِيذْ!“  
\v 27 نتَّا إِنَّا: ”\add مَاڒَا\add* سِيذِي وَارْ ذ أَمْ إِوْشِي أَفُوسْ، مَامّشْ نشّْ ذ أَمْ غَا وْشغْ أَفُوسْ؟ مَا أَذْ يِيڒِي \add س شَا\add* زڭْ ؤُنذْرَارْ نِيغْ زِي ثْسِيرْثْ ن ؤُضِيڒْ؟“  
\v 28 إِنَّا أَسْ ؤُجدْجِيذْ: ”مِينْ شكْ يُوغِينْ؟“ نتَّاثْ ثنَّا: ”ثَامْغَارْثْ-أَ ثنَّا أَيِي: ’أَوِي-د مِّيمْ، حِيمَا أَسّْ-أَ أَذْ ث نشّْ ؤُ مِّي أَذْ ث نشّْ خنِّي ثِيوشَّا.‘ “  
\v 29 \add أَمُّو\add* نشِّينْ نسّْننَّا مِّي ؤُشَا نشَّا إِ-ث. \add مَاشَا\add* ڒَامِي ذ أَسْ نِّيغْ ثِيوشَّا نّسْ: ’أوْشْ \add ڒخُّو\add* مِّيمْ، حِيمَا أَذْ ث نشّْ!‘، ڒخْذنِّي ثسّْنُوفَّارْ نتَّاثْ مِّيسْ.“ \x ◘ \xo 6:‏29 \xt أَعَوذ. 28‏:‏53\x*   
\m
\v 30 ؤُمِي إِسْڒَا ؤُجدْجِيذْ أَوَاڒنْ ن ثمْغَارْثْ-أَ، إِشَارّڭْ أَرُّوضْ نّسْ ؤُشَا \add أَمُّو إِ\add* يُويُورْ خْ ڒْحِيضْ ؤُشَا إِژْرَا ڒْڭنْسْ إِلَّا أَقَا يَارْضْ إِشْثْ ن ثْخَانْشثْ \add ن وشْضَانْ\add* خْ أَرِّيمثْ نّسْ.  
\v 31 نتَّا إِنَّا: ”أجّْ أَذْ أَيِي إِڭّْ أَربِّي ثَا ذ ثَا ؤُشَا أَذْ ذَايسْ يَارْنِي عَاذْ، مَاڒَا إِقِّيمْ ؤُزدْجِيفْ ن إِلِيشَاعْ، مِّيسْ ن شَافَاثْ، خَاسْ أَڒْ أَسّْ-أَ!“ \x ◘ \xo 6:‏31 \xt 1 إِج. 19‏:‏2\x*   
\m
\v 32 إِلِيشَاعْ إِقِّيمْ ذِي ثَادَّارْثْ نّسْ ذ إِمقّْرَاننْ قِّيمنْ غَارسْ. ثُوغَا \add ؤُجدْجِيذْ\add* إِسّكّْ إِجّْ ن ورْيَازْ غَارْ زَّاثْ نّسْ، مَاشَا قْبڒْ مَا يِيوضْ ؤُرقَّاسْ غَارسْ، إِنَّا \add إِلِيشَاعْ\add* إِ إِمقّْرَاننْ: ”مَا ثژْرِيمْ أَقَا وَانِيثَا، مِّيسْ ن إِجّْ ن ؤُقتَّاڒْ، إِسّكّْ-د ونِّي ذ أَيِي غَا إِقسّنْ أَزدْجِيفْ؟ حْضَامْ ڒخُّو، خْمِي د غَا يَاسْ ؤُرقَّاسْ، بلّْعمْ ثَاوَّارْثْ ؤُ سْبدّمْ ث غَارْ ثوَّارْثْ! مَا وَارْ \add إِتّْوَاسڒْ\add* ڒْحسّْ ن إِصُورَافْ ن سِيذِيسْ أَوَارْنِي أَسْ؟“  
\v 33 ڒَامِي ثُوغَا أَكِيذْسنْ إِسَّاوَاڒْ عَاذْ، خْزَارْ، إِهْوَا-د ؤُرقَّاسْ غَارسْ. ؤُشَا أَجدْجِيذْ إِنَّا: ”خْزَارْ، ثُوعفّْنَا-يَا زِي سِيذِي. مِينْ غَا رَاجِيغْ عَاذْ \add خنِّي\add* زِي سِيذِي؟“   
\b  
\b  
\m  
\c 7
\s1 إِلِيشَاعْ إِزْوَارْ إِبَارّحْ س ؤُسنْجمْ ن سَامَارْيَا  
\m
\v 1 \add خنِّي\add* إِنَّا إِلِيشَاعْ: ”سْڒمْ إِ وَاوَاڒْ ن سِيذِي! أَمُّو إِ إِقَّارْ سِيذِي: ’ثِيوشَّا غَارْ ڒْوقْثْ-أَ أَذْ ثسْوَا إِجّْ ن ڒقْيَاسْ ن وَارنْ أَزْذَاذْ غَارْ ثوَّارْثْ ن سَامَارْيَا مْغِيرْ إِجّْ ن شِيقْلُو ؤُ أَذْ مّنْزنْ ؤُڒَا ذ ثْنَاينْ ن ڒقْيَاسْ ن إِمنْذِي إِ يِيجّْ ن شِيقْلُو \add وَاهَا\add*!“ \f ◼ \fr 7:‏1 \ft \+bd ’ڒقْيَاسْ‘\+bd* - عْڒَاينْ 7-8 لِيثْرُو.\f*  
\v 2 إِجّْ ن ؤُنغْرَافْ \add ن ڒْعسْكَارْ\add*، ونِّي خْ ؤُغِيڒْ نّسْ إِعمّذْ ؤُجدْجِيذْ، يَارَّا-د خْ ورْيَازْ ن أَربِّي: ”خْزَارْ، وَاخَّا مَاڒَا سِيذِي إِڭَّا ڒكْوَازَا ذڭْ ؤُجنَّا، مَا إِزمَّارْ أَيَا أَذْ إِمْسَارْ؟“ \add مَاشَا\add* نتَّا إِنَّا: ”خْزَارْ، أَذْ ث ثْژَارذْ س ثِيطَّاوِينْ نّشْ، مَاشَا وَارْ زَّايسْ ثتّتّذْ.“   
\b  
\m
\v 3 ثُوغَا ذِينْ أَربْعَا ن يرْيَازنْ زَّاثْ إِ وَاذَافْ ن ثوَّارْثْ. نَّانْ إِجّْ إِ ونّغْنِي: ”مَايمِّي غَا نقِّيمْ ذَا أَڒْ غَا نمّثْ؟ \x ◘ \xo 7:‏3 \xt لَاوِي 13‏:‏46\x*  
\v 4 مَاڒَا أَذْ نِينِي: ’أجّْ أَنغْ أَذْ نَاذفْ غَارْ ثنْذِينْثْ!‘، خنِّي إِدْجَا ڒَاژْ ذِي ثنْذِينْثْ ؤُ نشِّينْ أَذْ ذَايسْ نمّثْ. ؤُ مَاڒَا نقِّيمْ نشِّينْ ذَا، أَذْ نمّثْ \add عَاوذْ\add*. خنِّي ڒخُّو، أجّْ أَنغْ أَذْ نفّغْ أَذْ نوْضَا ذڭْ إِفَاسّنْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ ن أَرَامْ. مَاڒَا نِيثْنِي جِّينْ أَنغْ ندَّارْ، أَذْ نقِّيمْ ندَّارْ، ؤُ مَاڒَا نِيثْنِي نْغِينْ أَنغْ، \add خنِّي\add* أَذْ نمّثْ.“  
\v 5 نِيثْنِي كَّارنْ ذِي ثْبَامْبَاسْثْ، حِيمَا أَذْ ؤُيُورنْ غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ ن أَرَامْ. \add مَاشَا ؤُمِي\add* ؤُذْفنْ نِيثْنِي غَارْ طَّارْفْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ ن أَرَامْ، وَارْ ذِينْ ثُوغِي ؤُڒَا ذ إِجّنْ.  
\v 6 مَاغَارْ سِيذِي إِجَّا ڒْعسْكَارْ ن أَرَامْ أَذْ إِسڒْ إِ يِيجّْ ن ؤُجَارِّي ن إِكَارُّوثنْ ذ إِجّْ ن دّْرِيزْ ن إِيْسَانْ ذ دْجْغَارغْ ن إِجّْ ن ڒْعسْكَارْ ذ أَمقّْرَانْ، \add أَڒَامِي\add* نِيثْنِي نَّانْ إِجّنْ إِ ونّغْنِي: ”خْزَارْ، أَجدْجِيذْ ن إِسْرَائِيل إِشْرَا ذ إِحَارّشْ-د خَانغْ إِجدْجِيذنْ ن إِحِيتِّييّنْ ذ إِجدْجِيذنْ ن إِمِيصْرِييّنْ.“ \f ◼ \fr 7:‏6 \ft \+bd ’سِيذِي‘\+bd* - س ثْعِيبْرَانِيثْ ’سِيذِي إِنُو‘.\f*  \x ◘ \xo 7:‏6 \xt إِشا. 13‏:‏4\x*  
\v 7 كَّارنْ ؤُشَا أَروْڒنْ ذِي ثْبَامْبَاسْثْ ؤُشَا جِّينْ إِقِيضَانْ نْسنْ ذ ييْسَانْ نْسنْ ذ يغْيَاڒْ نْسنْ ؤُڒَا ذ ڒْمَارْڭحْ ن ڒْعسْكَارْ أَمْ مَامّشْ ثنْ ثُوغَا، ؤُشَا أَروْڒنْ مَاحنْذْ أَذْ سّْنجْمنْ ڒعْمَارْ نْسنْ.   
\m
\v 8 \add ڒَْامِي\add* د-إِوْضنْ أَيْثْ ن بُو-ڒْبَارْصْ غَارْ طَّارْفْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ، ؤُذْفنْ غَارْ إِجّْ ن ؤُقِيضُونْ، شِّينْ، سْوِينْ ؤُ إِوْينْ سّنِّي نُّوقَارْثْ ذ وُورغْ ذ وَارُّوضنْ ؤُشَا فّْغنْ، سّْنُوفَّارنْ أَيَا. \add أَوَارْنِي مَانْ أَيَا\add*عقْبنْ-د، ؤُذْفنْ غَارْ إِجّْ ن ؤُقِيضُونْ نّغْنِي ؤُشَا إِوْينْ ؤُڒَا سّنِّي \add شَا\add*، ؤُشَا فّْغنْ، سّْنُوفَّارنْ أَيَا \add عَاوذْ\add*.  
\v 9 \add خنِّي\add* نَّانْ إِ وَايَاوْيَا: ”نشِّينْ وَارْ نتّڭّْ مِينْ إِدْجَانْ نِيشَانْ. أَسّْ-أَ ذ إِجّْ ن وَاسّْ ن ڒخْبَارْ أَصبْحَانْ ؤُ نشِّينْ نسّغْذْ. \add مَاڒَا\add* نْرَاجَا \add ذَا\add* أَڒْ إِ غَا إِفُّو ڒْحَاڒْ، أَذْ أَنغْ ثڒْقفْ ڒْمُوعْصِييّثْ. \add خنِّي\add* ڒخُّو، أَسمْ-د، أجّْ أَنغْ أَذْ نُويُورْ، أَذْ ث نْعَاوذْ ذِي ثَادَّارْثْ ن ؤُجدْجِيذْ.“   
\m
\v 10 نِيثْنِي إِوْضنْ \add ذِينْ\add*، ڒَاغَانْ خْ ؤُعسَّاسْ ن ثوَّارْثْ ن ثنْذِينْثْ، حَاجَانْ أَسنْ، نَّانْ: ”نشِّينْ نُوذفْ غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ ن أَرَامْ، ؤُ خْزَارْ، وَارْ ذِينْ ؤُڒَا ذ إِجّْ، وَارْ نسْڒِي إِ شَا ن ڒْحسّْ ن يوْذَانْ، مْغِيرْ إِيْسَانْ ثُوغَا قّْننْ ذ يغْيَاڒْ ثُوغَا شَارْفنْ، ذ إِقِيضَانْ أَمْ مَامّشْ \add دْجَانْ\add*.“  
\v 11 إِڒَاغَا خْ إِعسَّاسنْ ن ثوَّارْثْ ؤُشَا سِّيوْضنْ نِيثْنِي \add أَرقَّاسْ\add* غَارْ ذَاخڒْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ.   
\m
\v 12 إِكَّارْ ؤُجدْجِيذْ ذِي دْجِيڒثْ، إِنَّا إِ إِمْسخَّارنْ نّسْ: ”نشّْ أَذْ أَومْ إِنِيغْ مِينْ أَكِيذْنغْ إِ غَا يڭّْ أَرَامْ. نِيثْنِي سّْننْ، أَقَا نشِّينْ ذ أَيْثْ ن بُو-دْجُوژْ. \add خْ ؤُينِّي\add* فّْغنْ زِي ڒْمَارْڭحْ ن ڒْعسْكَارْ، حِيمَا أَذْ نُوفَّارنْ ذڭْ إِيَّارْ، قَّارنْ: ’مَاڒَا نِيثْنِي أَذْ فّْغنْ زِي ثنْذِينْثْ، أَذْ ثنْ نطّفْ دَّارنْ ؤُشَا أَذْ نَاذفْ غَارْ ثنْذِينْثْ.‘ “  
\v 13 إِجّنْ زڭْ إِمْسخَّارنْ يَارَّا-د، إِنَّا: ”أجّْ \add إِرْيَازنْ\add* أَذْ كْسِينْ خمْسَا ن إِيْسَانْ نِّي عَاذْ ذِينْ إِدْجَانْ، إِنِّي إِقِّيمنْ ذِي ثنْذِينْثْ، \add ؤُ خنِّي\add* أَذْ نْژَارْ مَا أَذْ أَسنْ إِمْسَارْ أَمْ وَاطَّاسْ ن أَيْثْ ن إِسْرَائِيل إِنِّي ذَا إِقِّيمنْ، \add نِيغْ\add* أَمْ وَاطَّاسْ ن أَيْثْ ن إِسْرَائِيل إِنِّي إِتّْوَاهلّْكنْ. أجّْ أَنغْ أَذْ ثنْ نسّكّْ ؤُشَا خنِّي أَذْ نْژَارْ \add مِينْ إِ غَا يِيڒِي\add*.“   
\m
\v 14 كْسِينْ نِيثْنِي ثْنَاينْ ن إِيْسَانْ ن ثَازْڒَا. أَجدْجِيذْ إِسّكّْ إِ-ثنْ أَوَارْنِي إِ ڒْعسْكَارْ ن أَرَامْ، إِنَّا: ”ؤُيُورمْ، ثخْزَارمْ!“  
\v 15 نِيثْنِي ضْفَارنْ ثنْ أَڒْ لْ-ؤُرْذُونْ، ؤُ خْزَارْ، أَبْرِيذْ مَارَّا إِنْثِي س وَارُّوضْ ذ ڒحْوَايجْ نِّي إِمّنْضَارنْ أَيْثْ ن أَرَامْ أَمْ ثُوغَا تّْقدْجِيقنْ \add ذِي ثَاروْڒَا\add* نْسنْ. إِرقَّاسنْعقْبنْ ؤُ سِّيوْضنْ ڒخْبَارْ إِ ؤُجدْجِيذْ.  
\v 16 \add خنِّي\add* إِفّغْ ڒْڭنْسْ \add زِي ثنْذِينْثْ\add* ؤُشَا كشّْضنْ ڒْمَارْڭحْ ن ڒْعسْكَارْ ن أَرَامْ ؤُشَا ثمّنْزْ إِجّْ ن ڒقْيَاسْ ن وَارنْ أَزْذَاذْ س يِيجّْ ن شِيقْلُو ذ ثْنَاينْ ن ڒقْيَاسْ ن إِمنْذِي س يِيجّْ ن شِيقْلُو عْلَاحْسَابْ أَوَاڒْ ن سِيذِي. \f ◼ \fr 7:‏16 \ft \+bd ’ڒقْيَاسْ‘\+bd* - عْڒَاينْ 7-8 لِيثْرُو.\f*  
\v 17 إِڭَّا ؤُجدْجِيذْ أَنغْرَافْ \add ن ڒْعسْكَارْ\add* ونِّي خْ إِتّْشَاڒْ، حِيمَا أَذْ يِيڒِي خْ ثوَّارْثْ، \add مَاشَا\add* إِعْفسْ خَاسْ ڒْڭنْسْ ذِي ثوَّارْثْ أَڒَامِي إِمُّوثْ أَمْ مَامّشْ ثُوغَا إِنَّا ورْيَازْ ن أَربِّي، ونِّي إِسِّيوْڒنْ ؤُمِي ثُوغَا غَارسْ د-إِهْوَا ؤُجدْجِيذْ.  
\v 18 أَقَا إِمْسَارْ أَمْ مَامّشْ ثُوغَا إِسِّيوڒْ ورْيَازْ ن أَربِّي إِ ؤُجدْجِيذْ، إِ إِنَّانْ: ”ثِيوشَّا غَارْ ڒْوقْثْ-أَ \add أَذْ مّنْزنْ\add* غَارْ ثوَّارْثْ ن سَامَارْيَا ثْنَاينْ ن ڒقْيَاسْ ن إِمنْذِي س يِيجّْ ن شِيقْلُو ذ يِيجّْ ن ڒقْيَاسْ ن وَارنْ أَزْذَاذْ س يِيجّْ ن شِيقْلُو.“  
\v 19 ثُوغَا يَارَّا-د ؤُنغْرَافْ \add ن ڒْعسْكَارْ\add* خْ ورْيَازْ ن أَربِّي، إِنَّا: ”خْزَارْ، وَاخَّا مَاڒَا سِيذِي إِڭَّا ڒكْوَازَا ذڭْ ؤُجنَّا، مَا إِزمَّارْ أَذْ إِمْسَارْ ؤُيَا؟“ ؤُ نتَّا ثُوغَا إِنَّا: ”خْزَارْ، أَذْ ث ثْژَارذْ س ثِيطَّاوِينْ نّشْ، مَاشَا وَارْ زَّايْسنْ ثتّتّذْ.“  
\v 20 أَمُّو إِ ذ أَسْ ثمْسَارْ، \add مَاغَارْ\add* ڒْڭنْسْ إِعْفسْ خَاسْ ذِي ثوَّارْثْ. \add أَڒَامِي\add* إِمُّوثْ.   
\b  
\b  
\m  
\c 8
\s1 شْوَارْ ن إِلِيشَاعْ إِ ثمْغَارْثْ زِي شُونَامْ  
\m
\v 1 ڒَامِي إِسِّيوڒْ إِلِيشَاعْ أَكْ-ذ ثمْغَارْثْ ثنِّي ؤُمِي ثُوغَا إِسّْفَاقْ مِّيسْ، إِنَّا \add أَسْ\add*: ”كَّارْ، فّغْ، شمْ أَكْ-ذ ثْوَاشُونْثْ نّمْ ؤُ زْذغْ أَمْ يِيشْثْ ن ثْبَارَّانشْثْ مَانِي مَا ثْزمَّارذْ أَذْ ثْزذْغذْ، مَاغَارْ سِيذِي يُورَا إِشْثْ ن ڒحْصَارثْ ن ڒَاژْ ثنِّي إِ غَا يكّنْ عَاوذْ سبْعَا ن إِسڭّْوُوسَا خْ ثمُّورْثْ.“ \x ◘ \xo 8:‏1 \xt 2 إِج. 4‏:‏34\x*  
\v 2 ؤُشَا ثكَّارْ ثمْغَارْثْ، ثڭَّا عْلَاحْسَابْ أَوَاڒْ ن ورْيَازْ ن أَربِّي. نتَّاثْ ثفّغْ أَكْ-ذ ثْوَاشُونْثْ نّسْ ؤُشَا ثزْذغْ سبْعَا ن إِسڭّْوُوسَا ذِي ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ.   
\m
\v 3 أَوَارْنِي سبْعَا ن إِسڭّْوُوسَا، إِمْسَارْ بلِّي ثَامْغَارْثْ ثعْقبْ-د زِي ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ. نتَّاثْ ثفّغْ، حِيمَا أَذْ ثتَّارْ ثْوِيزَا ن ؤُجدْجِيذْ خْ ثَادَّارْثْ نّسْ ذ ييَّارْ نّسْ.  
\v 4 أَجدْجِيذْ ثُوغَا إِتّْحَارّضْ أَكْ-ذ جِيحَازِي، أَمْسخَّارْ ن ورْيَازْ ن أَربِّي، إِنَّا: ”حَاجَا أَيِي مَارَّا ثِيمسْڒَايِينْ ثِيمقّْرَانِينْ إِ إِڭَّا إِلِيشَاعْ.“  
\v 5 إِمْسَارْ أَمْ ثُوغَا إِتّْعَاوَاذْ وَانِيثَا إِ ؤُجدْجِيذْ خْ مَامّشْ د-إِسّْفَاقْ إِلِيشَاعْ إِجّْ ن ؤُمتِّينْ، خْزَارْ، ثُوسَا-د ثمْغَارْثْ نِّي ؤُمِي د-إِسّْفَاقْ مِّيسْ، حِيمَا أَذْ ثتَّارْ ثْوِيزَا ن ؤُجدْجِيذْ خْ ثَادَّارْثْ نّسْ ذ ييَّارْ نّسْ. \add خنِّي\add* إِنَّا جِيحَازِي: ”\add أَ\add* سِيذِي إِنُو أَجدْجِيذْ، ثَا ذ ثَامْغَارْثْ ذ وَا ذ مِّيسْ إِ د-إِسّْفَاقْ إِلِيشَاعْ غَارْ ثُوذَارْثْ.“  
\v 6 أَجدْجِيذْ إِسّقْسَا ثَامْغَارْثْ ؤُ نتَّاثْ ثْحَاجَا أَسْ ت-إِ-د. \add خَاسْ ؤُشَا\add* إِوْشَا أَسْ ؤُجدْجِيذْ إِجّْ ن ؤُمْسخَّارْ أَمْشنّعْ، إِنَّا: ”حْضَاثْ أَذْ غَارسْ إِتّْوَارّْ مَارَّا مِينْ إِدْجَانْ نّسْ ؤُڒَا ذ مَارَّا صَّابثْ ن إِيَّارْ زڭْ وَاسّْ نِّي ذِي ثجَّا نتَّاثْ ثَامُّورْثْ أَڒْ أَسّْ-أَ.“   
\b  
\m  
\s1 إِلِيشَاعْ ذِي ذِيمَاشْقْ  
\m
\v 7 إِلِيشَاعْ يُوسَا-د غَارْ ذِيمَاشْقْ \add ؤُمِي\add* بِينْهَاذَاذْ، أَجدْجِيذْ ن أَرَامْ، إِهْڒشْ. حَاجَانْ أَسْ مَانْ أَيَا، نَّانْ: ”أَقَا أَرْيَازْ ن أَربِّي يُوسَا-د ذَانِيثَا.“  
\v 8 \add خَاسْ ؤُشَا\add* إِنَّا ؤُجدْجِيذْ إِ حَازَايِيلْ: ”أَوِي-د أَكِيذكْ إِشْثْ ن ثرْزفْثْ، رُوحْ أَذْ ثڒْقِيذْ أَرْيَازْ ن أَربِّي ؤُشَا سقْسَا زَّايسْ سِيذِي، أَذْ ثِينِيذْ: ”مَا نشّْ أَذْ ڭّنْفِيغْ زِي ڒهْڒَاشْ-أَ؟“ \x ◘ \xo 8:‏8 \xt 1 إِج. 14‏:‏2، 3؛ 2 إِج. 1‏:‏2\x*  
\v 9 حَازَايِيلْ يُويُورْ أَذْ ث إِڒْقَا ؤُشَا يِيوِي أَكِيذسْ إِشْثْ ن ثرْزفْثْ، عْڒَامْ كُوڒْ نْ مِينْ إِدْجَانْ ذ لمْلِيحْ زِي ذِيمَاشْقْ، إِجّْ ن دّْقڒْ ن أَربْعِينْ ن إِڒغْمَانْ. نتَّا يِيوضْ ؤُ إِبدّْ زَّاثسْ، إِنَّا: ”مِّيشْ بِينْهَاذَاذْ، أَجدْجِيذْ ن أَرَامْ، إِسّكّْ أَيِي-د غَاركْ، مَاحنْذْ أَذْ سّقْسِيغْ: ’مَا أَذْ ڭّنْفِيغْ زِي ڒهْڒَاشْ-أَ؟‘ “  
\v 10 إِنَّا أَسْ إِلِيشَاعْ: ”ؤُيُورْ، أَذْ ثِينِيذْ: ’شكْ وَارْ ثڭّنْفِيذْ شَا كُوڒْشِي!‘ سِيذِي إِسّْشنْ أَيِي، أَقَا نتَّا أَذْ إِمّثْ نِيشَانْ.“   
\m
\v 11 ؤُذمْ نّسْ إِبْعَارْ ؤُ إِسّقْسحْ ذَايسْ ثَامُوغْڒِي أَڒَامِي وَارْ إِسِّينْ مِينْ غَا يڭّْ. \add خنِّي إِبْذَا\add* ورْيَازْ ن أَربِّي إِتّْرُو.  
\v 12 \add خنِّي\add* إِنَّا حَازَايِيلْ: ”مَايمِّي إِتّْرُو سِيذِي إِنُو؟“ نتَّا إِنَّا: ”مِينْزِي نشّْ سّْنغْ ڒحْڒِيقْ إِ ذ غَا ثَاوْيذْ شكْ إِ أَيْثْ ن إِسْرَائِيل. شكْ أَذْ ثقّْذذْ ثِيمسِّي إِ لْقلْعَاثْ نْسنْ، أَذْ ثنْغذْ إِحُوذْرِييّنْ نْسنْ س سِّيفْ، أَذْ ثْڒبْزذْ إِحنْجِيرنْ نْسنْ ؤُ ثِيمْغَارِينْ نْسنْ إِ إِكْسِينْ س دّيْسثْ أَذْ أَسنْثْ ثْشَارّْڭذْ أَعذِّيسْ.“ \x ◘ \xo 8:‏12 \xt 2 إِج. 10‏:‏32؛ 12‏:‏17؛ 13‏:‏7\x*  
\v 13 حَازَايِيلْ إِنَّا: ”مَاغَارْ مِينْ إِعْنَا ؤُمْسخَّارْ نّشْ، أَقْزِينْ نِّي، أَقَا نتَّا إِزمَّارْ أَذْ إِڭّْ ڒْحَاجّثْ ذ ثَامقّْرَانْثْ أَمْ ثَانِيثَا؟“ إِلِيشَاعْ إِنَّا: ”سِيذِي إِسّْشنْ أَيِي-د بلِّي أَذْ ثِيڒِيذْ ذ أَجدْجِيذْ خْ أَرَامْ.“  
\v 14 \add خنِّي\add* إِڭّْوجْ نتَّا خْ إِلِيشَاعْ، ؤُشَا يُوسَا-د غَارْ سِيذِيسْ. وَانِيثَا إِنَّا أَسْ: ”مِينْ ذ أَشْ إِنَّا إِلِيشَاعْ؟“ ؤُ نتَّا يَارَّا-د: ”نتَّا إِنَّا أَيِي: ’أَقَا شكْ أَذْ ثڭّنْفِيذْ!‘ “  
\v 15 ثِيوشَّا نّسْ إِمْسَارْ أَقَا إِكْسِي نتَّا إِشْثْ ن مَالْثَا، إِسّغْضصْ إِ-ت ذڭْ وَامَانْ ؤُشَا إِسَّارْسْ إِ-ت خْ ؤُغمْبُوبْ نّسْ أَڒَامِي إِمُّوثْ. ؤُشَا إِذْوڒْ حَازَايِيلْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\m  
\s1 يُورَامْ، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 16 ذڭْ ؤُسڭّْوَاسْ وِيسّْ خمْسَا ن يُورَامْ، مِّيسْ ن أَخَابْ، أَجدْجِيذْ ن إِسْرَائِيل، ؤُمِي ثُوغَا يَاهُوشَافَاثْ ذ أَجدْجِيذْ ن يَاهُوذَا، إِذْوڒْ يَاهُورَامْ، مِّيسْ ن يَاهُوشَافَاطْ، ذ أَجدْجِيذْ ن يَاهُوذَا. \x ◘ \xo 8:‏16 \xt [2 إِم. 21‏:‏2‏-‏20] — 2 إِم. 21‏:‏4، 5\x*  
\v 17 نتَّا \add ثُوغَا\add* غَارسْ ثْنَاينْ ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ ثْمنْيَا ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ.  
\v 18 نتَّا يُويُورْ ذڭْ وبْرِيذْ ن إِجدْجِيذنْ ن إِسْرَائِيل، أَمْ مَامّشْ ثُوغَا ثڭَّا ثَادَّارْثْ ن أَخَابْ، مَاغَارْ يدْجِيسْ ن أَخَابْ ثذْوڒْ ذ ثَامْغَارْثْ نّسْ. نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي.  
\v 19 \add مَاشَا\add* سِيذِي وَارْ إِخْسْ أَذْ يَاردّدْجْ يَاهُوذَا ذِي طّْوعْ ن ؤُمْسخَّارْ نّسْ ذَاوُوذْ، أَمْ مَامّشْ ذ أَسْ ثُوغَا إِنَّا، أَذْ أَسْ إِوْشْ ڒبْذَا إِجّْ ن ڒفْنَارْ زَّاثْ إِ ثِيطَّاوِينْ نّسْ ذِي طّْوعْ ن وَارَّاونْ نّسْ. \x ◘ \xo 8:‏19 \xt 2 صم. 7‏:‏13؛ 1 إِج. 11‏:‏36؛ 15‏:‏4؛ إِزهد. 132‏:‏17\x*   
\m
\v 20 ذڭْ وُوسَّانْ نّسْ إِزمَّارْ إِذُومْ أَذْ إِخْثُوتّڒْ زڭْ إِفَاسّنْ ن يَاهُوذَا ؤُمِيغوّْغنْ، ؤُ نِيثْنِي ڭِّينْ إِجّْ ن ؤُجدْجِيذْ خْ يِيخفْ نْسنْ. \x ◘ \xo 8:‏20 \xt أَمز. 27‏:‏40؛ 2 إِم. 21‏:‏8\x*  
\v 21 \add خَاسْ ؤُشَا\add* إِعْذُو يَاهُورَامْ أَكْ-ذ مَارَّا إِكَارُّوثنْ \add ن ؤُمنْغِي\add* نّسْ غَارْ صَاعِيرْ. ؤُشَا إِمْسَارْ أَقَا إِكَّارْ س دْجِيڒثْ ؤُشَا إِهْجمْ خْ أَيْثْ ن إِذُومْ إِنِّي ثُوغَا إِ ذ أَسْ د-إِنّْضنْ إِ نتَّا ؤُ إِ إِمقّْرَاننْ ن إِكَارُّوثنْ \add ن ؤُمنْغِي\add*، \add مَاشَا\add* ڒْڭنْسْ يَارْوڒْ غَارْ إِقِيضَانْ نّسْ.  
\v 22 \add س ؤُينِّي\add*، خْثُوتّْڒنْ أَيْثْ ن إِذُومْ س ؤُغوّغْ زِي جَارْ إِفَاسّنْ ن يَاهُوذَا أَڒْ أَسّْ-أَ. ذِي ڒْوقْثْ نِّي بعْذَا إِغوّغْ ؤُڒَا ذ لِيبْنَا.   
\m
\v 23 إِمزْرُوينْ إِ إِقِّيمنْ ن يَاهُورَامْ، ذ مَارَّا مِينْ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا؟  
\v 24 يَاهُورَامْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نتَّا إِتّْوَانْضڒْ جَارْ ڒجْذُوذْ نّسْ ذِي ثنْذِينْثْ ن ذَاوُوذْ. مِّيسْ، أَخَازْيَا، إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. \x ◘ \xo 8:‏24 \xt 2 إِم. 21‏:‏19\x*   
\b  
\m  
\s1 أَخَازْيَا، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 25 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثنْعَاشْ ن يُورَامْ، مِّيسْ ن أَخَابْ، أَجدْجِيذْ ن إِسْرَائِيل، إِبْذَا أَخَازْيَا، مِّيسْ ن يَاهُورَامْ، أَجدْجِيذْ ن يَاهُوذَا، أَذْ إِحْكمْ. \x ◘ \xo 8:‏25 \xt [2 إِم. 22‏:‏1‏-‏6] — 2 إِم. 22‏:‏1\x*  
\v 26 أَخَازْيَا \add ثُوغَا\add* غَارسْ ثْنَاينْ ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ إِجّْ ن ؤُسڭّْوَاسْ ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ عَاثَالْيَا، يدْجِيسْ ن عُومْرِي، أَجدْجِيذْ ن إِسْرَائِيل. \x ◘ \xo 8:‏26 \xt 2 إِم. 22‏:‏2\x*  
\v 27 نتَّا يُويُورْ ذڭْ وبْرِيذْ ن ثَادَّارْثْ ن أَخَابْ ؤُ إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَمْ ثَادَّارْثْ ن أَخَابْ، مَاغَارْ ثُوغَا ذ أَضڭّْوَاڒْ ن ثَادَّارْثْ ن أَخَابْ.   
\m
\v 28 إِفّغْ \add أَخَازْيَا\add* أَكْ-ذ يُورَامْ، مِّيسْ ن أَخَابْ، إِ ؤُمنْغِي أَكْ-ذ حَازَايِيلْ، أَجدْجِيذْ ن أَرَامْ، غَارْ رَامُوثْ ذِي جِيلْعَاذْ، \add مَاشَا\add* أَيْثْ ن أَرَامْغڒْبنْ خْ يُورَامْ.  
\v 29 \add خنِّي\add* يَارڭّْوحْ ؤُجدْجِيذْ يُورَامْ، مَاحنْذْ أَذْ يَارْزُو ذِي يَازْرَاعِيلْ أَڭنْفُو زڭْ إِيزِّيمنْ نِّي إِ ذ أَسْ ڭِّينْ \add أَيْثْ ن\add* أَرَامْ ؤُمِي إِمّْنغْ نتَّا ذِي رَامُوثْ أَكْ-ذ ؤُجدْجِيذْ نْسنْ حَازَايِيلْ، أَجدْجِيذْ ن أَرَامْ. أَخَازْيَا، مِّيسْ ن يَاهُورَامْ، أَجدْجِيذْ ن يَاهُوذَا، إِهْوَا-د \add ذِينْ\add*، حِيمَا أَذْ إِسِّيجّْ خْ يُورَامْ، مِّيسْ ن أَخَابْ، ذِي يَازْرَاعِيلْ، ؤُمِي ثُوغَا إِهْڒشْ نتَّا. \x ◘ \xo 8:‏29 \xt 2 إِج. 9‏:‏15؛ 22‏:‏6، 7\x*   
\b  
\b  
\m  
\c 9
\s1 يَاهُو إِذْوڒْ ذ أَجدْجِيذْ خْ إِسْرَائِيل  
\m
\v 1 \add خنِّي\add* أَنَابِي إِلِيشَاعْ إِڒَاغَا-د إِ يِيجّنْ زڭْ أَيْثْ ن إِنَابِييّنْ، إِنَّا أَسْ: ”بْيسْ، كْسِي أَغَارَّافْ-أَ ن زّشْثْ ذڭْ ؤُفُوسْ نّشْ ؤُشَا ثُويُورذْ غَارْ رَامُوثْ \add ذِي\add* جِيلْعَاذْ. \x ◘ \xo 9:‏1 \xt 1 إِج. 19‏:‏16\x*  
\v 2 \add خْمِي\add* ذِينِّي إِ غَا ثَاوْضذْ، أَرْزُو خْ يَاهُو، مِّيسْ ن يَاهُوشَافَاطْ، مِّيسْ ن نِيمْشِي. أَذفْ \add غَارسْ\add* ؤُشَا أجّْ إِ-ث أَذْ د-إِكَّارْ زِي ڒْوسْطْ ن يَايْثْمَاسْ، نْذهْ إِ-ث غَارْ إِجّْ ن وخَّامْ إِطُّورْفِييْ مْلِيحْ.  
\v 3 \add خنِّي\add* كْسِي أَغَارَّافْ ن زّشْثْ، زدْجعْ إِ-ث خْ ؤُزدْجِيفْ نّسْ ؤُشَا إِنِي: ’أَمُّو إِ إِقَّارْ سِيذِي: نشّْ ذهْنغْ شكْ ذ أَجدْجِيذْ خْ إِسْرَائِيل.‘ \add خنِّي\add* أَرْزمْ ثَاوَّارْثْ، أَرْوڒْ، وَارْ تّْرِيجِي عَاذْ كْثَارْ!“ \x ◘ \xo 9:‏3 \xt 2 إِم. 22‏:‏7\x*   
\m
\v 4 أَحُوذْرِي، أَمْسخَّارْ ن ؤُنَابِي، يُويُورْ ذڭْ وبْرِيذْ غَارْ رَامُوثْ \add ذِي\add* جِيلْعَاذْ.  
\v 5 \add ؤُمِي\add* \add ذِينْ\add* د-يِيوضْ، خْزَارْ، إِكُومَانْذَارنْ ن ڒْعسْكَارْ ثُوغَا قِّيمنْ ذِينِّي. نتَّا إِنَّا: ”نشّْ غَارِي إِجّْ ن وَاوَاڒْ إِ شكْ، \add أَ\add* ڒْقبْطَانْ. يَاهُو إِسّقْسَا: ”إِ مَانْ ونْ زَّايْنغْ مَارَّا؟“ نتَّا إِنَّا: ”إِ شكْ، \add أَ\add* ڒْقبْطَانْ!“  
\v 6 \add خنِّي\add* إِكَّارْ يَاهُو، يُوذفْ غَارْ ثَادَّارْثْ. ؤُ نتَّا إِفَارّغْ أَسْ زّشْثْ خْ ؤُزدْجِيفْ نّسْ، إِنَّا أَسْ: ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’نشّْ ذهْنغْ شكْ ذ أَجدْجِيذْ خْ ڒْڭنْسْ ن سِيذِي، خْ إِسْرَائِيل.  
\v 7 شكْ أَذْ ثوْثذْ ثَادَّارْثْ ن أَخَابْ، سِيذِي نّشْ، ؤُ نشّْ أَذْ تَّارغْ زڭْ ؤُفُوسْ ن إِزَابِيلْ إِذَامّنْ ن إِمْسخَّارنْ إِنُو، إِنَابِييّنْ، ؤُڒَا ذ إِذَامّنْ ن مَارَّا إِمْسخَّارنْ ن سِيذِي.  
\v 8 مَارَّا ثَادَّارْثْ ن أَخَابْ أَذْ ثتّْوَاكّسْ، ؤُ نشّْ أَذْ قْضِيغْ زِي ثَادَّارْثْ ن أَخَابْ مَارَّا وِي ث إِتّڭّنْ خْ ڒْحِيضْ، \add أَمْ\add* ونِّي إِتّْوَاطّْفنْ، \add أَمْ\add* ونِّي ؤُمِي جِّينْ ذِي إِسْرَائِيل. \x ◘ \xo 9:‏8 \xt 1 إِج. 21‏:‏21\x*  
\v 9 نشّْ أَذْ أَرّغْ ثَادَّارْثْ ن أَخَابْ أَمشْنَاوْ ثَادَّارْثْ ن يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، ؤُ أَمْ ثَادَّارْثْ ن بَاعْشَا، مِّيسْ ن أَخِييَا. \x ◘ \xo 9:‏9 \xt 1 إِج. 14‏:‏10؛ 15‏:‏29؛ 16‏:‏3، 11\x*  
\v 10 إِطَانْ أَذْ شّنْ إِزَابِيلْ ذڭْ إِيَّارْ ن يَازْرَاعِيلْ ؤُشَا وَارْ إِتِّيڒِي ؤُڒَا ذ إِجّْ ونِّي ت إِ غَا إِنضْڒنْ.“ \add خنِّي\add* يَارْزمْ نتَّا ثَاوَّارْثْ ؤُشَا يَارْوڒْ.‘ “ \x ◘ \xo 9:‏10 \xt 1 إِج. 21‏:‏23\x*  
\v 11 ؤُمِي د-إِفّغْ يَاهُو غَارْ بَارَّا غَارْ إِمْسخَّارنْ ن سِيذِيسْ، نَّانْ أَسْ: ”أَقَا شكْ مْلِيحْ؟ مَايمِّي إِ غَاركْ د-يُوسَا ؤُبُوهَاڒِي-يَا؟“ نتَّا يَارَّا-د خَاسنْ: ”كنِّيوْ ثسّْنمْ أَرْيَازْ ذ ڒْهَارْذْ نّسْ!“  
\v 12 \add مَاشَا\add* نِيثْنِي نَّانْ ”ذ إِخَارِّيقنْ، إِنِي أَنغْ \add ث\add*!“ \add خنِّي\add* إِنَّا: ”أَمُّو ذ وَامُّو إِ كِيذِي إِسِّيوڒْ، إِنَّا: ’أَمُّو إِ إِقَّارْ سِيذِي: نشّْ ذهْنغْ شكْ ذ أَجدْجِيذْ خْ إِسْرَائِيل.‘ “  
\v 13 \add ڒخْذنِّي\add* قدْجْقنْ ؤُ كُوڒْ إِجّْ إِكْسِي أَرُّوضْ نّسْ ؤُشَا إِسَّارْسْ إِ-ث سَاذُو \add إِضَارنْ\add* نّسْ خْ ثَارذِّيفِينْ ن دّْرُوجْ ؤُشَا سُوضنْ ذڭْ ؤُيِيشّْ ن إِشَارِّي، نَّانْ: ”يَاهُو ذ أَجدْجِيذْ!“   
\m
\v 14 يَاهُو، مِّيسْ ن يَاهُوشَافَاطْ، مِّيسْ ن نِيمْشِي، إِڭَّا إِجّْ ن ڒْعَاهْذْ ضِيدّْ يُورَامْ. يُورَامْ، نتَّا \add جْمِيعْ\add* أَكْ-ذ مَارَّا إِسْرَائِيل، ثُوغَا إِحْضَا خْ رَامُوثْ \add ذِي\add* جِيلْعَاذْ أَرنْذَاذْ ن وُوذمْ ن حَازَايِيلْ، أَجدْجِيذْ ن أَرَامْ.  
\v 15 \add مَاشَا\add* أَجدْجِيذْ يُورَامْ يَارڭّْوحْ-د، مَاحنْذْ أَذْ يَارْزُو ذِي يَازْرَاعِيلْ أَڭنْفُو زڭْ إِيزِّيمنْ إِ ذ أَسْ ثُوغَا ڭِّينْ \add أَيْثْ ن\add* أَرَامْ، ؤُمِي إِمّْنغْ أَكْ-ذ حَازَايِيلْ، أَجدْجِيذْ ن أَرَامْ. يَاهُو إِنَّا: ”مَاڒَا كنِّيوْ ثتَّافْقمْ، \add خنِّي\add* وَارْ تّجِّيمْ أَذْ يَارْوڒْ ؤُڒَا ذ إِجّْ زِي ثنْذِينْثْ، أَذْ يُويُورْ مَاحنْذْ أَذْ إِسِّيوضْ ڒخْبَارْ-أَ غَارْ يَازْرَاعِيلْ.“ \x ◘ \xo 9:‏15 \xt 2 إِج. 8‏:‏29\x*   
\b  
\m  
\s1 ڒْموْثْ ن ؤُجدْجِيذْ يُورَامْ ذ ؤُجدْجِيذْ أَهَازْيَا ذ ثْجدْجِيذْثْ إِزَابِيلْ  
\m
\v 16 \add خنِّي\add* إِنْيَا \add ذڭْ ؤُكَارُّو نّسْ\add*، إِنْذهْ غَارْ يَازْرَاعِيلْ، مَاغَارْ ذِينِّي إِ ثُوغَا يُورَامْ. أَخَازْيَا، أَجدْجِيذْ ن يَاهُوذَا، ثُوغَا إِهْوَا-د، حِيمَا أَذْ إِسِّيجّْ خْ يُورَامْ.  
\v 17 أَعسَّاسْ إِبدّْ خْ صُّومْعثْ ذِي يَازْرَاعِيلْ ؤُشَا إِژْرَا يَاهُو يُوسَا-د، إِنَّا: ”نشّْ تّْوَاڒِيغْ إِجّْ ن ؤُهِيمُورْ.“ \add خنِّي\add* إِنَّا يُورَامْ: ”أَوِي-د إِجّْ ن بُو-ؤُيِيسْ ؤُشَا سّكّْ إِ-ث-إِ-د إِ ؤُمْسَاڭَارْ أَكِيذْسنْ، أَذْ يِينِي: ”مَا ذ ڒهْنَا \add مِينْ خفْ د-ثُوسِيذْ\add*؟“  
\v 18 بُو-ؤُيِيسْ إِنْيَا، حِيمَا أَذْ ث إِڒْقَا، إِنَّا: ”أَمُّو إِ إِقَّارْ ؤُجدْجِيذْ: ’مَا ذ ڒهْنَا \add مِينْ خفْ د-ثُوسِيذْ\add*؟‘ “ \add مَاشَا\add* يَاهُو يَارَّا-د \add خَاسْ\add*: ”مَانِي شكْ إِشْقَا ڒهْنَا؟ أَسْ-د غَارْ ضفَّارْ إِنُو.“ أَعسَّاسْ إِعْڒمْ \add أَيَا\add*، إِنَّا: ”أَمْسخَّارْ يِيوضْ غَارْسنْ، \add مَاشَا\add* وَارْ د-إِعْقِيبْ شَا.“  
\v 19 إِسّكّْ ؤُجدْجِيذْ إِجّْ ن بُو-ؤُيِيسْ وِيسّْ ثْنَاينْ. \add ؤُمِي\add* د-يُوسَا وَانِيثَا غَارْسنْ، إِنَّا: ”أَمُّو إِ إِقَّارْ ؤُجدْجِيذْ: ’مَا ذ ڒهْنَا \add مِينْ خفْ د-ثُوسِيذْ\add*؟‘ “ \add مَاشَا\add* يَاهُو يَارَّا-د \add خَاسْ\add*: ”مَانِي شكْ إِشْقَا ڒهْنَا. أَسْ-د غَارْ ضفَّارْ إِنُو.“  
\v 20 أَعسَّاسْ إِعْڒمْ \add س مَانْ أَيَا\add* عَاوذْ: ”نتَّا يِيوضْ إِ-ثنْ، \add مَاشَا\add* وَارْ د-إِعْقِيبْ شَا ؤُ مَامّشْ إِندّهْ أَيِيسْ، إِڭَّا أَمْ مَامّشْ إِتّڭّْ يَاهُو، مِّيسْ ن نِيمْشِي، مَاغَارْ نتَّا إِندّهْ أَمْ إِندّهْ إِجّْ ن ؤُبُوهَاڒِي.“   
\m
\v 21 \add خنِّي\add* إِنَّا يُورَامْ: ”حزّمْ أَكَارُّو!“ حزّْمنْ أَكَارُّو نّسْ ؤُ يُورَامْ، أَجدْجِيذْ ن إِسْرَائِيل، إِفّغْ أَكْ-ذ أَخَازْيَا، أَجدْجِيذْ ن يَاهُوذَا، نذْهنْ كُوڒْ إِجّْ أَكَارُّو نّسْ. نِيثْنِي فّْغنْ إِ ؤُمْسَاڭَارْ أَكْ-ذ يَاهُو ؤُشَا ؤُفِينْ ث غَارْ ييَّارْ ن نابُوثْ، أَيَازْرَاعِيلِي.  
\v 22 إِمْسَارْ ؤُمِي إِژْرَا يُورَامْ يَاهُو، إِنَّا: ”مَا ذ ڒهْنَا \add إِ خفْ د-ثُوسِيذْ\add*، \add أَ\add* يَاهُو؟“ \add مَاشَا\add* وَانِيثَا يَارَّا-د: ”مَانَا ڒهْنَا-يَا مِينْ غَا يكّْ فَارْقْ-شّْغڒْ ن يمَّاشْ إِزَابِيلْ ذ ثْسحَّارِينْ نّسْ \add أَمُّو\add* س وَاطَّاسْ؟“  
\v 23 إِنّقْڒبْ يُورَامْ، حِيمَا أَذْ يَارْوڒْ، ؤُشَا إِنَّا إِ أَخَازْيَا: ”ثَامنْزِيوْثْ، أَخَازْيَا!“  
\v 24 مَاشَا يَاهُو إِمْنعْ ڒْقوْسْ نّسْ ذڭْ ؤُفُوسْ ؤُشَا إِڒْقفْ يُورَامْ \add س فْڒِيثْشَا\add* جَارْ إِغَادْجنْ نّسْ. فْڒِيثْشَا ثسْنُوقّبْ قَاعْ ؤُڒْ نّسْ ؤُشَا إِوْضَا نتَّا ذڭْ ؤُكَارُّو نّسْ.  
\v 25 \add خنِّي\add* إِنَّا يَاهُو إِ بِيذْكَارْ، أَنغْرَافْ نّسْ \add ن ڒْعسْكَارْ\add*: ”كْسِي ث ؤُشَا نْضَارْ إِ-ث ذِي ثسْغَارْثْ ن ييَّارْ ن نابُوثْ، أَيَازْرَاعِيلِي. عْقڒْ، نشّْ ذ شكْ، إِجّْ غَارْ ؤُغزْذِيسْ ن ونّغْنِي، أَقَا نذْهنْ \add خْ إِكَارُّوثنْ نّغْ\add* أَوَارْنِي إِ بَابَاسْ أَخَابْ ؤُمِي خَاسْ إِشثْشَا سِيذِي أَمُّو، \add إِنَّا\add*:  
\v 26 ’س ثِيذتّْ أَمْ ژْرِيغْ إِضنَّاضْ إِذَامّنْ ن نابُوثْ ذ إِحنْجِيرنْ نّسْ، إِقَّارْ سِيذِي، أَمُّو إِ زَّايكْ ثنْ غَا خڒْفغْ خْ ييَّارْ-أَ، إِسَّاوَاڒْ سِيذِي.‘ خنِّي ڒخُّو، كْسِي ث ؤُشَا نْضَارْ إِ-ث ذڭْ إِيَّارْ عْلَاحْسَابْ أَوَاڒْ ن سِيذِي.“ \x ◘ \xo 9:‏26 \xt 1 إِج. 21‏:‏19\x*   
\m
\v 27 \add ؤُمِي\add* أَخَازْيَا، أَجدْجِيذْ ن يَاهُوذَا، إِژْرَا \add أَيَا\add*، إِطّفْ أَبْرِيذْ غَارْ بَايْثْ-هَاڭَانْ. يَاهُو إِضْفَارْ إِ-ث ؤُ \add ڒَْامِي يِيوضْ\add* غَارْ ثيْسَارْثْ ن جُورْ نِّي إِدْجَانْ غَارْ جِيبْلِيعَامْ، إِنَّا: ”وّثْ إِ-ث ؤُڒَا ذ نتَّا خْ ؤُكَارُّو!“ \add خنِّي\add* يَارْوڒْ نتَّا غَارْ مَاجِيدُّو ؤُشَا إِمُّوثْ ذِينْ. \x ◘ \xo 9:‏27 \xt 2 إِم. 22‏:‏7‏-‏9\x*  
\v 28 إِمْسخَّارنْ نّسْ إِوْينْ ث \add خْ ؤُكَارُّو\add* غَارْ ؤُرْشَالِيمْ ؤُشَا نضْڒنْ ث ذڭْ ونْضڒْ نّسْ جَارْ ڒجْذُوذْ نّسْ ذِي ثنْذِينْثْ ن ذَاوُوذْ.  
\v 29 ذڭْ ؤُسڭّْوَاسْ وِيسّْ حِيطَاشْ ن يُورَامْ، مِّيسْ ن أَخَابْ، ثُوغَا إِذْوڒْ أَخَازْيَا ذ أَجدْجِيذْ خْ يَاهُوذَا.   
\b  
\m
\v 30 \add خنِّي\add* يُوسَا-د يَاهُو غَارْ يَازْرَاعِيلْ. \add ڒَْامِي\add* ت ثسْڒَا إِزَابِيلْ، ثْكحّڒْ ثِيطَّاوِينْ نّسْ، ثْزوّقْ أَشُوَّافْ نّسْ ؤُشَا ثخْزَارْ زِي ڒْكَازِي غَارْ سْوَادَّايْ.  
\v 31 \add ؤُمِي\add* د-يُوذفْ يَاهُو زِي ثَاوَّارْثْ، ثنَّا: ”مَا ذ ڒهْنَا \add إِ خفْ د-ثُوسِيذْ\add*، زِيمْرِي، \add أَ شكْ\add* ونِّي إِنْغِينْ سِيذِيسْ؟“ \f ◼ \fr 9:‏31 \ft \+bd ’أَنقَّامْ‘\+bd* - أَقَا-ث ذ أَرْيَازْ ونِّي إِنْغِينْ إِجّْ ن بْنَاذمْ.\f*  \x ◘ \xo 9:‏31 \xt 1 إِج. 16‏:‏18\x*  
\v 32 نتَّا إِخْزَارْ غَارْ ڒْكَازِي سنّجْ، إِنَّا: ”وِي أَكِيذِي إِدْجَانْ؟ مَانْ ونْ؟“ \add خنِّي\add* خْزَارنْ ثْنَاينْ نِيغْ ثْڒَاثَا ن إِمْسخَّارنْ إِشنّْعنْ غَارسْ \add ذِينْ\add* سْوَادَّايْ.  
\v 33 نتَّا إِنَّا \add أَسنْ\add*: ”نْضَارمْ ت-إِ-د سْوَادَّايْ!“ نِيثْنِي نْضَارنْ-ت-إِ-د سْوَادَّايْ أَڒَامِي إِذَامّنْ نّسْ تّْوَارُوشّنْ خْ ڒْحِيضْ ؤُ خْ ييْسَانْ، ؤُ نتَّا إِڒْبزْ إِ-ت.  
\v 34 نتَّا يُوذفْ ؤُشَا إِشَّا، إِسْوَا. \add أَوَارْنِي ؤُيَا\add* إِنَّا: ”خْزَارمْ غَارْ ثْمخْزِيوْثْ نِّي ؤُ نضْڒمْ ت، مَاغَارْ نتَّاثْ ذ يدْجِيسْ ن ؤُجدْجِيذْ.“ \x ◘ \xo 9:‏34 \xt 1 إِج. 16‏:‏31\x*  
\v 35 نِيثْنِي ؤُيُورنْ، حِيمَا أَذْ ت نضْڒنْ، \add مَاشَا\add* نِيثْنِي وَارْ ت ؤُفِينْ شَا مْغِيرْ ثَاشقُّوفْثْ ن ؤُزدْجِيفْ ذ إِضَارنْ ذ إِفَاسّنْ وَاهَا.  
\v 36 \add ؤُمِي\add* د -عقْبنْ، عَاوْذنْ أَسْ \add ث\add* ؤُ نتَّا يَارَّا-د: ”وَا ذ أَوَاڒْ ن سِيذِي نِّي إِسِّيوِيڒْ س ؤُقمُّومْ ن ؤُمْسخَّارْ نّسْ، إِلِيشَاعْ أَثِيشْبِي. نتَّا إِنَّا: ’خْ ييَّارْ ن يَازْرَاعِيلْ إِطَانْ أَذْ شّنْ أَيْسُومْ \add ن ڒْخشْبثْ\add* ن إِزَابِيلْ. \x ◘ \xo 9:‏36 \xt 1 إِج. 21‏:‏23\x*  
\v 37 ڒْخشْبثْ ن إِزَابِيلْ أَذْ ثِيڒِي أَمْ ڒغْبَارْ خْ ييَّارْ ذڭْ وحْوِيشْ ن يَازْرَاعِيلْ، أَڒْ غَا ثَافْ وَارْ ذِينْ وِي غَا إِنِينْ: ثَا ذ إِزَابِيلْ.‘ “   
\b  
\b  
\m  
\c 10
\s1 يَاهُو إِنْغَا ڒَادْجْ ن أَخَابْ  
\m
\v 1 أَخَابْ ثُوغَا غَارسْ سبْعِينْ ن إِحنْجِيرنْ ذِي سَامَارْيَا. يَاهُو يُورَا ثِيبْرَاثِينْ، إِسّكّْ \add إِ-ثنْثْ\add* غَارْ سَامَارْيَا إِ إِمقّْرَاننْ ن يَازْرَاعِيلْ، إِ إِمْغَارنْ ؤُ إِ يِينِّي يَاربَّانْ \add إِحنْجِيرنْ ن\add* أَخَابْ. \add ذَايْسنْثْ\add* إِنَّا:  
\v 2 ”مَاڒَا ڒخُّو ثَابْرَاثْ-أَ ثُوسَا-د غَارْومْ، \add أَمْ\add* غَارْومْ إِحنْجِيرنْ ن سِيذِيثْومْ ڒَا ذ إِكَارُّوثنْ ذ ييْسَانْ، ذ إِشْثْ ن ثنْذِينْثْ إِفَارْينْ ذ ڒسْنَاحْ،  
\v 3 أَرْزُومْ \add خنِّي\add* خْ يِينِّي إِصبْحنْ ذ إِنِّي إِمحْضنْ قَاعْ جَارْ إِحنْجِيرنْ ن سِيذِيثْومْ ؤُ سْغِيممْ \add ث\add* خْ ڒْعَارْشْ ن بَابَاسْ ؤُ وْثمْ ذِي طّْوعْ ن ثَادَّارْثْ ن سِيذِيثْومْ.“  
\v 4 \add مَاشَا\add* نِيثْنِي ذوْڒنْ تّڭّْوذنْ أَطَّاسْ، نَّانْ: ”خْزَارْ، ثْنَاينْ ن إِجدْجِيذنْ وَارْ زمَّارنْ أَذْ قِّيمنْ بدّنْ زَّاثسْ، مَامّشْ \add إِ غَا نْزمَّارْ نشِّينْ\add* أَذْ نقِّيمْ نْبدّْ؟“  
\v 5 إِنِّي إِدْجَانْ خْ ثَادَّارْثْ ؤُ خْ ثنْذِينْثْ، إِمْغَارنْ ذ يِينِّي يَاربَّانْ \add إِحنْجِيرنْ ن أَخَابْ\add*، سّكّنْ \add إِجّْ ن ؤُرقَّاسْ\add* غَارْ يَاهُو، نَّانْ: ”نشِّينْ ذ إِمْسخَّارنْ نّشْ، ؤُ مَارَّا مِينْ ذ أَنغْ غَا ثِينِيذْ، أَذْ \add ث\add* نڭّْ. نشِّينْ وَارْ نتّڭّْ ؤُڒَا ذ إِجّْ ذ أَجدْجِيذْ. أڭّْ مِينْ ثتّْوَاڒِيذْ نِيشَانْ ذِي ثِيطَّاوِينْ نّشْ.“   
\m
\v 6 \add خنِّي\add* يُورَا غَارْسنْ إِشْثْ ن ثبْرَاثْ إِ ثْوَاڒَا وِيسّْ ثْنَاينْ، إِنَّا: ”مَاڒَا أَقَا كنِّيوْ غَارْ ؤُغزْذِيسْ إِنُو، أَذْ ثسْڒمْ غَارْ مِينْ غَا إِنِيغْ، كْسِيمْ \add خنِّي\add* إِزدْجِيفنْ ن إِحنْجِيرنْ ن سِيذِيثْومْ، ؤُ أَسمْ-د ثِيوشَّا أَمُّو غَارْ ڒْوقْثْ-أَ غَارِي ذِي يَازْرَاعِيلْ.“ إِحنْجِيرنْ ن ؤُجدْجِيذْ، سبْعِينْ ن يرْيَازنْ، \add ثُوغَا زدّْغنْ\add* غَارْ إِمْشنّْعنْ ن ثنْذِينْثْ، إِنِّي ثنْ يَاربَّانْ.  
\v 7 ؤُمِي غَارْسنْ د-ثِيوضْ ثبْرَاثْ، إِمْسَارْ، بلِّي نِيثْنِي طّْفنْ إِحنْجِيرنْ ن ؤُجدْجِيذْ، نْغِينْ ثنْ \add مَارَّا\add*، سبْعِينْ ن يرْيَازنْ. نِيثْنِي ڭِّينْ إِزدْجِيفنْ نْسنْ ذِي ڒْكُورْبَاثْ ؤُشَا سّكّنْ ثنْثْ غَارسْ غَارْ يَازْرَاعِيلْ.  
\v 8 يُوسَا-د ؤُمْسخَّارْ، إِسِّيوضْ أَرقَّاسْ، إِنَّا: ”أَقَا إِوْينْ-د إِزدْجِيفنْ ن إِحنْجِيرنْ ن ؤُجدْجِيذْ.“ نتَّا يَارَّا-د: ”سَارْسمْ ثنْ أَڒْ ثِيوشَّا ذِي ثْنَاينْ ن إِعُورَّاشْ غَارْ وَاذَافْ ن ثوَّارْثْ.“  
\v 9 غَارْ ثِيوشَّا، ؤُمِي إِفّغْ غَارْ بَارَّا، إِمْسَارْ، أَقَا إِبدّْ \add ذِينْ\add*، إِنَّا إِ مَارَّا ڒْڭنْسْ: ”كنِّيوْ ذ إِمْسڭَّاذنْ. خْزَارمْ، ذ نشّْ إِ إِڭِّينْ إِشْثْ ن ثْمعْمُوتْشْ خْ سِيذِي إِنُو ؤُ نْغِيغْ ث. \add مَاشَا\add* وِي إِنْغِينْ مَارَّا إِنَا؟  
\v 10 سْنمْ، أَقَا وَارْ إِوطِّي غَارْ ثمُّورْثْ ؤُڒَا ذ إِجّْ ن وَاوَاڒْ ن سِيذِي نِّي إِنَّا سِيذِي ضِيدّْ إِ ثَادَّارْثْ ن أَخَابْ، مَاغَارْ سِيذِي إِڭَّا مِينْ ثُوغَا إِنَّا س ؤُقمُّومْ ن ؤُمْسخَّارْ نّسْ إِلِيشَاعْ.“ \f ◼ \fr 10:‏10 \ft \+bd ’س ؤُقمُّومْ‘\+bd* - س ثْعِيبْرَانِيثْ ’س ؤُفُوسْ‘.\f*  \x ◘ \xo 10:‏10 \xt 1 إِج. 21‏:‏19، 21، 29\x*  
\v 11 يَاهُو إِنْغَا مَارَّا وِي إِقِّيمنْ زِي ثَادَّارْثْ ن أَخَابْ ذِي يَازْرَاعِيلْ ؤُڒَا ذ مَارَّا إِمْشنّْعنْ نّسْ ذ إِمدُّوكَّاڒْ نّسْ ذ إِكهَّاننْ نّسْ، أَڒَامِي وَارْ إِجِّي أَذْ زَّايسْ إِقِّيمْ ؤُڒَا ذ إِجّْ ن ؤُمَارْوڒْ.   
\m
\v 12 \add خنِّي\add* إِكَّارْ ؤُشَا إِطّفْ أَبْرِيذْ غَارْ سَامَارْيَا. ؤُمِي ث ثُوغَا نتَّا ذڭْ وبْرِيذْ، \add إِمْسَارْ ذِي\add* ثَادَّارْثْ ن ؤُمڒْقِي ن إِمكْسَاونْ، \f ◼ \fr 10:‏12 \ft \+bd ’إِمكْسَاونْ‘\+bd* - نِيغْ إِنِيتْشَانْ‘.\f*  
\v 13 أَقَا إِمّڒْقَا يَاهُو أَكْ-ذ أَوْمَاثنْ ن أَخَازْيَا، أَجدْجِيذْ ن يَاهُوذَا، إِنَّا: ”مِينْ ثعْنَامْ كنِّيوْ؟“ نِيثْنِي أَرِّينْ-د: ”نشِّينْ ذ أَوْمَاثنْ ن أَخَازْيَا ؤُ نهْوَا-د، حِيمَا أَذْ نْسدْجمْ خْ إِحنْجِيرنْ ن ؤُجدْجِيذْ ذ إِحنْجِيرنْ ن ثْجدْجِيذْثْ.“ \x ◘ \xo 10:‏13 \xt 2 إِم. 22‏:‏8\x*  
\v 14 \add خنِّي\add* إِنَّا: ”طّْفمْ ثنْ دَّارنْ!“ طّْفنْ ثنْ دَّارنْ ؤُ نْغِينْ ثنْ غَارْ وَانُو ن ثَادَّارْثْ ن إِمكْسَاونْ. \add ثُوغَا-ثنْ\add* ذِي ثْنَاينْ ؤُ أَربْعِينْ ن يرْيَازنْ. وَارْ إِجِّي ؤُڒَا ذ إِجّْ زَّايْسنْ إِدَّارْ.  
\v 15 نتَّا إِفّغْ سّنِّي ؤُشَا يُوفَا يُونَاذَابْ، مِّيسْ ن رِيكَابْ، ونِّي د-إِفّْغنْ إِ ؤُمْسَاڭَارْ أَكِيذسْ. نتَّا إِسدْجمْ خَاسْ، إِنَّا أَسْ: ”مَا ؤُڒْ نّشْ إِسڭّمْ \add أَكِيذِي\add* أَمْ مَامّشْ إِسڭّمْ وُوڒْ إِنُو أَكِيذكْ؟“ يُونَاذَابْ يَارَّا-د خَاسْ: ”أَمنِّي، أَمنِّي! أوْشْ \add أَيِي-د\add* أَفُوسْ نّشْ.“ نتَّا إِوْشَا أَسْ أَفُوسْ ؤُشَا إِجَّا إِ-ث أَذْ د-إِنِييْ غَارسْ ذڭْ ؤُكَارُّو.  
\v 16 نتَّا إِنَّا: ”أَسْ-د أَكِيذِي ؤُشَا أَذْ ثْژَارذْ أَسَامْ إِنُو إِ سِيذِي.“ \add أَمُّو إِ\add* جِّينْ ث أَذْ د-إِنِييْ أَكِيذسْ ذڭْ ؤُكَارُّو.  
\v 17 \add ؤُمِي\add* يِيوضْ غَارْ سَامَارْيَا، إِنْغَا نتَّا مَارَّا إِنِّي ثُوغَا إِقِّيمنْ ن أَخَابْ ذِي سَامَارْيَا، أَڒَامِي ث إِقْضَا قَاعْ أَمْ مَامّشْ إِنَّا وَاوَاڒْ ن سِيذِي نِّي ثُوغَا إِنَّا إِ إِلِيشَاعْ. \x ◘ \xo 10:‏17 \xt 2 إِم. 22‏:‏8\x*   
\b  
\m  
\s1 يَاهُو إِقْضَا خْ وعْبذْ ن بَاعَالْ  
\m
\v 18 يَاهُو إِسّْمُونْ مَارَّا ڒْڭنْسْ ؤُشَا إِنَّا أَسنْ: ”أَخَابْ ثُوغَا إِسخَّارْ إِ بَاعَالْ شْوَايْثْ، \add مَاشَا\add* يَاهُو أَذْ أَسْ إِسخَّارْ أَطَّاسْ \add عَاذْ\add*.  
\v 19 خنِّي ڒخُّو، ڒَاغَامْ-د خْ مَارَّا إِنَابِييّنْ ن بَاعَالْ ذ مَارَّا إِمْسخَّارنْ نّسْ ذ مَارَّا إِكهَّاننْ نّسْ، \add مَاحنْذْ أَذْ\add* غَارِي \add د-أَسنْ\add*. حْضَامْ أَقَا أَذْ إِقِّيمْ حذْ، مِينْزِي غَارِي إِشْثْ ن ثْغَارْصْثْ ذ ثَامقّْرَانْثْ إِ بَاعَالْ. مَارَّا وِي غَا إِغَابنْ، وَارْ إِتّْغِيمِي إِدَّارْ.“ يَاهُو \add مَاشَا\add* إِڭَّا ثَا س ثْحْرَايْمشْثْ، مَاحنْذْ أَذْ إِقْضَا خْ إِمْسخَّارنْ ن بَاعَالْ.  
\v 20 \add خَاسْ ؤُشَا\add* إِنَّا يَاهُو: ”سْقدّْسمْ إِجّْ ن ؤُمُونِي إِفَارْزنْ إِ بَاعَالْ!“ ؤُشَا نِيثْنِي بَارّْحنْ إِ مَانْ أَيَا.  
\v 21 إِسّكّْ يَاهُو \add إِرقَّاسنْ\add* ذِي مَارَّا إِسْرَائِيل ؤُ مَارَّا إِمْسخَّارنْ ن بَاعَالْ ؤُسِينْ-د، وَارْ إِقِّيمْ ؤُڒَا ذ إِجّْ وَارْ د-يُوسِي. نِيثْنِي ؤُذْفنْ غَارْ زَّاوشْثْ ن بَاعَالْ أَڒَامِي ثشُّورْ زَّاوشْثْ ن بَاعَالْ زِي طَّارْفْ أَڒْ طَّارْفْ.  
\v 22 \add خنِّي\add* إِنَّا إِ ونِّي إِدْجَانْ خْ وخَّامْ ن وَارُّوضْ: ”أَوِي-د أَرُّوضنْ إِ مَارَّا إِمْسخَّارنْ ن بَاعَالْ!“ ؤُ وَانِيثَا يِيوِي أَسنْ-د أَرُّوضنْ.   
\m
\v 23 يُوذفْ يَاهُو أَكْ-ذ يُونَاذَابْ، مِّيسْ ن رِيكَابْ، غَارْ زَّاوشْثْ ن بَاعَالْ ؤُ نتَّا إِنَّا إِ إِمْسخَّارنْ ن بَاعَالْ: ”خْزَارمْ مْلِيحْ، أَقَا وَارْ غَارْومْ إِتِّيڒِي ؤُڒَا ذ إِجّْ زڭْ إِمْسخَّارنْ ن سِيذِي، مْغِيرْ إِمْسخَّارنْ ن بَاعَالْ وَاهَا.“  
\v 24 \add ؤُمِي\add* إِوْضنْ، مَاحنْذْ أَذْ \add ذِينْ\add* أَوْينْ ثِيغَارْصَا ذ ثْغَارْصَا ن وشْمَاضْ، ثُوغَا إِسّْبدّْ يَاهُو ثْمنْيِينْ ن يرْيَازنْ إِ يِيخفْ نّسْ ذِي بَارَّا، إِنَّا: ”زڭْ ورْيَازْ نِّي إِ غَا يجّْ أَذْ إِنْجمْ إِجّْ زڭْ يرْيَازنْ نِّي ڭِّيغْ ذڭْ إِفَاسّنْ نْومْ، أَذْ \add إِذْوڒْ\add* ڒعْمَارْ نّسْ ذڭْ ومْشَانْ ن ڒعْمَارْ نِّي.“   
\m
\v 25 \add ڒَْامِي\add* إِقْفڒْ ؤُسوْجذْ ن ثْغَارْصْطْ ن وشْمَاضْ، إِمْسَارْ بلِّي نتَّا إِنَّا إِ إِرقَّاسمْ ن ثَازْڒَا ؤُ إِ ڒْقبْطَانَاثْ: ”أَذْفمْ، وْثمْ ثنْ، وَارْ تّجِّيمْ ؤُڒَا ذ إِجّْ أَذْ إِنْجمْ!“ نِيثْنِي نْغِينْ ثنْ س ڒقْضعْ ن سِّيفْ ؤُ ڒْقبْطَانَاثْ نْضَارنْ ثنْ \add بَارَّا\add*. نِيثْنِي ؤُذْفنْ غَارْ ؤُڒْ ن زَّاوشْثْ ن بَاعَالْ.  
\v 26 نِيثْنِي كّْسنْ إِمَايْضُوثنْ \add إِقدّْسنْ\add* زِي زَّاوشْثْ ن بَاعَالْ ؤُشَا سَّارْغنْ ثنْ.  
\v 27 نِيثْنِي أَرْژِينْ أَميْضَا \add إِقدّْسنْ\add* ن بَاعَالْ. هذْمنْ \add عَاوذْ\add* زَّاوشْثْ ن بَاعَالْ ؤُشَا ڭِّينْ ت ذ إِشْثْ ن ثْزُوبَاشْثْ أَڒْ أَسّْ-أَ.  
\v 28 \add أَمُّو إِ\add* إِمْحَا يَاهُو بَاعَالْ زِي إِسْرَائِيل.  
\v 29 مَاشَا يَاهُو وَارْ إِبدّْ زڭْ وضْفَارْ ن دّْنُوبْ ن يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، ونِّي يَارِّينْ إِسْرَائِيل أَذْ إِخْضَا: إِعجْمِييّنْ ن وُورغْ نِّي \add إِدْجَانْ\add* ذِي بَايْثْ-إِلْ. \f ◼ \fr 10:‏29 \ft \+bd ’أَمْوَا‘\+bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘.\f*  \x ◘ \xo 10:‏29 \xt 1 إِج. 12‏:‏28\x*   
\m
\v 30 سِيذِي إِنَّا إِ يَاهُو: ”مِينْزِي ثڭِّيذْ نِيشَانْ ؤُمِي ثڭِّيذْ مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ إِنُو، ؤُشَا ثڭِّيذْ أَكْ-ذ ثَادَّارْثْ ن أَخَابْ مَارَّا مِينْ غَارِي ذڭْ وُوڒْ، أَذْ قِّيمنْ إِحنْجِيرنْ نْومْ خْ ڒْعَارْشْ ن إِسْرَائِيل أَڒْ جِّيڒْ وِيسّْ أَربْعَا.“ \x ◘ \xo 10:‏30 \xt 2 إِج. 15‏:‏12\x*  
\v 31 \add مَاشَا\add* يَاهُو وَارْ إِحْضِي شَا مَاحنْذْ أَذْ يُويُورْ عْلَاحْسَابْ شَّارِيعَا ن سِيذِي، أَربِّي ن إِسْرَائِيل، س مَارَّا ؤُڒْ نّسْ. نتَّا وَارْ إِحيّذْ خْ دّْنُوبْ ن يَارُوبْعَامْ ونِّي يَارِّينْ إِسْرَائِيل أَذْ إِخْضَا.   
\m
\v 32 ذڭْ وُوسَّانْ نِّي إِبْذَا سِيذِي أَذْ إِسّمْژِي إِسْرَائِيل. حَازَايِيلْ إِوْثَا إِ-ثنْ ذِي مَارَّا ثَامُّورْثْ ن إِسْرَائِيل،  
\v 33 زِي لْ-ؤُرْذُونْ مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ، مَارَّا \add ثَامُّورْثْ ن\add* جِيلْعَاذْ، \add ثَامُّورْثْ\add* ن إِجَاذِييّنْ ذ إِرُوبِينِييّنْ ذ إِمَانَاسِّييّنْ، زِي أَرُوعِيرْ ونِّي \add إِدْجَانْ\add* غَارْ ثغْزَارْثْ ن أَرْنُونْ، ؤُڒَا ذ جِيلْعَاذْ ذ بَاشَانْ.   
\m
\v 34 إِمزْرُوينْ إِقِّيمنْ ن يَاهُو، ذ مَارَّا مِينْ إِڭَّا ذ مَارَّا ثِيمڭَّا نّسْ إِمحْضنْ، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل؟  
\v 35 يَاهُو إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نضْڒنْ ث ذِي سَامَارْيَا. مِّيسْ يَاهُويَاحَازْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.  
\v 36 ؤُسَّانْ إِ ذِي ثُوغَا يَاهُو إِحكّمْ ذِي سَامَارْيَا أَقَا أَثنْ ذِي ثْمنْيَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا.   
\b  
\b  
\m  
\c 11
\s1 أَكهَّانْ يَاهُويَاذَاعْ يُومُورْ حِيمَا أَذْ نْغنْ أَثَالْيَا  
\m
\v 1 ؤُمِي عَاثَالْيَا، يمَّاسْ ن أَخَازْيَا، ثژْرَا، أَقَا مِّيسْ إِمُّوثْ، ثڭَّا أَذْ ثقْضَا خْ مَارَّا ثَارَّاوْثْ \add ن ڒَادْجْ\add* ن ؤُجدْجِيذْ. \x ◘ \xo 11:‏1 \xt [2 إِم. 22‏:‏10‏-‏12؛ 23‏:‏1‏-‏21] — 2 إِم. 22‏:‏10\x*  
\v 2 مَاشَا يَاهُوشِيبَا، يدْجِيسْ ن ؤُجدْجِيذْ يَاهُورَامْ، ؤُتْشْمَاسْ ن أَخَازْيَا، ثكْسِي يُووَاشْ، مِّيسْ ن أَخَازْيَا، س ثْنُوفّْرَا زِي جَارْ إِحنْجِيرنْ ن ؤُجدْجِيذْ نِّي إِتّْوَانْغنْ ؤُشَا \add ثِيوْيِي\add* ث أَكْ-ذ ثمْغَارْثْ إِ ث إِسُّوطُّوضنْ ذڭْ وخَّامْ ن ثَاسُّوثْ ؤُشَا ثسّْنُوفَّارْ إِ-ث \add ذِينِّي\add* زِي عَاثَالْيَا، \add حِيمَا\add* وَارْ إِتّْوَانقّْ.  
\v 3 نتَّا إِقِّيمْ إِنُوفَّارْ أَكِيذسْ ستَّا ن إِسڭّْوُوسَا ذِي ثَادَّارْثْ ن سِيذِي، \add ؤُمِي\add* ثحْكمْ عَاثَالْيَا خْ ثمُّورْثْ.   
\m
\v 4 ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا إِسّكّْ يَاهُويَاذَاعْ ؤُشَا إِجَّا أَذْ د-أَسنْ إِمقّْرَاننْ خْ مْيَا ن إِعسَّاسنْ ن أَرِّيمثْ ؤُ ن إِرقَّاسنْ ن ثَازْڒَا ؤُشَا إِسّْمُونْ إِ-ثنْ غَارسْ ذِي ثَادَّارْثْ ن سِيذِي. نتَّا إِڭَّا أَكِيذْسنْ إِجّْ ن ڒْعَاهْذْ، إِجَّا إِ-ثنْ أَذْ جَّادْجنْ ذِي ثَادَّارْثْ ن سِيذِي. \add خَاسْ ؤُشَا\add* إِسّْشنْ أَسنْ مِّيسْ ن ؤُجدْجِيذْ. \x ◘ \xo 11:‏4 \xt 2 إِم. 23‏:‏1\x*  
\v 5 نتَّا يُومُورْ إِ-ثنْ، إِنَّا: ”ذ مَانْ أَيَا إِ غَا ثڭّمْ: إِشْثْ ن تُّوڒُوثْ نْومْ، إِنِّي إِ غَا يَاذْفنْ ذڭْ \add وَاسّْ ن\add* سّبْثْ، أَذْعسّنْ غَارْ ثَادَّارْثْ ن ؤُجدْجِيذْ.  
\v 6 إِشْثْ ن تُّوڒُوثْ \add أَذْ ثْبدّْ\add* غَارْ ثوَّارْثْ ن صُورْ ؤُ إِشْثْ ن تُّوڒُوثْ غَارْ ثوَّارْثْ أَوَارْنِي إِ إِرقَّاسنْ ن ثَازْڒَا. \add أَمُّو\add* إِ غَا ثْعسّمْ خْ ثَادَّارْثْ ذِي ثْنُوبَّاثْ.  
\v 7 ثْنَاينْ ن إِزيْنَاثْ نْومْ، زِي مَارَّا إِنِّي إِ غَا إِفّْغنْ ذِي سّبْثْ، أَذْ حْضَانْ غَارْ ثَادَّارْثْ ن سِيذِي، غَارْ ؤُجدْجِيذْ.  
\v 8 كنِّيوْ أَذْ ثنّْضمْ إِ ؤُجدْجِيذْ، \add كُوڒْ\add* أَرْيَازْ س ڒسْنَاحْ نّسْ ذڭْ ؤُفُوسْ نّسْ، ؤُ ونِّي إِ غَا يَارْزُونْ أَذْ يَاذفْ جَارْ ڒصْفُوفْ أَذْ إِتّْوَانغْ. إِتّْخصَّا كنِّيوْ أَذْ ثقِّيمنْ أَكْ-ذ ؤُجدْجِيذْ مَاڒَا نتَّا إِفّغْ نِيغْ مَاڒَا يُوذفْ.   
\m
\v 9 إِمقّْرَاننْ خْ مْيَا ڭِّينْ أَمْ مَامّشْ إِوصَّا ؤُكهَّانْ يَاهُويَاذَاعْ ؤُشَا كُوڒْ  إِجّْ زَّايْسنْ يِيوِي أَكِيذسْ إِرْيَازنْ نّسْ إِنِّي يُوذْفنْ ذڭْ وَاسّْ ن سّبْثْ، \add جْمِيعْ\add* أَكْ-ذ يِينِّي إِفّْغنْ ذڭْ وَاسّْ ن سّبْثْ ؤُشَا ؤُسِينْ-د غَارْ ؤُكهَّانْ يَاهُويَاذَاعْ. \x ◘ \xo 11:‏9 \xt 2 إِم. 23‏:‏8\x*  
\v 10 إِ إِمقّْرَاننْ ن مْيَا إِوْشَا ؤُكهَّانْ لَانْسَاثْ ذ ثْسدَّارِييِينْ إِقسْحنْ ن ڒْعسْكَارْ إِ ثُوغَا إِدْجَانْ ن ؤُجدْجِيذْ ذَاوُوذْ، ثِينِّي \add ثُوغَا إِدْجَانْ\add* ذِي ثَادَّارْثْ ن سِيذِي.  
\v 11 إِرقَّاسنْ ن ثَازْڒَا بدّنْ س ڒسْنَاحْ ذڭْ ؤُفُوسْ زڭْ ؤُغزْذِيسْ أَفُوسِي ن وُوذمْ ن ثَادَّارْثْ أَڒْ أَغزْذِيسْ أَزڒْمَاضْ ن وُوذمْ ن ثَادَّارْثْ، غَارْ ؤُعَالْطَارْ ؤُ غَارْ ثَادَّارْثْ، \add أَمُّو\add* قُووَّارنْ-د إِ ؤُجدْجِيذْ.  
\v 12 \add خنِّي\add* إِسُّوفّغْ-د مِّيسْ ن ؤُجدْجِيذْ غَارْ بَارَّا ؤُشَا إِڭَّا أَسْ تَّاجْ \add ن وعْزَاڒْ\add* \add خْ ؤُزدْجِيفْ\add* ؤُشَا إِوْشَا أَسْ شّْهَاذثْ. \add أَمُّو\add* إِ ث ڭِّينْ ذ أَجدْجِيذْ، ذهْننْ ث. نِيثْنِي وْثِينْ ذڭْ إِفَاسّنْ، نَّانْ: ”ثُوذَارْثْ إِ ؤُجدْجِيذْ!“   
\m
\v 13 \add ؤُمِي\add* ثسْڒَا عَاثَالْيَا ڒْحسّْ ن إِرقَّاسنْ ن ثَازْڒَا ذ ونِّي ن ڒْڭنْسْ، ثُوسَا-د نتَّاثْ غَارْ ڒْڭنْسْ غَارْ ثَادَّارْثْ ن سِيذِي.  
\v 14 ثژْرَا، ؤُ خْزَارْ، أَجدْجِيذْ إِبدّْ غَارْ ؤُپِيلَارْ أَمْ مَامّشْ ثدْجَا ذِي لْقَاعِيذَا، ؤُشَا إِكُومَانْذَارنْ \add ن ڒْعسْكَارْ\add* ذ إِنِّي إِصُوذنْ ذِي ڒبْوَاقْ \add بدّنْ\add* غَارْ ؤُجدْجِيذْ. مَارَّا ڒْڭنْسْ ن ثمُّورْثْ إِفْرَاحْ ؤُ إِسُوضْ ذِي ڒبْوَاقْ. \add خنِّي\add* ثْشَارّڭْ عَاثَالْيَا أَرُّوضْ نّسْ، ثسْغُويْ: ”ثَامنْزِيوْثْ، ثَامنْزِيوْثْ!“  
\v 15 \add مَاشَا\add* يُومُورْ ؤُكهَّانْ يَاهُويَاذَاعْ إِ إِمقّْرَاننْ خْ مْيَا، إِنِّي ثُوغَا إِدْجَانْ خْ ڒْعسْكَارْ، إِنَّا أَسنْ: ”أَوْيمْ ت جَارْ إِسذِّييّنْ \add ن ڒْعسْكَارْ\add* غَارْ بَارَّا ؤُشَا نْغمْ وِي ت غَا إِضْفَارنْ س سِّيفْ.“ مَاغَارْ أَكهَّانْ ثُوغَا إِنَّا: ”وَارْ ت تّجِّي أَذْ ثتّْوَانغْ ذِي ثَادَّارْثْ ن سِيذِي.“  
\v 16 نِيثْنِي سَّارْسنْ خَاسْ إِفَاسّنْ، ؤُشَا ڒَامِي ثْرُوحْ خْ وبْرِيذْ ن وَاذَافْ ن إِيْسَانْ غَارْ ثَادَّارْثْ ن ؤُجدْجِيذْ، نْغِينْ ت ذِينِّي. \f ◼ \fr 11:‏16 \ft \+bd ’إِفَاسّنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’س إِفَاسّنْ نْسنْ‘.\f*   
\m
\v 17 يَاهُويَاذَاعْ إِڭَّا إِجّْ ن ڒْعَاهْذْ جَارْ سِيذِي ذ ؤُجدْجِيذْ ذ ڒْڭنْسْ، حِيمَا أَذْ إِڒِينْ ذ إِجّْ ن ڒْڭنْسْ إِ سِيذِي، ؤُشَا \add نتَّا إِڭَّا ؤُڒَا ذ إِجّْ ن ڒْعَاهْذْ\add* جَارْ ؤُجدْجِيذْ ذ ڒْڭنْسْ. \x ◘ \xo 11:‏17 \xt 2 إِم. 23‏:‏16\x*  
\v 18 \add خَاسْ ؤُشَا\add* يُوذفْ مَارَّا ڒْڭنْسْ ن ثمُّورْثْ غَارْ ثَادَّارْثْ \add ن زَّاوشْثْ\add* ن بَاعَالْ ؤُ هذْمنْ ت. إِعَالْطَارنْ نّسْ ذ ڒخْيَاڒَاثْ نّسْ أَرْژِينْ ثنْ قَاعْ. ؤُ نِيثْنِي نْغِينْ مَاتَّانْ، أَكهَّانْ ن بَاعَالْ، زَّاثْ إِ إِعَالْطَارنْ. أَكهَّانْ يَاڒقّمْ إِمحْضَاينْ خْ ثَادَّارْثْ ن سِيذِي.  
\v 19 نتَّا يِيوِي \add أَكِيذسْ\add* إِمقّْرَاننْ خْ مْيَا ذ إِعسَّاسنْ ن أَرِّيمثْ ذ إِرقَّاسنْ ن ثَازْڒَا ذ مَارَّا ڒْڭنْسْ ن ثمُّورْثْ ؤُ نِيثْنِي سّهْوَانْ أَجدْجِيذْ زِي ثَادَّارْثْ ن سِيذِي ؤُشَا كِّينْ خْ وبْرِيذْ ن ثوَّارْثْ ن إِرقَّاسنْ ن ثَازْڒَا ثنِّي غَارْ ثَادَّارْثْ ن ؤُجدْجِيذْ، ؤُ ذِينِّي إِقِّيمْ خْ ڒْعَارْشْ ن إِجدْجِيذنْ.  
\v 20 مَارَّا ڒْڭنْسْ ن ثمُّورْثْ إِفَارْحْ ؤُشَا ثَارْسَا ثنْذِينْثْ. أَقَا نْغِينْ عَاثَالْيَا س سِّيفْ غَارْ ثَادَّارْثْ ن ؤُجدْجِيذْ.   
\b  
\b  
\m  
\c 12
\s1 يُووَاشْ، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 1 ثُوغَا غَارْ يُووَاشْ سبْعَا ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ.\x ◘ \xo 12:‏1 \xt [2 إِم. 24‏:‏1‏-‏27]\x*  
\v 2 ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا ن يَاهُو إِذْوڒْ يُووَاشْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ أَربْعِينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ ضِيبْيَا زِي بِئرْ-سبْعَا. \x ◘ \xo 12:‏2 \xt 2 إِم. 24‏:‏1\x*  
\v 3 يُووَاشْ إِڭَّا مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي، مَارَّا ؤُسَّانْ مِينْ إِكَّا ؤُكهَّانْ يَاهُويَاذَاعْ إِسّڒْمذْ إِ-ث.  
\v 4 وَارْ تّْوَاكّْسنْثْ مْغِيرْ ڒڭْعُوذِي. ؤُشَا ڒْڭنْسْ ثُوغَا إِتّْقدّمْ عَاذْ ثِيغَارْصَا ذ ثوْهِيبِينْ ن ڒبْخُورْ خْ ڒڭْعُوذِي \add نِّي\add*.  
\v 5 يُووَاشْ إِنَّا إِ إِكهَّاننْ: ”مَارَّا نُّوقَارْثْ ن ثوْهِيبِينْ إِقدّْسنْ نِّي إِ غَا يِيوْينْ ذِي ثَادَّارْثْ ن سِيذِي، ڒَا نُّوقَارْثْ إِ كُوڒْ ڒعْمَارْ إِ إِعدُّونْ \add غَارْ إِنِّي إِتّْوَاحسْبنْ\add*، \add ڒَا\add* نُّوقَارْثْ ن كُوڒْ ڒعْمَارْ عْلَاحْسَابْ أَقدَّارْ نّسْ ؤُشَا ؤُڒَا مَارَّا نُّوقَارْثْ إِ خْ د-يُوسَا ذڭْ وُوڒْ ن إِجّْ ن ورْيَازْ حِيمَا أَذْ ت يَاوِي غَارْ ثَادَّارْثْ ن سِيذِي، \x ◘ \xo 12:‏5 \xt 2 إِج. 22‏:‏3‏-‏21\x*  
\v 6 أَذْ ت كْسِينْ إِكهَّاننْ إِ يِيخفْ نْسنْ، \add كُوڒْ\add* أَرْيَازْ زڭْ إِنِّي إِسّنْ. ؤُشَا نِيثْنِي أَذْ \add زَّايسْ\add* أَرقّْعنْ \add ڒحْيُوضْ\add* إِهْرُورَانْ ن ثَادَّارْثْ، مَارَّا مِينْ ذِينْ إِتّْوَافنْ \add نْ ڒحْيُوضْ\add* إِهْرُورَانْ.“  
\v 7 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا ؤُ-عِيشْرِينْ ن ؤُجدْجِيذْ يُووَاشْ وَارْعدّْڒنْ إِكهَّاننْ \add عَاذْ\add* ڒحْيُوضْ إِهْرُورَانْ ن ثَادَّارْثْ.  
\v 8 \add خنِّي\add* إِڒَاغَا ؤُجدْجِيذْ يُووَاشْ إِ ؤُكهَّانْ يَاهُويَاذَاعْ ؤُ إِ إِكهَّاننْ \add إِنّغْنِي\add*، إِنَّا أَسنْ: ”مَايمِّي وَارْ ثْعدّْڒمْ ڒحْيُوضْ إِشَارّْڭنْ ن ثَادَّارْثْ؟ \add خنِّي\add* ڒخُّو، وَارْ ثْكسِّيمْ \add عَاذْ\add* نُّوقَارْثْ إِ د-إِتَّاسنْ زڭْ إِنِّي ثسّْنمْ، مْغِيرْ حِيمَا أَذْ ت ثسِّيوْضمْ إِ وعْذَاڒْ ن مِينْ إِشَارّْڭنْ \add ذِي ڒحْيُوضْ\add* ذِي ثَادَّارْثْ.“   
\m
\v 9 قبْڒنْ إِكهَّاننْ، مَاحنْذْ وَارْ كسِّينْ عَاذْ نُّوقَارْثْ زِي ڒْڭنْسْ ؤُ مَاحنْذْ وَارْ \add حْذِيجنْ شَا عَاذْ\add* أَذْعذْڒنْ ڒحْيُوضْ إِقطّْسنْ ن ثَادَّارْثْ.  
\v 10 أَكهَّانْ يَاهُويَاذَاعْ إِكْسِي إِشْثْ ن ثْسنْذُوقْثْ، إِڭَّا إِجّْ ن ؤُنُوقِّيبْ ذِي ثْقبَّارْثْ نّسْ ؤُشَا إِسَّارْسْ إِ-ت زَّاثْ إِ ؤُعَالْطَارْ غَارْ يفُوسْ ن كُوڒْ إِجّْ ن ونِّي إِتَّاذْفنْ ثَادَّارْثْ ن سِيذِي، ؤُشَا إِكهَّاننْ، إِنِّي إِحْضَانْ خْ وَاذَافْ \add غَارْ ثَادَّارْثْ\add*، ڭِّينْ ذَايسْ مَارَّا نُّوقَارْثْ إِ د-إِتّْوَاوْينْ ذِي ثَادَّارْثْ ن سِيذِي.  
\v 11 ؤُمِي ژْرِينْ أَقَا ذِينْ أَطَّاسْ ن نُّوقَارْثْ ذِي ثْسنْذُوقْثْ، إِمْسَارْ أَقَا إِڭعّذْ ؤُمَارِيرْ ن ؤُجدْجِيذْ أَكْ-ذ أَرَّايْسْ ن إِكهَّاننْ. نِيثْنِي سّْمُوننْ ت ذِي ثْخُونْشَايْ ؤُشَا وزْننْ نُّوقَارْثْ نِّي إِتّْوَافنْ ذِي ثَادَّارْثْ ن سِيذِي.  
\v 12 نِيثْنِي وْشِينْ \add ڒْقدّْ\add* إِوزْننْ ن نُّوقَارْثْ ذڭْ ؤُفُوسْ ن يِينِّي إِڭِّينْ ڒْخذْمثْ، إِ إِمحْضَاينْ ن ثَادَّارْثْ ن سِيذِي. ؤُ نِيثْنِي وْشِينْ ت \add عَاوذْ\add* إِ إِنقَّاشنْ \add ن ؤُكشُّوضْ\add* ؤُ إِ إِبنَّاينْ نِّي ثُوغَا إِخدّْمنْ ذِي ثَادَّارْثْ ن سِيذِي،  
\v 13 ؤُ إِ إِمَاصُّوثنْ ذ إِسُويْذَاينْ، ؤُ إِ ثْمسْغِيوْثْ ن ؤُكشُّوضْ ذ ثْصُوضَارْ يُويْذَانْ إِتّحْوَاجَانْ إِ وَارقّعْ ن مِينْ إِقطّْسنْ \add زِي ڒحْيُوضْ\add* ذِي ثَادَّارْثْ ن سِيذِي، ؤُ إِ مَارَّا مِينْ سيَّارنْ إِ وَارقّعْ ن ثَادَّارْثْ.  
\v 14 مْغِيرْ وَارْ تّْوَاڭّنْ طّْبَاصِي ن نُّوقَارْثْ ڒَا ثْجقَّاضِينْ، ڒَا طَّاوْيَاثْ إِ ؤُرُوشِّي ذ ڒبْوَاقْ، ؤُڒَا ذ ڒقْشُوعْ ن وُورغْ ذ نُّوقَارْثْ، زِي نُّوقَارْثْ إِ د-إِوْينْ \add إِوْذَانْ\add* ذِي ثَادَّارْثْ ن سِيذِي.  
\v 15 مَاغَارْ نِيثْنِي وْشِينْ ت مَارَّا إِ يِينِّي إِڭِّينْ ڒْخذْمثْ ؤُشَا نِيثْنِي أَرقّْعنْ زَّايسْ ثَادَّارْثْ ن سِيذِي.  
\v 16 وَارْ مّْسحْسِيبنْ شَا أَكْ-ذ يرْيَازنْ نِّي ؤُمِي وْشِينْ نُّوقَارْثْ ذڭْ ؤُفُوسْ نْسنْ، حِيمَا أَذْ ت وْشنْ إِ يِينِّي إِڭِّينْ ڒْخذْمثْ، مِينْزِي نِيثْنِي ثُوغَا تّڭّنْ س ؤُثِيقِّي.  
\v 17 نُّوقَارْثْ ن ثْغَارْصْثْ ن ؤُمَارْوَاسْ ذ نُّوقَارْثْ ن ثْغَارْصَا ن دّنْبْ وَارْ ت سِّيذْفنْ غَارْ ثَادَّارْثْ ن سِيذِي. ثُوغَا-ت إِ إِكهَّاننْ.   
\b  
\m
\v 18 خنِّي إِڭعّذْ حَازَايِيلْ، أَجدْجِيذْ ن أَرَامْ، إِمّْنغْ أَكْ-ذ جَاثْ، إِطّفْ إِ-ث. \add أَوَارْنِي مَانْ أَيَا\add* إِعوّڒْ حَازَايِيلْ ثَامُوغْڒِي نّسْ غَارْ ؤُرْشَالِيمْ، حِيمَا أَذْ إِڭعّذْ ضِيدّْ نّسْ. \x ◘ \xo 12:‏18 \xt 2 إِج. 8‏:‏12؛ 13‏:‏25؛ 2 إِم. 24‏:‏23\x*  
\v 19 \add مَاشَا\add* يُووَاشْ إِكْسِي مَارَّا ڒقْشُوعْ إِقدّْسنْ نِّي ثُوغَا إِسّْقدّسْ إِ-ثنْثْ يَاهُوشَافَاطْ، يَاهُورَامْ ذ أَخَازْيَا، ڒجْذُوذْ نّسْ، إِجدْجِيذنْ ن يَاهُوذَا، ؤُڒَا ذ ڒقْشُوعْ إِقدّْسنْ نّسْ ذ مَارَّا وُورغْ نِّي ثُوغَا إِدْجَانْ ذڭْ إِخَّامنْ ن ثْخُوبَايْ ن ثَادَّارْثْ ن سِيذِي ؤُ ن ثَادَّارْثْ ن ؤُجدْجِيذْ، ؤُشَا إِسّكّْ \add أَيَا\add* غَارْ حَازَايِيلْ، أَجدْجِيذْ ن أَرَامْ. \add خَاسْ ؤُشَا\add* إِڭّْوجْ نتَّا خْ ؤُرْشَالِيمْ. \x ◘ \xo 12:‏19 \xt 2 إِج. 18‏:‏15\x*   
\m
\v 20 إِمزْرُوينْ إِقِّيمنْ ن يُووَاشْ ذ مَارَّا مِينْ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا؟   
\m
\v 21 إِمْسخَّارنْ نّسْغوّْغنْ خَاسْ، ڭِّينْ \add خَاسْ\add* إِشْثْ ن ثْمعْمُوتْشْ ؤُشَا نْغِينْ يُووَاشْ ذِي ثَادَّارْثْ ن لْقلْعَا مَانِيسْ هكّْوَانْ غَارْ سِيلَّا. \x ◘ \xo 12:‏21 \xt 2 إِج. 14‏:‏5\x*  
\v 22 أَقَا يُوزَاكَارْ، مِّيسْ ن شِيمْعَاثْ، ذ يَاهُوزَابَاذْ، مِّيسْ ن شُومِيرْ، إِمْسخَّارنْ نّسْ، وْثِينْ ث أَڒَامِي إِمُّوثْ. نِيثْنِي نضْڒنْ ث جَارْ ڒجْذُوذْ نّسْ ذِي ثنْذِينْثْ ن ذَاوُوذْ. أَمَاصْيَا، مِّيسْ، إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\b  
\m  
\c 13
\s1 يَاهُويَاحَازْ، أَجدْجِيذْ ن إِسْرَائِيل  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا ؤُ-عِيشْرِينْ ن يُووَاشْ، مِّيسْ ن أَخَازْيَا، أَجدْجِيذْ ن يَاهُوذَا، إِذْوڒْ يَاهُويَاحَازْ، مِّيسْ ن يَاهُو، ذ أَجدْجِيذْ خْ إِسْرَائِيل، ذِي سَامَارْيَا. \add نتَّا إِحْكمْ\add* سْبعْطَاشْ ن إِسڭّْوُوسَا.  
\v 2 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي. نتَّا إِضْفَارْ دّْنُوبْ ن يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، ونِّي يَارَّانْ إِسْرَائِيل أَذْ إِخْضَا. نتَّا وَارْ إِحيّذْ خْ مَانْ أَيَا.  
\v 3 \add خْ ؤُينِّي\add* يَارْغَا وغْضَابْ ن سِيذِي خْ إِسْرَائِيل. مَارَّا ؤُسَّانْ \add نِّي\add* إِوْشَا إِ-ثنْ ذڭْ إِفَاسّنْ ن حَازَايِيلْ، أَجدْجِيذْ ن أَرَامْ، ؤُ ذڭْ إِفَاسّنْ ن بِينْهَاذَاذْ، مِّيسْ ن حَازَايِيلْ.   
\m
\v 4 \add مَاشَا\add* يَاهُويَاحَازْ إِحشّمْ زَّاثْ إِ وُوذمْ ن سِيذِي ؤُ سِيذِي إِسْڒَا أَسْ، مَاغَارْ نتَّا إِژْرَا ڒحْصَارثْ ن إِسْرَائِيل، مَامّشْ إِ ثنْ إِحْصَاڒْ ؤُجدْجِيذْ ن أَرَامْ.  
\v 5 سِيذِي إِوْشَا إِجّْ ن ؤُمْسنْجمْ إِ إِسْرَائِيل، أَڒَامِي زمَّارنْ أَذْ نْفكّنْ زڭْ ؤُفُوسْ ن أَيْثْ ن أَرَامْ، ؤُشَا \add خنِّي\add* ثُوغَا أَيْثْ ن إِسْرَائِيل زدّْغنْ \add عَاوذْ\add* أَمْ قْبڒْ ذڭْ إِقِيضَانْ نْسنْ.  
\v 6 مَاشَا نِيثْنِي وَارْ حيّْذنْ شَا خْ دّْنُوبْ ن ثَادَّارْثْ ن يَارُوبْعَامْ ونِّي يَارِّينْ إِسْرَائِيل أَذْ إِخْضَا. إِسْرَائِيل إِقِّيمْ إِڭُّورْ أَمُّو ؤُ ثقِّيمْ ثَاربِّيثْ ن شْوَارْثِي ثْبدّْ ذِي سَامَارْيَا.   
\m
\v 7 مَاغَارْ نتَّا وَارْ إِجِّي زِي ڒْعسْكَارْ ن يَاهُويَاحَازْ، مْغِيرْ خمْسِينْ ن إِمْنَاينْ ذعشْرَا ن إِكَارُّوثنْ ذعشْرَا أَڒفْ ن \add يرْيَازنْ\add* خْ إِضَارنْ، مَاغَارْ أَجدْجِيذْ ن أَرَامْ ثُوغَا إِقْضَا إِ-ثنْ، إِڭَّا إِ-ثنْ أَمْ ثْعجَّاجْثْ غَارْ ؤُسَارْوثْ.   
\m
\v 8 إِمزْرُوينْ إِقِّيمنْ ن يَاهُويَاحَازْ، ذ مَارَّا مِينْ إِڭَّا ذ مَارَّا ثِيمڭَّا نّسْ إِمحْضنْ، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل؟  
\v 9 يَاهُويَاحَازْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نضْڒنْ ث ذِي سَامَارْيَا. مِّيسْ يُووَاشْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\m  
\s1 يُووَاشْ، أَجدْجِيذْ ن إِسْرَائِيل  
\m
\v 10 ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا ؤُ-ثْڒَاثِينْ ن يُووَاشْ، أَجدْجِيذْ ن يَاهُوذَا، إِذْوڒْ يُووَاشْ، مِّيسْ ن يَاهُويَاحَازْ، ذ أَجدْجِيذْ خْ إِسْرَائِيل. \add نتَّا إِحْكمْ\add* سطَّاشْ ن إِسڭّْوُوسَا ذِي سَامَارْيَا.  
\v 11 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي. نتَّا وَارْ إِحيّذْ خْ دّْنُوبْ ن يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، ونِّي يَارِّينْ إِسْرَائِيل أَذْ إِخْضَا، \add مَاشَا\add* نتَّا يَارْنِي يُويُورْ \add أَمنِّي\add*.   
\m
\v 12 إِمزْرُوينْ إِقِّيمنْ ن يُووَاشْ ذ مَارَّا مِينْ إِڭَّا ذ مَارَّا ثِيمڭَّا نّسْ إِمحْضنْ إِ زِي إِمّْنغْ أَكْ-ذ أَمَاصْيَا، أَجدْجِيذْ ن يَاهُوذَا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل؟  
\v 13 يُووَاشْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. \add خَاسْ ؤُشَا\add* إِنْيَا يَارُوبْعَامْ خْ ڒْعَارْشْ نّسْ. يُووَاشْ إِتّْوَانْضڒْ ذِي سَامَارْيَا جَارْ إِجدْجِيذنْ ن إِسْرَائِيل.   
\b  
\m  
\s1 ڒْموْثْ ن إِلِيشَاعْ ذ لْمُوعْجِيزَا غَارْ ونْضڒْ نّسْ  
\m
\v 14 إِلِيشَاعْ إِتّْوَاڒْقفْ س ڒهْڒَاشْ إِ زِي غَا إِمّثْ. يُووَاشْ، أَجدْجِيذْ ن إِسْرَائِيل، إِهْوَا-د غَارسْ ؤُشَا إِرُو زَّاثسْ، إِنَّا: ”\add أَ\add* بَابَا، \add أَ\add* بَابَا! أَكَارُّو ن إِسْرَائِيل ذ إِمْنَاينْ نّسْ!“ \f ◼ \fr 13:‏14 \ft \+bd ’إِمْنَاينْ‘\+bd* - إِنِّي إِنْيِينْ خْ إِيْسَانْ ؤُ نذْهنْ خَاسنْ.\f*  \x ◘ \xo 13:‏14 \xt 2 إِج. 2‏:‏12\x*  
\v 15 إِلِيشَاعْ إِنَّا: ”كْسِي ڒْقوْسْ ذ فْڒِيثْشَاثْ!“ نتَّا إِطّفْ إِ يِيخفْ نّسْ إِجّْ ن ڒْقوْسْ ذ فْڒِيثْشَاثْ.  
\v 16 \add خنِّي\add* إِنَّا نتَّا إِ ؤُجدْجِيذْ ن إِسْرَائِيل: ”سَارْسْ أَفُوسْ نّشْ خْ ڒْقوْسْ!“ ؤُشَا إِسَّارْسْ نتَّا أَفُوسْ نّسْ \add خْ ڒْقوْسْ\add* ؤُشَا إِسَّارْسْ إِلِيشَاعْ إِفَاسّنْ نّسْ خْ إِفَاسّنْ ن ؤُجدْجِيذْ،  
\v 17 إِنَّا: ”أَرْزمْ ڒْكَازِي \add إِ إِدْجَانْ\add* غَارْ مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ!“، ؤُشَا نتَّا يَارْزمْ إِ-ث. \add خنِّي\add* إِنَّا إِلِيشَاعْ: ”وّثْ!“ ؤُ نتَّا إِوْثَا \add س ڒْقوْسْ نّسْ\add*. ؤُشَا إِنَّا \add إِلِيشَاعْ\add*: ”أَقَا-ت ذ إِشْثْ ن فْڒِيثْشَا ن ؤُسنْجمْ س \add ؤُفُوسْ ن\add* سِيذِي ؤُڒَا ذ إِشْثْ ن فْڒِيثْشَا ن ؤُسنْجمْ \add زڭْ إِفَاسّنْ\add* ن أَرَامْ، مِينْزِي أَذْ ثْغڒْبذْ أَرَامْ ذِي عَافِيكْ أَڒْ غَا إِتّْوَاردّدْجْ.“ \x ◘ \xo 13:‏17 \xt 1 إِج. 20‏:‏30\x*  
\v 18 \add خَاسْ ؤُشَا\add* إِنَّا نتَّا: ”كْسِي فْڒِيثْشَاثْ!“ ؤُشَا نتَّا إِطّفْ إِ-ثنْثْ. \add خنِّي\add* إِنَّا إِ ؤُجدْجِيذْ ن إِسْرَائِيل: ”وّثْ خْ ثمُّورْثْ!“ ؤُشَا وَانِيثَا إِوْثَا ثْڒَاثَا ن ثْوَاڒَاوِينْ خْ ثمُّورْثْ ؤُشَا \add ڒخْذنِّي\add* إِبدّْ.  
\v 19 أَرْيَازْ ن أَربِّي إِفُّوڭمْ خَاسْ أَطَّاسْ، إِنَّا: ”ثُوغَا إِتّْخصَّا أَذْ ثوْثذْ خمْسَا نِيغْ ستَّا ن ثْوَاڒَاوِينْ، إِڒِي أَذْ ثغْڒبْ خْ أَرَامْ أَڒَامِي ث إِ غَا ثقْضِيذْ \add قَاعْ\add*. ڒخُّو \add مَاشَا\add* أَذْ ثْغڒْبذْ خْ أَرَامْ \add مْغِيرْ\add* ثْڒَاثَا ن ثْوَاڒَاوِينْ.   
\m
\v 20 إِلِيشَاعْ إِمُّوثْ ؤُشَا نضْڒنْ ث. بَانْذِييَّاثْ ن أَيْثْ ن مُوآبَ ثُوغَا تّْنُومَانْثْ أَذْ أَذْفنْثْ غَارْ ثمُّورْثْ غَارْ ؤُمزْوَارُو ن ؤُسڭّْوَاسْ.  
\v 21 خْزَارْ، \add ؤُمِي\add* ثُوغَا نطّْڒنْ \add إِشْثْ ن ثْوَاڒَا\add* إِجّْ ن ورْيَازْ، إِمْسَارْ أَقَا ژْرِينْ إِشْثْ ن بَانْذِييَّا. نِيثْنِي نْضَارنْ أَرْيَازْ ذڭْ ونْضڒْ ن إِلِيشَاعْ. \add ؤُمِي ذَايسْ\add* إِوْضَا ورْيَازْ، إِحَاذَا إِيْسَانْ ن إِلِيشَاعْ، إِذْوڒْ إِدَّارْ عَاوذْ ؤُشَا إِكَّارْ إِبدّْ خْ إِضَارنْ نّسْ.   
\b  
\m  
\s1 إِغلَّابنْ ن يُووَاشْ خْ أَرَامْ  
\m
\v 22 حَازَايِيلْ، أَجدْجِيذْ ن أَرَامْ، إِحْصَارْ خْ إِسْرَائِيل، مَارَّا ؤُسَّانْ ن يَاهُويَاحَازْ.  
\v 23 \add مَاشَا\add* سِيذِي إِحِينّْ خْ ڒْڭنْسْ نّسْ ؤُشَا يَارْحمْ خَاسنْ ؤُشَا إِنّقْڒبْ غَارْسنْ ذِي طّْوعْ ن ڒْعَاهْذْ نّسْ أَكْ-ذ إِبْرَاهِيمْ، إِسْحَاقْ ذ يَاعْقُوبْ. نتَّا ثُوغَا وَارْ إِخْسْ أَذْ ثنْ يَاردّدْجْ ؤُ وَارْ إِخْسْ أَذْ ثنْ إِسّكّْ زِي زَّاثْ ن وُوذمْ نّسْ، أَڒْ ڒخُّو.  
\v 24 حَازَايِيلْ، أَجدْجِيذْ ن أَرَامْ، إِمُّوثْ ؤُ مِّيسْ بِينْهَاذَاذْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.  
\v 25 يُووَاشْ، مِّيسْ ن يَاهُويَاحَازْ، إِكّسْ-د زڭْ إِفَاسّنْ ن بِينْهَاذَاذْ، مِّيسْ ن حَازَايِيلْ، ثِيندَّامْ نِّي ثُوغَا إِطّفْ وَانِيثَا زڭْ إِفَاسّنْ ن بَابَاسْ يَاهُويَاحَازْ. يُووَاشْ إِغْڒبْ خَاسْ ثْڒَاثَا ن ثْوَاڒَاوِينْ ؤُشَا يَارَّا-د ثِيندَّامْ عَاوذْ غَارْ إِسْرَائِيل.   
\b  
\b  
\m  
\c 14
\s1 أَمَاصْيَا، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ ن يُووَاشْ، مِّيسْ ن يَاهُويَاحَازْ، أَجدْجِيذْ ن إِسْرَائِيل، إِذْوڒْ أَمَاصْيَا، مِّيسْ ن يُووَاشْ، ذ أَجدْجِيذْ ن يَاهُوذَا. \x ◘ \xo 14:‏1 \xt [2 إِم. 25‏:‏1‏-‏28]\x*  
\v 2 نتَّا \add ثُوغَا\add* غَارسْ خمْسَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا، ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ يَاهُوعَاذَانْ، زِي ؤُرْشَالِيمْ. \x ◘ \xo 14:‏2 \xt 2 إِم. 25‏:‏1\x*  
\v 3 نتَّا إِڭَّا مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي، مَاشَا وَارْ إِدْجِي أَمْ بَابَاسْ ذَاوُوذْ. إِڭَّا نِيشَانْ أَمْ مَامّشْ إِڭَّا بَابَاسْ يُووَاشْ.  
\v 4 مْغِيرْ وَارْ تّْوَاكّْسنْثْ ڒڭْعُوذِي. ڒْڭنْسْ يِيوِي عَاذْ ثِيغَارْصَا ذ ثوْهِيبِينْ ن ڒبْخُورْ خْ ڒڭْعُوذِي.  
\v 5 ؤُمِي ثُوغَا ثَاڭلْذَا ثمْثنْ ذڭْ إِفَاسّنْ نّسْ، إِمْسَارْ بلِّي نتَّا إِنْغَا إِمْسخَّارنْ نِّي إِنْغِينْ أَجدْجِيذْ، بَابَاسْ.  
\v 6 \add مَاشَا\add* إِحنْجِيرنْ ن إِقتَّاڒنْ وَارْ ثنْ إِنْغِي شَا، أَمْ مَامّشْ \add ث\add* يُورَا ذڭْ وذْلِيسْ إِتّْوَانّْضنْ ن شَّارِيعَا ن مُوسَا، إِ ذِي إِوصَّا سِيذِي، إِنَّا: ”إِبَابَاثنْ وَارْ تّْوَانقّنْ ذِي سِّيبّثْ ن إِحنْجِيرنْ \add نْسنْ\add* ؤُڒَا إِحنْجِيرنْ وَارْ تّْوَانقّنْ ذِي سِّيبّثْ ن إِبَابَاثنْ \add نْسنْ\add*، مَاغَارْ كُوڒْ إِجّْ أَذْ إِتّْوَانغْ خْ دّْنُوبْ \add ن يِيخفْ\add* نّسْ.“ \x ◘ \xo 14:‏6 \xt أَعَوذ. 24‏:‏16؛ حِز. 18‏:‏20\x*   
\m
\v 7 نتَّا إِغْڒبْ خْ أَيْثْ ن إِذُومْ ذِي ثغْزُورْثْ ن ثْمدْجَاحْثْ،عشْرَا أَڒفْ \add ن يرْيَازنْ\add*، ؤُ إِطّفْ سَالَاعْ ذڭْ ؤُمنْغِي ؤُ إِڭَّا أَسْ يَاقْثَايِيلْ، أَڒْ أَسّْ-أَ. \f ◼ \fr 14:‏7 \ft \+bd ’سَالَاحْ‘\+bd* - إِسمْ ن يِيجّْ ن ومْشَانْ نِيغْ ن إِشْثْ ن ثنْذِينْثْ.\f*   
\m
\v 8 خنِّي إِسّكّْ أَمَاصْيَا إِرقَّاسنْ غَارْ يُووَاسْ، مِّيسْ ن يَاهُويَاحَازْ، مِّيسْ ن يَاهُو، أَجدْجِيذْ ن إِسْرَائِيل، إِنَّا: ”أَسْ-د، أجّْ أَنغْ أَذْ نمّڒْقَا \add إِ ؤُمنْغِي\add*.“  
\v 9 \add مَاشَا\add* يُووَاشْ، أَجدْجِيذْ ن إِسْرَائِيل، إِسّكّْ \add إِجّْ ن ؤُرقَّاسْ\add* غَارْ أَمَاصْيَا، أَجدْجِيذْ ن يَاهُوذَا، إِنَّا: ”شْبَارْقْ أَكْ-ذ إِسنَّاننْ \add إِ إِغمّْينْ\add* خْ \add إِذُورَارْ ن\add* لُوبْنَانْ، إِسّكّْ \add إِشْثْ ن ثبْرَاثْ\add* غَارْ \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ خْ \add إِذُورَارْ ن\add* لُوبْنَانْ، إِنَّا: ’أوْشْ يدْجِيسْ ذ ثَامْغَارْثْ إِ مِّي!‘ \add مَاشَا\add* إِجّْ ن ڒْوحْشْ ن ڒخْڒَا إِ \add ذِينْ يُويُورنْ\add* خْ \add إِذُورَارْ ن\add* لُوبْنَانْ، إِكَّا ؤُ إِعْفسْ خْ شْبَارْقْ أَكْ-ذ إِسنَّاننْ.  
\v 10 إِوَا شكْ ثْغڒْبذْ خْ إِذُومْ ؤُ ڒخُّو ثْذوْڒذْ ذَايكْ نّْفَاخثْ ذڭْ وُوڒْ نّشْ. طّفْ ذڭْ ؤُوقَّارْ إِ غَاركْ ؤُ قِّيمْ ذِي ثَادَّارْثْ نّشْ، \add مِينْزِي\add* مَايمِّي غَا ثمّنْضَارذْ إِخفْ نّشْ ذِي ڒْغَارْ ؤُ أَذْ ثوْضِيذْ، شكْ ذ يَاهُوذَا أَكِيذكْ؟“   
\m
\v 11 \add مَاشَا\add* أَمَاصْيَا وَارْ إِخْسْ أَذْ إِسڒْ، ؤُشَا يُووَاشْ، أَجدْجِيذْ ن إِسْرَائِيل، إِڭعّذْ أَڒَامِي نتَّا ذ أَمَاصْيَا، أَجدْجِيذْ ن يَاهُوذَا، مّْقَابَاڒنْ غَارْ بَايْثْ-شَامْسْ \add إِ إِدْجَانْ\add* ذِي يَاهُوذَا.  
\v 12 يَاهُوذَا إِتّْوَاغْڒبْ س ؤُفُوسْ ن إِسْرَائِيل، ؤُشَا نِيثْنِي أَروْڒنْ، كُوڒْ إِجّْ غَارْ ؤُقِيضُونْ نّسْ.  
\v 13 يُووَاشْ، أَجدْجِيذْ ن إِسْرَائِيل، إِطّفْ أَمَاصْيَا، أَجدْجِيذْ ن يَاهُوذَا، مِّيسْ ن يُووَاشْ، مِّيسْ ن أَخَازْيَا، ذِي بَايْثْ-شَامْسْ ؤُشَا يِيوضْ ث-إِ-د غَارْ ؤُرْشَالِيمْ. \add ذِينِّي\add* إِڭَّا إِشْثْ ن ثَازِّيثْ ذِي ڒْحِيضْ ن ؤُرْشَالِيمْ، زِي ثوَّارْثْ ن إِفْرَايِيمْ أَڒْ ثوَّارْثْ ن ثغْمَارْثْ، خْ إِجّْ ن وبْرِيذْ ن أَربْعَا-مْيَا ن إِغَادْجنْ.  
\v 14 يِيوِي مَارَّا ؤُرغْ ذ نُّوقَارْثْ ذ مَارَّا ڒقْشُوعْ إِ إِتّْوَافنْ ذِي ثَادَّارْثْ ن سِيذِي ؤُ ذڭْ إِخَّامنْ ن ثْخُوبَايْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ، \add ؤُڒَا ذ\add* إِرهَّاننْ، ؤُشَا إِعْقبْ غَارْ سَامَارْيَا.   
\m
\v 15 إِمزْرُوينْ إِقِّيمنْ ن يُووَاشْ ذ مِينْ إِڭَّا ذ ثْمڭَّا نّسْ إِمحْضنْ ذ مَامّشْ إِمّْنغْ أَكْ-ذ أَمَاصْيَا، أَجدْجِيذْ ن يَاهُوذَا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل؟  
\v 16 يُووَاشْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نتَّا إِتّْوَانْضڒْ ذِي سَامَارْيَا جَارْ إِجدْجِيذنْ ن إِسْرَائِيل. مِّيسْ يَارُوبْعَامْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.  
\v 17 أَمَاصْيَا، مِّيسْ ن يُووَاشْ، أَجدْجِيذْ ن يَاهُوذَا، إِدَّارْ \add عَاذْ\add* خمّسْطَاشْ ن إِسڭّْوُوسَا أَوَارْنِي إِ ڒْموْثْ ن يُووَاشْ، مِّيسْ ن يَاهُويَاحَازْ، أَجدْجِيذْ ن إِسْرَائِيل.   
\m
\v 18 إِمزْرُوينْ إِقِّيمنْ ن أَمَاصْيَا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا؟   
\m
\v 19 نِيثْنِي ڭِّينْ إِشْثْ ن ثْمعْمُوتْشْ خَاسْ ذِي ؤُرْشَالِيمْ، أَڒَامِي نتَّا يَارْوڒْ غَارْ لَاخِيشْ، \add مَاشَا\add* نِيثْنِي سّكّنْ أَوَارْنِي أَسْ إِنِّي ث إِضْفَارنْ غَارْ لَاخِيشْ ؤُشَا نْغِينْ ث ذِينِّي. \x ◘ \xo 14:‏19 \xt 2 إِم. 25‏:‏27\x*  
\v 20 نِيثْنِي إِوْينْ ث-إِ-د خْ ييْسَانْ ؤُ نتَّا إِتّْوَانْضڒْ ذِي ؤُرْشَالِيمْ جَارْ ڒجْذُوذْ نّسْ ذِي ثنْذِينْثْ ن ذَاوُوذْ.   
\m
\v 21 مَارَّا ڒْڭنْسْ ن يَاهُوذَا يِيوِي عَازَارْيَا، ونِّي ؤُمِي غَارْ إِدْجَا سطَّاشْ ن إِسڭّْوُوسَا، ؤُ ڭِّينْ ث ذ أَجدْجِيذْ ذڭْ ومْشَانْ ن بَابَاسْ أَمَاصْيَا. \x ◘ \xo 14:‏21 \xt 2 إِم. 26‏:‏1\x*  
\v 22 نتَّا إِبْنَا إِلَاثْ ؤُ يَارَّا إِ-ث \add ذڭْ ؤُفُوسْ\add* ن يَاهُوذَا، أَوَارْنِي ڒَامِي إِڭَّا أَذْ يَاريّحْ ؤُجدْجِيذْ جَارْ ڒجْذُوذْ نّسْ.   
\b  
\m  
\s1 يَارُوبْعَامْ، أَجدْجِيذْ ن إِسْرَائِيل  
\m
\v 23 ذڭْ ؤُسڭّْوَاسْ وِيسّْ خمّسْطَاشْ ن أَمَاصْيَا، مِّيسْ ن يُووَاشْ، أَجدْجِيذْ ن يَاهُوذَا، إِذْوڒْ يَارُوبْعَامْ، مِّيسْ ن يُووَاشْ، أَجدْجِيذْ ن إِسْرَائِيل ذِي سَامَارْيَا. \add نتَّا إِحْكمْ\add* وَاحِيثْ ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ذِي سَامَارْيَا.  
\v 24 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي. نتَّا وَارْ إِحيّذْ خْ مَارَّا دّْنُوبْ ن يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، ونِّي يَارِّينْ إِسْرَائِيل أَذْ إِخْضَا.  
\v 25 نتَّا يَارَّا-د مَارَّا ثَامُّورْثْ ن إِسْرَائِيل \add سَاذُو ؤُفُوسْ نّسْ\add* زِي مَانِي غَا ثِيوْضذْ غَارْ حَامَاثْ أَڒْ ڒبْحَارْ ن ڒوْضَا عْلَاحْسَابْ أَوَاڒْ ن سِيذِي، أَربِّي ن إِسْرَائِيل، إِ ثُوغَا إِسِّيوڒْ س ؤُقمُّومْ ن ؤُمْسخَّارْ نّسْ يُونُوسْ، مِّيسْ ن أَمِيتَّايْ زِي جَاثْ-حَافِيرْ. \x ◘ \xo 14:‏25 \xt يُون. 1‏:‏1؛ مت. 12‏:‏39، 40\x*  
\v 26 مَاغَارْ سِيذِي إِژْرَا أَقَا ڒغْبنْ ن إِسْرَائِيل ذ أَمرْزَاڭْ أَطَّاسْ ؤُ وَارْ ذِينْ إِقِّيمْ \add عَاذْ\add* ونِّي إِتّْوَاطّْفنْ ذ ونِّي ؤُمِي جِّينْ ؤُ وَارْ ثُوغِي ونِّي إِعَاوْننْ إِ إِسْرَائِيل.  
\v 27 سِيذِي ثُوغَا وَارْ ينِّي أَذْ إِمْحَا إِسمْ ن إِسْرَائِيل زِي سَاذُو إِجنْوَانْ، ؤُشَا إِسّنْجمْ إِ-ثنْ س ؤُفُوسْ ن يَارُوبْعَامْ، مِّيسْ ن يُووَاشْ.   
\m
\v 28 إِمزْرُوينْ إِقِّيمنْ ن يَارُوبْعَامْ ذ مَارَّا مِينْ إِڭَّا ذ مَارَّا ثِيمڭَّا نّسْ إِمحْضنْ ذ مَامّشْ إِمّْنغْ ؤُ مَامّشْ إِكسّبْ ثْوَاڒَا نّغْنِيثْ ذِيمَاشْقْ ذ حَامَاثْ إِنِّي \add ثُوغَا إِدْجَانْ\add* غَارْ يَاهُوذَا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل؟  
\v 29 يَارُوبْعَامْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ، جَارْ إِجدْجِيذنْ ن إِسْرَائِيل. مِّيسْ زَاكَارِييَّا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\b  
\m  
\c 15
\s1 عَازَارْيَا، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا ؤُ عِيشْرِينْ ن يَارُوبْعَامْ، أَجدْجِيذْ ن إِسْرَائِيل، إِذْوڒْ عَازَارْيَا، مِّيسْ ن أَمَاصْيَا، أَجدْجِيذْ ن يَاهُوذَا. \x ◘ \xo 15:‏1 \xt [2 إِم. 26‏:‏1‏-‏23] — 2 إِج. 14‏:‏21؛ 2 إِم. 26‏:‏1\x*  
\v 2 نتَّا \add ثُوغَا\add* غَارسْ سطَّاشْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ ثْنَاينْ ؤُ-خمْسِينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ يَاكُولْيَا زِي ؤُرْشَالِيمْ. \x ◘ \xo 15:‏2 \xt 2 إِم. 26‏:‏1، 3؛ 2 إِم. 27‏:‏3\x*  
\v 3 نتَّا إِڭَّا مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَمْ مَامّشْ مَارَّا إِ ثُوغَا إِڭَّا بَابَاسْ أَمَاصْيَا.  
\v 4 مْغِيرْ وَارْ تّْوَاكّْسنْثْ ڒڭْعُوذِي. يِيوِي ڒْڭنْسْ عَاذْ ثِيغَارْصَا ذ ثوْهِيبِينْ ن ڒبْخُورْ خْ ڒڭْعُوذِي.  
\v 5 \add مَاشَا\add* سِيذِي إِوْثَا أَجدْجِيذْ أَڒَامِي إِهْڒشْ س ڒْبَارْصْ أَڒْ أَسّْ ن ڒْموْثْ نّسْ. نتَّا إِقِّيمْ إِزدّغْ ذڭْ إِشْثْ ن ثَادَّارْثْ ثتّْوَاعْزڒْ، \add ؤُمِي\add* يُوثَامْ، مِّيسْ ن ؤُجدْجِيذْ، ثُوغَا ذ ڒمْقدّمْ ن ثْزذِّيغْثْ \add ن ؤُجدْجِيذْ\add* ؤُ إِحكّمْ خْ ڒْڭنْسْ ن ثمُّورْثْ.   
\m
\v 6 إِمزْرُوينْ إِقِّيمنْ ن عَازَارْيَا ذ مَارَّا مِينْ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا؟  
\v 7 عَازَارْيَا إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نضْڒنْ ث جَارْ ڒجْذُوذْ نّسْ ذِي ثنْذِينْثْ ن ذَاوُوذْ. مِّيسْ يُوثَامْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\m  
\s1 زَاكَارْيَا، أَجدْجِيذْ ن إِسْرَائِيل  
\m
\v 8 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْمنْيَا ؤُ-ثْڒَاثِينْ ن عَازَارْيَا، أَجدْجِيذْ ن يَاهُوذَا، إِحْكمْ زَاكَارِييَّا، مِّيسْ ن يَارُوبْعَامْ، خْ إِسْرَائِيل ذِي سَامَارْيَا، \add ڒْْقدّْ ن\add* ستَّا ن إِيُورنْ.  
\v 9 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، \add نِيشَانْ\add* أَمْ مَامّشْ ث ڭِّينْ ڒجْذُوذْ نّسْ. نتَّا وَارْ إِحيّذْ خْ دّْنُوبْ ن يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، ونِّي يَارِّينْ إِسْرَائِيل أَذْ إِخْضَا.  
\v 10 شَالُّومْ، مِّيسْ ن يَابِيشْ، إِڭَّا خَاسْ إِشْثْ ن ثْمعْمُوتْشْ ؤُشَا إِوْثَا إِ-ث زَّاثْ إِ ڒْڭنْسْ ؤُشَا إِنْغَا إِ-ث. نتَّا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. \f ◼ \fr 15:‏10 \ft \+bd ’شَالُّومْ‘\+bd* - أَوَاڒْ-أَ إِخْسْ أَذْ يِينِي ’نّقْمثْ‘ نِيغْ ’أَخْڒَافْ‘.\f*   
\m
\v 11 إِمزْرُوينْ إِقِّيمنْ ن زَاكَارِييَّا، خْزَارْ، أَقَا تّْوَازمّمنْ ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل.  
\v 12 وَا ذ أَوَاڒْ إِ ثُوغَا إِسِّيوڒْ سِيذِي غَارْ يَاهُو، إِنَّا: ”إِحنْجِيرنْ نّشْ أَذْ قِّيمنْ خْ ڒْعَارْشْ ن إِسْرَائِيل أَڒْ جِّيڒْ وِيسّْ أَربْعَا!“ ؤُشَا أَمُّو إِ ثمْسَارْ. \x ◘ \xo 15:‏12 \xt 2 إِج. 10‏:‏30\x*   
\b  
\m  
\s1 شَالُّومْ، أَجدْجِيذْ ن إِسْرَائِيل  
\m
\v 13 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثسْعَا ؤُ-ثْڒَاثِينْ ن عُوزِّييَا، أَجدْجِيذْ ن يَاهُوذَا، إِذْوڒْ شَالُّومْ، مِّيسْ ن يَابِيشْ، ذ أَجدْجِيذْ. نتَّا إِحْكمْ إِجّْ ن ؤُيُورْ إِكْمڒْ ذِي سَامَارْيَا. \f ◼ \fr 15:‏13 \ft \+bd ’عُوزِييَا‘\+bd* - نِيغْ ’عُوزِي-يَاهُو‘. إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’سِيذِي ذ جّْهذْ إِنُو‘.\f*  
\v 14 مَانَاحِيمْ، مِّيسْ ن جَاذِي، إِفّغْ-د غَارسْ زِي ثِيرْصَا ؤُشَا يُوسَا-د غَارْ سَامَارْيَا، إِوْثَا شَالُّومْ، مِّيسْ ن يَابِيشْ، ذِي سَامَارْيَا، ؤُشَا إِنْغَا إِ-ث. نتَّا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\m
\v 15 إِمزْرُوينْ إِقِّيمنْ ن شَالُّومْ ذ ثْمعْمُوتْشْ إِ إِڭَّا، خْزَارْ، مَانْ أَيَا \add مَارَّا\add* إِتّْوَازمّمْ ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل.  
\v 16 خنِّي إِغْڒبْ مَانَاحِيمْ خْ ثَافْسَاحْ، ذ مَارَّا إِمزْذَاغْ نِّي ذَايسْ، ؤُشَا إِوْثَا ؤُڒَا ذ ثَامُّورْثْ نّسْ زِي ثِيرْصَا، مِينْزِي نِيثْنِي ثُوغَا وَارْ ذ أَسْ أَرْزِيمنْ \add ثِيوُّورَا\add*. أَقَا إِنْغَا \add إِ-ثنْ\add*. مَارَّا ثِيمْغَارِينْ س دّيْسثْ إِفتّقْ أَسنْثْ \add أَعذِّيسْ\add*.   
\b  
\m  
\s1 مَانَاحِيمْ، أَجدْجِيذْ ن إِسْرَائِيل  
\m
\v 17 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثسْعَا ؤُ-ثْڒَاثِينْ ن عَازَارْيَا، أَجدْجِيذْ ن يَاهُوذَا، إِذْوڒْ مَانَاحِيمْ، مِّيسْ ن جَاذِي، ذ أَجدْجِيذْ خْ إِسْرَائِيل. \add نتَّا إِحْكمْ\add*عشْرَا ن إِسڭّْوُوسَا ذِي سَامَارْيَا.  
\v 18 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي. مَارَّا ؤُسَّانْ \add ن ثُوذَارْثْ نّسْ\add* وَارْ إِحيّذْ شَا خْ دّْنُوبْ ن يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، ونِّي يَارِّينْ إِسْرَائِيل أَذْ إِخْضَا.  
\v 19 \add خنِّي\add* يُوسَا-د فُولْ، أَجدْجِيذْ ن أَشُّورْ، \add إِهْجمْ\add* خْ ثمُّورْثْ. إِوْشَا مَانَاحِيمْ أَڒفْ ثَالِينْثْ ن نُّوقَارْثْ إِ فُولْ، حِيمَا أَذْ إِقِّيمْ أَذْ إِحْكمْ ؤُ حِيمَا أَذْ إِسّمْثنْ ثَاڭلْذِيثْ ذڭْ ؤُفُوسْ نّسْ. \x ◘ \xo 15:‏19 \xt 1 إِم. 5‏:‏26\x*  
\v 20 مَانَاحِيمْ إِڭَّا إِسْرَائِيل أَذْ \add غَارسْ\add* د-يِيوِي نُّوقَارْثْ، مَارَّا أَيْثْ ن بُو-وَاڭْڒَا، حِيمَا أَذْ إِسِّيوضْ نُّوقَارْثْ نِّي إِ ؤُجدْجِيذْ ن أَشُّورْ. زِي كُوڒْ أَرْيَازْ \add إِكْسِي\add* خمْسِينْ شِيقْلُو. \add خَاسْ ؤُشَا\add* إِعْقبْ ؤُجدْجِيذْ ن أَشُّورْ، وَارْ إِقِّيمْ \add عَاذْ\add* ذِي ثمُّورْثْ.   
\m
\v 21 إِمزْرُوينْ إِقِّيمنْ ن مَانَاحِيمْ ذ مَارَّا مِينْ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل؟  
\v 22 مَانَاحِيمْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. مِّيسْ فَاقَاحْيَا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\m  
\s1 فَاقَاحْيَا، أَجدْجِيذْ ن إِسْرَائِيل  
\m
\v 23 ذڭْ ؤُسڭّْوَاسْ وِيسّْ خمْسِينْ ن عَازَارْيَا، أَجدْجِيذْ ن يَاهُوذَا، إِذْوڒْ فَاقَاحْيَا، مِّيسْ ن مَانَاحِيمْ، ذ أَجدْجِيذْ خْ إِسْرَائِيل. \add نتَّا إِحْكمْ\add* ثْنَاينْ ن إِسڭّْوُوسَا ذِي سَامَارْيَا.  
\v 24 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي. نتَّا وَارْ إِحيّذْ خْ دّْنُوبْ ن يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، ونِّي يَارِّينْ إِسْرَائِيل أَذْ إِخْضَا.  
\v 25 فَاقَاحْ، مِّيسْ ن رَامَالْيَاهُو، أَنغْرَافْ \add ن ڒْعسْكَارْ\add*، إِڭَّا خَاسْ إِشْثْ ن ثْمعْمُوتْشْ، إِوّثْ إِ-ث ذِي سَامَارْيَا، ذِي لْبُورْجْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ. أَرْجُوبْ ذ أَرْيَاهْ وْشِينْ أَسْ أَفُوسْ ؤُ ثُوغَا أَكِيذسْ \add عَاوذْ\add* خمْسِينْ ن يرْيَازنْ زِي جِيلْعَاذْ. نتَّا إِنْغَا فَاقَاحْيَا ؤُ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\m
\v 26 إِمزْرُوينْ إِقِّيمنْ ن فَاقَاحْيَا ذ مَارَّا مِينْ إِڭَّا، خْزَارْ، مَانْ أَيَا \add مَارَّا\add* إِتّْوَازمّمْ ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل.   
\b  
\m  
\s1 فَاقَاحْ، أَجدْجِيذْ ن إِسْرَائِيل  
\m
\v 27 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ ؤُ-خمْسِينْ ن عَازَارْيَا، إِذْوڒْ فَاقَاحْ، مِّيسْ ن رَامَالْيَاهُو، ذ أَجدْجِيذْ خْ إِسْرَائِيل. \add نتَّا إِحْكمْ\add* عِيشْرِينْ ن إِسڭّْوُوسَا ذِي سَامَارْيَا.  
\v 28 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي. نتَّا وَارْ إِحيّذْ شَا خْ دّْنُوبْ ن يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ نِّي يَارِّينْ إِسْرَائِيل أَذْ إِخْضَا.  
\v 29 ذڭْ وُوسَّانْ ن فَاقَاحْ، أَجدْجِيذْ ن إِسْرَائِيل، يُوسَا-د ثِيغْلَاثْ-فِيلَاسِيرْ، أَجدْجِيذْ ن أَشُّورْ. نتَّا إِحوّسْ عَايُونْ ذ أَبِيلْ-بَايْثْ-مَاعْكَا ذ يَانُوحْ ذ قَاذَاشْ ذ حَاصُورْ ذ جِيلْعَاذْ ذ لْجَالِيلْ ذ مَارَّا ثَامُّورْثْ ن نَافْثَالِي. نتَّا إِنْذهْ إِ-ثنْ غَارْ لْمنْفَا غَارْ أَشُّورْ. \x ◘ \xo 15:‏29 \xt إِشا. 8‏:‏23\x*  
\v 30 هُوشِيعَا، مِّيسْ ن إِلَا، إِڭَّا إِشْثْ ن ثْمعْمُوتْشْ خْ فَاقَاحْ، مِّيسْ ن رَامَالْيَاهُو. نتَّا إِوْثَا إِ-ث ؤُشَا إِنْغَا إِ-ث. نتَّا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ ذڭْ ؤُسڭّْوَاسْ وِيسّْ عِيشْرِينْ ن يُوثَامْ، مِّيسْ ن عُوزِّييَا.   
\m
\v 31 إِمزْرُوينْ إِقِّيمنْ ن فَاقَاحْ ذ مَارَّا مِينْ إِڭَّا، خْزَارْ، مَانْ أَيَا \add مَارَّا\add* إِتّْوَازمّمْ ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن إِسْرَائِيل.   
\b  
\m  
\s1 يُوثَامْ، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 32 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ ن فَاقَاحْ، مِّيسْ ن رَامَالْيَاهُو، أَجدْجِيذْ ن إِسْرَائِيل، إِذْوڒْ يُوثَامْ ذ أَجدْجِيذْ. \add ثُوغَا نتَّا\add* ذ مِّيسْ ن عُوزِّييَا، أَجدْجِيذْ ن يَاهُوذَا. \x ◘ \xo 15:‏32 \xt [2 إِم. 27‏:‏1‏-‏9]\x*  
\v 33 نتَّا \add ثُوغَا\add* غَارسْ خمْسَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. \add نتَّا إِحْكمْ\add* سطَّاشْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ يَارُوشَا، يدْجِيسْ ن صَاذُوقْ. \x ◘ \xo 15:‏33 \xt 2 إِم. 27‏:‏1‏-‏9\x*  
\v 34 نتَّا إِڭَّا مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي، نِيشَانْ أَمْ مَامّشْ ث إِڭَّا بَابَاسْ عُوزِّييَا.  
\v 35 مْغِيرْ وَارْ تّْوَاكّْسنْثْ ڒڭْعُوذِي. ڒْڭنْسْ يِيوْيِي-د \add عَاذْ\add* ثِيغَارْصَا ذ ثوْهِيبِينْ ن ڒبْخُورْ خْ ڒڭْعُوذِي. نتَّا إِبْنَا ثوَّارْثْ يُوعْڒَانْ ذِي ثَادَّارْثْ ن سِيذِي.   
\m
\v 36 إِمزْرُوينْ إِقِّيمنْ ن يُوثَامْ، ذ مَارَّا مِينْ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا؟  
\v 37 ذڭْ وُوسَّانْ نِّي إِبْذَا سِيذِي أَذْ إِسّكّْ رَاصِينْ، أَجدْجِيذْ ن أَرَامْ، ذ فَاقَاحْ، مِّيسْ ن رَامَالْيَاهُو، غَارْ يَاهُوذَا. \x ◘ \xo 15:‏37 \xt 2 إِج. 16‏:‏5؛ إِشا. 7‏:‏1\x*  
\v 38 يُوثَامْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نتَّا إِتّْوَانْضڒْ جَارْ ڒجْذُوذْ نّسْ ذِي ثنْذِينْثْ ن بَابَاسْ ذَاوُوذْ. مِّيسْ أَحَازْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. \f ◼ \fr 15:‏38 \ft \+bd ’أَحَازْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’نتَّا إِطّفْ‘.\f*   
\b  
\b  
\m  
\c 16
\s1 أَحَازْ، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ سْبعْطَاشْ ن فَاقَاحْ، مِّيسْ ن رَامَالْيَاهُو، إِذْوڒْ أَحَازْ، مِّيسْ ن يُوثَامْ، ذ أَجدْجِيذْ ن يَاهُوذَا. \x ◘ \xo 16:‏1 \xt [2 إِم. 28‏:‏1‏-‏27] — 2 إِم. 28‏:‏1\x*  
\v 2 أَحَازْ \add ثُوغَا\add* غَارسْ عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ سطَّاشْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. نتَّا وَارْ إِڭِّي مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَربِّي نّسْ، أَمْ مَامّشْ \add إِڭَّا\add* بَابَاسْ ذَاوُوذْ.  
\v 3 نتَّا يُويُورْ ذڭْ إِبْرِيذنْ ن إِجدْجِيذنْ ن إِسْرَائِيل. نتَّا إِجَّا عَاذْ مِّيسْ أَذْ يُويُورْ ذِي ثْمسِّي أَمْ مَامّشْ مَارَّا جّْعَايفْ ن ڒڭْنُوسْ إِنِّي ثُوغَا إِعَارّنْ سِيذِي زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 16:‏3 \xt لَاوِي 18‏:‏21؛ 20‏:‏2، 3؛ 2 إِج. 17‏:‏31\x*  
\v 4 نتَّا يِيوْيِي-د ثِيغَارْصَا ذ ثوْهِيبِينْ ن ڒبْخُورْ خْ ڒڭْعُوذِي ؤُ خْ ثوْرِيرِينْ ؤُ سَاذُو مَارَّا أَزْغَارْ أَزِيزَا.  
\v 5 خَاسْ ؤُشَا إِفّغْ رَاصِينْ، أَجدْجِيذْ ن أَرَامْ، ذ فَاقَاحْ، مِّيسْ ن رَامَالْيَاهُو، أَجدْجِيذْ ن إِسْرَائِيل، إِمّْنغْ أَكْ-ذ ؤُرْشَالِيمْ. نِيثْنِي نّْضنْ إِ أَحَازْ، \add مَاشَا\add* وَارْ زمَّارنْ أَذْ خَاسْغڒْبنْ. \x ◘ \xo 16:‏5 \xt إِشا. 7‏:‏1\x*   
\m
\v 6 ذِي ڒْوقْثْ نِّي يَارَّا-د رَاصِينْ، أَجدْجِيذْ ن أَرَامْ، إِلَاثْ إِ أَرَامْ. إِسُّوفّغْ أَيْثْ ن يَاهُوذَا زِي إِلَاثْ ؤُشَا ؤُسِينْ-د أَيْثْ ن أَرَامْ غَارْ إِلَاثْ، \add قِّيمنْ\add* زدّْغنْ ذِينْ أَڒْ أَسّْ-أَ. \f ◼ \fr 16:‏6 \ft \+bd ’إِرَامِييّنْ‘\+bd* - إِخْسْ أَذْ يِينِي ’أَيْثْ ن ثمُّورْثْ ن أَرَامْ‘.\f*  
\v 7 أَحَازْ إِسّكّْ إِرقَّاسنْ إِ ثِيغْلَاثْ-فِيلَاسِيرْ، أَجدْجِيذْ ن أَشُّورْ، إِنَّا: ”نشّْ ذ أَمْسخَّارْ نّشْ ذ مِّيشْ. ڭعّذْ ذ ثْفكّذْ أَيِي زڭْ ؤُفُوسْ ن ؤُجدْجِيذْ ن أَرَامْ ذ ؤُجدْجِيذْ ن إِسْرَائِيل، إِنِّي خَافِي إِنّْقڒْبنْ.“  
\v 8 أَحَازْ يِيوِي نُّوقَارْثْ ذ وُورغْ إِ إِتّْوَافنْ ذِي ثَادَّارْثْ ن سِيذِي ؤُ ذڭْ إِخَّامنْ ن ثْخُوبَايْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ ؤُشَا إِسّكّْ \add أَيَا أَمْ\add* إِشْثْ ن ثرْزفْثْ إِ ؤُجدْجِيذْ ن أَشُّورْ. \x ◘ \xo 16:‏8 \xt 2 إِم. 28‏:‏21\x*  
\v 9 أَجدْجِيذْ ن أَشُّورْ إِسْڒَا غَارسْ ؤُشَا إِڭعّذْ ؤُجدْجِيذْ ن أَشُّورْ غَارْ ذِيمَاشْقْ، إِطّفْ إِ-ت. نتَّا إِنْذهْ إِ-ت غَارْ لْمنْفَا غَارْ قِيرْ ؤُ إِنْغَا رَاصِينْ.   
\m
\v 10 أَجدْجِيذْ أَحَازْ إِفّغْ غَارْ ذِيمَاشْقْ إِ ؤُمْسَاڭَارْ أَكْ-ذ ثِيغْلَاثْ-فِيلَاسِيرْ، أَجدْجِيذْ ن أَشُّورْ، ؤُشَا إِژْرَا إِجّْ ن ؤُعَالْطَارْ ذِي ذِيمَاشْقْ. أَجدْجِيذْ أَحَازْ إِسّكّْ إِجّْ ن ؤُمذْيَا ن ؤُعَالْطَارْ ذ ثْوصَّافْ نّسْ نْ ڒبْنِي، قَاعْ أَمْ مَامّشْ ثُوغَا إِتّْخصَّا أَذْ ث ڭّنْ، غَارْ ؤُكهَّانْ ؤُرِييَا.  
\v 11 \add خَاسْ ؤُشَا\add* إِبْنَا ؤُكهَّانْ ؤُرِييَا أَعَالْطَارْ. غَارْ \add ڒْْوقْثْ إِ ذِي\add* د-إِعْقبْ ؤُجدْجِيذْ أَحَازْ زِي ذِيمَاشْقْ، أَقَا إِبْنَا ث ؤُكهَّانْ ؤُرِييَا أَمْ مَامّشْ مَارَّا مِينْ \add غَارسْ\add* د-إِسّكّْ ؤُجدْجِيذْ أَحَازْ زِي ذِيمَاشْقْ.  
\v 12 \add ؤُمِي\add* د-يُوسَا ؤُجدْجِيذْ زِي ذِيمَاشْقْ، إِژْرَا ؤُجدْجِيذْ أَعَالْطَارْ ؤُشَا إِقَارّبْ-د ؤُجدْجِيذْ غَارْ ؤُعَالْطَارْ ؤُشَا إِسّْبخَّارْ خَاسْ \add ثِيغَارْصَا\add*.  
\v 13 نتَّا إِسّْبخَّارْ ثَاغَارْصْثْ نّسْ ذ ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ؤُ إِسيّبْ خَاسْ ثَاوْهِيبْثْ ن ؤُسيّبْ نّسْ. إِسّْفَارّْغغْ ؤُڒَا ذ إِذَامّنْ ن ثْغَارْصَا نّسْ ن ڒهْنَا خْ ؤُعَالْطَارْ.  
\v 14 أَعَالْطَارْ ن نّْحَاسْ نِّي إِبدّنْ زَّاثْ إِ وُوذمْ ن سِيذِي، إِسّْمُوطِّييْ ث زڭْ ؤُغزْذِيسْ ن زَّاثْ ن ثَادَّارْثْ، زِي جَارْ ؤُعَالْطَارْ \add ن جْذِيذْ\add* ذ ثَادَّارْثْ ن سِيذِي، غَارْ ؤُغزْذِيسْ ن شَّامَالْ ن ؤُعَالْطَارْ \add ن جْذِيذْ\add* ؤُشَا إِسَّارْسْ إِ-ث \add ذِينِّي\add*.  
\v 15 ڒخْذنِّي أَجدْجِيذْ أَحَازْ إِوصَّا أَكهَّانْ ؤُرِييَا، إِنَّا: ”سْبخَّارْ ثَاغَارْصْثْ ن وشْمَاضْ ن صّْبحْ ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ن ثْمذِّيثْ ڒَا ثَاغَارْصْثْ ن وشْمَاضْ ن ؤُجدْجِيذْ ذ ثوْهِيبْثْ نّسْ \add ن ڒْغِيدْجثْ\add* ذ ثْغَارْصْثْ ن وشْمَاضْ ذِي طّْوعْ ن مَارَّا ڒْڭنْسْ ن ثمُّورْثْ ذ ثوْهِيبِينْ نْسنْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبِينْ نْسنْ ن ؤُسيّبْ، ؤُ زدْجعْ خَاسْ مَارَّا إِذَامّنْ ن مَارَّا ثِيغَارْصَا ن وشْمَاضْ ؤُ ن ثْغَارْصَا \add نّغْنِي\add*. أَعَالْطَارْ ن نّْحَاسْ أَذْ يِيڒِي إِ نّشْ، حِيمَا أَذْ \add ذَايسْ\add* أَرْزُوغْ عَاذْ.  
\v 16 أَكهَّانْ ؤُرِييَا إِڭَّا أَمْ مَامّشْ مَارَّا س مِينْزِي إِوصَّا ؤُجدْجِيذْ أَحَازْ.  
\v 17 أَجدْجِيذْ أَحَازْ إِقسّْ ثڒْوِيحِينْ \add إِ يدْجَانْ\add* خْ ثْكَارُّوثِينْ ؤُشَا إِكّسْ \add زَّايْسنْثْ\add* ثَابَانْيُوثْ إِ خَاسْ إِدْجَانْ. إِكّسْ ؤُڒَا ذ ثَارِيمَانْثْ ن وَامَانْ زڭْ إِفُونَاسنْ ن نّْحَاسْ إِنِّي سَاذُو نّسْ ؤُشَا إِسَّارْسْ إِ-ت خْ إِشْثْ ن زّلِّيجْ ن وژْرُو. \f ◼ \fr 16:‏17 \ft \+bd ’ثَارِيمَانْثْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒبْحَارْ‘ نِيغْ ’إِلْ‘.\f*  \x ◘ \xo 16:‏17 \xt 1 إِج. 7‏:‏23‏-‏51\x*  
\v 18 بَاسُو ن سّبْثْ إِ ثُوغَا إِبْنَانْ ذِي ثَادَّارْثْ، ؤُڒَا ذ أَذَافْ ن ؤُجدْجِيذْ غَارْ ؤُغزْذِيسْ ن بَارَّا إِكّسْ إِ-ثنْ زِي ثَادَّارْثْ ن سِيذِي ذِي سِّيبّثْ ن ؤُجدْجِيذْ ن أَشُّورْ. \x ◘ \xo 16:‏18 \xt 1 إِج. 10‏:‏5؛ 1 إِم. 9‏:‏18\x*  
\v 19 إِمزْرُوينْ إِقِّيمنْ ن أَحَازْ ذ مِينْ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا؟  
\v 20 أَحَازْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ ذِي ثنْذِينْثْ ن ذَاوُوذْ. مِّيسْ حِيزْقِييَا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\b  
\m  
\c 17
\s1 حُوشَاعْ، أَجدْجِيذْ ن إِسْرَائِيل أَڒْ لْمنْفَا غَارْ أَشُّورْ  
\m
\v 1 ذڭْ ؤُسڭّْوَّاسْ وِيسّْ ثنْعَاشْ ن أَحَازْ، أَجدْجِيذْ ن يَاهُوذَا، إِذْوڒْ هُوشِيعَا، مِّيسْ ن إِلَا، ذ أَجدْجِيذْ خْ إِسْرَائِيل ذِي سَامَارْيَا. \add نتَّا إِحْكمْ\add* ثسْعَا ن إِسڭّْوُوسَا.  
\v 2 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، مَاشَا وَارْ إِدْجِي أَنشْثْ ن إِجدْجِيذنْ ن إِسْرَائِيل، إِنِّي ثُوغَا قْبڒْ نّسْ.  
\v 3 شَالْمَانَاسَّارْ، أَجدْجِيذْ ن أَشُّورْ، إِهْجمْ خَاسْ ؤُشَا هُوشِيعَا إِذْوڒْ ذ أَمْسخَّارْ نّسْ ؤُشَا إِتّْوَاڭّْ خَاسْ مَاحنْذْ أَذْ أَسْ إِوْشْ لْجِيزْيَا.  
\v 4 أَجدْجِيذْ ن أَشُّورْ يُوفَا أَقَا هُوشِيعَا إِڭَّا إِشْثْ ن ثْمعْمُوتْشْ. وَانِيثَا ثُوغَا إِسّكّْ إِرقَّاسنْ نّسْ غَارْ سُو، أَجدْجِيذْ ن مِيصْرَا، ؤُشَا وَارْ د-يِيوِي عَاذْ لْجِيزْيَا أَمْ قْبڒْ إِ ؤُجدْجِيذْ ن أَشُّورْ، زڭْ ؤُسڭّْوَاسْ أَڒْ أَسڭّْوَاسْ. أَجدْجِيذْ ن أَشُّورْ إِطّفْ إِ-ث ؤُشَا إِشدّْ إِ-ث س إِشذِّييّنْ ذِي ڒحْبسْ.  
\v 5 أَجدْجِيذْ ن أَشُّورْ إِوْضَا خْ مَارَّا ثَامُّورْثْ، إِڭعّذْ غَارْ سَامَارْيَا ؤُ إِنّضْ أَسْ-د ثْڒَاثَا ن إِسڭّْوُوسَا. \x ◘ \xo 17:‏5 \xt 2 إِج. 18‏:‏9\x*  
\v 6 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثسْعَا ن هُوشِيعَا، إِحوّسْ أَجدْجِيذْ ن أَشُّورْ سَامَارْيَا ؤُشَا إِنْذهْ \add أَيْثْ ن\add* إِسْرَائِيل ذِي لْمنْفَا غَارْ أَشُّورْ ؤُ إِسّزْذغْ إِ-ثنْ ذِي حَالَاحْ ؤُ غَارْ خابُورْ ونِّي ذ إِغْزَارْ ن جُوزَانْ، ؤُ \add ذِي\add* ثْندَّامْ ن إِمَاذَاينْ. \x ◘ \xo 17:‏6 \xt 2 إِج. 18‏:‏10؛ إِشا. 8‏:‏4\x*   
\b  
\m
\v 7 أَيَا إِمْسَارْ مِينْزِي أَيْثْ ن إِسْرَائِيل خْضَانْ خْ سِيذِي، أَربِّي نْسنْ، ونِّي ثنْ د-إِسّْڭعّْذنْ زِي مِيصْرَا، زِي سَاذُو إِ ؤُفُوسْ ن فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا، ؤُ ؤُمِي ڭّْوذنْ نِيثْنِي إِربِّيثنْ نّغْنِي،  
\v 8 ڭِّينْ أَذْ دَّارنْ عْلَاحْسَابْ ثِيوصَّا ن ڒڭْنُوسْ نِّي إِعَارّنْ إِ-ثنْ سِيذِي زِي زَّاثْ إِ وُوذمْ نْسنْ، ؤُ \add عْلَاحْسَابْ ثِيوصَّا\add* ن إِجدْجِيذنْ ن إِسْرَائِيل إِنِّي \add ثنْ\add* إِڭِّينْ. \x ◘ \xo 17:‏8 \xt لَاوِي 18‏:‏3\x*  
\v 9 أَيْثْ ن إِسْرَائِيل ثُوغَا ذْڒِينْ ثِيمسْڒَايِينْ إِ وَارْ إِتّْڒِيقِينْ زَّاثْ إِ سِيذِي. نِيثْنِي سّْبدّنْ إِ إِخفْ نْسنْ ڒڭْعُوذِي ذِي مَارَّا ثِيندَّامْ نْسنْ، \add وَاهْ،\add* زِي لْبُورْجْ ن ثْعسَّاسْثْ أَڒْ ثَانْذِينْثْ إِفَارْينْ \add س إِغبْڒَاونْ\add*.  
\v 10 نِيثْنِي سّْبدّنْ إِمَايْضُوثنْ \add إِقدّْسنْ\add* ذ ثْربِّينْ ن شْوَارْثِي خْ كُوڒْ ثَاوْرِيرْثْ يُوعْڒَانْ ؤُ سَاذُو كُوڒْ أَزْغَارْ ذ أَزِيزَا.  
\v 11 نِيثْنِي قدّْمنْ ثِيوْهِيبِينْ ن ڒبْخُورْ خْ مَارَّا ڒڭْعُوذِي، أَمْ مَامّشْ ڭِّينْ ڒڭْنُوسْ نِّي ثُوغَا إِسُّوفّغْ سِيذِي زِي زَّاثْ ن وُوذمْ نْسنْ. نِيثْنِي ڭِّينْ ثِيمسْڒَايِينْ ذ ثِيعفَّانِينْ أَڒَامِي سْعَارنْ سِيذِي.  
\v 12 نِيثْنِي سخَّارنْ إِ إِميْضَا \add ن لْ-أَصْنَامْ\add* إِ خْ ثُوغَا ذ أَسنْ إِنَّا سِيذِي: ”وَارْ إِعدّڒْ أَذْ ثڭّمْ أَيَا!“ \x ◘ \xo 17:‏12 \xt ؤُف. 20‏:‏3، 4، 5؛ أَعَوذ. 5‏:‏7، 8، 9\x*  
\v 13 سِيذِي إِعْڒمْ إِ إِسْرَائِيل ذ يَاهُوذَا س ؤُقمُّومْ ن مَارَّا إِنَابِييّنْ، ؤُ س كُوڒْ إِجّْ ن ؤُمْوَاڒَاوْ، إِنَّا: ”ثُوبمْ زِي ثْبْرِيذِينْ نْومْ ثِيعفَّانِينْ ؤُ حْضَامْ خْ لْفَارَايِيضْ  إِنُو ذ ثْوصَّا إِنُو عْلَاحْسَابْ مَارَّا شَّارِيعَا إِ زِي ؤُمُورغْ ڒجْذُوذْ نْومْ ؤُ ونِّي ذ أَومْ د-سّكّغْ س ؤُفُوسْ ن إِمْسخَّارنْ إِنُو، إِنَابِييّنْ. \x ◘ \xo 17:‏13 \xt إِرْم. 18‏:‏11؛ 25‏:‏5؛ 35‏:‏15\x*  
\v 14 نِيثْنِي وَارْ سْڒِينْ شَا ؤُ ثُوغَا قسْحنْ أَطَّاسْ أَمْ مَامّشْ ثُوغَا قسْحنْ أَطَّاسْ ڒجْذُوذْ نْسنْ، إِنِّي وَارْ إِڭِّينْ تِّيقثْ ذِي سِيذِي، أَربِّي نْسنْ. \x ◘ \xo 17:‏14 \xt أَعَوذ. 31‏:‏27؛ مـَال. 3‏:‏7\x*  
\v 15 نِيثْنِي نْضَارنْ ثِيوصَّا نّسْ ذ ڒْعَاهْذْ نّسْ، ونِّي إِڭَّا نتَّا أَكْ-ذ ڒجْذُوذْ نْسنْ، ؤُڒَا ذ شّْهَاذَاثْ نّسْ نِّي ثُوغَا خَاسنْ إِشْهذْ. نِيثْنِي ضْفَارنْ مِينْ إِدْجَانْ ذِي ڒْبَاطڒْ ؤُشَا ؤُڒَا ذ نِيثْنِي \add س يِيخفْ نْسنْ\add* ذوْڒنْ بطّْڒنْ. \add نِيثْنِي ضْفَارنْ عَاوذْ\add* ڒڭْنُوسْ نِّي ذ أَسنْ د-إِنّْضنْ إِ خْ ثُوغَا ذ أَسنْ إِنَّا سِيذِي أَقَا أَذْ تّڭّنْ أَمْ مَامّشْ \add ڭِّينْ\add* نِيثْنِي.  
\v 16 نِيثْنِي أَڭّْوجنْ خْ مَارَّا ثِيوصَّا ن سِيذِي، أَربِّي نْسنْ، ؤُ ڭِّينْ إِ يِيخفْ نْسنْ ڒخْيَاڒَاثْ إِفسْينْ: ثْنَاينْ ن إِعجْمِييّنْ. نِيثْنِي ڭِّينْ \add عَاوذْ\add* إِشْثْ ن ثْربِّيثْ ن شْوَارْثِي ؤُشَا بنْذْقنْ إِ مَارَّا ڒْعسْكَارْ ن ؤُجنَّا ؤُعبْذنْ إِ بَاعَالْ. \f ◼ \fr 17:‏16 \ft \+bd ’أَمْوَا‘\+bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘.\f*  \x ◘ \xo 17:‏16 \xt ؤُف. 32‏:‏8؛ 1 إِج. 12‏:‏28\x*  
\v 17 نِيثْنِي أَرِّينْ إِحنْجِيرنْ نْسنْ ذ ثْحنْجِيرِينْ نْسنْ أَذْ شُوقنْ ذِي ثْمسِّي ؤُشَا سّْخذْمنْ أَعزّمْ ذ ثْڭزَّانْثْ. نِيثْنِي زّنْزنْ إِخفْ نْسنْ، مَاحنْذْ أَذْ ڭّنْ مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، حِيمَا أَذْ ث سْعَارنْ. \x ◘ \xo 17:‏17 \xt لَاوِي 20‏:‏3، 4؛ أَعَوذ. 18‏:‏10؛ 2 إِج. 16‏:‏3\x*  
\v 18 \add خْ ؤُينِّي\add* إِسْعَارْ سِيذِي أَطَّاسْ خْ إِسْرَائِيل، \add أَڒَامِي\add* إِنْضَارْ إِ-ثنْ خْ وُوذمْ نّسْ. وَارْ \add زَّايْسنْ\add* إِقِّيمْ وَالُو مْغِيرْ ثَاقْبِيتْشْ ن يَاهُوذَا. \x ◘ \xo 17:‏18 \xt حُوش. 1‏:‏6\x*   
\m
\v 19 \add مَاشَا\add* ؤُڒَا ذ يَاهُوذَا وَارْ إِحْضَا لْفَارَايِيضْ ن سِيذِي، أَربِّي نْسنْ. نِيثْنِي ؤُيُورنْ ذِي ثْوصَّا ن إِسْرَائِيل نِّي ڭِّينْ س يِيخفْ نْسنْ.   
\m
\v 20 سِيذِي إِنْضَارْ مَارَّا زَّارِيعثْ ن إِسْرَائِيل. نتَّا إِسّْبهْذڒْ إِ-ثنْ ؤُشَا إِوْشَا إِ-ثنْ ذڭْ ؤُفُوسْ ن إِمْكشَّاضنْ أَڒَامِي إِنْضَارْ إِ-ثنْ خْ وُوذمْ نّسْ.  
\v 21 مَاغَارْ نتَّا ثُوغَا إِقْڒعْ إِسْرَائِيل زِي ثَادَّارْثْ ن ذَاوُوذْ ؤُشَا ڭِّينْ يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ ذ أَجدْجِيذْ. يَارُوبْعَامْ \add مَاشَا\add* إِبْضَا إِسْرَائِيل خْ سِيذِي ؤُشَا يَارَّا إِ-ثنْ أَذْ ڭّنْ إِجّْ ن دّنْبْ ذ أَمقّْرَانْ. \x ◘ \xo 17:‏21 \xt 1 إِج. 12‏:‏16، 17، 26\x*  
\v 22 أَيْثْ ن إِسْرَائِيل كِّينْ ذِي مَارَّا دّْنُوبْ إِ إِڭَّا يَارُوبْعَامْ. نِيثْنِي وَارْ خَاسنْ حيّْذنْ شَا،  
\v 23 أَڒَامِي إِنْضَارْ سِيذِي إِسْرَائِيل زِي زَّاثْ إِ وُوذمْ نّسْ أَمْ مَامّشْ ثُوغَا إِسِّيوڒْ س ؤُقمُّومْ ن مَارَّا إِمْسخَّارنْ نّسْ، إِنَابِييّنْ. سُّوفّْغنْ إِسْرَائِيل زڭْ وُوذمْ ن ثمُّورْثْ نّسْ ذِي لْمنْفَا غَارْ أَشُّورْ، أَڒْ أَسّْ-أَ.   
\b  
\m  
\s1 ڒڭْنُوسْ نّغْنِي ذِي سَامَارْيَا  
\m
\v 24 أَجدْجِيذْ ن أَشُّورْ يِيوِي-د \add إِوْذَانْ\add* زِي بَابِيلْ ذ كُوثَا ذ عَاوَا ذ حَامَاثْ ذ سْفَارْوَايِيمْ، ؤُشَا إِسّزْذغْ إِ-ثنْ ذِي ثْندَّامْ ن سَامَارْيَا، ذڭْ ومْشَانْ ن أَيْثْ ن إِسْرَائِيل. نِيثْنِي طّْفنْ سَامَارْيَا ذ ڒْوَارْثْ \add إِ يِيخفْ نْسنْ\add* ؤُ ڭِّينْ أَذْ زذْغنْ ذِي ثْندَّامْ نّسْ.  
\v 25 ؤُمِي ذِينِّي زذْغنْ عَاذْ شْوَايْثْ، إِمْسَارْ أَقَا نِيثْنِي وَارْ ڭّْوِيذنْ شَا سِيذِي. \add خنِّي\add* إِسّكّْ سِيذِي إِيْرَاذنْ جَارْ أَسنْ إِنِّي إِنْغِينْ شَا زَّايْسنْ.  
\v 26 نِيثْنِي سِّيوْڒنْ \add خْ مَانْ أَيَا\add* أَكْ-ذ ؤُ ؤُجدْجِيذْ ن أَشُّورْ، نَّانْ: ”ڒڭْنُوسْ نِّي ثسُّوفّْغذْ ؤُ ثسّْزذْغذْ ذِي ثْندَّامْ ن سَامَارْيَا، وَارْ سِّيننْ مَامّشْ \add ثدْجَا\add* ثُوبَّارْثْ ن أَربِّي ن ثمُّورْثْ. \add خْ ؤُيَا\add* نتَّا إِسّكّْ إِيْرَاذنْ جَارْ أَسنْ، ؤُ خْزَارْ، نِيثْنِي نْغِينْ ثنْ، مَاغَارْ وَارْ سِّيننْ شَا ثُوبَّارْثْ ن أَربِّي ن ثمُّورْثْ.   
\m
\v 27 أَجدْجِيذْ ن أَشُّورْ يُومُورْ، إِنَّا: ”جّمْ أَذْ ذِينْ إِرَاحْ إِجّنْ زڭْ إِكهَّاننْ نِّي ثْنذْهمْ سّنِّي. نِيثْنِي أَذْ \add ذِينْ\add* رَاحنْ ؤُ أَذْ \add ذِينْ\add* زذْغنْ ؤُ نتَّا أَذْ أَسنْ إِسّڒْمذْ ثُوبَّارْثْ ن أَربِّي ن ثمُّورْثْ.“  
\v 28 يُوسَا-د إِجّنْ زڭْ إِكهَّاننْ نِّي ثُوغَا نذْهنْ زِي سَامَارْيَا ؤُشَا نتَّا إِزْذغْ ذِي بَايْثْ-إِلْ. إِسّڒْمذْ إِ-ثنْ مَامّشْ غَا وقَّارنْ سِيذِي.  
\v 29 \add مَاشَا\add* كُوڒْ ڒْڭنْسْ يَارْنِي أَذْ إِڭّْ إِربِّيثنْ ن يِيخفْ نّسْ ؤُشَا سّْبدّنْ ثنْ ذِي ثُوذْرِينْ خْ ڒڭْعُوذِي نِّي ثُوغَا بْنَانْ إِسَامَارِييّنْ، كُوڒْ ڒْڭنْسْ ذِي ثْندَّامْ نْسنْ مَانِي ثُوغَا زدّْغنْ.  
\v 30 إِرْيَازنْ ن بَابِيلْ ڭِّينْ \add إِ يِيخفْ نْسنْ\add* سُوكُّوثْ-بْنُوثْ، ؤُ إِرْيَازنْ زِي كُوثَا ڭِّينْ نَارْجَالْ، ؤُ إِرْيَازنْ زِي حَامَاثْ ڭِّينْ أَشِيمَا،  
\v 31 ؤُ إِعَاوِييّنْ ڭِّينْ إِوْرَافنْ ن نِيبْحَازْ ذ ثَارْثَاقْ، ؤُشَا إِسَافَارْوَايِّينْ سّْشمْضنْ إِحنْجِيرنْ نْسنْ إِ أَذْرَامِّيلِيكْ ذ عَانَامِّيلِيخْ، إِربِّيثنْ ن سْفَارْوَايِيمْ.  
\v 32 \add س مَارَّا مَانْ أَيَا\add* ڭّْوذنْ نِيثْنِي \add عَاوذْ\add* سِيذِي، \add مَاشَا ذِي ڒْوقْثْ ذ إِجّْ\add* ڭِّينْ نِيثْنِي إِ يِيخفْ نْسنْ زِي \add مَارَّا\add* ڒصْفُوفْ نْسنْ \add عَاوذْ\add* إِكهَّاننْ إِ ڒڭْعُوذِي، إِنِّي ذ أَسنْ إِسخَّارنْ ذِي ثُوذْرِينْ خْ ڒڭْعُوذِي. \x ◘ \xo 17:‏32 \xt 1 إِج. 12‏:‏31\x*  
\v 33 نِيثْنِي ڭّْوذنْ سِيذِي ؤُشَا سخَّارنْ ؤُڒَا إِ إِربِّيثنْ \add ن إِخفْ نْسنْ\add* أَمْ مَامّشْ \add ثُوغَا ثدْجَا\add* ثُوبَّارْثْ ن ڒڭْنُوسْ إِ زِي ثُوغَا تّْوَانذْهنْ نِيثْنِي. \x ◘ \xo 17:‏33 \xt صَاف. 1‏:‏5\x*   
\m
\v 34 أَڒْ أَسّْ-أَ تّڭّنْ نِيثْنِي عْلَاحْسَابْ طّْبَايعْ نْسنْ ن زِيشْ. نِيثْنِي وَارْ تّڭّْوْذنْ شَا سِيذِي ؤُ وَارْ تّڭّنْ شَا عْلَاحْسَابْ ثِيوصَّا ذ لْفَارِيضَا، \add إِخْسْ أَذْ يِينِي\add* شَّارِيعَا ذ ڒُومُورْ إِ إِڭَّا سِيذِي خْ أَيْثْ ن يَاعْقُوبْ ونِّي ؤُمِي ثُوغَا إِوْشَا إِسمْ ’إِسْرَائِيل‘. \x ◘ \xo 17:‏34 \xt أَمز. 32‏:‏27؛ 35‏:‏10؛ 1 إِج. 18‏:‏31\x*  
\v 35 سِيذِي إِڭَّا إِجّْ ن ڒْعَاهْذْ أَكِيذْسنْ، ؤُشَا يُومُورْ إِ-ثنْ، إِنَّا: ”كنِّيوْ وَارْ ثْزمَّارمْ أَذْ ثْوقَّارمْ إِربِّيثنْ نّغْنِي، وَارْ ذ أَسنْ تَّاضَارمْ، وَارْ ذ أَسنْعبّْذمْ ؤُ وَارْ ذ أَسنْ تَّاوْيمْ ثَاغَارْصْثْ. \x ◘ \xo 17:‏35 \xt ڒقض. 6‏:‏10\x*  
\v 36 مَاشَا إِتّْخصَّا أَذْ ثڭّْوْذمْ سِيذِي، ونِّي كنِّيوْ د-إِسُّوفّْغنْ زِي مِيصْرَا س جّْهذْ أَمقّْرَانْ ؤُ س ؤُغِيڒْ إِسّْوِيژّْضنْ، ؤُ أَذْ أَسْ ثْسجْذمْ ؤُ أَذْ أَسْ ثَاوْيمْ ثَاغَارْصْثْ.  
\v 37 أَذْ ثحْضَامْ ثِيوصَّا ذ لْفَارَايِيضْ ذ شَّارِيعَا ذ ڒُومُورْ نِّي ذ أَومْ يُورَا، مَاحنْذْ أَذْ ثنْ ثڭّمْ كُوڒْ أَسّْ. وَارْ إِحدْجڒْ أَذْ ثڭّْوْذمْ إِربِّيثنْ نّغْنِي.  
\v 38 وَارْ ثتّتُّومْ ڒْعَاهْذْ إِ ڭِّيغْ أَكِيذْومْ ؤُ وَارْ ثتّْوقَّارمْ إِ إِربِّيثنْ نّغْنِي،  
\v 39 مَاغَارْ أَذْ ثڭّْوذمْ سِيذِي، أَربِّي نْومْ. نتَّا أَذْ كنِّيوْ إِسّنْجمْ زڭْ ؤُفُوسْ ن مَارَّا ڒْعذْيَانْ نْومْ.“   
\m
\v 40 \add مَاشَا\add* نِيثْنِي وَارْ خْسنْ أَذْ سْڒنْ، مَاشَا ڭِّينْ عْلَاحْسَابْ ثُوبَّارْثْ نْسنْ ن زِيشْ.  
\v 41 ڒڭْنُوسْ ڭّْوذنْ سِيذِي ؤُ سخَّارنْ ؤُڒَا إِ ڒخْيَاڒَاثْ نْسنْ إِنقْشنْ ذڭْ ؤُمُورْ ذ إِجّنْ. ؤُڒَا ذ إِحنْجِيرنْ نْسنْ ذ إِحنْجِيرنْ ن إِحنْجِيرنْ نْسنْ تّڭّنْ \add عَاذْ\add* أَمْ مَامّشْ ڭِّينْ ڒجْذُوذْ نْسنْ، أَڒْ أَسّْ-أَ.   
\b  
\b  
\m  
\c 18
\s1 حِيزْقِييَا ذ أَجدْجِيذْ خْ يَاهُوذَا  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا ن هُوشِيعَا، مِّيسْ ن إِلَا، أَجدْجِيذْ ن إِسْرَائِيل، إِمْسَارْ بلِّي حِيزْقِييَا إِذْوڒْ ذ أَجدْجِيذْ. \add نتَّا ثُوغَا\add* ذ مِّيسْ ن أَحَازْ، أَجدْجِيذْ ن يَاهُوذَا. \x ◘ \xo 18:‏1 \xt [2 إِم. 29‏:‏1‏-‏2؛ 31‏:‏1] — 2 إِم. 28‏:‏27؛ 29‏:‏1\x*  
\v 2 نتَّا ثُوغَا غَارسْ خمْسَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ ثسْعَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ أَبِي، يدْجِيسْ ن زَاكَارِييَّا.  
\v 3 نتَّا إِڭَّا مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي، نِيشَانْ أَمْ مَامّشْ ث إِڭَّا بَابَاسْ ذَاوُوذْ.  
\v 4 نتَّا إِكّسْ ڒڭْعُوذِي، يَارْژَا إِمَايْضُوثنْ \add إِقدّْسنْ\add*، إِهْذمْ ثَاربِّيثْ ن شْوَارْثِي ؤُشَا إِڒْبزْ أَفِيغَارْ ن نّْحَاسْ إِ ثُوغَا إِڭَّا مُوسَا، مِينْزِي أَيْثْ ن إِسْرَائِيل ثُوغَا إِ ذ أَسْ د-يِيوْينْ ثِيوْهِيبِينْ ن ڒبْخُورْ أَڒْ ؤُسَّانْ نِّي. نتَّا إِڒَاغَا أَسْ نَاحُوشْثَانْ. \x ◘ \xo 18:‏4 \xt 2 إِم. 31‏:‏1\x*  
\v 5 نتَّا إِتّْشڒْ خْ سِيذِي، أَربِّي ن إِسْرَائِيل. جَارْ مَارَّا إِجدْجِيذنْ ن يَاهُوذَا إِنِّي د-يُوسِينْ أَوَارْنِي أَسْ نِيغْ \add دَّارنْ\add* قْبڒْ نّسْ، وَارْ ثُوغِي إِدْجِي ؤُڒَا ذ إِجّْ أَمْ نتَّا.  
\v 6 نتَّا ثُوغَا إِضْفَارْ أَبْرِيذْ ن سِيذِي، وَارْ خَاسْ إِحيّذْ شَا زِي ضفَّارْ نّسْ. نتَّا ثُوغَا إِحطَّا ڒُومُورَاثْ نّسْ نِّي ثُوغَا يُومُورْ سِيذِي إِ مُوسَا.  
\v 7 سِيذِي ثُوغَا أَكِيذسْ. مَانِي مَا ثُوغَا إِتّْرَاحْ، ثُوغَا إِفْڒحْ. نتَّا إِغوّغْ خْ ؤُجدْجِيذْ ن أَشُّورْ ؤُ وَارْ خَاسْ إِسخَّارْ \add عَاذْ\add*.  
\v 8 نتَّا إِغْڒبْ خْ إِفِيلِيسْطِينِييّنْ أَڒْ غَازَّا أَكْ-ذ جّْوَايهْ نّسْ، زِي لْبُورْجْ ن إِعسَّاسنْ أَڒْ ثَانْذِينْثْ إِفَارْينْ. \x ◘ \xo 18:‏8 \xt إِشا. 14‏:‏30\x*   
\m
\v 9 ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعَا ن ؤُجدْجِيذْ حِيزْقِييَا، ذ أَسڭّْوَاسْ وِيسّْ سبْعَا ن هُوشِيعَا، مِّيسْ ن إِلَا، أَجدْجِيذْ ن إِسْرَائِيل، إِمْسَارْ بلِّي شَالْمَانَاسَّارْ، أَجدْجِيذْ ن أَشُّورْ، إِڭعّذْ ضِيدّْ إِ سَامَارْيَا ؤُشَا إِطّفْ إِ-ت. \x ◘ \xo 18:‏9 \xt 2 إِج. 17‏:‏3\x*  
\v 10 نِيثْنِي طّْفنْ ت أَوَارْنِي إِ ثْڒَاثَا ن إِسڭّْوُوسَا. ذڭْ ؤُسڭّْوَاسْ وِيسّْ ستَّا ن حِيزْقِييَا، أَقَا-ث ذ أَسڭّْوَاسْ وِيسّْ ثسْعَا ن حُوشِيعَا، أَجدْجِيذْ ن إِسْرَائِيل، طّْفنْ نِيثْنِي سَامَارْيَا. \x ◘ \xo 18:‏10 \xt 2 إِج. 17‏:‏6\x*  
\v 11 أَجدْجِيذْ ن أَشُّورْ إِنْذهْ \add أَيْثْ ن\add* إِسْرَائِيل ذِي لْمنْفَا غَارْ أَشُّورْ ؤُشَا يِيوْيِي ثنْ ذِي حَالَاحْ ؤُ غَارْ خابُورْ، ونِّي ذ إِغْزَارْ ن جُوزَانْ، ؤُ \add ذِي\add* ثْندَّامْ ن إِمَاذَاينْ، \x ◘ \xo 18:‏11 \xt 1 إِم. 5‏:‏26\x*  
\v 12 مَاغَارْ نِيثْنِي ثُوغَا وَارْ سْڒِينْ غَارْ مِينْ ذ أَسنْ إِنَّا سِيذِي، أَربِّي نْسنْ، ؤُشَا أَرْژِينْ ڒْعَاهْذْ نّسْ. مَارَّا مِينْ يُومُورْ مُوسَا، أَمْسخَّارْ ن سِيذِي، وَارْ ذ أَسْ سْڒِينْ ؤُ وَارْ ث ڭِّينْ. \f ◼ \fr 18:‏12 \ft \+bd ’غَارْ مِينْ ذ سنْ إِنَّا‘\+bd* - س ثْعِيبْرَانِيثْ ’غَارْ ثْمِيجَّا ن‘.\f*  *   
\b  
\m  
\s1 أَذَافْ ن سَانْحَارِيبْ ذِي ثمُّورْثْ ن يَاهُوذَا  
\m
\v 13 ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَرْبعْطَاشْ ن ؤُجدْجِيذْ حِيزْقِييَا إِفّغْ سَانْحَارِيبْ، أَجدْجِيذْ ن أَسُّورْ، غَارْ مَارَّا ثِيندَّامْ إِفَارْينْ \add س إِغبْرَاونْ\add* ن يَاهُوذَا ؤُشَا إِحوّسْ إِ-ثنْثْ. \x ◘ \xo 18:‏13 \xt [2 إِم. 32‏:‏1‏-‏9؛ إِشا. 36‏:‏1‏-‏22] — 2 إِم. 32‏:‏1؛ إِشا. 36‏:‏1\x*  
\v 14 حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، إِسّكّْ \add إِرقَّاسنْ\add* غَارْ ؤُجدْجِيذْ ن أَشُّورْ، غَارْ لَاخِيشْ، إِنَّا: ”نشّْ خْضِيغْ! بعّذْ خَافِي! مَارَّا مِينْ خَافِي غَا ثڭّذْ، أَذْ ث خدْجْصغْ.“ \add خنِّي\add* إِڭَّا ؤُجدْجِيذْ ن أَشُّورْ إِشْثْ ن لْجِيزْيَا خْ حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا: ثڒْثْ مْيَا ثَالِينْثْ ن نُّوقَارْثْ ذ ثْڒَاثِينْ ثَالِينْثْ ن وُورغْ.  
\v 15 حِيزْقِييَا إِوْشَا مَارَّا نُّوقَارْثْ نِّي إِتّْوَافنْ ذِي ثَادَّارْثْ ن سِيذِي ؤُ ذڭْ إِخَّامنْ ن ثْخُوبَايْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ.  
\v 16 ذِي ڒْوقْثْ نِّي إِقسّْ حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، \add مَارَّا وُورغْ ن\add* ثوُّورَا ن زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي ؤُ ن ڒضْرُوفْ غَارْ ؤُغزْذِيسْ ن ثوَّارْثْ إِنِّي ثُوغَا إِغدْجفْ حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، \add س وُورغْ\add* ؤُشَا إِوْشَا إِ-ث إِ ؤُجدْجِيذْ ن أَشُّورْ.   
\m
\v 17 \add خنِّي\add* إِسّكّْ أَجدْجِيذْ ن أَشُّورْ لْجِينِيرَالْ أَكْ-ذ ؤُزدْجِيفْ ن إِمْسخَّارنْ إِشنّْعنْ ذ ؤُكُومَانْذَارْ ن ڒْعسْكَارْ أَكْ-ذ إِجّْ ن ڒْعسْكَارْ ذ أَمقّْرَانْ أَطَّاسْ زِي لَاخِيشْ غَارْ ؤُجدْجِيذْ حِيزْقِييَا ذِي ؤُرْشَالِيمْ. نِيثْنِي ڭعّْذنْ، إِوْضنْ غَارْ ؤُرْشَالِيمْ. ؤُشَا \add أَوَارْنِي ڒَامِي\add* ڭعّْذنْ ؤُشَا إِوْضنْ نِيثْنِي، بدّنْ غَارْ ؤُقَاذُوسْ ن وَامَانْ ن ؤُيڒْمَانْ ن سنّجْ، ونِّي \add إِدْجَانْ\add* غَارْ وبْرِيذْ يُوعْڒَانْ غَارْ وحْوِيشْ ن ؤُصبَّانْ.  
\v 18 نِيثْنِي ڒَاغَانْ، \add حِيمَا أَذْ د-يَاسْ\add* ؤُجدْجِيذْ. \add خنِّي\add* ؤُيُورنْ غَارْسنْ أَلْيَاقِيمْ، مِّيسْ ن حِيلْقِييَا، ونِّي إِدْجَانْ خْ ثَادَّارْثْ \add ن ؤُجدْجِيذْ\add*، أَكْ-ذ ؤُمَارِيرْ شِيبْنَا ذ يُووَاخْ، مِّيسْ ن أَسَافْ، أَمَارِيرْ ن ؤُمزْرُويْ.  
\v 19 أَكُومَانْذَارْ ن ڒْعسْكَارْ إِنَّا أَسنْ: ”إِنِيمْ إِ حِيزْقِييَا: ’أَمُّو إِ إِقَّارْ ؤُجدْجِيذْ أَمقّْرَانْ، أَجدْجِيذْ ن أَشُّورْ: مَانْ أَثشْڒِي-يَا إِ خْ ثتّشْڒذْ؟  
\v 20 أَقَا-ث ذ ڒْهَارْذْ ن إِينْشِيشنْ \add وَاهَا\add*، ؤُمِي ثنِّيذْ: أَقَا \add غَارْنغْ\add* شّْوَارْ ذ جّهْذْ إِ ؤُمنْغِي! مَانْ ونْ إِ خْ ثتّشْڒذْ، أَقَا شكْ ثْغوّْغذْ خَافِي؟  
\v 21 خْزَارْ، ڒخُّو ثتّشْڒذْ خْ مِيصْرَا، خْ ؤُغَانِيمْ نِّي إِنّْضفْسنْ، ونِّي، ؤُمِي حذْ خَاسْ إِ غَا إِعمّذْ، إِتّجُّونْ ذڭْ ؤُفُوسْ نّسْ ؤُشَا إِسّْنُوقّبْ إِ-ث. أَمُّو \add إِ يدْجَا\add* فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا، إِ مَارَّا إِنِّي خَاسْ إِتّشْڒنْ. \x ◘ \xo 18:‏21 \xt إِشا. 36‏:‏6؛ حِز. 29‏:‏6، 7\x*  
\v 22 مَاڒَا كنِّيوْ أَذْ ذ أَيِي ثِينِيمْ: ’نشِّينْ نتّْشڒْ خْ سِيذِي، أَربِّي نّغْ!‘ \add خنِّي نشّْ أَذْ إِنِيغْ\add*: ’مَا نتَّا وَارْ إِدْجِي ذ ونِّي إِ زِي إِحيّذْ حِيزْقِييَا ڒڭْعُوذِي ذ إِعَالْطَارنْ، ؤُ \add خنِّي\add* إِنَّا إِ يَاهُوذَا ذ ؤُرْشَالِيمْ: إِتّْخصَّا أَذْ ثْبنْذْقمْ زَّاثْ إِ ؤُعَالْطَارْ-أَ ذِي ؤُرْشَالِيمْ؟‘  
\v 23 خنِّي ڒخُّو، أڭّْ إِجّْ ن ؤُمْحَارّمْ أَكْ-ذ سِيذِي إِنُو، أَجدْجِيذْ ن أَشُّورْ، نشّْ أَذْ أَشْ وْشغْ أَڒْفَاينْ ن إِيْسَانْ مَاڒَا شكْ زڭْ ؤُغزْذِيسْ نّشْ أَذْ أَسنْ د-ثَاوْيذْ أَيْثْ ن بُو-ؤُيِيسْ.  
\v 24 مَامّشْ ثخْسذْ أَذْ ثنّْقڒْبذْ خْ وُوذمْ ن لْوَالِي، ونِّي قَاعْ ذ أَمژْيَانْ ن إِمْسخَّارنْ ن سِيذِي إِنُو، ؤُشَا أَذْ ثتّشْڒذْ خْ مِيصْرَا ذِي سِّيبّثْ ن إِكَارُّوثنْ ذ إِمْنَاينْ؟  
\v 25 عَاوذْ، مَاغَارْ مَا نشّْ ڭعّْذغْ-د ضِيدّْ ن ومْشَانْ-أَ، حِيمَا أَذْ ث أَردّْدْجغْ بْڒَا سِيذِي؟ سِيذِي إِنِي أَيِي: ’ڭعّذْ ضِيدّْ إِ ثمُّورْثْ-أَ، أَردّدْجْ إِ-ت!‘ “   
\m
\v 26 ؤُشَا نَّانْ أَلْيَاقِيمْ، مِّيسْ ن حِيلْقِييَا ذ شِيبْنَا ذ يُووَاخْ إِ ؤُكُومَانْذَارْ ن ڒْعسْكَارْ: ”سِيوڒْ عَافكْ س \add إِڒسْ ن\add* ثْرَامِيثْ أَكْ-ذ إِمْسخَّارنْ نّشْ، مِينْزِي نفْهمْ أَسْ مْلِيحْ. وَارْ كِيذْنغْ سِّيوِيڒْ س ثْيَاهُوذشْثْ ذڭْ إِمزُّوغنْ ن ڒْڭنْسْ \add إِ إِدْجَانْ\add* خْ ڒْحِيضْ.“  
\v 27 \add مَاشَا\add* أَكُومَانْذَارْ ن ڒْعسْكَارْ إِنَّا أَسنْ: ”مَا إِسّكّْ أَيِي-د سِيذِي إِنُو حِيمَا أَذْ سِّيوْڒغْ أَوَاڒنْ-أَ غَارْ سِيذِي نّشْ ؤُ غَاركْ \add وَاهَا\add*، وَارْ إِدْجِي إِ يرْيَازنْ نِّي إِقِّيمنْ خْ ڒْحِيضْ، \add مَاحنْذْ أَذْ إِنِيغْ\add* أَقَا أَثنْ \add جْمِيعْ\add* أَكِيذْومْ أَذْ شّنْ أَسُوفّغْ نْسنْ ؤُ أَذْ سْونْ إِبشِّيشنْ نْسنْ؟“  
\v 28 خنِّي إِكَّارْ ؤُكُومَانْذَارْ، إِڒَاغَا س جّْهذْ س ثْيَاهُوذشْثْ ؤُشَا إِسِّيوڒْ، إِنَّا: ”سْڒمْ إِ وَاوَاڒْ ن ؤُجدْجِيذْ أَمقّْرَانْ، أَجدْجِيذْ ن أَشُّورْ!  
\v 29 أَمُّو إِ إِقَّارْ ؤُجدْجِيذْ: ’حْضَامْ وَارْ كنِّيوْ إِتّْغشِّي حِيزْقِييَا، مِينْزِي نتَّا وَارْ إِزمَّارْ أَذْ كنِّيوْ إِفكّْ زڭْ ؤُفُوسْ نّسْ.  
\v 30 وَارْ تّجِّيمْ حِيزْقِييَا أَذْ كنِّيوْ يَارّْ أَذْ ثتّشْڒمْ خْ سِيذِي، أَذْ ثِينِيمْ: سِيذِي أَذْ أَنغْ إِفكّْ نِيشَانْ ؤُ ثَانْذِينْثْ-أَ وَارْ ثتّْموْشِي شَا ذڭْ إِفَاسّنْ ن ؤُجدْجِيذْ ن أَشُّورْ.‘  
\v 31 وَارْ ثسْڒِيمْ شَا غَارْ حِيزْقِييَا، مَاغَارْ أَمُّو إِ إِقَّارْ ؤُجدْجِيذْ ن أَشُّورْ: ’ڭّمْ أَيِي أَرَّايْ ؤُشَا فّْغمْ-د \add زِي ثنْذِينْثْ\add* غَارِي، \add خنِّي\add* إِزمَّارْ كُوڒْ إِجّنْ زَّايْومْ أَذْ إِشّْ زِي ثْزَايَارْثْ نّسْ ؤُ زڭْ وَارْثُو ن ثَازَارْثْ نّسْ ؤُ أَذْ إِسُو أَمَانْ زڭْ وَانُو نّسْ،  
\v 32 أَڒْ د غَا يَاسغْ ؤُ أَذْ كنِّيوْ أَوْيغْ غَارْ إِشْثْ ن ثمُّورْثْ أَمْ ثمُّورْثْ نْومْ: غَارْ إِشْثْ ن ثمُّورْثْ ثشُّورْ س إِمنْذِي ذ بِينُو ن جْذِيذْ، غَارْ إِشْثْ ن ثمُّورْثْ ثشُّورْ س وغْرُومْ ذ إِمَارْجَاعنْ ن ؤُضِيڒْ، إِشْثْ ن ثمُّورْثْ ن زِّيثُونْ ذ زّشْثْ ذ ثَامّنْثْ. أَمُّو إِ غَا ثقِّيممْ ثدَّارمْ، وَارْ ثْمتِّيمْ شَا. وَارْ تّسْڒِيمْ غَارْ حِيزْقِييَا، مَاغَارْ نتَّا إِتّْغَارَّا كنِّيوْ خْمِي إِقَّارْ: سِيذِي أَذْ أَنغْ إِفكّْ!  
\v 33 مَا زمَّارنْ \add خنِّي\add* إِربِّيثنْ ن ڒڭْنُوسْ، كُوڒْ إِجّْ \add زَّايْسنْ\add*، أَذْ فكّنْ ثَامُّورْثْ نْسنْ زڭْ ؤُفُوسْ ن ؤُجدْجِيذْ ن أَشُّورْ؟  
\v 34 مَانِي دْجَانْ إِربِّيثنْ ن حَامَاثْ ذ أَرْفَاذْ؟ مَانِي دْجَانْ إِربِّيثنْ ن سْفَارْوَايِيمْ ذ هَانِيعْ ذ عِيوَا؟ مَا فكّنْ نِيثْنِي سَامَارْيَا زڭْ ؤُفُوسْ إِنُو؟  
\v 35 مَانْ ونْ زِي مَارَّا إِربِّيثنْ ن ثمُّورَا \add نّغْنِي\add* إِ إِسّْنجْمنْ ثَامُّورْثْ نْسنْ زڭْ ؤُفُوسْ إِنُو أَڒَامِي غَا إِفكّْ سِيذِي ؤُرْشَالِيمْ زڭْ ؤُفُوسْ إِنُو؟‘ “   
\m
\v 36 \add مَاشَا\add* ڒْڭنْسْ إِسغْذْ، وَارْ خَاسْ د-يَارِّي س ؤُڒَا ذ إِجّْ ن وَاوَاڒْ، مَاغَارْ ڒُومُورْ ن ؤُجدْجِيذْ إِنَّا: ”كنِّيوْ وَارْ خَاسْ د-ثَارِّيمْ شَا!“  
\v 37 \add خنِّي\add* يُوسَا-د أَلْيَاقِيمْ، مِّيسْ ن حِيلْقِييَا، ڒمْقدّمْ ن ثْزذِّيغْثْ \add ن ؤُجدْجِيذْ\add*، أَكْ-ذ شِيبْنَا أَمَارِيرْ، ذ يُووَاخْ، مِّيسْ ن أَسَافْ، أَمَارِيرْ ن ؤُمزْرُويْ س وَارُّوضْ إِشَارّْڭنْ غَارْ حِيزْقِييَا. نِيثْنِي حَاجَانْ أَسْ مَارَّا أَوَاڒنْ ن ؤُكُومَانْذَارْ ن ڒْعسْكَارْ.   
\b  
\b  
\m  
\c 19
\s1 أَوَاڒْ أَمزْوَارُو خْ ؤُفكِّي ن ؤُرْشَالِيمْ  
\m
\v 1 ؤُمِي ثنْ إِسْڒَا ؤُجدْجِيذْ حِيزْقِييَا، إِشَارّڭْ أَرُّوضْ نّسْ، إِذْڒَا إِخفْ نّسْ س إِشْثْ ن ثْخَانْشثْ \add ن وشْضَانْ\add* ؤُشَا يُوذفْ غَارْ ثَادَّارْثْ ن سِيذِي. \f ◼ \fr 19:‏1 \ft \+bd ’ؤُمِي إِسْڒَا‘\+bd* - س ثْعِيبْرَانِيثْ ’إِمْسَارْ ؤُمِي إِسْڒَا ...‘\f*  \x ◘ \xo 19:‏1 \xt [2 إِم. 32‏:‏20‏-‏21؛ إِشا. 37‏:‏1‏-‏38]\x*  
\v 2 \add خنِّي\add* إِسّكّْ نتَّا أَلْيَاقِيمْ، ڒمْقدّمْ ن ثْزذِّيغْثْ \add ن ؤُجدْجِيذْ\add*، ذ شَابْنَا، أَمَارِيرْ، ذ إِمْغَارنْ ن إِكهَّاننْ ذڭْ وَارُّوضْ ن ثْخُونْشَايْ \add ن وشْضَانْ\add* غَارْ ؤُنَابِي إِشَاعْيَا، مِّيسْ ن أَمُوصْ. \x ◘ \xo 19:‏2 \xt إِشا. 1‏:‏1\x*  
\v 3 نِيثْنِي نَّانْ أَسْ: ”أَمُّو إِ إِقَّارْ حِيزْقِييَا: ’أَسّْ-أَ ذ إِجّْ ن وَاسّْ ن ڒحْصَارثْ ؤُ ن وعْقَابْ ؤُ ن ؤُبهْذڒْ، مَاغَارْ إِحنْجِيرنْ إِوْضنْ-د أَڒْ أَرْزَامْ ن ؤُعذِّيسْ \add ن يمَّاثْسنْ\add*، \add مَاشَا\add* وَارْ ذِينْ جّهْذْ إِ ثْوَارُوثْ. \x ◘ \xo 19:‏3 \xt إِشا. 37‏:‏3\x*  
\v 4 أَذْ ثَاغْ سِيذِي، أَربِّي نّشْ، إِسْڒَا مَارَّا أَوَاڒنْ ن ؤُكُومَانْذَارْ ن ڒْعسْكَارْ ونِّي إِتّْوَاسّكّنْ زِي سِيذِيسْ نّسْ، أَجدْجِيذْ ن أَشُّورْ، حِيمَا أَذْ إِسْثهْزَا زِي أَربِّي إِدَّارنْ، ؤُ \add أَذْ ثَاغْ\add* سِيذِي، أَربِّي نّشْ، أَذْ إِعَاقبْ أَوَاڒنْ إِ إِسْڒَا. سْڭعّذْ \add خنِّي\add* إِشْثْ ن ثْژَادْجِيثْ ذِي طّْوعْ ن ڒْبَاقِي نِّي إِ غَا إِتّْوَافنْ \add عَاذْ\add*.‘ “   
\m
\v 5 \add أَمُّو\add* إِوْضنْ إِمْسخَّارنْ ن ؤُجدْجِيذْ حِيزْقِييَا غَارْ إِشَاعْيَا.  
\v 6 إِنَّا أَسنْ إِشَاعْيَا: ”أَمُّو إِ إِتّْخصَّا أَذْ ثِينِيمْ إِ سِيذِيثْومْ: ’أَمُّو إِ إِقَّارْ سِيذِي: وَارْ ثڭّْوذْ شَا زڭْ وَاوَاڒنْ إِ ثسْڒِيذْ شكْ، إِ زِي إِ ذ أَيِي شقّْفنْ إِمْسخَّارنْ ن ؤُجدْجِيذْ ن أَشُّورْ.  
\v 7 خْزَارْ، نشّْ أَذْ ذَايسْ ڭّغْ إِجّْ ن بُوحْبڒْ ؤُ نتَّا أَذْ إِسڒْ إِ يِيجّْ ن ڒخْبَارْ ؤُ أَذْ إِعْقبْ غَارْ ثمُّورْثْ نّسْ ؤُ نشّْ أَذْ ث نْغغْ \add ذِينْ\add* ذِي ثمُّورْثْ نّسْ س سِّيفْ.‘ “   
\b  
\m
\v 8 \add خنِّي\add* إِعْقبْ-د ؤُكُومَانْذَارْ ن ڒْعسْكَارْ ؤُشَا يُوفَا أَجدْجِيذْ ن أَشُّورْ إِتّْمنْغَا أَكْ-ذ \add ثنْذِينْثْ ن\add* لِيبْنَا، مَاغَارْ إِسْڒَا أَقَا إِقْڒعْ إِقِيضَانْ نّسْ \add إِفّغْ\add* زِي لَاخِيشْ.  
\v 9 \add ؤُمِي\add* إِسْڒَا أَقَا نَّانْ خْ ثِيرْهَاقَا، أَجدْجِيذْ ن كُوشْ: ”خْزَارْ، إِفّغْ-د، حِيمَا أَكِيذكْ إِمّْنغْ!“، إِسّكّْ \add عَاوذْ\add* إِرقَّاسنْ غَارْ حِيزْقِييَا، إِنَّا:  
\v 10 ”أَمُّو إِ غَا ثسِّيوْڒمْ أَكْ-ذ حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، أَذْ ثِينِيمْ: ’وَارْ تّجِّي أَذْ شكْ إِغْوَا أَربِّي نّشْ ونِّي خْ ثتّشْڒذْ أَمْ إِقَّارْ: ؤُرْشَالِيمْ وَارْ ثتّْوطِّي إِ ؤُجدْجِيذْ ن أَشُّورْ ذڭْ إِفَاسّنْ!  
\v 11 خْزَارْ، ثسْڒِيذْ مِينْ ڭِّينْ إِجدْجِيذنْ ن أَشُّورْ أَكْ-ذ مَارَّا ثِيمُّورَا نّغْنِيثْ، ثِينِّي ثُوغَا أَذْ تّْوَاردّْدْجنْثْ. مَا إِتّْغِيڒْ أَشْ أَذْ ثتّْوَافكّذْ؟  
\v 12 مَا فكّنْ ثنْ إِربِّيثنْ ن ڒڭْنُوسْ إِنِّي يَاردّْدْجنْ ڒجْذُوذْ إِنُو؟ جُوزَانْ ذ حَارَانْ ذ رْصِيفْ ذ أَيْثْ ن عَاذَانْ، إِنِّي \add ثُوغَا إِزدّْغنْ\add* ذِي ثَالَاسَّارْ؟  
\v 13 مَانِي إِدْجَا ؤُجدْجِيذْ ن حَامَاثْ ذ ؤُجدْجِيذْ ن أَرْفَاذْ ذ ؤُجدْجِيذْ ن ثنْذِينْثْ ن سْفَارْوَايِيمْ ؤُڒَا ذ \add أَجدْجِيذْ ن\add* هَانَاعْ ذ عِيوَّا؟‘ “   
\b  
\m  
\s1 ثَاژَادْجِيثْ ن حِيزْقِييَا ذ ؤُفكِّي ن ؤُرْشَالِيمْ  
\m
\v 14 حِيزْقِييَا إِكْسِي ثِيبْرَاثِينْ زڭْ ؤُفُوسْ ن إِمْسخَّارنْ ؤُشَا إِغْرَا إِ-ثنْثْ. \add خنِّي\add* إِڭعّذْ غَارْ ثَادَّارْثْ ن سِيذِي ؤُشَا إِبزّعْ إِ-ثنْثْ حِيزْقِييَا زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 15 ؤُشَا إِژُّودْجْ حِيزْقِييَا زَّاثْ إِ وُوذمْ ن سِيذِي، إِنَّا: ”\add أَ\add* سِيذِي، أَربِّي ن إِسْرَائِيل، ونِّي إِتّْغِيمَانْ \add جَارْ\add* إِكِيرُوبنْ! شكْ، \add وَاهْ\add* شكْ وحّْذكْ ذ أَربِّي ن مَارَّا ثِيڭلْذِيوِينْ ن دُّونشْثْ. شكْ ثڭِّيذْ إِجنْوَانْ ذ ثمُّورْثْ. \f ◼ \fr 19:‏15 \ft \+bd ’إِكِيرُوبنْ‘\+bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*  
\v 16 \add أَ\add* سِيذِي، أوْشْ أَمزُّوغْ نّشْ، سڒْ! \add أَ\add* سِيذِي، أَرْزمْ ثِيطَّاوِينْ نّشْ، خْزَارْ! سڒْ إِ وَاوَاڒنْ ن سَانْحَارِيبْ نِّي د-إِسّكّْ، حِيمَا أَذْ إِسْثهْزَا زِي أَربِّي إِدَّارنْ.  
\v 17 ذ ثِيذتّْ، \add أَ\add* سِيذِي، إِجدْجِيذنْ ن أَشُّورْ قْضَانْ ڒڭْنُوسْ نِّي، خَارّْبنْ ثمُّورْثْ نْسنْ،  
\v 18 ؤُ نْضَارنْ إِربِّيثنْ نْسنْ ذِي ثْمسِّي، مَاغَارْ ثُوغَا وَارْ دْجِينْ ذ إِربِّيثنْ، مَاشَا ذ ثِيمڭَّا ن ؤُفُوسْ ن يوْذَانْ وَاهَا، زڭْ ؤُكشُّوضْ ذ وژْرُو، ؤُشَا نِيثْنِي مْحَانْ ثنْ.  
\v 19 \add مَاشَا\add* ڒخُّو، \add أَ\add* سِيذِي، أَربِّي نّغْ، سنْجمْ أَنغْ زڭْ ؤُفُوسْ نّسْ، مَاحنْذْ مَارَّا ثِيڭلْذِيوِينْ ن دُّونشْثْ أَذْ سّْننْ، \add أَ\add* سِيذِي، أَقَا شكْ وحّْذكْ ذ أَربِّي.“   
\b  
\m
\v 20 \add خنِّي\add* إِسكّْ إِشَاعْيَا، مِّيسْ ن أَمُوصْ، \add إِجّْ ن ؤُرقَّاسْ\add* غَارْ حِيزْقِييَا، إِنَّا: ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’نشّْ سْڒِيغْ س مِينْزِي غَارِي ثژُّودْجذْ خْ سَانْحَارِيبْ، أَجدْجِيذْ ن أَشُّورْ.  
\v 21 وَا ذ أَوَاڒْ إِ خَاسْ إِسِّيوڒْ سِيذِي: ’ثَاعْزَارشْثْ، يدْجِيسْ ن صِيهْيُونْ، ثسّحْقَارْ إِ شكْ، ثسْثهْزَا زَّايكْ، يدْجِيسْ ن ؤُرْشَالِيمْ ثْهزَّا أَزدْجِيفْ أَوَارْنِي أَشْ!  
\v 22 وِي زِي ثسْثهْزِيذْ ؤُ وِي ذِي ثْشقّْفذْ؟ وِي خفْ ثسّْڭعّْذذْ ثْمِيجَّا \add نّشْ\add*، ؤُ مِيخفْ ثسّْڭعّْذذْ س نّْفَاخثْ ثِيطَّاوِينْ نّشْ؟ \add شكْ ثتّْغنَّانذْ\add* خْ ؤُمْقدَّاسْ ن إِسْرَائِيل!  
\v 23 س ؤُقمُّومْ ن إِمْسخَّارنْ نّشْ ثسْثهْزِيذْ سِيذِي إِنُو، ثنِّيذْ: س ؤُبَارُّو ن إِكَارُّوثنْ إِنُو ڭعّْذغْ إِذُورَارْ يُوعْڒَانْ، إِغزْذِيسنْ ن لُوبْنَانْ. نشّْ أَذْ زذْمغْ ثِيشجُّورَا نّسْ ن ثنْڭلْثْ يُوعْڒَانْ ؤُڒَا ذ ڒمْخيّرْ ن سِّيبْرِي نّسْ ؤُ نشّْ أَذْ د-أَذْفغْ غَارْ ومْشَانْ نّسْ ن وَاريّحْ إِ إِڭّْوجنْ أَطَّاسْ، غَارْ وزْغَارْ ن ؤُمَارْجعْ نّسْ ن ؤُضِيڒْ إِصبْحنْ. \f ◼ \fr 19:‏23 \ft \+bd ’س ؤُقمُّومْ‘\+bd* - س ثْعِيبْرَانِيثْ ’س ؤُفُوسْ‘. \+bd ’أَمرْزِي‘\+bd* - نِيغْ ’أَمضْزِي‘.\f*  
\v 24 نشّْ غْزِيغْ \add أَنُوثنْ\add*، سْوِيغْ أَمَانْ. س ثَاڒقَّا ن إِضَارنْ إِنُو سِّيژْغغْ مَارَّا إِغزْرَانْ ن مِيصْرَا.  
\v 25 مَا وَارْ ثسْڒِيذْ أَقَا \add أَطَّاسْ\add* زڭْ وَامِي ڭِّيغْ مَانْ أَيَا، ؤُشَا وْشِيغْ أَسْ ؤُذمْ ذڭْ وُوسَّانْ ن مشْحَاڒْ ؤُيَا؟ ڒخُّو جِّيغْ ث أَذْ د-إِفّغْ، أَقَا شكْ ذ ونِّي إِ غَا يَارّنْ ثِيندَّامْ إِفَارْينْ ذ ڒْخِيرْبَاثْ.  
\v 26 إِمزْذَاغْ نْسنْ ثُوغَا أَثنْ أَرْخُونْ، أَرْژِينْ ؤُ سضْحَانْ. نِيثْنِي ثُوغَا أَثنْ أَمْ وفْسُو ذڭْ إِيَّارْ، \add أَمْ\add* ؤُغمُّويْ أَزِيزَا، \add أَمْ\add* ؤُڒُومْ خْ ثْزغْوِينْ، ؤُ \add أَمْ\add* \add إِمنْذِي\add* إِشمْضنْ \add س ؤُسمِّيضْ\add* قْبڒْ مَا أَذْ إِفّغْ.  
\v 27 \add مَاشَا\add* نشّْ سّْنغْ أَغِيمِي نّشْ ذ ؤُفُّوغْ نّشْ ذ وعْقَابْ نّشْ ذ ؤُغوّغْ نّشْ خَافِي.  
\v 28 مِينْزِي شكْ ثْغوّْغذْ خَافِي ؤُ ثُوفّثْ نّشْ ثِيوضْ غَارْ إِمزُّوغنْ إِنُو، أَذْ أَشْ سّكّغْ ثَاسنَّارْثْ ذڭْ ونْزَارنْ نّشْ ؤُ \add أَذْ ڭّغْ\add* سْڒِيمثْ جَارْ إِينْشِيشنْ نّشْ، ؤُ نشّْ أَذْ شكْ أَرّغْ خْ وبْرِيذْ إِ ذِي د-ثُوسِيذْ ذَا.‘   
\m
\v 29 ذ ثَا أَذْ أَشْ ثِيڒِي ذ ڒعْڒَامثْ: ذڭْ ؤُسڭّْوَاسْ-أَ أَذْ ثشّمْ مِينْ غَا إِغمّْينْ س يِيخفْ نّسْ ؤُ ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ مِينْ زَّايسْ غَا إِغمّْينْ عَاوذْ، مَاشَا ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا أَذْ ثْزَارْعمْ ؤُ أَذْ ثمْجَارمْ، أَذْ ثڭّمْ إِمَارْجَاعنْ ن ؤُضِيڒْ، أَذْ ذَايْسنْ ثژُّومْ ثْزَايَارِينْ ؤُشَا أَذْ ثشّمْ ڒْغِيدْجثْ نّسْ.  
\v 30 مَاغَارْ مِينْ إِنّجْمنْ، مِينْ إِقِّيمنْ زِي ثَادَّارْثْ ن يَاهُوذَا، أَذْ إِوّثْ عَاوذْ إِژوْرَانْ غَارْ سْوَادَّايْ ؤُ سنّجْ أَذْ يَاوِي ڒْغِيدْجثْ.  
\v 31 مَاغَارْ زِي ؤُرْشَالِيمْ أَذْ د-إِفّغْ مِينْ إِقِّيمنْ ؤُ زڭْ وذْرَارْ ن صِيهْيُونْ أَذْ إِفّغْ مِينْ إِنّجْمنْ، أَسَامْ ن سِيذِي \add ن ڒْعسْكَارَاثْ إِجهْذنْ\add* أَذْ إِڭّْ أَيَا.   
\m
\v 32 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي خْ ؤُجدْجِيذْ ن أَشُّورْ: نتَّا وَارْ د-إِتِّيذفْ شَا ذِي ثنْذِينْثْ-أَ ؤُ وَارْ ذَايسْ إِشِّيثْ شَا ؤُڒَا ذ إِشْثْ ن فْڒِيثْشَا، وَارْ غَارسْ-د إِقَارّبْ شَا س إِشْثْ ن ثْسدَّارْثْ \add ن ؤُعسْكَارِي\add* ؤُ وَارْ خَاسْ تّْبقِّيضنْ إِجّْ ن لْبَارَاجْ إِ ڒحْصَارثْ.  
\v 33 خْ وبْرِيذْ إِ خْ د غَا يَاسْ، أَذْ د-إِعْقبْ. وَارْ إِتِّيذِيفْ شَا غَارْ ثنْذِينْثْ-أَ، إِقَّارْ سِيذِي.  
\v 34 نشّْ أَذْ سّڒْقِيغْ خْ ثنْذِينْثْ-أَ، حِيمَا أَذْ ت سّْنجْمغْ ذِي طّْوعْ إِنُو ؤُ ذِي طّْوعْ ن ؤُمْسخَّارْ إِنُو ذَاوُوذْ.‘ “ \x ◘ \xo 19:‏34 \xt 2 إِج. 20‏:‏6\x*   
\b  
\m
\v 35 ذِي دْجِيڒثْ نِّي، إِمْسَارْ، أَقَا إِفّغْ لْمَالَاكْ ن سِيذِي، إِنْغَا مْيَا ؤُ-خمْسَا ؤُ-ثْمنْيِينْ-أَڒفْ \add ن يرْيَازنْ\add* ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ ن أَشُّورْ. ؤُمِي إِ د كَّارنْ نِيثْنِي ثِيوشَّا نّسْ، خْزَارْ، أَقَا أَثنْ مَارَّا إِذْسنْ ذ ڒْخشْبَاثْ. \x ◘ \xo 19:‏35 \xt إِشا. 37‏:‏36\x*  
\v 36 ؤُشَا سَانْحَارِيبْ، أَجدْجِيذْ ن أَشُّورْ، يَارْژَا إِقِيضَانْ نّسْ، إِرُوحْ ؤُشَا إِعْقبْ \add غَارْ ثمُّورْثْ نّسْ\add*. نتَّا إِقِّيمْ إِزدّغْ ذِي نِينْوَا.  
\v 37 ؤُمِي إِسْجذْ \add إِجّْ ن وَاسّْ\add* ذِي ثَادَّارْثْ ن أَربِّي نّسْ نِيسْرُوخْ، إِمْسَارْ، أَقَا \add إِحنْجِيرنْ نّسْ\add* أَذْرَامِّيلِيكْ ذ شَارَاصَارْ نْغِينْ ث س سِّيفْ. نِيثْنِي أَروْڒنْ غَارْ ثمُّورْثْ ن أَرَارَاثْ. مِّيسْ أَسَارْحَادُّونْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. \x ◘ \xo 19:‏37 \xt 2 إِم. 32‏:‏21؛ إِشا. 37‏:‏38\x*   
\b  
\b  
\m  
\c 20
\s1 ڒحْڒَاشْ ن هَازَاقِييَا ذ ؤُسْڭنْفِي نّسْ  
\m
\v 1 ذڭْ وُوسَّانْ نِّي إِحْڒشْ حِيزْقِييَا س إِجّْ ن ڒحْڒَاشْ إِنقّنْ. يُوسَا-د غَارسْ ؤُنَابِي إِشَاعْيَا، مِّيسْ ن أَمُوصْ، إِنَّا أَسْ: ”أَمُّو إِ إِقَّارْ سِيذِي: ’أوْشْ ڒُومُورَاثْ إِ ثَادَّارْثْ نّشْ، مَاغَارْ أَذْ ثمّْثذْ، وَارْ ثتّْغِيمِيذْ ثدَّارذْ \add عَاذْ كْثَارْ\add*.‘ “ \x ◘ \xo 20:‏1 \xt [2 إِم. 32‏:‏24؛ إِشا. 38‏:‏1‏-‏22] — 2 إِم. 32‏:‏24؛ إِشا. 38‏:‏1\x*  
\v 2 \add خنِّي\add* إِنّقْڒبْ س ؤُغمْبُوبْ نّسْ غَارْ ڒْحِيضْ ؤُشَا إِژُودْجْ إِ سِيذِي، إِنَّا:  
\v 3 ”أَ، سِيذِي، عْقڒْ أَقَا نشّْ ؤُيُورغْ زَّاثْ إِ وُوذمْ نّشْ س ڒَامَانْ ؤُ س يِيجّْ ن وُوڒْ إِكمّْڒنْ ؤُ ڭِّيغْ مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ نّشْ.“ ؤُشَا إِبْذَا حِيزْقِييَا إِتّْرُو س جّْهذْ.  
\v 4 ثُوغَا عَاذْ وَارْ إِفِّيغْ إِشَاعْيَا زِي ڒْوسْطْ ن ثنْذِينْثْ، ڒَامِي غَارسْ د-يُوسَا وَاوَاڒْ ن سِيذِي، إِنَّا:  
\v 5 ”عْقبْ، إِنِي إِ حِيزْقِييَا، ڒْحَاكمْ ن ڒْڭنْسْ إِنُو: ’أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن بَابَاشْ ذَاوُوذْ: نشّْ سْڒِيغْ إِ ثْژَادْجِيثْ نّشْ ؤُ ژْرِيغْ إِ إِمطَّاونْ نّشْ. خْزَارْ، أَذْ شكْ سّْڭنْفِيغْ. ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا أَذْ ثْڭعّْذذْ \add عَاوذْ\add* غَارْ ثَادَّارْثْ ن سِيذِي.  
\v 6 نشّْ أَذْ أَرْنِيغْ خمّسْطَاشْ ن إِسڭّْوُوسَا إِ وُوسَّانْ \add ن ثُوذَارْثْ\add* نّشْ ؤُ أَذْ شكْ فكّغْ زڭْ ؤُفُوسْ ن ؤُجدْجِيذْ ن أَشُّورْ، ؤُڒَا ذ ثَانْذِينْثْ. نشّْ أَذْ سّڒْقِيغْ خْ ثنْذِينْثْ-أَ ذِي طّْوعْ إِنُو ؤُ ذِي طّْوعْ ن ؤُمْسخَّارْ إِنُو ذَاوُوذْ.‘ “  
\v 7 \add خَاسْ ؤُشَا\add* إِنَّا إِشَاعْيَا: ”كْسِي إِجّْ ن وغْرُومْ ن ثَازَارْثْ!“ نِيثْنِي إِوْينْ ث-إِ-د، سَّارْسنْ خْ ؤُبُوعْرُوسْ ؤُشَا إِذْوڒْ إِڭّنْفَا.  
\v 8 حِيزْقِييَا \add مَاشَا\add* إِنَّا إِ إِشَاعْيَا: ”مَانْ ڒعْڒَامثْ أَقَا سِيذِي أَذْ أَيِي إِسّْڭنْفَا ؤُ نشّْ أَذْ ڭعّْذغْ غَارْ ثَادَّارْثْ ن سِيذِي ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا؟“  
\v 9 إِنَّا إِشَاعْيَا: ”أَيَا أَذْ أَشْ ثِيڒِي ذ ڒعْڒَامثْ ن سِيذِي، أَقَا سِيذِي أَذْ إِسّقْفڒْ أَوَاڒْ نِّي إِسِّيوڒْ: ’مَا أَذْ ثُويُورْ ثِيڒِيعشْرَا ن ثْرفِّيذِينْ غَارْ زَّاثْ نِيغْ أَذْ د-ثعْقبْعشْرَا ن ثْرفِّيذِينْ غَارْ ضفَّارْ؟‘ “  
\v 10 حِيزْقِييَا إِنَّا: ”إِهْونْ إِ ثِيڒِي، مَاحنْذْ أَذْ ثزُّوڭَّارْعشْرَا ن ثْرفِّيذِينْ، لَّا، أجّْ ثِيڒِي أَذْ ثعْقبْعشْرَا ن ثْرفِّيذِينْ غَارْ ضفَّارْ.“ \f ◼ \fr 20:‏10 \ft \+bd ’حَازَاقِييَا‘\+bd* - نِيشَانْ س ثْعِيبْرَانِيثْ ’يحَازْقِي-يَاهُو‘. إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’سِيذِي إِوْشَا أَيِي جّهْذْ‘.\f*  
\v 11 ؤُشَا إِڒَاغَا ؤُنَابِي إِشَاعْيَا غَارْ سِيذِي ؤُ وَانِيثَا إِجَّا ثِيڒِي أَذْ ثعْقبْ خْ ثْرفِّيذِينْ إِ خْ ثهْوَا خْ دّْرُوجْ ن أَحَازْ:عشْرَا ن ثْرفِّيذِينْ غَارْ ضفَّارْ.   
\b  
\m  
\s1 إِرقَّاسنْ زِي بَابِيلْ  
\m
\v 12 ذِي ڒْوقْثْ نِّي إِسّكّْ بَارَاذُوخْ-بَالَاذَانْ، مِّيسْ ن بَالَاذَانْ، أَجدْجِيذْ ن بَابِيلْ، ثِيبْرَاثِينْ ذ إِشْثْ ن ثَارْزفْثْ غَارْ حِيزْقِييَا، مَاغَارْ نتَّا ثُوغَا إِسْڒَا أَقَا حِيزْقِييَا إِهْڒشْ. \x ◘ \xo 20:‏12 \xt [2 إِم. 32‏:‏31‏-‏33؛ إِشا. 39‏:‏1‏-‏8] \x*  
\v 13 حِيزْقِييَا إِسْڒَا أَسنْ ؤُشَا إِسّْشنْ أَسنْ مَارَّا ثَادَّارْثْ ن ثْخُوبَايْ نّسْ: نُّوقَارْثْ ذ وُورغْ ذ ڒعْطُورْ ذ زّشْثْ ذ ڒهْرِي ن ڒسْنَاحْ نّسْ ذ مَارَّا مِينْ إِتّْوَافنْ ذڭْ إِخَّامنْ نّسْ ن ثْخُوبَايْ. وَارْ إِقِّيمْ وَالُو ذِي ثَادَّارْثْ نّسْ ؤُ ذِي مَارَّا ڒحْكَامثْ نّسْ نِّي وَارْ ثُوغِي ذ أَسنْ ث إِسّْشنْ.   
\m
\v 14 \add خنِّي\add* يُوسَا-د ؤُنَابِي إِشَاعْيَا غَارْ ؤُجدْجِيذْ حِيزْقِييَا، إِنَّا أَسْ: ”مِينْ نَّانْ إِرْيَازنْ نِّي ؤُ مَانِيسْ د-ؤُسِينْ غَاركْ؟“ حِيزْقِييَا إِنَّا: ”نِيثْنِي ؤُسِينْ-د زڭْ إِشْثْ ن ثمُّورْثْ ثِيڭّْوجْ، زِي بَابِيلْ.“  
\v 15 نتَّا إِنَّا: ”مِينْ ژْرِينْ نِيثْنِي ذِي ثَادَّارْثْ نّشْ؟“ حِيزْقِييَا إِنَّا: ”نِيثْنِي ژْرِينْ مَارَّا مِينْ إِدْجَانْ ذِي ثَادَّارْثْ إِنُو. وَارْ إِقِّيمْ شَا زِي مِينْ إِدْجَانْ ذڭْ إِخَّامنْ ن ثْخُوبَايْ إِنُو، وَارْ ذ أَسنْ ث سّشْنغْ.“  
\v 16 \add خنِّي\add* إِنَّا إِشَاعْيَا إِ حِيزْقِييَا: ”سڒْ إِ وَاوَاڒْ ن سِيذِي!  
\v 17 ’أَذْ د-أَسنْ وُوسَّانْ مڒْمِي مَارَّا مِينْ إِدْجَانْ ذِي ثَادَّارْثْ نّشْ ؤُڒَا ذ مِينْ يَارْونْ ڒجْذُوذْ نّشْ أَڒْ أَسّْ-أَ، أَذْ ث أَوْينْ غَارْ بَابِيلْ. وَارْ إِتّْغِيمِي وَالُو، إِقَّارْ سِيذِي.  
\v 18 أَذْ أَوْينْ ؤُڒَا زڭْ إِحنْجِيرنْ نّشْ إِنِّي د غَا إِفّْغنْ زَّايكْ، إِنِّي د غَا ثجّذْ، حِيمَا أَذْ إِڒِينْ ذ إِمْسخَّارنْ إِمْشنّْعنْ ذِي ڒقْصَارْ ن ؤُجدْجِيذْ ن بَابِيلْ.‘ “  
\v 19 حِيزْقِييَا إِنَّا إِ إِشَاعْيَا: ”أَوَاڒْ ن سِيذِي إِ ذ أَيِي ثنِّيذْ إِصْبحْ.“ نتَّا إِنَّا عَاوذْ: ”نِيغْ لَّا، مَاڒَا \add خنِّي\add* ذڭْ وُوسَّانْ إِنُو أَذْ \add ذِينْ\add* يِيڒِي ڒهْنَا ذ ڒَامَانْ!“   
\m
\v 20 إِمزْرُوينْ إِقِّيمنْ ن حِيزْقِييَا ذ مَارَّا ثِيمڭَّا نّسْ إِمحْضنْ ذ مَامّشْ إِڭَّا أَيڒْمَامْ ذ ؤُقَاذُوسْ ن وَامَانْ ؤُ \add مَامّشْ\add* إِنْذهْ أَمَانْ ذِي ثنْذِينْثْ، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا؟ \x ◘ \xo 20:‏20 \xt 2 إِم. 32‏:‏30\x*  
\v 21 حِيزْقِييَا إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. مِّيسْ مَانَاسَّا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\b  
\b  
\m  
\c 21
\s1 مَانَاسِّي، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 1 ثُوغَا غَارْ مَانَاسَّا ثنْعَاشْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ خمْسَا ؤُ-خمْسِينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ هَافْصِي-بَاهْ. \x ◘ \xo 21:‏1 \xt [2 إِم. 33‏:‏1‏-‏9، 20] — 2 إِم. 33‏:‏1\x*  
\v 2 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَمْ مَامّشْ جّْعَايفْ ن ڒڭْنُوسْ نِّي ثُوغَا إِسُّوفّغْ سِيذِي زِي زَّاثْ ن وُوذمْ ن أَيْثْ ن إِسْرَائِيل زِي ڒْوَارْثْ نْسنْ.  
\v 3 نتَّا إِبْذَا أَذْ إِعْذڒْ ڒڭْعُوذِي نِّي ثُوغَا إِهْذمْ بَابَاسْ حِيزْقِييَا. نتَّا إِسّْبدّْ إِعَالْطَارنْ إِ بَاعَالْ ؤُشَا إِڭَّا إِشْثْ ن ثْربِّيثْ ن شْوَارْثِي أَمْ مَامّشْ ثُوغَا \add ت\add* إِڭَّا أَخَابْ، أَجدْجِيذْ ن إِسْرَائِيل، ؤُشَا إِبنْذقْ إِ مَارَّا ڒْعسْكَارْ ن ؤُجنَّا ؤُشَا إِعْبذْ أَسنْ. \x ◘ \xo 21:‏3 \xt 2 إِج. 18‏:‏4\x*  
\v 4 إِسّْبدّْ عَاوذْ إِعَالْطَارنْ ذِي ثَادَّارْثْ ن سِيذِي إِ خْ إِنَّا سِيذِي: ”ذِي ؤُرْشَالِيمْ أَذْ سّْمثْنغْ إِسمْ إِنُو.“ \x ◘ \xo 21:‏4 \xt أَعَوذ. 12‏:‏5، 11؛ 2 صم. 7‏:‏13؛ 1 إِج. 8‏:‏29؛ 9‏:‏3؛ 2 إِم. 7‏:‏12؛ إِزهد. 132‏:‏13، 14؛ إِرْم. 32‏:‏34\x*  
\v 5 نتَّا إِبْنَا إِعَالْطَارنْ إِ مَارَّا ڒْعسْكَارْ ن ؤُجنَّا ذِي ثْنَاينْ ن ڒمْرَاحَاثْ ن ثَادَّارْثْ ن سِيذِي.  
\v 6 نتَّا إِجَّا مِّيسْ أَذْ يكّْ خْ ثْمسِّي ؤُ إِسّْخدَّامْ ثَابزْڭِيوْثْ ؤُ ثُوغَا إِتّْڭزّنْ. نتَّا يِيوِي-د إِنِّي إِسَّاوَاڒنْ أَكْ-ذ إِمتَّانْ، ذ إِڭزَّاننْ. نتَّا إِڭَّا أَطَّاسْ مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، مَاحنْذْ أَذْ ث إِسْعَارْ.  
\v 7 نتَّا إِسّْبدّْ إِجّْ ن ڒخْيَاڒْ إِنقْشنْ ن ثْربِّيثْ ن شْوَارْثِي نِّي ثُوغَا إِڭَّا، ذِي ثَادَّارْثْ نِّي خْ ثُوغَا إِنَّا سِيذِي إِ ذَاوُوذْ، مِّيسْ ن سُولِيمَانْ: ”ذِي ثَادَّارْثْ-أَ ؤُ ذِي ؤُرْشَالِيمْ إِ فَارْزغْ زِي مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل، أَذْ سّْمثْنغْ إِسمْ إِنُو إِ ڒبْذَا. \x ◘ \xo 21:‏7 \xt 2 صم. 7‏:‏10؛ 1 إِج. 8‏:‏16، 29؛ 9‏:‏3؛ 2 إِج. 23‏:‏27\x*  
\v 8 نشّْ وَارْ تّجِّيغْ عَاذْ أَضَارْ ن إِسْرَائِيل أَذْ إِودَّارْ بَارَّا إِ ثمُّورْثْ إِ وْشِيغْ إِ ڒجْذُوذْ نْسنْ. مْغِيرْ إِتّْخصَّا أَسنْ أَذْ حْضَانْ أَذْ ڭّنْ أَمْ مَامّشْ مَارَّا مِينْ ذ أَسنْ ؤُمُورغْ ؤُ أَمْ مَامّشْ مَارَّا شَّارِيعَا إِ ذ أَسنْ يُومُورْ ؤُمْسخَّارْ إِنُو مُوسَا.“  
\v 9 \add مَاشَا\add* نِيثْنِي وَارْ سْڒِينْ شَا، مَاغَارْ مَانَاسَّا يَارَّا إِ-ثنْ أَذْ ودَّارنْ، أَڒَامِي أَرنْينْ ذِي ثُوعّفْنَا مَاهُو ڒڭْنُوسْ نِّي إِمْحَا سِيذِي زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل.  
\v 10 \add خنِّي\add* إِسِّيوڒْ سِيذِي س ؤُقمُّومْ ن إِمْسخَّارنْ نّسْ، إِنَابِييّنْ، إِنَّا: \f ◼ \fr 21:‏10 \ft \+bd ’س ؤُقمُّومْ‘\+bd* - س ثْعِيبْرَانِيثْ ’س ؤُفُوسْ‘.\f*  
\v 11 ”مِينْزِي مَانَاسَّا، أَجدْجِيذْ ن يَاهُوذَا، إِڭَّا جّْعَايفْ-أَ، إِڭَّا نتَّا ثُوعّفْنَا مَاهُو خْ \add أَيْثْ ن\add* أَمُورْ إِنِّي \add إِ ذِينْ إِدْجَانْ\add* قْبڒْ نّسْ. نتَّا يَارَّا ؤُڒَا ذ يَاهُوذَا أَذْ إِخْضَا س إِميْضَا نّسْ \add ن لْ-أَصْنَامْ\add*. \x ◘ \xo 21:‏11 \xt إِرْم. 15‏:‏4\x*  
\v 12 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’خْزَارْ، نشّْ أَذْ ڭّغْ ثُوعفّْنَا خْ ؤُرْشَالِيمْ ذ يَاهُوذَا، مَاحنْذْ مَارَّا وِي خَاسْ إِ غَا إِسْڒنْ، أَقَا ثْنَاينْ ن إِمزُّوغنْ نّسْ أَذْ طْنطْننْ.  
\v 13 نشّْ أَذْ قّْنغْ إِ ؤُرْشَالِيمْ فِيڒُو ن ڒعْبَارْ ن سَامَارْيَا ذ ڒْمِيزَانْ ن ثَادَّارْثْ ن أَخَابْ. نشّْ أَذْ مسْحغْ ؤُرْشَالِيمْ أَمْ مَامّشْ مسْحغْ إِجّْ ن طّبْصِي. مسْحنْ ث ؤُ \add خنِّي\add* قڒْبنْ ث خْ ؤُزدْجِيفْ نّسْ.  
\v 14 أَذْ جّغْ مِينْ إِقِّيمنْ زِي ثسْغَارْثْ ن ڒْوَارْثْ إِنُو، أَذْ ثنْ سِّيوْضغْ غَارْ إِفَاسّنْ ن ڒْعذْيَانْ نْسنْ ؤُ نِيثْنِي أَذْ ذوْڒنْ ذ ثَاحڭّْوَاسْثْ ذ ثَاكشَّاضْثْ إِ مَارَّا ڒْعذْيَانْ نْسنْ،  
\v 15 مَاغَارْ نِيثْنِي ڭِّينْ مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي ؤُ \add مَاغَارْ\add* نِيثْنِي سْعَارنْ أَيِي زڭْ وَاسّْ إِ ذِي فّْغنْ ڒجْذُوذْ نْسنْ زِي مِيصْرَا أَڒْ أَسّْ-أَ.   
\m
\v 16 عَاوذْ ثُوغَا مَانَاسَّا إِسِّيزّڒْ أَطَّاسْ ن إِذَامّنْ إِمزْذَاڭنْ أَڒَامِي زَّايْسنْ إِشُّورْ مَارَّا ؤُرْشَالِيمْ زڭْ إِجّْ ن طَّارْفْ غَارْ ونّغْنِي، بْڒَا مَا نِيذَارْ \add عَاذْ\add* دّنْبْ نّسْ إِ زِي يَارَّا يَاهُوذَا أَذْ إِخْضَا، ؤُمِي إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي.   
\m
\v 17 إِمزْرُوينْ إِقِّيمنْ ن مَانَاسَّا ذ مَارَّا مِينْ إِڭَّا ؤُڒَا ذ دّنْبْ نّسْ إِ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا؟  
\v 18 مَانَاسَّا إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. نتَّا إِتّْوَانْضڒْ ذڭْ وحْوِيشْ ن ثَادَّارْثْ نّسْ، ذِي ڒمْرَاحْ ن عُوصَا. مِّيسْ أَمُونْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. \x ◘ \xo 21:‏18 \xt 2 إِم. 33‏:‏20\x*   
\b  
\m  
\s1 أَمُونْ، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 19 أَمُونْ \add ثُوغَا\add* غَارسْ ثْنَاينْ ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ ثْنَاينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ مْشُولَّامِيثْ، يدْجِيسْ ن حَارُوزْ زِي يُوثْبَا. \x ◘ \xo 21:‏19 \xt [2 إِم. 33‏:‏21‏-‏25]\x*  
\v 20 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، \add أَمُّو نِيشَانْ\add* أَمْ مَامّشْ ث إِڭَّا بَابَاسْ مَانَاسَّا.  
\v 21 نتَّا يُويُورْ كُوڒْ أَبْرِيذْ إِ ذِي يُويُورْ بَابَاسْ. نتَّا إِسخَّارْ إِ إِميْضَا \add ن لْ-أَصْنَامْ\add* إِ ثُوغَا إِسخَّارْ \add ؤُڒَا ذ\add* بَابَاسْ ؤُشَا إِسْجذْ أَسنْ.  
\v 22 نتَّا إِسْمحْ ذِي سِيذِي، أَربِّي ن ڒجْذُوذْ نّسْ، ؤُ نتَّا وَارْ يُويُورْ شَا ذڭْ وبْرِيذْ ن سِيذِي.  
\v 23 إِمْسخَّارنْ ن أَمُونْ ڭِّينْ خَاسْ إِشْثْ ن ثْمعْمُوتْشْ ؤُشَا نْغِينْ أَجدْجِيذْ ذِي ثَادَّارْثْ نّسْ.  
\v 24 \add مَاشَا\add* ڒْڭنْسْ ن ثمُّورْثْ نْغِينْ مَارَّا إِنِّي ثُوغَا إِڭِّينْ إِشْثْ ن ثْمعْمُوتْشْ إِ ؤُجدْجِيذْ أَمُونْ، ؤُشَا ڒْڭنْسْ ن ثمُّورْثْ ڭِّينْ مِّيسْ يُوشِييَا ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\m
\v 25 إِمزْرُوينْ إِقِّيمنْ ن أَمُونْ ذ مِينْ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا؟  
\v 26 نتَّا إِتّْوَانْضڒْ ذڭْ ونْضڒْ نّسْ ذڭْ وحْوِيشْ ن عُوزَّا. مِّيسْ يُوشِييَا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. \x ◘ \xo 21:‏26 \xt مت. 1‏:‏10\x*   
\b  
\b  
\m  
\c 22
\s1 يُوشِييَا، أَجدْجِيذْ ن يَاهُوذَا - أَذْلِيسْ إِتّْوَانّْضنْ ن شَّارِيعَا  
\m
\v 1 يُوشِييَا \add ثُوغَا\add* غَارسْ ثْمنْيَا ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ وَاحِيثْ ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ يَاذِيذْيَا، يدْجِيسْ ن عَاذَايَا زِي بُوصْقَاثْ. \x ◘ \xo 22:‏1 \xt [2 إِم. 34‏:‏1‏-‏28] — 2 إِم. 34‏:‏1\x*  
\v 2 نتَّا إِڭَّا مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي. نتَّا يُويُورْ ذِي كُوڒْ أَبْرِيذْ ن بَابَاسْ ذَاوُوذْ، وَارْ إِحيّذْ \add خْ وبْرِيذْ\add* \add غَارْ\add* يفُوسْ ؤُڒَا \add غَارْ\add* ؤُزڒْمَاضْ.   
\m
\v 3 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْمنْطَاشْ ن ؤُجدْجِيذْ يُوشِييَا، إِمْسَارْ بلِّي أَجدْجِيذْ يُوشِييَا إِسّكّْ أَمَارِيرْ شَافَانْ، مِّيسْ ن أَصَالْيَا، مِّيسْ ن مَاشُولَّامْ، غَارْ ثَادَّارْثْ ن سِيذِي، إِنَّا:  
\v 4 ”ڭعّذْ غَارْ حِيلْقِييَا، أَرَّايْسْ ن إِكهَّاننْ، حِيمَا أَذْ يڭّْ أَذْ سّْوجْذنْ ثْمنْيَاثْ ن نُّوقَارْثْ إِ د يِيوْينْ ذِي ثَادَّارْثْ ن سِيذِي، ذ ثِينِّي إِ د-يَارْونْ إِعسَّاسنْ ن ثوُّورَا زِي ڒْڭنْسْ.  
\v 5 أجّْ إِ-ثنْ أَذْ ثنْثْ ڭّنْ ذڭْ إِفَاسّنْ ن يِينِّي إِتّڭّنْ ڒْخذْمثْ، \add ذڭْ إِفَاسّنْ ن\add* إِمحْضَاينْ ن ثَادَّارْثْ ن سِيذِي، \add حِيمَا\add* نِيثْنِي أَذْ ثنْثْ وْشنْ إِ يِينِّي إِتّڭّنْ ڒْخذْمثْ إِ \add ذِينْ\add* إِدْجَانْ ذِي ثَادَّارْثْ ن سِيذِي، حِيمَا أَذْ أَرقّْعنْ ڒحْيُوضْ إِهْرُورَانْ ن ثَادَّارْثْ،  
\v 6 إِ إِنقَّاشنْ \add ن ؤُكشُّوضْ ذ وژْرُو\add*، إِ إِبنَّاينْ ذ إِمَاصُّوثنْ، ؤُ إِ ثْمسْغِيوْثْ ن ؤُكشُّوضْ ذ ثْصُوضَارْ إِتّْوَاسُّويْذَانْ إِ وعْذَاڒْ ن ثَادَّارْثْ.“  
\v 7 مَاشَا وَارْ إِتّْخصِّي مَاحنْذْ أَذْ كِيذْسنْ ڭّنْ ڒحْسَابْ زِي جِّيهثْ ن \add تّْمنْيَاثْ ن\add* نُّوقَارْثْ إِ ذ أَسنْ إِمّوْشنْ، مَاغَارْ نِيثْنِي تّڭّنْ س ؤُثِيقِّي.   
\b  
\m
\v 8 \add خنِّي\add* إِنَّا أَرَّايْسْ ن إِكهَّاننْ حِيلْقِييَا إِ ؤُمَارِيرْ شَافَانْ: ”نشّْ ؤُفِيغْ أَذْلِيسْ إِتّْوَانّْضنْ ن شَّارِيعَا ذِي ثَادَّارْثْ ن سِيذِي.“ ؤُشَا إِوْشَا حِيلْقِييَا إِ شَافَانْ أَذْلِيسْ إِتّْوَانّْضنْ ؤُ وَانِيثَا إِغْرَا إِ-ث.  
\v 9 \add أَوَارْنِي أَسْ\add* يُويُورْ ؤُمَارِيرْ شَافَانْ غَارْ ؤُجدْجِيذْ ؤُشَا إِسِّيوضْ ڒخْبَارْ إِ ؤُجدْجِيذْ، إِنَّا: ”إِمْسخَّارنْ نّشْ سّْمُوننْ \add تّْمنْيَاثْ ن\add* نُّوقَارْثْ نِّي إِتّْوَافنْ ذِي ثَادَّارْثْ، فَارّْغنْ ثنْثْ ؤُشَا وْشِينْ ثنْثْ ذڭْ إِفَاسّنْ ن يِينِّي إِڭِّينْ ڒْخذْمثْ، إِ إِمحْضَاينْ ن ثَادَّارْثْ ن سِيذِي.“  
\v 10 \add عَاوذْ\add* إِحَاجَا ؤُمَارِيرْ شَافَانْ إِ ؤُجدْجِيذْ، إِنَّا: ”أَكهَّانْ حِيلْقِييَا إِوْشَا أَيِي إِجّْ ن وذْلِيسْ.“ شَافَانْ إِغْرَا إِ-ث زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ.   
\m
\v 11 ؤُمِي إِسْڒَا ؤُجدْجِيذْ أَوَاڒنْ ن وذْلِيسْ إِتّْوَانّْضنْ ن شَّارِيعَا، إِشَارّڭْ أَرُّوضْ نّسْ. \f ◼ \fr 22:‏11 \ft \+bd ’ؤُمِي إِسْڒَا‘\+bd* - س ثْعِيبْرَانِيثْ ’إِمْسَارْ ؤُمِي إِسْڒَا ...‘.\f*  
\v 12 أَجدْجِيذْ يُومُورْ إِ ؤُكهَّانْ حِيلْقِييَا ؤُ إِ أَخِيقَامْ، مِّيسْ ن شَافَانْ، ؤُ إِ عَاكْبُورْ، مِّيسْ ن مِيخَا-يَاهْ، ؤُ إِ شَافَانْ، أَمَارِيرْ، ؤُ إِ عَاسَايَا، أَمْسخَّارْ ن ؤُجدْجِيذْ، إِنَّا:  
\v 13 ”ؤُيُورمْ، أَرْزُومْ سِيذِي ذِي طّْوعْ إِنُو ؤُ ذِي طّْوعْ ن ڒْڭنْسْ ؤُ ذِي طّْوعْ ن مَارَّا يَاهُوذَا زِي جِّيهثْ ن وَاوَاڒنْ-أَ ن وذْلِيسْ-أَ إِتّْوَانّْضنْ إِ إِتّْوَافنْ، مَاغَارْ أَسْعَارْ ن سِيذِي إِ يَارْغِينْ ضِيدّْ نّغْ ذ أَمقّْرَانْ، مِينْزِي ڒجْذُوذْ نّغْ وَارْ سْڒِينْ شَا غَارْ وَاوَاڒنْ ن وذْلِيسْ-أَ إِتّْوَانّْضنْ، حِيمَا أَذْ ڭّنْ أَمْ مَامّشْ مَارَّا \add مِينْ ذَايسْ\add* يُورَانْ إِ نشِّينْ.“   
\m
\v 14 \add خنِّي\add* يُويُورْ ؤُكهَّانْ حِيلْقِييَا أَكْ-ذ أَخِيقَامْ، عَاكْبُورْ، شَافَانْ ذ عَاسَايَا غَارْ ثْنَابِيثْ خُولْذَا، ثَامْغَارْثْ ن شَالُّومْ، مِّيسْ ن ثِيقْوَا، مِّيسْ ن حَارْحَاسْ، ونِّي إِحطَّانْ خْ وَارُّوضنْ. نتَّاثْ ثزْذغْ ذِي ؤُرْشَالِيمْ، ذڭْ وزْينْ نّغْنِي. نِيثْنِي سِّيوْڒنْ أَكِيذسْ.  
\v 15 نتَّاثْ ثنَّا أَسنْ: ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’إِنِي إِ ورْيَازْ نِّي كنِّيوْ إِ غَارِي د-إِسّكّنْ:  
\v 16 أَمُّو إِ إِقَّارْ سِيذِي: خْزَارْ، نشّْ أَذْ أَوْيغْ ثُوعفّْنَا خْ ومْشَانْ-أَ ؤُ خْ إِمزْذَاغْ نّسْ، أَقَا مَارَّا أَوَاڒنْ ن وذْلِيسْ-أَ إِتّْوَانّْضنْ إِ إِغْرَا ؤُجدْجِيذْ ن يَاهُوذَا،  
\v 17 مَاغَارْ نِيثْنِي سمْحنْ ذَايِي، إِوْينْ ثِيوْهِيبِينْ ن ڒبْخُورْ إِ إِربِّيثنْ نّغْنِي أَڒَامِي ذَايِي سْعَارنْ س مَارَّا ڒْخذْمثْ ن إِفَاسّنْ نْسنْ. أَسْعَارْ إِنُو أَذْ إِتّْوَاسَّارْغْ ضِيدّْ إِ ومْشَانْ-أَ ؤُ وَارْ إِخسِّي شَا عَاذْ.  
\v 18 \add مَاشَا\add* إِنِيمْ إِ ؤُجدْجِيذْ ن يَاهُوذَا، ونِّي كنِّيوْ د-إِسّكّنْ ذَا حِيمَا أَذْ ثتَّارمْ إِ سِيذِي: أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل، خْ وَاوَاڒنْ إِ ثسْڒِيذْ شكْ:  
\v 19 مِينْزِي ؤُڒْ نّشْ إِذْوڒْ يَارْضبْ ؤُ ثسّْوَاضْعذْ إِخفْ نّشْ زَّاثْ إِ وُوذمْ ن سِيذِي ؤُمِي ثسْڒِيذْ خْ مِينْ سِّيوْڒغْ خْ ومْشَانْ-أَ ؤُ خْ إِمزْذَاغْ نّسْ - أَقَا نِيثْنِي أَذْ ذوْڒنْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ ذ نّعْڒثْ - ؤُ ؤُمِي ثْشَارّْڭذْ أَرُّوضْ نّشْ ؤُشَا ثْرُوذْ زَّاثْ إِ وُوذمْ إِنُو، خْ ؤُيَا أَذْ أَشْ سْڒِيغْ، إِقَّارْ سِيذِي.  
\v 20 س ؤُيَا، أَقَا نشّْ أَذْ شكْ سّْمُونغْ غَارْ ڒجْذُوذْ نّشْ ؤُشَا أَذْ تّْوَاسَّارْسذْ ذڭْ ونْضڒْ ذِي ڒهْنَا ؤُ ثِيطَّاوِينْ نّشْ وَارْ ژَترّنْثْ ثُوعفّْنَا إِ ذ غَا أَوْيغْ خْ ومْشَانْ-أَ.‘ “ \add خنِّي\add* سِّيوْضنْ نِيثْنِي أَوَاڒْ-أَ غَارْ ؤُجدْجِيذْ.   
\b  
\b  
\m  
\c 23
\s1 أَڒقّحْ س ؤُفُوسْ ن يُوشِييَا  
\m
\v 1 \add خنِّي\add* إِسّكّْ ؤُجدْجِيذْ \add إِرقَّاسنْ\add* ؤُشَا مَارَّا إِمْغَارنْ ن يَاهُوذَا ذ ؤُرْشَالِيمْ مُوننْ غَارسْ. \x ◘ \xo 23:‏1 \xt [2 إِم. 34‏:‏29‏-‏30؛ 35‏:‏1‏-‏27] — 2 إِم. 34‏:‏29\x*  
\v 2 أَجدْجِيذْ إِڭعّذْ غَارْ ثَادَّارْثْ ن سِيذِي أَكْ-ذ مَارَّا إِرْيَازنْ ن يَاهُوذَا ذ مَارَّا إِمزْذَاغْ ن ؤُرْشَالِيمْ، ؤُڒَا ذ إِكهَّاننْ ذ إِنَابِييّنْ ذ مَارَّا ڒْڭنْسْ، زڭْ ؤُمژْيَانْ أَڒْ ؤُمقّْرَانْ، ؤُ نتَّا إِغْرَا خَاسنْ ذڭْ إِمزُّوغنْ نْسنْ مَارَّا أَوَاڒنْ ن وذْلِيسْ ن ڒْعَاهْذْ نِّي ثُوغَا ؤُفِينْ ذِي ثَادَّارْثْ ن سِيذِي.  
\v 3 أَجدْجِيذْ ثُوغَا إِبدّْ غَارْ إِجّْ ن ؤُپِيلَارْ ؤُشَا نتَّا إِقّنْ ڒْعَاهْذْ زَّاثْ إِ سِيذِي، حِيمَا أَذْ إِضْفَارْ سِيذِي، أَذْ إِحْضَا ڒُومُورَاثْ نّسْ ذ شّْهَاذَاثْ نّسْ ذ ثْوصَّا نّسْ س مَارَّا ؤُڒْ \add نّسْ\add* ؤُ س مَارَّا ڒعْمَارْ \add نّسْ\add*، مَاحنْذْ أَذْ إِسّمْثنْ أَوَاڒنْ ن ڒْعَاهْذْ-أَ نِّي يُورِينْ ذڭْ وذْلِيسْ-أَ. ؤُشَا يُوذفْ ڒْڭنْسْ مَارَّا ذِي ڒْعَاهْذْ.   
\m
\v 4 أَجدْجِيذْ يُومُورْ إِ حِيلْقِييَا، أَرَّايْسْ ن إِكهَّاننْ، ؤُ إِ إِكهَّاننْ ن ؤُستّفْ وِيسّْ ثْنَاينْ ؤُ إِ إِعسَّاسنْ ن ثوَّارْثْ، أَقَا نِيثْنِي أَذْ سُّوفّْغنْ مَارَّا ڒقْشُوعْ نِّي ثُوغَا إِتّْوَاڭّنْ إِ بَاعَالْ ؤُ إِ ثْربِّيثْ ن شْوَارْثِي ؤُڒَا إِ مَارَّا ڒْعسْكَارْ ن ؤُجنَّا زِي زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي غَارْ بَارَّا، ؤُ إِسّشْمضْ مَانْ أَيَا \add مَارَّا\add* بَارَّا إِ ؤُرْشَالِيمْ ذڭْ إِيَّارنْ ن قِيذْرُونْ ؤُ إِجَّا أَذْ أَرْبُونْ إِغّضْ نّسْ غَارْ بَايْثْ-إِلْ.  
\v 5 نتَّا إِكّسْ \add عَاوذْ\add* إِكهَّاننْ ن لْ-أَصْنَامْ نِّي ثُوغَا ڒقّْمنْ إِجدْجِيذنْ ن يَاهُوذَا، حِيمَا أَذْ قدّْمنْ ثِيوْهِيبِينْ ن ڒبْخُورْ ذِي ڒڭْعُوذِي، ذِي ثْندَّامْ ن يَاهُوذَا ؤُ ذِي جّْوَايهْ إِ د إِنّْضنْ إِ ؤُرْشَالِيمْ، ؤُڒَا ذ يِينِّي إِ إِقدّْمنْ ثِيوْهِيبِينْ نْ ڒبْخُورْ إِ بَاعَالْ، ذ ثْفُوشْثْ، ذ ثْزِيرِي، ذ ثمُّورَا ن ؤُجنَّا ؤُ إِ مَارَّا ڒْعسْكَارْ ن ؤُجنَّا. \f ◼ \fr 23:‏5 \ft \+bd ’ثِيمُّورَا ن ؤُجنَّا‘\+bd* - إِخْسْ أَذْ يِينِي كواكب سيارونِ.\f*  
\v 6 إِسُّوفّغْ ؤُڒَا ذ ثَاربِّيثْ ن شْوَارْثِي زِي ثَادَّارْثْ ن سِيذِي، \add إِڭَّا إِ-ت\add* بَارَّا إِ ؤُرْشَالِيمْ غَارْ ثغْزَارْثْ ن قِيذْرُونْ. نتَّا إِسّشْمضْ إِ-ت غَارْ ثغْزَارْثْ ن قِيذْرُونْ ؤُ إِدّزْ إِ-ت ذ ثَاعجَّاجْثْ ؤُ يَاريّشْ إِ-ت خْ إِمضْڒَانْ ن أَيْثْ ن ڒْڭنْسْ.  
\v 7 نتَّا إِهْذمْ إِخَّامنْ ن إِمثْليِّينْ نِّي ثُوغَا غَارْ ثَادَّارْثْ ن سِيذِي، مَانِي تّْخيَّاضنْثْ ثمْغَارِينْ إِقِيضَانْ نِّي ڭِّينْثْ أَمْ ثِيزَّايِيوِينْ إِ ثْربِّيثْ ن شْوَارْثِي.  
\v 8 نتَّا إِجَّا أَذْ سُّوفّْغنْ مَارَّا إِكهَّاننْ زِي ثْندَّامْ ن يَاهُوذَا ؤُشَا إِسّخْمجْ ڒڭْعُوذِي مَانِي قدّْمنْ إِكهَّاننْ ثِيوْهِيبِينْ ن ڒبْخُورْ، زِي جَابْعَا أَڒْ بِئرْ-سبْعَا. نتَّا إِهْذمْ ڒڭْعُوذِي غَارْ ثوُّورَا \add ن ثنْذِينْثْ\add*، ؤُڒَا ذ ثِينِّي \add إِدْجَانْ\add* غَارْ وَاذَافْ ن ثوَّارْثْ ن يَاشُووَا، أَزدْجِيفْ أَمقّْرَانْ ن ثنْذِينْثْ، غَارْ ؤُزڒْمَاضْ ن ونِّي \add إِ ثُوغَا إِتَّاذفْ\add* ثَاوَّارْثْ ن ثنْذِينْثْ.  
\v 9 مَاشَا إِكهَّاننْ ن ڒڭْعُوذِي وَارْ زمَّارنْ أَذْ ڭعّْذنْ غَارْ ؤُعَالْطَارْ ن سِيذِي ذِي ؤُرْشَالِيمْ، مَاشَا نِيثْنِي شِّينْ أَغْرُومْ بْڒَا أَنْثُونْ ذِي ڒْوسْثْ ن أَيْثْمَاثْسنْ.  
\v 10 نتَّا إِسّخْمجْ ؤُڒَا ذ ثُوفَاثْ نِّي \add إِدْجَانْ\add* ذِي ثغْزُورْثْ ن أَيْثْ ن هِينُّومْ، حِيمَا ؤُڒَا ذ إِجّْ وَارْ إِسّْعدُّو مِّيسْ نِيغْ يدْجِيسْ خْ ثْمسِّي إِ مُولَاكْ.  
\v 11 نتَّا إِكّسْ إِيْسَانْ إِ ثُوغَا ڭِّينْ إِجدْجِيذنْ ن يَاهُوذَا إِ ڒوْقَارْ ن ثْفُوشْثْ غَارْ وَاذَافْ ن ثَادَّارْثْ ن سِيذِي، غَارْ ثخَّامْثْ ن نَاثَانْ-مَالَاكْ، أَمْسخَّارْ أَشنّعْ، ونِّي \add إِدْجَانْ\add* ذِي ڒبْنِييَّاثْ بَارَّا \add إِ زَّاوشْثْ ثَامقّْرَانْثْ\add*. نتَّا إِقدّْ إِ إِكَارُّوثنْ ن ثْفُوشْثْ س ثْمسِّي.  
\v 12 \add ؤُڒَا ذ\add* إِعَالْطَارنْ نِّي ثُوغَا إِبدّنْ خْ ثْزقَّا ن ثْغُورْفثْ ن أَحَازْ نِّي ڭِّينْ إِجدْجِيذنْ ن يَاهُوذَا، ؤُڒَا ذ إِعَالْطَارنْ إِ إِڭَّا مَانَاسَّا ذِي ثْنَاينْ ن ڒمْرَاحَاثْ ن ثَادَّارْثْ ن سِيذِي، إِهْذمْ إِ-ثنْ ؤُجدْجِيذْ. نتَّا إِڒْبزْ إِ-ثنْ، \add إِسِّيڭّْوجْ إِ-ثنْ\add* سّنِّي ؤُشَا إِنْضَارْ ثَاعجَّاجْثْ نْسنْ ذِي ثغْزَارْثْ ن قِيذْرُونْ.  
\v 13 ؤُشَا إِسّخْمجْ ؤُجدْجِيذْ ڒڭْعُوذِي نِّي \add ذِينْ إِدْجَانْ\add* زَّاثْ إِ ؤُرْشَالِيمْ، غَارْ يفُوسْ ن وذْرَارْ ن ؤُضيّعْ، \add ڒڭْعُوذِي\add* إِ إِبْنَا سُولِيمَانْ، أَجدْجِيذْ ن إِسْرَائِيل، إِ أَشْثُورِيثْ، نّْعِي ن لْ-أَصْنَامْ ن أَيْثْ ن صِيذُونْ، ؤُ إِ كَامُوشْ، نّْعِي ن لْ-أَصْنَامْ ن أَيْثْ ن مُوآبَ، ؤُ إِ مِيلْكُومْ، جّْعِيفشْثْ ن لْ-أَصْنَامْ ن أَيْثْ ن عَامُّونْ.  
\v 14 نتَّا يَارْژَا إِمَايْضُوثنْ \add إِقدّْسنْ\add* ذ إِوثْوِيثنْ ؤُشَا إِهْذمْ ثِيربِّينْ ن شْوَارْثِي ؤُشَا إِشُّورْ أَمْشَانْ نْسنْ س يغْسَانْ ن يوْذَانْ. \x ◘ \xo 23:‏14 \xt ؤُف. 23‏:‏24؛ 34‏:‏13؛ ڒخْڒ. 33‏:‏52؛ أَعَوذ. 7‏:‏5، 25؛ 12‏:‏3\x*   
\m
\v 15 ؤُڒَا ذ أَعَالْطَارْ نِّي \add إِدْجَانْ\add* ذِي بَايْثْ-إِلْ، ڒْڭعّْذثْ إِ إِڭِّينْ يَارُوبْعَامْ، مِّيسْ ن نَابَاطْ، ذ ونِّي يَارِّينْ إِسْرَائِيل أَذْ إِخْضَا، أَقَا أَعَالْطَارْ نِّي ذ ڒْڭعّْذثْ نِّي، إِهْذمْ إِ-ثنْ س ثْنَاينْ إِذْسنْ. نتَّا إِسّشْمضْ ڒْڭعّْذثْ، إِدّزْ إِ-ت أَڒَامِي ثذْوڒْ ذ ثَاعجَّاجْثْ ؤُشَا إِسّشْمضْ ثَاربِّيثْ ن شْوَارْثِي. \x ◘ \xo 23:‏15 \xt 1 إِج. 12‏:‏32، 33\x*  
\v 16 \add ؤُمِي\add* د-إِنّقْڒبْ يُوشِييَا، إِژْرَا إِمضْڒَانْ إِ \add ثُوغَا\add* ذِينِّي خْ وذْرَارْ، ؤُشَا إِسّكّْ \add ذِينْ شَا ن يرْيَازنْ\add*، إِكْسِي-د إِغْسَانْ زڭْ إِمضْڒَانْ ؤُشَا إِسّشْمضْ إِ-ثنْ خْ ؤُعَالْطَارْ. \add أَمُّو\add* إِ إِسّخْمجْ إِ-ث عْلَاحْسَابْ أَوَاڒْ ن سِيذِي إِ زِي إِبَارّحْ ورْيَازْ ن أَربِّي ونِّي إِبَارّْحنْ أَوَاڒنْ-أَ. \x ◘ \xo 23:‏16 \xt 1 إِج. 13‏:‏2\x*  
\v 17 \add يَارْنِي\add* إِنَّا: ”مَانَا وژْرُو نِّي إِ وَارْ ژْرِيغْعمَّارْسْ إِ ذِينْ ثْوَاڒِيغْ؟“ نَّانْ أَسْ يرْيَازنْ ن ثنْذِينْثْ: ”وَا ذ أَنْضڒْ ن ورْيَازْ ن أَربِّي ونِّي ثُوغَا د-يُوسِينْ زِي يَاهُوذَا، ذ ونِّي إِبَارّْحنْ س ثْمسْڒَايِينْ-أَ نِّي ثڭِّيذْ أَكْ-ذ ؤُعَالْطَارْ-أَ ن بَايْثْ-إِلْ.“  
\v 18 نتَّا إِنَّا: ”جّمْ ث ذِينْ! ؤُڒَا ذ إِجّنْ وَارْ إِتّْحِيذِي إِغْسَانْ نّسْ!“ أَمُّو إِ جِّينْ نِيثْنِي إِغْسَانْ نّسْ \add جْمِيعْ\add* أَكْ-ذ يغْسَانْ ن ؤُنَابِي ونِّي د-يُوسِينْ زِي سَامَارْيَا.   
\m
\v 19 إِكّسْ يُوشِييَا مَارَّا ثُوذْرِينْ ن ثْزَاوِييِّينْ ن ڒڭْعُوذِي نِّي \add إِدْجَانْ\add* ذِي ثْندَّامْ ن سَامَارْيَا إِ ثُوغَا سّْبدّنْ إِجدْجِيذنْ ن إِسْرَائِيل، مَاحنْذْ أَذْ سْعَارنْ \add سِيذِي\add*. نتَّا إِڭَّا زَّايْسنْ أَمْ مَامّشْ إِڭَّا ذِي بَايْثْ-إِلْ. \x ◘ \xo 23:‏19 \xt 2 إِم. 34‏:‏6\x*  
\v 20 مَارَّا إِكهَّاننْ ن ڒڭْعُوذِي إِنِّي \add ثُوغَا إِدْجَانْ\add* ذِينْ، إِغَارْصْ أَسنْ خْ إِعَالْطَارنْ ؤُشَا إِسّشْمضْ إِغْسَانْ ن إِوْذَانْ. أَوَارْنِي أَسْ إِعْقبْ غَارْ ؤُرْشَالِيمْ.   
\b  
\m  
\s1 ڒْعِيذْ ن ثْغَارْصْثْ ن ؤُسعْذُو  
\m
\v 21 أَجدْجِيذْ يُومُورْ إِ مَارَّا ڒْڭنْسْ: ”سْوجْذمْ \add ڒْعِيذْ ن ثْغَارْصْثْ ن\add* ؤُسعْذُو إِ سِيذِي، أَربِّي نْومْ، أَمْ مَامّشْ إِتّْوَارِي ذڭْ وذْلِيسْ-أَ ن ڒْعَاهْذْ.“ \x ◘ \xo 23:‏21 \xt [2 إِم. 35] — ؤُف. 12‏:‏3؛ أَعَوذ. 16‏:‏2؛ 2 إِم. 35‏:‏1\x*  
\v 22 إِشْثْ ن \add ڒْعِيذْ ن ثْغَارْصْثْ ن\add* ؤُسعْذُو أَمْ وَا وَارْ إِتّْوَاڭّْ \add عمَّارْصْ\add* زڭْ وُوسَّانْ ن ڒْقُوضَاثْ نِّي ثُوغَا إِحكّْمنْ إِسْرَائِيل، ؤُڒَا ذِي مَارَّا ؤُسَّانْ ن إِجدْجِيذنْ ن إِسْرَائِيل ذ إِجدْجِيذنْ ن يَاهُوذَا.  
\v 23 مَاشَا ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْمنْطَاشْ ن ؤُجدْجِيذْ يُوشِييَا سّْوجْذنْ نِيثْنِي \add ڒْْعِيذْ ن ثْغَارْصْثْ\add* ن ؤُسعْذُو وَانِيثَا إِ سِيذِي ذِي ؤُرْشَالِيمْ.   
\m
\v 24 يُوشِييَا إِكّسْ ؤُڒَا ذ يِينِّي إِسَّاوَاڒنْ أَكْ-ذ إِمتَّانْ، ذ إِڭزَّاننْ، ذ ڒخْيَاڒَاثْ ثِيمژْيَانِينْ ن لْ-أَصْنَامْ، ذ إِميْضَا ن \add لْ-أَصْنَامْ\add*، ذ مَارَّا نّْعَاوَاثْ ن لْ-أَصْنَامْ إِ إِتّْوَاڒَانْ ذِي ثمُّورْثْ ن يَاهُوذَا ؤُ ذِي ؤُرْشَالِيمْ، حِيمَا أَذْ إِڭّْ أَوَاڒنْ ن شَّارِيعَا إِ إِتّْوَارِينْ ذڭْ وذْلِيسْ إِتّْوَانّْضنْ إِ ثُوغَا يُوفَا ؤُكهَّانْ حِيلْقِييَا ذِي ثَادَّارْثْ ن سِيذِي. \x ◘ \xo 23:‏24 \xt لَاوِي 19‏:‏31؛ 20‏:‏27؛ أَعَوذ. 18‏:‏11؛ إِشا. 8‏:‏19\x*  
\v 25 قْبڒْ نّسْ وَارْ ذِينْ ثُوغِي ؤُڒَا ذ إِجّْ ن ؤُجدْجِيذْ أَمْ نتَّا، إِذْوڒْ-د غَارْ سِيذِي س مَارَّا ؤُڒْ نّسْ ؤُ س مَارَّا ڒعْمَارْ نّسْ ذ س مَارَّا جّهْذْ نّسْ، عْلَاحْسَابْ شَّارِيعَا ن مُوسَا، ؤُ أَوَارْنِي أَسْ وَارْ ذِينْ ثُوغِي ؤُڒَا ذ إِجّنْ أَمْ نتَّا. \x ◘ \xo 23:‏25 \xt أَعَوذ. 6‏:‏5؛ 10‏:‏12؛ مت. 22‏:‏37؛ مك. 12‏:‏20، 33؛ لك. 10‏:‏27\x*   
\m
\v 26 مَاشَا سِيذِي وَارْ إِجِّي زِي ڒْحَاذُوقْ ن وغْضَابْ نّسْ أَمقّْرَانْ إِ زِي ثُوغَا يَارْغَا وغْضَابْ نّسْ خْ يَاهُوذَا زِي سِّيبّثْ ن مَارَّا أَسْعَارْ إِ ذ أَسْ إِڭَّا مَانَاسَّا.  
\v 27 سِيذِي إِنَّا: ”أَذْ سِّيڭّْوْجغْ ؤُڒَا ذ يَاهُوذَا خْ وُوذمْ إِنُو، أَمْ مَامّشْ سِّيڭّْوجغْ نشّْ إِسْرَائِيل، ؤُ نشّْ أَذْ نْضَارغْ ثَانْذِينْثْ-أَ ؤُرْشَالِيمْ إِ فَارْزغْ، ؤُڒَا ذ ثَادَّارْثْ إِ خفْ نِّيغْ: ’أَذْ يِيڒِي إِسمْ إِنُو ذِيهَا!‘ “ \x ◘ \xo 23:‏27 \xt 2 إِج. 17‏:‏18، 20؛ 24‏:‏3\x*   
\m
\v 28 إِمزْرُوينْ إِقِّيمنْ ن يُوشِييَا ذ مَارَّا مِينْ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا؟   
\b  
\m
\v 29 ذڭْ وُوسَّانْ نّسْ إِڭعّذْ فِيرْعُونْ نِيخُو، أَجدْجِيذْ ن مِيصْرَا، ضِيدّْ إِ ؤُجدْجِيذْ ن أَشُّورْ غَارْ يغْزَارْ ن لْفُورَاطْ. أَجدْجِيذْ يُوشِييَا إِفّغْ، مَاحنْذْ أَذْ ث إِڒْقَا، مَاشَا \add فِيرْعُونْ نِيخُو\add* إِنْغَا إِ-ث غَارْ مَاجِيدُّو ڒَامِي ث يژْرَا.  
\v 30 إِمْسخَّارنْ نّسْ إِوْينْ ث ذ أَمتِّينْ خْ إِجّْ ن ؤُكَارُّو زِي مَاجِيدُّو غَارْ ؤُرْشَالِيمْ، سِّيوْضنْ ث غَارْ ؤُرْشَالِيمْ ؤُشَا نضْڒنْ ث ذڭْ ونْضڒْ نّسْ. ڒْڭنْسْ ن ثمُّورْثْ إِكْسِي يَاهُويَاحَازْ، مِّيسْ ن يُوشِييَا، ؤُشَا ذهْننْ ث، ڭِّينْ ث ذ أَجدْجِيذْ ذڭْ ومْشَانْ ن بَابَاسْ. \x ◘ \xo 23:‏30 \xt 2 إِم. 36‏:‏1\x*   
\b  
\m  
\s1 يَاهُويَاحَازْ، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 31 يَاهُويَاحَازْ \add ثُوغَا\add* غَارسْ ثْڒَاثَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ ثْڒَاثَا ن إِيُورنْ ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ حَامُوثَالْ، يدْجِيسْ ن إِرْمِييَا زِي لِيبْنَا. \x ◘ \xo 23:‏31 \xt [2 إِم. 36‏:‏1‏-‏4]\x*  
\v 32 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، نِيشَانْ أَمْ مَامّشْ ث ڭِّينْ ڒجْذُوذْ نّسْ.  
\v 33 فِيرْعُونْ نِيخُو إِجَّا أَذْ ث إِبلّعْ ذِي رِيبْلَا ذِي ثمُّورْثْ ن حَامَاثْ، حِيمَا وَارْ إِحكّمْ \add عَاذْ\add* ذِي ؤُرْشَالِيمْ. نتَّا إِڭَّا إِ ثمُّورْثْ إِجّْ ن مُولْثَا ن مْيَا ثَالِينْثْ ن نُّوقَارْثْ ذ إِشْثْ ن ثَالِينْثْ ن وُورغْ.  
\v 34 \add خنِّي\add* إِڭَّا فِيرْعُونْ أَلْيَاقِيمْ، مِّيسْ ن يُوشِييَا ذ أَجدْجِيذْ ذڭْ ومْشَانْ ن بَابَاسْ ؤُشَا إِبدّڒْ إِسمْ نّسْ غَارْ يَاهُويَاقِيمْ. \add مَاشَا\add* يَاهُويَاحَازْ يِيوْيِي إِ-ث ؤُشَا يُوسَا-د غَارْ مِيصْرَا ؤُشَا إِمُّوثْ ذِينِّي. \x ◘ \xo 23:‏34 \xt مت. 1‏:‏11\x*   
\b  
\m  
\s1 يَاهُويَاقِيمْ، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 35 يَاهُويَاقِيمْ إِوْشَا نُّوقَارْثْ ذ وُورغْ إِ فِيرْعُونْ، مَاشَا نتَّا ثُوغَا إِقدَّارْ ثَامُّورْثْ، حِيمَا \add إِزمَّارْ\add* أَذْ إِسلّمْ نُّوقَارْثْ نِّي عْلَاحْسَابْ ڒُومُورْ ن فِيرْعُونْ. \add إِقدَّارْ كُوڒْ إِجّْ ن\add* ورْيَازْ عْلَاحْسَابْ ڒقْذَارْ نّسْ، \add أَمُّو إِ\add* إِتَّارْ نُّوقَارْثْ ذ وُورغْ ن ڒْڭنْسْ ن ثمُّورْثْ، حِيمَا أَذْ ث إِوْشْ إِ فِيرْعُونْ نِيخُو. \x ◘ \xo 23:‏35 \xt [2 إِم. 36‏:‏5‏-‏8]\x*  
\v 36 يَاهُويَاقِيمْ \add ثُوغَا\add* غَارسْ خمْسَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ حِيطَاشْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ زَابِيذَا، يدْجِيسْ ن فِيذَايَا زِي رُومَاثْ.  
\v 37 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، نِيشَانْ أَمْ مَامّشْ ث ڭِّينْ ڒجْذُوذْ نّسْ.   
\b  
\b  
\m  
\c 24
\s1 يَاهُوذَا سَاذُو ؤُفُوسْ ن ؤُجدْجِيذْ ن بَابِيلْ ڒْمِيجَاڒْ ن ثْڒَاثَا ن إِسڭّْوُوسَا  
\m
\v 1 ذڭْ وُوسَّانْ نّسْ إِڭعّذْ نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، ؤُ يَاهُويَاقِيمْ إِذْوڒْ  إِطَاعْ أَسْ ثْڒَاثَا ن إِسڭّْوُوسَا. \add خنِّي\add* إِنّقْڒبْ ؤُشَا إِغوّغْ خَاسْ. \x ◘ \xo 24:‏1 \xt 2 إِم. 36‏:‏6\x*  
\v 2 إِسّكّْ-د غَارسْ سِيذِي بَانْذِييَّاثْ ن إِكَالْذَانِييّنْ ذ بَانْذِييَّاثْ ن أَرَامْ ذ بَانْذِييَّاثْ ن مُوآبَ ذ بَانْذِييَّاثْ ن أَيْثْ ن عَامُّونْ. نتَّا إِسّكّْ إِ-ثنْ غَارْ يَاهُوذَا، حِيمَا أَذْ ت خَارّْبنْ عْلَاحْسَابْ أَوَاڒْ ن سِيذِي إِ ثُوغَا إِسِّيوڒْ س ؤُقمُّومْ ن إِمْسخَّارنْ نّسْ، إِنَابِييّنْ. \f ◼ \fr 24:‏2 \ft \+bd ’س ؤُقمُّومْ‘\+bd* - س ثْعِيبْرَانِيثْ ’س ؤُفُوسْ‘.\f*  \x ◘ \xo 24:‏2 \xt 2 إِج. 20‏:‏17؛ 23‏:‏27\x*  
\v 3 وَاهْ، مَانْ أَيَا \add إِمْسَارْ\add* أَكْ-ذ يَاهُوذَا عْلَاحْسَابْ ڒُومُورْ ن سِيذِي، حِيمَا أَذْ ث إِسِّيڭّْوجْ خْ وُوذمْ نّسْ ذِي سِّيبّثْ ن دّْنُوبْ ن مَانَاسَّا، ذِي سِّيبّثْ ن مَارَّا مِينْ إِڭَّا وَانِيثَا. \f ◼ \fr 24:‏3 \ft \+bd ’عْلَاحْسَابْ ڒُومُورْ ن سِيذِي‘\+bd* - س ثْعِيبْرَانِيثْ ’خْ ؤُقمُّومْ ن سِيذِي‘.\f*  
\v 4 ؤُڒَا ذِي سِّيبّثْ ن إِذَامّنْ إِمزْذَاڭنْ إِ إِسِّيزّڒْ ڒَامِي ثُوغَا زَّايْسنْ إِشُّورْ ؤُرْشَالِيمْ. \add س ؤُيَا\add* سِيذِي ثُوغَا وَارْ إِخْسْ أَذْ أَسْ إِغْفَارْ.   
\m
\v 5 إِمزْرُوينْ إِقِّيمنْ ن يَاهُويَاقِيمْ ذ مَارَّا مِينْ إِڭَّا، مَا مَانْ أَيَا \add مَارَّا\add* وَارْ إِتّْوَازمّمْ شَا ذڭْ وذْلِيسْ ن إِمزْرُوينْ ن إِجدْجِيذنْ ن يَاهُوذَا؟  
\v 6 يَاهُويَاقِيمْ إِڭَّا أَذْ يَاريّحْ جَارْ ڒجْذُوذْ نّسْ. مِّيسْ يَاهُويَاكِينْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.   
\m
\v 7 أَجدْجِيذْ ن مِيصْرَا وَارْ إِفِّيغْ عَاذْ \add غَارْ ؤُمنْغِي\add* زِي ثمُّورْثْ نّسْ، مَاغَارْ أَجدْجِيذْ ن بَابِيلْ ثُوغَا إِكْسِي مَارَّا مِينْ ثُوغَا \add إِدْجَانْ\add* ن ؤُجدْجِيذْ ن مِيصْرَا زِي ثغْزَارْثْ ن مِيصْرَا أَڒْ إِغْزَارْ ن لْفُورَاطْ.   
\b  
\m  
\s1 يَاهُويَاكِينْ، أَجدْجِيذْ ن يَاهُوذَا - أَمزْوَارْ ن لْمنْفَا غَارْ بَابِيلْ  
\m
\v 8 يَاهُويَاكِينْ \add ثُوغَا\add* غَارسْ ثْمنْطَاشْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ ثْڒَاثَا ن إِيُورنْ ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ نحُوشْطَا، يدْجِيسْ ن إِلْ-نَاثَانْ زِي ؤُرْشَالِيمْ. \x ◘ \xo 24:‏8 \xt [2 إِم. 36‏:‏9‏-‏10]\x*  
\v 9 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، نِيشَانْ أَمْ مَامّشْ ث إِڭَّا بَابَاسْ.  
\v 10 ذِي ڒْوقْثْ نِّي فّْغنْ إِمْسخَّارنْ ن نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، غَارْ ؤُرْشَالِيمْ ؤُشَا ثتّْوَاحْسَارْ ثنْذِينْثْ. \x ◘ \xo 24:‏10 \xt دَان. 1‏:‏1\x*  
\v 11 ؤُڒَا نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، \add نتَّا سِيمَانْثْ نّسْ\add* يُوسَا-د غَارْ ثنْذِينْثْ أَمْ ت حْصَارنْ إِمْسخَّارنْ نّسْ.  
\v 12 \add خنِّي\add* إِفّغْ يَاهُويَاكِينْ، أَجدْجِيذْ ن يَاهُوذَا، \add زِي ثنْذِينْثْ، يُويُورْ\add* غَارْ ؤُجدْجِيذْ ن بَابِيلْ، نتَّا أَكْ-ذ يمَّاسْ ذ إِمْسخَّارنْ نّسْ ذ ڒْحُوكَّامْ نّسْ ذ إِمْسخَّارنْ نّسْ إِشنّْعنْ. أَجدْجِيذْ ن بَابِيلْ إِحبّسْ إِ-ث ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْمنْيَا ن ثْڭلْذَا نّسْ.  
\v 13 نتَّا إِحوّسْ سّنِّي مَارَّا ثِيخُوبَايْ زِي ثَادَّارْثْ ن سِيذِي ذ ثْخُوبَايْ زِي ثَادَّارْثْ ن ؤُجدْجِيذْ ؤُشَا إِكّسْ \add ؤُرغْ\add* خْ مَارَّا ڒقْشُوعْ ن وُورغْ نِّي ثُوغَا إِڭَّا سُولِيمَانْ، أَجدْجِيذْ ن إِسْرَائِيل، ذِي زَّاوشْثْ ثَامقّْرَانْثْ ن سِيذِي، أَمْ مَامّشْ ثُوغَا إِسِّيوڒْ سِيذِي. \x ◘ \xo 24:‏13 \xt 2 إِم. 20‏:‏17؛ إِشا. 39‏:‏6\x*  
\v 14 نتَّا يِيوِي-د مَارَّا ؤُرْشَالِيمْ أَكْ-ذ مَارَّا ڒْحُوكَّامْ ذ مَارَّا أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ،عشْرَا-أَڒَافْ ن إِمحْبَاسْ، ؤُڒَا ذ كُوڒْ أَنقَّاشْ \add ن ؤُكشُّوضْ ذ وژْرُو\add* ذ إِمْزِيڒنْ. وَارْ إِجِّي ؤُڒَا ذ إِجّْ مْغِيرْ إِمزْڒَاضْ ن ڒْڭنْسْ ن ثمُّورْثْ.  
\v 15 نتَّا إِنْذهْ يَاهُويَاكِينْ غَارْ بَابِيلْ. يمَّاسْ ن ؤُجدْجِيذْ ذ ثمْغَارِينْ ن ؤُجدْجِيذْ ذ إِمْسخَّارنْ نّسْ إِشنّْعنْ ذ مَارَّا أَيْثْ ن جّهْذْ ذِي ثمُّورْثْ يِيوْيِي ثنْ ذِي لْمنْفَا زِي ؤُرْشَالِيمْ غَارْ بَابِيلْ. \x ◘ \xo 24:‏15 \xt 2 إِم. 36‏:‏10؛ إِسْت. 2‏:‏6\x*  
\v 16 مَارَّا إِرْيَازنْ إِمحْضنْ، سبْعَا-أَڒَافْ \add ن يرْيَازنْ\add*، ؤُڒَا ذ إِنقَّاشنْ \add ن ؤُكشُّوضْ ذ وژْرُو\add* ذ إِمْزِيڒنْ، أَڒفْ \add ن يرْيَازنْ\add*، ذ مَارَّا \add أَبَارُّو\add* ن أَيْثْ ن بُو-ثغْرُوضْثْ إِنِّي إِتّْقدَّانْ خْ ؤُمنْغِي، أَقَا أَجدْجِيذْ ن بَابِيلْ إِنْذهْ إِ-ثنْ \add مَارَّا\add* ذِي لْمنْفَا غَارْ بَابِيلْ. \x ◘ \xo 24:‏16 \xt إِرْم. 52‏:‏28\x*  
\v 17 أَجدْجِيذْ ن بَابِيلْ إِڭَّا مَاتَّانْيَا،عمِّيسْ، ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ ؤُشَا إِبدّڒْ إِسمْ نّسْ غَارْ صِيذْقِييَا.\x ◘ \xo 24:‏17 \xt إِرْم. 37‏:‏1؛ 52‏:‏1\x*   
\b  
\m  
\s1 صِيذْقِييَا، أَجدْجِيذْ ن يَاهُوذَا  
\m
\v 18 صِيذْقِييَا \add ثُوغَا\add* غَارسْ وَاحِيثْ ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ حِيطَاشْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. يمَّاسْ قَّارنْ أَسْ حَامُوطَالْ، يدْجِيسْ ن إِرْمِييَا، زِي لِيبْنَا. \x ◘ \xo 24:‏18 \xt [2 إِم. 36‏:‏11‏-‏21، إِرْم. 52‏:‏1‏-‏30]\x*  
\v 19 نتَّا إِڭَّا مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، نِيشَانْ أَمْ مَامّشْ ث إِڭَّا يَاهُويَاقِيمْ.  
\v 20 زِي سِّيبّثْ ن وغْضَابْ ن سِيذِي، أَقَا إِمْسَارْ إِ ؤُرْشَالِيمْ ذ يَاهُوذَا أَڒَامِي ثنْ-إِ-د إِسّكّْ زِي زَّاثْ إِ وُوذمْ نّسْ. \add أَوَارْنِي أَسْ\add* إِغوّغْ صِيذْقِييَا خْ ؤُجدْجِيذْ ن بَابِيلْ.   
\b  
\b  
\m  
\c 25
\s1 يَاهُوذَا ذِي لْمنْفَا غَارْ بَابِيلْ  
\m
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثسْعَا ن ڒحْكَامثْ نّسْ، ذڭْ ؤُيُورْ وِيسّْعشْرَا، ذڭْ \add وَاسّْ\add* وِيسّْعشْرَا ن ؤُيُورْ، إِمْسَارْ أَقَا يُوسَا-د نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، غَارْ ؤُرْشَالِيمْ، نتَّا أَكْ-ذ مَارَّا ڒْعسْكَارْ نّسْ. إِحْصَارْ إِ-ت ؤُشَا نِيثْنِي قُووَّارنْ أَسْ س إِشْثْ ن ڒْڭعّْذثْ إِ ثْعسَّاسْثْ. \x ◘ \xo 25:‏1 \xt 2 إِم. 36‏:‏17 إِرْم. 32‏:‏2؛ 39‏:‏1؛ 52‏:‏4\x*  
\v 2 حْصَارنْ ثَانْذِينْثْ أَڒْ أَسڭّْوَاسْ وِيسّْ حِيطَاشْ ن ؤُجدْجِيذْ صِيذْقِييَا.  
\v 3 ذڭْ \add وَاسّْ\add* وِيسّْ ثسْعَا ن ؤُيُورْ \add وِيسّْ أَربْعَا\add* إِذْوڒْ ڒَاژْ إِمْغَارْ ذِي ثنْذِينْثْ أَڒَامِي وَارْ ثُوغِي \add عَاذْ\add* مَاشَّا غَارْ ڒْڭنْسْ ن ثمُّورْثْ. \x ◘ \xo 25:‏3 \xt إِرْم. 52‏:‏6\x*  
\v 4 \add خنِّي\add* ثتّْوَارْژْ ثنْذِينْثْ ؤُ مَارَّا إِعسْكَارِييّنْ أَروْڒنْ ذِي دْجِيڒثْ خْ وبْرِيذْ ن ثوَّارْثْ \add إِ إِدْجَانْ\add* جَارْ ثْنَاينْ ن ڒحْيُوضْ نِّي \add إِدْجَانْ\add* غَارْ وحْوِيشْ ن ؤُجدْجِيذْ، وَاخَّا إِكَالْذَانِييّنْ ثُوغَا قُووَّارنْ إِ ثنْذِينْثْ، ؤُشَا أَجدْجِيذْ يُويُورْ ذڭْ وبْرِيذْ ن ڒوْضَا.  
\v 5 \add مَاشَا\add* ڒْعسْكَارْ ن إِكَالْذَانِييّنْ ضْفَارنْ أَجدْجِيذْ ؤُ نِيثْنِي حَارْثنْ خَاسْ ذِي ڒوْضَاثْ ن أَرِيحَا ؤُ مَارَّا ڒْعسْكَارْ نّسْ بزّْعنْ ث خَاسْ.  
\v 6 طّْفنْ أَجدْجِيذْ ؤُشَا إِوْينْ ث غَارْ ؤُجدْجِيذْ ن بَابِيلْ، غَارْ رِيبْلَا، ؤُشَا حكْمنْ خَاسْ.  
\v 7 نِيثْنِي غَارْصنْ إِ إِحنْجِيرنْ ن صِيذْقِييَا زَّاثْ إِ ثِيطَّاوِينْ نّسْ، سّْذَارْغْڒنْ ثِيطَّاوِينْ ن صِيذْقِييَا ؤُشَا شَارْفنْ ث س ثْنَاينْ ن سّْنَاسڒْ ن نّْحَاسْ، إِوْينْ ث غَارْ بَابِيلْ.   
\m
\v 8 \add أَوَارْنِي أَسْ\add* ذڭْ ؤُيُورْ وِيسّْ خمْسَا، ذڭْ \add وَاسّْ\add* وِيسّْ خمْسَا ن ؤُيُورْ - ثُوغَا-ث ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْسعْطَاشْ ن نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ - يُوسَا-د نابُوزَارَاذَانْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، أَمْسخَّارْ ن ؤُجدْجِيذْ ن بَابِيلْ، ذِي ؤُرْشَالِيمْ.  
\v 9 إِسّشْمضْ ثَادَّارْثْ ن سِيذِي ذ ثَادَّارْثْ ن ؤُجدْجِيذْ ذ مَارَّا ثُوذْرِينْ ن ؤُرْشَالِيمْ ؤُڒَا كُوڒْ ثَادَّارْثْ ذ ثَامقّْرَانْثْ إِسَّارْغْ أَسْ ثِيمسِّي.  
\v 10 ڒحْيُوضْ إِ د-إِنّْضنْ إِ ؤُرْشَالِيمْغضْڒنْ ثنْ مَارَّا ڒْعسْكَارْ ن إِكَالْذَانِييّنْ نِّي \add د-يُوسِينْ أَكْ-ذ\add* ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ.  
\v 11 مِينْ إِشطّنْ زِي ڒْڭنْسْ نِّي إِتّْوَاجّنْ ذِي ثنْذِينْثْ، \add إِخْسْ أَذْ يِينِي\add* \add مَارَّا\add* إِنِّي ثُوغَا إِعْذُونْ غَارْ ؤُجدْجِيذْ ن بَابِيلْ ذ مِينْ إِشطّنْ زِي ڒْغَاشِي، إِنْذهْ إِ-ثنْ نابُوزَارَاذَانْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، غَارْ لْمنْفَا.  
\v 12 ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ إِجَّا مْغِيرْ شَا ن إِمزْڒَاضْ ن ثمُّورْثْ أَمْ أَيْثْ ن بُو-ثْزَايَارْثْ ذ إِفدْجَاحنْ.   
\m
\v 13 إِپِيلَارنْ ن نّْحَاسْ ذِي ثَادَّارْثْ ن سِيذِي ذ ثْكَارُّوثِينْ ذ ثْرِيمَانْثْ ن نّْحَاسْ نِّي ثُوغَا \add ذِينْ\add* غَارْ ثَادَّارْثْ ن سِيذِي، أَرْژِينْ ثنْ إِكَالْذَانِييّنْ ؤُشَا أَرْبُونْ مَارَّا نّْحَاسْ غَارْ بَابِيلْ.\f ◼ \fr 25:‏13 \ft \+bd ’ثَارِيمَانْثْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒبْحَارْ‘ نِيغْ ’إِلْ‘.\f*  \x ◘ \xo 25:‏13 \xt 2 إِج. 20‏:‏17؛ إِرْم. 20‏:‏5؛ 27‏:‏19\x*  
\v 14 ؤُڒَا ذ ثِييْذُورِينْ، ذ إِغنْجَاينْ، ذ ثْجقَّاضِينْ، ذ ثْغنْجَايِينْ ؤُڒَا ذ مَارَّا ڒقْشُوعْ ن نّْحَاسْ إِ زِي ثُوغَا تّْسخَّارنْ، إِوْينْ ثنْ.  
\v 15 ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ يِيوِي-د ثِيمجْمَارِينْ ذ طَّاوْيَاثْ إِ ؤُرُوشِّي، \add مَارَّا\add* مِينْ \add ثُوغَا إِدْجَانْ\add* قَاعْ ن وُورغْ نِيغْ ن نُّوقَارْثْ.  
\v 16 \add ؤُڒَا ذ\add* ثْنَاينْ ن إِپِيلَارنْ ذ ثْرِيمَانْثْ ذ ثْكَارُّوثِينْ نِّي ثُوغَا إِڭَّا سُولِيمَانْ إِ ثَادَّارْثْ ن سِيذِي. ثُوغَا وَارْ إِزمَّارْ أَذْ وزْننْ نّْحَاسْ ن مَارَّا ڒقْشُوعْ-أَ.  
\v 17 ڒُْوعْڒَا ن إِجّْ ن ؤُپِيلَارْ ثُوغَا ذَايسْ ثْمنْطَاشْ ن إِغَادْجنْ، ؤُ تَّاجْ إِ خَاسْ، ثُوغَا ن نّْحَاسْ. ڒُْوعْڒَا ن تَّاجْ ثُوغَا-ث ثْڒَاثَا ن إِغَادْجنْ. ، ؤُ ثِيرَاشِّيوِينْ ذ إِرمَّامنْ إِ ذ أَسْ د-إِنّْضنْ إِ تَّاجْ ثُوغَا أَثنْ مَارَّا ن نّْحَاسْ. أَمُّو إِ ثُوغَا ؤُڒَا غَارْ ؤُپِيلَارْ وِيسّْ ثْنَاينْ، خْ ثْرَاشَّا إِ خَاسْ \add إِدْجَانْ\add*.\x ◘ \xo 25:‏17 \xt 1 إِج. 7‏:‏15؛ 2 إِم. 3‏:‏15؛ إِرْم. 52‏:‏21\x*   
\m
\v 18 يِيوِي-د ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ \add عَاوذْ\add* سَارَايَا، أَكهَّانْ أَمقّْرَانْ، ذ صَافَانْيَا، أَكهَّانْ وِيسّْ ثْنَاينْ، ؤُڒَا ذ ثْڒَاثَا ن إِعسَّاسنْ ن ثوَّارْثْ. \f ◼ \fr 25:‏18 \ft \+bd ’صَافَانْيَا‘\+bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي ث إِسّْنُوفَّارنْ سِيذِي‘.\f*  
\v 19 نتَّا يِيوِي-د إِجّْ ن ؤُمْسخَّارْ أَمْشنّعْ ونِّي إِتّْوَاڒقّْمنْ خْ إِعسْكَارِييّنْ ذ خمْسَا ن يرْيَازنْ إِمحْضنْ زڭْ إِمْثِيقَّانْ ن ؤُجدْجِيذْ، إِنِّي إِتّْوَافنْ ذِي ثنْذِينْثْ، \add جْمِيعْ\add* أَكْ-ذ ؤُمَارِيرْ ن ؤُكُومَانْذَارْ ن ڒْعسْكَارْ نِّي إِزمّمنْ ڒْڭنْسْ ن ثمُّورْثْ إِ ؤُمنْغِي، ؤُڒَا ذ ستِّينْ ن يرْيَازنْ زِي ڒْڭنْسْ ن ثمُّورْثْ نِّي إِتّْوَافنْ ذِي ثنْذِينْثْ.  
\v 20 يِيوِي ثنْ نابُوزَارَاذَانْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ ؤُشَا يُويُورْ أَكِيذْسنْ غَارْ ؤُجدْجِيذْ ن بَابِيلْ، غَارْ رِيبْلَا.  
\v 21 أَجدْجِيذْ ن بَابِيلْ إِوّثْ إِ-ثنْ، إِنْغَا إِ-ثنْ ذِي رِيبْلَا ذِي ثمُّورْثْ ن حَامَاثْ. \add أَمُّو إِ\add* إِتّْوَانْذهْ يَاهُوذَا زِي ثمُّورْثْ نّسْ غَارْ لْمنْفَا.  
\v 22 \add خْ\add* ڒْڭنْسْ إِ ثُوغَا إِقِّيمنْ ذِي ثمُّورْثْ ن يَاهُوذَا، إِ ثُوغَا إِجَّا \add ذِينْ\add* نابُوخَاذْنَاصَّارْ، أَجدْجِيذْ ن بَابِيلْ، أَقَا إِڭَّا خَاسنْ جَاذَالْيَا، مِّيسْ ن أَخِيقَامْ، مِّيسْ ن شَافَانْ. \x ◘ \xo 25:‏22 \xt إِرْم. 40‏:‏5، 9\x*  
\v 23 \add ؤُمِي\add* سْڒِينْ إِكُومَانْذَارنْ ن ڒْعسْكَارَاثْ، نِيثْنِي ذ يرْيَازنْ نْسنْ، بلِّي أَجدْجِيذْ ن بَابِيلْ إِڭَّا جَاذَالْيَا \add ذ أَوْكِيڒْ\add*، ؤُسِينْ-د نِيثْنِي غَارْ جَاذَالْيَا ذِي مِيصْفَا: إِسْمَاعِيلْ، مِّيسْ ن نَاثَانْيَا، يُوحَانَانْ، مِّيسْ ن قَارِيحَا، سَارَايَا، مِّيسْ ن ثَانْحُومَاثْ، أَنَاطُوفَاثِي، ذ يَازَانْيَاهُو، مِّيسْ ن ؤُمَاعْكِي، نِيثْنِي أَكْ-ذ يرْيَازنْ نْسنْ. \x ◘ \xo 25:‏23 \xt إِرْم. 40‏:‏7\x*  
\v 24 جَاذَالْيَا إِجُّودْجْ أَسنْ ؤُ إِ يرْيَازنْ نْسنْ، إِنَّا أَسنْ: ”وَارْ تّڭّْوْذمْ زڭْ إِمْسخَّارنْ ن إِكَالْذَانِييّنْ. قِّيممْ ذِي ثمُّورْثْ ؤُشَا سخَّارمْ إِ ؤُجدْجِيذْ ن بَابِيلْ، خنِّي أَذْ ثِيڒِيمْ مْلِيحْ.“   
\m
\v 25 \add مَاشَا\add* ذڭْ ؤُيُورْ وِيسّْ سبْعَا يُوسَا-د إِسْمَاعِيلْ، مِّيسْ ن نَاثَانْيَا، مِّيسْ ن إِلِيشَامَاعْ، \add ونِّي\add* د-إِقَّارْصنْ زڭْ ؤُجدْجِيذْ، أَكْ-ذعشْرَا ن يرْيَازنْ. نِيثْنِي وْثِينْ جَاذَالْيَا \add أَڒَامِي\add* إِمُّوثْ ؤُڒَا ذ إِيَاهُوذِييّنْ ذ إِكَالْذَانِييّنْ إِنِّي غَارسْ إِدْجَانْ ذِي مِيصْفَا.  
\v 26 \add خنِّي\add* إِكَّارْ مَارَّا ڒْڭنْسْ، أَمْ ؤُمژْيَانْ أَمْ ؤُمقّْرَانْ، ؤُڒَا ذ إِكُومَانْذَارنْ ن ڒْعسْكَارْ، فّْغنْ غَارْ مِيصْرَا، مِينْزِي ڭّْوذنْ زڭْ إِكَالْذَانِييّنْ.   
\b  
\m  
\s1 يَاهُويَاكِينْ إِطّفْ أَرْضَا ذِي بَابِيلْ  
\m
\v 27 ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا ؤُ-ثْڒَاثِينْ ن لْمنْفَا ن يَاهُويَاكِينْ، أَجدْجِيذْ ن يَاهُوذَا، ذڭْ ؤُيُورْ وِيسّْ ثنْعَاشْ، ذڭْ \add وَاسّْ\add* وِيسّْ سبْعَا ؤُ-عِيشْرِينْ ن ؤُيُورْ، إِمْسَارْ، أَقَا إِوِيلْ-مَارُوذَاخْ، أَجدْجِيذْ ن بَابِيلْ، ذڭْ ؤُسڭّْوَاسْ إِ ذِي إِذْوڒْ ذ أَجدْجِيذْ، إِضْڒقْ-د إِ يَاهُويَاكِينْ، أَجدْجِيذْ ن يَاهُوذَا، زِي ڒحْبسْ. \x ◘ \xo 25:‏27 \xt [إِرْم. 52‏:‏31‏-‏34]\x*  
\v 28 نتَّا إِسِّيوڒْ أَكِيذسْ س ڒضْرَافثْ ؤُ إِڭَّا ڒْكُورْسِي نّسْ ثِيوَا إِ ڒْكَارَاسِي ن إِجدْجِيذنْ نّغْنِي إِ ثُوغَا غَارسْ إِدْجَانْ ذِي بَابِيلْ.  
\v 29 إِبدّڒْ \add يَاهُويَاكِينْ\add* أَرُّوضْ نّسْ ن ڒحْبسْ ؤُشَا إِذْوڒْ إِتّتّْ ڒبْذَا غَارسْ مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّسْ.  
\v 30 خْ ڒْعُوتْشْ نّسْ، أَقَا إِمّوْشْ أَسْ زڭْ ؤُجدْجِيذْ ڒبْذَا إِجّْ ن ڒْعُوتْشْ أَقدَّا ن وَاسّْ خْ وَاسّْ نّسْ، مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّسْ.   