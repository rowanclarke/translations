\id PRO - Biblica® Open New Luo Translation 2020 
\h Ngeche 
\toc1 Ngeche 
\toc2 Ngeche 
\toc3 Nge 
\mt1 Ngeche 
\c 1  
\ms1 Gima omiyo nondik kitabu mar Ngeche kod thoro mare 
\p  
\v 1 Ngeche mag Solomon wuod Daudi, ruodh Israel: 
\q1  
\v 2 mamiyo iyudo rieko kod ritruok makare, 
\q2 kendo winjo tiend weche matut; 
\q1  
\v 3 kendo miyo idak e ngima moritore kendo mobidhore 
\q2 kitimo gima adiera kendo gima kare kendo mowinjore, 
\q1  
\v 4 gimiyo joma ngʼeyogi tin bedo mariek, 
\q2 kendo gimiyo jomatindo ngʼeyo tiend weche kendo pogo tiend wach. 
\q1  
\v 5 Mad jomariek chik itgi mondo owinji kendo gimedgi e puonjruokgi, 
\q2 to jogo mongʼeyo pogo tiend wach mad oyud gino ma chikogi, 
\q1  
\v 6 mondo gingʼe ngeche, sigendini, 
\q2 kod weche ma tiendgi tek mag jorieko. 
\b  
\q1  
\v 7 Luoro Jehova Nyasaye e chakruok mar ngʼeyo 
\q2 to joma ofuwo chayo rieko gi ritruok makare. 
\ms1 Weche motelo: Jip mar rwako rieko 
\s1 Siem kuom hoch manono 
\q1  
\v 8 Wuoda, chik iti ni puonj wuonu, 
\q2 kendo kik ijwangʼ puonj mar minu. 
\q1  
\v 9 Ginibedni kaka kondo michwowo e wiyi, 
\q2 kendo kaka thiwni miketo e ngʼuti mondo ineri maber. 
\b  
\q1  
\v 10 Wuoda, ka joricho hoyoi mondo itim marach, 
\q2 kik iyienegi. 
\q1  
\v 11 Kagiwachoni niya, “Bi idhi kodwa; 
\q2 mondo wabuti ni ngʼato wanegi, 
\q2 kendo wamonj kayiem nono joma onge ketho; 
\q1  
\v 12 mondo wamuonygi ngili ka bur liel 
\q2 mana ka joma omwony mangima gi bur; 
\q1  
\v 13 wabiro yudo gik moko duto mabeyo ma nengogi tek, 
\q2 mi wapongʼ utewa gi gik moyaki. 
\q1  
\v 14 In bende riwri kodwa e wachni, 
\q2 kendo wanapog gigo duto mwayako.” 
\q1  
\v 15 Wuoda, kik idhi kodgi ngangʼ 
\q2 kendo kik iwuoth e yoregigo, 
\q1  
\v 16 nikech tiendgi reto piyo piyo mar timo richo 
\q2 kendo gimwomore mondo gichwer remo. 
\q1  
\v 17 Mano kaka en gima nono chiko obadho 
\q2 ka winy duto neno. 
\q1  
\v 18 Jogi ochiko obadho ne gin giwegi, 
\q2 kendo gin ema ginimokie! 
\q1  
\v 19 Mano e giko jogo duto mohero yudo gimoro moyud e yo marach; 
\q2 gino kawo ngima jogo moyude. 
\s1 Siem kuom tamruok kawo rieko 
\q1  
\v 20 Rieko goyo koko matek e yore mag dala, 
\q2 ogoyo koko bende e kuonde chokruok; 
\q1  
\v 21 oywak kogoyo koko e akerkeke mag yore motimo koko, 
\q2 owuoyo e dhorangeye mag mier madongo kopenjo niya, 
\b  
\q1  
\v 22 “Nyaka karangʼo ma un joma ngʼeyogi tin nusik kuhero yoreu mag ngʼeyo matin?” 
\q2 Nyaka karangʼo ma jojaro pod nosik kamor, 
\q2 e jaro kendo joma ofuwo nosiki kochayo puonj? 
\q1  
\v 23 Ka dine uwinj siem mara, 
\q2 dine abedo kodu thuolo, 
\q2 kendo damiyo ungʼeyo pacha. 
\q1  
\v 24 To nikech ne udaga kane aluongo 
\q2 kendo onge ngʼama nodewa kane adwaro konyou, 
\q1  
\v 25 nimar ne udagi puonj maga duto 
\q2 kendo ne ok uwinjo siem mara. 
\q1  
\v 26 An to ananyieru bangʼe ka un e chandruok; 
\q2 Anajaru ajara ka masira oloyou, 
\q1  
\v 27 ka masira machalo yamb ahiti obiro kuomu, 
\q2 kendo ka chandruok oyweyou ka yamb kalausi. 
\q2 Ka lit kod thagruok ohingou. 
\b  
\q1  
\v 28 Giniluonga, to ok anadwokgi; 
\q2 ginimanya to ok giniyuda. 
\q1  
\v 29 Kaka ne ok gidwar puonj 
\q2 kendo ok negiyiero luoro Jehova Nyasaye, 
\q1  
\v 30 Kaka ne ok giyie gi puonjna 
\q2 kendo gidagi siem mara, 
\q1  
\v 31 kuom mano ginicham olemo mag yoregi 
\q2 kendo giniyiengʼ gi olemo mar riekogi maricho. 
\q1  
\v 32 Nikech yore mobam mag bayo mag jogo mangʼeyogi tin noneg-gi, 
\q2 kendo bedo ma ok odewo gimoro mar joma ofuwo notiekgi. 
\q1  
\v 33 To ngʼato angʼata mawinjo wachna nodag gi kwe 
\q2 kendo mayom, maonge luoro mar hinyruok. 
\c 2  
\s1 Ber mar dak mobidhore mar rieko 
\q1  
\v 1 Wuoda, ka iyie rwako wechena 
\q2 kendo kano chikena e chunyi; 
\q1  
\v 2 ka ichiko iti ni weche mag rieko 
\q2 kendo kiketo chunyi mondo iwinj tiend weche, 
\q1  
\v 3 to ka imanyo ngʼeyo malingʼ-lingʼ, 
\q2 kendo ikwayo ngʼeyo tiend wach, 
\q1  
\v 4 to ka idware ka fedha 
\q2 kendo imanye ka mwandu mopandi, 
\q1  
\v 5 eka iniwinj malongʼo tiend luoro Jehova Nyasaye, 
\q2 kendo iniyud rieko mar ngʼeyo Nyasaye. 
\q1  
\v 6 Jehova Nyasaye chiwo rieko 
\q2 kendo ngʼeyo gi winjo aa e dhoge. 
\q1  
\v 7 Oiko loch ni joma kare, 
\q2 en okumba ni jogo ma wuodhgi ler, 
\q1  
\v 8 nimar en okumba mar joma kare 
\q2 kendo orito yor joge ma jo-adiera. 
\b  
\q1  
\v 9 Ka iwinjo wachna, eka iningʼe gima kare, 
\q2 kendo mowinjore ma gin yore duto mabeyo. 
\q1  
\v 10 Nimar rieko nodonj e chunyi, 
\q2 kendo ngʼeyo nomi ngimani bedo mamor. 
\q1  
\v 11 Rieko mar pogo tiend wach noriti, 
\q2 kendo winjo tiend wach nobedni okumba. 
\b  
\q1  
\v 12 Rieko noresi kuom yore mag joma mono, 
\q2 kuom jogo mawacho weche mochido, 
\q1  
\v 13 jogo moweyo yore moriere mag bidhruok, 
\q2 mondo giwuothi e yore mag mudho, 
\q1  
\v 14 joma mor kuom timo maricho 
\q2 kendo giil e duwruok mar richo, 
\q1  
\v 15 jogo ma yoregi ogajore ogajore 
\q2 kendo gin jowuond e yoregi. 
\b  
\q1  
\v 16 Bende enoresi kuom dhako ma jachode, 
\q2 kuom dhako mabayo gi wechege maywayo ji, 
\q1  
\v 17 moseweyo chwore mane okende konyako, 
\q2 kendo oketho singruok mane otimo e nyim Nyasaye. 
\q1  
\v 18 Nikech ode tero ji e tho 
\q2 to yorene tero ji e piny joma otho. 
\q1  
\v 19 Onge ngʼato madhi ire maduogo 
\q2 kata yudo yor ngima. 
\b  
\q1  
\v 20 Kuom mano, iniluw yore joma beyo 
\q2 kendo irit yore joma kare. 
\q1  
\v 21 Nimar joma kare ema nodag e piny 
\q2 kendo jogo maonge bura ema nosiki e piny; 
\q1  
\v 22 to joma timbegi mono nogol oko e piny 
\q2 kendo jogo ma ok jo-adiera ok nobedie ngangʼ. 
\c 3  
\s1 Ber mamoko mag rieko 
\q1  
\v 1 Wuoda, kik wiyi wil kod puonjna 
\q2 to ket chikena osik e chunyi, 
\q1  
\v 2 nimar gibiro miyo ngimani dhi maber midag higni mangʼeny 
\q2 kendo ibed gi kwe kod mwandu. 
\b  
\q1  
\v 3 Kik iwe hera kod adiera weyi; 
\q2 twegi e ngʼuti, 
\q2 kendo ndikgi e chunyi maiye. 
\q1  
\v 4 Eka iniyud ngʼwono kod nying maber 
\q2 e nyim Nyasaye kod dhano. 
\b  
\q1  
\v 5 Gen kuom Jehova Nyasaye gi chunyi duto, 
\q2 kendo kik igen kuom ngʼeyoni iwuon; 
\q1  
\v 6 ket yoreni duto kuome 
\q2 eka nomi yoregi oriere tir. 
\b  
\q1  
\v 7 Kik ibed mariek e pachi iwuon 
\q2 to luor Jehova Nyasaye eka inilo richo. 
\q1  
\v 8 Tim ma kamano nomi ringri bedo gi ngima 
\q2 kendo nobed chiemo ne chunyi. 
\b  
\q1  
\v 9 Mi Jehova Nyasaye duongʼ gi mwanduni 
\q2 kichiwone cham mabeyo ma ikayo e puotheni; 
\q1  
\v 10 eka dechegi nopongʼ gi cham mogundho 
\q2 kendo agulnigi nopongʼ gi divai manyien maonge kama ikanoe. 
\b  
\q1  
\v 11 Wuoda, kik icha kum mar Jehova Nyasaye 
\q2 kendo kik ingʼur kokweri kuom gik maricho; 
\q1  
\v 12 nimar Jehova Nyasaye kumo jogo mohero 
\q2 mana kaka wuoro chiko wuode ma omorgo. 
\b  
\q1  
\v 13 En jahawi ngʼatno moyudo rieko, 
\q2 ngʼatno man-gi winjo, 
\q1  
\v 14 nimar en gohala moloyo fedha 
\q2 kendo okelo gik mabeyo moloyo dhahabu. 
\q1  
\v 15 Ober moloyo kite ma nengogi tek; 
\q2 onge gimoro amora migombo ma dipim kode. 
\q1  
\v 16 Ngima kuom ndalo mangʼeny ni e lwete korachwich; 
\q2 to e lwete koracham nitiere mwandu kod duongʼ. 
\q1  
\v 17 Yorene gin yore mag mor 
\q2 kendo yorene duto gin mag kwe. 
\q1  
\v 18 En yadh ngima ne jogo morwake; 
\q2 jogo mopadore kuome biro yudo gweth. 
\b  
\q1  
\v 19 Kuom rieko Jehova Nyasaye nochweyo mise mar piny 
\q2 kendo noketo polo kama entie kuom lony mare; 
\q1  
\v 20 kuom ngʼeyo mare ema nopogogo aore gi nembe, 
\q2 kendo nomiyo boche polo okelo thoo. 
\b  
\q1  
\v 21 Wuoda, rit ngʼado bura makare kod pogo tiend wach, 
\q2 kik iwe gilalni. 
\q1  
\v 22 Ginibedni ngima maber, 
\q2 ka tigo maber mitweyo e ngʼuti. 
\q1  
\v 23 Eka ibiro dhi e yoreni gi kwe 
\q2 kendo tiendi ok nochwanyre; 
\q1  
\v 24 ka inindo, to ok inibed maluor, 
\q2 kendo ininind mayom nyaka piny ru. 
\q1  
\v 25 Kik ibed giluoro mar masira ma ditimreni apoya nono 
\q2 kata kethruok mamako jogo maricho, 
\q1  
\v 26 nimar Jehova Nyasaye ema nomi ibed jachir 
\q2 kendo norit tiendi mondo kik odonji e obadho. 
\b  
\q1  
\v 27 Kik iwe timo maber ni jogo mowinjorego, 
\q2 ka in kod nyalo mar timo kamano. 
\q1  
\v 28 Ka inyalo konyo wadu kawuono, 
\q2 to kik iwachne niya, 
\q2 “Dogi iduog bangʼe kiny, eka akonyi.” 
\q1  
\v 29 Kik ichan hinyo jabathi, 
\q2 modak machiegni kodi gi kwe. 
\q1  
\v 30 Kik ihangne ngʼato wach maonge gima omiyo, 
\q2 kaonge gima rach mosetimoni. 
\b  
\q1  
\v 31 Kik nyiego maki gi ja-mahundu, 
\q2 kata wuotho e yore moro amora. 
\b  
\q1  
\v 32 Nimar Jehova Nyasaye ger gi jaricho 
\q2 to ogeno joma kare. 
\q1  
\v 33 Kwongʼ mar Jehova Nyasaye ni e od jaricho, 
\q2 to ogwedho dala ngʼat makare. 
\q1  
\v 34 Ojaro jojaro masungore 
\q2 to ochiwo ngʼwono ni joma obolore. 
\q1  
\v 35 Joma riek yudo luor kaka girkeni 
\q2 to joma ofuwo enonyis wichkuotgi ayanga. 
\c 4  
\s1 Ohala miyudo kuom bedo gi rieko 
\q1  
\v 1 Yawuota, winjuru puonj mag wuonu; 
\q2 chikuru itu eka ubed gi ngʼeyo moloyo. 
\q1  
\v 2 Puonj mara mamiyou beyo, 
\q2 omiyo kik ujwangʼ puonjna. 
\q1  
\v 3 Kane pod an wuowi e od wuora, 
\q2 kane pod an rawera kendo nyathi achiel kende mar minwa, 
\q2  
\v 4 nopuonja kowacho niya, 
\q1 “Mak matek wechena gi chunyi duto, 
\q2 rit chikena eka inibed mangima. 
\q1  
\v 5 Yud rieko kod ngʼeyo matut, 
\q2 wiyi kik wil kod wechena kata weyogi. 
\q1  
\v 6 Kik ijwangʼ rieko to obiro bedoni ragengʼ; 
\q2 here, to obiro ritoi. 
\q1  
\v 7 Rieko nigi duongʼ moloyo, omiyo yud rieko. 
\q2 Kata obedo ni mwanduni duto nyalo rumo, 
\q2 to bed gi winjo tiend wach. 
\q1  
\v 8 Miye duongʼ, to enotingʼi malo; 
\q2 rwake chutho, to obiro miyi duongʼ. 
\q1  
\v 9 Enoket ogut ngʼwono e wiyi 
\q2 kendo nosidhni osimbo mar duongʼ.” 
\b  
\q1  
\v 10 Wuoda, winji kendo yie gima awacho 
\q2 eka higni mag ngimani nobed mangʼeny. 
\q1  
\v 11 Apuonji e yor rieko 
\q2 kendo anyisi yo makare. 
\q1  
\v 12 Ka iwuotho, to ok inikier 
\q2 bende ka iringo, to ok inichwanyri. 
\q1  
\v 13 Mak motegno gima isepuonjori, 
\q2 kik iweye, olalni to irite maber, nikech en e ngimani. 
\q1  
\v 14 Kik iwuothi e yor joma timbegi mono 
\q2 kata kik iluw yor jomaricho. 
\q1  
\v 15 Bed mabor gi yorno, kik iwuothie, 
\q2 to wichri kendo iluw yori iwuon. 
\q1  
\v 16 Nikech ok ginyal nindo nyaka gitim gima mono; 
\q2 ayula wangʼ bende ok nyal terogi kapok gimiyo ngʼato opodho. 
\q1  
\v 17 Timbe mamono e chiembgi ma gichamo, 
\q2 to timbe ja-mahundu e divai ma gimadho. 
\b  
\q1  
\v 18 Yor joma kare chalo ka ugwe mar kogwen, 
\q2 omedo rieny maler nyaka chiengʼ wuogi. 
\q1  
\v 19 To yor joricho chalo gi mudho mandiwa; 
\q2 ok gingʼeyo gima miyo gichwanyore. 
\b  
\q1  
\v 20 Wuoda, chik iti malongʼo ne gima awacho, 
\q2 chik iti maber ne wechena. 
\q1  
\v 21 Kik iwe gilal e wangʼi 
\q2 to kan-gi e chunyi; 
\q1  
\v 22 nikech gikelo ngima ni jogo moyudogo 
\q2 kendo gin gi ngima maber ne ringre dhano duto. 
\q1  
\v 23 To moloyo duto, rit chunyi, 
\q2 nikech en e soko mar ngima. 
\q1  
\v 24 Wach ma ok adiera kik aa e dhogi; 
\q2 weche mag miganga kik wuogi e dhogi. 
\q1  
\v 25 Rang mana nyimi tir, 
\q2 ka ichomo wangʼi moriere tir e nyimi. 
\q1  
\v 26 Rie yore tir monego iluw 
\q2 kendo luw mana yore motegno. 
\q1  
\v 27 Kik ibar kidhiyo korachwich kata koracham; 
\q2 rit tiendi mondo kik idonji e richo. 
\c 5  
\s1 Siem kuom terruok 
\q1  
\v 1 Wuoda, chik iti malongʼo ne riekona, 
\q2 mondo iwinj maber puonj mago mopondo, 
\q1  
\v 2 eka isik kingʼeyo pogo tiend weche 
\q2 kendo dhogi norit rieko. 
\q1  
\v 3 Nimar dho jachode wacho weche mamit ka mor kich, 
\q2 kendo wuoyone yom maloyo moo; 
\q1  
\v 4 to gikone okech ka kedhno 
\q2 kendo obith ka ligangla ma dhoge ariyo. 
\q1  
\v 5 Tiendene ochomo kar tho, 
\q2 to ondamo mage ochiko bur tir. 
\q1  
\v 6 Ok opar ngangʼ yor ngima; yorene ogondore, 
\q2 to ok ongʼeyo kamano. 
\b  
\q1  
\v 7 Omiyo koro un yawuota, winjauru, 
\q2 kik uwe gima awachonu. 
\q1  
\v 8 Bed mabor gi dhako ma kamano, 
\q2 kendo kik idhi machiegni gi dhoode, 
\q1  
\v 9 nono to jomoko nono ema inimi tekreni maber moloyo 
\q2 kendo higni magi norum e lwet joma ger, 
\q1  
\v 10 nono to jomoko nono, ema nocham mwanduni 
\q2 kendo tichni matek nokony od ngʼat moro nono. 
\q1  
\v 11 To e giko mar ngimani inichur achura, 
\q2 ka ringri gi dendi chamore rumo. 
\q1  
\v 12 To iniwachi niya, “Mano kaka nasin gi puonj mar rieko! 
\q2 Mano kaka chunya nokwedo siem mane omiya kuom gik mane atimo ma ok nikare! 
\q1  
\v 13 Ne ok anyal winjo kendo timo weche jopuonjna, 
\q2 kata chiko ita ni jopuonjna. 
\q1  
\v 14 Asechopo e giko mar kethruok marach 
\q2 e dier chokruok mangima.” 
\b  
\q1  
\v 15 Modh pi moa e dapigi iwuon, 
\q2 pi mamol moa e sokoni iwuon. 
\q1  
\v 16 Bende ber mondo soknigi omol ka oo oko e yore mag dala, 
\q2 kata aoregi mag pi e kuonde chokruok manie dier dala? 
\q1  
\v 17 Ne ni gibedo magi iwuon 
\q2 kendo kik iriwgi gi joma galagala. 
\q1  
\v 18 Sokoni mondo ogwedhi, 
\q2 kendo ibed mamor gi chiegi mane ikendo ka in wuowi. 
\q1  
\v 19 Ojaber ka mwanda, kendo olongʼo ka nyakech, 
\q2 thundene mad romi kinde duto, mad herane omaki moloyo. 
\q1  
\v 20 Wuoda, ere gima omiyo jachode dikaw paroni? 
\q2 Ere gima omiyo chie ngʼato nono dilombi? 
\b  
\q1  
\v 21 Yore mag dhano nenore ratiro e nyim Jehova Nyasaye, 
\q2 kendo onono kamoro amora ma odhiyoe. 
\q1  
\v 22 Timbe mamono mag ngʼama jaricho obedone obadho mamake, 
\q2 tonde mag richone tweye matek. 
\q1  
\v 23 Obiro tho nikech ok oyie mondo orieye, 
\q2 obayo yo nikech fupe maduongʼ. 
\c 6  
\s1 Siem kuom fuwo 
\q1  
\v 1 Wuoda, ka isechiwo singo ni jabathi, 
\q2 kata ka isingori ni inichul ni ngʼat mikia gope, 
\q1  
\v 2 ka diponi omaki nikech gima ne iwacho, 
\q2 mi idwodori kod weche mane oa e dhogi, 
\q1  
\v 3 to tim kama, wuoda, mondo ibed thuolo, 
\q2 nikech isepodho e lwet jabathi: 
\q1 Dhiyo kendo ibolri e nyime; 
\q2 bangʼe to ikwa jabathino oweyi thuolo! 
\q1  
\v 4 Kik iwe nindo ohingi, 
\q2 kata ayula wangʼ oteri. 
\q1  
\v 5 To resri ibed thuolo, mana kaka mwanda mayombo jadwar, 
\q2 kata kaka winyo matony e obadho mar jamak winy. 
\b  
\q1  
\v 6 In janyawo, dhi ir biye; 
\q2 mondo ineye kendo ipar yoregi, mondo ibed mariek! 
\q1  
\v 7 Biye onge jatelo 
\q2 kata jaloch kata ruoth, 
\q1  
\v 8 to kata kamano, gikano chiembgi e ndalo oro, 
\q2 kendo gichoko chiembgi e ndalo keyo. 
\b  
\q1  
\v 9 In jasamuoyo, nyaka karangʼo ma ibiro bedo kinindo aninda kanyo? 
\q2 Karangʼo mibiro chiewoe mondo ia e nindo? 
\q1  
\v 10 Nindo matin, ayula wangʼ matin, 
\q2 kwakruok matin kiyweyo, 
\q1  
\v 11 to dhier biro monji ka janjore 
\q2 kendo chan ka jalweny momanore. 
\b  
\q1  
\v 12 Ngʼat mamono kendo jaricho 
\q2 mawuotho awuotha kowacho weche mogak, 
\q2  
\v 13 oningʼo wangʼe, 
\q2 owuoyo gi tiendene ka ogoro piny, 
\q2 kendo ogwelo ji gi lith lwetene, 
\q2  
\v 14 ochano richo kod miriambo ei chunye, 
\q2 kinde duto okelo miero. 
\q1  
\v 15 Kuom mano, masira biro make maloye apoya nono; 
\q2 notieke apoya nono, maonge resruok. 
\b  
\li1  
\v 16 Nitie gik moko auchiel ma Jehova Nyasaye mon-go, 
\li2 chutho gin gik moko abiriyo ma ok more: 
\li3  
\v 17 wenge mag sunga, 
\li3 lep mariambo, 
\li3 lwedo machwero remo maonge ketho, 
\li3  
\v 18 chuny machano chenro maricho, 
\li3 tiende maringo kadhi e richo, 
\li3  
\v 19 jahang wach mawacho miriambo 
\li3 kendo ngʼatno makelo miero e kind jowete. 
\s1 Siem kuom terruok 
\q1  
\v 20 Wuoda, rit chike wuonu 
\q2 kendo kik iwe puonj minu. 
\q1  
\v 21 Kan-gi ka ipandogi e chunyi nyaka chiengʼ; 
\q2 twegi e ngʼuti motegno. 
\q1  
\v 22 Ka iwuotho, to gibiro chiki; 
\q2 to ka inindo, to giniriti; 
\q2 to ka ichiewo, to giniwuo kodi. 
\q1  
\v 23 Nikech chikegi gin taya, 
\q2 to puonjni en ler, 
\q1 kendo kwer mikwerogo ngʼato kuom gima otimo marach 
\q2 kelo mana ngima, 
\q1  
\v 24 mamiyo ibedo mabor gi dhako mandhaga kaachiel 
\q2 gi lep mayom mar dhako mabayo. 
\b  
\q1  
\v 25 Kik ber mare mineno gi wangʼ omi chunyi gombe 
\q2 kata weye oywayi kolombi gi wangʼe. 
\b  
\q1  
\v 26 Nikech ochot nyalo miyo ibed matin maromo gi nengo makati, 
\q2 to dhako ma jachode biro tieko ngimani. 
\q1  
\v 27 Bende ngʼato nyalo tingʼo mach e kore, 
\q2 ma lepe ok owangʼ? 
\q1  
\v 28 Bende ngʼato nyalo wuotho e mirni mar mach maliel, 
\q2 ma ok tiendene owangʼ? 
\q1  
\v 29 Ma e kaka ngʼat ma terore gi chi ngʼat machielo chalo; 
\q2 ngʼato angʼata ma omule ok notony ma ok okum. 
\b  
\q1  
\v 30 Ji ok cha jakuo kokwalo chiemo 
\q2 mondo ogaago kech kodenyo. 
\q1  
\v 31 Kata kamano ka omake, to nyaka ochul nyadibiriyo, 
\q2 kata obedo ni en nengo mapek kuome makawo mwandu mag ode duto. 
\q1  
\v 32 To ngʼat ma terore gi chi ngʼat machielo onge gi rieko, 
\q2 ngʼat matimo kamano ketho ngimane owuon. 
\q1  
\v 33 Pokne en chwat kod wichkuot 
\q2 kendo nobed gi wichkuot ma ok norum. 
\b  
\q1  
\v 34 Nimar nyiego mamako chwor dhakono nyalo kelo tho, 
\q2 omiyo ka ochulo kuor, to nobed maonge ngʼwono kata matin. 
\q1  
\v 35 Ok enoyie chudo moro amora; 
\q2 ok enoyie asoya kata obedo ni en gima duongʼ manade. 
\c 7  
\s1 Siem kuom dhako ma jachode 
\q1  
\v 1 Wuoda, rit wechena 
\q2 kendo ipand chikena e chunyi. 
\q1  
\v 2 Rit chikena to ibiro bedo mangima; 
\q2 rit puonjna mana kaka dirit tong wangʼi. 
\q1  
\v 3 Twegi e lith lweti kendo ndikgi e chunyi maiye. 
\q1  
\v 4 Wach ne rieko niya, “In e nyaminwa,” 
\q2 to luong ngʼeyo tiend wach ni watni; 
\q1  
\v 5 ginimi itangʼ ni dhako ma jachode, 
\q2 inibed mabor gi dhako mabayo kaachiel, 
\q2 kod wechene malombo ji. 
\b  
\q1  
\v 6 Ka nangʼicho oko 
\q2 gie dirisa mar oda, 
\q1  
\v 7 ne aneno e dier joma ngʼeyogi tin, 
\q2 ne afwenyo e dier yawuowi matindo, 
\q2 rawera maonge gi rieko. 
\q1  
\v 8 Ne owuotho e wangʼ yo makadho but od dhakono, 
\q2 kowuotho kochiko od dhakono, 
\q1  
\v 9 ka piny ngʼiringʼiri, ka piny dwaro yuso, 
\q2 e kindeno ma mudho mako piny. 
\b  
\q1  
\v 10 Eka apoya nono dhakono nowuok mondo oromne, 
\q2 korwakore kaka ochot mopongʼ gi paro marach. 
\q1  
\v 11 En dhako ma wangʼe tek kendo maonge wichkuot, 
\q2 tiendene susni ma ok obed e ot; 
\q1  
\v 12 sani onene e yo, to bangʼ sa matin en kuonde chokruok, 
\q2 kendo e kuonde mopondo duto oyudore. 
\q1  
\v 13 Omiyo nokwake mi onyodhe, 
\q2 gi wangʼ matek, nowachone niya: 
\b  
\q1  
\v 14 “An gi misango mar lalruok e oda, 
\q2 kawuononi asechopo singruok maga. 
\q1  
\v 15 Omiyo ne abiro mondo arom kodi, 
\q2 asemanyi to koro aseyudi! 
\q1  
\v 16 Asepedho kitandana 
\q2 gi suke mokikokiko moa Misri. 
\q1  
\v 17 Asekiro moo e kitandana, 
\q2 gin modhi mangʼeny mangʼwe ngʼar gi mane-mane kod obala ndago. 
\q1  
\v 18 Bi, wadhi wayud mor mar hera nyaka piny ru, 
\q2 mondo wabed mamor ka wawinjo maber e hera! 
\q1  
\v 19 Chwora ok nitiere dala; 
\q2 osedhiyo e wuoth mabor. 
\q1  
\v 20 Nokawo mifukone mopongʼ gi pesa, 
\q2 kendo ok obi duogo dala nyaka bangʼ ndalo mogwarore.” 
\b  
\q1  
\v 21 Kamano, dhakono nowuonde gi weche mamit; 
\q2 mi nohoye kendo odhi kode. 
\q1  
\v 22 Gikanyono noluwe kodhi kode 
\q2 mana ka rwadh bwoch mitero kar yengʼo, 
\q1 kata ka mwanda madonjo e obeto 
\q2  
\v 23 nyaka asere chwowe mahob chunye, 
\q1 kata ka winyo madhiyo e obadho ma ochikne, 
\q2 ka ok ongʼeyo ni ngimane ni e tho! 
\b  
\q1  
\v 24 Koro un yawuota winjauru, 
\q2 chikuru itu ne gima awacho. 
\q1  
\v 25 Kik uyie mondo chunyu odhi e yorene, 
\q2 kata bayo e yorene. 
\q1  
\v 26 Oseketho ngima ji mangʼeny, 
\q2 kendo osemiyo ji mathoth mak kwanre otho. 
\q1  
\v 27 Ode en yo malach matero ji e liel, 
\q2 otelo ni ji koterogi e kuonde mag tho. 
\c 8  
\s1 Luong mar rieko 
\q1  
\v 1 Donge rieko luongo? 
\q2 Donge ngʼeyo tiend wach tingʼo dwonde ka goyo koko? 
\q1  
\v 2 Ochungʼ e kuonde motingʼore e bath yo, 
\q2 e akerkeke mag yore. 
\q1  
\v 3 Oywak matek e bath dhorangeye 
\q2 midonjogo e dala maduongʼ, 
\q1  
\v 4 kowacho niya, “Aluongou, yaye un ji, 
\q2 aluongou un ji duto manie piny. 
\q1  
\v 5 Un joma ngʼeyogi tin, nwangʼuru rieko; 
\q2 to un joma ofuwo, nwangʼuru ngʼeyo. 
\q1  
\v 6 Winjuru, nikech an gi gik mabeyo mangʼeny madwaro nyisou; 
\q2 ayawo dhoga mondo awach gima kare. 
\q1  
\v 7 Dhoga wacho gima adiera 
\q2 nikech dhoga kwedo gik maricho. 
\q1  
\v 8 Weche duto mawuok e dhoga gin kare, 
\q2 onge moro kuomgi mobam kata modwanyore. 
\q1  
\v 9 Ne jogo mongʼeyo pogo tiend wach, 
\q2 gigi duto nikare, giber ni jogo man-gi ngʼeyo. 
\q1  
\v 10 Yier puonjna kar fedha 
\q2 kendo ngʼeyo kar dhahabu mowal, 
\q1  
\v 11 nikech rieko ber moloyo kite ma nengogi tek, 
\q2 kendo gimoro amora madiher ok nyal romo kode. 
\b  
\q1  
\v 12 “An, rieko, wadak kaachiel gi ngʼado bura makare; 
\q2 an-gi ngʼeyo kod pogo tiend wach. 
\q1  
\v 13 Luoro Jehova Nyasaye en sin gi richo; 
\q2 amon gi sunga kod ngʼayi, 
\q2 timbe maricho kod wuoyo mochido. 
\q1  
\v 14 Ngʼado rieko kod ngʼado bura malongʼo gin maga; 
\q2 an-gi winjo tiend wach kod nyalo. 
\q1  
\v 15 An ema amiyo ruodhi locho 
\q2 kendo joloch loso chike makare. 
\q1  
\v 16 Nikech an, amiyo yawuot ruodhi loch 
\q2 kod joka ruodhi duto marito pinje. 
\q1  
\v 17 Ahero jogo mohera, 
\q2 to jogo ma manya yuda. 
\q1  
\v 18 Mwandu gi luor ni kuoma, 
\q2 mwandu mochwere kod mewo. 
\q1  
\v 19 Olemba ber moloyo dhahabu maber, 
\q2 gino machiwo oloyo fedha moyier. 
\q1  
\v 20 Awuotho e yo mobidhore makare, 
\q2 e yore mag bura makare, 
\q1  
\v 21 kachiwo mwandu ni jogo mohera 
\q2 kendo amiyo kuondegi mag keno bedo mopongʼ chutho. 
\b  
\q1  
\v 22 “Jehova Nyasaye nokwongo chweya 
\q2 kaka tichne mokwongo motelo ni tijene machon. 
\q1  
\v 23 Noyiera aa chakruok manyaka chiengʼ, 
\q2 kapok piny kobetie. 
\q1  
\v 24 Kapok nembe kobetie, 
\q2 nonywola kata ka sokni mopongʼ gi pi ne onge. 
\q1  
\v 25 Nonywola ka gode madongo ne pok obedo kuonde ma gintie, 
\q2 bende ka gode matindo ne pod onge, 
\q1  
\v 26 kapok ne ochweyo piny kaachiel gi pewene 
\q2 kata mana lowo mar piny. 
\q1  
\v 27 Ne antie kane oketo polo kama entie, 
\q2 kata kane oketo giko mar nembe, 
\q1  
\v 28 kane oketo boche polo malo, 
\q2 kendo kane oketo sokni mag nembe mogurore motegno, 
\q1  
\v 29 kane ochiwo kuonde giko mag nam matin 
\q2 mondo pi kik okadh kama oketee, 
\q1 kendo kane oloso mise mar piny. 
\q2  
\v 30 Ne an jatich molony mobedo bute. 
\q1 Napongʼ gi mor mogundho odiechiengʼ ka odiechiengʼ 
\q2 kamor e nyime kinde duto, 
\q1  
\v 31 ka amor e pinye mangima 
\q2 kendo ail gi ji duto. 
\b  
\q1  
\v 32 “Omiyo koro yawuota, winjauru; 
\q2 gin johawi jogo morito yorena. 
\q1  
\v 33 Winjuru puonjna mondo ubed mariek, 
\q2 kik uchagi. 
\q1  
\v 34 En jahawi ngʼat mawinja, 
\q2 marito pile e dhoutena korito e dhorangaya. 
\q1  
\v 35 Nimar ngʼat monwangʼa oyudo ngima 
\q2 kendo oyudo ngʼwono kuom Jehova Nyasaye. 
\q1  
\v 36 To ngʼatno ma odaga hinyore kende owuon; 
\q2 jogo duto mamon koda ohero tho.” 
\c 9  
\s1 Luong mag rwako rieko kod mag fuwo 
\q1  
\v 1 Rieko osegero ode, 
\q2 osechungo sirnige abiriyo. 
\q1  
\v 2 Oseiko ringe kendo oloso divai mare moru mamit, 
\q2 bende osepedho mesa mare. 
\q1  
\v 3 Oseoro jotichne ma nyiri, kendo oluongo ji 
\q2 ka en kuonde motingʼore e dala maduongʼ. 
\q1  
\v 4 “Weuru ji duto mangʼeyogi tin obi kae!” 
\q2 Owacho ni jogo maonge gi rieko mar ngʼado bura. 
\q1  
\v 5 Biuru, chamuru chiemba 
\q2 kendo madhuru divai ma aseruwo. 
\q1  
\v 6 Weuru yoreu maonge rieko, eka unubed mangima, 
\q2 wuothuru e yor winjo kod ngʼeyo. 
\b  
\q1  
\v 7 Ngʼat marieyo ja-ajara luongo mana wichkuot, 
\q2 ngʼat makwero ngʼat marach yudo mana ayany. 
\q1  
\v 8 Kik ikwer ngʼat ma jaro ji, nikech mano biro miyo obedo mamon kodi, 
\q2 kirieyo ngʼat mariek, to obiro heri. 
\q1  
\v 9 Puonj ngʼat mariek, to obiro bedo mariek moloyo, 
\q2 puonj ngʼat makare gimoro, to obiro medo puonjore. 
\b  
\q1  
\v 10 Luoro Jehova Nyasaye e chakruok mar rieko, 
\q2 to ngʼeyo Jal Maler miyo ngʼato ngʼeyo tiend wach. 
\q1  
\v 11 Nimar kuoma ndalogi biro bedo mangʼeny, 
\q2 kendo rieko biro medo hiki. 
\q1  
\v 12 Ka iriek, riekoni nomiyi ohala, 
\q2 ka ijajaro, to in iwuon ema ibiro hinyori. 
\b  
\q1  
\v 13 Dhako mofuwo en jakoko, 
\q2 ok oritore kendo ngʼeyone tin. 
\q1  
\v 14 Obedo e dhoode, 
\q2 e kom kama otingʼore mar dala maduongʼ, 
\q1  
\v 15 koluongo jogo makadho, 
\q2 madhi e yoregi. 
\q1  
\v 16 Owacho ni jogo maonge gi rieko mar ngʼado bura niya, 
\q2 “Weuru ji duto mangʼeyogi tin obi kae!” 
\q1  
\v 17 Nomedo wachonegi niya, “Pi mokwal mit, 
\q2 chiemo michamo apanda ema nigi ndhandhu moloyo!” 
\q1  
\v 18 To ok gingʼeyo kata matin ni joma otho ni kuno; 
\q2 bende ni joma lime ni e liel matut. 
\c 10  
\ms1 Ngeche mag Solomon 
\p  
\v 1 Ngeche mag Solomon: 
\q1 Wuowi mariek kelo mor ni wuon mare, 
\q2 to wuowi mofuwo miyo min mare chuny lit. 
\b  
\q1  
\v 2 Mwandu moyudi e yo marach onge gi ohala; 
\q2 to tim makare reso ji e tho. 
\b  
\q1  
\v 3 Jehova Nyasaye ok we ngʼat makare obed gi kech, 
\q2 to oketho gombo mar joricho. 
\b  
\q1  
\v 4 Lwedo manyap miyo ngʼato bedo jachan, 
\q2 to lwedo ma jakinda kelo mwandu. 
\b  
\q1  
\v 5 Ngʼat makayo cham e kinde oro en wuowi mariek, 
\q2 to ngʼat ma nindo kinde keyo en wuowi makwodo wich. 
\b  
\q1  
\v 6 Gweth sidho kondo mar loch ewi ngʼat makare, 
\q2 to timbe mahundu opongʼ e dho ngʼat marach. 
\b  
\q1  
\v 7 Paro miparogo ngʼat makare nobed gweth, 
\q2 to nying ngʼat marach nolal. 
\b  
\q1  
\v 8 Ngʼat mariek e chunye rwako chike, 
\q2 to ngʼat mofuwo ma wachne ngʼeny dhi e kethruok. 
\b  
\q1  
\v 9 Ngʼat mobidhore wuotho kaonge luoro, 
\q2 to ngʼatno maluwo yore mobam ibiro yudo mapiyo. 
\b  
\q1  
\v 10 Ngʼat madiemo wangʼe giwuond kelo kuyo, 
\q2 to ngʼat mofuwo ma wachne ngʼeny dhi e kethruok. 
\b  
\q1  
\v 11 Dho ngʼat makare en soko mar ngima, 
\q2 to timbe mahundu opongʼo dho ngʼat marach. 
\b  
\q1  
\v 12 Sigu kelo miero, 
\q2 to hera umo maricho duto. 
\b  
\q1  
\v 13 Rieko iyudo e dho jogo mongʼeyo tiend wach, 
\q2 to luth en mar ngʼe ngʼatno maonge gi rieko mar ngʼado bura. 
\b  
\q1  
\v 14 Joma riek okano ngʼeyo, 
\q2 to dho joma ofuwo kelo kethruok. 
\b  
\q1  
\v 15 Mwandu mar jomoko e ohinga mochiel motegno ma gigengʼorego, 
\q2 to dhier e kethruok mar jochan. 
\b  
\q1  
\v 16 Pok joma kare kelonegi ngima, 
\q2 to mwandu ma joricho yudo kelonegi kum. 
\b  
\q1  
\v 17 Ngʼat mawinjo weche mirieyego wuotho e yo madhiyo e ngima, 
\q2 to ngʼat motamore kethone tero ji mamoko e yor lal. 
\b  
\q1  
\v 18 Ngʼatno mapando sigu manie chunye, 
\q2 dhoge nigi miriambo, to ngʼatno ma jakwoth ofuwo. 
\b  
\q1  
\v 19 Ka weche ngʼeny, to richo ok nyal bare ma ok obetie, 
\q2 to ngʼat marito lewe oriek. 
\b  
\q1  
\v 20 Lew ngʼat makare en fedha mowal, 
\q2 to chuny ngʼat marach nigi ohala matin. 
\b  
\q1  
\v 21 Dho ngʼat makare konyo ji mangʼeny, 
\q2 to ngʼat mofuwo tho nikech rem mar ngʼeyo ngʼado bura. 
\b  
\q1  
\v 22 Gweth mar Jehova Nyasaye kelo mwandu, 
\q2 kendo ok omed chandruok kuome. 
\b  
\q1  
\v 23 Ngʼat mofuwo yudo mor e timbe maricho, 
\q2 to ngʼat man-gi winjo bedo mamor kuom rieko. 
\b  
\q1  
\v 24 Gima ngʼat marach oluoro biro loye; 
\q2 to gima ngʼat makare dwaro ibiro miye. 
\b  
\q1  
\v 25 Ka auka mager ofuto, to joricho otieko; 
\q2 to joma kare chungo motegno nyaka chiengʼ. 
\b  
\q1  
\v 26 Mana kaka kong awayo machamo lak kendo ka iro malungo wenge, 
\q2 e kaka jasamuoyo ni jogo moore. 
\b  
\q1  
\v 27 Luoro Jehova Nyasaye miyo idak amingʼa, 
\q2 to higni mar ngʼat marach ingʼado bedo machwok. 
\b  
\q1  
\v 28 Geno mar joma kare en mor, 
\q2 to geno mar joricho nolal nono. 
\b  
\q1  
\v 29 Yor Jehova Nyasaye e kar pondo ni joma kare, 
\q2 to en kethruok ni jogo matimo richo. 
\b  
\q1  
\v 30 Joma kare ok nopudh ngangʼ, 
\q2 to joricho ok nodongʼ e piny. 
\b  
\q1  
\v 31 Dho joma kare kelo rieko, 
\q2 to lep mar richo nongʼad oko. 
\b  
\q1  
\v 32 Lew joma kare ongʼeyo gima owinjore, 
\q2 to dho joricho wacho mana gik mochido. 
\b  
\c 11  
\q1  
\v 1 Jehova Nyasaye ok mor gi rapim ma ok nikare, 
\q2 to rapim makare ema omorgo. 
\b  
\q1  
\v 2 Ka sunga biro, eka wichkuot bende biro, 
\q2 to muolo biro kod rieko. 
\b  
\q1  
\v 3 Bidhruok mar joma kare telonegi, 
\q2 to joma ok jo-adiera kethore gi timbegi mag achach. 
\b  
\q1  
\v 4 Mwandu onge gi ohala e ndalo mar mirima, 
\q2 to tim makare reso ngʼato e tho. 
\b  
\q1  
\v 5 Tim makare mar joma kare maonge ketho loso yoregi moriere, 
\q2 to joricho podho nikech richogi. 
\b  
\q1  
\v 6 Tim makare mar joma kare resogi, 
\q2 to jogo ma ok jo-adiera imako gi gombogi maricho. 
\b  
\q1  
\v 7 Ka jaricho otho, to genone duto tho kode, 
\q2 gigo duto mane ogeno kuom tekone bedo nono. 
\b  
\q1  
\v 8 Ngʼat makare ireso kuom chandruok, 
\q2 to chandruok biro mana ni jaricho. 
\b  
\q1  
\v 9 Ngʼat ma ok ja-Nyasaye hinyo jabathe gi dhoge owuon, 
\q2 to rieko miyo ngʼat makare tony. 
\b  
\q1  
\v 10 Ka ngʼat makare mewo, dala maduongʼ bedo mamor, 
\q2 ka joricho otho, to nitie koko mar mor. 
\b  
\q1  
\v 11 Gweth mar joma kare kelo pak ne dala, 
\q2 to kuom dho joricho dala kethore. 
\b  
\q1  
\v 12 Ngʼat maonge gi rieko jaro jabathe, 
\q2 to ngʼat man-gi winjo rito lewe. 
\b  
\q1  
\v 13 Kuoth ketho genruok, 
\q2 to ngʼat ma ja-ratiro rito wach malingʼ-lingʼ. 
\b  
\q1  
\v 14 Oganda podho nimar onge puonj, 
\q2 to jongʼad rieko mangʼeny miyo loch mar adier bedo. 
\b  
\q1  
\v 15 Ngʼat machungʼ e gowi ni ngʼat mokia biro hinyore adier, 
\q2 to ngʼat motamore chungʼ e gowi ni ngʼat mokia okonyore. 
\b  
\q1  
\v 16 Dhako ma chunye ngʼwon yudo luor, 
\q2 to ji ma kitgi richo yudo mana mwandu kende. 
\b  
\q1  
\v 17 Ngʼat mangʼwon yudo ohala mana ne en owuon, 
\q2 to ngʼat makwiny kelo chandruok ni en owuon. 
\b  
\q1  
\v 18 Jaricho yudo ohala mar miriambo, 
\q2 to ngʼat machwoyo gima kare kayo pok mar adiera. 
\b  
\q1  
\v 19 Ngʼat man-gi tim makare kendo ma ja-adiera nobed mangima, 
\q2 to ngʼat maluwo richo dhiyo e thone. 
\b  
\q1  
\v 20 Jehova Nyasaye odagi jogo ma chunygi opongʼ gi richo, 
\q2 to omor gi jogo ma yoregi ler. 
\b  
\q1  
\v 21 Bed ka ingʼeyo ni jaricho ok notony ma ok okume, 
\q2 to jogo makare nobed thuolo. 
\b  
\q1  
\v 22 Mana ka tere mar dhahabu manie um anguro, 
\q2 e kaka dhako ma jaber maonge rieko chalo. 
\b  
\q1  
\v 23 Dwaro mar joma kare gik mana e ber kende, 
\q2 to geno mar joricho gik mana e mirima. 
\b  
\q1  
\v 24 Ngʼato achiel miyo ji ma ok odewo, 
\q2 to bende pod mwandu medorene moloyo, 
\q1 to ngʼat machielo kungo mokadhore, 
\q2 to ochopo mana e chan. 
\b  
\q1  
\v 25 Ngʼat mangʼwon biro bedo gi mwandu; 
\q2 to ngʼat makweyo chuny ji ibiro kwe chunye bende. 
\b  
\q1  
\v 26 Ji kwongʼo ngʼat mapando cham, 
\q2 to gweth bedo ni ngʼatno moyie golo chambe mondo ji ongʼiew kuome. 
\b  
\q1  
\v 27 Ngʼat madwaro ber winjo maber, 
\q2 to kethruok biro ni ngʼatno madware. 
\b  
\q1  
\v 28 Ngʼatno mogeno kuom mwandune biro podho; 
\q2 to joma kare nodhi nyime mana ka oboke mangʼich. 
\b  
\q1  
\v 29 Ngʼatno makelo chandruok ni joge ok nonwangʼ gimoro, 
\q2 to ngʼat mofuwo nobed misumba ngʼat mariek. 
\b  
\q1  
\v 30 Olemb joma kare en yadh ngima, 
\q2 to ngʼatno ma reso chunje riek. 
\b  
\q1  
\v 31 Ka joma kare yudo pokgi e piny, 
\q2 to joma ok oluoro Nyasaye gi joricho diyud mangʼeny maromo nadi! 
\b  
\c 12  
\q1  
\v 1 Ngʼat mohero puonj mar rieko ohero ngʼeyo, 
\q2 to ngʼat ma ok winj puonj ofuwo. 
\b  
\q1  
\v 2 Ngʼat maber yudo pwoch kuom Jehova Nyasaye, 
\q2 to Jehova Nyasaye kwero ngʼat ma timbene richo. 
\b  
\q1  
\v 3 Ngʼato ok nyal gerore motegno kuom richo, 
\q2 to ngʼat makare ok nyal pudhi. 
\b  
\q1  
\v 4 Dhako ma kite longʼo en osimbo mar chwore, 
\q2 to dhako ma timbene richo chalo gi nyamuoda manie choke. 
\b  
\q1  
\v 5 Chenro mar ngʼat makare nikare, 
\q2 to puonj mar joricho en wuondruok. 
\b  
\q1  
\v 6 Weche mag joricho opondo karito chwero remo, 
\q2 to wach mar joma kare resogi. 
\b  
\q1  
\v 7 Joricho osewiti kendo gilal nono, 
\q2 to od ngʼat makare osiko ogurore motegno. 
\b  
\q1  
\v 8 Ngʼato ipako kaluwore gi riekone, 
\q2 to jogo man-gi paro mobam ichayo. 
\b  
\q1  
\v 9 Ber bedo dhano adhana, to in gi jatich, 
\q2 moloyo wuondori ni in ngʼato, to ionge chiemo. 
\b  
\q1  
\v 10 Ngʼat makare chiwo kony ne gik ma jambe dwaro, 
\q2 to timbe mag ngʼwono mag ngʼat marach gin mana gero. 
\b  
\q1  
\v 11 Ngʼat matiyo e puothe biro bedo gi chiemo mogundho, 
\q2 to ngʼat mabayo abaya onge gi rieko. 
\b  
\q1  
\v 12 Joricho dwaro gik moyaki mag jogo mamono, 
\q2 to tiend joma kare kelo mwandu. 
\b  
\q1  
\v 13 Ngʼat marach imako mana gi wuoyone maricho, 
\q2 to ngʼat makare tony ne chandruok. 
\b  
\q1  
\v 14 Weche mabeyo mawuok e dho ngʼato miyo obedo gi gik mabeyo, 
\q2 adiera, tich mar lwete kelone konyruok. 
\b  
\q1  
\v 15 Yor ngʼat mofuwo nenorene ni nikare, 
\q2 to ngʼat makare chiko ite ne puonj. 
\b  
\q1  
\v 16 Ngʼat mofuwo nyiso mirimbe mapiyo, 
\q2 to ngʼat mariek mwonyo ayany. 
\b  
\q1  
\v 17 Janeno ma ja-adiera chiwo neno mobidhore, 
\q2 to janeno ma hango wach wacho miriambo. 
\b  
\q1  
\v 18 Weche mag muomruok chwoyo chuny mana kaka ligangla, 
\q2 to lew ngʼat mariek kelo ngima. 
\b  
\q1  
\v 19 Dhok ma ja-adiera osiko manyaka chiengʼ, 
\q2 to lep mariambo bedo mana kuom kinde machwok. 
\b  
\q1  
\v 20 Wuond ni e chuny jogo machano timo marach, 
\q2 to mor en mar jogo mohero kwe. 
\b  
\q1  
\v 21 Onge gima rach manyalo biro ni ngʼat makare; 
\q2 to joricho ni kod thagruok mathoth. 
\b  
\q1  
\v 22 Jehova Nyasaye mon kod dhok mariambo, 
\q2 to omor gi jogo ma jo-adiera. 
\b  
\q1  
\v 23 Ngʼat mariek orito ngʼeyone e iye, 
\q2 to chuny joma ofuwo wuoyo ma ok opimo. 
\b  
\q1  
\v 24 Tich matek miyo ngʼato bedo gi duongʼ, 
\q2 to nyawo gikone en tich mar misumba. 
\b  
\q1  
\v 25 Chuny maparore miyo ngʼato bedo mool, 
\q2 to wach mamuol jiwe. 
\b  
\q1  
\v 26 Ngʼat makare dak gi osiepene e yo mowinjore, 
\q2 to yor ngʼat marach terogi kama rach. 
\b  
\q1  
\v 27 Jasamuoyo ok nyal yudo dwarone, 
\q2 to jakinda maratego ongʼeyo ber gige. 
\b  
\q1  
\v 28 Yo makare nitie gi ngima, 
\q2 e yorno nitie ngima mochwere. 
\b  
\c 13  
\q1  
\v 1 Wuowi mariek winjo puonj wuon mare, 
\q2 to ngʼat ma wangʼe tek ok winj wach kikwere. 
\b  
\q1  
\v 2 Ngʼat makare yudo pok maber kaluwore gi gik mowacho, 
\q2 to ngʼatno ma ok ja-adiera nigi gombo mar miero. 
\b  
\q1  
\v 3 Ngʼatno morito dhoge orito ngimane, 
\q2 to ngʼatno ma wuoyo karodho wach biro dhiyo e kethruok. 
\b  
\q1  
\v 4 Jasamuoyo dwaro gimoro gi chunye duto to ok oyud gimoro, 
\q2 to jakinda yudo gik moko duto modwaro. 
\b  
\q1  
\v 5 Ngʼat makare mon kod gima ok adiera, 
\q2 to joricho kelo wichkuot kod dwanyruok. 
\b  
\q1  
\v 6 Tim makare rito ngʼat mobidhore, 
\q2 timbe maricho to tieko jaricho. 
\b  
\q1  
\v 7 Ngʼat moro wuondore ni en ja-mwandu, 
\q2 to adiera oonge gimoro; 
\q1 to ngʼat machielo wuondore ni en jachan, 
\q2 to adiera en gi mwandu mangʼeny. 
\b  
\q1  
\v 8 Mwandu ngʼato sa moro nyalo reso ngimane, 
\q2 to jochan onge gima bwogo. 
\b  
\q1  
\v 9 Ler mar ngʼat makare rieny maler, 
\q2 to taya mar ngʼat marach inego. 
\b  
\q1  
\v 10 Sunga nywolo mana dhawo, 
\q2 to rieko iyudo kuom jogo moyie puonj. 
\b  
\q1  
\v 11 Pesa moyud e yo ma ok kare lal nono, 
\q2 to ngʼat makano pesa matin matin miyo omedore. 
\b  
\q1  
\v 12 Gima igeno mobudho miyo chuny bedo matuo, 
\q2 to gima igeno motimore en yath mar ngima. 
\b  
\q1  
\v 13 Ngʼat ma jaro puonj biro yudo pokne, 
\q2 to ngʼat moluoro chik imiyo pok maber. 
\b  
\q1  
\v 14 Puonj mar ngʼat mariek en soko mar ngima 
\q2 ma reso ngʼato e obadho mag tho. 
\b  
\q1  
\v 15 Bedo gi winjo kelo luor, 
\q2 to yor ngʼato ma ok ja-adier tek. 
\b  
\q1  
\v 16 Ngʼato ka ngʼato mariek timo gik moko kuom ngʼeyo, 
\q2 to ngʼat mofuwo nyiso mana fupe. 
\b  
\q1  
\v 17 Jaote marach donjo e chandruok, 
\q2 to jaote modimbore kelo konyruok. 
\b  
\q1  
\v 18 Ngʼat modagi siem nwangʼo dhier kod wichkuot, 
\q2 to ngʼato angʼata mawinjo kikwere to yudo duongʼ. 
\b  
\q1  
\v 19 Geno mochopi en gima mit ne chuny, 
\q2 to joma ofuwo ok dwar aa e richo. 
\b  
\q1  
\v 20 Ngʼat mawuotho gi ngʼama riek bedo mariek, 
\q2 to osiep joma ofuwo hinyore. 
\b  
\q1  
\v 21 Chandruok luwo jaricho, 
\q2 to mwandu e ohand ngʼat makare. 
\b  
\q1  
\v 22 Ngʼat maber weyo mwandu ne nyithind nyithinde, 
\q2 to mwandu jaricho okan ni joma kare. 
\b  
\q1  
\v 23 Puoth ngʼat ma jachan sa moro nyalo nyago chiemo mangʼeny, 
\q2 to tim ma ok kare tiekogi duto. 
\b  
\q1  
\v 24 Ngʼat ma ok ti kod kede kuom chwado wuode, omon kod wuode, 
\q2 to ngʼat mohere bedo motangʼ mondo orieye. 
\b  
\q1  
\v 25 Joma kare chiemo moromo kaka chunygi dwaro, 
\q2 to ii ngʼat marach nigi kech. 
\b  
\c 14  
\q1  
\v 1 Dhako mariek gero ode, 
\q2 to dhako mofuwo muko ode gi lwete owuon. 
\b  
\q1  
\v 2 Ngʼat ma wuodhe oriere oluoro Jehova Nyasaye, 
\q2 to ngʼat ma yorene achach ochaye. 
\b  
\q1  
\v 3 Wuoyo mar ngʼama ofuwo kelone mana goch e ngʼeye, 
\q2 to dho jomariek bedonegi ragengʼ. 
\b  
\q1  
\v 4 Kama onge rwedhi, dipo bedo nono, 
\q2 to kama rwath nitiere keyo mangʼeny bedoe. 
\b  
\q1  
\v 5 Janeno ma ja-adiera ok riambi, 
\q2 to janeno ma hango wach wacho mana miriambo. 
\b  
\q1  
\v 6 Ngʼat ma jasunga nyalo dwaro rieko to ok oyud gimoro, 
\q2 ngʼeyo tiend wach to biro mayot ne ngʼat ma ongʼeyo pogo tiend weche. 
\b  
\q1  
\v 7 Bed mabor gi ngʼat mofuwo 
\q2 nimar ok iniyud ngʼeyo tiend wach e dhoge. 
\b  
\q1  
\v 8 Rieko mar jorieko en bedo gi paro ne yoregi, 
\q2 to fup joma ofuwo en wuondruok. 
\b  
\q1  
\v 9 Joma ofuwo jaro kowachnegi mondo giwe richo, 
\q2 to ngʼwono iyudo kuom joma kare. 
\b  
\q1  
\v 10 Chuny ka chuny ongʼeyo litne owuon, 
\q2 to onge ngʼato machielo manyalo bedo e mor ma en-go. 
\b  
\q1  
\v 11 Od ngʼat marach ibiro ketho 
\q2 to kar dak mar ngʼat makare biro dhiyo nyime. 
\b  
\q1  
\v 12 Nitie yo manenore ne dhano ni nikare, 
\q2 to gikone otero mana ngʼato e tho. 
\b  
\q1  
\v 13 Kata e kinde mar nyiero, chuny nyalo bedo gi lit, 
\q2 to mor nyalo gik e kuyo. 
\b  
\q1  
\v 14 Joma onge yie ibiro mi pok moromo gi timbegi, 
\q2 to ngʼat maber bende pok moromo kode. 
\b  
\q1  
\v 15 Ngʼat mangʼeyone tin thoro yie gimoro amora, 
\q2 to ngʼat mariek paro gik motimo. 
\b  
\q1  
\v 16 Ngʼat mariek oluoro Jehova Nyasaye kendo okwedo richo, 
\q2 to ngʼama ofuwo wiye tek kendo omuomore. 
\b  
\q1  
\v 17 Ngʼat ma iye wangʼ piyo timo gik mofuwo, 
\q2 to ngʼat ma ja-miganga ji mon-go. 
\b  
\q1  
\v 18 Joma ngʼeyogi tin nwangʼo fuwo, 
\q2 to jomariek irwako nigi ogut ngʼeyo. 
\b  
\q1  
\v 19 Joricho kulore e nyim joma beyo, 
\q2 to jo-ajendeke e dhorangeye mag joma kare. 
\b  
\q1  
\v 20 Jochan ok dwar kata gi jobutgi, 
\q2 to jo-mwandu nigi osiepe mangʼeny. 
\b  
\q1  
\v 21 Ngʼatno machayo jabute timo richo, 
\q2 to ogwedhi ngʼatno mangʼwon gi jogo mochando. 
\b  
\q1  
\v 22 Donge jogo machano marach lal nono? 
\q2 To jogo machano gima ber yudo hera kendo imiyogi luor. 
\b  
\q1  
\v 23 Tich matek duto kelo ohala, 
\q2 to wuoyo awuoya maonge tim kelo dhier. 
\b  
\q1  
\v 24 Mwandu jomariek e osimbo margi, 
\q2 to fup joma ofuwo nyago mana fuwo. 
\b  
\q1  
\v 25 Janeno ma ja-adiera reso ji e tho, 
\q2 to janeno ma hango wach en jawuond. 
\b  
\q1  
\v 26 Ngʼat moluoro Jehova Nyasaye nigi ohinga motegno, 
\q2 kendo nyithinde noyud kar pondo. 
\b  
\q1  
\v 27 Luoro Jehova Nyasaye en soko mar ngima, 
\q2 ma reso ngʼato e obadho mag tho. 
\b  
\q1  
\v 28 Ruoth ma joge ngʼeny ema yudo duongʼ, 
\q2 to ruoth maonge jogo morito to podho. 
\b  
\q1  
\v 29 Ngʼat ma terore mos nigi winjo, 
\q2 to ngʼatno ma iye wangʼ piyo nyiso fupe. 
\b  
\q1  
\v 30 Chuny man-gi kwe kelo ngima ni ringruok, 
\q2 to nyiego towo choke. 
\b  
\q1  
\v 31 Ngʼat masando jochan nyiso achaya ne Jal mane ochweyogi, 
\q2 to ngʼato angʼata mangʼwon ni jogo mochando miyo Nyasaye luor. 
\b  
\q1  
\v 32 Ka masira obiro, joricho itieko, 
\q2 to kata e tho ngʼat makare nigi kar pondo. 
\b  
\q1  
\v 33 Rieko odak e chuny ngʼat ma weche donjone, 
\q2 to kata mana e dier joma ofuwo omiyo ingʼeye. 
\b  
\q1  
\v 34 Tim makare tingʼo oganda malo, 
\q2 to richo en wichkuot ne ji. 
\b  
\q1  
\v 35 Ruoth mor gi jatich mariek, 
\q2 to jatich makwodo wich yudo mirimbe. 
\b  
\c 15  
\q1  
\v 1 Dwoko wach mamuol kweyo mirima, 
\q2 to wach makwiny jimbo ich wangʼ. 
\b  
\q1  
\v 2 Lew ngʼat mariek konyore gi rieko, 
\q2 to dho ngʼat mofuwo hulo gik mofuwo. 
\b  
\q1  
\v 3 Wenge Jehova Nyasaye ni kuonde duto, 
\q2 karito joricho gi joma beyo. 
\b  
\q1  
\v 4 Lep makelo ber en yath mar ngima, 
\q2 to lep mar miriambo omiyo chuny bedo mool. 
\b  
\q1  
\v 5 Ngʼat mofuwo chayo kum mar wuon mare, 
\q2 to ngʼat mawinjo ka ikwere nyiso rieko. 
\b  
\q1  
\v 6 Od ngʼat makare otingʼo mwandu maduongʼ, 
\q2 to pok mar joricho kelo nigi chandruok. 
\b  
\q1  
\v 7 Dho jomariek lando ngʼeyo, 
\q2 to ngʼat mofuwo to wechene obam. 
\b  
\q1  
\v 8 Jehova Nyasaye odagi misango mar jaricho, 
\q2 to lamo mar ngʼat moriere tir miye mor. 
\b  
\q1  
\v 9 Jehova Nyasaye odagi yore ngʼat marach, 
\q2 to ohero jogo matimo gik makare. 
\b  
\q1  
\v 10 Kum malit orito ngʼat maweyo yo, 
\q2 ngʼat masin kikwere biro tho. 
\b  
\q1  
\v 11 Jehova Nyasaye ongʼeyo gik moko matimore, 
\q2 bed ni en Tho kata Kethruok, 
\q2 omiyo dhano ok dipandne paro manie chunye! 
\b  
\q1  
\v 12 Ngʼat ma jasunga dagi puonj, 
\q2 ok odwar mondo ongʼadne rieko gi jomariek. 
\b  
\q1  
\v 13 Chuny mamor miyo wangʼ bedo gi mor, 
\q2 to chuny mokuyo miyo dhano bedo mool. 
\b  
\q1  
\v 14 Chuny mongʼeyo pogo tiend weche dwaro ngʼeyo, 
\q2 to dho ngʼat mofuwo chamo fuwo. 
\b  
\q1  
\v 15 Ndalo duto mag ngʼat mahinyore gin thagruok, 
\q2 to chuny mamor ni kod mor mosiko. 
\b  
\q1  
\v 16 Ber bedo gi matin ka iluoro Jehova Nyasaye 
\q2 moloyo mwandu mangʼeny kod koko. 
\b  
\q1  
\v 17 Ber chamo alot kama hera nitie, 
\q2 moloyo chamo ringʼo machwe kama achaya nitie. 
\b  
\q1  
\v 18 Ngʼat ma iye wangʼ piyo medo miero, 
\q2 to ngʼat ma terore mos kweyo dhawo. 
\b  
\q1  
\v 19 Yor jasamuoyo olor gi kuthe, 
\q2 to yor ngʼat moriere tir en yo malach. 
\b  
\q1  
\v 20 Wuowi mariek miyo wuon mare mor, 
\q2 to ngʼat mofuwo chayo min mare. 
\b  
\q1  
\v 21 Fuwo moro ngʼat maonge gi rieko, 
\q2 to ngʼat man-gi winjo wuotho moriere tir. 
\b  
\q1  
\v 22 Chenro ok chopi nikech onge puonj makare, 
\q2 to ka giyudo jongʼad rieko mangʼeny to gichopo. 
\b  
\q1  
\v 23 Ngʼato yudo mor e dwoko mowinjore, 
\q2 to mano ber manade kuom wach mochopo e sa midware. 
\b  
\q1  
\v 24 Yor ngima telo kadhi malo ni ngʼat makare, 
\q2 mondo ogengʼe kik odhi mwalo kar tho. 
\b  
\q1  
\v 25 Jehova Nyasaye muko od ngʼat masungore, 
\q2 to orito kiep dhako ma chwore otho ma ok omul. 
\b  
\q1  
\v 26 Jehova Nyasaye odagi paro mar joricho, 
\q2 to jogo ma chunygi ler miye mor. 
\b  
\q1  
\v 27 Ngʼat ma jawuoro kelo chandruok ne joode, 
\q2 to ngʼatno mamon gi asoya biro dak amingʼa. 
\b  
\q1  
\v 28 Chuny ngʼat makare pimo dwokoge, 
\q2 to dho ngʼat ma timbene richo hulo gik maricho. 
\b  
\q1  
\v 29 Jehova Nyasaye bor gi ngʼat ma timbene richo, 
\q2 to owinjo lamo mar ngʼat makare. 
\b  
\q1  
\v 30 Neno mamor kelo mor ni chuny, 
\q2 to wach maber miyo choke bedo gi ngima. 
\b  
\q1  
\v 31 Ngʼat machiko ite kikwere 
\q2 biro bedo thuolo e kind joma riek. 
\b  
\q1  
\v 32 Ngʼat ma ok dew kum ochayore owuon, 
\q2 to ngʼat mawinjo kikwere medo winjo wach. 
\b  
\q1  
\v 33 Luoro Jehova Nyasaye puonjo dhano rieko, 
\q2 to bedo mamuol kelo luor. 
\b  
\c 16  
\q1  
\v 1 Chuny dhano chano gik modwaro timo, 
\q2 to dwoko margi aa kuom Jehova Nyasaye. 
\b  
\q1  
\v 2 Yore duto mag dhano nenorene ni longʼo, 
\q2 to Jehova Nyasaye ema ongʼeyo mopondo mag chuny. 
\b  
\q1  
\v 3 Ket gimoro amora mitimo e lwet Jehova Nyasaye, 
\q2 to chenrogi biro dhi maber. 
\b  
\q1  
\v 4 Gik moko duto ma Jehova Nyasaye timo oseketo gikogi, 
\q2 kendo giko mar joricho en tho. 
\b  
\q1  
\v 5 Jehova Nyasaye odagi ji duto man-gi sunga e chunygi. 
\q2 Ngʼe ma malongʼo: Ok ginitony ni kum. 
\b  
\q1  
\v 6 Nikech hera kod adiera ema omiyo richo otimne misango, 
\q2 kuom luoro Jehova Nyasaye miyo ngʼato kwedo richo. 
\b  
\q1  
\v 7 Ka yore ngʼato moro Jehova Nyasaye, 
\q2 to omiyo kata wasike dak kode gi kwe. 
\b  
\q1  
\v 8 Ber bedo gi matin kod tim makare, 
\q2 moloyo mangʼeny kod tim ma ok kare. 
\b  
\q1  
\v 9 E chuny dhano ochano yore, 
\q2 to Jehova Nyasaye ema telone ondamo mage. 
\b  
\q1  
\v 10 Ruoth wuoyo kaka chik mar Nyasaye dwaro, 
\q2 to dhoge ok onego ndhog bura makare. 
\b  
\q1  
\v 11 Rapim mopogore opogore makare aa kuom Jehova Nyasaye, 
\q2 to gik mipimogo manie mifuke gin meke moloso. 
\b  
\q1  
\v 12 Ruodhi mon gi timbe maricho, 
\q2 nikech kom mar loch obedo mana kuom tim makare. 
\b  
\q1  
\v 13 Ruodhi ohero joma wacho adiera 
\q2 kendo gigeno ngʼat mawacho adiera. 
\b  
\q1  
\v 14 Mirimb ruoth en jaote mar tho, 
\q2 to ngʼat mariek biro hoye. 
\b  
\q1  
\v 15 Ka wangʼ ruoth nenore mamor to nitiere ngima, 
\q2 ngʼwonone chalo gi rumbi mag koth e ndalo chwiri. 
\b  
\q1  
\v 16 To ber maromo nade yudo rieko moloyo dhahabu, 
\q2 yiero ngʼeyo tiend wach moloyo fedha! 
\b  
\q1  
\v 17 Yor ngʼat moriere tir kwedore gi richo; 
\q2 ngʼat manono yorene orito ngimane! 
\b  
\q1  
\v 18 Sunga kelo masira, 
\q2 chuny mar ngʼayi kelo chwanyruok. 
\b  
\q1  
\v 19 Ber bedo gi chuny mobolore e dier jochan, 
\q2 moloyo pogo gik moyaki gi josunga. 
\b  
\q1  
\v 20 Ngʼato angʼata mawinjo puonj dhi maber, 
\q2 to ojahawi ngʼatno moketo genone kuom Jehova Nyasaye. 
\b  
\q1  
\v 21 Ngʼat man-gi paro en ngʼat mariek, 
\q2 kendo weche mowacho gin mana puonj. 
\b  
\q1  
\v 22 Winjo wach en soko mar ngima ne jogo man kode, 
\q2 to fuwo kelo kum ne joma ofuwo. 
\b  
\q1  
\v 23 Ngʼat mariek rito weche mawuok e dhoge, 
\q2 kendo wechene mowinjore kelo puonj makare. 
\b  
\q1  
\v 24 Weche mag mor chalo gi mor kich 
\q2 gimit ne chuny kendo gikelo ngima ni choke. 
\b  
\q1  
\v 25 Nitie yo manenore ne dhano ni nikare, 
\q2 to gikone otero mana ngʼato e tho. 
\b  
\q1  
\v 26 Miluma ma jatich nigo miyo otiyo matek, 
\q2 kendo kech makaye miyo omedo tiyo matek. 
\b  
\q1  
\v 27 Ngʼat marach chano timo timbe maricho, 
\q2 to wechene chalo mach mager. 
\b  
\q1  
\v 28 Ngʼat ma timbene richo kelo mana miero, 
\q2 to jakwoth pogo osiepe moherore. 
\b  
\q1  
\v 29 Ngʼat ma ja-mahundu wuondo jabute 
\q2 mi otere e yorno ma ok ber. 
\b  
\q1  
\v 30 Tangʼ gi ngʼat ma buonjo kodi nikech onyalo bet ni ochano timoni marach, 
\q2 ngʼatno maluwo dhoge ochomo timbe maricho. 
\b  
\q1  
\v 31 Lwar en osimbo mar duongʼ 
\q2 to iyude gi ngʼat man-gi ngima makare. 
\b  
\q1  
\v 32 Ngʼat ma terore mos ber moloyo jalweny, 
\q2 ngʼat makweyo mirimbe ber moloyo ngʼat mamonjo dala maduongʼ. 
\b  
\q1  
\v 33 Igoyo ombulu mondo ongʼe gima ditim, 
\q2 to kuom ngʼado weche duto Jehova Nyasaye ema tieko. 
\b  
\c 17  
\q1  
\v 1 Ber bangʼo kuon gi kwe kod mor 
\q2 moloyo ot mopongʼ gi chiemo mathoth kod dhawo. 
\b  
\q1  
\v 2 Misumba mariek biro bedo gi loch kuom wuowi makwodo wich, 
\q2 kendo obiro yudo pok mar girkeni machal mana gi owetene. 
\b  
\q1  
\v 3 Dhahabu gi fedha itemo gi mach, 
\q2 to Jehova Nyasaye ema temo chuny. 
\b  
\q1  
\v 4 Ngʼat ma timbene richo chiko ite ne dhok mopongʼ gi richo, 
\q2 ja-miriambo winjo lep mar ajara. 
\b  
\q1  
\v 5 Ngʼat ma jaro jochan ochayo Jachwechgi; 
\q2 ngʼat mamor gi masira ok notony ne kum. 
\b  
\q1  
\v 6 Nyikwayo gin osimbo ne joma oti, 
\q2 to jonywol e mor mar nyithindgi. 
\b  
\q1  
\v 7 Lep mar sunga ok owinjore ne ngʼama ofuwo, 
\q2 to en rach maromo nadi lep mariambo ne jaloch! 
\b  
\q1  
\v 8 Asoya en bilo ne ngʼat machiwe, 
\q2 kamoro amora modhiye, odhi maber. 
\b  
\q1  
\v 9 Ngʼat ma umo ketho mewo hera, 
\q2 to ngʼat mamedo timo gima kamano pogo osiepe moherore. 
\b  
\q1  
\v 10 Puonj mar kwer konyo ngʼat mariek, 
\q2 moloyo chwat nyadi mia ni ngʼat mofuwo. 
\b  
\q1  
\v 11 Ngʼat ma jaricho ohero mana miero, 
\q2 jaote makwiny ema ibiro orone. 
\b  
\q1  
\v 12 Ber romo gi ondiek madhako moma nyithinde, 
\q2 moloyo romo gi ngʼat mofuwo ei fupe. 
\b  
\q1  
\v 13 Ka ngʼato chulo rach kar ber, 
\q2 rach ok nowe ode. 
\b  
\q1  
\v 14 Chako dhawo chalo gimuko yawo, 
\q2 emomiyo we wach kapok dhawo owuok. 
\b  
\q1  
\v 15 Jehova Nyasaye mon-gi ngʼama chwako jaketho 
\q2 kata kumo ngʼat maonge ketho. 
\b  
\q1  
\v 16 Ere tiende mondo ngʼat mofuwo obed gi pesa 
\q2 nimar oonge gi dwaro mar bedo mariek? 
\b  
\q1  
\v 17 En adier ni osiepni nyalo heri kinde duto, 
\q2 to owadu ema konyi e chandruok. 
\b  
\q1  
\v 18 Ngʼat maonge gi rieko 
\q2 ema keto gir singo ne jabute. 
\b  
\q1  
\v 19 Ngʼat mohero dhawo ohero richo; 
\q2 ngʼat mogero ohinga mabor kelo mana hinyruok. 
\b  
\q1  
\v 20 Ngʼat man-gi chuny marach ok nyal dhi maber; 
\q2 ngʼat ma lewe riambo podho e chandruok. 
\b  
\q1  
\v 21 Bedo gi ngʼat mofuwo kaka wuowi kelo kuyo; 
\q2 onge mor ni wuoro ma wuon ngʼat mofuwo. 
\b  
\q1  
\v 22 Chuny mamor en yath maber, 
\q2 to chuny mool tuoyo choke. 
\b  
\q1  
\v 23 Ngʼat ma timbene richo yie asoya kama opondo 
\q2 mondo oketh gima kare. 
\b  
\q1  
\v 24 Ngʼat mariek keto rieko mondo otel, 
\q2 to wenge ngʼat mofuwo bayo nyaka giko piny. 
\b  
\q1  
\v 25 Wuowi mofuwo kelo kuyo ni wuon mare 
\q2 kod chuny lit ne ngʼat mane onywole. 
\b  
\q1  
\v 26 Ok en gima ber kumo ngʼat maonge ketho 
\q2 kata goyo joote nikech dimbruokgi. 
\b  
\q1  
\v 27 Ngʼat man-gi ngʼeyo konyore gi weche kotangʼ; 
\q2 to ngʼat man-gi winjo wach to ritore maber. 
\b  
\q1  
\v 28 Kata ngʼat mofuwo ikwano ka ngʼat mariek ka olingʼ thi; 
\q2 kendo ka ngʼat mongʼeyo ka orito lewe. 
\b  
\c 18  
\q1  
\v 1 Ngʼat ma ok jahera dwaro mana gige 
\q2 ok owinj puonj moro amora. 
\b  
\q1  
\v 2 Ngʼat mofuwo ok mor kod winjo wach 
\q2 to omor mana gi wacho paroge owuon. 
\b  
\q1  
\v 3 Ka richo biro, e kaka achaya biro, 
\q2 to wichkuot kelo duwruok. 
\b  
\q1  
\v 4 Weche mag dho ngʼato tut ka nam, 
\q2 to soko mar rieko en aora mabubni kamol. 
\b  
\q1  
\v 5 Ok en gima ber chwako ngʼat ma timbene richo 
\q2 kata ketho buch ngʼato maonge ketho. 
\b  
\q1  
\v 6 Lew ngʼat mofuwo kelone dhawo, 
\q2 to dhoge luongo goch. 
\b  
\q1  
\v 7 Dho ngʼat mofuwo ema tieke, 
\q2 to lewe ema bedo obadho ne ngimane. 
\b  
\q1  
\v 8 Weche mag kuoth chalo gi chiemo mamit; 
\q2 gidhiyo e chuny dhano ma iye. 
\b  
\q1  
\v 9 Ngʼat ma jasamuoyo e tich 
\q2 en owadgi ngʼat maketho gik moko. 
\b  
\q1  
\v 10 Nying Jehova Nyasaye en ohinga maratego, 
\q2 ngʼat makare ringo ma pond kanyo kendo yud resruok. 
\b  
\q1  
\v 11 Mwandu mar jomoko e ohinga mochiel motegno ma gigengʼorego, 
\q2 giparo ni en ohinga maonge ngʼama nyalo muko. 
\b  
\q1  
\v 12 Kapok ngʼato opodho, to sunga bedo e chunye, 
\q2 to muolo kelo pak. 
\b  
\q1  
\v 13 Chik iti kapok idwoko wach; 
\q2 ka ok itimo kamano to ibedo mofuwo kendo ikelo wichkuot. 
\b  
\q1  
\v 14 Chuny ngʼato sire e tuo, 
\q2 to chuny mool, en ngʼa manyalo konyo? 
\b  
\q1  
\v 15 Chuny ma weche donjone yudo ngʼeyo; 
\q2 to it mariek dwaro mondo weche odonjne. 
\b  
\q1  
\v 16 Chiwo yawo yo ne ngʼat machiwo 
\q2 kendo tere e nyim jomadongo. 
\b  
\q1  
\v 17 Ngʼat mokwongo keto wachne nenore ni en kare, 
\q2 nyaka ngʼat machielo bi maket penjo ne wachneno. 
\b  
\q1  
\v 18 Goyo ombulu tieko larruok 
\q2 kendo thego joma roteke. 
\b  
\q1  
\v 19 Kiketho ne owadu to duoge iri tek 
\q2 mana kadonjo e dala maduongʼ mochiel motegno; 
\q2 to larruok chalo gi dhorangeye mag dala modin gi lodi. 
\b  
\q1  
\v 20 Wach mawuok e dho ngʼato ema miyo ngʼato yiengʼ; 
\q2 keyo mar dhoge ema miyo oyiengʼ. 
\b  
\q1  
\v 21 Lep nigi teko mar ngima kod tho, 
\q2 to jogo mohere biro chamo olembe. 
\b  
\q1  
\v 22 Ngʼatno moyudo dhako onwangʼo gima ber 
\q2 kendo oyudo ngʼwono moa kuom Jehova Nyasaye. 
\b  
\q1  
\v 23 Ngʼat ma jachan ywak kokwayo ngʼwono, 
\q2 to ngʼat ma jamoko dwoko gi gero. 
\b  
\q1  
\v 24 Ngʼat man-gi osiepe mangʼeny nyalo chopo e kethruok 
\q2 to nitie osiep moro masiko buti machiegni maloyo owadu. 
\b  
\c 19  
\q1  
\v 1 Ber bedo jachan ma wuodhe ok nyal cha, 
\q2 moloyo ngʼat mofuwo ma lewe timo richo. 
\b  
\q1  
\v 2 Ok ber bedo gi gombo maonge gi ngʼeyo, 
\q2 kata bedo ka irikni kae to ibayo yo. 
\b  
\q1  
\v 3 Fuwo mar ngʼato owuon ketho ngimane; 
\q2 to bende chunye bedo mager gi Jehova Nyasaye. 
\b  
\q1  
\v 4 Mwandu kelo osiepe mangʼeny, 
\q2 to osiep ngʼat ma jachan ringe. 
\b  
\q1  
\v 5 Janeno ma ja-miriambo ok notony ma ok okum, 
\q2 to ngʼatno malando miriambo ok nobed thuolo. 
\b  
\q1  
\v 6 Ji mangʼeny temo mondo oyud pwoch kuom ruoth, 
\q2 to ngʼato ka ngʼato bedo osiep ngʼat machiwo mich. 
\b  
\q1  
\v 7 Ngʼat ma jachan wedene duto kwede, 
\q2 osiepene to noringe maromo nadi! 
\q1 Kata bed notemo sayogi 
\q2 onge kama doyudgie. 
\b  
\q1  
\v 8 Ngʼatno moyudo rieko ohero chunye owuon, 
\q2 to ngʼat mohero winjo wach dhi maber. 
\b  
\q1  
\v 9 Janeno ma ja-miriambo ok notony ma ok okume, 
\q2 to ngʼatno malando miriambo biro lal nono. 
\b  
\q1  
\v 10 Ok en gima owinjore mondo ngʼat mofuwo odagi e ber, 
\q2 to en gima rach machalo nadi ka misumba ema omi loch kuom yawuot ruoth! 
\b  
\q1  
\v 11 Ngʼat mariek iye ok wangʼ piyo; 
\q2 oyudo duongʼ kuom weyo wach ma ok odewo ketho. 
\b  
\q1  
\v 12 Gero mar ruoth chalo gi sibuor maruto, 
\q2 to ka omor kodi to ochalo gi tho manie wi lum. 
\b  
\q1  
\v 13 Wuowi mofuwo kelone wuon mare masira, 
\q2 to dhako maralep chalo gi kodh ajiki. 
\b  
\q1  
\v 14 Ute kod mwandu gin girkeni miyudo kuom jonywol, 
\q2 to dhako mariek aa kuom Jehova Nyasaye. 
\b  
\q1  
\v 15 Samuoyo kelo nindo matut, 
\q2 to ngʼat ma ja-mifwadhi bedo gi kech. 
\b  
\q1  
\v 16 Ngʼatno morito chike Jehova Nyasaye kendo timo gik mopuonje biro dak amingʼa, 
\q2 to ngʼat mochayo chikene biro tho. 
\b  
\q1  
\v 17 Ngʼat manyiso ngʼwono ne jochan, holo mana Jehova Nyasaye, 
\q2 obiro gwedhe kuom gik mosetimo. 
\b  
\q1  
\v 18 Kum wuodi, nikech mano e kama geno nitie; 
\q2 kik ibed e winjruok kuom gima nyalo kelone tho. 
\b  
\q1  
\v 19 Ngʼat ma ja-mirima nyaka yud kum, kendo ka ikonye, 
\q2 to chuno ni nyaka itim kamano kendo. 
\b  
\q1  
\v 20 Chik iti ka ingʼadoni rieko kendo rwak puonj, 
\q2 to giko ni inibed mariek. 
\b  
\q1  
\v 21 Dhano nigi chenro mangʼeny e chunye, 
\q2 to dwaro mar Jehova Nyasaye ema timore. 
\b  
\q1  
\v 22 Gima dhano dwaro en hera ma ok rum, 
\q2 ber bedo jachan moloyo bedo ja-miriambo. 
\b  
\q1  
\v 23 Luoro Jehova Nyasaye tero ji e ngima; 
\q2 eka ngʼato yweyo kodhil, ma ok omule gi chandruok. 
\b  
\q1  
\v 24 Jasamuoyo luto lwete malal ei tawo; 
\q2 kendo ok onyal gole oko moduoge e dhoge! 
\b  
\q1  
\v 25 Chwad jasunga mondo joma ngʼeyogi tin opuonjre; 
\q2 kwer ngʼat man-gi rieko, to obiro medo fwenyo tiend weche. 
\b  
\q1  
\v 26 Ngʼat mamayo wuon mare kendo riembo min mare 
\q2 en wuowi makelo wichkuot kod dwanyruok. 
\b  
\q1  
\v 27 Kidagi chiko iti ne puonj in wuoda, 
\q2 to ibiro bayo mabor kuom weche mag ngʼeyo. 
\b  
\q1  
\v 28 Janeno ma ja-jar ji ochayo adiera, 
\q2 to dho ngʼat ma timbene richo golo mana richo. 
\b  
\q1  
\v 29 Kum oket mana ne jo-achaya, 
\q2 to chwat ne ngʼe joma ofuwo. 
\b  
\c 20  
\q1  
\v 1 Divai en jajaro to kongʼo en koko; 
\q2 ngʼat motelne kodgi onge rieko. 
\b  
\q1  
\v 2 Mirimb ruoth chalo gi ruto mar sibuor; 
\q2 ngʼat momiyo obedo gi gero lalo ngimane. 
\b  
\q1  
\v 3 Enobed luor maduongʼ ne ngʼatno ma dagi dhawo, 
\q2 to joma ofuwo duto ohero dhawo. 
\b  
\q1  
\v 4 Jasamuoyo ok pur puothe e kinde mowinjore; 
\q2 omiyo e kinde mar keyo omanyo, to ok oyud gimoro. 
\b  
\q1  
\v 5 Dwaro mar chuny dhano chalo gi pi matut, 
\q2 to ngʼat man-gi winjo twomogi. 
\b  
\q1  
\v 6 Ji mangʼeny wacho ni gin gihera ma adiera; 
\q2 to ngʼat ma ja-adiera, en ngʼa ma diyude? 
\b  
\q1  
\v 7 Ngʼat makare nigi ngima ma ok ocha; 
\q2 nyithinde nigi gweth bangʼe. 
\b  
\q1  
\v 8 Ka ruoth obedo e kome mondo ongʼad bura; 
\q2 opiedho weche maricho duto gi wangʼe. 
\b  
\q1  
\v 9 En ngʼa manyalo wacho niya, “Aserito chunya maler; 
\q2 aler kendo aonge richo?” 
\b  
\q1  
\v 10 Rapim ma ok nikare gi pimo ma ok kare, 
\q2 Jehova Nyasaye mon kodgi duto. 
\b  
\q1  
\v 11 Kata mana nyathi ingʼeyo gi timbene, 
\q2 omiyo ingʼeyo ka kite obidhore kata ni kare. 
\b  
\q1  
\v 12 It mawinjo gi wangʼ maneno, 
\q2 Jehova Nyasaye ema osechweyo gik moko ariyogo. 
\b  
\q1  
\v 13 Kik iher nindo nono to ibiro bedo jachan, 
\q2 bed kineno to ok ibi chando chiemo. 
\b  
\q1  
\v 14 Jangʼiewo wacho niya, “Ok ber ngangʼ, ok ber ngangʼ!” 
\q2 To bangʼe owuok odhiyo ka osungore ni ongʼiewo gi nengo mayot. 
\b  
\q1  
\v 15 Dhahabu nitie, kendo kite ma nengogi tek bende nitie mogundho, 
\q2 to dhok mawacho weche mag ngʼeyo gin kaka mula mabeyo mayudo tek. 
\b  
\q1  
\v 16 Kaw law ngʼat mochungʼne ngʼat mokia kaka singo; 
\q2 mak gino mosingorego, ka otimo kamano ni dhako majabayo. 
\b  
\q1  
\v 17 Chiemo moyud e yo ma ok kare mit ne ngʼato, 
\q2 to achien omuodore mana ka kuoyo. 
\b  
\q1  
\v 18 Los chenro ka ikonyori gi ngʼado rieko; 
\q2 ka ichako lweny to dwar ikruok maber. 
\b  
\q1  
\v 19 Fuongʼo wach ketho genruok; 
\q2 omiyo tangʼ ni ngʼato ma wuoyo mathoth. 
\b  
\q1  
\v 20 Ka ngʼato okwongʼo wuon mare kata min mare, 
\q2 to ngimane norum mana ka taya motho e mudho molil. 
\b  
\q1  
\v 21 Mwandu moyud motelo e yo mayot 
\q2 ok bi bedo konyruok e kinde machien. 
\b  
\q1  
\v 22 Kik iwach niya, “Abiro chulo kuor kuom rachni motimna!” 
\q2 Bed kirito Jehova Nyasaye to obiro resi. 
\b  
\q1  
\v 23 Jehova Nyasaye mon gi rapim mag miriambo, 
\q2 kendo rapim ma ok kare ok miye mor. 
\b  
\q1  
\v 24 Okange mag ngʼato ichiko gi Jehova Nyasaye. 
\q2 Ere kaka ngʼato nyalo ngʼeyo yore owuon? 
\b  
\q1  
\v 25 En obadho ne ngʼato masingo gimoro ka ok oparo, 
\q2 to achien eka oparo singruokne. 
\b  
\q1  
\v 26 Ruoth mariek riembo joma timbegi richo; 
\q2 okumogi ma ok okechogi. 
\b  
\q1  
\v 27 Taya mar Jehova Nyasaye manyo chuny dhano, 
\q2 kendo omanyo chunye ma iye. 
\b  
\q1  
\v 28 Hera kod adiera miyo ruoth bedo gi kwe, 
\q2 nikech hera, lochne bedo motegno. 
\b  
\q1  
\v 29 Sunga ma yawuowi nigo e teko margi, 
\q2 to lwar en duongʼ ne jodongo. 
\b  
\q1  
\v 30 Goch kod adhonde pwodho richo, 
\q2 to chwat loso maler chuny maiye. 
\b  
\c 21  
\q1  
\v 1 Chuny ruoth ni e lwet Jehova Nyasaye, 
\q2 ochike mana kaka kuonde ma pi luwo kendo kaka ohero owuon. 
\b  
\q1  
\v 2 Yore duto mag dhano nenorene ni nikare, 
\q2 to Jehova Nyasaye ema pimo chuny. 
\b  
\q1  
\v 3 Timo gima kare kod mowinjore 
\q2 ema Jehova Nyasaye oyiego moloyo misango. 
\b  
\q1  
\v 4 Wangʼ teko, chuny mar sunga 
\q2 kod taya mar jo-mahundu, gin richo! 
\b  
\q1  
\v 5 Chenro mag ngʼat matiyo matek kelo ohala 
\q2 to chutho e kaka rikni kelo chan. 
\b  
\q1  
\v 6 Mwandu moyudi gi lep mariambo 
\q2 en mana tho malal piyo kendo en obeto mar tho. 
\b  
\q1  
\v 7 Timbe mahundu mar joricho biro terogi mabor magilal; 
\q2 nimar gidagi timo gima kare. 
\b  
\q1  
\v 8 Yor ngʼat ma jaketho ogondore, 
\q2 to kit ngʼat makare oriere tir. 
\b  
\q1  
\v 9 Ber dak e kona mar wi ot 
\q2 moloyo dak gi dhako maralep. 
\b  
\q1  
\v 10 Ngʼat ma timbene richo ohero richo; 
\q2 jabute ok yud ngʼwono kuome. 
\b  
\q1  
\v 11 Ka okum ngʼat ma jaro ji, to joma ngʼeyogi tin yudo rieko, 
\q2 ka ngʼat mariek opuonji, to oyudo ngʼeyo. 
\b  
\q1  
\v 12 Ngʼat Makare ongʼeyo od ngʼat ma timbene richo 
\q2 kendo otero ngʼat marach e kethruok. 
\b  
\q1  
\v 13 Ka ngʼato odino ite ne ywak mar jachan, 
\q2 en owuon bende obiro ywak to ok nodwoke. 
\b  
\q1  
\v 14 Mich mochiw lingʼ-lingʼ kweyo mirima 
\q2 to asoya mopandi ei law jiwo mirima maduongʼ. 
\b  
\q1  
\v 15 Ka adiera onenore, to joma timbegi nikare bedo mamor 
\q2 to joma timbegi richo to yudo bwok. 
\b  
\q1  
\v 16 Ngʼat moweyo yor winjo wach 
\q2 dhiyo kar yweyo mar oganda mar joma otho. 
\b  
\q1  
\v 17 Ngʼat mohero budho biro bedo jachan; 
\q2 ngʼat mohero divai kod moo ok nyal bedo ja-mwandu. 
\b  
\q1  
\v 18 Jomaricho bedo resruok mar joma kare; 
\q2 to jogo ma ok jo-adiera ne joma oriere tir. 
\b  
\q1  
\v 19 Ber dak e thim motwo 
\q2 moloyo dak gi dhako ma jadhawo kendo ma ja-mirima. 
\b  
\q1  
\v 20 Od ngʼat mariek opongʼ kod chiemo gi moo moyier, 
\q2 to ngʼat mofuwo chamo gik moko duto ma en-go. 
\b  
\q1  
\v 21 Ngʼatno maluwo tim makare kod hera 
\q2 yudo ngima, mwandu gi luor. 
\b  
\q1  
\v 22 Ngʼat mariek kawo dala ngʼat maratego 
\q2 kendo omuko dhorangeye matek magiketoe genogi. 
\b  
\q1  
\v 23 Ngʼatno marito dhoge kod lewe 
\q2 ritore kuom masiche. 
\b  
\q1  
\v 24 Ngʼat ma jasunga kendo jawuorre “Jajaro” e nyinge; 
\q2 otingʼore malo ka osungore malich. 
\b  
\q1  
\v 25 Dwaro mar jasamuoyo biro bedo thone owuon; 
\q2 nikech lwetene odagi tich. 
\q1  
\v 26 Odiechiengʼ duto odwaro mangʼeny, 
\q2 to ngʼat makare chiwo maonge giko. 
\b  
\q1  
\v 27 Misango mar jaricho ok ber, 
\q2 onyalo bedo marach maromo nade ka ochiwe gi paro marach! 
\b  
\q1  
\v 28 Janeno ma ja-miriambo biro lal; 
\q2 to ngʼat mawinje ibiro tieko chutho. 
\b  
\q1  
\v 29 Ngʼat ma jaricho wangʼe tek 
\q2 to ngʼat moriere tir tiyo gi paro e yorene. 
\b  
\q1  
\v 30 Onge rieko, onge neno matut, 
\q2 onge chenro manyalo loyo Jehova Nyasaye. 
\b  
\q1  
\v 31 Inyalo yiko faras ne ndalo mar lweny; 
\q2 to loyo lweny en mar Jehova Nyasaye. 
\b  
\c 22  
\q1  
\v 1 Nying maber oloyo bedo gi mwandu mathoth; 
\q2 bedo gi pwoch ber moloyo fedha gi dhahabu. 
\b  
\q1  
\v 2 Onge pogruok e kind jamoko kod jachan: 
\q2 Nikech Jehova Nyasaye e Jachwechgi duto. 
\b  
\q1  
\v 3 Ngʼat mariek neno masira kabiro kendo opondo, 
\q2 to ngʼat mofuwo dhiyo adhiya nyime ma ohinyre. 
\b  
\q1  
\v 4 Bolruok kod luoro Jehova Nyasaye 
\q2 kelo mwandu gi luor kod dak amingʼa. 
\b  
\q1  
\v 5 Yore joma timo richo opongʼ gi kudho kod obadho; 
\q2 to ngʼat morito chunye obedo mabor kodgi. 
\b  
\q1  
\v 6 Puonj nyathi e yo monego odhiye, 
\q2 to ka obedo maduongʼ to ok obi baro oa kuome. 
\b  
\q1  
\v 7 Jochan gin wasumb jo-mwandu, 
\q2 to ngʼat moholo gimoro bedo misumba ngʼat mohole. 
\b  
\q1  
\v 8 Ngʼatno mochwowo timbe richo kayo thagruok, 
\q2 to ludhe mar mirima ibiro ketho. 
\b  
\q1  
\v 9 Ngʼat mangʼwon noyud gweth, 
\q2 nimar opogo chiembe kod jochan. 
\b  
\q1  
\v 10 Riemb ngʼat ma jaro ji, to lweny bende aa, 
\q2 dhawo kod kinyruok rumo. 
\b  
\q1  
\v 11 Ngʼat ma chunye ler kendo ma wuoyo gi ngʼwono 
\q2 biro bedo osiep ruoth. 
\b  
\q1  
\v 12 Wangʼ Jehova Nyasaye rito ngʼeyo; 
\q2 to orundo weche mag jogo ma ok jo-adiera. 
\b  
\q1  
\v 13 Jasamuoyo wacho niya, “Sibuor ni oko!” 
\q2 Kata, “Ibiro nega e yore mag dala!” 
\b  
\q1  
\v 14 Dho dhako ma jachode en bur matut; 
\q2 ngʼatno manie bwo mirimb Jehova Nyasaye biro lingʼore e iye. 
\b  
\q1  
\v 15 Fuwo otwere e chuny nyathi, 
\q2 to ludh kum biro riembe mabor kode. 
\b  
\q1  
\v 16 Ngʼat mathiro jochan mondo mwandune omedre 
\q2 kod ngʼat machiwo mich ne jomoko biro bedo jochan. 
\ms1 Weche piero adek mag jomariek 
\s2 Wach Mokwongo 
\q1  
\v 17 Chik iti kendo iwinj weche mag jomariek; 
\q2 ket chunyi ne gima apuonjo, 
\q1  
\v 18 nimar en mor ka ikanogi ei chunyi 
\q2 kendo bed kodgi moikore e dhogi. 
\q1  
\v 19 Mondo omi ibed gi geno kuom Jehova Nyasaye; 
\q2 apuonji tinendeni, in bende. 
\q1  
\v 20 Donge asendikoni weche mowachi piero adek, 
\q2 weche mag puonj kod ngʼeyo, 
\q1  
\v 21 mapuonjou adiera gi weche migeno, 
\q2 mondo ichiw dwoko mowinjore ne ngʼat mane oori? 
\s2 Wach mar ariyo 
\q1  
\v 22 Kik ima jachan nikech gin jochan 
\q2 kendo kik ihiny joma ochando man-gi dwaro e kar bura, 
\q1  
\v 23 nimar Jehova Nyasaye biro chwako buchgi, 
\q2 kendo tieko ngima joma tieko ngimagi. 
\s2 Wach mar adek 
\q1  
\v 24 Kik imak osiep gi ngʼat ma iye wangʼ piyo; 
\q2 kik iriwri bende gi ngʼatno makecho piyo, 
\q1  
\v 25 dipo nono ka ipuonjori yorene, 
\q2 ma iwuon idonj e obadho. 
\s2 Wach mar angʼwen 
\q1  
\v 26 Kik ibed ngʼatno matimo singruok 
\q2 kata machungʼ ne ngʼato e gope; 
\q1  
\v 27 ka ionge gi yo kaka dichul, 
\q2 nono to wuon gowino nyalo kawo kitandani. 
\s2 Wach mar abich 
\q1  
\v 28 Kik igol kidi mar kiewo machon 
\q2 mane oket gi kweregi. 
\s2 Wach mar auchiel 
\q1  
\v 29 Bende ineno ngʼat molony e tije? 
\q2 Obiro tiyo ne ruodhi, 
\q2 ok onyal tiyo ne ji ma ok ongʼere. 
\c 23  
\s2 Wach mar abiriyo 
\q1  
\v 1 Ka ibedo mondo ichiem gi ruoth, 
\q2 non maber gima ni e nyimi, 
\q1  
\v 2 ka in jawuoro to dimbri 
\q2 nono to onyalo keto pala e dwondi. 
\q1  
\v 3 Kik igomb chiembe mamit, 
\q2 nimar chiemono en mar wuondruok. 
\s2 Wach mar aboro 
\q1  
\v 4 Kik iwe tich bari ndasi ni mondo ibed ja-mwandu, 
\q2 bed gi rieko mondo iritri. 
\q1  
\v 5 Ngʼi mwandu mana matin nono, to bangʼe gidhi, 
\q2 nimar adiera gibiro bedo gi bwombe, 
\q2 kendo gifu gidhi e kor polo ka ongo. 
\s2 Wach mar ochiko 
\q1  
\v 6 Kik icham chiemb jagwondo, 
\q2 kik igomb chiembe mamit, 
\q1  
\v 7 nimar en ngʼat 
\q2 mosiko paro nengo mochul. 
\q1 Owachoni niya, “Chiem kendo methi,” 
\q2 to chunye ok ni kodi. 
\q1  
\v 8 Ibiro ngʼogo mano matin mane ichamo 
\q2 kendo ibiro bedo ni iketho kindeni kuom pwoch mipuoyego. 
\s2 Wach mar apar 
\q1  
\v 9 Kik iwuo ne ngʼat mofuwo, 
\q2 nikech obiro chayo rieko mag wechegi. 
\s2 Wach mar apar gachiel 
\q1  
\v 10 Kik igol kidi mar kiewo machon, 
\q2 kata ima nyithindo maonge wuone puothegi; 
\q1  
\v 11 nimar Jal moritogi en ratego; 
\q2 obiro chwakogi e kindi kodgi. 
\s2 Wach mar apar gariyo 
\q1  
\v 12 Ket chunyi ne puonj 
\q2 to iti ne weche mag ngʼeyo. 
\s2 Wach mar apar gadek 
\q1  
\v 13 Kik itamri kumo nyathi; 
\q2 nimar chwat ok nyal nege. 
\q1  
\v 14 Kikumo nyathi kod kede 
\q2 to obiro reso chunye aa e tho. 
\s2 Wach mar apar gangʼwen 
\q1  
\v 15 Wuoda, ka chunyi riek, 
\q2 eka chunya biro bedo mamor, 
\q1  
\v 16 chunya ma iye nobed mamor 
\q2 ka lewi wacho gima nikare. 
\s2 Wach mar apar gabich 
\q1  
\v 17 Kik ibed gi nyiego e chunyi nikech joricho; 
\q2 to kinde duto bedi gi dwaro mar luoro Jehova Nyasaye moloyo. 
\q1  
\v 18 Adier, ka itimo kamano to inibed gi geno e ndalo mabiro, 
\q2 kendo genoni ok nongʼad oko. 
\s2 Wach mar apar gauchiel 
\q1  
\v 19 Wuoda, winja, eka inibed mariek, 
\q2 kendo ket chunyi e yo moriere tir. 
\q1  
\v 20 Kik iriwri gi jogo ma madho kongʼo mangʼeny 
\q2 kata jowuoro mohero ringʼo, 
\q1  
\v 21 nimar jomer kod jowuoro bedo jochan, 
\q2 kendo nongʼno rwakogi gi lewni moti. 
\s2 Wach mar apar gabiriyo 
\q1  
\v 22 Winj wuonu, nikech en ema nonywoli, 
\q2 kendo kik icha minu ka oti. 
\q1  
\v 23 Adiera gi rieko gi puonjruok kod ngʼeyo tiend wach ema nyaka iyudi, 
\q2 kata dabed ni ingʼiewogi gi nengo matek. 
\q1  
\v 24 Wuon ngʼat makare nigi mor maduongʼ; 
\q2 ngʼatno man-gi wuowi mariek obedo mamor kode. 
\q1  
\v 25 Mad wuonu gi minu bed mamor; 
\q2 mad minu mane onywoli bed gi ilo. 
\s2 Wach mar apar gaboro 
\q1  
\v 26 Wuoda, miya chunyi, kendo ket wengegi orit yorena, 
\q1  
\v 27 nimar dhako ma jachode en bur matut, 
\q2 to dhako mabayo en soko madiny. 
\q1  
\v 28 Ka jamecho obuto korito, 
\q2 to omedo keto ji ma ok jo-adiera mangʼeny e kind ji. 
\s2 Wach mar apar gochiko 
\q1  
\v 29 En ngʼa man-gi masira? 
\q2 En ngʼa man-gi lit? 
\q1 En ngʼa man-gi lweny? 
\q2 En ngʼa man-gi ngʼur? 
\q1 En ngʼa man-gi adhonde 
\q2 ma ok owinjore? 
\q1 En ngʼa man-gi wangʼ makwar 
\q2 motimo remo? 
\q1  
\v 30 Jogo madeko oko ka kongʼo, 
\q2 madhi mondo gibil kongʼo mokik mayoreyore. 
\q1  
\v 31 Kik ingʼi kongʼo kochiek mowalo, 
\q2 ka obabni e kikombe, 
\q2 ka omadhore mos kolor piny! 
\q1  
\v 32 Bangʼe to okecho ka thuol 
\q2 kendo oketo kwiri kaka fu. 
\q1  
\v 33 Wengeni biro neno gik mayoreyore 
\q2 to pachi paro gik morundore. 
\q1  
\v 34 Ibiro chalo ngʼat ma nindo e nam mar apaka matek, 
\q2 ka inindo ewi apaka. 
\q1  
\v 35 Ibiro wacho niya, “Gigoya, to ok ahinyra! 
\q2 Gigoya, to ok awinji! 
\q1 Karangʼo ma abiro chiewoe 
\q2 mondo adog ameth kendo?” 
\c 24  
\s2 Wach mar piero ariyo 
\q1  
\v 1 Kik nyiego maki gi joricho 
\q2 bende kik iyie chunyi gomb bedo e chokruok margi; 
\q1  
\v 2 nimar chunjegi chano timo mamono 
\q2 to dhogi wacho mana gik makelo chandruok. 
\s2 Wach mar piero ariyo gachiel 
\q1  
\v 3 Rieko ema igerogo ot, 
\q2 to kuom winjo ogurore mosiko; 
\q1  
\v 4 kuom ngʼeyo, utene maiye ipongʼo gi gik moko 
\q2 ma ok yudo yot kod mwandu mabeyo. 
\s2 Wach mar piero ariyo gariyo 
\q1  
\v 5 Ngʼat mariek nigi teko maduongʼ; 
\q2 to ngʼat man-gi ngʼeyo medo teko; 
\q1  
\v 6 nimar dhiyo e lweny dwaro ni ongʼadni rieko, 
\q2 to bedo gi loch dwaro jongʼad rieko mangʼeny. 
\s2 Wach mar piero ariyo gadek 
\q1  
\v 7 Rieko bor moyombo ngʼat mofuwo; 
\q2 e kar bura mar alap oonge gi gima onyalo wacho. 
\s2 Wach mar piero ariyo gangʼwen 
\q1  
\v 8 Ngʼat machano gima rach 
\q2 biro ngʼere kaka ja-andhoga. 
\q1  
\v 9 Andhoga mar fuwo en richo, 
\q2 to ji mon kod ja-jar ji. 
\s2 Wach mar piero ariyo gabich 
\q1  
\v 10 Ka tekri orumo mipodho e kinde mar lweny, 
\q2 to mano kaka tekri tin! 
\q1  
\v 11 Res jogo mitero kar tho; 
\q2 mak jogo mawuotho ka tangni dhiyo kar yengʼo. 
\q1  
\v 12 Ka iwacho niya, “Ne ok wangʼeyo gimoro kuom wachni,” 
\q2 donge ngʼatno mapimo chuny dhano ongʼeyo wachno? 
\q1 Donge ngʼat morito kendo ngʼiyo ngimani ongʼeyogo? 
\q2 To donge obiro chulo ngʼato ka ngʼato mowinjore gi timbene? 
\s2 Wach mar piero ariyo gauchiel 
\q1  
\v 13 Wuoda, cham mor kich, nimar ober; 
\q2 mor kich moa e pedni mar kich nigi ndhandhu mamit. 
\q1  
\v 14 Ngʼe bende ne rieko mit ni chunyi; 
\q2 ka iyude, nitie geno mar ndalo mabiro kuomi, 
\q2 to genoni ok nongʼad oko. 
\s2 Wach mar piero ariyo gabiriyo 
\q1  
\v 15 Kik ibut ka ngʼat marach mondo iketh od ngʼat makare, 
\q2 kik iyak dalane, 
\q1  
\v 16 kata bedni ngʼat makare ogore piny nyadibiriyo, 
\q2 pod obiro chungo kendo; 
\q2 to joricho igoyo piny gi masira. 
\s2 Wach mar piero ariyo gaboro 
\q1  
\v 17 Kik ibed mamor gi masiche mag jasiki, 
\q2 ka ochwanyore, kik iyie chunyi bed mamor; 
\q1  
\v 18 nimar Jehova Nyasaye biro neno 
\q2 kendo golo mirimbe oko kuome. 
\s2 Wach mar piero ariyo gochiko 
\q1  
\v 19 Kik ibed maluor nikech joricho 
\q2 kata kik nyiego maki kod joma timbegi richo, 
\q1  
\v 20 nimar jaricho onge gi geno mar ndalo mabiro, 
\q2 kendo taya mar ngʼat marach ibiro nego. 
\s2 Wach mar piero adek 
\q1  
\v 21 Wuoda, luor Jehova Nyasaye kod ruoth morito piny, 
\q2 kendo kik iriwri gi joma kwede, 
\q1  
\v 22 nimar ji ariyogo biro kelonegi chandruok apoya nono, 
\q2 to en ngʼa ma dingʼe ni en chandruok manade ma ginyalo kelo? 
\ms1 Weche mamoko mag jomariek 
\p  
\v 23 Magi bende gin weche mag jomariek: 
\q1 Luoro wangʼ kuom ngʼado bura ok ber: 
\q1  
\v 24 Ngʼatno mowachone jaketho niya, “In kare ionge ketho” 
\q2 ji biro kwongʼe to piny kwede. 
\q1  
\v 25 To nobed maber gi jogo makumo joma oketho, 
\q2 kendo gweth mogundho nobed kodgi. 
\b  
\q1  
\v 26 Dwoko maratiro 
\q2 nyiso ni mano osiepni mar adier. 
\b  
\q1  
\v 27 Tiek tijeni ma oko kendo ik puothegi; 
\q2 bangʼ mano, 
\q2 eka iger odi. 
\b  
\q1  
\v 28 Kik ibed janeno e wach jabuti 
\q2 kaonge gima omiyo, kata tiyo gi dhogi mondo iriambi. 
\q1  
\v 29 Kik iwach niya, “Abiro timone mana kaka osetimona; 
\q2 abiro chulo ngʼatno mana kaka notimona.” 
\b  
\q1  
\v 30 Nakadho but puoth jasamuoyo, 
\q2 kakadho but puoth olemb mzabibu mar ngʼat maonge gi rieko; 
\q1  
\v 31 kudho notwi kuonde duto, 
\q2 puodho duto noim gi buya, 
\q2 to ohinga mar kidi nomukore. 
\q1  
\v 32 Naketo chunya nono gino mane aneno 
\q2 to napuonjora kuom gino mane aneno. 
\q1  
\v 33 Nindo matin, ayula wangʼ matin, 
\q2 kwakruok matin kiyweyo, 
\q1  
\v 34 to dhier biro monji ka janjore 
\q2 kendo chan ka jalweny momanore. 
\c 25  
\ms1 Ngeche mamoko mag Solomon 
\p  
\v 1 Magi e ngeche mamoko mag Solomon, mane jo-Hezekia ruodh Juda ondiko. 
\q1  
\v 2 Wamiyo Nyasaye duongʼ kuom gik ma opando; 
\q2 to lero tiend weche en duongʼ ni ruodhi. 
\q1  
\v 3 Mana kaka polo bor kendo piny tut, 
\q2 e kaka chuny ruodhi ngʼeyo tek. 
\b  
\q1  
\v 4 Ka ogol chilo kuom fedha, 
\q2 to jatheth koro nigi gimoro mar theth; 
\q1  
\v 5 ka ogol ngʼat marach e nyim ruoth, 
\q2 eka kom ruodhe ibiro guro motegno e tim makare. 
\b  
\q1  
\v 6 Kik imiri duongʼ iwuon e nyim ruoth, 
\q2 kata bedo kar jomadongo, 
\q1  
\v 7 nimar ber moloyo owachni niya, “Bi ka,” 
\q2 moloyo ka igoli e nyim jomadongo. 
\b  
\q1  
\v 8 Gima wangʼi oseneno kik ikel mapiyo kirikni e nyim od bura; 
\q2 nimar ibiro timo angʼo achien ka jabuti oketi e wichkuot? 
\b  
\q1  
\v 9 Ka iloso wach manie kindi gi jabuti, 
\q2 to kik idhi ihul wach malingʼ-lingʼ mar ngʼato; 
\q1  
\v 10 nono to ngʼat moro mowinji biro keti e wichkuot; 
\q2 mi huma mari marach ok nogiki. 
\b  
\q1  
\v 11 Wach mowach e kinde mowinjore, 
\q2 chalo gi olemo mar dhahabu moketie tawo molos gi fedha. 
\q1  
\v 12 Mana kaka tere mar dhahabu kata tigo mar dhahabu maber 
\q2 e kaka siem mar ngʼat mariek mokwerogo ngʼat machiko ite. 
\b  
\q1  
\v 13 Mana kaka ngʼich mar pe e kinde mar keyo, 
\q2 e kaka jaote ma ja-adiera chalo ne ngʼat moore, 
\q2 omoro chuny ruodhe. 
\q1  
\v 14 Kaka boche polo gi yamo maonge koth, 
\q2 e kaka ngʼat mawuorore gi mich ma ok dochiw. 
\b  
\q1  
\v 15 Horuok mos nyalo loko chuny ruoth, 
\q2 to lep mamuol nyalo toyo chogo. 
\b  
\q1  
\v 16 Ka iyudo mor kich, to cham mana moromo, 
\q2 mathoth ahinya, nyalo miyo ingʼogi. 
\q1  
\v 17 Kik iter tiendi pile e od jabuti, 
\q2 dhiyo kuno pile, biro miyo ochayi. 
\b  
\q1  
\v 18 Mana kaka arungu kata ligangla; kata asere mabith, 
\q2 e kaka ngʼatno machiwo neno ma ok adiera kuom ngʼat ma gidakgo machiegni. 
\q1  
\v 19 Mana kaka lak marach kata tielo mongʼol 
\q2 e kaka keto geno kuom jogo ma ok jo-adiera e kinde mag chandruok. 
\q1  
\v 20 Mana ka ngʼat ma lonyo law midongʼ duk e ndalo ngʼich, 
\q2 kata kaka olo chumbi e adhola, 
\q2 e kaka ngʼat ma wero wende ne chuny mool. 
\b  
\q1  
\v 21 Ka jasiki odenyo, to miye chiemo ocham; 
\q2 ka riyo oloye, miye pi omodhi. 
\q1  
\v 22 Ka itimo kamano, ibiro choko chuk mach maliel e wiye, 
\q2 kendo Jehova Nyasaye biro miyi pok. 
\b  
\q1  
\v 23 Kaka yamb nyandwat kelo koth, 
\q2 e kaka lep mafuongʼo wach kelo miero. 
\b  
\q1  
\v 24 Ber dak e kona mar wi ot 
\q2 moloyo dak gi dhako maralep. 
\b  
\q1  
\v 25 Mana kaka pi mangʼich chalo ne chuny mool, 
\q2 e kaka wach maber moa e piny mabor chalo. 
\q1  
\v 26 Mana kaka soko motimo chwodho kata aora moduwore chalo 
\q2 e kaka ngʼat makare machiwo thuolo ne jaricho. 
\b  
\q1  
\v 27 Ok ber chamo mor kich mathoth, 
\q2 kata ok en gima longʼo mondo ngʼato odwar luor monego miye owuon. 
\b  
\q1  
\v 28 Mana kaka dala maduongʼ ma ohingane omukore mogore piny 
\q2 e kaka ngʼatno ma ok nyal ritore owuon. 
\c 26  
\q1  
\v 1 Mana kaka pe e ndalo oro kata koth e kinde keyo, 
\q2 e kaka luor ok owinjore ni ngʼat mofuwo. 
\q1  
\v 2 Mana kaka oyundi mafuyo kata ka opija maringo 
\q2 e kaka kwongʼ maonge gimomiyo kadho akadha. 
\q1  
\v 3 Kaka faras owinjore gi chwat, 
\q2 to dho punda owinjore gi tweyo 
\q2 e kaka ngʼe joma ofuwo owinjore gi goch. 
\q1  
\v 4 Kik idwok ngʼat mofuwo machalre gi fupe, 
\q2 to dipo ka ibiro bedo machal kode. 
\q1  
\v 5 Dwok ngʼat mofuwo koluwore gi fupe, 
\q2 dipo ka obiro nenore e wangʼe owuon ni oriek. 
\q1  
\v 6 Mana kaka ingʼado tiend ngʼato kata kelo masira, 
\q2 chalo gioro ngʼama ofuwo mondo oter ote. 
\q1  
\v 7 Mana ka tiend ngʼat mongʼol mawengni, 
\q2 e kaka ngero moa e dho ngʼat mofuwo. 
\q1  
\v 8 Mana kaka keto kidi e orujre 
\q2 e kaka miyo ngʼat mofuwo luor. 
\q1  
\v 9 Mana kaka bungu mar kudho e lwet ngʼat momer, 
\q2 e kaka ngero moa e dho ngʼat mofuwo. 
\q1  
\v 10 Mana kaka ngʼama thoro diro aserni adira 
\q2 ema chalo gi ngʼat mandiko ngʼat mofuwo kata ngʼato angʼata moyudo e tich. 
\q1  
\v 11 Kaka guok dok e ngʼokne mosengʼogo 
\q2 e kaka ngʼat mofuwo nwoyo fupe. 
\q1  
\v 12 Bende ineno ngʼato ma paro owuon ni oriek? 
\q2 Ngʼat mofuwo nitiere gi geno moloye. 
\b  
\q1  
\v 13 Jasamuoyo wacho niya, “Sibuor ni e wangʼ yo, 
\q2 sibuor mager bayo e yore mag dala!” 
\q1  
\v 14 Mana kaka dhoot marundore e pata, 
\q2 e kaka jasamuoyo lokore aloka e kitandane. 
\q1  
\v 15 Jasamuoyo luto lwete malal ei tawo; 
\q2 onyap ahinya ma ok onyal gole oko moduoge e dhoge. 
\q1  
\v 16 Jasamuoyo paro e chunye ni oriek 
\q2 moloyo ji abiriyo ma dwoko wach gi rieko. 
\b  
\q1  
\v 17 Mana kaka ngʼat mamako guok gi ite, 
\q2 e kaka ngʼat makadho akadha madonjo e dhawo ma ok mare. 
\b  
\q1  
\v 18 Mana kaka ngʼat ma janeko madiro 
\q2 pil mach kata aserni mager, 
\q1  
\v 19 e kaka ngʼato mawuondo jabute 
\q2 kowacho niya, “Ne angeri angera!” 
\b  
\q1  
\v 20 Ka yien onge to mach tho; 
\q2 ka kuoth onge dhawo rumo. 
\q1  
\v 21 Kaka makaa miyo mach ngʼangʼni, 
\q2 to yien bende miyo mach liel, 
\q2 e kaka ngʼat makwiny kelo miero. 
\q1  
\v 22 Weche mag kuoth chalo gi chiemo mamit; 
\q2 gidhiyo e chuny dhano ma iye. 
\b  
\q1  
\v 23 Mana kaka range mangʼangʼni mowir e agulu mochwe chalo 
\q2 e kaka lep mager mar chuny mopongʼ gi richo. 
\q1  
\v 24 Jasigu wuondore koumore kod dhoge, 
\q2 to ei chunye okano miriambo. 
\q1  
\v 25 Kata bed ni wechene lombo chuny, kik iyie kode, 
\q2 nimar gik maricho abiriyo opongʼo chunye. 
\q1  
\v 26 Onyalo wuondore ni oonge wuond, 
\q2 to timbene maricho biro nenore ratiro e nyim oganda. 
\q1  
\v 27 Ka ngʼato okunyo bur, obiro lutore e iye; 
\q2 to ka ngʼato ngʼielo kidi, 
\q2 to kidino biro ngʼielore kaduogo ire. 
\q1  
\v 28 Lep mariambo mon kod jogo mohinyo, 
\q2 to dhok mawuondo ji kelo kethruok. 
\b  
\c 27  
\q1  
\v 1 Kik isungri kuom kiny, 
\q2 nikech ok ingʼeyo gima odiechiengʼ nyalo kelo. 
\b  
\q1  
\v 2 We ngʼat moro ema opaki, 
\q2 to ok dhogi iwuon; ngʼato machielo, to ok lewi iwuon. 
\b  
\q1  
\v 3 Kidi pek to kuoyo bende pek, 
\q2 to chandruok ma ngʼat mofuwo kelo pek moloyo gik moko ariyogo. 
\b  
\q1  
\v 4 Mirima kwiny to gero pek moloyo, 
\q2 to en ngʼa manyalo chomore gi nyiego? 
\b  
\q1  
\v 5 Kwero ngʼato ratiro ber 
\q2 moloyo hera mopandi. 
\b  
\q1  
\v 6 Adhonde moa kuom osiep inyalo geno, 
\q2 to jasigu medo mana nyoth mar masira. 
\b  
\q1  
\v 7 Ngʼat moyiengʼ ok dwar mor kich, 
\q2 to ngʼatno modenyo kata mana gima kech mitne. 
\b  
\q1  
\v 8 Mana kaka winyo mabayo moa e ode 
\q2 e kaka ngʼatno mabayo aa e dalane. 
\b  
\q1  
\v 9 Moo mangʼwe ngʼar gi ubani kelo mor ne chuny, 
\q2 to ber mar osiep ngʼato wuok kuom ngʼado rieko gi adiera. 
\b  
\q1  
\v 10 Kik ijwangʼ osiepni kod osiep wuonu, 
\q2 to kik idhi e od owadu ka chandruok omaki, 
\q2 ber dhi ir jabuti machiegni moloyo owadu man mabor. 
\b  
\q1  
\v 11 Bed mariek, wuoda kendo imi chunya mor 
\q2 eka anyalo dwoko ngʼato moro amora machaya. 
\b  
\q1  
\v 12 Ngʼat mariek neno masira kabiro kendo opondo, 
\q2 to ngʼat mofuwo dhiyo adhiya nyime ma ohinyre. 
\b  
\q1  
\v 13 Kaw law ngʼatno mochungʼne ngʼat mokia kaka singo; 
\q2 kawe ka okete singo kar dhako mabayo. 
\b  
\q1  
\v 14 Ka ngʼato ogwedho jabute e lela gokinyi mangʼich, 
\q2 to ochalo mana gi ngʼama kwongʼe. 
\b  
\q1  
\v 15 Dhako ma jakoko 
\q2 chalo gi kodh ajiki, 
\q1  
\v 16 kwerogo chalo gi gengʼo yamo 
\q2 kata mako moo gi lwedo. 
\b  
\q1  
\v 17 Kaka nyinyo piago nyinyo, 
\q2 e kaka ngʼato piago nyawadgi. 
\b  
\q1  
\v 18 Ngʼat mopidho ngʼowu biro chamo olembe, 
\q2 to ngʼatno marito ruodhe ibiro miyo luor. 
\b  
\q1  
\v 19 Kirango pi, to wangʼi iwuon ema ineno, 
\q2 kendo kinono chunyi, to in iwuon ema inenori. 
\b  
\q1  
\v 20 Tho kod kethruok ok rom ngangʼ, 
\q2 to kata mana wenge dhano bende ok rom. 
\b  
\q1  
\v 21 Dhahabu gi fedha itemo gi mach, 
\q2 to dhano itemo gi pak moyudo. 
\b  
\q1  
\v 22 Kata bed ni iyoko ngʼat mofuwo e pany, 
\q2 iyoke kaka cham miswago, 
\q2 ok inigol fupe oa kuome. 
\b  
\q1  
\v 23 Bed ni ingʼeyo maber kaka jambi chalo; 
\q2 bende rit maber kwethgi; 
\q1  
\v 24 nimar mwandu ok sik mochwere, 
\q2 to osimbo mar loch ok nobed ne tiengʼ ka tiengʼ. 
\q1  
\v 25 Ka ongʼad lum oko eka manyien twi, 
\q2 to ka ichoko ne jambi lum manie kor got, 
\q1  
\v 26 eka iniyud yie rombe milosgo lewni, 
\q2 kendo iningʼiew lowo gi pesa miyudo kuom diek. 
\q1  
\v 27 Ibiro bedo gi chak mangʼeny mar diek 
\q2 ma ibiro pidhorigo gi joodi kendo pidho nyiri matiyoni. 
\b  
\c 28  
\q1  
\v 1 Jaricho ringo kaonge ngʼama lawe, 
\q2 to joma kare jochir ka sibuor. 
\b  
\q1  
\v 2 Ka piny toke tek, to en gi jotelo mangʼeny, 
\q2 to ngʼat mawinjo wach kendo man-gi ngʼeyo rito chik. 
\b  
\q1  
\v 3 Jatelo mahinyo jochan 
\q2 chalo kaka kodh oula maywero cham oko. 
\b  
\q1  
\v 4 Jogo ma ok rit chik pako ngʼat marach, 
\q2 to jogo marito chik dagi jogo maricho. 
\b  
\q1  
\v 5 Jomaricho ok ongʼeyo adiera, 
\q2 to jogo madwaro Jehova Nyasaye ongʼeyo adiera chutho. 
\b  
\q1  
\v 6 Ber ngʼat ma jachan ma wuodhe ok cha, 
\q2 moloyo ngʼat ma ja-mwandu ma yorene richo. 
\b  
\q1  
\v 7 Ngʼat marito chik en wuowi mariek, 
\q2 to bedo osiep jawuoro kelo wichkuot ne wuon mare. 
\b  
\q1  
\v 8 Ngʼat mamedo mwandu gi ohala ma malangʼ choko mwandu ne ngʼat machielo, 
\q2 mabiro bedo mangʼwon gi jochan. 
\b  
\q1  
\v 9 Ka ngʼato odino ite ne chik, 
\q2 kata mana lemone bende richo. 
\b  
\q1  
\v 10 Ngʼat matero ngʼat moriere tir e yo mar richo 
\q2 biro podho e obetone owuon, 
\q2 to ngʼat ma ok cha biro yudo pok maber. 
\b  
\q1  
\v 11 Jamoko nyalo paro owuon ni oriek, 
\q2 to jachan man-gi paro matut neno gik manie chuny jamokono. 
\b  
\q1  
\v 12 Ka ngʼat makare oloyo, nitie mor maduongʼ, 
\q2 to ka ngʼat marach omi teko mondo otel, 
\q2 ji ringo dhiyo kar pondo. 
\b  
\q1  
\v 13 Ngʼat mapando richone ok dhi maber, 
\q2 to ngʼat ma hulo richone kendo oweyogi yudo ngʼwono. 
\b  
\q1  
\v 14 En ngʼama ogwedhi ngʼat moluoro Jehova Nyasaye kinde duto, 
\q2 to ngʼatno ma chunye tek donjo e chandruok. 
\b  
\q1  
\v 15 Kaka sibuor maruto kata ondiek madwaro kecho 
\q2 e kaka ngʼat marach motelone joma ok nyal. 
\b  
\q1  
\v 16 Ruoth ma jasunga onge gi rieko, 
\q2 to ngʼatno mamon gi gik moyud e yo marach biro dak amingʼa. 
\b  
\q1  
\v 17 Ngʼat moneko chunye chandore 
\q2 enobed gi kuyo nyaka otho; 
\q2 omiyo kik ngʼato konye. 
\b  
\q1  
\v 18 Ngʼatno ma ja-adiera ibiro rito maonge hinyruok, 
\q2 to ngʼatno ma yorene richo biro podho apoya nono. 
\b  
\q1  
\v 19 Ngʼat matiyo e puothe biro bedo gi chiemo mogundho, 
\q2 to ngʼat mabayo abaya biro bedo jachan mochwere. 
\b  
\q1  
\v 20 Ngʼat ma ja-adiera ibiro gwedho mangʼeny, 
\q2 to ngʼat madwaro gi teko bedo ja-mwandu ok notony ma ok okume. 
\b  
\q1  
\v 21 Dok ne ngʼato kayiem ka oketho ok ber, 
\q2 to ngʼato biro timo marach mana ni mondo oyud asoya matin. 
\b  
\q1  
\v 22 Ngʼat ma iye lit dwaro ahinya ni mondo obed gi mwandu 
\q2 to ok ongʼeyo ni chan orite. 
\b  
\q1  
\v 23 Ngʼatno makwero ngʼato gikone obiro yudo pwoch mangʼeny 
\q2 moloyo ngʼatno man-gi lep mawuondo. 
\b  
\q1  
\v 24 Ngʼat mamayo wuon mare kata min, 
\q2 to owacho niya, “Timo kamano ok rach,” 
\q2 ochal gi ngʼat maketho gimoro. 
\b  
\q1  
\v 25 Ngʼat ma jawuoro thoro kelo miero, 
\q2 to ngʼat mogeno kuom Jehova Nyasaye biro dhiyo maber. 
\b  
\q1  
\v 26 Ngʼat moketo genone kuome owuon ofuwo, 
\q2 to ngʼatno mawuotho e rieko, oritore maonge hinyruok. 
\b  
\q1  
\v 27 Ngʼat mamiyo jochan ok nochand gimoro, 
\q2 to ngʼat ma gengʼo wangʼe ne jochan noyud kwongʼ mangʼeny. 
\b  
\q1  
\v 28 Ka jaricho oketi e teko mondo otel, ji dhiyo kar pondo; 
\q2 to ka jaricho otho joma kare dhiyo nyime. 
\b  
\c 29  
\q1  
\v 1 Ngʼat masiko katoke tek bangʼ siem mangʼeny 
\q2 ibiro tieko apoya nono maonge konyruok. 
\b  
\q1  
\v 2 Ka joma kare dhiyo nyime, ji mor, 
\q2 ka joricho ema otelo e loch ji ywak ka gichur. 
\b  
\q1  
\v 3 Ngʼat mohero rieko miyo wuon mare mor, 
\q2 to ngʼat momako osiep kod jachode ketho mwandune. 
\b  
\q1  
\v 4 Gi adiera ema ruoth miyo piny bet mochungʼ motegno, 
\q2 to ngʼat mawuor ne asoya muke magoye piny. 
\b  
\q1  
\v 5 Ngʼat mawuondo jabute 
\q2 ochiko obadho e tiende. 
\b  
\q1  
\v 6 Ngʼat marach dwodore e obadho mar richone owuon, 
\q2 to ngʼat makare nyalo wer mobed mamor. 
\b  
\q1  
\v 7 Ngʼat makare winjo ywak jochan mondo otimnegi gima kare, 
\q2 to ngʼat marach ok dew gimoro. 
\b  
\q1  
\v 8 Joma jaro ji kelo koko e dala, 
\q2 to jomariek ringo aa e mirima. 
\b  
\q1  
\v 9 Ka ngʼat mariek odhiyo gi ngʼat mofuwo e od bura, 
\q2 to ngʼat mofuwo goyo koko kendo jero, 
\q2 kendo kwe bedo maonge. 
\b  
\q1  
\v 10 Joma ohero chwero remo mon kod jogo modimbore, 
\q2 kendo gidwaro yo mar nego joma jo-ratiro. 
\b  
\q1  
\v 11 Ngʼat mofuwo chiwore duto komwomore amwoma e mirimbe, 
\q2 to ngʼat mariek ritore ka ogare. 
\b  
\q1  
\v 12 Ka ruoth thoro chiko ite ne miriambo, 
\q2 to jootene duto bedo joma timbegi richo. 
\b  
\q1  
\v 13 Jachan gi ngʼat mahinyo ji nigi gimoro achiel machalre: 
\q2 Jehova Nyasaye miyogi wenge maneno kargi ji ariyogo. 
\b  
\q1  
\v 14 Ka ruoth ongʼado bura ne jochan kod adiera, 
\q2 kom ruodhe biro bedo moritore ma ok hinyre. 
\b  
\q1  
\v 15 Ka ichwado nyathi kendo ikwere eka ikonye bedo mariek 
\q2 to nyathi ma owe aweya kelo wichkuot ne min mare. 
\b  
\q1  
\v 16 Ka jaricho dhiyo nyime maber, e kaka richo bende medore, 
\q2 to joma kare biro neno podho margi. 
\b  
\q1  
\v 17 Kum wuodi, to obiro miyi kwe; 
\q2 kendo obiro kelo mor ne chunyi. 
\b  
\q1  
\v 18 Kama onge lek, to ji chunygi aa 
\q2 to ngʼama orito chik en ngʼat mogwedhi. 
\b  
\q1  
\v 19 Misumba ok nyal kony kirieye mana gi wach kende; 
\q2 kata bed ni owinjo, to ok obi rwako. 
\b  
\q1  
\v 20 Bende ineno ngʼato ma wuoyo ka rikni mapiyo piyo? 
\q2 Nitie geno mathoth kuom ngʼat mofuwo maloye. 
\b  
\q1  
\v 21 Ka ngʼato omiyo misumbane gik moko duto chakre ka en rawera, 
\q2 obiro kelo kuyo e gikone. 
\b  
\q1  
\v 22 Ngʼat ma iye owangʼ kelo masira, 
\q2 to ngʼat makecho piyo timo richo mathoth. 
\b  
\q1  
\v 23 Sunga ngʼato ema miyo opodho, 
\q2 to ngʼat ma chunye muol yudo pak. 
\b  
\q1  
\v 24 Ngʼat makonyo jakuo mondo okwal ema bedo jasike owuon; 
\q2 nikech osekwongʼore kendo ok onyal bedo janeno. 
\b  
\q1  
\v 25 Luoro mar dhano biro nyisore ni en gima duodo ngʼato, 
\q2 to ngʼat mogeno kuom Jehova Nyasaye orite maonge hinyruok. 
\b  
\q1  
\v 26 Ji mangʼeny dwaro mondo girom gi ruoth, 
\q2 to en mana kuom Jehova Nyasaye ema adiera yudoree. 
\b  
\q1  
\v 27 Joma kare mon gi joma ok jo-adiera, 
\q2 to joricho mon gi joma oriere tir. 
\c 30  
\ms1 Weche mag Agur 
\p  
\v 1 Magi e weche mag Agur wuod Jake, ma gin weche matut. 
\q1 Magi e weche ma Agur wachone Ithiel; 
\q2 adier owuoyo ne Ithiel niya, 
\b  
\q1 “Aol marumo, yaye Nyasaye, 
\q2 to pod anyalo wuoyo. 
\q1  
\v 2 Chutho afuwo ahinya ma ok awinjora bedo dhano; 
\q2 ok an kod ngʼeyo tiend wach mar dhano. 
\q1  
\v 3 Ok asepuonjora rieko, 
\q2 kata ngʼeyo mar Nyasaye, ma en Jal Maler Moloyo, bende aongego. 
\q1  
\v 4 En ngʼa mosedhi e polo kendo olor piny? 
\q2 En ngʼa mosechoko yamo moketo ei lwete? 
\q1 En ngʼa mosechoko pi gi lawe 
\q2 kata mosepimo giko mar tungʼ piny? 
\q1 Nyinge to en ngʼa, koso wuode to nyinge ngʼa? 
\q2 Nyisa ane ka ingʼeyo! 
\b  
\b  
\q1  
\v 5 “Wach ka wach moa kuom Nyasaye en adier; 
\q2 Nyasaye en okumba ne jogo mopondo kuome. 
\q1  
\v 6 Kik imed gimoro e wachne, 
\q2 to nono obiro kwedi mi onyis ni in ja-miriambo. 
\b  
\q1  
\v 7 “Gik moko ariyo makwayi; yaye Jehova Nyasaye; 
\q2 kik itama biro buti kapok atho. 
\q1  
\v 8 Mi wuond gi miriambo obed mabor koda; 
\q2 kik imiya chan kata mwandu, 
\q2 to miya mana chiemba mapile. 
\q1  
\v 9 Nimar, ka ok kamano, to anyalo bedo gi mwandu mangʼeny mi akwedi 
\q2 ka awacho ni, ‘Jehova Nyasaye to en ngʼa?’ 
\q1 Kata anyalo bedo jachan mi akwel, 
\q2 mi ami nying Nyasacha wichkuot. 
\b  
\q1  
\v 10 “Kik iwuo marach kuom jatich ne ngʼat mondike 
\q2 nono to obiro kwongʼi, mi iyud chandruok. 
\b  
\q1  
\v 11 “Nitie jogo makwongʼo wuonegi 
\q2 kendo ok gwedh minegi; 
\q1  
\v 12 jogo ma paro giwegi ni giler 
\q2 to ok osepwodhgi kuom kethruokgi; 
\q1  
\v 13 jogo ma wangʼ-gi tek masungore, 
\q2 manenogi richo; 
\q1  
\v 14 joma lekegi chalo gi ligangla 
\q2 kendo nyipongʼ lekegi chalo pelni mabitho, 
\q1 mar chamo jochan manie piny, 
\q2 kod joma odhier manie dier ji. 
\b  
\q1  
\v 15 “Chwe nigi nyiri ariyo. 
\q2 Giywak ni, ‘Miwa! Miwa!’ 
\b  
\li1 “Nitie gik moko adek ma ok rom ngangʼ! 
\li2 Angʼwen ma ok wach ni, ‘Oromo!’ 
\li3  
\v 16 Gin liel, 
\li3 ich ma ok onywol, 
\li3 lowo ma pi ok rom, 
\li3 kata mach ma ok wach ni, ‘Oromo!’ 
\b  
\q1  
\v 17 “Wangʼ ma jaro wuoro, 
\q2 ma dagi winjo wach miyo, 
\q1 ibiro lodho oko kod agak manie holo, 
\q2 ibiro chamgi gi achudhe. 
\b  
\li1  
\v 18 “Nitie gik moko adek mamiya awuoro ahinya, 
\li2 angʼwen ma ok anyal ngʼeyo tiendgi. 
\li3  
\v 19 Yor ongo e kor polo, 
\li3 yor thuol e kor lwanda, 
\li3 yor yie ei nam mogingore 
\li3 kod yor ngʼama wuowi gi nyako. 
\b  
\q1  
\v 20 “Ma e yor dhako ma jachode: 
\q2 Ochiemo to bangʼe oyweyo dhoge, 
\q2 mi owach ni, ‘Ok asetimo gimoro marach.’ 
\b  
\li1  
\v 21 “Nitie gik moko adek mateto piny, 
\li2 to kuom gik moko angʼwen piny ok nyal yiego: 
\li3  
\v 22 misumba modoko ruodh piny, 
\li3 kata ngʼat mofuwo mochiemo moyiengʼ, 
\li3  
\v 23 moro en dhako ma ok oher to okende 
\li3 eka mogik jatich ma nyako ma omayo dhako mondike dichwo. 
\b  
\li1  
\v 24 “Gik moko angʼwen matindo ni e piny, 
\li2 to kata kamano giriek moloyo. 
\li2  
\v 25 Biye gin chwech ma tekregi tin, 
\li3 to kata kamano gikano chiembgi e ndalo oro; 
\li2  
\v 26 aidha bende gin le man-gi teko matin, 
\li3 to giloso gondgi e kind kite, 
\li2  
\v 27 kata bonyo onge ruodhgi, 
\li3 to ka giringo gidhiyo nyime kaachiel ka gichanore ka ogend lweny. 
\li2  
\v 28 Kamano olele bende inyalo mako gi lwedo, 
\li3 to iyude kodak e ute ruoth. 
\b  
\li1  
\v 29 “Nitie gik moko adek ma wuodhgi lich ka irango, 
\li2 chutho angʼwen maringo malich miwuoro. 
\li3  
\v 30 Sibuor, en ratego moloyo kuom le duto, kendo onge gimoro moluoro, 
\li3  
\v 31 thuon gweno magar ka dwaro gwere 
\li3 gi wadgi, nywok, 
\li3 kod ruoth gi oganda mar lweny moluoro bute. 
\b  
\q1  
\v 32 “Ka isetimo tim fuwo ma imiyori duongʼ kendi, 
\q2 kata ka isechano richo, 
\q2 to um dhogi gi lweti! 
\q1  
\v 33 Mana kaka puoyo chak kelo mo, 
\q2 kendo goyo um chwero remo, 
\q2 e kaka jiwo kecho kelo lweny.” 
\c 31  
\ms1 Weche mag Ruoth Lemuel 
\p  
\v 1 Weche mag Ruoth Lemuel, ma gin weche matut ma min mare nopuonje. 
\q1  
\v 2 Yaye wuoda, yaye wuoda mane anywolo! 
\q2 Winja, in wuoda mane anywolo 
\q2 bangʼ ka Nyasaye osewinjo lemo mane atimonego singruok. 
\q1  
\v 3 Kik iket tekri kuom mon, 
\q2 kata nyalo mari kuom jogo maketho ruodhi. 
\b  
\q1  
\v 4 Ok en gima owinjore ne ruodhi, yaye Lemuel, 
\q2 mondo ruodhi omadh math makech, 
\q2 kata jotelo ogomb kongʼo gi chunygi duto, 
\q1  
\v 5 nono ka gimetho to wigi diwil gi gima chik ochiko, 
\q2 ma gihiny joma ok nyal ka gitamogi e ratichgi. 
\q1  
\v 6 Chiw kongʼo ne jogo ma chunygi ool, 
\q2 to math makech ne jogo ma chunygi lit. 
\q1  
\v 7 Wegi mondo gimethi mondo wigi owil gi chan-gi 
\q2 kendo kik gichak gipar chandruokgi kendo. 
\b  
\q1  
\v 8 Wuo ka ichwako joma ok nyal wacho wachgi gin giwegi, 
\q2 ka ichwako jogo maonge nyalo. 
\q1  
\v 9 Wuo kendo ngʼad bura kare, 
\q2 chwak ratich jogo ma jochan kod jogo mochando. 
\ms1 Weche Mogik: Dhako ma kite longʼo 
\q1  
\v 10 Dhako ma kite longʼo en ngʼa manyalo nwangʼo? 
\q2 Nengone oloyo kite ma nengogi tek. 
\q1  
\v 11 Chwore ogenogo chutho 
\q2 kendo onge gima oreme. 
\q1  
\v 12 Okelone mana ber, 
\q2 ok hinyruok ndalo duto mar ngimane. 
\q1  
\v 13 Oyiero yie rombe kod tworo 
\q2 kendo otiyo matek gi lwete. 
\q1  
\v 14 Ochalo gi yiedhi mag ohala, 
\q2 kokelo chiemo moa kuma bor. 
\q1  
\v 15 Ochiewo aa e nindo ka pod piny mudho, 
\q2 ochiwo chiemo ne joode to moko omiyo nyiri matiyone. 
\q1  
\v 16 Omanyo puodho maber mi ongʼiew, 
\q2 kendo kuom ohala moloko opidhogo puothe mag olembe. 
\q1  
\v 17 Otiyo tijene gi teko duto; 
\q2 kendo oratego e tije motiyo. 
\q1  
\v 18 Oneno ni gik moloso miye ohala 
\q2 to tache ok tho gotieno. 
\q1  
\v 19 Ei lwete otingʼo yie rombe 
\q2 kendo omako gir chwecho gi lith lwetene. 
\q1  
\v 20 Oyawo bade ne joma jochan 
\q2 kendo otero lwete ne jogo mochando. 
\q1  
\v 21 Ka piny ngʼich, oonge luoro ne joode, 
\q2 nikech giduto girwakore gi nengni mapichni. 
\q1  
\v 22 Oloso raum ne kitandane, 
\q2 orwakore gi lewni marep-rep maralik ma nengogi tek. 
\q1  
\v 23 Chwore imiyo luor e dhoranga dala maduongʼ, 
\q2 kama obedoe e dier jodongo mag gwengʼ. 
\q1  
\v 24 Oloso lewni marep-rep mi ousgi, 
\q2 kendo omiyo johala gik moko. 
\q1  
\v 25 Orwakore gi teko kod dimbruok; 
\q2 omiyo onyalo bedo mamor e ndalo mabiro. 
\q1  
\v 26 Owuoyo gi rieko 
\q2 kendo puonj mar adiera ni e lewe. 
\q1  
\v 27 Orito weche mag ode 
\q2 to ok ocham chiemb mifwadhi. 
\q1  
\v 28 Nyithinde chungo kendo luonge ni en ngʼat mogwedhi, 
\q2 chwore bende pake, kawacho niya, 
\q1  
\v 29 “Mon mangʼeny timo gik mabeyo, 
\q2 to in iloyogi duto.” 
\q1  
\v 30 Ber mar wangʼ wuondo ji, to chia bende rumo; 
\q2 to dhako moluoro Jehova Nyasaye yudo pak. 
\q1  
\v 31 Miye pak moromo kode mondo onwangʼ 
\q2 kendo we mondo tijene okelne pak e dhorangach mar dala maduongʼ.