\id 2SA
\h 2 صَامْوِيلْ 
\toc1 2 صَامْوِيلْ 
\toc2 2 صَامْوِيلْ 
\toc3 2 صم. 
\mt1 2 صَامْوِيلْ  
\c 1
\s1 ڒْموْثْ ن شَاوُولْ ذ يُونَاثَانْ  
\m
\v 1 إِمْسَارْ أَوَارْنِي إِ ڒْموْثْ ن شَاوُولْ، \add ؤُمِي\add* د-إِعْقبْ ذَاوُوذْ زِي ڒغْڒبْ خْ أَيْثْ ن عَامَالِيقْ، إِقِّيمْ ذَاوُوذْ ثْنَاينْ ن وُوسَّانْ ذِي صِيقْلَاغْ. \x ◘ \xo 1:‏1 \xt 1 صم. 30‏:‏17\x*  
\v 2 \add خنِّي\add* إِمْسَارْ ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا، أَقَا ذَا، يُوسَا-د إِجّْ ن ورْيَازْ زِي ڒْمَارْڭحْ ن ڒْعسْكَارْ ن شَاوُولْ س وَارُّوضْ إِشَارّڭْ ؤُ س ؤُشَاڒْ خْ ؤُزدْجِيفْ نّسْ. \add ؤُمِي\add* د-يِيوضْ نتَّا غَارْ ذَاوُوذْ، إِوْضَا غَارْ ثمُّورْثْ، يُوضَارْ \add أَسْ\add*.  
\v 3 ذَاوُوذْ إِنَّا أَسْ: ”مَانِيسْ إِ د-ثُوسِيذْ شكْ؟“ نتَّا يَارَّا-د خَاسْ: ”نشّْ سّْنجْمغْ-د إِخفْ إِنُو زِي ڒْمَارْڭحْ ن ڒْعسْكَارْ ن إِسْرَائِيل.“  
\v 4 ذَاوُوذْ إِنَّا أَسْ: ”مِينْ \add ذِينْ\add* ذ ڒخْبَارْ؟ إِنِي أَيِي ث!“ نتَّا يَارَّا-د خَاسْ: ”ڒْْڭنْسْ يَارْوڒْ زڭْ ؤُمنْغِي ؤُ أَطَّاسْ نْ ڒْڭنْسْ إِ وْضَانْ، مُّوثنْ. ؤُڒَا ذ شَاوُولْ ذ مِّيسْ يُونَاثَانْ مُّوثنْ.“  
\v 5 ذَاوُوذْ إِنَّا إِ ؤُحُوذْرِي نِّي ذ أَسْ د-يِيوْينْ ڒخْبَارْ: ”مَامّشْ ثڭِّيذْ ثسّْنذْ، بلِّي شَاوُولْ ذ مِّيسْ يُونَاثَانْ مُّوثنْ؟“  
\v 6 \add خنِّي\add* إِنَّا ؤُحُوذْرِي إِ ذ أَسْ د-يِيوْينْ ڒخْبَارْ: ”نشّْ ؤُسِيغْ-د أَمنِّي وَاهَا غَارْ إِذُورَارْ ن جِيلْبُوعَا ؤُشَا ژْرِيغْ مَامّشْ إِسنّذْ شَاوُولْ خْ لَانْسَا نّسْ ؤُ إِكَارُّوثنْ \add ن ؤُمنْغِي\add* ذ إِمْنَاينْ إِنِّي خَاسنْ إِنْيِينْ ضفَّارنْ ث بْڒَا قطُّو. \f ◼ \fr 1:‏6 \ft \+bd ’أَمْنَايْ - إِمْنَاينْ‘\+bd* - نِيغْ ’بُو-إِيْسَانْ‘ - ’أَيْثْ ن إِيْسَانْ‘. ذ ونِّي إِنْيِينْ خْ يِيجّْ ن ؤُيِيسْ ذ نتَّا ذ أَمْنَايْ.\f*  
\v 7 نتَّا، أَمْ د-إِنّقْڒبْ، إِژْرَا أَيِي، إِڒَاغَا أَيِي-د ؤُ نشّْ نِّيغْ أَسْ: ’أَقَا-يِي ذَا!‘  
\v 8 نتَّا إِنَّا أَيِي: ’مِينْ ثعْنِيذْ شكْ؟‘ نشّْ أَرِّيغْ-د خَاسْ: ’نشّْ زڭْ أَيْثْ ن عَامَالِيقْ.‘  
\v 9 \add خنِّي\add* إِنَّا أَيِي نتَّا: ’أَسْ-د غَارِي، نغْ أَيِي، مَاغَارْ نشّْ ثڒْقفْ أَيِي ثُوشّنْثْ، مَاشَا \add وَاخَّا أَمنِّي\add* ثُوذَارْثْ أَقَا-ت ذَايِي.‘ \f ◼ \fr 1:‏9 \ft \+bd ’ثُوذَارْثْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ‘.\f*  
\v 10 \add ڒخْذنِّي\add* نشّْ ؤُيُورغْ ؤُ نْغِيغْ ث، مَاغَارْ نشّْ سّْنغْ، أَقَا وَارْ إِتّْغِيمِي إِدَّارْ أَوَارْنِي إِ ؤُوطُّو نّسْ. \add خنِّي\add* كْسِيغْ تَّاجْ \add ن وعْزَاڒْ\add* نِّي خْ ؤُزدْجِيفْ نّسْ ذ ثْمقْيَاسْثْ إِ ثُوغَا غَارسْ ذڭْ ؤُغِيڒْ، إِوْيغْ ثنْ-د \add ڒخُّو\add* ذَا غَارْ سِيذِي إِنُو.“   
\m
\v 11 \add ڒخْذنِّي\add* إِطّفْ ذَاوُوذْ أَرُّوضْ نّسْ، إِشَارّڭْ إِ-ث. \add أَمُّو إِ ت ڭِّينْ\add* ؤُڒَا ذ مَارَّا إِرْيَازنْ إِ ثُوغَا غَارسْ إِدْجَانْ. \x ◘ \xo 1:‏11 \xt 2 صم. 3‏:‏31؛ 13‏:‏31\x*  
\v 12 نِيثْنِي وْثِينْ أَڭجْذُورْ، رُونْ ؤُ ژُومّنْ أَڒْ ثَامذِّيثْ خْ شَاوُولْ، خْ مِّيسْ يُونَاثَانْ، خْ ڒْڭنْسْ ن سِيذِي ؤُ خْ ثَادَّارْثْ ن إِسْرَائِيل، مِينْزِي وْضَانْ س سِّيفْ.   
\m
\v 13 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ ؤُحُوذْرِي نِّي ثُوغَا إِ ذ أَسْ-د-يِيوْينْ ڒخْبَارْ: ”زِي مَانِيسْ \add د-ثُوسِيذْ\add* شكْ؟“ نتَّا إِنَّا أَسْ: ”نشّْ ذ مِّيسْ ن إِجّْ ن ؤُبَارَّانِي، ن إِجّْ ن ورْيَازْ زڭْ أَيْثْ ن عَامَالِيقْ.“  
\v 14 ذَاوُوذْ إِنَّا أَسْ: ”مَامّشْ ثڭِّيذْ، شكْ وَارْ ثڭّْوِيذذْ شَا أَذْ ثسّْوِيژّْضذْ س ؤُفُوسْ حِيمَا أَذْ ثَاردّْدْجذْ أَمذْهُونْ ن سِيذِي؟“  
\v 15 \add خَاسْ\add* ؤُشَا إِڒَاغَا-د ذَاوُوذْ خْ إِجّنْ زڭْ إِمْسخَّارنْ إِنَّا: ”قَارّبْ-د، حيّحْ خَاسْ!“ ؤُ نتَّا إِحيّحْ خَاسْ أَڒَامِي ث إِنْغَا.  
\v 16 ذَاوُوذْ إِنَّا أَسْ: ”إِذَامّنْ نّشْ \add أَذْ إِڒِينْ\add* خْ ؤُزدْجِيفْ نّشْ، مَاغَارْ أَقمُّومْ نّشْ إِشْهذْ خَاكْ ؤُمِي ثنِّيذْ: ’نشّْ نْغِيغْ أَمذْهُونْ ن سِيذِي.‘ “   
\b  
\m  
\s1 إِزْڒِي س إِڭجْذُورنْ خْ شَاوُولْ ذ يُونَاثَانْ  
\m
\v 17 إِغنّجْ ذَاوُوذْ إِزْڒِي-يَا ن وشْضَانْ خْ شَاوُولْ ؤُ خْ مِّيسْ يُونَاثَانْ.  
\v 18 نتَّا إِنَّا: ”أَذْ ڒمْذنْ أَيْثْ ن يَاهُوذَا \add إِزْڒِي ن\add* ڒْقوْسْ.“ خْزَارْ، يُورَا ذڭْ وذْلِيسْ ن ؤُمْسڭّذْ. \x ◘ \xo 1:‏18 \xt ياش. 10‏:‏13\x*   
\b  
\m
\v 19 \qt ”ثَالْوِيزْثْ ن إِسْرَائِيل إِتّْوَانغْ\qt*  
\m \qt خْ ڒڭْعُوذِي نّشْ.\qt*  
\m \qt مَامّشْ وْضَانْ أَيْثْ ن بُو-ثغْرُوضْثْ!\qt*   
\m
\v 20 \qt وَارْ \+tl ت\+tl* تّْحَاجَامْ ذِي جَاثْ،\qt*  
\m \qt وَارْ تّْسِيوْضمْ ڒخْبَارْ\qt*  
\m \qt ذڭْ إِبْرِيذنْ ن أَشْقَالُونْ،\qt*  
\m \qt مَاحنْذْ يسِّيسْ ن إِفِيلِيسْطِينِييّنْ\qt*  
\m \qt وَارْ فَارّْحنْثْ،\qt*  
\m \qt مَاحنْذْ يسِّيسْ ن يِينِّي وَارْ إِتّْوَاخثْننْ\qt*  
\m \qt وَارْ سّْڒِيوْڒِيونْثْ.\qt* \x ◘ \xo 1:‏20 \xt مِيخَا 1‏:‏10\x*   
\m
\v 21 \qt \+tl أَ\+tl* إِذُورَارْ ن جِيلْبُوعَا،\qt*  
\m \qt وَارْ خَاومْ إِتِّيڒِي نّْذَا نِيغْ أَنْژَارْ،\qt*  
\m \qt وَارْ خَاومْ تِّيڒِينْ إِيَّارنْ\qt*  
\m \tl مَاحنْذْ أَذْ زَّايْسنْ تّْوَاكّْسنْثْ\tl*  
\m \qt ثِيوْهِيبِينْ ن ؤُسْڭعّذْ،\qt*  
\m \qt مَاغَارْ ذِينْ إِتّْوَابقّضْ\qt*  
\m \qt ثْسدَّارْثْ ن أَيْثْ ن بُو-ثغْرُوضْثْ س ڒْعَارْ،\qt*  
\m \qt ثَاسدَّارْثْ ن شَاوُولْ،\qt*  
\m \qt \+tl أَخْمِي نتَّا\+tl* وَارْ إِدْجِي ذ أَمذْهُونْ س زّشْثْ.\qt*   
\m
\v 22 \qt زڭْ إِذَامّنْ ن يِينِّي إِتّْوَانْغنْ،\qt*  
\m \qt زِي ثَاذُونْثْ ن أَيْثْ ن بُو-ثغْرُوضْثْ\qt*  
\m \qt وَارْ ذ إِمْنِيعْ ڒْقوْسْ ن يُونَاثَانْ،\qt*  
\m \qt ؤُ سِّيفْ ن شَاوُولْ وَارْ د-إِعْقِيبْ بَاطڒْ.\qt*   
\m
\v 23 \qt شَاوُولْ ذ يُونَاثَانْ تّْوَاعِيزّنْ\qt*  
\m \qt ذ إِغْڒَانْ \+tl غَارْ إِوْذَانْ\+tl* ذِي ثُوذَارْثْ نْسنْ،\qt*  
\m \qt ؤُ ذِي ڒْموْثْ نْسنْ وَارْ مّْسبْضِينْ.\qt*  
\m \qt \+tl نِيثْنِي ثُوغَا أَثنْ\+tl* فْسُوسنْ خْ إِڭِيذَارنْ\qt*  
\m \qt ذ جهْذنْ خْ وَايْرَاذنْ.\qt*   
\m
\v 24 \qt \+tl أَ\+tl* يسِّيسْ ن إِسْرَائِيل، رُونْثْ خْ شَاوُولْ،\qt*  
\m \qt ونِّي كنِّينْثْ إِسّْيَارْضنْ س ؤُزڭّْوَاغْ،\qt*  
\m \qt س ڒقْشُوعْ إِغْڒَانْ،\qt*  
\m \qt ذ ونِّي إِڭِّينْ ثَالْوِيزْثْ ن وُورغْ\qt*  
\m \qt خْ وَارُّوضْ نْكنْثْ.\qt*   
\m
\v 25 \qt مَامّشْ إِ وْضَانْ أَيْثْ ن بُو-ثغْرُوضْثْ\qt*  
\m \qt ذِي ڒْوسْطْ ن ؤُمنْغِي!\qt*  
\m \qt \+tl أَ،\+tl* يُونَاثَانْ، ثتّْوَانْغذْ خْ ڒڭْعُوذِي نّشْ.\qt*   
\m
\v 26 \qt ذِي سِّيبّثْ نّشْ تّْوَاحْصَارغْ،\qt*  
\m \qt \+tl أَ\+tl* ؤُمَا يُونَاثَانْ!\qt*  
\m \qt شكْ ثُوغَا ثتّْوَاعِيزّذْ غَارِي أَطَّاسْ.\qt*  
\m \qt ثُوغَا ثَايْرِي نّشْ غَارِي ذ سَّارْ كْثَارْ\qt*  
\m \qt خْ ثَايْرِي ن ثمْغَارِينْ.\qt*   
\m
\v 27 \qt مَامّشْ وْضَانْ أَيْثْ ن بُو-ثغْرُوضْثْ،\qt*  
\m \qt \+tl مَامّشْ\+tl* ودَّارنْ ڒسْنَاحْ ن ؤُمنْغِي!“\qt*   
\b  
\b  
\m  
\c 2
\s1 ذَاوُوذْ إِتّْوَاذْهنْ أَمْ ؤُجدْجِيذْ خْ يَاهُوذَا  
\m
\v 1 أَوَارْنِي ؤُيَا إِمْسَارْ، أَقَا ذَاوُوذْ إِسّقْسَا سِيذِي، إِنَّا: ”مَا أَذْ ڭعّْذغْ غَارْ إِشْثنْ زِي ثْندَّامْ ن يَاهُوذَا؟“ سِيذِي إِنَّا أَسْ: ”ڭعّذْ!“ ؤُشَا ذَاوُوذْ إِنَّا: ”مَانِي غَا ڭعّْذغْ؟“ نتَّا إِنَّا: ”غَارْ حَابْرُونْ.“  
\v 2 \add خنِّي\add* إِڭعّذْ ذَاوُوذْ غَارْ حَابْرُونْ أَكْ-ذ ثْنَاينْ ن ثمْغَارِينْ نّسْ، أَخِينُوعَامْ زِي يَازْرَاعِيلْ، ؤُ أَبِيجَايِيلْ، ثَامْغَارْثْ ن نَابَالْ زِي كَارْمِيلْ.  
\v 3 ذَاوُوذْ يَارَّا أَذْ ڭعّْذنْ عَاوذْ إِرْيَازنْ نِّي ثُوغَا أَكِيذسْ \add إِدْجَانْ\add*، \add كُوڒْ\add* أَرْيَازْ أَكْ-ذ ثْوَاشُونْثْ نّسْ، ؤُشَا نِيثْنِي ؤُيُورنْ أَذْ زذْغنْ ذِي ثْندَّامْ ن حَابْرُونْ.  
\v 4 \add أَوَارْنِي ؤُيَا\add* ؤُسِينْ-د يرْيَازنْ ن يَاهُوذَا \add غَارْ حَابْرُونْ\add* ؤُشَا ذهْننْ ذَاوُوذْ ذِينِّي ذ أَجدْجِيذْ خْ ثَادَّارْثْ ن يَاهُوذَا. \add خنِّي\add* ؤُسِينْ-د حِيمَا أَذْ خبَّارنْ ذَاوُوذْ، نَّانْ: ”إِرْيَازنْ ن يَابِيشْ ذِي جِيلْعَاذْ أَقَا نضْڒنْ شَاوُولْ.“   
\m
\v 5 \add خنِّي\add* إِسّكّْ ذَاوُوذْ إِرقَّاسنْ غَارْ يرْيَازنْ ن يَابِيشْ ذِي جِيلْعَاذْ، إِنَّا أَسنْ: ”أَذْ كنِّيوْ إِبَاركْ سِيذِي، مِينْزِي كنِّيوْ ثڭِّيمْ إِ شَاوُولْ، سِيذِي نْومْ، س ثْمخْسِيوْثْ إِشوَّارنْ ؤُشَا ثْنضْڒمْ ث.  
\v 6 أَذْ أَومْ إِسّْشنْ سِيذِي ڒخُّو ثَامخْسِيوْثْ \add نّسْ\add* إِشوَّارنْ ذ ڒَامَانْ نّسْ. ؤُڒَا ذ نشّْ أَذْ أَومْ ڭّغْ س ثْشُونِي، مِينْزِي أَقَا كنِّيوْ ثڭِّيمْ أَيَا.  
\v 7 خنِّي ڒخُّو، جّمْ أَذْ تّْوَاسّْجهْذنْ إِفَاسّنْ نْومْ ؤُ إِڒِيمْ ثْمحّْذمْ، مَاغَارْ شَاوُولْ، سِيذِي نْومْ، إِمُّوثْ. ؤُڒَا ذ ثَادَّارْثْ ن يَاهُوذَا ثذْهنْ أَيِي ذ أَجدْجِيذْ خَاسنْ.“   
\b  
\m  
\s1 ذَاوُوذْ ذ إِشْ-بُوشَاثْ، مِّيسْ ن شَاوُولْ  
\m
\v 8 أَبْنِيرْ، مِّيسْ ن نِيرْ، أَكُومَانْذَارْ ن ڒْعسْكَارْ ن شَاوُولْ، ثُوغَا يِيوِي أَكِيذسْ إِشْ-بُوشَاثْ، مِّيسْ ن شَاوُولْ، غَارْ مَاحَانَايِيمْ.  
\v 9 نتَّا إِڭَّا إِ-ث ذ أَجدْجِيذْ خْ جِيلْعَاذْ، خْ إِشُورِييّنْ، خْ يَازْرَاعِيلْ، خْ إِفْرَايِيمْ، خْ بِينْيَامِينْ ؤُ خْ مَارَّا إِسْرَائِيل.  
\v 10 إِشْ-بُوشَاثْ، مِّيسْ ن شَاوُولْ، ثُوغَا غَارسْ أَربْعِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ نتَّا ذ أَجدْجِيذْ خْ إِسْرَائِيل، ؤُ نتَّا إِحْكمْ ثْنَاينْ ن إِسڭّْوُوسَا. مْغِيرْ إِنِّي ن ثَادَّارْثْ ن يَاهُوذَا بدّنْ أَكْ-ذ ذَاوُوذْ.  
\v 11 ڒْقدّْ ن وُوسَّانْ إِ ثُوغَا ذَاوُوذْ إِحْكمْ ذِي حَابْرُونْ أَمْ ؤُجدْجِيذْ خْ ثَادَّارْثْ ن يَاهُوذَا، ثُوغَا سبْعَا ن إِسڭّْوُوسَا ذ ستَّا ن إِيُورنْ. \x ◘ \xo 2:‏11 \xt 2 صم. 5‏:‏5؛ 1 إِج. 2‏:‏11\x*   
\m
\v 12 أَبْنِيرْ، مِّيسْ ن نِيرْ، إِفّغْ أَكْ-ذ إِمْسخَّارنْ ن إِشْ-بُوشَاثْ، مِّيسْ ن شَاوُولْ، زِي مَاحَانَايِيمْ غَارْ جِيبْعُونْ.  
\v 13 ؤُڒَا ذ يُووَابْ، مِّيسْ ن صَارُويَا، ذ إِمْسخَّارنْ ن ذَاوُوذْ فّْغنْ ؤُشَا نِيثْنِي مّڒْقَانْ أَكْ-ذ وَايَاوْيَا غَارْ ؤُيڒْمَامْ ن جِيبْعُونْ. \add ذِينِّي\add* قِّيمنْ نِيثْنِي بدّنْ، إِجّْ غَارْ ؤُغزْذِيسْ-أَ ن ؤُيڒْمَامْ ؤُ ونّغْنِي خْ ؤُجمَّاضْ ن ؤُيڒْمَامْ.  
\v 14 إِنَّا أَبْنِيرْ إِ يُووَابْ: ”أجّْ إِحُوذْرِييّنْ أَذْ كَّارنْ أَذْ مُّوغْزْڒنْ زَّاثْنغْ.“ يُووَابْ إِنَّا: ”نِيثْنِي أَذْ كَّارنْ!“  
\v 15 نِيثْنِي كَّارنْ، \add خنِّي\add*عدُّونْ. أَقَا حسْبنْ ثنْعَاشْ زِي بِينْيَامِينْ إِ إِشْ-بُوشَاثْ، مِّيسْ ن شَاوُولْ، ؤُ ثنْعَاشْ زڭْ إِمْسخَّارنْ ن ذَاوُوذْ.  
\v 16 إِجّْ إِطّفْ ونّغْنِي زڭْ ؤُزدْجِيفْ ؤُ إِجُّو أَسْ س سِّيفْ نّسْ ذڭْ ؤُغزْذِيسْ ن ونّغْنِي ؤُ نِيثْنِي وْضَانْ س ثْنَاينْ إِذْسنْ. س ؤُينِّي قَّارنْ أَسْ إِ ومْشَانْ نِّي حَالْقَاثْ-هَاصُورِيمْ ونِّي \add إِدْجَانْ\add* غَارْ جِيبْعُونْ.  
\v 17 ذڭْ وَاسّْ نِّي إِذْوڒْ ؤُمنْغِي إِقْسحْ أَطَّاسْ. أَبْنِيرْ ذ يرْيَازنْ ن إِسْرَائِيل تّْوَاغلّْبنْ زَّاثْ إِ وُوذمْ ن إِمْسخَّارنْ ن ذَاوُوذْ.   
\m
\v 18 ثُوغَا ذِينْ ثْڒَاثَا ن إِحنْجِيرنْ ن صَارُويَا، نِيثْنِي ذ يُووَابْ ذ أَبِيشَايْ ذ عَسَائِيلْ. عَسَائِيلْ ثُوغَا إِفْسُوسْ خْ إِضَارنْ أَمْ يِيجّْ زڭْ إِغَايْضنْ ن وزْغَارْ ذڭْ إِيَّارْ.  
\v 19 عَسَائِيلْ إِضْفَارْ أَبْنِيرْ. ؤُمِي ثُوغَا إِڭُّورْ، وَارْ إِحيّذْ غَارْ ضفَّارْ ن أَبْنِيرْ، \add ڒَْا غَارْ\add* يفُوسْ ؤُڒَا \add غَارْ\add* ؤُزڒْمَاضْ.  
\v 20 ؤُشَا إِنّقْڒبْ أَبْنِيرْ، إِنَّا: ”مَا ذ شكْ، عَسَائِيلْ؟“ ؤُ نتَّا إِنَّا: ”ذ نشّْ!“  
\v 21 أَبْنِيرْ إِنَّا أَسْ: ”فَارْغْ \add غَارْ\add* يفُوسْ نِيغْ \add غَارْ\add* ؤُزڒْمَاضْ ؤُ شبَّارْ ذڭْ إِجّْ زڭْ إِحُوذْرِييّنْ ؤُ كْسِي إِ يِيخفْ نّشْ أَرُّوضْ نّسْ ن ڒْعسْكَارْ!“ عَسَائِيلْ \add مَاشَا\add* وَارْ إِخْسْ أَذْ خَاسْ إِحيّذْ زِي ضفَّارْ نّسْ.  
\v 22 \add خنِّي\add* إِنَّا أَبْنِيرْ عَاوذْ إِ عَسَائِيلْ: ”حيّذْ زِي ضفَّارْ إِنُو. مَايمِّي شكْ إِ غَا وْثغْ غَارْ ثمُّورْثْ؟ مَامّشْ إِ غَا ڭّغْ خنِّي عَاذْ أَذْ خْزَارغْ إِ ؤُمَاشْ يُووَابْ ذِي ثِيطَّاوِينْ؟“  
\v 23 نتَّا \add مَاشَا\add* يُوڭِي أَذْ أَسْ إِحيّذْ. \add خنِّي\add* إِجُّو أَسْ أَبْنِيرْ ذڭْ ؤُعذِّيسْ س يِيخفْ أَنڭَّارُو ن لَانْسَا نّسْ، أَڒَامِي د-إِسُّوفّغْ فْڒِيثْشَا زِي ضفَّارْ. نتَّا إِوْضَا ذِينْ ؤُشَا إِمُّوثْ ذڭْ ومْشَانْ نِّي. إِمْسَارْ بلِّي مَارَّا إِنِّي د-يُوسِينْ غَارْ ومْشَانْ مَانِي إِوْضَا ؤُ مَانِي إِمُّوثْ عَسَائِيلْ، قِّيمنْ بدّنْ.  
\v 24 يُووَابْ ذ أَبِيشَايْ ضْفَارنْ أَبْنِيرْ. ڒَامِي د-إِوْضنْ نِيثْنِي أَڒْ ثَاوْرِيرْثْ ن أَمَّا، ثنِّي زَّاثْ إِ جِييَاحْ، غَارْ وبْرِيذْ ن ڒخْڒَا ن جِيبْعُونْ، ثغْڒِي ثْفُوشْثْ.  
\v 25 أَيْثْ ن بِينْيَامِينْ مُوننْ أَوَارْنِي أَبْنِيرْ، ذوْڒنْ ذ إِشْثْ ن ثرْبِيعْثْ \add أَكِيذسْ\add*، ؤُشَا \add أَمُّو إِ قِّيمنْ\add* نِيثْنِي بدّنْ خْ ثْقِيشّثْ ن إِشْثْ ن ثوْرِيرْثْ.  
\v 26 أَبْنِيرْ إِڒَاغَا-د خْ يُووَابْ، إِنَّا: ”مَا أَذْ إِشّْ سِّيفْ إِ ڒبْذَا؟ مَا وَارْ ثسِّينذْ شكْ، أَقَا أَيَا أَذْ إِنْذهْ غَارْ إِجّْ ن ؤُقطُّو ذ أَمرْزَاڭْ؟ أَڒْ مڒْمِي \add عَاذْ\add* وَارْ ثقَّارذْ إِ ڒْڭنْسْ \add نّشْ،\add* حِيمَا أَذْ إِعْقبْ زڭْ وضْفَارْ ن أَيْثْمَاثْسنْ؟“  
\v 27 يُووَابْ إِنَّا: ”\add س ثِيذتّْ أَمْ\add* إِدَّارْ أَربِّي، مَاڒَا شكْ وَارْ ثسِّيوْڒذْ \add خْ إِجّْ ن ؤُمُوغْزڒْ\add*، خنِّي أَذْ يِيڒِي ڒْڭنْسْ إِسّْبدّْ \add زِي مَانْ أَيَا\add* غَارْ صّْبحْ، إِڒِي \add كُوڒْ\add* أَرْيَازْ \add أَذْ إِسّْبدّْ\add* زڭْ وضْفَارْ ن ؤُمَاسْ!“  
\v 28 \add خنِّي\add* إِسُوضْ يُووَابْ ذڭْ ؤُيِيشّْ ن إِشَارِّي ؤُ مَارَّا ڒْڭنْسْ إِسّْبدّْ. نِيثْنِي وَارْ ضْفَارنْ عَاذْ إِسْرَائِيل ؤُشَا وَارْ مّنْغنْ عَاذْ كْثَارْ.   
\m
\v 29 أَبْنِيرْ ذ يرْيَازنْ نّسْ شُوقنْ دْجِيڒثْ نِّي مَارَّا ذِي ڒوْضَا، ژْوَانْ لْ-ؤُرْذُونْ، كِّينْ خْ مَارَّا ثَاغْزُورْثْ ؤُشَا إِوْضنْ غَارْ مَاحَانَايِيمْ.  
\v 30 ؤُڒَا ذ يُووَابْ إِعْقبْ-د زڭْ وضْفَارْ ن أَبْنِيرْ ؤُ نتَّا إِسّْمُونْ مَارَّا ڒْڭنْسْ. ودَّارنْ ثْسعْطَاشْ ن إِرْيَازنْ ن ذَاوُوذْ ؤُڒَا ذ عَسَائِيلْ.  
\v 31 إِمْسخَّارنْ ن ذَاوُوذْ \add مَاشَا\add* ثُوغَا وْثِينْ \add أَطَّاسْ ن يرْيَازنْ\add* زڭْ \add أَيْثْ ن\add* بِينْيَامِينْ ؤُ زڭْ يرْيَازنْ ن أَبْنِيرْ. مُّوثنْ ثڒْثْ-مْيَا ؤُ-ستِّينْ ن يرْيَازنْ.  
\v 32 نِيثْنِي سّْڭعّْذنْ عَسَائِيلْ ؤُ نضْڒنْ ث ذڭْ ونْضڒْ ن بَابَاسْ ذِي بَايْثْ-لَاحْمْ. يُووَابْ ذ يرْيَازنْ نّسْ ؤُيُورنْ دْجِيڒثْ نِّي مَارَّا ؤُ ڒَامِي إِوْضنْ غَارْ حَابْرُونْ، ثنْقَارْ-د خَاسنْ ثْفَاوْثْ.   
\b  
\b  
\m  
\c 3
\s1 أَمنْغِي جَارْ أَيْثْبَابْ ن ثَادَّارْثْ ن شَاوُولْ ذ ذَاوُوذْ  
\m
\v 1 إِذْوڒْ  إِجْ ن ؤُمنْغِي جَارْ ثَادَّارْثْ ن شَاوُولْ ذ ثَادَّارْثْ ن ذَاوُوذْ إِ إِكِّينْ أَطَّاسْ. ذَاوُوذْ إِذْوڒْ يَارنِّي ذِي جّْهذْ ؤُ إِنِّي ن ثَادَّارْثْ ن شَاوُولْ ڭُّورنْ أَرخُّونْ.   
\b  
\m
\v 2 \bd ذِي حَابْرُونْ تّْوَارْونْ-د إِ ذَاوُوذْ إِحنْجِيرنْ.\bd* أَمنْزُو نّسْ أَمْنُونْ، ن أَخِينُوعَامْ ثَايَازْرَاعِيلِيثْ. \f ◼ \fr 3:‏2 \ft \+bd ’ثَايَازْرَاعِيلِيثْ‘\+bd* - إِشْثْ ن ثمْغَارْثْ زِي جِّيهثْ ن يَازْرَاعِيلْ ذِي شَّامَالْ ن إِسْرَائِيل.\f*  \x ◘ \xo 3:‏2 \xt 1 إِم. 3‏:‏1‏-‏9\x*  
\v 3 وِيسّْ ثْنَاينْ نّسْ كِيلْ‘أَبْ، ن أَبِيجَايِيلْ، ثَامْغَارْثْ ن نَابَالْ، أَكَارْمَالِي، وِيسّْ ثْڒَاثَا أَبْشَالُومْ، مِّيسْ ن مَاعْكَا، يدْجِيسْ ن ثَالْمَايْ، أَجدْجِيذْ ن جَاشُورْ، \f ◼ \fr 3:‏3 \ft \+bd ’أَكَارْمَالِي‘\+bd* - إِجّْ ن ورْيَازْ زِي جِّيهثْ ن كَارْمِيلْ.\f*  
\v 4 وِيسّْ أَربْعَا أَذُونِييَا، مِّيسْ ن هَاجِّيثْ، وِيسّْ خمْسَا شَافَاطْيَا، مِّيسْ ن أَبِيطَالْ،  
\v 5 ؤُ وِيسّْ ستَّا يِيثْرَاعَامْ، ن عَاجْلَا، ثَامْغَارْثْ ن ذَاوُوذْ. إِنَا تّْوَارْونْ-د غَارْ ذَاوُوذْ ذِي حَابْرُونْ.   
\b  
\m
\v 6 مِينْ إِكَّا ؤُمنْغِي جَارْ ثَادَّارْثْ ن شَاوُولْ ذ ثَادَّارْثْ ن ذَاوُوذْ، إِمْسَارْ، أَقَا أَبْنِيرْ إِسّمْغَارْ ثِيزمَّارْ نّسْ ذِي ثَادَّارْثْ ن شَاوُولْ.  
\v 7 شَاوُولْ ثُوغَا غَارسْ إِشْثْ ن ثَايَّا، تّْڒَاغَانْ أَسْ رِيصْفَا. نتَّاثْ ثُوغَا-ت ذ يدْجِيسْ ن أَيَّا. ؤُشَا إِنَّا \add إِشْ-بُوشَاثْ\add* إِ أَبْنِيرْ: ”مَايمِّي ثُوذْفذْ غَارْ ثَايَّا ن بَابَا؟“ \x ◘ \xo 3:‏7 \xt 2 صم. 21‏:‏8، 10، 11\x*  
\v 8 أَبْنِيرْ إِفُّوڭمْ خْ وَاوَاڒنْ ن إِشْ-بُوشَاثْ، إِنَّا: ”مَا نشّْ ذ إِجّْ ن ؤُزدْجِيفْ ن وقْزِينْ إِ إِقّْننْ غَارْ يَاهُوذَا؟ مَا وَارْ إِدْجِي ذ نشّْ ذ ونِّي إِسّْشَاننْ \add عَاذْ أَڒْ\add* أَسّْ-أَ ثَامخْسِيوْثْ \add إِنُو\add* إِشوَّارنْ إِ ثَادَّارْثْ ن شَاوُولْ، بَابَاشْ، ؤُ إِ يَايْثْمَاسْ ؤُ إِ إِمدُّوكَّاڒْ نّسْ، مَا وَارْ إِدْجِي ذ نشّْ ذ ونِّي وَارْ شكْ إِجِّينْ أَذْ ثوْضِيذْ ذڭْ إِفَاسّنْ ن ذَاوُوذْ؟ مَا ثخْسذْ \add خنِّي\add* أَذْ خَافِي ثْعيَّارذْ أَسّْ-أَ خْ ڒْمُوعْصِييّثْ أَكْ-ذ إِشْثْ ن ثمْغَارْثْ؟  
\v 9 أجّْ أَربِّي أَذْ إِڭّْ ثَا ذ ثَا أَكْ-ذ أَبْنِيرْ ؤُ أَذْ ذَايسْ يَارْنِي عَاذْ! أَمْ مَامّشْ إِجُّودْجْ سِيذِي إِ ذَاوُوذْ أَمُّو إِ زَّايسْ غَا ڭّغْ،  
\v 10 ؤُمِي غَا سّعْذُوغْ ثَاڭلْذِيثْ ن ثَادَّارْثْ ن شَاوُولْ ؤُشَا أَذْ سّْمثْنغْ ڒْعَارْشْ ن ذَاوُوذْ خْ إِسْرَائِيل ؤُ خْ يَاهُوذَا، زِي ذَانْ أَڒْ بِئرْ-سبْعَا.“  
\v 11 ؤُشَا نتَّا وَارْ إِزمَّارْ خْ ثمْوَارِّيثْ إِ أَبْنِيرْ، مَاغَارْ نتَّا ثُوغَا إِڭّْوذْ زَّايسْ.   
\m
\v 12 \add خنِّي\add* إِسّكّْ أَبْنِيرْ إِرقَّاسنْ ذِي طّْوعْ ن يِيخفْ نّسْ غَارْ ذَاوُوذْ، إِنَّا: ”وِي \add يِيڒَانْ\add* ثَامُّورْثْ؟“ إِنَّا \add عَاوذْ\add*: ”أڭّْ أَكِيذِي ڒْعَاهْذْ نّشْ، خْزَارْ، أَذْ أَشْ وْشغْ أَفُوسْ حِيمَا مَارَّا إِسْرَائِيل أَذْ غَاركْ د-إِنّقْڒبْ.“  
\v 13 ؤُ نتَّا إِنَّا: ”مْلِيحْ، نشّْ أَذْ ڭّغْ إِجّْ ن ڒْعَاهْذْ أَكِيذكْ، مَاشَا مْغِيرْ إِشْثْ ن ثْمسْڒَاشْثْ أَذْ أَشْ ت تَّارغْ. أَذْ أَشْ إِنِيغْ: ’شكْ وَارْ ثْژَارّذْ ؤُذمْ إِنُو، مْغِيرْ مَاڒَا شكْ أَذْ ثَاوْيذْ \add ذَا\add* ذ أَمزْوَارُو مِيخَالْ، يدْجِيسْ ن شَاوُولْ، خْمِي د غَا ثَاسذْ حِيمَا أَذْ ثْژَارذْ ؤُذمْ إِنُو.‘ “   
\m
\v 14 خنِّي إِسّكّْ ذَاوُوذْ إِرقَّاسنْ غَارْ إِشْ-بُوشَاثْ، مِّيسْ ن شَاوُولْ، إِنَّا: ”أوْشْ أَيِي-د ثَامْغَارْثْ إِنُو مِيخَالْ، ثنِّي إِ د-إِوْيغْ س مْيَا ن ڒعْذَاڒيَّاثْ ن إِفِيلِيسْطِينِييّنْ س وخْضَابْ ن ثسْڒِيثْ!“ \x ◘ \xo 3:‏14 \xt 1 صم. 18‏:‏25، 27\x*  
\v 15 إِشْ-بُوشَاثْ إِسّكّْ \add إِرقَّاسنْ\add* ؤُشَا إِكّسْ إِ-ت خْ ورْيَازْ نّسْ، خْ فَالْطِييِيلْ، مِّيسْ ن لَايِيشْ. \x ◘ \xo 3:‏15 \xt 1 صم. 25‏:‏44\x*  
\v 16 أَرْيَازْ نّسْ يُويُورْ أَكِيذسْ أَڒْ بَاخُورِيمْ، يُويُورْ إِتّْرُو أَوَارْنِي أَسْ. \add خنِّي\add* إِنَّا أَسْ أَبْنِيرْ: ”ؤُيُورْ، عْقبْ!“ ؤُشَا إِعْقبْ نتَّا.   
\m
\v 17 ثُوغَا إِسِّيوڒْ أَبْنِيرْ خْ إِمْغَارنْ ن إِسْرَائِيل، إِنَّا: ”أَطَّاسْ زڭْ وَامِي كنِّيوْ ثخْسمْ ذَاوُوذْ \add أَذْ يِيڒِي\add* ذ أَجدْجِيذْ خَاومْ.  
\v 18 ڒخُّو ڭّمْ ث، مَاغَارْ سِيذِي إِسِّيوڒْ أَكْ-ذ ذَاوُوذْ، إِنَّا: ’س ؤُفُوسْ ن ذَاوُوذْ، أَمْسخَّارْ إِنُو، أَذْ فكّغْ ڒْڭنْسْ إِنُو إِسْرَائِيل زڭْ ؤُفُوسْ ن إِفِيلِيسْطِينِييّنْ ؤُ زڭْ ؤُفُوسْ ن مَارَّا ڒْعذْيَانْ نْسنْ.‘ “  
\v 19 إِسِّيوڒْ أَبْنِيرْ ؤُڒَا ذڭْ إِمزُّوغنْ ن \add أَيْثْ ن\add* بِينْيَامِينْ. \add خنِّي\add* يُويُورْ أَبْنِيرْ غَارْ حَابْرُونْ، حِيمَا أَذْ إِسِّيوڒْ ذڭْ إِمزُّوغنْ ن ذَاوُوذْ خْ مَارَّا مِينْ إِدْجَانْ ذ لمْلِيحْ ذِي ثِيطَّاوِينْ ن إِسْرَائِيل ؤُ ذِي ثِيطَّاوِينْ ن ثَادَّارْثْ ن بِينْيَامِينْ.   
\m
\v 20 ؤُشَا يُوسَا-د أَبْنِيرْ غَارْ ذَاوُوذْ ذِي حَابْرُونْ. ثُوغَا عِيشْرِينْ ن يرْيَازنْ أَكِيذسْ. ذَاوُوذْ إِڭَّا إِشْثْ ن زَّارْذثْ إِ أَبْنِيرْ ذ يرْيَازنْ إِ كِيذسْ \add إِدْجَانْ\add*.  
\v 21 \add خنِّي\add* إِنَّا أَبْنِيرْ إِ ذَاوُوذْ: ”نشّْ أَذْ كَّارغْ أَذْ طّْفغْ أَبْرِيذْ مَاحنْذْ أَذْ يَارْوغْ مَارَّا إِسْرَائِيل غَارْ سِيذِي إِنُو، أَجدْجِيذْ، حِيمَا نِيثْنِي أَذْ ڭّنْ أَكِيذكْ إِجّْ ن ڒْعَاهْذْ ؤُ شكْ أَذْ ثِيڒِيذْ ذ أَجدْجِيذْ خْ مَارَّا مِينْ إِمّژْرِي ڒعْمَارْ نّشْ.“ س ؤُيَا إِجَّا ذَاوُوذْ أَبْنِيرْ أَذْ يُويُورْ ذِي ڒهْنَا.   
\b  
\m  
\s1 أَبْنِيرْ إِتّْوَانغْ زِي يُو‘أَبْ  
\m
\v 22 ؤُشَا خْزَارْ، إِمْسخَّارنْ ن ذَاوُوذْ ذ يُووَابْعقْبنْ-د زڭْ إِجّْ ن ؤُسَافَارْ ن ؤُكشّضْ. نِيثْنِي إِوْينْ أَكِيذْسنْ إِشْثْ ن ثْكشَّاضْثْ ذ ثَامقّْرَانْثْ. أَبْنِيرْ ثُوغَا وَارْ إِدْجِي عَاذْ غَارْ ذَاوُوذْ ذِي حَابْرُونْ، مَاغَارْ \add ذَاوُوذْ\add* ثُوغَا إِجَّا إِ-ث أَذْ يُويُورْ ذِي ڒهْنَا.  
\v 23 \add ڒَْامِي\add* د-يِيوضْ يُووَابْ ذ مَارَّا ڒْعسْكَارْ نِّي غَارسْ، عَاوْذنْ إِ يُووَابْ، نَّانْ: ”أَبْنِيرْ، مِّيسْ ن نِيرْ، يُوسَا-د غَارْ ؤُجدْجِيذْ ؤُ نتَّا إِجَّا إِ-ث أَذْ يُويُورْ ؤُشَا \add خنِّي\add* يُويُورْ \add أَبْنِيرْ\add* ذِي ڒهْنَا.“  
\v 24 \add خنِّي\add* يُويُورْ يُووَابْ غَارْ ؤُجدْجِيذْ، إِنَّا أَسْ: ”مِينْ ثڭِّيذْ؟ أَقَا أَبْنِيرْ يُوسَا-د غَاركْ. مَايمِّي إِ ث ثسّكّذْ ؤُشَا \add خنِّي\add* يُويُورْ نتَّا أَمنِّي وَاهَا؟  
\v 25 شكْ ثسّْنذْ أَبْنِيرْ، مِّيسْ ن نِيرْ. نتَّا يُوسَا-د وَاهَا حِيمَا أَذْ شكْ إِشْمثْ ؤُ حِيمَا أَذْ إِسّنْ خْ وُوفُّوغْ نّشْ \add غَارْ ؤُمنْغِي\add* ؤُ خْ وعْقَابْ نّشْ ؤُ خْ مَارَّا مِينْ ثخْسذْ أَذْ ثڭّذْ.“  
\v 26 يُووَابْ إِفّغْ زِي غَارْ ذَاوُوذْ ؤُشَا إِسّكّْ إِرقَّاسنْ أَوَارْنِي إِ أَبْنِيرْ إِنِّي ث-إِ-د-يَارِّينْ أَذْ إِذْوڒْ زڭْ وَانُو ن سِيرَا. \add مَاشَا\add* ذَاوُوذْ وَارْ إِسِّينْ وَالُو خْ مَانْ أَيَا.  
\v 27 \add ؤُمِي\add* د-إِعْقبْ أَبْنِيرْ غَارْ حَابْرُونْ، إِنْذهْ إِ-ث يُووَابْ غَارْ ؤُغزْذِيسْ ذِي ڒْوسْطْ ن ثوَّارْثْ \add ن ثنْذِينْثْ\add* مَاحنْذْ أَذْ كِيذسْ إِسِّيوڒْ س ڒْهُوذْنثْ ؤُشَا \add خنِّي\add* إِجُّو ث ذِينْ ذڭْ ؤُعذِّيسْ، أَڒَامِي إِمُّوثْ، ذِي سِّيبّثْ \add ن وخْڒَافْ\add* ن إِذَامّنْ ن ؤُمَاسْ عَسَائِيلْ. \f ◼ \fr 3:‏27 \ft \+bd ’مَاحنْذْ أَكِيذسْ إِسِّيوڒْ‘\+bd* - إِخْسْ أَذْ يِينِي أَقَا يُو‘أَبْ إِڭَّا أَخْمِي إِخْسْ أَكِيذسْ إِسِّيوڒْ بْڒَا أَخوّجْ، مَاشَا س ثِيذتّْ نتَّا إِخْسْ أَذْ ث إِنغْ.\f*  \x ◘ \xo 3:‏27 \xt  2 صم. 2‏:‏23؛ 1 إِج. 2‏:‏5\x*  
\v 28 \add ؤُمِي\add* إِسْڒَا ذَاوُوذْ مَانَاونِّي أَوَارْنِي أَسْ، إِنَّا: ”نشّْ ذ ثْڭلْذِيثْ إِنُو ذ أَفُورِّي زَّاثْ إِ سِيذِي إِ ڒبْذَا خْ إِذَامّنْ ن أَبْنِيرْ، مِّيسْ ن نِيرْ.  
\v 29 أجّْ إِ-ثنْ أَذْ إِڒِينْ خْ ؤُزدْجِيفْ ن يُووَابْ ؤُ خْ مَارَّا ثَادَّارْثْ ن بَابَاسْ. أجّْ ثَادَّارْثْ ن يُووَابْ وَارْ ذ أَسْ إِنقّصْعمَّارْصْ شَا ن إِجّْ أَذْ ذَايسْ يِيڒِي ؤُسيّڒْ، نِيغْ ونِّي ذِي إِدْجَا ڒْبَارْصْ، نِيغْ ونِّي إِطّْفنْ ذڭْ ؤُمكُّوكْ ن ؤُخيَّاضْ، نِيغْ ونِّي إِوْضَانْ س سِّيفْ، نِيغْ ونِّي إِتّْخصَّانْ أَغْرُومْ!“   
\m
\v 30 يُووَابْ ذ ؤُمَاسْ أَبِيشَايْ نْغِينْ أَبْنِيرْ، مِينْزِي نتَّا ثُوغَا إِنْغَا ؤُمَاثْسنْ عَسَائِيلْ ذڭْ ؤُمنْغِي غَارْ جِيبْعُونْ.  
\v 31 \add مَاشَا\add* ذَاوُوذْ إِنَّا إِ يُووَابْ ؤُ إِ مَارَّا ڒْڭنْسْ نِّي ثُوغَا غَارسْ إِدْجَانْ: ”شَارّْڭمْ أَرُّوضْ نْومْ، يَارْضمْ أَرُّوضْ ن وشْضَانْ ؤُشَا \add ؤُيُورمْ\add* زَّاثْ إِ \add ڒْمحْمڒْ ن\add* أَبْنِيرْ \add أَمْ\add* ثشَّاثمْ أَڭجْذُورْ!“ أَجدْجِيذْ ذَاوُوذْ \add سِيمَانْثْ نّسْ\add* يُويُورْ غَارْ ضفَّارْ ن ڒْمحْمڒْ.  
\v 32 \add ڒَْامِي\add* نضْڒنْ أَبْنِيرْ ذِي حَابْرُونْ، إِسّْڭعّذْ ؤُجدْجِيذْ ثْمِيجَّا نّسْ، إِرُو غَارْ ونْضڒْ ن أَبْنِيرْ ؤُڒَا ذ ڒْڭنْسْ إِرُو مَارَّا.  
\v 33 أَجدْجِيذْ إِسّْڭعّذْ إِشْثْ ن ؤُشثْشِي ن إِمتَّانْ إِ أَبْنِيرْ، إِنَّا: ”مَا إِمُّوثْ أَبْنِيرْ أَمْ إِمُّوثْ إِجّْ ن ؤُبُوهَاڒِي؟  
\v 34 إِفَاسّنْ نّشْ ثُوغَا وَارْ شَارْفنْ ؤُ إِضَارنْ نّشْ ثُوغَا وَارْ قيّْذنْ س سّْنَاسڒْ ن نّْحَاسْ، مَاشَا شكْ ثوْضِيذْ أَمْ مَامّشْ إِوْضَا \add بْنَاذمْ\add* سَاذُو ؤُفُوسْ ن أَيْثْ ن ڒْمُوعْصِييّثْ.“ \add ڒخْذنِّي\add* يَارْنِي ڒْڭنْسْ مَارَّا عَاذْ ذڭْ إِمطَّاونْ.   
\m
\v 35 مَارَّا ڒْڭنْسْ يُوسَا-د غَارْ ذَاوُوذْ حِيمَا أَذْ خَاسْ زِييَّارنْ أَذْ إِشّْ أَغْرُومْ أَمْ ثُوغَا عَاذْ ذ أَزِيڒْ. \add مَاشَا\add* ذَاوُوذْ إِجِّيدْجْ، إِنَّا: ”أجّْ أَربِّي أَذْ أَيِي إِڭّْ ثَا ذ ثَا ؤُشَا أَذْ ذَايسْ يَارْنِي عَاذْ، مَاڒَا نشّْ شِّيغْ شَا ن وغْرُومْ نِيغْ شَا نّغْنِي قْبڒْ مَا أَذْ ثغْڒِي ثْفُوشْثْ!“  
\v 36 مَانْ أَيَا إِذْوڒْ إِتّْوَاسّنْ غَارْ مَارَّا ڒْڭنْسْ ؤُشَا ثُوغَا ذ مَانْ أَيَا ذ لمْلِيحْ ذِي ثِيطَّاوِينْ نْسنْ، أَمْ مَامّشْ ثُوغَا مَارَّا مِينْ إِڭَّا ؤُجدْجِيذْ ذ لمْلِيحْ ذِي ثِيطَّاوِينْ ن مَارَّا ڒْڭنْسْ.  
\v 37 مَارَّا ڒْڭنْسْ ذ مَارَّا إِسْرَائِيل سّْننْ ذڭْ وَاسّْ نِّي، أَقَا وَارْ د-يكِّي زڭْ ؤُجدْجِيذْ مَاحنْذْ أَذْ نْغنْ أَبْنِيرْ، مِّيسْ ن نِيرْ.  
\v 38 إِنَّا ؤُجدْجِيذْ إِ إِمْسخَّارنْ نّسْ: ”مَا وَارْ ثسِّينمْ كنِّيوْ، أَقَا أَسّْ-أَ إِوْضَا إِجّْ ن ڒْحَاكمْ، \add وَاهْ،\add* إِجّْ ن ورْيَازْ ذ أَمقّْرَانْ ذِي إِسْرَائِيل؟  
\v 39 أَسّْ-أَ ضعْفغْ، \add وَاخَّا\add* نشّْ تّْوَاذهْنغْ ذ أَجدْجِيذْ. إِرْيَازنْ-أَ، أَرَّاوْ ن صَارُويَا، قسْحنْ خَافِي. سِيذِي أَذْ إِخدْجصْ أَعفَّانْ ثُوعفّْنَا نّسْ نِّي إِڭَّا.“   
\b  
\b  
\m  
\c 4
\s1 أَنقِّي ن إِشْ-بُوشَاثْ  
\m
\v 1 \add ؤُمِي\add* إِسْڒَا مِّيسْ ن شَاوُولْ، أَقَا أَبْنِيرْ إِمُّوثْ ذِي حَابْرُونْ، ذوْڒنْ إِفَاسّنْ نّسْ ضعْفنْ ؤُ مَارَّا إِسْرَائِيل إِنّخْڒعْ.  
\v 2 مِّيسْ ن شَاوُولْ ثُوغَا غَارسْ ثْنَاينْ ن يرْيَازنْ \add جَارْ إِمْسخَّارنْ نّسْ\add*، إِنِّي \add إِدْجَانْ ذ\add* ڒْقبْطَانَاثْ ن بَانْذِييَّاثْ. إِجّنْ قَّارنْ أَسْ بَاعْنَا ؤُ ونّغْنِي رَاكَابْ، ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن رِيمُّونْ، أَبِي‘رُوثِي، زڭْ أَيْثْ ن بِينْيَامِينْ، مَاغَارْ ؤُڒَا ذ بِيعْرُوثْ إِتّْوَاحْسبْ-د غَارْ بِينْيَامِينْ. \x ◘ \xo 4:‏2 \xt ياش. 9‏:‏17، 18‏:‏25 \x*  
\v 3 إِبِيعْرُوثِييّنْ أَروْڒنْ غَارْ جَاتَّايِيمْ ؤُشَا قِّيمنْ زدّْغنْ ذِينِّي أَڒْ أَسّْ-أَ أَمْ إِبَارَّانِييّنْ.   
\b  
\m
\v 4 يُونَاثَانْ، مِّيسْ ن شَاوُولْ، ثُوغَا غَارسْ إِجّْ ن مِّيسْ نِّي ثُوغَا إِقَارّْمنْ زِي ثْنَاينْ ن إِضَارنْ. نتَّا ثُوغَا غَارسْ خمْسَا ن إِسڭّْوُوسَا ؤُمِي د-يُوسَا ڒخْبَارْ خْ شَاوُولْ ذ يُونَاثَانْ زِي يَازْرَاعِيلْ. ثنِّي ث إِسّيْمنْ ثُوغَا ثطّفْ إِ-ث ؤُشَا ثَارْوڒْ. أَقَا ذڭْ ؤُقدْجقْ ن ثَاروْڒَا، إِمْسَارْ، نتَّا إِوْضَا، إِذْوڒْ إِقَارّمْ. قَّارنْ أَسْ مَافِيبُوشَاثْ. \x ◘ \xo 4:‏4 \xt 2 صم. 9‏:‏3‏-‏13\x*   
\b  
\m
\v 5 رَاكَابْ ذ بَاعْنَا، إِحنْجِيرنْ ن رِيمُّونْ، أَبِيعْرُوثِي، طّْفنْ أَبْرِيذْ ؤُشَا ؤُسِينْ-د ذِي طّْحَا ن ؤُزِيڒْ غَارْ ثَادَّارْثْ ن إِشْ-بُوشَاثْ. نتَّا ثُوغَا إِزّڒْ ذِي قَامَا ذِي ثْمذِّيثْ. \f ◼ \fr 4:‏5 \ft \+bd ’أَبِيرُوثِي‘\+bd* - إِجّْ ن ورْيَازْ زِي ثنْذِينْثْ ن بِيرُوثْ ذِي ثمُّورْثْ ن أَيْثْ ن بِينْيَامِينْ.\f*  
\v 6 خْزَارْ، نِيثْنِي ؤُذْفنْ غَارْ ذَاخڒْ ذِي ثَادَّارْثْ أَخْمِي ثُوغَا نْوَانْ أَذْ كْسِينْ إِرْذنْ، ؤُشَا سّْنُوقّْبنْ ث ذڭْ ؤُعذِّيسْ. رَاكَابْ ذ ؤُمَاسْ بَاعْنَا خْثُوتّْڒنْ.  
\v 7 نِيثْنِي ؤُذْفنْ غَارْ ثَادَّارْثْ ؤُمِي ث ثُوغَا إِزّڒْ ذِي قَامَا نّسْ ذڭْ وخَّامْ ن يِيضصْ نّسْ، ؤُشَا سّْنُوقْبنْ ث، نْغِينْ ث ؤُشَا قسّنْ أَسْ أَزدْجِيفْ. \add خنِّي\add* كْسِينْ أَزدْجِيفْ نّسْ \add أَكِيذْسنْ\add* ؤُشَا ؤُيُورنْ دْجِيڒثْ ثْمُونْ، كِّينْ أَبْرِيذْ ن ڒوْضَا.  
\v 8 نِيثْنِي إِوْينْ أَزدْجِيفْ ن إِشْ-بُوشَاثْ غَارْ ذَاوُوذْ غَارْ حَابْرُونْ، نَّانْ إِ ؤُجدْجِيذْ: ”خْزَارْ، أَزدْجِيفْ ن إِشْ-بُوشَاثْ، مِّيسْ ن شَاوُولْ، ڒعْذُو نّشْ، ونِّي ثُوغَا يَارزُّونْ بُوحْبڒْ نّشْ. أَقَا أَسّْ-أَ سِيذِي إِخْڒفْ إِ سِيذِي إِنُو أَجدْجِيذْ زِي شَاوُولْ ذ زَّارِيعثْ نّسْ.“ \f ◼ \fr 4:‏8 \ft \+bd ’بُوحْبڒْ نّكْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ثُوذَارْثْ نّكْ‘.\f*  
\v 9 \add مَاشَا\add* ذَاوُوذْ يَارَّا-د خْ رَاكَابْ ذ ؤُمَاسْ بَاعْنَا، إِحنْجِيرنْ ن رِيمُّونْ، أَبِيعْرُوثِي، إِنَّا أَسنْ: ”\add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي، ونِّي إِفكّنْ ڒعْمَارْ إِنُو زِي مَارَّا ڒحْصَارثْ!  
\v 10 أَقَا ونِّي ذ أَيِي د-يِيوْينْ ڒخْبَارْ ؤُشَا إِنَّا: ’خْژَارْ، شَاوُولْ إِمُّوثْ!‘، ثُوغَا إِتّْغِيڒْ أَسْ ذِي ثِيطَّاوِينْ نّسْ أَقَا نتَّا أَمْ يِيجّنْ إِ د-يِيوْينْ ڒخْبَارْ أَصبْحَانْ، \add مَاشَا\add* نشّْ طّْفغْ ث ؤُشَا نْغِيغْ ث ذِي صِيقْلَاغْ، وَاخَّا نتَّا \add ثُوغَا إِرَاجَا\add* أَذْ أَسْ وْشغْ ڒْمُونثْ إِ ڒخْبَارْ أَصبْحَانْ. \x ◘ \xo 4:‏10 \xt 2 صم. 1‏:‏15\x*  
\v 11 مشْحَاڒْ عَاذْ \add ڒخُّو\add* إِرْيَازنْ إِعفَّاننْ إِنِّي إِنْغِينْ إِجّْ ن ورْيَازْ ذ أَمْسڭّذْ ذِي ثَادَّارْثْ نّسْ خْ قَامَا نّسْ! خنِّي ڒخُّو، مَا نشّْ وَارْ خدْجْفغْ خنِّي زَّايْومْ إِذَامّنْ نّسْ ؤُ أَذْ كنِّيوْ مْحِيغْ زِي ثمُّورْثْ؟“  
\v 12 \add خنِّي\add* يُومُورْ ذَاوُوذْ إِمْسخَّارنْ \add نّسْ\add* ؤُ نِيثْنِي نْغِينْ ثنْ. قسّنْ أَسنْ إِفَاسّنْ ذ إِضَارنْ ؤُشَا ؤُيْڒنْ ثنْ غَارْ ؤُيڒْمَامْ ن حَابْرُونْ. أَزدْجِيفْ ن إِشْ-بُوشَاثْ، \add مَاشَا\add* كْسِينْ ث نِيثْنِي، نضْڒنْ ث ذڭْ ونْضڒْ ن أَبْنِيرْ ذِي حَابْرُونْ. \x ◘ \xo 4:‏12 \xt 2 صم. 3‏:‏32\x*   
\b  
\b  
\m  
\c 5
\s1 ذَاوُوذْ إِتّْوَاذْهنْ أَمْ ؤُجدْجِيذْ ذِي هِيبْرُونْ  
\m
\v 1 مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل ؤُسِينْثْ-إِ-د غَارْ ذَاوُوذْ غَارْ حَابْرُونْ، سِّيوْڒنْثْ، نَّانْثْ: ”خْزَارْ، نشِّينْ ذ إِغُوسَّانْ ذ ويْسُومْ نّشْ. \x ◘ \xo 5:‏1 \xt [1 إِم. 11‏:‏1‏-‏9؛ 14‏:‏1‏-‏17]\x*  
\v 2 إِضنَّاضْ ؤُڒَا ذ فَارِيضنَّاضْ ؤُمِي ثُوغَا شَاوُولْ ذ أَجدْجِيذْ خَانغْ، ثُوغَا ذ شكْ إِ د-إِسُّوفّْغنْ إِسْرَائِيل \add غَارْ ؤُمنْغِي\add* ؤُ ثجِّيذْ إِ-ث-إِ-د أَذْ إِذْوڒْ. عَاوذْ إِنَّا أَشْ سِيذِي: ’شكْ أَذْ ثَاروْسذْ ڒْڭنْسْ إِنُو إِسْرَائِيل ؤُ شكْ أَذْ ثِيڒِيذْ ذ ڒْحَاكمْ خْ إِسْرَائِيل.‘ “ \x ◘ \xo 5:‏2 \xt 2 صم. 7‏:‏7؛ إِزهد. 78‏:‏71\x*  
\v 3 \add خنِّي\add* ؤُسِينْ-د مَارَّا إِمْغَارنْ ن إِسْرَائِيل غَارْ ؤُجدْجِيذْ ذِي حَابْرُونْ ؤُ أَجدْجِيذْ ذَاوُوذْ إِڭَّا إِجّْ ن ڒْعَاهْذْ أَكِيذْسنْ ذِي حَابْرُونْ زَّاثْ إِ وُوذمْ ن سِيذِي. نِيثْنِي ذهْننْ ذَاوُوذْ ذ أَجدْجِيذْ خْ إِسْرَائِيل.   
\m
\v 4 ثُوغَا غَارْ ذَاوُوذْ ثْڒَاثِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ نتَّا ذ أَجدْجِيذْ. نتَّا إِحْكمْ أَربْعِينْ ن إِسڭّْوُوسَا.  
\v 5 ذِي حَابْرُونْ إِحْكمْ خْ يَاهُوذَا سبْعَا ن إِسڭّْوُوسَا ذ ستَّا ن إِيُورنْ ؤُ ذِي ؤُرْشَالِيمْ إِحْكمْ ثْڒَاثَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا خْ مَارَّا إِسْرَائِيل ذ يَاهُوذَا. \x ◘ \xo 5:‏5 \xt 2 صم. 2‏:‏11؛ 1 إِج. 2‏:‏11؛ 1 إِم. 3‏:‏4\x*   
\b  
\m  
\s1 أَطّفُو ن ؤُرْشَالِيمْ  
\m
\v 6 أَجدْجِيذْ إِفّغْ أَكْ-ذ يرْيَازنْ نّسْ غَارْ ؤُرْشَالِيمْ، \add حِيمَا أَذْ إِمّْنغْ\add* أَكْ-ذ أَيْثْ ن إِيابُوسِييّنْ، إِمزْذَاغْ ن ثمُّورْثْ. سِّيوْڒنْ أَكْ-ذ ذَاوُوذْ، نَّانْ: ”شكْ وَارْ ثتِّيذْفذْ شَا ذَا، مَاغَارْ إِذَارْغَاڒنْ ذ إِقِيضَارنْ أَذْ شكْ حْصَارنْ، أَذْ إِنِينْ: ’ذَاوُوذْ وَارْ ذَا إِتِّيذفْ شَا.‘ “  
\v 7 ذَاوُوذْ إِحوّسْ لْبُورْجْ ن صِيهْيُونْ، ذ ونِّي ذ ثَانْذِينْثْ ن ذَاوُوذْ.  
\v 8 ذڭْ وَاسّْ نِّي إِنَّا ذَاوُوذْ: ”كُورْ إِجّْ إِ غَا إِوْثنْ إِجّْ ن ؤُيابُوسِي، أجّْ-إِ-ث أَذْ ث إِمّنْضَارْ ذڭْ وَامَانْ \add إِسِّيزّْڒنْ أَطَّاسْ\add*. إِقِيذَارنْ ذ إِذَارْغَاڒنْ إِشَارّهْ إِ-ثنْ ڒعْمَارْ ن ذَاوُوذْ.“ خْ ؤُيَا قَّارنْ: ”إِجّْ ن ؤُذَارْغَاڒْ ذ إِجّْ ن ؤُقِيذَارْ وَارْ د-تِّيذْفنْ غَارْ ثَادَّارْثْ.“ \x ◘ \xo 5:‏8 \xt 1 إِم. 11‏:‏6 \x*   
\m
\v 9 ذَاوُوذْ إِقِّيمْ إِزْذغْ ذِي لْقلْعَا ؤُشَا إِڭَّا أَسْ: ’ثَانْذِينْثْ ن ذَاوُوذْ‘. إِبْنَا ذَاوُوذْ ذڭْ ونّضْ ن لْبُورْجْ ؤُڒَا غَارْ ذَاخڒْ نّسْ.  
\v 10 ذَاوُوذْ إِذْوڒْ يَارنِّي ذِي ڒمْغَارثْ، مَاغَارْ سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ، \add ثُوغَا-ث\add* أَكِيذسْ.   
\m
\v 11 حِيرَامْ، أَجدْجِيذْ ن صُورْ، إِسّكّْ إِرقَّاسنْ غَارْ ذَاوُوذْ أَكْ-ذ أَكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ ذ إِنقَّاشنْ ن ؤُكشُّوضْ ذ إِنقَّاشنْ ن وژْرُو ن ڒْحِيضْ. نِيثْنِي سّْبدّنْ إِشْثْ ن ثَادَّارْثْ إِ ذَاوُوذْ. \f ◼ \fr 5:‏11 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  
\v 12 ذَاوُوذْ إِسّنْ، أَقَا سِيذِي ثُوغَا إِڭَّا إِ-ث ذ أَجدْجِيذْ خْ إِسْرَائِيل ؤُ ثُوغَا إِسّْڭعّذْ ثَاڭلْذِيثْ نّسْ ذِي طّْوعْ ن ڒْڭنْسْ نّسْ إِسْرَائِيل.   
\b  
\m
\v 13 أَوَارْنِي ثْوَاسِيثْ نّسْ زِي حَابْرُونْ ثُوغَا ذَاوُوذْ يَارنِّي ثِييَّا ذ ثمْغَارِينْ إِ يِيخفْ نّسْ زِي ؤُرْشَالِيمْ ؤُ \bd تّْوَارْونْ أَسْ-د إِ ذَاوُوذْ \+bdit عَاذْ\+bdit* إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.\bd* \x ◘ \xo 5:‏13 \xt 1 إِم. 3‏:‏9؛ 14‏:‏3‏-‏7\x*  
\v 14 إِنَا ذ إِسْمَاونْ ن إِحنْجِيرنْ إِ ذ أَسْ د-إِتّْوَارْونْ ذِي ؤُرْشَالِيمْ: شَامُّوعْ، شُوبَابْ، نَاثَانْ، سُولِيمَانْ،  
\v 15 يِيبْحَارْ، إِلِيشُوعْ، نَافَاجْ، يَافِيعْ،  
\v 16 أَلِيشَامَاعْ، أَلْيَاذَاعْ ذ إِلِيفَالَاطْ.   
\b  
\m  
\s1 أَغلّبْ خْ إِفِيلِيسْطِينِييّنْ  
\m
\v 17 \add ؤُمِي\add* سْڒِينْ إِفِيلِيسْطِينِييّنْ، أَقَا ذهْننْ ذَاوُوذْ ذ أَجدْجِيذْ خْ إِسْرَائِيل، ڭعّْذنْ مَارَّا إِفِيلِيسْطِينِييّنْ حِيمَا أَذْ أَرْزُونْ خْ ذَاوُوذْ. ذَاوُوذْ إِسْڒَا \add خْ مَانْ أَيَا\add* ؤُ نتَّا إِهْوَا غَارْ لْقلْعَا.  
\v 18 إِفِيلِيسْطِينِييّنْ ؤُسِينْ-د ؤُشَا بزّْعنْ إِخفْ نْسنْ ذِي ثغْزُورْثْ ن إِرَافَاوِييّنْ.  
\v 19 \add خنِّي\add* إِسّقْسَا ذَاوُوذْ سِيذِي، إِنَّا: ”مَا أَذْ ڭعّْذغْ ضِيدّْ إِ إِفِيلِيسْطِينِييّنْ؟ مَا أَذْ ثنْ ثڭّذْ ذڭْ ؤُفُوسْ إِنُو؟“ سِيذِي إِنَّا إِ ذَاوُوذْ: ”ڭعّذْ، مَاغَارْ نشّْ نِيشَانْ أَذْ ڭّغْ إِفِيلِيسْطِينِييّنْ ذڭْ ؤُفُوسْ نّشْ!“  
\v 20 ؤُ يِيوضْ ذَاوُوذْ غَارْ بَاعْلْ-فَارَاصِيمْ. ذِينِّي إِوْثَا ذَاوُوذْ إِفِيلِيسْطِينِييّنْ، إِنَّا: ”سِيذِي إِشُوقْ زَّاثْ إِ وُوذمْ إِنُو ذِي ڒْعذْيَانْ إِنُو أَمْ يِيشْثْ ن ثَارژِّيثْ ن وَامَانْ.“ خْ ؤُيَا إِڭَّا أَسْ إِ ومْشَانْ نِّي بَاعْلْ-فَارَاصِيمْ. \x ◘ \xo 5:‏20 \xt إِشا. 28‏:‏21\x*  
\v 21 إِفِيلِيسْطِينِييّنْ جِّينْ ذِينِّي ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ نْسنْ ؤُ ذَاوُوذْ ذ يرْيَازنْ نّسْ كْسِينْ ثنْ أَكِيذْسنْ.   
\m
\v 22 ڭعّْذنْ إِفِيلِيسْطِينِييّنْ إِشْثْ ن ثْوَاڒَا نّغْنِيثْ ؤُ بزّْعنْ إِخفْ نْسنْ ذِي ثغْزُورْثْ ن إِرَافَاوِييّنْ.  
\v 23 ذَاوُوذْ إِسّقْسَا سِيذِي ؤُ نتَّا إِنَّا: ”وَارْ تّْڭعِّيذْ شَا ضِيدّْ نْسنْ، مَاشَا أكّْ أَسنْ-د غَارْ ضفَّارْ، أَذْ غَارْسنْ د-ثَاسذْ زِي جِّيهثْ ن ثْشجُّورَا ن ؤُمتِّي.  
\v 24 خْمِي غَا ثسْڒذْ إِ ثشْڒِي ن إِصُورَافْ ذِي ثْقِيشَّاثْ ن ثْشجُّورَا ن ؤُمتِّي، \add خنِّي\add* فّغْ، ثْهجْمذْ، مَاغَارْ سِيذِي أَذْ أَشْ إِزْوَارْ زَّاثْ إِ وُوذمْ نّشْ، حِيمَا أَذْ إِوّثْ ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ.“  
\v 25 ذَاوُوذْ إِڭَّا أَمْ مَامّشْ ذ أَسْ يُومُورْ سِيذِي ؤُ نتَّا إِوْثَا إِفِيلِيسْطِينِييّنْ زِي جِيبْعَا أَڒْ مَانِي غَا ثَاوْضذْ غَارْ جَازَارْ.   
\b  
\b  
\m  
\c 6
\s1 أَسْمُوطِّي ن تَّاپُوثْ غَارْ ثنْذِينْثْ ن ذَاوُوذْ  
\m
\v 1 ذَاوُوذْ إِسّْمُونْ ثْوَاڒَا نّغْنِيثْ مَارَّا \add إِعسْكَارِييّنْ\add* إِتّْوَافَارْزنْ ذِي إِسْرَائِيل، ثْڒَاثِينْ-أَڒفْ \add ن يرْيَازنْ\add*. \x ◘ \xo 6:‏1 \xt [1 إِم. 13‏:‏1‏-‏14؛ 15‏:‏25‏-‏29؛16‏:‏1‏-‏3]\x*  
\v 2 ؤُشَا إِكَّارْ ذَاوُوذْ، إِفّغْ أَكْ-ذ مَارَّا ڒْڭنْسْ إِ غَارسْ \add إِدْجَانْ\add* زِي بَاعْلِي-يَاهُوذَا حِيمَا أَذْ سّنِّي إِسّْڭعّذْ تَّابُوثْ ن سِيذِي، \add تَّابُوثْ\add* إِ خْ إِتّْوَابَارّحْ س يِيسمْ، س إِسمْ ن سِيذِي ن ڒْعسْكَارَاثْ، ونِّي إِتّْغِيمَانْ \add خْ\add* إِكِيرُوبنْ. \f ◼ \fr 6:‏2 \ft \+bd ’إِكِيرُوبنْ‘\+bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*  
\v 3 نِيثْنِي نذْهنْ تَّابُوثْ ن سِيذِي خْ إِجّْ ن ؤُكَارُّو ن جْذِيذْ. نِيثْنِي إِوْينْ ت-إِ-د زِي ثَادَّارْثْ ن أَبِينَاذَابْ ثنِّي إِبدّنْ خْ إِشْثْ ن ثعْرُورْثْ. عُوزَّا ذ أَخِييُو، إِحنْجِيرنْ ن أَبِينَاذَابْ، نذْهنْ أَكَارُّو ن جْذِيذْ. \x ◘ \xo 6:‏3 \xt 1 صم. 6‏:‏7، 8؛ 7‏:‏1\x*  
\v 4 نِيثْنِي إِوْينْ ث-إِ-د زِي ثَادَّارْثْ ن أَبِينَاذَابْ إِ ثُوغَا إِبدّنْ خْ إِشْثْ ن ثعْرُورْثْ، ؤُشَا \add ؤُيُورنْ\add* أَكْ-ذ تَّابُوثْ ن سِيذِي. أَخِييُو يُويُورْ غَارْ زَّاثْ إِ تَّابُوثْ.  
\v 5 ذَاوُوذْ ذ مَارَّا ثَادَّارْثْ ن إِسْرَائِيل ؤُرَارنْ زَّاثْ إِ وُوذمْ ن سِيذِي س عْڒَامْ كُوڒْ دُّوزَانْ ن دْجْغَا زڭْ ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ؤُمرْزِي، س ڒْڭَامْبْرِييَاثْ ذ لهَارْپَاثْ ذ إِبنْذِيرنْ ذ نَّاقُوسَاثْ ذ ثدْجُونِينْ ن وُوزَّاڒْ. \f ◼ \fr 6:‏5 \ft \+bd ’أَمرْزِي‘\+bd* - نِيغْ ’أَمضْزِي‘. \+bd ’ثَادْجُونِينْ ن وُوزَّاڒْ‘\+bd* - نِيغْ ’أَسِيمْبَالْ‘ ذ ’إِسِيمْبَالنْ‘.\f*   
\m
\v 6 \add ؤُمِي\add* إِوْضنْ غَارْ ؤُنذْرَارْ ن نَاخُونْ، إِسّْوِيژّضْ عُوزَّا \add أَفُوسْ نّسْ\add* غَارْ تَّابُوثْ ن أَربِّي ؤُشَا إِطّفْ إِ-ت، مِينْزِي نْذرْفنْ إِفُونَاسنْ.  
\v 7 \add خنِّي\add* يَارْغَا وغْضَابْ ن سِيذِي خْ عُوزَّا ؤُشَا إِوْثَا إِ-ث أَربِّي ذِينْ خْ ؤُخطُّو-يَا. نتَّا إِمُّوثْ ذِينْ غَارْ تَّابُوثْ ن سِيذِي.  
\v 8 يِيوضْ سّمْ غَارْ وُوڒْ ن ذَاوُوذْ، أَقَا سِيذِي ثُوغَا إِسْعَارْ أَمُّو خْ عُوزَّا، ؤُشَا إِڒَاغَا أَسْ إِ ومْشَانْ نِّي فَارِيصْ-عُوزَّا أَڒْ أَسّْ-أَ.  
\v 9 ذڭْ وَاسّْ نِّي ثڒْقفْ ذَاوُوذْ ثِيڭّْوُوذِي زِي سِيذِي، إِنَّا: ”مَامّشْ إِ غَا يڭّْ أَذْ غَارِي د-ثَاسْ تَّابُوثْ ن سِيذِي؟“  
\v 10 \add س ؤُينِّي\add* ذَاوُوذْ وَارْ إِخْسْ أَذْ يجّْ أَذْ غَارسْ د-أَوْينْ تَّابُوثْ ن سِيذِي ذِي ثنْذِينْثْ ن ذَاوُوذْ. ذَاوُوذْ إِجَّا إِ-ت أَذْ ثَاڭّْوجْ غَارْ ثَادَّارْثْ ن عُوبِيذْ-إِذُومْ، أَجِيتِّي. \f ◼ \fr 6:‏10 \ft \+bd ’أَجَاثِي‘\+bd* - إِجّْ ن ورْيَازْ زِي ثنْذِينْثْ ن جَاثْ.\f*   
\m
\v 11 ثكَّا تَّابُوثْ ن سِيذِي ثْڒَاثَا ن إِيُورنْ ذِي ثَادَّارْثْ ن عُوبِيذْ-إِذُومْ، أَجِيتِّي، ؤُشَا سِيذِي إِبَاركْ عُوبِيذْ-إِذُومْ ذ مَارَّا ثَادَّارْثْ نّسْ.  
\v 12 \add خنِّي\add* خبَّارنْ إِ ؤُجدْجِيذْ ذَاوُوذْ، نَّانْ: ”سِيذِي أَقَا إِبَاركْ ثَادَّارْثْ ن عُوبِيذْ-إِذُومْ ذ مَارَّا مِينْ إِدْجَانْ نّسْ، ذِي طّْوعْ ن تَّابُوثْ ن أَربِّي.“ \add خنِّي\add* يُويُورْ ذَاوُوذْ \add ذِينْ\add*، إِسّْڭعّذْ تَّابُوثْ ن أَربِّي س ڒفْرَاحثْ زِي ثَادَّارْثْ ن عُوبِيذْ-إِذُومْ غَارْ ثنْذِينْثْ ن ذَاوُوذْ.  
\v 13 ڒَامِي ؤُيُورنْ إِنِّي يَاربُّونْ تَّابُوثْ ن سِيذِي ستَّا ن إِصُورَافْ، إِمْسَارْ، أَقَا إِقدّمْ \add ذَاوُوذْ\add* إِجّْ ن ؤُفُونَاسْ ذ \add إِجّْ ن ؤُعجْمِي إِمسْڒنْ\add* \add ذ ثْغَارْصْثْ\add*.  
\v 14 ذَاوُوذْ إِشْضحْ س مَارَّا ثِيزمَّارْ \add نّسْ\add* زَّاثْ إِ وُوذمْ ن سِيذِي. ثُوغَا ذَاوُوذْ يَارْضْ إِجّْ ن ؤُپَالْطُو \add ن ؤُكهَّانْ\add* ن ڒقْطنْ.   
\m
\v 15 ذَاوُوذْ ذ مَارَّا ثَادَّارْثْ ن إِسْرَائِيل إِوْينْ تَّابُوثْ ن سِيذِي س ؤُسْڒِيوْڒوْ ؤُ س ڒْحسّْ ن ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي غَارْ سنّجْ.  
\v 16 ڒَامِي د-ثِيوضْ تَّابُوثْ ن سِيذِي غَارْ ثنْذِينْثْ ن ذَاوُوذْ، إِمْسَارْ، أَقَا مِيخَالْ، يدْجِيسْ ن شَاوُولْ، ثخْزَارْ-د زِي ڒْكَازِي. \add ؤُمِي\add* ثژْرَا نتَّاثْ مَامّشْ إِنڭّزْ ذ إِشطّحْ ؤُجدْجِيذْ ذَاوُوذْ زَّاثْ إِ وُوذمْ ن سِيذِي، ثسّحْقَارْ إِ-ث ذڭْ وُوڒْ نّسْ.   
\m
\v 17 أَرْبُونْ تَّابُوثْ ن سِيذِي غَارْ ذَاخڒْ ؤُشَا سَّارْسنْ ت ذڭْ ومْشَانْ نّسْ ذِي ڒْوسْطْ ن ؤُقِيضُونْ نِّي ثُوغَا إِ ذ أَسْ إِشدّْ ذَاوُوذْ ؤُشَا ذَاوُوذْ إِسّْڭعّذْ ثِيغَارْصَا ن وشْمَاضْ زَّاثْ إِ وُوذمْ ن سِيذِي، ؤُڒَا ذ ثِيغَارْصَا ن ڒهْنَا.  
\v 18 \add ؤُمِي\add* إِكمّڒْ ذَاوُوذْ زڭْ ؤُسْڭعّذْ ن ثْغَارْصَا ن وشْمَاضْ ذ ثْغَارْصَا ن ڒهْنَا، إِبَاركْ ڒْڭنْسْ ذڭْ يِيسمْ ن سِيذِي ن ڒْعسْكَارَاثْ.  
\v 19 نتَّا إِبْضَا خْ مَارَّا ڒْڭنْسْ، خْ مَارَّا ڒْغَاشِي ن إِسْرَائِيل، خْ يرْيَازنْ ذ ثمْغَارِينْ، إِ كُوڒْ  إِجّْ إِوْشَا أَسْ إِشْثْ ن ثْخبَّازْثْ ن وغْرُومْ، إِجّْ ن ؤُڒقُّوزْ \add ن ويْسُومْ\add* ن ؤُفُونَاسْ ذ إِجّْ ن وغْرُومْ ن زّْبِيبْ. \add خنِّي\add* يُويُورْ ڒْڭنْسْ مَارَّا، \add كُوڒْ\add* أَرْيَازْ غَارْ ثَادَّارْثْ نّسْ.   
\m
\v 20 يَارڭّْوحْ ذَاوُوذْ، حِيمَا أَذْ إِبَاركْ ثَادَّارْثْ نّسْ. ثفّغْ-د غَارسْ مِيخَالْ، يدْجِيسْ ن شَاوُولْ، ثنَّا أَسْ: ”مَامّشْ إِڭَّا ؤُجدْجِيذْ ن إِسْرَائِيل أَسّْ-أَ شَّانْ ذ أَمقّْرَانْ إِ إِخفْ نّسْ، ؤُمِي إِعَارَّا نتَّا إِخفْ نّسْ زَّاثْ إِ ثِيطَّاوِينْ ن ثِييَّا ن إِمْسخَّارنْ نّسْ أَمْ مَامّشْ إِعَارَّا شَا ن يِيجّنْ زڭْ إِنِّي وَارْ إِسكّْوِينْ؟“  
\v 21 ذَاوُوذْ يَارَّا-د خْ مِيخَالْ: ”\add نشّْ ڭِّيغْ ث\add* زَّاثْ إِ وُوذمْ ن سِيذِي ونِّي ذ أَيِي إِفَارْزنْ خْ بَابَامْ ذ مَارَّا ثَادَّارْثْ نّسْ، حِيمَا أَذْ أَيِي إِڭّْ ذ ڒْحَاكمْ خْ ڒْڭنْسْ ن سِيذِي، خْ إِسْرَائِيل، أَقَا زَّاثْ إِ وُوذمْ ن سِيذِي إِ شطّْحغْ س ڒفْرَاحثْ.  
\v 22 ذ أَمژْيَانْ عَاذْ إِ غَا ذوْڒغْ. نشّْ أَذْ إِڒِيغْ ذ أَمُوقْڒِيڒْ ذِي ثِيطَّاوِينْ إِنُو. غَارْ ثِييَّا إِ خْ ثسِّيوْڒذْ شمْ، غَارْسنْثْ إِ غَا طّْفغْ شَّانْ.“  
\v 23 مِيخَالْ، يدْجِيسْ ن شَاوُولْ، ثقِّيمْ بْڒَا أَحنْجِيرْ أَڒْ أَسّْ ن ڒْموْثْ نّسْ.   
\b  
\b  
\m  
\c 7
\s1 ڒْوَاعْذْ زِي جِّيهثْ ن زَّاوشْثْ ثَامقّْرَانْثْ إِ غَا ثتّْوَابْنَا زِي سُولِيمَانْ  
\m
\v 1 ؤُمِي إِقِّيمْ ؤُجدْجِيذْ ذِي ثَادَّارْثْ نّسْ ؤُ سِيذِي ثُوغَا إِڭَّا أَسْ ڒهْنَا زِي مَارَّا ڒْعذْيَانْ نّسْ إِ ذ أَسْ د-إِنّْضنْ، إِمْسَارْ، \x ◘ \xo 7:‏1 \xt [1 إِم. 17‏:‏1‏-‏6]\x*  
\v 2 أَقَا إِنَّا ؤُجدْجِيذْ إِ ؤُنَابِي نَاثَانْ: ”خْزَارْ، نشّْ زدّْغغْ ذڭْ إِشْثْ ن ثَادَّارْثْ ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ، \add مَاشَا\add* تَّابُوثْ ن أَربِّي ثْڒحّفْ سَاذُو ثَاجَارْثِيڒْثْ \add ن ؤُقِيضُونْ\add*.“  
\v 3 نَاثَانْ إِنَّا إِ ؤُجدْجِيذْ: ”ؤُيُورْ وَاهَا، أڭّْ مَارَّا مِينْ غَاركْ ذڭْ وُوڒْ نّشْ، مَاغَارْ سِيذِي أَكِيذكْ.“   
\m
\v 4 ذِي دْجِيڒثْ نِّي إِمْسَارْ أَقَا إِفّغْ وَاوَاڒْ ن سِيذِي غَارْ نَاثَانْ، إِنَّا:  
\v 5 ”ؤُيُورْ، إِنِي إِ ؤُمْسخَّارْ إِنُو، إِ ذَاوُوذْ: ’أَمُّو إِ إِقَّارْ سِيذِي: مَا ثخْسذْ أَذْ أَيِي ثبْنِيذْ إِشْثْ ن ثَادَّارْثْ، مَاحنْذْ أَذْ ذَايسْ زذْغغْ؟  
\v 6 عمَّارْصْ وَارْ زْذِيغغْ ذڭْ إِشْثْ ن ثَادَّارْثْ زڭْ وَاسّْ ؤُمِي د-سّْڭعّْذغْ أَيْثْ ن إِسْرَائِيل زِي مِيصْرَا أَڒْ أَسّْ-أَ، \add مَاشَا\add* ذُورّْيغْ ذڭْ إِجّْ ن ؤُقِيضُونْ، ذڭْ إِشْثْ ن ثْزذِّيغْثْ.  
\v 7 مَانِي مَا ؤُيُورغْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل، مَا نشّْ سِّيوْڒغْعمَّارْصْ ؤُڒَا س يِيجّْ ن وَاوَاڒْ إِ يِيشْثْ زِي ثْقبَّاڒْ ن إِسْرَائِيل ثِينِّي إِ ؤُمُورغْ أَذْ أَرْوسنْ ڒْڭنْسْ إِنُو إِسْرَائِيل، ؤُ نِّيغْ: مَايمِّي وَارْ ذ أَيِي ثبْنِيمْ إِشْثْ ن ثَادَّارْثْ ن ؤُكشُّوضْ ن \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ؟  
\v 8 خنِّي ڒخُّو، أَمُّو إِ إِتّْخصَّا أَذْ ثِينِيذْ إِ ؤُمْسخَّارْ إِنُو، إِ ذَاوُوذْ: أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: نشّْ إِوْيغْ-د شكْ زِي ڒْكُورِي، زِي ضفَّارْ ن وُودْجِي، مَاحنْذْ أَذْ ثِيڒِيذْ ذ ڒْحَاكمْ خْ ڒْڭنْسْ إِنُو، خْ إِسْرَائِيل. \x ◘ \xo 7:‏8 \xt 1 إِج. 8‏:‏16؛ 2 إِم. 6‏:‏5\x*  
\v 9 مَانِي مَا ثُويُورذْ، دْجِيغْ نشّْ أَكِيذكْ ؤُ قْضِيغْ خْ مَارَّا ڒْعذْيَانْ نّشْ زَّاثْ إِ وُوذمْ نّشْ. نشّْ ڭِّيغْ أَشْ إِجّْ ن إِسمْ ذ أَمقّْرَانْ أَمْ يِيسْمَاونْ ن إِمقّْرَاننْ نِّي \add إِدْجَانْ\add* خْ ثمُّورْثْ. \x ◘ \xo 7:‏9 \xt 2 صم. 8‏:‏6، 14\x*  
\v 10 نشّْ نيّْشغْ إِجّْ ن ومْشَانْ إِ ڒْڭنْسْ إِنُو، إِ إِسْرَائِيل، ؤُشَا ژُّوغْ ث \add ذِينْ\add*، مَاحنْذْ أَذْ إِزْذغْ ذڭْ ومْشَانْ \add نّسْ\add*، وَارْ إِتّْوَانْهزِّي عَاذْ ؤُ وَارْ ث حصَّارنْ عَاذْ أَيْثْ ن ڒْمُوعْصِييّثْ أَمْ ذڭْ ؤُمزْوَارُو،  
\v 11 زڭْ وَاسّْ نِّي ڭِّيغْ نشّْ ڒْقُوضَاثْ خْ ڒْڭنْسْ إِنُو إِسْرَائِيل. نشّْ وْشِيغْ أَشْ ڒهْنَا زِي مَارَّا ڒْعذْيَانْ نّشْ ؤُشَا \add ڒخُّو\add* أَذْ أَشْ إِسّْشنْ سِيذِي، أَقَا سِيذِي أَذْ أَشْ إِڭّْ إِشْثْ ن ثَادَّارْثْ.  
\v 12 ڒَامِي تّْوَاكمّْڒنْ وُوسَّانْ نّشْ ؤُشَا أَذْ ثڭّذْ أَذْ ثَاريّْحذْ جَارْ ڒجْذُوذْ نّشْ، أَذْ د-سّكَّارغْ زَّارِيعثْ نّشْ إِ د-إِتّفّْغنْ زِي ذَاخڒْ نّشْ ؤُ نشّْ أَذْ سّْمثْنغْ ثَاڭلْذَا نّسْ. \x ◘ \xo 7:‏12 \xt 1 إِج. 8‏:‏20\x*  
\v 13 نتَّا أَذْ إِبْنَا إِشْثْ ن ثَادَّارْثْ إِ يِيسمْ إِنُو ؤُ نشّْ أَذْ سّْمثْنغْ ڒْعَارْشْ ن ثَاڭلْذَا نّسْ إِ ڒبْذَا. \x ◘ \xo 7:‏13 \xt 1 إِج. 5‏:‏19؛ 6‏:‏12؛ 1 إِم. 22‏:‏10\x*  
\v 14 نشّْ أَذْ إِڒِيغْ ذ بَابَاسْ إِ نتَّا ؤُ نتَّا أَذْ يِيڒِي إِ نشّْ ذ مِّي. مَاڒَا نتَّا إِفَّارْيضْ، أَذْ ث أَربِّيغْ س وعْمُوذْ ذ ثيِّيثَا ن ثَارْوَا ن بْنَاذمْ. \x ◘ \xo 7:‏14 \xt إِزهد. 89‏:‏27، 31؛ عبر. 1‏:‏5\x*  
\v 15 ثَامخْسِيوْثْ إِنُو إِشوَّارنْ وَارْ زَّايسْ ثتّْخنّسْ أَمْ مَامّشْ تّسّْخنْسغْ ت خْ شَاوُولْ إِ خْ ت كّْسغْ زَّاثْ إِ ثِيطَّاوِينْ نّشْ.  
\v 16 ثَادَّارْثْ نّشْ ذ ثْڭلْذَا نّشْ أَذْ تّْوَاسّْمثْننْثْ زَّاثْ إِ وُوذمْ نّشْ إِ ڒبْذَا، ڒْعَارْشْ نّشْ أَذْ إِقِّيمْ إِبدّْ إِ ڒبْذَا.‘ “ \f ◼ \fr 7:‏16 \ft \+bd ’ڒْعَارْشْ‘\+bd* - نِيغْ ’ڒْكُورْسِي إِڭلّْذنْ‘.\f*  
\v 17 نَاثَانْ إِسِّيوڒْ غَارْ ذَاوُوذْ \add نِيشَانْ\add* عْلَاحْسَابْ أَوَاڒنْ-أَ ؤُ عْلَاحْسَابْ مَارَّا ڒوْحِييْ-أَ.   
\b  
\m
\v 18 \add خنِّي\add* يُوذفْ ؤُجدْجِيذْ ذَاوُوذْ ؤُشَا إِقِّيمْ زَّاثْ إِ وُوذمْ ن سِيذِي، إِنَّا: ”مِينْ عْنِيغْ نشّْ، سِيذِي إِنُو، سِيذِي، ؤُ مِينْ ثعْنَا ثَادَّارْثْ إِنُو أَقَا شكْ ثْنذْهذْ أَيِي-د أَڒْ ذَانِيثَا؟  
\v 19 ذِي ثِيطَّاوِينْ نّشْ ذ مَانْ أَيَا \add مَارَّا\add* عَاذْ ذْرُوسْ، \add أَ\add* سِيذِي إِنُو سِيذِي، \add مَاشَا ڒخُّو\add* ثسِّيوْڒذْ عَاذْ خْ ثَادَّارْثْ ن ؤُمْسخَّارْ نّشْ \add ذڭْ وُوسَّانْ\add* إِڭّْوجنْ \add إِ د إِتَّاسنْ\add*. ذ مَانْ أَيَا ذ ثَاغُورِي \add ذ ثِيذتّْ\add* إِ بْنَاذمْ، \add أَ\add* سِيذِي إِنُو، سِيذِي!   
\m
\v 20 مِينْ ذ أَشْ إِ غَا يِينِي ذَاوُوذْ عَاذْ كْثَارْ؟ شكْ ثسّْنذْ أَمْسخَّارْ نّشْ، \add أَ\add* سِيذِي إِنُو، سِيذِي!  
\v 21 ذِي طّْوعْ ن وَاوَاڒْ نّشْ ؤُ عْلَاحْسَابْ ؤُڒْ نّشْ أَقَا ثڭِّيذْ مَارَّا \add بْلَانُو\add* إِمْغَارنْ وَانِيثَا، حِيمَا أَذْ ثسَّارْڭْبذْ أَمْسخَّارْ نّشْ.  
\v 22 خْ ؤُيَا شكْ ذ أَمقّْرَانْ، \add أَ\add* سِيذِي إِنُو سِيذِي، مَاغَارْ وَارْ \add ذِينْ\add* إِدْجِي ؤُڒَا ذ إِجّْ أَمْ شكْ ؤُ وَارْ \add ذِينْ\add* إِدْجِي ؤُڒَا ذ إِجّْ ن أَربِّي مْغِيرْ شكْ عْلَاحْسَابْ مَارَّا مِينْ نسْڒَا س إِمزُّوغنْ نّغْ. \x ◘ \xo 7:‏22 \xt أَعَوذ. 3‏:‏24؛ 4‏:‏35؛ 32‏:‏39؛ 1 صم. 2‏:‏2؛ إِزهد. 86‏:‏8؛ إِشا. 45‏:‏5، 18، 22؛ مك. 12‏:‏29، 32\x*  
\v 23 مَانْ ونْ \add إِ إِدْجَانْ\add* أَمْ ڒْڭنْسْ نّشْ، أَمْ إِسْرَائِيل، أَينِّي ن ڒْڭنْسْ خْ ثمُّورْثْ إِ غَارْ إِرَاحْ أَربِّي حِيمَا أَذْ ث إِفْذِي إِ يِيخفْ نّسْ ذ ڒْڭنْسْ، ؤُ حِيمَا أَذْ إِڭّْ إِ يِيخفْ نّسْ إِجّْ ن يِيسمْ، ؤُ حِيمَا أَذْ أَومْ إِڭّْ \add إِشْثْ ن ڒْخذْمثْ ذ\add* ثَامقّْرَانْثْ ؤُڒَا ذ ثْمڭَّا ذ ثِيمقّْرَانِينْ إِ ثمُّورْثْ نّشْ زَّاثْ إِ وُوذمْ ن ڒْڭنْسْ نّشْ نِّي ثفْذِيذْ إِ يِيخفْ نّشْ زِي مِيصْرَا، \add زِي\add* ڒڭْنُوسْ ؤُ \add زڭْ\add* إِربِّيثنْ نْسنْ. \f ◼ \fr 7:‏23 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78‏:35.\f*  \x ◘ \xo 7:‏23 \xt أَعَوذ. 4‏:‏7؛ 34؛ 10‏:‏21؛ 33‏:‏29؛ إِزهد. 147‏:‏20\x*  
\v 24 شكْ ثڭِّيذْ ڒْڭنْسْ نّشْ إِسْرَائِيل ذ إِجّْ ن ڒْڭنْسْ إِ يِيخفْ نّشْ إِ ڒبْذَا. شكْ، \add أَ\add* سِيذِي، أَقَا شكْ ثْذوْڒذْ ذ أَربِّي إِ نِيثْنِي.   
\m
\v 25 خنِّي ڒخُّو، سِيذِي أَربِّي، أجّْ أَوَاڒْ نِّي ثسِّيوْڒذْ خْ ؤُمْسخَّارْ نّشْ ؤُ خْ ثَادَّارْثْ نّسْ أَذْ إِبدّْ إِ ڒبْذَا ؤُ أڭّْ أَمْ مَامّشْ ثسِّيوْڒذْ.  
\v 26 أجّْ إِسمْ نّشْ أَذْ إِتّْوَاسّمْغَارْ إِ ڒبْذَا، أَذْ إِنِينْ: ’سِيذِي ن ڒْعسْكَارَاثْ إِجهْذنْ أَقَا-ث ذ أَربِّي خْ إِسْرَائِيل!‘، ؤُشَا إِڒِي أَذْ ثتّْوَاسّمْثنْ ثَادَّارْثْ ن ؤُمْسخَّارْ نّشْ ذَاوُوذْ زَّاثْ إِ وُوذمْ نّشْ.  
\v 27 مَاغَارْ شكْ، \add أَ\add* سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل، أَقَا ثسَّارْڭْبذْ ذڭْ إِمزُّوغنْ ن ؤُمْسخَّارْ نّشْ، ثنِّيذْ: ’نشّْ أَذْ أَشْ سّْبدّغْ إِشْثْ ن ثَادَّارْثْ!‘ خْ ؤُيَا ثُوسَا-د ذڭْ وُوڒْ ن ؤُمْسخَّارْ نّشْ مَاحنْذْ أَذْ إِژَّادْجْ ثَاژَادْجِيثْ-أَ غَاركْ.  
\v 28 \add خنِّي\add* ڒخُّو، \add أَ\add* سِيذِي إِنُو، سِيذِي، شكْ ذ أَربِّي نِّي ؤُشَا أَوَاڒنْ نّشْ ذ ثِيذتّْ ؤُ شكْ ثسِّيوْڒذْ س \add مَارَّا\add* ثْشُونِي-يَا غَارْ ؤُمْسخَّارْ نّشْ. \x ◘ \xo 7:‏28 \xt يُوح. 17‏:‏17\x*  
\v 29 \add خنِّي\add* ڒخُّو، مَاڒَا ثُوسَا أَشْ-د خْ ڒْخَاضَارْ، بَاركْ ثَادَّارْثْ ن ؤُمْسخَّارْ نّشْ، حِيمَا أَذْ ثِيڒِي زَّاثْ إِ وُوذمْ نّشْ إِ ڒبْذَا، مِينْزِي شكْ، \add أَ\add* سِيذِي إِنُو، سِيذِي، ثسِّيوْڒذْ \add أَيَا\add* ؤُ س لْبَارَاكَا نّشْ أَذْ ثتّْوَابَاركْ ثَادَّارْثْ ن ؤُمْسخَّارْ نّشْ إِ ڒبْذَا.‘ “   
\b  
\b  
\m  
\c 8
\s1 إِغلَّابنْ ن ذَاوُوذْ  
\m
\v 1 أَوَارْنِي أَيَا إِمْسَارْ أَقَا ذَاوُوذْ إِغْڒبْ خْ إِفِيلِيسْطِينِييّنْ ؤُشَا يَارَّا إِ-ثنْ سَاذُو أَفُوسْ نّسْ ؤُ ذَاوُوذْ إِكّسْ ڒحْكَامثْ زڭْ ؤُفُوسْ ن إِفِيلِيسْطِينِييّنْ. \x ◘ \xo 8:‏1 \xt [1 إِم. 18‏:‏1‏-‏14]\x*  
\v 2 \add عَاوذْ\add* إِغْڒبْ نتَّا خْ مُوآبَ ؤُشَا إِعْبَارْ إِ-ثنْ س يِيجّْ ن ؤُفِيڒُو \add ن ڒعْبَارْ\add* أَمْ زّْڒنْ ذِي ثمُّورْثْ. نتَّا إِعْبَارْ ثْنَاينْ ن إِفِيڒَانْ \add ن ڒعْبَارْ\add*، حِيمَا أَذْ ثنْ إِنغْ، ؤُڒَا ذ إِجّْ ن ؤُفِيڒُو إِمُونْ، حِيمَا أَذْ ثنْ يجّْ دَّارنْ. \add أَمُّو\add* إِ ذوْڒنْ أَيْثْ ن مُوآبَ ذ إِمْسخَّارنْ إِ ذَاوُوذْ نِّي إِتّْخصَّانْ أَذْ \add أَسْ\add* وْشنْ لْجِيزْيَا.   
\m
\v 3 ذَاوُوذْ إِغْڒبْ عَاوذْ خْ هَاذَاذْ-عَازَارْ، مِّيسْ ن رَاحُوبْ، أَجدْجِيذْ ن صُوبَا، ؤُمِي ثُوغَا د-إِفّغْ وَانِيثَا حِيمَا أَذْ غَارسْ د-يَارّْ ڒحْكَامثْ نّسْ غَارْ يغْزَارْ \add ن لْفُورَاطْ\add*. \f ◼ \fr 8:‏3 \ft \+bd ’ڒحْكَامثْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَفُوسْ نّسْ‘.\f*  
\v 4 ذَاوُوذْ إِكّسْ زَّايسْ أَڒفْ ؤُ سبْعَا-مْيَا ن إِمْنَاينْ ذ عِيشْرِينْ-أَڒفْ ن يرْيَازنْ خْ إِضَارنْ، ؤُشَا إِقسّْ ذَاوُوذْ إِژوْرَانْ ن إِضَارنْ ن مَارَّا \add إِيْسَانْ ن\add* إِكَارُّوثنْ، \add مَاشَا\add* إِجَّا زَّايسْ مْيَا ن \add إِيْسَانْ ن\add* إِكَارُّوثنْ. \x ◘ \xo 8:‏4 \xt 1 إِم. 18‏:‏4\x*  
\v 5 يُوسَا-د أَرَامْ زِي ذِيمَاشْقْ، حِيمَا أَذْ إِوْشْ أَفُوسْ إِ هَاذَاذْ-عَازَارْ، أَجدْجِيذْ ن صُوبَا، ؤُ ذَاوُوذْ إِغْڒبْ خْ ثْنَاينْ ؤُ-عِيشْرِينْ-أَڒَافْ ن يرْيَازنْ ن أَرَامْ.  
\v 6 ذَاوُوذْ إِڭَّا ڒْعسْكَارَاثْ \add ن ؤُحوّسْ\add* جَارْ إِرَامِييّنْ ن ذِيمَاشْقْ ؤُ إِرَامِييّنْ ذوْڒنْ ذ إِمْسخَّارنْ ن ذَاوُوذْ إِنِّي إِتّْخصَّانْ أَذْ \add أَسْ\add* وْشنْ ثَارْزِيفِينْ. سِيذِي إِڭَّا تَّاسِيعْ إِ ذَاوُوذْ مَانِي مَا إِرُوحْ.  
\v 7 ذَاوُوذْ إِكْسِي ثِيسدَّارِييِينْ إِقسْحنْ ن ؤُعسْكَارِي نِّي تّْوَاڭّنْثْ س وُورغْ، ثِينِّي ثُوغَا \add إِدْجَانْ\add* ن إِمْسخَّارنْ ن هَاذَاذْ-عَازَارْ ؤُ يِيوْيِي ثنْثْ غَارْ ؤُرْشَالِيمْ.  
\v 8 إِكْسِي ذَاوُوذْ أَطَّاسْ ن نّْحَاسْ زِي بَاثَاحْ ؤُ زِي بِيرَاثَايْ، ثِيندَّامْ ن هَاذَاذْ-عَازَارْ.   
\m
\v 9 \add ؤُمِي\add* ثُوعِي، أَجدْجِيذْ ن حَامَاثْ، إِسْڒَا أَقَا ذَاوُوذْ إِغْڒبْ خْ مَارَّا ڒْعسْكَارْ ن هَاذَاذْ-عَازَارْ،  
\v 10 إِسّكّْ ثُوعِي مِّيسْ يُورَامْ غَارْ ؤُجدْجِيذْ ذَاوُوذْ، حِيمَا أَذْ إِسّقْسَا خْ ؤُمدُّورْ نّسْ ؤُ حِيمَا أَذْ أَسْ إِبَاركْ، مِينْزِي نتَّا إِمّْنغْ أَكِيذسْ ؤُ إِغْڒبْ خَاسْ، مَاغَارْ هَاذَاذْ-عَازَارْ ثُوغَا يَارزُّو أَذْ إِمّْنغْ أَكْ-ذ ثُوعِي ڒبْذَا. \add نتَّا يِيوِي أَكِيذسْ\add* ذڭْ ؤُفُوسْ نّسْ ڒقْشُوعْ ن نُّوقَارْثْ ذ ڒقْشُوعْ ن وُورغْ ذ ڒقْشُوعْ ن نّْحَاسْ، \f ◼ \fr 8:‏10 \ft \+bd ’هَاذَاذْ-عَازَارْ ثُوغَا إِ ثُوعِي ذ إِجّْ ن ورْيَازْ يَارزُّو أَمنْغِي‘\+bd* - أَوَاڒنْ-أَ خْسنْ أَذْ إِنِينْ أَقَا هَاذَاذْ-عَازَارْ إِفّغْ أَطَّاسْ ن ثْوَاڒَاوِينْ غَارْ ؤُمنْغِي أَكْ-ذ ؤُجدْجِيذْ ثُويْ.\f*  
\v 11 إِنِّي إِسّْقدّسْ ؤُجدْجِيذْ ذَاوُوذْ عَاوذْ إِ سِيذِي، \add إِمُونْ\add* أَكْ-ذ نُّوقَارْثْ ذ وُورغْ نِّي ثُوغَا إِسّْقدّسْ زِي مَارَّا ڒڭْنُوسْ نِّي ثُوغَا يَارَّا سَاذُو نّسْ:  
\v 12 زِي أَرَامْ، زِي مُوآبَ، زڭْ أَيْثْ ن عَامُّونْ، زڭْ إِفِيلِيسْطِينِييّنْ، زِي عَامَالِيقْ ؤُڒَا زِي ثْكشَّاضْثْ ن هَاذَاذْ-عَازَارْ، مِّيسْ ن رَاخُوبْ، أَجدْجِيذْ ن صُوبَا.   
\m
\v 13 إِڭَّا ذَاوُوذْ عَاوذْ إِجّْ ن يِيسمْ، ؤُمِي د-إِعْقبْ نتَّا زڭْ ڒغْڒبْ خْ أَرَامْ ذِي ثغْزُورْثْ ن ثْمدْجَاحْثْ، ثْمنْطَاشْ-أَڒفْ \add ن يرْيَازنْ\add*. \x ◘ \xo 8:‏13 \xt إِزهد. 60‏:‏2\x*  
\v 14 نتَّا إِڭَّا ڒْعسْكَارَاثْ \add ن ؤُحوّسْ\add* ذِي إِذُومْ. ذِي مَارَّا إِذُومْ إِڭَّا ڒْعسْكَارَاثْ \add ن ؤُحوّسْ\add* ؤُ مَارَّا إِذُومِييّنْ ذوْڒنْ ذ إِمْسخَّارنْ إِ ذَاوُوذْ. سِيذِي إِڭَّا تَّاسِيعْ إِ ذَاوُوذْ مَانِي مَا إِفّغْ نتَّا.   
\b  
\m  
\s1 إِمْذبَّارنْ إِمقّْرَاننْ ن ذَاوُوذْ  
\m
\v 15 ذَاوُوذْ إِحْكمْ خْ مَارَّا إِسْرَائِيل ؤُ ذَاوُوذْ إِڭَّا س ڒْحقّْ ذ ثْسڭْذَا إِ مَارَّا ڒْڭنْسْ نّسْ. \x ◘ \xo 8:‏15 \xt [2 صم. 20‏:‏23‏-‏26، 1 إِم. 18‏:‏15‏-‏17]\x*   
\m
\v 16 يُووَابْ، مِّيسْ ن صَارُويَا، \add ثُوغَا-ث\add* خْ ڒْعسْكَارْ ؤُ يَاهُوشَافَاطْ، مِّيسْ ن أَخِيلُوذْ، ثُوغَا-ث ذ أَمَارِيرْ ن ؤُمزْرُويْ.  
\v 17 صَاذُوقْ، مِّيسْ ن أَخِيطُوبْ، ذ أَخِيمَالِيكْ، مِّيسْ ن أَبْيَاثَارْ، ثُوغَا أَثنْ ذ إِكهَّاننْ ؤُ سَارَايَا ثُوغَا-ث ذ أَمَارِيرْ.  
\v 18 بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ، \add ثُوغَا-ث خْ\add* إِعسَّاسنْ ن أَرِّيمثْ \add ن ؤُجدْجِيذْ\add* ؤُ \add خْ\add* إِرقَّاسنْ ن ثَازْڒَا. إِحنْجِيرنْ ن ذَاوُوذْ \add ثُوغَا أَثنْ ذ\add* إِمْثِيقَّانْ نّسْ.   
\b  
\b  
\m  
\c 9
\s1 ذَاوُوذْ ذ مَافِيپُوشَاثْ  
\m
\v 1 ذَاوُوذْ إِنَّا: ”مَا إِقِّيمْ عَاذْ شَا ن يِيجّنْ زِي ثَادَّارْثْ ن شَاوُولْ، حِيمَا نشّْ أَذْ أَسْ سّشْنغْ ثَامخْسِيوْثْ \add إِنُو\add* إِشوَّارنْ ذِي طّْوعْ ن يُونَاثَانْ؟“  
\v 2 ثُوغَا \add ذِينْ\add* إِجّْ ن ؤُمْسخَّارْ \add غَارْ\add* ثَادَّارْثْ ن شَاوُولْ، تّْڒَاغَانْ أَسْ صِيبَا. ڒَاغَانْ أَسْ-د غَارْ ذَاوُوذْ. إِنَّا أَسْ ؤُجدْجِيذْ: ”مَا شكْ ذ صِيبَا؟“ نتَّا إِنَّا: ”ذ أَمْسخَّارْ نّشْ.“ \x ◘ \xo 9:‏2 \xt 2 صم. 16‏:‏1‏-‏4؛ 19‏:‏17\x*  
\v 3 أَجدْجِيذْ إِنَّا: ”مَا إِقِّيمْ عَاذْ شَا ن إِجّْ زِي ثَادَّارْثْ ن شَاوُولْ \add إِدَّارْ\add*، حِيمَا أَذْ أَسْ سّشْنغْ ثَامخْسِيوْثْ إِشوَّارنْ ن أَربِّي؟“ \add خنِّي\add* إِنَّا صِيبَا إِ ؤُجدْجِيذْ: ”أَقَا ذِينْ عَاذْ إِجّْ ن مِّيسْ ن يُونَاثَانْ ونِّي ذ أَنعْضَابْ زِي ثْنَاينْ ن إِضَارنْ.“ \x ◘ \xo 9:‏3 \xt 2 صم. 4‏:‏4\x*  
\v 4 إِنَّا أَسْ ؤُجدْجِيذْ: ”مَانِي إِدْجَا نتَّا؟“ صِيبَا إِنَّا أَسْ إِ ؤُجدْجِيذْ: ”خْزَارْ، نتَّا أَقَا-ث ذِي ثَادَّارْثْ ن مَاخِيرْ، مِّيسْ ن عَامِّييِيلْ، ذِي لُو-ذَابَارْ.“   
\m
\v 5 \add خنِّي\add* إِسّكّْ ؤُجدْجِيذْ ذَاوُوذْ ذِينْ ؤُ يِيوْيِي ث-إِ-د زِي ثَادَّارْثْ ن مَاخِيرْ، مِّيسْ ن عَامِّييِيلْ ذِي لُو-ذَابَارْ.  
\v 6 \add ؤُمِي\add* مَافِيبُوشَاثْ، مِّيسْ ن يُونَاثَانْ، مِّيسْ ن شَاوُولْ، يُوذفْ غَارْ ذَاوُوذْ، إِوْضَا س ؤُغمْبُوبْ نّسْ \add غَارْ ثمُّورْثْ\add*، يُوضَارْ \add أَسْ\add*. ذَاوُوذْ إِنَّا: ”مَافِيبُوشَاثْ!“ نتَّا إِنَّا: ”خْزَارْ، أَقَا ذَا أَمْسخَّارْ نّشْ.“  
\v 7 ذَاوُوذْ إِنَّا أَسْ: ”وَارْ تّڭّْوذْ، مَاغَارْ نشّْ أَذْ أَشْ سّشْنغْ ثَامخْسِيوْثْ \add إِنُو\add* إِشوَّارنْ ذِي طّْوعْ ن بَابَاشْ يُونَاثَانْ. نشّْ أَذْ أَشْ أَرّغْ مَارَّا إِيَّارنْ ن جدّْ نّشْ شَاوُولْ ؤُ شكْ أَذْ ثشّذْ ڒبْذَا مَاشَّا غَارْ طَّابْڒَا إِنُو.“ \f ◼ \fr 9:‏7 \ft \+bd ’جدّْ نّكْ‘\+bd* - س ثْعِيبْرَانِيثْ ’بَابَاشْ‘.\f*  
\v 8 \add خنِّي\add* يُوضَارْ \add أَسْ\add*، إِنَّا: ”مِينْ إِعْنَا ؤُمْسخَّارْ نّشْ أَڒَامِي شكْ ثخْزَارذْ غَارْ إِجّْ ن وقْزِينْ إِمُّوثنْ أَمْ مَامّشْ دْجِيغْ نشّْ؟“  
\v 9 \add خنِّي\add* إِڒَاغَا ؤُجدْجِيذْ خْ صِيبَا، أَمْسخَّارْ ن شَاوُولْ، إِنَّا أَسْ: ”مَارَّا مِينْ إِدْجَانْ ن شَاوُولْ ذ مَارَّا ثَادَّارْثْ نّسْ، وْشِيغْ ث إِ مِّيسْ ن سِيذِي نّشْ.  
\v 10 شكْ أَذْ أَسْ ثْشَارْزذْ ثَامُّورْثْ، شكْ ذ إِحنْجِيرنْ نّشْ ذ إِمْسخَّارنْ نّشْ، ؤُشَا أَذْ أَسْ ثَاوْيذْ صَّابثْ نّسْ، حِيمَا مِّيسْ ن سِيذِي نّشْ أَذْ غَارسْ يِيڒِي وغْرُومْ مَاحنْذْ أَذْ يشّْ. مَافِيبُوشَاثْ، مِّيسْ ن سِيذِي نّشْ، أَذْ يشّْ ڒبْذَا أَغْرُومْ غَارْ طَّابْڒَا إِنُو.“ صِيبَا ثُوغَا غَارسْ خمّسْطَاشْ ن إِحنْجِيرنْ ذ عِيشْرِينْ ن إِمْسخَّارنْ.   
\m
\v 11 صِيبَا إِنَّا إِ ؤُجدْجِيذْ: ”أَمْسخَّارْ نّشْ أَذْ إِڭّْ عْلَاحْسَابْ مَارَّا مِينْ يُومُورْ سِيذِي إِنُو أَجدْجِيذْ إِ ؤُمْسخَّارْ نّسْ!“ \add ذَاوُوذْ إِنَّا عَاذْ\add*: ”مَافِيبُوشَاثْ أَذْ إِشّْ غَارْ طَّابْڒَا إِنُو أَمْ يِيجّنْ زڭْ إِحنْجِيرنْ ن ؤُجدْجِيذْ.“  
\v 12 مَافِيبُوشَاثْ ثُوغَا غَارسْ إِجّْ ن مِّيسْ تّْڒَاغَانْ أَسْ مِيخَا. مَارَّا إِنِّي ثُوغَا إِزدّْغنْ ذِي ثَادَّارْثْ ن صِيبَا ثُوغَا أَثنْ ذ إِمْسخَّارنْ ن مَافِيبُوشَاثْ.  
\v 13 ؤُ مَافِيبُوشَاثْ ثُوغَا إِزدّغْ ذِي ؤُرْشَالِيمْ، مَاغَارْ نتَّا إِتّتّْ ڒبْذَا غَارْ طَّابْڒَا ن ؤُجدْجِيذْ. نتَّا ثُوغَا-ث ذ أَنعْضَابْ زِي ثْنَاينْ ن إِضَارنْ.   
\b  
\b  
\m  
\c 10
\s1 أَمنْغِي أَكْ-ذ أَيْثْ ن عَامُّونْ ذ إِرَامِييّنْ  
\m
\v 1 أَوَارْنِي أَيَا إِمْسَارْ، أَقَا أَجدْجِيذْ ن أَيْثْ ن عَامُّونْ إِمُّوثْ. مِّيسْ حَانُونْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. \f ◼ \fr 10:‏1 \ft \+bd ’ذڭْ ومْشَانْ نّسْ‘\+bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي، أَقَا إِخْڒفْ إِ-ث.\f*  \x ◘ \xo 10:‏1 \xt [1 إِم. 19‏:‏1‏-‏19]\x*  
\v 2 \add خنِّي\add* إِنَّا ذَاوُوذْ: ”نشّْ خْسغْ أَذْ سّشْنغْ ثَامخْسِيوْثْ إِشوَّارنْ إِ حَانُونْ، مِّيسْ ن نَاحَاشْ، أَمْ مَامّشْ إِ ذ أَيِي إِسّْشنْ بَابَاسْ ثَامخْسِيوْثْ \add نّسْ\add* إِشوَّارنْ.“ ذَاوُوذْ إِسّكّْ \add إِرقَّاسنْ\add* حِيمَا أَذْ ث إِعزَّا خْ \add ڒْْموْثْ ن\add* بَابَاسْ س ؤُفُوسْ ن إِمْسخَّارنْ نّسْ ؤُ إِمْسخَّارنْ ن ذَاوُوذْ إِوْضنْ غَارْ ثمُّورْثْ ن أَيْثْ ن عَامُّونْ.  
\v 3 \add خنِّي\add* نَّانْ ڒْحُوكَّامْ ن أَيْثْ ن عَامُّونْ إِ سِيذِي نْسنْ حَانُونْ: ”مَا \add إِخْسْ\add* ذَاوُوذْ \add س ثِيذتّْ\add* أَذْ إِوقَّارْ بَابَاشْ ذِي ثِيطَّاوِينْ نّشْ، ؤُمِي د-إِسّكّْ نتَّا إِمْسخَّارنْ مَاحنْذْ أَذْ شكْعزَّانْ؟ مَا وَارْ د-إِسّكّْ ذَاوُوذْ إِمْسخَّارنْ نّسْ غَاركْ، حِيمَا أَذْ أَرْزُونْ ذِي ثنْذِينْثْ، أَذْ سّْمُوننْ ڒخْبَارْ ؤُشَا \add خنِّي\add* أَذْ ت أَرّنْ وَارْ ثدْجِي ذ نتَّاثْ؟“   
\m
\v 4 \add خَاسْ ؤُشَا\add* إِطّفْ حَانُونْ إِمْسخَّارنْ ن ذَاوُوذْ، إِحفّْ أَسنْ أَزْينْ زِي ثْمَارْثْ ؤُ إِقسّْ أَسنْ أَزْينْ ن وَارُّوضْ أَڒْ ضفَّارْ، ؤُشَا إِسّكّْ إِ-ثنْ.  
\v 5 \add ؤُمِي\add* خبَّارنْ أَيَا إِ ذَاوُوذْ، إِسّكّْ أَسنْ \add إِرقَّاسنْ\add*، مِينْزِي نِيثْنِي ثُوغَا تّْسضْحَانْ إِخفْ نْسنْ أَطَّاسْ. إِنَّا ؤُجدْجِيذْ: ”قِّيممْ ذِي أَرِيحَا أَڒْ د غَا ثمْغَارْ ثْمَارْثْ نْومْ، خنِّي أَذْ د-ثْذوْڒمْ.“   
\m
\v 6 \add ؤُمِي\add* ژْرِينْ أَيْثْ نْ عَامُّونْ بلِّي نِيثْنِي ثُوغَا سَّارْزْڭنْ إِخفْ نْسنْ غَارْ ذَاوُوذْ، سّكّنْ أَيْثْ ن عَامُّونْ \add إِرقَّاسنْ\add* ؤُ شْرَانْ زڭْ أَيْثْ ن أَرَامْ زِي بَايْثْ-رَاخُوبْ ؤُ زڭْ أَيْثْ ن أَرَامْ زِي صُوبَا عِيشْرِينْ-أَڒَافْ ن يرْيَازنْ خْ إِضَارنْ، ؤُ زڭْ ؤُجدْجِيذْ ن مَاعْكَا أَڒفْ ن يرْيَازنْ ؤُ زڭْ يرْيَازنْ ن طُوبْ ثنْعَاشْ-أَڒَافْ ن يرْيَازنْ.  
\v 7 \add ؤُمِي\add* إِسْڒَا ذَاوُوذْ أَيَا، إِسّكّْ نتَّا يُووَابْ س مَارَّا ڒْعسْكَارْ نّسْ، أَيْثْ ن بُو-ثغْرُوضْثْ.  
\v 8 أَيْثْ ن عَامُّونْ فّْغنْ-د ؤُ سدّنْ إِخفْ نْسنْ إِ ؤُمنْغِي غَارْ وَاذَافْ ن ثوَّارْثْ \add ن ثنْذِينْثْ\add*، مَاشَا أَيْثْ ن أَرَامْ ن صُوبَا ذ رَاخُوبْ ذ يرْيَازنْ ن طُوبْ ذ مَاعْكَا \add ثُوغَا أَثنْ\add* س يِيخفْ نْسنْ ذڭْ إِيَّارْ.  
\v 9 \add ؤُمِي\add* إِژْرَا يُووَابْ، أَقَا أَمنْغِي إِخژَّارْ إِ-ثنْ ذڭْ ؤُغمْبُوبْ غَارْ زَّاثْ ؤُ غَارْ ضفَّارْ، إِخْضَارْ نتَّا زِي مَارَّا إِنِّي إِتّْوَافَارْزنْ \add ذِي ڒْعسْكَارْ\add* ن إِسْرَائِيل ؤُشَا إِسّْبدّْ إِ-ثنْ \add إِ ؤُمنْغِي\add* أَجمَّاضْ ن أَيْثْ ن أَرَامْ.  
\v 10 مِينْ إِقِّيمنْ ن ڒْڭنْسْ إِڭَّا إِ-ثنْ سَاذُو ؤُفُوسْ ن ؤُمَاسْ أَبِيشَايْ، ونِّي ثنْ إِسّْبدّنْ أَجمَّاضْ ن أَيْثْ ن عَامُّونْ.  
\v 11 إِنَّا نتَّا: ”مَاڒَا أَرَامْ إِجْهذْ خَافِي، خنِّي أَسْ-د، فكّْ أَيِي! مَاڒَا أَيْثْ ن عَامُّونْ جهْذنْ خَاكْ، \add خنِّي\add* أَذْ د-أَسغْ أَذْ شكْ فكّغْ.  
\v 12 إِڒِي ذ أَرْيَازْ ؤُ أَذْ نِيڒِي ذ إِرْيَازنْ ذِي طّْوعْ ن ڒْڭنْسْ نّغْ ؤُ ذِي طّْوعْ ن ثْندَّامْ ن أَربِّي. أجّْ سِيذِي أَذْ إِڭّْ مِينْ إِدْجَانْ ذ لمْلِيحْ ذِي ثِيطَّاوِينْ نّسْ.“  
\v 13 \add خنِّي\add* إِقَارّبْ-د يُووَابْ ذ ڒْڭنْسْ إِ غَارسْ إِدْجَانْ إِ ؤُمنْغِي أَكْ-ذ أَرَامْ ؤُشَا إِنَا طّْفنْ ذِي ثَاروْڒَا زَّاثْ إِ وُوذمْ نّسْ.  
\v 14 \add ؤُمِي\add* ژْرِينْ أَيْثْ ن عَامُّونْ، أَقَا أَيْثْ ن أَرَامْ أَروْڒنْ، طّْفنْ ؤُڒَا ذ نِيثْنِي ذِي ثَاروْڒَا زَّاثْ إِ وُوذمْ ن أَبِيشَايْ ؤُشَا إِوْضنْ غَارْ ثنْذِينْثْ. يُووَابْ إِعْقبْ أَوَارْنِي إِ ؤُمنْغِي أَكْ-ذ أَيْثْ ن عَامُّونْ ؤُشَا يِيوضْ غَارْ ؤُرْشَالِيمْ.   
\m
\v 15 \add ؤُمِي\add* ژْرِينْ أَيْثْ ن أَرَامْ أَقَا نِيثْنِي تّْوَاغڒْبنْ زَّاثْ إِ وُوذمْ ن إِسْرَائِيل، نّْيَارْونْ ثْوَاڒَا نّغْنِيثْ.  
\v 16 ؤُشَا هَاذَاذْ-عَازَارْ إِسّكّْ \add إِرقَّاسنْ\add*، إِجَّا أَذْ د-أَسنْ أَيْثْ ن أَرَامْ إِنِّي \add إِزدّْغنْ\add* خْ ؤُجمَّاضْ نْ إِغْزَارْ \add ن لْفُورَاطْ\add* ؤُشَا نِيثْنِي ؤُسِينْ-د غَارْ حِيلَامْ. شُوبَاكْ، أَكُومَانْذَارْ ن ڒْعسْكَارْ ن هَاذَاذْ-عَازَارْ، إِفّغْ زَّاثْ إِ وُوذمْ نْسنْ.  
\v 17 \add ؤُمِي\add* إِتّْوَانَّا أَيَا إِ ذَاوُوذْ، إِسّْمُونْ نتَّا مَارَّا إِسْرَائِيل، إِژْوَا لْ-ؤُرْذُونْ، يُوسَا-د غَارْ حِيلَامْ. أَيْثْ ن أَرَامْ سدّنْ إِخفْ نْسنْ إِ ؤُمنْغِي قِيبَاتْشْ إِ ذَاوُوذْ ؤُ مّنْغنْ أَكِيذسْ.  
\v 18 أَيْثْ ن أَرَامْ أَروْڒنْ زَّاثْ إِ وُوذمْ ن إِسْرَائِيل ؤُ ذَاوُوذْ إِقْضَا خْ سبْعَا-مْيَا ن إِكَارُّوثنْ \add ن ؤُمنْغِي\add* ذ أَربْعِينْ-أَڒفْ ن إِمْنَاينْ ن أَيْثْ ن أَرَامْ. \add عَاوذْ\add* إِوْثَا نتَّا شُوبَاكْ، أَكُومَانْذَارْ ن ڒْعسْكَارْ نْسنْ، أَڒَامِي إِمُّوثْ ذِينْ.  
\v 19 \add ؤُمِي\add* ژْرِينْ مَارَّا إِجدْجِيذنْ نِّي ثُوغَا إِتّْرَاحنْ أَكْ-ذ هَاذَاذْ-عَازَارْ، بلِّي أَقَا نِيثْنِي ثْوَاغلّْبنْ زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل، ڭِّينْ نِيثْنِي ڒهْنَا أَكْ-ذ إِسْرَائِيل ؤُ سخَّارنْ أَسْ. أَيْثْ ن أَرَامْ ڭّْوذنْ أَذْ فكّنْ أَيْثْ نْ عَامُّونْ ثْوَاڒَا نّغْنِيثْ. \f ◼ \fr 10:‏19 \ft \+bd ’أَسْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَسنْ‘.\f*   
\b  
\b  
\m  
\c 11
\s1 ذَاوُوذْ ذ بَاثْشَابَاعْ  
\m
\v 1 غَارْ ؤُبدُّو ن ؤُسڭّْوَاسْ ن جْذِيذْ، ذِي ڒْوقْثْ إِ ذِي إِتّفّْغنْ إِجدْجِيذنْ \add غَارْ ؤُمنْغِي\add*، إِمْسَارْ أَقَا ذَاوُوذْ إِسّكّْ يُووَابْ أَكْ-ذ يرْيَازنْ نّسْ نِّي أَكِيذسْ \add إِدْجَانْ\add* ذ مَارَّا إِسْرَائِيل. نِيثْنِي ڒبْزنْ أَيْثْ ن عَامُّونْ ؤُشَا نّْضنْ إِ رَابَّا. مَاشَا ذَاوُوذْ سِيمَانْثْ نّسْ إِقِّيمْ ذِي ؤُرْشَالِيمْ. \x ◘ \xo 11:‏1 \xt 1 إِم. 20‏:‏1‏-‏3\x*   
\m
\v 2 ؤُمِي د-إِكَّارْ ذَاوُوذْ إِشْثْ ن ثْوَاڒَا ذِي ثْمذِّيثْ زِي قَامَا نّسْ، إِمْسَارْ أَقَا نتَّا يُويُورْ خْ ثْزقَّا \add إِوَاطَانْ\add* ن ثْزذِّيغْثْ ن ؤُجدْجِيذْ. إِژْرَا سّنِّي إِشْثْ ن ثمْغَارْثْ ثسِّيرِيذْ إِخفْ نّسْ. ثَامْغَارْثْ نِّي ذَايسْ أَژْرِي أَطَّاسْ.  
\v 3 ذَاوُوذْ إِسّكّْ \add إِجّْ\add* ذِينْ مَاحنْذْ أَذْ إِسّقْسَا خْ ثمْغَارْثْ نِّي. إِتّْوَانَّا \add أَسْ\add*: ”مَا وَارْ ثدْجِي ذ بَاثْ-شَابَاعْ، يدْجِيسْ ن إِلِيعَامْ، ثَامْغَارْثْ ن أَحِيتِّي ؤُرِييَا؟“  
\v 4 \add خَاسْ ؤُشَا\add* إِسّكّْ ذَاوُوذْ إِرقَّاسنْ، إِجَّا أَذْ ت-إِ-د-أَوْينْ. نتَّاثْ ثُوذفْ-د غَارسْ ؤُشَا إِطّصْ أَكِيذسْ. \add أَوَارْنِي ڒَامِي\add* ثُوغَا ثتّْوَازِيذْڭذْ زِي ڒخْمجْ نّسْ، ثعْقبْ غَارْ ثَادَّارْثْ نّسْ. \x ◘ \xo 11:‏4 \xt لَاوِي 15‏:‏19‏-‏24؛ 18‏:‏19\x*  
\v 5 ثَامْغَارْثْ ثُوغَا ثكْسِي س دّيْسثْ ؤُشَا ثسّكّْ \add إِجّْ\add*، ثسَّارْڭبْ ذَاوُوذْ، ثنَّا: ”نشّْ كْسِيغْ س دّيْسثْ.“   
\m
\v 6 \add خَاسْ ؤُشَا\add* إِسّكّْ ذَاوُوذْ \add إِشْثْ ن ثبْرَاثْ\add* غَارْ يُووَابْ: ”سكّْ-د أَحِيتِّي ؤُرِييَا غَارِي!“ ؤُ يُووَابْ إِسّكّْ ؤُرِييَا غَارْ ذَاوُوذْ.  
\v 7 \add ؤُمِي\add* غَارسْ-د يُوسَا ؤُرِييَا، إِسّقْسَا ذَاوُوذْ خْ مَامّشْ إِدْجَا يُووَابْ ؤُ خْ مَامّشْ إِدْجَا ڒْڭنْسْ ؤُ خْ مَامّشْ إِڭُّورْ ؤُمنْغِي.  
\v 8 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ ؤُرِييَا:” هْوَا غَارْ ثَادَّارْثْ نّشْ ؤُشَا سِّيرْذْ إِضَارنْ نّشْ!“ ؤُرِييَا إِسْمحْ ذِي ثَادَّارْثْ ن ؤُجدْجِيذْ ؤُ سّضْفَارنْ أَسْ \add عَاذْ\add* إِشْثْ ن ثَارْزفْثْ ن ؤُجدْجِيذْ.  
\v 9 \add مَاشَا\add* ؤُرِييَا إِزّڒْ إِطّصْ غَارْ ثوَّارْثْ ن ثَادَّارْثْ ن ؤُجدْجِيذْ أَكْ-ذ مَارَّا إِمْسخَّارنْ ن سِيذِي نّسْ. نتَّا وَارْ إِهْوِي شَا غَارْ ثَادَّارْثْ نّسْ.  
\v 10 خبَّارنْ إِ ذَاوُوذْ، نَّانْ: ”ؤُرِييَا وَارْ إِهْوِي شَا غَارْ ثَادَّارْثْ نّسْ.“ \add خَاسْ ؤُشَا\add* إِنَّا ذَاوُوذْ إِ ؤُرِييَا: ”مَا وَارْ د-ثذْوِيڒذْ زڭْ ؤُسَافَارْ؟ مَايمِّي شكْ وَارْ ثهْوِيذْ غَارْ ثَادَّارْثْ نّشْ؟“ \f ◼ \fr 11:‏10 \ft \+bd ’أَسَافَارْ‘\+bd* - نِيغْ ’أَمُودُّو‘.\f*  
\v 11 ؤُرِييَا يَارَّا-د خْ ذَاوُوذْ: ”تَّابُوثْ ذ إِسْرَائِيل ذ يَاهُوذَا تّْغِيمَانْ ذڭْ إِقِيضَانْ ؤُ سِيذِي إِنُو يُووَابْ ذ إِمْسخَّارنْ ن سِيذِي إِنُو وْثِينْ إِقِيضَانْ نْسنْ ذڭْ إِيَّارْ يَارزْمنْ. مَا \add خنِّي\add* أَذْ ؤُيُورغْ نشّْ غَارْ ثَادَّارْثْ إِنُو، حِيمَا أَذْ شّغْ، أَذْ سْوغْ ؤُ أَذْ وْضِيغْ أَكْ-ذ ثمْغَارْثْ إِنُو؟ \add س ثِيذتّْ أَمْ\add* ثدَّارذْ شكْ ؤُ إِدَّارْ ڒعْمَارْ نّشْ، وَارْ تّڭّغْ أَيَا!“  
\v 12 \add خَاسْ\add* ؤُشَا إِنَّا ذَاوُوذْ إِ ؤُرِييَا: ”قِّيمْ ؤُڒَا ذ أَسّْ-أَ عَاذْ ذَانِيثَا. ثِيوشَّا أَذْ شكْ سّكّغْ \add عَاوذْ\add*.“ ؤُشَا \add أَمُّو إِ\add* إِقِّيمْ ؤُرِييَا أَسّْ نِّي ذ وَاسّْ إِ ث-إِ-د-إِضْفَارنْ ذِي ؤُرْشَالِيمْ.   
\m
\v 13 إِعَارْضْ إِ-ث ذَاوُوذْ ؤُشَا نتَّا إِشَّا، إِسْوَا زَّاثْ إِ وُوذمْ نّسْ ؤُشَا \add ذَاوُوذْ\add* إِسّْشَارْ إِ-ث. غَارْ ثْمذِّيثْ \add مَاشَا\add* إِفّغْ ؤُرِييَا، حِيمَا أَذْ إِزّڒْ \add عَاوذْ\add* غَارْ إِمْسخَّارنْ ن سِيذِي نّسْ، \add مَاشَا\add* نتَّا وَارْ إِهْوِي شَا غَارْ ثَادَّارْثْ نّسْ.  
\v 14 غَارْ ثُوفُّوثْ إِمْسَارْ، أَقَا ذَاوُوذْ يُورَا إِشْثْ ن ثبْرَاثْ إِ يُووَابْ ؤُشَا إِسّكّْ إِ-ت س ؤُفُوسْ ن ؤُرِييَا.  
\v 15 نتَّا يُورَا ذِي ثبْرَاثْ نِّي: ”سْبدّثْ ؤُرِييَا غَارْ زَّاثْ مَانِي إِدْجَا ؤُمنْغِي إِقسْحنْ، خنِّي حيّْذثْ خَاسْ، حِيمَا أَذْ ث ڒقْفنْ، أَذْ إِمّثْ.“   
\m
\v 16 \add أَمْ\add* إِحْصَارْ يُووَابْ ثَانْذِينْثْ، إِمْسَارْ نتَّا إِسّْبدّْ ؤُرِييَا غَارْ مَانِي نتَّا إِسّنْ أَقَا ذِينِّي بدّنْ يرْيَازنْ إِمحْضنْ أَطَّاسْ.  
\v 17 \add خنِّي\add* إِ د-فّْغنْ يرْيَازنْ زِي ثنْذِينْثْ، مّنْغنْ أَكْ-ذ يُووَابْ. وْضَانْ \add يرْيَازنْ\add* زِي ڒْڭنْسْ، زڭْ إِمْسخَّارنْ ن ذَاوُوذْ، ؤُڒَا ذ أَحِيتِّي ؤُرِييَا إِمُّوثْ.  
\v 18 يُووَابْ إِسّكّْ \add إِجّْ ن ؤُمْسخَّارْ\add* ؤُشَا إِحَاجَا إِ ذَاوُوذْ خْ مَامّشْ إِڭُّورْ ؤُمنْغِي.  
\v 19 نتَّا يُومُورْ إِ ؤُمْسخَّارْ، إِنَّا: ”مَاڒَا شكْ ثْكمّْڒذْ ڒخْبَارْ نّشْ خْ مَامّشْ إِڭُّورْ مَارَّا ؤُمنْغِي،  
\v 20 ؤُشَا إِمْسَارْ أَذْ إِكَّارْ وسْعَارْ ن ؤُجدْجِيذْ، أَذْ أَشْ يِينِي: ”مَايمِّي ثُوذْسمْ ثَانْذِينْثْ ذڭْ ؤُمنْغِي؟ مَا وَارْ ثسِّينمْ كنِّيوْ، أَقَا نِيثْنِي أَذْ وْثِينْ كنِّيوْ زِي ڒْحِيضْ؟  
\v 21 مَانْ ونْ إِنْغِينْ أَبِيمَالِيكْ، مِّيسْ ن يَارُوبُّوشَاثْ؟ مَا وَارْ إِدْجِي ذ إِشْثْ ن ثمْغَارْثْ ثنْضَارذْ خَاسْ ثَاسِيرْثْ يُوعْڒَانْ ن ثْسِيرْثْ زِي ڒْحِيضْ، أَڒَامِي نتَّا إِمُّوثْ ذِي ثَابَاصْ؟ مَايمِّي ثُويُورمْ ثُوذْسمْ أَمُّو ڒْحِيضْ؟‘، خنِّي شكْ أَذْ ثِينِيذْ: ’ؤُڒَا ذ أَمْسخَّارْ نّشْ، أَحِيتِّي ؤُرِييَا، إِتّْوَانغْ.‘ “ \x ◘ \xo 11:‏21 \xt ڒقض. 9‏:‏52، 53\x*   
\m
\v 22 أَرقَّاسْ يُويُورْ، يُوسَا-د غَارْ ذَاوُوذْ ؤُشَا إِحَاجَا أَسْ مَارَّا خْ مِينْ خفْ ث إِسّكّْ يُووَابْ.  
\v 23 أَرقَّاسْ إِنَّا إِ ذَاوُوذْ: ”إِرْيَازنْ ثُوغَا جهْذنْ خَانغْ ؤُ نِيثْنِي ثُوغَا فّْغنْ-د غَارْنغْ أَڒْ إِيَّارْ، مَاشَا نشِّينْ نحْصَارْ إِ-ثنْ أَڒْ ثَاوَّارْثْ \add ن ثنْذِينْثْ\add*.  
\v 24 \add خنِّي\add* وْثِينْ إِنِّي إِتّْحَاكَانْ \add س ڒْقوْسْ\add* زِي ڒْحِيضْ خْ إِمْسخَّارنْ نّشْ، \add أَڒَامِي\add* مُّوثنْ إِمْسخَّارنْ ن ؤُجدْجِيذْ. ؤُڒَا ذ أَمْسخَّارْ نّشْ، أَحِيتِّي ؤُرِييَا، إِمُّوثْ.“  
\v 25 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ ؤُرقَّاسْ: ”أَمُّو إِ غَا ثِينِيذْ إِ يُووَابْ: ’وَارْ تّجِّي أَذْ ثِيڒِي ثْمسْڒَاشْثْ-أَ ذ ثَاعفَّانْثْ ذِي ثِيطَّاوِينْ نّشْ، مَاغَارْ سِّيفْ أَذْ إِشّْ وَانِيثَا، ذَاوحْذَا ونّغْنِي. إِڒِي ذ أَرْيَازْ ذڭْ ؤُمنْغِي أَكْ-ذ ثنْذِينْثْ ؤُ هْذمْ إِ-ت!‘ أڭّْ ذَايسْ ثَارْيَاسْثْ \add س وَاوَاڒْ-أَ\add*.“  
\v 26 ثَامْغَارْثْ ن ؤُرِييَا ثسْڒَا بلِّي أَقَا أَرْيَازْ نّسْ ؤُرِييَا إِمُّوثْ ؤُ نتَّاثْ ثڭَّا خْ سِيذِي نّسْ أَشْضَانْ.  
\v 27 \add ؤُمِي\add* ثعْذُو \add ڒْْوقْثْ ن\add* وشْضَانْ إِسّكّْ ذَاوُوذْ أَذْ ت-إِ-د-أَوْينْ ذِي ثَادَّارْثْ نّسْ. نتَّاثْ ثذْوڒْ ذ ثَامْغَارْثْ نّسْ ؤُشَا ثُورُووْ أَسْ-د إِجّْ ن ؤُحنْجِيرْ. \add مَاشَا\add* مِينْ ثُوغَا إِڭَّا ذَاوُوذْ، ثُوغَا ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي.   
\b  
\b  
\m  
\c 12
\s1 أَوَاڒْ ن ؤُنَابِي نَاثَانْ  
\m
\v 1 إِسّكّْ سِيذِي نَاثَانْ غَارْ ذَاوُوذْ. \add ڒَْامِي\add* غَارسْ يُوذفْ نتَّا، إِنَّا أَسْ:  
\m ”ذڭْ إِشْثْ ن ثنْذِينْثْ ثُوغَا ذِينْ ثْنَاينْ ن يرْيَازنْ، إِجّنْ \add ثُوغَا\add* غَارسْ أَڭْڒَا، ونّغْنِي ذ أَمزْڒُوضْ.  
\v 2 بُو-وَاڭْڒَا غَارسْ أَبَارُّو ن وُودْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ.  
\v 3 أَمزْڒُوضْ مَاشَا وَارْ غَارسْ وَالُو مْغِيرْ إِشْثْ ن ثْحُوڒِيثْ ذ ثَامژْيَانْثْ إِ ثُوغَا د-إِسْغَا. نتَّا ثُوغَا إِسّشَّا إِ-ت ؤُ ثذْوڒْ ثْمقَّارْ غَارسْ ؤُ غَارْ إِحنْجِيرنْ نّسْ. ثشَّا زڭْ ؤُڒقُّوزْ ن وغْرُومْ نّسْ ؤُ ثسْوَا زڭْ ؤُفنْجَاڒْ نّسْ ؤُ ثطّصْ خْ إِفَادّنْ نّسْ. ثُوغَا-ت إِ نتَّا أَمْ يِيشْثْ ن يدْجِيسْ.  
\v 4 \add ؤُمِي\add* د-يُوسَا إِجّْ ن ؤُمْسبْرِيذْ غَارْ ورْيَازْ بُو-وَاڭْڒَا، يوْعَارْ خَاسْ حِيمَا أَذْ إِسّوْجذْ \add مَاشَّا\add* إِ ؤُمْسبْرِيذْ إِ غَارسْ د-يُوسِينْ زڭْ \add إِجّْ ن\add* وُودْجِي نّسْ نِيغْ زڭْ \add إِجّْ ن\add* إِفُونَاسنْ ذ ثْفُونَاسِينْ نّسْ. س ؤُينِّي إِكْسِي نتَّا ثَاحُوڒِيثْ ثَامژْيَانْثْ ن ورْيَازْ أَمزْڒُوضْ ؤُشَا إِسّوْجذْ إِ-ت إِ ورْيَازْ نِّي ثُوغَا غَارسْ د-يُوسِينْ.“   
\m
\v 5 يَارْغَا ؤُخيّقْ ن ذَاوُوذْ أَطَّاسْ خْ ورْيَازْ نِّي، إِنَّا إِ نَاثَانْ: ”\add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي، أَرْيَازْ إِ إِڭِّينْ أَيَا، ثكَّارْ أَسْ-د ڒْموْثْ،  
\v 6 ؤُشَا ثَاحُوڒِيثْ ثَامژْيَانْثْ أَذْ ت إِخْڒفْ أَربْعَا ن ثْسقَّارْ، مِينْزِي نتَّا إِڭَّا أَيَا، وَارْ \add ذَايسْ\add* يَارْحِيمْ.“ \x ◘ \xo 12:‏6 \xt ؤُف. 22‏:‏1\x*   
\m
\v 7 \add خنِّي\add* إِنَّا نَاثَانْ إِ ذَاوُوذْ: ”شكْ \add سِيمَانْثْ نّشْ\add* ذ أَرْيَازْ \add نِّي\add*. أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: نشّْ ذهْنغْ شكْ ذ أَجدْجِيذْ خْ إِسْرَائِيل ؤُ نشّْ سّْنجْمغْ شكْ زڭْ ؤُفُوسْ ن شَاوُولْ. \x ◘ \xo 12:‏7 \xt 1 صم. 16‏:‏13\x*  
\v 8 نشّْ وْشِيغْ أَشْ ثَادَّارْثْ ن سِيذِي نّشْ ذ ثمْغَارِينْ ن سِيذِي نّشْ خْ إِفَادّنْ نّشْ ؤُ نشّْ وْشِيغْ أَشْ ثَادَّارْثْ ن إِسْرَائِيل ذ يَاهُوذَا. مَاڒَا أَيَا ذْرُوسْ، إِڒِي أَذْ أَرْنِيغْ وَا نِيغْ ثَا إِ شكْ.  
\v 9 مَايمِّي ثسّحْقَارذْ أَوَاڒْ ن سِيذِي ؤُ ثڭِّيذْ مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ نّسْ؟ شكْ ثنْغِيذْ أَحِيتِّي ؤُرِييَا س سِّيفْ ؤُ ثكْسِيذْ ثَامْغَارْثْ نّسْ، ثڭِّيذْ ت ذ ثَامْغَارْثْ إِ يِيخفْ نّشْ ؤُشَا ثنْغِيذْ أَرْيَازْ نّسْ س سِّيفْ ن أَيْثْ ن عَامُّونْ.  
\v 10 \add خنِّي\add* ڒخُّو، سِّيفْ وَارْ إِتّْحيِّيذْ إِ ڒبْذَا خْ ثَادَّارْثْ نّشْ، مَاغَارْ شكْ ثسّحْقَارذْ أَيِي ؤُ ثكْسِيذْ ثَامْغَارْثْ ن ؤُحِيتِّي ؤُرِييَا، حِيمَا أَذْ ثذْوڒْ ذ ثَامْغَارْثْ نّشْ.  
\v 11 أَمُّو إِ إِقَّارْ سِيذِي: خْژَارْ، نشّْ أَذْ خَاكْ سّكَّارغْ ثُوعفّْنَا زِي ثَادَّارْثْ نّشْ ؤُ نشّْ أَذْ أَشْ كّْسغْ ثِيمْغَارِينْ نّشْ زَّاثْ إِ ثِيطَّاوِينْ نّشْ، أَذْ ثنْثْ وْشغْ إِ جَّارْ نّشْ ؤُ نتَّا أَذْ إِطّصْ أَكْ-ذ ثمْغَارِينْ نّشْ غَارْ ثْفُوشْثْ ذڭْ ؤُجنَّا. \x ◘ \xo 12:‏11 \xt أَعَوذ. 28‏:‏30؛ 2 صم. 16‏:‏22\x*  
\v 12 مَاغَارْ شكْ ثڭِّيذْ ت س ثْنُوفّْرَا، مَاشَا نشّْ أَذْ ڭّغْ أَيَا زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا إِسْرَائِيل ؤُ غَارْ \add ثِيفَاوْثْ\add* ن ثْفُوشْثْ.“  
\v 13 \add خَاسْ\add* ؤُشَا إِنَّا ذَاوُوذْ إِ نَاثَانْ: ”نشّْ خْضِيغْ أَكْ-ذ سِيذِي!“ إِنَّا نَاثَانْ إِ ذَاوُوذْ: ”سِيذِي إِغْفَارْ دّنْبْ نّشْ، وَارْ ثْمتِّيذْ شَا.  
\v 14 مَاشَا، ؤُمِي شكْ ثَارِّيذْ ڒْعذْيَانْ ن سِيذِي أَذْ شقّْفنْ أَطَّاسْ، س ثِيذتّْ إِتّْخصَّا أَذْ إِمّثْ مِّيشْ إِ ذ أَشْ د-إِتّْوَارْونْ.“  
\v 15 خنِّي يُويُورْ نَاثَانْ غَارْ ثَادَّارْثْ نّسْ. سِيذِي إِڒْقفْ أَحنْجِيرْ إِ ثُوغَا د-ثُورُووْ ثمْغَارْثْ ن ؤُرِييَا إِ ذَاوُوذْ ؤُشَا إِذْوڒْ إِحْڒشْ أَطَّاسْ.   
\b  
\m  
\s1 ثَاژَادْجِيثْ ن ذَاوُوذْ إِ مِّيسْ  
\m
\v 16 ذَاوُوذْ يَارْزُو أَربِّي ذِي طّْوعْ ن ؤُحنْجِيرْ. إِژُومّْ ذَاوُوذْ بْڒَا قطُّو ؤُ نتَّا يُوذفْ، إِزّڒْ خْ ثمُّورْثْ ذِي دْجِيڒثْ.  
\v 17 إِمْغَارنْ ن ثَادَّارْثْ نّسْ ؤُسِينْ-د، بدّنْ غَارسْ حِيمَا أَذْ ث أَرّنْ أَذْ د-إِكَّارْ زِي ثمُّورْثْ. نتَّا مَاشَا وَارْ إِخْسْ ؤُ وَارْ إِشِّي أَغْرُومْ أَكِيذْسنْ.   
\m
\v 18 ذڭْ وَاسّْ وِيسّْ سبْعَا إِمْسَارْ أَقَا أَحنْجِيرْ إِمُّوثْ. إِمْسخَّارنْ ن ذَاوُوذْ ڭّْوذنْ أَذْ أَسْ إِنِينْ، أَقَا أَحنْجِيرْ إِمُّوثْ، مَاغَارْ نِيثْنِي نَّانْ: ”خْزَارْ، ؤُمِي أَحنْجِيرْ ثُوغَا إِدَّارْ عَاذْ، نسِّيوڒْ أَكِيذسْ، مَاشَا وَارْ غَارْنغْ إِسْڒِي شَا. مَامّشْ إِ نْزمَّارْ \add ڒخُّو\add* أَذْ أَسْ نِينِي: ’أَحنْجِيرْ إِمُّوثْ‘؟ نتَّا أَذْ إِڭّْ ثُوعفّْنَا \add ذڭْ إِخفْ نّسْ\add*.“  
\v 19 ذَاوُوذْ إِژْرَا أَقَا إِمْسخَّارنْ نّسْ سَّاوَاڒنْ س ثْحسّشْثْ جَارْ أَسنْ ؤُ ذَاوُوذْ يُوشَا إِلَّا أَحنْجِيرْ ثُوغَا إِمُّوثْ. نتَّا إِنَّا إِ إِمْسخَّارنْ نّسْ: ”مَا إِمُّوثْ ؤُحنْجِيرْ؟“ نِيثْنِي نَّانْ أَسْ: ”أَقَا إِمُّوثْ!“  
\v 20 \add خنِّي\add* إِكَّارْ ذَاوُوذْ زِي ثمُّورْثْ، إِسِّيرْذْ، إِذْهنْ إِخفْ نّسْ، إِبدّڒْ أَرُّوضْ نّسْ. نتَّا يُوذفْ غَارْ ثَادَّارْثْ ن سِيذِي، إِسْجذْ. \add ؤُمِي خنِّي\add* يَارڭّْوحْ غَارْ ثَادَّارْثْ، إِتَّارْ أَغْرُومْ ؤُ نِيثْنِي سَّارْسنْ أَغْرُومْ زَّاثسْ ؤُشَا إِشَّا.  
\v 21 نَّانْ أَسْ إِمْسخَّارنْ نّسْ: ”مِينْ ثڭِّيذْ شكْ ڒخُّو؟ ؤُمِي أَحنْجِيرْ عَاذْ إِدَّارْ، ثْژُومّذْ ذِي طّْوعْ نّسْ ؤُ ثْرُوذْ. \add مَاشَا\add* أَوَارْنِي ڒَامِي إِمُّوثْ ؤُحنْجِيرْ، ثكَّارذْ ؤُشَا ثشِّيذْ أَغْرُومْ.“  
\v 22 نتَّا يَارَّا-د خَاسنْ: ”ؤُمِي أَحنْجِيرْ عَاذْ إِدَّارْ، ژُومّغْ ؤُ رُوغْ، مَاغَارْ نشّْ نِّيغْ: ’وِي إِسّْننْ، سِيذِي أَذْ خَافِي إِحِينّْ ؤُ أَحنْجِيرْ أَذْ إِدَّارْ.‘  
\v 23 ڒخُّو مَاشَا إِمُّوثْ. مَايمِّي غَا ژُومّغْ عَاذْ؟ مَا زمَّارغْ أَذْ ث-إِ-د-أَرّغْ؟ نشّْ أَذْ غَارسْ رَاحغْ إِشْثْ ن ثْوَاڒَا، مَاشَا نتَّا وَارْ د غَارِي إِتّْعِيقِّيبْ.“   
\m
\v 24 ذَاوُوذْ إِسّْفوّجْ ثَامْغَارْثْ نّسْ بَاثْ-شَابَاعْ ؤُ نتَّا يُوذفْ خَاسْ، إِطّصْ أَكِيذسْ. نتَّاثْ ثُورُووْ-د إِجّْ ن ؤُحنْجِيرْ، إِڭَّا أَسْ سُولِيمَانْ. سِيذِي ثُوغَا إِتّخْسْ إِ-ث \x ◘ \xo 12:‏24 \xt 1 إِم. 22‏:‏9؛ مت. 1‏:‏6\x*  
\v 25 ؤُشَا إِڭَّا أَسْ يَاذِيذْ-يَاهْ س ؤُفُوسْ ن ؤُنَابِي نَاثَانْ، أَمْ مَامّشْ ثُوغَا إِخْسْ سِيذِي.   
\b  
\m  
\s1 أَغلّبْ خْ ثنْذِينْثْ ن رَابَّا ذِي عَامُّونْ  
\m
\v 26 يُووَابْ إِمّْنغْ أَكْ-ذ رَابَّا ن أَيْثْ ن عَامُّونْ ؤُ نتَّا إِحوّسْ ثَانْذِينْثْ ن ؤُجدْجِيذْ. \x ◘ \xo 12:‏26 \xt [1 إِم. 20‏:‏1‏-‏3]\x*  
\v 27 \add خَاسْ ؤُشَا\add* إِسّكّْ يُووَابْ إِرقَّاسنْ غَارْ ذَاوُوذْ، إِنَّا: ”نشّْ مّنْغغْ أَكْ-ذ رَابَّا طّْفغْ ؤُڒَا ذ ثَانْذِينْثْ ن وَامَانْ.  
\v 28 سْمُونْ مِينْ إِقِّيمنْ ن ڒْعسْكَارْ ؤُشَا نّضْ إِ ثنْذِينْثْ، طّفْ إِ-ت، نِيغْ أَذْ طّْفغْ نشّْ ثَانْذِينْثْ ؤُشَا أَذْ خَاسْ ڒَاغَانْ س يِيسمْ إِنُو.“   
\m
\v 29 \add خنِّي\add* إِسّْمُونْ ذَاوُوذْ مَارَّا ڒْعسْكَارْ، إِفّغْ غَارْ رَابَّا، إِمّْنغْ أَكِيذسْ ؤُشَا إِطّفْ إِ-ت.  
\v 30 إِكّسْ تَّاجْ خْ ؤُزدْجِيفْ ن ؤُجدْجِيذْ، ونِّي س يِيجّْ ن ڒوْزنْ ن إِشْثْ ن ثَالِينْثْ ن وُورغْ ؤُ خَاسْ ثَايَاقُوثِينْ إِغْڒَانْ، ؤُشَا ثُوسَا-د \add تَّاجْ\add* خْ ؤُزدْجِيفْ ن ذَاوُوذْ. نتَّا يِيوِي \add عَاوذْ\add* إِشْثْ ن ثْكشَّاضْثْ ذ ثَامقّْرَانْثْ أَطَّاسْ زِي ثنْذِينْثْ. \x ◘ \xo 12:‏30 \xt 1 إِم. 20‏:‏2\x*  
\v 31 ڒْڭنْسْ نِّي ذَايسْ \add إِدْجَانْ\add* إِسُّوفّغْ إِ-ث ؤُ إِحْجمْ خَاسنْ س ڒْمنْشَارَاثْ ذ إِيَاڒْزِيمنْ ن وُوزَّاڒْ ذ شّْوَاقَارْ ن وُوزَّاڒْ ؤُشَا نتَّا إِجَّا إِ-ثنْ أَذْ عْذُونْ س ڒْكُوشَّاثْ ن لَّاجُورْ. أَمُّو إِ إِڭَّا نتَّا أَكْ-ذ مَارَّا ثِيندَّامْ ن أَيْثْ ن عَامُّونْ. \add خنِّي\add* إِعْقبْ ذَاوُوذْ ذ مَارَّا ڒْڭنْسْ غَارْ ؤُرْشَالِيمْ. \x ◘ \xo 12:‏31 \xt 1 إِم. 20‏:‏3\x*   
\b  
\b  
\m  
\c 13
\s1 أَمْنُونْ ذ ثَامَارْ  
\m
\v 1 إِمْسَارْ أَوَارْنِي أَيَا، أَقَا أَبْشَالُومْ، مِّيسْ ن ذَاوُوذْ، ثُوغَا غَارسْ إِشْثْ ن ؤُتْشْمَاسْ ذَايسْ أَژْرِي، قَّارنْ أَسْ ثَامَارْ، ؤُشَا أَمْنُونْ، مِّيسْ ن ذَاوُوذْ، إِعْشقْ إِ-ت.  
\v 2 أَمْنُونْ ثُوغَا إِشْضنْ أَطَّاسْ أَڒَامِي إِهْڒشْ خْ سِّيبّثْ ن ؤُتْشْمَاسْ ثَامَارْ، مَاغَارْ نتَّاثْ ثُوغَا ذ ثَاعْزَارشْثْ، ؤُشَا ثُوغَا وَارْ إِزمَّارْ ذِي ثِيطَّاوِينْ ن أَمْنُونْ أَذْ أَسْ إِڭّْ شَا.  
\v 3 أَمْنُونْ ثُوغَا غَارسْ إِجّْ ن ؤُمدُّوكّڒْ قَّارنْ أَسّْ يُونَاذَابْ، إِجّْ ن مِّيسْ ن شِيمْعَا، ؤُمَاسْ ن ذَاوُوذْ. يُونَاذَابْ ثُوغَا ذ إِجّْ ن ورْيَازْ ذ أَحْرَايْمِي أَطَّاسْ.  
\v 4 نتَّا إِنَّا أَسْ: ”مَايمِّي ثْشضْنذْ أَمُّو زِي ثُوفُّوثْ أَڒْ ثُوفُّوثْ، شكْ، مِّيسْ ن ؤُجدْجِيذْ؟ مَا وَارْ ثخْسذْ شكْ أَذْ أَيِي ث ثْعَاوْذذْ؟“ أَمْنُونْ يَارَّا-د خَاسْ: ”نشّْعشْقغْ ثَامَارْ، ؤُتْشْمَاسْ ن ؤُمَا أَبْشَالُومْ.“   
\m
\v 5 إِنَّا أَسْ يُونَاذَابْ: ”زّڒْ ذِي قَامَا ؤُ أڭّْ إِخفْ نّشْ ثْهڒْشذْ. مَاڒَا \add خنِّي\add* يُوسَا-د بَابَاشْ، حِيمَا أَذْ خَاكْ إِسِّيجّْ، إِنِي أَسْ: ’أجّْ ؤُتْشْمَا ثَامَارْ أَذْ غَارِي د-ثَاسْ مَاحنْذْ أَذْ أَيِي ثوْشْ مَاشَّا ؤُ أَذْ ثسّوْجذْ مَاشَّا زَّاثْ إِ ثِيطَّاوِينْ إِنُو، حِيمَا أَذْ ژَترْغْ، أَذْ شّغْ زڭْ ؤُفُوسْ نّسْ.‘ “  
\v 6 أَمْنُونْ إِزّڒْ ذِينْ، إِسّْنِيعْمِيڒْ إِهْڒشْ. ؤُمِي د-يُوسَا ؤُجدْجِيذْ، حِيمَا أَذْ خَاسْ إِسِّيجّْ، إِنَّا أَمْنُونْ إِ ؤُجدْجِيذْ: ”أجّْ أَذْ د-ثَاسْ ؤُتْشْمَا ثَامَارْ مَاحنْذْ نتَّاثْ أَذْ أَيِي ثسّوْجذْ ثْنَاينْ ن ثْغَارْيِيطَاثِينْ ؤُ نشّْ أَذْ ثنْثْ شّغْ زڭْ ؤُفُوسْ نّسْ.“  
\v 7 ذَاوُوذْ إِسّكّْ \add إِجّْ\add* غَارْ ثَامَارْ، ذِي ثَادَّارْثْ \add نّسْ\add*، حِيمَا أَذْ أَسْ إِنَّا: ”رُوحْ غَارْ ثَادَّارْثْ ن ؤُمَامْ أَمْنُونْ ؤُ سوْجذْ أَسْ مَاشَّا.“  
\v 8 ثَامَارْ ثُويُورْ غَارْ ثَادَّارْثْ ن ؤُمَاسْ أَمْنُونْ ونِّي ذِينْ إِزّْڒنْ ذِي قَامَا. نتَّاثْ ثكْسِي أَرشْثِي، ثڭّْوَا ث ؤُ ثسّوْجذْ ثِيغَارْيِيطَاثِينْ زَّاثْ إِ ثِيطَّاوِينْ نّسْ ؤُشَا ثڭّْوَا ثِيغَارْيِيطَاثِينْ.  
\v 9 نتَّاثْ ثكْسِي مَارْمِيثَا ثڭِّيذْ-إِ-ت زَّاثسْ، مَاشَا نتَّا يُوڭِي أَذْ إِشّْ. \add خنِّي\add* إِنَّا أَمْنُونْ: ”أجّْ أَذْ خَافِي فّْغنْ مَارَّا!“ ؤُ مَارَّا فّْغنْ خَاسْ.   
\m
\v 10 \add خنِّي\add* إِنَّا أَمْنُونْ إِ ثَامَارْ: ”أَوِي-د مَاشَّا ذڭْ وخَّامْ، حِيمَا أَذْ شّغْ زڭْ ؤُفُوسْ نّمْ.“ ؤُ ثَامَارْ ثكْسِي ثِيغَارْيِيطَاثِينْ إِ ثُوغَا ثڭَّا ؤُ ثِيوْيِي ثنْثْ إِ ؤُمَاسْ أَمْنُونْ ذڭْ وخَّامْ.  
\v 11 نتَّاثْ ثسِّيژّْوِيضْ \add إِ-ثنْثْ\add* \add س ؤُفُوسْ نّسْ\add* غَارسْ مَاحنْذْ أَذْ إِشّْ. نتَّا إِطّفْ إِ-ت، إِنَّا أَسْ: ”أَسْ-د، طّصْ غَارِي، ؤُتْشْمَا!“  
\v 12 \add مَاشَا\add* نتَّاثْ ثنَّا أَسْ: ”لَّ، أَ ؤُمَا، وَارْ ذ أَيِي سّخْسَارِي شَا، مَاغَارْ أَمُّو وَارْ إِتّْوَاڭّْ ذِي إِسْرَائِيل. وَارْ تّڭّْ شَا ڒفْضِيحثْ-أَ!  
\v 13 مَانِي غَا ؤُيُورغْ ذِي ڒفْضِيحثْ إِنُو؟ ؤُ شكْ، شكْ أَذْ ثِيڒِيذْ ذ إِجّنْ زڭْ إِبُوهَاڒِييّنْ ذِي إِسْرَائِيل. سِيوڒْ مَاشَا أَكْ-ذ ؤُجدْجِيذْ، مِينْزِي نتَّا وَارْ ذ أَيِي إِتّطّفْ خَاكْ.“  
\v 14 \add مَاشَا\add* أَمْنُونْ وَارْ إِخْسْ شَا أَذْ غَارسْ إِسڒْ، مَاشَا إِجْهذْ خَاسْ ؤُشَا إِسّْبهْذڒْ إِ-ت، إِطّصْ أَكِيذسْ.   
\m
\v 15 \add ذَاوحْذَا نّسْ\add* إِعِيفّْ إِ-ت س يِيجّْ ن ؤُعِيفِّي ذ أَمقّْرَانْ أَطَّاسْ، مِينْزِي أَعِيفِّي إِ زِي ت إِعِيفّْ، ثُوغَا-ث ذ ثَامقّْرَانْثْ خْ ثَايْرِي إِ زِي ثُوغَا ت إِعْشقْ. أَمْنُونْ إِنَّا أَسْ: ”كَّارْ، أَڭّْوجْ!“  
\v 16 \add خنِّي\add* إِنَّا أَسْ: ”وَارْ ذِينْ ڒسْبَابْ مَاحنْذْ أَذْ أَيِي ثسّكّذْ. ثُوعفّْنَا-يَا أَذْ ثِيڒِي عَاذْ \add ذ ڒْعِيبْ\add* ذ أَمقّْرَانْ خْ مِينْ ذ أَيِي ثڭِّيذْ.“ نتَّا مَاشَا وَارْ إِخْسْ أَذْ غَارسْ إِسڒْ.  
\v 17 إِڒَاغَا خْ ؤُمْسخَّارْ نّسْ ونِّي إِ خَاسْ إِتّْسخَّارنْ، إِنَّا أَسْ: ”سكّْ ثَا خَافِي غَارْ بَارَّا ؤُ بلّعْ ثَاوَّارْثْ أَوَارْنِي أَسْ!“   
\m
\v 18 نتَّاثْ ثُوغَا خَاسْ أَرُّوضْ \add س إِفَاسّنْ ذ إِزِيرَارنْ\add*، مَاغَارْ أَمُّو إِ يَارْضنْثْ يسِّيسْ ن ؤُجدْجِيذْ مِينْ غَا كّنْثْ ذ ثِيعْزَارِييِّينْ. أَمْسخَّارْ نّسْ يِيوْيِي ت غَارْ بَارَّا، إِبلّعْ ثَاوَّارْثْ أَوَارْنِي أَسْ.  
\v 19 ثَامَارْ ثْزُوزَّارْ إِغّضْ خْ ؤُزدْجِيفْ نّسْ ؤُ ثْشَارّڭْ أَرُّوضْ \add س إِفَاسّنْ ذ إِزِيرَارنْ\add* إِ ثْيَارْضْ، ثسَّارْسْ إِفَاسّنْ نّسْ خْ ؤُزدْجِيفْ نّسْ، \add أَمْ\add* ثُويُورْ ثسْغُويُّو.   
\m
\v 20 ؤُمَاسْ أَبْشَالُومْ إِسّقْسَا ت: ”مَا ثُوغَا ؤُمَامْ أَمْنُونْ أَكِيذمْ؟ ڒخُّو \add خنِّي\add*، ؤُتْشْمَا، سُوسمْ، نتَّا ذ ؤُمَامْ. وَارْ ذ أَمْ إِتّقّسْ بُو ڒْحَاڒْ!“ ؤُ ثَامَارْ ثقِّيمْ وحّْذسْ ذِي ثَادَّارْثْ ن ؤُمَاسْ أَبْشَالُومْ.  
\v 21 \add ڒَْامِي\add* إِسْڒَا ؤُجدْجِيذْ ذَاوُوذْ خْ مَارَّا ثِيمسْڒَايِينْ-أَ، إِذْوڒْ إِخيّقْ أَطَّاسْ.  
\v 22 أَبْشَالُومْ وَارْ إِسِّيوڒْ عَاذْ أَكْ-ذ أَمْنُونْ، وَارْ إِدْجِي ذِي ثْشُونِي ؤُڒَا ذِي ثُوعفّْنَا، مَاغَارْ أَبْشَالُومْ إِعِيفّْ أَمْنُونْ مِينْزِي وَانِيثَا ثُوغَا إِسّْبهْذڒْ ؤُتْشْمَاسْ ثَامَارْ.   
\b  
\m  
\s1 إِتّْوَانغْ أَمْنُونْ زِي أَبْشَالُومْ  
\m
\v 23 أَوَارْنِي ڒَامِي \add عْذُونْ\add* ثْنَاينْ ن إِسڭّْوُوسَا مُوننْ، إِمْسَارْ، أَقَا أَبْشَالُومْ \add ثُوغَا غَارسْ\add* إِروَّانْ ذِي بَاعْلْ-حَاصُورْ نِّي \add إِدْجَانْ\add* غَارْ إِفْرَايِيمْ ؤُ أَبْشَالُومْ إِعَارْضْ مَارَّا أَرَّاوْ ن ؤُجدْجِيذْ.  
\v 24 يُويُورْ أَبْشَالُومْ غَارْ ؤُجدْجِيذْ، إِنَّا: ”خْزَارْ، أَمْسخَّارْ نّشْ غَارسْ إِروَّانْ! أجّْ ؤُجدْجِيذْ س مَارَّا إِمْسخَّارنْ نّسْ أَذْ ؤُيُورنْ أَكْ-ذ ؤُمْسخَّارْ نّشْ.“  
\v 25 \add مَاشَا\add* أَجدْجِيذْ يَارَّا-د خْ أَبْشَالُومْ: ”لَّ، \add أَ\add* مِّي، أجّْ أَنغْ وَارْ د-نتِّيسْ مَارَّا، حِيمَا وَارْ خَاكْ نتّڭّْ دّْقڒْ!“ نتَّا إِزيَّارْ خَاسْ، \add مَاشَا\add* نتَّا وَارْ إِخْسْ أَكِيذسْ يُويُورْ، \add مَاشَا وَاخَّا أَمنِّي\add* إِبَاركْ إِ-ث.  
\v 26 \add خنِّي\add* إِنَّا أَبْشَالُومْ: ”مَاڒَا لَّا، أجّْ ؤُمَا أَمْنُونْ أَذْ كِيذْنغْ يُويُورْ!“ أَجدْجِيذْ إِنَّا أَسْ: ”مَايمِّي أَكِيذكْ إِ غَا يُويُورْ؟“  
\v 27 \add ؤُمِي\add* خَاسْ إِزيَّارْ أَبْشَالُومْ، إِجَّا نتَّا أَذْ ؤُيُورنْ أَمْنُونْ ذ مَارَّا أَرَّاوْ ن ؤُجدْجِيذْ أَكِيذسْ.   
\m
\v 28 أَبْشَالُومْ يُومُورْ إِمْسخَّارنْ نّسْ، إِنَّا: ”حْضَامْ، خْمِي غَا يَارشّقْ ؤُڒْ ن أَمْنُونْ زِي بِينُو ؤُ نشّْ أَذْ أَومْ إِنِيغْ: ’وْثمْ أَمْنُونْ!‘، خنِّي إِتّْخصَّا كنِّيوْ أَذْ ث نْغمْ. وَارْ تّڭّْوذمْ شَا! مَا نشّْ سِيمَانْثْ إِنُو وَارْ ث ؤُمُورغْ إِ كنِّيوْ؟ إِڒِيمْ ذ إِرْيَازنْ ؤُ إِڒِيمْ ذ أَيْثْ ن بُو-ثرْيَاسْثْ.“  
\v 29 إِمْسخَّارنْ ن أَبْشَالُومْ ڭِّينْ أَكْ-ذ أَمْنُونْ أَمْ مَامّشْ إِ ثُوغَا خَاسنْ إِڭَّا أَبْشَالُومْ. \add خنِّي\add* كَّارنْ مَارَّا إِحنْجِيرنْ ن ؤُجدْجِيذْ، نْيِينْ، كُوڒْ أَرْيَازْ خْ ؤُسَارْذُونْ نّسْ، ؤُشَا أَروْڒنْ.   
\m
\v 30 ؤُمِي نِيثْنِي ثُوغَا أَثنْ عَاذْ ذڭْ وبْرِيذْ، إِمْسَارْ، أَقَا ڒخْبَارْ يِيوضْ غَارْ ذَاوُوذْ، نَّانْ: ”أَبْشَالُومْ إِنْغَا مَارَّا إِحنْجِيرنْ ن ذَاوُوذْ، وَارْ إِقِّيمْ ؤُڒَا ذ إِجّنْ زَّايْسنْ.“  
\v 31 ؤُشَا إِكَّارْ ذَاوُوذْ، إِشَارّڭْ أَرُّوضْ نّسْ، إِزّڒْ خْ ثمُّورْثْ. مَارَّا إِمْسخَّارنْ نّسْ بدّنْ \add ذِينْ غَارسْ\add* س وَارُّوضْ نْسنْ إِشَارّْڭنْ. \x ◘ \xo 13:‏31 \xt 2 صم. 1‏:‏11\x*  
\v 32 \add مَاشَا\add* يُونَاذَابْ، مِّيسْ ن شِيمْعَا، ؤُمَاسْ ن ذَاوُوذْ، إِسِّيوڒْ، إِنَّا: ”إِتّْخصَّا إِ سِيذِي إِنُو وَارْ إِتّْغِيڒْ \add ذڭْ إِخفْ نّسْ\add*، أَقَا نْغِينْ مَارَّا إِحُوذْرِييّنْ، إِحنْجِيرنْ ن ؤُجدْجِيذْ. أَمْنُونْ وَاهَا إِ إِتّْوَانْغنْ، مَاغَارْ أَبْشَالُومْ إِڭَّا أَيَا ذِي ڒْبَاڒْ نّسْ زڭْ وَاسّْ إِ ذِي إِسّْخَارّڭْ وَانِيثَا ؤُتْشْمَاسْ ثَامَارْ.  
\v 33 أجّْ سِيذِي إِنُو، أَجدْجِيذْ، وَارْ ذ أَسْ إِتّْغِيمِي ڒْحَاڒْ ڒخُّو، أَذْ يِينِي: ’مَارَّا أَرَّاوْ ن ؤُجدْجِيذْ تّْوَانْغنْ!‘، مَاغَارْ أَمْنُونْ وَاهَا إِمُّوثْ.“   
\m
\v 34 أَبْشَالُومْ ثُوغَا يَارْوڒْ. ؤُشَا أَمْسخَّارْ ونِّي إِتّْعسَّانْ، إِسّْڭعّذْ ثَامُوغْڒِي نّسْ، ؤُ خْزَارْ، أَقَا إِوْذَانْ أَطَّاسْ ؤُسِينْ-د زڭْ وبْرِيذْ \add إِ إِدْجَانْ\add* أَوَارْنِي أَسْ، زڭْ ؤُغزْذِيسْ ن وذْرَارْ.  
\v 35 \add خنِّي\add* إِنَّا يُونَاذَابْ إِ ؤُجدْجِيذْ: ”خْزَارْ، أَرَّاوْ ن ؤُجدْجِيذْ إِ د-تَّاسنْ. أَقَا إِمْسَارْ أَمْ مَامّشْ إِنَّا ؤُمْسخَّارْ نّشْ.“  
\v 36 ؤُشَا إِمْسَارْ ؤُمِي إِكمّڒْ أَوَاڒْ نّسْ، أَقَا خضْرنْ-د أَرَّاوْ ن ؤُجدْجِيذْ. نِيثْنِي سّْڭعّْذنْ ثْمِيجَّا نْسنْ، رُونْ. ؤُڒَا ذ أَجدْجِيذْ ذ مَارَّا إِمْسخَّارنْ نّسْ كْسِينْ ذڭْ إِمطَّاونْ.   
\m
\v 37 أَبْشَالُومْ ثُوغَا يَارْوڒْ، يُويُورْ غَارْ ثَالْمَايْ، مِّيسْ ن عَامِّيخُورْ، أَجدْجِيذْ ن جَاشُورْ. ذَاوُوذْ إِشْضنْ خْ مِّيسْ مَارَّا ؤُسَّانْ.  
\v 38 أَبْشَالُومْ ثُوغَا يَارْوڒْ، يُويُورْ غَارْ جَاشُورْ. نتَّا إِقِّيمْ ذِينِّي ثْڒَاثَا ن إِسڭّْوُوسَا.  
\v 39 أَيَا إِسّْبدّْ أَجدْجِيذْ ذَاوُوذْ مَاحنْذْ أَذْ إِفّغْ \add إِ ؤُمنْغِي\add* أَكْ-ذ أَبْشَالُومْ، مَاغَارْ نتَّا إِسّْعزَّا إِخفْ نّسْ زِي جِّيهثْ ن ڒْموْثْ ن أَمْنُونْ، مَاغَارْ وَانِيثَا أَقَا إِمُّوثْ.   
\b  
\b  
\m  
\c 14
\s1 أَعْقبْ ن أَبْشَالُومْ غَارْ ؤُرْشَالِيمْ  
\m
\v 1 ؤُمِي يُووَابْ، مِّيسْ ن صَارُويَا، إِحكَّارْ أَقَا ؤُڒْ ن ؤُجدْجِيذْ ثُوغَا ضِيدّْ إِ أَبْشَالُومْ،  
\v 2 إِسّكّْ يُووَابْ \add إِجّْ ن ؤُرقَّاسْ\add* غَارْ ثَاقُوعَا ؤُشَا إِجَّا أَذْ سّنِّي د-أَوْينْ إِشْثْ ن ثمْغَارْثْ ذ ثَامِيغِيسْثْ، إِنَّا أَسْ: ”تّْزَاوْڭغْ، أڭّْ أَخْمِي شمْ ثْشضْنذْ، يَارْضْ أَرُّوضْ ن وشْضَانْ، وَارْ ذهّنْ إِخفْ نّمْ س زّشْثْ! سْنعْمِيڒْ أَمْ يِيشْثْ ن ثمْغَارْثْ نِّي إِشضْننْ خْ إِجّْ ن ؤُمتِّينْ أَطَّاسْ ن وُوسَّانْ. \f ◼ \fr 14:‏2 \ft \+bd ’ثَاقُوعَا‘\+bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَمْشَانْ مَانِي إِزمَّارْ أَذْ تّْوَاثْونْ إِقِيضَانْ‘. ثُوغَا ثَاقُوعَا ذ إِشْثْ ن ثنْذِينْثْ غَارْ طَّارْفْ ن لْجَانُوبْ ن بَايْثْ-لَاحْمْ، عْڒَاينْ 8 كْمْ.\f*  
\v 3 أَذفْ غَارْ ؤُجدْجِيذْ ؤُ سِيوڒْ أَكِيذسْ أَوَاڒنْ-أَ.“ ؤُشَا يُووَابْ إِنَّا أَسْ مِينْ غَا ثِينِي.   
\m
\v 4 ثَامْغَارْثْ زِي ثَاقُّوعَا ثنَّا إِ ؤُجدْجِيذْ، أَمْ ثوْضَا س ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ، ثُوضَارْ \add أَسْ\add*: ”سنْجمْ \add أَيِي\add*، \add أَ\add* أَجدْجِيذْ!“  
\v 5 إِنَّا أَسْ ؤُجدْجِيذْ: ”مِينْ شمْ يُوغِينْ؟“ نتَّاثْ ثنَّا أَسْ: ”س ثِيذتّْ نشّْ ذ ثَاجَّاتْشْ، أَرْيَازْ إِنُو إِمُّوثْ.  
\v 6 ثَايَّا نّشْ ثُوغَا غَارسْ ثْنَاينْ ن إِحنْجِيرنْ ؤُ نِيثْنِي س ثْنَاينْ إِذْسنْ مّنْغنْ ذڭْ إِيَّارْ. ثُوغَا وَارْ ذِينْ ؤُڒَا ذ إِجّْ أَذْ ثنْ إِبْضَا. \add خنِّي\add* إِوْثَا إِجّنْ ونّغْنِي ؤُشَا إِنْغَا إِ-ث.  
\v 7 ؤُ خْزَارْ، مَارَّا ڒَادْجْ إِغوّغْ خْ ثَايَّا نّشْ، نَّانْ: ’أَوِي-د ونِّي إِنْغِينْ ؤُمَاسْ ذَا، مَاحنْذْ أَذْ ث ننّغْ ذِي سِّيبّثْ ن ڒعْمَارْ ن ؤُمَاسْ ونِّي ث إِنْغِينْ ؤُ \add أَمُّو إِ\add* غَا نقْضَا ؤُڒَا خْ ووْرِيثْ.‘ أَمُّو إِ خْسنْ نِيثْنِي أَذْ سّْخسْينْ \add أَينِّي ن\add* ڒفْحمْ إِتّحْذُوذُوقنْ إِ ذ أَيِي إِقِّيمنْ أَڒَامِي وَارْ إِتّْغِيمِي إِ ورْيَازْ إِنُو إِسمْ ذِي ثمُّورْثْ قَاعْ.“   
\m
\v 8 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ إِ ثمْغَارْثْ: ”ؤُيُورْ غَارْ ثَادَّارْثْ! نشّْ أَذْ سُّوفّْغغْ ڒُومُورَاثْ خَامْ.“  
\v 9 ثَامْغَارْثْ زِي ثَاقُّوعَا ثنَّا إِ ؤُجدْجِيذْ: ”سِيذِي إِنُو أَجدْجِيذْ، أجّْ أَذْ ثِيڒِي ڒْمُوعْصِييّثْ خَافِي ؤُ خْ ثَادَّارْثْ ن بَابَا. أَجدْجِيذْ ذ ڒْعَارْشْ نّسْ ذ إِمزْذَاڭنْ.“  
\v 10 إِنَّا ؤُجدْجِيذْ: ”أَوِي أَيِي-د غَارِي ونِّي غَارْ إِدْجَا شَا خَامْ، أَڒَامِي نتَّا وَارْ إِتّْغِيمِي عَاذْ أَذْ شمْ إِصدّعْ.“  
\v 11 نتَّاثْ ثنَّا: ”أجّْ أَجدْجِيذْ أَذْ إِخَارّصْ ذِي سِيذِي، أَربِّي نّشْ، حِيمَا ونِّي إِخْسنْ أَذْ إِخْڒفْ إِذَامّنْ وَارْ يَارنِّي عَاذْ ذِي أَرْژِييّثْ ؤُ وَارْ إِسُّوفُّوغْ مِّي غَارْ طَّارْفْ.“ \add خنِّي\add* إِنَّا نتَّا: ”\add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي، مَاڒَا ؤُڒَا ذ إِجّْ ن ؤُزطُّو ن ؤُشُوَّافْ \add ن ؤُزدْجِيفْ\add* ن مِّيمْ أَذْ إِوْضَا ذِي ثمُّورْثْ!“  
\v 12 \add خنِّي\add* ثنَّا ثمْغَارْثْ: ”تّْزَاوْڭغْ، أجّْ ثَايَّا نّشْ أَذْ ثِينِي \add عَاذْ\add* إِجّْ ن وَاوَاڒْ إِ سِيذِي إِنُو أَجدْجِيذْ.“ ؤُشَا نتَّا إِنَّا: ”سِيوڒْ.“  
\v 13 ثَامْغَارْثْ ثنَّا: ”مَايمِّي خنِّي ثنْوِيذْ شكْ س يِيخفْ نّكْ أَذْ ثڭّذْ أَمُّو أَكْ-ذ ڒْڭنْسْ ن أَربِّي؟ ؤُمِي إِنَّا ؤُجدْجِيذْ \add ڒخُّو\add* أَوَاڒْ-أَ، أَقَا نتَّا سِيمَانْثْ نّسْ أَمْ ونِّي ذِي إِدْجَا ڒْعِيبْ، مِينْزِي أَجدْجِيذْ وَارْ د-إِتَّارِّي \add غَارسْ\add* ونِّي ث إِنْضَارْ.  
\v 14 مَاغَارْ نشِّينْ \add مَارَّا\add* أَذْ نمّثْ، أَقَا نشِّينْ أَمْ وَامَانْ إِتّْوَافَارّْغنْ خْ ثمُّورْثْ، وَارْ نّْيَارْونْ. سِيذِي وَارْ إِتّكّسْ ڒعْمَارْ، \add مَاشَا\add* أَذْ إِخَارّصْ حِيمَا ونِّي زَّايسْ إِتّْوَامّنْضَارْ، وَارْ إِتّْغِيمِي إِمّنْضَارْ.  
\v 15 \add خنِّي\add* ڒخُّو، نشّْ ؤُسِيغْ-د \add ذَا\add* حِيمَا أَذْ سِّيوْڒغْ أَوَاڒْ-أَ أَكْ-ذ سِيذِي إِنُو أَجدْجِيذْ، مِينْزِي ڒْڭنْسْ إِسِّيڭّْوذْ أَيِي. \add خنِّي\add* ثنَّا ثَايَّا نّشْ: أجّْ أَيِي أَذْ سِّيوْڒغْ أَكْ-ذ ؤُجدْجِيذْ، أَذْ ثَاغْ أَذْ إِڭّْ ؤُجدْجِيذْ مِينْ غَا ثِينِي ثَايَّا نّسْ،  
\v 16 مَاغَارْ أَجدْجِيذْ أَذْ إِسڒْ غَارْ ثَايَّا نّسْ، مَاحنْذْ أَذْ ت إِفكّْ زڭْ ؤُفُوسْ ن ورْيَازْ نِّي إِخْسنْ أَذْ إِثحَّا نشّْ ذ مِّي زِي ثسْغَارْثْ إِ \add طّْفغْ\add* زِي أَربِّي.  
\v 17 ثَايَّا نّشْ ثنَّا \add عَاوذْ\add*: أجّْ أَذْ إِسَّاريّحْ وَاوَاڒْ ن سِيذِي إِنُو أَجدْجِيذْ، مَاغَارْ سِيذِي إِنُو أَجدْجِيذْ، إِڭَّا أَمْ يِيجّْ ن لْمَالَاكْ ن أَربِّي أَڒَامِي إِتّسْڒَا مِينْ إِصبْحنْ ذ مِينْ وَارْ إِحْڒِينْ. أَذْ كِيذكْ يِيڒِي سِيذِي أَربِّي نّشْ.“   
\m
\v 18 أَجدْجِيذْ يَارَّا-د خَاسْ، إِنَّا إِ ثمْغَارْثْ: ”وَارْ خَافِي ثفَّارْ وَالُو زِي ثْمسْڒَاشْثْ إِ خْ شمْ إِ غَا سّقْسِيغْ.“ ثَامْغَارْثْ ثنَّا: ”أجّْ سِيذِي إِنُو، أَجدْجِيذْ، أَذْ إِسِّيوڒْ.“  
\v 19 إِنَّا ؤُجدْجِيذْ: ”مَا يُووَابْ غَارسْ أَفُوسْ ذِي مَارَّا مَانْ أَيَا؟“ ثَامْغَارْثْ ثَارَّا-د خَاسْ: ”\add س ثِيذتّْ أَمْ\add* إِدَّارْ ڒعْمَارْ إِنُو، \add أَ\add* سِيذِي إِنُو، أَجدْجِيذْ، \add مَا إِزمَّارْ\add* ؤُڒَا ذ إِجّنْ \add أَذْ إِبعّذْ\add* غَارْ يفُوسْ نِيغْ غَارْ ؤُزڒْمَاضْ خْ مَارَّا مِينْ إِسِّيوڒْ سِيذِي إِنُو، أَجدْجِيذْ! وَاهْ، أَمْسخَّارْ نّشْ يُووَابْ ذ ونِّي ذ أَيِي يُومُورنْ. نتَّا إِڭَّا مَارَّا أَوَاڒنْ-أَ ذڭْ ؤُقمُّومْ ن ثَايَّا نّشْ.  
\v 20 أَيَا إِڭَّا إِ-ث ؤُمْسخَّارْ نّشْ يُووَابْ، حِيمَا أَذْ إِوْشْ إِ ثْمسْڒَاشْثْ إِجّْ ن ؤُغمْبُوبْ نّغْنِي. \add مَاشَا\add* سِيذِي إِنُو ذ أَمِيغِيسْ أَمْ يِيجّْ ن لْمَالَاكْ ن أَربِّي، أَڒَامِي إِسّنْ مَارَّا مِينْ إِتّمْسَارَانْ ذِي ثمُّورْثْ.“   
\m
\v 21 \add خَاسْ\add* ؤُشَا إِنَّا ؤُجدْجِيذْ إِ يُووَابْ: ”خْزَارْ عَافَاكْ، نشّْ ڭِّيغْ مَانْ أَيَا. ؤُيُورْ، أَوِي-د أَحُوذْرِي أَبْشَالُومْ!“  
\v 22 يُووَابْ إِوْضَا س ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ، يُوضَارْ \add أَسْ\add*، إِقَاذَا إِ ؤُجدْجِيذْ. ؤُشَا إِنَّا يُووَابْ: ”أَسّْ-أَ إِسّنْ ؤُمْسخَّارْ نّشْ، أَقَا ؤُفِيغْ أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، سِيذِي إِنُو، أَجدْجِيذْ، مِينْزِي أَجدْجِيذْ إِڭَّا عْلَاهْسَابْ أَوَاڒْ ن ؤُمْسخَّارْ نّسْ.“  
\v 23 إِكَّارْ يُووَابْ، يُويُورْ غَارْ جَاشُورْ ؤُ يِيوِيضْ غَارْ ؤُرْشَالِيمْ أَكْ-ذ أَبْشَالُومْ.  
\v 24 إِنَّا ؤُجدْجِيذْ: ”أجّْ إِ-ث أَذْ إِعْقبْ غَارْ ثَادَّارْثْ نّسْ. ؤُذمْ إِنُو \add مَاشَا\add* وَارْ ث إِژَّارْ.“ \add خنِّي\add* إِعْقبْ أَبْشَالُومْ غَارْ ثَادَّارْثْ نّسْ، \add مَاشَا\add* وَارْ إِژْرِي ؤُذمْ ن ؤُجدْجِيذْ.   
\m
\v 25 ذِي مَارَّا إِسْرَائِيل وَارْ إِدْجِي ؤُڒَا ذ إِجّْ ن ورْيَازْ إِشوَّارْ أَمْ أَبْشَالُومْ أَڒَامِي إِتّْوَاسُّوعْڒَا أَطَّاسْ. زِي ثَاڒقَّا ن إِضَارنْ أَڒْ ثْقِيشِّيثْ ن ؤُزدْجِيفْ نّسْ وَارْ ذَايسْ ؤُڒَا ذ إِجّْ ن ڒْعِيبْ.  
\v 26 مَاڒَا إِحفّْ أَشُوَّافْ نّسْ، \add ثُوغَا إِنُّومْ\add* أَذْ ث إِحفّْ غَارْ ؤُنڭَّارْ ن وُوسَّانْ عْلَاحْسَابْ ؤُسَّانْ \add ن كُوڒْ أَسڭّْوَاسْ\add*، مِينْزِي ثُوغَا إِدّكّْوَاڒْ إِذْقڒْ خَاسْ. إِحفّْ ؤُ إِوْزنْ أَشُوَّافْ ن ؤُزدْجِيفْ نّسْ. \add ثُوغَا ڒوْزنْ ن ؤُشُوَّافْ\add* مِيثَاينْ شِيقْلُو عْلَاحْسَابْ أَژْرُو س ڒوْزنْ إِمْثنْ ن ؤُجدْجِيذْ.  
\v 27 تّْوَارْونْ-د ثْڒَاثَا ن إِحنْجِيرنْ إِ أَبْشَالُومْ ذ إِشْثْ ن يدْجِيسْ قَّارنْ أَسْ ثَامَارْ. نتَّاثْ ثذْوڒْ ذ إِشْثْ ن ثمْغَارْثْ ذَايسْ أَژْرِي.   
\m
\v 28 أَبْشَالُومْ إِزْذغْ ثْنَاينْ ن إِسڭّْوُوسَا ذِي ؤُرْشَالِيمْ. نتَّا وَارْ إِژْرِي ؤُذمْ ن ؤُجدْجِيذْ.  
\v 29 \add خنِّي\add* إِسّكّْ أَبْشَالُومْ \add إِجّْ ن ؤُرقَّاسْ\add* غَارْ يُووَابْ، حِيمَا أَذْ ث إِسّكّْ غَارْ ؤُجدْجِيذْ \add ذِي طّْوعْ ن يِيخفْ نّسْ\add*، \add مَاشَا\add* يُووَابْ وَارْ إِخْسْ أَذْ غَارسْ د-يَاسْ. ؤُشَا إِسّكّْ \add أَرقَّاسْ\add* ثْوَاڒَا نّغْنِيثْ، مَاشَا نتَّا وَارْ إِخْسْ أَذْ د-يَاسْ.  
\v 30 \add خنِّي\add* إِنَّا إِ إِمْسخَّارنْ نّسْ: ”خْزَارمْ، إِيَّارْ ن يُووَابْ إِ إِدْجَانْ خْ ؤُغزْذِيسْ ن ونِّي إِنُو ؤُ نتَّا \add إِژُّو\add* ذَايسْ إِمنْذِي. ؤُيُورمْ ذِينْ، قّذمْ أَسْ ثِيمسِّي!“ ؤُشَا إِمْسخَّارنْ ن أَبْشَالُومْ قّْذنْ ثِيمسِّي إِ إِيَّارْ \add نِّي\add*.   
\m
\v 31 \add خَاسْ\add* ؤُشَا إِكَّارْ يُووَابْ ؤُشَا إِسِّيجّْ خْ أَبْشَالُومْ ذِي ثَادَّارْثْ \add نّسْ\add*، إِنَّا أَسْ: ”مَايمِّي قّْذنْ إِمْسخَّارنْ نّشْ ثِيمسِّي إِ ؤُرقِّيعْ ن إِيَّارْ إِ إِدْجَانْ إِنُو؟“  
\v 32 أَبْشَالُومْ إِنَّا إِ يُووَابْ: ”خْزَارْ، نشّْ سّكّغْ-د غَاركْ \add حِيمَا\add* أَذْ أَشْ إِنِيغْ: ’أَسْ-د ذَا، حِيمَا أَذْ شكْ سّكّغْ غَارْ ؤُجدْجِيذْ أَذْ ثِينِيذْ: مِينْ غَارْ د-ؤُسِيغْ \add ذَا\add* زِي جَاشُورْ؟ مْلِيحْ إِ نشّْ مْڒِي ذِينِّي قِّيمغْ.‘ خنِّي ڒخُّو إِتّْخصَّا أَذْ ژَترغْ ؤُذمْ ن ؤُجدْجِيذْ. مَاڒَا ذَايِي \add عَاذْ\add* ڒْمُوعْصِييّثْ، أجّْ إِ-ث أَذْ أَيِي إِنغْ.“  
\v 33 \add خنِّي\add* يُويُورْ يُووَابْ غَارْ ؤُجدْجِيذْ، إِنَّا أَسْ أَيَا. ؤُ وَانِيثَا إِڒَاغَا-د خْ أَبْشَالُومْ ؤُشَا يُوذفْ نتَّا غَارْ ؤُجدْجِيذْ، إِبنْذقْ أَسْ س ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ، زَّاثْ إِ ؤُجدْجِيذْ، ؤُشَا أَجدْجِيذْ إِسُّوذمْ أَبْشَالُومْ.   
\b  
\b  
\m  
\c 15
\s1 ثَامعْمُوتْشْ إِ إِڭَّا أَبْشَالُومْ خْ ذَاوُوذْ  
\m
\v 1 أَوَارْنِي ؤُيَا إِمْسَارْ، أَقَا أَبْشَالُومْ إِجَّا أَذْ أَسْ إِضبَّارَانْ إِجّْ ن ؤُكَارُّو ذ إِيْسَانْ ذ خمْسِينْ ن يرْيَازنْ إِنِّي إِتَّازّْڒنْ غَارْ زَّاثْ نّسْ.  
\v 2 ثُوغَا إِتّكَّارْ أَبْشَالُومْ زِيشْ غَارْ ثُوفُّوثْ \add ن ڒْحَاڒْ\add* ؤُشَا إِبدّْ غَارْ ؤُغزْذِيسْ ن وبْرِيذْ غَارْ ثوَّارْثْ \add ن ثنْذِينْثْ\add*. ؤُشَا إِمْسَارْ، مڒْمِي مَا إِخْسْ إِجّْ ن ورْيَازْ أَذْ إِرَاحْ س إِشْثْ ن دّعْوثْ غَارْ ؤُجدْجِيذْ إِ شّْرعْ، إِڒَاغَا-د خَاسْ غَارسْ، إِنَّا: ”زِي مَانْ ثَانْذِينْثْ شكْ؟“ مَاڒَا وَانِيثَا يَارَّا-د: ”أَمْسخَّارْ نّشْ زڭْ إِشْثْ زِي ثْقبَّاڒْ ن إِسْرَائِيل“،  
\v 3 إِنَّا أَسْ أَبْشَالُومْ: ”خْزَارْ، دّعْوَا نّشْ مْلِيحْ ؤُ نِيشَانْ، \add مَاشَا\add* غَارْ ؤُجدْجِيذْ وَارْ إِدْجِي ؤُڒَا ذ إِجّْ ونِّي غَاركْ غَا إِسْڒنْ.“  
\v 4 أَبْشَالُومْ يَارْنِي إِنَّا: ”مْڒِي ذ أَيِي ڭِّينْ ذ ڒْقَاضِي ذِي ثمُّورْثْ، \add مَاحنْذْ\add* \add كُوڒْ\add* أَرْيَازْ ونِّي غَارْ إِدْجَا ؤُمْشُوبّشْ نِيغْ دّعْوثْ، أَذْ غَارِي د-يَاسْ، نشّْ أَذْ أَسْ أَغغْ ثَاسْغَارْثْ؟“ \f ◼ \fr 15:‏4 \ft \+bd ’مَانْ ونْ ذ أَيِي إِ غَا إِڭّنْ ذ ڒْقَاضِي ذِي ثمُّورْثْ‘\+bd* - ڒْمعْنَا ن وَاوَاڒنْ ن أَبْشَالُومْ ذ وَانِيثَا: ’مْڒِي ذ أَيِي مَاشَا غَا ڭّنْ ذ ڒْقَاضِي ذِي ثمُّورْثْ‘.\f*  
\v 5 مَاڒَا إِقَارّبْ-د غَارسْ إِجّْ ن ورْيَازْ حِيمَا أَذْ أَسْ إِبنْذقْ، إِسّْوِيژّضْ أَفُوسْ نّسْ، إِطّفْ إِ-ث ؤُشَا إِسُّوذمْ إِ-ث.  
\v 6 أَمُّو إِڭَّا أَبْشَالُومْ غَارْ مَارَّا \add إِنِّي إِدْجَانْ زِي\add* إِسْرَائِيل، إِنِّي د-يُوسِينْ إِ شّْرعْ غَارْ ؤُجدْجِيذْ. أَمُّو يُوشَارْ أَبْشَالُومْ ؤُڒْ ن يرْيَازنْ ن إِسْرَائِيل.   
\m
\v 7 أَوَارْنِي أَربْعَا ن إِسڭّْوُوسَا إِمْسَارْ أَقَا أَبْشَالُومْ إِنَّا إِ ؤُجدْجِيذْ: ”أجّْ أَيِي أَذْ ؤُيُورغْ، أَذْ سّْقفْڒغْ ذِي حَابْرُونْ لْوَاعْذْ إِنُو إِ وَاعْذغْ إِ سِيذِي.  
\v 8 مَاغَارْ أَمْسخَّارْ نّشْ إِڭَّا إِجّْ ن لْوَاعْذْ ؤُمِي ثُوغَا زدّْغغْ \add عَاذْ\add* ذِي جَاشُورْ ذِي أَرَامْ، نِّيغْ: ’مَاڒَا سِيذِي إِجَّا أَيِي س ثِيذتّْ أَذْ د-ذوْڒغْ غَارْ ؤُرْشَالِيمْ، \add خنِّي\add* أَذْ خذْمغْ إِ سِيذِي.‘ “  
\v 9 \add خنِّي\add* إِنَّا أَسْ ؤُجدْجِيذْ: ”ؤُيُورْ ذِي ڒهْنَا!“ إِكَّارْ نتَّا ؤُشَا يُويُورْ غَارْ حَابْرُونْ.   
\m
\v 10 أَبْشَالُومْ \add مَاشَا\add* إِسّكّْ إِرْيَازنْ خْ إِضَارنْ غَارْ مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل حِيمَا أَذْ إِنِينْ: ”مَاڒَا كنِّيوْ ثسْڒَامْ إِ ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي، خنِّي إِتّْخصَّا أَذْ ثِينِيمْ: ’أَبْشَالُومْ ذ أَجدْجِيذْ ذِي حَابْرُونْ.‘ “  
\v 11 زِي ؤُرْشَالِيمْ ؤُيُورنْ أَكْ-ذ أَبْشَالُومْ مِيثَاينْ ن يرْيَازنْ إِنِّي إِتّْوَاعَارْضنْ. نِيثْنِي ؤُيُورنْ أَكِيذسْ ذِي ڒهْنَا نْسنْ، وَارْ سِّيننْ خْ وَالُو.  
\v 12 ڒَامِي \add ذِينْ\add* إِقدّمْ ثِيغَارْصَا، إِسّكّْ أَبْشَالُومْ \add عَاوذْ\add* غَارْ أَخِيثُوفِيلْ، زِي جِيلُو، ونِّي ذ أَمْشَاوَارْ ن ذَاوُوذْ، زِي ثنْذِينْثْ نّسْ، زِي جِيلُو. \add أَمُّو\add* إِ ثذْوڒْ ثْمعْمُوتْشْ ثْمقَّارْ ؤُشَا إِمَّارْنِي ڒْڭنْسْ \add إِ إِدْجَانْ\add* غَارْ أَبْشَالُومْ.   
\b  
\m  
\s1 أَرْوڒْ ن ذَاوُوذْ زِي أَبْشَالُومْ  
\m
\v 13 \add خنِّي\add* د-يُوسَا إِجّْ ن ؤُرقَّاسْ غَارْ ذَاوُوذْ، إِنَّا: ”ؤُڒْ ن \add كُوڒْ\add* أَرْيَازْ \add إِذْوڒْ\add* أَكْ-ذ أَبْشَالُومْ!“  
\v 14 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ مَارَّا إِمْسخَّارنْ نّسْ، إِنِّي ثُوغَا غَارسْ إِدْجَانْ ذِي ؤُرْشَالِيمْ: ”كَّارمْ، أَذْ نَارْوڒْ، مَاغَارْ وَارْ إِتّْغِيمِي غَارْنغْ ؤُڒَا ذ إِجّنْ نِّي إِ غَا إِنْجمْ زَّاثْ إِ وُوذمْ ن أَبْشَالُومْ. ذغْيَامْ ذڭْ وُوفُّوغْ نِيغْ نتَّا أَذْ إِقدْجبْ أَذْ خَانغْ إِحَارْثْ، أَذْ ذَايْنغْ إِڭّْ ثُوعفّْنَا ؤُشَا أَذْ إِوّثْ ثَانْذِينْثْ-أَ س ڒقْضعْ ن سِّيفْ.“  
\v 15 \add خنِّي\add* نَّانْ إِمْسخَّارنْ ن ؤُجدْجِيذْ إِ ؤُجدْجِيذْ: ”خْزَارْ، إِمْسخَّارنْ نّشْ \add أَذْ ڭّنْ\add* عْلَاحْسَابْ مَارَّا مِينْ غَا يِيخْضَارْ سِيذِي إِنُو أَجدْجِيذْ.“  
\v 16 أَمُّو إِ إِفّغْ ؤُجدْجِيذْ \add زِي ثنْذِينْثْ\add*، أَكْ-ذ مَارَّا ثَادَّارْثْ نّسْ ذڭْ إِصُورَافْ نّسْ. أَجدْجِيذْ إِجَّاعشْرَا ن ثِييَّا مَاحنْذْ أَذْ حْضَانْثْ ثَادَّارْثْ.  
\v 17 \add ؤُمِي\add* د-إِفّغْ ؤُجدْجِيذْ \add زِي ثنْذِينْثْ\add* أَكْ-ذ مَارَّا ڒْڭنْسْ نّسْ ذڭْ إِصُورَافْ نّسْ، قِّيمنْ نِيثْنِي بدّنْ غَارْ ڒَاڭّْوَاجْ.  
\v 18 مَارَّا إِمْسخَّارنْ عْذُونْ خَاسْ ؤُڒَا ذ إِعسَّاسنْ ن أَرِّيمثْ نّسْ مَارَّا، ؤُ مَارَّا إِرقَّاسنْ نّسْ ن ثَازْڒَا. ؤُڒَا ذ مَارَّا أَيْثْ ن جَاثْ، ستَّا-مْيَا ن يرْيَازنْ نِّي د-يُوسِينْ ذڭْ إِصُورَافْ نّسْ زِي جَاثْ، أَقَا كِّينْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ. \x ◘ \xo 15:‏18 \xt 2 صم. 8‏:‏18؛ 1 إِج. 1‏:‏38؛ 1 إِم. 18‏:‏17\x*   
\m
\v 19 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ إِ إِتَّايْ، ونِّي زڭْ أَيْثْ ن جَاثْ: ”مَايمِّي ثخْسذْ ؤُڒَا ذ شكْ أَذْ ثُويُورذْ أَكِيذْنغْ؟ عْقبْ ؤُ قِّيمْ غَارْ ؤُجدْجِيذْ، مَاغَارْ شكْ ذ إِجّْ ن ؤُبَارَّانِي، أَقَا شكْ بعْذَا ثتّْوَاسُّوفّْغذْ زِي ثمُّورْثْ نّشْ.  
\v 20 إِضنَّاضْ إِ د-ثُوسِيذْ شكْ. مَا نشّْ أَذْ شكْ أَوْيغْ أَكِيذْنغْ أَسّْ-أَ حِيمَا أَذْ د-ثفّْغذْ، \add ؤُمِي\add* إِ غَا ؤُيُورغْ نشّْ مَانِي مَا إِ تّْوَارِيغْ إِزمَّارْ أَذْ ڒَاحغْ. عْقبْ، أَوِي-د أَكِيذكْ أَيْثْمَاشْ. أَذْ كِيذكْ ثِيڒِي ثْمخْسِيوْثْ إِشوَّارنْ ذ ڒَامَانْ.“  
\v 21 \add مَاشَا\add* إِتَّايْ يَارَّا-د خْ ؤُجدْجِيذْ، إِنَّا: ”\add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي ؤُ إِدَّارْ سِيذِي إِنُو أَجدْجِيذْ، ذڭْ ومْشَانْ مَانِي غَا يِيڒِي سِيذِي إِنُو أَجدْجِيذْ، مَا إِمُّوثْ نِيغْ إِدَّارْ، ذِينِّي إِ غَا يِيڒِي ؤُڒَا ذ أَمْسخَّارْ نّشْ!“  
\v 22 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ إِتَّايْ: ”ؤُيُورْ \add خنِّي\add*، أكّْ-د!“ إِكَّا خَاسْ إِتَّايْ، ونِّي إِدْجَانْ زڭْ أَيْثْ ن جَاثْ، أَكْ-ذ مَارَّا إِرْيَازنْ نّسْ ذ إِحنْجِيرنْ إِ غَارسْ \add إِدْجَانْ\add*.  
\v 23 مَارَّا ثمُّورْثْ ثْرُو ؤُمِي إِكَّا ڒْڭنْسْ. أَجدْجِيذْ إِژْوَا ثِيغْزَارْثْ ن قِيذْرُونْ ؤُڒَا ذ مَارَّا ڒْڭنْسْ إِژْوَا، \add طّْفنْ\add* أَبْرِيذْ غَارْ ڒخْڒَا. \x ◘ \xo 15:‏23 \xt يُوح. 18‏:‏1\x*   
\m
\v 24 أَقَا ذِينْ ؤُڒَا ذ صَاذُوقْ ذ مَارَّا إِلَاوِييّنْ إِنِّي يَارْبُونْ تَّابُوثْ ن ڒْعَاهْذْ أَكِيذسْ. نِيثْنِي سَّارْسنْ تَّابُوثْ ن أَربِّي ؤُ أَبْيَاثَارْ إِڭعّذْ \add ذِينْ\add* أَڒَامِي إِقْفڒْ  ؤُعدُّو ن مَارَّا ڒْڭنْسْ زِي ثنْذِينْثْ.  
\v 25 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ إِ صَاذُوقْ: ”أَرّْ تَّابُوثْ ن أَربِّي غَارْ ثنْذِينْثْ. مَاڒَا نشّْ ؤُفِيغْ أَرْضَا زَّاثْ إِ ثِيطَّاوِينْ ن سِيذِي، خنِّي نتَّا أَذْ أَيِي يَارّْ \add غَارْ ذَا\add*، أَذْ أَيِي يَارّْ أَذْ ژَترْغْ \add تَّابُوثْ\add* عَاوذْ ؤُڒَا ذ ثَازذِّيغْثْ.  
\v 26 \add مَاشَا\add* مَاڒَا نتَّا أَذْ يِينِي: ’شكْ وَارْ ذ أَيِي د-ثُوسِيذْ خْ ڒْخَاضَارْ!‘، أَقَا أَيِي ذَا، أجّْ إِ-ث أَذْ كِيذِي إِڭّْ مِينْ إِدْجَانْ ذ لمْلِيحْ ذِي ثِيطَّاوِينْ نّسْ.“   
\m
\v 27 يَارنِّي إِنَّا ؤُجدْجِيذْ إِ ؤُكهَّانْ صَاذُوقْ: ”مَا وَارْ ثدْجِيذْ شكْ ذ أَمْوَاڒَاوْ؟ عْقبْ ذِي ڒهْنَا غَارْ ثمُّورْثْ نّشْ ذ ثْنَاينْ ن إِحنْجِيرنْ نْومْ أَكِيذْومْ: مِّيشْ أَخِيمَاعَاصْ، ذ يُونَاثَانْ، مِّيسْ ن أَبْيَاثَارْ. \f ◼ \fr 15:‏27 \ft \+bd ’أَمْوَاڒَاوْ‘\+bd* - ذ ونِّي إِتّْوَاڒَانْ س ثِيرْجَا نِيغْ س ثْمژْرَا\f*  
\v 28 خْزَارْ، نشّْ أَذْ رَاجِيغْ ذِي ڒخْڒَا غَارْ مَانِيسْ ژكّْوَانْ خْ \add لْ-ؤُرْذُونْ\add*، أَڒْ د غَا ثَاسْ ثبْرَاثْ زَّايْومْ غَارِي.“  
\v 29 \add خَاسْ ؤُشَا\add* يِيوْيِي صَاذُوقْ أَكْ-ذ أَبْيَاثَارْ تَّابُوثْ ن أَربِّي غَارْ ؤُرْشَالِيمْ ؤُشَا قِّيمنْ ذِينِّي.   
\m
\v 30 ذَاوُوذْ إِڭعّذْ ثَاسَاونْثْ ن \add وذْرَارْ ن\add* زِّيثُونْ. إِرُو أَمْ د-إِڭعّذْ. ثُوغَا أَزدْجِيفْ نّسْ إِرحّفْ، يُويُورْ خْ إِضَارنْ س ڒحْفَا. ؤُڒَا ذ مَارَّا ڒْڭنْسْ إِ غَارسْ، \add كُوڒْ\add* أَرْيَازْ \add زَّايسْ\add* إِرحّفْ أَزدْجِيفْ نّسْ، ؤُشَا ڭعّْذنْ نِيثْنِي، رُونْ أَمْ ڭعّْذنْ.  
\v 31 \add خنِّي\add* حَاجَانْ أَسْ إِ ذَاوُوذْ، نَّانْ: ”أَخِيثُوفِيلْ ثُوغَا-ث جَارْ إِنِّي إِڭِّينْ ثَامعْمُوتْشْ خْ ؤُغزْذِيسْ ن أَبْشَالُومْ.“ ؤُشَا إِنَّا ذَاوُوذْ: ”\add أَ\add* سِيذِي، سْبطّڒْ شّْوَارْ ن أَخِيثُوفِيلْ.“   
\m
\v 32 \add ڒَْامِي\add* ذَاوُوذْ يِيوضْ غَارْ ثْقِيشّثْ ن وذْرَارْ، مَانِي تّْنُومَانْ أَذْ سجْذنْ زَّاثْ إِ أَربِّي، خْزَارْ، \add يُوسَا-د\add* حُوشَايْ، أَيَارْكِي، إِ ؤُمْسَاڭَارْ أَكِيذسْ س وَارُّوضْ إِشَارّْڭنْ ؤُ س ؤُشَاڒْ خْ ؤُزدْجِيفْ نّسْ. \x ◘ \xo 15:‏32 \xt ياش. 16‏:‏2\x*  
\v 33 ذَاوُوذْ إِنَّا أَسْ: ”مَاڒَا شكْ ثژْوِيذْ أَكِيذِي، أَذْ خَافِي ثِيڒِيذْ ذ دّْقڒْ.  
\v 34 مَاڒَا مَاشَا شكْ ثْعقْبذْ غَارْ ثنْذِينْثْ، أَذْ ثِينِيذْ إِ أَبْشَالُومْ: ’نشّْ أَذْ إِڒِيغْ ذ أَمْسخَّارْ نّشْ، \add أَ\add* أَجدْجِيذْ! ثُوغَا أَيِي زِيشْ ذ أَمْسخَّارْ ن بَابَاشْ، ڒخُّو مَاشَا أَذْ إِڒِيغْ ذ أَمْسخَّارْ نّشْ!‘، \add خنِّي\add* ثْزمَّارذْ أَذْ ثْبضْڒذْ شّْوَارْ ن أَخِيثُوفِيلْ.  
\v 35 مَا وَارْ ذِينِّي غَاركْ إِكهَّاننْ صَاذُوقْ ذ أَبْيَاثَارْ؟ أَذْ إِمْسَارْ أَذْ ثْعَاوْذذْ مَارَّا مِينْ غَا ثسْڒذْ زِي ثَادَّارْثْ ن ؤُجدْجِيذْ إِ إِكهَّاننْ صَاذُوقْ ذ أَبْيَاثَارْ.  
\v 36 أَقَا نِيثْنِي غَارْسنْ ذِينِّي ثْنَاينْ ن إِحنْجِيرنْ نْسنْ، أَخِيمَاعَاصْ، مِّيسْ ن صَاذُوقْ، ذ يُونَاثَانْ، مِّيسْ ن أَبْيَاثَارْ. أَذْ أَيِي د-ثسِّيوْضمْ مَارَّا أَوَاڒْ إِ ثسْڒِيمْ \add زَّايْسنْ\add*.“   
\m
\v 37 ؤُشَا حُوشَايْ، أَمدُّوكّڒْ ن ذَاوُوذْ، يُوذفْ غَارْ ثنْذِينْثْ ؤُشَا ؤُڒَا ذ أَبْشَالُومْ يُوذفْ غَارْ ؤُرْشَالِيمْ.   
\b  
\b  
\m  
\c 16
\s1 أَمْسَاڭَارْ ن ذَاوُوذْ أَكْ-ذ صِيبَا  
\m
\v 1 \add ؤُمِي\add* إِعْذُو ذَاوُوذْ شْوَايْثْ خْ ثْقِيشّثْ ن وذْرَارْ، إِفّغْ صِيبَا، أَمْسخَّارْ ن مَافِيبُوشَاثْ، إِ ؤُمْسَاڭَارْ أَكِيذسْ س إِشْثْ ن ثْيُويَا ن يغْيَاڒْ بَارْذْعنْ، \add إِسَّارْسْ\add* خَاسنْ مِيثَاينْ ن إِغْرُومنْ، مْيَا ن إِغْرُومنْ ن زّْبِيبْ ؤُ مْيَا ن ثِينِي ن ؤُنبْذُو ذ إِشْثْ ن ثشْيَارْثْ \add ذَايسْ\add* بِينُو. \f ◼ \fr 16:‏1 \ft \+bd ’ثِينِي ن ؤُنبْذُو‘\+bd* - نِيغْ ’فْرُوثَا ن ؤُنبْذُو‘.\f*  
\v 2 إِنَّا ؤُجدْجِيذْ إِ صِيبَا: ”مِينْ ثخْسذْ أَذْ ثڭّذْ س ؤُيَا؟“ إِنَّا صِيبَا: ”إِغْيَاڒْ إِ ثَادَّارْثْ ن ؤُجدْجِيذْ حِيمَا أَذْ خَاسنْ نْينْ، ؤُ أَغْرُومْ ذ ثِينِي ن ؤُنبْذُو إِ إِمْسخَّارنْ، حِيمَا أَذْ شّنْ، ؤُ بِينُو إِ يِينِّي يُوحْڒنْ ذِي ڒخْڒَا، حِيمَا أَذْ سْونْ.“  
\v 3 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ: ”مَانِي إِدْجَا مِّيسْ ن سِيذِي نّشْ؟“ إِنَّا صِيبَا إِ ؤُجدْجِيذْ: ”خْزَارْ، نتَّا إِقِّيمْ ذِي ؤُرْشَالِيمْ، مَاغَارْ نتَّا إِنَّا: ’أَسّْ-أَ ثَادَّارْثْ ن إِسْرَائِيل أَذْ أَيِي د-ثَارّْ ثَاڭلْذِيثْ ن بَابَا.‘ “ \x ◘ \xo 16:‏3 \xt 2 صم. 19‏:‏27\x*  
\v 4 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ إِ صِيبَا: ”خْزَارْ، مَارَّا مِينْ \add إِدْجَانْ\add* ن مَافِيبُوشَاثْ، أَذْ يِيڒِي نّشْ!“ صِيبَا إِنَّا: ”نشّْ بنْذْقغْ، مْڒِي ؤُفِيغْ أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، \add أَ\add* سِيذِي إِنُو أَجدْجِيذْ!“   
\b  
\m  
\s1 ذَاوُوذْ إِتّْوَانْعڒْ زِي شِيمْعِي  
\m
\v 5 \add ؤُمِي\add* د-يُوسَا ؤُجدْجِيذْ ذَاوُوذْ غَارْ بَاخُورِيمْ، إِژْرَا إِجّْ ن ورْيَازْ إِفّغْ-د سّنِّي زِي ڒَادْجْ ن ثَادَّارْثْ ن شَاوُولْ. قَّارنْ أَسْ شِيمْعِي، مِّيسْ ن جِيرَا. نتَّا إِڭُّورْ أَمْ إِنعّڒْ. \x ◘ \xo 16:‏5 \xt 1 إِج. 2‏:‏8\x*  
\v 6 نتَّا إِحجَّارْ ذَاوُوذْ ذ مَارَّا إِمْسخَّارنْ ن ؤُجدْجِيذْ ذَاوُوذْ س يژْرَا، \add أَمْ\add* إِبدّْ ڒْڭنْسْ مَارَّا ذ مَارَّا أَيْثْ ن بُو-ثغْرُوضْثْ زَّاثسْ غَارْ يفُوسْ ذ ؤُزڒْمَاضْ.  
\v 7 أَمُّو إِ إِقَّارْ شِيمْعِي أَمْ ث إِنعّڒْ: ”أَڭّْوجْ، أَڭّْوجْ، شكْ، أَرْيَازْ ن \add ؤُسِيزّڒْ ن\add* إِذَامّنْ ذ ورْيَازْ إِ وَارْ إِسكّْوِينْ!  
\v 8 سِيذِي إِسِّيوضْ خَاكْ مَارَّا إِذَامّنْ ن ثَادَّارْثْ ن شَاوُولْ ونِّي ذڭْ ومْشَانْ نّسْ إِ ثْحكْمذْ. سِيذِي إِوْشَا ثَاڭلْذِيثْ ذڭْ إِفَاسّنْ ن مِّيشْ أَبْشَالُومْ. خْزَارْ \add مَانْ أَيَا إِفّغْ-د\add* زِي ثُوعفّْنَا نّشْ ؤُمِي شكْ ذ إِجّْ ن ورْيَازْ ن \add ؤُسِيزّڒْ ن\add* إِذَامّنْ.“  
\v 9 \add خنِّي\add* إِنَّا أَبِيشَايْ، مِّيسْ ن صَارُويَا، إِ ؤُجدْجِيذْ: ”مَايمِّي غَا إِنْعڒْ وقْزِينْ-أَ إِمُّوثنْ، سِيذِي إِنُو أَجدْجِيذْ؟ أجّْ أَيِي أَذْ ذِينْ ژْوِيغْ، أَذْ أَسْ قسّغْ أَزدْجِيفْ.“ \x ◘ \xo 16:‏9 \xt 1 صم. 24‏:‏15؛ 2 صم. 9‏:‏8\x*  
\v 10 \add مَاشَا\add* أَجدْجِيذْ إِنَّا: ”مِينْ ذِينْ جَارْ أَيِي ذ كنِّيوْ، أَرَّاوْ ن صَارُويَا؟ أَقَا نتَّا إِنْعڒْ، ؤُمِي ذ أَسْ إِنَّا سِيذِي: ’نْعڒْ ذَاوُوذْ!‘ مَانْ ونْ إِزمَّارنْ \add خنِّي\add* أَذْ يِينِي: ’مَايمِّي إِ ثڭِّيذْ أَيَا؟‘ “  
\v 11 ذَاوُوذْ يَارْنِي إِنَّا إِ أَبِيشَايْ ذ مَارَّا إِمْسخَّارنْ نّسْ: ”خْزَارمْ، مِّي إِ د-إِفّْغنْ زِي دَّاثْ إِنُو، يَارزُّو أَذْ أَيِي إِنغْ. مَاهُو خنِّي ڒخُّو أَرْيَازْ-أَ زڭْ أَيْثْ ن بِينْيَامِينْ؟ جّمْ ث أَذْ إِنْعڒْ، مِينْزِي سِيذِي إِ ذ أَسْ ث إِنَّانْ.  
\v 12 أَذْ ثَاغْ سِيذِي أَذْ إِتّْوَاڒَا ثَامَارَا إِنُو ؤُشَا أَذْ أَيِي د-يَارّْ سِيذِي ثَاصبْحَانْثْ ذڭْ ومْشَانْ ن نّعْڒثْ نّسْ ن وَاسّْ-أَ.“  
\v 13 ذَاوُوذْ أَكْ-ذ يرْيَازنْ نّسْ طّْفنْ أَبْرِيذْ ؤُ شِيمْعِي يُويُورْ أَرنْذَاذْ نّسْ غَارْ ؤُغزْذِيسْ نّغْنِي ن ثوْرِيرْثْ، أَمْ إِنعّڒْ ؤُ إِتّْحجَّارْ \add ذَاوُوذْ\add* س يژْرَا ؤُشَا إِڭَّا ثَاعجَّاجْثْ أَذْ ثْضُووْ.  
\v 14 يِيوضْ-د ؤُجدْجِيذْ أَكْ-ذ مَارَّا ڒْڭنْسْ إِ غَارسْ غَارْ أَيَافِيمْ. ذِينِّي إِزمَّارْ أَذْ يَارّْ نّفْسْ \add عَاوذْ\add*.   
\b  
\m  
\s1 حُوشَايْ ذ أَخِيثُوفِيلْ أَكْ-ذ أَبْشَالُومْ  
\m
\v 15 أَبْشَالُومْ أَكْ-ذ مَارَّا ڒْڭنْسْ، إِرْيَازنْ ن إِسْرَائِيل، ؤُسِينْ-د غَارْ ؤُرْشَالِيمْ ؤُ أَخِيثُوفِيلْ ثُوغَا-ث غَارسْ.  
\v 16 ؤُمِي إِ د-يُوسَا حُوشَايْ، أَيَارْكِي، أَمدُّوكّڒْ ن ذَاوُوذْ، غَارْ أَبْشَالُومْ، إِمْسَارْ بلِّي حُوشَايْ إِنَّا إِ أَبْشَالُومْ: ”ثُوذَارْثْ إِ ؤُجدْجِيذْ، ثُوذَارْثْ إِ ؤُجدْجِيذْ!“  
\v 17 أَبْشَالُومْ إِنَّا إِ حُوشَايْ: ”مَا ذ مَانْ أَيَا \add خنِّي\add* ذ \add إِجّْ ن وسْشَانْ ن\add* ثْمخْسِيوْثْ إِشوَّارنْ إِ ؤُمدُّوكّڒْ نّشْ؟ مَايمِّي وَارْ ثْرِيحذْ أَكْ-ذ ؤُمدُّوكّڒْ نّشْ؟“  
\v 18 حُوشَايْ إِنَّا إِ أَبْشَالُومْ: ”لَّ، نشّْ أَذْ إِڒِيغْ غَارْ ونِّي إِتّْوَافَارْزنْ زِي سِيذِي ؤُ \add زِي\add* مَارَّا ڒْڭنْسْ-أَ ؤُ \add زِي\add* مَارَّا إِرْيَازنْ ن إِسْرَائِيل، ؤُ نشّْ أَذْ غَارسْ قِّيمغْ.  
\v 19 إِ ؤُمِي غَا سخَّارغْ خنِّي؟ مَا وَارْ إِتِّيڒِي زَّاثْ إِ وُوذمْ ن مِّيسْ؟ أَمْ مَامّشْ نشّْ خذْمغْ زَّاثْ إِ وُوذمْ ن بَابَاشْ، أَمُّو إِ غَا إِڒِيغْ زَّاثْ إِ وُوذمْ نّشْ.“   
\m
\v 20 أَبْشَالُومْ إِنَّا إِ أَخِيثُوفِيلْ: ”وْشمْ \add أَنغْ\add* شّْوَارْ، مِينْ غَا نڭّْ؟“  
\v 21 أَخِيثُوفِيلْ إِنَّا إِ أَبْشَالُومْ: ”أَذفْ غَارْ ثِييَّا ن بَابَاشْ ثِينِّي إِجَّا أَوَارْنِي أَسْ حِيمَا أَذْ حْضَانْثْ ثَادَّارْثْ. \add أَمُّو\add* إِ غَا إِسڒْ مَارَّا إِسْرَائِيل، أَقَا شكْ ثسَّارْزْڭذْ إِخفْ نّشْ غَارْ بَابَاشْ ؤُشَا أَذْ تّْوَاسّْجهْذنْ إِفَاسّنْ ن مَارَّا إِنِّي أَكِيذكْ \add إِدْجَانْ\add*.“  
\v 22 وْثِينْ إِ أَبْشَالُومْ إِشْثْ ن ثْقِيضُونْثْ خْ ثْزقَّا ؤُ أَبْشَالُومْ يُوذفْ غَارْ ثِييَّا ن بَابَاسْ زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا إِسْرَائِيل.  
\v 23 ذڭْ وُوسَّانْ نِّي إِتّْوَاحْسبْ شّْوَارْ ن أَخِيثُوفِيلْ أَخْمِي \add إِجّنْ\add* يَارزُّو أَوَاڒْ ن أَربِّي. أَمُّو \add إِ يدْجَا\add* س مَارَّا شّْوَارْ ن أَخِيثُوفِيلْ، أَمْ غَارْ ذَاوُوذْ أَمْ غَارْ أَبْشَالُومْ.   
\b  
\b  
\m  
\c 17
\s1 أَبطّڒْ نْ شْوَارْ ن أَخِيثُوفِيلْ  
\m
\v 1 أَخِيثُوفِيلْ إِنَّا إِ أَبْشَالُومْ: ”أجّْ أَيِي أَذْ فَارْزغْ ثنْعَاشْ-أَڒفْ ن يرْيَازنْ، أَذْ سّْوجْذغْ إِخفْ إِنُو حِيمَا أَذْ ضْفَارغْ ذَاوُوذْ دْجِيڒثْ-أَ.  
\v 2 \add خنِّي\add* نشّْ أَذْ خَاسْ هجْمغْ، \add مِينْثْرَا\add* إِفَاسّنْ نّسْ \add عَاذْ\add* ؤُحْڒنْ ؤُ ضعْفنْ. أَذْ ث سِّيڭّْوِيذغْ ؤُ مَارَّا ڒْڭنْسْ إِ غَارسْ \add إِدْجَانْ\add* أَذْ يَارْوڒْ. \add خنِّي\add* نشّْ أَذْ نْغغْ أَجدْجِيذْ، نتَّا وَاهَا.  
\v 3 أَذْ غَاركْ د-أَرّغْ مَارَّا ڒْڭنْسْ. \add ڒْموْثْ ن\add* ورْيَازْ إِ خْ ثَارزُّوذْ \add أَقَا-ث\add* أَمْ وذْوَاڒْ ن يوْذَانْ مَارَّا، ڒْڭنْسْ \add أَذْ ث إِقْبڒْ،\add* أَذْ ثِيڒِي ڒهْنَا.“  
\v 4 ثُوغَا أَيَا ذ إِجّْ ن وَاوَاڒْ نِيشَانْ ذِي ثِيطَّاوِينْ ن أَبْشَالُومْ ؤُ ذِي ثِيطَّاوِينْ ن مَارَّا إِمْغَارنْ ن إِسْرَائِيل.   
\m
\v 5 \add مَاشَا\add* إِنَّا أَبْشَالُومْ: ”ڒَْاغَاثْ ؤُڒَا إِ حُوشَايْ، أَيَارْكِي. أجّْ أَنغْ أَذْ غَارسْ نْسڒْ عَاوذْ مِينْ غَا يِينِي.“  
\v 6 ؤُمِي د-يُوذفْ حُوشَايْ، إِسِّيوڒْ أَبْشَالُومْ أَكِيذسْ، إِنَّا: ”أَمُّو إِ إِسِّيوڒْ أَخِيثُوفِيلْ. مَا أَذْ نڭّْ عْلَاحْسَابْ أَوَاڒْ نّسْ؟ مَاڒَا وَارْ إِدْجِي أَمُّو، \add خنِّي\add* سِيوڒْ شكْ!“  
\v 7 \add خنِّي\add* إِنَّا حُوشَايْ إِ أَبْشَالُومْ: ”ثْوَاڒَاثْ-أَ شّْوَارْ نِّي إِوْشِينْ أَخِيثُوفِيلْ وَارْ إِدْجِي مْلِيحْ.“  
\v 8 \add يَارْنِي\add* حُوشَايْ إِنَّا: ”شكْ ثسّْنذْ أَقَا بَابَاشْ ذ يرْيَازنْ نّسْ، نِيثْنِي ذ أَيْثْ ن بُو-ثغْرُوضْثْ، ؤُ أَقَا ڒعْمَارْ نْسنْ يَارْزڭْ أَمْ يِيجّْ ن دُّوبْ ذِي ڒخْڒَا، ونِّي ؤُمِي إِتّْوَاشَارْ ونْجُوغْ. بَابَاشْ ذ إِجّْ ن ورْيَازْ أَعسْكَارِي ؤُ نتَّا وَارْ إِتّْنُوسِي أَكْ-ذ ڒْڭنْسْ.  
\v 9 أَقَا ڒخُّو إِنُّوفَّارْ ذڭْ إِجّْ زڭْ إِفْرَانْ نِيغْ ذڭْ إِجّْ زڭْ إِمُوشَانْ ن ثْنُوفّْرَا. مَاڒَا غَارْ ؤُمزْوَارُو وْضَانْ شَا زَّايْسنْ، \add خنِّي\add* مَارَّا وِي ث غَا إِسْڒنْ، أَذْ يِينِي: ’أَقَا ذِينْ إِشْثْ ن ثشْثِي ذِي ڒْڭنْسْ نِّي إِضْفَارنْ أَبْشَالُومْ.‘  
\v 10 \add خنِّي\add* عَاذْ ونِّي د-إِخڒْقنْ إِ ؤُمنْغِي، ونِّي ؤُڒْ نّسْ أَمْ وُوڒْ ن إِجّْ ن ويْرَاذْ، أَذْ إِفْشڒْ ذغْيَا، مَاغَارْ مَارَّا إِسْرَائِيل إِسّنْ أَقَا بَابَاشْ ذ إِجّْ ن بُو-ثغْڒُوضْثْ ؤُ غَارسْ أَيْثْ ن ؤُمنْغِي.  
\v 11 س ؤُينِّي أَذْ أَشْ سّشْنغْ أَذْ ثسّْمُونذْ ذغْيَا مَارَّا إِسْرَائِيل زِي ذَانْ أَڒْ بِئرْ-سبْعَا، إِجّْ ن ؤُبَارُّو أَطَّاسْ أَمْ يِيجْذِي غَارْ ثْمَا ن ڒبْحَارْ، ؤُ شكْ أَذْ كِيذْسنْ ثفّْغذْ غَارْ ؤُمنْغِي.  
\v 12 \add خنِّي\add* نشِّينْ أَذْ خَاسْ نهْجمْ ذڭْ إِجّْ زڭْ إِمُوشَانْ ن ثْنُوفّْرَا مَانِي غَا إِتّْوَافْ. أَذْ خَاسْ نهْجمْ أَمْ إِوطَّا نّْذَا خْ ثمُّورْثْ. وَارْ إِتّْغِيمِي ؤُڒَا ذ إِجّنْ زَّايسْ ؤُ زِي مَارَّا إِرْيَازنْ إِ غَارسْ إِدْجَانْ.  
\v 13 مَاڒَا نتَّا أَذْ إِسّْمُونْ إِخفْ نّسْ ذِي شَا ن ثنْذِينْثْ، مَارَّا إِسْرَائِيل أَذْ كَّارنْ أَذْ أَوْينْ إِسغْوَانْ غَارْ ثنْذِينْثْ نِّي، أَذْ ت نْجَارّْ ذِي ثغْزُورْثْ أَڒَامِي وَارْ زَّايسْ إِتّْوَافْ ؤُڒَا ذ إِجّْ ن وژْرُو عَاذْ.“   
\m
\v 14 \add خنِّي\add* إِنَّا أَبْشَالُومْ ؤُڒَا ذ مَارَّا إِرْيَازنْ ن إِسْرَائِيل: ”شّْوَارْ ن أَيَارْكِي حُوشَايْ إِحْڒَا خْ شّْوَارْ ن أَخِيثُوفِيلْ.“ أَقَا سِيذِي ثُوغَا يُومُورْ أَذْ بضْڒنْ شّْوَارْ لمْلِيحْ ن أَخِيثُوفِيلْ، حِيمَا سِيذِي أَذْ يَاوِي ثُوعفّْنَا خْ أَبْشَالُومْ.   
\b  
\m  
\s1 ذَاوُوذْ إِرُوحْ غَارْ مَاحَانَايِيمْ  
\m
\v 15 إِنَّا حُوشَايْ إِ إِكهَّاننْ صَاذُوقْ ذ أَبْيَاثَارْ: ”ثَا ذ ثَا إِشَاوَارْ أَخِيثُوفِيلْ إِ أَبْشَالُومْ ذ إِمْغَارنْ ن إِسْرَائِيل، مَاشَا ذ ثَا ذ ثَا إِخفْ وصِّيغْ نشّْ.  
\v 16 \add خنِّي\add* ڒخُّو، سكّْ ذغْيَا \add إِجّْ ن ؤُرقَّاسْ\add* مَاحنْذْ أَذْ إِخبَّارْ إِ ذَاوُوذْ، أَذْ يِينِي: ”وَارْ سنْسْ دْجِيڒثْ-أَ ذڭْ إِمُوشَانْ ن ؤُژكّْوُو ن ڒخْڒَا. ژْوَا ذغْيَا، نِيغْ أَذْ إِتّْوَاصَارْضْ ؤُجدْجِيذْ ذ مَارَّا ڒْڭنْسْ إِ غَارسْ \add إِدْجَانْ\add*.“  
\v 17 مَاشَا يُونَاثَانْ ذ أَخِيمَاعَاصْ قِّيمنْ بدّنْ غَارْ ثَاڒَا ن رُوجَالْ. إِشْثْ ن ثَايَّا ثُويُورْ ذِينِّي، ثْحَاجَا أَسنْ ت. نِيثْنِي ؤُيُورنْ ؤُ حَاجَانْ ت إِ ؤُجدْجِيذْ ذَاوُوذْ. ثُوغَا-ثنْ وَارْ زمَّارنْ أَذْ أَذْفنْ غَارْ ثنْذِينْثْ، ؤُمِي إِتّْخصَّا وَارْ ثنْ ژَترّنْ \add إِوْذَانْ\add*.  
\v 18 \add وَاخَّا أَمنِّي\add* إِجّْ ن ؤُمْسخَّارْ إِژْرَا إِ-ثنْ ؤُشَا إِحَاجَا ث إِ أَبْشَالُومْ. \add مَاشَا\add* إِنَا س ثْنَاينْ إِذْسنْ ؤُزّْڒنْ، ؤُسِينْ-د غَارْ ثَادَّارْثْ ن إِجّْ ن ورْيَازْ ذِي بَاخُورِيمْ ونِّي ثُوغَا غَارْ إِدْجَا إِجّْ ن وَانُو ذِي ڒمْرَاحْ. نِيثْنِي ضْرِينْ ذَايسْ.  
\v 19 ثَامْغَارْثْ ثكْسِي ثَازَارْبتْشْ ؤُشَا ثسَّارْسْ إِ-ت خْ ؤُقمُّومْ ن وَانُو ؤُشَا ثَاريّشْ خَاسْ إِوْزَانْ إِ إِتّْوَاقشَّارنْ ن إِمنْذِي. \add أَمُّو\add* إِ وَارْ د-ثْبِينْ ثْمسْڒَاشْثْ.  
\v 20 \add ڒَْامِي\add* إِمْسخَّارنْ ن أَبْشَالُومْ ؤُسِينْ-د غَارْ ثمْغَارْثْ ذِي ثَادَّارْثْ، سّقْسَانْ ت: ”مَانِي إِدْجَا أَخِيمَاعَاصْ ذ يُونَاثَانْ؟“ ثَامْغَارْثْ ثَارَّا-د خَاسنْ: ”نِيثْنِي ژْوَانْ ثِيغْزَارْثْ نِّي.“ \add خنِّي\add* فّْغنْ إِمْسخَّارنْ نِّي، أَرْزُونْ، وَارْ \add ثنْ\add* ؤُفِينْ. \add خنِّي\add*عقْبنْ غَارْ ؤُرْشَالِيمْ.   
\m
\v 21 أَوَارْنِي ؤُمِي ثُوغَا نِيثْنِي ؤُيُورنْ، إِمْسَارْ، نِيثْنِي ڭعّْذنْ زڭْ وَانُو، ؤُيُورنْ، خبَّارنْ أَيَا إِ ؤُجدْجِيذْ ذَاوُوذْ. نِيثْنِي نَّانْ إِ ذَاوُوذْ: ”كَّارمْ، ژْوَامْ أَمَانْ ذغْيَا، مَاغَارْ ثَا ذ ثَا ذ شّْوَارْ إِ خَاومْ إِڭَّا أَخِيثُوفِيلْ.“   
\m
\v 22 إِكَّارْ ذَاوُوذْ أَكْ-ذ مَارَّا ڒْڭنْسْ إِ غَارسْ إِدْجَانْ ؤُ نِيثْنِي ژْوَانْ لْ-ؤُرْذُونْ. غَارْ ثْفَاوْثْ ن ثُوفُّوثْ ن وَاسّْ، ثُوغَا وَارْ ذِينْ عَاذْ ؤُڒَا ذ إِجّنْ وَارْ إِژْوِي لْ-ؤُرْذُونْ.  
\v 23 \add ؤُمِي\add* أَخِيثُوفِيلْ إِژْرَا، أَقَا شّْوَارْ نّسْ إِتّْوَابطّڒْ، إِبَارْذعْ نتَّا إِ وغْيُوڒْ نّسْ، إِكَّارْ، يُويُورْ غَارْ ثَادَّارْثْ نّسْ ذِي ثنْذِينْثْ نّسْ. نتَّا يُومُورْ إِ ثَادَّارْثْ نّسْ، \add خنِّي\add* يُويڒْ إِخفْ نّسْ. \add أَمُّو\add* إِ إِمُّوثْ ؤُ إِتّْوَانْضڒْ ذڭْ ونْضڒْ ن بَابَاسْ.   
\m
\v 24 ذَاوُوذْ يِيوضْ غَارْ مَاحَانَايِيمْ، ؤُ أَبْشَالُومْ إِژْوَا لْ-ؤُرْذُونْ، نتَّا ذ مَارَّا إِرْيَازنْ ن إِسْرَائِيل أَكِيذسْ.  
\v 25 أَبْشَالُومْ ثُوغَا إِڭَّا عَامَاسَا خْ ڒْعسْكَارْ ذڭْ ومْشَانْ ن يُووَابْ. عَامَاسَا ثُوغَا ذ مِّيسْ ن إِجّْ ن ورْيَازْ قَّارنْ أَسْ يِيثْرَا، إِجّْ ن ورْيَازْ زِي إِسْرَائِيل، ونِّي ثُوغَا يُوذْفنْ خْ أَبِيجَايِيلْ، يدْجِيسْ ن نَاحَاشْ، ؤُتْشْمَاسْ ن صَارُويَا، يمَّاسْ ن يُووَابْ.  
\v 26 إِسْرَائِيل ذ أَبْشَالُومْ وْثِينْ إِقِيضَانْ نْسنْ ذِي ثمُّورْثْ ن جِيلْعَاذْ.   
\m
\v 27 ؤُمِي د-يُوسَا ذَاوُوذْ غَارْ مَاحَانَايِيمْ، إِمْسَارْ، أَقَا شُوبِي، مِّيسْ ن نَاحَاشْ، زِي رَابَّا، زڭْ أَيْثْ ن عَامُّونْ، ذ مَاخِيرْ، مِّيسْ ن عَامِّييِيلْ زِي لُو-ذَابَارْ، ذ بَارْزِيلَايْ، أَجِيلْعَاذِي زِي رُوجَالِيمْ \add إِوْينْ أَسْ-د مَارَّا مَانْ أَيَا\add*: \x ◘ \xo 17:‏27 \xt 2 صم. 19‏:‏31، 32؛ 1 إِج. 2‏:‏7\x*  
\v 28 إِفَارَّاشنْ ذ طّْبَاصِي ذ إِقْذِيحنْ ن ثْڒَاخْثْ ذ إِرْذنْ ذ إِمنْذِي ذ وَارنْ، \add أَقَا\add* ڒحْبُوبْ قْڒَانْ، ؤُشَا ؤُڒَا ذ إِبَاونْ ذ ڒعْذسْ، \add أَقَا\add* \add ؤُڒَا ذ نِيثْنِي\add* قْڒَانْ،  
\v 29 ذ ثَامّنْثْ ذ دّْهنْ ذ وُودْجِي ذ ثْرُوسِّي ن ثْفُونَاسِينْ. نِيثْنِي إِوْينْ مَارَّا مَانْ أَيَا غَارْ ذَاوُوذْ ذ ڒْڭنْسْ إِ غَارسْ إِدْجَانْ مَاحنْذْ أَذْ شّنْ. مَاغَارْ نَّانْ: ”ڒْڭنْسْ إِدْجُوژْ، إِهيّفْ، إِفُّوذْ \add ذِينْ\add* ذِي ڒخْڒَا.“   
\b  
\b  
\m  
\c 18
\s1 أَغلّبْ خْ أَبْشَالُومْ ذ ڒْموْثْ نّسْ  
\m
\v 1 إِسدّْ ذَاوُوذْ ڒْڭنْسْ نِّي ثُوغَا غَارسْ إِدْجَانْ ؤُ إِڭَّا خَاسنْ إِمقّْرَاننْ خْ وَاڒفْ ذ إِمقّْرَاننْ خْ مْيَا.  
\v 2 ذَاوُوذْ إِسّكّْ ڒْڭنْسْ. إِشْثْ ن ثُوڒُوثْ زَّايْسنْ سَاذُو ؤُفُوسْ ن يُووَابْ، إِشْثْ ن تُّوڒُوثْ سَاذُو ؤُفُوسْ ن أَبِيشَايْ، مِّيسْ ن صَارُويَا، ؤُمَاسْ ن يُووَابْ، ذ إِشْثْ ن ثُوڒُوثْ سَاذُو أَفُوسْ ن إِتَّايْ، زِي جَاثْ. إِنَّا ؤُجدْجِيذْ إِ ڒْڭنْسْ: ”ؤُڒَا ذ نشّْ أَذْ أَكِيذْومْ فّْغغْ \add غَارْ ؤُمنْغِي\add*.“  
\v 3 \add مَاشَا\add* ڒْڭنْسْ إِنَّا: ”شكْ وَارْ كِيذْنغْ ثفّْغضْ شَا \add غَارْ ؤُمنْغِي\add*، مَاغَارْ مَاڒَا نشِّينْ نَارْوڒْ س ثِيذتّْ، وَارْ كِيذْنغْ ڒهِّينْ. مَاڒَا أَزْينْ زَّايْنغْ إِمُّوثْ، وَارْ كِيذْنغْ ڒهِّينْ. مَاغَارْ شكْ \add ڒخُّو\add* ثْسكّْوِّيذْ أَمْعشْرَا ن ڒُوڒُوفْ زَّايْنغْ. س ؤُينِّي ڒخُّو مْلِيهْ، مَاڒَا شكْ أَذْ أَنغْ ثوْشذْ أَفُوسْ زِي ثنْذِينْثْ.“  
\v 4 \add خنِّي\add* إِنَّا أَسنْ ؤُجدْجِيذْ: ”نشّْ أَذْ ڭّغْ مِينْ ثتّْوَاڒَامْ مْلِيحْ ذِي ثِيطَّاوِينْ نْومْ!“ أَجدْجِيذْ إِبدّْ غَارْ ثوَّارْثْ \add ن ثنْذِينْثْ\add* ؤُ مَارَّا ڒْڭنْسْ إِفّغْ س ڒْمْيَاوَاثْ ذ ڒُوڒُوفْ.  
\v 5 يُومُورْ ؤُجدْجِيذْ إِ يُووَابْ، أَبِيشَايْ ذ إِتَّايْ: ”أڭّْ س ؤُحَاوڒْ أَكْ-ذ ؤُحُوذْرِي، أَكْ-ذ أَبْشَالُومْ، ذِي طّْوعْ إِنُو.“ مَارَّا ڒْڭنْسْ إِسْڒَا إِ ؤُجدْجِيذْ أَمْ يُومُورْ مَارَّا إِمقّْرَاننْ خْ أَبْشَالُومْ.   
\m
\v 6 ڒْڭنْسْ إِفّغْ غَارْ إِيَّارْ، غَارْ ؤُمْسَاڭَارْ أَكْ-ذ إِسْرَائِيل. أَمنْغِي إِكَّارْ ذڭْ وزْغَارْ ن إِفْرَايِيمْ. \f ◼ \fr 18:‏6 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  
\v 7 تّْوَاغلّْبنْ ذِينْ \add إِرْيَازنْ ن\add* ڒْڭنْسْ ن إِسْرَائِيل زَّاثْ إِ وُوذمْ ن إِمْسخَّارنْ ن ذَاوُوذْ. ذڭْ وَاسّْ نِّي ثمْسَارْ ذِينْ إِشْثْ ن ثشْثِي ثَامقّْرَانْثْ \add أَڒَامِي وْضَانْ\add* عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add*.  
\v 8 أَمنْغِي إِفّغْ سّنِّي ذِي مَارَّا جّْوَايهْ. ذڭْ وَاسّْ نِّي إِسَارْضْ وزْغَارْ \add إِرْيَازنْ\add* زِي ڒْڭنْسْ كْثَارْ زڭْ إِنِّي إِسَارْضْ سِّيفْ.   
\m
\v 9 إِمْسَارْ أَبْشَالُومْ إِبدّْ ثِيطّْ ذِي ثِيطّْ أَكْ-ذ إِمْسخَّارنْ ن ذَاوُوذْ. أَبْشَالُومْ إِنْيَا خْ إِجّْ ن ؤُسرْذُونْ. ؤُمِي أَسرْذُونْ يُويُورْ سَاذُو ڒفْرُوعْ إِمْشُوبّْشنْ ن يِيشْثْ ن ثْشجَّارْثْ ن يِيڭّْ أَمقّْرَانْ، إِنُّوغْ نتَّا س ؤُزدْجِيفْ نّسْ ذِي ثْشجَّارْثْ ن يِيڭّْ أَڒَامِي إِقِّيمْ إِتّنُّويڒْ جَارْ ؤُجنَّا ذ ثمُّورْثْ ذ ؤُسرْذُونْ يُويُورْ سْوَادَّايْ نّسْ.  
\v 10 إِجّْ ن ورْيَازْ إِژْرَا إِ-ث، إِحَاجَا ث إِ يُووَابْ، إِنَّا: ”خْزَارْ، نشّْ ژْرِيغْ أَبْشَالُومْ يُويڒْ غَارْ إِشْثْ ن ثْشجَّارْثْ ن يِيڭّْ.“  
\v 11 إِنَّا يُووَابْ إِ ورْيَازْ إِ ذ أَسْ إِحَاجَانْ أَيَا: ”خْزَارْ، شكْ ثژْرِيذْ \add ث\add*، مَايمِّي وَارْ ث ثژْوِيضذْ شَا ذِينِّي غَارْ ثمُّورْثْ؟ \add خنِّي إِڒِي\add* نشّْ أَذْ أَشْ وْشغْعشْرَا ن \add ؤُقِييَّاثْ ن\add* نُّوقَارْثْ ذ إِجّْ ن وبْيَاسْ!“  
\v 12 إِنَّا ورْيَازْ إِ يُووَابْ: ”وَارْ وزّْنغْ ؤُڒَا ذ أَڒفْ ن \add ؤُقِييَّاثْ ن\add* نُّوقَارْثْ ذڭْ إِفَاسّنْ إِنُو، وَارْ سّْوِيژِّيضغْ أَفُوسْ إِنُو خْ مِّيسْ ن ؤُجدْجِيذْ، مَاغَارْ أَجدْجِيذْ يُومُورْ إِ شكْ ذ أَبِيشَايْ ذ إِتَّايْ ذڭْ إِمزُّوغنْ ن ڒْڭنْسْ، إِنَّا: ’أجّْ كُوڒْ  إِجّْ أَذْ إِحْضَا خْ ؤُحُوضْرِي أَبْشَالُومْ!‘  
\v 13 مَاڒَا نشّْ أَذْ ڭّغْ س ڒْغشّْ أَكْ-ذ ڒعْمَارْ نّسْ - أَقَا إِ ؤُجدْجِيذْ وَارْ ثقِّيمْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ ثْخمّڒْ - خنِّي شكْ أَذْ خَافِي ثكَّارذْ.“  
\v 14 \add خنِّي\add* إِنَّا يُووَابْ: ”نشّْ وَارْ خَاكْ تّْرَاجِيغْ.“ ؤُ نتَّا إِكْسِي ثْڒَاثَا ن لَانْسَاثْ، إِجُّو أَسْ ثنْثْ ذڭْ وُوڒْ ن أَبْشَالُومْ، أَمْ نتَّا عَاذْ يُويڒْ إِدَّارْ ذِي ڒْوسْطْ ن ثْشجَّارْثْ ن يِيڭّْ.  
\v 15 عشْرَا ن إِمْسخَّارنْ إِنِّي ذ أَسْ يَاربُّونْ ڒسْنَاحْ إِ يُووَابْ، نّْضنْ أَسْ ؤُشَا وْثِينْ أَبْشَالُومْ، نْغِينْ ث.  
\v 16 \add خنِّي\add* إِسُوضْ يُووَابْ ذڭْ ؤُيِيشّْ ن إِشَارِّي ؤُشَا إِعْقبْ-د ڒْڭنْسْ مَارَّا زڭْ وضْفَارْ ن إِسْرَائِيل، مِينْزِي يُووَابْ إِخْسْ أَذْ إِحَاوڒْ خْ ڒْڭنْسْ.  
\v 17 نِيثْنِي كْسِينْ أَبْشَالُومْ، نْضَارنْ ث ذڭْ وزْغَارْ ذِي ثسْرَافْثْ ثُودْجغْ ؤُ سَّارْبُونْ خَاسْ إِجّْ ن ؤُعُورِّيشْ ن يژْرَا إِمْغَارْ أَطَّاسْ. مَارَّا إِسْرَائِيل إِطّفْ ذِي ثَاروْڒَا، \add كُوڒْ\add* أَرْيَازْ غَارْ ؤُقِيضُونْ نّسْ.  
\v 18 ؤُمِي ثُوغَا إِدَّارْ، إِكْسِي أَبْشَالُومْ إِ يِيخفْ نّسْ إِجّْ ن ؤُمَايْضُو \add إِقدّْسنْ\add*، إِسّْبدّْ إِ-ث ذِي ثغْزُورْثْ ن ؤُجدْجِيذْ، مِينْزِي إِنَّا: ”نشّْ وَارْ غَارِي بُو مِّي إِ غَا إِسّعْقڒْ إِسمْ إِنُو.“ نتَّا إِڒَاغَا أَسْ إِ ؤُمَايْضُو نِّي س يِيسمْ نّسْ. أَڒْ أَسّْ-أَ قَّارنْ أَسْ \add إِ ؤُمَايْضُو نِّي\add* ’أَفُوسْ ن أَبْشَالُومْ‘.   
\m
\v 19 \add خنِّي\add* إِنَّا أَخِيمَاعَاصْ، مِّيسْ ن صَاذُوقْ: ”أجّْ أَيِي أَذْ أَزّْڒغْ غَارْ ؤُجدْجِيذْ أَذْ أَسْ سِّيوْضغْ ڒخْبَارْ أَصبْحَانْ، أَقَا سِيذِي إِحْضَا ث زڭْ إِفَاسّنْ ن ڒْعذْيَانْ نّسْ.“  
\v 20 \add مَاشَا\add* يُووَابْ إِنَّا أَسْ: ”أَسّْ-أَ وَارْ ثسِّيوْضذْ شَا ڒخْبَارْ أَصبْحَانْ، \add مَاشَا\add* ذڭْ إِجّْ ن وَاسّْ نّغْنِي \add ثْزمَّارذْ\add* أَذْ ثسِّيوْضذْ ڒخْبَارْ أَصبْحَانْ. أَسّْ-أَ وَارْ ثسِّيوْضذْ أَرقَّاسْ ذ أَصبْحَانْ مَاغَارْ مِّيسْ ن ؤُجدْجِيذْ إِمُّوثْ.“  
\v 21 إِنَّا يُووَابْ إِ ؤُكُوشِي: ”ؤُيُورْ، إِنِي إِ ؤُجدْجِيذْ، مِينْ ثژْرِيذْ شكْ!“ أَكُوشِي إِبنْذقْ زَّاثْ إِ يُووَابْ ؤُشَا \add خنِّي\add* يُوزّڒْ.  
\v 22 \add خنِّي\add* أَخِيمَاعَاصْ، مِّيسْ ن صَاذُوقْ، إِنَّا إِشْثْ ن ثْوَاڒَا نّغْنِيثْ إِ يُووَابْ: ”أَذْ د-يَاسْ وِي إِخْسنْ، أجّْ أَيِي ؤُڒَا ذ نشّْ أَذْ أَزّْڒغْ أَوَارْنِي إِ ؤُكُوشِي!“ إِنَّا يُووَابْ: ”مَايمِّي ثخْسذْ \add عَاذْ\add* أَذْ ثَازّْڒذْ، أَ مِّي؟ وَارْ إِتّْوَافْ \add عَاذْ\add* أَرقَّاسْ ذ أَصبْحَانْ إِ شكْ، \add مَاحنْذْ أَذْ ث ثسِّيوْضذْ\add*!“  
\v 23 \add إِنَّا\add*: ”أَذْ د-يَاسْ وِي إِخْسنْ، نشّْ خْسغْ أَذْ \add ذِينْ\add* أَزّْڒغْ.“ \add خنِّي\add* إِنَّا أَسْ يُووَابْ: ”أَزّڒْ!“ ؤُشَا أَخِيمَاعَاصْ يُوزّڒْ خْ وبْرِيذْ ن ؤُذوَّارْ \add ن لْ-ؤُرْذُونْ\add* ؤُشَا إِزَّارْ نتَّا أَكُوشِي.   
\m
\v 24 ذَاوُوذْ إِقِّيمْ جَارْ ثْنَاينْ ن ثوُّورَا \add ن ثنْذِينْثْ\add*. أَعسَّاسْ إِڭعّذْ ثَازقَّا ن ثوَّارْثْ \add إِ إِدْجَانْ\add* غَارْ ڒْحِيضْ، إِسّْڭعّذْ ثَامُوغْڒِي نّسْ، إِشيّعْ، إِژْرَا إِجّْ ن ورْيَازْ إِتَّازّڒْ، نتَّا وحّْذسْ.  
\v 25 أَعسَّاسْ إِڒَاغَا، إِنَّا إِ-ت إِ ؤُجدْجِيذْ. أَجدْجِيذْ إِنَّا: ”مَاڒَا نتَّا وحّْذسْ، خنِّي أَذْ يَاوضْ إِجّْ ن ڒخْبَارْ ذ أَصبْحَانْ!“ يَارْنِي إِقَارّبْ-د ورْيَازْ.  
\v 26 \add خنِّي\add* إِژْرَا ؤُعسَّاسْ \add عَاذْ\add* إِجّْ ن ورْيَازْ نّغْنِي إِتَّازّڒْ ؤُشَا إِڒَاغَا غَارْ ؤُعسَّاسْ ن ثوَّارْثْ، إِنَّا: ”خْزَارْ، \add إِتَّازّڒْ ذِينْ\add* عَاذْ إِجّْ ن ورْيَازْ نّغْنِي، ؤُڒَا ذ نتَّا وحّْذسْ.“ أَجدْجِيذْ إِنَّا: ”ؤُڒَا ذ نتَّا أَذْ يَاوضْ إِجّْ ن ڒخْبَارْ ذ أَصبْحَانْ.“  
\v 27 أَعسَّاسْ إِنَّا \add عَاوذْ\add*: ”نشّْ تّْوَاڒِيغْ أَمزْوَارُو إِڭُّورْ أَمْ أَخِيمَاعَاصْ، مِّيسْ ن صَاذُوقْ.“ إِنَّا ؤُجدْجِيذْ: ”وَا ذ إِجّْ ن ورْيَازْ إِصْبحْ، نتَّا أَذْ د-يَاسْ س يِيجّْ ن ؤُرقَّاسْ ذ أَصبْحَانْ.“  
\v 28 أَخِيمَاعَاصْ إِڒَاغَا، إِنَّا إِ ؤُجدْجِيذْ: ”ڒهْنَا!“ ؤُ نتَّا إِبنْذقْ زَّاثْ إِ ؤُجدْجِيذْ س ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ، إِنَّا: ”أَذْ إِتّْوَابَاركْ سِيذِي، أَربِّي نّشْ، ونِّي ذ أَشْ إِسلّْمنْ إِرْيَازنْ نِّي إِڭعّْذنْ أَفُوسْ نْسنْ خْ سِيذِي إِنُو أَجدْجِيذْ.“  
\v 29 إِنَّا ؤُجدْجِيذْ: ”مَا أَحُوذْرِي، أَبْشَالُومْ، أَقَا-ث مْلِيحْ؟“ إِنَّا أَخِيمَاعَاصْ: ”نشّْ ژْرِيغْ إِجّْ ن ؤُبَارُّو ذ أَمقّْرَانْ ؤُمِي يُووَابْ، أَمْسخَّارْ ن ؤُجدْجِيذْ، إِسّكّْ أَمْسخَّارْ نّشْ، \add مَاشَا\add* نشّْ وَارْ سِّينغْ مِينْ \add إِمْسَارنْ\add*.“  
\v 30 إِنَّا ؤُجدْجِيذْ: ”حيّذْ غَارْ ؤُغزْذِيسْ، بدّْ ذَا!“ ؤُ نتَّا إِحيّذْ غَارْ ؤُغزْذِيسْ، إِقِّيمْ إِبدّْ \add ذِينِّي\add*.  
\v 31 ؤُشَا خْزَارْ، يُوسَا-د ؤُڒَا ذ أَكُوشِي. أَكُوشِي إِنَّا: ”خْزَارْ، إِجّْ ن ڒخْبَارْ ذ أَصبْحَانْ إِ سِيذِي إِنُو، أَجدْجِيذْ. سِيذِي إِحْضَا شكْ زڭْ ؤُفُوسْ ن مَارَّا إِنِّي خَاكْ إِغوّْغنْ.“  
\v 32 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ إِ ؤُكُوشِي: ”مَا أَحُوذْرِي، أَبْشَالُومْ، أَقَا-ث مْلِيحْ؟“ إِنَّا ؤُكُوشِي: ”إِڒِي أَذْ ذوْڒنْ مَارَّا ڒْعذْيَانْ ن سِيذِي إِنُو أَجدْجِيذْ ذ مَارَّا إِنِّي خَاكْ إِغوّْغنْ مَاحنْذْ أَذْ شكْ ڭّنْ ثُوعفّْنَا أَمْ ؤُحُوضْرِي.“   
\b  
\b  
\m  
\c 19
\s1 ذَاوُوذْ إِشْضنْ خْ أَبْشَالُومْ  
\m
\v 1 \add خنِّي\add* إِنّخْڒعْ ؤُجدْجِيذْ أَطَّاسْ، إِڭعّذْ غَارْ وخَّامْ إِ إِدْجَانْ سنّجْ إِ ثوَّارْثْ، إِرُو. ؤُشَا أَمْ إِكَّا سَّا ذ سَّا، إِنَّا \add أَمُّو\add*: ”\add أَ\add* مِّي أَبْشَالُومْ، \add أَ\add* مِّي، \add أَ\add* مِّي أَبْشَالُومْ! إِڒِي نشّْ مُّوثغْ ذڭْ ومْشَانْ نّشْ، \add أَ\add* أَبْشَالُومْ، \add أَ\add* مِّي، \add أَ\add* مِّي!“  
\v 2 نَّانْ إِ يُووَابْ: ”خْزَارْ، أَجدْجِيذْ إِتّْرُو، إِتّشْضِينْ خْ أَبْشَالُومْ.“  
\v 3 ذڭْ وَاسّْ نِّي إِذْوڒْ ؤُسنْجمْ ن مَارَّا ڒْڭنْسْ غَارْ وشْضَانْ، مَاغَارْ ڒْڭنْسْ إِسْڒَا ذڭْ وَاسّْ نِّي: ”أَجدْجِيذْ إِشْضنْ خْ مِّيسْ.“  
\v 4 ذڭْ وَاسّْ نِّي يُوذفْ-د ڒْڭنْسْ غَارْ ثنْذِينْثْ أَمْ مَامّشْ إِتّْحَامَا ڒْڭنْسْ إِ إِتّْسضْحَا إِخفْ نّسْ، خْمِي تَّاركّْوَاڒنْ زڭْ ؤُمنْغِي.   
\m
\v 5 أَجدْجِيذْ ثُوغَا إِڒحّفْ إِ ؤُغمْبُوبْ نّسْ، إِتّْڒَاغَا ؤُجدْجِيذْ س ثْمِيجَّا إِجهْذنْ: ”\add أَ\add* مِّي أَبْشَالُومْ، أَبْشَالُومْ، \add أَ\add* مِّي، \add أَ\add* مِّي!“  
\v 6 \add خنِّي\add* يُوذفْ يُووَابْ غَارْ ؤُجدْجِيذْ ذِي ثَادَّارْثْ، إِنَّا: ”شكْ أَسّْ-أَ ثسّْحشْمذْ ؤُذمْ ن مَارَّا إِمْسخَّارنْ نّشْ إِنِّي د-إِفكّنْ أَسّْ-أَ ڒعْمَارْ نّشْ ذ ڒعْمَارْ ن إِحنْجِيرنْ نّشْ ذ ثْحنْجِيرِينْ نّشْ ؤُڒَا ذ ڒعْمَارْ ن ثمْغَارِينْ نّشْ ذ ڒعْمَارْ ن ثِييَّا نّشْ،  
\v 7 ؤُمِي ثخْسذْ إِنِّي شكْ إِتّْعِيفّنْ ؤُ ؤُمِي ثْعِيفّذْ إِنِّي شكْ إِتّخْسنْ. مَاغَارْ شكْ ثوْشِيذْ أَنغْ أَسّْ-أَ أَذْ نسّنْ، أَقَا غَاركْ إِمقّْرَاننْ ذ إِمْسخَّارنْ وَارْ سكّْوِينْ وَالُو. إِوَا أَسّْ-أَ سّْنغْ، مَاڒَا أَبْشَالُومْ إِدَّارْ ؤُ نشِّينْ مَارَّا ثُوغَا نمُّوثْ، مَانْ أَيَا أَذْ يِيڒِي نِيشَانْ ذِي ثِيطَّاوِينْ نّشْ.  
\v 8 خنِّي ڒخُّو، كَّارْ، فّغْ غَارْ بَارَّا، ؤُشَا سِيوڒْ غَارْ وُوڒْ ن إِمْسخَّارنْ نّشْ، مَاغَارْ نشّْ أَذْ أَشْ جَّادْجغْ غَارْ سِيذِي، مَاڒَا شكْ وَارْ ثفِّيغذْ غَارْ بَارَّا، خنِّي دْجِيڒثْ-أَ وَارْ إِتّْغِيمِي أَذْ غَاركْ إِسّنْسْ ؤُڒَا ذ إِجّْ ن ورْيَازْ. ذ مَانْ أَيَا أَذْ يِيڒِي مَاهُو إِ شكْ خْ مَارَّا ثُوعفّْنَا إِ شكْ إِڒقْفنْ زِي ثمْژِي نّشْ أَڒْ إِضَا.“  
\v 9 \add خنِّي\add* إِكَّارْ ؤُجدْجِيذْ، إِقِّيمْ ذِي ثوَّارْثْ ن ثنْذِينْثْ. ؤُ نِيثْنِي خبَّارنْ مَارَّا ڒْڭنْسْ، نَّانْ: ”خْزَارْ، أَجدْجِيذْ إِقِّيمْ ذِي ثوَّارْثْ.“ ؤُشَا يُوسَا-د مَارَّا ڒْڭنْسْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ. \add مَاشَا\add* إِسْرَائِيل يَارْوڒْ، \add كُوڒْ\add* أَرْيَازْ غَارْ إِقِيضَانْ نّسْ.   
\b  
\m  
\s1 أَعْقَابْ ن ذَاوُوذْ غَارْ ؤُرْشَالِيمْ  
\m
\v 10 ؤُشَا مَارَّا ڒْڭنْسْ، ذِي مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل، ثُوغَا إِتّمْشُوبّشْ، نِيثْنِي نَّانْ: ”أَجدْجِيذْ إِسّنْجمْ أَنغْ زڭْ ؤُفُوسْ ن ڒْعذْيَانْ نّغْ ؤُ نتَّا إِفكّْ أَنغْ زڭْ ؤُفُوسْ ن إِفِيلِيسْطِينِييّنْ ؤُ ڒخُّو يَارْوڒْ زِي ثمُّورْثْ زِي سِّيبّثْ ن أَبْشَالُومْ،  
\v 11 \add ؤُمِي\add* أَبْشَالُومْ، ونِّي نذْهنْ نشِّينْ \add ذ أَجدْجِيذْ\add* خَانغْ، إِمُّوثْ ذڭْ ؤُمنْغِي. \add خنِّي\add* ڒخُّو، مَايمِّي ثسُّوسْممْ \add أَمُّو\add* حِيمَا أَذْ د-ثَارّمْ أَجدْجِيذْ عَاوذْ \add غَارْ ذَا\add*؟“  
\v 12 \add خنِّي\add* إِسّكّْ أَجدْجِيذْ ذَاوُوذْ \add إِجّْ ن ؤُرقَّاسْ\add* غَارْ إِكهَّاننْ صَاذُوقْ ذ أَبْيَاثَارْ، إِنَّا: ”سِيوڒْ أَكْ-ذ إِمْغَارنْ ن يَاهُوذَا، إِنِي: ’مَايمِّي ثخْسمْ أَذْ ثِيڒِيمْ ذ إِنڭُّورَا حِيمَا أَذْ ثَارّمْ أَجدْجِيذْ غَارْ ثَادَّارْثْ نّسْ؟‘ - \add مِينْزِي\add* أَوَاڒنْ ن مَارَّا إِسْرَائِيل إِوْضنْ غَارْ ؤُجدْجِيذْ ذِي ثَادَّارْثْ نّسْ -  
\v 13 ’كنِّيوْ ذ أَيْثْمَا إِنُو، كنِّيوْ ذ إِغْسَانْ إِنُو ذ ويْسُومْ إِنُو. مَايمِّي ثخْسمْ خنِّي أَذْ ثِيڒِيمْ ذ إِنڭُّورَا إِ ذ غَا يَارّنْ أَجدْجِيذْ؟‘  
\v 14 ؤُشَا إِ عَامَاسَا أَذْ أَسْ ثِينِيمْ: ’مَا وَارْ إِدْجِي شكْ ذ إِغْسَانْ إِنُو ذ أَيْسُومْ إِنُو؟ أجّْ أَربِّي أَذْ أَيِي إِڭّْ ثَا ذ ثَا، مَاڒَا وَارْ ثتِّيڒِيذْ ذ أَكُومَانْذَارْ ن ڒْعسْكَارْ ذڭْ ومْشَانْ ن يُووَابْ زَّاثْ إِ وُوذمْ إِنُو مَارَّا ؤُسَّانْ.‘ “ \x ◘ \xo 19:‏14 \xt 2 صم. 17‏:‏25\x*  
\v 15 أَمُّو \add إِزمَّارْ\add* ذَاوُوذْ أَذْ غَارسْ د-إِجْبدّْ ؤُڒْ ن مَارَّا إِرْيَازنْ ن يَاهُوذَا أَمْ \add ؤُڒْ\add* ن إِجّْ ن ورْيَازْ ؤُ نِيثْنِي سّكّنْ غَارْ ؤُجدْجِيذْ نَّانْ: ”عْقبْ، شكْ ذ مَارَّا إِمْسخَّارنْ نّشْ.“   
\m
\v 16 \add خنِّي\add* إِعْقبْ-د ؤُجدْجِيذْ ؤُشَا يِيوضْ-د غَارْ لْ-ؤُرْذُونْ، \add ؤُشَا\add* \add أَيْثْ ن\add* يَاهُوذَا ؤُسِينْ-د غَارْ جِيلْجَالْ إِ ؤُمْسَاڭَارْ أَكْ-ذ ؤُجدْجِيذْ مَاحنْذْ أَذْ رَاحنْ أَذْ عَاوْننْ أَژكّْوِي ن ؤُجدْجِيذْ خْ لْ-ؤُرْذُونْ.  
\v 17 ؤُشَا شِيمْعِي، مِّيسْ ن جِيرَا، إِجّْ زڭْ أَيْثْ ن بِينْيَامِينْ زِي بَاخُورِيمْ إِكْسِي ذڭْ ؤُضَارْ نّسْ، إِهْوَا أَكْ-ذ يرْيَازنْ ن يَاهُوذَا إِ ؤُمْسَاڭَارْ أَكْ-ذ ؤُجدْجِيذْ ذَاوُوذْ. \x ◘ \xo 19:‏17 \xt 2 صم. 16‏:‏5؛ 1 إِج. 2‏:‏8\x*  
\v 18 ثُوغَا أَكِيذسْ \add عَاوذْ\add* أَڒفْ ن يرْيَازنْ زِي بِينْيَامِينْ، ؤُڒَا ذ صِيبَا، أَمْسخَّارْ ن ثَادَّارْثْ ن شَاوُولْ أَكْ-ذ خمّسْطَاشْ ن إِحنْجِيرنْ نّسْ ذ عِيشْرِينْ ن إِمْسخَّارنْ نّسْ أَكِيذسْ. نِيثْنِي إِوْضنْ أَذْ عْذُونْ لْ-ؤُرْذُونْ قْبڒْ إِ د غَا يَاسْ \add ذِينِّي\add* ؤُجدْجِيذْ.  
\v 19 ثژْوَا ثْغَارَّابُوثْ إِ ؤُسژْوِي ن ثَادَّارْثْ ن ؤُجدْجِيذْ ؤُ حِيمَا أَذْ ثڭّْ مِينْ إِدْجَانْ ذ لمْلِيحْ ذِي ثِيطَّاوِينْ نّسْ. ؤُ شِيمْعِي، مِّيسْ ن جِيرَا، إِوْضَا \add س ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ\add* زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ، ؤُمِي د-إِژْوَا وَانِيثَا لْ-ؤُرْذُونْ،  
\v 20 ؤُ نتَّا إِنَّا إِ ؤُجدْجِيذْ: ”أجّْ سِيذِي إِنُو وَارْ ذ أَيِي إِحسّبْ ڒْمُوعْصِييّثْ إِنُو، أجّْ إِ-ث وَارْ إِتِّيذَارْ \add عَاذْ\add* ذڭْ ؤُفَارْيضْ إِ إِڭَّا ؤُمْسخَّارْ نّشْ ذڭْ وَاسّْ ؤُمِي إِفّغْ سِيذِي إِنُو أَجدْجِيذْ زِي ؤُرْشَالِيمْ، حِيمَا أَجدْجِيذْ وَارْ ت إِكسِّي أَمُّو غَارْ وُوڒْ \add حِيمَا أَذْ زَّايِي إِنْثَاقمْ\add*.  
\v 21 مَاغَارْ أَمْسخَّارْ نّشْ إِسّنْ: نشّْ، \add وَاهْ،\add* نشّْ خْضِيغْ، \add مَاشَا\add* خْزَارْ، نشّْ أَسّْ-أَ ذ أَمزْوَارُو زِي مَارَّا ثَادَّارْثْ ن يُوسُوفْ إِ د-إِهْوَانْ، حِيمَا أَذْ مْسَاڭَارغْ سِيذِي إِنُو أَجدْجِيذْ.“   
\m
\v 22 \add خنِّي\add* يَارَّا-د أَبِيشَايْ، مِّيسْ ن صَارُويَا، إِنَّا: ”زعْمَا وَارْ إِتّْخصِّي شِيمْعِي أَذْ إِمّثْ خْ مَانْ أَيَا؟ أَقَا نتَّا إِنْعڒْ أَمذْهُونْ ن سِيذِي.“  
\v 23 \add مَاشَا\add* ذَاوُوذْ إِنَّا: ”مِينْ جَارْ أَيِي-د أَكِيذْومْ، أَرَّاوْ ن صَارُويَا، ؤُمِي ثْذوْڒمْ أَيِي أَسّْ-أَ \add أَمْ\add* إِجّْ ن وغْرِيمْ؟ مَا إِتّْخصَّا أَذْ إِتّْوَانغْ أَسّْ-أَ شَا ن إِجّْ ذِي إِسْرَائِيل؟ أَخْمِي نشّْ وَارْ سِّينغْ، أَقَا نشّْ أَسّْ-أَ ذوْڒغْ ذ أَجدْجِيذْ خْ إِسْرَائِيل؟“  
\v 24 أَجدْجِيذْ إِنَّا إِ شِيمْعِي: ”شكْ وَارْ ثتّْمتِّيذْ شَا!“ ؤُشَا أَجدْجِيذْ إِجُّودْجْ أَسْ \add ث\add*.   
\m
\v 25 ؤُڒَا ذ مَافِيبُوشَاثْ، مِّيسْ ن شَاوُولْ، يُوسَا-د إِ ؤُمْسَاڭَارْ أَكْ-ذ ؤُجدْجِيذْ. نتَّا ثُوغَا وَارْ إِسِّيرْذْ إِضَارنْ نّسْ، ؤُ وَارْ إِحفّْ أَشْڒَاغمْ نّسْ ؤُ وَارْ إِصبّنْ أَرُّوضْ نّسْ زڭْ وَاسّْ إِ ذِي إِفّغْ ؤُجدْجِيذْ أَڒْ أَسّْ إِ ذِي د-إِعْقبْ نتَّا ذِي ڒهْنَا.  
\v 26 ؤُمِي د-يُوسَا ذِي ؤُرْشَالِيمْ إِ ؤُمْسَاڭَارْ أَكْ-ذ ؤُجدْجِيذْ، إِمْسَارْ، أَقَا إِنَّا أَسْ ؤُجدْجِيذْ: ”مَايمِّي وَارْ كِيذِي ثْرُوحذْ، مَافِيبُوشَاثْ؟“  
\v 27 نتَّا إِنَّا أَسْ: ”سِيذِي إِنُو أَجدْجِيذْ، أَمْسخَّارْ إِنُو إِغْذَارْ أَيِي، مَاغَارْ أَمْسخَّارْ نّشْ إِنَّا: ’نشّْ خْسغْ أَذْ بَارْذْعغْ إِ وغْيُوڒْ، أَذْ خَاسْ نْيغْ، أَذْ رَاحغْ أَكْ-ذ ؤُجدْجِيذْ!‘، مَاغَارْ أَمْسخَّارْ نّشْ ذ أَقجْذَاحْ.  
\v 28 نتَّا إِشقّفْ ذڭْ ؤُمْسخَّارْ نّشْ غَارْ سِيذِي إِنُو أَجدْجِيذْ. \add مَاشَا\add* سِيذِي إِنُو أَجدْجِيذْ، أَمْ يِيجّْ ن لْمَالَاكْ ن أَربِّي. أڭّْ مِينْ إِدْجَانْ ذ لمْلِيحْ ذِي ثِيطَّاوِينْ نّشْ. \x ◘ \xo 19:‏28 \xt 2 صم. 16‏:‏3\x*  
\v 29 مِينْزِي مَارَّا ثَادَّارْثْ ن بَابَا ثُوغَا وَارْ ثدْجِي مْغِيرْ إِرْيَازنْ إِمتِّيننْ إِ سِيذِي إِنُو أَجدْجِيذْ. \add وَاخَّا أَمنِّي\add* شكْ ثسّْغِيمذْ أَمْسخَّارْ نّشْ غَارْ يِينِّي إِتّتّنْ غَارْ طَّابْڒَا نّشْ! مِينْ غَارِي عَاذْ ذ ثَاسْغَارْثْ ؤُ إِ ؤُمِي غَا تَّارغْ عَاذْ كْثَارْ غَارْ ؤُجدْجِيذْ؟“  
\v 30 أَجدْجِيذْ إِنَّا أَسْ: ”مَايمِّي ثسَّاوَاڒذْ عَاذْ أَمُّو خْ ثْمسْڒَايِينْ نّشْ؟ نشّْ قَّارغْ أَشْ: شكْ ذ صِيبَا، كنِّيوْ أَذْ ثبْضَامْ ثَامُّورْثْ.“  
\v 31 إِنَّا مَافِيبُوشَاثْ إِ ؤُجدْجِيذْ: ”نتَّا إِزمَّارْ أَذْ ت إِكْسِي مَارَّا، مَاغَارْ سِيذِي إِنُو أَجدْجِيذْ، أَقَا إِعْقبْ غَارْ ثَادَّارْثْ نّسْ ذِي ڒهْنَا.“   
\m
\v 32 بَارْزِيلَّايْ، أَجِيلْعَاذِي، إِهْوَا زِي رُوجَالِيمْ مَاحنْذْ أَذْ ث إِوْشْ أَفُوسْ إِ ؤُجدْجِيذْ غَارْ ؤُژكّْوُو ن لْ-ؤُرْذُونْ، حِيمَا أَذْ ث إِسّْقبّضْ \add أَمُّو\add* خْ لْ-ؤُرْذُونْ.  
\v 33 بَارْزِيلَّايْ ثُوغَا إِوْسَارْ أَطَّاسْ، إِجّْ ن ورْيَازْ ن ثْمنْيِينْ ن إِسڭّْوُوسَا. نتَّا ثُوغَا إِكْسِي غَارسْ أَجدْجِيذْ ؤُمِي ث ثُوغَا ذِي مَاحَانَايِيمْ، مِينْزِي نتَّا ثُوغَا-ث ذ إِجّْ ن ورْيَازْ غَارسْ أَڭْڒَا أَطَّاسْ. \x ◘ \xo 19:‏33 \xt  2 صم. 17‏:‏27‏-‏29؛ 1 إِج. 2‏:‏7\x*  
\v 34 أَجدْجِيذْ إِنَّا إِ بَارْزِيلَّايْ: ”ژْوَا أَكِيذِي. نشّْ أَذْ شكْ غَارِي كْسِيغْ ذِي ؤُرْشَالِيمْ.“  
\v 35 \add مَاشَا\add* بَارْزِيلَّايْ إِنَّا إِ ؤُجدْجِيذْ: ”مشْحَاڒْ ن وُوسَّانْ ن إِسڭّْوُوسَا ن ثُوذَارْثْ إِنُو \add عَاذْ ذِينْ\add* أَڒَامِي غَا فّْغغْ أَكْ-ذ ؤُجدْجِيذْ غَارْ ؤُرْشَالِيمْ؟  
\v 36 أَسّْ-أَ نشّْ غَارِي ثْمنْيِينْ ن إِسڭّْوُوسَا. مَا زمَّارغْ أَذْ فَارْزغْ \add عَاذْ\add* مِينْ إِصبْحنْ زِي مِينْ وَارْ إِحْڒِينْ؟ مَا إِزمَّارْ ؤُمْسخَّارْ نّشْ أَذْ إِقَّاسْ مِينْ غَا شّغْ ذ مِينْ غَا سْوغْ؟ مَا زمَّارغْ أَذْ سْڒغْ عَاذْ إِ ثْمِيجَّا ن إِمذْيَازنْ ذ ثْمذْيَازِينْ؟ مَايمِّي غَا إِسّذْقڒْ ؤُمْسخَّارْ نّشْ عَاذْ خْ سِيذِي إِنُو أَجدْجِيذْ؟  
\v 37 أَمْسخَّارْ نّشْ أَذْ إِژْوَا لْ-ؤُرْذُونْ أَكْ-ذ ؤُجدْجِيذْ مْغِيرْ شْوَايْثْ. مَايمِّي ذ أَيِي غَا إِوْشْ ؤُجدْجِيذْ ثَاربَّاحْثْ-أَ؟  
\v 38 أجّْ أَمْسخَّارْ نّشْ أَذْ إِعْقبْ حِيمَا أَذْ مّْثغْ ذِي ثنْذِينْثْ إِنُو، غَارْ ونْضڒْ ن بَابَا ذ يمَّا. خْزَارْ، أَقَا ذَا أَمْسخَّارْ نّشْ كِيمْهَامْ! أجّْ إِ-ث أَذْ إِژْوَا أَكْ-ذ سِيذِي إِنُو أَجدْجِيذْ. أڭّْ أَسْ مِينْ ثتّْوَاڒِيذْ مْلِيحْ ذِي ثِيطَّاوِينْ نّشْ.“  
\v 39 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ: ”كِيمْهَامْ أَذْ كِيذِي إِژْوَا ؤُ مِينْ ثتّْوَاڒِيذْ مْلِيحْ ذِي ثِيطَّاوِينْ نّشْ، أَذْ أَسْ ث ڭّغْ. مَارَّا مِينْ زَّايِي ثسُّوثَارذْ، أَذْ أَشْ ث ڭّغْ.“   
\m
\v 40 \add ؤُمِي\add* إِژْوَا مَارَّا ڒْڭنْسْ لْ-ؤُرْذُونْ، إِژْوَا ؤُڒَا ذ أَجدْجِيذْ. أَجدْجِيذْ إِسُّوذمْ بَارْزِيلَّايْ، إِبَاركْ إِ-ث. \add خَاسْ ؤُشَا\add* إِذْوڒْ نتَّا غَارْ ثمُّورْثْ نّسْ.   
\m
\v 41 أَجدْجِيذْ مَاشَا يَارْنِي إِعْذُو غَارْ جِيلْجَالْ ؤُ كِيمْهَامْ إِعْذُو أَكِيذسْ. مَارَّا ڒْڭنْسْ ن يَاهُوذَا ثُوغَا إِسّعْذُو أَجدْجِيذْ، ؤُڒَا ذ أَزْينْ ن ڒْڭنْسْ ن إِسْرَائِيل.  
\v 42 ؤُ خْزَارْ، مَارَّا إِرْيَازنْ ن إِسْرَائِيل ؤُسِينْ-د غَارْ ؤُجدْجِيذْ، نَّانْ إِ ؤُجدْجِيذْ: ”مَايمِّي أَيْثْمَاثْنغْ، إِرْيَازنْ ن يَاهُوذَا، ؤُشَارنْ شكْ \add إِ نشِّينْ\add* ؤُ نذْهنْ أَجدْجِيذْ ذ ثَادَّارْثْ نّسْ ڒَامِي ثُوغَا إِژْوَا لْ-ؤُرْذُونْ ذ مَارَّا إِرْيَازنْ ن ذَاوُوذْ أَكِيذسْ؟“  
\v 43 \add خنِّي\add* أَرِّينْ-د مَارَّا إِرْيَازنْ ن يَاهُوذَا خْ يرْيَازنْ ن إِسْرَائِيل: ”مِينْزِي أَجدْجِيذْ إِتّعْنَا أَنغْ-د. مَايمِّي ثْخيّْقمْ خْ ؤُيَا؟ مَا نشَّا نشِّينْ زِي \add مَاشَّا ن\add* ؤُجدْجِيذْ نِيغْ يِيوِي-د نتَّا إِشْثْ ن ثَارْزفْثْ إِ نشِّينْ؟“  
\v 44 إِرْيَازْ\add أنْ\add* ن إِسْرَائِيل أَرِّينْ-د خْ يرْيَازنْ ن يَاهُوذَا، نَّانْ: ”نشِّينْ غَارْنغْعشْرَا ن إِفَاسّنْ غَارْ ؤُجدْجِيذْ، ؤُڒَا أَكْ-ذ ذَاوُوذْ \add غَارْنغْ خنِّي\add* كْثَارْ خَاومْ. مَايمِّي ذ أَنغْ ثسّحْقَارمْ؟ مَا وَارْ إِدْجِي وَاوَاڒْ نّغْ ذ أَمزْوَارُو، مَاحنْذْ أَذْ نَارّْ أَجدْجِيذْ نّغْ؟“ \add ؤُشَا\add* ثُوغَا أَوَاڒْ ن يرْيَازنْ ن يَاهُوذَا إِجْهذْ خْ وَاوَاڒْ ن يرْيَازنْ ن إِسْرَائِيل.   
\b  
\b  
\m  
\c 20
\s1 أَغوّغْ ن شَابْعَا  
\m
\v 1 ثُوغَا ذِينْ إِجّْ ن ورْيَازْ إِ وَارْ إِسكّْوِينْ، قَّارنْ أَسْ شَابَاعْ، مِّيسْ ن بِيكْرِي، إِجّْ ن ؤُبِينْيَامِينِي. نتَّا إِسُوضْ ذڭْ ؤُيِيشّْ ن إِشَارِّي، إِنَّا: ”نشِّينْ وَارْ غَارْنغْ ثَاسْغَارْثْ ذِي ذَاوُوذْ ؤُ نشِّينْ وَارْ غَارْنغْ ڒْوَارْثْ أَكْ-ذ مِّيسْ ن يَاسَّا. \add أجّْ\add* \add كُوڒْ\add* أَرْيَازْ أَذْ يُويُورْ غَارْ إِقِيضَانْ نّسْ، \add أَ\add* إِسْرَائِيل!“  
\v 2 \add خنِّي\add* إِفّغْ كُوڒْ أَرْيَازْ زِي ضفَّارْ ن ذَاوُوذْ، \add إِرُوحْ\add* أَوَارْنِي إِ شَابَاعْ، مِّيسْ ن بِيكْرِي. \add مَاشَا\add* إِرْيَازنْ ن يَاهُوذَا قِّيمنْ ڒسْقنْ أَكْ-ذ ؤُجدْجِيذْ نْسنْ، زِي لْ-ؤُرْذُونْ أَڒْ ؤُرْشَالِيمْ.   
\m
\v 3 \add ؤُمِي\add* يُوذفْ ذَاوُوذْ غَارْ ثَادَّارْثْ نّسْ ذِي ؤُرْشَالِيمْ، إِكْسِي ؤُجدْجِيذْعشْرَا ن ثمْغَارِينْ، ثِييَّا نّسْ ثِينِّي ثُوغَا إِجَّا أَوَارْنِي أَسْ حِيمَا أَذْ حْضَانْثْ ثَادَّارْثْ. نتَّا إِڭَّا إِ-ثنْثْ ذڭْ إِشْثْ ن ثَادَّارْثْ ثتّْوَاحْضَا ؤُ نتَّا إِتّْهِيلَّا ذَايْسنْثْ، مَاشَا وَارْ غَارْسنْثْ يُوذِيفْ. نِيثنْثِي قِّيمنْثْ بلّْعنْثْ أَڒْ أَسّْ ن ڒْموْثْ نْسنْثْ، دَّارنْثْ ذ ثِيجَّاڒْ.   
\m
\v 4 إِنَّا ؤُجدْجِيذْ \add عَاوذْ\add* إِ عَامَاسَا: ”ڒَْاغَا-د خْ يرْيَازنْ ن يَاهُوذَا أَذْ مُوننْ غَارِي ذِي ثْڒَاثَا ن وُوسَّانْ، ؤُشَا \add خنِّي\add* بدّْ شكْ ذَا!“  
\v 5 عَامَاسَا إِفّغْ حِيمَا أَذْ إِڒَاغَا خْ يَاهُوذَا أَذْ سّْمُوننْ، \add مَاشَا\add* نتَّا إِعطّڒْ خْ ڒْوقْثْ إِ ثُوغَا أَكِيذسْ إِڭَّا ؤُجدْجِيذْ.  
\v 6 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ أَبِيشَايْ: ”ڒخُّو أَذْ أَنغْ إِڭّْ شَابَاعْ، مِّيسْ ن بِيكْرِي، ثُوعفّْنَا مَاهُو خْ أَبْشَالُومْ. كْسِي أَكِيذكْ إِمْسخَّارنْ ن سِيذِي ؤُ ضْفَارْ إِ-ث، حِيمَا نتَّا وَارْ إِزمَّارْ أَذْ يَافْ إِ يِيخفْ نّسْ ثِيندَّامْ إِفَارْينْ ؤُشَا أَذْ إِودَّارْ زِي ثِيطَّاوِينْ نّغْ.“  
\v 7 فّْغنْ يرْيَازنْ ن يُووَابْ، \add ؤُيُورنْ\add* أَوَارْنِي أَسْ أَكْ-ذ إِعسَّاسنْ ن أَرِّيمثْ ذ إِرقَّاسنْ ن ثَازْڒَا ذ مَارَّا أَيْثْ ن بُو-ثغْرُوضْثْ. نِيثْنِي فّْغنْ-د زِي ؤُرْشَالِيمْ، حِيمَا أَذْ ضْفَارنْ شَابَاعْ، مِّيسْ ن بِيكْرِي.   
\m
\v 8 \add ؤُمِي\add* ثنْ ثُوغَا غَارْ وژْرُو أَمقّْرَانْ ن جِيبْعُونْ، ثُوغَا عَامَاسَا زَّاثْ إِ وُوذمْ نْسنْ. يُووَابْ ثُوغَا إِتّْحزَّامْ أَرُّوضْ نّسْ ن ؤُمنْغِي إِ يَارْضْ. ثُوغَا خَاسْ إِجّْ ن ؤُحزَّامْ أَكْ-ذ سِّيفْ ذڭْ ؤُفُورُّو ن وغْڒَافْ إِ خَاسْ إِتّْوَاڭّنْ غَارْ ثجْعِينَّا نّسْ. \add ؤُمِي\add* يُويُورْ نتَّا غَارْ زَّاثْ، إِوْضَا أَسْ سِّيفْ \add زَّايسْ\add*.  
\v 9 إِنَّا يُووَابْ إِ عَامَاسَا: ”أَقَا شكْ مْلِيحْ، ؤُمَا؟“ إِشبَّارْ يُووَابْ س ؤُفُوسْ أَفُوسِي ذِي ثْمَارْثْ ن عَامَاسَا حِيمَا أَذْ ث إِسُّوذمْ.  
\v 10 عَامَاسَا وَارْ إِحكَّارْ إِ سِّيفْ إِ ثُوغَا ذڭْ ؤُفُوسْ ن يُووَابْ ؤُشَا نتَّا إِڒْقفْ إِ-ث زَّايسْ ذڭْ ؤُعذِّيسْ ؤُشَا فّْغنْ أَسْ-د وَاذَانْ غَارْ ثمُّورْثْ. نتَّا إِمُّوثْ بْڒَا مَا إِڒْقفْ إِ-ث إِشْثْ ن ثْوَاڒَا نّغْنِيثْ. ؤُ يُووَابْ أَكْ-ذ ؤُمَاسْ أَبِيشَايْ إِضْفَارْ شَابَاعْ، مِّيسْ ن بِيكْرِي. \x ◘ \xo 20:‏10 \xt 1 إِج. 2‏:‏5\x*  
\v 11 إِجّْ ن ورْيَازْ إِبدّْ غَارسْ \add غَارْ عَامَاسَا\add*. \add ثُوغَا نتَّا\add* زڭْ إِمْسخَّارنْ ن يُووَابْ، إِنَّا: ”أجّْ ونِّي إِخْضَارنْ يُووَابْ ؤُڒَا ذ ونِّي إِدْجَانْ أَكْ-ذ ذَاوُوذْ، أَذْ إِضْفَارْ يُووَابْ!“ \f ◼ \fr 20:‏11 \ft \+bd ’إِبدّْ غَارسْ‘\+bd* - إِخْسْ أَذْ يِينِي إِبدّْ غَارْ أَرِّيمثْ ن أَمَاسَا.\f*   
\m
\v 12 عَامَاسَا مَاشَا ثُوغَا إِزّڒْ إِتّْوَانّضْ ذڭْ إِذَامّنْ نّسْ ذڭْ وبْرِيذْ أَمقّْرَانْ. \add ؤُمِي\add* إِژْرَا أَرْيَازْ نِّي، أَقَا مَارَّا ڒْڭنْسْ إِقِّيمْ إِبدّْ، إِجَارّْ نتَّا عَامَاسَا زڭْ وبْرِيذْ غَارْ ييَّارْ ؤُ إِنْضَارْ إِجّْ ن وَارُّوضْ ثِيوَا نّسْ، مِينْزِي إِژْرَا قَاعْ وِي غَارسْ د-إِوْضنْ، إِقِّيمْ إِتّْبدَّا.  
\v 13 أَڒَامِي ثُوغَا نتَّا إِتّْوَاڭّْوجْ خْ وبْرِيذْ، عْذُونْ مَارَّا إِرْيَازنْ أَوَارْنِي إِ يُووَابْ، حِيمَا أَذْ ضْفَارنْ شَابَاعْ، مِّيسْ ن بِيكْرِي،  
\v 14 ونِّي ثُوغَا إِكَّا خْ مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل غَارْ أَبَالْ ؤُ غَارْ بَايْثْ-مَاعْكَا، أَكْ-ذ مَارَّا إِبِيرِييّنْ نِّي إِتّْوَاسّْمُوننْ ؤُ رُوحنْ \add عَاوذْ\add* أَوَارْنِي أَسْ.  
\v 15 \add أَمُّو\add* د-إِوْضنْ نِيثْنِي \add غَارْ ذِينْ\add* ؤُشَا نّْضنْ-د إِ \add شَابَاعْ\add* ذِي أَبَالْ-بَايْثْ-مَاعْكَا. نِيثْنِي سّفْينْ إِجّْ ن لْبَارَاجْ خْ ثنْذِينْثْ ؤُ \add لْبَارَاجْ\add* نِّي إِبدّْ غَارْ ڒْحِيضْ ن زَّاثْ \add إِ د-إِنّْضنْ إِ ثنْذِينْثْ\add*. مَارَّا ڒْڭنْسْ إِ ثُوغَا أَكْ-ذ يُووَابْ، ڭِّينْ أَذْ أَردّْدْجنْ ڒْحِيضْ حِيمَا أَذْ أَسْ سّْغضْڒنْ.   
\m
\v 16 \add خنِّي\add* ثْڒَاغَا إِشْثْ ن ثمْغَارْثْ ذ ثْمِيغِيسْثْ زِي ثنْذِينْ:ث ”سْڒمْ، سْڒمْ، إِنِيمْ إِ يُووَابْ: ’أَسْ-د ذَا، أَذسْ-د، أَڒَامِي زمَّارغْ أَكِيذكْ سِّيوْڒغْ.‘ “  
\v 17 \add ؤُمِي\add* د-يُوسَا نتَّا، يُوذسْ-د غَارسْ، ثنَّا ثمْغَارْثْ: ”مَا شكْ ذ يُووَابْ؟“ نتَّا إِنَّا: ”ذ نشّْ.“ ثنَّا أَسْ نتَّاثْ: ”سڒْ غَارْ وَاوَاڒنْ ن ثَايَّا نّشْ.“ نتَّا إِنَّا: ”نشّْ تّسْڒِيغْ.“  
\v 18 \add خنِّي\add* ثنَّا: ”زِيشْ ثُوغَا سِّيوْڒنْ ذِي كُوڒْ أَمْشَانْ، نَّانْ: ’إِتّْخصَّا أَسنْ أَذْ ت سّقْسَانْ نِيشَانْ ذِي أَبَالْ!‘، ؤُشَا أَمُّو إِ كمّْڒنْ نِيثْنِي \add ثَامسْڒَاشْثْ نِّي\add* مْلِيحْ.  
\v 19 نشّْ زڭْ إِنِّي ن أَيْثْ ن ڒهْنَا ؤُ زڭْ إِمْثِيقَّانْ ذِي إِسْرَائِيل، \add مَاشَا\add* شكْ ثخْسذْ أَذْ ثنْغذْ إِشْثْ ن ثنْذِينْثْ، ثنِّي ذ يمَّاسْ ذِي إِسْرَائِيل. مَايمِّي غَا ثْصَارْضذْ ڒْوَارْثْ ن سِيذِي؟“  
\v 20 يُووَابْ يَارَّا-د خَاسْ، إِنَّا: ”أَيَا إِڭّْوجْ خَافِي أَقَا نشّْ أَذْ صَارْضغْ ؤُ أَذْ هذْمغْ!  
\v 21 ثَامسْڒَاشْثْ وَارْ ثدْجِي أَمنِّي. مَاشَا إِجّْ ن ورْيَازْ زڭْ إِذُورَارْ ن إِفْرَايِيمْ، قَّارنْ أَسْ شَابْعَا، مِّيسْ ن بِيكْرِي، إِكْسِي أَفُوسْ نّسْ خْ ؤُجدْجِيذْ، خْ ذَاوُوذْ. نتَّا وَاهَا إِتّْخصَّا أَذْ ث ثوْشمْ، \add خنِّي\add* أَذْ حيّْذغْ زِي ثنْذِينْثْ.“ ثنَّا ثمْغَارْثْ إِ يُووَابْ: ”خْزَارْ، أَزدْجِيفْ نّسْ أَذْ أَشْ ث-إِ-د-إِمّنْضَارْ ثِيوَا إِ ڒْحِيضْ.“  
\v 22 ثُوسَا-د ثمْغَارْثْ س ثِيغِيثْ نّسْ غَارْ مَارَّا ڒْڭنْسْ ؤُ نِيثْنِي قسّنْ أَزدْجِيفْ إِ شَابْعَا، مِّيسْ ن بِيكْرِي، نْضَارنْ ث إِ يُووَابْ. \add خنِّي\add* إِسُوضْ يُووَابْ ذڭْ ؤُيِيشّْ ن إِشَارِّي ؤُ نِيثْنِي بزّْعنْ إِخفْ نْسنْ، أَڭّْوجنْ خْ ثنْذِينْثْ ؤُ \add كُوڒْ\add* أَرْيَازْ \add يُويُورْ\add* غَارْ إِقِيضَانْ نّسْ ؤُ يُووَابْ إِعْقبْ غَارْ ؤُرْشَالِيمْ، غَارْ ؤُجدْجِيذْ.   
\b  
\m  
\s1 إِمْذبَّارَانْ إِمقّْرَاننْ ن ذَاوُوذْ  
\m
\v 23 يُووَابْ \add إِتّْوَاڭّْ\add* ذ أَزدْجِيفْ خْ مَارَّا ڒْعسْكَارْ ن إِسْرَائِيل، ؤُ بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ، ثُوغَا خْ إِعسَّاسنْ ن أَرِّيمثْ ؤُ خْ إِرقَّاسنْ ن ثَازْڒَا. \x ◘ \xo 20:‏23 \xt [2 صم. 8‏:‏16‏-‏18، 1 إِم. 18‏:‏15‏-‏17]\x*  
\v 24 أَذُورَامْ \add إِبدّْ\add* خْ لْجِيزْيَا ؤُ يَاهُوشَافَاطْ، مِّيسْ ن أَخِيلُوذْ، \add ثُوغَا-ث\add* ذ أَمَارِيرْ ن ؤُمزْرُويْ.  
\v 25 شِيوَا ثُوغَا ذ أَمَارِيرْ، ؤُ صَاذُوقْ ذ أَبْيَاثَارْ ثُوغَا أَثنْ ذ إِكهَّاننْ.  
\v 26 ؤُڒَا ذ عِيرَا زِي يَا‘إِرْ ثُوغَا ذ إِجّْ ن ؤُمْثِيقِّي ن ذَاوُوذْ.   
\b  
\b  
\m  
\c 21
\s1 دّعْوثْ ن أَيْثْ ن جِيبْعُونْ ضِيدّْ إِ شَاوُولْ  
\m
\v 1 ذڭْ وُوسَّانْ ن ذَاوُوذْ ثُوغَا ذِينْ إِجّْ ن ڒَاژْ، ثْڒَاثَا ن إِسڭّْوُوسَا، أَسڭّْوَاسْ أَوَارْنِي ؤُسڭّْوَاسْ. ؤُ ذَاوُوذْ يَارْزُو ؤُذمْ ن سِيذِي ؤُ سِيذِي إِنَّا: ”\add ذ مَانْ أَيَا\add* خْ شَاوُولْ ؤُ خْ إِذَامّنْ \add إِ إِڒصْقنْ ذِي\add* ثَادَّارْثْ \add نّسْ\add*، مِينْزِي نتَّا إِنْغَا أَيْثْ ن جِيبْعُونْ.“  
\v 2 \add خنِّي\add* إِڒَاغَا-د ؤُجدْجِيذْ خْ أَيْثْ ن جِيبْعُونْ، إِسِّيوڒْ أَكِيذْسنْ. أَيْثْ ن جِيبْعُونْ وَارْ \add د-قَّارْصنْ\add* شَا زڭْ أَيْثْ ن إِسْرَائِيل، مَاشَا زِي مِينْ \add عَاذْ\add* إِقِّيمنْ زڭْ إِمُورِييّنْ. أَيْثْ ن إِسْرَائِيل ثُوغَا جُّودْجنْ أَسنْ، \add مَاشَا\add* شَاوُولْ ثُوغَا يَارزُّو أَذْ ثنْ إِوّثْ ذڭْ وشْضَارْ نّسْ إِ أَيْثْ ن إِسْرَائِيل ذ يَاهُوذَا. \x ◘ \xo 21:‏2 \xt ياش. 9‏:‏19\x*  
\v 3 ذَاوُوذْ إِنَّا إِ أَيْثْ ن جِيبْعُونْ: ”مِينْ ذ أَومْ إِ غَا ڭّغْ ؤُ س مِينْ زِي غَا ڭّغْ أَصْڒَاحْ، \add مَاحنْذْ\add* أَذْ ثْبَارْكمْ ڒْوَارْثْ ن سِيذِي؟“  
\v 4 أَيْثْ ن جِيبْعُونْ نَّانْ أَسْ: ”وَارْ ذ أَنغْ إِشْقِي نُّوقَارْثْ نِيغْ ذ وُورغْ زِي شَاوُولْ نِيغْ زِي ثَادَّارْثْ نّسْ. عَاوذْ وَارْ ذ أَنغْ د-إِكَّارْ أَذْ ننغْ شَا ن إِجّْ ذِي إِسْرَائِيل.“ ؤُ نتَّا إِنَّا: ”مِينْ غَا ثِينِيمْ، أَذْ أَومْ ث ڭّغْ.“  
\v 5 نِيثْنِي نَّانْ إِ ؤُجدْجِيذْ: ”\add إِشْقَا أَنغْ\add* ورْيَازْ نِّي إِخْسنْ أَذْ خَانغْ إِقْضَا ؤُ ثُوغَا إِنْوَا أَذْ إِمْحَا أَغِيمِي نّغْ ذِي مَارَّا ثَامُّورْثْ ن إِسْرَائِيل.  
\v 6 أَذْ أَنغْ مّوْشنْ سبْعَا ن يرْيَازنْ زڭْ إِحنْجِيرنْ نّسْ، حِيمَا أَذْ ثنْ أَيْڒنْ زَّاثْ إِ سِيذِي ذِي جِيبْعَا ن شَاوُولْ، ونِّي إِتّْوَافَارْزنْ زِي سِيذِي!“ ؤُشَا أَجدْجِيذْ إِنَّا: ”نشّْ أَذْ \add ثنْ\add* وْشغْ.“  
\v 7 \add مَاشَا\add* أَجدْجِيذْ إِسّْعِيزّْ خْ مَافِيبُوشَاثْ، مِّيسْ ن يُونَاثَانْ، مِّيسْ ن شَاوُولْ، ذِي طّْوعْ ن ثْجَادْجِيثْ إِ سِيذِي، ثنِّي \add ثتّْوَاڭّْ\add* جَارْ أَسنْ، جَارْ ذَاوُوذْ ذ يُونَاثَانْ، مِّيسْ ن شَاوُولْ. \x ◘ \xo 21:‏7 \xt 1 صم. 18‏:‏3؛ 20‏:‏15، 42؛ 23‏:‏18\x*   
\m
\v 8 أَجدْجِيذْ إِكْسِي ثْنَاينْ ن إِحنْجِيرنْ ن رِيصْفَا، يدْجِيسْ ن أَيَا، إِ د-ثُورُووْ إِ شَاوُولْ، أَرْمُونِي ذ مَافِيبُوشَاثْ، ذ خمْسَا ن إِحنْجِيرنْ ن مِيرَابْ، يدْجِيسْ ن شَاوُولْ، إِ د-ثُورُووْ إِ عَاذْرِييِيلْ، مِّيسْ ن بَارْزِيلَّايْ زِي مَاحُولَايْ.  
\v 9 نتَّا إِوْشَا إِ-ثنْ ذڭْ إِفَاسّنْ ن أَيْثْ ن جِيبْعُونْ إِنِّي ثنْ أَيْڒنْ خْ وذْرَارْ زَّاثْ إِ وُوذمْ ن سِيذِي. سبْعَا نِّي وْضَانْ ذڭْ إِشْثْ ن ثْوَاڒَا ؤُ س إِجّْ ن وبْرِيذْ. نِيثْنِي تّْوَانْغنْ ذڭْ وُوسَّانْ ن ثْميْرَا، ذڭْ وُوسَّانْ إِمزْوُورَا، غَارْ بدُّو ن ثْميْرَا ن إِمنْذِي.   
\m
\v 10 \add خنِّي\add* ثكْسِي رِيصْفَا، يدْجِيسْ ن أَيَا، إِشْثْ ن ثْخَانْشثْ ثسُّو ت زَّاثْ إِ يِيخفْ نّسْ خْ إِجّْ ن جَّارْفْ. زِي بدُّو ن ثْميْرَا أَڒْ خَاسنْ د-زدْجْعنْ وَامَانْ زڭْ ؤُجنَّا. نتَّاثْ وَارْ ثجِّي إِجْضَاضْ ن ؤُجنَّا أَذْ غَارْسنْ د-أَسنْ س ؤُزِيڒْ ؤُڒَا ذ ڒوْحُوشْ ن ڒخْڒَا س دْجِيڒثْ.   
\m
\v 11 حَاجَانْ أَسْ إِ ذَاوُوذْ مِينْ ثُوغَا ثڭَّا رِيصْفَا، يدْجِيسْ ن أَيَا، ثَايَّا ن شَاوُولْ.  
\v 12 إِطّفْ ذَاوُوذْ أَبْرِيذْ مَاحنْذْ أَذْ إِكْسِي زڭْ إِمزْذَاغْ ن يَابِيشْ ذِي جِيلْعَاذْ إِغُوسَّانْ ن شَاوُولْ ذ إِغُوسَّانْ ن مِّيسْ يُونَاثَانْ نِّي د-كّْسنْ نِيثْنِي زڭْ وَازَّاغْ ن بَايْثْ-سَانْ، مَانِي ثنْ يُويْڒنْ إِفِيلِيسْطِينِييّنْ ذڭْ وَاسّْ إِ ذِيغڒْبنْ إِفِيلِيسْطِينِييّنْ شَاوُولْ خْ \add إِذُورَارْ ن\add* جِيلْبُوعَا. \x ◘ \xo 21:‏12 \xt 1 صم. 31‏:‏10‏-‏13\x*  
\v 13 نتَّا إِسّْڭعّذْ سّنِّي إِغْسَانْ ن شَاوُولْ ذ إِغْسَانْ ن مِّيسْ يُونَاثَانْ. نِيثْنِي سّْمُوننْ عَاوذْ إِغْسَانْ ن يِينِّي إِتّْوَايْڒنْ.  
\v 14 نضْڒنْ إِغْسَانْ ن شَاوُولْ ذ مِّيسْ يُونَاثَانْ ذِي ثمُّورْثْ ن بِينْيَامِينْ ذِي صَايْلَاعْ ذڭْ ونْضڒْ ن بَابَاسْ قِيسْ ؤُ نِيثْنِي ڭِّينْ مَارَّا مِينْ ذ أَسنْ يُومُورْ ؤُجدْجِيذْ. أَوَارْنِي مَانْ أَيَا إِجَّا أَربِّي أَذْ إِتّْوَاسّصْڒحْ إِخفْ نّسْ ذِي طّْوعْ ن ثمُّورْثْ س ثْژَادْجِيثْ \add نْسنْ\add* يُودْجْغنْ.   
\b  
\m  
\s1 أَمنْغِي أَكْ-ذ أَيْثْ ن رَافَا  
\m
\v 15 إِفِيلِيسْطِينِييّنْ مّنْغنْ عَاوذْ أَكْ-ذ إِسْرَائِيل. ذَاوُوذْ إِهْوَا ذ إِمْسخَّارنْ نّسْ أَكِيذسْ. نِيثْنِي مّنْغنْ أَكْ-ذ إِفِيلِيسْطِينِييّنْ ؤُشَا إِذْوڒْ ذَاوُوذْ يُوحڒْ أَطَّاسْ. \x ◘ \xo 21:‏15 \xt [1 إِم. 20‏:‏4‏-‏8]\x*  
\v 16 يِيشْبِي-بَانُوبْ، إِجّْ زڭْ إِحنْجِيرنْ ن رَافَا، ونِّي لَانْسَا نّسْ ثوْزنْ ثڒْثْ-مْيَا شِيقْلُو ن نّْحَاسْ ؤُ \add ونِّي\add* ثُوغَا إِبْيسْ س يِيجّْ ن \add سِّيفْ\add* ن جْذِيذْ، إِطّْغِيڒْ أَسْ أَذْ إِوّثْ ذَاوُوذْ.  
\v 17 \add مَاشَا\add* أَبِيشَايْ، مِّيسْ ن صَارُويَا، إِوْشَا أَفُوسْ \add إِ ذَاوُوذْ\add*، إِوْثَا أَفِيلِيسْطِينِي، إِنْغَا إِ-ث. خنِّي جُّودْجنْ أَسْ يرْيَازنْ ن ذَاوُوذْ، نَّانْ: ”شكْ وَارْ أَكِيذْنغْ ثفّْغذْ عَاذْ غَارْ ؤُمنْغِي، وَارْ إِعدّڒْ أَذْ ثْخسْيِيذْ ڒفْنَارْ ن إِسْرَائِيل.“   
\m
\v 18 أَوَارْنِي أَسْ إِمْسَارْ، أَقَا إِكَّارْ عَاوذْ ؤُمنْغِي أَكْ-ذ إِفِيلِيسْطِينِييّنْ ذِي جُوبْ. ڒخْذنِّي سَابْكَايْ، أَحُوشَايِي، إِوْثَا سَافْ، ونِّي ذ إِجّْ زڭْ إِحنْجِيرنْ ن رَافَا. \x ◘ \xo 21:‏18 \xt 1 إِم. 20‏:‏4\x*   
\m
\v 19 عَاوذْ ثُوغَا ذِينْ ؤُمنْغِي أَكْ-ذ إِفِيلِيسْطِينِييّنْ ذِي جُوبْ. إِلْحَانَانْ، مِّيسْ ن يَاعْرِي-أَرْجِيمْ، زِي بَايْثْ-لَاحْمْ، إِغْڒبْ خْ \add ؤُتْشْمَاسْ ن\add* جُولْيَاثْ زِي جَاثْ. أَكشُّوضْ ن لَانْسَا نّسْ إِڭَّا أَمْ يِيجّْ ن وعْمُوذْ ن ؤُكشُّوضْ ن ؤُخيّضْ.   
\m
\v 20 ؤُشَا إِكَّارْ عَاوذْ ؤُمنْغِي ذِي جَاثْ. ثُوغَا ذِينْ إِجّْ ن ورْيَازْ ذ أَزِيرَارْ، س ستَّا ن إِضوْضَانْ غَارْ إِفَاسّنْ نّسْ ؤُ ستَّا ن ثْفذْنِينْ غَارْ إِضَارنْ نّسْ، \add مَارَّا\add* ڒْقدّْ نْسنْ أَربْعَا ؤُ عِيشْرِينْ. ؤُڒَا ذ نتَّا إِتّْوَاخْڒقْ-د إِ رَافَا.  
\v 21 نتَّا إِسْثهْزَا زِي إِسْرَائِيل، مَاشَا يُونَاثَانْ، مِّيسْ ن شِيمْعَا، ؤُمَاسْ ن ذَاوُوذْ، إِغْڒبْ خَاسْ.   
\m
\v 22 أَربْعَا-يَا تّْوَاخڒْقنْ-د ذِي رَافَا ذِي جَاثْ ؤُ نِيثْنِي وْضَانْ س ؤُفُوسْ ن ذَاوُوذْ ؤُ س ؤُفُوسْ ن إِمْسخَّارنْ نّسْ.   
\b  
\b  
\m  
\c 22
\s1 إِزْڒِي ن ذَاوُوذْ  
\m
\v 1 ذَاوُوذْ إِسِّيوڒْ أَوَاڒنْ ن إِزْڒِي-يَا إِ سِيذِي ذڭْ وَاسّْ ؤُمِي ث إِفكّْ سِيذِي زڭْ ؤُفُوسْ ن مَارَّا ڒْعذْيَانْ نّسْ ؤُ زڭْ ؤُفُوسْ ن شَاوُولْ. \x ◘ \xo 22:‏1 \xt [إِزهد. 18]\x*  
\v 2 نتَّا إِنَّا:  
\b  
\m \qt ”سِيذِي ذ ثَاصْضَارْثْ إِنُو\qt*  
\m \qt ذ لْبُورْجْ إِنُو ذ أَمْفكِّي إِنُو.\qt*   
\m
\v 3 \qt سِيذِي ن ثصْضَارْثْ إِنُو، غَارسْ أَركّْوَاڒغْ.\qt*  
\m \qt \+tl شكْ\+tl* ذ أَسڒْقِي إِنُو\qt*  
\m \qt ذ يِيشّْ ن ؤُسنْجمْ إِنُو،\qt*  
\m \qt لْبُورْجْ إِنُو يُوعْڒَانْ،\qt*  
\m \qt أَمْشَانْ إِنُو ن ثَاروْڒَا ذ أَمْسنْجَامْ إِنُو.\qt*  
\m \qt شكْ ثْفكّذْ أَيِي زِي لْعُونْفْ.\qt* \x ◘ \xo 22:‏3 \xt عبر. 2‏:‏13\x*   
\m
\v 4 \qt ڒَْاغِيغْ: أَسمْغَارْ إِ سِيذِي!،\qt*  
\m \qt ؤُشَا تّْوَاسّْنجْمغْ زِي ڒْعذْيَانْ إِنُو.\qt*   
\m
\v 5 \qt مَاغَارْ نّْضنْ أَيِي-د\qt*  
\m \qt ڒمْوَاجْ ن ڒْموْثْ،\qt*  
\m \qt سِّيڭّْوذنْثْ أَيِي\qt*  
\m \qt ڒْحمْڒَاثْ ن وَامَانْ إِهَاجنْ.\qt*   
\m
\v 6 \qt إِسغْوَانْ ن ڒَاخَارْثْ شَارْفنْ أَيِي،\qt*  
\m \qt ثِيخشْفِينْ ن ڒْموْثْ حْصَارنْثْ أَيِي.\qt*   
\m
\v 7 \qt ذِي ڒحْصَارثْ إِنُو ڒَاغِيغْ-د خْ سِيذِي\qt*  
\m \qt ؤُ خْ أَربِّي إِنُو إِ خْ د-ڒَاغِيغْ.\qt*  
\m \qt زِي زَّاوشْثْ ثَامقّْرَانْثْ نّسْ\qt*  
\m \qt إِسْڒَا نتَّا إِ ثْمِيجَّا إِنُو\qt*  
\m \qt ؤُشَا إِغُويَّانْ إِنُو \+tl ؤُذْفنْ\+tl*\qt*  
\m \qt غَارْ إِمزُّوغنْ نّسْ.\qt*   
\m
\v 8 \qt \+tl خنِّي\+tl* ثنْهزّْ ؤُ ثَارْجِيجِي ثمُّورْثْ،\qt*  
\m \qt ذْسُوسَا ن ؤُجنَّا\qt*  
\m \qt تّْرَاحنْ-د تَّاسنْ-د، نْهزّنْ،\qt*  
\m \qt مَاغَارْ أَغْضَابْ نّسْ ثُوغَا إِتّْوَاسَّارْغْ.\qt*   
\m
\v 9 \qt دّخَّانْ إِڭعّذْ-د زڭْ ونْزَارنْ نّسْ،\qt*  
\m \qt ثِيمسِّي زڭْ ؤُقمُّومْ نّسْ ثْصَارْضْ،\qt*  
\m \qt ڒفْحمْ إِتّحْذُوذُوقنْ إِتّْوَاسَّارْغْ زَّايسْ.\qt*   
\m
\v 10 \qt نتَّا إِڭَّا أَجنَّا أَذْ يَاضَارْ،\qt*  
\m \qt نتَّا إِهْوَا-د.\qt*  
\m \qt \+tl أَقَا ذِينْ\+tl* إِجّْ ن ؤُسيْنُو إِبُّومْبسْ\qt*  
\m \qt سَاذُو إِضَارنْ نّسْ.\qt*   
\m
\v 11 \qt نتَّا إِنْذهْ خْ إِجّْ ن ؤُكِيرُوبْ، إِضْوَا،\qt*  
\m \qt نتَّا إِتّْوَاژَارْ خْ وَافْرِيونْ ن ؤُسمِّيضْ.\qt* \f ◼ \fr 22:‏11 \ft \+bd ’أَخِيرُوبْ‘\+bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*   
\m
\v 12 \qt نتَّا إِڭَّا ثَادْجسْثْ أَذْ أَسْ ثنّضْ\qt*  
\m \qt \+tl أَمْ\+tl* إِعُوشُّوثنْ،\qt*  
\m \qt إِجّْ ن وڭْرَاوْ ن وَامَانْ،\qt*  
\m \qt إِسيْنُوثنْ إِقلّْجنْ إِبَّارشْننْ.\qt*   
\m
\v 13 \qt زِي ثِيسِّيقْثْ قِيبَاتْشْ نّسْ\qt*  
\m \qt تّْوَاسَّارْغنْ ڒفْحمْ إِتّحْذُوذُوقنْ.\qt*   
\m
\v 14 \qt إِجَّا سِيذِي أَجَّاجْ أَذْ إِدُّوقّزْ زڭْ ؤُجنَّا،\qt*  
\m \qt ؤُشَا أَمْعُودْجِي خْ كُوڒْشِي\qt*  
\m \qt إِڭَّا ثْمِيجَّا نّسْ تّْنفْرَارَا.\qt*   
\m
\v 15 \qt نتَّا إِسّكّْ فْڒِيثْشَاثْ \+tl ن ڒْقوْسْ نّسْ\+tl*\qt*  
\m \qt ؤُشَا إِبزّعْ إِ-ثنْ،\qt*  
\m \qt \+tl إِزَّارْيضْ\+tl* أَسَّامنْ ؤُشَا إِسِّيڭّْوذْ إِ-ثنْ.\qt*   
\m
\v 16 \qt ثِيسِيوِينْ ن ڒبْحَارْ ذوْڒنْثْ تّْبَاننْثْ،\qt*  
\m \qt ذْسُوسَا ن دُّونشْثْ ذوْڒنْ عَارَّانْ\qt*  
\m \qt زڭْ ؤُودّبْ ن سِيذِي،\qt*  
\m \qt زڭْ ؤُسُوضِي ن ڒعْوِينْ زڭْ ونْزَارنْ نّسْ.\qt*   
\m
\v 17 \qt إِسّْوِيژّضْ-د \+tl أَفُوسْ نّسْ\+tl* زِي ڒُوعْڒَا،\qt*  
\m \qt يِيوِي أَيِي، إِجْبذْ أَيِي-د زڭْ وَامَانْ مْغَارنْ.\qt*   
\m
\v 18 \qt نتَّا إِفكّْ أَيِي-د\qt*  
\m \qt زِي ڒعْذُو إِنُو إِجهْذنْ،\qt*  
\m \qt زڭْ إِنِّي ذ أَيِي إِشَارّْهنْ،\qt*  
\m \qt مِينْزِي نِيثْنِي ثُوغَا جهْذنْ خَافِي.\qt*   
\m
\v 19 \qt حْصَارنْ أَيِي ذڭْ وَاسّْ ن أَرْژِييّثْ إِنُو،\qt*  
\m \qt \+tl مَاشَا\+tl* سِيذِي ثُوغَا ذ أَمْعمّذْ إِنُو.\qt*   
\m
\v 20 \qt نتَّا إِنْذهْ أَيِي غَارْ تَّاسِيعْ، إِسّنْجمْ أَيِي،\qt*  
\m \qt مَاغَارْ نتَّا ثُوغَا إِتّْعِيزَّا ذَايِي.\qt*   
\m
\v 21 \qt سِيذِي إِخْڒفْ أَيِي عْلَاحْسَابْ ثَاسڭْذَا إِنُو،\qt*  
\m \qt عْلَاحْسَابْ ثَازْذُوڭِي ن إِفَاسّنْ إِنُو إِخدْجصْ أَيِي.\qt*   
\m
\v 22 \qt مَاغَارْ نشّْ حْضِيغْ إِبْرِيذنْ ن سِيذِي،\qt*  
\m \qt وَارْ حيّْذغْ شَا خْ أَربِّي إِنُو س ؤُخيّبْ.\qt*   
\m
\v 23 \qt مَاغَارْ مَارَّا لْفَارَايِيضْ نّسْ\qt*  
\m \qt \+tl ثُوغَا\+tl* جَارْ \+tl ثِيطَّاوِينْ\+tl* إِنُو،\qt*  
\m \qt وَارْ حيِّيذغْ شَا خْ ثْوصَّا نّسْ.\qt*   
\m
\v 24 \qt ذوْڒغْ كمْڒغْ إِ نتَّا،\qt*  
\m \qt حْضِيغْ إِخفْ إِنُو زِي ڒْمُوعْصِييّثْ إِنُو.\qt*   
\m
\v 25 \qt سِيذِي إِخْڒفْ أَيِي أَنشْثْ ن ثَاسڭْذَا إِنُو،\qt*  
\m \qt أَنشْثْ ن ثَازْذُوڭِي إِنُو زَّاثْ إِ ثِيطَّاوِينْ نّسْ.\qt*   
\m
\v 26 \qt إِ ؤُمدُّوكّڒْ أَمْثِيقِّي\qt*  
\m \qt إِ ثدْجِيذْ ذ أَمدُّوكّڒْ ذ أَمْثِيقِّي،\qt*  
\m \qt إِ بُو-ثغْرُوضْثْ إِكمّْڒنْ\qt*  
\m \qt إِ ثدْجِيذْ شكْ ثْكمّْڒذْ.\qt*   
\m
\v 27 \qt إِ ونِّي إِتّْوَاسِّيزذْڭنْ\qt*  
\m \qt أَقَا شكْ ذ أَمزْذَاڭْ،\qt*  
\m \qt أَكْ-ذ ونِّي إِفَارْغنْ، أَقَا ثْفَارْغذْ.\qt*   
\m
\v 28 \qt شكْ ثسّْنجْمذْ ڒْڭنْسْ إِتّْوَاحْصَارْ،\qt*  
\m \qt \+tl مَاشَا\+tl* ثِيطَّاوِينْ نّشْ ضِيدّْ إِ إِمْعفَّارنْ،\qt*  
\m \qt شكْ أَذْ \+tl ثنْ\+tl* ثسّهْوِيذْ.\qt* \f ◼ \fr 22:‏28 \ft \+bd ’إِمْعفَّارنْ‘\+bd* - ’أَيْثْ بُو-نّْفَاخثْ‘.\f*   
\m
\v 29 \qt مِينْزِي شكْ ذ ڒفْنَارْ إِنُو، \+tl أَ\+tl* سِيذِي!\qt*  
\m \qt سِيذِي إِتّڭّْ ثَافَاوْثْ ذِي ثَادْجسْثْ إِنُو.\qt*   
\m
\v 30 \qt مِينْزِي أَكِيذكْ أَذْ أَزّْڒغْ\qt*  
\m \qt خْ إِشْثْ ن بَانْذِييَّا،\qt*  
\m \qt أَكْ-ذ أَربِّي إِنُو أَذْ نڭّْزغْ\qt*  
\m \qt خْ إِجّْ ن ڒْحِيضْ.\qt*   
\b  
\m
\v 31 \qt أَبْرِيذْ ن أَربِّي إِكْمڒْ، مِينْ إِقَّارْ سِيذِي\qt*  
\m \qt أَقَا إِتّْوَاصفَّا \+tl ذِي ثْمسِّي\+tl*.\qt*  
\m \qt نتَّا ذ أَسڒْقِي إِ مَارَّا\qt*  
\m \qt إِنِّي غَارسْ يَاركّْوَاڒنْ.\qt* \x ◘ \xo 22:‏31 \xt أَعَوذ. 32‏:‏4؛ دَان. 4‏:‏34؛ إِزهد. 12‏:‏7؛ 119‏:‏140؛ أَوڒن. 30‏:‏5؛ أَسَا. 15‏:‏3\x*   
\m
\v 32 \qt مَاغَارْ مَانْ ونْ إِ إِدْجَانْ ذ أَربِّي،\qt*  
\m \qt مْغِيرْ سِيذِي،\qt*  
\m \qt ؤُ مَانْ ونْ إِ إِدْجَانْ ذ ثَاصْضَارْثْ،\qt*  
\m \qt مْغِيرْ أَربِّي نّغْ؟\qt* \x ◘ \xo 22:‏32 \xt أَعَوذ. 32‏:‏39؛ 1 صم. 2‏:‏2؛ إِزهد. 86‏:‏8؛ إِشا. 45‏:‏5\x*   
\m
\v 33 \qt أَربِّي نِّي ذ لْقلْعَا إِنُو إِجْهذْ،\qt*  
\m \qt نتَّا إِسَّارْخُو أَبْرِيذْ إِنُو نِيشَانْ.\qt*   
\m
\v 34 \qt نتَّا إِڭَّا إِضَارنْ إِنُو\qt*  
\m \qt أَمْ يِينِّي ن ثُوذَاذِينْ،\qt*  
\m \qt نتَّا يَارَّا أَيِي\qt*  
\m \qt أَذْ بدّغْ خْ ڒڭْعُوذِي إِنُو.\qt*   
\m
\v 35 \qt نتَّا إِسّڒْمذْ إِفَاسّنْ إِنُو إِ ؤُمنْغِي،\qt*  
\m \qt إِغَادْجنْ إِنُو مَاحنْذْ أَذْ محْضنْ\qt*  
\m \qt إِجّْ ن ڒْقوْسْ ن نّْحَاسْ.\qt*   
\m
\v 36 \qt ثوْشِيذْ أَيِي أَسڒْقِي ن ؤُسنْجمْ نّشْ،\qt*  
\m \qt س ؤُوَاضعْ نّشْ ثسّمْغَارذْ أَيِي.\qt*   
\m
\v 37 \qt أَقَا ثڭّذْ تَّاسِيعْ إِ ؤُصُورِيفْ إِنُو سَاذُو إِنُو،\qt*  
\m \qt ؤُشَا ثِيشعْبِينْ إِنُو وَارْ ميّْڒنْثْ.\qt*   
\m
\v 38 \qt نشّْ ضْفَارغْ ڒْعذْيَانْ إِنُو\qt*  
\m \qt ؤُشَا ثحِّيغْ ثنْ،\qt*  
\m \qt وَارْ د-تّْعِيقِّيبغْ أَڒْ ثنْ قْضِيغْ.\qt*   
\m
\v 39 \qt نشّْ قْضِيغْ ثنْ ؤُ ڒبْزغْ ثنْ،\qt*  
\m \qt أَڒَامِي وَارْ كَّارنْ عَاوذْ.\qt*  
\m \qt نِيثْنِي وْضَانْ-د سَاذُو إِضَارنْ إِنُو.\qt*   
\m
\v 40 \qt شكْ ثْبيْسذْ أَيِي س جّهْذْ إِ ؤُمنْغِي،\qt*  
\m \qt ثَارِّيذْ إِنِّي غَارِي د-إِكَّارنْ\qt*  
\m \qt أَذْ أَضَارنْ سَاذُو إِنُو.\qt*   
\m
\v 41 \qt شكْ ثوْشِيذْ أَيِي ثِيمجَّارْثْ ن ڒْعذْيَانْ إِنُو،\qt*  
\m \qt ن يِينِّي ذ أَيِي إِشَارّْهنْ،\qt*  
\m \qt ؤُ نشّْ أَردّْدْجغْ ثنْ.\qt*   
\m
\v 42 \qt نِيثْنِي ڒَاغَانْ، \+tl مَاشَا\+tl* وَارْ ذِينْ ثُوغِي أَمْسنْجمْ،\qt*  
\m \qt \+tl ڒَاغَانْ،\+tl* خْ سِيذِي،\qt*  
\m \qt مَاشَا نتَّا وَارْ خَاسنْ د-يَارِّي.\qt*   
\m
\v 43 \qt نشّْ سّْودَّارغْ ثنْ\qt*  
\m \qt أَمْ ثْعجَّاجْثْ ن ثمُّورْثْ،\qt*  
\m \qt أَمْ ؤُبدْجَاعْ خْ إِبْرِيذنْ\qt*  
\m \qt عجْنغْ خَاسنْ ؤُ ڒبْزغْ ثنْ.\qt*   
\b  
\m
\v 44 \qt شكْ ثْفكّذْ أَيِي\qt*  
\m \qt زڭْ إِمْشُوبّشنْ ن ڒْڭنْسْ إِنُو،\qt*  
\m \qt ثحْضِيذْ أَيِي ذ أَزدْجِيفْ ن ڒڭْنُوسْ،\qt*  
\m \qt إِجّْ ن ڒْڭنْسْ وَارْ ث سِّينغْ، أَذْ أَيِي إِسخَّارْ.\qt* \x ◘ \xo 22:‏44 \xt إِزهد. 18‏:‏44\x*   
\m
\v 45 \qt ثَارْوَا ن إِجّْ ن ؤُبَارَّانِي\qt*  
\m \qt سّْنِيعْمِيڒنْ سّْوَاضْعنْ أَيِي.\qt*  
\m \qt مْغِيرْ ڒَامِي ذ أَيِي إِسْڒَا ؤُمزُّوغْ \+tl نْسنْ\+tl* وَاهَا،\qt*  
\m \qt سْڒِينْ-د غَارِي.\qt*   
\m
\v 46 \qt أَرَّاونْ ن إِجّْ ن ؤُبَارَّانِي فشْڒنْ،\qt*  
\m \qt \+tl وَاخَّا\+tl* نّْضنْ أَسنْ-د لْبَارَاجَاثْ نْسنْ.\qt*   
\m
\v 47 \qt ثُوذَارْثْ إِ سِيذِي.\qt*  
\m \qt أَذْ ثتّْوَابَاركْ ثصْضَارْثْ إِنُو.\qt*  
\m \qt أجّْ أَربِّي ن ثصْضَارْثْ ن ؤُسنْجمْ إِنُو\qt*  
\m \qt أَذْ إِتّْوَاسّْڭعّذْ \+tl غَارْ ؤُجنَّا\+tl*!\qt*.   
\m
\v 48 \qt أَربِّي ونِّي خَافِي إِتّنْثَاقَامنْ\qt*  
\m \qt \+tl ذ ونِّي\+tl* ذ أَيِي إِتّڭّنْ ڒڭْنُوسْ\qt*  
\m \qt سَاذُو ؤُفُوسْ إِنُو،\qt*   
\m
\v 49 \qt ونِّي ذ أَيِي إِتّْفكَّانْ\qt*  
\m \qt زڭْ \+tl ؤُفُوسْ ن\+tl* ڒْعذْيَانْ إِنُو،\qt*  
\m \qt \+tl وَاهْ\+tl*، شكْ ثسّْڭعَّاذذْ أَيِي\qt*  
\m \qt ثِيوَا ن يِينِّي ذ أَيِي إِتّْضَادَّانْ،\qt*  
\m \qt شكْ ثسّنْجَامذْ أَيِي\qt*  
\m \qt زڭْ ورْيَازْ ن ڒخْشُونثْ.\qt*   
\m
\v 50 \qt خْ ؤُيَا، سِيذِي، خْسغْ أَذْ شكْ قَاذِيغْ،\qt*  
\m \qt خْسغْ أَذْ زهّْذغْ إِسمْ نّشْ.\qt* \x ◘ \xo 22:‏50 \xt رُوم. 15‏:‏9\x*   
\m
\v 51 \qt نتَّا إِڭَّا إِسنْجِيمنْ\qt*  
\m \qt ن ؤُجدْجِيذْ نّسْ مْغَارنْ،\qt*  
\m \qt ؤُشَا إِسّْشنْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ\qt*  
\m \qt إِ ؤُمذْهُونْ نّسْ،\qt*  
\m \qt إِ ذَاوُوذْ ؤُ إِ زَّارِيعثْ نّسْ إِ ڒبْذَا.“\qt*   
\b  
\b  
\m  
\c 23
\s1 أَوَاڒنْ إِنڭُّورَا ن ذَاوُوذْ  
\m
\v 1 إِنَا ذ أَوَاڒنْ إِنڭُّورَا ن ذَاوُوذْ.  
\b  
\m ذَاوُوذْ، مِّيسْ ن يَاسَّا إِسَّاوَاڒْ، بُو-ثغْرُوضْثْ إِ إِتّْوَاسّْعُودْجَانْ إِسَّاوَاڒْ، أَمذْهُونْ ن أَربِّي ن يَاعْقُوبْ، أَمذْيَازْ إِعِيزّنْ ن إِسْرَائِيل.   
\b  
\m
\v 2 أَرُّوحْ ن سِيذِي إِسِّيوڒْ زَّايِي ؤُ أَوَاڒْ نّسْ خْ إِڒسْ إِنُو.   
\m
\v 3 أَربِّي ن إِسْرَائِيل إِنَّا، أَقَا ثَاصْضَارْثْ ن إِسْرَائِيل ثسِّيوڒْ أَكِيذِي:  
\b  
\m \qt ”إِجّْ ن ڒْحَاكمْ جَارْ إِوْذَانْ،\qt*  
\m \qt إِجّْ ن ؤُمْسڭّذْ،\qt*  
\m \qt إِجّْ ن ڒْحَاكمْ نِّي إِتّڭّْوذنْ أَربِّي،\qt*   
\m
\v 4 \qt \+tl ونِّي إِڭِّينْ\+tl* أَمْ ثْفَاوْثْ غَارْ ثُوفُّوثْ\qt*  
\m \qt خْمِي د-ثْنقَّارْ ثْفُوشْثْ،\qt*  
\m \qt غَارْ إِشْثْ ن ثُوفُّوثْ\qt*  
\m \qt بْڒَا إِسيْنُوثنْ إِعْبُوبّْزنْ،\qt*  
\m \qt \+tl خْمِي\+tl*، س ثِيسِّيقْثْ ن ثْفَاوْثْ\qt*  
\m \qt أَوَارْنِي إِ ونْژَارْ،\qt*  
\m \qt أَقَا إِسّْفُوفُّويْ أَغمُّويْ أَزِيزَا\qt*  
\m \qt زِي ثمُّورْثْ.“\qt*   
\b  
\m
\v 5 \qt ”مَا وَارْ ثدْجِي ثَادَّارْثْ إِنُو\qt*  
\m \qt غَارْ أَربِّي أَمنِّي؟\qt*  
\m \qt أَقَا إِڭَّا أَيِي إِجّْ ن ڒْعَاهْذْ إِ ڒبْذَا،\qt*  
\m \qt مْستّفْ ذِي مَارَّا ؤُ إِتّْوَاحْضَا.\qt*  
\m \qt قَاعْ أَسنْجمْ إِنُو\qt*  
\m \qt ذ مَارَّا مِينْ إِسّْنكَّارَانْ ڒفْرَاحثْ،\qt*  
\m \qt مَا نتَّا وَارْ إِسّْغمِّي أَيَا؟\qt*   
\m
\v 6 \qt \+tl مَاشَا\+tl* إِنِّي وَارْ إِسكّْوِينْ\qt*  
\m \qt أَذْ تّْوَامّنْضَارنْ\qt*  
\m \qt أَمْ إِشْثْ ن ثْسطَّا أَكْ-ذ إِسنَّاننْ،\qt*  
\m \qt مَارَّا نِيثْنِي،\qt*  
\m \qt مَاغَارْ وَارْ إِزمَّارْ\qt*  
\m \qt أَذْ تّْوَاطّْفنْ س ؤُفُوسْ.\qt*   
\m
\v 7 \qt أَرْيَازْ إِ إِخْسنْ أَذْ ثنْثْ إِحَاذَا،\qt*  
\m \qt أَذْ إِحزّمْ إِخفْ نّسْ س وُوزَّاڒْ\qt*  
\m \qt ذ ؤُكشُّوضْ نْ لَانْسَا\qt*  
\m \qt ؤُ نِيثْنِي أَذْ تّْوَاسّْشمْضنْ س ثْمسِّي\qt*  
\m \qt ذڭْ ومْشَانْ \+tl نْسنْ\+tl*.“\qt*   
\b  
\m  
\s1 أَيْثْ ن بُو-ثغْرُوضْثْ ن ذَاوُوذْ  
\m
\v 8 إِنَا ذ إِسْمَاونْ ن أَيْثْ ن بُو-ثغْرُوضْثْ إِ \add إِدْجَانْ\add* غَارْ ذَاوُوذْ: \bd يُوشَايْبْ بَاشَابَّاثْ\bd*، مِّيسْ ن أَثَاهْكَامُونِي، أَزدْجِيفْ ن إِنغْرَافنْ. لَانْسَا نّسْ ثُوغَا ذ ڒهْزُوطْ نّسْ، إِسّْنُوقّبْ ثمْنْ-مْيَا ن يرْيَازنْ ذڭْ إِجّْ ن ؤُمنْغِي. \f ◼ \fr 23:‏8 \ft \+bd ’ذڭْ إِجّْ ن ؤُمنْغِي‘\+bd* - س ثْعِيبْرَانِيثْ ’ذڭْ إِشْثنْ ثِيشْثِي‘.\f*  \x ◘ \xo 23:‏8 \xt [1 إِم. 11‏:‏10‏-‏47]\x*  
\v 9 أَوَارْنِي أَسْ \add يُوسَا-د\add* \bd أَلِيعَازَارْ\bd*، مِّيسْ ن ذُوذُو، مِّيسْ ن أَخُوخِي. نتَّا ثُوغَا \add ذ إِجّنْ\add* زِي ثْڒَاثَا ن أَيْثْ ن بُو-ثغْرُوضْثْ \add نِّي إِدْجَانْ\add* أَكْ-ذ ذَاوُوذْ، ڒَامِي نِيثْنِي سْثهْزَانْ زڭْ إِفِيلِيسْطِينِييّنْ نِّي ثُوغَا ذِينْ مُوننْ إِ ؤُمنْغِي، \add أَمْ\add* ڭعّْذنْ إِرْيَازنْ ن إِسْرَائِيل غَارْسنْ \add إِ ؤُمنْغِي\add*.  
\v 10 نتَّا إِكَّارْ، إِوْثَا ذڭْ إِفِيلِيسْطِينِييّنْ أَڒْ يُوحڒْ ؤُفُوسْ نّسْ. إِڒْصقْ ؤُفُوسْ نّسْ ذِي سِّيفْ. سِيذِي يِيوِيضْ إِجّْ ن ؤُسنْجمْ ذ أَمقّْرَانْ ذڭْ وَاسّْ نِّي ؤُشَا \add إِرْيَازنْ ن\add* ڒْڭنْسْعقْبنْ أَوَارْنِي أَسْ، \add مَاشَا\add* مْغِيرْ حِيمَا أَذْ كشّْضنْ.  
\v 11 أَوَارْنِي أَسْ \add يُوسَا-د\add* \bd شَامَّا\bd*، مِّيسْ ن أَجِي، أَهَارَارِي. \add ڒَْامِي\add* نّْجَارْونْ إِفِيلِيسْطِينِييّنْ غَارْ لَاخِي، ثُوغَا ذِينِّي إِجّْ ن إِيَّارْ إِشُّورنْ س ڒعْذسْ. ڒْڭنْسْ ثُوغَا يَارْوڒْ زَّاثْ إِ وُوذمْ ن إِفِيلِيسْطِينِييّنْ.  
\v 12 نتَّا إِبدّْ ذِي ڒْوسْثْ ن ؤُرقِّيعْ \add ن إِيَّارْ\add* \add نِّي\add*، إِفكّْ إِ-ث-إِ-د ؤُشَا إِغْڒبْ خْ إِفِيلِيسْطِينِييّنْ. \add أَمُّو\add* يَارَّا أَسْ سِيذِي إِجّْ ن وغْڒَابْ ذ أَمقّْرَانْ.   
\m
\v 13 ثْڒَاثَا زِي ثْڒَاثِينْ ن إِزدْجِيفنْ هْوَانْ، ؤُسِينْ-د غَارْ ذَاوُوذْ ذِي \add ڒْْوقْثْ ن\add* ثْميْرَا، ذڭْ إِفْرِي ن أَبْذُولَّامْ. ثُوغَا \add ذِينْ\add* إِشْثْ ن ثرْبِيعْثْ ن إِفِيلِيسْطِينِييّنْ ثوْثَا إِقِيضَانْ نْسنْ ذِي ثغْزُورْثْ ن إِرَافَاوِييّنْ.  
\v 14 ذَاوُوذْ \add ثُوغَا-ث\add* ذِي لْقلْعَا ؤُ \add ثُوغَا\add* ذِينْ إِشْثْ ن ثڒْبِيحْثْ ن ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ \add ذِي\add* بَايْثْ-لَاحْمْ.  
\v 15 ؤُشَا ذَاوُوذْ إِڒْقفْ إِ-ث ؤُفَاذِي، إِنَّا: ”وِي ذ أَيِي إِ د غَا يَاوْينْ أَمَانْ زِي ثَاڒَا ن بَايْثْ-لَاحْمْ إِ \add إِدْجَانْ\add* غَارْ ثوَّارْثْ \add ن ثنْذِينْثْ\add*؟“  
\v 16 \add خنِّي\add* شُوقنْ ثْڒَاثَا ن أَيْثْ ن بُو-ثغْرُوضْثْ نِّي ڒْمَارْڭحْ ن ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ، ؤُيْمنْ-د أَمَانْ زِي ثَاڒَا ن بَايْثْ-لَاحْمْ، إِ \add إِدْجَانْ\add* غَارْ ثوَّارْثْ \add ن ثنْذِينْثْ\add*. كْسِينْ ثنْ أَكِيذْسنْ ؤُ إِوْضنْ غَارْ ذَاوُوذْ، \add مَاشَا\add* نتَّا يُوڭِي أَذْ ثنْ إِسُو ؤُشَا إِزدْجعْ إِ-ثنْ زَّاثْ إِ سِيذِي.  
\v 17 نتَّا إِنَّا: ”أَيَا إِڭّْوجْ خَافِي، \add أَ\add* سِيذِي، أَقَا نشّْ أَذْ ڭّغْ مَانْ أَيَا. مَا أَذْ سْوغْ إِذَامّنْ ن يرْيَازنْ، إِنِّي \add ذِينْ\add* إِرُوحنْ \add أَمْ سبّْڒنْ\add* ثُوذَارْثْ نْسنْ؟“ ؤُ نتَّا وَارْ إِخْسْ أَذْ ثنْ إِسُو. ذ مَانْ أَيَا إِ ث إِڭِّينْ ثْڒَاثَا ن أَيْثْ ن بُو-ثغْرُوضْثْ نِّي.   
\m
\v 18 \bd أَبِيشَايْ\bd*، مِّيسْ ن يُووَابْ، مِّيسْ ن صَارُويَا، ثُوغَا ذ أَزدْجِيفْ ن ثْڒَاثَا \add نِّي\add*. نتَّا إِحنّضْ لَانْسَا نّسْ خْ ثڒْثْ-مْيَا، إِسّْنُوقّبْ إِ-ثنْ. نتَّا غَارسْ إِجّْ ن إِسمْ \add إِتّْوَاشنّعْ\add* جَارْ ثْڒَاثَا \add نِّي\add*.  
\v 19 مَا وَارْ إِدْجِي نتَّا ذ ونِّي إِتّْوَاشنّْعنْ أَطَّاسْ زِي ثْڒَاثَا-يَا؟ س ؤُيَا ثُوغَا نتَّا ذ ڒْقبْطَانْ نْسنْ. مَاشَا نتَّا وَارْ يِيوِيضْ ؤُڒَا غَارْ ثْڒَاثَا ن \add إِمزْوُورَا\add*.   
\m
\v 20 \add خنِّي\add* \bd بَانَايَا\bd*، مِّيسْ ن يَاهُويَاذَاعْ، مِّيسْ ن إِجّْ ورْيَازْ إِمحْضنْ، ثِيمڭَّا نّسْ مْغَارنْثْ، نتَّا زِي قَابْضِييِيلْ. نتَّا إِغْڒبْ خْ ثْنَاينْ ن إِيْرَاذنْ إِجهْذنْ. عَاوذْ ثُوغَا نتَّا إِهْوَا \add إِشْثْ ن ثْوَاڒَا\add*، إِغْڒبْ خْ إِجّْ ن ويْرَاذْ ذِي ڒْوسْطْ ن إِجّْ ن وَانُو ذڭْ إِجّْ ن وَاسّْ ؤُمِي إِوْثَا وذْفڒْ.  
\v 21 نتَّا إِغْڒبْ ؤُڒَا خْ يِيجّْ ن ورْيَازْ ذ أَمِيصْرِي، إِجّْ ن \add ورْيَازْ\add* إِسّڭّْوَاذنْ. أَمِيصْرِي ثُوغَا غَارسْ إِشْثْ ن لَانْسَا ذڭْ ؤُفُوسْ \add نّسْ\add*. إِهْوَا غَارسْ س يِيجّْ ن وعْمُوذْ، إِكّسْ لَانْسَا زڭْ ؤُفُوسْ ن ؤُمِيصْرِي ؤُ إِنْغَا إِ-ث س لَانْسَا نّسْ.  
\v 22 ذ مَانْ أَيَا إِ إِڭَّا بَانَايَا، مِّيسْ ن يَاهُويَاذَاعْ. س ؤُيَا غَارسْ إِسمْ \add إِشْنعْ\add* جَارْ ثْڒَاثَا ن أَيْثْ ن بُو-ثغْرُوضْثْ.  
\v 23 نتَّا ثُوغَا ذ ونِّي إِتّْوَاشنّْعنْ أَطَّاسْ زِي ثْڒَاثِينْ، مَاشَا وَارْ يِيوضْ أَڒْ ثْڒَاثَا إِمزْوُورَا. ذَاوُوذْ إِڭَّا إِ-ث جَارْ إِمْثِيقَّانْ نّسْ.   
\b  
\m
\v 24 \add ثُوغَا\add* \bd عَسَائِيلْ\bd*، ؤُمَاسْ ن يُووَابْ، جَارْ ثْڒَاثِينْ؛  
\m إِلْحَانَانْ، مِّيسْ ن ذُوذُو، زِي بَايْثْ-لَاحْمْ؛   
\m
\v 25 شَامْعَا، أَحَارُوذِي؛  
\m إِلِيقَا، أَحَارُوذِي؛   
\m
\v 26 هَالَاصْ، أَفَالْطِي؛  
\m عِيرَا، مِّيسْ ن عِيقِّيشْ، أَثِيقُّوعِي؛   
\m
\v 27 أَبِيعَازَارْ، أَعَانَاثُوثِي؛  
\m مابُونَّايْ، أَحُوشَايِي؛   
\m
\v 28 صَالْمُونْ، أَخُوخِي؛  
\m مَاهْرَايْ، أَنَاطُوفَاثِي؛   
\m
\v 29 خَالَابْ، مِّيسْ ن بَاعْنَا، أَنَاطُوفَاثِي؛  
\m إِتَّايْ، مِّيسْ ن رِيبَايْ،  
\m زِي جِيبْعَا زڭْ أَيْثْ ن بِينْيَامِينْ؛   
\m
\v 30 بَانَايَا، زِي فِيرْعَاثُونْ؛  
\m هِيدَّايْ، زِي ثغْزُورِينْ ن جَاعَاشْ؛   
\m
\v 31 أَبُو-عَالْبُونْ، أَعَارَابَاثِي؛  
\m عَازْمَاوثْ، أَبَارْحُومِي؛   
\m
\v 32 إِلْيَاحْبَا، أَشَاعْلُوبُونِي؛  
\m زڭْ إِحنْجِيرنْ ن يَاشَانْ، \add مْغِيرْ\add* يُونَاثَانْ؛   
\m
\v 33 شَامَّا، أَهَارَارِي؛  
\m أَخِييَامْ، مِّيسْ شَارَارْ، أَرَارِي؛   
\m
\v 34 إِلِيفَالَاطْ، مِّيسْ ن أَحَاسْبَايْ، مِّيسْ ن ؤُمَاعْكِي؛  
\m إِعَامْ، مِّيسْ ن أَخِيطُوفِيلْ، أَجِيلُونِي؛   
\m
\v 35 حَاصْرَايْ، أَكَارْمَالِي؛  
\m فَاعْرَايْ، أَلَارْبِي؛   
\m
\v 36 يِيجْعَالْ، مِّيسْ ن نَاثَانْ، زِي صُوبَا؛  
\m بَانِي، أَجَاذِي؛   
\m
\v 37 صَالَاقْ، أَعَامُّونِي؛  
\m نَاحْرَايْ، أَبِيعْرُوثِي،  
\m أَحمَّاڒْ ن ڒسْنَاحْ ن يُووَابْ، مِّيسْ ن صَارُويَا؛   
\m
\v 38 عِيرَا، أَيِيثْرِي؛  
\m جَارِيبْ، أَيِيثْرِي؛   
\m
\v 39 ؤُرِييَا، أَحِيتِّي.  
\m مَارَّا \add جْمِيعْ\add* سبْعَا ؤُ-ثْڒَاثِينْ \add ن يرْيَازنْ\add*.   
\b  
\b  
\m  
\c 24
\s1 أَحْسَابْ ن ڒْڭنْسْ ذ لْعِيقَابْ  
\m
\v 1 ثُوغَا يَارْغَا وغْضَابْ ن سِيذِي عَاوذْ خْ إِسْرَائِيل. نتَّا إِسّكَّارْ ذَاوُوذْ خَاسنْ، إِنَّا: ”ؤُيُورْ أَذْ ثْحسْبذْ إِسْرَائِيل ذ يَاهُوذَا!“ \x ◘ \xo 24:‏1 \xt [1 إِم. 21]\x*  
\v 2 إِنَّا ؤُجدْجِيذْ إِ يُووَابْ، أَكُومَانْذَارْ ن ڒْعسْكَارْ، ونِّي ثُوغَا غَارسْ \add إِدْجَانْ\add*: ”أكّْ مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل، زِي ذَانْ أَڒْ بِئرْ-سبْعَا، سدّْ ڒْڭنْسْ مَاحنْذْ نشّْ أَذْ سّْنغْ ڒْقدّْ \add ن إِرْيَازنْ\add* ن ڒْڭنْسْ.“  
\v 3 \add خنِّي\add* إِنَّا يُووَابْ إِ ؤُجدْجِيذْ: ”أَذْ يَارْنِي سِيذِي، أَربِّي نّشْ، أَطَّاسْ إِ ڒْڭنْسْ-أَ أَمْ مَامّشْ \add دْجَانْ\add* نِيثْنِي \add ڒخُّو\add*، \add عَاذْ\add* مْيَا ن ثْسقَّارْ أَمْ مَامّشْ \add دْجَانْ\add* نِيثْنِي \add ڒخُّو\add*، ؤُ أجّْ أَذْ ژَترنْثْ ثِيطَّاوِينْ ن سِيذِي إِنُو ؤُجدْجِيذْ \add أَيَا\add*. \add مَاشَا\add* إِ ؤُمِي إِوْشَا سِيذِي إِنُو أَجدْجِيذْ ثَايْنِيثْ إِ ثْمسْڒَاشْثْ-أَ؟“  
\v 4 \add مَاشَا\add* أَوَاڒْ ن ؤُجدْجِيذْ إِجْهذْ خْ يُووَابْ ؤُ خْ إِكُومَانْذَارنْ ن ڒْعسْكَارْ، ؤُشَا إِفّغْ يُووَابْ أَكْ-ذ إِكُومَانْذَارنْ ن ڒْعسْكَارْ، يَاڭّْوجْ خْ وُوذمْ ن ؤُجدْجِيذْ حِيمَا أَذْ إِسدّْ ڒْعسْكَارْ ن إِسْرَائِيل.  
\v 5 نِيثْنِي ژْوَانْ لْ-ؤُرْذُونْ ؤُ وْثِينْ إِقِيضَانْ نْسنْ غَارْ ؤُغزْذِيسْ أَفُوسِي ن ثنْذِينْثْ ن عَارُوعِيرْ ثنِّي غَارْ ڒْوسْطْ ن ثغْزَارْثْ ن \add يغْزَارْ ن\add* جَاذْ، ؤُشَا \add ؤُيُورنْ خنِّي\add* غَارْ يَاعْزِيرْ. \x ◘ \xo 24:‏5 \xt ڒخْڒ. 21‏:‏15؛ أَعَوذ. 2‏:‏36؛ ياش. 13‏:‏9، 16\x*  
\v 6 ؤُسِينْ-د ذِي جِيلْعَاذْ ؤُ ذِي ثَاحْثِيمْ-حُوذْشِي. \add خَاسْ ؤُشَا\add* ؤُسِينْ-د غَارْ ذَانْ-يَاعَانْ ؤُ غَارْ جّْوَايهْ ن صِيذُونْ.  
\v 7 ؤُشَا ؤُسِينْ-د غَارْ ثنْذِينْثْ ن صُورْ إِ إِفَارْينْ \add س إِغبْڒَاونْ\add* ؤُ غَارْ مَارَّا ثْندَّامْ ن إِحِيوِييّنْ ذ إِكنْعَانِييّنْ، \add غَارْ ؤُنڭَّارْ\add* إِوْضنْ \add نِيثْنِي\add* غَارْ لْجَانُوبْ ن يَاهُوذَا ذِي بِئرْ-سبْعَا.  
\v 8 أَمُّو كِّينْ نِيثْنِي مَارَّا ثَامُّورْثْ ؤُ أَوَارْنِي عْذُونْ ثسْعَا ن إِيُورنْ ذ عِيشْرِينْ ن وُوسَّانْ ؤُسِينْ-د غَارْ ؤُرْشَالِيمْ.  
\v 9 ؤُ يُووَابْ إِوْشَا إِ ؤُجدْجِيذْ ڒْقدّْ ن ڒحْسَابْ ن ڒْڭنْسْ. ذِي إِسْرَائِيل ثُوغَا ذَايسْ ثمْنْ-مْيَاثْ-أَڒفْ ن يرْيَازنْ إِمحْضنْ إِنِّي إِزمَّارنْ خْ سِّيفْ ؤُ خمْسَا-مْيَاثْ-أَڒفْ ن يرْيَازنْ \add ثُوغَا أَثنْ\add* زِي يَاهُوذَا.   
\m
\v 10 \add مَاشَا\add* ؤُڒْ ن ذَاوُوذْ إِبْذَا أَذْ إِردُّو أَسْ أَوَارْنِي إِحْسبْ ڒْڭنْسْ ؤُ ذَاوُوذْ إِنَّا إِ سِيذِي: ”نشّْ خْضِيغْ \add خَاكْ\add* أَطَّاسْ س مِينْ ڭِّيغْ. \add أَ\add* سِيذِي، كّسْ ڒخُّو ڒْمُوعْصِييّثْ خْ ؤُمْسخَّارْ نّشْ، مَاغَارْ نشّْ ڭِّيغْ ثُوبُّوهڒْيَا ثَامقّْرَانْثْ.“  
\v 11 \add ؤُمِي\add* ذَاوُوذْ إِكَّارْ غَارْ ثُوفُّوثْ، إِمْسَارْ، أَقَا يُوسَا-د أَوَاڒْ ن سِيذِي إِ ؤُنَابِي جَاذْ، أَمْوَاڒَاوْ ن ذَاوُوذْ، إِنَّا:  
\v 12 ”ؤُيُورْ، سِيوڒْ إِ ذَاوُوذْ: ’أَمُّو إِ إِقَّارْ سِيذِي: أَذْ أَشْ د-سَّارْسغْ ثْڒَاثَا ن ثْمسْڒَايِينْ. إِخْضَارْ إِشْثْ زَّايْسنْثْ ؤُشَا أَذْ أَشْ ت ڭّغْ.‘ “  
\v 13 يُوسَا-د جَاذْ غَارْ ذَاوُوذْ، إِخبَّارْ إِ-ث، إِنَّا أَسْ: ”مَا أَذْ إِوْضَا سبْعَا ن إِسڭّْوُوسَا ن ڒَاژْ خْ ثمُّورْثْ نّشْ؟ نِيغْ ثخْسذْ أَذْ ثَاروْڒذْ ثْڒَاثَا ن إِيُورنْ زَّاثْ إِ وُوذمْ ن ڒْعذْيَانْ نّشْ ؤُ نتَّا أَذْ شكْ إِضْفَارْ؟ نِيغْ \add ثخْسذْ\add* أَذْ يِيڒِي طَّاعُونْ ذِي ثمُّورْثْ نّشْ؟ خنِّي ڒخُّو، سّنْ \add مِينْ إِ غَا ثِيخْضَارذْ\add* ؤُ خْزَارْ، مِينْ د غَا أَرّغْ غَارْ ونِّي ذ أَيِي د-إِسّكّنْ.“   
\m
\v 14 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ جَاذْ: ”نشّْ تّْوَاحْصَارغْ أَطَّاسْ. أجّْ أَنغْ أَذْ نوْضَا ذڭْ إِفَاسّنْ ن سِيذِي، مَاغَارْ أَرّحْمثْ نّسْ ثمْغَارْ، مَاشَا وَارْ خْسغْ شَا أَذْ وْضِيغْ ذڭْ إِفَاسّنْ ن إِوْذَانْ.“  
\v 15 \add خنِّي\add* إِسِّيوضْ سِيذِي إِجّْ ن طَّاعُونْ خْ إِسْرَائِيل، زِي ثُوفُّوثْ أَڒْ إِجّْ ن ڒْمِيجَاڒْ إِتّْوَاڭّنْ. مُّوثنْ سبْعِينْ-أَڒفْ ن يرْيَازنْ ن ڒْڭنْسْ زِي ذَانْ أَڒْ بِئرْ-سبْعَا.  
\v 16 \add ؤُمِي\add* إِسّْوِيژّضْ لْمَالَاكْ أَفُوسْ نّسْ خْ ؤُرْشَالِيمْ، حِيمَا أَذْ إِغْضڒْ \add ثَانْذِينْثْ\add* ذڭْ ؤُضيّعْ، إِنْذمْ سِيذِي خْ ثُوعفّْنَا، إِنَّا إِ لْمَالَاكْ إِ إِڭُّورْ أَذْ إِغْضڒْ ڒْڭنْسْ ذڭْ ؤُضيّعْ: ”شْفَا، سهْوَا أَفُوسْ نّشْ ڒخُّو!“ ثُوغَا لْمَالَاكْ ن سِيذِي إِتَّاوضْ غَارْ ؤُنذْرَارْ ن ؤُيابُوسِي أَرَاوْنَا.  
\v 17 \add ؤُمِي\add* ذَاوُوذْ إِژْرَا لْمَالَاكْ ونِّي إِوْثِينْ ڒْڭنْسْ، إِسِّيوڒْ ذَاوُوذْ أَكْ-ذ سِيذِي، إِنَّا: ”خْزَارْ، نشّْ خْضِيغْ ؤُ نشّْ، \add وَاهْ\add* نشّْ ڭِّيغْ ڒْمُوعْصِييّثْ، مَاشَا ؤُدْجِي-يَا، مِينْ ڭِّينْ؟ أجّْ أَذْ يِيڒِي ؤُفُوسْ نّشْ إِ ثشْثِي غَارِي ذ غَارْ ثَادَّارْثْ ن بَابَا.“   
\b  
\m  
\s1 أَعَالْطَارْ خْ ونْذْرَارْ ن أَرَاوْنَا  
\m
\v 18 ذڭْ وَاسّْ نِّي بعْذَا يُوسَا-د جَاذْ غَارْ ذَاوُوذْ، إِنَّا أَسْ: ”ڭعّذْ، سْبدّْ إِجّْ ن ؤُعَالْطَارْ إِ سِيذِي خْ ؤُنذْرَارْ ن ؤُيابُوسِي أَرَاوْنَا.“  
\v 19 ذَاوُوذْ إِڭعّذْ عْلَاحْسَابْ أَوَاڒْ ن جَاذْ، أَمْ مَامّشْ \add ث\add* يُومُورْ سِيذِي.  
\v 20 أَرَاوْنَا إِشيّعْ ؤُ إِژْرَا أَجدْجِيذْ أَكْ-ذ إِمْسخَّارنْ نّسْ ؤُسِينْ-د غَارسْ. \add خنِّي\add* يُويُورْ أَرَاوْنَا غَارْ بَارَّا، إِبنْذقْ زَّاثْ إِ ؤُجدْجِيذْ س ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ.  
\v 21 أَرَاوْنَا إِنَّا: ”مَايمِّي إِ د-يُوسَا سِيذِي إِنُو أَجدْجِيذْ، غَارْ ؤُمْسخَّارْ نّسْ؟“ ذَاوُوذْ إِنَّا: ”حِيمَا أَذْ خَاكْ سْغغْ أَنْذْرَارْ حِيمَا أَذْ بْنِيغْ ذِينْ إِجّْ ن ؤُعَالْطَارْ إِ سِيذِي، مَاحنْذْ أَذْ ثْبدّْ ثشْثِي ذِي ڒْڭنْسْ.“  
\v 22 \add خنِّي\add* إِنَّا أَرَاوْنَا إِ ذَاوُوذْ: ”أجّْ سِيذِي إِنُو أَجدْجِيذْ أَذْ إِكْسِي ؤُ أَذْ إِوهّبْ مِينْ ذ أَسْ إِتّْغِيڒْ ذ لمْلِيحْ ذِي ثِيطَّاوِينْ نّسْ. خْزَارْ أَقَا ذِينْ إِفُونَاسنْ ذ ثْفُونَاسِينْ إِ ثْغَارْصْثْ ن وشْمَاضْ ؤُ \add كْسِي\add* ثِيڒْوِيحِينْ إِتّحْڒُودْجُوضنْ إِ ؤُسَارْوثْ ذ ڒحْوَايجْ ن إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ أَكشُّوضْ \add إِ ثْمسِّي\add*.  
\v 23 أَيَا مَارَّا، \add أَ\add* أَجدْجِيذْ، أَذْ أَشْ إِوْشْ أَرَاوْنَا إِ ؤُجدْجِيذْ.“ \add عَاوذْ\add* إِنَّا أَرَاوْنَا إِ ؤُجدْجِيذْ: ”إِڒِي أَذْ د-ثَاسذْ شكْ خْ ڒْخَاضَارْ غَارْ سِيذِي، أَربِّي نّشْ!“  
\v 24 \add مَاشَا\add* أَجدْجِيذْ إِنَّا إِ أَرَاوْنَا: ”لَّ، مَاغَارْ نشّْ خْسغْ أَذْ خَاكْ ث سْغغْ س تَّامَانْ \add نّسْ إِكْمڒْ\add*، مَاغَارْ نشّْ وَارْ تّْوهّْبغْ إِ سِيذِي، أَربِّي إِنُو، ثِيغَارْصَا ن وشْمَاضْ إِ وَارْ إِسكّْوِينْ وَالُو.“ ؤُ ذَاوُوذْ إِسْغَا أَنْذْرَارْ ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ إِ خمْسِينْ شِيقْلُو ن نُّوقَارْثْ.  
\v 25 ذَاوُوذْ إِبْنَا ذِينْ إِجّْ ن ؤُعَالْطَارْ إِ سِيذِي ؤُشَا إِسّْڭعّذْ ذِينْ ثِيغَارْصَا ن وشْمَاضْ ذ ثوْهِيبِينْ \add ن ڒْغِيدْجثْ\add*. أَمُّو إِتّْوَاسّصْڒحْ سِيذِي خْ ثمُّورْثْ س ثْژَادْجِيثْ يُودْجْغنْ ؤُ ثتّْوَاسّْبدّْ ثشْثِي ذِي إِسْرَائِيل.   