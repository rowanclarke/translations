\id PSA Biblica® Open Lingala Contemporary Bible 2020
\h Banzembo
\toc1 Banzembo
\toc2 Banzembo
\toc3 Nz
\mt1 Banzembo
\c 1
\ms1 Buku ya liboso
\mr Nz 1.1–41.14
\cl Nzembo 1
\s1 Mibeko ya Yawe ezali etima ya mapamboli
\q1 
\v 1 Esengo na moto oyo alandaka te toli ya bato mabe,
\q1 atelemaka te na nzela ya bato ya masumu,
\q2 mpe avandaka te esika moko na batioli,
\q1 
\v 2 kasi asepelaka na mibeko ya Yawe
\q2 mpe akanisaka yango butu mpe moyi.
\q1 
\v 3 Azali lokola nzete oyo balona pene ya mayi,
\q2 oyo ebotaka mbuma na eleko na yango,
\q1 mpe makasa na yango ekawukaka te ;
\q2 misala na ye nyonso etambolaka malamu.
\b
\q1 
\v 4 Kasi ezali bongo te mpo na bato mabe !
\q2 Bazali lokola matiti ya kokawuka
\q2 oyo mopepe epanzaka.
\q1 
\v 5 Yango wana bato mabe bakolonga te
\q2 kotelema na kosambisama,
\q1 mpe bato ya masumu bakowumelaka te
\q2 kati na lisanga ya bato ya sembo.
\b
\q1 
\v 6 Solo, Yawe ayebi nzela ya bato ya sembo,
\q2 kasi nzela ya bato mabe ememaka na libebi.
\c 2
\cl Nzembo 2
\s1 Yawe abulisi Mokonzi
\q1 
\v 1 Mpo na nini bikolo ezali kosala makelele
\q2 mpe bato bazali kosala makita ya pamba ?
\q1 
\v 2 Bakonzi ya mokili batomboki,
\q2 mpe bakambi basangani
\q1 mpo na kotelemela Yawe
\q2 elongo na mopakolami na Ye.
\q1 
\v 3 Bazali koganga elongo :
\q2 « Tokata minyololo na bango
\q2 mpe tomikangola na bokonzi na bango ! »
\b
\q1 
\v 4 Kasi Ye oyo avandi na Kiti na Ye ya Bokonzi
\q2 kuna na likolo aseki,
\q2 Yawe atioli bango.
\q1 
\v 5 Agangeli bango na kanda,
\q2 apelisi kanda makasi na Ye mpo na bango, alobi :
\q1 
\v 6 « Ezali Ngai nde natiaki mokonzi na Ngai
\q2 na Siona, ngomba na Ngai ya bule. »
\q1 
\v 7 Nakosakola mobeko ya Yawe.
\q2 Alobaki na ngai : « Ozali Mwana na Ngai ya mobali,
\q2 na mokolo ya lelo, nakomi Tata na Yo.
\q1 
\v 8 Senga Ngai,
\q2 mpe nakokomisa bikolo libula na Yo,
\q2 basuka ya mokili bozwi na Yo.
\q1 
\v 9 Okoyangela yango na bokonzi ya ebende,
\q2 okopanza yango lokola mbeki ya mabele. »
\b
\q1 
\v 10 Yango wana, bino bakonzi, bozala na mayele ;
\q2 bino bayangeli ya mokili, boyoka likebisi oyo.
\q1 
\v 11 Bosalela Yawe na kobanga
\q2 mpe bosepela na kolenga.
\q1 
\v 12 Bopesa Mwana na Ye beze, noki te akosilika
\q2 mpe bokokufa na nzela na bino,
\q1 pamba te kanda na Ye epelaka noki.
\q2 Esengo na bato oyo bazwaka Ye
\q2 lokola ebombamelo na bango.
\c 3
\cl Nzembo 3
\s1 Yawe Abikisaka
\d 
\v 1 Nzembo ya Davidi. Ayembaki yango tango azalaki kokima Abisalomi, mwana na ye.
\q1 
\v 2 Oh Yawe, banguna na ngai bazali motango boni !
\q2 Banguna boni oyo bazali kobundisa ngai !
\q1 
\v 3 Ebele bazali koloba na tina na ngai :
\q2 « Nzambe akobikisa ye te ! »
\b
\q1 
\v 4 Nzokande Yo, Yawe, ozali nguba mpe nkembo na ngai,
\q2 Yo nde omatisaka lokumu na ngai.
\q1 
\v 5 Nabelelaka Yawe,
\q2 mpe ayanolaka ngai wuta na ngomba na Ye ya bule.
\b
\q1 
\v 6 Nalalaka mpe nazwaka pongi ;
\q2 nalamukaka lisusu,
\q2 pamba te Yawe azali makasi na ngai.
\q1 
\v 7 Nakobanga te atako ebele ya bankoto
\q2 bazingeli ngai na bangambo nyonso.
\b
\q1 
\v 8 Yawe, telema !
\q2 Nzambe na ngai, kangola ngai !
\q1 Beta banguna na ngai nyonso bambata,
\q2 buka bato mabe minu.
\b
\q1 
\v 9 Kokangolama na ngai ewutaka na Yawe.
\q2 Tika ete lipamboli na Yo ewumela
\q2 kati na bato na Yo.
\c 4
\cl Nzembo 4
\s1 Yawe apesaka kimia
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi ; ezali ya koyemba na lindanda.
\q1 
\v 2 Nzambe, bosembo na ngai,
\q2 soki nabeleli Yo, yanola ngai.
\q1 Kangola ngai na pasi,
\q2 salela ngai ngolu,
\q2 mpe yoka libondeli na ngai.
\b
\q1 
\v 3 Bino bato, kino tango nini bokoyokisa
\q2 nkembo na ngai soni ?
\q1 Kino tango nini bokomisepelisa
\q2 na makambo ya pamba
\q2 mpe bokolanda makambo ya lokuta ?
\b
\q1 
\v 4 Boyeba ete Yawe abulisi mpo na Ye moko
\q2 mosali oyo azali sembo na miso na Ye ;
\q1 Yawe ayokaka ngai tango nabelelaka Ye.
\q1 
\v 5 Soki bosiliki, bosalaka masumu te ;
\q2 soki bolali na mbeto,
\q1 bolukaka kososola makambo
\q2 mpe bovandaka kimia.
\b
\q1 
\v 6 Bobonzaka bambeka kolanda mibeko
\q2 mpe botiaka elikya na bino kati na Yawe.
\q1 
\v 7 Bato mingi bazali kotuna :
\q2 « Nani akomemela biso bolamu ? »
\q2 Oh Yawe, ngengisela biso elongi na Yo.
\b
\q1 
\v 8 Tondisa motema na ngai na esengo
\q2 soki bafuluki na bambuma ya ble elongo na vino ya sika.
\q1 
\v 9 Nakolala mpe nakozwa pongi na kimia,
\q2 pamba te, Yo moko Yawe, osalaka
\q2 ete navanda na kimia.
\c 5
\cl Nzembo 5
\s1 Yawe, tambolisa ngai na nzela na Yo
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi ; ezali ya koyemba na flite.
\q1 
\v 2 Oh Yawe, yoka maloba na ngai,
\q2 sosola tina ya kolelalela na ngai.
\q1 
\v 3 Mokonzi na ngai mpe Nzambe na ngai,
\q2 yoka koganga na ngai
\q1 wana nazali kosenga lisungi,
\q2 pamba te nazali kobondela nde Yo.
\q1 
\v 4 Yawe, na tongo, oyokaka mongongo na ngai ;
\q2 na tongo, nabelemaka mpo na kosenga epai na Yo
\q2 mpe nazelaka.
\b
\q1 
\v 5 Pamba te ozali Nzambe te oyo asepelaka na mabe,
\q2 mpe moto mabe akoki kutu te kovanda elongo na Yo.
\q1 
\v 6 Bato ya lolendo bakoki te kotelema liboso na Yo.
\q2 Oyinaka bato nyonso oyo basalaka mabe.
\q1 
\v 7 Obomaka bato oyo balobaka lokuta.
\q2 Yo, Yawe, oyinaka babomi mpe bakosi.
\b
\q1 
\v 8 Kasi mpo ete bolingo na Yo eleki monene,
\q2 nakoki kokota kati na Ndako na Yo,
\q1 nakoki kofukama mpo na botosi
\q2 epai ya Tempelo na Yo ya bule.
\q1 
\v 9 Yawe, tambolisa ngai na bosembo na Yo,
\q2 pamba te nazali na banguna ;
\q2 bongisa nzela oyo olingi ete natambola na yango.
\q1 
\v 10 Minoko na bango elobaka kaka lokuta,
\q2 mitema na bango etondi na mabe.
\q1 Minoko na bango ezali lokola bakunda ya kofungwama,
\q2 mpe bakosaka na nzela ya lolemo na bango.
\q1 
\v 11 Oh Nzambe, katela bango etumbu.
\q2 Tika ete mabongisi na bango ebotela bango libebi.
\q1 Bengana bango mpo na ebele ya masumu na bango,
\q2 pamba te batombokeli nde Yo.
\b
\q1 
\v 12 Kasi tika ete bato nyonso oyo bazwaka Yo
\q2 lokola ebombamelo na bango
\q1 bazalaka na esengo tango nyonso,
\q2 tika ete bayembaka mpo na esengo,
\q1 bomoi na bango mobimba.
\q2 Batela bango mpo ete bato oyo balingaka Kombo na Yo
\q2 basepelaka kati na Yo.
\q1 
\v 13 Oh Yawe, solo, opambolaka bato ya sembo
\q2 mpe ozingelaka bango na nzela ya ngolu na Yo
\q2 lokola na nzela ya nguba.
\c 6
\cl Nzembo 6
\s1 Yawe, Mosungi na ngai
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi ; ezali ya koyemba na lindanda ya basinga mwambe.
\q1 
\v 2 Yawe, kopesa ngai etumbu te na kanda na Yo,
\q2 kopesa ngai etumbu te na kanda makasi na Yo.
\q1 
\v 3 Yawe, yokela ngai mawa,
\q2 pamba te nazangi makasi.
\q1 Yawe, bikisa ngai na bokono,
\q2 pamba te mikuwa na ngai elembi.
\q1 
\v 4 Molimo na ngai ezali kotungisama makasi ;
\q2 bongo Yo, Yawe, kino tango nini ?
\b
\q1 
\v 5 Yawe, zongela ngai, mpe kokangola ngai,
\q2 bikisa ngai, mpo na bolingo na Yo.
\q1 
\v 6 Pamba te bakufi bakoki lisusu te
\q2 kotatola Kombo na Yo te !
\q1 Mpe kati na mboka ya bakufi,
\q2 nani akoki kokumisa Yo ?
\b
\q1 
\v 7 Kolela elembisi ngai nzoto.
\b
\q1 Butu nyonso, nalelaka na mbeto na ngai,
\q2 mpe napolisaka na mpinzoli, esika oyo nalalaka.
\q1 
\v 8 Miso na ngai ebebi mpo na mawa ;
\q2 ezali lisusu komona malamu te likolo ya banyokoli na ngai.
\b
\q1 
\v 9 Bino nyonso oyo bosalaka mabe, bolongwa liboso na ngai,
\q2 pamba te Yawe ayoki kolela na ngai.
\q1 
\v 10 Yawe ayanoli mabondeli na ngai
\q2 mpe ayambi losambo na ngai.
\q1 
\v 11 Banguna na ngai nyonso bakoyoka soni,
\q2 mpe somo monene ekokanga bango ;
\q1 bakozonga na sima
\q2 mpe bakoyoka mbala moko soni.
\c 7
\cl Nzembo 7
\s1 Yawe, longisa ngai
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya mawa oyo Davidi ayembelaki Yawe na tina na Kushi, moto ya libota ya Benjame.
\q1 
\v 2 Yawe, Nzambe na ngai, nabombamaka kati na Yo ;
\q2 bikisa ngai mpe kangola ngai liboso ya bato nyonso
\q2 oyo balukaka koboma ngai.
\q1 
\v 3 Soki te, bakopasola ngai lokola nkosi
\q2 mpe bakokata ngai na biteni,
\q2 mpe moto akozala te mpo na kosunga ngai.
\b
\q1 
\v 4 Yawe, Nzambe na ngai, soki nasalaki makambo
\q2 oyo bazali kopamela ngai mpo na yango,
\q2 mpe soki ezali na mabe na maboko na ngai,
\q1 
\v 5 soki nasalaki moninga na ngai mabe,
\q2 soki nabotolaki na makasi mpe kaka na pamba,
\q2 biloko ya moyini na ngai ;
\q1 
\v 6 wana tika ete monguna na ngai alanda mpe akanga ngai,
\q2 tika ete asakanela bomoi na ngai
\q2 mpe abebisa lokumu na ngai.
\b
\q1 
\v 7 Yawe, telema na kanda na Yo,
\q2 telemela kotomboka ya banguna na ngai.
\q1 Nzambe na ngai, telema, kata likambo na ngai.
\q1 
\v 8 Tika ete bikolo esangana zingazinga na Yo,
\q2 kasi Yo, konza bango wuta na Kiti na Yo ya Bokonzi.
\q1 
\v 9 Tika ete Yawe asambisa bikolo.
\q2 Yawe, longisa ngai kolanda bosembo na ngai,
\q1 kolanda bozangi pamela na ngai,
\q2 Yo-Oyo-Oleki-Likolo.
\b
\q1 
\v 10 Yo Nzambe ya sembo oyo ososolaka
\q2 mozindo ya mayele mpe ya mitema,
\q1 sukisa kanza ya bato mabe
\q2 mpe yikisa moto ya sembo mpiko.
\b
\q1 
\v 11 Nzambe-Oyo-Aleki-Likolo azali nguba na ngai,
\q2 abikisaka bato ya sembo.
\q1 
\v 12 Nzambe azali Mosambisi ya sembo,
\q2 asilikaka mikolo nyonso.
\q1 
\v 13 Soki alembisi kanda na Ye te,
\q2 akopelisa minu ya mopanga na Ye,
\q2 akobongisa mpe akobeta tolotolo na Ye.
\q1 
\v 14 Abongisaka bibundeli oyo ebomaka
\q2 mpe asalaka ete makonga na Ye ekoma kozikisa.
\b
\q1 
\v 15 Moto nyonso oyo abongisaka kosala mabe
\q2 alukaka ndenge nini koyokisa bato pasi
\q2 mpe abebisaka boyokani ;
\q1 
\v 16 atimolaka libulu,
\q2 kasi ye moko nde akweyaka kati na yango.
\q1 
\v 17 Pasi oyo ayokisaka bato ezongelaka ye moko,
\q2 mpe mabe na ye ekweyaka na moto na ye moko.
\b
\q1 
\v 18 Nakokumisa Yawe mpo na bosembo na Ye,
\q2 mpe nakosanzola Yawe-Oyo-Aleki-Likolo na banzembo.
\c 8
\cl Nzembo 8
\s1 Nkembo ya Nzambe
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi ; ezali ya koyemba na lindanda ya bato ya Gati.
\q1 
\v 2 Oh Yawe, Nkolo na biso,
\q2 Kombo na Yo ezali monene kati na mokili mobimba !
\b
\q1 Ovandisi nkembo na Yo
\q2 kati na Lola.
\q1 
\v 3 Na nzela ya masanzoli ya bana mpe bana mike,
\q2 otelemisi ndako batonga makasi,
\q1 mpo na kotelemela bayini na Yo
\q2 mpe kokanga monoko ya monguna
\q2 mpe ya moto oyo alingaka kozongisa mabe na mabe.
\b
\q1 
\v 4 Tango natalaka Lola na Yo,
\q2 mosala ya misapi na Yo,
\q2 sanza mpe minzoto oyo otia,
\q1 
\v 5 namitunaka : Moto azali nini mpo ete okanisa ye,
\q2 mpe moto azali nani mpo ete obatela ye ?
\q1 
\v 6 Osalaki ye moke koleka ba-anjelu
\q2 mpe olatisaka ye motole ya nkembo mpe ya lokumu ;
\q1 
\v 7 otia ye moyangeli ya misala ya maboko na Yo,
\q2 otia nyonso na se ya matambe na ye :
\q1 
\v 8 bameme, bantaba,
\q2 bangombe mpe banyama ya zamba,
\q1 
\v 9 bandeke ya likolo,
\q2 mbisi ya ebale monene
\q2 mpe nyonso oyo etambolaka na bibale.
\b
\q1 
\v 10 Oh Yawe, Nkolo na biso,
\q2 Kombo na Yo ezali monene
\q2 kati na mokili mobimba !
\c 9
\cl Nzembo 9
\s1 Nzambe akataka makambo
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi.
\q1 
\v 2 Nakosanzola Yawe na motema na ngai mobimba,
\q2 nakotatola misala minene na Yo nyonso.
\q1 
\v 3 Nakozala na esengo mpe nakosepela kati na Yo,
\q2 nakoyemba mpo na lokumu ya Kombo na Yo-Oyo-Oleki-Likolo.
\b
\q1 
\v 4 Banguna na ngai bazongaka sima,
\q2 bakweyaka mpe balimwaka liboso na Yo.
\q1 
\v 5 Pamba te, okataki likambo na ngai
\q2 mpe olongisaki ngai,
\q1 ovandi na Kiti ya Bokonzi
\q2 lokola Mosambisi ya sembo.
\q1 
\v 6 Opamelaki bikolo mpe obomaki moto mabe,
\q2 olimwisaki kombo na bango mpo na libela.
\q1 
\v 7 Banguna na ngai balimwa mpo na libela ;
\q2 opanzaki bingumba na bango
\q2 kino bakanisa bango lisusu te.
\b
\q1 
\v 8 Yawe akonzaka mpo na libela,
\q2 atia Kiti na Ye ya Bokonzi
\q2 mpo na kokata makambo ya bato.
\q1 
\v 9 Akonzaka mokili na bosembo,
\q2 akataka makambo ya bato na alima.
\q1 
\v 10 Yawe azali ebombamelo
\q2 mpo na bato oyo bazali konyokolama,
\q2 mpe ndako makasi mpo na tango ya pasi.
\q1 
\v 11 Bato oyo bayebi Kombo na Yo
\q2 batiaka elikya na bango kati na Yo ;
\q1 pamba te, Yo Yawe,
\q2 osundolaka te bato oyo balukaka Yo.
\b
\q1 
\v 12 Boyembela Yawe oyo avandaka kati na Siona
\q2 banzembo ya masanzoli ;
\q2 bopanza sango ya misala na Ye kati na bikolo.
\q1 
\v 13 Pamba te Yawe azongisaka mabe na mabe
\q2 mpo na makila oyo esopani,
\q2 akanisaka koganga ya banyokolami.
\b
\q1 
\v 14 Yawe, yokela ngai mawa,
\q2 tala ndenge nini bayini na ngai
\q1 bazali konyokola ngai,
\q2 mpe kangola ngai wuta na bikuke ya kufa ;
\q1 
\v 15 mpo ete napanza sango ya lokumu na Yo
\q2 kati na bikuke ya Siona, mboka kitoko,
\q2 mpe nasepela na lobiko na Yo kuna.
\b
\q1 
\v 16 Bapagano bakweyi na libulu
\q2 oyo batimolaki,
\q1 makolo na bango ekangami na mitambo
\q2 oyo bango moko basalaki.
\q1 
\v 17 Yawe amilakisi
\q2 na nzela ya misala na Ye ya bosembo ;
\q1 bato mabe bakangami
\q2 na mitambo oyo bango moko basalaki.
\q1 
\v 18 Bato mabe, bikolo nyonso,
\q2 oyo bakanisaka Nzambe te,
\q2 bakokende na mboka ya bakufi.
\q1 
\v 19 Kasi Nzambe akotikala te kobosana mobola,
\q2 mpe elikya ya banyokolami ekotikala seko na seko.
\b
\q1 
\v 20 Yawe, telema ! Tika ete moto alonga te ;
\q2 tika ete bapagano basamba liboso na Yo !
\q1 
\v 21 Yawe, tika ete somo ekanga bango ;
\q2 tika ete bapagano bayeba ete bazali na bango kaka bato !
\c 10
\cl Nzembo 10
\s1 Yawe, belema
\q1 
\v 1 Yawe, mpo na nini otelemi mosika ?
\q2 Mpo na nini obombami na tango ya pasi ?
\b
\q1 
\v 2 Na lolendo na ye, moto mabe oyo akangami
\q2 na mabongisi na ye
\q2 anyokolaka mobola.
\q1 
\v 3 Pamba te moto mabe amikumisaka
\q2 na tina na posa makasi ya motema na ye,
\q1 apambolaka moto oyo azali na lokoso
\q2 mpe afingaka Yawe.
\q1 
\v 4 Na lolendo na ye, moto mabe alobaka : « Nzambe azalaka te. »
\q2 Kati na makanisi na ye nyonso, ezali na esika te mpo na Nzambe.
\q1 
\v 5 Misala na ye ekendeke liboso tango nyonso,
\q2 asalaka keba te na mikano na Yo, Yawe ;
\q2 atiolaka banguna na ye nyonso.
\q1 
\v 6 Amilobelaka :
\q2 « Eloko moko te ekotikala kolengisa ngai. »
\q1 Alapaka ndayi boye :
\q2 « Moko te akotikala kosala ngai mabe. »
\b
\q1 
\v 7 Monoko na ye etonda na bilakeli mabe,
\q2 lokuta mpe mangungu ;
\q2 abongisaka kaka pasi mpe mabe.
\q1 
\v 8 Abombamaka pene ya bamboka.
\q2 Wuta na bisika oyo abombamaka,
\q1 abomaka moto oyo asali mabe te.
\q2 Miso na ye ezelaka na kobombama bato ya koboma.
\q1 
\v 9 Abombamaka lokola nkosi kati na evandelo na yango,
\q2 abombamaka mpo na kokanga moto oyo azangi nguya ;
\q1 akangaka moto oyo azangi nguya
\q2 na kotindika ye pembeni ya motambo.
\q1 
\v 10 Agumbaka ye mpe avandisaka ye na mabele,
\q2 mpe akweyaka na se ya bokonzi na ye.
\q1 
\v 11 Amilobelaka :
\q2 « Nzambe akotikala koyeba te,
\q2 abombaka elongi na Ye mpe akotikala komona te. »
\b
\q1 
\v 12 Oh Yawe, telema.
\q2 Nzambe, sembola loboko na Yo,
\q2 kanisa babola.
\q1 
\v 13 Mpo na nini moto mabe afinga Nzambe ?
\q2 Mpo na nini amilobela :
\q2 « Nzambe akopesa ngai etumbu te ? »
\q1 
\v 14 Pamba te, Yo Nzambe, omoni pasi ya banyokolami ;
\q2 otalaka pasi na bango
\q1 mpe ozwaka yango kati na loboko na Yo.
\q2 Banyokolami bamipesaka epai na Yo
\q1 oyo osungaka bana bitike.
\q1 
\v 15 Bebisa nguya ya moto mabe,
\q2 pesa moto ya misala mabe etumbu
\q1 mpo na mabe na ye,
\q2 mpo ete emonana lisusu te.
\b
\q1 
\v 16 Yawe azali Mokonzi mpo na seko,
\q2 bapagano bakozala lisusu te kati na mokili na Ye.
\q1 
\v 17 Yawe, oyokaka posa ya banyokolami,
\q2 olendisaka bango,
\q2 mpe oyokaka koganga na bango,
\q1 
\v 18 mpo na kolongisa mwana etike mpe monyokolami ;
\q2 boye, bato ya mokili bakobangisa lisusu te.
\c 11
\cl Nzembo 11
\s1 Ebombamelo ya solo
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi.
\q1 Kati na Yawe, nazali koluka ebombamelo.
\q2 Ndenge nini bokoka koloba na ngai :
\q2 « Kimela na ngomba na bino lokola ndeke ? »
\q1 
\v 2 Pamba te, tala, bato mabe babendaka batolotolo na bango,
\q2 batiaka bambanzi na bango na singa
\q1 mpo na kobamba yango longwa na molili
\q2 bato oyo bazali na mitema sembo.
\q1 
\v 3 Soki miboko ebukani,
\q2 moto ya sembo akoki kosala nini ?
\b
\q1 
\v 4 Yawe azali kati na Tempelo na Ye ya bule ;
\q2 Yawe avandi na Kiti na Ye ya Bokonzi kati na Lola.
\q1 Azali kotala bato nyonso ;
\q2 mpe miso na Ye ezali kososola mozindo
\q2 ya mitema na bango.
\q1 
\v 5 Yawe atalaka mozindo ya moto ya sembo,
\q2 kasi ayinaka makasi moto mabe
\q2 elongo na moto oyo asepelaka na mobulu.
\q1 
\v 6 Tika ete akweyisela bato mabe
\q2 makala ya moto, sofolo ya moto !
\q2 Mpe mopepe ya moto ekozala libula na bango.
\b
\q1 
\v 7 Pamba te Yawe azali sembo,
\q2 alingaka bosembo.
\q2 Bato ya sembo bakomona elongi na Ye.
\c 12
\cl Nzembo 12
\s1 Nzambe akokisaka bilaka na Ye
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi ; ya koyemba na lindanda ya basinga mwambe.
\q1 
\v 2 Yawe, sunga biso !
\q2 Pamba te bayengebene bazali lisusu te ;
\q1 bato ya kotiela motema bazali lisusu te
\q2 kati na bana na bato.
\q1 
\v 3 Bato nyonso bazali kokosana bango na bango,
\q2 bazali kolobana maloba ya sukali,
\q2 kasi mitema na bango ezali sembo te.
\b
\q1 
\v 4 Tika ete Yawe aboma bato nyonso
\q2 oyo balobaka maloba ya sukali
\q2 mpe batondi na lolendo,
\q1 
\v 5 ba-oyo balobaka :
\q2 « Tokolonga na nzela ya lolemo na biso,
\q1 bibebu na biso ekolobela biso ;
\q2 nani akoluka kozala nkolo na biso ? »
\b
\q1 
\v 6 Yawe alobi :
\q2 « Mpo ete bazali konyokola babola
\q1 mpe kolelisa bato oyo bakelela,
\q2 natelemi sik’oyo mpo na kobikisa batiolami. »
\q1 
\v 7 Maloba ya Yawe ezalaka peto
\q2 lokola palata oyo balekisi na moto
\q2 mpe bapetoli mbala sambo.
\b
\q1 
\v 8 Yo, Yawe, okobatela bato oyo bakelela,
\q2 okobikisa biso mpo na libela liboso ya bato mabe.
\q1 
\v 9 Bato mabe batambolaka na bonsomi bipai na bipai
\q2 soki bato bapesi bozoba lokumu.
\c 13
\cl Nzembo 13
\s1 Kobanga mpe kolikya
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi.
\q1 
\v 2 Yawe, kino tango nini okobosana ngai mpo na libela ?
\q2 Kino tango nini okobomba elongi na Yo mpo ete namona Yo te ?
\q1 
\v 3 Kino tango nini nakozala mawa-mawa
\q2 kati na motema na ngai
\q1 mpe nakomitungisa mikolo nyonso ?
\q2 Kino tango nini monguna na ngai akolonga ngai ?
\b
\q1 
\v 4 Yawe, Nzambe na ngai, tala mpe yanola ngai.
\q2 Sala ete miso na ngai emona malamu ;
\q2 soki te, nakokufa,
\q1 
\v 5 bongo monguna na ngai akoloba :
\q2 « Nalongi ye, »
\q2 mpe bayini na ngai bakosepela soki nakweyi.
\b
\q1 
\v 6 Kasi ngai, natie elikya na ngai kati na bolingo na Yo,
\q2 mpe motema na ngai ezali kosepela kati na lobiko na Yo.
\q1 Nakoyemba mpo na lokumu ya Yawe,
\q2 pamba te asaleli ngai bolamu.
\c 14
\cl Nzembo 14
\s1 Mokili ezali ya kobeba
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi.
\q1 Bazoba bamilobelaka :
\q2 « Nzambe azali te. »
\q1 Makanisi na bango esila kobeba,
\q2 basalaka makambo ya nkele,
\q2 mpe moko te asalaka bolamu.
\b
\q1 
\v 2 Wuta na Likolo, Yawe atalaka bato
\q2 mpo na koluka koyeba
\q1 soki ezali ata na moko oyo azali na mayele,
\q2 oyo atalelaka Nzambe.
\q1 
\v 3 Bango nyonso babunga nzela,
\q2 bango nyonso bamibebisa ;
\q1 moko te asalaka bolamu,
\q2 ata moto moko te !
\b
\q1 
\v 4 Boni, bato wana nyonso ya misala mabe bayebi eloko te ?
\b
\q1 Bato baliaka bato na ngai ndenge baliaka lipa,
\q2 babelelaka Yawe te !
\q1 
\v 5 Somo monene ekangi bango,
\q2 pamba te Nzambe azali kati na bato ya sembo.
\q1 
\v 6 Bino, bato ya misala mabe, bobebisaka mabongisi ya mobola
\q2 kasi Yawe azali ebombamelo na ye.
\b
\q1 
\v 7 Tika ete lobiko ya Isalaele ebimela na Siona !
\q2 Tango Yawe akobongisa bato na Ye,
\q2 bakitani ya Jakobi bakosepela, mpe Isalaele ekozala na esengo.
\c 15
\cl Nzembo 15
\s1 Nani akoki kovanda esika moko na Nzambe
\d 
\v 1 Nzembo ya Davidi.
\q1 Yawe, nani akoki kovanda kati na Ndako na Yo ya bule ?
\q2 Nani akoki kowumela na ngomba na Yo ya bule ?
\b
\q1 
\v 2 Ezali moto oyo azangi pamela,
\q2 oyo asalaka makambo ya sembo
\q2 mpe alobaka solo ndenge ezali kati na motema na ye ;
\q1 
\v 3 oyo akoselaka moninga makambo te,
\q2 asalaka ye mabe te,
\q2 mpe ayokisaka ye pasi te ;
\q1 
\v 4 asanganaka te na moto oyo asalaka mabe,
\q2 kasi apesaka lokumu na moto oyo atosaka Yawe ;
\q1 akokisaka ndayi na ye atako ekopesa ye pasi,
\q2 mpe abongolaka mokano na ye te ;
\q1 
\v 5 asengaka mileki te soki adefisi mbongo,
\q2 andimaka kanyaka te
\q2 mpo na kokweyisa moto oyo asali mabe te.
\b
\q1 Moto nyonso oyo atambolaka bongo
\q2 akotikala kopengwa te.
\c 16
\cl Nzembo 16
\s1 Nzela ya bomoi
\d 
\v 1 Nzembo ya Davidi.
\q1 Nzambe, batela ngai,
\q2 pamba te nabombami kati na Yo.
\b
\q1 
\v 2 Nalobaka na Yawe : « Ozali Nkolo na ngai,
\q2 Yo moko kaka nde ozali bolamu na ngai. »
\q1 
\v 3 Natatolaka na tina na basantu
\q2 oyo bazali kati na mboka
\q1 ete bazali penza bato minene
\q2 oyo nasepelaka na bango makasi.
\q1 
\v 4 Bato oyo bapotaka mbangu mpo na koluka bolamu epai
\q2 ya banzambe mosusu bakomona pasi mingi.
\q1 Nakosopa te mbeka na bango ya makila epai ya banzambe ya lolenge wana
\q2 mpe nakotanga bakombo na yango te na bibebu na ngai.
\b
\q1 
\v 5 Yawe, Yo moko kaka nde ozali
\q2 libula mpe bomoi na ngai ;
\q2 ozali ndanga ya bozwi na ngai.
\q1 
\v 6 Nazwi etando ya motuya makasi,
\q2 ezali libula ya kitoko penza mpo na ngai !
\q1 
\v 7 Nakopambola Yawe oyo apesaka ngai toli
\q2 mpe, ezala na butu, angengisaka makanisi na ngai.
\q1 
\v 8 Natalelaka Yawe tango nyonso,
\q2 pamba te azali pene na ngai mpo ete naningana te.
\b
\q1 
\v 9 Yango wana motema na ngai etondi na esengo,
\q2 molimo na ngai ezali kosepela,
\q2 nzoto na ngai mpe ekopema na kimia.
\q1 
\v 10 Oh Yawe, okosundola ngai te kati na mboka ya bakufi,
\q2 okotika mpe te ete mosantu na Yo apola.
\q1 
\v 11 Okolakisa ngai nzela ya bomoi ;
\q2 okotondisa ngai na esengo kati na bozalisami na Yo,
\q2 elongo na bilengi ya suka te na ngambo ya loboko na Yo ya mobali.
\c 17
\cl Nzembo 17
\s1 Libondeli ya moto ya sembo
\d 
\v 1 Libondeli ya Davidi.
\q1 Oh Yawe, yoka ngai !
\q2 Kolela na ngai ezali sembo !
\q1 Yoka koganga na ngai !
\q2 Landa malamu libondeli na ngai,
\q2 oyo ezali kobimela te na bibebu ya lokuta.
\q1 
\v 2 Tika ete, na mitindo na Yo,
\q2 bosembo na ngai emonisama solo
\q2 mpe miso na Yo emona oyo ezali alima !
\b
\q1 
\v 3 Soki otali malamu motema na ngai,
\q2 soki olandeli ngai ata na butu
\q1 mpe omeki ngai,
\q2 okomona ete nasalaki mabongisi ya mabe te,
\q2 monoko na ngai ebukaki mobeko te.
\q1 
\v 4 Ata tango bato bamekaki kopesa ngai kanyaka,
\q2 nabatelaki kaka maloba na Yo
\q2 mpo ete natambola te na banzela ya bato ya masumu.
\q1 
\v 5 Matambe na ngai ezalaka kaka na banzela na Yo,
\q2 napengwaka te.
\b
\q1 
\v 6 Nzambe na ngai, nabelelaka Yo,
\q2 pamba te oyanolaka ngai.
\q2 Yoka libondeli na ngai.
\q1 
\v 7 Yo oyo obikisaka mpe okangolaka,
\q2 na nzela ya loboko na Yo ya mobali,
\q1 bato oyo bazwaka Yo lokola ebombamelo na bango,
\q2 lakisa ngai misala kitoko ya bolingo monene na Yo.
\q1 
\v 8 Batela ngai lokola mbuma ya liso,
\q2 bomba ngai na se ya mapapu na Yo,
\q1 
\v 9 mosika ya bato mabe oyo bazali konyokola ngai,
\q2 mosika ya banguna na ngai oyo bazingeli ngai.
\b
\q1 
\v 10 Bakomisi mitema na bango makasi,
\q2 mpe bazali koloba na lolendo.
\q1 
\v 11 Bazali kolanda ngai,
\q2 basili kozingela ngai,
\q1 mpe bazali koluka
\q2 ndenge nini kobwaka ngai na mabele.
\q1 
\v 12 Bazali lokola nkosi
\q2 oyo etondi na posa makasi ya kokanga nyama,
\q1 lokola nkosi ya kanda makasi
\q2 kati na ebombamelo na yango.
\b
\q1 
\v 13 Yawe, telema, kutana na bango
\q2 mpe bebisa bango ;
\q1 na nzela ya mopanga na Yo,
\q2 kangola ngai wuta na maboko ya bato mabe.
\q1 
\v 14 Yawe, na nzela ya nguya na Yo,
\q2 kangola ngai wuta na maboko ya bato wana,
\q1 kangola ngai wuta na maboko ya bato ya mokili oyo.
\q2 Tika ete kufa ezala litomba na bango !
\q1 Tika ete, bango mpe bana na bango,
\q2 balia na lokoso, mpe mabumu na bango etonda
\q1 na bikolo oyo obombaka mpo na bango ;
\q2 bongo babomba ndambo oyo ekotikala
\q2 mpo na bakitani na bango !
\b
\q1 
\v 15 Mpo na ngai, sima na ngai kolonga,
\q2 nakotala elongi na Yo ;
\q1 sima na ngai kolamuka,
\q2 nakosepela na komona Yo !
\c 18
\cl Nzembo 18
\s1 Natondi Yo mpo ete okangoli ngai
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi, mosali na Yawe. Ayembelaki Yawe nzembo na maloba oyo, tango Yawe akangolaki ye wuta na maboko ya banguna na ye nyonso mpe na loboko ya Saulo.
\q1 
\v 2 Oh Yawe, makasi na ngai, nalingaka Yo.
\b
\q1 
\v 3 Yawe azali libanga na ngai,
\q2 ndako na ngai ya makasi mpe mokangoli na ngai ;
\q1 azali Nzambe na ngai, libanga na ngai
\q2 mpe ebombamelo na ngai ;
\q1 azali nguba na ngai,
\q2 Mobikisi na ngai,
\q2 mpe ekimelo na ngai.
\q1 
\v 4 Nabelelaki Yawe oyo abongi na lokumu,
\q2 mpe nakangolamaki wuta na maboko ya banguna na ngai.
\q1 
\v 5 Basinga ya kufa efinaki ngai,
\q2 mpela ya libebi epesaki ngai somo.
\q1 
\v 6 Basinga ya mboka ya bakufi elingaki ngai,
\q2 mitambo ya kufa ekangaki ngai.
\b
\q1 
\v 7 Kati na pasi na ngai, nabelelaki Yawe,
\q2 nagangaki epai ya Nzambe na ngai
\q1 mpo ete asunga ngai.
\q2 Yawe ayokaki mongongo na ngai
\q1 wuta na Tempelo na Ye ;
\q2 koganga na ngai mpo na kosenga lisungi
\q2 ekomaki kino na matoyi na Ye.
\q1 
\v 8 Mabele ekomaki koningana makasi,
\q2 miboko ya bangomba elengaki mpe ebukanaki,
\q2 pamba te Yawe asilikaki.
\q1 
\v 9 Milinga ekomaki kobima na zolo na Ye,
\q2 moto makasi elongo na makala ya moto
\q2 ekomaki kobima na monoko na Ye.
\q1 
\v 10 Yawe afungolaki Lola mpe akitaki ;
\q2 mapata ya mwindo ezalaki na
\q2 se ya matambe na Ye.
\q1 
\v 11 Amataki na likolo ya Sheribe mpe apumbwaki,
\q2 apepaki na mapapu ya mopepe.
\q1 
\v 12 Akomisaki molili ebombamelo na Ye,
\q2 kapo na Ye, oyo ezingelaki Ye ;
\q1 mapata minene ezingelaki Ye,
\q2 mwindo lokola mayi ya mozindo.
\q1 
\v 13 Kongenga oyo ezalaki liboso na Ye
\q2 ezalaki kokimisa mapata,
\q1 konokisa mvula ya mabanga
\q2 mpe kobimisa makala ya moto.
\q1 
\v 14 Yawe agangaki wuta na Lola,
\q2 mongongo ya Ye-Oyo-Aleki-Likolo eyokanaki
\q1 na nzela ya mvula ya mabanga
\q2 mpe makala ya moto.
\q1 
\v 15 Abwakaki makonga na Ye
\q2 mpe atindaki yango na bangambo nyonso ;
\q1 abakisaki motango ya mikalikali
\q2 mpo na kopalanganisa yango.
\q1 
\v 16 Yawe, tango ogangelaki yango,
\q2 na nzela ya pema na Yo
\q1 mpe ya milinga ya zolo na Yo,
\q2 nzela oyo mayi ya ebale elekelaka ebimaki,
\q1 miboko ya mokili emonanaki na libanda.
\b
\q1 
\v 17 Atandaki loboko na Ye wuta na likolo,
\q2 akamataki ngai mpe abimisaki ngai
\q1 na likama oyo nazalaki na yango
\q2 kati na mayi ya mozindo makasi ;
\q1 
\v 18 akangolaki ngai wuta na maboko
\q2 ya monguna na ngai ya nguya mpe ya bayini na ngai,
\q2 pamba te balekaki ngai na makasi.
\q1 
\v 19 Babundisaki ngai,
\q2 na mokolo oyo pasi ezalaki kokanga ngai,
\q2 kasi Yawe azalaki eyekamelo na ngai.
\q1 
\v 20 Abimisaki ngai mpo na kokomisa ngai nsomi,
\q2 akangolaki ngai,
\q2 pamba te alingaka ngai.
\b
\q1 
\v 21 Yawe asaleli ngai makambo wana
\q2 kolanda bosembo na ngai,
\q2 afuti ngai kolanda bopeto ya maboko na ngai ;
\q1 
\v 22 pamba te nabateli banzela ya Yawe,
\q2 napesi Nzambe na ngai mokongo te
\q2 lokola bato mabe.
\q1 
\v 23 Natosaka mibeko na Ye nyonso
\q2 mpe nabatelaka bikateli na Ye.
\q1 
\v 24 Epai na Ye, nazalaki moto oyo azangi pamela
\q2 mpe namibatelaki mpo ete nasala masumu te.
\q1 
\v 25 Yawe afuti ngai kolanda bosembo na ngai,
\q2 kolanda bopeto ya maboko na ngai
\q2 na miso na Ye.
\b
\q1 
\v 26 Solo, otalisaka bosembo na Yo
\q2 epai ya moto oyo atambolaka na bosembo,
\q2 mpe bolamu na Yo, epai ya moto oyo azangi pamela.
\q1 
\v 27 Otalisaka bopeto na Yo epai ya moto ya peto,
\q2 kasi omibombaka liboso ya moto oyo atambolaka nyoka-nyoka.
\q1 
\v 28 Yo nde obikisaka banyokolami,
\q2 okitisaka bato na lofundu.
\q1 
\v 29 Yawe, Nzambe na ngai,
\q2 Yo nde opelisaka mwinda na ngai ;
\q2 obongolaka molili na ngai pole.
\q1 
\v 30 Elongo na Yo, nabundisaka mampinga oyo elati bibundeli ;
\q2 mpe na lisungi ya Nzambe na ngai,
\q2 nakatisaka bamir.
\q1 
\v 31 Nzela ya Nzambe ezali ya kokoka,
\q2 Liloba na Yawe ezali na mbeba te ;
\q1 azali nguba mpo na bato nyonso
\q2 oyo bazwaka Ye lokola ebombamelo na bango.
\q1 
\v 32 Nani azali Nzambe soki Yawe te ?
\q2 Nani azali libanga soki Nzambe na biso te ?
\q1 
\v 33 Nzambe apesaka ngai makasi
\q2 mpe akomisaka nzela na ngai ya kokoka ;
\q1 
\v 34 akomisaka makolo na ngai lokola ya mboloko,
\q2 mpe avandisaka ngai na bisika ya likolo ;
\q1 
\v 35 alakisaka ngai kobunda,
\q2 mpe maboko na ngai ekoki kobenda tolotolo ya bronze.
\q1 
\v 36 Okomisaka lobiko na Yo nguba na ngai,
\q2 loboko na Yo ya mobali elendisaka ngai,
\q2 mpe lisungi na Yo ekomisaka ngai makasi.
\q1 
\v 37 Otambolisaka ngai na kimia,
\q2 mpe makolo na ngai elengaka te.
\b
\q1 
\v 38 Nalandaka banguna na ngai,
\q2 mpe nakangaka bango ;
\q1 nazongaka kaka soki nasilisi koboma bango.
\q1 
\v 39 Nabebisaka bango nye,
\q2 mpe bakokaka lisusu kotelema te ;
\q2 bakweyaka na se ya matambe na ngai.
\q1 
\v 40 Opesaka ngai makasi ya bitumba,
\q2 ogumbaka banguna na ngai
\q2 mpe otiaka bango na se ya matambe na ngai.
\q1 
\v 41 Okimisaka banguna na ngai mosika na ngai,
\q2 mpe nabebisaka bayini na ngai.
\q1 
\v 42 Bagangaka mpo na koluka lisungi,
\q2 kasi moto oyo akokaki kobikisa bango azalaka te ;
\q2 babelelaka Yawe, kasi ayanolaka bango te.
\q1 
\v 43 Nanikaka bango lokola putulu
\q2 oyo mopepe epumbwisaka,
\q2 nanyataka bango lokola potopoto ya nzela.
\q1 
\v 44 Olongisaka ngai na bitumba ya bato,
\q2 obatelaka ngai mpo ete nazala mokambi ya bikolo.
\q2 Bato oyo nayebaki te bakomi kosalela ngai.
\q1 
\v 45 Soki kaka bayoki ngai, batosaka ngai ;
\q2 mpe bapaya bayaka
\q2 mpo ete nasepela na bango.
\q1 
\v 46 Bango nyonso balembi nzoto
\q2 mpe bakomi kobima na kolenga
\q2 wuta na bandako na bango ya makasi.
\b
\q1 
\v 47 Longonya na Yawe !
\q2 Tika ete Ye oyo azali libanga na ngai akumisama !
\q1 Tika ete Nzambe ya lobiko na ngai anetolama !
\q1 
\v 48 Azali Nzambe oyo abundelaka ngai,
\q2 oyo atiaka bikolo na se ya matambe na ngai,
\q1 
\v 49 oyo akangolaka ngai
\q2 wuta na maboko ya banguna na ngai.
\q1 Olongisaka ngai liboso ya banguna na ngai,
\q2 obikisaka ngai na maboko ya banguna na ngai.
\q1 
\v 50 Yango wana, nakosanzola Yo, Yawe, kati na bikolo ;
\q2 nakoyemba mpo na lokumu ya Kombo na Yo.
\b
\q1 
\v 51 Yawe apesaka elonga monene
\q2 epai ya mokonzi na Ye,
\q1 atalisaka bolingo na Ye epai ya mopakolami na Ye,
\q2 epai ya Davidi mpe epai ya libota na ye, mpo na libela.
\c 19
\cl Nzembo 19
\s1 Bimoniseli mibale ya Nzambe
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi.
\q1 
\v 2 Likolo etatolaka nkembo ya Nzambe,
\q2 mapata elobaka misala na Ye.
\q1 
\v 3 Mokolo moko na moko eyebisaka yango
\q2 epai ya mokolo oyo elandaka,
\q1 mpe butu moko na moko eyebisaka yango
\q2 epai ya butu oyo elandaka.
\q1 
\v 4 Ezali na nzela ya lisolo te,
\q2 na nzela mpe ya maloba te
\q2 oyo mingongo na yango eyokanaka te.
\q1 
\v 5 Nzokande, sango na yango eyokanaka na mokili mobimba,
\q2 maloba na yango ekomaka kino na suka ya mokili.
\q2 Na likolo, Nzambe atie ndako ya kapo mpo na moyi.
\q1 
\v 6 Moyi yango ebimaka na tongo
\q2 ndenge elenge mobali oyo abali sika
\q2 abimaka na shambre na ye,
\q1 mpe ndenge elombe atambolaka
\q2 na elikya ya kolonga na momekano.
\q1 
\v 7 Moyi ebimaka wuta na songe moko ya likolo,
\q2 mpe esukisaka mobembo na yango na songe mosusu ;
\q2 eloko moko te ezangaka kozwa molunge na yango.
\q1 
\v 8 Mibeko ya Yawe ezali ya kokoka,
\q2 epesaka biso lisusu nguya ya kozala na bomoi.
\q1 Maloba na Ye nyonso ezali ya solo,
\q2 ebongi na kotiela yango elikya,
\q2 mpe epesaka bwanya epai ya zoba.
\q1 
\v 9 Mitindo ya Yawe ezali alima,
\q2 esepelisaka motema ;
\q1 malako na Ye ezali peto,
\q2 epesaka bososoli.
\q1 
\v 10 Kotosa Yawe ezali peto,
\q2 ewumelaka libela na libela.
\q1 Mitindo ya Yawe ezali ya solo,
\q2 nyonso ezali penza sembo.
\b
\q1 
\v 11 Ezali na motuya koleka wolo,
\q2 koleka wolo ebele ya peto,
\q2 wolo oyo basangisa na eloko mosusu te ;
\q1 eleki mafuta ya nzoyi na elengi,
\q2 mafuta ya nzoyi oyo ezali kobima sika.
\q1 
\v 12 Epesaka mosali na Yo mayele ;
\q2 moto nyonso oyo atosaka yango azwaka litomba mingi.
\q1 
\v 13 Nani akoki kososola mabunga na ye
\q2 oyo asali na nko te ?
\q1 Limbisa masumu na ngai, oyo nayebi te !
\q1 
\v 14 Batela lisusu mosali na Yo
\q2 mpo ete nasala mabe na nko te.
\q1 Na bongo, nakozala moto ya kokoka
\q2 mpe nakosala bambeba minene te.
\q1 
\v 15 Yawe, Libanga na ngai mpe Mosikoli na ngai,
\q2 tika ete maloba mpe makanisi ya motema na ngai
\q2 esepelisa Yo !
\c 20
\cl Nzembo 20
\s1 Yawe, longisa mokonzi na biso
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi.
\q1 
\v 2 Tika ete Yawe ayanola yo
\q2 na tango ya pasi ;
\q1 tika ete Nzambe ya Jakobi azala
\q2 ndako batonga makasi mpo na kobatela yo.
\q1 
\v 3 Tika ete asunga yo wuta na Esika na Ye ya bule
\q2 mpe apesa yo makasi wuta na Siona.
\q1 
\v 4 Tika ete akanisa makabo na yo nyonso
\q2 mpe andima mbeka na yo ya kotumba.
\q1 
\v 5 Tika ete akokisa posa ya motema na yo
\q2 mpe mabongisi na yo nyonso.
\b
\q1 
\v 6 Tokoganga na esengo mpo na lobiko na Yo
\q2 mpe tokotombola bendele
\q2 na Kombo ya Nzambe na biso.
\q1 Tika ete Yawe akokisa bisengeli na Yo nyonso.
\b
\q1 
\v 7 Nayebi sik’oyo ete Yawe abikisaka mopakolami na Ye,
\q2 ayanolaka ye wuta na Esika na Ye ya bule kati na Lola,
\q2 na nzela ya nguya ya loboko na Ye ya mobali.
\q1 
\v 8 Bamoko batiaka elikya na bango kati na bashar,
\q2 bamosusu, kati na bampunda ;
\q1 kasi biso totiaka elikya na biso
\q2 kati na Kombo na Yawe, Nzambe na biso.
\q1 
\v 9 Bango, bafukamaka mpe bakweyaka ;
\q2 kasi biso, tozalaka kaka ya kotelema
\q2 mpe totikalaka ngwi.
\q1 
\v 10 Yawe, bikisa mokonzi !
\q2 Yanola biso tango tozali kobelela.
\c 21
\cl Nzembo 21
\s1 Matondi mpo na elonga
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi.
\q1 
\v 2 Yawe, mokonzi azali kosepela na nguya na Yo;
\q2 Tala ndenge nini elonga oyo opesi ye
\q2 epesi ye esengo monene !
\q1 
\v 3 Okokisi posa ya motema na ye
\q2 mpe opimeli ye te oyo azalaki kosenga Yo.
\q1 
\v 4 Oyei epai na ye na mapamboli ya motuya.
\q2 Na moto na ye, olatisi ye motole ya wolo
\q2 oyo basangisa na eloko mosusu.
\q1 
\v 5 Asengaki Yo bomoi, mpe opesaki ye yango ;
\q2 opesaki ye bomoi molayi mpe ya libela na libela.
\q1 
\v 6 Nkembo na ye ezali monene
\q2 mpo na lobiko oyo opesaki ye ;
\q2 olatisaki ye na kongenga mpe na lokumu.
\q1 
\v 7 Solo, okomisi ye etima ya mapamboli ya seko na seko ;
\q2 okomisaki ye moto ya esengo na miso na Yo.
\q1 
\v 8 Mokonzi atiaka elikya na Yawe,
\q2 aninganaka te mpo na bolingo ya Ye-Oyo-Aleki-Likolo.
\q1 
\v 9 Loboko na Yo ekokanga banguna na Yo nyonso ;
\q2 loboko na Yo ya mobali ekokanga bayini na Yo.
\q1 
\v 10 Tango okomimonisa,
\q2 okokomisa bango lokola fulu ya moto.
\q1 Yawe akosilisa koboma bango na kanda na Ye,
\q2 mpe moto ekozikisa bango.
\q1 
\v 11 Okolimwisa mabota na bango na mokili,
\q2 mpe bakitani na bango, kati na bana ya bato.
\q1 
\v 12 Atako bakani kosala Yo mabe,
\q2 atako basali mabongisi ya mabe
\q1 mpo na kotelemela Yo,
\q2 bakotikala kolonga ata moke te ;
\q1 
\v 13 pamba te okobengana bango
\q2 tango okobwakela bango bambanzi ya tolotolo na Yo.
\q1 
\v 14 Yawe, telema na nguya na Yo !
\q2 Tokoyemba nguya na Yo na nzela ya banzembo.
\c 22
\cl Nzembo 22
\s1 Mpo na nini osundoli ngai
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi, ya koyemba lokola nzembo na kombo « Mboloko ya tongo. »
\q1 
\v 2 Nzambe na ngai, Nzambe na ngai,
\q2 mpo na nini osundoli ngai ?
\q1 Mpo na nini otelemi mosika ?
\q2 Mpo na nini ozali kobikisa ngai te ?
\q2 Mpo na nini ozali koyoka te koganga na ngai ?
\q1 
\v 3 Nzambe na ngai, na moyi, nabeleli Yo,
\q2 kasi oyanoli ngai te ;
\q1 na butu, nabeleli lisusu,
\q2 mpe natikali kovanda nye te.
\b
\q1 
\v 4 Nzokande, ozali Mosantu,
\q2 ovandaka na Kiti na Yo ya Bokonzi,
\q2 kati na masanzoli ya Isalaele.
\q1 
\v 5 Batata na biso batiaki elikya na bango kati na Yo,
\q2 bamipesaki epai na Yo,
\q2 mpe okangolaki bango.
\q1 
\v 6 Bagangaki epai na Yo,
\q2 mpe Yo okangolaki bango ;
\q1 batiaki elikya na bango kati na Yo
\q2 mpe bayokisamaki soni te.
\b
\q1 
\v 7 Nazali lisusu moto te, kasi mutsopi ;
\q2 bato nyonso bazali kofinga mpe kotiola ngai.
\q1 
\v 8 Bato nyonso oyo bazali komona ngai
\q2 bazali koseka ngai, bazali kokamwa,
\q2 koningisa mito mpe koloba :
\q1 
\v 9 « Atiaka motema na ye epai na Yawe ;
\q2 tika ete Yawe abikisa ye !
\q1 Tika ete Yawe akangola ye,
\q2 pamba te asepelaka na Ye ! »
\b
\q1 
\v 10 Solo, Yawe, obimisaki ngai na libumu ya mama na ngai,
\q2 obatelaki ngai na kimia na tolo na ye.
\q1 
\v 11 Wuta mbotama na ngai,
\q2 batikaki ngai na maboko na Yo ;
\q1 wuta libumu ya mama na ngai,
\q2 ozali Nzambe na ngai.
\q1 
\v 12 Kozala mosika na ngai te,
\q2 pamba te pasi ekomi pene
\q2 mpe nazangi moto oyo akosunga ngai.
\q1 
\v 13 Banguna na ngai bazingeli ngai
\q2 lokola lisanga ya bangombe ya mibali,
\q1 bazingeli ngai lokola banyama mabe
\q2 oyo ezalaka na Bashani ;
\q1 
\v 14 mpe bafungoleli ngai makasi minoko na bango
\q2 lokola nkosi oyo etomboki mpe ezali kolia nyama.
\q1 
\v 15 Nakomi lokola mayi oyo ezali kosopana,
\q2 mpe mikuwa na ngai nyonso ekabwani ;
\q1 motema na ngai ekomi lokola mafuta
\q2 oyo ezali konyangwama kati na ngai.
\q1 
\v 16 Makasi na ngai ekawuki lokola potopoto,
\q2 mpe nazali kokoka lisusu koloba te ;
\q1 otie ngai pembeni ya lilita.
\b
\q1 
\v 17 Bambwa ezingeli ngai,
\q2 ngulupa ya bato mabe bayei kobundisa ngai,
\q1 bazali kotambola zingazinga na ngai ;
\q2 bakangi maboko mpe makolo na ngai na basinga.
\q1 
\v 18 Nakoki sik’oyo kotanga ata mikuwa na ngai nyonso ;
\q2 kasi bato bazali kotala mpe koseka ngai,
\q1 
\v 19 bazali kokabola bilamba na ngai
\q2 mpe kobeta zeke mpo na nzambala na ngai.
\q1 
\v 20 Kasi Yo, Yawe, kozala mosika te !
\q2 Ozali makasi na ngai ;
\q2 yaka noki kosunga ngai.
\q1 
\v 21 Bikisa bomoi na ngai liboso ya mopanga,
\q2 mpe kangola yango wuta na manzaka ya bambwa.
\q1 
\v 22 Bikisa ngai wuta na monoko ya nkosi
\q2 mpe na maseke ya mpakasa.
\q1 
\v 23 Nakotatola Kombo na Yo epai ya bandeko na ngai,
\q2 mpe nakokumisa Yo kati na mayangani.
\q1 
\v 24 Bino bato oyo botosaka Yawe, bosanzola Ye !
\q2 Bino nyonso bana ya Jakobi, bopesa Ye lokumu !
\q2 Bino nyonso bana ya Isalaele, botosa Ye !
\q1 
\v 25 Pamba te Yawe atiolaki te
\q2 mpe abwakaki te mobola ;
\q1 apesaka ye mokongo te mpe ayokaka ye
\q2 tango asengaka lisungi.
\b
\q1 
\v 26 Na ngolu na Yo, nakumisaka Yo kati na mayangani,
\q2 nakokisaka bandayi na ngai
\q2 na miso ya bato oyo batosaka Yo.
\q1 
\v 27 Babola bakolia mpe bakotonda ;
\q2 bato oyo balukaka Yawe bakosanzola Ye.
\q2 Tika ete bozala na bomoi libela na libela.
\b
\q1 
\v 28 Mokili mobimba ekokanisa Yawe,
\q2 ekomipesa epai na Ye ;
\q2 mpe bituka nyonso ya bikolo ekogumbama liboso na Ye.
\q1 
\v 29 Pamba te Yawe azali Mokonzi,
\q2 azali kokonza bikolo.
\b
\q1 
\v 30 Bazwi nyonso ya mokili bakolia
\q2 mpe bakogumbamela Ye ;
\q1 bato nyonso oyo bazali kokende na kunda,
\q2 ba-oyo bakoki te komibatela na bomoi,
\q2 bakogumbama liboso na Ye.
\q1 
\v 31 Bakitani na bango bakosalela Yawe
\q2 mpe bakopanza sango na Ye
\q2 epai ya ekeke oyo ekoya na sima ;
\q1 
\v 32 bakosakola misala ya bosembo na Ye,
\q2 epai ya bato oyo bakobotama.
\c 23
\cl Nzembo 23
\s1 Yawe azali Mobateli na ngai
\d 
\v 1 Nzembo ya Davidi.
\q1 Yawe azali mobateli na ngai,
\q2 nakozanga ata eloko moko te.
\q1 
\v 2 Apemisaka ngai na matiti ya mobesu,
\q2 mpe amemaka ngai pembeni ya mayi ya kimia.
\q1 
\v 3 Ayeisaka sika makasi ya bomoi na ngai,
\q2 akambaka ngai na banzela ya bosembo
\q2 mpo na lokumu ya Kombo na Ye.
\q1 
\v 4 Ata soki nasengeli kokatisa lubwaku
\q2 oyo etondi na molili ya kufa,
\q1 nakobanga mabe ata moko te,
\q2 pamba te ozali elongo na ngai,
\q1 nzete na Yo ya mobateli ekambaka ngai,
\q2 mpe lingenda na Yo ebatelaka ngai.
\q1 
\v 5 Obongisaka mesa mpo na ngai
\q2 na miso ya bayini na ngai,
\q1 opakolaka moto na ngai mafuta
\q2 mpe otondisaka kopo na ngai kino kosopana.
\q1 
\v 6 Solo, na mikolo nyonso ya bomoi na ngai,
\q2 esengo mpe bolingo na Yo ekobanda kolanda ngai ;
\q1 mpe nakovanda kati na Tempelo ya Yawe
\q2 kino suka ya bomoi na ngai.
\c 24
\cl Nzembo 24
\s1 Yawe akoti na Tempelo
\d 
\v 1 Nzembo ya Davidi.
\q1 Mabele mpe nyonso oyo ezali kati na yango
\q2 ezali ya Yawe.
\q1 Mokili mpe ezali ya Yawe,
\q2 elongo na bavandi na yango.
\q1 
\v 2 Pamba te ezali Yawe nde atia yango
\q2 na likolo ya bibale minene
\q2 mpe apikaki yango na likolo ya miluka.
\q1 
\v 3 Nani akokoka komata ngomba ya Yawe ?
\q2 Nani akokoka kotelema kati na Esika na Ye ya bule ?
\q1 
\v 4 Ezali moto oyo azali maboko pembe mpe motema peto,
\q2 oyo atiaka elikya te na banzambe ya bikeko
\q2 mpe alapaka ndayi ya lokuta te.
\b
\q1 
\v 5 Yawe akopambola ye ;
\q2 mpe Nzambe, Mobikisi na ye, akokomisa ye sembo.
\q1 
\v 6 Ndenge wana nde ezali,
\q2 ekeke ya bato oyo bakangamaka na Yo,
\q2 ba-oyo balukaka elongi na Yo, Nzambe ya Jakobi.
\b
\q1 
\v 7 Bino bikuke, botombola mitondo na bino !
\q2 Bino bikuke ya kala, bomitombola !
\q2 Tika ete Mokonzi ya nkembo akota !
\q1 
\v 8 Nani azali Mokonzi yango ya nkembo ?
\q2 Ezali Yawe, Elombe ya nguya ;
\q2 Yawe, Elombe ya bitumba.
\q1 
\v 9 Bino bikuke, botombola mitondo na bino !
\q2 Bino bikuke ya kala, bomitombola !
\q2 Tika ete Mokonzi ya nkembo akota !
\q1 
\v 10 Nani azali Mokonzi yango ya nkembo ?
\q2 Ezali Yawe, Mokonzi ya mampinga,
\q2 nde azali Mokonzi ya nkembo !
\c 25
\cl Nzembo 25
\s1 Yawe, lakisa ngai nzela ya kolanda
\d 
\v 1 Nzembo ya Davidi.
\q1 Yawe, Nzambe na ngai,
\q2 natiaka elikya na ngai kati na Yo.
\b
\q1 
\v 2 Nzambe na ngai,
\q2 natiaka elikya na ngai kati na Yo ;
\q1 sala ete nayoka soni te,
\q2 mpe banguna na ngai basepela te na tina na ngai.
\q1 
\v 3 Bato nyonso oyo batalelaka Yo
\q2 bakotikala koyokisama soni ata moke te ;
\q1 kaka ba-oyo bapesaka Yo mokongo
\q2 nde bakoyokisama soni.
\q1 
\v 4 Yawe, lakisa ngai nzela,
\q2 teya ngai nzela oyo olingi ete nalanda.
\q1 
\v 5 Kamba ngai kati na bosolo na Yo
\q2 mpe pesa ngai mayele,
\q1 pamba te ozali Nzambe, Mobikisi na ngai ;
\q2 mpe ngai natiaka elikya na ngai
\q2 kati na Yo tango nyonso.
\q1 
\v 6 Yawe, kanisa mawa mpe bolingo na Yo,
\q2 pamba te ezali mpo na libela na libela.
\q1 
\v 7 Yawe, kokanisa te masumu
\q2 mpe botomboki ya bolenge na ngai ;
\q1 kanisa ngai kaka kolanda boboto na Yo,
\q2 pamba te ozali malamu.
\b
\q1 
\v 8 Solo, Yawe azali malamu mpe alima ;
\q2 atalisaka banzela na Ye
\q2 epai ya bato ya masumu.
\q1 
\v 9 Atambolisaka bato oyo bamikitisa,
\q2 kati na banzela ya sembo,
\q2 mpe ateyaka bango banzela na Ye.
\q1 
\v 10 Banzela nyonso ya Yawe etalisaka bolingo
\q2 mpe boyengebene na Ye mpo na bato
\q2 oyo babatelaka boyokani mpe malako na Ye.
\q1 
\v 11 Yawe, mpo na bolingo ya Kombo na Yo,
\q2 limbisa masumu na ngai,
\q2 atako ezali minene.
\b
\q1 
\v 12 Banani bazali bato oyo batosaka Yawe ?
\q2 Alakisaka bango nzela ya kopona.
\q1 
\v 13 Boye, bakolekisa mikolo ya bomoi na bango
\q2 kati na bofuluki,
\q2 mpe mokili ekozala libula ya bana na bango.
\q1 
\v 14 Yawe ayebisaka mabongisi na Ye
\q2 epai ya bato oyo batosaka Ye,
\q2 alakisaka bango mabombami ya boyokani na Ye.
\q1 
\v 15 Natalelaka Yawe tango nyonso,
\q2 pamba te kaka Ye nde akolongola
\q2 makolo na ngai na motambo.
\b
\q1 
\v 16 Yawe, balola miso na Yo epai na ngai
\q2 mpe salela ngai ngolu,
\q1 pamba te nazali kaka ngai moko,
\q2 mpe nazali monyokolami.
\q1 
\v 17 Lembisa pasi ya motema na ngai
\q2 mpe kangola ngai na mitungisi na ngai.
\q1 
\v 18 Tala pasi mpe kolela na ngai,
\q2 mpe limbisa masumu na ngai nyonso.
\q1 
\v 19 Tala ndenge nini banguna na ngai bazali ebele,
\q2 mpe ndenge nini bazali koyina ngai makasi !
\b
\q1 
\v 20 Batela bomoi na ngai mpe kangola ngai ;
\q2 sala ete nayoka soni te,
\q2 pamba te nabombamaka kati na Yo.
\q1 
\v 21 Lokola mpe natielaka Yo motema,
\q2 tika ete bozangi pamela mpe bosembo ebatela ngai.
\b
\q1 
\v 22 Nzambe, kangola Isalaele,
\q2 na pasi na yango nyonso !
\c 26
\cl Nzembo 26
\s1 Yawe, longisa ngai
\d 
\v 1 Nzembo ya Davidi.
\q1 Yawe, longisa ngai na miso ya basambisi,
\q2 pamba te natambolaka na bosembo ;
\q1 natielaka Yawe motema,
\q2 nakozonga sima te.
\q1 
\v 2 Yawe, tala ngai malamu mpe meka ngai,
\q2 sosola motema mpe makanisi na ngai,
\q1 
\v 3 pamba te napengwaka te liboso ya bolingo na Yo
\q2 mpe nabikaka bomoi na ngai kolanda bosembo na Yo.
\b
\q1 
\v 4 Navandaka esika moko te na bakosi,
\q2 natambolaka nzela moko te na bato ya mitema mibale.
\q1 
\v 5 Nayinaka kosangana elongo na bato ya misala mabe
\q2 mpe navandaka te esika moko na bato mabe.
\q1 
\v 6 Yawe, nasukoli maboko na ngai
\q2 mpo na kolakisa ete nasali mabe te,
\q2 mpe nabandi na etumbelo na Yo,
\q1 
\v 7 mpo na kozongisela Yo matondi
\q2 mpe kotatola misala minene na Yo.
\b
\q1 
\v 8 Yawe, nasepelaka na Tempelo
\q2 epai wapi ovandaka elongo na nkembo na Yo.
\q1 
\v 9 Kolongola te molimo na ngai nzela moko na bato ya masumu,
\q2 bomoi na ngai elongo na basopi makila,
\q1 
\v 10 oyo maboko na bango etondi na makila,
\q2 mpe maboko na bango ya mibali etondi na kanyaka.
\q1 
\v 11 Natambolaka na bomoi ya bosembo ;
\q2 kangola ngai mpe salela ngai ngolu.
\b
\q1 
\v 12 Makolo na ngai etambolaka na nzela ya alima ;
\q2 nakopambola Yawe kati na mayangani ya monene.
\c 27
\cl Nzembo 27
\s1 Nabatelami malamu epai ya Nzambe
\d 
\v 1 Nzembo ya Davidi.
\q1 Yawe azali pole mpe lobiko na ngai ;
\q2 nakobanga nani ?
\q1 Yawe azali ndako batonga makasi ya bomoi na ngai ;
\q2 nakolenga liboso ya nani ?
\b
\q1 
\v 2 Tango bato mabe babundisaka ngai
\q2 mpo na koluka kosala ngai mabe,
\q1 ezali bayini mpe banguna na ngai
\q2 nde baninganaka mpe bakweyaka.
\q1 
\v 3 Ata limpinga ezingeli ngai,
\q2 motema na ngai ekobanga soki moke te ;
\q1 ata etumba etelemi mpo na koboma ngai,
\q2 atako bongo, nakozala kaka na elikya makasi.
\b
\q1 
\v 4 Nalukaka eloko moko kowuta na Yawe,
\q2 eloko moko kaka oyo nasengaka makasi :
\q1 nalingi kovanda na Tempelo ya Yawe,
\q2 mikolo nyonso ya bomoi na ngai,
\q1 mpo na kosepelaka na kitoko ya Yawe
\q2 mpe kosengaka toli na Ye kati na Tempelo na Ye.
\q1 
\v 5 Pamba te, na tango ya pasi,
\q2 akobatela ngai kati na evandelo na Ye,
\q1 akobomba ngai kati ya Ndako na Ye ya bule
\q2 mpe akotelemisa ngai na likolo ya libanga.
\b
\q1 
\v 6 Bongo, nakotombola moto na ngai
\q2 na likolo ya banguna oyo bazingeli ngai ;
\q1 nakobanda kobonza, na se ya lokito ya esengo,
\q2 bambeka kati Ndako na Ye ya bule ;
\q1 nakobanda koyembela Yawe
\q2 mpe kobetela Ye mindule.
\b
\q1 
\v 7 Yawe, yoka mongongo na ngai,
\q2 soki nabeleli Yo ;
\q1 salela ngai ngolu mpe yanola ngai.
\q1 
\v 8 Motema na ngai elobi na tina na Yo :
\q2 « Tala elongi na Ye ! »
\q2 Yawe, nakotala elongi na Yo.
\q1 
\v 9 Kopesa ngai mokongo te,
\q2 kobengana mosali na Yo te na kanda ;
\q1 osungaki ngai.
\q2 Kotika ngai te, kosundola ngai te,
\q2 Nzambe, Mobikisi na ngai.
\q1 
\v 10 Ata tata mpe mama na ngai basundoli ngai,
\q2 Yawe akolokota ngai.
\q1 
\v 11 Yawe, lakisa ngai nzela na Yo,
\q2 tambolisa ngai na nzela ya alima,
\q2 pamba te banguna na ngai bazali koluka ngai.
\q1 
\v 12 Kotika te ete nakangama na motambo ya bayini na ngai,
\q2 pamba te batatoli ya lokuta batelemi
\q1 mpo na kokosela ngai makambo,
\q2 bazali kobimisa maloba mabe.
\b
\q1 
\v 13 Nakozalaka na elikya na likambo oyo :
\q2 nakobika bolamu ya Yawe
\q2 kati na mokili ya bato ya bomoi.
\q1 
\v 14 Talela Yawe !
\q2 Zala makasi mpe yika mpiko !
\q2 Talela Yawe !
\c 28
\cl Nzembo 28
\s1 Yawe, yanola ngai
\d 
\v 1 Nzembo ya Davidi.
\q1 Yawe, nazali kobelela Yo !
\q2 Ozali Libanga na ngai,
\q2 koboya te koyoka ngai.
\q1 Soki te, nakozala lokola bato
\q2 oyo bazali kokita na kunda.
\q1 
\v 2 Yoka ngai tango nabondelaka Yo
\q2 mpo na kosenga lisungi,
\q1 tango natombolaka maboko na ngai,
\q2 na kotala na ngambo ya Esika-Oyo-Eleki-Bule.
\b
\q1 
\v 3 Kokumba ngai te elongo na bato mabe,
\q2 elongo na bato oyo basalaka mabe,
\q1 oyo balobaka makambo ya kimia epai ya baninga na bango,
\q2 kasi babombaka mabe kati na mitema na bango.
\q1 
\v 4 Zongisela bango kolanda misala na bango,
\q2 kolanda misala mabe na bango ;
\q1 zongisela bango kolanda misala ya maboko na bango,
\q2 mpe kweyisela bango oyo ekoki na misala na bango.
\b
\q1 
\v 5 Pamba te bamemiaka te misala ya Yawe
\q2 mpe makambo oyo akokisaka,
\q1 akobamba bango na mabele
\q2 mpe akotikala kotelemisa bango lisusu te.
\b
\q1 
\v 6 Tika ete Yawe akumisama,
\q2 pamba te ayanoli mabondeli na ngai.
\q1 
\v 7 Yawe azali makasi mpe nguba na ngai ;
\q2 natielaka Ye motema na ngai, mpe asungaka ngai.
\q1 Motema na ngai etondi na esengo,
\q2 mpe nazali kokumisa Ye na banzembo na ngai.
\b
\q1 
\v 8 Yawe azali makasi ya bato na Ye,
\q2 ndako batonga makasi epai wapi mopakolami na Ye azwaka lobiko.
\q1 
\v 9 Yawe, bikisa bato na Yo
\q2 mpe pambola libula na Yo ;
\q1 zala mobateli na bango
\q2 mpe sunga bango mpo na libela.
\c 29
\cl Nzembo 29
\s1 Mongongo ya Yawe
\d 
\v 1 Nzembo ya Davidi.
\q1 Bopesa Yawe, bino ba-anjelu ya Nzambe,
\q2 bopesa Yawe nkembo mpe makasi.
\q1 
\v 2 Bopesa Yawe nkembo oyo ekoki na lokumu ya Kombo na Ye ;
\q2 bogumbamela Yawe kati na kongenga ya bosantu na Ye.
\b
\q1 
\v 3 Mongongo ya Yawe eyokani na likolo ya mayi,
\q2 Nzambe ya nkembo azali koleka elongo na lokito,
\q2 Yawe azali koleka elongo na lokito na likolo ya mayi minene.
\q1 
\v 4 Mongongo ya Yawe ezali na nguya ;
\q2 mongongo ya Yawe ezali na lokumu mingi.
\q1 
\v 5 Mongongo ya Yawe ebukaka banzete ya sedele ;
\q2 Yawe abukaka banzete ya sedele ya Libani.
\q1 
\v 6 Apumbwisaka Libani lokola mwana ngombe,
\q2 apumbwisaka Sirioni lokola mwana ya mpakasa.
\q1 
\v 7 Mongongo ya Yawe ebimaka
\q2 elongo na bakake ya moto.
\q1 
\v 8 Mongongo ya Yawe elengisaka esobe ;
\q2 Yawe alengisaka Esobe ya Kadeshi.
\q1 
\v 9 Mongongo ya Yawe esalaka ete mboloko ebota,
\q2 esalaka mpe ete zamba etikala pamba.
\q1 Kati na Tempelo ya Yawe,
\q2 nyonso egangaka : « Nkembo ! »
\b
\q1 
\v 10 Yawe avandaki na Kiti ya Bokonzi
\q2 na likolo ya mpela ;
\q1 Yawe avandi na Kiti ya Bokonzi
\q2 lokola Mokonzi mpo na libela.
\q1 
\v 11 Yawe apesaka bato na Ye makasi ;
\q2 Yawe apambolaka bato na Ye na nzela ya kimia.
\c 30
\cl Nzembo 30
\s1 Yawe azongisi ngai na bomoi
\d 
\v 1 Nzembo ya Davidi mpo na libulisi ya Tempelo.
\q1 
\v 2 Yawe, nanetoli Yo,
\q2 pamba te obimisaki ngai na libulu ya mozindo
\q2 mpe otikaki te banguna na ngai kosepela na tina na ngai.
\q1 
\v 3 Yawe, Nzambe na ngai, nabelelaki Yo
\q2 mpo na kosenga lisungi,
\q2 mpe obikisaki ngai na bokono.
\q1 
\v 4 Yawe, obimisaki ngai na mboka ya bakufi,
\q2 obatelaki bomoi na ngai
\q2 mosika na bato oyo bazali kokita na libulu.
\b
\q1 
\v 5 Boyemba banzembo mpo na lokumu ya Yawe,
\q2 bino babulami na Ye ;
\q2 bokumisa Kombo na Ye ya bule.
\q1 
\v 6 Pamba te kanda makasi na Ye ewumelaka
\q2 mpo na mwa tango moke,
\q2 kasi ngolu na Ye ewumelaka seko na seko ;
\q1 kolela ekoki kowumela kino na pokwa,
\q2 kasi kosepela ekokota na tongo.
\b
\q1 
\v 7 Tango nazalaki na kimia, nalobaki :
\q2 « Nakotikala kokweya te. »
\q1 
\v 8 Yawe, tango osalelaki ngai ngolu,
\q2 olendisaki ngomba na ngai ;
\q1 kasi tango obombelaki ngai elongi,
\q2 nabungisaki elikya.
\b
\q1 
\v 9 Yawe, nabelelaki Yo ;
\q2 nabelelaki Yawe mpo na kosenga lisungi :
\q1 
\v 10 « Litomba nini ezali soki nakufi,
\q2 soki nakiti na libulu ?
\q1 Boni, putulu ekokumisa Yo ?
\q2 Boni, ekosakola boyengebene na Yo ?
\q1 
\v 11 Yawe, yoka ngai mpe salela ngai ngolu ;
\q2 Yawe, zala lisungi na ngai. »
\b
\q1 
\v 12 Obongoli kolela na ngai, okomisi yango mabina ;
\q2 olongoli mokumba na ngai mpe olatisi ngai esengo,
\q1 
\v 13 mpo ete molimo na ngai ekumisa Yo na banzembo,
\q2 kasi navanda nye te.
\q1 Yawe, Nzambe na ngai, nakokumisa Yo
\q2 libela na libela.
\c 31
\cl Nzembo 31
\s1 Natie elikya na ngai kati na Yawe
\d 
\v 1 Nzembo ya Davidi. Wuta na buku ya mokambi ya bayembi.
\q1 
\v 2 Eh Yawe, kati na Yo nde nazwa ebombamelo ;
\q2 kondima te ete nayoka soni !
\q2 Bikisa ngai na bosembo na Yo !
\q1 
\v 3 Yoka ngai mpe kangola ngai noki !
\q2 Zala mpo na ngai libanga oyo ezingelami na bamir
\q2 mpe ndako batonga makasi mpo na kobikisa ngai.
\q1 
\v 4 Mpo ete ozali libanga na ngai
\q2 mpe ndako na ngai ya makasi,
\q1 kamba mpe tambolisa ngai
\q2 mpo na lokumu ya Kombo na Yo.
\q1 
\v 5 Bikisa ngai na motambo oyo batieli ngai,
\q2 pamba te ozali ebombamelo na ngai.
\q1 
\v 6 Nazongisi molimo na ngai kati na maboko na Yo,
\q2 Yawe, Nzambe ya solo, oyo okangolaki ngai.
\b
\q1 
\v 7 Nalingaka te bato nyonso oyo bakangamaka
\q2 na banzambe ya bikeko,
\q2 pamba te natiaka elikya na ngai kati na Yawe.
\q1 
\v 8 Nakozalaka moto ya esengo
\q2 mpe nakosepelaka kati na bolingo na Yo ;
\q1 pamba te omonaka pasi na ngai,
\q2 mpe oyebi mitungisi na ngai.
\q1 
\v 9 Okabaki ngai te na maboko ya monguna na ngai,
\q2 kasi obombaka ngai mosika,
\q2 na esika ya kimia penza.
\q1 
\v 10 Yawe, yokela ngai mawa,
\q2 pamba te nazali kati na pasi ;
\q1 miso, motema mpe nzoto na ngai mobimba
\q2 ebebi mpo na mawa.
\q1 
\v 11 Bomoi na ngai ekawuki mpo na pasi,
\q2 mpe mibu na ngai ezali koleka kati na kolela ;
\q1 makasi na ngai esili mpo na mabe na ngai,
\q2 mpe mikuwa na ngai elembi.
\q1 
\v 12 Banguna na ngai nyonso bakomi kozwa ngai
\q2 lokola eloko ya lisuma,
\q1 baninga na ngai bakomi kozwa ngai
\q2 lokola eloko ya soni,
\q1 mpe bato oyo bayebi ngai bakomi kozwa ngai
\q2 lokola eloko ya somo.
\q1 
\v 13 Babosani ngai lokola moto oyo asila kokufa ;
\q2 nakomi lokola mbeki oyo epanzana.
\q1 
\v 14 Nayokaka matongi na bango na tina na ngai
\q2 tango basanganaka mpe basalaka makita
\q2 mpo na koluka ndenge nini koboma ngai.
\b
\q1 
\v 15 Kasi ngai, natiaka elikya na ngai kati na Yo, Yawe,
\q2 mpe nalobaka : « Ozali Nzambe na ngai. »
\q1 
\v 16 Mikolo ya bomoi na ngai ezali kati na maboko na Yo ;
\q2 kangola ngai wuta na maboko
\q2 ya banguna mpe ya bayini na ngai.
\q1 
\v 17 Tala ngai mosali na Yo, na miso ya bolingo ;
\q2 bikisa ngai kati na bolingo na Yo.
\q1 
\v 18 Yawe, sala ete nayokisama soni te,
\q2 pamba te nabeleli Yo.
\q1 Kasi tika ete bato mabe nde bayoka soni
\q2 mpe bakita kino na mboka ya bakufi.
\q1 
\v 19 Tika ete ekangama, bibebu oyo elobaka lokuta,
\q2 oyo elobaka na lolendo mpe na lofundu,
\q1 oyo ebebisaka lokumu ya moto ya sembo
\q2 na nzela ya songisongi.
\b
\q1 
\v 20 Boboto na Yo ezali penza monene,
\q2 boboto oyo obombaka mpo na bato oyo batosaka Yo,
\q1 boboto oyo otalisaka epai ya bato oyo bazwaka Yo
\q2 lokola ebombamelo na bango,
\q2 na miso ya bato nyonso.
\q1 
\v 21 Obombaka bango epai na Yo,
\q2 mosika ya mabongisi mabe ya bato ;
\q1 obatelaka bango kati na Yo,
\q2 mosika ya bato oyo babundisaka bango.
\b
\q1 
\v 22 Tika ete Yawe akumisama,
\q2 pamba te atalisaki ngai bolingo na Ye ya kokamwa,
\q1 tango nazalaki kati na engumba
\q2 oyo ezingelamaki na banguna !
\q1 
\v 23 Kati na kobanga na ngai, namilobelaki :
\q2 « Obengani ngai penza mosika na Yo ! »
\q1 Nzokande oyokaki ngai wana nazalaki kobondela Yo
\q2 mpe wana nazalaki kobelela Yo.
\b
\q1 
\v 24 Bino babulami na Ye nyonso,
\q2 bolinga Yawe !
\q1 Yawe abatelaka bato ya sembo epai na Ye,
\q2 kasi apesaka etumbu ya makasi
\q2 epai ya bato ya lofundu.
\q1 
\v 25 Bino nyonso oyo botalelaka Yawe,
\q2 bozala makasi mpe boyika mpiko.
\c 32
\cl Nzembo 32
\s1 Bolimbisi epesaka esengo
\d 
\v 1 Nzembo ya Davidi.
\q1 Esengo na moto oyo mabe na ye elimbisami,
\q2 mpe masumu na ye elongwe !
\q1 
\v 2 Esengo na moto oyo Yawe atangelaka lisumu te,
\q2 mpe atambolaka na lokuta te.
\b
\q1 
\v 3 Lokola nazalaki kondima mabe na ngai te,
\q2 nazalaki tango nyonso kolela mpo na pasi.
\q1 
\v 4 Butu mpe moyi,
\q2 loboko na Yo ezalaki kofinafina ngai ;
\q1 makasi na ngai ekomaki kosila
\q2 ndenge makasa ekawukaka na eleko ya moyi.
\b
\q1 
\v 5 Tango nandimaki masumu na ngai
\q2 mpe nabombaki mabe na ngai te,
\q1 nalobaki : « Nakotubela
\q2 masumu na ngai liboso ya Yawe. »
\q2 Bongo Yo olimbisaki mabe mpe masumu na ngai.
\b
\q1 
\v 6 Boye, tika ete bayengebene nyonso
\q2 basambelaka Yo na tango ya malamu !
\q1 Soki mayi minene etomboki,
\q2 bambonge na yango ekozwa bango te.
\q1 
\v 7 Ozali ebombamelo na ngai ;
\q2 obatelaka ngai mpo ete pasi ekanga ngai te
\q2 mpe ozingelaka ngai na banzembo ya kokangolama.
\b
\q1 
\v 8 Olobaki : « Nakopesa yo malako
\q2 mpe nakolakisa yo nzela ya kolanda ;
\q2 nakopesa yo toli mpe nakosenzela yo.
\q1 
\v 9 Kozala te lokola mpunda to lokola mile ezanga bososoli,
\q2 oyo bakangaka nguya na yango
\q1 na nzela ya ebende mpe ya singa
\q2 oyo batiaka na minoko na yango
\q2 mpo na kopekisa yango kopusana pene na yo. »
\q1 
\v 10 Bato mabe bazali na pasi mingi,
\q2 kasi bolamu ya Yawe ezingelaka bato
\q2 oyo batiaka elikya na Yawe.
\q1 
\v 11 Bino bato ya sembo, bosepela kati na Yawe,
\q2 bozala na esengo !
\q1 Bino nyonso oyo bozali na mitema alima,
\q2 bobeta milolo ya esengo.
\c 33
\cl Nzembo 33
\s1 Nzambe Mokeli mpe Mobikisi
\q1 
\v 1 Bino bato ya sembo, bobeta milolo ya esengo na tina na Yawe !
\q2 Kokumisa Nzambe ebongi na bato oyo bazali alima.
\q1 
\v 2 Bosanzola Yawe na nzenze,
\q2 bosanzola Ye na lindanda ya basinga zomi.
\q1 
\v 3 Boyembela Yawe nzembo ya sika,
\q2 bobetisa bibetelo mindule elongo na koganga ya esengo.
\b
\q1 
\v 4 Pamba te Liloba na Yawe ezali alima,
\q2 misala na Ye nyonso ekokisamaka na boyengebene.
\q1 
\v 5 Yawe alingaka bosembo mpe alima ;
\q2 mokili etondi na bolingo na Ye.
\q1 
\v 6 Likolo ekelamaki na Liloba na Yawe ;
\q2 mampinga na yango nyonso,
\q2 na nzela ya pema ya monoko na Ye.
\q1 
\v 7 Asangisaka mayi ya bibale minene esika moko,
\q2 mpe atiaka yango na bisika ya mozindo.
\q1 
\v 8 Tika ete mokili mobimba etosa Yawe !
\q2 Tika ete bavandi nyonso ya mokili balenga liboso na Ye.
\q1 
\v 9 Pamba te alobaki, mpe likambo esalemaki ;
\q2 mpe apesaki mitindo, mpe emonanaki.
\b
\q1 
\v 10 Yawe akweyisaka mikano ya bikolo,
\q2 abebisaka mabongisi ya bato.
\q1 
\v 11 Kasi mikano ya Yawe etikalaka mpo na seko,
\q2 mabongisi ya motema na Ye, mpo na bikeke nyonso.
\b
\q1 
\v 12 Esengo na ekolo oyo Yawe azali Nzambe na yango.
\q2 Esengo na bato oyo aponaki mpo na libula na Ye.
\q1 
\v 13 Yawe atalaka wuta na likolo,
\q2 amonaka bana nyonso ya bato.
\q1 
\v 14 Wuta na evandelo na Ye,
\q2 atalaka bavandi nyonso ya mokili.
\q1 
\v 15 Ye oyo asalaka mitema nyonso ya bato
\q2 asosolaka makambo nyonso oyo basalaka.
\b
\q1 
\v 16 Ezali te limpinga monene nde ebikisaka mokonzi
\q2 to nguya monene nde ekangolaka elombe.
\q1 
\v 17 Mpunda ezali na nguya te ya kopesa lobiko,
\q2 makasi na yango nyonso ekangolaka te.
\q1 
\v 18 Nzokande Yawe atalaka bato oyo batosaka Ye,
\q2 ba-oyo batiaka elikya na bolingo kati na Ye,
\q1 
\v 19 mpo na kokangola bango na kufa
\q2 mpe kobatela bango na bomoi
\q2 ata na tango ya nzala makasi.
\b
\q1 
\v 20 Totielaka Yawe motema ;
\q2 azali lisungi mpe nguba na biso.
\q1 
\v 21 Solo, mitema na biso esepelaka kati na Ye,
\q2 pamba te totiaka elikya na biso
\q2 kati na Kombo na Ye ya bule.
\q1 
\v 22 Yawe, lokola totiaka elikya na biso kati na Yo,
\q2 tika ete bolingo na Yo ezala elongo na biso.
\c 34
\cl Nzembo 34
\s1 Yawe, mokangoli na ngai
\d 
\v 1 Nzembo ya Davidi. Ayembaki yango tango akosanaki liboma liboso ya Abimeleki oyo abenganaki ye, mpe akendeki.
\q1 
\v 2 Nakopambola Yawe tango nyonso,
\q2 nakokumisa Ye mikolo nyonso na bibebu na ngai.
\q1 
\v 3 Tika ete bomoi na ngai emikumisa kati na Yawe ;
\q2 tika ete banyokolami bayoka mpe basepela !
\q1 
\v 4 Boya kosakola elongo na ngai
\q2 ete Yawe azali monene !
\q2 Tonetola Kombo na Ye, biso nyonso.
\b
\q1 
\v 5 Nalukaki Yawe, mpe ayanolaki ngai ;
\q2 akangolaki ngai na somo na ngai nyonso.
\q1 
\v 6 Bato oyo batalaka epai na Ye bangengaka na esengo,
\q2 mpe bayokisamaka soni ata moke te.
\q1 
\v 7 Mobola agangaki, mpe Yawe ayokaka ye ;
\q2 abikisaki ye na pasi na ye nyonso.
\q1 
\v 8 Anjelu ya Yawe atongaka molako na ye
\q2 zingazinga ya bato oyo batosaka Yawe,
\q2 mpe akangolaka bango.
\b
\q1 
\v 9 Bomeka elengi mpe botala
\q2 ndenge nini Yawe azali malamu ;
\q1 Esengo na moto oyo azwaka Yawe
\q2 lokola ebombamelo na ye !
\q1 
\v 10 Bino basantu ya Yawe, botosa Yawe ;
\q2 pamba te bato oyo batosaka Ye
\q2 bazangaka eloko moko te.
\q1 
\v 11 Bana ya nkosi ezangaka mpe ekufaka nzala,
\q2 kasi bato oyo balukaka Yawe
\q2 bakozanga eloko moko.
\q1 
\v 12 Bana na ngai, boya, boyoka ngai ;
\q2 Nakolakisa bino kotosa Yawe.
\q1 
\v 13 Nani asepelaka na bomoi ?
\q2 Nani alingaka kobika mikolo ebele ya esengo ?
\q1 
\v 14 Batela lolemo na yo mosika na mabe,
\q2 mpe bibebu na yo ete eloba lokuta te.
\q1 
\v 15 Zala mosika na mabe mpe sala bolamu,
\q2 luka kimia mpe koba na yango.
\b
\q1 
\v 16 Miso ya Yawe etalaka bato ya sembo,
\q2 mpe matoyi na Ye eyokaka koganga na bango ;
\q1 
\v 17 kasi Yawe apesaka bato mabe mokongo
\q2 mpo ete bakanisa bango lisusu te kati na mokili.
\b
\q1 
\v 18 Tango bato ya sembo babelelaka,
\q2 Yawe ayokaka mpe akangolaka bango
\q2 na pasi na bango nyonso.
\q1 
\v 19 Yawe azali pene ya bato
\q2 oyo bazoki na mitema
\q2 mpe abikisaka ba-oyo balembi na milimo na bango.
\b
\q1 
\v 20 Pasi mingi ekangaka moto ya sembo,
\q2 kasi Yawe akangolaka ye na nyonso,
\q1 
\v 21 abatelaka mikuwa na ye nyonso
\q2 mpo ete moko te kati na yango ebukana.
\b
\q1 
\v 22 Mabe ebomaka moto mabe,
\q2 mpe bayini ya moto ya sembo bakozwa etumbu.
\q1 
\v 23 Yawe akangolaka bomoi ya basali na Ye ;
\q2 mpe bato nyonso oyo bazwaka Ye
\q2 lokola ebombamelo na bango bakozwa etumbu te.
\c 35
\cl Nzembo 35
\s1 Yawe abatelaka bato ya bolembu
\d 
\v 1 Nzembo ya Davidi.
\q1 Yawe, kota likambo na ngai liboso ya bayini na ngai ;
\q2 bundisa bato oyo bazali kobundisa ngai.
\q1 
\v 2 Kamata nguba ya moke mpe ya monene,
\q2 mpe telema mpo na kosunga ngai.
\q1 
\v 3 Tombola likonga ya monene mpe ya moke
\q2 mpo na kobundisa bato oyo bazali kolanda ngai.
\q1 Loba na ngai :
\q2 « Nazali lobiko na Yo. »
\b
\q1 
\v 4 Tika ete bato oyo bazali komeka bomoi na ngai
\q2 basambwa mpe bayoka soni ;
\q1 tika ete bato oyo bazali kokana kosala ngai mabe
\q2 bazonga sima mpe bakoma mawa-mawa !
\q1 
\v 5 Tika ete bakoma lokola matiti ya kokawuka
\q2 oyo mopepe ezali kopumbwisa,
\q2 tango anjelu ya Yawe akotindika bango ;
\q1 
\v 6 tika ete nzela na bango ekoma molili mpe moselu
\q2 tango anjelu ya Yawe akobengana bango.
\b
\q1 
\v 7 Mpo ete, na kozanga tina, mpo na kokanga ngai,
\q2 batielaki ngai mitambo mpe batimolaki mabulu,
\q1 
\v 8 tika ete libebi ekweyela bango na mbalakata,
\q2 bakangama bango moko na mitambo oyo batielaki ngai
\q2 mpe bakweya kati na mabulu yango !
\q1 
\v 9 Nakotonda na esengo kati na Yawe
\q2 mpe nakosepela kati na lobiko na Ye.
\q1 
\v 10 Mikuwa na ngai nyonso ekoloba :
\q2 « Oh Yawe, nani akoki kokangola, lokola Yo,
\q1 mobola wuta na maboko ya moto oyo aleki ye na makasi,
\q2 mobola mpe mokeleli wuta na maboko ya banyokoli na bango ? »
\b
\q1 
\v 11 Batatoli oyo bamipesa na kanza batelemi,
\q2 bazali kopesa ngai mituna
\q2 na tina na makambo oyo nayebi te.
\q1 
\v 12 Bazali kozongisela ngai mabe
\q2 mpo na bolamu oyo nasalaki,
\q2 mpe kosundola ngai lokola monyokolami.
\q1 
\v 13 Nzokande tango bango babelaki,
\q2 ngai nalataki saki, namikitisaki na kokila bilei,
\q2 nazalaki kobondela mpo na bango.
\q1 
\v 14 Nazalaki kotambola na mawa
\q2 lokola mpo na moninga to mpo na ndeko ;
\q1 nazalaki kokitisa moto na se mpo na mawa
\q2 lokola moto oyo azali kolela mama na ye.
\q1 
\v 15 Kasi awa ngai nakomi na pasi,
\q2 bango bazali kosepela mpe kosangana ;
\q1 wana ngai nayebi te, bango bazali kosangana
\q2 mpo na kotonga ngai,
\q2 bazali kolemba te kofinga ngai.
\q1 
\v 16 Lokola bapagano, bazali koseka ngai,
\q2 bazali kolia minu na tina na ngai.
\b
\q1 
\v 17 Yawe, kino tango nini okotala kaka boye ?
\q2 Kangola ngai wuta na misala na bango ya mabe,
\q2 bomoi na ngai wuta na manzaka ya bankosi oyo.
\q1 
\v 18 Nakokumisa Yo kati na mayangani monene,
\q2 nakosanzola Yo kati na ebele ya bato.
\q1 
\v 19 Tika ete banguna na ngai basepela te
\q2 na tina na ngai ;
\q1 tika ete bayini na ngai na kozanga tina
\q2 bakanga miso te.
\q1 
\v 20 Pamba te balobaka te maloba ya kimia,
\q2 kasi babongisaka lokuta mpo na kokosela bato ya kimia
\q2 makambo kati na mboka.
\q1 
\v 21 Balobaka na mongongo makasi :
\q2 « Eh ! Eh ! Tomonaki ye ! »
\b
\q1 
\v 22 Yawe, omoni nyonso wana ; kovanda nye te !
\q2 Nkolo, kozala mosika na ngai te !
\q1 
\v 23 Lamuka mpe telema mpo na kolongisa ngai !
\q2 Nzambe na ngai mpe Nkolo na ngai,
\q2 kota likambo na ngai.
\q1 
\v 24 Yawe, Nzambe na ngai,
\q2 longisa ngai na bosembo na Yo ;
\q2 kotika bango te kosepela na tina na ngai.
\q1 
\v 25 Tika ete bamilobela te :
\q2 « Ah ! Tala makambo oyo tozalaki koluka ! »
\q2 Tika ete baloba te : « Tolie ye. »
\q1 
\v 26 Tika ete bato nyonso oyo basepelaka na pasi na ngai,
\q2 bango nyonso lisanga, bayoka soni mpe basambwa !
\q1 Tika ete bato oyo batombokelaka ngai
\q2 balata soni mpe bazala kati na yikiyiki !
\q1 
\v 27 Tika ete bato oyo basepelaka na bosembo na ngai
\q2 baganga na esengo mpe basepela ;
\q1 tika ete balobaka tango nyonso :
\q2 « Tika ete Yawe anetolama,
\q2 Ye oyo asepelaka na kimia ya mowumbu na Ye ! »
\b
\q1 
\v 28 Nakosakola bosembo na Yo,
\q2 nakokumisa Yo mikolo nyonso.
\c 36
\cl Nzembo 36
\s1 Boboto ya Yawe
\d 
\v 1 Nzembo ya Davidi, mowumbu ya Yawe. Wuta na buku ya mokambi ya bayembi.
\q1 
\v 2 Kati na motema na ngai,
\q2 nazali na sango kowuta na Nzambe
\q1 na tina na bato mabe oyo batondi na masumu :
\q2 Kotosa Nzambe ezali na tina ata moke te na miso na bango.
\b
\q1 
\v 3 Bamipesaka lokumu makasi,
\q2 bandimaka te mpe bayinaka masumu na bango te.
\q1 
\v 4 Minoko na bango ebimisaka maloba mabe mpe lokuta,
\q2 baboyaka kosala na bokebi mpe kosala bolamu.
\q1 
\v 5 Ezala na bambeto na bango,
\q2 basalaka kaka mabongisi ya kosala mabe,
\q1 batambolaka te mpo na kosala bolamu
\q2 mpe baboyaka mabe te.
\b
\q1 
\v 6 Yawe, bolingo na Yo ekenda kino na likolo,
\q2 boyengebene na Yo kino na mapata.
\q1 
\v 7 Bosembo na Yo ezali lokola bangomba ya Nzambe,
\q2 mikano na Yo ezali mozindo lokola lubwaku ya molayi.
\q2 Yawe, obikisaka bato mpe banyama.
\q1 
\v 8 Oh Nzambe, tala ndenge nini bolingo na Yo ezali motuya !
\q2 Bato bazwaka ebombamelo na elili ya mapapu na Yo.
\q1 
\v 9 Baliaka mpe batondaka bilei ya Ndako na Yo,
\q2 mpe omelisaka bango mayi
\q2 kowuta na bolingo monene na Yo.
\q1 
\v 10 Pamba te etima ya bomoi ezali elongo na Yo ;
\q2 kati na pole na Yo nde tomonaka pole.
\b
\q1 
\v 11 Koba kotalisa bolingo na Yo epai ya bato oyo bayebi Yo,
\q2 mpe bosembo na Yo epai ya bato ya mitema alima.
\q1 
\v 12 Tika ete bato ya lolendo bakoma te kino epai na ngai,
\q2 mpe tika ete bato mabe babengana ngai te.
\q1 
\v 13 Tala ndenge nini bato ya misala mabe bakweyi,
\q2 balali na mabele, bazangi makoki ya kotelema.
\c 37
\cl Nzembo 37
\s1 Malendisi mpo na moto ya sembo
\d 
\v 1 Nzembo ya Davidi.
\q1 Kosilikela bato ya mabe te,
\q2 kosalela bato oyo basalaka mabe zuwa te ;
\q1 
\v 2 pamba te bakokawuka noki lokola makasa,
\q2 mpe bakolemba noki lokola matiti.
\b
\q1 
\v 3 Tia elikya na yo kati na Yawe mpe sala bolamu,
\q2 vanda kati na mokili mpe lia na kimia.
\b
\q1 
\v 4 Komisa Yawe bilengi na yo ya makasi,
\q2 mpe akokokisela yo posa ya motema na yo.
\b
\q1 
\v 5 Kaba bomoi na yo epai na Yawe,
\q2 tia elikya kati na Ye, mpe akosala :
\q1 
\v 6 akongengisa bosembo na yo lokola pole,
\q2 makoki na yo lokola moyi ya midi.
\b
\q1 
\v 7 Batela kimia liboso ya Yawe
\q2 mpe talela Ye ;
\q1 kosilikela te moto oyo alongaka na misala na ye,
\q2 mpe oyo asalaka mabongisi ya mabe.
\b
\q1 
\v 8 Boya kanda mpe kosilika te ;
\q2 kotomboka te, noki te okosala mabe.
\q1 
\v 9 Pamba te bato oyo basalaka mabe bakolimwa,
\q2 kasi bato oyo batielaka Yawe motema
\q2 bakozwa mokili lokola libula na bango.
\b
\q1 
\v 10 Etikali tango moke kaka,
\q2 moto mabe akozala lisusu te ;
\q2 ata oluki ye, okomona ye te.
\q1 
\v 11 Kasi bato oyo bamikitisa bakozwa mokili
\q2 lokola libula na bango mpe bakozala na kimia makasi.
\b
\q1 
\v 12 Bato mabe basalelaka bato ya sembo makita
\q2 mpe baliaka minu mpo na kotelemela bango.
\q1 
\v 13 Kasi Yawe asekaka bato mabe,
\q2 pamba te ayebi ete mokolo na bango ezali kobelema.
\b
\q1 
\v 14 Bato mabe babimisi mipanga
\q2 mpe babongisi batolotolo
\q1 mpo na kokweyisa mobola mpe moto oyo akelela,
\q2 mpo na koboma bato oyo batambolaka alima.
\q1 
\v 15 Kasi mipanga na bango ekotobola mitema na bango moko,
\q2 mpe batolotolo na bango ekobukana.
\b
\q1 
\v 16 Mwa biloko ya moto ya sembo eleki
\q2 bozwi ya bato ebele ya mabe,
\q1 
\v 17 pamba te nguya ya bato mabe ekosila,
\q2 kasi Yawe alendisaka bato ya sembo.
\b
\q1 
\v 18 Yawe ayebi mikolo ya bato bazangi pamela,
\q2 mpe libula na bango ekowumela mpo na seko.
\q1 
\v 19 Na tango ya pasi, bakokawuka te ;
\q2 na mikolo ya nzala, bakozala na bilei ebele.
\b
\q1 
\v 20 Kasi bato mabe bakokufa,
\q2 banguna ya Yawe bazali lokola fololo ya elanga,
\q2 bakolimwa lokola molinga.
\b
\q1 
\v 21 Moto mabe adefaka mpe azongisaka te,
\q2 kasi moto ya sembo ayokaka mawa mpe akabaka.
\q1 
\v 22 Bato oyo Yawe apambolaka bakozwa
\q2 mokili lokola libula na bango,
\q2 kasi ba-oyo alakelaka mabe bakolimwa.
\b
\q1 
\v 23 Soki Yawe asepeli na etamboli ya moto,
\q2 alendisaka bomoi na ye ;
\q1 
\v 24 ezala akweyi, akotikala kaka ya kokweya te ;
\q2 pamba te Yawe asimbaka ye na loboko.
\b
\q1 
\v 25 Nazalaki elenge, mpe sik’oyo nakomi mobange,
\q2 namoni nanu te moto ya sembo kosundolama
\q2 to bana na ye kokoma kosenga-senga bilei.
\q1 
\v 26 Akabaka tango nyonso mpe adefisaka,
\q2 bana na ye bakozalaka kati na mapamboli.
\b
\q1 
\v 27 Zala mosika na mabe mpe sala bolamu,
\q2 okovanda na mokili mpo na libela ;
\q1 
\v 28 pamba te Yawe alingaka bosembo,
\q2 mpe asundolaka te bayengebene na Ye.
\b
\q1 Babatelamaka mpo na seko,
\q2 kasi bana ya bato mabe bakolimwa.
\q1 
\v 29 Bato ya sembo bakozwa mokili lokola libula na bango
\q2 mpe bakovanda kuna seko na seko.
\b
\q1 
\v 30 Monoko ya moto ya sembo ebimisaka bwanya,
\q2 mpe lolemo na ye elobaka kolanda bosembo.
\q1 
\v 31 Mobeko ya Nzambe na ye ezali kati na motema na ye,
\q2 makolo na ye ebetaka libaku te.
\b
\q1 
\v 32 Moto mabe atalaka moto ya sembo na miso mabe
\q2 mpe alukaka nzela ya koboma ye,
\q1 
\v 33 kasi Yawe akosundola moto ya sembo te
\q2 kati na maboko ya moto mabe,
\q2 mpe akokweyisa ye te na kosambisama.
\b
\q1 
\v 34 Zala na elikya kati na Yawe
\q2 mpe batela nzela na Ye ;
\q1 akonetola Yo mpo ete ozwa mboka lokola libula na yo,
\q2 mpe okomona tango bato mabe bakolimwa.
\b
\q1 
\v 35 Namonaki moto mabe mpe na kanza
\q2 kokoma na nguya mpe kofuluka
\q2 lokola nzete oyo ezali kokola na mabele na yango,
\q1 
\v 36 kasi alekaki noki mpe azalaki lisusu te ;
\q2 nalukaki ye, kasi namonaki ye lisusu te.
\b
\q1 
\v 37 Tala malamu moto oyo azangi pamela,
\q2 landela bomoi ya moto ya sembo ;
\q2 tango oyo ezali koya ezali kozela moto ya kimia.
\q1 
\v 38 Kasi batomboki bakobebisama,
\q2 tango oyo ezali koya ezali te mpo na bato mabe.
\b
\q1 
\v 39 Lobiko ya bato ya sembo ewutaka epai ya Yawe
\q2 oyo, na tango ya pasi, azali ndako na bango,
\q2 oyo batonga makasi.
\q1 
\v 40 Yawe asungaka mpe akangolaka bango,
\q2 akangolaka bango wuta na maboko ya bato mabe
\q1 mpe abikisaka bango,
\q2 pamba te babombamaka kati na Ye.
\c 38
\cl Nzembo 38
\s1 Losambo ya mobeli
\d 
\v 1 Nzembo ya Davidi mpo na kokanisa.
\q1 
\v 2 Yawe, kopamela ngai te kati na kanda na Yo
\q2 to kopesa ngai etumbu te kati na kanda makasi na Yo.
\q1 
\v 3 Pamba te makonga na Yo etoboli ngai,
\q2 mpe loboko na Yo ebeti ngai.
\q1 
\v 4 Mpo na kanda na Yo, nzoto na ngai ebeli ;
\q2 mpo na masumu na ngai, mikuwa na ngai elembi.
\q1 
\v 5 Mabe na ngai eleki moto na ngai,
\q2 ezali kilo makasi epai na ngai
\q2 lokola mokumba ya kilo makasi.
\b
\q1 
\v 6 Bapota na ngai epoli mpe ekomi kolumba solo
\q2 mpo na bozoba na ngai.
\q1 
\v 7 Nagumbami, nalembi makasi ;
\q2 nakomi moto ya mawa mpo na libela.
\q1 
\v 8 Pamba te nazali koyoka pasi makasi na mokongo na ngai,
\q2 eteni ata moko te ya nzoto na ngai ezali malamu.
\q1 
\v 9 Nalembi, makasi na ngai nyonso esili ;
\q2 mobulu ekoti na motema na ngai,
\q2 nakomi koganga na kolemba te.
\b
\q1 
\v 10 Nkolo, oyebi posa na ngai nyonso ;
\q2 kolela na ngai ezali ya kobombama te na miso na Yo.
\q1 
\v 11 Motema na ngai ezangi kimia,
\q2 makasi na ngai ekomi kosila,
\q2 nabungisi ata pole ya miso na ngai.
\q1 
\v 12 Bato oyo balingaka ngai mpe baninga na ngai
\q2 bakimi pasi na ngai,
\q2 ba-oyo bazalaka na ngai esika moko batelemi mosika na ngai.
\q1 
\v 13 Bato oyo balukaka kufa na ngai bazali kotia mitambo,
\q2 ba-oyo balukaka pasi na ngai bazali koloba mpo na kosala ngai mabe,
\q2 bakomi mikolo nyonso kobongisa lokuta.
\q1 
\v 14 Kasi ngai nazali kosala lokola mokufi matoyi ;
\q2 mpe lokola baba, nakangi monoko, naboyi koloba.
\q1 
\v 15 Nakomi lokola mokufi matoyi
\q2 oyo akoki kopesa eyano ata moko te na monoko na ye.
\q1 
\v 16 Yawe, natiaka elikya na ngai kati na Yo ;
\q2 oh Nkolo, Nzambe na ngai, solo, okoyanola.
\q1 
\v 17 Nalobaki : « Kopesa nzela te
\q2 ete basepela na tina na ngai
\q2 to bamitombola likolo na ngai soki nabeti libaku. »
\q1 
\v 18 Pamba te nakomi pene ya kokweya,
\q2 pasi na ngai ezali kaka elongo na ngai tango nyonso.
\q1 
\v 19 Solo nandimi mabe na ngai,
\q2 masumu na ngai ezali kotungisa molimo na ngai.
\q1 
\v 20 Banguna na ngai bazali makasi mpe bingambe,
\q2 bato oyo bayinaka ngai kaka pamba bazali ebele.
\q1 
\v 21 Bato oyo bazongisaka mabe na bolamu
\q2 bazali kofunda ngai atako nalukaka kosala bolamu.
\b
\q1 
\v 22 Yawe, kosundola ngai te ;
\q2 Nzambe na ngai, kozala mpe mosika na ngai te.
\q1 
\v 23 Nkolo, Mobikisi na ngai,
\q2 yaka noki kosunga ngai.
\c 39
\cl Nzembo 39
\s1 Liboso ya kufa
\d 
\v 1 Wuta na buku ya mokambi ya bayembi mpe ya Yedutuni. Nzembo ya Davidi.
\q1 
\v 2 Namilobelaki : « Nakosala keba na etamboli na ngai
\q2 mpo ete monoko na ngai esala masumu te ;
\q1 nakobatela penza monoko na ngai
\q2 tango nyonso moto mabe akozala liboso na ngai. »
\q1 
\v 3 Boye nakangaki monoko na ngai mpe navandaki nye,
\q2 natikalaki koloba ata likambo moko te ;
\q2 pasi na ngai ebakisamaki makasi.
\q1 
\v 4 Motema na ngai eswaki,
\q2 moto ezalaki kopela kati na ngai,
\q2 mpe nalobaki na nzela ya monoko na ngai.
\b
\q1 
\v 5 Yawe, yebisa ngai tango nini bomoi na ngai ekosuka
\q2 mpe motango ya mikolo ya bomoi na ngai
\q1 mpo ete nasosola ete bomoi na ngai ezali kaka
\q2 mpo na mwa tango moke.
\q1 
\v 6 Solo mikolo ya bomoi na ngai ekatama,
\q2 ezali pamba na miso na Yo.
\q2 Bomoi ya moto nyonso ezali kaka mopepe.
\b
\q1 
\v 7 Moto akendaka mpe azongaka,
\q2 azali kaka lokola elili ;
\q1 amitungisaka kaka pamba, andukaka bomengo,
\q2 kasi ayebaka te soki nani akotikala na yango.
\b
\q1 
\v 8 Sik’oyo, oh Nkolo, nazela lisusu nini ?
\q2 Natiaka elikya na ngai kati na Yo.
\q1 
\v 9 Bikisa ngai na mabe na ngai nyonso,
\q2 kopesa nzela te na bazoba ete bafinga ngai.
\q1 
\v 10 Nakangi monoko, nakoloba lisusu te,
\q2 pamba te Yo nde osali.
\q1 
\v 11 Kobeta ngai lisusu te,
\q2 nazali kokoka lisusu te.
\q1 
\v 12 Opesaka bato etumbu mpo na masumu na bango
\q2 mpo na kozongisa bango na nzela ;
\q1 obebisaka biloko na bango ya motuya lokola nselele.
\q2 Solo, moto nyonso azali kaka mopepe.
\b
\q1 
\v 13 Yawe, yoka
\q2 libondeli na ngai ;
\q1 yoka na bokebi, wana nazali
\q2 koganga mpo na kosenga lisungi,
\q2 kovanda nye te liboso ya mpinzoli na ngai,
\q1 pamba te epai na Yo, nazali mopaya
\q2 mpe moleki nzela lokola bakoko na ngai.
\q1 
\v 14 Kotala ngai te mpo ete nasepela lisusu,
\q2 liboso ete nakende na ngai mpe nazala lisusu te.
\c 40
\cl Nzembo 40
\s1 Lobiko ya Nzambe epai ya mosali na Ye
\d 
\v 1 Nzembo ya Davidi. Wuta na buku ya mokambi ya bayembi.
\q1 
\v 2 Natiaki elikya na ngai kati na Yawe ;
\q2 abalukaki epai na ngai mpe ayokaki koganga na ngai.
\q1 
\v 3 Abimisaki ngai na libulu ya mozindo, kati na potopoto ;
\q2 atelemisaki ngai na likolo ya libanga
\q2 mpe alendisaki makolo na ngai.
\q1 
\v 4 Atiaka nzembo ya sika kati na monoko na ngai,
\q2 nzembo ya masanzoli mpo na Nzambe na biso.
\q1 Bato ebele bakomona, bakobanga
\q2 mpe bakotiela Yawe motema.
\b
\q1 
\v 5 Esengo na moto oyo atiaka elikya kati na Yawe,
\q2 kasi atalelaka te bato ya lolendo mpe bakosi.
\q1 
\v 6 Yawe, Nzambe na ngai, bikamwa mpe mabongisi
\q2 oyo osalaka mpo na biso ezali ebele penza.
\q1 Moko te akokani na Yo ;
\q2 nalingi kotatola mpe kopanza sango na yango,
\q2 kasi motango na yango eleki ebele.
\b
\q1 
\v 7 Osepelaki te na bambeka mpe na makabo,
\q2 kasi ofungolaki matoyi na ngai ;
\q1 osengaki te makabo ya kotumba mpe bambeka
\q2 mpo masumu.
\q1 
\v 8 Bongo nalobaki : « Ngai oyo, nayei epai na Yo
\q2 kolanda ndenge ekomami na tina na ngai kati na buku.
\q1 
\v 9 Nzambe na ngai, nasepelaka kosala mokano na Yo,
\q2 Mobeko na Yo ezali kati na motema na ngai. »
\b
\q1 
\v 10 Nasakolaka bosembo na Yo kati na mayangani,
\q2 nakokanga monoko na ngai te ;
\q2 Yawe, oyebi yango !
\q1 
\v 11 Nabombaka bosembo na Yo te kati na motema na ngai,
\q2 natatolaka boyengebene mpe lobiko na Yo kati na mayangani,
\q2 nakobomba yango ata moke te.
\q1 
\v 12 Yawe, kopimela ngai mawa na Yo te ;
\q2 kasi sala ete bolingo mpe bosolo na Yo
\q2 ebatelaka ngai tango nyonso.
\q1 
\v 13 Pamba te makambo ebele ya pasi ezingeli ngai,
\q2 mabunga na ngai ekomi konyokola ngai,
\q1 mpe nazali kokoka lisusu te kotala yango ;
\q2 ezali ebele koleka suki ya moto na ngai,
\q2 mpe motema na ngai elembi kati na ngai.
\q1 
\v 14 Yawe, nabondeli Yo, kangola ngai ;
\q2 Yawe, yaka noki kosunga ngai.
\b
\q1 
\v 15 Tika ete bato oyo balukaka kufa na ngai
\q2 bakufa soni mpe basambwa !
\q1 Tika ete bato oyo bazelaka libebi na ngai
\q2 bazonga sima mpe babungisa lokumu na bango !
\q1 
\v 16 Tika ete ba-oyo balobaka na ngai : « Ah ! Ah ! »
\q2 bayoka somo mpe bakufa soni !
\q1 
\v 17 Kasi tika ete bato nyonso oyo balukaka Yo
\q2 batonda na esengo mpe basepela kati na Yo !
\q1 Tika ete ba-oyo balingaka lobiko na Yo
\q2 balobaka tango nyonso : « Yawe azali monene ! »
\b
\q1 
\v 18 Solo, nazali mobola mpe moto akelela,
\q2 kasi tika ete Nkolo asunga mpe akangola ngai.
\q2 Nzambe na ngai, kowumela te !
\c 41
\cl Nzembo 41
\s1 Mobeli mpe monyokolami
\d 
\v 1 Nzembo ya Davidi. Wuta na buku ya mokambi ya bayembi.
\q1 
\v 2 Esengo na moto oyo akanisaka mobola !
\q2 Yawe akokangola ye na tango ya pasi.
\q1 
\v 3 Yawe akokengela ye mpe akobatela bomoi na ye,
\q2 akokomisa ye moto ya esengo kati na mokili
\q2 mpe akokaba ye te na maboko ya banguna na ye.
\q1 
\v 4 Yawe akosunga ye na mbeto na ye soki abeli
\q2 mpe akobikisa ye na bokono na ye nyonso.
\b
\q1 
\v 5 Nalobaki : « Oh Yawe, yokela ngai mawa ;
\q2 bikisa ngai na bokono, pamba te nasalaki masumu epai na Yo. »
\q1 
\v 6 Banguna na ngai balobaka mabe na tina na ngai :
\q2 « Akokufa mokolo nini mpo ete kombo na ye etangama lisusu te ? »
\q1 
\v 7 Kati na bango, moto nyonso oyo ayaka kotala ngai
\q2 alobaka kaka lokuta mpo na kobebisa lokumu na ngai,
\q1 akangisaka kati na ye makambo ya lokuta
\q2 mpe, soki kaka abimi libanda, apanzaka yango na matongi.
\q1 
\v 8 Banguna na ngai basanganaka kaka
\q2 mpo na kotonga ngai mpe kokanisa mpo na libebi na ngai.
\q1 
\v 9 Balobaka : « Pasi moko ya somo penza ekangi ye,
\q2 ebwaki ye na mbeto mpe azali kokoka lisusu kotelema te. »
\q1 
\v 10 Ezala molingami na ngai ya kimia,
\q2 oyo nazalaki kotiela motema
\q1 mpe azalaki kolia sani moko elongo na ngai,
\q2 abalukeli ngai.
\b
\q1 
\v 11 Kasi Yo, Yawe, yokela ngai mawa mpe telemisa ngai
\q2 mpo ete nazongisela bango mabe na mabe.
\q1 
\v 12 Nakoyeba ete osepelaka na ngai
\q2 soki kaka monguna na ngai agangi te na tina na ngai.
\q1 
\v 13 Mpo ete nazangi pamela, okosunga ngai
\q2 mpe okovandisa ngai na makolo na Yo mpo na libela.
\b
\b
\q1 
\v 14 Tika ete Yawe, Nzambe ya Isalaele,
\q2 akumisama libela na libela !
\qc Amen ! Amen !
\c 42
\ms1 Buku ya mibale
\mr Nz 42.1–72.20
\cl Nzembo 42
\s1 Kozala na posa ya Nzambe
\d 
\v 1 Nzembo ya bana ya Kore. Wuta na buku ya mokambi ya bayembi.
\q1 
\v 2 Ndenge mbuli eyokaka posa ya komela mayi,
\q2 ndenge wana mpe molimo na ngai ezali na posa na Yo, Nzambe.
\q1 
\v 3 Molimo na ngai ezali na posa ya Nzambe, ya Nzambe na bomoi.
\q2 Tango nini nakoki kokende,
\q1 mpe tango nini nakoki kokutana na Nzambe ?
\q1 
\v 4 Butu mpe moyi,
\q2 mpinzoli na ngai ezalaka bilei na ngai ;
\q1 pamba te balobaka na ngai tango nyonso :
\q2 « Nzambe na Yo azali wapi ? »
\q1 
\v 5 Nazalaka na posa ya kokanisa makambo oyo,
\q2 ndenge mpe nasopaka molimo na ngai :
\q1 Tango nazalaki kotambola kati na ebele ya bato,
\q2 nazalaki komema bango kino na Tempelo ya Nzambe,
\q1 kati na koganga ya esengo mpe ya kozongisa matondi
\q2 lokola makelele ya bato oyo bazali na feti.
\b
\q1 
\v 6 Oh molimo na ngai, mpo na nini olembi boye ?
\q2 Mpo na nini ozali komitungisa makasi kati na ngai ?
\q1 Tia elikya na yo kati na Nzambe,
\q2 pamba te nakokumisa lisusu lobiko na Ye.
\b
\q1 
\v 7 Nzambe, molimo na ngai elembi kati na ngai ;
\q2 yango wana nazali kokanisa Yo wuta na mokili ya Yordani,
\q1 wuta na songe ya ngomba Erimoni
\q2 mpe wuta na ngomba Mitseari.
\q1 
\v 8 Mozindo ebendaka mozindo
\q2 tango bambonge na Yo nyonso etombokaka ;
\q1 Ezala ya mike to ya minene, elekaka likolo na ngai.
\b
\q1 
\v 9 Na moyi, Yawe apesaka mitindo epai ya bolingo na Ye ;
\q2 na butu, nakumisaka Ye na banzembo
\q2 mpe nasambelaka Nzambe ya bomoi na ngai.
\b
\q1 
\v 10 Nalobi na Nzambe, Libanga na ngai :
\q2 « Mpo na nini obosani ngai ?
\q1 Mpo na nini nasengeli kotambola na mawa kati na motema
\q2 mpe na se ya minyoko ya monguna ? »
\b
\q1 
\v 11 Nzoto na ngai ekomaka kosala pasi makasi
\q2 tango bayini na ngai bafingaka ngai,
\q1 tango balobaka na ngai mokolo mobimba :
\q2 « Wapi Nzambe na yo ? »
\b
\q1 
\v 12 Molimo na ngai, mpo na nini olembi boye ?
\q2 Mpo na nini ozali komitungisa kati na ngai ?
\q1 Tia elikya na yo kati na Nzambe.
\q2 Nakokumisa Ye lisusu,
\q2 lobiko mpe Nzambe na ngai.
\c 43
\cl Nzembo 43
\s1 Kotia elikya kati na Yawe
\q1 
\v 1 Oh Nzambe, longisa ngai mpe lobela ngai
\q2 liboso ya ekolo oyo etosaka makambo na Yo te ;
\q1 kangola ngai wuta na maboko
\q2 ya bakosi mpe ya bato mabe.
\q1 
\v 2 Nzambe, Yo nde ozali ndako na ngai,
\q2 oyo batonga makasi ;
\q1 mpo na nini osundoli ngai ?
\q2 Mpo na nini nasengeli kotambola na pasi boye,
\q2 na se ya minyoko ya monguna ?
\q1 
\v 3 Tinda mwinda mpe solo na Yo
\q2 mpo ete ekamba mpe emema ngai
\q2 na ngomba na Yo ya bule epai wapi ovandaka ;
\q1 
\v 4 bongo nakokende na etumbelo
\q2 epai ya Nzambe, esengo mpe bomengo na ngai.
\q1 Oh Yawe, Nzambe na ngai,
\q2 nakosanzola Yo na lindanda.
\q1 
\v 5 Oh molimo na ngai, mpo na nini olembi boye ?
\q2 Mpo na nini ozali komitungisa kati na ngai ?
\q1 Tia elikya na yo kati na Nzambe,
\q2 pamba te nakosanzola Ye lisusu,
\q2 Mobikisi mpe Nzambe na ngai.
\c 44
\cl Nzembo 44
\s1 Yawe abwaki biso
\d 
\v 1 Nzembo ya bana ya Kore. Wuta na buku ya mokambi ya bayembi.
\q1 
\v 2 Nzambe, toyokaki na matoyi na biso ;
\q2 bakoko na biso babetelaki biso lisolo
\q1 ya makambo oyo osalaki na tango na bango,
\q2 na tango ya kala.
\q1 
\v 3 Na nguya na Yo, obenganaki bikolo
\q2 mpe otiaki bakoko na biso ;
\q1 obetaki bikolo ya bapaya
\q2 mpe ofulukisaki bakoko na biso.
\q1 
\v 4 Pamba te ezalaki na mopanga na bango te
\q2 nde babotolaki mokili,
\q1 ezalaki mpe maboko na bango te
\q2 nde ebikisaki bango ;
\q1 kasi ezalaki nde loboko na Yo ya mobali,
\q2 nguya na Yo mpe pole ya elongi na Yo,
\q2 pamba te ozalaki kolinga bango.
\b
\q1 
\v 5 Oh Nzambe, Yo oyo ozali Mokonzi na ngai,
\q2 pesa mitindo mpo na elonga ya Jakobi.
\q1 
\v 6 Na lisungi na Yo, tolongaka banguna na biso,
\q2 mpe na Kombo na Yo, tonyataka bayini na biso.
\q1 
\v 7 Pamba te natiaka elikya te na tolotolo na ngai,
\q2 mpe mopanga na ngai ebikisaka ngai te.
\q1 
\v 8 Kasi ezali Yo nde obikisaka biso
\q2 wuta na maboko ya bayini na biso,
\q2 mpe oyokisaka bayini na biso soni.
\q1 
\v 9 Tomikumisaka mikolo nyonso kati na Nzambe
\q2 mpe tokokumisa Kombo na Yo mpo na libela.
\b
\q1 
\v 10 Kasi obwaki biso, oyokisi biso soni
\q2 mpe ozali lisusu kotambola te
\q2 elongo na mampinga na biso.
\q1 
\v 11 Otiki biso kokima liboso ya banguna na biso ;
\q2 mpe bayini na biso bazwi biloko na biso na makasi.
\q1 
\v 12 Osundoli biso na maboko na bango
\q2 lokola bameme ya koboma
\q2 mpe opanzi biso kati na bikolo.
\q1 
\v 13 Oteki bato na Yo na pamba
\q2 mpe ozwi ata litomba te kowuta na boteki yango.
\b
\q1 
\v 14 Okomisi biso eloko ya lisuma
\q2 na miso ya bato oyo bazali pembeni na biso,
\q1 eloko ya litio mpe ya liseki
\q2 na miso ya bato oyo bazali zingazinga na biso.
\q1 
\v 15 Okomisi biso lisapo kati na bikolo,
\q2 mpe bato bakomi koningisa mito na bango mpo na biso.
\q1 
\v 16 Kosambwa ekomi tango nyonso liboso na ngai
\q2 mpe soni ezipi elongi na ngai,
\q1 
\v 17 mpo na litio ya bato oyo bazali kofinga mpe kopamela ngai,
\q2 mpe ya monguna oyo akangela ngai kanda.
\b
\q1 
\v 18 Makambo wana nyonso ekweyeli biso
\q2 atako tobosanaki Yo te
\q2 mpe tobebisaki Boyokani na Yo te,
\q1 
\v 19 atako mitema na biso epengwaki te
\q2 mpe totamboli libanda ya nzela na Yo te.
\q1 
\v 20 Pamba te onyokolaki biso
\q2 kati na etando ya bambwa ya zamba
\q2 mpe ozipaki biso na molili makasi.
\b
\q1 
\v 21 Soki tobosanaki Kombo ya Nzambe na biso
\q2 to totombolaki maboko na biso epai ya nzambe ya mopaya,
\q1 
\v 22 boni, Nzambe na biso alingaki koyeba yango te,
\q2 lokola asosolaka mozindo ya mitema ?
\q1 
\v 23 Pamba te, likolo na Yo, babomaka biso mikolo nyonso
\q2 mpe bazwaka biso lokola bameme ya koboma.
\b
\q1 
\v 24 Nkolo, lamuka ! Mpo na nini ozali kolala ?
\q2 Lamuka, kobwaka biso te mpo na libela.
\q1 
\v 25 Yawe, mpo na nini ozali kobomba elongi na Yo ?
\q2 Mpo na nini ozali kobosana pasi mpe minyoko na biso ?
\b
\q1 
\v 26 Pamba te tokweyi na putulu,
\q2 mpe nzoto na biso ekangami na mabele.
\q1 
\v 27 Telema, yaka kosunga biso,
\q2 kangola biso mpo na bolingo na Yo !
\c 45
\cl Nzembo 45
\s1 Mpo na libala ya mokonzi
\d 
\v 1 Nzembo ya bolingo oyo bana ya Kore bayembaki. Wuta na buku ya mokambi ya bayembi. Eyembamaki na lindanda oyo babengaka Lisi.
\q1 
\v 2 Motema na ngai etondi na maloba kitoko.
\q2 Namilobeli : Nakotatola misala na ngai mpo na mokonzi.
\q1 Tika ete lolemo na ngai ezala
\q2 lokola ekomeli ya mokomi ya mayele.
\b
\q1 
\v 3 Oleki bato nyonso na kitoko,
\q2 mpe bibebu na Yo ebimisaka ngolu ;
\q2 yango wana Nzambe apambola Yo mpo na libela.
\b
\q1 
\v 4 Elombe ya bitumba, kanga mopanga na loketo na Yo !
\q2 Lata lokumu mpe kongenga.
\q1 
\v 5 Kati na kongenga na Yo, zala molongi,
\q2 mata na shar na Yo, telema mpo na solo,
\q1 mpo na komikitisa, mpe mpo na bosembo ;
\q2 tika ete loboko na Yo ya mobali esala misala minene.
\q1 
\v 6 Tika ete makonga na Yo ya minu
\q2 etobola mitema ya banguna ya mokonzi ;
\q2 tika ete bikolo ekweya na se ya matambe na Yo.
\q1 
\v 7 Nzambe, Kiti ya Bokonzi na Yo ekowumela seko na seko ;
\q2 lingenda ya bokonzi na Yo ezali mpo na bosembo.
\q1 
\v 8 Olingaka bosembo mpe oyinaka mabe ;
\q2 yango wana, oh Nzambe, Nzambe na Yo apakoli Yo mafuta ya esengo,
\q2 asepeli na Yo koleka baninga na Yo.
\q1 
\v 9 Bilamba na Yo nyonso ezali kolumba solo kitoko
\q2 ya malasi ya mire, ya aloe mpe ya kaneli ;
\q1 wuta na bandako minene
\q2 oyo ebongisama na pembe ya nzoko,
\q2 mandanda ezali kosepelisa Yo.
\q1 
\v 10 Bana basi ya bakonzi bazali kati na basi ya lokumu ;
\q2 mwasi ya mokonzi azali na ngambo ya loboko na Yo ya mobali,
\q2 alati biloko ya wolo ya Ofiri.
\b
\q1 
\v 11 Mwana na ngai ya mwasi, tala mpe yoka ;
\q2 bosana bato na yo mpe ndako ya tata na yo.
\q1 
\v 12 Mokonzi asepeli na kitoko na yo ;
\q2 lokola azali nkolo na yo, gumbama liboso na ye.
\q1 
\v 13 Tiri, mboka kitoko, bato oyo baleki na bozwi kati na bato
\q2 bakomemela yo bakado mpo ete olinga bango.
\q1 
\v 14 Mwana mwasi ya mokonzi azali kongenga na kitoko
\q2 kati na ndako ya mokonzi,
\q2 alati elamba batonga wolo.
\q1 
\v 15 Alati bilamba batonga bililingi kitoko na basinga,
\q2 mpe bamemi ye epai ya mokonzi.
\q1 Bamemi mpe balingami na ye epai na yo,
\q2 bilenge basi oyo batambolaka elongo na ye.
\q1 
\v 16 Bamemi bango na nsayi mpe na esengo ;
\q2 bakoti na ndako ya mokonzi.
\b
\q1 
\v 17 Bana na yo ya mibali bakozwa esika ya bakoko na bango ;
\q2 okotia bango bakambi kati na mokili mobimba.
\b
\q1 
\v 18 Nakosala ete bikeke nyonso ebosana kombo na yo te.
\q2 Boye bikolo nyonso ekosanzola Yo tango nyonso, seko na seko.
\c 46
\cl Nzembo 46
\s1 Nzambe azali ekimelo na biso
\d 
\v 1 Nzembo ya bana ya Kore. Wuta na buku ya mokambi ya bayembi. Eyembamaki na mongongo moke ya bilenge basi.
\q1 
\v 2 Mpo na biso, Nzambe azali ebombamelo mpe eyekamelo,
\q2 azali lisungi oyo ezangaka te na tango ya pasi.
\q1 
\v 3 Yango wana, tobangaka te ata soki mabele eningani,
\q2 bangomba ekweyi kati na ebale monene ;
\q1 
\v 4 ata soki bambonge na yango etelemi, ebimisi fulufulu
\q2 mpe eningisi bangomba.
\b
\q1 
\v 5 Ezali na ebale moko oyo mayi na yango
\q2 esepelisaka engumba ya Nzambe
\q2 oyo eleki bule kati na bivandelo ya Ye-Oyo-Aleki-Likolo.
\q1 
\v 6 Nzambe azali kati na yango, ebukani te ;
\q2 Nzambe asungaka yango wuta na tongo makasi.
\q1 
\v 7 Bikolo ezali kotomboka, bamboka ezali kokweya ;
\q2 kasi Nzambe atomboli mongongo na Ye,
\q2 mpe mabele ebukani.
\b
\q1 
\v 8 Yawe, Mokonzi ya mampinga, azali elongo na biso ;
\q2 Nzambe ya Jakobi azali ekimelo na biso.
\b
\q1 
\v 9 Boya kotala misala ya Yawe,
\q2 makambo minene oyo asalaka kati na mokili.
\q1 
\v 10 Asilisaka bitumba kino na basuka ya mokili,
\q2 akataka batolotolo, abukaka makonga
\q2 mpe atumbaka na moto bashar ya bitumba.
\q1 
\v 11 Alobaki : « Bovanda kimia,
\q2 boyeba ete ngai nazali Nzambe ;
\q2 nakonzaka bikolo, nakonzaka mpe mokili. »
\q1 
\v 12 Yawe, Mokonzi ya mampinga, azali elongo na biso ;
\q2 Nzambe ya Jakobi azali ekimelo na biso.
\c 47
\cl Nzembo 47
\s1 Bobetela Nzambe maboko
\d 
\v 1 Nzembo ya bana ya Kore. Wuta na buku ya mokambi ya bayembi.
\q1 
\v 2 Bino nyonso, bikolo, bobeta maboko !
\q2 Boganga epai na Nzambe na esengo nyonso.
\q1 
\v 3 Tala ndenge nini Yawe,
\q2 Ye-Oyo-Aleki-Likolo, azali somo !
\q2 Azali Mokonzi Monene na mokili mobimba.
\q1 
\v 4 Atiaki bikolo na se na biso,
\q2 mpe mabota na se ya bokonzi na biso.
\q1 
\v 5 Aponelaki biso libula na biso,
\q2 oyo ezali lokumu ya Jakobi, molingami na Ye.
\b
\q1 
\v 6 Nzambe amataki kati na koganga ya esengo ;
\q2 Yawe ayaka kati na lokito ya kelelo.
\q1 
\v 7 Boyemba mpo na lokumu ya Nzambe,
\q2 boyemba mpo na lokumu na Ye.
\q1 Boyemba mpo na lokumu ya Mokonzi na biso,
\q2 boyemba mpo na lokumu na Ye.
\q1 
\v 8 Pamba te Nzambe azali Mokonzi ya mokili mobimba ;
\q2 boyemba nzembo mpo na lokumu na Ye.
\b
\q1 
\v 9 Nzambe akonzaka bikolo nyonso ;
\q2 Nzambe avandi na Kiti na Ye ya bule.
\q1 
\v 10 Bato minene ya bikolo basangani,
\q2 lokola bato ya Nzambe ya Abrayami,
\q1 pamba te bilombe ya mokili bazali ya Nzambe ;
\q2 atombwama makasi.
\c 48
\cl Nzembo 48
\s1 Engumba ya Nzambe
\d 
\v 1 Nzembo ya bana ya Kore.
\q1 
\v 2 Yawe azali monene mpe abongi na lokumu,
\q2 kati na engumba ya Nzambe na biso,
\q2 ngomba na Ye ya bule.
\b
\q1 
\v 3 Ezali kitoko, ngomba moke oyo esalaka
\q2 esengo ya mokili mobimba,
\q2 ngomba Siona !
\q1 Ngambo na yango ya Nor nde ezali
\q2 engumba ya Mokonzi Monene.
\q1 
\v 4 Nzambe azali kati na bandako na yango ya bokonzi,
\q2 amimonisi lokola ndako batonga makasi.
\b
\q1 
\v 5 Pamba te bakonzi basanganaki,
\q2 batambolaki nzela moko.
\q1 
\v 6 Kasi tango kaka bamonaki yango,
\q2 bakamwaki mpe bakimaki na somo.
\q1 
\v 7 Mbala moko, bakomaki kolenga wana
\q2 lokola mwasi oyo azali na pasi ya kobota
\q2 
\v 8 to lokola mopepe ya Este oyo apanzaka masuwa ya Tarsisi.
\b
\q1 
\v 9 Ndenge kaka bayebisaki biso,
\q2 ndenge mpe tomonaki kati na engumba ya
\q2 Yawe, Mokonzi ya mampinga,
\q1 kati na engumba ya Nzambe na biso ;
\q2 Nzambe alendisaka yango seko na seko.
\b
\q1 
\v 10 Nzambe, kati na Tempelo na Yo,
\q2 tokanisaka bolingo na Yo.
\q1 
\v 11 Nzambe, lokumu na Yo epanzani kino na suka ya mokili,
\q2 ndenge moko na Kombo na Yo ;
\q2 loboko na Yo ya mobali etondi na bosembo.
\q1 
\v 12 Ngomba ya Siona ezali kosepela,
\q2 bamboka ya Yuda etondi na esengo
\q2 mpo na mikano na Yo.
\b
\q1 
\v 13 Botambola pembeni ya Siona,
\q2 bokende zingazinga na yango,
\q2 botanga bandako na yango ya milayi.
\q1 
\v 14 Botala lopango na yango,
\q2 botala malamu bandako na yango
\q1 mpo ete bopesa sango
\q2 epai ya bato oyo bakoya na sima.
\b
\q1 
\v 15 Pamba te Nzambe wana azali Nzambe na biso
\q2 seko na seko mpe libela na libela ;
\q2 akotambolisa biso, ezala kino na kufa.
\c 49
\cl Nzembo 49
\s1 Kotia motema na bomengo ezali bozoba
\d 
\v 1 Nzembo ya bana ya Kore. Wuta na buku ya mokambi ya bayembi.
\q1 
\v 2 Bino bikolo nyonso, boyoka malamu makambo oyo ;
\q2 bino bavandi nyonso ya mokili, boyoka,
\q1 
\v 3 bato pamba mpe bato minene,
\q2 bazwi mpe babola :
\q1 
\v 4 Monoko na ngai ekoloba maloba ya bwanya ;
\q2 motema na ngai ekanisi makambo
\q2 oyo ekopesa bino bososoli.
\q1 
\v 5 Nayokaka masese,
\q2 mpe nalimbolaka sambole na nzela ya lindanda.
\b
\q1 
\v 6 Mpo na nini nabanga na tango ya pasi,
\q2 tango mabe ya bakosi ezingeli ngai,
\q1 
\v 7 ba-oyo batielaka bomengo na bango motema
\q2 mpe bamikumisaka mpo na bofuluki ya bozwi na bango ?
\q1 
\v 8 Moko te akoki kosikola ndeko na ye,
\q2 moko te akoki kofuta mbongo epai ya Nzambe
\q2 mpo na lisiko na ye.
\q1 
\v 9 Talo ya bomoi na ye eleki motuya makasi,
\q2 mpe ekotikala kofutama te.
\q1 
\v 10 Akokaki kozala na bomoi libela na libela,
\q2 mpe akokaki kokufa te.
\q1 
\v 11 Solo, tomonaka bato ya bwanya kokufa
\q2 elongo na zoba mpe moto oyo azangi mayele,
\q2 mpe batikaka bomengo na bango epai ya bato mosusu.
\q1 
\v 12 Bakunda na bango nde ekomaka
\q2 bandako na bango mpo na libela,
\q1 mpe bisika na bango ya kovanda mpo na seko na seko,
\q2 atako bapesaki na bitando na bango ya mabele
\q2 bakombo na bango mpo ete ebengamaka na yango.
\b
\q1 
\v 13 Mozwi akowumelaka te na bomoi ;
\q2 ata aleki na lokumu,
\q2 akokani na nyama oyo ezali kokufa.
\b
\q1 
\v 14 Yango nde suka ya bato oyo
\q2 batiaka elikya kati na bango moko,
\q1 ya bato oyo balandaka bango
\q2 mpe basepelaka na maloba na bango.
\q1 
\v 15 Bazali lokola bameme
\q2 mpe babongisami mpo na mboka ya bakufi ;
\q2 kufa ekokoma kobokola bango.
\q1 Kala te, bato ya sembo bakonyata bango,
\q2 kitoko na bango ekonzuluka,
\q2 mpe mboka ya bakufi ekokoma ndako na bango.
\q1 
\v 16 Kasi Nzambe akokangola bomoi na ngai
\q2 wuta na maboko ya mboka ya bakufi,
\q2 pamba te akokamata ngai.
\q1 
\v 17 Komitungisaka te soki moto moko akomi kofuluka na bozwi,
\q2 soki kongenga ya ndako na ye ekomi komata se komata.
\q1 
\v 18 Pamba te akomema ata eloko moko te tango akokufa ;
\q2 bomengo na ye ekolanda ye te.
\q1 
\v 19 Atako, wana azalaki na bomoi,
\q2 azalaki komimona moto apambolama—
\q1 atako bato bakokumisa yo,
\q2 pamba te omisali bolamu—
\q1 
\v 20 okokende kaka kokutana na bakoko na yo
\q2 oyo bakotikala komona lisusu pole te.
\b
\q1 
\v 21 Moto oyo azali mozwi, kasi azangi bososoli,
\q2 azali lokola nyama oyo ezali kokufa.
\c 50
\cl Nzembo 50
\s1 Nzambe akosambisa bato na Ye
\d Nzembo ya Azafi.
\q1 
\v 1 Nzambe ya banzambe, Yawe alobi,
\q2 abengi mokili wuta na epai moyi ebimaka kino na epai elalaka.
\q1 
\v 2 Wuta na Siona, mboka kitoko,
\q2 Nzambe azali kongenga lokola moyi.
\b
\q1 
\v 3 Tika ete Nzambe na biso aya !
\q2 Tika ete akanga monoko te !
\q1 Liboso na Ye, moto makasi ezali kozikisa ;
\q2 mpe zingazinga na Ye, mopepe makasi ezali kopepa.
\q1 
\v 4 Abengi Likolo, kuna na likolo, mpe mabele
\q2 mpo na kokata makambo ya bato na Ye.
\q1 
\v 5 Alobi : « Bosangisela ngai bayengebene na ngai,
\q2 ba-oyo basalaki Boyokani elongo na ngai
\q2 na nzela ya mbeka. »
\q1 
\v 6 Likolo ekopanza sango ya bosembo na Ye,
\q2 pamba te azali Nzambe ya bosembo.
\b
\q1 
\v 7 Bino bato na ngai, boyoka ; nazali koloba na bino !
\q2 Isalaele, nakoloba mpo na kotelemela yo :
\q2 « Ngai Nzambe, nazali Nzambe na yo. »
\q1 
\v 8 Nakopamela yo te na tina na bambeka na yo,
\q2 pamba te bambeka na yo ya kotumba
\q2 ezalaka tango nyonso liboso na ngai.
\q1 
\v 9 Nakozwa ngombe te kati na ndako na yo
\q2 to ntaba mobali kati na etonga na yo ya bibwele,
\q1 
\v 10 pamba te banyama nyonso ya zamba ezali ya ngai ;
\q2 ezala ata ebele ya banyama oyo ezali kati na bangomba,
\q2 nyonso ezali ya ngai.
\q1 
\v 11 Nayebi bandeke nyonso ya bangomba ;
\q2 mpe banyama ya bilanga ezali ya ngai.
\q1 
\v 12 Soki nazalaki na nzala, nalingaki koyebisa yo te,
\q2 pamba te mokili mpe nyonso oyo
\q2 ezali kati na yango ezali ya ngai.
\q1 
\v 13 Boni, okanisi penza ete ngai naliaka
\q2 misuni ya bangombe
\q2 to namelaka makila ya bantaba ?
\b
\q1 
\v 14 Bonzelaka Nzambe matondi lokola mbeka,
\q2 mpe kokisaka bandayi na yo
\q2 epai ya Ye-Oyo-Aleki-Likolo.
\q1 
\v 15 Mpe belela ngai na tango ya pasi ;
\q2 nakokangola yo, mpe okopesa ngai nkembo.
\q1 
\v 16 Nzambe alobi na moto mabe :
\q2 « Mpo na nini opanzaka sango ya mibeko na ngai
\q2 mpe olobaka na tina na Boyokani na ngai ?
\q1 
\v 17 Nzokande oyinaka malako na ngai
\q2 mpe oyokaka te maloba na ngai ?
\q1 
\v 18 Soki omoni moyibi,
\q2 wana nde osepeli ;
\q1 mpe ovandaka esika moko na bato na bikobo.
\q1 
\v 19 Otikaka monoko na yo kosala mabe,
\q2 lolemo na yo ebimisaka kaka lokuta.
\q1 
\v 20 Ovandaka mpo na kotonga ndeko na yo,
\q2 mpe obebisaka lokumu ya bana ya mama na yo.
\q1 
\v 21 Yango nde makambo oyo ozalaki kosala ;
\q2 mpe ngai nabatelaki kimia.
\q1 Okanisi penza ete ngai nazali lokola yo ?
\q2 Nakopamela yo mpe nakotanda makambo nyonso
\q2 oyo nazwa yo na miso na yo.
\b
\q1 
\v 22 Bino bato oyo bozali kobosana Nzambe, nabondeli bino :
\q2 bososola makambo oyo ; noki te nakobebisa bino,
\q2 mpe moto moko te akokangola bino.
\q1 
\v 23 Moto oyo abonzaka matondi lokola mbeka,
\q2 apesaka ngai lokumu ;
\q1 mpe moto oyo asalaka keba na etamboli na ye,
\q2 nakotalisa ye lobiko ya Nzambe. »
\c 51
\cl Nzembo 51
\s1 Nasali masumu epai na Yo
\d 
\v 1 Nzembo ya Davidi. Wuta na buku ya mokambi ya bayembi.
\v 2 Eyembamaki tango mosakoli Natan akomaki epai ya Davidi sima na ye kosala ekobo elongo na Batisheba.
\q1 
\v 3 Oh Nzambe, yokela ngai mawa
\q2 kolanda bolingo monene na Yo ;
\q1 longola masumu na ngai
\q2 kolanda mawa monene na Yo !
\q1 
\v 4 Sukola ngai mobimba
\q2 mpo na kolongola mabe na ngai,
\q2 mpe petola ngai na masumu na ngai.
\b
\q1 
\v 5 Pamba te nayebi mabe na ngai,
\q2 mpe masumu na ngai ezalaka
\q2 tango nyonso liboso na ngai.
\q1 
\v 6 Epai na Yo, epai na Yo kaka,
\q2 nasali masumu mpe mabe na miso na Yo.
\q1 Boye, okozala sembo tango okozwa mokano,
\q2 mpe okozala na pamela te tango okokata makambo.
\q1 
\v 7 Solo, nabotamaki kati na lisumu ;
\q2 wuta na libumu ya mama na ngai,
\q2 nazali mosumuki.
\q1 
\v 8 Nzokande Yo, osepelaka na bosembo,
\q2 ata kati na libumu ;
\q1 mpe okoteya ngai bwanya
\q2 kati na esika ebombama.
\b
\q1 
\v 9 Petola ngai na nzela ya izope,
\q2 mpe nakokoma peto ;
\q1 sukola ngai, mpe nakokoma pembe
\q2 koleka mvula ya pembe.
\q1 
\v 10 Sepelisa ngai mpe yokisa ngai nsayi na motema ;
\q2 mpe mikuwa na ngai oyo obukaki
\q2 ekosepela makasi.
\q1 
\v 11 Kotala lisusu masumu na ngai te,
\q2 mpe longola bambeba na ngai nyonso.
\b
\q1 
\v 12 Oh Nzambe, mpo na ngai, kela motema ya peto ;
\q2 mpe kati na ngai, yeisa molimo sika mpe elenda.
\b
\q1 
\v 13 Kobengana ngai te mosika ya elongi na Yo,
\q2 mpe kolongola te kati na ngai
\q2 Molimo Mosantu na Yo.
\q1 
\v 14 Zongisela ngai esengo ya lobiko na Yo,
\q2 mpe kabela ngai molimo oyo emibongisi malamu
\q2 mpo na kolendisaka ngai.
\b
\q1 
\v 15 Nakoteya banzela na Yo epai ya babuki mibeko,
\q2 mpe bato ya masumu bakozonga epai na Yo.
\q1 
\v 16 Oh Nzambe ! Nzambe, Mobikisi na ngai,
\q2 kangola ngai wuta na mokumba ya makila,
\q2 mpe lolemo na ngai ekosakola bosembo na Yo.
\q1 
\v 17 Nkolo, fungola bibebu na ngai,
\q2 mpe monoko na ngai ekokumisa Yo.
\q1 
\v 18 Mpo ete osepelaka na mbeka te,
\q2 nakobonza te mbeka ya kotumba
\q2 oyo ondimaka te.
\q1 
\v 19 Nzambe, bambeka oyo osepelaka na yango ezali :
\q2 molimo oyo ebukani.
\q2 Nzambe, oyinaka te motema oyo etutami mpe emikitisi.
\b
\q1 
\v 20 Na ngolu na Yo, salela Siona bolamu,
\q2 tonga bamir ya Yelusalemi.
\q1 
\v 21 Bongo okosepela na bambeka ya bosembo,
\q2 bambeka ya kotumba mpe makabo ya kokoka ;
\q2 mpe bangombe ya mibali ekobonzama na bitumbelo na Yo.
\c 52
\cl Nzembo 52
\s1 Suka ya mozwi oyo anyokolaka bato
\d 
\v 1 Nzembo ya Davidi. Wuta na buku ya mokambi ya bayembi.
\v 2 Eyembamaki tango Doegi, moto ya Edomi, akendeki koyebisa Saulo ete Davidi akoti na ndako ya Ayimeleki.
\q1 
\v 3 Yo elombe, mpo na nini ozali komikumisa
\q2 na tina na mabe ?
\q2 Bolingo ya Nzambe emonanaka mikolo nyonso.
\q1 
\v 4 Yo oyo otambolaka na lokuta,
\q2 lolemo na yo esalaka mabongisi ya libebi,
\q2 ekosaka lokola mbeli bapelisa malamu.
\q1 
\v 5 Olingaka mabe koleka bolamu,
\q2 lokuta koleka koloba bosolo.
\q1 
\v 6 Oh lolemo ya lokuta,
\q2 olingaka maloba nyonso oyo epanzaka.
\b
\q1 
\v 7 Solo, Ye moko Nzambe akobebisa yo mpo na libela,
\q2 akokanga yo kati na ndako na yo,
\q1 akobwaka yo libanda
\q2 mpe akopikola yo na mokili ya bato ya bomoi.
\q1 
\v 8 Bato ya sembo bakomona
\q2 mpe bakokoma na somo,
\q2 bakotiola ye na maloba oyo :
\q1 
\v 9 « Tala moto oyo azalaki te kozwa Nzambe
\q2 lokola ebombamelo na ye,
\q1 azalaki kotiela bozwi na ye motema,
\q2 mpe kobakisa makasi na ye
\q2 na nzela ya kobebisa bato mosusu. »
\b
\q1 
\v 10 Kasi ngai, kati na Ndako na Yo,
\q2 nazali lokola nzete ya olive
\q1 oyo etondi na makasa ya mobesu ;
\q2 natiaka tango nyonso elikya na ngai
\q2 kati na bolingo monene ya Nzambe, mpo na libela.
\q1 
\v 11 Nakosanzola Yo mikolo nyonso,
\q2 mpo na oyo osali ;
\q1 mpe nazalaka na elikya kati na Kombo na Yo,
\q2 pamba te ozali malamu mpo na bayengebene na Yo.
\c 53
\cl Nzembo 53
\s1 Bato nyonso babungi nzela
\d 
\v 1 Nzembo ya Davidi. Wuta na buku ya mokambi ya bayembi. Eyembamaki na flite.
\q1 
\v 2 Bazoba bamilobelaka :
\q2 « Nzambe azali te. »
\q1 Makanisi na bango esila kobeba,
\q2 basalaka makambo mabe mpe ya nkele ;
\q2 moko te asalaka bolamu.
\b
\q1 
\v 3 Wuta na likolo, Nzambe atalaka bato
\q2 mpo na koluka koyeba
\q1 soki ezali ata na moko ya mayele,
\q2 oyo atalelaka Nzambe.
\q1 
\v 4 Bango nyonso bazali batomboki,
\q2 bango nyonso bamibebisa ;
\q1 moko te asalaka bolamu,
\q2 ata moto moko te.
\b
\q1 
\v 5 Boni, bato nyonso ya misala mabe bayebi eloko te ?
\b
\q1 Baliaka bato na ngai ndenge baliaka lipa
\q2 mpe batikala nanu kobelela Nzambe te,
\q2 bazali penza kososola eloko moko te ?
\b
\q1 
\v 6 Somo monene ekokanga bango
\q2 na esika oyo ezali ata na eloko moko te
\q1 oyo ekoki kopesa bango somo,
\q2 pamba te Nzambe apanzi mikuwa ya bato
\q1 oyo bayei kobundisa yo.
\q1 Okoyokisa bango soni,
\q2 pamba te Nzambe abwaka bango.
\b
\q1 
\v 7 Tika ete lobiko ya Isalaele ebimela na Siona !
\q2 Tango Nzambe akobimisa bato na Ye na bowumbu,
\q1 bakitani ya Jakobi bakosepela,
\q2 mpe Isalaele ekozala na esengo.
\c 54
\cl Nzembo 54
\s1 Nzambe akangoli ngai
\d 
\v 1 Nzembo ya Davidi. Wuta na buku ya mokambi ya bayembi.
\v 2 Eyembamaki na lindanda tango bato ya Zifi bayaki koyebisa Saulo : « Davidi abombami kati na biso. »
\q1 
\v 3 Oh Nzambe, bikisa ngai na nzela ya Kombo na Yo,
\q2 longisa ngai na nzela ya nguya na Yo.
\q1 
\v 4 Oh Nzambe, yoka libondeli na ngai,
\q2 yoka maloba ya monoko na ngai.
\b
\q1 
\v 5 Bapaya batelemi mpo na kobundisa ngai ;
\q2 mpe bato na kanza bazali koluka koboma ngai,
\q2 batalelaka Nzambe te.
\b
\q1 
\v 6 Tala, Nzambe azali lisungi na ngai,
\q2 Nkolo azali eyekamelo na ngai.
\b
\q1 
\v 7 Tika ete akweyisela bayini na ngai mabe !
\q2 Kati na boyengebene na Yo, bebisa bango.
\b
\q1 
\v 8 Nakobonzela Yo mbeka na motema malamu,
\q2 nakokumisa Kombo na Yo, Oh Yawe,
\q2 pamba te ozali malamu.
\q1 
\v 9 Okangoli ngai na pasi nyonso ;
\q2 mpe miso na ngai etali
\q2 lokola molongi ya banguna na ngai.
\c 55
\cl Nzembo 55
\s1 Libondeli ya moto oyo bateki
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Eyembamaki na lindanda. Nzembo ya Davidi.
\q1 
\v 2 Oh Nzambe, yoka libondeli na ngai,
\q2 komibomba te wana nazali kobelela Yo.
\q1 
\v 3 Yoka ngai mpe yanola ngai.
\q2 Kati na kolela na ngai, nakomi koyengayenga
\q2 mpe nazangi kimia,
\q1 
\v 4 mpo na maloba ya monguna na ngai
\q2 mpe kanda ya moto mabe,
\q1 pamba te bazali kokweyisela ngai misala mabe
\q2 mpe konyokola ngai na kanda.
\b
\q1 
\v 5 Motema na ngai etondi na mawa,
\q2 mpe somo ya kufa ekangi ngai.
\q1 
\v 6 Nakomi kobanga mpe kolenga,
\q2 somo monene ekangi ngai.
\q1 
\v 7 Nakomi komilobela :
\q2 « Soki nazalaki ata na mapapu ya ebenga,
\q2 nalingaki kopumbwa mpo na koluka bopemi ;
\q1 
\v 8 nalingaki kokima mosika penza,
\q2 mpo na kokende kovanda ata na esobe.
\q1 
\v 9 Solo, na lombangu penza,
\q2 nalingaki kokende koluka ebombamelo
\q2 mpo na kokima mopepe makasi mpe ekumbaki. »
\b
\q1 
\v 10 Nkolo, bebisa mabongisi ya banguna na ngai
\q2 mpe kotisa mobulu kati na bango ;
\q1 pamba te, kati na engumba,
\q2 nazali komona mobulu mpe bokabwani.
\q1 
\v 11 Butu mpe moyi, ezali kotambola
\q2 na bamir na yango ;
\q2 misala mabe mpe ya kanza etondi kati na yango.
\q1 
\v 12 Banguya oyo ebebisaka ezali kosala kati na yango,
\q2 minyoko mpe lokuta ezali kosila te.
\b
\q1 
\v 13 Soki monguna nde azalaki kofinga ngai,
\q2 nalingaki kokanga motema ;
\q1 soki ezalaki mpe moyini nde azalaki kotelemela ngai,
\q2 nalingaki komibomba mpo ete amona ngai te.
\q1 
\v 14 Kasi ezali yo, moto lokola ngai,
\q2 oyo otambolaka elongo na ngai,
\q2 molingami mpe moninga na ngai ya motema
\q1 
\v 15 oyo nazalaki kokabola elongo na yo,
\q2 pasi mpe basekele
\q1 tango tozalaki kokende
\q2 nzela moko na Tempelo ya Nzambe.
\b
\q1 
\v 16 Tika ete kufa ekanga bango na mbalakata
\q2 mpe bakita ya bomoi kati na mboka ya bakufi ;
\q1 pamba te mabe etondi kati na bandako
\q2 mpe mitema na bango.
\b
\q1 
\v 17 Mpo na ngai, nabelelaka Nzambe,
\q2 mpe Yawe akobikisa ngai.
\q1 
\v 18 Tongo, midi, pokwa,
\q2 nasopaka motema na ngai mpe nalelaka,
\q2 mpe ayokaka mongongo na ngai.
\q1 
\v 19 Akopesa ngai kimia, akokangola ngai
\q2 na bitumba oyo babundisaka ngai ;
\q2 pamba te bato oyo batelemeli ngai bazali ebele.
\q1 
\v 20 Nzambe ayokaka, akosambwisa bango penza ;
\q2 akonzaka mpo na libela na libela.
\b
\q1 Babongolaka mitema te
\q2 mpe batosaka Nzambe te.
\b
\q1 
\v 21 Abundisi balingami na ye,
\q2 abebisi boyokani na ye.
\q1 
\v 22 Maloba ya monoko na ye ezalaka sukali,
\q2 nzokande bitumba evandi kati na motema na ye ;
\q1 maloba na ye ezalaka ya kimia koleka mafuta,
\q2 nzokande ezali mopanga oyo ezangi ebombelo.
\b
\q1 
\v 23 Bwakela Yawe mokumba na yo,
\q2 akosunga yo ;
\q1 akotika te ete moto ya sembo akweya
\q2 mpo na libela.
\q1 
\v 24 Mpe Yo, Nzambe, okobwaka basopi makila
\q2 mpe bakosi kati na libulu ya libebi ;
\q1 bakokokisa ata kati-kati te
\q2 ya mikolo ya bomoi na bango.
\q2 Kasi ngai, natiaka elikya na ngai kati na Yo.
\c 56
\cl Nzembo 56
\s1 Elongo na Nzambe, kobanga ezali lisusu te
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Eyembamaki ndenge moko na « Ebenga ya terebente ya mosika. » Nzembo ya Davidi, tango bato ya Filisitia bakangaki ye kati na mboka Gati.
\q1 
\v 2 Nzambe, yokela ngai mawa,
\q2 pamba te bato bazali kotungisa ngai.
\q2 Babundisaka mpe banyokolaka ngai mikolo nyonso.
\q1 
\v 3 Bayini na ngai batungisaka ngai mikolo nyonso ;
\q2 bato oyo babundisaka ngai na lolendo bazali ebele.
\b
\q1 
\v 4 Mokolo oyo nazalaka na bobangi,
\q2 natiaka elikya na ngai kati na Yo.
\q1 
\v 5 Epai ya Nzambe, nakumisaka Liloba na Ye ;
\q2 Epai ya Nzambe, natiaka motema mpe nabangaka te.
\q2 Moto oyo akokufa akoki kosala ngai nini ?
\b
\q1 
\v 6 Babongolaka maloba na ngai mikolo nyonso ;
\q2 mabongisi na bango nyonso ezalaka
\q2 mpo na kosala ngai mabe.
\q1 
\v 7 Basalaka makita, babombamaka,
\q2 balandaka ngai mpo na kosala ngai mabe.
\q1 
\v 8 Mpo na makambo oyo ya mabe,
\q2 boni, bazanga etumbu ?
\q2 Oh Nzambe, kweyisela bikolo kanda na Yo !
\b
\q1 
\v 9 Solo, oyebi motango ya matambe
\q2 ya bomoi na ngai ya mitelengano.
\q1 Sopa mpinzoli na ngai kati na mbeki na Yo,
\q2 oyo ezali buku na Yo ya ekaniseli.
\q1 
\v 10 Bongo, na mokolo oyo nakobelela
\q2 mpo na kosenga lisungi,
\q1 banguna na ngai bakozonga sima.
\q2 Na nzela ya likambo yango,
\q2 nakoyeba ete Nzambe azali mpo na ngai.
\b
\q1 
\v 11 Pembeni ya Nzambe oyo nakumisaka Liloba na Ye,
\q2 pembeni ya Yawe oyo nakumisaka Liloba na Ye,
\q1 
\v 12 pembeni ya Nzambe oyo natielaka motema
\q2 mpe nazalaka na bobangi te,
\q2 moto akoki kosala ngai nini ?
\b
\q1 
\v 13 Epai na Yo Nzambe, nakokokisa bandayi na ngai
\q2 mpe nakobonza bambeka ya matondi.
\q1 
\v 14 Pamba te okangoli ngai na kufa
\q2 mpe obateli makolo na ngai ete ebeta mabaku te,
\q1 mpo ete natambola liboso na Yo Nzambe
\q2 kati na pole ya bomoi.
\c 57
\cl Nzembo 57
\s1 Kimia na kati ya banguna
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Eyembamaki ndenge moko na nzembo « Koboma te. » Nzembo ya Davidi, tango Saulo azalaki kolanda ye, mpe tango Davidi abombamaki kati na libulu.
\q1 
\v 2 Oh Nzambe, yokela ngai mawa !
\q2 Yokela ngai mawa,
\q1 pamba te nazali koluka ebombamelo ;
\q2 nazali koluka ebombamelo na se ya mapapu na Yo,
\q2 kino tango ya pasi ekoleka.
\b
\q1 
\v 3 Nazali koganga epai ya Nzambe-Oyo-Aleki-Likolo,
\q2 epai ya Nzambe oyo asalelaka ngai bolamu.
\q1 
\v 4 Akotinda wuta na likolo mpe akobikisa ngai,
\q2 akopamela bato oyo batungisaka ngai.
\q1 Nzambe akomonisa bolingo
\q2 mpe boyengebene na Ye.
\b
\q1 
\v 5 Nazali na kati-kati ya bankosi ;
\q2 nalali na kati-kati ya bato
\q1 oyo babomaka mpe baliaka bato,
\q2 oyo minu na bango ezali makonga mpe batolotolo,
\q2 mpe lolemo na bango ezali mopanga ya minu makasi.
\b
\q1 
\v 6 Oh Nzambe, tika ete omitombola na likolo ya Lola ;
\q2 tika ete nkembo na Yo ezala
\q2 awa na mokili mobimba !
\b
\q1 
\v 7 Batiaki monyama na makolo na ngai
\q2 mpo ete nakangama,
\q1 batimolaki libulu liboso na ngai,
\q2 kasi bango moko nde bakweyaki kati na libulu yango.
\b
\q1 
\v 8 Nzambe, lendisa motema na ngai ;
\q2 Nzambe, lendisa motema na ngai.
\q1 Nakoyembela Yo mpe nakosanzola Yo na mindule.
\q1 
\v 9 Lokumu na ngai, lamuka !
\q2 Lindanda mpe nzenze, bolamuka !
\q2 Nalingi kolamusa tongo.
\b
\q1 
\v 10 Nkolo, nakosanzola Yo kati na mabota,
\q2 nakosanzola Yo na mindule kati na bikolo.
\q1 
\v 11 Pamba te bolingo na Yo ezali monene,
\q2 ekenda kino na Lola ;
\q2 mpe bosembo na Yo ekenda kino na mapata.
\b
\q1 
\v 12 Nzambe, tika ete omitombola na likolo ya Lola ;
\q2 mpe tika ete nkembo na Yo etonda na mokili mobimba !
\c 58
\cl Nzembo 58
\s1 Nzambe, Mosambisi ya sembo ya bakambi mabe
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Eyembamaki ndenge moko na « Kobebisa te. » Nzembo ya Davidi.
\q1 
\v 2 Ezali solo ete bolobaka te tango bokataka makambo ?
\q2 Boni, bana na moto, bosambisaka na bosembo ?
\q1 
\v 3 Te, ezala kati na mitema na bino,
\q2 bosalaka mabongisi ezanga bosembo ;
\q2 botandaka kanza ya maboko na bino kati na mokili.
\b
\q1 
\v 4 Bato mabe babebaka wuta na mbotama na bango,
\q2 bapengwaka mpe balobaka lokuta
\q2 wuta na mabumu ya bamama na bango.
\q1 
\v 5 Bazalaka na ngenge lokola ngenge ya nyoka,
\q2 lokola ngenge ya etupa oyo eyokaka te,
\q2 oyo ekangaka litoyi na yango,
\q1 
\v 6 oyo eyokaka te ata mingongo ya bato na soloka
\q2 mpe ya moto ya maji oyo aleki na mayele.
\b
\q1 
\v 7 Nzambe, buka minu na bango
\q2 kati na minoko na bango ;
\q2 Yawe, buka bambanga ya bana ya bankosi.
\q1 
\v 8 Tika ete balimwa lokola mayi oyo ezali kotiola ;
\q2 Tika ete bambanzi na bango ebukana
\q2 tango babetaka batolotolo.
\q1 
\v 9 Tika ete balimwa lokola soyi ya mbembe,
\q2 lokola mwana oyo akomona moyi te
\q2 mpo ete abimi na zemi oyo esopani.
\b
\q1 
\v 10 Liboso ete banzungu na bino ekutana
\q2 na moto ya basende,
\q1 ezala ya mayi to ya kokawuka,
\q2 bato mabe akolimwa.
\q1 
\v 11 Moto ya sembo akosepela,
\q2 pamba te akomona Nzambe
\q1 kozongisela bato mabe, mabe na mabe,
\q2 mpe akotambola kati na makila na bango.
\q1 
\v 12 Mpe bato bakoloba :
\q2 « Solo, ezali na lifuti mpo na moto ya sembo ;
\q2 solo, ezali na Nzambe oyo asambisaka mokili. »
\c 59
\cl Nzembo 59
\s1 Nzambe na ngai, kangola ngai
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Eyembamaki ndenge moko na « Kobebisa te ! » tango Saulo atindaki bato kozingela ndako ya Davidi mpo na koboma ye. Nzembo ya Davidi.
\q1 
\v 2 Oh Nzambe na ngai, kangola ngai
\q2 wuta na maboko ya banguna na ngai ;
\q2 batela ngai liboso ya banyokoli na ngai.
\q1 
\v 3 Kangola ngai wuta na maboko
\q2 ya bato ya misala mabe,
\q2 mpe bikisa ngai liboso ya basopi makila ya bato.
\b
\q1 
\v 4 Yawe, bazali koluka koboma ngai ;
\q2 bato na nguya basaleli ngai likita,
\q1 nzokande nasali mabe te,
\q2 nasali na ngai mpe masumu te.
\q1 
\v 5 Nasali mabe ata moko te ;
\q2 kasi bango bazali kopota mbangu,
\q1 bazali komibongisa.
\q2 Lamuka mpo na koya kokutana na ngai, mpe tala.
\q1 
\v 6 Yawe, Nzambe-Na-Nguya-Nyonso,
\q2 Nzambe ya Isalaele, telema mpo na kopesa
\q1 bikolo nyonso etumbu ;
\q2 koyokela bato nyonso oyo basalaka mabe mawa te.
\b
\q1 
\v 7 Bazongaka na pokwa,
\q2 bagangaka lokola bambwa
\q2 mpe batambolaka zingazinga ya engumba.
\q1 
\v 8 Na nzela ya minoko na bango,
\q2 babimisaka na bibebu na bango
\q1 maloba oyo ezokisaka lokola mipanga ; bamilobelaka :
\q2 « Nani azali koyoka biso ? »
\q1 
\v 9 Kasi Yo, Yawe, osekaka bango,
\q2 otiolaka bikolo nyonso.
\b
\q1 
\v 10 Nzambe, ozali makasi na ngai,
\q2 nakotalela Yo ;
\q2 ozali ebombamelo na ngai,
\q1 
\v 11 Nzambe na ngai, oyo nalingaka.
\b
\q1 Nzambe ayaka kino liboso na ngai,
\q2 atikaka ngai kotala banguna na ngai.
\q1 
\v 12 Nkolo, nguba na biso, koboma bango te,
\q2 noki te bato na ngai bakobosana.
\q1 Na nguya na Yo, sala ete bayengayenga,
\q2 mpe mema bango kino na se.
\q1 
\v 13 Mpo na masumu ya minoko na bango,
\q2 mpo na maloba ya bibebu na bango,
\q1 tika ete bakangama na motambo ya lolendo na bango.
\q2 Mpo na bilakeli mabe mpe lokuta na bango,
\q1 
\v 14 bebisa bango na kanda na Yo,
\q2 bebisa bango kino bazala lisusu te.
\q1 Bongo bakoyeba ete Nzambe azali kokonza
\q2 kati na Jakobi kino na suka ya mokili.
\b
\q1 
\v 15 Bazongaka na pokwa,
\q2 bagangaka lokola bambwa
\q2 mpe batambolaka zingazinga ya engumba.
\q1 
\v 16 Bayengaka-yengaka mpo na koluka bilei ;
\q2 soki batondi te, balekisaka butu na kolelalela.
\q1 
\v 17 Kasi ngai nakoyembela makasi na Yo,
\q2 nakobetela bolingo na Yo milolo, na tongo,
\q1 pamba te ozali ebombamelo na ngai,
\q2 mpe ekimelo na ngai na tango ya pasi.
\q1 
\v 18 Ozali makasi na ngai,
\q2 nakoyemba mpo na lokumu na Yo ;
\q1 ozali ebombamelo na ngai, oh Nzambe ;
\q2 Nzambe na ngai, oyo nalingaka.
\c 60
\cl Nzembo 60
\s1 Tokolonga kaka
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Eyembamaki ndenge moko na « Lisi ya litatoli. » Nzembo ya Davidi mpo na koteya bato.
\v 2 Ayembaki yango tango abundisaki bato ya Siri ya Mezopotami mpe bato ya Siri ya Tsoba, mpe tango Joabi azongaki, sima na ye kolonga bato nkoto zomi na mibale ya Edomi, na bitumba kati na Lubwaku ya Mungwa.
\q1 
\v 3 Oh Nzambe, obwakaki mpe opanzaki biso,
\q2 osilikaki penza.
\q2 Sik’oyo, zongisa biso.
\q1 
\v 4 Solo, oningisaki mabele mpe obukaki yango.
\q2 Bamba madusu na yango,
\q2 pamba te ekomi koningana.
\q1 
\v 5 Omonisaki bato na Yo pasi makasi,
\q2 omelisaki biso vino oyo elangwisaka.
\q1 
\v 6 Opesaki na bato oyo batosaka Yo bendele
\q2 mpo na koyebisa bango
\q2 ete bakima liboso ya batolotolo ya banguna.
\b
\q1 
\v 7 Mpo ete balingami na Yo bakangolama,
\q2 bikisa na nguya ya loboko na Yo ya mobali,
\q2 mpe yanola biso ! Yanola ngai !
\q1 
\v 8 Nzambe alobaki kati na Esika na Ye ya bule :
\q2 « Nakolonga ! Nakokabola Sishemi
\q2 mpe nakomeka molayi ya lubwaku ya Sukoti.
\q1 
\v 9 Galadi ezali ya ngai, Manase mpe ezali ya ngai ;
\q2 Efrayimi ezali ekoti na ngai ya ebende,
\q2 mpe Yuda ezali lingenda na ngai ya bokonzi.
\q1 
\v 10 Moabi ezali sani monene oyo nasukolelaka,
\q2 Edomi ezali esika oyo nabwakaka sandale na ngai.
\q2 Mpo na Filisitia, nabetaka milolo ya elonga. »
\b
\q1 
\v 11 Nani akomema ngai kino na engumba
\q2 oyo batonga makasi ?
\q2 Nani akotambolisa ngai kino na Edomi ?
\q1 
\v 12 Ezali Yo te, Nzambe oyo obwakaki biso,
\q2 Nzambe oyo ozalaki lisusu te kokende bitumba
\q2 elongo na mampinga na biso ?
\q1 
\v 13 Yaka kosunga biso,
\q2 kangola biso liboso ya moyini ;
\q2 pamba te lisungi ya bato ezali pamba.
\q1 
\v 14 Nzokande, elongo na Nzambe,
\q2 tokosala makambo minene mpe ya kokamwa ;
\q2 ezali Ye nde akonyata banguna na biso.
\c 61
\cl Nzembo 61
\s1 Bomba ngai na se ya lipapu na Yo
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Eyembamaki na lindanda. Nzembo ya Davidi.
\q1 
\v 2 Oh Nzambe, yoka koganga na ngai,
\q2 yoka na bokebi losambo na ngai.
\q1 
\v 3 Wuta na suka ya mokili, nazali kobelela Yo,
\q2 motema na ngai ebukani !
\q1 Mema ngai na libanga oyo eleki likolo
\q2 epai wapi nakokoka te kokoma ngai moko.
\q1 
\v 4 Pamba te, ozali ebombamelo na ngai,
\q2 ndako molayi batonga makasi,
\q2 liboso ya banguna na ngai.
\q1 
\v 5 Posa ya motema na ngai ezali :
\q2 kovanda tango nyonso kati na Ndako na Yo
\q2 mpe kozwa ebombamelo na se ya mapapu na Yo.
\b
\q1 
\v 6 Pamba te Yo Nzambe, oyokaki bandayi na ngai,
\q2 opesaki ngai libula ya bato
\q2 oyo batosaka Kombo na Yo.
\b
\q1 
\v 7 Pesa na mokonzi na biso bomoi molayi ;
\q2 tika ete awumela na bomoi.
\q1 
\v 8 Tika ete awumela na bokonzi
\q2 libela na libela liboso ya Nzambe !
\q2 Bolingo mpe boyengebene na Yo ekobatela ye.
\b
\q1 
\v 9 Boye, nakoyemba mikolo nyonso
\q2 mpo na lokumu ya Kombo na Yo,
\q1 mpe nakokokisa bandayi na ngai
\q2 mokolo na mokolo.
\c 62
\cl Nzembo 62
\s1 Nazwaka na kimia kati na Nzambe
\d 
\v 1 Wuta na buku ya mokambi ya bayembi, kolanda Yedutuni. Nzembo ya Davidi.
\q1 
\v 2 Solo, nazwaka kimia kati na Nzambe ;
\q2 lobiko na ngai ewutaka epai na Ye.
\q1 
\v 3 Solo, azali libanga mpe lobiko na ngai ;
\q2 azali ebombamelo na ngai,
\q2 nakoningana te.
\b
\q1 
\v 4 Kino tango nini bokosangela moto moko ?
\q2 Kino tango nini bino nyonso bokosangana
\q1 mpo na koluka koboma ye
\q2 lokola mir oyo etengami,
\q2 lokola lopango oyo esili kokweya ?
\q1 
\v 5 Solo, basalaka makita mpo na kokweyisa ye
\q2 wuta na esika na ye ya likolo,
\q1 basepelaka kotatola lokuta.
\q2 Bapambolaka na nzela ya minoko na bango ;
\q2 kasi kati na mitema na bango, balakelaka mabe.
\b
\q1 
\v 6 Oh molimo na ngai, zwa bopemi kati na Nzambe,
\q2 pamba te elikya na ngai ewutaka epai na Ye.
\q1 
\v 7 Solo, azali libanga mpe lobiko na ngai ;
\q2 azali ebombamelo na ngai, nakoningana te.
\q1 
\v 8 Nzambe azali lobiko mpe nkembo na ngai ;
\q2 libanga ya makasi na ngai mpe ebombamelo na ngai
\q2 ezali kati na Nzambe.
\q1 
\v 9 Botielaka Ye elikya tango nyonso,
\q2 bosopaka mitema na bino liboso na Ye,
\q2 pamba te Nzambe azali ebombamelo mpo na biso.
\b
\q1 
\v 10 Solo, bato bazali lokola molunge,
\q2 bazali lokola lokuta ;
\q1 Soki batie bango na emekelo kilo,
\q2 ata molunge ekoleka bango nyonso na kilo.
\q1 
\v 11 Botiaka elikya te na mileki ya moyibi,
\q2 mpe botielaka yango motema te ;
\q1 soki bomengo na bino ekomi ebele,
\q2 bokangama na yango te.
\b
\q1 
\v 12 Nzambe alobaki mbala moko,
\q2 ngai nayokaki mbala mibale :
\q2 « Pamba te makasi ezali ya Nzambe ;
\q1 
\v 13 mpe bolingo ezali ya Nkolo ; »
\q2 mpe « ofutaka moto nyonso
\q2 kolanda misala na ye. »
\c 63
\cl Nzembo 63
\s1 Boboto ya Nzambe eleki bomoi na motuya
\d 
\v 1 Nzembo ya Davidi. Ayembaki yango tango azalaki kati na esobe ya Yuda.
\q1 
\v 2 Oh Nzambe, ozali Nzambe na ngai ;
\q2 nazali koluka Yo,
\q1 molimo na ngai ezali na posa na Yo,
\q2 bomoi na ngai ezali na posa na Yo makasi,
\q2 kati na mabele ekawuka mpe ezanga mayi.
\b
\q1 
\v 3 Natalaki Yo kati na Esika ya bule
\q2 mpo na komona makasi mpe nkembo na Yo.
\q1 
\v 4 Pamba te bolingo na Yo ezali malamu koleka bomoi,
\q2 bibebu na ngai ekosanzola Yo.
\q1 
\v 5 Boye, nakopambola Yo bomoi na ngai mobimba,
\q2 nakotombola maboko na ngai
\q2 mpo na lokumu ya Kombo na Yo.
\q1 
\v 6 Nakotonda lokola moto oyo asili kolia
\q2 misuni kitoko mpe mafuta ;
\q1 bibebu na ngai ekoganga na esengo
\q2 mpe monoko na ngai ekokumisa Yo.
\b
\q1 
\v 7 Soki nakanisi Yo na mbeto na ngai,
\q2 nasambelaka Yo na butu ;
\q1 
\v 8 pamba te ozali lisungi mpo na ngai,
\q2 mpe nagangaka na esengo
\q2 wana nazali na se ya elili ya mapapu na Yo.
\q1 
\v 9 Nakangami na Yo ;
\q2 loboko na Yo ya mobali esimbi ngai makasi.
\b
\q1 
\v 10 Bato oyo balukaka koboma ngai
\q2 bakozinda na mabele
\q1 
\v 11 Bakoboma bango na mopanga
\q2 mpe bakokoma bilei ya bambwa ya zamba.
\b
\q1 
\v 12 Kasi mokonzi akosepela kati na Nzambe ;
\q2 moto nyonso oyo alapaka ndayi
\q2 na Kombo ya Nzambe
\q1 akomikumisa mpo na yango,
\q2 pamba te minoko ya bakosi ekokangama.
\c 64
\cl Nzembo 64
\s1 Batela ngai
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi.
\q1 
\v 2 Oh Nzambe, yoka mongongo na ngai
\q2 kati kolela na ngai,
\q1 batela ngai mosika ya monguna
\q2 oyo azali kopesa ngai somo.
\b
\q1 
\v 3 Bomba ngai mosika ya mikano ya bato mabe,
\q2 mosika ya makita ya bato ya misala mabe.
\q1 
\v 4 Bapelisaka lolemo na bango
\q2 ndenge bapelisaka mopanga,
\q2 babimisaka maloba ya bololo lokola makonga
\q1 
\v 5 mpo na kobwakela, na kobombama,
\q2 moto oyo azangi pamela ;
\q2 babangaka te kobwakela ye yango na mbalakata.
\q1 
\v 6 Balendisanaka mpo na mabongisi mabe,
\q2 bayokanaka kotia mitambo ;
\q2 balobaka : « Nani akomona yango ? »
\q1 
\v 7 Basalaka mabongisi ya kosala bato mabe,
\q2 balobaka : « Toselingwi na mabongisi na biso ! »
\q2 Makanisi mpe motema ya moto ezali mozindo makasi.
\b
\q1 
\v 8 Kasi Nzambe akobwakela bango
\q2 makonga na Ye na mbalakata ;
\q2 ekozwa mpe ekozokisa bango.
\q1 
\v 9 Maloba na bango moko ekobalukela bango
\q2 mpe ekomema bango na libebi ;
\q1 mpe moto nyonso oyo akomona bango
\q2 akoningisa moto.
\q1 
\v 10 Bato nyonso bakokoma kobanga,
\q2 kopanza sango ya misala ya Nzambe
\q2 mpe kososola makambo oyo asalaka.
\b
\q1 
\v 11 Moto ya sembo akosepela
\q2 mpe akomibomba kati na Yawe ;
\q1 bato nyonso oyo bazali na mitema alima
\q2 bakomikumisa mpo na yango.
\c 65
\cl Nzembo 65
\s1 Opesaka bofuluki
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi.
\q1 
\v 2 Mpo na Yo Nzambe,
\q2 bozangi makelele ezali lokumu, kati na Siona ;
\q2 mpe mpo na Yo, ndayi ekokokisama.
\q1 
\v 3 Yo oyo oyokaka mabondeli,
\q2 bato nyonso bakoya epai na Yo.
\q1 
\v 4 Kilo ya bambeba eleki makasi mpo na ngai ;
\q2 kasi Yo, olimbisaka masumu na biso.
\q1 
\v 5 Esengo na moto oyo oponi mpe obulisi
\q2 mpo ete avanda kati na lopango na Yo.
\q1 Tokotonda na bolamu ya Ndako na Yo,
\q2 Tempelo na Yo ya bule.
\b
\q1 
\v 6 Nzambe Mobikisi na biso,
\q2 oyanolaka biso na bosembo,
\q1 na nzela ya biloko ya somo ;
\q2 Ozali elikya ya mokili mobimba
\q2 mpe ya bibale minene.
\q1 
\v 7 Alendisaka bangomba, na nguya na Ye ;
\q2 atondi na mpiko.
\q1 
\v 8 Akitisaka makelele ya bibale minene,
\q2 makelele ya bambonge na yango
\q2 mpe makelele ya bikolo.
\q1 
\v 9 Bato oyo bavandaka na basuka ya mokili
\q2 babangaka tango bamonaka bikamwa na Yo ;
\q2 osalaka ete este mpe weste eganga na esengo.
\b
\q1 
\v 10 Opambolaka mabele, ofulukisaka yango,
\q2 otondisaka yango na bozwi.
\q1 Otondisaka moluka ya Nzambe na mayi,
\q2 obongiselaka bato ble,
\q2 pamba te otondisaka mayi mpo na yango.
\q1 
\v 11 Olekisaka mayi kati na mikala,
\q2 okweyisaka mipiku ya mabele,
\q1 osopelaka mabele mayi
\q2 mpe opambolaka milona.
\q1 
\v 12 Opambolaka mobu na bolamu na Yo,
\q2 mpe banzela mike oyo olekelaka ebotaka ebele.
\q1 
\v 13 Bilanga ya esobe etondaka na bilei,
\q2 mpe bangomba mike etondaka na esengo.
\q1 
\v 14 Bilanga etondaka na bameme mpe bantaba ;
\q2 mabwaku etondaka na ble,
\q2 egangaka na esengo mpe eyembaka.
\c 66
\cl Nzembo 66
\s1 Lokumu na Nzambe oyo akangoli biso
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo.
\q1 Bino bato ya mokili mobimba,
\q2 bobetela Nzambe maboko !
\q1 
\v 2 Boyemba banzembo ya lokumu
\q2 mpo na nkembo ya Kombo na Ye,
\q2 bopesa lokumu na Ye nkembo.
\q1 
\v 3 Boloba na Nzambe :
\q2 « Tala ndenge nini misala na Yo ebongi na kobanga yango !
\q1 Mpo na nguya monene na Yo,
\q2 banguna na Yo bakomi koluka kokoma baninga na Yo.
\q1 
\v 4 Mokili mobimba efukamaka liboso na Yo ;
\q2 bayembaka mpo na lokumu na Yo,
\q2 basanzolaka Kombo na Yo. »
\b
\q1 
\v 5 Boya kotala misala ya Nzambe !
\q2 Misala na Ye ya minene mpo na bana ya bato ebongi na kobanga yango.
\q1 
\v 6 Abongolaki ebale monene mabele ya kokawuka ;
\q2 bakatisaki ebale na makolo ekawuka.
\q2 Tozali kosepela kati na Ye.
\q1 
\v 7 Na nguya na Ye, akonzaka mpo na libela ;
\q2 miso na Ye ekengelaka bikolo.
\q2 Tika ete batomboki batombokela Ye te.
\b
\q1 
\v 8 Bino bikolo, bopambola Nzambe na biso !
\q2 Bosala ete lokito ya masanzoli na Ye eyokana !
\q1 
\v 9 Asalaka ete totangama kati na bato ya bomoi.
\q2 Abatelaki makolo na biso mpo ete tokweya te.
\q1 
\v 10 Pamba te, Nzambe, omekaki biso,
\q2 olekisaki biso kati na moto
\q2 ndenge basalaka mpo na palata.
\q1 
\v 11 Okangaki biso kati na motambo ;
\q2 otiaki mikumba ya kilo, na baloketo na biso.
\q1 
\v 12 Otikaki moto komatela biso na moto.
\q2 Tolekaki kati na moto mpe kati na mayi,
\q2 mpe obimisaki biso kati na yango mpo na komema biso na bofuluki.
\b
\q1 
\v 13 Nakokota kati na Ndako na Yo,
\q2 nakomemela Yo makabo ya kotumba,
\q2 nakokokisa bandayi na ngai epai na Yo.
\q1 
\v 14 Bandayi oyo bibebu na ngai moko etatolaki
\q2 mpe monoko na ngai elobaki na tango nazalaki kati na pasi.
\q1 
\v 15 Lokola bambeka ya kotumba, nakobonzela Yo
\q2 banyama minene, bameme elongo na bambeka ya malasi ;
\q2 nakobonzela Yo bangombe mpe bantaba ya mibali.
\b
\q1 
\v 16 Bino nyonso oyo botosaka Nzambe, boya koyoka !
\q2 Nakoyebisa bino makambo oyo asali mpo na bomoi na ngai.
\q1 
\v 17 Nabelelaki Ye na monoko na ngai,
\q2 mpe lolemo na ngai ekumisaki Ye.
\q1 
\v 18 Soki nazalaki na masumu kati na motema na ngai,
\q2 Nkolo alingaki koyoka ngai te.
\q1 
\v 19 Nzokande, Nzambe ayokaki ngai,
\q2 ayokaki na bokebi libondeli na ngai.
\q1 
\v 20 Tika ete Nzambe akumisama !
\q2 Aboyaki te koyoka libondeli na ngai
\q2 mpe kotalisa ngai bolingo na Ye.
\c 67
\cl Nzembo 67
\s1 Tika ete bikolo nyonso ekumisa Nzambe
\d 
\v 1 Wuta na buku ya mokambi ya bayembi : nzembo ya koyemba na lindanda. Loyembo.
\q1 
\v 2 Tika ete Nzambe asalela biso ngolu
\q2 mpe apambola biso,
\q2 tika ete angengisela biso elongi na Ye ;
\q1 
\v 3 mpo ete toyeba nzela na Yo kati na mokili,
\q2 mpe lobiko na Yo kati na bikolo nyonso.
\b
\q1 
\v 4 Oh Nzambe, tika ete bikolo ekumisa Yo ;
\q2 tika ete bikolo nyonso ekumisa Yo !
\q1 
\v 5 Tika ete bato basepela,
\q2 tika ete babeta milolo ya esengo,
\q1 pamba te okambaka bikolo na bosembo,
\q2 mpe otambolisaka bato awa na mabele.
\q1 
\v 6 Oh Nzambe, tika ete bikolo ekumisa Yo ;
\q2 tika ete bikolo nyonso ekumisa Yo !
\b
\q1 
\v 7 Mabele eboti bambuma na yango ;
\q2 tika ete Nzambe, Nzambe na biso, apambola biso.
\q1 
\v 8 Tika ete Nzambe apambola biso ;
\q2 tika ete mokili mobimba etosa Ye !
\c 68
\cl Nzembo 68
\s1 Elonga ya Nzambe
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi. Loyembo.
\q1 
\v 2 Soki Nzambe atelemi, banguna na Ye bapalanganaka,
\q2 mpe bayini na Ye bakimaka mosika na Ye.
\q1 
\v 3 Liboso ya Nzambe, bato mabe bakufaka,
\q2 ndenge milinga elimwaka,
\q2 mpe mafuta enyangwamaka na moto.
\q1 
\v 4 Liboso ya Nzambe, bato ya sembo basepelaka,
\q2 batondaka na esengo.
\b
\q1 
\v 5 Boyembela Nzambe, boyemba banzembo
\q2 mpo na lokumu ya Kombo na Ye.
\q1 Bofungola nzela mpo na Ye
\q2 oyo atambolisaka mampinga na Ye kati na esobe.
\q1 Kombo na Ye ezali Yawe.
\q2 Botonda na esengo liboso na Ye.
\q1 
\v 6 Kati na Ndako na Ye ya bule, Nzambe azali Tata ya bana bitike,
\q2 mpe molobeli ya basi bakufisa mibali.
\q1 
\v 7 Nzambe apesaka libota epai ya bato
\q2 oyo bavandaka bango moko,
\q1 abimisaka bakangami wuta na minyololo ;
\q2 kasi batomboki batikalaka na mabele ekawuka.
\q1 
\v 8 Oh Nzambe, tango obimaki liboso ya bato na Yo,
\q2 tango otambolaki na esobe,
\q1 
\v 9 mabele eninganaki, likolo mpe esopaki mayi
\q2 liboso ya Nzambe, Nzambe ya Sinai ;
\q2 liboso ya Nzambe, Nzambe ya Isalaele.
\q1 
\v 10 Nzambe, osopaki mvula ya mapamboli,
\q2 olendisaki libula na Yo mpo ete elembaki.
\q1 
\v 11 Oh Nzambe, bato na Yo bavandaka na mokili oyo obongisaki,
\q2 na boboto na Yo, mpo na mobola.
\b
\q1 
\v 12 Na liloba moko kowuta na Nkolo,
\q2 basi oyo bamemaka sango basangani bato ebele,
\q1 
\v 13 bakonzi ya mampinga bakimi, bapoti mbangu,
\q2 mpe mwasi oyo atikali na ndako akaboli bomengo ya bitumba.
\q1 
\v 14 Boni, bokokoba kolala pongi kati na bandako na bino ?
\q2 Mapapu ya ebenga ezipami na se ya palata,
\q2 mpe bansala na yango ezipami na se ya wolo.
\q1 
\v 15 Tango Nkolo-Na-Nguya-Nyonso abenganaki kuna bakonzi,
\q2 anokisaki mvula ya pembe na ngomba Tsalimoni.
\b
\q1 
\v 16 Ngomba ya Bashani, ngomba ya Nzambe ;
\q2 ngomba ya Bashani, ngomba ya basonge ebele,
\q1 
\v 17 mpo na nini ozali kosala zuwa,
\q2 ngomba ya basonge ebele,
\q1 ngomba oyo Nzambe asepelaka kovanda ?
\q2 Nzokande Yawe akovanda kuna libela na libela.
\q1 
\v 18 Motango ya bashar ya Nzambe ezali ebele,
\q2 koleka minkoko ;
\q1 Nkolo azali kati na yango,
\q2 kuna na Sinai, kati na Esika ya bule.
\q1 
\v 19 Yawe Nzambe, tango omataki na likolo,
\q2 omemaki bakangami,
\q2 ozwaki makabo epai ya bato,
\q1 ata epai ya batomboki,
\q2 mpo ete okoma kovanda kuna.
\b
\q1 
\v 20 Tika ete Nkolo akumisama, mokolo na mokolo !
\q2 Nzambe Mobikisi na biso alataka makambo na biso.
\q1 
\v 21 Mpo na biso, Nzambe yango azali Nzambe oyo abikisaka ;
\q2 mpe bikuke ya kufa ezali ya Nkolo Yawe.
\q1 
\v 22 Solo, Nzambe apanzaka mito ya banguna na Ye,
\q2 oyo batambolaka kati na bomoi ya masumu,
\q2 oyo mito na bango etonda na suki.
\q1 
\v 23 Nkolo alobi :
\q2 « Wuta na Bashani, nakomema bango ;
\q1 wuta na mozindo ya ebale monene,
\q2 nakomema bango,
\q1 
\v 24 mpo ete opanza lokolo na yo kati na makila,
\q2 mpe mpo ete lolemo ya bambwa na yo ezwa eteni na yango. »
\b
\q1 
\v 25 Oh Nzambe, bazali komona ndenge ozali koya ;
\q2 koya ya Nzambe na ngai, ya Mokonzi na ngai, kati na Esika ya bule.
\q1 
\v 26 Bayembi bazali liboso ;
\q2 sima na bango, bato oyo bazali kobeta
\q1 mandanda ya basinga kati na bilenge basi
\q2 oyo bazali kobeta bambonda ya mike.
\q1 
\v 27 Bopambola Nzambe kati na mayangani,
\q2 bopambola Yawe wuta na etima ya Isalaele.
\q1 
\v 28 Kuna, Benjame, leki ya suka,
\q2 azali kotambolisa bakambi ya Yuda
\q1 elongo na mampinga na bango,
\q2 bakambi ya Zabuloni mpe ya Nefitali.
\b
\q1 
\v 29 Nzambe na yo apesi mitindo epai ya makasi na yo ; zala makasi.
\q2 Nzambe, osaleli biso penza makambo.
\q1 
\v 30 Wuta na Tempelo na Yo ya Yelusalemi
\q2 epai wapi bakonzi bamemelaka Yo makabo,
\q1 
\v 31 bengana ngando oyo ebombami kati na matiti,
\q2 lisanga ya bangombe ya mibali elongo na bana ngombe ya bikolo
\q1 oyo batambolaka kati na mbongo
\q2 ya bibende ya palata, mpe panza bikolo oyo basepelaka na bitumba.
\q1 
\v 32 Bazwi bakobimela na Ejipito ;
\q2 bato ya Kushi bakoya na lombangu,
\q2 bakotombola maboko epai ya Nzambe.
\b
\q1 
\v 33 Bino, babokonzi ya mabele, boyembela Nzambe ;
\q2 boyemba banzembo mpo na lokumu ya Nkolo !
\q1 
\v 34 Boyembela Ye oyo atambolisaka
\q2 mampinga kati na likolo, likolo ya libela ;
\q2 oyo, wuta na mongongo na Ye, agangaka makasi.
\q1 
\v 35 Bosakola ete nguya ezali ya Nzambe
\q2 oyo nkembo na Ye ezali na Isalaele,
\q2 mpe nguya na Ye ezali kati na mapata.
\q1 
\v 36 Nzambe, wuta kati na bisika na Yo ya bule,
\q2 obongi na botosi !
\q1 Nzambe ya Isalaele apesaka na bato na Ye
\q2 makasi mpe nguya.
\b
\q1 Tika ete Nzambe akumisama !
\c 69
\cl Nzembo 69
\s1 Nazindi, bikisa ngai
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi : ezali ya koyemba lokola « lisi. »
\q1 
\v 2 Nzambe, bikisa ngai,
\q2 pamba te mayi ekomi na kingo na ngai.
\q1 
\v 3 Nazali kozinda na potopoto, na mozindo makasi
\q2 epai wapi eloko ya kosimba ezali te ;
\q1 nakiti na mozindo ya mayi,
\q2 mbonge ememi ngai.
\q1 
\v 4 Nalembi nzoto likolo ya kobelela lisungi ;
\q2 mongongo na ngai ekawuki,
\q1 miso na ngai elembi
\q2 mpo na kotalela Nzambe na ngai.
\q1 
\v 5 Bato oyo bayinaka ngai na kozanga tina
\q2 bazali ebele koleka motango ya suki ya moto na ngai ;
\q1 ba-oyo balukaka kobebisa bomoi na ngai,
\q2 oyo bazali banguna na ngai kaka pamba,
\q1 bazali bato na nguya ;
\q2 bazali kosenga ngai na makasi ete nazongisa eloko oyo nayibaki te.
\b
\q1 
\v 6 Nzambe, oyebi bozoba na ngai,
\q2 mpe mabe na ngai ezali ya kobombama te na miso na Yo.
\b
\q1 
\v 7 Nkolo Yawe, Mokonzi ya mampinga,
\q2 tika ete ba-oyo batiaka elikya kati na Yo
\q2 basila lokumu te likolo na ngai !
\q1 Nzambe ya Isalaele,
\q2 tika ete bato oyo balukaka Yo
\q2 bayokisama soni te likolo na ngai !
\q1 
\v 8 Pamba te nandimi kofingama mpo na Yo,
\q2 mpe soni ezipi ngai elongi.
\q1 
\v 9 Bandeko na ngai bakomi kozwa ngai lokola moto oyo bayebi te,
\q2 nakomi lokola mopaya na miso ya bana ya mama na ngai.
\q1 
\v 10 Pamba te bolingo oyo nazali na yango
\q2 mpo na ndako na Yo ezali kozikisa ngai,
\q1 mpe mafinga ya bato oyo bafingaka Yo
\q2 ezali kokweya na moto na ngai.
\q1 
\v 11 Soki naleli mpe nakili bilei,
\q2 nasengeli kaka kofingama ;
\q1 
\v 12 soki nalati saki,
\q2 bato basalaka masapo mpo na kotiola ngai.
\q1 
\v 13 Bato oyo bavandi na ekuke batiolaka ngai,
\q2 balangwi masanga bayembaka kombo na ngai
\q2 kati na banzembo na bango.
\b
\q1 
\v 14 Yawe, nabondeli Yo !
\q2 Nzambe, tango ekoki,
\q1 tango ya kotalisa ngai bolingo monene na Yo !
\q2 Yanola ngai na nzela ya boyengebene mpe lobiko na Yo !
\q1 
\v 15 Bimisa ngai na potopoto,
\q2 sala ete nazinda lisusu te,
\q1 nakangolama wuta na maboko ya bayini na ngai
\q2 mpe nabima na mayi ya mozindo !
\q1 
\v 16 Tika ete mbonge ya mayi emema ngai lisusu te,
\q2 mozindo emela lisusu ngai te,
\q2 mpe libulu ekangamela ngai te !
\b
\q1 
\v 17 Yawe, yanola ngai, pamba te bolingo na Yo ezali malamu ;
\q2 baluka epai na ngai, na mawa monene na Yo.
\q1 
\v 18 Kobombela lisusu mosali na Yo te elongi na Yo.
\q2 Yanola ngai noki, pamba te nazali na pasi.
\q1 
\v 19 Pusana pene na ngai, mpe sikola ngai ;
\q2 kangola ngai wuta na maboko ya bayini na ngai.
\b
\q1 
\v 20 Oyebi ndenge nini nazali kofingama,
\q2 oyebi soni mpe kosambwa na ngai ;
\q2 banguna na ngai nyonso bazali liboso na Yo.
\q1 
\v 21 Mafinga ezokisi motema na ngai,
\q2 mpe pota yango ezali kosila te ;
\q1 nazelaki elembo ya mawa kowuta na bato,
\q2 kasi namonaki yango te ;
\q2 nalukaki babondisi, kasi namonaki bango te.
\q1 
\v 22 Batiaki ngenge kati na bilei na ngai,
\q2 mpe bamelisaki ngai vino ya ngayi
\q2 tango nayokaki posa ya mayi.
\b
\q1 
\v 23 Tika ete mesa na bango ekoma motambo liboso na bango,
\q2 mpe kimia na bango ekoma monyama.
\q1 
\v 24 Tika ete miso na bango ekufa mpo ete bamona lisusu te,
\q2 mpe babela mikongo mpo na libela.
\q1 
\v 25 Sopela bango kanda makasi na Yo,
\q2 mpe tika ete kanda na Yo ya makasi ekanga bango.
\q1 
\v 26 Tika ete molako na bango etikala polele,
\q2 mpe ete moto moko te avanda na bandako na bango ya kapo.
\q1 
\v 27 Pamba te bazali konyokola bato oyo ozokisaki,
\q2 mpe bazali kopanza sango ya pasi ya bato oyo oyokisaki pasi.
\q1 
\v 28 Bakisa mabe na likolo ya mabe na bango,
\q2 mpe kokota likambo na bango te na bosembo na Yo.
\q1 
\v 29 Tika ete bakombo na bango elongwa na buku ya bomoi,
\q2 mpe batangama te na molongo ya bato ya sembo.
\b
\q1 
\v 30 Solo, nazali mobola mpe moto ya pasi ;
\q2 kasi lobiko na Yo, oh Nzambe, ebatelaka ngai.
\b
\q1 
\v 31 Nakoyemba mpo na lokumu ya Kombo ya Nzambe,
\q2 mpe nakopesa Ye nkembo elongo na matondi.
\q1 
\v 32 Yango nde ekosepelisa Yawe,
\q2 koleka ngombe oyo ezali na maseke
\q2 mpe na makolo ekabwana.
\q1 
\v 33 Babola bamoni mpe bazali kosepela.
\q2 Tika ete mitema na bino oyo bolukaka Nzambe ezala na bomoi !
\q1 
\v 34 Pamba te Yawe ayokaka bato oyo bakelela,
\q2 mpe atiolaka bato na Ye te ata bazali bakangami kati na boloko.
\b
\q1 
\v 35 Tika ete likolo mpe mabele,
\q2 bibale minene mpe nyonso oyo ezali kati na yango ekumisa Ye !
\q1 
\v 36 Pamba te Nzambe akobikisa Siona
\q2 mpe akotonga lisusu bingumba ya Yuda.
\q1 Bato bakovanda kuna
\q2 mpe bakozwa yango lokola libula na bango.
\q1 
\v 37 Bakitani ya basali na Ye bakozwa
\q2 yango lokola libula,
\q1 mpe bato oyo balingaka Kombo na Ye
\q2 bakovanda kati na yango.
\c 70
\cl Nzembo 70
\s1 Nzambe, yaka kosunga ngai
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi mpo na kokanisa misala ya Nzambe.
\q1 
\v 2 Nzambe, yaka noki mpo na kangola ngai !
\q2 Yawe, yaka noki mpo na kosunga ngai !
\q1 
\v 3 Tika ete bato oyo balukaka kufa na ngai
\q2 bakufa soni mpe basambwa !
\q1 Tika ete bato oyo bazelaka libebi na ngai
\q2 bazonga sima mpe bayokisama soni !
\q1 
\v 4 Tika ete bato oyo balobaka na ngai :
\q2 « Ah ! Ah ! » bazonga mpo na soni !
\q1 
\v 5 Tika ete bato nyonso oyo balukaka Yo
\q2 batonda na esengo mpe basepela kati na Yo !
\q1 Tika ete ba-oyo balingaka lobiko na Yo
\q2 balobaka tango nyonso :
\q2 « Nzambe azali monene ! »
\b
\q1 
\v 6 Mpo ete nazali mobola mpe moto akelela,
\q2 Nzambe, yaka noki mpo na kosunga ngai.
\q1 Yawe, ozali Lisungi mpe Mokangoli na ngai,
\q2 kowumela te !
\c 71
\cl Nzambe 71
\s1 Na kimobange na ngai, kosundola ngai te
\q1 
\v 1 Yawe, ozali ebombamelo na ngai ;
\q2 kondima te ete nayoka soni !
\q1 
\v 2 Na bosembo na Yo, kangola mpe bikisa ngai.
\q2 Yoka ngai mpe bikisa ngai.
\q1 
\v 3 Zala mpo na ngai ekimelo ya libanga
\q2 epai wapi nakoki kokende tango nyonso.
\q1 Ozwaki mokano ya kobikisa ngai,
\q2 pamba te ozali libanga mpe ndako na ngai batonga makasi.
\q1 
\v 4 Nzambe na ngai, kangola ngai wuta na maboko ya bato mabe,
\q2 na maboko ya batomboki mpe bato na kanza.
\q1 
\v 5 Nkolo Yawe, ozali elikya na ngai ;
\q2 wuta bolenge na ngai, namipesaka na Yo.
\q1 
\v 6 Wuta mbotama na ngai, natalelaka Yo ;
\q2 Yo nde obimisaki ngai na libumu ya mama na ngai.
\q2 Nakokumisa Yo tango nyonso.
\q1 
\v 7 Nazali likamwisi mpo na bato ebele ;
\q2 ozali ebombamelo na ngai ya makasi.
\q1 
\v 8 Tika ete monoko na ngai etonda
\q2 na masanzoli mpo na lokumu na Yo ;
\q1 tika ete etatolaka tango nyonso
\q2 kongenga ya nkembo na Yo.
\b
\q1 
\v 9 Kobwaka ngai te awa nakomi mobange,
\q2 kotika ngai te awa makasi na ngai ekomi kosila.
\q1 
\v 10 Pamba te banguna na ngai bazali koloba mabe
\q2 na tina na ngai,
\q1 mpe bato oyo balukaka koboma ngai
\q2 basaleli ngai likita.
\q1 
\v 11 Bazali koloba : « Nzambe asundoli ye ;
\q2 bolanda ye, bokanga ye ;
\q2 moto oyo akokangola ye azali te ! »
\q1 
\v 12 Oh Nzambe, kozala mosika na ngai te !
\q2 Nzambe na ngai, yaka noki mpo na kosunga ngai.
\q1 
\v 13 Tika ete bato oyo bafundaka ngai bakufa soni mpe balimwa !
\q2 Tika ete ba-oyo balukaka pasi na ngai
\q2 basambwa mpe bayokisama soni !
\b
\q1 
\v 14 Kasi ngai, nakozala na elikya tango nyonso
\q2 mpe nakokoba kokumisa Yo.
\b
\q1 
\v 15 Monoko na ngai ekosakola tango nyonso
\q2 misala ya bosembo mpe ya lobiko na Yo,
\q2 pamba te nayebi motango na yango te.
\q1 
\v 16 Nkolo Yawe, nakoya epai na Yo
\q2 mpe nakotatola misala na Yo ya nguya ;
\q1 nakotatola misala malamu ya bosembo na Yo,
\q2 misala ya bosembo na Yo kaka.
\q1 
\v 17 Nzambe, wuta bolenge na ngai, oteya ngai ;
\q2 mpe kino lelo, nazali kotatola bikamwa na Yo.
\q1 
\v 18 Ezala ndenge nakomi sik’oyo mobange
\q2 mpe suki na ngai ekomi pembe,
\q1 oh Nzambe na ngai, kotika ngai te,
\q2 mpo ete natatola makasi na Yo
\q1 epai ya bato ya ekeke oyo,
\q2 mpe misala ya nguya na Yo
\q2 epai ya bato nyonso oyo bakoya sima.
\q1 
\v 19 Nzambe, bosembo na Yo ekenda kino na likolo,
\q2 pamba te osalaka makambo minene.
\q2 Oh Nzambe, nani akokani na Yo ?
\q1 
\v 20 Atako osalaki ete tokutana na pasi mingi mpe na makambo ya bololo,
\q2 kasi okotika lisusu biso kozala na bomoi,
\q2 okobimisa ngai lisusu wuta na mozindo ya mabele.
\q1 
\v 21 Okomatisa lisusu lokumu na ngai,
\q2 mpe okobondisa ngai lisusu.
\b
\q1 
\v 22 Nzambe na ngai, nakosanzola Yo
\q2 na lindanda mpo na boyengebene na Yo ;
\q1 Mosantu ya Isalaele, nakobeta lindanda
\q2 mpo na lokumu na Yo.
\q1 
\v 23 Nakoganga na esengo tango nakoyemba
\q2 banzembo mpo na lokumu na Yo,
\q2 pamba te okangoli bomoi na ngai.
\q1 
\v 24 Lolemo na ngai ekotatola tango nyonso
\q2 misala ya bosembo na Yo,
\q1 pamba te bato oyo balukaka pasi na ngai
\q2 bayokisami soni mpe basambwe.
\c 72
\cl Nzembo 72
\s1 Libondeli mpo na mokonzi
\d 
\v 1 Nzembo ya Salomo.
\q1 Oh Nzambe, pesa na mokonzi mayele na Yo ;
\q2 mpe na mwana ya mokonzi, bosembo na Yo !
\q1 
\v 2 Tika ete asambisa bato na Yo na bosembo ;
\q2 mpe babola na Yo, kolanda boyengebene.
\b
\q1 
\v 3 Bangomba milayi ekomemela bato kimia ;
\q2 mpe bangomba mike, bosembo.
\q1 
\v 4 Akokota likambo ya babola kati na bato,
\q2 akobikisa bana ya moto akelela
\q2 mpe akobebisa monyokoli.
\b
\q1 
\v 5 Bongo bakotosa Yo tango nyonso moyi ekongala,
\q2 tango nyonso sanza ekongenga,
\q2 na bikeke nyonso.
\b
\q1 
\v 6 Tika ete azala lokola mvula oyo ezali konoka
\q2 na bilanga oyo balongoli matiti,
\q2 lokola mamwe oyo ezali kopolisa mabele.
\q1 
\v 7 Na tango na ye, moto ya sembo akokende liboso,
\q2 mpe kimia ekofuluka
\q2 kino sanza ekongenga lisusu te.
\b
\q1 
\v 8 Tika ete akonza longwa na ebale moko ya monene
\q2 kino na ebale mosusu ya monene,
\q2 longwa na ebale Efrate kino na suka ya mokili.
\q1 
\v 9 Bavandi ya esobe bakofukama liboso na ye,
\q2 mpe banguna na ye bakolembola putulu.
\q1 
\v 10 Bakonzi ya Tarsisi mpe ya bisanga
\q2 bakomemela ye mpako ya mokonzi,
\q2 bakonzi ya Saba mpe ya Seba bakopesa ye makabo.
\q1 
\v 11 Bakonzi nyonso bakofukama liboso na ye,
\q2 mpe bikolo nyonso ekosalela ye.
\b
\q1 
\v 12 Pamba te akokangola moto akelela
\q2 oyo azali koganga mpo na kosenga lisungi,
\q2 mpe mobola oyo azangi mosungi.
\q1 
\v 13 Akoyokela mobola mpe moto akelela mawa,
\q2 mpe akobikisa moto akelela na kufa ;
\q1 
\v 14 akosikola bango na minyoko
\q2 mpe na makambo na kanza,
\q1 pamba te bomoi na bango ezali motuya
\q2 na miso na ye.
\b
\q1 
\v 15 Akozala na bomoi,
\q2 bakopesa ye wolo ya Saba.
\q1 Bakobanda kosambela mpo na ye tango nyonso
\q2 mpe kopambola ye mikolo nyonso.
\b
\q1 
\v 16 Tika ete ble etonda kati na mokili,
\q2 mbuma na yango ebota ebele na likolo ya bangomba lokola Libani !
\q1 Wuta na engumba, bato bakozala na bofuluki
\q2 lokola matiti ya elanga.
\q1 
\v 17 Tika ete kombo na ye ewumela libela na libela,
\q2 ewumela tango nyonso moyi ekozala,
\q1 mpo ete bato bakoma kotangaka kombo na ye
\q2 wana bakobanda kopambolanaka,
\q1 mpe bikolo nyonso ekoma kobengaka ye :
\q2 moto ya esengo.
\b
\b
\q1 
\v 18 Tika ete Yawe Nzambe
\q2 oyo asalaka Ye moko bikamwa,
\q2 Nzambe ya Isalaele, apambolama !
\q1 
\v 19 Tika ete Kombo na Ye ya nkembo
\q2 epambolama libela na libela !
\q1 Tika ete mokili mobimba etonda na nkembo na Ye !
\q2 Amen ! Amen !
\d 
\v 20 Mabondeli ya Davidi, mwana mobali ya Izayi, esuki awa.
\c 73
\ms1 Buku ya misato
\mr Nz 73.1–89.53
\cl Nzembo 73
\s1 Mpo na nini bato mabe bakendaka liboso ?
\d 
\v 1 Nzembo ya Azafi.
\q1 Solo, Nzambe azali malamu mpo na Isalaele,
\q2 mpo na bato oyo bazali mitema peto.
\b
\q1 
\v 2 Nzokande mpo na ngai,
\q2 etikalaki moke ete makolo na ngai eselumuka,
\q2 etikalaki moke ete nakweya,
\q1 
\v 3 pamba te nazalaki kolula bato ya lofundu
\q2 tango nazalaki komona kimia ya bato mabe.
\b
\q1 
\v 4 Kino na kufa na bango,
\q2 bazalaka na mitungisi te,
\q2 nzoto na bango ezalaka sembesembe.
\q1 
\v 5 Kati na bango, moko te amonaka pasi
\q2 oyo bato nyonso bamonaka ;
\q2 babelaka te bokono oyo ezwaka bato.
\q1 
\v 6 Yango wana, lolendo ekoma
\q2 lokola mayaka na bakingo na bango,
\q1 mpe makambo na kanza ekoma
\q2 lokola elamba na bango.
\q1 
\v 7 Miso na bango engengaka
\q2 na bilongi etonda na mafuta ;
\q1 mitema na bango esalaka kaka
\q2 mabongisi ya mabe ;
\q1 
\v 8 batiolaka mpe balobaka mabe,
\q2 bagangelaka minyoko.
\q1 
\v 9 Minoko na bango etombokelaka Likolo,
\q2 mpe lolemo na bango esakanelaka mokili.
\b
\q1 
\v 10 Yango wana bato balandaka bango
\q2 mpe bamelaka maloba na bango lokola mayi.
\q1 
\v 11 Balobaka : « Nzambe akoyeba ndenge nini ?
\q2 Ye-Oyo-Aleki-Likolo azali ata na boyebi ? »
\b
\q1 
\v 12 Tala ndenge bato mabe bazalaka :
\q2 tango nyonso, bazalaka na mitungisi te,
\q2 mpe bomengo na bango emataka se komata.
\b
\q1 
\v 13 Solo, ezali kaka na pamba nde
\q2 nabatelaki motema na ngai peto ;
\q1 ezali kaka na pamba nde
\q2 nasukolaki maboko na ngai
\q2 mpo ete nasala mabe te !
\q1 
\v 14 Mikolo nyonso, nanyokwamaka ;
\q2 mpe tongo nyonso, nazwaka etumbu.
\b
\q1 
\v 15 Soki nalobi : « Nakoloba lokola bango, »
\q2 wana nateki penza lokumu ya libota na Yo.
\b
\q1 
\v 16 Tango nakanisaki mpo na koluka kososola,
\q2 nayokaki pasi na motema
\q1 
\v 17 kino nakendeki na Esika ya bule ya Nzambe
\q2 mpe nasosolaki ndenge nini bakosuka.
\b
\q1 
\v 18 Solo, otielaka bango biloko ya moselu,
\q2 okweyisaka bango kati na libebi.
\q1 
\v 19 Ndenge nini babebisamaka mbala moko,
\q2 bakomaka na suka,
\q2 mpe somo elimwisaka bango !
\q1 
\v 20 Ndenge ndoto elimwaka
\q2 soki moto alamuki na pongi,
\q1 Nkolo, olimwisaka lisolo ya bomoi na bango
\q2 tango kaka otelemaka.
\b
\q1 
\v 21 Tango motema na ngai ezalaki kotomboka
\q2 mpe molimo na ngai emitungisaki,
\q1 
\v 22 nasilaki mayele, nakomaki lokola zoba,
\q2 nakomaki lokola nyama liboso na Yo.
\b
\q1 
\v 23 Nzokande, nazalaka tango nyonso elongo na Yo ;
\q2 osimba ngai na loboko na ngai ya mobali.
\q1 
\v 24 Otambolisaka ngai na nzela ya toli na Yo,
\q2 mpe, na sima, okoyamba ngai kati na nkembo.
\q1 
\v 25 Kuna na Likolo, nani azali mpo na ngai
\q2 soki Yo te ?
\q1 Mpe awa na mokili, nasepela na nani
\q2 soki na Yo te ?
\q1 
\v 26 Nzoto na ngai ekoki kobeba,
\q2 mpe motema na ngai ekoki kolemba ;
\q1 kasi Nzambe azali Libanga
\q2 mpe libula na ngai mpo na tango nyonso.
\b
\q1 
\v 27 Bato nyonso oyo bazali mosika na Yo bakokufa ;
\q2 obebisaka bato nyonso oyo batosaka Yo te.
\q1 
\v 28 Kasi mpo na ngai, ezali malamu
\q2 kozala pene ya Nzambe.
\q1 Nakomisi Nkolo Yawe ebombamelo na ngai,
\q2 mpo na kopanza sango ya misala na Yo nyonso.
\c 74
\cl Nzembo 74
\s1 Bileli mpo na kobebisama ya Tempelo
\d 
\v 1 Nzembo ya Azafi.
\q1 Oh Nzambe, mpo na nini kosundola biso
\q2 mpo na tango nyonso ?
\q1 Mpo na nini kongalisa kanda na Yo
\q2 likolo ya etonga oyo oleisaka ?
\q1 
\v 2 Kanisa lisusu lisanga ya bato na Yo,
\q2 oyo osikola wuta kala,
\q1 libota oyo okomisa libula na Yo.
\q2 Kanisa ngomba Siona epai wapi ovandaka.
\q1 
\v 3 Tika ete matambe na Yo ekoma
\q2 kino na bisika oyo ebebi nye !
\q1 Kati na Esika na Yo ya bule,
\q2 monguna abebisi nyonso ;
\q1 
\v 4 bayini na Yo bagangi lokola nkosi,
\q2 ata kati na esika oyo okutanaka na biso,
\q2 batelemisi bendele na bango lokola elembo.
\q1 
\v 5 Bazali lokola bato oyo basimbi bipasola
\q2 mpe bazali kokata banzete kati na zamba.
\q1 
\v 6 Babuki-buki bililingi nyonso
\q2 oyo batobola na mabaya,
\q2 na nzela ya bipasola mpe bamarto na bango ;
\q1 
\v 7 batumbi Esika na Yo ya bule,
\q2 bakweyisi mpe bakomisi mbindo
\q2 esika oyo Kombo na Yo evandaka.
\q1 
\v 8 Bazalaki komilobela :
\q2 « Tokopanza yango nyonso ! »
\q1 Kati na mokili, bazikisi esika nyonso
\q2 epai wapi bagumbamelaka Nzambe.
\q1 
\v 9 Tozali lisusu komona te bilembo na biso,
\q2 basakoli bazali lisusu te ;
\q1 mpe moko te kati na biso ayebi tango boni
\q2 makambo oyo ekowumela.
\q1 
\v 10 Oh Nzambe, kino tango nini
\q2 monguna akofinga Yo ?
\q1 Boni, akokoba tango nyonso
\q2 kotiola Kombo na Yo ?
\q1 
\v 11 Mpo na nini ozongisi loboko na Yo na sima,
\q2 loboko na Yo ya mobali ?
\q2 Mpo na nini okangi maboko na Yo ?
\b
\q1 
\v 12 Nzokande, Yo Nzambe,
\q2 ozali Mokonzi na ngai wuta kala ;
\q2 Yo nde omemaka lobiko kati na mokili.
\q1 
\v 13 Yo nde opasolaki ebale na nguya na Yo,
\q2 opanzaki mito ya bilima ya mayi ;
\q1 
\v 14 Yo nde opanzaki mito ya Leviatani
\q2 mpe opesaki yango lokola bilei
\q2 epai ya banyama ya esobe ;
\q1 
\v 15 Yo nde osalaki ete bitima ya mayi
\q2 mpe miluka etiola,
\q2 mpe okawusaki bibale mpo na libela.
\q1 
\v 16 Moyi ezali ya Yo, butu mpe ezali ya Yo ;
\q2 Yo nde osalaki sanza mpe moyi.
\q1 
\v 17 Ezali Yo nde otiaki bandelo nyonso ya mokili,
\q2 Yo nde osalaki tango ya malili
\q2 mpe tango ya moyi.
\b
\q1 
\v 18 Yawe, kobosana te ete monguna afingi Yo,
\q2 ete bato bazanga tina batioli Kombo na Yo !
\q1 
\v 19 Kokaba te bomoi ya ebenga na Yo
\q2 na monoko ya nyama oyo ezali na nzala,
\q1 kobosana te mpo na libela bomoi ya babola
\q2 oyo bazali bato na Yo !
\b
\q1 
\v 20 Tala lisusu Boyokani na Yo !
\q2 Pamba te, kati na mokili,
\q1 bisika ya molili ekomi ebele,
\q2 etondi na makambo na kanza.
\q1 
\v 21 Sala ete moto oyo bazali konyokola
\q2 azwa lisusu lokumu !
\q1 Sala ete mobola mpe moto akelela
\q2 bakumisa Kombo na Yo.
\b
\q1 
\v 22 Oh Nzambe, telema mpe lobela Kombo na Yo !
\q2 Kanisa lisusu ndenge nini bazoba bafingaka Yo
\q2 mikolo nyonso !
\q1 
\v 23 Kobosana te makelele ya bayini na Yo,
\q2 mangungu ya banguna na Yo,
\q2 oyo ezali kaka komata se komata !
\c 75
\cl Nzembo 75
\s1 Nzambe akosambisa mokili
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya koyemba lokola « Koboma te ! » Nzembo ya Azafi.
\q1 
\v 2 Nzambe, tozali kosanzola Yo,
\q2 tozali kosanzola Kombo na Yo ;
\q1 mpo ete Kombo na Yo ezali pene,
\q2 bato bazali kotatola bikamwa na Yo.
\b
\q1 
\v 3 Olobaki :
\q2 « Na tango oyo ngai moko nakobongisa,
\q2 nakokata makambo na bosembo.
\q1 
\v 4 Mokili ekoki kolenga
\q2 elongo na bavandi na yango nyonso,
\q1 kasi ezali ngai nde nalendisaka
\q2 makonzi na yango. »
\b
\q1 
\v 5 Nazali koloba na moto ya lofundu :
\q2 « Kotombola lisusu mapeka te ; »
\q1 mpe na bato mabe :
\q2 « Bosala lisusu lolendo te.
\q1 
\v 6 Bomeka lisusu te kosala lofundu
\q2 mpe koloba na lolendo. »
\b
\q1 
\v 7 Botombwami ewutaka na Este te, na Weste te,
\q2 ewutaka mpe na esobe te.
\q1 
\v 8 Pamba te ezali Nzambe nde akataka makambo :
\q2 akitisaka moto songolo
\q2 mpe atombolaka moto pakala.
\b
\q1 
\v 9 Loboko na Yawe esimbi kopo
\q2 oyo etondi na vino ya makasi mpe ya bololo.
\q1 Azali kosopa yango,
\q2 mpe bato mabe nyonso ya mokili
\q1 bazali komeka mpe komela yango
\q2 kino na mbindo oyo etikalaka na se ya kopo.
\b
\q1 
\v 10 Mpo na ngai, nakotatola makambo oyo
\q2 tango nyonso,
\q2 nakoyemba mpo na lokumu ya Nzambe ya Jakobi,
\q1 
\v 11 oyo azali koloba :
\q2 « Nakosilisa makasi nyonso ya bato mabe ;
\q1 kasi nguya ya bato ya sembo
\q2 ekomata lisusu makasi. »
\c 76
\cl Nzembo 76
\s1 Nzambe azali molongi
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Ezali ya koyemba na lindanda. Nzembo ya Azafi.
\q1 
\v 2 Nzambe ayebani kati na Yuda ;
\q2 Kombo na Ye ezali monene kati na Isalaele.
\q1 
\v 3 Ndako na Ye ya kapo ezali na Salemi ;
\q2 mpe esika na Ye ya kovanda ezali na Siona.
\b
\q1 
\v 4 Ezali kuna nde abukaki makonga ya makasi,
\q2 banguba, mipanga
\q2 mpe bibundeli nyonso ya bitumba.
\q1 
\v 5 Ozali kongenga lokola mwinda,
\q2 otonda na lokumu koleka bangomba
\q2 ya babotoli bomengo ya bitumba.
\b
\q1 
\v 6 Bilombe nyonso ya mpiko bakweyisamaki,
\q2 balalaki pongi na bango ya suka ;
\q2 basoda nyonso bakokaki lisusu te kotombola maboko.
\q1 
\v 7 Nzambe ya Jakobi, na kanda na Yo,
\q2 bato oyo babundaka likolo ya bampunda
\q2 elongo na bampunda bakweyi na somo.
\q1 
\v 8 Solo, ozali somo !
\q2 Nani akokoka kotelema liboso na Yo soki osiliki ?
\b
\q1 
\v 9 Wuta na likolo, osalaka ete mokano na Yo
\q2 eyokana na matoyi ya bato ;
\q2 mokili ekomaka na kobanga mpe evandaka kimia
\q1 
\v 10 tango, Yo Nzambe, otelemaka mpo na kosambisa
\q2 mpe kobikisa banyokolami nyonso ya mokili.
\q1 
\v 11 Pamba te kanda makasi ya bato esanzolaka Yo,
\q2 mpe olataka kanda ya batikali.
\b
\q1 
\v 12 Epai ya Yawe, Nzambe na bino,
\q2 bopesa bilaka mpe bokokisa yango.
\q1 Tika ete bato nyonso oyo bazingeli Ye
\q2 bamemela Nzambe ya somo makabo !
\q1 
\v 13 Abukaka lolendo ya bakambi,
\q2 mpe bakonzi ya mokili babangaka Ye.
\c 77
\cl Nzembo 77
\s1 Nzambe abongwani to te ?
\d 
\v 1 Wuta na buku ya mokambi ya bayembi, kolanda Yedutuni. Nzembo ya Azafi.
\q1 
\v 2 Nabelelaka Nzambe na koganga ;
\q2 nabelelaka Nzambe mpo ete ayoka ngai !
\q1 
\v 3 Tango nazalaka na pasi, nalukaka Nkolo ;
\q2 na butu, nalembaka te kotombola maboko na ngai
\q2 mpe naboyaka kobondisama.
\b
\q1 
\v 4 Nakanisaka Nzambe mpe nalelaka,
\q2 nakotaka na mozindo ya makanisi
\q2 mpe nalembaka nzoto.
\b
\q1 
\v 5 Opimelaka miso na ngai pongi,
\q2 namitungisaka mpe nayebaka lisusu te
\q2 eloko ya koloba.
\q1 
\v 6 Nakanisaka lisusu mikolo ya kala,
\q2 mibu nyonso oyo eleka ;
\q1 
\v 7 Na butu, nakanisaka lisusu banzembo na ngai ;
\q2 motema na ngai ezongelaka kokanisa,
\q2 mpe molimo na ngai ekomaka komituna :
\q1 
\v 8 « Boni, Nkolo akobwaka biso penza
\q2 mpo na libela ?
\q2 Akosalela biso lisusu bolamu te ?
\q1 
\v 9 Bolingo na Ye esili penza mpo na libela ?
\q2 Bilaka na Ye ekokokisama te mpo na libela ?
\q1 
\v 10 Nzambe abosani solo kosala ngolu ?
\q2 Akangi penza motema na Ye mpo na kanda ? »
\b
\q1 
\v 11 Mpe namilobelaka :
\q2 « Tala likambo oyo ezali kosala ngai pasi :
\q1 loboko ya mobali ya Ye-Oyo-Aleki-Likolo
\q2 ebongwani ! »
\q1 
\v 12 Nakanisaka misala minene ya Yawe,
\q2 bikamwa na Yo ya kala.
\q1 
\v 13 Nakanisaka nyonso oyo osalaki
\q2 kino na bikamwa na Yo.
\b
\q1 
\v 14 Oh Nzambe, banzela na Yo ezali bule ;
\q2 nzambe nini akokani na Yo na monene ?
\q1 
\v 15 Ozali Nzambe oyo asalaka bikamwa ;
\q2 olakisi nguya na Yo kati na bikolo.
\q1 
\v 16 Na nguya ya loboko na Yo,
\q2 okangolaki bato na Yo,
\q2 bakitani ya Jakobi mpe ya Jozefi.
\b
\q1 
\v 17 Oh Nzambe, mayi emonaki Yo !
\q2 Mayi emonaki Yo mpe ekomaki kolenga ;
\q2 ezala mozindo ya mayi eninganaki.
\q1 
\v 18 Mapata esopaki mayi ebele,
\q2 likolo eyokisaki lokito ya kake,
\q1 mpe makonga na Yo ezalaki koleka-leka
\q2 na bangambo nyonso.
\q1 
\v 19 Na lokito ya kake na Yo,
\q2 mikalikali engengisaki mokili,
\q2 mabele eninganaki mpe elengaki.
\q1 
\v 20 Opasolaki nzela kati na ebale monene,
\q2 balabala na Yo kati na mayi monene,
\q1 mpe moto moko te amonaki bilembo
\q2 ya matambe na Yo.
\q1 
\v 21 Otambolisaki bato na Yo lokola etonga,
\q2 na loboko ya Moyize mpe ya Aron.
\c 78
\cl Nzembo 78
\s1 Misala ya Nzambe
\d 
\v 1 Nzembo ya Azafi.
\q1 Bino, bato na ngai, boyoka malako na ngai !
\q2 Bopesa matoyi na maloba ya monoko na ngai !
\q1 
\v 2 Nakofungola monoko na ngai mpo na lisese,
\q2 nakosakola makambo oyo ebombama
\q2 wuta na tango ya kala.
\q1 
\v 3 Makambo oyo toyoka, oyo toyebi,
\q2 oyo batata na biso bayebisa biso.
\q1 
\v 4 Tokobombela yango bakitani na bango te,
\q2 kasi tokoloba na bikeke oyo ekoya na sima
\q1 nkembo ya masanzoli ya Yawe,
\q2 nguya na Ye mpe bikamwa oyo asalaki.
\b
\q1 
\v 5 Apesaki malako mpo na bolamu ya Jakobi,
\q2 atiaki mibeko kati na Isalaele,
\q1 apesaki mitindo epai ya batata na biso
\q2 ete bateya yango epai ya bana mibali na bango,
\q1 
\v 6 mpo ete bikeke oyo ekoya sima eyeba yango,
\q2 ekeke ya bana oyo bakobotama.
\q1 Tika ete batelema mpe bayebisa yango
\q2 na bana na bango,
\q1 
\v 7 mpo ete batonga elikya na bango kati na Nzambe,
\q2 babosana te misala ya Nzambe
\q2 mpe babatela mibeko na Ye.
\q1 
\v 8 Boye, bakozala te lokola bakoko na bango,
\q2 oyo bazalaki mito makasi mpe batomboki,
\q1 oyo mitema na bango ezalaki sembo te na miso ya Nzambe,
\q2 mpe milimo na bango ezangaki boyengebene epai na Ye.
\b
\q1 
\v 9 Bato ya libota ya Efrayimi basimbaki batolotolo,
\q2 kasi na mokolo ya etumba, bakimaki.
\q1 
\v 10 Babatelaki te Boyokani ya Nzambe
\q2 mpe baboyaki kotosa mibeko na Ye ;
\q1 
\v 11 babosanaki bikamwa na Ye
\q2 mpe makambo minene oyo atalisaki bango.
\q1 
\v 12 Na miso ya bakoko na bango,
\q2 asalaki bikamwa kati na Ejipito,
\q2 na etuka ya Tsoani ;
\q1 
\v 13 akabolaki ebale monene mpo na kolekisa bango,
\q2 atelemisaki mayi lokola mir.
\q1 
\v 14 Na moyi, azalaki kotambolisa bango
\q2 na nzela ya lipata ;
\q2 mpe na butu, na nzela ya pole ya moto.
\q1 
\v 15 Apasolaki mabanga kati na esobe
\q2 mpe amelisaki bango mayi ebele,
\q2 lokola mayi ya bibale ;
\q1 
\v 16 abimisaki mayi wuta na libanga
\q2 mpe asalaki ete etiola lokola mayi ya ebale.
\b
\q1 
\v 17 Kasi bakobaki kaka kosala masumu liboso na Ye,
\q2 kotombokela Ye-Oyo-Aleki-Likolo, kati na esobe.
\q1 
\v 18 Bamekaki Nzambe na nko,
\q2 na kosenga bilei kolanda posa na bango.
\b
\q1 
\v 19 Balobaki mabe na tina na Nzambe :
\q2 « Boni, Ye Nzambe azali penza na makoki
\q2 ya kopesa biso bilei kati na esobe ?
\q1 
\v 20 Solo, abetaki libanga,
\q2 mayi ebimaki, mpe ebimaki penza ebele.
\q1 Boni, akokoka lisusu kopesa biso mapa
\q2 to misuni epai ya bato na Ye ? »
\b
\q1 
\v 21 Tango Yawe ayokaki bongo,
\q2 asilikaki makasi ;
\q1 moto na Ye epelelaki Jakobi,
\q2 mpe kanda makasi na Ye ekitelaki Isalaele,
\q1 
\v 22 pamba te batiaki elikya na Nzambe te,
\q2 bandimaki te ete akoki kokangola bango.
\b
\q1 
\v 23 Nzokande, apesaki mitindo na mapata
\q2 mpe afungolaki bikuke ya likolo,
\q1 
\v 24 anokiselaki bango mana lokola mvula
\q2 mpo na kopesa bilei,
\q2 apesaki bango ble ya Likolo.
\q1 
\v 25 Moko na moko aliaki mapa ya ba-anjelu.
\q2 Atindelaki bango bilei ebele penza.
\q1 
\v 26 Wuta na likolo, atindikaki mosika mopepe ya Este ;
\q2 mpe na nguya na Ye, amemaki mopepe ya Sude.
\q1 
\v 27 Anokiselaki bango misuni lokola putulu,
\q2 bandeke ebele lokola zelo ya ebale monene ;
\q1 
\v 28 akweyiselaki bango yango kati na molako na bango,
\q2 zingazinga ya bandako na bango ya kapo.
\q1 
\v 29 Baliaki mpe batondaki makasi ;
\q2 Nzambe apesaki bango biloko
\q2 oyo bazalaki na yango posa.
\q1 
\v 30 Liboso ete posa na bango ekoka,
\q2 wana bazalaki nanu na minoko etonda na bilei,
\q1 
\v 31 kanda ya Nzambe ekweyelaki bango,
\q2 abomaki bato minene kati na bango,
\q2 anyokolaki bilenge ya Isalaele.
\b
\q1 
\v 32 Kasi atako bongo, bakobaki kaka kosala masumu,
\q2 bandimaki kaka te bikamwa na Ye.
\q1 
\v 33 Boye, asukisaki mikolo ya bomoi na bango
\q2 lokola mopepe,
\q2 mpe mibu na bango ya mbotama kati na somo.
\b
\q1 
\v 34 Tango nyonso Nzambe azalaki koboma bango,
\q2 bazalaki koluka Ye ;
\q2 bazalaki komizongisa noki epai na Ye.
\q1 
\v 35 Bazalaki kozongisa na makanisi na bango
\q2 ete Nzambe nde azali Libanga na bango,
\q1 ete Nzambe-Oyo-Aleki-Likolo azali
\q2 Mosikoli na bango.
\q1 
\v 36 Kasi bazalaki koloba lokuta,
\q2 minoko na bango ezalaki kokosa Ye ;
\q1 
\v 37 mitema na bango ezalaki sembo te
\q2 na miso na Ye,
\q2 mpe bazalaki kobuka Boyokani na Ye.
\b
\q1 
\v 38 Nzokande Ye, na mawa na Ye,
\q2 azalaki kolimbisa mabe na bango
\q1 na esika ya kobebisa bango ;
\q2 mbala mingi, azalaki kokanga motema
\q2 na esika ya kopelisela bango kanda na Ye ;
\q1 
\v 39 pamba te azalaki koyeba ete bazali kaka bato,
\q2 bazali kaka lokola mopepe oyo ezali koleka
\q2 mpe ekozonga lisusu te.
\b
\q1 
\v 40 Mbala mingi, batombokelaki Ye kati na esobe
\q2 mpe bayokisaki Ye mawa kati na bisika ya kokawuka ;
\q1 
\v 41 bazalaki kozongela komeka Nzambe,
\q2 koyokisa Mosantu ya Isalaele mawa.
\b
\q1 
\v 42 Babosanaki makambo minene oyo asalaki
\q2 na nguya na Ye,
\q1 mokolo oyo akangolaki bango
\q2 wuta na maboko ya monyokoli ;
\q1 
\v 43 babosanaki bikamwa oyo asalaki kati na Ejipito,
\q2 misala minene oyo asalaki kati na etuka ya Tsoani.
\q1 
\v 44 Abongolaki bibale na bango makila ;
\q2 boye, bakokaki lisusu te komela na mayi na bango.
\q1 
\v 45 Atindelaki bango banzinzi oyo eswaka,
\q2 mpe eliaki bango ;
\q1 mpe magorodo oyo ebebisaki bango.
\b
\q1 
\v 46 Akabaki bambuma ya bilanga na bango
\q2 epai ya mabanki,
\q2 mpe mbuma ya mosala na bango epai ya mankoko.
\q1 
\v 47 Abebisaki bilanga na bango ya vino
\q2 na nzela ya mvula ya mabanga,
\q1 mpe banzete na bango ya sikomori
\q2 na nzela ya mvula ya pembe ;
\q1 
\v 48 akabaki bameme na bango
\q2 epai ya mvula ya mabanga,
\q2 mpe bibwele na bango epai ya kake.
\b
\q1 
\v 49 Atindelaki bango kanda na Ye ya makasi lokola moto :
\q2 kanda makasi, kotomboka, pasi
\q2 mpe ba-anjelu oyo babebisaka.
\q1 
\v 50 Apesaki na kanda na Ye nzela ya kopela,
\q2 abatelaki bango te na kufa ;
\q2 kasi akabaki bango na bokono oyo ebomaka.
\q1 
\v 51 Abomaki bana mibali nyonso ya liboso
\q2 kati na Ejipito,
\q1 bambuma ya liboso ya makasi na bango
\q2 na se ya bandako ya kapo ya Cham.
\b
\q1 
\v 52 Abimisaki bato na Ye lokola etonga,
\q2 amemaki bango kati na esobe lokola meme ;
\q1 
\v 53 atambolisaki bango na kimia penza,
\q2 babangaki eloko te ;
\q2 mpe ebale monene emelaki banguna na bango.
\b
\q1 
\v 54 Amemaki bango na mokili na Ye ya bule,
\q2 na ngomba oyo loboko na Ye ya nguya ezwaki ;
\q1 
\v 55 abenganaki bikolo liboso na bango,
\q2 apesaki bango etando lokola libula
\q1 mpe avandisaki mabota ya Isalaele
\q2 kati na bandako na bango ya kapo.
\b
\q1 
\v 56 Kasi bamekaki Nzambe,
\q2 batombokelaki Ye-Oyo-Aleki-Likolo
\q2 mpe babatelaki te malako na Ye ;
\q1 
\v 57 bapengwaki mpe babukaki mibeko ya boyokani,
\q2 ndenge batata na bango basalaki ;
\q1 batengamaki lokola tolotolo
\q2 oyo mbanzi na yango ekeyi na mopanzi ;
\q1 
\v 58 bayokisaki Ye kanda na nzela ya
\q2 bisambelo na bango ya likolo ya bangomba,
\q1 mpe bapelisaki zuwa na Ye na nzela ya
\q2 banzambe na bango ya bikeko.
\b
\q1 
\v 59 Nzambe ayokaki mpe asilikaki makasi,
\q2 abwakaki Isalaele mobimba ;
\q1 
\v 60 asundolaki Mongombo ya Silo,
\q2 ndako ya kapo oyo atelemisaki kati na bato,
\q1 
\v 61 akabaki nguya na Ye na bowumbu,
\q2 mpe lokumu na Ye na maboko ya monguna ;
\q1 
\v 62 akabaki bato na Ye na mopanga,
\q2 mpe asilikelaki libula na Ye.
\q1 
\v 63 Moto etumbaki bilenge mibali,
\q2 mpe banzembo ya libala eyembamaki lisusu te
\q2 mpo na lokumu ya bilenge basi.
\q1 
\v 64 Banganga-Nzambe bakufaki na mopanga,
\q2 mpe basi oyo bakufisaki mibali
\q2 balelaki te na banzembo ya matanga.
\b
\q1 
\v 65 Nkolo alamukaki lokola moto oyo
\q2 awuti na pongi,
\q2 lokola moto oyo abimi na kwiti ya vino ;
\q1 
\v 66 azokisaki banguna na Ye na sima,
\q2 wana bazalaki kokima,
\q2 ayokisaki bango soni ya libela.
\b
\q1 
\v 67 Asundolaki bandako ya kapo ya Jozefi
\q2 mpe aboyaki kopona libota ya Efrayimi ;
\q1 
\v 68 kasi aponaki libota ya Yuda,
\q2 ngomba Siona oyo alingaki ;
\q1 
\v 69 atongaki Esika na Ye ya bule
\q2 lokola bisika ya likolo makasi,
\q2 lokola mabele oyo atia mpo na libela.
\b
\q1 
\v 70 Aponaki Davidi, mosali na Ye,
\q2 mpe azwaki ye kati na lopango ya meme ;
\q1 
\v 71 abengaki ye wuta na sima ya meme oyo
\q2 azalaki kobatela
\q1 mpo na kokomisa Ye mobateli ya Jakobi, bato na Ye,
\q2 mpe ya Isalaele, libula na Ye.
\q1 
\v 72 Davidi abatelaki bango na motema ezanga pamela,
\q2 mpe akambaki bango na maboko ya mayele.
\c 79
\cl Nzembo 79
\s1 Yelusalemi epanzani
\d 
\v 1 Nzembo ya Azafi.
\q1 Oh Nzambe, tala ndenge bato ya bikolo ya bapaya
\q2 bakoti na makasi kati na libula na Yo,
\q1 bakomisi Esika na Yo ya bule mbindo,
\q2 mpe bakomisi Yelusalemi mipiku ya mabanga !
\q1 
\v 2 Bapesi bibembe ya basali na Yo lokola bilei
\q2 epai ya bandeke ya likolo,
\q1 mpe bibembe ya bayengebene na Yo
\q2 epai ya banyama ya zamba ;
\q1 
\v 3 basopi makila na bango lokola mayi
\q2 zingazinga ya Yelusalemi,
\q2 mpe moto ya kokunda bango azalaki te !
\b
\q1 
\v 4 Tala ndenge bato ya bikolo oyo ezingeli biso
\q2 bazali kofinga biso,
\q1 mpe tokomi lokola eloko ya liseki
\q2 na miso na bango !
\q1 
\v 5 Kino tango nini, Yawe,
\q2 okokangela biso kanda ?
\q2 Kino tango nini zuwa na Yo ekopela lokola moto ?
\b
\q1 
\v 6 Sopela bikolo oyo eyebi Yo te
\q2 mpe mikili oyo ebelelaka Kombo na Yo te,
\q2 kanda makasi na Yo ;
\q1 
\v 7 pamba te babebisi Jakobi
\q2 mpe bapanzi mokili na ye.
\b
\q1 
\v 8 Kotangela biso te masumu na biso ya kala,
\q2 kokangela biso motema te, yokela biso mawa,
\q2 pamba te tokomi na suka !
\q1 
\v 9 Nzambe Mobikisi na biso, sunga biso
\q2 mpo na lokumu ya Kombo na Yo,
\q1 kangola biso mpe limbisa masumu na biso
\q2 mpo na Kombo na Yo !
\b
\q1 
\v 10 Mpo na nini bikolo eloba :
\q2 « Nzambe na bango azali wapi ? »
\q1 Tika ete, na miso na biso, bato ya bikolo bayeba
\q2 ete ozongiseli bango mabe na mabe,
\q2 mpo na makila ya basali na Yo, oyo basopaki.
\b
\q1 
\v 11 Tika ete kolela ya bakangami kati na boloko
\q2 ekoma liboso na Yo !
\q1 Na nguya monene na Yo,
\q2 bikisa ba-oyo bazwa etumbu ya kufa !
\q1 
\v 12 Oh Nkolo, zongisela bikolo
\q2 oyo ezingeli biso,
\q1 kotiola oyo batiolaki Yo ;
\q2 zongisela bango mbala sambo.
\q1 
\v 13 Mpe biso, bato na Yo, etonga oyo oleisaka,
\q2 tokosanzola Yo tango nyonso ;
\q1 mpe na bikeke nyonso,
\q2 tokosakola lokumu na Yo.
\c 80
\cl Nzembo 80
\s1 Eh Yawe, kino tango nini ?
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Ezali ya koyemba lokola « Lisi ya Mobeko. » Litatoli. Nzembo ya Azafi.
\q1 
\v 2 Mobateli ya Isalaele,
\q2 Yo oyo otambolisaka Jozefi
\q1 lokola etonga ya bameme, yoka ;
\q2 Yo oyo Kiti ya Bokonzi na Yo ezali
\q2 kati na basheribe, mimonisa
\q1 
\v 3 liboso ya Efrayimi, ya Benjame
\q2 mpe ya Manase.
\q1 Monisa nguya na Yo
\q2 mpe yaka kobikisa biso !
\b
\q1 
\v 4 Oh Nzambe, sala ete tozongela ndenge tozalaki,
\q2 ngengisela biso elongi na Yo mpo ete tobika.
\b
\q1 
\v 5 Eh Yawe, Nzambe-Na-Nguya-Nyonso,
\q2 kino tango nini okotombokela
\q2 mabondeli ya bato na Yo ?
\q1 
\v 6 Oleisaki bango lipa esangana na mayi ya miso
\q2 mpe olangwisaki bango na kopo
\q2 etonda na mpinzoli ;
\q1 
\v 7 okomisaki biso eloko ya kotiola
\q2 mpo na bazalani na biso,
\q2 mpe banguna na biso bakomi kotiola biso.
\b
\q1 
\v 8 Nzambe-Na-Nguya-Nyonso,
\q2 sala ete tozongela ndenge tozalaki,
\q1 ngengisela biso elongi na Yo
\q2 mpo ete tobika.
\b
\q1 
\v 9 Nzete ya vino oyo opikolaki wuta na Ejipito,
\q2 olonaki yango wana obenganaki bikolo ebele.
\q1 
\v 10 Obongiselaki yango mabele
\q2 mpo ete ezwa misisa mpe etondisa mokili.
\q1 
\v 11 Elili na yango ezipaki bangomba,
\q2 bitape na yango ezalaki
\q2 lokola banzete minene ya sedele.
\q1 
\v 12 Epanzaki bitape na yango kino na ebale monene,
\q2 mpe mito na yango ya sika kino na ebale.
\b
\q1 
\v 13 Mpo na nini otoboli madusu
\q2 kati na bamir na yango ?
\q1 Tala ndenge baleki nzela bazali kobuka
\q2 bambuma na yango !
\q1 
\v 14 Ngulu ya zamba ezali kobebisa yango,
\q2 mpe nyama ya zamba ezali kolia yango.
\q1 
\v 15 Zongela biso lisusu,
\q2 Nzambe-Na-Nguya-Nyonso !
\q1 Wuta na likolo, tala mpe mona !
\q2 Senzela mpo na nzete oyo ya vino !
\q1 
\v 16 Batela nzete oyo loboko na Yo ya mobali elonaki,
\q2 batela solo mwana oyo Yo moko obokolaki.
\b
\q1 
\v 17 Bakati nzete na Yo ya vino
\q2 mpe batumbi yango na moto ;
\q2 tika ete bakufa na pamela ya elongi na Yo !
\q1 
\v 18 Tika ete loboko na Yo ezala na likolo ya mokonzi
\q2 oyo avandi na ngambo ya loboko na Yo ya mobali,
\q1 mpe na likolo ya mwana na moto
\q2 oyo Yo moko okomisaki makasi.
\q1 
\v 19 Boye, tokozala lisusu mosika na Yo te ;
\q2 zongisela biso lisusu bomoi,
\q2 mpe tokobelela Kombo na Yo.
\b
\q1 
\v 20 Yawe, Nzambe-Na-Nguya-Nyonso,
\q2 sala ete tozongela ndenge tozalaki,
\q2 ngengisela biso elongi na Yo mpo ete tobika.
\c 81
\cl Nzembo 81
\s1 Soki bato na ngai bazalaki koyokela ngai…
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Azafi. Ezali ya koyemba na lindanda ya bato ya Gati.
\q1 
\v 2 Boganga na esengo
\q2 epai ya Nzambe, makasi na biso !
\q2 Bobetela Nzambe ya Jakobi maboko !
\q1 
\v 3 Boyemba banzembo, bobeta bambunda mike,
\q2 lindanda oyo ebimisaka lokito kitoko mpe nzenze !
\q1 
\v 4 Bobeta kelelo na ebandeli ya sanza,
\q2 na tango oyo sanza mobimba engengaka,
\q2 mpo na mokolo ya feti na biso !
\b
\q1 
\v 5 Pamba te ezali mobeko mpo na Isalaele,
\q2 mpe mokano ya Nzambe ya Jakobi.
\q1 
\v 6 Atiaki yango lokola mobeko mpo na Jozefi
\q2 tango abundisaki Ejipito.
\b
\q1 Nazali koyoka lokota oyo nayebi te :
\q1 
\v 7 « Nalongolaki mokumba
\q2 oyo ezalaki na mapeka na ye,
\q1 mpe maboko na ye elongwaki
\q2 na bowumbu ya kosimba bitunga. »
\q1 
\v 8 Tango ozalaki koganga mpo na pasi,
\q2 nakangolaki yo,
\q2 nayanolaki yo kati na kake
\q1 epai wapi nabombamaki,
\q2 namekaki yo pembeni ya mayi ya Meriba.
\b
\q1 
\v 9 Bato na ngai, boyoka ngai !
\q2 Mpe nakokebisa bino.
\q2 Ah Isalaele, soki kaka ozalaki koyokela ngai !
\q1 
\v 10 Okozala na nzambe ya mopaya te kati na yo,
\q2 okogumbamela nzambe mosusu te,
\q2 longola kaka ngai !
\q1 
\v 11 Nazali Yawe, Nzambe na yo,
\q2 oyo abimisaki yo na Ejipito ;
\q1 fungola malamu monoko na yo,
\q2 mpe nakotondisa yango.
\b
\q1 
\v 12 Kasi bato na ngai bayokaki mongongo na ngai te,
\q2 Isalaele aboyaki kotosa ngai.
\q1 
\v 13 Mpo na yango, natikaki bango kotambola
\q2 kolanda baposa ya mitema makasi na bango ;
\q2 mpe balandaki makanisi na bango.
\q1 
\v 14 Soki bato na ngai bazalaki koyokela ngai,
\q2 soki Isalaele azalaki kolanda banzela na ngai,
\q1 
\v 15 nalingaki mbala moko koyokisa
\q2 banguna na bango soni
\q2 mpe kobundisa bayini na bango.
\q1 
\v 16 Mpe bato oyo bayinaka Yawe
\q2 balingaki komikitisa liboso na Ye,
\q1 mpe etumbu na bango elingaki kowumela
\q2 mpo na libela.
\q1 
\v 17 Yawe alingaki koleisa Isalaele
\q2 bilei ya kitoko
\q2 mpe kotondisa bango na mafuta ya nzoyi.
\c 82
\cl Nzembo 82
\s1 Nzambe asambisaka bakambi ya bikolo
\d 
\v 1 Nzembo ya Azafi.
\q1 Nzambe atelemi kati na lisanga na Ye,
\q2 azali kokata makambo kati na banzambe.
\b
\q1 
\v 2 Kino tango nini bokokata makambo
\q2 na bosembo te
\q2 mpe bokokotela bato mabe ?
\b
\q1 
\v 3 Bolongisa moto oyo azangi makasi
\q2 mpe mwana etike,
\q1 bokata likambo ya moto ya mawa
\q2 mpe ya mobola ;
\q1 
\v 4 bopesa bonsomi na moto oyo azangi makasi
\q2 mpe na mobola,
\q2 bokangola bango wuta na maboko ya bato mabe.
\b
\q1 
\v 5 Bazangi boyebi mpe bososoli,
\q2 bazali koyengayenga kati na molili ;
\q2 miboko nyonso ya mokili ezali koningana.
\b
\q1 
\v 6 Nalobaki : « Bozali banzambe,
\q2 bozali bino nyonso bana
\q2 ya Ye-Oyo-Aleki-Likolo ! »
\q1 
\v 7 Nzokande, bokufaka lokola bato nyonso
\q2 mpe bokweyaka lokola bakambi.
\b
\q1 
\v 8 Nzambe, telema, sambisa mokili ;
\q2 pamba te bikolo nyonso ezali libula na Yo.
\c 83
\cl Nzembo 83
\s1 Telemela banguna na Yo
\d 
\v 1 Nzembo ya Azafi.
\q1 
\v 2 Oh Nzambe, kovanda nye te !
\q2 Nzambe, kokanga monoko na Yo te,
\q2 kotikala kimia te !
\q1 
\v 3 Tala ndenge banguna na Yo bazali kotomboka ;
\q2 tala ndenge bayini na Yo bazali kotombola
\q2 mito na bango !
\q1 
\v 4 Bazali kosalela bato na Yo likita,
\q2 kokanela bato oyo obatelaka.
\q1 
\v 5 Bazali koloba : « Boya, toboma bango nyonso
\q2 mpo ete ekolo na bango ezala lisusu te,
\q2 mpo ete batanga lisusu kombo ya Isalaele te. »
\b
\q1 
\v 6 Basangani mpe bayokani,
\q2 basali boyokani mpo na kotelemela Yo :
\q1 
\v 7 bato ya Edomi mpe bato ya Isimaeli,
\q2 bato ya Moabi mpe bato ya Agari,
\q1 
\v 8 Gebali, Amoni mpe Amaleki,
\q2 bato ya Filisitia elongo na bato ya Tiri.
\q1 
\v 9 Bato ya Asiri mpe basangani elongo na bango
\q2 mpo na kobakisa bakitani ya Loti makasi.
\b
\q1 
\v 10 Sala bango ndenge osalaki Madiani,
\q2 ndenge osalaki Sisera mpe Yabini,
\q2 kuna na mayi ya Kishoni.
\q1 
\v 11 Babebisamaki na Eyini-Dori,
\q2 bakomaki lokola matiti ya kopola mpo na mabele.
\q1 
\v 12 Sala bato na bango ya lokumu
\q2 ndenge osalaki Orebi mpe Zeebi ;
\q1 mpe sala bakambi na bango
\q2 ndenge osalaki Zeba mpe Tsalimuna
\q1 
\v 13 oyo bazalaki koloba :
\q2 « Tobotola mabele ya Nzambe ! »
\b
\q1 
\v 14 Nzambe na ngai, balola bango
\q2 lokola matiti oyo mopepe ezali kopumbwisa.
\q1 
\v 15 Ndenge moto ezikisaka zamba,
\q2 ndenge moto makasi ezikisaka bangomba,
\q1 
\v 16 landa bango na nzela ya mopepe na Yo
\q2 mpe bangisa bango
\q2 na nzela ya mopepe makasi na Yo !
\b
\q1 
\v 17 Yawe, tondisa bilongi na bango na soni
\q2 mpo ete baluka Kombo na Yo !
\q1 
\v 18 Tika ete soni mpe somo makasi elata bango
\q2 mpo na libela !
\q2 Tika ete bakufa na soni !
\q1 
\v 19 Tika bayeba ete Yo,
\q2 oyo Kombo na Yo ezali Yawe,
\q1 ozali Ye-Oyo-Aleki-Likolo
\q2 kati na mokili mobimba !
\c 84
\cl Nzembo 84
\s1 Nazali na posa makasi ya Tempelo na Yo
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya bana ya Kore. Ezali ya koyemba na lindanda ya bato ya Gati.
\q1 
\v 2 Yawe, Mokonzi ya mampinga,
\q2 tala ndenge bisika oyo ovandaka
\q2 ezali kopesa posa !
\q1 
\v 3 Nzoto na ngai mobimba ebukani pene nakufa
\q2 mpo na posa makasi ya lopango ya Yawe !
\q1 Motema mpe nzoto na ngai ezali koganga
\q2 epai ya Nzambe na bomoi.
\b
\q1 
\v 4 Ndeke ya moke ezwaka esika ya kovanda,
\q2 mpe mbilambila esalaka zala
\q1 epai wapi etiaka bana na yango,
\q2 pene ya bitumbelo na Yo,
\q1 Yawe, Mokonzi ya mampinga,
\q2 Mokonzi na ngai mpe Nzambe na ngai.
\q1 
\v 5 Esengo na bavandi ya Ndako na Yo !
\q2 Bakokumisa Yo tango nyonso !
\b
\q1 
\v 6 Esengo na bato oyo bazwaka makasi kati na Yo ;
\q2 bakendaka na esengo na Tempelo na Yo !
\q1 
\v 7 Tango bakatisaka Lubwaku ya Baka,
\q2 bakomisaka yango esika oyo etonda na bitima ya mayi,
\q2 mpe mvula etondisaka yango na mapamboli.
\q1 
\v 8 Makasi na bango ebakisamaka tango nyonso
\q2 kino bakomaka na Siona, liboso ya Nzambe.
\q1 
\v 9 Yawe, Nzambe-Na-Nguya-Nyonso,
\q2 yoka losambo na ngai !
\q2 Nzambe ya Jakobi, yoka ngai !
\b
\q1 
\v 10 Oh Nzambe, Yo oyo ozali nguba na biso, tala !
\q2 Tala elongi ya mopakolami na Yo !
\b
\q1 
\v 11 Lokola kovanda mokolo moko
\q2 kati na lopango na Yo
\q1 eleki kovanda mikolo nkoto moko
\q2 na esika mosusu,
\q1 naponaki kotelema na ekotelo
\q2 ya Ndako ya Nzambe na ngai
\q1 na esika ete navanda kati na bandako ya kapo
\q2 ya bato mabe.
\b
\q1 
\v 12 Pamba te, mpo na biso,
\q2 Yawe Nzambe azali moyi mpe nguba ;
\q1 Yawe apesaka ngolu mpe nkembo,
\q2 aboyaka kopesa eloko moko te
\q2 epai ya bato oyo batambolaka bazanga pamela.
\q1 
\v 13 Yawe, Mokonzi ya mampinga,
\q2 esengo na moto oyo atiaka elikya kati na Yo !
\c 85
\cl Nzembo 85
\s1 Yawe asalelaka biso bolamu
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya bana ya Kore.
\q1 
\v 2 Yawe, osalelaki mboka na Yo bolamu,
\q2 ozongisaki bato ya Jakobi,
\q2 oyo bazalaki na bowumbu,
\q1 
\v 3 olimbisaki mabe ya bato na Yo
\q2 mpe olongolaki masumu na bango nyonso.
\b
\q1 
\v 4 Otikaki kanda na Yo nyonso ya makasi
\q2 mpe okitisaki motema na Yo.
\q1 
\v 5 Nzambe Mobikisi na biso, zongela biso !
\q2 Longola kanda na Yo na tina na biso !
\q1 
\v 6 Boni, okosilikela biso penza mpo na libela ?
\q2 Okokangela penza biso kanda
\q2 mpo na tango nyonso ?
\b
\q1 
\v 7 Okozongisela biso lisusu bomoi te
\q2 mpo ete bato na Yo basepela kati na Yo ?
\q1 
\v 8 Yawe, talisa biso bolingo na Yo,
\q2 mpe pesa biso lobiko na Yo !
\b
\q1 
\v 9 Yawe,
\q2 nakoyoka maloba na Nzambe ;
\q1 pamba te alobaka mpo na kimia ya bato na Ye
\q2 mpe ya bayengebene na Ye.
\q2 Kasi tika ete bazongela te botomboki na bango.
\q1 
\v 10 Solo, lobiko na Ye ezali pene ya bato
\q2 oyo batosaka Ye
\q1 mpo ete nkembo na Ye ewumela
\q2 kati na mboka na biso.
\q1 
\v 11 Bolingo mpe boyengebene ekutanaka,
\q2 bosembo mpe kimia eyambanaka.
\q1 
\v 12 Bosolo ebotaka wuta na mabele,
\q2 mpe bosembo etalaka wuta na likolo.
\b
\q1 
\v 13 Ye moko Yawe akopesa esengo,
\q2 mpe mabele na biso ekobota bambuma.
\q1 
\v 14 Bosembo etambolaka liboso na Ye
\q2 mpe elakisaka nzela oyo ekolekela.
\c 86
\cl Nzembo 86
\s1 Yaka kobikisa ngai
\d 
\v 1 Libondeli ya Davidi.
\q1 Yawe, yoka mpe yanola ngai ;
\q2 pamba te nazali mobola mpe moto akelela.
\q1 
\v 2 Batela bomoi na ngai,
\q2 pamba te nazali moyengebene na Yo.
\q1 Yo, Nzambe na ngai, bikisa ngai, mosali na Yo,
\q2 oyo natiaka elikya kati na Yo.
\b
\q1 
\v 3 Oh Nkolo, yokela ngai mawa ;
\q2 pamba te nabelelaka Yo tango nyonso !
\q1 
\v 4 Nkolo, sepelisa motema na ngai,
\q2 mosali na Yo,
\q2 pamba te natombolaka molimo na ngai epai na Yo.
\q1 
\v 5 Nkolo, ozali malamu, olimbisaka,
\q2 otonda na bolingo mpo na bato nyonso
\q2 oyo babelelaka Yo.
\q1 
\v 6 Yawe, yoka losambo na ngai,
\q2 yoka libondeli na ngai !
\q1 
\v 7 Na mokolo ya pasi na ngai, nabelelaka Yo,
\q2 pamba te oyanolaka ngai.
\b
\q1 
\v 8 Nkolo, nzambe moko te ekokani na Yo,
\q2 kati na banzambe ;
\q2 moko te ekoki kosala makambo oyo Yo osalaka.
\q1 
\v 9 Nkolo, bikolo nyonso oyo osala
\q2 ekoya kogumbama liboso na Yo
\q2 mpe ekoya kopesa Kombo na Yo nkembo.
\q1 
\v 10 Pamba te ozali monene mpe osalaka bikamwa ;
\q2 Yo kaka nde ozali Nzambe.
\b
\q1 
\v 11 Yawe, lakisa ngai nzela na Yo,
\q2 mpe nakotambola kolanda bosolo na Yo.
\q2 Pesa ngai motema ya sembo mpo ete natosa Yo.
\q1 
\v 12 Nkolo, Nzambe na ngai, nakosanzola Yo,
\q2 na motema na ngai mobimba,
\q2 nakopesa Kombo na Yo nkembo mpo na Yo libela.
\q1 
\v 13 Pamba te bolingo na Yo mpo na ngai
\q2 ezali monene,
\q1 mpe okangolaki ngai wuta na mozindo
\q2 ya mboka ya bakufi.
\b
\q1 
\v 14 Nzambe, bato ya lofundu bazali kobundisa ngai,
\q2 mpe ngulupa ya bato na kanza bazali koluka
\q2 koboma ngai ; batosaka Yo ata moke te.
\b
\q1 
\v 15 Kasi Yo Nkolo, ozali Nzambe
\q2 na mawa mpe na ngolu,
\q1 osilikaka noki te,
\q2 otonda na bolingo mpe na boyengebene.
\q1 
\v 16 Balola elongi na Yo epai na ngai
\q2 mpe yokela ngai mawa ;
\q1 pesa ngai, mosali na Yo, makasi
\q2 mpe bikisa ngai mwana ya mwasi mosali na Yo !
\q1 
\v 17 Salela ngai elembo ya boboto na Yo
\q2 mpo ete banguna na ngai bamona yango mpe bakufa soni !
\q2 Yawe, ozali Mosungi mpe Mobondi na ngai.
\c 87
\cl Nzembo 87
\s1 Siona, etima ya bikolo nyonso
\d 
\v 1 Nzembo ya bana ya Kore.
\q1 Yawe atia moboko ya Siona
\q2 na likolo ya bangomba ya bule.
\q1 
\v 2 Yawe alingaka bikuke ya Siona
\q2 koleka bandako nyonso ya Jakobi.
\q1 
\v 3 Oh engumba ya Nzambe,
\q2 maloba ya nkembo ezali kolobama na tina na yo !
\b
\q1 
\v 4 Kati na bato oyo bayebi ngai,
\q2 natangi Rahavi mpe Babiloni.
\q1 Ezali kuna na Siona nde Filisitia, Tiri
\q2 mpe Kushi ebimela.
\q1 
\v 5 Na tina na Siona, maloba oyo ekolobama :
\q2 « Bato nyonso babimela awa,
\q1 mpe ezali Ye-Oyo-Aleki-Likolo
\q2 nde alendisaka yango. »
\q1 
\v 6 Tango Yawe akomaki
\q2 kati na buku ya bikolo,
\q1 akomaki boye mpo na moko na moko kati na bango :
\q2 « Moto songolo abotama kati na Siona ! »
\q1 
\v 7 Mpe tango bayembaka mpe babinaka, balobaka :
\q2 « Bitima na ngai nyonso ezali kati na yo ! »
\c 88
\cl Nzembo 88
\s1 Libondeli ya moto oyo akomi pene ya kokufa
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya bana ya Kore. Ezali ya koyemba na flite. Nzembo ya Emani, moto ya Ezera.
\q1 
\v 2 Yawe, ozali Nzambe ;
\q2 Yo nde obikisaka ngai !
\q2 Butu mpe moyi, nagangaka epai na Yo !
\q1 
\v 3 Tika ete losambo na ngai ekoma epai na Yo ;
\q2 Yoka koganga na ngai !
\b
\q1 
\v 4 Pamba te bomoi na ngai etondi na pasi
\q2 mpe nakomi pene ya kokufa.
\q1 
\v 5 Batie ngai na molongo ya bato
\q2 oyo bazali kokende na kunda ;
\q1 nakeseni ata moke te na moto
\q2 oyo azali lisusu na makasi te.
\q1 
\v 6 Nakomi moko kati na bakufi,
\q2 lokola bato oyo basila kokufa na bitumba
\q1 mpe bazali sik’oyo kati na kunda,
\q2 lokola bato oyo okanisaka lisusu te,
\q2 pamba te obatelaka bango lisusu te.
\b
\q1 
\v 7 Obwaki ngai na libulu ya mozindo makasi,
\q2 kati na mozindo ya molili.
\q1 
\v 8 Kanda na Yo ya makasi ekweyeli ngai,
\q2 bambonge na yango nyonso ezali konyokola ngai.
\b
\q1 
\v 9 Okaboli ngai na balingami na ngai ya motema,
\q2 okomisi ngai eloko ya nkele na miso na bango ;
\q1 nakomi lokola mokangami kati na boloko,
\q2 nakoki kobima te !
\q1 
\v 10 Miso na ngai ezali komona lisusu te mpo na pasi ;
\q2 nzokande nabelelaka Yo, Yawe,
\q2 mikolo nyonso,
\q2 natombolaka maboko na ngai epai na Yo !
\b
\q1 
\v 11 Boni, okosala bikamwa mpo na bakufi ?
\q2 Boni, bakufi bakoki kotelema
\q2 mpo na kosanzola Yo ?
\b
\q1 
\v 12 Boni, bolingo na Yo etatolamaka kati na kunda,
\q2 mpe bosembo na Yo, kati na mboka ya bakufi ?
\q1 
\v 13 Boni, bikamwa na Yo eyebani kati na molili,
\q2 mpe bosembo na Yo, kati na mokili
\q2 ya bato oyo babosana ?
\b
\q1 
\v 14 Kasi ngai, nazali kobelela nde Yo, Yawe ;
\q2 nabondelaka Yo tongo nyonso.
\q1 
\v 15 Yawe, mpo na nini kobwaka ngai
\q2 mpe kobombela ngai elongi na Yo ?
\b
\q1 
\v 16 Wuta bolenge na ngai,
\q2 nazali mobola mpe moto na pasi ;
\q1 mpe okweyiselaka ngai makambo na Yo ya somo !
\q2 Solo, elikya esili ngai !
\q1 
\v 17 Kanda makasi na Yo ebetaka ngai,
\q2 minyoko oyo ewutaka epai na Yo
\q2 ekomisaka ngai moto pamba.
\q1 
\v 18 Ezingelaka ngai mikolo nyonso,
\q2 lokola mayi, na bangambo nyonso.
\q1 
\v 19 Okaboli ngai na baninga mpe balingami na ngai,
\q2 natikali na moninga kaka moko ya motema : molili !
\c 89
\cl Nzembo 89
\s1 Wapi bolingo na Yo ya kala
\d 
\v 1 Maloba ya Etani, moto ya Ezera.
\q1 
\v 2 Nakoyemba tango nyonso
\q2 bolingo ya Yawe ;
\q1 monoko na ngai ekosakola boyengebene na Yo
\q2 libela na libela.
\q1 
\v 3 Solo, nazali kotatola yango :
\q2 « Miboko ya bolingo na Yo ezali na suka te ;
\q2 ovandisi boyengebene na Yo kati na likolo. »
\b
\q1 
\v 4 Olobaki : « Nasali boyokani
\q2 elongo na moponami na ngai,
\q1 nalapi ndayi epai ya mosali na ngai, Davidi :
\q1 
\v 5 ‹ Nakokomisa yo libota ya bokonzi
\q2 mpo na tango nyonso
\q1 mpe nakolendisa kiti na yo ya bokonzi
\q2 mpo na seko. › »
\b
\q1 
\v 6 Yawe, Lola esanzolaka
\q2 misala na Yo ya kokamwa
\q2 mpe bosembo na Yo kati na lisanga ya basantu.
\q1 
\v 7 Nani akokani na Yawe kuna na likolo ?
\q2 Nani akokani na Yawe
\q2 kati na mampinga ya likolo ?
\b
\q1 
\v 8 Azali Nzambe ya somo kati na lisanga ya basantu ;
\q2 solo, azali somo koleka ba-oyo nyonso bazingeli Ye.
\q1 
\v 9 Yawe, Nzambe-Na-Nguya-Nyonso,
\q2 nani azali na nguya lokola Yo ?
\q2 Nani, oh Yawe ?
\q2 Boyengebene na Yo ezingeli Yo.
\b
\q1 
\v 10 Yo nde okonzaka lolendo ya ebale monene
\q2 mpe okitisaka bambonge na yango soki etomboki.
\b
\q1 
\v 11 Yo nde olongaki Rahavi, dalagona ya Ejipito,
\q2 kino koboma ye ;
\q2 mpe, na nguya na Yo, opanzaki banguna na Yo.
\b
\q1 
\v 12 Likolo ezali ya Yo ; mabele mpe ezali ya Yo !
\q2 Yo nde osala mokili mpe nyonso oyo ezali kati na yango.
\q1 
\v 13 Yo nde okela Nor mpe Sude ;
\q2 Tabori mpe Erimoni egangaka na esengo
\q2 mpo na lokumu ya Kombo na Yo.
\b
\q1 
\v 14 Loboko na Yo ezali na makasi,
\q2 loboko na Yo ezali na nguya,
\q2 loboko na Yo ya mobali oyo otombola.
\q1 
\v 15 Bosembo mpe alima ezali miboko ya
\q2 Kiti ya Bokonzi na Yo,
\q2 boyengebene mpe bolingo etambolaka liboso na Yo.
\b
\q1 
\v 16 Esengo na bato oyo bayebi kobetela Yo maboko !
\q2 Yawe, batambolaka na pole ya elongi na Yo,
\q1 
\v 17 basepelaka mikolo nyonso na Kombo na Yo,
\q2 basanzolaka bosembo na Yo.
\q1 
\v 18 Pamba te ozali nkembo mpe nguya na bango ;
\q2 mpe olongisaka biso na ngolu na Yo.
\q1 
\v 19 Yawe azali nguba na biso ;
\q2 Mosantu ya Isalaele azali Mokonzi na biso.
\b
\q1 
\v 20 Mokolo moko, olobaki na bayengebene na Yo
\q2 kati na emoniseli :
\q1 « Nasungaki elombe moko ya bitumba,
\q2 natombolaki elenge mobali moko
\q2 kati na bato na ngai ;
\q1 
\v 21 namonaki Davidi, mosali na ngai ;
\q2 napakolaki ye mafuta na ngai ya bule.
\q1 
\v 22 Nakobatela ye na loboko na ngai ya nguya,
\q2 mpe loboko na ngai ekokomisa ye makasi.
\q1 
\v 23 Monguna akobimela ye ata moke te na pwasa,
\q2 moto mabe akokoka konyokola ye te.
\q1 
\v 24 Nakobebisa banguna na ye liboso na ye
\q2 mpe nakoboma bayini na ye.
\b
\q1 
\v 25 Bolingo mpe boyengebene na ngai ekozala
\q2 elongo na ye ;
\q2 mpe na Kombo na Ngai, akotombola elongi.
\q1 
\v 26 Nakotia ebale monene na se ya loboko na ye,
\q2 mpe bibale, na se ya loboko na ye ya mobali.
\q1 
\v 27 Akobelela ngai boye :
\q2 ‹ Ozali Tata na ngai,
\q1 Nzambe na ngai, Libanga
\q2 mpe Mobikisi na ngai ! ›
\q1 
\v 28 Mpe ngai, nakokomisa ye mwana na ngai ya liboso,
\q1 mokonzi oyo aleki na kotombwama
\q2 kati na bakonzi ya mokili.
\b
\q1 
\v 29 Nakobatela mpo na seko
\q2 bolingo na ngai mpo na ye ;
\q1 boyokani na ngai elongo na ye ekotikala kobeba te.
\q1 
\v 30 Nakobatela mpo na libela libota na ye ya bokonzi,
\q2 mpe kiti na ye ya bokonzi ekowumela
\q2 ndenge moko na likolo.
\b
\q1 
\v 31 Soki bana na ye basundoli mibeko na ngai
\q2 mpe balandi bosembo na ngai te,
\q1 
\v 32 soki babuki mitindo na ngai
\q2 mpe babateli te mibeko na ngai,
\q1 
\v 33 nakopesa bango etumbu na nzela ya lingenda,
\q2 mpo na botomboki na bango,
\q2 mpe na nzela ya makofi, mpo na masumu na bango ;
\q1 
\v 34 kasi nakowangana te bolingo na ngai
\q2 mpe nakobongola te boyengebene na ngai.
\b
\q1 
\v 35 Nakosambwisa te boyokani na ngai
\q2 mpe nakobongola te maloba na ngai.
\q1 
\v 36 Nalapaki yango na ndayi mbala moko
\q2 mpo na libela
\q1 na Kombo ya bosantu na ngai :
\q2 ‹ Nakokosa Davidi te ! ›
\q1 
\v 37 Libota na ye ya bokonzi ekowumela mpo na libela,
\q2 mpe kiti na ye ya bokonzi ekowumela
\q2 lokola moyi liboso na ngai.
\q1 
\v 38 Solo, lokola sanza, ekowumela na bokonzi
\q2 mpo na libela.
\q1 Motatoli oyo azali kuna kati na likolo
\q2 akoki kokosa te. »
\b
\q1 
\v 39 Nzokande, obwakaki, omonaki pamba,
\q2 osilikelaki mopakolami na Yo !
\q1 
\v 40 Owanganaki boyokani oyo osalaki
\q2 elongo na mosali na Yo,
\q1 obwakaki na mabele mpe osambwisaki
\q2 motole na ye.
\b
\q1 
\v 41 Otobolaki madusu kati na bamir na ye nyonso
\q2 mpe obukaki bandako na ye, oyo batonga makasi ;
\q1 
\v 42 bato nyonso oyo balekaki wana
\q2 babotolaki ye biloko,
\q2 mpe bavandi ya pembeni na ye bakomaki kotiola ye.
\b
\q1 
\v 43 Obakisaki makasi ya bayini na ye
\q2 mpe otondisaki banguna na ye nyonso na esengo,
\q1 
\v 44 osalaki kutu ete mopanga na ye ebalukela ye moko
\q2 mpe osungaki ye te na bitumba ;
\q1 
\v 45 osilisaki kongenga ya lokumu na ye,
\q2 obwakaki kiti na ye ya bokonzi na mabele ;
\q1 
\v 46 okomisaki moke mikolo ya bolenge na ye
\q2 mpe olatisaki ye kazaka ya soni.
\b
\q1 
\v 47 Yawe, kino tango nini ?
\q2 Okomibomba penza tango nyonso ?
\q2 Kino tango nini kanda na Yo ekongala lokola moto ?
\q1 
\v 48 Kanisa motango ya mikolo ya bomoi na ngai !
\q2 Okelaki penza bato mpo na suka
\q2 oyo ezanga ata tina !
\q1 
\v 49 Moto nani akoki kozala na bomoi
\q2 mpe azanga komona kufa ?
\q2 Nani akolonga kokima nguya ya mboka ya bakufi ?
\b
\q1 
\v 50 Nkolo, wapi bolingo na Yo ya kala
\q2 oyo alakaki Davidi na boyengebene na Yo
\q2 na nzela ya ndayi ?
\q1 
\v 51 Nkolo, kanisa ndenge bazali kosakanela
\q2 basali na Yo ;
\q1 kobosana te ete namemi mokumba
\q2 ya bato oyo nyonso !
\q1 
\v 52 Yawe, kanisa mafinga ya banguna na Yo,
\q2 oyo batiolaka bomoi ya mopakolami na Yo !
\b
\q1 
\v 53 Tika ete Yawe apambolama
\q2 libela na libela !
\qc Amen ! Amen !
\c 90
\ms1 Buku ya minei
\mr Nz 90.1–106.48
\cl Nzembo 90
\s1 Lakisa biso kotanga malamu motango ya mikolo na biso
\d 
\v 1 Losambo ya Moyize, moto na Nzambe.
\q1 Oh Nkolo, ozalaki ekimelo na biso,
\q2 na bikeke nyonso.
\q1 
\v 2 Liboso ete bangomba ezala,
\q2 liboso ete okela mabele mpe mokili,
\q2 libela na libela, ozali Nzambe.
\b
\q1 
\v 3 Ozongisaka moto na putulu,
\q2 pamba te oloba :
\q2 « Bino bato, bozonga na putulu ! »
\q1 
\v 4 Na miso na Yo, mibu nkoto moko ezali
\q2 lokola mokolo ya lobi oyo esili koleka,
\q2 lokola ngonga moko ya butu.
\q1 
\v 5 Olekisaka yango lokola pongi ya butu,
\q2 oyo na tongo, esilaka lokola lititi.
\q1 
\v 6 Na tongo, ebimisaka fololo mpe etelaka noki ;
\q2 kasi na pokwa, enzulukaka mpe ekawuki.
\b
\q1 
\v 7 Kanda na Yo elembisaka biso nzoto,
\q2 mpe kanda makasi na Yo epesaka biso bobangi.
\q1 
\v 8 Otiaka masumu na biso liboso na Yo
\q2 mpe obimisaka na polele makambo oyo tobombaka.
\b
\q1 
\v 9 Mikolo nyonso ya bomoi na biso elimwaka
\q2 mpo na kanda na Yo,
\q2 mpe mibu na biso esilaka lokola kolela.
\q1 
\v 10 Molayi ya bomoi na biso ekoki kozala
\q2 mibu tuku sambo
\q1 to mibu tuku mwambe mpo na bato
\q2 oyo baleki makasi ;
\q1 nzokande, etondi na pasi mpe na minyoko,
\q2 pamba te elekaka noki, mpe tolimwaka.
\b
\q1 
\v 11 Nani ayebi makasi ya kanda na Yo ?
\q2 Moto oyo azalaka na botosi mingi epai na Yo
\q2 asosolaka malamu kanda makasi na Yo.
\q1 
\v 12 Lakisa biso kotanga malamu
\q2 mikolo ya bomoi na biso
\q2 mpo ete tokoma na mitema ya bwanya.
\b
\q1 
\v 13 Yawe, lembisa moke !
\q2 Kino tango nini ekowumela ?
\q2 Yokela basali na Yo mawa !
\q1 
\v 14 Tongo nyonso, tondisaka biso na bolingo na Yo
\q2 mpe tokoganga na esengo,
\q2 mpe tokosepela mikolo nyonso ya bomoi na biso.
\b
\q1 
\v 15 Zongisela biso na mikolo ya esengo,
\q2 mikolo oyo onyokolaki biso ;
\q1 zongisela biso na mibu ya esengo,
\q2 mibu oyo tomonaki pasi.
\q1 
\v 16 Tika ete biso, basali na Yo, tomona misala na Yo ;
\q2 mpe ete bana na biso bamona kongenga makasi
\q2 ya nkembo na Yo !
\q1 
\v 17 Tika ete boboto ya Nkolo, Nzambe na biso,
\q2 ezala elongo na biso !
\q1 Mpo na biso, sala ete misala na biso ekende liboso !
\q2 Iyo, sala ete misala na biso ekende kaka liboso !
\c 91
\cl Nzembo 91
\s1 Ebombamelo ya malonga
\q1 
\v 1 Moto oyo awumelaka kati na ebombamelo
\q2 ya Ye-Oyo-Aleki-Likolo
\q1 avandaka na se ya bobatelami
\q2 ya Nkolo-Na-Nguya-Nyonso.
\b
\q1 
\v 2 Nalobaka na tina na Yawe :
\q2 « Nzambe na ngai azali ebombamelo
\q1 mpe ndako makasi na ngai ;
\q2 natiaka elikya na ngai kati na Ye ! »
\b
\q1 
\v 3 Ye nde akangolaka yo wuta na mitambo
\q2 ya mokangi bandeke
\q2 mpe na bokono oyo ebikisaka te.
\q1 
\v 4 Abombaka yo na se ya mapapu na Ye,
\q2 mpe ozwaka ebombamelo ya malonga
\q2 na se ya mapapu na Ye ;
\q1 bolingo na Ye ebatelaka lokola nguba
\q2 mpe lokola elamba ya ebende.
\b
\q1 
\v 5 Okobanga te somo ya butu,
\q2 makonga oyo epumbwaka na moyi makasi,
\q1 
\v 6 bokono oyo etambolaka kati na molili
\q2 mpe pasi oyo ebebisaka na midi.
\b
\q1 
\v 7 Ezala bato nkoto moko bakweyi
\q2 pembeni na yo,
\q1 mpe bato nkoto zomi,
\q2 na ngambo ya loboko na yo ya mobali,
\q2 ekozwa yo ata moke te.
\q1 
\v 8 Okotala kaka na miso na yo
\q2 mpe okomona ndenge nini bato mabe bazali
\q2 kozwa etumbu lokola lifuti na bango.
\b
\q1 
\v 9 Soki otatoli :
\q2 « Yawe azali ebombamelo na ngai, »
\q2 mpe okomisi Ye-Oyo-Aleki-Likolo ekimelo na yo,
\q1 
\v 10 mabe ata moko te ekokweyela yo,
\q2 pasi ata moko te ekopusana na ndako na yo ;
\q1 
\v 11 pamba te akopesa mitindo na ba-anjelu na Ye
\q2 ete babatela yo malamu na banzela na yo nyonso.
\b
\q1 
\v 12 Bakomema yo na maboko na bango
\q2 mpo ete lokolo na yo etutana na libanga te ;
\q1 
\v 13 okotambola na likolo ya nkosi mpe ya etupa,
\q2 okonyata nkosi ya monene mpe dalagona.
\b
\q1 
\v 14 Lokola akangami na ngai, nakokangola ye ;
\q2 lokola ayebi Kombo na Ngai, nakobatela ye.
\q1 
\v 15 Soki abeleli ngai, nakoyanola ye ;
\q2 nakozala elongo na ye na tango ya pasi,
\q2 nakokangola ye mpe nakopesa ye lokumu.
\q1 
\v 16 Nakopesa ye bomoi molayi
\q2 mpe nakolakisa ye lobiko na ngai.
\c 92
\cl Nzembo 92
\s1 Ezali malamu kokumisa Yawe
\d 
\v 1 Nzembo ya koyemba na mokolo ya Saba.
\q1 
\v 2 Tala ndenge ezali malamu kosanzola Yawe
\q2 mpe koyemba mpo na lokumu ya Kombo na
\q2 Yo-Oyo-Oleki-Likolo !
\q1 
\v 3 Tala ndenge ezali malamu kosakola bolingo na Yo,
\q2 na tongo,
\q2 mpe boyengebene na Yo, na butu,
\q1 
\v 4 na lindanda ya basinga zomi
\q2 mpe na nzenze !
\q1 
\v 5 Yawe, misala na Yo esepelisaka ngai !
\q2 Nagangaka na esengo liboso ya misala
\q2 ya maboko na Yo.
\q1 
\v 6 Yawe, misala na Yo ezali minene,
\q2 mpe makanisi na Yo ezali mozindo !
\b
\q1 
\v 7 Moto ya kilikili ayebaka te,
\q2 mpe zoba asosolaka eloko moko te.
\q1 
\v 8 Tango bato mabe bakolaka lokola matiti,
\q2 mpe bato nyonso ya misala mabe bafulukaka,
\q2 ezalaka nde mpo ete babebisama libela.
\b
\q1 
\v 9 Kasi Yo, kuna na likolo,
\q2 ozali Yawe mpo na libela.
\q1 
\v 10 Yawe, banguna na Yo,
\q2 banguna na Yo bakokufa penza ;
\q2 bato nyonso ya misala mabe bakolimwa.
\b
\q1 
\v 11 Okomisi ngai makasi lokola mpakasa,
\q2 opakoli ngai mafuta ya sika.
\q1 
\v 12 Miso na ngai ekomi komona bayini na ngai,
\q2 mpe matoyi na ngai ekomi koyoka
\q1 banguna na ngai nyonso, oyo bamibongisa
\q2 mpo na kosala ngai mabe.
\b
\q1 
\v 13 Bato ya sembo bafulukaka lokola nzete ya mbila,
\q2 bakolaka lokola nzete ya sedele ya Libani.
\q1 
\v 14 Lokola bapikama ngwi
\q2 kati na Tempelo ya Yawe,
\q1 bamonaka bolamu kati na lopango
\q2 ya Nzambe na biso.
\b
\q1 
\v 15 Ata bakomi mibange, babotaka kaka,
\q2 bazalaka kaka makasi mpe kitoko,
\q1 
\v 16 basakolaka : « Yawe azali alima,
\q2 azali Libanga na biso ;
\q2 kati na Ye, mabe ezali te ! »
\c 93
\cl Nzembo 93
\s1 Yawe akonzaka mpo na libela na libela
\q1 
\v 1 Yawe azali kokonza, alati lokumu monene ;
\q2 Yawe alati penza lokumu monene
\q2 mpe amizingeli na nguya.
\b
\q1 Solo, mokili etelema ngwi, eninganaka te.
\q1 
\v 2 Kiti ya Bokonzi na Yo epikama wuta kala ;
\q2 seko na seko, ozali.
\b
\q1 
\v 3 Yawe, bibale egangaka !
\q2 Bibale etombolaka lokito na yango ;
\q2 bibale etombolaka makelele na yango.
\b
\q1 
\v 4 Yawe azali monene makasi,
\q2 na bisika ya likolo ;
\q1 aleki lokito ya mayi minene,
\q2 mpe bambonge milayi ya ebale monene.
\b
\q1 
\v 5 Yawe, malako na Yo ezali penza ya solo ;
\q2 bosantu elati Ndako na Yo mpo na libela.
\c 94
\cl Nzembo 94
\s1 Kino tango nini bato mabe bakolonga ?
\q1 
\v 1 Yawe, Nzambe oyo azongisaka
\q2 mabe na mabe,
\q1 Nzambe oyo azongisaka mabe na mabe,
\q2 mimonisa kati na nkembo na Yo !
\q1 
\v 2 Mosambisi ya mokili, telema
\q2 mpo na kozongisela bato ya lolendo
\q2 mabe na mabe na bango !
\b
\q1 
\v 3 Yawe, kino tango nini bato mabe,
\q2 kino tango nini bato mabe bakosepela ?
\q1 
\v 4 Bazali komilakisa, bazali kobimisa mafinga ;
\q2 bato nyonso ya misala mabe bazali komikumisa !
\q1 
\v 5 Yawe, bazali konyokola bato na Yo
\q2 mpe bazali koyokisa libula na Yo pasi ;
\q1 
\v 6 bazali koboma mwasi oyo akufisa mobali,
\q2 mopaya mpe bana bitike ;
\q1 
\v 7 bazali koloba :
\q2 « Yawe amonaka eloko moko te,
\q2 Nzambe ya Jakobi asosolaka eloko moko te ! »
\b
\q1 
\v 8 Bino bato ya kilikili, bososola !
\q2 Bazoba, bokokoma mayele tango nini ?
\b
\q1 
\v 9 Boni, Ye oyo asala litoyi akoki koyoka te ?
\q2 Ye oyo asala liso akoki komona te ?
\q1 
\v 10 Ye oyo apesaka bikolo etumbu
\q2 akoki kopesa etumbu te ?
\q2 Ye oyo apesaka bato boyebi.
\q1 
\v 11 Yawe ayebi makanisi ya bato ;
\q2 ayebi ete ezali na tina te.
\b
\q1 
\v 12 Yawe, esengo na moto oyo
\q2 ozali kozongisa na nzela,
\q2 moto oyo ozali kolakisa mibeko na Yo
\q1 
\v 13 mpo na kopesa ye bopemi na tango ya pasi,
\q2 kino libulu etimolama mpo na moto mabe !
\b
\q1 
\v 14 Pamba te Yawe asundolaka bato na Ye te,
\q2 abwakaka libula na Ye te.
\q1 
\v 15 Bakosambisa lisusu kolanda bosembo,
\q2 mpe bato nyonso oyo bazali na mitema alima
\q2 bakotosa bosembo yango.
\b
\q1 
\v 16 Nani akotelema mpo na ngai
\q2 mpo na kotelemela bato mabe ?
\q1 Nani akokotela ngai
\q2 liboso ya bato ya misala mabe ?
\q1 
\v 17 Ah, soki Yawe asungaki ngai te,
\q2 mbele nakendeki noki na mokili ya kufa !
\b
\q1 
\v 18 Soki nalobi :
\q2 « Makolo na ngai ekomi kolenga na somo, »
\q1 bolingo na Yo, Yawe, epesaka ngai makasi.
\q1 
\v 19 Soki natungisami na makanisi ebele,
\q2 kobondisama na Yo epesaka ngai esengo.
\b
\q1 
\v 20 Boni, bokonzi ya mabe oyo ememelaka bato pasi
\q2 na nzela ya mibeko na yango ;
\q2 boni, ezali lisanga moko elongo na Yo ?
\q1 
\v 21 Bato mabe basanganaka mpo na kobundisa
\q2 bomoi ya moto ya sembo
\q2 mpe kokatela moto oyo asali mabe te etumbu ya kufa.
\b
\q1 
\v 22 Kasi Yawe azali, mpo na ngai,
\q2 ndako batonga makasi ;
\q1 Nzambe na ngai azali libanga
\q2 epai wapi nazwaka ebombamelo.
\q1 
\v 23 Akozongisela bango mabe na bango
\q2 mpe akobebisa bango mpo na kanza na bango.
\q2 Solo, Yawe, Nzambe na ngai, akoboma bango.
\c 95
\cl Nzembo 95
\s1 Mokili mobimba ezali kati na maboko ya Yawe
\q1 
\v 1 Boya, toganga na esengo mpo na Yawe !
\q2 Tobetela Libanga na biso maboko,
\q2 pamba te azali Mobikisi na biso !
\q1 
\v 2 Tokende liboso na Ye
\q2 elongo na mabondeli ya kozongisa matondi,
\q2 tobetela Ye maboko elongo na banzembo.
\b
\q1 
\v 3 Pamba te Yawe azali Nzambe Monene,
\q2 azali Mokonzi Monene,
\q2 na likolo ya banzambe nyonso.
\q1 
\v 4 Asimbi mozindo ya mokili kati na loboko na Ye ;
\q2 mpe basonge ya bangomba ezali ya Ye.
\q1 
\v 5 Ebale monene ezali ya Ye,
\q2 azali Mokeli na yango ;
\q1 mabele ya kokawuka ezali mpe ya Ye,
\q2 asala yango na maboko na Ye.
\b
\q1 
\v 6 Boya, togumbama mpe tofukama,
\q2 tobuka mabolongo na biso liboso ya Yawe,
\q2 Mokeli na biso !
\b
\q1 
\v 7 Pamba te azali Nzambe na biso ;
\q2 tozali bato oyo aleisaka,
\q2 etonga oyo abatelaka.
\b
\q1 Lelo, soki boyoki mongongo na Ye,
\q2 
\v 8 « boyeisa mitema na bino mabanga te,
\q2 ndenge bosalaki na Meriba ;
\q1 ndenge bosalaki na mokolo wana
\q2 ya Masa kati na esobe
\q1 
\v 9 epai wapi batata na bino batombokelaki ngai
\q2 mpe bamekaki ngai atako bamonaki ngai kosala.
\b
\q1 
\v 10 Mibu tuku minei, nayinaki bato
\q2 ya ekeke wana mpe nalobaki :
\q1 ‹ Bazali bato oyo mitema na bango ebeba,
\q2 bayebaka banzela na ngai te. ›
\q1 
\v 11 Yango wana, kati na kanda na ngai, nakati seleka :
\q2 ‹ Bakotikala kokota te
\q2 kati na bopemi na ngai ! › »
\c 96
\cl Nzembo 96
\s1 Mokili mobimba esanzolaka Yawe, Mokonzi na yango
\r (Nz 105; 106; 1Ma 16.23-33)
\q1 
\v 1 Boyembela Yawe nzembo ya sika !
\q2 Bino nyonso, bato ya mokili mobimba,
\q2 boyembela Yawe !
\q1 
\v 2 Boyembela Yawe,
\q2 bopambola Kombo na Ye !
\q1 Bopanza sango ya lobiko na Ye,
\q2 mokolo na mokolo !
\q1 
\v 3 Bopanza sango ya nkembo na Ye kati na mabota !
\q2 Boyebisa bato misala na Ye ya kokamwa
\q2 kati na bikolo nyonso.
\b
\q1 
\v 4 Pamba te Yawe azali monene
\q2 mpe abongi na lokumu,
\q2 azali somo makasi mpe aleki banzambe nyonso.
\q1 
\v 5 Banzambe nyonso ya bikolo ezali bikeko ya pamba,
\q2 nzokande Yawe akela likolo.
\q1 
\v 6 Kongenga mpe nkembo monene ezali liboso na Ye,
\q2 nguya mpe nkembo ezali
\q2 kati na Esika na Ye ya bule.
\b
\q1 
\v 7 Bino bituka ya mabota, bosanzola Yawe ;
\q2 bosanzola Yawe na kopanza
\q2 sango ya nkembo mpe nguya na Ye !
\q1 
\v 8 Bosanzola Yawe mpe bopesa
\q2 Kombo na Ye nkembo !
\q1 Bomema makabo na bino,
\q2 bokota na lopango na Ye !
\q1 
\v 9 Bogumbama liboso ya Yawe
\q2 oyo bosantu na Ye ezali kongenga makasi !
\q1 Bino bavandi ya mokili mobimba,
\q2 bolenga liboso na Ye !
\b
\q1 
\v 10 Boloba kati na mabota :
\q2 « Yawe azali Mokonzi !
\q1 Mokili elendisama makasi, ekoningana te.
\q2 Yawe asambisaka bato na bosembo. »
\b
\q1 
\v 11 Tika ete likolo esepela,
\q2 mpe mabele ezala kati na esengo !
\q1 Tika ete ebale monene elongo na nyonso
\q2 oyo ezali kati na yango epesa lokito !
\q1 
\v 12 Tika ete zamba mobimba elongo na nyonso
\q2 oyo ezali kati na yango esepela,
\q1 mpe tika ete banzete nyonso ya zamba eganga
\q2 na esengo
\q1 
\v 13 liboso ya Yawe, pamba te azali koya !
\q2 Solo, azali koya kosambisa mabele ;
\q1 akosambisa mokili na bosembo,
\q2 mpe bikolo kolanda boyengebene na Ye.
\c 97
\cl Nzembo 97
\s1 Nzambe Monene ya mokili mobimba
\q1 
\v 1 Yawe azali kokonza !
\q2 Tika ete mabele esepela ;
\q2 tika ete ebele ya bisanga ezala na esengo !
\b
\q1 
\v 2 Mapata mpe molili makasi ezingeli Ye,
\q2 bosembo mpe bosolo ezali miboko
\q2 ya Kiti na Ye ya Bokonzi.
\q1 
\v 3 Moto etambolaka liboso na Ye,
\q2 ezikisaka banguna na Ye, oyo bazingeli Ye.
\b
\q1 
\v 4 Mikalikali na Ye engengisaka mokili ;
\q2 mpe tango mabele emonaka bongo, elengaka.
\q1 
\v 5 Bangomba enyangwamaka lokola mafuta
\q2 liboso ya Yawe,
\q2 liboso ya Nkolo ya mokili mobimba.
\b
\q1 
\v 6 Likolo epanzaka sango ya bosembo na Ye,
\q2 mpe bikolo nyonso bamonaka nkembo na Ye.
\q1 
\v 7 Tika ete soni ekanga basambeli nyonso ya bikeko,
\q2 bato oyo bamikumisaka mpo na banzambe ya lokuta !
\q2 Bino banzambe nyonso, bogumbama liboso na Ye !
\b
\q1 
\v 8 Yawe, Siona eyoki yango mpe esepeli ;
\q2 bingumba ya Yuda ezali na esengo
\q2 mpo na mikano na Yo !
\q1 
\v 9 Pamba te, na mokili mobimba,
\q2 Yo nde Yawe, ozali Ye-Oyo-Aleki-Likolo ;
\q2 oleki banzambe nyonso.
\b
\q1 
\v 10 Bino bato oyo bolingaka Yawe,
\q2 boyina mabe !
\q1 Yawe abatelaka bomoi ya bayengebene na Ye
\q2 mpe akangolaka bango na maboko ya bato mabe.
\b
\q1 
\v 11 Moyi elonami mpo na moto ya sembo,
\q2 mpe esengo, mpo na bato
\q2 oyo bazali na mitema alima.
\q1 
\v 12 Bino bato ya sembo,
\q2 bosepela kati na Yawe ;
\q2 bosanzola Ye na kotatola bosantu na Ye.
\c 98
\cl Nzembo 98
\s1 Nzambe azali koya kosambisa mabele
\d 
\v 1 Nzembo.
\q1 Boyembela Yawe nzembo ya sika,
\q2 pamba te asalaka makambo ya kokamwa !
\q1 Na nguya mpe na bokonzi na Ye ya bonzambe,
\q2 alongaki.
\b
\q1 
\v 2 Yawe atalisaki elonga na Ye,
\q2 amonisaki bosembo na Ye epai ya bikolo.
\q1 
\v 3 Akanisaki bolingo mpe bosembo na Ye
\q2 mpo na libota ya Isalaele.
\q1 Kino na suka ya mokili,
\q2 elonga ya Nzambe na biso emonanaki.
\q1 
\v 4 Mokili mobimba, bobetela Yawe maboko,
\q2 boyemba banzembo ya esengo
\q2 mpe bobeta mindule !
\q1 
\v 5 Bobetela Yawe lindanda,
\q2 boyembela Ye banzembo na lokito ya nzenze !
\q1 
\v 6 Bobeta maboko liboso ya Yawe, Mokonzi,
\q2 na lokito ya bakelelo mpe ya maseke.
\b
\q1 
\v 7 Tika ete ebale monene elongo na nyonso
\q2 oyo ezali kati na yango,
\q2 mokili mpe bavandi na yango, bapesa lokito !
\q1 
\v 8 Tika ete bibale ebeta maboko
\q2 mpe bangomba nyonso eganga na esengo
\q1 
\v 9 liboso ya Yawe, pamba te azali koya
\q2 kosambisa mabele !
\q2 Akokata makambo na yango na bosembo.
\c 99
\cl Nzembo 99
\s1 Bogumbamela Yawe, pamba te azali Mosantu
\q1 
\v 1 Yawe azali kokonza ;
\q2 tika ete bato balenga !
\q1 Avandi na Kiti ya Bokonzi kati na basheribe ;
\q2 tika ete mabele eningana !
\q1 
\v 2 Yawe azali monene kati na Siona,
\q2 mpe Bokonzi na Ye ezali likolo ya bikolo nyonso.
\q1 
\v 3 Tika ete Kombo na Yo ya monene
\q2 mpe ya somo esanzolama ;
\q2 ezali bule !
\b
\q1 
\v 4 Mokonzi azali na nguya, alingaka bosolo.
\q2 Olendisaka bosembo.
\q2 Osalaki bosembo mpe bosolo kati na Jakobi.
\q1 
\v 5 Bonetola Yawe, Nzambe na biso,
\q2 mpe bogumbama liboso ya enyatelo makolo na Ye ;
\q2 azali Mosantu.
\b
\q1 
\v 6 Moyize mpe Aron kati na Banganga-Nzambe na Ye,
\q2 mpe Samuele kati na bato
\q1 oyo bazalaki kobelela Kombo na Ye,
\q2 bazalaki kobelela Yawe,
\q2 mpe Ye azalaki koyanola bango.
\q1 
\v 7 Azalaki koloba na bango kati na likonzi ya lipata.
\q2 Babatelaki malako na Ye
\q2 mpe mibeko oyo apesaki bango.
\b
\q1 
\v 8 Yawe, Nzambe na biso, oyanolaki bango.
\q2 Mpo na bango, ozalaki Nzambe oyo alimbisaka
\q1 atako opesaki bango etumbu
\q2 mpo na misala na bango ya mabe.
\b
\q1 
\v 9 Bonetola Yawe, Nzambe na biso,
\q2 mpe bogumbama na kotala
\q1 na ngambo ya ngomba na Ye ya bule.
\q2 Pamba te Yawe, Nzambe na biso, azali bule.
\c 100
\cl Nzembo 100
\s1 Yawe asanzolamaka kati na bato na Ye
\d 
\v 1 Nzembo ya kozongisa matondi.
\q1 Bino nyonso bato ya mokili mobimba,
\q2 boganga na esengo epai na Yawe !
\q1 
\v 2 Bosalela Yawe na esengo,
\q2 mpe boya liboso na Ye na banzembo ya esengo.
\b
\q1 
\v 3 Boyeba ete Yawe nde azali Nzambe ;
\q2 Ye nde asala biso, mpe tozali bato na Ye.
\q2 Solo, tozali bato na Ye mpe etonga oyo aleisaka.
\b
\q1 
\v 4 Bokota na bikuke na Ye na kozongisa matondi,
\q2 bokota na lopango na Ye na kokumisa.
\q2 Bosanzola Ye, bopambola Kombo na Ye.
\q1 
\v 5 Pamba te Yawe azali malamu ;
\q2 bolingo na Ye ewumelaka seko na seko,
\q2 mpe boyengebene na Ye, libela na libela.
\c 101
\cl Nzembo 101
\s1 Komipesa mpo na kobundisa mabe
\d 
\v 1 Nzembo ya Davidi.
\q1 Nakoyemba bolingo mpe bosembo ;
\q2 nakoyembela nde Yo, Yawe.
\b
\q1 
\v 2 Nakolanda na bokebi nzela ya bato
\q2 oyo bazangi pamela.
\q1 Okoya epai na ngai tango nini ?
\q2 Kati na ndako na ngai, nakotambola malamu
\q2 na motema ezangi pamela.
\b
\q1 
\v 3 Nakotala eloko moko te ya mabe ;
\q2 nayinaka misala ya bato oyo bazangi kondima,
\q2 ekoki kokangama na ngai te.
\q1 
\v 4 Mosika na ngai, motema ya kilikili ;
\q2 naboyi kosala mabe.
\q1 
\v 5 Nakosala ete avanda kimia,
\q2 moto oyo apanzaka, na nkuku, basango ya lokuta
\q1 mpo na kobebisa lokumu ya baninga.
\q2 Nakokoka te kotala moto ya lolendo
\q2 mpe moto ya lofundu.
\b
\q1 
\v 6 Nakopona nde bato ya sembo kati na mokili
\q2 mpo ete bavanda pembeni na ngai ;
\q1 moto na etamboli ezanga pamela
\q2 nde akozala mosali na ngai.
\q1 
\v 7 Kati na ndako na ngai, mokosi akovanda te ;
\q2 liboso na ngai, mokosi akotelema te.
\q1 
\v 8 Tongo nyonso, nakosala ete bato nyonso ya misala mabe
\q2 kati na mokili bavanda kimia ;
\q1 nakolongola na engumba ya Yawe
\q2 bato nyonso ya mabe.
\c 102
\cl Nzembo 102
\s1 Libondeli ya moto na pasi
\d 
\v 1 Libondeli ya moto na pasi, oyo abungisi elikya mpe azali kolela liboso ya Yawe.
\q1 
\v 2 Yawe, yoka libondeli na ngai !
\q2 Tika ete koganga na ngai ekoma kino epai na Yo !
\q1 
\v 3 Kobombela ngai elongi na Yo te,
\q2 wana nazali na pasi.
\q1 Yoka libondeli na ngai
\q2 na mokolo oyo nazali kobelela Yo ;
\q2 yanola ngai noki !
\b
\q1 
\v 4 Pamba te mikolo ya bomoi na ngai ezali kolimwa
\q2 lokola molinga,
\q1 mikuwa na ngai ezali kozika
\q2 lokola makala ya moto.
\q1 
\v 5 Motema na ngai ebungisi elikya
\q2 mpe ezali komitungisa lokola matiti oyo bakati ;
\q1 mpo na yango, nakomi ata kobosana
\q2 kolia bilei na ngai.
\q1 
\v 6 Mpo ete naleli makasi,
\q2 natikali kaka na poso ya nzoto likolo ya mikuwa.
\b
\q1 
\v 7 Nakomi lokola esulungutu ya esobe,
\q2 lokola esulungutu ya bisika oyo ebeba.
\q1 
\v 8 Pongi ekimi ngai ;
\q2 nakomi lokola ndeke oyo etikali yango moko
\q2 na likolo ya ndako.
\b
\q1 
\v 9 Banguna na ngai batombokeli ngai,
\q2 bazali kofinga ngai tango nyonso
\q1 mpe bazali kosalela kombo na ngai
\q2 mpo na kolakela bato mabe.
\q1 
\v 10 Nakomi kolia putulu na esika ya bilei,
\q2 mpe komela mayi esangana na mpinzoli na ngai.
\b
\q1 
\v 11 Mpo na kanda monene na Yo,
\q2 otombokeli ngai mpe obwaki ngai mosika.
\q1 
\v 12 Mikolo ya bomoi na ngai ezali kokima lokola elili,
\q2 mpe nakawuki lokola matiti.
\b
\q1 
\v 13 Kasi Yo Yawe, ozali Mokonzi
\q2 mpo na libela,
\q2 ozali Nzambe seko na seko.
\q1 
\v 14 Okotelema solo mpo na Siona,
\q2 pamba te ekomi tango ya koyokela yango mawa ;
\q2 tango oyo ekatama ekoki.
\q1 
\v 15 Pamba te biso basali na Yo, tosepelaka
\q2 na mabanga na yango,
\q2 mpe toyokelaka putulu na yango mawa.
\b
\q1 
\v 16 Bikolo ekotosa Yawe,
\q2 mpe bakonzi nyonso ya mokili bakondima
\q2 nkembo na Yo.
\q1 
\v 17 Pamba te Yawe akotonga lisusu Siona
\q2 mpe akomonana kati na nkembo na Ye.
\q1 
\v 18 Akoyanola libondeli ya bato
\q2 oyo babungisaki biloko,
\q2 mpe akondima mabondeli na bango.
\b
\q1 
\v 19 Tika ete bakoma yango
\q2 mpo na ekeke oyo ekolanda,
\q2 mpo ete bikelamu ya sika ekumisa Yawe.
\q1 
\v 20 Wuta na Esika na Ye ya bule,
\q2 wuta na likolo, Yawe atalaki biso
\q2 awa na mokili
\q1 
\v 21 mpo na koyoka kolela ya bakangami
\q2 kati na boloko
\q2 mpe kokangola bato oyo bazwaki etumbu ya kufa.
\b
\q1 
\v 22 Kombo ya Yawe ekokende sango
\q2 kati na Siona,
\q2 mpe masanzoli na Ye, kati na Yelusalemi
\q1 
\v 23 tango bato mpe bikolo bakosangana
\q2 mpo na kogumbamela Yawe.
\b
\q1 
\v 24 Na bomoi na ngai, abukaki lolendo
\q2 ya makasi na ngai,
\q2 mpe akitisaki motango ya mikolo ya bomoi na ngai.
\q1 
\v 25 Nalobaki :
\q2 « Nzambe na ngai,
\q1 Yo oyo ozali na bomoi seko na seko,
\q2 koboma ngai te na kati-kati ya mikolo
\q2 ya bomoi na ngai !
\q1 
\v 26 Na kala, otiaki miboko ya mokili,
\q2 mpe maboko na Yo esalaki Likolo.
\q1 
\v 27 Bango, bakokufa ;
\q2 kasi Yo, okotikala seko na seko.
\q1 Nzoto na bango ekolemba lokola elamba ;
\q2 okobongola bango lokola kazaka, mpe bakolimwa.
\q1 
\v 28 Kasi Yo, ozali ndenge moko,
\q2 mibu na Yo ekotikala kosuka te.
\b
\q1 
\v 29 Bana ya basali na Yo bakozwa esika ya kovanda,
\q2 mpe bakitani na bango bakowumela liboso na Yo. »
\c 103
\cl Nzembo 103
\s1 Tika ete bomoi na ngai mobimba ekumisa Yawe
\d 
\v 1 Nzembo ya Davidi.
\q1 Eh molimo na ngai, pambola Yawe !
\q2 Tika ete motema na ngai mobimba epambola
\q2 Kombo na Ye ya bule !
\q1 
\v 2 Eh molimo na ngai, pambola Yawe
\q2 mpe kobosana ata moko te
\q2 kati na misala malamu na Ye !
\q1 
\v 3 Ye nde alimbisaka masumu na Yo nyonso,
\q2 abikisaka yo na bokono nyonso,
\q1 
\v 4 akangolaka bomoi na yo wuta na libulu,
\q2 alatisaka yo motole ya bolingo mpe ya mawa,
\q1 
\v 5 atondisaka bomoi na yo na esengo
\q2 mpe akomisaka yo elenge lokola mpongo.
\b
\q1 
\v 6 Yawe asalaka mpo na bosembo,
\q2 akotelaka banyokolami nyonso.
\q1 
\v 7 Amonisaki banzela na Ye epai ya Moyize,
\q2 mpe bikamwa na Ye epai ya bato ya Isalaele.
\b
\q1 
\v 8 Yawe ayokelaka bato mawa
\q2 mpe asalelaka bango bolamu,
\q2 asilikaka noki te mpe atonda na bolingo ;
\q1 
\v 9 azwaka biso makambo te tango nyonso,
\q2 abombaka kanda na Ye te mpo na libela ;
\q1 
\v 10 apamelaka biso te kolanda masumu na biso,
\q2 azongiselaka biso te kolanda mabe na biso.
\b
\q1 
\v 11 Ndenge likolo etombolama mosika ya mabele,
\q2 ndenge wana mpe bolingo na Ye ezali monene
\q2 mpo na bato oyo batosaka Ye ;
\q1 
\v 12 ndenge este ezali mosika ya weste,
\q2 ndenge wana mpe abwakaka masumu na biso
\q2 mosika na biso.
\b
\q1 
\v 13 Ndenge tata alingaka makasi bana na ye,
\q2 ndenge wana mpe Yawe alingaka makasi
\q2 bato oyo batosaka Ye ;
\q1 
\v 14 pamba te Yawe ayebi na eloko nini asala biso,
\q2 ayebi malamu ete tozali putulu.
\b
\q1 
\v 15 Mikolo ya bomoi ya moto ezali lokola matiti,
\q2 ebongaka lokola fololo ya bilanga ;
\q1 
\v 16 nzokande soki kaka mopepe ebeti yango,
\q2 ezalaka lisusu te,
\q2 mpe esika epai wapi ezalaki ebosani yango.
\q1 
\v 17 Kasi bolingo ya Yawe
\q2 mpo na bato oyo batosaka Ye,
\q1 mpe bosembo na Ye
\q2 mpo na bakitani na bango,
\q1 
\v 18 mpo na bato oyo babatelaka boyokani na Ye
\q2 mpe batosaka mibeko na Ye,
\q2 ezali ya libela na libela.
\b
\q1 
\v 19 Yawe atia Kiti na Ye ya Bokonzi
\q2 kati na Likolo,
\q2 azali Mokonzi ya mokili mobimba.
\q1 
\v 20 Bopambola Yawe,
\q2 bino ba-anjelu na Ye nyonso oyo bozali na nguya
\q2 mpe botosaka mitindo na Ye.
\q1 
\v 21 Bopambola Yawe, bino mampinga na Ye nyonso
\q2 oyo bokokisaka mokano na Ye.
\q1 
\v 22 Bopambola Yawe, bino bikelamu na Ye nyonso,
\q2 kati na bisika nyonso ya Bokonzi na Ye.
\q2 Eh molimo na ngai, pambola Yawe !
\c 104
\cl Nzembo 104
\s1 Lokumu epai na Yawe
\q1 
\v 1 Eh molimo na ngai, pambola Yawe !
\b
\q1 Yawe, Nzambe na ngai, ozali monene !
\q2 Olata kongenga mpe lokumu,
\q1 
\v 2 omifinika moyi lokola kazaka,
\q2 otanda likolo lokola ndako ya kapo.
\b
\q1 
\v 3 Opika makonzi na yango na mayi ya likolo,
\q2 okomisaka mapata shar na Yo,
\q2 otambolaka na mapapu ya mopepe.
\q1 
\v 4 Okomisaka bantoma na Yo mipepe,
\q2 mpe basali na Yo, ndemo ya moto.
\b
\q1 
\v 5 Otia mokili na likolo ya miboko na yango
\q2 mpo ete eningana te seko na seko.
\q1 
\v 6 Ozipa yango na mayi monene lokola elamba ;
\q2 mayi ezalaki kovanda na likolo ya bangomba.
\b
\q1 
\v 7 Kasi na pamela na Yo, mayi ekimaki ;
\q2 na lokito ya kake na Yo, mayi etiolaki,
\q1 
\v 8 emataki na likolo ya bangomba,
\q2 ekitaki na mabwaku,
\q2 na bisika oyo obongisaki mpo na yango.
\q1 
\v 9 Otiaki mondelo oyo ekoki koleka te ;
\q2 ekozonga lisusu te kozipa mokili.
\b
\q1 
\v 10 Obimisaka mayi ya bitima
\q2 mpo na kosopa yango na mayi minene
\q2 oyo elekaka na kati-kati ya bangomba ;
\q1 
\v 11 ekomaka mayi ya komela
\q2 mpo na banyama nyonso ya bilanga
\q2 mpe mpo na ba-ane ya zamba.
\q1 
\v 12 Bandeke ya likolo evandaka
\q2 pembeni ya mayi yango
\q2 mpe eyembaka kati na makasa.
\b
\q1 
\v 13 Wuta na bandako na Yo ya likolo,
\q2 onokisaka mvula na likolo ya bangomba ;
\q2 mokili etondi na mbuma ya misala na Yo.
\q1 
\v 14 Matiti ebotaka mpo na bibwele,
\q2 mpe milona ya bato ekolaka
\q2 mpo ete mabele ebotela bango bilei,
\q1 
\v 15 vino mpo na kosepelisa mitema na bango,
\q2 mafuta mpo na kongengisa bilongi na bango,
\q2 mpe mapa mpo na kolendisa mitema na bango.
\b
\q1 
\v 16 Banzete ya Yawe etondi na mayi ;
\q2 ndenge wana nde ezali, banzete ya sedele ya Libani,
\q2 oyo Yawe alona.
\q1 
\v 17 Bandeke esalaka bazala na yango kuna,
\q2 mpe nkoko evandaka na banzete ya sipele.
\q1 
\v 18 Bangomba milayi ezali ekimelo
\q2 mpo na bantaba ya zamba,
\q1 mpe madusu ya mabanga ezali bibombamelo
\q2 mpo na bampanya ya zamba.
\b
\q1 
\v 19 Osala sanza mpo na koyeba mikolo ya bafeti.
\q2 Moyi eyebi tango na yango ya kolala.
\q1 
\v 20 Otindaka molili, mpe butu ekomaka.
\q2 Bongo banyama nyonso ya zamba ekomaka
\q2 kotambola-tambola.
\q1 
\v 21 Bana ya nkosi egangaka sima na nyama
\q2 mpe esengaka bilei epai ya Nzambe.
\q1 
\v 22 Soki moyi ebimi, nkosi elongwaka,
\q2 ezongaka mpo na kolala na bisika na yango ;
\q1 
\v 23 kasi moto abimaka mpo na kokende na mosala na ye
\q2 mpe asalaka kino na pokwa.
\b
\q1 
\v 24 Oh Yawe, misala na Yo ezali ebele !
\q2 Osalaki nyonso na bwanya ;
\q2 mokili etondi na biloko oyo okela.
\q1 
\v 25 Tala ndenge ebale monene ezali
\q2 molayi mpe epanzana,
\q1 etonda na banyama oyo tokoki kotanga te,
\q2 kobanda na oyo eleki mike kino na oyo eleki minene.
\q1 
\v 26 Kuna, bamasuwa ekendeke mpe ezongaka ;
\q2 bongo Leviatani oyo osala mpo ete esakanaka kuna.
\b
\q1 
\v 27 Nyonso etalelaka Yo
\q2 mpo ete opesa yango bilei na tango oyo ekoki.
\q1 
\v 28 Opesaka bilei, mpe ezwaka yango ;
\q2 ofungolelaka yango loboko na Yo,
\q2 mpe etondaka na biloko.
\b
\q1 
\v 29 Tango obombaka elongi na Yo,
\q2 somo ekangaka yango ;
\q1 tango olongolaka yango pema,
\q2 ekufaka mpe ezongaka na putulu ;
\q1 
\v 30 tango otindaka pema Yo, ezwaka bomoi ;
\q2 mpe okomisaka mokili sika.
\b
\q1 
\v 31 Tika ete nkembo ya Yawe ewumela
\q2 libela na libela !
\q2 Tika ete Yawe asepela na misala na Ye !
\q1 
\v 32 Soki atali mokili, mokili elengaka ;
\q2 soki asimbi bangomba, ebimisaka milinga.
\b
\q1 
\v 33 Nakoyembela Yawe
\q2 bomoi na ngai mobimba ;
\q1 nakoyembela Nzambe na ngai
\q2 tango nyonso nazali na bomoi.
\q1 
\v 34 Tika ete maloba na ngai esepelisa Ye !
\q2 Tika ete Yawe azala esengo na ngai !
\q1 
\v 35 Tika ete bato ya masumu basila na mokili,
\q2 mpe bato mabe bazala lisusu te !
\b
\q1 Oh molimo na ngai, pambola Yawe !
\q2 Aleluya, bokumisa Yawe !
\c 105
\cl Nzembo 105
\s1 Nzambe azali bolingo
\q1 
\v 1 Bokumisa Yawe, bobelela Kombo na Ye !
\q2 Bopanza sango ya misala minene na Ye kati na bikolo !
\q1 
\v 2 Boyemba mpo na lokumu na Ye,
\q2 bosanzola Ye na mindule !
\q1 Botatolaka tango nyonso
\q2 misala minene na Ye nyonso !
\b
\q1 
\v 3 Bosepela na Kombo na Ye ya bule !
\q2 Tika ete mitema ya bato
\q2 oyo balukaka Yawe etonda na esengo !
\q1 
\v 4 Bomipesa na Yawe.
\q2 Bosenga makasi na Ye.
\q2 Bolukaka tango nyonso elongi na Ye.
\b
\q1 
\v 5 Bokanisa bikamwa, makambo minene oyo asalaki
\q2 mpe bitumbu oyo apesaki,
\q1 
\v 6 bino, bakitani ya Abrayami, mosali na Ye ;
\q2 bino, baponami na Ye, bana mibali ya Jakobi !
\b
\q1 
\v 7 Yawe azali Nzambe na biso,
\q2 mikano na Ye ekambaka mokili mobimba.
\q1 
\v 8 Akanisaka tango nyonso Boyokani na Ye,
\q2 bilaka na Ye mpo na bikeke nkoto moko,
\q1 
\v 9 boyokani oyo asalaki elongo na Abrayami,
\q2 mpe ndayi oyo alapaki epai ya Izaki.
\q1 
\v 10 Akokisaki bosolo na yango epai ya Jakobi
\q2 lokola mobeko,
\q2 epai ya Isalaele lokola boyokani ya libela na libela,
\q1 
\v 11 tango alobaki :
\q2 « Nakopesa yo mokili ya Kanana
\q2 lokola libula oyo epesameli yo ! »
\b
\q1 
\v 12 Na tango wana, bazalaki kaka
\q2 motango moke ya bato
\q2 mpe bapaya kati na yango ;
\q1 
\v 13 bazalaki koyengayenga
\q2 longwa na ekolo moko kino na ekolo mosusu,
\q2 longwa na mokili moko kino na mokili mosusu.
\b
\q1 
\v 14 Atikaki moto moko te konyokola bango ;
\q2 apamelaki bakonzi na tina na bango :
\q1 
\v 15 « Bosimba bapakolami na Ngai te,
\q2 bosala mabe te epai na basakoli na Ngai ! »
\b
\q1 
\v 16 Abengisaki nzala makasi kati na mboka,
\q2 azangisaki bango bilei.
\q1 
\v 17 Atindaki moto moko liboso na bango :
\q2 Jozefi oyo atekamaki lokola mowumbu.
\q1 
\v 18 Bakangaki makolo na ye na minyololo
\q2 mpe batiaki bibende na kingo na ye,
\q1 
\v 19 kino makambo oyo Jozefi asakolaki ekokisamaki,
\q2 kino Liloba na Yawe etalisaki
\q2 ete Jozefi alobaki solo.
\b
\q1 
\v 20 Mokonzi apesaki mitindo
\q2 ete bafungola ye minyololo,
\q2 mokambi atikaki ye na bonsomi.
\q1 
\v 21 Akomisaki ye nkolo ya ndako na ye
\q2 mpe moyangeli ya biloko na ye nyonso,
\q1 
\v 22 mpo ete akonza bakambi na ye
\q2 mpe alakisa bwanya epai ya bapesi toli ya mokonzi.
\b
\q1 
\v 23 Bongo Isalaele akendeki na Ejipito ;
\q2 mpe Jakobi avandaki lokola mopaya
\q2 kati na mokili ya Cham.
\b
\q1 
\v 24 Yawe asalaki ete bato na Ye babota mingi,
\q2 mpe akomisaki bango makasi
\q2 koleka banguna na bango.
\q1 
\v 25 Abongolaki mitema ya banguna yango
\q2 mpo ete bayina bato na Ye
\q2 mpe banyokola bango makasi.
\b
\q1 
\v 26 Atindaki mosali na Ye, Moyize,
\q2 mpe Aron oyo aponaki.
\q1 
\v 27 Na mitindo na Ye Nzambe,
\q2 basalaki bikamwa kati na Ejipito,
\q2 misala minene kati na mokili ya Cham.
\q1 
\v 28 Atindaki molili oyo ekotaki kati na mokili,
\q2 mpe bato ya Ejipito batombokelaki maloba na Ye te.
\q1 
\v 29 Abongolaki mayi makila,
\q2 mpe abomaki mbisi na yango.
\q1 
\v 30 Mokili na bango etondaki na magorodo
\q2 kino na bashambre ya mokonzi na bango.
\b
\q1 
\v 31 Na mitindo na Ye,
\q2 banzinzi oyo eswaka mpe bangungi eyaki
\q2 na mboka mobimba.
\q1 
\v 32 Na esika ya mvula,
\q2 atindelaki bango mvula ya mabanga
\q2 mpe abetisaki kake kati na mokili na bango.
\q1 
\v 33 Abebisaki bilanga na bango ya vino mpe ya figi,
\q2 mpe abukaki banzete ya mboka na bango.
\b
\q1 
\v 34 Na mitindo na Ye,
\q2 mabanki mpe makelele oyo bakokaki kotanga te
\q2 esopanaki,
\q1 
\v 35 eliaki matiti nyonso ya mobesu
\q2 kati na mokili na bango,
\q2 eliaki bambuma ya mabele na bango.
\b
\q1 
\v 36 Abomaki bana liboso nyonso
\q2 kati na mokili na bango,
\q2 bambuma ya liboso ya makasi na bango.
\q1 
\v 37 Abimisaki Isalaele, bato na Ye,
\q2 elongo na palata mpe wolo ;
\q1 mpe moko te atiaki tembe
\q2 kati na mabota na bango.
\b
\q1 
\v 38 Ejipito esepelaki komona bango kobima,
\q2 pamba te somo ya Isalaele ekangaki bango.
\b
\q1 
\v 39 Atandaki lipata mpo na kobatela bango,
\q2 mpe moto mpo na kopesa pole na butu.
\b
\q1 
\v 40 Ndenge kaka basengaki, atindelaki bango bakayi
\q2 mpe atondisaki bango na bilei ya likolo.
\q1 
\v 41 Afungolaki libanga, mpe mayi ebimaki,
\q2 etiolaki lokola ebale kati na esobe.
\b
\q1 
\v 42 Mpo ete akanisaki elaka ya bule
\q2 oyo apesaki mosali na Ye, Abrayami,
\q1 
\v 43 abimisaki na esengo bato na Ye,
\q2 baponami na Ye na koganga ya esengo.
\b
\q1 
\v 44 Apesaki bango mabele ya bikolo mosusu
\q2 mpe bazwaki lokola libula mosala ya bikolo yango
\q1 
\v 45 mpo ete babatela mitindo na Ye
\q2 mpe batosa mibeko na Ye.
\b
\q1 Bokumisa Yawe !
\c 106
\cl Nzembo 106
\s1 Soki tozangi boyengebene, Nzambe azali kaka Moyengebene
\q1 
\v 1 Bokumisa Yawe !
\b
\q1 Bosanzola Yawe, pamba te azali malamu,
\q2 bolingo na Ye ewumelaka seko na seko !
\q1 
\v 2 Nani akoloba misala minene ya Yawe ?
\q2 Nani akopanza sango ya lokumu na Ye nyonso ?
\b
\q1 
\v 3 Esengo na bato oyo babatelaka mibeko
\q2 mpe batambolaka na bosembo !
\b
\q1 
\v 4 Yawe, kanisa ngai
\q2 tango okotalisa ngolu na Yo epai ya bato na Yo !
\q1 Salela ngai bolamu na nzela ya lobiko na Yo,
\q1 
\v 5 mpo ete namona esengo ya baponami na Yo,
\q2 nasepela na bolamu ya ekolo na Yo
\q2 mpe nasepela elongo na libula na Yo !
\b
\q1 
\v 6 Solo, tosalaki masumu lokola batata na biso,
\q2 tosalaki mabe mpe tomemaki ngambo.
\q1 
\v 7 Tango batata na biso bazalaki na Ejipito,
\q2 basosolaki eloko moko te kati na bikamwa na Yo ;
\q1 babosanaki noki misala malamu na Yo,
\q2 batombokaki pembeni ya ebale monene, ebale monene ya Barozo.
\b
\q1 
\v 8 Kasi abikisaki bango mpo na lokumu ya Kombo na Ye,
\q2 mpo na kotalisa nguya na Ye.
\q1 
\v 9 Agangelaki ebale monene ya Barozo, mpe ekawuki ;
\q2 atambolisaki bango kati na mozindo
\q2 lokola na esobe.
\q1 
\v 10 Abikisaki bango
\q2 wuta na maboko ya bayini na bango,
\q1 akangolaki bango
\q2 wuta na maboko ya monguna.
\q1 
\v 11 Mayi ezipaki banguna na bango,
\q2 moko te atikalaki na bomoi.
\q1 
\v 12 Bato na Ye bandimelaki maloba na Ye
\q2 mpe bayembaki masanzoli na Ye.
\q1 
\v 13 Kasi babosanaki noki misala na Ye,
\q2 bazelaki te kokokisama ya mabongisi na Ye.
\q1 
\v 14 Kati na esobe, bamipesaki na bilulela,
\q2 bamekaki Nzambe kati na mabele
\q2 oyo ezali na bato te.
\q1 
\v 15 Apesaki bango biloko oyo bazalaki kosenga,
\q2 kasi atindelaki bango lisusu pasi.
\b
\q1 
\v 16 Kati na molako, basalaki zuwa,
\q2 batelemelaki Moyize mpe Aron, mosantu ya Yawe.
\q1 
\v 17 Mabele efungwamaki mpe emelaki Datani,
\q2 ezipaki lisanga ya Abirami.
\q1 
\v 18 Moto ezikisaki lisanga na bango
\q2 mpe etumbaki bato mabe wana nyonso.
\q1 
\v 19 Na Orebi, basalaki mwana ngombe,
\q2 bafukamelaki nzambe ya ekeko basala na ebende
\q2 oyo banyangwisa na moto.
\q1 
\v 20 Babongolaki Nzambe na bango ya nkembo
\q2 elilingi ya ngombe oyo eliaka matiti.
\q1 
\v 21 Babosanaki Nzambe, Mobikisi na bango,
\q2 oyo asalaki makambo minene kati na Ejipito,
\q1 
\v 22 bikamwa kati na mokili ya Cham
\q2 mpe misala ya somo na ebale monene ya Barozo.
\b
\q1 
\v 23 Azwaki mokano ya koboma bango nyonso.
\q2 Kasi Moyize, moponami na Ye, atelemaki liboso na Ye
\q2 mpo na kobondela ete akitisa kanda na Ye mpe aboma te.
\b
\q1 
\v 24 Batiolaki mboka kitoko
\q2 mpo ete bandimelaki maloba na Ye te.
\q1 
\v 25 Bayimaki-yimaki kati na bandako na bango ya kapo,
\q2 batosaki mongongo ya Yawe te.
\b
\q1 
\v 26 Asembolaki loboko, alapaki ndayi
\q2 ya koboma bango kati na esobe,
\q1 
\v 27 ya kopanza bakitani na bango kati na bikolo mosusu
\q2 mpe ya koboma bango kati na mikili nyonso.
\q1 
\v 28 Bamitiaki na se ya ekangiseli ya Bala ya Peori,
\q2 baliaki bambeka oyo epesamaki
\q2 epai ya banzambe oyo ekufa.
\q1 
\v 29 Batumbolaki kanda ya Yawe
\q2 na nzela ya misala na bango ya mabe,
\q2 mpe pasi makasi ekotaki kati na bongo.
\b
\q1 
\v 30 Kasi Pineasi atelemaki, akataki makambo,
\q2 mpe pasi yango esilaki.
\q1 
\v 31 Mpo na yango, Pineasi atangamaki
\q2 lokola moto ya sembo
\q2 mpo na bikeke nyonso, seko na seko.
\b
\q1 
\v 32 Bapesaki Nzambe kanda pene ya mayi ya Meriba
\q2 mpe bamemisaki Moyize ngambo.
\q1 
\v 33 Mpo ete batombokelaki Molimo ya Nzambe,
\q2 Moyize akomaki koloba maloba oyo esengeli te.
\b
\q1 
\v 34 Babebisaki te bikolo
\q2 oyo Yawe ayebisaki bango,
\q1 
\v 35 kasi basanganaki elongo na bapagano
\q2 mpe bayekolaki bokoko ya bikolo na bango.
\q1 
\v 36 Bagumbamelaki banzambe na bango ya bikeko
\q2 oyo ekomaki motambo mpo na bango.
\q1 
\v 37 Bapesaki bana na bango lokola bambeka
\q2 epai ya milimo mabe.
\q1 
\v 38 Basopaki makila ya bato oyo basalaki mabe te,
\q2 makila ya bana na bango,
\q1 oyo bapesaki lokola mbeka
\q2 epai ya banzambe ya bikeko ya Kanana.
\q1 Boye mboka ekomaki mbindo
\q2 mpo na makila ya bato.
\q1 
\v 39 Bamikomisaki mbindo
\q2 mpe babebisaki lokumu na bango
\q2 na nzela ya misala na bango.
\q1 
\v 40 Yawe asilikelaki bato na Ye,
\q2 ayinaki libula na Ye.
\q1 
\v 41 Akabaki bango na maboko ya bikolo ya bapaya,
\q2 mpe banguna na bango bakomaki kokonza bango ;
\q1 
\v 42 banguna na bango banyokolaki bango
\q2 mpe batiaki bango na se ya bokonzi na bango.
\b
\q1 
\v 43 Akangolaki bango bambala ebele,
\q2 kasi bazalaki kaka kosala mabongisi ya kotomboka
\q2 mpe ya komipesa na bambeba na bango.
\q1 
\v 44 Yawe amonaki pasi na bango,
\q2 tango ayokaki koganga na bango.
\q1 
\v 45 Akanisaki Boyokani oyo asalaki elongo na bango ;
\q2 mpe mpo na bolingo monene na Ye,
\q2 abongolaki mokano na Ye ya komonisa bango pasi.
\q1 
\v 46 Asalaki ete bato nyonso
\q2 oyo bakomisaki bango bawumbu
\q2 bayokela bango mawa.
\b
\q1 
\v 47 Yawe, Nzambe na biso, bikisa biso !
\q2 Sangisa biso wuta na bikolo mosusu
\q1 mpo ete tosanzola Kombo na Yo ya bule
\q2 mpe tosepela na mosala ya kokumisa Yo.
\b
\q1 
\v 48 Tika ete Yawe, Nzambe ya Isalaele,
\q2 apambolama seko na seko !
\b
\q1 Tika ete bato nyonso baloba :
\q2 « Amen ! »
\b
\q1 Bokumisa Yawe !
\c 107
\ms1 Buku ya mitano
\mr Nz 107.1–150.6
\cl Nzembo 107
\s1 Nzembo ya basikolami
\q1 
\v 1 Bosanzola Yawe, pamba te azali malamu,
\q2 mpe bolingo na Ye ewumelaka seko na seko !
\q1 
\v 2 Tika ete bato oyo Yawe asikolaki
\q2 baloba bongo,
\q2 ba-oyo akangolaki wuta na maboko ya monguna,
\q1 
\v 3 ba-oyo asangisaki wuta na bikolo nyonso,
\q2 wuta na este, na weste, na nor mpe na sude.
\b
\q1 
\v 4 Ndambo bazalaki koyengayenga na esobe,
\q2 na esika oyo ezanga bato,
\q1 bamonaki te nzela ya engumba
\q2 epai wapi bakoki kovanda.
\q1 
\v 5 Likolo ya nzala mpe ya posa ya mayi,
\q2 bakomaki pene ya kokufa.
\q1 
\v 6 Bongo kati na pasi na bango,
\q2 babelelaki Yawe,
\q2 mpe akangolaki bango na mitungisi na bango.
\q1 
\v 7 Atambolisaki bango na nzela ya alima
\q2 mpo ete bakende kovanda kati na engumba.
\q1 
\v 8 Tika ete basanzola Yawe
\q2 mpo na bolingo mpe bikamwa na Ye mpo na bato !
\q1 
\v 9 Apesaki mayi epai ya bato
\q2 oyo bazalaki na posa ya mayi
\q2 mpe bilei epai ya bato oyo bazalaki na nzala.
\b
\q1 
\v 10 Bato oyo bazalaki kovanda na bisika
\q2 ya molili makasi mpe ya molili ya kufa
\q1 bazalaki ya kokangama na minyoko
\q2 mpe na minyololo ya bibende,
\q1 
\v 11 pamba te batombokelaki maloba na Nzambe
\q2 mpe batiolaki mabongisi ya Ye-Oyo-Aleki-Likolo.
\q1 
\v 12 Abukaki lolendo ya mitema na bango
\q2 na nzela ya misala makasi ;
\q2 bakweyaki, mpe moko te asungaki bango.
\q1 
\v 13 Kati na pasi na bango, babelelaki Yawe,
\q2 mpe abikisaki bango na mitungisi na bango.
\q1 
\v 14 Abimisaki bango
\q2 wuta na molili makasi mpe na molili ya kufa,
\q2 mpe abukaki minyololo na bango.
\q1 
\v 15 Tika ete basanzola Yawe mpo na bolingo
\q2 mpe bikamwa na Ye mpo na bato !
\q1 
\v 16 Pamba te abukaki bikuke ya bronze
\q2 mpe akataki bikangelo ya mabende.
\b
\q1 
\v 17 Bamosusu bakomaki bazoba
\q2 mpo na etamboli mabe na bango,
\q2 mpe bato na pasi, mpo na masumu na bango.
\q1 
\v 18 Minoko na bango eyinaki bilei nyonso,
\q2 mpe bakomaki pene ya bikuke ya kufa.
\b
\q1 
\v 19 Kati na pasi na bango, babelelaki Yawe,
\q2 mpe abikisaki bango na mitungisi na bango.
\q1 
\v 20 Atindaki Liloba na Ye mpe abikisaki bango,
\q2 akangolaki bango wuta na kunda.
\b
\q1 
\v 21 Tika ete basanzola Yawe
\q2 mpo na bolingo mpe bikamwa na Ye mpo na bato !
\q1 
\v 22 Tika ete babonza bambeka ya kozongisa matondi
\q2 mpe bapanza sango ya misala na Ye
\q2 na koganga na esengo !
\b
\q1 
\v 23 Bato oyo bakendaka mobembo
\q2 na ebale monene kati na masuwa
\q2 mpe basalaka mombongo na mayi minene
\q1 
\v 24 bamonaki misala ya Yawe,
\q2 mpe bikamwa kati na ebale monene.
\b
\q1 
\v 25 Alobaki, mpe mopepe makasi eyaki,
\q2 etombolaki bambonge.
\q1 
\v 26 Bazalaki komata kino na likolo
\q2 mpe kokita kino na se,
\q2 bazalaki kolemba nzoto kati na pasi.
\q1 
\v 27 Bazwaki kizunguzungu mpe bakomaki kotenga-tenga
\q2 lokola bato balangwe masanga,
\q2 bwanya na bango nyonso elimwaki.
\b
\q1 
\v 28 Kati na pasi na bango, babelelaki Yawe
\q2 mpe abimisaki bango na mitungisi na bango.
\q1 
\v 29 Akitisaki mopepe makasi,
\q2 bambonge ya ebale monene evandaki kimia.
\q1 
\v 30 Basepelaki na kimia oyo ezongaki,
\q2 mpe Nzambe amemaki bango
\q2 kino na libongo oyo balingaki.
\b
\q1 
\v 31 Tika ete basanzola Yawe
\q2 mpo na bolingo mpe bikamwa na Ye mpo na bato !
\q1 
\v 32 Tika ete banetola Ye kati na lisanga ya bato
\q2 mpe bakumisa Ye kati na mayangani ya bakambi.
\b
\q1 
\v 33 Akoki kobongola bibale esobe ;
\q2 kobongola bitima mabele ya kokawuka ;
\q1 
\v 34 kobongola mabele oyo ebotaka bambuma
\q2 mabele ya mungwa
\q2 likolo ya mabe ya bavandi na yango.
\q1 
\v 35 Akoki kobongola esobe liziba ;
\q2 kobongola mabele ya kokawuka bitima.
\q1 
\v 36 Akoki kosala ete bato na nzala
\q2 bakoma kovanda kuna,
\q2 batonga engumba oyo bato bakoki kovanda,
\q1 
\v 37 babwaka bambuma na bilanga
\q2 mpe balona banzete ya vino
\q2 oyo ekobota bambuma ebele.
\b
\q1 
\v 38 Apamboli bango, mpe bakomi ebele ;
\q2 mpe akitisi te motango ya bibwele na bango.
\b
\q1 
\v 39 Motango ya bato mosusu ekiti
\q2 mpe balembi nzoto mpo na minyoko mpe pasi.
\b
\q1 
\v 40 Nzambe asambwisaka bato minene,
\q2 akotisaka bango na mobulu makasi
\q2 kino bazanga nzela ya kobimela na pasi.
\q1 
\v 41 Kasi akangolaka babola wuta na pasi na bango,
\q2 mpe asalaka ete babotana ebele
\q1 kati na bituka na bango
\q2 lokola etonga ya bameme.
\b
\q1 
\v 42 Tango bato ya sembo bamonaka bongo,
\q2 basepelaka,
\q1 kasi bato nyonso ya mabe bakangaka
\q2 minoko na bango.
\q1 
\v 43 Tika ete moto ya bwanya asala keba
\q2 na makambo wana nyonso
\q2 mpe akanisa na tina na bolingo ya Yawe !
\c 108
\cl Nzembo 108
\s1 Nakolonga
\d 
\v 1 Nzembo ya Davidi.
\q1 
\v 2 Nzambe, motema na ngai ezali na kimia !
\q2 Nakoyembela Yo, nakosanzola Yo na mindule ;
\q2 ezali mpe lokumu na ngai.
\q1 
\v 3 Lindanda mpe nzenze, bolamuka !
\q2 Nalingi kolamusa tongo.
\b
\q1 
\v 4 Nkolo, nakosanzola Yo kati na bato,
\q2 nakoyembela Yo kati na bikolo.
\q1 
\v 5 Pamba te bolingo na Yo ezali monene koleka Lola,
\q2 mpe bosembo na Yo ekenda kino na mapata.
\b
\q1 
\v 6 Oh Nzambe, tika ete otombolama na likolo ya Lola,
\q2 mpe nkembo na Yo ezala awa na mokili mobimba !
\q1 
\v 7 Bikisa biso na nguya ya loboko na Yo
\q2 mpe yanola biso,
\q2 mpo ete balingami na Yo bakangolama !
\b
\b
\q1 
\v 8 Nzambe alobaki kati na Esika na Ye ya bule :
\q2 « Nakolonga ! Nakokabola Sishemi
\q2 mpe nakotia bandelo ya lubwaku ya Sukoti.
\q1 
\v 9 Galadi ezali ya ngai,
\q2 Manase mpe ezali ya ngai ;
\q1 Efrayimi ezali ekoti na ngai ya ebende,
\q2 mpe Yuda ezali lingenda na ngai ya bokonzi.
\q1 
\v 10 Moabi ezali sani monene oyo nasukolelaka,
\q2 Edomi ezali esika oyo nabwakaka sandale na ngai.
\q1 Nazali kobeta milolo ya bitumba
\q2 mpo na kobundisa mokili ya Filisitia. »
\b
\q1 
\v 11 Nani akomema ngai na engumba batonga makasi ?
\q2 Nani akotambolisa ngai kino na Edomi ?
\q1 
\v 12 Ezali Yo te, Nzambe oyo obwakaki biso,
\q2 Nzambe oyo ozalaki lisusu te kokende bitumba
\q2 elongo na mampinga na biso !
\q1 
\v 13 Yaka kosunga biso,
\q2 kangola biso liboso ya moyini !
\q2 Pamba te lisungi ya bato ezali pamba.
\q1 
\v 14 Elongo na Nzambe,
\q2 tokosala makambo minene mpe ya kokamwa ;
\q2 ezali Ye nde akonyata banguna na biso.
\c 109
\cl Nzembo 109
\s1 Nzambe, kovanda lisusu kimia te
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi.
\q1 Nzambe, Yo oyo ngai nakumisaka,
\q2 kovanda kimia te !
\q1 
\v 2 Bato mabe bazali koloba lokuta
\q2 mpo na kofunda ngai,
\q2 bazali mpe kokosela ngai makambo.
\q1 
\v 3 Bazingeli ngai na maloba ya koyina
\q2 mpe bazali kobundisa ngai kaka pamba.
\b
\q1 
\v 4 Bato oyo ngai nalingaka bafundi ngai,
\q2 kasi ngai namipesi na ngai kaka na mabondeli.
\q1 
\v 5 Bazali kozongisela ngai mabe na bolamu,
\q2 mpe koyina na bolingo.
\b
\q1 
\v 6 Kaba ye na maboko ya moto mabe !
\q2 Bimisela ye monguna,
\q2 na ngambo ya loboko na ye ya mobali !
\q1 
\v 7 Tika ete bazwa ye lokola moto mabe
\q2 na tango ya kosamba,
\q2 mpe libondeli na ye etangama lokola masumu !
\q1 
\v 8 Tika ete mikolo ya bomoi na ye ekoma moke,
\q2 tika ete moto mosusu azwa mokumba na ye !
\q1 
\v 9 Tika ete bana na ye bakoma bana bitike,
\q2 mpe tika ete mwasi na ye akoma
\q2 mwasi akufisa mobali !
\q1 
\v 10 Tika ete bana na ye batelengana
\q2 mpe bakoma bisengasenga,
\q1 tika ete bakende kosenga mosika
\q2 ya ndako na bango oyo ebukana-bukana !
\q1 
\v 11 Tika ete moto oyo adefisaki ye mbongo
\q2 akanga ye biloko nyonso,
\q1 mpe tika ete bapaya babotola ye
\q2 bambuma ya mosala na ye !
\q1 
\v 12 Tika ete moko te atalisa ye bolingo,
\q2 tika ete moko te ayokela bana bitike na ye mawa !
\q1 
\v 13 Tika ete bakitani na ye basila na kokufa,
\q2 mpe bakombo na bango elongwa
\q2 na ekeke oyo ezali kolanda !
\q1 
\v 14 Tika ete Yawe alandela
\q2 masumu ya batata na ye
\q2 mpe alimbisa te masumu ya mama na ye !
\q1 
\v 15 Tika ete Yawe akanisaka
\q2 masumu yango tango nyonso
\q2 mpe asala ete babosana bango libela na mokili !
\b
\q1 
\v 16 Lokola atikalaki te kotambola na boboto,
\q2 mpe lokola anyokolaki mobola mpe moto na mawa
\q2 kino kobomisa moto oyo azoka na motema ;
\q1 
\v 17 lokola azalaki kolinga mingi kolakela bato mabe,
\q2 tika ete bilakeli mabe ekweyela ye !
\q1 Lokola azalaki kosepela te kopambola bato,
\q2 tika ete mapamboli ezala mosika na ye !
\q1 
\v 18 Tika ete alata elakeli mabe lokola kazaka,
\q2 tika ete ekota kati na ye lokola mayi,
\q2 mpe kati na mikuwa na ye lokola mafuta !
\q1 
\v 19 Tika ete elakeli mabe yango elata ye lokola elamba
\q2 oyo alati,
\q1 mpe ekangama ye na loketo lokola mokaba
\q2 mpo na tango nyonso !
\b
\q1 
\v 20 Tala ndenge Yawe akofuta banguna na ngai
\q2 mpe bato oyo balobaka mabe na tina na ngai.
\b
\q1 
\v 21 Kasi Yo Nkolo Yawe,
\q2 salela ngai bolamu mpo na lokumu ya Kombo na Yo,
\q2 kangola ngai kolanda boboto ya bolingo na Yo.
\q1 
\v 22 Solo, nazali mobola mpe moto na mawa,
\q2 mpe motema na ngai ezali ya kozoka kati na ngai.
\q1 
\v 23 Nazali kokende lokola elili oyo ezali kolimwa ;
\q2 bazali kobengana ngai lokola mabanki.
\b
\q1 
\v 24 Mabolongo na ngai elembi
\q2 mpo na kokila mingi bilei,
\q1 nzoto na ngai mpe ebukani
\q2 mpo ete nakondi makasi.
\q1 
\v 25 Mpo na bango, nakomi eloko ya nkele ;
\q2 soki kaka bamoni ngai, baningisi mito.
\b
\q1 
\v 26 Yawe, Nzambe na ngai, sunga ngai ;
\q2 bikisa ngai kolanda bolingo na Yo !
\q1 
\v 27 Tika ete banguna na ngai bayeba
\q2 ete Yo Yawe nde osalaki bongo.
\b
\q1 
\v 28 Ata balakeli ngai mabe,
\q2 Yo okopambola ngai ;
\q1 soki mpe bameki kotelema
\q2 mpo na kobundisa ngai, bakokufa soni.
\q1 Nzokande ngai mosali na Yo, nakozala
\q2 moto ya esengo.
\q1 
\v 29 Tika ete bayini na ngai bazanga lokumu
\q2 mpe bamizipa na soni lokola kazaka.
\b
\q1 
\v 30 Nakosanzola Yawe na mongongo makasi,
\q2 nakokumisa Ye kati na ebele ya bato.
\q1 
\v 31 Pamba te atelemaka na ngambo
\q2 ya loboko ya mobali ya mobola
\q1 mpo na kokangola ye wuta na maboko ya bato
\q2 oyo bakatela ye etumbu.
\c 110
\cl Nzembo 110
\s1 Mokonzi mpe Nganga-Nzambe
\d 
\v 1 Nzembo ya Davidi.
\q1 Maloba ya Yawe epai ya nkolo na ngai :
\q2 « Vanda na ngambo ya loboko na Ngai ya mobali
\q2 kino nakomisa banguna na yo enyatelo makolo na yo. »
\q1 
\v 2 Wuta na Siona, Yawe akosala
\q2 ete nguya na yo ya bokonzi ekende mosika,
\q2 mpe okokonza kati na banguna na Yo.
\b
\q1 
\v 3 Na mokolo oyo okotanda basoda na yo
\q2 na molongo mpo na bitumba,
\q1 bato na yo bakotonda na mpiko,
\q2 bilenge basoda na yo nyonso bakoya na lombangu
\q2 epai na yo ndenge mamwe ebimaka na tongo.
\b
\q1 
\v 4 Yawe alapaki ndayi oyo,
\q2 akobongola maloba na Ye te :
\q1 « Ozali Nganga-Nzambe mpo na libela
\q2 kolanda molongo ya Melishisedeki ! »
\b
\q1 
\v 5 Nkolo azali na ngambo ya loboko na yo ya mobali,
\q2 akopanza bakonzi na mokolo ya kanda na Ye.
\q1 
\v 6 Akopesa bikolo etumbu :
\q2 bikolo nyonso ekotonda na bibembe,
\q2 mpe akonyata bakambi kati na mokili mobimba.
\q1 
\v 7 Na nzela, mokonzi amelaka mayi na mwa moluka ;
\q2 yango wana atombolaka moto.
\c 111
\cl Nzembo 111
\s1 Mosali makambo ya kokamwa
\q1 
\v 1 Bokumisa Yawe !
\b
\q1 Nakokumisa Yawe
\q2 na motema na ngai mobimba
\q1 kati na likita ya bato ya sembo
\q2 mpe kati na mayangani.
\b
\q1 
\v 2 Yawe asalaka makambo minene ;
\q2 bato nyonso oyo balingaka yango
\q2 bakanisaka yango.
\q1 
\v 3 Misala na Ye emonisaka
\q2 nkembo mpe lokumu na Ye,
\q2 mpe bosembo na Ye ewumelaka libela na libela.
\q1 
\v 4 Alingaka ete bakanisa bikamwa na Ye.
\q2 Yawe atondi na mawa
\q2 mpe atalisaka ngolu na Ye.
\q1 
\v 5 Apesaka bato oyo batosaka Ye bilei ;
\q2 akanisaka Boyokani na Ye tango nyonso.
\b
\q1 
\v 6 Amonisaki nguya na Ye epai ya bato na Ye
\q2 na nzela ya misala na Ye
\q1 tango apesaki bango libula
\q2 ya bato ya bikolo mosusu.
\q1 
\v 7 Misala na Ye nyonso elakisaka
\q2 boyengebene mpe bosembo na Ye ;
\q2 mibeko na Ye nyonso ebongi na kondima yango.
\q1 
\v 8 Epesama mpo na libela,
\q2 mpe esengeli kotosa yango
\q2 na bosembo mpe na bosolo.
\q1 
\v 9 Akangolaki bato na Ye,
\q2 mpe asalaki Boyokani ya libela elongo na bango.
\q2 Azali Nzambe Mosantu mpe Nzambe ya somo.
\b
\q1 
\v 10 Kotosa Yawe ezali mosisa ya bwanya ;
\q2 bato nyonso oyo batosaka Yawe
\q1 bazali na mayele ya peto.
\q2 Lokumu ya Yawe ezali ya libela na libela.
\c 112
\cl Nzembo 112
\s1 Bolamu ya bayengebene
\q1 
\v 1 Bokumisa Yawe !
\b
\q1 Esengo na moto oyo atosaka Yawe
\q2 mpe asepelaka makasi na mibeko na Ye.
\b
\q1 
\v 2 Bana na ye bakozala bato na nguya
\q2 kati na mokili ;
\q2 ekeke ya bato ya sembo ekopambolama.
\q1 
\v 3 Ndako na ye ezali na bokolongono
\q2 mpe na bomengo,
\q2 mpe bosembo na ye ewumelaka mpo na seko.
\q1 
\v 4 Pole engengaka kati na molili
\q2 mpo na bato ya alima,
\q1 mpo na moto oyo alimbisaka baninga,
\q2 ayokelaka bato mawa mpe azali sembo.
\q1 
\v 5 Esengo na moto oyo
\q2 ayokelaka bato mawa mpe adefisaka,
\q2 mpe asalaka misala na ye kolanda bosembo.
\b
\q1 
\v 6 Solo, aninganaka ata moke te.
\q2 Bakanisaka misala ya moto ya sembo tango nyonso.
\q1 
\v 7 Abangaka basango ya mabe te ;
\q2 motema na ye ezali na kimia,
\q2 atiaka elikya na ye kati na Yawe.
\q1 
\v 8 Motema na ye eninganaka te,
\q2 abangaka te kino akomona banguna na ye
\q2 kozwa etumbu.
\q1 
\v 9 Akabelaka babola na motema ya esengo ;
\q2 bosembo na ye ewumelaka libela na libela,
\q2 lokumu na ye ekitaka te.
\b
\q1 
\v 10 Moto mabe amonaka yango
\q2 mpe asilikaka na zuwa,
\q1 aliaka minu mpe alembaka nzoto.
\q2 Posa ya bato mabe elimwaka.
\c 113
\cl Nzembo 113
\s1 Moko te akokani na Nzambe
\q1 
\v 1 Bokumisa Yawe !
\b
\q1 Bino basali ya Yawe, bokumisa Ye ;
\q2 bokumisa Yawe !
\q1 
\v 2 Tika ete Kombo ya Yawe epambolama
\q2 kobanda sik’oyo kino libela na libela !
\q1 
\v 3 Longwa na este kino na weste,
\q2 tika ete Kombo ya Yawe epambolama !
\b
\q1 
\v 4 Yawe azali na likolo ya bikolo nyonso,
\q2 nkembo na Ye ezali na likolo koleka Lola.
\q1 
\v 5 Nani akokani na Yawe, Nzambe na biso,
\q2 oyo avandi na Kiti ya Bokonzi
\q2 kati na bisika oyo eleki likolo ?
\q1 
\v 6 Agumbamaka mpo na kotala
\q2 likolo mpe mokili.
\b
\q1 
\v 7 Wuta na putulu, atombolaka
\q2 moto oyo akelela ;
\q1 wuta na fulu ya matiti,
\q2 abimisaka mobola
\q1 
\v 8 mpo na kovandisa ye esika moko na bakambi,
\q2 na bankumu ya bato na Ye.
\q1 
\v 9 Avandisaka mwasi ekomba kati na ndako na ye,
\q2 lokola mama ya esengo kati na bana na ye.
\b
\q1 Bokumisa Yawe !
\c 114
\cl Nzembo 114
\s1 Tango Isalaele abimaki wuta na Ejipito
\q1 
\v 1 Tango Isalaele abimaki wuta na Ejipito,
\q2 tango libota ya Jakobi elongwaki
\q2 na ekolo ya bapaya,
\q1 
\v 2 Yuda ekomaki Esika ya bule ya Yawe,
\q2 mpe Isalaele ekomaki mabele na Ye.
\b
\q1 
\v 3 Ebale monene emonaki yango mpe ekimaki,
\q2 mayi ya Yordani ezongaki na sima,
\q1 
\v 4 bangomba epumbwaki lokola bameme,
\q2 bangomba mike epumbwaki lokola bana ya ntaba.
\b
\q1 
\v 5 Ebale monene, nini ezalaki kati na yo
\q2 mpo ete okima ?
\q2 Yordani, mpo na nini ozongaki na sima ?
\q1 
\v 6 Bino bangomba, mpo nini bopumbwaki
\q2 lokola bameme ?
\q1 Bongo bino bangomba mike, mpo na nini bopumbwaki
\q2 lokola bana ya ntaba ?
\b
\q1 
\v 7 Mokili, lenga liboso ya Yawe,
\q2 liboso ya Nzambe ya Jakobi,
\q1 
\v 8 oyo abongolaka libanga monene liziba,
\q2 mpe libanga etima.
\c 115
\cl Nzembo 115
\s1 Nkembo epai ya Nzambe kaka
\q1 
\v 1 Na biso te, Yawe, na biso te,
\q2 kasi pesa nkembo na Kombo na Yo
\q2 mpo na bolingo mpe boyengebene na Yo.
\b
\q1 
\v 2 Mpo na nini bikolo eloba :
\q2 « Wapi Nzambe na bango ? »
\q1 
\v 3 Nzambe na biso azali na Lola,
\q2 asalaka nyonso oyo alingi.
\q1 
\v 4 Kasi banzambe na bango ya bikeko ezali
\q2 ya palata mpe ya wolo,
\q2 esalema na maboko ya bato.
\q1 
\v 5 Ezali na minoko, kasi elobaka te ;
\q2 ezali na miso, kasi emonaka te ;
\q1 
\v 6 ezali na matoyi, kasi eyokaka te ;
\q2 ezali na zolo, kasi eyokaka solo te ;
\q1 
\v 7 ezali na maboko, kasi esimbaka te ;
\q2 ezali na makolo, kasi etambolaka te.
\q2 Minoko na yango ebimisaka ata makelele te.
\q1 
\v 8 Bato oyo basalaka yango
\q2 mpe bato nyonso oyo batielaka yango motema
\q2 bakokani na yango.
\b
\q1 
\v 9 Bana ya Isalaele, botia elikya kati na Yawe !
\q2 Azali lisungi mpe nguba na bango.
\q1 
\v 10 Bakitani ya Aron, botia elikya kati na Yawe !
\q2 Azali lisungi mpe nguba na bino.
\q1 
\v 11 Bino bato oyo botosaka Yawe,
\q2 botia elikya kati na Yawe.
\q2 Azali lisungi mpe nguba na bango.
\b
\q1 
\v 12 Yawe akanisaka biso, akopambola ;
\q2 solo, akopambola bana ya Isalaele,
\q2 akopambola bakitani ya Aron.
\q1 
\v 13 Akopambola bato oyo batosaka Yawe
\q2 kobanda na bato pamba kino na bato minene.
\q1 
\v 14 Tika ete Yawe afulukisa bino,
\q2 bino mpe bana na bino !
\b
\q1 
\v 15 Tika ete Yawe apambola bino,
\q2 Ye oyo asala likolo mpe mabele.
\b
\q1 
\v 16 Likolo ezali likolo ya Yawe ;
\q2 kasi apesa mabele epai ya bato.
\q1 
\v 17 Ezali te bakufi nde bakumisaka Yawe,
\q2 pamba te bango nyonso bakendaka
\q2 na esika ya kimia.
\q1 
\v 18 Kasi biso, tokopambola Yawe,
\q2 kobanda sik’oyo kino libela na libela.
\b
\q1 Bokumisa Yawe !
\c 116
\cl Nzembo 116
\s1 Yawe ayokaka ngai
\q1 
\v 1 Nalingaka Yawe, pamba te ayokaka
\q2 mongongo mpe mabondeli na ngai.
\q1 
\v 2 Ayokaki ngai ;
\q2 boye nakobelela Ye bomoi na ngai mobimba.
\b
\q1 
\v 3 Minyololo ya kufa ezingelaki ngai,
\q2 somo ya mboka ya bakufi ekangaki ngai ;
\q2 nakomaki moto ya pasi mpe ya mawa.
\q1 
\v 4 Kasi nabelelaki Kombo ya Yawe :
\q2 « Yawe, nabondeli Yo, bikisa ngai ! »
\b
\q1 
\v 5 Yawe asalaka ngolu mpe azali sembo,
\q2 Nzambe na biso ayokelaka bato mawa.
\q1 
\v 6 Yawe abatelaka bato oyo bazangi mayele.
\q2 Nalembaki nzoto, kasi abikisi ngai.
\b
\q1 
\v 7 Molimo na ngai, zongela kimia na yo,
\q2 pamba te Yawe asaleli yo bolamu.
\b
\q1 
\v 8 Solo, okangoli ngai na kufa,
\q2 okawusi mpinzoli na ngai
\q2 mpe obateli makolo na ngai ete ekweya te.
\q1 
\v 9 Nakotambola liboso ya Yawe
\q2 kati na mokili ya bato ya bomoi.
\b
\q1 
\v 10 Solo, nazalaka na elikya, ezala soki nalobaka :
\q2 « Nazali moto na pasi makasi. »
\q1 
\v 11 Kati na mitungisi na ngai, nazalaki komilobela :
\q2 « Bato nyonso bazali bakosi. »
\q1 
\v 12 Nini nakoki kozongisela Yawe
\q2 mpo na bolamu na Ye nyonso epai na ngai ?
\q1 
\v 13 Nakotombola kopo ya elonga
\q2 mpe nakobelela Kombo ya Yawe.
\q1 
\v 14 Nakokokisa bandayi na ngai epai na Yawe
\q2 na miso ya bato na Ye nyonso.
\b
\q1 
\v 15 Kufa ya bayengebene ya Yawe
\q2 ezali na motuya makasi na miso na Ye.
\q1 
\v 16 Yawe, yoka ngai, nazali mosali na Yo.
\q2 Nazali mosali na Yo,
\q1 mwana mobali ya mwasi mosali na Yo.
\q2 Ofungoli minyololo oyo ekangaki ngai.
\q1 
\v 17 Nakobonzela Yo mbeka
\q2 mpo na kozongisa matondi,
\q2 mpe nakobelela Kombo ya Yawe.
\b
\q1 
\v 18 Nakokokisa bandayi na ngai epai na Yawe
\q2 na miso ya bato na Ye nyonso,
\q1 
\v 19 kati na lopango ya Tempelo ya Yawe ;
\q2 kati na yo, Yelusalemi.
\b
\q1 Bokumisa Yawe !
\c 117
\cl Nzembo 117
\s1 Masanzoli ya bikolo nyonso
\q1 
\v 1 Bino bato ya bikolo nyonso,
\q2 bokumisa Yawe !
\q1 Bino bato ya mabota nyonso,
\q2 bopesa Ye nkembo !
\q1 
\v 2 Pamba te bolingo na Ye mpo na biso ezali monene,
\q2 mpe bosembo ya Yawe ewumelaka
\q2 seko na seko.
\b
\q1 Bokumisa Yawe !
\c 118
\cl Nzembo 118
\s1 Bolingo ya Yawe ezali na suka te
\q1 
\v 1 Bosanzola Yawe, pamba te azali malamu,
\q2 pamba te bolingo na Ye ewumelaka seko na seko !
\b
\q1 
\v 2 Tika ete Isalaele aloba :
\q2 « Pamba te bolingo na Ye ewumelaka seko na seko ! »
\q1 
\v 3 Tika ete bakitani ya Aron baloba :
\q2 « Pamba te bolingo na Ye ewumelaka seko na seko ! »
\q1 
\v 4 Tika ete bato oyo batosaka Yawe baloba :
\q2 « Pamba te bolingo na Ye ewumelaka seko na seko ! »
\b
\q1 
\v 5 Kati na pasi na ngai, nabelelaki Yawe,
\q2 mpe Yawe ayanolaki ngai, abikisaki ngai.
\q1 
\v 6 Yawe azali mpo na ngai, nakobanga te ;
\q2 bato bakoki kosala ngai nini ?
\q1 
\v 7 Yawe azali mpo na ngai,
\q2 ayaka kosunga ngai ;
\q1 boye natalaka banguna na ngai na miso
\q2 lokola molongi.
\b
\q1 
\v 8 Eleki malamu koluka ebombamelo
\q2 kati na Yawe
\q2 na esika ya kotia elikya na bato.
\q1 
\v 9 Eleki malamu koluka ebombamelo
\q2 kati na Yawe
\q1 na esika ya kotia elikya
\q2 kati na bato minene ya mokili.
\b
\q1 
\v 10 Bikolo nyonso ezingelaki ngai,
\q2 kasi nabebisaki bango na Kombo na Yawe.
\q1 
\v 11 Bakobaki kaka kozingela ngai,
\q2 kasi nabebisaki bango na Kombo na Yawe.
\q1 
\v 12 Bazingelaki ngai lokola banzoyi,
\q2 kasi ekufaki lokola moto ya esobe ;
\q2 nabebisaki yango na Kombo na Yawe.
\b
\q1 
\v 13 Batindikaki ngai mpo ete nakweyisa kondima,
\q2 kasi Yawe asungaki ngai.
\q1 
\v 14 Yawe azali makasi mpe nguya na ngai ;
\q2 apesaki ngai elonga.
\b
\q1 
\v 15 Koganga ya esengo mpe ya elonga eyokanaka
\q2 wuta na bandako ya kapo ya bato ya sembo,
\q1 pamba te nguya na Yawe esalaka
\q2 makambo minene !
\q1 
\v 16 Yawe asembolaka loboko na Ye ya mobali,
\q2 mpe nguya na Yawe esalaka makambo minene.
\q1 
\v 17 Nakokufa te, nakozala na bomoi
\q2 mpe nakopanza sango ya misala ya Yawe.
\q1 
\v 18 Solo, Yawe apesaki ngai etumbu makasi ;
\q2 kasi akabaki ngai na kufa te.
\b
\q1 
\v 19 Bofungolela ngai bikuke ya bosembo
\q2 mpo ete nakota mpe nakumisa Yawe.
\q1 
\v 20 Tala ekuke ya Yawe ;
\q2 bato ya sembo bakotelaka na ekuke yango.
\b
\q1 
\v 21 Nasanzolaka Yo, pamba te oyanolaki ngai
\q2 mpe opesaki ngai elonga.
\q1 
\v 22 Libanga oyo batongi ndako babwakaki
\q2 ekomi libanga ya songe ya ndako,
\q2 mpe esimbi ndako mobimba.
\q1 
\v 23 Ezali Yawe nde alingaki bongo,
\q2 mpe ezali penza likambo ya kokamwa
\q2 na miso na biso !
\b
\q1 
\v 24 Tala mokolo oyo Yawe asali ;
\q2 tika ete tosepela mpe toganga na esengo
\q2 mpo na mokolo yango !
\q1 
\v 25 Yawe, nabondeli Yo, pesa lobiko.
\q2 Yawe, nabondeli Yo, pesa elonga.
\b
\q1 
\v 26 Tika ete apambolama,
\q2 Ye oyo ayei na Kombo ya Nkolo !
\q1 Tozali kopambola bino
\q2 wuta na Tempelo ya Yawe.
\q1 
\v 27 Yawe azali Nzambe,
\q2 mpe angengisaki biso.
\q1 Bokota na molongo, bomema mandalala na maboko
\q2 mpe bokende kino na maseke ya etumbelo.
\b
\q1 
\v 28 Ozali Nzambe na ngai, nasanzolaka Yo !
\q2 Ozali Nzambe na ngai, nanetolaka Yo.
\b
\q1 
\v 29 Bosanzola Yawe, pamba te azali malamu,
\q2 pamba te bolingo na Ye ewumelaka seko na seko !
\c 119
\cl Nzembo 119
\s1 Mibeko ya Yawe ezali ya kokoka
\q1 
\v 1 Esengo na bato oyo bazangi pamela
\q2 mpe batambolaka kolanda mibeko ya Yawe !
\q1 
\v 2 Esengo na bato oyo babatelaka malako na Ye
\q2 mpe balukaka Ye na mitema na bango mobimba !
\q1 
\v 3 Basalaka mabe te,
\q2 kasi balandaka banzela ya Nzambe.
\q1 
\v 4 Opesaki mibeko
\q2 mpo ete etosama malamu.
\q1 
\v 5 Tika ete nabongisa etamboli na ngai
\q2 mpo ete natosa mitindo na Yo !
\q1 
\v 6 Na bongo, nakoyoka soni te
\q2 tango nakotosa mibeko na Yo nyonso.
\q1 
\v 7 Nakosanzola Yo na motema ya sembo
\q2 wana nakoyekola mibeko ya bosembo na Yo.
\q1 
\v 8 Nalingi kotosa mitindo na Yo ;
\q2 kosundola ngai libela te !
\b
\q1 
\v 9 Ndenge nini elenge akoki kowumela
\q2 na nzela ya sembo ?
\q2 Ezali na kotambola kolanda liloba na Yo.
\q1 
\v 10 Nalukaka Yo na motema na ngai mobimba ;
\q2 batela ngai mpo ete napengwa te
\q2 mosika ya mibeko na Yo !
\q1 
\v 11 Nabatelaka liloba na Yo kati na motema na ngai
\q2 mpo ete nasala masumu te na miso na Yo.
\q1 
\v 12 Yawe, tika ete opambolama !
\q2 Lakisa ngai mitindo na Yo !
\q1 
\v 13 Na monoko na ngai, natangaka
\q2 mibeko na Yo nyonso.
\q1 
\v 14 Nasepelaka kotambola kolanda malako na Yo
\q2 lokola nde nazali na bomengo nyonso.
\q1 
\v 15 Nakanisaka malako na Yo
\q2 mpe natambolaka na banzela na Yo.
\q1 
\v 16 Nasepelaka mingi na malako na Yo
\q2 mpe nabosanaka liloba na Yo te.
\b
\q1 
\v 17 Salela ngai, mosali na Yo, bolamu
\q2 mpo ete nabika mpe natosa liloba na Yo.
\q1 
\v 18 Fungola miso na ngai
\q2 mpo ete namona kitoko ya mibeko na Yo.
\q1 
\v 19 Nazali mopaya awa na mokili ;
\q2 kobombela ngai mibeko na Yo te.
\q1 
\v 20 Molimo na ngai ezalaka tango nyonso
\q2 na posa makasi ya koyeba mibeko na Yo.
\q1 
\v 21 Otelemelaka bato ya lofundu,
\q2 bato oyo balakelama mabe
\q2 mpe bapengwaka mosika ya mibeko na Yo.
\q1 
\v 22 Longola soni mpe kotiolama na bomoi na ngai,
\q2 pamba te natosaka malako na Yo.
\q1 
\v 23 Ezala soki bakambi basali likita
\q2 mpe bayokani kotelemela ngai, mosali na Yo,
\q2 nakokanisa kaka mitindo na Yo.
\q1 
\v 24 Malako na Yo esepelisaka ngai makasi,
\q2 epesaka ngai toli.
\b
\q1 
\v 25 Nakangami na putulu ;
\q2 batela bomoi na ngai kolanda liloba na Yo.
\q1 
\v 26 Nayebisaki Yo banzela na ngai,
\q2 mpe oyanolaki ngai ;
\q2 lakisa ngai mibeko na Yo !
\q1 
\v 27 Sala ete nasosola nzela ya mitindo na Yo
\q2 mpo ete nakanisa misala minene na Yo !
\q1 
\v 28 Nazali kolela mpo na pasi na motema ;
\q2 pesa ngai mpiko kolanda liloba na Yo.
\q1 
\v 29 Mema ngai mosika ya nzela ya lokuta ;
\q2 mpe, na boboto na Yo, teya ngai mobeko na Yo.
\q1 
\v 30 Naponaki nzela ya bosolo ;
\q2 natambolaka kolanda mibeko na Yo.
\q1 
\v 31 Nakangami na malako na Yo ;
\q2 Yawe, koyokisa ngai soni te.
\q1 
\v 32 Nakimaka mbangu kati na nzela ya mibeko na Yo,
\q2 pamba te opesaka ngai bososoli na yango.
\b
\q1 
\v 33 Yawe, teya ngai nzela ya mitindo na Yo
\q2 mpo ete nabatela yango kino na suka.
\q1 
\v 34 Pesa ngai bososoli mpo ete natosa mibeko na Yo
\q2 mpe nalanda yango na motema na ngai mobimba.
\q1 
\v 35 Tambolisa ngai kati na nzela ya mibeko na Yo,
\q2 pamba te nasepelaka na yango.
\q1 
\v 36 Sala ete motema na ngai esepela na malako na Yo,
\q2 kasi na bomengo te !
\q1 
\v 37 Longola miso na ngai na makambo ya pamba,
\q2 batela bomoi na ngai kati na banzela na Yo !
\q1 
\v 38 Kokisela mosali na Yo bilaka
\q2 oyo opesaki mpo na bato oyo batosaka Yo.
\q1 
\v 39 Longola mosika na ngai soni oyo nabangaka,
\q2 pamba te mibeko na Yo ezali malamu.
\q1 
\v 40 Nasepelaka makasi na mibeko na Yo ;
\q2 batela bomoi na ngai kati na bosembo na Yo !
\b
\q1 
\v 41 Yawe, tika ete bolingo ekomela ngai,
\q2 mpe lobiko na Yo, kolanda elaka na Yo ;
\q1 
\v 42 bongo nakokoka kozwa eyano ya kopesa
\q2 na mofingi na ngai,
\q2 pamba te natiaka elikya na liloba na Yo.
\q1 
\v 43 Tika ete monoko na ngai elobaka kaka bosolo,
\q2 pamba te natiaka elikya kati na mibeko na Yo.
\q1 
\v 44 Nakotosa mibeko na Yo tango nyonso,
\q2 mpe libela na libela.
\q1 
\v 45 Nakobika na bonsomi ya solo,
\q2 pamba te nasepelaka kotosa mitindo na Yo.
\q1 
\v 46 Nakolobela malako na Yo liboso ya bakonzi
\q2 na kozanga koyoka soni.
\q1 
\v 47 Nasepelaka mingi na mibeko na Yo
\q2 mpe nalingaka yango mingi.
\q1 
\v 48 Nalapi ndayi mpo na mibeko na Yo,
\q2 oyo nalingaka,
\q2 mpe nakokanisa mitindo na Yo.
\b
\q1 
\v 49 Kanisa makambo oyo olobaki na mosali na Yo,
\q2 pamba te opesaki ngai elikya.
\q1 
\v 50 Kati na pasi na ngai, liloba na Yo ebondisaka ;
\q2 batela bomoi na ngai kolanda elaka na Yo.
\q1 
\v 51 Solo, bato ya lolendo batiolaki ngai makasi ;
\q2 kasi ngai, natikalaki kopengwa te na mibeko na Yo.
\q1 
\v 52 Yawe, tango nakanisaka mikano na Yo ya kala,
\q2 nazwaka kati na yango kobondisama.
\q1 
\v 53 Nayokaka pasi mingi na motema
\q2 tango namonaka bato mabe
\q2 kosundola mibeko na Yo.
\q1 
\v 54 Nakoma koyemba mitindo na Yo
\q2 na bisika nyonso epai wapi nazali moleki nzela.
\q1 
\v 55 Yawe, nakanisaka Yo na butu
\q2 mpo ete nabatela mibeko na Yo ;
\q1 
\v 56 pamba te libula na ngai ezali :
\q2 kotosa mibeko na Yo.
\b
\q1 
\v 57 Yawe, nalobi lisusu ete libula na ngai ezali :
\q2 kotosa liloba na Yo.
\q1 
\v 58 Na motema na ngai mobimba, nalukaka kosepelisa Yo ;
\q2 salela ngai ngolu kolanda bilaka na Yo !
\q1 
\v 59 Natali malamu etamboli na ngai
\q2 mpe namizongisi kati na malako na Yo.
\q1 
\v 60 Natosaka mibeko na Yo noki,
\q2 nazelisaka te.
\q1 
\v 61 Solo, mitambo ya bato mabe ekangaki ngai,
\q2 kasi ngai nabosanaki te mibeko na Yo.
\q1 
\v 62 Na kati-kati ya butu, nalamukaka mpo na kokumisa Yo
\q2 likolo na mibeko na Yo ya sembo.
\q1 
\v 63 Nazali moninga ya bato nyonso oyo batosaka Yo
\q2 mpe babatelaka mitindo na Yo.
\q1 
\v 64 Yawe, mokili etondi na bolingo na Yo ;
\q2 lakisa ngai mitindo na Yo !
\b
\q1 
\v 65 Yawe, salela mosali na Yo bolamu
\q2 kolanda liloba na Yo.
\q1 
\v 66 Teya ngai bolamu ya bososoli mpe ya mayele,
\q2 pamba te namipesaka na mibeko na Yo.
\q1 
\v 67 Liboso ete obeta ngai, nazalaki mopengwi ;
\q2 kasi sik’oyo, nakomi kotosa liloba na Yo.
\q1 
\v 68 Ozali malamu mpe osalaka makambo ya malamu ;
\q2 teya ngai mitindo na Yo !
\q1 
\v 69 Bato ya lolendo bakoselaka ngai makambo ;
\q2 kasi ngai, natosaka mitindo na Yo
\q2 na motema na ngai mobimba.
\q1 
\v 70 Mitema na bango ezali mabanga ;
\q2 kasi ngai, nasepelaka na mibeko na Yo.
\q1 
\v 71 Ezalaki penza malamu mpo na ngai ete obeta ngai,
\q2 mpo ete nayekola mitindo na Yo.
\q1 
\v 72 Mpo na ngai, mibeko oyo ozwaki mpe osakolaki
\q2 na monoko na Yo ezali malamu
\q1 koleka biloko nkoto moko
\q2 ya wolo mpe ya palata.
\b
\q1 
\v 73 Osalaki mpe olendisaki ngai na maboko na Yo,
\q2 pesa ngai mayele mpo ete nayekola mibeko na Yo !
\q1 
\v 74 Tango bato oyo batosaka Yo bamonaka ngai,
\q2 basepelaka makasi,
\q2 mpo ete natiaka elikya na liloba na Yo.
\q1 
\v 75 Yawe, nayebi malamu
\q2 ete mibeko na Yo ezali sembo,
\q1 mpe ete ezali kaka mpo na bolingo na Yo
\q2 nde obetaki ngai.
\q1 
\v 76 Tika ete bolingo na Yo ebondisa ngai,
\q2 kolanda elaka na Yo epai ya mosali na Yo !
\q1 
\v 77 Talisa ngai mawa na Yo mpo ete nabika,
\q2 pamba te nasepelaka na mibeko na Yo.
\q1 
\v 78 Tika ete bato wana ya lofundu,
\q2 oyo bamonisaka ngai pasi na kozanga tina, bakufa soni !
\q2 Kasi ngai nakokanisa kaka mibeko na Yo.
\q1 
\v 79 Tika ete bato oyo batosaka Yo,
\q2 ba-oyo bayebi malako na Yo,
\q2 bazongela ngai.
\q1 
\v 80 Tika ete motema na ngai ezanga pamela
\q2 mpo na kotosa mitindo na Yo,
\q2 mpo ete nakufa soni te.
\b
\q1 
\v 81 Natondi na posa ya lobiko na Yo,
\q2 nazali na elikya kati na liloba na Yo.
\q1 
\v 82 Miso na ngai elembi kozela
\q2 kokokisama ya elaka na Yo ;
\q1 nakomi komituna :
\q2 « Okobondisa ngai tango nini ? »
\q1 
\v 83 Nakomi lokola mbeki
\q2 oyo ezali kokawuka na milinga,
\q2 nzokande nabosanaka mitindo na Yo te.
\q1 
\v 84 Mikolo ya bomoi ya mosali na Yo
\q2 ezali motango boni ?
\q1 Mokolo nini okopesa banyokoli na ngai etumbu ?
\q1 
\v 85 Bato ya lolendo batimoli mabulu
\q2 mpo na kokanga ngai,
\q2 baboyi kotosa mibeko na Yo.
\q1 
\v 86 Mibeko na Yo nyonso ezali sembo ;
\q2 kasi bazali konyokola ngai kaka pamba ;
\q2 yaka kosunga ngai !
\q1 
\v 87 Etikali moke mpo ete balongola ngai na mokili ;
\q2 kasi atako bongo, nasundoli mibeko na Yo te.
\q1 
\v 88 Kati na bolingo na Yo, batela bomoi na ngai
\q2 mpo ete natosa malako na Yo.
\b
\q1 
\v 89 Yawe, liloba na Yo ezali mpo na seko,
\q2 epikama kati na likolo ;
\q1 
\v 90 boyengebene na Yo ekowumela seko na seko.
\q2 Okela mabele, mpe ezali kaka kino na mokolo ya lelo ;
\q1 
\v 91 opesa mibeko, mpe ezali kaka kino na mokolo ya lelo,
\q2 pamba te nyonso kati na mokili mobimba
\q2 epesaka Yo lokumu.
\q1 
\v 92 Soki nasepelaki na mibeko na Yo te,
\q2 mbele nakufa kala kati na pasi na ngai.
\q1 
\v 93 Nakotikala kobosana ata moke te mitindo na Yo,
\q2 pamba te obatelaka bomoi na ngai
\q2 na nzela na yango.
\q1 
\v 94 Bikisa ngai, pamba te nazali moto na Yo
\q2 mpe natosaka mitindo na Yo !
\q1 
\v 95 Bato mabe bazali koluka koboma ngai,
\q2 kasi ngai nakangami kaka na malako na Yo.
\q1 
\v 96 Na nyonso oyo emonanaka lokola ya kokoka,
\q2 namonaki mondelo ;
\q2 kasi mibeko na Yo ezalaka na mondelo te.
\b
\q1 
\v 97 Nalingaka mibeko na Yo mingi !
\q2 Nakanisaka yango mikolo nyonso.
\q1 
\v 98 Mibeko na Yo ekomisaka ngai moto ya bwanya
\q2 koleka banguna na ngai ;
\q2 ezalaka elongo na ngai tango nyonso.
\q1 
\v 99 Naleki balakisi na ngai nyonso na mayele,
\q2 pamba te nakanisaka malako na Yo.
\q1 
\v 100 Naleki mibange na bososoli,
\q2 pamba te natosaka mibeko na Yo.
\q1 
\v 101 Natambolaka te na banzela nyonso ya mabe
\q2 mpo na kotosa liloba na Yo.
\q1 
\v 102 Nakangamaka na mibeko na Yo,
\q2 pamba te Yo moko nde oteyaka ngai yango.
\q1 
\v 103 Tala ndenge mitindo na Yo ezali elengi
\q2 na monoko na ngai !
\q2 Ezali malamu koleka mafuta ya nzoyi.
\q1 
\v 104 Mitindo na Yo ekomisi ngai moto ya bososoli ;
\q2 yango wana nayinaka nzela nyonso ya mabe.
\b
\q1 
\v 105 Liloba na Yo ezali mwinda
\q2 mpo na makolo na ngai,
\q2 mpe pole mpo na nzela na ngai.
\q1 
\v 106 Nalapaki ndayi oyo mpe nakokokisa yango :
\q2 « Nakotosaka mibeko ya bosembo na Yo. »
\q1 
\v 107 Motema na ngai etutami makasi ;
\q2 Yawe, batela bomoi na ngai
\q2 kolanda liloba na Yo.
\q1 
\v 108 Yawe, ndima likabo ya bibebu na ngai,
\q2 mpe teya ngai mibeko na Yo.
\q1 
\v 109 Solo, nakutanaka tango nyonso na makama,
\q2 kasi nabosanaka mibeko na Yo te.
\q1 
\v 110 Bato mabe batiaka mitambo mpo ete nakweya,
\q2 kasi nakangamaka kaka na mibeko na Yo.
\q1 
\v 111 Malako na Yo ezali libula na ngai mpo na libela,
\q2 esalaka esengo ya motema na ngai.
\q1 
\v 112 Nazwa mokano ya kotambola
\q2 kolanda mitindo na Yo,
\q2 tango nyonso, kino na suka.
\b
\q1 
\v 113 Nayinaka bato ya mitema mibale,
\q2 kasi nalingaka nde mibeko na Yo.
\q1 
\v 114 Ozali ebombamelo mpe nguba na ngai ;
\q2 natiaka elikya kati na liloba na Yo.
\q1 
\v 115 Bato ya misala mabe, bokende mosika na ngai !
\q2 Nakotosa mibeko ya Nzambe na ngai !
\q1 
\v 116 Sunga ngai kolanda elaka na Yo, mpe nakobika ;
\q2 koyokisa elikya na ngai soni te.
\q1 
\v 117 Sunga ngai mpo ete nabika ;
\q2 nakotikala kobosana mitindo na Yo ata moke te.
\q1 
\v 118 Obwakaka bato nyonso oyo bapesaka
\q2 mitindo na Yo mokongo,
\q2 pamba te mokano na bango ezalaka ya lokuta.
\q1 
\v 119 Olongolaka bato nyonso ya mabe ya mokili
\q2 lokola bosoto ;
\q2 yango wana nalingaka malako na Yo.
\q1 
\v 120 Nalengaka na somo liboso na Yo
\q2 mpe nabangaka mikano na Yo.
\b
\q1 
\v 121 Natambolaka na bosembo mpe bosolo ;
\q2 kokaba ngai na maboko ya banyokoli na ngai te !
\q1 
\v 122 Kamata mokumba ya bolamu na ngai,
\q2 mosali na Yo ;
\q2 tika ete bato ya lolendo banyokola ngai te.
\q1 
\v 123 Miso na ngai elembi kozela lisungi kowuta na Yo
\q2 mpe kokokisama ya bosembo na Yo
\q2 kolanda elaka na Yo.
\q1 
\v 124 Salela ngai, mosali na Yo, kolanda bolingo na Yo,
\q2 lakisa ngai mitindo na Yo.
\q1 
\v 125 Nazali mosali na Yo ; pesa ngai mayele
\q2 mpo ete nasosola malako na Yo.
\q1 
\v 126 Yawe, tango ya kosala ekoki ;
\q2 pamba te bazali kobuka mibeko na Yo !
\q1 
\v 127 Yango wana nalingaka mibeko na Yo
\q2 koleka wolo, koleka kutu wolo ya peto ;
\q1 
\v 128 namonaka mpe malako na Yo nyonso alima ;
\q2 nzokande, nayinaka lokuta nyonso.
\b
\q1 
\v 129 Malako na Yo ezali kitoko,
\q2 yango wana nabatelaka yango.
\q1 
\v 130 Emoniseli ya liloba na Yo engengisaka,
\q2 epesaka bazoba mayele.
\q1 
\v 131 Monoko na ngai efungwamaka makasi
\q2 likolo ya kozela,
\q2 pamba te nazali na posa makasi ya mibeko na Yo.
\q1 
\v 132 Baluka epai na ngai mpe talisa ngai ngolu na Yo
\q2 kolanda ndenge okata mpo na bato
\q2 oyo balingaka Kombo na Yo.
\q1 
\v 133 Lendisa bomoi na ngai na nzela ya liloba na Yo
\q2 mpe pekisa mabe ete ekonza ngai te.
\q1 
\v 134 Kangola ngai wuta na minyoko ya bato,
\q2 mpe nakotosa mibeko na Yo.
\q1 
\v 135 Tika ete elongi na Yo engengela ngai,
\q2 mosali na Yo ;
\q2 lakisa ngai mibeko na Yo !
\q1 
\v 136 Miso na ngai ezali kosopa mpinzoli,
\q2 pamba te mibeko na Yo ezali kotosama te.
\b
\q1 
\v 137 Yawe, ozali sembo,
\q2 mpe mibeko na Yo ezali alima ;
\q1 
\v 138 osalaki malako na Yo
\q2 na bosembo mpe na bolingo.
\q1 
\v 139 Mpo ete banguna na ngai bazwaka
\q2 liloba na Yo na motuya te,
\q2 nayokaka kanda makasi komata ngai na motema.
\q1 
\v 140 Nzokande liloba na Yo ezali penza peto ;
\q2 mpe ngai, mosali na Yo, nalingaka yango.
\q1 
\v 141 Atako nazali moke mpe batiolaka ngai,
\q2 kasi nabosanaka mitindo na Yo te.
\q1 
\v 142 Bosembo na Yo ekotikala bongo mpo na libela,
\q2 ekotikala kobongwana te ;
\q2 mpe mibeko na Yo ezali solo.
\q1 
\v 143 Pasi ekangi ngai, mpe mayele esili ngai ;
\q2 kasi mibeko na Yo epesaka ngai esengo.
\q1 
\v 144 Malako na Yo ezali sembo mpo na libela ;
\q2 pesa ngai bososoli mpo ete nabika !
\b
\q1 
\v 145 Nazali kobelela Yo
\q2 na motema na ngai mobimba :
\q1 « Yawe, yanola ngai ;
\q2 nakotosa mitindo na Yo !
\q1 
\v 146 Nazali kobelela Yo : bikisa ngai,
\q2 mpo ete natosa malako na Yo !
\q1 
\v 147 Nalamukaka liboso ete tongo etana
\q2 mpo na kobelela Yo,
\q2 nazali na elikya kati na liloba na Yo.
\q1 
\v 148 Nalamukaka na kati-kati ya butu
\q2 mpo na kokanisa mitindo na Yo.
\q1 
\v 149 Yoka ngai na bolingo na Yo !
\q2 Yawe, batela bomoi na ngai
\q2 kolanda mibeko na Yo !
\q1 
\v 150 Bato oyo basalaka mabongisi mabe,
\q2 oyo batosaka mibeko na Yo te,
\q2 bazali koya pene na ngai.
\q1 
\v 151 Nzokande Yo, Yawe, ozali pene,
\q2 mpe mibeko na Yo nyonso ezali bosolo.
\q1 
\v 152 Wuta kala, ngai nayebi, na nzela ya malako na Yo,
\q2 ete otia mibeko yango mpo na libela.
\b
\q1 
\v 153 Mona malamu pasi na ngai mpe kangola ngai,
\q2 pamba te nabosanaka mibeko na Yo te.
\q1 
\v 154 Kota likambo na ngai mpe kangola ngai,
\q2 batela bomoi na ngai kolanda elaka na Yo !
\q1 
\v 155 Lobiko ezalaka mosika ya bato mabe,
\q2 pamba te bamonaka pamba mitindo na Yo.
\q1 
\v 156 Yawe, mawa na Yo ezali monene penza ;
\q2 batela bomoi na ngai kolanda mibeko na Yo.
\q1 
\v 157 Banyokoli mpe banguna na ngai bazali solo ebele,
\q2 kasi ngai nakangamaka kaka na malako na Yo.
\q1 
\v 158 Natalaka na nkele bato oyo bazangi kondima,
\q2 ba-oyo batosaka liloba na Yo te.
\q1 
\v 159 Yawe, tala ndenge nalingaka mitindo na Yo !
\q2 Batela bomoi na ngai kolanda bolingo na Yo.
\q1 
\v 160 Moboko ya liloba na Yo ezali bosolo,
\q2 mpe mibeko nyonso ya bosembo na Yo ezali
\q2 mpo na libela.
\b
\q1 
\v 161 Bakambi banyokolaka ngai kaka pamba,
\q2 kasi kaka liloba na Yo nde ebangisaka
\q2 motema na ngai.
\q1 
\v 162 Nasepelaka na liloba na Yo
\q2 lokola moto oyo azwi bomengo ebele ya bitumba.
\q1 
\v 163 Nayinaka lokuta mpe nayokaka yango nkele,
\q2 nalingaka nde mibeko na Yo.
\q1 
\v 164 Nakumisaka Yo mbala sambo na mokolo
\q2 mpo na mibeko ya bosembo na Yo.
\q1 
\v 165 Bato oyo balingaka mibeko na Yo
\q2 bazali bato na kimia monene,
\q2 mpe eloko moko te ekobetisa bango lisusu mabaku.
\q1 
\v 166 Yawe, natielaka Yo motema
\q2 mpo ete obikisa ngai,
\q2 mpe natosaka mibeko na Yo.
\q1 
\v 167 Natosaka malako na Yo,
\q2 pamba te nalingaka yango makasi.
\q1 
\v 168 Natosaka malako mpe mibeko na Yo,
\q2 pamba te oyebi banzela na ngai nyonso.
\b
\q1 
\v 169 Yawe, tika ete koganga na ngai ekoma
\q2 kino epai na Yo !
\q2 Pesa ngai bososoli kolanda liloba na Yo !
\q1 
\v 170 Tika ete mabondeli na ngai ekoma
\q2 kino epai na Yo !
\q2 Kangola ngai kolanda elaka na Yo.
\q1 
\v 171 Tika ete bibebu na ngai ekumisa Yo,
\q2 pamba te olakisaka ngai mitindo na Yo !
\q1 
\v 172 Tika ete lolemo na ngai eyemba liloba na Yo,
\q2 pamba te mibeko na Yo nyonso ezali sembo.
\q1 
\v 173 Tika ete loboko na Yo esunga ngai,
\q2 pamba te napona kolanda malako na Yo.
\q1 
\v 174 Yawe, nazali na posa makasi
\q2 ya lobiko na Yo ;
\q2 mibeko na Yo epesaka ngai esengo.
\q1 
\v 175 Tika ete nazala na bomoi mpo na kokumisa Yo,
\q2 mpe tika ete mibeko na Yo esunga ngai !
\q1 
\v 176 Nazali koyengayenga lokola meme oyo ebungi ;
\q2 luka ngai, mosali na Yo,
\q2 pamba te nabosani mibeko na Yo te. »
\c 120
\cl Nzembo 120
\s1 Kangola ngai
\d 
\v 1 Nzembo ya mobembo tango bazalaki kokende na Tempelo ya Yawe.
\q1 Kati na pasi na ngai, nabelelaki Yawe,
\q2 mpe ayanolaki ngai.
\q1 
\v 2 Oh Yawe, kangola ngai
\q2 wuta na maboko ya bakosi
\q2 mpe wuta na lolemo ya lokuta !
\b
\q1 
\v 3 Yo, lolemo ya lokuta,
\q2 Yawe akopesa yo nini,
\q2 akofuta yo nini ?
\q1 
\v 4 Akobeta yo na makonga ya elombe ya bitumba,
\q2 oyo ezali ya songe,
\q2 elongo na makala ya moto ya nzete ya nzube.
\q1 
\v 5 Mawa na ngai, mpo ete navandi
\q2 lokola mopaya kati na Mesheki,
\q2 kati na bandako ya kapo ya Kedari.
\q1 
\v 6 Navandaki tango molayi
\q2 kati na bato oyo balingaka kimia te.
\q1 
\v 7 Ngai, nazali moto ya kimia ;
\q2 kasi soki kaka nameki koloba na tina na kimia,
\q2 bango baponaka mbala moko bitumba.
\c 121
\cl Nzembo 121
\s1 Yawe, Mosungi mpe Mobateli na ngai
\d 
\v 1 Nzembo ya mobembo tango bazalaki kokende na Tempelo ya Yawe.
\q1 Natomboli miso na ngai na ngambo ya bangomba :
\q2 lisungi na ngai ekowuta wapi ?
\q1 
\v 2 Lisungi na ngai ewutaka na Yawe
\q2 oyo akela likolo mpe mabele.
\q1 
\v 3 Akotika te ete lokolo na yo eselumuka ;
\q2 Ye oyo abatelaka yo animbaka te.
\b
\q1 
\v 4 Te, Ye oyo abatelaka Isalaele
\q2 animbaka te mpe alalaka pongi te !
\q1 
\v 5 Yawe azali mobateli na yo ;
\q2 Yawe azali, na ngambo ya loboko na yo ya mobali,
\q2 lokola elili oyo ebatelaka yo.
\b
\q1 
\v 6 Ezala na moyi to na butu,
\q2 moyi mpe sanza ekosala yo mabe ata moke te !
\q1 
\v 7 Yawe akobatela yo na mabe nyonso,
\q2 akobatela bomoi na yo ;
\q1 
\v 8 Yawe akobatela kokende
\q2 mpe kozonga na yo,
\q2 sik’oyo mpe libela na libela.
\c 122
\cl Nzembo 122
\s1 Bosambela mpo na kimia ya Yelusalemi
\d 
\v 1 Nzembo ya Davidi. Nzembo ya mobembo mpo na kokende na Tempelo ya Yawe.
\q1 Nasepelaka tango balobaka na ngai :
\q2 « Tokende na Tempelo ya Yawe ! »
\b
\q1 
\v 2 Yelusalemi, makolo na biso etelemi
\q2 na bikuke na yo !
\q1 
\v 3 Yelusalemi, engumba oyo etongama malamu ;
\q2 engumba oyo biteni na yango ekangana esika moko.
\q1 
\v 4 Ezali kuna nde mabota ekendaka, mabota ya Yawe,
\q2 kolanda mibeko kati na Isalaele,
\q2 mpo na kosanzola Kombo ya Yawe.
\q1 
\v 5 Pamba te bakiti ya bokonzi ya bato
\q2 oyo basalelaka bosembo ezali kuna,
\q2 bakiti ya bokonzi mpo na ndako ya Davidi.
\b
\q1 
\v 6 Bosenga kimia ya Yelusalemi !
\q2 Tika ete bato oyo balingaka yo, Yelusalemi,
\q2 babika na kimia !
\q1 
\v 7 Tika ete kimia ezala kati na yo
\q2 mpe kati na bandako na yo ya bokonzi !
\q1 
\v 8 Likolo ya bolingo na ngai
\q2 mpo na bandeko mpe balingami na ngai,
\q2 nalobi : « Tika ete kimia ezala kati na yo ! »
\q1 
\v 9 Likolo ya bolingo na ngai
\q2 mpo na Tempelo ya Yawe, Nzambe na biso,
\q2 nasengi bolamu mpo na yo.
\c 123
\cl Nzembo 123
\s1 Wana tozali kozela ngolu na Ye
\d 
\v 1 Nzembo ya mobembo mpo na kokende na Tempelo ya Yawe.
\q1 Natomboli miso na ngai epai na Yo, Yawe,
\q2 oyo ovandi na Kiti na Yo ya Bokonzi kati na Lola.
\b
\q1 
\v 2 Ndenge miso ya bawumbu etalaka nkolo na bango,
\q2 mpe miso ya mwasi mosali etalaka nkolo na ye ya mwasi,
\q1 ndenge wana mpe miso na biso ezali kotala
\q2 Yawe, Nzambe na biso,
\q2 kino asalela biso ngolu.
\b
\q1 
\v 3 Yawe, salela biso ngolu,
\q2 yokela biso mawa !
\q2 Pamba te tolembi kotiolama !
\q1 
\v 4 Tolembi penza kotiolama
\q2 na bato ya lolendo mpe ya lofundu !
\c 124
\cl Nzembo 124
\s1 Lisungi na biso ewutaka epai ya Yawe
\d 
\v 1 Nzembo ya Davidi. Nzembo ya mobembo mpo na kokende na Tempelo ya Yawe.
\q1 Soki Yawe abatelaki biso te ;
\q2 tika ete Isalaele aloba bongo !
\q1 
\v 2 Soki Yawe abatelaki biso te
\q2 tango bato babundisaki biso,
\q1 
\v 3 mbele bamelaki biso ya bomoi
\q2 tango basilikelaki biso makasi.
\q1 
\v 4 Boye mayi elingaki kozindisa biso,
\q2 mbonge makasi elingaki komema biso.
\q1 
\v 5 Mayi makasi elingaki kozindisa biso.
\b
\q1 
\v 6 Tika ete Yawe apambolama,
\q2 Ye oyo andimaki te ete minu na bango epasola biso !
\q1 
\v 7 Tobikaki lokola ndeke liboso ya motambo
\q2 ya mokangi bandeke ;
\q2 motambo ekatanaki, mpe tokimaki.
\q1 
\v 8 Lisungi na biso ezali kati na Kombo na Yawe
\q2 oyo akela likolo mpe mabele.
\c 125
\cl Nzembo 125
\s1 Kimia ya solo
\d 
\v 1 Nzembo ya mobembo mpo na kokende na Ndako ya Yawe.
\q1 Bato oyo batiaka elikya kati na Yawe
\q2 bazali lokola ngomba Siona oyo eninganaka te,
\q2 oyo epikama mpo na libela.
\q1 
\v 2 Ndenge bangomba ezingeli Yelusalemi,
\q2 ndenge wana mpe Yawe azingeli bato na Ye,
\q2 kobanda sik’oyo kino libela na libela.
\q1 
\v 3 Bokonzi ya mabe ekowumela te na etuka ya bato ya sembo,
\q2 mpo ete basangana te na mabe.
\b
\q1 
\v 4 Yawe, zala malamu mpo na bato malamu
\q2 mpe mpo na bato oyo bazali alima na mitema !
\q1 
\v 5 Kasi tika ete Yawe abengana
\q2 bato ya kilikili elongo na bato ya misala mabe !
\b
\q1 Tika ete kimia ezala na Isalaele !
\c 126
\cl Nzembo 126
\s1 Tango ya kolona mpe tango ya kobuka
\d 
\v 1 Nzembo ya mobembo mpo na kokende na Tempelo ya Yawe.
\q1 Tango Yawe azongisaki bato ya Siona
\q2 longwa na bowumbu,
\q2 tozalaki lokola bato oyo bazali kolota ndoto.
\q1 
\v 2 Boye, tozalaki koganga mpe koyemba na esengo.
\q2 Bongo, maloba oyo ekomaki kolobama kati na bikolo :
\q2 « Yawe asaleli bango makambo minene ! »
\q1 
\v 3 Solo, Yawe asaleli biso makambo minene,
\q2 mpe tozali kosepela.
\b
\q1 
\v 4 Yawe, yaka kobongisa makambo na biso
\q2 ndenge kaka otondisaka lisusu miluka ya Negevi.
\b
\q1 
\v 5 Bato oyo balonaka na mpinzoli
\q2 babukaka na banzembo ya esengo.
\q1 
\v 6 Moto oyo akendaka na kolela,
\q2 tango amemi milona na ye,
\q1 azongaka na esengo
\q2 wana amemi maboke na ye.
\c 127
\cl Nzembo 127
\s1 Nani asalaka nyonso
\d 
\v 1 Nzembo ya Salomo. Nzembo ya mobembo mpo na kokende na Tempelo ya Yawe.
\q1 Soki Yawe atongi ndako te,
\q2 batongi ndako bazali kosala mosala ya pamba ;
\q1 soki Yawe akengeli engumba te,
\q2 bakengeli bazali kosala na pamba.
\q1 
\v 2 Ezali na pamba nde, bino mpe,
\q2 bolamukaka na tongo makasi,
\q1 bolalaka noki te mpe bosalaka makasi
\q2 mpo na kozwa bilei ;
\q1 pamba te Nzambe apesaka bilei yango
\q2 kaka na balingami na Ye,
\q2 wana bazali nanu kolala pongi.
\b
\q1 
\v 3 Bana bazali libula kowuta na Yawe,
\q2 mpe kobota bana ezali lifuti.
\q1 
\v 4 Ndenge makonga ezali kati na maboko ya mobundi bitumba,
\q2 ndenge wana mpe bana oyo moto aboti
\q2 na bolenge na ye bazali.
\q1 
\v 5 Esengo na moto oyo atondisi makonga
\q2 kati na ebombelo na ye ya makonga !
\q1 Akokufa soni ata moke te
\q2 tango akosamba elongo na banguna na ye
\q2 na ekuke ya engumba.
\c 128
\cl Nzembo 128
\s1 Tika ete Yawe apambola yo
\d 
\v 1 Nzembo ya mobembo mpo na kokende na Tempelo ya Yawe.
\q1 Esengo na moto oyo atosaka Yawe
\q2 mpe alandaka banzela na Ye !
\q1 
\v 2 Oliaka mbuma ya mosala na Yo ;
\q2 ozali moto ya esengo mpe ozali na bofuluki.
\q1 
\v 3 Kati na ndako na yo,
\q2 mwasi na yo azali lokola nzete ya vino
\q1 oyo ebotaka bambuma ebele ;
\q2 bana na yo bazali lokola bankona ya nzete ya olive
\q2 zingazinga ya mesa na yo.
\q1 
\v 4 Ezali ndenge wana nde Yawe apambolaka
\q2 moto oyo atosaka Ye.
\b
\q1 
\v 5 Solo, Yawe akopambola yo wuta na Siona,
\q2 mpe okomona bofuluki ya Yelusalemi
\q2 mikolo nyonso ya bomoi na yo
\q1 
\v 6 mpe okomona bakitani na yo.
\b
\q1 Tika ete kimia ezala na Isalaele !
\c 129
\cl Nzembo 129
\s1 Banyokoli ngai mingi, kasi nalembi te
\d 
\v 1 Nzembo ya mobembo mpo na kokende na Tempelo ya Yawe.
\q1 Wuta bolenge na ngai, banyokoli ngai bambala ebele.
\q2 Tika ete Isalaele ezongela koloba :
\q1 
\v 2 « Wuta bolenge na ngai, banyokoli ngai bambala ebele,
\q2 kasi batikali kolonga ngai te ! »
\b
\q1 
\v 3 Bato mabe batimoli mokongo na ngai,
\q2 bazokisi ngai bapota ya banzela milayi na mokongo.
\q1 
\v 4 Kasi lokola Yawe azali sembo,
\q2 akati basinga ya bato mabe.
\b
\q1 
\v 5 Tika ete bato nyonso oyo bayinaka Siona
\q2 bakufa soni mpe bazonga sima !
\q1 
\v 6 Tika ete bakoma lokola matiti
\q2 oyo ebotaka na likolo ya ndako
\q2 mpe ekawukaka liboso ete balongola yango ;
\q1 
\v 7 tika ete mobuki bambuma ya bilanga
\q2 atondisa na yango te maboko na ye,
\q1 tika ete mokangi maboke ya banzete atondisa
\q2 na yango te saki na ye.
\q1 
\v 8 Tika ete baleki nzela baloba na bango te :
\q2 « Tika ete Yawe apambola bino ! »
\b
\q1 Topamboli bino na Kombo na Yawe !
\c 130
\cl Nzembo 130
\s1 Wuta na mozindo ya pasi
\d 
\v 1 Nzembo ya mobembo mpo na kokende na Ndako ya Nkolo.
\q1 Nkolo, nazali kobelela Yo wuta na mozindo ya pasi !
\q1 
\v 2 Nkolo, yoka ngai !
\q2 Yoka mabondeli na ngai !
\q1 
\v 3 Yawe, soki obosanaka masumu te,
\q2 Nkolo, nani akokaki kotelema ?
\q1 
\v 4 Kasi bolimbisi ezali epai na Yo,
\q2 yango wana basengeli kotosa Yo.
\b
\q1 
\v 5 Na motema na ngai mobimba,
\q2 nazali na elikya kati na Yawe,
\q1 nazali penza na elikya ;
\q1 nazali kozela maloba na Ye.
\q1 
\v 6 Nazali na elikya kati na Nkolo
\q2 koleka kutu ndenge mokengeli azelaka kotana ya tongo,
\q2 koleka penza ndenge mokengeli azelaka kotana ya tongo.
\b
\q1 
\v 7 Isalaele, tia elikya kati na Yawe,
\q2 pamba te azali bolingo,
\q2 mpe kokangolama ya kokoka ezali elongo na Ye.
\q1 
\v 8 Ye nde akokangola Isalaele
\q2 na bambeba na yango nyonso.
\c 131
\cl Nzembo 131
\s1 Kimia ya solo
\d 
\v 1 Nzembo ya Davidi. Nzembo ya mobembo mpo na kokende na Tempelo ya Yawe.
\q1 Yawe, motema na ngai ezali na lofundu te,
\q2 miso na ngai ezali na posa makasi te ;
\q1 namipesaka te na makambo oyo eleki ya minene
\q2 mpe eleki pasi mpo na ngai.
\q1 
\v 2 Kasi nabatelaki kimia kati na motema na ngai
\q2 mpe namitungisaki te
\q2 lokola mwana moke elongo na mama na ye.
\q1 Nazali na kimia lokola mwana
\q2 oyo mama alongola na mabele.
\q1 
\v 3 Isalaele, tia elikya kati na Yawe
\q2 kobanda sik’oyo mpe libela na libela.
\c 132
\cl Nzembo 132
\s1 Engumba ya Mokonzi
\d 
\v 1 Nzembo ya mobembo mpo na kokende na Tempelo ya Yawe.
\q1 Yawe, kanisa Davidi ;
\q2 kanisa pasi na ye nyonso !
\q1 
\v 2 Alapaki ndayi oyo epai na Yawe,
\q2 epai ya Elombe ya Jakobi :
\q1 
\v 3 « Nakokota na ndako na ngai te,
\q2 nakomata na mbeto na ngai te,
\q1 
\v 4 nakokanga miso na ngai te mpo na kolala pongi
\q2 to mpo na konimba mwa moke
\q1 
\v 5 kino nakozwa Esika mpo na Yawe,
\q2 Ndako mpo na Elombe ya Jakobi. »
\b
\q1 
\v 6 Toyokaki sango na tina na yango na Efrata,
\q2 tomonaki yango na elanga ya Yari.
\q1 
\v 7 Tokende na Ndako na Ye,
\q2 togumbama liboso ya enyatelo makolo na yango.
\b
\q1 
\v 8 Yawe, telema, yaka na Esika na Yo ya bopemi !
\q2 Yaka elongo na Sanduku ya Boyokani
\q2 epai wapi nguya na Yo ezali.
\q1 
\v 9 Tika ete Banganga-Nzambe na Yo balata bosembo lokola elamba ;
\q2 mpe tika ete basantu na Yo baganga na esengo !
\q1 
\v 10 Mpo na Davidi, mosali na Yo,
\q2 kobengana mopakolami na Yo te !
\b
\q1 
\v 11 Yawe alapaki epai ya Davidi ndayi ya solo,
\q2 oyo akowangana te :
\q1 « Nakotia moko kati na bakitani na yo
\q2 na kiti na yo ya bokonzi.
\q1 
\v 12 Soki bana na yo babateli boyokani mpe mibeko na ngai,
\q2 bana na bango mpe bakokitana na yo lokola bakonzi,
\q2 mpe ekosalema bongo mpo na libela. »
\q1 
\v 13 Pamba te Yawe aponaki Siona,
\q2 asepelaki kokomisa yango Esika na Ye ya kovanda :
\q1 
\v 14 « Ezali Esika na ngai ya bopemi mpo na libela ;
\q2 nakovanda awa, pamba te nasepelaki na yango.
\q1 
\v 15 Nakopambola, nakopambola yango na biloko ebele,
\q2 nakotondisa babola na yango na bilei.
\q1 
\v 16 Nakolatisa Banganga-Nzambe na yango lobiko,
\q2 mpe bato na yango bakoganga na esengo.
\b
\q1 
\v 17 Kuna na Siona, nakobakisa nguya ya Davidi,
\q2 mpe nakobimisela ye mokitani, mopakolami na ngai,
\q2 lokola mwinda ya kopela.
\q1 
\v 18 Nakoyokisa banguna na ye soni,
\q2 mpe motole na ye ekongenga na mbunzu na ye. »
\c 133
\cl Nzembo 133
\s1 Tango bandeko basangani
\d 
\v 1 Nzembo ya Davidi. Nzembo ya mobembo mpo na kokende na Tempelo ya Yawe.
\q1 Tala ndenge ezali malamu mpe ndenge ezali kitoko
\q2 mpo na bandeko kozala lisanga kati na bomoko !
\q1 
\v 2 Ezali lokola malasi ya motuya
\q2 oyo basopi na moto,
\q1 bongo ezali kokita na mandefu, na mandefu ya Aron,
\q2 ezali kokita kino na songe ya bilamba na ye.
\q1 
\v 3 Ezali lokola mamwe ya Erimoni,
\q2 oyo ekitaka na bangomba ya Siona.
\q1 Pamba te kuna, Yawe apesaka lipamboli na Ye,
\q2 mpe bomoi, mpo na libela.
\c 134
\cl Nzembo 134
\s1 Bokumisa Yawe
\d 
\v 1 Nzembo ya mobembo mpo na kokende na Ndako ya Nkolo.
\q1 Bopambola Yawe, bino nyonso, basali ya Nkolo,
\q2 oyo botelemaka na butu kati na Ndako ya Nkolo.
\b
\q1 
\v 2 Botombola maboko na bino na ngambo ya Esika ya bule
\q2 mpe bopambola Yawe !
\q1 
\v 3 Tika ete Yawe apambola bino, wuta na Siona,
\q2 Ye oyo asala likolo mpe mabele !
\c 135
\cl Nzembo 135
\s1 Yawe azali malamu
\q1 
\v 1 Bokumisa Yawe !
\b
\q1 Bokumisa Kombo ya Yawe !
\q2 Bokumisa Ye, bino basali ya Yawe,
\q1 
\v 2 oyo botelemaka kati na Ndako ya Yawe,
\q2 kati na lopango ya Ndako ya Nzambe na biso !
\b
\q1 
\v 3 Bokumisa Yawe !
\q2 Pamba te Yawe azali malamu !
\q1 Boyembela Kombo na Ye,
\q2 pamba te ezali kitoko makasi.
\q1 
\v 4 Pamba te Yawe aponaki Jakobi,
\q2 Isalaele, mpo ete azala ya Ye moko.
\b
\q1 
\v 5 Solo, ngai nayebi malamu ete Yawe azali monene,
\q2 ete Nkolo na biso aleki banzambe nyonso.
\q1 
\v 6 Yawe asalaka nyonso oyo alingi,
\q2 kuna na likolo mpe awa na mabele,
\q2 kati na bibale minene mpe kati na mozindo nyonso.
\b
\q1 
\v 7 Amatisaka mapata wuta na suka ya mokili,
\q2 atindaka mikalikali elongo na mvula,
\q2 abimisaka mopepe wuta na bibombelo na yango.
\b
\q1 
\v 8 Ye nde abomaki bana ya liboso ya Ejipito,
\q2 kobanda na bato kino na banyama ;
\q1 
\v 9 atindaki bilembo ya kokamwa mpe bikamwa
\q2 kati na yo, Ejipito,
\q2 mpo na kotelemela Faraon mpe basali na ye nyonso ;
\q1 
\v 10 abebisaki bikolo ebele
\q2 mpe abomaki bakonzi ya nguya :
\q1 
\v 11 Sikoni, mokonzi ya bato ya Amori ;
\q2 Ogi, mokonzi ya Bashani ;
\q2 mpe bakonzi nyonso ya Kanana.
\q1 
\v 12 Mpe akabaki mikili na bango lokola libula,
\q2 lokola libula epai ya bato na Ye, Isalaele.
\b
\q1 
\v 13 Oh Yawe, sango ya Kombo na Yo
\q2 ewumelaka libela na libela !
\q1 Yawe, bakopanza sango ya Kombo na Yo
\q2 seko na seko !
\q1 
\v 14 Pamba te Yawe akolimbisa bato na Ye,
\q2 akoyokela basali na Ye mawa.
\b
\q1 
\v 15 Banzambe ya bikolo ezali ya palata mpe ya wolo,
\q2 esalema na maboko ya bato.
\q1 
\v 16 Ezali na minoko, kasi elobaka te ;
\q2 ezali na miso, kasi emonaka te ;
\q1 
\v 17 ezali na matoyi, kasi eyokaka te ;
\q2 ezali ata na pema te kati na minoko na yango.
\q1 
\v 18 Bato oyo basalaka yango
\q2 mpe bato nyonso oyo batielaka yango motema
\q2 bakokani na yango.
\b
\q1 
\v 19 Bato ya Isalaele, bopambola Yawe !
\q2 Bakitani ya Aron, bopambola Yawe !
\q1 
\v 20 Bakitani ya Levi, bopambola Yawe !
\q2 Bino nyonso oyo botosaka Yawe,
\q2 bopambola Yawe !
\q1 
\v 21 Tika ete, wuta na Siona, Yawe apambolama,
\q2 Ye oyo avandaka na Yelusalemi !
\b
\q1 Bokumisa Yawe !
\c 136
\cl Nzembo 136
\s1 Bolingo ya Yawe ewumelaka seko na seko
\q1 
\v 1 Bosanzola Yawe, mpo ete azali malamu ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 2 Bosanzola Nzambe ya banzambe ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 3 Bosanzola Nkolo na bankolo ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\b
\q1 
\v 4 Ye kaka nde asalaka bikamwa ya minene ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 5 Akelaki likolo na mayele na Ye ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 6 Atandaki mabele na likolo ya mayi ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 7 Akelaki biloko minene oyo ebimisaka pole ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 8 moyi mpo na kongengisa mokolo ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 9 sanza mpe minzoto mpo na kongengisa butu ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\b
\q1 
\v 10 Abomaki bana mibali ya liboso ya Ejipito ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 11 Abimisaki Isalaele wuta na Ejipito ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 12 na nguya monene ya loboko na Ye ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 13 Akabolaki ebale monene ya Barozo na biteni mibale ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 14 Alekisaki Isalaele na kati-kati ya ebale monene ya Barozo ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 15 Azindisaki Faraon elongo na mampinga na ye kati na ebale monene ya Barozo ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 16 Atambolisaki bato na Ye kati na esobe ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 17 Abetaki bakonzi minene ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 18 Abomaki bakonzi ya nguya ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 19 Sikoni, mokonzi ya bato ya Amori ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 20 mpe Ogi, mokonzi ya Bashani ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 21 Akabaki mabele na bango lokola libula ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 22 lokola libula epai ya Isalaele, mosali na Ye ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\b
\q1 
\v 23 Akanisaki biso tango basambwisaki biso ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\q1 
\v 24 Akangolaki biso wuta na maboko ya banguna na biso ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\b
\q1 
\v 25 Apesaka bilei na bikelamu nyonso ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\b
\q1 
\v 26 Bosanzola Nzambe ya likolo ;
\qr pamba te bolingo na Ye ewumelaka seko na seko !
\c 137
\cl Nzembo 137
\s1 Pembeni ya bibale ya Babiloni
\q1 
\v 1 Ezalaki biso ya kovanda pembeni ya bibale ya Babiloni,
\q2 tozalaki kolela na tozalaki kokanisa Siona.
\q1 
\v 2 Todiembikaki mandanda na biso
\q2 na banzete ya pepiliye ya etuka yango.
\b
\q1 
\v 3 Kuna, bato oyo bamemaki biso na bowumbu
\q2 bazalaki kosenga biso banzembo ;
\q1 mpe banyokoli na biso bazalaki kosenga biso
\q2 ete tozala na esengo.
\q1 Bazalaki koloba :
\q2 « Boyembela biso banzembo ya Siona ! »
\b
\q1 
\v 4 Tokoyemba banzembo ya Yawe ndenge nini
\q2 na mabele ya bapaya ?
\q1 
\v 5 Oh Yelusalemi, soki nabosani yo,
\q2 wana tika ete loboko na ngai ya mobali elemba !
\q1 
\v 6 Soki natiki penza kokanisa yo, Yelusalemi,
\q2 soki natie yo te liboso ya esengo nyonso,
\q2 wana tika ete lolemo na ngai ekangama kati na monoko na ngai !
\b
\q1 
\v 7 Yawe, kobosana te bato ya Edomi
\q2 oyo basekaki Yelusalemi na mokolo na yango ya mawa ;
\q1 bazalaki koganga :
\q2 « Bobuka yango, bobuka kino na miboko na yango ! »
\b
\q1 
\v 8 Babiloni, engumba kitoko, yo oyo okobebisama solo,
\q2 esengo na moto oyo akozongisela yo mabe na mabe
\q2 oyo osalaki biso !
\q1 
\v 9 Esengo na moto oyo akokanga bana na yo
\q2 mpe akonika bango na libanga !
\c 138
\cl Nzembo 138
\s1 Nalingi koyemba bolingo ya Yawe
\d 
\v 1 Nzembo ya Davidi.
\q1 Nasanzolaka Yo na motema na ngai mobimba ;
\q2 nayembelaka Yo banzembo liboso ya banzambe.
\q1 
\v 2 Nagumbamaka na kotala na ngambo ya Tempelo na Yo ya Bule
\q2 mpe nasanzolaka Kombo na Yo
\q1 mpo na bolingo mpe boyengebene na Yo,
\q2 pamba te osalaki ete Kombo na Yo ekende sango
\q2 na nzela ya kokokisama ya bilaka na Yo.
\q1 
\v 3 Na mokolo oyo nabelelaki Yo, oyanolaki ngai,
\q2 otondisaki ngai na mpiko mpe na makasi.
\b
\q1 
\v 4 Yawe, bakonzi nyonso ya mabele bakokumisa Yo
\q2 tango bakoyoka maloba kobima na monoko na Yo ;
\q1 
\v 5 bakoyemba na tina na banzela ya Yawe,
\q2 pamba te nkembo na Yawe ezali monene.
\q1 
\v 6 Atako Yawe atombwama,
\q2 atalaka bato oyo bamikitisa
\q2 mpe amonaka na mosika bato ya lolendo.
\b
\q1 
\v 7 Tango pasi ekweyelaka ngai,
\q2 obatelaka bomoi na ngai,
\q1 osembolaka loboko na Yo
\q2 mpo na kotelemela kanda ya banguna na ngai ;
\q2 mpe loboko na Yo ya mobali ebikisaka ngai.
\q1 
\v 8 Yawe akokisaka makambo nyonso
\q2 mpo na bolamu na ngai.
\q1 Yawe, bolingo na Yo ewumelaka seko na seko !
\q2 Kosundola te bato oyo osala na maboko na Yo !
\c 139
\cl Nzembo 139
\s1 Yawe, oyebi nyonso na tina na ngai
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi.
\q1 Yawe, omonaka mozindo ya bomoi na ngai
\q2 mpe oyebi ngai malamu ;
\q1 
\v 2 oyebi tango navandaka mpe tango natelemaka.
\q2 Liboso na ngai kokanisa, ososolaka mabongisi na ngai ;
\q1 
\v 3 omonaka tango natambolaka mpe tango nalalaka,
\q2 oyebi mozindo ya banzela na ngai nyonso.
\q1 
\v 4 Pamba te, oh Yawe, liboso ete liloba ekoma na lolemo na ngai,
\q2 omiyebelaka yango.
\q1 
\v 5 Ozali pene ngai, na liboso mpe na sima,
\q2 mpe osimbi ngai na loboko na Yo.
\q1 
\v 6 Solo, boyebi oyo ya kokamwa elekelaka ngai,
\q2 ezali likolo makasi, nakoki kososola yango te.
\b
\q1 
\v 7 Nakende wapi mpo na kokima Molimo na Yo ?
\q2 Nakima wapi mpo na kozala mosika na Yo ?
\q1 
\v 8 Soki namati na likolo, ozali kuna ;
\q2 soki nakeyi na mboka ya bakufi, ozali lisusu kuna.
\q1 
\v 9 Soki nazwi mapapu ya lipekapeka
\q2 mpo na kokende kovanda mosika ya ebale monene,
\q1 
\v 10 kuna mpe loboko na Yo ekotambolisa ngai,
\q2 loboko na Yo ya mobali ekosimba ngai makasi.
\q1 
\v 11 Soki nalobi : « Tembe te, molili ekobomba ngai penza ;
\q2 tika ete pole ekoma butu zingazinga na ngai ! »
\q1 
\v 12 Epai na Yo, butu ezalaka molili te,
\q2 butu ezalaka na pole lokola moyi,
\q2 pole mpe molili ezali ndenge moko.
\b
\q1 
\v 13 Ezali Yo nde okelaki mozindo ya bomoto na ngai,
\q2 obombaki ngai kati na libumu ya mama na ngai.
\q1 
\v 14 Nasanzolaka Yo, pamba te osala ngai kitoko makasi.
\q2 Misala na Yo ezali ya kokamwa ;
\q2 ngai, nayebi yango malamu.
\b
\q1 
\v 15 Na miso na Yo, nzoto na ngai ezalaki ya kobombama te
\q2 tango osalaki ngai na esika ebombama,
\q2 tango otongaki ngai kati na mozindo ya mabele.
\b
\q1 
\v 16 Tango nazalaki nanu na lolenge te,
\q2 ozalaki komona ngai ;
\q1 mpe omikomelaki kati na buku na Yo
\q2 mikolo nyonso oyo obongisaki mpo na bomoi na ngai
\q2 liboso ete moko te kati na yango ezala.
\b
\q1 
\v 17 Oh Nzambe, tala ndenge ezali pasi mpo na ngai
\q2 kososola makanisi na Yo !
\q2 Tala ndenge motango na yango ezali ebele !
\q1 
\v 18 Nameki kotanga yango,
\q2 ezali ebele koleka motango ya bambuma ya zelo.
\q2 Nalamuki, nazali kaka elongo na Yo.
\q1 
\v 19 Oh Nzambe, soki kaka ozalaki na Yo koboma moto mabe !
\q2 Bino basopi makila ya bato, bokende mosika na ngai !
\q1 
\v 20 Bayini na Yo basalelaka Kombo na Yo
\q2 mpo na kosala mabongisi ya mabe,
\q2 batangaka Kombo na Yo mpo na kokosa.
\b
\q1 
\v 21 Yawe, ndenge nini nayina te banguna na Yo,
\q2 ndenge nini nayoka batelemeli na Yo nkele te ?
\q1 
\v 22 Nayinaka bango makasi ;
\q2 nazwaka bango lokola banguna na ngai.
\b
\q1 
\v 23 Oh Nzambe, kundola mpe yeba mozindo
\q2 ya motema na ngai,
\q2 meka ngai mpe yeba makambo oyo ezali kotungisa ngai !
\q1 
\v 24 Tala soki nazali kotambola na nzela mabe
\q2 mpe tambolisa ngai na nzela ya tango nyonso !
\c 140
\cl Nzembo 140
\s1 Kangola ngai wuta na maboko ya bakosi
\d 
\v 1 Wuta na buku ya mokambi ya bayembi. Nzembo ya Davidi.
\q1 
\v 2 Yawe, kangola ngai
\q2 wuta na maboko ya bato ya misala mabe !
\q2 Kokutanisa ngai te na bato na kanza.
\q1 
\v 3 Basalaka mabongisi mabe kati na mitema na bango
\q2 mpe balukaka bitumba mikolo nyonso.
\q1 
\v 4 Bapelisaka lolemo na bango lokola nyoka,
\q2 bibebu na bango ezali na ngenge ya etupa.
\q1 
\v 5 Yawe, batela ngai mosika ya maboko ya moto mabe ;
\q2 kokutanisa ngai te na bato na kanza
\q2 oyo bazali kosala mabongisi ya kokweyisa ngai !
\q1 
\v 6 Bato ya lofundu batieli ngai mitambo,
\q2 batandi basinga ya minyama na nzela
\q2 mpe batimoli mabulu mpo na kokanga ngai.
\b
\q1 
\v 7 Nalobaka na Yawe :
\q2 « Ozali Nzambe na ngai ! »
\q2 Yawe, yoka mabondeli na ngai.
\q1 
\v 8 Oh Yawe, Nkolo na ngai,
\q2 ozali makasi ya lobiko na ngai,
\q2 obatelaka moto na ngai kati na mokolo ya etumba.
\q1 
\v 9 Yawe, kokokisa te posa ya moto mabe,
\q2 kolongisa te mabongisi na ye, noki te akokoma lolendo.
\q1 
\v 10 Tika ete pasi oyo bibebu na bango esili kobongisa
\q2 ekweyela bato oyo bazingeli ngai.
\q1 
\v 11 Tika ete makala ya moto esopanela bango !
\q2 Tika ete Nzambe atindika bango kati na moto,
\q1 kati na mabulu ya potopoto
\q2 epai wapi bakokoka kotelema lisusu te !
\b
\q1 
\v 12 Batioli bakowumela te kati na mokili,
\q2 pasi ekolanda bato na kanza na kolemba te.
\b
\q1 
\v 13 Nayebi ete Yawe akotaka makambo ya babola
\q2 mpe alongisaka bato oyo bakelela.
\b
\q1 
\v 14 Solo, bato ya sembo bakosanzola Kombo na Yo,
\q2 bato ya alima bakovanda liboso na Yo.
\c 141
\cl Nzembo 141
\s1 Simba ngai kati na loboko na Yo
\d 
\v 1 Nzembo ya Davidi.
\q1 Yawe, nazali kobelela Yo ; yaka noki epai na ngai !
\q2 Yoka mongongo na ngai, wana nazali kobelela Yo !
\q1 
\v 2 Liboso na Yo, tika ete libondeli na ngai ezala
\q2 lokola mbeka ya malasi,
\q1 mpe botombwami ya maboko na ngai ezala
\q2 lokola mbeka ya pokwa !
\q1 
\v 3 Yawe, kengela monoko na ngai,
\q2 batela malamu ekuke ya bibebu na ngai !
\q1 
\v 4 Kotindika motema na ngai te na mabe,
\q2 mpo ete namipesa te na mobulu
\q1 elongo na bato ya misala mabe
\q2 mpe nalia bilei te elongo na bango.
\b
\q1 
\v 5 Soki moto ya sembo abeti ngai, ezali elembo ya bolingo ;
\q2 soki apameli ngai, ezali mafuta na moto na ngai ;
\q1 moto na ngai ekoboya yango te.
\q2 Kasi libondeli na ngai ekotelemelaka bato ya misala mabe.
\b
\q1 
\v 6 Tika ete bilombe na bango babwakama na mabanga ;
\q2 na bongo, maloba na ngai ekoyokana,
\q2 pamba te ezali kitoko.
\q1 
\v 7 Lokola tango babalolaka mpe batimolaka mabele,
\q2 mikuwa na biso epanzani liboso ya mboka ya bakufi.
\q1 
\v 8 Yawe, Nkolo na ngai,
\q2 miso na ngai ebaluki mpo na kotala Yo ;
\q2 nazali kobombama kati na Yo,
\q2 kotindika ngai na kufa te !
\q1 
\v 9 Batela ngai mpo ete nakangama te na motambo na bango
\q2 mpe nakweya te na mabulu ya bato ya misala mabe.
\q1 
\v 10 Tika ete bato mabe bakangama
\q2 na mitambo na bango moko,
\q2 mpe ete ngai naleka na kimia !
\c 142
\cl Nzembo 142
\s1 Ozali ekimelo kaka moko mpo na ngai
\d 
\v 1 Nzembo ya Davidi. Maloba na ye tango azalaki kati na ebombamelo ya mabanga.
\q1 
\v 2 Na mongongo makasi, nazali koganga epai na Yawe ;
\q2 na mongongo makasi, nazali kobondela Yawe.
\q1 
\v 3 Natalisi likambo na ngai liboso na Ye,
\q2 natandi pasi na ngai liboso na Ye.
\b
\q1 
\v 4 Soki molimo na ngai elembi kati na ngai,
\q2 Yo oyebi epai nazali kokende.
\q2 Batieli ngai motambo na nzela oyo nazali kotambola.
\q1 
\v 5 Bwaka miso na ngambo ya loboko ya mobali mpe tala !
\q2 Moto ata moko te ayebi ngai lisusu,
\q1 nazali lisusu na ekimelo te,
\q2 moto ata moko te azali komitungisa na tina na ngai !
\b
\q1 
\v 6 Yawe, nagangi epai na Yo !
\q2 Nalobi : « Ozali ebombamelo na ngai,
\q2 libula na ngai kati na mokili ya bato ya bomoi ! »
\q1 
\v 7 Yoka koganga na ngai,
\q2 pamba te nazali na pasi makasi !
\q1 Kangola ngai wuta na maboko ya banyokoli na ngai,
\q2 pamba te baleki ngai na makasi.
\q1 
\v 8 Bimisa ngai na boloko
\q2 mpo ete nasanzola Kombo na Yo !
\q1 Bato ya sembo bakoya kozingela ngai
\q2 sima na Yo kosalela ngai bolamu.
\c 143
\cl Nzembo 143
\s1 Tambolisa ngai na banzela na Yo
\d Nzembo ya Davidi.
\q1 
\v 1 Yawe, yoka losambo na ngai,
\q2 landa mabondeli na ngai !
\q2 Yanola ngai na boyengebene mpe na bosembo na Yo.
\q1 
\v 2 Kosambisa mosali na Yo te,
\q2 pamba te moto moko te ya bomoi azali sembo liboso na Yo.
\b
\q1 
\v 3 Monguna azali konyokola ngai,
\q2 azali kosakana na bomoi,
\q1 azali kosala ete navanda kati na molili
\q2 lokola bato oyo bakufa na tango ya kala.
\b
\q1 
\v 4 Molimo na ngai elembi kati na ngai,
\q2 motema na ngai emitungisi kati na ngai.
\q1 
\v 5 Nakanisi mikolo ya kala,
\q2 namilobeli nyonso oyo osala,
\q2 nakanisi malamu mosala ya maboko na Yo.
\q1 
\v 6 Nasemboli maboko na ngai epai na Yo ;
\q2 nakomi komimona lokola mabele ya kokawuka.
\b
\q1 
\v 7 Yawe, zongisela ngai eyano noki !
\q2 Molimo na ngai ezali kolemba.
\q1 Kopesa ngai mokongo te,
\q2 noki te nakozala lokola bato oyo bazali kokita na libulu.
\q1 
\v 8 Na tongo makasi, sala ete nayoka boboto na Yo,
\q2 pamba te natia elikya na ngai kati na Yo.
\q1 Lakisa ngai nzela ya kolanda,
\q2 pamba te napesi bomoi na ngai epai na Yo.
\b
\q1 
\v 9 Yawe, kangola ngai
\q2 wuta na maboko ya banguna na ngai !
\q2 Nazali koluka ebombamelo epai na Yo.
\q1 
\v 10 Lakisa ngai kosala mokano na Yo,
\q2 pamba te ozali Nzambe na ngai.
\q1 Tika ete Molimo malamu na Yo atambolisa ngai
\q2 na mabele oyo ezanga mabaku !
\q1 
\v 11 Yawe, mpo na lokumu ya Kombo na Yo,
\q2 bikisa bomoi na ngai !
\q2 Na bosembo na Yo, longola bomoi na ngai kati na pasi.
\q1 
\v 12 Na bolingo na Yo, kanga minoko ya banguna na ngai
\q2 mpe limwisa bayini na ngai nyonso,
\q2 pamba te nazali mosali na Yo.
\c 144
\cl Nzembo 144
\s1 Bato na Yo bazali na esengo
\d 
\v 1 Nzembo ya Davidi.
\q1 Tika ete Yawe, Libanga na ngai, apambolama ;
\q2 Ye oyo akembisaka maboko
\q2 mpe makofi na ngai mpo na bitumba !
\q1 
\v 2 Azali bolingo na ngai mpe ndako na ngai ya makasi,
\q2 ebombamelo mpe mokangoli na ngai,
\q1 nguba mpe ekimelo na ngai ;
\q2 Ye nde atiaka bato na ngai na se ya bokonzi na ngai.
\b
\q1 
\v 3 Oh Yawe, moto nde nani mpo ete obatelaka ye ?
\q2 Moto nde nani mpo ete okanisaka ye ?
\q1 
\v 4 Moto azali lokola mopepe,
\q2 mikolo ya bomoi na ye ezali lokola elili oyo ezali koleka.
\b
\q1 
\v 5 Yawe, fungola likolo mpe kita awa na mabele !
\q2 Yaka kosimba bangomba mpe sala ete ebimisa milinga !
\q1 
\v 6 Tinda mikalikali mpe panza banguna na ngai ;
\q2 bwakela bango makonga na Yo mpe bungisa bango nzela.
\q1 
\v 7 Tanda loboko na Yo wuta kuna na likolo
\q2 mpo na kobikisa mpe kokangola ngai
\q2 na mayi minene, na maboko ya bapaya
\q1 
\v 8 oyo minoko na bango elobaka kaka lokuta
\q2 mpe maboko na bango elapaka ndayi ya lokuta.
\b
\q1 
\v 9 Oh Nzambe, nakoyembela Yo nzembo ya sika,
\q2 nakobetela Yo lindanda ya basinga zomi.
\q1 
\v 10 Ezali Yo, Nzambe, nde opesaka bakonzi elonga,
\q2 obikisaka Davidi, mosali na Yo,
\q2 liboso ya mopanga oyo ebomaka.
\q1 
\v 11 Bikisa mpe kangola ngai na maboko ya bapaya
\q2 oyo minoko na bango elobaka kaka lokuta
\q2 mpe maboko na bango elapaka ndayi ya lokuta.
\b
\q1 
\v 12 Bana mibali na biso bazali lokola milona,
\q2 bazali kokola malamu wuta na bomwana na bango ;
\q1 bana basi na biso bazali lokola bililingi kitoko
\q2 oyo batoboli na bamir ya ndako ya mokonzi.
\q1 
\v 13 Bibombelo na biso etondi
\q2 na biloko ya ndenge na ndenge ;
\q1 bameme na biso ezali kobotana na minkoko,
\q2 na bankoto zomi kati na bitonga na biso ;
\q1 
\v 14 bangombe na biso ezali minene ;
\q1 likama ezali te, zemi ezali kosopana te,
\q2 mpe koganga moko te ya pasi ezali koyokana
\q2 na bisika na biso.
\b
\q1 
\v 15 Esengo na bato oyo batondisami na bolamu ya boye !
\q2 Esengo na bato oyo Yawe azali Nzambe na bango !
\c 145
\cl Nzembo 145
\s1 Bokonzi na Yo ezali na suka te
\d 
\v 1 Masanzoli. Nzembo ya Davidi.
\q1 Nakotombola Yo, Nzambe na ngai, Mokonzi na ngai ;
\q2 nakopambola Kombo na Yo seko na seko.
\b
\q1 
\v 2 Mikolo nyonso, nakopambola Yo
\q2 mpe nakokumisa Kombo na Yo libela na libela.
\b
\q1 
\v 3 Yawe azali monene, abongi na lokumu ;
\q2 moko te akoki komeka mozindo ya monene na Ye.
\b
\q1 
\v 4 Bikeke nyonso ekotombola kitoko ya misala na Yo
\q2 mpe ekopanza sango ya misala na Yo ya minene.
\b
\q1 
\v 5 Nakolemba te kotatola bikamwa na Yo
\q2 mpe kongenga makasi ya nkembo na Yo.
\b
\q1 
\v 6 Bakolobela nguya na Yo ya somo,
\q2 mpe ngai, nakosakola misala na Yo ya minene.
\b
\q1 
\v 7 Bakokanisa misala minene ya bolamu na Yo,
\q2 bakobetela bosembo na Yo maboko.
\b
\q1 
\v 8 Yawe atonda na ngolu mpe na mawa,
\q2 asilikaka noki te mpe atonda na bolingo.
\b
\q1 
\v 9 Yawe azali malamu mpo na bato nyonso,
\q2 atonda na mawa mpo na bikelamu na Ye nyonso.
\b
\q1 
\v 10 Yawe, misala na Yo nyonso ekumisaka Yo !
\q2 Tika ete bayengebene na Yo bapambola Yo !
\b
\q1 
\v 11 Bazali koloba ete bokonzi na Yo etondi na nkembo
\q2 mpe bazali kopanza sango ya misala ya nguya na Yo.
\b
\q1 
\v 12 Bazali koyebisa bato misala na Yo ya minene
\q2 mpe kongenga ya nkembo ya bokonzi na Yo.
\b
\q1 
\v 13 Ozali Mokonzi seko na seko,
\q2 mpe bokonzi na Yo ekowumela libela na libela.
\b
\q1 Yawe akokisaka bilaka na Ye nyonso,
\q2 asalaka nyonso na bolingo.
\b
\q1 
\v 14 Yawe alendisaka bato nyonso oyo bakweyaka,
\q2 atelemisaka bato nyonso oyo balembaka.
\b
\q1 
\v 15 Na bato nyonso oyo batalelaka Yo,
\q2 opesaka bilei na tango oyo ekoki.
\b
\q1 
\v 16 Ofungolaka loboko na Yo
\q2 mpe okokisaka posa ya nyonso oyo ezali na bomoi.
\b
\q1 
\v 17 Yawe azali sembo na nyonso oyo asalaka
\q2 mpe atonda na bolingo kati na misala na Ye nyonso.
\b
\q1 
\v 18 Yawe azali pene ya bato nyonso
\q2 oyo babelelaka Ye,
\q2 ya bato nyonso oyo babelelaka Ye na solo ;
\q1 
\v 19 akokisaka posa ya bato oyo batosaka Ye,
\q2 ayokaka mpe abikisaka bango tango babelelaka Ye.
\b
\q1 
\v 20 Yawe abatelaka bato nyonso oyo balingaka Ye,
\q2 kasi abebisaka bato nyonso ya mabe.
\b
\q1 
\v 21 Tika ete monoko na ngai ekumisa Yawe !
\q2 Tika ete bikelamu nyonso epambola
\q2 Kombo na Ye ya bule libela na libela !
\c 146
\cl Nzembo 146
\s1 Nzambe alongisaka banyokolami
\q1 
\v 1 Bokumisa Yawe !
\b
\q1 Oh molimo na ngai, kumisa Yawe !
\q1 
\v 2 Nakokumisa Yawe bomoi na ngai mobimba,
\q2 nakosanzola Nzambe na ngai tango nyonso
\q2 nakozala na bomoi.
\b
\q1 
\v 3 Botia elikya te na bakambi
\q2 to na bato oyo bazangi makoki ya kobikisa.
\q1 
\v 4 Soki bakufi, bazongaka na mabele,
\q2 mpe, mbala moko, mabongisi na bango elimwaka.
\b
\q1 
\v 5 Esengo na moto oyo Nzambe ya Jakobi azali mosungi na ye,
\q2 oyo atiaka elikya na ye kati na Yawe, Nzambe na ye !
\b
\q1 
\v 6 Yawe akelaki Likolo mpe mabele,
\q2 ebale monene mpe nyonso oyo ezali kati na yango ;
\q2 azali sembo seko na seko.
\q1 
\v 7 Yawe akataka na sembo makambo ya banyokolami
\q2 mpe apesaka bilei na bato oyo bazali na nzala ;
\q2 abimisaka bakangami na boloko.
\q1 
\v 8 Yawe abikisaka miso ya bakufi miso ;
\q2 Yawe asembolaka bato oyo bazali ya kogumbama ;
\q2 Yawe alingaka bato ya sembo.
\q1 
\v 9 Yawe abatelaka bapaya,
\q2 asungaka mwana etike mpe mwasi oyo akufisa mobali,
\q2 kasi abebisaka banzela ya bato mabe.
\b
\q1 
\v 10 Yawe azali Mokonzi seko na seko ;
\q2 Nzambe na yo, oh Siona, libela na libela !
\b
\q1 Bokumisa Yawe !
\c 147
\cl Nzembo 147
\s1 Nzambe kati na mokili mpe kati na tango
\q1 
\v 1 Bokumisa Yawe !
\b
\q1 Tala ndenge ezali malamu kosanzola Nzambe na biso,
\q2 mpe ndenge ezali kitoko kokumisa Ye !
\q1 
\v 2 Yawe azali kotonga lisusu Yelusalemi
\q2 epai wapi akosangisa bato ya Isalaele
\q2 oyo bakenda na bowumbu.
\q1 
\v 3 Abikisaka bato oyo batutami na mitema
\q2 mpe akawusaka bapota na bango.
\b
\q1 
\v 4 Ayebi motango ya minzoto
\q2 mpe abengaka moko na moko na kombo na yango.
\q1 
\v 5 Nkolo na biso azali monene mpe atonda na nguya ;
\q2 mayele na Ye ezali na mondelo te.
\q1 
\v 6 Yawe asungaka babola,
\q2 kasi akitisaka bato mabe kino na mabele.
\b
\q1 
\v 7 Boyembela Yawe nzembo ya matondi !
\q2 Bobetela Nzambe na biso lindanda mpo na kosanzola Ye !
\q1 
\v 8 Azipaka likolo na mapata,
\q2 abongisaka mvula mpo na mokili
\q2 mpe abotisaka matiti na bangomba.
\q1 
\v 9 Apesaka bilei epai ya bibwele
\q2 mpe epai ya bana ya yanganga oyo ezali koganga mpo na nzala.
\q1 
\v 10 Asepelaka na makasi ya mpunda te
\q2 mpe alingaka te nguya ya moto ;
\q1 
\v 11 kasi Yawe asepelaka na bato oyo batosaka Ye,
\q2 ba-oyo batielaka bolingo na Ye motema.
\b
\q1 
\v 12 Yelusalemi, pesa nkembo na Yawe !
\q2 Siona, kumisa Nzambe na yo !
\q1 
\v 13 Alendisaka bikangelo ya bikuke na yo
\q2 mpe apambolaka bana na yo epai na yo.
\q1 
\v 14 Atiaka kimia na etuka na yo
\q2 mpe atondisaka yo na farine.
\b
\q1 
\v 15 Atindaka mitindo na Ye na mokili,
\q2 mpe maloba na Ye epanzanaka mbala moko !
\q1 
\v 16 Anokisaka mvula ya pembe lokola bapwale ya meme
\q2 mpe apanzaka mvula ya mabanga lokola putulu ;
\q1 
\v 17 akweyisaka mabanga ya mvula yango
\q2 lokola mabanga ya mike-mike ;
\q2 nani akoki kotelema na malili na yango ?
\q1 
\v 18 Soki kaka atindi liloba, malili ekomaka kosila moke-moke ;
\q2 mpe soki atindi mopepe, mayi ekomaka kotiola.
\b
\q1 
\v 19 Asakolaki liloba na Ye epai ya Jakobi,
\q2 mibeko mpe malako na Ye epai ya Isalaele.
\q1 
\v 20 Asalaki bongo na ekolo ata moko te ;
\q2 boye eyebaka mpe mibeko na Ye te.
\b
\q1 Bokumisa Yawe !
\c 148
\cl Nzembo 148
\s1 Kati na likolo mpe na mabele
\q1 
\v 1 Bokumisa Yawe !
\b
\q1 Bokumisa Yawe wuta na likolo,
\q2 bokumisa Ye na bisika oyo eleki likolo.
\q1 
\v 2 Bokumisa Ye, bino ba-anjelu na Ye nyonso ;
\q2 bokumisa Ye, bino mampinga na Ye nyonso ;
\q1 
\v 3 bokumisa Ye, bino moyi mpe sanza ;
\q2 bokumisa Ye, bino minzoto nyonso oyo engengaka ;
\q1 
\v 4 bokumisa Ye, bino oyo boleki likolo kati na likolo,
\q2 mpe bino mayi oyo bozali na likolo !
\b
\q1 
\v 5 Tika ete ekumisa Kombo ya Yawe !
\q2 Pamba te apesaki mitindo, mpe ekelamaki.
\q1 
\v 6 Atiaki yango mpo na libela ;
\q2 apesaki mibeko oyo ekobongwana te.
\b
\q1 
\v 7 Bokumisa Yawe wuta na mokili,
\q2 ezala bilima ya mayi to mozindo nyonso,
\q1 
\v 8 ezala moto to mvula ya mabanga,
\q2 ezala mvula ya pembe to londende,
\q2 ezala mopepe makasi oyo ekokisaka liloba na Ye ;
\q1 
\v 9 ezala bangomba milayi to bangomba mikuse,
\q2 ezala banzete oyo ebotaka bambuma to banzete ya sedele,
\q1 
\v 10 ezala banyama ya zamba to bibwele nyonso,
\q2 ezala bikelamu oyo etambolaka na libumu to bandeke,
\q1 
\v 11 ezala bakonzi ya mabele to bikolo nyonso,
\q2 ezala bakambi to batambolisi nyonso ya mokili,
\q1 
\v 12 ezala bilenge mibali to bilenge basi,
\q2 ezala bampaka to bana mike !
\b
\q1 
\v 13 Tika ete bakumisa Kombo ya Yawe !
\q2 Pamba te Ye moko kaka nde aleki likolo ;
\q2 nkembo na Ye eleki mabele mpe likolo.
\q1 
\v 14 Abongisi elombe mokangoli mpo na bato na Ye !
\q2 Ezali likambo oyo bayengebene na Ye nyonso,
\q1 bana nyonso ya Isalaele, bato oyo balingaka Ye,
\q2 basengeli kokumisa Yawe mpo na yango.
\b
\q1 Bokumisa Yawe !
\c 149
\cl Nzembo 149
\s1 Yawe alingaka bato na Ye
\q1 
\v 1 Bokumisa Yawe !
\b
\q1 Boyembela Yawe nzembo ya sika,
\q2 bokumisa Ye na banzembo kati na mayangani ya bayengebene !
\b
\q1 
\v 2 Tika ete Isalaele asepela na Mokeli na Ye !
\q2 Tika ete bato ya Siona bazala na esengo
\q2 mpo na Mokonzi na bango !
\q1 
\v 3 Tika ete bakumisa Kombo na Ye na mabina ;
\q2 tika ete babetela Ye bambunda mpe mandanda !
\q1 
\v 4 Pamba te Yawe asepelaka na bato na Ye,
\q2 alatisaka babola motole ya elonga.
\b
\q1 
\v 5 Tika ete bayengebene na Yawe basepela
\q2 kati na lokumu oyo ;
\q2 tika ete bayemba na esengo na bambeto na bango !
\q1 
\v 6 Tika ete bakumisa Nzambe kati na minoko na bango
\q2 elongo na mopanga ya minu na bangambo nyonso mibale
\q2 kati na maboko na bango
\q1 
\v 7 mpo na kozongisa mabe na mabe ya bikolo
\q2 mpe kopesa bato etumbu ;
\q1 
\v 8 mpo na kokanga bakonzi na bango na minyololo,
\q2 kokanga bato na bango ya lokumu na mabende
\q1 
\v 9 mpe mpo na kopesa bango etumbu oyo ekomama na tina na bango !
\q2 Yango nde lokumu ya bayengebene na Ye nyonso.
\b
\q1 Bokumisa Yawe !
\c 150
\cl Nzembo 150
\s1 Bokumisa Yawe na mindule
\q1 
\v 1 Bokumisa Yawe !
\b
\q1 Bokumisa Nzambe kati na Esika na Ye ya bule,
\q2 bokumisa Ye kati na likolo na Ye ya monene
\q2 epai wapi avandi na nguya makasi !
\q1 
\v 2 Bokumisa Ye mpo na misala minene na Ye !
\q2 Bokumisa Ye mpo na monene na Ye ya somo !
\b
\q1 
\v 3 Bokumisa Ye na lokito ya kelelo ;
\q2 bokumisa Ye na lokito ya nzenze mpe ya lindanda !
\q1 
\v 4 Bokumisa Ye na lokito ya bambunda mpe na mabina !
\q2 Bokumisa Ye na mandanda mpe na baflite !
\q1 
\v 5 Bokumisa Ye na lokito ya manzanza !
\q2 Bokumisa Ye na lokito ya bangongi minene !
\b
\q1 
\v 6 Tika ete nyonso oyo ezali na pema ekumisa Yawe !
\b
\q1 Bokumisa Yawe !
