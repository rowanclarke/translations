\v 23 \w Como|strong="H3588"\w* \w el|strong="H1931"\w* \w ave|strong="H6833"\w* \w que|strong="H3588"\w* \w se|strong="H3045"\w* apresura \w al|strong="H5704"\w* \w lazo|strong="H6341"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w sabe|strong="H3045"\w* \w que|strong="H3588"\w* \add es\add* contra \w su|strong="H1931"\w* \w vida|strong="H5315"\w*, \w hasta|strong="H5704"\w* \w que|strong="H3588"\w* \w la|strong="H1931"\w* \w saeta|strong="H2671"\w* traspa­só \w su|strong="H1931"\w* \w hígado|strong="H3516"\w*.   
