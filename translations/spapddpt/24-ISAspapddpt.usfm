\v 25 \w Sucederá|strong="H1961"\w* \w en|strong="H5921"\w* \w aquel|strong="H3605"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w gran|strong="H7227"\w* \w matanza|strong="H2027"\w* \w que|strong="H5921"\w*, \w cuando|strong="H3117"\w* \w caigan|strong="H5307"\w* \w las|strong="H5921"\w* \w torres|strong="H4026"\w*, \w habrá|strong="H1961"\w* arroyos \w y|strong="H5921"\w* corrientes \w de|strong="H5921"\w* \w agua|strong="H4325"\w* \w en|strong="H5921"\w* \w toda|strong="H3605"\w* montaña \w alta|strong="H1364"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w toda|strong="H3605"\w* colina elevada.
