\p
\v 1 \w About|strong="H3117"\w* \w that|strong="H3588"\w* \w time|strong="H3117"\w*, \w Hezekiah|strong="H2396"\w* \w became|strong="H2470"\w* \add very\add* \w ill|strong="H2470"\w* \w and|strong="H1121"\w* \w was|strong="H3068"\w* close \w to|strong="H4191"\w* \w dying|strong="H4191"\w*. \add So\add* \w I|strong="H3588"\w* \w went|strong="H3068"\w* \w to|strong="H4191"\w* see \w him|strong="H6680"\w*. \w And|strong="H1121"\w* \w I|strong="H3588"\w* \w gave|strong="H6680"\w* \w him|strong="H6680"\w* \w this|strong="H3541"\w* \w message|strong="H3068"\w*: “\w This|strong="H3541"\w* \w is|strong="H3068"\w* \w what|strong="H3541"\w* \w Yahweh|strong="H3068"\w* \w says|strong="H3541"\w*: ‘\w You|strong="H3588"\w* \w should|strong="H3068"\w* tell \w the|strong="H3588"\w* \w people|strong="H1121"\w* \w in|strong="H3068"\w* \w your|strong="H3068"\w* \w palace|strong="H1004"\w* \w what|strong="H3541"\w* \w you|strong="H3588"\w* \w want|strong="H3808"\w* \w them|strong="H1992"\w* \w to|strong="H4191"\w* \w do|strong="H3068"\w* \w after|strong="H3117"\w* \w you|strong="H3588"\w* \w die|strong="H4191"\w*, \w because|strong="H3588"\w* \w you|strong="H3588"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w recover|strong="H2421"\w* \w from|strong="H1121"\w* \w this|strong="H3541"\w* illness. \w You|strong="H3588"\w* \w are|strong="H3117"\w* going \w to|strong="H4191"\w* \w die|strong="H4191"\w*’ ”   
\p
\v 2 \w Hezekiah|strong="H2396"\w* \w turned|strong="H5437"\w* \w his|strong="H3068"\w* \w face|strong="H6440"\w* \w toward|strong="H6440"\w* \w the|strong="H6440"\w* \w wall|strong="H7023"\w*, \w and|strong="H3068"\w* \w prayed|strong="H6419"\w* \w this|strong="H6440"\w*:  
