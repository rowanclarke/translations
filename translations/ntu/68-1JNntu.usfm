\id 1JN stc-631JN-Nat.sfm, 1 John, Natqgu (Santa Cruz) STC, Daniel Boerger, 11/07/2007
\ide UTF-8
\h 1 Jon
\toc3 1 Jon
\toc1 Nzryrkr Jon Kx Ayrnrngr
\toc2 1 Jon
\mt1 Nzryrkr Jon Kx Ayrnrngr
\imt1 Natq Ngr Nzaplxtqngr Mz Nzryrkr Jon Kx Ayrnrngr
\ip Mc ‘Natq Ngr Nzaplxtqngr Mz Nrpakxmrlz Kx Yr Jon.’ Mwx yrle letz lc mz mzlir yiz 90—95 AD mz nibr nzrmcngr mz Jiszs. Jon yrbzle mz lrmakxtr mz provins kc Esia, kcng tzmnclzbzng bade. Suti drtwrde nzapqtr-krbzle nabzdr mz nzaxvctr-zvz-krbzlr mz Gct badr Mrlxde Jiszs Kxnzmcpx. X rpibzle badr kx bzkq nzvz-nqblq-krdr nzalvztrkr kxnzalvztr-rbrng, murde ma tzvecpx-lzbqmqng mz Gct x Mrlxde.
\ip Kzdung da kx vz-rbr nidr seleng. Nzrpilr kx da amrlx mz nrlc ka kx nzmc x nzbxtr ngi da kxdrka'ngr, myapxbz nrkrdrtq leplz. Mz nzpokia-krdr nzrpi-kzlr kx Jiszs nide txpwz ncblo, x Kraes nide mqngr kx prtrpz bade mzli kc tqwrkxtr-ngrde, x rlasz-moule nide x sc tztqlvztr ate mz kros. Mz drtwrdr, Kraes kc tqngi Mrlx Gct trngi-angidru ncblo. Nzrpi-kzlr kx nidr leplz kxnzmyapxbzng murde nzkrlzlr nzyrplapxngr kx yc-kapq. X trtakitrdeu nzvz-nqblq-krdr natq Gct, da kc tzwai kzdung kz leplz. A' mrlz nzvz-zvz nzrmwimi-krdr leplz kxtrngiu krnalzdr. X nzalvztr-rbr-ngrdr kx mzli kc ncblo tqrlapxpe-ngrde mz nzlxngiti-krde Kraes, aopxpebzle drtqde mz nzaoti-zvzkr drtwrde kxmu nzmnc-zpwxngr mz nrlc ka. X nzrpi-kzlr kx trtakitrdeu nzmrlzti-krgu Gct, nzvz-nqblq-krgu natqde, x nzmrlzti-lzbq-krgu.
\ip Jon yr-kzle letz lc murde nakrlzku leplz angidr neng Gct.
\iot Mrkcng Mz Letz Lc
\io1 Jiszs ngi angidr Mrlx Gct. \ior [1:1-4]\ior*
\io1 Gct tubq-esz'ngr x trpnzngr doa x da kxtrka kx natutrpz mz mzte. \ior [1:5—2:2]\ior*
\io1 Kxnamu nzkrlz-krgu doa angidr neng Gct. \ior [2:3—3:10]\ior*
\io2 Nzvz-nqblq-zvzlr natqde. \ior [2:3-6]\ior*
\io2 Nzaelwapx-ngrdr nivz, a' trngiu nzrtrkalrngr. \ior [2:7-11]\ior*
\io2 Trnztao-zvzung mz da kcng tzatalzngr nigu mz nrlc ka. \ior [2:12-17]\ior*
\io2 Krkcng tzrpilr kx Jiszs trngiu Kxnzmcpx trnznginidru doa neng Gct. \ior [2:18-27]\ior*
\io2 Nzmnckr doa neng Gct natubq. \ior [2:28—3:10]\ior*
\io1 Kxnamu nqmq kr doa neng Gct. \ior [3:11—5:13]\ior*
\io2 Namrlzti-lzbqng x navz-nqblq-zvzlr natqde. \ior [3:11-24]\ior*
\io2 Nzrpilr kx Jiszs nide Mrlx Gct x nzvz-nqblq-zvzlr nzalvztrkr aposol. \ior [4:1-6]\ior*
\io2 Nzaelwapx-ngrdr nivz lrde, murde nide nou nivz. \ior [4:7-21]\ior*
\io2 Nzlxngitilr kx Jiszs nide Kxnzmcpx, nzmrlztilr nide, nzvz-nqblqlr natqde, x nzaovxiolr nzatalz-ngrng. \ior [5:1-5]\ior*
\io2 Brti drtwrdr natq Gct mz nzycmnetr-krde Mrlxde Jiszs. \ior [5:6-13]\ior*
\io1 Nakabz Gct da mz kxnzrlxngiting mz nzmnc-xgle-krdrleng x kzdq natq kx xplr mou. \ior [5:14-21]\ior*
\c 1
\s1 Jiszs Ngi Nou Nzlungr Kxboi
\p 
\v 1 Krlc tqyrbo bamu Mevalu Kxnzmcpx kc tzrpibz ‘Natq Ngr Nzlungr.’ Murde nide nrpa kc tqatwzlr-ngrm Gct mz leplz, x nide nou nzlungr amrlx. Kxmule-esz' mnc pnz kai mzli kc tzwz-ngrdr nrlc, a' nigr aposol mc-angidrkr nide mz mzkr, lalztqbzkr mz nzalvztr-krdeng, kctipxkr nzale-krde da kxmatq kxkqlu, x maletr-kzpzkr nrkrdrtqde mz mqgr. \fig Nigr aposol mc-angidrkr Mevalu Kxnzmcpx mz mzkr.|alt="137 We were witnesses: JnBap w/John & Andrew, behold lamb" src="137-CN01660b.tif" size="COL" loc="1JN 1:1-3" copy="David C. Cook" ref="1:1"\fig*
\v 2 Nzmnc-along ncdr Trtede Gct mrkc Heven. Zbz vzm nzngini-krde leplz x aelwapx-lzbq-ngrm bagr. Mckr nide, x mzli ka ryrbo bamu mz nzpipx-zpwx-krbo bamu kx. Natwzku nzlungr kxboi mz nzaxvctr-krbzku bade.
\v 3 Pibo bamu da kx mckr x xlrkr, murde narmcti-kzamu nzlungr kxboi. X naprtr-kzpa'mu bagr mz nzodutr-lxblr-ngrbz mz Gct Trtegu x Mrlxde Jiszs Kxnzmcpx.
\v 4 Yrbo letz lc murde drtwrmu naelalzm mz nzvz-nqblq-krmu natqnge.
\s1 Gct Tubq-esz'ngr
\p 
\v 5 Nrpa kc tqxlrbzkr mz Mrlxde x tqpibo bamu nide sele. Gct tubq-esz'ngr, x trtxpnzngr alwx ngrde kx akamrbrngr da mz nabzde. Trpnzngr doa x da kxtrka kx natutrpz mz mz Gct.
\v 6 Nzmu narpiku kx nzaxvctrpzku mz Gct, a' ale-zvzku alwx, pokiaku murde pxtxpx-ngrgu nzalvztrngr angidr.
\v 7 A' mz nzvz-nqblq-krgu nqmq kr Gct, odutr-lxblrku badr. X nzbzkr Mrlxde Jiszs atubqtile nqmq krgu, mz nzvz-nqblq-krgu nide.
\s1 Naplzpxku Alwx Rgung
\p 
\v 8 Nzmu narpiku kx trpnzngr alwx rgung, esabrti-lzbqku x pxtxpx-ngrgu da angidr.
\v 9 A' nzmu naplzpxbzku alwx rgung mz Gct, sa naipqle nigu x naycpqpxbzle da kxtrka amrlx mz nabzgu, murde natubqbzku mz nzobq-krde. Murde angidati-zvzle natqde x ale-zvzle da kxtubq.
\v 10 Rpi Gct kx leplz amrlx nzaleng alwx. X mz nzrpi-krgu kx trpnzngr alwx rgung, rpi-kzku Gct pokia. X aelwapx-ngrde kx pxtxpx-ngrgu natqde.
\c 2
\s1 Jiszs Okatrle Nigu Mzli Kc Tqtao-ngrgu Mz Alwx
\p 
\v 1 Doa nengeng mz Kraes, yrbo natq lcng bamu murde nayrlqpx-lzbqamu mz alwx. A' nzmu kzdq nigu kc tqalele alwx, Jiszs Kxnzmcpx kc tqtubq-esz'ngr, tu mz mzlir Trtede badr leplz nedeng x okatrle nigu mz nzrlxti-krbzle bade nzipq-krde nigu.
\v 2 Murde rlrpx-lzbq mz nzbzngr, mz nzxpe-krde alwx kcng tqalekung. X nzbz-krde takitr-kzde nzxpe-alongr alwx ngr leplz amrlx mz nrlc tulvzo.
\s1 Kxnzvz-nqblqlr Natq Gct Nidr Doa Angidr Nedeng
\p 
\v 3 Nzmu nayrlq-angidrku da kcng tqalvztrngr Kraes, krlzku kx nepede nigu.
\v 4 A' doa kx trvz-nqblqleu natqde, a' rpile kx, “Nepe Kraes ninge, murde aotr-angidrx nide, x sa namncx Heven,” doa lc tqpokia.
\v 5 Murde krkcng tzyrlq-angidrlr natq Kraes, nzmrlzti-angidrlr Gct. X aelwapx-ngrgu kx nzaxvctrpebzku mz Kraes,
\v 6 mz nzmnc-nqblq-krgu nzmnckr Kraes mzli kc tqmnc-ngrde mz nrlc.
\s1 Kxnzmrlztilr Leplz Neng Gct Nidr Doa Angidr Nedeng
\p 
\v 7 Mzlengeng x inwengeng, mzli kc tqlxngiti-ate-ngrnamu Kraes, xlramu natq kx namrlzti-lzbqku. Natq lc trngiu natq kxmrna, murde krlztipeamule mzli boipe.
\v 8 Kxmule-esz', a' mz mzli lcpwz ngi kz natq kxmrna. Murde Kraes aelwapx-ngrde drtwr ngr nivz mz nzbz-krde nigu. X mzli ka okatrle nigu mz nzmrlzti-lzbq-krgu. X nqmq krde tqtekqtrle nqmq ngr alwx mz nabzgu, apule nepi nztekqtr-krde nrlckxbq mz nrlckxngrlx mz nzprtz-krmle. X nivz lc amrlz-kzle leplz.
\p 
\v 9 Mz nzmu-krde lcde, doa kx rpile mz naode kx vz-nqblqle nivz lr Kraes, a' mzli lcpwz trka bade kztedeng, mrlx lc tqvz-nqblqbele nqmq ngr alwx.
\v 10 A' krkc tqmrlztile kztedeng, myapxbz kxnzrlxngiting, vz-nqblqle nivz lr Kraes, x nqmq kr Gct yc mz nabzde. X trpnzngr da kxtrka kc tqyc mz nabzde mz nzbatr-krbzle nzatrkati-krde kztedeng.
\v 11 Doa kx trmrlztileu kztedeng mnc-mrbr, x nqmq krde trka. Alwx ngrdeng nzakamrbr-ngrdr da mz nabzde x lrpzki rde tutr mz Hxl. Apule mrlx kx vzne mz nrlckxbq x trmcleu me navzkile.
\p 
\v 12-14 Natq kc tqyrbo bamu takitrde nzvz-nqblq-krmu. Nimu kcng tzrlxngiti-ateng, krlzamu kx Gct ipqpxle alwx ngrmung murde Jiszs bz-ngrde nimu. X krlz-zpwxamu kx Gct nide Trtemu. Navz-nqblqamu natqnge.
\p X nimu kcng tzxplrng mz nzbrtikr drtwrmu Gct, sc tqaovxiopeamu Setzn kc Tqdrka'ngr. X natq Gct yc mz nabzmu. Navz-nqblq-kzamu natqnge.
\p X nimu kcng nzrlxngiti-krdr tqbrpe mz nzlolvz-amqngi-krmu Gct ncdr Mrlxde, kcng tzmnc-along, navz-nqblqamu natqnge kz.
\p 
\v 15 Bzkq mrlzm bagu nzvz-nqblq-krgu nqmq kr kxtrnzrlxngitiung mz nrlc ka. Murde nzmu namrlzm bagu dalr nrlc, rblx nzmrlzti-krgu Gct.
\v 16 Bzkq rlr-ngrbzme mz alwx nzaclve-krde nim, kxmule-esz' mz da kx suti drtwr nrkrdrtqm, x mz da kx kcmnzngr mzp, x mz da kx batrpzle nzglqpx-lzbq-krm. Murde drtwr kxnzmulr lcng trnzvzpxpuung mz Gct, a' nzvzpxmqng mz Setzn.
\v 17 X mzli trnaboiu x nrlc ka sa nayrkrpx. X da kxtrka scdeng amrlx sa namrbrmi-kzleng. A' doa kx vz-nqblq-zvzle me pnz drtwr Gct, sa nalu alo.
\s1 Kxnzalvztr-ngrdr Da Angidr Nidr Doa Angidr Neng Gct
\p 
\v 18 Doa nengeng mz Kraes, xlrpeamu kx mzli kc nayrkrpxngr nrlc, Enqmi Kxetu ngr Kraes sa navzm, kc narpwa'-ngrde nzwzkr Kraes amrlx. X mzli ka krlzku kx ycpe pipz nzyrkrpxkr nrlc, murde leplz kxnzkqlung kx nznginidr kz enqmi r Kraes, nzmncpemqng bagu.
\v 19 X mzli kc, enqmi r Kraes lcng nzaxvctr-lzbqmqng bagu, nigu lrmakxtr ne Kraes. A' mzli ka sc tzrlaszpelr nigu murde trnzlxngiti-angidrlru Jiszs. X krlzku kx trnznginidru doa neng Gct.
\p 
\v 20 A' trnipwamuu leplz kxnzmulr lcng, murde Kraes avzopemle Mqngrkxtr bamu, mz nzalvztr-krde nimu nzalvztrngr angidrng.
\v 21 Trpi-ngrpou da lcng bamu murde trkrlzwamuu da angidr. Trtingr! A' yr-ngrboleng bamu murde na-amqngile da angidr kc tqkrlzpeamu. Murde mz nzkrlz-krmu da angidr lc trpnzngr nzpokiangr kx krlzle nzesabrti-krde nimu.
\p 
\v 22 Kzdung leplz nzpokia-zlwzng mz nzrpi-krdr kx Jiszs trngiu Mevalu Kxnzmcpx. Leplz kxnzmulr lcng nzpxtxpx-ngrdr Gct Trte ncdr Mrlxde, x nidr enqmi r Kraes.
\v 23 Murde krkc tqpxtxpx-ngrde Kraes kc tqngi Mrlx Gct, sc tqpxtxpx-kz-ngrde Gct Trtede. A' krkc tqlxngitile Kraes, tzaxvctr-kzpz mz Trtede.
\p 
\v 24 Delc, nalxngiti-zvz-ngrnamu nike nzalvztr-ngrmu mz Kraes mzli kc tqrlxngiti-ate-ngrnamu. Murde na-axvctr-angidr-zvzbzmu mz Mrlx ncdr Trtede.
\v 25 X mz nzaxvctr-zvz-krbzku lc badr, sc tqrmctipeku nzlungr kxboi tqesalz-ngrm Gct bagu.
\s1 Mz Nzvz-nqblq-krgu Nzalvztrkr Mqngrkxtr Rblxbz Mz Setzn Nzesabrti-krde Nimu
\p 
\v 26 Ryrbo bamu murde na-aclvetio-lzbqamu. Murde enqmi r Kraes lcng tzrlaszlr lrmakxtr, nzabzlr nzesabrti-krdr nimu mz nzalvztr-krdr kxnamu leplz nzrlapxngr. A' nzalvztr-krdr vz-rbr.
\v 27 Kraes avzomle Mqngrkxtr mz nzmncpx-krmle mz nabzmu, murde na-alvztrle nimu mz da kx ngi da angidr amrlx, x nakrlzamu da kxtubq x da kx vz-rbr. Bzkq rtangrtiamu kxakrlz kc-kzng mz nzyokaetipx-krdr da kc tqaopxpebzle Gct bamu. A' nabrti drtwrmu Mqngrkxtr kc tqpi-zvzle da angidr. Mz nzmu-krde lcde, navz zvz nzaxvctr-krbzmu mz Kraes x nzvz-nqblq-krmu nide, da kc tqwai nzpi-krbz Mqngrkxtr le bamu.
\s1 Doa Neng Gct Nzvz-nqblqlr Natqdeng
\p 
\v 28 Na-axvctr-lzbq-zvzbzmu mz Kraes, murde ma tqmwxlramu x drtqmu tqmya mzli kc nayzlu-ngrmle.
\v 29 Krlzpeamu kx Kraes tubq-esz'ngr mz nzobqkr Gct, x opx kz kx doa angidr neng Gct navz-nqblq-kzlr nzmncngr lc tqtubq.
\c 3
\p 
\v 1 Gct mrlztile nigu. Nzmrlzti-krde nigu etu-esz'ngr, delc tqrpi-ngrgu nigu doa nedeng. Zpwxtx, nigu doa neng Gct! A' leplz kxnzkqlung mz nrlc ka kx trnzkrlzlru nide. Mz nzmu-krde lcde, trnzkrlz-kzlru nigu doa nedeng.
\v 2 Mzlengeng x inwengeng, mzli ka nginipegu doa neng Gct. X mzli kc nayzlu-ngrm Kraes, sa natekqtr Gct nigu. Kxmule-esz' tropxka mz drtwrgu myx kxnamuku, a' krlzku kx mzli lcde sa naopx-angidrpe nzmc-krgu nide mz nzkrlz-angidr-krgule. X sa natekqtr Gct nigu mz nzapu-angidr-krgu nide.
\v 3 X krkcng amrlx tzobqtipxlr nzyzlu-krmle, navecpx-lzbqng mz nzalengr alwx, a' namnc-nqblqlr nqmq kr Kraes, kx trpnzngr alwx ngrde.
\p 
\v 4 A' krkcng tzale-zvzng alwx nzpxtxpx-ngrdr Gct x nzxpqbrlr-ngrdr lou scdeng, murde krlc drtwr ngr nzalengr alwx.
\v 5 Jiszs trpnzngr alwx ngrde. X krlzku kx vzm mz nrlc murde leplz trna-alepelru alwx.
\v 6 Mz nzmu-krde lcde, krkcng amrlx tzaxvctr-lzbqpebzng bade, trnzalepelru alwx. A' opx angidr kx krkcng tzale-zvzng alwx, trnzkrlzlru nide x trnznginidru doa nedeng.
\p 
\v 7 Doa nengeng mz Kraes, bzkq rlr-ngrbzmu mz leplz nzesabrti-krdr nimu. Murde krkcng tzale-zvzng da kxtubq, nztubq-kzng mz nzobqkr Gct, da kc tqwai Kraes nztubq-krde mz nzobq-krde.
\v 8 A' krkcng tzale-zvzng alwx nzaelwapx-ngrdr kx nidr doa neng Setzn, kc tqngi Nar Drka', mz nzapu-krdr nide kc tqale kai alwx. A' Mrlx Gct vzm mz nzodati-krde nzwzkr Setzn amrlx, murde trka-zlwzng.
\p 
\v 9 Doa angidr neng Gct trnzale-zvzung alwx, murde nqmq kr Gct ycpxm badr. X rblxbz badr nzale-zvz-krdr alwx murde sutitx drtwrdr nzapu-krdr Trtedr.
\v 10 Delc, opx angidr kxmu nzglx-krgu neke doa ne Gct o neke doa ne Setzn. Murde krkcng trnzalelru da kxtubq x trnzmrlztilru kztedrng trnznginidru doa neng Gct.
\s1 Doa Angidr Neng Gct Nzmrlzti-lzbqng
\p 
\v 11 Natq kcpwz tqxlr-ngrnamu mzli kc tqrlxngiti-ate-ngrnamu, nide sele. “Nigu leplz neng Kraes namrlzti-lzbqku!”
\v 12 Bzkq apuku Ken kc tqvz-nqblqle Setzn kc Tqdrka'ngr x nibqle mzlede Ebol. Murde nztubqkr nqmq kr mzlede aelwapx-ngrbzle bade kx nqmq krde drka'ngr. \x + \xo 3:12 \xt Nou 4:1-16\x*
\p 
\v 13 Mz nqmq lcdepwz, bzkq kctipxku leplz kcng trnzvz-nqblqlru Gct nztrkatikr drtwrdr nigu.
\v 14 A' nzmrlzti-krgu kztegung kxnzrlxngiting, aelwapx-ngrde kx rlapxpeku mz nzbz-alongr x prtrpeku mz nzlungr kxboi. A' krkcng trnzmrlztilru leplz neng Kraes, nzmnclzbzng mz zmatq ngr nzbz-alongr.
\v 15 Krkcng tztrkati drtwrdr leplz, nzapulr kxnzrnibqng mz nzobqkr Gct. X leplz kxnzmulr lcng trnzprtrpzung mz nzlungr kxboi.
\v 16 Jiszs aelwa-ngrmle bagu drtwr ngr nivz angidr mz nzrlrpx-krde nzbz-krde mz nzokatr-krde nigu. X suti drtwrde kx narlrpx-lzbq-ngrgu mz nzokatr-krgu mzlegung x inwegung mz Kraes, kxmule-esz' drtqgu etq x bzku.
\v 17 Doa kx rngisc da x px-ngrde nzokatr-krde mzlede kx tr-rngiscu da, trpnzngr nivz lr Gct kx ycpxm mz nabzde.
\v 18 Doa nengeng mz Kraes, nivz angidr aelwapx-lzbq-ngrde mz nzokatr-krde leplz. Mane nzycmnetrkr ncblo nivz x mzli lcpwz trokatrleu leplz.
\s1 Gct Mrlztile Nigu Doa Nedeng, Kxmule-esz' Kzdung Mzli Taoku Mz Alwx
\p 
\v 19 Mz nzmrlzti-lzbq-krgu lc, nakrlz-angidrku kx nigu doa nedeng. X mzli kc tqkrka'-ngrgu nakrlz-kzku mz nabzgu kx mrlztile nigu.
\v 20 Kzdung mzli, mz nztao-krgu mz alwx, drtqgu mya, x trxngipebzkuu nivz lrde mz nabzgu. Kxmule-esz', a' Gct krlz-zpwxle da kx ycpxm mz nabzgu x nivz lrde myaszpx-zlwzle da lcng amrlx.
\v 21 Doa nengeng, mz nzkrlz-krgu mz nabzgu kx trvz-rbrkuu, nelzgu nabr mz nzkrka'-krbzku bade. \x + \xo 3:21 \xt 1 Jon 1:9\x*
\v 22 X mz nzkrka'-krgu lc, sa nakamle bagu da kznikeng rlxtibzku bade, murde sc tqvz-nqblq-zvzpeku natqdeng x abrtz-ngrde nqmq krgu.
\v 23 X natqde kx myapx-esz'ngr nide sele. “Nalxngitiku Jiszs Kxnzmcpx nzngini-krde Mrlx Gct x namrlzti-lzbqku, da kc tqwai nzpi-krm Jiszs le bagu.”
\v 24 X krkc tqmnc-nqblq-angidrle natq Gct, sc tqaxvctr-lzbqpe-kzpz mz Gct x Gct axvctr-lzbqpebz bade. X Mqngrkxtr kc tqavzomle bagu pi-zvzmle da lc mz nabzgu.
\c 4
\s1 Kxnamu Nzglx-krgu Kxakrlz Ne Gct O Kxakrlz Ne Setzn
\p 
\v 1 Mzlengeng x inwengeng, aclvetio-lzbqamu kxnzakrlz kx mnckilzamu. Murde kxnzalvztr-rbrng nzkqlung, x natqdrng nzvzpxmqng mz drka'. Mz nzmu-krde lcde, abz-kaiamu natq amrlx mz nzrmc-krmu me nzvzkipxmlr.
\v 2 Murde mzli kc natq kxakrlz vzpxm mz Mqngrkxtr, ncblo lc sa na-alvztr-ngrde kx Jiszs Kxnzmcpx nide Mrlx Gct, kc tqvzm mz nrlc nzngini-krde leplz. Krkcng tzalvztr-ngrdr da lc nidr angidr kxnzakrlzng neng Gct.
\v 3 A' ncblo kx alvztr-ngrde kx Jiszs trngiu Mrlx Gct, kc tqvzm mz nrlc nzngini-krde leplz, tqnginide enqmi r Kraes. Xlrpeamu kx Enqmi r Kraes Kc Etu sa navzm kalr. Kxmule-esz', a' mzli ka enqmi r Kraes kxnzkqlung nzmncpeng mz nrlc.
\p 
\v 4 A' nipemu doa neng Gct x aovxiopeamu kx nzalvztr-rbr lcng, x trnzesabrtipelru nimu. Murde Mqngrkxtr kc tqmncpxm bamu myaszpxle Setzn badr drka' nedeng kcng mncpxmqng mz krkcng trnzrlxngitiung.
\v 5 Natqdr nzvz-nqblqlr nzaokr drtwr leplz mz nrlc kcng trnzkrlzlru Gct, murde kxnzakrlz lcng trnzkrlz-kzlru nide. X kxnzvz-nqblq-ngrdr natqdr ngi txpwz kxtrnzkrlz-kzlru Gct.
\v 6 A' kxnzkrlzlr Gct nzvz-nqblq-kzlr nzalvztr-krgrng mz nzngini-krgr aposol neng Jiszs kcng tqatwzlr-ngrm Gct. Leplz kx trnginedeu nzpxtxpx-ngrdr nzalvztr-krgr. Mz nzmc-krmu da lcng tqpi-atebo, naglxamu kxmnc mzlilxlr kx vz-nqblqle natq angidr x krkc tqvz-nqblqle natq kx vz-rbr. \f + \fr 4:6 \ft Nzalvztrkr aposol nzycpxmqng mz Nzryrngrkxtr Kc Ate. \f*
\s1 Gct Ngi Nou Nivz Lrgu
\p 
\v 7 Doa nengeng, navz zvz nzmrlzti-lzbq-krmu. Murde Gct ngi nou nivz lrgu mz nzmrlzti-krgu leplz. X mz nzmrlzti-krmu lc leplz, opx angidr kx Gct mncpxm bamu x nimu doa nedeng murde apuamu Trtemu.
\v 8 X opx angidr kz kx doa kx trmrlztileu kztedeng trkrlzleu Gct. Murde nivz lr leplz kcng tzaxvctr-lzbqbz bade, na-apule nivz lrde.
\v 9 Gct aelwapx-ngrde kx mrlztile nigu leplz mz nzatwzlr-krmle mrlxde kc esz'txu mz nrlc, murde narmctiku nzlungr kxboi.
\v 10 X mz nivz lc tqetu-esz'ngr aelwapx-kz-ngrde drtwr ngr nivz angidr. Murde nivz lc trvzpxpuu mz nzmrlzti-krgu Gct, a' mz nzmrlzti-krde nigu. Murde mz nivz lc, atwzlr-ngrmle mrlxde mz nzngini-krde blz kx naxpe-ngrde alwx rgung.
\v 11 Mz nzmu-krde lcde, namrlzti-lzbqku kz, murde takitrde nzmrlzti-krgu leplz kcng tqbzngr Gct nidr.
\p 
\v 12 Kxmule-esz' trmckuu Gct, a' mncpxm mz nabzgu nzmu namrlzti-lzbq-zvzku. X tekqtr-zvzle nabzgu murde nivz lrgu na-apupwzle nivz lrde.
\v 13 X krlzku kx Gct sc tqmncpxm mz nabzgu x axvctr-lzbqpebzku bade, murde kapemle Mqngrkxtr bagu. \f + \fr 4:13 \ft Mzli kc Mqngrkxtr tqmncpx-ngrmle mz nabz leplz, opx-angidrbz badr. Murde ycmne-lrpibz badr x okatrle nidr mz nzbrtikr drtwrdr Jiszs, nzmrlzti-krdr nide x nzvz-nqblq-krdr natqde. Mqngrkxtr aelwapx-ngrbzle alwx rdrng badr, murde naplxpxbzlr alwx lcng mz Gct x naipqle nidr. X mou, kabzle badr zmatqng kxmyapxbz mz nzwztr-krbzlr mz Gct. \f*
\m 
\v 14 Nigr aposol pipx-zvzbzkr mz leplz kx Gct Trte atwzlr-ngrmle Mrlxde mz nzarlapx-krde lr nrlc. Murde mc-angidrkr mz mzkr da lcng tqprtzting mzli kc.
\v 15 Krkc tqrlxngitile x rpile kx Jiszs nide Mrlx Gct, Gct sc tqmnc mz nabzde x nzaxvctr-zvzbz bade.
\v 16 Krlzpeku nzetu-krm nivz lr Gct bagu, murde aelwapx-ngrmle nivz lc bagu. X brtipe drtwrgu kx sa namrlzti-zvzle nigu, murde krlc nqmq krde. X krkcng tzmrlzti-zvzlr leplz, sc tzaxvctrpebzng mz Gct kc tqmncpxm mz nabzdr.
\p 
\v 17 Mz nzaxvctr-krbzku mz Kraes, tekqtrle nigu murde nivz lrgu na-apupwzle nivz lrde. X na-apuku nide mz nzmnc-krgu mz nrlc ka. Mz nzmu-krde lcde, nelzgu nabrpe mz nztutr-krbzku mz mz Kraes mzli kc nayzlu-ngrmle.
\v 18 Doa kx mwxlrtile nzayrplapxkr Gct nide mzli lcde, trkrlzkale kx Gct mrlztile nide. Murde mz nzkrlz-angidr-krde nivz lr Gct mz nabzde, trpnzngr zmwxlr kx naycpx-kzp elr.
\v 19 Nzmrlzti-krgu Gct x leplz vzpxm mz nzmrlzti-kaikr Gct nigu.
\v 20 Doa kx rpile kx mrlztile Gct, a' trkati drtwrde kztedeng, nide kxdrka'ngr kxpokia. Murde doa kx trkati drtwrde leplz kcng tqmctrpzle mztr, rblx nzmrlzti-krde Gct kc trmctrpwzleu mzte.
\v 21 Natq kx kam Kraes bagu nide sele. Doa kx mrlztile Gct, namrlzti-kzle kztedeng! \x + \xo 4:21 \xt Matiu 22:37-40; Mak 12:29-31; Luk 10:27-28; Jon 13:34; 14:15; 15:12\x*
\c 5
\s1 Doa Neng Gct Nzmrlztilr Nide, // Nzvz-nqblqlr Natqdeng, X Nzbrti Drtwrdr Kx Jiszs // Nide Mrlxde
\p 
\v 1 Krkcng amrlx tzlxngitilr kx Jiszs nide Kxnzmcpx ne Gct, nidr doa angidr nedeng x nzmrlztilr Gct Trtedr. X mrlzti-kzlr doa amrlx nedeng.
\v 2 X nzmrlzti-krgu lc doa nedeng vzpxm mz nzmrlzti-krgu Gct x nzvz-nqblq-krgu natqde.
\v 3-5 Aelwapx-ngrgu nzmrlzti-krgu Gct mz nzvz-nqblq-krgu natqde. X natqde tr-rblxpuu bagu murde doa nedeng nzkrlzlr nzvz-nqblq-krdr me pnz drtwr Trtedr. Doa nedeng amrlx kcng tzlxngitilr kx Jiszs nide Mrlxde, nidr txpwz kx nzrngiscng zmatq ngr nzaovxio-krdr nzatalzngr x alwx amrlx. Zmatq lc vzpxm mz nzabrtr-krbzku drtwrgu mz Jiszs nzokatr-krde nigu.
\s1 Gct Aelwapx-ngrbzle Kx Jiszs Nide Angidr Mrlxde
\p 
\v 6-8 Rkx kcng tq nzaelwapx-ngrdr kx Jiszs nide angidr mrlx Gct. Rkx kx ayrnrngr lue. Murde mzli kc tqwrkxtrngr Jiszs, rpi Gct kx, “Krlc Mrlxde.” Rkx krali mepyr. Murde yrleo-ngrm Jiszs mepyr ngrde mz kros mz nzbz-krde nigu. X rkx kratq Mqngrkxtr kc tqmncpxm mz nabzgu. Murde drtwrde esz'ti badr Gct kx Jiszs nide Mrlxde. Delc rkx lcng tq, lue, mepyr, x Mqngrkxtr drtwrdr esz'ti mz nzaelwapx-krmlr bagu kx Jiszs nide Mrlx Gct.
\v 9 Mz nrlc ka, lxngitiku nike nzpipx leplz mz nzycmnetr-krdr mz da kx nzkrlzlr. Delc takitrde nzlxngiti-kz-krgu natq Gct mz nzycmnepx-krde kx Jiszs nide Mrlxde. Murde Gct myaszlzle leplz x trkrlzleu nzpokiangr.
\v 10 Nigu amrlx kcng tzlxngitilr Mrlx Gct, krlzpeku mz nabzgu kx natq Gct ngi da angidr. A' doa kx trlxngitileu da kx pipxngr Gct Mrlxde, rpile kx Gct pokia, murde pxtxpx-ngrde natqde.
\s1 Krkcng Tzlxngitilr Da Kx Pipxngr Gct Mrlxde Narmctilr Nzlungr Kxboi
\p 
\v 11 Natq Gct nide sele. Gct sc tqkamle bagu nzlungr kxboi kc tqvzpxm mz Mrlxde.
\v 12 Krkc tqlxngitile Mrlx Gct rmctile nzlungr kxboi, a' krkc tqpxtxpx-ngrde Mrlxde trprtrpepzu mz nzlungr lc.
\p 
\v 13 X yrbo da lcng amrlx bamu, murde sc tqlxngitipeamu kx Jiszs nide Mrlx Gct. X suti drtwrnge kx nakrlz-kzamu kx sc tqrmctipeamu nzlungr kxboi.
\s1 Gct Ayzlubzle Nzkrka'kr Doa Nedeng
\p 
\v 14 Nigu doa neng Gct. Mz nzmu-krde lcde, krlzku kx mzli kc tqkrka'-ngrgu tqrlx-ngrbzku da mz Gct mz nzvz-nqblq-krde me pnz drtwrde, lalztqm bagu.
\v 15 X sa nakamle bagu da kcng tqrlxtibzku bade, mz nzvz-nqblq-krde me pnz drtwrde.
\p 
\v 16 Mz nzmu-krde lcde, mzli kc tqmc-ngrgu mzlegu mz Kraes kc tqale alwx kx tryrkrpxu mz nzbz-alongr, nakrka'-ngrgu x narlxtibzku mz Gct nzipq-krde nide. X Gct sa na-alq-mopwzle nabzde x na-amnctr-lxblr-moule nidr rlilrdr. A' kzdung alwx nzyrkrpxng mz nzbz-alongr, da kc tqwai mz nzpxtxpxngr Jiszs nzngini-krde Mrlx Gct. Bzkq rlxtibzku mz Gct nzipqpx-krde alwx kxnzmulr lcng.
\v 17 Nzvz-rbr-ngrng amrlx delang tqngi alwx mz nzobqkr Gct. A' alwx kxnzkqlung kx trnzbatrpwzlru mz leplz nzpxtxpx-alo-krdr Gct. Krlcng krlzle nzipqpx-krdeleng. \f + \fr 5:17 \ft Alwx esz'txu kx tripqpxu Gct. Krlc nzpxtxpxngr Mqngrkxtr kc tqokatrle leplz nzlxngiti-krdr Jiszs. Murde Gct krlzle nzipqtx-krpwzle krkcng tzplzpxbzlr alwx ngrdrng bade. A' rblxbz mz doa kc tqpxtxpx-ngrde Mqngrkxtr nzyckr drtwrde alwx ngrdeng, murde Mqngrkxtr dekc tqokatrle leplz mz nzkrlz-krdr alwx ngrdrng. X trpnzngr nzipqkr Gct doa kc trpnzngr nzplzpx-krbzle alwx ngrdeng bade. Bzkq krka'-ngrgu doa kc tqpxtxpx-ngrde Mqngrkxtr. Mc kz Matiu 12:32. \f*
\s1 Da Kcng Tqkrlzku
\p 
\v 18 Da kcng tqkrlzku nidr seleng. Krlzku kx doa angidr neng Gct trnzale-zvzlru alwx, a' nzvz-nqblqlr nqmq kr Gct. X Mrlx Gct aclvele nidr, murde Setzn ma tqatrkatile nzrlxngiti-krdr.
\v 19 X krlz-kzku kx nigu doa neng Gct, a' leplz amrlx kcng trnginedeu nzmnclzbzng mz zmatq ngr Setzn kc Tqdrka'ngr.
\v 20 X krlz-kzku kx Mrlx Gct vzm mz nzokatr-krde nigu murde nakrlz-zpwxku Gct angidr. X na-axvctrpzku bade mz nzaxvctr-lzbqpe-krbzku mz Mrlxde Jiszs Kxnzmcpx, kc tqngi kz Gct angidr x nou nzlungr kxboi.
\p 
\v 21 Doa nengeng, aclvetio-lzbqamu. X bzkq rlrpx-lzbq-ngrbzku mz doa x da kx natekqtrlr Gct mz nabzgu. A' na-angio-txpwzku nide.
\cls Delape. Mrlztix nimu. Ninge \sig Jon. \sig* 
