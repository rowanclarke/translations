\id TDX - Waskia Scriptures; 10-Dec-2013; Topical Index; Fay Barker and Janet Lee 
\h SAONGA DEN SAKI 
\toc1 Bala koma koma se nunga saonga den saki 
\toc2 SAONGA DEN SAKI 
\toc3 SAONGA DEN SAKI 
\mt1 Bala koma koma se nunga saonga den saki  
\s1 KAEM  
\b  
\li1 Nu bagoso: Psa 53:1; John 1:18; Acts 17:28; Rom 1:19-20; Heb 1:1-2 (Existence)  
\li1 Nu pempem bagoso, kumik menara mena: 1 Tim 1:17; Heb 1:10-12; Rev 1:8 (Eternal)  
\li1 Nu kuwim suen biya te bagoso: Psa 39:7-8; Acts 17:27 (Omnipresent)  
\li1 Noko bagara kelemak nunguningkiri: Isa 55:8-9; Rom 11:33-36; Pro 30:4 (Transcendant)  
\li1 Nu laili se diram: Mat 5:48; 1 Peter 1:16; Rev 15:4 (Holy, righteous)  
\li1 Nu sokel ago: Gen 1:1; Rom 1:20 (Omnipotent: all powerful)  
\li1 Nu mel suen biya beteram: Gen 1:1-2; Heb 11:3 (Creator)  
\li1 Nu mel suen biya bitarso: Psa 33:11; Pro 21:1; Acts 17:22-31; Eph 1:9-11 (Sovereign)  
\li1 Nu ko munan me guruguso patawoso: Heb 13:8; James 1:17 (Unchanging)  
\li1 Nu mel suen biya ko ikiso: Psa 139:1,4; Pro 15:3; Mat 10:29-30; Rom 11:33; Heb 4:13 (Omniscient: all knowing)  
\li1 Nu ko den balam mu karo tuso, ale nangarak la bagoso: Psa 36:5; 1 Cor 1:9; Heb 6:18; 1 Peter 4:19; Rev 19:11 (Faithful)  
\li1 Nu kariimet ninguru nunga kueso: Psa 145:8-9; Mat 7:11; 12:20; Luke 6:35-36; John 3:16; Rom 2:4; 5:8; Eph 2:4; 3:17-19; 1 John 3:1; 4:8,16,19 (Loving)  
\li1 Nu kariimet nunga tuteso ale memek betera alo mu koma ikup nungarso: Nahum 1:2-3; Rom 1:18-19; Heb 9:27; 12:18,23,28-29 (Judges sin)  
\li1 Nuet, Namar, Bur Laili, bare nunga bala suwanta: Mat 3:16-17; 28:19; Acts 5:3-4; Heb 1:8-12 (Trinity)  
\s1 Nuet:  
\li1 Nu Bur: John 4:24  
\s1 Namar Jesus:  
\li1 Nu Kaem tala: Mat 1:23; 18:20; 28:18-20; Luke 4:41; John 1:1-2; 8:58; 10:30-33; 16:30; 17:5; 20:28; 21:17; Heb 1:8,12; 13:8  
\li1 Nu Alpha se Omega: Rev 1:8  
\li1 Nu te mel suen la aratam se nu iluwoso: John 1:3; 1 Cor 8:6; Col 1:16; Heb 1:3  
\li1 Nu kari ko aratam: Phil 2:6-11  
\li1 Nu ko Nuet nanga kasurso: John 1:14,18; 14:7-11; Col 1:15,19; Heb 1:2-3  
\li1 Noko nup bo mu “Kaem ko den”: John 1:1; Rev 19:13  
\li1 Nu kariimet nunga memek siwurokko kueram: Isa 53:1-12; Luke 24:7; John 1:29; Eph 1:7; Heb 9:25-28; 10:7-10,14; 1 Peter 1:19; 3:18  
\li1 Nu kueram ale aking barasam: Luke 24:39-43; John 10:18; 20:19-29; Rome 1:4; 4:25; 1 Cor 15:6,17-19  
\li1 Nu duruk wonong te bagoso: Mark 16:19; John 17:5; Acts 1:9; Heb 4:14-16; 7:24-25  
\li1 Nu Kris alo nunga Kari Biya: Eph 1:22 5:23; Col 1:18  
\li1 Nu Bur Laili Kris alo nungarso: Mat 3:11; Luke 24:49; John 14:26; 16:7; Acts 1:8  
\li1 Nu Prophet: Deut 18:15; Mat 17:5; 21:11; Luke 7:16; 13:33  
\li1 Nu Priest: Heb 2:17-18; 4:14-16; 9:26; 10:12  
\li1 Nu King: Isa 9:7; Jer 23:5; Dan 7:14; Mat 2:2; 21:5; 25:34; Luke 1:33; Heb 1:8; Rev 11:15; 17:14; 19:16  
\li1 Nu Tutera Kari: Mat 13:40-42; 25:32; John 5:22; Acts 10:42; 17:31; Rom 2:16; 14:10; 2 Tim 4:1; Rev 20:11-15  
\li1 Nu Sangaru Tata Kari: Luke 1:69; 2 Peter 1:11  
\s1 Bur Laili:  
\li1 Nu Kaem tala: Psa 139:7; Acts 5:3-4; 1 Cor 2:10-11  
\li1 Nu sokel ago nunguning: Zech 4:6; Mat 3:11; 12:28; Luke 24:49; Acts 1:8; 2:3; 8:17-19,39; 10:38,44; 19:6  
\li1 Nu Jesus ilak baga se sangam sokel tuikaso: Luke 3:22; 4:1,18; Acts 10:38  
\li1 Noko ura saki: John 14:16-26; 15:26; 16:7-15; Acts 2:1-40; Rom 8:1-27; 1 Cor 12-14  
\li1 Nu kariimet gomang motam iru tuso: John 6:63; 2 Cor 3:6; 1 Peter 3:18  
\li1 Nu Kris alo nunga nongomang ningi bagoso ale sokel nungarso: Ezekiel 36:27; John 14:17; Rom 8:9; 1 Cor 3:16; 1 John 2:27  
\li1 Nu Kris alo nunga manarso nuna Kaem ko kuriang maso: Rom 8:16; Gal 4:6; 1 John 3:24; 4:13  
\li1 Nu kariimet nunga kiti guruguso: Luke 12:12; John 14:26; 16:13; Acts 8:29; 10:19-20; 13:2; 16:6; 1 Cor 2:13; 2 Peter 1:21; 1 John 2:27; Rev 22:17  
\li1 Nu balu maguwura mu ikup aromemek: Mark 3:29; Acts 5:3; 7:51; Eph 4:30; 1 Thes 5:19; Heb 10:29; 1 John 5:16  
\s1 KAEM KO DEN  
\li1 Kaem kote tairam se memek bo mena, nunguningta se diram: Pro 30:5-6; Luke 24:44; John 5:46-47; Acts 17:11; 2 Tim 3:16; 2 Peter 1:19-21  
\li1 Tom suen biya anirukko: Mat 24:35; 1 Peter 1:24-25; Rev 22:19  
\li1 Sokel ago: Isa 55:10-11; Mark 4:26-29; Luke 8:11-15; Rom 1:16; Eph 5:26; 6:17; 2 Tim 3:17; Heb 4:12  
\li1 Kariimet nunga sangarso: Psa 119:105,130; Mat 4:4; Luke 24:27; John 5:39-40; 15:3; 17:17; Acts 20:32; Rom 15:4; 1 Peter 2:2; 1 John 2:14  
\li1 Ninguru ko ikinak ale karo tunakko: Psa 119:59-60; Mat 22:29; Col 3:16; 2 Tim 4:2; James 1:22-25  
\s1 KAEM KO ENGEL  
\li1 Nuna duruk wonong te bagasan: Isaiah 6; Mark 12:25; Luke 12:8; 15:7,10; Heb 12:22; Rev 7:11; 8:2  
\li1 Nuna Kaem ko ura betesan: Gen 3:24; Mat 1:20; Luke 1:11,26; Acts 12:23  
\li1 Nuna kariimet nunga sangorsan: Psa 91:11; Mat 2:13,19; Acts 5:19; 12:7; 27:23; Heb 1:14  
\s1 SATAN SE KO ENGEL SE KO BUR MEMEK  
\li1 Satan engel saki nunga giam se kowom karosan: Mat 25:41; 2 Peter 2:4; Jude 6  
\li1 Nu kawel kari, Kaem ilak barimoso ale kariimet nunga maguwurokko ago kaeso: Gen 3:1,15; Mark 4:15; John 8:44; 10:10; 2 Cor 4:4; 11:14; 1 Peter 5:8; Rev 9:11; 12:9; 20:2,7-9  
\li1 Nu kawel te ali imi ko supuling ko aratam bare nu uwuta me baga lagurukko: Luke 4:6; John 12:31; 16:1; Rev 20:10  
\li1 Kristus noko sokel menawu kutuwurokko: Gen 3:15; Mat 25:41; 1 Cor 15:25; Thes 2:2; Heb 2:14; 1 John 3:8  
\li1 Bur memek: Mat 12:43-45; Mark 1:26; 5:8-9; 7:30; 9:17; 16:9; Luke 10:19-20; Acts 8:7; 19:12-16; Eph 6:12; 1 Tim 4:1; James 2:19; Rev 16:14  
\s1 KARIIMET  
\li1 Kaem kota numi dora te kariimet nunga nungam: Gen 1:27-31; 2:7. Nuna nup ago: Psa 8:3-8  
\li1 Kaem ko gomang mu kariimet noko ikimonko: Mat 22:37-40; John 10:10; Acts 17:26-27; Rev 21:3-4  
\li1 Kariimet suen la memek beteman: Gen 6:5; Isa 53:6; Mark 7:21-23; John 2:24-25; Rom 3:23; Eph 4:18-19; 1 John 1:8  
\li1 Buta se nuna kari kuera iwita: Gen 2:17; 3:1-24; Mat 8:22; John 6:53; Rom 6:23; Eph 2:1; 5:14; Col 2:13; 1 Tim 5:6; James 1:14-15; 5:20; Rev 3:1  
\li1 Bare Bur ko sokel te Kristus ningi kariimet iru ko aratasan: John 1:12-13; 3:3; 2 Cor 5:17; Titus 3:5; 1 Peter 1:23; 1 John 5:1  
\s1 DEN GILALONG YAWARA  
\li1 Giris palaga ko den: Psa 51:17; Mat 3:2; 5:4; Luke 13:3; 15:21; 18:13; Acts 3:19; 17:30; 2 Cor 7:10  
\li1 Kristus ko nangamang ningi nunguning ko den: John 3:15-16; 5:24; 11:25; 12:46; 20:31; Acts 4:12; 10:43; 16:31; Rom 10:9; 1 John 5:13-14  
\li1 Anuwa marak tata ko den: Mat 28:19; Mark 16:16; John 3:5; Acts 2:38; 8:12,38; 9:18; 10:48; 16:15,33; 18:8; 19:5; 22:16; Rom 6:3; 1 Cor 12:13; Gal 3:27; Col 2:12; 1 Peter 3:21  
\li1 Pempem bagara ko den: Gen 2:9; Dan 12:2; Mat 25:46; Luke 18:30; John 4:36; 5:24; 6:27,40; 10:28; 12:25; 17:3; Rom 2:7; 6:22; Gal 6:8; Titus 1:2; 1 John 2:25; 5:11-14; Jude 21; Rev 2:7; 22:1-2  
\s1 MUNAN MEMEK KO DEN  
\li1 Munan memek betera ko munan mu anape? Rom 14:23; Gal 3:10; James 2:10-11; 4:17; 1 John 3:4; 5:17  
\li1 Munan memek nubiring tua ko den: John 5:14; 8:11; Rom 6:12; 1 Cor 15:34; Eph 4:22; Heb 12:1; 1 Peter 2:11  
\li1 Munan Den 10: Exodus 20  
\li1 Munan memek duap duap: Mark 7:21-22; Rom 1:29-31; 1 Cor 6:9-10; Gal 5:19-21; Eph 4:25-31; 5:3-12; Col 3:5-10; 1 Thes 4:3-8; 2 Thes 3:6-13; Rev 21:8; 22:15  
\s1 Munan memek saki:  
\li1 Bo buring ko den bala: Pro 10:18-21; 16:28; 2 Cor 12:20; 1 Tim 5:13  
\li1 Dawur: Deut 18:10; Acts 13:6-11; Rev 21:8  
\li1 Den kawel bala: Psa 34:13; Pro Col 3:9  
\li1 Gagor: Pro 6:6-11; 2 Thes 3:6-12  
\li1 Ining singi kager: Rom 13:13; Gal 5:15; James 4:1-2; Pro 11:17 se ko footnote ago arikko  
\li1 Kaem kaem kawel nunup patowara: Psa 4:2; Acts 7:41-43; Rev 21:8  
\li1 Kari kuera ko dora se bur memek arungu munakara: Deut 18:11  
\li1 Munak ngual kasik bala: Mat 12:33-37; James 3; 4:13-16; Proverbs 12:18 se footnote saki ago arikko  
\li1 Namotam nangamang barasa: Luke 12:15  
\li1 Nangamang magara: Mat 5:22; Eph 4:26; James 1:19-20  
\li1 Nainimi patowara: Pro 11:2; 16:18; Mat 23:12; James 4:16; 1 John 2:16  
\li1 Nasupuling aora biya bagara: Acts 7:51; Pro 1:7 se ko footnote ago arikko  
\li1 Saman katagot: Pro 5 se 6; Mat 5:28; Heb 13:4  
\li1 Suwik sapara ko munan: Pro 9:7-8  
\li1 Tere nana: Mat 19:18; Eph 4:28  
\li1 Yu nana ngualara: Pro 20:1; 21:17; 23:20-21,29-35; 31:4-7; Eph 5:18  
\s1 BAGARA AOLAK KRISTUS NINGI  
\li1 Jesus kingdom ningi bagara ko munan saki balam: Matthew chapters 5-7  
\li1 Bur Laili nanga sangarso se munan ningo imitang aratoso: Gal 5:22-23  
\li1 Nu ana ura duap duap te betera ko mu ko sokel nangaru gurugam: 1 Cor 12-14; Rom 12:4-8; Eph 4:7-12; 1 Peter 4:10-11  
\li1 Kilek ningo duap duap ko den: Rom 12; Gal 5:22-6:10; Eph 4:1-3,32; 5:1-2,15-21; 6:10-18; Col 5:1-4,12-17; 1 Thes 4:9-12; 5:12-22; 2 Peter 1:3-11  
\s1 Munan gira se biya nunguning:  
\li1 Kaem kua tui se ilak kapetara: Mat 22:37; John 17:23-26  
\li1 Jesus kua tui se ilak kapetara: John 14:23; 15:4,9-11; 21:15; Gal 2:20; Phil 1:21; 3:7-15; 1 Peter 1:8  
\li1 Bur Laili kua tui se ilak kapetara: Rom 8; Gal 5:16,22,25; Eph 4:30; 5:18  
\li1 Nainimi kua tui se bagara: Mat 22:39; 5:43-44; John 13:35; 15:12; 1 Cor 13; Eph 5:2; Col 3:14; 1 Thes 3:12; 1 Peter 1:22; 1 John 3:11-24; 4:7-21  
\s1 Munan saki Bur ko sokel te Kris alo nunga ningi aratoso:  
\li1 Amilmil te bagara: Luke 10:20; Acts 5:41; 16:23-25; Rom 12:15; 2 Cor 6:10; Phil 4:4; 1 Thes 5:16; Heb 10:34; James 1:2-4; 1 Peter 4:12-13  
\li1 Guranek: Mat 6:5-15; 7:7; 18:19; 26:41; Mark 11:24-25; Luke 18:1; John 15:7; 16:24; Acts 1:14; 4:31; Rom 8:26-27; Eph 6:18; Phil 4:6; Col 4:2-4; 1 Thes 5:17; James 5:13,16; 1 Peter 5:7; 1 John 3:22; 5:14  
\li1 Ikia sinar kua tua: James 3:13-18; Proverbs 2:3-5 se ko footnote ago arikko  
\li1 Ikup gia bare am sokel ago bagara: Mat 5:11-12; 10:22,39; Acts 5:41; 9:16; Rom 8:17; 2 Cor 1:3-10; 4:11; 11:23; Heb 11:25; James 1:2-4; 5:10; 1 Peter 2:20-23  
\li1 Jesus ko dugu duap nguangara mena saki alo nunga maona: Mat 10:32-33; Mark 5:19; John 15:27; Acts 1:8; 4:20; 5:20-21; Rom 1:16; 2 Tim 1:8; 1 Peter 3:15  
\li1 Jesus tairukko nomotam loaga se bagara: Mat 24:44; 25:13; Luke 12:37; 1 Cor 1:7; Titus 2:13; Rev 16:15; 22:20  
\li1 Kaem amilmil tua: Phil 4:6; 1 Thes 5:18  
\li1 Kaem bowa ningi la bagara: Pro 1:7; Mat 4:10; 10:28  
\li1 Kaem kuring karo tua: Gen 6:22; 22:2-3; Mat 7:21; 12:50; John 7:17; 14:23; 15:10; Acts 5:29; Heb 5:8; James 1:22-25  
\li1 Kaem per tui se nup biya tua: Mat 4:10; 14:33; 28:9; John 4:24; 20:28; Heb 1:8; 13:15; Rev 5:8-14; 14:7; 22:9  
\li1 Kingdom mel gira ko betera: Mat 6:10,33; Mat 13:44-46; Col 3:2; James 4:1-6; 1 John 2:15-17  
\li1 Kris saki arungu biguwura: Acts 2:42; Heb 10:25; 1 John 1:7  
\li1 Kua kapara ko munan: Pro 22:4; Mat 18:4; Luke 14:10; 22:26; Rom 12:3; Phil 2:5-8; James 4:10; 1 Peter 5:5; Proverbs 11:2 se ko footnote ago arikko  
\li1 Lila te saki arungu bagara: Rom 12:14-21; James 3:17-18  
\li1 Manga mel ko me kua tua: Mat 6:19-24; Luke 12:13-21; James 5:1-6; Proverbs 10:15 se ko footnote ago arikko  
\li1 Manga mel te saki alo nunga saonga: Mat 5:42; 6:1-4; Luke 6:38; Acts 4:34-35 11:29; 20:35; Rom 12:13; 1 Cor 16:2; 2 Cor 8:2,12-15; 9:6-7; Gal 6:10; Phil 4:16; 1 Tim 5:3; Heb 13:16; Proverbs 11:24-26 se ko footnote ago arikko  
\li1 Munak ningo se diram la bala ale te saki alo nunga saonga: Eph 4:29; Col 4:6; James 1:19,26; 3:2; Proverbs 15:1 se ko footnote ago arikko  
\li1 Nangamang ningi nunguning te bagara: Mat 6:25-34; 17:20; Mark 9:23; John 6:28-29; Rom 5:1; 10:17; 14:23; Gal 2:20; 5:6; Eph 6:16; Phil 3:9; Heb 10:22; 11:1-40; James 1:5-6; 1 John 3:23; 5:4-5  
\li1 Nangamang suwanta bagara: John 17; Phil 2:1-2  
\li1 Saki alo nangamang nungara ale nunga memek siwura: Mat 5:7; 6:14; 18:21-22; Mark 11:25; Luke 17:4; Eph 4:32; Col 3:13; James 2:12-13  
\li1 Ura tata: 1 Thes 5:14; 2 Thes 3:6-12; Proverbs 6:6-11 se ko footnote ago arikko  
\s1 NUWUS KUARI KURIANG ARUNGU BAGARA KO MUNAN  
\li1 Kari imet numi gia ko den: Gen 2:23-24; Mark 10:6-8; Luke 20:35; 1 Cor 7:1-16,25-40; 2 Cor 6:14-15; Heb 13:4  
\li1 Kari nunga den: 1 Cor 6:15-20; Eph 5:25-33; Col 3:19; 1 Thes 4:3-4; 1 Tim 2:8; Titus 2:2,6; 1 Peter 3:7  
\li1 Imet nunga den: Pro 12:4; 31:10-31; 1 Cor 6:15-20; Eph 5:22-24; Col 3:18; 1 Tim 2:9-15; Titus 2:3-5; 1 Peter 3:1-6  
\li1 Kuriang nunga den: Pro 10:1; Eph 6:1-3; Col 3:20  
\li1 Nuam nuet nunga den: Pro 22:6; Eph 6:4; Col 3:21; Mat 15:22; Mark 5:23; Luke 15:20; Proverbs 13:1 se ko footnote ago arikko  
\li1 Nuwus kuari numi betera ko den: Mat 5:31-32; 19:3-6; Mark 10:9; Rom 7:2; 1 Cor 7:10-14,39  
\s1 KRIS ALO NUNUMI KAROGO BAGARA KO MUNAN  
\li1 Kaem ko ura kariimet nunga den: Acts 20:17-35; 1 Cor 2:1-16; 9:19-23; 2 Cor 6:1-10; 1 Tim 3:1-16; 6:11-21; 2 Tim 2:1-20,25; Titus 4:1-5; James 3:1; 1 Peter 5:1-4  
\li1 Kris alo nunga supuling nunga saonga: Mat 10:10; Rom 10:15; 15:30; 1 Cor 16:16; Gal 6:6; Phil 2:29; 1 Thes 5:12-13; 1 Tim 5:17; Heb 13:7,17  
\li1 Pasa inang na ko munan: Mat 26:26; Mark 14:22; Luke 22:19; 1 Cor 10:16; 11:23  
\s1 SOR SAKI  
\s1 Duruk wonong:  
\li1 Mat 6:20; Luke 10:20; John 14:2; Acts 7:55-56; 2 Cor 5:1; Heb 11:10; Rev 7:9 Paradise: Luke 23:43; 2 Cor 12:4; Rev 2:7  
\s1 Ali imi:  
\li1 Kaem ali imi beteram: Gen 1:1-2:25; Psa 8:3; 24:1-2; Acts 14:15; Heb 11:3  
\li1 Kaem ali imi den ikup tuam: Gen 3:17; Rom 8:19-23  
\li1 Kaem Noah ko tom te ali maguwuram: Gen 7:1-24; 2 Peter 3:6  
\li1 Kaem ali ko den saki iru balam: Gen 8:21-22; 9:3-4,9-17  
\li1 Kaem ali taiti iru nungokko: Isa 60:19-22; 65:17-25; Acts 3:21; 2 Peter 3:11-13; Heb 12:27-28; Rev 21:1; 22:3  
\s1 Kuera nunga nuguwim (Hebrew Sheol, Greek Hades):  
\li1 Luke 16:20; Acts 2:27; Rev 1:18; 6:8; 20:13  
\li1 \bd Tama biya:\bd*  
\li1 Mat 3:12; 5:22,29; 10:28; 13:42; 18:9; 23:15,33; 25:41; Mark 9:43-44; Luke 12:5; James 3:6; Rev 14:10; 20:10,15; 21:8  
\s1 MEL UDAGI ARATUKKO  
\li1 Den maiya la chapter imi te aniso: Matthew 24-25; Mark 13; Luke 21; Revelation ko den sang  
\li1 Den saki tala Jesus balam: Mat 13:36-43,47-50; Luke 17:26-37; John 14:1-3,18,28-29  
\li1 Kariimet nunga bagara aolak maga sapurukko: Mat 24:12; 2 Thes 2:1-3, 9-12; 2 Tim 3:1-5,12-13; 2 Peter 3:3-7; Jude 14-19  
\li1 Kari Memek Munan Kiawara ko den: 2 Thes 2:1-4,8  
\li1 Kristus ilak Barimara ko Kari ko den: 1 John 2:18-19; 4:3; 2 John 7  
\li1 Kristus peleruk tairukko: Mat 24-25; Mark 13; Luke 21; John 14:1-3,18,28-29; Acts 1:9-11; 3:19-21; 1 Cor 4:5; Col 3:1-4; 1 Thes 1:9-10; 2 Thes 1:6-10; 2 Tim 4:1-2; Heb 9:27,38; 2 Peter 3:8-12; Jude 14-15; Rev 1:7; 3:11-12; 16:15; 22:12,20  
\li1 Kariimet kueman mu aking barasomonko: Job 19:25-27; Psa 49:15; Isa 25:6-8; 26:19-21; Dan 12:2; Mat 24:30-31,39-40; John 5:28-29; Rom 8:18-25; 1 Cor 15; Phil 3:11,21; 1 Thes 4:13-18; Rev 20:4-6  
\li1 Yia tom 1000: Rev 20:1-7  
\li1 Satan memek taukko: Rev 20:1-10; 11:24-25; Acts 24:15; Rom 8:22-25; 1 Cor 15:20-28, 35-38; Phil 3:20-21; 1 Thes 4:13-18  
\li1 Jesus kariimet nunga tuterukko: Mat 25:31-46; 2 Thes 1:6-10; 2 Tim 4:1-2; 2 Peter 3:3-7; Jude 14-15; Rev 20:11-15  
\li1 Ali iru, taiti iru, Jerusalem iru: Acts 3:19-21; 2 Peter 3:11-13; Rev 21,22  
