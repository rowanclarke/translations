\id 2TI
\h Timoteo II.
\toc1 Timoteo II.
\toc2 Timoteo II.
\toc3 Timoteo II.
\mt1 Timoteo II.
\c 1
\s1 O KA EPISETOLE
\q1 
\v 1 NA Paulo, he lunaolelo na Iesu Kristo ma ka makemake o ke Akua, mamuli o ka olelo mua no ke ola iloko o Kristo Iesu,
\q1 
\v 2 Ia Timoteo, ke keiki punahele; ke aloha, a me ke ahonui, a me ka maluhia, mai ke Akua mai, o ka Makua, a me Kristo Iesu, ko kakou Haku.
\b
\q1 
\v 3 Ke aloha aku nei au i ke Akua, i ka'u mea e malama nei mai o'u mau kupuna mai, me ka manao maemae, i ko'u hoomanao mau ana aku ia oe i ka'u pule ana i ka po a me ke ao;
\q1 
\v 4 E ake ana e ike ia oe, e manao ana hoi i kou waimaka, i hoopihaia'i hoi au i ka olioli;
\q1 
\v 5 I ko'u hoomanao ana hoi i ka paulele hookamani ole iloko ou, i ka mea i noho mua'i iloko o kou kupuna wahine o Loisa, a me kou makuwahine o Eunike; a ke manao nei hoi au iloko ou kekahi.
\q1 
\v 6 Nolaila hoi ke paipai aku nei au ia oe, e hoomahuahua i ka haawina a ke Akua, i ka mea iloko ou ma ke kau ana o ko'u mau lima.
\q1 
\v 7 No ka mea, aole ke Akua i haawi mai ia kakou i ka manao makau; aka, o ka wiwo ole, a me ke aloha, a me ka naauao.
\q1 
\v 8 Mai noho oe a hilahila i ka mea a ko kakou Haku i hoike mai ai, aole hoi ia'u i kana pio nei; aka, e lawe pu oe i ka ehaeha ana no ka euanelio, mamuli o ka mana o ke Akua:
\q1 
\v 9 O ka mea nana kakou i hoola, a i wae mai hoi me ka wae hoano; aole hoi mamuli o ka kakou hana ana; aka, mamuli no o kona manao iho a me ka pono i haawiia mai ia kakou iloko o Kristo Iesu mamua loa aku o keia ao;
\q1 
\v 10 A ua hoakakaia mai ia i keia manawa ma ka ikea ana mai o ko kakou ola o Iesu Kristo, ka mea i kinai i ka make, a i hoomoakaka mai hoi i ke ola a me ka make ole, ma ka euanelio;
\q1 
\v 11 Nona wau i hookaawaleia'i i kahunahai, i lunaolelo, i kumu ao hoi no na lahuikanaka.
\q1 
\v 12 Nolaila hoi au i loohia'i i keia mau mea. Aka, aole au i hilahila; no ka mea, ua ike au i ka mea a'u i hilinai aku ai, ke manaoio nei hoi au, e hiki no ia ia ke malama i ka'u mea i haawi aku ai ia ia a hiki wale aku i kela la.
\q1 
\v 13 E hoopaa oe i ke kumu o na olelo kupono, au i lohe mai ai ia'u, ma ka manaoio a me ke aloha iloko o Kristo Iesu.
\q1 
\v 14 O ka mea maikai i kaurohaia aku ia oe, o kau ia e malama ai ma o ka Uhane Hemolele la, ka mea e noho ana iloko o kakou.
\b
\q1 
\v 15 Ua ike oe i keia mea, ua haalele mai ia'u ko Asia poe a pau; o Pugelo, a me Heremogene kekahi o ua poe la.
\q1 
\v 16 E haawi mai ka Haku i ke aloha i ko Onesiporo hale; no ka mea, ua hooluolu pinepine mai oia ia'u, aole hoi oia i hilahila i ko'u kaulahao.
\q1 
\v 17 Aka, ia ia ma Roma nei, ua huli ikaika oia ia'u a loaa.
\q1 
\v 18 E haawi mai ka Haku ia ia, e loaa mai ia ia ke alohaia mai e ka Haku i kela la. Ua ike paka oe i na mea he nui ana i malama mai ai ia'u ma Epeso.
\c 2
\b
\q1 
\v 1 O OE hoi, e ka'u keiki, e hooikaika ma ka pono iloko o Kristo Iesu.
\q1 
\v 2 A o na mea au i lohe mai ai ia'u ma na mea hoike he lehulehu, oia kau e kauoha aku ai i na kanaka kupaa, i ka poe makaukau hoi i ke ao aku ia hai.
\q1 
\v 3 E hoomanawanui hoi oe me he koa maikai la no Iesu Kristo.
\q1 
\v 4 Aole ke kanaka kaua e hoohihia ia ia iho i na mea o keia ola ana; i hiki hoi ia ia ke hooluola i ka mea nana ia i kuka e lilo i koa.
\q1 
\v 5 Ina e paio kekahi i lanakila, aole ia e hooleiia i ka lei, ke paio ole mamuli o ke kanawai.
\q1 
\v 6 He pono no ka mahiai e hana ia mamua o ka loaa ana o ka hua.
\q1 
\v 7 E noonoo oe i ka'u e olelo nei; a e haawi mai ka Haku ia oe i ka naauao ma na mea a pau.
\q1 
\v 8 E hoomanao hoi oe ia Iesu Kristo ka mamo a Davida, ua hoala hou ia mai ka make mai, e like me ka'u euanelio;
\q1 
\v 9 E a mea a'u i loohia'i i ka ino a me ka paa ana, me he kanaka hewa la; aka, aole i hoopeaia ka olelo a ke Akua.
\q1 
\v 10 Nolaila au e hoomanawanui nei i na mea a pau e pono ai ka poe i alobaia, i loaa hoi ia lakou ke ola iloko o Kristo Iesu, mo ka nani mau loa.
\q1 
\v 11 He olelo oiaio keia; Ina i make pu kakou, e ola pu no hoi kakou.
\q1 
\v 12 Ina e hoomanawanui pu kakou, e noho pu no hoi kakou i ke aupuni; a ina e hoole aku kakou ia ia, oia kekahi e hoole mai ia kakou.
\q1 
\v 13 A ina o kupaa ole kakou, oia nae ke kupaa mau; aole e hiki ia ia ke hoole ia ia iho.
\b
\q1 
\v 14 O keia mau mea kau e paipai aku ai ia lakou, me ke kauoha aku imua i ke alo o ka Haku, e hoopaapaa ole Lakou i na huaolelo waiwai ole, e hookahuli ana i ka poe lohe mai.
\q1 
\v 15 E hooikaika nui oe e hoike ia oe iho imua o ke alo o ke Akua me ka hoaponoia mai, i paahana hoi aole e pono ke hilahila, e puunaue pono aku ana i ka olelo oiaio.
\q1 
\v 16 E pale ae hoi i ka wawa hewa ana me ka lapuwale; e ulu ana no ia e mahuahua ai ka haihaia.
\q1 
\v 17 E aai ana hoi ka lakou olelo me he mai aai la: o Humenaio a me Pileto kekahi o lakou.
\q1 
\v 18 A no ka olelo oiaio, ua lalau hewa laua, e olelo ana ua hala e ke alahouana; a ke hoohiolo nei i ka manaoio o kekahi poe.
\q1 
\v 19 Oiaio hoi, ke kupaa mau nei ke kumu a ke Akua mai, me keia hoailona ona; Ua ike mai no ka Haku i kona poe ponoi; a, O ka mea i hoohiki i ka inoa o Kristo e haalele loa aku ia i ka hewa.
\q1 
\v 20 A iloko o ka hale nui, aole o na ipu gula a me ke kala wale no, aka, o ka laau, a me ka lepo kekahi; no ka hanohano kekahi, no ka hanohano ole kekahi.
\q1 
\v 21 A ina i hoomaemae ke kanaka ia ia iho ia lakou, e lilo no ia i ipu hanohano, i hoomaemaeia e pono ai ka Haku, a makaukau hoi no na hana maikai a pau.
\q1 
\v 22 E haalele hoi i na kuko o ka wa opiopio; a e hahai mamuli o ka pono, o ka manaoio, o ke aloha, a me ka maluhia; me ka poe i kahea aku i ka Haku mai loko aku o ka naau maemae.
\q1 
\v 23 A o na niele lapuwale a me ka naaupo, o kau ia e pale aku, me ka ike e aku ua hooulu lakou i ka hakaka.
\q1 
\v 24 Aole hoi e pono i ke kanwa a ka Haku e hakaka; aka, e akahai i na mea a pau, e akamai hoi i ke ao aku, e ahonui i ke ino:
\q1 
\v 25 E ao hoohaahaa aku ana i ka poe i ku e mai; i haawi mai paha ke Akua ia lakou i ka mihi a me ka hooiaio ana i ka olelo oiaio;
\q1 
\v 26 A i hoohemo lakou ia lakou iho mai loko ae o ka upena a ka diabolo, ka poe i lawe pio ia e ia ma kona makemake.
\c 3
\b
\q1 
\v 1 E I A hoi kau mea e ike ai; a i na la mahope e hiki mai ana na manawa popilikia.
\q1 
\v 2 No ka mea, e lilo ana na kanaka i poe makemake ia lakou iho, puni kala, hooioi, hookano, hoino wale, hoolohe ole i na makua, aloha ole, huikala ole,
\q1 
\v 3 Aole aloha maoli, pale berita, niania wale, kuko umi ole, huhu, hoowahawaha i na mea pono,
\q1 
\v 4 Kumakaia, paakiki, naau kiekie, makemake i ka lealea, aole makemake i ke Akua.
\q1 
\v 5 Hookokohu manao i ke Akua, aka, e hoole ana i ka mana o ia mea: e hookaawale ae oe mai ia poe ae.
\q1 
\v 6 O kekahi o ua poe la, na mea i komo iloko o na hale, e alakai pio ana i na wahine lapuwale i kaumaha i ka hewa, a i alakai e ia'e hoi e kela kuko a e keia kuko,
\q1 
\v 7 E ao mau ana hoi, aka, aole loa e hiki ia lakou ko ike i ka oiaio.
\q1 
\v 8 A, me ka Iane, a me ka Iamebore i ka e mai ai ia Mose, pela hoi ua poe la i ku e mai i ka olelo oiaio; na kanaka naau ino, a ma ka manaoio ua hoohewaia lakou.
\q1 
\v 9 Aka, aole lakou e hiki i ke kau wahi hou aku; no ka mea, e akaka ana no i na kanaka a pau ko lakou lapuwale e like me ke akaka ana o ko laua la.
\q1 
\v 10 Aka, ua ike paka oe i ka'u ao ana, noho ana, manao ana, paulele ana, hoomanawanui ana, aloha ana, ahonui ana,
\q1 
\v 11 A me ka hoomaauia a me ka ehaeha, me ia i loaa ia'u ma Anetioka, ma Ikonio, ma Lusetera, na hoomaau ana a'u i hoomanawanui ai; aka, ua hoola mai ka Haku ia'u mai loko mai o ua mau mea la a pau.
\q1 
\v 12 Oiaio hoi, o ka poe a pau e noho haipule ana iloko o Kristo Iesu, e hoomaauia'na hoi lakou.
\q1 
\v 13 Aka, o kanaka hewa, a me ka poe hoopunipuni, e mahuahua ana ko lakou hewa, e hoopunipuni aku ana me ka hoopunipuniia mai.
\q1 
\v 14 Aka hoi, e noho paa oe ma na mea au i ao iho ai, a i manaoio ai hoi, me ka ike aku i ka mea nana oe i ao mai.
\q1 
\v 15 A, mai kou wa kamalii uuku mai, ua ike oe i ka palapala hemolele, i ka mea e hiki ia ia ke hoonaauao ia oe e ola'i, ma ka manaoio iloko o Kristo Iesu.
\q1 
\v 16 O ka palapala hemolele a pau, na haawiia mai ia e ka Uhane o ke Akua, he mea ia e pono ai, no ke ao ana, no ka papa ana, no ka hoopololei ana, no ka hoonaauao ana ma ka pono;
\q1 
\v 17 I hemolele ai ke kanaka o ke Akua, i makaukau lea ai hoi i na hana maikai a pau.
\c 4
\b
\q1 
\v 1 KE a kauoha aku nei au imua o ke alo o ke Akua a me ka Haku, o Iesu Kristo, o ka mea e hookolokolo ana i ka poe ola a me ka poe make i kona hiki ana mai, a i kona aupuni;
\q1 
\v 2 E hai aku oe i ka olelo; e hooikaika i kela manawa a i keia manawa; e hoakaka aku, e papa aku, e paipai aku, me ke ahonui wale, a me ke ao ana'ku.
\q1 
\v 3 No ka mea, e hiki mai ana ka manawa e hoolohe ole ai lakou i ka olelo pono; aka, me ka pepeiao maneo e hapuku lakou i na kumuao na lakou mamuli o ko lakou kuko iho.
\q1 
\v 4 A e haliu ae lakou i na pepeiao mai ka olelo oiaio aku, a e hoohuliia'ku hoi ma na olelo lapuwale.
\q1 
\v 5 Aka, e kiai oe ma na mea a pau, e hoomanawanui i ka popilikia, e hana i ka oihana a ke kahuna hai euanelio, a e hooiaio loa aku i kau oihana.
\q1 
\v 6 No ka mea, ua makaukau au no ka nininiia'ku, a ua kokoke mai nei ka manawa o'u e hele aku ai.
\q1 
\v 7 Ua paio aku au i ka paio maikai, ua hoopau ae nei au i ka holo ana, ua hoopaa no hoi au i ka manaoio:
\q1 
\v 8 Ma keia hope aku, e waiho mai ana no'u he lei o ka pono, ka mea a ka Haku a ka Lunakanawai hoopono e haawi mai ai ia'u i kela la; aole hoi ia'u wale no, aka, i ka poe a pau i makemake i kona ikea ana mai.
\b
\q1 
\v 9 E hooikaika oe e hele koke mai io'u nei.
\q1 
\v 10 No ka mea, ua haalele o Dema ia'u, ua makemake ia i ke ao nei, a ua hele aku la ia i Tesalonike, o Keresena hoi i Galatia, o Tito hoi i Dalematia.
\q1 
\v 11 O Luka wale no hookahi me au. E kono oe ia Mareko e hele pu mai me oe; no ka mea, he mea ia e pono ai no'u ma ka oihana kahuna.
\q1 
\v 12 O Tukiko hoi ka'u i hoouna aka ai i Epeso.
\q1 
\v 13 O ka aahu a'u i waiho aku ai ma Teroa ia Karepo, o kau ia e lawe pu mai i kou hele ana mai, a me na buke, a me na ilipalapala hoi.
\q1 
\v 14 O Alekanedero ka hanakeleawe, ua hooili mai ia'u i na hewa ho nui; e hoopai mai ka Haku ia ia e like me kana hana.
\q1 
\v 15 E ao hoi oe ia oe iho ia ia; no ka mea, ua hoole ikaika mai oia i ka kakou mau olelo.
\q1 
\v 16 I ka'u hoike pono mua ana, aohe mea i ku pu mai me au aka, ua pau na kanaka i ka haalele mai ia'u: mai hoopaiia mai lakou ia mea.
\q1 
\v 17 Aka hoi, o ka Haku ka i ku mai me a'u; a ua kokua mai hoi ia'u, i hooiaio nui ia'ku ma o'u la ka hai ana'ku o kana olelo, i lohe mai no hoi na lahuikanaka a pau; a ua hoopakeleia mai hoi au i ka waha o ka liona.
\q1 
\v 18 A e hoopakele mai ana no ka Haku ia'u i na hana hewa a pau, a e malama mai hoi a hiki i kona aupuni i ka lani; nona hoi ka hoonani mau loa ia'ku. Amene.
\b
\q1 
\v 19 E aloha aku ia Pariseka, a me Akuila, a me ko ka hale o Onesiporo.
\q1 
\v 20 Ua noho no o Eraseto ma Korineto: a ua waiho aku au ia Teropimo ma Mileto, e mai ana.
\q1 
\v 21 E hooikaika oe e hele mai mamua o ka hooilo. Ke aloha aku nei o Eubulo ia oe, a o Ponde, a o Lino, a o Kelaudia, a o ka poe hoahanau a pau.
\b
\q1 
\v 22 O ka Haku pu kekahi o Iesu Kristo me kou uhane, E alohaia mai oukou. Amene. 
