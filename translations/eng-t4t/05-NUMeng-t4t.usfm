\v 29 \w But|strong="H3588"\w* \w Moses|strong="H4872"\w*/\w I|strong="H3588"\w* replied, “◄\w Are|strong="H5971"\w* \w you|strong="H5414"\w* worried \w that|strong="H3588"\w* \w they|strong="H3588"\w* \w might|strong="H3068"\w* injure \w my|strong="H5414"\w* reputation/\w Do|strong="H3068"\w* \w you|strong="H5414"\w* think \w that|strong="H3588"\w* \w I|strong="H3588"\w* want \w to|strong="H3068"\w* \w be|strong="H3068"\w* \w the|strong="H3605"\w* \w only|strong="H3588"\w* \w one|strong="H3605"\w* \w who|strong="H4310"\w* prophesies► [RHQ]? \w I|strong="H3588"\w* \w wish|strong="H4310"\w* \w that|strong="H3588"\w* \w all|strong="H3605"\w* \w Yahweh|strong="H3068"\w*’s \w people|strong="H5971"\w* \w could|strong="H4310"\w* ◄\w prophesy|strong="H5030"\w*/speak messages \w from|strong="H5921"\w* \w Yahweh|strong="H3068"\w*►. \w I|strong="H3588"\w* \w wish|strong="H4310"\w* \w that|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w would|strong="H4310"\w* \w give|strong="H5414"\w* \w the|strong="H3605"\w* power \w of|strong="H3068"\w* \w his|strong="H3605"\w* \w Spirit|strong="H7307"\w* \w to|strong="H3068"\w* \w all|strong="H3605"\w* \w of|strong="H3068"\w* \w them|strong="H5414"\w*!”
