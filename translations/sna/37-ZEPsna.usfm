\id ZEP - Biblica® Open Shona Contemporary Bible 2017 
\h Zefania 
\toc1 Zefania 
\toc2 Zefania 
\toc3 Zefa 
\mt1 ZEFANIA 
\c 1  
\p  
\v 1 Shoko raJehovha rakasvika kuna Zefania, mwanakomana waKushi, mwanakomana waGedharia, mwanakomana waAmaria, mwanakomana waHezekia, pamazuva okutonga kwaJosia mwanakomana waAmoni mambo weJudha richiti: 
\s1 Yambiro yokuuya kwoKuparadzwa 
\q1  
\v 2 “Ndichatsvaira zvose 
\q2 kubva pamusoro penyika,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 3 “Ndichatsvaira zvose vanhu nemhuka; 
\q2 ndichatsvaira shiri dzedenga nehove dzegungwa. 
\q1 Vakaipa vachasara nemirwi yamarara chete, 
\q2 kana ndabvisa munhu pamusoro penyika,” 
\q4 ndizvo zvinotaura Jehovha. 
\s1 Kurwiswa kweJudha 
\q1  
\v 4 Ndichatambanudza ruoko rwangu kuti ndirwise Judha 
\q2 uye ndicharwisa vose vanogara muJerusarema. 
\q1 Ndichaparadza kubva panzvimbo ino vose vakasara vaBhaari, 
\q2 mazita avaprista vechihedheni vanonamata zvifananidzo, 
\q1  
\v 5 vaya vanopfugama pamusoro pedzimba 
\q2 kuti vanamate nyeredzi dzedenga, 
\q1 vaya vanopfugama vachipika naJehovha 
\q2 uye vanopikawo naMoreki, 
\q1  
\v 6 vaya vanotsauka kubva pakutevera Jehovha 
\q2 uye vasingatsvaki Jehovha kana kubvunza kwaari. 
\q1  
\v 7 Nyararai pamberi paIshe Jehovha, 
\q2 nokuti zuva raJehovha rava pedyo. 
\q1 Jehovha agadzirira chibayiro; 
\q2 akavaita vatsvene, vaya vaakakoka. 
\q1  
\v 8 Pazuva rechibayiro chaJehovha, 
\q2 ndicharova machinda 
\q2 navanakomana vamambo, 
\q1 navaya vose vakapfeka 
\q2 nguo dzavatorwa. 
\q1  
\v 9 Pazuva iro ndicharanga 
\q2 vose vanonyenyeredza kuti vasatsika paburiro, 
\q1 vanozadza temberi yavamwari vavo 
\q2 nechisimba nounyengeri. 
\b  
\q1  
\v 10 “Pazuva iro,” ndizvo zvinotaura Jehovha, 
\q2 “kuchema kuchanzwikwa kubva kuSuo reHove, 
\q2 kuungudza kubva kuRutivi Rutsva rweguta, 
\q2 nokukoromoka kukuru kubva kuzvikomo. 
\q1  
\v 11 Ungudzai imi munogara munharaunda yomusika, 
\q2 vashambadzi venyu vose vachaparadzwa, 
\q2 vose vanotengesa nesirivha vachaparadzwa. 
\q1  
\v 12 Panguva iyoyo ndichanzvera Jerusarema nomwenje; 
\q2 uye ndicharanga vaya vagere zvavo, 
\q2 vakaita sewaini yakasiyiwa mumasese ayo, 
\q1 vanofunga kuti, ‘Jehovha hapana zvaangaita, 
\q2 zvakanaka kana zvakaipa.’ 
\q1  
\v 13 Upfumi hwavo huchapambwa, 
\q2 dzimba dzavo dzichaputswa, 
\q1 vachavaka dzimba, 
\q2 asi havangagari madziri; 
\q1 vachasima minda yemizambiringa, 
\q2 asi havanganwi waini yacho. 
\s1 Zuva Guru raJehovha 
\q1  
\v 14 “Zuva guru raJehovha rava pedyo, 
\q2 pedyo, uye riri kuuya nokukurumidza. 
\q1 Teererai! Kuchema pazuva raJehovha kucharwadza, 
\q2 kuchema kwemhere ipapo. 
\q1  
\v 15 Zuva iro richava rokutsamwa, 
\q2 zuva rokudzungaira nokumanikidzwa, 
\q1 zuva rokutambudzika nokuparadzwa, 
\q2 zuva rerima nokusuwa, zuva ramakore nezarima. 
\q1  
\v 16 Zuva rehwamanda nemhere yehondo yokurwisa maguta akakomberedzwa namasvingo, nokurwisa shongwe dzomumakona. 
\q1  
\v 17 Ndichauyisa kudzungaira pavanhu 
\q2 uye vachafamba samapofu, 
\q2 nokuti vakatadzira Jehovha. 
\q1 Ropa ravo richadururwa seguruva, 
\q2 uye nyama yavo sendove. 
\q1  
\v 18 Sirivha yavo kana goridhe ravo 
\q2 hazvingagoni kuvaponesa, 
\q2 pazuva rokutsamwa kwaJehovha. 
\q1 Mumoto wegodo rake 
\q2 nyika yose ichaparadzwa, 
\q1 nokuti achauyisa magumo pakarepo 
\q2 kuna vose vanogara panyika.” 
\c 2  
\q1  
\v 1 Unganai pamwe chete, unganai pamwe chete, 
\q2 imi rudzi runonyadzisa, 
\q1  
\v 2 nguva dzakatarwa dzisati dzasvika 
\q2 uye zuva iroro risati rapfuura sehundi, 
\q1 kutsamwa kukuru kwaJehovha kusati kwauya pamusoro penyu, 
\q2 zuva rehasha dzaJehovha risati rauya pamusoro penyu. 
\q1  
\v 3 Tsvakai Jehovha, imi mose vanyoro vapanyika, 
\q2 imi mose munoita zvaakarayira. 
\q1 Tsvakai kururama, tsvakai unyoro; 
\q2 zvimwe mungadzivirirwa 
\q2 pazuva rokutsamwa kwaJehovha. 
\s1 Kurwiswa kweFiristia 
\q1  
\v 4 Gaza richasiyiwa 
\q2 uye Ashikeroni richasiyiwa rava dongo. 
\q1 Pamasikati makuru Ashidhodhi richasiyiwa risisina chinhu 
\q2 uye Ekironi radzurwa. 
\q1  
\v 5 Mune nhamo imi munogara pedyo negungwa, 
\q2 imi vanhu veKereti; 
\q1 shoko raJehovha rinokurwisa, 
\q2 iwe Kenani nyika yavaFiristia. 
\q1 “Ndichakuparadza, 
\q2 uye hapana achasara.” 
\b  
\q1  
\v 6 Nyika iri pedyo negungwa, panogara vaKereti, 
\q2 ichava nzvimbo yavafudzi namatanga ehwai. 
\q1  
\v 7 Ichava yavakasara veimba yavaJudha; 
\q2 vachawana mafuro ikoko. 
\q1 Mumadekwana vachavata pasi 
\q2 mudzimba dzaAshikeroni. 
\q1 Jehovha Mwari wavo achavachengeta; 
\q2 Achavadzorera pfuma yavo. 
\s1 Kurwiswa kweMoabhu neAmoni 
\q1  
\v 8 “Ndakanzwa kutuka kwaMoabhu 
\q2 nokuzvidza kwavaAmoni, 
\q1 avo vakatuka vanhu vangu 
\q2 uye vakatyisidzira nyika yavo. 
\q1  
\v 9 Naizvozvo, zvirokwazvo noupenyu hwangu,” 
\q2 ndizvo zvinotaura Wamasimba Ose, Mwari waIsraeri, 
\q1 “zvirokwazvo Moabhu achaita seSodhomu, 
\q2 vaAmoni seGomora, 
\q1 nzvimbo yesora namakomba emunyu, 
\q2 matongo nokusingaperi. 
\q1 Vakasara vavanhu vangu vachavapamba; 
\q2 vachararama vorudzi rwangu vachagara nhaka yenyika yavo.” 
\b  
\q1  
\v 10 Izvi ndizvo zvavachawana nokuda kwokuzvikudza kwavo, 
\q2 nokuti vakatuka uye vakadadira vanhu vaJehovha Wamasimba Ose. 
\q1  
\v 11 Jehovha achava anotyisa kwavari 
\q2 paachaparadza vamwari vose venyika. 
\q1 Ndudzi pamahombekombe ose dzichamunamata, 
\q2 rudzi rumwe norumwe munyika yarwo. 
\s1 Kurwiswa kweEtiopia 
\q1  
\v 12 “Nemiwo, imi vaEtiopia, 
\q2 muchaparadzwa nomunondo wangu.” 
\s1 Kurwiswa kweAsiria 
\q1  
\v 13 Achatambanudza ruoko rwake kuti arwise nyika 
\q2 yokumusoro agoparadza Asiria, 
\q1 achasiya Ninevhe rava dongo zvachose 
\q2 uye raoma segwenga. 
\q1  
\v 14 Mapoka amakwai nemombe zvichavata pasi imomo, 
\q2 nezvipuka zvamarudzi ose. 
\q1 Zizi romurenje nezizi romurwizi 
\q2 zvichavata pamusoro pembiru dzavo. 
\q1 Kudana kwazvo kuchaungira nomumawindo, 
\q2 marara achava pamisuo yavo, 
\q2 mapango omusidhari achasiyiwa pachena. 
\q1  
\v 15 Iri ndiro guta risina hanya 
\q2 raigara vakachengetedzeka. 
\q1 Rakati mumwoyo maro, 
\q2 “Ndini, uye hakuna mumwe kunze kwangu.” 
\q1 Razova dongo rakadii, 
\q2 nzvimbo inovata mhuka dzesango! 
\q1 Vose vanopfuura napariri vanoseka 
\q2 Uye vanokunga zvibhakera zvavo. 
\c 3  
\s1 Ramangwana reJerusarema 
\q1  
\v 1 Rine nhamo guta ravamanikidzi, 
\q2 rakapanduka uye rikasvibiswa! 
\q1  
\v 2 Harina warinoteerera, 
\q2 harigamuchiri kudzorwa. 
\q1 Harivimbi naJehovha, 
\q2 hariswederi pedyo naMwari waro. 
\q1  
\v 3 Machinda aro ishumba dzinoomba, 
\q2 vatongi varo mapere amadekwana, 
\q2 vasingasiyi chinhu chamangwanani. 
\q1  
\v 4 Vaprofita vavo vanozvikudza; 
\q2 vanhu vanonyengera. 
\q1 Vaprista varo vanozvidza nzvimbo tsvene 
\q2 uye vanoputsa murayiro. 
\q1  
\v 5 Jehovha ari mariri mutsvene; 
\q2 haaiti zvakaipa. 
\q1 Mangwanani oga oga anotonga nokururamisira kwake, 
\q2 zuva rimwe nerimwe idzva anoriuyisa, 
\q2 asi vasakarurama havanyari. 
\q1  
\v 6 “Ndakaparadza ndudzi; 
\q2 shongwe dzavo dzakaparara. 
\q1 Ndakasiya nzira dzavo dzisisafambwi, 
\q2 hapasisina anopfuura nomo. 
\q1 Maguta avo akaparadzwa; 
\q2 hapana achasiyiwa, kana mumwe zvake. 
\q1  
\v 7 Ndakati kuguta, 
\q2 ‘Zvirokwazvo uchanditya 
\q2 ugogamuchira kudzorwa!’ 
\q1 Ipapo vagari varo havangaparadzwi, 
\q2 kana kuranga kwangu kwose hakungauyi pariri. 
\q1 Asi vakanga vachine shungu 
\q2 dzokuita uori pakuita kwavo kwose. 
\q1  
\v 8 Naizvozvo ndimirirei,” ndizvo zvinotaura Jehovha, 
\q2 “zuva randichasimuka kuti ndigopupura. 
\q1 Ndafunga kuunganidza ndudzi, 
\q2 kuunganidza ushe hwose 
\q1 uye nokudurura hasha dzangu pavari, 
\q2 kutsamwa kukuru kwangu kwose. 
\q1 Nyika yose ichaparadzwa 
\q2 nomoto wegodo rokutsamwa kwangu. 
\b  
\q1  
\v 9 “Ipapo ndichachenesa miromo yavanhu, 
\q2 kuti vose zvavo vadane kuzita raJehovha 
\q2 uye vamushumire nomwoyo mumwe. 
\q1  
\v 10 Kubva mhiri kwenzizi dzeEtiopia vanamati vangu, 
\q2 vanhu vangu vakapararira, 
\q2 vachandiunzira zvipiriso. 
\q1  
\v 11 Pazuva iro hamungaiswi pakunyadziswa 
\q2 nokuda kwezvakaipa zvamakandiitira, 
\q1 nokuti ndichabvisa kubva 
\q2 muguta rino vaya vanofara mukuzvikudza kwavo. 
\q1 Hamungazovizve namanyawi 
\q2 pagomo rangu dzvene. 
\q1  
\v 12 Asi ndichasiya pakati penyu 
\q2 vanyoro vanozvininipisa, 
\q2 vanovimba nezita raJehovha. 
\q1  
\v 13 Vakasara vaIsraeri havangaiti zvakaipa; 
\q2 havangarevi nhema, 
\q2 uye kunyengera hakuzowanikwi mumiromo yavo. 
\q1 Vachadya uye vagorara pasi, 
\q2 uye hapana angavatyisa.” 
\b  
\q1  
\v 14 Imba, iwe Mwanasikana weZioni, 
\q2 danidzira, iwe Israeri! 
\q1 Fara ugofarisisa nomwoyo wako wose, 
\q2 iwe Mwanasikana weJerusarema! 
\q1  
\v 15 Jehovha abvisa kurangwa kwako kwose, 
\q2 adzinga muvengi wako. Jehovha, 
\q1 Mambo waIsraeri, anewe; 
\q2 hauzotyizve kuti ungakuvadzwa nechinhu chipi zvacho. 
\q1  
\v 16 Pazuva iro vachati kuJerusarema, 
\q2 “Usatya, iwe Zioni; 
\q2 usarega maoko ako achishayiwa simba. 
\q1  
\v 17 Jehovha Mwari wako anewe, 
\q2 ndiye ane simba rokuponesa. 
\q1 Achafadzwa zvikuru newe, 
\q2 achakunyaradza norudo rwake, 
\q2 achafara nokuda kwako nokuimba.” 
\b  
\q1  
\v 18 “Matambudziko emitambo 
\q2 yakatarwa ndichaabvisa kwauri; 
\q2 iwo mutoro nokuzvidzwa kwauri. 
\q1  
\v 19 Panguva iyoyo ndichatonga 
\q2 vose vakakumanikidza; 
\q1 ndichanunura vakaremara 
\q2 uye ndichaunganidza vaya vakaparadzirwa. 
\q1 Ndichavapa rumbidzo norukudzo 
\q2 munyika dzose dzavakaiswa pakunyadziswa. 
\q1  
\v 20 Panguva iyoyo ndichakuunganidzai; 
\q2 panguva iyoyo ndichakuuyisai kumusha. 
\q1 Ndichakupai rukudzo nerumbidzo 
\q2 pakati pavanhu vose vapanyika, 
\q1 pandichadzora pfuma yenyu 
\q2 muchizviona nameso enyu,” 
\q4 ndizvo zvinotaura Jehovha.