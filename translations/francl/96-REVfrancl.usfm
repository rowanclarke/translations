\v 4 \w Puis|strong="G2532"\w* \w le|strong="G2532"\w* \w troisième|strong="G5154"\w* \w répandit|strong="G1632"\w* \w sa|strong="G2532"\w* \w coupe|strong="G5357"\w* \w dans|strong="G1519"\w* \w les|strong="G2532"\w* \w fleuves|strong="G4215"\w* \w et|strong="G2532"\w* \w les|strong="G2532"\w* \w sources|strong="G4077"\w* \w d|strong="G1519"\w*’\w eau|strong="G5204"\w* ; \w et|strong="G2532"\w* \w les|strong="G2532"\w* \w eaux|strong="G5204"\w* \w devinrent|strong="G1096"\w* \w du|strong="G2532"\w* \w sang|strong="G2532"\w*.\f + \fr 16:4 \ft 4. Comp. Exod. 7, 20 sv.\f*  
