\v 11 \w And|strong="G2532"\w* \w they|strong="G2532"\w* blasphemed \w the|strong="G2532"\w* \w God|strong="G2316"\w* \w of|strong="G1537"\w* \w heaven|strong="G3772"\w* \w because|strong="G1537"\w* \w of|strong="G1537"\w* \w their|strong="G2532"\w* \w pains|strong="G4192"\w*, \w and|strong="G2532"\w* \w because|strong="G1537"\w* \w of|strong="G1537"\w* \w their|strong="G2532"\w* ulcers; \w yet|strong="G2532"\w* \w they|strong="G2532"\w* \w did|strong="G2532"\w* \w not|strong="G3756"\w* \w repent|strong="G3340"\w* \w of|strong="G1537"\w* \w their|strong="G2532"\w* \w deeds|strong="G2041"\w*.   
