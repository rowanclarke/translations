\id 2CO - Yaouré NT [yre] -Côte d'Ivoire 1999 (web version -2013 bd)
\h 2 Korɛnti
\toc1 'Fluba "flizan nɛn Pɔl -a crɛn -tɛ Korɛnti 'nɔn lɛ
\toc2 2 Korɛnti
\toc3 2 Ko
\mt2 'Fluba "flizan nɛn Pɔl -a crɛn -tɛ
\mt1 Korɛnti
\mt2 'nɔn lɛ
\c 1
\p 
\v 1 'An 'bɔ Pɔl bɛ, Bali 'bɔ 'ci 'sɔ 'a nɛn an drɛ Zozi Crizi -le 'pasiazan -a. Mɛɛn 'fluba 'gʋɛ -a crɛn -tɛ 'kʋ 'vale -kaa "bʋɩ Zozizan Timote -a. Kʋa crɛn -tɛ Bali -le -leglizi nɛn Korɛnti fla bɛ -a -ji 'nɔn lɛ. Ɛn e ya "nyian Bali -le minnun pɛɛnɔn nɛn Akai 'lɛglɔn 'ji bɛ -wee vɛ -a.
\p 
\v 2 -Kaa "tɩ Bali 'lee Minsan Zozi Crizi 'o 'wee "yi 'lee 'wee -fʋdɩ -trɔɔ -nɔn 'cɛɛ.
\s1 Pɔl Bali muo "fɔ 'wɩ nɛn Bali -a drɛ Zozinɔn lɛ bɛ -a man
\p 
\v 3 -Kaa Bali 'tɔ bɔ! -Yɛɛ cɩ -kaa san Zozi Crizi "tɩ "a. Ɛn -yɛɛ cɩ "tɩ "nɛn min nyrinda -sɛan "da "bɛ -a. E ya Bali nɛn e -kaa "koe -tɔa -kaa da bɛ -a.
\v 4 Yra yɩdɩ pɛɛnɔn nɛn e bɔa -kaa man bɛ e -kaa "koe -tɔa -kaa da. Yaa dra zɩɛ 'nan -e -kaa 'bɔ "nyian, -kaa -kɔla "wʋ minnun nɛn yra yɩdɩ 'tɔ 'tʋdʋ pɛɛnɔn bɔa "o man bɛ, o "koe "tɔdɩ -a 'o da. Zɩ Bali 'bɔ -kaa "koe "tɔ -kaa da bɛ -a -tʋwli "nɛn "nyian -kaa dra -wee "lɛ.
\v 5 E ya 'wɩ 'kpa -a 'nan -kaa yra ye "kaga -kaa ya Crizi -le vɛ -a -le "wɛan. Ɛn e ya "nyian 'wɩ 'kpa -a, 'nan Crizi -kaa "koe -tɔa -kaa da 'kpa tɩglɩ.
\p 
\v 6 -Yee "wɛan -te kʋ ya 'kʋ yra yɩnan bɛ, e ya 'cee 'wɩ "yi "a. Kɔɔ kʋ yra ye 'nan -e 'ka "koe 'e 'kɔn 'ka da, -e 'ka 'si 'wɩ 'ji. Ɛn -te Crizi 'kʋ "koe -tɔa 'kʋ da bɛ, e ya 'cee 'wɩ "yi "a "nyian. Kɔɔ 'wɩ zɩɛ e 'ka "koe -tɔa 'ka da, ɛn e 'ka 'man -tɔa 'plɛblɛ yra yɩdɩ -tʋwli "nɛn e bɔa -kaa pɛɛnɔn man bɛ -a -ji.
\v 7 'Wɩ zɩɛ -yee "wɛan bɛ, nyɛn 'ka 'kʋ 'ji 'cee "wɛan dɩ. Kɔɔ kʋa -tɔa 'nan, -te ka ya 'ka yra yɩnan "le 'kʋe 'wɩ 'zʋ bɛ, Crizi -taa 'ka "koe "tɔlɛ 'ka da "le 'kʋe 'wɩ 'zʋ "nyian.
\p 
\v 8 'Kʋ "bʋɩ Zozinɔn, kʋ ya "vale 'ka -tɔ 'nan yra yɩdɩ -dan tʋ 'bɔ 'kʋ man Azi 'lɛglɔn 'ji. Yra yɩdɩ zɩɛ e 'nan 'kʋ da 'e 'ciɩla "da. 'Kʋ "koe 'si 'kʋ da "fo, ɛn 'kʋ 'ci nrɔn 'nan 'kʋ 'wulo 'ka 'bɔala "va "dɩ.
\v 9 'Wɩ 'kpa, -a -cin -tɔ 'kʋ 'ji 'nan minnun "ta 'kʋ -tɛɛman. Bali -si -nɔn 'nan 'wɩ zɩɛ 'e bɔ 'kʋ man -e 'kʋ vɩlɛ 'kʋ yi -tɛra 'kʋ 'bɔ 'fli da dɩ. 'Pian -e 'kʋ yi -tɛra Bali 'bɔ nɛn e minnun wuanla -kanɔn 'va bɛ -a da.
\v 10 Bali 'bɔ zɩɛ -yɛɛ 'kʋ 'sʋ -kadɩ nɛn e "ta paan bɔa 'kʋ man bɛ -yrɔ. Ɛn yaa dra tian cɛɛgʋ yi -a zɩ. Ɛn "nyian bɛ, 'kʋ 'bli a -yrɛ 'nan, yaa dra tian 'trilii.
\v 11 'Pian 'ka 'bɔ cɛɛ -tɔa 'kʋ 'wlu Bali trʋ 'badɩ -a 'kʋɛ. -Te min "kaga -a drɛ zɩɛ, -a -nan nɛn Bali -taa "yi "drɛlɛ 'kʋɛ, -e "yi "nɛn Bali -a drɛ 'kʋɛ zɩɛ -yee "wɛan bɛ, min "kaga 'o Bali muo "fɔ.
\s1 Pɔl -a 'vɩ 'nan 'e -ciala Korɛnti, 'pian ya'a "nyian -kʋlɛ dɩ. -Mɛ "le "wɛan?
\p 
\v 12 'Wɩ nɛn 'kʋ 'ci "nranman bɛ -nyrɛn 'nan, 'kʋ 'wulo -ji "nrɔndɩ 'ka tin tɛa 'kʋ da dɩ. Kɔɔ kʋ ta 'wʋ min -tʋdʋ pɛɛnɔn 'va 'kʋ 'ci 'fɩdaa 'a "le zɩ Bali -a dra bɛ -yee 'wɩ 'zʋ. Ɛn 'ka 'va nɛn kʋa drɛ "bʋʋ. 'Pian blamin -le 'wɩ 'tɔdɩ "cɛɛ -maan kʋ 'wɩ zɩɛ -a drɛ dɩ, Bali -le "yi "nɛn.
\v 13 Ɛn "nyian bɛ, kʋ 'ka "vale 'nan 'kʋ 'wɩ nɛn e "mlianla 'ka da bɛ 'kʋ crɛn -tɛa 'cɛɛ 'fluba 'ji dɩ. -Te kaa ta 'vɩ bɛ, 'wɩ nɛn kaa 'man bɛ, te -a 'bɔ nɛn, 'wɩ 'pee -cin 'ka 'kʋ 'ji -a -sru "dɩ. -A -cin a 'an 'ji 'nan, ka -taa 'wɩ 'gʋɛ -a -ci manlɛ 'kpa tɩglɩ.
\v 14 'Wɩ 'bɔ zɩɛ kaa -ci mandɩ 'sia 'sɛzɛnɔn 'va. -Nyrɛn 'nan yi nɛn Minsan Zozi -taa "man "bɛ, 'ka 'ci -taa "nranlɛ 'kʋe "wɛan ɛn 'kʋ 'ci -taa "nranlɛ 'cee "wɛan.
\p 
\v 15 'Wɩ zɩɛ an yi -tɛra "da 'kpa tɩglɩ, -a -nan nɛn maan 'pla 'nan 'an 'lʋ "flizan wo 'ka 'va, -e 'ka Bali -le "yi "yɩ "nyian.
\v 16 Maan 'pla 'nan 'an 'ciɩla 'ka 'va -e 'an 'kʋ Masedɔa 'lɛglɔn 'ji. "Bɛ -sru "mɛɛn vɩnan 'an "sia Masedɔa 'lɛglɔn 'ji bɛ, -e 'an 'ciɩla "nyian 'ka 'va. Maan dra zɩɛ 'nan "mɛɛn vɩnan 'an 'ko Zude 'lɛglɔn 'ji bɛ, -e 'kaan 'nɔn -si lɛ.
\v 17 'Wɩ zɩɛ -a -cin nɛn paan 'an 'ji 'nan 'an dra, 'pian ma'an drɛlɛ dɩ. Te 'ka 'ci "nrɔn 'nan 'an wei a "flivli "dɩ! Ɛn te 'ka 'ci "nrɔn 'nan an 'wɩ dra "le min -mienun -le 'wɩ 'zʋ dɩ! Kɔɔ waa ve 'wɩ man -inyan, te e ya -cɛjɛ -a.
\p 
\v 18 Bali a 'kʋe 'wɩ 'nan yɩzan -a. 'Wɩ nɛn 'kʋ 'ji bɛ, -a 'bɔ nɛn kʋa 'vɩ 'cɛɛ. 'Wɩ 'pee -cin 'ka 'kʋ 'ji -a -sru "dɩ.
\v 19 -A -cin 'e 'kɔn 'ka 'ji 'nan, Bali -pɩ Zozi Crizi wei 'ka "flivli "dɩ. 'Wɩ nɛn yaa 'vɩ bɛ yaa dra. 'An 'bɔ 'lee Sila 'lee Timote 'bɛ -yee 'wɩ 'vɩ 'cɛɛ.
\v 20 'Wɩ 'kpa, 'wɩ "yi pɛɛnɔn nɛn Bali "e 'nan 'e 'cɛn 'e dra minnun lɛ bɛ, Zozi Crizi 'bɛ drɛ -a 'lɛ sɔɔzan -a. -Yee "wɛan -kaa -ciala Zozi Crizi -va, -e -kaa vɩ 'nan 'e drɛ zɩ 'nan -e Bali 'tɔ 'e drɛ -dan.
\v 21 -A -cin 'e 'kɔn 'ka 'ji 'nan, Bali 'bɔ bɛ -kaa man -tɔa 'plɛblɛ Crizi -le 'wɩ 'ji. -Yɛɛ -kaa 'si "va 'yee 'nyranman 'panɔn 'a,
\v 22 ɛn e -kaa -kɔnnɛn 'pla 'yee vɛ -a. Yaa drɛ 'yee lei 'saun 'nɔndɩ -a -cɛɛ. -Yɛɛ cɩ "le "yi "nɛn e -taa -a -nɔnlɛ -cɛɛ bɛ -a va fɛ tɛdɛ -le 'wɩ 'zʋ.
\p 
\v 23 Bali 'bɛ cɩ 'mɛn 'wɩ 'nan yɩzan -a, -te an 'wlu 'sɛn bɛ, 'e 'wɩ "nɛn -kɔɔn 'mɛn. Fɛ -le "wɛan nɛn ma'an "nyian 'lʋlɛ 'ka 'va dɩɛ, -nyrɛn 'nan an 'ka "vale 'an 'wɩ "paala 'cɛɛ 'klagla -e 'ka 'ta 'e drɛ -trɔdrɔ dɩ.
\v 24 Ɛn kʋ 'ka -a -wɛɛnan 'nan, kʋʋ nɛn kʋ -kɔan "tin 'banɔn 'a 'cee yi -tɛradɩ Zozi da da dɩ. 'Pian kʋ ya -a -wɛɛnan 'nan 'kʋ "paa 'ka 'va -e ci "nrandɩ 'e 'kɔn 'ka 'lɔ. Kʋa -tɔa 'nan 'ka man a 'e 'tɔdɩ 'plɛblɛ 'cee yi -tɛradɩ Zozi da -ji.
\c 2
\p 
\v 1 An 'ka "vale 'ka 'ta 'e drɛ -trɔdrɔ dɩ. -Yee "wɛan maan 'yɩ "yi -e 'an vɩlɛ 'an 'lʋ 'pee wʋ 'ka 'va dɩ.
\v 2 Cɛɛ 'an 'ci "nranman paan, ɛn -te an 'ka 'ta drɛ 'trɔdrɔ bɛ, -tɩnun 'bɛ 'an 'ci "nranman "nyian? E 'ka "fo "dɩ.
\v 3 'Wɩ zɩɛ -yee "wɛan nɛn an 'fluba 'tʋ crɛn -tɛ 'cɛɛ. Maan drɛ zɩɛ 'nan -e "mɛɛn vɩnan 'an "lo "bɛ, te ka 'wɩ -mie paala "da. Kɔɔ an 'ka "vale 'nan 'ka 'bɔ nɛn ka ci "nrandɩ -nɔan 'mɛn bɛ 'kaan 'ta drɛ -trɔdrɔ dɩ. An yi -tɛra "da 'nan -te ci "nrandɩ a 'an 'lɔ bɛ, -a 'wɩ -taa "nyian "cee 'ci "nranlɛ.
\v 4 'Fluba zɩɛ, tʋ nɛn an ya -a crɛn -tɛnan 'cɛɛ bɛ, te 'cee 'wɩ 'an 'ta drɛ 'trɔdrɔ, ɛn te 'wɩ "naan 'an man. Maan crɛn -tɛ 'cɛɛ 'an yra le yiɛ 'yi 'a. Ma'an crɛn -tɛlɛ 'cɛɛ 'nan, -e 'ka 'ta 'e drɛ -trɔdrɔ dɩ. 'Pian maan crɛn -tɛ 'cɛɛ 'nan -e 'ka -tɔ 'nan an 'ka ye "yi 'kpa tɩglɩ.
\s1 Min 'wɩ 'wlidɩ "dra bɛ waa man wɩ "cɛa
\p 
\v 5 'Ka 'va min -tʋ -le 'wɩ 'wlidɩ "nɛn yaa drɛ 'mɛn bɛ, e min ta dra -trɔdrɔ. Maan ve 'cɛɛ 'nan 'an 'saza "cɛɛ 'yaan 'ta drɛ 'trɔdrɔ dɩ, e 'ka pɛɛnɔn 'ta drɛ 'trɔdrɔ. 'Pian e 'ka "le 'an -bloloo -sɛn "va "dɩ, e min "kaga 'ta drɛ 'trɔdrɔ 'ka yei.
\v 6 Min zɩɛ, 'wɩ nɛn 'ka 'va min "kaga 'ci drɛ 'tʋwli ɛn waa "nɛn kɔɔn -yrɛ "bɛ, e 'bɔ "yi.
\v 7 'Bɛ nɛn 'gʋɛ, 'ka man wɩ 'cɛ, -e 'ka "koe "tɔ 'e da. "Tɔgɔ -a -pɛ -sru 'e tɔa, -e -a "koe 'e 'si 'e da "fo.
\v 8 -Yee "wɛan an 'ka trʋ "baa, 'ka -kɔɔn -yrɛ 'nan kaa ye "yi.
\v 9 'Fluba nɛn maan crɛn -tɛ 'cɛɛ bɛ, kaa ta wɩ drɛ. An 'ka muo -fɔa. 'Ka 'nanjɛndɩ -le "wɛan nɛn maan drɛ zɩ ɛn kaan wei 'man "yi.
\v 10 Min nɛn kaa man wɩ 'cɛ bɛ, 'an 'bɔ "nyian "an man wɩ "cɛa. Ɛn -te e ya paan "mɛn 'saza 'a bɛ, maan man wɩ 'cɛ 'cee "wɛan, Crizi a 'mɛn 'wɩ 'nan yɩzan -a 'wɩ zɩɛ -a -ji.
\v 11 Maan drɛ zɩɛ 'nan -e Satan 'e vɩlɛ 'e -kaa man yɩ dɩ. Kɔɔ -kaa -tɔa 'nan 'wɩ zɩɛ Satan -a "vale 'e dra.
\s1 'Wɩ nɛn e drɛ Troas bɛ -nyrɛn 'gʋ
\p 
\v 12 An 'bɔla Troas fla, ɛn an Crizi -le 'wɩ 'nɔnnɔn 'vɩ min pɛɛnɔn lɛ. Minsan -a -si 'lɛ 'sʋ 'mɛn 'kpa tɩglɩ.
\v 13 'Pian te 'an 'ci 'kla "tra "dɩ, kɔɔ ma'an 'an "bʋɩ Zozizan Tit yɩlɛ dɩ. -Yee "wɛan nɛn an 'si 'nan nun, ɛn an Masedɔa 'lɛglɔn 'ji si 'sia.
\s1 Crizi fɛ pɛɛnɔn 'klɩ
\p 
\v 14 -Kaa Bali muo "fɔ! Kɔɔ yaa drɛ ɛn Crizi fɛ pɛɛnɔn 'klɩ. Ɛn e -kaa sɛn Crizi -le -guliga -va. Yaa drɛ zɩɛ 'nan -e -cee "wɛan min pɛɛnɔn 'o -kɔla Bali -tɔdɩ -a "le 'nan -laziglɔ nɛn -a -koei "a 'nɔnnɔn bɛ -yɛɛ cɩ fuilanan "man.
\v 15 'Wɩ 'kpa, -kaa Crizi -le 'wɩ 'nɔnnɔn ve minnun pɛɛnɔn lɛ. Bali "le 'va bɛ, -yɛɛ cɩ "le -laziglɔ nɛn -a -koei "a 'nɔnnɔn bɛ -yee 'wɩ 'zʋ. -Kaa Crizi -le 'wɩ 'nɔnnɔn ve minnun nɛn o ya -si nɛn e o "sia 'wɩ 'ji bɛ -a da bɛ -wlɛ. Ɛn -kaa ve minnun nɛn o ya -si nɛn e o "sia Bali man bɛ -a da bɛ -wlɛ.
\v 16 Minnun zɩɛ "o "kui maan "wlidɩ -e -kadɩ 'e drɛ -wee vɛ -a. 'Pian minnun nɛn "o "kui maan "yi "bɛ, 'belidɩ nɛn ya'a 'nyaan dɩɛ -yɛɛ dra -wee vɛ -a. Crizi -le 'wɩ 'nɔnnɔn zɩɛ, -tɩ -pɛ 'bɛ "sɔa -a vɩdɩ -a?
\p 
\v 17 'Kʋe vɛ bɛ, kʋ 'ka minnun nɛn o Bali wei baaman -e 'o fɛ -wɛɛ "a bɛ waa dɩ. 'Kʋ 'ci 'fɩdaa 'a nɛn kʋ Crizi -le 'wɩ ve minnun lɛ. Kʋ ya Crizi 'sunɔn 'a. Bali 'bɔ 'bɛ 'nyranman zɩɛ -a -pɛba 'wʋ 'kʋ 'lɔ, ɛn -a lɛ nɛn kʋa -sru "ve.
\c 3
\s1 -Tɩɛ -maan ɛn Zozi 'le 'pasiazan 'tɔ "yi bɔala?
\p 
\v 1 -Te kʋ ya 'wɩnun zɩɛ -a vɩnan bɛ, -a -ci nɛn 'nan kʋ ya 'kʋ 'fli 'tɔ "yi -wɛɛnan? -Te 'bɛ "cɛɛ dɩɛ, kʋ ya -a -wɛɛnan 'nan 'kʋ 'wɩ dra "le min -mienun -le 'wɩ 'zʋ? Kɔɔ 'nyranman nɛn waa "paa bɛ, waa 'fluba -kɔɔnman 'cɛɛ, ɛn 'nyranman nɛn waa 'pa 'ka 'va bɛ waa 'fluba 'nan laabo 'ka 'lɔ. -Cɛjɛ, 'kʋe vɛ 'ka zɩ dɩ.
\v 2 'Pian 'ka 'bɔ cɛɛ cɩ "le 'kʋe 'nyranman 'pa 'fluba 'le 'wɩ 'zʋ. Ɛn 'fluba zɩɛ -yɛɛ cɩ 'e 'crɛn -tɛdɩ 'kʋ souba ji. Min -tʋdʋ pɛɛnɔn 'a ye, ɛn o -kɔlaman -a ta vɩdɩ -a.
\v 3 -A -ci a 'wein 'nan ka ya 'fluba nɛn Crizi -a crɛn -tɛ bɛ -a. 'Nyranman nɛn kʋa 'pa bɛ -a va nɛn e ciɩla ɛn yaa crɛn -tɛ. Ya'a crɛn -tɛlɛ -gla 'yi 'a dɩ, ɛn ya'a crɛn -tɛlɛ -kɔlɛ 'fʋɩ da dɩ. 'Pian Bali nɛn -a yiɛ a "man "bɛ -a lei va nɛn e ciɩla ɛn yaa crɛn -tɛ. Yaa crɛn -tɛ 'ka souba ji, ɛn 'ka souba zɩɛ e ya nɛn -a.
\p 
\v 4 Fɛ -le "wɛan nɛn 'kʋ "koe "a 'kʋ da 'wɩ zɩɛ -a vɩnan bɛ, -yɛɛ cɩ 'nan Bali nɛn e ciɩla Crizi -va ɛn e 'kʋ 'pa 'sia bɛ, kʋ yi -tɛala "da.
\v 5 Kɔɔ -a -cin 'ka 'kʋ 'ji 'nan, 'kʋ 'pɛ "sɔa 'wɩ zɩɛ -a drɛdɩ -a 'kʋ 'bɔ 'a dɩ. 'Pian Bali 'plɛblɛ -nɔan 'kʋɛ, -a -nan nɛn kʋ -kɔlaman 'wɩ zɩɛ -a drɛdɩ -a.
\v 6 'Wɩ 'kpa, -yɛɛ -maan kʋ -kɔlaman Crizi -le 'wɩ 'nɔnnɔn vɩdɩ -a minnun lɛ. 'Wɩ 'nɔnnɔn zɩɛ -yɛɛ -kɔlaman min -plidɩ -a Bali man "nyian 'e 'pee. E 'ka "le -pei -tɔ wɩnun nɛn 'e 'crɛn -tɛdɩ -e min 'e 'ta wʋla "da "bɛ -yee 'wɩ 'zʋ dɩ. 'Pian Bali lei 'saun 'bɔ 'bɛ dra -e min 'e -pli Bali man. -Kaa -tɔa 'nan 'ta wʋladɩ -pei -tɔ wɩnun da min 'bɔ 'le 'plɛblɛ 'a bɛ e min -nɔan "ka lɛ, 'pian 'belidɩ nɛn ya'a 'nyaan dɩɛ Bali lei 'saun 'bɛ -nɔan "min lɛ.
\p 
\v 7 'Wɩ nɛn e drɛ Moizi tʋ va 'li bɛ, -kaa ci "nrɔn "da! -Pei -tɔ wɩnun 'bɔ a 'e 'crɛn -tɛdɩ -kɔlɛ 'fʋɩnun da, ɛn Moizi -ta 'e 'lɔ le -a Izraɛl 'nɔn 'va. Moizi yra "bia "bʋʋ -yee "wɛan Izraɛl 'nɔn 'ka -kɔlalɛ -a yra -nanjɛndɩ -a dɩ. 'Pian te 'bɛ 'ka 'mɔnlɛ dɩ. -Pei -tɔ wɩ nɛn 'bɛ min -nɔan "ka lɛ bɛ, -a 'sudɩ -maan nɛn Bali -le -dan Moizi yra bii "bʋʋ zɩɛ.
\v 8 -Yee "wɛan -kaa -tɔ 'nan, min nɛn e Bali lei 'saun "sua bɛ, e Bali -le -dan bɔala e -ciala "da.
\p 
\v 9 -Kaa 'yɩ 'nan min nɛn e -pei -tɔ wɩnun 'vɩ minnun lɛ bɛ, e Bali -le -dan kɔɔn, 'pian te -pei zɩɛ e min -nɔan "ka lɛ. -Yee "wɛan -kaa -tɔ 'nan min nɛn e 'wɩ 'nɔnnɔn ve minnun lɛ bɛ, e Bali -le -dan -kɔɔnman e -ciala "da. Kɔɔ minnun zɩɛ Bali o "siala min tɩglɩ 'a 'e 'lɛ.
\v 10 -Te waa "fli zɩɛ -a kɔɔn 'e cin man bɛ, Bali -le -dan tɛdɛ bɛ e 'ka fɛ -tʋ -a -yee -dan "flizan man dɩ.
\v 11 -Kaa 'yɩ 'nan -pei -tɔ wɩnun nɛn wa'a 'fʋlɛ -trilii dɩɛ, o Bali -le -dan kɔɔn min lɛ. -Yee "wɛan -kaa -tɔ 'nan 'wɩ 'nɔnnɔn nɛn e ya -nan 'li 'trilii bɛ, e Bali -le -dan -kɔɔnman e -ciala "da.
\p 
\v 12 'Wɩ zɩɛ -a lɛ nɛn 'kʋ 'bli cɩ, -yee "wɛan kʋ 'wɩ ve 'kʋ 'ta le 'kʋ "koe "a.
\v 13 'Kʋe vɛ bɛ, kʋ'a 'yra tɛa "le Moizi -le 'wɩ 'zʋ dɩ. Kɔɔ e sɔ 'pa 'e yra 'nan -e Izraɛl 'nɔn 'o vɩlɛ 'o -tɔ 'nan -a yra nɛn e "bia bɛ e dra tʋ "wɛnnɛn 'wlu dɩ.
\v 14 Ɛn Izraɛl 'nɔn 'bɔ 'o 'fli "trɔɛn drɛ "yuyu. -Yee "wɛan -e 'e bɔ cɛɛgʋ yi -a bɛ, -te o ya Bali -le -pei 'fluba ta vɩnan bɛ, e ya "le sɔ a tian 'e 'padɩ "da, ɛn wa'a 'ci maan dɩ. 'Pian min nɛn 'o 'vale Crizi -a o drɛ min -tʋwli "a bɛ, -a san lɛ nɛn sɔ zɩɛ e -kɔan 'e 'sidɩ "da.
\v 15 'Wɩ 'kpa, cɛɛgʋ yi -a tian bɛ, -te o ya Moizi -le 'fluba ta vɩnan bɛ, e ya "le sɔ a 'e 'padɩ -wee 'wɩ 'ci mandɩ da.
\v 16 'Pian -te Izraɛl 'nɔn 'bɔ 'si 'wɩ 'wlidɩ "drɛdɩ man, ɛn 'o 'fli -nɔn Minsan lɛ bɛ, sɔ zɩɛ e "sia -wee 'wɩ 'ci mandɩ da.
\v 17 Minsan nɛn maan 'vɩ 'nan 'o 'fli -nɔn -yrɛ 'gʋɛ, Bali lei nɛn maan ve. Kɔɔ min nɛn Bali lei 'saun -a "paala bɛ, -pei -le 'plɛblɛ 'ka "da "dɩ.
\v 18 -Kaa 'bɔ 'gʋɛ, sɔ 'ka "nyian 'e 'padɩ -kaa yra dɩ. -Yee "wɛan -kaa Minsan -le -dan ye tɩglɩ. -Te -kaa ya -yee -dan 'bɔ 'nanjɛnnan bɛ, e -ko -kaa liladɩ -a, te e -ko 'padɩ -a "da, -e -kaa drɛ "le -yee 'wɩ 'zʋ. Minsan 'bɛ 'wɩ zɩɛ -a dra 'yee lei 'saun 'a.
\c 4
\s1 Pɔl -le 'nyranman
\p 
\v 1 Bali 'kʋ nyrinda 'si, ɛn e 'yee 'wɩ 'nɔnnɔn vɩdɩ -pɛba 'wʋ 'kʋ 'lɔ. -Yee "wɛan 'kʋ "koe 'ka 'sia 'kʋ da 'nyranman zɩɛ -a 'panan dɩ.
\v 2 Ɛn 'wɩnun nɛn min -a dra 'e yɔɔdɩ te o min -tɛa 'yra -a bɛ, kʋ 'ka "vale 'kʋ dra dɩ. Ɛn kʋ'a minnun see "paaman 'kʋ wei -a 'nan -e 'o yi -tɛra Zozi da dɩ. Ɛn "nyian kʋ'a Bali wei baaman dɩ. 'Wɩ 'kpa, 'wɩ pɛɛnɔn zɩɛ kʋ'a dra dɩ. 'Pian 'kʋe vɛ bɛ, 'kʋ 'ci 'fɩdaa 'a nɛn kʋ Bali -le 'wɩ tɩglɩ ve minnun lɛ 'wein. 'Wɩ nɛn kʋa dra -e minnun pɛɛnɔn 'o -tɔ 'nan, 'nyranman 'gʋɛ -a 'pazan nɛn kʋa bɛ, -nyrɛn zɩɛ. Bali 'bɛ cɩ 'kʋe 'wɩ 'nan yɩzan -a.
\p 
\v 3 'Bɛ a zɩ, 'pian -te Zozi 'le 'wɩ 'nɔnnɔn nɛn kʋa ve minnun lɛ bɛ, -a -ci a tian 'e yɔɔdɩ min -mienun man bɛ, 'wɩ zɩɛ yaa -kɔɔnman 'nan, minnun zɩɛ o ya -si nɛn e o "sia Bali man -kɔɔbli bɛ -a da.
\v 4 Wa'a yi tɛala Zozi da dɩ, kɔɔ Satan nɛn e cɩ minnun zɩɛ -wee bali -a bɛ, e -wee 'wɩ 'ci mandɩ 'lɛ 'wʋ. Yaa drɛ zɩɛ 'nan -e 'o vɩlɛ 'o Zozi 'le 'wɩ 'nɔnnɔn 'ci man dɩ. -Yee "wɛan Zozi Crizi nɛn e Bali -kɔɔnman minnun lɛ bɛ wa'a -yee 'tɛ 'san ye dɩ.
\p 
\v 5 'Kʋ 'bɔ 'fli -le 'wɩ "cɛɛ kʋa ve minnun lɛ dɩ, 'pian Zozi Crizi -le 'wɩ 'nɔnnɔn nɛn kʋa ve minnun lɛ. Kʋa ve 'nan -yɛɛ cɩ Minsan -a, ɛn kʋ 'ka "sua 'wɩ zɩɛ -a Zozi 'bɔ 'le "wɛan.
\v 6 'Li bɛ, Bali -a 'vɩ 'nan:
\q1 «'Tɛ 'san 'e 'sɛn klun va!»
\m Ɛn 'bɛ nɛn 'gʋɛ Bali 'yee 'tɛ 'san zɩɛ -a -sɛn 'kʋ souba 'ji. Yaa drɛ zɩɛ -e minnun 'o -yee -dan ci yɩ. -Yee -dan zɩɛ -a 'bɔ nɛn Zozi Crizi -a -kɔɔnman minnun lɛ.
\p 
\v 7 'Pian Bali -le 'tɛ 'san nɛn e -sɛn 'kʋ souba 'ji zɩɛ, e ya 'e 'padɩ 'kʋ 'ji "le 'nan 'kʋ yɩfɛ -dan le 'wɩ 'zʋ. Bali -a 'pa 'kʋ 'bɔ nɛn kʋ cɩ -pɔ "tun "a 'gʋɛ 'kʋ 'ji. Yaa drɛ zɩɛ 'nan -e minnun 'o -tɔ 'nan -yee 'plɛblɛ nɛn -a -kɔɔn "manvɛ "ka "dɩɛ, -yɛɛ -maan 'kʋ -yee 'nyranman "paa, 'pian 'kʋ 'bɔ 'le 'plɛblɛ 'a "cɛɛ dɩ.
\v 8 'Kʋ yra ye minnun lɔ -pɛ pɛɛnɔn 'ji, 'pian kʋ'a 'klanman 'bɛ 'lɔ dɩ. Tʋ -mie bɔa "bɛ 'wɩ nɛn kɔ 'kʋ drɛ bɛ kʋ'a tɔa dɩ, 'pian 'kʋ 'pɛ -sru 'ka 'tɔaman dɩ.
\v 9 Ɛn tʋ -mie bɔa "bɛ minnun 'tɛ "paa 'kʋ da, 'pian Bali 'ka 'e yiɛ 'sia 'kʋ 'va dɩ. Ɛn tʋ -mie bɔa "bɛ, minnun 'kʋ -tiala "tra, 'pian 'kʋ 'wulo bɔala "va.
\p 
\v 10 Yi -tʋdʋ pɛɛnɔn man bɛ, 'kʋ 'ta a 'e "fluladɩ -ka lɛ "le zɩ e drɛ Zozi lɛ bɛ -yee 'wɩ 'zʋ. E dra zɩɛ 'nan -e minnun 'o ci yɩ 'nan Zozi 'le 'belidɩ nɛn 'kʋ 'lɔ.
\v 11 Fɛ nɛn maan ve zɩɛ -yɛɛ cɩ 'nan, tʋ nɛn kʋ ya tian 'trɛ da 'gʋɛ, Zozi 'le 'nyranman 'padɩ -le "wɛan nɛn 'kʋ 'ta a 'e "fluladɩ -ka lɛ. 'Pian e ya zɩɛ 'nan -e minnun 'o ci yɩ 'nan, 'kʋ 'bɔ nɛn -kadɩ a 'kʋe vɛ -a bɛ, Zozi 'le 'belidɩ nɛn 'kʋ 'lɔ.
\v 12 Zozi 'le 'nyranman nɛn kʋa "paa zɩɛ, e 'kʋ 'ta "flumlan -ka lɛ, 'pian e 'belidɩ nɛn ya'a 'nyaan dɩɛ -a -nɔan 'cɛɛ.
\p 
\v 13 E 'kʋ 'ta "flumlan -ka lɛ, 'pian te kʋa dra 'kʋe yi -tɛradɩ Bali da -le "wɛan. Kɔɔ e ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan:
\q1 «An yi -tɛala Bali da,
\q1 -yee "wɛan an -yee 'wɩ tin "baa.»
\m 'Wɩ 'tʋwli zɩɛ -nyrɛn 'kʋe vɛ -a. 'Kʋ 'bɔ "nyian "kʋ yi -tɛala Bali da, -yee "wɛan kʋ -yee 'wɩ 'nɔnnɔn tin "baa.
\v 14 Ɛn "nyian bɛ kʋa -tɔa 'nan, Bali nɛn e Minsan Zozi wluan -kanɔn 'va bɛ, e 'kʋ wuanla -kanɔn 'va "le zɩ yaa drɛ Zozi lɛ bɛ -yee 'wɩ 'zʋ. Yaa dra zɩɛ -e 'e 'kʋ -kaa pɛɛnɔn 'a 'e "srɔn.
\v 15 'Wɩ pɛɛnɔn zɩɛ 'cee "wɛan nɛn kʋa dra. Kʋa dra zɩɛ 'nan -e Bali -le "yi 'e fuila "man min "kaga 'va, -e 'o 'tɔ -dan nɔn Bali lɛ te waa muo -fɔa.
\p 
\v 16 'Wɩ zɩɛ -yee "wɛan nɛn 'kʋ "koe 'ka 'sia 'kʋ da dɩ. 'Wɩ 'kpa, 'kʋ 'kɔlɛ "koe "a -nyannan, te e -ko srɛdɩ -a 'sɛzɛnɔn. 'Pian 'belidɩ nɛn Bali -a -nɔn 'kʋɛ bɛ, Bali "koe -nɔan -yrɛ 'e -trɛ yi -tʋdʋ pɛɛnɔn man.
\v 17 Yra yɩdɩnun nɛn o bɔa 'kʋ man 'gʋɛ, o ya 'sɛzɛnɔn, ɛn o ya tʋ "wɛnnɛn 'wlu. 'Pian e ya 'kʋɛ 'wɩ "yi "a, kɔɔ o ya 'kʋ 'man wʋʋnan -e Bali 'e -kɔla 'tɔ -dan nɛn -a -kɔɔn "manvɛ "ka "dɩɛ -a -nɔndɩ -a 'kʋɛ 'li "fo "le vɛ -a.
\v 18 Fɛ nɛn maan ve zɩɛ -yɛɛ cɩ 'nan, fɛ nɛn min -a ye 'e yiɛ -a bɛ, -a lɛ "cɛɛ 'kʋ 'bli cɩ dɩ. 'Pian fɛ nɛn min 'ka -a ye 'e yiɛ -a dɩɛ, -a lɛ nɛn 'kʋ 'bli cɩ. Kɔɔ fɛ nɛn min -a ye 'e yiɛ -a bɛ, -yee 'mɔndɩ a tʋ "wɛnnɛn 'wlu. 'Pian fɛ nɛn min 'ka -a ye 'e yiɛ -a dɩɛ, e "mɔan 'li 'trilii.
\c 5
\s1 Fɛ nɛn Pɔl 'bli a -yrɛ "bɛ yaa 'vɩ
\p 
\v 1 Kʋa -tɔa 'nan 'kɔlɛ nɛn kʋ cɩ -ji 'trɛda 'gʋɛ, e ya "le segle pannɛn 'wlu nɛn kʋ cɩ 'tʋ "wɛnnɛn 'le vɛ -a. -Te e srɛ bɛ, 'kɔlɛ nɛn Bali -a drɛ 'e 'pɛ -a bɛ, e -taa -a -nɔnlɛ 'kʋɛ. -Yɛɛ -kɔan "le 'kʋe 'kɔn tɩglɩ 'le 'wɩ 'zʋ. Blamin "cɛɛ -tɔ 'e 'pɛ -a dɩ. E ya laji, ɛn ya'a 'srɛman 'li "fo "dɩ.
\v 2 'Wɩ 'kpa, 'bɛ nɛn kʋ ya tian 'trɛda 'gʋɛ, 'kʋ "koe "a -nyannan. Ɛn kʋ ya "vale 'nan 'kɔlɛ nɛn Bali -taa -a -nɔnlɛ 'kʋɛ bɛ 'e 'kɔn 'kʋ da 'va.
\v 3 Kɔɔ -te 'kɔlɛ zɩɛ -nyrɛn 'kʋ da ɛn kʋ -ka bɛ, kʋ'a 'kɔan 'kʋ plʋdɩ dɩ.
\v 4 Fɛ nɛn maan ve zɩɛ -yɛɛ cɩ 'nan, -te kʋ ya tian segle pannɛn 'gʋɛ -a 'wlu bɛ, 'kʋ "koe -nyaan ɛn kʋ -trunman. 'Pian e 'ka 'nan kʋ ya -kadɩ -wɛɛnan -e 'kʋ 'si segle pannɛn 'gʋɛ -a wlu dɩ. E 'ka zɩ dɩ, 'pian kʋ ya "vale 'kʋ 'kɔlɛ 'trɛ bɛ -nyrɛn 'e 'kɔn 'kʋ da, 'nan -e 'kʋ 'kɔlɛ nɛn -kadɩ a 'e pladɩ "man 'gʋɛ 'e lila 'kɔlɛ nɛn 'belidɩ a -yrɔ "bɛ -a.
\v 5 Ɛn Bali -kaa 'man wʋʋ 'wɩ zɩɛ -yee vɛ -a. Kɔɔ e 'yee lei 'saun 'nɔn -cɛɛ "yinun nɛn yaa 'pla -cɛɛ bɛ -a va fɛ tɛdɛ -a.
\p 
\v 6 -Yee "wɛan tʋ pɛɛnɔn man bɛ, 'kʋ "koe "a 'kʋ da. Kʋa -tɔa 'nan, -te 'kɔlɛ 'gʋɛ e ya tian 'kʋ da bɛ, te kʋ ya 'kʋ 'sidɩ Minsan man -kɔɔbli. 'Pian 'kʋ "koe 'ka 'e 'sidɩ 'kʋ da dɩ.
\v 7 Kʋ'a Minsan ye 'kʋ yiɛ -a dɩ, 'pian kʋ yi -tɛala "da ɛn kʋ ya -a -sru.
\v 8 'Kʋ "koe "a 'kʋ da tʋ pɛɛnɔn man. Ɛn kʋ ya "vale 'kʋ "sia 'kɔlɛ 'gʋɛ -a -sru -e 'kʋ 'kʋ Minsan "srɔn.
\v 9 'Wɩ nɛn e cɩ 'kʋ man 'wɩ -dan a bɛ, -nyrɛn 'nan 'kʋ 'sɔ Minsan lɛ. -Te kʋ ya tian 'kɔlɛ nɛn 'kʋ da 'gʋɛ -a -ji oo, 'kʋ 'sɔ -yrɛ. Ɛn -te kʋ 'si 'kɔlɛ 'bɔ -sru oo, 'kʋ 'sɔ -yrɛ.
\v 10 Kɔɔ yi -tʋ bɔa "bɛ, -kaa tʋdʋ pɛɛnɔn bɔala 'ji Crizi cɛin -da. Yi zɩɛ -a da nɛn 'nyranman nɛn min -tʋ -a 'pa bɛ, yaa -sru "ve. Tʋ nɛn e ya 'trɛda 'gʋɛ, -te 'wɩ "yi "nɛn yaa drɛ bɛ, yaa man -kopa ye, ɛn -te 'wɩ 'wlidɩ "nɛn yaa drɛ bɛ, yaa man -kopa ye.
\s1 Crizi -kaa yei "sɛn 'e cin va -kaa 'vale Bali -a
\p 
\v 11 Minsan -taa 'kʋe 'wɩ tin 'balɛ. 'Wɩ zɩɛ -yɛɛ "klan "paa 'kʋ 'ji. -Yee "wɛan nɛn kʋa -wɛɛman 'nan, 'wɩ nɛn kʋa ve minnun lɛ bɛ 'o man "yi -e 'o -sɔɔnla Zozi -sru. Bali a -tɔa 'nan 'wɩ zɩɛ -yɛɛ cɩ 'kʋ man, ɛn -a -cin a 'an 'ji "le 'nan 'wɩ zɩɛ kaa -tɔa 'nan -yɛɛ cɩ 'kʋ man.
\v 12 Kʋ 'ka 'kʋ 'fli 'tɔ -wɛɛnan 'wɩnun zɩɛ -a vɩdɩ -a dɩ. 'Pian 'wɩnun zɩɛ kʋa 'vɩ 'cɛɛ 'nan -e 'ka -kɔla 'kʋ 'sɩ -fɔdɩ -a. -E 'ka -kɔla 'wɩ 'ci vɩdɩ -a min -mienun lɛ. Kɔɔ minnun zɩɛ 'o 'fli -kɔɔnman fɛnun nɛn min -a ye 'e yiɛ 'a bɛ -a, 'pian 'wɩ nɛn o ji bɛ, e 'ka 'wɩ "yi "a dɩ.
\v 13 -Te kaa ye 'nan, kʋ 'wɩ dra "le minnun nɛn 'o 'wulo 'ka o da dɩɛ, -wee 'wɩ 'zʋ bɛ, Bali 'tɔ nɛn kʋa -wɛɛman 'nan 'e drɛ -dan. Ɛn -te kaa ye 'nan, kʋ 'wɩ dra "le minnun nɛn 'o 'wulo a o da bɛ, -wee 'wɩ 'zʋ bɛ, 'cee "wɛan nɛn kʋa dra.
\p 
\v 14 'Wɩ pɛɛnɔn nɛn kʋa dra bɛ, Crizi -le 'kʋ yɩdɩ "yi "le "wɛan nɛn kʋa dra. Kʋa -tɔa 'nan -yɛɛ min pɛɛnɔn 'lɛji -ka 'wʋ. E ya "mɛn "le 'nan min pɛɛnɔn 'bɛ kaa.
\v 15 E min pɛɛnɔn 'lɛji -ka 'wʋ 'nan -e minnun nɛn o yiɛ cɩ "man "bɛ, 'o vɩlɛ 'o 'kɔn 'trɛda 'o 'bɔ 'fli -ji dɩ. 'Pian -e 'o 'kɔn 'trɛda Crizi nɛn e min pɛɛnɔn 'lɛji -ka 'wʋ, ɛn Bali -a wluan -kanɔn 'va bɛ -yee vɛ -a.
\p 
\v 16 -Yee "wɛan 'bɛ nɛn 'gʋɛ, -ka'a "nyian min -nanjɛan 'e 'kɔlɛ man -e -kaa -yee 'wɩ vɩ dɩ. -Te 'wɩ zɩɛ -a 'bɔ -kaa drɛ Crizi lɛ 'e tɛdɛ oo, 'bɛ nɛn 'gʋɛ, -ka'a "nyian Crizi tɔa -pɛ zɩɛ 'bɛ 'ji dɩ.
\v 17 Fɛ nɛn maan ve zɩɛ -yɛɛ cɩ 'nan, -te min drɛ Crizi -le vɛ -a bɛ, e ya "le Bali a drɛ min -trɛ -a. Min nɛn e cɩ -a 'e tɛdɛ bɛ, 'bɛ yi -ka. 'Bɛ nɛn 'gʋɛ -yee 'wɩ pɛɛnɔn drɛ 'e -trɛ.
\v 18 Ɛn 'wɩ zɩɛ -a drɛdɩ bɛ, e "sia Bali va. E ciɩla Crizi -va, ɛn e -kaa yei "sɛn 'e cin va -kaa 'vale 'e 'bɔ 'a. Bali 'bɔ 'bɛ -a 'nyranman -pɛba 'wʋ 'kʋ 'lɔ 'nan 'kʋ 'wɩ zɩɛ -a vɩ minnun lɛ.
\v 19 'Wɩ 'kpa, Bali ciɩla Crizi -va, ɛn e minnun pɛɛnɔn yei "sɛn 'e cin va 'o 'vale 'e 'bɔ 'a. 'Wɩ 'wlidɩ "nɛn blamin -a drɛ 'e 'cɛn bɛ, ya'a 'palɛ 'bɛ man dɩ, ɛn e 'wɩ zɩɛ -a drɛ. E 'kʋ 'pa 'sia 'nan 'kʋ -nan 'sinan 'pa minnun lɛ.
\p 
\v 20 -Yee "wɛan kʋ drɛ Crizi -le 'pasianɔn 'a. 'Kʋ 'va nɛn Bali -ciala -e 'e 'wɩ 'pla minnun lɛ. 'Wɩ nɛn kʋa ve bɛ, -nyrɛn 'nan: «'Ka yra 'si! 'Ka 'wɩ "man -e 'ka yei 'e 'sɛn 'e cin va 'ka 'vale Bali -a.»
\v 21 Crizi 'ka 'wɩ 'wlidɩ "tʋwli "drɛlɛ dɩ, 'pian Bali -cee 'wɩ 'wlidɩ "nɛn "wɩ 'bɔ "man. Yaa drɛ zɩɛ 'nan -e -kaa drɛ min tɩglɩ 'a 'e lɛ, 'wɩ nɛn e 'bɔ Crizi man zɩɛ -yee "wɛan.
\c 6
\s1 Pɔl minnun trʋ "baa 'nan 'o 'wɩ Bali -le "yi "man
\p 
\v 1 'Kʋ pɛɛnɔn nɛn kʋ 'nyranman 'bɔ zɩɛ -a "paa bɛ, kʋ 'ka trʋ "baa 'nan Bali -le "yi "nɛn yaa drɛ 'cɛɛ bɛ, te 'ka 'tʋɩ -e -a "nɛn 'e 'fʋ 'e "tun "dɩ!
\v 2 Kɔɔ Bali -a 'vɩ 'nan:
\q1 «Tʋ "yi "man "bɛ,
\q1 an -taa 'wɩlɛ 'ka man.
\q1 Ɛn yi nɛn
\q1 an minnun "sia 'wɩ 'ji bɛ,
\q1 an "paa 'ka 'va.»
\p Kʋa ve 'cɛɛ 'nan, tʋ "yi "nɛn Bali -a 'vɩ bɛ -yɛɛ 'bɔ 'gʋ. Ɛn yi nɛn Bali -a 'vɩ 'nan e minnun "sia 'wɩ 'ji bɛ, -yɛɛ 'bɔ 'gʋ.
\p 
\v 3 Kʋ 'ka "vale 'nan minnun 'o 'wɩ 'wlidɩ 'kʋe 'nyranman man dɩ. -Yee "wɛan kʋa -wɛɛman 'nan, te 'kʋe 'wɩ drɛdɩ 'e 'nan min -tʋ man dɩ.
\v 4 'Pian 'kʋe 'wɩ pɛɛnɔn drɛdɩ -ji bɛ, 'kʋ 'fli -kɔɔnman 'nan kʋ ya Bali -le 'nyranman 'panɔn 'kpa -a. -Te 'kʋ yra 'yɩ minnun lɔ, ɛn o 'wɩ 'bɔ 'kʋ man, ɛn o 'tɛ 'pa 'kʋ da bɛ, kʋa kɔɔn 'kʋ -pɔan 'sɔdɩ -a 'nan kʋ ya Bali -le 'nyranman 'panɔn 'kpa -a.
\v 5 'Wɩ 'kpa, minnun 'kʋ 'sɔn, ɛn o 'kʋ 'fɔ -pʋ 'kuin. Ɛn o minnun wluan 'kʋ man. 'Pian 'wɩ pɛɛnɔn zɩɛ -a -ji bɛ, 'kʋ -pɔan 'sɔ. Ɛn "nyian bɛ, kʋ 'nyranman "paa 'e -ciala 'kʋ da. Kʋ yi "sɔan, ɛn kʋ fɛ "sɔan 'nyranman 'padɩ -le "wɛan.
\v 6 'Kʋe 'ta wʋ -pɛ a 'saun, ɛn kʋ Bali -le 'wɩ -tɔa. Kʋ man -sɛanla minnun va, ɛn 'kʋ ci "yi "taan -wlɛ. Bali lei 'saun "yi drɛ 'kʋɛ, ɛn kʋ min -tʋdʋ pɛɛnɔn ye "yi 'kʋ 'ci 'fɩdaa 'a. 'Wɩ pɛɛnɔn zɩɛ -a -ji bɛ, kʋa kɔɔn 'nan kʋ ya Bali -le 'nyranman 'panɔn 'kpa -a.
\v 7 Ɛn "nyian bɛ, kʋ Bali -le 'wɩ tɩglɩ 'vɩ minnun lɛ, ɛn Bali ciɩla 'kʋ va e 'yee 'plɛblɛ ci kɔɔn minnun lɛ. 'Wɩ tɩglɩ nɛn kʋa dra, -yɛɛ cɩ 'kʋe 'kuli 'tan vɛ -a, ɛn -yɛɛ 'wɩ "sia 'kʋ man.
\v 8 Minnun 'tɔ -dan -nɔan 'kʋɛ bee, ɛn o 'kʋ "srɔnman bee, ɛn o "we 'kʋ man -wlidɩ "bee, ɛn o 'kʋe 'wɩ "yi "ve bee, 'pian te 'wɩ tɩglɩ nɛn kʋa dra. Ɛn "nyian bɛ, o 'kʋ 'sia 'wlunɔn 'a, 'pian te 'wɩ tɩglɩ nɛn kʋa ve.
\v 9 Ɛn o 'kʋ 'sia minnun nɛn wa'a o tɔa dɩɛ waa, 'pian minnun 'kʋ -tɔa. Ɛn kʋ ya "le minnun nɛn o "ta -kaaman bɛ -wee 'wɩ 'zʋ, 'pian te 'kʋ yiɛ a "man. Ɛn minnun 'wɩ "nɛn kɔɔn 'kʋɛ, 'pian kʋ'a 'kalɛ -a 'wɩ 'ji dɩ.
\v 10 Minnun 'kʋ 'ta drɛ 'trɔdrɔ, 'pian te 'kʋ 'ci "nranman. Ɛn kʋ ya 'yalɛ -tɛnɔn 'a, 'pian te kʋ minnun "kaga dra fɛnɔn 'a Bali 'lɛ. Ɛn fɛ -tʋ 'ka 'kʋ 'lɔ dɩ, 'pian Bali "le 'va bɛ te fɛ pɛɛnɔn a 'kʋ 'lɔ.
\p 
\v 11 Korɛnti 'nɔn, kʋ 'wɩ "kaga tin 'ba 'cɛɛ 'wein. 'Wɩ pɛɛnɔn nɛn 'kʋ 'ji bɛ, kʋa 'vɩ 'cɛɛ.
\v 12 'Ka 'nan wɩ a 'kʋ man 'kpa, 'pian 'kʋ 'nan wɩ 'ka 'ka man dɩ.
\v 13 E ya "le 'an 'wɩ 'pla 'cɛɛ "le 'an 'pɔn -ji nɛnnun -le 'wɩ 'zʋ. Zɩ 'ka 'nan wɩ cɩ 'kʋ man bɛ, -a -tʋwli "nɛn "nyian 'ka -kɔɔn 'kʋɛ 'nan 'kʋ 'nan wɩ a 'ka man.
\s1 Bali -tʋwli "lɛ nɛn 'ka 'fli 'nɔn!
\p 
\v 14 Minnun nɛn wa'a yi tɛala Zozi da dɩɛ, te 'ka 'fɔ o -sru "dɩ! -A -cin 'e 'tɔ 'ka 'ji 'nan, 'wɩ tɩglɩ 'lee 'wɩ 'wlidɩ 'ka 'kɔlaman -e 'o 'tɛ 'e cin da dɩ. Ɛn "nyian bɛ, 'tɛ 'san 'lee klun 'ka 'kɔlaman -e 'o 'kɔn fɛ -tʋwli "nan dɩ.
\v 15 Ɛn "nyian bɛ, Crizi 'lee Satan yei 'ka 'a ble dɩ. Ɛn "nyian bɛ, min nɛn e yi -tɛala Crizi da 'lee min nɛn ya'a yi tɛala Crizi "da "dɩɛ, -wee ci "nrɔndɩ 'ka 'tʋwli "dɩ.
\v 16 Ɛn "nyian bɛ, Bali -pan 'kɔn bɛ, -yʋ -pan 'kɔn "cɛɛ dɩ. -A -cin 'e 'kɔn 'ka 'ji 'nan -kaa ya Bali nɛn -a yiɛ cɩ "man "bɛ -yee 'kɔn 'a. 'Wɩ zɩɛ Bali -a 'vɩ 'e 'cɛn. Kɔɔ e ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan:
\q1 «An -nyɛanla o va.
\q1 An -kɔan -wee Bali -a,
\q1 ɛn o -kɔan 'mɛn minnun -a.»
\m 
\v 17 -Yee "wɛan nɛn Minsan -a 'vɩ 'nan:
\q1 «'Ka 'si minnun yei,
\q1 'ka 'cɛn o man!
\q1 Fɛ nɛn e 'ka "tri -tɔa Bali 'lɛ bɛ,
\q1 'ka -wɛɛ 'nan 'ka "sia -a drɛdɩ man!
\q1 -Te ka 'wɩ zɩɛ -a drɛ bɛ,
\q1 an 'ka "kuan 'an 'pɛ "fli "a.
\q1 
\v 18 An -kɔan 'ka "tɩ "a.
\q1 Ɛn ka -kɔan 'an 'pɩnun 'lee 'an 'lunun -a.
\q1 'An 'bɔ 'plɛblɛ pɛɛnɔn 'san Bali,
\q1 mɛɛn 'wɩ zɩɛ -a 'vɩ.»
\c 7
\p 
\v 1 'An beenun, 'wɩnun zɩɛ Bali -tɔ "da 'nan 'e dra -cɛɛ, -yee "wɛan e ya "le -kaa 'fli drɛ 'saun Bali 'lɛ 'sidɩ -a 'wɩ 'wlidɩnun nɛn o -kaa "tri -tɔa Bali 'lɛ bɛ -a drɛdɩ man! -Kaa 'wɩ zɩɛ -a drɛ -e -kaa drɛ Bali -le vɛ -a "fo, ɛn -kaa drɛ "klandɩ -a Bali lɔ!
\s1 Pɔl Korɛnti 'nɔn trʋ 'ba 'nan 'e 'nan wɩ 'e 'kɔn o man
\p 
\v 2 'Kʋ 'nan wɩ 'e 'kɔn 'ka man. Kʋ'a 'wɩ drɛlɛ -wlidɩ 'ka 'va min -tʋ lɛ dɩ. Ɛn kʋ'a drɛlɛ -e 'ka 'va min -tʋ 'e 'si -si tɩglɩ da dɩ. Ɛn kʋ'a 'ka 'va min -tʋ ta -blɩlɛ dɩ.
\v 3 'Wɩ "cɛɛ maan -tɔa 'ka man 'wɩ zɩɛ -a vɩdɩ -a dɩ. Maan 'vɩ 'cɛɛ 'va 'nan 'ka 'nan wɩ a 'kʋ man 'kpa tɩglɩ. -Te e ya 'belidɩ -a oo, 'ka 'nan wɩ a 'kʋ man. Ɛn -te e ya -kadɩ -a oo, 'ka 'nan wɩ a 'kʋ man.
\v 4 An -kɔlaman 'wɩ tin 'badɩ -a 'cɛɛ 'an 'ta le 'an "koe "a. Ɛn an -kɔlaman 'ka 'sɩ -fɔdɩ -a. Yra yɩdɩ pɛɛnɔn nɛn e bɔa 'kʋ man bɛ, ya'a 'an "koe 'sia 'an da dɩ, 'pian 'an 'ci "nranman 'e -ciala "da.
\s1 Korɛnti 'nɔn 'ta wɩ mandɩ ci "nran -nɔn Pɔl lɛ
\p 
\v 5 Zɩ kʋ 'bɔla Masedɔa 'lɛglɔn 'ji bɛ, 'kʋ 'ci 'ka 'kɔnlɛa "tra "dɩ. 'Wɩ a 'kʋ man -pɛ pɛɛnɔn da. Minnun a 'tɛ 'panan 'kʋ da -pɛ -tʋ -a. Ɛn "nyian bɛ, 'kʋ 'ci a 'e 'tɔdɩ lou.
\v 6 'Pian Bali nɛn e minnun nɛn o -pɛ -fɔnan "ka "dɩɛ, e o ci -taa "tra "bɛ, e 'kʋ "koe "tɔ 'kʋ da Tit -le -tadɩ -a.
\v 7 E 'ka 'nan Tit -le -tadɩ 'saza 'bɛ 'kʋ "koe "tɔ 'kʋ da dɩ. 'Pian 'wɩ nɛn kaa 'bɔ "koe "tɔ -a 'e da bɛ, -yɛɛ 'kʋ "koe "tɔ 'kʋ da. Yaa 'sinan 'pa 'kʋɛ 'nan, 'an dra 'ka -tɛa 'kpa tɩglɩ. Ɛn 'wɩ nɛn e drɛ bɛ e 'ka ta drɛ 'trɔdrɔ. Ɛn "nyian 'nan, ka ya 'ka 'tɔdɩ 'an -sru 'plɛblɛ. 'Wɩ zɩɛ -yee "wɛan bɛ, 'bɛ nɛn 'gʋɛ 'an 'ci "nranman 'e -ciala "da.
\p 
\v 8 'Fluba nɛn maan crɛn -tɛ 'cɛɛ bɛ, maan -tɔa 'nan e 'wɩ 'nan 'ka man. 'Pian -a 'wɩ 'ka 'nanlɛ 'an man "fo "dɩ. E ya "le 'an vɩ 'cɛɛ 'nan, zɩ maan 'man 'nan 'fluba zɩɛ e 'ka ta drɛ 'trɔdrɔ 'e 'ciɩla "da "bɛ, 'wɩ 'nan 'an man.
\v 9 'Pian 'bɛ nɛn 'gʋɛ 'an 'ci "nranman. 'An 'ci 'ka "nranman 'nan an 'ka 'ta drɛ -trɔdrɔ dɩ. 'Pian 'an 'ci "nranman 'nan 'ka 'ta nɛn e drɛ 'trɔdrɔ bɛ yaa drɛ ɛn 'ka 'si 'wɩ 'wlidɩ "drɛdɩ man. 'Wɩ 'kpa, 'ka 'ta nɛn e drɛ 'trɔdrɔ zɩɛ -yɛɛ 'sɔ Bali lɛ. -Yee "wɛan nɛn 'fluba 'bɔ nɛn kʋa crɛn -tɛ zɩɛ ya'a 'wɩ drɛlɛ -wlidɩ 'ka 'va min -tʋ lɛ dɩ.
\v 10 Fɛ nɛn maan ve zɩɛ, -yɛɛ cɩ 'nan -te min ta drɛ 'trɔdrɔ 'wɩ 'wlidɩ "tʋ -le "wɛan ɛn e 'si -a drɛdɩ man bɛ, -yɛɛ 'sɔ Bali lɛ. 'Wɩ nɛn min zɩɛ yaa drɛ bɛ, -a 'wɩ 'ka -taa 'nanlɛ "man "dɩ, kɔɔ Bali -a "sia 'wɩ 'ji. 'Pian -te min ta drɛ 'trɔdrɔ 'wɩ 'wlidɩ "tʋ -le "wɛan ɛn ya'a 'silɛ -a drɛdɩ man dɩɛ, -a 'le 'srannan "nɛn -kadɩ -a.
\p 
\v 11 'Wɩ 'kpa, 'ka 'ta nɛn e drɛ 'trɔdrɔ zɩɛ, -yɛɛ 'sɔ Bali lɛ. Kɔɔ 'wɩ nɛn e drɛ 'ka 'va nun bɛ, kaa 'sia 'wɩ 'a, ɛn kaa man toba -fɔ 'mɛn. 'An yɩdɩ dra 'ka -tɛa, ɛn 'ka 'man a 'e 'tɔdɩ 'plɛblɛ Bali -le 'wɩ 'ji. 'Wɩ nɛn min zɩɛ yaa drɛ bɛ, e 'nan 'ka man, ɛn e 'ka 'tɛ "klan -a. -Yee "wɛan ka 'wɩ "nɛn kɔɔn -yrɛ. 'Wɩ 'bɔ zɩɛ -a drɛdɩ -a bɛ, kaa -ci kɔɔn 'nan ka 'ka -a -sru "dɩ.
\p 
\v 12 'Fluba 'bɔ nɛn maan crɛn -tɛ 'cɛɛ zɩɛ, ma'an crɛn -tɛlɛ min nɛn e 'wɩ 'wlidɩ drɛ bɛ -yee "wɛan dɩ. Ɛn "nyian bɛ, ma'an crɛn -tɛlɛ min nɛn e 'wɩ 'wlidɩ 'bɔ drɛ -yrɛ "bɛ -yee "wɛan dɩ. 'Pian maan crɛn -tɛ 'cɛɛ 'nan -e 'ka -kɔla -a -kɔɔndɩ -a 'nan Bali 'lɛ bɛ, ka ya 'kʋ -sru "fo.
\v 13 'Wɩ zɩɛ kaa drɛ. -Yɛɛ -maan 'kʋ "koe "tɔ 'kʋ da.
\p -A da "cɛɛ e -fʋ 'saza dɩ. 'Pian zɩ kʋ Tit 'yɩ bɛ, 'kʋ 'ci "nran 'e 'ciɩla "da. Kɔɔ 'wɩ nɛn kaa "koe "tɔ -a 'e da bɛ, e ci "nrandɩ -nɔn -yrɛ.
\v 14 'Wɩ 'kpa, Tit 'bɔ yiɛ man bɛ, an 'ka 'sɩ -fɔ, ɛn ka'an 'tɛlɛ 'yra -a dɩ. 'Ka 'tɔ "yi "nɛn kʋa 'vɩ bɛ, e drɛla "da, "le zɩ 'wɩ pɛɛnɔn nɛn kʋa 'vɩ 'cɛɛ bɛ e ya tʋ pɛɛnɔn man 'wɩ tɩglɩ 'a bɛ -yee 'wɩ 'zʋ.
\v 15 Tit -le 'ka yɩdɩ "yi "bɛ 'e 'ciɩla "da "mɛn. Kɔɔ zɩ e 'lʋ 'ka 'va bɛ, yaa 'yɩ 'nan 'ka 'man a 'e wʋʋdɩ -e 'ka 'ta wʋla 'kʋ wei da. Ɛn yaa 'yɩ "nyian 'nan 'ka yiɛ 'nan 'e man ɛn cee 'kun 'ka 'pɛ "fli "a.
\v 16 Kaa -ci kɔɔn 'nan, an -kɔlaman 'an yi -tɛala 'ka da 'wɩ pɛɛnɔn 'ji. 'Wɩ zɩɛ yaan 'ci nran 'kpa.
\c 8
\s1 'Yalɛ -tɛnɔn nɛn Zeruzalɛm -leglizi -ji bɛ Zozinɔn "yi drɛ -wlɛ
\p 
\v 1 'Kʋ "bʋɩ Zozinɔn, 'wɩ nɛn Bali -le "yi -a drɛ -leglizinun nɛn Masedɔa 'lɛglɔn 'ji bɛ -a -jinɔn lɛ bɛ, e ya "le 'kʋ 'sinan 'pa 'cɛɛ.
\v 2 Yra yɩdɩ "kaga 'bɔ o man -wee yi -tɛradɩ Bali da -nanjɛn vɛ -a. Ɛn 'yalɛ o -tɛ 'e 'ciɩla "da. 'Pian ci "nrandɩ -dan a -wlɔ, ɛn o "lala -nɔn "kaga Zozinɔn 'le vɛ -a.
\v 3 'Wɩ 'kpa, maan ve o man 'nan, zɩ e cɩ -wlɔ "bɛ waa -nɔn, ɛn "nyian waa -nɔn 'e 'ciɩla "da. Min -tʋ 'ka 'tɔlɛ o man -a -nɔndɩ -a dɩ.
\v 4 -Wɛɛ kɔala 'kʋ man 'kʋ trʋ 'badɩ -a 'nan 'kʋ 'si -nɔn 'wlɛ -e "yi "nɛn Zozinɔn "ta -a dra Bali -le minnun nɛn Zeruzalɛm bɛ -wlɛ "bɛ, 'o 'wee vɛ 'pa "va.
\v 5 'Wɩ nɛn -a -cin 'ka 'kʋ 'ji dɩɛ, -a 'bɔ nɛn waa drɛ. Kɔɔ 'o 'fli -nɔn Minsan -le 'nyranman -ji, ɛn "bɛ -sru 'o 'fli -nɔn "nyian 'kʋ 'bɔ lɛ 'padɩ -a 'kʋ 'va. Waa drɛ "le zɩ Bali cɩ "va "bɛ -yee 'wɩ 'zʋ.
\v 6 'Wɩ zɩɛ -yee "wɛan nɛn kʋ Tit trʋ 'ba 'nan, 'e 'lʋ 'ka 'va. "Yi "nɛn yaa pei -trɔa 'nan 'ka drɛ Zeruzalɛm Zozinɔn 'le vɛ -a bɛ, 'e 'lʋ -a 'le 'sran.
\p 
\v 7 'Cee yi -tɛradɩ Zozi da a -dan. Ɛn ka Bali -le 'wɩ "paaman sidɔ. Ɛn kaa -ci maan 'kpa tɩglɩ. Ɛn 'ka 'man a 'e 'tɔdɩ 'plɛblɛ Bali -le 'wɩ 'ji. Ɛn 'ka cin ye "yi 'kpa "le zɩ kʋa -nan kɔɔn 'cɛɛ bɛ -yee 'wɩ 'zʋ. 'Wɩ pɛɛnɔn zɩɛ cɛɛ dra 'e -ciala "da. -Yee "wɛan maan laabo 'ka lɔ 'nan "yi "nɛn ka "ta -a dra Zozinɔn 'le vɛ -a bɛ 'e -ciala "da "nyian!
\p 
\v 8 -Tɔ "cɛɛ maan wo 'ka man 'nan -e 'ka drɛ dɩ. 'Pian 'wɩ nɛn Zozinɔn -mienun -a drɛ bɛ, maan 'sinan 'pa 'cɛɛ 'nan -e 'ka "koe 'e 'kɔn 'ka da 'cee vɛ drɛnan. 'Wɩ zɩɛ -a drɛdɩ -a nɛn 'ka "bʋɩ Zozinɔn yɩdɩ "yi "ci -kɔɔnman.
\v 9 "Yi "nɛn -kaa san Zozi Crizi -a drɛ bɛ kaa -tɔa. Kaa -tɔa 'nan e ya fɛzan -a Bali 'lɛ, ɛn 'e 'fli drɛ 'yalɛ -tɛzan 'cee "wɛan. Yaa drɛ zɩɛ 'nan -e -yee 'yalɛ -tɛdɩ 'e 'ka drɛ fɛnɔn 'a Bali 'lɛ.
\p 
\v 10 'An 'ci wɩ nɛn e ya "le 'an vɩ 'cɛɛ 'wɩ zɩɛ -a da bɛ, -nyrɛn 'gʋ. E ya 'cee 'wɩ "yi "a -e "yi "nɛn Zozinɔn "ta -a dra Zeruzalɛm Zozinɔn 'le vɛ -a bɛ, 'ka 'cee vɛ 'pa "va. 'Wɩ 'kpa, cɛɛ 'wɩ zɩɛ -a pei 'trɔa "nɛn "lɛ pee man, ɛn cɛɛ 'vɩ 'ka 'bɔ 'a 'nan, kaa dra.
\v 11 -Yee "wɛan 'bɛ nɛn 'gʋɛ, 'ka yiɛ -trɔa "da, -e 'ka 'le 'sran. 'Ka 'ta 'e 'kɔn "fava -a drɛnan "le zɩ 'ka 'ta drɛ "fava -a vɩnan 'nan kʋa dra bɛ -yee 'wɩ 'zʋ. "Lala nɛn 'ka 'pɛ "sɔa -a -nɔndɩ -a bɛ, -a 'bɔ nɛn 'ka -nɔn!
\v 12 Maan ve 'cɛɛ 'nan, -te min fɛ -nɔn 'e 'ci 'fɩdaa 'a, "le zɩ -a -pɛ "sɔa -a bɛ -yee 'wɩ 'zʋ bɛ, -yɛɛ 'sɔ Bali lɛ. 'Pian 'bɛ nɛn min -pɛ 'ka 'sɔa 'bɛ 'nɔndɩ -a dɩɛ, Bali 'ka tin tɛa min da 'bɛ man dɩ.
\p 
\v 13 Fɛ nɛn maan 'vɩ zɩɛ -yɛɛ cɩ 'nan, e 'ka 'nan 'ka "drɛ wʋ 'yalɛ -tɛnɔn 'a fɛ -nɔndɩ min pee lɛ -le "wɛan dɩ. 'Wɩ nɛn e cɩ "yi "bɛ -nyrɛn 'nan, 'e 'kɔn 'ka pɛɛnɔn 'lɔ 'sɛzɛnɔn.
\v 14 'Bɛ nɛn 'gʋɛ fɛ a "cee 'lɔ "kaga, 'pian -a 'wɩ a -wee "man. -Yee "wɛan 'ka 'pa o va! 'Li 'pei -te -a 'wɩ a "cee "man bɛ, -wɛɛ "paa 'ka 'va. E ya "le Zozinɔn 'o 'wɩ zɩɛ -a drɛ te fɛ a o pɛɛnɔn 'lɔ 'sɛzɛnɔn.
\v 15 Kɔɔ e ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan:
\q1 «-Te min -tʋ -a koola "kaga 'kɔ oo,
\q1 -yee vɛ 'lee min nɛn
\q1 yaa koola "wɛnnɔn bɛ e 'bɔ 'e cin man.
\q1 Ɛn -te min -tʋ -a koola "wɛnnɔn 'kɔ oo,
\q1 -yee vɛ 'lee min nɛn
\q1 yaa koola "kaga "bɛ e 'bɔ 'e cin man.»
\s1 Pɔl minnun 'pa 'sia Korɛnti 'nɔn lɛ
\p 
\v 16 Kʋ Bali muo -fɔa 'nan, yaa drɛ ɛn 'ka 'nan wɩ a Tit man, "le zɩ 'ka 'nan wɩ cɩ 'kʋ man bɛ -yee 'wɩ 'zʋ.
\v 17 Kɔɔ 'wɩ nɛn kʋa laabʋ Tit -lɔ bɛ, e wɩɩ "man 'e 'ta le "koe "a. Maan ve 'cɛɛ 'nan, -yɛɛ 'vɩ 'e 'bɔ -a 'nan 'e "lo 'ka 'va.
\p 
\v 18 -Kaa "bʋɩ Zozizan nɛn -a 'tɔ "yi "a -leglizi -tʋdʋ pɛɛnɔn 'ji Zozi Crizi -le 'wɩ 'nɔnnɔn vɩdɩ man bɛ, kʋa "paa "va -wɛɛ "lo "a.
\v 19 -Leglizinun 'bɔ 'bɛ 'si "va 'nan 'e 'kʋ 'kʋ 'pa "yi "nɛn kʋ "ta -ko -a -nɔnlɛ Zeruzalɛm bɛ -a -nan. "Yi zɩɛ kʋ "ta -ko -a 'nan -e Minsan 'bɔ 'tɔ 'e drɛ -dan, ɛn -a -kɔɔndɩ nɛn "nyian 'nan kʋ ya "vale 'nan 'kʋ "paa o va.
\v 20 Ɛn "nyian bɛ, kʋ 'ka "vale 'nan minnun 'o 'wɩ 'kʋ man -wlidɩ "lala "kaga zɩɛ -yee "wɛan dɩ.
\v 21 Kɔɔ kʋa -wɛɛman 'nan 'wɩ nɛn kʋa dra bɛ 'e 'kɔn 'e 'sʋdɩ "ji Minsan 'lɛ, ɛn kʋa -wɛɛman 'nan 'e 'kɔn 'e 'sʋdɩ "ji minnun 'lɛ.
\p 
\v 22 Min "fli zɩɛ, -wɛɛ "ta "lo. Ɛn kʋ -kaa "bʋɩ Zozizan 'tʋ 'pa "nyian o va. -Kaa "bʋɩ zɩɛ, kʋa 'yɩ -pɛ "kaga "ji 'nan -a "koe "a 'e da Bali -le 'nyranman 'padɩ -ji. 'Bɛ nɛn 'gʋɛ, -a "koe "a 'e da 'e 'ciɩladɩ "da, kɔɔ e yi -tɛala 'ka da "fo.
\p 
\v 23 Tit -le vɛ bɛ, kʋɛ 'ta wʋla 'bɛ 'a, ɛn kʋɛ 'nyranman "paa 'bɛ 'a 'cee vɛ -a. 'Pian Zozinɔn nɛn o 'lʋ -a 'palɛ bɛ, -wee vɛ bɛ, -leglizinun 'bɛ o 'pa 'sia. Minnun Crizi 'tɔ dra -dan -wee "wɛan.
\v 24 -Yee "wɛan 'ka o 'kun 'ka 'pɛ "fli "a, -e -leglizinun 'o 'tɔ 'nan, ka min ye "yi. Ɛn -e 'o 'tɔ "nyian 'nan, 'ka 'sɩ nɛn kʋa -fɔ bɛ, e 'ka 'wɩ "tun "a dɩ.
\c 9
\s1 Fɛ -le "wɛan nɛn Pɔl Zozinɔn -mienun -trɔa 'e 'lɛ bɛ yaa -ci 'vɩ
\p 
\v 1 Maan 'yɩ 'nan, e 'ka paan "le 'an 'fluba crɛn -tɛ 'cɛɛ, "yi "nɛn Zozinɔn "ta -a dra Bali -le minnun nɛn Zeruzalɛm bɛ -wlɛ "bɛ, -a da dɩ.
\v 2 Kɔɔ maan -tɔa 'nan, 'ka 'ta a "fava 'wɩ zɩɛ -a drɛnan. Ɛn an 'ka 'sɩ -fɔ Masedɔa 'nɔn 'lɛ 'wɩ 'bɔ zɩɛ -a man. Maan 'vɩ -wlɛ 'nan, kaa nɛn Akai 'lɛglɔn 'ji bɛ, -e 'e "sia "nɛn "lɛ pee man bɛ, te 'ka 'man a 'e wʋʋdɩ 'wɩ zɩɛ -a drɛdɩ -a. Ɛn 'ka "koe "nɛn 'ka da -a drɛnan bɛ, e Zozinɔn "kaga "koe "tɔ 'o da.
\p 
\v 3 An -kaa "bʋɩ Zozinɔn 'labɛ o -trɔa 'an 'lɛ 'nan -e 'ka 'sɩ nɛn kʋa -fɔ bɛ, -a "nɛn 'e vɩlɛ 'e 'fʋ 'e "tun "dɩ. An ya "vale 'ka 'man 'e 'kɔn 'e wʋʋdɩ 'wɩ nɛn maan 'vɩ minnun lɛ bɛ -a da.
\v 4 Fɛ nɛn maan ve zɩɛ -yɛɛ cɩ 'nan, -te 'kʋ 'vale Masedɔa Zozinɔn -mienun -a kʋ 'lʋ te 'ka 'man 'ka 'e wʋʋdɩ dɩɛ, e 'ka "yi "dɩ. Kɔɔ 'kʋ 'bɔ nɛn kʋ 'ka 'sɩ -fɔ bɛ, 'yra -taa 'kʋ 'tɛlɛ, ɛn 'ka 'bɔ "nyian 'yra -taa "cee "tɛ wʋlɛ.
\v 5 -Yee "wɛan nɛn maan 'yɩ "yi -e 'an -kaa "bʋɩ Zozinɔn zɩɛ o trʋ 'ba 'nan 'o 'trɔa 'an 'lɛ. O "ta "lo 'nan -e "yi "nɛn kaa 'vɩ 'ka 'bɔ 'a 'nan 'ka dra bɛ 'o -tɛ 'e cin da. 'Ka -nɔn -wlɛ, kɔɔ an ya "vale -a man 'e 'kɔn 'e wʋʋdɩ 'vaa -e 'kʋ 'lʋ. 'Wɩ zɩɛ -yɛɛ -kɔɔnman 'nan kaa -nɔn 'ka 'ci 'fɩdaa 'a, ɛn min -tʋ 'ka 'tɔlɛ 'ka -sru "dɩ.
\s1 Fɛ -nɔndɩ ci 'fɩdaa 'a bɛ -yɛɛ 'sɔ Bali lɛ
\p 
\v 6 E ya "le 'an 'wɩ 'tʋ -cin -tɔ 'ka 'ji. -Nyrɛn 'nan, zɩ min fei 'pa bɛ -a ta fɛ 'wlɛ nɛn yaa -tɛa.
\v 7 'Wɩ zɩɛ -a da nɛn 'ka 'ci "nrɔn, -e min -tʋ 'e 'nɔn "le zɩ e 'si -a souba man bɛ -yee 'wɩ 'zʋ. Te 'e -nɔn 'e 'ci "pou "a dɩ, ɛn te 'e -nɔn "le 'nan fɛ nɛn min a 'e 'tɔdɩ -a -sru "bɛ -yee 'wɩ 'zʋ dɩ. Kɔɔ min nɛn e fɛ -nɔan ci "nrandɩ -a bɛ -a san nɛn Bali -a ye "yi.
\v 8 Ɛn "nyian bɛ, 'plɛblɛ a Bali lɔ 'nan -e 'e "yi 'tɔ 'tʋdʋ pɛɛnɔn drɛ 'cɛɛ. Yaa -nɔan 'cɛɛ 'e 'ciɩladɩ "da, 'nan -e 'ka 'bɔ "nyian 'ka -kɔla "yi 'tɔ 'tʋdʋ pɛɛnɔn drɛdɩ -a min pɛɛnɔn lɛ.
\p 
\v 9 'Ka drɛ zɩɛ, kɔɔ e ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan:
\q1 «Min nɛn e 'yee "yi fuila "man,
\q1 yaa -nɔn 'yalɛ -tɛnɔn lɛ bɛ,
\q1 -a 'tɔ "yi "fo 'li 'trilii.»
\m 
\v 10 Ɛn "nyian bɛ, Bali nɛn e fɛ 'wlɛ -nɔan fei 'pazan lɛ, ɛn e -blɩfɛ -nɔan -yrɛ "bɛ, e -taa fɛ 'wlɛ 'nɔnlɛ 'cɛɛ 'e 'ciɩladɩ "da. Yaa dra -e 'e 'pa "da, 'nan -e 'ka -kɔla 'cee "yi fuiladɩ -a "man.
\v 11 'Wɩ 'kpa, Bali -taa 'ka drɛlɛ fɛnɔn 'a -pɛ "kaga "ji, -e 'ka -kɔla "fɛ -nɔndɩ -a minnun lɛ 'kpa tɩglɩ. Tɔɔn 'cee "yi "nɛn kaa "paa 'kʋ 'lɔ -e 'kʋ 'kʋ -a bɛ, -yee "wɛan minnun -taa Bali muo "fɔlɛ.
\p 
\v 12 'Cee "yi "nɛn ka -taa -a drɛlɛ bɛ, e "paa Zozinɔn nɛn 'yalɛ o -tɛ Zeruzalɛm bɛ o va. Ɛn "nyian bɛ, yaa -maan -e min "kaga 'o Bali muo "fɔ.
\v 13 'Cee "yi "drɛdɩ zɩɛ, -te waa -nan 'yɩ bɛ, o Bali 'tɔ dra -dan. Kɔɔ ka ya 'ta wʋlanan Zozi Crizi -le 'wɩ 'nɔnnɔn da, ɛn ka fɛ -nɔan -wlɛ 'ka 'ci 'fɩdaa 'a, ɛn kaa dra zɩɛ min pɛɛnɔn lɛ.
\v 14 'Wɩ -dan nɛn Bali -le "yi -a drɛ 'cɛɛ bɛ, -yee "wɛan, o -taa Bali trʋ 'balɛ 'cɛɛ 'ka yɩdɩ "yi "a.
\v 15 Ɛn -kaa pɛɛnɔn -kaa Bali 'tɔ drɛ -dan! Kɔɔ "yi "nɛn min 'ka 'kɔlaman -e 'e vɩ 'e 'le dɩɛ, yaa drɛ -cɛɛ.
\c 10
\s1 'Tɔ nɛn minnun -a 'pa Pɔl man bɛ, yaa -ci 'si
\p 
\v 1 'An 'bɔ Pɔl, e ya "le 'an 'wɩ 'tʋ -ci 'si 'cɛɛ. Minnun 'wɩ "paa 'an da 'nan, -te 'an 'ka yra 'yɩ bɛ, an 'ka 'va wɩ ve -trɔɔ. 'Pian -te an 'ka 'ka "srɔn "kogo dɩɛ, an 'ka 'va wɩ tin "baa 'e 'plɛblɛ da. Kaa -tɔa 'nan Crizi a -trɔɔ, ɛn e ya min 'kpa -a. An ya "vale 'an 'wɩ dra "le -yee 'wɩ 'zʋ. -Yee "wɛan an 'ka trʋ "baa 'kpa tɩglɩ 'nan,
\v 2 te 'ka 'wɩ drɛ -te an 'bɔla 'ka 'va nun bɛ, -e 'an 'ka 'va wɩ drɛ 'e 'plɛblɛ da dɩ! 'Pian minnun nɛn o 'tɔ "paa 'kʋ man 'nan blamin -ci 'sɔ wɩ -sru "nɛn kʋ cɩ bɛ, -te an 'bɔla 'ka 'va bɛ, an tin "baa -wlɛ 'e 'plɛblɛ da.
\p 
\v 3 Kʋ ya blaminnun -a, 'bɛ a zɩ. 'Pian -kuli nɛn kʋ cɩ "man 'gʋɛ, e 'ka blamin -le -kuli -tandɩ pɛ -ji dɩ.
\v 4 Fɛ nɛn maan 'vɩ zɩɛ -yɛɛ cɩ 'nan, 'kʋe -kuli -tan fɛnun nɛn kʋ -kuli -taan "a bɛ, o 'ka fɛnun nɛn blamin -a "sia -e 'e 'kʋ -kuli man bɛ -a dɩ. 'Pian 'kʋe -kuli -tan fɛnun bɛ, Bali 'plɛblɛ 'nɔn -wlɛ -e 'kʋ Bali 'nanmannɔn 'le 'plɛblɛ 'klɩ. Blamin -le ci "nrɔndɩ nɛn e ya -wlidɩ "bɛ, kʋa yi -kaa.
\v 5 Ɛn -yee -dandan 'tandɩ nɛn yaa maan ya'a 'we "man -e 'e Bali -tɔ dɩɛ, kʋa yi -kaa. Kʋa dra 'nan -e blamin -le ci "nrɔndɩ pɛɛnɔn 'e lila Bali da te e 'ta wʋla Crizi wei da.
\v 6 Ɛn minnun nɛn 'o 'wɩ "paa 'kʋ da 'labɛ, kʋ -taa 'wɩ "nɛn -kɔɔnlɛ -wlɛ. 'Pian kʋ ya -a man -pɛnnan 'nan 'ka 'bɔ 'labɛ, 'ka 'ta wʋladɩ 'sia 'kʋ wei da tɩglɩ 'vaa -e 'kʋ drɛ.
\p 
\v 7 'Ka 'wɩ 'gʋɛ -a -nanjɛn 'ka 'bɔ 'a -tʋ. Min nɛn yaa ve 'e 'fli man 'nan 'e ya Crizi -le vɛ -a bɛ, -a -cin 'e 'tɔ "ji 'nan, 'kʋ 'bɔ "nyian "kʋ "ya wo Crizi -le vɛ -a "le -yee 'wɩ 'zʋ!
\v 8 Ɛn "nyian bɛ, 'ka -tɔ 'nan, Minsan -a -si -nɔn 'kʋɛ 'nan 'kʋ 'pa 'ka 'va -e 'ka 'tɔ 'plɛblɛ, 'pian yaa vɩlɛ 'nan kʋ 'ka 'ci baa -ji dɩ. -Te 'wɩ zɩɛ an 'kʋ 'sɩ -fɔ -a 'e 'ciɩla "da "bʋʋ "bɛ, -a 'yra 'ka 'an 'tɛa "fo "dɩ.
\p 
\v 9 Te 'ka 'ci "nrɔn 'nan, an ya "vale 'an 'ka -tɛa "klan -a 'mɛn 'flubanun nɛn maan crɛn -tɛa 'cɛɛ bɛ -a -ji dɩ!
\v 10 Fɛ nɛn maan ve zɩɛ -yɛɛ cɩ 'nan, minnun -a ve 'an man 'nan: «Pɔl -le 'flubanun nɛn yaa crɛn -tɛa "bɛ, e 'wɩ tin "baa min lɛ -ji 'e 'plɛblɛ da, ɛn e 'wɩ -dandan ve 'e 'fli man. 'Pian -te -a 'bɔ po a -nan bɛ, min yiɛ 'ka "naan "man "dɩ, ɛn e 'ka "le min 'e "trɔɛn "tɔ -a wei lɛ dɩ.»
\v 11 Min nɛn e 'wɩ zɩɛ -a ve 'an man bɛ, e ya "le 'an vɩ -a san lɛ 'nan, zɩ 'kʋ wei cɩ 'kʋe 'flubanun -ji bɛ, -a -tʋwli "nɛn "nyian, -te kʋ 'bɔla 'ka 'va bɛ, zɩ 'kʋ drɛ wɩnun -kɔan.
\p 
\v 12 -A -cin 'ka 'kʋ 'ji 'nan 'kʋ -kɔan minnun zɩɛ o va dɩ. -Te 'bɛ "cɛɛ dɩ, 'kʋ 'cɛin -tɔala 'kʋ cin yra 'kʋ 'vale waa dɩ. O 'wɩ -dandan ve 'o 'fli man, ɛn o ya 'o 'fli -kɔɔnnan 'o cin man. -Blʋ 'tandɩ 'bɛ cɩ zɩɛ.
\v 13 'Kʋe vɛ bɛ, kʋ'a 'wɩ -dandan ve 'kʋ 'fli man 'e 'ciɩladɩ "da "dɩ. 'Wɩ nɛn 'kʋ 'fli -kɔɔnman -a bɛ, Bali -a -nɔn 'kʋɛ. -Nyrɛn 'nan: Kʋɛ 'bɔla Zozi Crizi -le 'wɩ 'nɔnnɔn 'a 'ka 'va.
\v 14 -Yee "wɛan -a -ci a 'wein 'nan, kʋ 'ka 'wɩ -dandan vɩnan 'kʋ 'fli man 'e 'ciɩladɩ "da "dɩ. "Te 'e 'kɔn 'nan kʋɛ "cɛɛ 'bɔla Zozi Crizi -le 'wɩ 'nɔnnɔn 'a 'ka 'va 'e tɛdɛ dɩɛ, "te maan ve 'nan 'wɩnun nɛn kʋa ve 'kʋ 'fli man 'gʋɛ, e ya 'e 'ciɩladɩ "da.
\v 15 Kʋ'a 'wɩ -dandan ve 'kʋ 'fli man 'e 'ciɩladɩ "da "dɩ, ɛn e 'ka min pee -le 'nyranman da dɩ. 'Pian -a -cin a 'kʋ 'ji 'nan, -te 'cee yi -tɛradɩ Zozi da 'pa "da "bɛ, 'kʋ 'tɔ 'e drɛ "nyian -dan 'ka 'va. Ɛn e drɛ -dan 'nyranman nɛn kʋa "paa bɛ -yee "wɛan.
\v 16 'E drɛ zɩɛ -e 'kʋ -kɔla Zozi Crizi -le 'wɩ 'nɔnnɔn vɩdɩ -a 'ka -sru 'flanun da "nyian. 'Wɩ zɩɛ -a -cin nɛn 'kʋ 'ji. 'Pian kʋ 'ka "vale 'kʋ 'fli dra -dandan 'nyranman nɛn min pee -a 'pa bɛ, -a da dɩ.
\v 17 E ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan:
\q1 «Min nɛn e ya "vale 'e -dandan "taan bɛ,
\q1 'e -dandan 'tan 'nyranman nɛn
\q1 Minsan -a "paa bɛ -a.»
\m 
\v 18 -Yee "wɛan maan ve 'cɛɛ 'nan, -te min 'wɩ -dandan ve 'e 'fli man bɛ, e ya 'wɩ "tun "a. 'Pian min nɛn Minsan -a 'tɔ "yi "ve bɛ, -yɛɛ cɩ 'wɩ -dan a.
\c 11
\s1 Pɔl 'wɩ 'ci 'si Korɛnti 'nɔn lɛ 'e 'nanmannɔn da
\p 
\v 1 'Ka 'wɩ "man -e 'an 'wɩ tin 'ba 'cɛɛ "le "mɛɛn -wulo 'ka "nyian 'an da dɩ! 'Ka yra 'si, 'ka 'wɩ "man -e 'an 'bɔ "nyian "an 'fli -sɩ -fɔ!
\v 2 Maan ve 'cɛɛ 'nan, an 'ka 'sia te ka ye "le 'nan lɩmɔn nɛn ya'a tian 'kɔnnɛn -tɔlɛ dɩɛ -yee 'wɩ 'zʋ, ɛn an 'ka 'nɔn -kɔnnɛn lɛ. -Kɔnnɛn zɩɛ Crizi nɛn. -Yee "wɛan an ya 'ka 'ta man bʋnan "le zɩ Bali man bo 'yee minnun da bɛ -yee 'wɩ 'zʋ.
\v 3 'Wɩ nɛn -mlɛn -a drɛ 'li Ɛv lɛ bɛ, 'ka 'ci "nrɔn "da! E Ɛv man 'yɩ 'yee see "paa weinun -a. "Klan a 'an 'ji 'nan, te 'cee vɛ 'e drɛ zɩ dɩ! Kɔɔ an ya "vale 'nan 'ka 'fʋ Zozi Crizi -tʋwli -sru, ɛn 'ka 'fʋ -a -sru 'ka 'ci 'fɩdaa 'a.
\p 
\v 4 Fɛ nɛn maan ve zɩɛ -yɛɛ cɩ 'nan, kʋ Zozi Crizi -le 'wɩ 'vɩ 'cɛɛ, 'pian ka "we "man -e min 'e 'ta 'wɩ 'pee vɩ 'cɛɛ Zozi da. Ɛn "nyian bɛ, Bali lei 'saun a 'ka 'lɔ, 'pian ka "we "man -e min 'e 'ta lei pee -nɔndɩ 'cɛɛ 'wɩ vɩ. Ɛn "nyian bɛ, kʋ Zozi Crizi -le 'wɩ 'nɔnnɔn 'vɩ 'cɛɛ, 'pian ka "we "man -e min 'e 'wɩ 'nɔnnɔn 'pee vɩ 'cɛɛ.
\p 
\v 5 Zozi 'le 'pasianɔn nɛn o -dandan "taan 'labɛ, maan -tɔa 'nan an 'ka o man "wɛnnɔn Bali -le 'wɩ 'ji dɩ.
\v 6 'An 'pɛ 'ka 'sɔa 'wɩ tin 'badɩ -a fɛnyian "le -wee 'wɩ 'zʋ. 'Bɛ a zɩ, 'pian te e ya Bali -le 'wɩ 'tɔdɩ -a bɛ, mɛɛn -tɔa. 'Wɩ zɩɛ mɛɛn 'ci kɔɔn 'ka 'tʋdʋ pɛɛnɔn lɛ, ɛn mɛɛn 'ci kɔɔn -pɛ "kaga "ji.
\p 
\v 7 Bali -le 'wɩ 'nɔnnɔn nɛn maan 'vɩ 'cɛɛ bɛ, maan 'vɩ 'cɛɛ 'e "tun. Ka'an 'pan wʋlɛ dɩ. -Te an 'wɩ zɩɛ -a drɛ bɛ, e 'ka 'wɩ 'wlidɩ "a dɩ. 'Pian 'an 'fli drɛ 'cɛɛ "wɛnnɔn 'nan -e 'ka drɛ -a "nɛn "blɩnɔn 'a.
\v 8 An wɩɩ "man ɛn -leglizi peenun 'an pan 'wʋ 'nan -e 'an -kɔla 'nyranman zɩɛ -a 'padɩ -a 'cɛɛ. E ya "le crin nɛn maan 'wʋ, kɔɔ -a -nɔan da "cɛɛ -e -leglizi pee nɛn 'yaan 'pan wʋ dɩ.
\v 9 -A -cin 'e 'tɔ 'ka 'ji 'nan, tʋ nɛn maan drɛ 'ka 'va ɛn "lala 'wɩ 'tɔ 'an man bɛ, ma'an 'silɛ 'ka 'va min -tʋ -lɔ dɩ. 'Pian -kaa "bʋɩ Zozinɔn nɛn Masedɔa 'lɛglɔn 'ji bɛ -wɛɛ ta 'palɛ 'an 'va "lala "nɛn -a 'wɩ cɩ 'an man bɛ -a. Maan wɛɛ 'nan te 'an 'kɔn 'ka 'win -ji -trɔ -a dɩ. Ɛn maan dra tian zɩ.
\v 10 An ya Crizi -le 'wɩ tɩglɩ -sru, ɛn an 'wɩ tɩglɩ ve 'cɛɛ. Maan ve 'cɛɛ 'nan, 'wɩ nɛn maan ye 'mɛn 'tɔ -dan tʋ -a zɩɛ, min -tʋ 'ka Akai 'lɛglɔn pɛɛnɔn 'ji -e 'e -kɔla -a 'sidɩ -a 'an 'lɔ dɩ.
\v 11 -Mɛ "le "wɛan nɛn an 'wɩ zɩɛ -a 'vɩ? Ɛn -te maan 'vɩ bɛ, -a -ci nɛn 'nan ma'an 'ka 'ye "yi dʋʋ? -Cɛjɛ, 'bɛ "cɛɛ dɩ. 'Pian an 'ka ye "yi, ɛn Bali -a -tɔa 'nan 'wɩ 'kpa nɛn maan ve.
\p 
\v 12 An 'ka ye "yi, 'pian maan dra "le zɩ maan pei 'trɔa 'e 'cɛn bɛ -yee 'wɩ 'zʋ. Ma'an wɛɛman 'nan 'kaan 'pan wʋ dɩ. Maan dra zɩɛ minnun nɛn o cɩ 'kʋ 'man -wɛɛnan bɛ -wee "wɛan. O ya -si -tʋ -wɛɛnan 'nan -e 'o -dandan 'tan -a vɩdɩ -a 'nan, kʋ "lala "sia "le 'wee 'wɩ 'zʋ.
\p 
\v 13 Maan ve 'cɛɛ 'nan, Zozi Crizi -le 'pasianɔn tɩglɩ "cɛɛ waa dɩ. Min see "paanɔn nɛn waa, ɛn 'o 'fli ta yɔɔman 'nan o ya Zozi Crizi -le 'pasianɔn 'a.
\v 14 'Wɩ zɩɛ te 'e 'ka 'kan dɩ! Kɔɔ Satan 'bɔ bɛ, 'e 'fli ta yɔɔman 'nan e ya Bali -le 'pasiazan -a.
\v 15 -Yee "wɛan maan ve 'cɛɛ 'nan, e 'ka min 'kan wɩ -a -e Satan -le minnun zɩɛ 'o 'fli ta yɔɔ 'nan o ya Bali -le 'nyranman 'panɔn 'a dɩ. 'Pian -wee 'wɩ 'le 'srannan "bɛ, 'wɩ 'wlidɩ "nɛn waa drɛ bɛ -a man pan nɛn Bali -a wo -wlɛ.
\s1 Yra yɩdɩnun nɛn o 'bɔ Pɔl man bɛ yaa -nan wɩ 'vɩ
\p 
\v 16 E ya "le 'an vɩ "nyian 'cɛɛ 'nan, te -a -cin 'e 'kɔn 'ka 'ji 'nan 'an 'wulo 'ka 'an da dɩ! 'Pian -te 'wɩ zɩɛ -a -cin nɛn 'ka 'ji bɛ, ka 'wɩ "man -e 'an 'bɔ "nyian "an 'wɩ -dandan vɩ 'an 'fli man "wɛnnɔn "le 'an 'wulo 'ka 'an da dɩ.
\v 17 'Wɩ -dandan nɛn an "ta -a ve 'an 'fli man 'gʋɛ, maan -tɔa 'nan, e 'ka 'wɩ nɛn Minsan 'suzan -a ve bɛ -a dɩ. 'Pian e ya "le min nɛn -a -wulo 'ka 'e da dɩɛ, -yɛɛ cɩ 'wɩnan.
\v 18 Min "kaga "a 'ka yei, o 'wɩ -dandan ve 'o 'fli man 'nan -e 'o 'sɔ minnun lɛ. -Yee "wɛan 'an 'bɔ "nyian "an dra zɩ.
\v 19 'Ka 'fli "siala 'wɩ 'tɔnɔn 'a, 'pian ka "we "man -e 'ka "trɔɛn "tɔ minnun nɛn o -wulo 'ka 'o da 'labɛ dɩɛ -wlɛ.
\v 20 O 'ka drɛ 'wee nɔannun -a, te 'o 'ka 'ta -ble. Ka ya -wlɔ "pʋ 'kuin, ɛn o -va -ble 'ka da, te o 'pa -fɔɔman 'ka yra. 'Wɩ pɛɛnɔn zɩɛ waa dra 'cɛɛ te ka "we "man.
\v 21 Maan ve 'cɛɛ 'nan, -a -cin 'ka 'tɔlɛ 'kʋ 'ji 'nan 'kʋ 'ta zɩɛ -a wo 'ka 'va 'mlɔnmlɔn dɩ. 'Pian -te 'ka 'ci "nrɔnman 'nan, e ya 'yra -tɛ wɩ -a 'kʋ 'lɔ bɛ, -a -nɔan da nɛn.
\p 'Wɩ -dandan nɛn minnun -a ve 'o 'fli man bɛ, 'an 'bɔ "nyian an "ta "an "ve. "An "ve "nyian "le 'an 'wulo 'ka 'an da dɩ.
\v 22 O ya Ebre 'nɔn 'a. 'An 'bɔ "nyian Ebre min nɛn "mɛɛn "a. Izraɛl 'nɔn nɛn waa, ɛn 'an 'bɔ "nyian Izraɛl min nɛn "mɛɛn "a. Abraam kludanɔn nɛn waa, ɛn 'an 'bɔ "nyian Abraam kluda min nɛn "mɛɛn "a.
\v 23 O ya Crizi 'sunɔn 'a. 'An 'bɔ "nyian an ya Crizi 'suzan -a 'e "mlian o pɛɛnɔn da. Maan ve "le 'an 'wulo 'ka 'an da dɩ. An Bali -le 'nyranman 'pa e ciɩ o pɛɛnɔn 'le vɛ da. An -pʋ 'kɔn blɩ Bali -le 'wɩ 'ji e ciɩ o pɛɛnɔn 'le vɛ da. Minnun 'an -sɔn e ciɩ o pɛɛnɔn da. Tʋ "kaga 'bɔ bɛ, 'an 'kadɩ -fɔla tʋ Bali -le 'wɩ 'ji.
\v 24 Zuif 'nɔn 'an 'sɔn 'e 'pa -a 'soolu, te o -ngble 'lɛ wo 'an 'ji -tʋdʋ -fuba yaaga 'wlɛ 'sɔrasiɛn.
\v 25 Rɔm 'nɔn 'an 'sɔn sɔnba "a 'e 'pa -a yaaga. Ɛn Zuif 'nɔn -a wɛɛ 'nan 'waan -tɛa "kɔlɛ -a 'e 'pa -a -tʋ. Ɛn -klʋ -sran ji 'maan 'e 'pa -a yaaga 'yi yiɛ da. -A -tʋ drɛ bɛ, an -pei -man -tʋ 'lee yidɛa drɛ 'yi 'va.
\v 26 An 'ta "kaga 'wʋ bɛ, te fɛ 'an "bluman. -A -mie drɛ 'yi 'cɛnnan 'ji, ɛn -a -mie drɛ bɛ, yiɛ 'plɛnɔn 'bɛ 'an blu, ɛn -a -mie drɛ bɛ, 'an "bʋɩ Zuif 'nɔn 'bɛ 'an blu, ɛn -a -mie drɛ bɛ, minnun nɛn o 'ka Zuif 'nɔn 'a dɩɛ -wɛɛ 'an blu, ɛn -a -mie drɛ 'fla yei, ɛn -a -mie drɛ "bui "da, ɛn -a -mie drɛ 'yi yiɛ da, ɛn -a -mie drɛ bɛ, minnun nɛn 'o 'fli "siala 'an "bʋɩnun Zozinɔn 'a bɛ, -wɛɛ 'an blu.
\v 27 Ɛn "nyian bɛ, bodrun funnin te an ya 'nyranman da, ɛn bodrun funnin te 'an "koe -nyaan. -A -mie drɛ bɛ, 'an yi 'sɔn, ɛn -a -mie drɛ bɛ, dra 'an 'tɛ, ɛn -a -mie drɛ bɛ, 'yi dra 'an 'tɛ, ɛn -a -mie drɛ bɛ, an fɛ 'sɔn, ɛn -a -mie drɛ bɛ, trun 'an 'tɛ, ɛn -a -mie drɛ bɛ, sɔ klɩ 'an man.
\v 28 'Wɩ "kaga "a tian paan -e 'an vɩ, 'pian -a -tʋwli 'gʋɛ -a 'bɔ nɛn maan ve. Yi -tʋdʋ pɛɛnɔn man bɛ te -leglizi -nan wɩ a 'an man.
\v 29 -Yɛɛ cɩ "le 'nan -te min 'ka 'e 'tɔdɩ 'plɛblɛ yi -tɛradɩ Zozi da -ji dɩɛ, 'an 'bɔ "nyian te "mɛn "koe "a 'e 'sidɩ 'an da. Ɛn -te min -tʋ 'si -si tɩglɩ da bɛ, 'an 'bɔ "nyian -a 'wɩ trun -fɔa 'an man.
\p 
\v 30 -Te e ya 'nan 'an 'wɩ -dandan vɩ 'an 'fli man bɛ, yra yɩdɩnun nɛn o 'bɔ 'an man Bali -le 'wɩ 'ji bɛ -a 'bɔ 'a nɛn an -dandan "taan.
\v 31 'Wlu "cɛɛ maan -sɛan "dɩ. Bali nɛn -kaa san Zozi "tɩ "a bɛ yaa -tɔa zɩ. 'Tɔ -dan 'e 'fʋ -yee vɛ -a 'li 'trilii.
\v 32 'Wɩ 'kpa, tʋ nɛn an ya Damas bɛ, 'fla zɩɛ -a tazan nɛn mingɔnnɛn Areta -a -tɔ bɛ, e minnun paala 'fla man -klɔn -yrɛ pɛɛnɔn "nɛn 'nan -e 'waan 'kun.
\v 33 'Pian min -mienun 'pa 'an 'va, waan 'fɔ saannɛn 'ji, ɛn waan 'bɔla -fenɛdi da. -A -nan nɛn waan sɔɔnla 'fla man -klɔn -sru, ɛn an -kɔla 'tɛdɩ -a -ji.
\c 12
\s1 'Wɩnun nɛn Bali -a -nan kɔɔn Pɔl lɛ bɛ yaa 'vɩ
\p 
\v 1 E ya "le 'an 'wɩ -dandan vɩ tian 'an 'fli man. Maan -tɔa 'nan e ya 'wɩ "tun "a. 'Pian 'wɩnun nɛn Minsan -a -nan kɔɔn 'mɛn bɛ 'lee 'wɩnun nɛn yaa ta 'bɔla 'mɛn bɛ, 'e 'bɔ 'mɛn 'bɛ da.
\v 2 An Zozizan 'tʋ -tɔa. Zozizan zɩɛ 'wɩ nɛn e drɛ -yrɛ "bɛ -a -nan lɛ -fuda sinjɛn nɛn 'gʋ. Bali -a 'sia ɛn e -kʋ -a la yaaga da. 'Pian -te -a lei -a nɛn Bali -kʋ -o, ma'an tɔa dɩ. Ɛn -te -a po -a nɛn Bali -kʋ -o, ma'an tɔa dɩ. Bali -tʋwli 'bɛ -tɔa.
\v 3 'Wɩ 'kpa, min zɩɛ maan -tɔa. -Te -a lei -a nɛn Bali -kʋ -o, ma'an 'bɛ tɔa dɩ. Ɛn -te -a po -a nɛn Bali -kʋ -o, ma'an 'bɛ tɔa dɩ. Bali -tʋwli 'bɛ -tɔa.
\v 4 Maan -tɔa 'nan Bali -kʋ -a 'yee fɛnan nɛn min 'ka 'e yra ye 'mlɔnmlɔn dɩɛ -a -nan. Min zɩɛ 'wɩ nɛn yaa 'man bɛ, blamin 'ka 'kɔlaman -a vɩdɩ -a dɩ, ɛn -a -si 'ka 'e 'nɔndɩ 'nan blamin 'e vɩ dɩ.
\v 5 Min zɩɛ -a lɛ nɛn an 'tɔ -dan -nɔan. -Dandan 'tandɩ 'an 'bɔ 'le 'wɩ 'a bɛ, ma'an dra dɩ. 'Pian -te maan 'vɩ 'nan 'an -dandan "taan bɛ, yra yɩdɩnun nɛn o 'bɔ 'an man bɛ, -a 'bɔ nɛn maan ve.
\p 
\v 6 Ɛn -te an "ta -dandan "taan 'an 'bɔ 'le 'wɩ 'a bɛ, e 'ka 'nan 'an 'wulo 'ka 'an da dɩ. Kɔɔ 'wɩ nɛn e drɛ tɩglɩ bɛ -a 'bɔ nɛn maan ve. 'Pian 'an 'pɛ da -tɔa 'bɛ 'a. Maan dra zɩɛ 'nan -e minnun 'o 'mɛn 'wɩ tin 'ba 'wɩ nɛn waa -nan 'yɩ 'an 'lɔ bɛ -a da 'lee 'wɩ nɛn waa 'man 'an da bɛ -a da.
\p 
\v 7 'Wɩ nɛn Bali -a -nan kɔɔn 'mɛn zɩɛ, e ya -nyrɛnnɛn wɩ -a. -Yee "wɛan "tɔgɔ 'an -dandan 'tan -a vɩdɩ -a bɛ, Bali 'an 'mɛan drɛ. E ya "le 'nan lei nɛn 'an 'kɔlɛ 'ji. Satan -le 'pasiazan -tʋ nɛn 'an man te 'e 'tɛ -kɔɔnman 'mɛn "tɔgɔ 'an -dandan 'tan -a vɩdɩ -a.
\v 8 An Minsan trʋ 'ba 'e 'pa -a yaaga 'nan, 'e Satan -le 'pasiazan zɩɛ -a 'si 'an man.
\v 9 Minsan 'ka 'wɩlɛ "man "dɩ. 'Pian yaa 'vɩ 'mɛn 'nan: «Mɛin ye "yi, ɛn mɛin drɛ 'mɛn min -a, -yɛɛ cɩ 'wɩ -dan a. 'Bɛ nɛn 'i "koe 'ka 'i da dɩɛ, -a -nan nɛn 'mɛn 'plɛblɛ bɔala -dan.» 'Wɩ zɩɛ -yee "wɛan, an -dandan "taan 'nan 'an "koe 'ka 'an da dɩ. Maan dra zɩɛ 'nan -e Crizi -le 'plɛblɛ 'e 'kɔn 'an 'lɔ.
\v 10 -Yee "wɛan 'bɛ nɛn 'gʋɛ, -te yra yɩdɩ a 'an man oo, ɛn -te minnun 'an "srɔnman oo, ɛn -te 'wɩnun bɔa 'an man oo, ɛn -te minnun 'tɛ "paa 'an da oo, ɛn -te "klan 'an -tɛa oo, Crizi -le "wɛan bɛ an "we "man ci "nrandɩ -a. Kɔɔ maan -tɔa 'nan, 'bɛ nɛn 'an "koe 'ka 'an da 'gʋ dɩɛ, -a -nan nɛn Crizi 'plɛblɛ -nɔan 'mɛn 'e 'ciɩladɩ "da.
\s1 Korɛnti 'nɔn 'nan wɩ a Pɔl man
\p 
\v 11 An 'wɩ tin 'ba 'cɛɛ "le 'an 'wulo 'ka 'an da dɩ. Cɛɛ -maan maan drɛ zɩ. Kɔɔ cɛɛ 'wɩ -dandan ve paan 'an man, 'pian ka'a drɛlɛ dɩ. An 'ka fɛ -tʋ -a dɩ, 'pian Zozi 'le 'pasianɔn nɛn o -dandan "taan 'labɛ, maan -tɔa 'nan an 'ka o man "wɛnnɔn Bali -le 'wɩ 'ji dɩ.
\v 12 'Wɩnun nɛn waa -kɔɔnman 'nan an ya Zozi 'le 'pasiazan -a bɛ, 'an -pɔan 'sran 'e cin da, ɛn maan drɛ 'ka 'va. -Te e ya 'lɛbo "fɔ wɩnun -a oo, ɛn -te e ya -cɛ -srɔn "wɩnun -a oo, ɛn -te e ya 'wɩnun nɛn o Bali -le 'plɛblɛ 'ci -kɔɔnman bɛ -a oo, maan pɛɛnɔn drɛ 'ka 'va.
\v 13 -Mɛ "wɩ nɛn maan drɛ -leglizi peenun -ji, te ma'an 'bɛ drɛlɛ 'ka 'va dɩ? Maan -tɔa 'nan, e ya -tʋwli "cɛ, -nyrɛn 'nan, ma'an -wɛɛlɛ 'nan 'kaan 'pan wʋ dɩ. -Te kaa ye "le maan drɛ 'wlidɩ "bɛ, 'ka yra 'si, 'kaan man wɩ 'cɛ!
\p 
\v 14 'Bɛ nɛn 'gʋɛ an man wʋʋ 'nan -e 'an 'cɛin yaagazan 'e 'lʋ 'ka 'va. 'Pian -te an 'lʋ bɛ, ma'an -wɛɛman 'nan 'kaan 'pan wʋ dɩ. Kɔɔ 'ka 'lɔ fɛ va "cɛɛ an cɩ dɩ, 'pian 'ka 'bɔ po va nɛn an cɩ. Kaa -tɔa 'nan, 'nɛnnun "cɛɛ fɛ treman 'o "tɩ 'lee 'o "bʋ "le vɛ -a dɩ, 'pian 'nɛn "tɩ 'lee 'nɛn "bʋ 'bɛ fɛ treman 'wee 'nɛnnun -le vɛ -a.
\v 15 'Mɛn vɛ bɛ, "lala pɛɛnɔn nɛn 'an 'lɔ bɛ, e -ko 'ka 'wulo -wlu. Ɛn 'an 'bɔ 'an 'fli -nɔan "nyian "fo 'nan -e 'an 'pa 'ka 'va. -Te an 'ka ye "yi "bʋʋ zɩɛ, ɛn ka'a "mɛn 'yɩ 'wo "yi "dɩɛ, e ya 'kpa?
\p 
\v 16 Ma'an -wɛɛlɛ 'nan 'kaan 'pan wʋ dɩ. 'Wɩ 'kpa nɛn! 'Pian 'ka 'va min -mienun -a ve 'nan, an 'ka 'man 'yɩ see "paa weinun -a, te an "lala "kooman 'ka 'lɔ -pɛ pee -ji zia.
\v 17 Minnun nɛn an o 'pa 'sia 'ka 'va bɛ, -tɩɛ 'ka 'ta blɩ "lala "koodɩ -a 'ka 'lɔ?
\v 18 An Tit trʋ 'ba 'nan 'e 'lʋ 'ka 'va. Ɛn an -kaa "bʋɩ Zozizan 'tʋ 'pa "va, -wɛɛ 'lʋ 'a. Tit nɛn e 'lʋ zɩɛ, e 'ka 'ta blɩ "lala "koodɩ -a 'ka 'lɔ? -Cɛjɛ, ya'a drɛlɛ zɩ "fo "dɩ. Kɔɔ 'kʋ 'vale -a 'kʋe ci "nrɔndɩ a -tʋwli, ɛn kʋ 'ta wʋla 'a -si -tʋwli "da.
\p 
\v 19 -A -mie -nan bɛ, 'ka 'ci "nrɔnman 'nan, 'kʋe tin 'nɔnnɔn nɛn an cɩ -a -wɛɛnan. -Cɛjɛ, 'bɛ "cɛɛ dɩ. 'Pian kʋ ya Crizi 'sunɔn 'a, ɛn 'wɩnun nɛn kʋa dra bɛ, Bali lɛ nɛn kʋa -sru "ve. 'Kʋ "bʋɩ Zozinɔn, 'wɩ pɛɛnɔn nɛn kʋa dra bɛ, kʋa dra 'nan -e 'ka 'tɔ 'plɛblɛ Bali -le 'wɩ 'ji.
\v 20 Kɔɔ "klan a 'an 'ji 'nan, -te an 'lʋ bɛ, ma'an -taa "bɔlɛ 'ka man "le zɩ 'an cɩ "va "bɛ -yee 'wɩ 'zʋ dɩ. Ɛn 'ka 'bɔ "nyian ka'a 'taa 'an 'tɔlɛ "le zɩ 'ka cɩ "va "bɛ -yee 'wɩ 'zʋ dɩ. "Klan a 'an 'ji 'nan, an bɔa 'ka man te 'wɩ 'blɩdɩ a 'ka yei, ɛn te man bʋdɩ -a 'ka yei, ɛn te ka ya 'ka nyran siadɩ 'ka cin yei, ɛn te bɔɛ "blɩdɩ a 'ka yei, ɛn te "srɔn wʋdɩ a 'ka yei, ɛn te ka "we 'ka cin man -wlidɩ, ɛn te 'ka 'fli "siala -dandan 'ka cin man, ɛn te ka'a ble 'ka cin yei "dɩ.
\v 21 Ɛn "nyian bɛ "klan a 'an 'ji 'nan, -te an 'lʋ bɛ, Bali -taa -a drɛlɛ -e 'yra 'e 'an 'tɛ "nyian 'cee "wɛan. Ɛn 'an 'ta -taa "drɛlɛ -trɔdrɔ minnun nɛn o 'wɩ 'wlidɩ drɛ 'e tɛdɛ, ɛn wa'a tian 'silɛ -a drɛdɩ man dɩɛ -wee "wɛan. An ya "vale 'o 'si 'wɩ pɛɛnɔn nɛn e min "tri -tɔa Bali 'lɛ bɛ -a drɛdɩ man. Ɛn an ya "vale 'o 'si nyinnandɩ lɩ 'lee 'kɔnnɛn -a te wa'a 'o cin 'palɛ dɩɛ -a man! Ɛn an ya "vale 'o 'si 'wɩ 'wlidɩ "drɛdɩ nɛn waa -trɔa 'o 'win -ji bɛ -a man!
\c 13
\s1 Pɔl 'wɩ 'nyranman tin 'ba Korɛnti 'nɔn lɛ
\p 
\v 1 'Mɛn 'lʋdɩ 'ka 'va bɛ -a yaagazan nɛn an "ta -a -si "siala 'gʋ. Kaa -tɔa 'nan, wa'a fɔa -tʋwli -e 'o -klan "dɩ.
\v 2 -Yee "wɛan 'bɛ nɛn an ya tian 'ka man -kɔɔbli 'gʋɛ, 'wɩ nɛn maan 'vɩ te 'an 'cɛin "flizan 'lʋ 'ka 'va nun bɛ, maan -fɔa "nyian "ji minnun nɛn o 'wɩ 'wlidɩ drɛ 'e tɛdɛ bɛ, -wlɛ. Ɛn e ya "nyian min pɛɛnɔn 'le vɛ -a. 'Wɩ zɩɛ -nyrɛn 'nan, -te an 'lʋ bɛ, an 'wɩ tin "baa 'e 'plɛblɛ da, ma'an 'wɩ 'cɛa "fo "dɩ.
\v 3 Kɔɔ ka ya "vale 'an -ci -kɔɔn 'cɛɛ 'nan Crizi -ciala 'an 'va ɛn e 'wɩ tin "baa. Crizi a 'ka 'va 'yee 'plɛblɛ 'a, kaa -tɔa zɩ. Ɛn kaa -tɔa "nyian 'nan, e 'ka min "blɛblɛ -a dɩ.
\v 4 O Crizi pɛin yiba "plan da "le min "blɛblɛ -le 'wɩ 'zʋ, ɛn e -ka. 'Wɩ 'kpa, 'pian 'bɛ nɛn 'gʋɛ -a yiɛ a "man Bali -le 'plɛblɛ 'le "wɛan. 'Wɩ 'tʋwli zɩɛ e ya 'kʋe vɛ -a. Kʋ drɛ min "blɛblɛ -a 'kʋ 'vale Crizi -a. 'Pian -te kʋ 'bɔla 'ka 'va bɛ, ka -taa -a -tɔlɛ 'nan 'plɛblɛ a 'kʋ 'lɔ. Kɔɔ Bali -le 'plɛblɛ a -maan, ɛn 'belidɩ a 'kʋ 'lɔ 'kʋ 'vale Crizi -a.
\p 
\v 5 'Ka 'cee yi -tɛradɩ Zozi da -nanjɛn! Ɛn 'ka 'fli 'nanjɛn 'ka 'bɔ 'a, -e 'ka -tɔ! 'Ka 'nanjɛn -e 'ka -kɔnnɛn "yɩ 'nan, 'ka 'vale Zozi Crizi -a ka ya min -tʋwli "a. -Te ka'a yɩlɛ zɩ dɩɛ, te 'cee yi -tɛradɩ Zozi da a 'wɩ "tun "a.
\v 6 -A -cin a 'an 'ji 'nan, ka -taa -a -tɔlɛ 'nan 'kʋ 'kʋe vɛ -ci kɔɔn.
\p 
\v 7 Kʋ Bali trʋ "baa 'nan, te 'ka 'wɩ 'wlidɩ "tʋwli "drɛ dɩ. 'Kʋe tin 'nɔnnɔn "cɛɛ kʋ'a -wɛɛman 'wɩ zɩɛ -a -ji dɩ. 'Pian kʋa -wɛɛman 'nan, 'ka 'wɩ "yi "drɛ. Ɛn -te minnun 'ka 'kʋ 'siala min -a dɩɛ, "kʋɛ ye 'wɩ "tun "a.
\v 8 Maan ve 'cɛɛ 'nan, Bali -le 'wɩ tɩglɩ bɛ, kʋ'a 'kɔlaman -e 'kʋ 'si -tɔ -yrɔ "dɩ. 'Pian 'wɩ nɛn yaa 'vɩ bɛ, -a 'bɔ nɛn kʋa dra.
\v 9 -Yee "wɛan -te kʋ ya Bali -le 'wɩ 'ji "blɛblɛ ɛn ka ya 'ka 'tɔdɩ 'plɛblɛ bɛ, 'kʋ 'ci a 'e "nrandɩ. 'Wɩ nɛn kʋa laabo Bali lɔ bɛ, -nyrɛn zɩɛ. 'Nan 'ka 'li 'ka da -e 'ka -sɔɔnla -si tɩglɩ da Bali -sru.
\p 
\v 10 An ya tian 'ka man -kɔɔbli ɛn an 'fluba 'gʋɛ -a crɛn -tɛ 'cɛɛ. Maan drɛ zɩɛ 'nan -e -te an 'lʋ bɛ, 'an vɩlɛ 'an 'wɩ tin "baa 'cɛɛ 'e 'plɛblɛ da dɩ. Maan ve 'cɛɛ 'nan Minsan -a 'plɛblɛ 'nɔn 'mɛn. 'Pian ya'a -nɔnlɛ 'nan -e 'an 'ka fuila "man "dɩ, yaa -nɔn 'nan -e 'an 'pa 'ka 'va.
\p 
\v 11 'An "bʋɩ Zozinɔn, maan 'le -sɛanla -a vɩdɩ -a 'cɛɛ 'nan, 'ka 'ci 'e 'kɔn 'e "nrandɩ! Ɛn 'ka 'li 'ka da -e 'ka -sɔɔnla -si tɩglɩ da Bali -sru! Ɛn 'wɩnun nɛn maan 'vɩ 'cɛɛ bɛ 'ka 'sia 'wɩ 'a! Ɛn 'ka cin "koe "tɔ 'ka da! Ɛn 'ka 'ci "nrɔn 'wɩ 'tʋwli "da! Ɛn 'ka yei 'e 'kɔn 'e 'sɛndɩ 'e cin va! 'Ka drɛ zɩɛ -e Bali nɛn e min ye "yi ɛn e -fʋdɩ -trɔɔ -nɔan "min lɛ bɛ, 'e 'kɔn 'ka 'va.
\s1 Pɔl -a 'le 'sran 'tɔ bʋdɩ -a
\p 
\v 12 'Ka Zozinɔn pɛɛnɔn 'tɔ bʋ -atu -tɛdɩ -a o man! Minnun pɛɛnɔn nɛn o drɛ Bali -le vɛ -a 'kʋ 'va 'gʋɛ, o 'ka 'tɔ bo.
\p 
\v 13 -Kaa san Zozi Crizi -le "yi 'e 'kɔn 'ka pɛɛnɔn 'va! Ɛn -kaa "tɩ Bali -le min yɩdɩ "yi 'e 'kɔn 'ka pɛɛnɔn 'va! Ɛn 'ka 'vale Bali lei 'saun 'a, 'ka yei 'e 'kɔn 'e 'sɛndɩ 'e cin va!
