\c 5
\s1 Expelling those who were ritually impure
\p 
\v 1 \w Yahweh|strong="H3068"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w*,
\v 2 “\w Tell|strong="H3605"\w* \w this|strong="H3478"\w* \w to|strong="H3478"\w* \w the|strong="H3605"\w* Israeli \w people|strong="H1121"\w*: ‘\w You|strong="H6680"\w* \w must|strong="H1121"\w* \w send|strong="H7971"\w* \w away|strong="H7971"\w* \w from|strong="H4480"\w* \w your|strong="H3605"\w* ◄\w camp|strong="H4264"\w*/area \w where|strong="H4480"\w* \w you|strong="H6680"\w* \w have|strong="H1121"\w* \w your|strong="H3605"\w* \w tents|strong="H4264"\w*► \w any|strong="H3605"\w* \w man|strong="H1121"\w* \w or|strong="H1121"\w* \w woman|strong="H2931"\w* \w who|strong="H3605"\w* \w has|strong="H3478"\w* leprosy \w and|strong="H1121"\w* \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* \w has|strong="H3478"\w* \w a|strong="H3068"\w* \w discharge|strong="H2100"\w* \add of some fluid from his body\add*, \w and|strong="H1121"\w* \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* \w has|strong="H3478"\w* become unacceptable \w to|strong="H3478"\w* \w God|strong="H7971"\w* \w because|strong="H4480"\w* \w of|strong="H1121"\w* \add having touched\add* \w a|strong="H3068"\w* \w corpse|strong="H5315"\w*.
\v 3 \w Send|strong="H7971"\w* \w them|strong="H7971"\w* \w away|strong="H7971"\w* \w from|strong="H7971"\w* \w there|strong="H5704"\w* \w in|strong="H7931"\w* order \w that|strong="H5704"\w* \w they|strong="H3808"\w* \w will|strong="H3808"\w* \w not|strong="H3808"\w* \add touch people in the camp area\add* \w where|strong="H3808"\w* \w I|strong="H5704"\w* \w live|strong="H7931"\w* \w among|strong="H8432"\w* \w you|strong="H7971"\w* \w and|strong="H7971"\w* cause \w them|strong="H7971"\w* \w to|strong="H5704"\w* \w become|strong="H2930"\w* unacceptable \w to|strong="H5704"\w* \w me|strong="H7971"\w*.’”
\v 4 \w So|strong="H3651"\w* \add Moses/I told that to the Israeli people, and\add* \w the|strong="H6213"\w* Israeli \w people|strong="H1121"\w* obeyed \w what|strong="H6213"\w* \w Yahweh|strong="H3068"\w* \w commanded|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H7971"\w*.
\s1 Paying for committing crimes
\p 
\v 5 \w Yahweh|strong="H3068"\w* \w also|strong="H3068"\w* \w told|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w*,
\v 6 “\w Tell|strong="H1696"\w* \w this|strong="H6213"\w* \w to|strong="H1696"\w* \w the|strong="H3605"\w* Israeli \w people|strong="H1121"\w*: ‘\w If|strong="H3588"\w* \w someone|strong="H5315"\w* ◄\w commits|strong="H6213"\w* \w a|strong="H3068"\w* crime \w against|strong="H1696"\w*/\w does|strong="H6213"\w* \w something|strong="H3605"\w* wrong \w to|strong="H1696"\w*► another \w person|strong="H5315"\w*, \add I consider that\add* \w that|strong="H3588"\w* \w person|strong="H5315"\w* \w has|strong="H3068"\w* \w done|strong="H6213"\w* wrong \w to|strong="H1696"\w* \w me|strong="H5315"\w*.
\v 7 \w That|strong="H5414"\w* person must \w confess|strong="H3034"\w* \w that|strong="H5414"\w* \w he|strong="H6213"\w* \w or|strong="H7218"\w* \w she|strong="H5921"\w* \w is|strong="H7218"\w* guilty, \w and|strong="H7725"\w* \w he|strong="H6213"\w* \w or|strong="H7218"\w* \w she|strong="H5921"\w* must \w pay|strong="H5414"\w* \w to|strong="H7725"\w* \w the|strong="H5921"\w* person \w to|strong="H7725"\w* whom wrong \w was|strong="H7218"\w* \w done|strong="H6213"\w* \add what others consider to be a suitable/proper payment\add* \w for|strong="H5921"\w* \w what|strong="H6213"\w* \w he|strong="H6213"\w* \w has|strong="H6213"\w* \w done|strong="H6213"\w*, \w and|strong="H7725"\w* \w he|strong="H6213"\w* must \w pay|strong="H5414"\w* \w an|strong="H6213"\w* extra 20 percent.
\v 8 If \w the|strong="H5921"\w* person \w against|strong="H5921"\w* whom \w the|strong="H5921"\w* wrong \w was|strong="H3068"\w* done \add has died and\add* \w there|strong="H7725"\w* \w is|strong="H3068"\w* no \w relative|strong="H1350"\w* \w to|strong="H7725"\w* whom \w the|strong="H5921"\w* money \w can|strong="H3548"\w* \w be|strong="H3068"\w* \w paid|strong="H7725"\w*, \w then|strong="H7725"\w* \w the|strong="H5921"\w* money belongs \w to|strong="H7725"\w* \w me|strong="H7725"\w*, \w and|strong="H3068"\w* \w it|strong="H5921"\w* must \w be|strong="H3068"\w* \w paid|strong="H7725"\w* \w to|strong="H7725"\w* \w the|strong="H5921"\w* \w priest|strong="H3548"\w*. \w In|strong="H5921"\w* \w addition|strong="H5921"\w*, \w the|strong="H5921"\w* \w one|strong="H3068"\w* \w who|strong="H3068"\w* \w did|strong="H3068"\w* \w the|strong="H5921"\w* wrong must \w give|strong="H7725"\w* \w a|strong="H3068"\w* male sheep \w to|strong="H7725"\w* \w the|strong="H5921"\w* \w priest|strong="H3548"\w* \add to sacrifice\add* \w in|strong="H5921"\w* order \w that|strong="H3068"\w* ◄\w that|strong="H3068"\w* person’s sin \w may|strong="H3068"\w* \w be|strong="H3068"\w* \w forgiven|strong="H3722"\w*/\w I|strong="H5921"\w* \w can|strong="H3548"\w* \w forgive|strong="H3722"\w* \w that|strong="H3068"\w* person \w for|strong="H5921"\w* \w his|strong="H3068"\w* sin►.
\v 9 \w All|strong="H3605"\w* \w the|strong="H3605"\w* \w sacred|strong="H6944"\w* \w offerings|strong="H8641"\w* \w that|strong="H3605"\w* \w the|strong="H3605"\w* Israelis \w bring|strong="H7126"\w* \w to|strong="H3478"\w* \w the|strong="H3605"\w* \w priest|strong="H3548"\w* \w belong|strong="H1961"\w* \w to|strong="H3478"\w* \w the|strong="H3605"\w* \w priest|strong="H3548"\w*.
\v 10 \w The|strong="H5414"\w* \w priest|strong="H3548"\w* \w can|strong="H3548"\w* \w keep|strong="H1961"\w* \w those|strong="H1961"\w* \w gifts|strong="H6944"\w*.’”
\s1 Suspecting a wife of committing adultery
\p 
\v 11 \w Yahweh|strong="H3068"\w* \w also|strong="H3068"\w* \w said|strong="H1696"\w* \w this|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w*:
\v 12 “\w Tell|strong="H1696"\w* \w this|strong="H1696"\w* \w to|strong="H1696"\w* \w the|strong="H3588"\w* Israeli \w people|strong="H1121"\w*: ‘\w Suppose|strong="H3588"\w* \w a|strong="H3068"\w* \w man|strong="H1121"\w* thinks \w that|strong="H3588"\w* \w his|strong="H3478"\w* \w wife|strong="H1696"\w* \w has|strong="H3478"\w* slept \w with|strong="H1696"\w* another \w man|strong="H1121"\w*,
\v 13 \w but|strong="H3808"\w* \w neither|strong="H3808"\w* \w he|strong="H1931"\w* \w nor|strong="H3808"\w* \w anyone|strong="H1931"\w* \w else|strong="H3808"\w* knows \w if|strong="H1931"\w* \w it|strong="H1931"\w* \w is|strong="H1931"\w* true \w or|strong="H3808"\w* \w not|strong="H3808"\w*, \w because|strong="H2233"\w* \w no|strong="H3808"\w* \w one|strong="H3808"\w* saw \w her|strong="H7901"\w* doing \w that|strong="H1931"\w*.
\v 14 \w But|strong="H3808"\w* \w if|strong="H7068"\w* \w the|strong="H5921"\w* woman’s husband \w is|strong="H1931"\w* \w jealous|strong="H7065"\w*, \w and|strong="H5674"\w* \w if|strong="H7068"\w* \w he|strong="H1931"\w* suspects \w that|strong="H1931"\w* \w she|strong="H1931"\w* \w has|strong="H7307"\w* \w committed|strong="H5921"\w* adultery, \w and|strong="H5674"\w* \w he|strong="H1931"\w* wants \w to|strong="H5921"\w* know whether \w that|strong="H1931"\w* \w is|strong="H1931"\w* true \w or|strong="H3808"\w* \w not|strong="H3808"\w*,
\v 15 \w he|strong="H1931"\w* \w should|strong="H3588"\w* \w take|strong="H5414"\w* \w his|strong="H5414"\w* wife \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w priest|strong="H3548"\w*. \w He|strong="H1931"\w* \w must|strong="H3808"\w* \w take|strong="H5414"\w* \w along|strong="H5921"\w* \w as|strong="H3588"\w* \w an|strong="H5414"\w* \w offering|strong="H4503"\w* \w two|strong="H3808"\w* quarts/liters \w of|strong="H5921"\w* \w barley|strong="H8184"\w* \w flour|strong="H7058"\w*. \w The|strong="H5921"\w* \w priest|strong="H3548"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* \w pour|strong="H3332"\w* \add olive\add* \w oil|strong="H8081"\w* \w or|strong="H3808"\w* \w incense|strong="H3828"\w* \w on|strong="H5921"\w* \w it|strong="H5414"\w*, \w because|strong="H3588"\w* \w this|strong="H1931"\w* \w is|strong="H1931"\w* \w an|strong="H5414"\w* \w offering|strong="H4503"\w* \w that|strong="H3588"\w* \w the|strong="H5921"\w* man \w has|strong="H3588"\w* \w brought|strong="H5414"\w* \w because|strong="H3588"\w* \w he|strong="H1931"\w* ◄\w is|strong="H1931"\w* jealous/wants \w his|strong="H5414"\w* wife \w to|strong="H5921"\w* sleep \w only|strong="H3588"\w* \w with|strong="H5921"\w* \w him|strong="H5414"\w*►. \w It|strong="H5414"\w* \w is|strong="H1931"\w* \w an|strong="H5414"\w* \w offering|strong="H4503"\w* \w to|strong="H5921"\w* \w find|strong="H5414"\w* \w out|strong="H3332"\w* \w if|strong="H3588"\w* \w she|strong="H1931"\w* \w is|strong="H1931"\w* \w guilty|strong="H5771"\w* \w or|strong="H3808"\w* \w not|strong="H3808"\w*. \add Neither olive oil nor incense should be used because are associated with joy and this is not a time for joy.\add*
\p 
\v 16 \w The|strong="H6440"\w* \w priest|strong="H3548"\w* must tell \w the|strong="H6440"\w* woman \w to|strong="H3068"\w* \w stand|strong="H5975"\w* \add in front of the altar\add* \w in|strong="H3068"\w* \w my|strong="H3068"\w* \w presence|strong="H6440"\w*.
\v 17 \w He|strong="H4480"\w* \w must|strong="H3947"\w* \w put|strong="H5414"\w* \w some|strong="H4480"\w* sacred \w water|strong="H4325"\w* \w in|strong="H5414"\w* \w a|strong="H3068"\w* \w clay|strong="H2789"\w* \w jar|strong="H3627"\w*, \w and|strong="H3548"\w* \w then|strong="H1961"\w* \w he|strong="H4480"\w* \w must|strong="H3947"\w* \w put|strong="H5414"\w* \w some|strong="H4480"\w* \w dirt|strong="H6083"\w* \w from|strong="H4480"\w* \w the|strong="H5414"\w* \w floor|strong="H7172"\w* \w of|strong="H3627"\w* \w the|strong="H5414"\w* Sacred Tent \w into|strong="H3947"\w* \w the|strong="H5414"\w* \w water|strong="H4325"\w*.
\v 18 \w He|strong="H1931"\w* must untie/unfasten \w the|strong="H6440"\w* woman’s \w hair|strong="H7218"\w*. \w Then|strong="H1961"\w* \w he|strong="H1931"\w* must \w put|strong="H5414"\w* \w in|strong="H5921"\w* \w her|strong="H5414"\w* \w hands|strong="H3027"\w* \w the|strong="H6440"\w* grain \w that|strong="H1931"\w* \w her|strong="H5414"\w* jealous husband \w is|strong="H3068"\w* \w offering|strong="H4503"\w* \w to|strong="H3068"\w* determine whether \w she|strong="H1931"\w* \w has|strong="H3068"\w* \w committed|strong="H5414"\w* adultery \w or|strong="H7218"\w* \w not|strong="H5414"\w*. \w The|strong="H6440"\w* \w priest|strong="H3548"\w* must \w hold|strong="H5414"\w* \add the bowl that contains\add* \w bitter|strong="H4751"\w* \w water|strong="H4325"\w* \w that|strong="H1931"\w* \w will|strong="H3068"\w* \w cause|strong="H5414"\w* ◄\w the|strong="H6440"\w* woman \w to|strong="H3068"\w* \w be|strong="H1961"\w* cursed/bad \w things|strong="H7218"\w* \w to|strong="H3068"\w* \w happen|strong="H1961"\w* \w to|strong="H3068"\w* \w the|strong="H6440"\w* woman► \add if she is guilty\add*.
\v 19 \w The|strong="H8478"\w* \w priest|strong="H3548"\w* \w must|strong="H3808"\w* require \w her|strong="H7901"\w* \w to|strong="H4325"\w* \w solemnly|strong="H7650"\w* declare \add that she will tell the truth\add*. \w Then|strong="H3548"\w* \w he|strong="H3808"\w* \w must|strong="H3808"\w* say \w to|strong="H4325"\w* \w her|strong="H7901"\w*, “\w Has|strong="H3548"\w* \w another|strong="H3808"\w* man \w had|strong="H3548"\w* \w sex|strong="H7901"\w* [EUP] \w with|strong="H7901"\w* \w you|strong="H3808"\w*? \w Have|strong="H3548"\w* \w you|strong="H3808"\w* faithfully \add slept only with your husband\add* \w or|strong="H3808"\w* \w not|strong="H3808"\w*? If \w you|strong="H3808"\w* \w have|strong="H3548"\w* \w not|strong="H3808"\w* \w slept|strong="H7901"\w* \w with|strong="H7901"\w* \w another|strong="H3808"\w* man, \w nothing|strong="H3808"\w* bad \w will|strong="H3808"\w* happen \w to|strong="H4325"\w* \w you|strong="H3808"\w* if \w you|strong="H3808"\w* drink \w the|strong="H8478"\w* \w water|strong="H4325"\w*.
\v 20 \w But|strong="H3588"\w* \w if|strong="H3588"\w* \w you|strong="H3588"\w* \w have|strong="H5414"\w* \w had|strong="H3588"\w* sex \w with|strong="H7903"\w* another man, \add Yahweh will curse you\add*.
\v 21-22 Your womb will shrivel up and your stomach will swell up. You will never be able to give birth to children, and as \w a|strong="H3068"\w* result, everyone will curse you and avoid you. If you have committed adultery, \add when you drink\add* this water, that is what will happen to you.” Then the woman must answer, “\add If I am guilty\add*, I will not object if that happens.”
\p 
\v 23 ‘\w Then|strong="H3548"\w* \w the|strong="H3548"\w* \w priest|strong="H3548"\w* must \w write|strong="H3789"\w* \add with ink\add* \w on|strong="H3789"\w* \w a|strong="H3068"\w* small \w scroll|strong="H5612"\w* \w these|strong="H3789"\w* ◄curses/bad things \w that|strong="H3548"\w* \w will|strong="H4325"\w* happen \w to|strong="H4325"\w* \w her|strong="H4229"\w* if she \w is|strong="H4325"\w* guilty► \add and then wash the ink off into the bitter water\add*.
\v 24-25 The priest must take from her the offering of barley flour \add that she is holding\add*, and lift it up to dedicate it to me. Then he must put it on the altar
\v 26 \w and|strong="H3548"\w* \w burn|strong="H6999"\w* \w part|strong="H4480"\w* \w of|strong="H4325"\w* \w it|strong="H4325"\w* \w as|strong="H4196"\w* \w a|strong="H3068"\w* \w sacrifice|strong="H4503"\w*. \w Then|strong="H3548"\w* \w the|strong="H4480"\w* woman must \w drink|strong="H8248"\w* \w the|strong="H4480"\w* bitter \w water|strong="H4325"\w*.
\v 27 \w If|strong="H1961"\w* \w the|strong="H1961"\w* woman \w has|strong="H1961"\w* \w committed|strong="H4603"\w* adultery, \w the|strong="H1961"\w* \w water|strong="H4325"\w* \w will|strong="H1961"\w* \w cause|strong="H5971"\w* \w her|strong="H7130"\w* \w to|strong="H1961"\w* \w suffer|strong="H1961"\w* \w greatly|strong="H4751"\w*. \w Her|strong="H7130"\w* stomach \w will|strong="H1961"\w* \w swell|strong="H6638"\w* \w up|strong="H1961"\w* \w and|strong="H5971"\w* \w her|strong="H7130"\w* womb \w will|strong="H1961"\w* shrink, \add and she will be unable to give birth to children\add*. \w And|strong="H5971"\w* \w then|strong="H1961"\w* \w her|strong="H7130"\w* ◄relatives/fellow Israelis► \w will|strong="H1961"\w* curse \w her|strong="H7130"\w*.
\v 28 \w But|strong="H3808"\w* \w if|strong="H1931"\w* \w she|strong="H1931"\w* ◄\w is|strong="H1931"\w* \w innocent|strong="H5352"\w*/\w has|strong="H1931"\w* \w not|strong="H3808"\w* committed adultery►, \w her|strong="H1931"\w* body \w will|strong="H3808"\w* \w not|strong="H3808"\w* \w be|strong="H3808"\w* harmed, \w and|strong="H2233"\w* \w she|strong="H1931"\w* \w will|strong="H3808"\w* still \w be|strong="H3808"\w* able \w to|strong="H3808"\w* give \w birth|strong="H2232"\w* \w to|strong="H3808"\w* \w children|strong="H2233"\w*.
\p 
\v 29 ‘\w That|strong="H2063"\w* \w is|strong="H8451"\w* \w the|strong="H8478"\w* ritual \w that|strong="H2063"\w* must be performed \w when|strong="H7068"\w* \w a|strong="H3068"\w* woman who \w is|strong="H8451"\w* married \w has|strong="H7068"\w* \w been|strong="H2930"\w* unfaithful \w to|strong="H8451"\w* \w her|strong="H2063"\w* husband,
\v 30 \w or|strong="H3068"\w* \w when|strong="H6213"\w* \w a|strong="H3068"\w* \w man|strong="H3605"\w* \w is|strong="H3068"\w* \w jealous|strong="H7065"\w* \w and|strong="H3068"\w* suspects \w that|strong="H3605"\w* \w his|strong="H3605"\w* wife \add has had sex with another man\add*. \w The|strong="H3605"\w* \w priest|strong="H3548"\w* must \w tell|strong="H3605"\w* \w that|strong="H3605"\w* woman \w to|strong="H3068"\w* \w stand|strong="H5975"\w* \add at the altar\add* \w in|strong="H5921"\w* \w my|strong="H3605"\w* \w presence|strong="H6440"\w* \w and|strong="H3068"\w* \w obey|strong="H6213"\w* \w these|strong="H6213"\w* \w instructions|strong="H8451"\w*.
\v 31 Even \w if|strong="H1931"\w* \w the|strong="H5375"\w* woman \w has|strong="H5771"\w* \w not|strong="H5375"\w* done what \w the|strong="H5375"\w* husband suspected, \w he|strong="H1931"\w* \w will|strong="H1931"\w* \w not|strong="H5375"\w* \w be|strong="H5375"\w* punished [MTY] \w for|strong="H5771"\w* doing something \w wrong|strong="H5771"\w* \add by bringing his wife to the priest\add*. \w But|strong="H1931"\w* \w if|strong="H1931"\w* \w his|strong="H5375"\w* wife \w is|strong="H1931"\w* \w guilty|strong="H5771"\w*, \w she|strong="H1931"\w* \w will|strong="H1931"\w* \w suffer|strong="H5375"\w* as \w a|strong="H3068"\w* result.’”
\c 6
\s1 Rules about Nazir-men
\p 
\v 1 \w Yahweh|strong="H3068"\w* \w also|strong="H3068"\w* \w said|strong="H1696"\w* \w this|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w*:
\v 2 “\w Tell|strong="H1696"\w* \w this|strong="H1696"\w* \w to|strong="H1696"\w* \w the|strong="H3588"\w* Israeli \w people|strong="H1121"\w*: ‘\w If|strong="H3588"\w* \w any|strong="H1696"\w* \w of|strong="H1121"\w* \w you|strong="H3588"\w* \add wants to\add* \w make|strong="H5087"\w* \w a|strong="H3068"\w* solemn \w promise|strong="H1696"\w* \w to|strong="H1696"\w* \w dedicate|strong="H5144"\w* \w himself|strong="H3068"\w* \w to|strong="H1696"\w* belong \w to|strong="H1696"\w* \w me|strong="H1696"\w* \w in|strong="H3478"\w* \w a|strong="H3068"\w* \w special|strong="H6381"\w* way, \add after you obey these instructions\add*, \w you|strong="H3588"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* called \w a|strong="H3068"\w* Nazir-man, \add which means “dedicated man”\add*.
\v 3 \w You|strong="H3605"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* \w drink|strong="H8354"\w* \w any|strong="H3605"\w* \w wine|strong="H3196"\w* \w or|strong="H3808"\w* \w other|strong="H3605"\w* alcoholic/fermented \w drink|strong="H8354"\w*. \w You|strong="H3605"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* \w drink|strong="H8354"\w* \w any|strong="H3605"\w* \w vinegar|strong="H2558"\w* \w made|strong="H3605"\w* \w from|strong="H3196"\w* \w wine|strong="H3196"\w* \w or|strong="H3808"\w* \w from|strong="H3196"\w* \w any|strong="H3605"\w* \w other|strong="H3605"\w* alcoholic/fermented \w drink|strong="H8354"\w*. \w You|strong="H3605"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* \w drink|strong="H8354"\w* \w grape|strong="H6025"\w* \w juice|strong="H4952"\w* \w or|strong="H3808"\w* eat \w grapes|strong="H6025"\w* \w or|strong="H3808"\w* raisins.
\v 4 \w You|strong="H3605"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* eat \w anything|strong="H3605"\w* \w that|strong="H3605"\w* \w comes|strong="H3117"\w* \w from|strong="H3117"\w* grapevines, \w not|strong="H3808"\w* \w even|strong="H5704"\w* \w the|strong="H3605"\w* skins \w or|strong="H3808"\w* \w seeds|strong="H2785"\w* \w of|strong="H3117"\w* grapes, \w during|strong="H3117"\w* \w the|strong="H3605"\w* \w time|strong="H3117"\w* \w that|strong="H3605"\w* \w you|strong="H3605"\w* \w are|strong="H3117"\w* \w a|strong="H3068"\w* Nazir-man.
\p 
\v 5 ‘\w Even|strong="H5704"\w* \w your|strong="H3068"\w* \w hair|strong="H8181"\w* \w will|strong="H3068"\w* \w be|strong="H1961"\w* \w dedicated|strong="H5145"\w* \w to|strong="H5704"\w* \w me|strong="H5921"\w* \w during|strong="H3117"\w* \w the|strong="H3605"\w* \w time|strong="H3117"\w* \w that|strong="H3605"\w* \w you|strong="H3605"\w* area Nazir-man, \w so|strong="H1961"\w* \w you|strong="H3605"\w* \w must|strong="H3808"\w* \w never|strong="H3808"\w* allow \w anyone|strong="H3605"\w* \w to|strong="H5704"\w* cut \w your|strong="H3068"\w* \w hair|strong="H8181"\w*. \w Until|strong="H5704"\w* \w the|strong="H3605"\w* \w time|strong="H3117"\w* \w that|strong="H3605"\w* \w your|strong="H3068"\w* solemn \w promise|strong="H3068"\w* \w to|strong="H5704"\w* \w dedicate|strong="H5144"\w* \w yourself|strong="H5921"\w* \w to|strong="H5704"\w* \w me|strong="H5921"\w* \w is|strong="H3068"\w* \w ended|strong="H1961"\w*, \w you|strong="H3605"\w* \w must|strong="H3808"\w* allow \w your|strong="H3068"\w* \w hair|strong="H8181"\w* \w to|strong="H5704"\w* \w grow|strong="H1431"\w* \w long|strong="H5704"\w*.
\v 6 \w And|strong="H3068"\w* \w you|strong="H3605"\w* \w must|strong="H4191"\w* \w not|strong="H3808"\w* \w go|strong="H3068"\w* \w near|strong="H5921"\w* \w a|strong="H3068"\w* \w corpse|strong="H5315"\w* \w during|strong="H3117"\w* \w the|strong="H3605"\w* \w time|strong="H3117"\w* \w that|strong="H3605"\w* \w you|strong="H3605"\w* \w are|strong="H3117"\w* \w a|strong="H3068"\w* Nazir-man.
\v 7 \w Even|strong="H3588"\w* \w if|strong="H3588"\w* \w the|strong="H5921"\w* person \w who|strong="H3588"\w* \w died|strong="H4194"\w* \w is|strong="H7218"\w* \w your|strong="H5921"\w* father \w or|strong="H3808"\w* \w your|strong="H5921"\w* mother \w or|strong="H3808"\w* \w your|strong="H5921"\w* brother \w or|strong="H3808"\w* \w your|strong="H5921"\w* sister, \w you|strong="H3588"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* cause \w yourself|strong="H5921"\w* \w to|strong="H5921"\w* \w become|strong="H2930"\w* unacceptable \w to|strong="H5921"\w* \w me|strong="H5921"\w* \add by coming close to the corpse\add*. \w Your|strong="H5921"\w* \w long|strong="H5921"\w* \w hair|strong="H7218"\w* [MTY] shows \w that|strong="H3588"\w* \w you|strong="H3588"\w* belong \w to|strong="H5921"\w* \w me|strong="H5921"\w* \w in|strong="H5921"\w* \w a|strong="H3068"\w* special \w way|strong="H5921"\w*, \w so|strong="H3808"\w* \w you|strong="H3588"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* cut \w your|strong="H5921"\w* \w hair|strong="H7218"\w*.
\v 8 \w You|strong="H3605"\w* \w are|strong="H3117"\w* \w required|strong="H3117"\w* \w to|strong="H3068"\w* keep doing \w this|strong="H1931"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w time|strong="H3117"\w* \w that|strong="H3605"\w* \w you|strong="H3605"\w* \w are|strong="H3117"\w* \w dedicated|strong="H5145"\w* \w to|strong="H3068"\w* \w me|strong="H3117"\w* \w in|strong="H3068"\w* \w this|strong="H1931"\w* special \w way|strong="H3605"\w*.
\p 
\v 9 ‘\w If|strong="H3588"\w* \w anyone|strong="H3588"\w* \w dies|strong="H4191"\w* \w very|strong="H6621"\w* \w suddenly|strong="H6597"\w* \w when|strong="H3588"\w* \w he|strong="H3588"\w* \w is|strong="H3117"\w* \w near|strong="H5921"\w* \w you|strong="H3588"\w*, \w then|strong="H3588"\w* \w your|strong="H5921"\w* \w hair|strong="H7218"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w have|strong="H3117"\w* \w dedicated|strong="H5145"\w* \w to|strong="H4191"\w* \w me|strong="H5921"\w* \w is|strong="H3117"\w* \w no|strong="H7218"\w* longer sacred. \w So|strong="H4191"\w* \w you|strong="H3588"\w* \w must|strong="H4191"\w* wait \w seven|strong="H7637"\w* \w days|strong="H3117"\w* \w and|strong="H3117"\w* \w then|strong="H3588"\w* \w shave|strong="H1548"\w* \w it|strong="H5921"\w* \w all|strong="H3117"\w* \w off|strong="H5921"\w*. \w Then|strong="H3588"\w* \w you|strong="H3588"\w* \w must|strong="H4191"\w* perform \w a|strong="H3068"\w* special ritual \w to|strong="H4191"\w* cause \w yourself|strong="H5921"\w* \w to|strong="H4191"\w* \w become|strong="H2930"\w* acceptable \w to|strong="H4191"\w* \w me|strong="H5921"\w* again.
\v 10 \w The|strong="H3117"\w* next \w day|strong="H3117"\w* \w you|strong="H3117"\w* \w must|strong="H1121"\w* bring \w two|strong="H8147"\w* \w doves|strong="H3123"\w* \w or|strong="H3117"\w* \w two|strong="H8147"\w* \w young|strong="H1121"\w* \w pigeons|strong="H3123"\w* \w to|strong="H3117"\w* \w the|strong="H3117"\w* \w priest|strong="H3548"\w* \w at|strong="H3117"\w* \w the|strong="H3117"\w* \w entrance|strong="H6607"\w* \w of|strong="H1121"\w* \w the|strong="H3117"\w* Sacred Tent.
\v 11 ‘\w The|strong="H5921"\w* \w priest|strong="H3548"\w* \w must|strong="H5315"\w* \add kill the birds and\add* \w offer|strong="H6213"\w* \w them|strong="H5921"\w* \w as|strong="H3117"\w* \w sacrifices|strong="H5930"\w*. \w One|strong="H1931"\w* \w of|strong="H3117"\w* \w them|strong="H5921"\w* \w will|strong="H5315"\w* \w be|strong="H5315"\w* \w an|strong="H6213"\w* \w offering|strong="H5930"\w* \w to|strong="H5921"\w* enable \w me|strong="H5315"\w* \w to|strong="H5921"\w* \w forgive|strong="H3722"\w* \w you|strong="H5921"\w* \w for|strong="H5921"\w* \w the|strong="H5921"\w* \w sins|strong="H2403"\w* \w you|strong="H5921"\w* \w have|strong="H3548"\w* \w committed|strong="H6213"\w*, \w and|strong="H3117"\w* \w the|strong="H5921"\w* other \w will|strong="H5315"\w* \w be|strong="H5315"\w* \w an|strong="H6213"\w* \w offering|strong="H5930"\w* \w that|strong="H3117"\w* \w is|strong="H1931"\w* burned completely \w to|strong="H5921"\w* please \w me|strong="H5315"\w*. \add After the priest burns them on the altar\add*, \w I|strong="H3117"\w* \w will|strong="H5315"\w* \w forgive|strong="H3722"\w* \w you|strong="H5921"\w* \w for|strong="H5921"\w* \w having|strong="H5315"\w* come close \w to|strong="H5921"\w* \w a|strong="H3068"\w* \w corpse|strong="H5315"\w*, \w and|strong="H3117"\w* \add when\add* \w your|strong="H5921"\w* \w hair|strong="H7218"\w* \add grows again it\add* \w will|strong="H5315"\w* \w be|strong="H5315"\w* \w dedicated|strong="H6942"\w* \w to|strong="H5921"\w* \w me|strong="H5315"\w* again.
\v 12 \w The|strong="H3588"\w* amount \w of|strong="H1121"\w* \w time|strong="H3117"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w were|strong="H1121"\w* \w set|strong="H7223"\w* apart \w for|strong="H3588"\w* \w me|strong="H1121"\w* \w the|strong="H3588"\w* \w previous|strong="H7223"\w* \w time|strong="H3117"\w* \w does|strong="H3068"\w* \w not|strong="H3588"\w* \w count|strong="H8141"\w*, \w because|strong="H3588"\w* \w you|strong="H3588"\w* \w had|strong="H3068"\w* \w become|strong="H2930"\w* unacceptable \w to|strong="H3068"\w* \w me|strong="H1121"\w* \add by coming close to a corpse\add* \w during|strong="H3117"\w* \w the|strong="H3588"\w* \w time|strong="H3117"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* \w were|strong="H1121"\w* \w a|strong="H3068"\w* Nazir-man. \w So|strong="H3588"\w* \w you|strong="H3588"\w* \w must|strong="H1121"\w* again \w make|strong="H2930"\w* \w a|strong="H3068"\w* solemn \w promise|strong="H3068"\w* \w to|strong="H3068"\w* \w dedicate|strong="H5144"\w* \w yourself|strong="H5307"\w* \w to|strong="H3068"\w* \w me|strong="H1121"\w* \w for|strong="H3588"\w* \w the|strong="H3588"\w* \w entire|strong="H3117"\w* amount \w of|strong="H1121"\w* \w time|strong="H3117"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* indicated \w the|strong="H3588"\w* \w previous|strong="H7223"\w* \w time|strong="H3117"\w*. \w And|strong="H1121"\w* \w you|strong="H3588"\w* \w must|strong="H1121"\w* \w also|strong="H3068"\w* sacrifice \w a|strong="H3068"\w* one-year-old \w lamb|strong="H3532"\w* \w for|strong="H3588"\w* \w not|strong="H3588"\w* doing \w what|strong="H3588"\w* \w you|strong="H3588"\w* \w were|strong="H1121"\w* \w required|strong="H3117"\w* \w to|strong="H3068"\w* \w do|strong="H3068"\w*.
\p 
