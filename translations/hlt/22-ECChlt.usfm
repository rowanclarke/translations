\c 8  
\s1 Cueihnah Sarhi  
\p
\v 1 \w Unim|strong="H4310"\w* hlang \w cueih|strong="H2450"\w* \w bangla|strong="H9995"\w* aka om? \w Olka|strong="H1697"\w* te \w thuingaihnah|strong="H6592"\w* aka \w ming|strong="H3045"\w* te \w unim|strong="H4310"\w*? \w Hlang|strong="H0120"\w* he \w cueihnah|strong="H2451"\w* loh \w a|strong="H9909"\w* \w maelhmai|strong="H6440"\w* a \w sae|strong="H0215"\w* sak \w tih|strong="H9999"\w* \w a|strong="H9909"\w* \w maelhmai|strong="H6440"\w* khaw \w sarhi|strong="H5797"\w* a \w tho|strong="H8132"\w*.  
\v 2 \w Kamah|strong="H0589"\w* \w manghai|strong="H4428"\w* \w ka|strong="H6310"\w* dongkah he \w Pathen|strong="H0430"\w* \w olhlo|strong="H7621"\w* dongkah \w dumlai|strong="H1700"\w* la a om \w dongah|strong="H5921"\w* \w ngaithuen|strong="H8104"\w*.  
\v 3 \w A|strong="H9909"\w* \w mikhmuh|strong="H6440"\w* \w lamloh|strong="H4480"\w* na \w caeh|strong="H1980"\w* vaengah \w let|strong="H0926"\w* \w boeh|strong="H0408"\w*. \w Boethae|strong="H7451"\w* \w ol|strong="H1697"\w* \w dongah|strong="H9996"\w* \w pai|strong="H5975"\w* \w boeh|strong="H0408"\w*. A \w cungkuem|strong="H3605"\w* te a \w ngaih|strong="H2654"\w* \w bangla|strong="H0834"\w* a \w saii|strong="H6213"\w* bitni.  
\v 4 \w Manghai|strong="H4428"\w* \w ol|strong="H1697"\w* \w dongah|strong="H0834"\w* a \w khuet|strong="H7983"\w* om \w tih|strong="H9999"\w* \w anih|strong="H9909"\w* \w te|strong="H9997"\w* \w ulong|strong="H4310"\w*, “\w Balae|strong="H4100"\w* na \w saii|strong="H6213"\w*?” a \w ti|strong="H0559"\w* nah.   
\p
\v 5 \w Olpaek|strong="H4687"\w* aka \w tuem|strong="H8104"\w* tah \w boethae|strong="H7451"\w* \w ol|strong="H1697"\w* a \w ming|strong="H3045"\w* \w moenih|strong="H3808"\w*. Aka \w cueih|strong="H2450"\w* kah \w lungbuei|strong="H3820"\w* tah a \w tue|strong="H6256"\w* \w neh|strong="H9999"\w* \w laitloeknah|strong="H4941"\w* khaw a \w ming|strong="H3045"\w*.  
\v 6 \w Hlang|strong="H0120"\w* kah \w boethae|strong="H7451"\w* he \w amah|strong="H9909"\w* \w soah|strong="H5921"\w* \w ping|strong="H7227"\w* \w cakhaw|strong="H3588"\w* \w ngaihnah|strong="H2656"\w* \w cungkuem|strong="H3605"\w* \w ham|strong="H9997"\w* he a \w tuetang|strong="H6256"\w* \w neh|strong="H9999"\w* a \w khosing|strong="H4941"\w* \w om|strong="H3426"\w*.  
\v 7 \w Anih|strong="H9909"\w* te \w metla|strong="H4100"\w* a \w om|strong="H1961"\w* \w te|strong="H7578"\w* khaw a \w ming|strong="H3045"\w* \w moenih|strong="H0369"\w*. Te \w vanbangla|strong="H9995"\w* \w mebang|strong="H0834"\w* a \w om|strong="H1961"\w* ham khaw te \w anih|strong="H9909"\w* \w taengah|strong="H9997"\w* \w ulong|strong="H4310"\w* a \w thui|strong="H5046"\w* thai?  
\v 8 \w Khohli|strong="H7307"\w* \w te|strong="H0853"\w* \w hloh|strong="H3607"\w* \w hamla|strong="H9997"\w* \w khohli|strong="H7307"\w* \w soah|strong="H9996"\w* \w hlang|strong="H0120"\w* a \w boei|strong="H7989"\w* \w moenih|strong="H0369"\w*. \w Dueknah|strong="H4194"\w* \w khohnin|strong="H3117"\w* \w soah|strong="H9996"\w* a \w khuet|strong="H7983"\w* aka khueh khaw om \w pawh|strong="H0369"\w*. \w Caemtloeknah|strong="H4421"\w* \w khuiah|strong="H9996"\w* khaw \w paanah|strong="H4917"\w* a om \w moenih|strong="H0369"\w*. Te \w dongah|strong="H9999"\w* \w halangnah|strong="H7562"\w* loh \w a|strong="H9909"\w* \w boei|strong="H1167"\w* \w te|strong="H0853"\w* \w loeih|strong="H4422"\w* sak \w mahpawh|strong="H3808"\w*.  
\v 9 A \w cungkuem|strong="H3605"\w* \w he|strong="H2088"\w* ka \w sawt|strong="H7200"\w* \w tih|strong="H9999"\w* \w khomik|strong="H8121"\w* \w hmuikah|strong="H8478"\w* a \w saii|strong="H6213"\w* \w bibi|strong="H4639"\w* \w boeih|strong="H3605"\w* \w he|strong="H9997"\w* \w ka|strong="H9901"\w* \w lungbuei|strong="H3820"\w* ah ka \w dueh|strong="H5414"\w*. \w Hlang|strong="H0120"\w* loh \w hlang|strong="H0120"\w* \w soah|strong="H9996"\w* \w amah|strong="H9909"\w* \w kah|strong="H9997"\w* a \w yoethae|strong="H7451"\w* ham \w duela|strong="H9997"\w* a \w taemrhai|strong="H7980"\w* \w tue|strong="H6256"\w* khaw om.  
\v 10 \w Halang|strong="H7563"\w* rhoek a \w up|strong="H6912"\w* uh \w he|strong="H3651"\w* ka \w sawt|strong="H7200"\w* \w vaengah|strong="H9999"\w* \w hmuen|strong="H4725"\w* \w cim|strong="H6918"\w* \w lamloh|strong="H4480"\w* aka \w thoeng|strong="H0935"\w* \w tih|strong="H9999"\w* aka \w pongpa|strong="H1980"\w* rhoek ni. \w Tedae|strong="H9999"\w* \w te|strong="H3651"\w* bang a \w saii|strong="H6213"\w* \w nah|strong="H0834"\w* \w khopuei|strong="H5892"\w* \w ah|strong="H9996"\w* a \w hnilh|strong="H7911"\w* uh coeng. \w He|strong="H2088"\w* \w khaw|strong="H1571"\w* a \w honghi|strong="H1892"\w* coeng ni.  
\v 11 \w Khoboe|strong="H4639"\w* \w thae|strong="H7451"\w* khaw \w oltloeknah|strong="H6599"\w* \w hat|strong="H4120"\w* a \w saii|strong="H6213"\w* hae \w moenih|strong="H0369"\w*. \w Te|strong="H3651"\w* \w dongah|strong="H5921"\w* ni \w hlang|strong="H0120"\w* \w koca|strong="H1121"\w* kah \w lungbuei|strong="H3820"\w* tah \w a|strong="H9908"\w* \w khuiah|strong="H9996"\w* \w thae|strong="H7451"\w* \w saii|strong="H6213"\w* \w hamla|strong="H9997"\w* a \w hah|strong="H4390"\w*.  
\v 12 Aka \w tholh|strong="H2398"\w* \w khaw|strong="H0834"\w* \w boethae|strong="H7451"\w* \w yakhat|strong="H3967"\w* a \w saii|strong="H6213"\w* \w tih|strong="H9999"\w* \w anih|strong="H9909"\w* \w te|strong="H9997"\w* \w nguel|strong="H0748"\w* mai \w cakhaw|strong="H3588"\w* \w Pathen|strong="H0430"\w* aka \w rhih|strong="H3373"\w* tih \w a|strong="H9909"\w* \w mikhmuh|strong="H6440"\w* \w ah|strong="H9997"\w* aka \w rhih|strong="H3372"\w* \w taengah|strong="H9997"\w* ni \w hnothen|strong="H2896"\w* a \w om|strong="H1961"\w* eh \w tila|strong="H0834"\w* \w ka|strong="H0589"\w* \w ming|strong="H3045"\w*.  
