\c 9  
\s1 Contra los pueblos  
\p
\v 1 \w La|strong="H3588"\w* \w carga|strong="H4853"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* está \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* Hadrac \w y|strong="H3588"\w* llega \w a|strong="H3068"\w* \w Damasco|strong="H1834"\w* \w para|strong="H3588"\w* descansar. \w De|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w son|strong="H3588"\w* las ciudades \w de|strong="H3588"\w* Aram, \w así|strong="H3588"\w* \w como|strong="H3588"\w* \w todas|strong="H3605"\w* las \w tribus|strong="H7626"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*,  
