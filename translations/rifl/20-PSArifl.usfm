\id PSA
\h Izehhiden 
\toc1 Izehhiden 
\toc2 Izehhiden 
\toc3 Izhd. 
\mt1 Izehhiden  
\c 1
\s1 ADLIS AMEZWARU - IZEHHIDEN 1-41  
\m
\v 1 Sseɛd n weryaz,  
\m wenni war igguren  
\m di ccwar n iɛeffanen,  
\m d wenni war ibedden  
\m deg webrid n imednab,  
\m d wenni war iqqimen  
\m x řkursi n imestehzayen, \x ◘ \xo 1:1 \xt Izhd. 26:4; Awřn. 1:10, 15; 4:14, 15; 1 Kur. 15:33; Afa. 5:11\x*   
\m
\v 2 maca řefraḥet nnes  
\m aqa-tt di Ccariɛa n SIDI  
\m u ittxarreṣ di Ccariɛa nnes ass d ǧiřet. \x ◘ \xo 1:2 \xt Aɛwd. 6:6-9; 17:19; Yac. 1:8; Izhd. 119:1\x*   
\m
\v 3 Ad yiři am yict n tcejjart  
\m i ittwaẓẓun ɣar tɣezratin n waman,  
\m tenni itticen řɣiǧet nnes di řweqt nnes,  
\m afar nnes war ittiẓeɣ.  
\m Marra min ittegg, ad yiři. \f ◼ \fr 1:3 \ft \+fk tacejjart\ft  - niɣ ‘addag’ (‘iddagen’).\f*  \x ◘ \xo 1:3 \xt Irm. 17:8\x*   
\b  
\m
\v 4 War \add ttiřin\add* iɛeffanen ammu,  
\m minzi \add nitni\add* am icarfa ittawi-y-i-t usemmiḍ. \x ◘ \xo 1:4 \xt Ayub 21:18; Izhd. 35:5; Ica. 17:13; 29:5; Ḥuc. 13:3\x*   
\m
\v 5 X uya iɛeffanen war ttbeddin ca  
\m deg wass n řeḥsab,  
\m uřa d imednab di tmesmunt n imseggaden.   
\m
\v 6 Minzi SIDI issen abrid n imseggaden,  
\m \add maca\add* abrid n iɛeffanen ad ifna.   
\b  
\b  
\m  
\c 2
\m
\v 1 Mayemmi tthajen řegnus,  
\m ttxarriṣen ccuɛub di řbaṭer? \x ◘ \xo 2:1 \xt Řex. 4:25\x*   
\m
\v 2 Kkaren ijeǧiden n temmurt,  
\m ayt n bu-ṣṣulṭa mcawaren  
\m ḍidd i SIDI u ḍidd i Lmasiḥ nnes:   
\m
\v 3 ‘Ejj aneɣ ad nqess iceddiyyen nsen,  
\m ad xaneɣ nessbeɛɛed tiseɣwin nsen!’   
\b  
\m
\v 4 Wenni izeddɣen deg ujenna iḍeḥḥec,  
\m Sidi inu ad zzaysen isstehza.   
\m
\v 5 Xenni ad kidsen issiweř s weɣḍab nnes,  
\m s řḥaduq n weɣḍab nnes ad ten issiggʷed.   
\m
\v 6 “\bd Necc\bd* aqa dehneɣ Ajeǧid inu,  
\m x Ṣihyun, adrar inu iqeddsen!”   
\b  
\m
\v 7 Necc ad barrḥeɣ tikkest n wawař!  
\m SIDI inna ayi:  
\m “Cek d Mmi, ass-a jjiɣ-dd Cek! \x ◘ \xo 2:7 \xt Řex. 13:33; Ɛbr. 1:5; 5:5\x*   
\m
\v 8 Ttar zzayi  
\m u Necc ad ac wceɣ řegnus d řwart,  
\m tineggura n temmurt  
\m ad ɣarek iřint  
\m d agřa i Cek. \x ◘ \xo 2:8 \xt Izhd. 22:28; 72:8\x*   
\m
\v 9 Ad ten třebzed s yijj n weqḍib n wuzzař,  
\m ad ten tarẓid d tareẓẓit  
\m am yijj n uɣarraf n třaxt.”\x ◘ \xo 2:9 \xt Asa. 2:27; 19:15\x*   
\b  
\m
\v 10 Řexxu \add xenni\add*, a ijeǧiden,  
\m iřim d ifehhamen,  
\m tebbtem ixef nwem,  
\m a řquḍat n temmurt! \f ◼ \fr 2:10 \ft \+fk řquḍat\ft  - niɣ ‘imezurfa’.\f*   
\m
\v 11 Sexxarem i SIDI s teggʷudi,  
\m farḥem s tarjijet.   
\m
\v 12 Sudmem Mmis, ḥima Netta war iseɛɛar  
\m u ad tᵉttwahellkem deg webrid,  
\m waxxa ittwassarɣ weɣḍab nnes  
\m mɣir drus waha.  
\b  
\m Sseɛd nsen i yinni ɣares yarekkwařen. \x ◘ \xo 2:12 \xt Izhd. 34:9; Awřn. 16:20; Ica. 30:18; Irm. 17:7; Rum. 9:33; 10:11; 1 Bṭ. 2:6\x*   
\b  
\b  
\m  
\c 3
\m
\v 1 \add Azehhed n Dawud, umi yarweř zeg wudem n mmis Abcalum.\add*\x ◘ \xo 3:1 \xt 2 Ṣm. 15-18. \x*   
\b  
\m
\v 2 \add A\add* SIDI, inni d ayi iḥeṣṣaren  
\m aqa kettaren,  
\m aṭṭas aqa aten ḍidd inu.   
\m
\v 3 Aṭṭas aqa qqaren x řeɛmar inu:  
\m “I netta war din \add iǧi\add* usenjem ɣar AREBBI!”  
\m Silah.   
\b  
\m
\v 4 \add Aḥeqqa\add* Cek, \add a\add* SIDI,  
\m d taseddart n useřqi i necc,  
\m aɛuǧi inu,  
\m Cek d wenni issgeɛɛden azeǧif inu.   
\m
\v 5 S tmijja inu řaɣiɣ i SIDI,  
\m uca Netta yarra-dd xafi  
\m zeg wedrar nnes iqeddsen. Silah.   
\b  
\m
\v 6 Senndeɣ uca ikka xafi yiḍeṣ,  
\m faqeɣ-dd, minzi SIDI ittɛawen ayi. \x ◘ \xo 3:6 \xt Izhd. 4:9\x*   
\m
\v 7 War tteggʷideɣ zi ɛecra n řuřuf n řgens,  
\m inni d ayi dd-innḍen,  
\m ssbeddan ixef nsen x iɣezdisen inu. \x ◘ \xo 3:7 \xt Izhd. 27:3\x*   
\b  
\m
\v 8 Kkar, a SIDI, senjem ayi, \add a\add* AREBBI inu,  
\m minzi Cek tewtid marra řɛedyan inu  
\m ɣar uɣesmir,  
\m aqa teddzed tiɣmas n iɛeffanen.   
\m
\v 9 Asenjem aqa-t n SIDI,  
\m lbaraka nnec aqa-tt x řgens nnec. Silah. \x ◘ \xo 3:9 \xt Awřn. 21:31; Ica. 43:11; Irm. 3:23; Ḥuc. 13:4; Asa. 7:10; 19:1\x*   
\b  
\b  
\m  
\c 4
\m
\v 1 \add I umeqqran n imeɣnajen. Ak-d uzenzun x ifiřan. Azehhed n Dawud.\add*   
\b  
\m
\v 2 Arr-dd xafi xmi dd ttřaɣiɣ,  
\m \add a\add* AREBBI n tsegda inu!  
\m Di řeḥṣaret aqa Cek teggid ayi ttasiɛ.  
\m Ḥinn xafi u seř-dd ɣar tẓaǧit inu!   
\b  
\m
\v 3 Tarwa n \add yijj n\add* weryaz,  
\m ař meřmi i ɣa yiři uɛuǧi inu d řɛar?  
\m Ař meřmi ɣa texsem řbaṭeř,  
\m ad tarzum x ixarriqen? Silah.   
\m
\v 4 Snem \add xenni\add*, aqa SIDI iḥuzz  
\m ijj n umeddukkeř amtiqqi i yixef nnes.  
\m SIDI ad ayi iseř xmi d as i ɣa řaɣiɣ.   
\b  
\m
\v 5 Arjijem, \add maca\add* war xeṭṭim.  
\m Siwřem deg wuř nwem  
\m di řectu nwem uca susmem. Silah. \x ◘ \xo 4:5 \xt Afa. 4:26\x*   
\m
\v 6 Qeddmem tiɣarṣa n tsegda,  
\m ttecřem x SIDI. \x ◘ \xo 4:6 \xt Aɛwd. 33:19; Izhd. 51:21\x*   
\b  
\m
\v 7 Aṭṭas qqaren:  
\m “Wi d aneɣ i ɣa issecnen řxar?”  
\m Ejj ad xaneɣ dd-tenqar  
\m tfawt n wudem nnec, \add a\add* SIDI!   
\m
\v 8 Cek tessidfed řefraḥet ɣar wuř inu,  
\m ktar \add x řefraḥet\add* i \add din\add* iǧan di řweqt  
\m umi tuɣa feyyḍen  
\m imendi nsen d binu nsen n jdid.   
\b  
\m
\v 9 Di řehna ad zzřeɣ u ad ṭṭṣeɣ,  
\m minzi mɣir Cek, a SIDI,  
\m ad ayi tesszedɣed di řaman. \x ◘ \xo 4:9 \xt Lawi 26:5; Aɛwd. 12:10; 33:28; Izhd. 3:6\x*   
\b  
\b  
\m  
\c 5
\m
\v 1 \add I umeqqran n imeɣnajen. Ak-d temja. Azehhed n Dawud.\add*   
\b  
\m
\v 2 \add A\add* SIDI, seř i min ɣa iniɣ,  
\m fehmet i unixses inu.   
\m
\v 3 Ḥekkar i tmijja n tutra inu,  
\m \add a\add* Ajeǧid inu d AREBBI inu,  
\m aqa i Cek umi ttẓaǧiɣ.   
\m
\v 4 Ɣar tuffut, \add a\add* SIDI, tesřid Cek i tmijja inu,  
\m ɣar tuffut nnqeřbeɣ-dd ɣarek,  
\m uca qqimeɣ ttrajiɣ Cek.   
\b  
\m
\v 5 Cek war teǧid ca d Arebbi  
\m nni ittexsen tuɛeffna,  
\m bnadem aɛeffan war ɣarek ittif aɣimi.   
\m
\v 6 Ibuḥařiyyen war ttɣimin ttbeddan  
\m zzat i tiṭṭawin nnec,  
\m Cek tcarrhed marra inni itteggen řɣar.   
\m
\v 7 Ad thellked ayt n bu-ixarriqen,  
\m SIDI ittɛiffa aryaz n idammen d řɣecc.   
\b  
\m
\v 8 Maca s řemɣaret n tmexsiwt nnec icewwaren  
\m ad adfeɣ ɣar Taddart nnec,  
\m ad sejdeɣ ɣar Zzawect nnec Tameqqrant  
\m s tiggʷudi zzayek.   
\m
\v 9 \add A\add* SIDI, suyur ayi x webrid n tsegda nnec,  
\m di ṭṭweɛ n yinni i d ayi iḥeṣṣaren,  
\m seggem abrid nnec zzat i wudem inu.   
\m
\v 10 Minzi deg uqemmum nsen war din bu řaman,  
\m jjuf nsen d axeyyeb,  
\m tmijja nsen d anḍeř yarezmen,  
\m arebbun txancet s yiřes nsen. \x ◘ \xo 5:10 \xt Izhd. 34:17; 94:20; Rum. 3:13\x*   
\b  
\m
\v 11 Xřef zzaysen, \add a\add* AREBBI,  
\m ejj i-ten ad wḍan  
\m s řecwar \add n yixef\add* nsen,  
\m aẓẓeř xasen di ssibbet  
\m n waṭṭas n ixeṭṭan nsen,  
\m minzi nitni ɣewwɣen xak.   
\m
\v 12 Marra inni ɣarek yarekkwařen  
\m ad farḥen,  
\m ad sřiweřwen i řebda.  
\m Cek tfaryed xasen!  
\m Aqa inni ittexsen Isem nnec  
\m ad negzen s řefraḥet \add i ɣarsen\add* dayek.   
\m
\v 13 Minzi Cek, \add a\add* SIDI, ad tbarked amseggad,  
\m ad as tquwwared s uḥinni  
\m am s tseddart n useřqi tameqqrant.   
\b  
\b  
\m  
\c 6
\m
\v 1 \add I umeqqran n imeɣnajen. Ak-d uzenzun x ufiřu wiss tmenya. Azehhed n Dawud.\add*   
\b  
\m
\v 2 \add A\add* SIDI, war d ayi ttweddab  
\m deg weɣḍab nnec,  
\m war d ayi ttarebbi ca deg wesɛar nnec! \x ◘ \xo 6:2 \xt Izhd. 38:2\x*   
\m
\v 3 Ḥinn xafi, \add a\add* SIDI,  
\m maɣar necc aqa arxuɣ.  
\m Sgenfa ayi, \add a\add* SIDI,  
\m maɣar iɣsan inu ttarjijin!   
\m
\v 4 Wah, řeɛmar inu yarjef aṭṭas,  
\m u Cek, \add a\add* SIDI, ař meřmi?   
\b  
\m
\v 5 Dweř-dd, \add a\add* SIDI, fekk řeɛmar inu,  
\m senjem ayi di ṭṭweɛ  
\m n tmexsiwt nnec icewwaren.   
\m
\v 6 Minzi di řmewt war  
\m dinni bu řidaret nnec.  
\m Wi Cek i ɣa iqadan di řaxart?   
\m
\v 7 Necc uḥřeɣ s inixsisen inu.  
\m Ǧiřet tekmeř ssuffeɣ qama inu,  
\m uřa d tassut inu tᵉṭṭebṭeb qaɛ s imeṭṭawen.   
\m
\v 8 Tiṭṭ inu teɣři s wecḍan,  
\m jjehd nnes iruḥ zi marra  
\m inni d ayi iḥeṣṣaren.   
\b  
\m
\v 9 Aggʷejem xafi,  
\m marra inni itteggen řmuɛṣiyyet,  
\m minzi SIDI isřa i tmijja n imeṭṭawen inu. \x ◘ \xo 6:9 \xt Mt. 7:23; 25:41; Lk. 13:27\x*   
\m
\v 10 SIDI isřa i tutra inu,  
\m SIDI ad iqbeř taẓaǧit inu.   
\m
\v 11 Marra řɛedyan inu ad ten teřqef  
\m řefḍiḥet d unexřiɛ,  
\m ad dd-dewřen ɣar ḍeffar,  
\m ak-d wermac n wabřiwen ad seḍḥan.   
\b  
\b  
\m  
\c 7
\m
\v 1 \add Izři n Dawud deg waṭṭas n tmijjiwin, izři nni iɣennej i SIDI di ssibbet n wawařen n Kuc, wenni iǧan zeg ayt n Binyamin.\add*   
\b  
\m
\v 2 \add A\add* SIDI, AREBBI inu,  
\m aqa ɣarek arekkwařeɣ!  
\m Senjem ayi zi marra inni xafi ittaẓẓřen  
\m uca fekk ayi,   
\m
\v 3 maḥend netta war d ayi izeɛɛef  
\m am weyrad,  
\m ad ayi imezzeq,  
\m \add řami\add* war din wi ɣa ifekken!   
\b  
\m
\v 4 \add A\add* SIDI, AREBBI inu,  
\m mařa necc ggiɣ man aya,  
\m mařa din ca n řɣecc iřṣeq  
\m deg ifassen inu, \x ◘ \xo 7:4 \xt Ayub 31:1-34; Izhd. 15:2-5\x*   
\m
\v 5 mařa necc xeřfeɣ  
\m wenni akidi iddaren di řehna s řɣar,  
\m - \add maca s řɛeks\add* wenni d ayi iḥeṣṣaren x walu,  
\m jjiɣ t ad yuyur -   
\m
\v 6 ejj \add xenni\add* ad yaẓẓeř řeɛdu x řeɛmar inu,  
\m ad ayi iɛdu,  
\m ad iɛfes x tudart inu di temmurt,  
\m \add ejj i-t\add* ad issezdeɣ aɛuǧi inu di tɛejjajt!  
\m Silah.   
\b  
\m
\v 7 Kkar-dd, \add a\add* SIDI, deg weɣḍab nnec,  
\m suɛřa Ixef nnec x uduqqez  
\m n yinni d ayi iḥeṣṣaren,  
\m faq di ṭṭweɛ inu,  
\m aqa teggid tumured řḥeqq.   
\m
\v 8 Agraw n řegnus ad ac dd-inneḍ,  
\m \add xenni\add* dweř tiwa nsen ɣar sennej.   
\m
\v 9 SIDI ad iḥakem řegnus.  
\m Aɣ ayi tasɣart, \add a\add* SIDI,  
\m ɛlaḥsab tasegda inu,  
\m ɛlaḥsab řekmaret i dayi.   
\b  
\m
\v 10 Sbedd tuɛeffna n iɛeffanen,  
\m semten amsegged,  
\m \add Cek,\add* wenni iqeǧben uřawen d tiẓẓař,  
\m \add a\add* AREBBI iseggden! \f ◼ \fr 7:10 \ft \+fk tiẓẓař\ft  - niɣ ‘tigeẓřin’.\f*  \x ◘ \xo 7:10 \xt 1 Im. 28:9; Irm. 11:20; 17:10; 20:12; Asa. 2:23\x*   
\m
\v 11 Taseddart inu i useřqi ɣar AREBBI,  
\m Amsenjem n imseggmen n wuřawen.   
\b  
\m
\v 12 AREBBI d ijj n řqaḍi iseggden,  
\m Arebbi nni isexxḍen kuř ass. \x ◘ \xo 7:12 \xt Asa. 16:\x*   
\m
\v 13 Mařa netta war dd-iɛqib,  
\m ad isseqḍeɛ Netta ssif nnes,  
\m ad imḥeḍ řqews nnes  
\m uca ad \add xas\add* ineyyec.   
\m
\v 14 Igga xas řesnaḥ ineqqen,  
\m ad yarr fřitcat nnes  
\m d iṣefḍawen yareqqen.   
\b  
\m
\v 15 Xzar, aqa wḍan-dd xas  
\m řewjeɛ n tarut n řmuɛṣiyyet,  
\m iksi ddeyset n tamara  
\m uca ad yaru ixarriqen. \x ◘ \xo 7:15 \xt Ayub 15:35; Ica. 59:4\x*   
\m
\v 16 Iqqaz ijj n weḥfur uca issuǧeɣ i-t,  
\m maca d netta \add s yixef nnes\add* i iwḍan  
\m deg \add weḥfur n\add* turṣuḍi i igga. \x ◘ \xo 7:16 \xt Ayub 4:8; Izhd. 9:16; 10:2; Awřn. 5:22; 26:27; Amb. 10:8\x*   
\m
\v 17 Tamara nnes ad dd-tedweř  
\m x uzeǧif nnes,  
\m řexcunet nnes ad dd-tehwa  
\m x uceqquf nnes.   
\m
\v 18 Ad qadiɣ SIDI ɛlaḥsab tasegda nnes,  
\m ad zehhdeɣ i Yisem n SIDI, Amɛuǧi x kuřci.   
\b  
\b  
\m  
\c 8
\m
\v 1 \add I umeqqran n imeɣnajen. S teɣnint n Ujtti, weryaz zi Jat. Azehhed n Dawud.\add*   
\b  
\m
\v 2 \add A\add* SIDI, Arebbi nneɣ, mammec ijhed  
\m Yisem nnec x marra tammurt,  
\m \add Cek\add* d wenni iggin lɛaḍama nnec  
\m sennej i ijenwan. \x ◘ \xo 8:2 \xt Ayub 36:30\x*   
\m
\v 3 Zeg uqemmum n iḥenjiren d iseyman,  
\m teggid dsas ijhed  
\m zi ssibbet n yinni Cek iḥeṣṣaren,  
\m ḥima ad tbellɛed abrid x řeɛdu  
\m u x wenni yarezzun ad ixřef. \x ◘ \xo 8:3 \xt Mt. 21:16\x*   
\b  
\m
\v 4 Mařa twařiɣ ajenna,  
\m řxedmet n iḍewḍan nnec,  
\m taziri d yetran, inni teggid,   
\m
\v 5 min iɛna \add xenni\add* bnadem,  
\m aqa Cek txarrṣed dayes,  
\m mmis n bnadem,  
\m aqa Cek txezzared ɣares? \x ◘ \xo 8:5 \xt Ayub 7:17; Izhd. 144:3; Ɛbr. 2:6\x*   
\m
\v 6 Cek tarrid t mɣir  
\m cwayt waha qell i AREBBI,  
\m tewcid as ttaj n uɛuǧi d řɛezz.   
\b  
\m
\v 7 Cek tarrid t ad iḥkem  
\m x tmegga n ifassen nnec,  
\m tessarsed marra swadday i iḍaren nnes: \x ◘ \xo 8:7 \xt 1 Kur. 15:27; Afa. 1:22\x*   
\m
\v 8 uǧi d ifunasen, marra ina,  
\m uřa d řmař n yeyyar,   
\m
\v 9 ijḍaḍ n ujenna d iseřman n řebḥar,  
\m \add marra\add* min ittcuqan ibriden n řebḥur.   
\b  
\m
\v 10 \add A\add* SIDI, Siditneɣ,  
\m mammec ijhed Yisem nnec  
\m di marra tammurt!   
\b  
\b  
\m  
\c 9
\m
\v 1 \add I umeqqran n imeɣnajen. S teɣnint n ‘Řmewt n mmis’. Azehhed n Dawud.\add*   
\b  
\m
\v 2 \bd Alif.\bd* Ad qadiɣ SIDI s marra uř inu,  
\m ad barrḥeɣ marra lmuɛjizat nnec.   
\m
\v 3 Ad zzayek farḥeɣ ad zzayek sřiwřiweɣ.  
\m Necc ad zehhdeɣ i Yisem nnec,  
\m \add a\add* Cek, Amɛuǧi x kuřci!   
\b  
\m
\v 4 \bd Bit.\bd* Umi řɛedyan inu dewřen  
\m ɣar ḍeffar,  
\m wḍan u ɣeřyen zzat i wudem nnec.   
\m
\v 5 Maɣar Cek twennid ayi tasɣart inu  
\m u tbellɛed ddeɛwet inu,  
\m teqqimed x řɛarc,  
\m \add a Cek,\add* d řqaḍi amsegged.   
\b  
\m
\v 6 \bd Gimel.\bd* Cek twebbxed řegnus,  
\m thellked aɛeffan,  
\m temḥid isem nsen i řebda qaɛ.   
\m
\v 7 \bd Hi.\bd* Řeɛdu, aqa nitni ttwaqḍan,  
\m aqa aten d řxirbat i řebda.  
\m Tɣeḍřed iɣrimen nsen,  
\m řidaret nsen tefna.   
\b  
\m
\v 8 \bd Waw.\bd* SIDI ittɣima i řebda,  
\m aqa issbedd řɛarc nnes i řeḥkam.   
\m
\v 9 Netta ad icarreɛ ddunect s tsegda,  
\m ad iḥkem ccuɛub s řḥeqq. \x ◘ \xo 9:9 \xt Izhd. 96:13; 98:9\x*   
\b  
\m
\v 10 SIDI d lburj yuɛřan i wenni iḥṣaren,  
\m ijj n lburj yuɛřan di řweqt n řeḥṣaret. \x ◘ \xo 9:10 \xt Izhd. 37:39; 46:2; 91:2\x*   
\m
\v 11 Inni issnen Isem nnec, ad xak ttecřen,  
\m maɣar inni xak yarezzun,  
\m war daysen tsemmḥed, \add a\add* SIDI.   
\b  
\m
\v 12 \bd Zayin.\bd* Zehhdem i SIDI,  
\m wenni izeddɣen di Ṣihyun,  
\m barrḥem s tmegga nnes jar řegnus.   
\m
\v 13 Minzi Netta yarezzu  
\m x usizzeř n idammen,  
\m ittxarraṣ daysen.  
\m War ittu ca iɣuyyan  
\m n yinni ittwaḥeṣṣaren.   
\b  
\m
\v 14 \bd Xit.\bd* Ḥinn xafi, \add a\add* SIDI,  
\m xzar ɣar řeɣben inu  
\m i dd-yusin zeg inni d ayi icarrhen,  
\m Cek d wenni d ayi ɣa issgeɛɛden  
\m zi tewwura n řmewt,   
\m
\v 15 ḥima ad barrḥeɣ s marra ccan nnec,  
\m di tewwura n yeǧis n Ṣihyun.  
\m Necc farrḥeɣ x usenjem nnec.   
\b  
\m
\v 16 \bd Tit.\bd* Řegnus wḍan deg \add weḥfur n\add* turṣuḍi  
\m i ggin nitni \add s yixef nsen\add*,  
\m iḍaren nsen ttwacedden di tracca  
\m nni ssnuffaren nitni \add s yixef nsen\add*,. \x ◘ \xo 9:16 \xt Izhd. 7:16\x*   
\m
\v 17 SIDI igga Ixef nnes ad t ssnen,  
\m Netta yuɣa tasɣart.  
\m Aɛeffan innuɣ di tmegga n ifassen nnes.  
\m Ejj ifiřan ad ddendnen. Silah.   
\b  
\m
\v 18 \bd Yud.\bd* Iɛeffanen ad dd-dewřen ɣar řaxart,  
\m marra řegnus nni ittun AREBBI.   
\m
\v 19 Maca amezřuḍ war ittwattu i řebda,  
\m war ittwaqeṭṭeɛ řayas  
\m n yinni ittwaḥṣaren i řebda.   
\b  
\m
\v 20 \bd Quf.\bd* Kkar, \add a\add* SIDI,  
\m ḥima war iddikkwiř bnadem ijhed ktar.  
\m Ejj řegnus ad ttwacarrɛen  
\m zzat i wudem nnec.   
\m
\v 21 Siggʷed i-ten, \add a\add* SIDI,  
\m ejj řegnus ad ssnen aqa aten d iwdan! Silah.   
\b  
\b  
\m  
\c 10
\m
\v 1 \add Min iqqimen n Uzehhed 9\add*  
\m \bd Lamid.\bd* \add A\add* SIDI,  
\m mayemmi teqqimed tiggʷejed \add ammu\add*?  
\m Mayemmi tessnuffared Ixef nnec  
\m di řweqt n řeḥṣaret?   
\m
\v 2 S nnfaxet iḍeffar uɛeffan řmeskin.  
\m Ad ttwaṭṭfen s tmeɛmač i di ttxarrṣen. \x ◘ \xo 10:2 \xt Izhd. 7:16; 9:16; Awřn. 5:22\x*   
\b  
\m
\v 3 Maɣar aɛeffan issɛuǧa ixef nnes  
\m ɣar meẓri n řeɛmar nnes,  
\m ittbarek aḍemmaɛ, ittceqqaf di SIDI.   
\m
\v 4 Aɛeffan am wenni issgeɛɛaden  
\m tinzart nnes ɣar ujenna,  
\m war ittbeqqec, \add iqqar\add*.  
\m “War din AREBBI”,  
\m man aya d marra min di izemmar ad ittxarreṣ. \x ◘ \xo 10:4 \xt Izhd. 14:1; 53:2\x*   
\b  
\m
\v 5 Marra ibriden nnes  
\m tteffɣen as mliḥ kuř twařa.  
\m Řehkamat nnec ttuɛřant xas.  
\m Ittzawar marra inni t iḥeṣṣaren.   
\b  
\m
\v 6 Netta iqqar deg wuř nnes: “War ttenhezziɣ,  
\m zi jjiř ař jjiř war d ayi iřeqqef  
\m uřa d ijj n řɣar.”   
\m
\v 7 Aqemmum nnes iccur s nneɛřet  
\m d ixarriqen d ddeǧ.  
\m Sadu yiřes nnes  
\m \add aqa din\add* tamara d řmuɛṣiyyet. \x ◘ \xo 10:7 \xt Rum. 3:14\x*   
\b  
\m
\v 8 Netta ittɣima ɣar wecbar di dcurat,  
\m deg imucan innuffaren  
\m ineqq inni war iggin s ca.  
\m Tiṭṭawin nnes mmenḍarent x řmeskin.   
\b  
\m
\v 9 Iřbet deg wemcan innufaren  
\m am weyrad deg udurri n uɛiccu nnes.  
\m Netta ittḥekkar ḥima ad yacar řmeskin.  
\m Ittacar řmeskin umi t ijebbed  
\m di tracca nnes.   
\b  
\m
\v 10 Netta ihekkwa-dd ɣar wadday,  
\m ittaḍar, \add aqa\add* řmeskin iweṭṭa  
\m jar \add waccaren\add* nnes ijehden.   
\m
\v 11 Iqqar deg wuř nnes: “Arebbi ittu,  
\m Netta issnuffar udem nnes,  
\m ɛemmarṣ ad t iẓar.” \x ◘ \xo 10:11 \xt Izhd. 94:7\x*   
\b  
\m
\v 12 \bd Quf.\bd* Kkar, \add a\add* SIDI,  
\m Arebbi, sgeɛɛed afus nnec,  
\m war ttᵉttu řmusakin.   
\m
\v 13 Mayemmi ittceqqaf uɛeffan di AREBBI,  
\m \add mayemmi\add* iqqar deg wuř nnes:  
\m “Cek war tᵉttbeqqaced!”?   
\b  
\m
\v 14 \bd Rix.\bd* Aqa Cek teẓrid,  
\m minzi \bd Cek\bd* tᵉttwařid tamara d wecḍan,  
\m maḥend ad \add ten\add* tessarsed deg ufus nnec.  
\m Řmeskin ittarr-dd ɣarek s uzeǧif.  
\m \bd Cek\bd* d amɛawen n uyujiř. \f ◼ \fr 10:14 \ft \+fk ayujiř\ft  - niɣ ‘agugil’.\f*   
\b  
\m
\v 15 \bd Cin.\bd* Arẓ aɣiř n uɛeffan,  
\m xřef řɣar zeg wenni itteggen tuɛeffna,  
\m \add ař\add* war tᵉttifed walu \add ɛad\add*.   
\m
\v 16 SIDI d Ajeǧid i řebda qaɛ.  
\m Ttwateḥḥan řegnus zi temmurt nnes. \x ◘ \xo 10:16 \xt Izhd. 29:10; 145:13, 146:10; Irm. 10:10; Igjd. 5:19; Dan. 3:33; 6:27; 1 Tim. 1:17\x*   
\b  
\m
\v 17 \bd Taf.\bd* \add A\add* SIDI, Cek tesřid i meẓri n imwaḍɛen,  
\m ad tessjehded uřawen nsen,  
\m ad ɣarsen tmeyyřed amezzuɣ nnec,   
\m
\v 18 ḥima ad taɣed tasɣart i uyujiř  
\m u i wenni ittwaḥeṣṣaren,  
\m maḥend uřa d ijj n bnadem x temmurt  
\m war ittɣimi issaggʷad \add ɛad uřa d ijj\add*.   
\b  
\b  
\m  
\c 11
\m
\v 1 \add I umeqqran n imeɣnajen. N Dawud.\add*  
\b  
\m Ɣar SIDI arekkwařeɣ.  
\m Mammec teqqarem i řeɛmar inu:  
\m “Ḍwu ɣar wedrar nwem, \add a\add* ijḍaḍ!” \f ◼ \fr 11:1 \ft \+bd afessar\+bd* - ad taɣ xsen ad inin awařen-a aqa ittxeṣṣa i Dawud ad yarweř ɣar idurar am t igga deg wussan n Cawul (xzar 1 Ṣm. 26:20; 23:14).\f*   
\m
\v 2 Maɣar xzar,  
\m iɛeffanen aqa meḥḥḍen řqews,  
\m ssrusan fřitcat nsen ɣar ufiřu,  
\m ḥima ad wten di taǧest  
\m deg inni umi isegged wuř.   
\m
\v 3 Wah, dsusa n ddunect ttwareddǧen!  
\m Min \add izemmar xenni\add* ad yegg umsegged?   
\b  
\m
\v 4 SIDI \add izeddeɣ\add*  
\m di Zzawect nnes Tameqqrant iqeddsen,  
\m řɛarc n SIDI aqa-t deg ijenwan.  
\m Tiṭṭawin nnes ttwařant,  
\m řxezrat nnes arezzunt di tarwa n bnadem.   
\m
\v 5 SIDI ittbeqqec amsegged,  
\m \add maca\add* řeɛmar nnes ittɛiffa aɛeffan  
\m d wenni ittexsen lɛunf.   
\m
\v 6 Netta ad iwwet iɛeffanen  
\m s ijj n wenẓar n řefxux,  
\m timessi d řecbariyyet  
\m d tḥaryaḍt tameqqrant  
\m \add ad iřint\add* d tasɣart n řkas nsen.   
\b  
\m
\v 7 Minzi SIDI d amsegged,  
\m ittexs timegga iseggden.  
\m Inni igguren nican  
\m ad ẓaren udem nnes.   
\b  
\b  
\m  
\c 12
\m
\v 1 \add I umeqqran n imeɣnajen. X ufiřu wiss tmenya. Azehhed n Dawud.\add*   
\b  
\m
\v 2 Senjem, \add a\add* SIDI,  
\m minzi ameddukkeř amtiqqi  
\m war iqqim ɛad,  
\m maɣar war din \add ɛad\add* imtiqqan  
\m jar tarwa n bnadem. \x ◘ \xo 12:2 \xt Ica. 57:1\x*   
\m
\v 3 Nitni ssawařen jar asen s ixarriqen,  
\m s iyencicen ccuren  
\m s wawařen imiziḍen,  
\m aqa ssawařen s tnayen n iɣembab. \f ◼ \fr 12:3 \ft \+fk s tnayen n iɣembab\ft  - s Tiɛbranit ‘s wuř d wuř’.\f*   
\b  
\m
\v 4 Ejj SIDI ad iqḍeɛ  
\m marra iyencicen ccuren  
\m s wawařen imiziḍen,  
\m uřa d iřes s wawařen n ukebbar,   
\m
\v 5 inni iqqaren:  
\m “S yiřes nneɣ  
\m ad ɣarneɣ yiři uqarru imɣar,  
\m iyencicen aqa aten nneɣ!  
\m Man wen \add iǧan\add* xaneɣ d sidi?”   
\b  
\m
\v 6 “Di ssibbet n wareddeǧ n řmusakin,  
\m uřa di ssibbet n iɣuyyan n imezřaḍ  
\m ad kkareɣ řexxu Necc”, inna SIDI,  
\m “Wenni x tuɣa idduqez netta,  
\m Necc ad t awyeɣ di řaman.”   
\m
\v 7 Tiwařin n SIDI aqa atent d tiwařin ṣfant,  
\m ttwassizdgent \add am\add* nnuqart  
\m deg ijj n řkas i ufesyi deg ucař,  
\m ttwaṣeffant sebɛa n twařawin. \f ◼ \fr 12:7 \ft \+fk sebɛa n twařawin\ft  - ixs ad yini aṭṭas n twařawin, war izemmar bnadem ad tent iḥseb.\f*  \x ◘ \xo 12:7 \xt 2 Ṣm. 22:31; Izhd. 18:31; 119:140; Awřn. 30:5\x*   
\b  
\m
\v 8 \bd Cek\bd*, \add a\add* SIDI, ad ten teḥḍid,  
\m ad aneɣ tessared zi jjiř-a,  
\m i řebda qaɛ.   
\m
\v 9 Iɛeffanen gguren ttennḍen mani ma  
\m xmi ɣa ikkar ddeǧ jar tarwa n bnadem.   
\b  
\b  
\m  
\c 13
\m
\v 1 \add I umeqqran n imeɣnajen. Azehhed n Dawud.\add*   
\b  
\m
\v 2 Mecḥař ɛad, \add a\add* SIDI, i d ayi ɣa tᵉttud?  
\m Ař mecḥař ɛad  
\m i xafi i ɣa tessnuffared udem nnec?   
\m
\v 3 Mechař i iqqimen ad ggeɣ ɛad  
\m řehmum di řeɛmar inu,  
\m acḍan deg wuř inu mkuř ass?  
\m Ař meřmi ɣa issɛuǧa řeɛdu inu  
\m ixef nnes xafi?   
\b  
\m
\v 4 Xzar-dd, arr-dd xafi,  
\m \add a\add* SIDI, AREBBI inu!  
\m Egg tfawt ɣar tiṭṭawin inu,  
\m ḥima war ttᵉṭṭṣeɣ iḍeṣ n řmewt,   
\m
\v 5 ḥima řeɛdu inu war iqqar:  
\m “Necc ɣellbeɣ xas!”,  
\m \add ḥima\add* wenni d ayi iḥeṣṣaren  
\m war ifarreḥ mařa farɣeɣ.   
\b  
\m
\v 6 Necc ttecřeɣ  
\m x tmexsiwt nnec icewwaren.  
\m Uř inu ad ifarḥ x usenjem nnec.  
\m Necc ad ɣennjeɣ i SIDI,  
\m maɣar Netta igga dayi řxir.   
\b  
\b  
\m  
\c 14
\m
\v 1 \add I umeqqran n imeɣnajen. N Dawud.\add*  
\b  
\m Abuhaři inna deg wuř nnes:  
\m “War din bu AREBBI!”  
\m Nitni ttareddǧen,  
\m tteggen timesřayin iḍexsen,  
\m war din uřa d ijj ittegg min icnan. \x ◘ \xo 14:1 \xt Izhd. 10:4; 53:2; Rum. 3:10\x*   
\b  
\m
\v 2 SIDI ixezzar-dd zeg ujenna  
\m ɣar tarwa n bnadem,  
\m ḥima ad iẓar, ma din ḥed dayes řefhamet,  
\m ijj wenni yarezzun AREBBI.   
\b  
\m
\v 3 Marra ffɣen zeg webrid,  
\m \add aqa aten jmiɛ\add* dewřen d iɛeffanen,  
\m war din uřa d ijj ittegg řxar,  
\m uřa d ijj.   
\b  
\m
\v 4 Marra inni itteggen řmuɛṣiyyet  
\m ma war ɣarsen bu tussna,  
\m inni ittᵉtten řgens inu  
\m axmi ttᵉtten aɣrum?  
\m Nitni war ttřaɣan x SIDI.   
\b  
\m
\v 5 Aqa tewḍa-dd xasen din  
\m iggʷudi temɣar,  
\m maɣar AREBBI  
\m aqa-t ak-d jjiř n imseggaden.   
\b  
\m
\v 6 Kenniw tnefḍem array n řmusakin,  
\m maca SIDI d amcan nnes n tarewřa.   
\b  
\m
\v 7 Man wen zi Ṣihyun  
\m i ɣa yiwyen asenjem n Israil!  
\m Xmi dd ɣa yarr SIDI  
\m imeḥbas n řgens nnes,  
\m ad yarceq Yaɛqub,  
\m ad ifarḥ Israil.   
\b  
\b  
\m  
\c 15
\m
\v 1 \add Azehhed n Dawud.\add*  
\b  
\m \add A\add* SIDI, man wen i ɣa iqqimen  
\m deg Uqiḍun nnec?  
\m Man wen i ɣa izedɣen  
\m x wedrar nnec iqeddsen? \x ◘ \xo 15:1 \xt Izhd. 7:4-6; Ayub 31:1-34.\x*   
\m
\v 2 Wenni igguren  
\m di řekmařet n tudart nnes  
\m wenni itteggen tasegda,  
\m \add wenni\add* issawařen tidett deg wuř nnes. \x ◘ \xo 15:2 \xt Izhd. 24:4; Ica. 33:15-17\x*   
\b  
\m
\v 3 Wenni war ittceqqafen s yiřes nnes,  
\m \add wenni\add* war itteggen řɣar i imɛacaren nnes,  
\m u war ittzawar ajjar nnes.   
\m
\v 4 Wenni immenḍaren \add zi Arebbi\add*  
\m aqa ittwasseḥqar di tiṭṭawin nnes,  
\m \add maca\add* inni itteggʷeden SIDI,  
\m ittweqqar i-ten.  
\m Mařa ijjuǧ netta i txessart nnes,  
\m war \add t\add* ittbeddiř.   
\m
\v 5 Wenni war itticen  
\m \add tamenyat n\add* nnuqart nnes s arriba,  
\m wenni war itteṭṭfen arrecwet  
\m ḍidd n yinni war iggin s ca.  
\m Wenni itteggen man aya,  
\m war ifarreɣ i řebda.   
\b  
\b  
\m  
\c 16
\m
\v 1 \add Tira ineqcen. N Dawud.\add*  
\b  
\m Ḥḍa xafi, \add a\add* Arebbi,  
\m maɣar necc arekkwařeɣ ɣarek.   
\m
\v 2 \add Řeɛmar inu\add* tenna i SIDI:  
\m “Cek d Sidi inu,  
\m \add Cek\add* d řxar inu, war din min xak yuɛřan!” \x ◘ \xo 16:2 \xt Ayub 22:2; 35:7; Rum. 11:35\x*   
\m
\v 3 X imqeddasen i \add izeddɣen\add* x temmurt,  
\m nitni d ayt n jjehd  
\m zi \add ssibbet n\add* marra arḍa inu i daysen \add iǧan\add*.   
\b  
\m
\v 4 Tamara n yinni iḍeffaren \add ammu\add* deɣya  
\m ijj n \add arebbi\add* nneɣni ad ttwaktarent.  
\m Necc war ttfarriɣeɣ tawhibt nsen  
\m n useyyeb n idammen,  
\m war ttidareɣ ismawen nsen  
\m x iyencicen inu.   
\m
\v 5 SIDI d tasɣart inu d řkas inu.  
\m \bd Cek\bd* tᵉṭṭfed taqedduḥt inu deg ufus nnec. \x ◘ \xo 16:5 \xt Igjd. 3:24\x*   
\b  
\m
\v 6 Ifiřan \add n řeɛbar\add* kkaren ayi-dd  
\m deg imucan iṣebḥen,  
\m wah, tasɣart \add inu\add* \add aqa\add* tusa-dd xafi mliḥ.   
\m
\v 7 Ad barkeɣ SIDI, wenni d ayi ineṣḥen.  
\m Uřa s ǧiřet ssřemdent ayi tiẓẓař inu. \f ◼ \fr 16:7 \ft \+fk tiẓẓař\ft  - niɣ ‘tigeẓřin’.\f*   
\m
\v 8 Tteggeɣ SIDI řebda jar tiṭṭawin inu.  
\m Umi Netta \add iǧa\add* x ufus afusi inu,  
\m necc war ttefcireɣ. \x ◘ \xo 16:8 \xt Řex. 2:25\x*   
\b  
\m
\v 9 S uya ifarreḥ uř inu,  
\m ittarciq řeɛmar inu.  
\m Wah, \add uřa d\add* ddat inu ad iddar s řaman.   
\m
\v 10 Maɣar Cek war tsemmḥed ca  
\m di řeɛmar inu di řaxart,  
\m war tᵉttarrid amtiqqi nnec ad ikiccu. \x ◘ \xo 16:10 \xt Izhd. 49:10; Řex. 2:31; 13:35\x*   
\m
\v 11 Cek ad ayi tessecned abrid n tudart,  
\m tyawant zi řefraḥet  
\m aqa-t zzat i wudem nnec,  
\m nniɛmat aqa atent deg ufus nnec i řebda.   
\b  
\b  
\m  
\c 17
\m
\v 1 \add Taẓaǧit n Dawud.\add*  
\b  
\m \add A\add* SIDI, seř ɣar tsegda,  
\m egg řbař i uɣuyyi inu,  
\m ewc amezzuɣ xmi ttẓaǧiɣ  
\m s iyencicen war zzaysen dd-ittekk ca řɣecc.   
\m
\v 2 Ejj řḥeqq inu ad iffeɣ  
\m zi zzat i wudem nnec,  
\m ejj tiṭṭawin nnec ad xezzarent  
\m ɣar min iǧan iseggden.   
\b  
\m
\v 3 Cek tqeǧbed uř inu,  
\m tarzud \add dayes\add* s ǧiřet.  
\m Tjarrbed ayi, \add maca\add* war tufid walu.  
\m \add Mařa\add* nwiɣ ad xarrṣeɣ di ca war iḥři,  
\m war itteffiɣ zeg iyenciden inu.   
\m
\v 4 X min tteggen iwdan,  
\m aqa \bd necc\bd* ḥḍiɣ ixef inu  
\m zi tebridin n ayt n bu-řexcunet,  
\m ɛlaḥsab awař zeg iyencicen nnec.   
\m
\v 5 Egg iṣuraf inu di jjurrat \add n iḍaren\add* nnec,  
\m \add ḥima\add* war farrɣen iḍaren inu.   
\b  
\m
\v 6 \bd Necc\bd* řaɣiɣ xak,  
\m minzi Cek ad xafi dd-tarred, \add a\add* Arebbi,  
\m ewc ayi amezzuɣ, seř i min ɣa iniɣ.   
\m
\v 7 Scen řeɛjayeb  
\m n tmexsiwt nnec icewwaren,  
\m Cek d wenni issenjamen  
\m inni ɣarek yarekkwařen,  
\m \add Cek d wenni ten issenjamen\add*  
\m zeg yinni ittɣewwɣen s ufus nnec afusi.   
\b  
\m
\v 8 Ḥḍa ayi am mummu n tiṭṭ nnec,  
\m snuffar ayi di tiři n wafriwen nnec \f ◼ \fr 17:8 \ft \+fk am mummu n tiṭṭ nnec\ft  - xmi txezzared di tisi, itteḍhar řebda ijj n weryaz ameẓyan di mummu n tiṭṭ nnec wenni d taṣwirt n yixef nnec. S Tɛibranit ‘aryaz ameẓyan n yeǧis n tiṭṭ’.\f*   
\m
\v 9 zeg iɛeffanen inni ixsen ad dayi ḥṣaren,  
\m inni d řɛedyan n řeɛmar inu,  
\m inni d ayi ittquwwaren.   
\b  
\m
\v 10 Nitni bellɛen \add uř nsen\add* s tadunt nsen,  
\m s uqemmum nsen ssawařen s nnfaxet.   
\m
\v 11 Řexxu quwwaren ɛad i iṣuraf nneɣ,  
\m tiṭṭawin nsen mmuqqřent  
\m maḥend ad \add ayi\add* nḍaren ɣar temmurt.   
\m
\v 12 Netta yarwes deg weyrad nni imeẓẓren  
\m maḥend ad imezzeq \add taymart nnes\add*,  
\m deg ijj n weyrad d ameẓyan  
\m i iqqimen deg imucan innuffaren.   
\b  
\m
\v 13 Kkar, \add a\add* SIDI, ruḥ msagar akides,  
\m ɣḍeř-i-t ɣar temmurt.  
\m Fekk řeɛmar inu s ssif nnec zeg uɛeffan,   
\m
\v 14 s ufus nnec zeg iryazen, \add a\add* SIDI,  
\m zeg iryazen n ddunect-a  
\m nni ɣarsen tudart-a d tasɣart \add nsen\add*,  
\m inni zi tᵉttɛemmared aɛeddis nsen  
\m s řeknuz inuffaren,  
\m \add uřa d\add* iḥenjiren \add nsen\add* ttwayawanen,  
\m ttejjan min iceṭṭen i tarwa nsen.   
\m
\v 15 \bd Necc\bd* ad ẓareɣ udem nnec di tsegda,  
\m ad dewřeɣ jjiwneɣ s waddud nnec  
\m xmi dd ɣa faqeɣ.   
\b  
\b  
\m  
\c 18
\m
\v 1 \add I umeqqran n imeɣnajen. N umsexxar n SIDI.\add* \add N Dawud, wenni issiwřen awařen n yezři-ya i SIDI,\add* \add deg wass umi t ifekk SIDI\add* \add zeg ufus n marra řɛedyan nnes\add* \add u zeg ufus n Cawul.\add*\f ◼ \fr 18:1 \ft \+bd afessar\+bd* - tzemmared ad tafed Azehhed-a ɛawed di 2 Ṣam. 22.\f*  \x ◘ \xo 18:1 \xt 2 Ṣm. 22\x*   
\b  
\m
\v 2 Netta inna:  
\m “Necc ttexseɣ Cek, \add a\add* SIDI,  
\m jjehd inu \add d Cek\add*. \x ◘ \xo 18:2 \xt 1 Ṣm. \x*   
\m
\v 3 SIDI d Tasḍart inu  
\m d lburj inu d amfekki inu,  
\m Arebbi inu, Taṣḍart inu,  
\m necc ɣares arekkwařeɣ.  
\m \add Cek\add* d taseddart inu n useřqi  
\m d yicc n usenjem inu,  
\m lburj inu yuɛřan.   
\m
\v 4 Necc řaɣiɣ-dd x SIDI,  
\m wenni isdaheǧen asemɣar,  
\m u necc aqa ttwassnejmeɣ  
\m zi řɛedyan inu.   
\b  
\m
\v 5 Iseɣwan n řmewt nnḍen ayi-dd,  
\m ssiggʷedent ayi řḥemřat n waman ihajen.   
\m
\v 6 Iseɣwan n řaxart carfen ayi,  
\m tixecfin n řmewt ḥṣarent ayi.   
\m
\v 7 Di řeḥṣaret inu řaɣiɣ-dd x SIDI,  
\m x AREBBI inu i x dd-řaɣiɣ.  
\m Zi Zzawect nnes Tameqqrant  
\m isřa Netta i tmijja inu,  
\m iɣuyyan inu \add udfen\add*  
\m ɣar imezzuɣen nnes.   
\b  
\m
\v 8 \add Xenni\add* tenhezz u tarjij temmurt,  
\m dsusa n idurar  
\m ttraḥen-dd ttasen-dd u nhezzen,  
\m maɣar ittwassarɣ \add weɣḍab nnes\add*.   
\m
\v 9 Igeɛɛed ddexxan zeg wenzaren nnes,  
\m timessi zeg uqemmum nnes tṣarḍ,  
\m ittwassarɣ zzayes řefḥem.   
\m
\v 10 Netta ijja ajenna ad yaḍar  
\m uca \add xenni\add* ihwa-dd Netta,  
\m \add aqa din\add* ijj n useynu ibbumbes  
\m sadu iḍaren nnes.   
\b  
\m
\v 11 Indeh x ijj n ukirub, \add wah,\add* iḍwa,  
\m Netta iḥewwem x wafriwen n usemmiḍ. \f ◼ \fr 18:11 \ft \+fk akirub\ft  - ict n marka n lmalakat.\f*   
\m
\v 12 Netta igga taǧest  
\m am yijj n useřqi x yixef nnes,  
\m aɛiccu nnes aqa-t deg wenneḍ nnes,  
\m aman ibbubbsen,  
\m iseynuten ibbarecnen.   
\m
\v 13 Zi tissiqt qibač nnes  
\m ttekken iseynuten nnes,  
\m \add ak-d\add* tebruri d řefḥem itteḥduduqen. \x ◘ \xo 18:13 \xt Uf. 9:23, 24\x*   
\b  
\m
\v 14 SIDi igga ajjaj ad idduqqez deg ijenwan,  
\m Amɛuǧi x kuřci igga tmijja nnes ttnefrara:  
\m tabruri d řefḥem itteḥduduqen.   
\m
\v 15 Netta issekk fřitcat \add n řqews nnes\add*  
\m uca ibezzeɛ i-ten,  
\m \add izzaryeḍ\add* assamen uca issiggʷed i-ten.   
\m
\v 16 Tisiwin n iɣezran dewřent ttbanent,  
\m dsusa n ddunect dewřen ɛarran  
\m zeg uweddeb nnec, \add a\add* SIDI,  
\m zeg usuḍi n řeɛwin zeg wenzaren nnec.   
\b  
\m
\v 17 Zi sennej isswiẓẓeḍ-dd \add afus nnes\add*,  
\m yiwi ayi,  
\m ijbed ayi-dd zeg waman mɣaren.   
\m
\v 18 Netta ifekk ayi-dd zi řeɛdu inu ijehden,  
\m zeg inni d ayi icarrhen,  
\m minzi nitni tuɣa jehhden xafi.   
\m
\v 19 Nitni ḥṣaren ayi  
\m deg wass n arẓiyyet inu,  
\m maca SIDI tuɣa d amɛemmed inu.   
\m
\v 20 Netta indeh ayi ɣar ttasiɛ  
\m uca issenjem ayi,  
\m maɣar Netta tuɣa issɛizza ayi.   
\b  
\m
\v 21 SIDI ixřef ayi ɛlaḥsab tasegda inu,  
\m ɛlaḥsab tazdugi n ifassen inu ixeǧeṣ ayi.   
\m
\v 22 Maɣar necc ḥḍiɣ ibriden n SIDI,  
\m war ḥeyydeɣ ca x AREBBI inu s uxeyyeb.   
\m
\v 23 Maɣar marra lfarayiḍ nnes  
\m \add tuɣa\add* jar \add tiṭṭawin\add* inu,  
\m war ḥeyyideɣ ca x tweṣṣa nnes.   
\m
\v 24 Aqa-yi kemmřeɣ nican akides,  
\m ḥḍiɣ ixef inu zi řmuɛṣiyyet inu.   
\b  
\m
\v 25 SIDI ixřef ayi anect n tsegda inu,  
\m anect n tazdugi n ifassen inu  
\m zzat i tiṭṭawin nnes.   
\m
\v 26 I umeddukkeř amtiqqi  
\m i teǧid Cek d ameddukkeř amtiqqi,  
\m i bu-teɣruḍt ikemmřen  
\m i teǧid Cek tkemmřed.   
\m
\v 27 I wenni ittwassizedgen  
\m aqa Cek d amezdag,  
\m ak-d wenni ifarɣen, aqa tᵉttmuɣzřed.   
\m
\v 28 Cek tessnejmed řgens ittwaḥṣaren,  
\m \add maca\add* tiṭṭawin ɛeffarent  
\m ad tent tessehwid.   
\b  
\m
\v 29 Minzi Cek d řefnar inu, \add a\add* SIDI!  
\m AREBBI inu ittegg tafawt di taǧest inu.   
\m
\v 30 Minzi akidek ad azzřeɣ x ict n bandiyya,  
\m ak-d AREBBI inu ad negzeɣ x ijj n řḥiḍ.   
\m
\v 31 Abrid n Arebbi ikmeř,  
\m min iqqar SIDI ittwaṣeffa \add di tmessi\add*.  
\m Netta d aseřqi  
\m i marra inni ɣares yarekkwařen.   
\b  
\m
\v 32 Maɣar man wen i iǧan d Arebbi,  
\m mɣir SIDI,  
\m u man wen i iǧan d taṣḍart,  
\m mɣir AREBBI nneɣ?   
\m
\v 33 Arebbi wenni d ayi ittbeysen s jjhed,  
\m wenni d ayi itticen abrid inu ikmeř.   
\b  
\m
\v 34 Netta igga iḍaren inu  
\m am yinni n tudadin,  
\m Netta yarra ayi ad beddeɣ x řegɛudi inu. \x ◘ \xo 18:34 \xt Ḥab. 3:19\x*   
\m
\v 35 Isseřmed ifassen inu i umenɣi,  
\m iɣaǧen inu maḥend ad meḥḍen  
\m ijj n řqews n nnḥas.   
\b  
\m
\v 36 Tewcid ayi taseddart n useřqi  
\m n usenjem nnec,  
\m afus nnec afusi d asenned inu,  
\m awaḍeɛ nnec tessemɣared ayi.   
\m
\v 37 Aqa teggid ttasiɛ  
\m i iṣurif\add en\add* inu sadu inu,  
\m ticeɛbin inu war meyyřent.   
\b  
\m
\v 38 Necc ḍfareɣ řɛedyan inu u ḥarteɣ xasen,  
\m war ttɛiqibeɣ ař ten qḍiɣ.   
\m
\v 39 Necc areddǧeɣ ten,  
\m \add ařami\add* war zemmaren ad kkaren ɛawed.  
\m Nitni wḍan-dd sadu iḍaren inu.   
\m
\v 40 Cek tbeysed ayi s jjehd i umenɣi,  
\m tarrid-dd inni ɣari dd-ikkaren  
\m ad aḍaren sadu inu.   
\m
\v 41 Cek tewcid ayi timejjart n řɛedyan inu,  
\m n yinni d ayi icarrhen,  
\m u necc areddǧeɣ ten.   
\b  
\m
\v 42 Nitni řaɣan,  
\m \add maca\add* war din tuɣi amsenjem,  
\m \add řaɣan\add* x SIDI,  
\m maca Netta war xasen dd-yarri.   
\m
\v 43 Necc weddareɣ ten am tɛejjajt  
\m zzat i usemmiḍ,  
\m am ubeǧaɛ x ibriden farḍeɣ zzaysen.   
\b  
\m
\v 44 Cek tfekked ayi zeg imcubbcen n řgens,  
\m teggid ayi d azeǧif n řegnus,  
\m ijj n weydud war t ssineɣ, ad ayi isexxar. \x ◘ \xo 18:44 \xt 2 Ṣm. 22:44\x*   
\m
\v 45 Mɣir řami d ayi isřa umezzuɣ \add nsen\add* waha,  
\m sřin-dd ɣari.  
\m Ibarraniyyen ssniɛmiřen ssubuḍen ayi.   
\m
\v 46 Fecřen ibarraniyyen,  
\m \add waxxa\add* nnḍen asen-dd lbarajat nsen.   
\b  
\m
\v 47 Tudart i SIDI! Ad tᵉttwabarek Teṣḍart inu.  
\m Ad ittwassgeɛɛed AREBBI n usenjem inu.   
\m
\v 48 Arebbi wenni xafi ittentaqamen  
\m wenni d ayi itteggen řegnus sadu ufus inu,   
\m
\v 49 wenni d ayi ittfekkan  
\m zeg \add ufus n\add* řɛedyan inu,  
\m \add wah\add*, Cek tessgeɛɛaded ayi  
\m tiwa n yinni d ayi ittḍaddan,  
\m Cek tessenjamed ayi zeg weryaz n řexcunet.   
\b  
\m
\v 50 X uya, SIDI, xseɣ ad Cek qadiɣ,  
\m ad zehhdeɣ Isem nnec.   
\m
\v 51 Netta igga isenjimen  
\m n ujeǧid nnes mɣaren,  
\m isscen tamexsiwt nnes icewwaren  
\m i umedhun nnes,  
\m i Dawud u i zzariɛet nnes i řebda.   
\b  
\b  
\m  
\c 19
\m
\v 1 \add I umeqqran n imeɣnajen. Azehhed n Dawud.\add*   
\b  
\m
\v 2 Ijenwan ttbarrḥen s uɛuǧi n Arebbi,  
\m řqubbet tessawař  
\m x řxedmet n ifassen nnes.   
\m
\v 3 Ass issazzař awařen i wass,  
\m ǧiřet tesscan tussna ɣar ǧiřet.   
\m
\v 4 War iǧi d řhard u war ǧin ca d awařen,  
\m tmijja nsen war d as ittesři ḥed.   
\b  
\m
\v 5 Řumurat nsen ffɣent x temmurt marra,  
\m awařen nsen \add ffɣen\add* ař ṭṭarf n ddunect.  
\m Netta igga diha ijj n uqiḍun i tfuct, \x ◘ \xo 19:5 \xt Ḥuc. 6:3; Rum. 10:18\x*   
\m
\v 6 am muřay nni dd-issijjen  
\m zeg wexxam n řemřac,  
\m isřiwřew am yijj n bu-teryast,  
\m ḥima ad iksi di ticři nnes. \x ◘ \xo 19:6 \xt Amb. 1:5\x*   
\m
\v 7 Iffeɣ-dd zeg ijj n ṭṭarf n ujenna,  
\m uca yuyur ař ṭṭarf nnes nneɣni,  
\m war tᵉttnuffar uřa d ict n řḥajet  
\m i řḥaduq nnes.   
\b  
\m
\v 8 Aqa tekmeř Ccariɛa n SIDI,  
\m tiwi-dd agenfu i buḥbeř.  
\m Cchadat n SIDI daysent řaman,  
\m tticcent tiɣit i uḥafi. \x ◘ \xo 19:8 \xt 2 Ṣm. 22:31; Izhd. 18:31\x*   
\m
\v 9 Řumurat n SIDI seggdent,  
\m ssfarrḥent uř.  
\m Tawṣiyyet n SIDI teṣfa,  
\m tesscana tafawt i tiṭṭawin.   
\m
\v 10 Tiggʷudi zi SIDI teṣfa,  
\m teqqim tbedd i řebda.  
\m Řeḥkamat n SIDI d tidett,  
\m aqa atent d řḥeqq marra.   
\b  
\m
\v 11 Nitenti jebbdent meẓri ktar x wureɣ,  
\m \add wah\add*, ktar zeg wureɣ ittwaṣeffan,  
\m aqa atent d timiẓidin x tamment  
\m niɣ x tamment n teɣraṣt. \x ◘ \xo 19:11 \xt Izhd. 119:72, 103, 127; Awřn. 8:11 \x*   
\m
\v 12 Uřa d amsexxar nnec  
\m ittwawebbex zzaysent,  
\m deg uḥeṭṭu nsent \add tᵉttnuffar\add*  
\m dayes řmunet tameqqrant.   
\m
\v 13 Aweddar, wi zzayes yucin?  
\m Sizdeg ayi zi \add min\add* war ittbinen.   
\m
\v 14 Ḥḍa amsexxar nnec ɛawed zeg uɛeffar,  
\m ḥima war xafi ittṣeǧiḍ,  
\m \add ḥima\add* ad iřiɣ d amezdag  
\m zeg uxeṭṭu imɣaren.   
\m
\v 15 Ad dd-asen wawařen n uqemmum inu  
\m d ixariṣṣen n wuř inu,  
\m x řxaḍar nnec, \add a\add* SIDI,  
\m \add a\add* Taṣḍart inu d Amefdi inu!   
\b  
\b  
\m  
\c 20
\m
\v 1 \add I umeqqran n imeɣnajen. Azehhed n Dawud.\add*   
\b  
\m
\v 2 Ad xak dd-yarr SIDI  
\m deg wass n řeḥṣaret,  
\m ad cek issizdeɣ Isem n AREBBI n Yaɛqub  
\m \add deg wemcan\add* yuɛřan ifaryen.   
\m
\v 3 Ad ac iwc afus zi Zzawect Iqeddsen,  
\m ad cek dd-iɛawen zi Ṣihyun.   
\m
\v 4 Ad cek yidar di tewhibin \add n řɣiǧet\add* nnec,  
\m ad tiři tɣarṣt n wecmaḍ nnec  
\m am tadunt i Netta. Silah.   
\m
\v 5 Ad ac iwc ɛlaḥsab  
\m \add min immeẓri\add* wuř nnec,  
\m ejj i-t ad ikemmeř marra inwayen nnec.   
\m
\v 6 Neccin ad nesřiwřew  
\m x usenjem s ufus nnec,  
\m ad nessuɛřa ibanduten  
\m deg Yisem n AREBBI nneɣ.  
\m Ad issjiwen SIDI marra meẓri nnec.   
\m
\v 7 Řexxu ssneɣ, aqa SIDI ad yawi asenjem  
\m i umedhun nnes.  
\m Netta ad t-i-dd-yarr  
\m zeg ijenwan n Zzawect nnes Iqeddsen,  
\m s tmegga timeqqranin n usenjem  
\m s ufus afusi nnes.   
\b  
\m
\v 8 Ina ttxarraṣen deg ikarruten  
\m u ina deg iysan,  
\m maca \bd neccin\bd* ad nxarreṣ  
\m deg Isem n SIDI, AREBBI nneɣ.   
\m
\v 9 \bd Nitni\bd* uḍaren uca wḍan,  
\m \bd neccin\bd* nekkar u neqqim nbedd.   
\b  
\m
\v 10 \add A\add* SIDI, awi-dd asenjem!  
\m Ejj ad aneɣ dd-yarr ujeǧid  
\m deg wass i di nřaɣa.   
\b  
\b  
\m  
\c 21
\m
\v 1 \add I umeqqran n imeɣnajen. Azehhed n Dawud.\add*   
\b  
\m
\v 2 \add A\add* SIDI, ajeǧid ifarḥ s jjehd nnec,  
\m mammec ifarḥ aṭṭas s usenjem nnec!   
\m
\v 3 Tewcid as meẓri n wuř nnes,  
\m Cek war tugid ca  
\m azaweg n iyencicen nnes. Silah.   
\b  
\m
\v 4 Maɣar Cek tusid-dd i umsagar akides  
\m s lbarakat \add ccurent s\add* řxar,  
\m teqqned as ttaj n wureɣ ittwaṣeffan  
\m x uzeǧif nnes.   
\m
\v 5 Ittar ac tudart,  
\m tewcid as tt,  
\m tuzzeggart n wussan i řebda qaɛ.   
\b  
\m
\v 6 Imɣar uɛuǧi nnes s usenjem nnec,  
\m tesszehhjed t s tissiqt d řɛezz. \f ◼ \fr 21:6 \ft \+fk asenjem\ft  - niɣ ‘asellek’.\f*   
\m
\v 7 Minzi Cek tarrid i-t  
\m d lbaraka tameqqrant i řebda,  
\m Cek teccured t s řefraḥet  
\m ɣar wudem nnec.   
\b  
\m
\v 8 Maɣar ajeǧid ittcař x SIDI,  
\m war ittefriɣ s tmexsiwt icewwaren  
\m n Umɛuǧi x kuřci.   
\m
\v 9 Afus nnec ad yaf marra řɛedyan nnec,  
\m afus afusi nnec ad yaf  
\m marra inni Cek icarrhen.   
\b  
\m
\v 10 Cek ad ten tarrid am tefqunt icemmḍen  
\m di řweqt n weḍḥar nnec,  
\m SIDI ad ten isarḍ s weɣḍab nnes,  
\m timessi ad ten tecc.   
\m
\v 11 Ad temḥid řɣiǧet nsen zi temmurt,  
\m zzariɛet nsen zi tarwa n bnadem.   
\b  
\m
\v 12 Maɣar nitni nedyen ac řɣar,  
\m ggin ict n tmeɛmuč,  
\m maca war zemmaren walu.   
\m
\v 13 Maɣar Cek ad ten tegged jar tiṭṭawin,  
\m s ifiřan \add n řqews\add* nnec ad tneyyced  
\m x wudmawen nsen.   
\b  
\m
\v 14 Sgeɛɛed ixef nnec, \add a\add* SIDI, s jjhed nnec!  
\m Ejj aneɣ ad nɣennej  
\m u ad nzehhed i tzemmar nnec.   
\b  
\b  
\m  
\c 22
\m
\v 1 \add I umeqqran n imeɣnajen, s teɣnint n ‘Tudadt n tuffut’. Azehhed n Dawud.\add*   
\b  
\m
\v 2 Arebbi inu, Arebbi inu,  
\m mayemmi i d ayi tejjid?  
\m Zi řaggʷaj \add i teǧid\add* zeg usenjem inu,  
\m zeg wawařen i sɣuyyuɣ \add am weyrad\add*. \x ◘ \xo 22:2 \xt Mt. 27:46; Mk. 15:34\x*   
\m
\v 3 \add A\add* AREBBI inu, řaɣiɣ deg wass,  
\m \add maca\add* Cek war xafi dd-tarrid ca,  
\m s ǧiřet, \add maca\add* necc war \add ufiɣ\add* arraḥet.   
\b  
\m
\v 4 Cek d amqeddes \add i teǧid\add*,  
\m tzeddɣed \add di řwesṭ n\add* izřan  
\m n uṣebbeḥ n Israil.   
\m
\v 5 Ttecřen xak řejdud nneɣ,  
\m tuɣa ttecřen u Cek tarrid ten ad nejmen.   
\m
\v 6 Nitni sɣuyen-dd ɣarek  
\m uca ttwassnejmen,  
\m tuɣa ttecřen xak u war nnḥecmen ca. \x ◘ \xo 22:6 \xt Izhd. 25:3; 31:2; Ica. 49:23; Rum. 9:33\x*   
\b  
\m
\v 7 Necc d ict n tkecca, war iǧi d aryaz,  
\m \add necc d\add* řḥegra n bnadem  
\m ttwasseḥqareɣ jar řgens. \f ◼ \fr 22:7 \ft \+fk akecca\ft  - amarir n uzehhed-a issarwas ixef nnes deg uzehhed-a ak-d ict n tkecca nni ittxeṣṣa ad temmet řami i dd-taru. Awarni i řmewt nnes ttɣiman idammen nnes izeggʷaɣen, war zemmaren ad ttwameṣhen. Idammen nni aqa iɣřan aṭṭas, ssxeddamen ten ḥima ad zzayes ggen ict n ssbaɣet. Man aya d ijj n uceyyar ɣar idammen n Yasuɛ Lmasiḥ, wenni d aneɣ ittexsen u wenni d aneɣ ittfekkan zi ddnub nneɣ s idammen nnes (Asa. 1:5).\f*   
\m
\v 8 Marra inni d ayi iẓrin,  
\m sthezzan zzayi,  
\m arezzmen iyencicen \add nsen\add*,  
\m ssenhezzan azeǧif. \x ◘ \xo 22:8 \xt Mt. 27:39\x*   
\m
\v 9 \add Qqaren\add*: “Seɛdu t x SIDI,  
\m ejj Wanita ad t ifekk, ad t issenjem,  
\m maɣar Netta yarḍa xas.” \x ◘ \xo 22:9 \xt Mt. 27:43\x*   
\b  
\m
\v 10 Cek tjebbded ayi-dd  
\m zeg uɛeddis n yemma,  
\m Cek tarrid ayi di řaman  
\m x wabbucen n yemma.   
\m
\v 11 Zi řemrawet ttwammenḍareɣ xak,  
\m zeg uɛeddis n yemma  
\m aqa Cek d Arebbi inu.   
\m
\v 12 War ttɣimi bu ɣar řaggʷaj zzayi,  
\m maɣar řeḥṣaret tudes  
\m u war din ca amɛawan.   
\b  
\m
\v 13 Aṭṭas n ifunasen nnḍen ayi-dd,  
\m \add ifunasen\add* ijehden zi Bacan  
\m quwwaren ayi-dd, \f ◼ \fr 22:13 \ft \+fk Bacan\ft  - Bacan d tammurt n řegɛudi n Julan jar Suriya d Israil.\f*   
\m
\v 14 arzmen-dd ɣari aqemmum nsen  
\m amecnaw ijj n weyrad  
\m ittmezzaqen, izehharen.   
\b  
\m
\v 15 Necc ttwafarrɣeɣ am waman  
\m u marra iɣsan inu ttwammsebḍan.  
\m Uř inu am ccmeɛ,  
\m aqa ifsi daxeř inu.   
\m
\v 16 Jjehd inu yuẓeɣ  
\m am yijj n uceǧiq n ict n tqedduḥt,  
\m iřes inu iřṣeq ɣar waneɣ inu.  
\m Cek tessarsed ayi di tɛejjajt n řmewt.   
\b  
\m
\v 17 Maɣar iṭan nnḍen ayi-dd,  
\m ict n bandiyya n tarwa n řeḥram  
\m quwwaren ayi-dd,  
\m aqa am weyrad ifassen d iḍaren inu. \f ◼ \fr 22:17 \ft \+fk aqa am weyrad ifassen d iḍaren inu\ft  - ḥima ad nefhem awařen-a ktar nzemmar ad nɣar ‘aqa am ayrad ixs ad izɛef ifassen d iḍaren inu’. Awařen-a daysen ijj n uceyyar ɣar řmewt n Yasuɛ Lmasiḥ x ṣṣalib řami ssnuqqben Irumaniyyen ifassen d iḍaren nnes, waxxa řmewt nnes temsar ktar zeg wařef n iseggʷusa awarni ma ad ittwari uzehhed-a. S uyenni aqa din ict n nnubuwa tameqqrant deg wawařen n uzehhed-a nni issawařen x řmewt n Yasuɛ Lmasiḥ s yijj n ccekl issedhacen u s yijj n usfarz d ameqqran.\f*  \x ◘ \xo 22:17 \xt Ica. 38:13; Mt. 27:35; Mk. 15:24; Lk. 23:33; Yḥ. 19:23,37; 20:25\x*   
\m
\v 18 Zemmareɣ ad ḥesbeɣ  
\m marra iɣsan inu.  
\m \bd Nitni\bd* ttwařan ayi, xezzaren-dd ɣari.   
\m
\v 19 Nitni bḍan arruḍ inu jar asen,  
\m uca nḍaren taqedduḥt x řeɛbayet inu. \x ◘ \xo 22:19 \xt Lk. 23:34; Yḥ. 19:24\x*   
\b  
\m
\v 20 Cek, \add a\add* SIDI, war \add ttiři\add*  
\m ɣar řaggʷaj, \add a\add* jjehd inu,  
\m as-dd deɣya ḥima ad ayi tɛawned.   
\m
\v 21 Fekk řeɛmar inu zi ssif,  
\m ayenni zeg uqeṭṭes n weqzin.   
\m
\v 22 Fekk ayi zeg uqemmum n weyrad,  
\m \add fekk ayi\add* zeg waccawen d iziraren  
\m n iɣayḍ n řexřa!  
\m Aqa Cek tesřid ayi.   
\b  
\m
\v 23 Ad barrḥeɣ Isem nnec i wawmaten inu,  
\m ad xak ṣebḥeɣ di řwesṭ n wegraw n řgens. \x ◘ \xo 22:23 \xt Ɛbr. 2:12\x*   
\m
\v 24 Kenniw, inni itteggʷden SIDI,  
\m semɣarem t,  
\m \add a kenniw,\add* marra zzariɛet n Yaɛqub,  
\m sɛuǧem t u weqqarem t,  
\m \add a kenniw,\add* marra zzariɛet n Israil!   
\b  
\m
\v 25 Maɣar war isseḥqir ca  
\m řeḥṣaret n wenni ittwaḥṣaren,  
\m war tt iɛiff ca,  
\m war xas issnuffar ca udem nnes,  
\m \add maca\add* Netta isřa as mařa iřaɣa as-dd.   
\b  
\m
\v 26 Zzayek ad dd-yas uqadi inu  
\m deg ijj n wegraw \add n řgens\add* ameqqran,  
\m ad kemmřeɣ lwuɛud inu  
\m zzat i yinni zzayes itteggʷeden.   
\m
\v 27 Imwaḍɛen ad ccen u ad jjiwnen,  
\m inni arezzun x SIDI ad as ṣebbḥen,  
\m uřawen nsen ad ddaren i řebda.   
\b  
\m
\v 28 Marra tineggura n temmurt ad t idarent,  
\m ad dd-dewřent ɣar SIDI,  
\m marra řaǧat n řegnus  
\m ad sejdent zzat i wudem nnec, \x ◘ \xo 22:28 \xt Izhd. 2:8; 72:11; 86:9; Asa.15:4\x*   
\m
\v 29 minzi tageldit i SIDI \add i teǧa\add*,  
\m Netta iḥekkem jar řegnus.   
\m
\v 30 Marra inni iṣeḥḥen di temmurt  
\m ad ccen, ad sejden,  
\m marra inni dd-ihekkwan di tɛejjajt  
\m ad sejden zzat i wudem nnes,  
\m \add kuř ijjen\add* i war izemmaren  
\m ad iḥḍa řeɛmar nnes.   
\m
\v 31 Zzariɛet ad as tsexxar,  
\m ad tᵉttwazemm d arraw i Sidi inu.   
\m
\v 32 Ad dd-asen, ad barrḥen tasegda nnes  
\m i yijj n řgens i ɣa dd-ittwaxeřqen,  
\m maɣar Netta aqa igga i-tt. \x ◘ \xo 22:32 \xt Izhd. 52:11\x*   
\b  
\b  
\m  
\c 23
\m
\v 1 \add Azehhed n Dawud.\add*  
\b  
\m SIDI d Ameksaw inu,  
\m war xafi ittekk ca zzɛaf. \x ◘ \xo 23:1 \xt Ica. 40:11; Irm. 23:4; Ḥiz. 34:23; Yḥ. 10:11; 1 Bṭ. 2:25; Asa. 7:17\x*   
\m
\v 2 Netta issareyyaḥ ayi  
\m di ddmani n tarewsa izizawen,  
\m ineddeh ayi ɣar waman yarsan.   
\m
\v 3 Netta issfaqa řeɛmar inu,  
\m ineddeh ayi di řatarat n tsegda  
\m di ṭṭweɛ n Yisem nnes.   
\b  
\m
\v 4 Waxxa ggureɣ  
\m di teɣzurt n tiři n řmewt,  
\m war tteggʷdeɣ zi řɣar,  
\m maɣar Cek akidi.  
\m Aɛekkaz nnec d taɣɣarct nnec  
\m ssfewwajen xafi. \x ◘ \xo 23:4 \xt Izhd. 3:6; 118:6\x*   
\m
\v 5 Tessewjaded ṭṭabřa inu  
\m zzat i wudem n yinni d ayi iḥeṣṣaren.  
\m Tdehhned azeǧif inu s zzect,  
\m řkas inu ifeyyeḍ.   
\b  
\m
\v 6 Iwa, řxir d tmexsiwt icewwaren  
\m ad ayi ḍfaren,  
\m marra ussan n tudart inu,  
\m necc ad zedɣeɣ di Taddart n SIDI,  
\m ař aneggar n wussan.   
\b  
\b  
\m  
\c 24
\m
\v 1 \add Azehhed n Dawud.\add*  
\m \add A. Azehhed umi ttgeɛɛden ɣar wedrar n Ṣihyun\add*  
\m \add Marra imeɣnajen n řɣaci ittɛeyyden:\add*  
\b  
\m I SIDI teǧa temmurt d uɛemmar nnes,  
\m ddunect d imezdaɣ nnes.\x ◘ \xo 24:1 \xt Uf. 19:5; Aɛwd. 10:14; Ayub 41:3; Izhd. 50:12; 1 Kur. 10:26, 28\x*   
\m
\v 2 Maɣar \bd Netta\bd* issars dsas nnes x řebḥur,  
\m issemten i-t x sseḥřat.   
\b  
\m
\v 3 \add Tmijja:\add*  
\m Wi izemmaren ad igeɛɛed adrar n SIDI,  
\m wi izemmaren ad ibedd  
\m deg wemcan nnes iqeddsen? \x ◘ \xo 24:3 \xt Izhd. 15:1; Ica. 33:14, 15\x*   
\b  
\m
\v 4 \add Tmijja nneɣni:\add*  
\m Wenni ɣar iǧa ifassen imezdagen  
\m d wuř iṣfa,  
\m wenni war dd-ittarri řeɛmar nnes  
\m x řɣecc,  
\m war ittjjaǧa ẓur!   
\b  
\m
\v 5 \add Marra imeɣnajen:\add*  
\m Netta ad iksi lbaraka zi SIDI,  
\m uřa d tasegda zi AREBBI n usenjem nnes.   
\m
\v 6 D wa d jjiř n yinni xas yarezzun,  
\m inni yarezzun x wudem nnec,  
\m aqa-t d Yaɛqub. Silah.   
\b  
\m
\v 7 \add B. Azehhed umi udfen ɣar tendint n Ṣihyun\add*  
\m \add Marra imeɣnajen n řɣaci ittɛeyyden:\add*  
\m Sgeɛɛdent izeǧifen nwem, \add a\add* tiwwura,  
\m sgeɛɛdent ixef nkent, \add a\add* tiwwura n řebda,  
\m \add ḥima\add* ad yadef Ujeǧid n uɛuǧi!   
\b  
\m
\v 8 \add Tmijja zi tewwurt n tendint:\add*  
\m Man wen i iǧan d Ajeǧid n uɛuǧi wanita?  
\m \add Marra imeɣnajen:\add*  
\m D SIDI, ijhed ijebbar,  
\m SIDI aqa-t d ajebbar deg umenɣi.   
\m
\v 9 Sgeɛɛdent izeǧifen nkent, \add a\add* tiwwura,  
\m sgeɛɛdent ixef nkent, \add a\add* tiwwura n řebda,  
\m \add ḥima\add* ad yadef ujeǧid n uɛuǧi!   
\b  
\m
\v 10 \add Tmijja zi tewwart n tendint:\add*  
\m Min iɛna Netta, Ajeǧid-a n uɛuǧi?  
\m \add Marra imeɣnajen:\add*  
\m SIDI n řɛeskarat  
\m d Netta d Ajeǧid n uɛuǧi. Silah.   
\b  
\b  
\m  
\c 25
\m
\v 1 \add Azehhed n Dawud.\add*  
\b  
\m \bd Alif.\bd* \add A\add* SIDI,  
\m ɣarek i dd-ssgeɛɛadeɣ řeɛmar inu.   
\m
\v 2 \bd Bit.\bd* \add A\add* AREBBI inu, necc ttecřeɣ xak.  
\m Ejj ayi war ttseḍḥiɣ,  
\m ejj řɛedyan inu  
\m war xafi ttesřiwřiwen s řefraḥet. \x ◘ \xo 25:2 \xt Izhd. 22:6; 31:2; 34:6\x*   
\m
\v 3 \bd Gimel.\bd* Wah, marra inni Cek ittrajan  
\m war ttseḍḥin.  
\m Inni iggin s řeɣdar břa ssibbet,  
\m ad seḍḥen. \x ◘ \xo 25:3 \xt Ica. 28:16; Rum. 10:11\x*   
\m
\v 4 \bd Dalit.\bd* \add A\add* SIDI, scen ayi ibriden nnec,  
\m sɣar ayi imesraq nnec. \x ◘ \xo 25:4 \xt Izhd. 27:11; 86:11\x*   
\m
\v 5 \bd Hi.\bd* Ndeh ayi di tidett nnec u sɣar ayi,  
\m minzi Cek d AREBBI n usenjem inu,  
\m necc ssitimeɣ dayek ass marra.   
\m
\v 6 \bd Zayin.\bd* Ɛqeř, \add a\add* SIDI, x arreḥmet nnec,  
\m x tmegga n tmexsiwt nnec icewwaren,  
\m maɣar aqa atent \add ǧant\add* zi řebda. \x ◘ \xo 25:6 \xt Izhd. 103:17; 106:1; 107:1; 117:2, 136; Irm. 33:11\x*   
\m
\v 7 \bd Xit.\bd* War ttidar ca ddnub n temẓi inu  
\m uřa d ixeṭṭan inu.  
\m Xemm \add maca\add* ɣari  
\m di tmexsiwt nnec icewwaren,  
\m di ṭṭweɛ n tcuni nnec, \add a\add* SIDI.   
\m
\v 8 \bd Tit.\bd* SIDI iṣbeḥ, icna,  
\m x uya ad issɣar abrid i imednab.   
\m
\v 9 \bd Yud.\bd* Netta ad igewwed imhinen s řḥeqq,  
\m Netta ad isseřmed abrid nnes i imhinen.   
\m
\v 10 \bd Kaf.\bd* Marra imesraq n SIDI  
\m aqa aten d tamexsiwt icewwaren d řaman,  
\m i yinni iḥeṭṭan Řɛahd nnes  
\m d ccahadat nnes.   
\m
\v 11 \bd Lamid.\bd* Di ṭṭweɛ n Yisem nnec, \add a\add* SIDI,  
\m ɣfar řmuɛṣiyyet inu,  
\m maɣar aqa-tt d aṭṭas.   
\m
\v 12 \bd Mim.\bd* Man wen d aryaz  
\m i itteggʷeden SIDI?  
\m Netta ad as isseřmed abrid  
\m i ittxeṣṣa ad ixḍar.   
\m
\v 13 \bd Nun.\bd* Řeɛmar nnes ad issens di řxir,  
\m tarwa nnes ad twart tammurt.   
\m
\v 14 \bd Samix.\bd* Řaman i din n SIDI  
\m i yinni zzayes itteggʷeden,  
\m Řɛahd nnes aqa-t din  
\m maḥend ad asen t issargeb.   
\m
\v 15 \bd Ɛayin.\bd* Tiṭṭawin inu řebda di SIDI,  
\m minzi \bd Netta\bd* ad ifekk iḍaren inu zi tracca.   
\m
\v 16 \bd Pi.\bd* Arr-dd ɣari s wudem nnec, ḥinn xafi,  
\m maɣar necc aqa ayi weḥḥdi u di řeɣben.   
\m
\v 17 \bd Tsadi.\bd* Řeḥṣarat n wuř inu  
\m aqa mmarnint.  
\m Suffeɣ ayi zi ddiqat i d ayi.   
\m
\v 18 \bd Rix.\bd* Xzar-dd ɣar řeɣben inu d warber inu,  
\m ksi xafi marra ddnub inu.   
\m
\v 19 \bd Rix.\bd* Xzar ɣar řɛedyan inu,  
\m minzi ttwakettaren,  
\m nitni carrhen ayi s yijj n wecrah iqesḥen.   
\m
\v 20 \bd Cin.\bd* Ḥḍa x řeɛmar inu u fekk ayi!  
\m War d ayi ttejji ca ad seḍḥiɣ,  
\m minzi ɣarek i ɣa arekkwařeɣ.   
\m
\v 21 \bd Taf.\bd* Ad teḥḍa ayi řekmaret d řeṣfayet,  
\m maɣar ssitimeɣ dayek.   
\m
\v 22 \add A\add* AREBBI, fdi Israil zi marra řeḥṣarat nnes.   
\b  
\b  
\m  
\c 26
\m
\v 1 \add Azehhed n Dawud.\add*  
\b  
\m Aɣ ayi tasɣart inu, \add a\add* SIDI,  
\m maɣar \bd necc\bd* ggureɣ di řeṣfayet inu.  
\m Necc ttecřeɣ x SIDI,  
\m war ttefriɣeɣ ca. \x ◘ \xo 26:1 \xt Izhd. 7:9\x*   
\m
\v 2 Qeǧeb ayi, \add a\add* SIDI, jarreb ayi,  
\m seṣfa tiẓẓař inu d wuř inu. \f ◼ \fr 26:2 \ft \+fk tiẓẓař\ft  - niɣ ‘tigeẓřin’.\f*   
\m
\v 3 Minzi tamexsiwt nnec icewwaren  
\m aqa-tt zzat i tiṭṭawin inu,  
\m necc ggureɣ di tidett nnec.   
\b  
\m
\v 4 Necc war ttɣimiɣ  
\m ak-d iryazen war isekkwin,  
\m war ttmuneɣ ak-d yinni icemmten. \x ◘ \xo 26:4 \xt Ayub 31:5; Izhd. 1:1\x*   
\m
\v 5 Necc carrheɣ agraw n tarwa n řehram,  
\m war ttɣimiɣ ak-d iɛeffanen.   
\b  
\m
\v 6 Necc ssirideɣ ifassen inu  
\m am war dayi řɛib,  
\m ttennḍeɣ i uɛalṭar nnec,  
\m \add řmedbeḥ nnec n wecmaḍ\add*, \add a\add* SIDI,   
\m
\v 7 maḥend ad ssgeɛɛdeɣ  
\m tmijja teccur s uqadi,  
\m maḥend ad barrḥeɣ s marra lmuɛjizat nnec.   
\m
\v 8 \add A\add* SIDI, necc ttexseɣ  
\m Tazeddiɣt n Taddart nnec,  
\m uřa d amcan n Tzeddiɣt n uɛuǧi nnec.   
\b  
\m
\v 9 War smuna řeɛmar inu ak-d imednab,  
\m uřa d tudart inu ɣar iryazen  
\m \add i issazzařen\add* idammen.   
\m
\v 10 inni ɣar iǧa ifassen nsen  
\m \add ccuren s\add* tuɛeffna,  
\m afus nsen afusi \add iccur\add* s řɣecc.   
\m
\v 11 \bd Necc\bd* ggureɣ di řeṣfayet inu,  
\m fdi ayi u ḥinn xafi.   
\b  
\m
\v 12 Aḍar inu ibedd x temmurt iwaṭan.  
\m Necc ad barkeɣ SIDI di tmesmunin.   
\b  
\b  
\m  
\c 27
\m
\v 1 \add Azehhed n Dawud.\add*  
\b  
\m SIDI d tafawt inu d usenjem inu,  
\m wi zi ɣa ggʷedeɣ?  
\m SIDI d lqelɛa ijehden i tudart inu,  
\m wi zi ɣa nnxeřɛeɣ \add ɛad\add*? \x ◘ \xo 27:1 \xt Ica. 10:17; 60:19, 20; Mixa 7:8; Lk. 1:79; Yḥ. 1:4; 8:12; Asa. 21:23\x*   
\m
\v 2 Umi ɣari dd-qarrben iɛeffanen  
\m ḥima ad ccen ddat inu,  
\m inni d ayi iḥeṣṣaren d řɛedyan inu,  
\m nnqarḍen nitni, wḍan \add ɣar temmurt\add*.   
\m
\v 3 Waxxa ad xafi iḥjem ijj n řɛeskar,  
\m uř inu war itteggʷed ca.  
\m Waxxa ad xafi ikkar umenɣi,  
\m \add ɛad\add* necc ttɣimiɣ ttecřeɣ. \x ◘ \xo 27:3 \xt Lk. 10:42; Fil. 3:14\x*   
\b  
\m
\v 4 Ict n řḥajjet ttareɣ zi SIDI,  
\m ta ad xas arzuɣ:  
\m min ɣa kkeɣ ddareɣ ad qqimeɣ  
\m ad zedɣeɣ di Taddart n SIDI,  
\m ḥima ad ẓareɣ řeḍrafet n SIDI,  
\m ḥima ad beqceɣ  
\m di Zzawect nnes Tameqqrant.   
\m
\v 5 Maɣar Netta issdurruy ayi  
\m deg uɛucci nnes  
\m deg wass n řɣar.  
\m Netta issřeqqa ayi  
\m deg useřqi n Uqiḍun nnes,  
\m Netta issgeɛɛad ayi x ict n teṣḍart.   
\b  
\m
\v 6 Řexxu ad ittwassgeɛɛed uzeǧif inu  
\m x řɛedyan inu inni d ayi dd-innḍen,  
\m ɣar wesruddeḥ \add di řbuq\add* ad awyeɣ tiɣarṣa  
\m ɣar Uqiḍun nnes,  
\m ad ɣennjeɣ, \add wah,\add* ad zehhdeɣ i SIDI.   
\b  
\m
\v 7 Seř ɣar tmijja inu, \add a\add* SIDI, xmi ɣa řaɣiɣ,  
\m ḥinn xafi u arr-dd xafi.   
\m
\v 8 Zzayek i issawař wuř inu:  
\m “Arzu x wudem inu!”  
\m Necc arezzuɣ x wudem nnec, \add a\add* SIDI.   
\b  
\m
\v 9 War zzayi tteffar udem nnec,  
\m war ttxiyyab amsexxar nnec  
\m deg weɣḍab.  
\m Tuɣa Cek d amɛawen inu.  
\m War d ayi ttsemḥed u war d ayi ttejji,  
\m \add a\add* AREBBI n usenjem inu.   
\m
\v 10 Maɣar baba d yemma aqa semḥen dayi,  
\m \add maca\add* SIDI ad ayi iksi \add ɣares\add*.   
\b  
\m
\v 11 Scen ayi abrid nnec, \add a\add* SIDI,  
\m ndeh ayi ɣar webrid iseggmen,  
\m di ssibbet n yinni d ayi iḥeṣṣaren. \x ◘ \xo 27:11 \xt Izhd. 25:4; 86:11; 119:27\x*   
\m
\v 12 War d ayi ttsellem ɣar \add meẓri\add*  
\m \add deg\add* řeɛmar n yinni d ayi iḥeṣṣaren,  
\m maɣar řechud issxarriqen kkaren xafi,  
\m inni \add i xafi\add* ittsuḍen s řexcunet.   
\b  
\m
\v 13 \add Uh\add*, mařa necc zeɛma  
\m war umineɣ ad ẓareɣ řxar n SIDI  
\m di temmurt n yinni iddaren!   
\m
\v 14 Raja SIDI, raja i-t, iři d aryaz,  
\m Netta ad dayek yegg uř,  
\m \add wah\add* raja SIDI. \x ◘ \xo 27:14 \xt Ica. 25:9; 33:2; Ḥab. 2:3\x*   
\b  
\b  
\m  
\c 28
\m
\v 1 \add N Dawud.\add*  
\b  
\m I Cek umi řaɣiɣ,  
\m \add a\add* SIDI, aqa Cek d Taṣḍart inu.  
\m War ttegg ca Ixef nnec  
\m war ɣari tᵉttesřid,  
\m ařami, s wesqar nnec zzati,  
\m war ttarekkwiseɣ  
\m ak-d yinni dd-ihekkwan deg wenḍeř. \x ◘ \xo 28:1 \xt Izhd. 30:4; 143:7\x*   
\m
\v 2 Seř i tmijja n tutra inu,  
\m xmi xak ttřaɣiɣ,  
\m xmi kessiɣ ifassen inu  
\m ɣar Wexxam \add n Daxeř\add*  
\m n Zzawect nnec Iqeddsen.   
\m
\v 3 War d ayi ttjarri ak-d iɛeffanen,  
\m ak-d yinni itteggen řmuɛṣiyyet,  
\m inni issawařen x řehna  
\m ak-d jjiran nsen,  
\m am ɣarsen iǧa řɣar deg wuř nsen. \x ◘ \xo 28:3 \xt Izhd. 12:3; Irm. 9:7\x*   
\m
\v 4 Xeǧeṣ asen ɛlaḥsab min tteggen,  
\m ɛlaḥsab tuɛeffna n tmegga nsen.  
\m Xeǧeṣ asen  
\m ɛlaḥsab řxedmet n ifassen nsen,  
\m ewc asen řmunet nsen i isdaheǧen,   
\m
\v 5 minzi nitni war xezzaren  
\m ɣar řefɛayeř n SIDI,  
\m uřa ɣar řxedmet n ifassen nnes.  
\m Netta ad ten iɣḍeř, war ten ibenni ca.   
\b  
\m
\v 6 Ad ittwabarek SIDI,  
\m maɣar Netta isřa i tmijja n tutra inu.   
\m
\v 7 SIDI d řɛezz inu  
\m d taseddart inu n useřqi,  
\m uř inu ittceř xas uca ttwaɛawneɣ.  
\m Uř inu ineggez s řefraḥet,  
\m s yezři inu ad t qadiɣ.   
\m
\v 8 SIDI d jjehd nsen,  
\m Netta d lburj ijehden n isenjimen  
\m i umedhun nnes.   
\m
\v 9 Senjem řgens nnec, barek tasɣart nnec,  
\m arwes i-ten u arbu ten i řebda qaɛ.   
\b  
\b  
\m  
\c 29
\m
\v 1 \add Azehhed n Dawud.\add*  
\b  
\m Wcem i SIDI, arraw n irebbiten,  
\m wcem i SIDI aɛuǧi d tzemmar. \x ◘ \xo 29:1 \xt Izhd. 96:7, 8\x*   
\m
\v 2 Wcem i SIDI aɛuǧi n Yisem nnes,  
\m bendqem zzat i SIDI  
\m di řɛezz n Zzawect iqeddsen.   
\b  
\m
\v 3 \bd Tmijja n SIDI\bd* \add teddarḍeḥ\add* tiwa i waman,  
\m Arebbi n uɛuǧi isshemhem,  
\m SIDI, x waman aṭṭas. \x ◘ \xo 29:3 \xt Uf. 9:23\x*   
\m
\v 4 \bd Tmijja n SIDI\bd* \add teccur s\add* jjehd,  
\m \bd tmijja n SIDI\bd* \add teccur s\add* řɛezz.   
\b  
\m
\v 5 \bd Tmijja n SIDI\bd* tᵉttareẓẓa  
\m \add ticejjura n\add* tneglin,  
\m SIDI ittareẓẓa tineglin n Lubnan.   
\m
\v 6 Yarra i-ten ad negzen am uɛejmi,  
\m \add adrar n\add* Lubnan d \add wedrar n\add* Siryun,  
\m am umeẓyan n iɣayḍ n řexřa  
\m ak-d waccawen d iziraren. \f ◼ \fr 29:6 \ft \+fk afunas n řexřa\ft  - niɣ ‘ayenduz n řexřa’.\f*   
\m
\v 7 \bd Tmijja n SIDI\bd* tneqqec  
\m iceɛɛařen n tmessi.   
\b  
\m
\v 8 \bd Tmijja n SIDI\bd* tarra řexřa ittarjiji,  
\m SIDI yarra řexřa n Qadac ittarjiji.   
\m
\v 9 \bd Tmijja n SIDI\bd* tarra tudadin ttarwent,  
\m Netta ittɛarra izeɣran,  
\m \add maca\add* di Zzawect nnes Tameqqrant  
\m marra tessawař x uɛuǧi nnes.   
\b  
\m
\v 10 SIDI tuɣa ittɣima \add am řqaḍi\add*  
\m ɣar sseḥřet n waman,  
\m SIDI ittɣima \add am\add* Ujeǧid i řebda. \f ◼ \fr 29:10 \ft \+fk řqaḍi\ft  - niɣ ‘amezruf’.\f*   
\m
\v 11 SIDI ad iwc jjehd i řgens nnes,  
\m SIDI ad ibarek řgens nnes s řehna.   
\b  
\b  
\m  
\c 30
\m
\v 1 \add Azehhed. Izři i udeccen n taddart. N Dawud.\add*   
\b  
\m
\v 2 Necc ad Cek ssuɛřiɣ, \add a\add* SIDI,  
\m maɣar Cek tessgeɛɛded ayi,  
\m war tejjid ca řɛedyan inu  
\m ad farḥen x weɛrur inu.   
\m
\v 3 \add A\add* SIDI, AREBBI inu, necc řaɣiɣ ac,  
\m uca Cek tessgenfid ayi.   
\m
\v 4 \add A\add* SIDI, cek tessuɛřid řeɛmar inu  
\m zi řaxart,  
\m tarrid ayi-dd ɣar tudart  
\m jar yinni dd-ihekkwan deg weḥfur.   
\b  
\m
\v 5 Zehhdem i SIDI,  
\m \add a kenniw,\add* imtiqqan nnes,  
\m qadam, ɛeqřem x tqeddast nnes. \x ◘ \xo 30:5 \xt Izhd. 97:12\x*   
\m
\v 6 Maɣar aɣḍab nnes \add ittekk\add* drus \add waha\add*,  
\m maca arḍa nnes ittɣima \add marra\add* tudart.  
\m Di tmeddit aqa din imeṭṭawen ař ǧiřet,  
\m \add maca\add* ɣar tuffut aqa din asřiwřew.   
\b  
\m
\v 7 Deg ufřaḥ inu nniɣ \bd necc\bd*:  
\m “War ttfariɣeɣ ca i řebda!”   
\m
\v 8 \add A\add* SIDI, di řxaḍar nnec  
\m tessmetned adrar inu  
\m s umetten ijehden,  
\m \add maca\add* umi třeḥḥfed udem nnec,  
\m dewřeɣ tteggʷedeɣ.   
\b  
\m
\v 9 Necc řaɣiɣ ac-dd, \add a\add* SIDI,  
\m ttareɣ arḍa zi Sidi inu.   
\m
\v 10 Man řefḍeř n idammen inu,  
\m n uhekkwu inu ɣar turṣuḍi \add deg wenḍeř\add*?  
\m Ma ad Cek tqada tɛejjajt?  
\m Ma ad tbarreḥ s řaman nnec?   
\m
\v 11 Seř-dd ɣari, \add a\add* SIDI, ḥinn xafi,  
\m \add a\add* SIDI, iři d amɛawen inu.   
\b  
\m
\v 12 Cek aqa tarrid tɣuyyit inu \add n wecḍan\add*  
\m d ccḍiḥ s nnubtat,  
\m tessarxud taxancet inu \add n wecḍan\add*,  
\m tessbeysed ayi s řefraḥet,   
\m
\v 13 ḥima aɛuǧi \add inu\add*  
\m ad ac izehhed u war ittsusum.  
\m \add A\add* SIDI, AREBBI inu,  
\m necc ad Cek qadiɣ i řebda.   
\b  
\b  
\m  
\c 31
\m
\v 1 \add I umeqqran n imeɣnajen. Azehhed n Dawud.\add*   
\b  
\m
\v 2 Necc arekkwařeɣ ɣarek, \add a\add* SIDI,  
\m war ttejji ad seḍḥiɣ i řebda,  
\m fekk ayi s tsegda nnec. \x ◘ \xo 31:2 \xt Izhd. 22:6; 25:2, 3; 71:1, 2; Ica. 49:23\x*   
\m
\v 3 Ewc ayi amezzuɣ nnec, fekk ayi deɣya.  
\m Iři d Taṣḍart ijehden i necc,  
\m ijj n lburj ḥima ad ayi tessnejmed.   
\m
\v 4 Maɣar Cek d Taṣḍart inu d lburj inu.  
\m Ndeh ayi, thilla dayi  
\m di ṭṭweɛ n Yisem nnec.   
\m
\v 5 Fekk ayi zi tracca  
\m nni xafi ggin s tnuffra,  
\m maɣar Cek d jjehd inu.   
\m
\v 6 Deg ufus nnec i ggiɣ buḥbeř inu.  
\m Cek tefdid ayi, \add a\add* SIDI, Arebbi,  
\m d amtiqqi \add i teǧid\add*. \x ◘ \xo 31:6 \xt Lk. 23:46\x*   
\m
\v 7 Necc carrheɣ inni ittceɣřen ixef nsen  
\m s \add řexyařat\add* ibeṭṭřen.  
\m \bd Necc\bd* ttecřeɣ x SIDI.   
\m
\v 8 Necc ad arecqeɣ u ad farḥeɣ  
\m zi tmexsiwt nnec icewwaren,  
\m minzi Cek tᵉttwařid řeɣben inu  
\m \add u\add* tareggbed x řeḥṣarat inu,   
\m
\v 9 \add minzi\add* war d ayi tarrid  
\m ɣar ufus n řeɛdu inu,  
\m \add maca\add* teggid ayi ttasiɛ ɣar iḍaren inu.   
\b  
\m
\v 10 Ḥinn xafi, \add a\add* SIDI, maɣar ttwaḥeṣṣareɣ,  
\m tiṭṭ inu d řeɛmar inu d tekrict inu  
\m aqa fecřen.   
\m
\v 11 Maɣar tudart inu tkemmeř s wecḍan,  
\m iseggʷusa inu s uzehhar.  
\m Jjhed inu iheyyef zi řmuɛṣiyyet inu,  
\m ixsan inu aqa arcan.   
\m
\v 12 I marra inni d ayi iḥeṣṣaren  
\m dewřeɣ d astehzi,  
\m i jjiran inu \add qaɛ\add* aṭṭas,  
\m i yinni d ayi issnen  
\m \add dewřeɣ\add* d ijjen i issnexřiɛen.  
\m Inni d ayi ittwařin deg webrid,  
\m ttrakkwařen zzayi. \x ◘ \xo 31:12 \xt Ayub 19:13; Izhd. 38:12\x*   
\m
\v 13 Ttun ayi s wuř am yijj n umettin,  
\m dewřeɣ am yiceqfan n weqdiḥ,   
\m
\v 14 maɣar sřiɣ aqa aṭṭas ceqqfen \add dayek\add*,  
\m assiggʷed tuɣa ittenneḍ ayi-dd  
\m umi xafi ggin tameɛmuč.  
\m Tuɣa arezzun ad kksen tudart inu.   
\b  
\m
\v 15 \add Maca\add* \bd necc\bd* ttecřeɣ xak, \add a\add* SIDI,  
\m qqareɣ: ‘Cek d AREBBI inu!’   
\m
\v 16 Řweqt inu aqa-tt deg ufus nnec.  
\m Fekk ayi zeg ufus n řɛedyan inu  
\m u zeg inni d ayi iḍeffaren,   
\m
\v 17 Ejj udem nnec ad yarɣ  
\m x umsexxar nnec,  
\m senjem ayi s tmexsiwt nnec icewwaren.   
\m
\v 18 \add A\add* SIDI, war ttejji ad dewřeɣ ttseḍḥiɣ,  
\m maɣar xak i ttřaɣiɣ.  
\m Arr iɛeffanen ad dewřen ttseḍḥan,  
\m arr i-ten ad ssusmen di řaxart.   
\m
\v 19 Ejj ad sqaren iyencicen issxarriqen,  
\m inni issawařen s nnfaxet  
\m ḍidd i umsegged,  
\m s uɛeffar d useḥqar.   
\b  
\m
\v 20 Mecḥař imeqqar řxar nnec i txemmřed  
\m i yinni Cek itteggʷeden,  
\m nni tesswejded i yinni ɣarek yarekkwařen  
\m zi tarwa n bnadem! \x ◘ \xo 31:20 \xt Ica. 64:3; 1 Kur. 2:9\x*   
\m
\v 21 Cek tessdurruyed i-ten s uřeḥḥaf  
\m n wudem nnec,  
\m zi nnfaxet n bnadem.  
\m Cek tessnuffared i-ten di texzant,  
\m zeg umcubbec n iyencicen.   
\m
\v 22 Ad ittwabarek SIDI,  
\m maɣar Netta yarra ayi-dd  
\m tamexsiwt nnes icewwaren d řeɛjeb,  
\m deg ict n tendint ifaryen.   
\m
\v 23 Necc deɣya nniɣ:  
\m “Necc ttwaqesseɣ  
\m zi zzat i tiṭṭawin nnec!’  
\m Maca ɛad Cek tesřid i tmijja inu,  
\m umi dd xak řaɣiɣ. \x ◘ \xo 31:23 \xt Yun. 2:5\x*   
\m
\v 24 Sɛizzem SIDI, marra imtiqqan nnes,  
\m maɣar SIDI iḥeṭṭa x yinni ittamnen,  
\m u wenni itteggen s nnfaxet,  
\m ittxeǧeṣ i-t s aṭṭas.   
\m
\v 25 Iřim d iryazen  
\m u Netta ad daywem yegg uř,  
\m \add wah\add*, marra inni ittrajan SIDI. \x ◘ \xo 31:25 \xt Izhd. 27:14\x*   
\b  
\b  
\m  
\c 32
\m
\v 1 \add N Dawud. Axemmi.\add*  
\b  
\m Sseɛd n wenni  
\m umi tᵉttwaɣfar tɛeddit nnes,  
\m wenni umi dřin x ddnub nnes. \x ◘ \xo 32:1 \xt Rum. 4:6, 7\x*   
\m
\v 2 Sseɛd n weryaz  
\m wenni umi war iḥeṣṣeb SIDI  
\m řmuɛṣiyyet nnes,  
\m wenni ɣar iǧa buḥbeř war dayes bu řɣecc.   
\b  
\m
\v 3 Umi sqareɣ, arcan iɣsan inu,  
\m s uzehhar inu, ass marra.   
\m
\v 4 Maɣar ass d ǧiřet  
\m issedqeř ayi ufus nnec,  
\m idammen n tudart inu dewřen  
\m \add am\add* řaẓaɣ n unebdu. Silah.   
\m
\v 5 Ssaregbeɣ ac ddenb inu,  
\m war ssduryeɣ řmuɛṣiyyet inu.  
\m Necc nniɣ:  
\m “Ad neɛmeɣ x ixeṭṭan inu ɣar SIDI!”,  
\m \add xenni\add* \bd Cek\bd* teɣfared ayi  
\m řmuɛṣiyyet n ddenb inu. Silah. \x ◘ \xo 32:5 \xt Awřn. 28:13; 1 Yḥ. 1:9\x*   
\b  
\m
\v 6 S uyenni marra amtiqqi ad ac isjed  
\m di řweqt umi ɣa tejjed \add bnadem\add*  
\m ad Cek yufa.  
\m Xmi din ict n sseḥřet n waman aṭṭas,  
\m war t třeqqef qaɛ.   
\m
\v 7 Cek d amcan n udurri i necc,  
\m tessared ayi zi řeḥṣaret,  
\m tquwwared ayi  
\m s iɣuyyan n řefraḥet n ufekki. Silah. \x ◘ \xo 32:7 \xt Izhd. 27:5; 31:21\x*   
\b  
\m
\v 8 Necc ad cek wceɣ řefhamet  
\m uca ad ac ssřemdeɣ  
\m abrid ittxeṣṣa ad dayes tuyured.  
\m Necc ad cek weṣṣiɣ, ad xak tiři tiṭṭ inu.   
\m
\v 9 War ttiři am uyis,  
\m am usardun břa řeɛqeř,  
\m nni ittxeṣṣa ad ten qemmɛen  
\m s ssrimet d weryam,  
\m niɣ war izemmar ad ɣarek dd-iqarreb. \x ◘ \xo 32:9 \xt Awřn. 26:3; Yaɛ. 3:3\x*   
\m
\v 10 Aṭṭas \add ǧant\add* tamara n uɛeffan,  
\m \add maca\add* wenni ittcařen x SIDI,  
\m ad as iquwwar Netta  
\m s tmexsiwt nnes icewwaren.   
\b  
\m
\v 11 Farḥem di SIDI, arecqem, \add a\add* imseggaden,  
\m sřiweřwem, \add a\add* marra  
\m inni ɣar iǧa wuř iseggmen!   
\b  
\b  
\m  
\c 33
\m
\v 1 Sřiweřwem i SIDI, \add a\add* imseggaden,  
\m aṣebbaḥ d ict n telwizt i yinni iseggmen. \x ◘ \xo 33:1 \xt Izhd. 147:1\x*   
\m
\v 2 Qadam SIDI s řgambri,  
\m zehhdem as s lɛud  
\m u s lharpa ak-d ɛecra n ifiřan.   
\m
\v 3 Ɣennjem as s yijj n yezři amaynu,  
\m irarem mliḥ s wesruddeḥ \add n řbuq\add*. \x ◘ \xo 33:3 \xt Izhd. 40:4; 96:1; 98:1; 144:9; Ica. 42:10; Asa. 5:9; 14:3\x*   
\b  
\m
\v 4 Minzi awař n SIDI iseggem,  
\m marra min ittegg, \add ittegg i-t\add* s řaman.   
\m
\v 5 Netta ittexs tasegda d řḥeqq.  
\m Tammurt teccur  
\m s tmexsiwt icewwaren n SIDI. \x ◘ \xo 33:5 \xt Izhd. 45:8; 119:64; Ɛbr. 1:9\x*   
\b  
\m
\v 6 Zeg wawař n SIDI ttwaggen ijenwan,  
\m zi Arruḥ n uqemmum nnes  
\m \add ttwaggent\add* marra řɛeskarat nsen. \x ◘ \xo 33:6 \xt Amz. 1:6, 7\x*   
\m
\v 7 Netta issmun aman n řebḥar  
\m am yijj n weɣbar.  
\m Netta ixemmeř \add aman\add* ihewřen  
\m deg ixxamen n řexzen.   
\b  
\m
\v 8 Ad teggʷed marra tammurt zi SIDI,  
\m ad zzayes ggʷeden  
\m marra imezdaɣ n ddunect.   
\m
\v 9 Maɣar \bd Netta\bd* issawař uca aqa-t din,  
\m \bd Netta\bd* ittamar uca ad yiři ibedd din.   
\b  
\m
\v 10 SIDI ittareẓẓa ccwar n řegnus,  
\m issebḍeř ixarriṣen n řegnus. \x ◘ \xo 33:10 \xt Ica. 19:3\x*   
\m
\v 11 Ccwar n SIDI ad iqqim ibedd i řebda,  
\m ixarriṣen n wuř nnes zi jjiř ař jjiř. \x ◘ \xo 33:11 \xt Awřn. 19:21; 21:30; Ica. 46:10\x*   
\b  
\m
\v 12 Sseɛd n řgens  
\m i ɣar iǧa AREBBI nnes d SIDI,  
\m řgens nni ixḍar i-t Netta  
\m d tasɣart i Yixef nnes.\x ◘ \xo 33:12 \xt Izhd. 65:5; 144:15\x*   
\m
\v 13 SIDI ixezzar-dd zeg ujenna,  
\m ittwařa marra tarwa n bnadem.   
\b  
\m
\v 14 Zi tzeddiɣt nnes imetnen ixezzar  
\m ɣar marra imezdaɣ n temmurt.   
\m
\v 15 Netta weḥḥdes  
\m d wenni ikewwnen uř nsen,  
\m Netta iḥekkar i marra timegga nsen.   
\b  
\m
\v 16 Ajeǧid war ittwassenjam  
\m s yijj n řɛeskar d ameqqran,  
\m bu-teɣruḍt war ittwafekki  
\m s jjehd aṭṭas.   
\m
\v 17 Aqa d axarriq  
\m \add belli\add* ayis ad dd-yawi asenjem,  
\m \add ɛad\add* s jjehd nnes ameqqran  
\m war dd-ittenfekki.   
\b  
\m
\v 18 Xzar, tiṭṭ n SIDI  
\m x yinni zzayes itteggʷeden,  
\m x yinni ittrajan  
\m tamexsiwt nnes icewwaren, \x ◘ \xo 33:18 \xt Ayub 36:7; Izhd. 34:16; 1 Bṭ. 3:12\x*   
\m
\v 19 ḥima ad ifekk řeɛmar nsen zi řmewt,  
\m ḥima ad ten yejj qqimen ddaren di řaẓ.   
\b  
\m
\v 20 Řeɛmar nneɣ ittraja SIDI,  
\m aqa Netta d aɛawen nneɣ  
\m d taseddart nneɣ i useřqi.   
\m
\v 21 Maɣar zzayes ifarreḥ wuř nneɣ,  
\m minzi nettcař x Yisem nnes iqeddsen.   
\m
\v 22 Ad xaneɣ tarsa  
\m tmexsiwt nnec icewwaren, \add a\add* SIDI,  
\m am mammec i Cek nettraja.   
\b  
\b  
\m  
\c 34
\m
\v 1 \add N Dawud, umi issniɛmiř, igga ixef nnes d abuhaři zzat i wudem n Abimilik,\add* \add wenni i xas yuẓẓřen ařami yuyur netta.\add*\x ◘ \xo 34:1 \xt 1 Ṣm. 21:13\x*   
\b  
\m
\v 2 \bd Alif.\bd* Necc xseɣ ad barkeɣ i SIDI řebda,  
\m aṣebbiḥ nnes ad yiři  
\m deg uqemmum inu břa qeṭṭu.   
\m
\v 3 \bd Bit.\bd* Řeɛmar inu ad iṣebbeḥ i SIDI.  
\m Imhinen ad as sřen u ad farḥen.   
\m
\v 4 \bd Gimel.\bd* Semɣarem akidi SIDI,  
\m ejj aneɣ ad nessuɛřa Isem nnes jmiɛ.   
\b  
\m
\v 5 \bd Dalit.\bd* Necc arzuɣ x SIDI  
\m u Netta yarra-dd xafi,  
\m ifekk ayi zi marra innexřiɛen inu.   
\m
\v 6 \bd Hi.\bd* Nitni xezzaren ɣares uca ceɛceɛen,  
\m iɣembab nsen  
\m war ddikkwiřen zewɣen  
\m s useḍḥi ɛemmarṣ.   
\m
\v 7 \bd Zayin.\bd* Řmeskin-a \add danita\add* iřaɣa  
\m u SIDI isřa \add ɣares\add*,  
\m ifekk i-t zi marra řeḥṣarat nnes.   
\b  
\m
\v 8 \bd Xit.\bd* lmalak n SIDI iquwwar s řmargeḥ nnes  
\m x yinni t itteggʷeden,  
\m Netta ifekk i-ten.   
\m
\v 9 \bd Tit.\bd* Qasem uca xzarem, aqa SIDI icna.  
\m Sseɛd n weryaz wenni ɣares yarekkwařen.   
\m
\v 10 \bd Yud.\bd* Ggʷedem SIDI,  
\m \add a kenniw,\add* imqeddasen nnes,  
\m maɣar inni t itteggʷeden  
\m war ten ittxeṣṣi walu.   
\m
\v 11 \bd Kaf.\bd* Iyraden imeẓyanen tteḥwajen,  
\m daysen řaẓ,  
\m \add maca\add* inni yarezzun x SIDI,  
\m war ten ittxeṣṣi walu  
\m zi marra \add min iǧan\add* d řxar. \x ◘ \xo 34:11 \xt Ayub 4:11\x*   
\b  
\m
\v 12 \bd Lamid.\bd* Asem-dd,  
\m \add a, kenniw\add* iḥenjiren, sřem-dd ɣari!  
\m Necc ad awem ssřemdeɣ  
\m tiggʷudi n SIDI.   
\m
\v 13 \bd Mim.\bd* Man wen i iǧan d aryaz  
\m wenni di iǧa meẓri di tudart,  
\m wenni ittexsen ussan \add n tudart nnes\add*  
\m ḥima ad iẓar řxar? \x ◘ \xo 34:13 \xt 1 Bṭ. 3:10\x*   
\m
\v 14 \bd Nun.\bd* Mneɛ iřes nnec zi řɣar,  
\m uřa d iyencicen nnec zeg wawař n řɣecc.   
\m
\v 15 \bd Samix.\bd* Ḥeyyed x tuɛeffna u egg řxar,  
\m arzu x řehna u ḍfar i-t.   
\b  
\m
\v 16 \bd Ɛayin.\bd* Tiṭṭawin n SIDI x imseggaden,  
\m imezzuɣen nnes meyyřen  
\m ɣar iɣuyyan nsen. \x ◘ \xo 34:16 \xt Ayub 36:7; Izhd. 33:18; 1 Bṭ. 3:12\x*   
\m
\v 17 \bd Pi.\bd* Udem n SIDI  
\m ḍidd i yinni itteggen řɣar,  
\m ḥima ad ikkes řidaret daysen zi temmurt.   
\m
\v 18 \bd Tsadi.\bd* Nitni řaɣan u SIDI isřa \add ɣarsen\add*,  
\m Netta ifekk i-ten zi marra řeḥṣarat nsen.   
\m
\v 19 \bd Quf.\bd* SIDI yudes i marra  
\m inni umi ittwarẓ wuř nsen,  
\m issenjam inni umi ittwařbez buḥbeř nsen. \x ◘ \xo 34:19 \xt 2 Tim. 3:11\x*   
\m
\v 20 \bd Rix.\bd* Aṭṭas \add iǧan\add* ifeqqusen n imseggaden,  
\m \add maca\add* SIDI ifekk i-ten zzaysen marra. \x ◘ \xo 34:20 \xt 2 Tim. 3:12\x*   
\m
\v 21 \bd Cin.\bd* Netta iḥeṭṭa iɣsan nnes marra,  
\m uřa d ijj zzaysen war ittareẓẓi. \x ◘ \xo 34:21 \xt Yḥ. 19:36\x*   
\m
\v 22 \bd Taf.\bd* Aqa řɣar ad ineɣ aɛeffan,  
\m inni icarrhen amsegged ad ttwaɛaqben.   
\b  
\m
\v 23 SIDI ad ifdi řeɛmar n imsexxaren nnes,  
\m marra inni ɣares yarekkwařen,  
\m war ttwaɛaqben. \f ◼ \fr 34:23 \ft \+fk ad ifdi\ft  - xzar ‘Amefdi’ - Izhd. 78:35.\f*   
\b  
\b  
\m  
\c 35
\m
\v 1 \add N Dawud.\add*  
\b  
\m Mcubbec, \add a\add* SIDI,  
\m ak-d yinni akidi ittemcubbucen,  
\m mneɣ ak-d yinni kidi ittmenɣan.   
\m
\v 2 Ṭṭef taseddart n useřqi  
\m d tseddart tameqqrant,  
\m uca kkar, ewc ayi afus.   
\m
\v 3 Jbed-dd lansa, qqen \add abrid\add* i umsagar  
\m ak-d yinni dd ayi iḍaffaren,  
\m ini i řeɛmar inu:  
\m “Asenjem nnec aqa d Necc!”   
\b  
\m
\v 4 Arr inni yarezzun x řeɛmar inu  
\m ad ttwaxarewḍen u ad ttwafeḍḥen,  
\m ejj inni ittxarriṣen di řɣar xafi  
\m ad ttwaɛarrnen ɣar ḍeffar,  
\m ejj i-ten ad dewřen ttseḍḥan. \x ◘ \xo 35:4 \xt Izhd. 40:15; 70:3\x*   
\m
\v 5 Ejj i-ten ad dewřen am yicarfa  
\m deg usemmiḍ,  
\m ejj lmalak n SIDI ad ten iɛarn. \x ◘ \xo 35:5 \xt Ayub 21:18; Izhd. 1:4; Ica. 29:5; Ḥuc. 13:3\x*   
\m
\v 6 Ejj ad idweř webrid nsen d taǧest,  
\m ad yiři itteḥřuǧuḍ,  
\m uca ejj lmalak n SIDI ad ten iḍfar.   
\b  
\m
\v 7 Maɣar břa ssibbet  
\m ssnuffaren xafi \add aḥfur n\add* turṣuḍi  
\m d tracca nsen,  
\m břa ssibbet ɣzin t i řeɛmar inu.   
\m
\v 8 Ejj areddeǧ ad xas dd-yas břa ma issen,  
\m ejj tracca nnes nni issnuffar  
\m ad t tᵉṭṭef simant nnes,  
\m ejj i-t ad \add dayes\add* dd-iwḍa simant nnes,  
\m \add s ijj n uweṭṭu\add* i t i ɣa yareddǧen.   
\b  
\m
\v 9 Řeɛmar inu ad ifarḥ zi SIDI,  
\m ad yarceq deg usenjem nnes.   
\m
\v 10 Ad inin marra iɣsan inu:  
\m “\add A\add* SIDI, man wen \add iǧan\add* am Cek!  
\m Cek d wenni ittfekkan řmeskin  
\m zeg wenni xas ijehhden,  
\m řmeskin d umezřuḍ  
\m zeg inni d asen ikeccḍen.”   
\b  
\m
\v 11 Icehhaden iqṭaṭɛiyyen kkaren.  
\m Min war ssineɣ, ttseqsan ayi.   
\m
\v 12 Arrin ayi-dd řɣar di řxar,  
\m \add ggin dayi\add* řeḥwej n yinni xafi iɛizzen.   
\m
\v 13 Necc \add maca\add* arḍeɣ  
\m ict n txancet \add n wecḍan\add*,  
\m řami tuɣa heǧcen nitni,  
\m ggiɣ ad iẓumm řeɛmar inu,  
\m uca taẓaǧit inu \add tᵉttɣima\add*  
\m tᵉddekkwař-dd ɣari  
\m di daxeř inu.   
\b  
\m
\v 14 Axmi t tuɣa d ameddukkeř inu  
\m niɣ d uma,  
\m ammu i tuɣa ggureɣ,  
\m am ca n ijj iceṭṭ x yemmas,  
\m ammu tuɣa ayi ggureɣ ɣennseɣ  
\m \add deg warruḍ\add* d abarcan.   
\m
\v 15 \add Maca\add* xmi ttqejdiḥeɣ, farrḥen nitni,  
\m ttmunen ak-d wayawya.  
\m Ttmunen ḍidd inu inni n wadday,  
\m břa ma ad \add t\add* ssneɣ.  
\m Ceqqfen dayi, war ssusmen.   
\m
\v 16 Am inni iɣeṭṭṣen \add bnadem\add*  
\m i yijj n uřeqquz n weɣrum,  
\m \add ammu\add* ɣezzan-dd ɣari tiɣmas.   
\b  
\m
\v 17 \add A\add* Sidi inu, ař mecḥař i ɣa tekked  
\m txezzared \add waha\add*?  
\m Senjem ayi zeg wareddeǧ nsen i iggin,  
\m ayenni inu zeg weyraden imeẓyanen.   
\m
\v 18 Necc ad Cek qadiɣ  
\m deg yijj n wegraw \add n řgens\add* d ameqqran,  
\m ad Cek ṣebbḥeɣ jar ijj n řgens  
\m imɣar aṭṭas.\x ◘ \xo 35:18 \xt Izhd. 40:10, 11; 111:1\x*   
\b  
\m
\v 19 Inni iǧan d řɛedyan inu di řbaṭer,  
\m war ten ttejji ad xafi farḥen,  
\m inni d ayi icarrhen, war ten ttejji  
\m ad xafi mmseɣmazen břa ssibbet. \x ◘ \xo 35:19 \xt Yḥ. 15:25\x*   
\m
\v 20 Maɣar nitni war ssiwiřen ca x řehna,  
\m maca ttxarriṣen deg inwayen  
\m \add ccuren\add* s řɣecc  
\m ḍidd inni yarezzun řhudnet di temmurt.   
\m
\v 21 Nitni arezzmen aqemmum nsen qaɛ,  
\m qqaren: “Ha, ha, tiṭṭ nneɣ simant nnes  
\m teẓra i-tt!”   
\b  
\m
\v 22 \add A\add* SIDI, Cek teẓrid tt,  
\m war ttesqara, Sidi inu,  
\m war xafi tteggʷij ca.   
\m
\v 23 Faq, kkar di ṭṭweɛ n řḥeqq inu,  
\m \add a\add* AREBBI inu d Sidi inu,  
\m di ṭṭweɛ n ddeɛwet inu.   
\m
\v 24 Ḥkem xafi s řḥeqq  
\m ɛlaḥsab tasegda nnec,  
\m \add a\add* SIDI, AREBBI inu,  
\m war ten ttejji ad xafi farḥen.   
\b  
\m
\v 25 War \add ten\add* ttejji ad inin deg wuř nsen:  
\m “Ha, aqa aneɣ mliḥ!”,  
\m war ten ttejji ad inin:  
\m “Aqa nsarḍ i-t!”   
\m
\v 26 Ejj inni ifarrḥen x arẓiyyet inu,  
\m ad ttwaxarewḍen  
\m u ad ssnuffaren ixef nsen jmiɛ,  
\m ejj inni iggin ixef nsen mɣaren zzati,  
\m ad yarḍen s useḍḥi d řefḍiḥet.   
\b  
\m
\v 27 Ejj inni yarḍan di tsegda  
\m ad sřiweřwen u ad farḥen,  
\m ejj i-ten ad inin:  
\m “D ameqqran i yeǧa SIDI wenni yarḍan  
\m di řehna n umsexxar nnes.”   
\m
\v 28 \add Xenni\add* iřes inu  
\m ad ibarreḥ tasegda nnec  
\m d uṣebbeḥ nnec ass marra.   
\b  
\b  
\m  
\c 36
\m
\v 1 \add I umeqqran n imeɣnajen. Zeg umsexxar n SIDI. N Dawud.\add*   
\b  
\m
\v 2 Issawař uxeṭṭu n uɛeffan daxeř deg wuř inu:  
\m “War ɣares tiggʷudi n AREBBI  
\m zzat i tiṭṭawin nnes.”   
\m
\v 3 Minzi \add axeṭṭu-ya\add* issḥinnab i-t  
\m di tiṭṭawin nnes,  
\m aqa yufa řmuɛṣiyyet nnes  
\m \add tarra i-t-i-dd\add* ɣar wecrah.   
\b  
\m
\v 4 Awařen n uqemmum nnes  
\m aqa aten d řɣecc d wecmat,  
\m netta issbedd ḥima ad yarzu řefhamet  
\m ḥima ad igg řxar.   
\m
\v 5 Ittxemmem di řɣecc di qama nnes,  
\m iggur ad ibedd  
\m deg ijj n webrid war iṣebḥen.  
\m Řɣar war t ittmenḍir.   
\b  
\m
\v 6 \add A\add* SIDI, tamexsiwt nnec icewwaren  
\m \add tᵉttakkwaḍ\add* ař daxeř n ijenwan,  
\m řaman nnec ař iseynuten. \x ◘ \xo 36:6 \xt Izhd. 57:11; 108:5\x*   
\m
\v 7 Tasegda nnec \add tegga\add* am yidurar n Arebbi,  
\m řeḥkamat nnec am \add waman\add* ihewřen.  
\m SIDI issenjam bnadem d řmař.   
\b  
\m
\v 8 Mecḥař tiɣřa  
\m tmexsiwt nnec icewwaren, \add a\add* AREBBI!  
\m \add S uyenni\add* arekkwařen ɣarek  
\m tarwa n bnadem,  
\m ɣar tiři n wafriwen nnec.   
\m
\v 9 Ttwasjawnen s ufeyyeḍ  
\m s tadunt n Taddart nnec,  
\m iɣzar s nnɛami nnec tewced \add asen\add*  
\m maḥend ad \add zzayes\add* swen.   
\m
\v 10 Maɣar ɣarek i iǧa řɛunṣar n tudart,  
\m di tfawt nnec aqa nettwařa tafawt.   
\b  
\m
\v 11 Swiẓẓeḍ tamexsiwt nnec icewwaren  
\m x yinni i Cek issnen,  
\m tasegda nnec x yinni  
\m i ɣar iǧa wuř iseggmen.   
\m
\v 12 War ttejji ad xafi dd-yas  
\m uḍar n ayt n bu-nnfaxet,  
\m war ttejji afus n iɛeffanen  
\m ad ayi dd-yarr ad tellɛeɣ mani ma.   
\m
\v 13 Aqa din i wḍan,  
\m inni itteggen řmuɛṣiyyet,  
\m ttwaɣeḍřen ɣar temmurt,  
\m war zemmaren ɛad ad kkaren ɛawed.   
\b  
\b  
\m  
\c 37
\m
\v 1 \add N Dawud.\add*  
\b  
\m \bd Alif.\bd* War tᵉttwareqq \add tefqeḥt nnec\add*  
\m x iɛeffanen,  
\m war ttasem x yinni itteggen řɣecc. \x ◘ \xo 37:1 \xt Awřn. 23:17; 24:1\x*   
\m
\v 2 Maɣar ad wḍan deɣya am arbiɛ,  
\m am arbiɛ aziza ad sřawen.   
\m
\v 3 \bd Bit.\bd* Ttceř x SIDI u egg řxar,  
\m zdeɣ di temmurt u iři d amtiqqi.   
\m
\v 4 Arr meẓri di SIDI,  
\m u Netta ad cek iwc  
\m min di ittmeẓri wuř nnec.   
\m
\v 5 \bd Gimel.\bd* Arr ticři nnec ɣar SIDI,  
\m ttcař xas u Netta ad \add tt\add* igg. \x ◘ \xo 37:5 \xt Izhd. 22:9; 55:23; Awřn. 16:3; Mt. 6:25; Lk. 12:22; 1 Bṭ. 5:7\x*   
\m
\v 6 Netta ad isseḍhar tasegda nnec  
\m am tfawt,  
\m řḥeqq nnec am yiceɛciɛen n tfuct  
\m di ṭṭḥa n uziř.   
\m
\v 7 \bd Dalit.\bd* Susem zzat i SIDI u raja t.  
\m War ttejji \add tafqeḥt nnec\add* ad tasem  
\m x wenni ifeřhen deg webrid nnes,  
\m x weryaz nni itteggen taḥraymect.   
\m
\v 8 \bd Hi.\bd* Ejj aɣḍab nnec ad yarsa  
\m u ejj asɛar nnec ad iraḥ.  
\m War ttejji \add tafqeḥt nnec\add*  
\m ad tᵉttwassareɣ.  
\m \add Man aya ad yawi\add* mɣir tuɛeffna waha.   
\m
\v 9 Maɣar iɛeffanen ad ttwateḥḥan,  
\m \add maca\add* inni issitimen x SIDI  
\m ad warten tammurt.   
\m
\v 10 \bd Waw.\bd* Mɣir cwayt waha  
\m uca aɛeffan war ittɣimi \add ɛad\add*.  
\m Ad tḥekkared mliḥ wemcan nnes,  
\m \add maca\add* war din ittiři \add ɛad\add*.   
\m
\v 11 Imhinen ad warten tammurt,  
\m ad arren meẓri di řehna ameqqran. \x ◘ \xo 37:11 \xt Mt. 5:5\x*   
\b  
\m
\v 12 \bd Zayin.\bd* Aɛeffan ittxarreṣ  
\m di tmeɛmač tiḥraymiyyin ḍidd i umsegged,  
\m ittɣezza xas tiɣmas.   
\m
\v 13 Sidi inu iḍeḥḥec xas,  
\m maɣar ittwařa aqa ass nnes  
\m ad dd-yas.   
\m
\v 14 \bd Xit.\bd* Iɛeffanen jebden-dd ssif  
\m u meḥḍen řqews,  
\m ḥima ad ɣeḍřen řmeskin d umezřuḍ,  
\m ḥima ad ɣarṣen i yinni igguren  
\m deg webrid nsen nican.   
\m
\v 15 Ssif nsen ad ten iřqef deg wuř nsen,  
\m řeqwas nsen ad ttwarẓen.   
\m
\v 16 \bd Tit.\bd* Drus i ɣares ɣar umsegged,  
\m ḥsen zeg ufeyyeḍ n waṭṭas n iɛeffanen.   
\m
\v 17 Maɣař iɣaǧen n iɛeffanen ad ttwarẓen,  
\m \add maca\add* SIDI ad isenned imseggaden.   
\m
\v 18 \bd Yud.\bd* SIDI issen ussan  
\m n yinni igguren nican,  
\m tasɣart nsen ad teqqim i řebda.   
\m
\v 19 War ttwaqemmiḥen di řweqt taɛeffant,  
\m deg wussan n řaẓ ad ttwassjiwnen.   
\m
\v 20 \bd Kaf.\bd* Maɣar iɛeffanen ad fnan,  
\m řɛedyan n SIDI ad weddaren,  
\m ad ttwaqḍan am wenni iǧan iɣřan qaɛ  
\m zeg izmaren iqebbuzen,  
\m ad ḍwen di tayyut.   
\b  
\m
\v 21 \bd Lamid.\bd* Aɛeffan yareṭṭeř,  
\m war ittarri \add amarwas\add*,  
\m maca amsegged ittḥinn, ittic.   
\m
\v 22 Maɣar inni zzayes ittwabarken  
\m ad warten tammurt,  
\m \add maca\add* inni zzayes ittwaneɛřen,  
\m ad ttwateḥḥan.   
\m
\v 23 \bd Mim.\bd* Iṣuraf n weryaz ijehden  
\m ttwassmettnen zi SIDI,  
\m Netta yareṭṭa x webrid nnes.   
\m
\v 24 Mařa iwḍa, war ittmenḍar,  
\m maɣar SIDI iwca as afus nnes.   
\m
\v 25 \bd Nun.\bd* Necc tuɣa ayi d ameẓyan, \add řexxu\add* wsareɣ,  
\m \add maca\add* ɛemmarṣ war ẓriɣ  
\m amsegged ittwajj,  
\m niɣ tarwa nnes arezzun x weɣrum.   
\m
\v 26 Ass ikmeř ittḥinna  
\m u yařeṭṭeř \add i imezřaḍ\add*,  
\m zzariɛet nnes ad tiři i lbaraka.   
\m
\v 27 \bd Samix.\bd* Ḥeyyed x řɣar u egg řxar,  
\m \add xenni\add* ad ɣarek tiři tzeddiɣt i řebda qaɛ.   
\m
\v 28 Maɣar SIDI ittexs řḥeqq,  
\m war isemmeḥ deg imtiqqan nnes.  
\m \bd Ɛayin.\bd* Ad ttwaḥḍan i řebda qaɛ,  
\m maca zzariɛet n iɛeffanen ad tᵉttwateḥḥa.   
\m
\v 29 Imseggaden ad warten tammurt,  
\m ad dayes zedɣen i řebda.   
\m
\v 30 \bd Pi.\bd* Aqemmum n umsegged  
\m ittbarreḥ s tiɣit,  
\m iřes nnes issawař s řḥeqq.   
\m
\v 31 Ccariɛa n AREBBI nnes deg wuř nnes,  
\m iṣuraf nnes war ttefriɣen. \x ◘ \xo 37:31 \xt Izhd. 40:9; Ica. 51:7\x*   
\b  
\m
\v 32 \bd Tsadi.\bd* Aɛeffan iřebbet i umsegged,  
\m yarezzu ad t ineɣ,   
\m
\v 33 \add maca\add* SIDI war zzayes yarexxu  
\m afus nnes,  
\m war xas iḥkem xmi t ɣa iḥakem.   
\m
\v 34 \bd Quf.\bd* Sitim x SIDI  
\m u ṭṭef deg webrid nnes.  
\m Netta ad cek issgeɛɛed  
\m ḥima ad twarted tammurt.  
\m Ad tẓared aqa iɛeffanen ad ttwateḥḥan.   
\m
\v 35 \bd Rix.\bd* Necc ẓriɣ ijj n uɛeffan  
\m d bu-řexcunet,  
\m imeqqar am tcejjart n tengelt tazizawt. \f ◼ \fr 37:35 \ft \+fk tacejjart\ft  - niɣ ‘addag’ (‘iddagen’).\f*   
\m
\v 36 Aqa iɛdu, uca xzar, war t tuɣi ca ɛad din.  
\m Arzuɣ xas, maca idweř war iǧi \add ɛad\add*.   
\m
\v 37 \bd Cin.\bd* Ḥḍa x wenni iǧan ikmeř  
\m u xezzar ɣar wenni igguren nican,  
\m maɣar aneggar n weryaz nni  
\m ad yiři d řehna.   
\m
\v 38 Inni ittɛeddan ad ttwareddǧen jmiɛ,  
\m min iqqimen n iɛeffanen  
\m ad ittwateḥḥa.   
\m
\v 39 \bd Taf.\bd* Asenjem n imseggaden  
\m \add ad dd-yas\add* zi SIDI,  
\m aqa Netta d arewřa nsen  
\m di řweqt n řeḥṣaret.   
\m
\v 40 SIDI ad asen iwc afus u ad ten ifekk.  
\m Netta ad ten ifekk zeg iɛeffanen  
\m u ad ten issenjem,  
\m maɣar nitni arekkwařen ɣares.   
\b  
\b  
\m  
\c 38
\m
\v 1 \add Azehhed n Dawud. I řidaret.\add*   
\b  
\m
\v 2 \add A\add* SIDI, war d ayi ttɛaqab  
\m deg uduqqez n weɣḍab nnec,  
\m war d ayi ttweddab s wesɛar nnec. \x ◘ \xo 38:2 \xt Izhd. 6:2\x*   
\m
\v 3 Maɣar fřitcat n řqews nnec  
\m udfent dayi,  
\m afus nnec ittzeyyar xafi.   
\b  
\m
\v 4 War \add din\add* iqqim min iǧan ikemmřen  
\m di arrimet inu zeg wesxeḍ nnec,  
\m war iqqim min iṣeḥḥen deg iɣsan inu  
\m zi ssibbet n ddenb inu. \f ◼ \fr 38:4 \ft \+fk arrimet\ft  - s Tɛibranit ‘aysum’, awař-a ixs ad yini ‘arrimet’.\f*   
\m
\v 5 Maɣar řmuɛṣiyyat inu  
\m geɛɛdent ayi ɣar uzeǧif inu,  
\m deqqřent xafi  
\m am yijj n ddqeř imɣar aṭṭas.   
\b  
\m
\v 6 Iyezzimen inu daysen arriḥet,  
\m geyyḥen s tubbuheřya inu.   
\m
\v 7 Dewřeɣ qewseɣ, dewřeɣ ɣenseɣ ař ṭṭarf.  
\m Ass marra ggureɣ  
\m deg \add warruḍ n wecḍan d\add* abarcan.   
\b  
\m
\v 8 Maɣar ttaciɣ tijɛinnatin inu  
\m arɣint s tmessi marra,  
\m war din iqqim min iǧan ikemmřen  
\m di arrimet inu.   
\m
\v 9 Necc jemmdeɣ u ttwaɣeḍřeɣ qaɛ,  
\m sɣuyyuɣ s zzhir n wuř inu.   
\b  
\m
\v 10 \add A\add* Sidi inu, marra min di ɣari meẓri  
\m aqa-t zzatek, aweɛɛeḍ inu  
\m war zzayek ittnuffar.   
\m
\v 11 Uř inu iddendun, marra jjehd iffeɣ ayi,  
\m uřa d tafawt \add teffeɣ\add* zi tiṭṭawin inu,  
\m \add wah\add* uřa d nitenti war ɣari beddent \add ɛad\add*.   
\b  
\m
\v 12 Imɛizzen inu d imeddukkař inu  
\m bedden arendad \add inu ɣar\add* jjriḥect inu,  
\m uřa d inni i d ayi yudsen ttaggʷejen xafi.   
\m
\v 13 Inni yarezzun ad kksen tudart inu,  
\m nedyen ayi řefxux,  
\m inni yarezzun ad ayi ggen řɣar,  
\m ssawařen am mmeẓren ad areddǧen,  
\m nitni ceřɣen s řɣecc ass marra.   
\b  
\m
\v 14 \add Maca\add* necc tteggeɣ ixef inu  
\m axmi d adehcur,  
\m am weynaw nni war yarezzmen  
\m aqemmum nnes.   
\m
\v 15 Necc am weryaz war ittesřin,  
\m wenni war ɣar iǧi twarrit  
\m zeg uqemmum nnes.   
\b  
\m
\v 16 Maɣar ttrajiɣ Cek, \add a\add* SIDI,  
\m Cek ad dd-tarrid, \add a\add* Sidi inu,  
\m \add a\add* AREBBI inu!   
\m
\v 17 Maɣar nniɣ:  
\m “Ejj i-ten war xafi farrḥen,  
\m xmi ɣa farɣen iḍaren inu,  
\m ejj i-ten war ssemɣaran ixef nsen xafi.   
\b  
\m
\v 18 Maɣar necc aqa ad nqarḍeɣ,  
\m řeḥriq inu aqa-t řebda zzati.   
\m
\v 19 Maɣar ssargbeɣ ac řmuɛṣiyyet inu,  
\m aqa ttwaḥeṣṣareɣ zi ddenb inu. \x ◘ \xo 38:19 \xt Izhd. 32:5\x*   
\b  
\m
\v 20 Řɛedyan inu ddaren,  
\m aqa aten s jjehd,  
\m aṭṭas \add ǧan\add* inni d ayi icarrhen  
\m břa ssibbet.   
\m
\v 21 Inni ittarran řxar s řɣar  
\m ssbedden ixef nsen ḍidd inu,  
\m umi necc arezzuɣ x min iṣebḥen.   
\b  
\m
\v 22 War dayi semmeḥ, \add a\add* SIDI, AREBBI inu,  
\m war xafi ttaggʷej.   
\m
\v 23 Deɣyet ḥima ad ayi tewcid afus,  
\m \add a\add* Sidi inu, asenjem inu.   
\b  
\b  
\m  
\c 39
\m
\v 1 \add I umeqqran n imeɣnajen. I Yadutun. Azehhed n Dawud.\add*   
\b  
\m
\v 2 Nniɣ: “Necc ad kkareɣ ad ḥḍiɣ ibriden inu  
\m zi ddenb n yiřes inu,  
\m ad ṭṭfeɣ aḥeṭṭu ɣar uqemmum inu  
\m s ict n tecmant,  
\m min ɣa yekk uɛeffan zzati.”   
\m
\v 3 Necc dewřeɣ am weynaw,  
\m \add řeḥḥfeɣ ixef inu s\add* useɣd,  
\m bekmeɣ uřa x řxar,  
\m \add maca\add* řeḥriq inu tuɣa yarenni.   
\m
\v 4 Uř inu idweř iḥemma di daxeř inu,  
\m tᵉttwassareɣ ict n tmessi  
\m ɣar unixses inu.  
\m \add Xenni\add* ssiwřeɣ s yiřes inu:   
\b  
\m
\v 5 “\add A\add* SIDI, scen ayi aneggar inu,  
\m man iǧa řqedd n wussan inu,  
\m ḥima ad ssneɣ mammec arexfeɣ.   
\m
\v 6 Xzar, Cek tarrid ussan inu  
\m am yicbaren n ufus,  
\m řmijař n tudart inu zzat i Cek  
\m axmi d walu.  
\m Kuř bnadem, mammec ma ibedd imten,  
\m nican am yict n tayyut.” Silah. \x ◘ \xo 39:6 \xt Izhd. 62:10; 144:4\x*   
\m
\v 7 Iwa, bnadem iggur am yijj n řexyař,  
\m wah, \add am\add* ict n tayyut  
\m \add ammu i\add* ittraḥ ittas-dd.  
\m Netta issmun,  
\m war issin man wen t i ɣa iksin \add ɣares\add*.   
\b  
\m
\v 8 U řexxu, min ɣa ssitmeɣ, \add a\add* Sidi inu?  
\m Aqa necc ttrajiɣ Cek!   
\m
\v 9 Fekk ayi zi marra ixeṭṭan inu,  
\m war d ayi ttegg ca d tiseḍḥac i ubuḥaři.   
\m
\v 10 Necc dewřeɣ am weynaw,  
\m war arezzmeɣ aqemmum inu,  
\m maɣar d Cek i iggin aya.   
\m
\v 11 Ksi zzayi jjriḥect nnec,  
\m aqa fenniɣ s uṭeffu iḥeṣṣaren n ufus nnec.   
\m
\v 12 \add Mařa\add* tseggded ca n weryaz s tiyyita  
\m di ssibbet n řmuɛṣiyyet nnes,  
\m \add xenni\add* tessfesyed acewwar n waddud nnes  
\m am tcinda.  
\m Iwa kuř bnadem \add ad ifna\add*  
\m \add am yict n\add* tayyut. Silah.   
\b  
\m
\v 13 Seř i tẓaǧit inu, \add a\add* SIDI,  
\m sḥess i uɣuyyi inu.  
\m War ttebkim ɣar imeṭṭawen inu,  
\m maɣar aqa ayi d abarrani,  
\m d amɛezzeb ɣarek,  
\m am marra řejdud inu. \x ◘ \xo 39:13 \xt Lawi 25:23; 1 Im. 29:15; Izhd. 119:19; Ɛbr. 11:13; 1 Bṭ. 2:11\x*   
\m
\v 14 Sḥeyyed xafi  
\m maḥend ad ceɛceɛeɣ \add ɛad s řefraḥet\add*,  
\m qbeř ad raḥeɣ u war \add da\add* ttiřiɣ ɛad.   
\b  
\b  
\m  
\c 40
\m
\v 1 \add I umeqqran n imeɣnajen. N Dawud. Azehhed.\add*   
\b  
\m
\v 2 Ssitimeɣ qaɛ x SIDI.  
\m Netta yarra-dd ɣari s uzeǧif,  
\m issḥess ɣar uɣuyyi inu.   
\m
\v 3 Netta issgeɛɛed ayi-dd  
\m zeg ijj n wanu ineqqen,  
\m zeg ubeǧaɛ d ubaryuḍ,  
\m Netta issars iḍaren inu x teṣḍart,  
\m issemten iṣuraf inu.   
\m
\v 4 Netta igga ayi ijj n yezři d amaynu  
\m deg uqemmum inu,  
\m ijj n izři n uṣebbeḥ i AREBBI.  
\m Aṭṭas ad t ẓaren,  
\m ad tecřen x SIDI.   
\b  
\m
\v 5 Sseɛd n weryaz  
\m wenni ittecřen x SIDI,  
\m wenni war ittmeyyřen  
\m ɣar ayt n bu-nnfaxet,  
\m uřa ɣar yinni iweddaren ɣar uxarriq.   
\m
\v 6 Aṭṭas, \add a\add* SIDI, AREBBI inu, d lmuɛjizat  
\m nni teggid, uřa d min tenwid xaneɣ.  
\m Uřa d ijj izemmar  
\m ad iɛbar ixef nnes akidek.  
\m Necc ad tent hajiɣ, ad zzaysent ssiwřeɣ.  
\m Aqa nitenti deg waṭṭas,  
\m war zemmarent ad ttwaḥesbent. \x ◘ \xo 40:6 \xt Izhd. 89:7; Ica. 40:18\x*   
\b  
\m
\v 7 War texsed taɣarṣt  
\m d tewhibt \add n řɣiǧet\add*.  
\m Cek tarzmed imezzuɣen inu.  
\m Taɣarṣt n wecmaḍ d tɣarṣt n ddenb  
\m war tent tᵉttared. \x ◘ \xo 40:7 \xt Ɛbr. 10:5\x*   
\m
\v 8 Xenni nniɣ: “Xzar, Necc ad dd-aseɣ,  
\m deg wedlis ittwannḍen yura xafi.   
\m
\v 9 Necc ɣari meẓri, \add a\add* AREBBI,  
\m ḥima ad ggeɣ min texsed Cek.  
\m Ccariɛa nnec aqa-tt di daxeř inu.” \x ◘ \xo 40:9 \xt Izhd. 37:31; Ica. 51:7\x*   
\b  
\m
\v 10 Necc ttbarrḥeɣ řexbar aṣebḥan  
\m n tsegda \add nnec\add*  
\m deg wegraw \add n řgens\add* ameqqran.  
\m Xzar, war tteqqneɣ iyencicen inu,  
\m \add a\add* SIDI, Cek tessned t. \x ◘ \xo 40:10 \xt Izhd. 35:18; 111:1\x*   
\m
\v 11 War ttxemmřeɣ tasegda nnec  
\m daxeř deg wuř inu,  
\m ssawařeɣ x tidett nnec u x usenjem nnec.  
\m Tamexsiwt nnec icewwaren  
\m d řaman i dayek  
\m war ten ssnuffareɣ  
\m deg wegraw \add n řgens\add* ameqqran.   
\b  
\m
\v 12 Cek, \add a\add* SIDI,  
\m war xafi tessbeddid arreḥmet nnec.  
\m Ejj tamexsiwt nnec icewwaren  
\m d řaman i dayek ad ayi ḥḍant řebda.   
\m
\v 13 Maɣar war izemmar ad ittwaḥeṣṣeb  
\m řɣar i d ayi iquwwaren,  
\m řmuɛṣiyyat inu ttmenɛent ayi-dd,  
\m dewřeɣ war ttwiřiɣ ɛad \add s man aya\add*.  
\m Aqa-tent d aṭṭas x ucuwwaf n uzeǧif inu,  
\m uř inu ittefciř.   
\b  
\m
\v 14 \add A\add* SIDI, ad ac yarḍa  
\m ḥima ad ayi tfekked,  
\m \add a\add* SIDI, deɣyat ḥima ad ayi tewced afus.   
\m
\v 15 Ejj inni yarezzun řeɛmar inu  
\m ḥima ad t teḥḥan  
\m ad ttwaxarweḍen,  
\m ad ssnufaren ixef nsen \add jmiɛ\add*,  
\m ejj inni ifarrḥen deg uɛeddeb inu  
\m ad dewřen ɣar ḍeffar u ad ttwassbehdřen. \x ◘ \xo 40:15 \xt Izhd. 35:4, 26; 70:3; 71:13\x*   
\m
\v 16 Ejj i-ten ad ttwareddǧen  
\m am uxeǧeṣ i řefḍiḥet nsen \add i iggin\add*,  
\m inni din iqqaren: “Ha, ha!”   
\b  
\m
\v 17 Ejj marra inni xak yarezzun,  
\m ad arren meẓri, ad zzayek farḥen.  
\m Ejj inni ittexsen asenjem nnec  
\m ad inin řebda: “SIDI d ameqqran!”   
\m
\v 18 Necc di řeɣben u zeřḍeɣ,  
\m \add maca\add* Sidi inu iɛqeř xafi.  
\m Cek d wenni d ayi iwcin afus  
\m d wenni d ayi issnejmen.  
\m \add A\add* AREBBI inu, war ttɛeṭṭař ca.   
\b  
\b  
\m  
\c 41
\m
\v 1 \add I umeqqran n imeɣnajen. Azehhed n Dawud.\add*   
\b  
\m
\v 2 Sseɛd n wenni ifehhmen i umarxu.  
\m SIDI ad t ifekk deg wass n řɣar.   
\m
\v 3 SIDI ggur ad t iḥḍa,  
\m ad t yejj ad iddar,  
\m netta ad yarr meẓri di temmurt.  
\m War t ttsellam ca  
\m ɣar \add min din iǧan\add*  
\m \add di\add* řeɛmar n řɛedyan nnes.   
\m
\v 4 SIDI ad kides ibedd  
\m di tassut n řehřac.  
\m Cek tᵉttbeddřed marra řectu nnes  
\m umi iheǧec.   
\b  
\m
\v 5 Necc nniɣ: “\add A\add* SIDI, ḥinn xafi,  
\m sgenfa řeɛmar inu,  
\m maɣar xḍiɣ akidek.”   
\m
\v 6 Řɛedyan inu ssawařen xafi s řɣar:  
\m “Meřmi i ɣa immet  
\m u ad ittwakkes isem nnes?”   
\m
\v 7 Mařa yusa-dd \add ḥed\add*  
\m maḥend ad \add ayi\add* iẓar,  
\m issawař di řbaṭeř.  
\m Uř nnes issmun ɣares řɣecc,  
\m \add xenni\add* itteffeɣ ɣar barra, issawař.   
\b  
\m
\v 8 Marra inni d ayi icarrhen  
\m ttemtamen xafi jmiɛ,  
\m aqa aten ttxarriṣen dayi,  
\m maḥend \add ad\add* ayi \add ggen\add* řɣar.   
\m
\v 9 Iřqef i-t actab abarcan  
\m u wenni dd-iwḍan \add ammu\add*,  
\m war dd-ittekkar ɛad.   
\m
\v 10 Uřa d aryaz wi ak-d ddareɣ di řehna,  
\m wenni di ttiqqeɣ,  
\m wenni iccen aɣrum inu,  
\m aqa issemɣar xafi anirz nnes. \x ◘ \xo 41:10 \xt Ɛub. 1:7, Yḥ. 13:18\x*   
\b  
\m
\v 11 \add Maca\add* Cek, \add a\add* SIDI, ḥinn xafi,  
\m snekkar ayi-dd,  
\m \add xenni\add* necc ad ten xeǧṣeɣ.   
\m
\v 12 S man aya ad ssneɣ  
\m aqa usiɣ ac-dd x řxaḍar,  
\m maḥend řeɛdu inu  
\m war xafi ittduqqez s usřiwřew.   
\m
\v 13 U xafi, aqa Cek tticed ayi afus  
\m \add s wawař nnek\add* x řekmaret inu,  
\m tessbedded ayi  
\m zzat i wudem nnec i řebda. \x ◘ \xo 41:13 \xt 2 Ṣm. 7:16\x*   
\b  
\m
\v 14 Ad ittwabarek SIDI, AREBBI n Israil,  
\m zi řebda ař i řebda! Amin, \add wah,\add* amin!   
\b  
\b  
\m  
\c 42
\s1 ADLIS WISS TNAYEN - IZEHHIDEN 42-72  
\m
\v 1 \add I umeqqran n imeɣnajen. Axemmi n ayt n Quraḥ.\add*   
\b  
\m
\v 2 Am iɣayḍ n wezɣar ittmeẓri  
\m ɣar tɣezratin n waman,  
\m ammu uřa d uř inu  
\m ittmeẓri ɣarek, \add a\add* AREBBI.   
\m
\v 3 Řeɛmar inu ittfada ɣar AREBBI,  
\m ɣar Arebbi iddaren.  
\m Meřmi i ɣa adfeɣ,  
\m ad baneɣ zzat i wudem n AREBBI? \x ◘ \xo 42:3 \xt Izhd. 63:2\x*   
\m
\v 4 Imeṭṭawen inu  
\m tuɣa aten d aɣrum inu  
\m ass d ǧiřet,  
\m umi d ayi qqaren ass imun:  
\m “Mani iǧa AREBBI nnec?” \x ◘ \xo 42:4 \xt Izhd. 80:6\x*   
\m
\v 5 Necc ttidareɣ di man aya  
\m u ssfarrɣeɣ řeɛmar inu dayi,  
\m maɣar necc ttnumeɣ ggeɛɛdeɣ  
\m deg ijj n uhimur iqqen,  
\m am ggureɣ akidsen  
\m ɣar Taddart n AREBBI,  
\m s řḥess n usřiwřew d uqadi,  
\m ijj n řɣaci ittɛeyyden.   
\m
\v 6 \add A\add* řeɛmar inu,  
\m mayemmi tqenḍed ammu,  
\m thekkweřed dayi?  
\m Raja AREBBI,  
\m maɣar ad qqimeɣ ad t qadiɣ ɛad  
\m x isenjamen \add i dd-itteffɣen\add*  
\m \add zi zzat\add* n wudem nnes. \x ◘ \xo 42:6 \xt Izhd. 43:5; Izhd. 42:12; 43:5 \x*   
\b  
\m
\v 7 \add A\add* AREBBI, řeɛmar inu  
\m iqneḍ ammu dayi.  
\m X uya ttidareɣ Cek  
\m zi temmurt n L’Urdun,  
\m zeg \add idurar n\add* Hirmun,  
\m zeg idurar n Miṣɛara.   
\m
\v 8 Řḥemřet tᵉttřaɣa i řḥemřet nneɣni  
\m ɣar zzhir n icercuren nnec,  
\m marra řemhamed nnec  
\m d řemwaj nnec kkin xafi.   
\m
\v 9 Ejj SIDI ad iweṣṣa  
\m tamexsiwt nnes icewwaren s wass,  
\m \add uca\add* ad ɣari yiři yijj n izři di ǧiřet,  
\m aqa-t d tẓaǧit i Arebbi n tudart inu.   
\m
\v 10 Necc ad iniɣ i Arebbi:  
\m “Taṣḍart inu \add d Cek\add*, mayemmi d ayi tᵉttud?  
\m Mayemmi ggureɣ \add deg werruḍ\add* d abarcan  
\m zi ssibbet n ddeǧ n řeɛdu?” \x ◘ \xo 42:10 \xt Izhd. 35:14; 38:7; 43:2\x*   
\m
\v 11 Inni d ayi iḥeṣṣaren ssbehttřen ayi  
\m s ict n tajjut ineqqen deg iɣsan inu,  
\m umi d ayi qqaren:  
\m “Mani iǧa AREBBI nnec?”   
\m
\v 12 \add A\add* řeɛmar inu,  
\m mayemmi tqenḍed ammu,  
\m thekkweřed dayi?  
\m Raja AREBBI, maɣar ad t qadiɣ ɛad  
\m x isenjamen \add i dd-itteffɣen\add*  
\m \add zi zzat\add* n wudem inu,  
\m u \add zi zzat n\add* AREBBI inu. \x ◘ \xo 42:12 \xt Izhd. 42:6; Izhd. 43:5\x*   
\b  
\b  
\m  
\c 43
\m
\v 1 \add Min iqqimen n Uzehhed 42\add*  
\m Aɣ ayi tasɣart, \add a\add* AREBBI,  
\m ndeh ddeɛwet inu.  
\m Fekk ayi zeg ijj n řgens  
\m war dayes bu tmexsiwt,  
\m zeg weryaz n teḥraymect d ddeǧ.   
\m
\v 2 Aqa Cek d AREBBI n jjehd inu,  
\m mayemmi \add xenni\add* d ayi tenḍared?  
\m Mayemmi ggureɣ \add deg werruḍ\add* d abarcan  
\m zi ssibbet n ddeǧ n řeɛdu?” \x ◘ \xo 43:2 \xt Izhd. 35:14; 38:7; 42:10\x*   
\m
\v 3 Sekk-dd tafawt nnec d tidett nnec,  
\m maḥend ad ayi gewwdent,  
\m ad ayi nedhent  
\m ɣar wedrar nnec iqeddsen  
\m u ɣar tzeddiɣin nnec,   
\m
\v 4 \add ařami\add* i ɣa dd-aseɣ ɣar uɛalṭar,  
\m \add řmedbeḥ n wecmaḍ\add* n AREBBI,  
\m ɣar Arebbi n řefraḥet, \add wenni d\add* arceq inu.  
\m Necc ad Cek qadiɣ s řgambri,  
\m \add a\add* AREBBI, AREBBI inu!   
\m
\v 5 \add A\add* řeɛmar inu, mayemmi tqenḍed ammu,  
\m thekkweřed dayi?  
\m Raja AREBBI, maɣar ad t qadiɣ ɛad  
\m x isenjamen \add i dd-itteffɣen\add*  
\m \add zi zzat\add* n wudem inu,  
\m u \add zi zzat n\add* AREBBI inu. \x ◘ \xo 43:5 \xt Izhd. 42:6, 12\x*   
\b  
\b  
\m  
\c 44
\m
\v 1 \add I umeqqran n imeɣnajen. Zeg ayt n Quraḥ. Axemmi.\add*   
\b  
\m
\v 2 \add A\add* AREBBI, neccin nesřa tt  
\m s imezzuɣen nneɣ,  
\m řejdud nneɣ ḥajan aneɣ tt:  
\m Cek teggid ict n tmeggit  
\m deg wussan nsen,  
\m deg wussan n wecḥař uya.   
\m
\v 3 S ufus nnec aqa tessuffɣed řegnus  
\m zi tesɣart \add nsen\add*,  
\m \add xenni\add* teẓẓud ten \add dayes\add*.  
\m Cek teggid řɣar di ccuɛub,  
\m tbezzɛed ten. \x ◘ \xo 44:3 \xt Uf. 15:17; Izhd. 80:9\x*   
\m
\v 4 Nitni maca war warten tammurt s ssif,  
\m aɣiř nsen war d asen dd-yiwi asenjem,  
\m \add maca\add* afus nnec afusi,  
\m aɣiř nnec d tfawt n wudem nnec,  
\m minzi nitni ufin arḍa \add di tiṭṭawin nnec\add*.   
\b  
\m
\v 5 Aqa Cek d Ajeǧid inu, \add a\add* AREBBI!  
\m Ewc \add ɛad řexxu\add* řumur  
\m i isenjamen n Yaɛqub.   
\m
\v 6 Akidek ad neɣḍeř inni d aneɣ iḥeṣṣaren,  
\m s Yisem nnec ad neɛfes  
\m x yinni xaneɣ ittemɛařan.   
\m
\v 7 Maɣar war ttecřeɣ x řqews inu,  
\m ssif inu war d ayi issenjam.   
\m
\v 8 Maɣar Cek tessenjamed aneɣ  
\m zeg inni d aneɣ iḥeṣṣaren,  
\m tessbehdiřed inni d aneɣ icarrhen.   
\m
\v 9 Nṣebbeḥ i AREBBI ass marra,  
\m ad nqada Isem nnec i řebda. Silah.   
\b  
\m
\v 10 Maca řexxu tenḍared aneɣ,  
\m tessbehdařed aneɣ,  
\m Cek war tᵉtteffiɣed ca  
\m ak-d řɛeskarat nneɣ \add ɣar umenɣi\add*. \x ◘ \xo 44:10 \xt Izhd. 60:3; 74:1; 89:39; 108:12\x*   
\m
\v 11 Cek tejjid aneɣ nettrakkwař  
\m zzat i wenni d aneɣ iḥeṣṣaren,  
\m inni d aneɣ icarrhen  
\m ttkeccḍen \add min ttexsen\add* i yixef nsen.   
\m
\v 12 Cek tewcid aneɣ am wuǧi i macca,  
\m tezzuzared aneɣ jar řegnus.   
\m
\v 13 Cek tezznuzid řgens nnec s walu,  
\m deg uzzenzi nsen war ɣarek bu řefḍeř.   
\b  
\m
\v 14 Cek tᵉttegged aneɣ d řḥegra  
\m i wajjaren nneɣ,  
\m d astehzi d ubehdeř  
\m ɣar yinni d aneɣ-dd ittennḍen. \x ◘ \xo 44:14 \xt Izhd. 79:4; 80:7; Irm. 24:9\x*   
\m
\v 15 Cek tᵉttegged aneɣ d amedya  
\m jar řegnus,  
\m \add tᵉttegged\add* ad xaneɣ hezzen  
\m azeǧif jar ccuɛub.   
\m
\v 16 Ass marra řɛar inu aqa-t zzati  
\m \add jar tiṭṭawin inu\add*,  
\m řeḥya idřa aɣembub inu,   
\m
\v 17 zi tmijja n yinni isseḥqarran,  
\m ttceqqafen, zi ssibbet n řeɛdu  
\m u n wenni yarezzun antaqem.   
\b  
\m
\v 18 Aya marra ikka xaneɣ,  
\m \add maca\add* war Cek nettu,  
\m war nɣecc ca di Řɛahd nnec.   
\m
\v 19 Uř nneɣ war idwiř ɣar ḍeffar,  
\m iṣuraf nneɣ war dd-ffiɣen ca  
\m zeg umesruq nnec,   
\m
\v 20 waxxa Cek třebzed aneɣ  
\m deg wemcan n wuccanen n řexřa,  
\m tedřid aneɣ s tiři n řmewt.   
\m
\v 21 Mři tuɣa nettu Isem n AREBBI nneɣ,  
\m nesswiẓẓeḍ ifassen nneɣ  
\m ɣar yijj n arebbi d aɣrib,   
\m
\v 22 ma iři AREBBI war yarezzu di man aya?  
\m Aqa Netta yareggeb  
\m x min innuffaren deg wuř.   
\b  
\m
\v 23 Maɣar di ṭṭweɛ nnec  
\m neqqen aneɣ kuř ass,  
\m aqa ḥessben aneɣ am wuǧi n tɣarṣt. \x ◘ \xo 44:23 \xt Rum. 8:36\x*   
\m
\v 24 Faq, mayemmi tᵉṭṭṣed, Sidi inu?  
\m Faq, war d aneɣ neṭṭar i řebda!   
\m
\v 25 Mayemmi ɣa teffared udem nnec,  
\m ad tᵉttud řeɣben d ddeǧ nneɣ?   
\m
\v 26 Maɣar řeɛmar nneɣ ittaḍar ɣar tɛejjajt,  
\m aɛeddis nneɣ iřeṣṣeq di temmurt.   
\m
\v 27 Kkar, ewc aneɣ afus, fdi xaneɣ  
\m di ṭṭweɛ n tmexsiwt nnec icewwaren. \f ◼ \fr 44:27 \ft \+fk fdi\ft  - xzar ‘Amefdi’ - Izhd. 78:35.\f*   
\b  
\b  
\m  
\c 45
\m
\v 1 \add I umeqqran n imeɣnajen. S teɣnint n ‘Tlillicin’.\add* \add Zeg ayt n Quraḥ. Axemmi. Izři n tayri.\add*\f ◼ \fr 45:1 \ft \+fk tilillicin\ft  - ict n marka n nnuwarat daysen aẓri aṭṭas.\f*   
\b  
\m
\v 2 Zeg wuř inu idduqqez-dd  
\m ijj n wawař d aṣebḥan,  
\m qqareɣ i Ujeǧid min sswejdeɣ,  
\m iřes inu d řeqřem n ijj n umarir imeḥḍen. \f ◼ \fr 45:2 \ft \+fk řeqřem\ft  - niɣ ‘stilu’ niɣ ‘plumu’.\f*   
\m
\v 3 “Cek tecnid x marra tarwa n bnadem,  
\m řxaḍar ittwazeǧeɛ x iyencicen nnec,  
\m x uya ibarek i Cek AREBBI i řebda.   
\b  
\m
\v 4 Byes ssif x tmessaḍt nnec,  
\m \add a\add* bu-teɣruḍt,  
\m tissiqt nnec d řɛezz nnec.   
\m
\v 5 \add Wah\add*, řɛezz nnec! Iři tfeřḥed,  
\m ndeh di ṭṭweɛ n tidett,  
\m \add ḍidd i\add* řeḥṣaret n tsegda.  
\m Afus nnec afusi ad Cek isseřmed  
\m timesřayin ssaggʷadent.   
\m
\v 6 Fřitcat nnec qeḍɛent,  
\m - \add wah,\add* řegnus ad wḍan sadu \add ufus\add* nnec -  
\m cuqent uř n řɛedyan n Ujeǧid.   
\b  
\m
\v 7 Řkursi nnec igellden, \add a\add* AREBBI,  
\m aqa-t i řebda qaɛ.  
\m Azeǧaḍ n Tgeldit nnec  
\m d ijj n uzeǧaḍ n tsegda. \x ◘ \xo 45:7 \xt Ɛbr. 1:8\x*   
\m
\v 8 Cek tᵉttexsed tasegda u tcarrhed řɣar.  
\m X uya i Cek idhen, \add a\add* AREBBI, AREBBI nnec  
\m s zzect n řefraḥet  
\m tiwa i iɛciren nnec. \x ◘ \xo 45:8 \xt Ɛbr. 1:9\x*   
\b  
\m
\v 9 Marra řeɛbayat nnec  
\m am mirru d wecfiř d řqarfa,  
\m zi řeqṣur n řɛaj ssfarraḥen Cek  
\m s uzenzun x ifiřan \add n řgambri\add*, \f ◼ \fr 45:9 \ft \+fk acfiř\ft  - ixs ad yini ‘aluwi’ (‘aluwis’). \fk řɛaj\ft  - ixs ad yini ‘accawen n lfil’.\f*   
\m
\v 10 yessis n ujeǧid aqa-tent  
\m jar tinewjiwin nnec iweqqaren,  
\m tasřit n Ujeǧid tbedd ac x ufusi,  
\m s \add werruḍ zeg\add* wureɣ iɣřan qaɛ zi Ufir.   
\b  
\m
\v 11 Seř, \add a\add* yeǧi, xzar, ewc amezzuɣ nnem!  
\m Ttu řgens nnem d taddart n babam!   
\m
\v 12 \add Xenni\add* Ajeǧid ad immeẓri deg waẓri nnem,  
\m maɣar Netta d Sidi nnem!  
\m Bendeq zzates!   
\m
\v 13 Yeǧis n Ṣur s ict n tarzeft,  
\m \add wah,\add* ayt n bu-wagřa n ijj n řgens  
\m ad arzun ad xam arḍan. \x ◘ \xo 45:13 \xt Izhd. 72:10\x*   
\b  
\m
\v 14 Yeǧis n Ujeǧid  
\m aqa-tt d aɛuǧi marra daxeř,  
\m arruḍ nnes d ijj n umudi  
\m \add zeg ufiřu\add* n wureɣ.   
\m
\v 15 Ad tᵉttwandeh ɣar Ujeǧid  
\m deg warruḍ s tintat ifarzen.  
\m Tiɛzariyyin tinni tt iḍeffaran,  
\m aqa atent d timeddukkař nnes  
\m nni dd ɣarek ttwawyent.   
\m
\v 16 Aqa ttwawyent s řefraḥet d warceq,  
\m \add ammu\add* i ɣa adfent  
\m ɣar řeqṣar n Ujeǧid.   
\b  
\m
\v 17 Tarwa nnec ad iřin  
\m deg wemcan n řejdud nnec,  
\m Cek ad ten tegged d řḥukkam  
\m di marra tammurt.   
\m
\v 18 Necc ad idareɣ Isem nnec  
\m di kuř jjiř d \add kuř\add* jjiř \add awarni as\add*.  
\m X uya, ad Cek qadan  
\m marra řegnus i řebda qaɛ.”   
\b  
\b  
\m  
\c 46
\m
\v 1 \add I umeqqran n imeɣnajen. Zeg ayt n Quraḥ.\add* \add S lharpat ittwarriglan ɣar sennej. Izři.\add*   
\b  
\m
\v 2 AREBBI d amcan n tarewřa  
\m d jjehd i neccin.  
\m Aqa iban-dd ittic afus aṭṭas  
\m di řeḥṣarat.   
\m
\v 3 X uya war nᵉtteggʷed ca,  
\m waxxa ad tbeddeř tammurt,  
\m ad wḍan idurar deg wuř n řebḥur, \x ◘ \xo 46:3 \xt Asa. 16:18-21\x*   
\m
\v 4 ad hajant řḥemřat nnes,  
\m ad ggent akuffu,  
\m ad nhezzen idurar s unneqřeb nnes! Silah.   
\b  
\m
\v 5 Tiɣezratin n iɣzar  
\m ad ssfarrḥent tandint n AREBBI,  
\m Zzawect Iqeddsen  
\m n Tzeddiɣin n Umɛuǧi x kuřci. \x ◘ \xo 46:5 \xt Asa. 22:1\x*   
\m
\v 6 AREBBI aqa-t di řwest nnes,  
\m war tᵉttenhezza,  
\m AREBBI ad as iwc afus  
\m xmi dd ɣa tessij tuffut. \x ◘ \xo 46:6 \xt Asa. 14:1; 21:22, 23; Zak.14:4-9\x*   
\m
\v 7 Řegnus muzzaren,  
\m tigeldiwin nhezzent.  
\m Netta igga tmijja nnes ad tᵉttwaseř,  
\m tammurt aqa tefsi.   
\m
\v 8 SIDI n řɛeskarat aqa-t akidneɣ,  
\m AREBBI n Yaɛqub  
\m d lburj nneɣ yuɛřan. Silah.   
\b  
\m
\v 9 Asem-dd, xzarem timegga n SIDI,  
\m Netta i iggin anexřiɛ x temmurt.   
\m
\v 10 Netta issbedda imenɣan  
\m ař aneggar n temmurt,  
\m Netta ad yarẓ řqews,  
\m iccat lansa di iwetwiten,  
\m ikarruten issecmaḍ i-ten s tmessi. \x ◘ \xo 46:10 \xt Mixa 4:3; Asa. 2:26-28; \x*   
\m
\v 11 Sbedd, snem illa aqa Necc d AREBBI.  
\m Necc ad ttwassgeɛɛdeɣ jar řegnus,  
\m Necc ad ttwassgeɛɛdeɣ x temmurt.   
\m
\v 12 SIDI n řɛeskarat aqa-t akidneɣ,  
\m AREBBI n Yaɛqub  
\m d lburj yuɛřan i neccin.  
\m Silah.   
\b  
\b  
\m  
\c 47
\m
\v 1 \add I umeqqran n imeɣnajen. Zeg ayt n Quraḥ. Azehhed.\add*   
\b  
\m
\v 2 \add A\add* marra řegnus, wtem deg ifassen,  
\m duqqzem s usřiwřew zzat i AREBBI.   
\m
\v 3 Maɣar SIDI, Amɛuǧi x kuřci,  
\m aqa issaggʷad,  
\m Netta d ijj n ujeǧid d ameqqran  
\m x marra tammurt.   
\m
\v 4 Netta issaḍara aneɣ řegnus,  
\m Netta \add yarra\add* ccuɛub sadu iḍaren nneɣ.   
\m
\v 5 Netta ifarrez tasɣart nneɣ i neccin,  
\m \add tenni d\add* afeyyec n Yaɛqub  
\m wenni tuɣa ittexs. Silah.   
\b  
\m
\v 6 AREBBI yuři sennej s usřiwřew,  
\m SIDI, ɣar tmijja n usuḍi  
\m deg uyicc n icarri.   
\m
\v 7 Zehhdem i AREBBI, zehhdem!  
\m Zehhdem i Ujeǧid, zehhdem!   
\m
\v 8 Maɣar AREBBI d Ajeǧid  
\m x marra tammurt.  
\m Zehhdem \add aya\add* i uxemmi dayes.   
\m
\v 9 AREBBI iḥekkem x řegnus,  
\m AREBBI ittɣima  
\m x řɛarc nnes iqeddsen.   
\b  
\m
\v 10 Tarwa n taṣiřet n řegnus  
\m ttwassmunen  
\m ak-d řgens n AREBBI n Ibrahim,  
\m maɣar tiseddariyyen i useřqi n temmurt  
\m i AREBBI.  
\m Netta aqa ittwassɛuǧa qaɛ.   
\b  
\b  
\m  
\c 48
\m
\v 1 \add Izři, azehhed zeg ayt n Quraḥ.\add*   
\b  
\m
\v 2 SIDI d ameqqran,  
\m isdaḥeǧa ad ittwassemɣar aṭṭas,  
\m di tendint n AREBBI nneɣ,  
\m x wedrar nnes iqeddsen.   
\m
\v 3 Řuɛřa \add nnes\add* d řemřaḥet,  
\m adrar n Ṣihyun aqa-t d řefraḥet  
\m i marra tammurt,  
\m ɣar uɣezdis n ccamal  
\m n tendint n Ujeǧid d ameqqran. \x ◘ \xo 48:3 \xt Izhd. 2:8, 9; Mt. 5:35; Ɛbr. 12:22, 23\x*   
\b  
\m
\v 4 AREBBI aqa-t di řeqṣur nnes,  
\m Netta ittwassen am yijj n lburj yuɛřan.   
\m
\v 5 Maɣar xzar, ijeǧiden munen,  
\m aqa ffɣen jmiɛ.   
\m
\v 6 \add Řami t\add* ẓrin, tbehten,  
\m aqa nnjerfan uca arewřen deɣya.   
\m
\v 7 Dinni tᵉṭṭef i-ten tarjijit,  
\m am řeḥriq n ict n \add temɣart\add* tᵉttaru.   
\m
\v 8 S usemmiḍ zi ccarq  
\m tᵉttareẓẓid iɣarruba n Tarcic.   
\b  
\m
\v 9 Am mammec tuɣa tt nesřa,  
\m ammu i tt netwařa  
\m di tendint n SIDI n řɛeskarat,  
\m di tendint n AREBBI nneɣ.  
\m AREBBI ad tt issemten i řebda. Silah.   
\b  
\m
\v 10 \add A\add* AREBBI,  
\m nidar tamexsiwt nnec icewwaren,  
\m di řwesṭ n Zzawect nnec Tameqqrant.   
\m
\v 11 Am Isem nnec, \add a\add* AREBBI,  
\m ammu ittakkwaḍ uřa d ccan nnec  
\m ař tineggura n temmurt.  
\m Afus nnec afusi iccur s tsegda.   
\m
\v 12 Ejj adrar n Ṣihyun ad ifarḥ,  
\m jjem yessis n Yahuda ad arecqent  
\m zi ssibbet n řeḥkamat nnec.   
\b  
\m
\v 13 Kkem x Ṣihyun, nnḍem as-dd,  
\m ḥesbem ṣṣumɛat nnes!   
\m
\v 14 Ggem uř nwem x řḥiḍ nnes ijehden,  
\m xzarem mliḥ di řeqṣur nnes,  
\m ḥima ad tt ttɛawded i jjiř i dd ɣa yasen.   
\m
\v 15 Maɣar AREBBI wanita  
\m d AREBBI nneɣ  
\m \add i\add* řebda qaɛ.  
\m Netta ad aneɣ indeh  
\m ɣar ujemmaḍ n řmewt.   
\b  
\b  
\m  
\c 49
\m
\v 1 \add I umeqqran n imeɣnajen. Zeg ayt n Quraḥ. Azehhed.\add*   
\b  
\m
\v 2 Sřem \add i\add* uya, marra řegnus,  
\m sḥessem marra, \add a\add* imezdaɣ n ddunect,   
\m
\v 3 am tarwa n Adam,  
\m am tarwa n ijj n weryaz,  
\m aytbab n wagřa d imezřaḍ  
\m jmiɛ ak-d wayawya!   
\m
\v 4 Aqemmum inu issawař tiɣit,  
\m ixarriṣen n wuř inu  
\m \add ccuren\add* s řefhamet.   
\m
\v 5 Necc ad wceɣ amezzuɣ inu  
\m i wawař iweznen,  
\m ad ssargbeɣ tḥajit inu n twafit  
\m ɣar \add tirart n\add* řgambri. \x ◘ \xo 49:5 \xt Izhd. 78:2; Mt. 13:35\x*   
\b  
\m
\v 6 Mayemmi ɣa ggʷedeɣ  
\m deg wussan iɛeffanen,  
\m xmi dd ayi tᵉttenneḍ řmuɛṣiyyet  
\m n yinni d ayi dd-iḍeffaren di tiri inu. \f ◼ \fr 49:6 \ft \+fk di tiri inu\ft  - s Tɛibranit ‘deg inarziwen inu’.\f*  \x ◘ \xo 49:6 \xt Igjd. 4:18\x*   
\m
\v 7 \add Aqa din\add* inni ittcařen  
\m x řeksibet nsen,  
\m ttfeyycen s wagřa nsen ameqqran,   
\m
\v 8 \add maca\add* uřa d ijj n tawmat  
\m war izemmar ad ifdi yijj n weryaz,  
\m war izemmar ad ixeǧeṣ  
\m ddeyyet n yixef nnes i AREBBI. \f ◼ \fr 49:8 \ft \+fk ifdi\ft  - xzar Izhd. 78:35.\f*   
\m
\v 9 Ttaman n weṣřaḥ n řeɛmar nsen  
\m tiɣřa aṭṭas, war dd-tᵉttis i řebda,   
\m
\v 10 ḥima netta ad iddar i řebda,  
\m ɛemmarṣ war ittkiccu.   
\m
\v 11 Maɣar ittwařa imiɣisen mmuten,  
\m \add uřa d\add* abuhaři d uqeffuḥ  
\m ad ttwaqessen s tnayen,  
\m ad jjen řeksibet nsen  
\m i inneɣni awarni asen.   
\m
\v 12 Axarreṣ n wuř nsen  
\m aqa tudrin nsen \add ad qqiment\add* i řebda,  
\m tizeddiɣin nsen zi jjiř ař jjiř.  
\m \add Waxxa\add* uřa d timmura  
\m ggin asent ismawen nsen.   
\m
\v 13 Bnadem i ɣar iǧa ccan, war ittɣimi ca,  
\m netta am řebhimet ifennan.   
\b  
\m
\v 14 Wa d abrid i ɣarsen,  
\m min xef ttsennaden,  
\m uca inni ten iḍeffaren ad jjiwnen  
\m s uqemmum nsen. Silah. \f ◼ \fr 49:14 \ft \+fk inni ten iḍeffaren\ft  - awařen i nᵉttaf di ayat 13-15 ssarwasen abrid n iwdan imɛeffaren ak-d webrid n ict n tḥimart n wuǧi nni igguren ak-d wayawya am ttᵉtten arrbiɛ (ssyawanen ixef nsen s uqemmum nsen) uca ḍeffaren ijj wenneɣni u ɣar uneggaru ssareyyḥen ixef nsen di řaxart. Nitni gguren am ttᵉtten arrbiɛ, ammu d abrid n imɛeffaren di tudart-a. Nitni arrin meẓri nsen, war fekkaren ca di Arebbi, mɣir di min xsen nitni. Taneggarut n iwdan-a tban di ayet n 15.\f*   
\m
\v 15 Am wuǧi ssareyyḥen nitni ixef nsen  
\m di řaxart,  
\m řmewt ad ten tarwes.  
\m Imseggaden ad xasen ḥekmen x ṣṣbeḥ,  
\m addud nsen \add ad idweř\add* i řɣecc di řaxart,  
\m \add ttwassuffɣen nitni\add* zi tzeddiɣt nsen. \f ◼ \fr 49:15 \ft \+fk tazeddiɣt\ft  - arrimet d tazeddiɣt mani ixs Arebbi ad din izdeɣ. S uyenni arrimet d tazeddiɣt n Arebbi, maca bnadem i war ittexsen ad yarzem tazeddiɣt nni i Arebbi, ad ittwassuffeɣ zi tzeddiɣt n Arebbi awarni řmewt nnes, minzi tazeddiɣt nni war teǧi d řmuřk n bnadem, maca n Arebbi.\f*   
\m
\v 16 Maca AREBBI ad ifdi řeɛmar inu  
\m zeg ufus n řaxart,  
\m maɣar Netta ad ayi yawi \add akis\add*. Silah. \f ◼ \fr 49:16 \ft \+fk ifdi\ft  - xzar Izhd. 78:35.\f*   
\m
\v 17 War tteggʷed ca mařa ca n weryaz  
\m idweř d bu-wagřa,  
\m xmi i ɣa yarni ucuwwar n taddart nnes,   
\m
\v 18 maɣar di řmewt nnes  
\m war kides ikessi ca marra aya,  
\m acuwwar nnes war ihekkwi akides  
\m awarni as.   
\m
\v 19 Waxxa ibarek řeɛmar nnes  
\m di tudart nnes,  
\m waxxa nitni ad cek ssemɣaren  
\m maɣar teggid min iṣebḥen i yixef nnec,   
\m
\v 20 aqa ad dd-yaweḍ \add řeɛmar\add* nnes  
\m ɣar jjiř n řejdud nnes,  
\m \add nni\add* war ẓarren tafawt i řebda.   
\m
\v 21 Bnadem i ɣar iǧa ccan,  
\m \add maca\add* war ifehhem,  
\m netta am řebhimet ifennan.   
\b  
\b  
\m  
\c 50
\m
\v 1 \add Ijj n uzehhed n Asaf. Arebbi x marra irebbiten,\add* \add SIDI issawař. Netta ittřaɣa i temmurt\add* \add zi mani dd-tenqar tfuct ař mani teɣři.\add*   
\b  
\m
\v 2 Zi Ṣihyun, aẓri ikemmřen,  
\m ittban AREBBI ittissiq.   
\m
\v 3 AREBBI nneɣ ad dd-yas,  
\m war isseɣd ca.  
\m Timessi zzates ad tecc,  
\m taḥaryaḍt i d as dd-ittennḍen  
\m ad tsuḍ aṭṭas.   
\b  
\m
\v 4 Netta ad iřaɣa i ijenwan sennej,  
\m i temmurt ḥima ad iḥkem x řgens nnes:   
\m
\v 5 “Smunem-dd ɣari imtiqqan inu,  
\m inni kidi itteggen řɛahd s tɣarṣt.”   
\m
\v 6 Ijenwan ttbarrḥen tasegda nnes,  
\m maɣar AREBBI s Yixef nnes  
\m aqa-t d řqaḍi. Silah. \f ◼ \fr 50:6 \ft \+fk řqaḍi\ft  - niɣ ‘amezruf’.\f*   
\b  
\m
\v 7 “Seř, \add a\add* řgens inu,  
\m u Necc ad ssiwřeɣ, Israil,  
\m Necc ad cehdeɣ ḍidd nnec:  
\m Aqa Necc, AREBBI, d AREBBI nnec!   
\m
\v 8 War iǧi x tɣarṣa nnec  
\m ad cek webbxeɣ,  
\m maɣar tiɣarṣa nnec  
\m aqa atent řebda zzati.   
\m
\v 9 War kessiɣ ca afunas ameẓyan  
\m zi taddart nnec,  
\m uřa d iɣayḍen zi teqwirin nnec.   
\m
\v 10 Maɣar marra imuddar n wezɣar,  
\m aqa inu, řmař x wařef idurar. \f ◼ \fr 50:10 \ft \+fk azɣar\ft  - niɣ ‘řɣabet’ niɣ ‘tazgant’.\f*   
\m
\v 11 Necc ssneɣ marra ijḍaḍ n idurar,  
\m \add marra\add* min ittenhezzan deg iyyar,  
\m aqa-t Inu.   
\m
\v 12 Mři tuɣa dayi řaẓ,  
\m ma war d ac t qqareɣ,  
\m maɣar inu ddunect d uɛemmar nnes. \x ◘ \xo 50:12 \xt Uf. 19:5; Aɛwd. 10:14; Ayub 41:3; Izhd. 24:1; 1 Kur. 10:26, 28\x*   
\m
\v 13 Ma ad cceɣ \add xenni\add*  
\m aysum n \add ifunasen\add* ijehden,  
\m niɣ idammen n iɣayḍen?   
\m
\v 14 Awi-dd i AREBBI tawhibt n uqadi,  
\m kemmeř lwuɛud nnec i Umɛuǧi x kuřci. \x ◘ \xo 50:14 \xt Aɛwd. 23:22; Ayub 22:27; Izhd. 76:12; Amb. 5:3, 4, 5\x*   
\m
\v 15 Řaɣa ayi-dd deg wass n řeḥṣaret,  
\m \add xenni\add* ad cek ssnejmeɣ  
\m uca cek ad ayi tegged ccan.”   
\b  
\m
\v 16 \add Maca\add* i uɛeffan iqqar AREBBI:  
\m “Mayemmi tbarrḥed tiweṣṣa inu,  
\m \add mayemmi i\add* teggid Řɛahd inu  
\m deg uqemmum nnec,   
\m
\v 17 \add umi\add* tcarrhed ttarbiyyet inu  
\m u tenḍared awařen inu awarni ac.   
\m
\v 18 Mařa teẓriḍ ijj n uxewwan,  
\m ammu i teggured akides,  
\m tᵉttṣurid ak-d yinni izennan.   
\m
\v 19 Aqemmum nnec tᵉttarrid i-t i řɣar,  
\m iřes nnec ittxarreṣ deg wecmat.   
\m
\v 20 Tettɣimid \add dinni,\add* tessawařed x umac,  
\m tessefdaḥeḍ zi mmis n yemmas.   
\m
\v 21 Aya tᵉttegged u Necc sseɣdiɣ.  
\m Ttɣiř ac, aqa ayi am cek.  
\m Necc ad cek webbxeɣ,  
\m ad ssarseɣ \add ddnub nnec\add*  
\m zzat i tiṭṭawin nnec.   
\b  
\m
\v 22 Fhem aya \add xenni\add*, \add a cek\add* i ittun Arebbi,  
\m ḥima war \add cek\add* tmezzqeɣ  
\m \add am\add* war din ittiři ufekki.”   
\m
\v 23 Wenni dd-ittawyen taɣarṣt n uqadi,  
\m ittegg ayi ccan u issewjad abrid,  
\m ḥima ad as ssecneɣ asenjem n AREBBI.   
\b  
\b  
\m  
\c 51
\m
\v 1 \add I umeqqran n imeɣnajen. Azehhed n Dawud.\add*   
\m
\v 2 \add Ařami i ɣares dd-yusa unabi Natan, awarni řami yudef Dawud x Bat-Cabaɛ.\add* \f ◼ \fr 51:2 \ft \+fk Dawud\ft  - s Tiɛbranit ‘netta’.\f*  \x ◘ \xo 51:2 \xt 2 Ṣm. 11:4; 12:1 \x*   
\b  
\m
\v 3 Ḥinn xafi, \add a\add* AREBBI,  
\m ɛlaḥsab tamexsiwt nnec icewwaren.  
\m Mseḥ ixeṭṭan inu  
\m ɛlaḥsab afeyyeḍ n arreḥmet nnec.   
\m
\v 4 Ssird řmuɛṣiyyet inu zzayi marra,  
\m sizdeg ayi zi ddenb inu,   
\b  
\m
\v 5 maɣar necc ssneɣ ixeṭṭan inu,  
\m ddenb inu řebda ibedd ayi-dd  
\m ɣar tiṭṭawin. \f ◼ \fr 51:5 \ft \+fk ibedd ayi-dd ɣar tiṭṭawin\ft  - s Tɛibranit ‘ibedd qibač i nnec’.\f*   
\m
\v 6 Akidek, \add akidek\add* waha i xḍiɣ,  
\m ggiɣ min iǧan d aɛeffan  
\m jar tiṭṭawin nnec,  
\m ařami Cek tseggded  
\m deg wawařen nnec,  
\m teṣfid di řeḥkamat nnec. \x ◘ \xo 51:6 \xt Rum. 3:4\x*   
\b  
\m
\v 7 Xzar, ttwaxeřqeɣ-dd di ddnub,  
\m di ddnub teksi ayi yemma.   
\m
\v 8 Xzar, Cek tᵉttexsed tidett di daxeř,  
\m di tnuffra tesscaned ayi tiɣit.   
\b  
\m
\v 9 Ksi xafi ddnub s tɛelǧet,  
\m xenni ad dewřeɣ qqureɣ,  
\m sird ayi, \add xenni\add* ad dewřeɣ  
\m d acemřař x wedfeř. \x ◘ \xo 51:9 \xt Lawi 14:4, 6; Řxř. 19:6, 18; Ica. 1:18\x*   
\m
\v 10 Arr ayi ad sřeɣ arcuq d řefraḥet,  
\m ḥima iɣsan nni třebzed Cek,  
\m ad ceḍhen s řefraḥet.   
\m
\v 11 Snuffar udem nnec  
\m zzat i ddnub inu,  
\m mseḥ i marra řmuɛṣiyyet inu.   
\b  
\m
\v 12 Xřeq-dd dayi uř izdig, \add a\add* AREBBI,  
\m jedded di daxeř inu  
\m ijj n arruḥ imetnen.   
\m
\v 13 War d ayi neṭṭar zeg wudem nnec,  
\m war zzayi ttekkes  
\m Arruḥ Iqeddsen nnec.   
\b  
\m
\v 14 Ewc ayi ɛawed  
\m řefraḥet n usenjem nnec,  
\m uřa d ijj n buḥbeř amseɛɛaf  
\m i kidi ɣa ibedden.   
\m
\v 15 \add Xenni\add* ad ssɣareɣ ibriden nnec  
\m i yinni \add xak\add* iɛeddan,  
\m \add ḥima\add* ad ɣarek dd-ɛeqben imednab.   
\b  
\m
\v 16 Fekk ayi zeg umarwas n idammen,  
\m \add a\add* AREBBI, AREBBI n usenjem inu,  
\m \add xenni\add* ad isřewřiw iřes inu  
\m x tsegda nnec.   
\m
\v 17 Arzem ayi iyencicen inu, \add a\add* Sidi inu,  
\m \add xenni\add* ad ibarreḥ uqemmum inu  
\m s ccan nnec,   
\m
\v 18 maɣar war d ak tecqi tɣarṣt,  
\m iři wciɣ ac tt,  
\m taɣarṣt n wecmaḍ  
\m war d ac dd-tᵉttis x řxaḍar.   
\m
\v 19 Tiɣarṣa n AREBBI  
\m aqa atent d ijj n buḥbeř yareẓ,  
\m ijj n wuř iddez  
\m war t tesseḥqarid, \add a\add* AREBBI!   
\b  
\m
\v 20 Egg řxar i Ṣihyun ɛlaḥsab arḍa nnec,  
\m bna řeḥyuḍ n Urcalim!   
\m
\v 21 Xenni ad tarḍid di tɣarṣa n řmuɛṣiyyet,  
\m di tɣarṣt n wecmaḍ ikemmřen.  
\m \add Xenni\add* ad qeddmen ifunasen imeẓyanen  
\m x uɛalṭar nnec,   
\b  
\b  
\m  
\c 52
\m
\v 1 \add I umeqqran n imeɣnajen. Axemmi n Dawud.\add*   
\m
\v 2 \add Řami dd-yusa Duwaɛ, zi Idum,\add* \add ixebbar Cawul, inna as:\add*  
\m \add “Aqa Dawud yusa-dd ɣar taddart n Aximalik.”\add* \x ◘ \xo 52:2 \xt 1 Ṣm. 22:9-23\x*   
\b  
\m
\v 3 Mammec tfeyyced zi tɛeffant, \add a\add* jjiheř?  
\m Tamexsiwt icewwaren n Arebbi  
\m \add tᵉttekk\add* ass imun.   
\m
\v 4 Iřes nnec ittxarreṣ di řɣar,  
\m am mammec řmus iqeḍɛen i uḥeffi  
\m yiwyi druct s řɣefřet.   
\m
\v 5 Cek tᵉttexsed taɛeffant aṭṭas x tṣebḥant,  
\m řhard s ixarriqen  
\m ktar x řhard n tsegda. Silah.   
\m
\v 6 Cek tᵉttexsed awařen ittakkʷaren,  
\m uřa d iřes \add iccur\add* s wecmat.   
\b  
\m
\v 7 Maca Arebbi ad cek yareddeǧ i řebda,  
\m Netta ad cek iṭṭef,  
\m ad cek ikkes zi tzeddiɣt.  
\m Netta ad cek iqřeɛ zeg iẓewran nnec  
\m zi temmurt n yinni iddaren. Silah.   
\m
\v 8 Imseggaden ad t ẓaren ad ggʷeden.  
\m Ad xas ḍeḥcen, \add ad inin\add*:   
\m
\v 9 “Xzar aryaz ijehden  
\m wenni umi war iggi AREBBI jjehd nnes,  
\m maca tuɣa ittceř  
\m x wagřa nnes ameqqran.  
\m Tuɣa idweř ijhed  
\m s ṭṭbiɛet nnes iɣeccen.”   
\b  
\m
\v 10 Necc ad iřiɣ  
\m am yict n tzitunt tazeyzawt  
\m di Taddart n AREBBI.  
\m I řebda qaɛ i ɣa ttiqqeɣ  
\m di tmexsiwt icewwaren n AREBBI.   
\m
\v 11 Necc ad Cek qadiɣ i řebda qaɛ,  
\m maɣar Cek teggid \add t\add*.  
\m Ad ssitimeɣ deg Yisem nnec,  
\m maɣar Netta d aṣebḥan  
\m i imtiqqan nnec.   
\b  
\b  
\m  
\c 53
\m
\v 1 \add I umeqqran n imeɣnajen. S teɣnint n ‘Izři n wecḍan’.\add* \add Axemmi n Dawud.\add*   
\b  
\m
\v 2 Abuhaři inna deg wuř nnes:  
\m “War din bu AREBBI!”  
\m Nitni ttareddǧen,  
\m tteggen min iǧan d nnɛi n řɣecc,  
\m war din uřa d ijj ittegg min icnan. \x ◘ \xo 53:2 \xt Izhd. 10:4; Izhd. 14; Rum. 3:12 \x*   
\m
\v 3 AREBBI ixezzar-dd zeg ujenna  
\m ɣar tarwa n bnadem,  
\m ḥima ad iẓar ma din ḥed  
\m ɣares řefhamet,  
\m ijjen i yarezzun AREBBI. \x ◘ \xo 53:3 \xt Rum. 3:11\x*   
\m
\v 4 Marra ffɣen zeg webrid,  
\m \add aqa aten jmiɛ\add* dewřen d iɛeffanen,  
\m war din uřa d ijj ittegg řxar,  
\m uřa d ijj.   
\b  
\m
\v 5 Inni itteggen řmuɛṣiyyet  
\m ma war ɣarsen tussna,  
\m inni ittᵉtten řgens inu  
\m axmi ttᵉtten aɣrum?  
\m Nitni war ttřaɣan x AREBBI.   
\b  
\m
\v 6 Aqa din i xasen tewḍa  
\m tiggʷudi imɣaren,  
\m umi war din \add min zi\add* i ɣa ggʷeden,  
\m maɣar AREBBI iṭarrec iɣsan  
\m n wenni xak ihejjmen.  
\m Cek tessbehdřed i-ten,  
\m minzi AREBBI inḍar i-ten.   
\m
\v 7 Ah, iři asenjem ameqqran n Israil  
\m ad dd-yas \add deɣya\add* zi Ṣihyun!  
\m Xmi dd ɣa inneqřeb AREBBI  
\m tameḥbast n řgens nnes,  
\m ad yarceq Yaɛqub,  
\m ad ifarḥ Israil. \x ◘ \xo 53:7 \xt Yḥ. 4:22; Asa. 14:1\x*   
\b  
\b  
\m  
\c 54
\m
\v 1 \add I umeqqran n imeɣnajen. Ak-d uzenzun x ifiřan. Axemmi n Dawud.\add*   
\b  
\m
\v 2 \add Řami dd-usin Izifiyyen, nnan as i Cawul: “Ma war issnuffar Dawud ixef nnes ɣarneɣ?”\add*\x ◘ \xo 54:2 \xt 1 Ṣm. 23:19-28; 26:1\x*   
\b  
\m
\v 3 Senjem ayi, \add a\add* AREBBI, s Yisem nnec,  
\m aɣ ayi tasɣart s tzemmar nnec ijehden.   
\m
\v 4 \add A\add* AREBBI, seř i tẓaǧit inu,  
\m sḥess i wawařen n uqemmum inu.   
\m
\v 5 Maɣar ibarraniyyen kkaren akidi,  
\m ayt n bu-řexcunet arezzun ad ayi nɣen.  
\m War tteggen ca AREBBI  
\m zzat i tiṭṭawin nsen. Silah. \f ◼ \fr 54:5 \ft \+fk arezzun ad ayi nɣen\ft  - s Tɛibranit ‘arezzun ad nɣen řeɛmar inu’.\f*   
\b  
\m
\v 6 Xzar, AREBBI d amɛawen inu.  
\m Sidi inu aqa-t jar yinni d ayi isennden.   
\m
\v 7 Netta ad ixeǧeṣ řɣar  
\m i yinni d ayi iḥeṣṣaren.  
\m Qḍa xasen di řaman nnec.   
\m
\v 8 S řxaḍar ad ac dd-awyeɣ tiɣarṣa,  
\m ad qadiɣ Isem nnec, \add a\add* SIDI,  
\m maɣar \add Netta\add* d aṣebḥan,   
\m
\v 9 maɣar Netta ifekk ayi  
\m zi marra řeḥṣaret,  
\m uca yarra ayi-dd ad xezzareɣ  
\m x řɛedyan inu swadday.   
\b  
\b  
\m  
\c 55
\m
\v 1 \add I umeqqran n imeɣnajen.\add* \add Ak-d uzenzun x ifiřan.\add* \add Axemmi n Dawud.\add*   
\b  
\m
\v 2 \add A\add* AREBBI, seř i tẓaǧit inu,  
\m war ssnuffara ca Ixef nnec  
\m zzat i tutra inu.   
\m
\v 3 Ḥḍa ayi u arr-dd xafi.  
\m Necc ttraḥeɣ ttaseɣ-dd  
\m ɣar zzat d ḍeffar,  
\m am ttcetciɣ u ssɣunfiɣ,   
\m
\v 4 zi ssibbet n řḥess n řeɛdu,  
\m zeg uhuddi n uɛeffan.  
\b  
\m Maɣar nitni hejmen-dd xafi s řmuɛṣiyyet,  
\m ḍeffaren ayi s uxeyyeq.   
\m
\v 5 Uř inu ittfarfir dayi daxeř,  
\m inexřiɛen n řmewt wḍan-dd xafi.   
\m
\v 6 Tiggʷudi d tarjijit ttᵉṭṭfent ayi,  
\m uřa d arjef iḥeṣṣar ayi.   
\b  
\m
\v 7 Necc nniɣ:  
\m “Mři d ayi wcin afriwen am tedbirt,  
\m \add xenni\add* iři ḍwiɣ, ad zedɣeɣ  
\m di ca n wemcan \add nneɣni\add*.”   
\m
\v 8 Xzar, ad arewřeɣ ɣar řaggʷaj qaɛ,  
\m ad ssenseɣ di řexřa. Silah.   
\m
\v 9 Ad deɣyeɣ ɣar wemcan n ufekki,  
\m ḥima ad ttwafekkeɣ  
\m zeg usemmiḍ, zi tḥaryaḍt.   
\b  
\m
\v 10 Ṣarḍ i-ten, \add a\add* Sidi inu, sebḍa iřes nsen,  
\m minzi ttwařiɣ lɛunf d umenɣi di tendint.   
\m
\v 11 Ass d ǧiřet quwwaren nitni i řeḥyuḍ nnes.  
\m Ɣar daxeř n tendint \add aqa din\add* řeɣben d tamara,   
\m
\v 12 řɣecc aqa-t daxeř nnes,  
\m azzay nnes war zzayes ittḥeyyid ca  
\m ddeǧ d wecmat.   
\b  
\m
\v 13 Maɣar war iǧi d řeɛdu  
\m wenni d ayi isseḥqaran,  
\m \add minzi\add* aya zemmareɣ ad t ksiɣ.  
\m \add War iǧi\add* uřa d wenni d ayi icarrhen  
\m d wenni issemɣaran ixef nnes  
\m \add s wawař\add* xafi,  
\m \add minzi\add* zzayes zemmareɣ ad nnuffareɣ!   
\m
\v 14 \add Maca\add* aqa d cek, \add a\add* bnadem,  
\m cek d aqrin inu,  
\m ameddukkeř inu d jjar inu!   
\m
\v 15 Neccin inni igguren d lemliḥ  
\m ak-d wayawya di ttiqqet,  
\m neggur ɣar Taddart n AREBBI  
\m deg uhimur.   
\b  
\m
\v 16 Ad xasen tewḍa řmewt  
\m \add ařami\add* i ɣa hwan am ddaren di řaxart,  
\m maɣar aqa din řɣar di tzeddiɣin nsen,  
\m deg wuřawen nsen. \f ◼ \fr 55:16 \ft \+fk deg wuřawen nsen\ft  - s Tɛibranit ‘di daxeř nsen’.\f*   
\m
\v 17 Necc, \add wah,\add* necc ad řaɣiɣ x AREBBI,  
\m SIDI ad ayi issenjem.   
\b  
\m
\v 18 Ɣar tmeddit, ɣar tuffut u s uziř  
\m ad cetciɣ, ad ssɣunfeɣ  
\m u Netta ad iseř i tmijja inu.   
\m
\v 19 Netta igga aṣřaḥ x řeɛmar inu s řehna  
\m zeg inni ɣari dd-iqarrben \add i wehjam\add*,  
\m minzi aqa-ten deg waṭṭas ḍidd inu. \f ◼ \fr 55:19 \ft \+fk ifdi\ft  - xzar Izhd. 78:35.\f*   
\m
\v 20 Arebbi ad iseř, ad ten dd-issehwa.  
\m Netta ittɣima \add x řɛarc\add*  
\m zeg wecḥař uya. Silah.  
\m Aqa nitni war ttbeddiřen,  
\m war tteggʷeden ca AREBBI.   
\b  
\m
\v 21 Netta ineṭṭar afus deg inni  
\m ak-d wi \add igga\add* řehna,  
\m netta issexsar řɛahd nnes.   
\m
\v 22 Aqemmum nnes yarḍeb ḥsen zi trussi,  
\m maca deg wuř nnes itturja amenɣi.  
\m Awařen nnes d iřeqqaɣen x zzect,  
\m \add maca\add* aqa aten \add am\add* řesyuf ttwajebden.   
\b  
\m
\v 23 Nḍar amnus nnec x SIDI  
\m u Netta ad dayek itthilla.  
\m Ɛemmarṣ war ittejji  
\m amsegged ad ifarɣ.   
\m
\v 24 Cek \add maca\add*, \add a\add* AREBBI,  
\m ad ten tessehwid deg weḥfur n turṣuḍi.  
\m Iryazen n idammen d řɣecc  
\m war ttkemmřen  
\m azyen n wussan nsen.  
\m \add Maca\add* necc ttecřeɣ xak.   
\b  
\b  
\m  
\c 56
\m
\v 1 \add I umeqqran n imeɣnajen. S teɣnint n ‘Ict n tedbirt ibekkmem deg imucan iggʷejen’.\add* \add N Dawud. Tira ineqcen,\add* \add řami t ṭṭfen Ifilisṭiniyyen di Jat.\add* \x ◘ \xo 56:1 \xt 1 Ṣm. 21:12, 13, 14\x*   
\b  
\m
\v 2 Ḥinn xafi, \add a\add* AREBBI,  
\m maɣar ijj n bnadem yarezzu  
\m ad ayi isarḍ,  
\m iḥeṣṣar ayi umjahed ass marra.   
\m
\v 3 Inni d ayi iḥeṣṣaren xsen  
\m ad ayi ṣarḍen ass marra,  
\m maɣar inni kidi ittmenɣan s nnfaxet,  
\m aqa aten deg waṭṭas!   
\m
\v 4 Deg wass i di i ɣa ggʷedeɣ,  
\m ad xak ttecřeɣ,   
\m
\v 5 x AREBBI, wenni umi ɣa ṣebḥeɣ  
\m awař nnes,  
\m x AREBBI i ttecřeɣ,  
\m war tteggʷideɣ ca,  
\m \add maɣar\add* min zemmaren  
\m ad ayi ggen midden? \f ◼ \fr 56:5 \ft \+fk midden\ft  - s Tɛibranit ‘bacar’ niɣ ‘aysum’, ixs ad yini ‘bnadem’ niɣ ‘midden’ (xzar Izhd. 118:6).\f*   
\b  
\m
\v 6 Nitni qeǧben awařen inu ass ikmeř,  
\m marra tnawi nsen aqa aten xafi d řɣar.   
\m
\v 7 Nitni munen, nuffaren,  
\m nitni ḥeṭṭan inarziwen inu,  
\m xmi arezzun \add ad nɣen\add* řeɛmar inu.   
\m
\v 8 Ma zemmaren ad arewřen  
\m waxxa ggin řɣecc?  
\m Sehwa řegnus  
\m deg weɣḍab nnec, \add a\add* AREBBI!   
\b  
\m
\v 9 Cek tḥessbed \add ussan n\add* weṭlaɛ inu.  
\m Egg imeṭṭawen inu di tzeyyat n waman nnec,  
\m - ma war ǧin deg wedlis nnec? -   
\m
\v 10 xenni ad dewřen řɛedyan inu ɣar ḍeffar,  
\m deg wass umi ɣa řaɣiɣ.  
\m Necc ssneɣ aya: AREBBI aqa-t akidi.   
\m
\v 11 X AREBBI, wenni umi  
\m ɣa ssemɣareɣ awař nnes,  
\m x SIDI, wenni umi  
\m ɣa ssemɣareɣ awař nnes,   
\m
\v 12 x AREBBI i xef ttecřeɣ,  
\m war tteggʷideɣ ca,  
\m \add maɣar\add* min izemmar bnadem  
\m ad ayi yegg? \x ◘ \xo 56:12 \xt Izhd. 118:6\x*   
\b  
\m
\v 13 Xafi, \add a\add* AREBBI,  
\m arsin lwuɛud i Cek \add ittwaggen\add*.  
\m Ad \add ten\add* kemmřeɣ i Cek s uqadi.   
\m
\v 14 Maɣar Cek tfekked řeɛmar inu  
\m zi řmewt!  
\m Ma \add war teḥḍid\add* iḍaren inu  
\m zeg uneqraḍ,  
\m ḥima ad uyureɣ  
\m zzat i wudem n AREBBI  
\m di Tfawt n Tudart?   
\b  
\b  
\m  
\c 57
\m
\v 1 \add I umeqqran n imeɣnajen. ‘War t ttareddeǧ!’ N Dawud.\add* \add Tira ineqcen. Umi yarweř zi Cawul deg ifri.\add*\x ◘ \xo 57:1 \xt 1 Ṣm. 22:1; 24:4\x*   
\b  
\m
\v 2 Ḥinn xafi, \add a\add* AREBBI, ḥinn xafi,  
\m maɣar řeɛmar inu yarekkwař-dd ɣarek.  
\m Necc ufiɣ adurri  
\m di tiři n wafriwen nnec,  
\m ař ɣa ɛdunt řmuṣibat.   
\b  
\m
\v 3 Necc ad řaɣiɣ ɣar AREBBI,  
\m Amɛuǧi x kuřci,  
\m ɣar Arebbi wenni d ayi ɣa inedhen  
\m ɣar uneggar \add iṣebḥen\add*.   
\m
\v 4 Netta ad dd-issekk asenjem inu  
\m zeg ujenna,  
\m ad issbehdeř wenni ixsen  
\m ad ayi isarḍ. Silah.  
\m AREBBI ad issekk  
\m tamexsiwt nnes icewwaren  
\m d řaman nnes.   
\b  
\m
\v 5 Řeɛmar inu aqa-t jar iyraden,  
\m zzřeɣ jar iṣefḍawen yareqqen,  
\m tarwa n bnadem, inni tiɣmas nsen  
\m \add am\add* lansat d fřitcat \add n řqews\add*,  
\m iřes nsen am yijj n ssif iqḍeɛ.   
\m
\v 6 \add A\add* AREBBI, sgeɛɛed Ixef nnec  
\m tiwa i ijenwan,  
\m \add arr\add* aɛuǧi nnec  
\m sennej i marra tammurt. \x ◘ \xo 57:6 \xt Izhd. 108:6\x*   
\b  
\m
\v 7 Nitni ggin tracca i iṣuraf inu,  
\m řeɛmar inu tuɣa iɣnes.  
\m Nitni ɣzin ayi aḥfur,  
\m \add maca\add* wḍan dayes simant nsen.  
\m Silah. \x ◘ \xo 57:7 \xt Izhd. 7:16; 9:16\x*   
\b  
\m
\v 8 \add A\add* AREBBI, uř inu yarekken,  
\m uř inu yarekken.  
\m Aqa necc ad ɣennjeɣ ad zehhdeɣ. \x ◘ \xo 57:8 \xt Izhd. 108:2-6\x*   
\m
\v 9 Faq, aɛuǧi inu! Faq,  
\m lharpa d řgambri!  
\m Necc ttexseɣ ad ssfaqeɣ  
\m tafawt n řefjar.   
\b  
\m
\v 10 Necc ad Cek qadiɣ jar řegnus,  
\m \add a\add* Sidi inu,  
\m ad zehhdeɣ jar ccuɛub i Cek. \x ◘ \xo 57:10 \xt Izhd. 108:4\x*   
\m
\v 11 Maɣar tamexsiwt nnec icewwaren  
\m \add tᵉttakkwaḍ\add* ař ijenwan,  
\m řaman nnec ař iseynuten. \x ◘ \xo 57:11 \xt Izhd. 36:6; 108:5\x*   
\m
\v 12 \add A\add* AREBBI, sgeɛɛed Ixef nnec  
\m tiwa i ijenwan,  
\m \add arr\add* aɛuǧi nnec  
\m sennej i marra tammurt.   
\b  
\b  
\m  
\c 58
\m
\v 1 \add I umeqqran n imeɣnajen. ‘War t ttareddeǧ!’\add* \add N Dawud. Tira ineqcen.\add*   
\m
\v 2 Ma tessawařem s tidett  
\m tasegda deg useɣdi?  
\m Ma tḥekkmem tarwa n bnadem  
\m s řḥeqq?   
\m
\v 3 Lla, \add maca\add* deg wuř \add nwem\add*  
\m tᵉtteggem řɣecc,  
\m x temmurt twezznem  
\m lɛunf n ifassen nwem.   
\b  
\m
\v 4 Zeg \add wami ǧan di\add* řemřawet  
\m ffɣen iɛeffanen zeg webrid,  
\m zeg uɛeddis n yemmatsen  
\m weddaren ayt n bu-ixarriqen.   
\m
\v 5 Aqa daysen ssem am semm n ufiɣar.  
\m Nitni am yict n třefsa tadehcurt,  
\m tenni iqqnen amezzuɣ nnes, \x ◘ \xo 58:5 \xt Izhd. 140:4\x*   
\m
\v 6 tenni war ittesřin  
\m ɣar tmijja n iɛezzamen,  
\m \add uřa ɣar tmijja\add* n useḥḥar  
\m nni ittḥakan aṭṭas di tseḥḥart.   
\b  
\m
\v 7 \add A\add* AREBBI, arẓ asen tiɣmas  
\m deg uqemmum nsen,  
\m arẓ tiɣmas n teɣmart  
\m n iyraden imeẓyanen, \add a\add* SIDI!   
\m
\v 8 Ejj i-ten ad fesyen am waman,  
\m ařami ad ffɣen.  
\m Mařa imeḥḥeḍ \add řqews\add* s fřitcat nnes,  
\m ejj i-ten war qḍiɛen.   
\m
\v 9 Ejj i-t ad ifna am ubucceř irizzen.  
\m Ejj i-ten war ẓarren tfuct,  
\m am weṭṭu n uɛeddis n tmeṭṭut.   
\m
\v 10 Qbeř i ɣa acant marmitat nwem  
\m ak-d \add řeḥmu n\add* cbarq ak-d isennanen,  
\m ad dayes isuḍ ařami ad yaẓẓeř  
\m x \add weysum\add* d aziza  
\m niɣ \add x weysum\add* itteḥduduqen.   
\b  
\m
\v 11 Amsegged ad ifarḥ  
\m xmi ɣa iẓar antaqem.  
\m Netta ad issird iḍaren nnes  
\m deg idammen n iɛeffanen.   
\m
\v 12 Ad yini bnadem:  
\m “Wah, aqa din řɣiǧet i umsegged,  
\m aqa din ijj n AREBBI  
\m nni iḥekkmen di temmurt.”   
\b  
\b  
\m  
\c 59
\m
\v 1 \add I umeqqran n imeɣnajen. ‘War t ttareddeǧ!’\add* \add N Dawud. Tira ineqcen.\add* \add Umi Cawul ijja ad ḥḍan taddart n Dawud ḥima ad t nɣen.\add*\x ◘ \xo 59:1 \xt 1 Ṣm. 19:12\x*   
\b  
\m
\v 2 Fekk ayi zi řɛedyan inu, \add a\add* AREBBI,  
\m sgeɛɛed ayi sennej ɣar uḥeṭṭu  
\m zeg inni xafi ittekkaren.   
\m
\v 3 Fekk ayi zeg inni itteggen řɣecc,  
\m senjem ayi zeg iryazen n idammen.   
\m
\v 4 Aqa, xzar, nitni ggin  
\m ijj n řfex i řeɛmar inu,  
\m ayt n bu-ṣṣulṭa munen xafi.  
\m War din axeṭṭu  
\m uřa d ddenb ɣari, \add a\add* SIDI!   
\m
\v 5 \add Waxxa\add* war ggiɣ ljarima,  
\m aqa nitni \add zeɛma\add* usin-dd  
\m ttazzřen-dd ɣari  
\m u sswejjaden ixef nsen.  
\m Faq, as-dd ɣar umsagar akidi u xzar.   
\m
\v 6 Cek, \add a\add* SIDI, AREBBI n řɛeskarat,  
\m AREBBI n Israil,  
\m faq ḥima ad třeqfed marra řegnus.  
\m War ttḥinni x uřa d ijj  
\m zi marra iɣeddaren  
\m inni itteggen řɣecc. Silah.   
\b  
\m
\v 7 Aqa ttɛeqben ɣar tmeddit,  
\m ttzun am weqzin,  
\m ttennḍen i tendint. \x ◘ \xo 59:7 \xt Izhd. 59:15\x*   
\m
\v 8 Xzar, s uqemmum nsen ssusufen \add qaɛ\add*,  
\m řesyuf nsen aqa aten  
\m x iyencicen nsen,  
\m minzi man wen i ɣa isřen? \x ◘ \xo 59:8 \xt Izhd. 10:11; 55:22; 57:5; 94:7 \x*   
\m
\v 9 Cek \add maca\add*, \add a\add* SIDI, ad xasen tḍeḥced,  
\m Cek ad tḥecced x marra řegnus. \x ◘ \xo 59:9 \xt Izhd. 2:4\x*   
\m
\v 10 \add A\add* jjehd nnes, necc ad t rajiɣ,  
\m maɣar AREBBI d lburj inu yuɛřan.   
\b  
\m
\v 11 Tamexsiwt icewwaren n AREBBI inu  
\m ad ayi tizwar,  
\m AREBBI ad ayi yarr  
\m ad ẓareɣ inni d ayi iḥeṣṣaren.   
\m
\v 12 War ten neqq ca,  
\m maḥend řgens inu war t ittettu.  
\m Ejj i-ten ad weddaren s jjehd nnec,  
\m menḍar i-ten swadday,  
\m \add maɣar Cek d\add* taseddart nneɣ i useřqi,  
\m \add a\add* Sidi inu.   
\m
\v 13 \add X\add* ddnub n uqemmum nsen,  
\m \add x\add* wawařen i dd-itteffɣen  
\m zeg iyencicen nsen,  
\m \add x uya\add* ejj i-ten ad ttwaḥebbsen  
\m di nnfaxet nsen,  
\m uřa x nneɛřet u x uxarriq  
\m nni xef ttḥarden.   
\m
\v 14 Keḥḥeḍ i-ten deg wesɛar \add nnec\add*,  
\m keḥḥeḍ i-ten ařami war ǧin \add ɛad\add*,  
\m arr i-ten ad ssnen,  
\m aqa AREBBI d řḥakem di Yaɛqub,  
\m ař tineggura n temmurt. Silah.   
\b  
\m
\v 15 Aqa ad ɛeqben ɣar tmeddit,  
\m ttzun am weqzin  
\m u ttennḍen i tendint. \x ◘ \xo 59:15 \xt Izhd. 59:7\x*   
\m
\v 16 Ejj i-ten ttemhafan da d diha x macca,  
\m ejj i-ten \add xenni\add* ad qqimen ssnusan,  
\m mařa war jjiwnen,   
\m
\v 17 Necc ad ɣennjeɣ x jjhed nnec,  
\m ɣar teffut ad sřiwřeweɣ  
\m x tmexsiwt nnec icewwaren,  
\m maɣar tuɣa Cek  
\m d ijj n lburj yuɛřan i necc,  
\m d amcan n tarewřa  
\m deg wass n řeḥṣaret inu.   
\m
\v 18 Jjehd inu, necc ad zehhdeɣ i Cek,  
\m maɣar Cek AREBBI d lburj inu yuɛřan,  
\m AREBBI n tmexsiwt inu icewwaren.   
\b  
\b  
\m  
\c 60
\m
\v 1 \add I umeqqran n imeɣnajen. S teɣnint n ‘Talillect d acehhad’.\add* \add Tira ineqcen n Dawud i useřmed.\add* \f ◼ \fr 60:1 \ft \+fk Talillect\ft  - ict n marka n nnuwarat daysen aẓri aṭṭas.\f*   
\m
\v 2 \add X řami tuɣa ittmenɣa ak-d imezdaɣ n Aram-Nahrayn, aqa-tt d Misuputamya,\add* \add u ak-d ayt n Aram zi Ṣuba, umi dd-idweř Yuwab,\add* \add iwta ayt n Idum di teɣzurt n Tmeǧaḥt, ɛecra ařaf n yeryazen.\add*\x ◘ \xo 60:2 \xt 2 Ṣm. 8:3, 13; 1 Im. 18:3, 12\x*   
\b  
\m
\v 3 \add A\add* AREBBI, Cek tenḍareḍ aneɣ,  
\m tarẓid aneɣ.  
\m Tuɣa tesɛared \add aṭṭas\add*!  
\m Sbedd aneɣ ɛawed! \x ◘ \xo 60:3 \xt Izhd. 144:10\x*   
\m
\v 4 Cek tessenhezzed tammurt,  
\m tfeǧqed tt.  
\m Sgenfa tireẓẓa nnes,  
\m maɣar aqa tᵉttenhezza.   
\m
\v 5 Cek tessecned \add Ixef nnec\add*  
\m i řgens nnec s řeqsaḥet.  
\m Cek tewcid aneɣ  
\m ad nsu ccrab issdewwaxen. \x ◘ \xo 60:5 \xt Ica. 51:17-23\x*   
\m
\v 6 Inni Cek itteggʷeden,  
\m teggid asen taɛeǧant  
\m i ɣar ttrakkwařen  
\m zi \add fřitcat n\add* řqews. Silah.   
\m
\v 7 Ḥima imɛizzen nnec ad ttwafekken,  
\m awi asenjem s ufus afusi nnec  
\m u arr-dd xaneɣ. \x ◘ \xo 60:7 \xt Izhd. 108:7-14\x*   
\b  
\m
\v 8 AREBBI tuɣa issawař  
\m di Zzawect nnes Iqeddsen,  
\m s uyenni ad negzeɣ s řefraḥet.  
\m Necc ad bḍiɣ Cakim,  
\m ad ɛebbareɣ taɣzurt n Sukkut.   
\m
\v 9 Jilɛad inu, Manassa inu,  
\m Ifrayim d aseřqi ijehden n uzeǧif inu,  
\m Yahuda d amgewwed inu.   
\m
\v 10 Mu’ab d ssarij inu i usird,  
\m x Idum ad nḍareɣ sandaliyat inu,  
\m necc ad dduqzeɣ s usřiwřew  
\m x \add temmurt n\add* Filicit.   
\b  
\m
\v 11 Wi d ayi i ɣa inedhen  
\m \add di\add* tendint ifaryen?  
\m Wi d ayi ɣa igewwden ɣar Idum?   
\m
\v 12 Ma war d aneɣ tenḍared, \add a,\add* AREBBI,  
\m u ak-d řɛeskarat nneɣ  
\m ma war akidsen dd-teffiɣed \add ɛad\add*,  
\m \add a\add* AREBBI?   
\m
\v 13 Ewc aneɣ afus  
\m \add ḥima ad aneɣ tessnejmed\add* zi řeḥṣaret,  
\m \add maɣar\add* asenjem \add s ufus n\add* yijj n bnadem  
\m aqa-t baṭeř.   
\m
\v 14 Ak-d AREBBI ad negg s wemḥad,  
\m Netta ad iɛfes x yinni d aneɣ iḥeṣṣaren.   
\b  
\b  
\m  
\c 61
\m
\v 1 \add I umeqqran n imeɣnajen. Ak-d uzenzun x ifiřan. N Dawud.\add*   
\b  
\m
\v 2 \add A\add* AREBBI, seř i uřaɣi inu,  
\m seř mliḥ i tẓaǧit inu.   
\m
\v 3 Zi ṭṭarf aneggar n temmurt  
\m ttřaɣiɣ xak,  
\m xmi ittefciř wuř inu.  
\m Ndeh ayi x ijj n jjarf yuɛřan xafi.   
\m
\v 4 Maɣar Cek d amcan n tarewřa i necc,  
\m d lburj ijehden ḍidd i řeɛdu.   
\m
\v 5 Necc ad qqimeɣ  
\m deg Uqiḍun nnec i řebda,  
\m ad arewřeɣ  
\m sadu udurri n wafriwen nnec. Silah.   
\b  
\m
\v 6 Maɣar Cek, \add a\add* AREBBI,  
\m tesřid ɣar lwuɛud inu.  
\m Cek tewcid \add ayi\add* tasɣart  
\m n yinni itteggʷeden Isem nnec.   
\m
\v 7 Arni \add ɛad\add* ussan x wussan n ujeǧid,  
\m ejj ad aredfen iseggʷusa nnes  
\m ijj i wenneɣni  
\m am jjiř iḍfar umas.   
\m
\v 8 Netta ad iqqim  
\m zzat i wudem n AREBBI i řebda.  
\m Ad xas teḥḍa  
\m tamexsiwt icewwaren d řaman.   
\m
\v 9 Xenni ad zehhdeɣ i Yisem nnec i řebda,  
\m ḥima ad kemmřeɣ lwuɛud inu,  
\m ass \add awarni\add* umas.   
\b  
\b  
\m  
\c 62
\m
\v 1 \add I umeqqran n imeɣnajen. Sadu ufus n Yadutun. N Dawud.\add*   
\b  
\m
\v 2 Wah, řeɛmar inu yaressa,  
\m ittraja AREBBI waha,  
\m aqa zzayes \add dd-ittas\add* usenjem inu.   
\m
\v 3 Wah, Netta d taṣḍart inu d usenjem inu,  
\m lburj inu yuɛřan, war ttᵉfriɣeɣ aṭṭas.   
\m
\v 4 Mecḥař \add ɛad\add* i ɣa tekkem  
\m thejjmem x weryaz?  
\m \add Mecḥař ɛad\add* aqa třehham  
\m maḥend ad t teɣḍřem,  
\m am ijj n řḥiḍ iweṭṭa,  
\m am yijj n weɣbar ittwaɣḍeř?   
\b  
\m
\v 5 Wah, nitni ttemcawaren waha  
\m ḥima ad t-i-dd-ɣeḍřen  
\m zeg wemcan nnes yuɛřan.  
\m Nitni areṭṭan s ixarriqen.  
\m Ttbarken s uqemmum nsen,  
\m \add maca\add* deg wuř nsen neɛɛřen. Silah. \f ◼ \fr 62:5 \ft \+fk deg wuř\ft  - di Tɛibranit ‘di dwaxeř nsen’.\f*   
\b  
\m
\v 6 Wah, raja i AREBBI, \add a\add* řeɛmar inu,  
\m minzi zzayes řayas inu.   
\m
\v 7 Wah, Netta d taṣḍart inu d usenjem inu,  
\m lburj inu yuɛřan, war ttefriɣeɣ ca.   
\m
\v 8 Asenjem inu d uɛuǧi inu  
\m aqa aten di AREBBI,  
\m \add Netta d\add* Taṣḍart inu ijehden,  
\m amcan inu n tarewřa  
\m aqa-t di AREBBI.   
\b  
\m
\v 9 Tiqqem řebda dayes, \add a\add* řgens!  
\m Zeǧɛem uř nwem zzat i wudem nnes.  
\m AREBBI d amcan nneɣ n tarewřa. Silah.   
\b  
\m
\v 10 Wah, tarwa n Adam  
\m aqa aten d řeɛwin,  
\m tarwa n weryaz aqa daysen axarriq.  
\m Ad geɛɛden di řmizan  
\m s tnayen n ṭṭawyat,  
\m aqa aten jmiɛ \add fsusen\add* x řeɛwin.   
\m
\v 11 War ttecřem x ddeǧ,  
\m war ttejjim ad kenniw jebbden  
\m \add zeg webrid\add* s ukkarḍa.  
\m Mařa agřa imeqqar,  
\m war xas ssrusam uř nwem.   
\m
\v 12 AREBBI issiweř ict n twařa,  
\m sřiɣ tnayen n twařawin,  
\m aqa: “Jjehd zi AREBBI”.   
\m
\v 13 Tamexsiwt icewwaren i Cek, \add a\add* Sidi inu!  
\m Minzi Cek ad txeǧṣed  
\m kuř ijj ɛlaḥsab min igga. \x ◘ \xo 62:13 \xt Ayub 34:11; Awřn. 24:12; Irm. 32:19; Ḥiz. 7:27; 33:20; Mt. 16:27; Rum. 2:6; 2 Kur. 5:10; Afa. 6:8; Kul. 3:25; 1 Bṭ. 1:17; Asa. 22:12\x*   
\b  
\b  
\m  
\c 63
\m
\v 1 \add Azehhed n Dawud, ařami t tuɣa di řexřa n Yahuda.\add*\x ◘ \xo 63:1 \xt 1 Ṣm. 22:5; 23:14, 15\x*   
\b  
\m
\v 2 \add A\add* AREBBI, Cek d Arebbi inu!  
\m Ɣar tuffut arezzuɣ xak,  
\m řeɛmar inu ittfada ɣarek,  
\m aysum inu ittmeẓri dayek,  
\m deg ict n temmurt yuẓɣen  
\m ittfadan břa aman. \f ◼ \fr 63:2 \ft \+fk aysum inu\ft  - aya ixs ad yini ‘arrimet inu’.\f*   
\m
\v 3 Ammu i dayek xezzareɣ  
\m di Zzawect Iqeddsen,  
\m ḥima ad ẓareɣ jjehd nnec d uɛuǧi nnec.   
\m
\v 4 Maɣar tamexsiwt nnec icewwaren  
\m teḥřa x tudart,  
\m s uyenni ad Cek ṣebbḥen  
\m iyencicen inu.   
\b  
\m
\v 5 Ammu i d ac ɣa barkeɣ di tudart inu,  
\m ad ssgeɛɛdeɣ ifassen inu deg Yisem nnec.   
\m
\v 6 Řeɛmar inu ad ijjiwen  
\m am zi tadunt d min imesřen,  
\m s iyencicen isřiwřewen  
\m ad \add Cek\add* iṣebbeḥ uqemmum inu,   
\m
\v 7 mařa ttxarrṣeɣ dayek di tassut,  
\m ttxemmameɣ dayek  
\m ɣar uḍufen n wecbar n ǧiřet.   
\m
\v 8 Minzi tuɣa Cek d amɛawen inu,  
\m di tiři n wafriwen nnec ad sřiwřeweɣ.   
\m
\v 9 Řeɛmař inu iřeṣṣeq dayek awarni ac,  
\m afus nnec afusi ittᵉṭṭef dayi.   
\b  
\m
\v 10 Inni ittexsen ad areddǧen řeɛmar inu,  
\m ad iwḍen ɣar imucan yuǧɣen qaɛ  
\m sadu temmurt.   
\m
\v 11 Nitni ad ttwasellmen  
\m i tzemmar n ssif,  
\m ad dewřen d takeccaḍt i iceɛbawen.   
\m
\v 12 Maca ajeǧid ad ifarḥ zi AREBBI.  
\m Kuř ijj zeg inni i ɣares i ɣa ittjaǧan  
\m ad ifeyyec,  
\m minzi aqemmum n yinni issawařen  
\m s ixarriqen ad ittwabelleɛ.   
\b  
\b  
\m  
\c 64
\m
\v 1 \add I umeqqran n imeɣnajen. Azehhed n Dawud.\add*   
\b  
\m
\v 2 Seř, \add a\add* AREBBI, i tmijja inu xmi ttcetciɣ,  
\m ḥḍa tudart inu zeg usiggʷed n řeɛdu.   
\m
\v 3 Sdurri ayi zi tmeɛmuč n iɛeffanen,  
\m zi řɣaci n yinni itteggen řmuɛṣiyyet,   
\m
\v 4 inni isseqḍaɛen iřes nsen  
\m am yijj n ssif,  
\m qarrṣen awař yarezgen  
\m am fřitca \add n řqews\add* nsen,   
\m
\v 5 ḥima ad wten \add s řqews\add*  
\m x wenni ikemmřen  
\m zeg imucan inuffaren.  
\m Deɣya ad xas neyycen,  
\m \add iwa\add* war din minzi i ɣa ggʷeden.   
\b  
\m
\v 6 Nitni ḥezzmen  
\m maḥend ad ggen min war iḥřin,  
\m ssawařen s tnuffra  
\m maḥend ad nedyen tixcifin.  
\m Qqaren: “Wi ten i ɣa iẓaren!”   
\m
\v 7 Nitni ttxarrṣen  
\m di \add marra min iǧan d\add* aɛeffan: “Aqa newjed,  
\m ict n tmeɛmuč n teḥraymect!”  
\m Aqa min iǧan daxeř deg weryaz  
\m u deg wuř nnes aqa yuǧeɣ.   
\b  
\m
\v 8 AREBBI ad ten iwwet s fřitca \add n řqews\add*,  
\m deɣya ad banen jjrayeḥ nsen.   
\m
\v 9 Iřes nsen ad ten yarr  
\m ad nqarḍen deg ixef nsen,  
\m kuř ijj, zeg inni ten ittwařan,  
\m ad yarweř.   
\m
\v 10 \add Xenni\add* ad ggʷeden marra iwdan,  
\m ad barrḥen timegga n AREBBI  
\m uca ad xzaren mliḥ di min dd ittegg.   
\m
\v 11 Amsegged ad ifarḥ di SIDI  
\m u ad ɣares dd-yarweř,  
\m marra inni umi isegged wuř ad farḥen.   
\b  
\b  
\m  
\c 65
\m
\v 1 \add I umeqqran n imeɣnajen. Azehhed n Dawud. Izři.\add*   
\b  
\m
\v 2 Aṣebbeḥ ittraja i Cek di řhudnet,  
\m \add a,\add* AREBBI, di Ṣihyun,  
\m \add ittxeṣṣa\add* ad ittwakemmeř lwaɛd i Cek.   
\m
\v 3 Cek tesřid i tẓaǧit,  
\m marra ddat ad ɣarek dd-yas.   
\m
\v 4 Řmuɛṣiyyet tuɣa tejhed xafi,  
\m \add maca\add* Cek tᵉttegged aṣřaḥ x ixeṭṭan nneɣ.   
\m
\v 5 Sseɛd n wenni i tfarrzed Cek  
\m u tessqarrbed t-i-dd \add ɣarek\add*,  
\m ḥima ad izdeɣ di řemraḥat nnec.  
\m Neccin ad nejjiwen  
\m s řxar n Taddart nnec,  
\m s tqeddast n Zzawect nnec Tameqqrant.   
\b  
\m
\v 6 Cek ad xaneɣ dd-tarred di tsegda  
\m s tmegga issaggʷaden,  
\m \add a\add* AREBBI n usenjem nneɣ.  
\m Aqa \add Cek\add* d řaman  
\m n marra tineggura n temmurt,  
\m n řebḥur iggʷejen qaɛ.   
\m
\v 7 \add Cek\add* d wenni issrusan idurar  
\m s jjhed nnes,  
\m Cek tbekksed s jjehd.   
\m
\v 8 \add Cek\add* d wenni ittarran  
\m řehweř n řebḥur yaressa,  
\m řehweř n řemwaj  
\m zzhir n ccuɛub.   
\m
\v 9 Inni izeddɣen ɣar tneggura \add n temmurt\add*  
\m tteggʷeden zi řeɛřamat nnec,  
\m aqa Cek tᵉttarrid řefjar n tuffut  
\m d weṭṭu n tmeddit ad sřiweřwen.   
\b  
\m
\v 10 Cek tarezzfed tammurt,  
\m tᵉttarrid \add tiɣezratin\add* ad tt cuqent,  
\m aqa Cek tᵉttarrid tt-i-dd  
\m s řxir aṭṭas.  
\m Iɣzar n AREBBI \add nni tt ittcuqa\add*  
\m aqa ittcur s waman.  
\m Cek tessewjaded imendi nsen,  
\m maɣar i uya i teggid tammurt.   
\m
\v 11 Cek tᵉttsawed mseqqem  
\m řatarat n wecraz,  
\m tesshekkʷid ibuda nnes.  
\m Tessarḍabed tammurt s inecnacen,  
\m tᵉttbarked aɣemmuy nnes.   
\b  
\m
\v 12 Cek tᵉttegged ttaj  
\m i useggʷas n řxar nnec,  
\m řatarat nnec ttudument s tadunt.   
\m
\v 13 Aqa ttudument x ddmani n řexřa,  
\m tiwririn bekksent s řefraḥet.   
\m
\v 14 Ddmani n tarewsa ssunt s wuǧi,  
\m tiɣzurin dřint s imendi.  
\m Nitni dduqquzen s usřiwřew,  
\m \add wah\add*, ttɣennajen.   
\b  
\b  
\m  
\c 66
\m
\v 1 \add I umeqqran n imeɣnajen. Izři. Azehhed.\add*  
\b  
\m Duqqzem s usřiwřew i AREBBI,  
\m \add wah,\add* marra tammurt!   
\m
\v 2 Zehhdem i uɛuǧi n Yisem nnes,  
\m ssɛuǧa \add i-t\add* i usemɣar nnes. \x ◘ \xo 66:2 \xt Aɛwd. 10:21\x*   
\m
\v 3 Inim i AREBBI:  
\m “Mammec ssaggʷadent tmegga nnec!”  
\m Zi řemɣaret n jjhed nnec  
\m ad \add xak\add* ssniɛmiřen řɛedyan nnec  
\m ad aḍaren i Cek.   
\m
\v 4 Marra tammurt,  
\m \add wah marra\add* ad ac sejden  
\m u ad zehhden,  
\m ad zehhden i Yisem nnec. Silah.   
\b  
\m
\v 5 Asem-dd, xzarem timegga n AREBBI.  
\m Min igga zzat i tarwa n bnadem  
\m aqa issaggʷad.   
\m
\v 6 Netta yarra řebḥar d řbar.  
\m Nitni ẓwan iɣzar x iḍaren.  
\m Dinni i zzayes nfarreḥ. \x ◘ \xo 66:6 \xt Uf. 14:21-31; Yac. 3:14 \x*   
\m
\v 7 S jjehd nnes iḥekkem i řebda.  
\m Tiṭṭawin nnes ttɛessent x řegnus.  
\m Ɣarwem ad mmɛařan inni ittɣewwɣen.  
\m Silah. \x ◘ \xo 66:7 \xt 2 Im. 16:9; Ayub 28:24; Izhd. 33:13\x*   
\b  
\m
\v 8 Barkem AREBBI nneɣ, \add kenniw a\add* řegnus,  
\m ggem ad ittwaseř řḥess n uṣebbeḥ nnes.   
\m
\v 9 \add Netta\add* d wenni d aneɣ itticen tudart,  
\m d wenni war ijjin aḍar nneɣ ad ifarɣ.   
\m
\v 10 Minzi Cek, \add a\add* AREBBI, tqeǧbed aneɣ,  
\m Cek tessizedged aneɣ  
\m axmi ssizdagen nnuqart.   
\m
\v 11 Cek tnedhed aneɣ di tracca \add n řfex\add*.  
\m Tessarsed xaneɣ ijj n ddqeř  
\m x tejɛinna nneɣ.   
\m
\v 12 Cek tejjid iwdan ad nyen  
\m x izeǧifen nneɣ,  
\m aqa nedweř di tmessi d waman,  
\m \add maca\add* Cek tessuffɣed aneɣ  
\m s ijj n řqedd ifeyyeḍ.   
\b  
\m
\v 13 Necc ad dd-adfeɣ ɣar Taddart nnec  
\m s tɣarṣa n wecmaḍ,  
\m ad ac xeǧṣeɣ lwuɛud inu,   
\m
\v 14 \add lwuɛud\add* nni zzaysen neṭqen  
\m iyencicen inu,  
\m nni \add zzaysen\add* issiweř uqemmum inu,  
\m řami tuɣa ayi di řeḥṣaret.   
\m
\v 15 Tiɣarṣa n wecmaḍ n řmar iṣeḥḥen  
\m ad ac tent-i-dd-awyeɣ  
\m ak-d řebxur n icarriyyen.  
\m Necc ad \add ac\add* sswejdeɣ ifunasen d iɣayḍen.  
\m Silah.   
\b  
\m
\v 16 Marra kenniw i itteggʷden AREBBI,  
\m assettiw-dd, sřem,  
\m necc xseɣ ad awem ɛawdeɣ  
\m min i d ayi igga di řeɛmar inu.   
\m
\v 17 \add Ɛad\add* iřaɣa xas uqemmum inu,  
\m \add xenni\add* aqa Netta ittwassemɣar  
\m sadu yiřes inu.   
\m
\v 18 Mři tuɣa nwiɣ řmuɛṣiyyet  
\m deg wuř inu,  
\m \add xenni\add* aqa Sidi inu war d ayi ittesři ca.   
\m
\v 19 AREBBI \add maca\add* aqa isřa ayi,  
\m aqa Netta iwca taynit  
\m i tmijja n tẓaǧit inu.   
\m
\v 20 Ad ittwabarek AREBBI  
\m wenni war inḍaren taẓaǧit inu,  
\m war d ayi ikkis  
\m tamexsiwt nnes icewwaren.   
\b  
\b  
\m  
\c 67
\m
\v 1 \add I umeqqran n imeɣnajen. Ak-d uzenzun x ifiřan. Azehhed. Izři.\add*   
\b  
\m
\v 2 Ad xaneɣ iḥinn AREBBI.  
\m Netta ittejja udem nnes  
\m ad xaneɣ yarɣ - Silah - \x ◘ \xo 67:2 \xt Řxř. 6:25; Izhd. 4:7\x*   
\b  
\m
\v 3 maḥend ad ssnen abrid nnec  
\m x temmurt,  
\m \add ad ssnen\add* asenjem nnec  
\m jar marra řegnus!   
\b  
\m
\v 4 Řegnus ad Cek qadan, \add a\add* AREBBI,  
\m marra řegnus ad Cek qadan.   
\b  
\m
\v 5 Řegnus ad farḥen, ad sřiweřwen,  
\m maɣar Cek ad tḥekmed  
\m x řegnus nican,  
\m Cek ad tessuyured ccuɛub  
\m x temmurt - Silah -   
\b  
\m
\v 6 řegnus ad Cek qadan, \add a\add* AREBBI,  
\m marra řegnus ad Cek qadan.   
\b  
\m
\v 7 Tammurt tᵉttic řɣiǧet nnes.  
\m AREBBI, AREBBI nneɣ,  
\m ad aneɣ ibarek.   
\b  
\m
\v 8 AREBBI ad aneɣ ibarek  
\m u marra tineggura n temmurt  
\m ad zzayes ggʷedent.   
\b  
\b  
\m  
\c 68
\m
\v 1 \add I umeqqran n imeɣnajen. N Dawud. Azehhed. Izři.\add*   
\b  
\m
\v 2 AREBBI ad ikkar,  
\m řɛedyan nnes ad ttwareyycen,  
\m inni t icarrhen ad arewřen  
\m zzat i wudem nnes. \x ◘ \xo 68:2 \xt Řxř. 10:35\x*   
\m
\v 3 Cek ad ten tessiggʷejed  
\m am ddexxan \add iṭṭaw\add*,  
\m am ccmeɛ ifessi di tmessi,  
\m \add ammu\add* i ɣa fnan iɛeffanen  
\m zzat i wudem n AREBBI.   
\b  
\m
\v 4 Imseggaden ad farḥen,  
\m ad sřiwřiwen s řefraḥet  
\m zzat i wudem n AREBBI  
\m u ad ɣebban řefraḥet. \x ◘ \xo 68:4 \xt Řxř. 10:10\x*   
\m
\v 5 Ɣennjem i AREBBI, zehhdem  
\m i Yisem nnes,  
\m ggem ijj n webrid yuɛřan  
\m i wenni ineddhen di řewḍa.  
\m SIDi d Isem nnes.  
\m Negzem s řefraḥet  
\m zzat i wudem nnes. \x ◘ \xo 68:5 \xt Řxř. 22:1; 26:3, 63; 31:12; 33:48, 49, 50; 35:1, 13; Aɛwd. 34:1, 8; Yac. 13:32\x*   
\b  
\m
\v 6 Babatsen n iyujiřen d Řqaḍi n tijjař,  
\m \add ammu i yeǧa\add* AREBBI  
\m di Tzeddiɣt nnes iqeddsen, \f ◼ \fr 68:6 \ft \+fk řqaḍi\ft  - niɣ ‘amezruf’.\f*   
\m
\v 7 \add ammu i yeǧa\add* AREBBI  
\m wenni isszeddaɣen inni weḥḥedsen  
\m deg ict n twacunt,  
\m wenni issuffuɣen imeḥbas s ufřaḥ,  
\m maca imɣewwaɣen ad zedɣen  
\m deg ict n temmurt  
\m ittwasscemḍen \add zi tfuct\add*.   
\b  
\m
\v 8 \add A\add* AREBBI, ařami tizzared  
\m zzat i wudem n řgens nnec,  
\m ařami tuɣa teggured di tnezruft - Silah -   
\m
\v 9 tenhezz temmurt uca ucruren ijenwan,  
\m zzat i wudem n AREBBI,  
\m uřa d adrar n Sina \add inhezz\add*  
\m zzat i wudem n AREBBI, AREBBI n Israil. \f ◼ \fr 68:9 \ft \+fk Sina\ft  - ɣar wedrar-a idweř Arebbi d ajeǧid n Israil (Yacurun). Xzar Aɛwd. 33:5. Deg wemcan-a tebda ɛawed tesɣunt n řɛahd n řgens ak-d Ccariɛa n Musa, ixs ad yini ak-d Ttawrat.\f*  \x ◘ \xo 68:9 \xt Uf. 19\x*   
\b  
\m
\v 10 \add Ak-d\add* wenẓar ifsusen  
\m trucced \add tammurt\add*, \add a,\add* AREBBI,  
\m \add xmi\add* i ɣa isřaw řwart nnec,  
\m tewcid as Cek \add ɛawed\add* jjehd.   
\m
\v 11 Taḥimart nnec tuɣa tzeddeɣ dayes.  
\m S tcuni nnec tesswejded tt i řmeskin,  
\m \add a\add* AREBBI! \f ◼ \fr 68:11 \ft \+fk Tahimart nnec\ft  - niɣ ‘tudart nnec’, aqa marra min iǧan d agra iddaren ɣar ijj n bnadem. Awař-a d ijj n uceyyar ɣar řgens n Arebbi, ɣar Israil.\f*   
\b  
\m
\v 12 Sidi inu iwca awař,  
\m timɣarin nni dd-ittawyen  
\m řexbar aṣebḥan  
\m \add ttkewwnent\add* ijj n ubarru  
\m ameqqran n treqqasin.   
\m
\v 13 Ijeǧiden n řɛeskarat ttrakkwařen,  
\m aqa ttrakkwařen,  
\m u tenni iqqimen di taddart,  
\m tbeṭṭa takeccaḍt. \f ◼ \fr 68:13 \ft \+fk tenni iqqimen di taddart\ft  - ad taɣ awař-a d ijj n uceyyar ɣar Yaɛil (xzar Řqḍ. 5:24). Xzar ɛawed 2 Ṣm. 1:24.\f*   
\b  
\m
\v 14 Ma kenniw war tebbuzzřem  
\m jar tnayen n taryiwin,  
\m \add am wedbir jar\add* wafriwen \add nnes\add*  
\m i ittwařeḥḥfen s nnuqart,  
\m \add jar\add* arric nnes s wureɣ aziza ittissiqen,   
\m
\v 15 Řami Amzemmar x kuřci  
\m issareyyec ijeǧiden di temmurt,  
\m iccat wedfeř x Ṣalmun. \f ◼ \fr 68:15 \ft \+fk di temmurt\ft  - s Tɛibranit ‘dayes’. \fk Ṣalmun\ft  - neccin war nessin ca nican mani iǧa wedrar n Ṣalmun. Aqa din inni iqqaren aqa-t d ijj wedrar di řwest n temmurt n Israil u inneɣni qqaren aqa-t d ijj n wedrar jar idurar n Bacan (ixs ad yini řegɛudi n Julan deg wussan nneɣ). Aqa balak aqa-t di Bacan.\f*   
\b  
\m
\v 16 Adrar n AREBBI! Adrar n Bacan!  
\m Adrar n Bacan d ijj n wedrar  
\m s tqiccitin \add aṭṭas\add*. \f ◼ \fr 68:16 \ft \+fk adrar n Arebbi\ft  - aqa-t d adrar n Muriya mani iqeddem Ibrahim mmis Isḥaq d taɣarṣt i Arebbi. Deg wussan n Suliman bnan din Zzawect Tameqqrant di Urcalim uca adrar idweř itwassnen am wedrar n Ṣihyun. \fk Bacan\ft  - idurar n Bacan n zic aqa-ten d řegɛuḍi n Julan deg wussan nneɣ, ɣar ccamal n temmurt n Israil, u jar asen adrar n Hirmun wenni ɣar iǧa ijj n řuɛra n 2800 mitru. Adrar n Ṣiḥyun ɣars mɣir 800 mitru n řuɛřa.\f*   
\m
\v 17 Mayemmi txezzarem  
\m ammu s wasam,  
\m \add kenniw a\add* idurar  
\m s marra tiqiccitin \add nwem\add*,  
\m ɣar wedrar i imeẓri i-t AREBBI  
\m d tazeddiɣt i Yixef nnes?  
\m \add Wah, nican\add* SIDI ad din izdeɣ i řebda. \x ◘ \xo 68:17 \xt Izhd. 87:1, 2; 132:13\x*   
\b  
\m
\v 18 Ikarruten n AREBBI  
\m aqa aten d ɛecrayat n řuřuf  
\m d ɛecrayat n řuřuf,  
\m uřa d ařef u ɛawed \add ařef\add*.  
\m Sidi inu aqa-t jar asen,  
\m \add adrar n\add* Sina \add aqa ittwařeḥḥef\add*  
\m s tqeddast. \x ◘ \xo 68:18 \xt Aɛwd. 33:2\x*   
\m
\v 19 Cek tuřyed ɣar sennej,  
\m tnedhed imeḥbas di tmeḥbast,  
\m Cek tmenɛed tarzifin zeg iwdan,  
\m \add iwa ɛad\add* zeg imɣewwɣen,  
\m ḥima SIDi, AREBBI, ad izdeɣ \add dinni\add*. \x ◘ \xo 68:19 \xt Afa. 4:8; Řxř. 17:21; Yac. 9:23; Ɛiz. 8:20\x*   
\b  
\m
\v 20 Ad ittwabarek Sidi inu.  
\m Ass x wass yarebbu i neccin ddquřat.  
\m Arebbi nni d asenjem nneɣ - Silah - \f ◼ \fr 68:20 \ft \+fk amsenjem\ft  - niɣ ‘amsellek’.\f*   
\m
\v 21 Arebbi nni  
\m d ijj n Arebbi n isenjamen i neccin.  
\m Aqa din ifekkiten zi řmewt  
\m ɣar SIDI, Sidi inu.   
\b  
\m
\v 22 S tidett, AREBBI, ad iřbez  
\m azeǧif n řɛedyan nnes,  
\m aceqquf s ucuwwaf  
\m n wenni iqqimen ittenneḍ  
\m s imerwusa \add n ddnub\add* nnes. \x ◘ \xo 68:22 \xt Amz. 3:15; Řqḍ. 4:21\x*   
\m
\v 23 Sidi inu inna:  
\m “Necc ad \add kenniw\add* dd-arreɣ zi Bacan,  
\m ad \add kenniw\add* dd-arreɣ  
\m zi řaǧaɣ n řebḥar, \x ◘ \xo 68:23 \xt Uf. 14:29; Řxř. 21:33 \x*   
\m
\v 24 ḥima ad tḥarrced s uḍar nnec  
\m deg idammen,  
\m \add uca uřa d\add* iřes n yiṭan nnec  
\m \add ad iṭṭef\add* tasɣart nnes zi řɛedyan.”   
\b  
\m
\v 25 Nitni ẓrin ibriden nnec  
\m mammec ten tuyured, \add a\add* AREBBI,  
\m ibriden n Arebbi inu, Ajeǧid inu,  
\m \add řeḥḥfen\add* di tqeddast.   
\m
\v 26 Imeɣnajen tuɣa gguren ɣar zzat,  
\m inni iccaten x ifiřan awarni asen,  
\m tiɛzariyyin, tinni ittiraren  
\m x ibendiřen nsent di řwesṭ.   
\m
\v 27 Barkem AREBBI di tmesmunin, \add a\add* SIDI,  
\m zi řɛunṣar n Israil.   
\m
\v 28 Aqa din Binyamin ameẓyan,  
\m wenni xasen ittṣeǧaḍen,  
\m \add xenni\add* řḥukkam n Yahuda  
\m ak-d ubarru n iɛciren nsen,  
\m \add uřa d\add* řḥukkam n Zabulun  
\m \add d\add* řḥukkam n Naftali.   
\b  
\m
\v 29 AREBBI nnec iweṣṣa  
\m \add maḥend ad as immewc\add* jjehd nnec.  
\m \add A,\add* AREBBI, sejhed  
\m min teggid di ṭṭweɛ nneɣ,   
\m
\v 30 zi Zzawect nnec Tameqqrant,  
\m sennej i Urcalim.  
\m Ijeǧiden ad ac iwyen tarzifin. \x ◘ \xo 68:30 \xt 1 Ij. 10:10, 24, 25; 2 Im. 32:23; Izhd. 72:10; 76:12; Ica. 60:6-17; Ḥiz. 20:40; Ḥiz. 40:2; Ḥiz. 43:12 \x*   
\m
\v 31 Siggʷed řweḥc nni \add deg\add* uɣanim,  
\m abarru n \add ifunasen\add* ijehden  
\m ak-d iɛejmiyyen n řegnus,  
\m ařami igga ixef nnes am ittwařbez,  
\m \add am\add* nnuqart iddez.  
\m Netta izeǧeɛ řegnus  
\m nni tuɣa ttmeẓren deg umenɣi. \f ◼ \fr 68:31 \ft \+fk iɛejmiyyen\ft  - niɣ ‘amwa’, ‘ayenduz’ niɣ ‘yuggu’.\f*   
\m
\v 32 Ad dd-asen imcennɛen zi Miṣra,  
\m Kuc ad isswiẓẓeḍ ifassen nnes  
\m ɣar AREBBI s tezřa.   
\b  
\m
\v 33 \add A\add* tigeldiwin n temmurt,  
\m ɣennjent i AREBBI,  
\m zehhdent i Sidi inu. Silah.   
\m
\v 34 Netta d wenni ineddhen  
\m deg ujenna x \add marra\add* ijenwan  
\m zeg wecḥař uya.  
\m Xzar, aqa Netta igga  
\m ijj n řḥess ijehden s tmijja nnes.   
\m
\v 35 Wcem jjehd i AREBBI!  
\b  
\m Lɛaḍama nnes aqa-tt tiwa i Israil  
\m u jjehd nnes aqa-t deg iseynuten.   
\m
\v 36 \add A,\add* AREBBI, mammec tessiggʷeded  
\m zi Tizawiyyin nnec Iqeddsen,  
\m \add a\add* Arebbi n Israil, \add Cek\add* d wenni itticen  
\m jjehd d tzemmar i řgens.  
\m Ad ittwabarek AREBBI. *   
\b  
\b  
\m  
\c 69
\m
\v 1 \add I umeqqran n imeɣnajen. S teɣnint n ‘Tlillicin’. N Dawud.\add*\f ◼ \fr 69:1 \ft \+fk tilillicin\ft  - ict n marka n nnuwarat daysen aẓri aṭṭas.\f*   
\b  
\m
\v 2 Senjem ayi, \add a\add* AREBBI,  
\m maɣar aman iwḍen ayi  
\m ɣar řeɛmar \add inu\add*.   
\m
\v 3 Necc ɣebbiɣ deg ubaryuḍ yuǧeɣ,  
\m war \add din\add* mani ɣa beddeɣ.  
\m Aqa-yi deg waman yuǧɣen  
\m u řḥemřet tᵉttazzeř xafi.   
\b  
\m
\v 4 Necc uḥřeɣ s iɣuyyan,  
\m tmijja inu tebbuybeḥ,  
\m tiṭṭawin inu qḍant  
\m zeg uraji x AREBBI inu.   
\m
\v 5 Inni d ayi icarrhen x walu  
\m ttwessɛen x ucuwwaf \add i iǧan\add* x uzeǧif inu.  
\m Inni yarezzun ad ayi areddǧen,  
\m řɛedyan inu i \add xafi\add* issxarriqen,  
\m dewřen jehhden.  
\m Min war ucareɣ,  
\m ittxeṣṣa ayi ad tt-i-dd-arreɣ \add ɛad\add*. \x ◘ \xo 69:5 \xt Yḥ. 15:25\x*   
\b  
\m
\v 6 \add A\add* AREBBI, Cek tessned tubbuheřya inu,  
\m imerwusa \add n ddnub\add* inu war xak ffaren.   
\m
\v 7 Ejj inni xak issitimen, war ttseḍḥin,  
\m \add a\add* Sidi inu, SIDI n řɛeskarat,  
\m ejj inni xak yarezzun,  
\m war zzayi ttwafeṭṭḥen,  
\m \add a\add* AREBBI n Israil.   
\m
\v 8 Maɣar di ṭṭweɛ nnec i kessiɣ aseḥqar,  
\m aseḍḥi iřeḥḥef i uɣembub inu.   
\b  
\m
\v 9 Dewřeɣ d aɣrib ɣar aytma,  
\m i iḥenjiren n yemma \add dewřeɣ\add* d abarrani.   
\m
\v 10 Maɣar tusmi \add iqeddsen\add* i Taddart nnec  
\m tecca ayi,  
\m aseḥqar n yinni Cek isseḥqaran  
\m iwḍa-dd xafi. \x ◘ \xo 69:10 \xt Yḥ. 2:17; Rum. 15:3\x*   
\m
\v 11 Necc ruɣ ɣar uẓummi n řeɛmar inu,  
\m \add maca\add* aya yiwi ayi-dd ɛřam kuř aseḥqar.   
\b  
\m
\v 12 Necc yarḍeɣ ict n txancet \add n wecḍan\add*,  
\m \add maca\add* dewřeɣ asen d ijj n lmatal.   
\m
\v 13 Inni iqqimen ɣar tewwart \add n tendint\add*  
\m ssawařen xafi,  
\m uřa d izřan n yinni isessen ccrab.   
\m
\v 14 Necc maca ttᵉttareɣ ɣarek, \add a\add* SIDI!  
\m \add Aqa din\add* ijj n řḥař n arḍa, \add a\add* AREBBI,  
\m s řemɣaret n tmexsiwt nnec icewwaren.  
\m Arr-dd xafi s usenjem nnec  
\m i dd-iffɣen zi řmanet nnec.   
\b  
\m
\v 15 Jbed ayi-dd zeg ubaryuḍ,  
\m ejj ayi war ttɣebbiɣ,  
\m \add ḥima\add* ad ttwafekkeɣ  
\m zeg inni d ayi icarrhen  
\m u zeg waman yuǧɣen.   
\m
\v 16 War ttejji ad ayi tawi řḥemřet,  
\m \add war ttejji\add* řaǧaɣ ad ayi isarḍ,  
\m ad xafi ibelleɛ wanu aqemmum nnes.   
\b  
\m
\v 17 Arr xafi, \add a\add* SIDI,  
\m maɣar tamexsiwt nnec icewwaren  
\m teṣbeḥ.  
\m Qřeb ɣari  
\m ɛlaḥṣab arreḥmet nnec ifeyyḍen.   
\m
\v 18 War tteffar ca udem nnec  
\m x umsexxar nnec,  
\m maɣar ttwaḥṣareɣ.  
\m Arr-dd xafi daweḥda.   
\m
\v 19 Ades ayi-dd ɣar řeɛmar inu, fekk i-t.  
\m Seṣřeḥ ayi di ssibbet n řɛedyan inu.   
\b  
\m
\v 20 Cek tessned řɛar inu  
\m d useḍḥi inu d řefḍiḥet inu,  
\m aqa marra inni d ayi iḥeṣṣaren  
\m \add bedden\add* zzatek.   
\m
\v 21 Aseḥqar yarẓ ayi uř  
\m u necc qenḍeɣ aṭṭas.  
\m Rajiɣ aziǧez, maca walu,  
\m necc \add rajiɣ\add* inni d ayi ɣa iɛezzan,  
\m maca war ufiɣ \add uřa d ijjen\add*.   
\m
\v 22 Nitni ggin ssem di macca inu,  
\m i ufadi inu ggin ayi ad sweɣ řxeǧ. \x ◘ \xo 69:22 \xt Mt. 27:34,48; Mk. 15:23; Yḥ. 19:28, 29\x*   
\b  
\m
\v 23 Ejj ṭṭabřa nsen ad tedweř d řfex,  
\m uřa d taxceft i yinni akidsen ibedden. \x ◘ \xo 69:23 \xt Rum. 11:9\x*   
\m
\v 24 Sdarɣeř tiṭṭawin nsen,  
\m ḥima war ttwiřin \add ɛad\add*,  
\m arr tijɛinnatin nsen  
\m ad ttenhezzant řebda.\x ◘ \xo 69:24 \xt Ica. 6:9, 10; 29:10; 44:18; Rum. 11:10\x*   
\m
\v 25 Zeǧeɛ xasen asxeḍ nnec,  
\m ejj řḥaduq n weɣḍab nnec  
\m ad ten iřqef.   
\b  
\m
\v 26 Ejj řmargeḥ n tzeddiɣt nsen  
\m ad idweř d řxarbet,  
\m maḥend war \add dayes\add* izeddeɣ \add ɛad\add*  
\m uřa d ijjen. \x ◘ \xo 69:26 \xt Řex. 1:20\x*   
\m
\v 27 Maɣar nitni darracen x weryaz  
\m nni tuɣa tewtid Cek,  
\m s řhard nsen arnin i řeḥriq  
\m n yinni zzayek ittwařeqqfen.   
\m
\v 28 Arr ddenb x ddenb nsen,  
\m war ten ttejji ad dd-adfen  
\m ɣar tsegda nnec.   
\b  
\m
\v 29 Ejj i-ten ad ttwamḥan  
\m zeg Wedlis \add ittwanḍen\add* n Tudart,  
\m ařami war ttwazemmamen ca  
\m ɣar imseggaden. \x ◘ \xo 69:29 \xt Fil. 4:3; Asa. 13:8; 17:8; 20:15\x*   
\m
\v 30 \add Maca\add* necc aqa ayi  
\m di řeɣben u ttnezbareɣ.  
\m Iři ad ayi issgeɛɛed sennej  
\m usenjem nnec, \add a\add* AREBBI.   
\m
\v 31 Necc ad ṣebbḥeɣ Isem n AREBBI  
\m s yijj n yezři,  
\m s uqadi ad \add as\add* ssemɣareɣ.   
\b  
\m
\v 32 Aya ad yarḍa SIDI ktar  
\m zeg ijj n ufunas,  
\m zeg ijj n ufunas ameẓyan  
\m s waccawen d tecḍect immsebḍan.   
\m
\v 33 Imhinen nni tt iẓrin, ad farḥen,  
\m \add u\add* inni yarezzun x AREBBI,  
\m aqa uř nwem ad iddar.   
\m
\v 34 Maɣar SIDI ittesřa ɣar imezřaḍ,  
\m war isseḥqiri ca imeḥbas nnes.   
\b  
\m
\v 35 Ejj ijenwan d temmurt ad t ssemɣaren,  
\m řebḥur d marra min daysen ittenhezzan.   
\m
\v 36 Maɣar AREBBI ad issenjem Ṣihyun,  
\m ad ibna \add ɛawed\add* tineddam n Yahuda,  
\m uca nitni ad din zedɣen,  
\m ad tt ṭṭfen d řwart.   
\m
\v 37 Zzariɛet n imsexxaren nnes  
\m ad tt tᵉṭṭef d tasɣart,  
\m inni ittexsen Isem nnes  
\m ad dayes zedɣen.   
\b  
\b  
\m  
\c 70
\m
\v 1 \add I umeqqran n imeɣnajen. N Dawud. I řidaret.\add*   
\b  
\m
\v 2 \add A\add* AREBBI, deɣyat ḥima ad ayi tfekked,  
\m ḥima ad ayi tɛawned, \add a\add* SIDI. \x ◘ \xo 70:2 \xt Izhd. 40:14-19\x*   
\m
\v 3 Ejj inni yarezzun řeɛmar inu  
\m ad ttwaxarewḍen  
\m u ad ssnuffaren ixef nsen,  
\m ejj inni yareṭṭan x řɣar i dayi iřeqqfen,  
\m ad dewřen ɣar ḍeffar  
\m u ad ttwassbehdřen. \x ◘ \xo 70:3 \xt Izhd. 35:4, 26; 71:13\x*   
\m
\v 4 Ejj i-ten ad ɛeqben  
\m zi ssibbet n ubehdeř,  
\m inni din iqqaren: “Ha, ha!”   
\b  
\m
\v 5 Ejj marra inni xak yarezzun,  
\m ad arcqen, ad zzayek farḥen.  
\m Ejj inni ittexsen asenjem nnec,  
\m ad inin řebda:  
\m “AREBBI d ameqqran!”   
\m
\v 6 \add Maca\add* necc di řeɣben u zeřḍeɣ,  
\m \add a\add* AREBBI, deɣyat ɣari.  
\m Cek d twiza inu d amsenjem inu,  
\m \add a\add* SIDI, war ttɛeṭṭař ca!   
\b  
\b  
\m  
\c 71
\m
\v 1 Arekkwařeɣ ɣarek, \add a\add* SIDI,  
\m ejj ayi ɛemmarṣ  
\m war ttseḍḥiɣ i řebda.\x ◘ \xo 71:1 \xt Izhd. 22:6; 25:2, 3; 31:2, 3; Ica. 49:23\x*   
\m
\v 2 Fekk ayi s tsegda nnec u arxu ayi.  
\m Arr-dd ɣari amezzuɣ nnec  
\m u senjem ayi.   
\m
\v 3 Iři d ict n teṣḍart i tzeddiɣt i necc,  
\m ḥima ad ɣares dd-aseɣ řebda.  
\m Cek tweṣṣid ḥima ad ttwassnejmeɣ,  
\m maɣar Cek d Tasḍart inu d lburj inu.   
\b  
\m
\v 4 AREBBI inu, senjem ayi  
\m zeg ufus n uɛeffan,  
\m zeg ufus n mmis n řmuɛṣiyyet  
\m u zi bu-ɣezzu.   
\m
\v 5 Maɣar Cek d řayas inu,  
\m Sidi inu, SIDI,  
\m \add Cek\add* d atecři inu zi temẓi inu.   
\m
\v 6 Zeg uɛeddis \add n yemma\add*,  
\m tuɣa ayi ɛemmdeɣ xak.  
\m Zeg uɛeddis n yemma,  
\m aqa Cek d Wenni d ayi iḥuzen,  
\m necc ṣebḥeɣ Cek řebda.   
\b  
\m
\v 7 I waṭṭas necc am yict n řeɛřamet \add n řeɛjeb\add*,  
\m \add maca\add* Cek d amcan inu ijhed i tarewřa.   
\m
\v 8 Ejj aqemmum inu ad iccur  
\m s uṣebbeḥ nnec,  
\m ass imun s ccan nnec.   
\m
\v 9 War xafi ttmenḍar  
\m deg wussan n tewsar inu,  
\m war d ayi semmeḥ  
\m mařa jjehd inu iruḥ. \f ◼ \fr 71:9 \ft \+fk deg wussan\ft  - s Tiɛbranit ‘di řweqt’.\f*   
\b  
\m
\v 10 Maɣar řɛedyan inu ssawařen xafi,  
\m inni yarezzun řeɛmar inu,  
\m mcawaren xafi jmiɛ.   
\m
\v 11 Nitni qqaren: “AREBBI ismeḥ dayes.  
\m Ḍfarem t u menɛem t,  
\m maɣar war din wenni i ɣa ifekken.   
\m
\v 12 \add A\add* AREBBI, war ttɣimi tiggʷejed xafi,  
\m \add a\add* AREBBI inu, ewc ayi deɣya afus.   
\b  
\m
\v 13 Ejj iɣrimen n tudart inu  
\m ad ttwaseḍḥan u ad ttwaccen,  
\m ejj inni yarezzun ad ayi ggen řɣar  
\m ad ttwadřen s useḥqar d řefḍiḥet. \x ◘ \xo 71:13 \xt Izhd. 34:4, 26; 40:15; 70:3\x*   
\m
\v 14 \bd Necc\bd* maca ad qqimeɣ ttrajiɣ \add Cek\add* řebda,  
\m u ad arniɣ \add ɛad\add* ɣar uṣebbeḥ nnec.   
\m
\v 15 Aqemmum inu ad ibarreḥ  
\m s tsegda nnec,  
\m asenjem nnec, ass imun,  
\m maɣar war ssineɣ řqedd nnes.   
\b  
\m
\v 16 Necc ad dd-aseɣ s tmegga timeqqranin  
\m n Sidi inu, SIDI,  
\m ad idareɣ tasegda nnec,  
\m mɣir tenni Nnec waha.   
\m
\v 17 \add A\add* AREBBI, Cek tuɣa tesseřmaded ayi  
\m zi temẓi inu,  
\m u necc ař ass-a ttbarrḥeɣ  
\m s lmuɛjizat nnec.   
\m
\v 18 \add A\add* AREBBI, war d ayi semmeḥ ca,  
\m waxxa wsareɣ cabeɣ,  
\m ař ɣa ḥajiɣ i jjiř-a  
\m x \add tmegga n\add* ufus nnec  
\m uřa x tmegga nnec timeqqranin,  
\m i marra min i dd ɣa yasen.   
\b  
\m
\v 19 \add A\add* AREBBI, tasegda nnec  
\m tiweḍ ař sennej \add qaɛ\add*,  
\m maɣar Cek teggid timegga timeqqranin,  
\m \add a\add* AREBBI, man wen iǧan am Cek!   
\m
\v 20 Aqa Cek tejjid tekka xafi  
\m aṭṭas n řeḥṣarat d řɣar,  
\m \add maca waxxa amenni\add*  
\m Cek ad ayi tesseddared ɛawed,  
\m Cek ad ayi tessuffɣed  
\m zeg \add waman\add* ihewřen n temmurt.   
\m
\v 21 Cek ad tarrid řemɣaret inu ad temɣar,  
\m ad ayi dd-tennḍed s ufewwej nnec.   
\b  
\m
\v 22 Ad Cek qadiɣ \add ɛawed\add* s lharpa,  
\m \add x\add* řaman nnec, \add a\add* AREBBI,  
\m ad Cek zehhdeɣ s řgambri,  
\m \add a\add* Amqeddas n Israil.   
\m
\v 23 Iyencicen inu ad sřiwřewen,  
\m aqa ad zehhdeɣ i Cek,  
\m uřa d řeɛmar inu nni tefdid Cek.   
\m
\v 24 Uřa d iřes inu ad iḥaja  
\m x tsegda nnec ass marra,  
\m maɣar inni yarezzun  
\m ad ayi ggen řɣar,  
\m seḍḥan, iwa, ttwafeḍḥen.   
\b  
\b  
\m  
\c 72
\m
\v 1 \add N Suliman.\add*  
\b  
\m \add A\add* AREBBI, ewc i ujeǧid  
\m \add maḥend\add* ad iḥkem ɛlaḥsab řḥeqq nnec,  
\m u \add ewc\add* tasegda nnec i mmis n ujeǧid.   
\m
\v 2 \add Xenni\add* netta ad iḥakem  
\m řgens nnec s tsegda,  
\m řmusakin nnec s řḥeqq.   
\m
\v 3 Idurar ad iwyen řehna i řgens,  
\m \add uřa d\add* tiwririn tasegda.   
\m
\v 4 Netta ad yaɣ tesɣart  
\m n řmusakin n řgens,  
\m ad issenjem tarwa n imezřaḍ,  
\m uca ad iřbez wenni \add ten\add* iḥeṣṣaren.   
\b  
\m
\v 5 Nitni ad zzayek ggʷeden  
\m min ɣa tekk tfuct \add teǧa\add*,  
\m u taziri \add ad tesscen\add* udem \add nnes\add*,  
\m zi jjiř ař jjiř. \x ◘ \xo 72:5 \xt Izhd. 89:37,38\x*   
\m
\v 6 Netta ad dd-ihwa x iyyar  
\m awarni i weḥtac,  
\m am tinecnacin i issarḍaben tammurt. \x ◘ \xo 72:6 \xt 2 Ṣm. 23:4\x*   
\m
\v 7 Deg wussan nnes  
\m ad innuwar umsegged,  
\m ad din yiři řehna ifeyyḍen  
\m ař ɣa tafed taziri war teǧi ɛad.   
\m
\v 8 Netta ad iḥkem zi řebḥar ař řebḥar,  
\m zeg iɣzar \add n Lfuraṭ\add*  
\m ař tineggura n temmurt.   
\b  
\m
\v 9 Imezdaɣ n řexřa  
\m ad qqunjeřen zzates,  
\m \add maca\add* řɛedyan nnes ad řesḥen ucař.   
\m
\v 10 Ijeǧiden n Tarcic  
\m ad dd-iwyen ict n tewhibt,  
\m ijeǧiden n Caba d Seba  
\m ad dd-qarrben tarzefin.   
\m
\v 11 Marra ijeǧiden ad as aḍaren,  
\m marra řegnus ad as ɛebden.   
\b  
\m
\v 12 Maɣar netta ad ifekk amezřuḍ,  
\m wenni \add ɣares\add* ittřaɣan,  
\m uřa d řmeskin  
\m d wenni war ɣares amɛawen. \x ◘ \xo 72:12 \xt Ayub 29:12\x*   
\m
\v 13 Netta ad iɛteq amarxu d umezřuḍ,  
\m netta ad issenjem řeɛmar n imezřaḍ. \f ◼ \fr 72:13 \ft \+fk řeɛmar\ft  - ixs ad yini ‘tudart’.\f*   
\m
\v 14 Netta ad ifekk řeɛmar nsen  
\m zi ddeǧ d lɛunf,  
\m idammen nsen ad sekkwan aṭṭas  
\m di tiṭṭawin nnes.   
\m
\v 15 Netta ad iddar!  
\m U ad as immewc wureɣ zi Caba.  
\m U \add nitni\add* ad ẓẓaǧen řebda  
\m di ṭṭweɛ nnes,  
\m ass marra ad t barken.   
\b  
\m
\v 16 Ad yiři ijj n ufeyyeḍ n imendi  
\m di temmurt  
\m x tqiccat n idurar,  
\m řɣiǧet nnes ad tenhezz  
\m am \add tcejjura n\add* Lubnan,  
\m u inni zi tendint ad nnuwaren  
\m am aɣemmuy \add aziza\add* di temmurt.   
\m
\v 17 Isem nnes ad iqqim i řebda,  
\m iři ad innuwar isem nnes  
\m zzat i wudem n tfuct.  
\m Ad dayes ttwabarken nitni,  
\m marra řegnus ad t ssemɣaren.   
\m
\v 18 Ad ittwabarek SIDI AREBBI,  
\m AREBBI n Israil.  
\m Netta ittegg lmuɛjizat, Netta waha.   
\m
\v 19 Ad ittwabarek  
\m Isem n uɛuǧi nnes i řebda.  
\m Ad tᵉttwaccur marra tammurt  
\m s uɛuǧi nnes. Amin, \add wah,\add* amin.   
\b  
\m
\v 20 Tiẓiǧatin n Dawud, mmis n Yassa, aqa kemmřent.   
\b  
\b  
\m  
\c 73
\s1 ADLIS WISS TŘATA: IZEHHIDEN 73-89  
\m
\v 1 \add Azehhed n Asaf.\add*  
\b  
\m Wah, AREBBI d aṣebḥan i Israil,  
\m i yinni s wuř iṣfan.   
\b  
\m
\v 2 Necc maca, ɛřaḥař tuɣa iḍaren inu  
\m ffɣen \add zeg webrid\add*,  
\m war iqqim walu ad ḥřuǧḍen iṣuraf inu.   
\b  
\m
\v 3 Maɣar tuɣa usmeɣ zeg ibuhařiyyen,  
\m \add řami\add* ẓriɣ aqa iɛeffanen mliḥ i ǧan. \x ◘ \xo 73:3 \xt Ayub 21:7-15; Izhd. 37:1; Irm. 12:1, 2\x*   
\m
\v 4 Maɣar war din bu iseɣwan  
\m ɣar řmewt nsen,  
\m ṣṣulṭa nsen aqa ibedd nican.   
\m
\v 5 Nitni war carrcen di tamara n iwdan,  
\m war ttwařeqqfen \add s řmuṣibat\add*  
\m am \add wezyen nneɣni n\add* bnadem.   
\m
\v 6 S uya tᵉttayeř asen-dd nnfaxet  
\m am tseddect ɣar yiri nsen  
\m uca iřeḥḥef asen lɛunf  
\m am yijj n warruḍ.   
\b  
\m
\v 7 Tiṭṭawin nsen ttwaffɣent zi tadunt,  
\m nitni ɛeddun řexyařat n wuř \add nsen\add*.   
\m
\v 8 Nitni stehzan \add s bṭayṭay\add*  
\m ssawařen x řɣar, x ddeǧ,  
\m aqa ssawařen zi sennej.   
\m
\v 9 Nitni arezzmen uqemmum nsen  
\m x ujenna,  
\m řhard nsen iggur x temmurt.   
\m
\v 10 S uya inneqřeb  
\m \add ddab\add* nsen n řgens ɣar da,  
\m aman ifeyyḍen ttsekkafen ten nitni.   
\b  
\m
\v 11 Qqaren:  
\m “Mammec i ɣa issen Arebbi?”  
\m “Mammec i ɣa igg Umɛuǧi x kuřci  
\m ad issen?”   
\m
\v 12 Xzar, aqa aten d iɛeffanen!  
\m \add Ɛad\add* ddaren řebda di řhudnet,  
\m ssewsiɛen agřa nsen.   
\m
\v 13 S tidett, amenni waha  
\m ssizedgeɣ uř inu  
\m u ssirdeɣ ifassen inu di tazdugi.   
\m
\v 14 Ass am imun necc tiyyita dayi,  
\m kuř ṣṣbeḥ tᵉttwarebbiɣ.   
\b  
\m
\v 15 Mařa nniɣ: “Uřa d necc ad ssiwřeɣ ammu!”,  
\m xzar, iři ɣdareɣ  
\m jjiř n iḥenjiren nnec.   
\m
\v 16 Ittřiɣ ayi \add zemmareɣ\add* ad fehmeɣ aya,  
\m \add maca\add* di tiṭṭawin inu  
\m ittawi-dd \add mɣir\add* tamara ibeṭṭřen,   
\m
\v 17 ařami udfeɣ  
\m ɣar Tzawiyyin Iqeddsen n Arebbi,  
\m uca ḥekkareɣ i tneggarut nsen.   
\m
\v 18 Wah, Cek tessrusid ten  
\m x imucan itteḥruǧuḍen,  
\m Cek tɣeṭṭřed ten d řxirbat.   
\b  
\m
\v 19 Mammec dewřen  
\m d \add ict n řqecɛet n\add* unexřiɛ  
\m deg ict n tecti,  
\m ttwamḥan u ttwaqḍan  
\m s iceřwawen issaggʷaden.   
\m
\v 20 Am tarjit ɣar ufaqi, \add a\add* Sidi inu,  
\m \add ammu\add* i ɣa tesseḥqared  
\m \add abeyyen n\add* řexyař nsen  
\m xmi dd ɣa tfaqed.   
\m
\v 21 Řami ittwassarzeg uř inu  
\m \add di řweqt nni\add*,  
\m ittejju ayi \add řeḥriq\add* di tiẓẓař inu. \f ◼ \fr 73:21 \ft \+fk tiẓẓař\ft  - niɣ ‘tigeẓřin’.\f*   
\m
\v 22 Necc tuɣa ayi d aqeffuḥ,  
\m tuɣa ayi ɣarek am yijj n řweḥc  
\m břa řeɛqeř.   
\b  
\m
\v 23 \add Ɛad maca\add* řebda aqa ayi ɣarek,  
\m Cek tᵉṭṭfed ayi zeg ufus afusi inu.   
\m
\v 24 Cek ad ayi tgewwded s ccwar nnec  
\m u awarni man aya  
\m ad ayi teksid ɣar uɛuǧi nnec.   
\m
\v 25 Man wen i ɣari deg ujenna  
\m ḥaca Cek?  
\m Akidek war tzemmar ad ayi tarḍa  
\m uřa d ict n tmesřact di temmurt.   
\m
\v 26 Mařa arrimet d wuř inu  
\m semmḥen dayi,  
\m \add xenni\add* AREBBI d Taṣḍart n wuř inu  
\m d tasɣart inu i řebda.   
\b  
\m
\v 27 Maɣar xzar,  
\m inni zzayek itteggʷejen ad fnan.  
\m Cek ad tkeḥḥeḍed kuř ijj  
\m wenni xak ittḥeyyaden  
\m umi i ɣa issefsed ixef nnes,   
\m
\v 28 Necc maca, řdaset i AREBBI d mliḥ i necc.  
\m Necc ggiɣ Sidi inu, SIDI,  
\m d amcan inu n tarewřa,  
\m ḥima ad barrḥeɣ marra timegga nnec.   
\b  
\b  
\m  
\c 74
\m
\v 1 \add Axemmi n Asaf.\add*  
\b  
\m Mayemmi, \add a\add* AREBBI, tenḍared i řebda?  
\m Mayemmi ɣa yarɣ weɣḍab nnec  
\m x wuǧi n ddmani n tarewsa nnec?   
\m
\v 2 Xemmem di tmesmunt nnec  
\m nni tuɣa tkesbed zeg wecḥař uya,  
\m taqbič n tesɣart n řwart nnec tenni tefdid,  
\m adrar n Ṣihyun wenni x tuɣa tzeddɣed.   
\m
\v 3 Sgeɛɛed iṣuraf nnec  
\m ɣar min yareddǧen i řebda.  
\m Řeɛdu yarra marra d řxarbet  
\m di Zzawect Iqeddsen.   
\b  
\m
\v 4 Inni tuɣa Cek iḥeṣṣaren ssbuɛruten  
\m di řwest n wemcan nnec n umsagar,  
\m ssbeddan řeɛřamat nsen d řeɛřamat.   
\m
\v 5 Aqa netta idweř ittwassen am \add yijjen\add*  
\m issgeɛɛad ccwaqar di cbarq iqqnen,   
\m
\v 6 u xenni arẓin  
\m \add marra\add* inqacen nnes jmiɛ,  
\m s ccaqur d ifḍisen.   
\m
\v 7 Nitni qqeden timessi  
\m i Tzawiyyin nnec Iqeddsen,  
\m aqa ɛarran Tazeddiɣt n Yisem nnec  
\m ař tammurt. \x ◘ \xo 74:7 \xt 2 Ij. 25:9\x*   
\m
\v 8 Nitni nnan deg wuř nsen:  
\m “Ejj aneɣ ad tent nareddeǧ marra!”  
\m \add Ammu i\add* ssarɣen nitni  
\m marra imucan n umsagar n Arebbi  
\m di temmurt.   
\b  
\m
\v 9 Řeɛřamat nneɣ war tent nettwiři \add ɛad\add*,  
\m war din uřa d ijj n unabi \add ɛad\add*,  
\m uca uřa d ijj jar aneɣ issen  
\m ař meřmi \add ɛad\add*.   
\m
\v 10 Ař meřmi, \add a\add* AREBBI,  
\m ad \add zzayek\add* istehza wenni iḥeṣṣaren?  
\m Ma ad iceqqef řeɛdu i řebda  
\m deg Yisem nnec?   
\m
\v 11 Mayemmi i tᵉttegged  
\m ad dayneɣ ismeḥ afus nnec,  
\m afus nnec afusi?  
\m \add Suffuɣ i-t\add* zeg weḥsin  
\m \add n upartessu\add* nnec,  
\m qḍa \add xasen\add*. \f ◼ \fr 74:11 \ft \+fk aḥsin\ft  - niɣ ‘abeḥrur’.\f*   
\b  
\m
\v 12 Zeg wecḥař uya  
\m aqa AREBBI d Ajeǧid inu.  
\m Netta d wenni i dd-ittawyen  
\m isenjamen di řwest n temmurt.   
\m
\v 13 S tzemmar nnec tfetqed řebḥar,  
\m izeǧifen n řhaycat  
\m teddzed i-ten x waman. \x ◘ \xo 74:13 \xt Uf. 14:21-31\x*   
\m
\v 14 Cek třebzed izeǧifen n ‘Liviyatan’,  
\m tewcid i-t d macca i řewḥuc n řexřa. \f ◼ \fr 74:14 \ft \+fk řewḥuc n řexřa\ft  - ittxeṣṣa aneɣ ad nfekkar deg iseřman imeqqranen n řebḥar inni iccin řxecbat n Imiṣriyyen tinni iwḍent ɣar tma n Řebḥar n Uɣanim (xzar Uf. 14:30).\f*   
\b  
\m
\v 15 Cek tfeǧqed řɛunṣar d teɣzart,  
\m Cek tessiẓɣed iɣezran ittazzřen  
\m břa qeṭṭu. \x ◘ \xo 74:15 \xt Uf. 17:5, 6; Řxř. 20:11; Yac. 3:13; Izhd. 105:41; Ica. 48:21\x*   
\m
\v 16 Ass nnec, nnec uřa d ǧiřet,  
\m Cek teggid din tafawt d tfuct. \x ◘ \xo 74:16 \xt Amz. 1:14-19\x*   
\m
\v 17 Cek tessmetned  
\m marra iymiren n temmurt,  
\m anebdu d tgerst  
\m aqa teggid asen tifras \add nsen\add*.   
\b  
\m
\v 18 Ɛqeř x man aya:  
\m řeɛdu isseḥqar SIDI,  
\m ijj n řgens abuhaři iceqqef  
\m deg Yisem nnec.   
\m
\v 19 War ttic řeɛmar n tejlilleḥt nnec  
\m i řewḥuc,  
\m war tᵉttu i řebda  
\m tudart n řmusakin nnec.   
\m
\v 20 Xzar ɣar Řɛahd,  
\m maɣar \add deg\add* imucan n ṭṭřam di temmurt  
\m aqa daysen tudrin ɛemmarent s lɛunf.   
\b  
\m
\v 21 War ttejji wenni ittwaḥeṣṣaren  
\m ad dd-iɛqeb s useḍḥi,  
\m ejj řmeskin d umezřaḍ  
\m ad ṣebbḥen Isem nnec.   
\m
\v 22 Kkar bedd, \add a\add* AREBBI,  
\m belleɛ ddeɛwet nnec,  
\m xemm mammec Cek isseḥqaran  
\m ibuhařiyyen ass imun.   
\m
\v 23 War ttᵉttu ca aɣuyyi n iɣrimen nnec,  
\m asbuɛar n yinni i xak iɣewwɣen  
\m ittgeɛɛad ɣar ujenna břa \add a\add*qeṭṭu.   
\b  
\b  
\m  
\c 75
\m
\v 1 \add I umeqqran n imeɣnajen. ‘War ttareddeǧ!’ Azehhed n Asaf. Izři.\add*   
\b  
\m
\v 2 Neccin nettqada Cek,  
\m \add a\add* AREBBI, nettqada!  
\m Aqa Isem nnec yudes,  
\m aqa lmuɛjizat nnec  
\m ssawařen \add x man aya\add*.   
\b  
\m
\v 3 Maɣar Necc ad xḍareɣ  
\m řḥař ittwaggen,  
\m ad ggeɣ ccreɛ s řḥeqq.   
\m
\v 4 Tammurt ak-d marra imezdaɣ nnes tefsiy,  
\m maca Necc ssmettneɣ  
\m ipilaren nnes. Silah.   
\m
\v 5 Necc nniɣ i ibuhařiyyen:  
\m “War tteggʷedem ca!”,  
\m i iɛeffanen:  
\m “War ssgeɛɛadem icc \add nwem\add*!   
\m
\v 6 War ssgeɛɛadem icc nwem  
\m \add ammu\add* sennej,  
\m war ssawařem s nnfaxet!”   
\b  
\m
\v 7 Maɣar asgeɛɛed  
\m war dd-ittas zi ccarq,  
\m niɣ zi řɣarb uřa zi řexřa. \f ◼ \fr 75:7 \ft \+fk řexřa\ft  - aqa-t d řexřa n ljanub n Isarulwenni umi qqaren řexxu ‘Naqab’.\f*   
\m
\v 8 Maɣar AREBBI d řqaḍi.  
\m Netta issᵉhekkʷa ijjen  
\m u issgeɛɛad wenneɣni.   
\m
\v 9 Maɣar aqa \add din\add* ijj n řkas  
\m deg ufus n SIDI,  
\m binu ittegg kuffu, ittwaxeǧaḍ marra.  
\m Netta ittkebba zzayes.  
\m Marra iɛeffanen n temmurt  
\m ad ẓemmen uřa d řexmira nnes  
\m umi \add zzayes\add* i ɣa swen. \x ◘ \xo 75:9 \xt Asa. 16:19\x*   
\b  
\m
\v 10 Necc ad \add t\add* barrḥeɣ i řebda qaɛ,  
\m ad zehhdeɣ i AREBBI n Yaɛqub.   
\m
\v 11 Necc ad zedmeɣ  
\m marra accawen n iɛeffanen,  
\m accawen n imseggaden  
\m ad ttwassgeɛɛden.   
\b  
\b  
\m  
\c 76
\m
\v 1 \add I umeqqran n imeɣnajen. Ak-d uzenzun x ifiřan.\add* \add Azehhed n Asaf, izři.\add*   
\b  
\m
\v 2 AREBBI ittwassen di Yahuda,  
\m Isem nnes d ameqqran di Israil.   
\m
\v 3 Aɛucci nnes aqa-t di Calim,  
\m Tazeddiɣt nnes di Ṣihyun.   
\m
\v 4 Dinni yarẓa  
\m fřitcat yareqqen n řqews,  
\m taseddart n useřqi d ssif  
\m uřa d amenɣi. Silah.   
\b  
\m
\v 5 Tessaggʷaded u tjehded i teǧid  
\m x idurar nni immeẓren di tkeccaḍt.   
\m
\v 6 Inni izeɛɛamen ttwakeccḍen.  
\m Nitni nnudmen, ṭṭṣen,  
\m uřa d ijj zeg iryazen imeḥḍen  
\m war izemmar ad immɛařa.   
\m
\v 7 S uweddeb nnec, \add a\add* AREBBI n Yaɛqub,  
\m iɣarq ukarru d uyis deg yiḍeṣ.   
\b  
\m
\v 8 Cek, \add wah,\add* Cek tessaggʷaded,  
\m wi izemmaren ad iqqim ibedd  
\m zzat i wudem nnec,  
\m xmi dd ɣa ikkar weɣḍab nnec?   
\m
\v 9 Zeg ujenna teggid  
\m ad ittwaseř řḥukm.  
\m Teṭṭef teggʷudi tammurt uca tesseɣd,   
\m
\v 10 umi ikkar AREBBI  
\m maḥend ad icarreɛ,  
\m ḥima ad ifekk  
\m marra imhinen n temmurt. Silah.   
\b  
\m
\v 11 Maɣar afugem n iwdan  
\m ad yawi aqadi i Cek,  
\m min iqqimen \add ɛad\add* n wesɛar  
\m ad t tmenɛed.   
\m
\v 12 Wcem lwuɛud u ggem zzaysen  
\m zzat i SIDI, AREBBI nwem.  
\m Ejj marra inni d as dd-innḍen  
\m ad awyen ṣṣdaqi  
\m i Wenni ittxeṣṣa ad zzayes ggʷeden,   
\m
\v 13 wenni imennɛen i řḥukkam  
\m buḥbeřat nsen,  
\m wenni zzayes tteggʷden  
\m ijeǧiden n temmurt.   
\b  
\b  
\m  
\c 77
\m
\v 1 \add I umeqqran n imeɣnajen. Sadu ufus n Yadutun.\add* \add Azehhed n Asaf.\add*   
\b  
\m
\v 2 \add Necc ssgeɛɛdeɣ\add* tmijja inu  
\m ɣar AREBBI uca řaɣiɣ,  
\m \add ssgeɛɛdeɣ\add* tmijja inu ɣar AREBBI,  
\m Netta ad ayi iseř.   
\m
\v 3 Deg wass n řeḥṣaret inu  
\m arzuɣ Sidi inu.  
\m S ǧiřet sswiẓẓḍeɣ afus inu  
\m břa ma ad as arxuɣ,  
\m řeɛmar inu yugi ad ittwaɛezza.   
\m
\v 4 Umi tuɣa ttidareɣ AREBBI,  
\m \add xenni\add* ttzehhareɣ, ttxemmameɣ,  
\m \add uca\add* yarxu buḥbeř inu. Silah.   
\b  
\m
\v 5 Cek tarred tiṭṭawin inu  
\m ad qqiment faqent,  
\m nnhewřeɣ, war ssiwřeɣ.   
\m
\v 6 Necc ttxemmameɣ  
\m deg wussan n wecḥař uya,  
\m deg iseggʷusa n zzmanat \add iɛdun\add*.   
\m
\v 7 Necc ttidareɣ deg uzenzun  
\m x ifiřan inu s ǧiřet,  
\m xmi ttxemmameɣ deg wuř inu  
\m u buḥbeř inu yarezzu:   
\m
\v 8 Ma ad \add aneɣ\add* inḍar Sidi inu i řebda,  
\m war \add xafi\add* ittḥinni ɛad?   
\m
\v 9 Ma tbedd tmexsiwt nnes  
\m icewwaren i řebda?  
\m Ma ittwabḍeř wawař  
\m i iǧan zi jjiř i jjiř nneɣni  
\m \add awarni as\add*?   
\m
\v 10 Ma ittu Arebbi aḥinni nnes?  
\m Ma deg weɣḍab nnes  
\m ibelleɛ arreḥmet nnes?” Silah.   
\b  
\m
\v 11 Nniɣ: “Wa d řeɛdab inu,  
\m aqa d iseggʷusa  
\m zeg ufus n Umɛuǧi x kuřci.”   
\m
\v 12 Necc ad idareɣ timegga n SIDi,  
\m ad ɛeqřeɣ x lmuɛjizat nnec n zic.   
\m
\v 13 Necc ad xemmameɣ  
\m di marra řexdayem nnec,  
\m ad ttxarraṣeɣ di marra min teggid.   
\m
\v 14 \add A\add* AREBBI, abrid nnec  
\m aqa deg Uqeddas \add i yeǧa\add*!  
\m Man wen \add i yeǧan\add*  
\m d arebbi ameqqran  
\m am AREBBI?   
\m
\v 15 Cek d Arebbi  
\m nni itteggen lmuɛjizat,  
\m Cek tessecned tizemmar nnec  
\m jar řegnus. \x ◘ \xo 77:15 \xt Uf. 15:11\x*   
\m
\v 16 Cek tefdid řgens nnec s uɣiř nnec,  
\m tarwa n Yaɛqub d Yusuf. Silah.   
\b  
\m
\v 17 Aman ẓrin Cek, \add a\add* AREBBI,  
\m aman ẓrin Cek uca arjijen,  
\m \add wah,\add* \add aman\add* ihewřen nnhewřen. \x ◘ \xo 77:17 \xt Uf. 14:21\x*   
\m
\v 18 Iseynuten ideqqřen  
\m farrɣen-dd aman nsen,  
\m ibarruten n iseynuten  
\m ssgeɛɛden tmijja nsen,  
\m u fřitcat n řqews nnec ḍwint da d diha. \f ◼ \fr 77:18 \ft \+fk ssgeɛɛden\ft  - s Tɛibranit ‘wcin’.\f*  \x ◘ \xo 77:18 \xt Uf. 14:24\x*   
\m
\v 19 Tmijja nnec tegga  
\m am wajjaj di tḥaryaḍt,  
\m assamen ggin tafawt x ddunect,  
\m tammurt tenhezz tarjij. `   
\m
\v 20 Abrid nnec \add icuq\add* di řebḥar,  
\m amesraq nnec deg waman imeqqranen,  
\m \add maca\add* iṣuraf \add n iḍaren\add* nnec  
\m war binen \add ɛad\add*.   
\b  
\m
\v 21 Cek tnedhed řgens nnec  
\m am \add ict n tḥimart\add* n wuǧi,  
\m s ufus n Musa d Harun. \x ◘ \xo 77:21 \xt Izhd. 78:52; 80:2\x*   
\b  
\b  
\m  
\c 78
\m
\v 1 \add Axemmi n Asaf.\add*  
\b  
\m \add A\add* řgens inu, ewc amezzuɣ  
\m i Ccariɛa inu!  
\m Meyyřem amezzuɣ nwem  
\m ɣar wawařen n uqemmum inu.   
\m
\v 2 Necc ad arzmeɣ aqemmun inu  
\m s wawař iweznen,  
\m ad barrḥeɣ řemɛani innuffaren  
\m zeg wecḥař uya, \x ◘ \xo 78:2 \xt Izhd. 49:5; Mt. 13:35\x*   
\m
\v 3 \add timesřayin\add* nni nesřa u nessen,  
\m nni d aneɣ ḥajan řejdud nneɣ.   
\m
\v 4 War ten nᵉtteffar zeg iḥenjiren nsen,  
\m zi jjiř i dd ɣa yasen.  
\m Ad nbarreḥ s tmegga iṣebbḥen n SIDI,  
\m s tmegga nnes ijehden  
\m d lmuɛjizat nnes nni tuɣa igga.   
\b  
\m
\v 5 Maɣar Netta igga ict n cchadet  
\m di Yaɛqub,  
\m issars ict n Ccariɛa di Israil,  
\m nni tuɣa yumur i řejdud nneɣ,  
\m maḥend ad tt ssɣaren i iḥenjiren nsen, \x ◘ \xo 78:5 \xt Aɛwd. 4:9; 6:7\x*   
\m
\v 6 maḥend jjiř i dd ɣa yasen ad issen,  
\m iḥenjiren nni dd ɣa ittwaxeřqen  
\m \add awarni asen\add*,  
\m u \add xenni\add* uřa d nitni ad kkaren  
\m ad tt sseɛdun i iḥenjiren nsen,   
\m
\v 7 \add maḥend\add* nitni ad ssarsen  
\m řaman nsen x AREBBI,  
\m war ttᵉttun ca timegga n Arebbi,  
\m \add maca\add* ad ḥḍan tiweṣṣa nnes,   
\m
\v 8 war ttiřin am řejdud nsen,  
\m ijj n jjiř aɣennan d iɣewwɣen,  
\m ijj n jjiř s wuř war imten  
\m u s arruḥ iɣdaren Arebbi. \x ◘ \xo 78:8 \xt Uf. 32:9; 33:3, 5; 34:9; Aɛwd. 9:6, 13; 31:27\x*   
\m
\v 9 Ayt n Ifrayim, imjebbaden n řqews,  
\m ɛeqben deg wass n umenɣi.   
\m
\v 10 War ḥḍan Řɛahd ak-d AREBBI,  
\m ugin ad uyuren di Ccariɛa nnes.   
\m
\v 11 Ttun timegga nnes d lmuɛjizat,  
\m tinni i d asen isscen.   
\b  
\m
\v 12 Zzat i \add tiṭṭawin n\add* řejdud nsen  
\m igga Netta ict n lmuɛjiza,  
\m di temmurt n Miṣra,  
\m deg iyyar n Ṣuɛan.   
\m
\v 13 Netta ibḍa řebḥar  
\m uca isseẓwa ten zzayes,  
\m ijja aman ad bedden am weɣbar. \x ◘ \xo 78:13 \xt Uf. 14:21\x*   
\m
\v 14 Netta issqebbeḍ i-ten s wass  
\m s useynu,  
\m s ǧiřet marra s tfawt n tmessi. \x ◘ \xo 78:14 \xt Uf. 13:21; Izhd. 105:39\x*   
\m
\v 15 Netta ibḍa řejruf di řexřa,  
\m iwca i řgens ad isu s ufeyyeḍ  
\m amecnaw zeg \add waman\add* ihewřen. \x ◘ \xo 78:15 \xt Uf. 17:6; Řxř. 20:11; Izhd. 105:41; 1 Kur. 10:4\x*   
\m
\v 16 Netta ijja řɛunṣarat  
\m ad feyyḍent zi sseǧaḥ,  
\m Netta ijja aman  
\m ad hwan am yiɣezran.   
\b  
\m
\v 17 Maca nitni arnin  
\m di ddnub nsen xas,  
\m ɣewwɣen x Umɛuǧi x kuřci  
\m \add umi tuɣa aten\add* di tnezruft yuẓɣen.   
\m
\v 18 Nitni jarrben Arebbi  
\m deg wuř nsen  
\m umi ttaren macca  
\m ɣar \add meẓri n\add* řeɛmar nsen.   
\m
\v 19 Ssiwřen ḍidd i AREBBI, nnan:  
\m “Ma izemmar Arebbi  
\m ad issewjed ṭṭabřa di řexřa? \x ◘ \xo 78:19 \xt Řxř. 11:1, 4\x*   
\m
\v 20 Xzar, Netta iwta di teṣḍart,  
\m \add ařami\add* dd-uzzřen \add zzayes\add*  
\m waman d iɣezran.  
\m Ma izemmar Netta ad iwc aɣrum  
\m niɣ issewjed aysum i řgens nnes?” \x ◘ \xo 78:20 \xt Uf. 17:6; Řxř. 20:11\x*   
\b  
\m
\v 21 S uya isřa SIDI uca iffugem.  
\m Timessi tarɣa ḍidd i Yaɛqub,  
\m ikkar-dd weɣḍab nnes ḍidd i Israil, \x ◘ \xo 78:21 \xt Řxř. 11\x*   
\m
\v 22 maɣar war uminem ca di AREBBI,  
\m war ttciřin deg usenjem nnes.   
\m
\v 23 Netta yumur iseynuten sennej  
\m u yarzem tiwwura n ujenna.   
\m
\v 24 Ifarreɣ-dd xasen ‘manna’  
\m maḥend ad ccen,  
\m iwca asen imendi zeg ujenna. \x ◘ \xo 78:24 \xt Uf. 16:14\x*   
\m
\v 25 Marra ccin aɣrum  
\m n yinni daysen řɛezz.  
\m Issekk asen macca nsen ɣar webrid  
\m ařami jjiwnen. \f ◼ \fr 78:25 \ft \+fk aɣrum n yenni daysen řɛezz\ft  - tterjama Tayunanit n Řɛahd Aqdim zi ɛřayen mitayn u xemsin iseggʷusa qbeř Lmasiḥ, qqaren as Siptuwaxinta (LXX), teqqar ‘aɣrum n lmalakat’, minzi ‘manna’ tuɣa-t zeg ujenna mani zeddɣen lmalakat.\f*  \x ◘ \xo 78:25 \xt Yḥ. 6:31; 1 Kur. 10:3\x*   
\b  
\m
\v 26 Netta igga asemmiḍ  
\m n manis dd-tneqqar tfuct  
\m ad ikkar deg ujenna,  
\m s tzemmar nnes issekk-dd  
\m asemmiḍ n ljanub. \x ◘ \xo 78:26 \xt Řxř. 11:31\x*   
\m
\v 27 Ijja aysum ad xasen dd-iwḍa  
\m am \add wenẓar n\add* tɛejjajt,  
\m ijḍaḍ s wafriwen am yijdi n řebḥur.   
\m
\v 28 Netta ijja i-ten ad wḍan  
\m di řwest n řmargeḥ n řɛeskar,  
\m ɣar marra iɣezdisen n tzeddiɣin nsen.   
\m
\v 29 Nitni ccin u jjiwnen qaɛ,  
\m ksin min di tuɣa ḍemɛen.   
\b  
\m
\v 30 Nitni tuɣa ɛad war ttwafekken  
\m zeg weḍmaɛ nsen,  
\m macca tuɣa ɛad deg uqemmum nsen,   
\m
\v 31 \add umi\add* xasen ikkar weɣḍab n AREBBI.  
\m Netta inɣa inni iǧan  
\m d iqebbuzen qaɛ jar asen,  
\m yarra-dd iḥudriyyen n Israil  
\m ad aḍaren \add ɣar tɛejjajt n temmurt\add*. \x ◘ \xo 78:31 \xt Řxř. 11:33; 1 Kur. 10:5\x*   
\m
\v 32 \add Maca\add* qaɛ amenni arnin ggin ddnub,  
\m war uminen di lmuɛjizat nnes.   
\m
\v 33 Netta ijja ussan nsen  
\m ad ɛdun am yijj n řefwar,  
\m iseggʷusa nsen am yict n řɛurret.   
\b  
\m
\v 34 Xmi ten i ɣa ineɣ, arzun x Arebbi,  
\m dewřen-dd ɣares, arzun xas s cḍaret.   
\m
\v 35 Nitni ɛeqřen  
\m aqa AREBBI d Taṣḍart nsen,  
\m Arebbi, Amɛuǧi x kuřci,  
\m d Amefdi nsen. \f ◼ \fr 78:35 \ft \+bd ’Amefdi‘\+bd* - ijj n bnadem nni ifdin niɣ ifekken ijj n ismeɣ niɣ ict n tesmeɣt, niɣ ijj n bnadem dayes amarwas, niɣ ict n temmurt ɛlaḥsab řqanun, aqa netta ad ixeǧes ttaman i ɣa iřiqqen ismeɣ nni, niɣ ad ixeǧeṣ amarwas i ittxeṣṣa niɣ ttaman n temmurt nni niɣ ṣṣadaq i temɣart am mammec i d as icuwwar. S uyenni amefdi war ittfekki amenni waha maca netta d ijj wenni ifekken x řeḥsab řqanun, war ifekk břa ma ad ixeǧeṣ ttaman niɣ tamesřact i d as ittxeṣṣa ad tt iwc. D man aya i icuwwar ad t nessen x wawař ‘amefdi’ u x wawařen i ɣares dd-iqqnen am: ‘ifdi’, ‘ad ifdi’, niɣ ‘ad ifdi kur aseggʷas ijj n wezyen n yeyyar nnes’, u mammec nneɣni. S uyenni Yasuɛ Lmasiḥ d Amefdi i iǧa i marra iwdan minzi Netta iwca Tudart nnes di ṭṭweɛ nneɣ ammu i xaneɣ ifdi s idammen nnes izdigen iqeddsen, u ammu i ɣa ifdi Israil (‘marra Udayen inni i ɣa yamnen deg Yisem nnes’) d temmurt akides xmi dd ɣa yas i twařa wiss tnayen deg uneggar n wussan. Maca cciṭan war iǧi amenni. Netta ittegg am uceffar am uxcin u am uɣeṣṣab. War d as itthimmi řxar n bnadem maca mɣir ccan n yixef nnes, ḥima marra iwdan ad t ɛebden umi ten issiggʷej x Arebbi Iddaren s ixarriqen nnes d tseḥḥart nnes (xẓar Yḥ. 10).\f*   
\m
\v 36 Maca nitni ssniɛmiřen zzates  
\m s uqemmum nsen,  
\m s yiřes nsen ssxarriqen xas.   
\m
\v 37 War tuɣi uř nsen imten akides,  
\m war uyuren s řmanet  
\m ak-d Řɛahd nnes.   
\b  
\m
\v 38 Netta \add maca\add* tuɣa yareḥḥem \add daysen\add*  
\m u isseṣřeḥ x řmuɛṣiyyet nneɣ,  
\m war yareddeǧ, maca aṭṭas n twařawin  
\m ijja zeg weɣḍab nnes  
\m u war iggi marra asɛar nnes ad ikkar.   
\m
\v 39 Netta iɛqeř aqa nitni  
\m mɣir d aysum waha,  
\m d ijj n usemmiḍ iɛeddu  
\m war dd-ittɛiqqib.   
\m
\v 40 Mecḥař n twařawin  
\m sɛaren t di řexřa,  
\m ggin as řeḥriq di tnezruft!   
\b  
\m
\v 41 Twařa awarni tenneɣnit  
\m qeǧben Arebbi,  
\m ggin řeḥriq i Umqeddas n Israil.   
\m
\v 42 War xarrṣen ca ɛad deg ufus nnes,  
\m deg wass nni řami ten ifda  
\m \add zeg ufus\add* n wenni i-ten iḥṣaren, \f ◼ \fr 78:42 \ft \+fk ifda\ft  - xzar ‘Amefdi’ - Izhd. 78:35.\f*   
\m
\v 43 ařami igga řeɛřamat di Miṣra,  
\m uřa d lmuɛjizat nnes deg iyyar n Ṣuɛan,   
\m
\v 44 \add ařami\add* igga iɣezran nsen  
\m ad dewřen d idammen,  
\m uřa d marra řɛunṣarat nsen,  
\m ḥima nitni war zemmaren  
\m ad \add zzaysen\add* swen ɛad. \x ◘ \xo 78:44 \xt Uf. 7:20; Asa. 16:4\x*   
\b  
\m
\v 45 Issekk jar asen  
\m ijj n weyřaf n ibeɛɛac i ten iccen,  
\m uřa d iqarqriwen nni ten iteḥḥan. \x ◘ \xo 78:45 \xt Uf. 8:2, 20\x*   
\m
\v 46 Netta iwca řɣiǧet nsen  
\m i tmuɣri iṣarrḍen,  
\m uřa d ṣṣabet nsen i tmuɣri. \x ◘ \xo 78:46 \xt Uf. 10:13\x*   
\m
\v 47 Inɣa tazayart nsen s tebrurri,  
\m uřa d izemmuren nsen s tkeḍfin. \x ◘ \xo 78:47 \xt Uf. 9:23\x*   
\m
\v 48 Netta ijja řmař nsen i ubruri,  
\m tiḥimriwin nsen i wassamen.   
\b  
\m
\v 49 Netta issekk řḥaduq n weɣḍab nnes  
\m jar asen,  
\m amuzzar d tefqeḥt d řḥeṣran,  
\m umi dd-issekk lmalakat s jjrayeḥ.   
\m
\v 50 Netta iseggem ijj n umesraq  
\m i weɣḍab nnes,  
\m war issɛizz x řeɛmar nsen zi řmewt,  
\m isseɛdu řmař nsen i ṭṭaɛun. \x ◘ \xo 78:50 \xt Uf. 9:6\x*   
\m
\v 51 Netta inɣa marra imenza di Miṣra,  
\m imenza n yeryazen daysen teryast  
\m deg iqiḍan n Ḥam. \x ◘ \xo 78:51 \xt Uf. 12:29; Izhd. 105:36\x*   
\b  
\m
\v 52 Igga řgens nnes ad issgeɛɛed am wuǧi,  
\m issqebbeḍ i-ten  
\m am yict n tḥimart di řexřa.   
\m
\v 53 Indeh i-ten di řaman,  
\m war ggʷiden walu,  
\m maɣar řebḥar idřa řɛedyan nsen. \x ◘ \xo 78:53 \xt Uf. 14:27, 28; 15:10\x*   
\m
\v 54 Iwyi ten ɣar temmurt nnes iqeddsen,  
\m ɣar wedrar-a nni d ikseb ufus afusi nnes.   
\m
\v 55 Issuffeɣ řegnus zzat i wudem nsen,  
\m igga ad asen dd-tekkar tesɣart nsen  
\m s ufiřu \add n řeɛbar\add*,  
\m uca issezdeɣ tiqebbař n Israil  
\m deg iqiḍan nsen. \x ◘ \xo 78:55 \xt Yac. 13:7; Izhd. 136:21, 22\x*   
\b  
\m
\v 56 \add Maca\add* nitni qeǧben t, sɛaren AREBBI,  
\m Amɛuǧi x kuřci,  
\m war hḍin cchadat nnes.   
\m
\v 57 Nitni dewřen ɣar ḍeffar,  
\m ggin s řeɣdar am řejdud nsen.  
\m Nitni weddaren  
\m am yict n fřitca n řqews  
\m i iteffɣen s řexdeɛ.   
\m
\v 58 Sɛaren t s řegɛudi nsen  
\m \add i x wehhben tiɣarṣa\add*,  
\m arrin t ad yasem  
\m s řexyařat nsen ineqcen \x ◘ \xo 78:58 \xt Aɛwd. 32:16, 21\x*   
\m
\v 59 AREBBI isřa man aya  
\m uca ittwassarɣ weɣḍab nnes,  
\m idweř iɛiff aṭṭas zi Israil.   
\b  
\m
\v 60 Netta ijja Tazeddiɣt nnes di Cilu,  
\m Aqiḍun mani tuɣa izeddeɣ jar iwdan. \x ◘ \xo 78:60 \xt Irm. 7:14\x*   
\m
\v 61 Netta yarra jjehd nnes  
\m ɣar tmeḥbast,  
\m uřa d talwizt nnes  
\m ɣar ufus n wenni t iḥeṣṣaren. \x ◘ \xo 78:61 \xt 1 Ṣm. 4:10, 11\x*   
\m
\v 62 Netta isellem řgens nnes i ssif,  
\m yarɣa weɣḍab nnes x tesɣart nnes.   
\m
\v 63 Timessi tecca iḥudriyyen nsen,  
\m tiɛzariyyin nsen  
\m war xasent dd-iwyen iɣennijen.   
\m
\v 64 Ikehhanen nsen wḍan s ssif  
\m u tijjař nsen war runt ca. \x ◘ \xo 78:64 \xt 1 Ṣm. 4:11, 18, 19\x*   
\b  
\m
\v 65 \add Xenni\add* ifaq-dd Sidi inu  
\m am ca n ijj i tuɣa iṭṭṣen,  
\m am yijj n bu-teɣruḍt  
\m nni isɣuyyu zi binu.   
\m
\v 66 Netta iwta inni t iḥeṣṣaren  
\m ɣar ḍeffar,  
\m igga daysen řefḍiḥet i řebda. \x ◘ \xo 78:66 \xt 1 Ṣm. 5:6; 6:4\x*   
\m
\v 67 Aqiḍun n Yusuf inḍar i-t,  
\m taqbič n Ifrayim war tt ifarz.   
\m
\v 68 Ifarz taqbič n Yahuda,  
\m adrar n Ṣihyun wenni tuɣa ittexs.   
\b  
\m
\v 69 Ibna Zzawect nnes Iqeddsen  
\m am \add ijenwan\add* yuɛřan,  
\m am temmurt nni issemten i řebda.   
\m
\v 70 Ifarz amsexxar nnes Dawud,  
\m iksi t zi řkurit n wuǧi. \x ◘ \xo 78:70 \xt 1 Ṣm. 16:11; 2 Ṣm. 7:8\x*   
\m
\v 71 Ijja i-t ad dd-yas  
\m zi ɣar ḍeffar n wuǧi,  
\m maḥend ad yarwes Yaɛqub,  
\m řgens nnes,  
\m uřa d Israil, řwart nnes. \x ◘ \xo 78:71 \xt 2 Ṣm. 5:2; 1 Im. 11:2\x*   
\m
\v 72 Netta yarwes i-ten  
\m ɛlaḥsab řeṣfayet n wuř nnes,  
\m igewwed i-ten s ufus izemmaren.   
\b  
\b  
\m  
\c 79
\m
\v 1 \add Azehhed n Asaf.\add*  
\b  
\m \add A\add* AREBBI, řegnus udfen  
\m ɣar řwart nnec.  
\m Nitni ssxemjen  
\m Zzawect nnec Tameqqrant iqeddsen,  
\m arrin Urcalim d řxirbat.   
\m
\v 2 Řxecbat n imsexxaren nnec  
\m wcin tent d macca i ijḍaḍ n ujenna,  
\m aysum n imtiqqan nnec  
\m i řewḥuc n temmurt.   
\m
\v 3 Idammen nsen zeǧɛen ten  
\m am waman  
\m ɣar marra iɣezdisen n Urcalim,  
\m uřa d ijj war \add ten\add* inḍiř.   
\m
\v 4 Nedweř d řefdiḥet i jjiran nneɣ,  
\m d ustehzi d useḥqar  
\m i marra inni d aneɣ dd-innḍen. \x ◘ \xo 79:4 \xt Izhd. 44:14; 80:7\x*   
\b  
\m
\v 5 Ar meřmi, \add a\add* SIDI?  
\m Ma \add xenni\add* ad teqqimed  
\m tseɛɛared i řebda?  
\m \add Ma\add* ad tareɣ tusmi nnec \add iqeddsen\add*  
\m am tmessi \add i řebda\add*? \x ◘ \xo 79:5 \xt Izhd. 89:47\x*   
\m
\v 6 Farreɣ asɛar nnec  
\m x řegnus i war Cek issinen,  
\m x tigeldiwin nni war ittřiɣin  
\m x Yisem nnec. \x ◘ \xo 79:6 \xt Irm. 10:25\x*   
\m
\v 7 Maɣar nitni ccin Yaɛqub,  
\m areddǧen Tazeddiɣt nnes.   
\m
\v 8 War xaneɣ ɛeqqeř  
\m ɛlaḥsab řmuɛṣiyyet nneɣ n zic.  
\m Qeǧeq, ejj arreḥmet nnec  
\m ad kidneɣ temsagar,  
\m maɣar neḍɛef aṭṭas. \x ◘ \xo 79:8 \xt Ica. 64:8 \x*   
\b  
\m
\v 9 Ewc aneɣ afus nnec, \add a\add* AREBBI,  
\m di ṭṭweɛ n uɛuǧi n Yisem nnec,  
\m fekk aneɣ u seṣřeḥ x ddnub nneɣ  
\m di ṭṭweɛ n Yisem nnec.   
\m
\v 10 Mayemmi ɣa inin řegnus:  
\m “Mani iǧa AREBBI nsen?”  
\m Ejj antaqem n idammen  
\m ittwassizřen n řgens nnec  
\m ad idweř ittwassen  
\m jar řegnus jar tiṭṭawin nneɣ.   
\m
\v 11 Ejj azehhar n umeḥbus ad dd-yas  
\m zzat i wudem nnec,  
\m ḥḍa iḥenjiren n řmewt  
\m ɛlaḥsab řemɣaret n uɣiř nnec.   
\m
\v 12 Arr asen i jjiran nneɣ abehdeř nsen  
\m sebɛa n tseqqar ɣar weḥsin nsen,  
\m \add abehdeř nsen\add* i zi cek feḍḥen,  
\m \add a\add* Sidi inu.   
\b  
\m
\v 13 Neccin d řgens nnec  
\m d wuǧi n ddmani n tarewsa nnec.  
\m Nettqada Cek i řebda,  
\m zi jjiř ař jjiř.  
\m Neccin ad nbarreḥ ccan nnec.   
\b  
\b  
\m  
\c 80
\m
\v 1 \add I umeqqran n imeɣnajen.\add*  
\m \add S teɣnint n ‘Tlillicin’.\add*  
\m \add Cchadet n Asaf. Azehhed.\add* \f ◼ \fr 80:1 \ft \+fk tilillicin\ft  - ict n marka n nnuwarat daysen aẓri aṭṭas.\f*   
\b  
\m
\v 2 Seř, \add a\add* Ameksaw n Israil,  
\m Cek d wenni yarekkwesen Yusuf  
\m am wuǧi,  
\m Cek d wenni ittɣiman x ikiruben,  
\m ban-dd di tissiqt! \f ◼ \fr 80:2 \ft \+fk ikiruben\ft  - ict n marka n lmalakat.\f*   
\m
\v 3 Sekkar jjehd ameqqran nnec  
\m zzat i wudem n Ifrayim  
\m d Binyamin d Manassa,  
\m as-dd ḥima ad aneɣ tfekked.   
\m
\v 4 \add A\add* AREBBI, arr aneɣ-dd,  
\m ejj udem nnec ad \add xaneɣ\add* yarɣ,  
\m \add xenni\add* ad nettwafekk. \x ◘ \xo 80:4 \xt Izhd. 4:7; 31:17; 67:2; 80:8; Dan. 9:17\x*   
\b  
\m
\v 5 \add A\add* SIDI, AREBBI n řɛeskarat,  
\m mecḥař i ɣa tekked tᵉttxeyyaqed  
\m ɣar tẓaǧit n řgens nnec?   
\m
\v 6 Cek tessecced ten  
\m s weɣrum n imeṭṭawen,  
\m tarrid ten ad swen imeṭṭawen  
\m s ijj n řmijař ittwaggen.   
\m
\v 7 Cek teggid aneɣ  
\m d \add ict n tcamma n\add* imcubbecen  
\m i jjiran nneɣ,  
\m řɛedyan nneɣ  
\m stᵉhezzan \add zzayneɣ\add* jar asen. \x ◘ \xo 80:7 \xt Izhd. 44:14; 79:4\x*   
\m
\v 8 Arr aneɣ-dd, \add a\add* AREBBI n řɛeskarat,  
\m ejj udem nnec ad \add xaneɣ\add* yarɣ,  
\m \add xenni\add* ad nettwafekk. \x ◘ \xo 80:8 \xt Izhd. 80:4\x*   
\b  
\m
\v 9 Cek tqeřɛed ict n tzayart zi Miṣra,  
\m tuẓẓřed x řegnus, uca teẓẓud-i-tt \add din\add*.   
\m
\v 10 Cek tesswejded as \add amcan\add*  
\m u tarrid tt-i-dd ad tewwet iẓewran,  
\m tɛemmar \add tzayart\add* marra tammurt.   
\m
\v 11 Ttwassduryen idurar s tiři nnes,  
\m ticejjura n tengelt n Arebbi  
\m s řefruɛ nnes.   
\m
\v 12 Tegga tiseḍwin nnes  
\m ad awḍent ař řebḥar,  
\m ifetwan nnes iziyzawen  
\m ař iɣzar \add n Lfuraṭ\add*.   
\b  
\m
\v 13 Mayemmi tɣeḍřeḍ iɣebrawen nnes,  
\m ařami marra inni dd-ittekken  
\m x webrid řeqqḍen tt?   
\m
\v 14 Iřef zeg wezɣar iqřeb \add tazayart\add*,  
\m \add marra\add* min intenhezzan deg iyyar,  
\m aqa ihda i-tt. \f ◼ \fr 80:14 \ft \+fk azɣar\ft  - niɣ ‘řɣabet’ niɣ ‘tazgant’.\f*   
\m
\v 15 \add A\add* AREBBI n řɛeskarat,  
\m dweř-dd \add ɣarneɣ\add*,  
\m sijj-dd zeg ujenna,  
\m u xzar, arzef tazayart-a,   
\m
\v 16 tthilla di tzayart  
\m tenni iẓẓu ufus nnec afusi,  
\m di mmic nni tessjehded i Yixef nnec.   
\b  
\m
\v 17 Aqa tᵉttwassecmeḍ s tmessi, tᵉttwaqḍeɛ.  
\m Zeg useggʷed n wudem nnec  
\m ad weddaren.   
\m
\v 18 Ejj afus nnec ad yiři  
\m ak-d weryaz n ufus nnec afusi,  
\m ak-d mmis n bnadem  
\m wenni tessjehded i Yixef nnec.   
\m
\v 19 \add Xenni\add* war xak nḥeyyed ca.  
\m Ejj aneɣ ad neddar,  
\m \add xenni\add* ad nřaɣa x Yisem nnec.   
\m
\v 20 \add A\add* SIDI, AREBBI n řɛeskarat,  
\m arr aneɣ-dd,  
\m ejj udem nnec ad \add xaneɣ\add* yarɣ,  
\m \add xenni\add* ad nettwafekk.   
\b  
\b  
\m  
\c 81
\m
\v 1 \add I umeqqran n imeɣnajen.\add*  
\m \add S teɣnint n Ujitti, aryaz zi Jat.\add*  
\m \add N Asaf.\add*   
\b  
\m
\v 2 Sřiwřem i AREBBI, jjehd nneɣ,  
\m duqqzem s usřiwřew  
\m i AREBBI n Yaɛqub.   
\m
\v 3 Sgeɛɛdem ict n yezři n uṣebbeḥ,  
\m awi abendir,  
\m řgambri miẓid d lharpa.   
\m
\v 4 Suḍem deg uyicc n icarri  
\m ɣar ubeddi n uyur,  
\m ɣar tziri iqefřen,  
\m ɣar wass n řɛid nneɣ.   
\m
\v 5 Maɣar ta d tawṣeyyet i Israil,  
\m ict n lfariḍa n AREBBI n Yaɛqub.   
\m
\v 6 Igga i-tt d cchadet di Yusuf,  
\m řami dd-iffeɣ  
\m ḍidd i temmurt n Miṣra.  
\m Aqa sřiɣ ijj n yiřes  
\m war d as fehmeɣ. \f ◼ \fr 81:6 \ft \+fk Yusuf\ft  - s Tiɛbranit ‘Yah-husef’.\f*   
\b  
\m
\v 7 Taɣruḍt nnes fekkeɣ tt zi ddqeř,  
\m ifassen nnes arxun  
\m zi tsuǧet \add i tuɣa yarebbu\add*.   
\m
\v 8 Cek třaɣid di řeḥṣaret  
\m u Necc fekkeɣ cek \add zzayes\add*.  
\m Necc arriɣ-dd xak am ttnuffareɣ  
\m deg wajjaj,  
\m ɣar waman n Mariba  
\m qeǧbeɣ cek. Silah.   
\m
\v 9 Seř, řgens inu,  
\m \add xenni\add* Necc ad cehdeɣ  
\m di řwesṭ nnec, \add a\add* Israil,  
\m mařa \add xenni\add* tuɣa texsed  
\m ad ɣari dd-tesřed.   
\m
\v 10 War ɣarek ittiři  
\m ijj n arebbi d aɣrib,  
\m war sᵉjed uřa i yijj n arebbi  
\m i war tessined.   
\m
\v 11 Necc d SIDI, AREBBI nnec,  
\m wenni cek dd-issuffɣen zi Miṣra.  
\m Arzem aqemmun nnec  
\m u Necc ad t ccureɣ.   
\b  
\m
\v 12 Maca řgens inu war isři ca  
\m ɣar tmijja inu,  
\m Israil war d ayi ixs.   
\m
\v 13 \add S uyenni\add* jjiɣ ten i wuř nsen iqesḥen,  
\m \add ařami\add* i ɣa uyuren  
\m di řecwar \add n uzeǧif\add* nsen.   
\m
\v 14 Mři dd-isřa ɣari řgens inu,  
\m mři Israil ixs ad yuyur deg ibriden inu!   
\m
\v 15 \add Xenni\add* mammec deɣya iři qḍiɣ  
\m x řɛedyan nsen,  
\m arriɣ afus inu ḍidd i yinni ten iḥeṣṣaren.   
\m
\v 16 Inni icarrhen SIDI  
\m ad ɣares dd-dewřen  
\m ttmuruden deǧen,  
\m řweqt \add n uxeǧeṣ\add* nsen ad yiři i řebda.   
\b  
\m
\v 17 Iři aqa iwca as macca  
\m zi lemliḥ n yirden,  
\m \add wah\add*, iři s tamment zi jjarf  
\m aqa Necc ssjjiwneɣ cek.   
\b  
\b  
\m  
\c 82
\m
\v 1 \add Azehhed n Asaf.\add*  
\b  
\m AREBBI ibedd di tmesmunt n Arebbi.  
\m Netta iḥekkem s řḥeqq  
\m di řwest n irebbiten.   
\m
\v 2 Mecḥař i ɣa tekkem  
\m tḥekkmem s řɣecc,  
\m ad tessgeɛɛdem udem n iɛeffanen?  
\m Silah.   
\b  
\m
\v 3 Ḥekmem s řḥeqq x umarxu  
\m u x uyujiř,  
\m aɣem tasɣart i wenni ittwaḥeṣṣaren  
\m u i umezřuḍ.   
\m
\v 4 Fekkem amarxu d umezřuḍ,  
\m fekk i-t zeg ufus n iɛeffanen. \x ◘ \xo 82:4 \xt Awřn. 24:11\x*   
\b  
\m
\v 5 Nitni war ttessnen u war fehhmen,  
\m gguren ttennḍen di taǧest,  
\m marra dsusa n temmurt ttenhezzan.   
\b  
\m
\v 6 Necc nniɣ: “Kenniw d irebbiten,  
\m kenniw marra d iḥenjiren  
\m n Umɛuǧi x kuřci!” \x ◘ \xo 82:6 \xt Yḥ. 10:34-36\x*   
\m
\v 7 Ɛad ad temtem am \add kuř\add* bnadem,  
\m ad tewḍam am kuř ijjen zi řḥukkam.   
\b  
\m
\v 8 Kkar, \add a\add* AREBBI, ḥkem x temmurt,  
\m minzi Cek ad tᵉṭṭfed tasɣart nnec  
\m zi marra řegnus. \x ◘ \xo 82:8 \xt Izhd. 2:8; Ɛbr. 1:2\x*   
\b  
\b  
\m  
\c 83
\m
\v 1 \add Izři. Azehhed n Asaf.\add*   
\b  
\m
\v 2 \add A\add* AREBBI, war sseɣd,  
\m war ttegg Ixef nnec d adehcur,  
\m war seqqar ca, \add a\add* Arebbi.   
\m
\v 3 Maɣar xzar,  
\m řɛedyan nnec ttarruǧuden,  
\m inni Cek icarrhen ssgeɛɛden azeǧif.   
\m
\v 4 Ttxarrṣen deg ict n tmeɛmuč  
\m di tnuffar  
\m ḍidd i řgens nnec,  
\m ttemcawaren  
\m x yinni ittwaḥḍan zzayek.   
\m
\v 5 Qqaren: “Asem-dd, ejj aneɣ  
\m ad ten nteḥḥa am řgens,  
\m \add ařami\add* war ittidar ɛad  
\m deg yisem n Israil.”   
\b  
\m
\v 6 Maɣar ttemcawaren s wuř d ijj,  
\m aqa tteggen ijj n řɛahd ḍidd i Cek: \x ◘ \xo 83:6 \xt Ps 2:2\x*   
\m
\v 7 iqiḍan n Idum d ayt n Ismaɛil,  
\m Mu’ab d ayt n Hajar,   
\m
\v 8 Jabal d Ɛammun d Ɛamaliq,  
\m Filicit d imezdaɣ n Ṣur.   
\m
\v 9 Uřa d Accur immarni ɣarsen.  
\m Nitni tuɣa aten d afus ijhed  
\m i ayt n Luṭ. Silah.   
\b  
\m
\v 10 Egg asen am Midyan d Sisara,  
\m am Yabin ɣar yeɣzar n Qicun.   
\m
\v 11 Nitni ttwateḥḥan ɣar Ɛayn-Dur,  
\m dewřen d řeɣbar x temmurt.   
\m
\v 12 Egg i-ten ak-d tarwa n taṣiřet nsen  
\m am Ɣurab d Di’b,  
\m marra ayt n jjehd nsen  
\m am Zabaḥ d Ṣalmunnaɛ, \x ◘ \xo 83:12 \xt Řqḍ. 7:25; 8:5; Izhd. 83:12\x*   
\m
\v 13 inni iqqaren:  
\m “Ejj aneɣ ad neṭṭef  
\m tizeddiɣin n AREBBI  
\m i yixef nneɣ d řwart.”   
\b  
\m
\v 14 \add A\add* AREBBI inu, egg i-ten  
\m am yijj n uqellij  
\m ittennḍen \add di řeɛwin\add*,  
\m am uřum zzat i wudem n usemmiḍ.   
\m
\v 15 Am tmessi tessreqqa azɣar,  
\m am uceɛɛař ittett idurar, \f ◼ \fr 83:15 \ft \+fk azɣar\ft  - niɣ ‘řɣabet’ niɣ ‘tazgant’.\f*   
\m
\v 16 aẓẓeř ammu xasen s usemmiḍ nnec,  
\m snexřeɛ i-ten s tḥaryaḍt nnec.   
\m
\v 17 Řeḥḥef udem nsen s řeḥya,  
\m maḥend nitni, \add a\add* SIDI,  
\m ad arzun x Yisem nnec.   
\b  
\m
\v 18 Ejj i-ten ad barrqen  
\m u ad arejfen i řebda,  
\m ejj i-ten ad seḍḥan  
\m uca ad ttwahellken,   
\m
\v 19 ḥima ad ssnen, aqa Cek waha  
\m i ɣar iǧa Yisem ‘SIDI’,  
\m Amɛuǧi x marra tammurt.   
\b  
\b  
\m  
\c 84
\m
\v 1 \add I umeqqran n imeɣnajen.\add*  
\m \add S teɣnint n Ujitti, aryaz zi Jat.\add*  
\m \add Zeg ayt n Quraḥ. Azehhed.\add*   
\b  
\m
\v 2 Mammec ttɛizzent tzeddiɣin nnec,  
\m \add a\add* SIDI n řɛeskarat!   
\m
\v 3 Řeɛmar inu dayes meẓri,  
\m \add wah,\add* ifenna \add s uweḥḥec\add*  
\m x řemraḥat n SIDI,  
\m uř inu d ddat inu  
\m sřiwřiwen i Arebbi iddaren. \x ◘ \xo 84:3 \xt Izhd. 42:2; 63:2\x*   
\b  
\m
\v 4 Uřa d ẓẓawec ittaf ɛad ict n taddart,  
\m u tafarǧest tufa ijj n řɛucc i yixef nnes  
\m i di tessrussa issḍawen nnes,  
\m \add ɣar\add* iɛalṭaren nnec, \add a\add* SIDI n řɛeskarat,  
\m Ajeǧid inu d AREBBI inu!   
\b  
\m
\v 5 Sseɛd nsen n yinni izeddɣen  
\m di Taddart nnec,  
\m aqa aten ttṣebbaḥen i Cek  
\m břa qeṭṭu. Silah.   
\b  
\m
\v 6 Sseɛd n iwdan  
\m inni \add ittafen\add* jjehd nsen dayek,  
\m \add inni iḥeṭṭan\add* ibriden igeɛɛden  
\m \add ɣar Zzawect nnec Tameqqrant\add*  
\m deg wuř nsen.   
\m
\v 7 Xmi ttcuqan deg ijj n řewḍa n teɣzurt  
\m n tcejjura n umettin,  
\m arrin t d řɛunṣar.  
\m Uřa d anẓar amezwaru  
\m ad \add ten\add* issduriy s lbarakat.   
\b  
\m
\v 8 Nitni gguren zi jjehd ař jjehd,  
\m ad dd-banen ɣar AREBBI di Ṣihyun.   
\m
\v 9 \add A\add* SIDI, AREBBI n řɛeskarat,  
\m seř i tẓaǧit inu,  
\m sḥess, \add a\add* AREBBI n Yaɛqub! Silah.   
\b  
\m
\v 10 \add A\add* AREBBI,  
\m \add Cek d\add* taseddart nneɣ n useřqi,  
\m aqa xzar ɣar wudem n umedhun nnec!   
\m
\v 11 Maɣar ijj n wass di řemraḥat nnec  
\m iḥřa x wařef \add n wussan nneɣni\add*.  
\m Meɛlik ufiɣ ad beddeɣ  
\m x tnebdat n Taddart n AREBBI inu,  
\m uřa d atlaɛ deg iqiḍan n tuɛeffna.   
\b  
\m
\v 12 Maɣar SIDI AREBBI d tafuct  
\m d tseddart i useřqi,  
\m SIDI ad iwc aḥinni d uɛuǧi.  
\m Netta war issɛizzi řxar  
\m deg inni igguren s řekmaret.   
\b  
\m
\v 13 \add A\add* SIDI n řɛeskarat,  
\m sseɛd n bnadem nni dayek ittiqqan. \x ◘ \xo 84:13 \xt Izhd. 2:12; 34:9\x*   
\b  
\b  
\m  
\c 85
\m
\v 1 \add I umeqqran n imeɣnajen.\add*  
\m \add Zeg ayt n Quraḥ. Azehhed.\add*   
\b  
\m
\v 2 Cek tarḍid x temmurt, \add a\add* SIDI,  
\m tessenqeřbed tameḥbast n Yaɛqub.   
\m
\v 3 Tekksed řmuɛṣiyyet x řgens nnec,  
\m tedřid marra ddnub nnes. Silah.   
\m
\v 4 Cek tmenɛed marra afugem,  
\m tesstewwjed řḥaduq n weɣḍab nnec.   
\b  
\m
\v 5 Arr aneɣ, \add a\add* AREBBI n usenjem nneɣ,  
\m ttu aɣḍab nnec xaneɣ.   
\m
\v 6 Ma texsed ad xaneɣ tesɛared i řebda?  
\m Ma ad tegged aɣḍab nnec  
\m ad iqqim zi jjiř ař jjiř?   
\m
\v 7 Ma war d aneɣ tejjid ad neddar ɛawed,  
\m ḥima ad ac ifarḥ řgens nnec? \x ◘ \xo 85:7 \xt Izhd. 71:20\x*   
\m
\v 8 Scen aneɣ-dd  
\m tamexsiwt nnec icewwaren, \add a\add* SIDI,  
\m ewc aneɣ asenjem nnec.   
\b  
\m
\v 9 Necc xseɣ ad sřeɣ  
\m min ɣa issiweř Arebbi, SIDI,  
\m maɣar Netta ad issiweř ak-d řgens nnes  
\m u ak-d imtiqqan nnes x řehna.  
\m Ɣarwem, mařa nitni ad dd-dewřen  
\m ttcařan \add x yixef nsen\add*.   
\m
\v 10 Nican, aqa yudes-dd usenjem nnes  
\m i yinni zzayes itteggʷeden,  
\m ḥima aɛuǧi \add nnes\add*  
\m ad izdeɣ di temmurt nneɣ.   
\m
\v 11 Tamexsiwt icewwaren d řaman  
\m ad mmsagaren,  
\m tasegda d řehna ad mmsudumen. \x ◘ \xo 85:11 \xt Ɛbr. 7:2\x*   
\b  
\m
\v 12 Tidett ad teɣmi zi temmurt,  
\m tasegda ad tessijj ɣar swadday  
\m zeg ujenna.   
\m
\v 13 SIDI ad iwc uřa d min iṣebḥen,  
\m tammurt nneɣ ad tewc řɣiǧet nnes. \x ◘ \xo 85:13 \xt Izhd. 67:7\x*   
\m
\v 14 Tasegda ad as tizwar  
\m zzat i wudem nnes,  
\m ad teḥḍa jjurret n iṣuraf nnes.   
\b  
\b  
\m  
\c 86
\m
\v 1 \add Taẓaǧit n Dawud.\add*  
\b  
\m \add A\add* SIDI, arr amezzuɣ nnec \add ɣari\add*,  
\m seř ayi,  
\m maɣar necc di řeɣben u zeřḍeɣ.   
\m
\v 2 Ḥḍa x řeɛmar inu,  
\m maɣar necc d amtiqqi,  
\m \add a\add* AREBBI inu,  
\m senjem amsexxar nnec,  
\m wenni xak ittcařan.   
\m
\v 3 Ḥinn xafi, \add a\add* Sidi inu,  
\m maɣar ttřaɣiɣ xak ass am imun.   
\m
\v 4 Sfarḥ řeɛmar n umsexxar nnec,  
\m maɣar i Cek, \add a\add* Sidi inu,  
\m ssgeɛɛadeɣ řeɛmar inu.   
\m
\v 5 Maɣar Cek, \add a\add* Sidi inu,  
\m d aṣebḥan u d amsameḥ,  
\m ɣarek tamexsiwt icewwaren  
\m i marra inni ɣarek ittřaɣan.   
\b  
\m
\v 6 \add A\add* SIDI, seř i tẓaǧit inu,  
\m ḥekkar i tmijja n tutra inu.   
\m
\v 7 Deg wass n řeḥṣaret inu  
\m ttřaɣiɣ-dd ɣarek,  
\m maɣar Cek ad xafi dd-tarred. \x ◘ \xo 86:7 \xt Izhd. 50:15\x*   
\m
\v 8 Jar irebbiten war iǧi uřa d ijjen  
\m am Cek, \add a\add* Sidi inu,  
\m war din min yarwesen  
\m di tmegga nni teggid. \x ◘ \xo 86:8 \xt Aɛwd. 3:24; Izhd. 136:4\x*   
\m
\v 9 Marra řegnus i teggid, ad dd-asen,  
\m ad sejden zzat i wudem nnec,  
\m \add a\add* Sidi inu,  
\m ad ssɛuǧen Isem nnec.   
\m
\v 10 Maɣar Cek d ameqqran  
\m u Cek d wenni itteggen lmuɛjizat,  
\m Cek weḥḥdek d AREBBI \add i teǧid\add*.   
\m
\v 11 Scen ayi abrid nnec, \add a\add* SIDI,  
\m \add ḥima\add* ad uyureɣ di tidett nnec,  
\m smun uř inu  
\m maḥend ad ggʷedeɣ Isem nnec. \x ◘ \xo 86:11 \xt Izhd. 25:4; 27:11; 119:33\x*   
\m
\v 12 \add A\add* Sidi inu, AREBBI inu,  
\m xseɣ ad Cek qadiɣ s marra wuř inu,  
\m ad cennɛeɣ Isem nnec i řebda qaɛ.   
\m
\v 13 Maɣar tamexsiwt nnec icewwaren  
\m temɣar xafi,  
\m Cek tfekked řeɛmar inu  
\m zi řaǧaɣ n řaxart.   
\b  
\m
\v 14 \add A\add* AREBBI,  
\m imɛeffaren kkaren-dd akidi,  
\m ict n bandiyya n ayt n bu-řexcunet  
\m arezzun ad \add nɣen\add* řeɛmar inu.  
\m Cek war ɣarsen teǧid  
\m qibač i tiṭṭawin nsen. \x ◘ \xo 86:14 \xt Izhd. 54:5\x*   
\m
\v 15 \add Maca\add* Cek, \add a\add* Sidi inu,  
\m d Arebbi d arḥim d uḥnin,  
\m ɣarek ttasiɛ n řxaḍar  
\m uřa d tamexsiwt icewwaren  
\m d řaman mɣaren. \x ◘ \xo 86:15 \xt Uf. 34:6; Řxř. 14:18; Naḥ. 9:17; Izhd. 103:8; 145:8; Yuw. 2:13\x*   
\m
\v 16 Xzar-dd ɣari u ḥinn xafi,  
\m egg jjehd nnec deg umsexxar nnec,  
\m uca senjem mmis n tayya nnec.   
\m
\v 17 Egg ict n řeɛřamet di ṭṭweɛ inu,  
\m ḥima inni d ayi icarrhen  
\m ad t ẓaren ad seḍḥan,  
\m maɣar Cek, \add a\add* SIDI, tewcid ayi afus  
\m u tessfewwjed xafi.   
\b  
\b  
\m  
\c 87
\m
\v 1 \add Azehhed, izři n ayt n Quraḥ.\add*  
\b  
\m Dsas nnes \add aqa-t\add* x idurar iqeddsen.   
\m
\v 2 SIDI ittexs tiwwura n Ṣihyun  
\m aṭṭas x marra tizeddɣin n Yaɛqub.   
\m
\v 3 Timesřayin yuɛřan qqaren xam,  
\m \add a\add* tandint n AREBBI. Silah.   
\m
\v 4 Necc ad barrḥeɣ Rahab d Babil  
\m ɣar yinni i d ayi issnen.  
\m Xzar, Filicit d wenni zi Ṣuri  
\m ak-d Ukuci ...  
\m ‘Wanita ittwaxeřqed-dd din!’   
\b  
\m
\v 5 Maca x Ṣihyun ad inin:  
\m ‘\add Ina\add* marra ttwaxeřqen-dd dayes!’,  
\m Amɛuǧi x kuřci ad tt issemten.   
\m
\v 6 SIDI ad izemmem di lista n řegnus:  
\m ‘Wanita ixřeq-dd din’. Silah.   
\m
\v 7 Nitni ttɣennajen am ceṭṭḥen:  
\m ‘Tařawin inu marra dayem!’   
\b  
\b  
\m  
\c 88
\m
\v 1 \add Izři, azehhed n ayt n Quraḥ.\add*  
\m \add I umeqqran n imeɣnajen,\add* \add s teɣnint n ‘Izři n wecḍan’ ɣar řeḥṣarat.\add*  
\m \add Axemmi n Hayman, Azraḥi.\add*   
\b  
\m
\v 2 \add A\add* SIDI, AREBBI n usenjem inu,  
\m deg wass i di dd ɣa sɣuyeɣ ɣarek  
\m s ǧiřet,   
\m
\v 3 ejj \add xenni\add* ad dd-tas tẓaǧit inu zzatek,  
\m ewc amezzuɣ nnec i uřaɣi inu.   
\m
\v 4 Maɣar řeɛmar inu ijjiwen s řmuṣibat,  
\m tudart inu tudes-dd řaxart.   
\m
\v 5 Necc ttwaḥessabeɣ am yinni dd-ihekkwan  
\m deg weḥfur \add n wenḍeř\add*,  
\m am ijj n weryaz  
\m umi war dayes jjhed \add ɛad\add*.   
\b  
\m
\v 6 Aqa ttwaḥuzeɣ jar imettan,  
\m am yinni ittwanɣen  
\m inni izzřen deg wenḍeř,  
\m inni war ten tᵉttidared \add ɛad\add*,  
\m ttwaqeḍɛen nitni zeg ufus nnec.   
\m
\v 7 Cek teggid ayi  
\m deg wenḍeř yuǧɣen qaɛ,  
\m di taǧest, di řaǧaɣ.   
\m
\v 8 Asɛar nnec idqeř xafi aṭṭas,  
\m s marra řemwaj \add n wesɛar\add* nnec  
\m tessdeǧed ayi. Silah.   
\b  
\m
\v 9 Imqarraben inu  
\m tessiggʷejed i-ten xafi,  
\m tarrid ayi d nnɛi i nitni.  
\m Ittwabelleɛ xafi,  
\m war zemmareɣ ad dd-ffɣeɣ.   
\m
\v 10 Tiṭṭ inu teɛmec s řeɣben.  
\m \add A\add* SIDI, ass marra ttřaɣiɣ ɣarek,  
\m necc sswiẓẓḍeɣ ifassen inu ɣarek.   
\b  
\m
\v 11 Ma ad tegged ict n lmuɛjiza  
\m deg imettan?  
\m Niɣ ad dd-kkaren řexyařat \add n imettan\add*,  
\m ma ad Cek qadan? Silah.   
\m
\v 12 Ma ad barrḥen  
\m s tmexsiwt nnec icewwaren  
\m deg wenḍeř, s řaman nnec  
\m di \add tesraft n\add* uhellek?   
\m
\v 13 Ma ad ttwassnent lmuɛjizat nnec  
\m di taǧest,  
\m tasegda nnec di temmurt n tattut?   
\b  
\m
\v 14 \add A\add* SIDI, necc ttřaɣiɣ Cek,  
\m taẓaǧit inu tᵉttas-dd zzatek ɣar uteffu.   
\m
\v 15 Mayemmi, \add a\add* SIDI,  
\m tneṭṭared řeɛmar inu,  
\m \add mayemmi\add* tᵉssnuffared  
\m udem nnec zzayi?   
\m
\v 16 Zi temẓi inu necc di řeɣben  
\m u ggureɣ ɣar unuri,  
\m ksiɣ isnexriɛen nnec \add ḍidd inu\add*,  
\m ttwaḥṣareɣ \add zzaysen\add*.   
\b  
\m
\v 17 Tettekk xafi řḥaduq n weɣḍab nnec,  
\m itteḥḥa ayi useggʷid nnec.   
\m
\v 18 Ass marra ittenneḍ ayi-dd am waman,  
\m ittquwwar ayi-dd marra.   
\m
\v 19 Amɛizz inu d umeddukkeř inu  
\m tessiggʷejed i-ten xafi,  
\m inni d ayi issnen inu  
\m \add aqa aten ttwařeḥḥfen\add* s taǧest.   
\b  
\b  
\m  
\c 89
\m
\v 1 \add Axemmi n Itan, Azraḥi.\add*   
\b  
\m
\v 2 Ad ɣennjeɣ x \bd tmegga\bd*  
\m \bd n tmexsiwt icewwaren n SIDI\bd* i řebda,  
\m ad barrḥeɣ \bd řaman nnec\bd*  
\m s uqemmum inu zi jjiř ař jjiř.   
\m
\v 3 Maɣar nniɣ: “\bd Tamexsiwt icewwaren\bd*  
\m tᵉttwabna i řebda,  
\m aqa tḍemned \bd řaman nnec\bd*  
\m deg ijenwan.”   
\b  
\m
\v 4 “Necc ggiɣ ijj n Řɛahd  
\m ak-d wenni zzayi ittwafarzen,  
\m jjuǧeɣ i umsexxar inu Dawud:   
\m
\v 5 ‘Necc ad ḍemneɣ zzariɛet nnec i řebda  
\m u ad bniɣ řɛarc nnec zi jjiř ař jjiř.’” Silah.   
\b  
\m
\v 6 Ijenwan ttqadan \add Cek\add*  
\m x lmuɛjiza\add t\add* nnec, \add a\add* SIDI,  
\m deg wegraw n imqeddasen  
\m \add ttqadan Cek\add* x \bd řaman nnec\bd*. \x ◘ \xo 89:6 \xt Izhd. 19:2\x*   
\m
\v 7 Maɣar man wen deg iseynuten  
\m \add izemmar\add* ad ittwaqedd ak-d SIDI,  
\m \add man wen i iǧan\add*  
\m jar warrawen n irebbiten  
\m \add izemmar\add* ad imqudda ak-d SIDI?   
\b  
\m
\v 8 Arebbi iwɛar aṭṭas  
\m deg wegraw n imqeddasen,  
\m marra inni d as dd-innḍen  
\m tteggʷeden zzayes.   
\m
\v 9 \add A\add* SIDI, AREBBI n řɛeskarat,  
\m man wen ɣar iǧa tizemmar  
\m am Cek, \add a\add* SIDi!  
\m \bd Řaman nnec\bd* ittenneḍ i Cek.   
\b  
\m
\v 10 Cek tḥekkmed x nnfaxet n řebḥar.  
\m Xmi dd-ttnekkaren řemwaj nnes,  
\m aqa Cek taressid i-ten.   
\m
\v 11 Aqa třebzed Rahab  
\m am yijjen wenni issnuqqben,  
\m tzeǧɛed řɛedyan nnec  
\m s uɣiř nnec ijehden.   
\b  
\m
\v 12 Nnec d ijenwan,  
\m nnec uřa d tammurt.  
\m Ddunit d uɛemmar nnes  
\m teggid asen dsas. \x ◘ \xo 89:12 \xt Izhd. 24:1, 2\x*   
\m
\v 13 Cek txeřqed-dd ccamal d ljanub,  
\m Tabur d Hirmun sřiwřiwen  
\m s Yisem nnec.   
\b  
\m
\v 14 Aqa ɣarek aɣiř i di \add teggid\add* taryast,  
\m afus nnec ijhed,  
\m afus afusi nnec ittwassgeɛɛad.   
\m
\v 15 Tasegda d řḥeqq  
\m aqa aten d dsas n řɛarc nnec,  
\m \bd tamexsiwt icewwaren\bd* d \bd řaman\bd*  
\m ittizwaren zzat i wudem nnec. \x ◘ \xo 89:15 \xt Aɛwd. 32:4; Izhd. 85:14; 97:2; 99:4; 145:17; Asa. 15:3\x*   
\b  
\m
\v 16 Sseɛd n řgens i issnen \add ad meyyzen\add*  
\m asuḍi s wesruddeḥ \add n řbuq\add*, \add a\add* SIDI,  
\m nitni ad uyuren di tfawt n wudem nnec.   
\m
\v 17 Nitni ad farḥen ass marra  
\m s Yisem nnec  
\m uca ad dd-ttwassgeɛɛden  
\m s tsegda nnec,   
\b  
\m
\v 18 maɣar Cek d řemřaḥet n jjehd nsen,  
\m icc nneɣ ad ittwassgeɛɛed  
\m s řxaḍar nnec.   
\m
\v 19 Taseddart nneɣ n useřqi n SIDI,  
\m ajeǧid nneɣ aqa-t n Umqeddas n Israil.   
\b  
\m
\v 20 Ict n twařa tuɣa tessiwřed di řewḥiy  
\m x Umtiqqi nnec, tennid:  
\m “S \add ufus n\add* ijj n bu-teɣruḍt ggiɣ twiza,  
\m ijj wenni ittwafarzen zi řgens  
\m ssgeɛɛdeɣ-t.   
\m
\v 21 Necc ufiɣ Dawud, amsexxar inu,  
\m dehneɣ t s zzect iqeddsen, \x ◘ \xo 89:21 \xt 1 Ṣm. 16:1, 13\x*   
\b  
\m
\v 22 maḥend afus inu ad yiři imten akides,  
\m \add wah\add* aɣiř inu ad t issemḥed.   
\m
\v 23 Řeɛdu war t issaggʷad,  
\m mmis n řmuɛṣiyyet war t iḥeṣṣar. \x ◘ \xo 89:23 \xt 2 Ṣm. 7:10; 2 Th. 2:3. \x*   
\b  
\m
\v 24 Inni t iḥeṣṣaren ad ten řebzeɣ  
\m zzat i wudem nnes,  
\m inni t icarrhen ad ten wteɣ.   
\m
\v 25 \bd Řaman inu\bd* d \bd tmexsiwt inu icewwaren\bd*,  
\m aqa aten akides \add i ɣa yiřin\add*,  
\m ad ittwassgeɛɛed yicc nnes s Yisem inu.   
\m
\v 26 Ad ssarseɣ afus nnes x řebḥar,  
\m afus nnes afusi x iɣezran.   
\b  
\m
\v 27 Netta ad xafi dd-iřaɣa:  
\m ‘Aqa Cek d Baba inu, Arebbi inu,  
\m d Taṣḍart n usenjem inu!’ \x ◘ \xo 89:27 \xt 2 Ṣm. 7:14; Ɛbr. 1:4, 5\x*   
\m
\v 28 Necc ad t ggeɣ d amenzu \add inu\add*,  
\m Amɛuǧi x ijeǧiden n temmurt. \x ◘ \xo 89:28 \xt Kul. 1:15, 18; Ɛbr. 1:6; Asa. 1:5\x*   
\b  
\m
\v 29 I řebda ad ḥḍiɣ  
\m \bd tamexsiwt inu icewwaren\bd* zzates,  
\m u Řɛahd inu ad ɣares iqqim s řmanet.   
\m
\v 30 Ad ẓẓuɣ zzariɛet nnes i řebda,  
\m řɛarc nnes min ɣa kken  
\m ussan n ujenna ǧan.   
\b  
\m
\v 31 Mařa iḥenjiren nnes ḥeyyden  
\m x Ccariɛa inu,  
\m war gguren ak-d lfarayiḍ inu, \x ◘ \xo 89:31 \xt 2 Ṣm. 7:14\x*   
\m
\v 32 mařa ssfesden tiweṣṣa inu,  
\m war ḥeṭṭin řumurat inu,   
\b  
\m
\v 33 \add xenni\add* ad xeǧṣeɣ  
\m aɛeddu nsen s weɛmud,  
\m řmuɛṣiyyet nsen s teyyita.   
\m
\v 34 \add Maca\add* war xasen ttekkseɣ  
\m \bd tamexsiwt inu icewwaren\bd*,  
\m war nekkareɣ \bd řmanet inu\bd*.   
\b  
\m
\v 35 War ttɣeṣṣabeɣ Řɛahd inu,  
\m min dd-iffɣen zeg iyencicen inu,  
\m war t ttbeddiřeɣ.   
\m
\v 36 Necc jjuǧeɣ ict n twařa  
\m ɣar tqeddast inu:  
\m ’War ssxarriqeɣ ɛemmarṣ x Dawud!’ \x ◘ \xo 89:36 \xt Ɛbr. 6:13, 17, 18\x*   
\b  
\m
\v 37 Zzariɛet nnes ad teqqim i řebda,  
\m u řɛarc nnes \add ad din ibedd\add* zzati  
\m am tfuct.   
\m
\v 38 Netta ad iqqim ibedd i řebda am tziri  
\m u acehhad deg iseynu\add ten\add*  
\m aqa-t d amtiqqi.” Silah. \x ◘ \xo 89:38 \xt Ayub 16:19-21, Dan. 7:13, Asa. 1:5, 7; Asa. 14:14\x*   
\b  
\m
\v 39 \add Maca\add* Cek tɛarrned t ɣar uɣezdis,  
\m tenḍared t,  
\m Cek tfuggmed x umedhun nnec.   
\m
\v 40 Cek tenḍared Řɛahd  
\m ak-d umsexxar nnec,  
\m tfesded ttaj \add n weɛzař\add* nnes  
\m \add s ubeǧaɛ\add* n temmurt.   
\b  
\m
\v 41 Tɣeḍřed marra řeḥyud nnes,  
\m thedmed tineddam nsen ifaryen.   
\m
\v 42 Marra inni dd-ikkin abrid keccḍen t,  
\m netta idweř d aseḥqar i jjiran nnes. \x ◘ \xo 89:42 \xt Izhd. 80:13\x*   
\b  
\m
\v 43 Cek tessgeɛɛded afus afusi  
\m n yinni t iḥeṣṣaren,  
\m tessfarrḥed marra řɛedyan nnes.   
\m
\v 44 Cek tessenqeřbed řeqḍeɛ n ssif nnes,  
\m Cek tejjid t war ittɣimi ibedd deg umenɣi.   
\b  
\m
\v 45 Cek tessbedded aẓri nnes,  
\m řkursi nnes igellden  
\m tenḍared t ɣar temmurt.   
\m
\v 46 Cek tessemẓid as ussan n temẓi nnes,  
\m tedřid t s řefḍiḥet. Silah.   
\b  
\m
\v 47 Ař meřmi ɛad, \add a\add* SIDI,  
\m ad tessnuffared Ixef nnec břa qeṭṭu,  
\m ad yarɣ wesɛar nnec am tmessi?   
\m
\v 48 Ɛqeř x řmijař n tudart inu!  
\m Mayemmi dd-txeřqed  
\m marra arraw n bnadem amenni baṭeř?   
\m
\v 49 Man aryaz ijehden war ittwiři řmewt,  
\m \add man aryaz\add* i ɣa ifekken řeɛmar nnes  
\m zeg ufus n řaxart? Silah. \x ◘ \xo 89:49 \xt Izhd. 49:10, 16\x*   
\b  
\m
\v 50 \add A\add* Sidi inu, mani ǧant  
\m \bd tmegga n tmexsiwt nnec\bd* n zic,  
\m tinni x tuɣa tejjuǧed i Dawud  
\m s \bd řmanet nnec\bd*? \x ◘ \xo 89:50 \xt 2 Ṣm. 7:15\x*   
\m
\v 51 \add A\add* Sidi inu, ɛqeř  
\m x useḥqar n imsexxaren nnec,  
\m nni arebbuɣ deg weḥsin inu  
\m zeg ubarru n marra řegnus, \f ◼ \fr 89:51 \ft \+fk aḥsin\ft  - niɣ ‘abeḥrur’.\f*   
\m
\v 52 i zi d ayi sseḥqaran  
\m řɛedyan nnec, \add a\add* SIDI,  
\m i zi sseḥqaran iṣuraf n umedhun nnec.   
\b  
\m
\v 53 Ad ittwabarek SIDI i řebda qaɛ!  
\m Amin, \add wah,\add* amin!   
\b  
\b  
\m  
\c 90
\s1 ADLIS WISS AREBƐA: IZEHHIDEN 90-106  
\m
\v 1 \add Taẓaǧit n Musa, aryaz n AREBBI.\add*  
\b  
\m \add A\add* Sidi inu,  
\m Cek tuɣa d Tazeddiɣt nneɣ  
\m zi jjiř ař jjiř. \x ◘ \xo 90:1 \xt Aɛwd. 33:1, 27\x*   
\m
\v 2 Qbeř ma ad iřin idurar,  
\m qbeř ma ad dd-tessuffɣed  
\m tammurt d ddunect,  
\m \add wah\add* aqa Cek d Arebbi  
\m zi řebda ař řebda.   
\m
\v 3 Cek tejjid bnadem  
\m ad iɛqeb ɣar tɛejjajt.  
\m Teqqared:  
\m “Ɛeqbettiw-dd tarwa n bnadem!”   
\m
\v 4 Maɣar ařef n iseggʷusa  
\m di tiṭṭawin nnec  
\m am wass n iḍennaḍ nni iɛdun,  
\m uřa am yict n \add nnubet n\add* tɛessast di ǧiřet. \x ◘ \xo 90:4 \xt 2 Bṭ. 3:8\x*   
\b  
\m
\v 5 Cek tfarḍed ten, aqa aten am yiḍeṣ.  
\m Ɣar tuffut ggin am arbiɛ iyemman.   
\m
\v 6 Ɣar tuffut ittzᵉyziw \add arrbiɛ\add*  
\m uca iyemma,  
\m ɣar tmeddit ittwamjar, ittaẓeɣ.   
\m
\v 7 Maɣar neccin nefna s weɣḍab nnec,  
\m nennexřeɛ zeg wesɛar nnec.   
\m
\v 8 Cek teggid řmuɛṣiyyet nneɣ  
\m qibač nnec,  
\m ddnub nneɣ innuffaren  
\m di tfawt n wudem nnec.   
\b  
\m
\v 9 Maɣar marra ussan nneɣ ad ɛdun  
\m deg ufugem nnec isseggʷaden,  
\m nesseɛdu iseggʷusa nneɣ  
\m am yijj n usuḍi.   
\m
\v 10 Ussan n tudart nneɣ  
\m ttekken sebɛin n iseggʷusa,  
\m niɣ, meřmi i ɣa niři nejhed,  
\m aqa tmanyin n iseggʷusa.  
\m Min dayes d aɛuǧi,  
\m \add ittaru-dd\add* tamara d řweḥran,  
\m deɣya tᵉttekk tɛeddu u neṭṭaw ɣar din.   
\m
\v 11 Man wen issnen  
\m řqesḥan n weɣḍab nnec,  
\m \add u man wen issnen\add* tiggʷudi zzayek  
\m \add am dd-ittřiq\add*  
\m ak-d aduqqez nnec \add n ufugem\add*?   
\m
\v 12 Seřmed aneɣ ad nḥesseb ussan nneɣ,  
\m ḥima ad dd-nawi uř \add iccuren s\add* tiɣit.   
\b  
\m
\v 13 Dweř-dd, \add a\add* SIDI, ař meřmi?  
\m Ḥinn x imsexxaren nnec. \x ◘ \xo 90:13 \xt Aɛwd. 32:36; Izhd. 135:14\x*   
\m
\v 14 Sjjiwen aneɣ ɣar \add u\add*teffu  
\m s tmexsiwt nnec icewwaren,  
\m \add xenni\add* ad nesřiwřew,  
\m ad nfarḥ marra ussan nneɣ.   
\m
\v 15 Sfarḥ aneɣ anect n wussan  
\m i d aneɣ teḥṣared,  
\m \add anect n\add* iseggʷusa i di neẓra řɣar.   
\m
\v 16 Scen řxedmet nnec i imsexxaren nnec,  
\m řɛezz nnec x iḥenjiren nsen.   
\m
\v 17 Ad xaneɣ tehwa  
\m řeḍrafet n Sidi, AREBBI nneɣ,  
\m ḍmen Cek řxedmet n ifassen nneɣ,  
\m \add wah\add*, řxedmet n ifassen nneɣ ḍmen i-tt.   
\b  
\b  
\m  
\c 91
\m
\v 1 \add Tmijja tamezwarut:\add*  
\m Wenni izeddɣen  
\m deg udurri n Umɛuǧi x kuřci,  
\m aqa netta ad issens  
\m di tiři n Umzemmar x kuřci.   
\b  
\m
\v 2 \add Tmijja wiss tnayen:\add*  
\m Ad iniɣ i SIDI:  
\m \add Cek\add* d amcan inu n tarewřa d lburj inu,  
\m AREBBI inu, Wenni x ttecřeɣ!   
\b  
\m
\v 3 \add Tmijja tamezwarut:\add*  
\m Maɣar Netta ad cek ifekk  
\m zi řfex n ineymaren n ijḍaḍ,  
\m zi ṭṭaɛun yareddǧen. \x ◘ \xo 91:3 \xt Izhd. 124:7\x*   
\m
\v 4 S arric nnes ad cek ideř,  
\m sadu wafriwen nnes ad tafed adurri.  
\m Řmanet nnes d taseddart tameqqrant  
\m d arruḍ n wuzzař. \x ◘ \xo 91:4 \xt Izhd. 57:2\x*   
\m
\v 5 War tᵉtteggʷeded ca  
\m zeg unexřiɛ n ǧiřet,  
\m zi fřitca n řqews i \add din\add* iṭṭawen s wass, \x ◘ \xo 91:5 \xt Ayub 5:19, 20; Awřn. 3:25; Izři 3:8\x*   
\m
\v 6 uřa zi ṭṭaɛun i dd-ittennḍen di taǧest,  
\m zi lhalak i yareddǧen s uziř.   
\m
\v 7 Waxxa ad wḍan ařef ɣar uɣezdis nnec  
\m u ɛecra ařef ɣar afus afusi nnec,  
\m \add ɛad\add* war cek dd-ittikkʷiḍ.   
\m
\v 8 Ad twařid aya s tiṭṭawin nnec waha,  
\m ad tẓared mammec ɣa ittwaxřef  
\m zeg iɛeffanen.   
\b  
\m
\v 9 \add Tmijja wiss tnayen:\add*  
\m Maɣar \add xak\add*:  
\m ‘Cek \add a\add* SIDI, aqa Cek  
\m d amcan inu n tarewřa!’  
\b  
\m \add Tmijja tamezwarut\add*  
\m Aqa cek teggid Amɛuǧi x kuřci  
\m d tazeddiɣt i yixef nnec,   
\m
\v 10 war dayek tneṭṭeḥ tuɛeffna,  
\m uřa d ict n jjriḥect  
\m war dd-tqarrab ca ɣar uqiḍun nnec,   
\m
\v 11 maɣar Netta ad xak yumur  
\m lmalakat nnes,  
\m maḥend ad cek ḥḍant  
\m di marra ibriden nnec. \x ◘ \xo 91:11 \xt Izhd. 34:8; Mt. 4:6; Lk. 4:10\x*   
\m
\v 12 Ad cek ksin x ifassen nsent,  
\m ḥima aḍar nnec war ineggeḥ aẓru. \x ◘ \xo 91:12 \xt Lk. 4:11\x*   
\m
\v 13 Ad tɛefsed x weyrad izehharen  
\m u x třefsa,  
\m ad tɛejned x weyrad ameẓyan  
\m d řhaycet \add n řebḥar\add*. \x ◘ \xo 91:13 \xt Ayub 5:22, 23\x*   
\b  
\m
\v 14 \add Tmijja wiss třata zi Arebbi:\add*  
\m Umi dd-iqqen netta ɣari,  
\m Necc ad t ssnejmeɣ.  
\m Necc ad t ssgeɛɛdeɣ,  
\m maɣar netta issen Isem inu.   
\m
\v 15 Netta ad ayi iřaɣa  
\m u Necc ad xas dd-arreɣ.  
\m Di řeḥṣaret aqa ayi ɣares.  
\m Necc ad t fekkeɣ, ad as ssɛuǧeɣ.   
\m
\v 16 Necc ad t ssjjiwneɣ  
\m ak-d tuzzeggart n wussan,  
\m Necc ad as ssecneɣ asenjem inu.   
\b  
\b  
\m  
\c 92
\m
\v 1 \add Azehhid. Ijj n izři i wass n ssebt.\add*   
\b  
\m
\v 2 Mammec iṣbeḥ  
\m maḥend ad nqada SIDI,  
\m ad nzehhed i Yisem nnec,  
\m \add a\add* Amɛuǧi x kuřci,   
\m
\v 3 maḥend ad nbarreḥ  
\m s tmexsiwt nnec icewwaren  
\m ɣar tuffut,  
\m řaman nnec di ǧyaři,   
\m
\v 4 \add di lharpa\add* s ɛecra n ifiřan u di lharpa,  
\m s \add tirart x\add* ifiřan n řgambri.   
\b  
\m
\v 5 Maɣar Cek tessfarḥed ayi,  
\m \add a\add* SIDI, s tmegga nnec,  
\m necc ad sřiweřweɣ  
\m x řefɛayeř n ifassen nnec.   
\m
\v 6 Mammec mɣarent tmegga nnec, \add a\add* SIDI,  
\m mammec uǧɣen ixarriṣen nnec!   
\m
\v 7 Ijj n uqeffuḥ war ɣares min ɣa iɛawed,  
\m ijj n ubuhaři war ifehhem man aya.   
\b  
\m
\v 8 Mařa iɛeffanen ɣemmyen am arbiɛ,  
\m u marra inni itteggen řmuɛṣiyyet  
\m ttnewwaren,  
\m \add aqa aya ad issiweḍ\add* ateḥḥi nsen  
\m i řebda qaɛ.   
\m
\v 9 Cek d Amɛuǧi x kuřci i řebda, \add a\add* SIDI!   
\m
\v 10 Maɣar xzar, řɛedyan nnec, SIDI,  
\m řɛedyan nnec ad fnan,  
\m marra inni itteggen řɣecc  
\m ad ttwazeǧɛen.   
\b  
\m
\v 11 Cek ad tessgeɛɛded accaw inu  
\m am wenni n iɣayḍ n řexřa  
\m ak-d waccawen d iziraren,  
\m ttwadehneɣ s zzect n ṭri.   
\m
\v 12 Tiṭṭ inu ad tẓar inni xafi ittcekkmen,  
\m imezzuɣen inu ad sřen i iɣrimen inu  
\m inni xafi dd-ikkaren.   
\m
\v 13 Amsegged ad inewwar  
\m am tcejjart n tini,  
\m ad iɣmi am tcejjart n tengelt  
\m x \add idurar n\add* Lubnan, \x ◘ \xo 92:13 \xt Řqḍ. 9:15; Ḥuc. 14:6\x*   
\b  
\m
\v 14 inni ittwaẓẓun di Taddart n SIDI,  
\m ad nnuwaren  
\m di řemraḥat n AREBBI nneɣ.   
\m
\v 15 Nitni ad wcen řɣiǧet di tewsar,  
\m ad qqimen ṣeḥḥen d ṭri.   
\m
\v 16 maḥend ad barrḥen,  
\m belli SIDI aqa-t nican.  
\m Netta d Taṣḍart inu  
\m u war dayes bu řɣecc.   
\b  
\b  
\m  
\c 93
\m
\v 1 SIDI iḥekkem,  
\m Netta yarḍ s lɛaḍama,  
\m SIDI yarḍ s jjehd am s yijj n uḥezzam.  
\m Wah, ddunect tbedd temten,  
\m war tᵉttenhezzi ca. \x ◘ \xo 93:1 \xt Izhd. 2:6; 24:8, 10\x*   
\b  
\m
\v 2 Řkursi igellden nnec imten  
\m zi mecḥař uya,  
\m Cek teǧid zi řebda.   
\b  
\m
\v 3 Iɣezran ssgeɛɛden, \add a\add* SIDI,  
\m iɣezran ssgeɛɛden tmijja nsen.  
\m Iɣezran ad ssgeɛɛden  
\m \add řḥess n\add* zzhir nsen.   
\b  
\m
\v 4 SIDI di řuɛřa ijhed x zzhir  
\m n waṭṭas n waman ijehden  
\m u x uhaji n řebḥar.   
\b  
\m
\v 5 Cchadat nnec aqa daysent řaman.  
\m Taqeddast tzehhej i Taddart nnec,  
\m \add a\add* SIDI, ař marra ussan.   
\b  
\b  
\m  
\c 94
\m
\v 1 \add A\add* Arebbi n untaqem, \add a\add* SIDI,  
\m Arebbi n untaqem,  
\m ban-dd di tissiqt!   
\m
\v 2 \add A,\add* Řqaḍi n temmurt, sgeɛɛed Ixef nnec,  
\m arr tasɣart i imɛeffaren  
\m am min ssdaḥeǧen nitni.   
\m
\v 3 Mecḥař i ɣa kken ɛad iɛeffanen, \add a\add* SIDI,  
\m mecḥař i ɣa kken neggzen  
\m iɛeffanen s řefraḥet,   
\b  
\m
\v 4 ad qqimen ssawařen awařen iqesḥen,  
\m \add mecḥař\add* i ɣa qqimen marra  
\m inni itteggen řmuɛṣiyyet  
\m ad ssemɣaren ixef nsen?   
\m
\v 5 \add A\add* SIDI, nitni řebbzen řgens nnec,  
\m ḥeṣṣaren tasɣart n řwart nnec.   
\m
\v 6 Nitni neqqen tajjač d ubarrani,  
\m ɣarrṣen i iyujiřen.   
\m
\v 7 Nitni qqaren: “SIDi war tt ittwiři,  
\m AREBBI n Yaɛqub war d as ittḥekkar.” \x ◘ \xo 94:7 \xt Izhd. 10:11, 13; 59:8\x*   
\b  
\m
\v 8 Fetnem kenniw iqeffuḥen di řgens,  
\m \add jmiɛ\add* ak-d ibuhařiyyen,  
\m meřmi i ɣa tdewřem tfehhmem? \x ◘ \xo 94:8 \xt Izhd. 92:7\x*   
\m
\v 9 Ma war ittesři wenni iẓẓun amezzuɣ?  
\m Ma war iẓarr wenni iggin tiṭṭ? \x ◘ \xo 94:9 \xt Uf. 4:11\x*   
\m
\v 10 Ma war ittɛaqeb  
\m wenni ittwebbxen řegnus,  
\m wenni isseřmaden tussna i bnadem?   
\m
\v 11 SIDI yareggeb x ixarriṣen n iwdan,  
\m aqa aten am yijj n usuḍi waha. \x ◘ \xo 94:11 \xt 1 Kur. 3:20\x*   
\b  
\m
\v 12 Sseɛd n weryaz nni tᵉttwebbxed, \add a\add* SIDi,  
\m wenni tesseřmaded zi Ccariɛa nnec,   
\m
\v 13 ḥima ad t tessareyyeḥed  
\m zeg wussan iɛeffnen,  
\m ař ɣa ḥfaren aḥfur n turṣuḍi i uɛeffan.   
\m
\v 14 Maɣar SIDI war ineṭṭar řgens nnes,  
\m war isemmeḥ di tesɣart nnes. \x ◘ \xo 94:14 \xt 1 Ṣm. 12:22; Rum. 11:1, 2\x*   
\m
\v 15 Maɣar řḥukm ad dd-idweř ɣar tsegda,  
\m marra inni ɣarsen uř iseggmen  
\m ad tt-i-dd-ḍeffaren.   
\b  
\m
\v 16 Man wen kidi i ɣa ibedden  
\m ḍidd i iɛeffanen?  
\m Man wen xafi i ɣa iwten  
\m ḍidd i yinni itteggen řɣecc?   
\m
\v 17 Mři war iǧi SIDI d twiza inu,  
\m iři izdeɣ řeɛmar inu ɛřaḥař  
\m deg wesɣaḍ. \f ◼ \fr 94:17 \ft \+bd asɣaḍ\+bd* - d man aya ixs ad yini ‘deg unuri’.\f*   
\m
\v 18 Mařa nniɣ: ‘Aḍar inu ittefriɣ!’,  
\m \add xenni\add* tᵉṭṭef ayi  
\m tmexsiwt nnec icewwaren, \add a\add* SIDI!   
\m
\v 19 Mařa mmarnin dayi ixarriṣen  
\m ař ṭṭarf,  
\m tuɣa řeɛmar inu ittarr meẓri  
\m deg usfewwej nnec.   
\b  
\m
\v 20 Ma \add texsed\add* ad kidek issmun  
\m řkursi n uhellek,  
\m wenni issiwḍen řeɣben  
\m x \add dsas\add* n tewṣeyyet?   
\m
\v 21 Nitni ḥeṣṣaren řeɛmar n umseggad,  
\m cehhden x idammen imezdagen s řɣar.   
\m
\v 22 SIDI tuɣa ayi d ijj n lburj yuɛřan,  
\m AREBBI inu d Taṣḍart n tarewřa inu.   
\m
\v 23 Netta ad xasen isseɛqeb  
\m řmuɛṣiyyet nsen,  
\m am tteggen řɣar nsen ad ten iteḥḥa.  
\m SIDI, AREBBI nneɣ, ad ten iteḥḥa.   
\b  
\b  
\m  
\c 95
\m
\v 1 Asem-dd, ejj aneɣ ad nesřiwřew zzat i SIDI,  
\m ejj aneɣ ad nduqqez s usřiwřew  
\m i Teṣḍart n usenjem nneɣ.   
\m
\v 2 Ejj aneɣ ad nades  
\m ɣar wudem nnes s uqadi,  
\m ejj aneɣ ad as nᵉsřiwřew s izehhiden.   
\b  
\m
\v 3 Maɣar SIDI \add d\add* ijj Arebbi d ameqqran,  
\m ijj n Ujeǧid d ameqqran  
\m sennej i marra irebbiten.   
\m
\v 4 Deg ufus nnes \add ǧan\add*  
\m imucan yuǧɣen qaɛ n temmurt,  
\m uřa d tiqiccatin n idurar  
\m \add aqa atent\add* nnes.   
\m
\v 5 Nnes řebḥar, maɣar ixřeq i-t-i-dd,  
\m u ifassen nnes ggin uřa d řbar.   
\m
\v 6 Asem-dd, ejj aneɣ  
\m ad \add as\add* nbendeq, ad nesjed,  
\m ejj aneɣ ad nesjed x ifadden zzat i SIDI,  
\m wenni d aneɣ iggin,   
\m
\v 7 maɣar Netta d AREBBI nneɣ  
\m u neccin d řgens n tarewsa nnes,  
\m uřa d uǧi n ufus nnes.  
\m Mařa ass-a tseǧem ɣar tmijja nnes, \x ◘ \xo 95:7 \xt Izhd. 100:3; Ɛbr. 3:7, 13, 15; 4:7\x*   
\m
\v 8 war sseqsiḥem ca uř nwem,  
\m am di Mariba,  
\m am deg wass n Massa di řexřa, \x ◘ \xo 95:8 \xt Uf. 17:7; Řxř. 20:1, 3, 13; Aɛwd. 6:16\x*   
\m
\v 9 mani tuɣa d ayi ttjarrben  
\m řejdud nwem,  
\m qeǧben ayi,  
\m waxxa tuɣa ẓrin řxedmet inu. \x ◘ \xo 95:9 \xt Ɛbr. 3:9\x*   
\m
\v 10 Arebɛin n iseggʷusa  
\m tuɣa ttɛiffeɣ jjiř-a, nniɣ:  
\m “Aqa-ten d ijj n řgens  
\m s wuř iweddaren,  
\m war ssinen ibriden inu.”\x ◘ \xo 95:10 \xt Ɛbr. 3:9, 10, 17\x*   
\m
\v 11 S uyenni Necc jjuǧeɣ  
\m deg weɣḍab inu:  
\m “Nitni war dd-ttidfen ɛemmarṣ  
\m di arraḥet inu!” \x ◘ \xo 95:11 \xt Ɛbr. 3:11, 18; 4:3, 5\x*   
\b  
\b  
\m  
\c 96
\m
\v 1 Ɣennjem i SIDI ijj n yezři amaynu,  
\m ɣennjem i SIDI, marra tammurt! \x ◘ \xo 96:1 \xt 1 Im. 16:23-33\x*   
\m
\v 2 Ɣennjem i SIDI, barkem Isem nnes,  
\m beccarem i usenjem nnes ass x wass.   
\m
\v 3 Barrḥem aɛuǧi nnes jar řegnus,  
\m řeɛjayeb nnes jar marra řegnus.   
\b  
\m
\v 4 Maɣar SIDI d ameqqran,  
\m issdaḥeǧ asemɣar aṭṭas,  
\m Netta d amsaggʷed  
\m mahu marra irebbiten.   
\m
\v 5 Minzi marra irebbiten n řegnus  
\m aqa aten d l’aṣnam,  
\m \add maca\add* SIDI igga ijenwan.   
\m
\v 6 Tissiqt d řɛezz \add ǧan\add* zzat i wudem nnes,  
\m jjehd d waẓri aqa aten  
\m di Zzawect nnes Iqeddsen.   
\b  
\m
\v 7 Wcem i SIDI, \add a,\add* tiqebbař n řegnus,  
\m wcem i SIDI aɛuǧi d jjehd.   
\m
\v 8 Wcem i SIDI aɛuǧi n Yisem nnes,  
\m awyem-dd tawhibt,  
\m asem-dd ɣar řemraḥat nnes,   
\m
\v 9 bendeq zzat i SIDI  
\m s ucewwar iqeddsen,  
\m arjijem zzat i wudem nnes,  
\m \add a\add* marra tammurt! \x ◘ \xo 96:9 \xt Izhd. 29:2\x*   
\b  
\m
\v 10 Inim jar řegnus: “SIDI iḥekkem!”  
\m Nican, \add řexxu\add* ddunect tbedd temten,  
\m war ttenhezzi \add ɛad\add*.  
\m Netta ad iḥkem řegnus s řḥeqq.   
\m
\v 11 Ejj ijenwan ad farḥen  
\m u tammurt ad tarceq,  
\m ejj ad izhar řebḥar d uɛemmar nnes,   
\b  
\m
\v 12 ejj ad isřiwřiw yeyyar s řefraḥet  
\m s marra min dayes,  
\m xenni ad sřiwřiwent  
\m marra tcejjura n wezɣar \f ◼ \fr 96:12 \ft \+fk azɣar\ft  - niɣ ‘řɣabet’ niɣ ‘tazgant’.\f*   
\m
\v 13 zzat i wudem n SIDI,  
\m maɣar Netta ad dd-yas,  
\m maɣar Netta ad dd-yas  
\m ḥima ad icarreɛ tammurt.  
\m Netta ad icarreɛ ddunect s tsegda  
\m u řegnus s řḥeqq nnes. \x ◘ \xo 96:13 \xt Izhd. 98:9; Asa. 19:11\x*   
\b  
\b  
\m  
\c 97
\m
\v 1 SIDI iḥekkem,  
\m ejj tammurt ad tfarḥ,  
\m ad arecqent marra tegzirin. \x ◘ \xo 97:1 \xt Izhd. 93:1; 96:10\x*   
\m
\v 2 Quwwaren as iseynuten  
\m d yijj n useynu ibbumbes,  
\m tasegda d řḥeqq  
\m aqa aten d dsas n řɛarc nnes.   
\m
\v 3 Timessi teggur as  
\m zzat n wudem nnes,  
\m tqedd iɣrimen nnes  
\m i d as dd-ittennḍen.   
\b  
\m
\v 4 Assamen nnes ssřaqqan ddunect,  
\m tammurt tẓarr i-tt, tenhezza. \x ◘ \xo 97:4 \xt Izhd. 77:17; Asa. 4:5\x*   
\m
\v 5 Idurar fessyen am ccmeɛ  
\m zzat i wudem n SIDI,  
\m zzat i wudem n Sidi n marra tammurt.   
\m
\v 6 Ijenwan ttbarrḥen tasegda nnes,  
\m marra řegnus ttwařan aɛuǧi nnes. \x ◘ \xo 97:6 \xt Izhd. 19:2; 50:6\x*   
\b  
\m
\v 7 Ejj ad seḍḥan marra inni ɛebbden  
\m i \add řexyařat\add* ineqcen n ukeccuḍ,  
\m marra inni ittcennɛen di l’aṣnam.  
\m Bendqem zzates, kenniw,  
\m marra irebbiten!   
\m
\v 8 Ṣihyun isřa, ifarḥ,  
\m yessis n Yahuda arecqent,  
\m zi ssibbet n řeḥkamat nnec, \add a\add* SIDI.   
\b  
\m
\v 9 Maɣar Cek, \add a\add* SIDI,  
\m d Amɛuǧi x marra tammurt,  
\m Cek d wenni yuɛřan qaɛ  
\m x marra irebbiten.   
\b  
\m
\v 10 Kenniw i ittexsen SIDI, carhem řɣar.  
\m Netta iḥeṭṭa x řeɛmur n imtiqqan nnes,  
\m Netta ittfekka i-ten zeg ufus n iɛeffanen. \x ◘ \xo 97:10 \xt Ɛam. 5:15; Rum. 12:9\x*   
\m
\v 11 Tafawt tᵉttwazarɛ i umsegged,  
\m řefraḥet i yinni ɣar iǧa uř iseggmen.   
\m
\v 12 \add Kenniw\add* imseggaden, farḥem zi SIDI,  
\m qadam xmi tᵉttidarem taqeddast nnes.   
\b  
\b  
\m  
\c 98
\m
\v 1 \add Azehhid.\add*  
\b  
\m Ɣennjem i SIDI ijj n yezři n jdid,  
\m maɣar Netta igga lmuɛjizat.  
\m Afus nnes afusi d uɣiř nnes iqeddsen  
\m ssnejmen t.   
\b  
\m
\v 2 SIDI isscen asenjem nnes,  
\m issargeb tasegda nnes  
\m zzat i tiṭṭawin n řegnus.   
\m
\v 3 Netta iɛqeř x tmexsiwt nnes icewwaren,  
\m x řaman nnes i taddart n Israil.  
\m Marra tineggura n temmurt ẓrint asenjem  
\m s \add ufus n\add* n AREBBI nneɣ.   
\b  
\m
\v 4 Duqqzem s usřiwřew i SIDI,  
\m marra tammurt,  
\m sɣuyyem, sřiweřwem, zehhdem.   
\m
\v 5 Zehhdem i SIDI s řgambri,  
\m s řgambri u s tmijja n yezři,   
\m
\v 6 s řebwaq d řḥess n usuḍi  
\m deg uyicc n icarri.  
\m Duqqzem s usřiwřew  
\m zzat i wudem n ujeǧid, SIDI.   
\b  
\m
\v 7 Ejj ad izhar řebḥar  
\m d marra aɛemmar nnes,  
\m ddunect d yinni dayes izeddɣen.   
\m
\v 8 Ejj iɣezran ad wten camxa s ifassen,  
\m idurar ad ssřiwřewen \add jmiɛ\add*   
\m
\v 9 zzat i wudem n SIDI,  
\m maɣar Netta ad dd-yas  
\m ḥima ad iḥkem tammurt.  
\m Netta ad iḥkem tammurt s tsegda,  
\m řegnus s řḥeqq.   
\b  
\b  
\m  
\c 99
\m
\v 1 SIDI iḥekkem, ejj ad arjijen řegnus.  
\m Netta iqqim \add x\add* ikiruben,  
\m tammurt tebda ad tenhezz. \f ◼ \fr 99:1 \ft \+fk ikiruben\ft  - ict n marka n lmalakat.\f*   
\m
\v 2 SIDI d ameqqran di Ṣihyun,  
\m Netta yuɛřa aṭṭas x marra řegnus.   
\m
\v 3 Ejj i-ten ad qadan  
\m Isem nnec ameqqran issaggʷaden,  
\m \add ad inin\add*: “Aqa Netta d amqeddas!”   
\b  
\m
\v 4 Jjehd n ujeǧid aqa netta ittexs řḥeqq.  
\m Cek teggid amcan imten i tsegda,  
\m teggid řḥeqq d tsegda di Yaɛqub.   
\m
\v 5 Sɛuǧem SIDI, AREBBI nneɣ,  
\m bendqem zzat i tnebdat  
\m n iḍaren nnes.  
\m Aqa Netta d amqeddes!   
\b  
\m
\v 6 Musa d Harun \add tuɣa aten\add*  
\m zeg ikehhanen nnes,  
\m Camwil \add tuɣa\add* zeg inni iřaɣan Isem nnes.  
\m Nitni řaɣan ɣar SIDI  
\m uca Netta isřa asen.   
\m
\v 7 Issiweř akidsen zeg uqellij n useynu.  
\m Nitni ḥḍan cchadat nnes,  
\m uřa d tiweṣṣa nnes nni d asen iwca.   
\m
\v 8 \add A\add* SIDI, AREBBI nneɣ, Cek tesřid asen.  
\m Cek d ijj n Arebbi iɣeffaren,  
\m \add maca\add* uřa d umtaqem x tmegga nsen.   
\m
\v 9 Sɛuǧem SIDI, AREBBI nneɣ,  
\m bendqem \add as\add* zzat i wedrar nnes iqeddsen,  
\m maɣar SIDI, AREBBI nneɣ,  
\m d amqeddes \add i iǧa\add*.   
\b  
\b  
\m  
\c 100
\m
\v 1 \add Izři n uqadi.\add*  
\b  
\m Ejj ad tᵉdduqqez marra tammurt  
\m s usřiwřew i SIDI.   
\m
\v 2 Sexxarem i SIDI s řefraḥet,  
\m asem-dd zzat i wudem nnes s usřiwřew.   
\m
\v 3 Snem, aqa SIDI d AREBBI \add i yeǧa\add*.  
\m Netta ixřeq aneɣ-dd  
\m u neccin nnes \add i neǧa\add*,  
\m řgens nnes d wuǧi n tarewsa nnes. \x ◘ \xo 100:3 \xt Izhd. 95:7; Ḥiz. 34:30,31\x*   
\b  
\m
\v 4 Adfem tiwwura nnes s uqadi,  
\m řemraḥat nnes s izřan n uṣebbeḥ,  
\m qadam t, barkem Isem nnes.   
\m
\v 5 Maɣar SIDI d aṣebḥan,  
\m tamexsiwt nnes icewwaren  
\m \add tᵉttɣima\add* i řebda,  
\m řaman nnes zi jjiř ař jjiř.   
\b  
\b  
\m  
\c 101
\m
\v 1 \add Azehhed n Dawud.\add*  
\b  
\m Necc ad ɣennjeɣ  
\m x tmexsiwt icewwaren d řḥeqq,  
\m ad zehhdeɣ i Cek, \add a\add* SIDI!   
\m
\v 2 Necc ad ggeɣ s řeɛqeř  
\m ɛlaḥsab ijj n webrid ikemmřen.  
\m Meřmi ɣari i dd ɣa tased?  
\m Necc ad uyureɣ s wuř nican  
\m di řwesṭ n taddart inu,   
\m
\v 3 Necc war neṭṭareɣ tiṭṭawin inu  
\m di min ifeḍḥen.  
\m Necc carrheɣ min tteggen  
\m inni xak iḥeyyden  
\m \add man aya\add* war d ayi iřeṣṣeq.   
\m
\v 4 Uř ittefriɣen ittxeṣṣa  
\m ad xafi yaggʷej,  
\m war xseɣ ad ssneɣ min war iḥřin.   
\m
\v 5 Wenni iceqqfen  
\m deg jjar nnes s tnuffra,  
\m ad t teḥḥiɣ.  
\m Wenni ittkebbaren s tiṭṭawin nnes  
\m d wenni ittɛeffaren s wuř nnes,  
\m war t kessiɣ.   
\m
\v 6 Tiṭṭawin inu \add arezzunt\add*  
\m x imtiqqan di temmurt,  
\m ḥima nitni ad ɣari qqimen.  
\m Wenni igguren  
\m deg ijj n webrid ikemmřen,  
\m ad ayi isexxar.   
\m
\v 7 Wenni itteggen řɣecc,  
\m war ittɣimi di taddart inu,  
\m uřa d bu-ixarriqen war ittwaḍmen  
\m zzat i tiṭṭawin inu.   
\m
\v 8 Kuř ṣṣbeḥ ad teḥḥiɣ  
\m marra iɛeffanen zi temmurt,  
\m ḥima \add ammu i\add* ɣa mḥiɣ marra  
\m inni itteggen řmuɛṣiyyet  
\m zi tendint n SIDI.   
\b  
\b  
\m  
\c 102
\m
\v 1 \add Taẓaǧit n ijj n řmesksin mařa manayenni d aṭṭas xas,\add* \add uca xenni ittfarreɣ imunas nnes zzat i SIDI.\add*   
\b  
\m
\v 2 \add A\add* SIDI, seř ɣar tẓaǧit inu,  
\m ejj aɣuyyi inu ad ɣarek dd-yaweḍ.   
\m
\v 3 War tteffar udem nnec xafi  
\m deg wass i di ttwaḥṣareɣ.  
\m Arr-dd ɣari amezzuɣ nnec  
\m deg wass i di řaɣiɣ,  
\m seř-dd \add xenni\add* ɣari deɣya.   
\b  
\m
\v 4 Minzi ussan inu ɛdun am ddexxan,  
\m ixsan inu am tefqunt icemḍen. \x ◘ \xo 102:4 \xt Izhd. 37:20\x*   
\m
\v 5 Uř inu ittisřaw u yuẓeɣ am arbiɛ,  
\m ařami ttuɣ ad cceɣ aɣrum inu.   
\m
\v 6 Zi ssibbet n uzehhar yuǧɣen inu,  
\m řeṣqen iɣsan inu ɣar teřmect inu.   
\b  
\m
\v 7 Necc am yijj bu-uɛuqqi n ujḍiḍ  
\m di řexřa,  
\m dewřeɣ am yijj n muka jar řxirbat.   
\m
\v 8 Ttɣimeɣ faqeɣ s řeftanet,  
\m dewřeɣ am yijj n wejḍiḍ  
\m i iqqimen weḥḥdes x tzeqqa.   
\m
\v 9 Řɛedyan inu ttekkwaren ayi ass marra.  
\m Inni xafi ittɛeddan,  
\m neɛɛřen am qqaren isem inu.   
\b  
\m
\v 10 Maɣar ttᵉtteɣ iɣɣeḍ am weɣrum  
\m u xeǧḍeɣ tisessit inu s imeṭṭawen \add inu\add*   
\m
\v 11 zi ssibbet n wesxeḍ nnec  
\m d uduqqez n weɣḍab nnec,  
\m maɣar Cek tessgeɛɛded ayi  
\m u tenḍared ayi \add ɛawed\add* ɣar temmurt.   
\m
\v 12 Ussan inu am yict n tiři izzuggarten,  
\m u necc taẓɣeɣ am tuga.   
\b  
\m
\v 13 \add Maca\add* Cek, \add a\add* SIDI,  
\m ad teqqimed \add x řkursi nnek\add* i řebda,  
\m zi jjiř ař jjiř ad dayek xarrṣen.   
\m
\v 14 Cek ad tekkared ad tarḥmed x Ṣihyun,  
\m maɣar aqa d řweqt  
\m maḥend ad xas tḥinned,  
\m minzi řweqt ittwaggen  
\m aqa tiweḍ-dd.   
\m
\v 15 Maɣar iẓra nnes usin-dd  
\m x řxaḍar n imsexxaren nnec  
\m u nitni ksin s wesḥissef di tɛejjajt nsen.   
\b  
\m
\v 16 Řegnus ad ggʷeden Isem n SIDI,  
\m marra ijeǧiden n temmurt  
\m \add ad ggʷeden\add* aɛuǧi nnec.   
\m
\v 17 Xmi ɣa ibna SIDI Ṣihyun  
\m \add twařat nneɣnit\add*,  
\m ad dd-iban deg uɛuǧi nnes.   
\m
\v 18 Ad iřha ak-d tẓaǧit n umezřuḍ,  
\m war isseḥqara ca taẓaǧit nsen.   
\b  
\m
\v 19 Man aya ittwari i jjiř i dd ɣa yasen,  
\m řgens nni dd ɣa ittwaxeřqen,  
\m ad iṣebbeḥ i SIDi,   
\m
\v 20 maɣar Netta aqa issijj-dd  
\m zi Zzawect nnes Iqeddsen yuɛřan,  
\m zeg ujenna ixzar-dd SIDI  
\m ɣar temmurt swadday   
\m
\v 21 ḥima ad iseř aweɛɛeḍ n umeḥbus,  
\m ḥima ad yarxu  
\m i yinni \add iǧan d\add* tarwa n řmewt,   
\m
\v 22 maḥend ad barrḥen  
\m s Yisem n SIDI di Ṣihyun,  
\m d ccenɛet nnes di Urcalim,   
\m
\v 23 xmi dinni i ɣa ttwassmunen řegnus,  
\m \add jmiɛ\add* ak-d tgeldiwin,  
\m ḥima ad sexxaren i SIDI.   
\b  
\m
\v 24 Netta issarxu jjehd inu ak-d webrid,  
\m Netta issemẓi deg wussan inu.   
\m
\v 25 Necc nniɣ: ‘War d ayi kessi  
\m deg wezyen n wussan \add n tudart\add* inu, \add a\add* Arebbi,  
\m aqa iseggʷusa nnec \add ttɣiman\add* zi jjiř ař jjiř.   
\m
\v 26 Zeg wecḥař uya teggid dsas i temmurt,  
\m ijenwan d řxedmet n ifassen nnec. \x ◘ \xo 102:26 \xt Ɛbr. 1:10\x*   
\m
\v 27 Ina ad fnan, maca Cek ad tdumed.  
\m Nitni marra ad arcan am warruḍ,  
\m Cek ad ten tbeddřed  
\m am yict n řeɛbayet,  
\m \add ammu i\add* ɣa ttwabeddřen. \x ◘ \xo 102:27 \xt Ɛbr. 1:10-12 \x*   
\m
\v 28 Cek \add maca\add* d Cek,  
\m iseggʷusa nnec war qeṭṭin ɛemmarṣ.’ \x ◘ \xo 102:28 \xt Ɛbr. 1:12b\x*   
\m
\v 29 Iḥenjiren n imsexxaren nnec  
\m ad \add din\add* zedɣen  
\m u tarwa nsen ad ttwassmetnen  
\m zzat i wudem nnec.   
\b  
\b  
\m  
\c 103
\m
\v 1 \add N Dawud.\add*  
\b  
\m Barek SIDI, \add a\add* řeɛmar inu,  
\m d marra min dayi Isem nnes iqeddsen.   
\m
\v 2 Barek SIDI, \add a\add* řeɛmar inu,  
\m war ttᵉttu ɛemmarṣ  
\m marra timegga nnes iṣebḥen.   
\m
\v 3 \add Netta\add* d wenni d ac iɣeffaren  
\m marra ddnub nnec,  
\m wenni issgenfan marra řehřacat nnec, \x ◘ \xo 103:3 \xt Ɛbr. 6:5\x*   
\m
\v 4 wenni ifdin tudart nnec zi turṣuḍi,  
\m wenni xak iggin ttaj  
\m n tmexsiwt icewwaren d arreḥmet,   
\m
\v 5 wenni issjjawanen aqemmum nnec  
\m s min iṣebḥen,  
\m wenni ittarran temẓi nnec am ugider.   
\b  
\m
\v 6 SIDI ittegg tasegda d řḥeqq  
\m i marra inni ittwaḥeṣṣaren.   
\m
\v 7 Netta isscen i Musa ibriden nnes,  
\m i ayt n Israil timegga nnes.   
\m
\v 8 SIDI d arḥim d aḥnin,  
\m ɣares ttasiɛ n řxaḍar,  
\m iccur s tmexsiwt icewwaren. \x ◘ \xo 103:8 \xt Uf. 34:6; Řxř. 14:18; Aɛwd. 5:10; Naḥ. 9:17; Izhd. 86:15; 145:8; Irm. 32:18\x*   
\m
\v 9 Netta war ittemcubbuc i řebda,  
\m war ittɣimi \add ittxeyyiq\add* i řebda. \x ◘ \xo 103:9 \xt Ica. 57:16; Ica. 3:5\x*   
\m
\v 10 Netta war d aneɣ ittegg  
\m ɛlaḥsab ddnub nneɣ  
\m u war zzayneɣ ixeǧef  
\m ɛlaḥsab řmuɛṣiyyet nneɣ,   
\b  
\m
\v 11 maɣar am ujenna yuɛřan x temmurt,  
\m ammu i temɣar  
\m tmexsiwt nnes icewwaren  
\m tiwa marra inni t itteggʷeden.   
\m
\v 12 Am iggʷej ccarq x řɣarb,  
\m ammu i issiggʷej Netta  
\m ixeṭṭan nneɣ xaneɣ.   
\m
\v 13 Am mammec iḥinn babatsen  
\m x iḥenjiren nnes,  
\m ammu i ittḥinn SIDI x yinni t itteggʷeden.   
\m
\v 14 Maɣar Netta issen mammec nettwagg,  
\m iɛqeř aqa neccin d acař.   
\b  
\m
\v 15 Ussan n bnadem amecnaw tuga,  
\m netta ittnuwar am tnuwwact n yeyyar. \x ◘ \xo 103:15 \xt Ayub 14:1, 2; Izhd. 90:5, 6; Yaɛ. 1:10, 11; 1 Bṭ. 1:24\x*   
\m
\v 16 Mařa ikka-dd xas usemmiḍ, war teqqim  
\m u amcan mani tuɣa tbedd,  
\m war xas issin ɛad.   
\m
\v 17 \add Maca\add* tamexsiwt icewwaren n SIDI  
\m tᵉttɣima zi řebda ař řebda  
\m tiwa yinni t itteggʷeden,  
\m u tasegda nnes \add tᵉttɣima\add*  
\m i warraw n warraw,   
\m
\v 18 i marra inni iḥeṭṭan Řɛahd nnes  
\m u iɛeqqřen x řumurat nnes,  
\m maḥend ad zzaysen tteggen. \x ◘ \xo 103:18 \xt Aɛwd. 7:9\x*   
\b  
\m
\v 19 SIDI issbedd řɛarc nnes deg ujenna,  
\m Tagelda nnes tḥekkem x marra \add min iǧan\add*.   
\m
\v 20 Barkent SIDI, \add kennint\add*, lmalakat nnes,  
\m ayt n bu-teɣruḍt imeḥḍen  
\m inni itteggen awař nnes,  
\m inni ittesřan i tmijja n wawař nnes.   
\m
\v 21 Barkent SIDI, marra řɛeskarat nnes,  
\m \add kenniw,\add* imsexxaren nnes,  
\m inni itteggen min d as yarecqen! \x ◘ \xo 103:21 \xt Amz. 32:1; 1 Ij. 22:19; Afa. 3:10; Kul. 1:16\x*   
\m
\v 22 Barkem SIDI,  
\m \add a\add* marra min ittwaggen \add s ufus nnes\add*,  
\m di mani ma i teǧa řeḥkamet nnes.  
\m Barek SIDI, \add a\add* řeɛmar inu.   
\b  
\b  
\m  
\c 104
\m
\v 1 Barek SIDI, \add a\add* řeɛmar inu!  
\m \add A\add* SIDI, AREBBI inu,  
\m mammec d ameqqran Cek!  
\m Cek tyarḍed s lɛaḍama d řɛezz.   
\m
\v 2 Netta iřeḥḥef Ixef nnes s tfawt  
\m am s ijj n upartessu,  
\m Netta ittbezzeɛ ajenna  
\m am tjartiřt n uqiḍun. \x ◘ \xo 104:2 \xt Amz. 1:6; Ayub 26:7\x*   
\m
\v 3 \add Aqa Netta\add* d wenni issarsen  
\m tiḥenya n wesqef  
\m sadu ixxamen nnes x waman,  
\m d wenni iggin iseynuten  
\m d akarru nnes,  
\m d wenni igguren  
\m x wafriwen n usemmiḍ, \x ◘ \xo 104:3 \xt Izhd. 18:11; Ica. 19:1; Asa. 14:14\x*   
\m
\v 4 d wenni iggin lmalakat nnes  
\m am yisemmiḍen  
\m u imsexxaren nnes  
\m d ict n tmessi itteḥduduqen. \x ◘ \xo 104:4 \xt Ɛbr. 1:7\x*   
\b  
\m
\v 5 Netta issbedd tammurt x dsusa nnes,  
\m war tᵉttenhezzi ɛemmarṣ i řebda. \x ◘ \xo 104:5 \xt Ayub 26:7; 38:4, 5, 6; Izhd. 24:2; 78:69\x*   
\m
\v 6 Cek třeḥḥfed as s \add waman\add* ihewřen  
\m am s yijj n warruḍ,  
\m aman bedden tiwa i idurar.   
\m
\v 7 Nitni arewřen zeg usiggʷed nnec,  
\m qeǧqen ad ffɣen zi tmijja n wajjaj nnec.   
\m
\v 8 Ttwassgeɛɛden idurar,  
\m hekkwant teysarin  
\m deg wemcan i d asen teggid.   
\m
\v 9 Cek teggid aymir i waman  
\m nni war ɛeddun,  
\m war dd-dekkwiřen  
\m maḥend ad dřen tammurt.   
\b  
\m
\v 10 \add Cek\add* d wenni ineddhen  
\m tařawin di teɣzurin,  
\m aqa ttazzřent din jar idurar.   
\m
\v 11 Aqa warrdent marra řmař n yeyyar,  
\m iɣyař n řexřa ttekksen afadi nsen zzaysent.   
\m
\v 12 Ijḍaḍ n ujenna zeddɣen  
\m ɣar temmawin nsen,  
\m zi jar řefruɛ tᵉttekk-dd tmijja nsen.   
\m
\v 13 \add Netta aqa\add* d wenni ittessun idurar  
\m zeg ixxamen nnes deg ujenna,  
\m tammurt tᵉttyawan  
\m zi řɣiǧet \add i dd-iffɣen\add* zi min teggid Cek. \f ◼ \fr 104:13 \ft \+fk ixammen nnes deg ujenna\ft  - s Tɛibranit ‘ixammen nnes n nnej’.\f*   
\m
\v 14 Netta igga arbiɛ iɣemmi i řmar,  
\m uřa d aɣemmuy di ṭṭweɛ n bnadem.  
\m \add Igga i-tt\add* maḥend ad dd-yawi  
\m aɣrum zi temmurt   
\m
\v 15 u binu nni issfarraḥen uř n bnadem.,  
\m ařami iɣembab ad \add zzayes\add* wessgen  
\m mahu zi zzect,  
\m uřa d aɣrum nni issejhed uř n bnadem.   
\m
\v 16 Ticejjura n SIDI ttyawanent,  
\m ticejjura n tengelt n Lubnan  
\m nni iẓẓu Netta,   
\m
\v 17 mani tteggen ijḍaḍ řɛucc nsen,  
\m \add mani\add* i teǧa taddart n ubellarj  
\m di tcejjura n umerzi. \f ◼ \fr 104:17 \ft \+fk amerzi\ft  - niɣ ‘ameḍzi’.\f*   
\m
\v 18 Idurar yuɛřan aqa aten  
\m i iɣayḍen n tṣuḍar,  
\m řejruf d amcan n tarewřa  
\m i ikawkawen n teṣḍart.   
\b  
\m
\v 19 Netta igga taziri d řeɛbar  
\m i řewqat ittwaggen,  
\m tafuct tessen meřmi i ɣa teɣři.   
\m
\v 20 Cek tessekkid-dd taǧest  
\m u tewḍa-dd ǧiřet  
\m \add i di\add* ttextutyen  
\m marra řewḥuc n wezɣar. \f ◼ \fr 104:20 \ft \+fk azɣar\ft  - niɣ ‘řɣabet’ niɣ ‘tazgant’.\f*   
\m
\v 21 Ayraden imeẓyanen  
\m zehharen x zzardet,  
\m arezzun x macca nsen zi Arebbi. \x ◘ \xo 104:21 \xt Ayub 38:39,40; Ica. 31:4\x*   
\m
\v 22 Mařa teffeɣ-dd \add xenni\add* tfuct,  
\m ttecruruden ɣar řmargeḥ,  
\m ttɣemmaren deg ifran nsen.   
\m
\v 23 \add Xenni\add* itteffeɣ bnadem  
\m ɣar řxedmet nnes,  
\m ɣar tewwuri nnes ař tameddit.   
\b  
\m
\v 24 Mammec aṭṭas i teggid, \add a\add* SIDI,  
\m s tiɣit i teggid marra timesřayin,  
\m tammurt tᵉttwaccur s wagřa nnec.   
\m
\v 25 Aqa din řebḥar imɣar,  
\m yiriw ɣar marra iɣezdisen nnes,  
\m mani issfuffey marra s imuddaren  
\m imeqqranen d imeẓyanen,  
\m břa řeḥsab,   
\m
\v 26 mani gguren iɣarruba,  
\m \add uřa d\add* ‘Liviyatan’ nni teggid  
\m ḥima ad dayes ittirar.   
\b  
\m
\v 27 Nitni marra ttrajan Cek,  
\m ad asen tewced macca nsen  
\m di řweqt nnes. \x ◘ \xo 104:27 \xt Izhd. 145:15\x*   
\m
\v 28 \add Mařa\add* tewcid asen, yarrwen nitni,  
\m \add mařa\add* tarzmed afus nnec,  
\m ddakkwařen jjiwnen s řxar.   
\m
\v 29 \add Mařa\add* teffared udem nnec,  
\m aqa ttnexřaɛen,  
\m \add mařa\add* tkessid asen nnefs,  
\m ad ssuffɣen buḥbeř  
\m uca ad dd-dewřen ɣar ucař nsen. \x ◘ \xo 104:29 \xt Izhd. 30:8\x*   
\m
\v 30 \add Mařa\add* tessekked-dd Arruḥ nnec,  
\m \add xenni\add* ttwaxeřqen-dd nitni,  
\m ad tarrid aɣembub n temmurt d amaynu.   
\b  
\m
\v 31 Aɛuǧi n SIDI ad yiři i řebda,  
\m SIDI ad ifarḥ i marra min igga.   
\m
\v 32 \add Mařa\add* Netta ixezzar  
\m di temmurt, tᵉttarjiji,  
\m \add mařa\add* iḥada idurar, ad duxxnen.   
\m
\v 33 Necc xseɣ ad ɣennjeɣ i SIDI  
\m min ɣa kkeɣ ddareɣ,  
\m ad zehhdeɣ i AREBBI inu  
\m min \add da\add* i ɣa kkeɣ ǧiɣ. \x ◘ \xo 104:33 \xt Izhd. 63:5; 146:2\x*   
\m
\v 34 Axemmem inu ad dd-yas  
\m x řxaḍar nnes,  
\m ad farḥeɣ di SIDI.   
\m
\v 35 Imednab ad ttwateḥḥan qaɛ  
\m zi temmurt,  
\m iɛeffanen war ttiřin ɛad.  
\m Barek SIDI, \add a\add* řeɛmar inu. Hallilu-Yah!   
\b  
\b  
\m  
\c 105
\m
\v 1 Qadam SIDI,  
\m řaɣam x Yisem nnes,  
\m barrḥem s tmegga nnes jar řegnus. \x ◘ \xo 105:1 \xt 1 Im. 16:8-22\x*   
\m
\v 2 Ɣennjem as, zehhdem i Netta,  
\m siwřem x marra lmuɛjizat nnes.   
\m
\v 3 Cennɛem ixef nnec  
\m s Yisem nnes iqeddsen,  
\m ḥima uř n yinni yarezzun SIDI, ad ifarḥ. \x ◘ \xo 105:3 \xt Izhd. 34:3\x*   
\m
\v 4 Seqsam x SIDI d jjehd nnes,  
\m arzum udem nnes řebda.   
\m
\v 5 Ɛeqřem x lmuɛjizat nnes i igga,  
\m x řeɛřamet nnes  
\m u x řeḥkamat n uqemmum nnes.   
\m
\v 6 Zzariɛet n Ibrahim, amsexxar nnes,  
\m ayt n Yaɛqub, inni zzayes ittwafarzen!   
\b  
\m
\v 7 Netta d SIDI, AREBBI nneɣ.  
\m Řeḥkamat nnes \add i dd-ittasen\add*  
\m x temmurt marra.   
\m
\v 8 Ɛeqřem x Řɛahd nnes i řebda,  
\m awař nni iweṣṣa i wařef n jjiřat,   
\m
\v 9 i igga ak-d Ibrahim,  
\m u \add issemten i-t s\add* tjaǧit nnes i Isḥaq.   
\m
\v 10 Netta igga i-t d tawṣeyyet i Yaɛqub,  
\m i Israil \add igga i-t\add* d Řɛahd i řebda, \x ◘ \xo 105:10 \xt Amz. 28:13; 35:11; 1 Im. 16:17\x*   
\m
\v 11 umi inna:  
\m “Ad ac wceɣ tammurt n Kenɛan,  
\m afiřu \add n řeɛbar\add* n tesɣart nwem!” \x ◘ \xo 105:11 \xt Amz. 13:15; 15:18\x*   
\b  
\m
\v 12 umi tuɣa kenniw deg ijj n wuru n yeryazen,  
\m s drus \add waha\add*,  
\m u am yibarraniyyen \add i teǧim\add* dayes. \x ◘ \xo 105:12 \xt 1 Im. 16:19\x*   
\m
\v 13 Nitni telɛen zi řgens ɣar řgens \add nneɣni\add*,  
\m zeg ict n tgeldit ɣar ijj n řgens nneɣni.   
\m
\v 14 War ijji uřa d ijj n bnadem  
\m ad ten isseḥṣar,  
\m iɛaqeb ijeǧiden di ṭṭweɛ nsen. \x ◘ \xo 105:14 \xt Amz. 35:5\x*   
\m
\v 15 War ttḥadam ca imedhunen inu,  
\m war tteggem řɣar deg inabiyyen inu.   
\b  
\m
\v 16 \add Xenni\add* iřaɣa-dd i řaẓ ɣar temmurt.  
\m Yarẓa asen marra řeɛweč n weɣrum. \f ◼ \fr 105:16 \ft \+fk řeɛweč n weɣrum\ft  - s lḥarf: ‘azeǧaḍ n weɣrum’.\f*   
\m
\v 17 Issekk-dd ijj n weryaz ɣar zzat,  
\m Yusuf immenz d ismeɣ. \x ◘ \xo 105:17 \xt Amz. 37:27,35; 45:5\x*   
\m
\v 18 Carfen iḍaren nnes deg iceddiyyen,  
\m řeɛmar nnes ittwaḥṣar deg wuzzař. \f ◼ \fr 105:18 \ft \+fk ittwaḥṣar deg wuzzař\ft  - s Tɛibranit ‘yusa-dd wuzzař’.\f*   
\m
\v 19 Ař řweqt nni di ittwasseqfeř  
\m wawař nnes  
\m iṣeffa as řhard n SIDI.   
\m
\v 20 Issekk ujeǧid \add ijj\add* ḥima ad as issarxu,  
\m řḥakem n řegnus iḍřeq i-t.   
\m
\v 21 Netta igga i-t d bab x taddart nnes,  
\m uřa d řḥakem x marra min ɣares. \x ◘ \xo 105:21 \xt Amz. 41:40\x*   
\m
\v 22 ḥima ad ɣares icedd řḥukkam  
\m u \add ḥima\add* ad isseřmed tiɣit i imɣaren nnes.   
\m
\v 23 \add Awarni aya\add* yusa-dd Israil ɣar Miṣra,  
\m iqqim Yaɛqub am ubarrani  
\m di temmurt n Ḥam.   
\m
\v 24 Netta igga řɣiǧet di řgens nnes aṭṭas,  
\m yarra i-t ijhed x yinni t iḥeṣṣaren. \x ◘ \xo 105:24 \xt Uf. 1:7, 9\x*   
\b  
\m
\v 25 Netta yarra uř nsen inneqřeb,  
\m ařami dewřen carrhen řgens nnes,  
\m dewřen ɣeddaren imsexxaren nnes. \x ◘ \xo 105:25 \xt Uf. 1:9, 10, 12\x*   
\m
\v 26 \add Xenni\add* issekk-dd Musa, amsexxar nnes,  
\m d Harun wenni ifarz i-t Netta. \x ◘ \xo 105:26 \xt Uf. 3:10; 4:12\x*   
\m
\v 27 Nitni ggin řeɛřamat nsen ifarzen jar asen,  
\m u \add ggin\add* lmuɛjizat di temmurt n Ḥam. \x ◘ \xo 105:27 \xt Uf. 7:9\x*   
\m
\v 28 Netta issekk-dd taǧest  
\m uca tedweř marra d taǧest.  
\m Nitni war ɣewwɣen ca x wawařen nnes.   
\m
\v 29 Netta yarra aman nsen d idammen  
\m u inɣa iseřman nsen. \x ◘ \xo 105:29 \xt Uf. 7:17, 18, 20; Asa. 16:3, 4\x*   
\m
\v 30 Netta yarra tammurt nsen  
\m tseffay s iqarqriwen,  
\m ař daxeř deg ixxamen n ijeǧiden nsen.   
\m
\v 31 Netta issiweř uca yusa-dd  
\m weyřaf n ibeɛɛac,  
\m nnamus \add wḍan-dd\add*  
\m x temmurt nsen marra.   
\m
\v 32 Netta yarra anẓar nsen d abrurri,  
\m \add issekk-dd\add* timessi d iceɛɛařen  
\m x temmurt nsen.   
\m
\v 33 Netta iwta tazayart nsen d wartu nsen,  
\m yarẓa ticejjura di temmurt nsen.   
\m
\v 34 Netta issiweř, \add xenni\add* tusa-dd tmuɣri,  
\m uřa d bu-weřsaḥ, aqa aten břa řeḥsab.   
\m
\v 35 Nitni ccin marra afsu di temmurt nsen,  
\m ccin řɣiǧet n temmurt nsen.   
\m
\v 36 Netta inɣa marra imenza  
\m di temmurt nsen,  
\m imenza n marra taryast nsen. \x ◘ \xo 105:36 \xt Izhd.78:51\x*   
\m
\v 37 Netta issuffeɣ i-ten-dd  
\m s nnuqart d wureɣ,  
\m war din tuɣi uřa d ijj  
\m di tqebbař nsen i inderfen.   
\m
\v 38 Miṣra tfarḥ s wuffuɣ nsen,  
\m maɣar tewḍa xasen tiggʷudi temɣar. \x ◘ \xo 105:38 \xt Uf. 12:33\x*   
\b  
\m
\v 39 Netta ibezzeɛ aseynu am yijj n arwaq  
\m u tmessi ḥima ad tewc tafawt s ǧiřet.   
\m
\v 40 Nitni ẓẓuǧen u Netta yarra  
\m ad dd-asen ijḍaḍ, qqaren as ‘tsalwa’,  
\m issjjiwen i-ten s weɣrum n ujenna.   
\m
\v 41 Netta yarzem taṣḍart,  
\m aman duqqzen-dd zzayes,  
\m uzzřen x řaẓaɣ \add u dewřen\add* am yeɣzar.   
\m
\v 42 Maɣar Netta iɛqeř  
\m x wawař nnes iqeddsen,  
\m x umsexxar nnes Ibrahim. \x ◘ \xo 105:42 \xt Amz. 15:14\x*   
\m
\v 43 Netta issuffeɣ-dd řgens nnes  
\m s řefraḥet,  
\m inni zzayes ittwafarzen s usřiwřew. \x ◘ \xo 105:43 \xt Uf. 14:8; Řxř. 33:3\x*   
\m
\v 44 Netta iwca asen timmura n řegnus,  
\m nitni warten tamara n ccuɛub,   
\m
\v 45 ḥima ad ṭṭfen di tweṣṣa nnes,  
\m ad ḥḍan izerfan nnes. Hallilu-Yah. \x ◘ \xo 105:45 \xt Uf. 19:4, 5, 6; Aɛwd. 4:1, 40; 6:21, 22, 23, 24, 25\x*   
\b  
\b  
\m  
\c 106
\m
\v 1 Hallilu-Yah, qadam SIDI,  
\m maɣar Netta iṣbeḥ,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda. \x ◘ \xo 106:1 \xt 1 Im. 16:34-36; Izhd. 107:1; 118:1; 136:1\x*   
\m
\v 2 Wi izemmaren ad iḥaja  
\m timegga timeqqranin n SIDI,  
\m ad ibarreḥ marra ccan nnes?   
\m
\v 3 Sseɛd nsen i yinni iḥḍan řḥeqq,  
\m \add sseɛd nnes\add* i wenni itteggen  
\m řebda tasegda.   
\m
\v 4 Ɛqeř xafi, \add a\add* SIDI,  
\m s arḍa ɣar řgens nnec,  
\m ɛahed ayi s usenjem nnec,   
\m
\v 5 maḥend ad ẓareɣ řxar  
\m i yinni zzayek ittwafarzen,  
\m maḥend ad farḥeɣ  
\m s řefraḥet n řgens nnec,  
\m maḥend ad farḥeɣ s yixef inu  
\m \add jmiɛ\add* ak-d tesɣart nnec.   
\b  
\m
\v 6 Neccin nexḍa, \add jmiɛ\add*  
\m ak-d řejdud nneɣ,  
\m negga řɣecc,  
\m negga tuɛeffna. \x ◘ \xo 106:6 \xt Lawi 26:40; Irm. 3:25; Dan. 9:5\x*   
\m
\v 7 Řejdud nneɣ di Miṣra war fhimen  
\m i lmuɛjizat nnec,  
\m war xarrṣen deg ufeyyeḍ n tmegga  
\m n tmexsiwt nnec icewwaren,  
\m maca ɣewwɣen ɣar řebḥar,  
\m ɣar Řebḥar n Telga. \x ◘ \xo 106:7 \xt Uf. 14:11, 12\x*   
\m
\v 8 \add Maca\add* Netta issenjem i-ten  
\m di ṭṭweɛ n Yisem nnes,  
\m ḥima ad tᵉttwassen řemɣaret nnes. \x ◘ \xo 106:8 \xt Uf. 9:16\x*   
\m
\v 9 Netta iwebbex Řebḥar n Telga  
\m ařami idweř yuẓeɣ,  
\m uca ijja i-ten ad kken  
\m \add x wudem n temmurt\add*  
\m \add jar\add* \add waman\add* ihewřen axmi \add di\add* řexřa. \x ◘ \xo 106:9 \xt Uf. 14:21, 22, 29\x*   
\m
\v 10 Netta ifekk i-ten zeg ufus  
\m n yinni \add i-ten\add* icarrhen,  
\m ifekk i-ten zeg ufus n řeɛdu.   
\m
\v 11 Aman dřin inni ten iḥeṣṣaren,  
\m war iqqim uřa d ijjen zzaysen. \x ◘ \xo 106:11 \xt Uf. 14:27; 15:5\x*   
\m
\v 12 Nitni ttecřen x wawařen nnes,  
\m ṣebbḥen as s yijj n yezři n uṣebbeḥ. \x ◘ \xo 106:12 \xt Uf. 14:31; 15:1\x*   
\b  
\m
\v 13 \add Maca\add* ttun deɣya timegga nnes,  
\m war xsen ad rajan \add ɛad\add* ccwar nnes.   
\m
\v 14 Nitni dewřen ttmeɣɣřen aṭṭas di řexřa,  
\m qeǧben Arebbi di tnezruft. \x ◘ \xo 106:14 \xt Uf. 16:3; Řxř. 11:4, 6, 33; Izhd. 78:18; 1 Kur. 10:6\x*   
\m
\v 15 \add Xenni\add* iwca asen min ttaren,  
\m \add maca\add* issemẓi \add řqedd n\add* řeɛmur nsen. \x ◘ \xo 106:15 \xt Řxř. 11:20,33; Izhd. 78:30,31; Ica. 10:16\x*   
\m
\v 16 Nitni dewřen usmen zi Musa  
\m di řmargeḥ n řɛeskar,  
\m uřa zi Harun, amqeddes n SIDI. \x ◘ \xo 106:16 \xt Řxř. 16\x*   
\m
\v 17 Tammurt tennurzem, tṣarḍ Datan,  
\m uca tentiy abarru n Abiram. \x ◘ \xo 106:17 \xt Řxř. 16:31,32,33; Aɛwd. 11:6\x*   
\m
\v 18 Timessi tebda tecmeḍ jar ubarru nsen,  
\m ijj n uceɛɛař n tmessi  
\m iqqed iɛeffanen \add nni\add*. \x ◘ \xo 106:18 \xt Řxř. 16:35,46\x*   
\m
\v 19 Nitni ggin ijj n uɛejmi ɣar Ḥurib,  
\m bendqen i yijj n řexyař ifesyen. \x ◘ \xo 106:19 \xt Uf. 32:4\x*   
\m
\v 20 Nitni beddřen aɛuǧi n SIDI  
\m ak-d řexyař n ijj n ufunas  
\m i ittetten arbiɛ. \x ◘ \xo 106:20 \xt Irm. 2:11; Rum. 1:22-23\x*   
\m
\v 21 Ttun Arebbi, Amsenjem nsen,  
\m wenni tuɣa iggin  
\m timegga timeqqranin di Miṣra,   
\m
\v 22 lmuɛjizat di temmurt n Ḥam,  
\m timegga ssaggʷadent  
\m ɣar Řebḥar n Telga.   
\m
\v 23 Inna aqa ad ten ikeḥḥeḍ,  
\m mři war iǧi d Musa,  
\m wenni zzayes ittwafarzen,  
\m ikkar-dd di txenduqt zzat i wudem nnes  
\m di ṭṭweɛ nsen,  
\m maḥend ad issbeɛɛed asɛar nnes  
\m i zi ixs ad ten yareddeǧ. \x ◘ \xo 106:23 \xt Uf. 32:11,32; Aɛwd. 9:13, 14; 10:10\x*   
\b  
\m
\v 24 Nitni kksen taqcurt  
\m x temmurt iɛizzen,  
\m war tecřen ca x wawař nnes. \x ◘ \xo 106:24 \xt Řxř. 14:1, 2\x*   
\m
\v 25 Nitni ndeqmen deg iqiḍan nsen,  
\m war sřin ɣar tmijja n SIDI.   
\m
\v 26 Netta issgeɛɛed afus nnes xasen,  
\m \add ijjuǧ\add* ad ten isseɣḍeř di řexřa, \x ◘ \xo 106:26 \xt Řxř. 14:28\x*   
\m
\v 27 maḥend ad isseɣḍeř tarwa nsen  
\m jar řegnus,  
\m maḥend ad ten izeǧeɛ di temmura. \x ◘ \xo 106:27 \xt Izhd. 44:12; Ḥiz. 20:23\x*   
\m
\v 28 Nitni ssřeḥmen ixef nsen  
\m ɣar Baɛal-Faɣur,  
\m ccin tiɣarṣa i imettan. \x ◘ \xo 106:28 \xt Řxř. 25:3; 31:16; Asa. 2:14\x*   
\m
\v 29 Sɛaren t s tmegga nsen,  
\m ařami dd xasen tewḍa jjriḥect.   
\m
\v 30 \add Xenni\add* ikkar-dd Finaḥas,  
\m yusa-dd jar asen,  
\m u ammu i tᵉttwassbedd jjriḥect.   
\m
\v 31 Aya ittwaḥseb as-dd d tasegda,  
\m zi jjiř ař jjiř i řebda.   
\m
\v 32 Nitni sɛaren afugem nnes  
\m ɣar waman n Mariba,  
\m ařami igga Musa řɣar di ssibbet nsen, \x ◘ \xo 106:32 \xt Řxř. 20:12; Izhd. 95:8\x*   
\m
\v 33 maɣar ssarezgen řeɛmar nnes,  
\m ɣares ařami iffeɣ wawař war iḍbiɛen  
\m zeg iyencicen nnes.   
\b  
\m
\v 34 Nitni war teḥḥan řegnus  
\m ɛlaḥsab min d asen yumur SIDI.   
\m
\v 35 \add Maca\add* ṣṣuren ixef nsen ak-d řegnus  
\m řemden \add ad ggen\add* min ggin nitni. \x ◘ \xo 106:35 \xt Řqḍ. 2:2; 3:5, 6\x*   
\m
\v 36 Nitni tuɣa ttsexxaren  
\m i řexyařat n l’aṣnam nsen,  
\m inni d asen idewřen d řfex.   
\m
\v 37 Nitni iwyen iḥenjiren nsen  
\m d tḥenjirin nsen d taɣarṣt i ccwaṭen. \x ◘ \xo 106:37 \xt Lawi 18:21; Aɛwd. 12:31; 2 Ij. 16:3; 17:17; 21:6; 2 Im. 28:3; 33:6\x*   
\m
\v 38 Nitni ssizzřen idammen imezdagen,  
\m idammen n iḥenjiren nsen  
\m d tḥenjirin nsen,  
\m nni iwyen d taɣarṣt  
\m i řexyařat n l’aṣnam n Kenɛan,  
\m ařami tedweř temmurt tefsed  
\m s idammen. \x ◘ \xo 106:38 \xt Řxř. 35:33\x*   
\m
\v 39 Nitni dewřen xemjen zi tmegga nsen,  
\m ssfesden ixef nsen s řexdayem nsen.   
\m
\v 40 Yarɣa weɣḍab n SIDI x řgens nnes  
\m u Netta iɛiff tasɣart nnes.   
\m
\v 41 Netta isellem i-ten  
\m ɣar ifassen n řegnus  
\m u inni ten icarrhen dewřen ttseǧaḍen xasen.   
\m
\v 42 Ḥṣaren ten řɛedyan nsen,  
\m nitni ttwasswaḍɛen sadu afus nsen.   
\m
\v 43 Aṭṭas n twařawin tuɣa ittfekka i-ten,  
\m \add maca\add* nitni ssarezgen xas  
\m s tɣennant nsen,  
\m ttwassmeẓyen s řmuɛṣiyyet nsen.   
\m
\v 44 \add Waxxa amenni\add* Netta ixzar \add ɛad\add* ɣarsen  
\m umi ten tuɣa di řeḥṣaret,  
\m umi isřa tɣuyyit nsen.   
\m
\v 45 Yidar Řɛahd nnes di ṭṭweɛ nsen  
\m u indem zi ssibbet  
\m n tmexsiwt nnes icewwaren.   
\m
\v 46 Isscen asen arreḥmet \add nnes\add*  
\m zzat i wudem n marra  
\m inni ten iḥebbsen.   
\m
\v 47 Senjem aneɣ, \add a\add* SIDI, AREBBI,  
\m ndeh aneɣ nmun zi řegnus,  
\m ḥima ad nqada Isem amqeddas nnec,  
\m ad Cek nṣebbeḥ s yezřan n usemɣar. \x ◘ \xo 106:47 \xt 1 Im. 16:35\x*   
\b  
\m
\v 48 Ad ittwabarek SIDI, AREBBI n Israil,  
\m zi řebda ař řebda!”  
\b  
\m Ejj marra řgens ad yini:  
\m ‘Amin! Hallilu-Yah!’ \x ◘ \xo 106:48 \xt 1 Im. 16:36\x*   
\b  
\b  
\m  
\c 107
\s1 ADLIS WISS XEMSA: IZEHHIDEN 107-150  
\m
\v 1 Qadam SIDI,  
\m maɣar Netta iṣbeḥ,  
\m maɣar tamexsiwt nnes icewwaren  
\m \add tᵉttɣima\add* i řebda.   
\m
\v 2 Ejj inni ittwafekken n SIDI  
\m ad ssiwřen ammu,  
\m inni ifekk zeg ufus  
\m n yinni \add ten\add* iḥeṣṣaren, \f ◼ \fr 107:2 \ft \+fk ittwafekken ... ifekk\ft  - niɣ ‘ittwafdin ... ifdi’. Xzar Izhd. 78:35.\f*  \x ◘ \xo 107:2 \xt Izhd. 35:9; Izhd. 63:2, 3; Ica. 49:12; 56:18; 62:12; \x*   
\m
\v 3 inni issmun zi temmura,  
\m zi ccarq, zi řɣarb, zi ccamal  
\m u zi řebḥar. \x ◘ \xo 107:3 \xt Izhd. 106:47; Aɛwd. 30:4, 5 \x*   
\b  
\m
\v 4 \add Tuɣa din\add* inni iweddaren di řexřa,  
\m abrid \add nsen\add* ikka x tnezruft,  
\m war ufin tandint  
\m maḥend ad dayes zedɣen.   
\m
\v 5 Daysen řaẓ d ufadi,  
\m řeɛmar nsen ifceř daysen.   
\m
\v 6 \add Xenni\add* sɣuyen ɣar SIDI di řeḥṣaret nsen,  
\m \add u\add* Netta ifekk i-ten zi tiggʷudi nsen.   
\m
\v 7 Netta indeh i-ten  
\m deg ijj n webrid isegged,  
\m maḥend ad uyuren ɣar ict n tendint  
\m ḥima ad \add dayes\add* zedɣen.   
\m
\v 8 Ejj i-ten ad qadan SIDI  
\m x tmexsiwt nnes icewwaren,  
\m x lmuɛjizat nnes i tarwa n bnadem.   
\m
\v 9 Maɣar Netta issjjiwen řeɛmar iffuden,  
\m řeɛmar iǧuẓen iccur i-t s řxar.   
\b  
\m
\v 10 \add Tuɣa din\add* inni iqqimen  
\m di taǧest d tiři n řmewt,  
\m s iceddiyen n ddeǧ d wuzzař,   
\m
\v 11 maɣar ɣewwɣen  
\m ak-d wawařen n Arebbi,  
\m war sřin ɣar ccwar  
\m n Umɛuǧi x kuřci.   
\m
\v 12 Netta isseqneɛ uř nsen s tamara,  
\m nnderfen, war ufin wi ɣa iwcen afus.   
\m
\v 13 \add Xenni\add* řaɣan i SIDI di řeḥṣaret nsen  
\m u Netta issenjem i-ten  
\m zi tiggʷudi nsen,   
\m
\v 14 Netta issuffeɣ i-ten zi taǧest  
\m u zi tiři n řmewt,  
\m yarẓa iceddiyen nsen.   
\m
\v 15 Ejj i-ten ad qadan SIDI  
\m x tmexsiwt nnes icewwaren,  
\m x lmuɛjizat nnes i tarwa n bnadem.   
\m
\v 16 Maɣar Netta yarẓa tiwwura n nnḥas,  
\m icarreg zzekrunat n wuzzař.   
\b  
\m
\v 17 \add Tuɣa din\add* ibuhařiyyen inni ittwaɣezzan  
\m zi ssibbet n uxeṭṭu nsen d řmuɛṣiyyet nsen.   
\m
\v 18 Iɛiff řeɛmar nsen zi marra macca,  
\m iwḍen ař tewwura n řmewt.   
\m
\v 19 \add Xenni\add* řaɣan i SIDI di řeḥṣaret nsen  
\m u Netta issenjem i-ten zi tiggʷudi nsen.   
\m
\v 20 Netta issekk awař nnes,  
\m issgenfa i-ten u issenjem i-ten  
\m zeg iḥufar nsen.   
\m
\v 21 Ejj i-ten ad qadan SIDI  
\m x tmexsiwt nnes icewwaren,  
\m x lmuɛjizat nnes i tarwa n bnadem.   
\m
\v 22 Ejj i-ten ad awyen tiwhibin n uqadi,  
\m ad barrḥen timegga nnes s usřiwřew. \x ◘ \xo 107:22 \xt Lawi 7:12; Izhd. 50:14\x*   
\b  
\m
\v 23 \add Tuɣa din\add* inni ihekkwan  
\m ɣar řebḥar s iɣarruba,  
\m inni ixeddmen x waman iwesɛen. \x ◘ \xo 107:23 \xt Asa. 18:17\x*   
\m
\v 24 Ẓrin min igga SIDI,  
\m uřa d lmuɛjizat nnes di řaǧaɣ \add n řebḥar\add*.   
\m
\v 25 Mařa Netta issiweř,  
\m ikkar-dd ijj n usemmiḍ  
\m nni issgeɛɛden řemwaj nnes.   
\m
\v 26 Geɛɛden ɣar ujenna  
\m uca hwan ɣar tisi n \add waman\add* ihewřen.  
\m Ifsi řeɛmar nsen zi tiggʷudi.   
\m
\v 27 Meyyřen, meyyřem  
\m zi ssa ɣar da am umescar,  
\m iweddar asen marra řeɛqeř nsen.   
\m
\v 28 \add Xenni\add* řaɣan i SIDI di řeḥṣaret nsen  
\m \add u\add* Netta issuffeɣ i-ten-dd  
\m zi tiggʷudi nsen.   
\m
\v 29 Netta yarra asemmiḍ ad yarsa,  
\m ařami dewřen řemwaj sseɣḍen.   
\m
\v 30 Nitni farḥen umi arsin \add řemwaj\add*  
\m u \add umi\add* Netta indeh i-ten  
\m ɣar řmuyyi i ɣares tuɣa ttmeẓriyen.   
\m
\v 31 Ejj i-ten ad qadan SIDI  
\m x tmexsiwt nnes icewwaren,  
\m x lmuɛjizat nnes i tarwa n bnadem,   
\m
\v 32 ejj i-ten ad t ssɛuǧen  
\m deg wegraw n řgens,  
\m ad t cennɛen di řḥeřqet n imɣaren.   
\b  
\m
\v 33 Netta yarra iɣezran d řexřa,  
\m řɛunṣarat \add yarra i-tent\add*  
\m d tammurt iffuden,   
\m
\v 34 tammurt i itticen řɣiǧet  
\m \add yarra i-tt\add* d tameǧaḥt,  
\m zi ssibbet n tuɛeffna  
\m n yinni dayes izeddɣen.   
\m
\v 35 Netta yarra řexřa  
\m d ayeřmam n waman,  
\m tammurt yuẓɣen d řɛunṣarat.\x ◘ \xo 107:35 \xt Ica. 41:18\x*   
\m
\v 36 Dinni i issezdeɣ inni iǧuẓen  
\m uca \add din\add* ssbedden \add nitni\add* ict n tendint  
\m maḥend ad \add dayes\add* zedɣen.   
\m
\v 37 Nitni zarrɛen deg iyyaren,  
\m tteẓẓun tizayarin deg imarjaɛen,  
\m tinni dd-ittawyen igumma  
\m d řɣiǧet \add nsen\add*.   
\m
\v 38 Netta ibarek i-ten,  
\m \add ařami\add* dewřen deg waṭṭas,  
\m agřa n řmař nsen war ittwassemẓi.   
\b  
\m
\v 39 \add Xenni\add* maca dakkwařen di drus \add ɛawed\add*,  
\m hekkwan ɣar řaǧaɣ  
\m zi ssibbet n řeḥṣaret  
\m d řeɣben d wecḍan.   
\m
\v 40 Netta ittkebba aseḥqar  
\m x tarwa n taṣiřet,  
\m ijja i-ten ttᵉtliɛen di řexřa  
\m mani war \add ǧin\add* ibriden. \x ◘ \xo 107:40 \xt Ayub. 12:24\x*   
\m
\v 41 Issgeɛɛed-dd amezřuḍ zi řeɣben  
\m uca yarra řaǧat am tḥimarin n wuǧi. \x ◘ \xo 107:41 \xt 1 Ṣm. 2:8; Izhd. 113:7, 8\x*   
\m
\v 42 Inni igguren nican ttwařan  
\m uca farrḥen,  
\m \add maca\add* marra \add ayt n\add* řmuɛṣiyyet  
\m tteqqnen aqemmum \add nsen\add*. \x ◘ \xo 107:42 \xt Ayub 5:16; 22:19\x*   
\b  
\m
\v 43 Wenni d amiɣis, ejj i-t ad iḥḍa,  
\m ejj i-ten ad ssnen nican  
\m timegga n tmexsiwt n SIDI.   
\b  
\b  
\m  
\c 108
\m
\v 1 \add Izři. Azehhed n Dawud.\add*   
\b  
\m
\v 2 \add A\add* AREBBI, uř inu iɛewweř,  
\m ad ɣennjeɣ ad zehhdeɣ,  
\m \add wah\add* uřa d aɛuǧi inu.   
\m
\v 3 Faq, lharpa d řgambri!  
\m Necc xseɣ ad ssfaqeɣ tafawt n řefjar.   
\b  
\m
\v 4 Necc ad Cek qadiɣ jar řegnus, \add a\add* SIDI,  
\m ad ak zehhdeɣ jar ccuɛub.   
\m
\v 5 Maɣar tamexsiwt nnec icewwaren  
\m \add tᵉttakkwaḍ\add* tiwa i ijenwan,  
\m řaman nnec ař iseynuten. \x ◘ \xo 108:5 \xt Izhd. 36:6; 57:11\x*   
\m
\v 6 \add A\add* AREBBI, sgeɛɛed ixef nnec  
\m tiwa i ijenwan,  
\m \add arr\add* aɛuǧi nnec x marra tammurt,   
\b  
\m
\v 7 ḥima imɛizzen nnec ad ttwanejmen,  
\m awi asenjem s ufus afusi nnec  
\m u arr-dd xaneɣ \add awař\add*.   
\b  
\m
\v 8 AREBBI tuɣa issawař  
\m di Zzawect nnes Iqeddsen,  
\m s uyenni i ɣa negzeɣ s řefraḥet.  
\m Necc ad bḍiɣ Cakim,  
\m ad ɛebbareɣ taysart n Sukkut.   
\m
\v 9 Jilɛad inu, Manassa inu,  
\m Ifrayim d aseřqi ijehden n uzeǧif inu,  
\m Yahuda d amgewwed inu.   
\m
\v 10 Maca Mu’ab d ssarij inu n usird,  
\m x Idum ad nḍareɣ sandaliyat inu,  
\m x \add temmurt n\add* Filicit  
\m ad duqqzeɣ s usřiwřew.   
\b  
\m
\v 11 Wi d ayi ɣa inedhen  
\m \add ɣar\add* tendint ifaryen?  
\m Wi d ayi ɣa igewwden ɣar Idum?   
\m
\v 12 Ma war d aneɣ tenḍared, \add a\add* AREBBI,  
\m u ak-d řɛeskarat nneɣ ma \add zeɛma\add*  
\m war dd-teffiɣed \add ɛad\add* akidsen,  
\m \add a\add* AREBBI? \x ◘ \xo 108:12 \xt Izhd. 60:3\x*   
\m
\v 13 Ewc aneɣ afus  
\m \add ḥima ad aneɣ tessnejmed\add* zi řeḥṣaret,  
\m \add maɣar\add* asenjem \add s ufus n\add* yijj n bnadem  
\m aqa ibḍeř.   
\m
\v 14 Ak-d AREBBI ad negg s wemḥaḍ  
\m u Netta ad iɛfes x yinni d aneɣ iḥeṣṣaren.   
\b  
\b  
\m  
\c 109
\m
\v 1 \add I umeqqran n imeɣnajen. Azehhed n Dawud.\add*  
\b  
\m \add A\add* AREBBI n uṣebbeḥ inu, war sɣidi!   
\m
\v 2 Maɣar aqemmum n ijj n uɛeffan,  
\m aqa aqemmum \add iccur s\add* ixarriqen  
\m innurzem xafi.  
\m Nitni ssawařen akidi  
\m s yijj n yiřes issxarriqen.   
\m
\v 3 Nnḍen ayi-dd  
\m s wawařen iccuren s wecrah,  
\m ttmenɣan akidi x walu. \x ◘ \xo 109:3 \xt Izhd. 69:5\x*   
\m
\v 4 I twarrit x tmexsiwt inu,  
\m ccetcan nitni zzayi  
\m u necc kessiɣ s řmeɛruf.   
\m
\v 5 Nitni xeǧṣen ayi řxar s řɣar,  
\m tamexsiwt inu s wecrah.   
\b  
\m
\v 6 Egg xas ijj n uɛeffan,  
\m ejj ijj n cciṭan ad ibedd  
\m ɣar uɣezdis nnes. \x ◘ \xo 109:6 \xt Zak. 3:1, 2\x*   
\m
\v 7 Mařa xas carrɛen,  
\m ad iffeɣ am uqṭaṭɛi  
\m uca ejj taẓaǧit nnes ad tiři d ddenb. \x ◘ \xo 109:7 \xt Awřn. 15:8; 28:9\x*   
\m
\v 8 Ad dewřen ussan nnes udrusen,  
\m ejj wenneɣni ad iṭṭef řfusina nnes. \x ◘ \xo 109:8 \xt Řex. 1:20\x*   
\m
\v 9 Ad dewřen iḥenjiren nnes d iyujiřen,  
\m tamɣart nnes d tajjač.   
\m
\v 10 Ad tellɛen iḥenjiren nnes da d diha,  
\m ad ttaren, ad arzun x macca  
\m ɣar řaggʷaj n řxirbat \add n tzeddiɣin\add* nsen.   
\b  
\m
\v 11 Ad ittar bu-umarwas marra min ɣares,  
\m ad keccḍen ibarraniyyen  
\m \add řɣiǧet n\add* warber nnes.   
\m
\v 12 War ɣares ittiři uřa d ijjen  
\m wenni d as i ɣa iggin  
\m s tmexsiwt icewwaren,  
\m ejj uřa d ijj ad iḥinn  
\m x iyujiřen nnes.   
\m
\v 13 Ad ttwateḥḥan tarwa nnes awarni as,  
\m ad ittwamḥa isem nsen  
\m di jjiř i dd ɣa yasen.   
\m
\v 14 Ad yidar SIDI řmuɛṣiyyet n řejdud nnes,  
\m ɛemmarṣ war imeḥḥi ddenb n yemmas.   
\m
\v 15 Iři ad bedden řebda qibač i SIDI,  
\m ejj i-t ad ikkes řidaret nsen x temmurt. \x ◘ \xo 109:15 \xt Ayub 18:17; Izhd. 34:17\x*   
\b  
\m
\v 16 Maɣar netta war iɛqiř  
\m ḥima ad yegg s tmexsiwt icewwaren,  
\m \add maca\add* imarret řmeskin d umezřuḍ,  
\m uřa d wenni umi ittwarẓ wuř,  
\m ḥima ad t ineɣ.   
\m
\v 17 Netta tuɣa ittexs nneɛřet,  
\m \add xenni\add* ejj i-tt ad xas tewḍa,  
\m u umi war ifarḥ s lbaraka,  
\m ejj i-tt ad xas tiggʷej.   
\m
\v 18 Umi yarḍ nneɛřet am warruḍ nnes,  
\m ejj i-tt ad tadef \add xenni\add*  
\m am waman ɣar daxeř nnes,  
\m am zzect deg iɣsan nnes.   
\m
\v 19 Ejj ad tiři \add nneɛřet nni\add*  
\m am warruḍ i di ittřeḥḥef,  
\m am webyas i ibekkes řebda.   
\m
\v 20 Ta d řmunet n SIDI i iɣrimen inu,  
\m i yinni issawařen řɣar x řeɛmar inu.   
\b  
\m
\v 21 \add Maca\add* Cek, \add a\add* SIDI, Sidi inu,  
\m egg dayi \add am mammec texsed\add*  
\m di ṭṭweɛ n Yisem nnec,  
\m maɣar tamexsiwt nnec icewwaren  
\m d taṣebḥant,  
\m fekk ayi.   
\m
\v 22 Maɣar necc di řeɣben u zeřḍeɣ,  
\m uř inu ittwassnuqqeb  
\m ɣar daxeř \add deg idmaren inu\add*.   
\m
\v 23 Am ict n tiři izzuggarten qeṭṭiɣ,  
\m zzruzan ayi am yict n tmurɣi.   
\m
\v 24 Ifadden inu ttarjijin s uẓummi,  
\m arrimet inu d tamusriwt,  
\m ittxeṣṣa i-tt tadunt.   
\m
\v 25 Necc dewřeɣ asen  
\m d \add ict n řqecɛet n\add* useḥqar.  
\m Mařa ẓrin ayi,  
\m ssenhezzan azeǧif nsen.   
\b  
\m
\v 26 Ewc ayi afus, \add a\add* SIDI, AREBBI inu,  
\m senjem ayi  
\m ɛlaḥṣab tamexsiwt nnec icewwaren,   
\m
\v 27 ḥima ad ssnen  
\m aqa d man aya d afus nnec,  
\m aqa Cek i iggin man aya, \add a\add* SIDI.   
\m
\v 28 Nitni d yinni ineɛɛřen,  
\m maca Cek ad tbarked,  
\m mařa ttɣewwɣen,  
\m ad dewřen ttseḍḥan  
\m \add maca\add* amsexxar nnec ad ifarḥ.   
\m
\v 29 Ejj iɣrimen inu ad yarḍen s řefḍiḥet,  
\m ad řeḥḥfen deg useḍḥi  
\m am deg ijj n useřham.   
\m
\v 30 Zeg wuř inu ad qadiɣ SIDI  
\m s uqemmum inu,  
\m ad t ssemɣareɣ jar waṭṭas.   
\m
\v 31 Maɣar Netta ad ibedd  
\m ak-d umezřuḍ ɣar ufus nnes afusi,  
\m ḥima ad \add t\add* issenjem  
\m zeg inni iḥekkmen x řeɛmar nnes.   
\b  
\b  
\m  
\c 110
\m
\v 1 \add Azehhed n Dawud.\add*  
\b  
\m SIDI issawař ak-d Sidi inu:  
\m Qim ɣar ufus afusi inu,  
\m ař dd-ssarseɣ řɛedyan nnec  
\m d tanebdat sadu iḍaren nnec. \x ◘ \xo 110:1 \xt Mt. 22:42-45; Mk. 12:36; Lk. 20:41-44; Řex. 2:34-36; Ɛbr. 1:13, 6:20; 10:13; 1 Kur. 15:25-28; Afa. 1:22\x*   
\b  
\m
\v 2 SIDI ad issekk azeǧaḍ n ṣṣulṭa nnec  
\m zi Ṣihyun,  
\m Cek ad tṣellṭed di řwesṭ n řɛedyan nnec.   
\b  
\m
\v 3 Řgens nnec ad yiři d amseɛɛaf  
\m deg wass n ṣṣulṭa nnec,  
\m ad dd-yas di tissiqt iqeddsen  
\m zi řemřawřet n tuffut,  
\m \add ammu i ɣa yiři\add* i Cek nnda  
\m n yinni ɛad mammec  
\m d ac dd-ittwaxeřqen.   
\b  
\m
\v 4 SIDI ijjuǧ, ɛemmarṣ ad xas indem:  
\m “Cek d Akehhan i řebda,  
\m ɛlaḥsab ṣṣifet n Malkiṣadiq!”,  
\m \add ixs ad yini ‘Ajeǧid d Amsegged’\add*. \x ◘ \xo 110:4 \xt Ɛbr. 4:14-15; 5:6, 9-10; 6:20; 7:15-26; 8:1; 10:21\x*   
\b  
\m
\v 5 Sidi aqa-t ɣar ufus afusi nnec.  
\m Netta ad iřbez ijeǧiden  
\m deg wass n weɣḍab nnes.   
\m
\v 6 Netta ad iḥakem x řegnus,  
\m aqa da \add tammurt\add* teccur s řxecbat,  
\m ad iřbez azeǧif  
\m x ict n temmurt tameqqrant. \x ◘ \xo 110:6 \xt Asa. 14:14-20; 16:14-16; 20:8-10\x*   
\m
\v 7 Ak-d webrid ad isu zi teɣzart,  
\m x uya ad issgeɛɛed azeǧif nnes.   
\b  
\b  
\m  
\c 111
\m
\v 1 Hallilu-Yah!  
\b  
\m \bd Alif.\bd* Ad qadeɣ SIDI  
\m s marra uř inu,  
\m \bd Bit.\bd* di řaman n wegraw  
\m n yinni igguren nican, \add di\add* tmesmunt.   
\m
\v 2 \bd Gimel.\bd* Řefɛayeř n SIDI d imeqqranen,  
\m \bd Dalit.\bd* aqa twarezzun  
\m zi marra inni zzaysen ifarrḥen.   
\m
\v 3 \bd Hi.\bd* Netta igga s lɛaḍama d řɛezz,  
\m \bd Waw.\bd* tasegda nnes tᵉttɣima i řebda.   
\m
\v 4 \bd Zayin.\bd* Netta igga ijj n \add řɛid\add*  
\m \add i\add* řidaret n lmuɛjizat nnes.  
\m \bd Xit.\bd* SIDI d aḥnin d arḥim.   
\m
\v 5 \bd Tit.\bd* Netta iwca macca  
\m i yinni t itteggʷeden,  
\m \bd Yud.\bd* ittidar Řɛahd nnes i řebda.   
\m
\v 6 \bd Kaf.\bd* Netta isscen i řgens nnes  
\m timegga nnes ijehden,  
\m \bd Lamid.\bd* ḥima ad asen iwc  
\m tasɣart n řegnus.   
\m
\v 7 \bd Mim.\bd* Řefɛayeř n ifassen nnes  
\m d tidett d řḥeqq,  
\m \bd Nun.\bd* marra tiweṣṣa nnes  
\m daysent řaman,   
\m
\v 8 \bd Samix.\bd* aqa aten bedden i řebda,  
\m \bd Ɛayin.\bd* ttwaggen di tidett u s řeṣfayet.   
\m
\v 9 \bd Pi.\bd* Netta issewjed ttaman n weṣřaḥ  
\m i řgens nnes,  
\m \bd Tsadi.\bd* igga Řɛahd nnes i řebda.  
\m \bd Quf.\bd* Isem nnes  
\m d amqeddas d isseggʷaden.   
\m
\v 10 \bd Rix.\bd* Tiggʷudi n SIDI d beddu n tiɣit.  
\m \bd Cin.\bd* Marra inni itteggen amenni,  
\m aqa ɣarsen řeɛqeř d lemliḥ.  
\m \bd Taf.\bd* Ccan nnes ittɣima i řebda.   
\b  
\b  
\m  
\c 112
\m
\v 1 Hallilu-Yah!  
\b  
\m \bd Alif.\bd* Sseɛd n weryaz  
\m nni itteggʷeden SIDI,  
\m \bd Bit.\bd* wenni ifarrḥen aṭṭas  
\m x tweṣṣa nnes. \x ◘ \xo 112:1 \xt Izhd. 1:1, 2\x*   
\m
\v 2 \bd Gimel.\bd* Tarwa nnes  
\m ad iřin jehhden di temmurt,  
\m \bd Dalit.\bd* jjiř n yinni igguren nican  
\m ad ittwabarek.   
\m
\v 3 \bd Hi.\bd* Řxir d wagřa  
\m ad ccuren taddart nnes,  
\m \bd Waw.\bd* tasegda nnes tᵉttɣima i řebda.   
\m
\v 4 \bd Zayin.\bd* I yinni igguren nican  
\m \add ad asen\add* teɣři tfawt di taǧest.  
\m \bd Xit.\bd* \add Netta\add* d aḥnin d arḥim d umsegged.   
\m
\v 5 \bd Tit.\bd* Aryaz nni ittḥinna u yareṭṭeř,  
\m \add ad yiři\add* mliḥ,  
\m \bd Yud.\bd* aqa iɛeddeř timesřayin nnes nican.   
\m
\v 6 \bd Kaf.\bd* Maɣar netta war ittɣimi  
\m ittenhezza i řebda.  
\m \bd Lamid.\bd* Ad \add din\add* tiři řidaret  
\m deg umsegged i řebda.   
\m
\v 7 \bd Mim.\bd* Netta war itteggʷed  
\m zi nnab i war iḥřin,  
\m \bd Nun.\bd* Uř nnes imten, ittcař x SIDI.   
\m
\v 8 \bd Samix.\bd* Uř nnes imten, war itteggʷed,  
\m \bd Ɛayin.\bd* ař ɣa ixzar  
\m ɣar yinni t-i-dd iḥeṣṣaren.   
\m
\v 9 \bd Pi.\bd* Izuzzar, ittic i imezřaḍ.  
\m \bd Tsadi.\bd* Tasegda nnes  
\m tᵉttɣima i řebda,  
\m \bd Quf.\bd* icc nnes ad ittwassuɛřa s ccan.   
\m
\v 10 \bd Rix.\bd* Ad t iẓar uɛeffan, ad iffugem.  
\m \bd Cin.\bd* Netta ad iɣezz s teɣmas,  
\m \add xenni\add* ad ifsi.  
\m \bd Taf.\bd* Meẓri n iɛeffanen ad ibḍeř.   
\b  
\b  
\m  
\c 113
\m
\v 1 Hallilu-Yah, sɛuǧem,  
\m \add kenniw\add* imsexxaren n SIDI,  
\m sɛuǧem Isem n SIDI!   
\m
\v 2 Ad ittwabarek Isem n SIDI,  
\m zi řexxu ař řebda. \x ◘ \xo 113:2 \xt Dan. 2:20\x*   
\m
\v 3 Zi manis dd-tneqqar tfuct  
\m ař manis tɣeǧi tfuct,  
\m ad ittwassɛuǧa Isem n SIDI.\x ◘ \xo 113:3 \xt Mal. 1:11\x*   
\b  
\m
\v 4 SIDI yuɛřa x marra řegnus,  
\m tiwa i ijenwan d aɛuǧi nnes.   
\m
\v 5 Man wen iǧan  
\m am SIDI, AREBBI nneɣ,  
\m wenni izeddɣen di řuɛřa qaɛ,   
\m
\v 6 wenni yuḍaren  
\m maḥend ad iẓar deg ijenwan  
\m u x temmurt!   
\b  
\m
\v 7 Wenni dd-issnekkaran  
\m amuqřiř zi tɛejjajt,  
\m issgeɛɛed amezřuḍ zeg wefraḍ \x ◘ \xo 113:7 \xt 1 Ṣm. 2:8; Izhd. 107:41\x*   
\m
\v 8 maḥend ad \add t\add* issɣim ak-d tarwa n taṣiřet,  
\m ak-d tarwa n taṣiřet n řgens nnes.   
\m
\v 9 Wenni issezdaɣen  
\m tenni war ittirwen di taddart,  
\m \add am\add* ict n yemmatsen n iḥenjiren tfarḥ.  
\m Hallilu-Yah.   
\b  
\b  
\m  
\c 114
\m
\v 1 Ařami iffeɣ Israil zi Miṣra,  
\m taddart n Yaɛqub  
\m zeg ijj n řgens  
\m s yiřes n midden, \f ◼ \fr 114:1 \ft \+fk iřes\ft  - niɣ ‘tutlayt’.\f*  \x ◘ \xo 114:1 \xt Uf. 13:3\x*   
\m
\v 2 idweř Yahuda d Zzawect nnes Iqeddsen,  
\m Israil d \add tammurt n\add* řeḥkamet nnes.   
\b  
\m
\v 3 Řebḥar iẓra i-t uca yarweř,  
\m L’Urdun inneqřeb ɣar ḍeffar.   
\m
\v 4 Idurar negzen am yicarriyyen,  
\m tiwririn am yizmaren.   
\b  
\m
\v 5 Min cek yuɣin, \add a\add* řebḥar,  
\m ařami trekkwařed,  
\m \add a cek\add* L’Urdun,  
\m ařami tenqeřbed ɣar ḍeffar? \f ◼ \fr 114:5 \ft \+fk řebḥar\ft  - niɣ ‘il’.\f*   
\m
\v 6 \add A\add* idurar, \add min kenniw yuɣin\add*  
\m ařami tneggzem am yicarriyyen,  
\m tiwririn am yizmaren?   
\b  
\m
\v 7 \add A\add* tammurt arjiji zzat i wudem n Sidi,  
\m zzat i wudem n Arebbi n Yaɛqub,   
\m
\v 8 wenni yarrin taṣḍart  
\m d řḥemřet n waman,  
\m sseǧaḥ d řɛunṣarat n waman. \x ◘ \xo 114:8 \xt Uf. 17:6; Řxř. 20:11\x*   
\b  
\b  
\m  
\c 115
\m
\v 1 War iǧi i neccin, \add a\add* SIDI,  
\m war iǧi i neccin,  
\m maɣar i Yisem nnec ad yiři uɛuǧi,  
\m di ssibbet n tmexsiwt nnec icewwaren  
\m d řaman nnec.   
\m
\v 2 Mayemmi ɣa qqaren řegnus:  
\m ‘Mani iǧa xenni AREBBI nsen?’   
\b  
\m
\v 3 AREBBI nneɣ aqa-t deg ujenna,  
\m igga marra min d as yarḍan.   
\m
\v 4 Řexyařat nsen n l’aṣnam  
\m aqa atent s nnuqart d wureɣ,  
\m řxedmet n ifassen n iwdan. \f ◼ \fr 115:4 \ft \+fk ifassen n iwdan\ft  - s Tɛibranit ‘ifassen n Adam’.\f*   
\m
\v 5 Ɣarsen aqemmum,  
\m \add maca\add* war ssiwiřent,  
\m ɣarsent tiṭṭawin,  
\m \add maca\add* war ttwiřint, \x ◘ \xo 115:5 \xt Aɛwd. 4:28; Irm. 10:3, 4, 5, 9-16\x*   
\m
\v 6 Ɣarsent imezzuɣen,  
\m \add maca\add* war ttesřint,  
\m ɣarsent wanzaren,  
\m \add maca\add* war ttcemmint.   
\m
\v 7 Ifassen nsen  
\m war zemmaren ad cebbaren,  
\m iḍaren nsen  
\m war zemmaren ad uyuren.  
\m Nitni war ssuffuɣen řḥess zi tmijja nsen.   
\m
\v 8 Ejj inni tent iggin  
\m ad daysent arewsen,  
\m kuř ijj zeg inni xasent ittecřen.   
\b  
\m
\v 9 Israil, tceř x SIDI.  
\m Netta d twiza nsen  
\m d taseddart nsen i useřqi.   
\m
\v 10 Taddart n Harun, tceř x SIDI.  
\m Netta d twiza nsen  
\m d taseddart nsen i useřqi.   
\m
\v 11 \add Marra kenniw\add* inni itteggʷeden SIDI,  
\m tecřem x SIDI.  
\m Netta d twiza nsen  
\m d taseddart nsen i useřqi.   
\m
\v 12 SIDI iɛqeř xaneɣ, Netta ad ibarek.  
\m Ad ibarek taddart n Israil,  
\m ad ibarek taddart n Harun.   
\m
\v 13 Netta ad ibarek  
\m inni itteggʷeden zi SIDI,  
\m imeẓyanen \add jmiɛ\add* ak-d imeqqranen.   
\m
\v 14 SIDI ad awem issmarni \add tarwa\add*,  
\m i kenniw uřa i injiren nwem.   
\b  
\m
\v 15 Kenniw tᵉttwabarkem zi SIDI,  
\m wenni iggin ijenwan d temmurt.   
\m
\v 16 Ijenwan, \add wah,\add* ijenwan n SIDI,  
\m \add maca\add* tammurt iwca i-tt  
\m i tarwa n bnadem.   
\m
\v 17 Imettan war zemmaren  
\m ad ssemɣaren SIDi,  
\m uřa d inni dd-ihwan deg ususem.   
\m
\v 18 Neccin ad nbarek SIDi,  
\m zi řexxu ař i řebda. Hallilu-Yah!   
\b  
\b  
\m  
\c 116
\m
\v 1 Necc ttexseɣ,  
\m maɣar SIDI isřa  
\m i tmijja inu, i tutra inu,   
\m
\v 2 maɣar Netta iwca ayi ameẓẓuɣ nnes.  
\m Ad as řaɣiɣ marra ussan \add n tudart inu\add*.   
\m
\v 3 Iseɣwan n řmewt nnḍen ayi-dd,  
\m tewḍa-dd xafi tiggʷuda n řaxart.  
\m Necc ufiɣ aqa ayi ttwaḥṣareɣ u ceḍneɣ. \x ◘ \xo 116:3 \xt 2 Ṣm. 22:5, 6\x*   
\m
\v 4 Řaɣiɣ x Yisem n SIDI, nniɣ:  
\m “\add A\add* SIDI, fekk řeɛmar inu!”   
\b  
\m
\v 5 SIDI d aḥnin d amsegged,  
\m AREBBI nneɣ dayes řeḥnunect.   
\m
\v 6 SIDI iḥeṭṭa uřawen n iḥafiyyen.  
\m Necc tuɣa ayi \add am\add* uneɛḍab,  
\m \add maca\add* Netta issenjem ayi.   
\m
\v 7 Hna ɛawed, \add a\add* řeɛmar inu,  
\m maɣar SIDI igga ac min iṣebḥen. \x ◘ \xo 116:7 \xt Izhd. 13:6\x*   
\m
\v 8 Maɣar Cek teḥḍid řeɛmar inu  
\m zi řmewt,  
\m tiṭṭawin inu zeg imeṭṭawen,  
\m aḍar inu zeg uneqraḍ.   
\m
\v 9 Ad uyureɣ zzat i wudem n SIDI,  
\m di temmura n yinni iddaren.   
\b  
\m
\v 10 Necc umneɣ, s uyenni nniɣ:  
\m “Necc ttwaḥṣareɣ aṭṭas!” \x ◘ \xo 116:10 \xt 2 Kur. 4:13\x*   
\m
\v 11 Di tiggʷudi inu nniɣ:  
\m “Marra iwdan d ayt n bu-ixarriqen!” \x ◘ \xo 116:11 \xt Rum. 3:4\x*   
\m
\v 12 Mammec i ɣa xeǧṣeɣ SIDI  
\m x marra řxar i d ayi igga?   
\m
\v 13 Ad ssgeɛɛdeɣ  
\m řkas n usenjem ameqqran,  
\m ad řaɣiɣ x Yisem n SIDI.   
\m
\v 14 Necc ad kemmřeɣ  
\m lwuɛud inu i SIDI,  
\m qibač i marra řgens nnes.   
\b  
\m
\v 15 Aqa iɣřa di tiṭṭawin n SIDI  
\m řmewt n imtiqqan nnes.   
\m
\v 16 A SIDI, aqa necc d amsexxar nnec,  
\m nnec d amsexxar nnec,  
\m mmis n tayya nnec.  
\m Cek tessarxud xafi iceddiyen inu.   
\m
\v 17 Necc ad Cek dd-awyeɣ  
\m tawhibt n uqadi,  
\m ad řaɣiɣ x Yisem n SIDI.   
\m
\v 18 Necc ad ssqefřeɣ lwuɛud inu i SIDI,  
\m qibač i marra řgens nnes.   
\m
\v 19 di řemraḥat n Taddart n SIDI,  
\m di řwesṭ nnem, \add a\add* Urcalim!  
\m Hallilu-Yah.   
\b  
\b  
\m  
\c 117
\m
\v 1 Sɛuǧem SIDI, marra řegnus,  
\m ṣebḥem t, marra ccuɛub! \x ◘ \xo 117:1 \xt Rum. 15:11\x*   
\m
\v 2 Maɣar tamexsiwt nnes icewwaren  
\m d tameqqrant tiwa nneɣ,  
\m řaman n SIDI ittɣima i řebda,  
\m Hallilu-Yah!   
\b  
\b  
\m  
\c 118
\m
\v 1 \add Ɣar beddu ...\add*  
\m Qadam SIDI,  
\m maɣar Netta d aṣebḥan,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda.   
\m
\v 2 Ejj Israil ad yini:  
\m “Tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda.”   
\m
\v 3 Ejj taddart n Harun ad tini  
\m “Tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda.”   
\m
\v 4 Ejj inni itteggʷeden SIDI ad inin:  
\m “Tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda.”   
\b  
\m
\v 5 \add Deg webrid ...\add*  
\m Di řeḥṣaret řaɣiɣ ɣar SIDi.  
\m SIDi yarra-dd xafi, \add iwca ayi\add* ttasiɛ.   
\m
\v 6 SIDI aqa-t akidi, war tteggʷedeɣ ca,  
\m \add maɣar\add* min izemmar bnadem  
\m ad ayi igg? \x ◘ \xo 118:6 \xt Rum. 8:31; Ɛbr. 13:6\x*   
\m
\v 7 SIDI aqa-t akidi  
\m jar yinni d ayi iwcin afus.  
\m Necc ad xezzareɣ \add ɣar swadday\add*  
\m x yinni d ayi icarrhen.   
\m
\v 8 Iḥřa ad arewřeɣ ɣar SIDI  
\m x utecři x bnadem. \x ◘ \xo 118:8 \xt Izhd. 62:9, 10; 146:3; Irm. 17:5, 7\x*   
\m
\v 9 Iḥřa ad arewřeɣ ɣar SIDI  
\m x utecři x tarwa n taṣiřet.   
\m
\v 10 Marra řegnus nnḍen ayi-dd,  
\m necc ɣeḍřeɣ ten s Yisem n SIDI.   
\m
\v 11 Nnḍen ayi-dd, \add wah,\add* quwwaren ayi.  
\m Necc ɣeḍřeɣ ten s Yisem n SIDI.   
\m
\v 12 Nitni nnḍen ayi am tzizwa,  
\m aqa am tmessi n isennanen xesyen.  
\m Necc ɣeḍřeɣ ten s Yisem n SIDI.   
\m
\v 13 Cek tɛarned ayi s řeqsaḥet  
\m ařami ɛřaḥař wḍiɣ,  
\m maca SIDI iwca ayi afus.   
\m
\v 14 SIDi d jjehd inu d azehhed \add inu\add*,  
\m Netta idweř ayi d asenjem.   
\m
\v 15 Deg iqiḍan n imseggaden \add ittwaseř\add*  
\m řḥess n usřiwřew d usenjem.  
\m Afus afusi n SIDI igga s jjehd.   
\m
\v 16 Afus afusi n SIDI ittwassgeɛɛed,  
\m afus afusi n SIDI igga s wemḥaḍ. \x ◘ \xo 118:16 \xt Lk. 1:51\x*   
\m
\v 17 Necc war ttmettiɣ ca, ad ddareɣ,  
\m ad barrḥeɣ timegga n SIDi.   
\m
\v 18 SIDi iwebbex ayi aṭṭas,  
\m \add maca\add* war d ayi iwci i řmewt.   
\b  
\m
\v 19 \add Ɣar wadaf ...\add*  
\m Arzmem ayi tiwwura n tsegda,  
\m ad zzaysent adfeɣ, ad qadiɣ SIDi. \x ◘ \xo 118:19 \xt Ica. 26:2\x*   
\b  
\m
\v 20 \add Inni yareḥḥben zeg yinni ittadfen qqaren ...\add*  
\m Ta d tawwart n SIDI,  
\m imseggaden ad zzayes adfen.   
\m
\v 21 Necc ad ac qadiɣ umi d ayi tesřid,  
\m tdewřed ayi d asenjem.   
\m
\v 22 Aẓru i war xsen ibennayen,  
\m idweř d ixef n teɣmart. \x ◘ \xo 118:22 \xt Ica. 8:14; 28:16; Mt. 21:42; Mk. 12:10; Lk. 20:17; Řex. 4:11; Rum. 9:33; Afa. 2:20; 1 Bṭ. 2:4, 7\x*   
\m
\v 23 Wa yusa-dd zi SIDI  
\m u man aya d řeɛjeb di tiṭṭawin nneɣ.   
\m
\v 24 Wa d ass i igga SIDI,  
\m ejj aneɣ ad narceq u ad dayes nfarḥ.   
\m
\v 25 A SIDI, awi-dd asenjem,  
\m a SIDI, awi-dd afřaḥ.   
\m
\v 26 Lbaraka i wenni dd ɣa yasen  
\m s Yisem n SIDI!  
\m Neccin ad kenniw nbarek  
\m zi Taddart n SIDI. \x ◘ \xo 118:26 \xt Mt. 21:9; Mt. 23:39; Mk. 11:9, 10; Lk. 19:38; Yḥ. 12:13\x*   
\m
\v 27 Arebbi d SIDI nni d aneɣ iggin tafawt.  
\m Qnem \add taɣarṣt n\add* řɛid s iseɣwan  
\m ɣar waccawen n uɛalṭar,  
\m \add řmedbeḥ n wecmaḍ\add*.   
\b  
\m
\v 28 \add Inni ittadfen qqaren ...\add*  
\m Cek d Arebbi inu, s uya ad Cek qadiɣ,  
\m \add a\add* AREBBI inu, ad Cek ssɛuǧeɣ.   
\b  
\m
\v 29 \add Marra jmiɛ ...\add*  
\m Qadam SIDI, maɣar Netta iṣbeḥ,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda.   
\b  
\b  
\m  
\c 119
\m
\v 1 \bd Alif.\bd* Sseɛd nsen i yinni ikemmřen  
\m abrid \add n tudart\add* nsen břa řɛib,  
\m inni igguren x webrid n Ccariɛa n SIDI. \x ◘ \xo 119:1 \xt Izhd. 1:1\x*   
\m
\v 2 Sseɛd nsen i yinni iḥeṭṭan  
\m cchadat nnes,  
\m inni xas yarezzun s marra uř nsen.   
\m
\v 3 Nitni war tteggen řɣecc,  
\m maca gguren deg ibriden nnes.   
\m
\v 4 \add A\add* SIDI, cek tumared  
\m maḥend bnadem  
\m ad iḥḍa tiweṣṣa nnec nican.   
\m
\v 5 Mři qaɛ ibriden inu ttwaseggden,  
\m maḥend ad ḥḍiɣ tiweṣṣa nnec,   
\m
\v 6 \add xenni\add* ɛemmarṣ ad seḍḥiɣ  
\m mařa xezzareɣ ɣar marra tiweṣṣa nnec.   
\m
\v 7 S wuř iqqur ad Cek qadiɣ,  
\m mařa necc řemdeɣ  
\m řeḥkamat nnec iseggden.   
\m
\v 8 Ad ḥḍiɣ tiweṣṣa nnec!  
\m War dayi semmeḥ \add marra\add*!   
\b  
\m
\v 9 \bd Bit.\bd* Mammec i ɣa issizdeg  
\m ijj n uḥudri abrid nnes?  
\m S wemnaɛ nnes deg wawař nnec.   
\m
\v 10 Necc arezzuɣ xak s wuř inu marra,  
\m war d ayi ttejji  
\m ad ffɣeɣ x řumurat nnec.   
\m
\v 11 Min teqqared Cek,  
\m xemmřeɣ t deg wuř inu,  
\m maḥend war kidek xeṭṭiɣ.   
\m
\v 12 Tᵉttwabarked Cek, \add a\add* SIDI,  
\m seřmed ayi tiweṣṣa nnec.   
\m
\v 13 S iyencicen inu barrḥeɣ  
\m marra lfarayiḍ n uqemmum nnec.   
\m
\v 14 Aqa farḥeɣ s webrid n cchadat nnec,  
\m am s marra min iǧan iɣřa.   
\m
\v 15 Ad xarrṣeɣ di řumurat nnec,  
\m ad xezzareɣ ɣar imesraq nnec.   
\m
\v 16 Necc ttarreɣ meẓři di tiweṣṣa nnec,  
\m awař nnec war t ttᵉttuɣ.   
\b  
\m
\v 17 \bd Gimel.\bd* Egg tcuni i umsexxar nnec,  
\m maḥend ad ddareɣ u ad ḥḍiɣ awař nnec. \x ◘ \xo 119:17 \xt Izhd. 103:2; 116:7\x*   
\m
\v 18 Arzem ayi tiṭṭawin inu,  
\m ḥima ad ẓareɣ lmuɛjizat n Ccariɛa nnec.   
\m
\v 19 Necc aqa ayi d abarrani x temmurt,  
\m war xafi teffar řumurat nnec. \x ◘ \xo 119:19 \xt Amz. 47:9; 1 Im. 29:15; Izhd. 39:13; Ɛbr. 11:13\x*   
\m
\v 20 Řeɛmar inu ittwafna  
\m s uweḥḥec ɣar lfarayiḍ nnec, řebda.   
\m
\v 21 Cek tɛaqbed imɛeffaren ittwaneɛřen,  
\m inni itteffɣen x řumurat nnec.   
\m
\v 22 Ksi xafi řefḍiḥet d useḥqar,  
\m maɣar ḥḍiɣ cchadat nnec.   
\m
\v 23 Uřa d řḥukkam qqimen,  
\m ssawařen ak-d wayawya xafi,  
\m \add maca\add* amsexxar nnec  
\m ittxarreṣ di tweṣṣa nnec.   
\m
\v 24 Cchadat nnec d meẓri inu,  
\m aqa atent d imcawaren inu. \x ◘ \xo 119:24 \xt Izhd. 43:4\x*   
\b  
\m
\v 25 \bd Dalit.\bd* Řeɛmar inu iřṣeq ɣar tɛejjajt,  
\m arr-dd dayi tudart ɛlaḥsab awař nnec.   
\m
\v 26 Necc neɛmeɣ i Cek x ibriden inu  
\m u Cek testajbed ayi.  
\m Seřmed ayi tiweṣṣa nnec. \x ◘ \xo 119:26 \xt Izhd. 25:4; 27:11; 86:11\x*   
\m
\v 27 Arr ayi ad fehmeɣ  
\m abrid n řumurat nnec,  
\m ad xarrṣeɣ di lmuɛjizat nnec.   
\m
\v 28 Řeɛmar inu ifsi s wecḍan,  
\m seggem ayi ɣar \add webrid n\add* wawař nnec.   
\m
\v 29 Siggʷej ayi x webrid n ixarriqen,  
\m ḥinn xafi s Ccariɛa nnec.   
\m
\v 30 Necc ixḍareɣ abrid n tidett,  
\m ssarseɣ lfarayiḍ nnec \add zzati\add*.   
\m
\v 31 Necc cebbareɣ  
\m di cchadat nnec, \add a\add* SIDI,  
\m war d ayi ttejji ad seḍḥiɣ.   
\m
\v 32 Necc ad azzřeɣ  
\m abrid n řumurat nnec,  
\m maɣar Cek teggid ttasiɛ i wuř inu.   
\b  
\m
\v 33 \bd Hi.\bd* \add A\add* SIDI! seřmed ayi  
\m abrid n tweṣṣa nnec,  
\m \add xenni\add* necc ad dayes ṭṭfeɣ ař aneggar.   
\m
\v 34 Ewc ayi řefhamet,  
\m \add xenni\add* ad ḥḍiɣ Ccariɛa nnec  
\m u ad dayes ṭṭfeɣ s wuř inu marra.   
\m
\v 35 Ndeh ayi x webrid n řumurat nnec,  
\m minzi farrḥeɣ zzayes.   
\m
\v 36 Arr uř inu ɣar cchadat nnec,  
\m war iǧi ɣar ṭṭmeɛ n arbeḥ.   
\m
\v 37 Sheyyeḍ tiṭṭawin inu x řbaṭeř,  
\m arr-dd dayi tudart s ibriden nnec.   
\m
\v 38 Ḍmen min tennid i umsexxar nnec,  
\m wenni Cek itteggʷden.   
\m
\v 39 Sḥeyyed xafi řefḍiḥet i zi tteggʷedeɣ,  
\m maɣar lfarayiḍ nnec cnant.   
\m
\v 40 Xzar, ttweḥḥceɣ řumurat nnec,  
\m arr ayi ddareɣ s tsegda nnec.   
\b  
\m
\v 41 \bd Waw.\bd* Ejj ad ɣari dd-tas  
\m tmexsiwt nnec icewwaren, \add a\add* SIDI,  
\m asenjem nnec  
\m \add aqa-t\add* am mammec i tennid Cek.   
\m
\v 42 ḥima zemmareɣ ad arreɣ  
\m x wenni zzayi issbehdařen,  
\m maɣar ttecřeɣ x wawař nnec.   
\m
\v 43 War ttekkes awař n tidett qaɛ  
\m zeg uqemmum inu,  
\m maɣar ttrajiɣ lfarayiḍ nnec.   
\m
\v 44 Necc ad ḥḍiɣ Ccariɛa nnec břa qeṭṭu,  
\m i řebda qaɛ.   
\m
\v 45 Necc ggureɣ di ttasiɛ,  
\m maɣar arzuɣ x řumurat nnec.   
\m
\v 46 Ad ssiwřeɣ x cchadat nnec  
\m zzat i ijeǧiden,  
\m war \add zzatsen\add* ttseḍḥiɣ ca.   
\m
\v 47 Ad arreɣ meẓri di řumurat nnec,  
\m tinni i ttexseɣ.   
\m
\v 48 Ad sgeɛɛdeɣ ifassen inu  
\m qibař i řumurat nnec, tinni i ttexseɣ,  
\m ad xarrṣeɣ di tweṣṣa nnec.   
\b  
\m
\v 49 \bd Zayin.\bd* Ɛqeř x wawař  
\m \add i tennid\add* i umsexxar nnec,  
\m min xef tuyřed asitem inu.   
\m
\v 50 D wa d afewwej inu di řeɣben inu,  
\m maɣar lwaɛd nnec  
\m yarra-dd dayi tudart.   
\m
\v 51 Imɛeffaren stehzan zzayi ař ṭṭarf,  
\m \add maca\add* necc war ḥeyyideɣ ca  
\m x Ccariɛa nnec.   
\m
\v 52 Necc xarrṣeɣ  
\m di lfarayiḍ nnec n řebda, \add a\add* SIDI,  
\m \add xenni\add* aqa ttwafewwjeɣ.   
\m
\v 53 Tafqeḥt tᵉṭṭef ayi  
\m di ssibbet n iɛeffanen,  
\m inni isemmḥen di Ccariɛa nnec.   
\m
\v 54 Tiweṣṣa nnec tuɣa atent d izřan inu  
\m di taddart n tbarranect inu.   
\m
\v 55 Di ǧiřet tuɣa ttxarrṣeɣ  
\m deg Yisem nnec,  
\m \add a\add* SIDI, u ḥḍiɣ Ccariɛa nnec. \x ◘ \xo 119:55 \xt Izhd. 16:7; 42:9\x*   
\m
\v 56 Ammu i d ayi imsar,  
\m maɣar ḥḍiɣ řumurat nnec.   
\b  
\m
\v 57 \bd Xit.\bd* SIDI d tasɣart inu,  
\m necc nniɣ ad ḥḍiɣ awařen nnec.   
\m
\v 58 Ḥeccmeɣ \add zzat\add* i wudem nnec  
\m s marra wuř inu,  
\m ḥinn xafi am mammec i \add d ayi\add* tennid.   
\m
\v 59 Necc xarrṣeɣ deg ibriden inu,  
\m ad ssɛeqbeɣ \add iṣuraf n\add* iḍaren inu  
\m ɣar cchadat nnec.   
\m
\v 60 Necc qeǧqeɣ, war ɛeṭṭařeɣ ca,  
\m ḥima ad ḥḍiɣ řumurat nnec.   
\m
\v 61 Iseɣwan n iɛeffanen carrfen ayi,  
\m \add maca\add* war ttᵉttuɣ Ccariɛa nnec.   
\m
\v 62 Ɣar wezyen n ǧiřet ttnekkareɣ,  
\m ḥima ad Cek qadiɣ  
\m x lfarayiḍ nnec iseggden.   
\m
\v 63 Necc d aɛcir n marra  
\m inni Cek itteggʷeden,  
\m n yinni iḥeṭṭan řumurat nnec.   
\m
\v 64 Zi tmexsiwt nnec icewwaren  
\m teccur temmurt marra, \add a\add* SIDI,  
\m seřmed ayi tiweṣṣa nnec.   
\b  
\m
\v 65 \bd Tit.\bd* Cek teggid s tcuni i umsexxar nnec,  
\m \add a\add* SIDI, ɛlaḥsab awař nnec.   
\m
\v 66 Seřmed ayi maḥend ad meyyzeɣ  
\m u ad ssneɣ mliḥ,  
\m minzi ttecřeɣ x řumurat nnec.   
\m
\v 67 Qbeř ma ttwaḥṣareɣ, weddareɣ,  
\m \add maca\add* řexxu ḥeṭṭiɣ min teqqared Cek.   
\m
\v 68 Cek d aṣebḥan, tᵉttegged min iṣebḥen,  
\m seřmed ayi tiweṣṣa nnec.   
\m
\v 69 Imɛeffaren arexxun-dd xafi ixarriqen,  
\m \add maca\add* necc ḥeṭṭiɣ řumurat nnec  
\m s marra uř inu.   
\m
\v 70 Uř nsen war ittacan am tadunt,  
\m \add maca\add* necc, aqa Ccariɛa nnec  
\m ttafeɣ dayes meẓri.   
\m
\v 71 Tuɣa i necc mliḥ umi ttwaḥṣareɣ,  
\m maɣar ammu i řemdeɣ tiweṣṣa nnec.   
\m
\v 72 Ccariɛa zeg uqemmum nnec  
\m ɣari iḥřa aṭṭas  
\m x wařaf n \add uqiyyat\add* n wureɣ  
\m niɣ n nnuqart. \x ◘ \xo 119:72 \xt Izhd. 19:11\x*   
\b  
\m
\v 73 \bd Yud.\bd* Ifassen nnec ggin ayi,  
\m kewwnen ayi.  
\m Ewc ayi řeɛqeř,  
\m maḥend ad řemdeɣ řumurat nnec. \x ◘ \xo 119:73 \xt Ayub 10:9; Izhd. 139:13\x*   
\m
\v 74 Inni Cek itteggʷeden ad ayi ẓaren  
\m uca ad farḥen,  
\m maɣar ttrajiɣ awař nnec.   
\m
\v 75 Necc ssneɣ, \add a\add* SIDI,  
\m aqa seggdent řeḥkamat nnec,  
\m u aqa Cek teḥṣared ayi s řaman.   
\m
\v 76 Ejj ad tiři tmexsiwt nnec icewwaren  
\m d afewwej i necc,  
\m am mammec i tennid i umsexxar nnec.   
\m
\v 77 Ad xafi dd-tas arreḥmet nnec,  
\m maḥend ad ddareɣ,  
\m maɣar Ccariɛa nnec dayes meẓri inu.   
\m
\v 78 Ejj ad seḍḥan imɛeffaren,  
\m maɣar s ixarriqen  
\m ssfarrɣen ayi \add ṣṣifet inu\add*,  
\m \add maca\add* necc txemmameɣ  
\m di řumurat nnec.   
\m
\v 79 Ejj ad ɣari dd-dewřen  
\m inni Cek itteggʷeden,  
\m inni issnen cchadat nnec.   
\m
\v 80 Ejj ad yiři uř inu imun  
\m ɣar tweṣṣa nnec,  
\m ḥima war ttseḍḥiɣ ca.   
\b  
\m
\v 81 \bd Kaf.\bd* Řeɛmar inu isxef  
\m \add zi meẓri\add* ɣar usenjem nnec,  
\m aqa ttrajiɣ awař nnec.   
\m
\v 82 Tiṭṭawin inu deqqřent \add zi meẓri\add*  
\m ɣar min teqqared Cek, umi nniɣ:  
\m ‘Meřmi i xafi i ɣa tessfewwjed?’   
\m
\v 83 Maɣar dewřeɣ  
\m am yict n txancet n yiřem  
\m \add tuyeř\add* di ddexxan,  
\m \add maca\add* tiweṣṣa nnec  
\m war tent ttuɣ.   
\m
\v 84 Mecḥař n wussan \add ɛad\add*  
\m \add i iqqimen\add* i umsexxar nnec?  
\m Meřmi i ɣa tcarrɛed  
\m inni d ayi iḍeffaren?   
\m
\v 85 Imɛeffaren ɣzan ayi iḥufar,  
\m min war dd-yusin ak-d Ccariɛa nnec.   
\m
\v 86 Marra řumurat nnec d tidett.  
\m Nitni ttdarracen ayi s ixarriqen,  
\m ewc ayi afus!   
\m
\v 87 Ɛřaḥař iři aqa teḥḥan ayi  
\m zi temmurt,  
\m \add maca\add* necc war ḥeyydeɣ  
\m x řumurat nnec.   
\m
\v 88 Arr-dd dayi tudart  
\m ɛlaḥsab tamexsiwt nnec icewwaren,  
\m \add xenni\add* ad ḥḍiɣ cchadet \add i dd-iffɣen\add*  
\m zeg uqemmum nnec.   
\b  
\m
\v 89 \bd Lamid.\bd* \add A\add* SIDI, awař nnec  
\m ittɣima i řebda imten deg ujenna.   
\m
\v 90 Tamexsiwt nnec icewwaren  
\m \add tiweḍ\add* zi jjiř ař jjiř.  
\m Cek teggid tammurt ad tbedd temten  
\m u \add ammu i\add* ɣa teqqim tbedd. \x ◘ \xo 119:90 \xt Amb. 1:4\x*   
\m
\v 91 Ɛlaḥsab lfarayiḍ nnec ad qqimen bedden,  
\m maɣar marra nitni d imsexxaren nnec.   
\m
\v 92 Meɛlik war teǧi Ccariɛa nnec  
\m d meẓri inu,  
\m iři ttwahellkeɣ di řeḥṣaret inu.   
\m
\v 93 Ɛemmarṣ ad ttuɣ řumurat nnec i řebda,  
\m maɣar zzaysent tarrid ayi-dd tudart.   
\m
\v 94 Necc aqa ayi i Cek, senjem ayi,  
\m minzi arzuɣ x řumurat nnec.   
\m
\v 95 Iɛeffanen rajan ayi ḥima ad ayi teḥḥan,  
\m \add maca\add* necc xezzareɣ ɣar cchadat nnec.   
\m
\v 96 Necc ẓriɣ aqa marra min teǧa řekmaret  
\m ɣares aneggar,  
\m \add maca\add* řumur nnec ɣares ttasiɛ aṭṭas.   
\b  
\m
\v 97 \bd Mim.\bd* Mammec i xafi tɛizz Ccariɛa nnec,  
\m ass ikmeř ttxarrṣeɣ dayes.   
\m
\v 98 S řumurat nnec tarrid ayi d amiɣis  
\m x řɛedyan inu, maɣar aqa aten ɣari i řebda.   
\m
\v 99 Necc ɣari řeɛqeř ktar  
\m x marra imseřmaden inu,  
\m maɣar ttxarrṣeɣ deg ibriden nnec.   
\m
\v 100 Necc ɣari řefhamet ktar x iwessura,  
\m maɣar ḥḍiɣ řumurat nnec.   
\m
\v 101 Menɛeɣ iḍaren inu  
\m zi qaɛ ibriden iɛeffanen,  
\m ḥima ad ḥḍiɣ awař nnec.   
\m
\v 102 Necc war ḥeyydeɣ ca x lfarayiḍ nnec,  
\m maɣar Cek d wenni d ayi issɣaren.   
\m
\v 103 Mammec i ɣa yiři d miẓid  
\m min teqqared Cek  
\m i waneɣ inu, x tamment i uqemmum inu! \x ◘ \xo 119:103 \xt Izhd. 19:11; Awřn. 8:11\x*   
\m
\v 104 Zi řumurat nnec ttarriɣ-dd řeɛqeř,  
\m x uya carrheɣ kuř amesruq n ixarriqen.   
\b  
\m
\v 105 \bd Nun.\bd* Awař nnec d řefnar i uḍar inu  
\m d tafawt i umesruq inu.   
\m
\v 106 Necc jjuǧeɣ u ad \add t\add* ggeɣ,  
\m aqa ad ḥḍiɣ  
\m marra lfarayiḍ nnec iseggden. \x ◘ \xo 119:106 \xt Naḥ. 10:30\x*   
\m
\v 107 Necc ttwaḥṣareɣ aṭṭas, \add a\add* SIDI,  
\m arr-dd dayi tudart ɛlaḥsab awař nnec.   
\m
\v 108 Ttzawgeɣ, ksi s arḍa  
\m tiwhibin n řxaḍar  
\m zeg uqemmum inu, \add a\add* SIDI,  
\m u seřmed ayi lfarayiḍ nnec.   
\m
\v 109 Tudart inu aqa-t řebda di lxaṭer,  
\m \add maca\add* ɛemmarṣ ad ttuɣ Ccariɛa nnec.   
\m
\v 110 Iɛeffanen ggin ayi ijj n řfex,  
\m \add maca\add* necc war ffɣeɣ ca  
\m x řumurat nnec.   
\m
\v 111 Cchadat nnec d tasɣart inu i řebda,  
\m maɣar nitenti ssfarrḥent uř inu.   
\m
\v 112 Ḥezzmeɣ uř inu  
\m maḥend ad ggeɣ ɛlaḥsab tiweṣṣa nnec,  
\m i řebda, ař aneggar.   
\b  
\m
\v 113 \bd Samix.\bd* Ayt n tnayen n iɣembab  
\m carrheɣ ten,  
\m \add maca\add* ttexseɣ Ccariɛa nnec.   
\m
\v 114 Cek d adurri inu  
\m d taseddart n useřqi inu,  
\m necc ttrajiɣ awař nnec.   
\m
\v 115 Beɛɛdem xafi, \add a\add* iɛeffanen,  
\m ḥima ad ḥḍiɣ řumurat n AREBBI inu.   
\m
\v 116 Senned ayi ɛlaḥsab lwaɛd nnec,  
\m maḥend ad ddareɣ  
\m u war ttseḍḥiɣ di řayas inu.   
\m
\v 117 Ɛemmed ayi,  
\m \add xenni\add* ad ttwassnejmeɣ,  
\m u ad arreɣ meẓri  
\m di tweṣṣa nnec řebda.   
\m
\v 118 Marra inni ittaggʷejen  
\m x tweṣṣa nnec, sseḥqareɣ ten,  
\m maɣar řɣecc nsen \add mɣir\add* d ixarriqen.   
\m
\v 119 Am kuffu tmeḥḥid  
\m marra iɛeffanen zi temmurt,  
\m s uya ttexseɣ cchadat nnec.   
\m
\v 120 Zi tiggʷudi zzayek  
\m teccirruw arrimet inu,  
\m \add ammu i\add* ggʷedeɣ zi řeḥkamat nnec.   
\b  
\m
\v 121 \bd Ɛayin.\bd* Necc ggiɣ řḥeqq d tsegda,  
\m war d ayi ttsellem i \add řmargeḥ n\add*  
\m yinni d ayi iḥeṣṣaren.   
\m
\v 122 Egg řɛarbun di ṭṭweɛ n umsexxar nnec,  
\m war ttejji imɛeffaren ad ayi ḥṣaren.   
\m
\v 123 Tiṭṭawin inu deqqřent  
\m \add zi meẓri\add* ɣar usenjem nnec,  
\m ɣar lwaɛd n tsegda nnec.   
\m
\v 124 Egg s tmexsiwt nnec icewwaren  
\m ak-d umsexxar nnec,  
\m seřmed ayi tiweṣṣa nnec.   
\m
\v 125 Necc d amsexxar nnec, ewc ayi řeɛqeř,  
\m maḥend ad ssneɣ cchadat nnec.   
\m
\v 126 Aqa yiweḍ as-dd řḥař i SIDI,  
\m ḥima ad ibedd x iḍaren nnes,  
\m \add maɣar\add* nitni arẓin Ccariɛa nnec.   
\m
\v 127 Minzi ttexseɣ tiweṣṣa nnec x wureɣ,  
\m \add wah\add* aṭṭas x wureɣ ittwaṣeffan,   
\m
\v 128 x uya ḥesbeɣ marra řumurat \add nnec\add*  
\m di kuř \add tamesřact\add* nican,  
\m \add maca\add* carheɣ kuř amesruq n ixarriqen.   
\b  
\m
\v 129 \bd Pi.\bd* Cchadat nnec d lmuɛjizat,  
\m x uya iḥeṭṭa tent wuř inu.   
\m
\v 130 Anurzem n wawařen nnec  
\m isscan tafawt,  
\m i iḥafiyyen ittic asen řeɛqeř. \x ◘ \xo 119:130 \xt Izhd. 19:9\x*   
\m
\v 131 Arzmeɣ aqemmum inu aṭṭas  
\m u ssaḥrateɣ zi meẓri ɣar řumurat nnec.   
\m
\v 132 Arr udem \add nnec\add* ɣari u ḥinn xafi,  
\m am mammec dd-tekkar  
\m i yinni ittexsen Isem nnec.   
\m
\v 133 Semten iṣuraf inu  
\m am mammec i d ayi tennid,  
\m war ttejji ad xafi iḥkem řɣecc walu.   
\m
\v 134 Fekk ayi zi řeḥṣaret n iwdan,  
\m maḥend ad ḥḍiɣ řumurat nnec.   
\m
\v 135 Ejj udem nnec  
\m ad yarɣ x umsexxar nnec,  
\m seřmed ayi tiweṣṣa nnec. \x ◘ \xo 119:135 \xt Izhd. 4:7\x*   
\m
\v 136 Tiɣezratin n waman hwant-i-dd  
\m zi tiṭṭawin inu,  
\m maɣar nitni war ḥeṭṭan Ccariɛa nnec.   
\b  
\m
\v 137 \bd Tsadi.\bd* Aqa Cek d amsegged, \add a\add* SIDI,  
\m uřa d lfarayiḍ nnec seggdent.   
\m
\v 138 Cek tumured tasegda n cchadat nnec,  
\m řmanet \add nsen\add* d tameqqrant aṭṭas.   
\m
\v 139 Tusmi inu \add iqeddsen\add* inu tecca ayi,  
\m maɣar inni d ayi iḥeṣṣaren  
\m ttun awařen nnec.   
\m
\v 140 Lwaɛd nnec iqqur aṭṭas,  
\m amsexxar nnec ittexs i-t. \x ◘ \xo 119:140 \xt 2 Ṣm. 22:31; Izhd. 12:7; 18:31; Awřn. 30:5\x*   
\m
\v 141 Necc d amuqřiř u ttwasseḥqareɣ,  
\m \add maca\add* war ttᵉttuɣ řumurat nnec.   
\m
\v 142 Tasegda nnec d tasegda i řebda,  
\m Ccariɛa nnec d tidett.   
\m
\v 143 Ddiqet d teggʷudi řeqqfent ayi,  
\m \add maca\add* řumurat nnec  
\m daysent meẓri inu.   
\m
\v 144 Tasegda n cchadat nnec  
\m i řebda i teǧa.  
\m Sefhem ayi \add tent\add*, \add xenni\add* ad ddareɣ.   
\b  
\m
\v 145 \bd Quf.\bd* Řaɣiɣ s marra uř inu,  
\m arr-dd xafi, \add a\add* SIDI,  
\m \add xenni\add* ad ḥḍiɣ tiweṣṣa nnec.   
\m
\v 146 Necc řaɣiɣ-dd xak, fekk ayi,  
\m \add xenni\add* ad ḥḍiɣ marra cchadat nnec.   
\m
\v 147 Qbeř tuffut tuɣa ttřaɣiɣ  
\m ḥima ad ayi dd-tewced afus,  
\m rajiɣ awař nnec. \x ◘ \xo 119:147 \xt Izhd. 5:4; 88:14; 130:6\x*   
\m
\v 148 Tiṭṭawin inu faqent  
\m qbeř řweqt n wuḍuf n wecbar,  
\m ḥima ad xarrṣeɣ  
\m deg wawařen nnes. \x ◘ \xo 119:148 \xt Izhd. 63:2, 7; 90:4\x*   
\m
\v 149 Seř-dd ɣar tmijja inu  
\m ɛlaḥsab tamexsiwt nnec icewwaren,  
\m \add a\add* SIDI, arr-dd dayi tudart  
\m ɛlaḥsab lfarayiḍ nnec.   
\m
\v 150 Inni yarezzun ad ggen řefḍayeḥ,  
\m udsen ayi,  
\m aqa nitni ttaggʷejen aṭṭas  
\m x Ccariɛa nnec.   
\m
\v 151 Cek tudsed, \add a\add* SIDI,  
\m marra řumurat nnec d tidett i ǧan.   
\m
\v 152 \add Uřa\add* d aṭṭas zeg wami  
\m tuɣa ssneɣ cchadat nnec,  
\m maɣar Cek teggid tent i řebda.   
\b  
\m
\v 153 \bd Rix.\bd* Xzar ɣar řeɣben inu  
\m u tessnejmed ayi,  
\m maɣar war ttuɣ Ccariɛa nnec.   
\m
\v 154 Aɣ ayi tasɣart uca fekk ayi,  
\m arr-dd dayi tudart  
\m am mammec i d ayi tennid.   
\m
\v 155 Iggʷej usenjem x iɛeffanen,  
\m maɣar war arezzun tiweṣṣa nnec.   
\m
\v 156 \add A\add* SIDI, arreḥmet nnec d aṭṭas,  
\m arr-dd dayi tudart  
\m ɛlaḥsab lfarayiḍ n nnec.   
\m
\v 157 Inni d ayi ittdarracen  
\m d yinni d ayi iḥeṣṣaren  
\m aqa aten \add s\add* waṭṭas,  
\m \add maca\add* necc war ḥeyydeɣ ca  
\m x cchadat nnec.   
\m
\v 158 Ẓriɣ inni d ayi iɣdaren uca ɛiffeɣ \add ten\add*,  
\m maɣar nitni war ṭṭifen  
\m deg wawař nnec.   
\m
\v 159 Xzar, mammec ttexseɣ řumurat nnec,  
\m \add a\add* SIDI, arr-dd dayi tudart  
\m ɛlaḥsab tamexsiwt nnec icewwaren.   
\m
\v 160 Beddu n wawař nnec aqa-t d tidett,  
\m kuř řeḥkam iseggden zzayek  
\m aqa-t i řebda.   
\b  
\m
\v 161 \bd Cin.\bd* Řḥukkam darrcen xafi x walu,  
\m \add maca\add* uř inu tuɣa itteggʷed  
\m zeg wawař nnec.   
\m
\v 162 Necc farḥeɣ x lwaɛd nnec,  
\m amecnaw ijjen i ittaf  
\m ict n tkeccaḍt tameqqrant.   
\m
\v 163 Necc carrheɣ axarriq u ɛiffeɣ t,  
\m \add maca\add* ttexseɣ Ccariɛa nnec.   
\m
\v 164 Sebɛa n twařawin deg wass  
\m ṣebḥeɣ Cek  
\m x řeḥkamat n tsegda nnec.   
\m
\v 165 Inni ittexsen Ccariɛa nnec,  
\m aqa ɣarsen řehna tameqqrant,  
\m war din aẓru n uneqraḍ zzatsen.   
\m
\v 166 \add A\add* SIDI, ttrajiɣ asenjem nnec,  
\m u tteggeɣ ɛlaḥṣab tiweṣṣa nnec.   
\m
\v 167 Řeɛmar inu iḥeṭṭa cchadat nnec,  
\m ttexseɣ tent aṭṭas.   
\m
\v 168 Necc ḥeṭṭiɣ řumurat nnec  
\m d cchadat nnec,  
\m maɣar marra ibriden inu  
\m \add arzmen\add* zzatek.   
\b  
\m
\v 169 \bd Taf.\bd* \add A\add* SIDI, ejj ad ɣarek dd-yaweḍ  
\m uřaɣi inu zzat i wudem nnec,  
\m ewc ayi řeɛqeř ɛlaḥsab awař nnec.   
\m
\v 170 Ejj ad dd-tas tutra inu  
\m ɣar wudem nnec,  
\m fekk ayi am mammec i d ayi tennid.   
\m
\v 171 Iyencicen inu ad ucruren aṣebbeḥ  
\m am yijj n řɛunṣar,  
\m maɣar Cek tesseřmaded ayi  
\m tiweṣṣa nnec.   
\m
\v 172 Iřes inu ad yarr min tennid Cek,  
\m maɣar marra řumurat nnec seggden.   
\m
\v 173 Ejj afus nnec ad ayi igg twiza,  
\m maɣar ixḍareɣ řumurat nnec.   
\m
\v 174 \add A\add* SIDI, ttmeẓreɣ ɣar usenjem nnec,  
\m Ccariɛa nnec aqa dayes meẓri inu.   
\m
\v 175 Ejj řeɛmar inu ad iddar,  
\m ad Cek iṣebbeḥ,  
\m ad ayi ɛawnent lfarayiḍ nnec.   
\m
\v 176 Necc weddareɣ  
\m am yijj n uhuři iweddaren.  
\m Arzu x umsexxar nnec,  
\m maɣar war ttuɣ řumurat nnec. \x ◘ \xo 119:176 \xt Ica. 53:6; Lk. 15:4-7\x*   
\b  
\b  
\m  
\c 120
\m
\v 1 \add Izři n ugeɛɛed.\add*  
\b  
\m Necc řaɣiɣ ɣar SIDI di řeḥṣaret inu  
\m u Netta isřa ayi.   
\m
\v 2 \add A\add* SIDI, fekk řeɛmar inu  
\m zeg iyencicen issxarriqen,  
\m zeg iřes icemmten. \x ◘ \xo 120:2 \xt 1 Ṣm. 24:10; 26:19\x*   
\b  
\m
\v 3 Min d ac i ɣa yewc,  
\m min d ac i ɣa yarni iřes  
\m nni icemmten?   
\m
\v 4 Fřitcat n řqews qeḍɛent  
\m \add zeg ufus\add* n ijj n umjahed,  
\m ak-d řefḥem n tcejjart n tagga. \x ◘ \xo 120:4 \xt Izhd. 11:2; 59:8\x*   
\b  
\m
\v 5 Uct inu, aqa necc d abarrani di Macik,  
\m aqa zeddɣeɣ ɣar iqiḍan n Qidar!   
\m
\v 6 Aṭṭas i izdeɣ řeɛmar inu  
\m ɣar yinni icarrhen řehna.   
\m
\v 7 Necc d aheddan,  
\m maca xmi ɣa ssiwřeɣ,  
\m xenni arezzun amenɣi.   
\b  
\b  
\m  
\c 121
\m
\v 1 \add Izři n ugeɛɛed.\add*  
\b  
\m Necc ssgeɛɛdeɣ tiṭṭawin inu ɣar idurar,  
\m manis dd ɣa tas twiza inu?   
\m
\v 2 Twiza inu zi SIDI,  
\m wenni iggin ijenwan d temmurt.   
\b  
\m
\v 3 Netta war ittejji aḍar nnec ad ifarɣ,  
\m wenni cek iḥeṭṭan war ittnudum.   
\m
\v 4 Xzar, wenni iḥeṭṭan Israil  
\m war ittnudum u war itteṭṭeṣ.   
\b  
\m
\v 5 SIDI d ameḥḍay nnec,  
\m SIDI d tiři nnec ɣar ufus afusi nnec.   
\m
\v 6 Deg wass tafuct war cek teccit ca,  
\m uřa d taziri s ǧiřet.   
\b  
\m
\v 7 SIDI ad cek iḥḍa zi marra řɣar,  
\m Netta ad iḥḍa řeɛmar nnec. \f ◼ \fr 121:7 \ft \+fk řeɛmar nnec\ft  - ixs ad yini ‘tudart nnec’.\f*   
\m
\v 8 SIDI ad iḥḍa uffuɣ nnec d wadaf nnec,  
\m zi řexxu ař i řebda.   
\b  
\b  
\m  
\c 122
\m
\v 1 \add Izři n ugeɛɛed. N Dawud.\add*  
\b  
\m Necc farrḥeɣ umi d ayi nnan:  
\m “Neccin ad nuyur  
\m ɣar Taddart n SIDI.   
\m
\v 2 Iḍaren nneɣ bedden-dd  
\m ɣar tewwura nnec,  
\m \add a\add* Urcalim!”   
\m
\v 3 Urcalim tᵉttwabna am yict n tendint  
\m nni ittwacebbaren mliḥ  
\m ak-d yixef nnes.   
\b  
\m
\v 4 Ɣar dinni ttgeɛɛadent tqebbař,  
\m tiqebbař n SIDi,  
\m \add ɛlaḥsab\add* lfariḍa i Israil,  
\m ḥima ad qadan Isem n SIDI.   
\m
\v 5 Maɣar dinni bedden řekrasi n ccreɛ  
\m řekrasi n taddart n Dawud.   
\b  
\m
\v 6 Ttarem i řehna n Urcalim:  
\m “Aqa ad feřḥen inni cem ittexsen,   
\m
\v 7 ḥima ad din yiři řehna  
\m ɣar řḥiḍ n zzat nnem,  
\m uřa d řhudnet di řeqṣur nnem.”   
\m
\v 8 Di ṭṭweɛ n aytma  
\m d imeddukkař inu ad iniɣ:  
\m “Ad dayem yiři řehna!”   
\m
\v 9 Di ṭṭweɛ n Taddart n SIDI,  
\m AREBBI nneɣ,  
\m ad ac arzuɣ x min icnan.   
\b  
\b  
\m  
\c 123
\m
\v 1 \add Izři n ugeɛɛed.\add*  
\b  
\m Necc ssgeɛɛdeɣ tiṭṭawin inu ɣarek,  
\m Cek i iqqimen \add x řkursi nnes\add*  
\m deg ujenna. \x ◘ \xo 123:1 \xt Izhd. 2:4; Izhd. 113:5, 6; Izhd. 115:3\x*   
\m
\v 2 Xzar, am tiṭṭawin n isemɣan  
\m ɣar ufus n bab nsen,  
\m am tiṭṭawin n tayya  
\m ɣar ufus n lallas,  
\m ammu i \add xezzarent\add* tiṭṭawin nneɣ  
\m ɣar SIDI, AREBBI nneɣ,  
\m ař xaneɣ i ɣa iḥinn.   
\b  
\m
\v 3 Ḥinn xaneɣ, \add a\add* SIDI, ḥinn xaneɣ,  
\m maɣar yuza ɣarneɣ useḥqar.   
\m
\v 4 Řeɛmar nneɣ yuza ɣares aṭṭas  
\m zeg ustehzi n ayt n bu-nnfaxet,  
\m uřa zeg useḥqar n iɣebbanen.   
\b  
\b  
\m  
\c 124
\m
\v 1 \add Izři n ugeɛɛed. N Dawud.\add*  
\b  
\m Mři SIDI war kidneɣ ibedd!  
\m Ini \add t xenni ammu\add*, \add a\add* Israil,   
\m
\v 2 mři SIDI war kidneɣ ibedd,  
\m umi akidneɣ dd-kkaren iwdan,   
\b  
\m
\v 3 iři sarḍen aneɣ am neddar,  
\m umi yarɣa uxeyyeq nsen xaneɣ,   
\m
\v 4 iři aman feyyḍen xaneɣ,  
\m iři ict n řḥemřet tekka x řeɛmar nneɣ,   
\m
\v 5 iři aman iḥajen kkin x řeɛmar nneɣ.   
\b  
\m
\v 6 Ad ittwabarek SIDI,  
\m wenni war dd aneɣ ittejjin  
\m d takeccaḍt i teɣmas nsen.   
\m
\v 7 Řeɛmar nneɣ yarweř  
\m am wejḍiḍ zi řfex n unegmar.  
\m Řfex yareẓ u neccin nenfekk. \x ◘ \xo 124:7 \xt Awřn. 6:5\x*   
\b  
\m
\v 8 Twiza nneɣ tbedd deg Yisem n SIDI,  
\m wenni iggin ijenwan d temmurt. \x ◘ \xo 124:8 \xt Izhd. 121:2\x*   
\b  
\b  
\m  
\c 125
\m
\v 1 \add Izři n ugeɛɛed.\add*  
\b  
\m Inni ittecřen x SIDI,  
\m aqa aten am wedrar n Ṣihyun,  
\m wenni war ittenhezzin,  
\m \add maca\add* ittɣima i řebda. \x ◘ \xo 125:1 \xt Izhd. 9:5, 8, 12; Izhd.123:1 \x*   
\m
\v 2 Am mammec idurar  
\m quwwaren i Urcalim,  
\m ammu iquwwar SIDI i řgens nnes,  
\m zi řexxu ař řebda.   
\b  
\m
\v 3 Maɣar azeǧaḍ n řɣar  
\m war ittɣimi ittareyyeḥ  
\m x temmurt n imseggaden,  
\m ḥima imseggaden  
\m war sswiẓẓiḍen ifassen nsen ɣar řɣar.   
\b  
\m
\v 4 Iři ad yegg SIDI tacuni  
\m deg iṣebḥanen,  
\m deg inni iseggden s wuř, \f ◼ \fr 125:4 \ft \+fk s wuř\ft  - s Tɛibranit ‘s wuřawen’.\f*   
\m
\v 5 \add maca\add* inni i ɣa iḥeyyden \add zeg webrid\add*  
\m ɣar ibriden ifarɣen,  
\m ad ten issiggʷej SIDI \add jmiɛ\add*  
\m ak-d yinni itteggen řɣecc.  
\m \add Ad din yiři\add* řehna x Israil.   
\b  
\b  
\m  
\c 126
\m
\v 1 \add Izři n ugeɛɛed.\add*  
\b  
\m Umi isseɛqeb SIDI  
\m inni dd-idewřen ɣar Ṣihyun,  
\m tuɣa aneɣ axmi yinni itturjan.   
\m
\v 2 Tuɣa aqemmun nneɣ iccur  
\m s tḍeḥḥact,  
\m iřes nneɣ iccur s usřiwřew.  
\m Nnan jar řegnus:  
\m ‘SIDI igga daysen  
\m timesřayin timeqqranin!’ \x ◘ \xo 126:2 \xt Ayub 8:21\x*   
\m
\v 3 SIDI igga dayneɣ  
\m timesřayin timeqqranin,  
\m aqa neccin nfarḥ \add zzayes\add*.   
\m
\v 4 \add A\add* SIDI, qeǧeb tameḥbast nneɣ,  
\m am mammec \add ttqeǧbent\add* tiɣezratin  
\m \add Tammurt\add* n Ljanub.   
\m
\v 5 Inni izarrɛen s imeṭṭawen,  
\m ad mjaren s usřiwřew.   
\m
\v 6 Wenni yarebbun  
\m taxancet n zzariɛet,  
\m ittru xmi dd-iggur,  
\m \add maca\add* xmi dd ɣa yas,  
\m ad dd-yas s usřiwřew,  
\m ad yarbu tiqebbiḍin \add n imendi\add* nnes.   
\b  
\b  
\m  
\c 127
\m
\v 1 \add Izři n ugeɛɛed. N Suliman.\add*  
\b  
\m Mři war ibenni SIDI taddart,  
\m ad ssiḥřen ibennayen ixef nsen baṭeř.  
\m Mři war iḥeṭṭi SIDI x tendint,  
\m aɛessas ad iɛess baṭeř.   
\b  
\m
\v 2 Baṭeř aqa kenniw ad tekkarem zic,  
\m ad tᵉṭṭṣem tɛeḍřem,  
\m ad teccem aɣrum n řemḥayen,  
\m maɣar Netta ittic i-t  
\m i imɛizzen nnes deg yiḍeṣ.   
\b  
\m
\v 3 Xzar, arrawen d tasɣart  
\m \add i immewcen\add* zi SIDI,  
\m řɣiǧet n uɛeddis aqa-tt d řmunet.   
\m
\v 4 Am mammec \add jehdent\add* fřitcat n řqews  
\m deg ufus n weryaz,  
\m ammu i ǧan arrawen  
\m \add zeg iseggʷusa\add* n temẓi.   
\b  
\m
\v 5 Sseɛd n weryaz ijehden  
\m nni zzaysen iccur  
\m aqrab nnes n fřitcat n řqews.  
\m Nitni war ttseḍḥin ca  
\m umi ssawařen ak-d řɛedyan  
\m ɣar tewwart \add n tendint\add*.   
\b  
\b  
\m  
\c 128
\m
\v 1 \add Izři n ugeɛɛed.\add*  
\b  
\m Sseɛd n kuř ijj  
\m wenni itteggʷeden SIDI,  
\m wenni igguren deg ibriden nnes.   
\m
\v 2 Aqa ad tecced  
\m zeg warber n ifassen nnec,  
\m ad tiřid d amimun d lemliḥ.   
\b  
\m
\v 3 Tamɣart nnec ad tiři  
\m am ict n tzayart i dd-ittawyen řɣiǧet  
\m di taddart nnec,  
\m arrawen nnec ad iřin  
\m am iɣemmuyen n zzitun  
\m quwwaren i ṭṭabřa nnec.   
\b  
\m
\v 4 Ammu i ɣa ittwabarek weryaz ijehden  
\m nni itteggʷeden SIDI.   
\m
\v 5 SIDI ad cek ibarek zi Ṣihyun,  
\m u ad tẓared aqa Urcalim ad tiři mliḥ,  
\m marra ussan n tudart nnec,   
\m
\v 6 \add wah,\add* ad tẓared  
\m iḥenjiren n iḥenjiren nnec.  
\m Řehna \add ad yiři\add* x Israil.   
\b  
\b  
\m  
\c 129
\m
\v 1 \add Izři n ugeɛɛed.\add*  
\b  
\m “Zi temẓi inu  
\m ḥṣaren ayi aṭṭas n twařawin!”  
\m Ini \add t xenni ammu\add*, \add a\add* Israil,   
\m
\v 2 zi temẓi inu ḥṣaren ayi  
\m aṭṭas n twařawin,  
\m maca war d ayi zemmaren.   
\b  
\m
\v 3 Imcarrzen carzen x weɛrur inu,  
\m ggin řatarat n wecraz nsen d iziraren.   
\m
\v 4 SIDI d amsegged.  
\m Netta iqḍeɛ iseɣwan n iɛeffanen.   
\m
\v 5 Ejj marra inni icarrhen Ṣihyun,  
\m ad seḍḥan u ad ttwaɛarnen ɣar ḍeffar.   
\b  
\m
\v 6 Ejj i-ten ad dewřen  
\m am arbiɛ x tzeɣwin  
\m i ittisřaw qbeř i-t ɣa qeřɛen, \x ◘ \xo 129:6 \xt Ayub 8:12; 40:10\x*   
\m
\v 7 war zzayes ittɛemmar  
\m wenni imejjaren  
\m afus nnes,  
\m uřa d wenni ittceddan  
\m icuwwafen \add n imendi\add*  
\m aḥsin nnes,   
\m
\v 8 u ḥima imsebriden war qqaren:  
\m “Lbaraka n SIDI aqa-tt akidwem!”  
\m “Neccin nbarek kenniw s Yisem n SIDI.”   
\b  
\b  
\m  
\c 130
\m
\v 1 \add Izři n ugeɛɛed.\add*  
\b  
\m Zi řaǧaɣ řaɣiɣ-dd xak, \add a\add* SIDI!   
\m
\v 2 \add A\add* Sidi inu, seř i tmijja inu,  
\m ejj imezzuɣen nnec ad fetnen  
\m x tmijja n tutra inu!   
\b  
\m
\v 3 \add A\add* SIDi, mařa teḥḍiḍ  
\m řmuɛṣiyyat mliḥ,  
\m \add a\add* Sidi inu, man wen izemmaren  
\m ad iqqim ibedd. \x ◘ \xo 130:3 \xt Izhd. 143:2\x*   
\m
\v 4 Maca ɣarek asameḥ,  
\m maḥend ad zzayek ggʷeden. \x ◘ \xo 130:4 \xt 2 Ṣm. 24:14\x*   
\b  
\m
\v 5 Necc sitimeɣ di SIDI,  
\m řeɛmar inu \add iccur s\add* usitem,  
\m ttrajiɣ awař nnes, \x ◘ \xo 130:5 \xt Izhd. 27:14; 40:2; Ḥab. 2:3\x*   
\m
\v 6 Řeɛmar inu \add ittraja\add* Sidi inu,  
\m aṭṭas zeg iɛessasen \add ttrajan\add*  
\m ɣar \add u\add*teffu. \x ◘ \xo 130:6 \xt Izhd. 5:4; 119:147; 123:1, 2\x*   
\b  
\m
\v 7 Ejj Israil ad iraja SIDI,  
\m maɣar tamexsiwt icewwaren  
\m aqa-tt ɣar SIDI,  
\m ɣares afekki iceṭṭ.   
\m
\v 8 Netta ad issenjem Israil  
\m zi marra řmuɛṣiyyat nnes.   
\b  
\b  
\m  
\c 131
\m
\v 1 \add Izři n ugeɛɛed. N Dawud.\add*  
\b  
\m \add A\add* SIDI, uř inu  
\m war dayes bu nnfaxet,  
\m tiṭṭawin inu war daysent bu uneɛfar,  
\m war tteggeɣ ca timesřayin ujarent ayi  
\m niɣ d tinni d řeɛjeb i necc. \x ◘ \xo 131:1 \xt 2 Im. 32:25; Izhd. 101:5; Awřn. 6:17; 16:5\x*   
\b  
\m
\v 2 S tidett, ssareyyḥeɣ řeɛmar inu  
\m u ssesqareɣ t,  
\m am ijj n uniybu  
\m umi ittwassbedd wuṭṭuḍ  
\m ak-d yemmas,  
\m am ijj n uniybu  
\m umi ittwassbedd wuttuḍ  
\m ammu i iǧa řeɛmar inu dayi.   
\b  
\m
\v 3 Ejj Israil ad iraja SIDI,  
\m zi řexxu ař řebda.   
\b  
\b  
\m  
\c 132
\m
\v 1 \add Izři n ugeɛɛed.\add*  
\b  
\m \add A\add* SIDI, idar Dawud,  
\m \add idar\add* marra aweddeb nnes,   
\m
\v 2 mammec ijjuǧ i SIDI,  
\m iwaɛd i Umzemmar n Yaɛqub:   
\m
\v 3 “\add Uct\add*, mařa ad adfeɣ  
\m ɣar taqidunt n taddart inu,  
\m ad ḥebceɣ x qama n řectu inu, \x ◘ \xo 132:3 \xt 1 Im. 15:1\x*   
\m
\v 4 ad semmḥeɣ yiḍeṣ i tiṭṭawin inu,  
\m uřa d anudem i wabřiwen inu,   
\m
\v 5 qbeř i ɣa afeɣ amcan i SIDI,  
\m ict n Tzeddiɣt i SIDI,  
\m Amzemmar n Yaɛqub!”   
\b  
\m
\v 6 Xzar, nesřa x \add Ttabut\add* di Ifrata,  
\m nufa i-tt deg iyyaren n Yaɛar. \f ◼ \fr 132:6 \ft \+fk Yaɛar\ft  - ixs ad yini ‘Qaryat-Yaɛarim’ mani iǧan Ttabut awarni dd-idweř zi temmurt n Ifilisṭiniyyen (1 Ṣm. 6:21-7:2; 1 Im. 13:6).\f*   
\m
\v 7 Ad nadef ɣar tzeddiɣin nnes,  
\m ad nesjed i tnebdat n iḍaren nnes.   
\m
\v 8 Kkar, SIDI, \add uyur\add* ɣar arraḥet nnec,  
\m Cek d Ttabut n jjehd nnec.   
\m
\v 9 Ejj ikehhanen nnec  
\m ad yarḍen s tsegda,  
\m imtiqqan nnec ad sřiweřwen.   
\m
\v 10 War dd-tarri udem n umedhun nnec  
\m di ṭṭweɛ n umsexxar nnec Dawud.   
\b  
\m
\v 11 SIDI ijjuǧ i Dawud s řaman,  
\m ɛemmarṣ ad iḥeyyed Netta  
\m x tjaǧit nnes:  
\m “Zi řɣiǧet n uɛeddis nnec  
\m ad ssɣimeɣ \add ijj\add* x řɛarc nnec. \x ◘ \xo 132:11 \xt 2 Ṣm. 7:12; 1 Ij. 8:25; 2 Im. 6:16; Lk. 1:69 \x*   
\m
\v 12 Mařa iḥenjiren nnec  
\m ad ḥḍan Řɛahd inu d cchadat inu,  
\m tinni d asen i ɣa ssřemdeɣ,  
\m xenni uřa d iḥenjiren nsen  
\m ad qqimen x řkursi nnec i řebda.”   
\m
\v 13 Maɣar SIDI ifarz Ṣihyun,  
\m imeẓri tt d tazeddiɣt i Yixef nnes.   
\b  
\m
\v 14 “Wa d \add amcan n\add* arrahet inu i řebda,  
\m da i xseɣ ad zedɣeɣ, Necc xseɣ t. \x ◘ \xo 132:14 \xt Izhd. 68:17; 132:8 \x*   
\m
\v 15 Ad barkeɣ nniɛmet n Ṣihyun,  
\m ad ssjiwneɣ imezřaḍ nnes s weɣrum.   
\m
\v 16 Ad ssyarḍeɣ ikehhanen nnes  
\m s usenjem,  
\m imtiqqan nnes ad sřiweřwen s jjehd. \x ◘ \xo 132:16 \xt 2 Im. 6:41\x*   
\m
\v 17 Dinni ad ssɣemmyeɣ  
\m ijj n uyicc i Dawud,  
\m ijj n řefnar i umedhun inu  
\m sswejdeɣ \add t din\add*.\x ◘ \xo 132:17 \xt Lk. 1:69\x*   
\m
\v 18 Ad ssyarḍeɣ řɛedyan nnes  
\m s useḍḥi,  
\m maca ad xas innuwar  
\m ttaj \add n weɛzař\add* nnes.”   
\b  
\b  
\m  
\c 133
\m
\v 1 \add Izři n ugeɛɛed. N Dawud.\add*  
\b  
\m Xzar, mammec iṣbeḥ  
\m d mammec icna,  
\m mařa tawmat zeddɣen munen!   
\m
\v 2 Aya am zzect icnan x uzeǧif,  
\m tenni dd-ihekkwan x tmart,  
\m x tmart n Harun,  
\m thekkwa-dd  
\m x tma n ufurri n warruḍ nnes.   
\m
\v 3 Aya am nnda n \add wedrar n\add* Hirmun,  
\m wenni dd-ihekkwan x idurar n Ṣihyun,  
\m maɣar dinni yumur SIDI lbaraka \add nnes\add*,  
\m tudart i řebda.   
\b  
\b  
\m  
\c 134
\m
\v 1 \add Izři n ugeɛɛed.\add*  
\b  
\m Xzar, barkem SIDI,  
\m \add a\add* kenniw imsexxaren n SIDI,  
\m inni ibedden di Taddart n SIDI di ǧiřet.   
\m
\v 2 Sgeɛɛdem ifassen nwem  
\m ɣar Zzawect Iqeddsen  
\m u barkem SIDI.   
\b  
\m
\v 3 Ad cek ibarek SIDI zi Ṣihyun,  
\m Netta d wenni iggin ijenwan d temmurt.   
\b  
\b  
\m  
\c 135
\m
\v 1 Hallilu-Yah!  
\m Ṣebbḥem Isem n SIDI,  
\m ṣebbḥem \add xas\add*, \add a\add* imsexxaren n SIDI,   
\m
\v 2 \add kenniw\add* inni ibedden di Taddart n SIDI,  
\m di řemraḥat n Taddart n AREBBI nneɣ.   
\m
\v 3 Hallilu-Yah, maɣar SIDI iṣbeḥ,  
\m zehhdem i Yisem nnes,  
\m maɣar Netta d řeḍrafet.   
\m
\v 4 Maɣar SIDi ifarz Yaɛqub i Yixef nnes,  
\m Israil d agřa nnes. \x ◘ \xo 135:4 \xt Uf. 19:5; Aɛwd. 7:6; Tit. 2:14; 1 Bṭ. 2:9\x*   
\b  
\m
\v 5 Maɣar \bd necc\bd* ssneɣ aqa SIDI d ameqqran,  
\m Siditneɣ \add d ameqqran\add* x marra irebbiten.   
\m
\v 6 Marra min d as itteɛjiben i SIDI, igga i-t,  
\m deg ijenwan u x temmurt,  
\m di řebḥur u deg \add waman\add* ihewřen marra.   
\m
\v 7 Netta issgeɛɛed iseynuten  
\m zi ṭṭrufa n temmurt,  
\m Netta ittegg assamen ak-d wenẓar,  
\m ittgewwad asemmiḍ  
\m zi řehrit nnes ɣar barra. \x ◘ \xo 135:7 \xt Irm. 10:13; 51:16\x*   
\b  
\m
\v 8 Netta iwta imenza n Miṣra,  
\m zeg iwdan ař řmar. \x ◘ \xo 135:8 \xt Uf. 12:12, 29; Izhd. 78:51\x*   
\m
\v 9 Netta issekk řeɛřamat d lmuɛjizat  
\m di řwesṭ nnec, \add a\add* Miṣra,  
\m ɣar firɛun  
\m u ɣar marra imsexxaren nnes. \x ◘ \xo 135:9 \xt Uf. 7, 8, 9, 10, 14\x*   
\b  
\m
\v 10 Netta iwta aṭṭas n řegnus  
\m u inɣa ijeǧiden ijehden. \x ◘ \xo 135:10 \xt Yac. 12\x*   
\m
\v 11 Siḥun, ajeǧid n Imuriyyen,  
\m u Ɛuj, ajeǧid n Bacan,  
\m u marra tigeldiwin n Kenɛan.   
\m
\v 12 Iwca asen tammurt d tasɣart,  
\m d tasɣart i Israil, řgens nnes. \x ◘ \xo 135:12 \xt Izhd. 78:55\x*   
\b  
\m
\v 13 \add A\add* SIDI, Isem nnec ittɣima i řebda,  
\m axarreṣ dayek \add ad yiři\add* zi jjiř ař jjiř. \x ◘ \xo 135:13 \xt Uf. 3:15, Izhd. 102:13 \x*   
\m
\v 14 Maɣar SIDI ad yarr tasɣart  
\m ɣar řgens nnes,  
\m Netta ad iḥinn x imsexxaren nnes. \x ◘ \xo 135:14 \xt Aɛwd. 32:36, Izhd. 90:13\x*   
\b  
\m
\v 15 Řexyařat n l’aṣnam n řegnus  
\m aqa atent s nnuqart d wureɣ,  
\m ttwaggent s ifassen n iwdan.\x ◘ \xo 135:15 \xt Izhd. 115:4\x*   
\m
\v 16 Nitenti ɣarsent ijj n uqemmum,  
\m \add maca\add* war ssiwiřent,  
\m ɣarsen tiṭṭawin,  
\m \add maca\add* war ttwiřint,   
\m
\v 17 Nitenti ɣarsen timezzuɣen,  
\m \add maca\add* war ttesřint,  
\m walu asuḍi \add n nnefs\add*  
\m deg uqemmun nsen.   
\m
\v 18 Ad dewřen inni tent iggin  
\m am nitenti,  
\m marra wi xasent ittcař.   
\b  
\m
\v 19 \add A\add* taddart n Israil, barkem SIDI,  
\m \add a\add* taddart n Harun, barkem SIDI.   
\m
\v 20 \add A\add* taddart n Lawi, barkem SIDI!  
\m Ejj marra inni itteggʷeden SIDI,  
\m ad barken SIDI.   
\m
\v 21 Ad ittwabarek SIDI zi Ṣihyun,  
\m Netta d wenni izeddɣen di Urcalim.  
\m Hallilu-Yah!   
\b  
\b  
\m  
\c 136
\m
\v 1 Qadam SIDI, maɣar Netta iṣbeḥ,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda. \x ◘ \xo 136:1 \xt Ɛiz.3:11; Irm. 33:11\x*   
\m
\v 2 Qadam wenni d AREBBI x \add marra\add* irebbiten,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda.   
\m
\v 3 Qadam wenni d Sidi x \add marra\add* isiditen,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda,   
\b  
\m
\v 4 ... wenni itteggen lmuɛjizat timeqqranin,  
\m Netta waha,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda,   
\m
\v 5 ... wenni iggin ijenwan s řefhamet,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda, \x ◘ \xo 136:5 \xt Amz. 1:1\x*   
\m
\v 6 ... wenni iggin tammurt x waman,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda. \x ◘ \xo 136:6 \xt Izhd. 24:2\x*   
\b  
\m
\v 7 ... wenni iggin tifawin timeqqranin,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda, \x ◘ \xo 136:7 \xt Amz. 1:14\x*   
\m
\v 8 tafuct ḥima ad teḥkem x wass,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda, \x ◘ \xo 136:8 \xt Amz. 1:16\x*   
\m
\v 9 taziri d itran ḥima ad ḥekmen x ǧiřet,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda,   
\b  
\m
\v 10 ... wenni iwtin Imiṣriyyen  
\m deg imenza nsen,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda, \x ◘ \xo 136:10 \xt Uf. 12:29; Izhd. 78:43, 51\x*   
\m
\v 11 ... wenni dd-issuffɣen Israil  
\m zi řwest nsen,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda, \x ◘ \xo 136:11 \xt Uf. 12:31, 51; 13:3,17\x*   
\m
\v 12 s ufus ijehden d uɣiř ittwassgeɛɛden,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda. \x ◘ \xo 136:12 \xt Uf. 6:6\x*   
\b  
\m
\v 13 ... wenni ibḍan Řebḥar n Telga x tnayen,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda, \x ◘ \xo 136:13 \xt Uf. 14:21, 22; Izhd. 78:13\x*   
\m
\v 14 uca isseẓwa Israil di řwest nnes,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda.   
\m
\v 15 uca inḍar Firɛun di Řebḥar n Telga  
\m ak-d řɛeskar nnes,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda. \x ◘ \xo 136:15 \xt Uf. 14:24\x*   
\b  
\m
\v 16 ... wenni inedhen řgens nnes  
\m \add deg webrid\add* di řexřa,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda. \x ◘ \xo 136:16 \xt Uf. 15, 16, 17, 19; Izhd. 78:53\x*   
\m
\v 17 ... wenni iwtin ijeǧiden imeqqranen,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda, \x ◘ \xo 136:17 \xt Řxř. 21:24, 25,34,35; Yac. 12:1; Izhd. 135:10, 11\x*   
\m
\v 18 uca inɣa ijeǧiden ijehden,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda.   
\b  
\m
\v 19 \add Ɛqeř x\add* Siḥun, ajeǧid n Imuriyyen,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda,   
\m
\v 20 x Ɛuj, ajeǧid n Bacan,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda. \x ◘ \xo 136:20 \xt Aɛwd. 3:1-7\x*   
\m
\v 21 Tammurt nsen iwca i-tt d tasɣart,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda, \x ◘ \xo 136:21 \xt Yac. 12:6\x*   
\m
\v 22 d tasɣart i umsexxar nnes Israil,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda.   
\b  
\m
\v 23 Idar aneɣ di ddeǧ nneɣ,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda.   
\m
\v 24 Netta ikkes aneɣ-dd zeg \add ifassen\add*  
\m \add n\add* yinni d aneɣ iḥṣaren,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda.   
\m
\v 25 Netta d wenni itticen macca  
\m i marra imuddaren,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda. \f ◼ \fr 136:25 \ft \+fk i marra imuddaren\ft  - s Tɛibranit ‘i marra aysum’, ixs ad yini i marra iwdan u i marra imuddaren (lḥayawanat).\f*   
\m
\v 26 Qadam Arebbi n ijenwan,  
\m maɣar tamexsiwt nnes icewwaren  
\m tᵉttɣima i řebda.   
\b  
\b  
\m  
\c 137
\m
\v 1 Ɣar iɣezran n Babil,  
\m dinni i tuɣa nettɣima,  
\m nru ɛawed xmi tuɣa nettidar Ṣihyun.   
\m
\v 2 Nuyeř řgambriyat nneɣ  
\m ɣar iṣefṣafen \add i iǧan\add* di řwest nnes.   
\b  
\m
\v 3 Maɣar inni d aneɣ iḥebbsen  
\m ttaren zzayneɣ dinni  
\m \add ad nɣennej\add* awařen n ijj n yezři,  
\m inni d aneɣ iḥeṣṣaren  
\m ttaren ca n řḥajjet issefraḥen.  
\m \add Nitni nnan\add*: “Ɣennjem zeɛma  
\m \add ijj zeg\add* izřan n Ṣihyun i neccin!” \x ◘ \xo 137:3 \xt Izhd. 79:1 \x*   
\b  
\m
\v 4 Mammec nzemmar ad nɣennej  
\m ijj n yezři n SIDI di temmurt n midden?   
\m
\v 5 Mařa necc ttuɣ cem, \add a\add* Urcalim,  
\m ejj \add xenni\add* ad ittu ufus afusi ixef nnes.   
\b  
\m
\v 6 Ejj ad ayi iřṣeq iřes inu x waneɣ inu,  
\m mařa war cem ttidareɣ,  
\m mařa war ssɛuǧiɣ Urcalim  
\m x řefraḥet inu tameqqrant qaɛ.   
\b  
\m
\v 7 \add A\add* SIDI, ɛqeř x ayt n Idum,  
\m \add deg\add* wass n Urcalim,  
\m inni iqqaren: “Ɛarram \add tt\add*, ɛarram \add tt\add*,  
\m ař dsas nnes!” \x ◘ \xo 137:7 \xt Irm. 49:7; Ḥiz. 25:12\x*   
\b  
\m
\v 8 \add A\add* yeǧis n Babil,  
\m \add cem\add* tenni ittwassḥuzen i wareddeǧ,  
\m sseɛd n yinni d am  
\m i ɣa ixeǧṣen tameggit \add iɛeffnen\add*  
\m i dayneɣ teggid. \x ◘ \xo 137:8 \xt Irm. 50:15, 29; Asa. 18:6\x*   
\m
\v 9 Sseɛd n wenni i ɣa iṭṭfen  
\m iḥenjiren nwem imeẓyanen,  
\m ad ten iřbez x teṣḍart. \x ◘ \xo 137:9 \xt Ica. 13:16\x*   
\b  
\b  
\m  
\c 138
\m
\v 1 \add N Dawud.\add*  
\b  
\m Ad Cek qadiɣ s marra uř inu,  
\m ad Cek zehhdeɣ zzat i irebbiten.   
\m
\v 2 Ad bendqeɣ ɣar Zzawect nnec  
\m Tameqqrant iqeddsen,  
\m ad qadiɣ Isem nnec  
\m x tmexsiwt nnec icewwaren  
\m u x řaman nnec,  
\m maɣar Cek tessemɣared  
\m awař nnec x marra  
\m \add min ittwafen ɛad\add*  
\m \add deg\add* Yisem nnec.   
\b  
\m
\v 3 Deg wass řami xak dd-řaɣiɣ,  
\m tarrid-dd xafi,  
\m Cek tewcid jjehd i řeɛmar inu.   
\m
\v 4 Marra ijeǧiden n temmurt  
\m ad Cek qadan, \add a\add* SIDI,  
\m xmi ttesřan awařen  
\m zeg uqemmum nnec.   
\m
\v 5 Ad ɣennjen x ibriden n SIDI,  
\m maɣar aɛuǧi n SIDI d ameqqran.   
\m
\v 6 Maɣar waxxa ittwassuɛřa SIDI aṭṭas,  
\m \add ɛad\add* ixezzar-dd ɣar umwaḍeɛ,  
\m \add maca\add* bu-nnfaxet issen i-t zi řaggʷaj. \x ◘ \xo 138:6 \xt Izhd. 113:6, 7\x*   
\b  
\m
\v 7 Mařa uyureɣ di řwesṭ n řeḥṣaret,  
\m ad ayi dd-tᵉttarred ɣar tudart.  
\m Cek tesswiẓẓḍed afus nnec  
\m ḍidd i weɣḍab n řɛedyan inu,  
\m afus nnec afusi issenjem ayi.   
\m
\v 8 SIDI ad t ikemmeř i necc.  
\m \add A\add* SIDI, tamexsiwt nnec icewwaren  
\m tᵉttɣima i řebda,  
\m řefɛayeř n ifassen nnec  
\m war ten tarexxud.   
\b  
\b  
\m  
\c 139
\m
\v 1 \add I umeqqran n imeɣnajen. N Dawud. Azehhed.\add*  
\b  
\m \add A\add* SIDI, Cek tbeqqced ayi u tessned ayi.   
\m
\v 2 Cek tessned aɣimi inu d ubeddi inu,  
\m zi řaggʷaj tfehhmed ixarriṣen inu.   
\m
\v 3 Xmi ggureɣ u xmi ṭṭṣeɣ tarezzud dayi,  
\m aqa Cek tessned marra ibriden inu.   
\m
\v 4 Minzi war din uřa d ijj n wawař  
\m x yiřes inu, u xzar,  
\m Cek a SIDI, tessned t kuřci.   
\m
\v 5 Cek tḥeṣṣared ayi zi ḍeffar u zi zzat,  
\m tessarsed xafi tařeqqa n ufus nnec.   
\m
\v 6 Tussna-ya d atebhet i necc,  
\m tuɛřa xafi, war zemmareɣ ad tt awḍeɣ.   
\m
\v 7 Ɣar mani \add zemmareɣ\add*  
\m ad raḥeɣ zi Arruḥ nnec,  
\m ɣar mani ɣa arewřeɣ zeg wudem nnec?   
\m
\v 8 Mařa geɛɛdeɣ ɣar ujenna,  
\m aqa Cek dinni,  
\m \add mařa\add* ggiɣ řaxart d tassut inu, xzar,  
\m aqa Cek uřa dinni, \x ◘ \xo 139:8 \xt Ayub 26:6; Ɛam. 9:2, 3, 4; Ɛbr. 4:13\x*   
\m
\v 9 \add Mařa\add* ksiɣ afriwen \add am tfawt n\add* řefjar,  
\m ad zedɣeɣ ɣar uneggar qaɛ n řebḥar, \f ◼ \fr 139:9 \ft \+fk řebḥar\ft  - niɣ ‘il’.\f*   
\m
\v 10 \add xenni\add* uřa dinni ad ayi indeh ufus nnec,  
\m \add afus nnec\add* afusi ad ayi iṭṭef.   
\m
\v 11 Mařa nniɣ: “Iwa taǧest, wḍa-dd xafi,  
\m \add xenni\add* ǧiřet d tfawt i d ayi iquwwaren.   
\m
\v 12 I Cek taǧest war teǧi d ṭṭřam,  
\m \add i Cek\add* ǧiřet tᵉttegg tfawt am uziř,  
\m \add i Cek\add* taǧest \add aqa-tt\add* am tfawt.   
\b  
\m
\v 13 \add Wah,\add* Cek txeřqed-dd tiẓẓař inu,  
\m tmuded ayi deg uɛeddis n yemma.   
\m
\v 14 Qadiɣ Cek umi dd-ttwaxeřqeɣ  
\m zeg ict n tebridt n řeɛjeb d tameqqrant.  
\m Timegga nnec d lmuɛjizat,  
\m řeɛmar inu tessen t \add mliḥ\add* qaɛ.   
\m
\v 15 Ixsan inu tuɣa war xak nnuffaren,  
\m umi ttwaggeɣ s tnuffra,  
\m ttwamudeɣ \add am ijj n uburḍa\add*  
\m di řaǧaɣ n temmurt. \x ◘ \xo 139:15 \xt Ayub 10:8, 10; Amb. 11:5 \x*   
\m
\v 16 Tiṭṭawin nnec ẓrint  
\m abeddu inu iḍefṣen.  
\m Deg wedlis nnec ittwannḍen  
\m aqa marra yuran,  
\m aqa ussan i tuɣa ttwaggen,  
\m jar asen \add uřa d ass\add* amezwaru  
\m \add n ubeddu inu\add*.   
\m
\v 17 Mammec ɣari ttɛizzan  
\m ixarriṣen nnec, \add a\add* Arebbi,  
\m mammec imɣar ubarru nsen!   
\m
\v 18 Mařa xseɣ ad ten ḥesbeɣ,  
\m aqa aten ktar aṭṭas zeg yejdi,  
\m \add u\add* xmi faqeɣ, aqa ayi ɛad akidek.   
\b  
\m
\v 19 \add A\add* Arebbi, meɛlik i ɣa tenɣed aɛeffan,  
\m \add meɛlik\add* i ɣa tejjed iryazen  
\m i issazzařen idammen  
\m ad xafi aggʷejjen,   
\m
\v 20 inni xak issawařen s tḥraymect,  
\m řɛedyan nnec  
\m inni ineṭṭqen \add Isem nnec\add* di řbaṭeř. \x ◘ \xo 139:20 \xt Uf.20:7\x*   
\m
\v 21 \add A\add* SIDI, ma war carrheɣ  
\m inni Cek icarrhen,  
\m u ma war ttɛiffeɣ  
\m inni akidek ittemɛařan?   
\m
\v 22 Necc carrheɣ ten  
\m s ijj n wecrah ikmeř,  
\m aqa nitni dewřen ayi d řɛedyan.   
\m
\v 23 Arzu xafi, \add a\add* Arebbi, ssen uř inu,  
\m qeǧeb ayi u ssen ixarriṣen inu. \x ◘ \xo 139:23 \xt Ayub 31:6; Izhd. 26:2\x*   
\m
\v 24 Xzar-dd, ma aqa ayi  
\m di ca n webrid n řeqjaḥet  
\m u ndeh ayi ɣar webrid n řebda.   
\b  
\b  
\m  
\c 140
\m
\v 1 \add I umeqqran n imeɣnajen. Azehhed n Dawud.\add*   
\b  
\m
\v 2 Fekk ayi zi bnadem d aɛeffan, \add a\add* SIDI,  
\m ḥḍa ayi zeg weryaz n lɛunf,   
\m
\v 3 zeg yinni ittxarraṣen  
\m deg wuř \add nsen\add* di řɣar,  
\m \add u\add* ssekkaren imenɣan di marra ussan.   
\m
\v 4 Nitni ssqeḍɛen iřsawen nsen  
\m am yijj n ufiɣar,  
\m ssem iḥma aqa-t sadu iyencicen nsen.  
\m Silah. \x ◘ \xo 140:4 \xt Izhd. 58:5; Rum. 3:13\x*   
\b  
\m
\v 5 Ḥḍa xafi, \add a\add* SIDI, zeg ifassen n iɛeffanen,  
\m ḥḍa ayi zeg iryazen n lɛunf,  
\m inni yarezzun ad ayi ɣeḍřen  
\m ɣar temmurt. \f ◼ \fr 140:5 \ft \+fk inni yarezzun ad ayi ɣeḍřen ɣar temmurt\ft  - s Tɛibranit ‘inni yarezzun ad ssneqraden iḍaren inu’.\f*   
\m
\v 6 Ayt n bu-nnfaxet  
\m ssnuffaren xafi ijj n řfex,  
\m ttbezzaɛen tiseɣwin  
\m am yict n tracca  
\m ɣar uɣezdis n umesraq,  
\m aqa tteggen ayi tixefcin. Silah. \x ◘ \xo 140:6 \xt Irm. 18:22\x*   
\b  
\m
\v 7 Necc nniɣ i SIDI: “Cek d Arebbi inu!”  
\m Seř, \add a\add* SIDI, ɣar tmijja n tutra inu.   
\m
\v 8 \add A\add* SIDI, Sidi inu, jjehd n usenjem inu,  
\m deř azeǧif inu deg wass n \add řḥess\add* n řesnaḥ.   
\m
\v 9 \add A\add* SIDI, war ttejji aɛeffan ad yarr meẓri.  
\m War ttegg ttasiɛ i wenway nnes iɛeffnen,  
\m ařami ɣa ssɛuǧen ixef nsen. Silah.   
\b  
\m
\v 10 \add X\add* uzeǧif n \add marra\add* inni d ayi dd-innḍen,  
\m iři ad ten ideř uceqqef n iyencicen nsen,   
\m
\v 11 ejj ad xasen kebben řefḥem,  
\m \add iři\add* Netta ad ten iɣḍer di tmessi,  
\m di řḥemřat yuǧɣen,  
\m ḥima war ttekkaren ɛad.   
\m
\v 12 Ejj aryaz \add i iceqqfen\add* s yiřes  
\m war ittɣimi ibedd x temmurt,  
\m ejj ad iɛarn řɣar deɣya  
\m aryaz bu-řexcunet.   
\b  
\m
\v 13 Necc ssneɣ, aqa SIDI ad isseqfeř  
\m ddeɛwet n řmusakin, řḥeqq n imezřaḍ.   
\m
\v 14 S tidett, imseggaden  
\m ad qadan Isem nnec,  
\m inni igguren nican ad qqimen  
\m zzat i wudem nnec.   
\b  
\b  
\m  
\c 141
\m
\v 1 \add Azehhed n Dawud.\add*  
\b  
\m \add A\add* SIDI, necc ttřaɣiɣ ɣarek,  
\m deɣyat ɣari,  
\m seř ɣar tmijja inu  
\m xmi dd xak i ɣa ttřaɣiɣ.   
\m
\v 2 Iři ad tbedd tẓaǧit inu  
\m am řebxur \add ittfuḥen\add* zzat i wudem nnec,  
\m uřa d asgeɛɛed n ifassen inu  
\m am tewhibt n tmeddit. \x ◘ \xo 141:2 \xt Uf. 29:30; Řxř. 28:1-8; Asa. 5:8; 8:3\x*   
\b  
\m
\v 3 \add A\add* SIDI, egg ijj n uɛessas  
\m ɣar uqemmum inu,  
\m ḥḍa tawwart n iyencicen inu.   
\m
\v 4 Egg aqa uř inu war ittnejbid  
\m ɣar ict n tmesřact d taɛeffant,  
\m maḥend ad ggeɣ timegga s řɣecc  
\m ak-d iryazen nni itteggen řmuɛṣiyyet,  
\m egg aqa necc war ttᵉtteɣ  
\m zi tazyuḍi nsen.   
\b  
\m
\v 5 Ejj amsegged ad ayi iwwet,  
\m \add maɣar aya\add* d tamexsiwt icewwaren,  
\m mařa netta ittsegged ayi,  
\m aya d zzect x uzeǧif inu,  
\m ad tt iqbeř uzeǧif inu.  
\m \add Wah\add*, uřa ammu ad tiři tẓaǧit inu ɛad  
\m ḍidd i tmegga nsen iɛeffnen. \f ◼ \fr 141:5 \ft \+fk ḍidd i tmegga nsen\ft  - ixs ad yini: ḍidd i tmegga iɛeffnen n yeryazen nni itteggen řmuɛṣiyyet (xẓar ayet 4).\f*   
\m
\v 6 Řquḍat nsen mmenḍaren swadday  
\m x uɣezdis n jjarf,  
\m aqa sřin belli awařen inu ḍarfen.   
\m
\v 7 Axmi tᵉttwacarz  
\m u tennurzem temmurt,  
\m ammu i ttwazeǧɛen iɣsan nneɣ  
\m ɣar uqemmum n řaxart. \x ◘ \xo 141:7 \xt Ḥiz. 37:1, 11, 12\x*   
\b  
\m
\v 8 Maca tiṭṭawin inu  
\m xezzarent-i-dd ɣarek,  
\m \add a\add* SIDI, Sidi inu,  
\m necc arekkwařeɣ ɣarek,  
\m war ttejji řeɛmar inu yarxef.   
\m
\v 9 Siggʷej ayi i wemnaɛ n řfex  
\m i d ayi medyen,  
\m zi texcifin n yinni itteggen řmuɛṣiyyet.   
\m
\v 10 Iři iɛeffanen ad wḍan marra  
\m di traccawin nsen,  
\m min ɣa kkeɣ ɛedduɣ.   
\b  
\b  
\m  
\c 142
\m
\v 1 \add Axemmi n Dawud.\add*  
\m \add Taẓaǧit umi t tuɣa deg yefri.\add*   
\b  
\m
\v 2 S tmijja inu sɣuyeɣ ɣar SIDI,  
\m s tmijja inu ḥeccmeɣ SIDI.   
\m
\v 3 Necc ttzeǧaɛeɣ ifeqquṣen inu  
\m zzat i wudem nnes,  
\m ssargbeɣ \add as\add* řeḥṣaret inu  
\m zzat i wudem nnes.   
\m
\v 4 Mařa buḥbeř inu idqeř xafi aṭṭas,  
\m Cek tessned amesruq inu.  
\b  
\m Nitni ssnuffaren ayi ijj n řfex  
\m deg webrid nni di ɣa uyureɣ. \x ◘ \xo 142:4 \xt Izhd. 77:4\x*   
\m
\v 5 Sweḍ ɣar ufusi, u xzar,  
\m war din tuɣi ḥed  
\m i d ayi ɣa iwcen taynit,  
\m ittwakkes ayi qaɛ mani ɣa arewřeɣ,  
\m war din tuɣi uřa d ijj  
\m i ɣa isseqsan x řeɛmar inu.   
\m
\v 6 Necc sɣuyyuɣ-dd ɣarek, \add a\add* SIDI. Qqareɣ:  
\m “Cek d amcan inu n tarewřa,  
\m tasɣart inu di temmurt n yinni iddaren.\x ◘ \xo 142:6 \xt Izhd. 16:5\x*   
\b  
\m
\v 7 Ḥḍa x uɣuyyi inu, maɣar fniɣ qaɛ.  
\m Fekk ayi zeg inni d ayi iḍeffaren,  
\m maɣar nitni jehden xafi. \x ◘ \xo 142:7 \xt Izhd. 41:2; 79:8; 116:6\x*   
\m
\v 8 Suffeɣ řeɛmar inu zi řeḥbes  
\m maḥend ad qadiɣ Isem nnec.  
\m Imseggaden ad ayi dd-nnḍen,  
\m maɣar Cek tᵉttegged dayi s tcuni.”   
\b  
\b  
\m  
\c 143
\m
\v 1 \add Azehhed n Dawud.\add*  
\b  
\m \add A\add* SIDI, seř i tẓaǧit inu,  
\m sḥess i tutra inu.  
\m Arr-dd xafi ɛlaḥsab tidett nnec,  
\m ɛlaḥsab tasegda nnec.   
\m
\v 2 War ttegg ccreɛ ak-d umsexxar nnec,  
\m maɣar uřa d ijj zeg inni iddaren  
\m ad yiři d amsegged zzat i wudem nnec. \x ◘ \xo 143:2 \xt Rum. 3, 4; Gal. 3, 4 \x*   
\m
\v 3 Minzi řeɛdu ittdarrac řeɛmar inu,  
\m iɛeffes x tudart inu ɣar temmurt,  
\m isszeddeɣ ayi deg imucan n ṭṭřam,  
\m am yinni immuten zi mecḥař uya.   
\b  
\m
\v 4 Buḥbeř inu ittefciř xafi,  
\m uř inu yarewweɛ di daxeř inu.   
\m
\v 5 Necc ttɛeqřeɣ x wussan iɛdun,  
\m ttxemmameɣ di marra timegga nnec,  
\m ttxarrṣeɣ di řefɛayeř n ifassen nnec. \x ◘ \xo 143:5 \xt Izhd. 77:6, 11\x*   
\m
\v 6 Necc ttbezzɛeɣ ifassen inu ɣarek,  
\m řeɛmar inu aqa-t zzatek  
\m am ict n temmurt iffuden. Silah.   
\b  
\m
\v 7 Arr-dd xafi deɣya, \add a\add* SIDI,  
\m buḥbeř inu ittefciř,  
\m war ssnuffara udem nnec zzayi,  
\m maḥend war ddikkwiřeɣ  
\m am yinni dd-ihekkwan  
\m deg weḥfur \add n wenḍeř\add*.   
\m
\v 8 Ejj ayi ad sřeɣ  
\m i tmexsiwt nnec icewwaren  
\m ɣar teffut,  
\m maɣar ttecřeɣ xak.  
\m Scen ayi abrid i ɣa uyureɣ,  
\m maɣar ssgeɛɛdeɣ řeɛmar inu ɣarek. \x ◘ \xo 143:8 \xt Izhd. 25:1\x*   
\b  
\m
\v 9 \add A\add* SIDI, kkes ayi i řɛedyan inu,  
\m ɣarek i ɣa arewřeɣ.   
\m
\v 10 Seřmed ayi ad ggeɣ  
\m \add min iǧan\add* i arḍa nnec,  
\m maɣar Cek d AREBBI inu.  
\m Ejj Arruḥ nnec iṣebḥen ad ayi indeh  
\m deg ict n temmurt iwaṭan.   
\m
\v 11 \add A\add* SIDI, arr-dd dayi tudart  
\m di ṭṭweɛ n Yisem nnec.  
\m S tsegda nnec,  
\m suffeɣ řeɛmar inu zi řeḥṣaret,   
\m
\v 12 areddeǧ řɛedyan inu  
\m di tmexsiwt nnec icewwaren,  
\m qḍa x marra inni d ayi iḥeṣṣaren,  
\m maɣar necc d umsexxar nnec. \x ◘ \xo 143:12 \xt Izhd. 86:16; 116:16\x*   
\b  
\b  
\m  
\c 144
\m
\v 1 \add N Dawud.\add*  
\b  
\m Ad ittwabarek SIDI, Taṣḍart inu,  
\m wenni isseřmaden ifassen inu i umenɣi,  
\m iḍewḍan inu i řḥarb. \x ◘ \xo 144:1 \xt 2 Ṣm. 22:35; Izhd. 18:35\x*   
\m
\v 2 \add Cek i d ayi teǧid\add* d ameddukkeř inu  
\m i dayes tamexsiwt icewwaren,  
\m uřa d lburj inu, lburj inu yuɛřan  
\m d amsenjem inu,  
\m taseddart inu i useřqi,  
\m d wenni ɣar arekkwařeɣ,  
\m d wenni d ayi isswaḍḍɛen řgens inu. \x ◘ \xo 144:2 \xt 2 Ṣm. 22:48; Izhd. 18:48\x*   
\b  
\m
\v 3 \add A\add* SIDI, min iɛna bnadem,  
\m aqa Cek texsed ad t tessned?  
\m Mmis n bnadem,  
\m aqa Cek tᵉttxarriṣed dayes? \x ◘ \xo 144:3 \xt Ayub 7:17; Izhd. 8:5; 31:8; Ɛbr. 2:6\x*   
\m
\v 4 Bnadem amecnaw řefwar,  
\m ussan nnes ad ɛdun am tiři. \x ◘ \xo 144:4 \xt Ayub 8:9; 14:2, 3; Izhd. 39:6; 62:10; 102:12; Yaɛ. 4:14\x*   
\b  
\m
\v 5 Meyyeř ijenwan nnec, \add a\add* SIDI, hwa-dd.  
\m Ḥada idurar, \add xenni\add* ad ggen ddexxan. \x ◘ \xo 144:5 \xt Izhd. 18:8, 10; 104:32\x*   
\m
\v 6 Ẓaryeḍ assamen u zeǧeɛ i-ten,  
\m sekk fřitcat nnec u sxarweḍ i-ten. \x ◘ \xo 144:6 \xt 1 Ṣm. 7:10; 2 Ṣm. 22:8; Izhd. 18:15\x*   
\m
\v 7 Swiẓẓeḍ ifassen nnec zi sennej,  
\m suffeɣ ayi-dd u fekk ayi  
\m zi \add řḥemřat n\add* waman timeqqranin,  
\m zeg ufus n ibarraniyyen,   
\m
\v 8 maɣar aqemmum nsen iqqar ixarriqen,  
\m afus nsen afusi d ijj n ufus \add iccur\add* s řɣecc.   
\b  
\m
\v 9 \add A\add* AREBBI, ad ac ɣennjeɣ  
\m ijj n yezři d n jdid i Cek,  
\m s lharpa u \add s lɛud\add* s ɛecra n ifiřan  
\m ad ac zehhdeɣ.   
\m
\v 10 Cek d wenni issawaḍen  
\m asenjem i ijejǧiden,  
\m d wenni ifekken amsexxar nnes Dawud  
\m zi ssif aɛeffan,   
\m
\v 11 suffeɣ ayi-dd u fekk ayi  
\m zeg ufus n tarwa n ubarrani,  
\m zeg wenni ɣar iǧa uqemmum  
\m i iqqaren mɣir ixarriqen,  
\m u zeg wenni ɣar iǧa ufus afusi  
\m \add iccur\add* s řɣecc.   
\b  
\m
\v 12 Meɛlik iḥenjiren nneɣ  
\m ad iřin am yiɣeddiwen,  
\m inni imɣaren \add ɛad\add* di temẓi nsen,  
\m yessitneɣ am tɣemmar  
\m i ggin s ukeccuḍ  
\m \add s ɛřam kuř arcamen\add*,  
\m ggin tent i yict n zzawect iqeddsen.   
\m
\v 13 \add Ad ccuren\add* řehrit nneɣ,  
\m ad wcen zzad awarni zzad,  
\m ad yarni wuǧi nneɣ s řuřuf n tseqqar,  
\m s ɛecra n řuřuf n tseqqar  
\m di ddmani n tarewsa nneɣ.   
\m
\v 14 Ad ḥemřen imwan nneɣ mliḥ,  
\m war ittiři ɛad uhjam  
\m niɣ d uffuɣ \add i umenɣi\add*  
\m uřa d iɣuyyan deg wazzayen nneɣ.   
\m
\v 15 Sseɛd n řgens nni iǧan amya.  
\m Sseɛd n řgens nni zi AREBBI nsen d SIDI.   
\b  
\b  
\m  
\c 145
\m
\v 1 \add Izři n uṣebbeḥ n Dawud.\add*  
\b  
\m \bd Alif.\bd* \add A\add*, AREBBI inu, Ajeǧid,  
\m necc ad Cek ssɛuǧeɣ,  
\m ad barkeɣ Isem nnec i řebda qaɛ.   
\m
\v 2 \bd Bit.\bd* Kuř ass ad Cek barkeɣ,  
\m ad ssemɣareɣ Isem nnec i řebda qaɛ.   
\m
\v 3 \bd Gimel.\bd* SIDI d ameqqran,  
\m issdiheǧ asemɣar aṭṭas,  
\m řemɣaret nnes war dayes bu tarezzut. \x ◘ \xo 145:3 \xt Ayub 5:9; Izhd. 18:4; 150:2\x*   
\m
\v 4 \bd Dalit.\bd* Jjiř awarni jjiř  
\m ad issemɣar řexdayem nnec,  
\m ad barrḥen s tmegga nnec timeqqranin. \x ◘ \xo 145:4 \xt Aɛwd. 4:9; 6:7\x*   
\m
\v 5 \bd Hi.\bd* Necc ad ssiwřeɣ  
\m x tissiqt n uɛuǧi n lɛaḍama nnec,  
\m x řexbar n lmuɛjizat nnec. \f ◼ \fr 145:5 \ft \+fk x řexbar\ft  - s Tɛibranit ‘n wawařen’.\f*   
\m
\v 6 \bd Waw.\bd* Nitni ad ssiwřen  
\m x jjhed n tmegga nnec issaggʷaden,  
\m necc ad barrḥeɣ s řemɣaret nnec.   
\m
\v 7 \bd Zayin.\bd* Řidaret n tcuni nnec ifeyyḍen  
\m ad tt ggen \add d ijj n řɛunṣar ittcurcur\add*,  
\m ad sřiwřiwen i tsegda nnec. \x ◘ \xo 145:7 \xt Izhd. 119:171\x*   
\m
\v 8 \bd Xit.\bd* SIDI d arḥim d aḥnin,  
\m ɣares ttasiɛ n řxaḍar  
\m d waṭṭas n tmexsiwt icewwaren. \x ◘ \xo 145:8 \xt Uf. 34:6, 7; Řxř. 14:18; Izhd. 86:15; 103:8\x*   
\m
\v 9 \bd Tit.\bd* SIDI d aṣebḥan i marra,  
\m arreḥmet nnes aqa-tt tiwa  
\m marra timegga nnes.   
\m
\v 10 \bd Yud.\bd* Marra timegga nnec,  
\m \add a\add* SIDI, ad Cek qadint,  
\m imtiqqan nnec ad Cek barken.   
\m
\v 11 \bd Kaf.\bd* Nitni ad ssiwřen  
\m x uɛuǧi n Tgeldit nnec, ad ssiwřen  
\m x timegga nnec timeqqranin,   
\m
\v 12 \bd Lamid.\bd* ḥima ad barrḥen  
\m s tmegga nnes timeqqranin  
\m i tarwa n bnadem,  
\m s uɛuǧi n lɛaḍama n Tgeldit nnes.   
\m
\v 13 \bd Mim.\bd* Tageldit nnec  
\m d ict n Tgeldit i řebda,  
\m řeḥkamet nnec \add ad tiři\add* x kuř jjiř.   
\m
\v 14 \bd Samix.\bd* SIDI ittsenned  
\m marra inni iwḍan,  
\m ittseggem marra inni iqwisen.   
\m
\v 15 \bd Ɛayin.\bd* Marra tiṭṭawin ttrajant Cek,  
\m Cek tᵉtticed asen macca  
\m di řweqt nnes \add ittwaggen\add*. \x ◘ \xo 145:15 \xt Izhd. 104:27\x*   
\m
\v 16 \bd Pi.\bd* Cek tarezzmed afus nnec,  
\m tessyawaned marra min iddaren  
\m \add ak-d\add* min ixs řxaḍar \add nsen\add*.   
\m
\v 17 \bd Tsadi.\bd* SIDI aqa-t nican  
\m di marra ibriden nnes,  
\m ittegg s tmexsiwt icewwaren  
\m di marra timegga nnes.   
\m
\v 18 \bd Quf.\bd* SIDI yudes i marra  
\m inni xas ittřaɣan,  
\m marra inni xas ittřaɣan di tidett.   
\m
\v 19 \bd Rix.\bd* Netta igga s řxaḍar  
\m i marra inni t itteggʷden,  
\m ittesřa iɣuyyan nsen u issenjam i-ten.   
\m
\v 20 \bd Cin.\bd* SIDI iḥeṭṭa x marra inni t ittexsen,  
\m \add maca\add* marra iɛeffanen itteḥḥa i-ten.   
\m
\v 21 \bd Taf.\bd* Aqemmum inu ad issiweř  
\m x uṣebbeḥ n SIDI,  
\m marra ddat ad ibarek  
\m Isem nnes iqeddsen, i řebda qaɛ.   
\b  
\b  
\m  
\c 146
\m
\v 1 Hallilu-Yah.  
\m \add A\add* řeɛmar inu, ṣebbeḥ i SIDI.   
\m
\v 2 Necc ad ṣebbḥeɣ i SIDI  
\m min ɣa kkeɣ ddareɣ,  
\m ad zehhdeɣ i AREBBI inu  
\m min \add da\add* ɣa kkeɣ ɛad. \f ◼ \fr 146:2 \ft \+fk min ... ɣa kkeɣ ddareɣ\ft  - s Tɛibranit ‘di tudart inu’.\f*   
\m
\v 3 War tceř x tarwa n taṣiřet,  
\m x mmis n bnadem,  
\m wenni umi war ɣar iǧi bu usenjem. \x ◘ \xo 146:3 \xt Izhd. 118:8, 9\x*   
\m
\v 4 Iffeɣ buḥbeř nnes,  
\m idweř ɣar temmurt.  
\m Deg wass nni simant nnes  
\m ad qḍan inwayen nnes.   
\b  
\m
\v 5 Sseɛd n wenni ɣar iǧa  
\m Arebbi n Yaɛqub d amɛawen,  
\m wenni ittrajan SIDI, AREBBI nnes,   
\m
\v 6 wenni iggin ijenwan d temmurt,  
\m řebḥar d marra min dayes,  
\m wenni dayes řaman i řebda, \f ◼ \fr 146:6 \ft \+fk wenni dayes řaman\ft  - s Tɛibranit ‘wenni iḥeṭṭan řaman’.\f*   
\m
\v 7 wenni ittaɣen tasɣart  
\m i yinni ittwaḥeṣṣaren,  
\m wenni itticen aɣrum i yinni iǧuẓen.  
\m SIDI yarexxu i imeḥbas.   
\b  
\m
\v 8 SIDI yarezzem i idarɣařen tiṭṭawin,  
\m issbedda inni igguren itteqwisen,  
\m SIDI ittexs imseggaden. \x ◘ \xo 146:8 \xt Izhd. 145:14; 147:3; Mt. 9:30; Lk. 13:13; Yḥ. 9:7,32\x*   
\m
\v 9 SIDI iḥeṭṭa ibarraniyyen,  
\m ittic afus i uyujiř d tijjař,  
\m \add maca\add* abrid n iɛeffanen ad t issfarɣ.   
\m
\v 10 SIDI ad iḥkem i řebda,  
\m AREBBI nnec, \add a\add* Ṣihyun,  
\m \add iḥekkem\add* zi jjiř ař jjiř.  
\m Hallilu-Yah. \x ◘ \xo 146:10 \xt Uf. 15:18; Izhd. 145:13\x*   
\b  
\b  
\m  
\c 147
\m
\v 1 Hallilu-Yah,  
\m maɣar azehhed i AREBBI nneɣ  
\m d aṣebḥan, minzi ittas-dd akides  
\m ad as nṣebbeḥ. \x ◘ \xo 147:1 \xt Izhd. 33:1\x*   
\m
\v 2 SIDI ibenna Urcalim,  
\m issmun immeneɛraq n Israil.   
\m
\v 3 Netta issgenfa inni ɣarsen uř yarẓen,  
\m ittcedda iyezzimen nsen itteqsen. \x ◘ \xo 147:3 \xt Uf. 15:26; Ayub 5:18\x*   
\m
\v 4 Iḥesseb qedda n itran,  
\m ittřaɣa ten marra s yisem. \x ◘ \xo 147:4 \xt Ica. 40:26\x*   
\m
\v 5 Siditneɣ d ameqqran u jjehd nnes imɣar.  
\m Řeɛqeř nnes war ɣares bu řeɛbar.   
\m
\v 6 SIDI ittsenned imwaḍɛen,  
\m isshekkwa iɛeffanen ař tammurt.   
\b  
\m
\v 7 Qadam SIDI s uɣennej,  
\m zehhdem i AREBBI nneɣ s řgambri.   
\m
\v 8 \add Netta\add* d wenni iddařen ajenna  
\m s iseynuten,  
\m d wenni issewjaden anẓar i temmurt,  
\m d wenni issɣemmayen arbiɛ x idurar. \x ◘ \xo 147:8 \xt Ayub 38:26, 27; Izhd. 104:14; Ḥuc. 2:23, 24\x*   
\m
\v 9 d wenni itticen i řmař macca nnes,  
\m uřa i tarwa n ibaɣřiwen xmi ɣa sɣuyen.   
\m
\v 10 Netta war yareṭṭi s jjehd n uyis,  
\m iḍaren n weryaz war d as tteɛjiben.   
\m
\v 11 Yareṭṭa as i SIDI inni t itteggʷeden,  
\m inni issitmen  
\m di tmexsiwt nnes icewwaren.   
\b  
\m
\v 12 \add A\add* Urcalim, ṣebbeḥ i SIDI,  
\m \add a\add* Ṣihyun, ṣebbeḥ i AREBBI nnem.   
\m
\v 13 Maɣar Netta issemḥed  
\m zzekrunat n tewwura nnec,  
\m ibarek iḥenjiren nnec di řwest nnec,   
\m
\v 14 Netta iwca řehna i iymiren nnec,  
\m issjiwen i cek s min iṣebḥen qaɛ n yirden.   
\m
\v 15 Netta issekka tiwařin nnes ɣar temmurt,  
\m awař nnes ittazzeř aṭṭas. \x ◘ \xo 147:15 \xt Izhd. 33:9\x*   
\m
\v 16 Ittic adfeř am tḍuft,  
\m izzuzara nnda igersen am yiɣɣeḍ.   
\m
\v 17 Issekka adfeř nnes d ibquqen,  
\m wi izemmaren ad iqqim ibedd  
\m zzat i tesmuḍi nnes?   
\m
\v 18 Issekka awař nnes  
\m uca ittarra i-ten ad fesyen,  
\m Netta ittejja asemmiḍ nnes ittsuḍ,  
\m xenni ttucruren waman.   
\m
\v 19 Netta ibarreḥ i Yaɛqub awařen nnes,  
\m i Israil tiweṣṣa nnes d lfarayiḍ nnes.   
\m
\v 20 Uřa i yijj n řgens nneɣni  
\m war d as iggi ammu,  
\m nitni war ssinen ca lfarayiḍ nnes.  
\m Hallilu-Yah! \x ◘ \xo 147:20 \xt Řex. 14:16\x*   
\b  
\b  
\m  
\c 148
\m
\v 1 Hallilu-Yah!  
\m Ṣebbḥem i SIDI zeg ijenwan,  
\m ṣebbḥem t di řuɛřa. \x ◘ \xo 148:1 \xt Lk. 2:14; Asa. 5:13\x*   
\m
\v 2 Ṣebbḥem t, marra lmalakat nnes!  
\m Ṣebbḥem t, marra řɛeskarat nnes!   
\m
\v 3 Ṣebbḥent t, tafuct d tziri!  
\m Ṣebbḥem t, marra itran yareqqen!   
\m
\v 4 Ṣebbḥet, ajenna x ijenwan,  
\m uřa d aman nni \add iǧan\add* tiwa i ujenna.   
\m
\v 5 Ejj i-ten ad ṣebbḥen Isem n SIDI,  
\m maɣar Netta yumur  
\m u \add ammu\add* ttwaxeřqen-dd. \x ◘ \xo 148:5 \xt Amz. 1:6-31; Izhd. 33:6, 9\x*   
\m
\v 6 Netta idekken i-ten \add din\add* i řebda,  
\m iwca \add asen\add* ict n tewṣeyyet  
\m i war zemmaren ad tt ɛeddan \add ɛemmarṣ\add*. \x ◘ \xo 148:6 \xt Ayub 14:5, 13; 26:10; 38:33; Izhd. 104:5; 119:91; Irm. 31:35; 33:25\x*   
\b  
\m
\v 7 Ṣebbḥem i SIDI, zi temmurt,  
\m \add kenniw\add* řhaycat n řebḥar  
\m d marra \add aman\add* ihewřen,   
\m
\v 8 timessi d tebrurri  
\m d wedfeř d ddexxan,  
\m asemmiḍ n tḥaryaḍt  
\m nni itteggen awař nnes,   
\m
\v 9 idurar d marra tiwriririn,  
\m ticejjura n fruta  
\m d marra ticejjura n tengelt,   
\m
\v 10 řewḥuc n řexřa d marra řmar,  
\m imuddaren ittbuɛen d ijḍaḍ  
\m s wafriwen \add nsen\add*,   
\m
\v 11 \add kenniw\add* ijeǧiden n temmurt  
\m d marra ccuɛub,  
\m \add kenniw\add* řḥukkam  
\m d marra řquḍat x temmurt, \f ◼ \fr 148:11 \ft \+fk řquḍat\ft  - niɣ ‘imezurfa’.\f*   
\m
\v 12 ibřiɣen uřa d tiɛzariyyin,  
\m iwessura \add jmiɛ\add* ak-d imeẓyanen!   
\m
\v 13 Ejj i-ten ad ṣebbḥen Isem n SIDI,  
\m maɣar Isem nnes waha yuɛřan qaɛ,  
\m tissiqt nnes \add tařeqq\add*  
\m x temmurt d ijenwan. \x ◘ \xo 148:13 \xt Awřn. 18:10; Ica. 12:4\x*   
\m
\v 14 Netta issgeɛɛed icc n řgens nnes,  
\m aṣebbeḥ n marra imtiqqan nnes,  
\m n ayt n Israil,  
\m n řgens i dd as yudsen.  
\m Hallilu-Yah! \x ◘ \xo 148:14 \xt Izhd. 132:17\x*   
\b  
\b  
\m  
\c 149
\m
\v 1 Hallilu-Yah!  
\m Ɣennjem ijj n yezři n jdid i SIDI,  
\m sɛuǧem t deg wegraw n imtiqqan nnes.   
\m
\v 2 Ad ifarḥ Israil zeg wenni t iggin,  
\m ad arcqen iḥenjiren n Ṣihyun  
\m s Ujeǧid nsen. \x ◘ \xo 149:2 \xt Izhd. 100:3\x*   
\m
\v 3 Ad ṣebbḥen nitni Isem nnes  
\m s ccḍiḥ s nnubtat,  
\m ad as zehhden s ubendir d řgambri, \x ◘ \xo 149:3 \xt Izhd. 81:3, 4\x*   
\m
\v 4 maɣar SIDI yarḍa x řgens nnes,  
\m ad yawi ccan i imwaḍɛen s wenjam.   
\m
\v 5 Ad sřiweřwen imtiqqan  
\m s uweqqar yuǧɣen,  
\m ejj i-ten ad sɣuyen s řefraḥet  
\m zeg imucan nsen n arraḥet.   
\b  
\m
\v 6 Izřan n uɛuǧi i AREBBI  
\m deg uqemmum nsen  
\m ijj n ssif iqḍeɛ s tnayen n wudmawen  
\m deg ufus nsen, \x ◘ \xo 149:6 \xt 2 Ts. 2:8; Ɛbr. 4:12; Asa. 1:16\x*   
\m
\v 7 ḥima ad ntaqmen zi řegnus,  
\m \add ḥima\add* ad ɛaqben ccuɛub,   
\m
\v 8 ḥima ad carfen ijeǧiden nsen s ssnaseř,  
\m ayt n taṣiřet nsen s ssnaseř n wuzzař, \x ◘ \xo 149:8 \xt Mt. 18:18\x*   
\m
\v 9 ḥima ad xasen ggen řḥukm yuran.  
\m D man aya ad tiři d lɛaḍama  
\m n marra imtiqqan nnes.  
\m Hallilu-Yah. \x ◘ \xo 149:9 \xt Aɛwd. 4:6\x*   
\b  
\b  
\m  
\c 150
\m
\v 1 Hallilu-Yah,  
\m ṣebbḥem AREBBI  
\m di Zzawect nnes Iqeddsen,  
\m ṣebbḥem t di řkubbet n jjehd nnes! \x ◘ \xo 150:1 \xt Ica. 6:3\x*   
\m
\v 2 Ṣebbḥem t x tmegga nnes timeqqranin,  
\m ṣebbḥem t x řemɣaret nnes tameqqrant!   
\m
\v 3 Ṣebbḥem s tmijja n usuḍi  
\m deg uyicc n icarri,  
\m ṣebbḥem s lharpa d řgambri!   
\m
\v 4 Ṣebbḥem t s ubendir d ccḍiḥ s nnubtat,  
\m ṣebbḥem t s \add tirart\add* n ifiřan d temja!   
\m
\v 5 Ṣebbḥem as s řḥess ifsusen  
\m n teǧunin n wuzzař,  
\m ṣebbḥem as s řḥess yuɛřan  
\m n teǧunin n wuzzař!   
\b  
\m
\v 6 Marra min ittarran nnefs,  
\m ṣebbeḥ i SIDi.  
\m Hallilu-Yah!   