\c 12  
\p
\v 1  \w Then|strong="H1696"\w* \w Miriam|strong="H4813"\w* \w and|strong="H4872"\w* Aaron \w spoke|strong="H1696"\w* \w against|strong="H5921"\w* \w Moses|strong="H4872"\w* \w because|strong="H3588"\w* \w of|strong="H5921"\w* \w the|strong="H5921"\w* \w Cushite|strong="H3571"\w* woman \w he|strong="H3588"\w* \w had|strong="H4872"\w* \w married|strong="H3947"\w* (\w for|strong="H3588"\w* \w he|strong="H3588"\w* \w had|strong="H4872"\w* \w married|strong="H3947"\w* \w an|strong="H3947"\w* \w Ethiopian|strong="H3571"\w* woman).  
\v 2  \w They|strong="H3068"\w* \w said|strong="H1696"\w*, “\w Has|strong="H3068"\w* \w the|strong="H8085"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w only|strong="H7535"\w* \w spoken|strong="H1696"\w* \w through|strong="H1696"\w* \w Moses|strong="H4872"\w*? \w Has|strong="H3068"\w* \w he|strong="H3068"\w* \w not|strong="H3808"\w* \w also|strong="H1571"\w* \w spoken|strong="H1696"\w* \w through|strong="H1696"\w* \w us|strong="H8085"\w*?” \w And|strong="H4872"\w* \w the|strong="H8085"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w heard|strong="H8085"\w* \w it|strong="H1696"\w*.   
\p
