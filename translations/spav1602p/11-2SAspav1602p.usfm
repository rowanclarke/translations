\m
\v 5 \w Y|strong="H3068"\w* \w envió|strong="H7971"\w* \w David|strong="H1732"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* \w los|strong="H5973"\w* \w de|strong="H5973"\w* \w Jabes|strong="H3003"\w* \w de|strong="H5973"\w* \w Galaad|strong="H1568"\w*, diciéndo­\w les|strong="H5973"\w*: \w Benditos|strong="H1288"\w* seáis \w vosotros|strong="H5973"\w* \w del|strong="H5973"\w* \w SEÑOR|strong="H3068"\w*, \w que|strong="H2088"\w* habéis \w hecho|strong="H6213"\w* \w esta|strong="H2088"\w* \w misericordia|strong="H2617"\w* \w con|strong="H5973"\w* vuestro \w señor|strong="H3068"\w* \w Saúl|strong="H7586"\w* \w en|strong="H5973"\w* haberle dado sepultura.   
\m
\v 6 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, \w el|strong="H5973"\w* \w SEÑOR|strong="H3068"\w* \w haga|strong="H6213"\w* \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w* \w misericordia|strong="H2617"\w* \w y|strong="H1571"\w* ver­dad; \w y|strong="H1571"\w* \w yo|strong="H6213"\w* \w también|strong="H1571"\w* \w os|strong="H5973"\w* \w haré|strong="H6213"\w* \w bien|strong="H2896"\w* \w por|strong="H1697"\w* \w esto|strong="H2063"\w* \w que|strong="H6258"\w* habéis \w hecho|strong="H6213"\w*.   
