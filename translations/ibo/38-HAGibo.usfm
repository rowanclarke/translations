\id HAG - Biblica® Open Igbo Contemporary Bible 2020
\h Hegai
\toc1 Hegai
\toc2 Hegai
\toc3 Heg
\mt1 Hegai
\c 1
\s1 Oku maka ịrụ ụlọ \nd Onyenwe anyị\nd*
\p 
\v 1 Ozi \nd Onyenwe anyị\nd*, nke rutere Hegai onye amụma, nke o ziri Zerubabel nwa Shealtiel, onye na-achị Juda, na Joshua nwa Jehozadak, onyeisi nchụaja. Ozi a rutere ya nʼafọ nke abụọ nke ọchịchị eze Daraiọs, nʼụbọchị nke mbụ nʼọnwa nke isii.
\p 
\v 2 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwu, “Ndị a na-asị, ‘Nʼoge ahụ erubeghị mgbe anyị ga-ewu ụlọnsọ ukwu \nd Onyenwe anyị\nd*.’ ”
\p 
\v 3 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* bịara site nʼọnụ Hegai, onye amụma na-asị,
\v 4 “Nke a ọ bụ oge unu onwe unu ji ebi nʼụlọ unu e ji osisi machie, mgbe ụlọnsọ ukwu a nọgidere na-adakpọsị?”
\p 
\v 5 Ugbu a, ihe a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwu, “Lezienụ ụzọ unu anya.
\v 6 Unu na-agha mkpụrụ, ma na-enweta naanị ihe ntakịrị. Unu na-eri nri, ma ihe unu na-eri adịghị ezuru unu. Unu na-aṅụ ihe ọṅụṅụ ma unu adịghị aṅụju afọ ka o si mmasị unu. Unu na-eyikwasị onwe unu uwe, ma ọ dịghị achụ unu oyi. Unu na-anata ụgwọ ọrụ, maọbụ nʼakpa puru epu ka unu na-etinye ya.”
\p 
\v 7 Ihe a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwu, “Chezienụ echiche banyere ndụ unu.
\v 8 Jeenụ nʼelu ugwu, wedata osisi, jiri ya wuo ụlọnsọ ukwu ahụ. Mgbe ahụ, obi ga-atọ m ụtọ na ya, a ga-asọpụkwara m nʼebe ahụ.” Ọ bụ ihe \nd Onyenwe anyị\nd* kwuru.
\v 9 “Unu na-ele anya ihe ukwu, ma lee, ọ bụ naanị ihe ntakịrị ka ọ pụtara. Mgbe unu welatara ha nʼụlọ, a fụfụsiri m ha niile. Nke a ọ bụ nʼihi gịnị?” Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwupụtara. “Ọ bụ nʼihi na ụlọnsọ ukwu m, nke nọgidere na-abụ mkpọmkpọ ebe, ma onye ọbụla nʼime unu na-agba mbọ ịrụ naanị ihe gbasara ụlọ nke aka ya.
\v 10 Ya mere, nʼihi unu ka eluigwe ji jide igirigi ha, ala ejidekwala ihe omume nke ubi.
\v 11 Akpọọla m ka okpomọkụ bịakwasị nʼala ubi niile nakwa nʼelu ugwu niile, nʼelu ọka na mmanya ọhụrụ, mmanụ oliv na ihe niile nke ala na-emepụta. Ka ọ bịakwasị mmadụ na anụmanụ niile, nakwa ihe niile unu dọgburu onwe unu nʼọrụ inweta.”
\b
\p 
\v 12 Mgbe ahụ, Zerubabel nwa Shealtiel, na Joshua nwa Jehozadak, onyeisi nchụaja, na ndị niile fọdụrụ, ṅara ntị nʼolu \nd Onyenwe anyị\nd* Chineke ha, na nʼozi Hegai onye amụma, dịka \nd Onyenwe anyị\nd* Chineke ha zitere ya. Ndị Izrel niile tụkwara egwu \nd Onyenwe anyị\nd*.
\p 
\v 13 Mgbe ahụ Hegai, onyeozi \nd Onyenwe anyị\nd*, ziri ndị mmadụ ahụ niile ozi Onyenwe anyị, sị: “Mụ onwe m nọnyeere unu,” otu a ka \nd Onyenwe anyị\nd* kwupụtara.
\v 14 Ya mere, \nd Onyenwe anyị\nd* kwaliri mmụọ Zerubabel nwa Shealtiel, onye na-achị Juda, na mmụọ Joshua nwa Jehozadak, onyeisi nchụaja na mmụọ ndị niile ahụ fọdụrụ nʼala ahụ. Ha niile bịara bido ọrụ nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke ha,
\v 15 nʼụbọchị nke iri abụọ na anọ, nʼọnwa nke isii.
\s1 Ebube nke ụlọ ọhụrụ ahụ nke ekwere na nkwa
\p Ọ bụ nʼafọ nke abụọ, nke ọchịchị eze Daraiọs,
\c 2
\nb 
\v 1 nʼụbọchị nke iri abụọ na otu, nʼọnwa nke asaa, okwu \nd Onyenwe anyị\nd* si nʼọnụ onye amụma Hegai bịakwa na-asị:
\v 2 “Gwa Zerubabel nwa Shealtiel, onye na-achị Juda, na Joshua nwa Jehozadak, onyeisi nchụaja, na ndị Izrel ahụ fọdụrụ nʼala ahụ sị:
\v 3 ‘Onye nʼime unu nwere ike icheta otu ụlọnsọ ukwu nke mbụ si dị ebube? Ọ dị aṅaa nʼanya unu ugbu a? Ọ bụ na ọ dịghị unu ka ihe efu ugbu a.
\v 4 Ma ugbu a nwee obi ike Zerubabel,’ ka \nd Onyenwe anyị\nd* kwuru. ‘Nwekwaa obi ike gị Joshua onyeisi nchụaja, nwa Jehozadak. Nwekwaanụ obi ike unu ndị niile bi nʼala a.’ Ka \nd Onyenwe anyị\nd* kwuru. ‘Rụọnụ ọrụ nʼihi na anọnyeere m unu,’ ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwu.
\v 5 ‘Nke a bụ ihe merenụ mgbe mụ na unu gbara ndụ nʼoge ahụ unu si nʼIjipt pụta. Mmụọ m na-anọgidekwa nʼetiti unu. Unu atụla egwu.’
\p 
\v 6 “Nʼihi na ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, ‘Ọ fọdụrụ otu ugbo, nwa oge nta gasịa, aga m ayọgharị eluigwe na ụwa, na osimiri na ala akọrọ.
\v 7 Aga m ayọgharịkwa mba niile; ihe mba niile na-achọsi ike ga-abịa. Aga m eme ka ụlọ a jupụta nʼebube,’ ọ bụ ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru.
\v 8 ‘Ọlaọcha niile na ọlaedo niile, bụ nke m.’ Ọ bụ ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwupụtara.
\v 9 ‘Ebube nke ụlọ a ga-adị ukwuu karịa ebube nke mbụ,’ ọ bụ ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru. ‘Ọ bụkwa nʼebe a ka m ga-enye ọganihu na udo,’ otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwubiri ya.”
\s1 Ngọzị maka ndị rụrụ arụ
\p 
\v 10 Nʼụbọchị nke iri abụọ na anọ, nʼọnwa itoolu, nke afọ abụọ, nke ọchịchị eze Daraiọs, okwu \nd Onyenwe anyị\nd* bịakwutere onye amụma, bụ Hegai.
\v 11 “Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, ‘Jụọ ndị nchụaja ihe iwu na-ekwu.
\v 12 Ọ bụrụ na mmadụ etinye anụ e doro nsọ nʼakpa uwe ya, ọ bụrụkwa na uwe ahụ anụ nsọ ahụ dị nʼime ya emetụ achịcha, maọbụ ofe, maọbụ nri ọzọ dị iche, mmetụ uwe ahụ metụrụ ha ọ ga-eme ka ha dịrị nsọ?’ ”
\p Ndị nchụaja zara sị: “Mba!”
\p 
\v 13 Mgbe ahụ Hegai kwukwara, “Ọ bụrụ na mmadụ emerụọ onwe ya site nʼimetụ onye nwụrụ anwụ aka, mesịa metụ otu nʼime ihe ndị a aka, ọ ga-abụ ihe rụrụ arụ?”
\p Ndị nchụaja zara sị, “E, ọ ga-abụ ihe rụrụ arụ.”
\p 
\v 14 Mgbe ahụ Hegai kwuru sị, “ ‘Otu a ka mba a na ndị bi nʼime ya dị nʼihu m. Ihe ọbụla aka ha rụpụtara na onyinye ọbụla ha nyere bụ ihe rụrụ arụ.’ Ọ bụ ihe \nd Onyenwe anyị\nd* kwuru.
\p 
\v 15 “ ‘Ma ugbu a, chezienụ echiche banyere ihe ndị ga-emenụ site taa gaa nʼihu. Tuleenụ otu ihe si dị tupu adọnye otu nkume nʼelu ibe ya nʼụlọnsọ ukwu nke \nd Onyenwe anyị\nd*.
\v 16 Kedụ ọnọdụ unu? Mgbe mmadụ bịara nʼebe o debere ọtụtụ iri efere ọka abụọ, ihe ọ na-ahụ bụ naanị ọtụtụ efere ọka iri. Ọ bụrụkwa na ọ bịa nʼebe ịnara mmanya ka o were iri ite mmanya ise, ọ bụ naanị iri ite mmanya abụọ ka ọ ga-enweta.
\v 17 Eji m ọrịa na-eripịa ihe ubi, na ọmụma ebu, na mkpụrụ mmiri igwe bibie ọrụ aka unu niile; ma unu alọghachikwuteghị m,’ ọ bụ ihe \nd Onyenwe anyị\nd* kwupụtara.
\v 18 ‘Ma site nʼụbọchị taa gaa nʼihu, site nʼụbọchị taa bụ iri ụbọchị anọ nke ọnwa itoolu, chenụ echiche banyere ụbọchị a bụ ụbọchị a tọrọ ntọala ụlọnsọ ukwu \nd Onyenwe anyị\nd*. Chezienụ echiche banyere ya.
\v 19 Ọ ka nwere mkpụrụ ọghịgha unu nwere nʼọba unu? Ọzọkwa, osisi vaịnị, osisi fiig, osisi pomegranet na osisi oliv amịghị mkpụrụ, ruo ugbu a.
\p “ ‘Ma site nʼụbọchị taa gaa nʼihu aga m agọzi unu.’ ”
\s1 Zerubabel mgbaaka akara \nd Onyenwe anyị\nd*
\p 
\v 20 Okwu \nd Onyenwe anyị\nd* bịakwutere Hegai nke ugboro abụọ, nʼụbọchị nke iri abụọ na anọ nke ọnwa ahụ, sị,
\v 21 “Gwa Zerubabel, onye na-achị Juda sị ana m aga ịyọgharị eluigwe na ụwa.
\v 22 Aga m akwatu ocheeze alaeze dị iche iche, ana m agakwa imebi ike alaeze nke mba dị iche iche. Aga m akwatu ụgbọ ịnyịnya nʼala na ndị na-anya ha; ịnyịnya na ndị na-agba ha ga-adakwa. Onye ọbụla ga-adakwa site na mma agha nke onye otu ya.
\p 
\v 23 “ ‘Nʼụbọchị ahụ,’ ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwu, ‘Aga m ewere gị bụ onyeozi m Zerubabel nwa Shealtiel,’ ọ bụ ihe \nd Onyenwe anyị\nd* kwuru, ‘mee gị ka ị dị ka mgbaaka akara m, nʼihi na ahọrọla m gị,’ Ọ bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwu.”
