\p 
\v 3 \w The|strong="H3605"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Uzzi|strong="H5813"\w*: \w Izrahiah|strong="H3156"\w*.
\p \w The|strong="H3605"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Izrahiah|strong="H3156"\w*: \w Michael|strong="H4317"\w*, \w Obadiah|strong="H5662"\w*, \w Joel|strong="H3100"\w*, \w and|strong="H1121"\w* \w Isshiah|strong="H3449"\w*. \w All|strong="H3605"\w* \w five|strong="H2568"\w* \w were|strong="H1121"\w* family \w heads|strong="H7218"\w*.
\v 4 \w They|strong="H3588"\w* \w had|strong="H3588"\w* \w many|strong="H7235"\w* wives \w and|strong="H1121"\w* \w sons|strong="H1121"\w* \w and|strong="H1121"\w* \w so|strong="H3588"\w* \w in|strong="H5921"\w* \w their|strong="H5921"\w* genealogy \w they|strong="H3588"\w* list 36,000 battle-ready \w fighting|strong="H4421"\w* \w men|strong="H1121"\w*.
\v 5 \w The|strong="H3605"\w* \w relatives|strong="H4940"\w* \w who|strong="H3605"\w* \w were|strong="H4940"\w* \w warriors|strong="H1368"\w* belonging \w to|strong="H2428"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w families|strong="H4940"\w* \w of|strong="H1368"\w* \w Issachar|strong="H3485"\w*, according \w to|strong="H2428"\w* \w their|strong="H3605"\w* \w genealogy|strong="H3187"\w*, \w were|strong="H4940"\w* 87,000 \w in|strong="H1368"\w* \w total|strong="H3605"\w*.
\p 
\v 6 \w Three|strong="H7969"\w* sons \w of|strong="H1144"\w* \w Benjamin|strong="H1144"\w*: \w Bela|strong="H1106"\w*, \w Beker|strong="H1071"\w*, \w and|strong="H1144"\w* \w Jediael|strong="H3043"\w*.
\p 
\v 7 \w The|strong="H1121"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Bela|strong="H1106"\w*: Ezbon, \w Uzzi|strong="H5813"\w*, \w Uzziel|strong="H5816"\w*, \w Jerimoth|strong="H3406"\w*, \w and|strong="H1121"\w* \w Iri|strong="H5901"\w*, \w leaders|strong="H7218"\w* \w of|strong="H1121"\w* \w their|strong="H8147"\w* \w families|strong="H1004"\w*—\w a|strong="H3068"\w* total \w of|strong="H1121"\w* \w five|strong="H2568"\w*. \w They|strong="H2428"\w* \w had|strong="H1121"\w* 22,034 fighting \w men|strong="H1368"\w* according \w to|strong="H1121"\w* \w their|strong="H8147"\w* \w genealogy|strong="H3187"\w*.
