\c 24
\s1 Reinado de Joacim y Joaquín
\p 
\v 1 En su \w tiempo|strong="H3117"\w* \w subió|strong="H5927"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* de Babilonia, y \w Joacim|strong="H3079"\w* \w fue|strong="H1961"\w* su vasallo durante \w tres|strong="H7969"\w* \w años|strong="H8141"\w*. \w Luego|strong="H5927"\w* cambió de parecer y \w se|strong="H1961"\w* rebeló \w contra|strong="H1961"\w* él.
\v 2 Entonces \nd \w Yavé|strong="H3068"\w*\nd* \w envió|strong="H7971"\w* contra \w él|strong="H1121"\w* tropas \w de|strong="H1121"\w* \w caldeos|strong="H3778"\w*, sirios, moabitas y amonitas. Las \w envió|strong="H7971"\w* contra \w Judá|strong="H3063"\w* para destruirla, según la \w Palabra|strong="H1697"\w* \w que|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w habló|strong="H1696"\w* \w por|strong="H1697"\w* \w medio|strong="H3027"\w* \w de|strong="H1121"\w* sus esclavos \w profetas|strong="H5030"\w*.
\v 3 Ciertamente \w por|strong="H5921"\w* \w mandato|strong="H6310"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w sucedió|strong="H1961"\w* \w esto|strong="H6213"\w* \w contra|strong="H5921"\w* \w Judá|strong="H3063"\w* \w para|strong="H5921"\w* quitarla \w de|strong="H5921"\w* su \w Presencia|strong="H6440"\w* \w por|strong="H5921"\w* \w los|strong="H5921"\w* \w pecados|strong="H2403"\w* \w de|strong="H5921"\w* \w Manasés|strong="H4519"\w*, \w en|strong="H5921"\w* conformidad \w con|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w él|strong="H5921"\w* \w hizo|strong="H6213"\w*,
