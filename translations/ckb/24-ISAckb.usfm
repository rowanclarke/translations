\id ISA - Biblica® Open Kurdi Sorani Standard Version 
\h ئیشایا 
\toc1 ئیشایا 
\toc2 ئیشایا 
\toc3 ئیشایا 
\mt1 ئیشایا 
\c 1  
\p  
\v 1 خودا لە ماوەی پاشایەتی عوزیا و یۆتام و ئاحاز و حەزقیای پاشایانی یەهودا، دەربارەی یەهودا و ئۆرشەلیم ئەم بینینانەی بۆ ئیشایای کوڕی ئامۆچ ئاشکرا کرد. 
\s1 نەتەوەیەکی یاخی 
\q1  
\v 2 ئەی ئاسمان گوێ بگرە و ئەی زەوی گوێ شل بکە، 
\q2 چونکە یەزدان دەفەرموێت: 
\q1 «چەند کوڕێکم گەورە کرد و پێم گەیاندن، 
\q2 بەڵام ئەوان لێم یاخی بوون. 
\q1  
\v 3 گا خاوەنەکەی خۆی دەناسێت و 
\q2 گوێدرێژیش ئاخوڕی خاوەنی خۆی، 
\q1 بەڵام ئیسرائیل من ناناسێت، 
\q2 گەلی من تێناگات.» 
\b  
\q1  
\v 4 قوڕبەسەر نەتەوەی گوناهبار، 
\q2 بەسەر ئەو گەلەی تاوانی قورسە، 
\q1 توخمی بەدکاران، 
\q2 کوڕانی گەندەڵین! 
\q1 وازیان لە یەزدان هێنا، 
\q2 بە سووکییەوە تەماشای خودا پیرۆزەکەی ئیسرائیلیان کرد، 
\q2 پشتیان لێی کرد. 
\b  
\q1  
\v 5 بۆچی دووبارە لێتان بدرێتەوە؟ 
\q2 بۆچی بەردەوامن لە یاخیبوونتان؟ 
\q1 تەواوی سەر نەخۆشە و 
\q2 هەموو دڵ بیمارە. 
\q1  
\v 6 لە بنی پێ هەتا تەوقی سەر 
\q2 کوا تەندروستی تێیدا؟ 
\q1 بەڵکو برین و شین و مۆر بوونەوەیە، 
\q2 لێدانی تەڕ و تازە 
\q1 کە نەگوشراوە و نەبەستراوە و 
\q2 بە ڕۆن نەرم نەکراوە. 
\b  
\q1  
\v 7 خاکەکەتان وێرانە، 
\q2 شارەکانتان سووتاوە، 
\q1 لەبەرچاوتان زەوییەکەتان 
\q2 بێگانەکان دەیخۆن، 
\q2 وێرانە وەک ئەوەی بێگانە هەڵاوگێڕی کردبێت. 
\q1  
\v 8 سییۆنی کچ\f + \fr 1:8 \ft مەبەست لە وڵاتی یەهودایە.‏\f* ماوەتەوە، 
\q2 وەک کۆخ لەناو ڕەزەمێودا، 
\q1 وەک کەپر لەناو بێستانی خەیاردا، 
\q2 وەک شارێکی ئابڵوقەدراو. 
\q1  
\v 9 ئەگەر یەزدانی سوپاسالار 
\q2 کەمێک دەربازبووی بۆ نەهێشتباینایەوە، 
\q1 وەک سەدۆممان لێ دەهات، 
\q2 لە عەمۆرا دەچووین. 
\b  
\q1  
\v 10 گوێ لە فەرمایشتی یەزدان بگرن، 
\q2 ئەی فەرمانڕەوایانی سەدۆم! 
\q1 گوێ شل بکەن بۆ فێرکردنەکانی خودامان، 
\q2 ئەی گەلی عەمۆرا! 
\q1  
\v 11 یەزدان دەفەرموێت: 
\q2 «بۆچیمە، زۆری قوربانییە سەربڕدراوەکانتان؟ 
\q1 تێربووم لە قوربانی سووتاندنی بەرانەکان و 
\q2 لە چەوری دابەستەکان، 
\q2 دڵخۆش نیم بە خوێنی جوانەگا\f + \fr 1:11 \ft لەو کاتەوەی کە گوێرەکەی نێر لە شیر دەبڕدرێتەوە پێی دەگوترێت نۆبەن یان جوانەگا.‏\f* و بەرخ و تەگەکان\f + \fr 1:11 \ft نێری، سابرێن.‏\f*. 
\q1  
\v 12 کە دێن بۆ بینینی ڕووم، 
\q2 کێ داوای ئەمەی لێکردوون، 
\q2 کە پێ بنێنە ناو حەوشەکانم؟ 
\q1  
\v 13 چیتر پێشکەشکراوی دانەوێڵەی بێ کەڵک مەهێنن! 
\q2 بخوور قێزەونە بۆ من. 
\q1 سەرەمانگ و شەممە و بانگەوازی کۆبوونەوە، 
\q2 بەرگەی بۆنە ئایینییە خراپەکانتان ناگرم. 
\q1  
\v 14 سەرەمانگ و جەژنەکانتان 
\q2 گیانم ڕقی لێیانە. 
\q1 بوون بە بارگرانی بۆم، 
\q2 لێیان بێزار بووم. 
\q1  
\v 15 کە لە کاتی نزاکردندا دەستتان پان دەکەنەوە، 
\q2 چاوم لادەدەم لەسەرتان، 
\q1 تەنانەت ئەگەر نوێژیش زۆر بکەن، 
\q2 من گوێ ناگرم. 
\b  
\q1 «دەستتان بە خوێن سوور بووە! 
\b  
\q1  
\v 16 «خۆتان بشۆن، پاک ببنەوە. 
\q2 خراپەی کردەوەکانتان 
\q2 لەبەرچاوم لاببەن! 
\q1 وازبهێنن لە خراپەکاری، 
\q2  
\v 17 فێری چاکە بن! 
\q1 بەدوای دادپەروەریدا بگەڕێن، 
\q2 ستەملێکراوان هانبدەن. 
\q1 دادوەری هەتیو بکەن، 
\q2 پارێزەری بۆ بێوەژن بکەن.» 
\b  
\q1  
\v 18 یەزدان دەفەرموێت: 
\q2 «ئێستا وەرن یەکلایی بکەینەوە. 
\q1 ئەگەر گوناهەکانتان سووری ئاڵ بێت، 
\q2 وەک بەفر سپی دەبێتەوە؛ 
\q1 ئەگەر وەک قرمز سوور بێت، 
\q2 وەک خوری لێدێت. 
\q1  
\v 19 ئەگەر قایل بن و گوێ بگرن، 
\q2 خێروبێری خاکەکە دەخۆن. 
\q1  
\v 20 بەڵام ئەگەر قایل نەبن و یاخی بن، 
\q2 بە شمشێر دەخورێن،» 
\q4 چونکە دەمی یەزدان فەرمووی. 
\b  
\q1  
\v 21 «چۆن شارە دڵسۆزەکە 
\q2 بوو بە لەشفرۆش! 
\q1 پڕ دادوەری بوو، 
\q2 ڕاستودروستی تێیدا دەمایەوە، 
\q2 بەڵام ئێستا پیاوکوژان! 
\q1  
\v 22 زیوت بوو بە خڵت و 
\q2 شەرابت ئاوی تێکراوە. 
\q1  
\v 23 میرەکانت یاخین و 
\q2 دۆستی دزانن، 
\q1 هەموو حەزیان لە بەرتیلە و 
\q2 دوای پاداشت کەوتوون. 
\q1 دادوەری بۆ هەتیو ناکەن، 
\q2 سکاڵای بێوەژن ناگاتە لایان.» 
\b  
\q1  
\v 24 لەبەر ئەوە یەزدان، پەروەردگاری سوپاسالار، 
\q2 توانادارەکەی ئیسرائیل، دەفەرموێت: 
\q1 «ئای، من تووڕەییم بەسەر ناحەزانمدا دەڕێژم و 
\q2 تۆڵە لە دوژمنانم دەکەمەوە. 
\q1  
\v 25 دژ بە تۆ دەستم درێژ دەکەم، 
\q2 بە تەواوەتی خڵتەکەت پاک دەکەمەوە، 
\q2 هەموو خڵت و پیسییەکەت لێ دەکەمەوە. 
\q1  
\v 26 ڕابەرانت دەگەڕێنمەوە وەک یەکەم جار و 
\q2 ڕاوێژکارانت وەک لە سەرەتا. 
\q1 پاش ئەمە پێت دەگوترێت 
\q2 ”شاری ڕاستودروستی“، 
\q2 ”شاری دڵسۆز“.» 
\b  
\q1  
\v 27 بە دادپەروەری سییۆن دەکڕدرێتەوە، 
\q2 تۆبەکارەکانیشی بە ڕاستودروستی. 
\q1  
\v 28 بەڵام تێکشکانی یاخیبووان و گوناهباران پێکەوە دەبێت، 
\q2 وازهێنەران لە یەزدانیش دەفەوتێن. 
\b  
\q1  
\v 29 «شەرمەزار دەبن بەو دار بەڕووانەی 
\q2 ئارەزووتان کرد، 
\q1 تەریق دەبنەوە بەو باخچانەی 
\q2 هەڵتانبژارد. 
\q1  
\v 30 وەک دار بەڕووێکتان لێدێت کە گەڵاکانی وەریبێت و 
\q2 وەک باخچەیەک ئاوی نەبێت. 
\q1  
\v 31 مرۆڤی بەهێز دەبێت بە پەڕۆ و 
\q2 ئیشوکارەکەشی بە پریشکی ئاگر، 
\q1 جا هەردووکیان پێکەوە دەسووتێن و 
\q2 کەس نابێت بیانکوژێنێتەوە.» 
\c 2  
\s1 کێوی یەزدان 
\p  
\v 1 ئەو شتەی ئیشایای کوڕی ئامۆچ بینی سەبارەت بە یەهودا و ئۆرشەلیم: 
\b  
\p  
\v 2 لە ڕۆژانی کۆتاییدا، 
\q1 کێوی پەرستگای یەزدان 
\q2 لەسەر لووتکەی چیاکان جێگیر دەبێت، 
\q1 بەسەر گردەکانەوە بەرز دەبێتەوە و 
\q2 هەموو نەتەوەکان بە لێشاو بەرەو لای ئەو دەچن. 
\p  
\v 3 زۆرێک لە گەلان بەڕێ دەکەون و دەڵێن: 
\q1 «وەرن با بەرەو کێوی یەزدان سەربکەوین، 
\q2 بۆ ماڵەکەی خودای یاقوب. 
\q1 فێری ڕێگاکانی خۆیمان دەکات، 
\q2 بۆ ئەوەی بە ڕێچکەی ئەودا بڕۆین.» 
\q1 فێرکردن لە سییۆنەوە دەردەچێت، 
\q2 پەیامی یەزدانیش لە ئۆرشەلیمەوە. 
\q1  
\v 4 لەنێو نەتەوەکان دادوەری دەکات، 
\q2 ناوبژی بۆ چەندین گەل دەکات. 
\q1 شمشێرەکانیان دەکوتنەوە و دەیکەنە گاسن، 
\q2 ڕمەکانیشیان دەکەنە داس. 
\q1 هیچ نەتەوەیەک شمشێر لە نەتەوەیەکی دیکە هەڵناکێشێت، 
\q2 چیتر فێری جەنگ نابن. 
\b  
\q1  
\v 5 ئەی بنەماڵەی یاقوب، وەرن، 
\q2 با بە ڕووناکیی یەزداندا بڕۆین. 
\s1 ڕۆژی یەزدان 
\q1  
\v 6 وازت لە گەلەکەی خۆت هێنا، 
\q2 لە بنەماڵەی یاقوب، 
\q1 پڕ بوون لە بیروبۆچوونەکانی ڕۆژهەڵات و 
\q2 وەک فەلەستییەکان بەخت دەخوێننەوە، 
\q2 پابەند بوون بە نەریتی بتپەرستەکان. 
\q1  
\v 7 خاکیان پڕبوو لە زێڕ و زیو، 
\q2 گەنجینەکانی سنووریان نییە. 
\q1 خاکیان پڕبوو لە ئەسپ و 
\q2 گالیسکەکانی سنووریان نییە. 
\q1  
\v 8 خاکیان پڕبوو لە بت، 
\q2 کڕنۆشیان بۆ دەستکردی خۆیان برد، 
\q2 کە بە پەنجەکانی خۆیان دروستیان کرد. 
\q1  
\v 9 جا مرۆڤ دەچەمێتەوە و 
\q2 ئادەمیزاد نزم دەبێتەوە، 
\q2 لێیان خۆش مەبە. 
\b  
\q1  
\v 10 لە ڕووی سامی یەزدان و 
\q2 شکۆی مەزنییەکەی، 
\q1 بڕۆ ناو کەلەبەرد و 
\q2 لەناو خۆڵ خۆت بشارەوە! 
\q1  
\v 11 چاوە بەفیزەکانی مرۆڤ نزم دەبێتەوە و 
\q2 لووتبەرزیی ئادەمیزاد دەچەمێتەوە، 
\q1 لەو ڕۆژەدا تەنها یەزدان بە گەورە دەزانرێت. 
\b  
\q1  
\v 12 یەزدانی سوپاسالار ڕۆژێکی هەیە 
\q2 لە دژی هەموو خۆبەزلزان و لووتبەرزێک، 
\q2 لە دژی هەموو خۆهەڵکێشێک کە 
\q2 نزم دەبنەوە، 
\q1  
\v 13 لە دژی هەموو دار ئورزە بەرز و بڵندەکانی لوبنان، 
\q2 لە دژی هەموو دار بەڕووەکانی باشان، 
\q1  
\v 14 لە دژی هەموو چیا بەرزەکان و 
\q2 لە دژی هەموو کێوە بڵندەکان، 
\q1  
\v 15 لە دژی هەموو قوللەیەکی بەرز، 
\q2 لە دژی هەموو شوورایەکی سەخت، 
\q1  
\v 16 لە دژی هەموو کەشتییەکانی تەرشیش، 
\q2 لە دژی هەموو دەستکردێکی دڵگیر. 
\q1  
\v 17 جا فیزی مرۆڤ دەچەمێتەوە و 
\q2 لووتبەرزی ئادەمیزاد نزم دەبێت، 
\q1 لەو ڕۆژەدا تەنها یەزدان بە گەورە دەزانرێت و 
\q2  
\v 18 هەموو بتەکان لەناودەچن. 
\b  
\q1  
\v 19 کاتێک یەزدان بۆ هەژاندنی زەوی هەڵدەستێت، 
\q2 مرۆڤ لە ڕووی سامی شکۆی مەزنییەکەی 
\q1 دەچێتە ناو کەلێنی تاشەبەردەکان و 
\q2 ناو چاڵەکانی خۆڵ. 
\q1  
\v 20 لەو ڕۆژەدا مرۆڤ 
\q2 ئەو بتە زیو و زێڕانەی 
\q1 کە بۆ پەرستن دروستی کردوون، 
\q2 بۆ مشکەکوێرە و شەمشەمەکوێرەیان فڕێدەدات. 
\q1  
\v 21 کاتێک یەزدان بۆ هەژاندنی زەوی هەڵدەستێت، 
\q2 مرۆڤ لە ڕووی سامی شکۆی مەزنییەکەی 
\q1 دەچێتە ناو کەلێنی تاشەبەردەکانەوە و 
\q2 بۆ کەلەبەرەکانی ناو تاوێرەکان. 
\b  
\q1  
\v 22 پشت بە مرۆڤ مەبەستە، 
\q2 ئەوەی تەنها هەناسەیەکی لە لووتدایە. 
\q1 بۆچی حیسابی بۆ دەکرێت؟ 
\c 3  
\s1 دادوەری لەگەڵ ئۆرشەلیم و یەهودا 
\q1  
\v 1 ئێستا سەیر بکەن، پەروەردگار، 
\q2 یەزدانی سوپاسالار، 
\q1 بەتەمایە لە ئۆرشەلیم و لە یەهودا دابماڵێت 
\q2 پاڵپشتی و پشتگیری، 
\q1 هەموو پاڵپشتییەکی نان و ئاو، 
\q2  
\v 2 پاڵەوان و جەنگاوەر، 
\q1 دادوەر و پێغەمبەر، 
\q2 فاڵگرەوە و پیر، 
\q1  
\v 3 سەرۆکی پەنجاکان و پیاوماقوڵان، 
\q2 ڕاوێژکار و پیشەوەری دانا و نوشتەکەری تێگەیشتوو. 
\b  
\q1  
\v 4 مێردمنداڵان دەکەم بە میریان، 
\q2 منداڵان فەرمانڕواییان دەکەن. 
\b  
\q1  
\v 5 گەل لەنێو خۆیان ستەم لە یەکتری دەکەن، 
\q2 هەرکەسە و لە هاوڕێکەی. 
\q1 مێردمنداڵ لە پیر ڕاست دەبێتەوە، 
\q2 چروکیش لە سەنگین. 
\b  
\q1  
\v 6 پیاو یەخەی برای خۆی دەگرێت 
\q2 لە ماڵی باوکی و دەڵێت: 
\q1 «تۆ کەوات هەیە، ببە بە سەرۆکمان و 
\q2 ئەم کاولگەیەش لەژێر دەستتە!» 
\q1  
\v 7 بەڵام لەو ڕۆژەدا براکەی دەنگی بەرز دەکاتەوە و وەڵامی دەداتەوە: 
\q2 «نابم بە چارەساز، 
\q1 نان و جلوبەرگ لە ماڵەکەم نییە. 
\q2 مەمکەن بە سەرۆکی گەل.» 
\b  
\q1  
\v 8 ئۆرشەلیم شکست دەخوات و 
\q2 یەهوداش دەکەوێت، 
\q1 چونکە زمان و کردەوەکانیان لە دژی یەزدانە، 
\q2 بۆ یاخیبوون لەبەرچاوی شکۆمەندییەکەی. 
\q1  
\v 9 دیمەنی ڕوخساریان شایەتییان لەسەر دەدات، 
\q2 وەک سەدۆم گوناهەکەیان ڕادەگەیەنن، 
\q2 نایشارنەوە. 
\q1 قوڕبەسەریان، 
\q2 چونکە خراپە دەهێننە سەر خۆیان! 
\b  
\q1  
\v 10 بڵێن، ڕاستودروستان خۆشحاڵن 
\q2 چونکە بەری کردەوەکانی خۆیان دەخۆن. 
\q1  
\v 11 قوڕبەسەر بەدکار! خراپەی بۆ دەبێت، 
\q2 چونکە پاداشتی کردەوەکانی دەستی خۆی وەردەگرێت. 
\b  
\q1  
\v 12 منداڵان ستەم لە گەلی من دەکەن و 
\q2 ژنان فەرمانڕەوایەتی دەکەن. 
\q1 گەلی من، ڕاستەڕێکارانت چەواشەکارن و 
\q2 لە ڕێگای ڕاست لاتان دەدەن. 
\b  
\q1  
\v 13 یەزدان لە شوێنی دادوەر دانیشت، 
\q2 هەستا بۆ حوکمدان بەسەر گەلان. 
\q1  
\v 14 یەزدان دەست بە دادوەری دەکات، 
\q2 لەگەڵ پیرانی گەلەکەی و میرەکانیان: 
\q1 «ئێوە بوون ڕەزەمێوەکەتان لووشدا، 
\q2 تاڵانیی هەژاران لە ماڵەکانتاندایە. 
\q1  
\v 15 ئەوە چیتانە، گەلەکەم وردوخاش دەکەن و 
\q2 ڕووی هەژاران دەهاڕن؟» 
\q4 ئەوە فەرمایشتی یەزدانە، پەروەردگاری سوپاسالار. 
\b  
\q1  
\v 16 یەزدان دەفەرموێت: 
\q2 «کچانی سییۆن لەخۆبایی بوون، 
\q1 گەردنیان دەرخستووە و 
\q2 بە چاوبازییەوە دەڕۆن، 
\q1 بە لارولەنجەوە دەڕۆن 
\q2 بە زرنگەی لەرزانەی گۆزینگیان. 
\q1  
\v 17 لەبەر ئەوە پەروەردگار سەری کچانی سییۆن کەچەڵ دەکات، 
\q1 یەزدان ڕووتییان دەردەخات.» 
\p  
\v 18 لەو ڕۆژەدا پەروەردگار جوانکاری دادەماڵێت: لەرزانە و لاسەرە و ملوانکە،  
\v 19 گوارە و بازن و پەچە،  
\v 20 سەرپێچ و قۆڵبەست و پشتێن و تەلیسم و چەناخە،  
\v 21 ئەنگوستیلە و خەزێم،  
\v 22 جلوبەرگی جەژن و پاڵتۆ و چارۆکە و جزدان و  
\v 23 ئاوێنە، کراسی کەتان و سەرپۆش و کۆڵوانەکان. 
\q1  
\v 24 جا لە جێی بۆنوبەرام، بۆگەن و 
\q2 لە جێی کەمەربەند، گوریس و 
\q1 لە جێی پرچی بە ئەگریجە، سەری ڕووتاوە و 
\q2 لە جێی بەرگی گرانبەها گوش\f + \fr 3:24 \ft ڕیشاڵێکی ڕووەکییە کە لەو سەردەمە بەرگی ماتەمی لێ دروستدەکرا.‏\f* لەبەر دەکەن، 
\q2 نیشانەی داغیش لە جێی جوانی دەبێت. 
\q1  
\v 25 پیاوەکانتان بە شمشێر و 
\q2 پاڵەوانەکانتان لە جەنگدا دەکەون. 
\q1  
\v 26 جا دەروازەکانی سییۆن شین دەگێڕن و دەگریێن، 
\q2 بێکەس لەسەر زەوی دادەنیشن. 
\c 4  
\q1  
\v 1 لەو ڕۆژەدا حەوت ژن یەک پیاو دەگرن و 
\q2 دەڵێن: «نانی خۆمان دەخۆین و 
\q1 بەرگی خۆمان لەبەر دەکەین، 
\q2 تەنها ڕێگا بدە با بە ناوی تۆوە بانگ بکرێین. 
\q2 ڕیسواییەکەمان ڕاماڵە!» 
\s1 لقی یەزدان 
\p  
\v 2 لەو ڕۆژەدا لقی یەزدان\f + \fr 4:2 \ft لقی یەزدان: نازناوە بۆ مەسیح کە لە نەوەی داودە.‏\f* دەبێتە جوانی و شکۆ، بەروبوومی زەویش دەبێتە شانازی و قەشەنگی بۆ دەربازبووانی ئیسرائیل.  
\v 3 جا ئەوەی لە سییۆن ماوەتەوە و ئەوەی لە ئۆرشەلیم بەجێماوە، پێی دەگوترێت، پیرۆز، هەموو ئەوانەی کە خودا بۆ مانەوە لە ژیان لە ئۆرشەلیم هەڵیبژاردوون.  
\v 4 پەروەردگار پیسیی کچانی سییۆن دەشوات؛ بە ڕۆحی حوکمدان و سووتان خوێنەکانی نێو ئۆرشەلیم پاک دەکاتەوە.  
\v 5 ئینجا یەزدان لەسەر هەموو شوێنێکی کێوی سییۆن و لەسەر ئەوانەی لەوێ کۆدەبوونەوە، بە ڕۆژ هەور و بە شەو دووکەڵ و پڕشنگی ئاگری بڵێسەدار بەدی دەهێنێت، لەسەر هەموو شکۆیەک کەپر دەبێت.  
\v 6 بە ڕۆژ لەبەر گەرما دەبێت بە چادر بۆ سێبەر و لە لافاو و بارانیش دەبێت بە داڵدە و پەناگا. 
\c 5  
\s1 گۆرانی ڕەزەمێوەکە 
\q1  
\v 1 با گۆرانی بڵێم بۆ خۆشەویستەکەم، 
\q2 گۆرانی خۆشەویستەکەم بۆ ڕەزەمێوەکەی: 
\q1 خۆشەویستەکەم ڕەزەمێوێکی هەبوو 
\q2 لەسەر گردێکی بەپیت. 
\q1  
\v 2 بنکۆڵی کرد و بەردی لێ بژار کرد، 
\q2 شامێویشی لێ چاند. 
\q1 قوللەیەکی چاودێری لە ناوەڕاست بنیاد نا، 
\q2 هەروەها گوشەرێکی تێدا هەڵکۆڵی. 
\q1 بە هیوا بوو ترێی باش بگرێت، 
\q2 بەڵام ترێی خراپی گرت. 
\b  
\q1  
\v 3 «ئێستا ئەی دانیشتووانی ئۆرشەلیم و ئەی پیاوانی یەهودا، 
\q2 تکایە لەنێوان من و ڕەزەمێوەکەم دادوەری بکەن. 
\q1  
\v 4 چی دی هەیە بۆ ڕەزەمێوەکەم بکرێت کە 
\q2 من نەمکردبێت؟ 
\q1 کاتێک من هیوادار بووم ترێی باش بگرێت، 
\q2 بۆچی ترێی خراپی گرت؟ 
\q1  
\v 5 ئێستا پێتان دەڵێم 
\q2 چی لە ڕەزەمێوەکەم دەکەم: 
\q1 پەرژینەکەی لێ دەکەمەوە و 
\q2 وێران دەبێت، 
\q1 دیوارەکەی دەڕووخێنم، 
\q2 دەبێتە پێپەست. 
\q1  
\v 6 دەیکەمە کەلاوە، 
\q2 نە پەرچ دەکرێت و نە ژێری هەڵدەدرێتەوە، 
\q1 دڕکوداڵ سەرهەڵدەدات. 
\q2 فەرمان بە هەورەکان دەکەم 
\q1 باران بەسەریدا نەبارێنن.» 
\b  
\q1  
\v 7 ڕەزەمێوی یەزدانی سوپاسالار 
\q2 بنەماڵەی ئیسرائیلە و 
\q1 پیاوانی یەهوداش 
\q2 نەمامی شادی ئەون. 
\q1 بە هیوای دادوەری بوو، بەڵام ئەوەتا خوێنڕژانە؛ 
\q2 بە هیوای ڕاستودروستی بوو، بەڵام ئەوەتا داد و بێدادە. 
\s1 دادوەری یەزدانی سوپاسالار 
\q1  
\v 8 قوڕبەسەر ئەوانەی خانوو بە خانووەوە دەلکێنن و 
\q2 کێڵگە لە کێڵگە نزیک دەکەنەوە 
\q1 هەتا هیچ جێیەک نەما و 
\q2 بە تەنها خۆتان لە خاکەکە نیشتەجێ بوون. 
\p  
\v 9 بە ڕاستی گوێم لێ بوو کە یەزدانی سوپاسالار فەرمووی: 
\q1 «بێگومان کۆشکی مەزن دەبێتە کەلاوە، 
\q2 خانووی گەورە و خۆشیش چوڵەوانی. 
\q1  
\v 10 جێی دە دۆنم ڕەزەمێو، یەک بەت\f + \fr 5:10 \ft یەک بەت دەکاتە 22 لیتر.‏\f* شەراب بەرهەم دەهێنێت و 
\q2 حۆمەرێک\f + \fr 5:10 \ft نزیکەی 160 کیلۆگرامی تۆو.‏\f* تۆویش ئێفەیەک\f + \fr 5:10 \ft نزیکەی 16 کیلۆگرام.‏\f* بەرهەم دەهێنێت.» 
\b  
\q1  
\v 11 قوڕبەسەر ئەوانەی بەیانییان زوو هەڵدەستن 
\q2 بەدوای شەراب دەکەون، 
\q1 لە زەردەپەڕی ئێواران دوا دەکەون 
\q2 مەی گڕی تێبەرداون. 
\q1  
\v 12 قیسارە و ساز، دەف و شمشاڵ و 
\q2 شەراب بووە بە خەو و خۆراکیان، 
\q1 بەڵام ئاوڕ لە کاری یەزدان نادەنەوە، 
\q2 دەستکردەکانی نابینن. 
\q1  
\v 13 لەبەر ئەوە گەلەکەم لەبەر نەزانی ڕاپێچ دەکرێن، 
\q2 سەنگینەکانی لە برسان دەمرن، 
\q2 سادە و ساکارەکانی لە تینووان وشک دەبن. 
\q1  
\v 14 لەبەر ئەوە جیهانی مردووان خۆی پانوپۆڕ کرد و 
\q2 بێ ئەندازە دەمی خۆی کردەوە، 
\q1 تاکو بەگزادە و ڕەشۆکی و شەڕانگێزان، 
\q2 لەگەڵ هەموو ئەوانەش کە شانازی بە ئۆرشەلیم دەکەن، شۆڕ ببنەوە ناوی. 
\q1  
\v 15 مرۆڤ دەچەمێتەوە و 
\q2 پیاو نزم دەبێت، 
\q2 چاوی بەفیزان نزم دەبێت، 
\q1  
\v 16 بەڵام یەزدانی سوپاسالار بە دادوەری بە گەورە دەزانرێت، 
\q2 خودای پیرۆز بە ڕاستودروستییەکەی دەردەکەوێت کە پیرۆزە. 
\q1  
\v 17 مەڕەکان دەلەوەڕێن وەک لە لەوەڕگای خۆیان، 
\q2 بەرخەکانیش لە کەلاوەی دەوڵەمەندەکان دەلەوەڕێن. 
\b  
\q1  
\v 18 قوڕبەسەر ئەوانەی بە گوریسی فێڵ تاوان کێش دەکەن، 
\q2 گوناهیش وەک گوریسی عەرەبانە، 
\q1  
\v 19 ئەوانەی دەڵێن: «با خودا پەلە بکات، 
\q2 با خێرا بێت لە کارەکەی 
\q2 بۆ ئەوەی ببینین. 
\q1 با نزیک بێتەوە و بێتە دی، 
\q2 هەتا بزانین پلانی خودا پیرۆزەکەی ئیسرائیل.» 
\b  
\q1  
\v 20 قوڕبەسەر ئەوانەی بە خراپ دەڵێن چاک و 
\q2 بە چاکیش دەڵێن خراپ، 
\q1 ئەوانەی تاریکی دەکەن بە ڕووناکی و 
\q2 ڕووناکیش دەکەن بە تاریکی، 
\q1 ئەوانەی تاڵ دەکەن بە شیرین و 
\q2 شیرین دەکەن بە تاڵ. 
\b  
\q1  
\v 21 قوڕبەسەر ئەوانەی لەبەرچاوی خۆیان دانان، 
\q2 لەلای خۆیان تێگەیشتوون. 
\b  
\q1  
\v 22 قوڕبەسەر ئەوانەی لە شەراب خواردنەوە پاڵەوانن، 
\q2 پیاوی ئازان بۆ تێکەڵکردنی مەی، 
\q1  
\v 23 بۆ بەرتیل خراپەکار بێتاوان دەکەن، 
\q2 ڕاستودروستانیش لە مافی خۆیان بێبەش دەکەن. 
\q1  
\v 24 لەبەر ئەوە وەک کا بە زمانی ئاگر قووت بدرێت، 
\q2 وەک گژوگیای گڕگرتوو داکەوێت، 
\q1 ڕەگیان وەک کەڕووی لێدێت، 
\q2 خونچەیان وەک تۆز بەرز دەبێتەوە، 
\q1 چونکە فێرکردنی یەزدانی سوپاسالاریان ڕەتکردەوە، 
\q2 سووکایەتییان بە وشەی خودا پیرۆزەکەی ئیسرائیل کرد. 
\q1  
\v 25 لەبەر ئەوە تووڕەیی یەزدان لەسەر گەلەکەی جۆشا، 
\q2 دەستی بۆ درێژکرد و لێیدا. 
\q1 چیاکان هەژان و 
\q2 جەستەکانیان وەک زبڵی سەر شەقامەکانی لێهات. 
\b  
\q1 لەگەڵ هەموو ئەوەشدا تووڕەییەکەی دانەمرکایەوە، 
\q2 هێشتا دەستی درێژکردووە. 
\b  
\q1  
\v 26 ئاڵا بۆ نەتەوە دوورەکان بەرز دەکاتەوە، 
\q2 فیکە بۆ ئەوانە لێدەدات کە لەوپەڕی زەوین. 
\q2 ئەوەتا خێرا بە پەلە دێن! 
\q1  
\v 27 نە ماندوو لەنێویاندایە و نە شەکەت، 
\q2 نە دەخەوێت و نە خەواڵو دەبێت، 
\q1 نە پشتێنی ناوقەدی دەکرێتەوە و 
\q2 نە ئاوزەنگی\f + \fr 5:27 \ft ئاوەزێنە.‏\f* پێڵاوەکانی دەپچڕێت. 
\q1  
\v 28 ئەوانەی تیرەکانیان تیژ و 
\q2 کەوانەکانیان توند کراوە، 
\q1 سمی ئەسپەکانیان وەک بەردەئەستێن، 
\q2 چەرخەی گالیسکەکانیان وەک گەردەلوولە. 
\q1  
\v 29 نەڕەیان وەک نەڕەی شێرە مێیە و 
\q2 وەک بەچکە شێر دەنەڕێنن، 
\q1 دەمڕێنن و نێچیر دەگرن، 
\q2 دەیبەن و کەس ڕزگاریان ناکات. 
\q1  
\v 30 لەو ڕۆژە بەسەریدا دەنەڕێنن، 
\q2 وەک هاژەی دەریا. 
\q1 دەڕواننە خاکەکە و دەبینن 
\q2 وا تاریکییەکی تەنگە، 
\q2 ڕووناکیش بە هەورەکانی تاریک بووە. 
\c 6  
\s1 دانانی ئیشایا لەسەر ئەرک 
\p  
\v 1 لە ساڵی مردنی عوزیای پاشادا، پەروەردگارم بینی لەسەر تەختێکی بەرز و بڵند دانیشتبوو، دامێنیشی پەرستگاکەی پڕکردبوو.  
\v 2 سەرافیمەکان\f + \fr 6:2 \ft سەرافیمەکان: جۆرە بوونەوەرێکی ئاسمانین کە دەکرێت جۆرێکی تایبەتی فریشتە بن.‏\f* لەبەردەستی بوون، هەریەکە شەش باڵیان هەبوو، بە دووانیان ڕووی خۆی داپۆشی بوو، بە دووانی دیکەیان پێیەکانی داپۆشی بوو، بە دووانیش دەفڕی.  
\v 3 ئەمیان بانگی ئەوەی دیکەی کرد و گوتی: 
\q1 «یەزدانی سوپاسالار پیرۆزە، پیرۆزە، پیرۆزە! 
\q2 شکۆمەندییەکەی هەموو زەویی پڕکردووە.» 
\m  
\v 4 چوارچێوە و سەکۆی دەروازەکان لە دەنگی بانگدەر لەرینەوە و پەرستگاکە پڕبوو لە دووکەڵ. 
\p  
\v 5 گوتم: «قوڕبەسەرم، فەوتام! من کابرایەکی لێو گڵاوم و لەنێو گەلێکی لێو گڵاودا نیشتەجێم و لەگەڵ ئەوەشدا چاوەکانم پاشا، یەزدانی سوپاسالاریان بینی.» 
\p  
\v 6 ئینجا یەکێک لە سەرافیمەکان بۆ لای من فڕی و پشکۆیەکی بەدەستەوە بوو بە مەقاش لەسەر قوربانگاکەوە هەڵیگرت و  
\v 7 لە دەمی منی سووی و گوتی: «ئەوەتا ئەمە لە لێوت سوا، تاوانت داماڵرا و گوناهت کەفارەتی بۆ کرا.» 
\p  
\v 8 ئینجا گوێم لە دەنگی پەروەردگار بوو، دەیفەرموو: «کێ بنێرم و کێ بۆمان دەڕوات؟» 
\p منیش گوتم: «ئەوەتام، من بنێرە.» 
\p  
\v 9 ئەویش فەرمووی: «بڕۆ و بەم گەلە بڵێ: 
\q1 «”هەمیشە ببیستن بەڵام هەرگیز تێناگەن، 
\q2 هەمیشە سەیر بکەن، بەڵام هەرگیز نابینن.“ 
\q1  
\v 10 دڵی ئەم گەلە ڕەق بکە، 
\q2 گوێی گران بکە و 
\q2 چاوی بنوقێنە، 
\q1 نەوەک بە چاوی ببینێت و 
\q2 بە گوێی ببیستێت، 
\q2 بە دڵی تێبگات و 
\q1 بگەڕێتەوە و چاک ببێتەوە.» 
\p  
\v 11 منیش گوتم: «ئەی پەروەردگار، هەتا کەی؟» 
\p ئەویش فەرمووی: 
\q1 «هەتا شارەکان دەبن بە وێرانەی 
\q2 بێ ئاوەدانی و 
\q1 ماڵەکانیش بێ خەڵک و 
\q2 کێڵگەکانیش وێران و چۆڵەوانی، 
\q1  
\v 12 هەتا یەزدان هەموو خەڵک دووردەخاتەوە و 
\q2 شوێنی بەجێهێڵراو لەناو خاکەکە زۆر دەبێت. 
\q1  
\v 13 ئەگەر دەیەکی تێدا مایەوە، 
\q2 جارێکی دیکە بۆ سووتان دەبێت. 
\q1 بەڵام وەک دارەبەن و دار بەڕوو، 
\q2 کە کاتێک دەبڕێنەوە بنەدارەکەیان هەر دەمێنێت، 
\q2 پاشماوەی ئەو گەلەش وەک بنەدارێکە و زیندوو دەبێتەوە.» 
\c 7  
\s1 نیشانەی ئیمانوێل 
\p  
\v 1 لە سەردەمی پاشایەتی ئاحازی کوڕی یۆتام کوڕی عوزیای پاشای یەهودا، ڕەچینی پاشای ئارام و پەقەحی کوڕی ڕەمەلیاهوی پاشای ئیسرائیل هێرشیان کردە سەر ئۆرشەلیم، بەڵام نەیانتوانی دەستی بەسەردا بگرن. 
\p  
\v 2 هەروەها بە بنەماڵەی داود\f + \fr 7:2 \ft مەبەستی لە ئاحازی نەوەی داودە.‏\f* ڕاگەیەنرا و گوترا: «ئارامییەکان لەگەڵ ئەفرایم پەیمانیان بەستووە.» جا دڵی ئەو و دڵی گەلەکەی لەرزین، وەک لەرزینی داری دارستان لە ڕووی بادا. 
\p  
\v 3 یەزدانیش بە ئیشایای فەرموو: «ئێستا بچۆ بۆ پێشوازی ئاحاز، خۆت و شئار یاشوبی کوڕت، لە کۆتایی ئاوباری گۆمەکەی سەرەوە لەلای ڕێگای کێڵگەی جلشۆرەکە و  
\v 4 پێی بڵێ: ”وریا و هێدی بە، مەترسە و با دڵت ورە بەر نەدات لەبەر گڕی تووڕەیی ڕەچین و ئارام و کوڕەکەی ڕەمەلیاهو، وەک دوو پارچە داری سووتێنراو دووکەڵ دەکەن.  
\v 5 لەبەر ئەوەی ئارام لەگەڵ ئەفرایم و کوڕەکەی ڕەمەلیاهو پیلانی خراپەیان لە دژی تۆ ناوەتەوە و گوتیان،  
\v 6 ’دەچینە سەر یەهودا و پەلاماری دەدەین، داگیری دەکەین و لەناوەندیدا کوڕەکەی تاڤئێل بە پاشا دادەنێین.‘  
\v 7 یەزدانی باڵادەستیش ئەمە دەفەرموێت: 
\q1 «”سەرناگرێت و نابێت، 
\q1  
\v 8 چونکە سەری ئارام دیمەشقە و 
\q2 سەری دیمەشقیش ڕەچینە، 
\q1 لە ماوەی شەست و پێنج ساڵدا 
\q2 ئەفرایم دەشکێت و وەک گەل نامێنێت. 
\q1  
\v 9 سەری ئەفرایمیش سامیرەیە و 
\q2 سەری سامیرەش کوڕەکەی ڕەمەلیاهوە. 
\q1 ئەگەر لە باوەڕدا نەچەسپێن، 
\q2 لە دڵنیاییدا نابن.“» 
\p  
\v 10 جارێکی دیکە یەزدان بە ئاحازی فەرموو:  
\v 11 «بۆ خۆت داوای نیشانەیەک لە یەزدانی پەروەردگارت بکە، جا چ لە قووڵترینی قووڵاییەکان بێت یان لە بەرزترینی بەرزاییەکان.» 
\p  
\v 12 ئاحازیش گوتی: «هیچ داوا ناکەم و یەزدان تاقی ناکەمەوە.» 
\p  
\v 13 ئینجا ئیشایا گوتی: «ئێستا ئەی بنەماڵەی داود، گوێ بگرن! خەڵکت بێزار کرد، ئەمە بەس نییە؟ ئێستاش دەتەوێ خوداکەم بێزار بکەیت؟  
\v 14 لەبەر ئەوە پەروەردگار خۆی نیشانەیەکتان دەداتێ، ئەوەتا پاکیزەیەک سکی دەبێت و کوڕێکی دەبێت، ناوی لێ دەنێت ئیمانوێل\f + \fr 7:14 \ft بڕوانە \xt مەتا 1‏:21‏\ft ‏. \+tl ئیمانوێل‏\+tl* واتا خودا لەگەڵمانە.‏\f*.  
\v 15 دەڵەمە\f + \fr 7:15 \ft یان دەرەمە، قۆناغی پێش دروستبوونی پەنیر.‏\f* و هەنگوین دەخوات، کاتێک دەزانێت خراپە ڕەت بکاتەوە و چاکە هەڵبژێرێت،  
\v 16 چونکە پێش ئەوەی کوڕەکە بزانێت خراپە ڕەت بکاتەوە و چاکە هەڵبژێرێت، ئەو خاکەی کە تۆ لە دوو پاشاکەی دەترسیت دەبێتە چۆڵەوانی.  
\v 17 یەزدان سەردەمێک بەسەر خۆت و گەلەکەت و بنەماڵەکەتدا دەهێنێت، کە لە کاتی جیابوونەوەی ئەفرایمەوە لە یەهودا سەردەمی وا نەهاتبێت. ئەو پاشای ئاشور دەهێنێت.» 
\s1 یەزدان ئاشور بەکاردەهێنێت 
\p  
\v 18 لەو ڕۆژە، یەزدان فیکە بۆ مێشەکان لێدەدات، ئەوانەی لەوپەڕی جۆگە ئاوەکانی میسرن و هەروەها بۆ ئەو هەنگانەی کە لە خاکی ئاشورن.  
\v 19 جا دێن و هەموو لەناو شیوە هەڵدێرەکان و لەناو کون و کەلەبەری گابەردەکان و لەناو هەموو دڕکوداڵەکان و لەناو هەموو لەوەڕگاکان دەنیشنەوە.  
\v 20 لەو ڕۆژەدا پەروەردگار بە گوێزانێکی بەکرێگیراو لەوبەری ڕووباری فوراتەوە، کە پاشای ئاشورە، سەر و مووی بەرتان دەتاشێت و ڕیشیش دادەماڵێت.  
\v 21 لەو ڕۆژەدا، پیاو مانگایەک و دوو بزن بەخێو دەکات،  
\v 22 جا ئەوەندە شیر دەدەن هەر دەڵەمە دەخوات، چونکە هەموو ئەوانەی لەناو خاکەکە دەمێننەوە دەڵەمە و هەنگوین دەخۆن.  
\v 23 لەو ڕۆژەدا، هەر شوێنێک کە لێی بوو هەزار ڕەز بە هەزار شاقل\f + \fr 7:23 \ft نزیکەی 11,5 کیلۆگرام.‏\f* زیو، دەبێت بە دڕکوداڵ.  
\v 24 بە تیر و بە کەوانەوە دێنە ئەوێ، چونکە هەموو زەوییەکە دەبێت بە دڕکوداڵ.  
\v 25 هەموو ئەو چیایانەی کە بە قازمە کون دەکران کەس نایەتە ئەوێ لە ترسی دڕکوداڵ، بەڵکو گاگەلی تێدا بەڕەڵا دەکرێت و مەڕ پێپەستی دەکات. 
\c 8  
\s1 ئیشایا و منداڵان وەک نیشانە و هێما 
\p  
\v 1 یەزدان پێی فەرمووم: «پارچە چەرمێکی گەورە بۆ خۆت ببە و بە پێنووسی قامیش لەسەری بنووسە: ”مەهێر شالال حاش بەز.\f + \fr 8:1 \ft مەهێر شالال حاش بەز: واتا خێرا بۆ تاڵانکردن.‏\f*“»  
\v 2 هەروەها دوو شایەتی سەرڕاست بۆ خۆم بکەم بە شایەت، ئوریای کاهین و زەکەریای کوڕی یەڤەرەخیا. 
\p  
\v 3 لە پێغەمبەرە ژن\f + \fr 8:3 \ft مەبەست لە ژنەکەی خۆیەتی کە ئەویش پێغەمبەر بووە.‏\f* نزیک بوومەوە و سکی بوو و کوڕێکی بوو. یەزدانیش پێی فەرمووم: «ناوی بنێ: مەهێر شالال حاش بەز،  
\v 4 چونکە بەر لەوەی منداڵەکە بزانێت بڵێت ”بابە“ و ”دایە،“ سامانی دیمەشق و دەستکەوتی سامیرە دەهێنرێتە بەردەم پاشای ئاشور.» 
\p  
\v 5 ئینجا یەزدان دووبارە قسەی لەگەڵمدا کردەوە و فەرمووی: 
\q1  
\v 6 «لەبەر ئەوەی ئەم گەلە 
\q2 ئاوی هێمنی شیلۆوەحی\f + \fr 8:6 \ft شیلۆوەح: هەمان ئاوی سیلوامە. بڕوانە \xt نەحەمیا 3‏:15 و یۆحەنا 9‏:7‏.‏\ft ‏\f* ڕەتکردەوە، 
\q1 دڵخۆش بوو بە ڕەچین و 
\q2 کوڕەکەی ڕەمەلیاهو، 
\q1  
\v 7 لەبەر ئەوە پەروەردگار خەریکە 
\q2 ئاوی ڕووبارە\f + \fr 8:7 \ft واتا ڕووباری فورات.‏\f* بەهێز و زۆرەکە بەسەریاندا هەڵدەستێنێت، 
\q2 مەبەست لە پاشای ئاشور و هەموو شکۆمەندییەکەیەتی. 
\q1 جا بەسەر هەموو جۆگەکانیدا سەردەکەوێت و 
\q2 بەسەر هەموو کەنارەکانیدا دەڕوات، 
\q1  
\v 8 بەناو یەهودا ڕەت دەبێت، هەڵدەچێت و 
\q2 تێدەپەڕێت هەتا دەگاتە گەردن، 
\q1 لێککشانی باڵەکانی پڕ بە پانتایی خاکەکەتە، 
\q2 ئەی ئیمانوێل!» 
\b  
\q1  
\v 9 ئەی گەلینە، گەلەکۆمە بکەن و بشکێنەوە! 
\q2 ئەی هەموو خاکە دوورەکانی جیهان، گوێ بگرن: 
\q1 خۆتان توند بکەن و بشکێنەوە! 
\q2 خۆتان توند بکەن و بشکێنەوە! 
\q1  
\v 10 ڕاوێژ بکەن، پووچ دەبێت، 
\q2 قسە بکەن، سەرناگرێت، 
\q1 چونکە خودا لەگەڵمانە.\f + \fr 8:10 \ft عیبری: \+tl ئیمانوێل‏\+tl*. بڕوانە 7‏:14 و \xt مەتا 1‏:23‏\ft ‏.‏\f* 
\p  
\v 11 یەزدان بەم جۆرەی پێ فەرمووم، کە دەستی گرتم و ئاگاداری کردمەوە بە ڕێگای ئەم گەلەدا نەڕۆم: 
\q1  
\v 12 «مەڵێ ”پیلانگێڕییە!“ 
\q2 بە هەموو ئەوەی ئەم گەلە پێی دەڵێت پیلانگێڕی، 
\q1 مەترسە لەوەی کە ئەوان لێی دەترسن، 
\q2 مەتۆقە. 
\q1  
\v 13 تەنها یەزدانی سوپاسالار بە پیرۆز دابنێ و 
\q2 دەبێ لەو بترسی، 
\q2 لەو بتۆقی. 
\q1  
\v 14 ئەو دەبێتە پیرۆزگا، 
\q2 بەڵام بۆ هەردوو بنەماڵەکەی ئیسرائیل 
\q1 دەبێتە بەردێک بۆ کۆسپ، 
\q2 تاشەبەردێکیش کە لێی بکەونە خوارەوە. 
\q1 بۆ دانیشتووانی ئۆرشەلیم 
\q2 دەبێت بە تەڵە و داو. 
\q1  
\v 15 زۆر کەس ساتمەی لێ دەکەن و دەکەون، 
\q2 دەکەون و تێکدەشکێن، 
\q2 بە داوەوە دەبن و دەگیرێن.» 
\b  
\q1  
\v 16 ئەم شایەتییە بۆ ئاگادارکردنەوە بپێچەوە، 
\q2 فێرکردنەکە بە قوتابییەکانم مۆر بکە. 
\q1  
\v 17 چاوەڕێی یەزدان دەکەم، 
\q2 ئەو کە ڕووی خۆی لە بنەماڵەی یاقوب شاردووەتەوە، 
\q1 من پشت بەو دەبەستم. 
\p  
\v 18 ئەوەتا خۆم و ئەو منداڵانەی کە یەزدان پێیداوم، لەناو ئیسرائیلدا وەک نیشانە و هێمای یەزدانی سوپاسالارین کە لە کێوی سییۆن نیشتەجێیە. 
\s1 تاریکی دەبێتە ڕووناکی 
\p  
\v 19 کە پێتان دەڵێن: «”پرسیار لە نێوانگرەکان\f + \fr 8:19 \ft نێوانگرەکان: لێرە بەو واتایە دێت، ئەو کەسانە کە گوایە هۆی پەیوەندی ڕێکخەرن لەنێوان خەڵکی مردوو و زیندوودا.‏\f* و ڕۆح ئامادەکاران\f + \fr 8:19 \ft ڕۆح ئامادەکاران: بەو کەسانە دەگوترێت کە ڕۆح ئامادە دەکەن. بڕوانە \xt یەکەم ساموئێل 28‏:3؛ 8‏–9‏\ft ‏.‏\f* بکەن کە ورتەورت و چپەچپیانە،“ پێیان بڵێ: ”ئەی گەل، لە خوداکەتان بپرسن. ئایا لە پێناو زیندووان پرسیار لە مردووان دەکەن؟“  
\v 20 بەرەو فێرکردنەکە و بەرەو شایەتییەکە! ئەگەر وەک ئەم قسەیە نەکەن، گزنگی بەیانییان نابێت.  
\v 21 بە سەختی و برسیێتییەوە پێیدا تێدەپەڕن، کاتێک برسی دەبن و قینیان هەڵدەستێت نەفرەت لە پاشای خۆیان و خودای خۆیان دەکەن و سەر هەڵدەبڕن.  
\v 22 ئینجا تەماشای زەوی دەکەن، ناخۆشی و تاریکی و ڕەشی دەبینن، فڕێدەدرێنە ناو تەنگانە و سێبەری مەرگ.» 
\c 9  
\p  
\v 1 بەڵام ئەوانەی لەژێر گوشار بوون لە تاریکی تەنگانەدا نامێنن، وەک سەردەمی پێشوو خاکی زەبولون و خاکی نەفتالی زەلیل کردەوە، سەردەمی کۆتایی ڕێز لە جەلیلی ناجولەکەکان دەگرێت، ئەوەی لە ڕێگای دەریایە، ئەوبەری ڕووباری ئوردون. 
\q1  
\v 2 ئەو گەلەی لە تاریکیدا دەڕۆیشت، 
\q2 ڕووناکییەکی گەورەی بینی، 
\q1 دانیشتووان لە خاکی سێبەری مەرگ 
\q2 ڕووناکی بەسەریاندا هەڵهات. 
\q1  
\v 3 ئەو نەتەوەیەت زۆر کرد و 
\q2 خۆشییەکی گەورەت پێی بەخشی، 
\q1 لەبەردەمت دڵخۆش بوو 
\q2 وەک خۆشی کاتی دروێنە، 
\q1 وەک ئەوانەی شاد دەبن 
\q2 بە دابەشکردنی دەستکەوت. 
\q1  
\v 4 لەبەر ئەوەی نیری بارگرانی ئەو و 
\q2 داری پشتی ئەو و 
\q1 کوتەکی بێگاری پێکردنی ئەوت 
\q2 وەک ڕۆژی میدیان شکاند. 
\q1  
\v 5 هەموو پۆستاڵی جەنگاوەران لە گەرمەی شەڕدا و 
\q2 بەرگی لەناو خوێن گەوزاو 
\q1 بۆ سووتان دەبێت، 
\q2 سووتەمەنییە بۆ ئاگر، 
\q1  
\v 6 چونکە کوڕێکمان دەبێت، 
\q2 کوڕێکمان پێدەدرێت و 
\q2 سەرکردایەتی دەکەوێتە سەرشانی. 
\q1 ناوی لێ دەنرێت 
\q2 سەرسوڕهێنەر و ڕاوێژکار، خودای بەتوانا، 
\q2 باوکی هەتاهەتایی، میری ئاشتی. 
\q1  
\v 7 گەشەسەندنی سەرۆکایەتی و ئاشتییەکەی 
\q2 بێ کۆتایی دەبێت. 
\q1 لەسەر تەختی داود و بەسەر شانشینەکەی 
\q2 پاشایەتی دەکات 
\q1 بۆ چەسپاندنی و بەهێزکردنی، 
\q2 بە دادپەروەری و بە ڕاستودروستی 
\q2 لە ئێستاوە و هەتاهەتایە. 
\q1 دڵگەرمی یەزدانی سوپاسالار ئەمە دەکات. 
\s1 تووڕەیی یەزدان لە دژی ئیسرائیل 
\q1  
\v 8 پەروەردگار وشەیەکی لە دژی یاقوب نارد و 
\q2 بەسەر ئیسرائیلدا کەوت. 
\q1  
\v 9 گەل هەموو دەزانن، 
\q2 ئەفرایم و دانیشتووانی سامیرە، 
\q1 بە لووتبەرزی و 
\q2 فیزی دڵەوە دەڵێن: 
\q1  
\v 10 «خشت ڕووخا، 
\q2 بەڵام بە بەردی تاشراو بنیاد دەنێینەوە؛ 
\q1 هەنجیرە کێوی بڕایەوە، 
\q2 بەڵام داری ئورز لە شوێنی دادەنێین.» 
\q1  
\v 11 یەزدان دوژمنانی ڕەچینی پاشای لێ هەڵدەستێنێت، 
\q2 ناحەزانی جۆش دەدات. 
\q1  
\v 12 ئارامییەکان لە ڕۆژهەڵاتەوە و فەلەستییەکان لە ڕۆژئاواوە 
\q2 پڕ بە دەم ئیسرائیل هەڵدەلووشن. 
\b  
\q1 لەگەڵ هەموو ئەوەشدا تووڕەییەکەی دانەمرکایەوە، 
\q2 هێشتا دەستی درێژکردووە. 
\b  
\q1  
\v 13 گەل هێشتا نەگەڕایەوە لای لێدەرەکەی، 
\q2 ڕوویان لە یەزدانی سوپاسالار نەکرد. 
\q1  
\v 14 یەزدان لە ئیسرائیل سەر و کلک دەبڕێت، 
\q2 دار خورما و قامیش لە یەک ڕۆژدا، 
\q1  
\v 15 پیر و پیاوماقوڵ سەرەکەن، 
\q2 ئەو پێغەمبەرانەی کە فێرکردنی درۆیین فێر دەکەن کلکەکەن. 
\q1  
\v 16 ڕابەرانی ئەم گەلە بوون بە چەواشەکار، 
\q2 ئەوانەی ڕابەرایەتی دەکرێن سەریان لێ شێواوە. 
\q1  
\v 17 لەبەر ئەوە پەروەردگار دڵخۆش نابێت بە گەنجەکانیان، 
\q2 بەزەیی نایەتەوە بە هەتیو و بێوەژنەکانیان، 
\q1 چونکە هەموو خوانەناس و خراپەکارن، 
\q2 هەموو دەمەکان بە گێلی دەدوێن. 
\b  
\q1 لەگەڵ هەموو ئەوەشدا تووڕەییەکەی دانەمرکایەوە، 
\q2 هێشتا دەستی درێژکردووە. 
\b  
\q1  
\v 18 بێگومان بەدکاری وەک ئاگر دەسووتێت، 
\q2 دڕکوداڵ دەخوات، 
\q1 گڕ لە دەوەنی دارستان بەردەدات، 
\q2 ستوونی دووکەڵ لوول دەخوات. 
\q1  
\v 19 بە جۆشی تووڕەیی یەزدانی سوپاسالار 
\q2 خاکەکە دەسووتێت، 
\q1 گەلیش دەبێت بە سووتەمەنی ئاگر، 
\q2 پیاو دڵی بە برای خۆی ناسووتێ. 
\q1  
\v 20 لای ڕاست لێ دەکاتەوە و 
\q2 هەر برسییە، 
\q1 لای چەپ دەخوات و 
\q2 تێر نابێت. 
\q1 پیاو گۆشتی قۆڵی خۆی دەخوات: 
\q1  
\v 21 مەنەشە ئەفرایم دەخوات و ئەفرایمیش مەنەشە، 
\q2 هەردووکیان پێکەوە لە دژی یەهودا هەڵدەگەڕێنەوە. 
\b  
\q1 لەگەڵ هەموو ئەوەشدا تووڕەییەکەی دانەمرکایەوە، 
\q2 هێشتا دەستی درێژکردووە. 
\b  
\b  
\c 10  
\q1  
\v 1 قوڕبەسەر فەرزدانەرانی فەرزی بەدکاری و 
\q2 ئەوانەی فەرمانی ستەمکارانە دەردەکەن، 
\q1  
\v 2 بۆ ئەوەی دەست بنێن بە ڕووی هەژارانەوە لە دادوەری و 
\q2 مافی نەدارانی گەلەکەم بخۆن، 
\q1 بۆ ئەوەی بێوەژنان ببن بە دەستکەوتیان و 
\q2 هەتیوانیش تاڵان بکەن. 
\q1  
\v 3 لە ڕۆژی سزا چی دەکەن، 
\q2 کاتێک ماڵوێرانی لە دوورەوە دێت؟ 
\q1 بۆ لای کێ هەڵدێن بۆ یارمەتی و 
\q2 گەنجینەتان لەکوێ بەجێدەهێڵن؟ 
\q1  
\v 4 بێجگە لە چۆکدادان لەژێر دیل و 
\q2 کەوتن لەژێر کوژراوەکان. 
\b  
\q1 لەگەڵ هەموو ئەوەشدا تووڕەییەکەی دانەمرکایەوە، 
\q2 هێشتا دەستی درێژکردووە. 
\s1 حوکمی خودا بەسەر ئاشور 
\q1  
\v 5 «قوڕبەسەر ئاشور، داردەستی تووڕەییم، 
\q2 هەڵچوونم گۆچانە بە دەستیەوە. 
\q1  
\v 6 بۆ سەر نەتەوەیەکی خوانەناس دەینێرم، 
\q2 فەرمانی پێدەدەم بۆ سەر ئەو گەلەی تووڕەییم لێی دەجۆشێت، 
\q1 تاکو دەستکەوتی دەست بکەوێت و تاڵان بکات، 
\q2 هەتا بیکات بە پێشێلکراو وەک قوڕی کۆڵانان. 
\q1  
\v 7 بەڵام ئەو وا بیر ناکاتەوە، 
\q2 ئەو ئەمەی لە دڵدا نییە، 
\q1 چونکە ئامانجی ئەو وێرانکردنە، 
\q2 لەناوبردنی گەلانێکی زۆرە. 
\q1  
\v 8 دەڵێت: ”ئایا هەموو میرەکانم پاشا نین؟ 
\q2  
\v 9 ئایا کەلنۆ وەک کەرکەمیش نییە؟ 
\q1 یان حەمات وەک ئەرپاد؟ 
\q2 یان سامیرە وەک دیمەشق؟ 
\q1  
\v 10 وەک چۆن دەستم بە شانشینی بتەکان گەیشت و 
\q2 وێنەی بتەکانیان زۆرترن لەوانەی ئۆرشەلیم و لەوانەی سامیرە، 
\q1  
\v 11 ئایا وەک ئەوەی بە سامیرە و بە بتەکانی ئەوم کرد، 
\q2 وا بە ئۆرشەلیم و بە وێنەی بتەکانی ناکەم؟“» 
\p  
\v 12 دوای ئەوەی پەروەردگار هەموو ئیش و کارەکەی لە کێوی سییۆن و لە ئۆرشەلیم تەواو دەکات، دەڵێت: «سزای بەروبوومی بەفیزی دڵی پاشای ئاشور و شانازی لووتبەرزییەکەی دەدەم،  
\v 13 چونکە دەڵێت: 
\q1 «”بە توانای دەستی خۆم کردم و 
\q2 بە داناییەکەم، چونکە تێگەیشتووم، 
\q1 سنووری گەلانم گواستەوە و 
\q2 گەنجینەکانی ئەوانم تاڵان کرد، 
\q2 وەک دلێرێک پاشاکانی ئەوانم ملکەچ کرد، 
\q1  
\v 14 دەستم گەیشتە سامانی گەلان، 
\q2 وەک چۆن دەست دەگاتە هێلانە؛ 
\q1 وەک کۆکردنەوەی هێلکەی بەجێماو، 
\q2 هەموو زەویم کۆکردەوە، 
\q1 کەسیش نەبوو باڵی لێک بدات 
\q2 یان دەمی بکاتەوە و ورتەیەکی لێ بێت.“» 
\b  
\q1  
\v 15 تەور شانازی دەکات بەسەر ئەو کەسەی پێی دەبڕێتەوە، 
\q2 یان مشار خۆی بە زل دەزانێت بەسەر ئەو کەسەی دەیبات و دەیهێنێت؟ 
\q1 وەک ئەوەی داردەست هەڵگرەکەی ڕاوەشێنێت 
\q2 وەک ئەوەی گۆچان ئەو کەسە بەرز بکاتەوە کە دار نییە. 
\q1  
\v 16 لەبەر ئەوە یەزدان، پەروەردگاری سوپاسالار 
\q2 لەڕی دەنێرێتە ناو پاڵەوانە بەهێزەکان، 
\q1 لەژێر شکۆمەندییەکەشی پشکۆیەک دادەگیرسێنێت 
\q2 وەک داگیرسانی ئاگر. 
\q1  
\v 17 ڕووناکی ئیسرائیل\f + \fr 10:17 \ft نازناوە بۆ خودای ئیسرائیل.‏\f* دەبێت بە ئاگر و 
\q2 پیرۆزەکەشی بە گڕ، 
\q1 دەیسووتێنێت و دەیخوات چقڵ و دڕکەکەی 
\q2 لە یەک ڕۆژدا. 
\q1  
\v 18 چڕی دارستان و باخەکانی بە تەواوی لەناودەبات، 
\q2 گیان و لەش پێکەوە 
\q2 وەک توانەوەی نەخۆش دەبێت. 
\q1  
\v 19 پاشماوەی داری دارستانەکانی ئەوەندە کەم دەبن 
\q2 منداڵێک دەتوانێت بیانژمێرێت. 
\s1 پاشماوەی ئیسرائیل 
\q1  
\v 20 لەو ڕۆژەدا، پاشماوەی ئیسرائیل و 
\q2 دەربازبووەکانی بنەماڵەی یاقوب، 
\q1 چیتر پشت نابەستن 
\q2 بەوانەی لێیان دەدەن، 
\q1 بەڵکو بەڕاستی بە یەزدان و 
\q2 بە خودا پیرۆزەکەی ئیسرائیل پشت دەبەستن. 
\q1  
\v 21 پاشماوە دەگەڕێتەوە، پاشماوەی یاقوب 
\q2 بۆ لای خودای توانادار. 
\q1  
\v 22 ئەی ئیسرائیل، ئەگەر گەلت بەقەد لمی دەریا بێت، 
\q2 تەنها پاشماوەی لێ دەگەڕێتەوە. 
\q1 بڕیاری قڕبوون دراوە، 
\q2 لافاوی ڕاستودروستییە. 
\q1  
\v 23 یەزدانی پەروەردگاری سوپاسالار 
\q2 بڕیاری وێرانکردنی هەموو خاکەکە جێبەجێ دەکات. 
\p  
\v 24 بەڵام یەزدان، پەروەردگاری سوپاسالار ئەمە دەفەرموێت: 
\q1 «ئەی گەلی من کە لە سییۆن دانیشتووی، 
\q2 لە ئاشور مەترسە 
\q1 کە بە داردەست لێت دەدات و 
\q2 گۆچانەکەی لێت بەرز دەکاتەوە لەسەر شێوازی میسرییەکان. 
\q1  
\v 25 بەم زووانە هەڵچوونم لەسەر ئێوە نامێنێت و 
\q2 تووڕەییم بۆ لەناوچوونی ئەوان دەبێت.» 
\b  
\q1  
\v 26 یەزدانی سوپاسالار بە قامچی لێی دەدات 
\q2 وەک لێدانەکەی میدیان لەلای تاشەبەردی عۆرێڤ و 
\q1 گۆچانەکەی بەسەر دەریاوەیە 
\q2 لەسەر شێوازی میسرییەکان بەرزی دەکاتەوە. 
\q1  
\v 27 جا لەو ڕۆژەدا، 
\q2 باری لەسەر شانت لادەچێت و 
\q1 نیری\f + \fr 10:27 \ft مەبەستی لە بارگرانییە.‏\f* لەسەر ملت، 
\q2 لەبەر قەڵەوبوونت نیر دەتەقێت. 
\b  
\q1  
\v 28 گەیشتە\f + \fr 10:28 \ft مەبەستی لە هاتنی سوپای ئاشورە بۆ شارۆچکەکانی باکووری یەهودا.‏\f* عەییات، 
\q2 لە میگرۆن پەڕییەوە، 
\q2 لە میخماس کەلوپەلەکانی خۆی دانا. 
\q1  
\v 29 ئەوان لە دەربەندەکە دەپەڕنەوە و دەڵێن: 
\q2 «گەڤەع شوێنی شەو مانەوەیە.» 
\q1 ڕامە داچڵەکی، 
\q2 گیڤعای شاول هەڵات. 
\q1  
\v 30 ئەی دانیشتووانی شاری گەلیم، بە دەنگی خۆتان بحیلێنن! 
\q2 ئەی لەیشا، گوێ بگرە! 
\q2 داماوە عەناتۆت. 
\q1  
\v 31 مەدمێنا ڕایکردووە، 
\q2 خەڵکی گێڤیم پەناگیر بوون. 
\q1  
\v 32 ئەمڕۆ لە نۆڤ دەوەستن، 
\q2 بە ڕاوەشاندنی دەست هەڕەشە دەکەن 
\q1 لە کێوەکەی شاری سییۆن، 
\q2 لە گردەکەی ئۆرشەلیم. 
\b  
\q1  
\v 33 ئەوەتا یەزدان، پەروەردگاری سوپاسالار 
\q2 بە هێزێکی تۆقێنەر لق دەبڕێتەوە. 
\q1 باڵا بەرزەکان دەبڕدرێنەوە، 
\q2 لووتبەرزەکان نزم دەکرێن. 
\q1  
\v 34 چڕی دارستانەکان بە تەور دەبڕێتەوە، 
\q2 لوبنانیش بەرامبەر بە خودای توانادار دەکەوێت. 
\c 11  
\s1 لقەکە لە بنەماڵەی یەسا 
\q1  
\v 1 چڵێک لە بنەداری یەسا دەردەچێت، 
\q2 لقێکی نوێ لە ڕەگەکەیەوە دەڕوێت. 
\q1  
\v 2 ڕۆحی یەزدان لەسەری دەنیشێتەوە، 
\q2 ڕۆحی دانایی و تێگەیشتن، 
\q1 ڕۆحی ڕاوێژ و ئازایەتی، 
\q2 ڕۆحی زانین و لەخواترسی، 
\q1  
\v 3 بە لەخواترسی شادمان دەبێت. 
\b  
\q1 بەگوێرەی بینینی چاوی خۆی دادوەری ناکات، 
\q2 بەگوێرەی بیستنی گوێی خۆی بڕیار نادات، 
\q1  
\v 4 بەڵکو بە ڕاستودروستی دادوەری بۆ هەژاران دەکات و 
\q2 بە ڕاستی بڕیار بۆ نەدارانی جیهان دەدات. 
\q1 بە داردەستی دەمی لە زەوی دەدات، 
\q2 بە بای لێوەکانی بەدکاران دەکوژێت. 
\q1  
\v 5 ڕاستودروستی دەبێتە پشتێن و 
\q2 دڵسۆزیش دەبێتە کەمەربەند بە ناوقەدیەوە. 
\b  
\q1  
\v 6 گورگ لەگەڵ بەرخ نیشتەجێ دەبێت، 
\q2 پڵنگ لەگەڵ کارەبزن پاڵ دەداتەوە، 
\q1 گوێرەکە و بەچکە شێر و دابەستە پێکەوەن و 
\q2 منداڵێکی بچووک بەڕێوەیان دەبات. 
\q1  
\v 7 مانگا و ورچ پێکەوە دەلەوەڕێن، 
\q2 بێچووەکانیان پێکەوە پاڵ دەدەنەوە، 
\q2 شێر وەکو گا کا دەخوات. 
\q1  
\v 8 کۆرپەی شیرەخۆرە لەسەر کونی ماری کۆبرا یاری دەکات، 
\q2 لەشیربڕاوە دەست دەباتە ناو کونی مارەوە. 
\q1  
\v 9 خراپە و گەندەڵی ناکەن لە هەموو کێوی پیرۆزم، 
\q2 چونکە زەوی پڕ دەبێت لە ناسینی یەزدان 
\q2 هەروەک ئاو دەریا دادەپۆشێت. 
\p  
\v 10 لەو ڕۆژەدا ڕەگەکەی یەسا کە چەقاوە وەک ئاڵای گەلان، نەتەوەکان داوای ئەو دەکەن و شوێنی حەوانەوەی شکۆدار دەبێت.  
\v 11 لەو ڕۆژەدا پەروەردگار دووبارە دەستی درێژ دەکاتەوە بۆ کڕینەوەی پاشماوەی گەلەکەی خۆی، ئەوەی ماوەتەوە لە ئاشور، لە پاشایەتی باکووری میسر و پاشایەتی باشووری میسر، لە کوش\f + \fr 11:11 \ft واتا ئەو ناوچەیە کە نزیکی سەرچاوەی ڕووباری نیل.‏\f*، ئیلام، بابل، حەمات و لە دوورگەکانی دەریا. 
\q1  
\v 12 ئاڵایەک بۆ نەتەوەکان بەرز دەکاتەوە و 
\q2 دوورخراوەکانی ئیسرائیل کۆدەکاتەوە، 
\q1 پەرتەوازەکانی یەهودا خڕدەکاتەوە 
\q2 لە هەر چوار لای زەوییەوە. 
\q1  
\v 13 بەغیلی ئەفرایم نامێنێت و 
\q2 هەراسانی یەهوداش دەبڕدرێتەوە، 
\q1 ئەفرایم بەغیلی بە یەهودا نابات و 
\q2 یەهوداش ئەفرایم هەراسان ناکات. 
\q1  
\v 14 پێکەوە ڕووەو دەریا بەلای زوورگەکان پەلاماری فەلەستییەکان دەدەن و 
\q2 خەڵکی ڕۆژهەڵات تاڵان دەکەن. 
\q1 ئەدۆم و مۆئاب ژێردەستەیان دەبن، 
\q2 عەمۆنییەکانیش گوێڕایەڵیان دەبن. 
\q1  
\v 15 یەزدان کەنداوی دەریای میسر 
\q2 تێکوپێک دەدات، 
\q1 بە بایە سووتێنەرەکەی 
\q2 دەستی ڕادەوەشێنێت بەسەر فوراتدا، 
\q1 لێی دەدات و دەیکاتە حەوت جۆگە 
\q2 بە پێڵاوەوە بەناویدا دەڕۆن. 
\q1  
\v 16 دەبێت بە ڕێگا بۆ پاشماوەی گەلەکەی 
\q2 ئەوانەی لە ئاشور دەمێننەوە 
\q1 وەک ئەوەی بۆ ئیسرائیل بوو 
\q2 لەو ڕۆژەی لە خاکی میسرەوە هاتنە دەرەوە. 
\c 12  
\s1 گۆرانی ستایش 
\q1  
\v 1 لەو ڕۆژەدا دەڵێیت: 
\q2 «ئەی یەزدان، ستایشت دەکەم، 
\q1 هەرچەندە لێم تووڕە بوویت، 
\q2 بەڵام تووڕەییەکەت لە من دامرکایەوە و دڵت دامەوە. 
\q1  
\v 2 ئەوەتا خودای ڕزگاریی من، 
\q2 دڵنیا دەبم و ناترسم، 
\q1 چونکە یەزدانی پەروەردگار هێز و سروودی منە و 
\q2 ئەو بوو بە ڕزگاریم.» 
\q1  
\v 3 بە شادییەوە ئاو دەکێشنەوە 
\q2 لە کانییەکانی ڕزگاری. 
\p  
\v 4 لەو ڕۆژەدا دەڵێن: 
\q1 «ستایشی یەزدان بکەن، ناوی ڕابگەیەنن، 
\q2 وا بکەن کردارەکانی لەنێو گەلاندا زانراو بێت، 
\q2 باسی ئەوە بکەن کە ناوی بەرز بووەتەوە. 
\q1  
\v 5 گۆرانی بۆ یەزدان بڵێن، 
\q2 چونکە کاری شکۆمەندانەی کردووە، 
\q2 با ئەمە لە هەموو جیهاندا زانراو بێت. 
\q1  
\v 6 ئەی نیشتەجێی سییۆن دەنگ بەرز بکەرەوە و هاوار بکە! 
\q2 چونکە خودا پیرۆزەکەی ئیسرائیل لەنێوتاندا مەزنە.» 
\c 13  
\s1 سروشێک سەبارەت بە بابل 
\p  
\v 1 سروشێک\f + \fr 13:1 \ft ‏فەرموودەیەکی خودایە کە لە ڕێگای ڕۆحی پیرۆزەوە بۆ مرۆڤ هاتبێت.‏\f* سەبارەت بە بابل ئەوەی ئیشایای کوڕی ئامۆچ بینی: 
\q1  
\v 2 لەسەر کێوێکی ڕووت ئاڵایەک هەڵبکەن، 
\q2 دەنگیان لێ بەرز بکەنەوە، 
\q1 دەست ڕابشەکێنن با بێنە ژوورەوە 
\q2 بۆ ناو دەرگای میران. 
\q1  
\v 3 من فەرمانم بە تەرخانکراوەکانم کرد، 
\q2 هەروەها بانگی پاڵەوانەکانی خۆمم کرد لەبەر تووڕەییم، 
\q2 ئەو پاڵەوانانەی دڵخۆشن بە سەرکەوتنم. 
\b  
\q1  
\v 4 گوێ بگرن، دەنگی هەراوهۆریا لە چیاکان دێت، 
\q2 وەک دەنگی خەڵکێکی ئێجگار زۆر! 
\q1 گوێ بگرن، دەنگی هاتوهەرای شانشینەکان دێت، 
\q2 وەک دەنگی نەتەوەکان کۆبوونەتەوە! 
\q1 یەزدانی سوپاسالار 
\q2 سوپایان لێ پێکدەهێنێت بۆ جەنگ! 
\q1  
\v 5 لە خاکێکی دوورەوە دێن، 
\q2 لەوپەڕی ئاسمانەوە دێن، 
\q1 یەزدان و چەکەکانی تووڕەیی، 
\q2 بۆ تێکوپێکدانی سەراپای زەوی. 
\b  
\q1  
\v 6 واوەیلا بکەن، چونکە ڕۆژی یەزدان\f + \fr 13:6 \ft ڕۆژی سزادانی گوناهباران و ڕزگارکردنی گەلی خودا.‏\f* نزیک بووەتەوە، 
\q2 وەک وێرانبوون لەلایەن خودای هەرە بەتواناوە دێت. 
\q1  
\v 7 لەبەر ئەوە هەموو دەستەکان شل دەبن، 
\q2 هەموو دڵێکی مرۆڤ دەتوێتەوە. 
\q1  
\v 8 ڕادەچڵەکێن، 
\q2 ئازار و ژان دەیانگرێت، 
\q2 وەک منداڵبوو دەتلێنەوە. 
\q1 پیاو واقی وڕدەمێنێت لە هاوڕێکەی، 
\q2 ڕوویان وەک ڕووی گڕی ئاگرە. 
\b  
\q1  
\v 9 ئەوەتا ڕۆژی یەزدان دێت، 
\q2 سەختە، توندوتیژ و تووڕەیی بە جۆشە، 
\q1 بۆ ئەوەی زەوی وێران بکات و 
\q2 گوناهبارانی لێ ببڕێتەوە. 
\q1  
\v 10 ئەستێرەکانی ئاسمان و کەلووەکانی 
\q2 ڕووناکییان دەرناخەن، 
\q1 خۆر لە کاتی هەڵاتنی تاریک دادێت، 
\q2 مانگیش ڕووناکییەکەی نادرەوشێتەوە. 
\q1  
\v 11 سزای جیهان دەدەم لەسەر خراپەکەی، 
\q2 بەدکارانیش لەسەر تاوانەکانیان، 
\q1 کۆتایی دەهێنم بە فیزی لووتبەرزان و 
\q2 سەری بێ ویژدانەکان شۆڕ دەکەم. 
\q1  
\v 12 مرۆڤ لە زێڕی بێگەرد دەگمەنتر دەکەم و 
\q2 ئادەمیزادیش لە زێڕی ئۆفیر. 
\q1  
\v 13 لەبەر ئەوە ئاسمان دەهەژێنم و 
\q2 زەویش لە شوێنی خۆی دەلەرزێت، 
\q1 لەبەر تووڕەیی یەزدانی سوپاسالار و 
\q2 لە ڕۆژی هەڵچوونی تووڕەییەکەی. 
\b  
\q1  
\v 14 وەک مامزی ڕاونراو دەبێت و 
\q2 وەک ڕانە مەڕ کەس نەبێت کۆی بکاتەوە، 
\q1 هەرکەسە ڕوو لە گەلەکەی خۆی دەکات و 
\q2 هەرکەسە بەرەو خاکەکەی خۆی هەڵدێت. 
\q1  
\v 15 ئەوەی بدۆزرێتەوە دەدرێتە بەر خەنجەر و 
\q2 ئەوەی بگیرێت بە شمشێر دەکوژرێت. 
\q1  
\v 16 منداڵەکانیان لەبەرچاویان پارچەپارچە دەکرێن و 
\q2 ماڵیان تاڵان دەکرێت و ژنەکانیان زەوت دەکرێن. 
\b  
\q1  
\v 17 ئەوەتا من مادەکان لە دژیان هەڵدەستێنم، 
\q2 ئەوانەی گوێ بە زیو نادەن و 
\q2 کەیفیان بە زێڕ نایەت. 
\q1  
\v 18 کەوانەکانیان لاوان تێکدەشکێنن، 
\q2 بەزەییان بە کۆرپەکاندا نایەتەوە، 
\q2 دڵیان بە منداڵان ناسووتێت. 
\q1  
\v 19 بابلی شکۆمەندی شانشینەکان و 
\q2 جوانی شانازی بابلییەکان 
\q1 وەک سەدۆم و عەمۆرا دەبێت، 
\q2 کە لەلایەن خوداوە سەرەوژێر کرابێت. 
\q1  
\v 20 هەتاهەتایە ئاوەدان ناکرێتەوە و 
\q2 نەوە دوای نەوە کەس تێیدا نیشتەجێ نابێت، 
\q1 عەرەب لەوێ دەوار هەڵنادات، 
\q2 شوانەکان لەوێ مێگەل مۆڵ نادەن. 
\q1  
\v 21 بەڵام لەوێ دڕندە بیابانییەکان ڕادەکشێن، 
\q2 چەقەڵ خانووەکانی پڕ دەکەن؛ 
\q1 کوندەپەپوو لەوێ نیشتەجێ دەبێت، 
\q2 تەگە لەوێ سەما دەکەن. 
\q1  
\v 22 کەمتیار لەناو قەڵاکانی بابل دەلوورێنێت، 
\q2 چەقەڵیش لەناو کۆشکەکانی. 
\q1 کاتەکەی نزیکە بۆ هاتن، 
\q2 ڕۆژگاری درێژە ناکێشێت. 
\b  
\b  
\c 14  
\q1  
\v 1 یەزدان بەزەیی بە یاقوبدا دێتەوە و 
\q2 دیسان ئیسرائیل هەڵدەبژێرێتەوە، 
\q2 لە خاکەکەی خۆیان دەیانحەسێنێتەوە، 
\q1 نامۆکان خۆیانی پێوە دەلکێنن و 
\q2 دێنە پاڵ بنەماڵەی یاقوب. 
\q1  
\v 2 گەلان دەیانگرن و 
\q2 دەیانبەن بۆ شوێنی خۆیان، 
\q1 بەڵام بنەماڵەی ئیسرائیل دەستیان بەسەردا دەگرن و 
\q2 دەیانکەن بە کۆیلە و کەنیزە لە خاکی یەزدان، 
\q1 دەبنە ڕاپێچکەری ڕاپێچکەرانیان و 
\q2 دەسەڵاتدار دەبن بەسەر ستەمکارانیاندا. 
\p  
\v 3 ئەو ڕۆژەی یەزدان لە ناخۆشی و هەراسانی و ئەو کۆیلایەتییە سەختەی چێژتت دەتحەسێنێتەوە،  
\v 4 ئەم پەندە بەسەر پاشای بابلدا هەڵدەدەیت و دەڵێیت: 
\q1 زۆردار چۆن کۆتایی پێ هات! 
\q2 خۆبەزلزانەکە چۆن کۆتایی هات! 
\q1  
\v 5 یەزدان گۆچانی بەدکارانی شکاند، 
\q2 داردەستی فەرمانڕەواکان، 
\q1  
\v 6 ئەوانەی بە قینەوە لە گەلەکانیان دەدا، 
\q2 لێدانێکی بێ بڕانەوە، 
\q1 بە تووڕەییەوە دەسەڵاتیان لەسەر نەتەوەکان پەیڕەو دەکرد، 
\q2 بێ بەزەیی دەیانچەوساندنەوە. 
\q1  
\v 7 هەموو زەوی حەسایەوە و دڵنیابوو 
\q2 بە هوتاف لێدان دەنگیان هەڵبڕی. 
\q1  
\v 8 هەروەها دار سنەوبەر و ئورزی لوبنانیش 
\q2 شادن بەوەی بەسەرت هاتووە و دەڵێن: 
\q1 «لەو کاتەوەی تۆ ڕاکشایت 
\q2 داربڕ نەهاتووەتە سەرمان.» 
\b  
\q1  
\v 9 جیهانی مردووان لە ژێرەوە دەوروژێنێت 
\q2 بۆ پێشوازی لە هاتنت، 
\q1 ڕۆحی مردووەکان بۆ تۆ هەڵدەستێنێت، 
\q2 هەموو سەرکردەکانی جیهان، 
\q1 لەسەر تەختەکانیان هەڵیاندەستێنێت، 
\q2 هەموو پاشایانی نەتەوەکان. 
\q1  
\v 10 هەموو وەڵام دەدەنەوە و پێت دەڵێن: 
\q2 «هەروەها تۆش وەک ئێمە لاواز بوویت، 
\q2 وەک ئێمەت لێ هات.» 
\q1  
\v 11 مەزنیت شۆڕکرایەوە ناو جیهانی مردووان 
\q2 بەدەم ئاوازی سازەکانت، 
\q1 لە ژێرت مۆرانە ڕادەخرێت و 
\q2 کرمیش دەبێتە لێفەت. 
\b  
\q1  
\v 12 چۆن لە ئاسمانەوە بەربوویتەوە، 
\q2 ئەی ئەستێرەی پڕشنگدار،\f + \fr 14:12 \ft دەربڕینێکە نووسەر بە گاڵتەجاڕییەوە بە پاشای بابلی دەڵێت.‏\f* کوڕی بەرەبەیان! 
\q1 بەرەو زەوی بڕایتەوە، 
\q2 ئەی بەزێنەری نەتەوەکان! 
\q1  
\v 13 تۆ کە لە دڵی خۆتدا گوتت: 
\q2 «سەردەکەوم بۆ ئاسمان، 
\q1 لە سەرووی ئەستێرەکانی خوداوە 
\q2 تەختی خۆم بەرز دەکەمەوە، 
\q1 لەسەر کێوی ژووان دادەنیشم، 
\q2 لەسەر لووتکەی چافۆن. 
\q1  
\v 14 سەردەکەومە سەر بەرزاییەکانی هەور، 
\q2 خۆم وەک خودای هەرەبەرز لێدەکەم.» 
\q1  
\v 15 بەڵام بەرەو جیهانی مردووان شۆڕ بوویتەوە، 
\q2 بەرەو قووڵایی بیری بێ بن. 
\b  
\q1  
\v 16 ئەوانەی دەتبینن تەماشات دەکەن، 
\q2 لێت ورد دەبنەوە: 
\q1 «ئایا ئەمە ئەو پیاوەیە کە زەوی لەرزاند، 
\q2 شانشینەکانی هەژاند، 
\q1  
\v 17 ئەوەی جیهانی کردە چۆڵەوانی، 
\q2 شارەکانی جیهانی تەفروتونا کرد، 
\q2 ئەوەی دیلەکانی بەرەو ماڵی خۆیان بەڕەڵا نەکرد؟» 
\b  
\q1  
\v 18 هەموو پاشایانی نەتەوەکان بە ڕێزەوە ڕاکشان، 
\q2 هەریەکە و لە ئارامگای خۆی. 
\q1  
\v 19 بەڵام تۆ لە گۆڕەکەتەوە تووڕ هەڵدەدرێیت 
\q2 وەک چڵەدارێکی ڕەتکراوە. 
\q1 دادەپۆشرێیت بە تەرمی کوژراوان 
\q2 کە بە شمشێر لێیان دراوە، 
\q2 شۆڕبووەوەکان بەرەو بەردەکانی بیری بێ بن. 
\q1 وەک لاشەی پێشێلکراو، 
\q2  
\v 20 لە ناشتن لەگەڵیاندا یەک ناگریت، 
\q1 چونکە خاکەکەی خۆتت کاول کرد، 
\q2 گەلەکەی خۆتت کوشت. 
\b  
\q1 با توخمی خراپەکاران 
\q2 هەتاهەتایە ناویان نەیەت. 
\q1  
\v 21 سەربڕین بۆ کوڕەکانیان ئامادە بکەن 
\q2 لەسەر تاوانی باوکانیان، 
\q1 با هەڵنەستن بۆ ئەوەی زەوی داگیر بکەن و 
\q2 ڕووی جیهان بە شار پڕ بکەنەوە. 
\b  
\q1  
\v 22 «هەڵدەستمە سەریان،» 
\q2 یەزدانی سوپاسالار دەفەرموێت. 
\q1 «لە بابل ناو و پاشماوە و 
\q2 نەوە و وەچە ڕیشەکێش دەکەم.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\q1  
\v 23 «دەیکەم بە میراتی کوندەپەپوو و 
\q2 گۆمی ئاو، 
\q1 بە گسکی نەمان گسکی دەدەم،» 
\q2 یەزدانی سوپاسالار دەفەرموێت. 
\s1 پلان لە دژی ئاشور 
\q1  
\v 24 یەزدانی سوپاسالار سوێندی خوارد و فەرمووی: 
\q1 «بێگومان هەروەک ئەوەی دامڕشتووە ئاوا دەبێت، 
\q2 وەک ئەوەی پلانم بۆ داناوە دێتە دی. 
\q1  
\v 25 ئاشور لە خاکەکەی خۆم دەشکێنم، 
\q2 لەسەر چیاکانم پێشێلی دەکەم، 
\q1 جا نیرەکەی لەسەریان لادەچێت و 
\q2 بارگرانییەکەی لە کۆڵیان دەبێتەوە.» 
\b  
\q1  
\v 26 ئەمە ئەو پلانەیە کە بۆ هەموو جیهان داڕێژراوە و 
\q2 ئەمە ئەو دەستەیە کە بۆ سەر هەموو نەتەوەکان درێژکراوە. 
\q1  
\v 27 یەزدانی سوپاسالار پلانی داناوە، کێ پووچی دەکاتەوە؟ 
\q2 دەستی ئەوە درێژکراوە، کێ دەیگێڕێتەوە؟ 
\s1 سروشێک سەبارەت بە فەلەستییەکان 
\q1  
\v 28 لە ساڵی مردنی ئاحازی پاشادا ئەم سروشە هات: 
\q1  
\v 29 ئەی هەموو فەلەستییەکان شاد مەبن، 
\q2 کە گۆچانی لێدەرەکەت شکا، 
\q1 چونکە توولە مار لە ڕەگی مارەوە دەردەچێت و 
\q2 بەرەکەی مارێکی سووتێنەری باڵدارە. 
\q1  
\v 30 هەژارترینی هەژاران بەخێو دەکرێن و 
\q2 نەداران بە ئاسوودەیی پاڵ دەدەنەوە، 
\q1 ڕەگی تۆش بە قاتوقڕی دەکوژم و 
\q2 پاشماوەکەشت دەکوژرێت. 
\b  
\q1  
\v 31 ئەی دەروازە واوەیلا بکە! ئەی شار هاوار بکە! 
\q2 ئەی فەلەستی سەراپات توایەوە! 
\q1 چونکە دووکەڵ لە باکوورەوە دێت و 
\q2 ناڕێکی لە ڕیزەکانی نابینرێت. 
\q1  
\v 32 چی وەڵامی نێردراوی نەتەوەکان دەدرێتەوە؟ 
\q2 «یەزدان سییۆنی دامەزراند و 
\q2 لە ئەودا گەلە چەوسێنراوەکەی پەناگیر دەبن.» 
\c 15  
\s1 سروشێک سەبارەت بە مۆئاب 
\p  
\v 1 سروشێک سەبارەت بە مۆئاب: 
\q1 عار لە مۆئاب وێران بوو، 
\q2 لە یەک شەودا کاول بوو! 
\q1 قییر لە مۆئاب وێران بوو، 
\q2 لە یەک شەودا کاول بوو! 
\q1  
\v 2 دیڤۆنیش بۆ پەرستگاکەی\f + \fr 15:2 \ft مەبەست لە پەرستگای بتپەرستانە، نەک پەرستگاکەی یەزدان.‏\f* سەرکەوت، 
\q2 بۆ نزرگەکانی سەر بەرزاییەکان بۆ گریان، 
\q2 مۆئاب بەسەر نیبۆ و مادەبادا شیوەن دەکات. 
\q1 هەموو سەرێک ڕووتاوەتەوە و 
\q2 هەموو ڕیشێک تاشراون. 
\q1  
\v 3 لە شەقامەکانی جلوبەرگی گوش\f + \fr 15:3 \ft لە کاتی ماتەمگێڕان و تۆبەکردندا جلوبەرگی لە گوش دروستکراویان لەبەرکردووە کە ئەزیەتی پێستیانی داوە.‏\f* دەپۆشن، 
\q2 لە سەربانەکانی و لە گۆڕەپانەکانی 
\q1 هەموو شیوەن دەکەن 
\q2 بەخوڕ دەگریێن. 
\q1  
\v 4 حەشبۆن و ئەلعالێ هاواریانە، 
\q2 دەنگیان لە یەهەچ دەبیسترێت. 
\q1 لەبەر ئەوە چەکدارەکانی مۆئاب هاوار دەکەن 
\q2 گیانیان دەلەرزێت. 
\b  
\q1  
\v 5 دڵم بۆ مۆئاب دەناڵێنێت، 
\q2 هەڵاتووەکانی بەرەو زۆعەر ڕادەکەن، 
\q2 هەتا عەگلەت شەلیشیا. 
\q1 بە گریانەوە 
\q2 لە هەورازەکەی لوحیت سەردەکەون، 
\q1 لە ڕێگای حۆرۆنایم 
\q2 هاواری شکست بەرز دەکەنەوە. 
\q1  
\v 6 ئاوەکانی نیمریم وشک بوون، 
\q2 گیایەکەش سیس بوو، 
\q1 لەوەڕگا نەما و 
\q2 سەوزایی نەما. 
\q1  
\v 7 لەبەر ئەوە ئەو سامانەی بەدەستیان هێنا و شتە ئەمبارکراوەکانیان 
\q2 هەتا شیوی ئەسپیندار هەڵدەگرن. 
\q1  
\v 8 هاوار سنووری مۆئابی گرتەوە، 
\q2 واوەیلای دەگاتە ئەگلەیم، 
\q2 واوەیلای لە بیری ئێلیمە. 
\q1  
\v 9 ئاوەکانی دیمۆن پڕن لە خوێن، 
\q2 بەڵام زیاتر بەسەر دیمۆندا دەهێنم، 
\q1 شێر بۆ سەر دەربازبووەکانی مۆئاب و 
\q2 بۆ پاشماوەی خاکەکە دەهێنم. 
\b  
\c 16  
\q1  
\v 1 بەرخ وەک سەرانە بنێرن 
\q2 بۆ فەرمانڕەوای خاکەکە، 
\q1 لە سەلەعەوە بە چۆڵەوانیدا 
\q2 بەرەو چیاکەی شاری سییۆن. 
\q1  
\v 2 وەک باڵندەی هەڵاتوون 
\q2 وەک لە هێلانە دەرپەڕێنراویان لێدێت، 
\q1 کچانی مۆئاب 
\q2 لە تەنکاییەکانی ڕووباری ئەرنۆن. 
\b  
\q1  
\v 3 «ڕاوێژ بکە، 
\q2 دادوەری ئەنجام بدە، 
\q1 لە قرچەی نیوەڕۆدا 
\q2 سێبەرت وەک شەوی لێ بکە. 
\q1 دەرکراوەکان بشارەوە، 
\q2 هەڵاتووەکان ئاشکرا مەکە. 
\q1  
\v 4 با ئاوارەکانی مۆئاب لەلات بمێننەوە، 
\q2 لە ڕووی کاولکەر بۆیان ببە پەناگا.» 
\b  
\q1 کاتێک چەوسێنەر کۆتایی پێ دێت، 
\q2 کاولبوون نامێنێت، 
\q2 پێشێلکاران لە خاکەکەدا لەناودەچن. 
\q1  
\v 5 بە خۆشەویستی نەگۆڕ تەخت جێگیر دەبێت، 
\q2 یەکێک لە بنەماڵەی داود 
\q2 دادپەروەر و داواکاری دادپەروەری، 
\q1 دەستپێشخەر بۆ ڕاستودروستی، 
\q2 بە دڵسۆزییەوە لەسەری دادەنیشێت. 
\b  
\q1  
\v 6 لووتبەرزی مۆئابمان بیست، 
\q2 لووتبەرزییەکی زۆر، 
\q1 خۆبەزلزانی و لووتبەرزی و بەفیزی، 
\q2 بەڵام قسە پووچەکانی ناچەسپێن. 
\q1  
\v 7 لەبەر ئەوە با خەڵکی مۆئاب واوەیلا بکەن، 
\q2 سەراپا بۆ مۆئاب واوەیلا بکەن. 
\q1 ئەی مۆئابییە بەزێنراوەکان، 
\q2 بۆ نانی کشمیشی\f + \fr 16:7 \ft نانی کشمیش بۆ بەعل پێشکەش دەکرا وەک سوپاسگوزاری بۆ دروێنە و خەرمان.‏\f* قییر حەراسەت شیوەن بگێڕن. 
\q1  
\v 8 کێڵگەکانی حەشبۆن سیس بوون، 
\q2 هەروەها ڕەزەکەی سیڤما. 
\q1 گەورەکانی نەتەوەکان 
\q2 شا مێوەکانییان شکاند، 
\q1 کە گەیشتبووە یەعزێر و 
\q2 پەلی هاویشت هەتا چۆڵەوانی. 
\q1 لقەکانی درێژ ببوونەوە و 
\q2 لە دەریا پەڕیبوونەوە. 
\q1  
\v 9 لەبەر ئەوە گریانی یەعزێر دەگریێم 
\q2 بۆ ڕەزەکەی سیڤما، 
\q1 بە فرمێسکەکانم ئاوتان دەدەم 
\q2 ئەی حەشبۆن و ئەلعالێ! 
\q1 لە کاتی میوە گەییوەکانت و دروێنەکانت 
\q2 هەراوزەنای جەنگ هات. 
\q1  
\v 10 خۆشی و شادی لە باخ بڕایەوە، 
\q2 لەناو ڕەزان گۆرانی ناگوترێت و هاوار ناکرێت، 
\q1 شەراب لەناو گوشەر ناگوشرێت، 
\q2 هوتاف کپ بوو. 
\q1  
\v 11 لەبەر ئەوە هەناوم وەک قیسارە بۆ مۆئاب دەناڵێنێت، 
\q2 ناخیشم بۆ قییر حەراسەت. 
\q1  
\v 12 جا کە مۆئاب لە نزرگەی سەر بەرزاییەکە دەردەکەوێت، 
\q2 ماندوو دەبێت. 
\q1 کە دەچێتە ناو نزرگەکەوە نوێژ بکات، 
\q2 قبوڵ نابێت. 
\p  
\v 13 ئەمە ئەو فەرمایشتەیە کە یەزدان پێشتر بە مۆئابی فەرموو.  
\v 14 ئێستاش یەزدان دەدوێت و دەفەرموێت: «لە ماوەی سێ ساڵدا وەک ساڵەکانی کرێگرتە، سەنگینی مۆئاب سووک دەبێت، بەو هەموو خەڵکە زۆرەوە، پاشماوەکەی زۆر کەم و لاواز دەبێت.» 
\c 17  
\s1 سروشێک سەبارەت بە دیمەشق 
\p  
\v 1 سروشێک سەبارەت بە دیمەشق: 
\q1 «بڕوانە، دیمەشق لەنێو شاران دەسڕێتەوە و 
\q2 دەبێتە تەپەیەکی ڕووخاو. 
\q1  
\v 2 شارەکانی عەرۆعێر بەجێماون و 
\q2 بۆ مێگەلەکان دەبن، 
\q1 تێیدا ڕادەکشێن، 
\q2 کەس نییە بیانترسێنێت. 
\q1  
\v 3 قەڵا لە ئەفرایم نامێنێت و 
\q2 پاشایەتیش لە دیمەشق. 
\q1 پاشماوەی ئارام وەک 
\q2 شکۆمەندی نەوەی ئیسرائیلی لێ دێت،» 
\q4 ئەوە فەرمایشتی یەزدانی سوپاسالارە. 
\b  
\q1  
\v 4 «لەو ڕۆژەدا شکۆمەندی یاقوب نزم دەبێتەوە، 
\q2 قەڵەوی گۆشتەکەی لاواز دەبێت. 
\q1  
\v 5 وەک کۆکردنەوەی دەغڵی بەپێوە ڕاوەستاو دەبێت لەلایەن دروێنەکەرانەوە، 
\q2 بازووشی گوڵەگەنم دەدروێتەوە. 
\q1 وەک هەڵگرتنەوەی گوڵەگەنم دەبێت 
\q2 لە دۆڵی ڕفایم. 
\q1  
\v 6 وەک تەکاندنی دار زەیتوون 
\q2 کە پاشماوەی تێدا دەمێنێتەوە، 
\q1 دوو یان سێ دەنک لەسەر چڵەکان، 
\q2 چوار یان پێنج لە لقە بەردارەکان.» 
\q4 ئەوە فەرمایشتی یەزدانە، خودای ئیسرائیل. 
\b  
\q1  
\v 7 لەو ڕۆژەدا مرۆڤ ئاوڕ لە دروستکەرەکەی دەداتەوە و 
\q2 چاوەکانیش بەرەو خودا پیرۆزەکەی ئیسرائیلە. 
\q1  
\v 8 ئاوڕ لە قوربانگاکان ناداتەوە 
\q2 کە دروستکراوی دەستی خۆین، 
\q1 ئەوەی پەنجەکانی دروستی کردوون سەیریان ناکات، 
\q2 ستوونە ئەشێراکان\f + \fr 17:8 \ft ستوونە ئەشێرا: هێمای خواژنە. بڕوانە \xt یەکەم پاشایان 11‏:5‏\ft ‏.‏\f* و قوربانگاکانی بخوور. 
\p  
\v 9 لەو ڕۆژەدا شارە قەڵابەندەکانی وەک کەلاوەی چۆڵکراوی ناو دارستانەکان و چڵەدارەکانی لێدێت کە لە ڕووی نەوەی ئیسرائیل چۆڵیان کردن، جا وێران دەبێت. 
\q1  
\v 10 خودای ڕزگارکەری خۆتت لەبیر چوو، 
\q2 تاشەبەردەکەت، قەڵاکەت بەبیر نەهاتەوە. 
\q1 لەبەر ئەوە ڕووەکی چاک دەچێنن 
\q2 بەڵام نەمامی نامۆ سەرهەڵدەدات. 
\q1  
\v 11 ئەو ڕۆژەی دەیچێنیت، وای لێ دەکەیت نەمام بکات 
\q2 بۆ بەیانی وای لێ دەکەیت گوڵ بکات، 
\q1 بەڵام دروێنە لە ڕۆژی نەخۆشی و ئازاری 
\q2 بێ چارەسەردا لەدەست دەچێت. 
\b  
\q1  
\v 12 ئای لە هاژەهاژی خەڵکانێکی زۆر، 
\q2 وەک هاژەی دەریا کە دەهەژێت! 
\q1 خوڕەی نەتەوەکان 
\q2 وەک خوڕەی ئاوی زۆر کە خوڕەی دێت! 
\q1  
\v 13 نەتەوەکان کە خوڕەیان دێت وەک خوڕەی ئاوی زۆر، 
\q2 بەڵام تێیان ڕادەخوڕێت و بۆ دوور هەڵدێن، 
\q1 وەک پووشی چیاکان لەبەردەم با ڕاو دەنرێت و 
\q2 وەک تەپوتۆز لەبەردەم ڕەشەبا. 
\q1  
\v 14 دەمەو ئێوارە تۆقینێکی لەناکاوە! 
\q2 بەرەبەیانێکی زوو نامێنن! 
\q1 ئەمە بەشی تاڵانکارانمانە، 
\q2 بەختی ڕاوڕووتکارانمانە. 
\c 18  
\s1 قوڕبەسەری کوش 
\q1  
\v 1 قوڕبەسەر خاکی فڕەفڕی باڵەکان، 
\q2 ئەوەی لەوبەری ڕووبارەکانی کوشە، 
\q1  
\v 2 پەیامبەران بە ڕێی دەریادا دەنێرێت، 
\q2 بە بەلەمی قامیش لەسەر ڕووی ئاوەکان. 
\b  
\q1 بڕۆن ئەی نێردراوە خێراکان، 
\q1 بۆ لای نەتەوەیەکی باڵا بەرز و کۆسە، 
\q2 بۆ لای گەلێک خەڵکی دوور و نزیک لێیان دەترسن، 
\q1 نەتەوەیەکی بێگانە و پێشێلکار، 
\q2 ئەوەی ڕووبارەکان دڕیانداوە بە خاکەکەی. 
\b  
\q1  
\v 3 ئەی هەموو دانیشتووانی جیهان و 
\q2 نیشتەجێبووانی زەوی، 
\q1 کە ئاڵا لەسەر چیاکان بەرزکرایەوە، 
\q2 ببینن و 
\q1 کە کەڕەنا لێدرا، 
\q2 گوێ بگرن. 
\q1  
\v 4 یەزدان ئەمەم پێ دەفەرموێت: 
\q2 «هێمن دەبم و لە نشینگەی خۆمەوە تەماشا دەکەم 
\q1 وەک گەرمایەکی ڕوون لە بەر هەتاودا، 
\q2 وەک هەوری خوناو لە گەرمای دروێنەدا.» 
\q1  
\v 5 پێش ترێ ڕنین لە کاتی تەواو چرۆکردن و 
\q2 کاتێک گوڵەکان دەبن بە پەسیرەی گەییو، 
\q1 چڵەکان بە داس دەبڕێتەوە و 
\q2 لقەکان لێ دەکاتەوە و فڕێیان دەدات. 
\q1  
\v 6 پێکەوە بەجێدەهێڵدرێن بۆ بازەکانی چیا و 
\q2 بۆ گیانلەبەرە کێوییەکانی زەوی، 
\q1 بازەکان هاوینیان پێ بەسەردەبەن و 
\q2 هەموو گیانلەبەرە کێوییەکانی زەویش زستانیان پێ بەسەردەبەن. 
\p  
\v 7 لەو ڕۆژەدا دیاری پێشکەش بە یەزدانی سوپاسالار دەکرێت، 
\q1 لە گەلێکی باڵا بەرز و کۆسە، 
\q2 گەلێکی ترسناک، دوور و نزیک، 
\q1 نەتەوەیەکی بێگانە و پێشێلکار، 
\q2 ئەوەی ڕووبارەکان زەوییەکەیانی دابەش کردووە، 
\m بۆ شوێنی ناوی یەزدانی سوپاسالار لە کێوی سییۆن. 
\c 19  
\s1 سروشێک سەبارەت بە میسر 
\p  
\v 1 سروشێک سەبارەت بە میسر: 
\q1 ئەوەتا یەزدان بەسەر هەورێکی خێراوە 
\q2 بەرەو میسر دێت. 
\q1 بتەکانی میسر لە ڕووی ئەودا دەلەرزن، 
\q2 دڵی میسریش لە ناخیدا دەتوێتەوە. 
\b  
\q1  
\v 2 «میسرییەکان لە دژی میسرییەکان هاندەدەم، 
\q2 هەرکەسە لە دژی برای خۆی شەڕ دەکات، 
\q2 هەرکەسە لە دژی هاوڕێی خۆی، 
\q2 شار لە دژی شار و 
\q2 شانشین لە دژی شانشین. 
\q1  
\v 3 میسر ڕۆحی تێدا نامێنێت، 
\q2 ڕاوێژەکەی هەڵدەلووشم، 
\q1 داوا لە بتەکان و لە نوشتەکەران دەکەن، 
\q2 لە نێوانگرەکان و لە ڕۆح ئامادەکاران. 
\q1  
\v 4 میسرییەکان ڕادەستی گەورەیەکی دڵڕەق دەکەم و 
\q2 پاشایەکی توندوتیژ فەرمانڕەوایەتییان دەکات،» 
\q2 یەزدان، پەروەردگاری سوپاسالار دەفەرموێت. 
\b  
\q1  
\v 5 ئاوی نیل وشک دەبێت، 
\q2 ڕووبارەکەش کاول دەبێت و وشک دەبێت. 
\q1  
\v 6 نۆکەندەکان بۆن دەکەن، 
\q2 لقەکانی نیل کز دەبن و کاول دەبن. 
\q1 قامیش و زەل بۆگەن دەبن، 
\q2  
\v 7 سەوزایی لەسەر نیل، 
\q2 لە ڕێژگەی\f + \fr 19:7 \ft ‏ئەو شوێنەی ڕووبار دەڕژێتە ناو دەریا.‏\f* ڕووبارەکە. 
\q1 هەموو ئەوەی لەسەر نیل چانراوە 
\q2 وشک دەبێت، هەڵدەوەرێت و نامێنێت. 
\q1  
\v 8 ماسیگرەکان ئاخ هەڵدەکێشن و شین دەگێڕن، 
\q2 هەموو ئەوانەی قولاپ هەڵدەدەنە\f + \fr 19:8 \ft دەهاوێژنە.‏\f* ناو نیلەوە، 
\q1 ئەوانەی تۆڕ لەسەر ڕووی ئاوەکان بڵاو دەکەنەوە 
\q2 ورەیان نامێنێت. 
\q1  
\v 9 کرێکارەکان لە کەتانی ئامادەکراو بێ ئومێد دەبن، 
\q2 جۆڵاکانیش ڕوو زەرد دەبن. 
\q1  
\v 10 جۆڵاکانی میسر وردوخاش دەبن و 
\q2 هەموو کرێکارەکانی خەمبار دەبن. 
\b  
\q1  
\v 11 بێگومان میرەکانی چۆعەن گێلن: 
\q2 دانا ڕاوێژکارەکانی فیرعەون ڕاوێژەکانیان ئاژەڵانەیە. 
\q1 چۆن بە فیرعەون دەڵێن: 
\q2 «کوڕی دانایانم من، 
\q2 کوڕی\f + \fr 19:11 \ft لەم ڕستەیەدا کوڕ بە واتای پەروەردەی بەردەست دێت، نەک پەیوەندی کوڕ و باوکایەتی.‏\f* پاشا دێرینەکان»؟ 
\b  
\q1  
\v 12 کەواتە کوا داناکانت؟ 
\q2 با پێت بڵێن و با بزانن، 
\q1 یەزدانی سوپاسالار 
\q2 پلانی چی داناوە لە دژی میسر. 
\q1  
\v 13 میرانی چۆعەن گێل بوون، 
\q2 میرانی مەمفیس چەواشە کران، 
\q1 پیاوماقوڵانی هۆزەکانی 
\q2 میسریان گومڕا کرد. 
\q1  
\v 14 یەزدان ڕۆحی گێژبوونی تێدا تێکەڵ کردووە، 
\q2 میسریان گومڕا کرد لە هەموو کردارەکانی 
\q2 وەک گومڕاکردنی سەرخۆش لەناو ڕشانەوەکەی. 
\q1  
\v 15 هیچ کارێک نابێت لە میسر 
\q2 کە سەر یان کلک، دار خورما یان زەل، بیکات. 
\p  
\v 16 لەو ڕۆژەدا میسرییەکان وەک ژنیان لێدێت، لە ترسان دەلەرزن، کاتێک یەزدانی سوپاسالار دەستی لێیان بەرز دەکاتەوە.  
\v 17 میسرییەکان لە خاکی یەهودا دەتۆقن، هەموو ئەوەی بەبیری بێتەوە لە یەهودا دەترسێت، لەبەر ئەو پلانەی یەزدانی سوپاسالار لە دژی دایدەڕێژێت. 
\p  
\v 18 لەو ڕۆژەدا پێنج شار دەبێت لە خاکی میسردا کە بە زمانی کەنعانی بدوێن و بە یەزدانی سوپاسالار سوێند دەخۆن، یەکێکیان پێی دەگوترێت «شاری خۆر»\f + \fr 19:18 \ft بڕوانە \xt یەرمیا 43‏:13‏\ft ‏. بە یۆنانی هیلیۆپۆلیس، مەبەست لە شاری خۆرە لە میسر، کە ئێستا پێی دەگوترێ (میسری نوێ).‏\f*. 
\p  
\v 19 لەو ڕۆژەدا، لە ناوەڕاست خاکی میسردا قوربانگایەک بۆ یەزدان دەبێت و ستوونێکیش لەسەر سنوورەکەی بۆ یەزدان.  
\v 20 جا دەبێتە نیشانە و شایەتی بۆ یەزدانی سوپاسالار لە خاکی میسردا، چونکە هاوار بۆ یەزدان دەکەن لە ڕووی زۆردار، ئەویش ڕزگارکەر و پارێزەریان بۆ دەنێرێت و دەربازیان دەکات.  
\v 21 ئینجا یەزدان لە میسر ناسراو دەبێت، لەو ڕۆژەدا میسرییەکان یەزدان دەناسن و بە قوربانی و پێشکەشکراوی دانەوێڵە دەیپەرستن و نەزر\f + \fr 19:21 \ft نەزر: داوا لە خودا دەکەیت بۆ ئەنجامدانی کارێک، کارەکە پابەند دەکەیت بە مەرجێکەوە. داوا دەکەیت ئەگەر خودا ئەو کارەم بۆ ئەنجام بدات، ئەوا دەرئەنجام منیش ئەو کارەی بۆ ئەنجام دەدەم. بڕوانە \xt سەرژمێری 21‏:2‏\ft ‏.‏\f* بۆ یەزدان دەکەن و بەجێی دەهێنن.  
\v 22 یەزدان لە میسر دەدات، لێیان دەدات و چاکیشیان دەکاتەوە، دەگەڕێنەوە لای یەزدان و وەڵامیان دەداتەوە و چاکیان دەکاتەوە. 
\p  
\v 23 لەو ڕۆژەدا شاڕێگایەک لە میسرەوە بەرەو ئاشور دەبێت، جا ئاشورییەکان دێنە میسر و میسرییەکانیش دێنە ئاشور، میسر لەگەڵ ئاشور پێکەوە خزمەت دەکەن.  
\v 24 لەو ڕۆژەدا ئیسرائیل دەبێتە یەکێک لە سێیەکە، لەگەڵ میسر و ئاشور، دەبنە بەرەکەت لە خاکەکە.  
\v 25 ئەوەی یەزدانی سوپاسالار بەرەکەتداریان دەکات و دەفەرموێت: «بەرەکەتدار بێت میسری گەلی من و ئاشوری دەستکردی من و ئیسرائیلی میراتی من.» 
\c 20  
\s1 نیشانە و پەند لەسەر میسر و کوش 
\p  
\v 1 لە ساڵی هاتنی فەرماندە گشتییەکە بۆ ئەشدۆد، کاتێک سەرگۆنی پاشای ئاشور ناردی و لەگەڵ ئەشدۆد جەنگا و گرتی،  
\v 2 لەو کاتەدا یەزدان لە ڕێگەی ئیشایای کوڕی ئامۆچەوە قسەی کرد و فەرمووی: «بڕۆ جلوبەرگە گوشەکە لە کەمەرت بکەرەوە و پێڵاوەکانت لە پێت دابکەنە.» ئەویش بەم جۆرەی کرد و بە ڕووتی و پێ خاوسی ڕۆیشت. 
\p  
\v 3 ئینجا یەزدان فەرمووی: «وەک ئەوەی ئیشایای بەندەم بۆ ماوەی سێ ساڵ بە ڕووتی و پێ خاوسی ڕۆیشت، ئەمە نیشانە و پەندە لەسەر میسر و لەسەر کوش،  
\v 4 پاشای ئاشوریش بۆ ڕیسوایی میسر بەم جۆرە ڕاپێچکراوانی میسر و دیلەکانی کوش، گەنج و پیر بە ڕووتی و پێ خاوسی و سمت ڕووتی دەداتە پێش خۆی.  
\v 5 دەتۆقن و شەرمەزار دەبن لەبەر کوش کە مایەی هیوایان بوو و لەبەر میسر کە مایەی شانازییان بوو.  
\v 6 جا دانیشتووی ئەم کەنارە لەو ڕۆژەدا دەڵێت: ”سەیر بکەن چی بەسەر ئەوانەدا هاتووە کە چاوەڕێمان دەکرد لە بەرامبەر پاشای ئاشور فریامان بکەون! ئیتر ئێمە چۆن ڕزگارمان دەبێت؟“» 
\c 21  
\s1 سروشێک سەبارەت بە بابل 
\p  
\v 1 سروشێک سەبارەت بە چۆڵەوانی نزیکی دەریا\f + \fr 21:1 \ft دەکرێت مەبەست لە ناوچەی خوارووی خاکی بابل بێت کە نزیکی کەنداوی فارس.‏\f*: 
\q1 وەک گەردەلوول لە باشوور هەڵدەکات، 
\q2 لە چۆڵەوانییەوە دێت، 
\q2 لە خاکێکی ترسناک. 
\b  
\q1  
\v 2 ئەم بینینە ترسناکەم بۆ ئاشکرا کراوە: 
\q2 ناپاک ناپاکی دەکات و تاڵانکەر تاڵان دەکات. 
\q1 سەربکەوە ئەی ئیلام! گەمارۆ بدە ئەی میدیا! 
\q2 کۆتاییم هێنا بە هەموو ئاخ هەڵکێشانەکەی. 
\b  
\q1  
\v 3 لەبەر ئەوە کەلەکەم پڕ بووە لە ئازار، 
\q2 ژانێک منی گرت، وەک ژانی منداڵبوون، 
\q1 سەرسام بووم لە گوێگرتن، 
\q2 واقم وڕما لە بینین. 
\q1  
\v 4 سەرم لێ شێوا، 
\q2 ترس منی لەرزاند، 
\q1 زەردەپەڕی خۆشیی منی 
\q2 کردە تۆقین. 
\b  
\q1  
\v 5 خوان ئامادە دەکەن، 
\q2 ڕایەخ ڕادەخەن، 
\q2 دەخۆن و دەخۆنەوە! 
\q1 هەستن ئەی میران! 
\q2 قەڵغان چەور بکەن! 
\p  
\v 6 پاشان پەروەردگار ئەمەم پێ دەفەرموێت: 
\q1 «بڕۆ ئێشکگر بە پێوە ڕابگرە، 
\q2 ئەوەی دەیبینێت با ڕایبگەیەنێت. 
\q1  
\v 7 کاتێک چەند گالیسکەیەک دەبینێت، 
\q2 لەگەڵ ئەسپ سوار جووت جووت، 
\q2 سواری گوێدرێژ یان سواری وشتر، 
\q1 با بە تەواوی گوێی شل بکات، 
\q2 زۆر شلی بکات.» 
\p  
\v 8 ئینجا ئێشکگرەکە هاواری کرد: 
\q1 «گەورەم، من ڕۆژانە لەسەر قوللەی چاودێرییەکە ڕاوەستاوم، 
\q2 هەموو شەوانیش لە بنکەی پاسەوانێتییەکەم دەمێنمەوە. 
\q1  
\v 9 ئەوەتا پیاوێک بە سواری گالیسکە هاتووە، 
\q2 لەگەڵ ئەسپ سوار جووت جووت. 
\q1 وەڵامی دەداتەوە و دەڵێت: 
\q2 ”کەوتووە، بابل کەوتووە! 
\q1 هەموو وێنەی خوداوەندەکانی 
\q2 بەرەو زەوی شکان!“» 
\b  
\q1  
\v 10 ئەی خەڵکینە، کە لەسەر جۆخین جەنجەرکراون، 
\q2 ئەوەی لە یەزدانی سوپاسالارەوە بیستوومە 
\q2 لە خودای ئیسرائیلەوە پێتان ڕادەگەیەنم. 
\s1 سروشێک سەبارەت بە ئەدۆم 
\p  
\v 11 سروشێک سەبارەت بە دوما: 
\q1 لە سێعیرەوە هاوارم بۆ دەکرێت، 
\q2 «ئێشکگر، شەو چەندی ماوە؟ 
\q2 ئێشکگر، شەو چەندی ماوە؟» 
\q1  
\v 12 ئێشکگرەکەش\f + \fr 21:12 \ft مەبەست لە پێغەمبەر ئیشایایە.‏\f* وەڵام دەداتەوە: 
\q2 «بەیانی دێت، هەروەها شەویش. 
\q1 ئەگەر داواکارن، داوا بکەن، 
\q2 بگەڕێنەوە، وەرن.» 
\s1 سروشێک سەبارەت بە عەرەبستان 
\p  
\v 13 سروشێک سەبارەت بە عەرەبستان: 
\q1 ئەی کاروانی دیدانییەکان، 
\q2 ئەوانەی لەنێو دەوەنەکانی عەرەبستان شەو بەسەردەبەن، 
\q2  
\v 14 بەرەوپیری تینوو، ئاو بهێنن. 
\q1 ئەی دانیشتووانی خاکی تێما، 
\q2 بە نانەوە بەرەو ڕووی هەڵاتوو بچن، 
\q1  
\v 15 چونکە لە ڕووی شمشێر هەڵاتوون، 
\q2 لە ڕووی شمشێری هەڵکێشراو، 
\q1 لە ڕووی کەوانی توندکراو، 
\q2 لە ڕووی سەختی جەنگ. 
\p  
\v 16 پەروەردگار ئەمەم پێ دەفەرموێت: «دوای یەک ساڵی ڕەبەق، هەموو شکۆمەندی قێدار بەسەردەچێت و  
\v 17 پاشماوەی پاڵەوانە کەوان بەدەستەکانی نەوەی قێدار ژمارەیان کەم دەبن، چونکە یەزدانی پەروەردگاری ئیسرائیل فەرمووی.» 
\c 22  
\s1 سروشێک سەبارەت بە ئۆرشەلیم 
\p  
\v 1 سروشێک سەبارەت بە دۆڵی بینین\f + \fr 22:1 \ft دۆڵی بینین: ناوێکی مەجازییە بۆ ئۆرشەلیم.‏\f*: 
\q1 چیتانە وا سەرکەوتوون، 
\q2 هەموو بۆ سەربان، 
\q1  
\v 2 ئەی شارە بە هاتوهاوارەکە، 
\q2 پڕ لە دەنگەدەنگ، شارۆچکە بە شانازییەکە؟ 
\q1 کوژراوەکانت کوژراوی شمشێر نین و 
\q2 مردووی جەنگ نین. 
\q1  
\v 3 فەرمانڕەواکانت پێکەوە هەڵاتن، 
\q2 بێ بەرگری بە دیل گیران. 
\q1 هەموو ئەوانەی گیران، پێکەوە بران بۆ زیندان، 
\q2 ئەوانەش کە دوور بوون و هەڵاتبوون. 
\q1  
\v 4 لەبەر ئەوە گوتم: «وازم لێ بهێنن، 
\q2 بە تاڵییەوە دەگریێم، 
\q1 زۆرم لێ مەکەن بۆ دڵدانەوەم 
\q2 لەسەر وێرانبوونی گەلەکەم.» 
\b  
\q1  
\v 5 یەزدان، پەروەردگاری سوپاسالار 
\q2 ڕۆژێکی هەیە لە دۆڵی بینین 
\q2 بۆ هاتوهەرا و سەرکوتکردن و سەرلێشێوان 
\q1 بۆ دیوار بڕین و 
\q2 هاوارکردن بۆ چیا. 
\q1  
\v 6 ئیلام تیردانی هەڵگرتووە 
\q2 بە گالیسکە و پیادە و سوارەوە، 
\q2 قییریش قەڵغانی دەرخست. 
\q1  
\v 7 جا هەڵبژاردەی دۆڵەکانت پڕ دەبێت لە گالیسکە و لە سوارەکان، 
\q2 ڕیزیان بەستووە ڕووەو دەروازەکە. 
\b  
\q2  
\v 8 داپۆشینی یەهودا نامێنێت. 
\q1 جا لەو ڕۆژەدا دەڕوانیتە 
\q2 چەکەکانی کۆشکی دارستان، 
\q1  
\v 9 کەلێنەکانی شاری داود دەبینن کە زۆر بوون و 
\q2 ئاوی گۆمی خوارێ کۆدەکەنەوە. 
\q1  
\v 10 ماڵەکانی ئۆرشەلیم دەژمێرن و 
\q2 ماڵەکان دەڕووخێنن بۆ پتەوکردنی شووراکە. 
\q1  
\v 11 ئەستێلێک دروستدەکەن لەنێوان دوو شووراکە، 
\q2 بۆ ئاوی گۆمە کۆنەکە. 
\q1 بەڵام نەتانڕوانییە یەزدانی دروستکەری، 
\q2 ئەوەی لەمێژەوە شێوەی کێشابوو نەتانبینی. 
\b  
\q1  
\v 12 یەزدان، پەروەردگاری سوپاسالار، 
\q2 لەو ڕۆژەدا بانگەوازی کرد 
\q1 بۆ گریان و شیوەن و 
\q2 سەرتاشین و پۆشینی جلوبەرگی گوش. 
\q1  
\v 13 بەڵام ئەوەتا خۆشی و شادی، 
\q2 مانگا کوشتنەوە و مەڕ سەربڕین، 
\q2 گۆشت خواردن و شەراب خواردنەوە! 
\q1 «با بخۆین و بخۆینەوە، 
\q2 چونکە سبەی دەمرین.» 
\p  
\v 14 گوێم لێگرت یەزدانی سوپاسالار بۆی ئاشکرا کردم: «کەفارەت بۆ ئەم تاوانەتان ناکرێت تاکو دەمرن،» یەزدان، پەروەردگاری سوپاسالار دەفەرموێت. 
\p  
\v 15 یەزدان، پەروەردگاری سوپاسالار ئەمە دەفەرموێت: 
\q1 «بڕۆ بۆ لای ئەو کارگێڕە، 
\q2 شەڤنا ئەوەی سەرپەرشتیاری کۆشکەکەیە: 
\q1  
\v 16 چیت هەیە لێرە و کێ ڕوخسەتی پێداویت، 
\q2 هەتا گۆڕێک بۆ خۆت هەڵبکەنیت، 
\q1 ئەی ئەوەی لە بەرزایی گۆڕی خۆتت هەڵکەندووە و 
\q2 بۆ خۆت لەناو تاشەبەرد ماڵت تاشیوە؟ 
\b  
\q1  
\v 17 «ئەی پاڵەوان، ئەوەتا یەزدان خەریکە بە توندی تووڕت دەدات و 
\q2 بە هێزەوە لوولت دەکات، 
\q1  
\v 18 وەک تۆپ بە توندی دەتپێچێتەوە و 
\q2 بەرەو خاکێکی بەرفراوان تووڕت دەدات. 
\q1 لەوێ دەمریت و 
\q2 گالیسکەکانی شکۆمەندیت لەوێ دەبێت، 
\q2 ئەی مایەی سووکایەتی ماڵی گەورەکەت! 
\q1  
\v 19 لە پلەکەت دەرتدەکەم و 
\q2 لە پایەکەت فڕێدەدرێیتە خوارەوە. 
\p  
\v 20 «لەو ڕۆژەدا بانگی بەندەکەی خۆم، بانگی ئەلیاقیمی کوڕی حیلقیا دەکەم و  
\v 21 جلەکەی تۆی لەبەر دەکەم و بە کەمەربەندەکەی تۆ کەمەری توند دەکەم و دەسەڵاتی تۆ دەدەمە دەست ئەو و دەبێت بە باوک بۆ ئۆرشەلیم و بۆ بنەماڵەی یەهودا.  
\v 22 کلیلی ماڵی داود دەدەمە دەستی و ئەوەی ئەو دەیکاتەوە کەس ناتوانێت دایبخات و ئەوەی دایدەخات کەس ناتوانێت بیکاتەوە.  
\v 23 وەک سنگ دەیچەقێنم لە شوێنێکی چەسپاو و دەبێت بە تەختی شکۆمەندی بۆ بنەماڵەکەی.  
\v 24 هەموو شکۆمەندی بنەماڵەکەی بەوەوە هەڵدەواسن، چڵەکان و لقەکان، هەموو دەفرە بچووکەکان، لە دەفرە پەلەکانەوە هەتا دەفرە قووڵەکان.» 
\p  
\v 25 یەزدانی سوپاسالار دەفەرموێت: «بەڵام سەردەمێک دێت سنگە چەقاوەکە لە شوێنە چەسپاوەکە نامێنێت و دەشکێت و دەکەوێت، ئەو بارگرانییەی لەسەری بوو دەبڕدرێتەوە.» ئەوە فەرمایشتی یەزدانە. 
\c 23  
\s1 سروشێک سەبارەت بە شاری سور 
\p  
\v 1 سروشێک سەبارەت بە سور: 
\q1 واوەیلا بکەن ئەی کەشتییەکانی تەرشیش! 
\q2 چونکە سور کاول کراوە، 
\q2 نە خانوو نە بەندەری بە پێوە نەماوە، 
\q1 لە خاکی قوبرسەوە پێیان ڕاگەیەنرا. 
\b  
\q1  
\v 2 بحەپەسێن دانیشتووانی دوورگەکە و 
\q2 بازرگانانی سەیدا، 
\q2 ئەوانەی دەریا دەبڕن، پڕیان کردوویت. 
\q1  
\v 3 دانەوێڵەی شیحۆر 
\q2 لەسەر ئاوە زۆرەکان دەهات، 
\q1 داهاتی ئەو دروێنەی ڕووباری نیلە، 
\q2 جا سور بوو بە بازاڕی نەتەوەکان. 
\b  
\q1  
\v 4 شەرمەزار بە ئەی سەیدا، ئەی قەڵای دەریا! 
\q2 چونکە دەریا گوتی: 
\q1 «نە ژانم گرت و نە منداڵم بوو، 
\q2 نە گەنجم گەورە کرد و نە کچی عازەبم پێگەیاند.» 
\q1  
\v 5 کاتێک هەواڵ بە میسر دەگات، 
\q2 بە هەواڵی سور ژان دەیانگرێت. 
\b  
\q1  
\v 6 بپەڕنەوە بۆ تەرشیش، 
\q2 واوەیلا بکەن، ئەی دانیشتووانی دوورگەکە! 
\q1  
\v 7 ئایا ئەمە شاری خۆشییە بۆتان، 
\q2 ئەوەی دێرینی لە دێرزەمانەوەیە، 
\q1 ئەوەی پێیەکانی بەرەو دووری دەبەن 
\q2 بۆ ئاوارە بوون؟ 
\q1  
\v 8 کێ ئەم پلانەی لە دژی سوری تاج لەسەر داڕشت، 
\q2 ئەوەی میران بازرگانەکانی ئەون، 
\q2 فرۆشیارەکانی بەناوبانگەکانی زەوین؟ 
\q1  
\v 9 یەزدانی سوپاسالار پلانی داڕشتووە 
\q2 بۆ گڵاوکردنی شانازی هەموو شکۆمەندییەک، 
\q2 بۆ نزمکرنەوەی هەموو بەناوبانگەکانی زەوی. 
\b  
\q1  
\v 10 ئەی دانیشتووانی تەرشیش، 
\q2 زەوییەکەتان وەک کەناری نیل بکێڵن، 
\q2 ئیتر بەندەر نەما. 
\q1  
\v 11 یەزدان دەستی بەسەر دەریادا درێژکرد و 
\q2 شانشینەکان تۆقین. 
\q1 لە دژی فینیکیا فەرمانی دا 
\q2 بۆ کاولبوونی قەڵاکانی. 
\q1  
\v 12 فەرمووی: «جارێکی دی شانازی ناکەیت، 
\q2 ئەی سەیدای کچە پاکیزە\f + \fr 23:12 \ft پاکیزە: مەبەست لەپێش داگیرکردنیەتی، کە بەراوردی دەکات بە کچی پاکیزە.‏\f*، ئێستا پێشێل کراویت! 
\b  
\q1 «هەستە بەرەو قوبرس بپەڕەوە، 
\q2 لەوێش حەوانەوەت نابێت.» 
\q1  
\v 13 ئەوەتا خاکی بابلییەکان، 
\q2 گەلێکی لێیە کە بە هیچ دانانرێت! 
\q1 ئاشور کردییە شوێنی دڕندە بیابانییەکان\f + \fr 23:13 \ft بڕوانە \xt ئیشایا 13‏:21 و یەرمیا 50‏:39‏\ft ‏.‏\f*. 
\q2 قوللەکانیان\f + \fr 23:13 \ft قوللە لێرە مەبەست لە بورجێکە کە بە دار دروستکراوە لە کاتی شەڕدا بەکارهاتووە بۆ هێرشکردنە سەر شارێکی شوورابەند.‏\f* دروستکرد، 
\q2 قەڵاکانیان ڕووخاند، 
\q2 کردیان بە کاولگە. 
\b  
\q1  
\v 14 ئەی کەشتییەکانی تەرشیش واوەیلا بکەن، 
\q2 چونکە قەڵاکانتان کاول بوون. 
\p  
\v 15 لەو ڕۆژەدا ئەوە دەبێت، سور حەفتا ساڵ لەبیر دەکرێت، بەقەد ڕۆژگاری پاشایەک. پاش حەفتا ساڵەکە وەک گۆرانی ژنە لەشفرۆشێک بۆ سور دەبێت: 
\q1  
\v 16 «دەست بدە قیسارە و بەناو شاردا بسووڕێوە 
\q2 ئەی ژنە لەشفرۆشی لەبیرکراو! 
\q1 باش مۆسیقا بژەنە و زۆر گۆرانی بڵێ 
\q2 بۆ ئەوەی لەیاد نەکرێیت.» 
\p  
\v 17 جا پاش حەفتا ساڵەکە، یەزدان سور بەسەردەکاتەوە و سور دەگەڕێتەوە سەر کرێ وەرگرتنی و لەگەڵ هەموو شانشینەکانی جیهان لەسەر ڕووی زەوی لەشفرۆشی دەکات.  
\v 18 بەڵام بازرگانییەکەی و کرێ وەرگرتنەکەی تەرخانکراو دەبێت بۆ یەزدان. هەڵناگیرێت و لە گەنجینە ناکرێت، بەڵکو بازرگانییەکەی بۆ ئەوانە دەبێت کە لەبەردەم یەزدانن، بۆ ئەوەی بخۆن و تێر بن و جلی گرانبەها بپۆشن. 
\c 24  
\s1 یەزدان زەوی وێران دەکات 
\q1  
\v 1 ئەوەتا یەزدان لە داهاتوودا زەوی چۆڵ دەکات، 
\q2 بەتاڵی دەکات و ڕووی وەردەگێڕێت، 
\q2 دانیشتووانەکەی پەرت دەکات. 
\q1  
\v 2 کاهین وەک خەڵکی سادەی لێدێت، 
\q2 گەورە وەک کۆیلەکەی، 
\q2 خانم وەک کەنیزەکەی، 
\q2 کڕیار وەک فرۆشیار، 
\q2 بەخشەر وەک وەرگر، 
\q2 قەرزدەر وەک قەرزار. 
\q1  
\v 3 زەوی بە چۆڵکردن چۆڵ دەکرێت و 
\q2 بە تاڵان تاڵان دەکرێت، 
\q4 یەزدان ئەم بڕیارەی فەرموو. 
\b  
\q1  
\v 4 زەوی شیوەن دەکات و سیس بوو، 
\q2 جیهان داهێزرا و سیس بوو، 
\q2 گەورەترین خەڵکانی زەوی لەشیان داهێزرا. 
\q1  
\v 5 زەوی لەژێر دانیشتووانەکەی گڵاو بوو، 
\q2 چونکە سەرپێچی فێرکردنەکانیان کرد، 
\q1 فەرزەکانیان پێشێل کرد و 
\q2 پەیمانی هەتاهەتاییان شکاند. 
\q1  
\v 6 لەبەر ئەوە زەوی نەفرەتی خوارد و 
\q2 دانیشتووانەکەی سزادران. 
\q1 لەبەر ئەوە دانیشتووانی زەوی سووتان و 
\q2 خەڵکێکی کەم مایەوە. 
\q1  
\v 7 شەرابی نوێ شیوەن دەکات و ڕەزەمێو سیس بوو، 
\q2 هەموو دڵخۆشەکان ئاخ هەڵدەکێشن. 
\q1  
\v 8 دەفی دەنگ خۆش کپ بوو، 
\q2 هاتوهەرای شادمانەکان بڕایەوە، 
\q2 قیسارەی دەنگ خۆش کپ بوو. 
\q1  
\v 9 بە دەم گۆرانییەوە شەراب ناخۆنەوە، 
\q2 مەی بۆ نۆشەرەکەی تاڵ دەبێت. 
\q1  
\v 10 شاری وێران تێکشکاوە، 
\q2 هەموو ماڵێک دادەخرێت، چوونە ژوورەوە نییە. 
\q1  
\v 11 لە شەقامەکان هاوارە بۆ شەراب 
\q2 خۆرئاوا بوو بەسەر هەموو خۆشییەک، 
\q2 دوورخرایەوە شادی زەوی. 
\q1  
\v 12 ئەوەی لە شار دەمێنێتەوە وێرانەیە و 
\q2 لێدانی دەروازەش کاولییە. 
\q1  
\v 13 ئاوا دەبێت لەناوەندی زەوی 
\q2 لەنێو گەلان، 
\q1 وەک داتەکاندنی دار زەیتوون، 
\q2 وەک کۆکردنەوەی هێشوو کە ڕنین تەواو دەبێت. 
\b  
\q1  
\v 14 ئەوان دەنگ هەڵدەبڕن، هوتافی خۆشی دەکێشن، 
\q2 بۆ شکۆی یەزدان لە ڕۆژئاواوە هاوار دەکەن. 
\q1  
\v 15 لەبەر ئەوە لە ڕۆژهەڵات یەزدان شکۆدار بکەن، 
\q2 لە دوورگەکانی دەریاشەوە 
\q2 ناوی یەزدان، پەروەردگاری ئیسرائیل بەرز بکەنەوە. 
\q1  
\v 16 لەوپەڕی زەوییەوە گوێمان لە گۆرانییەک بوو: 
\q2 «شکۆمەندی بۆ خودای ڕاستودروست!» 
\b  
\q1 جا گوتم: «فەوتام! فەوتام! 
\q2 قوڕبەسەرم! 
\q1 ناپاکان ناپاکییان کرد! 
\q2 ناپاکان ناپاکییان لە ناپاکی کرد!» 
\q1  
\v 17 ترس و چاڵ و تەڵە 
\q2 بەسەرتەوەیە ئەی دانیشتووی زەوی. 
\q1  
\v 18 ئەوەی لە دەنگی ترسەکە هەڵدێت 
\q2 دەکەوێتە چاڵەکەوە و 
\q1 ئەوەی لەناو چاڵەکە بێتە دەرەوە 
\q2 بە تەڵەکەوە دەبێت. 
\b  
\q1 بەربەستی جۆگەکان لە ئاسمانەوە کرانەوە و 
\q2 بناغەکانی زەوی هەژان. 
\q1  
\v 19 زەوی بە شکان دەشکێت، 
\q2 زەوی بە وردوخاشبوون وردوخاش دەبێت، 
\q2 زەوی بە لەقین دەلەقێت. 
\q1  
\v 20 زەوی وەک سەرخۆش بە لادا دێت، 
\q2 جۆلانە دەکات وەک کەپر لەبەردەم با. 
\q1 یاخیبوونەکەی لەسەری قورسە، 
\q2 دەکەوێت و جارێکی دیکە هەڵناستێتەوە. 
\b  
\q1  
\v 21 لەو ڕۆژەدا یەزدان 
\q2 سزای هێزەکان دەدات لە ئاسمان و 
\q2 لەسەر زەوی سزای پاشایانی دەدات. 
\q1  
\v 22 بە کۆمەڵ کۆیان دەکەنەوە 
\q2 وەک دیل لە بەندیخانە و 
\q1 لە گرتووخانە توند دەکرێن و 
\q2 دوای ماوەیەکی درێژ سزا دەدرێن. 
\q1  
\v 23 مانگ ڕیسوا دەبێت و خۆر شەرمەزار دەبێت، 
\q2 چونکە یەزدانی سوپاسالار حوکمڕانی دەکات 
\q1 لە کێوی سییۆن و لە ئۆرشەلیم، 
\q2 شکۆمەندیش لەبەردەم پیرانی ئەوە. 
\c 25  
\s1 ستایش بۆ یەزدان 
\q1  
\v 1 ئەی یەزدان، تۆ خودای منیت! 
\q2 بە گەورەت دەزانم، ستایشی ناوت دەکەم، 
\q1 چونکە تۆ کاری سەرسوڕهێنەرت کردووە، 
\q2 پلانەکانت لە دێرزەمانەوەن، 
\q2 بە دڵسۆزی چەسپاون. 
\q1  
\v 2 شارت کاول کرد و 
\q2 شارۆچکەی قەڵابەندت وێران کرد، 
\q1 قەڵای بێگانەکان وەک شار نامێنێتەوە، 
\q2 بۆ هەتاهەتایە بنیاد نانرێتەوە. 
\q1  
\v 3 لەبەر ئەوە گەلی بەهێز ڕێزت لێ دەگرن، 
\q2 شارۆچکەی نەتەوە بێ ویژدانەکان لێت دەترسن. 
\q1  
\v 4 بوویت بە پەناگای هەژار، 
\q2 پەناگای نەدار لە کاتی تەنگانە، 
\q1 چەتر لە لێزمەی باران و 
\q2 سێبەر لە گەرما، 
\q1 چونکە هەڵچوونی بێ ویژدانەکان 
\q2 لێزمەی بارانە بەسەر دیوارەوە، 
\q1  
\v 5 وەک گەرمایە لە خاکی وشکدا. 
\q2 هاتوهەرای بێگانەکان کپ دەکرێت 
\q1 وەک گەرما بە سێبەری هەور 
\q2 گۆرانی بێ ویژدانەکان زەلیل دەکرێت. 
\b  
\q1  
\v 6 یەزدانی سوپاسالار بۆ هەموو گەلان 
\q2 لەم کێوە خوانی دابەستەکان ساز دەکات، 
\q1 خوانی شەرابی سادە و دابەستە پڕ لە مۆخەکان 
\q2 مەی سادەی پاڵاوتە. 
\q1  
\v 7 لەم کێوەدا لووشی دەدات 
\q2 پەچەی سەر مردوو، 
\q1 پەچە بەسەر هەموو گەلانەوە، 
\q1 هەروەها ئەو سەرپۆشەی بەسەر هەموو نەتەوەکاندا پۆشراوە، 
\q2  
\v 8 مردن لووشدەدات بۆ هەتاهەتایە. 
\q1 یەزدانی باڵادەست فرمێسک 
\q2 لەسەر هەموو ڕووەکان دەسڕێتەوە، 
\q1 ڕیسوایی گەلەکەی دادەماڵێت 
\q2 لە هەموو زەویدا، 
\q4 چونکە یەزدان فەرمووی. 
\p  
\v 9 لەو ڕۆژەدا دەگوترێت: 
\q1 «ئەوەتا ئەمە خودامانە، 
\q2 چاوەڕێمان دەکرد، ڕزگاری کردین. 
\q1 ئەمە یەزدانە، چاوەڕێمان دەکرد، 
\q2 شاد دەبین و دڵشاد دەبین بە ڕزگارییەکەی.» 
\b  
\q1  
\v 10 دەستی یەزدان ئەم کێوە دەپارێزێت، 
\q2 بەڵام مۆئاب لە جێی خۆی پێپەست دەکرێت 
\q2 وەک پێپەستکردنی کا بە ئاوی تەپاڵە. 
\q1  
\v 11 جا مۆئاب لە ناوەڕاستیدا دەستی بڵاو دەکاتەوە 
\q2 وەک چۆن مەلەوان بۆ مەلەکردن بڵاوی دەکاتەوە. 
\q1 خودا لووتبەرزییەکەی دادەگرێت 
\q2 لەگەڵ فرتوفێڵەکانی دەستی. 
\q1  
\v 12 قەڵابەندی بەرزی شووراکانت دەچەمێنێتەوە، 
\q2 دایدەگرێت دەینووسێنێت بە زەوییەوە، هەتا خۆڵ. 
\c 26  
\s1 گۆرانییەک بۆ ستایش 
\p  
\v 1 لەو ڕۆژەدا لە خاکی یەهودا ئەم گۆرانییە دەڵێن: 
\q1 شاری بەهێزمان هەیە، 
\q2 خودا ڕزگاری دەکاتە 
\q2 شوورا و سەنگەری. 
\q1  
\v 2 دەروازەکان بکەنەوە 
\q2 با نەتەوەی ڕاستودروست 
\q2 پارێزەری باوەڕ بێتە ژوورەوە. 
\q1  
\v 3 تۆ کەسی بیروڕا چەسپاو 
\q2 بە ئاشتی تەواو دەپارێزیت، 
\q2 چونکە پشتی بە تۆ بەستووە. 
\q1  
\v 4 هەتاهەتایە پشت بە یەزدان ببەستن، 
\q2 چونکە یەزدان، هەر یەزدان، تاشەبەردەکەی هەتاهەتاییە. 
\q1  
\v 5 ئەوانەی لە بەرزاییدا نیشتەجێن نزم دەکاتەوە، 
\q2 شاری بەرزیش نەوی دەکات، 
\q1 دەیدات بە زەویدا، 
\q2 تەختی دەکات لەگەڵ خۆڵ. 
\q1  
\v 6 پێی هەژار و هەنگاوی نەدار 
\q2 پێشێلی دەکات. 
\b  
\q1  
\v 7 ڕێڕەوی کەسی ڕاستودروست ڕێکە، 
\q2 ئەی خودای ڕاست، ڕێگای ڕاستودروست خۆش دەکەیت. 
\q1  
\v 8 ئەی یەزدان، لە ڕێی حوکمەکانت 
\q2 چاوەڕێی تۆ دەکەین؛ 
\q1 ناوەکەت و یادکردنەوەت 
\q2 ئارەزووی گیانمانە. 
\q1  
\v 9 گیانم بە شەو ئارەزووت دەکات، 
\q2 هەروەها لە بەیانیدا ڕۆحم لە ناخمدا پەرۆشە بۆت، 
\q1 چونکە کاتێک حوکمەکانت لە زەوین، 
\q2 دانیشتووانی جیهان فێری ڕاستودروستی دەبن. 
\q1  
\v 10 بەدکار بەر میهرەبانی بکەوێت، 
\q2 فێری ڕاستودروستی نابێت، 
\q1 لە خاکی ڕاستییەکاندا ناڕەوایی دەکات، 
\q2 شکۆی یەزدان نابینێت. 
\q1  
\v 11 ئەی یەزدان تۆ باڵا دەستیت، 
\q2 بەڵام ئەوان نایبینن. 
\q1 با دڵگەرمیت بۆ گەلەکەت ببینن و شەرمەزار بن، 
\q2 با ئەو ئاگرەی کە ئامادەت کردووە دوژمنەکانت بخوات. 
\b  
\q1  
\v 12 ئەی یەزدان ئاشتیمان دەدەیتێ، 
\q2 چونکە لە ڕاستیدا هەموو کارەکانمان تۆ کردووتە. 
\q1  
\v 13 ئەی یەزدانی پەروەردگارمان، 
\q2 گەورەکانی دیکە جگە لە تۆ، بوون بە گەورەمان، 
\q2 بەڵام تەنها تۆ، یادی ناوی تۆ دەکەین. 
\q1  
\v 14 ئەوان مردوون، زیندوو نابنەوە! 
\q2 تارمایین، هەڵناستنەوە، 
\q1 لەبەر ئەوە سزات دان و تێکت شکاندن، 
\q2 هەموو یادگاریێکی ئەوانت لەناوبرد. 
\q1  
\v 15 ئەی یەزدان، نەتەوەت زیاد کرد، 
\q2 نەتەوەت زیاد کرد و 
\q1 شکۆمەند بوویت، 
\q2 هەموو سنوورەکانی خاکەکەت فراوان کرد. 
\b  
\q1  
\v 16 ئەی یەزدان، لە تەنگانەدا هانایان بۆ هێنایت، 
\q2 کاتێک تەمبێت کردن، 
\q2 بە چرپەوە نوێژیان هەڵڕشت. 
\q1  
\v 17 وەک ژنی سکپڕ کە لە منداڵبوون نزیک دەبێتەوە 
\q2 لە ژاندا دەتلێتەوە و دەقیژێنێت، 
\q2 ئاوامان لێ هات لەبەردەمت، ئەی یەزدان. 
\q1  
\v 18 سکپڕ بووین تلاینەوە 
\q2 وەک ئەوەی بامان بووبێت. 
\q1 لە زەویدا ڕزگاریمان بەرپا نەکرد و 
\q2 کەسێکی جیهانمان لێ نەبوو. 
\b  
\q1  
\v 19 مردووەکانت زیندوو دەبنەوە، 
\q2 لاشەکان هەڵدەستنەوە. 
\q1 هەستن و گۆرانی بڵێن 
\q2 ئەی دانیشتووانی خۆڵ، 
\q1 چونکە شەونمت شەونمی بەیانییە، 
\q2 زەوی تارماییەکانی لێ لەدایک دەبێت. 
\b  
\q1  
\v 20 گەلەکەم بڕۆ، بڕۆ ناو ژوورەکانت و 
\q2 دەرگاکەت لەدوای خۆت کلیل بدە، 
\q1 بۆ ساتێک خۆت بشارەوە 
\q2 هەتا تووڕەیی تێدەپەڕێت. 
\q1  
\v 21 ئەوەتا یەزدان لە شوێنی خۆیەوە دێتە دەرەوە 
\q2 هەتا سزای تاوانی دانیشتووانی زەوی بدات لەسەری. 
\q1 زەوی خوێنەکانی ناو خۆی دەردەخات، 
\q2 لەمەودوا کوژراوەکانی ناشارێتەوە. 
\c 27  
\s1 ڕزگاریی ئیسرائیل 
\p  
\v 1 لەو ڕۆژەدا، 
\q1 یەزدان بە شمشێرە 
\q2 ڕەق و گەورە و بەهێزەکەی، 
\q1 سزای لیڤیاتان دەدات کە مارە هەڵاتووەکەیە، 
\q2 لیڤیاتان کە مارە پێچ خواردووەکەیە، 
\q1 ئەژدیهاکەی ناو دەریاش دەکوژێت. 
\p  
\v 2 لەو ڕۆژەدا 
\q1 «گۆرانی بۆ ڕەزەمێوی بەردار بڵێن: 
\q2  
\v 3 من یەزدانم، چاودێری ئەوم، 
\q2 هەموو ساتێک ئاوی دەدەم. 
\q1 بە شەو و بە ڕۆژ چاودێری دەکەم 
\q2 نەوەک ئازار بدرێت. 
\q2  
\v 4 هەڵچوونم نییە. 
\q1 وای ئەگەر لە جەنگدا دڕکوداڵیان دەخستە بەرپێم! 
\q2 من پێشێلم دەکردن و دەمسووتاندن، 
\q2 گڕم لە هەموویان بەردەدا. 
\q1  
\v 5 بەڵام ئەگەر پەنا بداتە پاڵ من 
\q2 لەگەڵ من ئاشتی دەبەستێت، 
\q2 ئاشتی لەگەڵ من دەبەستێت.» 
\b  
\q1  
\v 6 لە داهاتوودا، یاقوب ڕەگ دادەکوتێت، 
\q2 ئیسرائیل گوڵ دەکات و لق دەردەکات، 
\q2 ڕووی جیهان پڕ بەروبووم دەکات. 
\b  
\q1  
\v 7 ئایا یەزدان لێیدان 
\q2 بەو شێوەیەی لەوانەی دا کە لێیان دەدان؟ 
\q1 یان ئەوەندەی لێ کوشتن 
\q2 وەک لە بکوژانی ئەوانی کوشت؟ 
\q1  
\v 8 بە دوورخستنەوە و بە ڕاپێچکردن دژایەتی ئەوت کرد، 
\q2 ڕایماڵی بە بای بەهێزی خۆی 
\q2 لە ڕۆژێکی بای ڕۆژهەڵاتیدا. 
\q1  
\v 9 لەبەر ئەوە بەمە کەفارەت بۆ تاوانی یاقوب دەکرێت، 
\q2 ئەمەش هەموو بەروبوومی داماڵینی گوناهەکەیەتی 
\q1 بەوەی هەموو بەردەکانی قوربانگاکە 
\q2 وەک بەردی گەچی وردوخاشکراو لێ بکات، 
\q1 نە ستوونە ئەشێراکان و نە قوربانگاکانی خۆر 
\q2 بە پێوە نەمێنێت. 
\q1  
\v 10 شاری قەڵابەند تەنهایە، 
\q2 ماڵ چۆڵ و بەجێماوە وەک چۆڵەوانی، 
\q1 لەوێ گوێرەکە دەلەوەڕێت و 
\q2 لەوێ پاڵ دەداتەوە و 
\q2 لقەکانی تێکدەدات. 
\q1  
\v 11 کە وشک دەبێت پۆپکەکانی دەشکێن و 
\q2 ژنان دێن ئاگریان تێبەر دەدەن، 
\q1 چونکە گەلێکی تێگەیشتوو نییە، 
\q2 لەبەر ئەوە دروستکەرەکەی بەزەیی پێیاندا نایەتەوە و 
\q2 شێوەکێشەکەی لەگەڵیدا میهرەبان نابێت. 
\p  
\v 12 لەو ڕۆژەدا یەزدان دەیکوتێت لە ئاوەڕۆی فوراتەوە هەتا دۆڵی میسر، ئێوەش یەک بە یەک هەڵدەگیرێنەوە، ئەی نەوەی ئیسرائیل.  
\v 13 لەو ڕۆژەدا فوو بە کەڕەنایەکی گەورەدا دەکرێت، جا ونبووەکان لە خاکی ئاشور و دوورخراوەکان بۆ خاکی میسر دێن و کڕنۆش بۆ یەزدان دەبەن لە کێوی پیرۆز لە ئۆرشەلیم. 
\c 28  
\s1 قوڕبەسەری بۆ ئەفرایم 
\q1  
\v 1 قوڕبەسەر ئەو تاجەی سەرخۆشانی ئەفرایم شانازی پێوە دەکەن! 
\q2 قوڕبەسەر ئەو شارەی دەسەڵاتدارە بەسەر دۆڵی بەپیت، 
\q1 کە جوانی و شکۆمەندییەکەی وەک گوڵێکی سیسە. 
\q2 قوڕبەسەر ئەوانەی شەراب ئەوانی کەواندووە! 
\q1  
\v 2 ئەوەتا بەهێز و توند هی پەروەردگارە. 
\q2 وەک لێزمەی تەرزە و ڕەشەبای وێرانکەر، 
\q1 وەک لێزمەی ئاوی زۆری ڕاماڵ، 
\q2 بە دەست فڕێیدەداتە سەر زەوی. 
\q1  
\v 3 پێشێل دەکرێت 
\q2 تاجی شانازی سەرخۆشانی ئەفرایم. 
\q1  
\v 4 دەبێت بە گوڵی سیس بوو 
\q2 جوانی شکۆمەندییەکەی، 
\q1 ئەوەی لەسەر دۆڵی بەپیتە، 
\q2 وەک پێگەیشتنی هەنجیر بەر لە هاوین، 
\q1 ئەوەی دەیبینێت 
\q2 هێشتا لە مستیەتی قووتی دەدات. 
\b  
\q1  
\v 5 لەو ڕۆژەدا یەزدانی سوپاسالار 
\q2 دەبێتە تاجەگوڵینەی جوانی و 
\q1 تاجی شکۆمەندی 
\q2 بۆ پاشماوەی گەلەکەی. 
\q1  
\v 6 دەبێتە ڕۆحی دادپەروەری 
\q2 بۆ دانیشتوو لەسەر تەختی حوکمدان و 
\q1 پاڵەوانیێتی 
\q2 بۆ بەرەنگاربووانی جەنگ لەبەر دەروازەکان. 
\b  
\q1  
\v 7 ئەمانیش بە شەراب گێژن و 
\q2 بە مەی گومڕان: 
\q1 کاهین و پێغەمبەر بە مەی گێژن، 
\q2 بە شەراب قووتدەدرێن، 
\q1 بە مەی گومڕان، 
\q2 کە بینینیان بۆ ئاشکرا دەکرێت گێژن، 
\q2 کوێرانە حوکم دەدەن. 
\q1  
\v 8 هەموو مێزەکان پڕ بوون لە ڕشانەوە و 
\q2 هیچ جێگایەک بێ پیسایی نەماوە. 
\b  
\q1  
\v 9 دەڵێن: «زانیاری فێری کێ دەکات؟ 
\q2 پەیام بۆ کێ ڕوون دەکاتەوە؟ 
\q1 بۆ لەشیربڕاوەکان، 
\q2 یان بۆ لە مەمک بڕاوەکان؟ 
\q1  
\v 10 وەک گغە گغ بۆ گغە گغ، 
\q2 بڤە بڤ بۆ بڤە بڤ،\f + \fr 28:10 \ft عیبری: \+tl چاڤ لاچاڤ، قاڤ لاقاڤ‏\+tl*، کە تەنها دەنگە لە زمانی عیبری بەبێ واتا، وەک گوێگرتن لە زمانێکی بیانی.‏\f* 
\q2 کەمێک لێرە و کەمێک لەوێ.» 
\b  
\q1  
\v 11 کەواتە خوداش بە لێوی بێگانە و زمانێکی نامۆ 
\q2 قسە بۆ ئەم گەلە دەکات. 
\q1  
\v 12 بۆ ئەوانەی پێی گوتن: 
\q2 «ئەمە حەسانەوەیە، 
\q1 با ماندوو بحەسێتەوە، ئەمە ئارامگایە.» 
\q2 بەڵام نەیانویست گوێ بگرن. 
\q1  
\v 13 جا فەرمایشتی یەزدان بۆیان دەبێت بە: 
\q2 گغە گغ بۆ گغە گغ، 
\q2 بڤە بڤ بۆ بڤە بڤ، 
\q2 کەمێک لێرە و کەمێک لەوێ. 
\q1 بۆ ئەوەی بڕۆن و بەرەو دواوە بکەون و 
\q2 بشکێنەوە و ڕاو بکرێن و بگیرێن. 
\b  
\q1  
\v 14 ئەی پیاوانی گاڵتەجاڕ، لەبەر ئەوە گوێ لە فەرمایشتی یەزدان بگرن، 
\q2 ئەی فەرمانڕەوایانی ئەم گەلە کە لە ئۆرشەلیمن! 
\q1  
\v 15 گوتتان: «پەیمانمان لەگەڵ مردن بەستووە و 
\q2 پەیماننامەمان لەگەڵ جیهانی مردووان مۆر کردووە، 
\q1 کە قامچی لافاو تێدەپەڕێت 
\q2 لە ئێمە نزیک ناکەوێتەوە، 
\q1 چونکە درۆمان کردووە بە داڵدەمان و 
\q2 لەناو ساختە پەناگیر دەبین.» 
\p  
\v 16 لەبەر ئەوە یەزدانی باڵادەست ئەمە دەفەرموێت: 
\q1 «ئەوەتا بەردێک لە سییۆن دادەنێم، 
\q2 کە دەبێتە سەنگی مەحەک، 
\q1 گرنگترین و گرانبەهاترین بەردی بناغە\f + \fr 28:16 \ft گرنگترین بەردی بناغە: بەردی قولینچک، بەردێکی گەورەیە لە گۆشەی دیوار دادەنرێت لەو بەردانە بەهێزترە کە لە دیوارەکە بەکاردێت و دەبێتە هۆی بەهێزکردنی دیوارەکە.‏\f* بۆ بناغەیەکی پتەو، 
\q2 ئەوەی پشتی پێ ببەستێت ناشڵەژێت. 
\q1  
\v 17 دادوەری دەکەمە گوریسی پێوانە و 
\q2 بە شاووڵ ڕاستودروستی دەکەم، 
\q1 جا تەرزە داڵدەی درۆ ڕادەماڵێت و 
\q2 پەناگاش ئاو دایدەپۆشێت. 
\q1  
\v 18 پەیمانەکەتان لەگەڵ مردن دەسڕێتەوە و 
\q2 پەیماننامەکەتان لەگەڵ جیهانی مردووان سەر ناگرێت. 
\q1 کاتێک قامچی لافاو تێدەپەڕێت، 
\q2 ئێوە بۆی دەبن بە پێشێل. 
\q1  
\v 19 هەر کاتێک تێبپەڕێت دەتانبات، 
\q2 چونکە هەموو بەیانییەک تێدەپەڕێت 
\q2 بە شەو و بە ڕۆژ.» 
\b  
\q1 بە تەنها تێگەیشتنی پەیامەکە 
\q2 دەبێتە مایەی تۆقاندن. 
\q1  
\v 20 دۆشەک کورت بووە بۆ ڕاکشان و 
\q2 لێفەش تەنک بووە بۆ لەخۆپێچانەوە. 
\q1  
\v 21 یەزدان هەڵدەستێت، وەک لە کێوی پەراچیم هەستا، 
\q2 هەروەک لە دۆڵی گبعۆن، تووڕەیی دێتە جۆش 
\q1 بۆ ئەوەی کارەکەی بکات، کارەکەی نامۆیە! 
\q2 بۆ ئەوەی ئیشەکەی بکات، ئیشەکەی نامۆیە! 
\q1  
\v 22 ئێستا گالتەجاڕ مەبن، 
\q2 نەوەک کۆتتان توندتر بکرێت، 
\q1 چونکە لەلایەن یەزدان، پەروەردگاری سوپاسالار، 
\q2 گوێم لە کۆتایی پێهێنان و بڕانەوە بووە بەسەر هەموو خاکەکەدا. 
\b  
\q1  
\v 23 گوێ شل بکەن و دەنگم ببیستن، 
\q2 گوێ بگرن و قسەم ببیستن. 
\q1  
\v 24 ئایا جوتیار هەموو ڕۆژێک زەوییەکەی دەکێڵێت، 
\q2 هەڵیدەکۆڵێت و خەرتەی دەکات بۆ چاندن؟ 
\q1  
\v 25 ئەی کە ڕووەکەی تەخت کرد، 
\q2 تۆوی دەکات بە کونجی و زیرەی تێدا دەوەشێنێت و 
\q1 گەنم لە هێڵی جووتەکانی دادەنێت و 
\q2 جۆ لە شوێنی نیشانکراو، 
\q2 گوڵەبەڕۆژەش لە سنوورەکانی؟ 
\q1  
\v 26 جا خودای خۆی فێری دەکات، 
\q2 بە دادوەری ڕێنمایی دەکات. 
\b  
\q1  
\v 27 کونجی بە جەنجەڕ ناکوترێت، 
\q2 چەرخەی عەرەبانەش بەسەر زیرەدا نایەت، 
\q1 بەڵکو کونجی بە دار تێکدەدرێت و 
\q2 زیرەش بە گۆچان. 
\q1  
\v 28 دانەوێڵە بۆ نان دەکوترێت، 
\q2 هەتاهەتایە جەنجەڕی بەسەردا ناهێنێت، 
\q1 چەرخەی عەرەبانەکەی و 
\q2 ئەسپەکەی وردوخاشی ناکەن. 
\q1  
\v 29 هەموو ئەمانەش لەلایەن یەزدانی سوپاسالارەوە هاتوون، 
\q2 ڕاوێژی سەیرە و دانایی مەزنە. 
\c 29  
\s1 قوڕبەسەر شارەکەی داود 
\q1  
\v 1 قوڕبەسەر ئەریێل، ئەریێل\f + \fr 29:1 \ft ئەریێل ئەو ناوە شیعرییەیە کە بۆ ئۆرشەلیم بەکاردەهێنرا، واتای ناوەکە: شێری خودا.‏\f* 
\q2 ئەو شارەی داود تێیدا مایەوە! 
\q1 ساڵ لەدوای ساڵ زیاد بکەن، 
\q2 با جەژنەکان بسوڕێنەوە. 
\q1  
\v 2 منیش تەنگ بە ئەریێل هەڵدەچنم، 
\q2 جا دەبێت بە گریان و شیوەن و 
\q2 بۆ من وەک ئاگردانی قوربانگای\f + \fr 29:2 \ft ‏لە زمانی عیبری هەمان وشەی ئەریێل بەکارهاتووە بە واتایەکی دیکە. بڕوانە ئایەتی 1.‏\f* لێدێت، 
\q1  
\v 3 وەک بازنە دەورت دەدەم، 
\q2 بە قەڵا تەنگت پێهەڵدەچنم و 
\q2 سەنگەر بە چواردەورتدا لێ دەدەم. 
\q1  
\v 4 جا نزم دەبیتەوە و لە زەوییەوە دەدوێیت، 
\q2 قسەکەت لەناو خۆڵ دەچەمێتەوە، 
\q1 دەنگت وەک تارمایی دەبێت لە زەوییەوە، 
\q2 قسەکەت لەناو خۆڵ چرپەی دێت. 
\b  
\q1  
\v 5 ئاپۆرەی دوژمنانت وەک تۆزی کوتراو دەبن و 
\q2 ئاپۆرەی زۆرداران وەک پووشی با بردوو دەبێت. 
\q1 لە ساتێکدا لەپڕ ئەوە دەبێت، 
\q2  
\v 6 لەلایەن یەزدانی سوپاسالارەوە سزا دەدرێت 
\q1 بە هەورەتریشقە و بوومەلەرزە و دەنگێکی بەرزەوە، 
\q2 بە زریان و ڕەشەبا و گڕی ئاگری سووتێنەرەوە. 
\q1  
\v 7 وەک خەون و زیندەخەوی شەوانی لێدێت، 
\q2 ئاپۆرەی هەموو نەتەوە لەشکرکێشەکانی سەر ئەریێل، 
\q1 هەموو لەشکرکێشەکانی سەری و سەر قەڵاکانی 
\q2 لەگەڵ تەنگ پێ هەڵچنانی، 
\q1  
\v 8 وەک ئەوەی برسی خەون ببینێت و ئەوەتا دەخوات، 
\q2 بەڵام کە هەڵدەستێت ورگی بەتاڵە، 
\q1 وەک ئەوەی تینوو خەون ببینێت و ئەوەتا دەخواتەوە، 
\q2 بەڵام کە هەڵدەستێت شەکەتە و گیانی ئارەزوو دەکات، 
\q1 ئاوایان لێدێت ئاپۆرەی هەموو ئەو نەتەوانەی 
\q2 لەشکرکێشییان کردووە بۆ سەر کێوی سییۆن. 
\b  
\q1  
\v 9 بحەپەسێن و سەرسام بن! 
\q2 خۆتان کوێر بکەن و کوێربن! 
\q1 بەبێ شەراب ئێوە مەستن، 
\q2 بەبێ مەی ئێوە بە لارەلار دەڕۆن. 
\q1  
\v 10 یەزدان ڕۆحی خەوی قووڵی بەسەر ئێوەدا ڕشتووە، 
\q2 بەم شێوەیە یەزدان چاوەکانی ئێوەی نوقاندووە کە پێغەمبەرەکانن، 
\q2 هەروەها یەزدان سەری ئێوەی پێشبینیکەری داپۆشیوە. 
\p  
\v 11 جا تەواوی ئەم پەیامەی کە بە بینینێک ئاشکرا کراوە تەنها بۆ ئێوە وەک وشەکانی تۆمارێکی مۆرکراوی لێهاتووە، ئەوەی دەیدەنە کەسێکی خوێندەوار و دەڵێن: «تکایە ئەمە بخوێنەوە.» ئەویش دەڵێت: «ناتوانم، چونکە مۆر کراوە.»  
\v 12 یان ئەگەر تۆمارەکە دەدەنە کەسێکی نەخوێندەوار و دەڵێن: «تکایە ئەمە بخوێنەوە.» ئەویش دەڵێت: «خوێندەواریم نییە.» 
\p  
\v 13 جا پەروەردگار دەفەرموێت: 
\q1 «لەبەر ئەوەی ئەم گەلە هەر بە دەم نزیک دەبنەوە و 
\q2 بە لێوەکانیان ڕێزم لێ دەگرن، 
\q2 بەڵام دڵیان لێم دوورە، 
\q1 پەرستنیان بۆ من 
\q2 تەنها فێرکردن و ڕاسپاردەی خەڵکە. 
\q1  
\v 14 لەبەر ئەوە ئەوەتا من جارێکی دیکە 
\q2 کاری سەیر و سەمەرە بەم گەلە دەکەم، 
\q1 دانایی داناکانی لەناودەبەم و 
\q2 تێگەیشتنی تێگەیشتووانی ون دەبێت.» 
\q1  
\v 15 قوڕبەسەر ئەوانەی دەچنە قووڵاییەوە 
\q2 بۆ ئەوەی پیلانەکانیان لە یەزدان بشارنەوە، 
\q1 کارەکانیان لە تاریکی دەبێت و 
\q2 دەڵێن: «کێ دەمانبینێ؟ کێ دەمانناسێت؟» 
\q1  
\v 16 ئای لە هاڵاوگێڕیتان، 
\q2 ئایا گۆزەکەر و قوڕ دەکرێن بە یەک 
\q1 تاکو دروستکراو بە دروستکەرەکەی بڵێت: 
\q2 «تۆ دروستت نەکردم»؟ 
\q1 یان گۆزەکە بە گۆزەکەر بڵێت: 
\q2 «تێناگەیت»؟ 
\b  
\q1  
\v 17 ئایا لە ساتێکی کەمدا لوبنان ناگۆڕێت بۆ باخ و 
\q2 باخیش بە دارستان دانانرێت؟ 
\q1  
\v 18 جا لەو ڕۆژەدا کەڕەکان گوێیان لە وشەکانی تۆمارەکە دەبێت و 
\q2 لە ئەنگوستەچاو و لە تاریکیدا 
\q2 چاوی نابیناکان دەبینن. 
\q1  
\v 19 زەلیلەکان دڵخۆشییان بە یەزدان زیاتر دەبێت، 
\q2 نەدارانیش بە خودا پیرۆزەکەی ئیسرائیل دڵشاد دەبن. 
\q1  
\v 20 زۆردار لەناودەچێت و 
\q2 گاڵتەجاڕ نەمێنێت و 
\q2 هەموو ئێشکگرانی خراپەکاری دەبڕێنەوە. 
\q1  
\v 21 ئەوانەی بە وشەیەک مرۆڤ گوناهبار دەکەن و 
\q2 لە دادگا داو بۆ دادوەر دەنێنەوە و 
\q2 بە شتی پووچ دادپەروەری خوار دەکەن. 
\p  
\v 22 لەبەر ئەوە یەزدان ئەوەی ئیبراهیمی کڕییەوە، ئەمە بە بنەماڵەی یاقوب دەفەرموێت: 
\q1 «ئێستا یاقوب شەرمەزار نابێت و 
\q2 ئێستا ڕوو زەرد نابێت. 
\q1  
\v 23 کاتێک منداڵەکانی دەستکردەکانی دەستم 
\q2 لەنێویاندا دەبینن، 
\q1 وەک ناوێکی پیرۆز ڕێز لە ناوەکەم دەگرن، 
\q2 دان بە پیرۆزی پیرۆزەکەی یاقوبدا\f + \fr 29:23 \ft پیرۆزەکەی یاقوب: مەبەست لە خودای پیرۆزی یاقوبە.‏\f* دەنێن، 
\q2 لە خودای ئیسرائیل دەترسن. 
\q1  
\v 24 ئەوانەی لە ناوەڕۆکەوە گومڕا بوون تێگەیشتن بەدەستدەهێنن و 
\q2 بۆڵەبۆڵکەران فێربوون وەردەگرن.» 
\c 30  
\s1 قوڕبەسەر نەتەوەی کەللەڕەق 
\q1  
\v 1 یەزدان دەفەرموێت: 
\q2 «قوڕبەسەر کوڕانی کەللەڕەق، 
\q1 پلانێک جێبەجێ دەکەن کە هی من نییە، 
\q2 داڕێژراوێک دادەڕێژن کە لە ڕۆحی منەوە نییە 
\q2 بۆ ئەوەی گوناه لەسەر گوناه زیاد بکەن. 
\q1  
\v 2 دەڕۆن هەتا بەرەو میسر شۆڕ بنەوە 
\q2 بێ ئەوەی پرس بە من بکەن، 
\q1 هەتا پەنا بدەنە پاڵ قەڵای فیرعەون، 
\q2 لە سایەی میسر پەناگیر بن. 
\q1  
\v 3 بەڵام قەڵای فیرعەون بۆتان دەبێت بە ڕیسوایی و 
\q2 پەناگیریشتان لە سایەی میسر بە شەرمەزاری. 
\q1  
\v 4 هەرچەندە میرەکانی وا لە چۆعەنن، 
\q2 نێردراوەکانی گەیشتنە شاری حانێس، 
\q1  
\v 5 بەڵام هەموو شەرمەزار دەبن 
\q2 لە گەلێک کە بێ سوودە بۆیان، 
\q1 بۆ یارمەتیدان نییە و بۆ سوود بەخشین نییە، 
\q2 چونکە بۆ ڕیسوایی و بۆ شورەییە.» 
\b  
\p  
\v 6 سروشێک سەبارەت بە ئاژەڵەکانی نەقەب: 
\q1 لە خاکی تەنگانە و ناخۆشیدا، 
\q2 ئەوەی شێرە مێ و شێری لێوە دێت، 
\q2 مار و ماری ژەهراوی باڵدار، 
\q1 سامانەکانیان لەسەر شانی گوێدرێژ بار دەکەن، 
\q2 لەسەر پشتی وشتریش گەنجینەکانیان 
\q1 بۆ لای گەلێک کە سوود نابەخشن، 
\q2  
\v 7 چونکە پووچ و بەفیڕۆدانە یارمەتییەکەی میسر. 
\q1 لەبەر ئەوە ناوم لەمە نا: 
\q2 «ڕەهەڤ ئەوەی هیچ ناکات». 
\b  
\q1  
\v 8 ئێستا وەرە لەلایان لەسەر تەختەیەک بینووسە و 
\q2 لە تۆمارێک نەخشی بکە، 
\q1 هەتا بۆ ڕۆژگاری داهاتوو ببێت بە 
\q2 شایەتێک بۆ هەتاهەتایە. 
\q1  
\v 9 ئەوان گەلێکی یاخین، کوڕانی درۆزنن، 
\q2 ئەو کوڕانەی نەیانویست گوێ لە فێرکردنی یەزدان بگرن. 
\q1  
\v 10 بە پێشبینیکەر دەڵێن: 
\q2 «پێشبینی مەکە!» 
\q1 بەوەی پەیامی خودا ڕادەگەیەنێت دەڵێن: 
\q2 «پەیامی ڕاستمان پێ ڕامەگەیەنە! 
\q1 قسەی لووسمان بۆ بکە، 
\q2 خەونی تەفرەدەر ببینە! 
\q1  
\v 11 لە ڕێگا لابدەن، 
\q2 ڕێچکە بەر بدەن، 
\q1 چیتر ڕووبەڕوومان مەکەنەوە 
\q2 لەگەڵ داواکارییەکانی خودا پیرۆزەکەی ئیسرائیل!» 
\p  
\v 12 لەبەر ئەوە خودا پیرۆزەکەی ئیسرائیل وا دەفەرموێت: 
\q1 «ئەم پەیامەتان ڕەتکردەوە و 
\q2 متمانەتان بە زۆرداری و خواروخێچی کرد و 
\q2 پشتتان پێیان بەست، 
\q1  
\v 13 لەبەر ئەوە ئەم تاوانەتان وەک 
\q2 دیوارێکی ناڕێک و بەرز درزی تێکەوتبێت، 
\q2 ئەوەی لەناکاو و دەستبەجێ دادەڕووخێت. 
\q1  
\v 14 وەک شکانی گۆزەی گۆزەکەران دەشکێت 
\q2 بێ بەزەییانە وردوخاش دەکرێت، 
\q1 لەناو پارچە وردوخاشکراوەکانی 
\q2 پارچەیەک نابێت بۆ هەڵگرتنی ئاگر لە ئاگردانەوە 
\q2 یان بۆ ئاو دەرهێنان لە ئەمباراوەوە.» 
\p  
\v 15 یەزدانی باڵادەست، پیرۆزەکەی ئیسرائیل وا دەفەرموێت: 
\q1 «بە تۆبەکردن و ئارامگرتن ڕزگارتان دەبێت، 
\q2 پاڵەوانیتان لە هێمنی و لە دڵنیاییتان دەبێت، 
\q2 بەڵام نەتانویست، 
\q1  
\v 16 گوتتان: ”وا نا، بەڵکو بە ئەسپ هەڵدێین،“ 
\q2 لەبەر ئەوە هەڵدێن! 
\q1 گوتتان: ”سواری ئەسپی خێرا دەبین،“ 
\q2 لەبەر ئەوە ڕاونەرانتان خێرا دەکەن! 
\q1  
\v 17 لە ڕووی نەڕەی یەک کەس 
\q2 هەزار کەس هەڵدێت، 
\q1 لە ڕووی نەڕەی پێنج کەس 
\q2 هەمووتان هەڵدێن، 
\q1 هەتا وەک دار ئاڵا لەسەر لووتکەی چیا و 
\q2 وەک بەیداخ بەسەر گردەوە دەمێننەوە.» 
\b  
\q1  
\v 18 بەڵام یەزدان چاوەڕێی ئەوە دەکات هەتا لەگەڵتان میهرەبان بێت، 
\q2 لەبەر ئەوە هەڵدەستێت بۆ ئەوەی بەزەیی پێتاندا بێتەوە، 
\q1 چونکە یەزدان خودای دادپەروەرییە. 
\q2 خۆزگە بەوانەی چاوەڕێی دەکەن! 
\p  
\v 19 ئەی گەلی سییۆن کە لە ئۆرشەلیم نیشتەجێن، ئێوە ئیتر ناگریێن. بە تەواوی میهرەبان دەبێت لەگەڵتان، لەگەڵ دەنگی هاوارتان کە گوێی لێ دەبێت، بە دەنگتانەوە دێت.  
\v 20 هەرچەندە پەروەردگار نانی تەنگانە و ئاوی ناخۆشیتان دەداتێ، بەڵام ئیتر مامۆستاکانتان ناخرێنە پەنای چاوەکانتان، مامۆستاکانتان دەبینن.  
\v 21 کاتێک بەلای ڕاست یان چەپدا لادەدەن، گوێیەکانتان دەنگێک دەبیستێت لە دواتانەوە دەڵێت: «ئەمە ڕێگاکەیە، پێیدا بڕۆن.»  
\v 22 پەیکەرە داتاشراوە بە زیو ڕووکەشکراوەکانتان و بتە لەقاڵبدراوە بە زێڕ ڕووکەشکراوەکانتان بە گڵاو دادەنێن. وەک پەڕۆی پیسی ئافرەت فڕێیدەدەن، پێی دەڵێن: «بڕۆ دەرەوە!» 
\p  
\v 23 ئینجا بارانی تۆوەکەت دەداتێ کە زەوییەکەی پێ تۆو دەکەیت، نانی بەروبوومی زەوییەکە چەور و قەڵەو دەبێت. لەو ڕۆژەدا مەڕوماڵاتەکەت لە لەوەڕگایەکی پانوبەریندا دەلەوەڕێن.  
\v 24 گاجووت و نێرەکەرەکانت کە لە زەوییەکەت کار دەکەن ئالیکی پاککراو دەخۆن کە بە شەن و بێڵ شەن کرابێت.  
\v 25 جا لەسەر هەموو کێوێکی بڵند و لەسەر هەموو تەپۆڵکەیەکی بەرز ڕووبار و جۆگەی ئاو دەبێت لە ڕۆژی کوشتارە مەزنەکە، کاتێک قوللەکان دەکەون.  
\v 26 جا ڕووناکی مانگ وەک ڕووناکی خۆر دەبێت، ڕووناکی خۆریش حەوت ئەوەندە دەبێت وەک ڕووناکی حەوت ڕۆژ لەو ڕۆژەی یەزدان شکاوی گەلەکەی دەگرێتەوە و جێی لێدانەکانی تیمار دەکات. 
\q1  
\v 27 ئەوەتا ناوی یەزدان لە دوورەوە هات، 
\q2 تووڕەییەکەی گڕی گرتووە و بارەکەی قورسە. 
\q1 لێوەکانی پڕن لە هەڵچوون و 
\q2 زمانی وەک ئاگرێکی لووشدەرە. 
\q1  
\v 28 هەناسەی وەک ڕووبارێکی هەستاوە 
\q2 دەگات بە گەردن، 
\q1 بۆ لەبێژنگدانی نەتەوەکان 
\q2 بە بێژنگی لەناوچوون و 
\q2 لغاوی گومڕابوونیش لەدەم گەلانە. 
\q1  
\v 29 گۆرانییەکتان بۆ دەبێت 
\q2 وەک شەوی تەرخانکردنی جەژن، 
\q1 خۆشی دڵیش 
\q2 وەک ئەوەی بەدەم بلوێرەوە بڕوات 
\q1 هەتا بێت بۆ کێوی یەزدان، 
\q2 بۆ تاشەبەردەکەی ئیسرائیل. 
\q1  
\v 30 یەزدان وا دەکات دەنگی مەزنی ببیسترێت و 
\q2 دابەزینی بازووی ببینرێت 
\q1 بە هەڵچوونی تووڕەیی و گڕی ئاگری لووشدەر، 
\q2 بە ڕەشەبا و لێزمەی باران و تەرزەوە. 
\q1  
\v 31 ئاشور لە دەنگی یەزدان لەرز دەیگرێت، 
\q2 بە داردەست لێدەدات. 
\q1  
\v 32 جا هەموو لێدانێکی گۆچانی دادوەری، 
\q2 ئەوەی یەزدان بەسەریدا دەهێنێت، 
\q1 بە دەف و قیسارەوە دەبێت و 
\q2 بە ڕاوەشاندنی دەستی کە دەجەنگێت. 
\q1  
\v 33 چاڵی تۆفەت\f + \fr 30:33 \ft ‏شوێنێک بووە بۆ سووتاندنی قوربانی بتپەرستەکان کە زۆر جار مرۆڤی تێدا کراوەتە قوربانی. بڕوانە \xt دووەم پاشایان 23‏:10‏\ft ‏.‏\f* لەمێژە ڕێکخراوە، 
\q2 بۆ پاشا ئامادە کراوە، 
\q1 قووڵە، بەرینە، 
\q2 کەڵەکە کراوەکەی ئاگرە و داری زۆرە. 
\q1 هەناسەی یەزدان 
\q2 وەک ڕووباری گۆگردە 
\q2 گڕی تێبەردەدات. 
\c 31  
\s1 قوڕبەسەر ئەوانەی پشت بە میسر دەبەستن 
\q1  
\v 1 قوڕبەسەر ئەوانەی دادەبەزن بۆ میسر بۆ یارمەتی، 
\q2 پشت بە ئەسپ دەبەستن، 
\q1 متمانە بە زۆری گالیسکە و 
\q2 هێزی لە ڕادەبەدەری سوارەکانیان دەکەن، 
\q1 بەڵام پشتیان بە خودا پیرۆزەکەی ئیسرائیل نەبەست و 
\q2 داوای یارمەتییان لە یەزدان نەکرد. 
\q1  
\v 2 ئەویش هەروەها دانایە و کارەسات دەهێنێت، 
\q2 لە وشەی خۆی با ناداتەوە. 
\q1 هەڵدەستێتە سەر ماڵی خراپەکاران و 
\q2 بۆ سەر یارمەتیدەری ستەمکاران. 
\q1  
\v 3 بەڵام میسرییەکان مرۆڤن نەک خودا، 
\q2 ئەسپەکانیان جەستەیین نەک ڕۆح. 
\q1 کاتێک یەزدان دەستی درێژ دەکات، 
\q2 یارمەتیدەر ساتمە دەکات و 
\q2 یارمەتیدراو دەکەوێت، 
\q2 هەموو پێکەوە لەناودەچن. 
\p  
\v 4 ئێستا یەزدان ئەمەم پێ دەفەرموێت: 
\q1 «وەک شێر و بەچکە شێر دەنەڕێنێت 
\q2 بەسەر نێچیرەکەیەوە، 
\q1 ئەوەی کۆمەڵە شوان 
\q2 هاواری لێ دەکەن، 
\q1 لە دەنگیان ناترسێت و 
\q2 لە هاتوهەرایان ناشڵەژێت، 
\q1 ئاواش یەزدانی سوپاسالار دادەبەزێت 
\q2 بۆ شەڕکردن لەسەر کێوی سییۆن و لەسەر گردەکانی. 
\q1  
\v 5 وەک باڵندە فڕیوەکان، 
\q2 ئاوا یەزدانی سوپاسالار پارێزگاری لە ئۆرشەلیم دەکات، 
\q1 پارێزگاری دەکات و فریادەکەوێت، 
\q2 بەسەریدا تێدەپەڕێت\f + \fr 31:5 \ft بڕوانە \xt دەرچوون 12‏:12‏-13.‏\ft ‏\f* و دەربازی دەکات.» 
\p  
\v 6 ئەی نەوەی ئیسرائیل، بگەڕێنەوە بۆ لای ئەوەی کە بە توندی لێی هەڵگەڕانەوە،  
\v 7 چونکە لەو ڕۆژەدا هەرکەسە و بتە زێڕ و زیوەکانتان ڕەت دەکەنەوە، ئەوەی دەستە گوناهبارەکانتان دروستی کردن. 
\q1  
\v 8 «ئاشور دەکەوێت، بەڵام بە شمشێری مرۆڤ نا، 
\q2 شمشێری ئادەمیزاد نییە کە دەیخوات. 
\q1 جا لە ڕووی شمشێر هەڵدێت و 
\q2 گەنجەکانی بۆ بێگاری دەبن. 
\q1  
\v 9 قەڵاکەیان لە ترسان دەکەوێت، 
\q2 میرەکانیشی لە ئاڵا دەترسن،» 
\q1 یەزدان دەفەرموێت، 
\q2 ئەوەی ئاگری هەیە لە سییۆن و 
\q2 تەنووری هەیە لە ئۆرشەلیم. 
\c 32  
\s1 شانشینی ڕاستودروستی 
\q1  
\v 1 ئەوەتا پاشایەک بە ڕاستودروستی پاشایەتی دەکات و 
\q2 میرانیش بە دادوەری سەرۆکایەتی دەکەن، 
\q1  
\v 2 مرۆڤ وەک حەشارگەیەک دەبێت لە ڕووی با و 
\q2 وەک چەتر لە ڕووی لێزمەی باران، 
\q1 وەک جۆگەی ئاو لە شوێنێکی وشکدا و 
\q2 وەک سێبەری تاشەبەردێکی گەورە لە خاکی ماندووبووندا. 
\b  
\q1  
\v 3 چاوی بینەران کز نابێت و 
\q2 گوێی گوێگرەکان دەبیستێت. 
\q1  
\v 4 دڵی هەڵەشەکان دەزانن و تێدەگەن و 
\q2 زمانی زمانگرانەکان بە ڕوونی و ڕەوانی دەدوێن. 
\q1  
\v 5 ئیتر گێل بە «ڕێزدار» بانگ ناکرێت، 
\q2 بە فێڵبازیش ناگوترێت «خانەدان»، 
\q1  
\v 6 چونکە گێل بە گێلی دەدوێت و 
\q2 دڵیشی خراپە دەکات، 
\q1 بۆ ئەوەی گڵاوی ئەنجام بدات، 
\q2 لە دژی یەزدان بوختان هەڵدەبەستێت، 
\q1 بۆ ئەوەی برسی تێر نەبێت و 
\q2 تینوو لە خواردنەوە بێبەش بێت. 
\q1  
\v 7 ڕێبازی فێڵبازیش خراپە و 
\q2 پیلانی بەدکاری دەگێڕێت، 
\q1 هەتا بە قسەی درۆ کڵۆڵان تەفروتونا بکات 
\q2 ئەگەر قسەی نەدارانیش ڕاست بێت. 
\q1  
\v 8 بەڵام ڕێزدار بە ڕێزداری پلان دادەنێت و 
\q2 لەسەر ڕێزیش جێگیر دەبێت. 
\s1 ئافرەتانی ئۆرشەلیم 
\q1  
\v 9 ئەی ئافرەتە لەخۆڕازییەکان، 
\q2 هەستن گوێ لە دەنگی من بگرن! 
\q1 ئەی کیژە دڵنیاکان، 
\q2 گوێ شل بکەن بۆ قسەی من! 
\q1  
\v 10 ئەی دڵنیاکان، ڕۆژانێک پتر لە یەک ساڵ 
\q2 لەرز دەتانگرێت، 
\q1 چونکە ڕەزچنین بەسەرچوو و 
\q2 کۆکردنەوە نایەت. 
\q1  
\v 11 ئەی ئافرەتە لەخۆڕازییەکان، بلەرزن! 
\q2 ئەی کیژە دڵنیاکان لەرز بتانگرێت! 
\q1 جلتان دابکەنن و خۆتان ڕووت بکەنەوە، 
\q2 گوش لە کەمەرتان ببەستن. 
\q1  
\v 12 لە سنگی خۆتان بدەن بۆ کێڵگە بەردارەکان، 
\q2 بۆ ڕەزی بەردار، 
\q1  
\v 13 بۆ خاکی گەلەکەم 
\q2 دڕکوداڵ دەڕوێت، 
\q1 بەڵێ، بۆ هەموو ماڵە شادەکان، 
\q2 بۆ شارە گەشاوەکە. 
\q1  
\v 14 بێگومان کۆشک چۆڵ دەکرێت، 
\q2 شاری قەرەباڵغ چۆڵ دەبێت، 
\q1 قەڵا و قوللەی چاودێری لەگەڵ زەوی تەخت دەبن بۆ هەتاهەتایە، 
\q2 دەبن بە سەیرانگای گوێدرێژەکان، لەوەڕگا بۆ مێگەلەکان، 
\q1  
\v 15 هەتا ئەو کاتەی لە بەرزاییەوە ڕۆحی خودا بەسەرماندا دەڕژێت، 
\q2 جا چۆڵەوانی دەبێت بە باخ و 
\q2 باخیش بە دارستان دادەنرێت. 
\q1  
\v 16 جا دادپەروەری یەزدان لە چۆڵەوانی نیشتەجێ دەبێت و 
\q2 ڕاستودروستییەکەشی لەناو باخ دادەنیشێت. 
\q1  
\v 17 جا ئەنجامدانی ڕاستودروستی ئاشتی دەبێت و 
\q2 کاری ڕاستودروستیش ئارامی و ئاسوودەیی هەتاهەتایی. 
\q1  
\v 18 ئینجا گەلی من لە ئاشتی و ئاوەدانی نیشتەجێ دەبێت و 
\q2 لە نشینگەی ئاسوودەیی و 
\q2 شوێنی پشوودانەکانیان بە ئارامی. 
\q1  
\v 19 تەرزە دەبارێت و دارستانەکان دەکوتێت، 
\q2 شارەکە بە تەواوی دەکەوێنێت، 
\q1  
\v 20 بەڵام خۆزگە بە خۆتان 
\q2 کاتێک تۆو لەدەم هەموو ئاوەکان دەچێنن و 
\q2 گا و گوێدرێژەکانتان دەلەوەڕن. 
\c 33  
\s1 تەنگانە و یارمەتی 
\q1  
\v 1 قوڕبەسەرت ئەی تێکدەر، 
\q2 کە تێکیان نەدایت! 
\q1 قوڕبەسەرت ئەی ناپاک، 
\q2 کە ناپاکییان لێ نەکردوویت! 
\q1 کاتێک لە تێکدان تەواو دەبیت، 
\q2 خۆت تێکدەدرێیت؛ 
\q1 کاتێک لە ناپاکی بوویتەوە، 
\q2 خۆت ناپاکیت لێ دەکرێت. 
\b  
\q1  
\v 2 ئەی یەزدان، لەگەڵماندا میهرەبان بە، 
\q2 هیوامان بە تۆیە. 
\q1 هەموو بەیانییەک ببە هێزمان و 
\q2 هەروەها ڕزگاریمان لە کاتی تەنگانەدا. 
\q1  
\v 3 لە نەڕەی دەنگت گەلان ڕایانکرد، 
\q2 کە ڕاپەڕیت نەتەوەکان پەرت بوون. 
\q1  
\v 4 ئەی نەتەوەکان، دەستکەوتەکانتان کۆ دەکرێنەوە وەک چۆن کوللە لە دەغڵ دەدات، 
\q2 وەک ڕەوە کوللە خەڵک ڕووتتان دەکەنەوە. 
\b  
\q1  
\v 5 یەزدان پایەبەرزە، چونکە نیشتەجێی بەرزاییە، 
\q2 سییۆن لە ڕاستودروستی و دادپەروەری پڕ دەکات. 
\q1  
\v 6 یەزدان دەبێتە مایەی دڵنیایی کاتەکانت. 
\q2 گەنجینەی ڕزگاری و دانایی و زانینە، 
\q2 لەخواترسی کلیلی ئەو گەنجینەیە. 
\b  
\q1  
\v 7 ئەوەتا دلێرەکانیان لە دەرەوە دەقیژێنن، 
\q2 نێردراوانی ئاشتی بە تاڵی دەگرین. 
\q1  
\v 8 ڕێگاکان چۆڵ بوون، 
\q2 بڕانەوە ڕێبواران. 
\q1 پەیمان شکا و 
\q2 شایەتەکانی ڕەتکرانەوە و 
\q2 کەس بە هیچ دانانرێت. 
\q1  
\v 9 زەوی شیوەن دەکات و سیس بوو، 
\q2 لوبنان ڕیسوا بوو، داڕزا، 
\q1 شارۆن وەک بیابانی عەراڤای\f + \fr 33:9 \ft شیوێک بوو لە دەریاچەی جەلیلەوە هەتا دەریای مردوو.‏\f* لێهات، 
\q2 باشان و کارمەل ڕووتانەوە. 
\b  
\q1  
\v 10 یەزدان دەفەرموێت: «ئێستا هەڵدەستم، 
\q2 ئێستا بە گەورە دەزانرێم، 
\q2 ئێستا بڵند دەکرێمەوە. 
\q1  
\v 11 بە گیا دووگیان دەبن و 
\q2 کاتان دەبێت، 
\q2 هەناسەتان ئاگرە و خۆتان دەخوات. 
\q1  
\v 12 گەلان دەبن بە گەچ، 
\q2 وەک چقڵی بڕاوە بە ئاگر دەسووتێنرێن.» 
\b  
\q1  
\v 13 ئەی دوورەکان گوێتان لێ بێت چیم کردووە، 
\q2 ئەی نزیکەکان هێزم بزانن! 
\q1  
\v 14 گوناهباران لە سییۆن تۆقین، 
\q2 گڵاوەکان لەرز دایگرتن: 
\q1 «کێ لە ئێمە لەناو ئاگری لووشدەر دەمێنێتەوە؟ 
\q2 کێ لە ئێمە لەناو سووتانی هەمیشەیی دەمێنێتەوە؟» 
\q1  
\v 15 ئەوەی بە ڕاستودروستی هەڵسوکەوت دەکات و 
\q2 ڕاستی دەڵێت، 
\q1 ئەوەی قازانجی زۆرداری ڕەت دەکاتەوە و 
\q2 ڕێگری دەکات لە دەستەکانی بۆ وەرگرتنی بەرتیل، 
\q1 ئەوەی لە بیستنی خوێنڕشتن گوێی خۆی کەڕ دەکات و 
\q2 لە بینینی خراپە چاوی خۆی دەنوقێنێت، 
\q1  
\v 16 ئەو لە بەرزایی نیشتەجێ دەبێت، 
\q2 قەڵای چیاکان پەناگایەتی، 
\q1 نانی دەدرێت و 
\q2 ئاوی مسۆگەرە. 
\b  
\q1  
\v 17 چاوت پاشا لە جوانی خۆیدا دەبینێت، 
\q2 سنوورێکی فراوان دەبینن. 
\q1  
\v 18 دڵت لە تۆقین ڕادەمێنێت: 
\q2 «کوا خامەی نهێنی\f + \fr 33:18 \ft ‏ڕازپۆش.‏\f* و کوا باجگر؟ 
\q2 کوا بەرپرسی قوللەکان؟» 
\q1  
\v 19 ئیتر گەلی دڕندە نابینن، 
\q2 گەلێک قسەیان ئاڵۆزە بۆ بیستن، 
\q2 زمانیان گرانە تێیان ناگەیت. 
\b  
\q1  
\v 20 بڕوانە سییۆن شاری جەژنمان، 
\q2 چاوەکانت ئۆرشەلیم دەبینن، 
\q2 ماڵێکی ئاسوودە، چادرێک ناگوازرێتەوە. 
\q1 سنگەکانی هەرگیز هەڵناکەنرێن، 
\q2 هیچ کام لە گوریسەکانی ناپسێن. 
\q1  
\v 21 بێگومان لەوێ یەزدانی توانادار پشتگیرمان دەبێت. 
\q2 شوێنی ڕووبارەکان و کەناری جۆگە فراوانەکان دەبێت. 
\q1 کەشتی سەوڵدار پێیدا ناڕوات و 
\q2 کەشتی مەزن پێیدا تێناپەڕێت. 
\q1  
\v 22 یەزدان دادوەرمانە، 
\q2 یەزدان فەرزدانەرمانە، 
\q1 یەزدان پاشامانە، 
\q2 ئەو ڕزگارمان دەکات. 
\b  
\q1  
\v 23 گوریسەکانت شل بوون، 
\q2 بنکەی دار ئاڵای کەشتییەکەیان توند ناکەن، 
\q2 چارۆکە بڵاو ناکەنەوە. 
\q1 ئینجا دەستکەوتی زۆر دابەش کرا، 
\q2 شەلەکانیش تاڵانییان تاڵان کرد. 
\q1  
\v 24 دانیشتووی سییۆن ناڵێت، «نەخۆش کەوتم،» 
\q1 ئەو گەلەی تێیدا نیشتەجێیە تاوانەکانی بەخشراو دەبێت. 
\c 34  
\s1 دادوەری لە دژی نەتەوەکان 
\q1  
\v 1 ئەی نەتەوەکان نزیک بنەوە هەتا گوێ بگرن، 
\q2 ئەی نەتەوەکان گوێ شل بکەن! 
\q1 با زەوی و هەرچی تێیدایە گوێ بگرێت، 
\q2 جیهان و هەموو بەرهەمەکانی، 
\q1  
\v 2 چونکە تووڕەیی یەزدان لەسەر هەموو نەتەوەکانە، 
\q2 هەڵچوونی لەسەر هەموو سوپاکانیانە. 
\q1 بە تەواوی قڕی کردوون\f + \fr 34:2 \ft قڕی کردوون: لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f*، 
\q2 بەدەستەوەی داون بۆ سەربڕین. 
\q1  
\v 3 کوژراوەکانیان فڕێدەدرێن، 
\q2 تەرمەکانیان بۆنی بۆگەن دەردەکات و 
\q2 چیاکان لەناو خوێنی ئەوان دەتوێنەوە. 
\q1  
\v 4 خۆر و مانگ و ئەستێرەکان دەتوێنەوە، 
\q2 ئاسمان وەک تۆمارێک دەپێچرێتەوە. 
\q1 هەموو ئەستێرەکان هەڵدەوەرن، 
\q2 وەک هەڵوەرینی گەڵای مێو، 
\q2 وەک وەرینی هەنجیر لە دارەکەی. 
\b  
\q1  
\v 5 شمشێری من لە ئاسمان کاری تەواو بووە، 
\q2 وا دادەبەزێتە سەر ئەدۆم و 
\q2 بەسەر گەلێک بە نەفرەتم کردووە بۆ حوکم بەسەردادان. 
\q1  
\v 6 شمشێری یەزدان خوێنی لێ دەتکێت، 
\q2 قەڵەو بووە بە پیو\f + \fr 34:6 \ft پیو: واتا بەز، لێرە و لە ئایەتی 7.‏\f*، 
\q1 بە خوێنی بەرخ و تەگە، 
\q2 بە پیوی گورچیلەی بەرانەکان، 
\q1 چونکە یەزدان قوربانی سەربڕاوی هەیە لە بۆزرا و 
\q2 سەربڕینێکی گەورەی هەیە لە خاکی ئەدۆم. 
\q1  
\v 7 گای کێوی لەگەڵیان دەکەون، 
\q2 گوێرەکەکان لەگەڵ کەڵەگاکان، 
\q1 زەوییان بە خوێن ئاو دەدرێت، 
\q2 خۆڵیان بە پیو قەڵەو دەبێت. 
\b  
\q1  
\v 8 یەزدان ڕۆژی تۆڵەسەندنەوەی هەیە، 
\q2 ساڵی سزادان لەبەر کێشەکەی سییۆن. 
\q1  
\v 9 جا ڕووبارەکانی ئەدۆم دەبن بە قیر و 
\q2 خۆڵەکەی بە گۆگرد، 
\q2 زەوییەکەی دەبێت بە قیری داگیرساو! 
\q1  
\v 10 شەو و ڕۆژ ناکوژێتەوە، 
\q2 دووکەڵی بۆ هەتاهەتایە بەرز دەبێتەوە. 
\q1 نەوە دوای نەوە کاول دەبێت، 
\q2 بۆ هەتاهەتایە کەس پێیدا تێناپەڕێت. 
\q1  
\v 11 کوندەپەپووی بیابان و بایەقووش داگیری دەکەن، 
\q2 کوندەپەپووی گەورە و قەلەڕەش تێیدا نیشتەجێ دەبن. 
\q1 بەسەر ئەدۆمدا خودا گوریسی پێوانە بۆ خاپوور بوون و 
\q2 شاووڵی چۆڵبوون درێژ دەکات. 
\q1  
\v 12 خانەدانەکانی هیچیان لەوێ نابێت کە بە شانشینێک دادەنرێن، 
\q2 هەموو میرەکانی لەناودەچن. 
\q1  
\v 13 دڕک لە کۆشکەکانی شین دەبێت، 
\q2 چقڵ و وشترالووک لە قەڵاکانی. 
\q1 دەبێت بە مۆڵگای چەقەڵ و 
\q2 لانەی کوندەپەپوو. 
\q1  
\v 14 دڕندە بیابانییەکان و کەمتیار پێکدەگەن، 
\q2 تەگە\f + \fr 34:14 \ft نێری، سابرێن.‏\f* بانگی هاوەڵەکانیان دەکەن، 
\q1 دڕندەکان شەو لەوێدا ئارام دەگرن و 
\q2 جێی حەوانەوە بۆ خۆیان دەدۆزنەوە. 
\q1  
\v 15 لەوێ کوندەپەپوو هێلانە دەکات و هێلکە دەکات، 
\q2 کڕ دەکەوێت و لەژێر سێبەری باڵەکانی هەڵیدەهێنێت. 
\q1 لەوێ شاهین و شمقاڕ کۆدەبنەوە، 
\q2 هەریەکە و لەگەڵ تاکەکەی. 
\p  
\v 16 تۆمارەکەی یەزدان بپشکنن و بخوێننەوە: 
\q1 یەکێک لەمانە کەم نابێتەوە، 
\q2 هیچ مێینەیەک نێرەکەی خۆی ون ناکات، 
\q1 چونکە دەمی یەزدان فەرمانی داوە، 
\q2 ڕۆحی ئەو کۆیان دەکاتەوە. 
\q1  
\v 17 ئەو زەوییەکە لەنێوانیان دابەش دەکات، 
\q2 دەستی ئەو بە پەت بۆی بەش دەکات. 
\q1 بۆ هەتاهەتایە داگیری دەکەن، 
\q2 نەوە دوای نەوە تێیدا نیشتەجێ دەبن. 
\c 35  
\s1 خۆشحاڵی ئەوانەی یەزدان کڕیونیەتیەوە 
\q1  
\v 1 چۆڵەوانی و خاکی وشک شادمان دەبن، 
\q2 بیابان دەگەشێتەوە و چرۆ دەکات، 
\q1 وەک گوڵاڵە سوورە،  
\v 2 بە تەواوی چرۆ دەکات و 
\q2 تەواو دەگەشێتەوە و هاواری خۆشی دەکات! 
\q1 شکۆی لوبنانی پێدەدرێت، 
\q2 شەوکەتی کارمەل و شارۆن، 
\q1 ئەوان شکۆی یەزدان و 
\q2 شەوکەتی خودامان دەبینن. 
\b  
\q1  
\v 3 دەستە شلەکان توند بکەن و 
\q2 ئەژنۆ لەرزۆکەکان بچەسپێنن. 
\q1  
\v 4 بەوانە بڵێن کە دڵەکوتێیانە: 
\q2 «خۆتان توند بکەن، مەترسن! 
\q1 ئەوەتا خوداتان، 
\q2 بە تۆڵەسەندنەوە دێت، 
\q1 سزای خوداتان. 
\q2 ئەو دێت و ڕزگارتان دەکات.» 
\b  
\q1  
\v 5 ئەوسا چاوی کوێر دەبینێت و 
\q2 گوێی کەڕ دەکرێتەوە. 
\q1  
\v 6 ئەوسا شەل وەک ئاسک باز دەدات و 
\q2 زمانی لاڵ هاواری خۆشی دەکات، 
\q1 چونکە لە چۆڵەوانی ئاو تەقییەوە و 
\q2 ڕووباریش لە بیابان. 
\q1  
\v 7 سەراب دەبێتە گۆم و 
\q2 خاکی تینوو بە کانیاو. 
\q1 لە لانەی چەقەڵەکان، لە مۆڵگەکەیان، 
\q2 قامیش و زەلی لێ سەوز دەبێت. 
\b  
\q1  
\v 8 لەوێ ڕێڕەوێک و ڕێگایەک دەبێت، 
\q2 ڕێگای پیرۆزی پێ دەگوترێت. 
\q1 گڵاو پێیدا تێناپەڕێت، 
\q2 بەڵکو بۆ ئەوانەیە 
\q1 کە بە چاکە پێیدا دەڕۆن، 
\q2 گێلەکان پێدا ناڕۆن. 
\q1  
\v 9 شێر لەوێ نابێت، 
\q2 جانەوەری دڕندە بۆ ئەوێ سەرناکەوێت، 
\q2 لەوێ بەرچاو ناکەون. 
\q1 بەڵکو ئەوانەی کڕاونەتەوە پێیدا دەڕۆن، 
\q2  
\v 10 ئەوانەی یەزدان کڕیونیەتیەوە دەگەڕێنەوە، 
\q1 بە هاواری خۆشییەوە بۆ سییۆن دێن، 
\q2 شادییەکی هەتاهەتایی بەسەر سەریانەوە. 
\q1 خۆشی و شادی پێیان دەگەن و 
\q2 ناخۆشی و ئاخ هەڵکێشان هەڵدێن. 
\c 36  
\s1 سەنحێریب هەڕەشە لە ئۆرشەلیم دەکات 
\p  
\v 1 لە ساڵی چواردەیەمی حەزقیا پاشا، سەنحێریبی پاشای ئاشور هێرشی کردە سەر هەموو شارە قەڵابەندەکانی یەهودا و داگیری کردن.  
\v 2 ئیتر پاشای ئاشور لە لاخیشەوە فەرماندەی ناوچەکەی بە سوپایەکی گەورەوە بۆ حەزقیای پاشا نارد لە ئۆرشەلیم. کاتێک لەلای ئاوباری گۆمەکەی سەرەوە ڕاوەستا کە لەسەر ڕێگای شوێنی جلشۆرینەکەیە،  
\v 3 ئەلیاقیمی کوڕی حیلقیا سەرپەرشتیاری کۆشک و شەڤنای خامەی نهێنی\f + \fr 36:3 \ft ڕازپۆش.‏\f* و یۆئاحی تۆمارکار کوڕی ئاساف چوونە دەرەوە بۆ لای. 
\p  
\v 4 فەرماندەی ناوچەکە پێی گوتن: «بە حەزقیا بڵێن: 
\pm «”پاشای گەورە، پاشای ئاشور دەڵێت: تۆ پشتت بە چی بەستووە؟  
\v 5 تۆ دەڵێیت کە پلان و هێزت هەیە بۆ جەنگ، بەڵام ئەوە قسەی پووچە. ئێستاش پشتت بە کێ بەستووە تاکو لێم یاخی بیت؟  
\v 6 وا پشتت بە پاڵپشتی ئەو قامیشە شکاوەی میسر بەستووە، ئەوەی کە هەرکەسێک خۆی بەسەردا بچەمێنێتەوە لەپی دەستی بریندار دەبێت و کونی دەکات! فیرعەونی پاشای میسر ئاوایە بۆ هەموو ئەوانەی پشتی پێ دەبەستن.  
\v 7 ئەگەر پێشم بڵێیت: ’پشتمان بە یەزدانی پەروەردگارمان بەستووە،‘ ئایا ئەوە ئەو نەبوو کە حەزقیا نزرگەکانی سەر بەرزایی و قوربانگاکانی تێکدا و بە یەهودا و ئۆرشەلیمی گوت: ’لەبەردەم ئەم قوربانگایە کڕنۆش دەبەن‘؟ 
\pm  
\v 8 «”ئێستاش گرەو لەگەڵ پاشای ئاشوری گەورەم بکە، من دوو هەزار ئەسپت دەدەمێ، ئەگەر تۆ بتوانیت بۆ خۆت سوار لەسەریان دابنێیت!  
\v 9 ئیتر چۆن دەتوانیت تاکە ئەفسەرێک لە خزمەتکارە بچووکەکانی گەورەکەم ببەزێنیت، تەنانەت ئەگەر پشت بە میسریش ببەستیت بۆ گالیسکە و سوار؟  
\v 10 ئێستاش ئایا من بەبێ یەزدان هێرشم کردووەتە سەر ئەم خاکە هەتا وێرانی بکەم؟ یەزدان پێی فەرمووم: بەسەر ئەو خاکەدا بدە و وێرانی بکە.“» 
\p  
\v 11 ئینجا ئەلیاقیم و شەڤنا و یۆئاح بە فەرماندەی ناوچەکەیان گوت: «تکایە لەگەڵ خزمەتکارەکانت بە زمانی ئارامی قسە بکە، چونکە لێی تێدەگەین، بە عیبری قسەمان لەگەڵ مەکە لەبەرچاوی خەڵکەکەی سەر شووراکە.» 
\p  
\v 12 فەرماندەکەش گوتی: «ئایا گەورەم تەنها بۆ لای گەورەکەت و تۆی ناردووین هەتا ئەم قسانە بکەین؟ ئایا بۆ لای ئەو پیاوانەی سەر شووراکەی نەناردووین، بۆ ئەوەی پیسایی خۆیان بخۆن و میزی خۆیان بخۆنەوە لەگەڵتان؟» 
\p  
\v 13 ئینجا فەرماندەکە وەستا و بە دەنگێکی بەرز بە زمانی عیبری هاواری کرد و گوتی: «گوێ لە قسەی پاشای گەورە بگرن، پاشای ئاشور!  
\v 14 پاشا ئاوا دەڵێت: مەهێڵن حەزقیا فریوتان بدات، چونکە ناتوانێت ڕزگارتان بکات.  
\v 15 مەهێڵن حەزقیا واتان لێ بکات پشت بە یەزدان ببەستن و بڵێت: ”بێگومان یەزدان فریامان دەکەوێت و ئەم شارە ناداتە دەست پاشای ئاشور.“ 
\p  
\v 16 «گوێ لە حەزقیا مەگرن، چونکە پاشای ئاشور دەڵێت: ڕازی بن بە ملکەچبوون بۆ من، وەرنە دەرەوە بۆ لام، با هەرکەسە لە مێوەکەی خۆی و لە دار هەنجیرەکەی خۆی بخوات و ئاو لە ئەمباراوەکەی خۆی بخواتەوە،  
\v 17 هەتا ئەو کاتەی دێم و دەتانبەمە خاکێکی وەک خاکەکەی خۆتان، خاکی دانەوێڵە و شەرابی نوێ، خاکی نان و ڕەزەمێو. 
\p  
\v 18 «با حەزقیا فریوتان نەدات کە دەڵێت: ”یەزدان ڕزگارمان دەکات.“ ئایا خوداوەندی هیچ نەتەوەیەک توانی خاکەکەی خۆی لە دەست پاشای ئاشور ڕزگار بکات؟  
\v 19 کوان خوداوەندەکانی حەمات و ئەرپاد؟ کوان خوداوەندەکانی سفەرڤەیم؟ ئایا فریای سامیرە کەوتن لە دەستم؟  
\v 20 کام لە هەموو خوداوەندەکانی ئەو خاکانە توانی خاکەکەی خۆی لە دەستی من ڕزگار بکات؟ ئیتر چۆن یەزدان فریای ئۆرشەلیم دەکەوێت لە دەستی من؟» 
\p  
\v 21 بەڵام گەل بێدەنگ بوون و بە یەک وشەش وەڵامیان نەدایەوە، چونکە پاشا فەرمانی کردبوو: «وەڵامی نەدەنەوە.» 
\p  
\v 22 ئینجا ئەلیاقیمی کوڕی حیلقیای سەرپەرشتیاری کۆشک و شەڤنای خامەی نهێنی و یۆئاحی کوڕی ئاسافی تۆمارکار هاتنە لای حەزقیا و جلەکانیان دادڕی بوو، قسەکانی فەرماندەی ناوچەکەیان پێی ڕاگەیاند. 
\c 37  
\s1 پێشبینی ڕزگاربوونی ئۆرشەلیم 
\p  
\v 1 کاتێک حەزقیای پاشا گوێی لەمە بوو، جلەکانی لەبەر خۆیدا دادڕی و بەرگی لە گوش دروستکراوی پۆشی و چووە ناو پەرستگای یەزدان  
\v 2 ئینجا ئەلیاقیمی سەرپەرشتیاری کۆشک و شەڤنای خامەی نهێنی و کاهینانی باڵا کە هەموویان جلوبەرگی گوشیان پۆشیبوو ناردیانە لای ئیشایا پێغەمبەری کوڕی ئامۆچ،  
\v 3 پێیان گوت: «حەزقیا دەڵێت، ئەمڕۆ ڕۆژی تەنگانە و سەرزەنشت و سووکایەتییە، وەک کاتێک کە کۆرپە لە سکی دایکیدا ئامادەیە بێتە دەرەوە، بەڵام دایکەکەی هێزی پاڵدانی نییە بۆ ئەوەی منداڵەکەی ببێت.  
\v 4 بەڵکو یەزدانی پەروەردگارت گوێی لە قسەکانی فەرماندەی ناوچەکە بێت، کە گەورەکەی، پاشای ئاشور ناردی، تاکو سووکایەتی بە خودای زیندوو بکات. با یەزدانی پەروەردگارت سەرزەنشتی بکات لەسەر ئەو قسانەی یەزدانی پەروەردگارت گوێی لێبوو. ئیتر نوێژ بکە لە پێناوی ئەوانەی ماونەتەوە.» 
\p  
\v 5 کاتێک خزمەتکارەکانی حەزقیای پاشا هاتنە لای ئیشایا،  
\v 6 ئیشایاش پێی گوتن: «بە گەورەکەتان بڵێن: ”یەزدان ئەمە دەفەرموێت: لەو قسانە مەترسە کە گوێت لێیان بوو، کە خزمەتکارەکانی پاشای ئاشور کفریان بەرامبەر بە من کرد.  
\v 7 گوێ بگرە! من وای لێ دەکەم هەواڵێک ببیستێت و بگەڕێتەوە خاکەکەی خۆی، لەوێش بە شمشێر لەناوی دەبەم.“» 
\p  
\v 8 کاتێک فەرماندەی ناوچەکە بیستییەوە کە پاشای ئاشور لاخیشی بەجێهێشتووە، کشایەوە، بینی پاشای ئاشور لە دژی لیڤنا دەجەنگێت. 
\p  
\v 9 سەنحێریب دەربارەی تیرهاقای پاشای کوش هەواڵی پێگەیشت کە لە میسرەوە لە دژی ئەو سوپای جوڵاندووە. کاتێک گوێ لەمە بوو، نێردراوی بۆ لای حەزقیا نارد و گوتی:  
\v 10 «بە حەزقیای پاشای یەهودا بڵێن: ڕێگا مەدە خوداوەندەکەت ئەوەی کە پشتت پێی بەستووە فریوت بدات بەوەی کە دەڵێت: ”ئۆرشەلیم ناکەوێتە دەست پاشای ئاشور.“  
\v 11 بە دڵنیاییەوە تۆ خۆت بیستووتە کە پاشاکانی ئاشور چییان بە هەموو خاکەکان کردووە، بە تەواوی لەناویانبردوون. ئایا تۆ دەرباز دەبیت؟  
\v 12 ئایا خوداوەندەکانی ئەو نەتەوانە فریای ئەوان کەوتن، ئەو نەتەوانەی باوباپیرانم لەناویانبردن، خوداوەندەکانی گۆزان و حەڕان و ڕەچەف و نەوەی عەدەن ئەوەی لە تێل‌ئەسار بوو؟  
\v 13 کوان پاشای حەمات و پاشای ئەرپاد و پاشای شارەکانی سفەرڤەیم، هێنەع و عیڤا؟» 
\s1 نوێژی حەزقیا 
\p  
\v 14 حەزقیا نامەکەی لە دەستی نێردراوەکان وەرگرت و خوێندییەوە. ئینجا سەرکەوت بۆ پەرستگای یەزدان، لەبەردەم یەزدان ڕایخست.  
\v 15 حەزقیا نوێژی بۆ یەزدان کرد و گوتی:  
\v 16 «ئەی یەزدانی سوپاسالار، خودای ئیسرائیل، تۆ لەسەر تەخت لەنێوان کەڕوبەکان دانیشتوویت\f + \fr 37:16 \ft لەنێوان کەڕوبەکان: جووتێک پەیکەری بوونەوەری ئاسمانی باڵدارە، لە شێوەی ئاژەڵ و مرۆڤدایە، بۆ پارێزگاریکردن لە سندوقی پەیمان دانرابوو، بڕوانە \xt دەرچوون 25‏:22 و عیبرانییەکان 9‏:5‏\ft ‏.‏\f*، تۆ بە تەنها خودای هەموو شانشینەکانی زەویت، تۆ ئاسمان و زەویت دروستکرد.  
\v 17 ئەی یەزدان، گوێ شل بکە و ببیستە! ئەی یەزدان، چاوەکانت بکەرەوە و ببینە، گوێ لە تەواوی پەیامەکەی سەنحێریب بگرە کە ناردوونی، هەتا سووکایەتی بە خودای زیندوو بکات. 
\p  
\v 18 «ئەی یەزدان، ئەوە ڕاستە کە پاشاکانی ئاشور هەموو ئەو نەتەوانە و خاکەکانیان وێران کردووە.  
\v 19 خوداوەندەکانیشیان لێ فڕێدانە ناو ئاگرەوە و لەناویانبردن، چونکە ئەوانە خودا نەبوون، بەڵکو تەنها دار و بەرد و دەستکردی مرۆڤ بوون.  
\v 20 ئێستاش ئەی یەزدانی پەروەردگارمان، لە دەستی ئەو ڕزگارمان بکە، تاکو هەموو شانشینەکانی زەوی بزانن کە بە تەنها تۆ، ئەی یەزدان، خودایت.» 
\s1 ڕووخاندنی پاشایەتی سەنحێریب 
\p  
\v 21 ئینجا ئیشایای کوڕی ئامۆچ ناردی بۆ لای حەزقیا و گوتی: «یەزدانی پەروەردگاری ئیسرائیل دەفەرموێت: لەبەر ئەوەی نوێژت بۆ کردم سەبارەت بە سەنحێریبی پاشای ئاشور،  
\v 22 ئەمە ئەو فەرمایشتەیە کە یەزدان لەسەر ئەو فەرموویەتی: 
\q1 «سییۆنی کچە\f + \fr 37:22 \ft کچی شاری پایتەخت واتا هەموو گەلی ئەو وڵاتە.‏\f* پاکیزە\f + \fr 37:22 \ft پاکیزە: مەبەست لە وڵاتێکە کە داگیر نەکراوە.‏\f*، 
\q2 بێزت لێ دەکاتەوە و گاڵتەت پێ دەکات. 
\q1 ئۆرشەلیمی کچ، 
\q2 کە تۆ هەڵدێیت پێت پێدەکەنێت. 
\q1  
\v 23 سووکایەتی و کفرت بە کێ کرد؟ 
\q2 دەنگت بەسەر کێدا بەرز کردەوە و 
\q1 چاوەکانت بە فیزەوە\f + \fr 37:23 \ft عیبری: بۆ باڵا.‏\f* هەڵدەبڕیت؟ 
\q2 لەسەر خودا پیرۆزەکەی ئیسرائیل! 
\q1  
\v 24 لەسەر دەستی خزمەتکارەکانت 
\q2 سووکایەتیت بە پەروەردگار کرد. 
\q1 هەروەها دەڵێیت: 
\q2 ”بە زۆری گالیسکەکانمەوە 
\q1 من سەرکەوتمە سەر بەرزایی چیاکان، 
\q2 هەتا ئەوپەڕی لوبنان. 
\q1 بەرزترین دار ئورز و 
\q2 باشترین دار سنەوبەرم بڕییەوە. 
\q1 چوومە ناو دوورترین بەرزاییەکانی، 
\q2 ناو چڕی دارستانەکانی. 
\q1  
\v 25 من لە خاکی بێگانەکان چەندین بیرم لێدا و 
\q2 ئاوم لێیان خواردەوە. 
\q1 هەموو لقەکانی نیلم، 
\q2 بە بنی پێیەکانم کوێر کردەوە.“ 
\b  
\q1  
\v 26 «ئەی گوێت لێ نەبووە؟ 
\q2 من لەمێژە دیاریم کردووە، 
\q1 لە ڕۆژگاری کۆنەوە نەخشەم کێشاوە، 
\q2 ئێستاش دەیهێنمە دی، 
\q1 کە تۆ بێیت شارە قەڵابەندەکان بڕووخێنیت، 
\q2 هەتا ببنە وێرانەیەک لە کەڵەکە بەرد. 
\q1  
\v 27 دانیشتووانەکانیان بێ دەسەڵاتن، 
\q2 ڕەنگ زەرد و شەرمەزار بوون، 
\q1 بوونە گیای کێڵگە، 
\q2 ڕووەکی سەوز، 
\q1 گژوگیای سەربان، 
\q2 هەڵبزڕکاو بەر لەوەی گەشە بکات. 
\b  
\q1  
\v 28 «بەڵام من هەستان و دانیشتنت و 
\q2 کاتی هاتوچۆکەت دەزانم، 
\q2 هەروەها هەڵچوونت لە دژی من. 
\q1  
\v 29 لەبەر ئەوەی هەڵچوونت لێم و خۆبەزلزانیت 
\q2 گەیشتنە گوێم، 
\q1 قولاپەکەم دەخەمە لووتت و 
\q2 لغاوەکەم لە لێوەکانت و 
\q1 بەو ڕێگایەدا دەتنێرمەوە 
\q2 کە لێوەی هاتوویت. 
\p  
\v 30 «ئەی حەزقیا، ئەمەش نیشانەیە بۆ تۆ: 
\q1 «ئەم ساڵ دەغڵی خۆڕسک دەخۆن، 
\q2 ساڵی دووەم ئەوەی لەوەوە بەردەگرێت، 
\q1 بەڵام لە ساڵی سێیەم دەکێڵن و دەدورنەوە و 
\q2 مێو دەچێنن و لە بەرەکەی دەخۆن. 
\q1  
\v 31 ئەوانەی لە بنەماڵەی یەهودا دەرباز بوون و ماونەتەوە، 
\q2 جارێکی دیکە لە ژێرەوە ڕەگ دادەکوتن و لە سەرەوەش بەر دەگرن. 
\q1  
\v 32 لە ئۆرشەلیمەوە پاشماوەیەک بڵاو دەبنەوە و 
\q2 دەربازبووانیش لە کێوی سییۆنەوە، 
\q1 دڵگەرمی یەزدانی سوپاسالار 
\q2 ئەمە دەکات. 
\p  
\v 33 «لەبەر ئەوە یەزدان لەبارەی پاشای ئاشورەوە ئەمە دەفەرموێت: 
\q1 «نایەتە ناو ئەم شارەوە و 
\q2 تیرێکیش بۆ ئەوێ ناهاوێژێت. 
\q1 بە قەڵغانیشەوە لێی نایەتە پێشەوە و 
\q2 سەنگەریشی لێ ناگرێت. 
\q1  
\v 34 نایەتە ناو ئەم شارەوە، 
\q2 بەو ڕێگایەدا دەگەڕێتەوە کە پێیدا هاتووە.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\q1  
\v 35 «بەرگری لەم شارە دەکەم و دەیپارێزم، 
\q2 لە پێناوی خۆم و لە پێناوی داودی بەندەم.» 
\p  
\v 36 ئیتر فریشتەی یەزدان هات و سەد و هەشتا و پێنج هەزار کەسی لەناو ئۆردوگای ئاشور کوشت، بەیانی زوو کە هەستان بینییان هەموویان لاشەی مردوون.  
\v 37 ئینجا سەنحێریبی پاشای ئاشور دەستی کێشایەوە و ڕۆیشت، گەڕایەوە و لە نەینەوا مایەوە. 
\p  
\v 38 لەدوای ئەوە، کاتێک سەنحێریب لە پەرستگای نیسرۆخی خوداوەندی کڕنۆشی بردبوو، هەردوو کوڕەکەی، ئەدرەمەلەک و سەرئەچەر، بە شمشێر لێیاندا و ڕایانکرد بۆ خاکی ئارارات. ئیتر ئێسەرحەدۆنی کوڕی لەدوای خۆی بوو بە پاشا. 
\c 38  
\s1 نەخۆشی حەزقیا 
\p  
\v 1 لەو ڕۆژانەی\f + \fr 38:1 \ft مەبەست لەو ڕۆژانەیە پێش ڕووداوەکانی بەشی 36.‏\f* حەزقیا نەخۆش کەوت، لە سەرە مەرگ بوو، ئیشایا پێغەمبەر کوڕی ئامۆچ هات بۆ لای و پێی گوت: «یەزدان ئەمە دەفەرموێت: وەسیەت بۆ ماڵەکەت بکە، چونکە دەمریت و ناژیت.» 
\p  
\v 2 حەزقیا ڕووی لە دیوارەکە کرد و نوێژی بۆ یەزدان کرد،  
\v 3 گوتی: «ئای یەزدان، ئەوەت لەیاد بێت کە چۆن بە دڵسۆزی و پڕ بە دڵ دۆستایەتیم کردیت، ئەوەی پێت باش بوو کردم.» ئینجا حەزقیا بەکوڵ گریا. 
\p  
\v 4 جا ئیشایا فەرمایشتی یەزدانی بۆ هات، فەرمووی:  
\v 5 «بڕۆ و بە حەزقیا بڵێ: ”یەزدان، پەروەردگاری داودی باپیرە گەورەت ئەمە دەفەرموێت: گوێم لە پاڕانەوەکەت بوو و فرمێسکەکانتم بینی، پازدە ساڵ لە تەمەنت زیاد دەکەم و  
\v 6 فریای خۆت و ئەم شارەش دەکەوم، بەرگری لەم شارە دەکەم لە دەستی پاشای ئاشور. 
\p  
\v 7 «”ئەمەش نیشانە بێت بۆت لەلایەن یەزدانەوە، کە یەزدان ئەم کارە دەکات کە بەڵێنی دا:  
\v 8 ئەوەتا سێبەر دەگەڕێنمەوە بەو پلانەی پێی هاتووەتە خوارەوە، بە پلەکانی ئاحاز بە خۆر، دە پلە بەرەو دواوە.“» جا خۆر دە پلە گەڕایەوە بەو پلانەی پێی هاتبووە خوار. 
\b  
\p  
\v 9 نووسراوی حەزقیای پاشای یەهودا، دوای ئەوەی نەخۆش کەوت و لە نەخۆشییەکەی چاک بووەوە: 
\q1  
\v 10 گوتم: «ئایا لە هەڕەتی گەنجیمدا 
\q2 من دەچم بۆ جیهانی مردووان، 
\q2 چونکە یەزدان لە پاشماوەی ژیانم بێبەشی کردووم؟» 
\q1  
\v 11 گوتم: «یەزدان نابینم 
\q2 لە خاکی زیندوواندا، 
\q1 لەمەودوا چیتر سەیری ئادەمیزاد ناکەم 
\q2 لەسەر ڕووی زەوی. 
\q1  
\v 12 خانووم هەڵتەکا و لەلام ڕۆیشت 
\q2 وەک خێوەتی شوانان، 
\q1 وەکو جۆڵا ژیانی خۆمم پێچایەوە و 
\q2 لە تەونەکەمدا بڕیمەوە، 
\q2 شەو و ڕۆژ تۆ لەناوم دەبەیت. 
\q1  
\v 13 بە ئارامییەوە هەتا بەرەبەیان چاوەڕێ دەکەم، 
\q2 بەڵام وەک شێر ئێسکم ورد دەکات، 
\q2 شەو و ڕۆژ تۆ لەناوم دەبەیت. 
\q1  
\v 14 وەک پەڕەسێلکە و ڕیشۆڵە جیکە جیک دەکەم، 
\q2 وەکو کۆتر دەگمێنم، 
\q1 چاوم شل بوو هێندە لە ئاسمان بڕوانم. 
\q2 وەڕس بووم، ئەی پەروەردگار، بە هانام وەرە!» 
\b  
\q1  
\v 15 ئیتر چی بڵێم؟ 
\q2 ئەو پێی فەرمووم و ئەو خۆی کردی. 
\q1 بە بێفیزی بە هەموو ساڵانمدا دەڕۆم 
\q2 لەبەر تاڵاوی گیانم. 
\q1  
\v 16 ئەی پەروەردگار، مرۆڤ لەسەر ئەمانە دەژین، 
\q2 ژیانی ڕۆحیم لە هەموو ئەمانەدایە. 
\q1 تۆ منت چاککردەوە و 
\q2 ژیانت پێ بەخشیم. 
\q1  
\v 17 بێگومان سوودی بۆ من هەبوو کە 
\q2 تاڵی لەسەر تاڵیم چێشت. 
\q1 لە خۆشەویستیدا تۆ گیانی منت 
\q2 لە تەڵەی لەناوچوون ڕزگار کرد، 
\q1 چونکە هەموو گوناهەکانی منت 
\q2 فڕێدایە پشت خۆتەوە. 
\q1  
\v 18 جیهانی مردووان سوپاست ناکات و 
\q2 مردووانیش ستایشت ناکەن، 
\q1 هەروەها ئەوانەی لە گۆڕ دەنرێن 
\q2 هیوایان بە دڵسۆزی تۆ نییە. 
\q1  
\v 19 زیندووان، تەنها زیندووان سوپاست دەکەن، 
\q2 باوکان دڵسۆزی تۆ 
\q2 بە منداڵەکانیان دەناسێنن. 
\b  
\q1  
\v 20 یەزدان ڕزگارم دەکات، 
\q2 هەموو ڕۆژانی ژیانمان 
\q1 مۆسیقا دەژەنین 
\q2 لە پەرستگای یەزدان. 
\p  
\v 21 ئینجا ئیشایا گوتی: «با هەویری هەنجیر هەڵبگرن و بیخەنە سەر دوومەڵەکە، چاک دەبێتەوە.» 
\p  
\v 22 حەزقیاش گوتبووی: «نیشانە چییە، کە دەچمە پەرستگای یەزدان؟» 
\c 39  
\s1 نێردراوانی بابل 
\p  
\v 1 لەو کاتەدا مەرۆدەخ بەلەدانی کوڕی بەلەدانی پاشای بابل نامە و دیاری بۆ حەزقیا نارد، چونکە بیستی کە نەخۆش کەوتووە و چاک بووەتەوە.  
\v 2 جا حەزقیا دڵخۆش بوو بە هاتنیان و هەموو ماڵ و سامانەکەی پیشان دان، لە زێڕ و زیو و بۆن و زەیتی چاک و جبەخانەکەی و ئەو شتانەی کە لە گەنجینەکانی بوون. هیچ شتێک لە کۆشکەکەی و لە شانشینەکەی نەمایەوە کە حەزقیا پیشانیان نەدات. 
\p  
\v 3 ئینجا ئیشایا پێغەمبەر هاتە لای حەزقیای پاشا و لێی پرسی: «ئەو پیاوانە چییان گوت و لەکوێوە هاتوونەتە لات؟» 
\p حەزقیاش وەڵامی دایەوە: «لە خاکێکی دوورەوە، لە بابلەوە هاتوون.» 
\p  
\v 4 ئیشایا لێی پرسی: «چییان لە کۆشکەکەت بینی؟» 
\p حەزقیاش وەڵامی دایەوە: «هەموو شتەکانی ناو کۆشکەکەمیان بینی، لە گەنجینەکانم هیچ نەمایەوە کە پیشانیان نەدەم.» 
\p  
\v 5 ئینجا ئیشایا بە حەزقیای گوت: «گوێ لە پەیامی یەزدانی سوپاسالار بگرە،  
\v 6 یەزدان دەفەرموێت: بێگومان سەردەمێک دێت هەموو ئەوەی لە کۆشکەکەتدایە و هەموو ئەوەی باوباپیرانت هەتا ئەمڕۆ پاشەکەوتیان کردووە بۆ بابل بار دەکرێن، هیچ شتێک بەجێناهێڵدرێت.  
\v 7 لە نەوەکانیشت، ئەوانەی لە تۆ دەبن، ئەوانەی بۆت لەدایک دەبن، لێیان دەبردرێت و لە کۆشکی پاشای بابل دەبنە کاربەدەستی خەسێنراو.» 
\p  
\v 8 حەزقیا وەڵامی ئیشایای دایەوە و گوتی: «ئەو پەیامەی یەزدان کە بە منت دا، پەیامێکی باشە،» چونکە لەبیری خۆیدا گوتی\f + \fr 39:8 \ft بڕوانە \xt دووەم پاشایان 20‏:19‏\ft ‏.‏\f*: «واتا ئاشتی و ئاسوودەیی لە ماوەی پاشایەتی خۆمدا دەبێت.» 
\c 40  
\s1 حەسانەوە بۆ گەلی خودا 
\q1  
\v 1 دڵنەوایی گەلەکەم بکەن، دڵنەواییان بکەن، 
\q2 خوداتان دەفەرموێت، 
\q1  
\v 2 بە دڵنەرمی لەگەڵ ئۆرشەلیم بدوێن، 
\q2 پێی ڕابگەیەنن 
\q1 کە ڕەنجکێشانەکەی تەواو بووە، 
\q2 کە تاوانەکەی بەخشراوە، 
\q1 چونکە بە دەستی یەزدان 
\q2 لەسەر گوناهەکانی دووقاتی وەرگرتەوە. 
\b  
\q1  
\v 3 کەسێک هاوار دەکات و دەڵێت: 
\q1 «لە چۆڵەوانی ڕێگا بۆ هاتنی یەزدان ئامادە بکەن، 
\q2 لە بیابان شاڕێگا بۆ خودامان ڕێکبخەن. 
\q1  
\v 4 هەموو دۆڵێک هەڵدەچێت و 
\q2 هەموو چیا و گردێک ڕۆدەچێت. 
\q1 خوار ڕاست دەبێتەوە، 
\q2 هەورازیش دەبێت بە دەشت، 
\q1  
\v 5 شکۆمەندی یەزدان دەردەکەوێت و 
\q2 هەموو مرۆڤایەتی پێکەوە دەیبینن، 
\q4 چونکە دەمی یەزدان فەرمووی.» 
\b  
\q1  
\v 6 دەنگێک دەڵێت: «بانگەواز بکە!» 
\q2 منیش گوتم: «بانگەوازی چی بکەم؟» 
\b  
\q1 «هەموو مرۆڤێک وەک گژوگیا وایە و 
\q2 هەموو دڵسۆزییەکەی وەک گوڵی کێوی وایە. 
\q1  
\v 7 گژوگیا وشک دەبێت و گوڵ هەڵدەوەرێ، 
\q2 چونکە هەناسەی یەزدان هەڵیکردە سەری، 
\q2 بێگومان گەل وەکو گژوگیان. 
\q1  
\v 8 گژوگیا وشک دەبێت و گوڵ هەڵدەوەرێ، 
\q2 بەڵام پەیامی خودامان بۆ هەتاهەتایە چەسپاو دەبێت.» 
\b  
\q1  
\v 9 ئەی مزگێنیدەر بۆ سییۆن، 
\q2 بڕۆ سەر کێوێکی بەرز، 
\q1 بە هێزەوە دەنگت بەرز بکەرەوە، 
\q2 بەرزی بکەرەوە، مەترسە. 
\q1 ئەی مزگێنیدەر بۆ ئۆرشەلیم، 
\q2 بە شارۆچکەکانی یەهودا بڵێ: 
\q2 «ئەوەتا خوداتان!» 
\q1  
\v 10 ئەوەتا یەزدانی باڵادەست بە هێزەوە دێت، 
\q2 بە بازووی فەرمانڕەوایەتی بۆ دەکات. 
\q1 ئەوەتا پاداشتەکەی لەگەڵیدایە و 
\q2 خەڵاتەکەی لەبەردەمی. 
\q1  
\v 11 وەک شوان مێگەلەکەی دەلەوەڕێنێت: 
\q2 بە بازووی خۆی بەرخەکان کۆدەکاتەوە و 
\q1 بە باوەش هەڵیاندەگرێت، 
\q2 بە نەرمی شیردەرەکان بە پێش خۆی دەدات. 
\b  
\q1  
\v 12 کێ بە چنگ ئاوی پێواوە و 
\q2 بە بست ئاسمان؟ 
\q1 کێ خۆڵی زەوی بە قزناغ پێواوە؟ 
\q2 کێ چیاکانی بە قەپان کێشاوە و 
\q2 گردەکانیش بە تەرازوو؟ 
\q1  
\v 13 کێ لەبیری یەزدان تێگەیشتووە 
\q2 یاخود وەک ڕاوێژکار فێری کردووە؟ 
\q1  
\v 14 یەزدان ڕاوێژی بە کێ کرد و تێیگەیاند، 
\q2 ڕێگای دادپەروەری فێرکرد؟ 
\q1 کێ زانینی فێرکرد و 
\q2 ڕێگای تێگەیشتنی پێ ناساند؟ 
\b  
\q1  
\v 15 ئەوەتا نەتەوەکان وەک دڵۆپێک ئاوی ناو سەتڵ و 
\q2 بە تۆزی تەرازوو دادەنرێن. 
\q2 ئەوەتا دوورگەکان وەک پووش هەڵدەگرێت. 
\q1  
\v 16 داری لوبنان بەس نییە بۆ سووتەمەنی قوربانگا و 
\q2 ئاژەڵەکانی بەس نین بۆ قوربانی سووتاندن. 
\q1  
\v 17 هەموو نەتەوەکان وەک هیچن لەبەردەمی، 
\q2 لەلای ئەو بە نەبوو و پووچ دادەنرێن. 
\b  
\q1  
\v 18 جا خودا بە چی هاوشێوە دەکەن، 
\q2 چ وێنەیەک بەو یەکسان دەکەن؟ 
\q1  
\v 19 پەیکەرێک کە وەستا دایدەڕێژێت، 
\q2 زێڕنگەریش بە زێڕ ڕووکەشی دەکات، 
\q2 زنجیری زیویش زیوگەر. 
\q1  
\v 20 دەستکورتیش بۆ پێشکەشکردنی پیتاک 
\q2 دارێکی ساغ هەڵدەبژێرێت کە نەڕزیبێت. 
\q1 داوای وەستایەکی شارەزا دەکات 
\q2 بۆ ئەوەی پەیکەرێکی نەلەقیوی بۆ دابنێت. 
\b  
\q1  
\v 21 ئایا نازانن؟ 
\q2 ئایا نابیستن؟ 
\q1 ئەی لە سەرەتاوە پێتان ڕانەگەیەنراوە؟ 
\q2 ئایا لەو کاتەوەی زەوی بەدیهێنراوە تێنەگەیشتوون کە 
\q1  
\v 22 ئەو لەسەر ئاسۆی زەوی دادەنیشێت و 
\q2 دانیشتووانەکەی وەک پێکوڕە وان؟ 
\q1 ئەو ئاسمان وەک پڵاس بڵاو دەکاتەوە، 
\q2 وەک ڕەشماڵ هەڵیدەدات بۆ نیشتەجێبوون. 
\q1  
\v 23 ئەو مەزنەکان وەک نەبوو لێدەکات و 
\q2 حوکمڕانانی جیهان دەکات بە هیچ. 
\q1  
\v 24 هەر ئەوەندەی نێژران، چێنران و 
\q2 قەدیان لە زەوی ڕەگی داکوتا، 
\q1 فووی لێکردن و وشک هەڵگەڕان، 
\q2 ڕەشەبا وەک پووش هەڵیاندەگرێت. 
\b  
\q1  
\v 25 خودای پیرۆز دەفەرموێت: «لەگەڵ کێ هاوشێوەم دەکەن؟ 
\q2 من هاوتای کێم؟ 
\q1  
\v 26 چاوتان بۆ بەرزی هەڵبڕن و 
\q2 ببینن کێ ئەمەی بەدی هێناوە، 
\q1 کێ ئەستێرەکانی بە ژمارە دەردەهێنێت و 
\q2 ناو لە هەموویان دەنێت؟ 
\q1 لەبەر زۆری هێز و توندی توانای 
\q2 هیچ کامیان ون نابێت. 
\b  
\q1  
\v 27 «ئەی یاقوب، بۆ دەڵێیت، 
\q2 ئەی ئیسرائیل، بۆ سکاڵا دەکەیت: 
\q1 ”ڕێگای من لە یەزدان شاردرایەوە، 
\q2 دادی من لە خودام تێپەڕی“؟ 
\q1  
\v 28 ئایا نەتزانی، 
\q2 یان نەتبیست؟ 
\q1 یەزدان خودای هەتاهەتاییە، 
\q2 بەدیهێنەری ئەمسەر و ئەوسەری زەوی. 
\q1 نە ماندوو و نە شەکەت دەبێت، 
\q2 کەس پەی بە تێگەیشتنی ئەو نابات. 
\q1  
\v 29 توانا بە ماندوو دەدات و 
\q2 بۆ داهێزراویش هێز زۆر دەکات. 
\q1  
\v 30 گەنجەکان ماندوو و شەکەت دەبن، 
\q2 لاوەکان پێیان هەڵدەکەوێت و دەکەون، 
\q1  
\v 31 بەڵام ئەوانەی چاوەڕوانی یەزدانن، 
\q2 هێزیان نوێ دەبێتەوە، 
\q1 وەک هەڵۆ لە شەقەی باڵ دەدەن، 
\q2 ڕادەکەن و شەکەت نابن، 
\q2 دەڕۆن و ماندوو نابن. 
\c 41  
\s1 یارمەتیدەری ئیسرائیل 
\q1  
\v 1 «ئەی خەڵکی دوورگەکان لەبەردەمم بێدەنگ بن! 
\q2 با نەتەوەکان هێزیان نوێ بکەنەوە! 
\q1 با نزیک بنەوە ئینجا قسە بکەن، 
\q2 با پێکەوە بچینە دادگاییکردن. 
\b  
\q1  
\v 2 «کێ لە ڕۆژهەڵاتەوە کەسە سەرکەوتووەکەی هەستاندووە، 
\q2 ئەوەی بە ڕاستودروستی بانگی کرد بۆ خزمەتەکەی؟ 
\q1 نەتەوەکانی دەداتە پێشی، 
\q2 پاشایان ژێردەستەی دەکات. 
\q1 بە شمشێرەکەی وەک خۆڵیان لێ دەکات، 
\q2 بە کەوانەکەی وەک سەرکۆزەری بەباکراو. 
\q1  
\v 3 ڕاویان دەنێت، بە سەلامەتی تێدەپەڕێت، 
\q2 بە ڕێگایەکدا کە پێیەکانی پێیدا نەڕۆیشتوون. 
\q1  
\v 4 کێ کردوویەتی و کێ ئەنجامی داوە، 
\q2 لە سەرەتاوە بانگی نەوەکانی کردووە؟ 
\q1 من یەزدانم، 
\q2 لە سەرەتاوە هەتا کۆتایی، من هەر ئەوم.» 
\b  
\q1  
\v 5 دوورگەکان تەماشایان کردووە و دەترسن، 
\q2 هەر چوار لای زەوی دەلەرزن، 
\q1 نزیک بوونەوە و دێن، 
\q2  
\v 6 هەریەکە و هاوکاری برادەرەکەی دەکات، 
\q2 بە براکەی دەڵێت: «ورەت بەرز بێت!» 
\q1  
\v 7 دارتاش زێڕنگەر هاندەدات، 
\q2 ئەوەی بە چەکوش لووس دەکات 
\q2 ئاسنگەر هاندەدات لە دەستگاکەی بکوتێت، 
\q1 بە جۆشکردن دەڵێت: «باشە.» 
\q2 بە بزمارەکان توندی دەکات هەتا نەلەقێت. 
\b  
\q1  
\v 8 «بەڵام تۆ ئەی ئیسرائیلی بەندەم، 
\q2 ئەی یاقوب کە هەڵمبژاردووە، 
\q2 توخمی ئیبراهیمی خۆشەویستم، 
\q1  
\v 9 ئەوەی لەوپەڕی زەوییەوە تۆم گرت، 
\q2 لە دوورترین گۆشەیەوە بانگم کردیت و 
\q1 بە تۆم گوت: ”تۆ بەندەی منیت،“ 
\q2 تۆم هەڵبژاردووە و ڕەتم نەکردوویتەوە. 
\q1  
\v 10 مەترسە، چونکە لەگەڵتدام، 
\q2 مەپەشۆکێ، چونکە من خودای تۆم. 
\q1 بەهێزت دەکەم و یارمەتیت دەدەم، 
\q2 بە دەستی ڕاستی دادپەروەریم پشتیوانیت دەکەم. 
\b  
\q1  
\v 11 «ئەوەتا شەرمەزار و ڕیسوا دەبن 
\q2 هەموو ئەوانەی لە تۆ تووڕەن، 
\q1 وەک هیچیان لێدێت و لەناودەچن 
\q2 ئەوانەی دژایەتیت دەکەن. 
\q1  
\v 12 بەدوایدا دەگەڕێیت و نایانبینیتەوە 
\q2 ئەوانەی ناکۆکن لەگەڵت. 
\q1 ئەوانەی لە دژت دەجەنگن 
\q2 وەک هیچ و وەک نەبوو دەبن، 
\q1  
\v 13 چونکە من یەزدانم، خودای تۆ، 
\q2 ئەوەی دەستی ڕاستی گرتوویت، 
\q1 ئەوەی پێت دەڵێت، 
\q2 مەترسە، من یارمەتیت دەدەم. 
\q1  
\v 14 مەترسە ئەی یاقوبی کرم، 
\q2 ئەی ئیسرائیلی بچووک، 
\q1 من یارمەتیت دەدەم.» ئەوە فەرمایشتی یەزدانە، 
\q2 ئەوەی دەتکڕێتەوە، پیرۆزەکەی ئیسرائیل. 
\q1  
\v 15 «ئەوەتا دەتکەمە جەنجەڕێکی 
\q2 تیژی نوێی دداندار. 
\q1 چیاکان دەکوتییەوە و وردوخاشیان دەکەیت، 
\q2 گردەکان وەک کا لێ دەکەیت. 
\q1  
\v 16 شەنیان دەکەیت و با هەڵیاندەگرێت، 
\q2 ڕەشەبا پەرتوبڵاویان دەکات، 
\q1 بەڵام تۆ بە یەزدان دڵخۆش دەبیت، 
\q2 شانازی بە خودا پیرۆزەکەی ئیسرائیل دەکەیت. 
\b  
\q1  
\v 17 «کڵۆڵ و هەژاران بەدوای ئاودا دەگەڕێن و نییە، 
\q2 لە تینووێتییان زمانیان وشک بوو. 
\q1 بەڵام من یەزدانم بە دەنگیانەوە دەچم، 
\q2 خودای ئیسرائیلم بەجێیان ناهێڵم. 
\q1  
\v 18 ڕووباری ڕۆیشتوو لە گردۆڵکەکان دەردەهێنم، 
\q2 کانیاو لەناوەندی دۆڵەکانیش هەڵدەقوڵێنم. 
\q1 چۆڵەوانی دەکەم بە گۆلاو، 
\q2 زەوی وشک دەکەمە سەرچاوەی ئاو. 
\q1  
\v 19 داری ئورز و ئەکاسیا\f + \fr 41:19 \ft داری شەتیم.‏\f* و مۆرد\f + \fr 41:19 \ft مۆرد: دارێکە گەڵاکانی بەبریقە و سەوزێکی تۆخە، گوڵی سپی دەگرێت و بۆنی خۆشە، لە بێت‌لەحم و حەبرۆن هەیە. ئەو ناوەی ئێستا لە ڕۆژهەڵات بەکاریدەهێنن بۆی (ئاس)ـە.‏\f* و زەیتوون 
\q2 لە چۆڵەوانی دەڕوێنم، 
\q1 داری سنەوبەر و کاژ و سەروو پێکەوە 
\q2 لە بیابان دادەنێم، 
\q1  
\v 20 بۆ ئەوەی پێکەوە ببینن و بزانن و 
\q2 سەرنج بدەن و تێبگەن 
\q1 کە دەستی یەزدان ئەمەی کردووە و 
\q2 خودا پیرۆزەکەی ئیسرائیل بەدییهێناوە.» 
\b  
\q1  
\v 21 یەزدان دەفەرموێت: «بەرگری لە خۆتان بکەن.» 
\q2 پاشای یاقوب دەفەرموێت: «بەڵگەکانتان بخەنە بەردەستم. 
\q1  
\v 22 بتەکانتان بهێنن و با پێمان ڕابگەیەنن 
\q2 ئەوەی ڕوودەدات. 
\q1 ئەوانەی ڕابردوو چین، پێمان ڕابگەیەنن، 
\q2 با مێشکمان بخەینە سەری و 
\q2 بزانین کۆتاییەکەیان چییە. 
\q1 یان داهاتوومان پێ بڵێن، 
\q2  
\v 23 ئەوانەی لە داهاتوودا دێن، ڕایبگەیەنن 
\q2 بۆ ئەوەی بزانین ئێوە خوداوەندەکانن، 
\q1 هەرچی بێت بیکەن، چاکە یان خراپە، 
\q2 هەتا پێکەوە سەرسام بین و ببینین. 
\q1  
\v 24 بەڵام ئێوە هیچن و 
\q2 کارەکانتان لە هیچ کەمترن، 
\q2 قێزەونە ئەوەی ئێوە هەڵدەبژێرێت. 
\b  
\q1  
\v 25 «لە باکوورەوە هەڵمستاند و هات. 
\q2 لە ڕۆژهەڵاتەوە بە ناوی منەوە نزا دەکات، 
\q1 بەسەر پارێزگارەکاندا دێت وەک بەسەر قوڕدا، 
\q2 وەک گۆزەکەر قوڕ بشێلێت. 
\q1  
\v 26 کێ لە سەرەتاوە ڕایگەیاند، بۆ ئەوەی بزانین، 
\q2 پێشوەخت، هەتا بڵێین: ”ڕاستودروستە؟“ 
\q1 بێگومان ڕاگەیەنەر نییە، 
\q2 بێگومان بەگوێدادەر نییە، 
\q2 بێگومان گوێگری وشەکانتان نییە. 
\q1  
\v 27 سەرەتا بە سییۆن: ”ئەوەتا ئەوان!“ 
\q2 بە ئۆرشەلیمیش مزگێنیدەرم دا. 
\q1  
\v 28 بینیم کەس نییە، 
\q2 ئەمانە ڕاوێژکاریان تێدا نییە 
\q2 هەتا پرسیاریان لێ بکەم و بە وشەیەک وەڵام بدەنەوە. 
\q1  
\v 29 تەماشا بکە، هەموو هەڵخەڵەتێنەرن! 
\q2 کارەکانیان هیچ نین، 
\q2 بتە داتاشراوەکانیان بە وێنەی بایە و پووچن. 
\c 42  
\s1 بەندەی یەزدان 
\q1  
\v 1 «ئەوەتا خزمەتکارەکەم، ئەوەی پشتیوانی دەکەم، 
\q2 هەڵبژاردەکەم کە پێی دڵشادم، 
\q1 ڕۆحی خۆمی دەخەمە سەر، 
\q2 دادپەروەری بۆ نەتەوەکان بەرپا دەکات. 
\q1  
\v 2 هاوار ناکات و بانگ ناکات و 
\q2 دەنگی لە شەقامەکان نابیسترێت. 
\q1  
\v 3 قامیشێکی کوتراو ناشکێنێت، 
\q2 پڵیتەیەکی پرتەپرتکەر ناکوژێنێتەوە. 
\q1 بە ڕاستییەوە دادپەروەری دەردەخات. 
\q2  
\v 4 نە ماندوو دەبێت و نە وردوخاش دەبێت 
\q1 هەتا ئەوەی لەسەر زەوی دادپەروەری بەرقەرار دەکات. 
\q2 دوورگەکان هیوایان بە فێرکردنەکانی ئەو دەبێت.» 
\b  
\q1  
\v 5 خودای پەروەردگار، بەدیهێنەری ئاسمان و لێککەرەوەی، 
\q2 ڕاخەری زەوی و ئەوەی لێی بەرهەم دێت، 
\q1 هەناسەی داوە بەو گەلەی لەسەریەتی، 
\q2 ڕۆحیش بەوانەی هاتوچۆی تێدا دەکەن، 
\q1 ئەمە دەفەرموێت: 
\q1  
\v 6 «من یەزدانم، بە ڕاستودروستی بانگم کردیت، 
\q2 جا دەستت دەگرم و دەتپارێزم، 
\q2 دەتکەمە پەیمان بۆ گەل و ڕووناکی بۆ نەتەوەکان. 
\q1  
\v 7 بۆ ئەوەی چاوی نابیناکان بکەیتەوە، 
\q2 بۆ ئەوەی دیلەکان لە زیندان دەربهێنیت، 
\q2 لە بەندیخانەش دانیشتووان لە تاریکی. 
\b  
\q1  
\v 8 «من یەزدانم، ئەمەیە ناوم و 
\q2 شکۆمەندی خۆم نادەمە کەسی دیکە و 
\q2 ستایشم نادەمە بتە تاشراوەکان. 
\q1  
\v 9 ببینن، ئەوەی لە ڕابردوو گوترا هاتە دی، 
\q2 ئێستاش شتی نوێتان پێ ڕادەگەیەنم، 
\q1 پێش ئەوەی سەر دەربێنێت 
\q2 من پێتانی دەڵێم.» 
\s1 گۆرانی ستایش بۆ یەزدان 
\q1  
\v 10 ئەی ئەوانەی دادەبەزنە ناو دەریا و هەموو ئەوانەی تێیدان، 
\q2 دوورگەکان و دانیشتووانەکانیان، 
\q1 گۆرانییەکی نوێ بۆ یەزدان بڵێن، 
\q2 ستایشیشی لەوپەڕی زەوییەوە. 
\q1  
\v 11 با چۆڵەوانی و شارۆچکەکانی دەنگ بەرز بکەنەوە، 
\q2 گوندەکانی نشینگەی قێدار. 
\q1 با دانیشتووانی سەلەع هاواری خۆشی بکەن، 
\q2 لە ترۆپکی چیاکانەوە هاوار بکەن. 
\q1  
\v 12 با شکۆمەندی بە یەزدان بدەن، 
\q2 لە دوورگەکان ستایشی ڕابگەیەنن. 
\q1  
\v 13 یەزدان وەک پاڵەوان دێتە دەرەوە، 
\q2 وەک جەنگاوەر دڵگەرمی دەهەژێت، 
\q1 هاوار دەکات و نەعرەتەی جەنگ دەکێشێت، 
\q2 بەسەر دوژمنانیدا سەردەکەوێت. 
\b  
\q1  
\v 14 «زۆر دەمێکە کپ بووم، 
\q2 بێدەنگ بووم و دانم بە خۆمدا گرت. 
\q1 بەڵام ئێستا وەک ژنێک کە منداڵی ببێت دەقیژێنم، 
\q2 هەناسە دەدەم و هەناسە هەڵدەکێشم پێکەوە. 
\q1  
\v 15 چیا و گردەکان تێکدەدەم، 
\q2 هەموو گیاوگوڵیان وشک دەکەم. 
\q1 ڕووبار دەکەمە دوورگە و 
\q2 گۆلاوەکان وشک دەکەم. 
\q1  
\v 16 نابیناکان بە ڕێگایەکدا دەبەم شارەزای نەبن، 
\q2 بە ڕێچکەیەکدا هاتوچۆیان پێ دەکەم کە نایزانن، 
\q1 تاریکی لەبەردەمیاندا دەکەم بە ڕووناکی، 
\q2 ڕێگا خوارەکانیش بە ڕاستە ڕێ. 
\q1 ئەم شتانە دەکەم و 
\q2 بەجێیان ناهێڵم. 
\q1  
\v 17 بەڵام ئەوانەی پشت بە بتی داڕێژراو دەبەستن، 
\q2 ئەوانەی بە پەیکەری داتاشراو دەڵێن، ”ئێوە خوداوەندی ئێمەن،“ 
\q2 بەرەو دواوە دەگەڕێنەوە و بە تەواوی شەرمەزار دەبن. 
\s1 ئیسرائیلی کوێر و کەڕ 
\q1  
\v 18 «ئەی کەڕەکان گوێ بگرن! 
\q2 ئەی کوێرەکان سەیر بکەن بۆ ئەوەی ببینن! 
\q1  
\v 19 کێ کوێرە تەنها بەندەکەم\f + \fr 42:19 \ft مەبەست لە گەلی ئیسرائیل و پێغەمبەرەکانە.‏\f* نەبێت، 
\q2 یان کەڕە وەک نێردراوەکەم کە دەینێرم؟ 
\q1 کێ کوێرە وەک ئەوەی تەواوە و 
\q2 کوێرە وەک بەندەی یەزدان؟ 
\q1  
\v 20 زۆرت بینیوە و سەرنجت نەداوە، 
\q2 گوێیەکانت کراونەتەوە و نەتبیستووە.» 
\q1  
\v 21 یەزدان دڵخۆشە لە پێناوی ڕاستودروستی خۆی، 
\q2 فێرکردنەکانی خۆی بە گەورە دادەنێت و ڕێزی لێ دەگرێت. 
\q1  
\v 22 بەڵام ئەو گەلێکی تاڵانکراو و ڕووتکراوەیە 
\q2 هەموو کەوتوونەتە چاڵەوە، 
\q2 لە بەندیخانەکان خۆیان شاردووەتەوە، 
\q1 بوون بە تاڵانی و کەس فریایان نەکەوت، 
\q2 ڕووتکرانەوە و کەس نەبوو بڵێت، «دەست بگێڕەوە!» 
\b  
\q1  
\v 23 کێ لە ئێوە گوێ لەمە دەگرێت، 
\q2 گوێ شل دەکات و هەتا کۆتایی دەبیستێت؟ 
\q1  
\v 24 کێ یاقوبی دایە دەست ڕووتکردنەوە و 
\q2 ئیسرائیلیش بۆ تاڵانکاران؟ 
\q1 ئایا یەزدان نییە 
\q2 کە گوناهمان دەرهەقی کرد و 
\q1 نەیانویست ڕێگاکانی بگرنەبەر و 
\q2 گوێیان لە فێرکردنەکانی نەگرت؟ 
\q1  
\v 25 ئیتر گڕی تووڕەیی خۆی بەسەردا ڕشتن، 
\q2 بە جەنگێکی سەخت، 
\q1 لە هەموو لایەکەوە گڕی تێبەردان، بەڵام پێیان نەزانی، 
\q2 سووتاندنی، بەڵام نەچووە مێشکیانەوە. 
\c 43  
\s1 تاکە ڕزگارکەری ئیسرائیل 
\q1  
\v 1 ئێستاش یەزدان ئەمە دەفەرموێت، 
\q2 بەدیهێنەرت، ئەی یاقوب، 
\q2 شێوەکێشت، ئەی ئیسرائیل: 
\q1 «مەترسە، چونکە تۆم کڕیوەتەوە، 
\q2 بە ناوی خۆتەوە بانگم کردوویت، تۆ هی منیت. 
\q1  
\v 2 کە بەناو ئاودا بپەڕیتەوە، من لەگەڵتدام، 
\q2 بەناو ڕووبارەکانیشدا، نوقومت ناکەن. 
\q1 بەناو ئاگردا بڕۆیت، داغ نابیت، 
\q2 بڵێسەش ناتسووتێنێت، 
\q1  
\v 3 چونکە من یەزدانم، خودای تۆم، 
\q2 پیرۆزەکەی ئیسرائیل، ڕزگارکەری تۆ. 
\q1 میسرم کردووە بە کەفارەتی تۆ، 
\q2 کوش و سەبا لە جێی تۆ. 
\q1  
\v 4 لەبەر ئەوەی تۆ بەنرخ بوویت لەلام، 
\q2 سەنگین بوویت و من خۆشم ویستیت، 
\q1 لە جێی تۆ خەڵکی دەدەم، 
\q2 لە جیاتی گیانت نەتەوەکان. 
\q1  
\v 5 مەترسە، چونکە من لەگەڵتدام. 
\q2 لە ڕۆژهەڵاتەوە نەوەکانت دەهێنم و 
\q2 لە ڕۆژئاواوە کۆت دەکەمەوە. 
\q1  
\v 6 بە باکوور دەڵێم: ”بیاندەرێ!“ و 
\q2 بە باشووریش: ”مەیانگرە!“ 
\q1 کوڕانم لە دوورەوە بهێنە و 
\q2 کچانم لەوپەڕی زەوییەوە. 
\q1  
\v 7 هەموو ئەوانەی بە ناوی منەوە بانگ دەکرێن، 
\q2 بۆ شکۆمەندیی خۆم بەدیم هێناون، 
\q2 شێوەم کێشاون و دروستم کردوون.» 
\b  
\q1  
\v 8 دەریبخە ئەو گەلەی کوێرە، بەڵام چاوی هەیە، 
\q2 کەڕە، بەڵام گوێی هەیە. 
\q1  
\v 9 با هەموو نەتەوەکان پێکەوە کۆببنەوە، 
\q2 با نەتەوەکان خڕ ببنەوە. 
\q1 کێ لەوان ئەمە ڕادەگەیەنێت و 
\q2 سەرەتاکانمان پێ دەڵێت؟ 
\q1 با شایەتەکانیان بهێننە پێش و ڕاستی پێشبینییەکانیان دەربخەن، 
\q2 یان گوێیان لێ بێت و بڵێن: «ڕاستە.» 
\q1  
\v 10 یەزدان دەفەرموێت: «ئێوە شایەتی منن، 
\q2 بەندەی هەڵبژاردەم، 
\q1 بۆ ئەوەی بزانن و باوەڕم پێ بهێنن و 
\q2 تێبگەن کە من ئەوم، 
\q1 پێش من شێوەی هیچ خودایەک نەکێشراوە و 
\q2 پاش منیش نابێت. 
\q1  
\v 11 منم، منم یەزدان، 
\q2 لە من بەولاوە ڕزگارکەر نییە. 
\q1  
\v 12 من ئاشکرام کرد و ڕزگارم کرد و ڕامگەیاند، 
\q2 منم، نەک خوداوەندێکی بێگانە لەنێوتاندا بێت. 
\q1 ئێوە شایەتی منن کە من خودام.» ئەوە فەرمایشتی یەزدانە. 
\q2  
\v 13 «لەو ڕۆژەوە من ئەوم، 
\q1 کەس لە دەستم دەرباز نابێت. 
\q2 هەرچی بکەم، کێ ڕەتی دەکاتەوە؟» 
\s1 بەزەیی خودا و بێوەفایی ئیسرائیل 
\q1  
\v 14 یەزدان ئەوەی دەتانکڕێتەوە، 
\q2 پیرۆزەکەی ئیسرائیل، ئەمە دەفەرموێت: 
\q1 «لە پێناوی ئێوە دەنێرم بۆ بابل و 
\q2 هەموو هەڵاتووەکانی بەدەردەنێم، 
\q2 بابلییەکانیش بەو کەشتییانەی کە هاواری شادییان تێدا کردبوون. 
\q1  
\v 15 منم یەزدان، پیرۆزەکەتان، 
\q2 بەدیهێنەری ئیسرائیل، پاشاکەتان.» 
\b  
\q1  
\v 16 یەزدان، ئەوەی لەناو دەریا ڕێگای داناوە، 
\q2 لەناو ئاوە بەهێزەکان ڕێچکە، 
\q1  
\v 17 ئەوەی گالیسکە و ئەسپی دەرکرد، 
\q2 سوپا و هێزی پێکەوە ڕاکێشا و هەڵنەستانەوە، 
\q1 کپ بوون، وەک پڵیتەیەک کوژانەوە، 
\q2 ئەو ئەمە دەفەرموێت: 
\q1  
\v 18 «باسی سەرەتاکان مەکەن، 
\q2 لە دێرینەکان ڕامەمێنن. 
\q1  
\v 19 ئەوەتا من شتێکی نوێ دەکەم! 
\q2 ئێستا سەرهەڵدەدات، ئایا نایزانن؟ 
\q1 لە چۆڵەوانی ڕێگا دادەنێم و 
\q2 لە بیابان ڕووبارەکان. 
\q1  
\v 20 ئاژەڵە کێوییەکان شکۆمەندم دەکەن، 
\q2 چەقەڵ و کوندەپەپوو، 
\q1 چونکە ئاوم خستە چۆڵەوانییەوە، 
\q2 ڕووبارەکان لە بیاباندا 
\q1 بۆ ئاودانی گەلەکەم، هەڵبژاردەکەم، 
\q2  
\v 21 ئەم گەلە بۆ خۆم شێوەم کێشاوە 
\q2 باسی ستایشم دەکەن. 
\b  
\q1  
\v 22 «بەڵام نزاتان بۆ نەکردم، ئەی یاقوب، 
\q2 لە پێناوی من کۆششتان نەکرد، ئەی ئیسرائیل. 
\q1  
\v 23 بەرخی قوربانی سووتاندنەکەی خۆتت بۆ من نەهێنا، 
\q2 بە قوربانییە سەربڕدراوەکانت ڕێزت لێ نەگرتم. 
\q1 بە پێشکەشکراوی دانەوێڵە بارگرانم نەکردیت، 
\q2 بە قوربانی بخوور ماندووم نەکردیت. 
\q1  
\v 24 بە زیوەکەت قامیشی بۆنخۆشت بۆ نەکڕیم، 
\q2 بە پیوی قوربانییە سەربڕدراوەکانت تێرت نەکردم، 
\q1 بەڵکو بە گوناهەکانت بارگرانت کردم، 
\q2 بە تاوانەکانت ماندووت کردم. 
\b  
\q1  
\v 25 «منم، منم کە یاخیبوونەکانت دەسڕمەوە، 
\q2 لە پێناو خۆم، 
\q2 گوناهەکانیشت بەبیری خۆم ناهێنمەوە. 
\q1  
\v 26 بەبیرم بخەرەوە، 
\q2 با پێکەوە بکەوینە دادگاییکردن، 
\q2 بە بەڵگە بێتاوانییەکەت بسەلمێنە. 
\q1  
\v 27 باوکی یەکەمت گوناهی کرد و 
\q2 پەیوەندی ڕێکخەرانت لێم یاخی بوون. 
\q1  
\v 28 لەبەر ئەوە میرانی پیرۆزگا گڵاو دەکەم و 
\q2 یاقوب دەدەمە قڕکردن\f + \fr 43:28 \ft قڕکردن: لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f* و 
\q2 ئیسرائیلیش بۆ جنێوپێدان. 
\c 44  
\s1 ئیسرائیلی هەڵبژێردراو 
\q1  
\v 1 «ئێستا یاقوبی بەندەم، 
\q2 ئیسرائیلی هەڵبژاردەم، گوێ بگرە. 
\q1  
\v 2 دروستکەر، یارمەتیدەرت، 
\q2 شێوەکێشت لە سکی دایکەوە، 
\q2 یەزدان ئەمە دەفەرموێت: 
\q1 مەترسە یاقوبی بەندەم، 
\q2 یەشوروونی\f + \fr 44:2 \ft یەشوروون: وشەیەکی عیبرییە بە واتای سەرڕاست یان دادپەروەر، لێرە مەبەست لە گەلی ئیسرائیلە.‏\f* هەڵبژاردەم، 
\q1  
\v 3 چونکە ئاو بەسەر خاکە تینووەکەدا دەڕێژم و 
\q2 لافاو بەسەر زەوییە وشکەکەدا، 
\q1 ڕۆحی خۆم بەسەر نەوەکانتدا دەڕێژم و 
\q2 بەرەکەتم بەسەر توخمت. 
\q1  
\v 4 جا لەنێو سەوزەگیا سەرهەڵدەدەن 
\q2 وەک شۆڕەبی ڕۆخ جۆگەکان. 
\q1  
\v 5 ئەمەیان دەڵێت: ”من سەر بە یەزدانم،“ 
\q2 ئەویان بە ناوی یاقوب بانگ دەکرێت، 
\q1 ئەمیان لەسەر دەستی دەنووسێت: ”بۆ یەزدانە“ و 
\q2 بە ناوی ئیسرائیلەوە نازناوی لێ دەنرێت. 
\s1 یەزدان، نەک بت 
\q1  
\v 6 «یەزدان، پاشای ئیسرائیل و ئەوەی دەیکڕێتەوە، 
\q2 یەزدانی سوپاسالار، ئەمە دەفەرموێت: 
\q1 من سەرەتا و من کۆتاییم، 
\q2 لە من بەولاوە هیچ خودایەک نییە. 
\q1  
\v 7 کێ وەک منە؟ با بانگەواز بکات، 
\q2 با ڕایبگەیەنێت و بیخاتە بەردەمم 
\q1 لەو کاتەوەی گەلی دێرینم داناوە و 
\q2 داهاتووەکان و ئەوەی لەگەڵ خۆی دەیهێنێت، 
\q2 با پێیان ڕابگەیەنن. 
\q1  
\v 8 مەتۆقن و مەترسن. 
\q2 ئەی لە کۆنەوە پێم نەگوتوویت و پێم ڕانەگەیاندوویت؟ 
\q1 ئێوە شایەتی منن، ئایا لە من بەولاوە خودای دیکە هەیە؟ 
\q2 نەخێر، هیچ تاشەبەردێکی دیکە نییە؛ هیچی دیکە ناناسم.» 
\b  
\q1  
\v 9 شێوەکێشەکانی بت هەموو پووچن، 
\q2 شتە ئارەزوو بەخشەکانیان بێ سوودن. 
\q1 شایەتیدەری خۆیانن کە نابینن و 
\q2 نازانن، لەبەر ئەوە شەرمەزار دەبن. 
\q1  
\v 10 کێ شێوەی خودایەکی کێشاوە 
\q2 یان بتێکی داڕشتووە بەبێ سوود؟ 
\q1  
\v 11 ئەوەتا هەموو هاوڕێیەکانی شەرمەزار دەبن. 
\q2 وەستاکانی لە مرۆڤن، 
\q1 هەموو کۆدەبنەوە و ڕادەوەستن، 
\q2 پێکەوە دەتۆقن و شەرمەزار دەبن. 
\b  
\q1  
\v 12 ئاسنگەر بە ئامێرەکانی 
\q2 پارچە ئاسن لەناو خەڵووز سوور دەکاتەوە. 
\q1 بە چەکوش شێوەی دەکات، 
\q2 بە هێزی بازووی دروستی دەکات. 
\q1 برسی دەبێت هێزی نییە، 
\q2 ئاوی نەخواردووەتەوە و ماندوو بوو. 
\q1  
\v 13 دارتاش گوریسی پێوانەی ڕاکێشا، 
\q2 نیشانی کرد بە نیشانکەر، 
\q1 بە ئەسکەنە دروستی دەکات. 
\q2 بە پرگال وێنەی دەکێشێت، 
\q1 جا وەک شێوەی پیاو دروستی دەکات، 
\q2 وەک جوانی مرۆڤ 
\q2 بۆ ئەوەی لە نزرگە جێگیر بێت. 
\q1  
\v 14 دار ئورزی بۆ خۆی بڕییەوە، 
\q2 یان داری سەروو یاخود داری بەڕووی برد، 
\q1 بەجێی هێشت کە لەنێو دارەکانی دارستان گەشە بکات، 
\q2 یاخود دار سنەوبەرێکی ڕواند و باران گەورەی کرد. 
\q1  
\v 15 جا بۆ مرۆڤ دەبێت بۆ سووتاندن، 
\q2 لێی دەبات و گەرم دەبێتەوە، 
\q2 دایدەگیرسێنێت و نانی پێ دەبرژێنێت. 
\q1 بەڵام خوداوەندێکیش دروستدەکات و کڕنۆشی بۆ دەبات، 
\q2 دەیکات بە پەیکەر و ڕوو لە زەوی دەکات بۆی. 
\q1  
\v 16 نیوەی بە ئاگر دەسووتێنێت، 
\q2 لەسەر نیوەی خواردن ئامادە دەکات، 
\q2 گۆشت دەبرژێنێت و تێردەبێت. 
\q1 هەروەها گەرم دەبێتەوە و دەڵێت: «ئەها! 
\q2 گەرم بوومەوە، ئاگرم بینی.» 
\q1  
\v 17 پاشماوەکەشی خوداوەندێکی لێ دروستکرد، بتە داتاشراوەکەی، 
\q2 ڕوو لە زەوی دەکات بۆی و کڕنۆشی بۆ دەبات. 
\q1 نوێژی بۆ دەکات و دەڵێت: 
\q2 «ڕزگارم بکە، چونکە تۆ خودای منی.» 
\q1  
\v 18 نازانن و تێناگەن، 
\q2 چونکە چاوەکانیان داخراوە لە بینین و 
\q2 مێشکیان لە تێگەیشتن. 
\q1  
\v 19 لە دڵی خۆیدا بیری لێ ناکاتەوە و 
\q2 زانین و تێگەیشتنی نییە 
\q1 هەتا بڵێت: «بە نیوەی ئاگرم خۆشکرد، 
\q2 بە پشکۆیەکەشی نان و گۆشتم برژاند و خواردم. 
\q1 ئەو کاتە پاشماوەکەی بکەم بە قێزەون، 
\q2 بۆ قەدی دارێک ڕوو لە زەوی بکەم؟» 
\q1  
\v 20 لەسەر خۆڵەمێش دەلەوەڕێت، دڵی هەڵخەڵەتا و چەواشەی کرد. 
\q2 گیانی خۆی ڕزگار ناکات، 
\q2 ناڵێت: «ئایا ئەمە درۆ نییە لەنێو دەستی ڕاستم؟» 
\b  
\q1  
\v 21 «ئەمەت لەبیر بێت، ئەی یاقوب، 
\q2 ئەی ئیسرائیل، چونکە تۆ بەندەی منیت، 
\q1 شێوەی تۆم کێشا، تۆ بەندەی منیت. 
\q2 ئەی ئیسرائیل، لەبیرم ناچیت. 
\q1  
\v 22 یاخیبوونەکانی تۆم وەک هەوری تار سڕییەوە، 
\q2 گوناهەکانیشت وەک تەمی بەیانییان. 
\q1 بگەڕێوە بۆ لام، 
\q2 چونکە تۆم کڕییەوە.» 
\b  
\q1  
\v 23 ئەی ئاسمان، هاواری خۆشی بکە، چونکە یەزدان ئەمەی کرد؛ 
\q2 ئەی ناخی زەوی، هاوار بکەن! 
\q1 هاواری خۆشی بکەن، ئەی چیاکان، 
\q2 ئەی دارستان و هەموو دارێک کە تێیدایە، 
\q1 چونکە یەزدان یاقوبی کڕییەوە و 
\q2 لە ئیسرائیل شکۆدارە. 
\s1 ئاوەدانی ئۆرشەلیم 
\q1  
\v 24 «یەزدان، ئەوەی دەتکڕێتەوە، شێوەکێشت لە سکی دایکەوە، 
\q2 ئەمە دەفەرموێت: 
\b  
\q1 «من یەزدانم، 
\q1 دروستکەری هەموو، 
\q1 بە تەنها ئاسمانم لێککردەوە، 
\q1 زەویم ڕاخست، کەسم لەگەڵ نەبوو، 
\q1  
\v 25 نیشانەی پێغەمبەرانی درۆزنم پوکاندەوە، 
\q2 فاڵگرەوەم گێل کرد. 
\q1 دانام گەڕاندەوە دواوە، 
\q2 زانینەکەی ئەوانم کردە نەزانی. 
\q1  
\v 26 وشەی خزمەتکارەکەی بەجێدەهێنێت، 
\q2 پلانی نێردراوەکانی تەواو دەکات، 
\q1 سەبارەت بە ئۆرشەلیم دەڵێت: ”ئاوەدان دەبێتەوە،“ 
\q2 بە شارۆچکەکانی یەهوداش: ”بنیاد دەنرێنەوە،“ 
\q2 سەبارەت بە کەلاوەکانیش: ”نۆژەنیان دەکەمەوە،“ 
\q1  
\v 27 بە دەریا دەڵێت: ”وشک بە، 
\q2 منیش ڕووبارەکانت وشک دەکەم،“ 
\q1  
\v 28 سەبارەت بە کۆرش\f + \fr 44:28 \ft بڕوانە \xt دووەم پوختەی مێژوو 36‏:22‏\ft ‏ و 23.‏\f* دەڵێت: ”ئەو شوانی منە، 
\q2 هەموو ئەوەی دڵم پێی خۆشە دەیهێنێتە دی. 
\q1 سەبارەت بە ئۆرشەلیمیش دەڵێت: ’با بنیاد بنرێتەوە،‘ 
\q2 بە پەرستگاش دەڵێت: ’با دابمەزرێتەوە.‘ “» 
\b  
\c 45  
\q1  
\v 1 «یەزدان بەم شێوەیە بە کۆرشی دەستنیشانکراوی دەفەرموێت، 
\q2 ئەوەی دەستی ڕاستیم گرت 
\q1 بۆ ئەوەی لەبەردەمی ئەو نەتەوەکان بخەمە ژێر ڕکێفم و 
\q2 پاشایان چەک بکەم، 
\q1 بۆ ئەوەی لەبەردەمیدا دەروازەکان بکەمەوە و 
\q2 دەرگاکان دانەخرێن: 
\q1  
\v 2 ”من لەپێشتەوە دەڕۆم و 
\q2 تەپەکان تەخت دەکەم، 
\q1 دەروازە بڕۆنزییەکان دەشکێنم و 
\q2 شەوبەندە ئاسنینەکان دەبڕمەوە. 
\q1  
\v 3 گەنجینەکانی تاریکی و 
\q2 خشڵە شاردراوەکانت دەدەمێ، 
\q1 هەتا بزانیت کە من یەزدانم، خودای ئیسرائیل، 
\q2 ئەوەی بە ناوی خۆتەوە بانگت دەکات. 
\q1  
\v 4 لەبەر یاقوبی بەندەم و 
\q2 ئیسرائیلی هەڵبژاردەم، 
\q1 بە ناوی خۆت بانگت دەکەم و 
\q2 نازناوی چاکم بە تۆ بەخشی 
\q2 هەرچەندە تۆ دان بە مندا نانێیت. 
\q1  
\v 5 من یەزدانم و یەکێکی دیکە نییە، 
\q2 بێجگە لە من خودای دیکە نییە. 
\q2 هەرچەندە دانت بە مندا نەناوە، 
\q2 بەڵام من کەمەربەندی تۆ توند دەکەم، 
\q1  
\v 6 بۆ ئەوەی لە ڕۆژهەڵاتەوە هەتا ڕۆژئاوا بزانن 
\q2 بێجگە لە من خودای دیکە نییە. 
\q1 من یەزدانم و یەکێکی دیکە نییە. 
\q1  
\v 7 شێوەکێشی ڕووناکی و بەدیهێنەری تاریکیم، 
\q2 دروستکەری ئاشتی و بەدیهێنەری خراپەم،\f + \fr 45:7 \ft بڕوانە \xt ئەیوب 2‏:1‏-10،‏\ft ‏ خودا هەندێک جار ڕێ دەدات کە شتی خراپ ڕووبدەن بۆ بەدیهێنانی مەبەستەکانی خۆی.‏\f* 
\q2 من یەزدانم دروستکەری هەموو ئەمانە.“ 
\b  
\q1  
\v 8 «ئەی ئاسمان لە سەرەوە، ڕاستودروستییەکەم ببارێنە، 
\q2 با هەورەکان بیپرژێنێت. 
\q1 با زەوی بکرێتەوە و پێکەوە 
\q2 ڕزگاری بەر بگرێت و 
\q1 ڕاستودروستی سەرهەڵبدات؛ 
\q2 من یەزدانم بەدیم هێنا. 
\b  
\q1  
\v 9 «قوڕبەسەر ئەوەی کێشە لەگەڵ شێوەکارەکەی دروستدەکات، 
\q2 پارچەی گۆزەیەکە لەنێو گۆزەکانی سەر زەوی. 
\q1 ئایا قوڕ بە گۆزەکەرەکەی دەڵێت: 
\q2 ”چی دروستدەکەیت؟“ 
\q1 یان دەڵێت: 
\q2 ”ئەوەی دروستت کردووە دوو دەسکی نییە“؟ 
\q1  
\v 10 قوڕبەسەر ئەوەی بە باوکی دەڵێت: 
\q2 ”چ منداڵێکت خستەوە؟“ 
\q2 بە دایکەکەشی: ”چیت لێ دەبێت؟“ 
\b  
\q1  
\v 11 «یەزدان، پیرۆزەکەی ئیسرائیل و شێوەکێشەکەی، 
\q2 ئەمە دەفەرموێت: 
\q1 دەربارەی ئەوانەی دێت، 
\q2 ئایا سەبارەت بە منداڵەکانم لێم دەپرسن، 
\q2 سەبارەت بە کاری دەستم، ڕامدەسپێرن؟ 
\q1  
\v 12 من زەویم دروستکرد و 
\q2 مرۆڤی سەریم بەدیهێنا. 
\q1 دەستەکانی من ئاسمانی لێککردەوە و 
\q2 هەموو هێزەکانی ئاسمانم پێکهێنا. 
\q1  
\v 13 من کۆرش بە ڕاستودروستی هەڵدەستێنم و 
\q2 هەموو ڕێگاکانی ڕێک و ڕاست دەکەم. 
\q1 ئەو شارەکەم بنیاد دەنێتەوە و 
\q2 ڕاپێچکراوەکانم ئازاد دەکات 
\q1 بەبێ پارە و بەبێ بەرتیل. 
\q2 ئەمە فەرمایشتی یەزدانی سوپاسالارە.» 
\p  
\v 14 یەزدان ئەمە دەفەرموێت: 
\q1 «بەرهەمی میسر و بازرگانی کوش و 
\q2 سەبئییە باڵا بەرزەکان 
\q1 بۆ لای ئێوە\f + \fr 45:14 \ft مەبەست لە یەهودایە لەدوای گەڕاندنەوەی گەلی خودا لە ڕاپێچکراوی لەلایەن کۆرش پاشای فارسەوە.‏\f* دەپەڕنەوە و 
\q2 بۆ ئێوە دەبن. 
\q1 لەدوای ئێوەوە بە کۆت و زنجیرەوە دەڕۆن و 
\q2 دەپەڕنەوە بۆ لاتان. 
\q1 کڕنۆش بۆ ئێوە دەبەن و 
\q2 لە ئێوە دەپاڕێنەوە و دەڵێن: 
\q1 ”بێگومان خودا لەنێو ئێوەدایە و یەکێکی دیکە نییە، 
\q2 خودای دیکە نییە.“» 
\b  
\q1  
\v 15 بەڕاستی تۆ خودایەکی خۆت دەشاریتەوە، 
\q2 خودای ئیسرائیل، ئەی ڕزگارکەر. 
\q1  
\v 16 هەروەها هەموو وەستای پەیکەرەکان شەرمەزار و ڕیسوا دەبن، 
\q2 پێکەوە بە سەرشۆڕییەوە دەڕۆن، 
\q1  
\v 17 بەڵام ئیسرائیل بە یەزدان ڕزگاری دەبێت، 
\q2 بە ڕزگارییەکی هەتاهەتایی. 
\q1 شەرمەزار و ڕیسوا نابن 
\q2 هەتاهەتایە. 
\b  
\q1  
\v 18 یەزدان ئەمە دەفەرموێت، 
\q1 بەدیهێنەری ئاسمان، 
\q2 ئەو خودایە، 
\q1 شێوەکێشی زەوی و دروستکەری، 
\q2 ئەو دایمەزراند. 
\q1 بەخۆڕایی بەدی نەهێنا، 
\q2 بەڵام بۆ نیشتەجێبوون شێوەی کێشا، 
\q1 دەفەرموێت: 
\q1 «من یەزدانم و 
\q2 یەکێکی دیکە نییە. 
\q1  
\v 19 لە پەناوە قسەم نەکرد، 
\q2 لە شوێنێکی تاریکی زەوی. 
\q1 بە توخمی یاقوبم نەفەرموو، 
\q2 ”بەخۆڕایی بەدوامدا بگەڕێن.“ 
\q1 من یەزدانم بە ڕاستی دەدوێم و 
\q2 ڕاستودروستی ڕادەگەیەنم. 
\b  
\q1  
\v 20 «کۆببنەوە و وەرن، 
\q2 ئەی دەربازبووانی نەتەوەکان، پێکەوە وەرنە پێش. 
\q1 نازانن ئەوانەی هەڵیانگرتووە، داری بتە داتاشراوەکانیان، 
\q2 ئەوانەی داوا لە خوداوەندێک دەکەن کە ڕزگار ناکات. 
\q1  
\v 21 ڕایبگەیەنن و وەرنە پێش. 
\q2 با ئەوان پێکەوە ڕاوێژ بکەن. 
\q1 لە کۆنەوە کێ پێشبینی ئەمەی کردووە، 
\q2 لە دێرزەمانەوە ڕایگەیاندووە؟ 
\q1 ئایا منی یەزدان نەبوو؟ 
\q2 بێجگە لە من هیچ خودایەک نییە، 
\q1 خودایەکی ڕاستودروست و ڕزگارکەر 
\q2 بێجگە لە من نییە. 
\b  
\q1  
\v 22 «ڕوو لە من بکەن و ڕزگارتان بێت، 
\q2 ئەی هەموو لایەکانی زەوی، 
\q2 چونکە من خودام و یەکێکی دیکە نییە. 
\q1  
\v 23 سوێندم بە گیانی خۆم خوارد، 
\q2 ڕاستی لە دەممەوە هاتە دەرەوە، 
\q2 وشەیەکە و ناگەڕێتەوە، 
\q1 کە هەموو ئەژنۆیەک بۆ من چۆک دەدات، 
\q2 هەموو زمانێک بە من سوێند دەخوات. 
\q1  
\v 24 سەبارەت بە من دەڵێن: ”ڕاستودروستی و هێز 
\q2 تەنها بە یەزدانە.“» 
\q1 هەموو ئەوانەی ڕقیان لێی هەستاوە 
\q2 بۆ لای ئەو دێن و شەرمەزار دەبن، 
\q1  
\v 25 بەڵام هەموو توخمی ئیسرائیل 
\q2 بە یەزدان ڕاستودروست دەبن و شانازی دەکەن. 
\c 46  
\s1 خوداوەندەکانی بابل 
\q1  
\v 1 بێل\f + \fr 46:1 \ft بێل، هەروەها ناسراوە بە ناوی مەردوخ، یەکێک بووە لە خوداوەندە سەرەکییەکانی بابل. هەروەها نەبۆ خوداوەندێکی دیکە بووە و کوڕی مەردوخ بووە. ناوی ئەم دوو خوداوەندە لەسەر ئەو تەختە گڵینانە دۆزراوەتەوە کەوا زانایانی شوێنەوارناس لە پاشماوەی بابل دۆزیویانەتەوە.\f* چۆکی دادا و نەبۆ چەمایەوە، 
\q2 بتەکانیان بارن بۆ ڕەشەوڵاخ. 
\q1 ئەوەی باری دەکەن باری هەڵگیراون، 
\q2 بارن بەسەر ئاژەڵە ماندووەکانەوە. 
\q1  
\v 2 هەموو چەمانەوە، پێکەوە چۆکیان دادا، 
\q2 نەیانتوانی بارەکە دەرباز بکەن و 
\q2 ئەوان خۆشیان ڕاپێچ کران. 
\b  
\q1  
\v 3 «ئەی بنەماڵەی یاقوب، گوێم لێ بگرن، 
\q2 ئەی هەموو پاشماوەی بنەماڵەی ئیسرائیل، 
\q1 ئەی ئەوانەی هەڵمگرتوون لەو کاتەوەی لەناو ڕەحم بوونە، 
\q2 لەو ڕۆژەوەی کە لەدایک بوونە گرنگیم پێداون. 
\q1  
\v 4 هەتا پیریش بن هەر من ئەوم، 
\q2 هەتا ڕیش سپیێتیش هەر من هەڵتاندەگرم. 
\q1 من دروستم کردوون و ئێوە باری منن، 
\q2 هەر من هەڵدەگرم و دەرباز دەکەم. 
\b  
\q1  
\v 5 «بە کێ هاوشێوەم دەکەن و یەکسانم دەکەن و 
\q2 هاووێنەم دەکەن بۆ ئەوەی لە یەک بچین؟ 
\q1  
\v 6 ئەوانە زێڕ لە کیسەوە بەتاڵ دەکەن و 
\q2 زیویش بە تەرازوو دەکێشن، 
\q1 زێڕنگەرێک بەکرێ دەگرن و دەیکاتە خوداوەندێک، 
\q2 ڕوو لە زەوی دەکەن بۆی و کڕنۆشی بۆ دەبەن. 
\q1  
\v 7 دەیخەنە سەر شان، هەڵیدەگرن، 
\q2 لە جێی خۆی دایدەنێن بۆ ئەوەی ڕاوەستێت، 
\q2 لە جێی خۆی ناجوڵێتەوە. 
\q1 هاواری بۆ دەکات و وەڵام ناداتەوە، 
\q2 لە تەنگانەکەی ڕزگاری ناکات. 
\b  
\q1  
\v 8 «ئەمەتان لەبیر بێت و وردبنەوە! 
\q2 ئەی یاخیبووان، بیخەنە مێشکتانەوە. 
\q1  
\v 9 سەرەتاکانتان لەبیر بێت کە لە کۆنەوەیە، 
\q2 بە ڕاستی من خودام و یەکێکی دیکە نییە، 
\q2 خودام و هیچی دیکە نییە وەک من. 
\q1  
\v 10 لە سەرەتاوە کۆتاییم ڕاگەیاندووە، 
\q2 لە کۆنەوەش ئەوەی هێشتا نەکراوە. 
\q1 فەرمووم: ”ڕاوێژی من سەر دەگرێت، 
\q2 هەموو ئەوەی پێم خۆشە دەیکەم.“ 
\q1  
\v 11 داڵ لە ڕۆژهەڵاتەوە بانگ دەکەم، 
\q2 لە خاکێکی دووریشەوە ئەوەی ئامانجی من بەجێدەگەیەنێت. 
\q1 فەرمووم و ئەنجامی دەدەم، 
\q2 دامڕشتووە و دەیکەم. 
\q1  
\v 12 ئەی کەللەڕەقەکان، گوێم لێ بگرن، 
\q2 ئەی دوورەکان لە ڕاستودروستی. 
\q1  
\v 13 ڕاستودروستی خۆمم نزیک خستووەتەوە، 
\q2 دوور ناکەوێتەوە و 
\q2 ڕزگاربوونم دوا ناکەوێت. 
\q1 ڕزگاری بە سییۆن دەبەخشم، 
\q2 بە ئیسرائیلی شکۆمەندیم. 
\c 47  
\s1 کەوتنی بابل 
\q1  
\v 1 «دابەزە و لەسەر خۆڵ دابنیشە، 
\q2 ئەی بابلی کچە پاکیزە\f + \fr 47:1 \ft پاکیزە: مەبەست لەپێش داگیرکردنیەتی، کە بەراوردی دەکات بە کچی پاکیزە.‏\f*. 
\q1 بەبێ تەخت لەسەر زەوی دابنیشە، 
\q2 کچی بابلییەکان، 
\q1 چونکە چیتر پێت ناگوترێت 
\q2 ناسک و نازدار. 
\q1  
\v 2 دەستاڕ ببە و باراش بهاڕە، 
\q2 عەبات فڕێبدە، 
\q1 دامێن هەڵبکە و قاچ بەدەرخە، 
\q2 لە ڕووبارەکان بپەڕەوە. 
\q1  
\v 3 ڕووتیت دەردەکەوێت، 
\q2 هەروەها ڕیسواییت دەبینرێت. 
\q1 تۆڵەی خۆم دەکەمەوە و 
\q2 لە کەس نابوورم.» 
\b  
\q1  
\v 4 ئەوەی دەمانکڕێتەوە ناوی یەزدانی سوپاسالارە، 
\q2 پیرۆزەکەی ئیسرائیلە. 
\b  
\q1  
\v 5 «بێدەنگ دابنیشە و وەرە ناو تاریکییەوە، 
\q2 شاری شاهانەی بابلییەکان، 
\q1 چونکە چیتر پێت ناگوترێت 
\q2 شاژنی شانشینەکان. 
\q1  
\v 6 تووڕە بووم لە گەلی خۆم و 
\q2 میراتی خۆمم گڵاوکرد. 
\q1 ئەوانم دا بە دەست تۆوە، 
\q2 تۆش لەگەڵیاندا بە بەزەیی نەبوویت. 
\q1 تەنانەت لەسەر پیرەکانیش 
\q2 نیری\f + \fr 47:6 \ft مەبەستی لە بارگرانییە.‏\f* خۆتت زۆر قورس کرد. 
\q1  
\v 7 گوتت: ”بۆ هەتاهەتایە 
\q2 دەبمە شاژن!“ 
\q1 بەڵام لەم ڕووداوانە وردنەبوویتەوە، 
\q2 بیرت لە کۆتاییەکەی نەکردەوە. 
\b  
\q1  
\v 8 «ئێستا گوێ لەمە بگرە، ئەی سۆزانی، 
\q2 ئەی دانیشتوو بە ئاسوودەیی، 
\q1 ئەی ئەوەی لە دڵی خۆیدا دەڵێت: 
\q2 ”هەر خۆم و بەس! 
\q1 نە بێوەژن دەبم و 
\q2 نە سک سووتاوی دەزانم.“ 
\q1  
\v 9 لەپڕ لە یەک ڕۆژدا 
\q2 ئەم دووانەت بەسەردێت، 
\q2 سک سووتان و بێوەژنیێتی. 
\q1 بە تەواوی بەسەرت دێت، 
\q2 سەرەڕای زۆری جادووگەری و 
\q2 سەرەڕای لە ڕادەبەدەر نوشتەکردنت. 
\q1  
\v 10 پشتت بە خراپەکارییەکانت بەست و 
\q2 گوتت: ”کەس نامبینێت.“ 
\q1 داناییەکەت و زانینەکەت تۆیان لەڕێ لادا، 
\q2 لە دڵی خۆتدا گوتت: 
\q2 ”هەر خۆم و بەس.“ 
\q1  
\v 11 خراپەیەکت بەسەردێت، 
\q2 سەرهەڵدانەکەی نازانیت، 
\q1 بەڵایەکت بەسەردێت. 
\q2 ناتوانیت ڕەتی بکەیتەوە، 
\q1 لەپڕ کاولبوونێکت بەسەردێت 
\q2 پێی نازانیت. 
\b  
\q1  
\v 12 «جا بەردەوام بە، بە نوشتەکانت و 
\q2 بە زۆری جادووگەریت، 
\q2 ئەوەی لە مێردمنداڵیتەوە تێیدا ماندوو بوویت، 
\q1 بەڵکو سوودی هەبێ بۆت، 
\q2 بۆ ئەوەی بیانترسێنیت! 
\q1  
\v 13 هێزت لەبەر بڕا لە زۆری ڕاوێژەکانت! 
\q2 با ئەستێرەناسەکانت بێنە پێشەوە، 
\q1 ئەوانەی ئاسمان دابەش دەکەن و 
\q2 چاو لە ئەستێرەکان دەبڕن و 
\q1 مانگ لەدوای مانگ پێشبینی دەکەن، 
\q1 با ئەوانە ڕزگارت بکەن 
\q2 لەوەی بەسەرت دێت. 
\q1  
\v 14 ئەوەتا وەک پووشیان لێدێت، 
\q2 ئاگر دەیانسووتێنێت. 
\q1 لە دەست بڵێسە 
\q2 فریای گیانی خۆیان ناکەون. 
\q1 ئەو پشکۆ خەڵووزە بۆ خۆگەرمکردنەوە نییە، 
\q2 ئەو ئاگرەش بۆ دانیشتن لەبەردەمی نییە. 
\q1  
\v 15 ئەو جادووگەرانەی لە مێردمنداڵیتەوە هەڵسوکەوتت لەگەڵدا دەکردن و 
\q2 پێیانەوە ماندوو بوویت، 
\q2 بەو دەردە دەچن. 
\q1 هەرکەسە و ملی ڕێی خۆی دەگرێت، 
\q2 کەس نییە ڕزگارت بکات. 
\c 48  
\s1 کەللەڕەقیی ئیسرائیل 
\q1  
\v 1 «گوێ لەمە بگرن، ئەی بنەماڵەی یاقوب، 
\q2 ئێوە پێتان دەگوترێت ئیسرائیل، 
\q2 ئێوە لە پشتی یەهوداوە دەرچوون، 
\q1 ئێوە بە ناوی یەزدانەوە سوێند دەخۆن، 
\q2 ناوی خودای ئیسرائیل دەهێنن، 
\q2 بەڵام نەک بە دڵسۆزی و نەک بە ڕاستودروستی، 
\q1  
\v 2 بە خۆتان دەڵێن، خەڵکی شاری پیرۆز و 
\q2 خۆتان دەدەنە پاڵ خودای ئیسرائیل 
\q2 کە ناوی یەزدانی سوپاسالارە: 
\q1  
\v 3 سەرەتاکانم لە کۆنەوە ڕاگەیاندووە، 
\q2 لە دەمی منەوە هاتوونەتە دەرەوە و وام کرد ببیسترێن، 
\q2 لەپڕ کردم و ڕوویان دا. 
\q1  
\v 4 دەمزانی ئێوە کەللەڕەقن و 
\q2 ملتان دەماری ئاسنینە و 
\q2 ناوچەوانتان بڕۆنزە. 
\q1  
\v 5 لەبەر ئەوە لە کۆنەوە ئەمانەم پێ ڕاگەیاندن، 
\q2 وام کرد پێش ئەوەی ڕووبدەن ئێوە گوێتان لێی بێت، 
\q1 نەوەک بڵێن: ”بتەکەم کردی، 
\q2 خوداوەندە دەستکردەکەم فەرمانی دا.“ 
\q1  
\v 6 ئێوە گوێتان لێ بوو، جا بڕواننە هەمووی. 
\q2 ئەی ئێوە دانی پێدا نانێن؟ 
\b  
\q1 «وا دەکەم لە ئێستاوە گوێتان لە شتە نوێیەکان بێت، 
\q2 ئەو نهێنییانەی کە نایانزانن. 
\q1  
\v 7 ئێستا بەدیهێنران، لە کۆنەوە نەبوون، 
\q2 بەر لە ئەمڕۆ نەتانبیستبوون 
\q1 نەوەک بڵێن، 
\q2 ”ئەوەتا دەمانزانی.“ 
\q1  
\v 8 هەروەها نە گوێتان لێ بوو نە زانیشتان، 
\q2 لە کۆنەوەش گوێت نەکردەوە. 
\q1 باش دەزانم چۆن بە تەواوی ناپاکی دەکەن، 
\q2 لەناو سکی دایکتانەوە پێتان گوترا: ”یاخی.“ 
\q1  
\v 9 لە پێناوی ناوی خۆم تووڕەییەکەم دوا دەخەم، 
\q2 لە پێناوی ستایشم دانبەخۆمدا دەگرم، 
\q2 نەوەک بتانبڕمەوە. 
\q1  
\v 10 ئەوەتا ئێوەم پاڵاوت، بەڵام نەک وەکو زیو، 
\q2 لەناو کوورەی ئازارچێژتن تاقیم کردنەوە. 
\q1  
\v 11 لە پێناوی خۆم، لە پێناوی خۆم دەیکەم، 
\q2 چۆن ڕێگا دەدەم ناوی من گڵاو بکرێت؟ 
\q2 شکۆمەندیم بە یەکێکی دیکە نادەم. 
\s1 دەربازکردنی ئیسرائیل 
\q1  
\v 12 «ئەی یاقوب، گوێم لێ بگرن، 
\q2 ئەی ئیسرائیل، ئەوانەی کە بانگم کردن. 
\q1 ئەوە منم، 
\q2 من سەرەتا و من کۆتاییم. 
\q1  
\v 13 دەستی من زەوی دامەزراند، 
\q2 دەستی ڕاستم ئاسمانی لێککردەوە. 
\q1 کاتێک من بانگیان دەکەم، 
\q2 پێکەوە دەوەستن. 
\b  
\q1  
\v 14 «هەمووتان کۆبنەوە و گوێ بگرن! 
\q2 کام لە بتەکان ئەمەی ڕاگەیاندووە؟ 
\q1 هاوپەیمانی خۆشەویستی یەزدان،\f + \fr 48:14 \ft مەبەست لە کۆرشی پاشایە.‏\f* 
\q2 هەرچی پێ خۆش بێت بە بابلی دەکات، 
\q2 بازووشی لە دژی بابلییەکان دەبێت. 
\q1  
\v 15 من، من قسەم کرد و بانگم کرد، 
\q2 هێنام و ڕێگاکەشی سەرکەوتوو دەبێت. 
\p  
\v 16 «وەرنە پێش بۆ لام، گوێ لەمە بگرن: 
\q1 «لە سەرەتاوە بە نهێنی قسەم نەکرد، 
\q2 کاتێک ڕوودەدات، من لەوێم.» 
\b  
\q1 ئێستاش یەزدانی باڵادەست منی نارد 
\q2 لەگەڵ ڕۆحی خۆی. 
\b  
\q1  
\v 17 یەزدان، ئەوەی دەتانکڕێتەوە، پیرۆزەکەی ئیسرائیل، 
\q2 ئەمە دەفەرموێت: 
\q1 «من یەزدانی پەروەردگارتانم، 
\q2 فێرتان دەکەم بۆ ئەوەی سوود وەربگرن، 
\q2 بەو ڕێگایەدا دەتانبەم کە دەبێت بیگرنەبەر. 
\q1  
\v 18 خۆزگە گوێتان لە فەرمانەکانم دەگرت، 
\q2 جا ئاشتیتان وەک ڕووبار دەبوو، 
\q2 ڕاستودروستیشتان وەک شەپۆلی دەریا. 
\q1  
\v 19 نەوەکانتان وەک لم دەبوو، 
\q2 وەچەتان وەک دەنکی لم، 
\q1 ناویان لەبەردەمم نە دەبڕایەوە و 
\q2 نە لەناودەچوو.» 
\b  
\q1  
\v 20 لە بابل بچنە دەرەوە، 
\q2 لە بابلییەکان هەڵبێن! 
\q1 بە هاواری خۆشییەوە ڕایبگەیەنن، 
\q2 جاڕی ئەمە بدەن. 
\q1 سەرتاسەری زەوی لێ ئاگادار بکەنەوە، 
\q2 بڵێن: «یەزدان یاقوبی بەندەی کڕییەوە.» 
\q1  
\v 21 تینوو نەبوون کە بە چۆڵەوانیدا بردنی، 
\q2 لە تاشەبەردەوە ئاوی بۆ هەڵقوڵاندن، 
\q1 تاشەبەردی شەقکرد و 
\q2 ئاو تەقییەوە. 
\b  
\q1  
\v 22 یەزدان دەفەرموێت: «ئاشتی بۆ بەدکاران نییە.» 
\c 49  
\s1 بەندەی یەزدان 
\q1  
\v 1 ئەی دوورگەکان، گوێم لێ بگرن، 
\q2 ئەی نەتەوە دوورەکان، گوێ شل بکەن: 
\q1 یەزدان پێش لەدایکبوونم بانگی کردم، 
\q2 لەناو سکی دایکمەوە دیاری کردم. 
\q1  
\v 2 دەمی منی کرد بە شمشێرێکی تیژ، 
\q2 لە سێبەری دەستی خۆیدا منی شاردەوە، 
\q1 منی کردە تیرێکی تیژکراو، 
\q2 لەناو تیردانەکەی منی شاردەوە. 
\q1  
\v 3 بە منی فەرموو: «تۆ بەندەی منیت، 
\q2 ئیسرائیل، ئەوەی بەهۆیەوە شکۆی خۆم دەردەخەم.» 
\q1  
\v 4 منیش گوتم: «بەخۆڕایی ماندوو بووم، 
\q2 لە شتی هیچوپووچدا توانای خۆمم نەهێشت، 
\q1 بەڵام دادم لەلای یەزدانە و 
\q2 پاداشتم لای خودامە.» 
\b  
\q1  
\v 5 ئێستاش یەزدان ئەمە دەفەرموێت، 
\q2 یەزدان کە لە سکی دایکمەوە شێوەی منی کێشا، 
\q1 بۆ ئەوەی ببم بە بەندەی خۆی، 
\q2 تاوەکو یاقوب بۆ لای ئەو بگەڕێنمەوە و 
\q2 ئیسرائیلیش بخەمەوە پاڵ ئەو، 
\q1 جا لەبەرچاوی یەزدان شکۆمەند دەبم و 
\q2 خوداشم دەبێتە هێزم، 
\q1  
\v 6 ئەو دەفەرموێت: 
\q1 «ئەمە شتێکی کەمە بۆ تۆ کە بەندەی من بیت 
\q2 بۆ هەستانەوەی هۆزەکانی یاقوب و 
\q2 بۆ گەڕانەوەی ئەوانەی کە لە ئیسرائیل ئەوانم پاراست، 
\q1 بەڵکو دەتکەمە ڕووناکی بۆ نەتەوەکان 
\q2 تاکو ڕزگاریم بەوپەڕی زەوی بگەیەنیت\f + \fr 49:6 \ft بڕوانە \xt لۆقا 2‏:29‏-32.‏\ft ‏\f*.» 
\b  
\q1  
\v 7 یەزدان، پیرۆزەکەی ئیسرائیل، ئەوەی دەیکڕێتەوە، دەفەرموێت: 
\q2 بە گیان ڕیسواکراو، بەوەی مایەی ڕقی نەتەوەیە، 
\q1 بە خزمەتکاری فەرمانڕەواکان: 
\q2 «پاشایان دەبینن و هەڵدەستن، 
\q1 میرانیش کڕنۆش دەبەن، 
\q2 لەبەر یەزدان کە دڵسۆزە و 
\q2 لەبەر پیرۆزەکەی ئیسرائیل کە تۆی هەڵبژارد.» 
\s1 گەڕانەوەی ئیسرائیل 
\p  
\v 8 یەزدان ئەمە دەفەرموێت: 
\q1 «لە کاتی پەسەندیم وەڵامت دەدەمەوە، 
\q2 لە ڕۆژی ڕزگاریدا یارمەتیت دەدەم، 
\q1 جا دەتپارێزم و دەتکەمە پەیمان بۆ گەل، 
\q2 بۆ بوژاندنەوەی زەوی، 
\q2 بۆ بەمیراتکردنی میراتی چیاوچۆڵەکان، 
\q1  
\v 9 بە دیلەکان دەڵێت: ”وەرنە دەرەوە،“ 
\q2 بەوانەی لە تاریکیدان: ”ئازاد بن!“ 
\b  
\q1 «لەسەر ڕێگاکان دەلەوەڕێن، 
\q2 لەوەڕگاکانیان لەسەر هەموو گردۆڵکەیەکی ڕووتەنن. 
\q1  
\v 10 نە برسی دەبن و نە تینوو، 
\q2 نە گەرما لێیان دەدات و نە خۆر، 
\q1 چونکە ئەوەی بەزەیی پێیاندا دێتەوە، ڕێنماییان دەکات و 
\q2 بۆ سەر کانیاوەکانیان دەبات. 
\q1  
\v 11 هەموو چیاکانم دەکەم بە ڕێگا و 
\q2 ڕێڕەوەکانم بەرز دەبنەوە. 
\q1  
\v 12 ئەوەتا ئەمانە لە دوورەوە دێن و 
\q2 ئەوەتا ئەمانە لە باکوور و ڕۆژئاواوە و 
\q2 ئەمانەش لە ناوچەی ئەسوانەوە.» 
\b  
\q1  
\v 13 ئەی ئاسمان، هاواری خۆشی بکە، 
\q2 ئەی زەوی، شادمان بە! 
\q2 چیاکان دەکەونە ناو هاواری خۆشییەوە، 
\q1 چونکە یەزدان دڵنەوایی گەلی خۆی دەکات و 
\q2 بەزەیی بە زەلیلەکانیدا دێتەوە. 
\b  
\q1  
\v 14 بەڵام سییۆن گوتی: «یەزدان بەجێی هێشتم! 
\q2 پەروەردگار لەبیری کردم.» 
\b  
\q1  
\v 15 «چۆن دایک کۆرپەی شیرەخۆرەی خۆی لەبیر دەکات، 
\q2 یان بەزەیی بە بەری سکی خۆی نایەتەوە؟ 
\q1 تەنانەت ئەویش لەبیر دەکات، 
\q2 بەڵام من تۆ لەبیر ناکەم. 
\q1  
\v 16 ئەوەتا لەناو لەپم تۆم هەڵکۆڵیوە، 
\q2 هەمیشە شووراکانت لەبەرچاومن. 
\q1  
\v 17 کوڕەکانت خێرا دەگەڕێنەوە، 
\q2 ڕووخێنەران و تێکدەرانت لێت دەچنە دەرەوە. 
\q1  
\v 18 چاوهەڵبڕە بۆ دەوروبەرت و ببینە! 
\q2 هەموو کۆبوونەوە، هاتن بۆ لات.» 
\q1 یەزدان دەفەرموێت: «بە گیانی خۆم، 
\q2 تۆ هەموویان وەک خشڵ لەبەر دەکەیت، 
\q2 وەک بووک خۆت بەوان دەڕازێنیتەوە. 
\b  
\q1  
\v 19 «هەرچەندە بوویت بە شوێنێکی کەلاوە و وێران و 
\q2 خاکەکەشت ڕووخێنرا، 
\q1 بەڵام ئێستا تەنگ دەبیت بۆ دانیشتووان، 
\q2 لووشدەرانت دوور دەکەونەوە. 
\q1  
\v 20 ڕۆژێک لە ڕۆژان گوێت لێ دەبێت 
\q2 کە کوڕانی سەردەمی سک سووتاویت دەڵێن: 
\q1 ”ئەم جێیە تەنگە بۆمان، 
\q2 جێمان بکەرەوە با نیشتەجێ بین.“ 
\q1  
\v 21 لە دڵی خۆتدا دەڵێیت: 
\q2 ”کێ ئەمانەی بۆ من بوو 
\q1 کە من سک سووتاو و نەزۆکم، 
\q2 دوورخراوە و دەربەدەرم؟ 
\q2 ئەی کێ بەخێوی کردن؟ 
\q1 ئەوەتا من بە تەنها مابوومەوە، 
\q2 ئەمانە لەکوێ بوون؟“» 
\p  
\v 22 یەزدانی باڵادەست ئەمە دەفەرموێت: 
\q1 «ئەوەتا من دەست بۆ نەتەوەکان بەرز دەکەمەوە، 
\q2 بۆ گەلانیش ئاڵای خۆم بەرز دەکەمەوە، 
\q1 جا کوڕەکانت بە باوەش دەهێنن و 
\q2 کچەکانیشت لەسەر شانیان هەڵدەگرن. 
\q1  
\v 23 پاشاکان تۆ پەروەردە دەکەن، 
\q2 شاژنەکانیان دەبنە دایەنی تۆ، 
\q1 ڕوویان لە زەوی دەبێت، 
\q2 کڕنۆشت بۆ دەبەن و تۆزی پێیەکانت دەلێسنەوە، 
\q1 ئیتر تۆ دەزانیت کە من یەزدانم. 
\q2 ئەوانەی شەرمەزار نابن ئەوانەن چاوەڕوانی منن.» 
\b  
\q1  
\v 24 ئایا دەستکەوت لە پاڵەوان دەبردرێت؟ 
\q2 ئایا ڕاپێچکراو لە دەستی ستەمکار دەربازی دەبێت؟ 
\p  
\v 25 بەڵام یەزدان ئەمە دەفەرموێت: 
\q1 «تەنانەت ڕاپێچ لە چنگی پاڵەوانیش دەبردرێت، 
\q2 دەستکەوت لە چنگی زۆرداریش دەرباز دەبێت. 
\q1 من دژایەتی دژەکانت دەکەم و 
\q2 من منداڵەکانت ڕزگار دەکەم. 
\q1  
\v 26 وا دەکەم ستەمکارانت گۆشتی خۆیان بخۆن و 
\q2 وەک شەرابی شیرین، بە خوێنی خۆیان سەرخۆش بن. 
\q1 جا هەموو مرۆڤ دەزانێت 
\q2 من کە یەزدانم ڕزگارکەری تۆم، 
\q2 ئەوەش کە دەتکڕێتەوە توانادارەکەی یاقوبە.» 
\c 50  
\s1 گوناهی ئیسرائیل و ملکەچی بەندە 
\p  
\v 1 یەزدان ئەمە دەفەرموێت: 
\q1 «کوا تەڵاقنامەی دایکتان 
\q2 ئەوەی کە من بەڕەڵام کرد پێی؟ 
\q1 یان خاوەن قەرزەکانم کێن، 
\q2 ئەوانەی ئێوەم پێی فرۆشتووە؟ 
\q1 ئەوەتا لەبەر تاوانەکانتان فرۆشران، 
\q2 لەبەر یاخیبوونەکانتان دایکتان بەڕەڵا کرا. 
\q1  
\v 2 بۆچی هاتم و کەس نەبوو؟ 
\q2 بانگم کرد و کەس وەڵامی نەدایەوە؟ 
\q1 ئایا دەستکورت بووم لە کڕینەوە؟ 
\q2 ئایا توانای فریاکەوتنم نییە؟ 
\q1 ئەوەتا بە ڕاخوڕینم دەریا وشک دەکەم، 
\q2 ڕووبارەکان دەکەم بە چۆڵەوانی، 
\q1 لەبەر بێ ئاوی ماسییەکانی بۆگەن دەبن، 
\q2 لە تینووان دەمرن. 
\q1  
\v 3 تاریکی دەکەمە بەر ئاسمان، 
\q2 گوش دەکەم بە پۆشاکی.» 
\b  
\q1  
\v 4 یەزدانی باڵادەست زمانی فێربووانی پێم بەخشی 
\q2 بۆ ئەوەی بزانم کە چۆن بە قسە یارمەتی ماندوو بدەم. 
\q1 هەموو بەیانییەک بەخەبەرم دەهێنێتەوە، 
\q2 گوێی من بەئاگا دەهێنێت 
\q2 بۆ سەرنجدان وەک قوتابی. 
\q1  
\v 5 یەزدانی باڵادەست گوێیەکانی منی کردەوە، 
\q2 منیش یاخی نەبووم، 
\q2 بەرەو دوا هەڵنەگەڕامەوە. 
\q1  
\v 6 پشتم ڕاگرت بۆ ئەوەی لێی بدەن، 
\q2 ڕوومەتیشم بۆ ئەوەی ڕیشم بڕننەوە. 
\q1 ڕووی خۆمم دانەپۆشی لە 
\q2 گاڵتەپێکردن و تفلێکردن. 
\q1  
\v 7 لەبەر ئەوەی یەزدانی باڵادەست یارمەتیم دەدات، 
\q2 ڕیسوا نابم، 
\q1 لەبەر ئەوە ڕووی خۆمم وەک بەردەئەستێ لێکرد، 
\q2 دەزانم شەرمەزار نابم. 
\q1  
\v 8 ئەوەی بێتاوانم دەکات نزیکە، 
\q2 کێ سکاڵا لە من دەکات؟ 
\q2 با پێکەوە ڕابوەستین، 
\q1 کێ خاوەنی سکاڵایە لە دژی من؟ 
\q2 با لێم بێتە پێش! 
\q1  
\v 9 ئەوەتا یەزدانی باڵادەست یارمەتیم دەدات، 
\q2 ئیتر کێ تاوانبارم دەکات؟ 
\q1 ئەوەتا هەموویان وەک کراس دادەڕزێن، 
\q2 مۆرانە دەیانخوات. 
\b  
\q1  
\v 10 کێ لە ئێوە لە یەزدان دەترسێت و 
\q2 گوێڕایەڵی بەندەکەی دەبێت؟ 
\q1 ئەوەی بە تاریکیدا دەڕوات و 
\q2 ڕووناکی نابینێت، 
\q1 با پشت بە ناوی یەزدان ببەستێت و 
\q2 پاڵ بداتە پاڵ خودای خۆی. 
\q1  
\v 11 بەڵام ئەی هەموو ئەوانەی ئاگر دەکەنەوە، 
\q2 مەشخەڵ داگیرسێنن، 
\q1 بڕۆن بە ڕووناکی ئاگرەکەی خۆتان و 
\q2 بەو مەشخەڵانەی داتانگیرساند. 
\q1 لە دەستی منەوە ئەمەتان بۆ دەبێت 
\q2 لەناو ئازاردا ڕادەکشێن. 
\c 51  
\s1 ڕزگاریی هەتاهەتایی بۆ ئیسرائیل 
\q1  
\v 1 «ئەی ئەوانەی دوای ڕاستودروستی کەوتوون، گوێم لێ بگرن، 
\q2 ئەی ئەوانەی ڕوو لە یەزدان دەکەن: 
\q1 تەماشای ئەو تاشەبەردە بکەن کە لێوەی بڕاون و 
\q2 کونی ئەو چاڵەی لێوەی هەڵکەنراون، 
\q1  
\v 2 تەماشای ئیبراهیمی باوکتان بکەن، 
\q2 بڕواننە سارا، ئەوەی ئێوەی بووە، 
\q1 چونکە کە بانگم کرد تەنها یەک کەس بوو، 
\q2 بەرەکەتدارم کرد و زۆرم کرد. 
\q1  
\v 3 بێگومان یەزدان دڵنەوایی سییۆن دەکات، 
\q2 دڵنەوایی هەموو کاولبووەکانی دەکات. 
\q1 چۆڵەوانییەکانی وەک عەدەن لێ دەکات و 
\q2 شیوە وشکەکانی وەک باخچەی یەزدان. 
\q1 شادی و خۆشی تێدا دەبینرێتەوە، 
\q2 سوپاس و دەنگی مۆسیقا. 
\b  
\q1  
\v 4 «ئەی گەلی من، گوێم لێ بگرن، 
\q2 ئەی نەتەوەکەم، گوێم بۆ شل بکەن، 
\q1 چونکە فێرکردن لەلای منەوە دەردەچێت و 
\q2 دادپەروەریم بۆ ڕووناکی گەلان دەچەسپێنم. 
\q1  
\v 5 ڕاستودروستیم نزیکە، 
\q2 ڕزگاریم بەڕێوەیە، 
\q2 بازووی من دادوەری بۆ گەلان دەکات. 
\q1 دوورگەکان چاوەڕێی منن، 
\q2 هیوایان بە بازووی منە. 
\q1  
\v 6 چاوتان بۆ ئاسمان هەڵبڕن و 
\q2 لە ژێرەوە سەیری زەوی بکەن، 
\q1 چونکە ئاسمان وەک دووکەڵ دەڕەوێتەوە و 
\q2 زەوی وەک جل دادەڕزێت و 
\q2 دانیشتووانەکەی وەک مێشوولە دەمرن. 
\q1 بەڵام ڕزگاریی من بۆ هەتاهەتایە دەبێت، 
\q2 ڕاستودروستیشم هەرگیز ناڕووخێت. 
\b  
\q1  
\v 7 «ئەی ئەوانەی ڕاستودروستی دەزانن، گوێم لێ بگرن، 
\q2 ئەی ئەو گەلەی فێرکردنەکەم لەناو دڵیانە: 
\q1 مەترسن لەوەی خەڵکی گاڵتەتان پێ بکەن، 
\q2 لە جنێوەکانیان مەتۆقن، 
\q1  
\v 8 چونکە وەک کراس مۆرانە دەیانخوات و 
\q2 وەک خوری کرم لێیان دەدات، 
\q1 بەڵام ڕاستودروستی من بۆ هەتاهەتایە دەبێت و 
\q2 ڕزگاریشم بۆ نەوەی نەوەکان.» 
\b  
\q1  
\v 9 بەئاگا بە، بەئاگا بە! هێز لەبەر بکە، 
\q2 ئەی بازووی یەزدان، 
\q1 بەئاگا بە وەک لە ڕۆژگارە دێرینەکان، 
\q2 وەک لە سەردەمانی پێشوو! 
\q1 ئایا تۆ نەبوویت کە ڕەهەڤت لەتکرد، 
\q2 کە ئەو ئەژدیهایەت بە سەختی پێکا؟ 
\q1  
\v 10 ئایا تۆ نەبوویت دەریات وشک کرد، 
\q2 ئاوی دەریا گەورەکەی ژێر زەوی\f + \fr 51:10 \ft بەپێی بیروباوەڕی خەڵکی ڕۆژهەڵاتی کۆن (دەریای ژێر زەوی) هەبوو کە لەژێر زەوی بوو و سەرچاوەی کانیاو و ڕووبارەکان بوو.‏\f*، 
\q1 ئەوەی قووڵایی دەریای کردە ڕێگا 
\q2 بۆ پەڕینەوەی ئەوانەی کڕاونەتەوە؟ 
\q1  
\v 11 جا ئەوانەی یەزدان کڕیونیەتیەوە دەگەڕێنەوە، 
\q2 بە هاواری خۆشییەوە بۆ سییۆن دێن، 
\q2 شادییەکی هەتاهەتایی لەسەر سەریانە. 
\q1 خۆشی و شادی پێیان دەگەن و 
\q2 ناخۆشی و ئاخ هەڵکێشان هەڵدێن. 
\b  
\q1  
\v 12 «منم، منم کە دڵنەواییتان دەکەم. 
\q2 تۆ کێیت لە مرۆڤ دەترسیت کە دەمرێت، 
\q2 یاخود لە ئادەمیزاد کە وەک گیای لێدێت؟ 
\q1  
\v 13 تۆ کێیت تاوەکو یەزدان لەیاد بکەیت کە دروستی کردوویت، 
\q2 کە ئاسمانی لێککردووەتەوە و 
\q2 زەوی دامەزراندووە، 
\q1 کە بەردەوام هەموو ڕۆژێک زەندەقت چووە 
\q2 لە تووڕەیی ستەمکار، 
\q2 کە ئامادەی کردووە بۆ لەناوبردن؟ 
\q1 بەڵام کوا تووڕەیی ستەمکار؟ 
\q2  
\v 14 بەم نزیکانە گەلە دیلەکە ئازاد دەکرێن، 
\q1 لەناو زیندان نامرن، 
\q2 نانیان کەم نابێت، 
\q1  
\v 15 چونکە من یەزدانی پەروەردگارتانم، 
\q2 ئەوەی دەریا دەهەژێنێت و شەپۆلەکانی دەوروژێنێت، 
\q2 ناوم یەزدانی سوپاسالارە. 
\q1  
\v 16 من وتەکانم خستووەتە دەمی تۆوە و 
\q2 بە سێبەری دەستم تۆم شاردووەتەوە، 
\q1 من کە ئاسمانم لە شوێنی خۆی دانا و 
\q2 زەویم دامەزراند، 
\q2 کە بە سییۆن دەڵێم: ”تۆ گەلی منیت.“» 
\s1 جامی تووڕەیی یەزدان 
\q1  
\v 17 بەئاگا بە! بەئاگا بە! 
\q2 ئۆرشەلیم هەستە! 
\q1 ئەوەی جامی تووڕەییت 
\q2 بە دەستی یەزدان خواردەوە، 
\q1 خڵتی جامی بەلاداهاتنت 
\q2 خواردەوە و چۆڕاندتەوە. 
\q1  
\v 18 کەس نییە ڕێنمایی بکات 
\q2 لە هەموو ئەو کوڕانەی بۆی لەدایک بوون، 
\q1 کەس نییە دەستی بگرێت 
\q2 لە هەموو ئەو کوڕانەی بەخێوی کردن. 
\q1  
\v 19 کارەساتەکان بە جووت بە پیرتەوە هاتوون، 
\q2 کاولبوون و وردوخاشبوون، قاتوقڕی و شمشێر. 
\q1 کێ دەتوانێت بۆت بلاوێنێتەوە؟ 
\q2 کێ دەتوانێت دڵنەواییت بکات؟ 
\q1  
\v 20 کوڕەکانت گرمۆڵە بوون و ڕاکشان 
\q2 لەسەر سووچی هەموو شەقامێک 
\q2 وەک ئاسک لەناو تۆڕدا. 
\q1 پڕن لە تووڕەیی یەزدان و 
\q2 لە سەرزەنشتی خودات. 
\b  
\q1  
\v 21 لەبەر ئەوە ئێستا گوێ لەمە بگرە ئەی زەلیلەکە، 
\q2 ئەی سەرخۆش، بەبێ شەراب سەرخۆش بوویت. 
\q1  
\v 22 یەزدانی باڵادەستت ئەمە دەفەرموێت، 
\q2 خوداکەت کە پشتگیری گەلەکەی خۆی دەکات: 
\q1 «ئێستا ئەو جامە لە دەستت دەبەم کە وا دەکات بەلادابێیت، 
\q2 لەمەودوا لەو جامەی کە جامی تووڕەیی منە ناخۆیتەوە. 
\q1  
\v 23 دامە دەست ئەشکەنجەدەرانت، 
\q2 ئەوانەی بە گیانی تۆیان گوت: 
\q2 ”بچەمێوە بۆ ئەوەی بپەڕینەوە.“ 
\q1 جا پشتت وەک زەوی دانا، 
\q2 وەک شەقام بۆ ئەوانەی دەپەڕنەوە.» 
\b  
\b  
\c 52  
\q1  
\v 1 ئەی سییۆن، بەئاگا بە! بەئاگا بە! 
\q2 بەرگی هێزت لەبەر بکە، 
\q1 ئەی ئۆرشەلیم، شاری پیرۆز، 
\q2 بەرگی جوانیت بپۆشە، 
\q1 چونکە ئیتر لەمەودوا نایەتە ناوت 
\q2 خەتەنەنەکراو و گڵاو. 
\q1  
\v 2 ئەی ئۆرشەلیم، لەناو خۆڵ هەستە و 
\q2 خۆت بتەکێنە، لەسەر تەخت دابنیشە. 
\q1 ئەی ڕاپێچکراوەکە، شاری سییۆن، 
\q2 کۆتەکانی ملت بکەرەوە. 
\p  
\v 3 ئێستا یەزدان ئەمە دەفەرموێت: 
\q1 «بەخۆڕایی فرۆشران، 
\q2 بەبێ پارە دەکڕدرێنەوە.» 
\p  
\v 4 هەروەها یەزدانی باڵادەست ئەمە دەفەرموێت: 
\q1 «سەرەتا گەلەکەم دابەزین بۆ میسر و ئاوارەبوون لەوێ، 
\q2 لەم دواییانەشدا ئاشور ستەمی لێدەکرد.» 
\p  
\v 5 یەزدان دەفەرموێت: «ئێستا لێرە چیم هەیە؟ 
\q1 «گەلەکەم بەخۆڕایی بردرا و 
\q2 فەرمانڕەواکانی دەلوورێنن، 
\q1 بەردەوام بە درێژایی ڕۆژیش 
\q2 کفر بە ناوی من دەکرێت. 
\q1  
\v 6 لەبەر ئەوە گەلەکەم بە ناوی من ئاشنا دەبن، 
\q2 لەو ڕۆژەدا دەزانن 
\q1 ئەوەتام، ئەوە منم کە ئەم بەڵێنە دەدەم.» 
\q4 یەزدان دەفەرموێت. 
\b  
\q1  
\v 7 چەند جوانە لەسەر چیاکان 
\q2 پێیەکانی مزگێنیدەران، 
\q1 ڕاگەیەنەری ئاشتی، 
\q2 مزگێنیدەری خۆشی، 
\q2 ڕاگەیەنەری ڕزگاری، 
\q1 ئەوانەی بە سییۆن دەڵێن: 
\q2 «خودات پاشایەتی دەکات!» 
\q1  
\v 8 گوێ بگرە! ئێشکگرەکانت دەنگیان هەڵدەبڕن، 
\q2 پێکەوە هاواری خۆشی دەکەن، 
\q1 بە چاوی خۆیان دەبینن 
\q2 کاتێک یەزدان دەگەڕێتەوە بۆ سییۆن. 
\q1  
\v 9 ئەی کەلاوەکانی ئۆرشەلیم، 
\q2 پێکەوە بە خۆشی گۆرانی بڵێن، 
\q1 چونکە یەزدان دڵنەوایی گەلەکەی خۆی دەکات، 
\q2 بێگومان ئۆرشەلیم دەکڕێتەوە. 
\q1  
\v 10 یەزدان بازووی پیرۆزی خۆی هەڵدەکات 
\q2 لەبەرچاوی هەموو نەتەوەکان، 
\q1 هەر چوار لای زەویش 
\q2 ڕزگاریی خودای ئێمە دەبینن. 
\b  
\q1  
\v 11 ئەی هەڵگرانی کەلوپەلی پەرستگای یەزدان، 
\q2 جیا بنەوە، جیا بنەوە، لە بابل بچنە دەرەوە! 
\q1 دەست لە هیچ شتێکی گڵاو مەدەن! 
\q2 لەناوی وەرنە دەرەوە، خۆتان پاک بکەنەوە! 
\q1  
\v 12 بەڵام بە پەلە دەرناچن، 
\q2 بە هەڵاتن ناڕۆن، 
\q1 چونکە یەزدان لەبەردەمتانەوە دەڕوات، 
\q2 خودای ئیسرائیل پاشڕەو و پارێزەرتانە. 
\s1 ئازارچێژتنی بەندەی یەزدان 
\q1  
\v 13 ببینە، بەندەکەم وا بە وریاییەوە هەڵسوکەوت دەکات، 
\q2 بەرز و بڵند و زۆر پایەبەرز دەبێت. 
\q1  
\v 14 وەک ئەوەی زۆر کەس واقیان لێی وڕما، 
\q2 دیمەنی وەک مرۆڤ نەبوو، 
\q2 وێنەی لە ئادەمیزاد نەدەچوو، 
\q1  
\v 15 ئاوا زۆر لە نەتەوەکان لێی سەرسام دەبن، 
\q2 لەبەر ئەو پاشایان دەمی خۆیان دەگرن، 
\q1 چونکە ئەوەی بۆیان باس نەکرابوو دەیبینن، 
\q2 ئەوەی نەیانبیستبوو تێی دەگەن. 
\b  
\c 53  
\q1  
\v 1 کێ باوەڕی بە پەیامەکەمان کرد و 
\q2 هێزی یەزدان بۆ کێ دەرکەوت؟ 
\q1  
\v 2 بەندەکە وەک چەکەرە لەبەردەمی باڵای کرد، 
\q2 وەک ڕەگ لە خاکێکی تینوو گەشەی کرد. 
\q1 نە جوانی هەبوو و نە پایەبەرزی تاوەکو سەرنجمان بۆی بچێت، 
\q2 نە دیمەن تاوەکو ئارەزووی بکەین. 
\q1  
\v 3 ڕیسوا و سووک لەلایەن خەڵکەوە، 
\q2 پیاوی ئازار و شارەزای ناخۆشی. 
\q1 وەک یەکێک خەڵک ڕووی خۆیانی لێ بشارنەوە، 
\q2 ڕیسوا بوو و بە هیچمان نەزانی. 
\b  
\q1  
\v 4 بە دڵنیاییەوە دەردەکانی ئێمەی هەڵگرت، 
\q2 ئازارەکانی ئێمەی برد، 
\q1 ئێمەش وامانزانی لەلایەن خوداوە گورزی بەرکەوتووە، 
\q2 لێی دراوە و زەلیلە. 
\q1  
\v 5 بەڵام ئەو لەبەر یاخیبوونەکانمان بریندار بوو، 
\q2 لەبەر تاوانەکانمان وردوخاشکرا. 
\q1 ئەو لە پێناوی ئاشتبوونەوەی ئێمە سزای چێژت، 
\q2 بە برینەکانی ئەو چاک بووینەوە. 
\q1  
\v 6 هەموومان وەک مەڕ وێڵ و سەرگەردان بووین، 
\q2 هەریەکەمان ملی ڕێگای خۆی گرتووە، 
\q1 بەڵام یەزدان هەموو تاوانەکانی ئێمەی 
\q2 خستە سەر ئەو. 
\b  
\q1  
\v 7 زەلیل کرا و ستەمیان لێکرد، 
\q2 بەڵام دەمی نەکردەوە. 
\q1 ئەو وەک بەرخ بۆ سەربڕین بردرا، 
\q2 وەک چۆن مەڕێک لەبەردەستی ئەوانەی خورییەکەی دەبڕنەوە بێدەنگە، 
\q2 ئەو دەمی نەکردەوە. 
\q1  
\v 8 بە ستەم و حوکم بەسەردادان بردرا. 
\q2 بەڵام کێ لە نەوەی سەردەمی خۆی لە دژی وەستایەوە؟ 
\q1 چونکە لە جیهانی زیندووان هەڵگیرا، 
\q2 لەبەر یاخیبوونی گەلەکەم ئەو لێی درا. 
\q1  
\v 9 گۆڕی لەگەڵ بەدکاران دانرا، 
\q2 دوای مردنی لە گۆڕی دەوڵەمەندێک نێژرا، 
\q1 هەرچەندە ستەمکاری نەکرد و 
\q2 فڕوفێڵی لەسەر زار نەبوو. 
\b  
\q1  
\v 10 بەڵام خواستی یەزدان بوو وردوخاشی بکات و ئازار بکێشێت، 
\q2 لەگەڵ ئەوەشدا یەزدان ژیانی کرد بە قوربانیی تاوان، 
\q1 نەوە و ڕۆژگاری درێژ دەبینێت، 
\q2 خواستی یەزدان بە دەستی ئەو سەردەکەوێت. 
\q1  
\v 11 لەدوای ئەو ئازارەی بەرگەی گرت، 
\q2 ڕووناکی ژیان دەبینێت و تێر دەبێت، 
\q1 بەندە ڕاستودروستەکەم بە ئەزموونی خۆی زۆر کەس بێتاوان دەکات و 
\q2 ئەو تاوانەکانیان هەڵدەگرێت. 
\q1  
\v 12 لەبەر ئەوە لەگەڵ مەزنەکان بەشی دەدەم، 
\q2 لەگەڵ بەهێزەکان دەستکەوت بەش دەکات، 
\q1 چونکە ژیانی خۆی بەخت کرد و 
\q2 لەگەڵ یاخیبووان ژمێردرا، 
\q1 لەبەر ئەوەی گوناهی زۆر کەسی هەڵگرت و 
\q2 داکۆکی لە یاخیبووان کرد. 
\c 54  
\s1 شکۆی داهاتوو بۆ سییۆن 
\q1  
\v 1 «ئەی نەزۆک، گۆرانی بڵێ، 
\q2 ئەی ئەوەی منداڵت نەبووە، 
\q1 ئەی ئەوەی ژانت نەگرتووە، 
\q2 لە خۆشیدا هاوار بکە و گۆرانی بڵێ، 
\q1 چونکە منداڵی ژنی بەجێهێڵراو 
\q2 زیاترن لەوەی مێردی لەگەڵیەتی،» 
\q4 یەزدان دەفەرموێت. 
\q1  
\v 2 «شوێنی ڕەشماڵەکانت فراوان بکە، 
\q2 پەردەی نشینگەکانت لێک بکەرەوە، 
\q2 دەست مەگێڕەوە، 
\q1 گوریسەکانت درێژ بکە و 
\q2 سنگەکانت توند بچەقێنە، 
\q1  
\v 3 چونکە بەلای ڕاست و چەپدا پەل دەهاوێیت، 
\q2 نەوەی تۆ نەتەوەکان دەردەکەن و 
\q2 شارە وێرانەکان ئاوەدان دەکەنەوە. 
\b  
\q1  
\v 4 «مەترسە، چونکە ڕیسوا نابیت. 
\q2 گاڵتەت پێ ناکرێت، چونکە شەرمەزار نابیت. 
\q1 ڕیسوایی سەردەمی گەنجیێتیت لەبیر دەکەیت، 
\q2 ئیتر شورەیی بێوەژنیێتیت بەبیر نایەتەوە، 
\q1  
\v 5 چونکە مێردی\f + \fr 54:5 \ft پەیوەندی نێوان خودا و گەلەکەی بە پەیوەندی نێوان ژن و مێرد دەچووێنرێت، لە ڕووی ئەرک و وەفا و گوێڕایەڵییەوە.‏\f* تۆ دروستکەرەکەی تۆیە، 
\q2 ناوی یەزدانی سوپاسالارە. 
\q1 ئەوەی دەتکڕێتەوە پیرۆزەکەی ئیسرائیلە، 
\q2 پێی دەگوترێت خودای هەموو زەوی. 
\q1  
\v 6 وەک ژنێکی بەجێماو و ڕۆح پڕ لە ژان 
\q2 یەزدان بانگت دەکاتەوە، 
\q1 وەک ژنێک کە لە گەنجیدا شووی کردبێت و ڕەتکرابێتەوە،» 
\q2 خودات دەفەرموێت. 
\q1  
\v 7 «بۆ ساتێکی کەم بەجێم هێشتیت، 
\q2 بەڵام بە بەزەییەکی زۆرەوە کۆت دەکەمەوە. 
\q1  
\v 8 بە زریانی تووڕەییەوە 
\q2 بۆ ساتێک ڕووی خۆمم لێت داپۆشی، 
\q1 بەڵام بە خۆشەویستی نەگۆڕی هەتاهەتایی 
\q2 بەزەییم پێتدا هاتەوە،» 
\q2 ئەوە فەرمایشتی یەزدانە، ئەوەی دەتکڕێتەوە. 
\b  
\q1  
\v 9 «ئەمە وەک لافاوی نوحە بۆ من 
\q2 ئەوەی سوێندم خوارد، کە لافاوەکەی نوح جارێکی دیکە بەسەر زەویدا تێنەپەڕێت. 
\q1 ئاوا سوێندم خوارد، کە لێت تووڕە نەبم و 
\q2 لێت ڕانەخوڕم. 
\q1  
\v 10 هەرچەندە چیاکان نامێنن و 
\q2 گردەکان دەهەژێن، 
\q1 بەڵام خۆشەویستی نەگۆڕی من بۆ تۆ دەمێنێت و 
\q2 پەیمانی ئاشتیم ناهەژێت،» 
\q1 ئەوە فەرمایشتی یەزدانە، ئەوەی بەزەیی پێتدا دێتەوە. 
\b  
\q1  
\v 11 «ئەی شارە زەلیلەکە، زریان لێدراوەکە، دڵنەوایی نەکراوەکە، 
\q2 ئەوەتا من بەردەکانت بە بەردە پیرۆزە\f + \fr 54:11 \ft بەردە پیرۆزە: بەردێکی شینی سەوزباو.‏\f* لەسەر ڕیز دەکەم، 
\q2 بە یاقووتی شین\f + \fr 54:11 \ft یاقووتی شین: دەشێت لاجیوەرد بێت.‏\f* داتدەمەزرێنم. 
\q1  
\v 12 قوللەکانت دەکەم بە یاقووت\f + \fr 54:12 \ft یاقووت: گەوهەری سووری تێر.‏\f* و 
\q2 دەروازەکانیشت بە بەردی پڕشنگدار، 
\q2 هەموو سنوورەکانیشت بە بەردی گرانبەها. 
\q1  
\v 13 هەموو منداڵەکانت لە یەزدانەوە فێر دەبن و 
\q2 ئاشتی منداڵەکانت زۆر دەبێت. 
\q1  
\v 14 بە ڕاستودروستی دەچەسپێیت 
\q1 دوور لە جەوروستەم، 
\q2 چونکە هیچ هۆیەک نییە بۆ ئەوەی بترسیت، 
\q1 هەروەها دووریت لە تۆقینیش، 
\q2 چونکە لێت نزیک ناکەوێتەوە. 
\q1  
\v 15 ئەگەر پەلامار درایت، ئەوە لەلایەن منەوە نابێت، 
\q2 ئەوەی هێرش دەکاتە سەرت، دەبێتە ژێر دەستت. 
\b  
\q1  
\v 16 «ئەوەتا من ئاسنگەرم بەدیهێنا 
\q2 کە کوورەی ئاگری خەڵووز دەم دەدات، 
\q2 چەکی گونجاو دروستدەکات، 
\q1 هەروەها من لەناوبەرم بەدیهێنا بۆ ئەوەی بفەوتێنێت. 
\q2  
\v 17 هەر چەکێک لە دژی تۆ شێوەی بکێشرێت سەرناکەوێت و 
\q2 هەر زمانێک لە دادگا لە دژی تۆ ڕادەوەستێت بەرپەرچی دەدەیتەوە. 
\q1 ئەمە میراتی خزمەتکارانی یەزدانە، 
\q2 بێتاوانیتان لەلایەن منەوەیە،» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\c 55  
\s1 بانگهێشتکردنی تینووەکان 
\q1  
\v 1 «هۆ ئەی هەموو تینووەکان، وەرن، 
\q2 وەرن بۆ ئاو\f + \fr 55:1 \ft ئاو: هێمایە بۆ ژیان و بەزەیی خودا.‏\f*، 
\q1 ئەوانەش کە پارەیان نییە، 
\q2 وەرن، بکڕن و بخۆن! 
\q1 وەرن ئێوە پارە مەدەن، بەبێ نرخ 
\q2 شەراب و شیر بکڕن. 
\q1  
\v 2 بۆچی پارە بە شتێک بەهەدەر دەدەن کە نان نییە؟ 
\q2 بۆچی کارێک دەکەن لە پێناوی شتێک کە تێرتان ناکات؟ 
\q1 بە تەواوی گوێم لێ بگرن و ئەوە بخۆن کە باشە، 
\q2 با گیانتان تام لە چەوری وەربگرێت. 
\q1  
\v 3 گوێتان شل بکەن و وەرنە لام، 
\q2 گوێ بگرن بۆ ئەوەی گیانتان بژیێت. 
\q1 پەیمانی هەتاهەتاییتان لەگەڵدا دەبەستم، 
\q2 خۆشەویستی نەگۆڕ و چەسپاوم بۆ داود. 
\q1  
\v 4 ئەوەتا کردم بە شایەت بەسەر نەتەوەکانەوە، 
\q2 ڕابەر و فەرماندە بۆ نەتەوەکان. 
\q1  
\v 5 ئەوەتا ئەو نەتەوانەی نایانناسیت بانگیان دەکەیت و 
\q2 ئەو نەتەوانەی ناتناسن بۆ لات ڕادەکەن، 
\q1 لەبەر یەزدانی پەروەردگارت، 
\q2 لەبەر پیرۆزەکەی ئیسرائیل، 
\q2 چونکە شکۆمەندی کردیت.» 
\b  
\q1  
\v 6 ڕووتان لە یەزدان بکەن هەتا کاتی ماوە، 
\q2 لێی بپاڕێنەوە کە هێشتا نزیکە. 
\q1  
\v 7 با بەدکار واز لە ڕێگای خۆی بهێنێت و 
\q2 خراپەکاریش لە بیرکردنەوەکانی، 
\q1 با بگەڕێتەوە لای یەزدان، ئەویش بەزەیی پێدا بێتەوە، 
\q2 بۆ لای خودامان، چونکە زۆر لێبوردەیە. 
\b  
\q1  
\v 8 «بێگومان بیرکردنەوەی من بیرکردنەوەی ئێوە نییە و 
\q2 ڕێگاکانی ئێوەش ڕێگاکانی من نین،» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\q1  
\v 9 «هەروەک بەرزیی ئاسمان لە زەوییەوە، 
\q2 ئاوا بەرزە ڕێگاکانم بەسەر ڕێگاکانتاندا و 
\q2 بیرکردنەوەم بەسەر بیرکردنەوەتان. 
\q1  
\v 10 هەروەک چۆن باران و بەفر 
\q2 لە ئاسمانەوە دێنە خوارەوە و 
\q1 ناگەڕێنەوە ئەوێ، 
\q2 بەڵکو زەوی ئاو دەدەن و 
\q1 وای لێ دەکەن بەرهەم بدات و ڕووەکی لێ بڕووێت و 
\q2 تۆو بدات بۆ تۆوکردن و نان بۆ خواردن، 
\q1  
\v 11 فەرمایشتەکەم ئاوا دەبێت کە لە دەممەوە دێتە دەرەوە: 
\q2 بە بەتاڵی ناگەڕێتەوە بۆم، 
\q1 بەڵکو ئەوەی من پێم خۆشە دەیکات و 
\q2 سەرکەوتوو دەبێت لەوەی بۆی دەنێرم. 
\q1  
\v 12 ئەو کاتە بە خۆشییەوە دەچنە دەرەوە و 
\q2 بە ئاشتییەوە ڕابەرایەتیتان دەکرێت، 
\q1 چیاکان و گردەکان 
\q2 لەبەردەمتان دەکەونە هاواری خۆشییەوە، 
\q1 هەموو دارەکانی دەشتودەریش 
\q2 بە دەست چەپڵە لێ دەدەن. 
\q1  
\v 13 لە جێی دڕک سنەوبەر دەڕوێت و 
\q2 لە جێی چقڵیش مۆرد دەڕوێت، 
\q1 بۆ یەزدان دەبێت بە ناوێک، 
\q2 نیشانەیەکی هەتاهەتایی 
\q2 کە لەناو ناچێت.» 
\c 56  
\s1 ڕزگاری بۆ ئەوانەی دوورن 
\p  
\v 1 یەزدان ئەمە دەفەرموێت: 
\q1 «دادپەروەری بپارێزن و 
\q2 ڕاستودروستی ئەنجام بدەن، 
\q1 چونکە بەم نزیکانە ڕزگاریم دێت و 
\q2 ڕاستودروستیم ئاشکرا دەبێت. 
\q1  
\v 2 خۆزگە بەو مرۆڤەی ئەمە دەکات و 
\q2 بەو ئادەمیزادەی توند دەستی پێوە دەگرێت، 
\q1 ئەوەی ڕۆژی شەممە لە گڵاوبوون دەپارێزێت و 
\q2 دەستی دەپارێزێت لە کردنی هەموو خراپەیەک.» 
\b  
\q1  
\v 3 با ئەو بیانییەی خۆی داوەتە پاڵ یەزدان نەڵێت: 
\q2 «یەزدان بە تەواوی جیام دەکاتەوە لە گەلەکەی.» 
\q1 با خەساویش نەڵێت: 
\q2 «ئەوەتا من تەنها دارێکی وشکم.» 
\p  
\v 4 لەبەر ئەوەی یەزدان ئەمە دەفەرموێت: 
\q1 «ئەو خەساوانەی ڕۆژەکانی شەممەم دەپارێزن، 
\q2 ئەوە هەڵدەبژێرن کە دڵم پێی خۆشە و 
\q2 دەستیان بە پەیمانەکەمەوە گرتووە، 
\q1  
\v 5 لەناو پەرستگای خۆم و دیوارەکانی 
\q2 یادەوەری و ناویان پێدەدەم، 
\q2 لە کوڕان و لە کچان باشترن بۆیان. 
\q1 ناوێکی هەتاهەتاییان پێدەدەم 
\q2 کە نابڕدرێتەوە. 
\q1  
\v 6 ئەو بیانییانەش کە خۆیان داوەتە پاڵ یەزدان 
\q2 بۆ پەرستنی و 
\q1 بۆ خۆشویستنی ناوی یەزدان 
\q2 هەتا بۆی ببن بە بەندە، 
\q1 هەموو ئەوانەی ڕۆژی شەممە لە گڵاوبوون دەپارێزن و 
\q2 دەستیان بە پەیمانەکەمەوە گرتووە 
\q1  
\v 7 دەیانهێنمە کێوی پیرۆزم، 
\q2 لە ماڵی نوێژم دڵخۆشیان دەکەم. 
\q1 قوربانی سووتاندن و سەربڕاویان 
\q2 مایەی ڕەزامەندین لەسەر قوربانگاکەم، 
\q1 چونکە ماڵەکەم بە ماڵی نوێژ ناودەبردرێت 
\q2 بۆ هەموو گەلان.» 
\q1  
\v 8 یەزدانی باڵادەست، 
\q2 ئەوەی دوورخراوەکانی ئیسرائیل کۆدەکاتەوە، دەفەرموێت: 
\q1 «زیاتر کۆدەکەمەوە 
\q2 لەگەڵ ئەوانەی کە کۆمکردوونەتەوە.» 
\s1 خودا بەدکاران تاوانبار دەکات 
\q1  
\v 9 ئەی هەموو گیانلەبەرانی دەشتودەر، 
\q2 ئەی هەموو گیانلەبەرانی دارستان، وەرن، بخۆن! 
\q1  
\v 10 ئێشکگرەکانی گەل هەموو کوێرن، 
\q2 نەزانن. 
\q1 هەموو سەگی لاڵن، 
\q2 ناتوانن بوەڕن. 
\q1 خەونبین و پاڵکەوتوون، 
\q2 حەزیان لە خەوە. 
\q1  
\v 11 سەگەکان چاو برسین، 
\q2 تێربوون نازانن. 
\q1 ئەوان شوانن و تێناگەن، 
\q2 هەموو ملی ڕێی خۆیان گرت، 
\q2 هەریەکە و بۆ قازانج لەلای خۆیەوە. 
\q1  
\v 12 دەڵێن: «وەرن شەراب بهێنین! 
\q2 با مەی بنۆشین! 
\q1 بەیانیش وەک ئەمڕۆ دەبێت، 
\q2 بەڵکو زۆر باشتریش.» 
\b  
\b  
\c 57  
\q1  
\v 1 ڕاستودروستان لەناودەچن، 
\q2 کەسیش لە دڵی خۆیدا بیر لەمە ناکاتەوە. 
\q1 خودا خۆشەویستانی بۆ لای خۆی دەگەڕێنێتەوە، 
\q2 بەڵام کەس تێناگات 
\q1 کە ڕاستودروست بۆ لای خۆی دەگەڕێنێتەوە 
\q2 بۆ ئەوەی لە خراپە ڕزگاریان بکات. 
\q1  
\v 2 ئەوەی ڕێگای ڕاستی گرتووەتەبەر 
\q2 دێتە ناو ئاشتییەوە، 
\q2 لەناو تابووتەکانیان دەحەسێنەوە. 
\b  
\q1  
\v 3 «بەڵام ئێوە، ئەی کوڕانی ژنە بەخت خوێنەرەکە، 
\q2 توخمی داوێنپیسە لەشفرۆشەکان، وەرنە پێشەوە! 
\q1  
\v 4 گاڵتە بە کێ دەکەن؟ 
\q2 لە کێ دەم دەکەنەوە و 
\q2 زمان درێژ دەکەن؟ 
\q1 ئەی ئێوە کوڕانی یاخیبوون و 
\q2 توخمی درۆ نین؟ 
\q1  
\v 5 ئێوە لەنێو دار بەڕووەکان، 
\q2 لەژێر هەموو دارێکی سەوزدا جۆش دەستێنن، 
\q1 ئەوانەی منداڵان لە شیوەکان و 
\q2 لەژێر کەلەبەرەکانی تاوێرەکاندا دەکەنە قوربانی. 
\q1  
\v 6 بەشت ئەو بتانەیە کە لەنێو بەردە لووسەکانی شیوەکانن، 
\q2 بێگومان ئەوان پشکی تۆن. 
\q1 هەروەها بۆ ئەوان شەرابی پێشکەشکراو و 
\q2 پێشکەشکراوی دانەوێڵەت پێشکەش کرد. 
\q2 ئایا لەبەر ئەمە پاشگەز ببمەوە؟ 
\q1  
\v 7 جێگای نوستنت لەسەر کێوێکی بەرز و بڵند داناوە، 
\q2 بۆ ئەوێ سەرکەوتیت تاوەکو قوربانی سەرببڕیت. 
\q1  
\v 8 لە پشت دەرگا و چوارچێوەکەی 
\q2 هێمای بتەکەتت داناوە. 
\q1 پشتت لە من کرد و خۆتت ڕووت کردەوە، 
\q2 سەرکەوتیتە سەر جێگای خەوی خۆت و فراوانت کرد. 
\q1 پەیمانت لەگەڵ بتەکاندا بەست، 
\q2 حەزت کرد داوێنپیسییان لەگەڵ بکەیت، 
\q2 ناموسی ئەوانت بینی. 
\q1  
\v 9 بە زەیتەوە چوویتە لای مۆلەخ\f + \fr 57:9 \ft خوداوەندێکی کەنعانییە بتپەرستەکان بووە، بۆ پەرستنی هەستاون بە تێپەڕاندنی منداڵەکانیان بەناو ئاگردا. بڕوانە \xt دووەم پوختەی مێژوو 28‏:3‏\ft .‏\f* و 
\q2 بۆنوبەرامی خۆتت زیاد کرد. 
\q1 نێردراوەکانت بۆ دوور نارد، 
\q2 شۆڕ بوویتەوە هەتا جیهانی مردووان! 
\q1  
\v 10 درێژی گەشتەکانت ماندووی کردیت، 
\q2 کەچی نەتگوت: ”ئەمە بێ ئومێدییە.“ 
\q1 هێزێکی نوێت دۆزییەوە 
\q2 لەبەر ئەوە شەکەت نەبوویت. 
\b  
\q1  
\v 11 «لە کێ ترسایت و تۆقیت 
\q2 وا ناپاکیت لەگەڵ کردم، 
\q1 منت لە دڵت نەهێشتەوە و 
\q2 لەبیرت کردم؟ 
\q1 ئایا لەبەر ئەوەی من ماوەیەکی زۆرە بێدەنگم 
\q2 لە من نەترسایت؟ 
\q1  
\v 12 من ڕاستودروستی و کردەوەکانت دەخەمە ڕوو، 
\q2 کە هیچ سوودیان بۆت نییە. 
\q1  
\v 13 کاتێک هاوار دەکەیت، 
\q2 با بتە کۆکراوەکانت فریات بکەون! 
\q1 بای گێژەڵوکە هەموویان هەڵدەگرێت، 
\q2 تەنانەت شنەبا دەیانبات. 
\q1 بەڵام ئەوەی پەنای داوەتە پاڵ من 
\q2 دەبێت بە میراتگری خاکەکە، 
\q2 کێوی پیرۆزم دەبێت بە موڵکی.» 
\s1 ژیاندنەوەی دڵشکێنراوەکان 
\p  
\v 14 یەزدان دەفەرموێت: 
\q1 «ڕێگاکە بنیاد بنێنەوە، بنیادی بنێنەوە و ئامادەی بکەن! 
\q2 کۆسپ لە ڕێگای گەلەکەم هەڵبگرن.» 
\q1  
\v 15 خودای بەرز و بڵند کە بە نەمری نیشتەجێیە، 
\q2 ناوی پیرۆزە، ئەمە دەفەرموێت: 
\q1 «لە جێی بەرز و پیرۆز نیشتەجێم، 
\q2 هەروەها لەگەڵ ئەوانەدام 
\q1 کە دڵشکێنراون و بێفیزن، 
\q2 بۆ ئەوەی بێفیز و دڵشکێنراوەکان بژیێنمەوە. 
\q1  
\v 16 هەتاسەر کێشمەکێش ناکەم و 
\q2 هەتا کۆتایی تووڕە نابم، 
\q1 چونکە ڕۆح لەبەردەمم گرژ دەبێت، 
\q2 هەناسەی مرۆڤ کە من دروستم کردووە. 
\q1  
\v 17 لەبەر تاوانی چاوچنۆکییەکەی تووڕە بووم، 
\q2 لێم دا، لە تووڕەییدا ڕوخساری خۆمم شاردەوە، 
\q2 بەڵام هەر بە ڕێگای دڵی خۆی بەردەوام بوو لە یاخیبوون. 
\q1  
\v 18 ڕێگاکانی ئەوم بینی بەڵام چاکی دەکەمەوە، 
\q2 ڕێنمایی دەکەم و دڵی خۆی و شیوەنگێڕەکانیشی دەدەمەوە، 
\q2  
\v 19 وا دەکەم بەرهەمی لێوەکانیان سوپاسگوزاری بێت. 
\q1 ئاشتی! ئاشتی بۆ دوور و بۆ نزیک، 
\q2 چاکیشی دەکەمەوە،» 
\q4 یەزدان دەفەرموێت. 
\q1  
\v 20 بەڵام بەدکاران وەک دەریای هەڵچوون 
\q2 کە ناتوانێت ئارام بێتەوە، 
\q2 ئاوەکانی لیتە و قوڕاو فڕێدەدات. 
\q1  
\v 21 خودام دەفەرموێت: «ئاشتی بۆ بەدکاران نییە.» 
\c 58  
\s1 ڕۆژووگرتنی ڕاستەقینە 
\q1  
\v 1 «پڕ بە گەرووت هاوار بکە و مەیگەڕێنەوە، 
\q2 وەک کەڕەنا دەنگت بەرز بکەوە! 
\q1 یاخیبوونەکەی گەلەکەم بە خۆیان ڕابگەیەنە، 
\q2 گوناهەکانی بنەماڵەی یاقوبیش بە خۆیان. 
\q1  
\v 2 ڕۆژ بە ڕۆژ داوای من دەکەن و 
\q2 خۆیان وا دەردەخەن کە بە پەرۆشن بۆ زانینی ڕێگاکانم، 
\q1 وەک نەتەوەیەک ڕاستودروستی ئەنجام دابێت و 
\q2 حوکمەکانی خودای خۆیان پشتگوێ نەخستبێت. 
\q1 داوای حوکمەکانی ڕاستودروستیم لێ دەکەن و 
\q2 خۆیان وا دەردەخەن کە بە پەرۆشن بۆ نزیکبوونەوە لە خودا. 
\q1  
\v 3 دەڵێن: ”بۆچی بەڕۆژوو بووین و سەیرت نەکردین، 
\q2 خۆمان زەلیل کرد و پێت نەزانین؟“ 
\b  
\q1 «وا لە ڕۆژی بەڕۆژوبوونتان خۆشی دەبینن و 
\q2 هەموو کرێکارەکانتان دەچەوسێننەوە. 
\q1  
\v 4 وا سەرئەنجامی ڕوژووگرتنتان دەبێتە شەڕ و ناکۆکی، 
\q2 بە خراپە مست لە یەکتری دەوەشێنن. 
\q1 ئەمڕۆ ناتوانن بەڕۆژوو بن و 
\q2 چاوەڕێ دەکەن لە ئاسمان دەنگتان ببیسترێت. 
\q1  
\v 5 ئایا ئەمە ئەو ڕۆژووەیە کە من دەمەوێت؟ 
\q2 مرۆڤ تەنها ڕۆژێک گیانی خۆی زەلیل دەکات، 
\q1 وەک زەل سەری دادەنەوێنێت و 
\q2 لەسەر گوش و خۆڵەمێش ڕادەکشێت؟ 
\q1 ئایا ئەمە ناو دەنێیت ڕۆژوو، 
\q1 یان ڕۆژێکی پەسەند لەلای یەزدان؟ 
\b  
\q1  
\v 6 «ئایا ئەمە ئەو ڕۆژووە نییە کە من دەمەوێت: 
\q1 کۆتی ستەمکاری بکرێتەوە و 
\q2 گرێیەکانی نیر شل بکرێنەوە، 
\q1 چەوساوەکان بەڕەڵا بکرێن و 
\q2 هەموو نیرێک بشکێنن؟ 
\q1  
\v 7 ئایا ئەوە نییە کە نانی خۆت بۆ برسی لەت بکەیت و 
\q2 هەژارە بێ لانەکان ببەیتە ماڵەوە، 
\q1 کە ڕووتێکت بینی پۆشتەی بکەیت و 
\q2 خۆت لە خزمەکانی خۆت نەشاریتەوە؟ 
\q1  
\v 8 ئەوسا ڕووناکیت وەک بەیان پڕشنگ دەداتەوە، 
\q2 تەندروستیت بە خێرایی چرۆ دەکات، 
\q1 ڕاستودروستیت لەپێشتەوە دەڕوات و 
\q2 شکۆمەندی یەزدانیش پاشڕەو و پارێزەری تۆیە. 
\q1  
\v 9 ئەوسا هاوار دەکەیت و یەزدان وەڵام دەداتەوە، 
\q2 هاواری فریاکەوتن دەکەیت، ئەویش پێت دەفەرموێت: ئەوەتام. 
\b  
\q1 «ئەگەر بەرگی ستەم لە خۆت داماڵیت و 
\q2 واز لە قسەی بەد و تاوانبارکردنی خەڵکی بهێنیت، 
\q1  
\v 10 هەروەها ئەگەر خۆت بۆ برسی ماندوو بکەیت و 
\q2 پێداویستی زەلیل دابین بکەیت، 
\q1 ئاوا ڕووناکیت لەناو تاریکی دەدرەوشێتەوە و 
\q2 تاریکی ئەنگوستەچاوت وەک نیوەڕۆ دەبێت. 
\q1  
\v 11 یەزدان هەمیشە ڕێنماییت دەکات و 
\q2 لە خاکی ڕووتەندا گیانت تێر دەکات و 
\q2 جەستەت بەهێز دەکات. 
\q1 وەک باخچەیەکی تێر ئاوت لێدێت، 
\q2 کانییەک کە ئاوی لێ نەبڕێت. 
\q1  
\v 12 گەلی تۆ کەلاوە داڕووخاوە کۆنەکان بنیاد دەنێنەوە، 
\q2 بناغەکان هەڵدەستێننەوە، کە لە نەوەکانی پێشووەوەیە، 
\q1 ئینجا ناوت لێ دەنێن، ”بنیادنەرەوەی شوورا“ و 
\q2 ”ئاوەدانکەرەوەی کۆڵانەکان“. 
\b  
\q1  
\v 13 «ئەگەر بە پێیەکانت ڕۆژی شەممەت نەشکاند، 
\q2 لە ڕۆژی پیرۆزم بە ئارەزووی خۆت نەکەیت، 
\q1 ئەگەر ڕۆژی شەممە بە ڕۆژی خۆشی دابنێیت و 
\q2 ڕۆژی پیرۆزی یەزدان، ڕێزدارە، 
\q1 ئەگەر ڕێزی لێ بگریت بەوەی ڕێگای خۆت ئەنجام نەدەیت و 
\q2 بەدوای خۆشی خۆتەوە نەبیت و قسەکانی خۆت نەکەیت، 
\q1  
\v 14 ئەوسا خۆشی لە یەزدان دەبینیت و 
\q2 سواری بەرزاییەکانی زەویت دەکەم و 
\q2 میراتەکەی یاقوبی باوکت دەرخوارد دەدەم.» 
\q4 یەزدان بە دەمی خۆی فەرمووی. 
\c 59  
\s1 گوناه، دانپێدانان و کڕینەوە 
\q1  
\v 1 بێگومان یەزدان بێ دەسەڵات نییە بۆ ڕزگارکردن، 
\q2 گوێشی گران نییە بۆ بیستن، 
\q1  
\v 2 بەڵکو تاوانەکانتان بوون بە بەربەست 
\q2 لەنێوان ئێوە و خوداتان، 
\q1 گوناهەکانتان بەم جۆرەی کرد ڕووی خودای لێ شاردنەوە 
\q2 تاکو گوێتان لێ نەگرێت. 
\q1  
\v 3 لەبەر ئەوەی لەپی دەستتان بە خوێن گڵاو بوو و 
\q2 پەنجەکانیشتان بە تاوان، 
\q1 لێوەکانتان بە درۆ دوان و 
\q2 زمانیشتان ناڕەوایی دەگوتەوە. 
\q1  
\v 4 کەس نییە بە ڕاستودروستی بچێتە دادگا و 
\q2 کەس نییە بە ڕاستگۆیی سکاڵا بکات. 
\q1 پشت بە شتی پووچ دەبەستن و بە درۆ دەدوێن. 
\q2 بە ئاژاوە دووگیان دەبن و خراپەیان لێ دەبێت. 
\q1  
\v 5 هێلکەی ماریان هەڵهێنا، 
\q2 تۆڕی جاڵجاڵۆکە دەچنن. 
\q1 ئەوەی هێلکەیان دەخوات دەمرێت، 
\q2 ئەوانەش کە دەشکێن مار هەڵدێنن. 
\q1  
\v 6 تەونەکانیان نابێتە بەرگ و 
\q2 خۆیان بە کردارەکانیان ناپۆشن، 
\q1 کردارەکانیان کرداری خراپەن و 
\q2 کردەوەی دەستیان ستەمە. 
\q1  
\v 7 پێیەکانیان بەرەو خراپە ڕادەکەن، 
\q2 پەلە دەکەن بۆ ڕشتنی خوێنی بێتاوان. 
\q1 بیرکردنەوەیان بیرکردنەوەی خراپەیە، 
\q2 وێرانی و تێکشکاندن لە ڕێگاکانیان هەیە. 
\q1  
\v 8 ڕێگای ئاشتی پێنازانن، 
\q2 دادپەروەری نییە لە ڕێچکەکانیان. 
\q1 ڕێڕەوەکانی خۆیان خوار کرد، 
\q2 هەموو ئەو کەسانەی پێیدا دەڕۆن ئاشتی نازانن. 
\b  
\q1  
\v 9 لەبەر ئەمە دادپەروەری لێمان دوور کەوتەوە و 
\q2 ڕاستودروستی پێمان ناگات. 
\q1 چاوەڕێی ڕووناکی دەکەین و ئەوەتا تاریکی دێت، 
\q2 بە هیواین ڕۆشنایی بێت، 
\q2 بەڵام بە تاریکی ئەنگوستەچاودا دەڕۆین. 
\q1  
\v 10 وەک کوێر دەست لە دیوار دەدەین، 
\q2 وەک یەکێک دوو چاوی نەبێت دەست دەکوتین. 
\q1 لە نیوەڕۆدا هەروەک کاتی تاریک و ڕوونی پەل دەکوتین، 
\q2 لەنێو چالاکەکان وەک مردوو واین. 
\q1  
\v 11 هەموومان وەک ورچ دەبۆڕێنین، 
\q2 وەک کۆتر دەگمێنین، 
\q1 چاوەڕێی دادپەروەری دەکەین و نییە، 
\q2 بە هیوای ڕزگارین، 
\q2 بەڵام لێمان دوور دەکەوێتەوە. 
\b  
\q1  
\v 12 بێگومان یاخیبوونەکانمان لە بەرامبەر تۆدا زۆر بوون، 
\q2 گوناهەکانمان شایەتیمان لەسەر دەدەن. 
\q1 یاخیبوونەکانمان پێمانەوە لکاون، 
\q2 دان بە تاوانەکانی خۆماندا دەنێین: 
\q1  
\v 13 یاخیبوون و ناپاکی لە دژی یەزدان، 
\q2 لادان لە ڕێگای خودای خۆمان، 
\q1 هاندان بۆ ستەم و هەڵگەڕانەوە، 
\q2 دروستکردنی درۆ لە دڵەوە و بە ساختە قسەکردن. 
\q1  
\v 14 دادپەروەری هەڵدەدرێتە دواوە و 
\q2 ڕاستودروستی پشتگوێ دەخرێت. 
\q1 ڕاستی لە گۆڕەپانی شاردا کەوتووە و 
\q2 ڕێگا نادرێت ڕاستگۆیی بێتە ژوورەوە. 
\q1  
\v 15 ڕاستی ون بووە و 
\q2 ئەوەی لە خراپە لادەدات دەبێت بە نێچیر. 
\b  
\q1 یەزدان بینی و لەبەرچاوی خراپ بوو 
\q2 کە دادپەروەری نەبوو. 
\q1  
\v 16 بینی کەس نەبوو، 
\q2 سەرسام بوو کە ناوبژیوان نەبوو. 
\q1 بە هێزی بازووی خۆی ڕزگاری کردین، 
\q2 ڕاستودروستی خۆی پاڵپشتی کرد. 
\q1  
\v 17 ڕاستودروستی وەک زرێ\f + \fr 59:17 \ft جلێکی ئاسنینە بۆ پاراستنی سنگی سەرباز لە کاتی جەنگدا. بڕوانە \xt ئەفەسۆس 6‏:14‏\ft ‏.‏\f* لەبەرکرد و 
\q2 کڵاوی ئاسنینی ڕزگاریش لەسەری، 
\q1 بەرگی تۆڵەسەندنەوەی لەبەرکرد، 
\q2 دڵگەرمیشی وەک کەوا لە خۆی پێچا. 
\q1  
\v 18 بەگوێرەی کردەوەکان لە ناحەزانی تووڕە دەبێت، 
\q2 سزای ڕەوای دوژمنانی دەدات، 
\q2 بە تەواوی سزای دوورگەکانیش دەدات. 
\q1  
\v 19 خەڵکی ڕۆژئاوا لە ناوی یەزدان دەترسن، 
\q2 خەڵکی ڕۆژهەڵات لە شکۆمەندییەکەی، 
\q1 چونکە یەزدان وەک لافاو دێت، 
\q2 بە هەناسەی خۆی پاڵی پێوە دەنێت. 
\b  
\q1  
\v 20 «ئەوەی دەمانکڕێتەوە دێت بۆ سییۆن، 
\q2 بۆ لای ئەوانە لە نەوەی یاقوب کە لە گوناهەکانیان تۆبەیان کرد.» 
\q4 ئەمە فەرمایشتی یەزدانە. 
\p  
\v 21 یەزدان دەفەرموێت: «ئەمەش پەیمانی منە لەگەڵ ئەوان: ڕۆحم لەگەڵتدایە و وتەکانی خۆمم خستووەتە دەمی تۆوە، نە لە دەمی خۆت و نە لە دەمی نەوەت و نە لە دەمی نەوەی دوای نەوەت نابڕێنەوە، لە ئێستاوە و هەتاهەتایە،» 
\q4 یەزدان دەفەرموێت. 
\c 60  
\s1 شکۆمەندی سییۆن 
\q1  
\v 1 «ئەی ئۆرشەلیم هەستە! پڕشنگ بدەوە، چونکە ڕووناکییت هات، 
\q2 شکۆمەندی یەزدانیش بەسەرتدا گزنگی داوە. 
\q1  
\v 2 ئەوەتا تاریکی زەوی داپۆشیوە و 
\q2 هەوری تاریش نەتەوەکان. 
\q1 بەڵام یەزدان بەسەر تۆدا گزنگ دەدات، 
\q2 شکۆمەندییەکەشی بەسەرتەوە دەبینرێت. 
\q1  
\v 3 نەتەوەکان بەرەو ڕووناکی تۆ دێن، 
\q2 پاشاکانیش بەرەو گزنگی ڕووناکییت. 
\b  
\q1  
\v 4 «چاو هەڵبڕە بۆ دەوروبەری خۆت و تەماشا بکە! 
\q2 هەموو کۆبوونەوە و بۆ لای تۆ هاتن، 
\q1 کوڕەکانت لە دوورەوە دێن و 
\q2 کچەکانیشت لە ئامێز دەگرن. 
\q1  
\v 5 ئینجا تەماشا دەکەیت و ڕووناکییت لێ دەبارێت، 
\q2 لە خۆشیدا دڵت دادەخورپێت، 
\q1 چونکە سامانی دەریا بۆ تۆ دەگوازرێتەوە، 
\q2 دەوڵەمەندی نەتەوەکان بۆ لای تۆ دێت. 
\q1  
\v 6 ڕەوە وشتر زەویت دادەپۆشێت، 
\q2 وشترەکانی میدیان و عێفا. 
\q1 هەموو لە شەباوە دێن، 
\q2 زێڕ و بخووریان بارکردووە، 
\q2 ستایشی یەزدان ڕادەگەیەنن. 
\q1  
\v 7 هەموو مەڕی قێدار بۆ تۆ کۆدەکرێتەوە، 
\q2 بەرانەکانی نەبایۆت لەژێر دەستتدان، 
\q1 بە پەسەندییەوە سەردەخرێنە سەر قوربانگاکەم و 
\q2 پەرستگای شکۆمەندیم شکۆمەند دەکەم. 
\b  
\q1  
\v 8 «ئەوانە کێن وەک هەور دەفڕن و 
\q2 وەک کۆتر بەرەو ماڵەکانیان؟ 
\q1  
\v 9 بێگومان دوورگەکان چاوەڕوانی منن، 
\q2 هەروەها کەشتییەکانی تەرشیش لەپێشەوەن 
\q1 بۆ هێنانی کوڕەکانت لە دوورەوە، 
\q2 زێڕ و زیوەکانیشیان لەگەڵیاندایە 
\q1 بۆ ناوی یەزدانی پەروەردگارت، 
\q2 خودا پیرۆزەکەی ئیسرائیل 
\q2 کە شکۆداری کردیت. 
\b  
\q1  
\v 10 «نەوەی بێگانە شووراکانت بنیاد دەنێنەوە، 
\q2 پاشاکانیان خزمەتت دەکەن. 
\q1 هەرچەندە لە کاتی تووڕەییمدا لێم دایت، 
\q2 بەڵام لە کاتی ڕەزامەندیمدا بەزەییم پێتدا دێتەوە. 
\q1  
\v 11 دەروازەکانت هەمیشە واڵا دەبن، 
\q2 شەو و ڕۆژ داناخرێن 
\q1 بۆ هێنانی سامانی نەتەوەکان بۆت و 
\q2 پاشاکانیشیان بە پێش دەدرێن، 
\q1  
\v 12 چونکە ئەو نەتەوە و شانشینەی خزمەتت نەکات لەناودەچێت و 
\q1 بە تەواوی وێران دەبێت. 
\b  
\q1  
\v 13 «شانازی لوبنان بۆ تۆ دێت، 
\q2 داری سنەوبەر، کاژ و سەروو پێکەوە، 
\q1 بۆ ڕازاندنەوەی جێی پیرۆزگاکەم و 
\q2 شوێنی پێیەکانم شکۆدار دەکەم. 
\q1  
\v 14 کوڕی ئەوانەی تۆیان زەلیل کرد بە کڕنۆشەوە دێن بۆ لات، 
\q2 هەموو ئەوانەی سووکایەتییان پێ دەکردیت کڕنۆش بۆ بنی پێت دەبەن و 
\q1 پێت دەڵێن: شاری یەزدان، 
\q2 سییۆنی خودا پیرۆزەکەی ئیسرائیل. 
\b  
\q1  
\v 15 «لە جێی ئەوەی بەجێماو و ڕق لێبوو و 
\q2 بێ ڕێبوار بیت، 
\q1 دەتکەمە شانازی هەتاهەتایی، 
\q2 شادی نەوە دوای نەوە. 
\q1  
\v 16 لە شیری نەتەوەکان دەخۆیت، 
\q2 لە مەمکی شاهانە شیر دەخۆیت. 
\q1 جا دەزانیت کە منی یەزدان، ڕزگارکەری تۆم، 
\q2 ئەوەی تۆ دەکڕێتەوە توانادارەکەی یاقوبە. 
\q1  
\v 17 لە جیاتی بڕۆنز زێڕ و 
\q2 لە جیاتی ئاسنیش زیو دەهێنم، 
\q1 لە جیاتی داریش بڕۆنز و 
\q2 لە جیاتی بەردیش ئاسن دەهێنم. 
\q1 سەلامەتی دەکەمە سەرپەرشتیارت و 
\q2 ڕاستودروستی دەکەمە سەرکارت. 
\q1  
\v 18 ئیتر نە ستەم لە خاکەکەتدا دەبیسترێت 
\q2 نە وێرانی و شکانیش لە سنوورەکانت، 
\q1 بەڵکو شووراکانت ناو لێ دەنێیت: ”ڕزگاری“ و 
\q2 دەروازەکانیشت ”ستایش“. 
\q1  
\v 19 ئیتر خۆر بۆت نابێتە ڕووناکی ڕۆژ، 
\q2 درەوشانەوەی مانگیش نابێتە سەرچاوەی ڕووناکی تۆ، 
\q1 بەڵکو یەزدان بۆت دەبێت بە ڕووناکی هەتاهەتایی، 
\q2 خوداشت دەبێتە شکۆمەندیت. 
\q1  
\v 20 لەمەودوا خۆری تۆ ئاوا نابێت، 
\q2 مانگی تۆ کەم ناکات، 
\q1 چونکە یەزدان بۆت دەبێت بە ڕووناکی هەتاهەتایی، 
\q2 ڕۆژانی ماتەمینیت تەواو دەبێت. 
\q1  
\v 21 لەو کاتەدا گەلەکەت هەمووی ڕاستودروست دەبن، 
\q2 زەویش بۆ هەتاهەتایە موڵکی خۆیان دەبێت. 
\q1 ئەوەی من ناشتوومن نەمامن، 
\q2 دەستکردی منن بۆ شکۆمەندبوونم. 
\q1  
\v 22 بچووک دەبێت بە هەزار و 
\q2 بچووکترین بە نەتەوەیەکی مەزن. 
\q1 من یەزدانم، 
\q2 لە کاتی خۆیدا پەلەی لێ دەکەم.» 
\c 61  
\s1 ساڵی ڕەزامەندی یەزدان 
\q1  
\v 1 ڕۆحی یەزدانی باڵادەست بەهێزم دەکات، 
\q2 چونکە یەزدان دەستنیشانی کردووم 
\q2 بۆ مژدەدان بە هەژاران. 
\q1 منی ناردووە بۆ تیمارکردنی دڵشکاوەکان، 
\q2 بۆ جاڕدانی ئازادی بۆ ڕاپێچکراوەکان و 
\q2 ئازادکردنی کۆیلەکان، 
\q1  
\v 2 بۆ ڕاگەیاندنی ساڵی ڕەزامەندیی یەزدان و 
\q2 ڕۆژی تۆڵەسەندنەوەی خودامان، 
\q1 بۆ دڵنەواییکردنی هەموو ماتەمدارەکان. 
\q2  
\v 3 ناردوومی بۆ ئەوەی بە پرسەدارەکانی سییۆن ببەخشم، 
\q1 تاجێکی جوانیان لەسەر بنێم لە جێی قوڕ\f + \fr 61:3 \ft عیبری: خۆڵەمێش.‏\f*، 
\q2 زەیتی دڵخۆشی لە جێی پرسە، 
\q1 هەروەها بەرگی ستایش لە جێی ڕۆحی ورەبەردان. 
\q2 جا پێیان دەگوترێت دار بەڕووی ڕاستودروستی، 
\q2 نەمامی یەزدان بۆ دەرخستنی شکۆمەندییەکەی. 
\b  
\q1  
\v 4 کەلاوە کۆنەکان بنیاد دەنێنەوە و 
\q2 وێرانکراوەکانی پێشتر هەڵدەستێننەوە. 
\q1 شارە خاپوورەکان نۆژەن دەکەنەوە 
\q2 کە لە چەرخەکانی پێشووەوە وێران کرابوون. 
\q1  
\v 5 بێگانە دێنە خزمەتتان و شوانایەتی مێگەلەکانتان دەکەن و 
\q2 کوڕانی نامۆکان دەبنە جوتیار و ڕەزەوانتان. 
\q1  
\v 6 ئێوەش ناوتان لێ دەنرێت، کاهینەکانی یەزدان، 
\q2 پێتان دەگوترێت، خزمەتکارەکانی خودامان. 
\q1 سامانی نەتەوەکان دەخۆن و 
\q2 شانازی بەسەر شکۆمەندی ئەوانەوە دەکەن. 
\b  
\q1  
\v 7 گەلەکەم لە جێی ڕیسوایی، دوو ئەوەندە میراتی وەردەگرن، 
\q2 لە جێی شەرمەزاربوون، بە بەشی خۆیان دڵخۆش دەبن. 
\q1 ئیتر لە خاکەکەیان دوو هێندە میرات وەردەگرن، 
\q2 خۆشی هەتاهەتاییان بۆ دەبێت. 
\b  
\q1  
\v 8 «من کە یەزدانم، دادپەروەریم خۆشدەوێت، 
\q2 ڕقم لە دزی و بەدکارییە پێکەوە. 
\q1 بە دڵسۆزییەوە پاداشتی گەلەکەم دەدەمەوە و 
\q2 پەیمانێکی هەتاهەتاییان لەگەڵدا دەبەستم. 
\q1  
\v 9 توخمیان لەنێو نەتەوەکان دەناسرێن و 
\q2 وەچەشیان لەنێو گەلاندا. 
\q1 هەموو ئەوانەی دەیانبینن دانی پێدا دەنێن 
\q2 کە ئەوان گەلێکن یەزدان بەرەکەتداری کردوون.» 
\b  
\q1  
\v 10 بە شادی دڵشاد دەبم بە یەزدان، 
\q2 گیانم بە خودای خۆم شادمان دەبێت، 
\q1 چونکە بەرگی ڕزگاری لەبەرکردم، 
\q2 کەوای ڕاستودروستی بەسەر شانمدا دا، 
\q1 وەک زاوایەک کە سەری خۆی لەسەر شێوەی کاهین بڕازێنێتەوە 
\q2 یان بووکێک بە خشڵ خۆی جوان بکات. 
\q1  
\v 11 وەک زەوی کە چەکەرەی ڕووەکی خۆی دەردەخات و 
\q2 وەک باخچە کە چێنراوەکانی دەڕوێنێت، 
\q1 ئاواش یەزدانی باڵادەست ڕاستودروستی و ستایش 
\q2 لەبەردەم هەموو نەتەوەکان دەڕوێنێت. 
\c 62  
\s1 سییۆن ناوێکی نوێی هەیە 
\q1  
\v 1 لە پێناوی سییۆن بێدەنگ نابم و 
\q2 لە پێناوی ئۆرشەلیم هێمن نابم 
\q1 هەتا بێتاوانییەکەی وەک گزنگی خۆر دەدرەوشێتەوە و 
\q2 ڕزگاریشی وەک مەشخەڵ داگیرسێت. 
\q1  
\v 2 ئەو کاتە هەموو نەتەوەکان بێتاوانییەکەت دەبینن، 
\q2 هەموو پاشاکانیش شکۆمەندییەکەت. 
\q1 ناوێکی نوێت لێ دەنرێت 
\q2 کە دەمی یەزدان دیاری دەکات. 
\q1  
\v 3 دەبیت بە تاجی جوانی لە دەست یەزدان و 
\q2 تاجەگوڵینە لەناو لەپی خودات. 
\q1  
\v 4 چیتر ناوت نانرێت «بەجێماو» و 
\q2 چیتر بە خاکەکەت ناگوترێت «وێرانە»، 
\q1 بەڵکو پێت دەگوترێت «حەفچیڤا\f + \fr 62:4 \ft واتا (شادیم لە ئەودایە).‏\f*»، 
\q2 خاکەکەشت، «بەعولە\f + \fr 62:4 \ft واتا بە مێرد.‏\f*»، 
\q1 چونکە یەزدان بە تۆ دڵخۆش دەبێت، 
\q2 خاکەکەشت مێردی دەبێت. 
\q1  
\v 5 وەک چۆن گەنج دەبێت بە مێردی کچێکی پاکیزە، 
\q2 ئاواش کوڕەکانت دەبن بە مێردت. 
\q1 وەک دڵخۆشی زاوا بە بووک، 
\q2 ئاواش خودات بە تۆ دڵخۆش دەبێت. 
\b  
\q1  
\v 6 ئەی ئۆرشەلیم، ئێشکگرم لەسەر شووراکانت داناوە، 
\q2 بەردەوام شەو و ڕۆژ بێدەنگ نابن. 
\q1 ئەی ئەوانەی یەزدانتان لە یادە، 
\q2 ئۆقرە مەگرن، 
\q1  
\v 7 لێ مەگەڕێن یەزدان ئۆقرە بگرێت هەتا ئۆرشەلیم دەچەسپێنێت و 
\q2 ناوداری دەکات لە زەویدا. 
\b  
\q1  
\v 8 یەزدان بە دەستی ڕاستی خۆی و 
\q2 بە هێزی بازووی سوێندی خوارد: 
\q1 «چیتر دانەوێڵەکەت 
\q2 ناکەم بە خۆراک بۆ دوژمنەکانت و 
\q1 شەرابە نوێیەکەشت کە پێوەی ماندوو بوویت، 
\q2 نامۆکان نایخۆنەوە، 
\q1  
\v 9 بەڵکو ئەوانە دەیخۆن کە گەنمیان بەرهەم هێناوە و 
\q2 ستایشی یەزدان دەکەن، 
\q1 ئەوانەی ترێیان ڕنیوەتەوە 
\q2 لە حەوشەی پیرۆزگاکەم دەیخۆنەوە.» 
\b  
\q1  
\v 10 تێپەڕ بن! تێپەڕ بن لە دەروازەکانەوە! 
\q2 ڕێگای گەل خۆش بکەن. 
\q1 ئامادەی بکەن! ڕێڕەو ئامادە بکەن! 
\q2 لە بەرد پاکی بکەنەوە. 
\q1 ئاڵا بۆ گەل بەرز بکەنەوە. 
\b  
\q1  
\v 11 ئەوەتا یەزدان 
\q2 بە هەر چوار لای زەویدا ڕایگەیاندووە: 
\q1 «بە شاری سییۆن بڵێن، 
\q2 ”وا ڕزگارکەرەکەت دێت! 
\q1 وا پاداشتەکەی لەگەڵیەتی و 
\q2 خەڵاتەکەی لەبەردەمییەتی.“» 
\q1  
\v 12 ناویان لێ دەنێن، «گەلە پیرۆزەکە»، 
\q2 «ئەوانەی یەزدان کڕیونیەتیەوە»، 
\q1 تۆش ناوت لێ دەنرێت، «داواکراوەکە»، 
\q2 «شارە بەجێنەماوەکە». 
\c 63  
\s1 ڕۆژی خودا بۆ تۆڵەسەندن و ڕزگاری 
\q1  
\v 1 ئەوە کێیە لە ئەدۆمەوە دێت 
\q2 بە بەرگی سوور لە بۆزراوە، 
\q1 ئەو شکۆمەندەی بە جلوبەرگەکەیەوە 
\q2 بە زۆری هێزەکەیەوە نمایش دەکات؟ 
\b  
\q1 «منم، بە ڕاستودروستی دەدوێم 
\q2 مەزنم بۆ ڕزگاری.» 
\b  
\q1  
\v 2 بۆچی بەرگت سوورە و 
\q2 بەرگت وەک پەستێنەری گوشەری ترێیە؟ 
\b  
\q1  
\v 3 «کەس لە گەلان لەگەڵمدا نەبوو 
\q2 بە تەنها گوشەرم پەستەوە. 
\q1 لە تووڕەییدا ئەوانم پڵیشاندەوە، 
\q2 بە هەڵچوونی خۆم پێم لێنان. 
\q1 جا خوێنیان بەسەر بەرگمدا پرژا و 
\q2 هەموو جلەکەم لەکەدار بوو. 
\q1  
\v 4 ڕۆژی تۆڵەسەندنەوە لە دڵمدا بوو و 
\q2 ساڵی کڕینەوەی گەلم هات. 
\q1  
\v 5 تەماشام کرد بەڵام یارمەتیدەر نەبوو، 
\q2 سەرسام بووم کە پشتگیری نەبوو، 
\q1 بەڵام بە هێزی بازووی خۆم ڕزگاریم دەستەبەر کرد، 
\q2 هەڵچوونم پشتگیری کردم. 
\q1  
\v 6 بە تووڕەیی خۆم گەلانم پەستەوە، 
\q2 بە هەڵچوونی خۆم سەرخۆشم کردن، 
\q2 خوێنی ئەوانم بەسەر زەویدا ڕشت.» 
\s1 نوێژ و ستایش 
\q1  
\v 7 باسی خۆشەویستی نەگۆڕی یەزدان دەکەم، 
\q2 کارەکانی کە شایستەی ستایشن، 
\q2 بۆ هەموو ئەوەی کە لە پێناوی ئێمەدا کردی. 
\q2 باسی چاکە مەزنەکەی دەکەم بۆ بنەماڵەی ئیسرائیل، 
\q1 ئەوەی پاداشتی پێدانەوە بەپێی بەزەییەکەی و 
\q2 بەپێی زۆری خۆشەویستییە بێ سنوورەکەی. 
\q1  
\v 8 فەرمووی: «بە ڕاستی گەلی منن، 
\q2 کوڕن، ناپاکیم لەگەڵ ناکەن،» 
\q2 جا بۆیان بوو بە ڕزگارکەر. 
\q1  
\v 9 لە هەموو تەنگانەکانیان ئەویش تەنگاو بوو و 
\q2 فریشتەی ئامادەبوونەکەی\f + \fr 63:9 \ft مەبەستی لە ئەو فریشتەیە کە هەمیشە ئامادەیە لەبەردەمی یەزدان بۆ ڕاپەڕاندنی کارەکانی.‏\f* ڕزگاری کردن. 
\q1 ئەو بە خۆشەویستییەکەی و بە میهرەبانی ئەوانی کڕییەوە، 
\q2 بەرزی کردنەوە و هەڵیگرتن 
\q2 هەموو ڕۆژانی کۆن. 
\q1  
\v 10 بەڵام ئەوان یاخی بوون و 
\q2 ڕۆحی پیرۆزی ئەویان خەمبار کرد، 
\q1 جا لێیان بوو بە دوژمن و 
\q2 لەگەڵیان کەوتە جەنگەوە. 
\b  
\q1  
\v 11 ئینجا گەل ڕۆژانی کۆنیان بەبیر هاتەوە، 
\q2 ڕۆژانی موسا و گەلەکەی. 
\q1 کوا ئەوەی لە دەریاوە سەری خستن 
\q2 لەگەڵ شوانی مێگەلەکەی؟ 
\q1 کوا ئەوەی ڕۆحی پیرۆزی خۆی 
\q2 لەنێویان دانا؟ 
\q1  
\v 12 کوا ئەوەی لەلای دەستی ڕاستی موسا 
\q2 هێزە شکۆدارەکەی بازووی خۆی نارد، 
\q1 ئەوەی ئاوی لەبەردەمیان دوو لەت کرد، 
\q2 بۆ ئەوەی ناوێکی هەتاهەتایی بۆ خۆی دروستبکات، 
\q1  
\v 13 ئەوەی بەناو دەریا قووڵەکاندا بردنی؟ 
\q2 وەک ئەسپ بە چۆڵەوانیدا سەرسمیان نەدا، 
\q1  
\v 14 وەک دابەزینی ڕەشەوڵاخ بەرەو دەشتایی، 
\q2 ڕۆحی یەزدان پشووی پێدان. 
\q1 ئاوا ڕێنمایی گەلەکەتت کرد 
\q2 بۆ ئەوەی ناوێکی شکۆمەند بۆ خۆت دروستبکەیت. 
\b  
\q1  
\v 15 لە ئاسمانەوە تەماشا بکە، 
\q2 لە نشینگەی پیرۆز و شکۆمەندیتەوە ببینە، 
\q1 کوا دڵگەرمی و پاڵەوانیێتییەکەت؟ 
\q2 ئاخ هەڵکێشانی هەناوت و بەزەییت لە ئێمە بڕی. 
\q1  
\v 16 بەڵام تۆ باوکی ئێمەی، 
\q2 ئەگەر ئیبراهیم نەمانناسێت و 
\q2 ئیسرائیلیش دانمان پێدا نەنێت. 
\q1 ئەی یەزدان تۆ باوکی ئێمەیت، 
\q2 لە ئەزەلەوە ناوت دەمانکڕێتەوە. 
\q1  
\v 17 ئەی یەزدان، بۆچی لە ڕێگاکانی خۆت وێڵت کردین، 
\q2 بۆچی دڵت ڕەق کردین هەتا لێت نەترسین؟ 
\q1 بگەڕێوە لە پێناو خزمەتکارەکانت، 
\q2 هۆزەکانی میراتەکەت. 
\q1  
\v 18 بۆ ماوەیەکی کەم گەلی پیرۆزت خاوەنی پیرۆزگای تۆ بوون، 
\q2 بەڵام ئێستا دوژمنانمان پێشێلیان کرد. 
\q1  
\v 19 ئێمە لە کۆنەوە گەلی تۆین، 
\q2 ئێستا وامان لێ هاتووە کە تۆ فەرمانڕەوایی ئێمەت نەکردووە، 
\q2 وەک چۆن هەرگیز بە ناوی تۆوە ناو نەنرابین. 
\b  
\c 64  
\q1  
\v 1 خۆزگە ئاسمانت شەق دەکرد و دەهاتیتە خوارەوە، 
\q2 چیاکان لەبەردەمت دەلەرزین! 
\q1  
\v 2 وەک ئەوەی ئاگر گڕ بەردەداتە پوشوپەڵاش و 
\q2 ئاگر وا دەکات ئاو بکوڵێت، 
\q1 وەرە خوارەوە، با دوژمنانت ناوت بزانن، 
\q2 با نەتەوەکان لەبەردەمتدا بلەرزن. 
\q1  
\v 3 کاتێک کارە ترسناکەکانت کرد کە چاوەڕێمان نەدەکرد، 
\q2 دابەزیت و چیاکان لەبەردەمتدا لەرزین. 
\q1  
\v 4 لە کۆنەوە نە گوێیان لێ بووە و 
\q2 نە بیستوویانە، 
\q1 هیچ چاوێک خودایەکی جگە لە تۆ نەبینیوە، 
\q2 ئەوە بکات بۆ ئەو کەسەی چاوەڕێی دەکات. 
\q1  
\v 5 تۆ دێیت بۆ یارمەتی ئەوانەی بە دڵخۆشییەوە کاری ڕاستودروستی دەکەن، 
\q2 ئەوانەی بیر لە ڕێگاکانت دەکەنەوە هەتا پەیڕەوی بکەن. 
\q1 بەڵام کاتێک ئێمە بە بەردەوامی گوناهمان لە دژی ئەوان کرد، 
\q2 تۆ تووڕە بوویت. 
\q2 ئیتر چۆن ڕزگار دەبین؟ 
\q1  
\v 6 هەموومان وەک کەسێکی گڵاومان لێ هات، 
\q2 هەموو کاری ڕاستودروستیمان وەک پەڕۆی پیسی مانگانەی ئافرەت بوو. 
\q1 هەموو وەک گەڵا سیس بووین، 
\q2 تاوانەکانمان وەک با هەڵماندەگرێت. 
\q1  
\v 7 کەس نییە بە ناوی تۆوە نزا بکات 
\q2 یان وریابێت بۆ ئەوەی خۆی بە تۆوە بگرێت، 
\q1 چونکە ڕووی خۆتت لێمان شاردەوە و 
\q2 بە دەست تاوانەکانمان ئێمەت تواندەوە. 
\b  
\q1  
\v 8 بەڵام ئەی یەزدان، تۆ باوکی ئێمەیت، 
\q2 ئێمە قوڕین و تۆ گۆزەکەری ئێمەیت و 
\q2 ئێمە هەموو دەستکردی تۆین. 
\q1  
\v 9 ئەی یەزدان، تەواو تووڕە مەبە و 
\q2 هەتا کۆتایی تاوانمان بەبیر خۆت مەهێنەرەوە، 
\q1 تکایە، تەماشامان بکە! 
\q2 ئێمە هەموو گەلی تۆین. 
\q1  
\v 10 شارە پیرۆزەکانت بوون بە چۆڵەوانی، 
\q2 سییۆن بوو بە چۆڵەوانی و ئۆرشەلیم وێران بوو. 
\q1  
\v 11 پەرستگای پیرۆزی و شانازیمان، کە لەوێ باوباپیرانمان ستایشی تۆیان کرد، 
\q2 بە ئاگر سووتێنراوە و 
\q2 هەموو ئەو شوێنانەی کە بۆ ئێمە گەنجینە بوون، بە کەلاوە بوون. 
\q1  
\v 12 ئەی یەزدان، ئایا لەدوای هەموو ئەمانە لە یارمەتیدان خۆت بە دوور دەگریت؟ 
\q2 ئایا بێدەنگ دەبیت و بە تەواوی سزامان دەدەیت؟ 
\c 65  
\s1 دادوەری و ڕزگاری 
\q1  
\v 1 «من دەرکەوتم بۆ ئەوانەی کە داوای منیان نەکرد، 
\q2 دۆزرامەوە لەلایەن ئەوانەی بەدوامدا نەگەڕان. 
\q1 بە نەتەوەیەک کە بە ناوی منەوە نزا ناکەن، 
\q2 فەرمووم: ”ئەوەتام! ئەوەتام!“ 
\q1  
\v 2 بە درێژایی ڕۆژ دەستم 
\q2 بۆ گەلێکی کەللەڕەق ڕاگرت، 
\q1 بە ڕێگایەکدا دەڕۆن باش نییە، 
\q2 بەدوای بیرکردنەوەی خۆیان دەکەون. 
\q1  
\v 3 گەلێک بەردەوام 
\q2 بەرەو ڕووم پەستم دەکەن، 
\q1 گەلێک لەناو باخچەکان قوربانی سەردەبڕێت، 
\q2 لەسەر قوربانگا خشتەکان بخوور دەسووتێنێت، 
\q1  
\v 4 ئەوەی لەنێو گۆڕەکان دادەنیشێت، 
\q2 لە گۆڕستانەکان شەو بەسەردەبات، 
\q1 گۆشتی بەراز دەخوات و 
\q2 لەناو قاپوقاچاغەکەی گۆشتاوی گڵاو هەیە. 
\q1  
\v 5 دەڵێت: ”لە شوێنی خۆت ڕابوەستە، لێم نزیک مەکەوە، 
\q2 چونکە من لە تۆ پیرۆزترم!“ 
\q1 ئەوانە دووکەڵن لە لووتی مندا، 
\q2 ئاگرێکن کە بە درێژایی ڕۆژ داگیرساوە. 
\b  
\q1  
\v 6 «ئەوەتا لەبەردەمم نووسراوە: 
\q2 بێدەنگ نابم، بەڵکو بە تەواوی پاداشت دەدەمەوە، 
\q2 سزای خۆیان دەخەمە بەردەستیان، 
\q1  
\v 7 لەبەر تاوانەکانتان و تاوانی باوباپیرانتان پێکەوە،» 
\q2 یەزدان دەفەرموێت. 
\q1 «لەبەر ئەوەی ئەوانە لەسەر چیاکان قوربانییان سووتاند و 
\q2 لەسەر گردەکان سووکایەتییان بە من کرد، 
\q1 کردەوەکانی پێشوویان دەپێومەوە و 
\q2 سزای خۆیان بەسەردا دەسەپێنم.» 
\p  
\v 8 یەزدان ئەمە دەفەرموێت: 
\q1 «وەک ئەوەی لە هێشوودا شەرابی نوێ هەیە، 
\q2 جا دەگوترێت: ”مەیفەوتێنە، 
\q2 چونکە خێروبێری تێدایە،“ 
\q1 ئاوا دەکەم لە پێناوی بەندەکانم 
\q2 بۆ ئەوەی هەمووان نەفەوتێنم. 
\q1  
\v 9 بەڵکو لە یاقوبەوە نەوەیەک دەردەکەم، 
\q2 لە یەهوداشەوە ئەوانەی دەبنە میراتگری چیاکانم. 
\q1 جا چیاکان دەبن بە میراتی هەڵبژێردراوانم و 
\q2 بەندەکانم لەوێ نیشتەجێ دەبن. 
\q1  
\v 10 جا شارۆن دەبێت بە لەوەڕگای مێگەل و 
\q2 دۆڵی عاخۆریش\f + \fr 65:10 \ft \+tl عاخۆر‏\+tl* وشەیەکی عیبرییە بە واتای تێکدان. بڕوانە \xt یەشوع 7‏:24‏\ft ‏.‏\f* بە مۆڵگای مانگا، 
\q2 بۆ گەلەکەم کە داوای منیان کردووە. 
\b  
\q1  
\v 11 «بەڵام ئێوە کە وازتان لە یەزدان هێناوە و 
\q2 کێوی پیرۆزی منتان لەیاد کردووە، 
\q1 خوانتان بۆ بتێک بە ناوی ”گەد“ خوداوەندی بەخت ئامادە کردووە و 
\q2 بۆ ”مەنی“ خوداوەندی چارەنووس شەرابی تێکەڵاوتان پڕکردووە، 
\q1  
\v 12 چارەنووستان دەخەمە بەر شمشێر و 
\q2 هەمووتان بۆ سەربڕین بە چۆکدا دێن، 
\q1 لەبەر ئەوەی بانگم کرد و وەڵامتان نەدایەوە، 
\q2 قسەم کرد و گوێتان نەگرت 
\q1 بەڵکو لەبەرچاوم خراپەکاریتان کرد، 
\q2 ئەوەی من پێم ناخۆش بوو هەڵتانبژارد.» 
\p  
\v 13 لەبەر ئەوە یەزدانی باڵادەست ئەمە دەفەرموێت: 
\q1 «ئەوەتا بەندەکانم دەخۆن، 
\q2 بەڵام ئێوە برسی دەبن، 
\q1 ئەوەتا بەندەکانم دەخۆنەوە، 
\q2 بەڵام ئێوە تینوو دەبن، 
\q1 ئەوەتا بەندەکانم دڵخۆش دەبن، 
\q2 بەڵام ئێوە شەرمەزار دەبن. 
\q1  
\v 14 ئەوەتا لە دڵخۆشیدا 
\q2 بەندەکانم گۆرانی دەڵێن، 
\q1 بەڵام ئێوە لە دڵتەنگیدا دەقیژێنن و 
\q2 لەبەر دڵشکاندن شین دەگێڕن. 
\q1  
\v 15 لە داهاتوودا هەڵبژێردراوانم ناوتان 
\q2 وەک نەفرەت بەکاردەهێنن و 
\q1 یەزدانی باڵادەست دەتانکوژێت، 
\q2 بەڵام ناوێکی دیکە لە خزمەتکارەکانی خۆی دەنێت. 
\q1  
\v 16 ئەوەی لە خاکەکەدا بۆ خۆی داوای بەرەکەت بکات، 
\q2 بە خودای ڕاستەقینەوە داوای بەرەکەت دەکات و 
\q1 ئەوەی لە خاکەکەدا سوێند بخوات 
\q2 بە خودای ڕاستەقینە سوێند دەخوات، 
\q1 چونکە تەنگانەکانی پێشوو لەبیر چوون و 
\q2 لەبەرچاوم شاردرانەوە. 
\s1 ئاسمانی نوێ و زەوی نوێ 
\q1  
\v 17 «بڕوانن، من لە داهاتوودا ئاسمانی نوێ و 
\q2 زەوی نوێ بەدی دەهێنم و 
\q1 ئەوانەی پێشوو نە باس دەکرێن و 
\q2 نە بە مێشکدا دێنەوە. 
\q1  
\v 18 بەڵکو ئێوە بۆ هەتاهەتایە دڵخۆش و شاد بن 
\q2 لەوەی من بەدی دەهێنم، 
\q1 چونکە ئەوەتا من ئۆرشەلیمی شاد بەدی دەهێنم و 
\q2 دانیشتووانەکەی دڵخۆش دەبن. 
\q1  
\v 19 بە ئۆرشەلیم دڵخۆش دەبم و 
\q2 بە گەلی خۆم شاد دەبم، 
\q1 چیتر لەناویدا دەنگی گریان و هاوار نابیسترێت. 
\b  
\q1  
\v 20 «چیتر لەوێ نە کۆرپەی تازە لەدایکبوو دەمرێت و 
\q2 نە پیری لە تەمەن تێر نەخواردوو، 
\q1 چونکە ئەوەی لە تەمەنی سەد ساڵی بمرێت 
\q2 بە گەنج دادەنرێت و 
\q1 ئەوەی نەگات بە تەمەنی سەد ساڵی 
\q2 وەک نەفرەت لێکراو دەبینرێت. 
\q1  
\v 21 خانوو بنیاد دەنێن و نیشتەجێ دەبن، 
\q2 ڕەز دەڕوێنن و لە بەرەکەی دەخۆن. 
\q1  
\v 22 خانوو بنیاد نانێن و یەکێکی دیکە تێیدا دانیشێت، 
\q2 ڕەز ناڕوێنن و یەکێکی دیکە بیخوات، 
\q1 چونکە ڕۆژانی گەلەکەم 
\q2 وەک ڕۆژانی دار\f + \fr 65:22 \ft مەبەست لەو دارانەیە کە تەمەنیان زۆر درێژە.‏\f* دەبێت و 
\q1 هەڵبژێردراوانم خۆشی دەبینن 
\q2 لە کردارەکانی دەستیان. 
\q1  
\v 23 بەخۆڕایی ماندوو نابن و 
\q2 بۆ تۆقاندن منداڵیان نابێت، 
\q1 چونکە ئەوان نەوەی بەرەکەتپێدراوی یەزدانن و 
\q2 وەچەکانیان لەگەڵیاندان. 
\q1  
\v 24 جا بەر لەوەی نزا بکەن من وەڵام دەدەمەوە و 
\q2 هێشتا ئەوان قسە دەکەن من گوێم لێیان دەبێت. 
\q1  
\v 25 گورگ و بەرخ پێکەوە دەلەوەڕێن، 
\q2 شێریش وەک مانگا گیا دەخوات، 
\q2 بەڵام نانی مار خۆڵە. 
\q1 لە هەموو کێوی پیرۆزم 
\q2 نە زیان دەبەخشن و نە دەفەوتێنن،» 
\q4 یەزدان دەفەرموێت. 
\c 66  
\s1 دادوەری و هیوا 
\p  
\v 1 یەزدان ئەمە دەفەرموێت: 
\q1 «ئاسمان تەختی منە و 
\q2 زەویش تەختەپێمە. 
\q1 کوا ئەو ماڵەی کە ئێوە بۆم بنیاد دەنێن و 
\q2 لەکوێیە شوێنی حەوانەوەم؟ 
\q1  
\v 2 ئایا هەموو ئەمانەش دەستی من دروستی نەکردن؟ 
\q2 جا هەموو ئەمانە نەهاتنە دی؟» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\b  
\q1 «من ڕوو لەمە دەکەم: 
\q2 لەوەی بێفیز و دڵشکێنراوە و 
\q2 لەبەر ڕێزی فەرمایشتەکەم دەلەرزێت. 
\q1  
\v 3 بەڵام ئەوەی گا سەردەبڕێت 
\q2 وەک ئەوەیە مرۆڤ بکوژێت، 
\q1 ئەوەی بەرخ دەکاتە قوربانی سەربڕاو، 
\q2 وەک ئەوەیە ملی سەگ بشکێنێت\f + \fr 66:3 \ft لەوانەیە مەبەستی لە شێوازی قوربانیکردنی کەنعانییەکان بێت.‏\f*، 
\q1 ئەوەی پێشکەشکراوی دانەوێڵە پێشکەش دەکات، 
\q2 وەک ئەوەیە خوێنی بەراز پێشکەش بکات و 
\q1 ئەوەی بخوور دەسووتێنێت، 
\q2 وەک ئەوەیە بت بەرەکەتدار بکات. 
\q1 ئەوان ڕێگاکانی خۆیان هەڵبژارد و 
\q2 دڵیان بە قێزەونەکانیان خۆش بوو، 
\q1  
\v 4 هەروەها منیش کارەساتەکانیان هەڵدەبژێرم و 
\q2 ترسەکانیان بەسەریاندا دەهێنم، 
\q1 لەبەر ئەوەی بانگم کرد و کەس نەبوو وەڵام بداتەوە، 
\q2 قسەم کرد و گوێیان نەگرت، 
\q1 بەڵکو لەبەرچاوم خراپەکارییان کرد، 
\q2 ئەوەی پێی دڵخۆش نەبووم هەڵیانبژارد.» 
\b  
\q1  
\v 5 ئەی ئەوانەی لە ڕێزی وشەی یەزدان دەلەرزن، 
\q2 گوێ لە فەرمایشتی ئەو بگرن: 
\q1 «براکانتان ئەوانەی ڕقیان لێتانە و 
\q2 لەبەر ناوی من دەریانکردن، 
\q1 بە تەوسەوە گوتیان: ”با یەزدان شکۆمەند بێت و 
\q2 دڵخۆشی ئێوە ببینین!“ 
\q2 بەڵام ئەوان شەرمەزار دەبن. 
\q1  
\v 6 دەنگی هاتوهەرایە لە شارەوە، 
\q2 دەنگە لە پەرستگاوە! 
\q1 ئەمە دەنگی یەزدانە 
\q2 سزای شایستەی دوژمنانی دەدات. 
\b  
\q1  
\v 7 «پێش ئەوەی ژان بگرێت، منداڵی بوو، 
\q2 پێش ئەوەی ژانی بۆ بێت، کوڕێکی بوو. 
\q1  
\v 8 کێ شتی وەک ئەمەی بیستووە؟ 
\q2 کێ وەک ئەمەی بینیوە؟ 
\q1 ئایا وڵاتێک لە یەک ڕۆژدا ژان دەیگرێت 
\q2 یان نەتەوەیەک بە یەک جار لە دایک دەبێت؟ 
\q1 بەڵام ئەو ساتەی کە سییۆن ژان دەیگرێت 
\q2 چەندین منداڵی دەبێت.» 
\q1  
\v 9 یەزدان دەفەرموێت: «ئایا من کە ژانی منداڵبوون دەهێنم، 
\q2 وا ناکەم منداڵ لەدایک ببێت؟ 
\q1 یان ئەگەر من وا دەکەم منداڵ ببێت، 
\q2 سکی دایک دادەخەم؟» خودای تۆ دەفەرموێت. 
\q1  
\v 10 «ئەی هەموو خۆشەویستانی ئۆرشەلیم، 
\q2 لەگەڵی دڵخۆش بن و تێیدا شاد بن، 
\q1 ئەی هەموو ئەوانەی شیوەنی بۆ دەگێڕن، 
\q2 بە تەواوی لەگەڵی دڵخۆش بن. 
\q1  
\v 11 بۆ ئەوەی شیری مەمکی بمژن و 
\q2 تێر و ئارام بن 
\q1 هەتا لە پڕی شکۆمەندییەکەی بخۆنەوە و 
\q2 چێژ ببینن.» 
\p  
\v 12 سەبارەت بەمەش یەزدان بەم جۆرە دەفەرموێت: 
\q1 «ئەوەتا من ئاشتی بەسەردا دەشکێنمەوە وەک ڕووبار و 
\q2 شکۆمەندی نەتەوەکان وەک جۆگەیەکی ڕاماڵ، 
\q1 جا ئێوە شیر دەدرێن و لە ئامێز دەگیرێن و 
\q2 لەسەر ئەژنۆکان ڕادەژەنرێن. 
\q1  
\v 13 وەک کەسێک دایکی دڵنەوایی بکات، 
\q2 منیش ئاوا دڵنەواییتان دەکەم، 
\q2 بە ئۆرشەلیم دڵنەوایی دەکرێن.» 
\b  
\q1  
\v 14 جا دەبینن و دڵتان خۆش دەبێت و 
\q2 جەستەتان وەک گیا نەشونما دەکات. 
\q1 جا دەزانرێت کە یەزدان لەگەڵ خزمەتکارەکانی دەبێت، 
\q2 بەڵام لە دوژمنەکانی تووڕە دەبێت. 
\q1  
\v 15 ئەوەتا یەزدان بە ئاگرەوە دێت، 
\q2 گالیسکەکانی وەک گەردەلوولن، 
\q1 تاکو تووڕەییەکەی بە گڕەوە بگەڕێنێتەوە، 
\q2 سەرزەنشتەکەی بە بڵێسەی ئاگرەوە. 
\q1  
\v 16 لەبەر ئەوەی یەزدان بە ئاگر و شمشێرەکەی 
\q2 حوکم بەسەر هەموو مرۆڤدا دەدات، 
\q2 ئەوانەی بە دەستی یەزدان دەکوژرێن زۆر دەبن. 
\p  
\v 17 «پێکەوە دەفەوتێن، ئەوانەی خۆیان تەرخان و پاک دەکەن بۆ چوونە ناو باخچەکان، شوێنی ئەو کەسە دەکەون کە لە ناوەڕاستی ئەوانە کە جرج و گۆشتی بەراز و شتی قێزەون دەخۆن.» ئەوە فەرمایشتی یەزدانە. 
\p  
\v 18 «من کردەوەکانیان و بیروڕایان دەزانم، لەبەر ئەوە خەریکە دێم و هەموو نەتەوەکان و زمانەکان کۆدەکەمەوە، جا دێن و شکۆمەندی من دەبینن.» 
\p  
\v 19 یەزدان دەفەرموێت: «نیشانەیەکیان لەنێو دادەنێم و دەربازبووانیان لێ دەنێرم بۆ نەتەوەکان، بۆ تەرشیش و بۆ لای لیبییەکان و لوودییەکان، ئەوانەی تیرئەندازن، بۆ توبال، یۆنان و دوورگە دوورەکان، ئەوانەی هەواڵی منیان نەبیستووە و شکۆمەندی منیان نەبینیوە، جا شکۆمەندی من لەنێو نەتەوەکاندا ڕادەگەیەنن.  
\v 20 هەموو براکانتان لە هەموو نەتەوەکانەوە وەک پێشکەشکراو بۆ یەزدان لەسەر ئەسپ و بە گالیسکە و بە عەرەبانە و بە هێستر و وشتر بۆ کێوی پیرۆزم بۆ ئۆرشەلیم دەهێننەوە، وەک ئەوەی نەوەی ئیسرائیل پێشکەشکراوی دانەوێڵەیان لەناو دەفرێکی پاک بەپێی ڕێوڕەسم بۆ پەرستگای یەزدان بهێنن.  
\v 21 هەروەها هەندێک لەوان هەڵدەبژێرم بە کاهین و بە لێڤی.» ئەوە فەرمایشتی یەزدانە. 
\p  
\v 22 یەزدان دەفەرموێت: «بێگومان وەک ئەو ئاسمانە نوێیە و ئەو زەوییە نوێیە کە من دروستیان دەکەم لەبەردەممدا دەمێننەوە، ئاواش ناو و نەوەی ئێوە دەمێنێت.  
\v 23 لە سەرەمانگێکەوە بۆ سەرەمانگێک و لە شەممەیەکەوە بۆ شەممەیەک هەموو مرۆڤێک دێت بۆ ئەوەی لەبەردەمم کڕنۆش ببات،» یەزدان دەفەرموێت.  
\v 24 «دەچنە دەرەوە و لاشەی ئەو خەڵکانە دەبینن کە لە من یاخی بوون، چونکە کرمەکانیان نامرن و ئاگریان ناکوژێتەوە و بۆ هەمووان دەبن بە قێزەون.»