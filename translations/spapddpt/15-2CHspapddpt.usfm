\v 19 Pero Uzías, quien tenía un incensario \w en|strong="H5921"\w* su \w mano|strong="H3027"\w* \w para|strong="H5921"\w* quemar incienso, \w se|strong="H5921"\w* llenó \w de|strong="H5921"\w* \w ira|strong="H2196"\w*. Cuando \w se|strong="H5921"\w* airó \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w*, \w le|strong="H5921"\w* brotó \w lepra|strong="H6883"\w* \w en|strong="H5921"\w* su \w frente|strong="H4696"\w*, \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w altar|strong="H4196"\w* \w del|strong="H5921"\w* incienso.  
\v 20 \w Cuando|strong="H3588"\w* \w el|strong="H1931"\w* \w sumo|strong="H7218"\w* \w sacerdote|strong="H3548"\w* \w Azarías|strong="H5838"\w* \w y|strong="H1571"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* \w se|strong="H1931"\w* \w volvieron|strong="H6437"\w* \w hacia|strong="H8033"\w* \w él|strong="H1931"\w*, \w ciertamente|strong="H3588"\w* \w tenía|strong="H1931"\w* \w la|strong="H1931"\w* \w frente|strong="H4696"\w* leprosa. \w Entonces|strong="H3588"\w* \w lo|strong="H1931"\w* hicieron \w salir|strong="H3318"\w* \w de|strong="H3588"\w* prisa \w de|strong="H3588"\w* \w allí|strong="H8033"\w*, \w y|strong="H1571"\w* \w él|strong="H1931"\w* \w mismo|strong="H1931"\w* \w se|strong="H1931"\w* dio prisa \w para|strong="H3588"\w* \w salir|strong="H3318"\w*, \w porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w lo|strong="H1931"\w* \w hirió|strong="H5060"\w*.   
\p
\v 21 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* Uzías \w fue|strong="H1961"\w* \w leproso|strong="H6879"\w* \w hasta|strong="H5704"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* \w muerte|strong="H4194"\w*. \w Vivió|strong="H3117"\w* \w leproso|strong="H6879"\w* \w en|strong="H5921"\w* una \w casa|strong="H1004"\w* aislada, \w pues|strong="H3588"\w* \w fue|strong="H1961"\w* excluido \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \w Su|strong="H3588"\w* \w hijo|strong="H1121"\w* Jotam \w quedó|strong="H1961"\w* \w a|strong="H3068"\w* cargo \w del|strong="H5921"\w* palacio \w real|strong="H4428"\w* \w y|strong="H3588"\w* \w juzgaba|strong="H8199"\w* \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.   
