\v 1 \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*:  
\v 2 \wj \+w Si|strong="H1931"\+w* una persona peca \+w y|strong="H5921"\+w* comete delito \+w contra|strong="H5921"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*, \+w porque|strong="H5921"\+w* engaña \+w a|strong="H3068"\+w* \+w su|strong="H1931"\+w* prójimo \+w en|strong="H5921"\+w* \+w cuanto|strong="H5921"\+w* \+w a|strong="H3068"\+w* depósito \+w o|strong="H3068"\+w* prenda confiada \+w en|strong="H5921"\+w* \+w su|strong="H1931"\+w* \+w mano|strong="H1931"\+w*, \+w o|strong="H3068"\+w* \+w por|strong="H5921"\+w* hurto, \+w o|strong="H3068"\+w* \+w porque|strong="H5921"\+w* roba \+w u|strong="H5704"\+w* oprime \+w a|strong="H3068"\+w* \+w su|strong="H1931"\+w* prójimo,\wj*  
