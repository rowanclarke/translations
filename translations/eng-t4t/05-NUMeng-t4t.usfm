\c 7
\s1 The offerings brought to the Sacred Tent
\p 
\v 1 \w When|strong="H1961"\w* \w Moses|strong="H4872"\w*/\w I|strong="H3117"\w* \w had|strong="H1961"\w* \w finished|strong="H3615"\w* \w setting|strong="H6965"\w* \w up|strong="H6965"\w* \w the|strong="H3605"\w* Sacred Tent, \w he|strong="H3117"\w*/\w I|strong="H3117"\w* \w dedicated|strong="H6942"\w* [MTY] \w it|strong="H6942"\w* \w to|strong="H1961"\w* \w Yahweh|strong="H3068"\w*. \w He|strong="H3117"\w*/\w I|strong="H3117"\w* \w also|strong="H4872"\w* \w dedicated|strong="H6942"\w* \w the|strong="H3605"\w* \w things|strong="H3605"\w* \w that|strong="H3605"\w* \w are|strong="H3117"\w* inside \w the|strong="H3605"\w* tent, \w and|strong="H6965"\w* \w the|strong="H3605"\w* \w altar|strong="H4196"\w* \add for burning sacrifices\add*, \w and|strong="H6965"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w things|strong="H3605"\w* \w that|strong="H3605"\w* \w would|strong="H4872"\w* \w be|strong="H1961"\w* \w used|strong="H1961"\w* \w at|strong="H3117"\w* \w the|strong="H3605"\w* \w altar|strong="H4196"\w*.
\v 2 \w Then|strong="H7126"\w* \w the|strong="H5921"\w* \w leaders|strong="H7218"\w* \w of|strong="H1004"\w* \w the|strong="H5921"\w* \add twelve\add* Israeli \w tribes|strong="H4294"\w*, \w the|strong="H5921"\w* \w same|strong="H1992"\w* \w men|strong="H7218"\w* \w who|strong="H3478"\w* \w had|strong="H3478"\w* \add helped Aaron and Moses/me to\add* \w count|strong="H7218"\w* \w the|strong="H5921"\w* \w men|strong="H7218"\w* \add who could fight in battles\add*,
\v 3 \w came|strong="H7126"\w* \w to|strong="H3068"\w* \w the|strong="H6440"\w* tent, bringing gifts \w to|strong="H3068"\w* \w Yahweh|strong="H3068"\w*. \w They|strong="H3068"\w* \w brought|strong="H7126"\w* \w six|strong="H8337"\w* sturdy/large \w carts|strong="H5699"\w* \w and|strong="H3068"\w* \w twelve|strong="H8147"\w* \w oxen|strong="H1241"\w*, \w one|strong="H3068"\w* \w ox|strong="H7794"\w* \w from|strong="H6440"\w* \w each|strong="H8147"\w* \w of|strong="H3068"\w* \w the|strong="H6440"\w* \w leaders|strong="H5387"\w* \w and|strong="H3068"\w* \w a|strong="H3068"\w* \w cart|strong="H5699"\w* \w from|strong="H6440"\w* \w each|strong="H8147"\w* \w of|strong="H3068"\w* \w the|strong="H6440"\w* \w two|strong="H8147"\w* \w leaders|strong="H5387"\w*.
\p 
\v 4 \w Then|strong="H4872"\w* \w Yahweh|strong="H3068"\w* said \w to|strong="H3068"\w* \w Moses|strong="H4872"\w*/me,
\v 5 “\w Accept|strong="H3947"\w* \w these|strong="H3947"\w* gifts, \w in|strong="H5414"\w* order \w that|strong="H5414"\w* \w the|strong="H5414"\w* descendants \w of|strong="H6310"\w* \w Levi|strong="H3881"\w* \w can|strong="H3947"\w* \w use|strong="H3947"\w* \w them|strong="H5414"\w* \w for|strong="H5414"\w* carrying \w the|strong="H5414"\w* sacred items \w that|strong="H5414"\w* \w are|strong="H6310"\w* here \w at|strong="H1961"\w* \w the|strong="H5414"\w* Sacred Tent.”
\p 
\v 6 \w So|strong="H3947"\w* \w Moses|strong="H4872"\w*/\w I|strong="H5414"\w* \w took|strong="H3947"\w* \w the|strong="H5414"\w* \w carts|strong="H5699"\w* \w and|strong="H4872"\w* \w oxen|strong="H1241"\w* \w and|strong="H4872"\w* \w gave|strong="H5414"\w* \w them|strong="H5414"\w* \w to|strong="H5414"\w* \w the|strong="H5414"\w* descendants \w of|strong="H3947"\w* \w Levi|strong="H3881"\w*.
\v 7 \w He|strong="H5414"\w*/\w I|strong="H5414"\w* \w gave|strong="H5414"\w* \w two|strong="H8147"\w* \w carts|strong="H5699"\w* \w and|strong="H1121"\w* four \w oxen|strong="H1241"\w* \w to|strong="H5414"\w* \w the|strong="H5414"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Gershon|strong="H1648"\w* \w for|strong="H1121"\w* \w their|strong="H5414"\w* \w work|strong="H5656"\w*,
\v 8 \w and|strong="H1121"\w* \w he|strong="H3027"\w*/\w I|strong="H5414"\w* \w gave|strong="H5414"\w* four \w carts|strong="H5699"\w* \w and|strong="H1121"\w* \w eight|strong="H8083"\w* \w oxen|strong="H1241"\w* \w to|strong="H5414"\w* \w the|strong="H5414"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Merari|strong="H4847"\w* \w for|strong="H3027"\w* \w their|strong="H5414"\w* \w work|strong="H5656"\w*. Aaron’s \w son|strong="H1121"\w* Ithamar \w was|strong="H1121"\w* \w the|strong="H5414"\w* supervisor \w of|strong="H1121"\w* \w all|strong="H5414"\w* \w their|strong="H5414"\w* \w work|strong="H5656"\w*.
\v 9 \w But|strong="H3588"\w* \w he|strong="H3588"\w*/\w I|strong="H3588"\w* \w did|strong="H3808"\w* \w not|strong="H3808"\w* \w give|strong="H5414"\w* \w any|strong="H5375"\w* carts \w or|strong="H3808"\w* oxen \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* \w Kohath|strong="H6955"\w*, \w because|strong="H3588"\w* \w they|strong="H3588"\w* \w took|strong="H5375"\w* \w care|strong="H5921"\w* \w of|strong="H1121"\w* \w the|strong="H5921"\w* \w sacred|strong="H6944"\w* \w items|strong="H6944"\w* \w that|strong="H3588"\w* \w were|strong="H1121"\w* \w to|strong="H5921"\w* \w be|strong="H3808"\w* \w carried|strong="H5375"\w* \w on|strong="H5921"\w* \w their|strong="H5375"\w* \w shoulders|strong="H3802"\w*, \add not on carts\add*.
\p 
\v 10 \w On|strong="H3117"\w* \w the|strong="H6440"\w* \w day|strong="H3117"\w* \w that|strong="H3117"\w* \w the|strong="H6440"\w* \w altar|strong="H4196"\w* \w was|strong="H3117"\w* dedicated [MTY], \w the|strong="H6440"\w* \add twelve\add* \w leaders|strong="H5387"\w* \w brought|strong="H7126"\w* other \w gifts|strong="H2598"\w* \w to|strong="H6440"\w* \w be|strong="H3117"\w* dedicated \w and|strong="H3117"\w* put \w them|strong="H6440"\w* \w in|strong="H3117"\w* \w front|strong="H6440"\w* \w of|strong="H3117"\w* \w the|strong="H6440"\w* \w altar|strong="H4196"\w*.
\v 11 \w Yahweh|strong="H3068"\w* said \w to|strong="H3068"\w* \w Moses|strong="H4872"\w*/\w me|strong="H3117"\w*, “\w Each|strong="H3117"\w* \w of|strong="H3068"\w* \w the|strong="H3068"\w* next twelve \w days|strong="H3117"\w* \w one|strong="H3068"\w* \w leader|strong="H5387"\w* \w should|strong="H3068"\w* \w bring|strong="H7126"\w* \w his|strong="H3068"\w* \w gifts|strong="H2598"\w* \w for|strong="H3068"\w* \w the|strong="H3068"\w* \w dedication|strong="H2598"\w* \w of|strong="H3068"\w* \w the|strong="H3068"\w* \w altar|strong="H4196"\w*.”
\p 
\v 12-83 These are the gifts that each of the leaders brought:
\pi1 —\w a|strong="H3068"\w* silver dish that weighed ◄more than three pounds/1.5 kg.►, and \w a|strong="H3068"\w* silver bowl that weighed ◄almost two pounds/800 grams►, both of which were full of good flour and mixed with \add olive\add* oil to be offerings of grain; they both were weighed using the standard scales;
\pi1 —\w a|strong="H3068"\w* small gold dish that weighed ◄four ounces/14 grams►, filled with incense;
\pi1 —\w a|strong="H3068"\w* young bull, \w a|strong="H3068"\w* \add full-grown\add* ram, and \w a|strong="H3068"\w* one-year-old ram, to be sacrifices to be completely burned on the altar;
\pi1 —\w a|strong="H3068"\w* goat to be sacrificed to \add enable me to forgive the people \add*for the sins they have committed;
\pi1 —and two bulls, five full-grown rams, five male goats, and five rams that were one-year-old, to be sacrifices to maintain the people’s fellowship with \w Yahweh|strong="H3068"\w*.
\p This was the order in which the leaders brought their gifts:
\pi1 on the first day, Nahshon, son of Amminadab from the tribe of Judah brought his gifts;
\pi1 on the next/second day, Nethanel, son of Zuar, from the tribe of Issachar;
\pi1 on the next/third day, Eliab, son of Helon, from the tribe of Zebulun;
\pi1 on the next/fourth day, Elizur, son of Shedeur, from the tribe of Reuben;
\pi1 on the next/fifth day, Shelumiel, son of Jurishhaddai, from the tribe of Simeon;
\pi1 on the next/sixth day, Eliasaph, son of Deuel, from the tribe of Gad;
\pi1 on the next/seventh day, Elishama, son of Ammihud, from the tribe of Ephraim;
\pi1 on the next/eighth day, Gamaliel, son of Pedahzur, from the tribe of Manasseh;
\pi1 on the next/ninth day, Abidan, son of Gideoni, from the tribe of Benjamin;
\pi1 on the next/tenth day, Ahiezer, son of Ammishaddai, from the tribe of Dan;
\pi1 on the next/eleventh day, Pagiel, son of Acran, from the tribe of Asher;
\pi1 on the next/twelfth day, Ahira, son of Enam, from the tribe of Naphtali.
\p 
\v 84-88 When the altar was dedicated to \w Yahweh|strong="H3068"\w*, those \add twelve\add* leaders brought these gifts:
\pi1 —twelve silver plates and twelve silver bowls, weighing \w a|strong="H3068"\w* total of about ◄60 pounds/27.6 kg.►, each of them being weighed on the scales kept in the Sacred Tent;
\pi1 —twelve gold dishes filled with incense, weighing \w a|strong="H3068"\w* total of about ◄three pounds/1.4 kg.►, each being weighed on those same scales;
\pi1 —twelve bulls, twelve \add full-grown\add* rams, and twelve one-year-old rams, to be sacrifices that were completely burned, along with the grain offerings;
\pi1 —twelve goats to be sacrificed \add to forgive the people\add* for the sins \add they have committed\add*;
\pi1 —and 24 bulls, 60 full-grown rams, 60 goats, and 60 rams that were one-year-old, to be sacrifices to maintain the people’s fellowship with \w Yahweh|strong="H3068"\w*.
\p 
\v 89 Whenever \w Moses|strong="H4872"\w*/\w I|strong="H5921"\w* entered \w the|strong="H5921"\w* Sacred Tent \w to|strong="H1696"\w* \w talk|strong="H1696"\w* \w with|strong="H1696"\w* \w Yahweh|strong="H3068"\w*, \w he|strong="H8147"\w*/\w I|strong="H5921"\w* \w heard|strong="H8085"\w* \w Yahweh|strong="H3068"\w*’s \w voice|strong="H6963"\w* \w speaking|strong="H1696"\w* \w between|strong="H6963"\w* \w the|strong="H5921"\w* \w two|strong="H8147"\w* \add images of\add* creatures \w with|strong="H1696"\w* \w wings|strong="H8147"\w* \w that|strong="H8085"\w* \w were|strong="H3742"\w* \w above|strong="H5921"\w* \w the|strong="H5921"\w* lid \w of|strong="H6963"\w* \w the|strong="H5921"\w* sacred chest.
\c 8
\s1 Aaron set up the lampstand
\p 
\v 1 \w Yahweh|strong="H3068"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*/\w me|strong="H1696"\w*,
\v 2 “\w Tell|strong="H1696"\w* Aaron \w to|strong="H1696"\w* \w put|strong="H5927"\w* \w the|strong="H6440"\w* \w seven|strong="H7651"\w* \w lamps|strong="H5216"\w* \w on|strong="H5927"\w* \w the|strong="H6440"\w* \w lampstand|strong="H4501"\w* \w and|strong="H6440"\w* place \w them|strong="H6440"\w* \w in|strong="H1696"\w* \w such|strong="H1696"\w* \w a|strong="H3068"\w* \w way|strong="H6440"\w* \w that|strong="H5927"\w* \w they|strong="H6440"\w* shine \w toward|strong="H6440"\w* \w the|strong="H6440"\w* \w front|strong="H6440"\w* \w of|strong="H6440"\w* \w the|strong="H6440"\w* \w lampstand|strong="H4501"\w*.”
\p 
\v 3 \w So|strong="H3651"\w* \add Moses/I told him what Yahweh said\add*, \w and|strong="H4872"\w* \w he|strong="H3651"\w* \w did|strong="H6213"\w* \w that|strong="H3068"\w*.
\v 4 \w The|strong="H7200"\w* \w lampstand|strong="H4501"\w* \w had|strong="H3068"\w* \w been|strong="H3068"\w* \w made|strong="H6213"\w* \w from|strong="H5704"\w* \w gold|strong="H2091"\w* \w that|strong="H7200"\w* \w had|strong="H3068"\w* \w been|strong="H3068"\w* \w hammered|strong="H4749"\w* \add from one large lump of gold\add*, \w from|strong="H5704"\w* \w its|strong="H6213"\w* \w base|strong="H3409"\w* \w to|strong="H5704"\w* \w the|strong="H7200"\w* decorations \w at|strong="H3068"\w* \w the|strong="H7200"\w* top \add that resembled\add* \w flowers|strong="H6525"\w*. \w The|strong="H7200"\w* \w lampstand|strong="H4501"\w* \w was|strong="H3068"\w* \w made|strong="H6213"\w* \w exactly|strong="H3651"\w* \w like|strong="H4758"\w* \w Yahweh|strong="H3068"\w* \w had|strong="H3068"\w* \w told|strong="H6213"\w* \w Moses|strong="H4872"\w*/\w me|strong="H7200"\w* \w that|strong="H7200"\w* \w it|strong="H1931"\w* \w should|strong="H3068"\w* \w be|strong="H3068"\w* \w made|strong="H6213"\w*.
\s1 Instructions for dedicating the descendants of Levi
\p 
