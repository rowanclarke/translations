\id 1TH  
\h Tesalonike I. 
\toc1 Tesalonike I. 
\toc2 Tesalonike I. 
\toc3 Tesalonike I. 
\mt1 Tesalonike I.  
\c 1  
\s1 O KA EPISETOLE  
\q1
\v 1 NA Paulo aku, a me Silevano, a me Timoteo, i ka ekalesia o ko Tesalonike, iloko o ke Akua ka Makua, a me ka Haku Iesu Kristo, no oukou ke aloha a me ka pomaikai, mai ke Akua mai, o ko kakou Makua a me ka Haku Iesu Kristo.   
\b  
\q1
\v 2 Ke hoomaikai mau aku nei makou i ke Akua no oukou a pau, e hoohiki ana ia oukou i ka makou pule;   
\q1
\v 3 E manao mau aku ana i ka hana a ka manaoio o oukou, a me ka hooikaika o ke aloha, a me ke ahonui o ka manaolana i ko kakou Haku, ia Iesu Kristo, imua o ke alo o ke Akua ko kakou Makua:   
\q1
\v 4 E ike aku ana hoi, e na hoahanau aloha, i ko oukou waeia mai e ke Akua.   
\q1
\v 5 No ka mea, aole ma ka olelo wale no i hiki aku ai ka makou euanelio io oukou la, aka, ma ka mana no hoi, a me ka Uhane Hemolele, a me ka hooiaio loa; na ike hoi oukou i ke ano o ko makou noho ana iwaena o oukou, no oukou.   
\q1
\v 6 A ua hahai mai oukou mamuli o makou a me ka Haku, ua apo mai oukou i ka olelo me ka ehaeha nui, a me ka olioli no ka Uhane Hemolele:   
\q1
\v 7 Pela i lilo ai oukou i mau alakai no ka poe manaoio a pau i Makedonia a me Akaia.   
\q1
\v 8 No ka mea, mai o oukou aku i pae aku ai ka olelo a ka Haku, aole ma Makedonia a me Akaia wale no, aka, ma ia wahi aku a ia wahi aku, i hoolahaia ae ai ko oukou paulele ana i ke Akua, i ole ai e pono ia makou ke hai hou aku.   
\q1
\v 9 No ka mea, na lakou no i hoike mai no kakou, i ke ano o ko makou komo ana iwaena o oukou, a me ko oukou huli ana i ke Akua, mai na'kua kii mai e malama aku i ke Akua ola oiaio;   
\q1
\v 10 A e kali hoi i kana Keiki, mai ka lani mai, ana i hoala mai ai, mai ka make mai, ia Iesu, nana kakou e hoopakele i ka inaina e kau mai ana.   
\c 2  
\b  
\q1
\v 1 U A ike hoi oukou, e na hoahanau, i ko makou komo ana iwaena o oukou, aole ia he mea ole;   
\q1
\v 2 Aka, i ko makou eha mua ana'e me ka hoino wale ia mai, ma Pilipi, ua ike oukou, ua wiwo ole ae la makou ma ko kakou Akua i ka hai aku ia oukou i ka euanelio a ke Akua, me ka paio nui ana.   
\q1
\v 3 No ka mea, aole ma ka wahahee ka makou ao ana aku, aole hoi ma ka haumia aole hoi ma ka hoopunipuni;   
\q1
\v 4 Aka, me ka haawi ana mai o ke Akua ia makou, i kauohaia mai ka euanelio ia makou, pela hoi makou e olelo aku nei; aole me he mea hoolealea la i kanaka, aka, i ke Akua, i ka mea nana ko kakou naau i hoao mai nei.   
\q1
\v 5 Aole makou i lawe i na hua olelo malimali, ua ike oukou; aole hoi i ka hookohu o ka makee waiwai; o ke Akua ka mea ike.   
\q1
\v 6 Aole makou i imi i ka hoonaniia mai e kanaka, aole hoi e oukou, aole hoi e hai, i ka wa pono e lilo ai makou i poe hookaumaha, me he mau lunaolelo la na Kristo.   
\q1
\v 7 Ua ahonui makou iwaena o oukou, e like me ka wahine hanai la, e malama ana i kana mau keiki:   
\q1
\v 8 Oia, me ko makou aloha nui aku ia oukou, ua oluolu makou ke haawi aku, aole i ka euanelio wale no a ke Akua ia oukou, aka, i ko makou ola kekahi, no ka mea, he hiwahiwa oukou na makou.   
\q1
\v 9 Ke hoomanao nei no oukou, e na hoahanau, i ka makou hana, a me ko makou luh! ana hoi; e hana ana i ka po a me ke ao, i ole ai makou e lilo i mea e luhi ai kekahi o oukou, pela makou i hai aku ai ia oukou i ka euanelio a ke Akua.   
\q1
\v 10 O oukou ko makou poe hoike, a o ke Akua kekahi, i ka hemolele, a me ka pono, a me ka hala ole o ko makou noho ana iwaena o oukou ka poe i manaoio.   
\q1
\v 11 Ua ike hoi oukou i ko makou hooikaika ana'ku, a me ka hooluolu ana'ku, a me ke kauoha ana'ku ia oukou a pau, me he makuakane la i kana mau keiki,   
\q1
\v 12 I hele pono oukou ma ka pono o ke Akua, ka mea nana oukou i hea mai iloko o kona aupuni, a i kona nani.   
\b  
\q1
\v 13 No ia mea hoi i hoomaikai mau aku ai makou i ke Akua, no ka mea, i ka loaa ana ia oukou o ka ke Akua olelo a oukou i lohe mai ai ia makou nei, aole oukou i apo mai ia me ho olelo la na kanaka, aka, he olelo no na ke Akua, he oiaio no ia, o ka mea i hooikaika nui iloko o oukou o ka poe i manaoio.   
\q1
\v 14 No ka mea, ua lilo mai oukou, e na hoahanau, i mau mea hoohalike me na ekalesia o ke Akua, ma ludea, iloko o Kristo Iesu; no ka mea, ua hoinoia mai hoi oukou e ko ka aina o oukou iho, e like me lakou e ka poe Iudaio;   
\q1
\v 15 Ka poe i pepehi i ka Haku ia Iesu, a i ko lakou poe kaula hoi, a i alualu kolohe mai hoi ia makou; aole no e hooluolu i ke Akua, a ua ku e i na kanaka a pau.   
\q1
\v 16 Ua keakea mai la lakou ia makou i ka olelo aku i ko na aina e e ola'i lakou, e hoopiha mau ana i ko lakou hewa; aka, e kau mai ana ka inaina nui loa maluna iho o lakou.   
\b  
\q1
\v 17 Aka, o makou la, e na hoahanau, ua hookaawaleia mai nei mai o oukou mai la, i keia mau la, o ko makou kino, aole ka naau, ua ma kemake loa makou e ike hou aku i ko oukou mau maka, ua hooikaika nui aku ilaila.   
\q1
\v 18 No ia mea, o ko makou manao e hele aku io oukou la, owau o Paulo kekahi i keia manawa a i keia manawa; aka, ua alalai mai la o Satana ia makou.   
\q1
\v 19 Heaha hoi ko makou manaolana a me ka olioli, a me ka lei e hauoli ai makou? aole anei o oukou ia, i ke alo o ko kakou Haku o Ieau Kristo i kona hiki ana mai?   
\q1
\v 20 No ka mea, o oukou no ka nani a me ka olioli o makou.   
\c 3  
\b  
\q1
\v 1 A I hiki ole ia makou ke hoomanawanui hou aku, manao iho la makou he pono ke waiho hookahi ia mai ma Atenai.   
\q1
\v 2 A ua hoouna aku la ia Timoteo, o ko kakou hoahanau, he mea lawehana na ke Akua, a o ko makou hoalawehana ma ka euanelio o Kristo, e hooikaika aku oia ia oukou, a e hooluolu hoi ia oukou i ko oukou manaoio ana;   
\q1
\v 3 I hoonaue ole ia kekahi e keia mau pilikia; no ka mea, ua ike no oukou, ua haawiia mai ia mau mea no kakou.   
\q1
\v 4 No ka mea, i ko makou noho pu ana me oukou, na hai e aku makou ia oukou, e hoinoia'na kakou; a ua hiki mai la no ia pela, ua ike hoi oukou.   
\q1
\v 5 Nolaila, i ka pono ole ia'u ke hoomanawanui hou aku, ua hoouna aku la au e ike i ko oukou manaoio, o lilo paha oukou i ka hoowalewaleia mai e ka hoowalewale, a ua lilo iho la ka makou hana i mea ole:   
\q1
\v 6 Aka, i ka hoi ana mai nei o Timoteo mai o oukou mai io makou nei, me ka hoike lea mai ia makou i ka pono o ko oukou manaoio ana me ke aloha, a i ko oukou manao maikai mau ana mai ia makou, e ake ana e ike ia makou, e like hoi me makou ia oukou;   
\q1
\v 7 No ia mea, e na hoahanau, no ko oukou manaoio, ua oluolu iho nei makou ia oukou iloko o ko makou ehaeha ana, a me ka pilikia a pau.   
\q1
\v 8 No ka mea, ano, ua ola makou ke kupaa oukou iloko o ka Haku.   
\q1
\v 9 Pehea hoi makou e hoomaikai hou aku ai i ke Akua no oukou, no ka olioli a pau a makou e olioli nei ia oukou imua o ko kakou Akua?   
\q1
\v 10 E pole nui ana i ka po a me ke ao, i ike aku makou i ko oukou maka, a e hoolawa aku hoi i ke koenao ko oukou manaoio.   
\b  
\q1
\v 11 Na ke Akua ko kakou Makua, a me ko kakou Haku na Iesu Kristo makou e alakai pono aku io oukou la.   
\q1
\v 12 Na ka Haku hoi oukou e hoo piha a hu aku i ke aloha i kekahi i kekahi, a ia hai ae hoi a pau, e like me makou ia oukou;   
\q1
\v 13 I hookupaa mai oia i ko oukou naau i kina ole ka hemolele imua o ke Akua, o ko kakou Makua, i ka hiki ana mai o ko kakou Haku o Iesu Kristo, me kona poe hoano a pau loa.   
\c 4  
\b  
\q1
\v 1 EIA hou neia, e na hoahanau, ke nonoi aku nei makou me ka hooikaika aku ia oukou ma o Iesu Kristo la, e like me ka pono a oukou i lohe mai ai ia makou e hele ai oukou, a e hooluolu ai i ke Akua, pela hoi oukou e hoomahuahua mau aku ai.   
\q1
\v 2 Ua ike hoi oukou i na kauoha a makou i haawi aku ai ia oukou ma ka Haku, ma o Iesu la.   
\q1
\v 3 Eia hoi ka makemake o ke Akua, o ko oukou maemae ana, i haalele loa oukou i ka moe kolohe;   
\q1
\v 4 I ike hoi oukou a pau i ka malama i kana ipu ae, a i kana ipu ae, me ka maemae a me ka maikai.   
\q1
\v 5 Aole ma ke kuko ino wale, e like me na lahuikanaka, ka poe ike ole i ke Akua,   
\q1
\v 6 Aole make hoopoho kekahi, aole ka hoomake hewa i ka kona hoahanau i kekahi mea; no ka mea, o ka Haku ka mea nana ia poe e hoopai mai, oia ka makou i hai mua aku ai me ka hoike e aku ia oukou.   
\q1
\v 7 Aole ke Akua i hea mai ia kakou no ka haumia, aka, no ka hemolele no.   
\q1
\v 8 O ka mea hoi i hoowahawaha mai, aole ia i hoowahawaha i ke kanaka, i ke Akua no nana i haawi mai i kona Uhane Hemolele ia makou.   
\b  
\q1
\v 9 A o ke aloha hoahanau hoi, aole o oukou hemahema e pono ai au ke palapala aku ia oukou; no ka mea, ua aoia mai oukou e ke Akua e aloha i kekahi i kekahi   
\q1
\v 10 Oia hoi, o ka oukou ia e hana'i i na hoahanau a pau ma Makedonia a puni; a, ke nonoi aku nei makou ia oukou, e na hoahanau, e hoomahuahua nui ae oukou.   
\q1
\v 11 A e imi oukou e noho malie me ka hana aku i ka oukou hana iho, a, me ko oukou mau lima iho e hana'i, e like me ka makou kauoha ana'ku ia oukou;   
\q1
\v 12 I pono ka oukou hele ana imua o ka poe o waho, a i nele ole hoi oukou i kekahi mea.   
\b  
\q1
\v 13 Aole hoi au i makemake, e na hoahanau, e naaupo oukou no ka poe i hiamoe, i ole ai oukou e kumakena, e like me ka poe manaolana ole.   
\q1
\v 14 No ka mea, ina i manaoio kakou, na make aku la o Iesu, a ua ala hou mai, pela no hoi ke Akua e lawe pu mai ai me ia i ka poe e hiamoe aua iloko o Iesu.   
\q1
\v 15 Eia ka makou e olelo aku nei ia oukou ma ka olelo a ka Haku, o kakou ka poe e ola ana i ka hiki ana mai o ka Haku, aole kakou e hiki e aku mamua o ka poe e hiamoe ana.   
\q1
\v 16 No ka mea, e iho io mai no ka Haku mai ka lani mai, me ka hooho, a me ka leo o ka luna auela, a me ka pu a ke Akua; a o ka poe make iloko o Kristo ke ala e mai.   
\q1
\v 17 Alaila e kaili pu ia'ku kakou ka poe i koe e ola okoa ana, me lakou, iloko o na ao kaalelewa e halawai pu me ka Haku, i ka lewa; oia hoi, e mau loa ana ko kakou noho ana me ka Haku.   
\q1
\v 18 Nolaila hoi e hooluolu oukou i kekahi i kekahi ma keia mau huaolelo.   
\c 5  
\b  
\q1
\v 1 A NO na wa, a me na manawa, e na hoahanau, aole o oukou hemahema e pono ai au ke palapala aku ia oukou:   
\q1
\v 2 No ka mea, ua ike paka no oukou, e, o ka la o ka Haku, me he aihue la i ka po, pela no ia e hiki mai ai.   
\q1
\v 3 A i ka wa e olelo ai lakou, He pomaikai, he malu; alaila, loohia koke e mai lakou e ka make, me he haakokohi la o ka wahine hapai; aole hoi lakou e pakele.   
\q1
\v 4 Aka, o oukou, e na hoahanau, aole oukou iloko o ka pouli, e loohia ai oukou e ua ia la, me he aihue la.   
\q1
\v 5 He poe keiki oukou a pau no ka malamalama, a he mau kamalii no hoi no ke ao; aole no ka po kakou, aole hoi no ka pouli.   
\q1
\v 6 Mai hiamoe hoi kakou e like me kekahi poe; aka, e kiai kakou me ke kuoo.   
\q1
\v 7 No ka mea, o ka poe hiamoe, na hiamoe lakou i ka po; a o ka poe ona, ua ona lakou i ka po.   
\q1
\v 8 Aka, o kakou ka poe o ke ao, e kuoo kakou, e komo ana i ka pale umauma o ka manaoio a me ke aloha; a i ka papale koa hoi o ka manaolana i ke ola.   
\q1
\v 9 Aole ke Akua i hookaawale mai ia kakou no ka inaina, aka, no ka loaa ana mai a ko ola i ko kakou Haku ia Iesu Kristo,   
\q1
\v 10 I ka mea i make aku no kakou, i ola pu ai kakou me ia, i ke ala ana, a i ka hiamoe ana paha o kakou.   
\q1
\v 11 Nolaila e hooluolu pu ai oukou ia oukou iho, a e hookukulu kekahi i kekahi, e like me ka oukou hana ana no.   
\b  
\q1
\v 12 Ke nonoi aku nei makou ia oukou, e na hoahanau, e ike aku i ka poe e hooikaika ana iwaena o oukou, ka poe maluna iho o oukou iloko o ka Haku, a e ao mai ana ia oukou;   
\q1
\v 13 A e mahalo nui aku ia lakou me ke aloha, no ka lakou hana. E kuikahi hoi oukou iho.   
\q1
\v 14 Ke nei aku nei makou ia oukou, e na hoahanau, e ao aku i ka poe hookekee, e hooluolu i ka poe naau hopohopo, e kokua i ka poe nawaliwali, e ahonui aku hoi i na kanaka a pau:   
\q1
\v 15 E malama hoi, i hoihoi ole aku kekahi i ka hewa no ka hewa i kekahi; e hahai mau oukou i ka pono iwaena o oukou a me na kanaka a pau.   
\q1
\v 16 E hauoli mau loa.   
\q1
\v 17 E pule hooki ole.   
\q1
\v 18 Ma na mea a pau e hoomaikai aku ai: no ka mea, oia ko ke Akua manao iloko o Kristo Iesu ia oukou.   
\q1
\v 19 Mai kinai i kauhane.   
\q1
\v 20 Mai hoowahawaha i ka wanana ana.   
\q1
\v 21 E hooiaio i na mea a pau; a e hoopaa i ka mea pono.   
\q1
\v 22 E naalele i na mea ano ino a pau.   
\b  
\q1
\v 23 A na ke Akua e malu ai e hoomaemae loa mai ia oukou; a e malama pono ia mai ko oukou naau, a me ko oukou uhane, a me ko oukou kino, me ka hala ole, a hiki mai ko kakou Haku, o Iesu Kristo.   
\q1
\v 24 He oiaio mau ko ka mea nana oukou i hea mai, nana no hoi ia e hana.   
\b  
\q1
\v 25 E na hoahanau, e pule oukou no makou.   
\b  
\q1
\v 26 E aloha aku i na hoahanau a pau me ka honi hoano.   
\q1
\v 27 Ke kauoha aku nei au ia oukou ma ka Haku, e heluheluia aku keia episetole i ka poe hoahanau laa a pau loa.   
\b  
\q1
\v 28 la oukou ke aloha mai ko kakou Haku o Iesu Kristo. Amene.   