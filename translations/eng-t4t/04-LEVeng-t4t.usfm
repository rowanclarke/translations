\c 21
\s1 Rules for priests
\p 
\v 1 \w Yahweh|strong="H3068"\w* \w also|strong="H3068"\w* said \w to|strong="H3068"\w* \w Moses|strong="H4872"\w*/\w me|strong="H5315"\w*, “Speak \w to|strong="H3068"\w* \w the|strong="H3068"\w* \w priests|strong="H3548"\w*, \w the|strong="H3068"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* Aaron, \w and|strong="H1121"\w* say \w to|strong="H3068"\w* \w them|strong="H1121"\w*,
\v 2 ‘\w You|strong="H3588"\w* priests \w must|strong="H1121"\w* \w not|strong="H3588"\w* cause yourselves \w to|strong="H1121"\w* become unfit \w to|strong="H1121"\w* do \w my|strong="H3588"\w* work \w by|strong="H3588"\w* \add touching\add* corpses. Priests \w are|strong="H1121"\w* permitted \w to|strong="H1121"\w* touch \w only|strong="H3588"\w* \w the|strong="H3588"\w* corpses \w of|strong="H1121"\w* \w close|strong="H7138"\w* \w relatives|strong="H7607"\w*, such \w as|strong="H3588"\w* \w the|strong="H3588"\w* priest’s mother \w or|strong="H1121"\w* \w father|strong="H1121"\w* \w or|strong="H1121"\w* \w his|strong="H3588"\w* \w son|strong="H1121"\w* \w or|strong="H1121"\w* \w daughter|strong="H1323"\w* \w or|strong="H1121"\w* \w his|strong="H3588"\w* brother.
