\v 24 C'est pourquoi \w il|strong="H4481"\w* \w a|strong="H3068"\w* \w envoyé|strong="H7972"\w* \w cette|strong="H1836"\w* \w extrémité|strong="H6447"\w* \w de|strong="H4481"\w* \w main|strong="H3028"\w*, \w et|strong="H4481"\w* \w cette|strong="H1836"\w* \w écriture|strong="H3792"\w* \w a|strong="H3068"\w* été \w tracée|strong="H7560"\w*.   
\p
\v 25 « \w Voici|strong="H1836"\w* l'\w écriture|strong="H3792"\w* \w qui|strong="H1836"\w* \w a|strong="H3068"\w* été \w tracée|strong="H7560"\w* : MENE, MENE, TEKEL, UPHARSIN.   
\p
\v 26 « \w Voici|strong="H1836"\w* l'interprétation \w de|strong="H4437"\w* \w ces|strong="H1836"\w* \w mots|strong="H4406"\w* :  
\m MENE : \w Dieu|strong="H1836"\w* \w a|strong="H3068"\w* \w compté|strong="H4484"\w* les jours \w de|strong="H4437"\w* \w ton|strong="H1836"\w* \w règne|strong="H4437"\w*, \w et|strong="H6591"\w* \w y|strong="H6591"\w* \w a|strong="H3068"\w* \w mis|strong="H4406"\w* \w fin|strong="H8000"\w*.   
