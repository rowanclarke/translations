\q1 
\v 33 Aatz u Nasoon,
\q2 Aminadaab ibꞌii vitat.
\q1 Aatz u Aminadaab,
\q2 Araam ibꞌii vitat.
\q1 Aatz u Araam,
\q2 Esroom ibꞌii vitat.
\q1 Aatz u Esroom, Fares ibꞌii vitat.
\q1 Aatz u Fares, Judaa ibꞌii vitat.
\q1 
\v 34 Aatz u Judaa,
\q2 Jacoob ibꞌii vitat.
\q1 Aatz u Jacoob, Isaac ibꞌii vitat.
\q1 Aatz u Isaac,
\q2 Abrahaam ibꞌii vitat.
