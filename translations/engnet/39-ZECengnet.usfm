\p 
\v 7 “\w What|strong="H4310"\w* \w are|strong="H4310"\w* \w you|strong="H6440"\w*, \w you|strong="H6440"\w* \w great|strong="H1419"\w* \w mountain|strong="H2022"\w*? \w Because|strong="H6440"\w* \w of|strong="H2022"\w* \w Zerubbabel|strong="H2216"\w* \w you|strong="H6440"\w* \w will|strong="H4310"\w* \w become|strong="H3318"\w* \w a|strong="H3068"\w* \w level|strong="H4334"\w* \w plain|strong="H4334"\w*! \w And|strong="H1419"\w* \w he|strong="H6440"\w* \w will|strong="H4310"\w* \w bring|strong="H3318"\w* \w forth|strong="H3318"\w* \w the|strong="H6440"\w* temple capstone \w with|strong="H6440"\w* \w shoutings|strong="H8663"\w* \w of|strong="H2022"\w* ‘\w Grace|strong="H2580"\w*! \w Grace|strong="H2580"\w*!’ \w because|strong="H6440"\w* \w of|strong="H2022"\w* \w this|strong="H6440"\w*.”
