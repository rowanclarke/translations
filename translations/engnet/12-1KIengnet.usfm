\v 14  \w But|strong="H3588"\w* \w Micaiah|strong="H4321"\w* \w said|strong="H1696"\w*, “\w As|strong="H3068"\w* \w certainly|strong="H3588"\w* \w as|strong="H3068"\w* \w the|strong="H3588"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w lives|strong="H2416"\w*, \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w say|strong="H1696"\w* \w what|strong="H3588"\w* \w the|strong="H3588"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w tells|strong="H1696"\w* \w me|strong="H1696"\w* \w to|strong="H1696"\w* \w say|strong="H1696"\w*.”   
