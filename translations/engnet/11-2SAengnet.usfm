\v 3  \w and|strong="H7725"\w* \w will|strong="H1961"\w* \w bring|strong="H7725"\w* \w the|strong="H3605"\w* \w entire|strong="H3605"\w* \w army|strong="H5971"\w* \w back|strong="H7725"\w* \w to|strong="H7725"\w* \w you|strong="H3605"\w*. \w In|strong="H7725"\w* exchange \w for|strong="H1245"\w* \w the|strong="H3605"\w* \w life|strong="H3605"\w* \w of|strong="H5971"\w* \w the|strong="H3605"\w* \w man|strong="H3605"\w* \w you|strong="H3605"\w* \w are|strong="H5971"\w* \w seeking|strong="H1245"\w*, \w you|strong="H3605"\w* \w will|strong="H1961"\w* \w get|strong="H7725"\w* \w back|strong="H7725"\w* \w everyone|strong="H3605"\w*. \w The|strong="H3605"\w* \w entire|strong="H3605"\w* \w army|strong="H5971"\w* \w will|strong="H1961"\w* \w return|strong="H7725"\w* \w unharmed|strong="H7965"\w*.”   
\p
\v 4  \w This|strong="H1697"\w* \w seemed|strong="H5869"\w* \w like|strong="H3478"\w* \w a|strong="H3068"\w* \w good|strong="H3474"\w* \w idea|strong="H1697"\w* \w to|strong="H3478"\w* Absalom \w and|strong="H3478"\w* \w to|strong="H3478"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w leaders|strong="H2205"\w* \w of|strong="H1697"\w* \w Israel|strong="H3478"\w*.  
