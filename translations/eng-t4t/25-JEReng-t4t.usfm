\q2 \w that|strong="H3605"\w* \w are|strong="H3027"\w* \w made|strong="H4639"\w* \w by|strong="H3027"\w* \w skilled|strong="H2450"\w* \w workers|strong="H2796"\w*.   
\q1
\v 10 \w But|strong="H3808"\w* \w Yahweh|strong="H3068"\w* \w is|strong="H3068"\w* \w the|strong="H3068"\w* \add only\add* \w true|strong="H3068"\w* \w God|strong="H3068"\w*;  
