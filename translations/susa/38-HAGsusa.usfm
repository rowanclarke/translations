\id HAG  
\h عَننَبِ هَفٍ 
\toc1 عَلَ شَ مَسٍنيِ عَننَبِ هَفٍ بّ 
\toc2 عَننَبِ هَفٍ 
\toc3 هَف 
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ هَفٍ بّ 
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ 
\ip عَلَ نَشَ عَننَبِ هَفٍ شّي دَرِ سَلَمُ ثٍرِ سٍ مَنفّ دَرِيُسِ شَ وَشَتِ حّ كّمّ سُولِ بٍينُ عِسَ شَ بَرِ. عِسِرَيِلَكَيٍ نُ بَرَ حّ تٌنفٌ سٌلٌقٍرٍ رَبَ كٌنيِيَ كُي ثٍرِ سٍ بْشِ مَ عٍ شَ كُيٍ بَتُي شَ قٍ رَ، كْنْ عَلَ نَشَ عَ نِيَ دَرِيُسِ شَ عٍ بّحِن فبِلٍنقٍ رَ عِسِرَيِلَ بْشِ مَ. عٍ تٌ مّننِ لِ، عٍ شَ تَايٍ نُن عَلَ شَ هْرْ مْبَنشِ بِرِن نُ بَرَ كَنَ. عٍ نَشَ وَلِ سُشُ نٍيٍ يَءِلَنقٍ رَ، كْنْ عٍ يَشُييٍ نَشَ عٍ تْورْ. نَ كُي عَلَ نَشَ عَننَبِ سٌقٌنِ نُن عَننَبِ هَفٍ شّي دَرِ سَلَمُ عَلَكٌ عٍ شَ عِسِرَيِلَكَيٍ رَلِمَنِيَ. 
\ip عَننَبِ هَفٍ تٌ وْيّن عِسِرَيِلَ كُنتِفِيٍ رَ، عَ نَشَ عَ تٌ عٍ مُ فّشِ نَتّ تٌنفٌدٍ سِندٍن عٍ شَ عَلَ شَ هْرْ مْبَنشِ تِ. عَلَ نَشَ عَ مَسٍن عٍ بّ نَمِحْنمّ سَابُي رَ، عَ نُ لَن عٍ شَ سّنبّ سٌ عَلَ شَ بَنشِ تِقٍ نَن مَ، دَنفِ عٍ فبٍ بَنشِيٍ تِقٍ رَ. نَ نُ بَرَ عَ نِيَ بْشِ شَ لُ تْورّ كُي سَنسِ بٌفِ شَ قٍ رَ. بَلٌي نُ بَرَ شُرُن نَ وَكِلِتَرٍحَ شَ قٍ رَ. 
\ip عَننَبِ هَفٍ تٌ كُنتِفِيٍ رَلِمَنِيَ، عٍ نَشَ عَلَ شَ وَلِ سُشُ عَ قَنيِ رَ. عَ نَشَ عَ قَلَ عٍ بّ عَلَ شَ هْرْ مْبَنشِ قِرِن ندٍ قَمَ تٌقَندٍ دَنفِقٍ نَ سِنفٍ رَ. عَلَتَلَ نَشَ لَايِدِ تٌنفٌ عٍ بّ عَ شَ بَرَكَ رَفٌرٌ عٍ مَ نَ شَ قٍ رَ. 
\ip يِ نَمِحْنمّ مَسٍنيِ قِندِ مَ لْننِ بٍلٍبٍلٍ نَن نَ تٌ مِشِيٍ بّ. شَ وٌن تٌندِ عَلَ شَ وَلِ سُشُدٍ، عَ قَن تٌندِ مَ نّ وٌن مَلِدٍ. كْنْ شَ وٌن بَرَ نَتّ تٌنفٌ عَلَ بّ، وٌن شَ عَ سَفٌ رَبَ، عَ نِيَمَ نّ وٌن مَ دُنِحّءِفِرِ بِرِن شَ سْونّيَ. عَلَ وَ مَ نَ نَن شْن مَ وٌن بّ، كْنْ قٌ وٌن شَ دَنشَنِيَ عَ مَ. عَلَ شَ نَ نَتّ رَ سٌ وٌن بْحّ كُي. عَمِنَ. 
\mt1 عَننَبِ هَفٍ شَ كِتَابُي 
\c 1  
\s1 دُنِحّءِفِرِ سْونّيَتَرٍحَ قَتَنشِ قٍ نَشَن نَ 
\p  
\v 1 مَنفّ دَرِيُسِ شَ مَنفّيَ حّ قِرِن ندٍ، كِكٍ سٍننِ ندٍ، شِ سِنفٍ رَ، عَلَتَلَ نَشَ يِ مَسٍنيِ تِ سَلَتِيٍلِ شَ دِ سٌرٌبَبٍلِ بّ، يُدَيَ فٌمِنَ، عَننَبِ هَفٍ سَابُي رَ. عَ مَن نَشَ يِ مَسٍنيِ تِ سّرّشّدُبّ كُنتِفِ يٌسَدَكِ شَ دِ يٌسُوٍ بّ.  
\v 2 عَلَتَلَ شَ مَسٍنيِ نَن يَ، «يِ حَمَ عَ قَلَمَ، ‹عَ مُ لَن وٌن شَ عَلَتَلَ شَ بَنشِ يَءِلَن سِندٍن.›»  
\v 3 نَ كُي، عَلَتَلَ نَشَ يِ مَسٍنيِ تِ عٍ بّ عَننَبِ هَفٍ سَابُي رَ، 
\q1  
\v 4 «عَ لَنمَ وٌ تَن شَ لُ بَنشِ رَشُنمَشِ كُي، 
\q1 ﭑ تَن مَ هْرْ مْبَنشِ كَنَشِ؟» 
\q1  
\v 5 مَنفّ عَلَتَلَ شَ مَسٍنيِ نَن يَ، 
\q1 «وٌ وٌ شَ وَلِ مَتٌ. 
\q1  
\v 6 وٌ سَنسِ شْرِ فبٍفبٍ سِمَ، 
\q1 كْنْ وٌ نَشَن سْتْمَ، نَ شُرُن. 
\q1 وٌ وٌ دّفٍمَ، كْنْ وٌ مُ لُفَمَ. 
\q1 وٌ وٌ مِنمَ، كْنْ عَ مُ وٌ رَلِمَ. 
\q1 وٌ شِنبٍلِ دٌنمَ رَفٌرٌ مَ وٌ مَ، 
\q1 كْنْ شِنبٍلِ مُ بَمَ وٌ مَ. 
\q1 وٌ وٌ شَ وَلِ سَرٍ سْتْمَ، 
\q1 كْنْ يَلٍ نَ وٌ شَ يُبَيٍ مَ.» 
\b  
\q1  
\v 7 مَنفّ عَلَتَلَ شَ مَسٍنيِ نَن يَ، 
\q1 «وٌ وٌ شَ وَلِ مَتٌ. 
\q1  
\v 8 وٌ تٍ فٍيَ قَرِ وُرِ قٍندٍ، 
\q1 وٌ شَ ﭑ مَ بَنشِ تِ 
\q1 عَلَكٌ ﭑ شَ بِنيّ سْتْ نَشَن نَقَنشِ ﭑ مَ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن عَ رَ. 
\b  
\q1  
\v 9 «وٌ بَرَ وَ هَرِفٍ فبٍفبٍ شْن مَ، 
\q1 كْنْ وٌ دٌندٌرٌنتِ فبَنسَن نَن سْتْشِ. 
\q1 وٌ بَرَ نَ شَنِن وٌ شْنيِيٍ، 
\q1 ﭑ بَرَ نَ قَن نَيٍنسٍن حّ. 
\q1 نَ كٍلِشِ مُنسٍ مَ؟ 
\q1 نَ كٍلِشِ ﭑ مَ بَنشِ شَ كَنّ نَن مَ قٍ رَ. 
\q1 عَ قَ لِ، كَنكَن سِنفَنشِ وَكِلِ مَ عَ فبٍ وَلِ تَن نَ، 
\q1 كْنْ وٌ مُ سٍسٍ رَبَمَ ﭑ فبٍ وَلِ تَن شَ قٍ رَ.» 
\q1 مَنفّ عَلَتَلَ شَ مَسٍنيِ نَن عَ رَ. 
\b  
\q1  
\v 10 «نَ قٍ بَرَ عَ نِيَ تُنّ يٍ مُ فٌرٌ مَ، 
\q1 بْشِ مُ دَشَمُي رَ مِنِمَ. 
\q1  
\v 11 ﭑ بَرَ عَ نِيَ بْشِ نُن فٍيَيٍ شَ شَرَ، 
\q1 وٌ شَ مّنفِ، وٌ شَ وّنِ نّينّ، وٌ شَ تُرٍ، 
\q1 وٌ شَ سَنسِيٍ، وٌ شَ مِشِيٍ، وٌ شَ شُرُ سٍيٍ، 
\q1 نُن وٌ شَ وَلِ بِرِن شَ نَشَسِ.» 
\p  
\v 12 سَلَتِيٍلِ شَ دِ سٌرٌبَبٍلِ، سّرّشّدُبّ كُنتِفِ يٌسَدَكِ شَ دِ يٌسُوٍ، نُن حَمَ دْنشْي بِرِن نَشَ عٍ مَرِفِ عَلَتَلَ شُي سُشُ، عَ نَشَن قِشِ عَننَبِ هَفٍ مَ. حَمَ نَشَ فَاشُ عَلَتَلَ يَ رَ.  
\v 13 عَلَتَلَ شَ شّيرَ عَننَبِ هَفٍ نَشَ عَلَتَلَ شَ يِ مَسٍنيِ قَلَ حَمَ بّ، «وٌن بِرِن نَن عَ رَ.» عَلَتَلَ شَ مَسٍنيِ نَن عَ رَ. 
\p  
\v 14 عَلَتَلَ نَشَ سَلَتِيٍلِ شَ دِ سٌرٌبَبٍلِ، يُدَيَ فٌمِنَ بْحّ رَوُتُن. عَ مَن نَشَ سّرّشّدُبّ كُنتِفِ يٌسَدَكِ شَ دِ يٌسُوٍ نُن حَمَ دْنشْي بْحّ رَوُتُن. نَ نَشَ عَ نِيَ عٍ شَ عٍ مَرِفِ عَلَتَلَ شَ بَنشِ تِ وَلِ سُشُ،  
\v 15 دَرِيُسِ شَ مَنفّيَ حّ قِرِن ندٍ، كِكٍ سٍننِ ندٍ، شِ مْشْحّن نُن نَانِ ندٍ رَ. 
\c 2  
\s1 عَلَ شَ هْرْ مْبَنشِ نّينّ شَ نْرّ 
\p  
\v 1 عَ كِكٍ سٌلٌقٍرٍ ندٍ، شِ مْشْحّن نُن كٍرٍن ندٍ رَ، عَلَتَلَ نَشَ يِ مَسٍنيِ تِ عَننَبِ هَفٍ سَابُي رَ،  
\v 2 «عَ قَلَ سَلَتِيٍلِ شَ دِ سٌرٌبَبٍلِ بّ، يُدَيَ فٌمِنَ، نُن سّرّشّدُبّ كُنتِفِ يٌسَدَكِ شَ دِ يٌسُوٍ، نُن حَمَ دْنشْي بّ، 
\q1  
\v 3 ‹ندٍ نَ وٌ يَ مَ 
\q1 نَشَن بَرَ يِ بَنشِ تٌ نُ عَ قٌرِ مَ كِ عَ شَ نْرّ كُي؟ 
\q1 يَكْسِ تَن فٌ، وٌ عَ تٌمَ دِ؟ 
\q1 تِدٍ يٌ مُ نَ عَ مَ وٌ بّ سْنْن، كَ؟›» 
\q1  
\v 4 عَلَتَلَ شَ مَسٍنيِ نَن يَ، 
\q1 «سٌرٌبَبٍلِ، عِ عِ سّنبّ سٌ. 
\q1 سّرّشّدُبّ كُنتِفِ يٌسُوٍ يٌسَدَكِ شَ دِ، 
\q1 عِ عِ سّنبّ سٌ. 
\q1 حَمَ بِرِن، وٌ وٌ سّنبّ سٌ.» 
\b  
\q1 عَلَتَلَ شَ مَسٍنيِ نَن يَ، 
\q1 «وٌ وَلِ سُشُ، 
\q1 وٌن بِرِن نَ عَ رَ.» 
\q1 مَنفّ عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\q1  
\v 5 «ﭑ تٌ وٌ رَ مِنِ مِسِرَ بْشِ مَ، 
\q1 ﭑ نُ بَرَ يِ سَاتّ تٌنفٌ وٌ بّ. 
\q1 ﭑ شَشِلِ نَ وٌ تَفِ، 
\q1 وٌ نَشَ فَاشُ قٍقٍ مَ.» 
\b  
\q1  
\v 6 مَنفّ عَلَتَلَ شَ مَسٍنيِ نَن يَ، 
\q1 «عَ فبٍ مُ لُشِ ﭑ شَ كٌورٍ نُن بْشِ رَ سّرّن، 
\q1 ﭑ شَ بَا نُن شَرٍ رَ مَشَ. 
\q1  
\v 7 ﭑ سِ بِرِن نَسّرّنمَ نّ، 
\q1 عٍ قَمَ نّ هَرِفٍ فبٍفبٍ رَ ﭑ بّ نَشٍيٍ قَن عَ بِرِن بّ. 
\q1 يِ بَنشِ كُي رَقٍمَ نّ نْرّ رَ.» 
\q1 مَنفّ عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\q1  
\v 8 «ﭑ تَن نَن فبٍ نَ فبٍتِ رَ، 
\q1 ﭑ تَن نَن فبٍ نَ شّيمَ رَ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\q1  
\v 9 «نْرّ نَشَن قَمَ لُدٍ ﭑ مَ بَنشِ مَ، 
\q1 نَ دَنفِمَ نّ عَ سِنفٍ رَ.» 
\q1 مَنفّ عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\q1 «ﭑ يِ بَنشِ قِندِ مَ بْحّسَ يِرٍ نَن نَ مِشِيٍ بّ.» 
\q1 مَنفّ عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\p  
\v 10 دَرِيُسِ شَ مَنفّيَ حّ قِرِن ندٍ، كِكٍ سٌلٌمَنَانِ، شِ مْشْحّن نُن نَانِ ندٍ رَ، عَلَتَلَ نَشَ يِ مَسٍنيِ تِ عَننَبِ هَفٍ بّ،  
\v 11 «عَلَتَلَ شَ مَسٍنيِ نَن يَ. سّرّشّدُبّيٍ مَشْرِن،  
\v 12 ‹شَ مِشِ ندٍ سُبٍ سّنِيّنشِ سَ عَ شَ سٌسٍ كُي، عَ قَ نَ سٌسٍ دِن تَامِ، وّنِ، تُرٍ، شَ نَ مُ عَ رَ دٌنسٍ فبّتّ رَ نَشَن مُ سّنِيّنشِ، نَ سّنِيّنمَ نَ سُبٍ سّنِيّنشِ سَابُي رَ؟› سّرّشّدُبّيٍ عِ يَابِمَ نّ، ‹عَدٍ.›» 
\p  
\v 13 عَننَبِ هَفٍ نَشَ عٍ مَشْرِن، «شَ مِشِ ندٍ دِن قُرٍ رَ، عَ قَ قِندِ سّنِيّنتَرٍ رَ، عَ دِن سٍسٍ رَ، نَ قَن قِندِ مَ نّ سٍ سّنِيّنتَرٍ رَ؟» سّرّشّدُبّيٍ نَشَ عَ يَابِ، «عِيٌ، نَ قَن قِندِ مَ نّ سٍ سّنِيّنتَرٍ رَ.» 
\p  
\v 14 نَ كُي، عَننَبِ هَفٍ مَن نَشَ عَ مَسٍن، 
\q1 «يِ حَمَ نَ نَ كِ نّ. 
\q1 سِ نَشَن نَ ﭑ يَ تٌدٍ رَ، عٍ نَ نَ كِ نّ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\q1 «عٍ بّلّشّ قْشِ مُ سّنِيّن، 
\q1 عٍ نَشَن بَمَ سّرّشّ رَ سٍ سّنِيّنتَرٍ نَن عَ رَ.» 
\b  
\q1  
\v 15 «يَكْسِ، وٌ قٍ مَتٌ عَ قَنيِ رَ نَشَن قَمَ رَبَدٍ كٍلِ تٌ مَ هَن يَرٍ. 
\q1 بٍينُن وٌ شَ فّمّ دْشْ عَ بٌورٍ قَرِ 
\q1 عَلَتَلَ شَ هْرْ مْبَنشِ وَلِ كُي، 
\q1 وٌ شَ رَتُ يِ مَ؛ 
\q1  
\v 16 وٌ تٌ نُ بُسَلِ مْشْحّن قٍنمَ، 
\q1 وٌ نُ قُ فبَنسَن نَن سْتْمَ. 
\q1 وٌ تٌ نُ تُرٍ لِتِرِ تٌنفٌ سُولِ قٍنمَ، 
\q1 وٌ نُ لِتِرِ مْشْحّن فبَنسَن نَن سْتْمَ. 
\q1  
\v 17 ﭑ بَرَ وٌ شَ وَلِ بِرِن كَنَ قُرٍ نُن بَلَبَلَنيِ رَ، 
\q1 كْنْ وٌ مُ تِن فبِلٍندٍ ﭑ مَ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\b  
\q1  
\v 18 «يَكْسِ، وٌ عَ مَتٌ عَ قَنيِ رَ، 
\q1 قٍ نَشَن قَمَ رَبَدٍ كٍلِ تٌ مَ هَن يَرٍ، 
\q1 كٍلِ يِ كِكٍ سٌلٌمَنَانِ شِ مْشْحّن نُن نَانِ مَ، 
\q1 كٍلِ عَلَتَلَ شَ هْرْ مْبَنشِ شَ فّمّ سِنفٍ دْشْ لْشْي مَ. 
\q1 وٌ شَ وٌ حْشْ سَ نَ شْن مَ عَ قَنيِ رَ. 
\q1  
\v 19 مّنفِ رَفَتَشِ مُ نَ وٌ شَ سٍنتِيٍ كُي، كَ؟ 
\q1 وّنِ بِلِ، شْرّ بِلِ، كْوبّ بِلِ، نُن عٌلِوِ بِلِ، 
\q1 نٍيٍ قَن مُ بٌفِقٍ هَلِ كٍرٍن. 
\q1 كْنْ، قْلْ تٌ مَ، ﭑ قَمَ نّ بَرَكّ سَدٍ وٌ مَ.» 
\b  
\p  
\v 20 عَلَتَلَ مَن نَشَ مَسٍنيِ قِرِن ندٍ تِ عَننَبِ هَفٍ بّ، شِ مْشْحّن نُن نَانِ ندٍ رَ. 
\q1  
\v 21 «عَ قَلَ سٌرٌبَبٍلِ بّ يُدَيَ فٌمِنَ، 
\q1 ‹ﭑ كٌورٍ نُن بْشِ رَ سّرّنمَ نّ. 
\q1  
\v 22 ﭑ مَنفّيٍ رَفٌرٌ مَ نّ عٍ شَ كِبَنيِ كُي. 
\q1 ﭑ سِ فبّتّيٍ سّنبّ كَنَمَ نّ. 
\q1 ﭑ سْورِ رَفِسٍيٍ نُن عٍ رَفِمَيٍ رَبِرَ مَ نّ. 
\q1 ﭑ سٌي نُن سٌي رَفِيٍ قَشَمَ نّ 
\q1 عٍ نفَشَكٍرٍنيِ شَ سَنتِدّفّمَ رَ.›» 
\b  
\q1  
\v 23 عَلَتَلَ شَ مَسٍنيِ نَن يَ، 
\q1 «نَ لْشْي، سٌرٌبَبٍلِ سَلَتِيٍلِ شَ دِ 
\q1 ﭑ عِ قِندِ مَ نّ ﭑ مَ كٌنيِ رَ، 
\q1 عِ لُمَ نّ عَلْ ﭑ مَ شُرُندّ تْنشُمَ. 
\q1 ﭑ بَرَ عِ سُفَندِ.» 
\q1 مَنفّ عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.