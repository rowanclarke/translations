\s1 The man that used to be blind believed in Jesus  
\p
\v 35 \w Jesus|strong="G2424"\w* heard \w that|strong="G3754"\w* \w the|strong="G2532"\w* Jewish \w leaders|strong="G3004"\w* \w told|strong="G3004"\w* \w that|strong="G3754"\w* \w man|strong="G1519"\w* \w to|strong="G1519"\w* \w get|strong="G2147"\w* \w out|strong="G1544"\w* \w of|strong="G5207"\w* \w the|strong="G2532"\w* meeting house. \w So|strong="G2532"\w* \w he|strong="G2532"\w* \w went|strong="G2424"\w* \w and|strong="G2532"\w* \w found|strong="G2147"\w* \w the|strong="G2532"\w* \w man|strong="G1519"\w*, \w and|strong="G2532"\w* \w Jesus|strong="G2424"\w* \w asked|strong="G3004"\w* \w him|strong="G3588"\w*, “\w Do|strong="G2532"\w* \w you|strong="G4771"\w* \w believe|strong="G4100"\w* \w in|strong="G1519"\w* \w the|strong="G2532"\w* special \w man|strong="G1519"\w* \w that|strong="G3754"\w* \w God|strong="G3004"\w* \w sent|strong="G1544"\w* \w from|strong="G2532"\w* heaven?”   
\p
\v 36 \w The|strong="G2532"\w* \w man|strong="G5101"\w* \w said|strong="G3004"\w*, “\w Sir|strong="G2962"\w*, \w tell|strong="G3004"\w* \w me|strong="G3004"\w* \w who|strong="G5101"\w* \w he|strong="G2532"\w* \w is|strong="G1510"\w*, \w so|strong="G2443"\w* \w that|strong="G2443"\w* \w I|strong="G2532"\w* \w can|strong="G3004"\w* \w believe|strong="G4100"\w* \w in|strong="G1519"\w* \w him|strong="G1565"\w*.”   
\p
