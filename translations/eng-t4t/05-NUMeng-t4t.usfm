\c 32
\s1 The land east of the Jordan River
\p 
\v 1 \w The|strong="H7200"\w* \w people|strong="H1121"\w* \w of|strong="H1121"\w* \w the|strong="H7200"\w* tribes \w of|strong="H1121"\w* \w Reuben|strong="H7205"\w* \w and|strong="H1121"\w* \w Gad|strong="H1410"\w* \w had|strong="H1961"\w* \w much|strong="H7227"\w* \w livestock|strong="H4735"\w*. \w They|strong="H7200"\w* \w saw|strong="H7200"\w* \w that|strong="H7200"\w* \w the|strong="H7200"\w* \w land|strong="H4725"\w* \w near|strong="H7200"\w* \w Jazer|strong="H3270"\w* \add city\add* \w and|strong="H1121"\w* \w the|strong="H7200"\w* \w Gilead|strong="H1568"\w* \add region east of the Jordan River\add* \w had|strong="H1961"\w* \w good|strong="H3966"\w* \add grass\add* \w for|strong="H1121"\w* \w the|strong="H7200"\w* \w animals|strong="H1961"\w* \add to graze on\add*.
