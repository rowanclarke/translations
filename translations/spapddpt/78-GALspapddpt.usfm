\v 1 \w Pero|strong="G1161"\w* \w digo|strong="G3004"\w*: \w mientras|strong="G1909"\w* \w el|strong="G3588"\w* \w heredero|strong="G2818"\w* es \w niño|strong="G3516"\w*, \w aunque|strong="G1161"\w* es \w señor|strong="G2962"\w* \w de|strong="G1909"\w* \w todas|strong="G3956"\w* \w las|strong="G3588"\w* \w cosas|strong="G3745"\w*, \w en|strong="G1909"\w* \w nada|strong="G3762"\w* \w difiere|strong="G1308"\w* \w de|strong="G1909"\w* \w un|strong="G3588"\w* esclavo,  
\v 2 sino \w está|strong="G3588"\w* \w bajo|strong="G5259"\w* tutores \w y|strong="G2532"\w* administradores hasta \w el|strong="G3588"\w* \w tiempo|strong="G4287"\w* fijado \w por|strong="G5259"\w* \w el|strong="G3588"\w* \w padre|strong="G3962"\w*.   
\p
\v 3 \w Así|strong="G3779"\w* \w también|strong="G2532"\w* \w nosotros|strong="G2249"\w*, \w cuando|strong="G3753"\w* \w éramos|strong="G1510"\w* \w niños|strong="G3516"\w*, nos esclavizábamos \w bajo|strong="G5259"\w* \w los|strong="G3588"\w* \w rudimentos|strong="G4747"\w* \w del|strong="G3588"\w* \w mundo|strong="G2889"\w*.  
\v 4 \w Pero|strong="G1161"\w* \w cuando|strong="G3753"\w* \w vino|strong="G2064"\w* \w el|strong="G3588"\w* \w cumplimiento|strong="G4138"\w* \w del|strong="G3588"\w* \w tiempo|strong="G5550"\w*, \w Dios|strong="G2316"\w* \w envió|strong="G1821"\w* \w a|strong="G1537"\w* \w su|strong="G3588"\w* \w Hijo|strong="G5207"\w*, nacido \w de|strong="G1537"\w* \w mujer|strong="G1135"\w*, nacido \w bajo|strong="G5259"\w* \add la\add* \w Ley|strong="G3551"\w*,  
\v 5 \w para|strong="G2443"\w* \w que|strong="G3588"\w* redimiera \w a|strong="G2443"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* estaban \w bajo|strong="G5259"\w* \add la \add*\w Ley|strong="G3551"\w*, \w a|strong="G2443"\w* fin \w de|strong="G5259"\w* \w que|strong="G3588"\w* recibiéramos \w la|strong="G3588"\w* \w adopción|strong="G5206"\w*.\f + \fr 4:5 \ft Adoptar es recibir como hijo. Adopción de hijos es una redundancia que no está en el original.\f*   
\p
\v 6 \w Por|strong="G1519"\w* \w cuanto|strong="G3588"\w* \add ustedes\add* \w son|strong="G1510"\w* \w hijos|strong="G5207"\w*, \w Dios|strong="G2316"\w* \w envió|strong="G1821"\w* \w al|strong="G3588"\w* \w Espíritu|strong="G4151"\w* \w de|strong="G1519"\w* \w su|strong="G3588"\w* \w Hijo|strong="G5207"\w* \w a|strong="G1519"\w* nuestros \w corazones|strong="G2588"\w*, \w Quien|strong="G3588"\w* \w clama|strong="G2896"\w*: \tl ¡Abba!\tl* (\w Padre|strong="G3962"\w*).  
\v 7 \w Por|strong="G1223"\w* \w tanto|strong="G5620"\w*, \w ya|strong="G3765"\w* \w no|strong="G3765"\w* \w eres|strong="G1510"\w* esclavo \w sino|strong="G1487"\w* \w hijo|strong="G5207"\w*, \w y|strong="G2532"\w* \w si|strong="G1487"\w* \w hijo|strong="G5207"\w*, \w también|strong="G2532"\w* \w heredero|strong="G2818"\w* \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1223"\w* \w Dios|strong="G2316"\w*.   
\s1 Asombro de Pablo  
\p
\v 8 Pero \w entonces|strong="G5119"\w*, \w ciertamente|strong="G3303"\w*, \w por|strong="G3588"\w* \w no|strong="G3756"\w* \w conocer|strong="G1492"\w* a \w Dios|strong="G2316"\w*, ustedes servían como esclavos a \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w por|strong="G3588"\w* \w naturaleza|strong="G5449"\w* \w no|strong="G3756"\w* \w son|strong="G1510"\w* \w dioses|strong="G2316"\w*.  
\v 9 \w Pero|strong="G1161"\w* \w ahora|strong="G3568"\w*, \w por|strong="G5259"\w* \w cuanto|strong="G3739"\w* \w conocen|strong="G1097"\w* \w a|strong="G1909"\w* \w Dios|strong="G2316"\w*, \w y|strong="G2532"\w* \w más|strong="G1161"\w* \w bien|strong="G3123"\w*, \w por|strong="G5259"\w* \w cuanto|strong="G3739"\w* fueron conocidos \w por|strong="G5259"\w* \w Él|strong="G3588"\w*, ¿\w cómo|strong="G4459"\w* \w vuelven|strong="G3825"\w* \w otra|strong="G3825"\w* vez \w a|strong="G1909"\w* \w los|strong="G3588"\w* débiles \w y|strong="G2532"\w* \w pobres|strong="G4434"\w* \w rudimentos|strong="G4747"\w*, \w a|strong="G1909"\w* \w los|strong="G3588"\w* \w cuales|strong="G3739"\w* \w quieren|strong="G2309"\w* \w otra|strong="G3825"\w* vez \w servir|strong="G1398"\w* \w como|strong="G4459"\w* esclavos?  
\v 10 \w Se|strong="G2532"\w* someten escrupulosamente a guardar \w días|strong="G2250"\w*, \w meses|strong="G3376"\w*, \w tiempos|strong="G2540"\w* \w y|strong="G2532"\w* \w años|strong="G1763"\w*.  
\v 11 \w Temo|strong="G5399"\w* \w por|strong="G1519"\w* ustedes, \w no|strong="G3361"\w* sea \w que|strong="G1519"\w*, \w de|strong="G1519"\w* algún modo, un trabajo duro \w entre|strong="G1519"\w* ustedes fue \w en|strong="G1519"\w* vano.   
\s1 Recuerdo de la primera visita  
\p
\v 12 Les \w ruego|strong="G1189"\w*, hermanos, \w que|strong="G3754"\w* \w sean|strong="G1096"\w* \w como|strong="G5613"\w* \w yo|strong="G1473"\w*, \w porque|strong="G3754"\w* \w yo|strong="G1473"\w* \w también|strong="G2504"\w* soy \w como|strong="G5613"\w* ustedes. \w No|strong="G3762"\w* \w me|strong="G1473"\w* hicieron agravio.  
\v 13 \w Saben|strong="G1492"\w* \w que|strong="G3754"\w* \w la|strong="G3588"\w* primera vez me presenté \w a|strong="G1161"\w* predicarles \w las|strong="G3588"\w* Buenas Noticias \w por|strong="G1223"\w* \add causa de \add*\w una|strong="G3588"\w* enfermedad física.  
\v 14 Ustedes \w no|strong="G3756"\w* \w me|strong="G1473"\w* despreciaron \w ni|strong="G3761"\w* \w me|strong="G1473"\w* rechazaron \w por|strong="G1722"\w* \w la|strong="G3588"\w* prueba \w que|strong="G3588"\w* había \w en|strong="G1722"\w* \w mi|strong="G3588"\w* cuerpo. \w Más|strong="G2532"\w* bien \w me|strong="G1473"\w* \w recibieron|strong="G1209"\w* \w como|strong="G5613"\w* \w a|strong="G1722"\w* \w un|strong="G3588"\w* ángel \w de|strong="G1722"\w* \w Dios|strong="G2316"\w*, \w como|strong="G5613"\w* \w a|strong="G1722"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w*.   
\p
\v 15 ¿\w Dónde|strong="G4226"\w* \w está|strong="G3588"\w* \w su|strong="G3588"\w* bendición? \w Porque|strong="G1063"\w* les \w doy|strong="G1325"\w* \w testimonio|strong="G3140"\w* \w de|strong="G1325"\w* \w que|strong="G3754"\w* \w si|strong="G1487"\w* hubiera sido \w posible|strong="G1415"\w*, se habrían sacado \w los|strong="G3588"\w* \w ojos|strong="G3788"\w* \w y|strong="G3767"\w* \w me|strong="G1473"\w* \w los|strong="G3588"\w* habrían \w dado|strong="G1325"\w*.  
\v 16 ¿Me convertí \w en|strong="G1096"\w* su \w enemigo|strong="G2190"\w* al decirles la verdad?   
\p
\v 17 Ellos están profundamente inquietos \w por|strong="G2443"\w* ustedes, \w no|strong="G3756"\w* \w para|strong="G2443"\w* \w bien|strong="G2573"\w*, sino \w quieren|strong="G2309"\w* separarlos \w para|strong="G2443"\w* \w que|strong="G2443"\w* ustedes mismos estén profundamente preocupados \add por ellos\add*.  
\v 18 \w Bueno|strong="G2570"\w* es estar \w siempre|strong="G3842"\w* profundamente preocupado \w por|strong="G1722"\w* \w lo|strong="G3588"\w* \w bueno|strong="G2570"\w*, \w y|strong="G2532"\w* \w no|strong="G3361"\w* \w solo|strong="G3441"\w* \w al|strong="G3588"\w* estar \w presente|strong="G3918"\w* \w yo|strong="G1473"\w* \w con|strong="G1722"\w* ustedes.   
\p
\v 19 \w Hijos|strong="G5043"\w* míos, \w por|strong="G1722"\w* \w quienes|strong="G3739"\w* \w otra|strong="G3825"\w* vez sufro dolores \w de|strong="G1722"\w* parto \w hasta|strong="G3360"\w* \w que|strong="G3739"\w* \w Cristo|strong="G5547"\w* sea formado \w en|strong="G1722"\w* ustedes,  
\v 20 \w deseaba|strong="G2309"\w* \w más|strong="G1161"\w* \w bien|strong="G1161"\w* estar \w presente|strong="G3918"\w* \w con|strong="G1722"\w* ustedes \w y|strong="G2532"\w* mudar \w mi|strong="G3588"\w* tono, \w porque|strong="G3754"\w* \w me|strong="G1473"\w* asombro \w de|strong="G1722"\w* ustedes.   
\s1 Simbolismo de Sara y Agar  
\p
\v 21 Díganme, \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w desean|strong="G2309"\w* estar \w bajo|strong="G5259"\w* \add la \add*\w Ley|strong="G3551"\w*: ¿\w No|strong="G3756"\w* ponen atención a \w la|strong="G3588"\w* \w Ley|strong="G3551"\w*?  
\v 22 \w Porque|strong="G1063"\w* fue \w escrito|strong="G1125"\w* \w que|strong="G3754"\w* Abraham \w tuvo|strong="G2192"\w* \w dos|strong="G1417"\w* \w hijos|strong="G5207"\w*: \w uno|strong="G1520"\w* \w de|strong="G1537"\w* \w la|strong="G3588"\w* esclava \w y|strong="G2532"\w* \w uno|strong="G1520"\w* \w de|strong="G1537"\w* \w la|strong="G3588"\w* \w libre|strong="G1658"\w*.  
\v 23 \w El|strong="G3588"\w* \w de|strong="G1537"\w* \w la|strong="G3588"\w* esclava \w ciertamente|strong="G3303"\w* fue engendrado \w en|strong="G2596"\w* conformidad \w con|strong="G1223"\w* \w la|strong="G3588"\w* naturaleza \w humana|strong="G4561"\w*, \w pero|strong="G1161"\w* \w el|strong="G3588"\w* \w de|strong="G1537"\w* \w la|strong="G3588"\w* \w libre|strong="G1658"\w*, \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1537"\w* \w la|strong="G3588"\w* \w promesa|strong="G1860"\w*.   
\p
\v 24 \w Esto|strong="G3778"\w* \w es|strong="G3778"\w* dicho simbólicamente, \w porque|strong="G1063"\w* \w éstas|strong="G3778"\w* \add mujeres\add* simbolizan \w dos|strong="G1417"\w* \w pactos|strong="G1242"\w*: \w una|strong="G1520"\w* \w ciertamente|strong="G3303"\w* \w de|strong="G1519"\w* la Montaña \w Sinaí|strong="G4614"\w*, la \w cual|strong="G3748"\w* concibe \w para|strong="G1519"\w* esclavitud.  
\v 25 Agar es \add la\add* Montaña \w Sinaí|strong="G4614"\w* \w en|strong="G1722"\w* Arabia, \w que|strong="G3588"\w* corresponde \w a|strong="G1722"\w* \w la|strong="G3588"\w* Jerusalén \w de|strong="G1722"\w* \w ahora|strong="G3568"\w*, \w porque|strong="G1063"\w* \w sirve|strong="G1398"\w* \w como|strong="G1722"\w* esclava \w con|strong="G3326"\w* \w sus|strong="G3588"\w* \w hijos|strong="G5043"\w*.  
