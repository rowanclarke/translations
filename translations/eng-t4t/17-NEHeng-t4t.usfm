\c 6  
\s1 Plots against Nehemiah  
\p
\v 1 \w Sanballat|strong="H5571"\w*, \w Tobiah|strong="H2900"\w*, \w Geshem|strong="H1654"\w*, \w and|strong="H8085"\w* \w our|strong="H8085"\w* other enemies \w heard|strong="H8085"\w* \add a report\add* \w that|strong="H3588"\w* \w we|strong="H3068"\w* \w had|strong="H1961"\w* finished \w rebuilding|strong="H1129"\w* \w the|strong="H8085"\w* \w wall|strong="H2346"\w*, \w and|strong="H8085"\w* \w that|strong="H3588"\w* \w now|strong="H1961"\w* \w there|strong="H1961"\w* \w were|strong="H1961"\w* \w no|strong="H3808"\w* \w more|strong="H3808"\w* ◄\w gaps|strong="H6556"\w*/places \w where|strong="H3808"\w* \w the|strong="H8085"\w* \w wall|strong="H2346"\w* \w was|strong="H1961"\w* \w not|strong="H3808"\w* finished► (\w although|strong="H3588"\w* \w we|strong="H3068"\w* \w had|strong="H1961"\w* \w not|strong="H3808"\w* \w yet|strong="H3588"\w* put \w the|strong="H8085"\w* \w doors|strong="H1817"\w* \w in|strong="H8085"\w* \w the|strong="H8085"\w* \w gates|strong="H8179"\w*).  
\v 2 \w So|strong="H6213"\w* \w Sanballat|strong="H5571"\w* \w and|strong="H7971"\w* \w Geshem|strong="H1654"\w* \w sent|strong="H7971"\w* \add a message\add* \w to|strong="H3212"\w* \w me|strong="H7971"\w*, \w in|strong="H6213"\w* \w which|strong="H1992"\w* \w they|strong="H1992"\w* said “\w Come|strong="H3212"\w* \w and|strong="H7971"\w* talk \w with|strong="H6213"\w* \w us|strong="H6213"\w* \w at|strong="H6213"\w* \w a|strong="H3068"\w* place \w in|strong="H6213"\w* Ono \w Plain|strong="H1237"\w* \add north of Jerusalem\add*.” \w But|strong="H1992"\w* \add I knew that\add* \w really|strong="H1992"\w* \w they|strong="H1992"\w* wanted \w to|strong="H3212"\w* \w harm|strong="H7451"\w* \w me|strong="H7971"\w* \add if I went there\add*.   
\p
\v 3 \w So|strong="H6213"\w* \w I|strong="H5921"\w* \w sent|strong="H7971"\w* \w messengers|strong="H4397"\w* \w to|strong="H3381"\w* \w them|strong="H5921"\w*, \w to|strong="H3381"\w* tell \w them|strong="H5921"\w*, “\w I|strong="H5921"\w* am \w doing|strong="H6213"\w* \w an|strong="H6213"\w* \w important|strong="H1419"\w* \w work|strong="H4399"\w*, \w and|strong="H7971"\w* \w I|strong="H5921"\w* \w cannot|strong="H3808"\w* \w go|strong="H7971"\w* \w down|strong="H3381"\w* \add there\add*. ◄\w Why|strong="H4100"\w* \w should|strong="H4100"\w* \w I|strong="H5921"\w* \w stop|strong="H7673"\w* \w doing|strong="H6213"\w* \w this|strong="H6213"\w* \w work|strong="H4399"\w* \w just|strong="H6213"\w* \w to|strong="H3381"\w* \w go|strong="H7971"\w* \w down|strong="H3381"\w* \w to|strong="H3381"\w* \add talk with\add* \w you|strong="H7971"\w*?/\w I|strong="H5921"\w* \w do|strong="H6213"\w* \w not|strong="H3808"\w* \w want|strong="H3808"\w* \w to|strong="H3381"\w* \w stop|strong="H7673"\w* \w doing|strong="H6213"\w* \w this|strong="H6213"\w* \w work|strong="H4399"\w* \w just|strong="H6213"\w* \w to|strong="H3381"\w* \w go|strong="H7971"\w* \w down|strong="H3381"\w* \w to|strong="H3381"\w* \add talk with\add* \w you|strong="H7971"\w*.►” [RHQ]  
\v 4 \w They|strong="H1697"\w* \w sent|strong="H7971"\w* \w me|strong="H7971"\w* \w the|strong="H7725"\w* \w same|strong="H2088"\w* \w message|strong="H1697"\w* four \w times|strong="H6471"\w*, \w and|strong="H7971"\w* \w each|strong="H2088"\w* \w time|strong="H6471"\w* \w when|strong="H7725"\w* \w I|strong="H1697"\w* replied \w to|strong="H7725"\w* \w them|strong="H7725"\w* \w I|strong="H1697"\w* \w said|strong="H1697"\w* \w the|strong="H7725"\w* \w same|strong="H2088"\w* \w thing|strong="H1697"\w*.   
\p
\v 5 \w Then|strong="H2088"\w* \w Sanballat|strong="H5571"\w* \w sent|strong="H7971"\w* \w one|strong="H2088"\w* \w of|strong="H3027"\w* \w his|strong="H7971"\w* \w servants|strong="H5288"\w* \w to|strong="H7971"\w* \w me|strong="H7971"\w*, bringing \w a|strong="H3068"\w* \w fifth|strong="H2549"\w* \w message|strong="H1697"\w*. \w This|strong="H2088"\w* \w one|strong="H2088"\w* \w was|strong="H1697"\w* written, but \w it|strong="H7971"\w* \w was|strong="H1697"\w* \w not|strong="H2088"\w* sealed. \add He did that in order that others would read the message that the servant was carrying\add* \w in|strong="H1697"\w* \w his|strong="H7971"\w* \w hand|strong="H3027"\w*.  
\v 6 \w This|strong="H3651"\w* \w is|strong="H1697"\w* \w what|strong="H1697"\w* \w was|strong="H1697"\w* \w written|strong="H3789"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* \w message|strong="H1697"\w*:  
\pi1 “\w Some|strong="H1697"\w* \w people|strong="H1471"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* nearby countries \w have|strong="H1471"\w* \w heard|strong="H8085"\w* \w a|strong="H3068"\w* \w report|strong="H1697"\w* \w that|strong="H8085"\w* \w you|strong="H5921"\w* \w and|strong="H4428"\w* \w the|strong="H5921"\w* other \w Jews|strong="H3064"\w* \w are|strong="H1471"\w* \w rebuilding|strong="H1129"\w* \w the|strong="H5921"\w* \w wall|strong="H2346"\w* \add in order to be able to resist attacks\add*, \w because|strong="H5921"\w* \w you|strong="H5921"\w* \w are|strong="H1471"\w* \w planning|strong="H2803"\w* \w to|strong="H5921"\w* revolt \add against the king of Babylon\add*. \w And|strong="H4428"\w* \w the|strong="H5921"\w* \w report|strong="H1697"\w* \w also|strong="H4428"\w* \w says|strong="H1697"\w* \w that|strong="H8085"\w* \w you|strong="H5921"\w* \w are|strong="H1471"\w* \w planning|strong="H2803"\w* \w to|strong="H5921"\w* become \w the|strong="H5921"\w* \w king|strong="H4428"\w* \add of the Israelis\add*. \w Geshem|strong="H1654"\w* \w says|strong="H1697"\w* \w that|strong="H8085"\w* \w what|strong="H1697"\w* \w they|strong="H3651"\w* \w have|strong="H1471"\w* \w reported|strong="H8085"\w* \w is|strong="H1697"\w* \w true|strong="H3651"\w*.  
\v 7  \add People are also saying that\add* \w you|strong="H5921"\w* \w have|strong="H1571"\w* \w appointed|strong="H5975"\w* \w some|strong="H1697"\w* \w prophets|strong="H5030"\w* \w to|strong="H3212"\w* \w proclaim|strong="H7121"\w* \w in|strong="H5921"\w* \w Jerusalem|strong="H3389"\w* \w that|strong="H8085"\w* \w you|strong="H5921"\w*, \add Nehemiah,\add* \w are|strong="H1697"\w* \w now|strong="H6258"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w* \w in|strong="H5921"\w* Judea. \w King|strong="H4428"\w* \add Artaxerxes\add* \w will|strong="H4428"\w* \w certainly|strong="H1571"\w* \w hear|strong="H8085"\w* \w these|strong="H7121"\w* \w reports|strong="H1697"\w*, \add and then you will be in big trouble\add*. \w So|strong="H7121"\w* \w I|strong="H5921"\w* suggest \w that|strong="H8085"\w* \w we|strong="H3068"\w* \w should|strong="H4428"\w* meet \w together|strong="H3162"\w* \w to|strong="H3212"\w* \w talk|strong="H1697"\w* \w about|strong="H5921"\w* \w this|strong="H6258"\w* \w matter|strong="H1697"\w*.”   
\p
\v 8  \add When I read that message,\add* \w I|strong="H3588"\w* \w sent|strong="H7971"\w* \add the messenger\add* back \w to|strong="H7971"\w* Sanballat \w to|strong="H7971"\w* \w say|strong="H1697"\w*, “\w None|strong="H3808"\w* \w of|strong="H1697"\w* \w what|strong="H1697"\w* \w you|strong="H3588"\w* \w are|strong="H1697"\w* \w saying|strong="H1697"\w* \w is|strong="H3820"\w* true. \w You|strong="H3588"\w* \w have|strong="H1961"\w* ◄\w made|strong="H1961"\w* \w this|strong="H1697"\w* \w up|strong="H1961"\w*/concocted \w this|strong="H1697"\w*► \w in|strong="H1697"\w* \w your|strong="H3588"\w* \w own|strong="H1961"\w* head/\w mind|strong="H3820"\w*.”  
\v 9  \add I said that because I knew that\add* \w they|strong="H3588"\w* \w were|strong="H3027"\w* trying \w to|strong="H6213"\w* \w cause|strong="H6213"\w* \w us|strong="H6213"\w* \w to|strong="H6213"\w* \w be|strong="H3808"\w* \w afraid|strong="H3372"\w*, \w with|strong="H6213"\w* \w the|strong="H3605"\w* \w result|strong="H4480"\w* \w that|strong="H3588"\w* \w we|strong="H3068"\w* \w would|strong="H6213"\w* \w stop|strong="H3808"\w* \w working|strong="H6213"\w* \add on the wall\add*. \w So|strong="H6213"\w* \w I|strong="H3588"\w* actually \w became|strong="H2388"\w* \w more|strong="H4480"\w* determined (\w OR|strong="H3068"\w*, \w I|strong="H3588"\w* prayed \w to|strong="H6213"\w* \w God|strong="H3808"\w* \w to|strong="H6213"\w* \w help|strong="H2388"\w* \w me|strong="H4480"\w*) \add to continue the work\add*.   
\p
\v 10  \add One day\add* \w I|strong="H3588"\w* \w went|strong="H1121"\w* \w to|strong="H1121"\w* talk \w with|strong="H1004"\w* \w Shemaiah|strong="H8098"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Delaiah|strong="H1806"\w* \w and|strong="H1121"\w* \w grandson|strong="H1121"\w* \w of|strong="H1121"\w* \w Mehetabel|strong="H4105"\w*. \w I|strong="H3588"\w* \w went|strong="H1121"\w* \w to|strong="H1121"\w* talk \w with|strong="H1004"\w* \w him|strong="H1931"\w* \w in|strong="H1004"\w* \w his|strong="H3588"\w* \w house|strong="H1004"\w*, \w because|strong="H3588"\w* \w he|strong="H1931"\w* \w was|strong="H1931"\w* \w not|strong="H3588"\w* \w able|strong="H6113"\w* (\w OR|strong="H3068"\w*, allowed) \w to|strong="H1121"\w* leave \w his|strong="H3588"\w* \w house|strong="H1004"\w*. \w He|strong="H1931"\w* said \w to|strong="H1121"\w* \w me|strong="H2026"\w*, “\w You|strong="H3588"\w* \w and|strong="H1121"\w* \w I|strong="H3588"\w* \w must|strong="H1121"\w* enter \w the|strong="H3588"\w* very sacred \w place|strong="H1004"\w* \w in|strong="H1004"\w* \w the|strong="H3588"\w* \w temple|strong="H1004"\w* \w and|strong="H1121"\w* lock \w the|strong="H3588"\w* \w doors|strong="H1817"\w*, \w because|strong="H3588"\w* \w people|strong="H1121"\w* \w are|strong="H1121"\w* going \w to|strong="H1121"\w* come \w to|strong="H1121"\w* \w kill|strong="H2026"\w* \w you|strong="H3588"\w* \w at|strong="H1004"\w* \w night|strong="H3915"\w*.”   
\p
\v 11 \w I|strong="H3808"\w* replied, “\w I|strong="H3808"\w* ◄am \w not|strong="H3808"\w* \w that|strong="H4310"\w* kind \w of|strong="H3808"\w* person/\w do|strong="H4310"\w* \w not|strong="H3808"\w* \w do|strong="H4310"\w* \w things|strong="H3644"\w* \w like|strong="H3644"\w* \w that|strong="H4310"\w*► [RHQ]! \w I|strong="H3808"\w* \w would|strong="H4310"\w* \w not|strong="H3808"\w* run \w and|strong="H1272"\w* hide \w in|strong="H3808"\w* \w the|strong="H3808"\w* \w temple|strong="H1964"\w* \w to|strong="H1272"\w* save \w my|strong="H3808"\w* \w life|strong="H2425"\w*! \w No|strong="H3808"\w*, \w I|strong="H3808"\w* \w will|strong="H4310"\w* \w not|strong="H3808"\w* \w do|strong="H4310"\w* \w that|strong="H4310"\w*!”  
\v 12 \w When|strong="H3588"\w* \w I|strong="H3588"\w* \w thought|strong="H1696"\w* \add about what he had said\add*, \w I|strong="H3588"\w* \w realized|strong="H3588"\w* \w that|strong="H3588"\w* \w God|strong="H3808"\w* \w had|strong="H3588"\w* \w not|strong="H3808"\w* \w told|strong="H1696"\w* Shemaiah \w to|strong="H1696"\w* \w say|strong="H1696"\w* \w that|strong="H3588"\w* \w to|strong="H1696"\w* \w me|strong="H7971"\w*. \w I|strong="H3588"\w* \w realized|strong="H3588"\w* \w that|strong="H3588"\w* \w Tobiah|strong="H2900"\w* \w and|strong="H7971"\w* \w Sanballat|strong="H5571"\w* \w had|strong="H3588"\w* bribed \w him|strong="H5921"\w* \add to say that to me\add*.  
\v 13 \w They|strong="H1992"\w* \w had|strong="H1961"\w* bribed \w him|strong="H6213"\w* \w to|strong="H1961"\w* \w cause|strong="H6213"\w* \w me|strong="H6213"\w* \w to|strong="H1961"\w* \w be|strong="H1961"\w* \w afraid|strong="H3372"\w*. \w They|strong="H1992"\w* \w wanted|strong="H4616"\w* \w me|strong="H6213"\w* \w to|strong="H1961"\w* \add disobey God’s commands and\add* \w sin|strong="H2398"\w* \add by hiding in the temple\add*. \w If|strong="H1961"\w* \w I|strong="H3651"\w* \w did|strong="H6213"\w* \w that|strong="H1931"\w*, \w they|strong="H1992"\w* \w would|strong="H6213"\w* \w be|strong="H1961"\w* able \w to|strong="H1961"\w* \w ruin|strong="H7451"\w* \w my|strong="H1961"\w* \w reputation|strong="H8034"\w* [MTY] \w and|strong="H6213"\w* discredit \w me|strong="H6213"\w*.   
\p
\v 14  \add So I prayed,\add* “\w My|strong="H1961"\w* God, \w do|strong="H4639"\w* \w not|strong="H1961"\w* forget \w what|strong="H4639"\w* \w Tobiah|strong="H2900"\w* \w and|strong="H3372"\w* \w Sanballat|strong="H5571"\w* \w have|strong="H1961"\w* \w done|strong="H1961"\w*. Punish \w them|strong="H1961"\w*. \w And|strong="H3372"\w* \w do|strong="H4639"\w* \w not|strong="H1961"\w* forget \w that|strong="H5030"\w* \w the|strong="H2142"\w* female \w prophet|strong="H5030"\w* \w Noadiah|strong="H5129"\w* \w and|strong="H3372"\w* some \w of|strong="H4639"\w* \w the|strong="H2142"\w* other \w prophets|strong="H5030"\w* \w have|strong="H1961"\w* \w also|strong="H1571"\w* tried \w to|strong="H1961"\w* \w cause|strong="H1961"\w* \w me|strong="H3372"\w* \w to|strong="H1961"\w* \w be|strong="H1961"\w* \w afraid|strong="H3372"\w*.”   
\s1 They finished building the wall  
\p
\v 15 \w On|strong="H3117"\w* October 2 \w we|strong="H3068"\w* \w finished|strong="H7999"\w* rebuilding \w the|strong="H3117"\w* \w wall|strong="H2346"\w*. \w We|strong="H3117"\w* \w did|strong="H3117"\w* \w it|strong="H7999"\w* \w all|strong="H3117"\w* \w in|strong="H3117"\w* 52 \w days|strong="H3117"\w*.  
\v 16 \w When|strong="H3588"\w* \w our|strong="H3605"\w* enemies \w in|strong="H6213"\w* \w the|strong="H3605"\w* nearby countries \w heard|strong="H8085"\w* \w about|strong="H5439"\w* \w that|strong="H3588"\w*, \w they|strong="H3588"\w* \w realized|strong="H3045"\w* \w that|strong="H3588"\w* \w they|strong="H3588"\w* \w had|strong="H1961"\w* \w been|strong="H1961"\w* humiliated, \w because|strong="H3588"\w* \w everyone|strong="H3605"\w* \w knew|strong="H3045"\w* \w that|strong="H3588"\w* \w it|strong="H6213"\w* \w was|strong="H1961"\w* \w because|strong="H3588"\w* God helped \w us|strong="H6213"\w* \w that|strong="H3588"\w* \w we|strong="H3068"\w* \w had|strong="H1961"\w* \w been|strong="H1961"\w* able \w to|strong="H1961"\w* \w do|strong="H6213"\w* \w this|strong="H2063"\w* \w work|strong="H4399"\w* \add and that they had not been able to force us to quit\add*.   
\p
\v 17 \w During|strong="H3117"\w* \w this|strong="H3117"\w* \w time|strong="H3117"\w*, \w the|strong="H5921"\w* Jewish \w leaders|strong="H2715"\w* \w had|strong="H3063"\w* been sending \w many|strong="H7235"\w* messages/letters \w to|strong="H1980"\w* \w Tobiah|strong="H2900"\w*, \w and|strong="H1980"\w* \w Tobiah|strong="H2900"\w* \w had|strong="H3063"\w* been sending messages \w back|strong="H1980"\w* \w to|strong="H1980"\w* \w them|strong="H1992"\w*.  
\v 18 \w Many|strong="H7227"\w* \w people|strong="H1121"\w* \w in|strong="H7227"\w* Judea \w were|strong="H1121"\w* closely associated \w with|strong="H3947"\w* Tobiah, \w because|strong="H3588"\w* \w he|strong="H1931"\w* \w was|strong="H1931"\w* \w the|strong="H3588"\w* \w son-in-law|strong="H2860"\w* \w of|strong="H1121"\w* \w Shecaniah|strong="H7935"\w* \w the|strong="H3588"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Arah. Furthermore, Tobiah’s \w son|strong="H1121"\w* \w Jehohanan|strong="H3076"\w* \w had|strong="H3063"\w* \w married|strong="H3947"\w* \w the|strong="H3588"\w* \w daughter|strong="H1323"\w* \w of|strong="H1121"\w* \w Meshullam|strong="H4918"\w* \w the|strong="H3588"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Berekiah.  
\v 19 \w People|strong="H1571"\w* often talked \w in|strong="H6440"\w* \w my|strong="H7971"\w* \w presence|strong="H6440"\w* \w about|strong="H1961"\w* \w all|strong="H1697"\w* \w the|strong="H6440"\w* \w good|strong="H2896"\w* \w things|strong="H1697"\w* \w that|strong="H1697"\w* \w Tobiah|strong="H2900"\w* \w had|strong="H1961"\w* \w done|strong="H1961"\w*, \w and|strong="H7971"\w* \w then|strong="H1961"\w* \w they|strong="H1697"\w* \w would|strong="H1697"\w* tell \w him|strong="H6440"\w* everything \w that|strong="H1697"\w* \w I|strong="H1697"\w* \w said|strong="H1697"\w*. \w So|strong="H7971"\w* \w Tobiah|strong="H2900"\w* \w sent|strong="H7971"\w* many letters \w to|strong="H3318"\w* \w me|strong="H6440"\w* \w to|strong="H3318"\w* try \w to|strong="H3318"\w* \w cause|strong="H1697"\w* \w me|strong="H6440"\w* \w to|strong="H3318"\w* \w become|strong="H1961"\w* \w afraid|strong="H3372"\w*.   
\c 7  
\p
\v 1 \w After|strong="H1961"\w* \w the|strong="H1129"\w* \w wall|strong="H2346"\w* \w had|strong="H1961"\w* \w been|strong="H1961"\w* finished \w and|strong="H5975"\w* \w we|strong="H3068"\w* \w had|strong="H1961"\w* \w put|strong="H6485"\w* \w the|strong="H1129"\w* \w gates|strong="H1817"\w* \w in|strong="H5975"\w* \w their|strong="H1961"\w* places, \w we|strong="H3068"\w* \w assigned|strong="H6485"\w* \w to|strong="H1961"\w* \w the|strong="H1129"\w* temple \w guards|strong="H7778"\w* \w and|strong="H5975"\w* \w to|strong="H1961"\w* \w the|strong="H1129"\w* members \w of|strong="H2346"\w* \w the|strong="H1129"\w* \add sacred\add* choir \w and|strong="H5975"\w* \w the|strong="H1129"\w* other descendants \w of|strong="H2346"\w* \w Levi|strong="H3881"\w* \w the|strong="H1129"\w* work \w that|strong="H3881"\w* \w they|strong="H5975"\w* \w were|strong="H1961"\w* \w to|strong="H1961"\w* do.  
\v 2 \w I|strong="H3588"\w* \w appointed|strong="H6680"\w* two \w men|strong="H8269"\w* \w to|strong="H5921"\w* \add help me to\add* govern \w Jerusalem|strong="H3389"\w*, \w my|strong="H5921"\w* brother \w Hanani|strong="H2607"\w* \w and|strong="H3389"\w* \w Hananiah|strong="H2608"\w* \w who|strong="H1931"\w* \w was|strong="H1931"\w* \w the|strong="H5921"\w* \w commander|strong="H8269"\w* \w of|strong="H8269"\w* \w the|strong="H5921"\w* \w fortress|strong="H1002"\w* \add in Jerusalem\add*. \w Hananiah|strong="H2608"\w* always \w did|strong="H3389"\w* \w his|strong="H5921"\w* work reliably, \w and|strong="H3389"\w* \w he|strong="H1931"\w* \w revered|strong="H3372"\w* God \w more|strong="H7227"\w* \w than|strong="H5921"\w* most other \w people|strong="H1931"\w* \w do|strong="H6680"\w*.  
\v 3 \w I|strong="H5704"\w* said \w to|strong="H5704"\w* \w them|strong="H1992"\w*, “Do \w not|strong="H3808"\w* \w open|strong="H6605"\w* \w the|strong="H5704"\w* \w gates|strong="H8179"\w* \w of|strong="H1004"\w* \w Jerusalem|strong="H3389"\w* \w until|strong="H5704"\w* late \w each|strong="H1817"\w* morning. \w And|strong="H1004"\w* close \w the|strong="H5704"\w* \w gates|strong="H8179"\w* \w and|strong="H1004"\w* put \w the|strong="H5704"\w* bars across \w the|strong="H5704"\w* \w doors|strong="H1817"\w* \add ◄late in each afternoon/before sunset►\add* \w while|strong="H5704"\w* \w the|strong="H5704"\w* gatekeepers \w are|strong="H1992"\w* \w still|strong="H5975"\w* guarding \w the|strong="H5704"\w* \w gates|strong="H8179"\w*.” \w I|strong="H5704"\w* \w also|strong="H3389"\w* told \w them|strong="H1992"\w* \w to|strong="H5704"\w* \w appoint|strong="H5975"\w* \w some|strong="H1992"\w* \w people|strong="H3427"\w* \w who|strong="H3427"\w* \w lived|strong="H3427"\w* \w in|strong="H3427"\w* \w Jerusalem|strong="H3389"\w* \w to|strong="H5704"\w* \w be|strong="H3808"\w* \w guards|strong="H4931"\w* \add on the wall\add*, \w and|strong="H1004"\w* \w to|strong="H5704"\w* assign \w some|strong="H1992"\w* \w of|strong="H1004"\w* \w them|strong="H1992"\w* \w to|strong="H5704"\w* \w be|strong="H3808"\w* \w guards|strong="H4931"\w* \w at|strong="H3427"\w* certain \w other|strong="H5048"\w* \w places|strong="H1004"\w* \w and|strong="H1004"\w* \w to|strong="H5704"\w* assign \w others|strong="H1992"\w* \w to|strong="H5704"\w* \w guard|strong="H4929"\w* \w the|strong="H5704"\w* area close \w to|strong="H5704"\w* \w their|strong="H1992"\w* own \w houses|strong="H1004"\w*.   
\s1 A list of those who returned to Jerusalem  
\p
\v 4 \w The|strong="H8432"\w* \w city|strong="H5892"\w* \add of Jerusalem\add* covered \w a|strong="H3068"\w* \w large|strong="H1419"\w* area, \w but|strong="H5971"\w* \add at that time\add* \w not|strong="H5892"\w* \w many|strong="H1419"\w* \w people|strong="H5971"\w* \w lived|strong="H8432"\w* \w in|strong="H1004"\w* \w the|strong="H8432"\w* \w city|strong="H5892"\w*, \w and|strong="H1419"\w* \w they|strong="H5971"\w* \w had|strong="H3027"\w* \w not|strong="H5892"\w* \w built|strong="H1129"\w* \w many|strong="H1419"\w* new \w houses|strong="H1004"\w* yet [HYP].  
\v 5  \add To defend the city, we needed more people there.\add* \w Then|strong="H5414"\w* \w God|strong="H5414"\w* \w gave|strong="H5414"\w* \w me|strong="H5414"\w* \w the|strong="H5414"\w* idea \w to|strong="H5927"\w* summon \w the|strong="H5414"\w* \w leaders|strong="H5461"\w* \w and|strong="H5971"\w* \w officials|strong="H5461"\w* \w and|strong="H5971"\w* \add other\add* \w people|strong="H5971"\w*, \w and|strong="H5971"\w* \w to|strong="H5927"\w* look \w in|strong="H3789"\w* \w the|strong="H5414"\w* \w books|strong="H5612"\w* \add in which were written the names\add* \w of|strong="H5971"\w* \w all|strong="H6908"\w* \w the|strong="H5414"\w* \w people|strong="H5971"\w* \w and|strong="H5971"\w* \w their|strong="H5414"\w* clans. \w So|strong="H5414"\w* \w I|strong="H5414"\w* \w found|strong="H4672"\w* \w the|strong="H5414"\w* \w records|strong="H5612"\w* \w of|strong="H5971"\w* \w the|strong="H5414"\w* \w people|strong="H5971"\w* \w who|strong="H5971"\w* \w had|strong="H5414"\w* \w first|strong="H7223"\w* \w returned|strong="H5927"\w* \w from|strong="H5927"\w* Babylonia. \w This|strong="H5414"\w* \w is|strong="H3820"\w* \w what|strong="H5927"\w* \w I|strong="H5414"\w* \w found|strong="H4672"\w* \w written|strong="H3789"\w* \w in|strong="H3789"\w* those \w records|strong="H5612"\w*:   
\pi1
\v 6 ◄\w This|strong="H7725"\w* \w is|strong="H5892"\w* \w a|strong="H3068"\w* list/Here \w are|strong="H1121"\w* \w the|strong="H7725"\w* names► \w of|strong="H1121"\w* \w the|strong="H7725"\w* \w people|strong="H1121"\w* \w who|strong="H1121"\w* \w returned|strong="H7725"\w* \w to|strong="H7725"\w* \w Jerusalem|strong="H3389"\w* \w and|strong="H1121"\w* \w to|strong="H7725"\w* other places \w in|strong="H4428"\w* Judea. \w They|strong="H3389"\w* \w had|strong="H4428"\w* \w been|strong="H5927"\w* living \w in|strong="H4428"\w* Babylonia \w since|strong="H5927"\w* \w King|strong="H4428"\w* \w Nebuchadnezzar|strong="H5019"\w*’s \w army|strong="H5927"\w* \w had|strong="H4428"\w* \w captured|strong="H7628"\w* \w their|strong="H7725"\w* \w relatives|strong="H1121"\w*/ancestors \w and|strong="H1121"\w* \w took|strong="H5927"\w* \w them|strong="H7725"\w* \w to|strong="H7725"\w* Babylonia. \w But|strong="H4428"\w* \w they|strong="H3389"\w* \w had|strong="H4428"\w* \w returned|strong="H7725"\w* \w to|strong="H7725"\w* Judea \w and|strong="H1121"\w* \w were|strong="H1121"\w* living \w in|strong="H4428"\w* \w the|strong="H7725"\w* \w towns|strong="H5892"\w* \add where their ancestors had lived\add*.  
\v 7 \w Their|strong="H5973"\w* leaders \w were|strong="H3478"\w* \w Zerubbabel|strong="H2216"\w*, Joshua, \w Azariah|strong="H5838"\w*, \w Raamiah|strong="H7485"\w*, \w Nahamani|strong="H5167"\w*, \w Mordecai|strong="H4782"\w*, \w Bilshan|strong="H1114"\w*, \w Mispereth|strong="H4559"\w*, Bigvai, \w Nehum|strong="H5149"\w*, \w Baanah|strong="H1196"\w*, \w and|strong="H3478"\w* \w me|strong="H5973"\w*.  
\b  
\pi1 \w This|strong="H3478"\w* \w is|strong="H3478"\w* \w a|strong="H3068"\w* \w list|strong="H4557"\w* \w of|strong="H4557"\w* \w the|strong="H5973"\w* \w number|strong="H4557"\w* \w of|strong="H4557"\w* \w men|strong="H5971"\w* \w in|strong="H3478"\w* \w each|strong="H5971"\w* clan \w who|strong="H5971"\w* returned:   
\li2
\v 8 2,172 men from the clan of Parosh;   
\li2
\v 9 372 men from the clan of Shephatiah;   
\li2
\v 10 652 men from the clan of Arah;   
\li2
\v 11 2,818 men from the clan of Pahath-Moab, who are descendants of Jeshua and Joab;   
