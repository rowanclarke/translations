\s1 The Intercession of Moses  
\p
\v 11  \w So|strong="H5921"\w* Aaron said \w to|strong="H5921"\w* \w Moses|strong="H4872"\w*, “\w O|strong="H3068"\w* \w my|strong="H5921"\w* lord, \w please|strong="H4994"\w* \w do|strong="H4994"\w* not \w hold|strong="H7896"\w* \w this|strong="H4994"\w* \w sin|strong="H2403"\w* \w against|strong="H5921"\w* \w us|strong="H4994"\w*, \w in|strong="H5921"\w* \w which|strong="H2403"\w* \w we|strong="H3068"\w* \w have|strong="H2403"\w* \w acted|strong="H2973"\w* \w foolishly|strong="H2973"\w* \w and|strong="H4872"\w* \w have|strong="H2403"\w* \w sinned|strong="H2398"\w*!  
\v 12  \w Do|strong="H3318"\w* \w not|strong="H1961"\w* \w let|strong="H4994"\w* \w her|strong="H3318"\w* \w be|strong="H1961"\w* \w like|strong="H1961"\w* \w a|strong="H3068"\w* baby \w born|strong="H3318"\w* \w dead|strong="H4191"\w*, whose \w flesh|strong="H1320"\w* \w is|strong="H1320"\w* half-consumed \w when|strong="H1961"\w* \w it|strong="H1961"\w* \w comes|strong="H3318"\w* \w out|strong="H3318"\w* \w of|strong="H3318"\w* \w its|strong="H1961"\w* \w mother|strong="H7358"\w*’s \w womb|strong="H7358"\w*!”   
\p
\v 13  \w Then|strong="H4872"\w* \w Moses|strong="H4872"\w* \w cried|strong="H6817"\w* \w to|strong="H3068"\w* \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd*, “\w Heal|strong="H7495"\w* her \w now|strong="H4994"\w*, \w O|strong="H3068"\w* \w God|strong="H3068"\w*.”  
\v 14  \w The|strong="H6440"\w* \nd \+w Lord|strong="H3068"\+w*\nd* said \w to|strong="H3068"\w* \w Moses|strong="H4872"\w*, “If \w her|strong="H5462"\w* father \w had|strong="H3068"\w* only \w spit|strong="H3417"\w* \w in|strong="H3068"\w* \w her|strong="H5462"\w* \w face|strong="H6440"\w*, \w would|strong="H3068"\w* \w she|strong="H6440"\w* \w not|strong="H3808"\w* \w have|strong="H3068"\w* \w been|strong="H3068"\w* \w disgraced|strong="H3637"\w* \w for|strong="H6440"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w*? \w Shut|strong="H5462"\w* \w her|strong="H5462"\w* \w out|strong="H2351"\w* \w from|strong="H6440"\w* \w the|strong="H6440"\w* \w camp|strong="H4264"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w*, \w and|strong="H4872"\w* afterward \w she|strong="H6440"\w* \w can|strong="H3808"\w* \w be|strong="H3808"\w* \w brought|strong="H4872"\w* back \w in|strong="H3068"\w* \w again|strong="H6440"\w*.”   
\p
\v 15  \w So|strong="H3808"\w* \w Miriam|strong="H4813"\w* \w was|strong="H3117"\w* \w shut|strong="H5462"\w* \w outside|strong="H2351"\w* \w of|strong="H3117"\w* \w the|strong="H3117"\w* \w camp|strong="H4264"\w* \w for|strong="H5704"\w* \w seven|strong="H7651"\w* \w days|strong="H3117"\w*, \w and|strong="H3117"\w* \w the|strong="H3117"\w* \w people|strong="H5971"\w* \w did|strong="H5971"\w* \w not|strong="H3808"\w* \w journey|strong="H5265"\w* \w on|strong="H3117"\w* \w until|strong="H5704"\w* \w Miriam|strong="H4813"\w* \w was|strong="H3117"\w* \w brought|strong="H5265"\w* back \w in|strong="H3117"\w*.  
\v 16  After \w that|strong="H5971"\w* \w the|strong="H5971"\w* \w people|strong="H5971"\w* \w moved|strong="H5265"\w* \w from|strong="H5265"\w* \w Hazeroth|strong="H2698"\w* \w and|strong="H5971"\w* \w camped|strong="H2583"\w* \w in|strong="H2583"\w* \w the|strong="H5971"\w* \w wilderness|strong="H4057"\w* \w of|strong="H4057"\w* \w Paran|strong="H6290"\w*.   
