\id OBA - Biblica® Open Yoruba Contemporary Bible 2017 
\h Obadiah 
\toc1 Ìwé Wòlíì Obadiah 
\toc2 Obadiah 
\toc3 Od 
\mt1 Ìwé Wòlíì Obadiah 
\c 1  
\p  
\v 1 Ìran ti Obadiah. 
\b  
\b  
\p       Èyí ni \nd Olúwa\nd* Olódùmarè wí nípa Edomu. 
\q1 Àwa ti gbọ́ ohùn kan láti ọ̀dọ̀ \nd Olúwa\nd* wá, 
\q2 a sì ti rán ikọ̀ kan sí gbogbo kèfèrí láti sọ pé, 
\q1 “Ẹ dìde, ẹ jẹ́ kí a dìde ogun sí i.” 
\b  
\q1  
\v 2 “Kíyèsi i, Èmi yóò sọ ọ́ di kékeré láàrín àwọn kèfèrí; 
\q2 ìwọ yóò sì di gígàn lọ́pọ̀lọ́pọ̀. 
\q1  
\v 3 Ìgbéraga àyà rẹ ti tàn ọ́ jẹ, 
\q2 ìwọ tí ń gbé inú pálapàla àpáta, 
\q2 tí o sì kọ́ ibùgbé rẹ sí ibi gíga, 
\q1 ìwọ wí nínú ọkàn rẹ pé, 
\q2 ‘Ta ni yóò mú mi sọ̀kalẹ̀?’ 
\q1  
\v 4 Bí ìwọ tilẹ̀ gbé ara rẹ ga bí ẹyẹ idì, 
\q2 bí ìwọ tilẹ̀ tẹ́ ìtẹ́ rẹ sí àárín àwọn ìràwọ̀, 
\q2 láti ibẹ̀ ni èmi yóò ti sọ̀ ọ kalẹ̀,” 
\q2 ni \nd Olúwa\nd* wí. 
\q1  
\v 5 “Bí àwọn olè tọ̀ ọ́ wá, 
\q2 bí àwọn ọlọ́ṣà ní òru, 
\q1 Háà! Irú ìparun wo ló dúró dè ọ́, 
\q2 wọn kò ha jalè tó bí wọ́n ti fẹ́? 
\q1 Bí àwọn tí ń ká èso àjàrà tọ̀ ọ́ wá, 
\q2 wọn kò ha ni fi èso àjàrà díẹ̀ sílẹ̀? 
\q1  
\v 6 Báwo ni a ṣe ṣe àwárí nǹkan Esau, 
\q2 tí a sì wá ohun ìní ìkọ̀kọ̀ rẹ̀ jáde. 
\q1  
\v 7 Gbogbo àwọn ẹni ìmùlẹ̀ rẹ 
\q2 ti mú ọ dé ìpẹ̀kun ilẹ̀ rẹ, 
\q1 àwọn ọ̀rẹ́ rẹ ti tàn ọ́ jẹ, wọ́n sì ti borí rẹ; 
\q2 àwọn tó jẹ oúnjẹ rẹ dẹ pàkúté dè ọ́, 
\q2 ṣùgbọ́n ìwọ kò ní ní òye rẹ̀.” 
\b  
\q1  
\v 8 \nd Olúwa\nd* wí pé, “Ní ọjọ́ náà, 
\q2 Èmi kì yóò ha pa àwọn ọlọ́gbọ́n Edomu run, 
\q2 àti àwọn amòye run kúrò ní òkè Esau? 
\q1  
\v 9 A ó ṣe ẹ̀rù ba àwọn jagunjagun rẹ, ìwọ Temani, 
\q2 gbogbo àwọn tó wà ní orí òkè Esau 
\q2 ní a ó gé kúrò nínú ìpànìyàn náà. 
\q1  
\v 10 Nítorí ìwà ipá sí Jakọbu arákùnrin rẹ, 
\q2 ìtìjú yóò bò ọ, 
\q2 a ó sì pa ọ run títí láé. 
\q1  
\v 11 Ní ọjọ́ tí ìwọ dúró ní apá kan, 
\q2 ní ọjọ́ tí àlejò kó ogún rẹ lọ, 
\q1 tí àwọn àjèjì sì wọ ibodè rẹ, 
\q2 tí wọ́n sì sẹ́ kèké lórí Jerusalẹmu, 
\q2 ìwọ náà wà bí ọ̀kan nínú wọn. 
\q1  
\v 12 Ìwọ kì bá tí fi ojú kéré arákùnrin rẹ, 
\q2 ní àkókò ìbànújẹ́ rẹ̀ 
\q1 ìwọ kì bá tí yọ̀ lórí àwọn ọmọ Juda, 
\q2 ní ọjọ́ ìparun wọn 
\q1 ìwọ kì bá tí gbéraga púpọ̀ 
\q2 ní ọjọ́ wàhálà wọn. 
\q1  
\v 13 Ìwọ kì bá tí wọ inú ibodè àwọn ènìyàn mi lọ, 
\q2 ní ọjọ́ àjálù wọn. 
\q1 Ìwọ kì bá tí fojú kó wọn mọ́lẹ̀ 
\q2 nínú ìdààmú wọn, ní ọjọ́ àjálù wọn. 
\q1 Ìwọ kì bá tí jí ẹrù wọn kó, 
\q2 ní ọjọ́ ìpọ́njú wọn. 
\q1  
\v 14 Ìwọ kì bá tí dúró ní ìkóríta ọ̀nà 
\q2 láti ké àwọn tirẹ̀ tó ti sálà kúrò. 
\q1 Ìwọ kì bá tí fa àwọn tó ṣẹ́kù nínú 
\q2 wọn lélẹ̀ ní ọjọ́ wàhálà wọn. 
\b  
\q1  
\v 15 “Nítorí ọjọ́ \nd Olúwa\nd* súnmọ́ etílé 
\q2 lórí gbogbo àwọn kèfèrí. 
\q1 Bí ìwọ ti ṣe, bẹ́ẹ̀ ni a ó ṣe sí ìwọ náà; 
\q2 ẹ̀san rẹ yóò sì yípadà sí orí ara rẹ. 
\q1  
\v 16 Gẹ́gẹ́ bí ìwọ̀ ṣe mu lórí òkè mímọ́ mi, 
\q2 bẹ́ẹ̀ ni gbogbo kèfèrí yóò máa mu títí; 
\q1 wọn yóò mu ún ní àmutẹ́rùn 
\q2 wọn yóò sì wà bí ẹni pé wọn kò mu ún rí. 
\q1  
\v 17 Ṣùgbọ́n ìgbàlà yóò wà lórí òkè Sioni, 
\q2 wọn yóò sì jẹ́ mímọ́, 
\q1 àti ilé Jakọbu yóò sì ní ìní wọn. 
\q1  
\v 18 Ilé Jakọbu yóò sì jẹ́ iná 
\q2 àti ilé Josẹfu ọwọ́ iná 
\q1 ilé Esau yóò jẹ àgékù koríko 
\q2 wọn yóò fi iná sí i, 
\q1 wọn yóò jo run. 
\q2 Kì yóò sí ẹni tí yóò kù ní ilé Esau.” 
\q1 Nítorí \nd Olúwa\nd* ti sọ̀rọ̀. 
\b  
\q1  
\v 19 Àwọn ará gúúsù yóò ni òkè Esau, 
\q2 àwọn ará ẹsẹ̀ òkè yóò ni 
\q1 ilẹ̀ àwọn ará Filistini ní ìní. 
\q2 Wọn yóò sì ni oko Efraimu àti Samaria; 
\q2 Benjamini yóò ní Gileadi ní ìní. 
\q1  
\v 20 Àwọn ìgbèkùn Israẹli tí ó wà ní Kenaani 
\q2 yóò ni ilẹ̀ títí dé Sarefati; 
\q1 àwọn ìgbèkùn láti Jerusalẹmu tí ó wà ní Sefaredi 
\q2 yóò ni àwọn ìlú gúúsù ní ìní. 
\q1  
\v 21 Àwọn tó ń gba ni là yóò sì gòkè Sioni wá 
\q2 láti jẹ ọba lé orí àwọn òkè Esau. 
\q2 Ìjọba náà yóò sì jẹ́ ti \nd Olúwa\nd*.