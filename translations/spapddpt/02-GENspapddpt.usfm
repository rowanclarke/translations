\c 18  
\s1 La Teofanía  
\p
\v 1 \w Después|strong="H3427"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w se|strong="H1931"\w* \w le|strong="H1931"\w* \w apareció|strong="H7200"\w* \add a Abraham\add* en \w el|strong="H1931"\w* robledal de \w Mamre|strong="H4471"\w* \w cuando|strong="H3117"\w* \w él|strong="H1931"\w* \w estaba|strong="H3427"\w* \w sentado|strong="H3427"\w* en \w la|strong="H1931"\w* \w puerta|strong="H6607"\w* de \w la|strong="H1931"\w* tienda en \w el|strong="H1931"\w* intenso calor del \w día|strong="H3117"\w*.  
\v 2 Cuando \w levantó|strong="H5375"\w* sus \w ojos|strong="H5869"\w* \w miró|strong="H7200"\w*, \w y|strong="H5921"\w* ahí \w estaban|strong="H5324"\w* \w tres|strong="H7969"\w* varones \w en|strong="H5921"\w* pie \w frente|strong="H7125"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*. Tan pronto \w como|strong="H5921"\w* \w los|strong="H5921"\w* \w vio|strong="H7200"\w*, \w corrió|strong="H7323"\w* \w a|strong="H3068"\w* su encuentro \w desde|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w de|strong="H5921"\w* su tienda \w y|strong="H5921"\w* \w se|strong="H5921"\w* postró \w en|strong="H5921"\w* tierra.   
\p
\v 3 \w Y|strong="H3068"\w* exclamó: \nd ʼAdón\nd* \w mío|strong="H5921"\w*, \w si|strong="H4994"\w* \w hallo|strong="H4672"\w* \w gracia|strong="H2580"\w* ante tus \w ojos|strong="H5869"\w*, \w te|strong="H5869"\w* \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* \w no|strong="H5921"\w* \w pases|strong="H5674"\w* \w de|strong="H5921"\w* largo \w junto|strong="H5921"\w* \w a|strong="H3068"\w* tu esclavo.  
\v 4 \w Que|strong="H4994"\w* se \w traiga|strong="H3947"\w* \w ya|strong="H4994"\w* un \w poco|strong="H4592"\w* \w de|strong="H8478"\w* \w agua|strong="H4325"\w*, laven sus \w pies|strong="H7272"\w* y se recuesten \w debajo|strong="H8478"\w* del \w árbol|strong="H6086"\w*  
\v 5 \w mientras|strong="H3588"\w* \w tomo|strong="H3947"\w* un trozo \w de|strong="H5921"\w* \w pan|strong="H3899"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* sustenten sus corazones. \w Luego|strong="H3651"\w* seguirán adelante, \w pues|strong="H3588"\w* \w por|strong="H5921"\w* \w eso|strong="H3651"\w* \w pasaron|strong="H5674"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* esclavo.  
\p Contestaron: \wj \+w Haz|strong="H6213"\+w* \+w como|strong="H3588"\+w* \+w dijiste|strong="H1696"\+w*.\wj*   
\p
\v 6 Abraham se apresuró \w a|strong="H3068"\w* entrar en la tienda de \w Sara|strong="H8283"\w* y le dijo: ¡Toma \w pronto|strong="H4116"\w* \w tres|strong="H7969"\w* \w medidas|strong="H5429"\w* de flor de \w harina|strong="H7058"\w*, amásalas y \w haz|strong="H6213"\w* \w panes|strong="H5692"\w*!   
\p
\v 7 En seguida, Abraham \w corrió|strong="H7323"\w* \w hacia|strong="H6213"\w* \w el|strong="H1121"\w* \w ganado|strong="H1121"\w*, \w tomó|strong="H3947"\w* un becerro \w tierno|strong="H7390"\w* \w y|strong="H1241"\w* \w bueno|strong="H2896"\w* \w y|strong="H1241"\w* se \w lo|strong="H6213"\w* \w dio|strong="H5414"\w* al esclavo. Éste se apresuró \w a|strong="H3068"\w* aderezarlo.  
\v 8 Juntamente \w con|strong="H5921"\w* \w el|strong="H1931"\w* becerro \w que|strong="H1931"\w* \w aderezó|strong="H6213"\w*, \add Abraham\add* \w tomó|strong="H3947"\w* también cuajada \w y|strong="H5921"\w* \w leche|strong="H2461"\w*, \w y|strong="H5921"\w* \w lo|strong="H1931"\w* \w presentó|strong="H5414"\w* \w ante|strong="H6440"\w* \w ellos|strong="H1931"\w*. Mientras \w él|strong="H1931"\w* \w se|strong="H1931"\w* mantenía \w en|strong="H5921"\w* \w pie|strong="H5975"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w ellos|strong="H1931"\w* \w debajo|strong="H8478"\w* \w del|strong="H5921"\w* \w árbol|strong="H6086"\w*, \w ellos|strong="H1931"\w* comían.   
\p
\v 9 Después le dijeron: \wj ¿Dónde está tu esposa \+w Sara|strong="H8283"\+w*?\wj*  
\p \w Y|strong="H3068"\w* él contestó: Ahí está en la tienda.   
\p
\v 10 \w Y|strong="H3068"\w* dijo: \wj \+w Volveré|strong="H7725"\+w* \+w a|strong="H3068"\+w* ti sin falta según \+w el|strong="H1931"\+w* \+w tiempo|strong="H6256"\+w* \+w de|strong="H1121"\+w* \+w la|strong="H1931"\+w* \+w vida|strong="H2416"\+w*, y tu esposa \+w Sara|strong="H8283"\+w* tendrá un \+w hijo|strong="H1121"\+w*.\wj*  
\p \w Y|strong="H3068"\w* \w Sara|strong="H8283"\w* \w escuchaba|strong="H8085"\w* en \w la|strong="H1931"\w* entrada \w de|strong="H1121"\w* \w la|strong="H1931"\w* tienda, \w pues|strong="H1931"\w* \w estaba|strong="H2009"\w* detrás \w de|strong="H1121"\w* \w él|strong="H1931"\w*.  
\v 11 Abraham y \w Sara|strong="H8283"\w* \w eran|strong="H1961"\w* \w ancianos|strong="H2205"\w*, entrados en \w días|strong="H3117"\w*, y \w a|strong="H3068"\w* \w Sara|strong="H8283"\w* le \w había|strong="H1961"\w* cesado la costumbre de las mujeres.  
\v 12 \w Sara|strong="H8283"\w* \w se|strong="H1961"\w* rió \w dentro|strong="H7130"\w* de ella y \w se|strong="H1961"\w* dijo: ¿\w Después|strong="H1961"\w* \w que|strong="H1961"\w* envejecí \w tendré|strong="H1961"\w* \w deleite|strong="H5730"\w*, \w cuando|strong="H1961"\w* también \w mi|strong="H1961"\w* \tl ʼadonay \tl* \w es|strong="H1961"\w* anciano?   
\p
\v 13 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* Abraham: \wj ¿\+w Por|strong="H2088"\+w* \+w qué|strong="H4100"\+w* \+w Sara|strong="H8283"\+w* \+w se|strong="H4100"\+w* rió \+w así|strong="H2088"\+w*? \+w Y|strong="H3068"\+w* dijo: ¿Será cierto \+w que|strong="H4100"\+w* daré \+w a|strong="H3068"\+w* luz ahora \+w cuando|strong="H4100"\+w* soy anciana?\wj*   
\p
\v 14 \wj ¿Hay \+w algo|strong="H1697"\+w* imposible para \+nd \+w Yavé|strong="H3068"\+w*\+nd*? \+w Volveré|strong="H7725"\+w* \+w a|strong="H3068"\+w* ti según \+w el|strong="H1121"\+w* \+w tiempo|strong="H6256"\+w* \+w de|strong="H1121"\+w* la \+w vida|strong="H2416"\+w*, y \+w Sara|strong="H8283"\+w* tendrá un \+w hijo|strong="H1121"\+w*.\wj*   
\p
\v 15 \w Pero|strong="H3588"\w* \w Sara|strong="H8283"\w* \w negó|strong="H3584"\w* \w y|strong="H3588"\w* dijo: \w No|strong="H3808"\w* \w me|strong="H3588"\w* reí, \w pues|strong="H3588"\w* \w tuvo|strong="H3372"\w* \w miedo|strong="H3372"\w*.  
\p \w Pero|strong="H3588"\w* \w Él|strong="H3588"\w* dijo: \wj \+w No|strong="H3808"\+w*, realmente \+w te|strong="H3588"\+w* reíste.\wj*   
\p
