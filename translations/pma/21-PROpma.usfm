\id PRO - PMA Paama Language
\h Proveb
\toc1 Proveb
\toc2 Pro
\mt1 Proveb
\c 3
\s1 Selkatien min meatin hau keil
\r Proveb 3:1-12,27-35
\q1 
\v 1 Natkuli, em navobongentei asa koa naviseinuk eni.
\q2 Lisenges, kindem kat mengkatien keil onak ka kusil kati.
\q1 
\v 2 Hihiseien onak houmon moulien onom hetaveah
\q2 ka kiles tahosien.
\q1 
\v 3 En moulien onom, avaseini asa hemai,
\q2 kitie lat sakien ten more envatien onom en meatin sav keil
\q2 ka lises kumoni hetahos min keil.
\q1 Konalokoveintei sise keilu ekek,
\q2 hetahos keke kitis kati hel en tinom.
\q1 
\v 4 Munak kumon koanek, Ahi ka meatin sav keil
\q2 isi keil venuk ka isom hetahos.\x + \xo 3:4 \xt Luk 2:52\x*
\b
\q1 
\v 5 Hetal min moulien vasi onom, kiling desien onom en Iahova.
\q2 Konandesintei ileilien onom enges.
\q1 
\v 6 Kindem kat Iahova en tounah vasi koa komumoni,
\q2 ka kei hetie sise koa mal minuk.
\q1 
\v 7 Konandem sasom enuktei konahit ileilien onom mulin ileilien onen meatin sav keil.\x + \xo 3:7 \xt Rom 12:16\x*
\q2 Kihouhou min Iahova ka konahatei vesesal en tisaen.
\q1 
\v 8 Munak kumon koanek, hesak revi avem
\q2 ka en tinom, kilonge hetahos.
\b
\q1 
\v 9 Kihouhou min Iahova hetal min tounah vasi onom,
\q2 ka kisan tei anien hau koa moul en ah osom heha mini.
\q1 
\v 10 Munak kumon koanek, kiles tahosien koa hemariso en moulien onom,
\q2 vah onom hehilelau en anien lises ka kirtamureitei en etai tounah.
\b
\q1 
\v 11 Natkuli, navong Iahova ralimal enuk ven tounah,
\q2 kisik enges veni ka kindem kati. \x + \xo 3:11 \xt Siob 5:17\x*
\q1 
\v 12 Kumon koanek veni Iahova ralimal en koakeil envatien onen mul en keil.
\q2 Kei mumoni suval tata tai koa ralimal en natnali koa si veni.\x + \xo 3:12 \xt Rev 3:19\x*
\b
\q1 
\v 27 Hetahos minuk keke konahuli kattei ui umen onen koakeil amum
\q2 navong mul en hem keke kovasani min keil.
\q1 
\v 28 Munak meatin tai visuk en tounah tai koa kovuli kati mul, tahos keke kisan vareini mini.
\q2 Konahitentei konahit, “Vuo, visuvong esuk nisani minuk.”
\b
\q1 
\v 29 Konoumontei sise vapurun meatin tai koa ro vesesal venuk
\q2 veni ro ral minuk ka ling desien onen mul enuk.
\q1 
\v 30 Konasel kutut kattei meatin sav
\q2 koa romumon etai tounah vapurunuk.
\b
\q1 
\v 31 Konahati lattei meatin tatituen,
\q2 ka konousiltei sakien keil onen,
\q1 
\v 32 veni Iahova vuroh kat vati meatin koa mukonek,
\q2 ka koakeil moulien one mal, kei lah keil umai vesesal veni.
\b
\q1 
\v 33 Iahova hesan sesendaen heha kat teim sen meatin keil koa amum tisa.
\q2 Ka hesan tokolkatien heha en teim sen meatin keil koa amum mal.
\q1 
\v 34 Kei mundem heisav en vati meatin keil koa avut keil ka amundem heisav en meatin sav keil.
\q2 Ka mul lele tahos min koakeil amumon rendemien one va netan.\x + \xo 3:34 \xt Tiem 4:6; 1Pit 5:5\x*
\q1 
\v 35 Meatin keil koa avi meteisau, ise hetahos.
\q2 Ka koakeil avi varu, keil apurun ise.
\c 5
\s1 Selkatien va kat sakien ten hoeasoen
\r Proveb 5:15-20
\q1 
\v 15 Keik koa koretalihe, kitie lat envatien onom min ahin onom
\q2 ka kito hetal min kei enges.
\q1 
\v 16 ?Mukave? ?Tahos keke kiha kiles ahin sav keil?
\q2 ?Mal keke kiha kisan asa koa vi onen ahin kati onom min teisav keil? !Vuo!
\q1 
\v 17 Tahosien ten tetaliheien onamil enges.
\q2 Rovitei tounah koa kokilea kovasan heisav eni min mesav keil.
\q1 
\v 18 Hetahos imok kisik ven ahin koa koretalihe ral mini mai vi asom navong kovi meatin hau veah,
\q2 ka kitos en sien hetal mini lisenges.
\q1 
\v 19 Kimaen kei sasen hesakinuk kilonge hetahos lises.
\q2 Kihi vau en aven ahin onom enges ka kisik ven envatien onen.
\q1 
\v 20 ?Natkuli, vensa kitie lat envatien onom en ahin koa vi hoeaso tai?
\q2 ?Vensa kiles aven ka kindemi keke kei tahos imok mulin ahin kati onom? !Konomontei vamukonek!
\c 8
\s1 Ahi mumon tounah keil vasi ral min meteisauen
\r Proveb 8:22-31
\q1 
\v 22 En avong mulamu, Ahi mumonau, isok vi Meteisauen.
\q2 Kei mumonau mulamu en tounah savsav keil vasi koa mumoni.\x + \xo 8:22 \xt Rev 3:14\x*
\q1 
\v 23 En avong koa mum rohtoh en tounah keil, inau namulamu en keil.
\q2 Navong out netan tovuol veah, inau namul tuai.
\q1 
\v 24 Navong atas ka oaisal keil atovuol veah,
\q2 inau naros.
\q1 
\v 25 Ahi mumonau mulamu en vatihou keil
\q2 ka mulamu en avong kei ling kat hou keil en out kati one.
\q1 
\v 26 Mulamu en avong koa Ahi mumon out netan ka tounah keil koa amoul ien,
\q2 navong atan tovuol veah, namul tuai.
\q1 
\v 27 Inau namul en usiven Ahi navong kei ling teilang en out kati onen,
\q2 ka navong ling hakot teni mai rokol atas.
\q1 
\v 28 Inau nalesi navong kei ling mahmah en teilang,
\q2 ka sakin oaisal keil amue uva en atas.
\q1 
\v 29 Nalonge navong Ahi viten out koa atas hevus eni,
\q2 ka navong ling hakot ten atan.
\q1 
\v 30 Inau namum vesesal ven Ahi suval avat toumien onen.
\q2 Lises, kei si venau, ka inau, nasi nau mun mato vatal mini.
\q1 
\v 31 Nalonge tahos ven out netan koa kei mumoni,
\q2 ka nasi nau ven meatin keil koa aro ien.
\c 9
\s1 Selusien ten meteisauen
\r Proveb 9:7-10; 13:1,4; 14:23-24; 15:1-2,18,22; 18:22; 19:1; 20:1,4; 22:6; 23:13-14
\q1 
\v 7 Munak kovit kovatalimal en vatkeih tai, kei heselus karenuk,
\q2 ka munak kosel kat meatin tisa tai, kei hepurunuk.
\q1 
\v 8 Sakini, konasak vistei kovatalimal en meatin koa vuti, veni kei hevuroh katuk veni.
\q2 Ka munak kitalimal en meatin koa vi meteisau, envatien onen hel enuk.
\q1 
\v 9 Munak kosel kat meatin koa vi meteisau, kei hehi meteisau revi mok.
\q2 Ka munak kosan hihiseien min meatin koa mal, ileilien onen hemariso tamun.
\q1 
\v 10 Houhouen min Iahova vi vatte ten meteisauen.\x + \xo 9:10 \xt Siob 28:28; Sam 111:10; Pro 1:7\x*
\q2 Munak kokilea kei koa vi votut, kokilea en tounah tai koa vi hetetamen imok.
\b
\c 13
\q1 
\v 1 Titiali keil koa avi meteisau amul along kat tata ka mama one keil navong asel kat keil.
\q2 Ka vatkeih keil, asakras avalong kat.
\b
\q1 
\v 4 Avaseini taripeng tai en vati mok vakur etai tounah, kei sakras vakuri.
\q2 Ka meatin koa mum keih, kei helah vasi tounah koa en vati.
\b
\c 14
\q1 
\v 23 Munak kum, kihotin ui umen onom.
\q2 Ka munak koselus enges ka kormumtei, kirkur etai tounah.
\q1 
\v 24 Tahosien vi ui umen onen meatin koa vi meteisau,
\q2 ka varuen vi ui umen onen meatin koa vi varu.
\b
\c 15
\q1 
\v 1 Navong kosa kes selusien en sakien ten merauen, koanek hesakin vurohien heha netan.
\q2 Ka selusien takeih hesakin tin meatin sav heatiat.
\q1 
\v 2 Navong meatin koa vi meteisau selus, meatin sav keil asi keil avakur ileilien rani,
\q2 ka varu keil ason kalah en selusien koa vi varu enges.
\b
\q1 
\v 18 Meatin koa tin tamurei mumon selkututien houlu,
\q2 ka kei koa merau mumon tin meatin va netan.
\b
\q1 
\v 22 Lingkatien keil onom hemai hetisa munak kirvistei meteisauen ran meatin sav keil,
\q2 ka munak kihis meteisauen, keik kiles heite teni koa hetahos.
\b
\c 18
\q1 
\v 22 Munak kovotin ahin tai vahi asom, kovotin tounah tai koa tahos,
\q2 ka kiles tahosien onen Iahova hel en moulien onom.
\b
\c 19
\q1 
\v 1 Tahos imok munak sakien keil onom mal ka tounah onom rovitei houlu
\q2 mulin koa kovi varu tai koa komul koluvos.
\b
\c 20
\q1 
\v 1 Sakien ten munmunien mumon tituen ka verien,
\q2 ka koakeil enges avi varu amaen oai takeih valeh keil avaha en sise keil tatisa.
\b
\q1 
\v 4 Taripeng tai koa en rovattei voum en ah osen en avong kati taluhluhien,
\q2 kei hervotin etai anien en avong tasuhutien.
\b
\c 22
\q1 
\v 6 Navong kovisein titiali keil onom en sise koa mal keke avousili,
\q2 keil indem kati en moulien one ka irlokoveintei sise koanek navong imai imatu.
\b
\c 23
\q1 
\v 13 Konametautei kovatalimal en titam keil.
\q2 ?Komundemi keke imat munak komulelas keil? Vuo, romukteinek.
\q1 
\v 14 Ka munak komulelas keil,
\q2 komutut keil keke irvatei en Ahang.
\s1 Selkatien usil sakien tatisa ten munmunien
\r Proveb 23:29-35
\q1 
\v 29 ?Isei vit, ‘Aue li’? ?Isei longe tisa?
\q2 ?Isei mul mutit? ?Isei mul musel?
\q1 ?Isei aven mutetep ka reingeingen asa koa kula?
\q2 ?Isei meten vilhili tisa?
\q1 
\v 30 Koakeil amunmun houlu amukonek.
\q2 Anatin, koakeil enges amun oai takeih alonge mukonek.
\q1 
\v 31 Konamaentei uaen koa vilhili tahos valeh lat rendemien onom,
\q2 avaseini kolesi tahos imok en veite teni ka sakin ongom kas eni.
\q1 
\v 32 Ka en keite teni kilong mahien eni
\q2 hesuval navong ahai ten atas sin rilik ka kolong mahien teni.
\q1 
\v 33 Metom heles tounah keil vilehiles hemai heteisav,
\q2 ka rendemien onom hermum revitei.
\q1 
\v 34 Kilonge kihit kovatetavel suval komul en sip tai,
\q2 kilonge hesuval koa komurur en mas teni ka kuvinuk kova en usite evus kova en usite sav.
\q1 
\v 35 Evus, kihiteni kihit, “Amutinau ka narlongtei. Amuas nau ka narkileatei.
\q2 ?Vensa nasakras mamea? Tahos imok munak mamun etai mun oai takeih.”
\c 24
\s1 Meteisauen usil sakien onen taripeng keil
\r Proveb 24:30-34
\q1 
\v 30 Inau, namual en sise vesesal en ah osen taripeng tai,
\q2 ka naka vasi neiai osen varu tai.
\q1 
\v 31 Nalesi keke oumunai tatisa keil amusar koe ka viau tatisa keil apar vini.
\q2 Nalesi keke vieh teni mahoiahoi mules mukonek.
\q1 
\v 32 Munak nalesi mukonek, namundem usili,
\q2 ka koanek viseinau en tounah tai.
\q1 
\v 33 Munak em vati kovamatil lisenges, tahosis, kiles kimatil.
\q2 Kiha kihotin more out koa mandil ka kiseh revi ien.
\q1 
\v 34 Ka navong komul komatil veah, tounah vasi keil onom hevupuol ranuk hesuval tarhena tai mai venani ranuk.
\q2 Anatin, kitimanin kimai kihi heite hon.
\c 29
\s1 Selusien sav ten meteisauen
\r Proveb 29:15,17
\q1 
\v 15 Navong komulelas titiali tai onom keke kovatalimal eni, komul kosan meteisauen mini,
\q2 ka munak kolei maenis mumon vatin, titiali enek houmon mama onen hememou.
\b
\q1 
\v 17 Munak koralimal en titiali onom, lises houmonuk kiles tomat ka kirmundemkotei.
\q2 Kei hesakinuk kivutuk veni.
\c 31
\s1 Sakien tetahos onen ahin keil
\r Proveb 31:10-13,17,20,26-31
\q1 
\v 10 Keih ramat keke kovahotin ahin tai koa marir en umen onen ka sakien keil onen tahos.
\q2 Kei tahos imok mulin tounah koa kokilea kovakuri ral mani onom.
\q1 
\v 11 Meatin onen kilea valing desien onen eni.
\q2 Ven umen onen ahin onen, kei hertamureitei en etai tounah.
\q1 
\v 12 Navong luro vituai en teim onealu,
\q2 ahin onen mum tahos mini ka ropuruntei.
\q1 
\v 13 Hen vasi keilu lurmusehtei,
\q2 kei vei suvon keil ka rili revi eisin keil.
\b
\q1 
\v 17 Kei vi ahin toumien tai,
\q2 ka hen keilu lumum keih lises.
\b
\q1 
\v 20 Kei mul kataun koakeil tounah one tovuol,
\q2 ka san tounah min koakeil atetamurei en tounah.
\b
\q1 
\v 26 Ahin koa tahos mul selus ral min meteisau
\q2 ka hihiseien tahos keil akistal ran ongon.
\q1 
\v 27 Kei kilea en tounah koa kur out en teim sen,
\q2 ka sakien ten taripeng tovuol ien.
\q1 
\v 28 Titiali keil onen amasmasi,
\q2 ka meatin onen emun vati lat isen.
\q1 
\v 29 Meatin onen mul viteni mini vit, “Ahin sav keil amum tahos,
\q2 ka keik, komum tahos mulin keil.”
\q1 
\v 30 Ahin koa vi hungevai kilea valuvos meatin, ka more nan hevuol avong tai.
\q2 Ka ahin koa mul vouhou revi min Iahova, kei ihati lat isen.
\q1 
\v 31 Tahos keke meatin onen hesan ris ui umen min ahin onen,
\q2 ka hehati lat isen en meten meatin sav keil ven umen tetahos onen. 
