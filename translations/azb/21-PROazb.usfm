\id PRO Azeri-N: Azerbaijani Bible 2008 
\h SÜLEYMANIN MƏSƏLLƏRİ 
\toc1 Süleymanin Məsəlləri 
\toc2 Süleymanin Məsəlləri 
\toc3 Sül 
\mt1 SÜLEYMANIN MƏSƏLLƏRİ  
\imt1 GİRİŞ  
\ip \bk «Süleymanın Məsəlləri»\bk* Kitabı hikmətli sözlər və məsəllər şəklində olan əxlaqi və mənəvi təlim toplusudur. Bu kitab Allahdan gələn müdrikliyi gündəlik həyatda tətbiq etməyi tövsiyə edir:  
\iq1 «Rəbb qorxusu biliyin başlanğıcıdır» (1:7),  
\iq1 «Bütün qəlbinlə Rəbbə güvən,  
\iq1 Öz idrakına etibar etmə» (3:5).  
\ip Buradakı əsas fikir \bk «Qanunun Təkrarı»\bk* Kitabı ilə həmahəng səslənir: Allaha güvənən, Onun göstərdiyi yolla gedən insan hər işində xeyir-dua alar. Məsəllər ailə və dostluq münasibətlərindən, əmək və ictimai həyatdan bəhs edir. Əsas mövzular müdriklik və səfehlik, salehlik və pislik, hikmətli sözün qüvvəti, sərvət və yoxsulluq, ümid və ehtiyat, sevinc və kədər, ağır əmək və bikarçılıqdır.  
\ip Biliyin, hikmətin təməli «Allah qorxusudur», yəni Allaha hörmət və ehtiramla yanaşmaqdır.  
\iot Kitabın məzmunu:  
\io2 1:1–9:18 Hikmətin faydası  
\io2 10:1–22:16 Süleymanın məsəlləri  
\io2 22:17–24:22 Otuz hikmətli söz  
\io2 24:23-34 Hikmətli sözlərin davamı  
\io2 25:1–29:27 Süleymanın məsəllərinin davamı  
\io2 30:1-33 Aqurun məsəlləri  
\io2 31:1-9 Lemuel padşahın anasının sözləri  
\io2 31:10-31 Xeyirxah arvad  
\c 1  
\p
\v 1 \x * \xo 1:1 \xt 1Pad. 4:32 \x* İsrail padşahı Davud oğlu Süleymanın məsəlləri:   
\s1 Hikmət mənbəyi  
\q1
\v 2 Hikmət və tərbiyəyə malik olmaq,  
\q1 Müdrik sözləri dərk etmək üçün,   
\q1
\v 3 Salehlik, ədalət, insaf barədə  
\q1 İdrak tərbiyəsi almaq üçün,   
\q1
\v 4 Cahillərə uzaqgörənlik,  
\q1 Gənc oğlana bilik və dərrakə vermək üçün;   
\q1
\v 5 Qoy hikmətli qulaq asıb müdrikliyini artırsın,  
\q1 Dərrakəli adam sağlam məsləhət alsın.   
\q1
\v 6 Bu yolla insanlar məsəl və kinayələri,  
\q1 Hikmətlilərin sözlərini və müəmmalarını anlasınlar.   
\q1
\v 7 \x * \xo 1:7 \xt Əyy. 28:28; Zəb. 111:10; Sül. 9:10 \x* Rəbb qorxusu biliyin başlanğıcıdır,  
\q1 Amma səfehlər hikmət və tərbiyəyə xor baxar.   
\s1 Günahkarlardan uzaq durmaq  
\q1
\v 8 Oğlum, ata tərbiyəsinə qulaq as,  
\q1 Ananın öyrətdiklərini kənara atma.   
\q1
\v 9 Onlar başını gözəl çələng kimi,  
\q1 Boynunu boyunbağı kimi bəzər.   
\q1
\v 10 Oğlum, qoyma səni günahkarlar azdırsın.   
\q1
\v 11 Desələr ki: «Gəl bizimlə pusqu qurub qan tökək,  
\q1 Nahaq yerə günahsızları güdək,   
\q1
\v 12 Gəl onları ölülər diyarı kimi diri-diri udaq,  
\q1 Tamam qəbirə düşənlərə bənzəsinlər.   
\q1
\v 13 Onda çoxlu qiymətli sərvət taparıq,  
\q1 Evlərimizi talan malı ilə doldurarıq.   
\q1
\v 14 Bizə qoşul,  
\q1 Qoy kisəmiz bir olsun»,   
\q1
\v 15 Oğlum, onlara qoşulma,  
\q1 Yollarına ayaq basma.   
\q1
\v 16 \x * \xo 1:16 \xt Yeş. 59:7; Rom. 3:15 \x* Çünki onların ayaqları pisliyə tərəf qaçar,  
\q1 Qan tökməyə tələsər.   
\q1
\v 17 Bir quşun gözü önündə  
\q1 Tələ qurmaq faydasızdır.   
\q1
\v 18 Çünki onların qurduğu pusqu öz qanlarını tökmək üçündür,  
\q1 Güdməkləri öz canları üçündür.   
\q1
\v 19 Tamahkarın yolu həmişə belədir,  
\q1 Tamahı onun canını alar.   
\s1 Hikmət çağırır  
\q1
\v 20 \x * \xo 1:20 \xt Sül. 8:1-3 \x* Hikmət bayırda ucadan çağırır,  
\q1 Meydanlarda onun səsi ucalır.   
\q1
\v 21 O, səsli-küylü küçələrin başında çağırır,  
\q1 Şəhər darvazalarında deyir:   
\q1
\v 22 «Ey cahillər, nə vaxtadək  
\q1 Cəhaləti sevəcəksiniz?  
\q1 Nə vaxtadək rişxəndçilər rişxənddən zövq alacaq,  
\q1 Axmaqların bilikdən zəhləsi gedəcək?   
\q1
\v 23 Məzəmmətimdən düzəlsəydiniz,  
\q1 Ruhumu üstünüzə tökərdim,  
\q1 Sözlərimi sizə bildirərdim.   
\q1
\v 24 Sizi çağıranda məni rədd etdiniz,  
\q1 Əlimi uzadanda əhəmiyyət vermədiniz.   
\q1
\v 25 Bütün nəsihətlərimi boş saydınız,  
\q1 Məzəmmətlərimi qəbul etmədiniz.   
\q1
\v 26 Ona görə də sizin üzərinizə bəla gələndə güləcəyəm,  
\q1 Dəhşət sizi bürüyəndə,   
\q1
\v 27 Tufan kimi dəhşət sizə hücum çəkəndə,  
\q1 Sizə qasırğa kimi bəla gələndə,  
\q1 Dara, əziyyətə düşəndə istehza edəcəyəm.   
\q1
\v 28 O vaxt məni çağıranlara cavab verməyəcəyəm,  
\q1 Səylə axtarsalar da, məni tapa bilməyəcəklər.   
\q1
\v 29 Çünki onlar biliyə nifrət etdilər,  
\q1 Rəbdən qorxmaq istəmədilər,   
\q1
\v 30 Nəsihətimi istəmədilər,  
\q1 Hər məzəmmətimi rədd etdilər.   
\q1
\v 31 Buna görə də öz yollarının bəhrəsini yeyəcəklər,  
\q1 Öz nəsihətləri ilə doyacaqlar.   
\q1
\v 32 Cahili özbaşınalığı öldürəcək,  
\q1 Axmağı laqeydliyi məhv edəcək.   
\q1
\v 33 Mənə qulaq asanlarsa əmin-amanlıqda yaşayacaq,  
\q1 Rahatlıq tapacaq, pislikdən qorxmayacaq».   
\c 2  
\s1 Hikmətin dəyəri  
\q1
\v 1 Oğlum, əgər sözlərimi qəbul etsən,  
\q1 Əmrlərimi qorusan,   
\q1
\v 2 Qulağını hikmətə tərəf çevirsən,  
\q1 Ürəyini dərrakəyə tərəf meyl etdirsən,   
\q1
\v 3 Sən, həqiqətən, idrakı çağırsan,  
\q1 Səs ucaldıb dərrakəni səsləsən,   
\q1
\v 4 Bunları gümüş kimi axtarsan,  
\q1 Gizli xəzinə kimi arasan,   
\q1
\v 5 Onda Rəbb qorxusunu anlayarsan,  
\q1 Allahı tanıyarsan.   
\q1
\v 6 Çünki Rəbb hikmət verir,  
\q1 Onun ağzından bilik və dərrakə çıxır.   
\q1
\v 7 O, əməlisalehlərin sağlam şüurunu qoruyur,  
\q1 Kamalla gəzənlərə sipər olur.   
\q1
\v 8 O, ədalətin yollarını qoruyur,  
\q1 Möminlərin yollarını hifz edir.   
\q1
\v 9 Onda salehlik və ədaləti dərk edərsən,  
\q1 İnsafı, bütün yaxşı yolları tanıyarsan.   
\q1
\v 10 Hikmət qəlbinə dolar,  
\q1 Bilikdən könlün xoş olar.   
\q1
\v 11 İdrak səni hifz edər,  
\q1 Dərrakə səni qoruyar.   
\q1
\v 12 Hikmət səni pislərin yolundan,  
\q1 Sözü məkrli adamlardan qurtarar.   
\q1
\v 13 Onlar düz yolları atıblar,  
\q1 Qaranlıq yollarda dolanırlar.   
\q1
\v 14 Şər iş görəndə şad olurlar,  
\q1 Şərin məkrindən xoşhallanırlar.   
\q1
\v 15 Bu adamların yolları əyridir,  
\q1 Onlar dolaşıq yollarla gedir.   
\b  
\q1
\v 16 Hikmət səni yad arvaddan,  
\q1 Şirin dilli əxlaqsız qadından qurtarar.   
\q1
\v 17 Bu qadın gənc vaxtı getdiyi ərini atıb,  
\q1 Allahının əhdini unudub.   
\q1
\v 18 Onun evi ölümə,  
\q1 Yolları qəbiristanlığa aparar.   
\q1
\v 19 Yanına gələn kimsə geri qayıtmaz,  
\q1 Bir daha həyat yollarına çatmaz.   
\b  
\q1
\v 20 Beləliklə, yaxşıların yolu ilə gedərsən,  
\q1 Salehlərin yollarına bağlı qalarsan.   
\q1
\v 21 Çünki əməlisalehlər yer üzündə sakin olacaq,  
\q1 Kamillər burada qalacaq.   
\q1
\v 22 Pis adamlar bu torpaqdan atılacaq,  
\q1 Xainlərin kökü buradan qoparılacaq.   
\c 3  
\s1 Rəbbə güvən  
\q1
\v 1 Oğlum, təlimimi unutma,  
\q1 Qoy qəlbin əmrlərimə bağlansın.   
\q1
\v 2 Onlar ömrünü uzadar,  
\q1 Həyatına illər, firavanlıq artırar.   
\q1
\v 3 Qoy səni xeyirxahlıq və sədaqət tərk etməsin,  
\q1 Onları boynuna bağla, ürəyinin lövhəsinə yaz.   
\q1
\v 4  \x * \xo 3:4 \xt 1Şam. 2:26; Sül. 3:4; Luka 2:52 \x* Onda Allahın və insanların gözündə  
\q1 Lütf tapıb şərəfə çatarsan.   
\b  
\q1
\v 5 Bütün qəlbinlə Rəbbə güvən,  
\q1 Öz idrakına etibar etmə.   
\q1
\v 6 Bütün yollarında Onu tanı,  
\q1 O sənin yollarını düzəldər.   
\q1
\v 7  \x * \xo 3:7 \xt Rom. 12:16 \x* Öz gözündə özünü hikmətli sanma,  
\q1 Rəbdən qorx, şərdən çəkin.   
\q1
\v 8 Bu, bədəninə şəfa verər,  
\q1 Sümüklərinə ilik olar.   
\b  
\q1
\v 9 Rəbbi var-dövlətinlə,  
\q1 Məhsulunun nübarı ilə şərəfləndir.   
\q1
\v 10 Onda anbarların nemətlə dolar,  
\q1 Şərab çənlərin təzə şərabla daşar.   
\b  
\q1
\v 11  \x * \xo 3:11 \xt İbr. 12:5-6 \x* \x * \xo 3:11 \xt Əyy. 5:17 \x* Oğlum, Rəbbin verdiyi tərbiyəyə xor baxma,  
\q1 Onun məzəmmətinə nifrət etmə.   
\q1
\v 12  \x * \xo 3:12 \xt Vəhy 3:19 \x* Ata sevdiyi oğlunu necə məzəmmət edərsə,  
\q1 Rəbb də sevdiyini elə məzəmmət edər.   
\s1 Hikmətin mədhi  
\q1
\v 13 Hikmətə çatan,  
\q1 Dərrakə tapan insan nə bəxtiyardır!   
\q1
\v 14 Bunları qazanmaq gümüş qazanmaqdan yaxşıdır,  
\q1 Bu qazanc saf qızıldan dəyərlidir.   
\q1
\v 15 Hikmət yaqutlardan qiymətlidir,  
\q1 Xoşladığın bütün şeylər ona tay deyil.   
\q1
\v 16 Onun sağ əlində uzun ömür,  
\q1 Sol əlində sərvət və şərəf var.   
\q1
\v 17 Onun yolları bəyənilir,  
\q1 Bütün yolları əmin-amandır.   
\q1
\v 18 Ona bağlananlar üçün o, həyat ağacıdır,  
\q1 Ondan möhkəm yapışanlar nə bəxtiyardır!   
\b  
\q1
\v 19 Rəbb dünyanın təməlini hikmətlə qurub,  
\q1 Dərrakə vasitəsilə göyləri bərqərar edib.   
\q1
\v 20 Biliyi ilə dərinliklər yarılıb,  
\q1 Göylərdən şeh çilənir.   
\s1 Qonşularla davranış  
\q1
\v 21 Oğlum, sağlam şüura, dərrakəyə bağlan,  
\q1 Bunlardan gözünü çəkmə.   
\q1
\v 22 Onlar sənin həyatın olar,  
\q1 Gözəl naxış kimi boynuna bağlanar.   
\q1
\v 23 O zaman rahat gəzərsən,  
\q1 Ayaqların büdrəməz.   
\q1
\v 24 Qorxusuz, rahat yatarsan,  
\q1 Şirin yuxu taparsan.   
\q1
\v 25 Qəfil fəlakətdən,  
\q1 Pislərə gələn bəladan qorxma.   
\q1
\v 26 Çünki güvəndiyin Rəbdir,  
\q1 O qoymaz ki, sən tələyə düşəsən.   
\b  
\q1
\v 27 Əlindən yaxşılıq gəlirsə,  
\q1 Buna layiq insanlardan əsirgəmə.   
\q1
\v 28 İmkanın varsa, qonşuna demə:  
\q1 «Sonra gələrsən, sabah verərəm».   
\q1
\v 29 Yanında sakit yaşayan qonşun üçün  
\q1 Şər qurma.   
\q1
\v 30 Sənə pislik etməyənlə  
\q1 Nahaq yerə çəkişmə.   
\b  
\q1
\v 31 Zorakıya qibtə etmə,  
\q1 O gedən yolların heç birini seçmə.   
\q1
\v 32 Çünki azğınlar Rəbdə ikrah yaradar,  
\q1 Rəbb əməlisalehlərlə dost olar.   
\q1
\v 33 Rəbb pislərin ocağına lənət edər,  
\q1 Salehlərin yurduna xeyir-dua verər.   
\q1
\v 34  \x * \xo 3:34 \xt Yaq. 4:6; 1Pet. 5:5 \x* Rəbb rişxəndçilərə istehza edər,  
\q1 İtaətkarlara isə lütf göstərər.   
\q1
\v 35 Hikmətlilər şərəfi irs alacaq,  
\q1 Axmağın nəsibi şərəfsizlik olacaq.   
\c 4  
\s1 Hikmətin üstünlüyü  
\q1
\v 1 Ey oğullar, atanızın verdiyi tərbiyə qulağınızda qalsın,  
\q1 İdrakı dərk etmək üçün diqqətli olun.   
\q1
\v 2 Çünki sizə yaxşı dərs verirəm,  
\q1 Təlimimi atmayın.   
\q1
\v 3 Mən ata ocağında uşaq olanda,  
\q1 Anamın yeganə balası olanda   
\q1
\v 4 Atam mənə təlim verərək dedi:  
\q1 «Qoy qəlbin sözümə möhkəm bağlansın,  
\q1 Əmrlərimə əməl et ki, ömrün uzun olsun.   
\q1
\v 5 Hikmət qazan, idrak qazan,  
\q1 Sözlərimi unutma, sözümdən çıxma.   
\q1
\v 6 Hikmətdən ayrılmasan, o səni qoruyar,  
\q1 Əgər onu sevsən, səni saxlayar.   
\q1
\v 7 Hikmət hər şeydən üstündür, gərək onu qazanasan,  
\q1 İdraka sahib olmaq üçün var-yoxunu verəsən.   
\q1
\v 8 Onu üstün tutsan, səni ucaldar,  
\q1 Əgər ona bağlansan, səni şərəfə çatdırar.   
\q1
\v 9 O sənin başının gözəl çələngi olar,  
\q1 Başına şərəf tacı qoyar».   
\b  
\q1
\v 10 Oğlum, məni dinlə,  
\q1 Sözlərimi qəbul etsən, ömrünü uzadarsan.   
\q1
\v 11 Sənə hikmət yolunun təlimini verirəm,  
\q1 Düz yolda gəzdirirəm.   
\q1
\v 12 Gedəndə addımların büdrəməz,  
\q1 Qaçanda ayaqların sürüşməz.   
\q1
\v 13 Aldığın tərbiyəyə bağlan, ayrılma,  
\q1 Onu saxla, o sənin həyatındır.   
\q1
\v 14 Pislərin yoluna ayaq basma,  
\q1 Şər insanın yolu ilə getmə.   
\q1
\v 15 Çəkil, bu yolun yaxınından belə, keçmə,  
\q1 Uzaq dur, başqa bir səmtdən yolu keç.   
\q1
\v 16 Çünki şər adamlar pislik etməsələr,  
\q1 Yata bilməzlər.  
\q1 Kimisə yıxmasalar, yuxuları qaçar.   
\q1
\v 17 Şərin çörəyini yeyərlər,  
\q1 Zorakılığın şərabını içərlər.   
\q1
\v 18 Salehlərin yolu isə dan yeri tək şəfəq saçar,  
\q1 Nurunu artıraraq gündüzə qovuşar.   
\q1
\v 19 Pislərinsə yolu zülmətdir,  
\q1 Onlar nəyə görə büdrədiklərini bilməzlər.   
\b  
\q1
\v 20 Oğlum, sözlərimə fikir ver,  
\q1 Dediklərimə qulaq as.   
\q1
\v 21 Onları gözlərinin önündən ayırma,  
\q1 Onları ürəyində qoru.   
\q1
\v 22 Çünki onları tapanlar  
\q1 Həyat və cansağlığı tapar.   
\q1
\v 23 Hər şeydən əvvəl öz ürəyini qoru,  
\q1 Çünki həyat çeşməsi odur.   
\q1
\v 24 Əyri danışığı ağzından götür,  
\q1 Azğın dodaqları özündən uzaqlaşdır.   
\q1
\v 25 Gözlərin irəliyə baxsın,  
\q1 Düppədüz qarşına nəzər sal.   
\q1
\v 26  \x * \xo 4:26 \xt İbr. 12:12-13 \x* Getdiyin yolu düzəlt,  
\q1 Yollarını sahmana sal.   
\q1
\v 27 Nə sağa, nə də sola dön,  
\q1 Ayağını pislikdən çək.   
\c 5  
\s1 Əxlaqsızlıqdan uzaqlaş  
\q1
\v 1 Oğlum, mənim hikmətimə diqqət yetir,  
\q1 Qulağını müdrik sözlərimə tərəf çevir.   
\q1
\v 2 Onda dərrakəyə bağlanarsan,  
\q1 Dilin biliyi kənara atmaz.   
\q1
\v 3 Əxlaqsız qadının dodağından sanki bal axır,  
\q1 Dili şirin, yağdan yumşaqdır.   
\q1
\v 4 Amma aqibəti yovşan kimi acıdır,  
\q1 İkiağızlı qılınc kimi kəskindir.   
\q1
\v 5 Onun ayaqları ölümə aparır,  
\q1 Onun addımları ölülər diyarına çatır.   
\q1
\v 6 Həyat yoluna fikir vermir,  
\q1 Yolları dolaşıqdır, özü də bilmir.   
\b  
\q1
\v 7 İndi, ey övladlar, mənə qulaq asın,  
\q1 Dilimdən çıxan sözlərdən yayınmayın.   
\q1
\v 8 Belə qadından uzaq ol,  
\q1 Evinin qapısına yaxın getmə.   
\q1
\v 9 Yoxsa şərəfini yadlara verərsən,  
\q1 Ömrünü zalımlara sərf edərsən.   
\q1
\v 10 Sənin var-yoxunu yadlar yeyər,  
\q1 Qazancın özgənin evinə gedər.   
\q1
\v 11 Ömrünün sonu çatanda,  
\q1 Canında taqət qalmayanda  
\q1 Ah-nalə çəkərək belə deyərsən:   
\q1
\v 12 «Mən də tərbiyəyə nifrət etdim,  
\q1 Ürəyimdə məzəmmətlərə güldüm!   
\q1
\v 13 Müəllimimin sözünə baxmadım,  
\q1 Tərbiyəçilərimə qulaq asmadım.   
\q1
\v 14 Camaatın və icmanın arasında  
\q1 Az qala hər cür bəlaya düşəcəkdim».   
\s1 Arvadına vəfalı ol  
\q1
\v 15 Öz su anbarından,  
\q1 Öz quyunun içməli suyundan iç.   
\q1
\v 16 Niyə sənin qaynaqların küçələrə,  
\q1 Su arxların meydanlara axıb getsin?   
\q1
\v 17 Onlar yalnız səninki olsun,  
\q1 Yadlara paylama.   
\q1
\v 18 Qoy çeşmən bərəkətli olsun,  
\q1 Gənc ikən evləndiyin arvadınla xoşbəxt yaşa!   
\q1
\v 19 Sevimli maralın, gözəl ceyranın  
\q1 Həmişə səni öz döşləri ilə doydursun,  
\q1 Onun eşqi ilə məst ol.   
\q1
\v 20 Oğlum, niyə əxlaqsız qadınla məst olmalısan,  
\q1 Yad arvadı qoynuna almalısan?   
\b  
\q1
\v 21 İnsanların yolları Rəbbin gözü qarşısındadır,  
\q1 Onların hər addımlarını yoxlayır.   
\q1
\v 22 Şər insan öz təqsirlərinə görə tutular,  
\q1 Günahının kəməndinə dolanar.   
\q1
\v 23 Tərbiyəsizliyi üzündən həlak olar,  
\q1 Hədsiz səfehliyi üzündən azar.   
\c 6  
\s1 Tələlərdən ehtiyatlı ol  
\q1
\v 1 Oğlum, qonşuna zamin durub,  
\q1 Yadlarla əlbir olub,   
\q1
\v 2 Ağzından çıxan sözlərlə tələyə düşmüsənsə,  
\q1 Ağzından çıxan sözlərlə ələ keçmisənsə,   
\q1
\v 3 Demək bu qonşunun əlinə düşmüsən.  
\q1 Oğlum, çalış, özünü qurtar:  
\q1 Get onun ayağına düş, yalvar-yaxar.   
\q1
\v 4 Qoy gözünə yuxu getməsin,  
\q1 Kirpiklərin ağırlaşmasın.   
\q1
\v 5 Özünü ovçunun əlindən ceyran kimi,  
\q1 Quşbazın əlindən quş kimi qurtar.   
\b  
\q1
\v 6 Ey tənbəl, qarışqalara diqqət yetir,  
\q1 Onların həyatından ibrət götür.   
\q1
\v 7 Onların nə başçıları var,  
\q1 Nə nəzarətçiləri, nə də hökmdarları.   
\q1
\v 8 Yayda azuqələrini yığar,  
\q1 Biçin vaxtı özlərinə yem toplayarlar.   
\q1
\v 9 Ey tənbəl, nə qədər yatacaqsan?  
\q1 Nə vaxt yuxudan oyanacaqsan?   
\q1
\v 10  \x * \xo 6:10 \xt Sül. 24:33-34 \x* Bir az da uzanıb yuxuya dalsan,  
\q1 Əl-qolunu uzadaraq yatsan,   
\q1
\v 11 Yoxsulluq soyğunçu kimi üstünə gələr,  
\q1 Ehtiyac quldur kimi sənə hücum çəkər.   
\b  
\q1
\v 12 Yaramaz adam – şər insan  
\q1 Əyri danışaraq dolanar,   
\q1
\v 13 Göz vurar, ayaqları ilə işarə edər,  
\q1 Barmaqları ilə göstərər.   
\q1
\v 14 Qəlbinin məkrli niyyəti var,  
\q1 Həmişə şər qurar, nifaq salar.   
\q1
\v 15 Ona görə başına qəfildən bəla gələr,  
\q1 Birdən yıxılıb çarəsiz qalar.   
\b  
\q1
\v 16 Rəbbin zəhləsi altı şeydən gedir,  
\q1 Yeddi şey var, ondan ikrah edir:   
\q1
\v 17 Təkəbbürlə baxan gözlər;  
\q1 Yalan danışan dil;  
\q1 Nahaq qan tökən əllər;   
\q1
\v 18 Məqsədi şər olan ürək;  
\q1 Şərə çatmaq üçün qaçan ayaqlar;   
\q1
\v 19 Nəfəsini yalanla çıxaran yalançı şahid;  
\q1 Qardaşlar arasında nifaq salan şəxs.   
\s1 Zinaya qarşı xəbərdarlıq  
\q1
\v 20 Oğlum, atanın əmrini yerinə yetir,  
\q1 Ananın öyrətdiklərini atma.   
\q1
\v 21 Onları qəlbinin başına yapışdır,  
\q1 Həmişə onları boynuna bağla.   
\q1
\v 22 Gəzəndə onlar sənə yol göstərər,  
\q1 Yatanda səni hifz edər,  
\q1 Oyananda sənə məsləhət verər.   
\q1
\v 23 Bu əmr çıraqdır, bu təlim nurdur,  
\q1 Tərbiyə üçün edilən məzəmmət həyat yoludur.   
\q1
\v 24 Bunlar səni pozğun qadından,  
\q1 Şirindilli yad arvaddan qoruyar.   
\q1
\v 25 Onun gözəlliyinə aşiq olma,  
\q1 Onun kirpiklərinin əsiri olma.   
\q1
\v 26 Fahişənin üzündən insan bir tikə çörəyə möhtac qalar,  
\q1 Kiminsə zinakar arvadı insanın qiymətli canını ovlar.   
\q1
\v 27 Bir kişi qoynuna od alanda  
\q1 Əyin-başı yanmazmı?   
\q1
\v 28 Köz üzərində gəzənin  
\q1 Ayaqları bişməzmi?   
\q1
\v 29 Qonşusunun arvadının yanına girənin də halı belədir,  
\q1 O qadına toxunan cəzasını çəkər.   
\b  
\q1
\v 30 Qarnını doydurmaq üçün ac oğru oğurlarsa,  
\q1 Kimsə onu qınamaz.   
\q1
\v 31 Amma onu tutsalar, yeddi qat ödəməlidir,  
\q1 Evinin var-yoxunu verməlidir.   
\q1
\v 32 Qadınla zina edən qanmazdır,  
\q1 Özünü məhv etmək istəyən belə edər.   
\q1
\v 33 Bu kişinin nəsibi kötək, şərəfsizlikdir,  
\q1 Biabırçılığı üzərindən silinməz.   
\q1
\v 34 Çünki ərini qeyrət coşdurar,  
\q1 Ondan amansızcasına qisas alar.   
\q1
\v 35 Heç nə ilə ərinin qarşısını almaq olmaz,  
\q1 Nə verilsə belə, o razılaşmaz.   
\c 7  
\s1 Əxlaqsız qadının hiyləsi  
\q1
\v 1 Oğlum, sözlərimə bağlı qal,  
\q1 Əmrlərimi özündə saxla.   
\q1
\v 2 Əmrlərimə bağlı qalsan, yaşayacaqsan,  
\q1 Təlimimi göz bəbəyin kimi qoru.   
\q1
\v 3 Onları üzük kimi barmağına keçir,  
\q1 Ürəyinin lövhəsinə köçür.   
\q1
\v 4 Hikmətə de: «Bacımsan»,  
\q1 İdraka söylə: «Yaxın dostumsan».   
\q1
\v 5 Onlar səni əxlaqsız qadından,  
\q1 Şirindilli yad arvaddan qoruyar.   
\b  
\q1
\v 6 Evimin pəncərəsinin şəbəkəsindən  
\q1 Mən bayıra baxırdım.   
\q1
\v 7 Bir dəstə cahil gənc arasında  
\q1 Qanmaz bir cavanı gördüm.   
\q1
\v 8 Bu qadının evinin tininə yaxın küçədən keçirdi,  
\q1 Onun evi olan yolla gedirdi.   
\q1
\v 9 Alaqaranlıqda, gün batanda,  
\q1 Gecə düşəndə, hava qaralanda.   
\q1
\v 10 Fahişə libaslı, qəlbi fitnə dolu bu qadın  
\q1 Dərhal onu qarşıladı.   
\q1
\v 11 O hay-küyçüdür, o bihəyadır,  
\q1 Öz evində oturmayandır.   
\q1
\v 12 Gah küçəyə, gah meydanlara çıxar,  
\q1 Hər tin başı bir pusqu qurar.   
\q1
\v 13 O, oğlanı tutub öpdü,  
\q1 Həyasızcasına belə dedi:   
\q1
\v 14 «Ünsiyyət qurbanı kəsməyə borclu idim,  
\q1 Əhdimə bu gün əməl etmişəm.   
\q1
\v 15 Ona görə səni görmək üçün qarşına çıxdım,  
\q1 Səni çox axtardım, axır ki tapdım.   
\q1
\v 16 Yatağıma Misir kətanından toxunan  
\q1 Əlvan üz çəkmişəm.   
\q1
\v 17 Yorğan-döşəyimə  
\q1 Mirra, əzvay, darçın səpmişəm.   
\q1
\v 18 Gəl sübhə qədər doyunca sevişək,  
\q1 Eşqdən məst olaq.   
\q1
\v 19 Ərim evdə yoxdur,  
\q1 Uzaq bir səfərə gedib.   
\q1
\v 20 Pul kisəsini götürüb,  
\q1 Evə ay bədirlənəndə qayıdacaq».   
\q1
\v 21 Fəndlər işlədib onu tovladı,  
\q1 Şirin dilə tutub yoldan çıxartdı.   
\q1
\v 22 Kəsilməyə aparılan bir öküz kimi,  
\q1 Kəməndə salınan bir maral kimi  
\q1 Bu oğlan o qadının ardınca düşdü.   
\q1
\v 23 Axırda ciyərinə bir ox saplanacaq.  
\q1 Uçub tez tora düşən quş kimi  
\q1 Bu oğlan da canının alınacağını bilmirdi.   
\b  
\q1
\v 24 İndi, ey övladlar, mənə qulaq asın,  
\q1 Dilimdən çıxan sözlərə laqeyd olmayın.   
\q1
\v 25 Qoyma qəlbin o qadının yollarına meyl etsin,  
\q1 Onun yoluna dönmə.   
\q1
\v 26 Çünki o qadın nə qədər insanı qurban edib,  
\q1 Nə qədər adamı öldürüb.   
\q1
\v 27 Onun evinin yolu ölülər diyarına aparır,  
\q1 Ölüm mənzilinə gedib çatır.   
\c 8  
\s1 Hikmətin nitqi  
\q1
\v 1  \x * \xo 8:1 \xt Sül. 1:20-21 \x* Məgər hikmət çağırmırmı,  
\q1 Məgər dərrakə səsləmirmi   
\q1
\v 2 Uca yerlərdə, yol kənarında,  
\q1 Yollar ayrıcında dayanıb?   
\q1
\v 3 Darvazaların yanında, şəhərin qarşısında,  
\q1 Qapıların kandarında çağırır:   
\q1
\v 4 «Ey insanlar, mən sizi səsləyirəm,  
\q1 Ey bəşər övladları, sizə xitab edirəm.   
\q1
\v 5 Ey cahillər, uzaqgörən olun,  
\q1 Ey axmaqlar, ağıllanın.   
\q1
\v 6 Dinləyin, əla şeylərdən danışıram,  
\q1 Dilimdən düz sözlər çıxır.   
\q1
\v 7 Ağzım həqiqət söyləyir,  
\q1 Dilim şərdən iyrənir.   
\q1
\v 8 Ağzımdan yalnız salehlik sözləri çıxır,  
\q1 Sözlərimdə nə əyrilik, nə də ki yalan var.   
\q1
\v 9 Anlayanlar üçün hər şey aydındır,  
\q1 Bilik qazananlar üçün bu bir həqiqətdir.   
\q1
\v 10 Gümüşü yox, tərbiyəmi qəbul edin,  
\q1 Saf qızıldan çox biliyi seçin.   
\q1
\v 11 Çünki hikmət yaqutdan qiymətlidir,  
\q1 İnsanın könlü istəyən şeylər ona tay deyil.   
\b  
\q1
\v 12 Mən hikmətəm, uzaqgörənlik məndə məskən salıb,  
\q1 Biliyi, dərrakəni tapmışam.   
\q1
\v 13 Rəbb qorxusu pisliyə nifrət etməkdir,  
\q1 Lovğalığa, təkəbbürə, pis yola,  
\q1 Hiyləli dilə nifrət edərəm.   
\q1
\v 14 Nəsihət, sağlam şüur mənimdir,  
\q1 İdrak mənəm, qüvvəm var.   
\q1
\v 15 Mənim vasitəmlə şahlar hökmranlıq edir,  
\q1 Hökmdarlar ədalətli fərman verir.   
\q1
\v 16 Ədalətli hakim olan bütün başçılar və əsilzadələr  
\q1 Mənim vasitəmlə hökm verir.   
\q1
\v 17 Məni sevənləri sevirəm,  
\q1 Məni səylə axtaran tapır.   
\q1
\v 18 Sərvət və şərəf,  
\q1 Dağılmaz var-dövlət və salehlik yanımdadır.   
\q1
\v 19 Barım qızıldan, saf qızıldan dəyərlidir,  
\q1 Bəhərim gümüşdən qiymətlidir.   
\q1
\v 20 Mən salehlik yolunda,  
\q1 Ədalət yollarının ortasında gəzərəm.   
\q1
\v 21 Məni sevənləri sərvətə çatdıraram,  
\q1 Xəzinələrini dolduraram.   
\b  
\q1
\v 22  \x * \xo 8:22 \xt Vəhy 3:14-15 \x* Rəbb Öz yolunun başlanğıcında,  
\q1 Hər işindən əvvəl mənə malik oldu.   
\q1
\v 23 Yaradılışın əzəlindən,  
\q1 Dünya yaranmazdan əvvəl mən var idim.   
\q1
\v 24 Dərin sular olmazdan əvvəl,  
\q1 Bol sulu çeşmələr olmazdan əvvəl doğulmuşam.   
\q1
\v 25 Dağlar yaradılmazdan əvvəl,  
\q1 Təpələr mövcud olmazdan əvvəl təvəllüd tapmışam.   
\q1
\v 26 Rəbb dünyanı, çölü-düzü, torpaqları yaradanda,   
\q1
\v 27 Göyləri yaradanda,  
\q1 Dərinliyin üzü üstündə bir dairə çəkəndə,   
\q1
\v 28 Buludları yuxarıda yerləşdirəndə,  
\q1 Dərinlikdə bulaqları bağlayanda,   
\q1
\v 29 Sular əmrindən çıxmasın deyə dənizə sədd çəkəndə,  
\q1 Yerin bünövrələrini təyin edəndə   
\q1
\v 30 Rəbbin yanında memar idim.  
\q1 Hər gün fərəhlənirdim,  
\q1 Hüzurunda həmişə sevinirdim.   
\q1
\v 31 Yaratdığı aləmə görə sevinirdim,  
\q1 Bəşər övladlarına görə fərəhlənirdim.   
\b  
\q1
\v 32 İndi, ey övladlar, mənə qulaq asın:  
\q1 Yoluma bağlı qalan nə bəxtiyardır!   
\q1
\v 33 Verdiyim tərbiyəyə qulaq asın,  
\q1 Hikmət alın, onu bir tərəfə atmayın.   
\q1
\v 34 Mənə qulaq asan,  
\q1 Hər gün darvazalarım qarşısında duran,  
\q1 Qapılarımda dayanıb gözləyən nə bəxtiyardır!   
\q1
\v 35 Çünki məni tapan həyat tapar,  
\q1 Rəbbi razı salar.   
\q1
\v 36 Məni əldən verən canına qəsd edər,  
\q1 Mənə nifrət edənlərin hamısı ölümü sevər».   
\c 9  
\s1 Hikmət yolu  
\q1
\v 1 Hikmət evini qurub,  
\q1 Yeddi dirəyini yonub,   
\q1
\v 2 Heyvanlarını kəsib,  
\q1 Şərabını hazırlayıb,  
\q1 Süfrəsini də düzəldib.   
\q1
\v 3 Göndərdiyi kənizlər  
\q1 Şəhərin uca yerlərindən car çəkərlər:   
\q1
\v 4 «Gəlin bura, ey cahillər!»  
\q1 Qanmazlara belə deyərlər:   
\q1
\v 5 «Gəlin, çörəyimdən yeyin,  
\q1 Hazırladığım şərabdan için.   
\q1
\v 6 Cəhaləti atın, ömür sürün,  
\q1 İdrak yolu ilə düz gedin».   
\b  
\q1
\v 7 Rişxəndçini tənqid edən özünü rüsvayçılığa salar,  
\q1 Şər adamı danlayan axırda ləkələnər.   
\q1
\v 8 Rişxəndçini danlama, yoxsa sənə nifrət edər,  
\q1 Müdrik insanı danlasan, səni sevər.   
\q1
\v 9 Hikmətliyə öyüd versən, hikmətini artıracaq,  
\q1 Salehə bilik öyrətsən, müdrikliyini çoxaldacaq.   
\b  
\q1
\v 10  \x * \xo 9:10 \xt Əyy. 28:28; Zəb. 111:10; Sül. 1:7 \x* Rəbb qorxusu hikmətin başlanğıcıdır,  
\q1 Müqəddəsi tanımaq idraklı olmaqdır.   
\q1
\v 11 Hikmətin vasitəsilə ömrün-günün çoxalar,  
\q1 Həyatına illər əlavə olar.   
\q1
\v 12 Əgər hikmət qazansan, özünə xeyir verərsən,  
\q1 Əgər rişxənd etsən, zərərini özün çəkərsən.   
\s1 Axmaqlıq yolu  
\q1
\v 13 Axmaq qadın hay-küy salır,  
\q1 Cahildir, heç nə qanmır.   
\q1
\v 14 O, evinin qapısı önündə oturub,  
\q1 Şəhərin uca yerlərində kətil üstə əyləşib,   
\q1
\v 15 Yoldan ötənləri,  
\q1 Düz yolda olanları çağırır:   
\q1
\v 16 «Bura gəlin, ey cahillər!»  
\q1 Qanmazlara belə deyir:   
\q1
\v 17 «Oğurluq su şirin olar,  
\q1 Gizli yeyilən çörəyin başqa ləzzəti var».   
\q1
\v 18 Lakin yanına gələnlər bilməzlər ki,  
\q1 Orada ölüm var,  
\q1 Bu qadının çağırdıqları ölülər diyarının dərinliyindədir.   
\c 10  
\s1 Məsəllər  
\p
\v 1 Süleymanın məsəlləri:  
\q1 Hikmətli oğul atasını sevindirər,  
\q1 Axmaq oğul anasına dərd gətirər.   
\b  
\q1
\v 2 Şər yolla yığılan xəzinədən fayda götürmək olmaz,  
\q1 Amma salehlik insanı ölümdən qurtarar.   
\b  
\q1
\v 3 Rəbb saleh insanı ac qoymaz,  
\q1 O, acgöz pisləri doydurmaz.   
\b  
\q1
\v 4 Tənbəlin əlləri onu yoxsullaşdırar,  
\q1 Çalışqanın əli sərvət qazanar.   
\b  
\q1
\v 5 Ağıllı oğul yayda məhsul yığar,  
\q1 Biçin vaxtı yatan oğul rüsvay olar.   
\b  
\q1
\v 6 Saleh insanın başından bərəkət yağar,  
\q1 Şər adamın dili zorakılığı gizli saxlar.   
\b  
\q1
\v 7 Saleh insanın adı xeyir-dua ilə çağırılar,  
\q1 Şər adamın adı isə çürüyər.   
\b  
\q1
\v 8 Qəlbən hikmətli olan əmrləri qəbul edər,  
\q1 Səfeh boşboğazlığı üzündən itib-batar.   
\b  
\q1
\v 9 Kamalla gəzib-dolaşan dinc yaşar,  
\q1 Yolu əyri olanlar üzə çıxar.   
\b  
\q1
\v 10 Göz vuran başına bəla açar,  
\q1 Səfeh boşboğazlığı üzündən itib-batar.   
\b  
\q1
\v 11 Salehin ağzı həyat qaynağı olar,  
\q1 Amma şər adamın dili zorakılığı gizli saxlar.   
\b  
\q1
\v 12  \x * \xo 10:12 \xt Yaq. 5:19-20; 1Pet. 4:8 \x* Nifrət nifaq yaradar,  
\q1 Lakin məhəbbət bütün günahları örtər.   
\b  
\q1
\v 13 Dərrakəlinin dilindən hikmət tökülər,  
\q1 Qanmaz kürəyindən kötəklənər.   
\b  
\q1
\v 14 Hikmətli adamlar bilik toplar,  
\q1 Səfehin boşboğazlığı onu bəlaya yaxınlaşdırar.   
\b  
\q1
\v 15 Zənginin var-dövləti ona qalalı şəhərdir,  
\q1 Kasıbı yoxsulluq bəlaya salar.   
\b  
\q1
\v 16 Salehin mükafatı həyatdır,  
\q1 Şər adamınsa qazancı günahdır.   
\b  
\q1
\v 17 Tərbiyəyə bağlanan həyat yolunda olar,  
\q1 Məzəmməti rədd edən yolunu azar.   
\b  
\q1
\v 18 Nifrətini gizlədən yalan danışar,  
\q1 Axmaq hər yana böhtanlar yayar.   
\b  
\q1
\v 19 Çox sözlərlə günahı azaltmaq olmaz,  
\q1 Dilini saxlayan ağıllıdır.   
\b  
\q1
\v 20 Saleh insanın dili saf gümüşə oxşar,  
\q1 Şər adamın qəlbinin dəyəri az olar.   
\b  
\q1
\v 21 Saleh öz dili ilə çox adamı doydurar,  
\q1 Səfeh qanmazlığı üzündən həlak olar.   
\b  
\q1
\v 22 Rəbbin xeyir-duası insana sərvət gətirər,  
\q1 Daha ona qüssə verməz.   
\b  
\q1
\v 23 Axmaq üçün şər iş görmək bir əyləncədir,  
\q1 Dərrakəlininsə hikməti var.   
\b  
\q1
\v 24 Şər adam nədən qorxursa, başına gələr,  
\q1 Saleh isə muradına çatar.   
\b  
\q1
\v 25 Qopan tufan şəri süpürüb aparar,  
\q1 Salehin təməli əbədi qalar.   
\b  
\q1
\v 26 Dişlərə sirkə, gözlərə tüstü necə təsir edirsə,  
\q1 Tənbələ iş buyuran bunu elə hiss edər.   
\b  
\q1
\v 27 Rəbb qorxusu ömür uzadar,  
\q1 Şər insanların ömründən illər azalar.   
\b  
\q1
\v 28 Salehləri sevinc gözlər,  
\q1 Şər insanların ümidi boşa çıxar.   
\b  
\q1
\v 29 Kamilin pənahı Rəbbin yoludur.  
\q1 Şər iş görənin başı bəla ilə doludur.   
\b  
\q1
\v 30 Saleh heç vaxt sarsılmaz,  
\q1 Şər insanlar yer üzündə qalmaz.   
\b  
\q1
\v 31 Salehin ağzı hikmətlə çiçəklənər,  
\q1 Hiyləli dillər kəsilər.   
\b  
\q1
\v 32 Saleh insanın dili razı salmağı bacarar,  
\q1 Şər insanın ağzından hiyləli sözlər çıxar.   
\b  
\c 11  
\q1
\v 1 Aldadıcı tərəzi Rəbdə ikrah yaradar,  
\q1 Rəbb düz çəki daşından razı qalar.   
\b  
\q1
\v 2 Lovğalıq gələndə şərəfsizlik gətirər,  
\q1 Hikmət itaətkarın yanına gələr.   
\b  
\q1
\v 3 Əməlisalehi kamillik yolu aparar,  
\q1 Xəyanətkar əyriliyindən məhv olar.   
\b  
\q1
\v 4 Heç kimi var-dövləti qəzəb günündən xilas etməz,  
\q1 Amma salehlik insanı ölümdən qurtarar.   
\b  
\q1
\v 5 Kamil insanın yolunu salehliyi düz edər,  
\q1 Şər adamı pisliyi yıxar.   
\b  
\q1
\v 6 Əməlisalehi salehliyi qurtarar,  
\q1 Xaini acgözlüyü tələyə salar.   
\b  
\q1
\v 7 Şər insan ölər, ümidi də boşa çıxar,  
\q1 Pislərin arzusu itib-batar.   
\b  
\q1
\v 8 Saleh dardan qurtular,  
\q1 Onun yerinə pis insan dara düşər.   
\b  
\q1
\v 9 Allahsızın dili qonşusunu məhv edər,  
\q1 Bilik salehi xilas edər.   
\b  
\q1
\v 10 Salehlər xeyrə çatanda bütün şəhər şad olar,  
\q1 Şər adamlar öləndə sevinc harayı qalxar.   
\b  
\q1
\v 11 Əməlisalehlərin alqışı şəhəri şərəfə çatdırar,  
\q1 Lakin şərin qarğışı oranı viran qoyar.   
\b  
\q1
\v 12 Qanmaz qonşusuna xor baxar,  
\q1 Dərrakəli insan dinc dayanar.   
\b  
\q1
\v 13 Sözgəzdirən sirləri açıb yayar,  
\q1 Etibarlı adam sözü gizli saxlar.   
\b  
\q1
\v 14 Düz məsləhət verilməyən yerdə xalq yıxılar,  
\q1 Doğru nəsihət verən çoxdursa, xalq qurtuluşa çatar.   
\b  
\q1
\v 15 Özgəyə zamin duran özünü bəlaya salar,  
\q1 Belə zaminlikdən zəhləsi gedən dinc yaşar.   
\b  
\q1
\v 16 Mehriban qadın şərəfdən,  
\q1 Zalım insan isə sərvətdən yapışar.   
\b  
\q1
\v 17 İnsanın sadiqliyi ona xeyir gətirər,  
\q1 Qəddar adam özünə əzab verər.   
\b  
\q1
\v 18 Şər adam saxta mükafat qazanar,  
\q1 Salehlik toxumu əkən, həqiqətən, onun əvəzini alar.   
\b  
\q1
\v 19 Sidq ürəkdən saleh olan həyata qovuşar,  
\q1 Şərin ardınca düşən ölümə çatar.   
\b  
\q1
\v 20 Əyri ürəkli olmaq Rəbdə ikrah yaradar,  
\q1 O, yolu kamil olanlardan razı qalar.   
\b  
\q1
\v 21 Doğrudan da, pis cəzasız qalmaz,  
\q1 Salehlərin nəsli xilas olar.   
\b  
\q1
\v 22 Bir gözəl qadının xoş rəftarı olmazsa,  
\q1 Burnuna qızıl halqa taxılmış donuza bənzər.   
\b  
\q1
\v 23 Salehlər yalnız yaxşılıq arzular,  
\q1 Şər adama qəzəb nəsib olar.   
\b  
\q1
\v 24 Əliaçıq adamın bərəkəti artar,  
\q1 Başqasının qazancını yeyən ehtiyaca düşər.   
\b  
\q1
\v 25 Comərd bolluğa yetişər,  
\q1 Su verənə su verilər.   
\b  
\q1
\v 26 Taxılı anbarda gizlədənə camaat lənət oxuyar,  
\q1 Onu satanın başına bərəkət yağar.   
\b  
\q1
\v 27 Səylə yaxşılığın ardınca gedən lütf axtarar,  
\q1 Şər ardınca düşən isə başını bəlaya salar.   
\b  
\q1
\v 28 Sərvətinə güvənənlər yıxılar,  
\q1 Salehlər isə yaşıl yarpaq kimi təzələnər.   
\b  
\q1
\v 29 Külfətini əzaba salanın nəsibi yel tək sovrular,  
\q1 Qəlbində hikmət olana səfeh qul olar.   
\b  
\q1
\v 30 Salehin barı həyat ağacıdır,  
\q1 Hikmətli insan canları qurtarar.   
\b  
\q1
\v 31  \x * \xo 11:31 \xt 1Pet. 4:18 \x* Əgər bu dünyada salehlərə belə, cəza verilirsə,  
\q1 Pislərə, günahkarlara gör nə qədər cəza verilər!   
\b  
\c 12  
\q1
\v 1 Tərbiyəni sevən biliyi sevər,  
\q1 Məzəmmətə nifrət edən şüursuzdur.   
\b  
\q1
\v 2 Rəbb yaxşı adamdan razı qalar,  
\q1 Pisniyyət adamı isə məhkum edər.   
\b  
\q1
\v 3 İnsan şərlə möhkəm olmaz,  
\q1 Salehinsə kökü sarsılmaz.   
\b  
\q1
\v 4 Xeyirxah arvad ərinin tacıdır,  
\q1 Adbatıran qadın çürümüş sümüyə oxşar.   
\b  
\q1
\v 5 Salehlərin məqsədi ədalətdir,  
\q1 Şər insanların məsləhəti hiyləgərlikdir.   
\b  
\q1
\v 6 Şər adamların sözləri ölüm üçün pusqu qurar,  
\q1 Əməlisalehlər dili ilə xilas olar.   
\b  
\q1
\v 7 Pislər yıxılıb məhv olar,  
\q1 Salehin evi dağılmaz.   
\b  
\q1
\v 8 İnsan ağıllı sözlərinə görə təriflənər,  
\q1 Qəlbində hiylə olanlara xor baxılar.   
\b  
\q1
\v 9 Şöhrətsiz, lakin qul sahibi olan insan  
\q1 Lovğalanan, lakin çörəyə möhtac adamdan yaxşıdır.   
\b  
\q1
\v 10 Saleh insan hətta heyvanlarının ehtiyacını duyar,  
\q1 Şər insanın mərhəmətində də zalımlıq var.   
\b  
\q1
\v 11 Torpağını əkib-becərən doyunca çörək yeyər,  
\q1 Qanmaz boş şeylərin ardınca gedər.   
\b  
\q1
\v 12 Şər adam pislərin şikarına qibtə edər,  
\q1 Salehin kökü pöhrələnər.   
\b  
\q1
\v 13 Pis adamı itaətsiz dili tələyə salar,  
\q1 Saleh dara düşsə də, oradan salamat qurtarar.   
\b  
\q1
\v 14 İnsanın dilindən yaxşı söz çıxarsa, bol xeyir tapar,  
\q1 Əlinin zəhmətinin əvəzini alar.   
\b  
\q1
\v 15 Səfehin yolu öz gözündə düz görünər,  
\q1 Hikmətli adam nəsihəti dinlər.   
\b  
\q1
\v 16 Səfeh dərhal qəzəbini üzə verər,  
\q1 Uzaqgörən şərəfsizliyin üstünü örtər.   
\b  
\q1
\v 17 Doğru şahid həqiqəti danışar,  
\q1 Yalançı şahid hiylə qurar.   
\b  
\q1
\v 18 Düşünmədən danışanın dili qılınc kimi yaralar,  
\q1 Hikmətlinin dili isə insanları sağaldar.   
\b  
\q1
\v 19 Düz söz əbədi yaşar,  
\q1 Yalanın ömrü az olar.   
\b  
\q1
\v 20 Şər quranın qəlbində hiylə olar,  
\q1 Nəsihət verib sülhə çağıran sevinc tapar.   
\b  
\q1
\v 21 Saleh heç vaxt bəlaya düşməz,  
\q1 Pislərin başı bəla ilə dolu olar.   
\b  
\q1
\v 22 Rəbb yalançı dilə ikrah edər,  
\q1 Həqiqəti yerinə yetirənlərdən isə razı qalar.   
\b  
\q1
\v 23 Uzaqgörən bildiyini özü üçün saxlar,  
\q1 Axmaq qəlbinin səfehliyini hamıya yayar.   
\b  
\q1
\v 24 Çalışqanın əli özünü ağa edər,  
\q1 Tənbəllik insanı qula çevirər.   
\b  
\q1
\v 25 Qəlbi narahat olanın qəddi əyilər,  
\q1 Xoş söz könlü şad edər.   
\b  
\q1
\v 26 Saleh insan qonşusuna da yol göstərər,  
\q1 Lakin şər insanın yolu dolaşıqdır.   
\b  
\q1
\v 27 Tənbəlin əlinə ov düşsə də, onu bişirməz,  
\q1 Çalışqan qiymətli sərvətə çatar.   
\b  
\q1
\v 28 Salehliyin yollarında həyat var,  
\q1 Kim bu yolla getsə, orada ölüm tapmaz.   
\b  
\c 13  
\q1
\v 1 Hikmətli oğul ata tərbiyəsinə qulaq asar,  
\q1 Rişxəndçi iradı qulaq ardına vurar.   
\b  
\q1
\v 2 İnsanın dilində yaxşı söz olsa, onun xeyrini yeyər,  
\q1 Xain zorakılıq istər.   
\b  
\q1
\v 3 Dilini saxlayan canını qoruyar,  
\q1 Boşboğaz başını bəlaya salar.   
\b  
\q1
\v 4 Tənbəl arzuladığına çatmaz,  
\q1 Çalışqan bolluğa qovuşar.   
\b  
\q1
\v 5 Saleh adam yalana nifrət edər,  
\q1 Şər insanın sözləri xəcalət və rüsvayçılıq gətirər.   
\b  
\q1
\v 6 Kamillik yolunda olanı salehlik qoruyar,  
\q1 Günahkarı şər yıxar.   
\b  
\q1
\v 7 Adam var ki, heç nəyi yoxdur, özünü varlı göstərir,  
\q1 Adam var ki, malı çoxdur, özünü yoxsul göstərir.   
\b  
\q1
\v 8 Sərvət insanın canını təhlükədən qurtarar,  
\q1 Yoxsul isə hədə-qorxu eşitməz.   
\b  
\q1
\v 9 Saleh insanların işığı könlü sevindirər,  
\q1 Şər insanların çırağı sönər.   
\b  
\q1
\v 10 Təkəbbürdən ancaq münaqişə yaranar,  
\q1 Yaxşı nəsihətə qulaq asanın hikməti var.   
\b  
\q1
\v 11 Kələklə gələn sərvət azalar,  
\q1 Zəhmətlə qazanılan sərvət isə artar.   
\b  
\q1
\v 12 Gecikən ümid ürəyi xəstələndirir,  
\q1 Arzuya çatmaq həyat ağacıdır.   
\b  
\q1
\v 13 Öyüdə xor baxan öz canını həlak edər,  
\q1 Əmrə ehtiram edənlərə mükafat verilər.   
\b  
\q1
\v 14 Hikmətli adamın təlimi həyat qaynağıdır,  
\q1 İnsanı ölüm tələsinə düşməkdən geri qaytarır.   
\b  
\q1
\v 15 Dərin ağlı olan lütf qazanır,  
\q1 Xainin yolu dolaşıqdır.   
\b  
\q1
\v 16 Uzaqgörən hər gördüyü işi bilir,  
\q1 Axmaq öz səfehliyini hamıya göstərir.   
\b  
\q1
\v 17 Pis qasid bəlaya düşər,  
\q1 Etibarlı elçi şəfa verər.   
\b  
\q1
\v 18 Tərbiyəni rədd edən yoxsullaşıb şərəfdən düşər,  
\q1 Məzəmməti qəbul edən şərəfə yetişər.   
\b  
\q1
\v 19 Arzuya çatmaq qəlbə, cana şirin gələr,  
\q1 Axmaq pislikdən dönməyə ikrah edər.   
\b  
\q1
\v 20 Hikmətli ilə oturub-duran hikmət qazanar,  
\q1 Axmaqlarla ayaqlaşan bədbəxt olar.   
\b  
\q1
\v 21 Günahkarı şər qovar,  
\q1 Salehin yaxşı bir əvəzi var.   
\b  
\q1
\v 22 Yaxşı insan nəvələrinə də irs qoyar,  
\q1 Günahkarın yığdığı sərvət salehə qalar.   
\b  
\q1
\v 23 Yoxsulların əkini bol bəhrə versə də,  
\q1 Ədalət olmayan yerdə bada gedər.   
\b  
\q1
\v 24 Oğlundan kötəyi əsirgəyən sanki ona nifrət edər,  
\q1 Oğlunu sevən ona düzgün tərbiyə verər.   
\b  
\q1
\v 25 Saleh yeyib doyar,  
\q1 Şər adamsa ac qalar.   
\b  
\c 14  
\q1
\v 1 Hikmətli qadın evini qurar,  
\q1 Səfeh qadın onu öz əli ilə uçurar.   
\b  
\q1
\v 2 Düz yol tutan Rəbdən qorxar,  
\q1 Yolunu azan Ona xor baxar.   
\b  
\q1
\v 3 Səfeh lovğa sözlərinə görə kötək qazanar,  
\q1 Hikmətlinin dili onu qoruyar.   
\b  
\q1
\v 4 Öküz olmayan yerdə axur təmiz olar,  
\q1 Amma bol məhsul öküzün gücü ilə yaranar.   
\b  
\q1
\v 5 Doğru şahid yalan deməz,  
\q1 Yalançı şahid yalandan üzə durar.   
\b  
\q1
\v 6 Rişxəndçi hikmət axtaranda onu tapmaz,  
\q1 Dərrakəli adama bilik tapmaq asan olar.   
\b  
\q1
\v 7 Axmağın qarşısından çəkil,  
\q1 Onun dilində ağıllı söz tapmazsan.   
\b  
\q1
\v 8 Uzaqgörən hikməti ilə öz yolunu anlar,  
\q1 Axmaq səfehliyi ilə öz-özünü aldadar.   
\b  
\q1
\v 9 Səfehlər günaha rişxənd edər,  
\q1 Əməlisalehlər bir-birini məmnun edər.   
\b  
\q1
\v 10 Ürək öz dərdini bilər,  
\q1 Özgələr onun sevincinə şərik olmaz.   
\b  
\q1
\v 11 Şərin evi tar-mar olar,  
\q1 Əməlisalehlərin yurdu çiçək açar.   
\b  
\q1
\v 12  \x * \xo 14:12 \xt Sül. 16:25 \x* Yol var ki, insanın qarşısında düz görünür,  
\q1 Amma sonu ölümdür.   
\b  
\q1
\v 13 Ürək güləndə də qəmli olar,  
\q1 Sevincin sonunda da kədər var.   
\b  
\q1
\v 14 Azğın ürəklilər öz yollarının bəhrəsini doyunca yeyir,  
\q1 Yaxşı adam isə əməlinin əvəzini alır.   
\b  
\q1
\v 15 Cahil hər sözə inanar,  
\q1 Uzaqgörən hər addımına nəzər salar.   
\b  
\q1
\v 16 Hikmətli qorxub pislikdən dönər,  
\q1 Axmaq ehtiyatsızdır, özünə güvənər.   
\b  
\q1
\v 17 Hövsələsiz səfeh-səfeh iş görər,  
\q1 Pisniyyət adama nifrət edilər.   
\b  
\q1
\v 18 Cahil səfehliyi irs alar,  
\q1 Uzaqgörənin başına bilik tacı qoyular.   
\b  
\q1
\v 19 Pislər yaxşıların qarşısında,  
\q1 Şər adam isə salehin qapısında əyilər.   
\b  
\q1
\v 20 Yoxsula qonşusu da nifrət edər,  
\q1 Zəngini isə çox adam sevər.   
\b  
\q1
\v 21 Qonşusuna xor baxan günaha batar,  
\q1 Məzluma səxavət göstərən nə bəxtiyardır!   
\b  
\q1
\v 22 Şər quranlar yolundan azmırlarmı?  
\q1 Məqsədi xeyirxahlıq olan xeyirxahlığa, sədaqətə çatar.   
\b  
\q1
\v 23 Hər zəhmətdə bir fayda var,  
\q1 Boş sözlər insanı ehtiyac içində qoyar.   
\b  
\q1
\v 24 Hikmətlinin başına sərvət tacı qoyular,  
\q1 Axmaqlar səfehliyi ilə tanınar.   
\b  
\q1
\v 25 Doğru şahid canları qurtarar,  
\q1 Yalançı şahid hiylə qurar.   
\b  
\q1
\v 26 Rəbdən qorxan tam arxayındır,  
\q1 Çünki Rəbb onun övladlarının pənahıdır.   
\b  
\q1
\v 27 Rəbb qorxusu həyat qaynağıdır,  
\q1 İnsanı ölüm tələsinə düşməkdən geri qaytarır.   
\b  
\q1
\v 28 Padşahın əzəməti xalqın çoxluğu ilə bilinər,  
\q1 Əgər təbəələri olmasa, hökmdar süqut edər.   
\b  
\q1
\v 29 Gec qəzəblənənin böyük dərrakəsi var,  
\q1 Hövsələsizlərdən səfehlik çıxar.   
\b  
\q1
\v 30 Ürəyin rahatlığı cana həyat verər,  
\q1 Paxıllıqsa sümükləri çürüdər.   
\b  
\q1
\v 31 Kasıba zülm edən Yaradanına xor baxar,  
\q1 Yoxsula lütf göstərən Ona hörmət edər.   
\b  
\q1
\v 32 Şər adam pisliyi üzündən qovular,  
\q1 Salehin ölümündə belə, pənahı var.   
\b  
\q1
\v 33 Hikmət dərrakəlinin qəlbində özünə rahat yuva qurar,  
\q1 Hətta axmaqların arasında da bəlli olar.   
\b  
\q1
\v 34 Salehlik bir milləti ucaldar,  
\q1 Günah ümmətləri utandırar.   
\b  
\q1
\v 35 Padşah ağıllı qulundan razı qalar,  
\q1 Adbatıransa onun qəzəbinə düçar olar.   
\b  
\c 15  
\q1
\v 1 Həlim cavab hirsi yatırar,  
\q1 Sərt söz qəzəbi alovlandırar.   
\b  
\q1
\v 2 Hikmətlinin dili biliyi mədh edər,  
\q1 Axmaqların dilindən səfehlik tökülər.   
\b  
\q1
\v 3 Rəbbin gözü hər yerə baxar,  
\q1 Pislərə, yaxşılara nəzər salar.   
\b  
\q1
\v 4 Şəfa gətirən dil həyat ağacıdır,  
\q1 Əyri dil ürək qırar.   
\b  
\q1
\v 5 Səfeh ata tərbiyəsini ələ salar,  
\q1 Məzəmməti qəbul edən uzaqgörən olar.   
\b  
\q1
\v 6 Salehin evində böyük xəzinə yaşar,  
\q1 Şər insanın isə gəlirində əzab var.   
\b  
\q1
\v 7 Hikmətlinin dili bilik səpələyir,  
\q1 Axmağın qəlbi bunu edə bilmir.   
\b  
\q1
\v 8 Rəbb şər insanın etdiyi qurbandan ikrah edir,  
\q1 Əməlisalehlərin duasından isə razı qalır.   
\b  
\q1
\v 9 Rəbb şər insanın yollarından ikrah edər,  
\q1 Amma salehliyin ardınca gedəni sevər.   
\b  
\q1
\v 10 Düz yolu buraxana şiddətli töhmət verilər,  
\q1 Məzəmmətə nifrət edənə ölüm gələr.   
\b  
\q1
\v 11 Ölüm və Həlak yeri Rəbbə aşkardır,  
\q1 Gör O, insan ürəyindən necə agahdır.   
\b  
\q1
\v 12 Rişxəndçi iradı sevməz,  
\q1 Hikmətlilərin yanına gəlməz.   
\b  
\q1
\v 13 Qəlbin sevinci üzü xoş edər,  
\q1 Ürəyin kədəri könlü sındırar.   
\b  
\q1
\v 14 Dərrakəlinin könlü bilik axtarar,  
\q1 Axmaqların ağzı səfehliklə qidalanar.   
\b  
\q1
\v 15 Məzlumun hər günü qaradır,  
\q1 Ürəyi bəxtəvərin elə bil daima ziyafəti var.   
\b  
\q1
\v 16 Rəbb qorxusu ilə qazanılan az şey  
\q1 Qayğı ilə yığılan böyük xəzinədən yaxşıdır.   
\b  
\q1
\v 17 Sevgi dolu bir yerdə göyərti yemək  
\q1 Nifrət dolu bir yerdə yağlı dana əti yeməkdən yaxşıdır.   
\b  
\q1
\v 18 Kəmhövsələ dava yaradar,  
\q1 Səbirli münaqişəni sovuşdurar.   
\b  
\q1
\v 19 Tənbəlin yolunu tikanlar basar,  
\q1 Əməlisalehlərin yolu baş yoldur.   
\b  
\q1
\v 20 Hikmətli oğul atasını sevindirər,  
\q1 Axmaq anasına xor baxar.   
\b  
\q1
\v 21 Qanmaz səfehlikdən sevinər,  
\q1 Dərrakəli düz yolla gedər.   
\b  
\q1
\v 22 Məsləhətsiz niyyət boşa çıxar,  
\q1 Doğru nəsihət verən çoxdursa, uğur qazandırar.   
\b  
\q1
\v 23 İnsan münasib cavab versə, şad olar,  
\q1 Sözü yerində demək nə yaxşıdır!   
\b  
\q1
\v 24 Ağıllı insan aşağıdan – ölülər diyarından ayrılmaq üçün  
\q1 Həyat yolunu tutub yuxarı gedər.   
\b  
\q1
\v 25 Rəbb təkəbbürlünün evini yıxar,  
\q1 Dul qadının sərhədini qoruyar.   
\b  
\q1
\v 26 Pislərin məqsədləri Rəbdə ikrah yaradar,  
\q1 Ona xoş gələnlərin sözlərini təmiz sayar.   
\b  
\q1
\v 27 Tamahkar külfətini əzaba salar,  
\q1 Rüşvətə nifrət edənin ömrü uzun olar.   
\b  
\q1
\v 28 Saleh insan cavab verməzdən əvvəl qəlbində düşünər,  
\q1 Şər insanın dilindən pislik tökülər.   
\b  
\q1
\v 29 Rəbb şər adamdan gen dayanar,  
\q1 Saleh insanların duasına qulaq asar.   
\b  
\q1
\v 30 Nurlu gözlər qəlbi sevindirər,  
\q1 Yaxşı xəbər qəddi düzəldər.   
\b  
\q1
\v 31 Həyatverici məzəmmətə qulaq asan  
\q1 Hikmətlilərin içərisində yaşar.   
\b  
\q1
\v 32 Tərbiyəni rədd edən öz canına xor baxar,  
\q1 Məzəmmətə qulaq asan anlayış qazanar.   
\b  
\q1
\v 33 Rəbb qorxusu hikmət tərbiyəsi verər,  
\q1 İtaətkarlıq şərəfdən əvvəl gələr.   
\b  
\c 16  
\q1
\v 1 Ürəyin fikirləri insandan,  
\q1 Dilin cavabı isə Rəbdəndir.   
\b  
\q1
\v 2 İnsanın bütün yolları öz gözündə təmiz sayılar,  
\q1 Lakin Rəbb ürəkləri yoxlar.   
\b  
\q1
\v 3 Görəcəyin işləri Rəbbə ver,  
\q1 Onda niyyətlərin yerinə yetər.   
\b  
\q1
\v 4 Rəbb hər şeyi məqsədinə müvafiq yaradıb,  
\q1 O, pis insanı bəla günü üçün yaradıb.   
\b  
\q1
\v 5 Rəbb qəlbi təkəbbürlülərdən ikrah edər,  
\q1 Doğrudan da, onlar cəzasız qalmaz.   
\b  
\q1
\v 6 Xeyirxahlıq və sədaqət hər təqsiri kəffarə edər,  
\q1 İnsan Rəbb qorxusuna görə pislikdən dönər.   
\b  
\q1
\v 7 Rəbb insanın həyatından razı qaldısa,  
\q1 Düşmənlərini belə, onunla barışdırar.   
\b  
\q1
\v 8 Salehliklə qazanılan az şey  
\q1 Haqsız yolla olan bol gəlirdən yaxşıdır.   
\b  
\q1
\v 9 İnsan ürəyində özü üçün yol qurar,  
\q1 Amma Rəbbin verdiyi istiqamətlə addımlar.   
\b  
\q1
\v 10 Padşah uzaqgörənliklə dilindən sözlər çıxarar,  
\q1 Qoy onda məhkəmədə ədalətdən yan keçməsin.   
\b  
\q1
\v 11 Rəbb düzgün tərəzi və çəkini tələb edər,  
\q1 O, torbadakı hər çəki daşını müəyyən edər.   
\b  
\q1
\v 12 Şər iş görmək padşahlarda ikrah yaradar,  
\q1 Çünki salehliklə taxtlar möhkəm olar.   
\b  
\q1
\v 13 Saleh adamın dili padşahları razı salar,  
\q1 Onlar düz danışanı sevər.   
\b  
\q1
\v 14 Padşahın hiddəti ölüm elçisidir,  
\q1 Amma hikmətli insan bu hiddəti yatırar.   
\b  
\q1
\v 15 Padşahın üzü nuranidirsə, demək, həyat var,  
\q1 Razılığı yaz yağışı gətirən buluda oxşar.   
\b  
\q1
\v 16 Qızıldan çox hikmət qazanmaq yaxşıdır,  
\q1 Gümüşü yox, idrakı yığmaq üstün tutular.   
\b  
\q1
\v 17 Əməlisalehlər pislikdən dönmək yolunu tutar,  
\q1 Yoluna diqqət edən canını qoruyar.   
\b  
\q1
\v 18 Əcəldən əvvəl təkəbbür gələr,  
\q1 Fəlakətdən əvvəl lovğalıq ruhu gələr.   
\b  
\q1
\v 19 Məzlumlar arasında sadə qəlbli olmaq  
\q1 Təkəbbürlülərlə talan malı bölüşdürməkdən yaxşıdır.   
\b  
\q1
\v 20 Sözdən hikmət alan xeyir tapar,  
\q1 Rəbbə güvənən insan nə bəxtiyardır!   
\b  
\q1
\v 21 Qəlbində hikmət olan dərrakəli adlanar,  
\q1 Şirin dilli olan müdrikliyi artırar.   
\b  
\q1
\v 22 Ağıl insan üçün həyat çeşməsidir,  
\q1 Axmağa tərbiyə vermək səfehlikdir.   
\b  
\q1
\v 23 Hikmətlinin ürəyi dilinə tərbiyə verir,  
\q1 Ağzındakı müdrik sözləri artıq edir.   
\b  
\q1
\v 24 Xoş sözlər sanki pətəkdə baldır,  
\q1 Cana şirinlik, sümüklərə şəfadır.   
\b  
\q1
\v 25  \x * \xo 16:25 \xt Sül. 14:12 \x* Yol var ki, insanın qarşısında düz görünür,  
\q1 Amma sonu ölümdür.   
\b  
\q1
\v 26 Əməkçi qarnı üçün zəhmət çəkir,  
\q1 Aclıq onu məcbur edir.   
\b  
\q1
\v 27 Yaramaz şər quyusu qazar,  
\q1 Dili alov kimi yandırıb-yaxar.   
\b  
\q1
\v 28 Hiyləgər adam dava yaradar,  
\q1 Qeybətçi əziz dostları ayırar.   
\b  
\q1
\v 29 Zorakı qonşularını aldadar,  
\q1 Onları yaxşı olmayan yola aparar.   
\b  
\q1
\v 30 Niyyəti hiyləli olan göz vurar,  
\q1 Dodaq büzər, şər qurar.   
\b  
\q1
\v 31 Ağaran saçlar şərəf tacıdır,  
\q1 Salehlik yolunun qazancıdır.   
\b  
\q1
\v 32 İgid olmaqdan səbirli olmaq yaxşıdır,  
\q1 Nəfsə hakim olmaq şəhəri almaqdan üstündür.   
\b  
\q1
\v 33 Ətəyin üstünə püşk atılar,  
\q1 Amma hökm Rəbdən gələr.   
\b  
\c 17  
\q1
\v 1 Quru bir loğması olan dinc ev  
\q1 Münaqişəli olan, ziyafət dolu evdən yaxşıdır.   
\b  
\q1
\v 2 Ağıllı nökər adbatıran oğlun ağası olar,  
\q1 Qardaşlar arasında miras payı alar.   
\b  
\q1
\v 3 Qızıl-gümüş isti kürədə yoxlanar,  
\q1 Rəbb isə ürəyi araşdırar.   
\b  
\q1
\v 4 Pis adamın diqqəti şər ağızdadır,  
\q1 Yalançı fitnəkarın sözlərinə qulaq asır.   
\b  
\q1
\v 5 Yoxsula rişxənd edən Yaradanına xor baxır,  
\q1 Başqasının bəlasına sevinən cəzasız qalmır.   
\b  
\q1
\v 6 Nəvələr ahılların tacıdır,  
\q1 Oğulların şərəfi atalarıdır.   
\b  
\q1
\v 7 Sarsağa bəlağətli \f + \fr 17:7 \fq Bəlağətli \ft – inandırıcı, gözəl və aydın nitq.\f* söz yaraşmadığı kimi  
\q1 Əsilzadəyə də yalançı dil yaraşmaz.   
\b  
\q1
\v 8 Rüşvət verənin gözündə rüşvət bir tilsimdir,  
\q1 Çünki hansı tərəfə getsə, uğur gətirir.   
\b  
\q1
\v 9 Günahı örtən məhəbbət axtarar,  
\q1 Sözgəzdirən əziz dostları ayırar.   
\b  
\q1
\v 10 Qanan insan üçün bir irad  
\q1 Axmağa vurulan yüz zərbədən də artıq təsir edir.   
\b  
\q1
\v 11 Pis insan ancaq üsyankarlıq axtarar,  
\q1 Onun əleyhinə qəddar qasid göndərilər.   
\b  
\q1
\v 12 Balalarını itirmiş bir ayıya rast gəlmək  
\q1 Səfahətə batmış axmaqla rastlaşmaqdan yaxşıdır.   
\b  
\q1
\v 13 Kim yaxşılıq əvəzinə pislik etsə,  
\q1 Evindən pislik ayrılmaz.   
\b  
\q1
\v 14 Davanın başlanması su bəndinin açılmasına bənzər,  
\q1 Dava başlanmamış münaqişəni tərk et.   
\b  
\q1
\v 15 Şərə haqq vermək, salehi məhkum etmək –  
\q1 Hər ikisi Rəbdə ikrah yaradır.   
\b  
\q1
\v 16 Axmaq hikmət qazanmaq istəməz,  
\q1 Bunun üçün pul sərf etmək fayda verməz.   
\b  
\q1
\v 17 Dost hər zaman sevər,  
\q1 Qardaş dar gün üçün doğular.   
\b  
\q1
\v 18 Qanmaz başqası ilə əlbir olar,  
\q1 O, qonşusuna zamin durar.   
\b  
\q1
\v 19 İtaətsizliyi sevən münaqişəni sevər,  
\q1 Qapısını ucaldan əcəlini səslər.   
\b  
\q1
\v 20 Əyri ürəkli xeyir tapmaz,  
\q1 Hiyləgər dilli insanı bəlaya salar.   
\b  
\q1
\v 21 Axmağın atası dərdə düşər,  
\q1 Sarsağın atasının sevinci itər.   
\b  
\q1
\v 22 Ürək sevinci can üçün ən yaxşı məlhəmdir,  
\q1 Könlün sınması sümükləri qurudar.   
\b  
\q1
\v 23 Şər qoltuğuna rüşvət götürər ki,  
\q1 Ədalət yollarını pozsun.   
\b  
\q1
\v 24 Qanan adam hikmətə baxar,  
\q1 Axmağın gözləri dünyanın o tayını axtarar.   
\b  
\q1
\v 25 Axmaq oğul atasına qəm-kədər verər,  
\q1 Onu doğan anasını qubarladar.   
\b  
\q1
\v 26 Saleh insanı cərimə etmək yaxşı deyil,  
\q1 Əsilzadəni düzlüyünə görə döymək yaxşı deyil.   
\b  
\q1
\v 27 Çoxbilən az danışar,  
\q1 Müdrik həlimlik ruhunda olar.   
\b  
\q1
\v 28 Səfeh belə, sakit dayansa, hikmətli hesab edilər,  
\q1 Ağzını yumsa, dərrakəli görünər.   
\b  
\c 18  
\q1
\v 1 Tənhalığı sevən niyyətinin ardınca düşür,  
\q1 Sağlam şüura zidd gedir.   
\b  
\q1
\v 2 Axmaq dərrakəni deyil,  
\q1 Fikrini ortaya tökməyi sevir.   
\b  
\q1
\v 3 Şər insanla hörmətsizlik,  
\q1 Şərəfsizliklə rüsvayçılıq gələr.   
\b  
\q1
\v 4 Dilin sözlərindən dərin sular yaranar,  
\q1 Hikmət qaynağından çay axar.   
\b  
\q1
\v 5 Məhkəmədə salehi haqsız çıxarmaq üçün  
\q1 Pis adama tərəfkeşlik etmək yaxşı deyil.   
\b  
\q1
\v 6 Axmağın dili münaqişəyə girişər,  
\q1 Ağzı özünü döydürər.   
\b  
\q1
\v 7 Axmağın ağzı onu bəlaya salar,  
\q1 Dili canına tələ qurar.   
\b  
\q1
\v 8 Qeybətçinin sözləri şirin tikələrə bənzər,  
\q1 Mədənin ən dərin yerlərinə düşər.   
\b  
\q1
\v 9 Ləng işləyən dağıdıcıya yoldaşdır.   
\b  
\q1
\v 10 Rəbbin adı qüvvətli bir qaladır,  
\q1 Saleh qaçıb ona pənah aparır.   
\b  
\q1
\v 11 Varlı üçün sərvəti ona qala şəhəridir,  
\q1 Öz gümanında özü üçün pənah hasarı tikir.   
\b  
\q1
\v 12 Ürəyin təkəbbürü əcəldən əvvəl gələr,  
\q1 İtaətkarlıq şərəfdən əvvəl gələr.   
\b  
\q1
\v 13 Eşitməzdən qabaq cavab vermək  
\q1 Səfehlik və rüsvayçılıqdır.   
\b  
\q1
\v 14 Xəstənin ürəyi bütün ağrıları çəkər.  
\q1 Amma ürəyi sınıqdırsa, buna necə dözər?   
\b  
\q1
\v 15 Dərrakəli ürək bilik qazanar,  
\q1 Hikmətlinin qulağı bilik axtarar.   
\b  
\q1
\v 16 İnsanın hədiyyəsi ona yol açar,  
\q1 Böyük adamların hüzuruna aparar.   
\b  
\q1
\v 17 İddiasını əvvəl deyən haqlı görünər,  
\q1 Amma əleyhdarı gəlib onu istintaq edər.   
\b  
\q1
\v 18 Püşk atmaq davaları yatırar,  
\q1 Savaşanları bir-birindən ayırar.   
\b  
\q1
\v 19 İncik qardaşın könlünü almaq qalalı şəhəri almaqdan daha çətindir,  
\q1 Belə davalar qapısı cəftəli qala kimidir.   
\b  
\q1
\v 20 İnsanın qarnı ağzının bəhəri ilə,  
\q1 Dilinin səmərəsi ilə doyar.   
\b  
\q1
\v 21 Ölüm və həyat dilin əlindədir,  
\q1 Onu sevənlər barından yeyir.   
\b  
\q1
\v 22 Arvad alan uğur qazanar,  
\q1 Rəbbin razılığını alar.   
\b  
\q1
\v 23 Yoxsul rəhm istəyər,  
\q1 Zəngin isə sərt cavab verər.   
\b  
\q1
\v 24 Dost çoxaldan öz-özünü yıxar,  
\q1 Amma qardaşdan daha yaxın dost da var.   
\b  
\c 19  
\q1
\v 1 Kamalla yaşayan yoxsul insan  
\q1 Şər danışan axmaqdan yaxşıdır.   
\b  
\q1
\v 2 Bilik yoxdursa, həvəs yaxşılıq edə bilməz.  
\q1 Tələsən tərsə düşər.   
\b  
\q1
\v 3 İnsan öz səfehliyi ilə yolunu alt-üst edər,  
\q1 Ürəyində isə Rəbbə hiddətlənər.   
\b  
\q1
\v 4 Var-dövlət dost artırar,  
\q1 Kasıbı isə dostları atar.   
\b  
\q1
\v 5 Yalançı şahid cəzasız qalmaz,  
\q1 Yalandan üzə duran qurtuluş tapmaz.   
\b  
\q1
\v 6 Çoxları nəcabətlinin üzünü görmək istər,  
\q1 Səxavətli adamla çoxları dostluq edər.   
\b  
\q1
\v 7 Yoxsuldan qardaşının da zəhləsi gedər,  
\q1 Dostları ondan lap uzaq gəzər,  
\q1 Yalvararaq ardınca düşsə də, yaxınına gəlməz.   
\b  
\q1
\v 8 Anlayış qazanan öz canını sevər,  
\q1 Dərrakəyə bağlanan uğur qazanar.   
\b  
\q1
\v 9 Yalançı şahid cəzasız qalmaz,  
\q1 Yalandan üzə duran həlak olar.   
\b  
\q1
\v 10 Axmağa dəbdəbəli həyat yaraşmadığı kimi  
\q1 Qulun ağalara hökm etməsi də yaraşmaz.   
\b  
\q1
\v 11 İnsanın ağlı hiddəti ləngidər,  
\q1 Başqasının günahını bağışlamaq ona şərəf gətirər.   
\b  
\q1
\v 12 Padşahın qəzəbi aslan nərəsinə bənzər,  
\q1 Razılığı çəmənə düşən şehə bənzər.   
\b  
\q1
\v 13 Axmaq oğul atasına bəla olar,  
\q1 Davakar arvad kəsilməyən damcıya oxşar.   
\b  
\q1
\v 14 İnsana ev, var-dövlət atalardan miras qalar,  
\q1 Ağıllı arvadı isə Rəbb nəsib edər.   
\b  
\q1
\v 15 Tənbəllik insana dərin yuxu gətirər,  
\q1 Avaralıq insanı ac qoyar.   
\b  
\q1
\v 16 Əmrə əməl edən canını saxlar,  
\q1 Yoluna baxmayan həlak olar.   
\b  
\q1
\v 17 Kasıba səxavət göstərən sanki Rəbbə borc verər,  
\q1 Çünki onun əvəzi Rəbdən gələr.   
\b  
\q1
\v 18 Ümid varkən oğluna tərbiyə ver,  
\q1 Ölümünə bais olma.   
\b  
\q1
\v 19 Kəmhövsələ insan cəriməyə düşər,  
\q1 Onu qurtarsan belə, yenə də davam edər.   
\b  
\q1
\v 20 Nəsihətə qulaq as, tərbiyəni qəbul et,  
\q1 Bunun nəticəsində hikmətli olarsan.   
\b  
\q1
\v 21 İnsanın qəlbində çox amalı var,  
\q1 Amma Rəbbin niyyəti həyata keçər.   
\b  
\q1
\v 22 İnsan etibar arzular,  
\q1 Yoxsul adam fırıldaqçıdan yaxşıdır.   
\b  
\q1
\v 23 Rəbb qorxusu insana həyat verər,  
\q1 Ona şər yaxınlaşmaz, tox yatar.   
\b  
\q1
\v 24 Tənbəl əlini qabda olana batırar,  
\q1 Ağzına belə, aparmaz.   
\b  
\q1
\v 25 Rişxəndçini döysən, cahil insan uzaqgörən olar,  
\q1 Dərrakəlini danlasan, biliyini artırar.   
\b  
\q1
\v 26 Kim ki atasını soyub, anasını qovar,  
\q1 Xəcalət gətirən övladdır, ad batırar.   
\b  
\q1
\v 27 Oğlum, bilik verən sözlərdən dönmək istəsən,  
\q1 Tərbiyəyə qulaq asmaqdan vaz keç!   
\b  
\q1
\v 28 Yaramaz şahid ədalətə rişxənd edər,  
\q1 Pislərin ağzı acgözlüklə şəri yeyər.   
\b  
\q1
\v 29 Rişxəndçilər üçün məhkəmə,  
\q1 Axmaqların kürəyi üçün kötək hazırlanar.   
\b  
\c 20  
\q1
\v 1 Şərab insanları ələ salar,  
\q1 Kefləndirici içki onları dalaşdırar,  
\q1 Sərxoş olan müdrik olmaz.   
\b  
\q1
\v 2 Padşahın vahiməsi aslan nərəsinə bənzər,  
\q1 Onu əsəbləşdirən canını itirər.   
\b  
\q1
\v 3 Münaqişədən çəkinmək insana şərəf gətirər,  
\q1 Hər səfeh davaya girişər.   
\b  
\q1
\v 4 Mövsümündə kotan sürməyən tənbəl əkinçi  
\q1 Biçin vaxtı heç nə tapmaz.   
\b  
\q1
\v 5 Ürəyin düşüncələri dərin sulara oxşar,  
\q1 Dərrakəli adam onu çəkib çıxarar.   
\b  
\q1
\v 6 İnsanların çoxu sədaqətindən dəm vurar.  
\q1 Amma sadiq adamı haradan tapmaq olar?   
\b  
\q1
\v 7 Saleh kamalı ilə yaşar,  
\q1 Özündən sonra gələn nəsli bəxtiyar olar.   
\b  
\q1
\v 8 Nə zaman ki padşah hökm üçün taxta çıxar,  
\q1 Gözləri ilə bütün pisliyi sovurar.   
\b  
\q1
\v 9 Kim deyər ki, qəlbimi təmizləmişəm,  
\q1 Günahımı silmişəm?   
\b  
\q1
\v 10 Aldadıcı ölçü, aldadıcı çəki –  
\q1 Hər ikisi Rəbdə ikrah yaradar.   
\b  
\q1
\v 11 Hətta uşaq da əməlləri ilə,  
\q1 İşlərinin saf, doğru, yoxsa əksinə olması ilə tanınar.   
\b  
\q1
\v 12 Eşidən qulaq, görən gözlər –  
\q1 Bunların hər ikisini yaradan Rəbdir.   
\b  
\q1
\v 13 Sevmə yatmağı, yoxsullaşarsan,  
\q1 Ayıq ol, onda bol çörəyə çatarsan.   
\b  
\q1
\v 14 Müştəri deyər: «Pisdir, pis maldır»,  
\q1 Amma alıb gedəndə özünü öyər.   
\b  
\q1
\v 15 Qızıl və çox yaqut var,  
\q1 Amma ağıllı söz danışan dil qiymətli cəvahirdir.   
\b  
\q1
\v 16 Özgəyə zamin duranın libasını al,  
\q1 Onu qəriblər üçün girov saxla.   
\b  
\q1
\v 17 Kələklə əldə edilən çörək əvvəlcə şirin olar,  
\q1 Axırda ağzı çınqılla doldurar.   
\b  
\q1
\v 18 Nəsihət alaraq möhkəm qərar çıxar,  
\q1 Müharibəni sağlam məsləhətlə apar.   
\b  
\q1
\v 19 Sözgəzdirən sirləri açıb yayar,  
\q1 Gərək boşboğaza qoşulmayasan.   
\b  
\q1
\v 20 Kim ki atasına, anasına qarğış edər,  
\q1 Zülmətə düşərkən çırağı sönər.   
\b  
\q1
\v 21 Tələsik alınan mülk  
\q1 Axırda xeyir gətirməz.   
\b  
\q1
\v 22 Demə «bu pisliyin əvəzini çıxacağam»  
\q1 Rəbbi gözlə, qoy O səni xilas etsin.   
\b  
\q1
\v 23 Fərqli çəki daşları Rəbdə ikrah yaradar,  
\q1 O, aldadıcı tərəzidən xoşlanmaz.   
\b  
\q1
\v 24 Kişiyə addım atdıran Rəbdir.  
\q1 Bəs tutduğu yolu insan necə anlasın?   
\b  
\q1
\v 25 Düşünmədən nəzir edən özünü tələyə salar,  
\q1 Sonra öz əhdi barədə çox fikirləşməli olar.   
\b  
\q1
\v 26 Hikmətli padşah pisləri sovurar,  
\q1 Onlar dəyirman daşında üyüdülər.   
\b  
\q1
\v 27 İnsanın ruhu Rəbbin çırağıdır,  
\q1 Daxilinin dərin yerlərini araşdırar.   
\b  
\q1
\v 28 Padşahı məhəbbət və sədaqət qoruyar,  
\q1 Taxtını xeyirxahlıq möhkəm saxlar.   
\b  
\q1
\v 29 Gəncləri qüvvəti şərəfləndirər,  
\q1 Ağ saçlar qocalara zinət verər.   
\b  
\q1
\v 30 Yaralayıcı zərbələr pis insanı düzəldə bilər,  
\q1 Kötəkləmək daxilin dərin yerlərinə təsir edə bilər.   
\b  
\c 21  
\q1
\v 1 Padşahın ürəyi Rəbbin əlindədir,  
\q1 Onu su arxı kimi istədiyi səmtə döndərər.   
\b  
\q1
\v 2 İnsanın yolu öz gözündə düz sayılar,  
\q1 Lakin ürəkləri Rəbb yoxlayar.   
\b  
\q1
\v 3 Rəbb Ona qurban təqdimindən çox  
\q1 Salehliyə, ədalətə riayət edilməsini istər.   
\b  
\q1
\v 4 Təkəbbürlü baxış, lovğa ürək  
\q1 Pislərin işığı və günahıdır.   
\b  
\q1
\v 5 Çalışqanın niyyəti xeyir gətirər,  
\q1 Tələsən ehtiyac içinə düşər.   
\b  
\q1
\v 6 Yalançılıqla qazanılan xəzinə  
\q1 Havaya yayılan sis-dumandır, bir ölüm tələsidir.   
\b  
\q1
\v 7 Zorakılığına görə pislər süpürülüb atılacaq,  
\q1 Çünki onlar ədalətə əməl etmək istəmir.   
\b  
\q1
\v 8 Günahkarın yolu dolaşıqdır,  
\q1 Pak insanın etdiyi doğru sayılır.   
\b  
\q1
\v 9 Davakar arvadla bir evdə yaşamaqdansa  
\q1 Damın bir küncündə yaşamaq yaxşıdır.   
\b  
\q1
\v 10 Pis insan şərə can atar,  
\q1 Qonşusu gözündə lütf tapmaz.   
\b  
\q1
\v 11 Rişxəndçini cərimə etsən, cahil bundan hikmət alar,  
\q1 Hikmətli ibrətdən bilik qazanar.   
\b  
\q1
\v 12 Saleh insan pislərin evi barədə düşünər,  
\q1 Çünki pislər alt-üst olub bəlaya düşər.   
\b  
\q1
\v 13 Qulağını tutub kasıbın fəryadını eşitməyənin  
\q1 Fəryadına cavab verilməyəcək.   
\b  
\q1
\v 14 Gizli hədiyyə qəzəbi,  
\q1 Qoltuqdakı rüşvət hiddəti yatırar.   
\b  
\q1
\v 15 Haqq öz yerinə gələndə saleh sevinər,  
\q1 Şər iş görənin başı bəlaya düşər.   
\b  
\q1
\v 16 Kim ki ağlın yolundan çıxar,  
\q1 Ölülər camaatı arasında uyuyar.   
\b  
\q1
\v 17 Zövq-səfaya düşkün olan ehtiyaca düşər,  
\q1 Şərab və yağlı yemək hərisi sərvət tapmaz.   
\b  
\q1
\v 18 Pis insan salehin yerinə,  
\q1 Xain əməlisalehin əvəzinə girov verilər.   
\b  
\q1
\v 19 Davakar, deyingən arvadla yaşamaqdansa  
\q1 Çöllükdə yaşamaq yaxşıdır.   
\b  
\q1
\v 20 Hikmətlinin evində istənilən xəzinə və bolluq var,  
\q1 Axmağın nəyi varsa, yeyib-qurtarar.   
\b  
\q1
\v 21 Salehlik və sədaqətin ardınca gedən  
\q1 Həyat, salehlik və şərəf tapar.   
\b  
\q1
\v 22 Bir hikmətli qəhrəmanların şəhərinə hücum çəkər,  
\q1 Alınmaz qalanı darmadağın edər.   
\b  
\q1
\v 23 Ağzını, dilini tutan insan  
\q1 Canını bəlalardan saxlayar.   
\b  
\q1
\v 24 Lovğa, təkəbbürlü adam rişxəndçi adlanır,  
\q1 Lovğalandıqca lovğalanır.   
\b  
\q1
\v 25 Tənbəlin arzusu onu ölümə aparır,  
\q1 Çünki əlləri zəhmətdən qaçır.   
\q1
\v 26 Tənbəl bütün gün çox şey arzulayar,  
\q1 Salehsə əsirgəmədən azuqə paylayar.   
\b  
\q1
\v 27 Şər adamın etdiyi qurban iyrəncdir,  
\q1 Pis niyyətlə təqdim olunarsa, daha pisdir.   
\b  
\q1
\v 28 Yalançı şahid həlak olar,  
\q1 Söz eşidən həmişə danışdırılar.   
\b  
\q1
\v 29 Şər adam üzünü sərtləşdirər,  
\q1 Əməlisaleh tutduğu yolu möhkəmləndirər.   
\b  
\q1
\v 30 Heç bir hikmət, dərrakə, ibrət  
\q1 Rəbbin qarşısında dayana bilməz.   
\b  
\q1
\v 31 Atlar döyüş günü üçün hazırlanar,  
\q1 Amma zəfəri Rəbb qazandırar.   
\b  
\c 22  
\q1
\v 1 Yaxşı ad böyük sərvətdən,  
\q1 Lütfkarlıq isə qızıl-gümüşdən üstündür.   
\b  
\q1
\v 2 Zəngin və yoxsul insan bir şeydə bir-birinə bənzəyir –  
\q1 Hər ikisini yaradan Rəbdir.   
\b  
\q1
\v 3 Uzaqgörən qabaqcadan şəri görüb ondan qaçar,  
\q1 Cahil isə irəli çıxar, ziyan tapar.   
\b  
\q1
\v 4 İtaətkarlığın və Rəbb qorxusunun nəticəsi  
\q1 Sərvət, şərəf, həyatdır.   
\b  
\q1
\v 5 Əyri yol tikanlıdır, orada tələlər var,  
\q1 Canını qoruyan bundan uzaqlaşar.   
\b  
\q1
\v 6 Uşağa tərbiyə ver ki, layiqli yol tutsun,  
\q1 O qocalanda da bu yoldan dönməz.   
\b  
\q1
\v 7 Zəngin yoxsulun ağası olar,  
\q1 Borclu adam borc verənə qul olar.   
\b  
\q1
\v 8 Haqsızlıq əkən şər biçər,  
\q1 Onun qəzəbinin dəyənəyi məhv edilər.   
\b  
\q1
\v 9 Əliaçıq bərəkət qazanar,  
\q1 Çünki çörəyindən kasıba paylar.   
\b  
\q1
\v 10 Rişxəndçi adamı qovsan, münaqişə qurtarar,  
\q1 Çəkişmə, şərəfsizlik sona çatar.   
\b  
\q1
\v 11 Ürək təmizliyini sevən,  
\q1 Dilindən lütfkar sözlər tökülən padşahın dostudur.   
\b  
\q1
\v 12 Rəbbin gözləri biliyi qoruyar,  
\q1 Xainin sözlərini isə boşa çıxarar.   
\b  
\q1
\v 13 Tənbəl deyər: «Bayırda aslan var,  
\q1 Küçəyə çıxsam, məni parçalar».   
\b  
\q1
\v 14 Əxlaqsız qadının ağzı dərin çuxura oxşar,  
\q1 Rəbbin lənətinə gələn ora yıxılar.   
\b  
\q1
\v 15 Səfehlik uşağın qəlbindən yapışar,  
\q1 Kötəklə tənbeh ediləndə bu ondan uzaqlaşar.   
\b  
\q1
\v 16 Varlanmaq üçün kasıba zülm edən,  
\q1 Zəngin adama verən ehtiyaca düşər.   
\s1 Hikmətlilərin sözləri  
\q1
\v 17 Qulağını aç, hikmətlilərin sözlərini eşit,  
\q1 Ürəyini mənim biliyimə ver.   
\q1
\v 18 Onları sinənə doldursan,  
\q1 Onların hamısını dilinə salsan, yaxşı olar.   
\q1
\v 19 Rəbbə güvənəsən deyə  
\q1 Bu gün bunları sənə bildirirəm.   
\q1
\v 20 Sənə nəsihətlə, biliklə dolu əla məsəllər yazmamışammı?   
\q1
\v 21 Qoy bunlar haqq sözün həqiqətini sənə bildirsinlər ki,  
\q1 Hara səni göndərsələr, düz məlumat gətirəsən.   
\b  
\q1
\v 22 Kasıbı fəqir olduğu üçün soyma,  
\q1 Darvazada məzlumu zülmə salma.   
\q1
\v 23 Çünki onların münaqişəsinə Rəbb baxar,  
\q1 Onları soyanları soyub-talayar.   
\b  
\q1
\v 24 Tez qəzəblənənə yoldaş olma,  
\q1 Kəmhövsələ ilə yola çıxma.   
\q1
\v 25 Yoxsa onun yollarına alışarsan,  
\q1 Canını tələyə salarsan.   
\b  
\q1
\v 26 Başqalarının borclarına zamin durmaqdan,  
\q1 Belə işə əl atmaqdan çəkin.   
\q1
\v 27 Ödəməyə pulun olmasa,  
\q1 Altından yatağını apararlar.   
\b  
\q1
\v 28 Ata-babalarından qalan  
\q1 Qədim sərhəd daşının yerini dəyişmə.   
\b  
\q1
\v 29 İşində mahir olanı görürsənmi?  
\q1 Sıravi adamların deyil, şahların hüzurunda dayanar.   
\b  
\c 23  
\q1
\v 1 Bir ağa ilə süfrəyə əyləşəndə  
\q1 Qarşında olana yaxşı bax.   
\q1
\v 2 İştahan çox olsa da, boğazına sərhəd qoy.   
\q1
\v 3 Onun ləziz xörəklərinə tamah salma,  
\q1 Çünki bu yemək adamı aldadar.   
\b  
\q1
\v 4 Sərvət qazanmaq üçün özünü əldən salma,  
\q1 İdraklı ol, bu fikirdən vaz keç.   
\q1
\v 5 Gözünü sərvətə diksən, yox olar,  
\q1 Birdən qanadlanar, uçub qartal tək göyə qalxar.   
\b  
\q1
\v 6 Xəsisin çörəyini yemə,  
\q1 Onun ləziz xörəklərinə tamah salma.   
\q1
\v 7 O, ürəyində hər şeyin hesabını edər.  
\q1 Dilində sənə «ye, iç» deyər,  
\q1 Amma ürəyi ilə dili bir deyil.   
\q1
\v 8 Yediyin loğmanı qusarsan,  
\q1 Dediyin bütün şirin sözlər boşa çıxar.   
\b  
\q1
\v 9 Axmağın qulağına söz demə,  
\q1 Çünki sənin ağıllı sözlərinə xor baxar.   
\b  
\q1
\v 10 Qədim sərhəd daşının yerini dəyişmə,  
\q1 Yetimlərin əkininə girmə.   
\q1
\v 11 Çünki onların Hamisi qüvvətlidir,  
\q1 Səninlə olan münaqişəyə O baxar.   
\b  
\q1
\v 12 Qəlbini tərbiyəyə,  
\q1 Qulaqlarını bilik sözlərinə ver.   
\b  
\q1
\v 13 Uşağa tərbiyə ver, bundan vaz keçmə,  
\q1 Tərbiyə kötəyi ona ölüm gətirməz.   
\q1
\v 14 Əgər sən onu kötəkləsən,  
\q1 Canını ölülər diyarından xilas edərsən.   
\b  
\q1
\v 15 Oğlum, ürəyin hikmətli olarsa,  
\q1 Mənim də ürəyim sevinər.   
\q1
\v 16 Dilindən düz sözlər çıxarsa,  
\q1 Könlüm sevincdən cuşa gələr.   
\b  
\q1
\v 17 Ürəyin günahkarlara qibtə etməsin,  
\q1 Ancaq bütün gün Rəbb qorxusu ilə yaşa.   
\q1
\v 18 Sənin də bir aqibətin var,  
\q1 Ümidin boşa çıxmaz.   
\b  
\q1
\v 19 Oğlum, dinlə, hikmətli ol,  
\q1 Qəlbini düz yola bağla.   
\q1
\v 20 Şərab düşkünü olan əyyaşlara,  
\q1 Ət qapan qarınqululara qoşulma.   
\q1
\v 21 Çünki əyyaş və qarınqulu yoxsullaşar,  
\q1 Yeyib-içib, məst olan cır-cındır içində qalar.   
\b  
\q1
\v 22 Doğma atana qulaq as,  
\q1 Qoca anana xor baxma.   
\q1
\v 23 Həqiqət al, onu satma,  
\q1 Hikməti, tərbiyəni, idrakı qoruyub-saxla.   
\q1
\v 24 Salehin atası bolluca fərəhlənəcək,  
\q1 Hikmətlinin övladı onu sevindirəcək.   
\q1
\v 25 Qoy ata-anan sevinsin,  
\q1 Səni doğan fərəhlənsin.   
\b  
\q1
\v 26 Oğlum, ürəyini mənə yönəlt,  
\q1 Gözlərin mənim yollarımı nəzərdən keçirsin.   
\q1
\v 27 Fahişə dərin bir çuxurdur,  
\q1 Yad arvad dar quyudur.   
\q1
\v 28 Quldur kimi pusqu qurar,  
\q1 İnsanlar arasında xainləri artırar.   
\b  
\q1
\v 29 Kimdir yaslı?  
\q1 Kimdir dərdli?  
\q1 Kimin münaqişəsi var?  
\q1 Kimin şikayəti var?  
\q1 Kim boş yerə yaralandı?  
\q1 Kimin gözləri qızarar?   
\q1
\v 30 Şərab içməyə oturub qalxmayan,  
\q1 Gedib müxtəlif şərab dadanlar!   
\q1
\v 31 Şərabın al rənginə,  
\q1 Qədəhdə parlamasına, rahat içilməsinə baxma.   
\q1
\v 32 Axırda ilan kimi sancar,  
\q1 Əfi ilan kimi zəhərlər.   
\q1
\v 33 Gözlərinə qəribə şeylər görünər,  
\q1 Qəlbinə əyri fikirlər gələr.   
\q1
\v 34 Özünü dənizin ortasında sanarsan,  
\q1 Sanki gəmi dirəyinin başında yatmısan.   
\q1
\v 35 Deyərsən: «Məni vurublar, hiss etməmişəm,  
\q1 Məni döyüblər, heç bilməmişəm.  
\q1 Yenə içmək üçün nə zaman ayılacağam?»   
\b  
\c 24  
\q1
\v 1 Pis adamlara qibtə etmə,  
\q1 Onlara qoşulmaq istəmə.   
\q1
\v 2 Çünki ürəklərində zalımlığı fikirləşər,  
\q1 Dilləri qəddarlıqdan danışar.   
\b  
\q1
\v 3 Ev hikmətlə tikilər,  
\q1 Dərrakə ilə möhkəmlənər.   
\q1
\v 4 Mənzillər bilik vasitəsilə,  
\q1 Hər cür dəyərli, yaxşı şeylərlə dolar.   
\b  
\q1
\v 5 Hikmətli kişi qüvvətli olar,  
\q1 Bilikli adam öz gücünü artırar.   
\q1
\v 6 Düzgün məsləhətlə müharibə edə bilərsən,  
\q1 Doğru nəsihət verən çoxdursa, qələbəyə çatarsan.   
\b  
\q1
\v 7 Səfeh üçün hikmət əlçatmazdır,  
\q1 Darvazada susub ağzını açmır.   
\b  
\q1
\v 8 Şər quran fitnəkar adlanar,   
\q1
\v 9 Səfehin pis əməlləri günah sayılar,  
\q1 Rişxəndçilər insanlarda ikrah yaradar.   
\b  
\q1
\v 10 Dar gündə taqətdən düşsən,  
\q1 Necə də zəif adamsan!   
\q1
\v 11 Ölümə aparılanları qurtar,  
\q1 Qırğın təhlükəsi altında olanları geri çək.   
\q1
\v 12 Desən ki, bax bundan xəbərim yox idi,  
\q1 Ürəkləri yoxlayan bunu görməzmi?  
\q1 Canını qoruyan bunu bilməzmi?  
\q1 İnsan əməlinə görə Ondan əvəz almazmı?   
\b  
\q1
\v 13 Oğlum, bal ye, xeyri var,  
\q1 Şanı balının şirin dadı damağında qalar.   
\q1
\v 14 Bil ki, hikmət də canın üçün belə olar,  
\q1 Onu tapsan, nəticəsi də var,  
\q1 Ümidin boşa çıxmaz.   
\b  
\q1
\v 15 Ey şər insan, salehin yurdu üçün pusqu qurma,  
\q1 Onun evini soyma.   
\q1
\v 16 Saleh yeddi dəfə yıxılsa belə, yenə qalxar,  
\q1 Şər insan büdrəsə, bəlaya düçar olar.   
\b  
\q1
\v 17 Düşməninin yıxılmasına sevinmə,  
\q1 Onun büdrəməsinə görə ürəyin fərəhlənməsin.   
\q1
\v 18 Yoxsa Rəbb görər, bundan xoşu gəlməz,  
\q1 Düşmənin üzərindən qəzəbini götürər.   
\b  
\q1
\v 19 Pislik edənlərə görə qəzəblənmə,  
\q1 Şər insanlara qibtə etmə,   
\q1
\v 20 Çünki pis insanın axırı yoxdur,  
\q1 Şər adamın çırağı sönər.   
\b  
\q1
\v 21 Oğlum, Rəbdən və padşahdan qorx,  
\q1 Xəyanətkarlarla yoldaş olmaqdan çəkin.   
\q1
\v 22 Onların bəlası qəfildən gəlir.  
\q1 Hər ikisinin verəcəyi cəzanı kim bilir?   
\s1 Hikmətli sözlərin davamı  
\q1
\v 23 Bu sözləri də hikmətlilər deyib:  
\b  
\q1 Məhkəmədə tərəfkeşlik etmək yaxşı deyil.   
\q1
\v 24 Pis insana «sən salehsən» deyəni xalqlar qınayar,  
\q1 Ümmətlər lənət yağdırar.   
\q1
\v 25 Amma onu danlayanlar xeyir tapar,  
\q1 Başlarından bol bərəkət yağar.   
\b  
\q1
\v 26 İnsana doğru cavab verən  
\q1 Sanki onun üzündən öpər.   
\b  
\q1
\v 27 Əvvəlcə çöldəki işini qurtar,  
\q1 Zəmi sal, sonra evini tik.   
\b  
\q1
\v 28 Qonşunun əleyhinə haqsız şahidlik etmə,  
\q1 Qoy dilindən yalan söz çıxmasın.   
\q1
\v 29 Demə: «Mənə etdiyini mən də ona edəcəyəm,  
\q1 Onun əməlinin əvəzini verəcəyəm».   
\b  
\q1
\v 30 Tənbəlin zəmisindən,  
\q1 Qanmazın üzümlüyündən keçdim.   
\q1
\v 31 Gördüm hər yanı tikan basıb,  
\q1 Gicitkən bürüyüb, daşı-divarı uçub.   
\q1
\v 32 Baxaraq ona diqqət yetirdim,  
\q1 Bundan ibrət götürdüm:   
\q1
\v 33  \x * \xo 24:33 \xt Sül. 6:10-11 \x* Bir az da uzanıb yuxuya dalsan,  
\q1 Əl-qolunu uzadaraq yatsan,   
\q1
\v 34 Yoxsulluq üstünə soyğunçu kimi,  
\q1 Ehtiyac üstünə quldur kimi hücum çəkər.   
\c 25  
\s1 Süleymanın məsəllərinin davamı  
\p
\v 1 Bunlar da Süleymanın məsəlləridir. Yəhuda padşahı Xizqiyanın adamları bir yerə yığılıb bunların üzünü köçürtdü.   
\b  
\q1
\v 2 Allahın işlərinin müəmması Onu şərəfləndirər,  
\q1 Bu işləri aşkar etmək padşahlara şərəf gətirər.   
\b  
\q1
\v 3 Göyün yüksəkliyini, yerin dərinliyini,  
\q1 Padşahın da qəlbindən keçənləri bilmək olmaz.   
\b  
\q1
\v 4 Tullantını gümüşdən ayırsan,  
\q1 Zərgərə əl işi qalar.   
\q1
\v 5 Əgər şər adam padşahın yanından ayrılarsa,  
\q1 Taxtı salehliklə möhkəmlənər.   
\b  
\q1
\v 6  \x * \xo 25:6 \xt Luka 14:7-10 \x* Padşahın hüzurunda özünü ucaltma,  
\q1 Rütbəlilərin yanında dayanma.   
\q1
\v 7 Çünki «buyur yuxarı» dəvətini almaq  
\q1 Bir əsilzadə qarşısında aşağı endirilməkdən yaxşıdır.   
\b  
\q1
\v 8 Gördüyün şeylər barədə  
\q1 Dava yaratmağa tələsmə.  
\q1 Sonra qonşun səni utandırsa, nə edərsən?   
\q1
\v 9 Münaqişəni qonşunla özün həll et,  
\q1 Özgənin sirrini açma.   
\q1
\v 10 Yoxsa hər eşidən sənə xor baxar,  
\q1 Bu səni etibardan salar.   
\b  
\q1
\v 11 Yerində deyilən sözlər,  
\q1 Gümüş oymalar içində qızıl almalara bənzər.   
\b  
\q1
\v 12 Sözəbaxan insana hikmətlinin məzəmməti  
\q1 Qızıl sırğa, qızıl bəzək kimidir.   
\b  
\q1
\v 13 Biçin zamanı qar kimi sərinlik necədirsə,  
\q1 Etibarlı elçi də onu göndərən üçün belədir.  
\q1 O, ağasının ruhunu təzələyir.   
\b  
\q1
\v 14 Kim ki vermədiyi bəxşişlərlə öyünür,  
\q1 Yağışsız buluda və küləyə bənzəyir.   
\b  
\q1
\v 15 Səbirlə hökmdarı da inandırmaq olar,  
\q1 Şirin dil sümükləri belə, yumşaldar.   
\b  
\q1
\v 16 Bal tapsan, lazımi qədər ye,  
\q1 Acgözlüklə yesən, qusarsan.   
\q1
\v 17 Qonşunun evinə az-az get,  
\q1 Yoxsa bezər, sənə nifrət edər.   
\b  
\q1
\v 18 Kim ki qonşusuna qarşı yalandan şahidlik edir,  
\q1 Toppuza, qılınca, iti oxa bənzəyir.   
\b  
\q1
\v 19 Dar gündə namərdə bel bağlamaq  
\q1 Çürük dişə, şikəst ayağa güvənməyə bənzəyir.   
\b  
\q1
\v 20 Qəlbi qubarlıya nəğmə söyləmək  
\q1 Soyuq havada lüt qoyulmağa,  
\q1 Soda üstə sirkə tökülməyə bənzəyir.   
\b  
\q1
\v 21  \x * \xo 25:21 \xt Rom. 12:20 \x* Düşmənin acdırsa, onu yedizdir,  
\q1 Susuzdursa, ona su ver.   
\q1
\v 22 Belə etməklə sanki onun başına köz tökərsən,  
\q1 Bunun əvəzini Rəbdən alarsan.   
\b  
\q1
\v 23 Şimal küləyi yağış gətirir,  
\q1 Qeybətçi dil isə insanın üzünə qəzəb gətirir.   
\b  
\q1
\v 24 Davakar arvadla bir evdə yaşamaqdansa  
\q1 Damın bir küncündə yaşamaq yaxşıdır.   
\b  
\q1
\v 25 Susuzluqdan yanana sərin su necədirsə,  
\q1 Uzaq diyardan gələn xoş xəbər də elədir.   
\b  
\q1
\v 26 Əgər saleh insan pis adama təslim olarsa,  
\q1 Bulanan bulağa, murdarlanan quyuya bənzəyir.   
\b  
\q1
\v 27 Qədərindən çox bal yemək xeyirli olmadığı kimi  
\q1 Tərifə uymaq da yaxşı deyil.   
\b  
\q1
\v 28 Nəfsini saxlaya bilməyən  
\q1 Dağılmış, hasarsız şəhərə bənzəyir.   
\b  
\c 26  
\q1
\v 1 Yay fəslinə qar, biçinə yağış yaraşmadığı kimi  
\q1 Axmağa da şərəf yaraşmaz.   
\b  
\q1
\v 2 Sərçənin ora-bura uçduğu kimi,  
\q1 Qaranquşun gəlib-getdiyi kimi  
\q1 Nahaq qarğış da boşdur.   
\b  
\q1
\v 3 Ata qamçı, eşşəyə noxta necə yaraşırsa,  
\q1 Axmağın kürəyinə də kötək elə yaraşır.   
\b  
\q1
\v 4 Axmağa səfehliyinə görə cavab vermə,  
\q1 Yoxsa ona bənzərsən.   
\q1
\v 5 Axmağa səfehliyinə görə elə bir cavab ver ki,  
\q1 Öz gözündə hikmətli görünməsin.   
\b  
\q1
\v 6 Kim ki axmaq vasitəsilə xəbər göndərir,  
\q1 Öz ayaqlarını kəsib ziyan çəkənə bənzəyir.   
\b  
\q1
\v 7 Axmağın ağzından çıxan məsəl  
\q1 Topalın ayağının axsamağına bənzəyir.   
\b  
\q1
\v 8 Axmağı tərifləmək  
\q1 Sapanda qoyulan daşa bənzəyir.   
\b  
\q1
\v 9 Sərxoş tikanlı budağı əlində tutduğu kimi  
\q1 Axmaq da məsəl çəkər.   
\b  
\q1
\v 10 Axmağı, hər yoldan ötəni muzdla tutan  
\q1 Hamını yaralayan naşı oxatan kimidir.   
\b  
\q1
\v 11  \x * \xo 26:11 \xt 2Pet. 2:22 \x* Hansı axmaq öz səfehliyini təkrarlayırsa,  
\q1 Qusduğuna qayıdan itə oxşayır.   
\b  
\q1
\v 12 Öz gözündə hikmətli sayılanı görmüsənmi?  
\q1 Axmağa ondan artıq ümid var.   
\q1
\v 13 Tənbəl deyər: «Yolda aslan var,  
\q1 Şir küçələri dolanır».   
\q1
\v 14 Qapı öz oxu üstündə necə fırlanırsa,  
\q1 Tənbəl də yatağında elə fırlanır.   
\q1
\v 15 Tənbəl əlini qabda olana batırar,  
\q1 Ağzına aparmağa ərinər.   
\q1
\v 16 Tənbəl öz gözündə  
\q1 Ağıllı cavab verən yeddi nəfərdən də çox hikmətli görünər.   
\b  
\q1
\v 17 Ona aid olmayan münaqişəyə qarışan  
\q1 Elə bil küçədəki iti qulaqlarından tutur.   
\b  
\q1
\v 18 Odlu, öldürücü oxlar atan dəli necədirsə,   
\q1
\v 19 Qonşusunu aldadıb «zarafat etdim» deyən də elədir.   
\b  
\q1
\v 20 Odun qurtaranda ocaq sönər,  
\q1 Qeybətçi olmayan yerdə dava bitər.   
\b  
\q1
\v 21 Necə ki kömür köz salar, odun alışar,  
\q1 Davakar adam da münaqişəni bu cür alovlandırar.   
\b  
\q1
\v 22 Qeybətçinin sözləri şirin tikələrə bənzər,  
\q1 Mədənin ən dərin yerlərinə düşər.   
\b  
\q1
\v 23 Hərarətli dili, şər dolu ürəyi olan insan  
\q1 Gümüşü suya çəkilmiş saxsı qaba oxşayır.   
\b  
\q1
\v 24 Düşmən kinini dili altında gizlədər,  
\q1 Qəlbində hiyləsini saxlar.   
\q1
\v 25 Onun mehriban danışığına inanma,  
\q1 Qəlbinə yeddi cür iyrənclik doldurub.   
\q1
\v 26 Nifrətini fırıldaqla gizlətsə də,  
\q1 Şəri camaat qarşısında üzə çıxar.   
\b  
\q1
\v 27 Quyu qazan özü quyuya düşər,  
\q1 Daş isə onu yuvarlayanın üstünə gələr.   
\b  
\q1
\v 28 Yalan danışan dil sancdığı adamlara nifrətini göstərər,  
\q1 Yaltaqlanan ağız hər yanı xarabaya çevirər.   
\b  
\c 27  
\q1
\v 1  \x * \xo 27:1 \xt Yaq. 4:13-14 \x* Sabahkı gününlə öyünmə,  
\q1 Günün nə doğacağını bilməzsən.   
\b  
\q1
\v 2 Qoy səni özün yox, başqaları tərifləsin,  
\q1 Sənə tərifi öz dilin yox, yad söyləsin.   
\b  
\q1
\v 3 Daşın, qumun çəkisi ağırdır,  
\q1 Səfehin əsib-coşması bunların ikisindən də ağırdır.   
\b  
\q1
\v 4 Hiddət amansızdır, qəzəbsə aşıb-daşar,  
\q1 Paxıllıq daha betərdir, ona necə dözmək olar?   
\b  
\q1
\v 5 Aşkar irad gizli məhəbbətdən üstündür.   
\b  
\q1
\v 6 Dostun vurduğu yara onun sədaqətinə görədir,  
\q1 Amma düşmən öpdükcə öpər.   
\b  
\q1
\v 7 Toxun könlü şanı balını belə, rədd edər,  
\q1 Lakin ac olana acı şeylər belə, şirin gələr.   
\b  
\q1
\v 8 Yurdundan ayrı düşən insan  
\q1 Bir quş kimi yuvasından ayrı düşür.   
\b  
\q1
\v 9 Gözəl ətir və buxurun ürəyə verdiyi ləzzət kimi  
\q1 Dostun nəsihəti də insana xoş gələr.   
\b  
\q1
\v 10 Həm öz dostunu, həm də atanın dostunu tərk etmə,  
\q1 Dara düşəndə qardaşının evinə getmə.  
\q1 Yaxın qonşu uzaq qohumdan yaxşıdır.   
\b  
\q1
\v 11 Oğlum, hikmətli ol, qoy qəlbim sevinsin,  
\q1 Onda məni utandırana cavab verə bilərəm.   
\b  
\q1
\v 12 Uzaqgörən qabaqcadan şəri görüb ondan qaçar,  
\q1 Cahil isə irəli çıxar, ziyan tapar.   
\b  
\q1
\v 13 Özgəyə zamin duranın libasını al,  
\q1 Onu qərib qadın üçün girov saxla.   
\b  
\q1
\v 14 Kim ki qonşusunu sübh erkən ucadan salamlar,  
\q1 O zaman salamı söyüş sayılar.   
\b  
\q1
\v 15 Davakar qadın yağışda daman damcıya oxşar.   
\q1
\v 16 Onu yel kimi dayandırmaq olmaz,  
\q1 Zeytun yağı kimi ovucda saxlamaq olmaz.   
\b  
\q1
\v 17 Dəmir dəmiri itilər,  
\q1 İnsan insanın ağlını iti edər.   
\b  
\q1
\v 18 Əncir becərən barını yeyər,  
\q1 Ağasının qayğısına qalan şərəfləndirilər.   
\b  
\q1
\v 19 Sifətin əksi suyun üzünə düşdüyü kimi  
\q1 İnsanın ürəyi də onu elə göstərər.   
\b  
\q1
\v 20 Ölüm və Həlak yeri doymadığı kimi  
\q1 İnsanın da gözü doymaz.   
\b  
\q1
\v 21 İsti kürədə qızıl-gümüş yoxlanar,  
\q1 İnsan da başqalarının tərifi ilə tanınar.   
\b  
\q1
\v 22 Buğdanı həvəngdəstədə döysən, kəpəyi çıxar,  
\q1 Amma səfehi nə qədər döysən, səfehliyi çıxmaz.   
\b  
\q1
\v 23 Sürünə yaxşı bax, naxırına nəzər yetir,   
\q1
\v 24 Nə var-dövlət əbədidir, nə də tac nəsildən-nəslə keçir.   
\q1
\v 25 Saman yığılandan sonra təzə ot bitəndə,  
\q1 Dağlarda ot biçiləndə   
\q1
\v 26 Quzuların səni geyindirər,  
\q1 Təkələrini satıb tarla ala bilərsən.   
\q1
\v 27 Keçilər sənə yemək üçün o qədər süd verər ki,  
\q1 Bu, evin azuqəsinə, kənizlərinin dolanışığına çatar.   
\b  
\c 28  
\q1
\v 1 Şər insan onu qovan yox ikən qaçar,  
\q1 Saleh aslan kimi mərd dayanar.   
\b  
\q1
\v 2 Ölkədə üsyan olanda rəhbərlər artar,  
\q1 Dərrakəli, işbilən adam olsa, ölkəni uzun müddət qoruyar.   
\b  
\q1
\v 3 Bir yoxsul kişi kasıbları incidərsə,  
\q1 Bu, əkini yuyub aparan, qıtlıq yaradan güclü yağışa bənzər.   
\b  
\q1
\v 4 Qanunu pozanlar pisi təriflər,  
\q1 Qanuna əməl edənlər onlara qarşı çıxar.   
\b  
\q1
\v 5 Pis insanlar nə bilir ki, ədalət nədir,  
\q1 Rəbbi axtaranlar bunu dərk edir.   
\b  
\q1
\v 6 Kamalla yaşayan yoxsul insan  
\q1 Əyri yolla sərvət qazanandan yaxşıdır.   
\b  
\q1
\v 7 Qanan oğul qanunu yerinə yetirər,  
\q1 Qarınquluya qoşulan atasına xəcalət çəkdirər.   
\b  
\q1
\v 8 Kim ki müamilə ilə, sələmlə var-dövlət yığar,  
\q1 Onun varı axırda kasıblara səxavət göstərənə qalar.   
\b  
\q1
\v 9 Kim ki qanunu eşitməmək üçün qulaqlarını bağlayır,  
\q1 Onun duaları iyrəncdir.   
\b  
\q1
\v 10 Kim ki əməlisalehləri əyri yola çəkər,  
\q1 Öz qazdığı quyuya düşər,  
\q1 Kamillərə yaxşı şeylər irs qalar.   
\b  
\q1
\v 11 Zəngin özünü hikmətli sanar,  
\q1 Amma müdrik kasıb onun qəlbini oxuyar.   
\b  
\q1
\v 12 Salehlərin zəfəri hamıya şərəf gətirər,  
\q1 Amma pislər hakim olsa, hamı gizlənər.   
\b  
\q1
\v 13 Günahlarını ört-basdır edən uğur qazanmaz,  
\q1 Onu etiraf edərək tərk edən mərhəmət tapar.   
\b  
\q1
\v 14 Həmişə Rəbdən qorxan bəxtiyardır,  
\q1 Ürəyi inadkar bəlaya düşər.   
\b  
\q1
\v 15 Kasıb xalqın üzərində olan pis hökmdar  
\q1 Nərildəyən aslan, hücum edən ayıya oxşar.   
\b  
\q1
\v 16 Dərrakəsiz hökmdar qəddar, zülmkar olar,  
\q1 Haram qazanca nifrət edənin ömrü uzanar.   
\b  
\q1
\v 17 Qantökən qorxub məzara düşənədək qaçar.  
\q1 Qoy heç kim ona kömək etməsin.   
\b  
\q1
\v 18 Kamillik yolu ilə gedən qurtular,  
\q1 Əyri yolda olanlar qəflətən yıxılar.   
\b  
\q1
\v 19 Torpağını əkib-becərən doyunca çörək yeyər,  
\q1 Boş şeylərin ardınca gedən müflisləşər.   
\b  
\q1
\v 20 Etibarlı insanın bərəkəti boldur,  
\q1 Tez varlanmaq istəyən cəzasız qalmır.   
\b  
\q1
\v 21 Tərəfkeşlik yaxşı deyil,  
\q1 Kişi bir loğma çörək üçün günah işlədə bilər.   
\b  
\q1
\v 22 Xəsis var-dövlət ardınca düşər,  
\q1 Bilmədən yoxsulluğa yetişər.   
\b  
\q1
\v 23 Kim ki başqasını danlayır,  
\q1 Yağlı dilə tutandan çox axırda o, lütf qazanır.   
\b  
\q1
\v 24 Ata-anasını soyub «günah deyildir» deyən  
\q1 Qırıcı insana yoldaşdır.   
\b  
\q1
\v 25 Tamahkar dava yaradar,  
\q1 Rəbbə güvənən bolluğa çatar.   
\b  
\q1
\v 26 Öz ağlına güvənən axmaqdır,  
\q1 Hikmətlə gəzib-dolaşan azad olur.   
\b  
\q1
\v 27 Yoxsula əl tutan möhtac qalmır,  
\q1 Ona məhəl qoymayan lənət qazanır.   
\b  
\q1
\v 28 Pislər hakim olsa, hamı gizlənər,  
\q1 Onlar yox olanda salehlər çoxalar.   
\b  
\c 29  
\q1
\v 1 Məzəmmətlərə baxmayıb dikbaşlıq edən  
\q1 Birdən yıxılıb çarəsiz qalar.   
\b  
\q1
\v 2 Salehlər artanda xalq sevinər,  
\q1 Pis hökmdar olanda xalq nalə çəkər.   
\b  
\q1
\v 3 Hikmət sevən atasını sevindirər,  
\q1 Fahişələrə aşna olanın əlindən var-yoxu gedər.   
\b  
\q1
\v 4 Padşah ölkəni ədalətlə möhkəmləndirər,  
\q1 Ağır vergilər qoyansa ölkəni süqut etdirər.   
\b  
\q1
\v 5 Bir kişi ki qonşusunu yağlı dilə tutur,  
\q1 Onun addımları üçün tor qurur.   
\b  
\q1
\v 6 Pisin günahı özünə tələdir,  
\q1 Saleh sevincindən haray çəkir.   
\b  
\q1
\v 7 Saleh kasıbların haqqını görür,  
\q1 Pis adam bunu dərk etmir.   
\b  
\q1
\v 8 Rişxəndçilər şəhəri çaxnaşdırar,  
\q1 Hikmətlilər isə qəzəbi yatırar.   
\b  
\q1
\v 9 Hikmətli səfehi məhkəməyə versə,  
\q1 Səfeh coşub lağ edər, dinclik gedər.   
\b  
\q1
\v 10 Qana susayanlar kamil insana nifrət edər,  
\q1 Əməlisalehlər can qurtarar.   
\b  
\q1
\v 11 Axmaq həddini aşıb özündən çıxar,  
\q1 Hikmətli səbirli dayanar.   
\b  
\q1
\v 12 Hökmdar yalan sözə qulaq asarsa,  
\q1 Bütün xidmətçiləri şər insana çevrilər.   
\b  
\q1
\v 13 Yoxsul insan və zalım bir-birinə bir şeydə bənzəyir:  
\q1 Hər ikisinin gözlərini işıqlandıran Rəbdir.   
\b  
\q1
\v 14 Padşah kasıblara həqiqətlə hökm versə,  
\q1 Taxtı əbədi möhkəmlənər.   
\b  
\q1
\v 15 Kötək və məzəmmət hikmət gətirər,  
\q1 Özbaşına qalan uşaq anasını rüsvay edər.   
\b  
\q1
\v 16 Pislər çoxalanda cinayət artar,  
\q1 Salehlər görəcək ki, onlar necə yıxılacaqlar.   
\b  
\q1
\v 17 Oğluna tərbiyə ver ki, canın dinc olsun,  
\q1 Könlün bundan ləzzət alsın.   
\b  
\q1
\v 18 İlahi söz nazil olmayanda xalqda hərc-mərclik olar.  
\q1 Qanuna əməl edən nə bəxtiyardır!   
\b  
\q1
\v 19 Qula sözlə tərbiyə vermək olmaz,  
\q1 Çünki başa düşsə belə, qulaq asmaz.   
\b  
\q1
\v 20 Düşünmədən danışana baxmısanmı?  
\q1 Axmağa ondan artıq ümid var.   
\b  
\q1
\v 21 Kim ərköyün qul böyütsə,  
\q1 Axırda bu ona dərd verər.   
\b  
\q1
\v 22 Qəzəbli insan dava yaradar,  
\q1 Kəmhövsələ günahı artırar.   
\b  
\q1
\v 23 İnsanı təkəbbürü alçaldar,  
\q1 İtaətkar şərəfə çatar.   
\b  
\q1
\v 24 Oğruya qoşulan öz-özünə düşməndir,  
\q1 And içsə də, məhkəmədə həqiqəti söyləməz.   
\b  
\q1
\v 25 İnsandan qorxan özünü tələyə salar,  
\q1 Amma Rəbbə güvənən arxayın yaşar.   
\b  
\q1
\v 26 Çoxu hökmdarın hüzurunu arzular,  
\q1 Amma insan ədaləti Rəbdə tapar.   
\b  
\q1
\v 27 Salehlər haqsızlardan,  
\q1 Pis insanlarsa əməlisalehlərdən ikrah edər.   
\c 30  
\s1 Aqurun müdrik məsəlləri  
\p
\v 1 Yaqe oğlu Aqurun sözləri, onun kəlamı.  
\q1 Bu adam Yetielə, Yetiel və Ukala belə dedi: \f + \fr 30:1 \fq Bu adam Yetielə, Yetiel və Ukala belə dedi \ft – yaxud \fq ey Allah, yorulmuşam, yorulub taqətdən düşmüşəm.\f*   
\b  
\q1
\v 2 Həqiqətən, mən hamıdan ağılsızam,  
\q1 İnsan idrakına malik deyiləm.   
\q1
\v 3 Nə hikmət öyrənmişəm,  
\q1 Nə də Müqəddəsin biliyindən xəbərim var.   
\q1
\v 4 Kim göylərə qalxıb endi?  
\q1 Kim yeli ovcunda topladı?  
\q1 Kim suları paltarına sarıdı?  
\q1 Yer üzünün qurtaracağınadək hər yeri kim yaratdı?  
\q1 Adı nədir? Oğlunun adı nədir?  
\q1 Bilirsənmi?   
\b  
\q1
\v 5 Allahın hər bir kəlamı safdır,  
\q1 Ona pənah gətirənlərin sipəri Odur.   
\q1
\v 6 Onun sözünə heç nəyi əlavə etmə,  
\q1 Yoxsa səni tənbeh edər, yalanını çıxarar.   
\b  
\q1
\v 7 Ey Allah, Səndən iki şey istəyirəm,  
\q1 Nə qədər ömrüm var, məndən onları əsirgəmə:   
\q1
\v 8 Saxta, yalan sözlər qoy məndən uzaq olsun;  
\q1 Məni nə yoxsul, nə də zəngin et,  
\q1 Ancaq mənə gündəlik çörəyimi ver.   
\q1
\v 9 Varlansam, «Rəbb kimdir?» deyə Sənə küfr edərəm,  
\q1 Yoxsul olsam, oğurlaram və Allahımın adını ləkələrəm.   
\b  
\q1
\v 10 Qul barədə ağasına pis sözlər demə,  
\q1 Yoxsa sənə qarğış edər, bu təqsirlə yüklənərsən.   
\b  
\q1
\v 11 Adam var ki, atasına qarğış edir,  
\q1 Anasına alqış etmir.   
\q1
\v 12 Adam var ki, özünü təmiz sanır,  
\q1 Amma murdarlıqdan təmizlənməyib.   
\q1
\v 13 Adam var ki, yuxarıdan aşağı baxar,  
\q1 Təkəbbürlə baxmaq üçün gözlərini qaldırar.   
\q1
\v 14 Adam var ki, dişləri qılınca bənzər,  
\q1 Elə bil çənəsinə bıçaqlar düzüb,  
\q1 Yer üzündən məzlumları udar,  
\q1 İnsanların içindən fəqirləri məhv edər.   
\b  
\q1
\v 15 Zəlinin iki qızı var,  
\q1 «Ver, ver» deyib bağırar.  
\b  
\q1 Üç şey var ki, heç doymaz,  
\q1 Dörd şey var ki, «bəsdir» deməz:   
\q1
\v 16 Ölülər diyarı, qısır bətn,  
\q1 Sudan doymayan torpaq,  
\q1 «Bəsdir» deməyən alov.   
\b  
\q1
\v 17 Kim ki atasına rişxənd edir,  
\q1 Anasının sözünə xor baxır,  
\q1 Dərələrdəki qarğalar onun gözlərini deşəcək,  
\q1 Qartal balaları onun bəbəklərini yeyəcək.   
\b  
\q1
\v 18 Mənim ağlım kəsməyən üç şey var,  
\q1 Anlamadığım dörd şey var:   
\q1
\v 19 Səmada qartalın yolu,  
\q1 Qayada ilanın yolu,  
\q1 Dənizdə gəminin yolu,  
\q1 Kişi ilə gənc qadının yolu.   
\q1
\v 20 Zinakar qadının da yolu belədir:  
\q1 Yeyər, ağzını silər,  
\q1 «Nə pis iş görmüşəm ki?» deyər.   
\b  
\q1
\v 21 Yer üç şeydən lərzəyə gəlir,  
\q1 Dörd şey var ki, ona tab gətirmir:   
\q1
\v 22 Qulun padşah olması,  
\q1 Sarsağın doyunca çörək tapması,   
\q1
\v 23 Nifrətəlayiq qadının ərə getməsi,  
\q1 Qarabaşın öz xanımının yerinə keçməsi.   
\b  
\q1
\v 24 Yer üzündə dörd şey var,  
\q1 Kiçik olsa da, hikməti çoxdur:   
\q1
\v 25 Qarışqalar qüvvətli olmayan birlikdir,  
\q1 Yemini yayda tədarük edir;   
\q1
\v 26 Qayadovşanları \f + \fr 30:26 \fq Qayadovşanı \ft – ibrani dilində \+tl şafan\+tl* adlanan məməli heyvan.\f* da güclü olmayan birlikdir,  
\q1 Evlərini qaya içində tikir;   
\q1
\v 27 Çəyirtkələrin şahı yoxdur,  
\q1 Lakin hamısı dəstə-dəstə irəliləyir;   
\q1
\v 28 Kərtənkələni əllə tutmaq olur,  
\q1 Amma o, padşah saraylarına çıxır.   
\b  
\q1
\v 29 Üç məxluq var ki, yerişi gözəldir,  
\q1 Dörd məxluq var ki, gedişi gözəldir:   
\q1
\v 30 Heyvanların ən güclüsü,  
\q1 Heç nəyin qarşısından geri dönməyən şir,   
\q1
\v 31 Döyüşkən xoruz, təkə,  
\q1 Qoşun qabağına çıxan padşah.   
\b  
\q1
\v 32 Əgər özünü ucaltmaqla sarsaqlıq etmisənsə,  
\q1 Fikrində pis niyyətin varsa, əlinlə ağzını tut.   
\q1
\v 33 Çünki südü çalxalayanda yağ çıxdığı kimi,  
\q1 Burnu sıxanda qan çıxdığı kimi  
\q1 Qəzəbi qızışdıranda da dava yaranar.   
\c 31  
\s1 Lemuel padşahın anasının sözləri  
\p
\v 1 Lemuel padşahın sözləri, anasının ona öyrətdiyi kəlam.   
\b  
\q1
\v 2 Nə deyim, oğlum, ey doğduğum oğul,  
\q1 Nəzir-niyazla əldə etdiyim oğul?   
\q1
\v 3 Gücünü qadınlara,  
\q1 Yollarını padşahları məhvə aparanlara sərf etmə.   
\b  
\q1
\v 4 Ey Lemuel, şərab içmək padşahlara yaraşmaz,  
\q1 Kefləndirici içkiyə aludə olmaq hökmdarlara yaraşmaz.   
\q1
\v 5 İçəndə qayda-qanunu unudarlar,  
\q1 Bütün məzlumların haqqını pozarlar.   
\q1
\v 6 Kefləndirici içkini düşkünə,  
\q1 Şərabı dərdliyə verin.   
\q1
\v 7 Qoy içib yoxsulluğunu unutsun,  
\q1 Öz dərdini daha yada salmasın.   
\b  
\q1
\v 8 Dilsizə görə ağız aç,  
\q1 Bütün möhtacların haqqını qoru.   
\q1
\v 9 Ağzını aç, ədalətlə hökm ver,  
\q1 Məzlumların, fəqirlərin haqqını yerinə yetir.   
\s1 Xeyirxah arvad  
\q1
\v 10 Xeyirxah arvad tapan kimdir? \f + \fr 31:10 \ft Bu ayələr akrostix şəkildə yazılıb, yəni ayələr ibrani əlifbasının sırası ilə başlayır.\f*  
\q1 O, yaqutlardan daha qiymətlidir.   
\q1
\v 11 Ərinin qəlbi ondan arxayındır,  
\q1 Dayanmadan bərəkət qazanır.   
\q1
\v 12 Ömrü boyu ərinə pislik deyil, yaxşılıq gətirir,   
\q1
\v 13 Yunu, kətanı tapıb seçir,  
\q1 Əlindən hər iş zövqlə gəlir.   
\q1
\v 14 Ticarət gəmilərinə bənzəyir,  
\q1 Uzaqlardan gələn ruzini gətirir.   
\q1
\v 15 Alaqaranlıqda yuxudan durur,  
\q1 Ailəsinə yemək hazırlayır,  
\q1 Kənizlərinə də paylayır.   
\q1
\v 16 Tarlaya baxandan sonra satın alır,  
\q1 Əlinin zəhməti ilə bağ salır.   
\q1
\v 17 Belini möhkəm bağlayır,  
\q1 Qolları güc üstündən güc alır.   
\q1
\v 18 Ticarətin şirinliyindən dadır,  
\q1 Bütün gecə boyu çırağı yanır.   
\q1
\v 19 Əlləri ilə cəhrə əyirir,  
\q1 İyini \f + \fr 31:19 \fq İy \ft – cəhrənin sap dolanan düz çubuğu.\f* bərkidir.   
\q1
\v 20 Məzlumlar üçün əliaçıqdır,  
\q1 Fəqirlərə əl tutur.   
\q1
\v 21 Qar yağanda ailəsi üçün qayğısı olmaz,  
\q1 Çünki hamısı qırmızı paltar geyinib.   
\q1
\v 22 Yorğan-döşək üçün örtük toxuyur,  
\q1 Öz libası tünd qırmızı incə kətandandır.   
\q1
\v 23 Əri şəhər darvazalarında yaxşı tanınır,  
\q1 El ağsaqqalları ilə oturub-durur.   
\q1
\v 24 Qadın tacirlərə qurşaqları,  
\q1 Toxuduğu kətan paltarları satır.   
\q1
\v 25 Qüvvəyə, şərəfə bürünür,  
\q1 Gələcək üzünə gülür.   
\q1
\v 26 Ağzını açanda hikmət axır,  
\q1 Dilindən sədaqət təlimi çıxır.   
\q1
\v 27 Ailəsinin işini idarə edir,  
\q1 Tənbələ layiq olan çörəyi yemir.   
\q1
\v 28 Övladları ayağa qalxıb onu alqışlayır,  
\q1 Əri onu tərifləyir:   
\q1
\v 29 «Xeyirxah qadınlar çoxdur,  
\q1 Amma sənin tayın yoxdur».   
\q1
\v 30 Qadının məlahəti aldadıcı, gözəlliyi fanidir,  
\q1 Yalnız Rəbdən qorxan qadın tərifə layiqdir.   
\q1
\v 31 Ona əlinin bəhrəsini verin,  
\q1 Qoy şəhər darvazasında əməlləri ona tərif gətirsin.   