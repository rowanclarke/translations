\id NUM
\h Di Řexřa
\toc1 Di Řexřa
\toc2 Di Řexřa
\toc3 Řxř.
\mt1 Di Řexřa
\c 1
\s1 Lɛadad n řɛeskar n Israil
\m 
\v 1 Issiweř SIDI ak-d Musa di řexřa n Sina, deg Uqiḍun n Umsagar, deg \add wass\add* amezwaru n uyur wiss tnayen, deg useggʷas wiss tnayen awarni řami dd-ffɣen zi temmurt n Miṣra, inna:
\m 
\v 2 “Ksim řqedd n ismawen n marra iryazen n marra tamesmunt n ayt n Israil, azeǧif azeǧif, \add am ttwasettfen nitni\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen. \x ◘ \xo 1:2 \xt Uf. 30:12\x*
\v 3 Ittxeṣṣa cek d Harun ad tḥesbem kuř ijj di Israil zi ɛicrin n iseggʷusa sennej, \add marra\add* inni dd-iffɣen ak-d řɛeskar, ɛlaḥsab \add tirbiɛin n\add* řɛeskar nsen.
\v 4 Ad awem iwc afus ijj n weryaz zi \add kuř\add* taqbič, aryaz i iǧan d azeǧif n taddart n babas.
\v 5 Aqa d ina d ismawen n yeryazen nni d awem ɣa iwcen afus:
\m I Rubin, Iliṣur mmis n Cadayur,
\m 
\v 6 i Cimɛun, Calumiyil, mmis n Ṣuriycadday,
\m 
\v 7 i Yahuda, Naḥcun, mmis n Ɛamminadab,
\m 
\v 8 i Issakar, Natanayil, mmis n Ṣuɣar.
\m 
\v 9 i Zabulun, Iliyab, mmis n Ḥilun,
\m 
\v 10 i ayt n Yusuf:
\m i Ifrayim, Ilicamaɛ, mmis n Ammihud,
\m i Manassa, Jamliyil, mmis n Fadahṣur,
\m 
\v 11 i Binyamin, Abidan mmis n Jidɛuni,
\m 
\v 12 i Dan, Axiɛazar, mmis n Ɛammicadday,
\m 
\v 13 i Acir, Fajɛiyil, mmis n Ɛukran,
\m 
\v 14 i Jad, Iliyasaf, mmis n Daɛuyil,
\m 
\v 15 i Naftali, Axiraɛ, mmis n Ɛinan.”
\m 
\v 16 Ina tuɣa d inni ittwařaɣan zi tmesmunt, \add nitni\add* d řḥukkam n tqebbař n ibabaten nsen, izeǧifen x řuřuf n Israil.
\v 17 Ksin Musa d Harun iryazen nni tuɣa ittwarecmen s ismawen nsen
\v 18 uca ssmunen tamesmunt marra deg wass amezwaru n uyur wiss tnayen uca nitni xebbaren jjdira nsen, ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen, am ttwazemmemen ismawen n yinni ɣar iǧa ɛicrin n iseggʷusa sennej, azeǧif azeǧif.
\b
\m 
\v 19 Am mammec d as yumur SIDI i Musa, aqa iḥseb i-ten di řexřa n Sina.
\b
\m 
\v 20 \bd Ayt n Rubin\bd*, amenzu n Israil: tarwa nsen - \add ttwasettfen\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen - inni zzayes ittwaḥesben ɛlaḥsab ismawen \add nsen\add* azeǧif azeǧif, kuř aryaz zi ɛicrin iseggʷusa sennej, marra wenni i ɣa iffɣen ak-d řɛeskar,
\v 21 \add wah,\add* inni ittwaḥesben \add ammu\add* i teqbič n Rubin, tuɣa aten di setta u-rebɛin-ařef u-xemsa mya.
\m 
\v 22 \bd Ayt n Cimɛun:\bd* tarwa nsen - \add ttwasettfen\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen - inni zzayes ittwaḥesben ɛlaḥsab lɛadad n ismawen \add nsen\add*, azeǧif azeǧif, kuř aryaz zi ɛicrin iseggʷusa sennej, marra wenni i ɣa iffɣen ak-d řɛeskar,
\v 23 \add wah,\add* inni ittwaḥesben \add ammu\add* i teqbič n Cimɛun tuɣa aten di tesɛa u-xemsin-ařef u-teřt-mya.
\m 
\v 24 \bd Ayt n Jad:\bd* tarwa nsen - \add ttwasettfen\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen - inni zzayes ittwaḥesben ɛlaḥsab ismawen n \add marra iryazen\add* zi ɛicrin iseggʷusa sennej, marra wenni i ɣa iffɣen ak-d řɛeskar,
\v 25 \add wah,\add* inni ittwaḥesben \add ammu\add* i teqbič n Jad tuɣa aten di xemsa u-rebɛin-ařef u-setta-mya u-xemsin.
\m 
\v 26 \bd Ayt n Yahuda:\bd* tarwa nsen - \add ttwasettfen\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen - inni zzayes ittwaḥesben ɛlaḥsab ismawen n \add marra iryazen\add* zi ɛicrin iseggʷusa sennej, kuř ijjen i dd-itteffɣen ak-d řɛeskar,
\v 27 \add wah,\add* inni ittwaḥesben \add ammu\add* i teqbič n Yahuda tuɣa aten di arebɛa u-sebɛin-ařef u-setta-mya.
\m 
\v 28 \bd Ayt n Issakar:\bd* tarwa nsen - \add ttwasettfen\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen - inni zzayes ittwaḥesben ɛlaḥṣab ismawen n \add marra iryazen\add* zi ɛicrin iseggʷusa sennej, marra wenni i ɣa iffɣen ak-d řɛeskar,
\v 29 \add wah,\add* inni ittwaḥesben \add ammu\add* i teqbič n Issakar tuɣa aten di arebɛa u-xemsin-ařef u-arebɛa-mya.
\m 
\v 30 \bd Ayt n Zabulun:\bd* tarwa nsen - \add ttwasettfen\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen - inni zzayes ittwaḥesben ɛlaḥsab ismawen n \add marra iryazen\add* zi ɛicrin iseggʷusa sennej, marra wenni i ɣa iffɣen ak-d řɛeskar,
\v 31 \add wah,\add* inni ittwaḥesben \add ammu\add* i teqbič n Zabulun tuɣa aten di sebɛa u-xemsin-ařef u-arebɛa-mya.
\m 
\v 32 \bd Ayt n Yusuf:\bd*
\m \bd Ayt n Ifrayim:\bd* tarwa nsen - \add ttwasettfen\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen, inni zzayes ittwaḥesben ɛlaḥsab ismawen n \add marra iryazen\add* zi ɛicrin iseggʷusa sennej, marra wenni i ɣa iffɣen ak-d řɛeskar,
\v 33 \add wah,\add* inni ittwaḥesben \add ammu\add* i teqbič n Ifrayim tuɣa aten di arebɛin-ařef u-xemsa-mya.
\m 
\v 34 \bd Ayt n Manassa:\bd* tarwa nsen - \add ttwasettfen\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen, inni zzayes ittwaḥesben ɛlaḥsab ismawen n \add marra iryazen\add* zi ɛicrin iseggʷusa sennej, marra wenni i ɣa iffɣen ak-d řɛeskar,
\v 35 \add wah,\add* inni ittwaḥesben \add ammu\add* i teqbič n Manassa tuɣa aten di tnayen u-třatin-ařef u-mitayen.
\m 
\v 36 \bd Ayt n Binyamin:\bd* tarwa nsen - \add ttwasettfen\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen, inni zzayes ittwaḥesben ɛlaḥsab ismawen n \add marra iryazen\add* zi ɛicrin iseggʷusa sennej, marra wenni i ɣa iffɣen ak-d řɛeskar,
\v 37 \add wah,\add* inni ittwaḥesben \add ammu\add* i teqbič n Binyamin tuɣa aten di xemsa u-třatin-ařef u-arebɛa-mya.
\m 
\v 38 \bd Ayt n Dan:\bd* tarwa nsen - \add ttwasettfen\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen, inni zzayes ittwaḥesben ɛlaḥsab ismawen n \add marra iryazen\add* zi ɛicrin iseggʷusa sennej, marra wenni i ɣa iffɣen ak-d řɛeskar,
\v 39 \add wah,\add* inni ittwaḥesben \add ammu\add* i teqbič n Dan tuɣa ten di tnayen u-settin-ařef u-sebɛa-mya.
\m 
\v 40 \bd Ayt n Acir:\bd* tarwa nsen - \add ttwasettfen\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen, inni zzayes ittwaḥesben ɛlaḥsab ismawen n \add marra iryazen\add* zi ɛicrin iseggʷusa sennej, marra wenni i ɣa iffɣen ak-d řɛeskar,
\v 41 \add wah,\add* inni ittwaḥesben \add ammu\add* i teqbič n Acir tuɣa ten di waḥit u-rebɛin-ařef u-xemsa-mya.
\m 
\v 42 \bd Ayt n Naftali:\bd* tarwa nsen - \add ttwasettfen\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen, inni zzayes ittwaḥesben ɛlaḥsab ismawen n \add marra iryazen\add* zi ɛicrin iseggʷusa sennej, marra wenni i ɣa iffɣen ak-d řɛeskar,
\v 43 \add wah,\add* inni ittwaḥesben \add ammu\add* i teqbič n Naftali tuɣa aten di třata u-xemsin-ařef u-arebɛa-mya.
\m 
\v 44 Ina d inni ittwaḥesben, inni ttwaḥesben s \add ufus\add* n Musa d Harun d řḥukkam n Israil, tenɛac n yeryazen, ijjen weryaz i taddart n babas. \f ◼ \fr 1:44 \fk taddart n babas\ft - ixs ad yini ‘raǧ i dd-itteffɣen zeg ict n tbabat ak-d twacunin i dayes d jjiřat nnes’.\f*
\v 45 \bd Marra inni ittwaḥesben zeg ayt n Israil\bd* - \add am ttwasettfen nitni\add* ɛlaḥsab taddart n ibabaten nsen - marra inni ɣar iǧa ɛicrin n iseggʷusa sennej, kuř ijj wenni dd-itteffɣen ak-d řɛeskar,
\v 46 \add wah,\add* marra inni ittwaḥesben tuɣa aten di setta-mya u-ṭeřt-ařaf u-xemsa-mya u-xemsin. \x ◘ \xo 1:46 \xt Uf. 38:26\x*
\m 
\v 47 \bd Ilawiyyen\bd* war carcen ca jar asen di řeḥsab di ṭṭweɛ n teqbič n ibabaten nsen,
\v 48 minzi SIDI tuɣa issiweř ak-d Musa, inna:
\v 49 “Mɣir taqbič n Lawi war tt ttᵉḥseb ca u war tt zemmi ca \add azeǧif\add* azeǧif jar ayt n Israil.
\v 50 \add Maca\add* ittxeṣṣa cek s yixef nnec, ad tegged Ilawiyyen x Tzeddiɣt n Cchadet u x marra řeqcuɛ nnes u x marra min d as dd-yusin. Nitni ad arbun Tazeddiɣt ak-d řeqcuɛ nnes marra, uca ad dayes sexxaren. Ittxeṣṣa ad wten iqiḍan nsen min dd-innḍen i Tzeddiɣt.
\v 51 Mařa ad tᵉttwafsi Tzeddiɣt, ad tt hedmen Ilawiyyen uca mařa tiweḍ Tzeddiɣt ɣar řmargeh \add aneḍfar\add*, \add xenni\add* ad tt ssbedden Ilawiyyen \add ɛawed\add*. Mařa dd-iqarreb ca n ubarrani, xenni netta ad ittwaneɣ.
\v 52 Ayt n Israil ad wten iqiḍan n řmargeḥ nsen, kuř ijj ɣar tɛeǧant nnes, \add am ttwasettfen nitni\add* ɛlaḥsab \add tirbiɛin n\add* řɛeskar nsen.
\v 53 Ilawiyyen ad wten iqiḍan nsen ɣar kuř jjihet n Tzeddiɣt n Cchadet, ḥima war ittiři uduqqez \add n weɣḍab\add* x tmesmunt n ayt n Israil. Ittxeṣṣa i Ilawiyyen ad ḥḍan x Tzeddiɣt n Cchadet.”
\m 
\v 54 Uca ggin ayt n Israil s marra min yumur SIDI i Musa, \add wah,\add* ammu \add i-t\add* ggin.
\b
\b
\c 2
\s1 Asettef n tqebbař
\m 
\v 1 Issiweř SIDI ak-d Musa d Harun, inna:
\m 
\v 2 “Ayt n Israil ad wten iqiḍan nsen kuř ijj ɣar tɛeǧant nnes, ɣar řeɛřamat n taddart n ibabaten nsen. Ad wten iqiḍan nsen cwayt ɣar řaggʷaj ɣar marra iɣezdisen n Uqiḍun n Umsagar.”
\m 
\v 3 Inni iǧan sadu n tɛeǧant n \bd řmargeḥ n řɛeskar n Yahuda\bd* ad wten iqiḍan nsen, \add am ttwasettfen nitni\add* ɛlaḥsab \add tirbiɛin n\add* řɛeskar nsen \bd ɣar ccarq\bd*, ɣar manis dd-tneqqar tfuct. Naḥcun, mmis n Ɛamminadab, \add ad yiři\add* d řḥakem n ayt n Yahuda.
\v 4 Inni ittwaḥesben i řɛeskar nnes, tuɣa aten di arebɛa u-sebɛin-ařef u-setta-mya.
\m 
\v 5 Zzates ad tewwet \bd teqbič n Issakar\bd* iqiḍan nnes. Natanayil, mmis n Ṣuɣar, \add ad yiři\add* d řḥakem n ayt n Issakar.
\v 6 Inni ittwaḥesben i řɛeskar nnes, tuɣa aten di arebɛa u-xemsin-ařef u-arebɛa-mya.
\m 
\v 7 \add Xenni\add* \bd taqbič n Zabulun\bd*. Iliyab, mmis n Hilun, \add ad yiři\add* d řḥakem n ayt n Zabulun.
\v 8 Inni ittwaḥesben i řɛeskar nnes, tuɣa aten di sebɛa u-xemsin-ařef u-arebɛa-mya.
\m 
\v 9 Inni ittwaḥesben i řmargeḥ n řɛeskar n Yahuda tuɣa aten marra \add jmiɛ\add* di mya u-setta u-tmanin-ařef u-arebɛa-mya \add n yeryazen\add*, \add ttwasettfen\add* ɛlaḥsab \add tirbiɛin n\add* řɛeskar nsen. Nitni ad fesyen iqiḍan nsen amezwaru.
\b
\m 
\v 10 \bd Ɣar ljanub\bd* ad tiři tɛeǧant n \bd řmargeḥ n řɛeskar n Rubin\bd*. \add Nitni ad iřin ttwasettfen\add* ɛlaḥsab \add tirbiɛin n\add* řɛeskar nsen. Iliṣur, mmis n Cadayyur, \add ad yiři\add* d řḥakem n ayt n Rubin. \f ◼ \fr 2:10 \fk ɣar uẓeřmaḍ\ft - niɣ ‘ɣar ljanub’.\f*
\v 11 Inni ittwaḥesben i řɛeskar nnes, tuɣa aten di setta u-rebɛin-ařef u-xemsa-mya.
\m 
\v 12 Zzates ad tewwet \bd teqbič n Cimɛun\bd* iqiḍan nnes. Calumiyil, mmis n Ṣuriycadday, \add ad yiři\add* d řḥakem n ayt n Cimɛun.
\v 13 Inni ittwaḥesben i řɛeskar nnes, tuɣa aten di tesɛa u-xemsin-ařef u-teřt-mya.
\m 
\v 14 \add Xenni\add* \bd taqbič n Jad\bd*. Ilyasaf, mmis n Raɛuyil, \add ad yiři\add* d řḥakem n ayt n Jad.
\v 15 Inni ittwaḥesben i řɛeskar nnes, tuɣa aten di xemsa u-rebɛin-ařef u-setta-mya u-xemsin.
\m 
\v 16 Inni ittwaḥesben i řmargeḥ n řɛeskar n Rubin, tuɣa aten marra di mya u-waḥit u-xemsin-ařef u-arebɛa-mya u-xemsin \add n yeryazen\add*, \add ttwasettfen\add* ɛlaḥsab \add tirbiɛin n\add* řɛeskar nsen. Nitni ad fesyen iqiḍan nsen wiss tnayen.
\b
\m 
\v 17 \add Xenni\add* ad ittwafsi \bd Uqiḍun n Umsagar \bdit ak-d\bdit* řmargeḥ n Ilawiyyen, di řwesṭ n \bdit marra\bdit* řɛeskar\bd*. Am mammec ɣa wten iqiḍan nsen, ammu ittxeṣṣa ad mmuṭṭiyen \add ɛawed\add*, kuř ijj deg wemcan nnes, \add am ttwasettfen nitni\add* ɛlaḥsab tiɛeǧanin nsen.
\b
\m 
\v 18 \bd Ɣar řɣarb\bd* ad tiři tɛeǧant n \bd řmargeḥ n řɛeskar n Ifrayim\bd*. \add Nitni ad iřin ttwasettfen\add* ɛlaḥsab \add tirbiɛin n\add* řɛeskar nsen. Ilicamaɛ, mmis n Ɛammihud, \add ad yiři\add* d řḥakem n ayt n Ifrayim.
\v 19 Inni ittwaḥesben i řɛeskar nnes, tuɣa aten di arebɛin-ařef u-xemsa-mya.
\m 
\v 20 Zzates \add ad tiři\add* \bd teqbič n Manassa\bd*. Jamliyil, mmis n Fadahṣur \add ad yiři\add* d řḥakem n ayt n Manassa.
\v 21 Inni ittwaḥesben i řɛeskar nnes, tuɣa aten di tnayen u-třatin-ařef u-mitayn.
\m 
\v 22 \add Xenni\add* \bd taqbič n Binyamin\bd*. Abidan, mmis n Jidɛuni, \add ad yiři\add* d řeḥkam n ayt n Binyamin.
\v 23 Inni ittwaḥesben i řɛeskar nnes, tuɣa aten di xemsa u-ṭřatin-ařef u-arebɛa-mya.
\m 
\v 24 Inni ittwaḥesben i řmargeḥ n řɛeskar n Ifrayim, tuɣa aten di mya u-tmenya-ařef u-mya \add n yeryazen\add*, \add ttwasettfen\add* ɛlaḥsab \add tirbiɛin n\add* řɛeskar nsen. Nitni ad fesyen iqiḍan nsen wiss třata.
\b
\m 
\v 25 \bd Ɣar ccmal\bd* ad tiři tɛeǧant n \bd řmargeḥ n řɛeskar n Dan\bd*. \add Nitni ad iřin ttwasettfen\add* ɛlaḥsab \add tirbiɛin n\add* řɛeskar nsen. Axiɛazar, mmis n Ɛammicadday, \add ad yiři\add* d řḥakem n ayt n Dan.
\v 26 Inni ittwaḥesben i řɛeskar nnes, tuɣa aten di tnayen u-settin-ařef u-sebɛa-mya.
\m 
\v 27 Zzates ad tewwet \bd teqbič n Acir\bd* iqiḍan nnes. Fajɛiyil, mmis n Ɛukran, \add ad yiři\add* d řḥakem n ayt n Acir.
\v 28 Inni ittwaḥesben i řɛeskar nnes, tuɣa aten di waḥit u-rebɛin-ařef u-xemsa-mya.
\m 
\v 29 \add Xenni\add* \bd taqbič n Naftali\bd*. Axiraɛ, mmis n Ɛinan, \add ad yiři\add* d řḥakem n ayt n Naftali.
\v 30 Inni ittwaḥesben i řɛeskar nnes, tuɣa aten di třata u-xemsin-ařef u-arebɛa-mya.
\m 
\v 31 Inni ittwaḥesben i řmargeḥ n řɛeskar n Dan, tuɣa aten di mya u-sebɛa u-xemsin-ařef u-setta-mya \add n yeryazen\add*. Nitni ad fesyen iqiḍan nsen d aneggaru, \add am ttwasettfen nitni\add* ɛlaḥsab tiɛeǧanin nsen.
\b
\m 
\v 32 \bd Ina d inni ittwaḥesben n ayt n Israil\bd*, \add am ttwasettfen nitni\add* ɛlaḥsab taddart n ibabaten nsen. Marra inni ittwaḥesben di řemrageḥ n řɛeskar, \add am ttwasettfen nitni\add* ɛlaḥsab \add tirbiɛin n\add* řɛeskar nsen, \add tuɣa aten\add* di setta-mya u-teřt-ařaf u-xemsa-mya u-xemsin \add n yeryazen\add*.” \x ◘ \xo 2:32 \xt Uf. 38:26; Řxř. 1:46\x*
\m 
\v 33 \bd Ilawiyyen\bd* jar ayt n Israil war ttwaḥesben ca, \add nican\add* am mammec d as yumur SIDI i Musa. \x ◘ \xo 2:33 \xt Řxř. 1:48, 49\x*
\m 
\v 34 Uca ggin ayt n Israil am mammec marra min d as yumur SIDI i Musa: am mammec wtin iqiḍan nsen s usettef ɣar tɛeǧanin nsen, ammu i ɣa fesyen iqiḍan nsen \add ɛawed\add*, kuř ijjen \add ittwasettef\add* ɛlaḥsab řaǧat nnes, ɣar taddart n ibabaten nnes.
\b
\b
\c 3
\s1 Ayt n Harun
\m 
\v 1 \bd Aqa ina d tarwa n Harun d Musa\bd* deg wussan nni issiweř SIDI ak-d Musa x wedrar n Sina.
\v 2 Aqa ina d ismawen n warraw n Harun: Nadab d amenzu, \add xenni\add* Abihu, Aliɛazar d Itamar. \x ◘ \xo 3:2 \xt Uf. 6:23; Řxř. 3:4 4:28\x*
\v 3 Aqa ina d ismawen n warraw n Harun, ikehhanen inni ittwadehnen u inni ittwařeqqmen am yikehhanen.
\v 4 \add Maca\add* Nadab d Abihu mmuten zzat i wudem n SIDI, umi qeddmen timessi tařɣibt zzat i wudem n SIDI di řexřa n Sina. War tuɣi ɣarsen arraw. \add S uya\add* tuɣa Aliɛazar d Itamar sexxaren \add am\add* ukehhan zzat i wudem n babatsen Harun. \x ◘ \xo 3:4 \xt Lawi 10:1-7; Řxř. 26:61; 1 Im. 24:2\x*
\b
\s1 Tasexxart n ayt n Lawi
\m 
\v 5 Issiweř SIDI ak-d Musa, inna:
\m 
\v 6 “Sqarreb-dd taqbič n Lawi uca egg i-ten zzat i wudem n ukehhan Harun, ḥima ad xas sexxaren. \x ◘ \xo 3:6 \xt Řxř. 16:9; 18:2\x*
\v 7 Ejj i-ten ad řhan tasexxart nnes d tsexxart n marra tamesmunt zzat i Uqiḍun n Umsagar, maḥend ad kemmřen řxedmet n Tzeddiɣt.
\v 8 Ad ḥḍan x marra řeqcuɛ n Uqiḍun n Umsagar uca ad ṭṭfen aḥeṭṭu n ayt n Israil maḥend ad sexxaren di tsexxart n Tzeddiɣt.
\v 9 Cek ad tewced Ilawiyyen i Harun u i warrawen nnes. Aqa d yina i d as immewcen i netta waha zeg ayt n Israil.
\v 10 Ad třeqqmed Harun d warraw nnes maḥend ad ḥḍan x tukehhant. Abarrani nni i dd ɣa iqarrben ad ittwaneɣ.”
\m 
\v 11 Issiweř SIDI ak-d Musa, inna:
\m 
\v 12 “Xzar, Necc ksiɣ Ilawiyyen zi řwesṭ n ayt n Israil deg wemcan n imenza, marra inni yarezmen řemřawet \add d amezwaru\add* jar ayt n Israil. Ilawiyyen ad iřin inu, \x ◘ \xo 3:12 \xt Uf. 13:2\x*
\v 13 minzi kuř amenzu aqa inu. Deg wass min di wtiɣ marra imenza di temmurt n Miṣra, aqa ssqeddseɣ i Yixef inu marra imenza di Israil, zi bnadem ař řmař. Nitni ad iřin inu, Necc d SIDI!” \x ◘ \xo 3:13 \xt Uf. 13:2; 22:29; 34:19; Lawi 27:26; Řxř. 8:16; Lk. 2:22\x*
\b
\s1 Řqedd n Ilawiyyen
\m 
\v 14 Issiweř SIDI ak-d Musa di řexřa n Sina, inna:
\m 
\v 15 “Ḥseb ayt n Lawi, \add am ttwasettfen nitni\add* ɛlaḥsab tudrin n ibabaten nsen, ɛlaḥsab řaǧat nsen. Marra iwetman nni iǧan d \add ijj n\add* uyur sennej, ad ten teḥseb.”
\v 16 Uca Musa iḥseb i-ten x řumur n SIDI, am mammec \add d as\add* iweṣṣa.
\b
\m 
\v 17 \bd \bdit Tuɣa\bdit* ina d ayt n Lawi ak-d ismawen nsen: Jarcun, d Qahat d Marari.\bd* \x ◘ \xo 3:17 \xt Uf. 6:16, 17, 18; Řxř. 26:57; 1 Im. 6:1, 16; 23:6\x*
\m 
\v 18 \add Tuɣa\add* ina d ismawen n ayt n Jarcun, ɛlaḥsab řaǧat nsen: Libni d Cimɛi.
\m 
\v 19 Ayt n Qahat, ɛlaḥsab řaǧat nsen: Ɛamram d Yiṣhar d Ḥabrun d Ɛuzziyil.
\m 
\v 20 Ayt n Marari, ɛlaḥsab řaǧat nsen: Maḥli d Muci. \add Tuɣa\add* ina d řaǧat n Ilawiyyen, \add ttwasettfen\add* ɛlaḥsab tudrin n ibabaten nsen.
\b
\m 
\v 21 \bd Ɣar Jarcun\bd* \add tuɣa teǧa\add* řaǧ n Ilibniyyen d řaǧ n Icimɛiyyen. \add Tuɣa\add* tina d řaǧat n Ijarcuniyyen.
\v 22 Řqedd n yinni zzaysen ittwaḥesben, n marra iwetman zeg \add ijj n\add* uyur sennej, \add aqa řqedd nni n\add* yinni zzaysen ittwaḥesben tuɣa di sebɛa-ařaf u-xemsa-mya.
\v 23 Wtint řaǧat n Ijarcuniyyen iqiḍan nsen ɣar ḍeffar n Tzeddiɣt, \bd ɣar řɣarb\bd*.
\v 24 \add Tuɣa\add* Ilyasaf, mmis n Layil, d řḥakem n taddart n babatsen n Ijarcuniyyen.
\v 25 Zi jjihet n Uqiḍun n Umsagar ḥḍan ayt n Jarcun x Tzeddiɣt, x Uqiḍun ak-d tseqqafin nnes, x warwaq ɣar wadaf n Uqiḍun n Umsagar,
\v 26 x řizarat n řemraḥ d warwaq ɣar wadaf n řemraḥ i zi tᵉttwanneḍ Tzeddiɣt d uɛalṭar, u x ifiřan nnes, uřa x marra \add min dd-ittasen ak-d\add* tsexxart nni.
\b
\m 
\v 27 \bd Zi Qahat\bd* \add tuɣa iqqarṣ-dd\add* řaǧ n Iɛamramiyyen d řaǧ n Iṣhariyyen d řaǧ n Iḥibruniyyen d řaǧ n Iɛaziyiliyyen. \add Tuɣa\add* tina d řaǧat n Iqahatiyyen.
\v 28 \add Tuɣa\add* řqedd n marra iwetman zeg \add ijj n\add* uyur sennej temn-ařaf u-setta-mya. Nitni ḥḍan x Zzawect Iqeddsen.
\v 29 Wtint řaǧat n ayt n Qahat iqiḍan nsen ɣar uɣezdis n Tzeddiɣt, \bd ɣar ljanub\bd*.
\v 30 Iliṣafan, mmis n Ɛuzziyil, \add tuɣa\add* d řḥakem n taddart n babatsen n řaǧat n Iquhatiyyen.
\v 31 Nitni tuɣa ḥeṭṭan x Ttabut d tzewḍa d řqendiř d iɛalṭaren u x řeqcuɛ n Zzawect Iqeddsen i ssxedmen u x uřeḥḥaf, \add wah,\add* x marra \add i dd-ittasen ak-d\add* tsexxart nni.
\m 
\v 32 \add Tuɣa\add* Aliɛazar, mmis n ukehhan Harun, d řḥakem amezwaru qaɛ x \add marra\add* řḥukkam n Lawi. Netta iṭṭef acbar x yinni tuɣa iḥeṭṭan x Zzawect Iqeddsen.
\b
\m 
\v 33 \bd Zi Marari\bd* \add tuɣa iqqarṣ\add* řaǧ n Imaḥliyyen d řaǧ n Imuciyyen. \add Tuɣa\add* tina d řaǧat n Marari.
\v 34 \add Tuɣa\add* řqedd n yinni zzaysen ittwaḥesben, n marra iwetman zeg \add ijj n\add* uyur sennej, di setta-ařaf u-mitayn.
\v 35 \add Tuɣa\add* Suriyil, mmis n Abixayil, d řḥakem n taddart n babatsen n řaǧat n Marari. Nitni wtin iqiḍan nsen ɣar uɣezdis n Tzeddiɣt, \bd ɣar ccamal\bd*.
\v 36 Ayt n Marari tuɣa tᵉṭṭfen acbar maḥend ad wcen taynit i marra tifeřwin n Tzeddiɣt, i tḥenya n uɛarreḍ, i ipilaren nnes, i tyarsawin nnes u i marra řeqcuɛ nnes, \add wah.\add* i marra \add min dd-ittasen ak-d\add* tsexxart nni,
\v 37 uřa i ipilaren nni dd-innḍen i řemraḥ ak-d tyarsawin nsen d řewtad nsen d ifiřan nsen.
\b
\m 
\v 38 \bd Musa d Harun ak-d warraw nnes\bd* wtin iqiḍan nsen zzat i wudem n Tzeddiɣt, zzat i wudem n Uqiḍun n Umsagar, \bd ɣar ccarq\bd* manis dd-tneqqar tfuct. Nitni ḥḍan x Zzawect Iqeddsen di ṭṭweɛ n ayt n Israil. Abarrani nni dd-iqarrben, tuɣa ittxeṣṣa ad ittwaneɣ. \x ◘ \xo 3:38 \xt Řxř. 3:10; 16:40\x*
\m 
\v 39 \bd Marra inni ittwaḥesben n Ilawiyyen,\bd* inni iḥseb Musa ak-d Harun ɛlaḥsab řumur n SIDI, \add am ttwasettfen nitni\add* ɛlaḥsab řaǧat nsen, marra iwetman zeg \add ijj n\add* uyur sennej, tuɣa aten di tnayen u-ɛicrin-ařef.
\m 
\v 40 Inna SIDI i Musa: “Ḥseb marra imenza n iwetman n ayt n Israil, zeg \add ijj n\add* uyur sennej, uca ksi řqedd n ismawen nsen.
\v 41 Ad teksid Ilawiyyen i Necc - Necc d SIDI! - deg wemcan n marra imenza jar ayt n Israil uřa d řebhayem n Ilawiyyen deg wemcan n marra imenza jar řebhayem n ayt n Israil.”
\v 42 Uca iḥseb Musa marra imenza jar ayt n Israil am mammec d as yumur SIDI.
\v 43 Řqedd n ismawen n marra imenza iwetman n \add ijj n\add* uyur sennej, n yinni zzaysen ittwaḥesben, tuɣa aten di tnayen u-ɛicrin-ařef u-mitayn u-třata u-sebɛin.
\b
\m 
\v 44 Issiweř SIDI ak-d Musa, inna:
\m 
\v 45 “Ksi Ilawiyyen deg wemcan n marra imenza jar ayt n Israil uřa d řebhayem n Ilawiyyen deg wemcan n řebhayem nsen, minzi Ilawiyyen ad iřin inu. Aqa Necc d SIDI.
\v 46 Zi jjihet n mitayen u-třata u-sebɛin, inni ittxeṣṣa ad ttwafdin, maɣar nitni qqimen sennej i Ilawiyyen n imenza n ayt n Israil,
\v 47 ittxeṣṣa ad teksid xemsa ciqlu i \add kuř ijj n\add* uzeǧif. Ad t teksid anect n ciqlu n Zzawect Iqeddsen. Ciqlu \add wanita\add* aqa dayes ɛicrin jira. \x ◘ \xo 3:47 \xt Uf. 30:31; Lawi 27:25; Řxř. 18:16; Ḥiz. 45:12\x*
\v 48 Ad tewced nnuqart nni i Harun u i warraw nnes, aqa-tt i ttaman n ufekki n yinni iqqimen \add sennej i řqedd n Ilawiyyen\add*.”
\m 
\v 49 \add Xenni\add* iksi Musa nnuqart n ttaman n ufekki n yinni iqqimen sennej n yinni ittwafdin s Ilawiyyen.
\v 50 Uca iṭṭef nnuqart \add nni\add* zeg imenza n ayt n Israil: ařef u-teřt-mya u-xemsa u-settin \add ciqlu\add*, ɛlaḥsab ciqlu n Zzawect Iqeddsen.
\v 51 U Musa iwca nnuqart n yinni iwcin ttaman n ufekki i Harun u i warraw nnes, ɛlaḥsab \add awař n\add* uqemmum n SIDI, am mammec d as yumur SIDI i Musa.
\b
\b
\c 4
\s1 Tasexxart n Iqahatiyyen
\m 
\v 1 Issiweř SIDI ak-d Musa d Harun, inna:
\m 
\v 2 “\bd Ḥseb ayt n Qahat\bd* azeǧif \add azeǧif\add* jar ayt n Lawi, \add am ttwasettfen nitni\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen,
\v 3 zi třatin n iseggʷusa sennej ař xemsin n iseggʷusa, marra wenni i ɣa yadfen ɣar řɛeskar maḥend ad yegg řxedmet deg Uqiḍun n Umsagar.
\m 
\v 4 D ta \add i ɣa yiřin\add* d \bd tasexxart n ayt n Qahat\bd* deg Uqiḍun n Umsagar: \add aḥeṭṭu x\add* Weqdas x Uqeddas.
\v 5 Xmi dd ɣa fesyen řmargeḥ, ad dd-yas Harun d warraw nnes uca ad kksen ařeḥḥaf i iǧan i dduri uca ad zzayes ssduryen Ttabut n Cchadet.
\m 
\v 6 Ittxeṣṣa ad xas ggen ijj n dduri n iřmawen n ddenfiřat uca ad xas bezzɛen ijj n dduri marra d adeḥmi uca ad as ggen iɛumad nnes \add i tarebbut\add*.
\v 7 Ad bezzɛen ict n tjartiřṭ tadeḥmit x tzewḍa i weɣrum n wescan uca ad xas ggen ṭṭbaṣi, tiɣenjayin d řkisan d iɣarrafen s inni i ɣa kebben. Uca ittxeṣṣa ad xas yiři weɣrum n řebda. \x ◘ \xo 4:7 \xt Uf. 25:30\x*
\v 8 \add Awarni uya\add* ad xas bezzɛen ijj n dduri azeggʷaɣ iḥedqen uca ad tt dřen \add ɛawed\add* s ijj n dduri n iřmawen n ddenfiřat uca ad as ggen iɛumad nnes \add i tarebbut\add*.
\v 9 \add Xenni\add* ad ksin ict n tjartiřt tadeḥmanit uca ad zzayes dřen řqendiř i tfawt uřa d řefnarat nnes d tjeqqaḍin \add n teftič\add* nnes d tmejmarin nnes d marra řeqcuɛ nnes i zzect di ṭṭweɛ n tsexxart i \add řqendiř\add*. \x ◘ \xo 4:9 \xt Uf. 25:31,38\x*
\v 10 Ad ggen \add řqendiř-a\add* d marra řeqcuɛ nnes deg ijj n dduri n iřmawen n ddenfiřat uca ad t ssarsen x ǧuḥ n tkessit.
\v 11 Ad bezzɛen ijj n dduri adeḥmani x uɛalṭar \add n řebxur\add* uca ad t dřen \add ɛawed\add* s yijj n dduri n iřmawen n ddenfiřat uca ad as ggen iɛumad nnes \add i tarebbut\add*.
\v 12 Uca ad ksin marra řeqcuɛ i tsexxart i ssxeddmen di Zzawect Iqeddsen uca ad ten ggen deg ijj n dduri adeḥmani uca ad t dřen s yijj n dduri n iřmawen n ddenfiřat, \add xenni\add* ad ssarsen aya x ǧuḥ n tkessit.
\v 13 Ad kksen min iqqimen n tadunt n uɛalṭar uca ad xas bezzɛen ict n tjartiřt tarjuwanit.
\v 14 Ad xas ssarsen marra řeqcuɛ i ssxedmen i tsexxart: timejmarin, furcayat, iɣenjayen, ṭṭawyat i urucci d marra dduzan n uɛalṭar. Tiwwa nnes ad bezzɛen ijj n dduri n iřmawen n ddenfiřat uca ad as ggen iɛumad nnes \add i tarebbut\add*.
\m 
\v 15 Xmi ɣa ikemmeř Harun d warraw nnes dduri n Zzawect Iqeddsen d marra řeqcuɛ n Zzawect Iqeddsen xmi ɣa fesyen iqiḍan n řmargeḥ n řɛeskar, \add xenni\add* ad dd-asen warraw n Quhat ḥima ad arbun \add marra\add*, maca ittxeṣṣa war ttḥidin min iǧan iqeddsen, minzi mařa lla ad mmten. Man aya d min ittxeṣṣa ad arbun warraw n Qahat di tmesřact n Uqiḍun n Umsagar.
\m 
\v 16 Aliɛazar, mmis n ukehhan Harun, ad iṭṭef acbar x zzect i tfawt d řebxur ittfuḥen d tewhibt \add n řɣiǧet\add* n řebda d zzect i wedhan, \add wah, Harun ad iṭṭef acbar\add* x Tzeddiɣt marra u x marra min dayes, řa x min iǧan di Zzawect Iqeddsen uřa x řeqcuɛ nnes.” \x ◘ \xo 4:16 \xt Uf. 29:40; 30:23, 24,34,35\x*
\m 
\v 17 Issiweř SIDI ak-d Musa d Harun, inna:
\m 
\v 18 “Ɣarwem ad tqeḍɛem taqbič n řaǧat n Iqahatiyyen zi řwesṭ n Ilawiyyen.
\v 19 Ggem kisen ammu ḥima ad ddaren, war ttmettin xmi dd ɣa qarrben ɣar Weqdas x Uqeddas: ittxeṣṣa as i Harun d warraw nnes ad dd-adfen uca ad ggen kuř aryaz di řxedmet nnes u di ddqeř i ittxeṣṣa ad yarbu.
\v 20 War iɛeddeř ad adfen maḥend ad ẓaren Zzawect Iqeddsen, mɣir i yict n wermac n wabřiwen waha, \add maɣar xenni\add* ad mmten.”
\b
\s1 Tasexxart n Ijarcuniyyen
\m 
\v 21 Issiweř SIDI ak-d Musa, inna:
\m 
\v 22 “\bd Ḥseb ɛawed ayt n Jarcun\bd* azeǧif \add azeǧif\add*, \add am ttwasettfen nitni\add* ɛlaḥsab tudrin n ibabaten nsen, ɛlaḥsab řaǧat nsen.
\v 23 Ad ten tḥesbed zi třatin n iseggʷusa sennej, ař xemsin n iseggʷusa, kuř ijj i ɣa yadfen ɣar řɛeskar ḥima ad yegg tasexxart deg Uqiḍun n Umsagar.
\v 24 D ta d \bd tasexxart n řaǧat n Jarcun\bd* di tmesřact n tsexxart d tarebbut.
\v 25 Ad arbun tijartiřin n Tzeddiɣt d Uqiḍun n Umsagar: taseqqaft nnes d tseqqaft nnes n iřmawen n ddenfiřat nni i ɣa yiřin tiwwa nnes, d warwaq n wadaf n Uqiḍun n Umsagar,
\v 26 d řizarat n řemraḥ d arwaq i tewwart n wadaf ɣar řemraḥ i dd-innḍen i Tzeddiɣt d uɛalṭar d \add marra\add* ifiřan nsen d marra řeqcuɛ \add i dd-ittasen ak-d\add* tsexxart nsen u marra min d as ṣennɛen, \add d man aya\add* ad tiři řxedmet nsen.
\m 
\v 27 Marra řxedmet n ayt n Jarcun di tmesřact n marra tarebbut d marra tasexxart nsen, ad tiři ɛlaḥsab řumur n Harun d warraw nnes. Ittxeṣṣa awem ad ten tessecnem s \add u\add*ḥeṭṭu marra min ittxeṣṣa ad arbun.
\v 28 Ta d tasexxart n řaǧat n ayt n Jarcun deg Uqiḍun n Umsagar. Nitni ad ksin amnus \add i uya\add* sadu ufus n Itamar, mmis n Harun, akehhan.
\b
\s1 Tasexxart n Ayt n Marari
\m 
\v 29 Ad tḥesbed \bd ayt n Marari\bd*, \add am ttwasettfen nitni\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen.
\v 30 Ad ten tḥesbed zi třatin n iseggʷusa sennej, ař xemsin n iseggʷusa, marra wenni i ɣa yadfen ɣar řɛeskar maḥend ad isexxar di tsexxart n Uqiḍun n Umsagar.
\v 31 D ta d tasɣart nsen di trebbut ɣar marra \bd tasexxart nsen\bd* deg Uqiḍun n Umsagar: tifeřwin n Tzeddiɣt d tḥenya n uɛarreḍ d ipilaren nnes d tyarsawin nnes,
\v 32 d ipilaren n řemraḥ i d as dd-innḍen ak-d tyarsawin nsen d řewtad nsen d iseɣwan nsen, \add aqa d ta d tasɣart nsen di trebbut\add* n marra řeqcuɛ nsen u di marra tasexxart \add i dd-ittasen ak-d marra man aya\add*. Řeqcuɛ i ittxeṣṣa ad ten arbun, ittxeṣṣa kenniw ad ten tzemmed s ismawen nsen.
\v 33 D ta d \bd tasexxart n řaǧat n ayt n Marari\bd* ɣar marra tasexxart nsen deg Uqiḍun n Umsagar sadu ufus n Itamar, mmis n Harun, akehhan.”
\b
\s1 Imsexxaren n Ilawiyyen
\m 
\v 34 Musa d Harun d řḥukkam n tmesmunt ḥesben \bd ayt n Qahat\bd*, \add am ttwasettfen nitni\add* ɛlaḥsab řaǧat nsen u ɛlaḥsab tudrin n ibabaten nsen,
\v 35 zeg \add wenni ɣar iǧa\add* třatin n iseggʷusa sennej, ař \add wenni ɣar iǧa\add* xemsin n iseggʷusa, kuř ijj i ɣa yadfen maḥend ad isexxar deg Uqiḍun n Umsagar.
\v 36 Inni zzaysen ittwaḥesben, \add am ttwasettfen nitni\add* ɛlaḥsab řaǧat nsen, tuɣa aten di ařfayen u-sebɛa-mya u-xemsin.
\v 37 Ina d inni ittwaḥesben zi řaǧat n Iqahatiyyen, marra wi ittsexxaren deg Uqiḍun n Umsagar, inni ḥesben Musa d Harun x řumur n SIDI sadu ufus n Musa.
\b
\m 
\v 38 Inni ittwaḥesben zeg \bd ayt n Jarcun\bd*, \add am ttwasettfen nitni\add* ɛlaḥsab řaǧat nsen u ɛlaḥsab tudrin n ibabaten nsen,
\v 39 zeg \add wenni ɣar iǧa\add* třatin n iseggʷusa sennej, ař \add wenni ɣar iǧa\add* xemsin n iseggʷusa, kuř ijj i ɣa yadfen maḥend ad isexxar deg Uqiḍun n Umsagar,
\v 40 aqa inni zzaysen ittwaḥesben, \add am ttwasettfen nitni\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen, tuɣa aten di ařfayen u-setta-mya u-třatin,
\v 41 Ina d inni ittwaḥesben n řaǧat n ayt n Jarcun, marra wi ittsexxaren deg Uqiḍun n Umsagar, inni ḥesben Musa d Harun x řumur n SIDI.
\b
\m 
\v 42 Ina d inni ittwaḥesben n řaǧat n \bd ayt n Marari\bd*, \add am ttwasettfen nitni\add* ɛlaḥsab řaǧat nsen, ɛlaḥsab tudrin n ibabaten nsen,
\v 43 zeg \add wenni ɣar iǧa\add* třatin n iseggʷusa sennej, ař \add wenni ɣar iǧa\add* xemsin n iseggʷusa, kuř ijj i ɣa yadfen di řɛeskar maḥend ad isexxar deg Uqiḍun n Umsagar,
\v 44 aqa inni zzaysen ittwaḥesben, \add am ttwasettfen nitni\add* ɛlaḥsab řaǧat nsen, tuɣa aten di teřt-ařaf u-mitayen.
\v 45 Ina d inni ittwaḥesben n řaǧat n Marari, inni ḥesben Musa d Harun x řumur n SIDI sadu ufus n Musa.
\m 
\v 46 Marra inni ittwaḥesben, inni ḥesben Musa d Harun d řḥukkam n Israil zeg Ilawiyyen, \add am ttwasettfen nitni\add* ɛlaḥsab řaǧat nsen u ɛlaḥsab tudrin n ibabaten nsen,
\v 47 zeg \add wenni ɣar iǧa\add* třatin n iseggʷusa sennej ař \add wenni ɣar iǧa\add* xemsin n iseggʷusa, marra wenni i ɣa yadfen maḥend ad igg řxedmet n tsexxart u řxedmet n \add trebbut\add* n ddquřat deg Uqiḍun n Umsagar,
\v 48 aqa inni zzaysen ittwaḥesben tuɣa aten di temn-ařaf u-xemsa-mya u-tmanin.
\v 49 Nitni ttwaḥesben x řumur n SIDI sadu ufus n Musa, kuř aryaz \add ittwařeqqem\add* di tsexxart nnes u x ddqeř nnes. Nitni ttwaḥesben zzayes am mammec d as yumur SIDI i Musa.
\b
\b
\c 5
\s1 Izerfan nneɣni
\m 
\v 1 Issiweř SIDI ak-d Musa, inna:
\m 
\v 2 “Umur ayt n Israil ad ssuffɣen marra ayt n řbarṣ zi řmargeḥ n řɛeskar, uřa d marra inni ɣar iǧa useyyeř d marra inni ittwassxemjen zeg ict n řxecbet. \x ◘ \xo 5:2 \xt Lawi 13:3, 46; 15:2; 21:1 \x*
\v 3 Ad ten tessuffɣem, am yeryazen am temɣarin. Kenniw ad ten tessuffɣem barra i řmargeḥ n řɛeskar ḥima war ssxemmajen řemrageḥ nsen mani zeddɣeɣ Necc di řwesṭ nsen.”
\m 
\v 4 Uca ggin ayt n Israil ammu. Nitni ssuffɣen ten barra i řmargeḥ n řɛeskar. Ayt n Israil ggin am mammec i inna SIDI i Musa.
\b
\m 
\v 5 Issiweř SIDI ak-d Musa, inna:
\m 
\v 6 “Siweř ak-d ayt n Israil: ‘Mařa ijj n weryaz niɣ ict n temɣart i iggin ca n ddenb n bnadem i zi iɣdar di SIDI, \add xenni\add* ad yiři řeɛmar nni d bu-umarwas. \x ◘ \xo 5:6 \xt Lawi 5:21, 22\x*
\v 7 Ad neɛmen x ddenb nsen i ggin. Netta ad ixeǧeṣ amarwas nnes marra u ad as yarni ict n tesɣart texmusect uca ad iwc aya i wenni idewřen itturs as netta. \x ◘ \xo 5:7 \xt Lawi 5:24\x*
\m 
\v 8 \add Maca\add* mařa war din iǧi umefdi i weryaz \add nni\add*, maḥend ad as ixeǧeṣ amarwas, \add xenni\add* ad yiři umarwas, i ittxeṣṣa ad ixeǧeṣ i SIDI, i ukehhan, ak-d d icarri n weṣřaḥ i zzayes t ɣa isseṣřeḥ. \f ◼ \fr 5:8 \fk amefdi ... ifdi\ft - xzar Izhd. 78:35.\f*  \x ◘ \xo 5:8 \xt Lawi 5:21-26\x*
\v 9 Kuř tawhibt nni ssgeɛɛden ayt n Israil n tewhibin iqeddsen nni dd-ittawyen ɣar ukehhan ad tiři nnes.
\v 10 Marra \add tiwhibin\add* iqeddsen n ca n weryaz ad iřint i netta, min ma i ɣa iwc ijj n weryaz i ukehhan, \add d man aya\add* ad yiři i netta.’” \x ◘ \xo 5:10 \xt Lawi 10:12\x*
\b
\s1 Azerf x tusmi
\m 
\v 11 Issiweř SIDI ak-d Musa, inna:
\m 
\v 12 “Siweř ak-d ayt n Israil uca ini asen: ‘Mařa tamɣart n ca n weryaz teffeɣ u teɣdar i-t,
\v 13 u ca n weryaz issen i-tt, uca man aya innufaren i tiṭṭawin n weryaz nnes u nettat tessnuffar i-t uca \add ammu\add* tessexmej ixef nnes u war din wi xas ɣa icehden u nettat \add ɛemmarṣ\add* war tᵉttwaṭṭef,
\v 14 uca \add xenni\add* yusa-dd xas buḥbeř n tusmi uca yusem x temɣart nnes umi nettat tᵉttwassexmej, niɣ yusa-dd xas buḥbeř n tusmi uca yusem x temɣart nnes umi nettat war tᵉttwassexmij ca,
\v 15 \add xenni\add* aryaz ad yawi tamɣart nnes ɣar ukehhan uca ad yawi tawhibt nnes i nettat, aqa-tt d taɛcart n ijj n ifa n waren n imendi. War xas ifarreɣ zzect niɣ ad xas issars jjawi, minzi aqa-tt d tawhibt \add n řɣiǧet\add* di ssibbet n tusmi, ict n tewhibt \add n řɣiǧet\add* i řidaret, \add tenni\add* dd ɣa yawyen axarreṣ di řmuɛṣiyyet.
\m 
\v 16 Ad tt-i-dd-issqarreb ukehhan uca ad tt issars zzat i wudem n SIDI.
\v 17 Ad iksi ukehhan aman iqeddsen deg ict n řqecɛet n třaxt uca ad iksi \add ca\add* zeg ucař i iǧan di temmurt n Tzeddiɣt, ad yegg \add aya\add* deg waman.
\v 18 \add Xenni\add* ad igg ukehhan tamɣart \add nni\add* zzat i wudem n SIDI, ad ifekk \add acuwwaf n\add* uzeǧif n temɣart uca ad igg tawhibt \add n řɣiǧet\add* i řidaret deg ifassen nnes, aqa d tawhibt \add n řɣiǧet\add* n tusmi. Akehhan ad iṭṭef deg ufus nnes aman imerzagen nni dd-ittawyen nneɛřet.
\v 19 Akehhan ad tt yejj ad tejjaǧ uca ad yini i temɣart: Mařa war kim iṭṭiṣ ḥed u war tewḍid zeg weryaz nnem di texmuji, aqa ad tiřid tᵉttwaṣfid zeg waman-a imerzagen inni dd-ittawyen nneɛřet.
\v 20 \add Maca uct xam,\add* mařa tewḍid zeg weryaz nnem uca tᵉttwassxemjed uca ijj n weryaz mɣir aryaz nnem iṭṭeṣ akim!
\v 21 \add Xenni\add* ad yejj ukehhan tamɣart ad tejjaǧ tajaǧit n nneɛřet. Ad yini ukehhan i temɣart: SIDI ad cem yarr d \add ijj n umedya\add* n nneɛřet\add -a\add* d tjaǧit\add -a\add* di řwesṭ n řgens nnem, xmi ɣa yejj SIDI ad iwḍa umeṣṣaḍ nnem uca ad yarr aɛeddis nnem yuff,
\v 22 uca aman-a i dd-ittawyen nneɛřet ad adfen ɣar wadan nnem maḥend ad ssuffen aɛeddis nnem uca ad ssɣeḍřen ameṣṣaḍ nnem! Uca ad tini temɣart: Amin Amin!
\m 
\v 23 Ad yari ukehhan nnɛaři-ya x ict n tewriqt ittwannḍen uca \add xenni\add* ad \add tent\add* imḥa deg waman imerzagen.
\v 24 Ad iwc aman imerzagen i dd-ittawyen nneɛřet i temɣart u nettat ad tsu ařami aman i dd-ittawyen nneɛřet ad dayes adfen daxeř uca ad dewřen d imerzagen.
\v 25 Akehhan ad iksi tawhibt \add n řɣiǧet\add* n tusmi zeg ufus n temɣart uca ad issenhezz tawhibt \add n řɣiǧet\add* zzat i wudem n SIDI uca ad tt-i-dd issqarreb ɣar uɛalṭar.
\v 26 Ad iksi ukehhan ijj n wuru zi tewhibt \add n řɣiǧet\add*, aqa-tt d tawhibt n řidaret, uca ad issbexxar aya x uɛalṭar uca xenni ad iwc aman i temɣart ad tsu.
\v 27 Mařa iwca as aman ad tsu, \add xenni\add*, mařa tᵉttwassexmej uca nettat teɣdar aryaz nnes, aman i dd-ittawyen nneɛřet ad dayes dewřen d imerzagen uca aɛeddis nnes ad yuff uca ameṣṣaḍ nnes ad ittwaɣḍeř u tamɣart ad tedweř d nneɛřet di řwesṭ n řgens nnes.
\v 28 \add Maca\add* mařa war texmij ca temɣart, \add maca\add* tezdeg, \add xenni\add* ad tiři war xas ca, ad tiři tᵉttaru.’”
\m 
\v 29 \bd Wa d azerf zi jjihet n tusmi\bd*, xmi tewḍa ict n temɣart zeg weryaz nnes uca tᵉttwassexmej
\v 30 niɣ xmi dd yusa buḥbeř n tusmi x weryaz uca netta yusem x temɣart nnes. \add Xenni\add* ad yarra tamɣart ad tbedd zzat i wudem n SIDI u akehhan ad as ikemmeř marra azerf-a wa.
\v 31 Aryaz ad yiři d amezdag zi ssibbet n řmuɛṣiyyet, tamɣart-a ad tarbu řmuɛṣiyyet nnes.
\b
\b
\c 6
\s1 Lwaɛd n temrist n weɛzař
\m 
\v 1 Issiweř SIDI ak-d Musa, inna:
\m 
\v 2 “Siweř ak-d ayt n Israil uca ini asen: ‘Mařa ijj n weryaz niɣ ict n temɣart i iwejden maḥend ad iwc awař n ttaj \add n ucuwwaf n lwaɛd\add*, maḥend ad iɛzeř ixef nnes \add s ttaj nni\add* i SIDI,
\v 3 \add xenni\add* ad iggʷej x binu d ccrab. War isess řxeǧ zi binu niɣ řxeǧ zi ccrab u war isess aman n uḍiř, u war ittett zeg uḍiř azeyza niɣ zeg uḍiř yuẓɣen. \f ◼ \fr 6:3 \fk aman n uḍiř\ft - niɣ: ‘aẓemmi n uḍiř’.\f*
\v 4 Marra ussan n ttaj nnes \add n weɛzař\add* war ittett ca min dd-iffɣen zi tzayart, zeg uɛeqqa \add nnes\add* ař taqcurt \add nnes\add*.’”
\m 
\v 5 “Marra ussan n wawař i dd ttasen ak-d ttaj nnes \add n weɛzař\add* war ittekk řmus x uzeǧif nnes ař ɣa kemmřen wussan nni iɛzeř i SIDI uca ad yiři iqeddes uca ad yejj iɛeyyacen n ucuwwaf n uzeǧif nnes ad mɣaren. \x ◘ \xo 6:5 \xt Řqḍ. 13:5; 1 Ṣm. 1:11\x*
\v 6 Marra ussan i issḥuzz i SIDI, war dd-ittqarrib ca ɣar řeɛmar n ijj n umettin. \f ◼ \fr 6:6 \fk arrimet\ft - s Tɛibranit ‘ɣar řeɛmar’.\f*
\v 7 War issxemmij ixef nnes x babas niɣ x yemmas niɣ x umas niɣ x učmas mařa gguren ad mmten, minzi ttaj \add n weɛzař\add* n AREBBI nnes aqa-tt x uzeǧif nnes.”
\m 
\v 8 “Marra ussan n ttaj nnes \add n weɛzař\add* ad yiři iqeddes i SIDI.
\v 9 Mařa wenni ittmettan ad immet deɣya deg wermac n wabřiwen uca issexmej azeǧif \add nnes\add* s ttaj nnes \add n weɛzař\add*, \add xenni\add* ad iḥeff azeǧif nnes deg wass n usizdeg nnes. Deg wass wiss sebɛa ittxeṣṣa ad t iḥeff.
\v 10 Deg wass wiss tmenya ad yawi tnayen n tejlilliḥin niɣ tnayen n iḍbiren ɣar ukehhan ɣar wadaf n Uqiḍun n Umsagar.
\v 11 Akehhan ad issewjed ict d taɣarṣt n ddenb d ict d taɣarṣt n wecmaḍ uca ad t isseṣřeḥ, minzi netta aqa ixḍa di ssibbet n umettin. Netta ad issqeddes azeǧif nnes \add ɛawed\add* deg wass nni \f ◼ \fr 6:11 \fk ifdi\ft - xzar Izhd. 78:35.\f*
\v 12 uca \add twařa nneɣni\add* ad ineyyec netta ussan n ttaj nnes \add n weɛzař\add* i SIDI uca ad iqeddem ijj n izmar n ijj n useggʷas d taɣarṣt n umarwas. Ussan iɛdun ad iřin wḍan minzi aqa tᵉttwassexmej ttaj nnes \add n weɛzař\add*.”
\m 
\v 13 “Wa d azerf n wenni yarebbun ttaj \add n weɛzař\add*: deg wass min di ttwakemmřen wussan n ttaj nnes \add n weɛzař\add*, ad t awyen ɣar wadaf n Uqiḍun n Umsagar.
\v 14 \add Xenni\add* ad dd-issqarreb tawhibt nnes ɣar SIDI, ijj n izmar icnan qaɛ n ijj n useggʷas am tɣarṣt n wecmaḍ d ict n texsi icnan qaɛ n ijj n useggʷas am tɣarṣt n ddenb d ijj n icarri icnan qaɛ am tɣarṣt n řehna
\v 15 d ict n tsuǧet ak-d weɣrum břa antun d řemsemnat n waren azdad ixeǧḍen s zzect d teřfaf n weɣrum břa antun ttwadehnent s zzect uřa d tawhibt nnes \add n řɣiǧet\add* d tewhibin nnes n useyyeb.”
\m 
\v 16 “Akehhan ad yawi \add man aya\add* zzat i wudem n SIDI uca ad issewjed taɣarṣt nnes n ddenb d tɣarṣt nnes n wecmaḍ.
\v 17 Ad issewjed icarri am tɣarṣt n řehna i SIDI uřa d tasuǧet ak-d tecnifin břa antun uca akehhan ad issewjed \add ɛawed\add* tawhibt \add n řɣiǧet\add* nnes d tewhibin n useyyeb nnes.”
\m 
\v 18 “\add Xenni\add* wenni yarebbun ttaj \add n weɛzař\add* ad iḥeff azeǧif n ttaj nnes \add n weɛzař\add* ɣar wadaf n Uqiḍun n Umsagar uca ad iksi acuwwaf n uzeǧif n ttaj nnes \add n weɛzař\add* uca ad yegg aya x tmessi \add i iǧan\add* sadu tɣarṣt n řehna. \x ◘ \xo 6:18 \xt Řex. 21:24\x*
\v 19 \add Xenni\add* ad iksi ukehhan tameṣṣaḍt n zzat yenggʷan n icarri d ict n temsemment břa antun zi tsuǧet d ict n teřfeft břa antun uca ad tent issars x ifassen n wenni yarebbun ttaj \add n weɛzař\add* awarni ma iḥeff ttaj nnes \add n weɛzař\add*.
\v 20 Akehhan ad tent issenhezz zi ssa ɣar da zzat i wudem n SIDI. Aqa-tt d ict n tmesřact tamqeddast i ukehhan, ak-d idmaren n wenhezzi u ak-d ucekrud n tewhibt ittwassgeɛɛden. Awarni aya iɛeddeř i wenni yarebbun ttaj \add n weɛzař\add* maḥend ad isu binu.” \x ◘ \xo 6:20 \xt Uf. 29:27\x*
\m 
\v 21 “Wa d azerf n wenni yarebbun ttaj \add n weɛzař\add*, wenni tuɣa iwaɛden i SIDI tawhibt nnes di ssibbet n ttaj \add n weɛzař\add* nnes, barra min izemmar ufus nnes \add ɛad\add* ad issiweḍ. Ittxeṣṣa as ad yegg ɛlaḥsab awař i iwcin, \add ɛlaḥsab\add* azerf n ttaj \add n weɛzař\add* nnes.”
\b
\s1 Lbaraka s ufus n ikehhanen
\m 
\v 22 Issiweř SIDI ak-d Musa, inna:
\m 
\v 23 “Siweř ak-d Harun d warraw nnes uca ini: ‘Ammu ad tbarkem ayt n Israil uca ad asen tinim:
\b
\m 
\v 24 \qt SIDI ad ac ibarek uca ad cek iḥḍa!\qt*
\m 
\v 25 \qt SIDI ad yarr udem nnes\qt*
\m \qt ad xak yegg tfawt uca ad xak iḥinn.\qt*
\m 
\v 26 \qt SIDI ad ɣarek dd-inneqřeb udem nnes\qt*
\m \qt uca ad ac iwc řehna!’\qt*
\b
\m 
\v 27 Ad ssiwḍen Isem inu x ayt n Israil u Necc ad ten barkeɣ.’”
\b
\b
\c 7
\s1 Tiwhibin n izeǧifen n ayt n Israil
\m 
\v 1 Imsar deg wass min di ikemmeř Musa asbeddi n Tzeddiɣt, idhen u issqeddes i-tt ak-d řeqcuɛ nnes uřa d marra aɛalṭar ak-d řeqcuɛ nnes. Aqa idhen i-ten uca issqeddes i-ten. \x ◘ \xo 7:1 \xt Uf. 40:18\x*
\v 2 \add Xenni\add* qarrben-dd řḥukkam n Israil, izeǧifen n tudrin n řejdud nsen. Nitni d řḥukkam n tqebbař, nitni tuɣa x yinni ittwaḥesben.
\v 3 Nitni iwyen-dd tawhibt nsen zzat i wudem n SIDI: setta n ikarruten ak-d tseqqift d tenɛac n ifunasen, aqa d ijj n ukarru i tnayen n řḥukkam d ijj n ufunas i kuř ijj \add n řḥakem\add* uca iwyen ten zzat i wudem n Tzeddiɣt.
\m 
\v 4 Issiweř SIDI ak-d Musa, inna:
\m 
\v 5 “Ksi aya zzaysen, ḥima ad iřin i řxedmet n tsexxart n Uqiḍun n Umsagar. Ittxeṣṣa ad ten tewced i Ilawiyyen, \add i kuř aryaz\add* am mammec dd-ittas ak-d tsexxart nnes.”
\v 6 \bd Uca Musa iṭṭef ikarruten d ifunasen uca iwca i-ten i Ilawiyyen.\bd*
\v 7 Tnayen n ikarruten d arebɛa n ifunasen i iwca \bd i ayt n Jarcun\bd*, am mammec dd-ittas ak-d tsexxart nsen,
\v 8 u \bd i ayt n Marari\bd* iwca asen arebɛa n ikarruten d tmenya n ifunasen, am mammec dd-ittas ak-d tsexxart nsen sadu ufus n Itamar, mmis n ukehhan Harun.
\v 9 \bd I ayt n Qahat\bd* war d asen iwci walu, minzi tuɣa xasen tasexxart n Zzawect Iqeddsen, nitni arbun \add Zzawect\add* x tɣarwaḍ \add nsen\add*.
\b
\m 
\v 10 \add Xenni\add* qarrben-dd řḥukkam ak-d tewhibt i udeccen n uɛalṭar deg wass min di ittwadhen \add uɛalṭar\add*. Iwyen řḥukkam tiwhibin nsen zzat i wudem n uɛalṭar.
\v 11 Inna SIDI i Musa: “Ijj n řḥakem deg \add ijj n\add* wass, \add xenni ɛawed\add* ijj n řḥakem deg wass \add awarni as\add*, \add ammu\add* i ɣa qeddmen nitni tiwhibin nsen i udeccen n uɛalṭar.”
\m 
\v 12 \bd Deg wass amezwaru\bd* iqeddem Naḥcun, mmis n Ɛamminadab, zi teqbič n \bd Yahuda\bd*, tawhibt nnes.
\v 13 Tuɣa-tt tawhibt nnes: ijjen ṭṭebṣi n nnuqart n mya u-třatin ciqlu \add n ddqeř\add*, d icten ṭṭawya i urucci n nnuqart n sebɛin ciqlu, ɛlaḥsab ciqlu n Zzawect Iqeddsen. Tuɣa-ten s tnayen ccuren s waren azdad ixeǧḍen s zzect am tewhibt \add n řɣiǧet\add*.
\v 14 \add Xenni\add* ict n tɣenjact n wureɣ n ɛecra \add ciqlu\add* teccur s řebxur,
\v 15 ijj n ufunas - ameẓyan n tfunast - ijj n icarri, ijj n izmar n ijj n useggʷas am tɣarṣt n wecmaḍ,
\v 16 ijj n umyan zeg iɣayḍen i tɣarṣt n ddenb
\v 17 u i tɣarṣt n řehna: tnayen n ifunasen d xemsa n icarriyyen d xemsa n iɣayḍen d xemsa n izmaren n ijj n useggʷas. Aqa ta d tawhibt n Naḥcun, mmis n Ɛamminadab.
\m 
\v 18 \bd Deg wass wiss tnayen\bd* iqeddem Natanayil, mmis n Ṣuɣar, wenni d řḥakem n \bd Issakar\bd*, tawhibt nnes.
\v 19 Tuɣa-tt tawhibt nnes: ijjen ṭṭebṣi n nnuqart n mya u-třatin ciqlu \add n ddqeř\add*, d icten ṭṭawya i urucci n nnuqart n sebɛin ciqlu, ɛlaḥsab ciqlu n Zzawect Iqeddsen. Tuɣa-ten s tnayen ccuren s waren azdad ixeǧḍen s zzect am tewhibt \add n řɣiǧet\add*.
\v 20 \add Xenni\add* ict n tɣenjact n wureɣ n ɛecra \add ciqlu\add* teccur s řebxur,
\v 21 ijj n ufunas - ameẓyan n tfunast - ijj n icarri d ijj n izmar n ijj n useggʷas am tɣarṣt n wecmaḍ,
\v 22 ijj n umyan zeg iɣayḍen i tɣarṣt n ddenb
\v 23 u i tɣarṣt n řehna: tnayen n ifunasen, xemsa n icarriyyen, xemsa n iɣayḍen d xemsa n izmaren n ijj n useggʷas. Aqa ta d tawhibt n Natanayil, mmis n Ṣuɣar.
\m 
\v 24 \bd Deg wass wiss třata\bd* iqeddem řḥakem n ayt n \bd Zabulun\bd*, Iliyab, mmis n Ḥilun, tawhibt nnes.
\v 25 Tuɣa-tt tawhibt nnes: ijjen ṭṭebṣi n nnuqart n mya u-třatin ciqlu \add n ddqeř\add*, d icten ṭṭawya i urucci n nnuqart n sebɛin ciqlu, ɛlaḥsab ciqlu n Zzawect Iqeddsen. Tuɣa-ten s tnayen ccuren s waren azdad ixeǧḍen s zzect am tewhibt \add n řɣiǧet\add*.
\v 26 \add Xenni\add* ict n tɣenjact n wureɣ n ɛecra \add ciqlu\add* teccur s řebxur,
\v 27 ijj n ufunas - ameẓyan n tfunast - ijj n icarri d ijj n izmar n ijj n useggʷas am tɣarṣt n wecmaḍ,
\v 28 ijj n umyan zeg iɣayḍen i tɣarṣt n ddenb
\v 29 u i tɣarṣt n řehna: tnayen n ifunasen, xemsa n icarriyyen, xemsa n iɣayḍen d xemsa n izmaren n ijj n useggʷas. Aqa ta d tawhibt n Iliyab, mmis n Ḥilun.
\m 
\v 30 \bd Deg wass wiss arebɛa\bd* iqeddem řḥakem n ayt n \bd Rubin\bd*, Aliṣur, mmis n Cadayyur, tawhibt nnes.
\v 31 Tuɣa-tt tawhibt nnes: ijjen ṭṭebṣi n nnuqart n mya u-třatin ciqlu \add n ddqeř\add*, d icten ṭṭawya i urucci n nnuqart n sebɛin ciqlu, ɛlaḥsab ciqlu n Zzawect Iqeddsen. Tuɣa-ten s tnayen ccuren s waren azdad ixeǧḍen s zzect am tewhibt \add n řɣiǧet\add*.
\v 32 \add Xenni\add* ict n tɣenjact n wureɣ n ɛecra \add ciqlu\add* teccur s řebxur,
\v 33 ijj n ufunas - ameẓyan n tfunast - ijj n icarri d ijj n izmar n ijj n useggʷas am tɣarṣt n wecmaḍ,
\v 34 ijj n umyan zeg iɣayḍen i tɣarṣt n ddenb
\v 35 u i tɣarṣt n řehna: tnayen n ifunasen, xemsa n icarriyyen, xemsa n iɣayḍen d xemsa n izmaren n ijj n useggʷas. Aqa ta d tawhibt n Aliṣur, mmis n Cadayyur.
\m 
\v 36 \bd Deg wass wiss xemsa\bd* iqeddem řḥakem n ayt n \bd Cimɛun\bd*, Calumiyil, mmis n Ṣuricadday, tawhibt nnes.
\v 37 Tuɣa-tt tawhibt nnes: ijjen ṭṭebṣi n nnuqart n mya u-třatin ciqlu \add n ddqeř\add*, d icten ṭṭawya i urucci n nnuqart n sebɛin ciqlu, ɛlaḥsab ciqlu n Zzawect Iqeddsen. Tuɣa-ten s tnayen ccuren s waren azdad ixeǧḍen s zzect am tewhibt \add n řɣiǧet\add*.
\v 38 \add Xenni\add* ict n tɣenjact n wureɣ n ɛecra \add ciqlu\add* teccur s řebxur,
\v 39 ijj n ufunas - ameẓyan n tfunast - ijj n icarri d ijj n izmar n ijj n useggʷas am tɣarṣt n wecmaḍ,
\v 40 ijj n umyan zeg iɣayḍen i tɣarṣt n ddenb
\v 41 u i tɣarṣt n řehna: tnayen n ifunasen, xemsa n icarriyyen, xemsa n iɣayḍen d xemsa n izmaren n ijj n useggʷas. Aqa ta d tawhibt n Calumiyil, mmis n Ṣuricadday.
\m 
\v 42 \bd Deg wass wiss setta\bd* iqeddem řḥakem n ayt n \bd Jad\bd*, Aliyasaf, mmis n Daɛuyil, tawhibt nnes.
\v 43 Tuɣa-tt tawhibt nnes: ijjen ṭṭebṣi n nnuqart n mya u-třatin ciqlu \add n ddqeř\add*, d icten ṭṭawya i urucci n nnuqart n sebɛin ciqlu, ɛlaḥsab ciqlu n Zzawect Iqeddsen. Tuɣa-ten s tnayen ccuren s waren azdad ixeǧḍen s zzect am tewhibt \add n řɣiǧet\add*.
\v 44 \add Xenni\add* ict n tɣenjact n wureɣ n ɛecra \add ciqlu\add* teccur s řebxur,
\v 45 ijj n ufunas - ameẓyan n tfunast - ijj n icarri d ijj n izmar n ijj n useggʷas am tɣarṣt n wecmaḍ,
\v 46 ijj n umyan zeg iɣayḍen i tɣarṣt n ddenb
\v 47 u i tɣarṣt n řehna: tnayen n ifunasen, xemsa n icarriyyen, xemsa n iɣayḍen d xemsa n izmaren n ijj n useggʷas. Aqa ta d tawhibt n Aliyasaf, mmis n Daɛuyil.
\m 
\v 48 \bd Deg wass wiss sebɛa\bd* iqeddem řḥakem n ayt n \bd Ifrayim\bd*, Ilicamaɛ, mmis n Ɛammihud, tawhibt nnes.
\v 49 Tuɣa-tt tawhibt nnes: ijjen ṭṭebṣi n nnuqart n mya u-třatin ciqlu \add n ddqeř\add*, d icten ṭṭawya i urucci n nnuqart n sebɛin ciqlu, ɛlaḥsab ciqlu n Zzawect Iqeddsen. Tuɣa-ten s tnayen ccuren s waren azdad ixeǧḍen s zzect am tewhibt \add n řɣiǧet\add*.
\v 50 \add Xenni\add* ict n tɣenjact n wureɣ n ɛecra \add ciqlu\add* teccur s řebxur,
\v 51 ijj n ufunas - ameẓyan n tfunast - ijj n icarri d ijj n izmar n ijj n useggʷas am tɣarṣt n wecmaḍ,
\v 52 ijj n umyan zeg iɣayḍen i tɣarṣt n ddenb
\v 53 u i tɣarṣt n řehna: tnayen n ifunasen, xemsa n icarriyyen, xemsa n iɣayḍen d xemsa n izmaren n ijj n useggʷas. Aqa ta d tawhibt n Ilicamaɛ, mmis n Ɛammihud.
\m 
\v 54 \bd Deg wass wiss tmenya\bd* iqeddem řḥakem n ayt n \bd Manassa\bd*, Jamaliyil, mmis n Fadahṣur, tawhibt nnes.
\v 55 Tuɣa-tt tawhibt nnes: ijjen ṭṭebṣi n nnuqart n mya u-třatin ciqlu \add n ddqeř\add*, d icten ṭṭawya i urucci n nnuqart n sebɛin ciqlu, ɛlaḥsab ciqlu n Zzawect Iqeddsen. Tuɣa-ten s tnayen ccuren s waren azdad ixeǧḍen s zzect am tewhibt \add n řɣiǧet\add*.
\v 56 \add Xenni\add* ict n tɣenjact n wureɣ n ɛecra \add ciqlu\add* teccur s řebxur,
\v 57 ijj n ufunas - ameẓyan n tfunast - ijj n icarri d ijj n izmar n ijj n useggʷas am tɣarṣt n wecmaḍ,
\v 58 ijj n umyan zeg iɣayḍen i tɣarṣt n ddenb
\v 59 u i tɣarṣt n řehna: tnayen n ifunasen, xemsa n icarriyyen, xemsa n iɣayḍen d xemsa n izmaren n ijj n useggʷas. Aqa ta d tawhibt n Jamaliyil, mmis n Fadahṣur.
\m 
\v 60 \bd Deg wass wiss tesɛa\bd* iqeddem řḥakem n ayt n \bd Binyamin\bd*, Abidan, mmis n Jidɛuni, tawhibt nnes.
\v 61 Tuɣa-tt tawhibt nnes: ijjen ṭṭebṣi n nnuqart n mya u-třatin ciqlu \add n ddqeř\add*, d icten ṭṭawya i urucci n nnuqart n sebɛin ciqlu, ɛlaḥsab ciqlu n Zzawect Iqeddsen. Tuɣa-ten s tnayen ccuren s waren azdad ixeǧḍen s zzect am tewhibt \add n řɣiǧet\add*.
\v 62 \add Xenni\add* ict n tɣenjact n wureɣ n ɛecra \add ciqlu\add* teccur s řebxur,
\v 63 ijj n ufunas - ameẓyan n tfunast - ijj n icarri d ijj n izmar n ijj n useggʷas am tɣarṣt n wecmaḍ,
\v 64 ijj n umyan zeg iɣayḍen i tɣarṣt n ddenb
\v 65 u i tɣarṣt n řehna: tnayen n ifunasen, xemsa n icarriyyen, xemsa n iɣayḍen d xemsa n izmaren n ijj n useggʷas. Aqa ta d tawhibt n Abidan, mmis n Jidɛuni.
\m 
\v 66 \bd Deg wass wiss ɛecra\bd* iqeddem řḥakem n ayt n \bd Dan\bd*, Axiɛazar, mmis n Ɛamicadday, tawhibt nnes.
\v 67 Tuɣa-tt tawhibt nnes: ijjen ṭṭebṣi n nnuqart n mya u-třatin ciqlu \add n ddqeř\add*, d icten ṭṭawya i urucci n nnuqart n sebɛin ciqlu, ɛlaḥsab ciqlu n Zzawect Iqeddsen. Tuɣa-ten s tnayen ccuren s waren azdad ixeǧḍen s zzect am tewhibt \add n řɣiǧet\add*.
\v 68 \add Xenni\add* ict n tɣenjact n wureɣ n ɛecra \add ciqlu\add* teccur s řebxur,
\v 69 ijj n ufunas - ameẓyan n tfunast - ijj n icarri d ijj n izmar n ijj n useggʷas am tɣarṣt n wecmaḍ,
\v 70 ijj n umyan zeg iɣayḍen i tɣarṣt n ddenb
\v 71 u i tɣarṣt n řehna: tnayen n ifunasen, xemsa n icarriyyen, xemsa n iɣayḍen d xemsa n izmaren n ijj n useggʷas. Aqa ta d tawhibt n Axiɛazar, mmis n Ɛamicadday.
\m 
\v 72 \bd Deg wass wiss ḥiṭac\bd* iqeddem řḥakem n ayt n \bd Acir\bd*, Fajɛiyil, mmis n Ɛukran, tawhibt nnes.
\v 73 Tuɣa-tt tawhibt nnes: ijjen ṭṭebṣi n nnuqart n mya u-třatin ciqlu \add n ddqeř\add*, d icten ṭṭawya i urucci n nnuqart n sebɛin ciqlu, ɛlaḥsab ciqlu n Zzawect Iqeddsen. Tuɣa-ten s tnayen ccuren s waren azdad ixeǧḍen s zzect am tewhibt \add n řɣiǧet\add*.
\v 74 \add Xenni\add* ict n tɣenjact n wureɣ n ɛecra \add ciqlu\add* teccur s řebxur,
\v 75 ijj n ufunas - ameẓyan n tfunast - ijj n icarri d ijj n izmar n ijj n useggʷas am tɣarṣt n wecmaḍ,
\v 76 ijj n umyan zeg iɣayḍen i tɣarṣt n ddenb
\v 77 u i tɣarṣt n řehna: tnayen n ifunasen, xemsa n icarriyyen, xemsa n iɣayḍen d xemsa n izmaren n ijj n useggʷas. Aqa ta d tawhibt n Fajɛiyil, mmis n Ɛukran.
\m 
\v 78 \bd Deg wass wiss tenɛac\bd* iqeddem řḥakem n ayt n \bd Naftali\bd*, Axiraɛ, mmis n Ɛiynan, tawhibt nnes.
\v 79 Tuɣa-tt tawhibt nnes: ijjen ṭṭebṣi n nnuqart n mya u-třatin ciqlu \add n ddqeř\add*, d icten ṭṭawya i urucci n nnuqart n sebɛin ciqlu, ɛlaḥsab ciqlu n Zzawect Iqeddsen. Tuɣa-ten s tnayen ccuren s waren azdad ixeǧḍen s zzect am tewhibt \add n řɣiǧet\add*.
\v 80 \add Xenni\add* ict n tɣenjact n wureɣ n ɛecra \add ciqlu\add* teccur s řebxur,
\v 81 ijj n ufunas - ameẓyan n tfunast - ijj n icarri d ijj n izmar n ijj n useggʷas am tɣarṣt n wecmaḍ,
\v 82 ijj n umyan zeg iɣayḍen i tɣarṣt n ddenb
\v 83 u i tɣarṣt n řehna: tnayen n ifunasen, xemsa n icarriyyen, xemsa n iɣayḍen d xemsa n izmaren n ijj n useggʷas. Aqa ta d tawhibt n Axiraɛ, mmis n Ɛiynan.
\b
\m 
\v 84 Tuɣa ta d tawhibt i udeccen n uɛalṭar zi řḥukkam n Israil deg wass nni di ittwadhen \add uɛalṭar\add*: tenɛac n ṭṭbaṣi n nnuqart d tenɛac n ṭṭawyat i urucci n nnuqart d tenɛac n tɣenjayin n wureɣ.
\m 
\v 85 Ijjen ṭṭebṣi n nnuqart \add iwzen\add* mya u-třatin \add ciqlu\add* d icten ṭṭawya i urucci \add iwzen\add* sebɛin \add ciqlu\add*. Marra nnuqart n řeqcuɛ \add nni tewzen\add* ařfayen u-arebɛa-mya \add ciqlu\add* ɛlaḥsab ciqlu n Zzawect Iqeddsen.
\m 
\v 86 Tenɛac n tɣenjayin n wureɣ ccurent s řebxur. Kuř taɣenjayt \add tewzen\add* ɛecra ciqlu, ɛlaḥsab ciqlu n Zzawect Iqeddsen. Marra ureɣ n tɣenjayin \add iwzen\add* mya u-ɛicrin \add ciqlu\add*.
\m 
\v 87 Marra řebhayem i tɣarṣt n wecmaḍ aqa daysent tenɛac n ifunasen imeẓyanen, tenɛac n icarriyyen, tenɛac n izmaren n ijj n useggʷas ak-d tewhibt \add n řɣiǧet\add* nsen, u tenɛac imyanen zeg iɣayḍen i tɣarṣt n ddenb.
\m 
\v 88 Marra řebhayem n tɣarṣt n řehna aqa daysent arebɛa u-ɛicrin n ifunasen imeẓyanen, settin n icarriyyen d settin n iɣayḍen d settin n izmaren n ijj n useggʷas. Man aya d tawhibt i udeccen n uɛalṭar awarni ittwadhen.
\b
\m 
\v 89 \add Umi\add* yudef Musa ɣar Uqiḍun n Umsagar, ḥima ad kides issiweř, isřa Tmijja tessiweř akides zi sennej n tqebbart n weṣřaḥ i iǧan x Ttabut n Cchadet, zi jar tnayen n ikiruben. \add Ammu i\add* issiweř \add SIDI\add* akides. \f ◼ \fr 7:89 \fk ikiruben\ft - ict n marka n lmalakat.\f*
\b
\b
\c 8
\s1 Asbeddi n řqendiř
\m 
\v 1 Issiweř SIDI ak-d Musa, inna:
\m 
\v 2 “Siweř ak-d Harun, ini as: ‘Xmi ɣa tessarsed tifawin \add x řqendiř\add*, ittxeṣṣa sebɛa n tfawin ad wcent tafawt ɣar zzat n řqendiř.’” \x ◘ \xo 8:2 \xt Uf. 25:37\x*
\m 
\v 3 Uca ammu i igga Harun. Issars tifawin nnes ɣar zzat n řqendiř, am mammec d as yumur SIDI i Musa.
\v 4 Tuɣa řqendiř d ict n ṣṣenɛet n wureɣ yeɛdeř s wefḍis. Zeg ufuḍ x uḍar nnes ař nnuwwarat nnes tuɣa ittwagg s wefḍis. Ɛlaḥsab amedya i d as isccen SIDI, ammu i iṣenneɛ řqendiř. \x ◘ \xo 8:4 \xt Uf. 25:31\x*
\b
\s1 Tamewci n Ilawiyyen d řxedmet nsen
\m 
\v 5 Issiweř SIDI ak-d Musa, inna:
\m 
\v 6 “Ksi Ilawiyyen zi jar řwesṭ n ayt n Israil uca sizdeg i-ten.
\v 7 Ammu i d asen ɣa tegged ḥima ad ten tessizedged: Rucc i-ten s waman n usizdeg. Ittxeṣṣa asen ad ḥeffen marra arrimet nsen uca ad ssirden arruḍ nsen uca ad ssizdegen ixef nsen.
\v 8 Xenni ad ksin ijj n ufunas, ameẓyan n tfunast, ak-d tewhibt \add n řɣiǧet\add* nnes n waren azdad ixeǧḍen s zzect u \add ɛawed\add* ijj n ufunas wiss tnayen, ameẓyan n tfunast, am tɣarṣt n ddenb.
\v 9 Ad tawyed Ilawiyyen zzat i Uqiḍun n Umsagar uca ad tessmuned marra tamesmunt n ayt n Israil.
\v 10 Ad dd-tessqarrbed Ilawiyyen zzat i wudem n SIDI uca ayt n Israil ad ssarsen ifassen nsen x Ilawiyyen.
\v 11 Ad yejj Harun ad hezzen Ilawiyyen zi ssa ɣar da zzat i wudem n SIDI am yict n tewhibt n wenhezzi di ṭṭweɛ n ayt n Israil. Nitni ad dewřen ttsexxaren di tsexxart n SIDI.
\v 12 Ilawiyyen ad ssarsen ifassen nsen x izeǧifen n ifunasen imeẓyanen uca ad tesswejded ijj i tɣarṣt n ddenb d yijj i tɣarṣt n wecmaḍ i SIDI, ḥima ad zzaysen ittwagg weṣřaḥ i Ilawiyyen.
\v 13 Ad tegged Ilawiyyen ad bedden zzat i wudem n Harun u zzat i wudem n warraw nnes uca \add ad ten tarred\add* ad hezzen zi ssa ɣar da am yict n tewhibt n wenhezzi zzat i wudem n SIDI.
\v 14 \add Ammu\add* i ɣa tḥuzzed Ilawiyyen zi řwesṭ n ayt n Israil ḥima Ilawiyyen ad iřin inu. \x ◘ \xo 8:14 \xt Řxř. 3:45\x*
\m 
\v 15 Awarni man aya ad dd-asen Ilawiyyen ḥima ad sexxaren deg Uqiḍun n Umsagar. Ad ten tessizedged uca ad ten tarred ad hezzen zi ssa ɣar da am yict n tewhibt n wenhezzi,
\v 16 minzi nitni ttwammewcen ayi nican zi řwesṭ n ayt n Israil, uca Necc ksiɣ ten i Yixef inu deg wemcan n marra min yarezmen řemřawet \add d amezwaru\add*, \add deg wemcan n\add* umenzu n marra ayt n Israil.
\v 17 Minzi marra amenzu jar ayt n Israil aqa-t inu, zeg iwdan, ammu zi řmař, zeg wass i di nɣiɣ Necc marra imenza di temmurt n Miṣra, ssqeddseɣ ten i Necc. \x ◘ \xo 8:17 \xt Uf. 13:2; 22:29; 34:19; Lawi 27:26; Řxř. 3:13; Lk. 2:23\x*
\v 18 Necc ksiɣ Ilawiyyen deg wemcan n marra imenza jar ayt n Israil. \x ◘ \xo 8:18 \xt Řxř. 3:12\x*
\v 19 Necc wciɣ Ilawiyyen i Harun u i warraw nnes am yijj n uriɣalu zi řwesṭ n ayt n Israil, maḥend ad ggen tasexxart n ayt n Israil deg Uqiḍun n Umsagar u maḥend ad ittwagg weṣřaḥ di ṭṭweɛ n ayt n Israil, ḥima war tᵉttiři jjriḥect x ayt n Israil xmi dd ɣa qarrben ayt n Israil ɣar Zzawect Iqeddsen.”
\m 
\v 20 Musa d Harun d marra tamesmunt n ayt n Israil ggin ak-d Ilawiyyen ɛlaḥsab marra min d as yumur SIDI i Musa zi jjihet n Ilawiyyen, ammu i ggin ayt n Israil akidsen.
\v 21 Ilawiyyen ssizdigen ixef nsen zi ddenb nsen uca ṣebbnen arruḍ nsen uca Harun yarra i-ten ad nhezzen zi ssa ɣar da am yict n tewhibt n wenhezzi zzat i wudem n SIDI uca Harun isseṣřeḥ i-ten i usizdeg nsen. \f ◼ \fr 8:21 \fk ifdi\ft - xzar Izhd. 78:35.\f*
\v 22 Awarni man aya usin-dd Ilawiyyen ḥima ad sexxaren deg Uqiḍun n Umsagar zzat i wudem n Harun u zzat i wudem n warraw nnes am mammec d as yumur SIDI i Musa zi jjihet n Ilawiyyen, ammu i kidsen ggin.
\b
\m 
\v 23 Issiweř SIDI ak-d Musa, inna:
\m 
\v 24 “Ta zi jjihet n Ilawiyyen: \add aqa\add* ittxeṣṣa i \add kuř\add* mmis n xemsa u-ɛicrin n iseggʷusa sennej ad dd-yas, ḥima ad isexxar di ṭṭweɛ n tsexxart n Uqiḍun n Umsagar
\v 25 u xmi i ɣa yiweḍ ɣar xemsin n iseggʷusa ad iffeɣ zi řɛeskar n tsexxart u war iqqim ittsexxar ɛad ktar.
\v 26 Ad iwc afus i yaytmas deg Uqiḍun n Umsagar ḥima ad \add xas\add* ḥḍan, \add maca\add* netta \add s yixef nnes\add* war izemmar ad isexxar. Ammu i ɣa tegged ak-d Ilawiyyen zi jjihet n uḥeṭṭu i xasen ittwaggen.”
\b
\b
\c 9
\s1 Tiweṣṣa i Tɣarṣt n Useɛdu
\m 
\v 1 Issiweř SIDI ak-d Musa di řexřa n Sina deg useggʷas wiss tnayen awarni řami dd-ffɣen zi temmurt n Miṣra, deg uyur amezwaru, inna:
\m 
\v 2 “Jjem ayt n Israil ad sswejden \add Taɣarṣt n\add* Useɛdu di řweqt nnes ittwaggen. \x ◘ \xo 9:2 \xt Uf. 12:1-28; Lawi 23:5; Řxř. 28:16; Aɛwd. 16:2\x*
\v 3 Deg wass wiss arbeɛṭac n uyur-a, jar beddu n wezyen n wass ař dd-tewḍa tmeddit, ittxeṣṣa ad tt tesswejdem di řweqt nnes ittwaggen. Ittxeṣṣa ad tt tesswejdem ɛlaḥsab marra tiweṣṣa d lfarayiḍ nnes.”
\m 
\v 4 Issiweř Musa ak-d ayt n Israil, \add inna\add* ittxeṣṣa asen ad sswejden \add Taɣarṣt n\add* Useɛdu.
\v 5 Uca nitni sswejden \add Taɣarṣt n\add* Useɛdu deg wass wiss arbeɛṭac n \add uyur\add* amezwaru di řexřa n Sina, jar beddu n wezyen n wass ař dd-tewḍa tmeddit, ɛlaḥsab marra min d as yumur SIDI i Musa, ammu i tt sswejden ayt n Israil.
\m 
\v 6 Ca n yeryazen ttwassxemjen s řxecbet n ijj n bnadem \add immuten\add* uca war zemmaren ad sswejden \add Taɣarṣt n\add* Useɛdu. \add X uya\add* qarrben-dd nitni deg wass nni zzat i wudem n Musa u zzat i wudem n Harun
\v 7 uca nnan as yeryazen nni: “Neccin nexmej s řxecbet n ijj n bnadem \add immuten\add*. Mayemmi i nettwassbedd ařami war nzemmar ad dd-nessqarreb tawhibt n SIDI deg wass nnes ittwaggen di řwesṭ n ayt n Israil?”
\v 8 Musa inna asen: “Qqimem tbeddem, \add ḥima\add* ad sřeɣ min d awem ɣa iweṣṣa SIDI.”
\m 
\v 9 Issiweř SIDI ak-d Musa, inna:
\m 
\v 10 “Siweř ak-d ayt n Israil uca ini: ‘Mařa ḥed zzaywem niɣ zi jjiřat nwem \add i dd ɣa yasen\add* ittwassexmej zi řxecbet \add n yijj n umettin\add*, niɣ netta deg webrid d azirar, \add xenni\add* ad issewjed \add ɛad\add* \add Taɣarṣt n\add* Useɛdu i SIDI.
\v 11 Deg uyur wiss tnayen, deg wass wiss arbeɛṭac, jar beddu n wezyen n wass ař dd-tewḍa tmeddit, ad tt sswejden. \add Xenni\add* ad tt ccen ak-d weɣrum břa antun u ak-d řebzar yarezgen.
\v 12 War ttejjin zzayes walu ař ṣṣbeḥ uca war zzayes ttareẓẓan iɣes. Ittxeṣṣa ad tt sswejden ɛlaḥsab marra tiweṣṣa n \add Tɣarṣt n\add* Useɛdu.’” \x ◘ \xo 9:12 \xt Uf. 12:46; Yḥ. 19:33, 36\x*
\m 
\v 13 “Mařa ijj n weryaz d amezdag i war iǧin deg webrid, ad yejj ad issewjed \add Taɣarṣt n\add* Useɛdu, \add xenni\add* ad ittwaqess řeɛmar nni zi řgens nnes, minzi netta war dd-issqarreb ca tawhibt n SIDI di řweqt nnes ittwaggen. Aryaz nni ad yarbu ddenb nnes.
\v 14 Mařa izdeɣ akidwem ijj n ubarrani, wenni i ɣa isswejden \add Taɣarṣt n\add* Useɛdu n SIDI, \add xenni\add* ad issewjed \add Taɣarṣt n\add* Useɛdu ɛlaḥsab tawṣeyyet n \add Taɣarṣt n\add* Useɛdu u ɛlaḥsab lfarayiḍ nnes. Ad din tiři ict n tewṣeyyet i kenniw, i ubarrani ammu i wenni dd-ixeřqen di temmurt.” \x ◘ \xo 9:14 \xt Uf. 12:49\x*
\b
\s1 Agewwed n SIDI s useynu
\m 
\v 15 Deg wass min di tᵉttwassgeɛɛed Tzeddiɣt, idřa useynu Tazeddiɣt ak-d Uqiḍun n Cchadet u di ǧiřet iḍhar-dd x Tzeddiɣt am tmessi ař ṣṣbeḥ. \x ◘ \xo 9:15 \xt Uf. 40:34\x*
\v 16 Ammu i tuɣa řebda, aseynu idřa i-tt u di ǧiřet iḍhar-dd am tmessi.
\v 17 Řami dd-igeɛɛed useynu zi sennej n Uqiḍun, \add xenni\add* awarni aya fesyen ayt n Israil iqiḍan nsen u deg wemcan mani tuɣa dd-ibedd useynu, din i wtin ayt n Israil iqiḍan nsen.
\v 18 Fesyen ayt n Israil iqiḍan nsen ɛlaḥsab řumur n SIDI uca x řumur n SIDI wtin iqiḍan nsen. Marra ussan tuɣa aseynu iqqim sennej i Tzeddiɣt, qqimen nitni zeddɣen \add din\add*. \x ◘ \xo 9:18 \xt 1 Kur. 10:1\x*
\v 19 Řami dd-ibedd useynu aṭṭas n wussan sennej i Tzeddiɣt, ḥḍan ayt n Israil tasexxart n SIDI uca war fesyen ca iqiḍan nsen.
\m 
\v 20 Umi iqqim useynu cwayt n wussan sennej i Tzeddiɣt, \add xenni\add* wtin nitni iqiḍan nsen ɛlaḥsab řumur n SIDI u x řumur n SIDI fesyen iqiḍan nsen \add ɛawed\add*.
\v 21 Mařa imsar belli aseynu ibedd din zi ǧiřet ař ṣṣbeḥ uca igeɛɛed useynu di ṣṣbeḥ, \add xenni\add* fesyen nitni iqiḍan nsen. Ma deg wass \add i iǧa\add* niɣ di ǧiřet, xmi dd-igeɛɛed useynu, fesyen nitni iqiḍan nsen.
\v 22 Uca mařa iqqim useynu ibedd sennej i Tzeddiɣt tnayen n wussan, niɣ ijj n uyur, niɣ aṭṭas n wussan, ařami xas ɣa yarsa, \add xenni\add* qqimen ayt n Israil ttxeyymen \add dinni\add*, war fesyen ca iqiḍan nsen. Mařa igeɛɛed useynu, \add xenni\add* fesyen nitni iqiḍan nsen. \x ◘ \xo 9:22 \xt Uf. 40:36, 37\x*
\v 23 X řumur n SIDI wtin iqiḍan nsen u x řumur n SIDI fesyen iqiḍan nsen. Aqa ḥḍan min d asen yumur SIDI, x řumur n SIDI, s tsexxart n Musa.
\b
\b
\c 10
\s1 Accawen n icarri i usuḍi
\m 
\v 1 Issiweř SIDI ak-d Musa, inna:
\m 
\v 2 “Egg i yixef nnec tnayen n řebwaq \add iziraren\add* n nnuqart, \add s yijj n umarsu\add* s wefḍis ad ten tegged uca ad iřin i ubarreḥ n tmesmunt u i usmuṭṭi n řemrageḥ n řɛeskar.
\m 
\v 3 \add Xmi\add* daysen ɣa suḍen, ad ɣarek tmun tmesmunt marra ɣar wadaf n Uqiḍun n Umsagar.
\v 4 Xmi ɣa suḍen deg ijj \add zi tnayen nni\add*, \add xenni\add* \add mɣir\add* řḥukkam, izeǧifen x řuřuf n Israil, i xak dd ɣa imunen.
\v 5 Xmi ɣa tsuḍem s wesruddeḥ \add di řbuq\add*, \add xenni\add* ad mmuṭṭiyent řemrageḥ nni immarsen ɣar ccarq.
\v 6 Xmi ɣa tsuḍem s wesruddeḥ \add di řbuq\add* tnayen n twařawin, \add xenni\add* ad mmuṭṭiyent řemrageḥ nni immarsen ɣar uɣezdis n ljanub. Ad suḍen s wesruddeḥ umi ɣa muṭṭiyen zeg wemcan ɣar wemcan \add nneɣni\add*.
\v 7 I tmesmunt n wegraw \add n řgens\add* ittxeṣṣa ad tsuḍem \add di řebwaq\add*, \add maca\add* břa asruddeḥ.
\v 8 Ad suḍen warraw n Harun, ikehhanen, di řebwaq. Ad tiři d ict n tewṣeyyet i řebda i \add marra\add* jjiřat nwem.”
\m 
\v 9 “Xmi dd ɣa teffɣem ɣar garra di temmurt nwem, ḥima ad tmenɣem ak-d weɣrim nni kenniw dd-ihekkweřen, \add xenni\add* ad tsuḍem s wesruddeḥ di řebwaq uca kenniw ad tᵉttwatidarem zzat i wudem n SIDI, AREBBI nwem, uca ad tnejmem zi řɛedyan nwem.
\v 10 \add Ammu\add* di kuř ijj n wass n řefraḥet u di řeɛyudat ittwaggen u deg umezwaru n iyuren nwem ad tsuḍem di řebwaq xmi \add ɣa tawyem\add* tiɣarṣa n wecmaḍ nwem d tɣarṣa n uqadi nwem uca \add ammu i\add* ɣa iřint di ṭṭweɛ nwem i řidaret zzat i wudem n AREBBI, Necc d SIDI, AREBBI nwem.” \x ◘ \xo 10:10 \xt Izhd. 68:\x*
\b
\s1 Aggʷejji zi řexřa n Sina
\m 
\v 11 Imsar deg useggʷas wiss tnayen, deg uyur wiss tnayen, deg \add wass\add* wiss ɛicrin n uyur, aqa ittwassgeɛɛed useynu zi sennej n Tzeddiɣt n Cchadet.
\v 12 Uca fesyen ayt n Israil iqiḍan nsen, mmuṭṭiyen zeg wemcan ɣar wemcan zi řexřa n Sina uca ibedd-dd useynu di řexřa n Faran.
\v 13 \add Ammu\add* fesyen iqiḍan nsen twařa tamezwarut, x řumur n SIDI, x ufus n Musa.
\m 
\v 14 \bd D amezwaru tᵉttwakkes tɛeǧant n řmargeḥ n řɛeskar n ayt n Yahuda\bd*, \add uyuren am ttwasettfen\add* ɛlaḥsab \add tirbiɛin n\add* řɛeskar nsen. Naḥcun, mmis n Ɛamminadab, tuɣa \add d azeǧif\add* x řɛeskar. \x ◘ \xo 10:14 \xt Řxř. 1:7; 2:3 \x*
\v 15 Natanayil, mmis n Ṣuɣar, tuɣa \add d azeǧif\add* x řɛeskar n teqbič n ayt n Issakar.
\v 16 Iliyab, mmis n Ḥilun, tuɣa \add d azeǧif\add* x řɛeskar n teqbič n ayt n Zibulun.
\m 
\v 17 Awarni man aya hedmen Tzeddiɣt uca fesyen ayt n Jarcun d ayt n Marari iqiḍan nsen uca arbun Tazeddiɣt.
\m 
\v 18 \bd \bdit Xenni\bdit* tᵉttwakkes tɛeǧant n řmargeḥ n řɛeskar n Rubin\bd* \add uyuren, ttwasettfen\add* ɛlaḥsab \add tirbiɛin n\add* řɛeskar nsen. Iliṣur, mmis n Cadayur, tuɣa \add d azeǧif\add* x řɛeskar nnes.
\v 19 Calumiyil, mmis n Ṣuricadday, tuɣa \add d azeǧif\add* x řɛeskar n teqbič n ayt n Cimɛun.
\v 20 Ilyasaf, mmis n Daɛuyil, tuɣa \add d azeǧif\add* x řɛeskar n teqbič n ayt n Jad.
\m 
\v 21 \add Xenni\add* fesyen ayt n Qahat iqiḍan nsen, arbun Zzawect Iqeddsen. Uca \add ayt n Jarcun d ayt n Marari\add* bnan Tazeddiɣt qbeř twasit nsen. \x ◘ \xo 10:21 \xt Řxř. 4:4\x*
\m 
\v 22 \bd \bdit Awarni as\bdit* tᵉttwakkes tɛeǧant n řmargeḥ n řɛeskar n ayt n Ifrayim\bd*, \add uyuren, ttwasettfen\add* ɛlaḥsab \add tirbiɛin n\add* řɛeskar nsen. Ilicamaɛ, mmis n Ɛammihud, tuɣa \add d azeǧif\add* x řɛeskar nnes.
\v 23 Jamaliyil, mmis n Fadahṣur, tuɣa \add d azeǧif\add* x řɛeskar n teqbič n ayt n Manassa.
\v 24 Abidun, mmis n Jidɛuni, tuɣa \add d azeǧif\add* x řɛeskar n teqbič n ayt n Binyamin.
\m 
\v 25 \bd \bdit Xenni\bdit* tᵉttwakkes tɛeǧant n řmargeḥ n řɛeskar n ayt n Dan\bd*, am uɣezdis uneggar n marra řemrageḥ, \add uca uyuren, ttwasettfen\add* ɛlaḥsab \add tirbiɛin n\add* řɛeskar nsen. Axiɛazar, mmis n Ɛammicadday, tuɣa \add d azeǧif\add* x řɛeskar nnes.
\v 26 Fajɛiyil, mmis n Ɛukran, tuɣa \add d azeǧif\add* x řɛeskar n teqbič n ayt n Acir.
\v 27 Axiraɛ, mmis n Ɛinan, tuɣa \add d azeǧif\add* x řɛeskar n teqbič n ayt n Zibulun.
\m 
\v 28 \add Ammu i\add* ssmuṭṭiyen ayt n Israil iqiḍan nsen \add zeg wemcan ɣar wemcan\add*, \add am ttwasettfen nitni\add* ɛlaḥsab řɛeskarat nsen, \add ammu i\add* fesyen nitni iqiḍan nsen.
\b
\m 
\v 29 Inna Musa i \bd Ḥubab, mmis n Raɛuyil, Amidyani, aḍeggʷař n Musa:\bd* “Neccin ad nemmuṭṭi ɣar wemcan i d aneɣ inna SIDI: ‘Necc ad awem t-i-dd wceɣ!’ As-dd akidneɣ, ad ac negg tcuni, minzi SIDI issiweř x Israil s řxir.”
\v 30 Netta inna as: “Necc war ttriḥeɣ, maɣar ad uyureɣ ɣar temmurt inu u ɣar řaǧ inu.”
\v 31 Uca netta inna as: “Ttzawgeɣ cek, war d aneɣ ttejji, minzi cek tessned mammec icuwwar ad newwet iqiḍan nneɣ. Cek aqa tdewřed aneɣ \add - am mammec neqqar -\add* am tiṭṭawin.
\v 32 Xmi ɣa traḥed akidneɣ uca ad aneɣ dd-yas řxir i dayneɣ ɣa igg SIDI, aqa neccin ad ac negg tcuni \add ɛawed\add*.”
\b
\m 
\v 33 Uca fesyen iqiḍan nsen, \add uyuren\add* zeg wedrar n SIDI ticři n třata n wussan. Ttabut n Řɛahd tuyur zzat i wudem nsen ticři n třata n wussan, ḥima ad yarzu x ijj n wemcan i arraḥet.
\v 34 Deg uziř tuɣa aseynu n SIDI sennej nsen umi kksen iqiḍan nsen zi řmargeḥ n řɛeskar.
\v 35 Řami tᵉttwassmuṭṭi Ttabut, temsar \add řebda\add* belli Musa inna: “Kkar, \add a\add* SIDI, ejj řeɛdyan nnec ad mmzeǧaɛen u inni kenniw icarrhen ad arewřen zeg wudem nnec!” \x ◘ \xo 10:35 \xt Izhd. 68:2\x*
\v 36 Ɣar ubeddi \add n Ttabut\add*, inna: “Dweř-dd, \add a\add* SIDI, ɣar ɛecra n řuřuf n řuřuf n Israil!”
\b
\b
\c 11
\s1 Timessi n SIDI
\m 
\v 1 Imsar umi idweř řgens am yijj n ubarru ittcetcan, tuɣa man aya d řeḥriq i imezzuɣen n SIDI. \add Řami\add* isřa SIDI aya, yarɣa weɣḍab nnes u timessi n SIDI tarɣa di řwesṭ nsen uca tecca řeḍruf n řmargeḥ n řɛeskar. \x ◘ \xo 11:1 \xt Aɛwd. 9:22; Izhd. 78:21 \x*
\v 2 \add Xenni\add* iřaɣa-dd řgens x Musa uca Musa iẓẓuǧ i SIDI uca texsi tmessi.
\v 3 Uca iřaɣa as i wemcan nni ‘Tabɛira’, minzi timessi n SIDI tuɣa tarɣa di řwesṭ nsen.
\b
\s1 Sebɛin n imɣaren - Tisekrin
\m 
\v 4 Abarru imxeǧaḍen \add n ibarraniyyen nni iǧan\add* di řwesṭ nsen, dewřen curren s umeẓri u bdan ayt n Israil ɛawed ad cettcan, nnan: “Wi d aneɣ ɣa iwcin aysum? \x ◘ \xo 11:4 \xt Uf. 12:38; 16:3; Izhd. 106:14; 1 Kur. 10:6\x*
\v 5 Nɛeqqeř ɛad x iseřman nni necca di Miṣra baṭeř u x řexyar d ddellaɛ d řebṣeř yuẓɣen d řebṣeř d ticcart.
\v 6 Řexxu řeɛmur nneɣ uẓɣen uca war din walu mɣir ‘manna’-ya zzat i tiṭṭawin nneɣ!”
\v 7 Tuɣa ‘manna’ ittemcabeh di zzariɛet n řqeṣbur uca ccuf nnes amecnaw ccuf n \add userɣaɣ acemřař qqaren as\add* ‘bᵉdula’. \x ◘ \xo 11:7 \xt Uf. 16:14, 31; Izhd. 78:24; Yḥ. 6:31, 49\x*
\v 8 Řgens iffeɣ, immsebḍa uca yrun \add tt\add* uca ḥaryen \add tt\add* sadu tsirt niɣ ddzen \add tt\add* s wezduz uca \add xenni\add* ssenggʷen tt di arwa uca ggin zzayes tifḍirin. Tuɣa aředdi nnes am min inggʷan s zzect.
\v 9 Xmi dd-ihekkwa nnda x řmargeḥ n řɛeskar, \add xenni\add* thekkʷa-dd xas ‘manna’ \add ɛawed\add*.
\v 10 Uca isřa Musa aqa řgens isɣuy, řaǧ awarni inneɣni, kuř ijj ɣar wadaf n uqiḍun nnes. Yarɣa weɣḍab n SIDI aṭṭas, uca tuɣa man aya uřa d tuɛeffna di tiṭṭawin n Musa.
\v 11 Inna Musa i SIDI: “Mayemmi teggid řɣar deg umsexxar nnec u mayemmi war ufiɣ řxaḍar di tiṭṭawin nnec, umi xafi dd-tessarsed ddqeř n marra řgens-a?
\v 12 Ma necc deyseɣ \add balak\add* s marra řgens-a? Niɣ necc i-t-i-dd yurwen, maḥend tzemmared ad ayi tinid: ‘Awyi t deg wecyun nnec!’, am wenni issuṭṭuḍen yarebbu aseymi, ɣar temmurt min xef tejjuǧed Cek i řejdud nnes.
\v 13 Zi manis \add d asen-dd\add* ɣa yawyeɣ aysum i ɣa wceɣ \add d macca\add* i marra řgens-a? Minzi nitni sɣuyyun-dd ɣari, qqaren: ‘Ewc aneɣ aysum i ɣa necc!’
\v 14 Necc weḥḥdi war zemmareɣ ad arbuɣ řgens-a marra, aqa man aya idqeř xafi aṭṭas.
\v 15 Mařa dayi teggid ammu, necc ttzawageɣ ad ayi tenɣed \add ḥsen\add*, mařa ufiɣ arḍa di tiṭṭawin nnec, \add xenni\add* necc war ẓarreɣ řeɣben inu \add ɛad\add* ktar!”
\m 
\v 16 Xenni inna SIDI i Musa: “Smun ayi-dd sebɛin n yeryazen zeg imɣaren n Israil, inni tessned cek d imɣaren n řgens u d imeḥḍayen. Awyi ten-dd ɣar Uqiḍun n Umsagar uca ejj iten ad din bedden zzatek.
\v 17 \add Xenni\add* Necc ad hwiɣ uca ad kik ssiwřeɣ. Ad ksiɣ zi Arruḥ i xak iǧan uca ad xasen t ssarseɣ. \add Ammu i kik ɣa\add* arbun ddqeř n řgens-a, maḥend war t tarebbud ca weḥḥdek.
\v 18 Ad tinid i řgens: ‘Sqeddsem ixef nwem i tiwecca, \add xenni\add* ad teccem aysum, minzi aqa trum deg imezzuɣen n SIDI, tennam: Wi d aneɣ ɣa iwcen ad necc aysum? Tuɣa-neɣ mliḥ di Miṣra! \add S uya\add* i d awem ɣa iwc SIDI aysum ad teccem.
\v 19 War t tᵉttettem ijj n wass \add waha\add* uřa d tnayen n wussan, niɣ xemsa n wussan, niɣ ɛecra n wussan, niɣ ɛicrin n wussan,
\v 20 \add maca\add* \add marra\add* ussan n uyur ař d awem dd-iffeɣ zeg wenzaren nwem uca ad zzayes tɛiffem, umi tenḍarem SIDI wenni iǧan di řwesṭ nwem, uca trum zzat i uɣembub nnes, tennam: Mayemmi \add ɛad\add* dd-neffeɣ zi Miṣra?’” \x ◘ \xo 11:20 \xt Řxř. 21:5 \x*
\m 
\v 21 Uca Musa inna: “Řgens-ya, di řwesṭ nsen i ǧiɣ, aqa-t di setta-ařaf n yeryazen x iḍaren uca Cek teqqared: ‘Ad asen wceɣ aysum uca ad \add zzayes\add* ccen ijj n uyur amen ikmeř!’
\v 22 \add Mařa\add* ɣarṣen asen i \add marra\add* wuǧi d ifunasen, ma ad yiři cfa asen? \add Niɣ mařa\add* ssmunen asen marra iseřman n řebḥar, ma ad yiři cfa asen?” \x ◘ \xo 11:22 \xt Yḥ. 6:7 \x*
\v 23 Inna SIDI i Musa: “Ma \add xenni\add* yebri ufus n SIDI? Řexxu \add xenni\add*, ad tẓared ma ad iqfeř awař nnes niɣ lla!” \x ◘ \xo 11:23 \xt Ica. 50:2; 59:1\x*
\m 
\v 24 Iffeɣ-dd Musa uca inna awařen n SIDI i řgens uca issmun sebɛin n yeryazen zeg imɣaren n řgens uca issbedd i-ten am dd-nnḍen i Uqiḍun.
\v 25 \add Xenni\add* ihwa-dd SIDI deg useynu uca issiweř akides uca iksi zi Arruḥ nni tuɣa xas uca issars i-t x sebɛin n yeryazen, \add x\add* imɣaren. Uca imsar, umi tuɣa xasen Arruḥ, \add bdan\add* ad nebban, maca awarni i uya war iqqim ɛad.
\m 
\v 26 Uca qqimen tnayen n yeryazen di řmargeḥ n řɛeskar, ijjen qqaren as Ildad u wenneɣni qqaren as Midad uca Arruḥ n SIDI tuɣa-t xasen, \add minzi\add* nitni aqa aten zeg inni yuran, \add maca\add* war dd-ffiɣen ɣar Uqiḍun uca tuɣa ttnebban di řmargeḥ n řɛeskar.
\v 27 Yuzzeř-dd ijj n uḥenjir uca ixebbar man aya i Musa, inna: “Ildad d Midad ttnebban di řmargeḥ n řɛeskar.”
\v 28 Yarra-dd Yacuwa, mmis n Nun, \add ijjen\add* zeg ibřiɣen ittfarzen, inna: “Sidi inu, Musa, ḥarrem i-ten!”
\v 29 Inna as Musa: “Ma cek tecḍared di ṭṭweɛ inu? Mři marra řgens n SIDI tuɣa-t marra d inabiyyen, iři igga xasen SIDI Arruḥ nnes!”
\m 
\v 30 Idweř-dd Musa ɣar řmargeḥ n řɛeskar, netta d imɣaren n Israil.
\m 
\v 31 \add Xenni\add* yusa-dd ijj n usemmiḍ, \add issekkar i-t\add* SIDI, indeh-dd ijḍaḍ qqaren as ‘tsalwa’ zi řebḥar uca inḍar i-tent x řmargeḥ n řɛeskar, ticři n webrid n ijj n wass ɣar ijj n tma d ticři n webrid ɣar tma nneɣni, deg wenneḍ n řmargeḥ n řɛeskar, ař ɛřayen tnayen n iɣaǧen x wudem n temmurt. \x ◘ \xo 11:31 \xt Uf. 16:13; Izhd. 78:26\x*
\v 32 Ikkar řgens uca ass \add nni\add* ikmeř d ǧiřet \add nni\add* tekmeř d marra ass i t-i-dd iḍfaren yrun nitni ijḍaḍ qqaren as ‘tsalwa’. Wenni ɣares drus, iksi ɛecra iḥumiren. Bezzɛen tent qibač nsen x tiru i innḍen i řmargeḥ n řɛeskar.
\v 33 Mintra aysum ɛad jar teɣmas nsen, qbeř ma ad t ffẓen, yarɣa weɣḍab n SIDI x řgens uca SIDI iwta řgens s ict n tecti temɣar aṭṭas. \x ◘ \xo 11:33 \xt Izhd. 78:30, 31 \x*
\v 34 Isemma \add Musa\add* amcan nni ‘Qabarut-Hata’awat’, minzi dinni i neḍřen řgens i tuɣa immeẓren \add ammu\add*.
\v 35 Zi Qabarut-Hata’awat ifsi řgens iqiḍan \add nnes\add*, \add uyuren\add* ɣar Ḥaḍayrut uca qqimen di Ḥaḍayrut.
\b
\b
\c 12
\s1 Řbarṣ n Maryam
\m 
\v 1 Tessiweř Maryam ak-d Harun x Musa di ssibbet n temɣart Takucit nni tuɣa dd-yiwi, minzi netta yiwi-dd ict n temɣart Takucit. \f ◼ \fr 12:1 \fk Takucit\ft - ixs ad yini ‘tamɣart zi temmurt n Kuc’. Tammurt n Kuc tuɣa-tt di Ifriqiyya mani teǧa iḍa tammurt n Ssudan d temmurt n Itiyupiyya (Al-Habac).\f*
\v 2 Uca nnan: “Ma issiweř SIDI zi Musa waha? Ma war zzayneɣ issiweř ɛawed?” Uca isřa SIDI \add man aya\add*.
\v 3 Tuɣa Musa d aryaz amwaḍeɛ aṭṭas, ktar zi marra iwdan i iddaren x temmurt.
\v 4 Deɣya issiweř SIDI ak-d Musa d Harun d Maryam: “Ffɣem kenniw s třata, \add uyurem\add* ɣar Uqiḍun n Umsagar!” Uca ffɣen-dd s třata.
\v 5 \add Xenni\add* ihwa-dd SIDI deg uqellij n useynu uca ibedd ɣar wadaf n Uqiḍun, iřaɣa i Harun d Maryam. Ffɣen-dd nitni s tnayen.
\v 6 Uca inna asen Netta: “Sřem xenni i wawařen inu! Mařa din jar awem ijj n unabi, ad as ssecneɣ Ixef inu, Necc, SIDI, s ij n řewḥiy \add uca\add* ad kis ssiwřeɣ s ict n tarjit.
\v 7 \add Maca\add* war tteggeɣ \add amenni\add* s umsexxar inu Musa, aqa netta d amtiqqi di taddart inu tekmeř. \x ◘ \xo 12:7 \xt Ɛbr. 3:2\x*
\v 8 Necc ssiwřeɣ akides zeg uqemmum ɣar uqemmum, war iǧi s řemɛani innufaren. Aqa iẓra addud n SIDI. Mayemmi war teggʷidem zeg umsexxar inu u \add mayemmi\add* i tessiwřem \add ammu\add* x Musa?” \x ◘ \xo 12:8 \xt Uf. 33:11; Aɛwd. 34:10 \x*
\m 
\v 9 \add Xenni\add* yarɣa xasen weɣḍab n SIDI uca iruḥ.
\v 10 Uca aseynu iffeɣ x Uqiḍun, uca xzar, Maryam dayes řehřac n řbarṣ, aqa-tt d tacemřařt am wedfeř. Uca Harun inneqřeb-dd ɣar Maryam, u xzar, aqa nettat dayes řbarṣ.
\m 
\v 11 Uca inna Harun i Musa: “A, sidi inu, war xaneɣ srussi ddenb i negga s tefɣuri umi dayes nexḍa!
\v 12 War tt ttejji ad tedweř am umettin i zi ittwacc wezyen n arrimet nnes am dd-teffeɣ zi řemřawet n yemmas.”
\v 13 Iřaɣa Musa i SIDI, inna: “\add A\add* Arebbi, ttzawageɣ ad tt tessgenfid!”
\v 14 Inna SIDI i Musa: “Ma mařa babas aqa inxar deg wudem nnes, ma war tᵉseḍḥi sebɛa n wussan? Ejj i-tt ad tᵉttwassuffeɣ zi řmargeḥ n řɛeskar sebɛa n wussan uca awarni as ad tᵉttwaqbeř \add ɛawed\add*.”
\v 15 Tᵉttwassuffeɣ Maryam sebɛa n wussan barra i řmargeḥ n řɛeskar uca řgens war ikkis iqiḍan nnes ařami tᵉttwaqbeř Maryam \add ɛawed\add*.
\v 16 Awarni man aya ifsi řgens iqiḍan nnes, \add yuyur\add* zi Ḥaḍayrut uca wtin iqiḍan nsen di řexřa n Faran.
\b
\b
\c 13
\s1 Tenɛac n ibergagen
\m 
\v 1 Issiweř SIDI ak-d Musa, inna:
\m 
\v 2 “Sekk iryazen zzatek ḥima ad bergagen tammurt n Kenɛan, tenni i ɣa wceɣ i ayt n Israil. I kuř taqbič n řejdud ad tessekkem ijj n weryaz, kuř ijj \add ad yiři\add* d řḥakem jar asen.” \f ◼ \fr 13:2 \fk kuř taqbič n ibabaten\ft - s Tɛibranit ‘kuř taqbič n ibabaten nnes’.\f*
\v 3 Musa issekk i-ten zi řexřa n Faran, x řumur n SIDI. Tuɣa marra iryazen \add nni\add* d izeǧifen n ayt n Israil.
\v 4 Aqa d ina d ismawen nsen:
\b
\m zi teqbič n Rubin, Cammuɛ, mmis n Zakkur,
\m 
\v 5 zi teqbič n Cimɛun, Cafat, mmis n Axuri,
\m 
\v 6 zi teqbič n Yahuda, Kalib, mmis n Yafunni,
\m 
\v 7 zi teqbič n Issakar, Yijɛal, mmis n Yusuf,
\m 
\v 8 zi teqbič n Ifrayim, Hucaɛ, mmis n Nun, \f ◼ \fr 13:8 \fk Hucaɛ\ft - isem wanita ixs ad yini ‘asenjem’. Tuɣa isem wanita d yisem amezwaru n Yacuwa wenni issidfen řgens n Israil di temmurt n Kenɛan.\f*
\m 
\v 9 zi teqbič n Binyamin, Falṭi, mmis n Rafu,
\m 
\v 10 zi teqbič n Zabulun, Jaddiyil, mmis n Sudi,
\m 
\v 11 zi teqbič n Yusuf, i teqbič n Manassa, Jaddi, mmis n Susi,
\m 
\v 12 zi teqbič n Dan, Ɛammiyil, mmis n Jamalli,
\m 
\v 13 zi teqbič n Acir, Satur, mmis n Mixayil,
\m 
\v 14 zi teqbič n Naftali, Naḥbi, mmis n Wafsi,
\m 
\v 15 zi teqbič n Jad, Ja’uyil, mmis n Maki.
\b
\m 
\v 16 Aqa ina d ismawen n yeryazen nni issekk Musa ḥima ad bergagen tammurt uca Musa iřaɣa i Huciɛa, mmis n Nun, s yisem n Yacuwa.
\v 17 Issekk i-ten Musa ḥima ad bergagen tammurt n Kenɛan, inna asen: “Ařyem ssiha ař \add Tammurt n\add* Ljanub uca ařyem xenni ɣar idurar,
\v 18 uca xzarem mammec teǧa temmurt d řgens i dayes izeddɣen, ma ijhed niɣ iḍɛef \add i yeǧa\add*, ma \add aqa din\add* drus niɣ aṭṭas.
\v 19 \add Xzarem ɛawed\add* mammec teǧa temmurt i di izeddeɣ \add řgens\add*, ma \add tammurt\add* d taṣebḥant niɣ d taɛeffant i \add teǧa\add*, u mammec ǧant tneddam i di izeddeɣ \add řgens\add*, ma \add zeddɣen di\add* řemrageḥ n iqiḍan niɣ \add di\add* tneddam ifaryen \add s iɣebřawen\add*.
\v 20 \add U ɛawed\add* mammec teǧa temmurt, ma tessɣemmi niɣ tuẓeɣ, ma aqa din ticejjura niɣ lla. Ggem taryast uca ksim \add ca\add* zi řɣiǧet n temmurt. Ussan nni tuɣa aten d ussan n tmenzut n uḍiř.”
\v 21 Uca nitni geɛɛden uca bergagen tammurt zi řexřa n Ṣin ař Raḥub, mani ɣa tiwḍed ɣar Ḥamat.
\v 22 Geɛɛden \add ɛad ktar\add* ɣar \add Temmurt n\add* Ljanub uca iwḍen ɣar Ḥabrun. Dinni i tuɣa Aximan, Cicay d Talmay, \add nitni\add* d iḥenjiren n Ɛanaq. Ḥabrun tuɣa tᵉttwabna sebɛa n iseggʷusa qbeř Ṣuɛan di Miṣra.
\v 23 \add Xenni\add* iwḍen ař taɣzurt n Ackul uca ssenni kksen ict n tezremt s yijj n uzekkun n uḍiř wenni dd-iwyen s tnayen s yijj n uzeǧaḍ n trebbut. \add Kksen ɛawed\add* zeg aremmam u zi tazart. \f ◼ \fr 13:23 \fk Ackul\ft - isem wanita ixs ad yini ‘azekkun’.\f*
\v 24 Qqaren as i wemcan nni taɣzurt n Ickul, \add isem wanita ixs ad yini\add* ‘taɣzurt n Uzekkun’, di ssibbet n uzekkun \add n uḍiř\add* nni qessen ayt n Israil din.
\b
\m 
\v 25 Umi kemmřen arebɛin n wussan, dewřen-dd zeg ubergag n temmurt.
\v 26 Ɛeqben nitni uca usin-dd ɣar Musa d Harun u ɣar marra tamesmunt n ayt n Israil di řexřa n Faran, ɣar Qadac, uca wcin řexbar i marra tamesmunt uca ssecnen asen řɣiǧet n temmurt. \f ◼ \fr 13:26 \fk Ɛeqben\ft - s Tɛibranit ‘Uyuren’.\f*
\v 27 Ḥajan as, nnan: “Aqa nudef ɣar temmurt nni mani d aneɣ tessekked. S tidett tfeyyeḍ s uɣi d tamment u tanita d řɣiǧet nnes. \x ◘ \xo 13:27 \xt Uf. 3:8; 33:3\x*
\v 28 Maca řgens, wenni izeddɣen di temmurt, ijhed u tineddam ɣarsent iɣebrawen mɣarent aṭṭas, u neẓra ɛawed arrawen n Ɛanaq.
\v 29 Ayt n Ɛamaliq zeddɣen di Temmurt n Ljanub, u Iḥittiyyen d Iyabusiyyen d Imuriyyen zeddɣen deg idurar u ayt n Kenɛan zeddɣen ɣar řebḥar u x tma n L’Urdun.”
\v 30 Xenni issesqar Kalib řgens zzat i Musa, inna: “Ejj aneɣ ad ngeɛɛed s jjehd uca ad tt neṭṭef d řwart, \add minzi\add* nzemmar as neccin!”
\v 31 \add Maca\add* iryazen nni geɛɛden akides, nnan: “War nzemmar ad ngeɛɛed ḍidd i řgens nni, minzi aqa ijhed xaneɣ aṭṭas.”
\v 32 \add Ammu\add* i dd-iwyen ijj n řexbar war iḥřin i ayt n Israil x temmurt nni x tuɣa ttbergagen, nnan: “Tammurt x manis nekka ḥima ad tt nbergeg, aqa d ict n temmurt tsarreḍ imezdaɣ nnes uca marra iwdan nni neẓra, aqa aten d iryazen n waddad imɣar.
\v 33 Aqa neẓra din ‘nifilim’, \add ixs ad yini\add* ‘jjwaheř iwḍan’, ayt n Ɛanaq, arrasa n jjwaheř iwḍan. Tuɣa neccin di tiṭṭawin nneɣ amecnaw tamurɣi uca ammu i dd asen nettban di tiṭṭawin nsen.” \f ◼ \fr 13:33 \fk nifilim\ft - aqa-ten lmalakat i iwḍan zeg wemcan nsen deg ujenna umi ddenben ḍidd i SIDI. Xzar Amz. 6:4. \fk tamuɣri\ft - s Tɛibranit ‘tamuɣri iřeḥḥfen’.\f*
\b
\b
\c 14
\s1 Tiggʷudi n řgens zi řɛedyan
\m 
\v 1 Marra tamesmunt tebda tesɣuyyu s jjehd uca řgens iru marra ǧiřet nni.
\v 2 Marra ayt n Israil tuɣa ttnedqamen ḍidd i Musa u ḍidd i Harun uca tenna as marra tmesmunt: “Meɛlik qaɛ nemmut di temmurt n Miṣra!” niɣ: “Meɛlik qaɛ nemmut di řexřa-ya!”
\v 3 “Mayemmi d aneɣ dd-yiwi SIDI ɣar temmurt-a ḥima ad newḍa s ssif u \add xenni\add* ad dewřent temɣarin nneɣ d tarwa nneɣ d takeccaḍt? Ma war yeǧi ḥsen zeɛma ad neɛqeb ɣar Miṣra?”
\v 4 Uca nnan ijj i wenneɣni: “Ejj aneɣ ad negg ijj d azeǧif \add xaneɣ\add* uca ad neɛqeb ɣar Miṣra!”
\m 
\v 5 \add Řexdenni\add* wḍan Musa d Harun x uɣembub nsen zzat i wudem n marra agraw n tmesmunt n ayt n Israil.
\v 6 Yacuwa, mmis n Nun, d Kalib, mmis n Yafunni, inni tuɣa zeg inni tuɣa ittbergagen x temmurt, carrgen arruḍ nsen.
\v 7 Nitni ssiwřen ɣar marra tamesmunt n ayt n Israil, nnan: “Tammurt nni x nekka maḥend ad tt nbergeg, aqa-tt d ict n temmurt mliḥ aṭṭas.
\v 8 Mařa SIDI issfarnen ɣarneɣ, Netta ad aneɣ dd-yawi ɣar temmurt-a uca ad aneɣ tt iwc, ict n temmurt ifeyyḍen s uɣi d tamment.
\v 9 Maca war ttiřim d imɣewwɣen ḍidd i SIDI uca war tteggʷedem ca zi řgens n temmurt-a, minzi aqa aten d aɣrum nneɣ. Tiři nsen teffeɣ-dd sennej nsen, aqa SIDI akidneɣ, war zzaysen tteggʷdem ca!”\x ◘ \xo 14:9 \xt Aɛwd. 20:3\x*
\m 
\v 10 \add Maca řami\add* tessiweř marra tamesmunt belli ittxeṣṣa ad ten arejmen, iban-dd uɛuǧi n SIDI deg Uqiḍun n Umsagar zzat i marra ayt n Israil.
\m 
\v 11 Inna SIDI i Musa: “Ař meřmi d ayi ɣa isɛar řgens-a? Ař meřmi war d ayi ttimnen s marra řeɛřamat nni ggiɣ di řwesṭ nsen?
\v 12 Necc ad ten wteɣ s ṭṭaɛun uca ad xasen kkseɣ řwart uca ad cek ggeɣ d ijj n řgens d ameqqran, ijhed xasen.”
\v 13 Inna Musa i SIDI: “Ad sřen Imiṣriyyen man aya, minzi Cek tessuffɣed řgens-a s jjehd nnec zi řwesṭ nsen.\x ◘ \xo 14:13 \xt Uf. 32:12\x*
\v 14 uca ad t inin i imezdaɣ n temmurt-a, inni isřin belli Cek, \add a\add* SIDI, di řwesṭ n řgens-a, belli Cek, a SIDI, tbaned-dd \add amecnaw\add* udem deg wudem, belli aseynu nnec ittbedda sennej nsen u belli Cek teggured zzat i wudem nsen deg ijj n uqellij n useynu s uziř uca s ǧiřet deg ijj n uqellij n tmessi. \f ◼ \fr 14:14 \fk udem deg wudem\ft - s Tɛibranit ‘tiṭṭ di tiṭṭ’.\f*  \x ◘ \xo 14:14 \xt Uf. 13:21; 40:38\x*
\v 15 Mařa tenɣid řgens-a am yijj n weryaz, xenni řegnus nni isřin x usemɣar nnec ad ssiwřen ad inin:
\v 16 ‘Minzi SIDI war izemmar ad issidef řgens-a di temmurt nni x ijjuǧ \add ad asen tt iwc\add*, aqa s uyenni d asen iɣarṣ di řexřa!’ \x ◘ \xo 14:16 \xt Aɛwd. 9:28 \x*
\v 17 Řexxu xenni, ejj ad yiři jjehd n Sidi inu imɣar am mammec tuɣa tessiwřed, tennid:
\v 18 ‘SIDI ɣares ttasiɛ n řxaḍar uřa d aṭṭas n tmexsiwt icewwaren. Aqa yarebbu řmuɛṣiyyet d uxeṭṭu \add nneɣ\add* u Netta war ittbarri wenni itteggen ddenb \add u\add* isseɛɛdu řmuɛṣiyyet n ibabaten ɣar iḥenjiren \add nnes\add* ař \add jjiř\add* wiss třata d \add jjiř\add* wiss arebɛa.’ \x ◘ \xo 14:18 \xt Uf. 20:5; 34:6; Aɛwd. 5:9; Izhd. 86:15; 103:8; 145:8; Yun. 4:2\x*
\v 19 Ɣfar i řgens-a řmuɛṣiyyet nnes ɛlaḥsab řemɣaret n tmexsiwt nnec icewwaren u am mammec themřed ak-d řgens-a zi temmurt n Miṣra ař danita!”
\m 
\v 20 Inna SIDI: “Necc ɣfareɣ asen ɛlaḥsab awař nnec.
\v 21 S tidett \add am\add* ddareɣ Necc, aqa marra tammurt ad tᵉttwaccur s uɛuǧi n SIDI!
\v 22 Minzi marra iryazen nni iẓrin aɛuǧi inu d řeɛřamat inu i ggiɣ di Miṣra u di řexřa, d yinni d ayi iqeǧben di řexřa \add ɛad\add* ɛecra n twařawin u war sřin i tmijja inu,
\v 23 war ẓarren tammurt nni x jjuǧeɣ i řejdud nsen \add ad asen tt wceɣ\add*, \add wah,\add* marra inni d ayi issdduqqzen \add ammu\add*, war tt ẓarren. \x ◘ \xo 14:23 \xt Aɛwd. 1:35, 36 \x*
\v 24 \add Maca\add* ad ssiwḍeɣ amsexxar inu Kalib ɣar temmurt mani tuɣa yudef \add qbeř\add* uca ad tt warten tarwa nnes, minzi tuɣa akides ijj n arruḥ nneɣni uca netta iḍfar ayi nican. \x ◘ \xo 14:24 \xt Yac. 14:8, 9\x*
\v 25 Aqa ayt n Ɛamaliq d ayt n Kenɛan zeddɣen di řewḍa n teɣzurt. Ad dd-tdewřem tiwecca uca ad tekksem iqiḍan nwem \add ssa\add*, ffɣem ɣar řexřa, \add uyurem\add* deg webrid ɣar Řebḥar n Telga.”
\b
\m 
\v 26 Issiweř SIDI ak-d Musa d Harun, inna:
\m 
\v 27 “Ař meřmi ɣa teqqim tmesmunt-a taɛeffant tᵉttnedqam xafi? Anedqem n ayt n Israil i zi xafi ttnedqamen, aqa sřiɣ t. \x ◘ \xo 14:27 \xt Izhd. 106:26 \x*
\v 28 Ini asen: ‘S tidett am ddareɣ Necc, iqqar SIDI, mařa war d awem tteggeɣ am mammec d awem sřiɣ s imezzuɣen inu min tennam kenniw. \x ◘ \xo 14:28 \xt Řxř. 26:65; 32:11 \x*
\v 29 Řxecbat nwem ad wḍant di řexřa-ya, \add řxecbat n\add* marra inni ittwaḥesben \add n řgens\add*, marra řqedd n iḥenjiren nwem zi ɛicřin iseggʷusa sennej i tuɣa xafi ittnedqamen. \x ◘ \xo 14:29 \xt Aɛwd. 1:35; Ɛbr. 3:17 \x*
\v 30 Kenniw war tᵉttidfem ca ɣar temmurt min xef ssgeɛɛdeɣ afus inu \add maḥend ad jjaǧeɣ\add* ad kenniw ggeɣ ad dayes tzedɣem, mɣir Kalib, mmis n Yafunni, d Yacuwa, mmis n Nun. \x ◘ \xo 14:30 \xt Yac. 14:6 \x*
\v 31 Tarwa nwem i xef tennam: ‘Ad ttwakeccḍen!’, Necc ad ten ssidfeɣ dayes uca nitni ad ssnen tammurt nni tenḍarem kenniw ammu s useḥqar.
\v 32 \add Maca\add* řxecbat nwem, \add wah,\add* kenniw \add simant nwem\add*, ad tewḍam di řexřa-ya,
\v 33 uca iḥenjiren nwem ad tellɛen di řexřa-ya řmijař n arebɛin n iseggʷusa uca kenniw ad \add kiwem\add* tarbum farq-ccɣeř nwem ař ɣa fnant řxecbat nwem di řexřa.
\v 34 Anect i řqedd n wussan i tuɣa tᵉttbergagem tammurt, \add iqqar\add* arebɛin n wussan - aqa ijj n wass d ijj n useggʷas - ad tarbum řmuɛṣiyyet nwem, řmijař n arebɛin n iseggʷusa. Kenniw ad tessnem aqa Necc beɛɛdeɣ \add xawem\add*. \x ◘ \xo 14:34 \xt Izhd. 95:1 \x*
\v 35 Necc \add d\add* SIDI ssiwřeɣ: Mařa war tteggeɣ ammu ak-d marra tamesmunt-a taɛeffant tenni ikksen awař xafi: ad mmten di řexřa-ya, ad mmten din!”
\m 
\v 36 Iryazen nni issekk Musa maḥend ad bergagen tammurt, \add řami\add* dd-dewřen, tamesmunt am tekmeř tedweř ḍidd nnes umi nitni ssiwřen s řɣar x tammurt,
\v 37 aqa iryazen nni ibehdřen tammurt, mmuten s ict n jjriḥect zzat i wudem n SIDI. \x ◘ \xo 14:37 \xt 1 Kur. 10:10; Yah. 5\x*
\v 38 \add Maca\add* Yacuwa, mmis n Nun, d Kalib, mmis n Yafunni, qqimen ddaren jar iryazen nni iruḥen ad bergagen tammurt.
\b
\m 
\v 39 Issiweř Musa awařen-a ɣar marra ayt n Israil. Iḥzen \add xenni\add* řgens aṭṭas.
\v 40 Uca nitni kkaren zic uca uřyen ař taqiccat n wedrar, nnan: “Aqa-neɣ da uca ad ngeɛɛed ɣar wemcan min xef issiweř SIDI, minzi neccin aqa nexḍa!”
\v 41 Maca Musa inna: “Mayemmi tᵉttɛeddam ammu řumur n SIDI? Man aya war iɛeddu! \x ◘ \xo 14:41 \xt Aɛwd. 1:41\x*
\v 42 War ttgeɛɛidem ca minzi SIDI war ittiři di řwesṭ nwem. War ttejjim ixef nwem ad texsarem zzat i wudem n řɛedyan nwem.
\v 43 Minzi ayt n Ɛamaliq d ayt n Kenɛan aqa aten din zzat nwem uca ad tewḍam kenniw s ssif minzi kenniw tiggʷejem x SIDI. S uya SIDI war kiwem ittiři.”
\v 44 Maca nitni tuɣa ttuffen maḥend ad dd-ařyen ař taqiccat n wedrar. \add Maca\add* Ttabut n Řɛahd n SIDI d Musa war ffiɣen zi řwesṭ n řmargeḥ n řɛeskar.
\v 45 \add Xenni\add* hwan-dd ayt n Ɛamaliq d ayt n Kenɛan nni tuɣa izeddɣen deg wedrar nni uca arenyen ten u řebzen ten ař Ḥurma.
\b
\b
\c 15
\s1 Tiɣarṣa n tmessi
\m 
\v 1 Issiweř SIDI ak-d Musa, inna:
\m 
\v 2 “Siweř ak-d ayt n Israil, ini asen: ‘Xmi ɣa tadfem ɣar temmurt \add mani ɣa\add* tzeddɣem, \add tammurt\add* nni d awem ɣa wceɣ,
\v 3 uca ad tesswejdem \add din\add* ict n tewhibt n tmessi i SIDI, ict n tɣarṣt n wecmaḍ niɣ ict n tewhibt i tɣarṣt i ukemmeř n ijj n lwaɛd niɣ ict n tewhibt s řxaḍar niɣ \add ict n tewhibt\add* i řeɛyudat nwem ittwaggen, maḥend ad tiři d ict n řefwaḥet ittfuḥen i SIDI, zi řebhayem niɣ zeg wuǧi,
\v 4 \add xenni\add* wenni dd ɣa iqeddmen tawhibt nnes i SIDI, ad yawi \add ɛawed\add* ict n tewhibt \add n řɣiǧet\add* zeg ict n teɛcart \add n yijj n ifa\add* n waren azdad ixeǧḍen s yijj n arbeɛ n ijj n uhinu n zzect. \x ◘ \xo 15:4 \xt Lawi 2:1; 6:14\x*
\v 5 Ad tesswejded \add ak-d man aya\add* ijj n arbeɛ n ijj n uhinu n binu am tewhibt n useyyeb i kuř ijj n izmar, \add maḥend ad tiři\add* x tɣarṣt n wecmaḍ niɣ x tewhibt i tɣarṣt,
\v 6 niɣ, \add mařa ad tiři\add* i yijj n icarri, \add xenni\add* ittxeṣṣa ad tesswejded ict n tewhibt \add n řɣiǧet\add* zi tnayen n teɛcuray n ijj n ifa n waren azdad ixeǧḍen s ict n ttuřut n ijj n uhinu n zzect,
\v 7 uca ad tqeddmed \add ɛawed\add* ict n ttuřut n ijj n uhinu n binu am tewhibt n useyyeb, am yict n řefwaḥet ittfuḥen i SIDI.’”
\m 
\v 8 “Xmi ɣa tesswejded ameẓyan n ufunas am tɣarṣt n wecmaḍ niɣ am tewhibt i tɣarṣt \add maḥend ad yiři\add* i ukemmeř n ijj n lwaɛd niɣ am tɣarṣt n řehna i SIDI,
\v 9 \add xenni\add* ittxeṣṣa ad tqeddmed ak-d umeẓyan n ufunas \add ɛawed\add* ict n tewhibt \add n řɣiǧet\add* n třata n teɛcuray n ijj n \add ifa\add* n waren azdad ixeǧḍen deg wezyen n uhinu n zzect,
\v 10 uca ittxeṣṣa \add ɛawed\add* ad dd-tawyed azyen n uhinu n binu am tewhibt n useyyeb, \add am\add* tewhibt n tmessi, ict n řefwaḥet ittfuḥen i SIDI.
\v 11 Ammu i ittxeṣṣa ad ggen i \add kuř\add* afunas, niɣ i \add kuř\add* icarri, niɣ i \add kuř\add* ijj zeg wuǧi, zeg iḥuřiyyen niɣ zeg iɣayḍen.
\v 12 Ɛlaḥsab řqedd \add n imuddaren i tɣarṣt\add* i ɣa tesswejdem, ad teggem ammu i kuř ijj \add n umuddar\add*, ɛlaḥsab řqedd ikemmřen \add n imuddaren\add*.
\v 13 Marra inni dd-ittwaxeřqen di temmurt ad ggen timesřayin-a ammu, xmi dd ɣa qeddmen nitni ict n tewhibt n tmessi, ict n řefwaḥet ittfuḥen i SIDI.
\v 14 Xmi ɣa tafed jar \add marra\add* jjiřat nwem ijj n ubarrani i iqqimen akidwem, niɣ ijjen wenni \add izeddɣen\add* di řwesṭ nwem, aqa netta ad issewjed ict n tewhibt n tmessi, ict n řefwaḥet ittfuḥen i SIDI, \add xenni\add* ad \add tt\add* igg am mammec \add tt\add* tᵉtteggem kenniw.”
\m 
\v 15 \add Ay,\add* agraw \add n řgens\add*, ad din tiři ict n tewṣeyyet, ict n tewṣeyyet i řebda i kenniw u i ubarrani nni \add akidwem\add* iqqimen i \add marra\add* jjiřat nwem. Ad yiři ubarrani am mammec \add teǧam\add* kenniw zzat i wudem n SIDI. \x ◘ \xo 15:15 \xt Uf. 12:49; Řxř. 9:14 \x*
\v 16 Ad yiři ijj n uzerf d ict n lfariḍa i kenniw u i ubarrani nni akidwem iqqimen.”
\b
\s1 Imezwura n waren
\m 
\v 17 Issiweř SIDI ak-d Musa, inna:
\m 
\v 18 “Siweř ak-d ayt n Israil uca ini asen: ‘Xmi ɣa tadfem ɣar tammurt mani kenniw ɣa \add y\add*awyeɣ,
\v 19 \add xenni\add* ad imsar, umi ɣa teccem aɣrum \add zi řɣiǧet\add* n temmurt, aqa kenniw ad tessgeɛɛdem ict n tewhibt n usgeɛɛed i SIDI.
\v 20 Zi tmezwarut n warecti nwem ad tessgeɛɛdem ict n temsemment \add am\add* tewhibt n usgeɛɛed. Ad tt tessgeɛɛdem am mammec tessgeɛɛdem tawhibt n usgeɛɛed n unedrar.
\v 21 Zi tmezwarut n warecti nwem ad tqeddmem ict n tewhibt n usgeɛɛed i SIDI di \add marra\add* jjiřat nwem.’”
\b
\s1 Ddenb war iǧi neɛmada
\m 
\v 22 “Mařa tweddarem u war tᵉtteggem marra řumurat-a i tuɣa issawař SIDI ak-d Musa
\v 23 - marra min d awem yumur SIDI s tsexxart n Musa zeg wass min zi \add t\add* yumur SIDI, ssenni d tsawent, di \add marra\add* rejyuř nwem -
\v 24 \add xenni\add* ad imsar, \bd mařa ittwagg s uweddar\bd* barra i tiṭṭawin n tmesmunt, aqa tamesmunt marra ad tessewjed ijj n ufunas, ameẓyan n tfunast, am tɣarṣt n wecmaḍ, \add am\add* ict n řefwaḥet ittfuḥen i SIDI ak-d tewhibt nnes \add n řɣiǧet\add* d tewhibt nnes n useyyeb ɛlaḥsab lfariḍa u ak-d yijj n umyan zeg iɣayḍen am tɣarṣt n ddenb.
\v 25 \add Xenni\add* ad igg ukehhan asřaḥ i marra tamesmunt n ayt n Israil uca ad asen ittwaɣfar, minzi man aya imsar zeg uweddar, uca nitni qeddmen tawhibt nsen, ict n tewhibt n tmessi i SIDI, uřa d taɣarṣt nsen n ddenb, zzat i wudem n SIDI. \f ◼ \fr 15:25 \fk ifdi\ft - xzar Izhd. 78:35.\f*
\v 26 Marra tamesmunt n ayt n Israil ad tᵉttwaɣfar, uřa d abarrani nni izeddɣen di řwesṭ nwem, x umi imsar am iweddar marra řgens.”
\m 
\v 27 “Mařa ijjen bnadem ixḍa am netta iweddar, \add xenni\add* ad dd-issqarreb ict n tɣayḍet n ijj n useggʷas am tɣarṣt n ddenb. \f ◼ \fr 15:27 \fk bnadem\ft - s Tɛibranit ‘řeɛmar’. Ammu uřa di ayat wiss 28 d 30.\f*  \x ◘ \xo 15:27 \xt Lawi 4:27 \x*
\v 28 Akehhan ad igg aṣřaḥ zzat i wudem n SIDI x bnadem nni tuɣa iweddar, am tuɣa ixḍa s uweddar zzat i wudem n SIDI, am xas i ɣa yegg asřaḥ uca \add xenni\add* ad as ittwaɣfar.
\m 
\v 29 Ad \add din\add* yiři ijj n uzerf i wenni iggin \add ca\add* s uweddar, i wenni dd-ixeřqen di temmurt uřa i ubarrani nni izeddɣen di řwesṭ nwem.”
\s1 Ddenb s ufus igeɛɛden
\m 
\v 30 “Maca bnadem nni iggin ca \bd s ufus igeɛɛden\bd*, ma netta ittwaxřeq-dd di temmurt niɣ netta d abarrani, aqa netta iceqqef di SIDI uca bnadem nni ad ittwaqess zi řwesṭ n řgens nnes, \f ◼ \fr 15:30 \fk s ufus issgeɛɛden\ft - man aya ixs ad yini aqa igga i-t s neɛmada.\f*
\v 31 umi isseḥqar awař n SIDI u yarẓa řumur nnes. Bnadem nni ad ittwaqess qaɛ \add zi řgens nnes\add*, řmuɛṣiyyet nnes ad tiři xas.”
\b
\m 
\v 32 \add Řami\add* tuɣa ayt n Israil di řexřa, ufin ijj n weryaz ittḥarwac akeccuḍ deg wass n ssebt.
\v 33 Inni t yufin am tuɣa ittḥarwac akeccuḍ, iwyen t ɣar Musa d Harun d marra tamesmunt.
\v 34 Ggin t di tḥeṭṭut, minzi tuɣa war dd-ibin min zzayes ɣa ggen. \x ◘ \xo 15:34 \xt Lawi 24:12 \x*
\v 35 \add Xenni\add* inna SIDI i Musa: “Aryaz \add nni\add* ad ittwaneɣ nican. Marra tamesmunt ad t tarjem barra i řmargeḥ n řɛeskar.”
\v 36 \add Xenni\add* tessuffeɣ i-t marra tmesmunt barra i řmargeḥ n řɛeskar uca nitni arejmen t ařami immut, am mammec \add t\add* yumur SIDI i Musa.
\b
\s1 Ticarcifa n řidaret
\m 
\v 37 Issiweř SIDI ak-d Musa, inna:
\m 
\v 38 “Siweř ak-d ayt n Israil uca ini asen, ad ggen i yixef nsen ticarcifa ɣar tɣemmura n warruḍ nsen di \add marra\add* jjiřat nsen uca ad ggen ijj n ufiřu d adeḥmi ɣar tcarcifa, tinni ɣar tɣemmura. \x ◘ \xo 15:38 \xt Aɛwd. 22:12; Mt. 23:5 \x*
\v 39 Ad yiři \add ufiřu\add* ɣar tcarcift, ḥima ad twařam afiřu nni uca ad tidarem di marra řumurat n SIDI uca ad tent teggem u war tḍeffarem \add ccehwat n\add* wuřawen nwem d tiṭṭawin nwem, inni awarni asent tennumem ad tessefsedem ixef nwem,
\v 40 \add u\add* ḥima ad txarrṣem di řumurat inu, ad \add zzaysent\add* teggem, \add maḥend\add* ad tiřim tᵉttwaqeddsem zzat i AREBBI nwem.
\v 41 Necc d SIDI, AREBBI nwem wenni kenniw dd-issuffɣen zi temmurt n Miṣra ḥima ad iřiɣ d AREBBI nwem. Necc d SIDI, AREBBI nwem!”
\b
\b
\c 16
\s1 Aɣewweɣ n Quraḥ d Datan d Abiram
\m 
\v 1 Quraḥ, mmis n Yiṣhar, mmis n Qahat, mmis n Lawi, ak-d Datan d Abiram, tnayen n iḥenjiren n Iliyab, d Un, mmis n Falat, iḥenjiren n Rubin, iwyen \add iryazen\add*, \x ◘ \xo 16:1 \xt Řxř. 26:9; 27:3; Yah. 11\x*
\v 2 uca kkaren ḍidd i Musa, \add jmiɛ\add* ak-d iryazen \add nneɣni\add* zeg ayt n Israil, mitayen u-xemsin n řḥukkam n tmesmunt, aqa aten zeg inni dd-ittwařaɣan ɣar umuni, iryazen s ccan.
\v 3 Nitni munen ḍidd i Musa d Harun, nnan asen: “Cfa awem kenniw! Minzi marra tamesmunt, \add wah,\add* marra nitni d imqeddasen uca SIDI di řwesṭ nsen. Mayemmi tessuɛřam ixef nwem sennej i wegraw \add n řgens\add* n SIDI?”
\m 
\v 4 Umi isřa Musa \add i man aya\add*, iwḍa x wudem nnes.
\v 5 Uca issiweř ak-d Quraḥ d marra abarru nnes, inna: “Tiwecca ad isscen SIDI wenni iǧan nnes d wenni \add iǧan\add* d amqeddas d wenni i ɣares dd ɣa issqarreb. Wenni ifarz Netta, d wenni i dd ɣa issqarreb Netta ɣares.
\v 6 Ggem aya! Ejj Quraḥ d marra abarru nnes ad awyen timejmarin.
\v 7 Tiwecca ggem xasent \add řefḥem i\add* tmessi, sarsem xas řebxur zzat i wudem n SIDI. \add Xenni\add* ad imsar belli aryaz nni ixḍar SIDI, ad yiři d amqeddas. Aqa truḥem tiggʷijem, ayt n Lawi!”
\v 8 Inna Musa i Quraḥ: “Sřem řexxu, ttzawageɣ, kenniw, ayt n Lawi!
\v 9 Ma war xawem icfi umi kenniw issfarz AREBBI n Israil x tmesmunt n Israil maḥend ad kenniw ɣares dd-issqarreb, ḥima ad tsexxarem di Tzeddiɣt n SIDI uca \add ḥima\add* ad tbeddem zzat i wudem n tmesmunt maḥend ad ten tsexxarem?
\v 10 Netta issqarreb i cek-dd \add ɣares\add*, cek d marra aytmac, ayt n Lawi, \add jmiɛ\add* akidek. Ma tarezzum \add řexxu\add* ɛawed tukehhant?
\v 11 S uya, cek d marra abarru nnec, aqa kenniw tmunem ḍidd n SIDI, minzi min iɛna Harun, min iɛna ḥima ad xas tennedqem?”
\m 
\v 12 Uca issekk Musa ad řaɣan x Datan d Abiram, iḥenjiren n Iliyab, maca nitni nnan: “War dd-nettis ca!”
\v 13 Ma war iǧi icfa awem umi d aneɣ dd-tssuffɣem zeg ict n temmurt ifeyyḍen s uɣi d tamment, ḥima ad aneɣ tesshelleked di řexřa uca \add xenni\add* ɛawed tegged ixef nnec d řḥakem xaneɣ?
\v 14 Uřa d cek war d aneɣ dd-tessidfed ca deg ict n temmurt ifeyyḍen s uɣi d tamment, u war d aneɣ tewcid iyyar\add en\add* d imarjaɛen n uḍiř d řwart. Ma ittɣiř ac tzemmared ad tessdaɣřed tiṭṭawin n yeryazen-a? Neccin war dd-nettis ca!”
\m 
\v 15 \add Xenni\add* ittwassarɣ ufugem n Musa, inna i SIDI: “War xezzar ɣar tewhibt nsen! Necc war zzaysen kessiɣ qaɛ ijj n uɣyuř uca war ggiɣ řɣar uřa i yijj zzaysen.” \x ◘ \xo 16:15 \xt 1 Ṣm. 12:3\x*
\m 
\v 16 Inna Musa i Quraḥ: “Cek d marra abarru nnec, \add asem-dd\add* tiwecca zzat i wudem n SIDI, cek d nitni, d Harun.
\v 17 Ksim kuř ijj \add zzaywem\add* ijj n řmejmar, ggem dayes řebxur uca qarrbem-dd akides zzat i wudem n SIDI. Kuř aryaz ak-d řmejmar nnes, mitayen u-xemsin n tmejmarin, uca \add ɛawed\add* cek d Harun, kuř ijj \add ak-d\add* řmejmar nnes.”
\v 18 Iksi kuř ijj řmejmar nnes uca ggin dayes timessi u ssarsen xas řebxur uca uyuren ad bedden zzat i wadaf n Uqiḍun n Umsagar, uřa d Musa d Harun.
\v 19 Quraḥ iɣewweɣ xasen marra abarru \add nnes\add* ɣar wadaf n Uqiḍun n Umsagar. \add Řexdenni\add* iban-dd uɛuǧi n SIDI ɣar marra tamesmunt.
\b
\m 
\v 20 Issiweř SIDI ak-d Musa d Harun, inna:
\m 
\v 21 “Ḥeydem ixef nwem zeg ubarru-ya, \add xenni\add* ad ten hellkeɣ deg wermac n wabřiwen!”
\v 22 \add Maca\add* nitni wḍan x wudem nsen, nnan: “\add A\add* Arebbi, AREBBI n marra buḥbeřat n marra ddat! \add Mařa\add* ixḍa ijj n weryaz, ma \add xenni\add* ad tegged aɣḍab nnec ad idduqqez x marra tamesmunt?” \x ◘ \xo 16:22 \xt Řxř. 27:16; Ɛbr. 12:9 \x*
\m 
\v 23 Issiweř SIDI ak-d Musa, inna:
\m 
\v 24 “Siweř ak-d tmesmunt, ini: ‘Beɛɛdem x tzeddiɣt n Quraḥ d Datan d Abiram d min d as dd-innḍen.’”
\v 25 \add Xenni\add* Musa ikkar uca iruḥ ɣar Datan d Abiram uca uyuren imɣaren n Israil awarni as.
\v 26 Uca issiweř netta ak-d tmesmunt, inna: “Ttzawgeɣ, beɛɛdem x iqiḍan n yeryazen-a iqejḥen u war ttḥadam uřa d ict n řḥajjet n min iǧan nsen, ḥima kenniw war tᵉttwahellikem ca s ddnub nsen!”
\v 27 Kkaren nitni uca beɛɛden x iqiḍan n Quraḥ d Datan d Abiram d min d as dd-innḍen. Datan d Abiram ffɣen-dd, bedden ɣar wadaf n iqiḍan nsen ak-d temɣarin nsen d iḥenjiren nsen d iḥenjiren nsen imeẓyanen.
\v 28 \add Xenni\add* inna Musa: “S man aya i ɣa tessnem belli SIDI issekk ayi-dd, ḥima ad ggeɣ marra timegga-ya, minzi war dd-ffiɣent ca zeg wuř inu.
\v 29 Mařa ina ad mmten am mammec \add mmuten\add* iwdan marra u ad ten iřqef min iřeqfen marra iwdan, \add xenni\add* ad taf SIDI war d ayi dd-issekk.
\v 30 \add Maca\add* mařa SIDI ixřeq-dd ca n řḥajjet d tamaynut qaɛ uca tammurt ad tarzem aqemmum nnes, ad ten tsarḍ ak-d marra \add min iǧan\add* nsen uca ad hwan ddaren di řaxart, xenni i ɣa tessnem belli iryazen-a aqa ssduqqzen SIDI.”
\m 
\v 31 Uca imsar, umi ikemmeř awařen-a, tfeǧeq temmurt nni swadday nsen.
\v 32 Tarzem temmurt aqemmum nnes uca tsarḍ i-ten ak-d aytbab n taddart nsen u ak-d marra iwdan n Quraḥ d marra agřa \add nsen\add*. \x ◘ \xo 16:32 \xt Řxř. 26:10; 27:3; Aɛwd. 11:6; Izhd. 106:17\x*
\v 33 Hwan-dd ddaren di řaxart ak-d marra \add min iǧan\add* nsen uca tammurt tessduriy i-ten u ttwateḥḥan zi řwesṭ n wegraw \add n řgens\add*.
\v 34 Marra Israil, inni tuɣa dd-innḍen, arewřen \add umi sřin\add* i tɣuyyit nsen, minzi nnan: “Niɣ ad taf \add uřa d neccin\add* ad aneɣ tṣarḍ temmurt.”
\v 35 Uca teffeɣ-dd tmessi zi SIDI, tecca mitayen u-xemsin n yeryazen nni dd-yiwyen řebxur.
\b
\b
\c 17
\s1 Jjriḥect ineqqen
\m 
\v 1 Issiweř SIDI ak-d Musa, inna:
\m 
\v 2 “Ini i Aliɛazar, mmis n ukehhan Harun, belli ad iksi timejmarin zeg uḥaduq n tmessi uca ad issuyes \add min iqqimen n\add* tmessi di řaggʷaj, minzi aqa timejmarin nni, qeddsent i ǧant!
\v 3 Jjem ten ad ggen zi tmejmarin n \add yeryazen-a\add*, inni tuɣa ixeṭṭan ḍidd i řeɛmur nsen, tiřwiḥin d tizirarin i dduri i uɛalṭar, minzi iwyen tent zzat i wudem n SIDI, s uya ttwaqeddsent tina. Ad iřint d ijj n uceyyar i ayt n Israil.”
\v 4 \add Xenni\add* iksi ukehhan Aliɛazar timejmarin n nnḥas nni dd-iwyen yinni ittwacemḍen \add i tewhibt\add*, uca tketken tent ḥima ad \add zzaysent\add* dřent aɛalṭar
\v 5 i řidaret i ayt n Israil, ḥima uřa d ijj n weryaz war iǧin zi zzariɛet n Harun, war dd-ittqarrib ca břa ttesriḥ zzat i wudem n SIDI, ḥima ad issbexxar řebxur, maḥend war d as iřqef min iřeqfen Quraḥ d ubarru nnes, am mammec tuɣa issiweř SIDI s uqemmum n Musa.
\m 
\v 6 Tiwecca nnes tuɣa marra tamesmunt n ayt n Israil tᵉttnedqam ḍidd i Musa d Harun, nnan: “Kenniw tenɣim řgens n SIDI!”
\v 7 Uca \add umi\add* tmun tmesmunt ḍidd i Musa d Harun uca bdan nitni gguren ɣar Uqiḍun n Umsagar, xzar, aqa din aseynu nni t idřin uca iban-dd uɛuǧi n SIDI.
\v 8 Yusa-dd Musa ak-d Harun, \add bedden\add* zzat i Uqiḍun n Umsagar.
\v 9 Issiweř SIDI ak-d Musa, inna:
\m 
\v 10 “Kkarem, \add aggʷejem\add* zi řwesṭ n tmesmunt u Necc ad ten mḥiɣ deg ijj n wermac n wabřiwen!” \add Xenni\add* wḍan x wudem nsen.
\v 11 Inna Musa i Harun: “Ksi \add deɣya\add* ijj n řmejmar, egg xas timessi n uɛalṭar uca sars xas řebxur. Azzeř ɣar tmesmunt uca egg aṣřaḥ di ṭṭweɛ nsen, minzi iffeɣ-dd uduqqez \add n weɣḍab\add* zi zzat i wudem n SIDI. Aqa da jjriḥect am tebda \add ɛad\add*.”
\v 12 Iksi Harun \add řmejmar\add*, am mammec inna Musa, uca yuzzeř ɣar řwesṭ n wegraw \add n řgens\add*, uca xzar, jjriḥect tuɣa am tebda \add ɛad\add* jar řgens, uca netta issars dayes řebxur uca igga aṣřaḥ di ṭṭweɛ n řgens. \f ◼ \fr 17:12 \fk ifdi\ft - xzar Izhd. 78:35.\f*
\v 13 Tuɣa ibedd jar imettan d imuddaren uca tᵉttwassbedd jjriḥect.
\v 14 Wi immuten zi jjriḥect tuɣa aten di arbeɛṭac-ařef u-sebɛa-mya, břa inni immuten di ssibbet n Quraḥ.
\v 15 Idweř Harun ɣar Musa ɣar wadaf n Uqiḍun n Umsagar. Aqa tᵉttwassbedd jjriḥect.
\b
\s1 Taɣɣarct izzeyzuyen n Harun
\m 
\v 16 Issiweř SIDI ak-d Musa, inna:
\m 
\v 17 “Siweř ak-d ayt n Israil uca ksi zzaysen ict n teɣɣarct i kuř taddart n ibabaten \add nsen\add*, zi marra řḥukkam nsen, ɛlaḥsab \add lɛadad n\add* tudrin n ibabaten nsen, tenɛac n tᵉɣɣaryen. Ittxeṣṣa ad tarid isem n kuř ijj \add zzaysen\add* x teɣɣarct nnes.
\v 18 Ad tarid isem n Harun x teɣɣarct n Lawi, minzi \add ad din tiři\add* ict n teɣɣarct i yijj n uzeǧif n taddart n řejdud nsen.
\v 19 Ad tent tegged deg Uqiḍun n Umsagar, zzat i Cchadet, mani kidwem ɣa msagareɣ. \x ◘ \xo 17:19 \xt Uf. 25:22 \x*
\v 20 \add Xenni\add* ad imsar, aqa ad tnuwwar teɣɣarct n weryaz nni ixḍareɣ Necc uca ad ssbeddeɣ anedqem ḍidd inu i zi xawem nndeqmen ayt n Israil.”
\m 
\v 21 Issiweř Musa ak-d ayt n Israil, uca marra řḥukkam nsen wcin ict n teɣɣarct i mkuř ijj n řḥakem, ɛlaḥsab \add řqedd n\add* tudrin n ibabaten nsen, tenɛac n teɣɣaryen. Uca taɣɣarct n Harun tuɣa-t jar tᵉɣɣaryen nsen.
\v 22 Musa issars tiɣɣaryen \add nni\add* zzat i wudem n SIDI deg Uqiḍun n Cchadet.
\v 23 Tiwecca nnes yudef Musa ɣar Uqiḍun n Cchadet, uca xzar, taɣɣarct n Harun di ṭṭweɛ n taddart n Lawi tuɣa tegga tacřařt uca taɛebbuzt tessuffeɣ-dd uca nnuwwar \add nnes\add* yarzem uca yiwi-dd ǧuz yiwḍen.
\v 24 Xenni issuffeɣ Musa marra tiɣɣaryen zi zzat i wudem n SIDI ɣar marra ayt n Israil. Ẓrin aya uca ṭṭfen kuř ijj taɣɣarct nnes.
\m 
\v 25 \add Xenni\add* inna SIDI i Musa: “Arr taɣɣarct n Harun zzat i Cchadet, ad tt teḥḍid am yijj n uceyyar ḍidd i yinni iɣewwɣen. \add Ammu\add* i ɣa tessbedded anedqem nsen ḍidd inu maḥend nitni war ttmettin ca.” \x ◘ \xo 17:25 \xt Ɛbr. 9:4\x*
\v 26 Uca igga Musa am mammec d as yumur SIDI, ammu i igga netta.
\v 27 \add Xenni\add* ssiwřen ayt n Israil ak-d Musa, nnan: “Xzar, ad zzayneɣ iffeɣ buḥbeř, ad nettwahellek, ad nettwahellek marra neccin!
\v 28 Man wen ma i dd ɣa iqarrben ɣar Uqiḍun n SIDI, ad immet. Ma ad nettwateḥḥa ař zzayneɣ iffeɣ buḥbeř?”
\b
\b
\c 18
\s1 Řeḥmeř d řmunet n ikehhanen d Ilawiyyen
\m 
\v 1 Inna SIDI i Harun:
\m “Cek d warraw nnec d taddart n babac akidek, ad tarbum řmuɛṣiyyet n Zzawect Iqeddsen nwem. Cek d warraw nnec akidek ad arbun řmuɛṣiyyet n tukehhant nwem.
\v 2 Ad dd-tiwyed akidek uřa d aytmac, taqbič n Lawi, taqbič n babac. Nitni ad dd-mmarenyen ɣarek, ad ac sexxaren, \add maca\add* cek, jmiɛ ak-d iḥenjiren nnec, \add ad tsexxared\add* zzat i wudem n Uqiḍun n Cchadet.
\v 3 Ad ṭṭfen acbar nnec uca ad ḥḍan x marra Aqiḍun, maca war zemmaren ad dd-qarrben ɣar řeqcuɛ n Zzawect Iqeddsen u ɣar uɛalṭar ḥima war ttᵉttmettin, war iǧi řa d nitni uřa d kenniw.
\v 4 Ittxeṣṣa asen ad mmarenyen ɣarek uca ad ṭṭfen acbar x Uqiḍun n Umsagar u x marra tasexxart n Uqiḍun. Wenni war ɣar iǧi ttesriḥ war izemmar ad ɣarwem dd-iqarreb.
\v 5 Ad tᵉṭṭfem acbar x Zzawect Iqeddsen uřa x uɛalṭar, ḥima war dd-ittis \add ɛad\add* uduqqez \add n weɣḍab\add* x ayt n Israil.
\v 6 Necc, aqa da Necc, ksiɣ awmaten nwem, Ilawiyyen, zi jar řwesṭ n ayt n Israil. Aqa nitni am yict n tewhibt i kenniw tenni ittxeṣṣa ad twehhbem i SIDI maḥend ad sexxaren nitni deg Uqiḍun n Umsagar. \x ◘ \xo 18:6 \xt Řxř. 3:45 \x*
\v 7 \add Maca\add* cek d iḥenjiren nnec akidek ad tᵉṭṭfem tukehhant nwem di marra min iqqnen ak-d uɛalṭar d min iǧan daxeř i uřeḥḥaf uca \add ammu\add* ad tsexxarem kenniw. Necc ad awem wceɣ tukehhant d tsexxart am yict n terzeft. Abarrani nni dd ɣa iqarrben, ad ittwaneɣ.”
\m 
\v 8 Issiweř SIDI ak-d Harun:
\m “Necc, xzar, aqa d Necc i d ac iwcin \add a\add*ḥeṭṭu x \add tewhibin n\add* usgeɛɛed \add i qeddmen nitni\add* i Necc. Necc wciɣ tent ak-d marra \add tiwhibin\add* iqeddsen n ayt n Israil am tesɣart i x ittwagg wedhan, i cek u i warraw nnec, am yict n tewṣeyyet i řebda.
\v 9 Zi \add tewhibin\add* iqeddsen ad iřint iziynat i war yudifen ɣar tmessi i cek: marra tiwhibin nsen ak-d marra tiwhibin nsen \add n řɣiǧet\add*, ak-d marra tiɣarṣa nsen n ddenb u ak-d marra tiɣarṣa nsen n umarwas nni d ayi dd ɣa yarren \add am texriṣt\add*. \add Man aya marra\add* ad yiři d amqeddas qaɛ i cek u i iḥenjiren nnec.
\v 10 Ad tecced aya deg ijj n wemcan iqeddsen qaɛ. Kuř awtem ad zzayes yecc. Aya ad yiři d amqeddas i kenniw.”
\m 
\v 11 “\add Ɛawed\add* d man aya \add ad yiři\add* i cek: tawhibt n usgeɛɛed n tewhibt nsen ak-d marra tiwhibin n wenhezzi n ayt n Israil. Wciɣ tent i cek u i warrawen nnec d tarrawin nnec nni kidek \add iǧan\add*. \add Aqa-tt\add* d ict n tewṣeyyet i řebda. Kuř ijjen di taddart nnec nni iǧan d amezdag, ad zzaysent yecc.”\x ◘ \xo 18:11 \xt Lawi 10:14\x*
\m 
\v 12 “Min iǧan řemxeyyar n zzect d min iǧan řemxeyyar n binu n jdid u zeg irden, aqa d tamezwarut i zzaysen ad wcen i SIDI, aqa wciɣ ac tt.
\v 13 Tamenzut n marra min iǧan x temmurt nsen, nni dd ɣa yawyen ɣar SIDI, aqa \add marra\add* man aya ad yiři i cek. Kuř ijjen wenni iǧan d amezdag di taddart nnec, izemmar ad zzayes yecc.”
\m 
\v 14 “Marra min ittwaḥarrmen di Israil, ad yiři nnec. \x ◘ \xo 18:14 \xt Lawi 27:28\x*
\v 15 Marra min yarezmen řemřawat \add d amezwaru\add* jar marra aysum i ɣa qeddmen i SIDI, zi bnadem niɣ zi řebhimet, ad yiři nnec. Maca ad tefdid qaɛ amenzu n iwdan uca ittxeṣṣa \add ɛawed\add* ad tefdid amenzu n řebhayem ixemjen. \x ◘ \xo 18:15 \xt Uf. 13:2; 22:29; Lawi 27:26; Řxř. 3:13\x*
\v 16 Wi zzaysen ɣa ttwafdin nitni, ad ttwafdin d mmis n ijj n uyur ɛlaḥsab řqimet i tqeddared cek di nnuqart, xemsa ciqlu ɛlaḥsab ciqlu n Zzawect Iqeddsen, wenni \add iǧan\add* ɛicrin jira. \x ◘ \xo 18:16 \xt Uf. 30:13; Lawi 27:25; Řxř. 3:47; Ḥiz. 45:12\x*
\v 17 Maca amenzu n ufunas d umenzu n uḥuři d umenzu n iɣayḍ, war t tfeddim ca. Aqa aten qeddsen \add i ǧan\add*. Ad tzeǧɛed idammen nsen x uɛalṭar u tadunt nsen ad tt tessbexxared am tewhibt n tmessi, am yict n řefwaḥet ittfuḥen i SIDI.
\v 18 Aysum nnes ad yiři nnec, am yidmaren n wenhezzi am ucekrud afusi ad iřin nnec.
\v 19 Marra \add tiwhibin n\add* usgeɛɛed zi \add tewhibin\add* iqeddsen nni ɣa ssgeɛɛden ayt n Israil i SIDI, wciɣ tent i cek u i iḥenjiren nnec d tḥenjirin nnec \add inni\add* akidek \add iǧan\add*. \add Aqa\add* d ict n tewṣeyyet i řebda, ad yiři d ijj n řɛahd s řemřaḥet i řebda zzat i wudem n SIDI, i cek u i zzariɛet nnec nni akidek \add iǧan\add*.”
\m 
\v 20 Inna SIDI i Harun:
\m “War tᵉttᵉṭṭfed řwart di temmurt nsen u war ɣarek tᵉttiři bu tesɣart di řwesṭ nsen. Necc d tasɣart nnec d řwart nnec di řwesṭ n ayt n Israil. \x ◘ \xo 18:20 \xt Aɛwd. 10:9; 18:2; Ḥiz. 44:28 \x*
\v 21 Xzar, Necc wciɣ i ayt n Lawi marra řeɛcur di Israil d řwart di ṭṭweɛ n tsexxart nni ggin nitni, tasexxart n Uqiḍun n Umsagar.
\v 22 Ayt n Israil war dd-ttqarriben ɛad ɣar Uqiḍun n Umsagar, ḥima war dd-ttiwyen \add ammu\add* ddenb x yixef nsen uca ad mmten.
\v 23 \add Maca\add* Ilawiyyen ad sexxaren di tsexxart n Uqiḍun n Umsagar uca ad arbun řmuɛṣiyyet nsen. \add Aqa-tt\add* d ict n tewṣeyyet i řebda i \add marra\add* jjiřat nwem, aqa nitni war ttᵉṭṭfen řwart di řwesṭ n ayt n Israil,
\v 24 minzi řeɛcur n ayt n Israil nni ssgeɛɛden nitni i SIDI am tewhibt n usgeɛɛed, wciɣ ten i Ilawiyyen. X uya nniɣ asen: War warrten di řwesṭ n ayt n Israil!”
\m 
\v 25 Issiweř SIDI ak-d Musa, inna:
\m 
\v 26 “Ammu i ɣa tessiwřed ak-d Ilawiyyen uca ad asen tinid: ‘Xmi teksim řeɛcur n ayt n Israil nni wciɣ kenniw d řwart, \add xenni\add* ad zzaysen tessgeɛɛdem ict n tewhibt n usgeɛɛed i SIDI, řeɛcur zi řeɛcur.
\v 27 Ad awem dd-tᵉttwaḥseb am tewhibt n usgeɛɛed, am yirden n unedrar u am teccuret n tsirt \add n uḍiř\add*.
\v 28 Ammu i d awem ittxeṣṣa ad tessgeɛɛdem ict n tewhibt n usgeɛɛed i SIDI zi marra řeɛcur nwem nni ɣa teksim zeg ayt n Israil. Ittxeṣṣa ad tewcem tawhibt, tenni tessgeɛɛdem zzaysen i SIDI, ɣar ukehhan Harun.
\v 29 Zi marra min d awem ɣa wcen, ad tessgeɛɛdem tawhibt n usgeɛɛed tmun i SIDI, zi řemxeyyar nnes, tasɣart nnes iqeddsen zzayes.’
\m 
\v 30 Uca ittxeṣṣa ac ad asen tinim: ‘Mařa teksim zzayes řemxeyyar nnes, \add aqa\add* aya ad dd-ittwaḥseb d řɣiǧet n unedrar d řɣiǧet n tsirt \add n uḍiř\add* i Ilawiyyen.
\v 31 Ad teccem aya di kuř amcan, kenniw d \add aytbab n\add* taddart nwem, minzi ta d řmunet i tsexxart nwem deg Uqiḍun n Umsagar.
\v 32 Mařa ad zzayes teksim min iǧan ḥsen, \add xenni\add* war xawem tarebbum ddenb. War iɛeddeř ad tfesdem \add tiwhibin\add* iqeddsen n ayt n Israil, \add ḥima\add* war tᵉttmettim ca.’”
\b
\b
\c 19
\s1 Aman n usizdeg
\m 
\v 1 Issiweř SIDI ak-d Musa d Harun, inna:
\m 
\v 2 “Ta d tawṣeyyet n CCariɛa nni yumur SIDI, \add umi\add* inna: ‘Siweř ak-d ayt n Israil ad ac dd-awyen \bd ict n tfunast tazeggʷaɣt\bd*, tenni icnan u tenni war di iǧi uneɛḍab uca war xas ssarsen ɛad azayřu.
\v 3 Ad tt tewcem i ukehhan Aliɛazar u netta ad tt issuffeɣ barra i řmargeḥ n řɛeskar u ad as ɣarṣen zzat i wudem nnes. \x ◘ \xo 19:3 \xt Ɛbr. 13:11, 12 \x*
\v 4 Akehhan Aliɛazar ad iksi \add cwayt\add* n idammen nnes s uḍaḍ nnes uca ad irucc sebɛa n twařawin \add cwayt\add* zeg idammen nnes jjihet n wudem n Uqiḍun n Umsagar. \x ◘ \xo 19:4 \xt Ɛbr. 9:13\x*
\v 5 Ad sscemḍen tafunast zzat i tiṭṭawin nnes. Tiřmect nnes, aysum nnes d idammen nnes ad ten sscemḍen \add jmiɛ\add* ak-d umessař nnes. \x ◘ \xo 19:5 \xt Uf. 29:14; Lawi 4:11, 12 \x*
\v 6 Ad iksi ukehhan akeccuḍ n \add tcejjart n\add* tengelt d tɛelǧet d uzeggʷaɣ iḥedqen uca ad inḍar aya di řwesṭ n tmessi \add i di tᵉttwacmeḍ\add* tfunast. \f ◼ \fr 19:6 \fk tɛelǧet\ft - niɣ ‘hisup’\f*
\v 7 Xenni ad iṣebben ukehhan arruḍ nnes, ad issird arrimet nnes deg waman, uca awarni as ad yadef ɣar řmargeḥ. Akehhan ad yiři ixmej ař tameddit.
\v 8 D wenni tt isscemḍen, ad iṣebben \add ɛawed\add* arruḍ nnes deg waman uca ad issird arrimet nnes s waman. Netta ad yiři ixmej ař tameddit.
\v 9 Aryaz amezdag ad iyru iɣɣeḍ n tfunast uca ad ten igg barra i řmargeḥ deg ijj n wemcan izdig. Aqa x tmesmunt n ayt n Israil maḥend ad teḥḍa x waman n weɛzař, aqa aten i usizdeg n ddenb.
\v 10 Wenni iyrun iɣɣeḍ n tfunast ad iṣebben arruḍ nnes uca ad yiři ixmej ař tameddit. \add Aqa\add* d ict n tewṣeyyet i řebda i ayt n Israil u i ubarrani nni izeddɣen di řwesṭ nsen.’”
\b
\m 
\v 11 “Wi ɣa iḥadan ca n umettin, mammec ma \add tegga\add* ca n řxecbet n bnadem, ad yiři ixmej sebɛa n wussan. \x ◘ \xo 19:11 \xt Řxř. 31:19; Ḥag. 2:13\x*
\v 12 Deg wass wiss třata ad ikkes ddenb x yixef nnes \add s waman n weɛzař\add*. \add Xenni\add* ad yiři izdig deg wass wiss sebɛa. Mařa war ikkis ddenb x yixef nnes deg wass wiss třata, war ittiři izdig deg wass wiss sebɛa.
\v 13 Marra wi iḥadan ijj n umettin, řeɛmar n ijj n bnadem immut, uca war ikkis ddenb x yixef nnes, aqa issexmej Tazeddiɣt n SIDI. Řeɛmar nni ad ittwaqess zi Israil. Minzi war xas zzuzaren ca aman n weɛzař, ad yiři ixmej. Řexmej nnes \add aqa-t\add* xas ɛad.”
\m 
\v 14 “Wa d azerf x ijj n bnadem nni immuten deg ijj n uqiḍun. Marra wi ɣa yadfen ɣar uqiḍun nni u marra wi \add ɣa iqqimen\add* deg uqiḍun nni, ad yiři ixmej sebɛa n wussan.
\v 15 \add Ɛawed\add* kuř řqecɛet yarezmen, war xas taqebbart teqqen s tesɣunt, ad tiři texmej,
\v 16 Marra wi iḥadan ḥed ittwassnuqqben s ssif deg iyyar, niɣ ca n umettin niɣ iɣsan n ijj n bnadem, niɣ ijj n wenḍeř, ad yiři ixmej sebɛa n wussan.
\v 17 I yijj n umexmuj ittxeṣṣa ad ksin \add cwayt\add* n iɣɣeḍ n \add tɣarṣt n\add* ddenb icemḍen uca ad xas ssfarrɣen aman iddaren deg ict n řqecɛet.
\v 18 Ijj n weryaz d amezdag ad iksi tɛelǧet, ad \add tt\add* issuf deg waman uca \add xenni\add* ad tt irucc x uqiḍun u x marra řeqcuɛ u x řeɛmur nni tuɣa din iǧan, uca \add ammu ɛawed\add* x wi iḥadan iɣsan niɣ ca n yijjen nni ittwassnuqqben niɣ ca n umettin niɣ ca n wenḍeř. \x ◘ \xo 19:18 \xt Izhd. 51:9 \x*
\v 19 Amezdag ad irucc x umexmuj deg wass wiss třata u deg wass wiss sebɛa ad xas irucc u deg wass wiss sebɛa ad xas ikkes ddenb. Ad iṣebben arruḍ nnes ad issird ixef nnes s waman uca ad yiři izdeg ař tameddit.
\v 20 Aryaz ixemjen i war ittejjin ad ikkes ddenb x yixef nnes, řeɛmar nni ad ittwaqess zi řwesṭ n wegraw \add n řgens\add*, minzi aqa issexmej Zzawect Iqeddsen n SIDI. War xas ruccen aman n weɛzař, aqa ixmej.
\v 21 Ta d ict n tewṣeyyet i řebda i nitni. Wenni iruccen aman n weɛzař ad iṣebben arruḍ nnes u wi ɣa iḥadan aman n weɛzař, ad yiři ixmej ař tameddit.
\v 22 Marra min ittwaḥadan zeg umexmuj, ad yiři ixmej, uca bnadem nni i ɣa iḥadan aya, ad yiři ixmej ař tameddit.”
\b
\b
\c 20
\s1 Řmewt n Maryam
\m 
\v 1 Deg uyur amezwaru tiweḍ marra tamesmunt n ayt n Israil ɣar řexřa n Ṣin. Řgens iqqim di Qadac. Din i temmut Maryam uca neḍřen tt din.
\b
\s1 Aman n Miriba
\m 
\v 2 War tuɣi din ca aman i tmesmunt. \add Xenni\add* munen ḍidd i Musa d Harun.
\v 3 Tuɣa řgens imcubbec ak-d Musa, nnan: “Mři tuɣa zzayneɣ iffeɣ buḥbeř umi tuɣa iffeɣ buḥbeř zeg aytmatneɣ zzat i wudem n SIDI! \x ◘ \xo 20:3 \xt Řxř. 16:32, 49\x*
\v 4 Mayemmi tessidfem wegraw \add n řgens\add* n SIDI di řexřa-ya maḥend ad mmten din, neccin d řebhayem nneɣ?
\v 5 U mayemmi d aneɣ dd-tessiřyem zi Miṣra ḥima ad aneɣ tessiwḍem ɣar wemcan-a aɛeffan? Deg wemcan-a war \add din\add* zzariɛet niɣ tazart niɣ tzayart niɣ aremmam u war din ɛad aman ḥima ad nsu.”
\m 
\v 6 \add Xenni\add* yiweḍ Musa ak-d Harun zi zzat n wudem n wegraw \add n řgens\add* ɣar wadaf n Uqiḍun n Umsagar uca wḍan x wudmawen nsen uca iban asen-dd uɛuǧi n SIDI.
\v 7 Issiweř SIDI ak-d Musa, inna:
\m 
\v 8 “Ksi taɣɣarct uca smun tamesmunt, cek d Harun, umac. Ittxeṣṣa ad tessiwřem ak-d teṣḍart zzat i tiṭṭawin nsen uca \add xenni\add* ad tewc aman nnes. \add Ammu\add* i ɣa tessuffɣem aman i nitni zi teṣḍart uca ad tᵉssessud tamesmunt d řebhayem.” \x ◘ \xo 20:8 \xt Naḥ. 9:15; Izhd. 78:15, 16; 105:41; 114:8\x*
\m 
\v 9 \add Xenni\add* iksi Musa taɣɣarct zi zzat n wudem n SIDI am mammec d as yumur Netta,
\v 10 uca issmun Musa d Harun agraw \add n řgens\add* zzat i wudem n teṣḍart. Netta inna asen: “Sřem \add řexxu\add*, \add a kenniw\add* inni iɣewwɣen, ma ittxeṣṣa aneɣ ad dd-nessuffeɣ aman zi teṣḍart-a?” \x ◘ \xo 20:10 \xt Aɛwd. 32:51; Izhd. 106:32,33 \x*
\v 11 Uca issgeɛɛed Musa afus nnes uca iwta taṣḍart tnayen n twařawin s taɣɣarct nnes uca ffɣen-dd zzayes aṭṭas n waman uca teswa tmesmunt d řebhayem nsen. \x ◘ \xo 20:11 \xt Izhd. 78:15; 105:41; Ica. 43:20; 48:21; 1 Kur. 10:4\x*
\m 
\v 12 \add Xenni\add* inna SIDI i Musa d Harun: “Minzi kenniw war d ayi tᵉttecřem zzat i tiṭṭawin n ayt n Israil ařami d ayi tweqqarem s uweqqar iqeddsen, s uya war tessidifem agraw-a \add n řgens\add* di temmurt nni d asen wciɣ.” \x ◘ \xo 20:12 \xt Řxř. 27:14; Aɛwd. 1:37\x*
\m 
\v 13 Ina aqa d aman n Mariba min xef arezzun ayt n Israil ad mcubbcen ak-d SIDI u \add mani\add* Netta iban-dd d Amqeddes jar asen.
\b
\s1 Idum yugi aẓwi n řgens
\m 
\v 14 Issekk Musa ireqqasen zi Qadac ɣar ujeǧid n Idum, nnan: “Ammu i iqqar Israil, umac: ‘Cek tessned marra tamara nni xaneɣ ikkin, \x ◘ \xo 20:14 \xt Aɛwd. 23:6; Ɛub. 10, 12 \x*
\v 15 aqa řejdud nneɣ hwan-dd ɣar Miṣra u tuɣa nzeddeɣ aṭṭas n iseggʷusa di Miṣra u Imiṣriyyen ggin dayneɣ u di řejdud nneɣ aṭṭas n řɣar.
\v 16 Nřaɣa x SIDI uca Netta isřa tmijja nneɣ uca issekk-dd lmalak uca issuffeɣ aneɣ-dd zi Miṣra. Xzar, aqa aneɣ di Qadac, ict n tendint ɣar ṭṭarf n jjihet nnec. \x ◘ \xo 20:16 \xt Uf. 2:23; 14:19 \x*
\v 17 Ejj aneɣ, mařa texsed, ad neẓwa x temmurt nnec. War nẓekkwi x iyyaren niɣ x imarjaɛen nnec n uḍiř u war nᵉsess aman zeg wanuten. X webrid igellden ad neɛdu břa ma ad nḥeyyed \add ɣar\add* yefus uřa \add ɣar\add* uzeřmaḍ, ař ɣa neɛdu \add ɛawed\add* iymiren \add n temmurt\add* nnec.’”
\m 
\v 18 Inna as Idum: “War ttẓekkʷid xafi, niɣ ak kic mmsagareɣ s ssif balak!”
\v 19 \add Xenni\add* nnan as ayt n Israil: “Ad neḍfar abrid ameqqran u mařa ad sweɣ aman nnec, necc d řebhayem inu, ad ten xeǧṣeɣ. Ad ẓwiɣ \add tammurt\add* x iḍaren d wenni netta waha.”
\m 
\v 20 \add Maca\add* netta inna: “War xas tẓekkʷid!” Uca iffeɣ Idum maḥend ad kis imsagar s yijj n ubarru d ameqqran d ufus ijehden.
\v 21 \add Ammu\add* yugi Idum ad iwc ttesriḥ i Israil maḥend ad iẓwa aymir nnes. S uyenni i ijja Israil abrid di ssibbet nnes. \x ◘ \xo 20:21 \xt Řqḍ. 11:18 \x*
\b
\s1 Řmewt n Harun
\m 
\v 22 Fesyen iqiḍan nsen, \add ffɣen\add* zi Qadac, uca \add xenni\add* iwḍen ayt n Israil ɣar wedrar n Hur, tamesmunt marra. \x ◘ \xo 20:22 \xt Řxř. 33:37 \x*
\v 23 Issiweř SIDI ak-d Musa d Harun ɣar wedrar n Hur, ɣar weymir n temmurt n Idum, inna:
\m 
\v 24 “Ad immarni Harun ɣar řgens nnes, minzi war ittidef ɣar temmurt nni wciɣ i ayt n Israil, minzi kenniw tɣennanem x řumur inu ɣar waman n Mariba.
\v 25 Ksi Harun d Aliɛazar, mmis, uca arr i-ten ad geɛɛden x wedrar n Hur. \x ◘ \xo 20:25 \xt Řxř. 33:38; Aɛwd. 32:50 \x*
\v 26 Ɛarra Harun zeg warruḍ nnes uca syarḍ i-t i Aliɛazar, mmis. \add Xenni\add* ad ittwaksi Harun uca ad immet din.”
\m 
\v 27 Musa igga am mammec d as yumur SIDI. Uřyen adrar n Hur zzat i tiṭṭawin n marra tamesmunt.
\v 28 Musa iɛarra Harun zeg warruḍ nnes uca issyarḍ i-t i Aliɛazar, mmis. Uca immut Harun din x tqiccat n wedrar. \add Xenni\add* ihwa-dd Musa zeg wedrar ak-d Aliɛazar. \x ◘ \xo 20:28 \xt Aɛwd. 10:6; 32:50 \x*
\v 29 Marra tamesmunt teẓra belli Harun iḍřeq i buḥbeř nnes uca run třatin n wussan di ssibbet n Harun, marra taddart n Israil.
\b
\b
\c 21
\s1 Tasexxart n ujeǧid n Ɛarad
\m 
\v 1 \add Umi\add* isřa Akenɛani, ajeǧid n Ɛarad nni izeddɣen di \add Temmurt n\add* Ljanub, belli yusa-dd Israil x webrid n ibergagen, immneɣ ḍidd i Israil uca iṭṭef \add ca\add* zzaysen d imeḥbas.
\m 
\v 2 \add Xenni\add* iwca Israil ijj n wawař i SIDI uca inna: “Mařa d tidett tɛarrned řgens-a deg ufus inu, necc ad ḥarrmeɣ tineddam nsen \add i uteḥḥi\add*.”
\v 3 SIDI istajeb i Israil uca isellem as ayt n Kenɛan uca nitni ḥarrmen i-ten i uteḥḥi uřa d marra tineddam nsen uca iřaɣa amcan nni s yisem n Ḥurma. \f ◼ \fr 21:3 \fk istajeb i Israil\ft - s Tɛibranit ‘isřa i tmijja n Israil’.\f*
\b
\s1 Afiɣar n nnḥas
\m 
\v 4 \add Xenni\add* fesyen iqiḍan nsen zeg wedrar n Hur, \add ruḥen\add* x webrid ɣar Řebḥar n Telga uca s man aya \add tuɣa ittxeṣṣa\add* ad nnḍen i temmurt n Idum. Uca řgens war iṣbir deg webrid.
\v 5 Aqa iqaceḥ řgens ḍidd i AREBBI d Musa: “Mayemmi d aneɣ dd-tessuffɣem zi Miṣra, maḥend ad nemmet di řexřa-ya? War da iǧi weɣrum uřa d aman. Řeɛmar nneɣ iɛiff zeg weɣrum-a i war isekkwin!”
\m 
\v 6 \add Xenni\add* iḍřeq SIDI ifiɣran yareqqen jar řgens, inni izeɛfen řgens uca immut waṭṭas n řgens n Israil. \x ◘ \xo 21:6 \xt 1 Kur. 10:9 \x*
\v 7 Yusa-dd řgens ɣar Musa, nnan: “Aqa nexḍa, minzi nqaceḥ ak-d SIDI u akidek. Ẓaǧ i SIDI maḥend ad xaneɣ ikkes ifiɣran-a.” \add Xenni\add* iẓuǧ Musa di ṭṭweɛ n řgens. \f ◼ \fr 21:7 \fk ifiɣran\ft - s Tɛibranit ‘afiɣar’.\f*
\m 
\v 8 Inna SIDI i Musa: “Egg ijj n ufiɣar yareqqen uca sars i-t x ict n teḥnact uca man wen ma ittwazeɛfen u ad ɣares ixzar, ad iddar.” \x ◘ \xo 21:8 \xt Yḥ. 3:14\x*
\v 9 Uca igga Musa ijj n ufiɣar n nnḥas uca issars i-t x teḥnact uca xmi izeɛɛef ca n ufiɣar ca n yijjen, uca wanita ixezzar ɣar ufiɣar n nnḥas, \add xenni\add* ad iqqim iddar. \x ◘ \xo 21:9 \xt 2 Ij. 18:4; Yḥ. 3:14\x*
\b
\s1 Zi Ubut ɣar Fisja
\m 
\v 10 \add Xenni\add* fesyen ayt n Israil iqiḍan nsen uca wtin iqiḍan nsen di Ubut. \x ◘ \xo 21:10 \xt Řxř. 33:43 \x*
\v 11 \add Xenni\add* kksen iqiḍan nsen zi Ubut, wtin iqiḍan nsen ɣar arwinat n Ɛabarim di řexřa i \add iǧan\add* zzat i wudem n Mu’ab manis dd-tneqqar tfuct.
\v 12 Ssenni kksen iqiḍan nsen uca wtin iqiḍan nsen di teɣzurt n Zarad.
\v 13 Ssenni kksen iqiḍan nsen uca wtin iqiḍan nsen x ujemmaḍ n \add yeɣzar n\add* Arnun, wenni \add issizřen\add* di řexřa, iffeɣ zi jjihet n weymir n Imuriyyen, minzi aqa Arnun d aymir ak-d Mu’ab, jar Mu’ab d Imuriyyen. \x ◘ \xo 21:13 \xt Řqḍ. 11:18\x*
\v 14 X uya qqaren deg wedlis ittwannḍen n garrat n SIDI:
\b
\m \qt “Wahib di Sufa d tɣezratin n Arnun,\qt*
\m 
\v 15 \qt u tiɣezratin i dd-ihekkwan,\qt*
\m \qt ařami meyyřent ɣar tzeddiɣt n Ɛar,\qt*
\m \qt d tenni isennden x weymir n Mu’ab.”\qt* \x ◘ \xo 21:15 \xt Aɛwd. 2:36; Yac. 13:9, 16; 2 Ṣm. 24:5\x*
\b
\m 
\v 16 Ssenni \add ruḥen\add* ɣar Bi’r, \add ‘Anu’\add*. Wa aqa d anu min xef inna SIDI i Musa: “Smun řgens, \add xenni\add* ad asen wceɣ aman.”
\v 17 Xenni iɣennej Israil izři-ya:
\b
\m \qt “Ngez, \tl a\tl* anu!”\qt*
\m \qt Arrim-dd xas s ijj n izři:\qt*
\m 
\v 18 \qt “\tl Cek\tl* anu, wenni ɣzin řḥukkam,\qt*
\m \qt wenni ineqcen tarwa n taṣiřet n řgens\qt*
\m \qt ak-d umgewwad nsen\qt*
\m \qt s izeǧaḍen nsen \tl n řeḥkamet\tl*.”\qt*
\b
\m Zi řexřa \tl ruḥen\tl* ɣar Mattana,
\v 19 uca zi Mattana ɣar Naḥliyil, zi Naḥliyil ɣar Bamut,
\v 20 uca zi Bamut ɣar teɣzurt nni \add iǧan\add* deg iyyar n Mu’ab, x tqiccat n Fisja nni ittsijjan ɣar tnezruft.
\b
\s1 Aɣelleb x Siḥun d Ɛuj
\m 
\v 21 \add Xenni\add* issekk Israil ireqqasen ɣar Siḥun, ajeǧid n Imuriyyen, inna: \x ◘ \xo 21:21 \xt Aɛwd. 2:26; Řqḍ. 11:19 \x*
\m 
\v 22 “Ejj ayi ad cuqeɣ di temmurt nnec. War nettmeyyiř ca ɣar iyyaren niɣ ɣar imarjaɛen \add nnec\add* n uḍiř u war nsess aman zeg wanuten. Ad neɛdu x webrid igellden, ař ɣa neɛdu x temmurt nnec.” \x ◘ \xo 21:22 \xt Řxř. 20:17 \x*
\v 23 \add Maca\add* Siḥun war yejji ad iẓwa Israil x jjwayeh nnes. Issmun Siḥun marra řgens nnes uca iffeɣ, ḥima ad imsagar ak-d Israil, ɣar řexřa, uca yusa-dd di Yahaṣ uca immneɣ ak-d Israil. \x ◘ \xo 21:23 \xt Aɛwd. 2:30; 29:7; Yac. 24:8; Řqḍ. 11:20 \x*
\v 24 Uca Israil iwta i-t s řeqḍeɛ n ssif uca iksi temmurt nnes d řwart, zi Arnun ař Yabbuq, ař ayt n Ɛammun, minzi jjihet n ayt n Ɛammun aqa-t d \add ijj n lburj\add* ijehden. \x ◘ \xo 21:24 \xt Aɛwd. 2:33,37; 29:7; Yac. 12:2; 24:8; Řqḍ. 11:2; Izhd. 135:11, 12; 136:19; Ɛam. 2:9 \x*
\v 25 Iksi Israil marra tineddam-a uca izdeɣ Israil di marra tineddam n Imuriyyen, di Ḥacbun u di marra tneddam i ɣares dd-iqqnen. \x ◘ \xo 21:25 \xt Aɛwd. 2:34, 35\x*
\v 26 Minzi Ḥacbun tuɣa d tandint n Siḥun, ajeǧid n Imuriyyen, uca netta tuɣa immneɣ ak-d ujeǧid i d as dd-izwaren n Mu’ab uca iksi zzayes marra tammurt nnes ař Arnun.
\v 27 X uya qqaren inni issawařen s wawařen iweznen:
\b
\m \qt “Asem-dd ɣar Ḥacbun,\qt*
\m \qt ad tᵉttwabna u ad tᵉttwaɛdeř\qt*
\m \qt tendint n Siḥun!\qt*
\m 
\v 28 \qt Minzi teffeɣ-dd tmessi zi Ḥacbun\qt*
\m \qt d ijj n uɛeccař zi tendint n Siḥun,\qt*
\m \qt \tl aceɛɛař\tl* nni icca Ɛar n ayt n Mu’ab\qt*
\m \qt řḥukkam n řuɛřat n Arnun.\qt* \x ◘ \xo 21:28 \xt Ica. 48:45\x*
\m 
\v 29 \qt Uct xak, Mu’ab!\qt*
\m \qt Aqa ittwahellek řgens n Kamuc.\qt*
\m \qt Iḥenjiren nnes i tuɣa yarewřen\qt*
\m \qt d tḥenjirin nnes,\qt*
\m \qt aqa isellem i-ten d imeḥbas i Siḥun,\qt*
\m \qt ajeǧid n Imuriyyen.\qt* \x ◘ \xo 21:29 \xt 1 Ij. 11:7, 33 \x*
\m 
\v 30 \qt Aqa newwet i-ten \tl s fřitcat\tl*.\qt*
\m \qt Ḥacbun ittwahellek ař Dibun.\qt*
\m \qt Nareddeǧ i-ten ař Nufaḥ\qt*
\m \qt tenni \tl iǧan\tl* ař Midaba.”\qt*
\b
\m 
\v 31 Ammu i idweř Israil ad izdeɣ di temmurt n Imuriyyen.
\v 32 Uca issekk Musa ibergagen ɣar Yaɛzir uca ksin tineddam i ɣares dd-iqqnen uca kksen tasɣart n Imuriyyem nni tuɣa din \add izeddɣen\add*.
\m 
\v 33 \add Xenni\add* meyyřen zeg webrid nsen, uřyen abrid ɣar Bacan. \add Xenni\add* iffeɣ-dd Ɛuj, ajeǧid n Bacan, netta d marra řgens nnes, maḥend ad kidsen imsagar i umenɣi di Idraɛi. \x ◘ \xo 21:33 \xt Aɛwd. 3:1; 29:7\x*
\v 34 Inna SIDI i Musa: “War zzayes tteggʷed ca, minzi Necc ggiɣ t deg ufus nnec, ak-d marra řgens nnes d temmurt nnes uca ad zzayes tegged am mammec teggid zi Siḥun ajeǧid n Imuriyyen, wenni tuɣa izeddɣen di Ḥacbun.” \x ◘ \xo 21:34 \xt Izhd. 136:20\x*
\v 35 Uca areddǧen t, netta d iḥenjiren nnes d marra řgens nnes, ař mani war iqqim uřa d ijj n umařwar zzayes uca ksin tammurt nnes d řwart. \x ◘ \xo 21:35 \xt Izhd. 136:20, 21, 22\x*
\b
\b
\c 22
\s1 Balɛam ittwařaɣa zi Balak
\m 
\v 1 \add Xenni\add* fesyen ayt n Israil iqiḍan nsen uca wtin iqiḍan nsen di řewḍat n Mu’ab, arendad n Ariḥa nni iǧan x ujemmaḍ n L’Urdun.
\v 2 Uca iẓra Balaq, mmis n Ṣiffur, marra min igga Israil deg Imuriyyen.
\v 3 Mu’ab tuɣa itteggʷed aṭṭas zi řgens-a, minzi tuɣa aten deg waṭṭas. Mu’ab tuɣa ittnexřaɛ zeg ayt n Israil.
\m 
\v 4 \add Xenni\add* inna Mu’ab i imɣaren n Midyan: “Řexxu řɣaci-ya ad iřseḥ marra min d aneɣ-dd innḍen, am mammec iřesseḥ ufunas taziyzawt n yeyyar.” \add Tuɣa\add* Balaq, mmis n Ṣiffur, ajeǧid n Mu’ab.
\v 5 Issekk ireqqasen ɣar Balɛam, mmis n Baɛur, ɣar \add tendint n\add* Fatur ɣar yeɣzar \add n Lfuraṭ\add*, \add di\add* temmurt n ayt n řgens nnes, maḥend ad as dd-řaɣan uca \add netta\add* inna: “Xzar, iffeɣ-dd ijj n řgens zi Miṣra uca xzar, aqa idřa udem n temmurt uca aqa nitni zeddɣen nican arendad inu. \x ◘ \xo 22:5 \xt Yac. 24:9 \x*
\v 6 As-dd řexxu, nɛeř řgens di ṭṭweɛ inu, minzi aqa ijhed xafi. Ad taɣ necc zemmareɣ ad t ɣeřbeɣ niɣ ad t ssuffɣeɣ zi temmurt, minzi necc ssneɣ belli wi ɣa tbarked cek, ad ittwabarek u wi ɣa tneɛřed, ad ittwanɛeř.”
\m 
\v 7 \add Xenni\add* ruḥen imɣaren n Mu’ab d imɣaren n Midyan ak-d řmunet n uɛezzem deg ufus nsen, iwḍen ɣar Balɛam uca ssiwřen akides \add s\add* wawařen n Balak.
\v 8 Netta inna asen: “Sensem da ǧiřet-a, \add xenni\add* necc ad xawem dd-arreɣ am mammec ɣari ɣa issiweř SIDI.” \add Xenni\add* qqimen řḥukkam n Mu’ab ɣar Balɛam.
\v 9 Yusa-dd AREBBI ɣar Balɛam, inna: “Min ɛnan iryazen nni iǧan akidek?”
\v 10 Inna Balɛam i AREBBI: “Balak, mmis n Ṣiffur, ajeǧid n Mu’ab, issekk i-ten-dd ɣari, \add inna\add*:
\v 11 ‘Xzar, ijj n řgens iffeɣ-dd zi Miṣra u aqa idřa udem n temmurt. As-dd, nɛeř i-t di ṭṭweɛ inu. Ad taɣ zemmareɣ \add xenni\add* ad kisen menɣeɣ niɣ ad ten ssuffɣeɣ.’”
\v 12 Inna AREBBI i Balɛam: “War ttriḥ kisen niɣ ad tneɛřed řgens nni, minzi řgens aqa ittwabarek.”
\m 
\v 13 \add Xenni\add* ikkar Balɛam di ṣṣbeḥ uca inna i řḥukkam n Balak: “Dewřem-dd ɣar temmurt nwem, minzi SIDI war d ayi ismiḥ ḥima ad raḥeɣ akidwem.”
\v 14 \add Xenni\add* kkaren řḥukkam n Mu’ab uca dewřen-dd ɣar Balak uca nnan: “Balɛam yugi ad dd-yas akidneɣ.”
\b
\m 
\v 15 Issekk Balak ɛawed řḥukkam, \add ɛad\add* ktar u \add ɛad\add* wenni icennɛen ktar x yina \add imezwura\add*.
\v 16 Usin-dd ɣar Balɛam, nnan: “Ammu i iqqar Balak, mmis n Ṣiffur: ‘Ttzawgeɣ cek, war ttejji ixef nnec maḥend war ɣari dd-ttased,
\v 17 minzi ad cek karrmeɣ s waṭṭas uca ad ggeɣ marra min d ayi ɣa tinid. Ttzawgeɣ cek, as-dd uca nɛeř řgens-a di ṭṭweɛ inu!”
\m 
\v 18 Yarra-dd Balɛam uca inna i imsexxaren n Balak: “Waxxa Balak ad ayi iwc taddart nnes teccur s nnuqart d wureɣ, \add ɛad\add* war zmireɣ ad ffɣeɣ x řumur n SIDI, AREBBI inu, \add maḥend ad ggeɣ\add* ca n řḥajjet d tameẓyant niɣ ca n řḥajjet d tameqqrant. \x ◘ \xo 22:18 \xt Řxř. 24:13 \x*
\v 19 \add Xenni\add* řexxu, ttzawageɣ kenniw, qqimem danita ǧiřet-a ḥima ad ssneɣ min d ayi ɣa yini SIDI ɛad ktar.”
\v 20 Di ǧiřet yusa-dd AREBBI ɣar Balɛam, inna as: “Mařa dewřen-dd yeryazen nni maḥend ad ac dd-řaɣan, kkar \add xenni\add* uca ruḥ akidsen. Maca war ttegg mɣir min d ac ɣa iniɣ.”
\v 21 Ikkar Balɛam ɣar ṣṣbeḥ uca iḥezzem i teɣyuč nnes uca yuyur ak-d řḥukkam n Mu’ab.
\b
\m 
\v 22 \add Xenni\add* yarɣa weɣḍab n AREBBI, minzi netta iruḥ uca lmalak n SIDI ibedd deg webrid \add am\add* cciṭan ḍidd nnes. Netta inya x teɣyuč nnes uca tnayen n imsexxaren tuɣa aten akides.
\v 23 Uca taɣyuč teẓra lmalak n SIDI ibedd deg webrid s ssif nnes ittwajebden deg ufus nnes. S uyenni teřḥem teɣyuč zeg webrid uca tuyur deg iyyar. \add Xenni\add* iwta Balɛam taɣyuč ḥima ad tt yarr ɣar webrid. \x ◘ \xo 22:23 \xt 2 Bṭ. 2:16; Yah. 11\x*
\m 
\v 24 Maca lmalak n SIDI ibedd deg ict n tebridt teḥṣar jar imarjaɛen n uḍiř s yijj n weɣbar ɣar ṭṭarf d ijj n weɣbar ɣar ṭṭarf nneɣnit.
\v 25 Umi teẓra teɣyuč lmalak n SIDI, teřṣeq ɣar weɣbar uca ittwaḥṣar uḍar n Balɛam ak-d weɣbar uca netta iqqim iccat i-tt.
\m 
\v 26 \add Uca\add* iruḥ lmalak n SIDI ɣar zzat uca ibedd deg ijj n wemcan iḥṣar aṭṭas ař mani war ittwif ttasiɛ maḥend ad iḥeyyed \add ɣar\add* yefus uřa \add ɣar\add* uzeřmaḍ.
\v 27 Umi teẓra teɣyuč lmalak n SIDI, tbarc sadu Balɛam uca Balɛam ixeyyeq aṭṭas uca ifarc taɣyuč s yijj n ukeccuḍ.
\m 
\v 28 \add Xenni\add* yarzem SIDI aqemmum n teɣyuč uca tenna i Balɛam: “Min d ac ggiɣ umi d ayi tfarced \add řexxu ɛad\add* třata n imuren?” \x ◘ \xo 22:28 \xt 2 Bṭ. 2:16; Yah. 11\x*
\v 29 \add Xenni\add* inna Balɛam i teɣyuč: “Minzi cem tbuṣared xafi. Mři ɣari ssif deg ufus inu, ad tiři xenni nɣiɣ cem!”
\v 30 Tenna teɣyuč i Balɛam: “Ma war ǧiɣ necc taɣyuč nnec i xef tenyid zeg wami necc ɣarek ǧiɣ ař ass-a? Ma aqa necc nnumeɣ tteggeɣ ak kik ammu?” Uca yarra-dd \add xas\add*: “Lla!”
\v 31 Xenni yarzem SIDI tiṭṭawin n Balɛam ařami iẓra lmalak n SIDI ibedd deg webrid s ssif nnes ittwajebden deg ufus nnes. \add Xenni\add* yuḍar Balɛam, ibendeq s uɣembub nnes \add ɣar temmurt\add*.
\v 32 Inna as lmalak n SIDI: “Mayemmi tewtid taɣyuč nnec třata n imuren? Xzar, aqa Necc ffɣeɣ-dd \add am\add* ijj n weɣrim, minzi abrid-a ittḍarra ayi Necc nican. \x ◘ \xo 22:32 \xt 2 Bṭ. 2:15\x*
\v 33 Teẓra ayi teɣyuč uca teřḥem xenni zi zzat i wudem inu třata n imuren. Mařa war teřḥim zi zzat i wudem inu, \add xenni\add* Necc ad yiři aqa řexxu nɣiɣ cek u nettat ad tt jjeɣ ad teddar.”
\v 34 \add Xenni\add* inna Balɛam i lmalak n SIDI: “Aqa necc xḍiɣ, minzi war ssineɣ belli Cek tbedded zzati deg webrid. Ɛad řexxu, mařa aya d řɛib di tiṭṭawin nnec, necc ad dd-dewřeɣ.”
\v 35 Inna lmalak n SIDI i Balɛam: “Ruḥ ak-d iwdan-a, maca siweř waha min d ac ɣa iniɣ Necc.” \add Ammu\add* iruḥ Balɛam ak-d řḥukkam n Balak.
\b
\m 
\v 36 \add Umi\add* Balak isřa, aqa Balɛam yusa-dd, iruḥ ḥima ad t immeřqa ɣar tandint n Mu’ab i iǧan ɣar jjihet n weymir n Arnun, ɣar ṭṭarf n jjihet n weymir.
\v 37 Uca Balak inna i Balɛam: “Ma war ssekkeɣ necc \add iwdan\add* ad ac dd-řaɣan? Mayemmi war ɣari dd-tusid? Ma war zemmareɣ necc ad cek karmeɣ?”
\v 38 \add Xenni\add* yarra-dd Balɛam x Balak: “Xzar, necc usiɣ-dd ɣarek, \add maca\add* ma zemmareɣ necc řexxu ad ssiwřeɣ x ca? Awař nni i ɣa yegg SIDI deg uqemmum inu, ad t iniɣ.” \f ◼ \fr 22:38 \fk yarra-dd\ft - s Tɛibranit ‘inna’.\f*
\v 39 Uca iruḥ Balɛam ak-d Balak uca usin-dd ɣar Qaryat-Ḥaṣut.
\v 40 \add Xenni\add* iɣarṣ Balak i ifunasen d wuǧi, issekk \add zzaysen\add* ɣar Balɛam u ɣar řḥukkam nni tuɣa akides.
\v 41 Ɣar ṣṣbeḥ imsar belli Balak yiwi akis Balɛam uca issiři i-t x řuɛřat n Baɛl mani tuɣa izemmar ad iẓar řgens ař ṭṭarf iggʷejen qaɛ.
\b
\b
\c 23
\s1 Balɛam ibarek Israil
\m 
\v 1 \add Xenni\add* inna Balɛam i Balak: “Bna sebɛa n iɛalṭaren danita i necc uca sewjed ayi sebɛa n ifunasen imeẓyanen d sebɛa n icarriyyen.”
\v 2 Balak igga am mammec d as inna Balɛam uca Balak d Balɛam qeddmen ijj n ufunas ameẓyan d ijj n icarri x \add kuř ijj n\add* uɛalṭar.
\v 3 \add Xenni\add* Balɛam inna i Balak: “Bedd \add din\add* zzat i tɣarṣt n wecmaḍ nnec, \add xenni\add* necc ad raḥeɣ. Ad taɣ ad kidi imsagar SIDI uca mammec ma igga wawař nni d ayi ɣa isscen, necc ad ac t-i-dd-ssargbeɣ.” \add Xenni\add* iruḥ \add Balɛam\add* ɣar \add tqiccat\add* d taqeccart \add n wedrar\add*.
\m 
\v 4 U immeřqa AREBBI ak-d Balɛam uca \add netta\add* inna as: “Aqa sswejdeɣ sebɛa n iɛalṭaren uca qeddmeɣ ijj n ufunas ameẓyan d ijj n icarri x \add kuř ijj n\add* uɛalṭar.”
\v 5 \add Xenni\add* igga SIDI ijj n wawař deg uqemmum n Balɛam uca inna: “Dweř ɣar Balak uca siweř \add akides\add* ammu.”
\m 
\v 6 Uca \add umi\add* ɣares-dd idweř, xzar, ibedd zzat i tɣarṣt n wecmaḍ nnes, \add jmiɛ\add* ak-d marra řḥukkam n Mu’ab.
\v 7 \add Xenni\add* ibda iqqar awař nnes iweznen, inna:
\b
\m \qt “Zi Aram indeh ayi-dd Balak, ajeǧid n Mu’ab,\qt*
\m \qt zeg idurar n ccarq, inna:\qt*
\m \qt ‘As-dd, nɛeř ayi Yaɛqub,\qt*
\m \qt as-dd, zawar Israil!’\qt*
\m 
\v 8 \qt \tl Maca\tl* mammec ɣa neɛřeɣ,\qt*
\m \qt wenni war ittwaneɛřen zi Arebbi,\qt*
\m \qt u mammec ɣa zawareɣ\qt*
\m \qt wenni war izawar SIDI?\qt*
\m 
\v 9 \qt Minzi zi tqiccat n tṣuḍar twařiɣ t,\qt*
\m \qt uca zi tiwririn xezzareɣ dayes.\qt*
\m \qt Aqa wa d ijj n řgens izeddɣen weḥḥdes\qt*
\m \qt u war iḥesseb ixef nnes jar řegnus.\qt* \x ◘ \xo 23:9 \xt Aɛwd. 33:28\x*
\m 
\v 10 \qt Wi ɣa iḥesben acař n Yaɛqub\qt*
\m \qt niɣ \tl wi i ɣa iḥesben\tl* řqedd n ijj n arbeɛ zi Israil?\qt*
\m \qt Ejj ad immet řeɛmar inu\qt*
\m \qt řmewt n imseggaden\qt*
\m \qt u ejj ɛawed ad yiři uneggar \tl n tudart\tl* inu\qt*
\m \qt ad imqudda akides!”\qt*
\b
\m 
\v 11 \add Xenni\add* inna Balak i Balɛam: “Min d ayi teggid? Necc iwyeɣ cek ḥima ad tneɛřed řɛedyan inu, \add maca\add* xzar, aqa nican tbarked i-ten!”
\v 12 Netta yarra-dd, inna: “Ma war ittxeṣṣi ad ḥḍiɣ maḥend ad ssiwřeɣ min igga SIDI deg uqemmum inu?”
\v 13 \add Xenni\add* inna Balak: “Ttzawgeɣ cek ad dd-tased akidi ɣar ijj n wemcan nneɣni zi manis ɣa tẓared řgens \add ɛawed\add*. Ad tẓared ṭṭrufa nnes waha, war t tẓarred marra. Ssenni ad t tneɛřed di ṭṭweɛ inu!”
\m 
\v 14 Uca yiwyi i-t ɣar řewḍa n Ṣufim x tqiccat n Fisja uca ibna \add din\add* sebɛa n iɛalṭaren uca x \add kuř ijj n\add* uɛalṭar iqeddem ijj n ufunas ameẓyan d ijj n icarri.
\v 15 Netta inna i Balak: “Mařa cek ad tbedded da zzat i tɣarṣt nnec n wecmaḍ, xenni necc ad \add kis\add* mmsagareɣ din.”
\v 16 Uca imsagar SIDI ak-d Balɛam uca igga ijj n wawař deg uqemmum nnes, inna: “Dweř ɣar Balak uca ini as ammu.” \x ◘ \xo 23:16 \xt Řxř. 22:35\x*
\v 17 Uca netta yusa-dd ɣares, u xzar, netta tuɣa ibedd zzat i tɣarṣt n wecmaḍ nnes uca řḥukkam n Mu’ab bedden zzates. Inna as Balak: “Min inna SIDI?”
\m 
\v 18 \add Xenni\add* ibda netta awař nnes iweznen, inna:
\b
\m \qt “Kkar, Balak, sḥess!\qt*
\m \qt Seř ɣari, \tl cek\tl*, mmis n Ṣiffur!\qt*
\m 
\v 19 \qt Arebbi war iǧi d mmis n bnadem,\qt*
\m \qt maḥend zeɛma ad issxarriq,\qt*
\m \qt niɣ d mmis n bnadem\qt*
\m \qt maḥend zeɛma ad t iřqef wendam.\qt*
\m \qt Ma ad yini uca war tt ittegg,\qt*
\m \qt niɣ ad issiweř uca war tt ittkemmiř?\qt* \x ◘ \xo 23:19 \xt 1 Ṣm. 15:29; Yaɛ. 1:17\x*
\m 
\v 20 \qt Xzar, aqa ṭṭfeɣ \tl řumur\tl* ḥima ad barkeɣ.\qt*
\m \qt Umi ibarek Netta,\qt*
\m \qt necc war zemmareɣ ad dd-arreɣ aya.\qt*
\m 
\v 21 \qt War ittwiři řmuɛṣiyyet n Yaɛqub\qt*
\m \qt u řeɣben n Israil war t iẓar.\qt*
\m \qt SIDI, AREBBI nnes, aqa-t akides\qt*
\m \qt uca asuḍi s wesruddeḥ \tl di řbuq\tl*\qt*
\m \qt di ṭṭweɛ n Ujeǧid aqa-t dayes.\qt* \x ◘ \xo 23:21 \xt Izhd. 32:1, 2; 51:11; Irm. 50:20; Rum. 4:7\x*
\m 
\v 22 \qt Arebbi issuffeɣ i-ten-dd zi Miṣra.\qt*
\m \qt Netta i nitni am waccawen \tl iziraren\tl*\qt*
\m \qt n iɣayḍ n řexřa.\qt* \x ◘ \xo 23:22 \xt Řxř. 24:8\x*
\m 
\v 23 \qt Aqa zeɛma war din aɛezzem di Yaɛqub\qt*
\m \qt u war din tagezzant di Israil.\qt*
\m \qt Ta d řweqt i di tᵉttwanna x Yaɛqub d Israil:\qt*
\m \qt ‘\tl Aqa xzar\tl*, min igga Arebbi!’\qt*
\b
\m 
\v 24 \qt Aqa da, řgens ad ikkar am teyradt\qt*
\m \qt u ad dd-igeɛɛed am weyrad.\qt*
\m \qt War issezzeř ixef nnes\qt*
\m \qt ař ɣa yecc taymart nnes\qt*
\m \qt uca ad issu idammen n min imezzeq.”\qt* \f ◼ \fr 23:24 \fk min imezzeq\ft - nican zi Tɛibranit ‘min issnuqqeb’ niɣ ‘min isseyzem’.\f*
\b
\m 
\v 25 \add Xenni\add* inna Balak i Balɛam: “Mařa \add xenni\add* war texsed qaɛ ad t tneɛřed, war t ttbarak ca ɛawed.”
\m 
\v 26 Balɛam yarra-dd, inna i Balak: “Ma war d ac nniɣ: ‘Marra min d ayi ɣa yini SIDI, ad t ggeɣ?’”
\m 
\v 27 \add Xenni\add* inna Balak i Balɛam: “Ttzawgeɣ cek ad dd-tased, ad cek awyeɣ ɣar ijj n wemcan nneɣni. Ad taɣ ad yiři nican di tiṭṭawin n AREBBI mařa ad t tneɛřed ssenni di ṭṭweɛ inu.”
\v 28 Uca Balak indeh Balɛam ɣar tqiccat n Faɣur nni ixezzaren ɣar tnezruft.
\v 29 \add Xenni\add* inna Balɛam i Balak: “Bna danita sebɛa n iɛalṭaren uca sewjed ayi danita sebɛa n ifunasen imeẓyanen d sebɛa n icarriyyen.”
\v 30 Balak igga am mammec d as inna Balɛam uca x kuř ijj n uɛalṭar iqeddem \add din\add* ijj n ufunas ameẓyan d ijj n icarri.
\b
\b
\c 24
\s1 Awařen iweznen n Balɛam
\m 
\v 1 Iẓra Balɛam belli aqa yarḍa i tiṭṭawin n SIDI umi ibarek Israil uca \add xenni\add* war yarezzu, am umur \add amezwaru\add* d umur \add wiss tnayen\add*, ḥima \add ad iɛezzem\add* s ifiɣran, maca yarra udem nnes ɣar řexřa.
\v 2 \add Umi\add* issgeɛɛed tamuɣři nnes, iẓra Israil izdeɣ \add din\add*, \add tᵉttwasettef\add* ɛlaḥsab tiqebbař nnes, \add xenni\add* yusa-dd Arruḥ n AREBBI xas.
\v 3 Ibda netta awař nnes iweznen, inna:
\b
\m \qt “Awař n Balɛam, mmis n Baɛur,\qt*
\m \qt awař n weryaz ijehden, wenni umi teqqen tiṭṭ,\qt*
\m 
\v 4 \qt ijj n wawař n wenni isřin awařen n Arebbi,\qt*
\m \qt d wenni ixezzaren řewḥiy\qt*
\m \qt n Umzemmar x kuřci,\qt*
\m \qt \tl am\tl* dd-iwḍa s tiṭṭawin yarezmen.\qt*
\m 
\v 5 \qt \tl A\tl* Yaɛqub, mecḥař ṣebḥen iqiḍan nnec,\qt*
\m \qt d tzeddiɣin nnec, \tl a\tl* Israil!,\qt*
\m 
\v 6 \qt aqa sswiẓẓaḍen amecnaw tiɣzurin,\qt*
\m \qt amecnaw aɣemmuy icewwaren ak-d yeɣzar,\qt*
\m \qt amecnaw acfiř nni iẓẓu SIDI,\qt*
\m \qt amecnaw ticejjura n tengelt\qt*
\m \qt zzat i waman.\qt* \f ◼ \fr 24:6 \fk acfiř\ft - ixs ad yini ‘aluwi’ (‘aluwis’)\f*
\m 
\v 7 \qt Zeg ibuqařen nnes ad ssizzřen waman\qt*
\m \qt uca zzariɛet nnes \tl ad tiři\tl* di tuffet.\qt*
\m \qt Ajeǧid nnes ad ittwassgeɛɛed x Ajaj\qt*
\m \qt u tageldit nnes ad tᵉttwassuɛřa.\qt*
\m 
\v 8 \qt Arebbi issuffeɣ i-t-i-dd zi Miṣra.\qt*
\m \qt Jjehd nnes am waccawen \tl iziraren\tl*\qt*
\m \qt n iɣayḍ n řexřa.\qt*
\m \qt Ad yecc řegnus, iɣrimen nnes,\qt*
\m \qt ad iřbez iɣussan nsen\qt*
\m \qt uca ad \tl ten\tl* issnuqqeb s fřitcat nnes.\qt* \x ◘ \xo 24:8 \xt Řxř. 23:22\x*
\m 
\v 9 \qt Aqa iɣnes,\qt*
\m \qt issezzeř ixef nnes am weyrad,\qt*
\m \qt am teyradt.\qt*
\m \qt Wi t i dd ɣa issekkaren?\qt*
\m \qt Wenni cek ittbarken, ad ittwabarek\qt*
\m \qt u wenni cek ineɛɛřen, ad yiři ittwanɛeř!’”\qt*\x ◘ \xo 24:9 \xt Amz. 49:9; Řxř. 23:24\x*
\b
\m 
\v 10 \add Xenni\add* yarɣa uxeyyeq n Balak x Balɛam. Iwta netta deg ifassen nnes uca Balak inna i Balɛam: “Aqa řaɣiɣ-dd cek maḥend ad tneɛřed řɛedyan inu, \add maca\add* xzar, aqa tbarked \add i-ten\add* ɛad nican třata n imuren!
\v 11 Xenni řexxu, arweř ɣar wemcan mani tzeddɣed! Necc nniɣ ac t, ad cek cenɛeɣ aṭṭas, \add maca\add* xzar, SIDI imneɛ xak ccenɛet nni!”
\m 
\v 12 \add Xenni\add* inna Balɛam i Balak: “Ma war ssiwřeɣ ak-d ireqqasen nni d ayi dd-tᵉssekked uca nniɣ:
\v 13 ‘Waxxa Balak ad ayi iwc taddart nnes teccur s nnuqart d wureɣ, \add xenni\add* necc \add ɛad\add* war zmireɣ ad ɛeddiɣ x řumur n SIDI, maḥend ad ggeɣ ca n řḥajjet n řxar niɣ n řɣar \add i dd-itteffɣen\add* zeg wuř inu. Min ɣa yini SIDi, ad t iniɣ.’ \x ◘ \xo 24:13 \xt Řxř. 22:18\x*
\v 14 Řexxu xenni, xzar, necc ad dd-dewřeɣ ɣar řgens inu. As-dd, necc ad cek ssaregbeɣ x řefhamet uca ad ac iniɣ min d ac ɣa yegg řgens-a deg uneggar n wussan.”
\m 
\v 15 \add Xenni\add* ibda netta awař iweznen nnes, inna:
\b
\m \qt “Awař n Balɛam, mmis n Baɛur,\qt*
\m \qt awař n weryaz ijehden,\qt*
\m \qt wenni umi teqqen tiṭṭ!\qt*
\b
\m 
\v 16 \qt Tawařt n wenni isřin awařen n Arebbi,\qt*
\m \qt d wenni issnen zi tussna\qt*
\m \qt n wenni d Amɛuǧi x kuřci,\qt*
\m \qt d wenni ixezzaren řewḥiy\qt*
\m \qt n Umzemmar x kuřci,\qt*
\m \qt \tl am\tl* dd-iwḍa s tiṭṭawin yarezmen.\qt*
\m 
\v 17 \qt Ad t ẓarɣ, war iǧi řexxu,\qt*
\m \qt ad t twařiɣ, \tl maca\tl* war iǧi zi řadaset.\qt*
\m \qt Ad dd-iffeɣ itri zi Yaɛqub\qt*
\m \qt uca ad tekkar uzeǧaḍ\qt*
\m \qt \tl n řḥakem\tl* zi Israil,\qt*
\m \qt wenni i ɣa iřebzen lḥenkat\qt*
\m \qt \tl n uzeǧif\tl* n Mu’ab\qt*
\m \qt uca ad iřbez marra tarwa n ssdeɛ\qt* \x ◘ \xo 24:17 \xt Irm. 48:45\x*
\m 
\v 18 \qt uca ad ittwaṭṭef Idum d řwart\qt*
\m \qt u Saɛir, \tl wenni\tl* d řeɛdu nnes,\qt*
\m \qt ad t ṭṭfen d řwart \tl ɛawed\tl*,\qt*
\m \qt uca \tl ammu\tl* i ɣa yegg Israil s taryast.\qt*
\m 
\v 19 \qt U \tl wenni i dd ɣa iffɣen\tl* zi Yaɛqub ad iḥkem\qt*
\m \qt u netta ad isshellek\qt*
\m \qt wenni yarewřen zi tendint.”\qt* \x ◘ \xo 24:19 \xt 2 Ṣm. 8:14\x*
\b
\m 
\v 20 \add Umi\add* netta iẓra Ɛamaliq, ibda awař iweznen nnes, inna:
\b
\m \qt “Ɛamaliq d amezwaru n řegnus,\qt*
\m \qt maca aneggaru nnes ad idweř d ahellek!”\qt*
\b
\m 
\v 21 \add Řami\add* iẓra Iqiniyyen, ibda netta awař iweznen nnes, inna:
\b
\m \qt “Tazeddiɣt nnec temten\qt*
\m \qt uca teggid řɛucc nnec di teṣḍart.\qt*
\m 
\v 22 \qt Ɛad Qayin ad ittwassecmeḍ.\qt*
\m \qt Ař meřmi izemmar Accur\qt*
\m \qt ad ac dd-yawi d ameḥbus?”\qt*
\b
\m 
\v 23 Uca ibda netta awař iweznen nnes, inna:
\b
\m \qt “Ay, wi ɣa iqqimen iddaren\qt*
\m \qt xmi xas i ɣa issars Arebbi man aya?\qt*
\m 
\v 24 \qt Iɣarruba zi jjwayeh n Kittim\qt*
\m \qt ad ɣezzan Accur\qt*
\m \qt uca ad ɣezzan \tl ɛawed\tl* Ɛabir\qt*
\m \qt u netta ad ittwateḥḥa.”\qt* \f ◼ \fr 24:24 \fk Kittim\ft - ixs ad yini ‘Qubrus’.\f*
\b
\m 
\v 25 Ikkar Balɛam, yuyur uca idweř ɣar wemcan nnes \add n tzeddiɣt\add*. Uřa d Balak iṭṭef abrid nnes.
\b
\b
\c 25
\s1 Israil d l’aṣnam n yessis n Mu’ab
\m 
\v 1 Izdeɣ Israil di Ciṭṭim uca ibda řgens ad issefsed ixef nnes ak-d yessis n Mu’ab. \x ◘ \xo 25:1 \xt Řxř. 31:16; 33:49\x*
\v 2 Ɛarḍen-dd řgens ɣar tɣarṣi n irebbiten nsent uca řgens icca \add zzaysent\add*, uca nitni bendqen i irebbiten nsent. \x ◘ \xo 25:2 \xt Izhd. 106:28; Ḥuc. 9:10\x*
\v 3 \add Ammu\add* imun řgens ak-d Baɛl-Faɣur uca yarɣa weɣḍab n SIDI x Israil. \x ◘ \xo 25:3 \xt Izhd. 106:29\x*
\m 
\v 4 Inna SIDI i Musa: “Ksi marra \add iryazen nni iǧan\add* d izeǧifen n řgens uca ayeř i-ten zzat i SIDI di tfuct \add iḥarren\add*, \add xenni\add* ad iggʷej řḥaduq n weɣḍab n SIDI x Israil.” \x ◘ \xo 25:4 \xt Aɛwd. 4:3; Yac. 22:17\x*
\v 5 \add Xenni\add* inna Musa i řquḍat n Israil: “Ejj kuř ijj ad ineɣ \add inni\add* zi jar yeryazen nnes i imunen ak-d Baɛl-Faɣur!”
\m 
\v 6 Uca xzar, ijj n weryaz zeg ayt n Israil yusa-dd uca netta yiwi-dd ict n \add temɣart\add* Tmidiyanect ɣar aytmas zzat i tiṭṭawin n Musa u zzat i tiṭṭawin n marra tamesmunt n ayt n Israil, am ttrun nitni ɣar wadaf n Uqiḍun n Umsagar.
\v 7 Iẓra i-t Finaḥas, mmis n Aliɛazar, mmis n Harun. Netta ikkar zi řwesṭ n tmesmunt, iksi ijj n uḥric deg ufus nnes \x ◘ \xo 25:7 \xt Izhd. 106:30\x*
\v 8 uca iruḥ awarni i weryaz zi Israil ɣar uqiḍun s řqubbet uca issnuqqeb i-ten s tnayen, \add am\add* weryaz nni zi Israil, am temɣart s uɛeddis nnes. \add Xenni\add* tbedd jjriḥect x ayt n Israil.
\v 9 Uca mmuten di jjriḥect arebɛa u-ɛicrin-ařef \add n iwdan\add*. \x ◘ \xo 25:9 \xt 1 Kur. 10:8\x*
\m 
\v 10 Issiweř SIDI ak-d Musa, inna:
\m 
\v 11 “Fineḥas, mmis n Aliɛazar, mmis n Harun, akehhan, isseggwej asɛar inu x ayt n Israil, minzi netta tuɣa imḥeḍ \add aṭṭas\add* di řwesṭ nsen di ṭṭweɛ n tusmi inu \add iqeddsen\add*, ařami Necc war \add hdijeɣ ɛad\add* ad teḥḥiɣ ayt n Israil di \add řweqt n\add* tusmi inu \add iqeddsen\add*. \x ◘ \xo 25:11 \xt 2 Kur. 11:2\x*
\v 12 S uya ini: ‘Xẓar, Necc ad as wceɣ Řɛahd inu n řehna. \x ◘ \xo 25:12 \xt 106:31\x*
\v 13 I netta u i zzariɛet nnes awarni as ad ɣarsen yiři Řɛahd n tukehhant i řebda, minzi netta tuɣa imḥeḍ di ṭṭweɛ n AREBBI nnes uca igga aṣřaḥ di ṭṭweɛ n ayt n Israil.’”
\m 
\v 14 Isem n weryaz n Israil nni inɣa Fineḥas, i tuɣa ittwaneɣ \add jmiɛ\add* ak-d temɣart Tamidyanect, \add tuɣa-t\add* d Zimri, mmis n Salu, ijj n řḥakem x taddart n babatsen, x Icimɛuniyyen.
\v 15 Isem n temɣart Tamidyanict i tuɣa ittwanɣen \add tuɣa-tt\add* Kuzbi, yeǧis n Ṣur, wenni d ijj n uzeǧif x tqebbařt n taddart n ijj n tbabat n Imidyaniyyen.
\b
\m 
\v 16 Issiweř SIDI ak-d Musa, inna:
\m 
\v 17 “Ḥṣarem x Imidyaniyyen uca ɣellbem xasen,\x ◘ \xo 25:17 \xt Řxř. 31:2\x*
\v 18 minzi nitni ḥṣaren kenniw s teḥraymect nsen s minzi kenniw zeřɣen zi jjihet n Faɣur d Kuzbi, yeǧis n řḥakem n Midyan, učmatsen, tenni ittwanɣen deg wass n jjriḥect di ssibbet n Faɣur.” \x ◘ \xo 25:18 \xt Asa. 18:6\x*
\m 
\v 19 Uca awarni i jjriḥect imsar \add min dd-igguren.\add*
\b
\b
\c 26
\s1 Ittwaḥseb Israil i twařa wiss tnayen
\m 
\v 1 Issiweř SIDI ak-d Musa d Aliɛazar, mmis n Harun, akehhan, inna:
\m 
\v 2 “Ḥesbem marra tamesmunt n ayt n Israil, azeǧif \add azeǧif\add*, zi ɛicřin n iseggʷusa sennej, \add am ttwasettfen nitni\add* ɛlaḥsab taddart n ibabaten nsen, marra wenni dd-itteffɣen di Israil ak-d řɛeskar.” \x ◘ \xo 26:2 \xt Řxř. 1:3\x*
\v 3 Musa d Aliɛazar, akehhan, ssiwřen akidsen di řewḍat n Mu’ab, ɣar L’Urdun \add arendad n\add* Ariḥa uca nnan:
\v 4 “Zi ɛicřin n iseggʷusa sennej!” am mammec \add t\add* yumur SIDI i Musa.
\b
\m \add Ina d\add* ayt n Israil nni tuɣa dd-iffɣen zi temmurt n Miṣra: \x ◘ \xo 26:4 \xt Řxř. 1:1, 2, 3\x*
\b
\m 
\v 5 \bd Rubin \bdit tuɣa\bdit* d amenzu n Israil.\bd*
\m \bd Aqa ina d iḥenjiren n Rubin\bd*: \add zi\add* Ḥanuk řaǧ n Iḥanukiyyen, zi Fallu řaǧ n Ifalluwiyyen, \x ◘ \xo 26:5 \xt Amz. 46:9; Uf. 6:14; 1 Im. 5:1\x*
\m 
\v 6 zi Ḥaṣrun řaǧ n Iḥaṣruniyyen, zi Karmi řaǧ n Ikarmiyyen.
\m 
\v 7 Tina \add tuɣa\add* d řaǧat n Irubiniyyen uca inni zzaysen ittwaḥesben tuɣa aten di třata u-rebɛin-ařef u-sebɛa-mya u-třatin \add n yeryazen\add*.
\m 
\v 8 Tarwa n Fallu \add tuɣa aten\add*: \add mɣir\add* Iliyab.
\m 
\v 9 \add Tuɣa\add* arraw n Iliyab: Nimuyil, Datan d Abiram. Ina, Datan d Abiram, tuɣa aten d imřaɣan n tmesmunt inni iɣewwɣen ḍidd i Musa d Harun, \add jmiɛ\add* ak-d ubarru n Quraḥ, umi ɣewwɣen ḍidd i SIDI. \f ◼ \fr 26:9 \fk imřaɣan\ft - ixs ad yin ‘inni ittwařaɣan’.\f*  \x ◘ \xo 26:9 \xt Řxř. 16:12\x*
\v 10 Tammurt tarzem aqemmum nnes uca tsarḍ i-ten, \add jmiɛ\add* ak-d Quraḥ, řami immut ubarru nni umi timessi tecca mitayen u-xemsin n yeryazen. Dewřen nitni d ijj n weɛřam \add issiggwiden\add*.
\v 11 Maca iḥenjiren n Quraḥ war mmuten ca.
\b
\m 
\v 12 \bd \bdit Ina tuɣa\bdit* d iḥenjiren n Cimɛun ɛlaḥsab řaǧat nsen:\bd* \add zi\add* Nimuyil \add iqqarṣ\add* řaǧ n Inimuyiliyyen, zi Yamin řaǧ n Iyaminiyyen, zi Yakin řaǧ n Iyakiniyyen,
\v 13 zi Zaraḥ řaǧ n Izaraḥiyyen, zi Cawul řaǧ n Icawuliyyen.
\v 14 Tina \add tuɣa\add* d řaǧat n Icimɛuniyyen: tnayen u-ɛicrin-ařef u-mitayn \add n yeryazen\add*.
\b
\m 
\v 15 \bd \bdit Ina tuɣa\bdit* d iḥenjiren n Jad ɛlaḥsab řaǧat nsen:\bd* \add zi\add* Ṣifun \add iqqarṣ\add* řaǧ n Iṣifuniyyen, zi Ḥajji řaǧ n Iḥajjiwiyyen, zi Cuni řaǧ n Icuniyyen,
\v 16 zi Uzni řaǧ n Iyuzniyyen, zi Ɛiri řaǧ n Iɛiriyyen,
\v 17 zi Arud řaǧ n Irudiyyen, zi Ariyili řaǧ n Iriyiliyyen.
\v 18 Tina \add tuɣa atent d\add* řaǧat n Jad uca inni zzaysen ittwaḥesben tuɣa aten di arebɛin-ařef u-xemsa-mya.
\b
\m 
\v 19 \bd Ayt n Yahuda\bd* \add tuɣa aten d\add* Ɛir d Unan. \add Maca\add* mmuten Ɛir d Unan di temmurt n Kenɛan. \x ◘ \xo 26:19 \xt Amz. 38:7, 10; 46:12\x*
\v 20 \bd \bdit Ina tuɣa aten\bdit* d iḥenjiren n Yahuda ɛlaḥsab řaǧat nsen\bd*: \add zi\add* Cayla \add iqqarṣ\add* řaǧ n Icilayyen, zi Fariṣ řaǧ n Ifaraṣiyyen, zi Zaraḥ řaǧ n Izaraḥiyyen.
\m 
\v 21 \bd \bdit Ina tuɣa aten\bdit* d iḥenjiren n Fariṣ\bd*: \add zi\add* Ḥaṣrun \add iqqarṣ\add* řaǧ n Iḥaṣruniyyen, zi Ḥamul řaǧ n Iḥamuliyyen. \x ◘ \xo 26:21 \xt Amz. 46:12\x*
\v 22 Tina \add tuɣa atent d\add* řaǧat n Yahuda uca inni zzaysen ittwaḥesben tuɣa aten di setta u-sebɛin-ařef u-xemsa-mya \add n yeryazen\add*.
\b
\m 
\v 23 \bd \bdit Ina tuɣa aten\bdit* d iḥenjiren n Issakar ɛlaḥsab řaǧat nsen:\bd* \add zi\add* Tulaɛ \add iqqarṣ\add* řaǧ n Itulaɛiyyen, zi Puwa řaǧ n Ipuwaniyyen,
\v 24 zi Yacub řaǧ n Iyacubiyyen, zi Cimrun řaǧ n Icimruniyyen.
\v 25 Tina \add tuɣa atent d\add* řaǧat n Issakar uca inni zzaysen ittwaḥesben tuɣa aten di arebɛa u-settin-ařef u-teřt-mya \add n yeryazen\add*.
\b
\m 
\v 26 \bd \bdit Ina tuɣa aten\bdit* d iḥenjiren n Zabulun ɛlaḥsab řaǧat nsen:\bd* \add zi\add* Sarid \add iqqarṣ\add* řaǧ n Isaridiyyen, zi Ilun řaǧ n Iluniyyen, zi Yaḥliyil řaǧ n Iyaḥliyiliyyen.
\v 27 Tina \add tuɣa atent d\add* řaǧat n Izabuluniyyen uca inni zzaysen ittwaḥesben tuɣa aten di settin-ařef u-xemsa-mya \add n yeryazen\add*.
\b
\m 
\v 28 \bd \bdit Ina tuɣa aten\bdit* d iḥenjiren n Yusuf ɛlaḥsab řaǧat nsen:\bd* Manassa d Ifrayim.
\m 
\v 29 \bd \bdit Ina tuɣa aten\bdit* d iḥenjiren n Manassa:\bd* \add zi\add* Makir \add iqqarṣ\add* řaǧ n Imakiriyyen. Makir yejj-dd Jilɛad. Zi Jilɛad \add iqqarṣ\add* řaǧ n Ijilɛadiyyen. \x ◘ \xo 26:29 \xt Yac. 17:1\x*
\m 
\v 30 \bd \bdit Ina tuɣa aten\bdit* d iḥenjiren n Jilɛad\bd*: \add zi\add* Iɛazar \add iqqarṣ\add* řaǧ n Iɛazariyyen, zi Ḥalaq řaǧ n Iḥalaqiyyen,
\v 31 zi Asriyil řaǧ n Isriyiliyyen, zi Cakam řaǧ n Icakamiyyen,
\v 32 zi Cimidaɛ řaǧ n Icimdaɛiyyen, zi Ḥafar řaǧ n Iḥafariyyen.
\m 
\v 33 Ṣalufḥad, mmis n Ḥafar, war tuɣi ɣares ca iḥenjiren, mɣir tiḥenjirin. \add Ina tuɣa aten\add* d ismawen n yessis n Ṣalufḥad: Maḥla, Nuɛa, Ḥujla, Milka d Tirṣa. \x ◘ \xo 26:33 \xt Řxř. 27:1\x*
\m 
\v 34 Tina \add tuɣa atent d\add* řaǧat n Manassa uca inni zzaysen ittwaḥesben tuɣa aten di tnayen u-xemsin-ařef u-sebɛa-mya \add n yeryazen\add*.
\b
\m 
\v 35 \bd Ina \bdit tuɣa aten d\bdit* iḥenjiren n Ifrayim\bd*, ɛlaḥsab řaǧat nsen: \add zi\add* Cutalaḥ \add iqqarṣ\add* řaǧ n Icutalaḥiyyen, zi Bakar řaǧ n Ibakariyyen, zi Taḥan řaǧ n Itaḥaniyyen.
\m 
\v 36 Ina \add tuɣa aten d\add* iḥenjiren n Cutalaḥ: zi Ɛiran řaǧ n Iɛiraniyyen.
\m 
\v 37 Tina \add tuɣa atent d\add* řaǧat n warrawen n Ifrayim uca inni zzaysen ittwaḥesben tuɣa aten di tnayen u-třatin-ařef u-xemsa-mya \add n yeryazen\add*.
\m Ina tuɣa aten d arrawen n Yusuf, \add ttwasettfen\add* ɛlaḥsab řaǧat nsen.
\b
\m 
\v 38 \bd \bdit Ina tuɣa aten\bdit* d iḥenjiren n Binyamin ɛlaḥsab řaǧat nsen:\bd* \add zi\add* Bilaɛ \add iqqarṣ\add* řaǧ n Ibilaɛiyyen, zi Acbil řaǧ n Icbiliyyen, zi Aḥiram řaǧ n Iḥiramiyyen,
\v 39 zi Cafufam řaǧ n Icafufamiyyen, zi Ḥufam řaǧ n Iḥufamiyyen.
\m 
\v 40 \bd \bdit Ina tuɣa aten\bdit* d iḥenjiren n Balaɛ\bd*: Ard d Nuɛman. \add Zi\add* Ard \add iqqarṣ\add* řaǧ n Irdiyyen, zi Nuɛman řaǧ n Inuɛmaniyyen.
\m 
\v 41 Ina \add tuɣa aten d\add* iḥenjiren n Binyamin, ɛlaḥsab řaǧat nsen uca inni zzaysen ittwaḥesben tuɣa aten di xemsa u-rebɛin-ařef u-setta-mya \add n yeryazen\add*.
\b
\m 
\v 42 \bd \bdit Ina tuɣa aten\bdit* d iḥenjiren n Dan ɛlaḥsab řaǧat nsen:\bd* \add zi\add* Cuḥam \add iqqarṣ\add* řaǧ n Icuḥamiyyen. Tina \add tuɣa\add* d řaǧat n Dan, \add ttwasettfent\add* ɛlaḥsab řaǧat nsen.
\m 
\v 43 Marra řaǧat n Icuḥamiyyen, aqa inni zzaysen ittwaḥesben tuɣa aten di arebɛa u-settin-ařef u-arebɛa-mya \add n yeryazen\add*.
\b
\m 
\v 44 \bd \bdit Ina tuɣa aten\bdit* d iḥenjiren n Acir ɛlaḥsab řaǧat nsen:\bd* \add zi\add* Yimna \add iqqarṣ\add* řaǧ n Iyimniyyen, zi Yicwi řaǧ n Iyicwiyyen, zi Beriɛa řaǧ n Ibariɛiyyen.
\m 
\v 45 \bd \bdit Ina tuɣa aten\bdit* d iḥenjiren n Beriɛa:\bd* \add zi\add* Ḥabir \add iqqarṣ\add* řaǧ n Iḥabiriyyen, zi Malkiyil řaǧ n Imalkiyiliyyen.
\v 46 Isem n yeǧis n Acir tuɣa-tt d Saraḥ.
\m 
\v 47 Ina \add tuɣa aten\add* d iḥenjiren n Acir uca inni zzaysen ittwaḥesben tuɣa aten di třata u-xemsin-ařef u-arebɛa-mya \add n yeryazen\add*.
\b
\m 
\v 48 \bd \bdit Ina tuɣa aten\bdit* d iḥenjiren n Naftali ɛlaḥsab řaǧat nsen:\bd* \add zi\add* Yaḥasyil \add iqqarṣ\add* řaǧ n Iyaḥasliyyen, zi Juni řaǧ n Ijuniyyen,
\v 49 zi Yaṣir řaǧ n Iyaṣiriyyen, zi Cillim řaǧ n Icillimiyyen.
\m 
\v 50 Tina \add tuɣa atent\add* d řaǧat n Naftali, ɛlaḥsab řaǧat nsen uca inni zzaysen ittwaḥesben tuɣa aten di xemsa u-rebɛin ařaf u-arebɛa-mya \add n yeryazen\add*.
\b
\m 
\v 51 \bd Ina d inni ittwaḥesben zeg ayt n Israil: setta-mya u-waḥit-ařef u-sebɛa-mya u-třatin \bdit n yeryazen\bdit*\bd*.
\b
\m 
\v 52 Issiweř SIDI ak-d Musa, inna:
\m 
\v 53 “Jar ina ad tᵉttwabḍa temmurt d řwart, ɛlaḥsab řqedd n ismawen \add nsen\add*.
\v 54 I wenni umi ɣar iǧa aṭṭas \add n iwdan\add*, ad tewced ktar d řwart uca i wenni umi ɣar iǧa drus \add n iwdan\add*, ad tewced qell d řwart. Kuř ijjen ɛlaḥsab inni ittwaḥesben ad as temmewc tasɣart nnes. \x ◘ \xo 26:54 \xt Řxř. 33:54\x*
\v 55 Tammurt ad tᵉttwabḍa s tqedduḥt. Nitni ad warten ɛlaḥsab ismawen n tqebbař n řejdud nsen. \x ◘ \xo 26:55 \xt Řxř. 33:54; Yac. 11:23; 14:2\x*
\v 56 Ad tᵉttwabḍa tesɣart n kuř ijj s tqedduḥt jar \add inni iǧan s\add* waṭṭas d \add inni iǧan\add* drus.”
\b
\m 
\v 57 \bd \bdit Ina tuɣa aten\bdit* d inni ittwaḥesben zi Lawi ɛlaḥsab řaǧat nsen:\bd* zi Jarcun řaǧ n Ijarcuniyyen, zi Qahat řaǧ n Iqahatiyyen, zi Marari řaǧ n Imarariyyen. \x ◘ \xo 26:57 \xt Uf. 6:17, 18, 19, 20\x*
\v 58 \add Tuɣa\add* tina d řaǧat n Ilawiyyen: řaǧ n Ilibniyyen, řaǧ n Iḥibruniyyen, řaǧ n Imahliyyen, řaǧ n Imuciyyen, řaǧ n Iquraḥiyyen. Uca Qahat yejj-dd Ɛamram.
\v 59 Tamɣart n Ɛamram qqarent as Jukabad, yeǧis n Lawi, tenni dd-ittwarwen i Lawi di Miṣra. D nettat turuw-dd Harun d Musa d Maryam, učmatsen, i Ɛamram. \x ◘ \xo 26:59 \xt Uf. 2:1, 2; 6:19\x*
\v 60 I Harun ttwarwen as-dd Nadab d Abihu, Aliɛazar d Itamar.
\v 61 Maca Nadab d Abihu mmuten, umi dd-iwyen timessi taɣribt zzat i wudem n SIDI. \x ◘ \xo 26:61 \xt Lawi 10:2; Řxř. 3:4; 1 Im. 24:2\x*
\v 62 Inni zzaysen ittwaḥesben, zeg Ilawiyyen, marra iwetman n ijj n uyur sennej, tuɣa aten di třata u-ɛicrin-ařef. Ina maca war ttwaḥesben ca ak-d ayt n Israil, minzi war d asen temmewc tesɣart d řwart jar ayt n Israil.
\b
\m 
\v 63 Ina \add tuɣa aten d\add* inni ittwaḥesben s \add ufus n\add* Musa d Aliɛazar, akehhan. Nitni ḥesben ayt n Israil di řewḍat n Mu’ab, ɣar L’Urdun arendad n Ariḥa.
\v 64 War tuɣi jar asen uřa d ijj zeg inni ittwaḥesben n Musa d Harun, akehhan, umi ḥesben nitni ayt n Israil di řexřa n Sina.
\v 65 minzi xasen tuɣa inna SIDI ad mmten s tidett di řexřa. War zzaysen iqqim uřa d ijj, mɣir Kalib, mmis n Yafunni, d Yacuwa, mmis n Nun.\x ◘ \xo 26:65 \xt Řxř. 14:28, 29, 34, 35; 1 Kur. 10:5, 6\x*
\b
\b
\c 27
\s1 Yessis n Ṣalufḥad
\m 
\v 1 \add Xenni\add* usint-i-dd yessis n Ṣalufḥad, mmis n Ḥafar, mmis n Jilɛad, mmis n Makir, mmis n Manassa, \add inni iǧan\add* n řaǧat n Manassa, mmis n Yusuf. Ina d ismawen n yessis: Maḥla, Nuɛa, Ḥujla, Milka d Tirṣa.\x ◘ \xo 27:1 \xt Řxř. 26:33; 36:2; Yac. 17:3\x*
\v 2 Tuɣa beddent zzat i wudem n Musa u zzat i wudem n Aliɛazar, akehhan, u zzat i wudem n řḥukkam u zzat i wudem n marra tamesmunt ɣar wadaf n Uqiḍun n Umsagar, nnant:
\v 3 “Babatneɣ immut di řexřa u war t tuɣi jar ubarru n yinni imunen ḍidd i SIDI, deg ubarru n Quraḥ \add war din t tuɣi netta\add*, minzi immut di ddnub nnes u war ɣares tuɣi iḥenjiren. \f ◼ \fr 27:3 \fk jar\ft - s Tɛibranit ‘di řwest n’.\f*  \x ◘ \xo 27:3 \xt Řxř. 14:35; 16:1; 26:64\x*
\v 4 Mayemmi ɣa ikkes isem n babatneɣ zi jar řaǧ nnes, ma minzi war ɣares tuɣi bu uḥenjir? Ewc aneɣ agřa di řwesṭ n aytmas n babatneɣ.”
\m 
\v 5 Musa yiwi ddeɛwa nsent zzat i wudem n SIDI.
\v 6 Issiweř SIDI ak-d Musa, inna:
\m 
\v 7 “\add Aqa aya\add* am mammec t nnant yessis n Ṣalufḥad. Ittxeṣṣa ad asent tewced tasɣart n řwart di  řwest n aytmas n babatsen uca ad xasent tesseɛdud řwart n babatsent. \x ◘ \xo 27:7 \xt Řxř. 36:2\x*
\v 8 Uca ad tessiwřed ak-d ayt n Israil, ad tinid: ‘Mařa ca n yijjen immut břa mmis, \add xenni\add* ad tesseɛdum řwart nnes ɣar yeǧis,
\v 9 u mařa war ɣares yeǧis, ad tewcem řwart nnes i yaytmas.
\v 10 Mařa war ɣares aytmas \add ɛawed\add*, ad tewcem řwart nnes i yaytmas n babas.
\v 11 Mařa babas war ɣares aytmas \add ɛawed\add*, ad tewcem řwart nnes i raǧ nnes, \add i\add* wenni \add i d as dd-\add*yudsen zi řaǧ nnes, ḥima ad tt iwart netta.’ Man aya ad tiři d ict n tewṣeyyet n uzerf i řebda i ayt n Israil, am mammec \add t\add* yumur SIDI i Musa.”
\b
\s1 Ařeqqem n Yacuwa
\m 
\v 12 \add Xenni\add* inna SIDI i Musa: “Geɛɛed-dd adrar-a Abarim uca xzar tammurt nni wciɣ i ayt n Israil. \x ◘ \xo 27:12 \xt Aɛwd. 32:48, 49\x*
\v 13 Xmi tt ɣa tẓared, ad tᵉmmarnid ɣar řgens nnec, uřa d cek, am mammec uřa d umac Harun immarni ɣar řgens nnes, \x ◘ \xo 27:13 \xt Řxř. 20:24\x*
\v 14 minzi kenniw tɣewwɣem zzat i tiṭṭawin nsen ḍidd i řumur inu maḥend ad ayi tessqeddsem di řexřa n Ṣin, řami din \add tuɣa\add* amcubbec di tmesmunt. Aqa d ina d aman n Mariba, ɣar Qadac di řexřa n Ṣin.” \x ◘ \xo 27:14 \xt Řxř. 20:12\x*
\v 15 Issiweř Musa ak-d SIDI, inna:
\m 
\v 16 “Ad igg SIDI, AREBBI n buḥbeřat n marra ddat, aḥeṭṭu x tmesmunt \add deg ufus n\add* ijj n weryaz, \x ◘ \xo 27:16 \xt Řxř. 16:22; Ɛbr. 12:9\x*
\v 17 \add ḥima\add* netta ad iffeɣ zzat i wudem nsen uca ad yadef zzat i wudem nsen uca ad ten indeh ɣar barra, ad ten issidef ɣar daxeř, maḥend tamesmunt n SIDI war tᵉttiři am wuǧi břa ameksaw.” \f ◼ \fr 27:17 \fk ameksaw\ft - niɣ ‘aniči’.\f*  \x ◘ \xo 27:17 \xt 1 Ij. 22:17; Mt. 9:36; Mk. 6:34\x*
\m 
\v 18 \add Xenni\add* inna SIDI i Musa: “Ksi Yacuwa, mmis n Nun, ijj n weryaz i di iǧa Arruḥ, uca sars xas afus nnec \x ◘ \xo 27:18 \xt Aɛwd. 3:21; 34:9 \x*
\v 19 uca ad t tegged zzat i wudem n ukehhan Aliɛazar u zzat i marra tamesmunt, ad as tewced řumur zzat i tiṭṭawin nsen.
\v 20 Ewc as \add ca\add* zeg uweqqar nnec ḥima ad \add as\add* tseř marra tamesmunt n ayt n Israil.
\v 21 Netta ad ibedd zzat i ukehhan Aliɛazar, wenni i ɣa icawar zzat i wudem n SIDI ɛlaḥsab řeḥkam n Urim. X řumur nnes ad dd-ffɣen ɣar barra u x řumur nnes ad adfen ɣar daxeř, netta d marra ayt n Israil uřa d marra tamesmunt.” \x ◘ \xo 27:21 \xt Uf. 28:30; Lawi 8:8\x*
\m 
\v 22 Uca Musa igga am mammec d as yumur SIDI. Yiwi Yacuwa uca issbedd i-t zzat i ukehhan Aliɛazar u zzat i wudem n marra tamesmunt.
\v 23 Issars xas ifassen nnes uca isseɛdu as řumur am mammec d as inna SIDI s tsexxart n Musa.
\b
\b
\c 28
\s1 Tiɣarṣa n kuř ass
\m 
\v 1 Issiweř SIDI ak-d Musa, inna:
\m 
\v 2 “Umur ayt n Israil, ini asen: ‘Ittxeṣṣa kenniw ad teḥḍam x tɣarṣṭ inu, macca inu i tewhibin inu n tmessi, ict n řefwaḥet ittfuḥen i Necc, maḥend ad ayi tent tqeddmem di řweqt nnes ittwaggen.’
\v 3 Ad asen tinid: ‘Aqa ta d tawhibt n tmessi i ittxeṣṣan ad tqeddmem: tnayen n izmaren icnan n ijj n useggʷas, \add am\add* tɣarṣt n wecmaḍ řebda. \x ◘ \xo 28:3 \xt Uf. 29:38\x*
\v 4 Ijj n izmar ad t tesswejded di ṣṣbeḥ uca izmar nneɣni ad t tesswejded jar beddu n wezyen n wass ař dd-tewḍa tmeddit
\v 5 uca \add ak-d man aya\add* am tewhibt \add n řɣiǧet\add* ict n teɛcart \add n yijj n ifa\add* n waren azdad ixeǧḍen s yijj n arbeɛ n ijj n uhinu n zzect, ttwaddzen t-i-dd \add zi zzitun\add*. \x ◘ \xo 28:5 \xt Uf. 16:36; 29:40; Lawi 2:1 \x*
\v 6 Aqa-tt d taɣarṣṭ n wecmaḍ n řebda, tenni tuɣa ittwaggen deg wedrar n Sina am yict n řefwaḥet ittfuḥen, \add aqa-tt\add* d ict n tewhibt n tmessi i SIDI.
\v 7 Tawhibt nnes n useyyeb ad tiři d ijj n arbeɛ n ijj n uhinu i yijj n izmar. Seyyeb tawhibt n useyyeb n ccrab di Zzawect Iqeddsen zzat i SIDI.
\v 8 Ad tesswejded izmar nneɣni jar beddu n wezyen n wass ař dd-tewḍa tmeddit. Ad t tesswejded am mammec \add tesswejded\add* tawhibt \add n řɣiǧet\add* di ṣṣbeḥ u am mammec \add tesswejded\add* tawhibt n useyyeb nnes, \add am\add* ict n tewhibt n tmessi, ict n řefwaḥet ittfuḥen i SIDI.’”
\b
\s1 Tiɣarṣa n kuř ssimana
\m 
\v 9 “Deg wass n ssebt \add ad tesswejded\add* tnayen n izmaren icnan n ijj n useggʷas d tnayen n teɛcurin \add n yijj n ifa\add* n waren azdad am tewhibt \add n řɣiǧet\add* ixeǧḍen s zzect ak-d tewhibt nnes n useyyeb.
\v 10 Aqa-tt d taɣarṣṭ n wecmaḍ n ssebt i mkuř ssebt, ad tt tarnid i tɣarṣt n wecmaḍ n řebda d tewhibt nnes n useyyeb.”
\b
\s1 Tiɣarṣa n kuř uyur
\m 
\v 11 “Deg umezwar n \add kuř ijj n\add* iyuren nwem ittxeṣṣa ad tqeddmem ict n tɣarṣt n wecmaḍ i SIDI: tnayen n ifunasen - imeẓyanen n ict n tfunast - ijj n icarri, sebɛa n izmaren icnan qaɛ n ijj n useggʷas
\v 12 uca \add ak-d man aya\add* třata n teɛcurin n \add ijj n ifa n\add* waren azdad \add am\add* tewhibt \add n řɣiǧet\add* ixeǧḍen s zzect i yijj n ufunas ameẓyan u tnayen n teɛcurin n \add yijj n ifa n\add* waren azdad \add am\add* tewhibt \add n řɣiǧet\add* ixeǧḍen s zzect i yijj n icarri
\v 13 \add uca arni\add* ict n teɛcart n \add yijj n ifa\add* n waren azdad \add am\add* tewhibt \add n řɣiǧet\add* ixeǧḍen s zzect i yijj n izmar. \add Aqa-tt\add* d taɣarṣt n wecmaḍ s ict n řefwaḥet ittfuḥen, \add aqa-tt\add* d ict n tewhibt n tmessi i SIDI.
\v 14 Tiwhibin nsen n useyyeb ad iřint d azyen n uhinu n binu ak-d ufunas ameẓyan d ict n ttuřut n ijj n uhinu ak-d icarri d yijj n arbeɛ n ijj n uhinu ak-d izmar. Ta d taɣarṣt n wecmaḍ n kuř ayur, i kuř ayur zeg iyuren n useggʷas.
\v 15 Ittxeṣṣa ad tesswejded ijj n umyan zeg iɣayḍen d taɣarṣt n ddenb i SIDI, ad tt tarnid i tɣarṣt n wecmaḍ n řebda ak-d tewhibt nnes n useyyeb.”
\b
\s1 Tiɣarṣa deg wussan n Řɛid n Useɛdu
\m 
\v 16 Deg uyur amezwaru, deg wass wiss arbeɛṭac n uyur, ad tiři \add Tɣarṣt n\add* Useɛdu n SIDI. \x ◘ \xo 28:16 \xt Uf. 12:18; 23:15; Lawi 23:5\x*
\v 17 Deg wass wiss xemmesṭac n simant n uyur \add ad yiři\add* Řɛid. Sebɛa n wussan ad ccen aɣrum břa antun.
\v 18 Deg wass amezwaru \add n Řɛid\add* ad yiři yijj n umuni iqeddsen. War tteggem uřa d ict řxedmet i ittxeṣṣan ad tᵉttwagg. \x ◘ \xo 28:18 \xt Lawi 23:7\x*
\m 
\v 19 Ad tqeddmem ict n tewhibt n tmessi \add am\add* tɣarṣt n wecmaḍ i SIDI: tnayen n ifunasen imeẓyanen d ijj n icarri d sebɛa n izmaren n ijj n useggʷas. Ittxeṣṣa ad iřin cnan qaɛ.
\v 20 \add Ad tiři\add* tewhibt \add n řɣiǧet\add* n waren azdad ixeǧḍen s zzect. Ad \add zzayes\add* tesswejdem třata n teɛcurin \add n yijj n ifa\add* i yijj n ufunas ameẓyan d tnayen n teɛcurin \add n yijj n ifa\add* i yijj n icarri.
\v 21 Ad tesswejded ict n teɛcart \add n yijj n ifa\add* i yijj n izmar, \add uca ammu\add* i \add marra\add* sebɛa n izmaren \add nni\add*.
\v 22 \add Sewjed ɛawed\add* ijj n umyan zeg iɣayḍen d taɣarṣt n ddenb maḥend ad ittwagg weṣřaḥ i kenniw.
\v 23 Ad tesswejdem man aya sennej i \add usewjed n\add* tɣarṣt wecmaḍ di ṣṣbeḥ nni \add iǧan\add* d ict n tɣarṣt n wecmaḍ i řebda.
\v 24 Am mammec uya ad tesswejdem macca n tewhibin n tmessi sebɛa n wussan, di kuř ass \add zzaysen\add*, \add am\add* ict n řefwaḥet ittfuḥen i SIDI. Ad ittwassewjed sennej i \add usewjed n\add* tɣarṣt n wecmaḍ n řebda ak-d tewhibt nnes n useyyeb.
\v 25 Deg wass wiss sebɛa ad teggem ijj n umuni iqeddsen. War tteggem uřa d ict řxedmet i ittxeṣṣan ad tᵉttwagg.”
\b
\s1 Imezwura n řɣiǧet
\m 
\v 26 “Deg wass n tmenzut \add n ṣṣabet\add* di Řɛid n Ssimanat, xmi dd ɣa tqeddmem ict n tewhibt \add n řɣiǧet\add* n jdid ɣar SIDI, ad teggem ijj n umuni iqeddsen. War tteggem uřa d ict n řxedmet i ittxeṣṣan ad tᵉttwagg.
\v 27 Ad tqeddmem ict n tɣarṣt n wecmaḍ am yict n řefwaḥet ittfuḥen i SIDI: tnayen n ifunasen imeẓyanen i yijj n icarri d sebɛa n izmaren n ijj n useggʷas
\v 28 ak-d tewhibt nnes \add n řɣiǧet\add* n waren azdad ixeǧḍen s zzect: třata n teɛcurin \add n yijj n ifa\add* i yijj n ufunas ameẓyan d tnayen n teɛcurin \add n yijj n ifa\add* i yijj n icarri
\v 29 uřa d ict n teɛcart \add n yijj n ifa\add* i kuř izmar, \add uca ammu\add* i \add marra\add* sebɛa n izmaren \add nni\add*.
\v 30 \add Swejdem ɛawed\add* ijj n umyan zeg iɣayḍen am tɣarṣt n ddenb maḥend ad ittwagg weṣřaḥ i kenniw.
\v 31 Ad ten tesswejdem sennej i \add usewjed n\add* tɣarṣt n wecmaḍ n řebda d tewhibt nnes \add n řɣiǧet\add*. Ad iřin cnan qaɛ i kenniw ak-d tewhibin nsen n useyyeb.”
\b
\b
\c 29
\s1 Taɣarṣt n wass umezwaru n uyur wiss sebɛa
\m 
\v 1 “Deg uyur wiss sebɛa, deg \add wass\add* amezwaru n uyur, ad teggem ijj n umuni iqeddsen. War tteggem uřa d ict n řxedmet i ittxeṣṣan ad tᵉttwagg. Ad awem yiři d ijj n wass n usuḍi s wesruddeḥ \add deg uyicc n icarri\add*. \x ◘ \xo 29:1 \xt Lawi 23:24\x*
\v 2 Ad tesswejdem ict n tɣarṣt n wecmaḍ am yict n řefwaḥet ittfuḥen i SIDI: ijj n ufunas - ameẓyan n ict n tfunast - d yijj n icarri d sebɛa n izmaren icnan qaɛ n ijj n useggʷas
\v 3 ak-d tewhibt nsen \add n řɣiǧet\add* zeg waren azdad ixeǧḍen s zzect: třata n teɛcurin \add n yijj n ifa\add* i ufunas ameẓyan d tnayen n teɛcurin \add n yijj n ifa\add* i icarri
\v 4 ak-d ict n teɛcart \add n yijj n ifa\add* i kuř izmar, \add uca ammu\add* i sebɛa n izmaren \add marra\add*.
\v 5 \add Swejdem ɛawed\add* ijj n umyan zeg iɣayḍen am tɣarṣt n ddenb maḥend ad ittwagg weṣřaḥ i kenniw.
\v 6 sennej i \add usewjed n\add* tɣarṣt n wecmaḍ ak-d tewhibt nnes \add n řɣiǧet\add* d \add sennej i usewjed n\add* tɣarṣt n wecmaḍ n řebda ak-d tewhibt nnes \add n řɣiǧet\add* d tewhibin nsen n useyyeb, ɛlaḥsab lfariḍa nsent, am yict n řefwaḥet ittfuḥen, ict n tɣarṣt n tmessi i SIDI.
\b
\s1 Tiɣarṣa deg Wass n Weṣřaḥ
\m 
\v 7 Deg \add wass\add* wiss ɛecra ad teggem ijj n umuni iqeddsen uca ad tesswaḍɛem ixef nwem. War tteggem uřa d ict n řxedmet i ittxeṣṣan ad tᵉttwagg. \x ◘ \xo 29:7 \xt Lawi 16:29, 31; 23:27\x*
\v 8 Ad tqeddmem ict n tɣarṣt n wecmaḍ am yict n řefwaḥet ittfuḥen i SIDI: ijj n ufunas ameẓyan d yijj n icarri d sebɛa n izmaren icnan qaɛ n ijj n useggʷas. Ittxeṣṣa ad awem iřin cnan \add aṭṭas\add*. \x ◘ \xo 29:8 \xt Řxř. 28:19\x*
\v 9 \add Ɛawed\add* tawhibt nsen \add n řɣiǧet\add* n waren azdad ixeǧḍen s zzect: třata n teɛcurin \add n yijj n ifa\add* i yijj n ufunas ameẓyan, tnayen n teɛcurin \add n yijj n ifa\add* i yijj n icarri
\v 10 u ict n teɛcart \add n yijj n ifa\add* i kuř izmar, \add uca ammu\add* i sebɛa n izmaren \add marra\add*.
\v 11 \add Swejdem ɛawed\add* ijj n umyan zeg iɣayḍen am tɣarṣt n ddenb, sennej i \add usewjed n\add* tɣarṣt n ddenb i zi tᵉttwagg weṣřaḥ uca uřa d taɣarṣt n wecmaḍ n řebda ak-d tewhibt nnes \add n řɣiǧet\add* d tewhibin nsen n useyyeb.
\b
\s1 Tiɣarṣa n Řɛid n Iɛuccuten
\m 
\v 12 Deg wass wiss xemmesṭac n uyur wiss sebɛa ad teggem ijj n umuni iqeddsen. War tteggem uřa d ict n řxedmet i ittxeṣṣan ad tᵉttwagg. Sebɛa n wussan ad tɛeyydem řɛid i SIDI.
\v 13 Ad tqeddmem ict n tɣarṣt n wecmaḍ \add am\add* tewhibt n tmessi, \add am\add* ict n řefwaḥet ittfuḥen i SIDI: třeṭṭac n ifunasen - imeẓyanen n ict n tfunast - tnayen n icarriyyen \add u\add* arbeɛṭac n izmaren n ijj n useggʷas. Ittxeṣṣa ad iřin cnan \add qaɛ\add*.
\v 14 \add Ɛawed\add* tawhibt nsen \add n řɣiǧet\add* n waren azdad ixeǧḍen s zzect: třata n teɛcurin \add n yijj n ifa\add* i yijj n ufunas ameẓyan, i \add marra\add* třeṭṭac n ifunasen imeẓyanen, u tnayen n teɛcurin \add n yijj n ifa\add* i yijj n ucarri, i tnayen n icarriyyen \add nni\add*
\v 15 uřa d ict n teɛcart \add n yijj n ifa\add* i kuř izmar, \add uca ammu\add* i \add marra\add* arbeɛṭac n izmaren \add nni\add*.
\v 16 \add Swejdem ɛawed\add* ijj n ijj n umyan zeg iɣayḍen am tɣarṣt n ddenb, sennej i \add usewjed n\add* tɣarṣt n wecmaḍ n řebda \add ak-d\add* tewhibt nnes \add n řɣiǧet\add* d tewhibt nnes n useyyeb.
\m 
\v 17 Deg wass wiss tnayen: tenɛac n ifunasen imeẓyanen d tnayen n icarriyyen d arbeɛṭac n izmaren icnan n ijj n useggʷas,
\v 18 ak-d tewhibt nsen \add n řɣiǧet\add* d tewhibin nsen n useyyeb i ifunasen imeẓyanen, i icarriyyen u i izmaren, ɛlaḥsab řqedd nsen, ɛlaḥsab lfariḍa.
\v 19 \add Swejdem ɛawed\add* ijj n umyan zeg iɣayḍen am tɣarṣt n ddenb, sennej i \add usewjed n\add* tɣarṣt n wecmaḍ n řebda ak-d tewhibt nnes \add n řɣiǧet\add* d tewhibin nsen n useyyeb.
\m 
\v 20 Deg wass wiss třata: ḥiṭac n ifunasen imeẓyanen d tnayen n icarriyyen d arbeɛṭac n izmaren n ijj n useggʷas, ican \add qaɛ\add*,
\v 21 ak-d tewhibt nsen \add n řɣiǧet\add* d tewhibin nsen n useyyeb i ifunasen imeẓyanen, i icarriyyen u i izmaren, ɛlaḥsab řqedd nsen, ɛlaḥsab lfariḍa.
\v 22 \add Swejdem ɛawed\add* ijj n umyan zeg iɣayḍen am tɣarṣt n ddenb, sennej i \add usewjed n\add* tɣarṣt n wecmaḍ n řebda ak-d tewhibt nnes \add n řɣiǧet\add* d tewhibt nnes n useyyeb.
\m 
\v 23 Deg wass wiss arebɛa: ɛecra n ifunasen imeẓyanen d tnayen n icarriyyen d arbeɛṭac n izmaren icnan n ijj n useggʷas,
\v 24 ak-d tewhibt nsen \add n řɣiǧet\add* d tewhibin nsen n useyyeb i ifunasen imeẓyanen, i icarriyyen u i izmaren, ɛlaḥsab řqedd nsen, ɛlaḥsab lfariḍa.
\v 25 \add Swejdem ɛawed\add* ijj n umyan zeg iɣayḍen am tɣarṣt n ddenb, sennej i \add usewjed n\add* tɣarṣt n wecmaḍ n řebda ak-d tewhibt nnes \add n řɣiǧet\add* d tewhibt nnes n useyyeb.
\m 
\v 26 Deg wass wiss xemsa: tesɛa n ifunasen imeẓyanen d tnayen n icarriyyen d arbeɛṭac n izmaren icnan n ijj n useggʷas,
\v 27 ak-d tewhibt nsen \add n řɣiǧet\add* d tewhibin nsen n useyyeb i ifunasen imeẓyanen, i icarriyyen u i izmaren, ɛlaḥsab řqedd nsen, ɛlaḥsab lfariḍa.
\v 28 \add Swejdem ɛawed\add* ijj n umyan \add zeg iɣayḍen\add* am tɣarṣt n ddenb, sennej i \add usewjed n\add* tɣarṣt n wecmaḍ n řebda ak-d tewhibt nnes \add n řɣiǧet\add* d tewhibt nnes n useyyeb.
\m 
\v 29 Deg wass wiss setta: tmenya n ifunasen imeẓyanen d tnayen n icarriyyen d arbeɛṭac n izmaren icnan n ijj n useggʷas,
\v 30 ak-d tewhibt nsen \add n řɣiǧet\add* d tewhibin nsen n useyyeb i ifunasen imeẓyanen, i icarriyyen u i izmaren, ɛlaḥsab řqedd nsen, ɛlaḥsab lfariḍa.
\v 31 \add Swejdem ɛawed\add* ijj n umyan \add zeg iɣayḍen\add* am tɣarṣt n ddenb, sennej i \add usewjed n\add* tɣarṣt n wecmaḍ n řebda ak-d tewhibt nnes \add n řɣiǧet\add* d tewhibin nnes n useyyeb.
\m 
\v 32 Deg wass wiss sebɛa: sebɛa n ifunasen imeẓyanen d tnayen n icarriyyen d arbeɛṭac n izmaren icnan n ijj n useggʷas,
\v 33 ak-d tewhibt nsen \add n řɣiǧet\add* d tewhibin nsen n useyyeb i ifunasen imeẓyanen, i icarriyyen u i izmaren, ɛlaḥsab řqedd nsen, ɛlaḥsab lfariḍa.
\v 34 \add Swejdem ɛawed\add* ijj n umyan \add zeg iɣayḍen\add* am tɣarṣt n ddenb, sennej i \add usewjed n\add* tɣarṣt n wecmaḍ n řebda ak-d tewhibt nnes \add n řɣiǧet\add* d tewhibt nnes n useyyeb.
\m 
\v 35 Deg wass wiss tmenya ad teggem ijj n umuni ifarzen. War tteggem uřa d ict řxedmet i ittxeṣṣan ad tᵉttwagg. \x ◘ \xo 29:35 \xt Lawi 23:36\x*
\v 36 Ad tqeddmem ict n tɣarṣt n wecmaḍ \add am\add* tewhibt n tmessi, \add am\add* ict n řefwaḥet ittfuḥen i SIDI: ijj n ufunas ameẓyan d yijj n icarri d sebɛa n izmaren icnan n ijj n useggʷas
\v 37 ak-d tewhibt nsen \add n řɣiǧet\add* d tewhibin nsen n useyyeb i ufunas ameẓyan, i icarri u i izmaren, ɛlaḥsab řqedd nsen, ɛlaḥsab lfariḍa.
\v 38 \add Swejdem ɛawed\add* ijj n umyan \add zeg iɣayḍen\add* am tɣarṣt n ddenb, sennej i \add usewjed n\add* tɣarṣt n wecmaḍ n řebda ak-d tewhibt nnes \add n řɣiǧet\add* d tewhibt nnes n useyyeb.
\m 
\v 39 Ad teggem timesřayin-a i SIDI di řeɛyudat nwem ittwaggen sennej i tewhibin n řewɛud nwem d tewhibin nwem s řxaḍar i ittraḥen ak-d tɣarṣa n wecmaḍ nwem d tewhibin nwem \add n řɣiǧet\add* d tewhibin nwem n useyyeb d tewhibin nwem n řehna.”
\b
\b
\c 30
\s1 Tijuǧa
\m 
\v 1 Uca issiweř Musa ak-d ayt n Israil ɛlaḥsab marra min yumur SIDI i Musa.
\v 2 Issiweř Musa ak-d izeǧifen n tqebbař n ayt n Israil, inna: “Aqa d ta min xef yumur SIDI:
\m 
\v 3 ‘Xmi ɣa tafed \bd ijj n weryaz\bd* iwca awař niɣ ijjuǧ ict n tjaǧit ḥima ad iqqen ixef nnes s yijj n řɛahd, \add xenni\add* war ittareẓẓi awař nnes. Ittxeṣṣa as ad igg ɛlaḥsab min dd-iffɣen zeg uqemmum nnes. \x ◘ \xo 30:3 \xt Aɛwd. 23:20\x*
\m 
\v 4 Xmi ɣa tafed \bd ict n temɣart\bd* tewca awař nnes i SIDI uca ad teqqen ixef nnes s yijj n řɛahd di temẓi nnes di taddart n babas,
\v 5 uca babas isřa i wawař n lwaɛd nnes d řɛahd nnes i zi teqqen ixef nnes, uca babas isqar zzates, \add xenni\add* marra lwuɛud nnes ad iřin ṣeřḥen d kuř aqqan nnes ad yiři iṣřeḥ.
\v 6 \add Maca\add* mařa babas issbedd i-tt \add zi man aya\add* deg wass nni di isřa aya, \add xenni\add* uřa d ijj zi lwuɛud nnes u uřa d ijj zeg waqqan nnes i zi teqqen ixef nnes, war iṣeǧeḥ ca. SIDI ad as iɣfar, minzi babas issbedd i-tt \add x man aya\add*.
\m 
\v 7 Mařa tuɣa-tt temřec ak-d yijj n weryaz uca xas lwuɛud niɣ nettat tuɣa teqqen ixef nnes s yijj n wawař iffeɣ-dd s tcarfayeḥ zeg iyencicen nnes,
\v 8 uca aryaz nnes isřa as uca isqar zzates deg wass i di isřa \add aya\add*, \add xenni\add* ad seřḥen lwuɛud nnes d kuř aqqan nnes ad yiři iṣřeḥ.
\v 9 \add Maca\add* mařa aryaz nnes deg wass nni di isřa \add aya\add*, inhar i-tt, \add xenni\add* netta issebḍeř lwaɛd nni xas uřa d awař s tcarfayeḥ zeg iyencicen nnes i zi tuɣa teqqen ixef nnes uca AREBBI ad as iɣfar \add aya\add*.’”
\b
\m 
\v 10 “\bd X lwaɛd n tajjač niɣ n tenni ittwaǧfen\bd*: marra min zi tuɣa teqqen ixef nnes, ad yiři iṣeǧeḥ.
\v 11 Mařa tuɣa tewca awař niɣ teqqen ixef nnes s ict n tjaǧit i yijj n řɛahd di taddart n weryaz nnes,
\v 12 uca aryaz nnes isřa \add i uya\add* uca isqar zzates uca war tt issbedd x man aya, \add xenni\add* ad ṣeřḥen marra lwuɛud nnes u kuř aqqan nnes i zi tuɣa teqqen ixef nnes ad yiři iṣřeḥ.
\v 13 \add Maca\add* mařa aryaz nnes issebḍeř aya qaɛ deg wass i di isřa, \add xenni\add* war ittiři iṣeǧeḥ ca qaɛ zi min dd-iffɣen zeg iyencicen nnes n lwuɛud niɣ n waqqan. Aryaz nnes issebḍeř aya uca AREBBI ad as iɣfar.
\m 
\v 14 Kuř lwaɛd d kuř aqqan s ict n tjaǧit i umi ɣa tesswaḍeɛ ixef nnes, aryaz nnes izemmar ad t issemten niɣ aryaz nnes izemmar ad t issebḍeř.
\v 15 Mařa aryaz nnes isqar qaɛ zeg wass x wass, \add xenni\add* issemten marra lwuɛud nnes niɣ kuř aqqan nnes i xas iǧan. Aqa issemten i-ten minzi isqar zzates deg wass i di \add ten\add* isřa.
\v 16 Mařa netta, awarni řami \add d asen\add* isřa, ad ten issebḍeř, \add xenni\add* ad yarbu netta řmuɛṣiyyet n \add temɣart\add* nnes.”
\m 
\v 17 Aqa d tina d tiweṣṣa i zi yumur SIDI i Musa, \add i iǧan\add* jar weryaz d temɣart, jar babas d yessis, \add tenni iqqimen\add* di taddart n babas di temẓi nnes.
\b
\b
\c 31
\s1 Garra ak-d Midyan
\m 
\v 1 Issiweř SIDI ak-d Musa, inna:
\m 
\v 2 “Ntaqem di ṭṭweɛ n ayt n Israil x Imidyaniyyen. Awarni as ad tᵉmmarnid ɣar řgens nnec.” \x ◘ \xo 31:2 \xt Řxř. 25:17; 27:13 \x*
\m 
\v 3 Issiweř Musa ak-d řgens, inna: “Swejdem zi ɣarwem iryazen i umenɣi ḍidd i Midyan u nitni ad iřin ḍidd i Midyan maḥend ad ssiwḍen nneqmet n SIDI x Midyan.
\v 4 Ittxeṣṣa awem ad tessekkem ařef \add n yeryazen\add* zi kuř taqbič ɣar umenɣi, \add zi kuř ict zi\add* marra tiqebbař n Israil.”
\v 5 \add Ammu\add* i ttwafarzen zi řuřuf n Israil ařef \add n yeryazen\add* zi kuř taqbič, aqa aten \add jmiɛ\add* tenɛac-n-řuřuf \add n yerazen\add* iwejden i umenɣi.
\m 
\v 6 Musa issekk i-ten ɣar umenɣi, ařef \add n yeryazen\add* zi kuř taqbič. \add Netta issekk\add* i-ten ɣar umenɣi ak-d Finaḥas, mmis n ukehhan Aliɛazar, u \add netta ɣares\add* řeqcuɛ iqeddsen d řebwaq i usuḍi s wesruddeḥ \add i umenɣi\add* deg ufus nnes
\v 7 uca mmenɣen ḍidd i Imidyaniyyen, am mammec \add t\add* yumur SIDI i Musa uca nɣin marra min iǧan d awtem.
\v 8 Sennej i yinni \add zzaysen\add* ittwassnuqqben, nɣin ɛawed ijeǧiden n Midyan: Iwi, Raqim, Ṣur, Ḥur d Rabaɛ, xemsa n ijeǧiden n Midyan, \add uřa\add* Balɛam, mmis n Baɛur, nɣin t s ssif. \x ◘ \xo 31:8 \xt Yac. 13:21, 22\x*
\m 
\v 9 Ayt n Israil ḥebbsen timɣarin n Midyan d tarwa nsen, u keccḍen řebhayem nsen d tḥimriwin nsen d marra min ɣarsen.
\v 10 Sscemḍen s tmessi marra tineddam nsen mani tuɣa zeddɣen d marra lqelɛat nsen.
\v 11 Ksin marra min keccḍen, marra takeccaḍt n iwdan d řebhayem \x ◘ \xo 31:11 \xt Aɛwd. 20:14\x*
\v 12 uca iwyen-dd imeḥbas d marra takeccaḍt ɣar Musa u ɣar ukehhan Aliɛazar u ɣar tmesmunt n ayt n Israil, di řmargeḥ n řɛeskar, di řewḍat n Mu’ab, ɣar L’Urdun, \add arendad n\add* Ariḥa.
\v 13 Uca iffeɣ-dd Musa ak-d ukehhan Aliɛazar d marra řḥukkam n tmesmunt barra i řmargeḥ n řɛeskar maḥend ad ten mmsagaren.
\m 
\v 14 Iffugem Musa aṭṭas x imgewwaden n řɛeskar, x imeqqranen x wařef u x imeqqranen x mya, inni dd-iɛeqben zeg umenɣi.
\v 15 Inna asen Musa: “Ma tejjim marra min iǧan d tawtent iddar?
\v 16 Xzar, s wescan n Balɛam, \add timɣarin-a\add* tuɣa atent d řesbab aqa ayt n Israil ɣdaren SIDI di tmesřact n Faɣur uca tewḍa-dd jjriḥect x tmesmunt n SIDI. \x ◘ \xo 31:16 \xt Řxř. 25:1, 2, 18; 2 Bṭ. 2:15; Asa. 2:14 \x*
\v 17 Řexxu \add xenni\add*, nɣem marra iwetman nni jar iḥenjiren imeẓyanen uca nɣem marra tamɣart nni imunen ak-d ijj n weryaz am tᵉṭṭeṣ nettat ak-d ijj n weryaz. \x ◘ \xo 31:17 \xt Řqḍ. 21:11\x*
\v 18 Maca marra tiḥenjirin jar temɣarin nni war imunen ak-d ijj n weryaz am \add akides\add* ṭṭṣent, jjem tent i yixef nwem ad ddarent.
\m 
\v 19 Ittxeṣṣa awem ad tewtem iqiḍan nwem barra i řmargeḥ n řɛeskar řmijař n sebɛa n wussan. Kuř ijjen, wenni inɣin ijj n řeɛmar \add n bnadem\add*, u kuř ijjen, wenni iḥadan ijjen i ittwassnuqqben, ad yejj ad kksen ddenb x yixef nnes deg wass wiss třata u deg wass wis sebɛa, \add ammu\add* i ɣa teggem kenniw uřa d imeḥbas nwem.
\m 
\v 20 Ittxeṣṣa ad tekksem ddenb ɛawed x marra arruḍ d marra řeqcuɛ n iřmawen d marra min ittwaggen s thiḍurt n iɣayḍ d marra řeqcuɛ n ukeccuḍ.”
\m 
\v 21 Aliɛazar, akehhan, inna i iɛeskariyyen nni dd-iffɣen ɣar umenɣi: “Ta d tawṣeyyet zi Ccariɛa nni yumur SIDI i Musa:
\v 22 Mɣir ureɣ d nnuqart d nnḥas d uzzař d istanyu d řexfif,
\v 23 marra min izemmaren i tmessi, x tmessi ad t tessekkem, \add xenni\add* ad yiři izdig, \add maca\add* ittxeṣṣa ad zzayes tekksem ddenb s waman n weɛzař. Marra min war izemmaren i tmessi, ad t tessekkem x waman. \x ◘ \xo 31:23 \xt Řxř. 19:9\x*
\v 24 Deg wass wiss sebɛa ad tṣebbnem arruḍ nwem, \add xenni\add* ad tiřim d imezdagen. Awarni uya tzemmarem ad tadfem ɣar řmargeḥ n řɛeskar.”
\b
\m 
\v 25 Issiweř SIDI ak-d Musa, inna:
\m 
\v 26 “Ṭṭef řeɛbar n tkeccaḍt n iwdan d řebhayem nni tᵉttwaḥebbes, cek \add jmiɛ\add* ak-d ukehhan Aliɛazar u ak-d izeǧifen n \add tudrin n\add* ibabaten n tmesmunt.
\v 27 Bḍa takeccaḍt x tnayen jar inni icarcen deg umenɣi d yinni iffɣen ak-d řɛeskar \add zeg ict n jjihet\add* d marra tamesmunt \add zi jjihet nneɣnit\add*. \x ◘ \xo 31:27 \xt 1 Ṣm. 30:24\x*
\v 28 Sgeɛɛdet ict n ṣṣedqet i SIDI zeg iɛeskariyyen nni dd-iffɣen ɣar umenɣi ak-d řɛeskar: ijj n řeɛmar zi xemsa mya n iwdan uca \add amenni\add* zeg ifunasen d tfunasin u zeg iɣyař u zeg wuǧi.
\v 29 Zeg wezyen nsen n \add tkeccaḍt\add* ad teksid \add ṣṣedqet-a\add* uca ad tt tewced i ukehhan Aliɛazar \add am\add* ict n tewhibt n usgeɛɛed i SIDI.
\v 30 Zeg wezyen \add n tkeccaḍt\add* n ayt n Israil ad teksid ijj zi kuř xemsin: zeg iwdan, zeg ifunasen d tfunasin, zeg iɣyař u zeg wuǧi, \add wah,\add* zi marra řebhayem. Ad tewced aya i Ilawiyyen nni iṭṭfen acbar x Tzeddiɣt n SIDI.” \f ◼ \fr 31:30 \fk ifunasen d tfunasin\ft - s Tɛibranit aqa din ijj n wawař waha, war iǧi tnayen.\f*
\m 
\v 31 Uca igga Musa d ukehhan Aliɛazar am mammec \add t\add* yumur SIDI i Musa.
\v 32 \add Awarni as\add* tuɣa řeksibet nni iqqimen n tkeccaḍt nni ikecceḍ řgens n řɛeskar setta-mya u-xemsa u-sebɛin-ařef n wuǧi. \f ◼ \fr 31:32 \fk iɛeskariyyen\ft - s Tɛibranit ‘řgens n řɛeskar’.\f*
\v 33 tnayen u-sebɛin-ařef n ifunasen d tfunasin,
\v 34 waḥit u-settin-ařef n iɣyař
\v 35 uca \add zi jjihet n\add* řeɛmar n bnadem, zi temɣarin nni war iṭṭiṣen di qama ak-d ijj n weryaz, aqa atent marra tnayen u-třatin-ařef.
\m 
\v 36 Ijj n wezyen, \bd tasɣart n yinni dd-iffɣen ak-d řɛeskar\bd*, aqa-t di teřt-mya u-sebɛa u-třatin-ařef n wuǧi.
\v 37 Ṣṣedqet i SIDI n wuǧi \add tuɣa-tt di\add* setta-mya u-xemsa u-sebɛin.
\v 38 Uca \add tuɣa din\add* setta u-třatin-ařef n ifunasen d tfunasin uca ṣṣedqet \add zzaysen\add* i SIDI \add tuɣa-tt\add* di tnayen u-sebɛin.
\v 39 Uca \add tuɣa din\add* třatin-ařef u-xemsa-mya n iɣyař uca ṣṣedqen zzaysen i SIDI, waḥit u-settin.
\v 40 Uca \add zi jjihet n\add* řeɛmur n bnadem \add tuɣa din\add* seṭṭac-ařef \add n temɣarin\add* u aṣeddeq zzaysent i SIDI aqa tnayen u-třatin \add n temɣarin\add*.
\m 
\v 41 Iwca Musa ṣṣedqet, tenni d tawhibt n usgeɛɛed i SIDI, i ukehhan Aliɛazar, am mammec \add t\add* yumur SIDI i Musa. \x ◘ \xo 31:41 \xt Řxř. 18:8, 19\x*
\b
\m 
\v 42 Zeg wezyen \add nneɣni\add* i ayt n Israil, wenni ifarz Musa \add di ṭṭweɛ nsen\add* zeg yeryazen nni tuɣa immenɣen,
\v 43 \bd - azyen \bdit nni n tesɣart\bdit* i tmesmunt\bd* tuɣa-t di teřt-mya u-sebɛa u-třatin-ařef u-xemsa mya n wuǧi,
\v 44 setta u-třatin-ařef n ifunasen d tfunasin,
\v 45 třatin-ařef u-xemsa-mya n yeɣyař
\v 46 uca seṭṭac-ařef n řeɛmur n iwdan -
\v 47 zeg wezyen nni i ayt n Israil iksi Musa ijj zi kuř xemsin, \add ammu\add* zeg iwdan \add am\add* zi řebhayem, uca iwca aya i Ilawiyyen, inni iṭṭfen acbar x Tzeddiɣt n SIDI, am mammec \add t\add* yumur SIDI i Musa.
\b
\m 
\v 48 \add Xenni\add* usin-dd ikumandaren x řuřuf n řɛeskar, imeqqranen x wařef d imeqqranen x mya, ɣar Musa,
\v 49 nnan i Musa: “Imsexxaren nnec aqa ḥesben marra iɛeskariyyen nni sadu ufus nneɣ u war d aneɣ iruḥ uřa d \add ijj n\add* weryaz.
\v 50 S uya niwi tawhibt n SIDI, kuř ijj min yufa: ict n řqecɛet n wureɣ, ict n txeřxařt, ict n tmeqyast, ict n txatent \add n ucemmiɛ\add*, ict n texrazt niɣ ict n tseddect s wedmam n wureɣ, ḥima ad zzaysent ittwagg weṣřaḥ x řeɛmur nneɣ zzat i wudem n SIDI.”
\v 51 Musa d ukehhan Aliɛazar ksin zzaysen ureɣ nsen, marra řeqcuɛ i ggin \add s lfenn\add*.
\v 52 Marra ureɣ n tewhibt nni ssgeɛɛden i SIDI zeg imeqqranen x wařef u zeg imeqqranen x mya tuɣa di seṭṭac-ařef u-sebɛa-mya u-xemsin ciqlu.
\v 53 Iɛeskariyyen aqa keccḍen kuř ijj i yixef nnes \add min xsen\add*. \x ◘ \xo 31:53 \xt Aɛwd. 20:14\x*
\v 54 Musa d ukehhan Aliɛazar ṭṭfen ureɣ \add nni\add* n imeqqranen x wařef u x mya uca iwyen t ɣar Uqiḍun n Umsagar, am yict n řidaret i ayt n Israil zzat i wuden n SIDI.
\b
\b
\c 32
\s1 Tutra n teqbič n Rubin d teqbič n Jad
\m 
\v 1 Ayt n Rubin ɣarsen aṭṭas n řebhayem u ayt n Jad ɣarsen aṭṭas s waṭṭas \add n řebhayem\add* uca nitni ẓrin tammurt n Yaɛzir d temmurt n Jilɛad, uca xzar, jjihet \add nni\add* \add tecna\add* i řebhayem.
\v 2 Usin-dd ayt n Jad u ayt n Rubin, ssiwřen ak-d Musa d ukehhan Aliɛazar u ak-d řḥukkam n tmesmunt, nnan:
\v 3 “Ɛaṭarut, Dibun, Yaɛzir, Nimra, Ḥacbun, Aliɛala, Cabam, Nabu d Baɛun,
\v 4 tammurt nni x iɣřeb SIDI zzat i wudem n tmesmunt n Israil, aqa-tt d ict n temmurt \add tecna\add* i řebhayem u \add neccin\add*, imsexxaren nnec ɣarsen řebhayem.”
\v 5 Nnan: “Mařa nufa arḍa di tiṭṭawin nnec, ma zeɛma ad temmewc temmurt-a d agřa i imsexxaren nnec u war d aneɣ ttejji ad neẓwa L’Urdun.”
\m 
\v 6 Yarra-dd Musa x ayt n Jad u x ayt n Rubin: “Mařa aytmatwem ad dd-ffɣen ɣar garra, ma xenni kenniw ad teqqimem da?
\v 7 Mayemmi ɣa tessɛegzem uř n ayt n Israil maḥend war ẓekkʷin ɣar temmurt i d asen iwca SIDI?
\v 8 Ammu i ggin řejdud nwem umi ten ssekkeɣ zi Qadac-Barniɛ ḥima xenni ad ẓaren tammurt. \x ◘ \xo 32:8 \xt Řxř. 13:3; Aɛwd. 1:22 \x*
\v 9 Iwḍen nitni ɣar teɣzurt \add n teɣzart\add* n Ickul uca ẓrin tammurt uca qeřben uřawen n ayt n Israil, maḥend war ttidfen ca di temmurt i d asen iwca SIDI.
\v 10 Deg wass nni yarɣa weɣḍab n SIDI uca ijjuǧ, inna:
\v 11 ‘Iryazen nni dd-iffɣen zi Miṣra, zi ɛicrin iseggʷusa sennej, war ẓarren tammurt nni x jjuǧeɣ ad tt wceɣ i Ibrahim d Isḥaq d Yaɛqub, minzi nitni war d ayi ḍfaren nican, \x ◘ \xo 32:11 \xt Řxř. 14:28; Aɛwd. 1:35\x*
\v 12 mɣir Kalib, mmis n Yafunni, Aqinizi, d Yacuwa, mmis n Nun, minzi nitni ḍfaren nican i SIDI.’
\v 13 Uca \add ammu\add* yarɣa weɣdab n SIDI x Israil uca igga i-ten ad tellɛen di řexřa arebɛin n iseggʷusa, ařami ifna marra jjiř nni iggin řɣar di tiṭṭawin n SIDI,
\v 14 Uca xzar, kenniw tɣewwɣem am řejdud nwem, \add kenniw\add* d ijj n ubarru n yeryazen d imednab, \add uca ammu\add* i ɣa tarnim ɛad řḥaduq n weɣḍab n SIDI x Israil.
\v 15 Mařa tdewřem-dd kenniw zi ḍeffar nnes, Netta ad yejj \add řgens\add* di řexřa ɛawed uca \add ammu i ɣa\add* tejjem marra řgens aya ad ihellek.”
\m 
\v 16 Xenni qarrben-dd ɣares, nnan: “Ad nebna da řkuriyyat i wuǧi nneɣ u tineddam i iḥenjiren nneɣ,
\v 17 maca neccin ad dd-neffeɣ newjed i umenɣi zzat i wudem n ayt n Israil s řesnaḥ \add nneɣ\add*, ařami ten nessiweḍ ɣar wemcan nsen. Iḥenjiren nneɣ ad qqimen di tneddam ifaryen zi ssibbet n imezdaɣ n temmurt.
\v 18 War nᵉddekkwiř ɣar tudrin nneɣ ař i ɣa temmewc tesɣart n řwart i kuř ijj zeg ayt n Israil.
\v 19 Minzi war nteṭṭef di řwart akidsen ɣar tma nneɣni n L’Urdun uřa ɣar zzat, minzi tasɣart i d aneɣ dd-ittasen aqa-tt ɣar tma-ya tanita n L’Urdun, ɣar ccarq.”
\m 
\v 20 \add Xenni\add* inna asen Musa: “Mařa teggim ammu, mařa tesswejdem ixef nwem i umenɣi zzat i wudem n SIDI,
\v 21 u kuř ijj, wenni isswejden ixef nnes i umenɣi, ad iẓwa L’Urdun zzat i wudem n SIDI, ař Netta ad yaẓẓeř x řɛedyan nnes zzat i wudem nnes zi tesɣart nsen n řwart,
\v 22 u ad tiři temmurt tᵉttwaxḍeɛ zzat i wudem n SIDI, \add xenni\add* iɛeddeř ad dd-tdewřem u ad tiřim tbeddem zzat i SIDI u zzat i Israil břa amarwas u ad tiři temmurt-a d agřa nwem zzat i wudem n SIDI.
\m 
\v 23 \add Maca\add* mařa war teggim ammu, \add xenni\add* aqa texḍam ḍidd i SIDI uca ad tessnem aqa ddenb nwem ad kenniw yaf.
\v 24 Bnam tineddam i iḥenjiren nwem d řkuriyyat i wuǧi nwem uca ggem min dd-iffɣen zeg uqemmum nwem.”
\m 
\v 25 \add Xenni\add* ssiwřen ayt n Jad d ayt n Rubin ak-d Musa, nnan: “Imsexxaren nnec ad ggen am mammec ten yumur sidi inu.
\v 26 Tarwa nneɣ, timɣarin nneɣ, řeksibet nneɣ d marra řebhayem nneɣ ad qqimen di tneddam n Jilɛad,
\v 27 \add maca\add* imsexxaren nnec ad ẓwan i umenɣi zzat i wudem n SIDI, marra inni isswejden \add ixef nsen\add* i umenɣi, am mammec issiweř sidi inu.”
\m 
\v 28 Uca yumur xasen Musa i ukehhan Aliɛazar u i Yacuwa, mmis n Nun, u i izeǧifen n \add tudrin n\add* ibabaten n tqebbař n ayt n Israil, \x ◘ \xo 32:28 \xt Yac. 1:13; 4:12\x*
\v 29 inna asen Musa: “Mařa ayt n Jad d ayt n Rubin ad kiwem ẓwan L’Urdun, kuř ijj wenni isswejden ixef nnes i umenɣi zzat i wudem n SIDI, u mařa \add xenni\add* tammurt ad tiři tᵉttwaxḍeɛ zzat i wudem nwem, \add ad taf\add* ad asen tewcem tammurt n Jilɛad d agřa.
\v 30 Maca mařa war kiwem ẓekkʷim wejden i umenɣi, \add xenni\add* ad ṭṭfen agřa di řwesṭ nwem di temmurt n Kenɛan.”
\v 31 Ayt n Jad d ayt n Rubin arrin-dd, nnan: “Am mammec issiweř SIDI ak-d imsexxaren nnec, ammu i ɣa negg.
\v 32 Neccin ad neẓwa ɣar temmurt n Kenɛan ad niři newjed i umenɣi zzat i wudem n SIDI, \add maca\add* tasɣart nneɣ n řwart ad tiři ɣar tma-ya wanita n L’Urdun.”
\b
\m 
\v 33 U iwca asen Musa, i ayt n Jad u i ayt n Rubin u i wezyen n teqbič n Manassa, mmis n Yusuf, tageldit n Siḥun, ajeǧid n Imuriyyen, d tgeldit n Ɛuj, ajeǧid n Bacan, tammurt s tneddam nnes nni iǧan di jjwayeh nnes uřa d tineddam di temmurt i d as dd-innḍen. \x ◘ \xo 32:33 \xt Aɛwd. 3:12; Yac. 13:8; 22:4 \x*
\v 34 Ayt n Jad bnan Dibun, Ɛaṭarut, Ɛaruɛir,
\v 35 Ɛaṭrut-Cufan, Yaɛzir, Yujbaha,
\v 36 Bayt-Nimra d Bayt-Haran, tineddam ifaryen d řkuriyyat i wuǧi.
\v 37 Ayt n Rubin bnan Ḥacbun, Aliɛala, Qaryatayim, \f ◼ \fr 32:37 \fk Qaryatayim\ft - ixs ad yini ‘tnayen n tneddam’.\f*
\v 38 Nabu, Baɛl-Maɛun, tenni zi ittwabeddeř isem nsen, d Sibma, uca řaɣan ismawen n tneddam i bnan \add ɛawed\add* s yisem \add nneɣni\add*.
\m 
\v 39 Ayt n Makir, mmis n Manassa, ruḥen ɣar Jilɛad uca ṭṭfen tt uca uẓẓřen x Imuriyyen nni din iǧan zi řwart nsen. \x ◘ \xo 32:39 \xt Amz. 50:23\x*
\v 40 Uca Musa iwca Jilɛad i Makir, mmis n Manassa, uca iruḥ netta ad izdeɣ din.
\v 41 Uca Ya’ir, mmis n Manassa, iruḥ uca iṭṭef dcurat nnes uca iřaɣa asent dcurat n Ya’ir.
\v 42 Amenni iruḥ Nubaḥ uca iṭṭef Qinat d tneddam i ɣares dd-iqqnen uca isemma as Nubaḥ s yisem nnes.
\b
\b
\c 33
\s1 Isafaren zi Miṣra ař Kenɛan
\m 
\v 1 Ammu i ssmmuṭṭiyen ayt n Israil inni dd-iffɣen zi temmurt n Miṣra, zeg wemcan ɣar wemcan, \add am ttwasettfen nitni\add* ɛlaḥsab \add tirbiɛin n\add* řɛeskar nsen, s ufus n Musa d Harun.
\v 2 X řumur n SIDI yura Musa imucan manis dd-ffɣen ak-d ireḥḥalen nsen. Ina d ireḥḥalen nsen ak-d imucan manis dd-ffɣen.
\b
\m 
\v 3 Fesyen iqiḍan nsen, \add ffɣen\add* \bd zi Raɛamsis\bd* deg uyur amezwaru, deg wass wiss xemmesṭac n uyur amezwaru. Di ṣṣbeḥ, \add deɣya\add* awarni i \add Tɣarṣt n\add* Useɛdu ffɣen-dd ayt n Israil s yijj n ufus ittwassgeɛɛden zzat i tiṭṭawin n marra Imiṣriyyen, \x ◘ \xo 33:3 \xt Uf. 12:37 \x*
\v 4 \add umi\add* tuɣa ceɣřen Imiṣriyyen neṭṭřen marra imenza nsen, inni iwta SIDI \add s řmewt\add* jar asen. \add Ɛawed\add* issiweḍ SIDI řeḥkam \add nnes\add* x irebbiten nsen.
\m 
\v 5 Fesyen ayt n Israil iqiḍan nsen, \add ffɣen\add* zi Raɛamsis uca wtin iqiḍan nsen di Sukkut.
\m 
\v 6 Fesyen iqiḍan nsen, \add ffɣen\add* zi Sukkut uca wtin iqiḍan nsen di Itam ɣar tma n řexřa. \x ◘ \xo 33:6 \xt Uf. 13:20 \x*
\m 
\v 7 Fesyen iqiḍan nsen, \add ffɣen\add* zi Itam uca dewřen-dd ɣar Pi-Haḥirut nni iǧan arendad n Baɛl-Ṣafun uca wtin iqiḍan nsen zzat i wudem n Majdal. \x ◘ \xo 33:7 \xt Uf. 14:2 \x*
\m 
\v 8 Fesyen iqiḍan nsen, \add ffɣen\add* zi Pi-Haḥirut uca cukken di řwesṭ n řebḥar ɣar řexřa uca uyuren ticři n třata n wussan di řexřa n Itam, \add xenni\add* wtin iqiḍan nsen di Mara. \x ◘ \xo 33:8 \xt Uf. 15:22, 23\x*
\m 
\v 9 Fesyen iqiḍan nsen, \add ffɣen\add* zi Mara uca iwḍen ɣar Ilim, mani iǧa tenɛac n iɣbaluten n waman d sebɛin n tcejjura n tini uca wtin iqiḍan nsen din. \x ◘ \xo 33:9 \xt Uf. 15:27\x*
\m 
\v 10 Fesyen iqiḍan nsen, \add ffɣen\add* zi Ilim uca wtin iqiḍan nsen ɣar Řebḥar n Telga.
\m 
\v 11 Fesyen iqiḍan nsen, \add ffɣen\add* zi Řebḥar n Telga uca wtin iqiḍan nsen di řexřa n Sin. \x ◘ \xo 33:11 \xt Uf. 16:1\x*
\m 
\v 12 Fesyen iqiḍan nsen, \add ffɣen\add* zi řexřa n Sin uca wtin iqiḍan nsen di Dufqa.
\m 
\v 13 Fesyen iqiḍan nsen, \add ffɣen\add* zi Dufqa uca wtin iqiḍan nsen di Aluc.
\m 
\v 14 Fesyen iqiḍan nsen, \add ffɣen\add* zi Aluc uca wtin iqiḍan nsen di Rafidim, mani war yufi aman i řgens maḥend ad swen. \x ◘ \xo 33:14 \xt Uf. 17:1\x*
\m 
\v 15 Fesyen iqiḍan nsen, \add ffɣen\add* zi Rafidim uca wtin iqiḍan nsen di řexřa n Sina.\x ◘ \xo 33:15 \xt Uf. 19:1\x*
\m 
\v 16 Fesyen iqiḍan nsen, \add ffɣen\add* zi řexřa n Sina uca wtin iqiḍan nsen di Qabarut-Hata’awat. \x ◘ \xo 33:16 \xt Řxř. 11:34, 35\x*
\m 
\v 17 Fesyen iqiḍan nsen, \add ffɣen\add* zi Qabarut-Hata’awat uca wtin iqiḍan nsen di Ḥaḍayrut.
\b
\m 
\v 18 Fesyen iqiḍan nsen, \add ffɣen\add* zi Ḥaḍayrut uca wtin iqiḍan nsen di \bd Ritma\bd*.
\m 
\v 19 Fesyen iqiḍan nsen, \add ffɣen\add* zi Ritma uca wtin iqiḍan nsen di Rimmun-Fariṣ.
\m 
\v 20 Fesyen iqiḍan nsen, \add ffɣen\add* zi Rimmun-Fariṣ uca wtin iqiḍan nsen di Libna.
\m 
\v 21 Fesyen iqiḍan nsen, \add ffɣen\add* zi Libna uca wtin iqiḍan nsen di Rissa.
\m 
\v 22 Fesyen iqiḍan nsen, \add ffɣen\add* zi Rissa uca wtin iqiḍan nsen di Qihaylata.
\m 
\v 23 Fesyen iqiḍan nsen, \add ffɣen\add* zi Qihaylata uca wtin iqiḍan nsen di wedrar n Cafar.
\m 
\v 24 Fesyen iqiḍan nsen, \add ffɣen\add* zeg wedrar n Cafar uca wtin iqiḍan nsen di Ḥarada.
\m 
\v 25 Fesyen iqiḍan nsen, \add ffɣen\add* zi Ḥarada uca wtin iqiḍan nsen di Maqhaylut.
\m 
\v 26 Fesyen iqiḍan nsen, \add ffɣen\add* zi Maqhaylut uca wtin iqiḍan nsen di Taḥat.
\m 
\v 27 Fesyen iqiḍan nsen, \add ffɣen\add* zi Taḥat uca wtin iqiḍan nsen di Taraḥ.
\m 
\v 28 Fesyen iqiḍan nsen, \add ffɣen\add* zi Taraḥ uca wtin iqiḍan nsen di Mitqa.
\m 
\v 29 Fesyen iqiḍan nsen, \add ffɣen\add* zi Mitqa uca wtin iqiḍan nsen di Ḥacmuna.
\m 
\v 30 Fesyen iqiḍan nsen, \add ffɣen\add* zi Ḥacmuna uca wtin iqiḍan nsen di Musirut.\x ◘ \xo 33:30 \xt Aɛwd. 10:6\x*
\m 
\v 31 Fesyen iqiḍan nsen, \add ffɣen\add* zi Musirut uca wtin iqiḍan nsen di Bani-Yaɛqan.
\b
\m 
\v 32 Fesyen iqiḍan nsen, \add ffɣen\add* zi Bani-Yaɛqan uca wtin iqiḍan nsen di \bd Ḥur-Jidjad\bd*.
\m 
\v 33 Fesyen iqiḍan nsen, \add ffɣen\add* zi zi Hur-Jidjad uca wtin iqiḍan nsen di Yutbat.
\m 
\v 34 Fesyen iqiḍan nsen, \add ffɣen\add* zi zi Yutbat uca wtin iqiḍan nsen di Ɛabruna.
\m 
\v 35 Fesyen iqiḍan nsen, \add ffɣen\add* zi zi Ɛabruna uca wtin iqiḍan nsen di Ɛiṣyun-Jabar.
\m 
\v 36 Fesyen iqiḍan nsen, \add ffɣen\add* zi zi Ɛiṣyun-Jabar uca uca wtin iqiḍan nsen di řexřa n Ṣin nni \add yeǧa\add* Qadac. \x ◘ \xo 33:36 \xt Řxř. 20:1\x*
\m 
\v 37 Fesyen iqiḍan nsen, \add ffɣen\add* zi Qadac uca wtin iqiḍan nsen ɣar wedrar n Hur, ɣar tma n temmurt n Idum. \x ◘ \xo 33:37 \xt Řxř. 20:22\x*
\b
\m 
\v 38 Yuři ukehhan \bd Harun\bd* adrar n Hur am mammec d as inna SIDI uca immut din deg useggʷas wiss arebɛin awarni i uffuɣ n ayt n Israil zi temmurt n Miṣra, deg uyur wiss xemsa, deg wass amezwaru n uyur. \x ◘ \xo 33:38 \xt Řxř. 20:25; Aɛwd. 32:50\x*
\v 39 Tuɣa Harun ɣares mya u-třata u-ɛicrin n iseggʷusa umi immut deg wedrar n Hur.
\b
\m 
\v 40 Uca Akenɛani, ajeǧid n Ɛarad, \add wenni\add* tuɣa izeddɣen di ljanub n temmurt n Kenɛan, isřa s twasit n ayt n Israil. \x ◘ \xo 33:40 \xt Řxř. 21:1\x*
\b
\m 
\v 41 Fesyen iqiḍan nsen, \add ffɣen\add* zeg wedrar n Hur uca wtin iqiḍan nsen di Ṣalmuna.\x ◘ \xo 33:41 \xt Řxř. 21:4\x*
\m 
\v 42 Fesyen iqiḍan nsen, \add ffɣen\add* zi Ṣalmuna uca wtin iqiḍan nsen di Funun.
\m 
\v 43 Fesyen iqiḍan nsen, \add ffɣen\add* zi Funun uca wtin iqiḍan nsen di Ubut. \x ◘ \xo 33:43 \xt Řxř. 21:10\x*
\m 
\v 44 Fesyen iqiḍan nsen, \add ffɣen\add* zi Ubut uca wtin iqiḍan nsen di řxirbat n Ɛabarim di jjwayeh n weymir ak-d Mu’ab. \f ◼ \fr 33:44 \fk řxirbat\ft - niɣ ‘arwinat’.\f*
\m 
\v 45 Fesyen iqiḍan nsen, \add ffɣen\add* zi řxirbat \add n Ɛabarim\add* uca wtin iqiḍan nsen di Dibun-Jad.
\m 
\v 46 Fesyen iqiḍan nsen, \add ffɣen\add* zi Dibun-Jad uca wtin iqiḍan nsen di Ɛalmun-Diblatayim.
\b
\m 
\v 47 Fesyen iqiḍan nsen, \add ffɣen\add* zi Ɛalmun-Diblatayim uca wtin iqiḍan nsen \bd deg idurar n Ɛabarim zzat i wudem \bdit n wedrar\bdit* n Nabu\bd*.
\m 
\v 48 Fesyen iqiḍan nsen, \add ffɣen\add* zeg idurar n Ɛabarim uca wtin iqiḍan nsen \bd di řewḍat n Mu’ab ɣar L’Urdun \bdit arendad\bdit* i Ariḥa\bd*.
\m 
\v 49 Nitni wtin iqiḍan nsen ɣar L’Urdun zi Bayt-Yacimut ař Abal-Ciṭṭim di řewḍat n Mu’ab.\x ◘ \xo 33:49 \xt Řxř. 25:1; Yac. 2:1\x*
\b
\s1 Awař n Musa x uṭeffu n Kenɛan
\m 
\v 50 Issiweř SIDI ak-d Musa di řewḍat n Mu’ab ɣar L’Urdun \add arendad n\add* Ariḥa, inna:
\m 
\v 51 “Siweř ak-d ayt n Israil uca ini asen: ‘Xmi i ɣa teẓwam L’Urdun ɣar temmurt n Kenɛan,
\v 52 \add xenni\add* ittxeṣṣa kenniw ad tessuffɣem marra imezdaɣ n temmurt zzat i uɣembub nwem d marra řexyařat nsen ineqcen ad tent taredǧem. \add Ɛawed\add* ittxeṣṣa kenniw ad tᵉteḥḥam marra řexyařat ifesyen nsen d marra řegɛudi nsen. \x ◘ \xo 33:52 \xt Aɛwd. 7:2-26 \x*
\v 53 Ad tᵉṭṭfem tammurt d řwart uca ad dayes tzedɣem, minzi Necc wciɣ awem tammurt nni d agřa.
\v 54 Ad tebḍam tammurt s tqedduḥt am řwart x řaǧat nwem. Wi ɣar iǧa aṭṭas, ad as tewcem aṭṭas, u wenni ɣar iǧa drus, ad as tewcem drus. Mani d as dd-tusa tqedduḥt, ad yiři nnes. Ɛlaḥsab tiqebbař n řejdud nwem ad twartem tasɣart nwem. \x ◘ \xo 33:54 \xt Řxř. 26:54-65\x*
\v 55 Maca mařa kenniw war tessuffuɣem ca imezdaɣ n temmurt zzat i wudem nwem, \add xenni\add* ad imsar aqa inni i ɣa tejjem ad qqimen, ad dewřen d isennanen di tiṭṭawin nwem d iwezwizen deg iɣezdisen nwem uca nitni ad kenniw ḥṣaren di temmurt nni mani tzeddɣem. \x ◘ \xo 33:55 \xt Yac. 23:13; Řqḍ. 2:3\x*
\v 56 Uca \add xenni\add* ad imsar ad awem ggeɣ am mammec tuɣa xarrṣeɣ ad akidsen ggeɣ.”
\b
\b
\c 34
\s1 Iymiren n temmurt
\m 
\v 1 Issiweř SIDI ak-d Musa, inna:
\m 
\v 2 “Umur ayt n Israil uca ini asen: ‘Xmi ɣa tadfem tammurt n Kenɛan, \add xenni\add* ta d tammurt i d awem ɣa yiřin d řwart, tammurt n Kenɛan ak-d iymiren nnes \add ad tiři ammu\add*:
\m 
\v 3 Jjihet n ljanub ad ɣarwem tiři zi řexřa n Ṣin ař aymir n Idum uca \bd aymir n ljanub\bd* ad ɣarwem yiři zi ṭṭarf aneggaru n Řebḥar Ameǧaḥ di ccarq \x ◘ \xo 34:3 \xt Yac. 15:1\x*
\v 4 uca aymir ad imeyyeř zi ljanub ɣar Tsunta n Tɣarḍmiwin uca ad iɛdu ɣar Ṣin uca ṭṭrufa nnes \add ad dd-awḍen\add* jjihet n ljanub n Qadac-Barniɛ uca ad iɛdu ɣar Ḥaṣar-Addar uca ad iẓwa ɣar Aṣmun.
\v 5 Ad inneḍ weymir zi Aṣmun ɣar Teɣzart n Miṣra uca ṭṭrufa nnes \add ad awḍen\add* ař řebḥar.
\b
\m 
\v 6 Uca \bd aymir n řɣarb\bd* ad awem yiři Řebḥar Ameqqran. Wa ad awem yiři d aymir n řɣarb.”\f ◼ \fr 34:6 \fk Řebḥar Ameqqran\ft - niɣ ‘Ill Ameqqran’. Řebḥar-a qqaren as di Arif ‘Řebḥar Ameẓyan’, uca isem nnes n jdid aqa-t ‘Ill Agrakal’.\f*
\b
\m 
\v 7 Wa ad awem yiři d \bd aymir n ccamal\bd*: ad t tarcmem i yixef nwem zeg Řebḥar Ameqqran ař adrar n Hur.
\v 8 Zeg wedrar n Hur ad t tarcmem ař mani ɣa tawḍed ɣar Ḥamat uca ṭṭrufa n weymir ad awḍen ař Ṣadad.
\v 9 Ad yeɛdu weymir ař Zifrun uca ṭṭrufa nnes ad awḍen ař Ḥaṣar-Ɛinan. Wa ad awem yiři d aymir n ccamal.
\b
\m 
\v 10 Ad tarcmem \bd aymir nwem n ccarq\bd* zi Ḥaṣar-Ɛinan ɣar Cafam
\v 11 uca ad dd-ihwa weymir zi Cfam ař Ribla, ccarq n Ɛayn. \add Xenni\add* ad dd-ihwa weymir \add ɛad\add* ktar uca ad imun ak-d tma n ccarq n Řebḥar n Kinnarat.
\v 12 \add Xenni\add* ad dd-ihwa weymir ɣar L’Urdun uca ṭṭrufa nnes ad awḍen ař Řebḥar Ameǧaḥ. Ta ad awem tiři d tammurt ak-d iymiren nnes i d as dd-innḍen.”
\b
\m 
\v 13 Uca Musa yumur ayt n Israil, inna: “Ta d tammurt nni i ɣa tebḍam jar awem s tqedduḥt, tenni x yumur SIDI ad temmewc i tesɛa n tqebbař u i wezyen n teqbič \add n Manassa\add*.
\v 14 Minzi taqbič n ayt n Rubin \add tᵉttwasettef\add* ɛlaḥsab taddart n ibabaten nsen u taqbič n Jad \add tᵉttwasettef\add* ɛlaḥṣab taddart n ibabaten nsen, aqa nitni ṭṭfen \add ɛad tasɣart nsen\add*, u azyen n teqbič n Manassa tᵉṭṭef \add uřa d nettat\add* tasɣart nnes n řwart.
\v 15 Tnayen n tqebbař d wezyen aqa ṭṭfent řwart nsent ɣar ujemmaḍ n L’Urdun, zi Ariḥa ɣar ccarq ɣar manis dd-tneqqar \add tfuct\add*.”
\b
\m 
\v 16 Issiweř SIDI ak-d Musa, inna:
\m 
\v 17 “Ina d ismawen n yeryazen inni i ɣa ibḍan tammurt jar awem:
\m Akehhan Aliɛazar d Yacuwa, mmis n Nun. \x ◘ \xo 34:17 \xt Yac. 14:1\x*
\b
\m 
\v 18 Ad teksim \add ɛawed\add* ijj n řḥakem zi kuř taqbič maḥend ad tebḍam tammurt.
\m 
\v 19 Ina d ismawen n yeryazen:
\m i teqbič n Yahuda, Kalib, mmis n Yafunni
\m 
\v 20 i teqbič n ayt n Cimɛun, Cimuwil, mmis n Ɛammihud,
\m 
\v 21 i teqbič n Binyamin, Ilidad, mmis n Kaslun,
\m 
\v 22 i teqbič n ayt n Dan, řḥakem Buqqi, mmis n Yujli,
\m 
\v 23 i teqbič n ayt n Yusuf:
\m i teqbič n ayt n Manassa, řḥakem Ḥanniyil, mmis n Ifud,
\m 
\v 24 i teqbič n ayt n Ifrayim, řḥakem Qimuyil, mmis n Cifṭan,
\m 
\v 25 i teqbič n ayt n Zabulun, řḥakem Iliṣafan, mmis n Farnax,
\m 
\v 26 i teqbič n ayt n Issakar, řḥakem Falṭiyil, mmis n Ɛazzan,
\m 
\v 27 i teqbič n ayt n Acir, řḥakem Axihud, mmis n Calumi,
\m 
\v 28 i teqbič n ayt n Naftali, řḥakem Fadahyil, mmis n Ɛammihud.”
\m 
\v 29 Ina d inni x yumur SIDI ad bḍan řwart i ayt n Israil di temmurt n Kenɛan.
\b
\b
\c 35
\s1 Tineddam i Ilawiyyen
\m 
\v 1 Issiweř SIDI ak-d Musa di řewḍat n Mu’ab ɣar L’Urdun \add arendad n\add* Ariḥa uca inna:
\m 
\v 2 “Umur ayt n Israil ḥima ad wcen, zi řwart nsen i ṭṭfen, tineddam i Ilawiyyen maḥend ad daysent zedɣen. Ad tewcem i Ilawiyyen \add ɛawed\add* ddmani n tarewsa, inni d asen dd-innḍen i tneddam. \x ◘ \xo 35:2 \xt Yac. 21:2\x*
\v 3 Tineddam-a ad iřint maḥend ad daysent zedɣen, uca ddmani n tarewsa ad iřin i řebhayem nsen u i wagřa nsen u i marra imuddaren nsen.
\v 4 Uca ddmani n tarewsa i iǧan ɣar tneddam nni i ɣa tewcem i Ilawiyyen, ad iřin zeg weɣbar n tendint ɣar barra ařef n iɣaǧen uca \add amenni\add* ɣar marra iɣezdisen \add nnes\add*.
\v 5 Barra n tendint ɣar ccarq ad tɛebbarem ařfayen n iɣaǧen u ɣar ljanub ařfayen n iɣaǧen u ɣar řɣarb ařfayen n iɣaǧen u ɣar ccamal ařfayen n iɣaǧen uca tandint \add ad tiři\add* di řwesṭ. Ina ad asen iřin d ddmani n tarewsa n tneddam.
\v 6 Tineddam i ɣa tewcem i Ilawiyyen \add ad iřint\add* setta n tneddam n tarewřa. Ad tent tewcem maḥend ad din yarweř uqettař. Sennej i man aya ad \add tent\add* tewcem \add ɛad\add* tnayen u-rebɛin n tneddam. \x ◘ \xo 35:6 \xt Yac. 21:21\x*
\m 
\v 7 Marra tineddam i ɣa tewcem i Ilawiyyen, \add ad iřint\add* tmenya u-rebɛin n tneddam, tina \add simant nsent\add* d ddmani nsent n tarewsa.
\v 8 X tneddam i ɣa tewcem zeg wagřa n ayt n Israil, ad tent teksim ktar zeg wenni ɣar iǧa waṭṭas u zeg wenni ɣar iǧa drus, ad teksid drus. Kuř ijj ad iwc zi tneddam nnes i Ilawiyyen ɛlaḥsab \add řqedd n\add* tesɣart nnes zi řwart i iṭṭef.”
\b
\s1 Tineddam i tarewřa
\m 
\v 9 Issiweř SIDI ak-d Musa, inna:
\m 
\v 10 “Siweř ak-d ayt n Israil uca ini asen: ‘Xmi ɣa teẓwam L’Urdun ɣar temmurt n Kenɛan, \x ◘ \xo 35:10 \xt Aɛwd. 19:2; Yac. 20:2\x*
\v 11 ad tneyycem i yixef nwem tineddam nni d awem i ɣa iřint d tineddam n tarewřa, ḥima aqettař, wenni inɣin ḥed zeg uweddar, izemmar ad din yarweř.
\v 12 Tineddam-a ad awem iřint i tarewřa zeg uneqqam n idammen, ḥima war ittmetti uqettař qbeř ma ad ibedd zzat i wudem n tmesmunt i řḥukm.
\v 13 Zi tneddam i ɣa tewcem, ad \add zzaysent\add* iřint setta d tineddam n tarewřa i kenniw.
\m 
\v 14 Třata n tneddam ad \add tent\add* tewcem ɣar ujemmaḍ n L’Urdun u třata n tneddam ad \add tent\add* tewcem di temmurt n Kenɛan. Ad iřint d tineddam n tarewřa. \x ◘ \xo 35:14 \xt Aɛwd. 4:41; Yac. 20:8\x*
\v 15 Setta n tneddam-a ad iřint i tarewřa i ayt n Israil uřa i ubarrani d umɛezzeb di řwesṭ nsen, ḥima wenni inɣin ḥed zeg uweddar, izemmar ad din yarweř.
\m 
\v 16 Mařa iwwet i-t s ict n řqecɛet n wuzzař uca immut, \add xenni\add* aqa netta d aqettař. Aqettař ad ittwaneɣ nican.
\v 17 Mařa iwwet i-t s ijj n weẓru deg ufus i zi izemmar ad immet uca \add xenni\add* immut, aqa netta d aneqqam. Aneqqam ad ittwaneɣ nican.
\v 18 Niɣ \add mařa\add* iwwet i-t s ict n řqecɛet n ukeccuḍ deg ufus i zi izemmar ad immet uca \add xenni\add* immut, aqa netta d aqettař. Aqettař ad ittwaneɣ nican.
\v 19 Aneqqam n idammen ad ineɣ aqettař. Mařa ad t iřqa, ad t ineɣ.
\m 
\v 20 U mařa iɛarn i-t s wecrah, niɣ inḍar ɣares \add ca\add* s neɛmada ařami \add zzayes\add* immut, \x ◘ \xo 35:20 \xt Aɛwd. 19:11\x*
\v 21 niɣ iwwet i-t s řeɛdawet s ufus nnes, ařami \add zzayes\add* immut, \add xenni\add* wenni \add t\add* inɣin ad ittwaneɣ nican. Aqa-t d aqettař. Aneqqam n idammen ad ineɣ aqettař xmi t ɣa iřqa.
\m 
\v 22 \add Maca\add* mařa tuɣa iɛarren i-t amenni deg wermac n wabřiwen břa řeɛdawet, niɣ inḍar ɣares ca n řqecɛet am iweddar,
\v 23 niɣ am war t iẓri, igga ad xas dd-iwḍa ca n weẓru i zi izemmar ad immet, uca \add xenni\add* immut am war tuɣi d řeɛdu nnes u netta tuɣa war d as yarezzu řɣar,
\v 24 \add xenni\add* tamesmunt ad teḥkem jar uqettař d uneqqam n idammen ɛlaḥsab lfarayiḍ-a.
\v 25 Tamesmunt ad tfekk aqettař zeg ufus n uneqqam n idammen uca tamesmunt ad tejj netta ad iɛqeb ɣar tendint nnes n tarewřa. Ad din iqqim ař řmewt n arrays n ikehhanen, wenni dehnen nitni s zzect iqeddsen.
\v 26 \add Maca\add* mařa aqettař iffeɣ barra n iymiren n tendint n tarewřa mani yarweř,
\v 27 uca aneqqam n idammen yufa i-t barra n iymiren n tendint n tarewřa uca aneqqam n idammen inɣa wenni inɣin, war xas ca idammen \add xenni\add*.
\v 28 Minzi tuɣa xas ad iqqim di tendint nnes n tarewřa ař řmewt n arrays n ikehhanen. \add Maca\add* awarni řmewt n arrays n ikehhanen izemmar ad iɛqeb uqettař ɣar temmurt nni iǧan nnes.
\v 29 Aya ad awem tiři d tawṣeyyet n řḥeqq i \add marra\add* jjiřat nwem mani ma ɣa tzedɣem.
\m 
\v 30 Kuř ijj, wenni inɣin ḥed, aqa aqettař ad ittwaneɣ ɛlaḥsab aqemmum n řechud, \add maca\add* ijj n ucehhad \add waha\add*, war izemmar ad iched x ict n nnefs s řmewt. \x ◘ \xo 35:30 \xt Aɛwd. 17:6; 19:15\x*
\v 31 War kessim ddeyyet x řeɛmar n uqettař nni x ittwaḥkem s řmewt, maɣar ittxeṣṣa ad ittwaneɣ nican.
\v 32 War kessim ddeyyet x wenni yarewřen ɣar tendint nnes n tarewřa di ṭṭweɛ n weɛqab nnes, maḥend ad izdeɣ di temmurt qbeř řmewt n arrays n ikehhanen.
\m 
\v 33 War iɛeddeř ad tessexsarem tammurt mani teǧam, minzi idammen ssexsaran tammurt uca war izemmar ad ittwagg weṣřaḥ i temmurt di ṭṭweɛ n idammen i dayes ittwassizřen, mɣir s idammen n wenni ten issizzřen.
\v 34 War sxemmijem tammurt mani ɣa tzedɣem kenniw, di řwesṭ nnes i ɣa zedɣeɣ Necc, minzi Necc d SIDI, wenni izeddɣen di řwesṭ n ayt n Israil.”
\b
\b
\c 36
\s1 Tasɣart n řwart i yessis n Ṣalufḥad
\m 
\v 1 Zi řaǧat n iḥenjiren n Yusuf qarrben-dd izeǧifen jar ibabaten n řaǧ n iḥenjiren n Jilɛad, mmis n Makir, mmis n Manassa uca nitni ssiwřen zzat i wudem n Musa u zzat i wudem n řḥukkam, izeǧifen \add nneɣni\add* x ibabaten \add n řaǧat\add* n ayt n Israil
\v 2 uca nitni nnan: “SIDI yumur sidi inu maḥend ad iwc tammurt s tqedduḥt i ayt n Israil d řwart. Uca yumur SIDI i sidi inu ad iwc tasɣart n řwart n umatneɣ Ṣalufḥad i yessis. \x ◘ \xo 36:2 \xt Řxř. 26:55, 56; 27:7; 33:54; Yac. 17:3, 4\x*
\v 3 Mařa dewřent nitenti d tinemřač ak-d ijjen zeg iḥenjiren n tqebbař nneɣni n ayt n Israil, xenni ad tᵉttwakkes tesɣart nsent di řwart n řejdud nneɣ uca ad tᵉttwarni \add tasɣart nsent\add* i tesɣart n teqbič i ɣar ɣa munent uca \add ammu\add* ad ittwassemẓi min iǧan d tasɣart nneɣ s tqedduḥt.
\v 4 Xmi dd ɣa yas useggʷas \add n usřiwřew\add* i ayt n Israil, \add xenni\add* ad tᵉttwamarni tesɣart nsent i tesɣart n teqbič ak-d wi ɣa munent. \add Ammu\add* i ɣa tᵉttwakkes \add xenni\add* tesɣart nsent di řwart n teqbič n řejdud nneɣ.”
\m 
\v 5 \add Xenni\add* yumur Musa i ayt n Israil ɛlaḥsab řumur n SIDI, inna: “\add Aqa d tidett\add* am mammec tessiweř teqbič n ayt n Yusuf.
\v 6 Wa d awař i zi yumur SIDI x yessis n Ṣalufḥad, iqqar: ‘Ejj i-tent ad meřcent ak-d wenni d asent yarecqen. Ittxeṣṣa mɣir ad meřcent di řaǧ n teqbič n babatsent.
\v 7 War iɛeddeř ad traḥ tesɣart n ayt n Israil zi teqbič ɣar teqbič \add nneɣni\add*, minzi kuř aryaz n ayt n Israil ad iqqim iṭṭef di tesɣart n teqbič n řejdud nnes.
\v 8 Yeǧis n kuř ijj i ɣa iṭṭfen ict n tesɣart zeg ayt n Israil, ittxeṣṣa as ad temřec ak-d ijj zeg ijj n řaǧ zi teqbič n babas, ḥima kuř ijj zeg ayt n Israil ad iwart tasɣart n řejdud nnes. \f ◼ \fr 36:8 \fk Yeǧis\ft - niɣ ‘iǧis’.\f*
\v 9 War iɛeddeř ad traḥ tesɣart n ict n teqbič ɣar teqbič nneɣni, minzi ittxeṣṣa i kuř ict zi tqebbař n ayt n Israil ad iqqim iṭṭef di tesɣart nnes.’”
\m 
\v 10 Yessis n Ṣalufḥad ggint am mammec \add t\add* yumur SIDI i Musa.
\v 11 Maḥla, Tirṣa, Ḥujla, Milka d Nuɛa, yessis n Ṣalufḥad, dewřent d tinemřač ak-d iḥenjiren n ɛemmitsent. \x ◘ \xo 36:11 \xt Řxř. 27:1\x*
\v 12 Dewřent d tinemřač di řaǧat n ayt n Manassa, mmis n Yusuf. \add Ammu i\add* teqqim tesɣart nsent di teqbič n babatsent.
\m 
\v 13 Tina d tiweṣṣa d lfarayiḍ nni yumur SIDI s tsexxart n Musa i ayt n Israil di řewḍat n Mu’ab, ɣar L’Urdun \add arendad n\add* Ariḥa. 
