\id 1PE
\h ÁR NDU̱I AR PEDRO
\toc1 ÁR NDU̱I AR PEDRO Ár ndu̱i ar he̱ꞌmi bi ꞌyotꞌa ar Pedro
\toc2 ÁR NDU̱I AR PEDRO
\toc3 1 P.
\mt1 ÁR NDU̱I AR PEDRO
\mt2 Ár ndu̱i ar he̱ꞌmi bi ꞌyotꞌa ar Pedro
\c 1
\s1 Ar nze̱ngwa
\p 
\v 1 Nuga dar Pedro, ár mpo̱tegi ar tsi Hmu Hesukristo. Di otꞌahu̱ nunar he̱ꞌminu̱, nuꞌahu̱ xka mfonthu̱ ha maꞌra ya ha̱i núnu̱ Mponto, Ngalasia, Nkapadosia, Nꞌasia ne har ha̱i Mbitinia.
\p 
\v 2 Jö ar Dada xki hwañꞌahu̱ ya mahamꞌu̱ ngu xki beñꞌö, ne bi hñuxꞌahu̱ nda tꞌaxkꞌa ri mꞌu̱ihu̱ ár Hñö Jö. Njapꞌu̱ da tsa̱ gi ꞌyo̱thu̱ Jö, ne nda xu̱kꞌahu̱ hár ji ar tsi Hmu Hesukristo. Dá hñusꞌa ar nhwëki ne ar hogamꞌu̱i tꞌaꞌahu̱.
\s1 Nꞌar döta ndo̱ꞌmi
\p 
\v 3 Nsunda Jö ár Dada ar tsi Hmu Hesukristo, togo bi hwëgagihu̱ da mꞌu̱hu̱ manꞌagi. Ne xa di ꞌwithu̱ di to̱ꞌmhu̱ nöꞌö xi ꞌñepꞌu̱, ngetho bi mengi bi nte manꞌagi ar tsi Hmu Hesukristo.
\p 
\v 4 Ne ma ga höñhu̱nu̱ mhetsꞌi nꞌar ñho hiñhamꞌu̱ da nhwati, hinto da tsa̱ da ja̱xtꞌi, ne hinda tho ár nza̱tho. Gehnu̱ xi tꞌe̱gagihu̱nu̱.
\p 
\v 5 Ár tsꞌe̱di Jö fa̱xa ma ñꞌemu̱ihu̱ ga höñhu̱ nunar mpo̱ho̱ xi tꞌe̱gagihu̱, ne da tꞌaju̱ ha ya ngöxapa.
\p 
\v 6 Ne go gehyu̱ jaꞌahu̱ gi njohyahu̱, mödi ꞌra ya tsi pa gi thohu̱ ya ntꞌu̱tsa, nuꞌmu̱ njapꞌu̱ handa xiñho ar tsi Dada.
\p 
\v 7 Ne njapꞌu̱ da tsꞌa̱tꞌa ri ñꞌemu̱ihu̱, töta ár ñho ar kꞌaxtꞌabo̱jö tꞌe̱ntꞌa har tsibi, ne da ꞌwe gatho nöꞌö hingi ho, mödi ma da thotho. Ha nuna ri jamfihu̱nu̱ ma da tꞌeꞌspa ár nsu, ne da nhumañho xta epꞌu̱ ar tsi Hmu Hesukristo.
\p 
\v 8 Hinxka hyanthu̱ ha gi möhu̱, ne gi ñꞌemu̱ihu̱ mödi hingi hanthu̱pya. Nunar jamfinu̱ jaꞌahu̱ gi pe̱ꞌsu̱ nꞌar johya xa nza̱tho, hingi tsa̱ ga möñhu̱ tenguꞌö.
\p 
\v 9 Ne gi tsu̱hu̱ ar mpo̱ho̱, gehnu̱ gi ñꞌemu̱ihu̱ gi tsu̱hu̱.
\p 
\v 10 Nuyá mꞌe̱hni Jö bi ñꞌa̱ni ne bi hñetꞌu̱ tema ndi bo̱nga nunar mpo̱ho̱ xki ñhötꞌahu̱, ne bi möñꞌu̱ nunar nhwëkinu̱ xki tꞌe̱kꞌahu̱.
\p 
\v 11 Mi hetꞌu̱ xiñho togo ne hamꞌu̱ ma nda tho nöꞌö xki xipa ár Hñö ar tsi Hmu Hesukristo mi pe̱sꞌu̱. Gehnu̱ mi xipꞌu̱ tema u̱gi ma nda thoꞌö, ne ya döta njöpi nda e mꞌe̱fa.
\p 
\v 12 Xki tꞌutwabiꞌu̱ nehe hinge nda zu̱ nuya ñhoyu̱, go ma nda zu̱ju̱. Nöꞌö mi möñꞌu̱ mahamꞌu̱, xi xiꞌahu̱pya nuꞌu̱ togo hömpa ár tsꞌe̱di ár Hñö Jö, gehnu̱ xpa e mhetsꞌi. Gathoyu̱ nemhö da bö xiñho ya e̱nxe̱.
\s1 Tsꞌónkagihu̱ ga ꞌbu̱hu̱ nꞌar mꞌu̱i xintꞌaxi
\p 
\v 13 Jange umba ri mu̱ihu̱ gi pöhu̱ tema gi pe̱hu̱. Da xo ri da̱hu̱, ne gi to̱ꞌmthohu̱ ar nhwëki ma da hö ma tsi Hmuhu̱ Hesukristo xta ehe.
\p 
\v 14 Nupya gar bötsiꞌihu̱ Jö gi o̱hu̱ gatho nöꞌö nsiꞌahu̱. Jange yo gi nehu̱ nuya tsꞌoki ngi o̱thu̱ mahamꞌu̱ núꞌmu̱ hinge ngi pöhu̱ ngi ꞌyo̱thu̱ ar ñho.
\p 
\v 15 Jangu nöꞌö togo bi zoñꞌahu̱ xintꞌaxi ár mꞌu̱i, gi njahu̱pꞌu̱ nꞌehe, dár ntꞌaxi gatho nöꞌö gi ꞌyo̱thu̱.
\p 
\v 16 Ngetho njanu̱ xi mönga Jö har Tꞌofo: Dár ntꞌaxi ri mꞌu̱ihu̱ nguga xintꞌaxigi.
\p 
\v 17 Ha nuꞌmu̱ gi ndöñhu̱ ngu ri Dadahu̱ togo o̱tꞌa ar hoga tsꞌu̱tꞌwi, umba ngu xi ꞌyo̱tꞌa nꞌa ngu nꞌa, ne hingi hwantho; jange ntsuñhu̱ hanja gi ꞌyohu̱ gatho ya pa gi nehu̱ ar ꞌñu di ma mhetsꞌi.
\p 
\v 18 Ngetho bi nju̱kꞌahu̱ har mꞌu̱i hinte mar ñho bi zokꞌa ri dadahu̱. Ha nunar njutꞌi bi tꞌuni bi tsꞌiñꞌahu̱, hinge ngu nöꞌö thege, ngu ar kꞌaxtꞌi wa ar tꞌaxbo̱jö.
\p 
\v 19 Gese̱ ár ji ar tsi Hmu Hesukristo bi nöꞌmi, ngu nꞌar tsi de̱ti tꞌunga ngu ar mꞌo̱ñho̱, xa ꞌbu̱i xiñho ne hingar tsꞌonte.
\p 
\v 20 Jö xki benga nda ꞌyo̱tꞌa njapꞌu̱ núꞌmu̱ hinxki hyokta ar ximha̱i, ne ka xi nheki nuya payu̱ hompꞌa ri ñhohu̱.
\p 
\v 21 Ne nuna ar u̱gi bi tho ar tsi Hmu Hesukristo, bi jaꞌahu̱ gi ñꞌemu̱ihu̱ Jö, togo bi koꞌspa ár te ne xi umba nꞌar döta nsunda. Njapꞌu̱ gi ñꞌemu̱ihu̱ Jö, ne gi to̱ꞌmbabihu̱ ár mfa̱tsꞌi.
\p 
\v 22 Xi tꞌaxka ri mu̱ihu̱ gi o̱thu̱ nöꞌö majöni, ne ár Hñö Jö fa̱xꞌahu̱ gi pe̱ꞌsu̱ ar hoga mhöte hindi oxta mañö. Jange mhöhu̱ nꞌa ngu nꞌa. Nunar mhötenu̱ di ꞌñe ha nꞌar hogamu̱i xintꞌaxi.
\p 
\v 23 Ngetho xka penju̱ xka mꞌu̱hu̱ manꞌagi. Hinge xka ꞌñehu̱pya ha nꞌa di the ár te. Xka po̱ñhu̱ ha nꞌa hingi the ár te, núꞌmu̱ ga pöthwu̱ ár mhö Jö hö ar te ne hiñhamꞌu̱ da thege.
\p 
\v 24 Ngetho hár Tꞌofo Jö enö njawa:
\q1 Gatho ya jöꞌi ñhe̱hwi ya do̱ni,
\q1 ne ár nsu ngu ár ndo̱ni.
\q1 Xta ꞌyotꞌa ar do̱ni da da̱ ár ndo̱ni.
\q1 
\v 25 Ha nunár mhö Jö hiñhamꞌu̱ da thege.
\m Gehnu̱ ar hoga mhö xi nsiꞌahu̱.
\c 2
\p 
\v 1 Jange hye̱hu̱ nꞌagitho gatho ya tsꞌoki, ya nhemhñö, nöꞌö gi yotꞌa ri hmihu̱, ya hyo̱kte, ne ya ꞌyonga ꞌbede.
\p 
\v 2 Xa gi hyoñhu̱ ngu nꞌar tsi tꞌu̱lo bötsi ar ꞌba di ꞌñe mhetsꞌi hinte xi nthöntsꞌi. Njapꞌu̱ gi tehu̱ xiñho ne gi pe̱ꞌsu̱ ar mpo̱ho̱.
\p 
\v 3 ꞌYo̱thu̱ njapꞌu̱ ngetho xka pöthwu̱ ár nhwëki ar tsi Hmu.
\s1 Ar tsi Hmu Hesukristo ngu nꞌar do pe̱ꞌsa ar te
\p 
\v 4 Kwathu̱ gi hyoñhu̱ ar tsi Hmu Hesukristo, togo ngu nꞌar do pe̱ꞌsa ar te. Mödi nunar donu̱ bi zanda nuꞌu̱ togo mi ho̱ ar ngu, ha Jö go bi hyandi ngu nꞌar do xi thahni ne nza̱tho.
\p 
\v 5 Gi njahu̱pꞌu̱ nꞌehe, di hñöxꞌahu̱ ar do hö ar te, nꞌa ngu nꞌa gi jafu̱ da heꞌsa ár nijö Jö. Ne di hñöxꞌahu̱ ar möjö pe̱ꞌsa nꞌar mꞌu̱i xintꞌaxi, gi e̱ntꞌa ri tehu̱ ngu nꞌar mꞌo̱ñho̱ numañho Jö, gi hömfu̱ ár tsꞌe̱di ar tsi Hmu Hesukristo.
\p 
\v 6 Jange enga har Tꞌofo:
\q1 Pöhu̱ di exnu̱ Nsion ar mu̱dido du̱ꞌma ar jödo xi thahni nza̱tho.
\q1 Nuꞌu̱ togo da ñꞌemu̱ibi, hinda ma da ꞌbe̱ ár tsa̱.
\m 
\v 7 Jange nuꞌahu̱ xka ñꞌemu̱ihu̱, gi hanthu̱ nza̱thoꞌö. Ha nuꞌu̱ togo hinxi ñꞌemu̱i, ngu enga har Tꞌofo:
\q1 Nunar do bi zanda ya ho̱ngu,
\q1 nupya ar mu̱dido du̱ꞌmba ár jödo ar ngu.
\m 
\v 8 Ne enö nꞌehe:
\q1 Gehnu̱ ar do da japi da feꞌsa yá wa ne da hwangi.
\m Ngetho nthe̱wi ar mfetsꞌe hár mhö Jö, gehyu̱ ya me̱ꞌsku. Njapꞌu̱ xki thutsꞌi nda njapꞌu̱ꞌu̱.
\s1 Ár hnini Jö
\p 
\v 9 Ha nuꞌahu̱ yá bötsiꞌihu̱ Jö xi hwañꞌahu̱, yá möjöꞌihu̱ ar ndö mhetsꞌi. Go geꞌahu̱ ár hnini Jö ꞌbu̱ xintꞌaxi, ne ár me̱tiꞌihu̱ꞌö. Gese̱ꞌö bi hwañꞌahu̱ gi xifu̱ maꞌra tengu ár tsꞌe̱di ne ár nsunda nöꞌö togo bi zoꞌahu̱ ngi po̱ñhu̱ har ꞌbe̱xui, ne gi ꞌbu̱hu̱pya har hoga hyatsꞌi xa nza̱tho.
\p 
\v 10 Mahamꞌu̱ hinge ngar hniniꞌihu̱ Jö, ha nupya hö, yá hniniꞌihu̱ꞌö. Mahamꞌu̱ hinge ngi pe̱ꞌsfu̱ ár nhwëkiꞌö, ha nupya hö, xka hñömfu̱ ár nhwëki.
\s1 ꞌBu̱hu̱ ngu yá ꞌbe̱goꞌihu̱ Jö
\p 
\v 11 Tsi kuhu̱, di zoꞌahu̱ ngu ya nzo̱ho̱ ne ngu ya neꞌñu. Di xiꞌahu̱ gi hye̱hu̱ nuya te gatho ne ri ndoꞌyohu̱, gehyu̱ nto̱xkwi nöꞌö ne ri mu̱ihu̱.
\p 
\v 12 ꞌBu̱hu̱ nꞌar hogamꞌu̱i madeda nuꞌu̱ togo hinxi jamfi, mödi ꞌyompꞌa ri ꞌbedehu̱ eñꞌu̱ xi ntsꞌotho nöꞌö gi o̱thu̱. Ne xta epꞌu̱ ar tsi Hmu Hesukristo, ma da nsundabi Jö xta xo yá da̱, da böꞌu̱ mar ñho nöꞌö ngi o̱thu̱.
\p 
\v 13 Ngetho gi jamfihu̱ ar tsi Hmu, ꞌyo̱thu̱ gatho nuꞌu̱ togo pe̱ꞌsa nꞌar nsu. ꞌYo̱thu̱ ar ndö xi tꞌexa mañö,
\p 
\v 14 ne gatho yá ma̱xte, ngetho xi mꞌe̱hni da umbya mfe̱i ya tsꞌokte, ne da ꞌñeꞌspa yá nsu nuꞌu̱ o̱tꞌa xiñho.
\p 
\v 15 Ne Jö gi ꞌyo̱thu̱ xiñho, ne njapꞌu̱ gi kothwu̱ yá ne nuꞌu̱ ya jöꞌi hingi numañho nöꞌö di pe̱hu̱.
\p 
\v 16 ꞌBu̱hu̱ wande hinto suꞌahu̱, ho̱nse̱ hingi jahu̱ gi ne gi ꞌyo̱thu̱ nöꞌö hingi ho. ꞌYohu̱ ngu yá ꞌbe̱goꞌihu̱ ar tsi Dada.
\p 
\v 17 ꞌÑeꞌsfu̱ ár nsu gatho. Möhu̱ ya tsi ku. Tsufu̱ Jö. ꞌÑeꞌsfu̱ ár nsu ar ndö nꞌehe.
\p 
\v 18 ꞌBe̱gohu̱, pe̱ꞌsu̱ nꞌar hogamu̱i gi ꞌyo̱thu̱ ri hmuhu̱. Hinge ho̱nse̱ nuꞌu̱ togo ya hogajöꞌi, ꞌyo̱thu̱ nuꞌu̱ xi ñhembi gi tse̱thu̱ nꞌehe.
\p 
\v 19 Jö handa xiñho nuꞌu̱ tho ya mfe̱i hindi ꞌñepabi, nuya thogi tse̱ti, o̱tꞌe da gohwi xiñho Jö.
\p 
\v 20 Tema ñho gi ju̱ju̱ nuꞌmu̱ gi tse̱thu̱ ar mfe̱i ngetho xka ntsꞌoju̱. Ha nuꞌmu̱ gi thohu̱ ar mfe̱i ngetho gi o̱thu̱ nöꞌö xiñho, njapꞌu̱ hö, hantꞌahu̱ xiñho Jö.
\p 
\v 21 Xi tsꞌoñꞌahu̱ gi tse̱thu̱; ngetho ar tsi Hmu Hesukristo go bi thoꞌö ya thogi ma nga thohu̱hmö, ne njapꞌu̱ bi utkagihu̱ ár mꞌu̱i ga te̱ñhu̱.
\p 
\v 22 Nöꞌö hinte ma tsꞌoki bi ꞌyo̱tꞌe, ne hinte mar nhemhñö bi bo̱nga hár ne.
\p 
\v 23 Númꞌu̱ mi tsꞌani, himi koꞌsa ar ntsꞌani. Númꞌu̱ mi tho ya u̱gi, hinge mi xipabi nda njapabipꞌu̱ nꞌehe. Mi tsokwa gatho hár ꞌye̱ nöꞌö togo o̱tꞌa ar hoga tsꞌu̱tꞌwi.
\p 
\v 24 Gese̱ bi hñöska ma tsꞌokihu̱ hár ndoꞌyo núꞌmu̱ mi tsꞌu̱ta har pontꞌi, ne njapꞌu̱ nuꞌu̱ di ꞌbu̱hu̱, hinte tsa̱ te da jaju̱ ar tsꞌoki. Nupya ga ꞌbu̱hu̱ ga o̱thu̱ nöꞌö xiñho. Bi tho ar u̱giꞌö, ne njapꞌu̱ gi pe̱ꞌsu̱ ar nzaki.
\p 
\v 25 Ngetho ngi ñhe̱hwihu̱ ꞌra ya tsi de̱ti xki mfontꞌi, ha nupya xka penju̱ xka tsu̱hu̱ ar ma̱ꞌyo suꞌa ri tehu̱.
\c 3
\s1 Hanja da mꞌu̱ ya nthöti
\p 
\v 1 Di zoꞌahu̱ nuꞌahu̱ gar ꞌbe̱hñöhu̱ nꞌehe, gi ꞌyo̱thu̱ ri dömehu̱, ne njapꞌu̱ nuꞌmu̱ togo hinxi ñꞌemu̱i, da hñönga ár mhö Jö hantꞌahu̱ ri hogamꞌu̱ihu̱, hinge mahyoni gi zohu̱.
\p 
\v 2 Ho̱nse̱ da hyantꞌa ri hogamꞌu̱ihu̱ xintꞌaxi ne gi tsufu̱ Jö.
\p 
\v 3 Nuna ri ñhokihu̱, hinge xa gi hyoñhu̱ nöꞌö oxta mañö xa di thotho gi ñhoju̱. Yo xa gi ñho̱xu̱ ya hwe̱xkabo̱jö, ne hingi hyehu̱ ya he gi ñꞌexu̱.
\p 
\v 4 Hyoñhu̱ nöꞌö di ꞌñe mbo ri mu̱ihu̱. Nunar ñhokinu̱ hiñhamꞌu̱ da thege. Gi umba ri mu̱ihu̱ gi ꞌbu̱hu̱ nꞌar hogamꞌu̱i, ne gi ꞌyo̱thwu̱ ar ñho maꞌra. Gehnu̱ numañho Jö.
\p 
\v 5 Ngetho njapꞌu̱ mi ñhoka mahamꞌu̱ nuꞌu̱ ya tsi ꞌbe̱hñö mi ꞌbu̱ nꞌar mꞌu̱i xintꞌaxi. Ne mi to̱ꞌmba ár mfa̱tsꞌi Jö, mi o̱ta gatho nöꞌö mi xipa yá döme.
\p 
\v 6 Jangu ar Sara mi o̱ta ar Abra, ne mi embabi ár hmu. Ha nuꞌahu̱ xka ehu̱ di bo̱ni yá tꞌinxuꞌihu̱, nuꞌmu̱ gi ꞌyo̱thu̱ ar ñho ne hiñꞌotho te gi tsuhu̱.
\p 
\v 7 Di zoꞌahu̱pya nuꞌahu̱ gar dömehu̱, ꞌbu̱hwihu̱ ri ꞌbe̱hñöhu̱ gi pe̱ꞌsu̱ nꞌar döta mfödi, ne gi umfu̱ ar nsu di ꞌñepi, ngetho hintsꞌu̱ nze̱ye̱ yá tsꞌe̱di. Beñhu̱ gehnu̱ ri ñꞌowihu̱ gi hñöngwi mahye̱gi yá njöpi Jö, ne njapꞌu̱ hinte di ja te da kꞌaꞌsa da tꞌaꞌahu̱ nöꞌö gi a̱fu̱ Jö.
\s1 Hanja da mꞌu̱ gatho ya ku
\p 
\v 8 Hár ngötsꞌi di xiꞌahu̱ gi beñhu̱ nꞌadar mfeni, di ko ri mu̱ihu̱ gi mhöhu̱ ngu ya tsi ku, gi pe̱ꞌsu̱ ar nhwëki ne gi ntsixkwihu̱ gatho.
\p 
\v 9 Yo gi koꞌspabihu̱ yá ñöni togo o̱tꞌahu̱ ar tsꞌoki, ne hingi ntsa̱ntsꞌaniwi maꞌra. Nöꞌö gi ꞌyo̱thu̱, te̱twathohu̱ Jö, ngetho xi tsꞌoñꞌahu̱ da tꞌaꞌahu̱ ar njöpi.
\p 
\v 10 Ngetho ngu enga har Tꞌofo:
\q1 Nöꞌö togo ne da mö ár te, ne da hyanda ya hoga pa,
\q1 hinda hye̱ ár ne da mönga nöꞌö hingi ho,
\q1 ne hinda hye̱gi da mönga ya nhemhñö.
\q1 
\v 11 Dá hye̱ ar tsꞌoki ne da ꞌyo̱tꞌa nöꞌö xiñho.
\q1 Da hyonga ar hogamꞌu̱i, ne xta dini hinda hye̱gi.
\q1 
\v 12 Ngetho ar tsi Hmu handa xiñho nuꞌu̱ pe̱ꞌsa nꞌar mꞌu̱i xintꞌaxi,
\q1 ne o̱xtho to̱ꞌmi tema da ꞌya̱pabi.
\q1 Ne ꞌbu̱tho da umba yá mfe̱i nuꞌu̱ togo hingi o̱tꞌa xiñho nꞌehe.
\p 
\v 13 Ha nuꞌmu̱ gi o̱thu̱ nöꞌö xiñho, togo tsa̱ te da jaꞌahu̱ ꞌmu̱.
\p 
\v 14 Ne nuꞌmu̱ ja te da njaꞌahu̱ ngetho gi o̱thu̱ xiñho, nza̱thoꞌö. Yo gi jafu̱masu ne da piꞌahu̱, ne hingi tu ri mu̱ihu̱.
\p 
\v 15 Nöꞌö gi pe̱hu̱, nsundahu̱ Jö ar tsi Hmu ha ri mu̱ihu̱. Ne hyaxꞌmu̱ gi ꞌbu̱hu̱ xka ñhoju̱ gi thöthu̱, hingi ñꞌexu̱ ne di ꞌbe̱nga ntꞌekꞌei nuꞌu̱ togo a̱ñꞌahu̱ teme di bo̱nga ri ndo̱ꞌmihu̱ gi pe̱ꞌsu̱.
\p 
\v 16 ꞌBu̱hu̱ hinte di tsu̱ꞌa ri mfenihu̱. Ne njapꞌu̱ nuꞌu̱ ju̱sꞌahu̱ ri ꞌbedehu̱ enö gar tsꞌoktehu̱, da ꞌbe̱ yá tsa̱ xta nu hingi njapꞌu̱. Xta nuꞌahu̱ gi pe̱ꞌsu̱ nꞌar hogamꞌu̱i, ngetho gi ꞌbu̱hwihu̱ ar tsi Hmu Hesukristo.
\p 
\v 17 Xiñhoꞌö nuꞌmu̱ gi thohu̱ ya thogi ngetho gi o̱thu̱ nöꞌö xiñho, nuꞌmu̱ njapꞌu̱ ne ar tsi Hmu, hinge gi thohu̱ ya thogi ngetho gi o̱thu̱ ya tsꞌoki.
\p 
\v 18 Nunar tsi Hmu Hesukristo bi tho nꞌagitho ar ndöte, njapꞌu̱ bi hñöga ma tsꞌokihu̱. Ar hogajöꞌi bi unga ár te bi po̱kagihu̱ nuju̱ xta o̱thu̱ ya tsꞌoki, ne da zixkagihu̱ ma ga ꞌbu̱hwihu̱ Jö. Majöni bi du ár ndoꞌyo, ha nu ár hñö himbi du, po̱ntho bi mengi bi nte núꞌmu̱ mi nanga manꞌagi ár ndoꞌyo.
\p 
\v 19 Nunár hñö bi ma ba humbyá hmi nuꞌu̱ yá hñö ya jöꞌi bi jotꞌi.
\p 
\v 20 Nuꞌu̱ mahamꞌu̱ himbi ne bi ꞌyo̱de, hangu bi do̱ꞌmahmö Jö, gatho ya pa bi ziꞌspa ar Noe bi hyoka ar motsa. Himbi kꞌontꞌa nze̱ye̱ ya jöꞌi, ho̱nse̱ hñöto bi bongi nda jötꞌa har dehe.
\p 
\v 21 Nunar dehenu̱ bi ñuꞌsa ar ximha̱i, ñhe̱hwi ar xixthe nuya payu̱. Nunar xixthenu̱, hinge di nehu̱ ga xu̱ju̱ ma ndoꞌyohu̱. Gehnu̱ nꞌar ntꞌudi di uñhu̱ hár nthandi Jö hinte tsu̱ka ma mfenihu̱, ne xta mpo̱hu̱. Gathonu̱ xta höñhu̱ ngetho bi mengi bi nte ar tsi Hmu Hesukristo.
\p 
\v 22 Gehnu̱ mi wadi bi bo̱xa mhetsꞌi, bi hñuxa hár ñꞌe̱i Jö. Ne gatho ya e̱nxe̱, ya ndö ne ya tsꞌu̱tꞌwi o̱ta nöꞌö möñꞌö.
\c 4
\s1 Ngu yá hoga ꞌbe̱goꞌihu̱ Jö, jafu̱ da mpe̱ ya hogantꞌuni xi ꞌraꞌahu̱ Jö
\p 
\v 1 Ar tsi Hmu Hesukristo bi ze̱ta nuya thogiyu̱ hár ndoꞌyo, jange pe̱ꞌsu̱ nunar mfeninu̱ nꞌehe. Ngetho nuꞌu̱ togo xi tho ya u̱gi hár ndoꞌyo, xi ñꞌehwi ar tsꞌoki.
\p 
\v 2 Nuya pa xi ꞌñepꞌu̱ hinda mꞌu̱ ngu nese̱, te̱mtho yá tsꞌonhe ya meximha̱i. Nupya da ꞌyo̱tꞌa gatho ngu ne Jö.
\p 
\v 3 Hye̱hu̱pꞌu̱ nöꞌö ngi o̱thu̱ mi numañho nuꞌu̱ hingya gamfi. Nuꞌu̱ ꞌbe̱ngwi ya jöꞌi, te gatho neꞌu̱, xa ya nti, xa ne da ꞌbe̱ yá mfeni ha ya da̱ngo, ne ndönga ya tsita empꞌö, xa xi ntsꞌotho nöꞌö o̱tꞌu̱.
\p 
\v 4 Nuyu̱ ꞌyo̱tho hingi ñꞌowihu̱ ha yá tsꞌoꞌbe̱fi, ne theñꞌahu̱.
\p 
\v 5 Ha ma da da̱twa majöni nöꞌö togo xi ñhoki da umbyá mfe̱i nuꞌu̱ te, ne nuꞌu̱ xi du.
\p 
\v 6 Jange xi nsipabi ar hoga mhö nuꞌu̱ togo xi dupya, ne da tsa̱ da mꞌu̱ꞌu̱ ngu ar hñö di hñöxkwi Jö, mödi bi hñönga ar ndöte ngu ar njutꞌi ar tsꞌoki tho gatho ya jöꞌi.
\p 
\v 7 Nöꞌö ar pa da göxa xo̱ge, ꞌba̱pꞌu̱tho da zo̱ho̱. Jange hyanthu̱ xiñho tema gi pe̱hu̱, ne ndöꞌmhu̱ hingi tsa̱ya̱hu̱ gi zohu̱ Jö.
\p 
\v 8 Ne gi umba ri mu̱ihu̱ mꞌe̱tꞌo xa gi mhöhu̱ nꞌa ngu nꞌa, ngetho ar mhöte punga nze̱ye̱ ya tsꞌoki.
\p 
\v 9 Gi nethohu̱ gi uñhu̱ ar tsa̱ya̱ nꞌa ngu nꞌa.
\p 
\v 10 Ngu yá hoga ꞌbe̱goꞌihu̱ xi tꞌe̱ntꞌa ha ri ꞌye̱hu̱ nuya nze̱ye̱ ya hogantꞌuni unga Jö, jafu̱ da mpe̱ ha yá mꞌu̱i maꞌra ngu ar ntꞌuni xi nhwëkꞌahu̱.
\p 
\v 11 Nuꞌmu̱ ja nꞌa togo ñö, dá ñö ngu mönga ár mhö Jö. Ha nuꞌmu̱ ja nꞌa togo pe̱pa maꞌra, dá ꞌyo̱tꞌe ngu ár döta ár tsꞌe̱di Jö xi thembabi. Ne njapꞌu̱ gatho nöꞌö gi pe̱hu̱ da nsundabi Jö, ngetho gi pe̱fu̱ ar tsi Hmu Hesukristo. Jö ár me̱ti ar nsunda ne ar tsꞌu̱tꞌwi hiñhamꞌu̱ da götsꞌi. Dá njapꞌu̱.
\s1 Di thohu̱ ya thogi ngetho dar gamfihu̱
\p 
\v 12 Ma tsi hmöka kuhu̱, yo gi tu ri mu̱ihu̱ nuꞌmu̱ xta epꞌu̱ ya thogi, ne da zu̱ꞌahu̱ ngu nꞌar tsibi da tsa̱tꞌahu̱ ri ñꞌemu̱ihu̱. Yo ma gi ꞌyo̱hu̱ xta epꞌu̱ gathoyu̱.
\p 
\v 13 Nöꞌö gi ꞌyo̱thu̱, njohyahu̱ ngetho gi thohu̱ nꞌa tsi tu̱i ya u̱gi ngu bi tho ar tsi Hmu Hesukristo, ne núꞌmu̱ xta nheki ár nsunda xa ma gi njohyahu̱.
\p 
\v 14 Nuꞌmu̱ ntꞌu̱tsaꞌihu̱ ngetho gi te̱ñhu̱ ar tsi Hmu Hesukristo, xa nza̱thoꞌö, njapꞌu̱ nheki gi ꞌbu̱hwihu̱ ár Hñö Jö. Majöni nuꞌu̱ tsani, ha nuꞌahu̱ gi nsundabihu̱ ha ri mꞌu̱ihu̱.
\p 
\v 15 Yo ma gi thohu̱ ya thogi ngetho gar hyotehu̱, gar bëhu̱, gar tsꞌoktehu̱, wa gi ñꞌöxtehu̱ tengu yá mꞌu̱i maꞌra.
\p 
\v 16 Ha nuꞌmu̱ gi thohu̱ ya thogi ngetho xka ñꞌemu̱ihu̱, yo ma gi ntsa̱hu̱. Nsundabihu̱ Jö gi thohu̱yu̱.
\p 
\v 17 Ngetho bi zo̱ ar pa da nja ár mfe̱i Jö, ne ma da du̱ꞌma mꞌe̱tꞌo hár nijö. Ha nuꞌmu̱ xi ndu̱i xi gu̱tka ma guhu̱, tema ngötsꞌi to̱ꞌma nuꞌu̱ hinxi ñꞌemu̱i ár hoga mhö Jö.
\p 
\v 18 Ne enga har Tꞌofo nꞌehe:
\q1 Nuꞌmu̱ xa xi ñhembi da mpo̱ho̱ nꞌar hogajöꞌi,
\q1 habu̱ di gohmö nöꞌö hingi benga Jö, ne ar tsꞌokte ꞌmu̱.
\p 
\v 19 Jange nuꞌu̱ togo gi thohu̱ ya thogi ngu ne Jö, ꞌye̱ntꞌathohu̱ ri tehu̱ ha yá ꞌye̱ ar tsi Dada togo bi hyogagihu̱, ne xa gi umba ri mu̱ihu̱ gi ꞌyo̱thu̱ ar ñho.
\c 5
\s1 Sufu̱ yá tsi de̱ti Jö
\p 
\v 1 Di zo nuꞌu̱ ya ndö har nijö gi ꞌbu̱hwihu̱pꞌu̱. Di a̱pabiga dar ndöse̱ nꞌehe, ne da handwa yá u̱gi bi tho ar tsi Hmu Hesukristo, ne di to̱ꞌmi ga ꞌbu̱ꞌbenu̱ mhetsꞌi xta nheki ár nsunda.
\p 
\v 2 Suhu̱ ya tsi de̱ti gi ꞌbu̱hwihu̱pꞌu̱ yá me̱ti ar tsi Hmu. Yo gi o̱thu̱ ngetho njaꞌahu̱, go gi nese̱hu̱. Yo gi homfu̱ yá bojö, njohya gi suhu̱.
\p 
\v 3 Hingi ꞌyo̱thu̱ ndöta gi ne gi hyo̱maha̱ihu̱ nuꞌu̱ togo gi suhu̱. Nöꞌö gi ꞌyo̱thu̱, ꞌñuhu̱ nꞌar hogamꞌu̱i.
\p 
\v 4 Ne xta epꞌu̱ ar Döngama̱ꞌyo, ma gi hñöñhu̱ ar nthöhö nsunda hinda ma da thege.
\p 
\v 5 Mahye̱gi di xiꞌahu̱ nuꞌahu̱ gi bötsihu̱, ꞌyo̱thu̱ te da xiꞌahu̱ ya ndö har nijö. Gathoꞌihu̱ ñꞌo̱thu̱ nꞌa ngu nꞌa, ne di nhekitho ri hogamu̱ihu̱, ngetho:
\q1 Jö nto̱xkwi nuꞌu̱ ya ñꞌexte,
\q1 ne hwëkwa ár mfa̱tsꞌi nuꞌu̱ hingya ñꞌetsꞌi.
\p 
\v 6 Ntsꞌa̱ꞌmhu̱ hár nthandi Jö togo xa ja ár tsꞌe̱di, ne go da ꞌñesꞌahu̱ ri nsuhu̱ núꞌmu̱ xta zo̱nga ar pa xi beñꞌö.
\p 
\v 7 Tsokwabihu̱ Jö gatho ri dumu̱ihu̱, nöꞌö hingi tsa̱ya̱ suꞌahu̱.
\p 
\v 8 Zo̱tꞌa xiñho ri da̱hu̱ ne yo gi öthu̱, ngetho ri ñꞌu̱nihu̱ ar tsꞌondöhi ꞌyo ngu nꞌar ꞌmuhu honi togo da ꞌye̱ntꞌa ár ne.
\p 
\v 9 No̱xju̱ gi to̱ꞌspabihu̱ xi nze̱ ri jamfihu̱. Gi pöhu̱ nuya thogiyu̱, bí thopya nze̱ye̱ ya ku xo̱ge ár nxidi ar ximha̱i.
\p 
\v 10 Ne Jö togo ár me̱ti ar nhwëki, bi zokagihu̱ ga ꞌbu̱hu̱ hár nsunda hingi thege, ngetho di te̱ñhu̱ ar tsi Hmu Hesukristo. Nu xta tho ꞌra ya tsi pa gi thohu̱ ya thogi, gese̱ꞌö da ma̱xꞌahu̱ gi ꞌbu̱hu̱ nꞌar mꞌu̱i xintꞌaxi, da ze̱tꞌa ri jamfihu̱, da ꞌraꞌahu̱ ar tsꞌe̱di, ne da zixꞌahu̱ xiñho hár ꞌñuꞌö.
\p 
\v 11 Jö go ár me̱tiꞌö ar nsunda ne ar tsꞌu̱tꞌwi hiñhamꞌu̱ da götsꞌi. Dá njapꞌu̱.
\s1 Ya ngöxanze̱ngwa
\p 
\v 12 Di pe̱ñꞌahu̱ nunar he̱ꞌminu̱ da hñösꞌahu̱ ar ku Silbano, togo di handi nꞌar ku o̱ta xiñho ar tsi Hmu. Xta otꞌahu̱ nꞌa tsi tu̱i, di ne ga hupꞌa ri mu̱ihu̱, ne di da̱majöni gehnu̱ ár nhwëki Jö nöꞌö gi te̱ñhu̱.
\p 
\v 13 Ar nijö ꞌbu̱ Mbabilonia, mahye̱gi nguꞌahu̱ xi hwahna Jö, pe̱ñꞌahu̱ ar nze̱ngwa nꞌehe. Ar ku Mörko togo po̱ntho ma tꞌu̱ ze̱ngwaꞌihu̱ nꞌehe.
\p 
\v 14 Nze̱ngwahu̱ nꞌa ngu nꞌa xa gi mhötehu̱. Gi ꞌbu̱hu̱ nꞌar hogamꞌu̱i gatho nuꞌahu̱ xka nthe̱xu̱ ar tsi Hmu Hesukristo. Dá njapꞌu̱.
