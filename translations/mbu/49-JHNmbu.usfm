\id JHN - Mbula
\h Yohana
\toc3 Yoh
\toc2 Yohana
\toc1 Cau amsǝban a nê mala Yohana
\mt2 Cau amsǝban a nê mala
\mt1 YOHANA
\imt1 Mǝncau
\im Mwashat atà alaggana mala Yesu, yì Yohana ka, nda gilǝ mǝnia yì malǝmce ka. À kǝ sǝni kǝla à gilǝ mǝnia yì Cau Amsǝban ngga a pǝlǝa 85 anzǝm ɓǝlban mala Yesu.
\ip \bk Yì Cau Amsǝban a nê mala Yohana\bk* ka lǝmdǝa sǝm ama Yesu nda Cau mala Ɓakuli, yì Cau mǝnana te pà nǝ̀ mal raka, mǝnana <<yi duk ɓwamǝpǝndǝe sǝ do aɓalǝ sǝm ngga.>> (\xt Yoh 1:14\xt*) À gilǝì ace mǝnana amǝ ɓallè ka ɓǝa earnǝi ama Yesu nda Mǝ'amsǝban mǝnana à pacau ace ka, yì Muna mala Ɓakuli, sǝ ɗǝm ngga nǝ́ paɓamuru malea a baní ka ɓǝà kum yilǝmu (\xt Yoh 20:31.\xt*)
\ip \bk Yohana \bk* kǝ bangŋi nǝ rǝcandǝa ama ɓoro mala yilǝmu mǝnana málá male pà kàm raka à kǝ kumi nǝban Kǝrǝsti, yì ɓoro mǝnana kǝ tite ado sǝ nǝ̀ ngga yiu aban aɓwana mǝnana à earnǝ Yesu ama nda njargula, andǝ mǝsǝcau, andǝ yilǝmu ka. \bk Yohana\bk* pak túró nǝ agir mala koya pwari mǝnana aɓwana súrǝ̀ia pepe ka ace lǝmdǝ mǝsǝcau mala agir ɓá bangŋo, agir kǝla <<mur>>, <<bǝredi ko girlina>>, <<tǎlaban>>, <<yalgir andǝ anzur male>>, <<kun-nda>>, <<njargula>>, <<nggun anap andǝ aɓǝle>>, sǝ <<yilǝmu.>>
\iot Agir mǝnana aɓalǝi ka
\io1 Tita cau\ior 1:1-18\ior*
\io1 Yohana Mǝbatisǝma andǝ alaggana mǝdǝmbe mala Yesu\ior 1:19-51\ior*
\io1 Túró mala Yesu a ban aɓwana\ior 2:1--12:50\ior*
\io1 Masǝlǝata anonggio mala Yesu arǝ ban mala Urǝshalima sǝ aɓalǝi\ior 13:1--19:42\ior*
\io1 Lo ɓembe mala Mǝtalabangŋo andǝ lǝmdǝrǝu male arǝ anjar ɗàngɗáng\ior 20:1-31\ior*
\io1 Masǝlǝata cau: Yesu lǝmdǝ rǝì ɗǝm a Galili\ior 21:1-25\ior*
\c 1
\s1 Cau duk ɓwa
\q1 
\v 1 Kaniama Ɓakuli nǝ̀
\q2 pusǝ ɓanza ka,
\q1 Cau ni nda kam,
\q2 sǝ mǝno yì Cau ka
\q1 à nda tàrǝia andǝ Ɓakuli;
\q2 sǝ yì, yì Cau ka Ɓakuli na.
\q1 
\v 2 A tite ka à nda
\q2 andǝ Ɓakuli.
\q1 
\v 3 Nǝ yi sǝ Ɓakuli pusǝ agir kat.
\q1 Kǝgìr pà kàm mwashat
\q2 mana à pusǝì mǝnana
\q2 nǝ yi sǝ à pusǝì raka.
\q1 
\v 4 Yì nda tǝr yilǝmu,
\q2 sǝ mǝnia yì yilǝmu
\q1 ka yiu nǝ tǎlaban
\q2 aban ɓwapǝndǝa.
\q1 
\v 5 Sǝ yì tǎlaban ngga
\q2 kǝ ta aɓa pǝndǝa
\q1 sǝ pǝndǝa ka gandǝ
\q2 bwalte ɗàng!\f + \fr 1:5 \fq sǝ pǝndǝa ka gandǝ bwalte ɗàng: \ft Ko <<sǝ pǝndǝa ka pà nǝ̀ gandǝ limge ɗang.>>\f*
\q1 
\v 6 Ɓè ɓwa yiu,
\q2 mǝ'njar mǝnana
\q1 Ɓakuli túrí ka,
\q2 lùllǝì ama Yohana.\f + \fr 1:6 \ft Ɓalli gbal aɓa: \xt Mat 3:1; Mar 1:4; Luk 3:1,2\xt*\ft .\f*
\q1 
\v 7 Yiu yi ne ɓwapǝndǝa
\q2 cau amur mǝnia
\q1 yì tǎlaban ngga,
\q2 ace mǝnana ɓǝ̀
\q1 ɓwapǝndǝa kat ok
\q2 mǝnia yì cau ka, ɓǝ̀ é.
\q1 
\v 8 Yohana nǝ ɓamúrì ka
\q2 nda tǎlabanì ɗang;
\q1 yì ka, yiu ace nacau
\q2 amur tǎlabanì.
\q1 
\v 9 Tǎlaban mǝ'mǝsǝcau nì,
\q2 mǝnana kǝ ta aban
\q1 ɓwapǝndǝa kat ka,
\q2 ndo kǝ yiu a ɓanza ka.
\q1 
\v 10 Yì Cau ka nda a ɓanza,
\q2 sǝ kat andǝ amani ama
\q1 nǝ yi sǝ à pusǝ ɓanza ka,
\q2 ɓanza súrǝì ɗàng.
\q1 
\v 11 Yiu aban aɓwana
\q2 mǝnana amale na ka,
\q2 sǝ amale é ɗàng.
\q1 
\v 12 Sǝ aɓwana mǝnana kat à é,
\q2 à pa ɓamuria a baní ka,
\q1 pània wia rǝcandǝa
\q2 ɓǝà duk amuna
\q1 mala Ɓakuli.
\q1 
\v 13 Ɓǝlban malea ka,
\q2 mala nkila na
\q1 andǝ nggūrǝu ɗang.
\q1 Pa aɓa kpapi
\q2 mala ɓwama andǝ
\q2 ɓwabura ɗang.
\q1 Mǝnia ka pe mala Ɓakuli na.
\q1 
\v 14 Mǝnia yì Cau ka
\q1 yi duk ɓwamǝpǝndǝe,
\q2 sǝ yi duk zuku aɓalǝ sǝm.
\q1 Sǝm sǝna gulo male,
\q2 gulo mala kǝ̀ Muna
\q1 mwashat ɓǝ̀rɓǝ̀r, mana pur
\q2 nǝban Tárrí Ɓakuli ka,
\q1 lùmsǝo nǝ ɓwamuru
\q2 andǝ mǝsǝcau.
\p 
\v 15 Yohana ne aɓwana cau amurí nǝ giu mǝcandǝe ama, <<Mǝnia ka nda ɓwa mǝnana ǝn na wun cau amurí nǝma nda ban yiu a nzǝmam ngga, sǝ yì ka, kútiǎm nǝ gulo, acemǝnana yì ka, ndakam ɗiɗyal sǝ à yì ɓǝ̀lám.>>
\v 16 Aɓa ɓwamuru andǝ mǝnbu male sǝ tsǝka sǝm bu kat, kǝ pa sǝm agir mǝɓoarne a nzǝmarǝia.
\v 17 Ɓakuli pa sǝm Nggurcau nǝ bu Musa, sǝ nǝ bu Yesu Kǝrǝsti sǝ pa sǝm ɓwamuru andǝ mǝsǝcau.
\v 18 Kǝ ɓwa sǝn ma Ɓakuli àkǝ̀ pwari ɗàng, she kǝ Muni mǝnana à nda mwashat andǝ yi, sǝ nda a nkanggari ka. Yì nda tsǝa sǝ sǝm súrǝ̀ Tárrí ka.
\s1 Yohana Mǝbatisǝma nda Kǝrǝsti ɗàng
\r (Matiu 3:1-12; Markus 1:1-18; Luka 3:1-18)
\p 
\v 19 Aɓwana-mǝgule mala amǝ Yahudi mǝnana a Urǝshalima ka à túr apǝris andǝ Amǝ'Lawi ɓǝà kya ɗì Yohana ama, yì ka, nda yana le?
\p 
\v 20 Yohana sǝmbǝrǝia wia kǝgìr ɗàng, banggia wia mǝsǝcau ama, <<Mǝ nda Kǝrǝsti\f + \fr 1:20 \fq Kǝrǝsti (nǝ kún Gǝrik) ko Mezaya (nǝ kún Ibǝru) ka ɓālǝi nda: \ft Ɓwa mǝnana à ɗārǝì wi mùrú olif amurí, mǝnana lǝmdǝ ama Ɓakuli tsǝngŋǝni a buno-gulo andǝ rǝcandǝa ka.\f* ɗàng.>>
\p 
\v 21 À ɗì ama, <<Sǝ we ka a nda yana? A nda Iliya le?>>\f + \fr 1:21 \ft Ɓalli gbal aɓa: \xt Nggur 18:15; Mal 4:5\xt*\ft .\f* Yohana earia wia ama, <<Awo, mǝ nda yì ɗàng.>> Sǝ à ɗì ama, <<A nda mǝɓangnǝa mala Ɓakuli mǝnana sǝm nggǝ kundǝmuri ka le?>> Earia wia ama, <<Awo.>>
\p 
\v 22 A masǝlǝate ka à ɗì ama, <<Na sǝm cau mǝnana ɓǝ̀ sǝm nyesǝi aɓwana mǝnana à túr sǝm ngga. A kǝ twali ɓamuro ama a nda yana?>>
\p 
\v 23 Yohana earia wia nǝ cau mala Ishaya mǝɓangnǝa mala Ɓakuli ama, <<Mǝ nda gìu mǝnana kǝ hama a ɓabondo ka, ama, <Wu tsǝk njargula ɓǝ cam kporong ace Mǝtalabangŋo.> >>\f + \fr 1:23 \ft Ɓalli gbal aɓa: \xt Isha 40:3\xt*\ft .\f*
\p 
\v 24 Aɓea amǝ Farisi mǝnana à túriá ka,
\v 25 à ɗì Yohana ama, <<Sǝ ɓǝ̀ a nda Kǝrǝsti,\f + \fr 1:25 \ft Sǝn cau amur Kǝrǝsti a \fv 1:20.\f* ko Iliya, ko mǝno yì mǝɓangnǝa mala Ɓakuli raka, palang sǝ a kǝ pakki aɓwana batisǝma?>>
\p 
\v 26 Yohana earia wia ama, <<Ən nggǝ pakki aɓwana batisǝma nǝ mùr, sǝ ɓeɓwa nda came aɓalǝ wun mǝnana wu súrǝì raka,
\v 27 yì ka, nda ɓwa mǝnana kǝ yiu a tam tù ka, ǝn kārǝa mǝ nǝ panzǝ anggur-nkura male ka ɗàng.>>
\p 
\v 28 Mǝnia yì gir ka à pè a Betani, a nkaring Nggeasala Jodan, àkǝ̀ ban mǝnana Yohana pakkiyi batisǝma kam ngga.
\s1 Yesu nda Mǝgam mala Ɓakuli
\p 
\v 29 Ɓè ban fana ka, Yohana sǝn Yesu aban yiu nǝ bani, sǝ pǝlǝa na ama, <<Wu sǝn Mǝgam mala Ɓakuli, mǝnana twalkiyi cauɓikea mala ɓanza ka!
\v 30 Mǝnia ka nda ɓwa mǝnana ǝn na ce ama, <Ɓè ɓwa nda kǝ yiu atàm ngga. Yì ka, kútiǎm nǝ gulo, acemǝnana yì ka, ndakam ɗiɗyal sǝ à yì ɓǝlam.>
\v 31 Nggearǝ mim ngga ǝn súrǝì ɗiɗyal ɗang, sǝ tǝr yiu mem mǝnana ǝn nggǝ pakki aɓwana batisǝma nǝ mùr ka nda ace mǝnana ɓǝà lǝmdǝì amǝ Isǝrayila rǝì ka.>>
\p 
\v 32 Pǝlǝa Yohana bang gìr mǝnana súrǝì amurí ka ani: <<Ən sǝn Bangŋo mala Ɓakuli kǝla kutu, sulǝ nǝ kuli yi do amurí.
\v 33 Ɓǝ́ pà mǝ nǝ súrǝì ɗàng, ɓǝ̀ Ɓakuli mǝnana tasǝam ama ɓǝ̀n yi pakki aɓwana batisǝma nǝ múr ka nda nam raka. Nam ama, <Ɓwa mǝnana a sǝni Bangŋo mem sulǝo yi do amurí ka, nda ɓwa mǝnana nǝ̀ pakki aɓwana batisǝma nǝ Bangŋo Mǝfele ka.>
\v 34 Ən sǝnǝni sǝ ǝn nggǝ bangcau amurí ama, yì ka, nda Muna mala Ɓakuli.>>
\s1 Alaggana mana Yesu tita tunǝia ka
\p 
\v 35 Ɓè ban fana ka, Yohana nda kano ɗǝm andǝ aɓea alaggana male ɓari.
\v 36 Lang nǝ̀ sǝn Yesu aban kutio ka, na ama, <<Wu sǝn Mǝgam mala Ɓakuli!>>
\p 
\v 37 Lang alaggana mǝnia ɓari à ongŋǝni náná anggo ka, kara à o atà Yesu.
\v 38 Yesu nǝ̀ pǝlǝ rǝì ka, kara sǝnia aban yiu atè, sǝ ɗia ama, \wj <<Mana wu earki ce?>>\wj*
\p À eare ama, <<Rabbi a ya ban sǝ a pa?>> (Rabbi ka ɓālǝi nda Malǝm.)
\p 
\v 39 Yesu earia wia ama, \wj <<Wu yiu wu yi sǝni.>>\wj*
\p À pǝlǝa à wario à kya sǝn ban-do male. Sǝ à kya do atè bà du. Anggo ka bu-pwari ine nǝ pwarikpǝra na.
\p 
\v 40 Ɓè ɓwa mwashat atà mǝnia yì aɓwana ɓari mǝnana à ok cau mǝnana Yohana na ka nda Andǝru, mǝ'eam Shiman Bitǝrus.
\v 41 Andǝru pǝlǝa kum mǝ'eambi Shiman, sǝ ne wi ama, <<Sǝm kumǝna Mezaya (Tǝr Mezaya nda Kǝrǝsti, Mǝ'amsǝban mǝnana Ɓakuli bang ama nǝ̀ tasǝi ka.)>>
\v 42 Sǝ yiu nǝ Shiman aban Yesu.
\p Yesu sǝni kyap-kyap, sǝ na ama, \wj <<A nda Shiman muna mala Yohana. À nǝ̀ tunǝo ama, Kefas.>>\wj* (Tǝr Kefas nda Bitǝrus, ɓālǝi ama, Tali.)
\s1 Yesu tunǝ Filip andǝ Nataniyel
\p 
\v 43 Ɓè ban fana ka, Yesu twali a ɓabumi ama nǝ̀ o a Galili. Yi kum Filip sǝ ne wi ama, \wj <<Yiu atàm.>>\wj*
\p 
\v 44 Filip ka ɓwa Beseda na, la mala Andǝru andǝ Bitǝrus.
\v 45 Filip alta Nataniyel yi kumi sǝ ne wi ama, <<Sǝm kumǝna ɓwa mǝnana Musa gilǝgir amurí aɓa malǝmce Nggurcau mala Musa, andǝ mǝnana à gilǝa aɓa malǝmce mala amǝ'ɓangnǝa mala Ɓakuli ka, yì Yesu ɓwa Nazarat, muna mala Yisǝfu.>>
\p 
\v 46 Nataniyel na ama, <<A Nazarat! Kǝ gir mǝɓoarne nǝ̀ pur a Nazarat gbal?>> Filip ne wi ama, <<Yiu sǝni.>>
\p 
\v 47 Lang Yesu sǝn Nataniyel aban yiu ka, nacau amurí ama, \wj <<Mǝnia ka ɓwa Isǝrayila mǝɓafoe na, mǝnana pànǝ nyir arǝì raka.>>\wj*
\p 
\v 48 Nataniyel ɗì Yesu ama, <<A pak lang sǝ a súrǝàm?>>
\p Yesu eari wi ama, \wj <<Mǝnana a nda a tǝta nggun vwari ka, ǝn angŋa dǝmba ǝn sǝnǝ no, sǝ Filip tunǝo.>>\wj*
\p 
\v 49 Pǝlǝa Nataniyel ne Yesu ama, <<Rabbi, a nda Muna mala Ɓakuli! A nda Murǝm mala amǝ Isǝrayila!>>
\p 
\v 50 Yesu ne Nataniyel ama, \wj <<A earnǝ mim acemǝnana ǝn banggo nǝma, ǝn sǝno a tǝta nggun vwari ka le? A nǝ sǝn agir mǝgulke mǝnana à kútì man ngga.>>\wj*
\v 51 Yesu nyare nea wia ama, \wj <<Ən nggǝ na wun mǝsǝcau, wun nǝ̀ sǝn kùli nǝ mǝnna, andǝ amǝturonjar mala Ɓakuli aban eauwe andǝ sulǝo amur Muna mala Ɓwa.>>\wj*\f + \fr 1:51 \ft Ɓalli gbal aɓa: \xt Tite 28:12\xt*\ft .\f*
\c 2
\s1 Yesu tsǝk mùr pǝlǝ // mùr-ɓǝlanggun anap
\p 
\v 1 A tàruià nongŋo ka, à ndanǝ isǝban a Kana a nzali Galili, sǝ nggea Yesu ndakam abanì.
\v 2 À tunǝ Yesu andǝ alaggana male aban isǝbanì.
\v 3 À nda ɓá pakkiɗire ka, mùr-ɓǝlanggun anap málá a rǝia.\fig Ɓǝlanggun anap|alt="Fruit of the vine" src="hk00111c.tif" size="col" loc="JHN 2:3" copy="Horace Knowles" ref="2:3"\fig* Nggea Yesu yi ne wi ama, <<Mùr ɓǝlanggun anap malea malǝna.>>
\p 
\v 4 Pǝlǝa Yesu eari wi ama, \wj <<Nnâ, palang sǝ a oasǝam aɓa ce? Bu-pwari mala lǝmdǝrǝu mem malaká karǝ peatu ɗàng.>>\wj*
\p 
\v 5 Nggea Yesu ne amǝ gau girlina ama, <<Wu pàk gìr mǝnana kat bangga wun ngga.>>
\p 
\v 6 Àkǝ̀ banì ka, aganggǝlang mǝnana à kwária aɓa tali ka à ndakam, yia tongno-nong-mwashat; amǝnana amǝ Yahudi kǝ soak mùr aɓalǝia à kǝ lákkína rǝia nǝi andǝ agir ace peri a ɓadǝm Ɓakuli ka. Ko mǝ ye ka kǝ twal amunabang-mùr lumi-ɓari ko lumi-tàrú.
\p 
\v 7 Yesu ne amǝ gau girlina ama, \wj <<Wu to mùr wu lumsǝki aganggǝlang.>>\wj* Sǝ à lumsǝkia kat nǝ mur.
\p 
\v 8 Sǝ nea wia ama, \wj <<Adyan ngga wu ɗàrǝa wu kya pe ɓwamǝgule mala pakkiɗire isǝban.>>\wj* Pǝlǝa à ɗàrǝa à wari wi nǝi.
\v 9 Sǝ ɓwamǝgule mala pakkiɗire isǝban ok mùr mǝnana à nyesǝi pǝlǝna mùr-ɓǝlanggun anap ka. Sǝ yì ka, súrǝ̀ ban mǝnana à pusǝ mǝnia yì mùr-ɓǝlanggun anap kàm ngga ɗàng (sǝ amǝ gau girlina mǝnana à ɗàrǝ́ mùr nì ka à sǝlǝna). Sǝ pǝlǝa tunǝ bura-māfela a giriban.
\v 10 Sǝ na ama, <<Aɓwana pak ka à kǝ yinǝ mùr-ɓǝlanggun anap mǝɓoarne a dǝmba, ɓǝ̀ abǝri nùna karǝnia ka, sǝ à kǝ yiu nǝ mǝnana twal tè ka; sǝ mò ka a tsǝk mǝɓoarne a nzǝ́mò!>>
\p 
\v 11 Gir'ndǝliki mǝnia Yesu pè a Kana, a nzali Galili ka, nda mǝdǝmbe mala agir-ndali male mǝnana lǝmdǝ gulo male ka. Sǝ alaggana male sǝni à pa ɓamuria a baní.
\p 
\v 12 Anzǝm man ngga, Yesu andǝ ngge andǝ amǝ'eambi andǝ alaggana male o a Kapanahum sǝ à kya nonggi kam zuku.
\s1 Yesu pǝr amǝ kúrkúró a // Ndàmǝgule mala Ɓakuli
\r (Matiu 21:12-13; Markus 11:15-17; Luka 19:45-46)
\p 
\v 13 Lang pwari Lamsan Yàlîmurû mala amǝ Yahudi gbashìnà ka, Yesu o a Urǝshalima.\f + \fr 2:13 \ft Ɓalli gbal aɓa: \xt Pur 12:1-27\xt*\ft .\f*
\v 14 Kya kum amǝ makki andá, andǝ anzur andǝ akutu, andǝ aɓwana mǝnana à dumǝna nǝ do aban nggaɗi boalo ka, aɓa Ndàmǝgule mala Ɓakuli.
\v 15 Pǝlǝa Yesu peau nkamso nǝ nggúr sǝ pǝria kat, andǝ anzur, andǝ andá, ɓǝà purî ɓá Ndàmǝgule mala Ɓakuli. Sǝ ndǝlǝkí agir, mesǝki amǝsǝ-boalo mala amǝ nggaɗi boalo.
\v 16 Sǝ ne amǝ makki akutu ama, \wj <<Wu pusǝ agir mǝnia ka aban man! Wu kǝa nyesǝ Ɓala mala Tárrám ɓǝ̀ duk limo ɗang!>>\wj*
\p 
\v 17 Sǝ ɓalǝ alaggana male kasǝa arǝ cau mǝnana Malǝmce na ama, <<Rǝɓǝla mem arǝ Ɓala mo we Ɓakuli ka, nǝ̀ earke a ɓalǝam kǝla bǝsa.>>\f + \fr 2:17 \ft Ɓalli gbal aɓa: \xt Ang 69:9\xt*\ft .\f*
\p 
\v 18 Aɓwana-mǝgule mala amǝ Yahudi ɗì Yesu ama, <<Ya gir'ndǝlǝki na ado awu nǝ pa, mǝnana nǝ̀ lǝmdǝa sǝm ama, Ɓakuli pano rǝcandǝa mala pak mǝnia yì gir ka?>>
\p 
\v 19 Yesu earia wia ama, \wj <<Wu arki man yì Ndàmǝgule mala Ɓakuli ka, sǝ aɓa nongŋo tàrú ka mǝ nǝ loasǝi ɗǝm.>>\wj*\f + \fr 2:19 \ft Ɓalli gbal aɓa: \xt Mat 26:61; Mat 27:40; Mar 14:58; Mar 15:29\xt*\ft .\f*
\p 
\v 20 Pǝlǝa amǝ Yahudi ne wi ama, <<Ndàmǝgule mala Ɓakuli mǝnana twal amǝɓa pǝlǝa lumi-ine bwamdǝ tongno-nong-mwashat sǝ à ɓè ka, a na ama awu nǝ ɓè aɓa nongŋo tàrú?>>
\p 
\v 21 Sǝ Ndàmǝgule mala Ɓakuli mǝnana Yesu nakiyi ce ka, nda nggūrǝì.
\v 22 Anzǝm mǝnana Yesu longŋǝni ɓembe ka, sǝ ɓalǝ alaggana male kasǝa ama, Yesu nania wia. Pǝlǝa à earnǝ Malǝmce andǝ acau mǝnana Yesu nea wia ka.
\s1 Yesu súrǝ̀ ɓabum ɓwapǝndǝa
\p 
\v 23 Mǝnana Yesu nda a Urǝshalima a pwari Lamsan Yàlîmurû ka, aɓwana pas à sǝn agir-ndǝlǝki mǝnana pea ka, pǝlǝa à pà ɓamuria a baní.
\v 24 Sǝ Yesu ka earnǝia ɗàng, acemǝnana súrǝ́nà rǝ ɓwapǝndǝa kat.
\v 25 Yesu pà aban alte ɓǝ̀ kǝɓwa ɓǝ̀ ne wi cau amur ɓwapǝndǝa ɗàng, acemǝnana yì nǝ ɓamúrì ka súrǝ́nà rǝ ɓabum ɓwapǝndǝa.
\c 3
\s1 Yesu bǝ́lì Nikodimus ɓá ɓaria ɓǝlban
\p 
\v 1 Ɓè ɓwa ndakam atà aɓwana-mǝgule, amǝ kùrcau mala amǝ Yahudi, mǝnana lùllǝì ama Nikodimus ka. Nda aɓalǝ amǝ Farisi.
\v 2 Ɓwabura man yiu aban Yesu nǝ dú, sǝ yi ne wi ama, <<Malǝm, sǝm sǝlǝna ama a nda mǝkànìgìr mǝnana Ɓakuli túrí ka. Kǝ ɓwa pà kàm nǝ̀ gandǝ pakki agir-ndǝlǝki mǝnana a pakkiyi ka ɗàng, yi mǝnana ɓǝ̀ Ɓakuli pa atè raka.>>
\p 
\v 3 Yesu eari wi ama, \wj <<Mǝ nda ban nô mǝsǝcau, ɓǝà ɓǝsǝlǝ ɓǝl ɓwa raka, pà nǝ̀ kutio aɓa domurǝm mala Ɓakuli ɗang.>>\wj*
\p 
\v 4 Nikodimus ɗiban ama, <<Lang sǝ à nǝ̀ ɓǝsǝlǝ ɓǝl ɓwa mǝnana gulna ka? Nǝ̀ kútí a bum ngge ɗǝm sǝ à nǝ̀ ɓǝsǝlǝ ɓǝle lè?>>
\p 
\v 5 Yesu ne wi ama, \wj <<Mǝ nda ban nô mǝsǝcau, kǝɓwa pà nǝ̀ kutio aɓa domurǝm mala Ɓakuli ɗang, she ɓǝà ɓǝlǝni nǝ mùr andǝ Bangŋo mala Ɓakuli ka.\wj*
\v 6 \wj Tárrú andǝ nggeau à nda à ɓǝlkiyi ɓwapǝndǝa ka, sǝ ɓǝlban ɓá Bangŋo ka, túró mala Bangŋo mala Ɓakuli na.\wj*
\v 7 \wj Kǝa ndali nǝ cau mǝnana ǝn banggo nǝma, <Dumǝna púp à nǝ̀ basǝ ɓǝl wun ngga> ɗàng.\wj*
\v 8 \wj Gung kǝ ɓua kǝ o aban mǝnana earce nǝ̀ ká kàm ngga. Wu kǝ ok gǝshi, sǝ wu súrǝ̀ ban mǝnana purkiyi kam andǝ ban mǝnana kákiyi kam ngga ɗàng. Anggo sǝ ɓwa mǝnana à basǝ ɓǝle aɓa Bangŋo mala Ɓakuli ka pa.>>\wj*
\p 
\v 9 Nikodimus ɗì ama, <<Lang sǝ mǝnia yì ɓǝlban ngga nǝ̀ gandǝ pa?>>
\p 
\v 10 Yesu pǝlǝa eari wi ama, \wj <<Nggearǝ we ka a nda ɓwamǝgule aɓa kànìgìr a nzali Isǝrayila, sǝ a súrǝ̀ mǝnia yì gìr ka ɗàng?\wj*
\v 11 \wj Mǝ nda ban nô mǝsǝcau, gìr mǝnana sǝm súrǝì, andǝ mǝnana sǝm sǝn ngga, nda sǝm nakiyia wun ce ka. Kat andǝ amani ka wu ɓinǝ ak cau mǝnana sǝm nggǝ na wun ngga.\wj*
\v 12 \wj Ən na wun cau mala agir mǝnana a ɓanza man ngga, sǝ wu earnǝ mim ɗang, lang sǝ wun nǝ̀ earnǝ mim yì mǝnana ɓǝ̀ ǝn na wun cau mala agir mǝnana a kùli ka?\wj*
\v 13 \wj Kǝ ɓwa malaká eau a kùli ɗang, she kǝ yì mǝnana sulǝ nǝ kuli ka, yì Muna mala Ɓwa, mǝnana nda a kùli ka.\wj*
\p 
\v 14 \wj <<Kǝla mǝnana Musa loasǝ n'yau amur gara a ɓabondo ka, anggo sǝ dumǝna púp à nǝ̀ loasǝ Muna mala Ɓwa a kùli,\wj*\f + \fr 3:14 \ft Ɓalli gbal aɓa: \xt Ɓal 21:9\xt*\ft .\f*
\v 15 \wj acemǝnana koya ɓwa mǝnana kat pa ɓamúrì a baní ka ɓǝ̀ kǝa kìɗìkì ɗàng, yì ka ɓǝ̀ kum yilǝmu mǝnana málá male pà kàm raka.\wj*
\p 
\v 16 \wj <<Ɓakuli ka earce ɓanza kǝ̀rkǝ́r, sǝ yi pâ kǝ̀ Muna male mwashat ace mǝnana ɓwa mana kat pà ɓamúrì a baní ka ɓǝ̀ kǝa kìɗìkì ɓǝ̀ ueɓà ɗàng, ɓǝ̀ kum yilǝmu mǝnana málá male pà kàm raka.\wj*
\v 17 \wj Ɓakuli tasǝ Muni ɓǝ̀ yì ɓashì ɓanza ɗàng, tasǝì ɓǝ̀ yì amsǝ ɓanza.\wj*
\p 
\v 18 \wj <<Ɓwa mǝnana kat pà ɓamúrì aban Muna mala Ɓakuli ka, pà aɓata ɓashi ɗàng. Sǝ ɓwa mǝnana kat ɓinǝ pà ɓamúrì ka, à angŋa dǝmba à kasǝna ɓashi ɓǝ̀ sulǝo amurí, acemǝnana ɓinǝ pà ɓamúrì aban Muna mwashat ɓǝ̀rɓǝ̀r mala Ɓakuli ka.\wj*
\v 19 \wj Tǝ́r ɓashi mala Ɓakuli ka nda mǝnana ama, tǎlaban yiu a ɓanza, sǝ ɓwapǝndǝa earce pǝndǝa kútì tǎlaban, acemǝnana atúró malea ka amǝɓealɓike na.\wj*
\v 20 \wj Ɓwa mǝnana kat kǝ pak gìr mǝɓike ka, kǝ ginǝ tǎlaban, sǝ pà nǝ̀ yiu aban tǎlaban ɗang, ace mǝnana ɓǝ̀ tǎlaban ɓǝ̀ kǝa lǝmdǝ atúró ɓealɓikea male ɗàng.\wj*
\v 21 \wj Sǝ ɓwa mǝnana kǝ pak gìr aɓa mǝsǝcau ka, kǝ yiu aban tǎlaban, ace mǝnana ɓǝ̀ tǎlaban lǝmdǝ atúró male, mǝnana pea nǝ́ ɓanggi Ɓakuli ka.>>\wj*
\s1 Cau mana Yohana Mǝbatisǝma // bang amur Yesu ka
\p 
\v 22 Anzǝm man ngga, Yesu andǝ alaggana male nying Urǝshalima sǝ à o arǝ aɓea muna-là aɓa bu-nzali Yahudi. À kya pakkia anonggio kam, aban pakki aɓwana batisǝma.
\v 23 \f + \fr 3:23 \ft Ɓalli gbal aɓa: \xt Mat 14:3,4; Mar 6:17,18; Luk 3:19,20\xt*\ft .\f* Yohana gbal ka nda aban pak batisǝma a Ainon mǝnana a ban Salim ngga, acemǝnana mùr nda abanì kpǝm. Ɓwapǝndǝa camarǝ yiu a baní, sǝ kǝ pakkia wia batisǝma.
\v 24 (Anggo ka à malaká oasǝ Yohana a ndàkurban peatu ɗàng.)
\p 
\v 25 Aɓea alaggana mala Yohana andǝ ɓeɓwa Yahudi, à lo makgìr amur kúncau mala lákkí rǝu andǝ lákkí agir ace peri aban Ɓakuli.
\v 26 Sǝ alaggana mala Yohana yiu a baní à yì ne wi ama, <<Rabbi, ɓālǝo kasǝa arǝ ɓwa mǝnana wu nda wunǝi a nkaring Nggeasala Jodan, yì mǝnana a bangga sǝm cau amurí ka? Sǝni, nda kǝ̀ pàkkî aɓwana batisǝma ka, sǝ aɓwana pwanǝna rǝia kat aban ká a baní.>>
\p 
\v 27 Pǝlǝa Yohana na ama:
\pi1 Ɓakuli ka nda kǝ pe ɓwa túró mǝnana nǝ̀ pak ka.
\v 28 Wun, nǝ ɓamur rǝ wun ngga, wun nǝ̀ nakunam mǝnana ǝn bang nǝma, <<Mǝ nda Kǝrǝsti, Mǝ'amsǝban ɗang. À túrǎm nǝ túrô ɓǝ̀n aki wi dǝmba yiu.>>
\pi1 
\v 29 Māfela ka mālá bura-māfela na; sǝ murǝm gyajam mala bura-māfela mǝnana cam aban kundǝe kǝ kwakikiri arǝì ka, ban kǝ ɓoari wi arǝ ok gì bura-māfela. Mim gbal ka, ban kǝ ɓoaram arǝ cau mǝno wu banggàm ngga.
\v 30 Dumǝna púp ama, nǝ̀ nggǝ lidǝmba nǝ gulo, sǝ mim ngga mǝ nǝ nggǝ amsǝa.
\s1 Ɓwa mǝnana sulǝ nǝ kuli ka
\p 
\v 31 Ɓwa mǝnana pur nǝ kuli ka, nda mǝnana ndanǝ gulo kútì acili aɓwana kat ka. Ɓwa mǝnana ndakani a ɓanza ka, mala ɓanza na, sǝ acau male ka a mala ɓanza na. Sǝ ɓwa mǝnana sulǝ nǝ kuli ka, ndanǝ gulo kútì aɓwana kat.
\v 32 Yì ka, yiu, yi bǝlkuni amur gir mǝnana sǝna sǝ ok ka, sǝ kǝɓwa ak cau male ɗàng.
\v 33 Sǝ ɓwa mǝnana kat ak cau male ka earǝna ama cau mala Ɓakuli ka mǝsǝcau na.
\v 34 Ɓwa mǝnana Ɓakuli túrí ka, kǝ na gì Ɓakuli, acemǝnana Ɓakuli soapi wi Bangŋo male puppup.
\v 35 Ɓakuli earce Muni sǝ nyinggi wi girbunda kat a buì.\f + \fr 3:35 \ft Ɓalli gbal aɓa: \xt Mat 11:27; Luk 10:22\xt*\ft .\f*
\v 36 Koya ɓwa na sǝ pà ɓamúrì aban Muna mala Ɓakuli ka, ndanǝ yilǝmu mǝnana málá male pà kàm raka. Sǝ ɓwa mǝnana kat ɓinǝ Muna mala Ɓakuli ka pà nǝ̀ kum yilǝmu ɗang, bumlulla mala Ɓakuli ka nǝ̀ ueo amurí.
\c 4
\s1 Yesu nacau andǝ ɓe ɓwama Samariya
\p 
\v 1 Yesu sǝlǝ ama amǝ Farisi ongŋǝna ce ama yì ka, nda arǝ kum amǝkpate pas sǝ nda arǝ pakkia wia batisǝma kútì mala Yohana.
\v 2 (Aɓa mǝsǝcau ka, Yesu nǝ ɓamúrì ka pakki kǝɓwa batisǝma ɗàng, alaggana male na à pakkiyi ka.)
\v 3 Lang Yesu yi sǝlǝ ama amǝ Farisi ongŋǝna ama amǝkpate nǝ̀ nggǝ̀ làkkì ka, nying bu-nzali Yahudi, nyare o ɗǝm a bu-nzali Galili.
\v 4 O male ka dumǝni wi púp nǝ̀ ara aɓa nzali Samariya.
\p 
\v 5 Lang yina a nzali Samariya ka, pǝlǝa yiu a ɓe la mǝnana à tunǝki ama Saika ka; banì sapi nzali mǝnana Yakupu pe muni Yisǝfu a pwarian ngga ɗang.\f + \fr 4:5 \ft Ɓalli gbal aɓa: \xt Tite 33:19; Jes 24:32\xt*\ft .\f*
\v 6 Tūli-mùr mala Yakupu ka, nda abanì. Yesu aulǝna nǝ gya nǝ pwari zǝkya ka, yi do a kun tūli-mùrî nǝ̀ usǝlǝo.
\p 
\v 7 Ɓè ɓwama Samariya yiu a to mùr, sǝ Yesu ne wi ama, \wj <<Ɗàrǝâm mùr mǝ nu.>>\wj*
\v 8 (Anggo ka alaggana male warina a kúr girlina aɓa là.)
\p 
\v 9 Sǝ ɓwame pǝlǝa ne Yesu ama, <<A nda ɓwa Yahudi, sǝ mǝ nda ɓwa Samariya. Lang sǝ a nǝ zǝm mùr-nùná a buam yi mǝnana kǝgìr kǝ kpapi amǝ Yahudi andǝ amǝ Samariya raka?>>\f + \fr 4:9 \ft Ɓalli gbal aɓa: \xt Ezr 4:1-5; Nehe 4:1-2\xt*\ft .\f*\f + \fr 4:9 \fq kǝgìr kǝ kpapi amǝ Yahudi andǝ amǝ Samariya raka: \ft Ko <<amǝ Yahudi nukiyi gir ko à likiyi gir a kwar mwashat andǝ amǝ Samariya raka.>>\f*
\p 
\v 10 Yesu eari wi ama, \wj <<Ɓǝ̀ a súrǝ́nà rǝ ɓoro mǝnana Ɓakuli ndanǝi aceo, andǝ ɓwa mǝnana zǝmggiyio mùr-nùná ka, ɓǝ́ a zǝmni wi mùr mǝnana pākiyi yilǝmu ka, sǝ yì ka, nǝ̀ po.>>\wj*
\p 
\v 11 Ɓwame na ama, <<Ɓwamǝgule, a panǝ gir nun mur ɗang, sǝ tūli ka mǝlime na. Ake sǝ a nǝ kum mǝnia yì mur mǝnana kǝ pa yilǝmu ka?
\v 12 A kútì kà sǝm Yakupu mǝnana pà sǝm mǝnia yì tūli, mǝnana yì nǝ nggearǝì, andǝ amuni, andǝ agirkusǝu malea à nu mur kàm ngga le?>>
\p 
\v 13 Pǝlǝa Yesu ne wi ama, \wj <<Ɓwa mǝnana kat nu mùr man ngga nǝ̀ ok mǝsamur ɗǝm.\wj*
\v 14 \wj Sǝ ɓwa mana kat nǝ̀ nu mùr mǝnana mǝ nǝ pe wi ka, pà nǝ̀ ok mǝsamur ɗǝm ɗàng. Mùr mǝnana mǝ nǝ pe wi ka, nǝ̀ duk mgbeɗe mùr a bumi mana nǝ̀ nggǝ pe wi yilǝmu mǝnana tè pà nǝ̀ mal raka.>>\wj*
\p 
\v 15 Ɓwame banggi wi ama, <<Ɓwamǝgule, pam mǝnia yì mur ka, ace mǝnana mǝsamur ɓǝ̀ kǝa walam ɗǝm ɗàng, sǝ ɓǝ̀n ngga nyarki kani aban toki mur raka.>>
\p 
\v 16 Yesu ne wi ama, \wj <<Kyane kya tunǝ burio wu yiu.>>\wj*
\p 
\v 17 Ɓwame ne Yesu ama, <<Ən panǝ bura ɗang.>>
\p Yesu banggi wi ama, \wj <<A bangŋǝna mǝsǝcau yì mǝnana a na ama, a panǝ bura raka.\wj*
\v 18 \wj Mǝsǝcau ka nda mǝnana ama, a dumǝna nǝ aburana tongno, sǝ ɓwa mǝno ado a nda tè ka burio na ɗang. Cau mǝnana a ne ka mǝsǝcau na.>>\wj*
\p 
\v 19 Ɓwame na ama, <<Ɓwamǝgule, ǝn nggǝ sǝni kǝla we ka a nda mǝɓangnǝa mala Ɓakuli.
\v 20 Aká sǝm peri a ban Ɓakuli amur nkono Gerizim man, sǝ wun amǝ Yahudi ka, wu na ama Urǝshalima nda ban mǝnana duk púp sǝm nǝ̀ peri kàm ngga.>>
\p 
\v 21 Yesu eari wi ama, \wj <<Ɓwama, earnǝ cau mǝnana ǝn nggǝ banggo ka. Pwari nda kǝ yiu ka mǝnana peri a ban Ɓakuli ka, pà nǝ̀ pa amur nkono man ko aɓa Urǝshalima ka ɗàng.\wj*
\v 22 \wj Wun amǝ Samariya ka, wu kǝ peri a ban ɓwa mǝnana wu súrǝì raka, sǝ sǝm, amǝ Yahudi ka, sǝm sùrǝ́nà rǝ ɓwa mǝnana sǝm nggǝ peri a baní ka. Acemǝnana amsǝban ngga pur nǝban amǝ Yahudi.\wj*
\v 23 \wj Sǝ pwari nda kǝ yiu ka, yàle pwari nì yina, mǝnana amǝperi mǝ'mǝsǝcau nì nǝ̀ nggá peri a ban Ɓakuli nǝ ɓabumia kat nǝ mǝsǝcau. Yia ka à nda ka ulang amǝperi mǝnana Ɓakuli earkiyi cea ka.\wj*
\v 24 \wj Ɓakuli ka Bangŋo na, sǝ amǝperi a baní ka, dumǝna púp, à nǝ̀ peri nǝ ɓabumia kat nǝ mǝsǝcau.>>\wj*
\p 
\v 25 Pǝlǝa ɓwame ne Yesu ama, <<Ən sǝlǝna ama, Mǝ'amsǝban mǝnana à kǝ tunǝi ama Kǝrǝsti ka nǝ̀ yiu. Ɓǝ̀ yina ka, nǝ̀ yia mǝngia sǝm ɓalǝ agir kat.>>
\p 
\v 26 Sǝ Yesu banggi wi ama, \wj <<Mim ɓwa mǝnana ado nakiyi cau nǝ we ka, Mǝ nda kǝ yì.>>\wj*
\p 
\v 27 Anggo ka, alaggana mala Yesu yi tusǝo, à ndali mǝnana à yì kumi aban nacau andǝ ɓwama ka. Sǝ kǝɓwa ɗì ɓwame ama, mana a alkite ka ɗàng. Sǝ kǝɓwa ɗì gbal ama, ace mana sǝ a kǝ nacau nǝ ɓwame ka ɗàng.
\p 
\v 28 Sǝ ɓwame nying bàng-mùr male nyare o a la kya ne aɓwana ama,
\v 29 <<Wu yiu, wu yi sǝn ɓwa mǝnana nam koya gìr nani ǝn pa aɓa do mem ngga! Ko ɓwa man nda Kǝrǝsti Mǝ'amsǝban le?>>
\v 30 Pǝlǝa ɓwapǝndǝa purrì là à yiu a ban Yesu.
\p 
\v 31 Anggo ka, alaggana mala Yesu zǝmbi wi ama, <<Rabbi, yiu li girlina.>>
\p 
\v 32 Yesu pǝlǝa nea wia ama, \wj <<Mǝ ndanǝ girlina mǝnana wu súrǝ̀ kǝgìr amurí raka.>>\wj*
\p 
\v 33 Sǝ alaggana male kutia ɗiki rǝia ama, <<Kǝ ɓwa yinǝì wi nǝ girlina le?>>
\p 
\v 34 Yesu nea wia ama:
\pi1 \wj Girlina mem nda ɓǝ̀n pak gir mǝnana Tárrám mana túrǎm ngga earkiyi ce, sǝ ɓǝ̀n masǝlǝta túró male mǝnana pam ɓǝ̀n pe ka.\wj*
\v 35 \wj Wun nǝ̀ naki mbak ama, ueo zongŋo ine à nǝ̀ pwan girɓaban? Sǝ ǝn nggǝ na wun, wu loasǝ amǝsǝ wun, wu sǝn agirɓaban, à ɓǝlna, à kārǝ́na pwano.\wj*
\pi1 
\v 36 \wj Ɓwa mǝnana nda ban pwan girɓaban ngga, Ɓakuli na arǝ pe wi tangnakusǝi, sǝ ndarǝ pwan girɓaban mala yilǝmu mǝnana tè pà nǝ̀ mal raka; ace mani ka mǝɓeale andǝ mǝ'pwan girɓaban ngga ban nǝ ɓoaria wia atārǝia.\wj*
\v 37 \wj Anggo ka cau mǝnana à kǝ ne ama, <<Ɓè ɓwa ɓeale, sǝ ɓeɓwa pwan>> ngga, dumǝna mǝsǝcau.\wj*
\v 38 \wj Ən tasǝ wun, wu kya pwan girɓaban mǝnana wu nda wu ɓeal raka; aɓea aɓwana nda à ɓeale, sǝ wun ngga wu kya kum tangnakusǝ túró mǝnana à pak ka.\wj*
\p 
\v 39 Amǝ Samariya pas a mǝno yì là ka, à pa ɓamuria a ban Yesu atàcau mala ɓwama mǝnana banggia wia ama, <<Nam koya gìr nani ǝn pa aɓa do mem ngga.>>
\v 40 Lang amǝ Samariyi yiu a ban Yesu ka, à yì zǝmbi wi ɓǝ̀ do ateà, pǝlǝa Yesu do pak nongŋo ɓari a bania.
\p 
\v 41 Ɓwamǝpǝndǝe pas ɗǝm à yì pa ɓamuria a ban Yesu ace cau male.
\v 42 Pǝlǝa yia ka à ne mǝno yì ɓwama ka ama, <<Ado ka pa ace cau mo sǝ sǝm pà ɓamur sǝm a baní ka ɗàng, nggearǝ sǝm ngga sǝm ongŋǝni nǝ kir sǝm. Sǝm sǝlǝna ama, aɓa mǝsǝcau ka, yì nda Mǝ'amsǝ ɓanza.>>
\s1 Yesu twalban rǝkwana // mala muna mala // ɓè mǝtamurǝm
\r (Matiu 8:5-13; Luka 7:1-10)
\p 
\v 43 Anzǝm mǝnana Yesu pàngŋǝ̀nà nongŋo ɓari a banì ka, lo o a Galili.
\v 44 Yesu nǝ ɓamúrì ka bangŋǝna ama, <<À kǝ pê mǝɓangnǝa mala Ɓakuli gulo a la male ɗàng.>>\f + \fr 4:44 \ft Ɓalli gbal aɓa: \xt Mat 13:57; Mar 6:4; Luk 4:24\xt*\ft .\f*
\v 45 Lang yi bwalǝna Galili ka, ɓwapǝndǝa gingsǝi à é nǝ bu ɓari, acemǝnana yia ka à warina a Urǝshalima a ban Lamsan Yàlîmurû, sǝ à sǝnǝna agir mǝnana Yesu pea a banì kat ka.\f + \fr 4:45 \ft Ɓalli gbal aɓa: \xt Yoh 2:23\xt*\ft .\f*
\p 
\v 46 Aɓa gya mala Yesu aɓa nzali Galili ka, kya kútí ɗǝm a Kana, la mǝnana tsǝk mùr pǝlǝ mùr-ɓǝlanggun anap kàm ngga.\f + \fr 4:46 \ft Ɓalli gbal aɓa: \xt Yoh 2:1-11\xt*\ft .\f* Ɓè mǝtamurǝm nda kam a Kapanahum, muni ka mǝkwánó na.
\v 47 Lang mǝnia yì ɓwa ongŋǝna ama Yesu nyìngŋǝ̀nà bu-nzali Yahudi yina a Galili ka, pǝlǝa wari a baní kya zǝmbi wi ɓǝ̀ yiu a Kapanahum ɓǝ̀ kya twalban rǝkwana mala muni mǝnana nda kúnlú ka.
\v 48 Sǝ Yesu ne wi ama, \wj <<Ɓǝ̀ wu sǝn gìr-gyambǝliban andǝ gir'ndǝlǝki raka pà wun nǝ̀ earnǝ mim ɗang.>>\wj*
\p 
\v 49 Mǝtamurǝm ni pǝlǝa ne Yesu ama, <<Ɓwamǝgule, yiu atàm tù, ce munem masǝlǝa arǝàm ɗàng.>>
\p 
\v 50 Yesu ne wi ama, \wj <<Kyane, munio pà nǝ̀ wu ɗàng.>>\wj* Ɓwabura man earnǝ cau mala Yesu, pǝlǝa nyare aban o.
\v 51 Nda ban o ka, amuna-ɓala male yi kasǝi a njar à ne wi ama, <<Munio ka auna, rǝì malǝna.>>
\p 
\v 52 Sǝ ɗia ama, <<Nǝ ya bu-pwari sǝ rǝ muna tita malâ?>> Sǝ à ne wi ama, <<Nda yilung nǝ bu-pwari mwashat mala pwari, sǝ ɓauwa nyi.>>
\v 53 Pǝlǝa ɓalǝ tár muna kasǝa ama, nda aɓa kǝ bu-pwari mǝnana Yesu ne wi nǝi ama, \wj <<Kyane, munio pà nǝ̀ wu ɗàng.>>\wj* Pǝlǝa yì andǝ amǝ'ɓala male pà ɓamuria aban Yesu.
\p 
\v 54 Mǝnia ka nda ɓaria gir'ndǝlǝki mǝnana Yesu pè ka. Pè anzǝm mǝnana nyìngŋǝ̀nà bu-nzali Yahudi yina a Galili ka.
\c 5
\s1 Yesu twali gbakǝre ban rǝkwana
\p 
\v 1 Anzǝm man ngga, Yesu wari a Urǝshalima a ɓe lamsan mala amǝ Yahudi.
\v 2 Aɓa Urǝshalima ka, ɓe guguri nakam a Kun njar mala anzur mǝnana à tunǝki nǝ kun mala amǝ Yahudi ama Beseda ka. À gumbǝli nǝ atara tongno.
\v 3 Aɓalǝ amǝnia yì atara ka sǝ amǝ rǝkwana pas, ante, andǝ agbakǝre andǝ aɓwana mǝnana aɓea barea wu ka, à kǝ nongŋo [aban kundǝ zurǝì mùr.]
\v 4 Acemǝnana arǝ aɓea apwari ka, mǝturonjar mala Mǝtalabangŋo kǝ zurǝi mùr. Anzǝm zurǝi mùr ka, mǝkwánó mǝnana ak dǝmba kutio a mùr ka, ɓǝ̀ ya ulang kwánó ndanǝi ka, nǝ̀ mal kat.
\v 5 Ɓè ɓwabura nakam abanì, pàngŋǝ̀nà apǝlǝa lumi-tàrú-bwamdǝ-tongno-nong-tàrú aban nongŋo nǝ rǝkwana.
\v 6 Yesu sǝni aban nongŋo, sǝ sǝlǝna ama sauwuna aɓa rǝkwana male, pǝlǝa ɗì ama, <<A kǝ́ earce ɓǝa twalo ban rǝkwana mo le?>>
\p 
\v 7 Mǝkwánó ear ama, <<Ɓwamǝgule, ǝn panǝ kǝɓwa a muram, mǝnana ɓǝa zurina mùr ka nǝ̀ ramtam aɓa guguri ka ɗang. Ɓǝ̀ mǝ nda ban ɓariki mǝ nǝ kútí ka, kara ɓeɓwa nǝ̀ akàm dǝmba.>>
\p 
\v 8 Yesu ne wi ama, <<Lo, twal kala mo o!>>
\v 9 Àkǝ̀ banì rǝkwana male malâ, lo twal kala male aban o.
\p Pwari mǝnana à pak mǝnia yì gir ka pwari Sabbat na, pwari usǝlǝo mala amǝ Yahudi.
\v 10 Pǝlǝa aɓwana-mǝgule mala amǝ Yahudi ne ɓwa mǝnana à twali wi ban rǝkwana ka ama, <<Yalung ngga pwari usǝlǝo na, Nggurcau ma'sǝm eare ama wu twal kal nongŋo mo a pwari usǝlǝo ɗang.>>\f + \fr 5:10 \ft Ɓalli gbal aɓa: \xt Nehe 13:19; Ir 17:21\xt*\ft .\f*
\p 
\v 11 Pǝlǝa nea wia ama, <<Ɓwa mǝnana twàlâm-ban rǝkwana ka nǝ̀ nam ama, mǝ twal kala mem mǝ o.>>
\p 
\v 12 Sǝ à ɗì ama, <<Yana ɓwe na no ama wu pak mǝnia yì gir ka?>>
\p 
\v 13 Ɓwa mǝnana à twali wi ban rǝkwana ka súrǝ̀ yana nda Yesu ɗang, acemǝnana ɓwapǝndǝa làkkì pas abanì, sǝ Yesu kongŋǝna aɓalǝ aɓwana.
\p 
\v 14 Anzǝm mani ka Yesu kumi aɓa Ndàmǝgule mala Ɓakuli, sǝ ne wi ama, <<Sǝni ado ka à twalǝ́nò ban rǝkwana, nying pàkki acauɓikea, ɓǝ̀ ana raka gìr mǝɓane mǝnana kútì mǝno ka nǝ̀ kumǒ.>>
\v 15 Pǝlǝa ɓwe o kya ne aɓwana-mǝgule mala amǝ Yahudi ama Yesu nǝ̀ twali wi ban rǝkwana male.
\v 16 Pǝlǝa yia amǝ Yahudi ka à tsǝk Yesu a dǝmba, acemǝnana twalban rǝkwana a pwari Sabbat, pwari usǝlǝo.
\v 17 Yesu banggia wia ama, <<Ko aya pwari ka Tárrám nda mur túró, ace mani ka dumǝna púp ama, mim gbal ka mǝ nǝ pak túró.>>
\p 
\v 18 Ace mani ka, aɓwana-mǝgule mala amǝ Yahudi ɓariki kǝ̀rkǝ́r ama à nǝ̀ wal-lú Yesu, acemǝnana yàl nzongcau mala Sabbat nǝmurǝì ɗàng, tunǝ Ɓakuli ama Tárrí. Anggo ka ndaban karǝ ɓamúrì arǝ Ɓakuli.
\s1 Rǝcandǝa mala Yesu // Muna mala Ɓakuli
\p 
\v 19 Yesu earia wia ama:
\pi1 Ən nggǝ na wun mǝsǝcau, pà mǝ nǝ pak kǝgìr aɓa ɓamúràm ɗang. Kǝ gìr mǝnana ǝn sǝn Tárrám Ɓakuli pak ka, nda ǝn pakkiyi ka. Gìr mǝnana kat Tárrám pak ka, nda mana ǝn pakkiyi ka.
\v 20 Ɓakuli Tárrú ka kǝ earcem mim Muni, sǝ kǝ lǝmdǝam agir mǝnana kat yì nǝ nggearǝì pakkiyi ka. Yàle nǝ̀ lǝmdǝam agir mǝgulke mǝnana à kútì man ngga, sǝ wun kat wun nǝ̀ nggǝ ndalǝki.
\v 21 Kǝla mǝnana Ɓakuli Tárrám kǝ loasǝ alú sǝ kǝ pea wia yilǝmu ka, anggo sǝ mim Muni ka mǝ nǝ pea aɓwana mǝnana ǝn earce mǝ nǝ pea wia ka yilǝmu.
\pi1 
\v 22 Tárrám nǝ ɓamúrì ka kǝ ɓashi kǝɓwa ɗàng, panam mim Muni rǝcandǝa mala ɓashi kat,
\v 23 ace mǝnana ɓǝ̀ aɓwana kat pam gulo kǝla mǝnana à pe Tárrám Ɓakuli ka. Ɓwa mǝnana kat pam gulo raka, pà aban pê Tárrám mǝnana tasǝam ngga gulo ɗang.
\v 24 Mǝ nda ban na wun mǝsǝcau, ɓwa mǝnana kat kǝ ok cau mem, sǝ kǝ pa ɓamúrì a ban Tárrám mǝnana tasǝam ngga, ndanǝ yilǝmu mǝnana masǝlǝate pà kàm raka. Ɓashi pà nǝ̀ sulǝo amurí ɗang, yì ka, angŋǝna dǝmba yàlǝ́nì lú, kutina a yilǝmu.
\pi1 
\v 25 Mǝ nda ban na wun mǝsǝcau, pwari nda ban yiu, yàle pwari nì pàngŋǝ̀nà, mǝnana aɓwana mana alú na ka à nǝ̀ ok gi Muna mala Ɓakuli, sǝ aɓwana mǝnana à o ka, à nǝ̀ long nǝ yilǝmu.
\v 26 Kǝla mǝnana Tárrám Ɓakuli nda tǝr yilǝmu ka, anggo gbal panam mim Muni ɓǝ̀ ǝn duk tǝr yilǝmu.
\v 27 Sǝ ɗǝm ngga panam rǝcandǝa mala ɓashi, acemǝnana mǝ nda Muna mala Ɓwa.
\pi1 
\v 28 Wu kǝa ndali arǝ man ɗang, pwari nda kǝ yiu ka, mǝnana alú mana aɓalǝ aɓembe malea ka, à nǝ̀ ok gi Muna mala Ɓwa
\v 29 sǝ à nǝ̀ purî ɓalǝ aɓembe. Aɓwana mǝnana à pak mǝɓoarne ka, à nǝ̀ lo à nǝ̀ kutia yilǝmu, sǝ aɓwana mǝnana à pak mǝɓane ka, à nǝ̀ lo sǝ à nǝ̀ kum ɓashi.\f + \fr 5:29 \ft Ɓalli gbal aɓa: \xt Dan 12:2\xt*\ft .\f*
\pi1 
\v 30 Pa mǝ nǝ pak ɓè kǝgìr aɓa rǝcandǝa mem ɗàng. Ən nggǝ pak ɓashi mem à pě mǝnana Ɓakuli banggàm ɓǝ̀n nggǝ pe ka. Ace mani ka, ɓashi mem ngga nda amur njarì, acemǝnana ǝn pa aban ɓariki mǝ nǝ pak gìr mǝnana ǝn earkiyice ka ɗàng. Kǝ nggearǝ mǝsǝrǝ gir mǝnana Tárrám mana túrǎm ngga earkiyi ce ka, nda ǝn nggǝ pe ka.
\pi1 
\v 31 Ɓǝ̀ ǝn nacau amur ɓamúràm ngga, cau mem ka, à pà nǝ̀ é kǝla mǝsǝcau ɗang.
\v 32 Sǝa ma ɓeɓwa nda kam mǝnana kǝ nakunam ngga, sǝ ǝn sǝlǝna ama acau mǝnana nea a muram ngga mǝsǝcau na.
\pi1 
\v 33 Yohana Mǝbatisǝma nda ɓwa mǝnana wu tasǝ amǝturonjar ma'wun a baní, sǝ na wun mǝsǝcau a muram ngga.\f + \fr 5:33 \ft Ɓalli gbal aɓa: \xt Yoh 1:19-27; 3:27-30\xt*\ft .\f*
\v 34 Kat andǝ amani ka, ǝn pa aban came amur nakún mala ɓwamǝpǝndǝe ɗang; mǝ nda ban na anggo ace mǝnana wun ngga ɓǝ̀ wu kum àwá.
\v 35 Yohana ka nda kǝla pitǝla mana kǝ earke sǝ kǝ ta ka, sǝ wun ngga wu eare wun nǝ̀ pak banɓoarnado zuku arǝ tǎlaban male.
\pi1 
\v 36 Sǝ mǝ ndanǝ mem yi nakún a muram mǝnana kútì mana Yohana na a muram ngga. Agir mǝnana ǝn nggǝ pakkia ka, atúró mǝnana Tárrám pam ama ɓǝ̀n pakkia ka à nda. À kǝ̀ nakunam, sǝ à kǝ̀ lǝmdǝ ama Tárrám nǝ̀ túrǎm.
\pi1 
\v 37 Sǝ Tárrám mǝnana tasǝam ngga náná kunam. Wu malaká ok gì àkǝ̀ pwari ɗàng, sǝ wu malaká sǝn ɓamǝsǝi gbal ɗàng.\f + \fr 5:37 \ft Ɓalli gbal aɓa: \xt Mat 3:17; Mar 1:11; Luk 3:22\xt*\ft .\f*
\v 38 Sǝ wun ngga nggearǝ cau male pa a ɓabum wun ɗàng, acemǝnana wu earnǝ mim mǝnana Ɓakuli tasǝi ka ɗàng.
\pi1 
\v 39 Wu kǝ ɓalla andǝ mǝngi ɓá Malǝmce, acemǝnana wu kǝ sǝni kǝla aɓalǝi sǝ wu nǝ̀ kum yilǝmu mǝnana málá male pà kàm raka, sǝ aman yì acau wu ɓalkiyi ka, mǝ nda à nakiyi cau a muram ngga.
\v 40 Kat andǝ amani ka, wu ɓinǝ yiu a banam ace kum yilǝmu.
\pi1 
\v 41 Ɓwangsǝban mala ɓwapǝndǝa nda ǝn alkite ka ɗàng.
\v 42 Sǝ mim ngga ǝn súrǝ́nà rǝ wun, ɗǝm ngga ǝn sǝlǝna nǝma wu pànǝ earce Ɓakuli a ɓabum wun ɗàng.
\v 43 Ən yiu aɓa lullǝ Tárrám, sǝ wun ngga wu em ɗang, sǝ ɓǝ̀ ɓeɓwa yiu aɓa rǝcandǝa male ka wun nǝ̀ earnǝi, wun nǝ̀ é.
\v 44 Lang sǝ wun nǝ̀ earnǝ mim, yi mǝnana wu kǝ earce ak ɓwangsǝban arǝarǝ wun, sǝ wu kǝ ɓariki ama wun nǝ̀ kum ɓwangsǝban a ban ɓwa mǝnana yì mwashat nda Ɓakuli ka, ɗàng?
\pi1 
\v 45 Wu kǝa sǝni kǝla mǝ nda ɓwa mǝnana nǝ̀ oasǝkimur wun a ban Tárrám ka ɗàng. Musa mǝnana wu tsǝkɓalǝ wun arǝì ka, nda kǝ ɓwa mǝnana nǝ̀ oasǝki mur wun ngga.
\v 46 Ɓǝ̀ kàngkàng wu earǝna nǝ Musa ka, ɓǝ́ wu earǝna nǝ mim, acemǝnana mǝ nda ɓwa mǝnana Musa gilǝ cau a muram ngga.
\v 47 Sǝ mǝnana wu ginǝ earnǝ gir mǝnana Musa gilǝ ka, lang sǝ wun nǝ̀ earnǝ gir mǝnana ǝn na ka?
\c 6
\s1 Yesu linǝ́ aɓwana á-tongno
\r (Matiu 14:13-21; Markus 6:30-44; Luka 9:10-17)
\p 
\v 1 A ɓe pwari anzǝm man ngga Yesu eauwe a nkaring Garang Galili, mǝnana à tunǝki gbal ama, Garang Tiberiya ka.
\v 2 Ɓwabunda mǝ'làkke o atè, acemǝnana à sǝn agir-ndǝlǝki mǝnana twalban rǝkwana ka.
\v 3 Yesu pǝlǝa eauwe amur nkono sǝ do andǝ alaggana male.
\v 4 Anggo ka pwari Lamsan Yàlîmurû\f + \fr 6:4 \fq Lamsan Yàlîmurû: \ft Pakkiɗire ace ɗenyi nǝ pwari purî ɓá do guro mala amǝ Isǝrayila aɓa nzali Masar.\f* mala amǝ Yahudi gbashìnà.
\v 5 Lang Yesu loasǝ muri sǝn nggea làkkì mala ɓwapǝndǝa aban yiu a baní ka, pǝlǝa ɗì Filip ama, <<Ake sǝ sǝm nǝ̀ kúr girlina mǝnana aɓwabundǝa man kat nǝ̀ lì ka?>>
\v 6 Yesu na mǝnia yì cau ka nǝ̀ mwam Filip; aɓa mǝsǝcau ka súrǝ́nà rǝ gir mǝnana nǝ̀ pak ka.
\p 
\v 7 Filip eari wi ama, <<Ko ɓǝ̀ dinari\f + \fr 6:7 \fq dinari: \ft Ko <<boalo túró zongŋo tongno-nong-tàrú.>>\f* na à nǝ̀ walo ace kúr girlina mǝnana ɓǝ̀ koya ɓwa nani ka ɓǝ̀ li ka, pà nǝ̀ karǝ ɗang.>>
\p 
\v 8 Sǝ ɓeɓwa mwashat aɓalǝ alaggana male, Andǝru mǝ'eam Shiman Bitǝrus, ne Yesu ama,
\v 9 <<Ɓè mǝlagga ndya a kani nǝ agbatali nɗǝmo muku-bale tongno andǝ anji ɓari, sǝ mǝno ka, nǝ̀ karǝ man a ban mǝnia yì làkkì mala ɓwabundǝa ka.>>
\p 
\v 10 Yesu ne alaggana male ama, <<Wu ne aɓwana ɓǝà dumnǝdo.>> Pǝlǝa yia kat à do amur munabondo a banì. (Làkkì mala aburana nǝmurǝia ka bwal á-tongno.)
\v 11 Yesu pǝlǝa twal akuro-nɗǝmo, pakki Ɓakuli yàwá, sǝ gaki aɓwana mǝno à dumnǝdo ka. Anggo sǝ pang nǝ anji. Yia mǝno kat ka à lìli girlina kárǝìa.
\v 12 Anzǝm mǝnana à ɗǝmgina kat ka, pǝlǝa Yesu ne alaggana male ama, <<Wu ramgi acili girlina mǝnana à ué ka ace mǝnana kǝgìr ɓǝ̀ kǝa kìɗìkì ɗang.>>
\v 13 Pǝlǝa à ramgi ɓwangine girlina mǝnana ɓwapǝndǝa li sǝ à nying cili aɓa kuro-nɗǝmo muku-bale tongno ka, à lumsǝki andakade lum-nong-ɓari nǝia.
\p 
\v 14 Lang aɓwana mǝno nǝ sǝn gir'gyambǝliban mǝnana Yesu pe ka, à na ama, <<Mǝsǝcau, mǝnia yì ɓwa ka nda mǝɓangnǝa mala Ɓakuli mǝnana sǝm kundǝkiyi yiu male a ɓanza ka!>>
\v 15 Sǝ lang Yesu yi sǝlǝna ama, à ndo à nǝ̀ yia bwali à nǝ̀ tsǝì ɓǝ̀ dupia wia murǝm púp ka, pǝlǝa nyar zàng amur nkono nǝmurǝì.
\s1 Yesu gya amúr mùr
\r (Matiu 14:22-33; Markus 6:45-52)
\p 
\v 16 Lang pwari kpana ka, alaggana mala Yesu kutio aban ká a kun garang.
\v 17 À kya eauwe aɓa waru à nǝ̀ nyare aban o a nkaring garang a Kapanahum. Anggo ka ban bwalǝna sǝ Yesu malaká yiu abania ɗang.
\v 18 Banì sau ɗang nggea gung mǝcandǝe lo ɓua sǝ nda rǝ eaki nkono amúr mùr.
\v 19 Anzǝm mǝnana à samsǝna, à bwalǝna kǝla mel tàrú ko ine ka, kara à sǝn Yesu aban gya amúr mùr, kǝ yiu nǝ ban waru, sǝ yia ka ɓangciu pakkia wia kǝ̀rkǝ́r.
\v 20 Sǝ Yesu banggia wia ama, <<Mǝ nda, ɓǝ̀ ɓangciu ɓǝ̀ kǝa pakka wun ɗang.>>
\v 21 Pǝlǝa à eare à twali ateà aɓa waru, sǝ zuku ka waru yi kpashina a kún múr aban mǝnana à tsǝk múrià kam ngga.
\s1 Aɓwana alta Yesu
\p 
\v 22 Ban fana ka, ɓwabundǝa mǝnana ueo a nkaring mur mǝnana Yesu nyi ka, à yì sǝlǝ ama, kǝ waru na mwashat abanì, sǝ à sǝlǝna ama Yesu eauwe atà alaggana male ɗang, sǝ o malea ka pà ateà ɗang.
\v 23 Aɓea waru mǝnana à pùr a Tiberiya ka à yiu à kya kpashi tù nǝ́ ban mǝnana Mǝtalabangŋo pak yàwá amur girlina sǝ pè ɓwapǝndǝa à li kam ngga.
\v 24 Lang ɓwabundǝa sǝni ka Yesu andǝ alaggana male pà abanì raka, à kutiki aɓalǝ awaru mǝno sǝ à o a Kapanahum, aban alta Yesu.
\s1 Yesu nda girlina mala yilǝmu
\p 
\v 25 Lang à yì kumǝni a ɓe nkaring garang ngga, à ɗì ama, <<Rabbi,\f + \fr 6:25 \fq Rabbi: \ft Ko <<Mǝkanigir, ko Malǝm>>\f* a ya pwari sǝ a yiu kani?>>
\p 
\v 26 Yesu earia wia ama, <<Mǝ nda ban na wun mǝsǝcau, wu pà aban altam acemǝnana wu sǝn agir-ndǝlǝki ka ɗang, nda ace girlina mǝnana wu li wu ɗǝmnggi ka.
\v 27 Sǝ wu kǝa wu pak túró ace girlina mǝnana kǝ kiɗiki ka ɗang; wu pak túró ace girlina mǝnana nǝ̀ pà wun yilǝmu mǝnana málá male pà kàm raka. Mǝnia ka nda girlina mǝnana Muna mala Ɓwa nǝ̀ pà wun ngga, acemǝnana Tárrú, yì Ɓakuli ka, tsǝ̀ngŋǝ̀nà buì ama earǝna nǝi.>>
\p 
\v 28 Pǝlǝa à ɗì Yesu ama, <<Mana sǝm nǝ̀ pa ace mǝnana ɓǝ̀ sǝm pàk gìr mana Ɓakuli earce ama ɓǝ̀ sǝm pàk ka?>>
\v 29 Yesu earia wia ama, <<Gìr mǝnana Ɓakuli earkiyice ama ɓǝ̀ wu pàk ka, nda mǝnana ama, wu pa ɓamur wun aban ɓwa mǝnana túrí ka.>>
\p 
\v 30 À ɗì Yesu ama, <<Sǝ, ya ulang gìr pa-ndǝlǝki na a nǝ pa ace mǝnana ɓǝ̀ sǝm sǝni sǝ ɓǝ̀ sǝm earnǝ we ka? Mana awu nǝ pa?
\v 31 Aká sǝm li girlina mǝnana à tunǝki ama <Manna> ka aɓa gya malea aɓa pǝɗanban a njenza. Malǝmce na ama, <Musa pea wia girlina mǝnana pur nǝ kuli ka ɓǝà li.> >>\f + \fr 6:31 \ft Ɓalli gbal aɓa: \xt Pur 16:4; Ang 78:24-25; Nehe 9:15\xt*\ft .\f*
\p 
\v 32 Yesu nea wia ama, <<Mǝ nda ban bangga wun mǝsǝcau, Musa nǝ̀ pa wun girlina mǝnana pur a kùli ka ɗàng, Tárrám na pà wun ngga. Sǝ adyan ngga ndya kǝ pà wun girlina mǝ'mǝsǝcau nì mǝnana pur a kùli ka.
\v 33 Girlina mǝ'mǝsǝcau nì mǝnana Ɓakuli pākiyi ka nda Ɓwa mǝnana sulǝ nǝ kuli sǝ kǝ pè ɓanza yilǝmu ka.>>
\p 
\v 34 À ne Yesu ama, <<Ɓwamǝgule, wú kǝ̀ pa sǝm mǝnia yì girlina ka pwari-pwari.>>
\p 
\v 35 Pǝlǝa Yesu bang ama:
\pi1 <<Mǝ nda girlina mala yilǝmu. Ɓwa mǝnana kat yiu abanam ngga pà nǝ̀ ok nzala ɗǝm ɗàng, sǝ ɓwa mǝnana kat pàɓamuri abanam ngga pà nǝ̀ ok mǝsamur ɗàng ko bǝti.
\v 36 Sǝ ado ka ǝn bangga wun ama wu sǝnǝnam nǝ amǝsǝ wun sǝ kat andǝ amani ka wu earnǝ mim ɗang.
\v 37 Ɓwa mǝnana kat Tárrám pam ngga nǝ̀ yiu abanam, sǝ ɓwa mǝnana kat yiu abanam ngga pà mǝ nǝ ɓínǝì ɗàng.
\pi1 
\v 38 <<Ən sulǝ nǝ kuli ace pak gìr ɓamúràm ɗàng, ǝn yiu ace pak túró mala Tárrám mǝnana tasǝam ngga.
\v 39 Sǝ mǝnia ka nda kànì mala Tárrám mǝnana tasǝam ngga, ama mǝ kǝa turta kǝɓwa aɓalǝ aɓwana mǝnana pam ngga ɗàng, sǝ a kun mani ka ɓǝn loasǝia kat nǝ yilǝmu a masǝlǝata apwari.
\v 40 Gìr mǝnana Tárrám earkiyice ka, nda mǝnana ama ɓwa mana kat sǝn Muni sǝ paɓamuri a baní ka, ɓǝ̀ kum yilǝmu mǝnana málá male pà kàm raka, sǝ mim gbal ka mǝ nǝ loasǝi nǝ yilǝmu a masǝlǝata apwari.>>
\p 
\v 41 Ace mǝno yì cau ka aɓwana-mǝgule mala amǝ Yahudi tita nggwani acemǝnana Yesu bang ama yì ka, nda girlina mǝnana sulǝ nǝ kuli ka.
\v 42 À bang ama, Yesu ka nda muna mala Yisǝfu, mǝnana à súrǝ̀ tárrí andǝ ngge ka. Sǝ palang, adyan sǝ nǝ̀ na ama, sulǝ nǝ kuli?
\p 
\v 43 Pǝlǝa Yesu earia wia ama:
\pi1 <<Wu ɗeki nggwani a rǝarǝ wun.
\v 44 Kǝɓwa pà nǝ̀ yiu abanam, mǝnana ɓǝ̀ Tárrám mana túrǎm ngga nǝ̀ nunni arǝàm raka. Sǝ mim ngga mǝ nǝ loasǝi nǝ yilǝmu a masǝlǝata apwari.
\v 45 Kǝla mǝnana à gilǝì aɓa Malǝmce mala amǝ'ɓangnǝa ka: <Yia kat ka, Ɓakuli nda nǝ̀ kania wia gìr ka.>\f + \fr 6:45 \ft Ɓalli gbal aɓa: \xt Isha 54:13\xt*\ft .\f* Lǝmdǝ ama, ɓwa mǝnana kat kǝ kwakikiri arǝ Ɓakuli Tárrú sǝ kǝ kànì a baní ka, nǝ̀ yiu a banam.
\pi1 
\v 46 <<Mǝnia ka pa aban lǝmdǝ ama, ɓekǝ ɓwamǝpǝndǝe ka sǝnǝna Ɓakuli ɗang; kǝ mim ɓwa mǝnana pur nǝban Ɓakuli ka, nda kǝ mana sǝn Ɓakuli Tárrú ka.
\v 47 Mǝ nda ban bangga wun mǝsǝcau, ɓwa mǝnana paɓamuri abanam ngga, ndanǝ yilǝmu mǝnana málá male pà kàm raka.
\pi1 
\v 48 <<Mǝ nda girlina mala yilǝmu.
\v 49 Aká wun li girlina mǝnana à tunǝki ama <Manna> ka aɓa pǝɗanban a njenza, sǝ kat andǝ amani ka à wu.
\v 50 Sǝ girlina mǝnana pur nǝ kuli ka ndya ka. Ɓwa mǝnana kat li mǝnia yì girlina ka pà nǝ̀ wu ɗàng.
\v 51 Mǝ nda girlina mala yilǝmu mǝnana sulǝ nǝ kuli ka. Ɓwa mǝnana kat li mǝnia yì girlina ka nǝ̀ dumnǝ yilǝmu mǝnana málá male pà kàm raka. Sǝ mǝnia yì girlina ka nyam nggūrǝam na, mǝnana mǝ nǝ pa ace mǝnana ɓǝ̀ ɓanza kum yilǝmu ka.>>
\p 
\v 52 Pǝlǝa amǝ Yahudi kutia makgìr arǝarǝia, sǝ à na ama, <<Lang sǝ ɓwa man nǝ̀ pà sǝm nyam nggūrǝì ama ɓǝ̀ sǝm li?>>
\p 
\v 53 Yesu banggia wia ama:
\pi1 <<Mǝ nda ban bangga wun mǝsǝcau, ɓǝ̀ wu li nyam nggūrǝ Muna mala Ɓwa sǝ wu nu nkile raka, wu pànǝ yilǝmu aɓalǝ wun ɗàng.
\v 54 Ɓwa mǝnana kat li nyamam sǝ nu nkílèm ngga, ndanǝ yilǝmu mǝnana málá male pà kàm raka, sǝ mǝ nǝ loasǝi nǝ yilǝmu a masǝlǝata apwari.
\v 55 Acemǝnana nyam nggūrǝam ngga girlina mǝ'mǝsǝcau nì na, sǝ nkílèm ngga girnùná mǝ'mǝsǝcau nì na.
\v 56 Ɓwa mǝnana kat li nyam nggūrǝam, sǝ nu nkílèm ngga, nda aban do a ɓalǝam, sǝ mim gbal mǝ ndanǝ do aɓalǝi.
\pi1 
\v 57 <<Kǝla mǝnana Tárrám mana nǝ yilǝmu ka túrǎm, sǝ àtàcau male sǝ ǝn dum nǝ yilǝmu ka, anggo gbal ɓwa mǝnana li nyam nggūrǝam ngga nǝ̀ dum nǝ yilǝmu àtàcau mem.
\v 58 Mǝnia ka nda girlina mǝnana sulǝ nǝ kuli ka. Pà kǝla <Manna> mǝnana aká wun li sǝ nǝnzǝ́mò ka à yì wuki ka ɗàng. Sǝ ɓwa mǝnana li nyam nggūrǝam ngga pà nǝ̀ wu ɗàng, nǝ̀ kum yilǝmu mǝnana pà nǝ̀ mal raka.>>
\p 
\v 59 Yesu banggí amǝnia yì acau ka, mǝnana nda aban kanigir aɓa ndakpapi mala amǝ Yahudi aɓa Kapanahum ngga.
\s1 Acau Yilǝmu mǝnana málá // male pà kàm raka
\p 
\v 60 Amǝkpate pas ok man yì cau ka sǝ à na ama, <<Man yi kanigir ka kwanǝna, yana nǝ̀ gandǝ é?>>
\p 
\v 61 Kǝɓwa ne wi ɗàng, sǝ Yesu ka sǝlǝna ama alaggana male nda aban nggwani amur man yì kanigir ka, pǝlǝa nea wia ama, <<Kànìgìr man tsǝk wun bum wun kiɗiki le?
\v 62 Mana nǝ̀ duk ɗenyicau ma'wun yi mǝnana ɓǝ̀ wu sǝn Muna mala Ɓwa aban o a kùli aban mǝnana pur kàm ngga?
\v 63 Bangŋo mala Ɓakuli nda pākiyi yilǝmu ka; ɓariki mala ɓwapǝndǝa pa nǝ̀ pà yilǝmu ɗang. Acau mǝnana ǝn bangga wun ngga a mala bangŋo na andǝ yilǝmu.
\v 64 Sǝ aɓea aɓwana atà wun ngga à earnǝ cau mem ɗàng.>> Yesu ka angŋǝna dǝmba súrǝ́nà rǝ aɓwana mǝnana à earnǝi raka, andǝ ɓwa mǝnana nǝ̀ nggá me ka.
\v 65 Pǝlǝa nea wia ama, <<Mǝnia ka nda gir mǝnana tsǝa sǝ ǝn na wun ama, kǝɓwa pà nǝ̀ gandǝ yiu abanam ɗang, she ɓǝ̀ Tárrám earǝnì wi ka.>>
\p 
\v 66 Ace cau mǝnana Yesu na ka, twal àkǝ̀ pwari mǝno ka, amǝkpate pas nyàrî te, à o à ɗeki.
\p 
\v 67 Yesu pǝlǝ rǝi aban alaggana male mana lum-nong-ɓari ka sǝ ɗia ama, <<Sǝ wun ngga, wu nǝ̀ o gbal le?>>
\p 
\v 68 Shiman Bitǝrus eari wi ama, <<Mǝtala sǝm, aban yan sǝ sǝm nǝ̀ ká le? A nda mǝnana nǝ cau mala pà yilǝmu mǝnana pà nǝ̀ mal raka.\f + \fr 6:68 \ft Ɓalli gbal aɓa: \xt Mat 16:16; Mar 8:29; Luk 9:20\xt*\ft .\f*
\v 69 Sǝ adyan ngga sǝm pànà ɓamur sǝm, sǝ sǝm sǝlǝna ama a nda kǝ Mǝfele mǝnana pur aban Ɓakuli ka.>>
\p 
\v 70 Pǝlǝa Yesu pa eare ama, <<Ən tar wun, wun lum-nong-ɓari. Sǝ ɓeɓwa atà wun ngga shetan na!>>
\v 71 Yahuda muna mala Shiman Iskariyoti, nda ɓwa mǝnana Yesu nakiyi cau amurí ka. Kat andǝ amani ama nda aɓalǝ alaggana male mǝnana lum-nong-ɓari ka, yì nda ɓwa mǝnana nǝ̀ nggá me ka.
\c 7
\s1 Amǝ'eam Yesu earnǝi ɗang
\p 
\v 1 Anzǝm man ngga, Yesu gya aɓa nzali Galili; eare kutio aɓa bu-nzali Yahudi ɗang, acemǝnana aɓwana-mǝgule mala amǝ Yahudi mǝnana akanó ka, à nda ban alte à nǝ̀ wal-luí.
\v 2 Sǝ lang Lamsan Do aɓalǝ Agumli, mala amǝ Yahudi gbashìnà ka,\f + \fr 7:2 \ft Ɓalli cê aɓa: \xt Pur 23:16; Pǝris 23:34; Nggur 16:13\xt*\ft .\f*
\v 3 amǝ'eam Yesu ne wi ama, <<Kyane a bu-nzali Yahudi, ace mǝnana ɓǝ̀ alaggana mò ɓǝà kya sǝn agir-ndali mǝnana a kǝ pea ka.
\v 4 Kǝɓwa pà kàm mǝnana kǝ earce ɓǝ̀ aɓwana súrǝì, sǝ nǝ̀ nggǝ pakki atúró aɓa sǝmbǝrǝa ka ɗàng. Sǝ acemǝnana a kǝ pakki amǝnia yì agir ka, puro lǝmdǝ rǝò ɓǝ̀ ɓanza súrǝ̀o.>>
\v 5 Nggearǝ amǝ'eam Yesu nǝ ɓamuria ka, à earnǝi à paɓamuria a baní ɗàng.
\p 
\v 6 Pǝlǝa Yesu nea wia ama, \wj <<Pwari mem mǝnana mǝ nǝ pur nǝi a banfana ka, malaká karǝ peatu ɗàng, sǝ ma'wun ngga koya pwari ka ma'wun na.\wj*
\v 7 \wj Ɓanza pa nǝ ɓinǝ mǝsǝ wun ɗàng, sǝ mim ngga kǝ ɓinǝ mǝsǝam, acemǝnana ǝn nggǝ bang aɓealɓikea mǝnana kǝ pak ka.\wj*
\v 8 \wj Wu kyane. Mim ngga pà mǝ nǝ ká ado ɗàng, acemǝnana pwari mem malaká karǝ ɗang.>>\wj*
\v 9 Anzǝm mǝnana Yesu bangŋǝnia wia cau anggo ka, pǝlǝa akrǝi zuku a Galili.
\s1 Yesu wari a ban Lamsan // mala Do aɓalǝ Agumli
\p 
\v 10 Anzǝm mǝnana amǝ'eambi umna a ban Lamsan ka, Yesu gbal ka wari ɗǝong, pusǝrǝi ɗàng.
\v 11 Aɓwana-mǝgule mala amǝ Yahudi camarǝ alte a ban Lamsan, à kǝ ɗikiban ama, <<Ɓwe nda ake le?>>
\p 
\v 12 Aɓwabundǝa kǝ nacau nggùr-nggùr amur Yesu. Aɓea ɓwana ama, <<Yì ka, ɓwa mǝɓoarne na.>>
\p Sǝ aɓea ɓwana gbal ka ama, <<Awo, yì ka, mǝ'swarkiban na.>>
\v 13 Sǝ kǝɓwa puro nacau bwāng amurí ɗàng, acemǝnana à kǝ ɓanggi aɓwana-mǝgule mala amǝ Yahudi.
\p 
\v 14 Lang à warina ɗār aɓa Lamsan, à gauwuni a tsùrú ka, Yesu kutio aɓa Ndàmǝgule mala Ɓakuli, pǝlǝa tita kani aɓwana gìr.
\v 15 Sǝ aɓwana-mǝgule mala amǝ Yahudi ka à ndali kǝ̀rkǝ́r, à na ama, <<Lang sǝ ɓwa man súrǝ̀ gir ani kǝ̀rkǝ́r, yi mǝnana kǝɓwa kani wi raka?>>
\p 
\v 16 Pǝlǝa Yesu nea wia ama:
\pi1 \wj Agir mǝnana ǝn nggǝ kania wun ngga à mem na ɗang, à puro a ban Ɓakuli mǝnana tasǝam ngga.\wj*
\v 17 \wj Ɓwa mǝnana kat earǝna ama nǝ̀ pak gìr mǝnana Ɓakuli earkiyi ce ka, nǝ̀ sǝlǝa ko kanigir mem ngga pur nǝ ban Ɓakuli, ko mala ɓamur rǝàm nda ǝn nggǝ na ka.\wj*
\v 18 \wj Ɓwa mǝnana kǝ nacau aɓa ɓamur rǝì ka, gulo mala ɓamur rǝì nda alkiyite ka, sǝ ɓwa mǝnana kǝ pak gìr ace gulo mala ɓwa mǝnana túrí ka, ɓwa mǝ'mǝsǝcau nì na, ɓe kǝgìr nyir pa a ɓālǝi ɗàng.\wj*
\v 19 \wj Musa nǝ̀ pà wun Nggurcau re? Sǝ kǝɓwa atà wun kpate ɗàng. Ace mana sǝ wu kǝ earce ama wun nǝ̀ wal-luem?\wj*
\p 
\v 20 Ɓwabunda mǝnana ram ngga ne wi ama, <<We ka, kukwar na a rǝò. Yana alkiyito ama nǝ̀ wal-luio?>>
\p 
\v 21 Pǝlǝa Yesu earia wia ama, \wj <<Ən pak gir'ndǝlǝki mwashat ɓǝ̀rɓǝ̀r a pwari Sabbat, sǝ wun kat ka wu pak ndali.\wj*
\v 22 \wj Musa pà wun Nggurcau mala kasǝ-ɓatau, kat andǝ amani ama yì nǝ̀ tite raka, aká wun nǝ̀ tite. Ace mani ka wu kǝ kasǝi muna ɓate a pwari Sabbat, pwari usǝlǝo.\wj*\f + \fr 7:22 \ft Ɓalli gbal aɓa: \xt Tite 17:10; Pǝris 12:3\xt*\ft .\f*
\v 23 \wj Ɓǝ̀ pwari mana à tsǝa ace kasǝî muna-ɓwabura ɓate, kpa a pwari Sabbat, pwari usǝlǝo ka, wu kǝ lidǝmba nǝ pe, ace mǝnana ɓǝà kǝa yàl Nggurcau mala Musa raka. Palang sǝ bum wun lúllô a rǝàm acemǝnana ǝn twali ɓwa ban rǝkwana a pwari Sabbat ka?\wj*
\v 24 \wj Wu kǝa wu pak ɓashi ace sǝn ɓamǝsǝu ɗang. Wu pak ɓashi amur gìr mǝnana mǝsǝcau na ka.>>\wj*
\s1 Yesu ka, nda Kǝrǝsti, Mǝ'amsǝban le?
\p 
\v 25 Pǝlǝa aɓea amǝ Urǝshalima na ama, <<Nggearǝ ɓwa mǝnia nda mbak aɓwana-mǝgule mala amǝ Yahudi alkiyite ama à nǝ̀ wal-luí ka re?
\v 26 Sǝ ndya came kǝ nacau a banfana ka, sǝ kǝɓwa loasǝ kun arǝì ɗàng. Ko aɓwana-mǝgule ka, à earǝna adyan ama mǝsǝcau yì ka, nda Kǝrǝsti, yì ɓwa mǝnana Ɓakuli tarrì ka le?
\v 27 Màlà mǝnia yì ɓwa ka sǝm sùrǝ́nà rǝ ban mǝnana pur kàm ngga. Sǝ ɓǝ̀ Kǝrǝsti yiu ka, kǝɓwa pà nǝ̀ súrǝ̀ ban mǝnana pur kàm ngga ɗàng.>>
\p 
\v 28 Mǝnana Yesu nda ban kanigìr aɓa Ndàmǝgule mala Ɓakuli ka, loasǝ gi kpǝm na ama, \wj <<Kàngkàng wu súrǝàm andǝ ban mǝnana ǝn pur kàm ngga? Mim ngga ǝn yiu ace cau mala ɓamur rǝàm ɗàng. Tárrám mǝnana tasǝam ngga mǝ'mǝsǝcau na. Wun ngga wu súrǝì ɗàng.\wj*
\v 29 \wj Mim ngga ǝn súrǝì, acemǝnana a baní sǝ ǝn puro, sǝ yì nǝ̀ túrǎm.>>\wj*
\p 
\v 30 Lang Yesu bangŋǝna cau man anggo ka, aɓwana-mǝgule mala amǝ Yahudi ɓariki ama à nǝ̀ bwali, sǝ kǝɓwa tsǝk bu arǝì ɗàng, acemǝnana pwari male malaká pak ɗàng.
\v 31 Sǝ aɓa mǝno anggo kat ka aɓwana pas aɓalǝ aɓwana mǝnana à ram ngga à pà ɓamuria a ban Yesu. À kǝ na ama, <<Ɓǝ̀ Kǝrǝsti, yì ɓwa mǝnana Ɓakuli tarrì, yiu ka, nǝ̀ yia pakki agir-ndǝlǝki mǝnana à kútì mana mǝnia yì ɓwa ka pakkia ka le?>>
\s1 À tasǝ amǝ yálban ɓǝà // kya bwal Yesu
\p 
\v 32 Amǝ Farisi ok ɓwabundǝa aban sherǝ amǝnia yì acau ka amur Yesu, pǝlǝa yia andǝ agbani pǝris tasǝ amǝ'yál Ndàmǝgule mala Ɓakuli ama ɓǝà kya bwali.
\p 
\v 33 Yesu nea wia ama, \wj <<Mǝ ndakani ado atà wun zuku, sǝ mǝ nǝ nyare mǝ nǝ o a ban Tárrám mǝnana tasǝam ngga.\wj*
\v 34 \wj Wun nǝ̀ altam, sǝ pa wu nǝ̀ kumam ɗang; sǝ ban mǝnana mǝ ndakam ngga pa wu nǝ̀ gandǝ ká kàm ɗàng.>>\wj*
\p 
\v 35 Sǝ aɓwana-mǝgule mala amǝ Yahudi nacau arǝarǝia ama, <<Nggearǝì ka, ake sǝ nǝ̀ ká le, mǝnana pà sǝm nǝ̀ sǝni raka? Ko nǝ̀ ká a ban aɓwana ma'sǝm mǝnana à mesǝkea arǝ alá mala amǝ Gǝrik ka, sǝ nǝ̀ nggá kània amǝ Gǝrik agir gbal le?
\v 36 Sǝ ɓālǝi aman, yi mǝnana na ama, sǝm nǝ̀ alte sǝ pà sǝm nǝ̀ kumi ɗàng; sǝ ɗǝm ngga na ama, ban mǝnana ndakam ngga pà sǝm nǝ̀ gandǝ ká kàm ɗàng?>>
\s1 Mùr mǝnana kǝ pa yilǝmu ka
\p 
\v 37 A masǝlǝata pwari, mǝnana ndà pwari mǝgule mala Lamsan ngga, Yesu lo came sǝ loasǝ gì kpǝm na ama, \wj <<Ɓwa mǝnana kat kǝ ok mǝsamur ka ɓǝ̀ yiu a banam ɓǝ̀ yi nu.\wj*\f + \fr 7:37 \ft Ɓalli gbal aɓa: \xt Pǝris 23:36\xt*\ft .\f*
\v 38 \wj Ɓwa mǝnana kat pà ɓamur rǝì a banam ngga, a bumi sǝ amealmur mala mùr mǝpà yilǝmu nǝ̀ puro, à nǝ̀ nggǝ ɓangŋa, kǝla mǝnana Malǝmce na ka.>>\wj*\f + \fr 7:38 \ft Ɓalli gbal aɓa: \xt Ezǝk 47:1; Zak 14:8\xt*\ft .\f*
\v 39 Yesu ndaban nacau amur kǝ Bangŋo mǝnana aɓwana mana à pà ɓamuria a baní ka, à nǝ̀ nggá kum ngga. Sǝ a pwari mǝno gbal anggo ka à malaká pà Bangŋo nì ɗàng, acemǝnana Yesu malaká loapi ɓembe kutia aɓa gulo male peatu raka.
\s1 Kun aɓwana gaki amur Yesu
\p 
\v 40 Lang à nǝ̀ ok cau mǝnana Yesu na ka, aɓea ɓwana na ama, <<Mǝsǝcau na, mǝnia yì ɓwa ka nda Mǝɓangnǝa mala Ɓakuli mǝnana sǝm kundǝkiyi ka.>>
\p 
\v 41 Sǝ aɓea ɓwana na ama, <<Kǝ yì nda Kǝrǝsti, Mǝ'amsǝban.>> Aɓea ɓwana bang ama, <<Palang sǝ Kǝrǝsti ka nǝ̀ pur a Galili?
\v 42 Malǝmce na ama, Kǝrǝsti Mǝ'amsǝban ngga nǝ̀ pur a tàu mala Dauda, sǝ à nǝ̀ ɓǝli a Betalami, la mǝnana Dauda dukam ngga.>>\f + \fr 7:42 \ft Ɓalli gbal aɓa: \xt 2Sam 7:12; Mik 5:2\xt*\ft .\f*
\v 43 Kara kun aɓwana gakina amur Yesu.
\v 44 Aɓea aɓwana ka eare malea ka à nǝ̀ bwal Yesu, sǝ kǝɓwa gandǝ tsǝk bu arǝì ɗàng.
\s1 Ɗwanyi pa ɓamuru mala aɓwana // mǝgule mala amǝ Yahudi
\p 
\v 45 Sǝ lang amǝ'yál Ndàmǝgule nyarǝna ka, agbani pǝris andǝ amǝ Farisi ɗia ama, <<Palang sǝ wu bwali wu yinǝi ɗàng?>>
\p 
\v 46 Amǝ'yálban banggia wia ama, <<Kǝɓwa pà kàm mǝnana kǝ nacau kǝla mala mǝnia yì ɓwa ka ɗàng.>>
\p 
\v 47 Sǝ amǝ Farisi pǝlǝa à nea wia ama, <<Wun gbal ka yi ɓosǝkina ta kun wun le?
\v 48 Wu ok àkǝ̀ pwari ama kǝɓwa aɓalǝ aɓwana-mǝgule mala amǝ Yahudi ko amǝ Farisi, pà ɓamúrì a baní le?
\v 49 Sǝ ɓwabundǝa mǝnia à kǝ gyate ka, à súrǝ̀ Nzongcau mala Musa raka, à nda a ɓata súban mala Ɓakuli!>>
\p 
\v 50 Nikodimus ndakam a banì. Yì ka, nda aɓalǝ amǝ Farisi, amǝ kùrcau, sǝ nda ɓwamǝgule mǝnana wari a ban Yesu ɗiɗyal ka. Ɗiban ama,\f + \fr 7:50 \ft Ɓalli gbal aɓa: \xt Yoh 3:1-2\xt*\ft .\f*
\v 51 <<Nggearǝì ka, Nggurcau ma'sǝm eara sǝm ama ɓǝ̀ sǝm kasǝ ɓashi amur ɓwa mǝnana à ok kǝcau a kúni, sǝ sǝm súrǝ̀ gir mǝnana pàk la raka le?>>
\p 
\v 52 Sǝ à pe wi eare ama, <<Tino, we gbal ka a pur nǝ Galili le? Kyane kya bǝlki ɓá Malǝmce ɓukɓuk sǝ awu nǝ sǝlǝ ama kǝ mǝɓangnǝa pa nǝ̀ pur a Galili ɗàng.>>
\p 
\v 53 [Sǝ koyan le ka nyare o a ɓala male.
\c 8
\s1 Yesu twalî ɓè ɓwama // ban cauɓikea male
\p 
\v 1 Yesu ka, eau amur Nkono mala anggun Olif.
\v 2 Ban fana nǝ tadǝmbari ka, nyare wari a Ndàmǝgule mala Ɓakuli. Sǝ ɓwapǝndǝa yiu ramba a baní, pǝlǝa do tita kania wia gìr.
\v 3 Amalǝm Nggurcau mala Musa andǝ amǝ Farisi yiu nǝ ɓe ɓwama mǝnana à bwalia amur rǝarǝia andǝ ɓe ɓwabura ka, sǝ à yì tamsǝi a ɓadǝm ɓwapǝndǝa.
\v 4 À ɗì Yesu ama, <<Malǝm, ɓwama man ngga à bwali amur rǝarǝia andǝ ɓwabura.
\v 5 \f + \fr 8:5 \ft Ɓalli gbal aɓa: \xt Pǝris 20:10; Nggur 22:22-24\xt*\ft .\f* Nggurcau mala Musa bang ama ɓwama mǝnana pàk ulang man yì gìr ka, ɓǝà ɓukki nǝ atali ɓǝ̀ wú. Sǝ ado ka, mana a na amurí?>>
\v 6 Ɗiban mǝnia aɓwana ɗì Yesu ka, gbǝ́lî na à dambi Yesu ka, acemǝnana ɓǝ̀ na ɓekǝ cau sǝ à nǝ̀ bwali nǝi ka.
\p Sǝ Yesu ka kū`ndǝó kǝ gilǝgir a nzali nǝ munabuì.
\v 7 Lang à camarǝ ɗike ka, pǝlǝa loasǝ múrí sǝ nea wia ama, \wj <<Ɓwa mǝnana atà wun pànǝ cauɓikea raka, ɓǝ̀ tita túr tali.>>\wj*
\v 8 Sǝ nyare kū`ndǝó aban gilǝgir a nzali.
\v 9 Lang amalǝm nggurcau andǝ amǝ Farisi ongŋǝna cau mǝnana Yesu na ka, kara à purkî banì mwashat-mwashat, tite a ban ɓwamǝgule. Sǝ à nying Yesu nǝmurǝì andǝ ɓwame aban came aɓalǝ aɓwana.
\p 
\v 10 Yesu lo cam nǝ came, sǝ ɗì ɓwame ama, \wj <<Aɓwana mǝnana à yiu nǝ we ka, à nda ke le? Kǝɓwa pà kàm ateà mǝnana ueo nǝ̀ pakko ɓashi-lú ka re?>>\wj*
\p 
\v 11 Pǝlǝa eare ama, <<Awo, Ɓwamǝgule, kǝɓwa pà kàm ɗàng.>>
\p Yesu banggi wi ama, \wj <<Nggearǝ mim gbal ka ǝn kasǝò ɓashi-lú ɗàng. Kyane, sǝ kǝa pak cauɓikea ɗǝm ɗàng.>>\wj*]
\s1 Yesu nda tǎlaban mala ɓanza
\p 
\v 12 Yesu nyar ɗǝm banggi aɓwana ama, \wj <<Mǝ nda tǎlaban mala ɓanza! Ɓwa mǝnana kat kpatam ngga, pà nǝ̀ gya aɓa pǝndǝa ɗang, nǝ̀ kum tǎlaban mala yilǝmu.>>\wj*\f + \fr 8:12 \ft Ɓalli gbal aɓa: \xt Mat 5:14; Yoh 9:5\xt*\ft .\f*
\p 
\v 13 Amǝ Farisi ne wi ama, <<Ado ka a ndaban nakún ɓamuro, cau mò ka à pà nǝ̀ é ama mǝsǝcau na ka ɗàng.>>\f + \fr 8:13 \ft Ɓalli gbal aɓa: \xt Yoh 5:31\xt*\ft .\f*
\p 
\v 14 Sǝ Yesu nea wia ama:
\pi1 \wj Ko ɓǝ̀ ǝn nakún ɓamúràm ngga, cau mem ngga à nǝ̀ earnǝi, acemǝnana ǝn súrǝ́nà rǝ ban mǝnana ǝn pur kàm ngga, sǝ ǝn súrǝ́nà rǝ ban mǝnana mǝ nǝ ká kàm ngga. Sǝ wun ngga, wu súrǝ̀ ban mǝnana ǝn pur kàm, andǝ ban mǝnana mǝ nǝ ká kàm ngga ɗàng.\wj*
\v 15 \wj Wu kǝ pak ɓashi aɓa nggūrǝu, sǝ mim ngga ǝn nggǝ ɓashi kǝɓwa ɗàng.\wj*
\v 16 \wj Sǝ ɓǝà na ama ǝn nggǝ pak ɓashi ka, ɓashi mem ngga mǝsǝcau na, acemǝnana ǝn pa nǝmurǝam atà ɓashi ɗàng, Tárrám mǝnana tasǝam ngga nda atàm.\wj*
\v 17 \wj Nggurcau ma'wun bang ama, ɓǝ̀ kún aɓwana ɓari yiu mwashat amur cau ka, cê ka mǝsǝcau na.\wj*\f + \fr 8:17 \ft Ɓalli gbal aɓa: \xt Nggur 19:15\xt*\ft .\f*
\v 18 \wj Sǝ mim ngga, ǝn nakún ɓamúràm, sǝ Tárrám mǝnana tasǝam ngga nakunam gbal.\wj*
\p 
\v 19 Sǝ à ɗì ama, <<Tárró na ake?>>
\p Pǝlǝa Yesu earia wia ama, \wj <<Wu súrǝàm ɗang, sǝ wu súrǝ̀ Tárrám ɗang. Ɓǝ̀ wu sùrǝ́nà rǝam ngga, ɓǝ́ wu sùrǝ́nà rǝ Tárrám gbal.>>\wj*
\p 
\v 20 Yesu naki amǝnia yì acau ka mǝnana nda rǝ kanigir a buban mǝnana à kǝ tsǝk boalo kam andǝ agir mǝɓoarne aɓa Ndàmǝgule mala Ɓakuli ka. Sǝ kǝɓwa bwali ɗàng, acemǝnana pwari male malaká karǝ ɗang.
\p 
\v 21 Yesu nea wia ɗǝm ama, \wj <<Mǝ ndo mǝ nǝ o; ɓǝn umna ka, wu nǝ̀ altam, sǝ wu nǝ̀ wú aɓalǝ acauɓikea ma'wun. Pa wu nǝ̀ gandǝ ká aban mǝnana mǝ nǝ ká kam ngga ɗang.>>\wj*
\p 
\v 22 Pǝlǝa aɓwana-mǝgule mala amǝ Yahudi ɗiban ama, <<Nggearǝì ka nda ban earce nǝ̀ wal ɓamúrì le? Mana tsǝa sǝ na ama, pà sǝm nǝ̀ gandǝ ká aban mǝnana nǝ̀ ká kam ngga ɗang?>>
\p 
\v 23 Yesu ear ama, \wj <<Tǝta wun ngga a ɓanza mǝnia a nzali ka sǝ pa, sǝ mim ngga ǝn pur nǝ kuli. Wu nda ka mala ɓanza man, sǝ mim ngga mǝ nda mala ɓanza man ɗang.\wj*
\v 24 \wj Nda gir mǝnana tsǝa sǝ ǝn na wun ama wu nǝ̀ wú aɓalǝ acauɓikea ma'wun ngga; ɓǝ̀ wu earnǝ mim ama Mǝ Nda\wj*\f + \fr 8:24 \fq Mǝ Nda: \ft Aban amǝ Yahudi ka lullǝu mana karban kat nǝ fele à tunǝ Ɓakuli nǝi ka nda <<Yahweh,>> sǝ ɓālǝi ka nda <<Mǝ nda.>> Arǝ aɓea ban aɓa Cau Amsǝban a nê mala Yohana ka, Yesu pak túró nǝ <<Mǝ Nda>> ace mǝnana ɓǝ̀ lǝmdǝ ama yì nda ɓwe.\f*\wj ɓwa mǝnana ǝn na nǝma Mǝ Nda ka raka, wu nǝ̀ wú aɓalǝ acauɓikea ma'wun.>>\wj*
\p 
\v 25 Pǝlǝa à ɗì Yesu ama, <<A nda yana?>>
\p Sǝ Yesu earia wia ama, \wj <<Mǝ nda kǝ ɓwa mǝnana ǝn na wun a dǝmbe nǝma mǝ nda ka.\wj*
\v 26 \wj Mǝ ndanǝ acau pas amur wun, mǝnana mǝ nǝ ɓashia wun nǝia ka, sǝ pa mǝ nǝ pè ɗàng. Tárrám mǝnana tasǝam ngga mǝ'mǝsǝcau na, sǝ ǝn nggǝ ne ɓanza gir mǝnana ǝn ok a kúni ka.>>\wj*
\p 
\v 27 Sǝ kǝɓwa sǝlǝa ateà ama Yesu na ban nea wia cau amur Tárrí Ɓakuli ɗang.
\v 28 Ace mǝno ka, Yesu nea wia ama, \wj <<A pwari mǝnana wu loasǝna Muna mala Ɓwa a kùli amur nggun-gangndǝi ka, akanó sǝ wun nǝ̀ sǝlǝ ama Mǝ Nda ɓwa mǝnana ǝn na wun nǝma Mǝ Nda ka. A pwari mǝno sǝ wun nǝ̀ sǝlǝ gbal ama ǝn nggǝ pak kǝgìr aɓa rǝcandǝa mem ɗàng. Kǝ gìr mǝnana Tárrám kaniam ngga kǝ nda ǝn nggǝ na ka.\wj*
\v 29 \wj Ɓwa mǝnana tasǝam ngga nda atàm; nyem nǝmurǝam ɗàng. Acemǝnana koya pwari ka ǝn nggǝ pak gìr mǝnana kǝ pwasǝbumi ka.>>\wj*
\v 30 Pas atà aɓwana mǝnana à ok Yesu aban na amǝnia yì acau ka à pà ɓamuria a baní.
\s1 Kǝ mǝsǝcau nda nǝ̀ panzǝ wun ngga
\p 
\v 31 Yesu ne aɓwana mǝnana à pà ɓamuria a baní ka ama, \wj <<Ɓǝ̀ wu kpata kanigir mem ngga, wu nda ka amǝkpatam amǝ'mǝsǝcau nì.\wj*
\v 32 \wj Sǝ wun nǝ̀ súrǝ̀ mǝsǝcau, sǝ mǝsǝcau ka nǝ̀ panzǝki wun.>>\wj*
\p 
\v 33 Pǝlǝa à eari wi ama, <<Sǝm ngga, sǝm nda ka amǝkau mala Ibǝrayim, sǝm duk aguro mala kǝɓwa àkǝ̀ pwari ɗàng. Lang sǝ a nǝ na sǝm ama à nǝ̀ panzǝ sǝm?>>\f + \fr 8:33 \ft Ɓalli gbal aɓa: \xt Mat 3:9; Luk 3:8\xt*\ft .\f*
\p 
\v 34 Yesu nea wia ama:
\pi1 \wj Mǝ nda ban na wun mǝsǝcau, ɓwa mǝnana kat kǝ pak cauɓikea ka, guro mala cauɓikea na.\wj*
\v 35 \wj Guro pà nǝ̀ do a ɓala nǝ̀ ue kam ɗàng, sǝ muna ka, mala ɓala na, do male a ɓala ka pà nǝ́ masǝlǝate ɗàng.\wj*
\v 36 \wj Ɓǝ̀ Muna mala Ɓakuli nǝ̀ panzǝo ka, panzǝban mò ka mǝ'mǝsǝcaunì na.\wj*
\v 37 \wj Ən sǝlǝna ama wu nda ka amǝkau mala Ibǝrayim, sǝama wu kǝ earce walam, acemǝnana wu eari cau mem ɓǝ̀ kum ban-do a ɓabum wun ɗàng.\wj*
\v 38 \wj Mim ngga ǝn nggǝ bang gìr mǝnana ǝn sǝni aban Tárrám ngga. Sǝ wun ngga wu kǝ pak gìr mǝnana tár wun kǝ na wun ngga.\wj*
\p 
\v 39 Sǝ à eare ama, <<Ibǝrayim nda kà-sǝm.>>
\p Yesu nea wia ama, \wj <<Ɓǝ̀ kàngkàng wu nda ka amǝkau mala Ibǝrayim ngga, wun nǝ̀ pak agir mǝnana Ibǝrayim pea ka.\wj*
\v 40 \wj Wu kǝ earce ama wun nǝ̀ wal-luem, acemǝnana ǝn bangga wun mǝsǝcau mana ǝn o a kún Ɓakuli ka. Sǝ Ibǝrayim pak kǝgìr anggo ɗàng.\wj*
\v 41 \wj Wu nda rǝ pak gìr mǝnana nggearǝ tár wun pakkiyi ka.>>\wj*
\p Amǝ Yahudi ne wi ama, <<Ɓakuli nda kǝ Tár sǝm, sǝm nda ka muna tà-jam ɗang.>>
\p 
\v 42 Sǝ Yesu nea wia ama:
\pi1 \wj Ɓǝ̀ tár wun nda Ɓakuli ka, wun nǝ̀ earcem, acemǝnana ǝn pur aban Ɓakuli, sǝ ado ka mǝ ndakani. Ən yipì ɓamúràm ɗàng, Ɓakuli nǝ̀ túrǎm.\wj*
\v 43 \wj Man tsǝa sǝ wu bwalta acau mǝnana ǝn nggǝ na wun ngga ɗàng? Nda ace mǝnana wu gandǝ ok cau mem ɗàng.\wj*
\v 44 \wj Wun nda ka muna mala tár wun yì Shetan, sǝ wu kǝ earce lumsǝî tár wun kún atúró male. Yì ka, tita walki-alú ɗiɗyal, sǝ kǝ earce mǝsǝcau ɗàng, acemǝnana mǝsǝcau pà aɓalǝi ɗàng. Ɓǝ̀ ndarǝ na nyir ka nda ban lǝmdǝ girbui, acemǝnana yì ka, mǝ nyir na, sǝ nda tár amǝ nyir kat.\wj*
\pi1 
\v 45 \wj Sǝ acemǝnana ǝn nggǝ na mǝsǝcau ka, wu earnǝ mim ɗang.\wj*
\v 46 \wj Yana atà wun nǝ̀ lǝmdǝ buì arǝ kǝ cauɓikea mǝnana ǝn pê ka? Sǝ ɓǝ̀ mǝsǝcau na ǝn nggǝ bang ngga, mana tsǝa sǝ wu ginǝ earnǝ mim?\wj*
\v 47 \wj Ɓwa mǝnana mala Ɓakuli na ka kǝ kwakikiri arǝ cau mala Ɓakuli. Sǝ wun ngga wun nda ka mala Ɓakuli ɗang, nda gìr mǝnana tsǝa sǝ wu kǝ kwaki kir wun arǝì raka.\wj*
\s1 Yesu akì Ibǝrayim dǝmba
\p 
\v 48 Sǝ aɓwana-mǝgule mala amǝ Yahudi ɗì Yesu ama, <<Cau mǝnana sǝm na ama a nda ɓwa Samariya sǝ kukwar nda arǝò ka mǝsǝcau na re?>>
\p 
\v 49 Pǝlǝa Yesu nea wia ama, \wj <<Ən panǝ kukwar arǝàm ɗang. Ən nggǝ pê Tárrám gulo sǝ wu kǝ nyesǝam ɓà.\wj*
\v 50 \wj Ən pa aban alita ɓamúràm gulo ɗang. Tárrám na kǝ alamta gulo ka, sǝ yì nda ɓwa mǝnana pakkiyi ɓashi mǝ'mǝsǝcau nì ka.\wj*
\v 51 \wj Mǝ nda ban bangga wun mǝsǝcau, ɓwa mǝnana kǝ kpata cau mem ngga pà nǝ̀ wu ɗàng.>>\wj*
\p 
\v 52 Pǝlǝa aɓwana-mǝgule mala amǝ Yahudi ne wi ama, <<Ado sǝ sǝm sǝlǝa aɓa mǝsǝcau ama, a ndanǝ kukwar arǝò! Nggearǝ Ibǝrayim ngga wǔ, sǝ amǝ'ɓangnǝa mala Ɓakuli wú, pǝlǝa a nǝ yia na sǝm ama, <Ɓǝ̀ ɓwa kpata cau mem ka pà nǝ̀ wu ɗang.>
\v 53 A kútì kà-sǝm Ibǝrayim le? Yì ka, wǔ, sǝ amǝ'ɓangnǝa mala Ɓakuli gbal ka à wǔ. Sǝ we ka a kǝ sǝni kǝla a nda yana?>>
\p 
\v 54 Yesu earia wia ama, \wj <<Ɓǝ̀ ǝn pê ɓamúràm gulo ka, gulê pà a kún kǝgìr ɗàng. Sǝ Tárrám mǝnana wu kǝ twali ama nda Ɓakuli ma'wun ngga, nda mǝnana pākiyam gulo ka.\wj*
\v 55 \wj Wun ngga wu súrǝì ɗàng, sǝ mim ngga ǝn súrǝì. Ɓǝ̀ ǝn na ama ǝn súrǝì raka, mǝ nda mǝ'nyir kǝla wun. Sǝ mim ngga ǝn súrǝì, sǝ ǝn nggǝ kpata cau male.\wj*
\v 56 \wj Kà wun Ibǝrayim ngga, pak banɓoarnado ama nǝ̀ sǝn pwari yiu mem, pǝlǝa sǝni sǝ bumi pwasǝo.>>\wj*
\p 
\v 57 Pǝlǝa amǝ Yahudi banggi Yesu ama, <<A malaká bwal pǝlǝa lumi-tongno ɗang, sǝ lang sǝ a nǝ na ama a sǝn Ibǝrayim?>>
\p 
\v 58 Yesu earia wia ama, \wj <<Mǝ nggǝ bangga wun mǝsǝcau, kaniama à nǝ̀ ɓǝl Ibǝrayim ngga, <Mǝ ndakam.\wj*>\f + \fr 8:58 \fq Mǝ ndakam: \ft Mǝnia yì cau ama <<Mǝ ndakam>> ko <<Mǝ nda>> ka lǝmdǝ ama Yesu na arǝ na ama yì ka, Ɓakuli na, kǝla mana Ɓakuli tunǝ ɓamúrì ama <<Mǝ nda>> aɓa malǝmce \xt Pur 3:14\xt*\ft ka.\f*>>
\v 59 À nǝ̀ ok mǝno yì cau ka, kara à pwan atali ama à nǝ̀ ɓukki, sǝ Yesu gbar rǝì, pǝlǝa puro nying Ndàmǝgule mala Ɓakuli.
\c 9
\s1 Yesu mǝn mǝsǝ ɓwa mana // à ɓǝlì nte na ka
\p 
\v 1 Yesu nda ban kutio pǝlǝa sǝn ɓeɓwa mǝnana à ɓǝlì nte na ka.
\v 2 Alaggana male ɗì ama, <<Malǝm, cauɓikea mala yana tsǝa sǝ à ɓǝl ɓwa mǝnia ka nte? Cauɓikea male na le, ko mala angge na andǝ tárrí?>>\f + \fr 9:2 \ft Ɓalli gbal aɓa: \xt Luk 13:2; Atúró 28:4; Ezǝk 18:20; Pur 20:5\xt*\ft .\f*
\p 
\v 3 Yesu nea wia ama, \wj <<Pà ace cauɓikea male, ko mala tárrí andǝ ngge sǝ à ɓǝlì nte na ka ɗàng. À ɓǝlì anggo ace mǝnana ɓǝa lǝmdǝ túró mala Ɓakuli amurí.\wj*\f + \fr 9:3 \ft Ɓalli gbal aɓa: \xt Yoh 11:4\xt*\ft .\f*
\v 4 \wj Ado mǝnana pwari ndakam ngga, dumǝna púp sǝm nǝ̀ pak túró mala Tárrám mǝnana tasǝam ngga. Dù nda kǝ yiu, mǝnana kǝɓwa pà nǝ̀ pak túró raka.\wj*
\v 5 \wj Ado mǝnana mǝ nda a ɓanza ka, mǝ nda tǎlaban mala ɓanza.>>\wj*\f + \fr 9:5 \ft Ɓalli gbal aɓa: \xt Mat 5:14; Yoh 1:4; 8:12; 12:46\xt*\ft .\f*
\p 
\v 6 Lang Yesu naná cau anggo ka, pǝlǝa tau ntāra a nzali sǝ torǝi pǝlǝ dǝɓang, sǝ hasǝì ɓwabure arǝ amǝsǝì.
\v 7 Sǝ ne wi ama, \wj <<Kyane kya lak ɓamǝsǝo a guguri Silowam.>>\wj* (Silowam ngga ɓālǝi nda <<Mǝnana à tàsǝì ka.>>) Pǝlǝa ɓwabure wario, kya lak ɓamǝsǝi. Nǝ̀ nyar ka amǝsǝì longŋǝna à nǝ̀ nggǝ sǝnban.
\p 
\v 8 Aɓi amǝ njarmurkala andǝ aɓwana mǝnana à súrǝì ama mǝ zǝmgi agir na ɗiɗyal ka, à ɗì rǝia ama, <<Ɓwa mǝnia ka nda mbo dukiyi kani aban zǝmgi agir ka?>>
\v 9 Aɓea ɓwana na ama, <<Kǝ nda.>>
\p Sǝ aɓea ɓwana bang ama, <<Awo, nda ɗang, à pur rǝia nǝ puro.>>
\p Ɓwabure nǝ ɓamúrì pǝlǝa nea wia ama, <<Mǝ nda kǝ ɓwe.>>
\p 
\v 10 Pǝlǝa à ɗì ama, <<Sǝ kar lang, sǝ a kǝ sǝnban?>>
\p 
\v 11 Earia wia ama, <<Ɓwa mǝnana à tunǝki ama Yesu ka, nda torǝ dǝɓang sǝ hasǝami arǝ amǝsǝam, sǝ nam ama, ɓǝ̀ ǝn kya guguri Silowam mǝ lak ɓamǝsǝam kam. Pǝlǝa ǝn wario, ǝn lak mǝsǝam, nda sǝ ǝn tita sǝnban ngga.>>
\p 
\v 12 À ɗì ama, <<Ɓwe ka nda a ke?>>
\p Pǝlǝa nea wia ama, <<Ən sǝlǝ ɗang.>>
\s1 Amǝ Farisi bǝlkusǝ twalban // rǝkwana mala nte
\p 
\v 13 Pǝlǝa à twal ɓwabura mǝnia mǝnana nte na ɗiɗyal ka, à wari nǝi a ban amǝ Farisi,
\v 14 acemǝnana pwari mǝno Yesu torǝna dǝɓang nǝi sǝ hasǝi ɓwabure arǝ amǝsǝì, sǝ amǝsǝì mǝn ngga, pwari Sabbat na, pwari usǝlǝo mala amǝ Yahudi.
\v 15 Pǝlǝa amǝ Farisi nyare à ɗì ɓwabure lang sǝ kum sǝnban male. Pǝlǝa nea wia ama, <<Hasǝam dǝɓang arǝ amǝsǝam, ǝn lak ɓamǝsǝam, sǝ ado ka ǝn nggǝ sǝnban.>>
\p 
\v 16 Aɓea amǝ Farisi na ama, <<Mǝnia yì ɓwa yì Yesu ka, pur nǝ ban Ɓakuli ɗang, acemǝnana gusǝlǝ Sabbat ɗang.>>
\p Sǝ aɓea ɓwana ɗiban ama, <<Lang sǝ mǝ'cauɓikea nǝ pak a'ulang amǝnia yì agir-ndǝlǝki ka le?>> Kara aɗenyicau malea ginggia rǝia ɗàngɗáng.
\p 
\v 17 Anzǝm man ngga pǝlǝa à nyare a ban ɓwabure à ɗì ɗǝm ama, <<We ado ka, mana a na amur mǝno yì ɓwa mǝnana mǝnbo amǝsǝo ka?>>
\p Pǝlǝa earia wia ama, <<Yì ka, mǝɓangnǝa mala Ɓakuli na.>>
\p 
\v 18 Aɓwana-mǝgule mala amǝ Yahudi ka, à ear ama mǝnia yì ɓwa ka nte na ɗiɗyal sǝ ado ka kǝ sǝnban ɗang. Pǝlǝa a túrban ɓǝa tunǝ tárrí andǝ ngge.
\v 19 Sǝ à ɗia ama, <<Mǝnia yì muna ka wun nǝ̀ ɓǝlì le? Wu na ama à ɓǝlì ka nte na? Sǝ kar lang ado sǝ kǝ sǝnban?>>
\p 
\v 20 A tárrí andǝ ngge eare ama, <<Sǝm sǝlǝna ama muna ka ma'sǝm na, sǝ sǝm sǝlǝna gbal ama sǝm ɓǝlì ka nte na.
\v 21 Sǝ cau mala sǝnban male andǝ ɓwa mǝnana mǝnbi wi amǝsǝì ka, sǝm sǝlǝ ce ɗang. Wu ɗì, kārǝ́na ɓwa, nǝ̀ gandǝ na kúni.>>
\v 22 Atarrí andǝ ngge ka à na mǝnia yì cau anggo acemǝnana à kǝ ɓanggi aɓwana-mǝgule mala amǝ Yahudi. Amǝnia yì aɓwana-mǝgule ka à bangŋǝna a dǝmba ama, ɓwa mǝnana earnǝ Yesu ama nda Kǝrǝsti Mǝ'amsǝban ngga, à nǝ̀ pǝri pà nǝ̀ nggǝ yiu aɓa ndakpapi ɗǝm ɗàng.
\v 23 Nda gìr mǝnana tsǝa sǝ à na ama, <<Wu ɗì, acemǝnana yì ka, kārǝ́na ɓwa>> ka.
\p 
\v 24 Aɓwana-mǝgule nyar ɓaria à tunǝ ɓwa mǝno nte na ɗiɗyal ka, sǝ à ne wi ama, <<Pe Ɓakuli gulo, na sǝm mǝsǝcau! Sǝm sǝlǝna ama ɓwabura mǝnana mǝnbo amǝsǝo ka mǝ'cauɓikea na.>>
\v 25 Ɓwabure earia wia ama, <<Ən sǝlǝ ɗang ko mǝ'cauɓikea na, ko mǝ'cauɓikea na ɗang. Gìr mǝnana ǝn sǝlǝ ka nda mǝnana ama, ɗiɗyal ka mǝ nda nte, sǝ ado ka ǝn nggǝ sǝnban.>>
\v 26 À ɗì ɗǝm ama, <<Pakko lang sǝ mǝnbo amǝsǝo?>>
\p 
\v 27 Sǝ earia wia ama, <<Ən nanà wun mǝni, sǝ wu ginǝ kwaki kir wun. Ace mana sǝ wu kǝ earce oe ɗǝm? Wu kǝ earce wun nǝ̀ pǝlǝ amǝkpate gbal le?>>
\p 
\v 28 Kara à lo a rǝi nǝ sanggiban, à ne wi ama, <<A nda mǝnana a kpakiyi atà mǝno yì ɓwa ka, sǝm ngga sǝm nda ka amǝkpata Musa.
\v 29 Sǝm sǝlǝna ama, Ɓakuli nacau nǝ Musa, sǝ mala ɓwabura mǝno ka, yàle sǝm súrǝ̀ ban mǝnana pur kam ngga ɗàng!>>
\p 
\v 30 Sǝ ɓwabure banggia wia ama, <<Kúk! Wu okam kǝcau. Wu súrǝ̀ ban mǝnana pur kam ngga ɗàng, sǝ gandǝ mǝnbam amǝsǝam!
\v 31 Sǝm sǝlǝna ama, Ɓakuli pakkiyi gir mǝnana amǝ'cauɓikea na ama ɓǝ̀ pakkia wia ka ɗàng; sǝama ɓǝ̀ kǝɓwa kǝ pe Ɓakuli gulo sǝ kǝ kpata gìr mǝnana kǝ earce ama ɓǝa pe ka, Ɓakuli nǝ̀ kwakikiri nǝ̀ oki wi.
\v 32 Twal a share ta ɓanza ka, sǝm o àkǝ pwari ama kǝɓwa gandǝ mǝn mǝsǝ kǝɓwa mǝnana à ɓǝli nte na ka ɗàng.
\v 33 Ɓǝ̀ man yì ɓwa ka pur a ban Ɓakuli raka, pà nǝ̀ gandǝ pe ɗàng.>>
\p 
\v 34 Pǝlǝa à ne wi ama, <<We mǝnana gbal à ɓǝ̀lo aɓa cauɓikea, sǝ à gulo aɓa cauɓikea ka, a kǝ ɓariki ama, awu nǝ kania sǝm gìr?>> Kara à pǝrì purî ɓá ndakpapi.
\s1 Do nte aɓa bangŋo
\p 
\v 35 Lang Yesu ok ce gìr mǝnana à pakki ɓwabure ka, kya kum ɓwabure sǝ ɗì ama, \wj <<A earǝna nǝ Muna mala Ɓwa le?>>\wj*
\p 
\v 36 Ɓwabure eari wi ama, <<Ɓwamǝgule, banggàm, yana ɓwe nda Muna mala Ɓwa, ace mǝnana ɓǝ̀n earnǝi ɓǝ̀n pà ɓamúràm a baní?>>
\p 
\v 37 Yesu ne wi ama, \wj <<A angŋa dǝmba a sǝnǝni, mǝ nda kǝ ɓwe mǝnana ado ǝn nakiyio cau ka.>>\wj*
\p 
\v 38 Kara ɓwabure kū`ndǝó a ɓadǝm Yesu peri, sǝ na ama, <<Mǝtalem, e, ǝn earǝna, ǝn panà ɓamúràm a bano.>>
\p 
\v 39 Pǝlǝa Yesu na ama, \wj <<Ən yiu aɓa ɓanza man ace ɓashi, ace mǝnana ɓǝ̀ ante kum sǝnban, sǝ aɓwana mǝnana à kǝ sǝnban ngga, ɓǝa pǝlǝ ante.>>\wj*\f + \fr 9:39 \ft Ɓalli gbal aɓa: \xt Yoh 5:27; 3:19; Mat 15:14\xt*\ft .\f*
\p 
\v 40 Aɓea amǝ Farisi mana aban came tù a banì ka, ok cau mǝnana Yesu na ka, pǝlǝa à ɗì ama, <<A nda ban na ama, sǝm nda ka nte le?>>
\p 
\v 41 Sǝ Yesu pǝlǝia wia ama, \wj <<Ɓǝ̀ wu nda ka nte ka, ɓǝ́ mur wun pà nǝ̀ halǝki wun arǝ acauɓikea ma'wun ɗàng. Sǝ mǝno ado wun ne nǝ ɓamurǝ wun ama wun nǝ̀ nggǝ sǝnban ngga, lǝmdǝna ama, cauɓikea ma'wun ngga nda kam amur wun più.>>\wj*
\c 10
\s1 Yálgír mǝɓoarne andǝ anzur male
\p 
\v 1 Yesu na ama:
\pi1 \wj Mǝ nda ban bangga wun mǝsǝcau, ɓwa mǝnana kútí aɓa domwan mala anzur nǝ kun-nda raka, sǝ kútí nǝ ɓekǝ njar ɗàng ngga, mǝn'í na sǝ mǝɓǝmbǝriban na.\wj*\f + \fr 10:1 \ft Ɓalli gbal aɓa: \xt Mar 6:34\xt*\ft .\f*
\v 2 \wj Sǝ ɓwa mǝnana kútì nǝ kun-nda ka, nda mǝ'yál anzur.\wj*
\v 3 \wj Mǝtsǝkir kun-nda nǝ̀ mǝnbi wi kun-nda; anzur nǝ̀ ok gi mǝ'yália ɓǝ̀ tunǝia nǝ lullǝia ka, sǝ nǝ̀ kà nǝia a nza.\wj*
\pi1 
\v 4 \wj Anzǝm mǝnana pusǝna anzur male kat a nza ka, kǝ upia wia a dǝmba, sǝ anzur kǝ kpate acemǝnana à sùrǝ́nà rǝ gi.\wj*
\v 5 \wj Anzur pa nǝ̀ gya atà bǝri-ɓwa ɗang; à nǝ̀ ɓanggi wi, acemǝnana à súrǝ̀ gi ɗàng.\wj*
\p 
\v 6 Yesu nea wia man yì cau aɓa ɓi, sǝ yia ka à bwalta gìr mǝnana nakiyi ka ɗàng.
\p 
\v 7 Ace mǝno ka Yesu bǝlia wia ɓālǝi ama:
\pi1 \wj Mǝ nda ban na wun mǝsǝcau, mǝ nda kun-nda mala anzur.\wj*
\v 8 \wj Acili aɓwana mǝnana kat à akàm dǝmba à yiu ka, amǝn'í na andǝ amǝ'ɓǝmbǝriban. Anzur mǝ'mǝsǝcau nì okia wia ɗàng.\wj*\f + \fr 10:8 \ft Ɓalli gbal aɓa: \xt Ir 23:1; Ezǝk 34:2\xt*\ft .\f*
\v 9 \wj Mǝ ndà kun-nda. Ɓwa mǝnana kat kútí nǝ banam ngga nǝ̀ kum àwá; nǝ̀ kutio sǝ nǝ̀ puro, sǝ nǝ̀ kum girlina.\wj*
\pi1 
\v 10 \wj Mǝn'í ka kǝ yiu ace iun'í, ace wal-lú, andǝ kiɗiki gir. Sǝ mim ngga ǝn yiu ace pea aɓwana yilǝmu, andǝ do mǝɓoarne mǝnana lùmsǝo a koya njarì ka.\wj*
\v 11 \wj Mǝ nda yálgír mǝɓoarne. Yálgír mǝɓoarne ka kǝ pa yilǝmi, nǝ̀ wu ace anzur male. \wj*\f + \fr 10:11 \ft Ɓalli gbal aɓa: \xt Isha 40:11; Ezǝk 34:11; Ib 13:20; 1Bit 5:4; Sǝn 7:17; 1Yoh 3:16; Yoh 15:13\xt*\ft .\f*
\v 12 \wj Sǝ ɓwa mǝnana à twali à kǝ mbwe, ace tsǝkir anzur, sǝ yì ka, yálgír na ɗang, sǝ anzur ka a male na raka, ɓǝ̀ sǝn nvwa-bondo aban yiu ka, nǝ̀ nying anzur nǝ̀ ɓangŋa, sǝ nvwa-bondo nǝ̀ bwal atà anzur sǝ nǝ̀ mesǝkia.\wj*
\v 13 \wj Ɓwa mǝnana à twali a túró-boalo ace yál agir ka, nǝ̀ ɓangŋa acemǝnana yì ka, túró-boalo nda pakkiyi ka, kǝgìr oasǝi arǝ anzur nì ɗàng.\wj*
\pi1 
\v 14 \wj Mǝ nda yálgír mǝɓoarne; ǝn súrǝ̀ anzur mem, sǝ yia gbal ka à súrǝàm,\wj*
\v 15 \wj kǝla mǝnana Tárrám súrǝàm, sǝ ǝn súrǝ̀ Tárrám ka. Ən pa yilǝmem ace anzur mem.\wj*\f + \fr 10:15 \ft Ɓalli gbal aɓa: \xt Mat 11:24\xt*\ft .\f*
\v 16 \wj Mǝ ndanǝ aɓea anzur mem mǝnana à pà aɓa domwan man raka. Dumǝna púp mǝ nǝ yinǝia gbal. À nǝ̀ kwaki kiria à nǝ̀ ok giem, sǝ domwan ngga nǝ̀ duk mwashat, nǝ yálgír mwashat.\wj*\f + \fr 10:16 \ft Ɓalli gbal aɓa: \xt Isha 56:8; Yoh 11:52; 17:20; Afi 2:13-18; 1Bit 2:25\xt*\ft .\f*
\pi1 
\v 17 \wj Tárrám kǝ earcem acemǝnana ǝn eare mǝ nǝ pà yilǝmem mǝ nǝ wu, ace mana ɓǝ̀n é ɗǝm ɓǝ̀n lo nǝ yilǝmu ka.\wj*
\v 18 \wj Kǝɓwa pà nǝ̀ twal yilǝmem a rǝàm ɗàng. Ən nggǝ pa yilǝmem nǝ eare mem. Mǝ ndanǝ rǝcandǝa mǝ nǝ pà yilǝmem, sǝ mǝ ndanǝ rǝcandǝa mǝnana mǝ nǝ é ɗǝm ngga. Mǝnia ka nda nzongcau mǝnana Tárrám pam ama ɓǝ̀ ǝn pak ka.\wj*
\p 
\v 19 Lang Yesu banggina acau mǝnia ka, kara ɗenyicau mala amǝ Yahudi a rǝi gakya.
\v 20 Aɓea aɓwana pas aɓalǝia à bang ama, <<Yì ka, ndanǝ kukwar arǝì! Pà aɓa ɗenyicau male ɗàng! Ace man sǝ wu kǝ kwaki kir wun arǝì?>>
\p 
\v 21 Sǝ acili aɓwana ka à bang ama, <<Ɓwa mǝnana ndanǝ kukwar arǝì ka, pà nǝ̀ bang amǝnia yì acau ka ɗàng! Lang sǝ kukwar nǝ̀ mǝn mǝsǝ ante?>>
\s1 Aɓwana-mǝgule mala amǝ Yahudi // ginǝki Yesu
\p 
\v 22 Nda nǝ kunɗwal, sǝ yi karǝ nǝ kúnì Hanuka, yì Lamsan ace ɗenyi nǝ bákú mǝnana à tàr Ndàmǝgule nǝi ace Ɓakuli, aɓa Urǝshalima ka.
\v 23 Ɓè pwari ka, Yesu gya kǝ kutio aɓa ɓè buì mala Ndàmǝgule mala Ɓakuli, mǝnana à tunǝki ama Tara mala Solomon ngga.\f + \fr 10:23 \ft Ɓalli gbal aɓa: \xt Atúró 3:11; 5:12\xt*\ft .\f*
\p 
\v 24 Aɓwana-mǝgule mala amǝ Yahudi yi ramba a baní, sǝ à ɗì ama, <<Lang sǝ a nǝ nying sǝm anggo aɓa pǝndǝa? Ɓǝ̀ a nda Kǝrǝsti ka, Pura sǝm bwāng, bangga sǝm.>>
\p 
\v 25 Yesu nyesǝia wia ama:
\pi1 \wj Ən angŋa dǝmba ǝn nanà wun, sǝ wun ngga, wu earnǝ mim ɗang. Atúró mǝnana ǝn nggǝ pea aɓa rǝcandǝa mala Tárrám ngga, à nda à lǝmdǝ koyan nda mim ngga.\wj*
\v 26 \wj Sǝ wun ngga wu earnǝ mim ɗang, acemǝnana wu nda ka nzur mem ɗàng.\wj*
\v 27 \wj Anzur mem kǝ ok giem; ǝn súrǝ̀ia, sǝ à kǝ kpatam.\wj*
\v 28 \wj Ən nggǝ pea wia yilǝmu mǝnana málá male pà kàm raka, sǝ à pà nǝ̀ kìɗìkì à nǝ̀ ueɓà ɗàng. Kǝɓwa pà nǝ̀ fea a buam ɗàng.\wj*
\v 29 \wj Tárrám mǝnana pam mia ka kútì koyan ngga kat nǝ rǝcandǝa. Kǝɓwa pà nǝ̀ gandǝ ea arǝì ɗàng.\wj*
\v 30 \wj Mim sǝnǝ Tárrám ka sǝm nda mwashat.\wj*
\p 
\v 31 Amǝ Yahudi pwan atali ɗǝm ama à nǝ̀ ɓukki.
\v 32 Sǝ Yesu nea wia ama, \wj <<Ən pakkina agir mǝɓoarne pas, a ɓadǝm wun, mǝnana Tárrám túrǎm ama ɓǝ̀n pea ka. Nda ace mǝye mwashat aɓalǝia sǝ wu kǝ earce wun nǝ̀ ɓukkiam?>>\wj*
\p 
\v 33 Pǝlǝa à eari wi ama, <<Pà ace kǝ agir mǝɓoarne mǝnana à pea, sǝ sǝm earce ama sǝm nǝ̀ ɓukkio ka ɗàng. Nda ace cau ɓǝsǝki Ɓakuli mǝnana a na ka. We ka, a nda ɓwamǝpǝndǝe sǝ a kǝ twal ɓamuro a nda Ɓakuli!>>\f + \fr 10:33 \ft Ɓalli gbal aɓa: \xt Pǝris 24:16; Mar 14:64\xt*\ft .\f*
\p 
\v 34 Yesu earia wia ama:
\pi1 \wj Pà akàm à gilǝe aɓa Malǝmce Nggurcau ma'wun mbo, mǝnana Ɓakuli bang ama, <<Wu nda ka aɓakuli>> ka re?\wj*\f + \fr 10:34 \ft Ɓalli gbal aɓa: \xt Yoh 8:17; Ang 82:6\xt*\ft .\f*
\v 35 \wj Wu sǝlǝna ama cau mǝnana Malǝmce bang ngga makgìr pà arǝì ɗàng, camǝna anggo pà nǝ̀ nggaɗi ɗang. Sǝ ɓǝa aɓwana mǝno à ak cau mǝno ka, à tunǝia ama <<aɓakuli>> ka,\wj*
\v 36 \wj ace mana sǝ wu twali ama cau ɓǝsǝki Ɓakuli na ǝn na ka, mǝnana ǝn bang nǝma <<Mǝ nda Muna mala Ɓakuli,>> yì mim mǝnana Ɓakuli tàram sǝ tasǝam a ɓanza ka?\wj*
\v 37 \wj Wu kǝa earnǝ mim ɗang ɓǝ̀ atúró mǝnana ǝn pakkiyi ka a mala Tárrám Ɓakuli na raka.\wj*
\v 38 \wj Sǝ ɓǝ̀ atúró male na ǝn pakkiyi ka, ɓǝ̀ pà wu nǝ̀ earnǝ mim raka, wu earnǝ agir-ndali mǝnana ǝn pea ka, ace mǝnana ɓǝ̀ wu sǝlǝa, sǝ ɓǝ̀ kpaka wun ama, Tárrám ngga nda a ɓalǝam, sǝ mim ngga mǝ nda aɓa Tárrám.\wj*
\p 
\v 39 Nyar ɗǝm ngga, à ɓariki ama à nǝ̀ bwal Yesu, kara purî ɓabuia.
\v 40 O kya yàl a nkaring Mùr mala Jodan, yi pur a ban mǝnana Yohana pakkiyi batisǝma kam atà dǝmbe ka. Akanó sǝ kya do.
\v 41 Aɓwana pas yiu a baní, à kǝ bang arǝarǝia ama, <<Yohana pak kǝ gir'ndǝlǝki ɗàng, sǝama acau mǝnana ne amur man yì ɓwa ka, à yì pur a mǝsǝcau.>>
\v 42 Pas atà aɓwana mǝnana abanì ka à pà ɓamuria aban Yesu.
\c 11
\s1 Lo mala Liazaro a ɓembe
\p 
\v 1 Ɓè ɓwabura nda kam lùllǝì ama Liazaro. Rǝì pakki wi. Yì andǝ amǝ'eambi amuna-mamǝna ɓari, Maryamu andǝ Marta ka, à ndanǝ do a Betani.\f + \fr 11:1 \ft Ɓalli gbal aɓa: \xt Mar 11:1; Luk 10:38\xt*\ft .\f*
\v 2 Mǝnia yì Maryamu mǝ'eambi Liazaro nong nǝ rǝkwana ka, nda kǝ ɓwama mǝnana nǝnzǝ́mò yiu soapi Mǝtalabangŋo Yesu mùrú mǝ'rǝmɓoarne arǝ akusǝi, sǝ esǝki wi nǝ nyang-múrí ka.\f + \fr 11:2 \ft Ɓalli gbal aɓa: \xt Yoh 12:3; Luk 7:38; Mar 14:3\xt*\ft .\f*
\v 3 Amǝ'eambu amamǝna mǝnia ɓari ka, à túrban atà Mǝtalabangŋo Yesu ɓǝa ne wi ama, gyajam male, mǝnana earkiyi ace raka, rǝì eari wi ɗang.
\p 
\v 4 Lang Yesu yi ok ce ka, na ama, \wj <<Rǝkwana mala Liazaro ka pà nǝ̀ ká nǝi a lú ɗang, nda ace lǝmdǝ gulo mala Ɓakuli, sǝ àkǝ̀ ce gbal sǝ Muna mala Ɓakuli nǝ̀ kum gulo.>>\wj*
\v 5 Yesu ka earce Marta andǝ amǝ'eambi Maryamu andǝ Liazaro.
\v 6 Kat andǝ a mani ka, lang ok ce rǝkwana mala Liazaro ka, akrǝi pak aɓea nongŋo ɓari aban mǝnana ndakam ngga.
\p 
\v 7 Anzǝm mani ka pǝlǝa banggi alaggana male ama, \wj <<Wu fa sǝm nǝ̀ nyare a Yahudi.>>\wj*
\p 
\v 8 Sǝ alaggana male ne wi ama, <<Malǝm, àkǝ̀ dyan tù, sǝ amǝ Yahudi lo ama à nǝ̀ ɓukkio nǝ atali, sǝ a kǝ na ama a nǝ nyar kano ɗǝm le?>>
\p 
\v 9 Pǝlǝa Yesu earia wia ama, \wj <<Abúpwari mala tǎlaban aɓa pwari mwashat ka à nda lum-nong-ɓari. Nǝ pwari ka ɓwa nǝ̀ gandǝ gya pà nǝ̀ anndǝ ɗang, acemǝnana kǝ sǝn tǎlaban mala ɓanza man.\wj*
\v 10 \wj Sǝ nǝ dú ka, à nǝ̀ gandǝ annda, acemǝnana à pànǝ tǎlaban ɗang.>>\wj*
\v 11 Pǝlǝa nea wia ama, \wj <<Gyajam ma'sǝm yì Liazaro ka kongŋǝna a ntulo, sǝ ado ka mǝ nǝ ká kàm mǝ nǝ nggá loasǝi.>>\wj*
\p 
\v 12 Sǝ alaggana male na ama, <<Mǝtalabangŋo, ɓǝ̀ nda a ntulo ka, lǝmdǝ ama rǝì nǝ̀ malâ.>>
\v 13 Yia ka à twali ama mǝsǝrǝ ntulo na Yesu nakiyi ce ama Liazaro nonggi ka, sǝ Yesu ka nda arǝ na ama Liazaro wuna.
\p 
\v 14 Pǝlǝa Yesu pùrria wia kwas, banggia wia ama, \wj <<Liazaro ka wuna.\wj*
\v 15 \wj Sǝ ace wun ngga, ban kǝ ɓoaram mǝnana ǝn pa abanì raka, acemǝnana ado wuni sǝ wun nǝ̀ pà ɓamur wun a banam pepe. Wu lo, sǝm nǝ̀ o a baní.>>\wj*
\p 
\v 16 Toma (mǝnana à tunǝki ama Pasa ka) ne aɓi alaggana ama, <<Wu longŋi kat sǝm nǝ̀ o atà Malǝm, ace mǝnana ɓǝ̀ sǝm kya wu atè!>>
\s1 Yesu nda lo mala lú andǝ yilǝmu
\p 
\v 17 Lang Yesu bwalǝna Betani ka, à banggi wi ama, Liazaro pàngŋǝ̀nà nongŋo ine a ɓembe.
\v 18 Betani ka sapi Urǝshalima ɗang, nda a baní tù, yàle bwal mel ɓari ɗang,
\v 19 sǝ amǝ Yahudi pas yiu aban Marta andǝ Maryamu, à yiua girikia ace lú mala mǝ'eambia.\f + \fr 11:19 \ft Ɓalli gbal aɓa: \xt Ayu 2:11\xt*\ft .\f*
\p 
\v 20 Lang Marta ongŋǝna ama Yesu na kǝ yiu ka, puro nǝ̀ nggá kúllì. Sǝ Maryamu ka ueo a ɓala.
\v 21 Marta ne Yesu ama, <<Mǝtalabangŋo, ɓǝ̀ pǝlǝ ama a ndakani ka, ɓǝ́ mǝ'eambam pa nǝ̀ wu ɗàng!
\v 22 Sǝ ǝn sǝlǝna ama, ko ado ka Ɓakuli nǝ̀ po gìr mǝnana kat a zǝm ngga.>>
\p 
\v 23 Yesu pǝlǝa banggi wi ama, \wj <<Mǝ'eambǝo nǝ̀ lo nǝ yilǝmu ɗǝm.>>\wj*
\p 
\v 24 Marta na ama, <<Ən sǝlǝna ama nǝ̀ lo nǝ yilǝmu a lo mala alú a masǝlǝata apwari.>>\f + \fr 11:24 \ft Ɓalli gbal aɓa: \xt Dan 12:2; Yoh 5:28; Atúró 24:15\xt*\ft .\f*
\p 
\v 25 Yesu ne wi ama, \wj <<Mǝ nda lo mala alú sǝ mǝ nda yilǝmu. Ɓwa mǝnana kat pà ɓamúrì a banam ngga, ko ɓǝ̀ wù ka, nǝ̀ lo nǝ yilǝmu.\wj*
\v 26 \wj Sǝ ɓwa mǝnana kat nda nǝmǝsǝi sǝ pà ɓamúrì a banam ngga, pà nǝ̀ wù ɗang. A earǝna nǝ cau man le?>>\wj*\f + \fr 11:26 \ft Ɓalli gbal aɓa: \xt Yoh 6:47; 8:51\xt*\ft .\f*
\p 
\v 27 Pǝlǝa Marta eari wi ama, <<E, Mǝtalabangŋo, ǝn earǝna nǝ we, ama a nda Kǝrǝsti Mǝ'amsǝban, Muna mala Ɓakuli, mǝnana Ɓakuli bang ama nǝ̀ yiu a ɓanza ka.>>\f + \fr 11:27 \ft Ɓalli gbal aɓa: \xt Mat 16:16\xt*\ft .\f*
\p 
\v 28 Marta pǝlǝa nyare kya tunǝ mǝ'eambi Maryamu a giriban, sǝ ne wi ama, <<Malǝm yina, sǝ kǝ earce sǝno.>>
\v 29 Lang Maryamu nǝ̀ ok anggo ka, kara lo a kaurǝa, wari a baní.
\v 30 Yesu ka malaká bwal là peatu ɗàng, nda àkǝ̀ ban mǝnana Marta kumi kàm ngga.
\v 31 Lang aɓwana mǝnana atà Maryamu a ɓala, aban girike, sǝni lo pur tsuk-tsuk ka, à lo atè. À twali ama kǝ um nǝ o a ɓembe nǝ̀ nggá ɓua abanì.
\p 
\v 32 Maryamu yi bwal ban Yesu. Lang mǝsǝì nǝ̀ kpa arǝ Yesu ka, yi kūndǝo a ɓadǝmbi, kǝ na ama, <<Mǝtalabangŋo, ɓǝ̀ pǝlǝ ama a nda kani ka, ɓǝ́ mǝ'eambam wù ma ɗang!>>
\p 
\v 33 Lang Yesu sǝni aban ɓua, sǝ sǝn aɓwana mǝnana à yiu atè ka aban ɓua gbal ka, gìr nî je Yesu a ɓabumi kǝ̀rkǝ́r.
\v 34 Pǝlǝa ɗia ama, \wj <<Ake ɗe sǝ wu tsǝì?>>\wj*
\p Sǝ à ne wi ama, <<Mǝtalabangŋo, yiu sǝni.>>
\p 
\v 35 Yesu sukki mǝrǝm.
\v 36 Aɓwana mǝnana aban came abanì ka à na ama, <<Wu sǝn ɓekǝ earcearǝu mǝnana ndanǝi arǝì ka!>>
\p 
\v 37 Sǝ aɓia aɓwana na ama, <<Mǝnia yì ɓwa ka gandǝ mǝn mǝsǝ nte, anggo re? Man tsǝa sǝ gandǝ tamsǝ lú mala Liazaro ɗàng?>>
\s1 Yesu loasǝ Liazaro a ɓembe
\p 
\v 38 Nǝ́ cê kùlkùl a ɓabumi più ka, Yesu yi bik ban ɓembe. Ɓembe ka à gwami aɓa tali, sǝ à gìr kúni nǝ tali.\f + \fr 11:38 \ft Ɓalli gbal aɓa: \xt Mat 27:60; Mar 15:46; Luk 24:2; Yoh 20:11\xt*\ft .\f*
\v 39 Yesu na ama, \wj <<Wu gǝshi talî!>>\wj*
\p Sǝ Marta mǝ'eam lú ne Yesu ama, <<Mǝtalabangŋo, lú ka à tsǝì pàngŋǝ̀nà nongŋo ine adyan. Rǝmban mǝɓike nǝ̀ akiban!>>
\p 
\v 40 Yesu banggi wi ama, \wj <<Ən no nǝma ɓǝ̀ a earnǝ mim ngga a nǝ sǝn gulo mala Ɓakuli re?>>\wj*
\p 
\v 41 Pǝlǝa aɓea ɓwana mǝnana abanì ka à gǝshi talî. Yesu loasǝ mǝsǝì a kùli sǝ na ama, \wj <<We Dâ, ǝn pakko yàwá mǝnana a ongŋǝnam ngga.\wj*
\v 42 \wj Ən sǝlǝna nǝma ko aya pwari ka a kǝ oem, sǝ ado ka ǝn na mǝnia yì cau ka ace aɓwana man kani ka, ace mǝnana ɓǝà ear ama a nǝ̀ túrǎm.>>\wj*
\p 
\v 43 Lang bangŋǝna anggo ka, sǝ tunǝban nǝ giu mǝcandǝe, ama, \wj <<Liazaro, puro!>>\wj*
\v 44 Pǝlǝa Liazaro mǝnana lú na ka puro, abuí andǝ akusǝi ka, à mārǝkia nǝ bugir, sǝ ɓamǝsǝi ka, à mārǝi nǝ nggubyau. Yesu banggia wia ama, \wj <<Wu panzǝi, sǝ wu nyi ɓǝ̀ o!>>\wj*\fig Liazaro purî ɓembe|alt="Lazarus comes out of the tomb." src="WA03868b.tif" size="col" loc="JHN 11:44" copy="Wade Images" ref="11:44"\fig*
\s1 Kùrkûn amur Yesu
\r (Matiu 26:1-5; Markus 14:1,2; Luka 22:1,2)
\p 
\v 45 Pas atà aɓwana mǝnana à yiua makki Maryamu kun, sǝ à sǝn gìr mǝnia Yesu pè ka, à pà ɓamuria a baní.
\v 46 Sǝ aɓea ateà ka à o aban amǝ Farisi à kya banggia wia gìr mǝnana Yesu pè ka.
\v 47 Pǝlǝa amǝ Farisi andǝ agbani pǝris tunǝ do mala amǝkùrcau. À ɗì rǝia ama, <<Mana ado sǝm nǝ̀ pa? Aɓa mǝsǝcau ka, ɓwa mǝnia nda kǝ pakki agir-ndǝlǝki pas ka!
\v 48 Ɓǝ̀ sǝm ɗeki sǝ lidǝmba anggo ka, muna-ɓwapǝndǝa kat nǝ̀ earnǝi. Sǝ amǝ lwa mala amǝ Roma nǝ̀ yia kiɗiki Ndàmǝgule mala Ɓakuli ma'sǝm andǝ nzali ma'sǝm!>>
\p 
\v 49 Mwashat aɓalǝia, mǝnana à tunǝki ama Kayafas, mǝnana nda Pǝris Mǝgule a bàkú mǝno ka, bang ama, <<Wu súrǝ̀ cau mǝnana wu nakiyi ka ɗàng!
\v 50 Wu sǝlǝ mbo ama nǝ̀ ɓoaribanì ɓǝ̀ ɓwa mwashat wu ace aɓwana, amur mǝnana amǝ Roma ɓǝà yi twalta aɓwana mala nzali Yahudi ma'sǝm ngga?>>
\v 51 Mǝnia yì cau Kayafas ne ka, bangŋe mala ɓamúrì na ɗang. Acemǝnana yì nda Pǝris Mǝgule a mǝno yì pǝlǝa ka, nda ɓangnǝ-ɓangnǝa ama, Yesu nǝ̀ yia wu ace aɓwana mala nzali Yahudi ka.
\v 52 Sǝ pà ace amǝ Yahudi nǝmurǝia ɗàng, nda gbal ace acilia aɓwana kat arǝ anzali aɓa ɓanza, amǝnana à nǝ̀ yia pà ɓamuria aban Ɓakuli, sǝ nǝ̀ dapi ɓamuria kat ɓǝa yi duk mwashat ka.
\p 
\v 53 Twal amǝno yì pwari ka, aɓwana-mǝgule mala amǝ Yahudi kutia alkita anjar mǝnana à nǝ̀ wal-lú Yesu ka.
\v 54 Ace mani ka Yesu nyare ging ɗǝm bwāng aɓalǝ amǝ Yahudi ɗang. Nying Urǝshalima sǝ o a njenza, aɓa pǝɗanban tù a ban ɓè muna-là mǝnana à tunǝi ama Ifǝrem ngga. Akanó sǝ kya do andǝ alaggana male.
\p 
\v 55 Lang pwari Lamsan mala Yàlîmurû gbashìnà ka, amǝ Yahudi pas purkio arǝ aɓea aban aɓa nzali Yahudi sǝ à o a Urǝshalima, ace mǝnana ɓǝà kya gilǝki rǝia aɓa peri ace man yì Lamsan ngga.
\v 56 À camarǝ alta Yesu. À yì came aɓa Ndàmǝgule mala Ɓakuli sǝ à kǝ ɗiki rǝarǝia ama, <<Lang sǝ wu sǝni? Nǝ̀ yiu a man yì Lamsan ngga le?>>
\v 57 Anggo ka agbani Pǝris andǝ amǝ Farisi angŋa dǝmba à hamǝna ama, ɓǝ̀ kǝɓwa súrǝ́nà rǝ ban mǝnana Yesu nda kam ngga, ɓwe ɓǝ̀ yì na ce, ace mǝnana à nǝ̀ bwali ka.
\c 12
\s1 Maryamu soapi Yesu // mùrú mǝ'rǝmɓoarne
\r (Matiu 26:6-13; Markus 14:3-9)
\p 
\v 1 Lang Lamsan Yàlîmurû ueo nongŋo tongno-nong-mwashat ka, Yesu wari a Betani, muna-là mala Liazaro, ɓwa mǝnana wu, sǝ Yesu loasǝi nǝ yilǝmu ka.\f + \fr 12:1 \ft Ɓalli gbal aɓa: \xt Mat 26:6-11; Mar 14:3-9; Luk 7:37-38\xt*\ft .\f*
\v 2 À lam girlina mala pwarikpǝra ace pè Yesu gulo. Marta nda gaki girlina ka, sǝ Liazaro ka nda aɓalǝ aɓwana mǝnana à lì girlina andǝ Yesu ka.
\v 3 Pǝlǝa Maryamu twal muna-dù mùrú mǝ'rǝmɓoarne, mǝnana à pè nǝ nard mǝɓoarnsari, sǝ kúrè pa bǝti raka, soe arǝ akusǝ Yesu, sǝ hasǝkia nǝ nyang múrí. Kara rǝm mùrú mǝɓoarne man aki ɓala kat.
\p 
\v 4 Sǝ Yahuda Iskariyoti, mwashat atà alaggana mǝnana nǝ̀ nggá mak Yesu ka, na ama,\f + \fr 12:4 \ft Ɓalli gbal aɓa: \xt Yoh 6:71; 13:26\xt*\ft .\f*
\v 5 <<Mana tsǝa sǝ à ginǝ mak man yì mùrú ka a kún dinari gbǝman-tàrú, sǝ boale ka à pè mia amǝ'tǝ̀r ɗàng?>>
\v 6 Yahuda ka bang anggo, pà acemǝnana kǝ ɓuàce amǝ'tǝ̀r ka ɗàng, nda acemǝnana yì ka, mǝn'í na ka; sǝ acemǝnana yì nda mǝbwal ndaboalo mala alaggana mala Yesu ka, pak ka kǝ iu aɓa boale ace ɓamur rǝì.
\p 
\v 7 Sǝ Yesu na ama, \wj <<Wu nying ɓwama man zàng! Gìr mǝnana pe ka nda ace gilǝki luem ace pwari tsǝkban mem.\wj*
\v 8 \wj Wun ngga, wu nda a tarǝ wun wunǝ amǝ'tǝ̀r ko aya pwari ka, sǝ mim ngga ǝn pa atà wun koya pwari ɗàng.>>\wj*
\s1 Kùrkûn amur Liazaro à nǝ̀ wal-luí
\p 
\v 9 Amǝ Yahudi pas ongŋǝna ama Yesu warina a Betani. Pǝlǝa à waria sǝne andǝ Liazaro mǝnana Yesu loasǝi nǝ yilǝmu a ɓembe ka.
\v 10 Pǝlǝa agbani Pǝris kurkunarǝia, à nǝ̀ wal Liazaro gbal,
\v 11 acemǝnana nda ace loasǝe nǝ yilǝmu a ɓembe sǝ pas aɓalǝ amǝ Yahudi kǝ ginǝkia, sǝ à kǝ pa ɓamuria a ban Yesu.
\s1 Kutio limurǝm mala Yesu aɓa Urǝshalima
\r (Matiu 21:1-11; Markus 11:1-11; Luka 19:28-40)
\p 
\v 12 Ban fana ka, aɓwana pas mǝnana à yiu ace Lamsan Yàlîmurû ka, à yì ok ama Yesu nda njar aban yiu a Urǝshalima.
\v 13 Pǝlǝa à twalki ambú nkangga a buia sǝ à puro à nǝ̀ ká kúllì. À kǝ mak-gāwàn, à kǝ na ama,
\q1 <<Wu ɓwangsǝki Ɓakuli!
\q1 Tsǝkbu mala Ɓakuli na
\q2 amur ɓwa mǝnana kǝ yiu
\q1 aɓa lullǝ Mǝtalabangŋo
\q2 Ɓakuli ka!
\q1 Tsǝkbu mala Ɓakuli na
\q2 amur Murǝm mala
\q1 amǝ Isǝrayila!>>\f + \fr 12:13 \ft Ɓalli gbal aɓa: \xt Ang 118:25,26\xt*\ft .\f*
\p 
\v 14 Yesu kum muna dambǝritso sǝ eauwe do a nzǝmi, kǝla mǝnana Malǝmce na ka ama,
\q1 
\v 15 <<Wun amǝ Siyona,
\q2 ɓangciu ɓǝ̀ kǝa
\q1 pakka wun ɗàng!
\q1 Murǝm ma'wun ndya
\q2 kǝ yiu anzǝm muna
\q2 dambǝritso ka!>>\f + \fr 12:15 \ft Ɓalli gbal aɓa: \xt Zak 9:9\xt*\ft .\f*
\p 
\v 16 A dǝmbe ka alaggana mala Yesu bwalta amǝnia yì agir ka ama lùmsǝo mala ɓangnǝa na ka ɗàng. Anzǝm mǝnana Ɓakuli loasǝna Yesu nǝ yilǝmu a ɓembe, sǝ Yesu kutina aɓa ɓoarɓwa male ka, nda sǝ ɓalǝia kasǝna arǝ gir mǝnana kumban ngga, sǝ à yì sǝlǝ ama agir mǝnia kat ka, à nda kam à gilǝe amur Kǝrǝsti aɓa Malǝmce.
\p 
\v 17 Ɓwabunda mǝnana à nda atà Yesu a pwari mǝnana tunǝ Liazaro ɓǝ̀ purî ɓembe, sǝ loasǝi nǝ yilǝmu ka, à camarǝ banggia aɓwana cau mala gìr mǝnana à sǝn ngga.
\v 18 Gìr mǝnana tsǝa sǝ ɓwabundǝa puro waria kúllí Yesu ka, nda acemǝnana à ongŋǝna ama pak mǝnia yì gir'lǝmdǝa ka.
\v 19 Pǝlǝa amǝ Farisi ne arǝarǝia ama, <<Wu sǝni, túró mǝɓane nda sǝm pakkiyi ka. Ɓanza pwana rǝì kat umna kpate!>>
\s1 Yesu nacau amur lú male
\p 
\v 20 Aɓea amǝ Gǝrik nda aɓalǝ aɓwana mǝnana à waria peri a Urǝshalima a Lamsan Yàlîmurû ka.
\v 21 À yiu a ban Filip, mǝnana yì gbal ka pur a Beseda aɓa Galili ka, sǝ à zǝmba ama, <<Ɓwamǝgule, sǝm nggǝ earce sǝn Yesu.>>
\v 22 Pǝlǝa Filip wario kya banggi Andǝru, sǝ yia kǝm à kutio à kya banggi Yesu.
\p 
\v 23 Yesu nyesǝia wia ama:
\pi1 \wj Ado ka pwarî yina, yì mǝnana Ɓakuli nǝ̀ lǝmdǝ gulo mala Muna mala Ɓwa ka.\wj*
\v 24 \wj Mǝ nda ban bangga wun mǝsǝcau, ɓǝ̀ mǝsǝ mǝssa kpa a nzali sǝ wu raka, nǝ̀ ueo anggo nǝmurǝì mwashat. Sǝ ɓǝ̀ wu ka, nǝ̀ pusǝ amǝsǝì pas.\wj*
\v 25 \wj Ɓwa mǝnana kat kǝ earce yilǝmi ka, nǝ̀ ɗwanyibanì, sǝ ɓwa mǝnana ginǝki yilǝmi a man yì ɓanza ka, nǝ̀ kum yilǝmu mǝnana málá male pà kàm raka.\wj*
\v 26 \wj Ɓwa mǝnana kat earce nǝ̀ do a ɓatam ngga, dumǝna púp nǝ̀ yiu atàm, ace mǝnana ban mǝnana kat mǝ nda kam ngga, àkǝ̀ banì sǝ guro mem nǝ̀ pa. Sǝ Tárrám gbal ka nǝ̀ gusǝlǝ ɓwa mǝnana kat pà ɓamúrì kǝ pak túró a ɓatam ngga.\wj*
\pi1 
\v 27 \wj Ado ka ɓabumam kǝ pi, sǝ aman sǝ mǝ nǝ na? Mǝ nǝ na nǝma, <<Dâ, amsǝam aɓa mǝnia yì tanni ka ɓǝ̀ kǝa sulǝ amuram ɗàng>> le? Awo! Mǝnia ka nda tǝr yiu mem, acemǝnana ɓǝ̀n kutio aɓa mǝnia yì bu-pwari mala tanni ka.\wj*
\v 28 \wj We Dâ, yinǝ gulo ace lùllǝò!\wj*
\p Kara Ɓakuli nacau nǝ kuli ama, <<Ən angŋa dǝmba ǝn gusǝlǝna lullǝam, sǝ Mǝ nǝ gusǝlǝi ɗǝm.>>
\v 29 Lang ɓwabundǝa mǝnana à came a banì à ok man yì giu ka, cilia twali ama mgbarangce na. Aɓea ɓwana ka à bang ama, <<Mǝturonjar mala Ɓakuli nda ne wi cau ka!>>
\p 
\v 30 Pǝlǝa Yesu nea wia ama, \wj <<Man yì giu ka pà acem sǝ yiu ɗang, nda ace wun.\wj*
\v 31 \wj Pwari mala pakkî mǝnia yì ɓanza ɓashi ka, kārǝ́na; ado sǝ Ɓakuli ak murǝm arǝ Shetan, yì murǝm mala ɓanza man.\wj*
\v 32 \wj Sǝ anzǝm mǝnana à loasǝnam amur nggun-gangndǝi ka, mǝ nǝ nun ɓwapǝndǝa kat a banam.>>\wj*
\v 33 Yesu bang anggo acemǝnana ɓǝ̀ lǝmdǝ ulang lú mǝnana nǝ wu ka.
\p 
\v 34 Ɓwabunda pǝlǝa ne Yesu ama, <<Sǝm ok aɓa Nggurcau mala Musa ama, Kǝrǝsti ka nǝ̀ dum nǝ yilǝmu mǝnana málá male pà kàm raka.\f + \fr 12:34 \ft Ɓalli gbal aɓa: \xt Ang 110:4; Isha 9:7; Ezǝk 37:24,25; Dan 7:14\xt*\ft .\f* Sǝ lang sǝ a na ama, <Dumǝna púp, à nǝ̀ loasǝ Muna mala Ɓwa amur nggun-gangndǝi?> Yana ɓwe nda man yì <Muna mala Ɓwa> ka?>>
\p 
\v 35 Yesu earia wia ama, \wj <<Tǎlaban ngga nda a ban wun ado, sǝ banì pà nǝ̀ sau ɗang. Wu gya aɓa mǝnia yì tǎlaban ado mǝnana nda a ban wun ngga, ace mǝnana ɓǝ̀ pǝndǝa ɓǝ̀ kǝa gìr amur wun ɗàng. Aɓwana mǝnana à kǝ gya aɓa pǝndǝa ka, à kǝ gandǝ sǝn ban mǝnana à káki kam ngga ɗàng.\wj*
\v 36 \wj Wu gūlì arǝ tǎlabanì ado mǝnana nda a ban wun ngga, ace mǝnana ɓǝ̀ wu duk amuna mala tǎlaban.>>\wj*
\p Anzǝm mana Yesu naná man yì cau ka, pǝlǝa upia wia, à sǝni ɗǝm ɗàng.
\v 37 Kat andǝ agir-ndǝlǝki mǝnana lǝmdǝ bu Ɓakuli, mǝnana Yesu peǎ a ɓadǝmbia ka, à pà ɓamuria a baní ɗàng.
\v 38 Mǝnia ka, nda ace lùmsǝ ɓangnǝa mala Ishaya mǝnana bang ama,
\q1 <<Mǝtalabangŋo,
\q2 yana ɓwe na earnǝ cau
\q1 mǝnana sǝm bang ngga,
\q2 sǝ a ban yan sǝ à
\q1 lǝmdǝ rǝcandǝa mala
\q2 Mǝtalabangŋo?>>\f + \fr 12:38 \ft Ɓalli gbal aɓa: \xt Isha 53:1\xt*\ft .\f*
\m 
\v 39 Ace mani ka à ginǝ earnǝ Yesu, acemǝnana Ishaya angŋa dǝmba bangŋǝna ama,
\q1 
\v 40 <<Mǝtalabangŋo girkina amǝsǝia,
\q2 ɗǝm ngga girkina ɓabumia.
\q1 Gìrkia ace mǝnana amǝsǝia
\q2 ɓǝà kǝa sǝnban ɗang,
\q1 sǝ ɓabumia ɓǝ̀ kǝa kum
\q2 sǝlǝe ɗàng,
\q1 sǝ à pà nǝ̀ nyàre a banam
\q2 ace mǝnana ɓǝ̀n
\q2 sonzǝia ka raka.\f + \fr 12:40 \ft Ɓalli gbal aɓa: \xt Isha 6:10\xt*\ft .\f*>>
\m 
\v 41 Ishaya bang man yì cau ka, acemǝnana ak dǝmba sǝn gulo mala Yesu ɗiɗyal, sǝ bangcau amurí.
\p 
\v 42 Kat andǝ amani ama pas atà aɓwana-mǝgule mala amǝ Yahudi, pà ɓamuria a ban Yesu ka, à bang ce a ban aɓwana bwāng ɗang, acemǝnana à kǝ ɓanggi amǝ Farisi ɓǝà kǝa pǝria aɓa ndakpapi ɗàng.
\v 43 Yia ka à kǝ earce ɓwangsǝban mala ɓwapǝndǝa amur ɓwangsǝban mala Ɓakuli.
\s1 Cau mala Yesu nǝ̀ ɓashi aɓwana
\p 
\v 44 Pǝlǝa Yesu loasǝ gì kpǝm sǝ na ama:
\pi1 \wj Ɓwa mǝnana kat gūlì arǝàm, mǝ nda gūlikiyi arǝàm nǝmurǝam ngga ɗàng, ndaban gūlì gbal arǝ Tárrám mǝnana tasǝam ngga.\wj*
\v 45 \wj Ɓwa mǝnana kat sǝnam ngga sǝna Tárrám mǝnana tasǝam ngga.\wj*
\v 46 \wj Ən yiu kǝla tǎlaban ace pa tǎlaban aɓa pǝndǝa mala ɓanza man, ace mǝnana ɓwa mana kat pà ɓamúrì a banam ngga, ɓǝ̀ kǝa ueo aɓa pǝndǝa ɗang.\wj*
\pi1 
\v 47 \wj Ɓwa mǝnana kat ok kanigir mem, sǝ kpate raka, mǝ nda mǝ nǝ ɓashi wi ka ɗàng. Pa ace ɓashi sǝ ǝn yiu a ɓanza ɗang, ǝn yiu ace amsǝ ɓanza.\wj*
\v 48 \wj Aɓwana mǝnana kat à ginǝam sǝ à ginǝ ak cau mem ngga, à ndanǝ mǝ'ɓashi mǝnana nǝ̀ ɓashia wia ka. Acau mǝnana ǝn nea ka, à nǝ̀ mea a ɓashi a masǝlǝata apwari!\wj*
\v 49 \wj Agir mǝnana kat ǝn nggǝ kània ka, à pà aɓa rǝcandǝa mem ɗàng, Tárrám mǝnana tàsǝàm ngga, nǝ̀ pam nzongcau arǝ mana ɓǝ̀n na sǝ lang sǝ mǝ nǝ né.\wj*
\v 50 \wj Sǝ ǝn sǝlǝna ama anzongcau male ka à nǝ̀ kánǝ ɓwa aɓa yilǝmu mǝnana málá male pà kàm raka. Gìr mǝnana ǝn naki ka nda gìr mǝnana kat Tárrám banggàm mǝ na ka.\wj*
\c 13
\s1 Yesu lákkí akusǝ alaggana male
\p 
\v 1 Ué bǝti à nǝ̀ tita Lamsan Yàlîmurû, sǝ Yesu sǝlǝna ama bu-pwari male yina mǝnana nǝ̀ nying ɓanza nǝ̀ o aban Tárrí ka. Yì ka, earnace aɓwana male mǝnana à nda a ɓanza man ngga, sǝ ado ka lǝmdǝia wia earcearǝu mǝnana malkiyi raka.
\p 
\v 2 Yesu andǝ alaggana male ka à nda ban lí nǝ pwarikpǝra. Shetan angŋa dǝmba tsǝ̀ngŋǝ̀nà ɗenyicau mala mak Yesu a ɓabum Yahuda Iskariyoti muna mala Shiman.\f + \fr 13:2 \ft Ɓalli gbal aɓa: \xt Yoh 6:71; Mar 14:10\xt*\ft .\f*
\v 3 Yesu sǝlǝna ama Ɓakuli Tárrú pani wi rǝcandǝa amur agir kat, sǝ sǝlǝna gbal ama pur nǝban Ɓakuli, sǝ ndo nǝ̀ nyare nǝ̀ o a baní ka.
\v 4 Ace mani ka loapi múr girlina, swár nggea-daura male, sǝ kùr nggubyau esǝki rǝǔ a taɓuni.
\v 5 Pǝlǝa solǝ mùr a nkenye, sǝ tita lákkí akusǝ alaggana male sǝ kǝ esǝkia nǝ nggubyau esǝki rǝǔ mǝnana a taɓuni ka.\f + \fr 13:5 \ft Ɓalli gbal aɓa: \xt Luk 7:44; 22:27\xt*\ft .\f*
\v 6 Lang Yesu yiu a ban Shiman Bitǝrus ka, Bitǝrus ɗì ama, <<Mǝtalabangŋo, a nda a nǝ lákkàm akusǝam ngga le?>>
\p 
\v 7 Pǝlǝa Yesu eari wi ama, \wj <<A pà nǝ súrǝ̀ gir mǝnana ado ǝn pakkiyi ka ɗang, sǝ nǝnzǝ́mò ka a nǝ nggá sǝlǝa.>>\wj*
\p 
\v 8 Shiman Bitǝrus banggi wi ama, <<Awo, a pà nǝ lákkàm akusǝam ɗang!>>
\p Sǝ Yesu ne wi ma, \wj <<Ɓǝn lákkò akusǝo raka, a pà nǝ duk mǝkpatam ɗǝm ɗàng.>>\wj*
\p 
\v 9 Sǝ Shiman Bitǝrus pè wi eare ama, <<Mǝtalabangŋo, akusǝam nda nǝmurǝia a nǝ lak ka ɗàng, lákkàm abuam andǝ ɓamuram gbal!>>
\p 
\v 10 Pǝlǝa Yesu na ama, \wj <<Ɓwa mǝnana sussǝna ka, akusǝi na à nǝ̀ bangce lea ka. Sǝ wu fànà kat, kǝ ɓwa mwashat nda ueo atà wun ngga.>>\wj*
\v 11 Yesu ka angŋa dǝmba súrǝ́nà rǝ ɓwa mǝnana nǝ̀ nggá me ka. Nda gìr mǝnana tsǝa sǝ bang ama, \wj <<Wun kat sǝ wu fà ɗàng.>>\wj*
\p 
\v 12 Anzǝm mǝnana langŋǝnia wia akusǝia ka, pǝlǝa nyesǝ daura male oasǝi arǝì, sǝ nyare kya do a ban-do male. Pǝlǝa nea wia ama:
\pi1 \wj Wu súrǝ̀ gir mǝno ado ǝn pakka wun ngga le?\wj*
\v 13 \wj Wu kǝ tunǝam ama Malǝm, sǝ Mǝtalabangŋo. Sǝ wu ɓwarki ɗang, anggo sǝ ǝn pa.\wj*
\v 14 \wj Sǝ mǝnana mim Mǝtala wun andǝ Mǝkania wun gìr, ǝn lákkà wun akusǝ wun ngga, wun gbal ka dumǝna amur wun, wun nǝ̀ lákkià rǝ wun akusǝu.\wj*
\v 15 \wj Ado ka, gìr mǝnana ǝn pê ka, kusǝu na ǝn tsǝka wun ngga, ace mǝnana ɓǝ̀ wu kǝ pakkia rǝ wun anggo ka.\wj*\f + \fr 13:15 \ft Ɓalli gbal aɓa: \xt 1Bit 2:21\xt*\ft .\f*
\v 16 \wj Mǝ nda ban bangga wun mǝsǝcau, kǝ guro pà kàm gulo kútì mǝtala-ɓala male ɗàng, sǝ kǝ mǝturonjar pà kàm nǝ́ gulo kútì ɓwa mǝnana túrí ka ɗàng.\wj*
\v 17 \wj Mǝno ado wu sùrǝ́nà rǝ mǝnia yì mǝsǝcau ka, ɓǝ̀ wu tsǝì aɓa túró ka Ɓakuli nǝ̀ tsǝka wun buì!\wj*\f + \fr 13:17 \ft Ɓalli gbal aɓa: \xt Luk 11:28; Jem 1:25\xt*\ft .\f*
\pi1 
\v 18 \wj Ən pa aban nacau amur wun kat ɗàng, acemǝnana ǝn súrǝ́nà rǝ aɓwana mǝnana ǝn tarkia ka. Sǝ cau mǝnana Malǝmce mala Ɓakuli bang ama, <<Kǝ yì, yì ɓwa mǝnana oasǝ buì atàm a kwar ka nda pǝlǝ arǝàm ngga,>> dumǝna púp nǝ̀ lùmsǝo.\wj*\f + \fr 13:18 \ft Ɓalli gbal aɓa: \xt Ang 41:9\xt*\ft .\f*
\pi1 
\v 19 \wj Mǝ nda aban na wun man yì cau ka ado sǝ ɓǝ̀ yi lumsǝo, ace mǝnana ɓǝ̀ yi lumsǝna ka, wun nǝ̀ earnǝ mim ama <<Mǝ Nda kǝ ɓwe mǝnana ǝn na nǝma Mǝ nda ka.>>\wj*
\v 20 \wj Sǝ mǝ nda ban bangga wun mǝsǝcau: ɓwa mana kat ak ɓwa mǝnana ǝn túrí ka, mǝ nda akiyiam gbal ka, sǝ ɓwa mana kat em ngga, nda rǝ ak Tárrám mǝnana tasǝam ngga.\wj*\f + \fr 13:20 \ft Ɓalli gbal aɓa: \xt Mat 10:40; Luk 10:16\xt*\ft .\f*
\s1 Yesu sǝlǝna ama Yahuda nǝ̀ ngga me
\r (Matiu 26:20-25; Markus 14:17-21; Luka 22:21-23)
\p 
\v 21 Anzǝm mana Yesu bangŋǝna man yì cau ka, bumkiɗikea ɓākì kǝ̀rkǝ́r aɓa bangŋo, sǝ ne bwāng ama, \wj <<Mǝ nda ban bangga wun mǝsǝcau, ɓeɓwa nda aɓalǝ wun nǝ̀ nggá mem.>>\wj*
\p 
\v 22 Kara alaggana male sǝngi rǝarǝia, à kǝ ndali ko yana ateà nakiyi cau amurí.
\v 23 Ɓè lagga mǝnana Yesu earkiyi ace raka nda a ban-do a nkanggari Yesu.
\v 24 Pǝlǝa Shiman Bitǝrus lǝmdǝì cau nǝ bui ama ɓǝ̀ ɗì Yesu, ɓǝ̀ na ɓwa mǝnana nakiyi cau amurí ka.
\p 
\v 25 Pǝlǝa lagga mǝno pǝlǝ rǝi aban Yesu sǝ ɗì ama, <<Mǝtalabangŋo, yana ɓwe atà sǝm a nakiyi cau amurí le?>>
\p 
\v 26 Yesu pa eare ama, \wj <<Nda ɓwa mǝnana ado mǝ nǝ oasǝ nɗǝmo a mbú mǝ nǝ pè wi ka.>>\wj* Pǝlǝa Yesu ɓwan nɗǝmo, ɗàrǝ́ mbú, sǝ pè Yahuda muna mala Shiman Iskariyoti.
\v 27 Lang Yahuda ak nɗǝmo she ka, kara Shetan kutia rǝì. Sǝ Yesu ne wi ama, \wj <<Lo tsuk-tsuk, kya pak gìr mǝnana a nǝ pak ka.>>\wj*
\v 28 Sǝ kǝɓwa pà kàm ateà a ban-li mǝnana súrǝ̀ gir mǝnana tsǝa sǝ Yesu ne wi man yì cau ka ɗàng.
\v 29 Sǝ acemǝnana Yahuda nda mǝbwal boalo malea ka, aɓea laggana kǝ sǝni kǝla Yesu nda ban ne wi ɓǝ̀ kyane ɓǝ̀ kya kúr gìr mǝnana à nǝ̀ pàngŋǝ̀nà túró nǝi ace Lamsan ngga. Ko a na raka, ɓǝ̀ kya pê amǝ'tǝ̀r aɓa boalo mǝnana a buì ka.
\v 30 Anzǝm mana Yahuda shekina nɗǝmo ka, pǝlǝa lo tù puro. Sǝ du pǝndǝna.
\s1 Bǝsa nzongcau
\p 
\v 31 Anzǝm mana Yahuda nyìngŋǝ̀nà banì ka, Yesu na ama:
\pi1 \wj Ado ka pwari kārǝ́na mǝnana Muna mala Ɓwa nǝ̀ kutio aɓa gulo male ka, sǝ Ɓakuli ka, nǝ̀ kum gulo atà kusǝì.\wj*
\v 32 \wj Sǝ acemǝnana Ɓakuli nǝ̀ kum gulo atà kusǝ Muni ka, banì pà nǝ̀ sau ɗang, Ɓakuli nǝ̀ pè Muni gulo.\wj*
\pi1 
\v 33 \wj Wun amunem, mǝ nda mǝ nǝ do atà wun zuku. Wun nǝ̀ altam, sǝ kǝla mǝnana ǝn banggi aɓwana-mǝgule mala amǝ Yahudi ka, ban mǝnana ǝn kákiyi kam ngga, pà wu nǝ̀ gandǝ ká kàm ɗàng.\wj*
\pi1 
\v 34 \wj Sǝ ace mǝno ka mǝ ndarǝ pa wun bǝsa nzongcau: Wu earce rǝarǝ wun. Kǝla mǝnana ǝn earce wun ngga, anggo sǝ wun nǝ̀ dum nǝ earcea rǝ wun.\wj*
\v 35 \wj Ɓǝ̀ wu ndanǝ earcea rǝ wun ngga, aɓwana kat nǝ̀ sǝlǝ ama wu nda ka amǝkpatam.\wj*
\s1 Yesu sǝlǝna ama Bitǝrus nǝ̀ makgìr súrǝè
\r (Matiu 26:31-35; Markus 14:27-31; Luka 22:31-34)
\p 
\v 36 Shiman Bitǝrus ɗì Yesu ama, <<Mǝtalabangŋo, a nǝ ká a ke le?>>
\p Yesu eari wi ama, \wj <<Ado ka a pà nǝ gandǝ ká atàm aban mǝnana mǝ nǝ ká kàm ngga ɗàng, sǝ nǝnzǝ́mò ka a nǝ gandǝ yiu atàm.>>\wj*
\p 
\v 37 Pǝlǝa Bitǝrus ɗì ama, <<Mǝtalabangŋo, ace mana sǝ pà mǝ nǝ gandǝ ká atò ado ɗàng? Ən earǝna mǝ nǝ wu aceo.>>
\p 
\v 38 Yesu ear ama, \wj <<A na ama a nǝ pà yilǝmio, a nǝ wu acem ɓafo? Mǝ nda ban banggo mǝsǝcau, kaniama nggǔ nǝ̀ ɓua ka, a nǝ makgirem kusǝ tàrú ama a súrǝàm ɗàng.>>\wj*
\c 14
\s1 Yesu nda njargula ká aban Ɓakuli
\p 
\v 1 \wj <<Ɓabum wun ɓǝ̀ kǝa kiɗiki ɗàng. Wu pà ɓamur wun aban Ɓakuli, sǝ wu pà ɓamur wun gbal abanam.\wj*
\v 2 \wj Aɓa ɓala mala Tárrám ngga aban-do nda kam pas. Ɓǝ̀ pa anggo raka ɓǝn bangŋǝna wun. Mǝ ká mǝ nǝ nggá gilǝki ban-do ace wun.\wj*
\v 3 \wj Sǝ ɓǝ̀ ǝn warina ǝn gilǝkina wun ban-do ka, mǝ nǝ nyare mǝ nǝ yia kúllí wun, ace mǝnana ban mana mǝ nda kam ngga, abanì sǝ wun nǝ̀ pǎ.\wj*
\v 4 \wj Wu sùrǝ́nà rǝ njargula ká a ban mǝnana mǝ nǝ ká kàm ngga.>>\wj*
\p 
\v 5 Toma ne wi ama, <<Mǝtalabangŋo, sǝm súrǝ̀ ban mǝnana a nǝ ká kàm ngga ɗàng, sǝ lang sǝ sǝm nǝ̀ súrǝ̀ njar ká a banì le?>>
\p 
\v 6 Yesu eari wi ama, \wj <<Mǝ nda njargula, Mǝ nda mǝsǝcau, sǝ Mǝ nda yilǝmu; kǝɓwa pà nǝ̀ ká aban Ɓakuli Tárrú ɗang she nǝ banam.\wj*
\v 7 \wj Ɓǝ̀ wu sùrǝ́nà rǝàm ngga, wu sùrǝ́nà rǝ Tárrám. Sǝ twal ado aban ká a dǝmba ka wu sùrǝ́nà rǝì, sǝ wu sǝnǝ nǝi.>>\wj*
\p 
\v 8 Pǝlǝa Filip ne wi ama, <<Mǝtalabangŋo, lǝmdǝa sǝm yì Tárrú; mani ka kārǝ́na sǝm.>>
\p 
\v 9 Yesu ne wi ama:
\pi1 \wj Filip, ǝn sauwuna nǝ do atà wun, sǝ bà ado ka a malaká súrǝàm ɗàng? Ɓwa mǝnana sǝnǝnam ngga sǝnǝna Tárrám. Sǝ palang sǝ a kǝ na ama mǝ lǝmdǝa wun rǝì?\wj*
\v 10 \wj A ear mbo ama mǝ nda aɓa Tárrám, sǝ Tárrám ngga nda a ɓalǝam? Acau mǝnana ǝn nggǝ na wun ngga à pur nǝ banam ɗàng, Tárrám mǝnana dukiyi a ɓalǝam ngga nǝ̀ pakkiyi túró male nǝ mim.\wj*
\v 11 \wj Wu earnǝ mim ama mǝ nda aɓa Tárrám, sǝ Tárrám ngga nda a ɓalǝam. Sǝ ɓǝ̀ ana raka, wu earnǝ mim ace atúró mǝnana wu sǝnam ǝn nggǝ pea ka.\wj*
\v 12 \wj Mǝ nda ban bangga wun mǝsǝcau, ɓwa mǝnana pà ɓamúrì a banam ngga, nǝ̀ pàk agir-ndali kǝla amǝnana ǝn pea ka. Yàle nǝ̀ pàkki agir mǝgulke mǝnana à kútì amǝnana ǝn pea ka, acemǝnana mǝ ndo mǝ nǝ o aban Tárrám.\wj*
\v 13 \wj Sǝ mǝ nǝ pàk gìr mǝnana kat wu zǝmba aɓa lullǝam ngga, acemǝnana Muna ka ɓǝ̀ yinǝì Tárrí gulo.\wj*\f + \fr 14:13 \ft Ɓalli gbal aɓa: \xt Mat 7:7; Yoh 15:7,16; 16:23; Jem 1:5\xt*\ft .\f*
\v 14 \wj Wu zǝm gir mǝnana kat wu earkiyi ce ka aɓa lullǝam, mǝ nǝ pè.\wj*
\s1 Yesu pàcau mala Bangŋo Mǝfele
\pi1 
\v 15 \wj Ɓǝ̀ wu kǝ earcem ngga, wun nǝ̀ kpata anzongcau mem.\wj*\f + \fr 14:15 \ft Ɓalli gbal aɓa: \xt Yoh 15:10; 1Yoh 5:3; 2Yoh 6\xt*\ft .\f*
\v 16 \wj Sǝ mǝ nǝ zǝmbi Tárrám, sǝ nǝ̀ pa wun Mǝbwala wun nggam, mǝnana nǝ̀ yia do atà wun bà málá male ka.\wj*
\v 17 \wj Yì nda kǝ Bangŋo mana kǝ lǝmdǝ mǝsǝcau amur Ɓakuli ka. Amǝ'kpata ɓanza pa nǝ̀ gandǝ é ɗàng, acemǝnana à kǝ sǝni ɗàng, sǝ à súrǝì ɗàng. Sǝ wun ngga wu súrǝì, acemǝnana ndanǝ do atà wun ado, sǝ nǝnzǝ́mò ka nǝ̀ nggá do a ɓabum wun.\wj*
\pi1 
\v 18 \wj Ɓǝ̀ ǝn umna ka, pà mǝ nǝ nying wun kǝla akáwá ɗang, mǝ nǝ yiu a ban wun.\wj*
\v 19 \wj Banì pà nǝ̀ sau ɗang, ɓanza pà nǝ̀ sǝnam ɗǝm ɗàng, sǝ wun ngga wun nǝ̀ sǝnam. Sǝ acemǝnana mǝ ndanǝ yilǝmu ka, wun gbal ka wun nǝ̀ dum nǝ yilǝmu.\wj*
\v 20 \wj Ɓǝ̀ pwarî mǝno yina ka, wun nǝ̀ sǝlǝ ama mǝ nda aɓa Tárrám, sǝ wun ngga wu nda a ɓalǝam, sǝ mǝ nda aɓalǝ wun.\wj*
\v 21 \wj Ɓwa mǝnana kat ak anzongcau mem sǝ kǝ kpatea ka, nda ɓwa mǝnana kǝ earcem ngga. Sǝ ɓwa mǝnana kǝ earcem ngga, Tárrám nǝ̀ earce ɓwe, sǝ mim gbal ka mǝ nǝ earce, mǝ nǝ lǝmdǝ ɓamúràm a baní.\wj*
\p 
\v 22 Pǝlǝa Yahuda (mǝnana nda Yahuda Iskariyoti raka) banggi wi ama, <<Mǝtalabangŋo, mana tsǝa sǝ a nǝ lǝmdǝ ɓamuro a ban sǝm, sǝ a pà nǝ lǝmdǝì ɓanza kat ɓamuro ɗàng?>>
\p 
\v 23 Yesu eari wi ama:
\pi1 \wj Ɓwa mǝnana kat earcem ngga, nǝ̀ kpata kanigir mem, Tárrám nǝ̀ earce, sǝ mim sǝnǝ Tárrám ngga, sǝm nǝ̀ yiu a baní sǝm nǝ̀ do atè.\wj*\f + \fr 14:23 \ft Ɓalli gbal aɓa: \xt 1Yoh 2:24; Sǝn 21:3\xt*\ft .\f*
\v 24 \wj Ɓwa mǝnana kǝ earcem raka, pà nǝ̀ kpata kanigir mem ɗàng. Sǝ acau mǝnia wu kǝ oea ka, à mem na ɗang, à pur nǝ ban Tárrám mǝnana tasǝam ngga.\wj*
\pi1 
\v 25 \wj Amǝnia yì acau ka, ǝn nggǝ bangga wunia acemǝnana mǝ nda aban wun ado.\wj*
\v 26 \wj Sǝ Mǝ'pa wun gbasha, yì Bangŋo Mǝfele, mǝnana Tárrám nǝ̀ tasǝi aɓa lullǝam ngga, nǝ̀ yia kania wun agirbunda kat, sǝ nǝ̀ kasǝɓalǝ wun arǝ agir mǝnana kat, ǝn bangga wun ngga.\wj*
\pi1 
\v 27 \wj Mǝ ndya ǝn nggǝ nying wun nǝ dorǝpwala ka. Sǝ mǝnia yì dorǝpwala ǝn pākiyi ka, ɓanza pànǝi nǝ̀ pà ɗàng. Acemani ka, ɓabum wun ɓǝ̀ kǝa kiɗiki ɗàng, sǝ ɓangciu ɓǝ̀ kǝa pàkka wun ɗàng.\wj*\f + \fr 14:27 \ft Ɓalli gbal aɓa: \xt Yoh 16:33; Filp 4:7; Kol 3:15; Yoh 20:19\xt*\ft .\f*
\pi1 
\v 28 \wj Wu ɗenyinǝ cau mǝnana ǝn bangga wun ama, mǝ nǝ o, sǝ mǝ nggá nyar aban wun ɗǝm ngga. Ɓǝ̀ mǝsǝcau wu earǝnacem ngga, ban nǝ̀ ɓoara wun ace o mem aban Tárrám, mǝnana kútiǎm nǝ gulo ka.\wj*
\pi1 
\v 29 \wj Ən nanà wun ce amǝnia yì agir ka ado sǝ ɓǝà yì lumsǝo, ace mǝnana ɓǝà yì lumsǝna ka, wun nǝ̀ ear ama cau mem ngga mǝsǝcau na.\wj*
\v 30 \wj Pà mǝ nǝ samsǝ ban cau mǝnana mǝ nǝ na wun ngga ɗǝm ɗàng, acemǝnana murǝm mala ɓanza man ndya kǝ yiu ka, sǝ pànǝ rǝcandǝa amuram ɗàng.\wj*
\v 31 \wj Mǝ nǝ pak gìr mǝnana Tárrám banggàm ɓǝ̀ ǝn pak ka, ace mǝnana koyan a ɓanza ka ɓǝ̀ sǝlǝ ama ǝn nggǝ earce Tárrám.\wj*
\pi1 \wj Wu lo, ɓǝ̀ sǝm o.\wj*
\c 15
\s1 Yesu nda nggun anap mǝ'mǝsǝcaunì
\pi1 
\v 1 \wj Mǝ nda nggun anap mǝ'mǝsǝcaunì, sǝ Tárrám nda mǝtsǝkkir ɓaban.\wj*\f + \fr 15:1 \ft Ɓalli gbal aɓa: \xt Isha 5:1-7; Ezǝk 19:10; Mar 12:1-9; Mat 15:13; Rom 11:17\xt*\ft .\f*
\v 2 \wj Ko ya bu-nggun a ɓalǝam mǝnana kǝ pa ɓǝle raka, kǝ kasǝi kǝ túrí a nzali, sǝ abu-nggun mǝnana à kǝ pa ɓǝlea ka, kǝ gilǝkicea ace mǝnana ɓǝà ɓoaro ɓǝà pa ɓǝlea kpǝm ngga.\wj*
\v 3 \wj Cau mǝnana ǝn kania wun ngga gilǝkina wun, wu fànà.\wj*
\pi1 
\v 4 \wj Wu do a ɓalǝam sǝ mim ngga mǝ nǝ do aɓalǝ wun. Kǝla mǝnana bu-nggun anap pà nǝ̀ gandǝ pa ɓǝle nǝmurǝì raka, she ɓǝ̀ dumǝna aɓa nggea ngguni ka, anggo gbal sǝ wun ngga pà wù nǝ̀ gandǝ pa ɓǝla wun ɗang, she ɓǝ̀ wu dumǝna a ɓalǝam ngga.\wj*\f + \fr 15:4 \ft Ɓalli gbal aɓa: \xt Yoh 6:56; 1Yoh 2:6\xt*\ft .\f*
\pi1 
\v 5 \wj Mǝ nda nggun-anap, sǝ wu nda ka bu-nggun. Ɓǝ̀ ɓwa do a ɓalǝam, sǝ ǝn do a ɓālǝi ka, nǝ̀ pusǝ ɓǝle kpǝm. Ɓǝ̀ nǝ́ mim raka pà wù nǝ̀ gandǝ pak ɓè kǝgìr ɗàng.\wj*
\v 6 \wj Ɓǝ̀ koya ɓwa na sǝ do a ɓalǝam raka, nda kǝla bu-nggun mǝnana à túrí sǝ im ngga; a'ulang abu-nggun mǝno ka aɓwana kǝ ramgia, à nǝ̀ soea aɓa bǝsa à nǝ̀ pisǝia.\wj*
\pi1 
\v 7 \wj Sǝ ɓǝ̀ wu do a ɓalǝam, sǝ cau mem do aɓalǝ wun ngga, wu zǝmbi Ɓakuli gir mǝnana kat wu earkiyice ka, sǝ nǝ̀ pa wun girnî.\wj*\f + \fr 15:7 \ft Ɓalli gbal aɓa: \xt Yoh 14:13; 16:23; Mat 7:7; Jem 1:5\xt*\ft .\f*
\v 8 \wj Ɓǝ̀ wu pusǝ aɓǝla wun kpǝm ngga, nda lǝmdǝ ama wu nda ka laggana mem ngga. Sǝ mǝno gbal ka nda nǝ̀ yinǝì Tárrám nǝ́ gulo ka.\wj*
\pi1 
\v 9 \wj Kǝla mǝnana Tárrám kǝ earcem ngga, anggo sǝ ǝn nggǝ earce wun. Wu do aɓa earcearǝu mem.\wj*
\v 10 \wj Ɓǝ̀ wu kpata anzongcau mem ngga, wun nǝ̀ do aɓa earcearǝu mem, kǝla mǝnana ǝn kpata anzongcau mala Tárrám sǝ ǝn do aɓa earcearǝu male ka.\wj*
\pi1 
\v 11 \wj Ən bangga wun agir mǝnia ka, ace mǝnana ɓǝ̀ bumpwasǝa mem do aɓalǝ wun, sǝ ɗǝm ngga, ɓǝ̀ bumpwasǝa ma'wun ɓǝ̀ lùmsǝo.\wj*
\v 12 \wj Mǝnia ka nda nzongcau mem: Wu earce rǝarǝ wun kǝla mǝnana ǝn earce wun ngga.\wj*\f + \fr 15:12 \ft Ɓalli gbal aɓa: \xt Yoh 13:34\xt*\ft .\f*
\v 13 \wj Earcearǝu mǝgule mǝnana kat ɓwa nǝ̀ lǝmdǝì agyajam male ka, nda mǝnana ɓǝ̀ pà yilǝmi acea ka.\wj*\f + \fr 15:13 \ft Ɓalli gbal aɓa: \xt Rom 5:7; Yoh 10:11\xt*\ft .\f*
\v 14 \wj Ɓǝ̀ wu kǝ pak gìr mǝnana ǝn bangga wun nǝma wu pak ka, wu nda ka gyajam mem.\wj*\f + \fr 15:14 \ft Ɓalli gbal aɓa: \xt Luk 12:4\xt*\ft .\f*
\v 15 \wj Pa mǝ nǝ tunǝ wun ɗǝm ama aguro ɗàng, acemǝnana guro ka súrǝ̀ gir mǝnana mǝtala-ɓala male kǝ pak ka ɗàng. Ado ka, wu nda ka gyajam mem, acemǝnana ǝn nanà wun gìr mana kat ǝn ok a kún Tárrám ka.\wj*
\pi1 
\v 16 \wj Wun nǝ̀ tàram ɗang, mǝ nda mǝnana ǝn târ wun, sǝ ǝn pa wun túró nǝma wu kya pâ ɓǝla wun, ulang ɓǝle mǝnana pà nǝ̀ kiɗiki raka. Anggo ka sǝ Tárrám nǝ̀ pa wun gìr mǝnana kat wu zǝmbi wi aɓa lullǝam ngga.\wj*
\v 17 \wj Mǝnia ka nda nzongcau mǝnana ǝn pa wun ngga: Wu earce rǝarǝ wun.\wj*
\s1 Ɓinǝmǝsǝu mala ɓanza arǝ // amǝkpata Yesu
\pi1 
\v 18 \wj Ɓǝ̀ ɓanza ɓinǝmǝsǝ wun ngga, wu sǝlǝ ama, ɓinǝna mǝsǝam gbal a dǝmba.\wj*
\v 19 \wj Ɓǝ̀ wu nda ka mala ɓanza ka, ɓanza nǝ̀ earce wun kǝla amale. Sǝ ado ka wu nda ka mala ɓanza ɗàng. Acemǝnana ǝn tarki wun ɓǝ̀ wu purî ɓá ɓanza ka, nda tsǝa sǝ ɓanza kǝ ɓinǝmǝsǝ wun ngga.\wj*
\v 20 \wj Wu ɗenyinǝ cau mǝnana ǝn bangga wun nǝma, <<Kǝ guro pà kàm gulo kútì mǝtala-ɓala male ɗàng.>>\wj*\f + \fr 15:20 \ft Ɓalli gbal aɓa: \xt Mat 10:24; Luk 6:40; Yoh 13:16; 1Kor 4:12; Atúró 4:17; 1Bit 4:14; Sǝn 2:3\xt*\ft .\f*\wj Ɓǝà pàm tanni ka, à nǝ̀ pà wun tanni gbal. Sǝ ɓǝ̀ pǝlǝa ama à kpanatà kanigir mem ngga, à nǝ̀ kpata kanigir ma'wun gbal.\wj*
\pi1 
\v 21 \wj À nǝ̀ pakka wun amǝnia yì agir kat ka atàcau mem, acemǝnana à súrǝ̀ Tárrám mǝnana tasǝam ngga ɗàng.\wj*
\v 22 \wj Ɓǝ̀ ǝn yiu ma ǝn yi namia cau raka, ɓǝ́ cauɓikea pa a ɓamuria ɗàng. Sǝ ado ka à pànǝ kun nacau ace acauɓikea malea ɗàng.\wj*
\pi1 
\v 23 \wj Ɓwa mǝnana kat ɓinǝ mǝsǝam ngga, ɓinǝna mǝsǝ Tárrám gbal.\wj*
\v 24 \wj Ɓǝ̀ ǝn pakki ma agir mǝnana kǝɓwa malaká pea aɓalǝia raka, ɓǝ́ à pà nǝ̀ kumia nǝ cauɓikea ɗang. Sǝ ado ka à sǝnǝna amǝnia yì agir-ndali ǝn pea ka, sǝ kat andǝ mǝno ka, à ɓinǝ mǝsǝam sǝnǝ Tárrám.\wj*
\v 25 \wj Mǝnia ka nda yi lùmsǝ gir mǝnana à gilǝì aɓa Malǝmce mala Ɓakuli ama: <<À ɓinǝ mǝsǝam ɓà, tǝri pà kàm ɗàng.>>\wj*\f + \fr 15:25 \ft Ɓalli gbal aɓa: \xt Ang 35:19; 69:4\xt*\ft .\f*
\pi1 
\v 26 \wj Nǝ nzǝ́mò ka mǝ nǝ tasǝa wun Mǝbwali aɓwana, yì Bangŋo mala mǝsǝcau mǝnana nǝ̀ pur nǝban Tár sǝm aban yiu a ban wun ngga, nǝ̀ yia bang kúni kat amuram.\wj*
\v 27 \wj Sǝ wun gbal ka, dumǝna ama wun nǝ̀ nakunam a ban aɓwana, acemǝnana tita túró mem ngga sǝm nda a tarǝ sǝm sǝnǝa wun.\wj*
\c 16
\pi1 
\v 1 \wj Ən na wun amǝnia yì acau ka, ace mǝnana wu kǝa vwaki bu wun arǝ paɓamuru ma'wun a banam ɗàng.\wj*
\v 2 \wj À nǝ̀ pǝr wun arǝ yiu aɓalǝ andakpapi, sǝ pwari na kǝ yiu ka, mana ɓwa mǝnana wal-lú wun ngga nǝ̀ twali ama nda ban pakki Ɓakuli túró.\wj*\f + \fr 16:2 \ft Ɓalli gbal aɓa: \xt Yoh 9:22; Atúró 26:9-11; Isha 66:5\xt*\ft .\f*
\v 3 \wj À nǝ̀ pakka wun amǝnia yì agir ka acemǝnana à malaká súrǝ̀ Tárrám ɗàng, sǝ à malaká surǝam gbal ɗàng.\wj*
\v 4 \wj Mǝ nda arǝ bangga wun agir mǝnia ka ado, ace mǝnana ɓǝ̀ pwari nì yi kārǝ́na, sǝ à tinata pa wun tanni ka, ɓǝ̀ ɓalǝ wun kasǝa ama ǝn nunna kir wun. Ən bangga wun agir mǝnia ka atadǝmbe ɗàng, acemǝnana banem nǝ̀ sauwa atà wun.\wj*
\s1 Túró mala Bangŋo mala Ɓakuli
\pi1 
\v 5 \wj Ado ka, mǝ ndo mǝ nǝ nyare a ban Tárrám mǝnana tasǝam ngga, sǝ kǝɓwa aɓalǝ wun ɗiem ban mǝnana mǝ nǝ ká kam ngga ɗàng.\wj*
\v 6 \wj Sǝ acemǝnana ǝn bangga wun ngga, kara wu lùmsǝ nǝ bumkiɗikea.\wj*
\v 7 \wj Sǝ aɓa mǝsǝcau ka, o mem ngga nda ace ɓoaro ma'wun. Ɓǝn o raka, Ɓwa mǝnana nǝ̀ kwarkir wun, yì Bangŋo mala Ɓakuli ka, pà nǝ̀ yiu ɗang. Sǝ ɓǝn o ka, mǝ nǝ nggá tasǝi ɓǝ̀ yiu a ban wun.\wj*
\pi1 
\v 8 \wj Sǝ ɓǝ̀ yina ka, nǝ̀ yia pusǝta aɓwana a ɓanza, nǝ̀ lǝmdǝia wia ɓwarkio mala ɗenyicau malea amur cauɓikea, andǝ gir mana nda a njarì, sǝ amur ɓashi mala Ɓakuli mana kǝ yiu ka.\wj*
\v 9 \wj Nǝ̀ lǝmdǝì aɓwana ama cauɓikea malea ka, nda mǝnana ama à ginǝ pa ɓamuria a banam ngga.\wj*
\v 10 \wj Nǝ̀ lǝmdǝìa wia ɓwarkio malea amur gir mǝnana nda pepè a njarì ka, acemǝnana mǝ ndo mǝ nǝ nyare mǝ nǝ o a ban Tárrám, sǝ pà wu nǝ̀ sǝnam ɗǝm ɗàng.\wj*
\v 11 \wj Ɗǝm ngga nǝ̀ lǝmdǝì aɓwana ama ɓashi na amúrià acemǝnana Ɓakuli angŋa dǝmba kasǝna ɓashi amur Shetan, yì murǝm mala Ɓanza mǝnia ka.\wj*
\pi1 
\v 12 \wj Mǝ ndanǝ agir kam pas mǝnana ǝn earce na wun ngga, sǝ pà wu nǝ̀ gandǝ ea ado ɗàng.\wj*
\v 13 \wj Sǝ ɓǝ̀ Bangŋo, mǝnana kǝ lǝmdǝ mǝsǝcau amur Ɓakuli, yina ka, nǝ̀ yia kania wun ɓǝ̀ wu súrǝ̀ mǝsǝcau mǝnana kat kǝ pur a ban Ɓakuli ka. Pà nǝ̀ ɓun cau a ɓamúrì ɗàng, kǝgìr mǝnana ok a kun Ɓakuli ka, kǝ nda nǝ̀ bang ngga. Sǝ nǝ̀ bangga wun ce agir mǝnana à malaká yiu peatu raka.\wj*
\v 14 \wj Yì ka, nǝ̀ yinǝàm nǝ gulo, acemǝnana nǝ̀ twal cau mana ǝn ne ka sǝ nǝ̀ mǝngia wun ɓālǝi.\wj*
\v 15 \wj Agir mǝnana kat mala Tárrám na ka amem na. Nda gìr mana tsǝa sǝ ǝn na wun nǝma, Bangŋo ni nǝ̀ twal cau mǝnana mem na ka sǝ nǝ̀ mǝngia wun ɓālǝi.\wj*
\pi1 
\v 16 \wj Zuku ka pà wu nǝ̀ sǝnam ɗǝm ɗàng. Sǝ zuku anzǝmi ka wun nǝ̀ sǝnam ɗǝm.\wj*
\s1 Bumkiɗikea mala alaggana male // nǝ̀ pǝlǝ bumpwasǝa
\p 
\v 17 Aɓea alaggana male ɗiki rǝarǝia ama, <<Mana nda ɓacau male mǝnana ama, <Zuku ka pà wu nǝ̀ sǝnam ɗang, sǝ zuku anzǝmi ka wu nǝ̀ sǝnam.> Sǝ ɗǝm ngga ama, <Mǝ ndo mǝ nǝ o a ban Tárrám> ka?
\v 18 Sǝ <Zuku> mǝnana nakiyi ce ka, ɓālǝi aman le? Sǝm súrǝ̀ gir mǝnana nakiyi ka ɗàng!>>
\p 
\v 19 Yesu sǝlǝna ama à kǝ earce à nǝ̀ ɗì amurí, pǝlǝa nea wia ama:
\pi1 \wj Wu ndarǝ ɗiki rǝarǝ wun amur man nda ɓacau mǝnana ǝn na nǝma, <<Zuku ka pà wu nǝ̀ sǝnam ɗang, sǝ zuku anzǝmi ka wun nǝ̀ sǝnam ɗǝm>> ngga le?\wj*
\v 20 \wj Mǝ ndarǝ na wun mǝsǝcau: Wun nǝ̀ ɓua nǝ mǝrǝm, andǝ keban, amur gir mǝnana nǝ̀ kumam ngga, sǝ amǝ ɓanza ka à nǝ̀ pak bumpwasǝa. Wun nǝ̀ pak bumkiɗikea, sǝ bumkiɗikea ma'wun nǝ̀ yia pǝlǝ bumpwasǝa.\wj*
\pi1 
\v 21 \wj Ɓǝ̀ ɓwama malanǝ̀ gbáshí ka kǝ kutio aɓa tanni kwanban mala gbáshí acemǝnana pwari male yina; sǝ ɓǝ̀ yi gbashina ka, ɓālǝi lorǝna kwanban mala gbáshí, acemǝnana ban na ban ɓoari wi nǝ́ ɓǝl bǝsa muna a ɓanza.\wj*
\v 22 \wj Anggo sǝ wu pa: Adyan ngga wu ndanǝ bumkiɗikea, sǝ ǝn nggǝ na wun ama, mǝ nǝ nggá sǝn wun ɗǝm, sǝ ɓabum wun ngga nǝ̀ pakkiɗire, ulang bumpwasǝa mǝnana kǝɓwa pà nǝ̀ é arǝ wun raka.\wj*
\pi1 
\v 23 \wj A pwari mǝno ka, pà wu nǝ̀ zǝm kǝgìr ɗǝm a banam ɗàng. Ən nggǝ bangga wun mǝsǝcau, Tárrám nǝ̀ pa wun gir mǝnana kat wu zǝmba aɓa lullǝam ngga.\wj*
\v 24 \wj Yàle ado ka wu malaká zǝm kǝgìr aɓa lullǝam ɗàng: wu zǝmba sǝ à nǝ̀ pà wun, sǝ bumpwasǝa ma'wun nǝ̀ lùmsǝo.\wj*
\s1 Yesu nǝ̀ limurǝm amur ɓanza
\pi1 
\v 25 \wj Ən na wun amǝnia yì acau ka nǝ cauɓaɓi, sǝ pwari na kǝ yiu ka mǝnana pà mǝ nǝ na wun cau ɗǝm nǝ cauɓaɓi raka. Mǝ nǝ pusǝa wun cau a banfana amur Tárrám.\wj*
\v 26 \wj Sǝ wun nǝ̀ zǝmba aɓa lullǝam. Ən pa aban na nǝma mǝ nǝ zǝmbi Tárrám amur wun ɗang.\wj*
\v 27 \wj Tárrám nǝ ɓamúrì ka kǝ earce wun kǝ̀rkǝ́r, acemǝnana wu kǝ earcem, sǝ acemǝnana wu earnǝ mim ama ǝn pur nǝ bani ka.\wj*
\v 28 \wj Ən pur a ban Tárrám sǝ ǝn yiu a ɓanza, sǝ ado ka, mǝ ndo mǝ nǝ nying ɓanza mǝ nǝ nyare a ban Tárrám.\wj*
\p 
\v 29 Pǝlǝa alaggana male banggi wi ama, <<Ado wuni sǝ a kǝ pusǝa sǝm cau a banfana. Cauɓaɓe na a banggiyi ɗǝm ngga ɗàng.
\v 30 Adyan ngga sǝm sǝlǝna ama we ka a súrǝ̀ agir kat, ɓwa pà nǝ̀ na ama nǝ̀ ɗio kǝ cau ɗàng. Ace mǝno ka sǝm earǝna ama we ka a pur nǝban Ɓakuli.>>
\p 
\v 31 Yesu pǝlǝa eare ama:
\pi1 \wj Ado ka, wu earǝna nǝ mim le?\wj*
\v 32 \wj Wu sǝni, pwari na kǝ yiu ka, yàle nggearǝ pwari nì yina, yì mǝnana wun kat ka, wun nǝ̀ mesǝke, koyan ngga nǝ̀ bwal njar male, wun nǝ̀ ɗekiam nǝmurǝam. Sǝ ǝn pa gbal nǝmurǝam ɗàng, acemǝnana Tárrám nda atàm.\wj*\f + \fr 16:32 \ft Ɓalli gbal aɓa: \xt Yoh 4:23; Mar 14:27; Zak 13:7\xt*\ft .\f*
\v 33 \wj Ən bangga wun amǝnia yì acau ka, acemǝnana a ɓalǝam ngga wun nǝ̀ kum dorǝpwala. Aɓa mǝnia yì ɓanza ka, wun nǝ̀ kum patanni, sǝama ɓabum wun ɓǝ̀ kǝa ɓungi ɗang! Ən linamurǝm amur ɓanza!\wj*\f + \fr 16:33 \ft Ɓalli gbal aɓa: \xt Yoh 14:27; 15:18; Rom 8:37; 2Kor 2:14; Sǝn 3:21\xt*\ft .\f*
\c 17
\s1 Yesu pàk hiwi ace amǝkpate
\p 
\v 1 Anzǝm mǝnana Yesu malǝna naki acau mǝnia ka, pǝlǝa loasǝ mǝsǝì a kùli, sǝ pàk hiwi ama:
\pi1 \wj Dâ, adyan ngga bu-pwarî yina. Gusǝlǝ Munio ace mǝnana ɓǝ̀ Munio pò gulo mô ka.\wj*
\v 2 \wj A panì wi rǝcandǝa amur ɓanza kat, ɓǝ̀ pea aɓwana mǝnana a yinǝia a baní ɓǝà duk amǝkpate ka, yilǝmu mǝnana málá male pà kàm raka.\wj*
\v 3 \wj Sǝ mǝnia ka nda njar kum yilǝmu mǝnana pà nǝ̀ mal raka, ɓǝà súrǝ̀o, kǝ we Ɓakuli Mǝ'mǝsǝcau nì, andǝ Munio Yesu Kǝrǝsti mǝnana a túrí aɓa ɓanza ka.\wj*
\v 4 \wj Ən yinǝno nǝ́ gulo a ɓanza man, acemǝnana ǝn malǝna túró mô mana a pam ama ɓǝ̀n pê ka.\wj*
\v 5 \wj Sǝ ado ka, Dâ, nyesǝâm gulo a ɓadǝmbo, gulo mǝnana mǝ ndanǝi sǝnǝ we ɗiɗyal sǝ a yi pusǝ ɓanza ka.\wj*
\pi1 
\v 6 \wj Ən lǝmdǝni aɓwana mǝnana a pam mia a ɓanza ka rǝò. Yia ka amô na. A nǝ̀ pam mia, sǝ à kpanatà cau mò.\wj*
\v 7 \wj Yia adyan ngga à sǝlǝna ama koya gìr mǝ ndanǝi ka kǝ pur nǝ bano.\wj*
\v 8 \wj Ən pania wia cau mǝnana a pam ngga, sǝ yia gbal ka à angŋǝni; à sǝlǝna ama mǝsǝcau na ǝn pur a bano, sǝ à earǝna ama a nǝ̀ túrǎm.\wj*
\pi1 
\v 9 \wj Hiwi mem ngga, pà ace ɓanza ɗàng, nda kǝ cea, aɓwana mǝnana a pam ngga, acemǝnana yia ka amô na.\wj*\f + \fr 17:9 \ft Ɓalli gbal aɓa: \xt Luk 22:32; Yoh 14:16\xt*\ft .\f*
\v 10 \wj Aɓwana mǝnana kat mǝ ndanǝia ka amô na, sǝ a nda a pamia ka, ace mǝnana ɓǝà lǝmdǝ gulo mem aɓalǝia ka.\wj*
\pi1 
\v 11 \wj Ado ka mǝ ndo mǝ nǝ nying ɓanza, mǝ nǝ nyare a bano, sǝ yia ka à ndakani a ɓanza più. Dâ Ɓakuli Mǝfele! Yália, nǝ rǝcandǝa mala lùllǝò mǝnana a pam ngga, acemǝnana yia ka ɓǝà duk mwashat kǝla mǝnana sǝm nda mwashat sǝnǝ we ka.\wj*
\v 12 \wj A do mem sǝnǝia ka, ǝn yália, sǝ ǝn bwalia nǝ rǝcandǝa mala lùllǝò mǝnana a pam ngga. Kǝ ɓè ɓwàr ateà ɗàng, she kǝ yì ɓwa mǝnana dupî ká kìɗìkì ka, acemǝnana cau mò mana à gilǝì aɓa Malǝmce ka, ɓǝ̀ lùmsǝo.\wj*
\pi1 
\v 13 \wj Adyan ngga mǝ ndya ǝn nggǝ ká a bano ka. Ən nggǝ banggia wia amǝnia yia cau mǝnana mǝ ndakani più amǝnia yì ɓanza ka, acemǝnana ɓǝà lùmsǝ nǝ bumpwasǝa mem.\wj*
\v 14 \wj Ən pania wia cau mò, sǝ ɓanza kǝ ɓinǝ mǝsǝia, acemǝnana yia ka à nda ka mala ɓanza ɗàng, kǝla mǝnana mim ngga mǝ nda mala ɓanza raka.\wj*
\pi1 
\v 15 \wj Ən pa aban zǝmba nǝma wu pusǝia, ɓǝà nying ɓanza ɗàng. Mǝ nda aban zǝmba ama, wu bwalia, ɓǝà kǝa kútí a ɓabù Shetan, mǝɓealɓikea ɗang.\wj*
\v 16 \wj Yia ka à mala ɓanza mǝnia na ɗang kǝla mǝnana mim ngga mǝ nda mala ɓanza raka.\wj*
\v 17 \wj Tària ɓǝà duk amô nǝ mǝsǝcau mò; cau mò ka nda kǝ mǝsǝcau.\wj*
\v 18 \wj Kǝla mǝnana a túrǎm aɓa ɓanza ka, anggo gbal sǝ ǝn nggǝ túriá aɓa ɓanza.\wj*
\v 19 \wj Sǝ àkǝ̀ cea sǝ ǝn tàr ɓamúràm ɓǝ̀n duk mô, acemǝnana yia gbal ka, ɓǝà tàr ɓamuria aceo ɓǝà duk amô aɓa mǝsǝcau.\wj*
\pi1 
\v 20 \wj Hiwi mem ngga pà ace alaggana mem mǝnia nǝmurǝia ɗàng, nda gbal ace aɓwana mǝnana à nǝ̀ yia ak Cau Amsǝban mǝnana amǝkpatam nǝ̀ hamnǝi a banià ka.\wj*
\v 21 \wj Ən nggǝ pak hiwi nǝma yia kat ka ɓǝà duk mwashat, kǝla mǝnana mim sǝnǝ we, sǝm nda mwashat ka. Dâ, kǝla mǝnana a nda a ɓalǝam, sǝ mǝ nda a ɓālǝo ka, yia gbal ka ɓǝà do aɓalǝ sǝm, ace mǝnana ɓanza ɓǝ̀ eare ama a nǝ̀ túrǎm ngga.\wj*
\pi1 
\v 22 \wj Ən pania wia gulo mǝnana a pam ngga, acemǝnana ɓǝà duk mwashat, kǝla mǝnana mim sǝnǝ we sǝm nda mwashat ka.\wj*
\v 23 \wj Mim sǝnǝia ka sǝm nda mwashat, sǝ mim sǝnǝ we ka sǝm nda mwashat. Cia, ɓǝà kum ulang mǝnia yì dotarǝu mǝɓoarne ka aɓalǝia, ace mǝnana amǝɓanza ɓǝà sǝlǝ ama a nǝ̀ túrǎm, sǝ ɓǝà sǝlǝ gbal ama a kǝ earcea kǝla mǝnana a kǝ earcem ngga.\wj*
\pi1 
\v 24 \wj Dâ! Ən nggǝ earce nǝma aɓwana mǝnana a pamia ka, ɓǝà do atàm a ban mǝnana mǝ nda kam ngga; sǝ ɓǝà sǝn gulo mem mǝnana a pam, acemǝnana a kǝ earcem sǝ a yi pusǝ ɓanza ka.\wj*\f + \fr 17:24 \ft Ɓalli gbal aɓa: \xt Yoh 1:14; 17:5; Mat 25:34\xt*\ft .\f*
\v 25 \wj We Dâ Mǝ'cauɓoarna! Ɓanza súrǝ̀o ɗàng, sǝ mim ngga ǝn súrǝ̀o, sǝ amǝnia yì alaggana mem ngga, à sǝlǝna ama a nǝ̀ túrǎm.\wj*
\v 26 \wj Ən lǝmdǝnia wia rǝò, sǝ mǝ nǝ lidǝmba nǝ lǝmdǝia wia rǝò ɗǝm, ace mǝnana earcearǝu mana a ndanǝi arǝàm ngga ɓǝ̀ do aɓalǝia, sǝ mim ngga mǝ nǝ duk gbal aɓalǝia.\wj*
\c 18
\s1 À bwal Yesu
\r (Matiu 27:47-56; Markus 14:43-50; Luka 22:47-53)
\p 
\v 1 Anzǝm mǝnana Yesu malǝna hiwi ka, pǝlǝa lo andǝ alaggana male à eauwe a nkaring mala ɓangŋaban Kidǝron. À kya kutio a ɓè ɓaban mala anggun olif.\f + \fr 18:1 \ft Ɓalli gbal aɓa: \xt Mat 26:30,36; Mar 14:26,32; Luk 22:39; 2Sam 15:23\xt*\ft .\f*
\p 
\v 2 Yahuda, mǝnana mak Yesu ka, súrǝ́nà rǝ banì, acemǝnana kusǝ pas Yesu kǝ dapi kam andǝ alaggana male.
\v 3 Agbani Pǝris andǝ amǝ Farisi tasǝ amǝ'yál Ndàmǝgule mala Ɓakuli andǝ aɓea soje mala amǝ Roma, ɓǝa kyane atà Yahuda aban mǝnana Yesu nakam ngga. À kur rǝia nǝ agirbura, sǝ à bwal bǝsa arǝ aɓukan, andǝ apitǝla, pǝlǝa à puro à yì tusǝo a ɓabanì.\f + \fr 18:3 \ft Ɓalli gbal aɓa: \xt Mat 26:47-56; Mar 14:43-50; Luk 22:47-53\xt*\ft .\f*
\v 4 Sǝ Yesu ka angŋa dǝmba sǝlǝna gir mǝnana nǝ̀ kumi ka, pǝlǝa puro cam a ɓadǝmbia, sǝ ɗia ama, \wj <<Yana ɓwe na wu alkite?>>\wj*
\p 
\v 5 À eare ama, <<Yesu ɓwa Nazarat.>>
\p Banggia wia ama, <<Mǝ Nda.>>\f + \fr 18:5 \ft Ɓalli gbal aɓa: \xt Pur 3:14\xt*\ft .\f*
\p Yahuda, yì ɓwa mǝnana mak Yesu ka, nda aban came ateà.
\v 6 Lang Yesu banggia wia ama, <<Mǝ Nda>> ka, kara à nyar nǝ nzǝmia à sukki a nzali.
\v 7 Pǝlǝa Yesu nyare ɗia ama, \wj <<Yana ɓwe na wu alkiyite le?>>\wj*
\p À eare ama, <<Yesu Ɓwa Nazarat.>>
\p 
\v 8 Yesu eare ama, \wj <<Ən nanà wun nǝma Mǝ Nda. Sǝ ɓǝ̀ mǝ nda wu alkiyitam ngga, wu ɗeki alaggana mem mǝnia ka ɓǝa o.>>\wj*
\v 9 Mǝnia ka pa anggo ace mǝnana cau mana pur a kúni ka ɓǝ̀ lùmsǝo, mǝnana ama, \wj <<Dâ, aɓalǝ aɓwana mǝnana a pam ngga, ǝn turta kǝɓwa mwashat ɗang.>>\wj*\f + \fr 18:9 \ft Ɓalli gbal aɓa: \xt Yoh 17:12; 6:39\xt*\ft .\f*
\p 
\v 10 Shiman Bitǝrus kwetǝ nggeabyau, kwarǝna guro mala Pǝris Mǝgule nǝi, kasǝ kiri mǝlì kpat. (Lullǝ mǝno yì guro nda Malchus.)
\v 11 Yesu banggi Bitǝrus ama, \wj <<Nyesǝ nggeabyau mo oasǝi a ndè! A kǝ sǝni kǝla pa mǝ nǝ nu kwap mala tanni mǝnana Tárrám pam ama ɓǝn nu ka re?>>\wj*\f + \fr 18:11 \ft Ɓalli gbal aɓa: \xt Mar 10:38; 14:36\xt*\ft .\f*
\s1 Yesu a ɓadǝm Annas Pǝris Mǝgule
\r (Matiu 26:57-58; Markus 14:53-54; Luka 22:54)
\p 
\v 12 Pǝlǝa asoje andǝ mǝ'sàrǝ̀ban malea, andǝ amǝ munagara mala amǝ Yahudi, bwal Yesu, sǝ à taka abui.
\v 13 A tadǝmbe ka à umnǝ Yesu a ɓadǝm Annas, nkil Kayafas, yì Pǝris Mǝgule a mǝno yì pǝlǝa ka.
\v 14 Kǝ Kayafas mǝno nda kwarkir aɓwana-mǝgule mala amǝ Yahudi ama ndanǝ ɓoaro ɓǝ̀ ɓwa mwashat wú a kún aɓwana mala amǝ Yahudi ka.\f + \fr 18:14 \ft Ɓalli gbal aɓa: \xt Yoh 11:49-51\xt*\ft .\f*
\s1 Shiman Bitǝrus makgìr súrǝ̀ Yesu
\r (Matiu 26:69-70; Markus 14:66-68; Luka 22:55-57)
\p 
\v 15 Shiman Bitǝrus andǝ ɓe lagga mala Yesu wari a ban mǝnana à kútí nǝ Yesu kàm ngga. Mǝnia yì lagga ka Pǝris Mǝgule súrǝì pepè, nda sǝ à eari wi kutio aɓa ɓala mala Pǝris Mǝgule ka.
\v 16 Bitǝrus ka ueo aban came a kunɓala nǝ nza. Sǝ mǝnia yì lagga mana pǝris mǝgule súrǝì ka, nyare yiu yi nacau nǝ muna-ɓwama mǝnana à tamsǝi ace yál kunɓala ka, pǝlǝa earî Bitǝrus ɓǝ̀ kutio.
\v 17 Muna-ɓwame ɗì Bitǝrus ama, <<A nda gbal aɓalǝ amǝkpata ɓwa mǝno à bwali ka le?>>
\p Bitǝrus eari wi ama, <<Awo, ǝn pa aɓalǝia ɗàng.>>
\p 
\v 18 Ɗwal nda kam kǝ̀rkǝ́r, pǝlǝa amǝtúró palta andǝ amǝ munagara bwal bǝsa, à kǝ dandǝ rǝia. Sǝ Bitǝrus yiu, yi cam a bania a kun bǝsa.
\s1 Pǝris Mǝgule ɗiki Yesu
\r (Matiu 26:59-66; Markus 14:55-64; Luka 22:66-71)
\p 
\v 19 Pǝlǝa Pǝris Mǝgule tita ɗiki Yesu amur alaggana male andǝ kanigir male.
\v 20 Yesu banggi wi ama, \wj <<Acau mem ngga ǝn nea bwāng a ɓadǝm ɓwapǝndǝa kat. Sǝ ko aya pwari ka mǝ ndaban kanigir arǝ ndakpapi andǝ Ndàmǝgule mala Ɓakuli, ban ramba mala amǝ Yahudi. Ən na kǝ cau aɓa sǝmbǝrǝa ɗang.\wj*
\v 21 \wj Sǝ ace man sǝ à kǝ ɗìkiam? Ɗì ka aɓwana mǝnana à ok cau mana ǝn na ka. Yia ka à súrǝ́nà rǝ cau mǝnana ǝn na ka.>>\wj*
\p 
\v 22 Lang Yesu bangŋǝna anggo ka, ɓeɓwa aɓalǝ amǝ yál Ndàmǝgule, mǝnana came a banì, kwak Yesu a takiri, sǝ bang ama, <<Anggo sǝ a nǝ pǝlǝì Pǝris Mǝgule cau?>>
\p 
\v 23 Pǝlǝa Yesu ear ama, \wj <<Ɓǝ̀ ǝn nacau mǝnana mǝɓane na ka, banggàm ɓá ɓwarke, sǝ ɓǝ̀ mǝsǝcau na ǝn na ka, mana nda tǝr koem a takiram?>>\wj*
\p 
\v 24 Anggo, andǝa kǝ tà bu mǝnana à tàkà abu Yesu ka, sǝ Annas tasǝte a ban Kayafas, yì Pǝris Mǝgule.
\s1 Ɓaria andǝ tàruià tǝmce // súrǝ̀ Yesu mala Bitǝrus
\r (Matiu 26:71-75; Markus 14:69-72; Luka 22:58-62)
\p 
\v 25 Aɓa mǝno anggo ka, Shiman Bitǝrus nda àkǝ̀ bancame a kun bǝsa, aban dandǝ rǝì. Sǝ aɓwana a banì ɗì ama, <<We ka, a pa aɓalǝ alaggana mala ɓwa mǝno re?>> Pǝlǝa yì ka, tǝmce, na ama, <<Awo, ǝn pa aɓalǝia ɗàng.>>
\p 
\v 26 Sǝ ɓeɓwa mwashat aɓalǝ aguro mala Pǝris Mǝgule, ɓǝla mala ɓwa mǝnana Bitǝrus kasǝ kiri ka, nacau ama, <<Ən sǝno mǝni atà Yesu akanó a ɓaban re?>>
\p 
\v 27 Bitǝrus nyare tǝmce, ama, <<Awo mǝ nda ɗang.>> Anggo ka, kara nggu ɓua.
\s1 A warinǝ Yesu a ɓadǝm Bilatus
\r (Matiu 27:1-2,11-14; Markus 15:1-5; Luka 23:1-5)
\p 
\v 28 Nǝ dǝmbari ɗiɗyal ka à pusǝ Yesu a ɓala mala Kayafas, à um nǝi a banmǝgule mala Nggwamna, ɓwa Roma. Sǝ aɓwana-mǝgule mala amǝ Yahudi, mǝnana à tsǝki Yesu cau atè ka, à ɓinǝ kutio aɓa palta mala Nggwamna, acemǝnana ɓǝà kútí ka, à nǝ̀ pǝndǝki ɓamuria, mǝnana nǝ̀ tsǝa à pà nǝ̀ kùmô à nǝ̀ li girlina Lamsan Yàlîmurû raka.\f + \fr 18:28 \fq à nǝ̀ pǝndǝki ɓamuria, mǝnana nǝ̀ tsǝa à pà nǝ̀ kùmô à nǝ̀ li girlina Lamsan Yàlîmurû raka: \ft Amǝ Yahudi mǝnana à je aɓwana mala acilia anzali ko à gbashi bania tù a dǝm Lamsan Yàlîmurû ka à earia wia ɓǝa li girlina Lamsan Yàlîmurû ɗang.\f*
\v 29 Ace mǝno ka, Bilatus pur a bania, sǝ ɗia ama, <<Ya cau na wu yiu nǝi amur mǝnia yì ɓwa ka le?>>
\p 
\v 30 Pǝlǝa à eare ama, <<Ɓǝ̀ ɓwa mǝnia ka, mǝ'ɓealɓikea na raka, ɓǝ́ pa sǝm nǝ̀ yiu nǝi a bano ɗàng.>>
\p 
\v 31 Bilatus pǝlǝa banggia wia ama, <<Ɓǝ̀ nda anggo ka, wu um nǝi, wu kya ɓashi wi nǝ nggurcau ma'wun la.>>
\p Pǝlǝa amǝ Yahudi eare ama, <<Sǝm pà nǝ́ rǝcandǝa mala kasǝ ɓashi-lú amur kǝɓwa ɗàng.>>
\v 32 Mǝnia ka lùmsǝ cau mǝnana Yesu bang amur ulang lú mǝnana nǝ̀ wu ka.\f + \fr 18:32 \ft Ɓalli gbal aɓa: \xt Yoh 3:14; 12:32\xt*\ft .\f*
\p 
\v 33 Pǝlǝa Bilatus nyare aɓa palta male sǝ túrban ɓǝà kútí nǝ Yesu a baní. Ɗì Yesu ama, <<A nda murǝm mala amǝ Yahudi le?>>
\p 
\v 34 Yesu eari wi ama, \wj <<Mǝnia yì ɗiban ngga, a twali a mala ɓamuro le ko aɓea ɓwana na à no cau a muram ngga?>>\wj*
\p 
\v 35 Bilatus ne wi ama, <<Mim ngga mǝ nda ɓwa Yahudi le? Aɓwana mô andǝ agbani pǝris ma'wun na à yiu nǝ we a ɓashi a banam ngga. Mana ɗe a pa?>>
\p 
\v 36 Yesu eare ama, \wj <<Domurǝm mem ngga mala ɓanza mǝnia na ɗang. Ɓǝ̀ pǝlǝ ama mala ɓanza man na ka, ɓǝ́ amǝkpatam nǝ̀ munǝo acem, à pà nǝ̀ eari aɓwana-mǝgule mala amǝ Yahudi ɓǝà bwalam ɗang. Awo, domurǝm mem ngga mala ɓanza man na ɗang.>>\wj*
\p 
\v 37 Bilatus pǝlǝa ne Yesu ama, <<Ashe a nda murǝm!>>
\p Yesu eari wi ama, \wj <<A bang ama mǝ nda murǝm. Ace kǝ mani sǝ à ɓǝ̀lám, sǝ yiu mem a ɓanza ka nda ace na mǝsǝcau, sǝ ɓwa mǝnana kat kǝ camata mǝsǝcau ka, kǝ kwakikiri kǝ ok giem.>>\wj*
\p 
\v 38 Pǝlǝa Bilatus ɗì ama, <<Mana nda mǝsǝcau?>>
\s1 Bilatus pà Yesu ɓǝà wal-luí
\r (Matiu 27:15-31; Markus 15:6-20; Luka 23:13-25)
\p Bilatus nyare puro a ban amǝ Yahudi sǝ banggia wia ama, <<Mim ngga ǝn kumi nǝ ɓekǝ cauɓikea ɗang!
\v 39 Sǝ wun amǝ Yahudi ka, ko aya pǝlǝa sǝ ɓǝ̀ yi karǝ nǝ Lamsan Yàlîmurû ka, pàk ka wu kǝ earce ama ɓǝn panzǝa wun ɓwa mwashat atà aɓwana mǝnana à kùria a ndàkurban ngga. Ado ka, wu earce ɓǝn panzǝa wun mǝnia yì <Murǝm mala amǝ Yahudi> ka le?>>
\p 
\v 40 Sǝ à nyesǝi wi nǝ loasǝban ama, <<Awo, ɓwa mǝnia na à nǝ̀ panzǝa sǝmi ka ɗàng! Panzǝa sǝm Barabbas!>> (Barabbas ka à bwali acemǝnana yì ka, mǝ'mgbicau na.)
\c 19
\p 
\v 1 Bilatus pǝlǝa tsǝa à kwak Yesu nǝ kamso.
\v 2 Asoje marǝki zwe kǝla mbulan-murǝm sǝ à oasǝì Yesu a ɓamúrí. À túrì wi daura ulang mala amurǝma arǝì,
\v 3 sǝ à kǝ nyarke a ɓadǝmbi, à kǝ ne wi cau ɓanginǝban ama, <<Ɓǝ̀ rǝo pwalo, we murǝm mala amǝ Yahudi!>> Sǝ à kǝ koe a ɓamǝsǝi nǝ ɓabuia.
\p 
\v 4 Bilatus pǝlǝa pur ɗǝm a ban aɓwana-mǝgule mala amǝ Yahudi sǝ nea wia ama, <<Wu kwaki kir wun! Mǝ ndo mǝ nǝ pusǝì, mǝ nǝ yinǝi a ban wun, sǝama wu sǝlǝ ama mim ngga ǝn kumi nǝ ɓekǝ cauɓikea ɗang.>>
\v 5 Pǝlǝa Yesu pur a bania a nza, nǝ mbulan zwe a múrí andǝ daura mala amurǝma arǝì. Sǝ Bilatus nea wia ama, <<Ɓwe ndya ka!>>
\p 
\v 6 Lang agbani pǝris andǝ amǝ'yál Ndàmǝgule nǝ̀ sǝni ka, à loasǝ già a kùli à na ama, <<Gbàllì a nggun-gangndǝi! Gbàllì a nggun-gangndǝi!>>
\p Bilatus na ama, <<Wu twali la, wu kya gbàllì a nggun-gangndǝi nǝ ɓamur rǝ wun! Acemǝnana mim ngga ǝn kumi nǝ ɓekǝ cauɓikea ɗang.>>
\p 
\v 7 Pǝlǝa aɓwana-mǝgule mala amǝ Yahudi eari wi ama, <<Aɓa nggurcau ma'sǝm ngga, ɓoaro ɓǝ̀ wú, acemǝnana twal ɓamúrì ama yì ka, Muna mala Ɓakuli na!>>
\p 
\v 8 Lang Bilatus nǝ̀ ok man yì cau ka, gir nî pe wi ɓangciu kǝ̀rkǝ́r.
\v 9 Pǝlǝa nyesǝ Yesu wari nǝi aɓa palta ɗǝm sǝ ɗì ama, <<We ka, a pur a ya ban?>>
\p Sǝ Yesu ka duk kúni più, pǝlǝi wi kǝ cau ɗàng.
\v 10 Bilatus banggi wi ama, <<A pà nǝ nam cau ɗang? A sǝlǝ mbak ama mǝ ndanǝ rǝcandǝa mǝ nǝ panzǝo, ko mǝ nǝ tsǝa ɓǝà gbàllio a nggun-gangndǝi?>>
\p 
\v 11 Yesu eari wi ama, \wj <<A pà nǝ kum rǝcandǝa a muram ɗàng, yi mǝnana ɓǝ̀ Ɓakuli pamo raka. Ace mǝno ka, ɓwa mǝnana tasǝam aɓa buo ka, cauɓikea male gulo kútì mò.>>\wj*
\v 12 Lang Bilatus ok mǝnia yì cau ka, pǝlǝa ɓariki nǝ̀ alta njargula mǝnana nǝ̀ pusǝna Yesu nǝi ka. Sǝ aɓwana-mǝgule mala amǝ Yahudi ka, à loasǝ già bàng-bàng ama, <<Ɓǝ̀ a panzǝ ɓwa mǝnia sǝ au ka, lǝmdǝ ama a nda gyajam mala Kaisar, Mǝtala nzali ɗang! Acemǝnana ɓwa mana kat twal ɓamúrì ama yì ka, murǝm na ka, ɓwe ka mǝ'mgbicau na arǝ Mǝtala nzali!>>
\p 
\v 13 Lang Bilatus nǝ̀ ok cau mǝno ka, pǝlǝa pusǝ Yesu a banfana sǝ eauwe do amur buno ɓashi mǝnana à kǝ tunǝi ama, <<Ban múr tali>> ka. (Nǝ kun Ibǝru ka à kǝ tunǝi ama, <<Gabbata.>>)
\v 14 Anggo ka pwarizǝkya gbàshìnà a pwari gilǝrǝu ace Lamsan Yàlîmurû. Pǝlǝa Bilatus banggi amǝ Yahudi ama, <<Wu sǝni, murǝm ma'wun ndya ka!>>
\p 
\v 15 Kara yia kat à lo arǝì gǝu ama, <<Wali ɓǝ̀ wu! Wali ɓǝ̀ wu! Gbàllì a nggun-gangndǝi!>>
\p Bilatus ɗia ama, <<Mana! Wu earce ɓǝ̀n gballì murǝm ma'wun a nggun le?>>
\p Pǝlǝa agbani pǝris malea ear ama, <<Kǝ murǝm pa a bu sǝm ɗàng, she kǝ Kaisar, Mǝtala nzali mala amǝ Roma!>>
\v 16 Gandǝa Bilatus pea wia Yesu, ɓǝà kya gbàllì amur nggun-gangndǝi ka.
\p Sǝ à bwal Yesu à um nǝi.
\s1 À gbàllì Yesu amur nggun-gangndǝi
\r (Matiu 27:32-44; Markus 15:21-32; Luka 23:26-43)
\p 
\v 17 À tsǝki wi nggun-gangndǝi mǝnana à nǝ̀ ká gbàllì amurí ka, a meali, sǝ pur aban ká a ban mǝnana à kǝ tunǝi ama <<Ban kpouloɓamuru>> ka. Nǝ kun Ibǝru ka, à tunǝ banì ama, <<Golgota.>>
\v 18 Àkǝ̀ banì sǝ à gbàllì Yesu amur nggun-gangndǝi. À gbàllì aɓea aɓwana ɓari gbal andǝ Yesu, mwashat atà buì mǝlì sǝ ɓè ka atà buì mǝ'nggare, sǝ Yesu ka nda aɓa ɓalǝu.
\p 
\v 19 Bilatus gilǝgir arǝ gbǝlang kpamgbang sǝ tsǝa à gbàllì arǝ nggun-gangndǝi amur Yesu. Cau mǝnana gilǝ ka nda, <<Yesu Ɓwa Nazarat, Murǝm Mala Amǝ Yahudi.>>
\v 20 Ban mǝnana à gbàllì Yesu kàm ngga, sau nǝ là ɗàng, aɓwana pas ɓal mǝnia yì gìr à gilǝì ka, acemǝnana à gilǝì nǝ kún mala amǝ Ibǝru, andǝ kún mala amǝ Latin, andǝ kún mala amǝ Gǝrik.
\v 21 Sǝ agbani pǝris wari a ban Bilatus à kya banggi wi ama, <<Kǝa gilǝ ama, <Yì ka, nda Murǝm mala amǝ Yahudi> ɗàng. Ɓoaro male ka à nǝ̀ gilǝ ama, <Ɓwa mǝnia ka bang ama, yì nda Murǝm mala amǝ Yahudi.> >>
\p 
\v 22 Bilatus nyesǝia wia ama, <<Awo! Gìr mǝnana ǝn gilǝna ka dumǝna anggo.>>
\p 
\v 23 Anzǝm mǝnana asoje gbàllìnà Yesu amur nggun-gangndǝi ka, à pwan agir-nggūrǝì à gauwia banì ine, sǝ koya soje ka twal banì mwashat. Sǝ nggea-daura male mǝnana à tè nǝ nggubyau mwashat, kunkpakǝri pa arǝì raka, à twali gbal.
\v 24 Pǝlǝa à nea rǝia ama, <<Ɓǝ̀ sǝm ngga na ama sǝm nǝ̀ sàngi daura man ɗang, a kun mani ka, ɓǝ̀ sǝm kocàca amurí, ɓwa mǝnana lì ka ɓǝ̀ twali.>> Mǝnia yì gìr ka yi pa anggo ace mǝnana ɓǝ̀ lùmsǝ cau mala Ɓakuli mǝnana bang ama,
\q1 <<À gakkia rǝia adaura mem
\q2 sǝ à kocàca ace
\q1 nggea-daura mem.>>\f + \fr 19:24 \ft Ɓalli gbal aɓa: \xt Ang 22:18\xt*\ft .\f*
\m Mǝnia ka nda gìr mǝnana asoje pê ka.
\p 
\v 25 Nggea Yesu, andǝ mǝ'eam ngge mǝɓwame, andǝ Maryamu mālá Kilobas, andǝ Maryamu Ɓwa Magdala ka, à ndaban came tù a ban nggun-gangndǝi mǝnana à gbàllì Yesu amurí ka.
\v 26 Yesu sǝn nggè andǝ ɓe lagga male mǝnana earkiyi ace raka aban came a banì; pǝlǝa banggi nggè ama, \wj <<Nnâ, munio ndya ka.>>\wj*
\p 
\v 27 Sǝ ne mǝnia yì lagga male ka ama, \wj <<We ka, nggo ndya ka.>>\wj* Twal a pwari mǝno ka, mǝnia yì lagga mala Yesu ka, um nǝ nggea Yesu a ɓala male.
\s1 Lú mala Yesu
\r (Matiu 27:45-56; Markus 15:33-41; Luka 23:44-49)
\p 
\v 28 Yesu sǝlǝna ama ado ka agir mǝnana kat Ɓakuli túrí ɓǝ̀ yi pea ka, malǝna pea, sǝ ace mǝnana ɓǝ̀ cau mala Malǝmce mala Ɓakuli ɓǝ̀ lùmsǝ ka, bang ama, \wj <<Ən nggǝ ok mǝsamur.>>\wj*
\p 
\v 29 Kwar ndakam a banì, mǝnana lùmsǝ nǝ mùr-ɓǝlanggun anap mǝhangŋe ka, pǝlǝa asoje par soso aɓalǝi, sǝ à loasǝi a kun gara, à tsǝki wi a kúni ɓǝ̀ nu.
\v 30 Lang Yesu sonzǝ mur anap nì ka, na ama, \wj <<Malǝna!>>\wj*
\p Pǝlǝa dili múrí sǝ pa yilǝmi.
\s1 À zuɓi Yesu nǝ kaɗa a mǝsǝnkanggari
\p 
\v 31 Pwari mǝno ka pwari gilǝrǝu na, acemǝnana ɓǝ̀ ban fana ka, pwari Sabbat na. Sǝ aɓwana-mǝgule mala amǝ Yahudi ka, à pà nǝ̀ earce ɓǝ̀ alú ueo akanó aban gyare amur anggun-gangndi, ɓǝà bwal ɓè pwari mǝno kǝ yiu ka ɗàng. Ace mani ka à banggi Bilatus ama, ɓǝ̀ earia wia ɓǝà ɓungi akusǝ aɓwana mǝnana à gbàllia amur anggun-gangndi ka. À earce pe anggo ace mǝnana ɓǝà wu tù à nǝ̀ sulǝ aluia a nzali. À zǝmba anggo acemǝnana mǝnia yì pwari Sabbat ka, pwari mǝfele na a ban amǝ Yahudi, sǝ ɗǝm ngga pwari mǝgule na, acemǝnana yi karǝ nǝ Pwari Lamsan ngga.
\v 32 Asoje pǝlǝa à wario à kya ɓungi akusǝ aɓwana mǝnana à gbàllia a bu mǝlì andǝ bu mǝ'nggare mala Yesu ka.
\v 33 Lang à yiu a ban Yesu ka, à sǝni ka Yesu angŋa dǝmba wuna, sǝ à ɗeki, à ɓungi akusǝi ɗàng.
\v 34 Sǝa ma, mwashat aɓalǝ amǝnia yì asoje ka, zuɓi Yesu a nkanggari nǝ kaɗa, kara nkila andǝ mùr puro aban sukkio.
\v 35 Ɓwa mǝnana sǝn mǝnia yì gìr ka, nda bang ce ka, sǝ cau mǝnana na ka mǝsǝcau na, ace mǝnana wun gbal ka ɓǝ̀ wu ak cê, sǝ ɓǝ̀ wu pa ɓamur wun.
\v 36 Mǝnia yì gìr ka pa anggo ace mǝnana ɓǝ̀ lùmsǝ cau mala Ɓakuli mǝnana à gilǝì aɓa Malǝmce ama, <<À pà nǝ̀ ɓun mu kǝ bare ɗàng.>>\f + \fr 19:36 \ft Ɓalli gbal aɓa: \xt Pur 12:46; Ɓal 9:12; Ang 34:20\xt*\ft .\f*
\v 37 Sǝ ɓè ban ɗǝm aɓa Malǝmce mala Ɓakuli bang ama, <<Aɓwana nǝ̀ sǝn ɓwa mǝnana à zuɓi nǝ kaɗa ka.>>\f + \fr 19:37 \ft Ɓalli gbal aɓa: \xt Zak 12:10; Sǝn 1:7\xt*\ft .\f*
\s1 À tsǝk Yesu a ɓembe
\r (Matiu 27:57-61; Markus 15:42-47; Luka 23:50-56)
\p 
\v 38 Nǝ nzǝ́mò ka, Yisǝfu, ɓwa Arimatiya zǝmbi Bilatus ama, nǝ̀ twal lú Yesu. (Yì Yisǝfu ka mǝkpata Yesu na aɓa sǝmbǝrǝa, acemǝnana kǝ ɓanggi aɓwana-mǝgule mala amǝ Yahudi.) Bilatus pǝlǝa earî wi ɓǝ̀ twali. Nda sǝ Yisǝfu wario kya twal lú Yesu um nǝi ka.
\v 39 \f + \fr 19:39 \ft Ɓalli gbal aɓa: \xt Yoh 3:1,2\xt*\ft .\f* Nikodimus, ɓwabura mǝnana ɗiɗyal yiu a ban Yesu nǝ du ka, wari atà Yisǝfu. Yinǝ mùrú mǝ'rǝmɓoarne, a buì, ace hasǝi lú. Mùruî ka à pè nǝ myang nggun mǝr mana à zurǝì andǝ muku nggun-alus ka. Dǝmbǝrya male na tyang lumi-tàrú.
\v 40 Aburana mǝnia yia kǝm ngga à twal lú Yesu sǝ à marǝki aɓa nggurbyau pwasǝa andǝ mùrú mǝ'rǝmɓoarne, kǝla mǝnana amǝ Yahudi kǝ pang nǝ lú sǝ à nǝ̀ tsǝì ka.
\v 41 A ban mǝnana à gbàllì Yesu kàm ngga, ɓe ɓaban nda kam nǝ ɓembe aɓalǝi, mǝnana à kwarí aɓa sorotali ka, bǝshe na, à malaká tsǝk kǝɓwa kàm ɗàng.
\v 42 Sǝ acemǝnana pwari mǝno ka pwari gilǝrǝu na ace Sabbat andǝ Lamsan Yàlîmurû mala amǝ Yahudi ka, sǝ acemǝnana gbal mǝno yì ɓembe ka nda a bania tù ka, à tsǝk lú Yesu aɓalǝi.
\c 20
\s1 Lo mala Yesu a ɓembe nǝ yilǝmu
\r (Matiu 28:1-8; Markus 16:1-8; Luka 24:1-12)
\p 
\v 1 Anzǝm pwari Sabbat nǝ tadǝmbari ɗiɗyal, ban na mbul-mbul più, Maryamu Ɓwama Magdala wari a ɓembe, sǝ kya sǝni ka tali mǝnana à girna kun ɓembe nǝi ka, à gǝshini.
\v 2 Pǝlǝa nyar nǝ mire aban ká aban Shiman Bitǝrus andǝ ɓe lagga, mǝnana Yesu kǝ earce kǝ̀rkǝ́r ka, sǝ banggia wia ama, <<À pusǝna Mǝtala sǝm Yesu a ɓembe, sǝ sǝm súrǝ̀ ban mǝnana à wari nǝi kam ngga ɗang!>>
\p 
\v 3 Pǝlǝa Bitǝrus andǝ mǝno yì ɓe lagga ka, à puro à dǝshi ɓembe.
\v 4 Yia kǝm ngga à nda aban ká nǝ mire, sǝ mǝno yì ɓe lagga ka ɓangŋa aki Bitǝrus dǝmba yi bik ban ɓembe.
\v 5 Pǝlǝa dili muri a kun ɓembe, sǝn anggubyau-múr lú aɓa ɓembe sǝ kútí ɗang.
\v 6 Lang Shiman Bitǝrus yiu nǝnzǝ́mò ka, kara kútí nǝ kútiô aɓa ɓembe. Yì gbal ka kǝ anggubyau-múr lú nda sǝn ngga,
\v 7 sǝ nggurbyau mǝnana à marǝkina ɓamur Yesu nǝi ka, pà aban acili anggurbyau mǝnana à tsǝ̀ngŋǝ̀nàban Yesu nǝia ka ɗàng; male ka à kàrrì à nongsǝi ɗàng.
\v 8 Sǝ lagga mǝnana akdǝmba ɓangŋa yiu a kún ɓembe ka, kútí gbal aɓa ɓembe; sǝn agir nì kat, sǝ ear ama mǝsǝcau na, Yesu longŋǝni ɓembe.
\v 9 Kaniama gìr mǝnia ka nǝ̀ yia kumban ngga, yìa ka, à bwalta cau mala Malǝmce mala Ɓakuli mǝnana bang ama, Yesu nǝ̀ loapi ɓembe nǝ yilǝmu ka ɗàng.
\v 10 Pǝlǝa alaggana mǝno nyare à o a la.
\p 
\v 11 Sǝ Maryamu ka came a nza a kún ɓembe aban ɓuá. Nǝ́ ɓuá a kúni, sǝ dìlì múrí nǝ̀ sǝn ɓá ɓembe.
\v 12 Kara sǝn amǝturonjar mala Ɓakuli ɓari nǝ agir-pwasǝa arǝia, aban do, aban mǝnana à nongsǝ lú Yesu kàm ɗiɗyal ka. Mwashat ka do nǝ ban ɓamúrí, sǝ ɓè mǝnia mwashat ka nda a bu ban akusǝi.
\v 13 Sǝ à ɗì Maryamu ama, <<Ɓwama, mana pur arǝò sǝ a kǝ ɓua le?>>
\p Pǝlǝa Maryamu earia wia ama, <<Aɓwana twalna Mǝtalem à umna nǝi, sǝ ǝn súrǝ̀ ban mǝnana à tsǝì kàm ngga ɗàng!>>
\p 
\v 14 Sǝ pǝlǝ rǝì, nǝ̀ u ka, kara sǝn Yesu aban came a baní, sǝ sǝlǝ ama Yesu na ɗang.
\v 15 Pǝlǝa Yesu ɗì ama, \wj <<Ɓwama, mana pur arǝò sǝ a kǝ ɓua? Yana ɗe a alkite?>>\wj*
\p Maryamu kǝ sǝni kǝla yì ka, mǝtala ɓaban na, pǝlǝa ne wi ama, <<Ɓwamǝgule, ɓǝ̀ a nda a twali ka, banggàm ban mǝnana a tsǝì kàm ngga, ace mǝnana ɓǝ̀n kyane ɓǝ̀n kya twali ka.>>
\p 
\v 16 Pǝlǝa Yesu tunǝi nǝ lùllǝì ama, \wj <<Maryamu!>>\wj*
\p Pǝlǝa pǝlǝ rǝì a baní sǝ na ama, <<Rabbonai!>> (Mǝnia nǝ kun Ibǝru ka nda <<Malǝm.>>)
\p 
\v 17 Yesu ne wi ama, \wj <<Ce a kúr a rǝàm ɗàng, acemǝnana ǝn malaká nyare aban Tárrám a kùli peatu ɗàng. Ado ka, kyane aban amǝ'eambǝam, alaggana mem, kya banggia wia ama, Mǝ ndo mǝ nǝ nyare aban Tárrám, mǝnana nda Tárrià ka, aban Ɓakuli mem, mǝnana nda Ɓakuli malea ka.>>\wj*
\p 
\v 18 Anggo sǝ Maryamu Ɓwama Magdala wario kya kum alaggana mala Yesu sǝ banggia wia ama, <<Ən sǝnǝna Mǝtalabangŋo Yesu!>> Pǝlǝa banggia wia cau mǝnana Yesu banggi wi ka.
\s1 Yesu pusǝrǝi aban alaggana male
\r (Matiu 28:16-20; Markus 16:14-18; Luka 24:36-49)
\p 
\v 19 Nǝ pwarikpǝra a mǝno yì pwari a nzǝm pwari Sabbat ka, alaggana mala Yesu nda atārǝia aɓa kurǝm. À girki akunkurǝm acemǝnana à kǝ ɓanggi aɓwana-mǝgule mala amǝ Yahudi. Ɓalǝia ama nǝ̀ kasǝ ka, kara à sǝn Yesu purna, camǝna aɓalǝia, sǝ nea wia ama, \wj <<Ɓǝ̀ rǝ wun pwalo.>>\wj*
\v 20 Lang bangŋǝna anggo ka, pǝlǝa lǝmdǝia wia anpenye mǝnana arǝ abui andǝ nkanggari ka. Alaggane lùmsǝ nǝ banɓoarnado acemǝnana à sǝnǝna Mǝtalabangŋo ka.
\p 
\v 21 Yesu banggia wia ɗǝm ama, \wj <<Ɓǝ̀ rǝ wun pwalo. Kǝla mǝnana Tárrám túrǎm ngga, anggo gbal sǝ ǝn nggǝ túr wun.>>\wj*
\v 22 Pǝlǝa pyaupia wia lin'ueo amúrià sǝ na ama, \wj <<Wu ak Bangŋo Mǝfele.\wj*
\v 23 \wj Ɓǝ̀ wu twali aɓwana ban acauɓikea malea ka, à twalǝnia wia banì. Sǝ ɓǝ̀ wu twalia wia banì raka, yia ka à twalia wia banì gbal ɗàng.>>\wj*
\s1 Yesu lǝmdǝ ɓamúrì aban Toma
\p 
\v 24 Toma, mwashat aɓalǝ alaggana lum-nong-ɓari, mǝnana à kǝ tunǝi ama Pasa ka, pa aɓalǝia, a pwari mǝno Yesu yiu abania ka ɗang.
\v 25 Pǝlǝa aɓi alaggana banggi wi ama, <<Sǝm sǝnǝna Mǝtalabangŋo!>>
\p Sǝ Toma banggia wia ama, <<Mim ngga pà mǝ nǝ earnǝ mǝno ka ɗàng, she ɓǝn sǝnǝna akun anpenye mala akūsà mǝnana arǝ abui, sǝ ǝn jena kun anpenye nǝ munabuam, sǝ ǝn tsǝ́ngŋǝ̀nà buam arǝ penye mǝnana a nkanggari ka.>>
\p 
\v 26 Anzǝm nongŋo tongno-nong-tàrú ka, alaggana nda ɗǝm atārǝia a ɓala andǝ Toma, sǝ akunakurǝm ngga à girkinia kat; kara Yesu yi cam ɗǝm aɓalǝia sǝ bang ama, \wj <<Ɓǝ̀ rǝ wun pwalo.>>\wj*
\v 27 Pǝlǝa lǝmdǝì Toma abui sǝ ne wi ama, \wj <<Sǝn abuam; sǝ wu tsǝk muna-buo kani; sárǝ́ buo tsǝì arǝ penye mana a mǝsǝ nkanggariam ngga. Ɗeki ɓabum tuti mo, earnǝ cau!>>\wj*
\p 
\v 28 Toma pǝlǝa eari Yesu ama, <<Mǝtalem andǝ Ɓakuli mem!>>
\p 
\v 29 Yesu pǝlǝa ne wi ama, \wj <<Nda acemǝnana a sǝnǝnam ngga, sǝ a nǝ earnǝ mim le? Aɓwana mǝnana à sǝnam raka, sǝ à ak cau mem nǝ ɓabumia kat ka, à ndanǝ tsǝkbu mala Ɓakuli!>>\wj*
\s1 Gir mǝnana tsǝa sǝ à gilǝ // mǝnia yì malǝmce ka
\p 
\v 30 Yesu pakki aɓea agir-ndǝlǝki pas a mǝsǝ alaggana male, mǝnana à gilǝia aɓa malǝmce mǝnia raka.
\v 31 Sǝ amǝnia à gilǝia ka, nda ace mǝnana ɓǝ̀ wu earnǝi ama Yesu nda Kǝrǝsti, Mǝ'amsǝban, Muna mala Ɓakuli; sǝ aɓa paɓamuru ma'wun a baní ka, wu nǝ̀ kum yilǝmu aɓa rǝcandǝa mala lùllǝì.
\c 21
\s1 Yesu pusǝrǝi aban alaggana // male a Galili
\p 
\v 1 Nǝ nzǝ́mò ka, Yesu nyar ɗǝm pusǝrǝi a ban alaggana male a kun Garang Tiberiya. Ani sǝ gir nî pa.
\v 2 Shiman Bitǝrus, sǝ Toma mǝnana à tunǝki ama Pasa ka, andǝ Nataniyel ɓwa Kana mala Galili, andǝ amuna-burana mala Zabadi, andǝ aɓea alaggana mala Yesu ɓari, à nda atārǝia kat.
\v 3 Pǝlǝa Shiman Bitǝrus banggi aɓi ama, <<Mim ngga mǝ ndo mǝ nǝ o a taula.>>
\p Sǝ aɓi banggi wi gbal ama, <<Sǝm nǝ̀ ká atò.>> Pǝlǝa yia kat à eauwe a waru malea aban ká taula. Sǝ a bu du mǝno ka à bwal kǝgìr ɗang.
\p 
\v 4 Ban kwarǝna, pwari nǝ̀ nggǝ eau ka, Yesu yiu yi came a kun mur sǝ yia alaggana ka à sǝlǝ ama Yesu na ɗang.
\v 5 Pǝlǝa tunǝban ɗia ama, \wj <<Wun alaggana, wu bwal kǝ nji le?>>\wj*
\p À ear ama, <<Awo!>>
\p 
\v 6 Pǝlǝa Yesu banggia wia ama, \wj <<Wu túr ndámbú ma'wun atà bu mǝlì mala waru, wu nǝ̀ bwal nji!>>\wj* Pǝlǝa à túr ndámbú a mùr sǝ à bwal nji kǝ̀rkǝ́r, yàle à gandǝ nun ndámbú, à eamsǝi aɓa waru ɗang, acemǝnana anji làkkì pas aɓa ndámbú.
\p 
\v 7 Sǝ lagga mǝnana Yesu earkiyi ace raka ne Bitǝrus ama, <<Mǝtalabangŋo na!>> Lang Shiman Bitǝrus oè ama Mǝtalabangŋo na ka, kara twal daura male mǝnana swárí sǝ kútí a túró ka, oasǝi arǝì, tǎ zurro a mùr sǝ oakio aban ká a kún mùr.
\v 8 Acili alaggana ueo aɓa waru aban nungi ndámbú mǝnana lùmsǝ nǝ nji ka, aban ká a nza. Ban mǝnana waru nda kam aɓa mùr ka sau nǝ nza ɗàng; sauwa male nda kǝla kusǝu gbǝman-tàrú.
\p 
\v 9 Lang à nǝ̀ yia eau a nza ka, à sǝn nkalang bǝsa aban earke nǝ anji-twana amurí andǝ bǝredi a banì.
\v 10 Yesu banggia wia ama, <<Wu yiu nǝ aɓea anji aɓalǝ amǝnana wu bwal adyan ngga.>>
\p 
\v 11 Pǝlǝa Shiman Bitǝrus eauwe aɓa waru sǝ kya nun ndámbú eamsǝi a kún nza. Ndámbú lùmsǝ nǝ anji mǝgulke gbǝman-nǝ-lumi-tongno nǝ mǝsǝì tàrú (153), sǝ kat andǝ làkkì mala anji mǝno ka, ko bǝti ndámbú san ɗàng.
\v 12 Yesu pǝlǝa tunǝia ama, \wj <<Wu yiu wu lìli!>>\wj* Sǝ kǝɓwa pà kàm atà alaggana male, mǝnana gandǝ ɗî ama, a nda yana le ka ɗàng, acemǝnana yia kat ka, à sǝlǝna ama Mǝtalabangŋo na.
\v 13 Pǝlǝa Yesu twal bǝredi pea wia, anggo gbal sǝ pang nǝ anji.
\p 
\v 14 Mǝnia ka nda tàruià pusǝrǝu mala Yesu a ban alaggana male anzǝm loapi ɓembe male.
\s1 Yesu andǝ Bitǝrus
\p 
\v 15 Anzǝm mǝnana à lina girlina ka, Yesu pǝlǝa ɗì Shiman Bitǝrus ama, \wj <<Shiman muna mala Yohana, a earcem kútì amǝnia ka le?>>\wj*\f + \fr 21:15 \fq a earcem kútì amǝnia ka le: \ft Ko <<a earcem amur agir mǝnia ka le?>>\f*
\p Bitǝrus eare ama, \wj <<E, Mǝtalabangŋo, a sǝlǝna ama ǝn nggǝ earceo.>>\wj*
\p Yesu banggi wi ama, \wj <<Ɗenyi nǝ amuna-nzur mem.>>\wj*
\p 
\v 16 Yesu ɗì ɗǝm ama, \wj <<Shiman muna mala Yohana, a earcem le?>>\wj*
\p Shiman ama, <<E, Mǝtalabangŋo, a sǝlǝna ama ǝn nggǝ earceo.>>
\p Yesu ne wi ama, \wj <<Tsǝkir anzur mem.>>\wj*
\v 17 Yesu nyare ɗì Shiman Bitǝrus tàruià ɗiban ɗǝm ama, \wj <<Shiman muna mala Yohana, a kǝ earcem le?>>\wj*
\p Bum Bitǝrus kìɗìkì nǝ mǝnia yì tàruià ɗiban ngga. Nda sǝ ne Yesu ama, <<Mǝtalabangŋo, a súrǝ̀ agir kat. A sǝlǝna ama mim ngga ǝn nggǝ earceo!>>
\p Pǝlǝa Yesu banggi wi ama, \wj <<Tsǝkir anzur mem.\wj*
\v 18 \wj Mǝ nda ban banggo mǝsǝcau: mǝnana a kǝ long-nǝ-lo ka, a kǝ gandǝ oasǝ agir a rǝo sǝ a kǝ wari a ban mǝnana kat a earce a nǝ ká kàm ngga. Sǝ ɓǝ̀ a enà ka, a nǝ sárǝ́ abuo, sǝ aɓea ɓwana ɗàng nda à nǝ̀ oasǝo agir a rǝò, sǝ à nǝ̀ ká nǝ we, a ban mǝnana a earce ká kàm raka.>>\wj*
\p 
\v 19 Yesu na anggo ace mǝnana ɓǝ̀ lǝmdǝ ulang njar mǝnana Bitǝrus nǝ̀ wù nǝi ka, mǝnana nǝ̀ gusǝlǝ lullǝ Ɓakuli ka. Pǝlǝa Yesu ne wi ama, \wj <<Yiu atàm.>>\wj*
\s1 Yesu andǝ lagga mana // earkiyi ce ka
\p 
\v 20 Bitǝrus pǝlǝ rǝì sǝ sǝn lagga mǝnana Yesu earkiyi ace raka a nzǝmia, aban yiu ateà. Yì nda kǝ lagga mǝnana eangnǝ arǝ Yesu a masǝlǝata ligirlina malea, sǝ ɗìkiyi Yesu ama, <<Mǝtalabangŋo, yana ɓwe na nǝ̀ meo ka?>>
\v 21 Lang Bitǝrus nǝ̀ sǝni ka, pǝlǝa ɗì Yesu ama, <<Mǝtalabangŋo, sǝ lagga man ngga, mana nǝ̀ kumi?>>
\p 
\v 22 Yesu eari wi ama, \wj <<Ɓǝ̀ ǝn eare nǝma yì ka, ɓǝ̀ do nǝ yilǝmu bà nyare mem ngga, mana oasǝo aɓalǝi? We ka, kpatam!>>\wj*
\p 
\v 23 Kara cau akban aɓalǝ acili amǝkpata Yesu ama mǝnia yì lagga ka, pà nǝ̀ wu ɗàng. Sǝ anggo sǝ Yesu na ɗang. Yesu ka bang nǝ bang ama, <<Ɓǝ̀ ǝn eare nǝma yì ka, ɓǝ̀ do nǝ yilǝmu bà nyare mem ngga, mana oasǝo?>>
\p 
\v 24 Mǝnia yì lagga ka nda mǝnana bang cau amur agir mǝnia, sǝ gilǝia aɓa Malǝmce ka. Sǝ sǝm sǝlǝna ama cau mǝnana na ka, mǝsǝcau na.
\s1 Masǝlǝata cau
\p 
\v 25 Aɓea agir ndakam pas mǝnana Yesu pea ka, yàle ɓǝà na ama, à nǝ̀ kpatea mwashat-mwashat à nǝ̀ gilǝia kat ka, ǝn nggǝ sǝni nǝma ɓanza kat ka, pà nǝ̀ gandǝ bwal amalǝmce mǝnana à nǝ̀ gilǝia ka ɗàng.
