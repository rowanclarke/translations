\p \w I|strong="H7200"\w* replied, “\add I see some\add* \w figs|strong="H8384"\w*. Some \w are|strong="H4100"\w* \w very|strong="H3966"\w* \w good|strong="H2896"\w* \w ones|strong="H8384"\w*, \w but|strong="H3808"\w* some \w are|strong="H4100"\w* \w very|strong="H3966"\w* \w bad|strong="H7451"\w*, \w with|strong="H3068"\w* \w the|strong="H7200"\w* result \w that|strong="H7200"\w* \w no|strong="H3808"\w* \w one|strong="H3808"\w* \w would|strong="H3068"\w* eat \w them|strong="H7200"\w*.”   
\p
\v 4 \w Then|strong="H1961"\w* \w Yahweh|strong="H3068"\w* \w gave|strong="H1961"\w* \w me|strong="H1697"\w* \w this|strong="H1697"\w* \w message|strong="H1697"\w*:  
\v 5 “\w This|strong="H2088"\w* \w is|strong="H3068"\w* \w what|strong="H2896"\w* \add I\add*, \w Yahweh|strong="H3068"\w*, \w the|strong="H3541"\w* \w God|strong="H3068"\w* whom \w the|strong="H3541"\w* Israeli people \add say that they worship\add*, \w say|strong="H3478"\w*: ‘\w The|strong="H3541"\w* \w good|strong="H2896"\w* \w figs|strong="H8384"\w* represent [SIM] \w the|strong="H3541"\w* people \w of|strong="H3068"\w* \w Judah|strong="H3063"\w* whom \w I|strong="H3541"\w* exiled \w to|strong="H3478"\w* \w Babylonia|strong="H3778"\w*.  
