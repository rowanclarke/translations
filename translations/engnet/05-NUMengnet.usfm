\v 15  \w But|strong="H3588"\w* \w if|strong="H3588"\w* \w he|strong="H3588"\w* \w should|strong="H3588"\w* nullify \w them|strong="H5921"\w* \w after|strong="H5921"\w* \w he|strong="H3588"\w* \w has|strong="H3117"\w* \w heard|strong="H8085"\w* \w them|strong="H5921"\w*, \w then|strong="H6965"\w* \w he|strong="H3588"\w* \w will|strong="H3117"\w* bear \w her|strong="H3605"\w* iniquity.”   
\p
\v 16  \w These|strong="H8085"\w* \w are|strong="H5771"\w* \w the|strong="H8085"\w* statutes \w that|strong="H8085"\w* \w the|strong="H8085"\w* \nd Lord\nd* commanded Moses, relating \w to|strong="H8085"\w* \w a|strong="H3068"\w* \w man|strong="H5375"\w* \w and|strong="H8085"\w* \w his|strong="H5375"\w* wife, \w and|strong="H8085"\w* \w a|strong="H3068"\w* father \w and|strong="H8085"\w* \w his|strong="H5375"\w* young daughter who \w is|strong="H5771"\w* still living \w in|strong="H8085"\w* \w her|strong="H5375"\w* father’s house.   
\c 31  
\p
\v 1  \w The|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w spoke|strong="H1696"\w* \w to|strong="H1696"\w* \w Moses|strong="H4872"\w*:  
\v 2 “\w Exact|strong="H5358"\w* \w vengeance|strong="H5360"\w* \w for|strong="H1121"\w* \w the|strong="H1121"\w* \w Israelites|strong="H3478"\w* \w on|strong="H5360"\w* \w the|strong="H1121"\w* \w Midianites|strong="H4084"\w* – after \w that|strong="H5971"\w* \w you|strong="H5971"\w* \w will|strong="H5971"\w* \w be|strong="H1121"\w* \w gathered|strong="H3478"\w* \w to|strong="H3478"\w* \w your|strong="H3478"\w* \w people|strong="H5971"\w*.”   
\p
\v 3  \w So|strong="H1961"\w* \w Moses|strong="H4872"\w* \w spoke|strong="H1696"\w* \w to|strong="H1696"\w* \w the|strong="H5921"\w* \w people|strong="H5971"\w*: “\w Arm|strong="H2502"\w* \w men|strong="H5971"\w* \w from|strong="H5921"\w* \w among|strong="H5921"\w* \w you|strong="H5414"\w* \w for|strong="H5921"\w* \w the|strong="H5921"\w* \w war|strong="H6635"\w*, \w to|strong="H1696"\w* attack \w the|strong="H5921"\w* \w Midianites|strong="H4080"\w* \w and|strong="H4872"\w* \w to|strong="H1696"\w* \w execute|strong="H5414"\w* \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd*’s \w vengeance|strong="H5360"\w* \w on|strong="H5921"\w* \w Midian|strong="H4080"\w*.  
