\mt1 NIWAKATE HEBREUTEDI 
\ip AÉĄĖķica ane yowooÉĄĖķodi ane lidie naÉĄĖķadi niwakate hebreutedi, idoka oyowooÉĄĖķodi me judeu niÉĄĖķica ane idÃ­. Oditibige me Paulo, oÉĄĖķoa domige Apolo ane idÃ­. MoidÃ­ odidikotibige judeutedi anonakato ĮĪoniotagodi me doÉĄĖķoika monakato ĮĪoniotagodi Jesus, oditaÉĄĖķa opitacelogo lakataÉĄĖķa laamipi. YeloÉĄĖķoditiogi hebreutedi Jesus me niÉĄĖķijaaÉĄĖķijoa NiÉĄĖķicoa ane niiÉĄĖķe AneotedoÉĄĖķoji me ĮĪonewikatitoÉĄĖķodi, codaa yeloÉĄĖķodi niÉĄĖķina oko me daÉĄĖķadiaa yakadi me iÉĄĖķenaÉĄĖķatibigiwaji lodoe AneotedoÉĄĖķoji daÉĄĖķa leeÉĄĖķodi moyotete liiÉĄĖķenatakaneÉĄĖķeco AneotedoÉĄĖķoji ane iditedini MoisÃĐs, codaa niÉĄĖķina modioteci lakataÉĄĖķa judeutedi ane daÉĄĖķadiaaÉĄĖķica ane jaoÉĄĖķate. MoidÃ­ oyalaÉĄĖķata niÉĄĖķijo jotigide lakatigi judeutedi sacerdotitedi maleeÉĄĖķonigodi eijedi anoibootalo AneotedoÉĄĖķoji mowotibige AneotedoÉĄĖķoji me daÉĄĖķalee iloikatidi oko leeÉĄĖķodi libeyaceÉĄĖķeco. Eledi yalaÉĄĖķata Jesus me ÉĄĖķonisacerdoti ÉĄĖķoneÉĄĖķegi, codaa me nadooÉĄĖķodi lawodi meotedibige AneotedoÉĄĖķoji me dibatacedoÉĄĖķogi. Lawodi Jesus ÉĄĖķodiwilegitema inoatawece ane ÉĄĖķobeyaceÉĄĖķeco. Ikee niÉĄĖķida gela anejinaÉĄĖķa me idinilakidenaÉĄĖķatege AneotedoÉĄĖķoji me daÉĄĖķaxa mele, aliciagi niÉĄĖķijo oxiiÉĄĖķodi domaÉĄĖķa ÉĄĖķonimaweneÉĄĖķegi me idinilakidenaÉĄĖķatege AneotedoÉĄĖķoji. YalaÉĄĖķatiogi niÉĄĖķijo laamipi judeutedi AneotedoÉĄĖķoji ane yakadi me iÉĄĖķenaÉĄĖķatibigiwaji leeÉĄĖķodi monakato, idaaÉĄĖķida me nawikodeeÉĄĖķa. 
\ip NiÉĄĖķidiaaÉĄĖķidi eo loniciwaÉĄĖķa niÉĄĖķina anonakato ĮĪoniotagodi moyowo anodaaÉĄĖķeeteda Jesus me dinatiteta ijoatawece lawikodico, odaa leeditibige midaÉĄĖķaÉĄĖķaee modinatitalo lawikodico leeÉĄĖķodi modiotece Cristo. Codaa maÉĄĖķaÉĄĖķa onalaÉĄĖķatibige niÉĄĖķica noÉĄĖķeedi anicota me yajigotediogi AneotedoÉĄĖķoji, niÉĄĖķica ane daÉĄĖķa daa. NoÉĄĖķowidijedi lotaÉĄĖķa jeÉĄĖķeote ladeenaÉĄĖķaneÉĄĖķeco. 
\c 1  
\s1 AneotedoÉĄĖķoji ibake Lionigi me dinikeetedoÉĄĖķowa 
\p  
\v 1 NiÉĄĖķijo jotigide AneotedoÉĄĖķoji eliodi me notaÉĄĖķaneÉĄĖķetedi ÉĄĖķodoiigi, codaa owidi anigotediogi me notaÉĄĖķaneÉĄĖķetediniwace jotigide ÉĄĖķodaamipi. Imonyatediogi niÉĄĖķijo anoyeloÉĄĖķoditedibece AneotedoÉĄĖķoji lowooko moditece ane yemaa.  
\v 2 Pida natigide, niÉĄĖķinoa owidijedi nokododi, AneotedoÉĄĖķoji ibake Lionigi me yeloÉĄĖķodi niÉĄĖķica ane yemaa. AneotedoÉĄĖķoji ibake Lionigi meote inoatawece aninoa ditibigimedi, codaa aninoa digoina iiÉĄĖķo, odaa ja iolatedice Lionigi me yajigoteta inoatawece mepoka nepiliditeda.  
\v 3 Lionigi datale digo mijoataÉĄĖķa AneotedoÉĄĖķoji me datale, codaa liciagi AneotedoÉĄĖķoji. Ibake lotaÉĄĖķa loniciweÉĄĖķenaÉĄĖķa me doweditedeloco codaa me ika midioka limedi minoa inoatawece niÉĄĖķinoa ane jinataÉĄĖķa. NiÉĄĖķidiaaÉĄĖķidi neÉĄĖķeote nimaweneÉĄĖķegi me napitaÉĄĖķadi inoatawece ÉĄĖķobeyaceÉĄĖķeco, odaa ja nicotedini digoida ditibigimedi nimedi ÉĄĖķoneÉĄĖķegi liwai libaaÉĄĖķadi AneotedoÉĄĖķoji ane iiÉĄĖķe inoatawece. 
\p  
\v 4 Odaa jeÉĄĖķeote me daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi naÉĄĖķaxatedeloco aanjotedi, digo anee LiboonaÉĄĖķadi ane yajigote AneotedoÉĄĖķoji me daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi, aÉĄĖķica liciagi. AneotedoÉĄĖķoji yajigote LiboonaÉĄĖķadi me âLionigiâ. 
\s1 LotaÉĄĖķanaÉĄĖķaxi AneotedoÉĄĖķoji ikee Lionigi AneotedoÉĄĖķoji me daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi caticedi aanjotedi 
\p  
\v 5 Lionigi daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi, igaataÉĄĖķa AneotedoÉĄĖķoji aÉĄĖķica otiÉĄĖķidatece daÉĄĖķa eeteta okanicodaaÉĄĖķicata aanjo niÉĄĖķijoa lotaÉĄĖķa aneeteta Lionigi, niÉĄĖķijo meeteta, 
\q1 âAkamokakaamita makaami Ionigi, 
\q1 amina noko ja jaote me Ee ĮĪadiodi.â 
\m Eledi meeteta, 
\q1 âJeÉĄĖķee ĮĪadiodi, 
\q1 codaa akaami Ionigi.â 
\m  
\v 6 NiÉĄĖķina AneotedoÉĄĖķoji me nadeegite Lionigi ane daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi niÉĄĖķina iiÉĄĖķo, eledi mee, 
\q1 âAkaamitawecetiwaji anakaami niaanjotedi AneotedoÉĄĖķoji 
\q1 oÉĄĖķeetetalo Ionigi!â 
\m  
\v 7 NiÉĄĖķijo AneotedoÉĄĖķoji me yalaÉĄĖķate aanjotedi, mee, 
\q1 âJaote iniaanjotedi micataÉĄĖķa daÉĄĖķa niwocotadi, 
\q1 codaa niÉĄĖķidiwa iniaanjotedi ane iotaka dinoe 
\q1 micataÉĄĖķa daÉĄĖķa ÉĄĖķalewaÉĄĖķa.â 
\m  
\v 8 Pida niÉĄĖķina AneotedoÉĄĖķoji naÉĄĖķaÉĄĖķa yalaÉĄĖķate Lionigi, mee, 
\q1 âInoenoÉĄĖķodi, 
\q1 idioka limedi makaami ane diiÉĄĖķenataka. 
\q1 NiÉĄĖķina me iiÉĄĖķeni niÉĄĖķina oko, 
\q1 awii ÉĄĖķanimaweneÉĄĖķegi ane iÉĄĖķenaÉĄĖķa me iiÉĄĖķenatakani. 
\q1  
\v 9 Emaani niÉĄĖķina ane iÉĄĖķenaÉĄĖķa, 
\q1 codaa ÉĄĖķadeleÉĄĖķedi niÉĄĖķina ane beyagi. 
\q1 JoaniÉĄĖķidaa leeÉĄĖķodi Ee, 
\q1 ĮĪanoenoÉĄĖķodi AneotedoÉĄĖķoji, 
\q1 me ÉĄĖķadiolaatice, 
\q1 codaa me ÉĄĖķadiweniÉĄĖķideni caticedi niÉĄĖķijoa ÉĄĖķadokaaÉĄĖķetedipi, 
\q1 codaa jiÉĄĖķidaa me jao meliodi me aniniitibeci.â 
\p  
\v 10 AneotedoÉĄĖķoji eledi yalaÉĄĖķate Lionigi, niÉĄĖķijo neÉĄĖķee, 
\q1 âĮĪoniotagodi, 
\q1 niÉĄĖķijo jotigide aniÉĄĖķicatibige daÉĄĖķa jinataÉĄĖķa inoatawece aninoa, 
\q1 jaÉĄĖķakamaÉĄĖķakaami ane oeni iiÉĄĖķo, 
\q1 codaa abakeni ÉĄĖķabaaÉĄĖķatedi me oeni ditibigimedi. 
\q1  
\v 11 Odaa ditibigimedi inaa iiÉĄĖķo icota me ma, 
\q1 pida akaami biÉĄĖķidioka limedi makaami. 
\q1 Ditibigimedi inaa iiÉĄĖķo icota me laxokodi 
\q1 micataÉĄĖķa nowoodaÉĄĖķagi moxiiÉĄĖķodi. 
\q1  
\v 12 AteciÉĄĖķitiwage macataÉĄĖķa wetaÉĄĖķajo, 
\q1 codaa me iikoeÉĄĖķeni 
\q1 micataÉĄĖķa niÉĄĖķina me jiikoenaÉĄĖķa nowoodaÉĄĖķagi oxiiÉĄĖķodi. 
\q1 Pida akaami biÉĄĖķidioka limedi makaami, 
\q1 adiniigi aneni, 
\q1 codaa aÉĄĖķakaami oxiiÉĄĖķodi.â 
\m  
\v 13 AneotedoÉĄĖķoji aÉĄĖķica deÉĄĖķeeteta anigetiÉĄĖķijo aanjo ane ligegiteta Lionigi, niÉĄĖķijo mee, 
\q1 âAnicooti digoina iwai ibaaÉĄĖķadi 
\q1 nigepaaÉĄĖķicota me jiiÉĄĖķeke ÉĄĖķaneloÉĄĖķododipi.â 
\p  
\v 14 Inoatawece aanjotedi niwicidi anodibatema AneotedoÉĄĖķoji, ane iiÉĄĖķe moyaxawa niÉĄĖķina oko aneote me newiÉĄĖķatace. 
\c 2  
\s1 Leeditibige me jatacoloÉĄĖķojoÉĄĖķotece lotaÉĄĖķa AneotedoÉĄĖķoji 
\p  
\v 1 AneotedoÉĄĖķoji ibake Lionigi me ÉĄĖķodotaÉĄĖķaneÉĄĖķe, odaa leeditibige me jatacoloÉĄĖķojoÉĄĖķotece lotaÉĄĖķa anewi ane jajipaaÉĄĖķatalo, amanagawini aÉĄĖķejamaÉĄĖķajoÉĄĖķotice.  
\v 2 NiÉĄĖķijo nibodigi aanjotedi anodita MoisÃĐs ewi, codaa niÉĄĖķijo aneote AneotedoÉĄĖķoji iÉĄĖķenaÉĄĖķa niÉĄĖķina me iloikatidi niÉĄĖķijo oko leeÉĄĖķotedi ijoatawece ane beyagi anowote, niÉĄĖķijo midatibece me doÉĄĖķoyiwaÉĄĖķaditeda liiÉĄĖķenatakaneÉĄĖķeco AneotedoÉĄĖķoji.  
\v 3 Enice nige deÉĄĖķejiwaÉĄĖķataÉĄĖķateda lotaÉĄĖķa ÉĄĖķoneÉĄĖķaÉĄĖķa anonikeetoÉĄĖķowa anodaaÉĄĖķee AneotedoÉĄĖķoji meote ÉĄĖķodewiÉĄĖķa, odaa aÉĄĖķodiwoko niÉĄĖķina nige limedi me iloikatidi oko leeÉĄĖķodi libeyaceÉĄĖķeco. ĮĪoniotagodi Jesus jiÉĄĖķijaa odoejegi ane nikeetedoÉĄĖķowa anodaaÉĄĖķee AneotedoÉĄĖķoji meote ÉĄĖķodewiÉĄĖķa. Odaa niÉĄĖķidiaaÉĄĖķidi niÉĄĖķijo anowajipatalo joÉĄĖķonatematitedoÉĄĖķowa lotaÉĄĖķa.  
\v 4 AneotedoÉĄĖķoji ikee niÉĄĖķinoa lotaÉĄĖķa Lionigi mewi niÉĄĖķina meote ÉĄĖķobinico anoikee anicota me loenatagi AneotedoÉĄĖķoji, inoa ÉĄĖķodoxiceÉĄĖķetedi, codaa me icilatidi owidi eelotaginadi, codaa niÉĄĖķina me yajigotediogi oko lixaketedi anepaa yemaa me yajigotediogi, ane najigotedoÉĄĖķowa Liwigo AneotedoÉĄĖķoji. 
\s1 Jesus jiÉĄĖķijaaÉĄĖķeote ÉĄĖķodewiÉĄĖķa 
\p  
\v 5 EjinaÉĄĖķatece niÉĄĖķicoa nokododi nige dopitedijo AneotedoÉĄĖķoji Lionigi me diiÉĄĖķenataka digoina iiÉĄĖķo. AneotedoÉĄĖķoji ayajigotediogi aanjotedi loniciwaÉĄĖķa moiiÉĄĖķe niÉĄĖķica gela iiÉĄĖķo aneote anigida noko.  
\v 6 MaditaÉĄĖķa lotaÉĄĖķanaÉĄĖķaxi AneotedoÉĄĖķoji, iwoteloco Davi ane ligegitalo AneotedoÉĄĖķoji, niÉĄĖķijo mee, 
\q1 âInoenoÉĄĖķodi, 
\q1 igaamee ina mowoo ina oko, 
\q1 ane liotedawaana, 
\q1 ane diÉĄĖķicata jaoÉĄĖķate? 
\q1 Igaamee ina madowetiteloco ina oko ane diÉĄĖķica loniciwaÉĄĖķa? 
\q1  
\v 7 NiÉĄĖķijoa nokododawaanaÉĄĖķa adianite ĮĪoneleegiwa ane icoÉĄĖķotibigimece ditibigimedi, 
\q1 natinedi aanjotedi. 
\q1 Pida natigide, 
\q1 jaÉĄĖķaweniÉĄĖķideni 
\q1 codaa jaÉĄĖķajicitalo eliodi loniciwaÉĄĖķa. 
\q1  
\v 8 Codaa jaÉĄĖķajicitalo loniciwaÉĄĖķa 
\q1 codaa me naÉĄĖķatetigi me iiÉĄĖķe inoatawece aninoa.â 
\m NiÉĄĖķijo AneotedoÉĄĖķoji naÉĄĖķa yajigote loniciwaÉĄĖķa me iiÉĄĖķete inoatawece, odaa aÉĄĖķica idi ane daÉĄĖķa yajigote niÉĄĖķijoa ĮĪoneleegiwa ane icoÉĄĖķotibigimece ditibigimedi me iiÉĄĖķe. Pida natigide jinataÉĄĖķa aÉĄĖķinatawece oko oyiwaÉĄĖķadi.  
\v 9 Pida ijoa me jinataÉĄĖķa Jesus. OnateciÉĄĖķijoa nokododi AneotedoÉĄĖķoji ideyate Jesus natinedi aanjotedi, eotedibige me yeleotetema inatawece oko meote lewiÉĄĖķa, leeÉĄĖķodi AneotedoÉĄĖķoji me iwikode niÉĄĖķina oko. JoaniÉĄĖķidaa leeÉĄĖķodi AneotedoÉĄĖķoji naÉĄĖķa iweniÉĄĖķide codaa me yajigote eliodi loniciwaÉĄĖķa. 
\p  
\v 10 AneotedoÉĄĖķoji eote inoatawece aninoa codaa doweditedeloco inoatawece, codaa inoatawece nepilidi. AneotedoÉĄĖķoji nadeegite miniwataÉĄĖķa eliodi oko meote me lionigipi, codaa me iweniÉĄĖķide. Enice joaniÉĄĖķidaa mewi, niÉĄĖķijo meote lewiÉĄĖķa oko, ika Jesus, me dawikode, odaa joaniÉĄĖķidaa naÉĄĖķa igodi libakedi. Jesus jiÉĄĖķijaaÉĄĖķeote ÉĄĖķodewiÉĄĖķa, joaniÉĄĖķidaa ane libakedi.  
\v 11 Jesus iwilegitetema oko libeyaceÉĄĖķeco. Odaa inatawece ane yapiditibigiwaji, codaa jiÉĄĖķiniaaÉĄĖķiniwa ane ÉĄĖķodapitaÉĄĖķadi, odaa Eliodi, iniaaÉĄĖķiniwa ĮĪodiodi. JoaniÉĄĖķidaa leeÉĄĖķodi Jesus aniboliÉĄĖķatedoÉĄĖķodici meetedoÉĄĖķowa moko nioxoadipi.  
\v 12 MaditaÉĄĖķa notaÉĄĖķanaÉĄĖķaxi enaco, meete, 
\q1 âInoenoÉĄĖķodi, 
\q1 ejitaÉĄĖķadici miditaÉĄĖķa inioxoadipi. 
\q1 JoÉĄĖķetetaÉĄĖķawa liwigotigi ÉĄĖķadoiigi 
\q1 niÉĄĖķina me yatecoÉĄĖķo.â 
\m  
\v 13 Codaa eledi mee, 
\q1 âEmeÉĄĖķeeta jaÉĄĖķatalo AneotedoÉĄĖķoji.â 
\m Eledi mee, 
\q1 âIte Ee minataÉĄĖķa niÉĄĖķina oko 
\q1 ane najigotediwa AneotedoÉĄĖķoji, 
\q1 ane micataÉĄĖķa daÉĄĖķa lionigipi.â 
\p  
\v 14 NiÉĄĖķina oko aneete Jesus me lionigipi AneotedoÉĄĖķoji, AneotedoÉĄĖķoji eote lawodi codaa me libole. JoaniÉĄĖķidaa leeÉĄĖķodi niÉĄĖķijo Jesus naÉĄĖķa enitedini malee nigaanigawaanigi, AneotedoÉĄĖķoji yajigote lolaadi, lawodi codaa me liboledi. Eote lolaadi me liciagi ÉĄĖķodolaadi. Odaa jiÉĄĖķidaaÉĄĖķee menitedini liciagi okanicodaaÉĄĖķica oko, eotedibige me yakadi me yeleo, odaa ja inoke loniciwaÉĄĖķa diaabo ane domiÉĄĖķijo mida loniciwaÉĄĖķateloco nÃĐmaÉĄĖķa.  
\v 15 Eleditace eotedibige me ikatedicoace niÉĄĖķina oko ane micataÉĄĖķa daÉĄĖķa niwilogojedipi leeÉĄĖķodi modoitigi nÃĐmaÉĄĖķa inoatawece nokododi.  
\v 16 Ewi Jesus me daÉĄĖķa enagiteda me yaxawateda aanjotedi. Pida enagi me yaxawa niÉĄĖķina oko anida aneetege licoÉĄĖķegi AbraÃĢo.  
\v 17 JoaniÉĄĖķidaa me leeditibige Jesus me diniciaceeketedoÉĄĖķogi, me diÉĄĖķicata ane diniwokotedoÉĄĖķodici. Eote me ÉĄĖķodiciaceekawa, eotedibige me ÉĄĖķonisacerdoti ÉĄĖķoneÉĄĖķegi ane ÉĄĖķodiwikode codaa midioka limedi meote libakedi anele. Eleditace eotedibige me yakadi me yeleotetema ÉĄĖķobeyaceÉĄĖķeco, eotedibige AneotedoÉĄĖķoji me daÉĄĖķadiaaÉĄĖķoko laagetedipi.  
\v 18 Dawikode niÉĄĖķijo me dineetalo ÉĄĖķodaxakawa, joaniÉĄĖķidaa leeÉĄĖķodi miniaaÉĄĖķiniwa yakadi me yaxawa niÉĄĖķina ane dineeta ÉĄĖķodaxakawa. 
\c 3  
\s1 Jesus iniaa MoisÃĐs 
\p  
\v 1 Inioxoadipi, AneotedoÉĄĖķoji ÉĄĖķadiolaatedicoace makaami nepilidi, codaa eniditedaÉĄĖķawa midioka limedi me ideoni miniwataÉĄĖķa, odaa ina boÉĄĖķowoo Jesus, NiÉĄĖķijoa liiÉĄĖķexegi AneotedoÉĄĖķoji, jiÉĄĖķiniaa ÉĄĖķonisacerdoti ane daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi, okotawece ane jinakatonaÉĄĖķa.  
\v 2 AneotedoÉĄĖķoji iolatedice meote niÉĄĖķida libakedi me ÉĄĖķonisacerdoti ÉĄĖķoneÉĄĖķegi, odaa idioka limedi meote inoatawece AneotedoÉĄĖķoji ane iiÉĄĖķete meote, digo mijotaÉĄĖķa MoisÃĐs midioka limedi meo ijoatawece niÉĄĖķijoa AneotedoÉĄĖķoji ane iiÉĄĖķete meote me libaketedi liwigotigi AneotedoÉĄĖķoji loiigi.  
\v 3 NiÉĄĖķina oko ane dabiteÉĄĖķetini diimigi daÉĄĖķaxa moiweniÉĄĖķide caticedi niÉĄĖķini diimigi loenatagi. JiÉĄĖķidaaÉĄĖķee Jesus leeditibige moiweniÉĄĖķide caticedi MoisÃĐs, leeÉĄĖķodi liciagi niÉĄĖķijo ane dabiteÉĄĖķetini diimigi.  
\v 4 Natigide okanicodaaÉĄĖķica diimigi ini noenatagodi, pida NiÉĄĖķijoa ane yoe inoatawece baÉĄĖķa AneotedoÉĄĖķoji.  
\v 5 MoisÃĐs idioka limedi mele me diba liwigotigi loiigi AneotedoÉĄĖķoji, micataÉĄĖķa daÉĄĖķa niotagi ane dibatigi diimigi. Ikee niÉĄĖķica AneotedoÉĄĖķoji ane yatemati nigidiaaÉĄĖķidi.  
\v 6 Pida Cristo baÉĄĖķa daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi caticedi okanicodaaÉĄĖķica niotagi. IgaataÉĄĖķa eote ijoatawece niÉĄĖķijoa AneotedoÉĄĖķoji ane iiÉĄĖķete meote, micataÉĄĖķa niÉĄĖķina nionigi ane dowediteloco diimigi. Oko baÉĄĖķa ÉĄĖķodiciagi niÉĄĖķini diimigi, nigidioka limedi mabo ÉĄĖķodaaleÉĄĖķena, codaa nigidioka limedi me jinakatonaÉĄĖķa mida ÉĄĖķonaÉĄĖķajegi ane inibeoonaÉĄĖķatege. 
\s1 ĮĪonajoineÉĄĖķegi me daÉĄĖķa jakakaÉĄĖķataÉĄĖķa ÉĄĖķodaaleÉĄĖķena 
\p  
\v 7 Odaa digawini ane ligegi Liwigo AneotedoÉĄĖķoji, mee, 
\q1 âNige ajipaatatiwaji ligegi AneotedoÉĄĖķoji niÉĄĖķina noko, 
\q1  
\v 8 jinaÉĄĖķa akakaÉĄĖķati ÉĄĖķadaaleÉĄĖķenali, 
\q1 digo mijotaÉĄĖķa anee jotigide ÉĄĖķadaamipi 
\q1 miditaÉĄĖķa nipodigi ane yadilo ane diÉĄĖķicata niÉĄĖķeladimigipi, 
\q1 noÉĄĖķodakapetege AneotedoÉĄĖķoji, 
\q1 codaa modineetalo.â 
\q1  
\v 9 âOdaa mee AneotedoÉĄĖķoji, 
\q1 âDigoida miditaÉĄĖķa niÉĄĖķijo nipodigi ane yadilo, 
\q1 jotigide ÉĄĖķadaamipi odineetiwa, 
\q1 idaaÉĄĖķee monadi libinico ane jaote niÉĄĖķijoatigilo cwareenta nicaaÉĄĖķape. 
\q1  
\v 10 JoaniÉĄĖķidaa leeÉĄĖķodi me idelatema niÉĄĖķijo noiigi, 
\q1 odaa meji, 
\q1 âIdi anidioka limedi meyamaÉĄĖķaticoace inaigi 
\q1 codaa aÉĄĖķoyemaa moyiwaÉĄĖķadi iiÉĄĖķenatakaneÉĄĖķeco.â 
\q1  
\v 11 Odaa naÉĄĖķa idelatema 
\q1 odaa ja jao igegitiogi meji, 
\q1 âNiÉĄĖķidi aÉĄĖķica ane yakadi micota niÉĄĖķidi nipenaÉĄĖķadi 
\q1 ane jilakidetema yoiigi.â ââ 
\p  
\v 12 Inioxoadipi, adowetita adiÉĄĖķica niÉĄĖķina akaamitiwaji ane abeyaceÉĄĖķe laaleÉĄĖķena aneo me daÉĄĖķa nakatoteda ĮĪoniotagodi, codaa niÉĄĖķida niciagi ÉĄĖķadadeegiticogi ditigedi motonitedice AneotedoÉĄĖķoji, NiÉĄĖķijoa ewikegi.  
\v 13 Pida akamaÉĄĖķakaami adinoniciwaÉĄĖķatitiwage inoatawece nokododi maleeÉĄĖķakati majipaata ligegi AneotedoÉĄĖķoji, amanagawini aÉĄĖķicoa niÉĄĖķina akaamitiwaji ane dakake laaleÉĄĖķena, leeÉĄĖķodi libeyaceÉĄĖķeco ane inaale.  
\v 14 IgaataÉĄĖķa oko lokaaÉĄĖķetedipi Cristo nige idokee me jinakatonaÉĄĖķa nigepaa ÉĄĖķodiniogo, digo mijotaÉĄĖķa me jinakatonaÉĄĖķa maleekoka joleeÉĄĖķatibige me jinakatonaÉĄĖķa. 
\p  
\v 15 IgaataÉĄĖķa mee lotaÉĄĖķa AneotedoÉĄĖķoji, 
\q1 âNigajipaata ligegi AneotedoÉĄĖķoji niÉĄĖķina noko, 
\q1 jinaÉĄĖķakakaÉĄĖķati ÉĄĖķadaaleÉĄĖķenali, 
\q1 mijotaÉĄĖķa anee jotigide ÉĄĖķadaamipi noÉĄĖķodakapetege AneotedoÉĄĖķoji, 
\q1 codaa modineetalo.â 
\p  
\v 16 Amiidi ica anowajipatalo AneotedoÉĄĖķoji odaa niÉĄĖķidiaaÉĄĖķidi ja nakapetegi? Ijotawece niÉĄĖķijo oko ane noÉĄĖķaticoace MoisÃĐs me ideitice Egito.  
\v 17 Amiidi ica AneotedoÉĄĖķoji ane yelatetema icoatigilo cwareenta nicaaÉĄĖķape? Yelatetema niÉĄĖķijo anowote loenataka ane beyagi odaa ja nigo miditaÉĄĖķa nipodigi ane yadilo ane diÉĄĖķicata niÉĄĖķeladimigipi.  
\v 18 NiÉĄĖķijo AneotedoÉĄĖķoji neÉĄĖķeote ligegitediogi ica noiigi me doÉĄĖķoyakadi motota ane yoetetema me nipenaÉĄĖķadi loiigi, amiidi ica aneetediogi AneotedoÉĄĖķoji? Eetetece AneotedoÉĄĖķoji niÉĄĖķijo ane doÉĄĖķoyiwaÉĄĖķaditeda.  
\v 19 Odaa ja jinataÉĄĖķa aÉĄĖķoyakadi motota niÉĄĖķica nipodigi AneotedoÉĄĖķoji ane yemaa me yajigotediogi loiigi, leeÉĄĖķodi me doÉĄĖķonakatoteda. 
\c 4  
\s1 Ica nipenaÉĄĖķadi loiigi AneotedoÉĄĖķoji 
\p  
\v 1 AneotedoÉĄĖķoji eote ligegitedoÉĄĖķogi me jakataÉĄĖķa me jakaÉĄĖķatiwece codaa me inipenaÉĄĖķatini miniwataÉĄĖķa digoida ditibigimedi. Enice ele me idinowetaÉĄĖķa adiÉĄĖķica niÉĄĖķina akaamitiwaji aneyamaÉĄĖķatice, oditaÉĄĖķa aÉĄĖķalee yakadi me iwida niÉĄĖķica ÉĄĖķonipenaÉĄĖķadi.  
\v 2 IgaataÉĄĖķa oko eledi jajipaaÉĄĖķatalo nibodicetedi anele ane icoÉĄĖķotedibigimece miniwataÉĄĖķa AneotedoÉĄĖķoji, digo mijotaÉĄĖķa ÉĄĖķodaamipi mowajipatalo. Owajipatalo lotaÉĄĖķa AneotedoÉĄĖķoji, pida niÉĄĖķijo mowajipatalo aÉĄĖķica anoniboloiteetece leeÉĄĖķodi aÉĄĖķoyiwaÉĄĖķadi.  
\v 3 IgaataÉĄĖķa niÉĄĖķida moko baanaÉĄĖķa jinakatonaÉĄĖķa ĮĪoniotagodi, baÉĄĖķa jakaÉĄĖķatio miditaÉĄĖķa ÉĄĖķonipenaÉĄĖķadi. Pida beÉĄĖķeetediogi AneotedoÉĄĖķoji ÉĄĖķodaamipi, 
\q1 âIdelatema niÉĄĖķijo oko 
\q1 odaa ja jao igegitiogi me diÉĄĖķicata ane nakatiobece 
\q1 odaa anipenaÉĄĖķa digoina meetaÉĄĖķaâ. 
\m AneotedoÉĄĖķoji eote niÉĄĖķida ligegi leeÉĄĖķodi me dakapetetege jotigide ÉĄĖķodaamipi idaaÉĄĖķee naÉĄĖķa igodi inoatawece me ilakidetedi nipenaÉĄĖķadi. 
\p  
\v 4 Digawini anodaaÉĄĖķee AneotedoÉĄĖķoji me yalaÉĄĖķate niÉĄĖķica noko ÉĄĖķonipeneÉĄĖķegi maditaÉĄĖķa lotaÉĄĖķanaÉĄĖķaxi, mee, âAneotedoÉĄĖķoji yadeegi dibatio ÉĄĖķobaaÉĄĖķadi nokododi meote inoatawece ane loenataka, odaa neÉĄĖķeledi noko jaÉĄĖķanipetedini.â  
\v 5 Odaa ja yalaÉĄĖķatace niÉĄĖķica noko, niÉĄĖķijo mee, âAÉĄĖķoyakadi me nakatiobece oditaÉĄĖķa nipenaÉĄĖķa meetaÉĄĖķa.â  
\v 6 NiÉĄĖķijo odoejedipi oko anowajipatalo nibodicetedi ane icoÉĄĖķotedibigimece miniwataÉĄĖķa AneotedoÉĄĖķoji adakatiobece miditaÉĄĖķa ica domaÉĄĖķa nipenaÉĄĖķadi ane yoetetema AneotedoÉĄĖķoji, leeÉĄĖķodi aÉĄĖķoyiwaÉĄĖķadi lotaÉĄĖķa. Pida ina eledi oko anepaÉĄĖķa dakatiobece miditaÉĄĖķa niÉĄĖķica nipenaÉĄĖķadi.  
\v 7 IgaataÉĄĖķa AneotedoÉĄĖķoji ja iolatedice eledi noko anidokeyatedigi me âNiÉĄĖķina nokoâ. NiÉĄĖķijo jotigide ÉĄĖķodaamipi oyotigimade AneotedoÉĄĖķoji. Odaa naÉĄĖķa ixomaÉĄĖķatedijo owidi nicaaÉĄĖķape, AneotedoÉĄĖķoji ja iiÉĄĖķe Davi meetece niÉĄĖķijoa notaÉĄĖķa baanaÉĄĖķa ejinaÉĄĖķatece, 
\q1 âNigajipaata ligegi AneotedoÉĄĖķoji niÉĄĖķina noko, 
\q1 jinaÉĄĖķa akakaÉĄĖķati ÉĄĖķadaaleÉĄĖķenali!â 
\p  
\v 8 JosuÃĐ daantaÉĄĖķa yadeegi niÉĄĖķijo noiigi miditaÉĄĖķa niÉĄĖķica nipenaÉĄĖķadi anejinaÉĄĖķatece, daÉĄĖķanagawini AneotedoÉĄĖķoji aÉĄĖķeetetece niÉĄĖķidiaaÉĄĖķidi niÉĄĖķica eledi noko aneyatedigi me âNiÉĄĖķina nokoâ.  
\v 9 Odaa jiÉĄĖķidaaÉĄĖķee eÉĄĖķidita ica nipenaÉĄĖķadi AneotedoÉĄĖķoji loiigi, digo mijoataÉĄĖķa AneotedoÉĄĖķoji manipetedini naÉĄĖķa saabado naÉĄĖķa igodi inoatawece ane loenataka.  
\v 10 IgaataÉĄĖķa niÉĄĖķijo ane dakatio manipetini miniwataÉĄĖķa AneotedoÉĄĖķoji digoida ditibigimedi, niÉĄĖķini oko ja ika inoatawece libaketedi, digo mijoataÉĄĖķa AneotedoÉĄĖķoji manipetedini odaa ja ika libakedi.  
\v 11 Enice ele me idinoniciwaÉĄĖķataÉĄĖķa me jakaÉĄĖķatio, me inipenaÉĄĖķatini miniwataÉĄĖķa AneotedoÉĄĖķoji, amaleeÉĄĖķaÉĄĖķa aÉĄĖķica oko ane yotigimade AneotedoÉĄĖķoji mijotaÉĄĖķa jotigide ÉĄĖķodaamipi moyotigimade, odaa aÉĄĖķaleeÉĄĖķoyakadi me dakatiobece aneite AneotedoÉĄĖķoji. 
\p  
\v 12 IgaataÉĄĖķa niÉĄĖķinoa notaÉĄĖķa ane iwoteloco AneotedoÉĄĖķoji lotaÉĄĖķanaÉĄĖķaxi liciagi niÉĄĖķina ane yewiÉĄĖķa codaa mida loniciwaÉĄĖķa. Yakadi me dakatedio caticedi me liciagi nodaajo-ocaÉĄĖķataÉĄĖķa ane dalepe idoatawece liwailidi. IgaataÉĄĖķa niÉĄĖķinoa notaÉĄĖķa yakadi me yakagidi codaa me yawalacetiwage ÉĄĖķodowooko codaa me ÉĄĖķodiwigo, liciagi niÉĄĖķijo nodaajo me yakadi me iomaÉĄĖķaditege libitagi, libole. NiÉĄĖķinoa lotaÉĄĖķa AneotedoÉĄĖķoji oikee domige beyagi, oÉĄĖķoa, domigele niÉĄĖķinoa ane ÉĄĖķodemaanaÉĄĖķa, inoa ÉĄĖķodowooko catiwedi ÉĄĖķodaaleÉĄĖķena.  
\v 13 AÉĄĖķica ane jakataÉĄĖķa me jaÉĄĖķataÉĄĖķatema AneotedoÉĄĖķoji. Inoatawece ane loenataka yeloÉĄĖķotelogo, inoatawece naditedeloco. Codaa leeditibige me idinigeeÉĄĖķatalo, inoatawece ane ÉĄĖķodoenataka. 
\s1 Jesus ÉĄĖķonisacerdoti ÉĄĖķoneÉĄĖķegi anele 
\p  
\v 14 Enice ele me jatitaÉĄĖķateloco ÉĄĖķotiwaÉĄĖķatakaneÉĄĖķegi, igaataÉĄĖķa iniwa ÉĄĖķonisacerdoti ÉĄĖķoneÉĄĖķegi aneletedoÉĄĖķodomi, ane dakatediwece digoida ditibigimedi, lodoe AneotedoÉĄĖķoji. Jesus jiÉĄĖķiniaa ÉĄĖķonisacerdoti, Lionigi AneotedoÉĄĖķoji.  
\v 15 NiÉĄĖķiniwa ÉĄĖķonisacerdoti ÉĄĖķoneÉĄĖķegi yakadi me ÉĄĖķodiwikode niÉĄĖķina me ÉĄĖķodaÉĄĖķamalaÉĄĖķa, codaa niÉĄĖķina me jawikodeeÉĄĖķa, igaataÉĄĖķa IniaaÉĄĖķiniwa odineetalo inoatawece anodigotalo, codaa me dawikode digo mokotaÉĄĖķa, pida baadeÉĄĖķeote ane beyagi.  
\v 16 Enice iniÉĄĖķa lodoe AneotedoÉĄĖķoji anidioka limedi meliodi meletedoÉĄĖķodomi, jiiÉĄĖķatalo me daÉĄĖķa idoiiÉĄĖķatalo amaleeÉĄĖķaÉĄĖķa ÉĄĖķodiwikode AneotedoÉĄĖķoji, codaa amaleeÉĄĖķaÉĄĖķa eliodi meletedoÉĄĖķodomi, codaa me ÉĄĖķodaxawatetece niÉĄĖķinoa ÉĄĖķodaÉĄĖķalanaÉĄĖķa. 
\c 5  
\p  
\v 1 Ijoatawece niÉĄĖķijoa ÉĄĖķoneleegiwadi ane ijo me lacilodi-sacerdotitedi oiolaticoace liwigotigi eletidi ÉĄĖķoneleegiwadi, oixipeticoace modibatema AneotedoÉĄĖķoji moyaxawa eledi oko. Oyadeegitalo AneotedoÉĄĖķoji liboonaÉĄĖķa niÉĄĖķijo oko, codaa me niÉĄĖķijoa eijedi anonigodi owotibige AneotedoÉĄĖķoji me ixomaÉĄĖķateetedice niÉĄĖķijoa libeyaceÉĄĖķeco anowote niÉĄĖķijo oko. \fig |src="cn02093b.tif" size="span" copy="ÂĐ 1978 David C. Cook Publishing Co." ref="Hebreus 5.1" \fig* 
\v 2 Oyakadi moiwikode niÉĄĖķijo oko niÉĄĖķina mowote libatico ane doÉĄĖķoyowooÉĄĖķoditeda me beyagi, codaa niÉĄĖķijo oko anoninaaletiniwace, odaa jeÉĄĖķeyamaÉĄĖķaticoace, igaataÉĄĖķa iniaaÉĄĖķini idatecibece me naÉĄĖķamalaÉĄĖķa, codaa me dibatÃĄ.  
\v 3 LeeÉĄĖķodi maÉĄĖķaÉĄĖķa dibatÃĄ, odaa leeditibige maÉĄĖķaÉĄĖķa nigodi eijedi aÉĄĖķijoka leeÉĄĖķotedi niÉĄĖķijo oko libeyaceÉĄĖķeco, pida eledi leeÉĄĖķodi aaÉĄĖķaÉĄĖķa libeyaceÉĄĖķeco.  
\v 4 AÉĄĖķica ane yakadi mepaa diniweniÉĄĖķide codaa aÉĄĖķica ane yakadi deÉĄĖķepaa diniomaÉĄĖķaditice me lacilo-sacerdotitedi niÉĄĖķijo jotigide, pida ijokijo niÉĄĖķijo AneotedoÉĄĖķoji ane iolatedice, codaa anenidite me niÉĄĖķiniaa lacilo-sacerdotitedi, digo mijotaÉĄĖķa niÉĄĖķijo jotigide AneotedoÉĄĖķoji neÉĄĖķenidite ArÃĢo me niÉĄĖķijaa lacilo-sacerdotitedi. 
\p  
\v 5 JoaniÉĄĖķidaa Cristo me daÉĄĖķa diniweniÉĄĖķideteda, codaa me deÉĄĖķepaa dinixipetedice me niÉĄĖķiniaa lacilo-sacerdotitedi. Pida AneotedoÉĄĖķoji epaa iweniÉĄĖķide, niÉĄĖķijo neÉĄĖķeeteta, 
\q1 âAkaami Ionigi. 
\q1 NiÉĄĖķina noko jao me Ee ĮĪadiodi.â 
\m  
\v 6 MiditaÉĄĖķa eledi liwai lotaÉĄĖķanaÉĄĖķaxi AneotedoÉĄĖķoji, mee AneotedoÉĄĖķoji, 
\q1 âIdioka limedi makaami sacerdoti, 
\q1 ÉĄĖķadiciagi mijotaÉĄĖķa Melquisedeque, 
\q1 niÉĄĖķijo jotigide.â 
\p  
\v 7 NiÉĄĖķijo Jesus maleeÉĄĖķinaaÉĄĖķite digoina iiÉĄĖķo, yotaÉĄĖķaneÉĄĖķetedibece AneotedoÉĄĖķoji, dipokote. Igedi me dotaÉĄĖķa codaa datiidi me dipokote AneotedoÉĄĖķoji me noÉĄĖķatedice lawikodigi niÉĄĖķidaaÉĄĖķoyatedigi moyametibigo neÉĄĖķepaa yeleo. Odaa AneotedoÉĄĖķoji wajipate Jesus ane lipoketegi leeÉĄĖķodi me yemaa meote icokica niÉĄĖķica ane yemaa AneotedoÉĄĖķoji.  
\v 8 IdaaÉĄĖķida me Lionigi AneotedoÉĄĖķoji, pida niÉĄĖķijo Jesus naÉĄĖķa dawikode, odaa ja yowooÉĄĖķodi me leeditibige midioka limedi meyiwaÉĄĖķadi Eliodi leeÉĄĖķotedi lawikodico.  
\v 9 NiÉĄĖķijo Jesus naÉĄĖķa ixomaÉĄĖķateetedijo ijoatawece ane leeditibige me lawikodico, odaa jeÉĄĖķeote me ĮĪonewikatitoÉĄĖķodi. Odaa ja yakadi meote midioka limedi me newiÉĄĖķa inatawece oko anoyiwaÉĄĖķadi.  
\v 10 Odaa AneotedoÉĄĖķoji ja yeloÉĄĖķoditedibece me niÉĄĖķiniaa iolatedice Jesus me ÉĄĖķonisacerdoti ÉĄĖķoneÉĄĖķegi, digo mijotaÉĄĖķa Melquisedeque. 
\s1 Leeditibige me ÉĄĖķodili mejiwaÉĄĖķatakanaÉĄĖķa odaa aÉĄĖķejamaÉĄĖķajoÉĄĖķotice 
\p  
\v 11 Ja domaÉĄĖķa eliodi me idalaÉĄĖķa Melquisedeque, pida dakake me jeloÉĄĖķoditaÉĄĖķawatiwaji ane diitigi, leeÉĄĖķodi jaÉĄĖķakakaÉĄĖķati ÉĄĖķadaaleÉĄĖķenali, odaa aÉĄĖķajipaatiwaji.  
\v 12 Ja leegi makaamitiwaji manakatoni ĮĪoniotagodi, odaa ja domaÉĄĖķakatitiwaji daÉĄĖķakaami niiÉĄĖķaxinaÉĄĖķanadi. Pida niÉĄĖķida makaamitiwaji eleeditibige mini oko ane ÉĄĖķadiiÉĄĖķaxinitacece niÉĄĖķinoa niiÉĄĖķaxinaÉĄĖķaneÉĄĖķeco ane daÉĄĖķa dakaketeda maditaÉĄĖķa AneotedoÉĄĖķoji lotaÉĄĖķanaÉĄĖķaxi. NiÉĄĖķida makaamitiwaji jiÉĄĖķide eni micataÉĄĖķa niÉĄĖķina daÉĄĖķakaamitace nigaanigipawaanigi anoyopotibige waca-lotiidi, analee doÉĄĖķoyakadi moyeligo niÉĄĖķina baanaÉĄĖķa niweenigi.  
\v 13 NiÉĄĖķina nigaanigawaanigi baÉĄĖķaleeÉĄĖķilibi, ayakadi me yowooÉĄĖķoditece liiÉĄĖķaxinaÉĄĖķaneÉĄĖķeco AneotedoÉĄĖķoji lotaÉĄĖķa ane ikee anele, codaa ane beyagi, leeÉĄĖķodi malee nigaanigawaanigi.  
\v 14 Pida niÉĄĖķida eledi niweenigi, liweenigi niÉĄĖķina baanaÉĄĖķa oko, niÉĄĖķijo baanoÉĄĖķoyowooÉĄĖķodi moiwi niÉĄĖķina ane iÉĄĖķenaÉĄĖķa, inaaÉĄĖķina ane beyagi, odaa owo inokina ane iÉĄĖķenaÉĄĖķa. 
\c 6  
\p  
\v 1 Enice joleeÉĄĖķatibige midapaÉĄĖķa jiiÉĄĖķaticogi odoe me idiniiÉĄĖķaxinaÉĄĖķa. JikanaÉĄĖķa me jiiÉĄĖķaxinaÉĄĖķanaÉĄĖķatece niÉĄĖķijoa odoejedi niiÉĄĖķaxinaÉĄĖķaneÉĄĖķeco ane daÉĄĖķa dakaketeda anoditece Cristo. Odaa ele me idiniiÉĄĖķaxinaÉĄĖķatece niiÉĄĖķaxinaÉĄĖķaneÉĄĖķeco ane dakake, amaleeÉĄĖķaÉĄĖķa ili ÉĄĖķotiwaÉĄĖķatakaneÉĄĖķegi. JinaÉĄĖķalee idiniiÉĄĖķaxinaÉĄĖķatacece me leeditibige me idinilaanaÉĄĖķatece ÉĄĖķobeyaceÉĄĖķeco anowo oko midioka limedi me yeleo, codaa jinaÉĄĖķalee idiniiÉĄĖķaxinaÉĄĖķatece me leeditibige me jinakatonaÉĄĖķa AneotedoÉĄĖķoji.  
\v 2 JinaÉĄĖķalee idiniiÉĄĖķaxinaÉĄĖķatacece niiÉĄĖķaxinaÉĄĖķaneÉĄĖķegi aneetece me idinilegenaÉĄĖķa, codaa anodaaÉĄĖķee judeutedi me diniwilegi, codaa me niiÉĄĖķaxinaÉĄĖķaneÉĄĖķegi aneetece anodaaÉĄĖķee Liwigo AneotedoÉĄĖķoji me iiÉĄĖķe oko niÉĄĖķina me jipekenaÉĄĖķateloco ÉĄĖķobaaÉĄĖķatedi. JinaÉĄĖķalee idiniiÉĄĖķaxinaÉĄĖķatacece niiÉĄĖķaxinaÉĄĖķaneÉĄĖķegi aneetece anodaaÉĄĖķee AneotedoÉĄĖķoji meote ÃĐmaÉĄĖķaÉĄĖķa me newiÉĄĖķatace, codaa anodaaÉĄĖķee me iwi, odaa midioka limedi me iloikatidi niÉĄĖķina oko abeyacaÉĄĖķaÉĄĖķa.  
\v 3 Enice jikanaÉĄĖķa inoa niiÉĄĖķaxinaÉĄĖķaneÉĄĖķeco, odaa idiniiÉĄĖķaxinaÉĄĖķatece niiÉĄĖķaxinaÉĄĖķaneÉĄĖķeco baÉĄĖķa dakake, nige ÉĄĖķodika AneotedoÉĄĖķoji me jaoÉĄĖķa. 
\p  
\v 4 Odaa ele me joleeÉĄĖķatibige midapaÉĄĖķa jiiÉĄĖķaticogi odoe me idiniiÉĄĖķaxinaÉĄĖķa, igaataÉĄĖķa niÉĄĖķijo aneyamaÉĄĖķatice eliwaÉĄĖķatakaneÉĄĖķegi, codaa ane daÉĄĖķalee yemaa me diotece ĮĪoniotagodi, aÉĄĖķaleeÉĄĖķica nimaweneÉĄĖķegi me dinilaatace. Ja yowooÉĄĖķodi nilokokena AneotedoÉĄĖķoji, codaa ja ici niÉĄĖķijo noÉĄĖķeedi AneotedoÉĄĖķoji ane yajigoteta, codaa jiÉĄĖķijo me deemitetece loniciwaÉĄĖķa Liwigo AneotedoÉĄĖķoji catiwedi laaleÉĄĖķena.  
\v 5-6 JiÉĄĖķijo me ici lotaÉĄĖķa AneotedoÉĄĖķoji, odaa ja yowooÉĄĖķodi mele, codaa jiÉĄĖķijo me ici niÉĄĖķinoa lixaketedi anele ane yajigota AneotedoÉĄĖķoji Liwigo, nigeyamaÉĄĖķatice odaa aÉĄĖķalee yemaa me diotece ĮĪoniotagodi, aÉĄĖķaleeÉĄĖķica ÉĄĖķonimaweneÉĄĖķegi daÉĄĖķa jaoÉĄĖķa me dinilaatacece libeyaceÉĄĖķeco, igaataÉĄĖķa niÉĄĖķida anee micataÉĄĖķa daÉĄĖķa yototacedini Lionigi AneotedoÉĄĖķoji, odaa ja yametibigimece lodoe eledi oko. 
\p  
\v 7 NiÉĄĖķina oko liciaceekawa iiÉĄĖķo. IgaataÉĄĖķa niÉĄĖķina ebici midatibece menitinigi iiÉĄĖķo, odaa iiÉĄĖķo jiÉĄĖķinoa ane nokoloÉĄĖķoteloco nawodigijedi anele, ane yemaa nawodaÉĄĖķanaÉĄĖķa, odaa AneotedoÉĄĖķoji ibinie niÉĄĖķidi iiÉĄĖķo.  
\v 8 Pida niÉĄĖķina iiÉĄĖķo minoka yajigoteda lalepiÉĄĖķigoli inaa lewaÉĄĖķa ane diÉĄĖķicata aneletema, doidetibige AneotedoÉĄĖķoji me ixoo niÉĄĖķidi iiÉĄĖķo, codaa me yalegi. 
\p  
\v 9 Pida idaaÉĄĖķidata mejinaÉĄĖķa niÉĄĖķijoa ÉĄĖķodotaÉĄĖķa, yokaaÉĄĖķetedipi yemaanigipi, aÉĄĖķejiwaÉĄĖķatakanaÉĄĖķa daÉĄĖķamiÉĄĖķiticoace, pida ejiwaÉĄĖķataÉĄĖķa midioka limedi me ikeeni anodaaÉĄĖķeni me ÉĄĖķadewiki AneotedoÉĄĖķoji meote gela ÉĄĖķadewiÉĄĖķa.  
\v 10 AneotedoÉĄĖķoji iÉĄĖķenaÉĄĖķa, codaa ayaagiditedibige niÉĄĖķijo ÉĄĖķabakedi anawiitiwaji, codaa me ÉĄĖķademaanaÉĄĖķaneÉĄĖķegitalo anikeenitiwaji niÉĄĖķijo maxawani codaa niÉĄĖķina natigide maxawani ÉĄĖķanioxoadipi, domoÉĄĖķonoÉĄĖķa libeyaceÉĄĖķeco.  
\v 11 Eliodi me jemaanaÉĄĖķa moninitecibeci niÉĄĖķina akaamitiwaji midioka limedi madinoniciwaÉĄĖķatitiwaji nigepaaÉĄĖķicota niÉĄĖķica owidijegi noko, amaleeÉĄĖķaÉĄĖķa abaatege niÉĄĖķica ÉĄĖķanaÉĄĖķajegitiwaji ane nibeotaÉĄĖķagi.  
\v 12 AjemaanaÉĄĖķa daÉĄĖķakaamitiwaji abaciÉĄĖķegipi, pida iwitece anodaaÉĄĖķee niÉĄĖķina aneniwaÉĄĖķatakanaÉĄĖķa, codaa odinatitalo inoatawece, amanagawini abaatege niÉĄĖķica AneotedoÉĄĖķoji anee me yajigotedaÉĄĖķawatiwaji. 
\s1 NiÉĄĖķina AneotedoÉĄĖķoji ane ligegi, idioka limedi meote 
\p  
\v 13 NiÉĄĖķijo jotigide AneotedoÉĄĖķoji eote ligegitetege AbraÃĢo. NiÉĄĖķijo neÉĄĖķeote ligegitetege, AneotedoÉĄĖķoji ibake epaa LiboonaÉĄĖķadi, igaataÉĄĖķa aÉĄĖķica eledi boonaÉĄĖķadi ane daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi.  
\v 14 NiÉĄĖķijo AneotedoÉĄĖķoji neÉĄĖķeote ligegitetege AbraÃĢo, meeteta, âJao igegitaÉĄĖķagi jaotaÉĄĖķadomi niÉĄĖķina anele, codaa jaotaÉĄĖķadomi mowidi ÉĄĖķadionigipi, ÉĄĖķadawaÉĄĖķa.â  
\v 15 AbraÃĢo abotege me dinatita me nibeotege niÉĄĖķijo ane ligegiteta AneotedoÉĄĖķoji, joaniÉĄĖķidaa leeÉĄĖķodi me dibatege niÉĄĖķijo aneeteta AneotedoÉĄĖķoji me yajigote.  
\v 16 NiÉĄĖķina oko mowo ligegi, oibake eledi oko liboonaÉĄĖķadi ane daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi moikee mewi mowo niÉĄĖķida ane ligegi. Odaa niÉĄĖķina mowo nigegitege eledi oko, odaa ja yaaÉĄĖķadi okanicodaaÉĄĖķica notigimadigi.  
\v 17 AneotedoÉĄĖķoji yemaa meote me yenikamaÉĄĖķa moyowooÉĄĖķodi niÉĄĖķina oko niÉĄĖķica aneote ligegitetege. Yemaa me ikee me daÉĄĖķa anojicetetema ane ligegi. JoaniÉĄĖķidaa leeÉĄĖķodi me ibake epaa LiboonaÉĄĖķadi niÉĄĖķina meote niÉĄĖķijo ligegitetege AbraÃĢo.  
\v 18 JoaniÉĄĖķidaaÉĄĖķee idoa itoataale ane daÉĄĖķa yakadita me diniigi: JiÉĄĖķiniaa AneotedoÉĄĖķoji aneote ligegi, codaa jiÉĄĖķiniaaÉĄĖķiniwa ane ibake epaa LiboonaÉĄĖķadi. Odaa joaniÉĄĖķidaaÉĄĖķee AneotedoÉĄĖķoji ayakadi daÉĄĖķa ÉĄĖķodinaale. Codaa joaniÉĄĖķidaa leeÉĄĖķodi me jotetaÉĄĖķatini, okomodi baanaÉĄĖķa jelaÉĄĖķatalo AneotedoÉĄĖķoji me ÉĄĖķodotete, codaa jakataÉĄĖķa mabo ÉĄĖķodaaleÉĄĖķena me inibeoonaÉĄĖķatege ÉĄĖķonaÉĄĖķajegi anicota me najigotedoÉĄĖķowa.  
\v 19 NiÉĄĖķina me inibeoonaÉĄĖķatege niÉĄĖķica ÉĄĖķonaÉĄĖķajegi, ele me joleeÉĄĖķatibige me jotetaÉĄĖķateloco ÉĄĖķotiwaÉĄĖķatakaneÉĄĖķegi, odaa aÉĄĖķejamaÉĄĖķajoÉĄĖķotice daÉĄĖķa jotonaÉĄĖķatedice AneotedoÉĄĖķoji. NiÉĄĖķina me jotetaÉĄĖķateloco ÉĄĖķotiwaÉĄĖķatakaneÉĄĖķegi, ÉĄĖķotiwaÉĄĖķatakaneÉĄĖķegi liciagi niÉĄĖķina ÉĄĖķapileceÉĄĖķe anoyate catinedi ninyoÉĄĖķodi ane daÉĄĖķa ika niwatece me yadeegi ninyoÉĄĖķodi, igaataÉĄĖķa dotetetini. InibeoonaÉĄĖķatege NiÉĄĖķijoa ane dakatediwece digoida lodoe AneotedoÉĄĖķoji, micataÉĄĖķa niÉĄĖķijo lacilo-sacerdotitedi me dakatiobece AneotedoÉĄĖķoji liÉĄĖķeladi, ixomaÉĄĖķatice caticedi naÉĄĖķajo lipegeteÉĄĖķe epoacajo, odaa ja dakatiwece digoida lodoe AneotedoÉĄĖķoji.  
\v 20 Jesus jiÉĄĖķijaa odoejegi me dakatediwece lodoe AneotedoÉĄĖķoji digoida ditibigimedi me ÉĄĖķodeleÉĄĖķete. JiÉĄĖķijaaÉĄĖķijoa anidioka limedi me sacerdoti ÉĄĖķoneÉĄĖķegi, liciaceekawa mijotaÉĄĖķa sacerdoti Melquisedeque. 
\c 7  
\s1 Melquisedeque, sacerdoti codaa me inionigi-eliodi 
\p  
\v 1 NiÉĄĖķica jotigide ica Melquisedeque ninionigi-eliodi aca nigotaÉĄĖķa ane liboonaÉĄĖķadi SalÃĐm, codaa me sacerdoti ane dibatema AneotedoÉĄĖķoji ane iiÉĄĖķe inoatawece. NiÉĄĖķica AbraÃĢo naÉĄĖķa dopitice me diwitide niÉĄĖķica naÉĄĖķa nigodi icoa ciinco inionaÉĄĖķa-eloodoli anoideleÉĄĖķe, odaa Melquisedeque jiÉĄĖķigo dakapetege, odaa ja ibinie.  
\v 2 Odaa AbraÃĢo ja yajigota Melquisedeque nidiizimo icoatawece niÉĄĖķicoa lateka ane nepilidi niÉĄĖķijoa inionaÉĄĖķa-eloodoli. Ica liboonaÉĄĖķadi Melquisedeque one amina anejinaÉĄĖķata âInionigi-eliodi ane iÉĄĖķenaÉĄĖķaâ, iniaaÉĄĖķini ninionigi-eliodi aca SalÃĐm, amina anejinaÉĄĖķa âInionigi-eliodi aneote mele ÉĄĖķodaaleÉĄĖķenaliâ.  
\v 3 Codaa aÉĄĖķica ane yowooÉĄĖķodi niÉĄĖķica eliodi oteÉĄĖķexaaÉĄĖķaÉĄĖķa aca eliodo, oteÉĄĖķexaaÉĄĖķaÉĄĖķa ica nelokododipi. AÉĄĖķica ane yowooÉĄĖķodi ica neÉĄĖķenitini, codaa ica naÉĄĖķa yeleo. Odaa ja liciagi AneotedoÉĄĖķoji Lionigi, igaataÉĄĖķa ijaaÉĄĖķijo idioka limedi me sacerdoti. 
\p  
\v 4 Digowootiwaji Melquisedeque me daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi! AbraÃĢo aneliodi inatawece ÉĄĖķodoiigi pida yajigota Melquisedeque nidiizimo niÉĄĖķicoa lateka me diwitide.  
\v 5 NiÉĄĖķijo anida aneetege licoÉĄĖķegi Levi, niÉĄĖķijo lionigi JacÃģ, ane libatadeÉĄĖķegi me sacerdotitedi. NiÉĄĖķijoa lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs iiÉĄĖķe niÉĄĖķidiwa sacerdotitedi modibatege nidiizimo niÉĄĖķidi noiigi, inoatawece ane nepilidi, idaaÉĄĖķee niÉĄĖķidi noiigi me nioxoadipi, codaa mida aneetege licoÉĄĖķegi AbraÃĢo.  
\v 6 Melquisedeque aÉĄĖķica aneetege licoÉĄĖķegi Levi, pida dibatege nidiizimo AbraÃĢo, liwai niÉĄĖķicoa lateka. Odaa ja ibinie AbraÃĢo, niÉĄĖķijo ane dibatege niÉĄĖķijo ane ligegitetege AneotedoÉĄĖķoji me yajigote.  
\v 7 AjawienatakanaÉĄĖķa me niÉĄĖķina ane ibinie eledi oko daÉĄĖķaxa me ÉĄĖķoneÉĄĖķegi caticedi niÉĄĖķini ane ibinie.  
\v 8 NiÉĄĖķijo anida aneetege licoÉĄĖķegi Levi anodibatibigege nidiizimo niÉĄĖķica oko, liwai ane nepilidi, niÉĄĖķidiwa ÉĄĖķoneleegiwadi anodibatibigege baÉĄĖķa nigo. Pida lotaÉĄĖķanaÉĄĖķaxi AneotedoÉĄĖķoji mee niÉĄĖķijo analeeÉĄĖķini me yewiÉĄĖķa ja dibatege nidiizimo AbraÃĢo, liwai lateka.  
\v 9 JakataÉĄĖķa mejinaÉĄĖķa niÉĄĖķijo AbraÃĢo naÉĄĖķa yajigo nidiizimo, liwai lateka, odaa Levi micataÉĄĖķa deÉĄĖķeledi yajigota Melquisedeque nidiizimo niÉĄĖķijo AbraÃĢo naÉĄĖķa yajigo, liwai lateka.  
\v 10 Levi aniÉĄĖķica deÉĄĖķenitini, pida itigi lolaadi nelokodi AbraÃĢo niÉĄĖķijo AbraÃĢo naÉĄĖķa dakapetege Melquisedeque. (JoaniÉĄĖķidaa leeÉĄĖķodi me jakataÉĄĖķa mejinaÉĄĖķa Levi maÉĄĖķaÉĄĖķa yajigota Melquisedeque nidiizimo niÉĄĖķijo AbraÃĢo naÉĄĖķa yajigo liwai lateka.) 
\p  
\v 11 NiÉĄĖķijo AneotedoÉĄĖķoji naÉĄĖķa yajigote loiigi Israel niÉĄĖķijoa lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs, iiÉĄĖķe niÉĄĖķijoa leviitatedi anida aneetege licoÉĄĖķegi ArÃĢo me sacerdotitedi. Pida niÉĄĖķijo libakedi ayakadi deÉĄĖķeo niÉĄĖķidi noiigi midioka limedi me newiÉĄĖķa miniwataÉĄĖķa AneotedoÉĄĖķoji. JoaniÉĄĖķidaa leeÉĄĖķodi naÉĄĖķa leeditibige eledi latopagi sacerdoti, liciagi Melquisedeque, pida baadaÉĄĖķa liciagi ArÃĢo.  
\v 12 Pida niÉĄĖķina me leeditibige me diniigi ane latopagi sacerdoti, odaa eledi leeditibige me diniigi lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs.  
\v 13 LotaÉĄĖķanaÉĄĖķaxi AneotedoÉĄĖķoji eetece niÉĄĖķica eledi sacerdoti, codaa eledi ane licoÉĄĖķegi, aÉĄĖķica aneetege licoÉĄĖķegi Levi. AÉĄĖķica otiÉĄĖķinitece oko niÉĄĖķida ane licoÉĄĖķegi ane dibatema AneotedoÉĄĖķoji me nigodi codaa me yalegi eijedi maditaÉĄĖķa AneotedoÉĄĖķoji nameeja.  
\v 14 JowooÉĄĖķotaÉĄĖķa ĮĪoniotagodi mida aneetetege ane licoÉĄĖķegi JudÃĄ. Pida MoisÃĐs aÉĄĖķica deÉĄĖķee niÉĄĖķina oko anida aneetege licoÉĄĖķegi JudÃĄ daÉĄĖķa yakadi mowo me sacerdoti. 
\s1 Ica eledi sacerdoti ane liciagi Melquisedeque 
\p  
\v 15 Digawini jeÉĄĖķeneÉĄĖķegi yenikamaÉĄĖķa naÉĄĖķa diniigi anodaaÉĄĖķee sacerdoti, igaataÉĄĖķa jeÉĄĖķeno eledi ane latopagi sacerdoti ane liciaceekawa Melquisedeque.  
\v 16 Adinoe me sacerdoti daÉĄĖķa leeÉĄĖķotedi niiÉĄĖķenatakaneÉĄĖķeco anowo licoÉĄĖķegi Levi me sacerdotitedi. Pida dinoe me sacerdoti leeÉĄĖķodi iniaa loniciwaÉĄĖķa aneo midioka limedi me yewiÉĄĖķa, igaataÉĄĖķa aÉĄĖķica ane yakadi me yaaÉĄĖķadi lewiÉĄĖķa.  
\v 17 IgaataÉĄĖķa lotaÉĄĖķanaÉĄĖķaxi AneotedoÉĄĖķoji eetece, niÉĄĖķijo mee, âIdioka limedi makaami sacerdoti, ÉĄĖķadiciaceekawa Melquisedeque.â  
\v 18 JiÉĄĖķidaa naÉĄĖķa yaaÉĄĖķadi niÉĄĖķijo lajoinaÉĄĖķaneÉĄĖķegi MoisÃĐs aneetece niÉĄĖķica ane yakadi me sacerdoti. IgaataÉĄĖķa niÉĄĖķijo najoinaÉĄĖķaneÉĄĖķegi inokeo me sacerdoti niÉĄĖķina oko ane diÉĄĖķica loniciwaÉĄĖķa, codaa ane diÉĄĖķica ane jaoÉĄĖķa.  
\v 19 IgaataÉĄĖķa liiÉĄĖķenatakaneÉĄĖķeco AneotedoÉĄĖķoji aÉĄĖķica loniciwaÉĄĖķa deÉĄĖķeo oko me iÉĄĖķenaÉĄĖķa. Pida AneotedoÉĄĖķoji jeÉĄĖķeote niÉĄĖķica eledi ane daÉĄĖķaxa meletoÉĄĖķodomi ane inibeoonaÉĄĖķatege. Odaa leeÉĄĖķodi niÉĄĖķica ane inibeoonaÉĄĖķatege, odaa ja jakataÉĄĖķa me jipecaÉĄĖķatege AneotedoÉĄĖķoji, leeÉĄĖķodi ÉĄĖķodilaÉĄĖķatege. 
\p  
\v 20 AneotedoÉĄĖķoji eote ligegitetege Jesus niÉĄĖķijo neÉĄĖķeote me sacerdoti. Pida niÉĄĖķijo anida aneetege licoÉĄĖķegi Levi niÉĄĖķijo noÉĄĖķowote me sacerdotitedi, AneotedoÉĄĖķoji aÉĄĖķica deÉĄĖķeote ligegitetege.  
\v 21 Pida niÉĄĖķijo Jesus naÉĄĖķa sacerdoti, AneotedoÉĄĖķoji eote ligegitetege, meeteta, 
\q1 âĮĪoniotagodi AneotedoÉĄĖķoji eote ligegi 
\q1 codaa aiigi lowoogo. 
\q1 NiÉĄĖķida makaami idioka limedi makaami sacerdoti, 
\q1 digo mijotaÉĄĖķa Melquisedeque.â 
\m  
\v 22 LeeÉĄĖķodi AneotedoÉĄĖķoji meote ligegitetege Jesus, odaa Jesus daÉĄĖķaxa meliodi loniciwaÉĄĖķa meote niÉĄĖķijo AneotedoÉĄĖķoji ane ligegitetege, niÉĄĖķijo neÉĄĖķeote me ÉĄĖķodilaÉĄĖķatacege AneotedoÉĄĖķoji meote ÉĄĖķodewiÉĄĖķa. 
\p  
\v 23 Digawini eledi ane jinaditece. NiÉĄĖķijo jotigide ijoa owidi sacerdotitedi leeÉĄĖķodi me nigo odaa aÉĄĖķoyakadi midioka limedi me nibaaÉĄĖķa.  
\v 24 Pida Jesus biÉĄĖķidioka limedi miniwa me yewiÉĄĖķa, odaa yakadi midioka limedi me sacerdoti, odaa aleeditibige eledi sacerdoti ane waxodi limedi.  
\v 25 JoaniÉĄĖķidaa leeÉĄĖķodi mida loniciwaÉĄĖķa meote midioka limedi me newiÉĄĖķa niÉĄĖķina oko ane yadeegiteta AneotedoÉĄĖķoji, igaataÉĄĖķa idioka limedi me yewiÉĄĖķa me dipokotedibigeloco niÉĄĖķidi oko miniwataÉĄĖķa AneotedoÉĄĖķoji. 
\p  
\v 26 Enice Jesus jiÉĄĖķijaaÉĄĖķijoa niÉĄĖķica sacerdoti ÉĄĖķoneÉĄĖķegi ane jopooÉĄĖķatibige. IjaaÉĄĖķijoa liciagi AneotedoÉĄĖķoji, aÉĄĖķica deÉĄĖķeote ane beyagi, aÉĄĖķica nibeyaceÉĄĖķegi catiwedi laaleÉĄĖķena. AneotedoÉĄĖķoji iomaÉĄĖķaditedice Jesus liwigotigi niÉĄĖķina oko abeyacaÉĄĖķaÉĄĖķa, odaa AneotedoÉĄĖķoji ja yadeegi me ideite miniwataÉĄĖķa mepaa iiÉĄĖķe inoatawece.  
\v 27 Jesus aliciagi niÉĄĖķijoa eletidi sacerdotitedi ane leeditibige monigodi eijedi odaa joÉĄĖķoyajigotalo AneotedoÉĄĖķoji inoatawece nokododi, leeÉĄĖķotedi epaa libeyaceÉĄĖķeco codaa me libeyaceÉĄĖķeco eledi oko. IgaataÉĄĖķa Jesus epaa diniboote AneotedoÉĄĖķoji leeÉĄĖķotedi libeyaceÉĄĖķeco oko. Odaa onijoteci meote, odaa aÉĄĖķalee leeditibige deÉĄĖķeotace, igaataÉĄĖķa niÉĄĖķijo aneote idioka limedi me diniwaloe.  
\v 28 NiÉĄĖķijoa lajoinaÉĄĖķaneÉĄĖķeco MoisÃĐs iolaticoace ÉĄĖķoneleegiwadi me lacilodi-sacerdotitedi, pida niÉĄĖķidiwa ÉĄĖķoneleegiwadi inoa libeyaceÉĄĖķeco. Pida niÉĄĖķidiaaÉĄĖķidi MoisÃĐs naÉĄĖķa igodi me idÃ­ lajoinaÉĄĖķaneÉĄĖķeco, niÉĄĖķidiaaÉĄĖķidi AneotedoÉĄĖķoji jeÉĄĖķeote ligegi, odaa ja iolatedice Lionigi, niÉĄĖķijoa aneote midioka limedi me sacerdoti ane diÉĄĖķica libatiigi. 
\c 8  
\s1 Jesus ÉĄĖķonisacerdoti ÉĄĖķoneÉĄĖķegi 
\p  
\v 1 Ijoatawece niÉĄĖķijoa ÉĄĖķodotaÉĄĖķa anejinaÉĄĖķatece, idiwa ane daÉĄĖķaxa me ÉĄĖķoneÉĄĖķaÉĄĖķa baanaÉĄĖķa ejinaÉĄĖķa natigide. Iniwa ÉĄĖķonisacerdoti ÉĄĖķoneÉĄĖķegi ane nicote liwai libaaÉĄĖķadi AneotedoÉĄĖķoji anida loniciwaÉĄĖķatedeloco inoatawece.  
\v 2 NiÉĄĖķiniwa sacerdoti eote libakedi lodoe iniaaÉĄĖķiniwa AneotedoÉĄĖķoji. AÉĄĖķeote libakedi catiwedi nopegedi liciagi niÉĄĖķijo anowo loiigi AneotedoÉĄĖķoji niÉĄĖķijo jotigide, pida libakadi niÉĄĖķijo nimedi ĮĪoniotagodi AneotedoÉĄĖķoji ane yoetetema, nimedi ane iÉĄĖķenaÉĄĖķa, digoida ditibigimedi. 
\p  
\v 3 Ijoatawece lacilodi-sacerdotitedi oiolaticoace moyadeegitalo AneotedoÉĄĖķoji niÉĄĖķicoa liboonaÉĄĖķa niÉĄĖķina oko, codaa minoa eijedi anonigodi, owotibige AneotedoÉĄĖķoji me ixomaÉĄĖķateetedice libeyaceÉĄĖķeco. JoaniÉĄĖķidaa leeÉĄĖķodi me leeditibige ÉĄĖķonisacerdoti ÉĄĖķoneÉĄĖķegi maÉĄĖķaÉĄĖķa leeditibige midi ica ane yadeegiteta AneotedoÉĄĖķoji.  
\v 4 DiÉĄĖķinaaÉĄĖķite niÉĄĖķina iiÉĄĖķo, agotaÉĄĖķa sacerdoti, igaataÉĄĖķa owidi sacerdotitedi anoyadeegitalo AneotedoÉĄĖķoji liboonaÉĄĖķa niÉĄĖķijo oko, ane liiÉĄĖķenatakaneÉĄĖķegi najoinaÉĄĖķaneÉĄĖķeco judeutedi. Codaa Cristo aÉĄĖķica aneetetege licoÉĄĖķegi Levi daÉĄĖķa liciagi niÉĄĖķijoa eletidi sacerdotitedi.  
\v 5 NiÉĄĖķidiwa eletidi sacerdotitedi odibatema AneotedoÉĄĖķoji catiwedi nopegedi ane liwigo niÉĄĖķica digoida ditibigimedi, codaa micataÉĄĖķa daÉĄĖķa liwa niÉĄĖķica ane libakadi Jesus digoida ditibigimedi. JoaniÉĄĖķidaa leeÉĄĖķodi niÉĄĖķijo MoisÃĐs maleekoka doletibige meo ica lopegedi AneotedoÉĄĖķoji, AneotedoÉĄĖķoji yajoi meeteta, âAdowetita, awii liciagi niÉĄĖķini ÉĄĖķawinigi ane jikeetaÉĄĖķawa digoida maditaÉĄĖķa wetiÉĄĖķa.â  
\v 6 Pida natigide Cristo ja dibatetege libakedi ane daÉĄĖķaxa mele caticedi niÉĄĖķijoa jotigide libaketedi niÉĄĖķijoa sacerdotiteditigi niÉĄĖķina iiÉĄĖķo. Codaa niÉĄĖķijo Jesus aneote eo AneotedoÉĄĖķoji inaa ÉĄĖķoneleegiwadi moyakadi gela nimaweneÉĄĖķegi me dinilakidetiwage, eo ane daÉĄĖķaxa mele, aliciagi niÉĄĖķijo jotigide anee me dinilakidetetege oko. IgaataÉĄĖķa niÉĄĖķijo AneotedoÉĄĖķoji neÉĄĖķeote ligegi, niÉĄĖķijo aneetetece daÉĄĖķaxa meletoÉĄĖķodomi. 
\p  
\v 7 Codaa niÉĄĖķijo odoejegi anigotedoÉĄĖķowa me dinilakidetedoÉĄĖķogi daaditaÉĄĖķa naÉĄĖķamalaÉĄĖķa, AneotedoÉĄĖķoji agotaÉĄĖķa leeditibige meote gela anigotedoÉĄĖķowa me dinilakidetedoÉĄĖķogi.  
\v 8 Pida AneotedoÉĄĖķoji laagetedipi loiigi, niÉĄĖķijo naÉĄĖķa doÉĄĖķowo niÉĄĖķica ane dinilakidetetege, odaa jeÉĄĖķee, 
\q1 ââIcotalo nokododiâ, 
\q1 mee ĮĪoniotagodi AneotedoÉĄĖķoji, 
\q1 âNige jao gela anejigo me idinilakidetege loiigi Israel, 
\q1 codaa me loiigi JudÃĄ. 
\q1  
\v 9 NiÉĄĖķida gela anejigotaÉĄĖķawatiwaji me idinilakidetaÉĄĖķagi 
\q1 aliciagi niÉĄĖķijo oxiiÉĄĖķodi 
\q1 anejigota me idinilakidetege jotigide ÉĄĖķadaamipi, 
\q1 niÉĄĖķijo noko naÉĄĖķa jibatigi libaaÉĄĖķatedi me jadeegiticogi wetice niiÉĄĖķo Egito. 
\q1 Pida aÉĄĖķowo niÉĄĖķijo ane igegi me idinilakidetege, 
\q1 joaniÉĄĖķidaa leeÉĄĖķodi naÉĄĖķa jikaticoaceâ, 
\q1 eledi mee ĮĪoniotagodi AneotedoÉĄĖķoji. 
\q1  
\v 10 âNigicotalo nokododi, 
\q1 nigicota me idinilakidetacege loiigi Israel, 
\q1 jiÉĄĖķidaaÉĄĖķeeâ, 
\q1 eleditace mee ĮĪoniotagodi AneotedoÉĄĖķoji. 
