\id HEB - Ikwerre 
\h Ele Hiburu 
\toc1 Ọkwukwo izi Ele Hiburu 
\toc2 Ele Hiburu 
\toc3 Hib 
\mt2 Ọkwukwo izi 
\mt1 Ele Hiburu 
\imt1 Nhne gbasịri ọkwukwo izi ka 
\im \bk Ọkwukwo izi Ele Hiburu\bk* bụ ke be gbaznennu ele Karaịsi ele be neemegidne, ele zị nụ ogwnu nụ be jaaghasa ọkwnata mkpọma nụ Karaịsi. Nye gbarụ ọkwukwo ka naakanụ be nụ Jizọsi Karaịsi bụ ezi oyiyi Chiokike n'iwhuru a. O neegesi nhne ka, ke mbọm, Jizọsi bụ Nnwọ Chiokike ke zị ọkwnukokwnu, nye mụhiaru obno nsnị hite n'awhnụwhnu ọ gawheru. Lele Nnwọ Chiokike, Jizọsi kakwo kpakara ele ọwhnurninya ke Tẹsitamenti Ọknani, ma ele enine izi, ma Mozizi n'iwhuru a. Ke ẹbo, Chiokike karụ nụ Jizọsi bụ nye arịohna, nye ọbula ke kweru nụ ya, jeenwehịa ọznohia nụ mmehie. 
\ip Nye gbarụ ọkwukwo izi ka kwuru ọka gbasịri ele dikne ke ọkwnata ovu, ele gwuzoru kwem dụ n'ẹnwu. Be lekwasịri Jizọsi anya, nụ ruwhnu awhnụwhnu nụ ọkpagbu be kpagburu be. O jiri ọdo aka nụ nsnị nụ ezni mesni ọkwukwo izi a. 
\iot Nhne zị n'ọkwukwo izi ka 
\io1 Karaịsi bụ oyiyi Chiokike zuru ozu \ior (1:1-3)\ior* 
\io1 Karaịsi kakwo ele enine izi \ior (1:4---2:18)\ior* 
\io1 Karaịsi kakwo Mozizi nụ Josụa \ior (3:1---4:13)\ior* 
\io1 Karaịsi bụ nye risi arịohna kakwo \ior (4:14---7:28)\ior* 
\io1 Ọgba-njọ-ẹhni Karaịsi kakwo \ior (8:1---9:22)\ior* 
\io1 Arịohna Karaịsi kakwo \ior (9:23---10:39)\ior* 
\io1 Ọkwnata mkpọma bụ risi nhne \ior (11:1---12:29)\ior* 
\io1 Mee nhne jọoso Chiokike n'ọnu \ior (13:1-17)\ior* 
\io1 Okpukpe nụ ọka ipne-aznụ \ior (13:18-25)\ior* 
\c 1  
\s1 Nnwọ a kakwo  //  ele ọwhnurninya 
\p  
\v 1 N'ige wheru ewhe, Chiokike kwunnu ele nda aị ọknani ọka agịda ige hite n'ọnu ele ọwhnurninya n'apna zị ichne ichne.  
\v 2 Kọvu kịtna, n'ọbochi ipne-aznụ ka, o kwunnu aị ọka hite n'ọnu Nnwọ a Jizọsi, bụ nye ọ họhiaru ma ọ bụru nye jeeri kpakara mkpe, nye o hiri n'aka a kpụ ọwa.  
\v 3 O nwernu igwugwu Nda a. Nnwọ wam bụ nhne Nda a bụ. O ji ikwu-ọnu a ke nwernu iknernema jigidne kpakara nhne. O jiri aka a snụsnama mmehie ọwa. Nga o mekworu ka, ọ dazịri ẹli n'akarikwnunga Chiokike n'oligwe, nye kakwo kpakara nhne n'olu. 
\s1 Nnwọ Chiokike kakwo  //  ele enine izi 
\p  
\v 4 Nnwọ wam kakwo ele enine izi lele kpa rẹwhna a “Nnwọ,” ke Chiokike nyernu a kakwo rẹwhna be. 
\p  
\v 5 Kwnornu nụ ọ zá enine izi ọbula ke Chiokike kannụ, 
\q1 “Ji bụ Nnwọ m. 
\q2 M ghọlam Nda ị tna.” 
\m Mọbu, ọ zị́ masị enine izi ke Chiokike kannụ, 
\q1 “M jọoburunu ị Nda, 
\q2 ị jọoburu Nnwọ m.” 
\p  
\v 6 Nga Chiokike neeziya Nnwọ a nụ rime ọwa, ọ kaa, 
\q1 “Kpakara ele enine izi Chiokike kpọnu a risi ẹli.” 
\p  
\v 7 Ka bụ nhne Chiokike kwuru gbasịri ele enine izi, 
\q1 “Chiokike mernu ele enine izi a lele ruwhere, 
\q2 ele izi a lele bẹkwnu neerne erne.” 
\p  
\v 8 Kọvu nhne gbasịri Nnwọ wam, Chiokike karụ, 
\q1 “Chiokike, ngadna eze i jaazị tim tọm, 
\q2 Mkpara ẹli-eze i bụ ikpe zị snam. 
\q1  
\v 9 Ị whnụrnu nhne ọma n'anya, sno nhne ọjo irno, 
\q2 kam kpayarụ, Chiokike, bụ Chiokike i teru i mọno ovu ọso n'ọnu, 
\q2 bịta ị nụ hne kakwo kpakara ele ibne i.” 
\p  
\v 10 Ọ kaa, 
\q1 “Jị Jihova, ị tụru ntụ-ẹli ọwa hite nụ mbọm. 
\q2 I ji aka ị lawụru kpụ oligwe. 
\q1  
\v 11 Kpakara be joowhu, kọvu ị jaazị ọkwnukokwnu. 
\q2 Be jaaka bụka lele iwo. 
\q1  
\v 12 Ị jaapịakota be lele iwo olu, 
\q2 be jaagbanwo be lele ikpe, 
\q1 kọvu ị zị kpa ị zị nụ mbọm, 
\q2 ọnu ọgwnugwnu awha ị jéebi ebi.” 
\p  
\v 13 Ọ zá enine izi ọbula ke Chiokike kannụ, 
\q1 “Dazịri ẹli n'akarikwnunga m 
\q2 tem dụ nga me jaabịta ele irno i 
\q1 lele nhne ị jọotukwasi ọchi ị lawụru.” 
\m  
\v 14 Ele enine izi, kpakara be bụ́o ele o ziyaru o yinu ele jeekehịa ọznohia aka sa? 
\c 2  
\s1 Okne ọznohia wam 
\p  
\v 1 Kam kpayarụ, a jigidne ezi ọka wam a nụrnu aka rikne, ọ zị be vume aị lele kpa mini noovume ọgbo.  
\v 2 Ọ bụru nụ ikwu-ọnu ele enine izi kwuru gwuzosiri rikne, kpakara mmehie nụ risi rikne nahịaru ọgwo ẹrnu awhnụwhnu kwesiri be,  
\v 3 ndaa kpa a jaagbanahọru, ọ bụru nụ a lewhuru okne ọznohia hna kpa anya? Ọ bụ ke Nyenwe aị n'iwhuru a beru ọsno zni, ele nụrnu a kannụ aị nụ ọ bụ ezi ọka.  
\v 4 Chiokike gbannụ be akebne hite nụ ẹrnu elekema zị ichne ichne ke rikne, nụ ẹrnu ndu-ẹhni, nụ ẹrnu rikne zị ichne ichne. Ọ gba masịri akebne nga o nyernu ele badnụ nkesi ke Enine Nsọ lele kpa ọ masịri a. 
\s1 Jizọsi nụ lele rụmu nne a 
\p  
\v 5 Berere kwno, Chiokike bị́tage ele enine izi ele jaachị ọwa ke jaava, bụ ọwa ke a nookwu ọka a.  
\v 6 Kọvu be kwuru n'otu hnenum n'ọkwukwo nsọ, 
\q1 “Kịni bụ nhne badnụ etekne bụ, ke ị naarị ọriri gbasịri a, 
\q2 nụ nnwọ ke badnụ ke i neelekọta a? 
\q1  
\v 7 I mernu a o hietu ẹli matị karụ ele enine izi. 
\q1 I jiri igwugwu nụ ọson'anya kpusi a nụ risi lele okpu-eze. 
\q2  
\v 8 I mernu a nye risi kpakara nhne.” 
\m Ka neegesi nụ ọ zá nhne ọ sịgbasiri ọ bịta nụ mkpururu ọchi a. Kọvu kịtna, a whnụ́ge nụ kpakara nhne ka zị nụ mkpururu ọchi a.  
\v 9 Kọvu a whnụrnu Jizọsi, nye o mernu hietu ẹli matị karụ ele enine izi. O jiri igwugwu nụ ọson'anya kpusi a nụ risi lele okpu-eze kwnornu nụ ọ nwụrnu ẹnwu. Hite n'oru Chiokike, o ratụru ẹnwu riro kwnornu kpakara badnụ. 
\p  
\v 10 Chiokike nwe kpakara nhne, ya ke masịri kpakara nhne hite n'iknernema a. O mernu nhne kwesiri nga o mernu Jizọsi zu ozu hite n'awhnụwhnu, ma ọ znọhia agịda rụmu Chiokike, mee be snornu a kehịa igwe n'igwugwu a.  
\v 11 Kwnornu nụ nye bịtaru be nsọ nụ ele be bịtaru nsọ bụ otu ọro. Kam kpayarụ, o sukwu be rụmu nda a zá nọotu a iwhnerne.  
\v 12 Ọ karụ, 
\q1 “M jookwupịya rẹwhna ị n'esilawụru rụmu nda m, 
\q2 m jaaznarnị ị n'esilawụru ọgbako Chiokike.” 
\p  
\v 13 Berere kwno, 
\q1 “M jọotukwasi a ovu,” 
\m o kwu kwno, 
\q2 “Le me nụ rụmu Chiokike nyernu m.” 
\p  
\v 14 Lele rụmu o sukwuru vugwu anọ-ẹhni nụ ọvnarna, Jizọsi ghọru badnụ ke vugwu anọ-ẹhni nụ ọvnarna ke nwernu rikne nwụ ẹnwu, ma hite n'ẹnwu a, o megbu nye wam bụ Ekwensu ke nwernu rikne ẹnwu,  
\v 15 ma ọ dọhia ele zị n'ọhi kpakara bụdnu be n'ogwnu ẹnwu.  
\v 16 Kwnornu n'ezi, Jizọsi váge o yinu ele enine izi aka, kọvu rụmu avnụrnu Ebereham.  
\v 17 Kam kpayarụ, ọ zị mkpa Jizọsi nụ lele rụmu nda a nụ apna ọbula, ma ọ bụru nye risi arịohna ke nwernu mkpọma obirizi kwesiri ọkwnata ovu nụ ruwhnu Chiokike, ọ bụru masị nye mernu badnụ nụ Chiokike zịri n'udno hite nụ ọgbaru mmehie.  
\v 18 Kwnornu nụ o tarụ awhnụwhnu nga be rnarnụ a ọrnurna, o nwernu rikne yisinu ele be naarna ọrnurna aka. 
\c 3  
\s1 Jizọsi kakwo Mozizi 
\p  
\v 1 Kam kpayarụ, rụmu nda m, ele zị nsọ, ele vu osukwu ikwu oligwe, anụ rị ọriri nhne gbasịri Jizọsi, nye izi, nụ nye risi arịohna ke ọkwnata ovu aị.  
\v 2 Ọ bụ nye kwesiri ọkwnata ovu nyee nye họhiaru a, lele kpa Mozizi bụri nye be tụkwasiri ovu nụ kpakara ẹrnu a n'ọro Chiokike.  
\v 3 Jizọsi kwesiri o nwe igwugwu ke kakwo igwugwu Mozizi lele kpa nye wuru ọro nwernu igwugwu karụ ọro o wuru.  
\v 4 Kwnornu nụ kpakara ọro nwernu nye wuru a, kọvu Chiokike wuru kpakara nhne.  
\v 5 Mozizi, lele nnwọ izi be kwesiri ọ tụkwasi ovu nụ kpakara ọro a, gbarụ akebne nhne be jookwu nụ ruwhnu.  
\v 6 Kọvu Karaịsi kwesiri ọkwnata ovu lele nnwọ n'ọro Nda a. A bụ ọro a, ọ bụru a bịta mkpọma siri rikne aị, gwuzosi masị rikne nụ nhne a neele anya a. 
\s1 Ozukwa inwe ke rụmu  //  Chiokike 
\p  
\v 7 Lele kpa Enine Nsọ karụ, 
\q1 “Tna, ọ bụru nụ anụ nụrnu nkọli a, 
\q2  
\v 8 anụ mée ovu anụ si rikne, 
\q1 lele kpa ele Izirẹli mernu nga be gwuzogidnernu Chiokike, 
\q2 ige ọrnurna n'ẹli-ịkpa. 
\q1  
\v 9 Nga ele nda anụ ọknani kparụ m iru, kpahịa m, 
\q2 be whnụrnu ẹrnu m nri awha ẹno. 
\q1  
\v 10 Ovu weru m ẹhni kwnornu ebiri kam, 
\q2 m kaa, ‘Mkpọma be noowhu apna, 
\q2 be kwége ọ bịta iwu m.’ 
\q1  
\v 11 Kam kpayarụ, m ji m ovu owe ẹhni dụ risi, kaa, 
\q2 ‘Be jáabna hne me jeenye be ozukwa inwe.’ ” 
\p  
\v 12 Rụmu nda m, anya dụ anụ ẹli, ọ zá nye ọbula n'esilawụru anụ ke jeenwe ovu mmehie ke kwé ekwe ke jeeme a ọ whọga nụ hne Chiokike ke zị bụdnu zị.  
\v 13 Kọvu anụ kwnagidne ibne anụ hnebụko ọbochi be kwuru “Tna.” Ọ zá nye kwe aghịgho ke mmehie mee ovu a si rikne megidne Chiokike.  
\v 14 Kwnornu nụ ọ bụru a jidne ọkwnata mkpọma a nwernu nụ mbọm dụ okwukwo, aị nụ Karaịsi jeekekọ nhne.  
\v 15 Lele kpa be gbarụ n'ọkwukwo nsọ, 
\q1 “Tna, ọ bụ nụ anụ nụrnu nkọli a, 
\q2 anụ mékọ ovu anụ si rikne 
\q1 lele kpa ele Izirẹli mernu nga be gwuzogidnernu Chiokike.” 
\p  
\v 16 Ndaa ele nụrnu nkọli Chiokike mee risi rikne? Ọ bụ́o ele Mozizi hiri n'ẹli Ijipiti duhịa sa?  
\v 17 Ndaa ele Chiokike wesanụ ovu ẹhni nri awha ẹno? Ọ bụ́o ele mehieru, bụ ele iznu be dnarnụ n'ẹli-ịkpa?  
\v 18 Ndaa ele Chiokike dụru risi nụ be jáabna nụ hne o jeenye be ozukwa inwe? Ọ bụ́o ele bnóge nsnị?  
\v 19 A whnụrnu nụ be bnáge hne o jeenye be ozukwa inwe kwnornu nụ ókwe ekwe be. 
\c 4  
\p  
\v 1 Chiokike kweru aị mkwna ọ bna n'ozukwa inwe a, mkwna wam noogwuzo kwem, anụ ngwa ma a tụ ogwnu, ọ zị otu nyenum n'esilawụru anụ ba adna nụ ọ bna nụ rime a.  
\v 2 Kwnornu nụ be znirni aị izi ọma lele kpa be znirni be. Kọvu izi be znirni be bnágene be nụ nhne, kwnornu nụ ele nụrnu a jíle ọkwnata ovu naahọru a.  
\v 3 Kịtna aị ele kweru bnarnụ n'ozukwa inwe a lele kpa Chiokike kwuru, 
\q1 “M ji m ovu owe ẹhni dụ risi, 
\q2 be jáabna hne me jeenye be ozukwa inwe.” 
\m O kwuru ka, ọ bụ n'ezi nụ ẹrnu wam kwolem kpa ọ tụru ntụ-ẹli ọwa.  
\v 4 O kwuru ọka gbasịri ọbochi ke ẹsau n'otu hnanụm, “Chiokike zukwaru inwe n'ọbochi ke ẹsau nụ kpakara ẹrnu a.”  
\v 5 Nụ hnam kwno, ọ kaa, “Be jáabna n'ozukwa inwe m.” 
\p  
\v 6 A whnụrnu nụ ozukwa inwe zịnu ele ke Chiokike. Kọvu, ele nụrnu izi ọma wam nụ mbọm bnáge n'ozukwa inwe wam kwnornu n'ókwe ekwe be.  
\v 7 Chiokike bịtaru ọbochi berere ele badnụ ji naabna n'ozukwa inwe a, kwu a “Tna.” Nga agịda awha whemernu, o hi n'ọnu Devidi kwu lele kpa o kwuru nụ mbọm, 
\q1 “Tna, ọ bụru nụ anụ nụrnu nkọli a, 
\q2 anụ mée ovu anụ si rikne.” 
\p  
\v 8 Kwnornu nụ ọ bụru nụ Josụa duru be bna n'ozukwa inwe, Chiokike bó kwule ọka gbasịri ọbochi ozukwa inwe berere.  
\v 9 Ka neegesi nụ ozukwa inwe berere zịnu rụmu Chiokike lele kpa Chiokike zukwaru inwe kpa o kekworu ọwa n'ọbochi ke ẹsau.  
\v 10 Nye ọbula ke bnarnụ n'ozukwa inwe ke Chiokike, noozukwa inwe nụ kpakara ẹrnu a lele kpa Chiokike zukwaru inwe n'ẹrnu a.  
\v 11 A yisi ẹhni ma a bnazne n'ozukwa inwe a, ọ zị nye ọbula ba adna kwnornu nụ ókwe ekwe lele kpa rụmu Izirẹli dnarnụ. 
\p  
\v 12 Ikwu-ọnu Chiokike zị bụdnu nọornusi ẹrnu rikne. Ọ zị bụko kakwo ama-ọgwnu ruwhnu lawụru. Ọ nọodubna, neekewa mkpụru ovu nụ enine, ma ọkpukpu nụ ọmio. Ọ nọotupiya echiche ovu nụ agwa ke badnụ.  
\v 13 Ọ zá nhne be keru eke ke tugwaru otugwa n'anya Chiokike, kpakara nhne gbe anya n'anya nye wam a jaasa ajịji gbasịri ẹhni aị. 
\s1 Jizọsi bụ nye risi arịohna 
\p  
\v 14 Hne a nwernu nye risi arịohna hna ezi kpa, nye beru ọsno zne nụ ruwhnu Chiokike n'oligwe, Jizọsi Karaịsi Nnwọ Chiokike, a jidnesi okwuhịa ke ọtukwasi ovu aị aka rikne.  
\v 15 Kwnornu nụ a nwée nye risi arịohna ke nhne gbasịri aị zá neemetụ n'ovu, kọvu a nwernu nye risi arịohna nye be kparụ iru n'apna ọbula lele aị, kọvu o méne mmehie.  
\v 16 Ngwa ma a gweru ovu siri rikne vadu ngadna oru ke Chiokike ma a nahịa obirizi nụ oru jeeyinu aị aka n'ige mkpa. 
\c 5  
\p  
\v 1 Nye risi arịohna ọbula bụ nye be họhiaru n'esilawụru ele badnụ, be bịta a ichne ma ọ dnasni anya badnụ nụ ruwhnu Chiokike, naakwanụ be arịohna nụ nkesi kwnornu mmehie.  
\v 2 O nwernu rikne gweru ovu ọma mesno ele nwée rikne nụ ele máa nhne n'apna ọbula, kwnornu nụ ya n'iwhuru a zá rikne.  
\v 3 Kam kpayarụ, ọ naakwa arịohna kwnornu mmehie ke a, nụ ke ele berere.  
\v 4 Ọ zá nye gweru igwugwu o chni ẹhni a nye risi arịohna, kọvu nye Chiokike sukwuru lele kpa o sukwuru Erọni.  
\v 5 Kpam masị, Karaịsi nyége ẹhni a igwugwu ke nye risi arịohna. Kọvu Chiokike kwuru nhne gbasịri a, 
\q1 “Jị bụ Nnwọ m, 
\q2 M ghọlam Nda ị tna.” 
\m  
\v 6 Chiokike kwu kwno nụ hne berere, 
\q1 “Ị bụ nye arịohna ọkwnukokwnu, 
\q2 n'ahịri ke Mẹkizedeki.” 
\p  
\v 7 Nga Karaịsi zị bụdnu n'ọwa, o ji okne ẹkwna nụ anya-mini rịo arịrio a n'okpukpe nyee Chiokike, bụ nye nwernu rikne ọ dọhia a n'ẹnwu. Ọ nụrnu okpukpe a, kwnornu nụ o gwednarnụ ẹhni a ẹli.  
\v 8 Ọ bụ n'ezi nụ Jizọsi bụ Nnwọ Chiokike, kọvu, ọ mụhiaru obno nsnị hite n'awhnụwhnu ọ tarụ.  
\v 9 Nga be mernu a ọ zịri snam, ọ ghọru nye risi ọznohia ọkwnukokwnu ke kpakara ele joobno nsnị.  
\v 10 Chiokike mernu a ọ bụru nye risi arịohna n'ahịri Mẹkizedeki. 
\s1 Ọdnahala aznụ 
\p  
\v 11 A nwernu agịda nhne a jookwu gbasịri Karaịsi nye risi arịohna n'ahịri Mẹkizedeki, kọvu a jóokwu a kwnornu nụ anụ jéenwe rikne ghọhia be.  
\v 12 Kịtna, anụ kwesiri ọ bụru ele jeezni nhne, kọvu ọ zị kọriri mkpa be neezni anụ nhne mbọm ke ikwu-ọnu Chiokike. Ọ bụru nụ mini-rẹma bụ nhne anụ zị kọriri nọonwo, ọ bụ́o wiri siri rikne.  
\v 13 Kwnornu nụ nye ọbula ke nọonwo mini-rẹma bụ watakịri, o nwée rikne mahịa nhne ọma nụ nhne bụ́o ọma.  
\v 14 Wiri siri rikne bụ ke ele soru oso, bụ ele be znụrnu ọ mahịa nhne zị ichne nụ hne nhne ọma nụ nhne ọjo zị. 
\c 6  
\p  
\v 1 Ngwa ma a zne ruwhnu, a sịgbasi iznizni mbọm ke Karaịsi zne nụ ozu ozu, a zọ́ma ọ tụ ntụ-ẹli ọtuhnasna nụ mmehie berere hite n'ome nhne ke neegweya ẹnwu, kweru nụ Chiokike.  
\v 2 Ka bụ iznizni ke ọwu mini nụ ke ọbniakwasi aka nụ risi, nụ ke ohi n'ẹnwu lizọ, nụ ke ikpe zị ọkwnukokwnu.  
\v 3 Chiokike kwe, a jeeme nhne ka.  
\v 4 Ọ bụ nhne kwé omume nụ ele mahịaru iwhne ke Chiokike dnahnala, jeehiehna, bụ ele ratụru nkesi oligwe riro, bụ ele kehịaru igwe nụ rime Enine Nsọ.  
\v 5 Ele ka bụ ke ratụru nhne ọma ke ikwu-ọnu Chiokike riro ya nụ iknernema ke ọwa ke jaava,  
\v 6 be hi nụ ya dnahnala. Ọ bụ nhne jéekwe omume o kwuhnaya be, ọ nụ lele be nọokpogidne Nnwọ Chiokike n'olu ọgba berere, naakpasị a iwhnerne nụ ruwhnu ọhna. 
\p  
\v 7 Ẹli ke nwọrnu mini ke noozokwasi a, naamịpiya mkpụru ke bnannụ ele ẹkwu iru, ọ nahịa ngọzi Chiokike.  
\v 8 Kọvu ẹli ke nooru igwnu nụ akịkara bnáge iru ọbula. Be jọovu a ọnu, n'ipne-aznụ, bẹkwnu jeerne a. 
\p  
\v 9 Kọvu ele me whnụrnu n'anya, ọ bụ n'ezi a nookwu kpa, a tụkwasiri ovu nụ nhne kakwo mma gbasịri anụ, bụ ngọzi ke ọznohia nụ mmehie.  
\v 10 Chiokike zá neeme nhne ọjo. O jéechezu ẹrnu anụ ya nụ ọwhnun'anya anụ gesiri rẹwhna a, zị kọriri neegesi hne ele ke Chiokike zị.  
\v 11 A noopio ma nye ọbula mee kọriri kpam dụ okwukwo, ma olile anya anụ zịri kwem.  
\v 12 A píole anụ bụru ele ime-mgwụ, kọvu anụ nụ lele ele kweru ekwe nwe masị ndidi tem dụ ọ nahịa mkwna Chiokike kweru. 
\s1 Mkwna Chiokike zị kwem 
\p  
\v 13 Nga Chiokike kweru Ebereham mkwna, o jiri ẹhni a dụ risi kwnornu nụ ọ zá nye berere kakwo a.  
\v 14 Ọ kaa, “N'ezi ọka, m jọogozi ị, nyee i ọbuba masị.”  
\v 15 Ebereham jiri ogologo nkasi ovu nwehịa mkwna wam Chiokike kweru a. 
\p  
\v 16 Ele badnụ neeji nye kakwo be dụ risi, neemesi ọka be rikne, kam bụru mbimambi ọka nụ ọdogbuta.  
\v 17 Chiokike, ma o gesi ele jeekehịa mkwna, nụ ọ jáagbanwo mkwna wam, jiri rẹwhna a dụ risi.  
\v 18 Chiokike nyernu aị mkwna a nụ ọ dụ risi a, nhne lawụru ka gbánwo agbanwo kwnornu nụ Chiokike jáagha aghalaghala, aị ele gbaznernu jigidne olile anya ke zị nụ ruwhnu aị aka ọ zị inwe gwụ aị.  
\v 19 A nwernu olile anya ka lele nkno ke mkpụru ovu, ke zị jịi nụ kwem, ke dubnarnụ aị n'aznụ ikpe obnosni nụ rime hne zị nsọ,  
\v 20 hne Jizọsi beru aị ọsno bnazne, bụru nye risi arịohna ọkwnukokwnu n'ahịri Mẹkizedeki. 
\c 7  
\s1 Mẹkizedeki, nye arịohna 
\p  
\v 1 Mẹkizedeki ka bụ eze Salẹm, nye arịohna ke Chiokike ke Kakwo Nhne Dum Olu. O zuteru Ebereham nga o hiri ọgwnu ke o gburu ele eze neehiehna, ọ gọzi Ebereham.  
\v 2 Ebereham nyee a otu nga nụ nri nga kpakara nhne o gweyarụ. Rẹwhna a ke mbọm bụ “Eze Ome Mma,” ke ẹbo bụ “Eze Salẹm,” ke bụ “Eze Udno.”  
\v 3 Ọ zá ọtnutnu gbaka gbasịri nda a mọbu nne a, mọbu avnụrnu a, ọmumu a, mọbu ẹnwu a, lele Nnwọ Chiokike, ọ bụ nye arịohna ọkwnukokwnu. 
\p  
\v 4 Le nye kwu ka, ke nda aị Ebereham nyegarụ a otu nga nụ nri nga kpakara nhne ọ lụhiaru n'ọgwnu.  
\v 5 N'ezi ọka, iwu karụ rụmu Livaị ele arịohna nahọru rụmu nda be otu nga nụ nri nga. Ọ bụ n'ezi nụ be bụ rụmu Ebereham.  
\v 6 Kọvu Mẹkizedeki híge nụ avnụrnu Livaị, kọvu ọ nahọru Ebereham otu nga nụ nri nga, gọzi masị nye wam nahịaru mkwna Chiokike.  
\v 7 N'ezi, nye wam ke gọziri kakwo nye wam ọ gọziri.  
\v 8 Hna, badnụ etekne ke jọonwu ọnwu nanarnụ otu nga nụ nri nga. Kọvu hne berere, Mẹkizedeki nye be gbarụ akebne nụ ọ jaazị tem nanarnụ otu nga nụ nri nga.  
\v 9 A jaakaa nụ nga Ebereham kwụru otu nga nụ nri nga, nụ Livaị nye nanahọru otu nga nụ nri nga kwụru ke a masị nụ rime Ebereham,  
\v 10 kwnornu nụ Livaị zị nụ rụwho Ebereham nda a nga Mẹkizedeki zuteru Ebereham. 
\s1 Jizọsi bụ nye arịohna  //  lele Mẹkizedeki 
\p  
\v 11 Be nyernu ele Izirẹli iwu hite n'ele arịohna Livaị. Ọ bụru nụ iwu ke mernu rụmu Livaị bụru ele arịohna mernu badnụ zu ozu, ọ zá mkpa nụ nye arịohna berere jaava n'ahịri Mẹkizedeki, bụ́o n'ahịri Erọni.  
\v 12 Kwnornu nụ kpa be gbanwornu ele arịohna, kpam masị bụ kpa be jiri gbanwo iwu kam.  
\v 13 Nye a nookwu ọka bụ Nyenwe aị, nye hiri n'avnụrnu berere, ọ zá nye ọbula ke hiri n'avnụrnu kam bụ nye ọkwa arịohna.  
\v 14 A magwụ nụ Nyenwe aị hiri nụ avnụrnu Juda whụya, bụ ele Mozizi kwúge nhne ọkwa arịohna gbasịri be. 
\p  
\v 15 Ka dnornu aị anya nkarị nkarị, kwnornu nụ nye arịohna berere whụyaru lele Mẹkizedeki.  
\v 16 Ọ bụ́o nye arịohna hite n'iwu ke osnusno ọmumu ke badnụ, kọvu ọ bụ nye arịohna hite nụ iknernema bụdnu ke kwó okwo.  
\v 17 Kwnornu nụ ọkwukwo nsọ karụ kpa, 
\q1 “Ị bụ nye arịohna ọkwnukokwnu, 
\q2 n'ahịri Mẹkizedeki.” 
\p  
\v 18 Be sịgbasiri iwu ọknani kwnornu nụ ọ zá rikne, ọ bnáge iru ọbula,  
\v 19 kwnornu nụ ọ zá nhne ke iwu mernu ozu ozu. Kọvu a nwernu olile anya ke ka mma ke a jeeji vadu Chiokike ndụndu.  
\v 20 Chiokike dụru risi gbasịri a, ele berere bụru ele arịohna hne be dụ́ge risi.  
\v 21 Jizọsi bụ nye arịohna Chiokike dụnnu risi, kwu masị nhne gbasịri a, 
\q1 “Jihova dụru risi, 
\q2 ọ jáalahna aznụ, 
\q1 ‘Ị bụ nye arịohna ọkwnukokwnu.’ ” 
\p  
\v 22 Kwnornu ọdu risi ka, Jizọsi bụ mbimambi ke ọgba-njọ-ẹhni ke kakwo mma. 
\p  
\v 23 Ele arịohna wam zị agịda kwnornu nụ be nwụrnu ọnwu ke mernu be nwée rikne dazịgidne lele ele arịohna.  
\v 24 Kọvu Jizọsi zị bụdnu ọkwnukokwnu, ẹrnu ke nye arịohna a zá naagbanwo agbanwo.  
\v 25 Kam kpayarụ, o nwernu rikne ọ znọhia kpam kpam bụ ele hiri n'aka a vakwnusi Chiokike, kwnornu nụ ọ zị bụdnu ọkwnukokwnu nọorionu be arịrio nụ ruwhnu Chiokike. 
\p  
\v 26 A nwernu nye risi arịohna nụ kpa, nye zị nsọ, nwée ntụbo, nye mmehie zị́la nụ rime, nye zị ichne hne ele badnụ ele mmehie zị, nye be gwelizọru olu kakwo kpakara oligwe.  
\v 27 Jizọsi nụ́na lele ele risi arịohna ele berere, ọ zá naakwa arịohna kpakara ọbochi kwnornu mmehie ke a nụ ke ele Izirẹli. Kọvu ọ kwarnụ otu arịohna kpọi ke zuru ọhna nga o gweru ẹhni a kwa arịohna.  
\v 28 Kwnornu nụ iwu mernu ele badnụ ele zúge ozu ele risi arịohna, kọvu ikwu-ọnu wam Chiokike jiri dụ risi ke sno iwu wam n'aznụ mernu Nnwọ wam nye zuru ozu ọkwnukokwnu. 
\c 8  
\s1 Jizọsi bụ nye risi  //  ọgba-njọ-ẹhni ikne 
\p  
\v 1 Ka bụ risi kpakara nhne a nookwu, a nwernu nye risi arịohna nụ kpa, nye dazị n'akarikwnunga ngadna eze Chiokike n'oligwe.  
\v 2 Nye arịohna nụ kpa zị nọornu ẹrnu nye arịohna nụ Hne Kakwo Nsọ n'oligwe, bụ ezi Ọro-Ẹka Nsọ ke Nyenwe aị wuru, ọ bụ́la badnụ.  
\v 3 Nye risi arịohna ọbula jaakwa arịohna nụ nkesi nụ ruwhnu Chiokike, ọ zị mkpa nụ nye ka jeenwerịri nhne o jeeji kwa arịohna.  
\v 4 Ọ bụru nụ ọ zị n'ọwa, ọ jọ́obu nye arịohna rịa rịa, kwnornu nụ agịda ele arịohna zị ele naakwa arịohna lele kpa Iwu Mozizi kwuru.  
\v 5 Be neezne izi n'Ọro Nsọ ke nhne atụ lele ke zị n'oligwe. Lele kpa Chiokike kannụ Mozizi nga o noowu Ọro-Ẹka Nsọ, “Whnụ nụ i mernu kpakara nhne lele kpa be gesiri ị be n'olu rugwu.”  
\v 6 Kọvu ẹrnu ọkwa arịohna ke Jizọsi kakpa ke ele rnụrnu ẹrnu nụ mkpururu iwu ọknani. Ọgba-njọ-ẹhni ke ọ gbarụ n'esilawụru Chiokike nụ ele badnụ kakwo mma, kwnornu nụ o gwuzogwu n'olu mkwna ke kakwo mma. 
\p  
\v 7 Ọ bụru nụ ọgba-njọ-ẹhni ke mbọm zuru ozu, mkpa ke ẹbo be znéne akpa aị.  
\v 8 Kọvu Chiokike whnụrnu nụ ele badnụ zúge ozu, ọ kaa, 
\q1 “Ọbochi vawa, bụ nhne Jihova kwuru, 
\q2 nga me nụ ọro Izirẹli nụ ọro Juda, 
\q2 jaagba njọ-ẹhni ikne. 
\q1  
\v 9 Ọ jọ́onu lele njọ-ẹhni, 
\q2 me nụ ele nda be gbarụ, 
\q1 n'ọbochi me jiri be n'aka m 
\q2 dọhia be n'ẹli Ijipiti, 
\q1 be kwnátala ovu nụ njọ-ẹhni wam me nụ be gbarụ, 
\q2 m lemernu m be anya, 
\q2 bụ nhne Jihova kwuru. 
\q1  
\v 10 Kịtna, ka bụ njọ-ẹhni me nụ ele Izirẹli jaagba 
\q2 nụ ọbochi ke jaava, bụ nhne Jihova kwuru. 
\q1 M jeeyisi iwu m nụ rime echiche be, 
\q2 m jaagbakwasị be n'olu mkpọma be, 
\q1 m jọoburu Chiokike be, 
\q2 be jọoburu ele ke m. 
\q1  
\v 11 Ọ zá nye n'esilawụru be ke jeezni ibne a, 
\q2 mọbu kanụ nwene a, ‘Mahịa Jihova,’ 
\q1 kwnornu nụ kpakara be jaamahịa m, 
\q2 hite nụ nye zị matị dụ nye ezi. 
\q1  
\v 12 M jaagbarụnu be ọgahie be, 
\q2 m jéechenwanya mmehie be berere.” 
\p  
\v 13 Hne o nookwu ọka ọgba-njọ-ẹhni ikne, Chiokike mernu ma ke mbọm zịri ọknani, nhne ọbula mernu ọknani jọodoka ọdoka, whume masị. 
\c 9  
\s1 Okpenu Chiokike n'ọwa 
\p  
\v 1 Ọgba-njọ-ẹhni ke mbọm ke Chiokike nụ rụmu Izirẹli gbarụ nwernu iwu osnusno okpukpe n'ọro nsọ ke ọwa. 
\p  
\v 2 Be wuru ọro okpukpe ke mbọm ke bụ hne zị nsọ. Nụ rime ọnu ọro ke mbọm, nhne zị nụ rime a bụ nhne be bịta tọnji nụ ikpechi nụ brẹdi arịohna Chiokike.  
\v 3 N'aznụ ikpe obnosni ke ẹbo bụ hne be kwu Hne Kakwo Nsọ.  
\v 4 Nhne zị nụ rime a bụ ojo golu ke isensi, nụ Igbe Ọgba-Njọ-Ẹhni be wọru golu. Nụ rime igbe wam, nhne zị a bụ otu ite golu mana, nụ mkpara Erọni ke warụ ọkwukwo nụ mbadamba akaworugwu lawụru ke be gbakwasịri iwu wam n'olu be.  
\v 5 N'olu igbe, ele enine izi be wụru ọwu zị igwugwu be kwu Cherubim gbasarụ akankwu be kpusnirni ikpechi oru. A jéenwe rikne kọwa kpa be kịtna. 
\p  
\v 6 Nga be bịta kworu kpakara nhne, ele arịohna naabna nụ hne zị nsọ kpakara ọbochi nọornu ẹrnu be.  
\v 7 Kọvu okwolem nye risi arịohna naabna nụ Hne Kakwo Nsọ n'aznụ ikpe obnosni wam otu mgba n'awha. O jeeji ọvnarna ke o jeeji kpusni mmehie ke a nụ mmehie ele Izirẹli mernu nụ ọ́ma ama.  
\v 8 Enine Nsọ neegesi kpa Ọro-Ẹka Nsọ ke mbọm nụ omen'ẹli a gwuzo kọriri, apna be jeeji naabna nụ rime Hne Kakwo Nsọ mesnirni emesni.  
\v 9 Ka bụ nhne neegesi n'ige ka, nụ nkesi nụ arịohna be jiri kwanụ Chiokike arịohna jéenwe rikne mee ele neegweya nkesi arịohna zu ozu.  
\v 10 Ka bụ wiri nụ manya nụ mmemem ke ọsnusna, kpakara omen'ẹli ele ka bụ nhne anya nọowhnu joogwuzo tem dụ ige Chiokike jaagbanwo be. 
\s1 Ọvnarna Karaịsi 
\p  
\v 11 Kọvu Karaịsi varụ lele nye risi arịohna nhne ke ka mma ke zị hna, Ọro-Ẹka Nsọ ke ọ nọornu ẹrnu nụ rime a kakpa, zu masị ozu. Ọ bụ́o ke be jiri aka wu, ọ bụ́o ke be keru eke n'ọwa ka.  
\v 12 Nga Karaịsi bnaznernu nụ rime Hne Kakwo Nsọ, ọ bnarnụ otu mgba kpọi. O jíle ọvnarna owu mọbu ke nnwọ ehni kwa arịohna, kọvu o ji ọvnarna ke a gbahịa kpakara aị ọkwnukokwnu.  
\v 13 Ọvnarna owu nụ ehni nụ nnwọ ehni nụ rẹtnu ke be wekwasịri ele zị́la rịchna mernu be zịri rịchna n'olu ẹhni.  
\v 14 Ọ kọ bụru ọvnarna Karaịsi, nye hiri n'Enine Nsọ ọkwnukokwnu gweru ẹhni a kwa arịohna nwée ọru nụ ruwhnu Chiokike, jọosnusnama akọniche aị whọga n'ẹrnu ọjo ke jaakpaya ẹnwu, ma a kpenu Chiokike ke zị bụdnu. 
\p  
\v 15 Kam kpayarụ, Karaịsi jiri bụru nye agbata ke ọgba-njọ-ẹhni ikne, ma ele Chiokike sukwuru nwehịa mkwna o kehịa nhne kwó okwo. Kwnornu nụ ọ nwụrnu ẹnwu ma ọ zị kpa ọ gbahịa be nụ rime awhnụwhnu ke mmehie be mernu nụ mkpururu ọgba-njọ-ẹhni ke mbọm. 
\p  
\v 16 Hne iwu oke mkpe zị, be jeegesiri nụ nye wam gbarụ a nwụrnu ọnwu.  
\v 17 Kwnornu nụ iwu oke mkpe bụ nhne etekne hne nye gbarụ a zị bụdnu, kọvu ọ jaabna n'ẹrnu nga nye gbarụ a nwụrnu ẹnwu.  
\v 18 Ka bụ nhne kpayarụ nụ ọgba-njọ-ẹhni ke mbọm jiri ọwusi ọvnarna gwuzosiri rikne.  
\v 19 Kwnornu nụ nga Mozizi kannụ ele Izirẹli kpakara nhne iwu wam kwuru, o gweru ọvnarna nnwọ ehni gwagidne a mini, gweru hisopu nụ wuulu ihie whesi n'ọkwukwo iwu wam nụ kpakara ele badnụ.  
\v 20 Ọ kaa, “Anụ bno nsnị, ka bụ ọvnarna ọgba-njọ-ẹhni ke anụ nụ Chiokike gbarụ, anụ bịta a.”  
\v 21 Kpam masị, o whesiri Ọro-Ẹka Nsọ ọvnarna nụ kpakara agbụgba nụ nhne be ji zne izi.  
\v 22 N'ezi ọka, ọ gwnarnụ matị ọvnarna mee kpakara nhne zịri snam n'iwu, kwnornu nụ hne be wụ́sage ọvnarna, ọgbaru mmehie zị́la. 
\s1 Arịohna Karaịsi  //  noovume mmehie 
\p  
\v 23 Kam kpayarụ, Ọro-Ẹka Nsọ ke ọwa ka nụ kpakara nhne zị nụ rime a, bụ oyiyi nhne zị n'oligwe, bụ nhne be jeeji ọvnarna nọosnu, kọvu nhne ke oligwe n'iwhuru a pioru arịohna ke kakwo mma karụ ọvnarna anọhia.  
\v 24 Kwnornu nụ Karaịsi bnáge nhne zị nsọ be jiri aka wu, ke bụ oyiyi ke ọkwnamarna nhne. Kọvu ọ bnaznernu oligwe hne o gwuzo nụ ruwhnu Chiokike nụ risi aị.  
\v 25 Nye risi arịohna ele Ju naabna Hne Kakwo Nsọ otu mgba n'awha gweru ọvnarna anọhia. Kọvu Karaịsi znége o ji ẹhni a kwa arịohna agịda ige.  
\v 26 Ọ bụru kpam, Karaịsi znernu ata awhnụwhnu agịda ige hite n'ọpanizo okike ọwa. Kọvu ọ whụyaru otu mgba kpọi kwnornu aị n'okwukwo ige ka, gweru ẹhni a kwa arịohna ma o vume mmehie.  
\v 27 Ka bụ ezi ọka, badnụ jọonwuriri otu mgba, omekwo, ikpe Chiokike sno a.  
\v 28 Kpam masị, be jiri Karaịsi kwa arịohna otu mgba o vume mmehie agịda ele badnụ, ọ jaava ke mgba lawụru znọhia ele neele anya a hne mmehie zị́la a. 
\c 10  
\s1 Karaịsi kwarụ arịohna  //  zuru ọhna otu mgba 
\p  
\v 1 Iwu wam bụ enine nhne ọma ke jaava, ọ bụ́o nhne wam, kam kpayarụ, o nwée rikne hite nụ arịohna ke be naakwa ige ọbula mee ele naava ọ kpọ risi ẹli zu ozu.  
\v 2 Ọ bụru nụ ele neekpenu Chiokike zị rịchna nụ rime ovu, ikpe mmehie ba mána be. Kpakara ọkwa arịohna znernu okwome.  
\v 3 Kọvu kpakara arịohna wam bụ nhne ke neechenwanyanụ be mmehie be hite n'awha dụ n'awha.  
\v 4 Kwnornu nụ ọvnarna ehni nụ owu nwée rikne vume mmehie. 
\p  
\v 5 Kam kpayarụ nga Karaịsi varụ n'ọwa, ọ karụ, 
\q1 “Arịohna nụ nkesi ruwhnu ọma másige i, 
\q2 kọvu ị bịtannu m anọ-ẹhni o bnonu ị nsnị. 
\q1  
\v 6 Ovu zá nọoso ị n'ọnu 
\q2 kwnornu arịohna ọkporne bẹkwnu mọbu arịohna mmehie. 
\q1  
\v 7 M kaa, ‘Chiokike, le, m valẹm 
\q2 o mee nhne i pioru me mee, 
\q2 lele kpa be gbarụ nhne gbasịri m n'ọkwukwo nsọ.’ ” 
\p  
\v 8 Ke mbọm, ọ karụ, i píole arịohna nụ nkesi ruwhnu ọma, mọbu arịohna ọkporne bẹkwnu mọbu arịohna mmehie, ọ bụ n'ezi nụ iwu wam karụ be mee kpam.  
\v 9 Ọ kaa, “Chiokike, le, m valẹm o mee nhne i pioru me mee.” O gwemernu nhne ke mbọm ma ọ zị kpa o gwuzote nhne ke ẹbo.  
\v 10 Kwnornu nụ Jizọsi Karaịsi mernu nhne Chiokike pioru o mee, ọ snụsnamarnu mmehie aị hite n'arịohna ke o jiri ẹhni a kwa otu mgba ke zuru ọhna.  
\v 11 Nye ọkwa arịohna ọbula noogwuzo kpakara ọbochi nọornu ẹrnu a, naakwa otu arịohna agịda ige. Kọvu kpakara arịohna ka nwée rikne noovume mmehie.  
\v 12 Kọvu nga nye arịohna ka kwarụ arịohna ke zị ọkwnukokwnu kwnornu mmehie, ọ dazịri ẹli n'akarikwnunga Chiokike.  
\v 13 Hite n'ige wam, ọ zị neese ige Chiokike jaabịta ele irno a lele nhne ọgbakwasi ọchi a.  
\v 14 Hite nụ otu arịohna, o mernu ele zị snam hite nụ mmehie zu ozu ọkwnukokwnu. 
\p  
\v 15 Enine Nsọ naagbanụ aị akebne ka hite nụ nhne o kwuru nụ mbọm, 
\q1  
\v 16 “Ka bụ njọ-ẹhni ke me nụ be jaagba, 
\q2 n'ọbochi ke jaava, bụ nhne Jihova kwuru, 
\q1 m jeeyisi iwu m nụ rime ovu be, 
\q2 m jaagbakwasị be n'echiche be.” 
\p  
\v 17 Ọ kaa kwno berere, 
\q1 “M jéechenwanya arụru-ẹli be, 
\q2 nụ mmehie be berere.” 
\p  
\v 18 Kịtna, ọ gbarụnnu be kpakara mmehie be, arịohna berere zá kwnornu mmehie.  
\v 19 Kam kpayarụ, rụmu nda m, a nwernu ovu siri rikne ọ bnazne nụ Hne Kakwo Nsọ hite n'ọvnarna Jizọsi.  
\v 20 Ọ gbamannụ aị apna ikne ke zị bụdnu hite n'ikpe obnosni wam ke bụ anọ-ẹhni a.  
\v 21 A nwernu nye risi arịohna ke kakwo, nye neelegidne ọro Chiokike anya.  
\v 22 Ngwa ma a gweru mkpọma zị rịchna nụ ezi ọkwnata ọvu, nụ ovu ikpe mána vakwnusi Chiokike, ya nụ ẹhni be jiri mini zị rịchna snụsnama.  
\v 23 Ngwa ma a knetasị olile anya ke ọkwnata ovu aị aka rikne, kwnornu nụ nye kweru aị mkwna jaabịta mkwna o kweru.  
\v 24 A gbalị mee nhne joovulizọ ọwhnun'anya n'ovu ibne aị hite n'ọrnu ẹrnu ọma.  
\v 25 A ghása ọgbako rụmu nda n'otu lele kpa agwna ele badnụ neeme. Kọvu a kwnagidne ibne aị ke kakwo kpa ọbochi wam naava ndụndu. 
\p  
\v 26 Ọ bụru nụ a jaazị kọriri neeme mmehie hne a nụrnu ezi ọka wam, ọ zá arịohna berere be jaakwa kwnornu aị.  
\v 27 Kọvu nhne ke gwnarnụ bụ olile anya ke tụ ogwnu ke ikpe, ya nụ ke okne bẹkwnu ke jeerne ele neemegidne Chiokike.  
\v 28 Nye ọbula ke dnarnụ Iwu Mozizi nwụrnu ẹnwu hne badnụ lawụru mọbu ẹto gbagidnernu a akebne, be dọ́nnu a obirizi.  
\v 29 Anụ le kpa ikpe wam jaazị rikne bụ awhnụwhnu nye wam jaata bụ nye lednarnụ Nnwọ Chiokike anya, nye kpọ́ge ọvnarna ọgba-njọ-ẹhni ke Chiokike nhne, ke snụsnamarnu mmehie a, nye lednarnụ Enine Nsọ ke oru anya.  
\v 30 Kwnornu nụ a magwụ nye karụ, “Mawa nwe mmegwnahịa, m jeemegwnarnụ.” Jihova kwuru berere, “Jihova jeekpe ele ke a ikpe.”  
\v 31 Ọ bụ nhne tụ ogwnu ọ dnabna n'aka Chiokike ke zị bụdnu. 
\p  
\v 32 Anụ chenwanya ọbochi ele ke wheru ewhe kpa anụ snụrnu ovu kpa iwhne Karaịsi mụkwasiri anụ nụ rime kpakara awhnụwhnu.  
\v 33 Agwna ige anụ bụru ele be kpasịri iwhnerne n'ọhna, ige berere anụ dasịri ele berere be neemegbu emegbu n'ikwnu.  
\v 34 Anụ dọnnu ele zị n'ikelu obirizi. Nga be nahọru anụ nhne anụ nwernu, ovu sọru anụ n'ọnu kwnornu nụ anụ magwụ nụ anụ nwernu ẹkwnu ke jaazị ọkwnukokwnu n'oligwe. 
\p  
\v 35 Anụ túwhu ovu osi rikne anụ, o jeenwe ọgwo ẹrnu zị agịda.  
\v 36 Anụ snụta ovu ma anụ nwernu rikne mee nhne Chiokike pioru, nahịa masị nhne o kweru nụ mkwna.  
\v 37 Kwnornu, 
\q1 “Ige matị, 
\q2 nye wam jaava bụ nye jaava, o jóogbu ọkwnu. 
\q2  
\v 38 Kọvu, nye mee mma ke m jeehi n'ọkwnata ovu zịri bụdnu, 
\q1 ọ bụru nụ nye ọbula lahna aznụ, 
\q2 nhne gbasịri a jọ́oso m ovu n'ọnu.” 
\p  
\v 39 Kọvu a bụ́o ele naalahna aznụ, whu etekne, a bụ ele kweru dụ n'ọznohia mkpụru ovu. 
\c 11  
\s1 Ele dikne ke ọkwnata ovu 
\p  
\v 1 Ọkwnata ovu bụ ọdnabnernu nụ nhne a neele anya, nụ ọtukwasi ovu nụ nhne ke a whnụ́ge anya zị.  
\v 2 Hite n'ọkwnata ovu, ele gbaka nahịaru ruwhnu ọma n'aka Chiokike. 
\p  
\v 3 Hite n'ọkwnata ovu, a ghọhiaru nụ Chiokike jiri ikwu-ọnu a ke ọwa, ke kpayarụ, nhne a nọowhnu anya hi nụ nhne a whnụ́ge anya whụya. 
\p  
\v 4 Ebelị jiri ọkwnata ovu kwanụ Chiokike arịohna ke ka arịohna Keni nwene a mma. Hite n'ọkwnata n'ovu a, Chiokike gbarụ akebne nụ ọ bụ nye mee mma kwnornu nụ Chiokike nahọru nkesi a. Hite n'ọkwnata n'ovu a, ọ zị kọriri nookwu ọka ọ bụ n'ezi nụ ọ nwụrnu ọnwu. 
\p  
\v 5 Hite n'ọkwnata ovu, Ịnoku nwụ́na ọnwu, kọvu Chiokike kwururu a nụ bụdnu, be whnụ́na a, kwnornu nụ Chiokike kwururu a. Kọvu sụ Chiokike kwururu a, be gbarụ akebne a nụ o mernu nhne sọru Chiokike ovu n'ọnu.  
\v 6 Hne ọkwnata ovu zị́la, be nwée rikne mee nhne jọoso Chiokike ovu n'ọnu. Kwnornu nụ nye jaavakwnusi Chiokike jeekwerịri nụ Chiokike zị, nụ ọ bụ nye nọokwu ele noopiosi a rikne ọgwo ẹrnu. 
\p  
\v 7 Hite n'ọkwnata ovu, Noa tụru ọgbo nga Chiokike dọru a aka nụ nsnị nhne ke zị nụ ruwhnu, ọ whnụ́na anya, ọ tụ ọgbo o jiri znọhia ele ọro a. Ọ marnụ ọwa ikpe, kehịa ome mma hite n'ọkwnata ovu. 
\p  
\v 8 Hite n'ọkwnata ovu, Ebereham bnornu nsnị nga Chiokike sukwuru a zne ẹli ke o jeekehịa nụ mkwna, ọ whọga neezne hne ọ máa.  
\v 9 Hite n'ọkwnata ovu, o wuru n'ẹli Chiokike kweru a mkwna lele nye izne. O wuru n'ọro-ẹka, ya nụ Aziki nụ Jekọpu, ele ya nụ be kehịaru otu mkwna wam.  
\v 10 Kwnornu nụ Ebereham neele anya ẹli ke nwernu ntụ-ẹli, ke Chiokike bụ nye nka nụ nye wuru a. 
\p  
\v 11 Hite n'ọkwnata ovu, Sera nahịaru rikne ọ tụ rime nga o wheru ige, ọ bụ n'ezi nụ o nwée nnwọ\f + \fr 11:11 \ft mọbu \fq hite n'ọkwnata ovu, Ebereham ghọru nda, ọ bụ n'ezi o mernu okno badnụ, Sera n'iwhuru a nwée nnwọ\f* kwnornu o karụ nụ ọ bụ nye kwesiri ọkwnata ovu bụ nye kweru mkwna.  
\v 12 Hite n'otu badnụ ka, Ebereham, ọ bụ n'ezi ọ nụ lele nye nwụrnu ọnwu, hne avnụrnu a hna lele mbọ ke oligwe nụ lele rịzna ke zị nụ ngeri osimini hna ke nwée ọnu ọgwnugwnu. 
\p  
\v 13 Kpakara ele ka nwụrnu nụ rime ọkwnata ovu. Be náhịage nhne Chiokike kweru mkwna, kọvu be whnụrnu be hite nụ hne zị ikere, gweru be, kwuhịa nụ be bụ ele izne nụ ele neewhe ewhe n'ọwa.  
\v 14 Nga ele badnụ nookwu kpa, ka neegesi nụ be neele anya ẹli ke aka be.  
\v 15 N'ezi ọka, ọ bụru nụ be naarị ọriri gbasịri ẹli ke be hiri whụya, be znernu alahna aznụ.  
\v 16 Kịtna, be neele anya ẹli ke ka mma, ẹli ke oligwe. Kam kpayarụ, iwhnerne zá neeme Chiokike ma be sukwu a Chiokike be, kwnornu nụ ọ bịtannu be otu ẹli. 
\p  
\v 17 Hite n'ọkwnata ovu, Ebereham gweru Aziki kwa arịohna nga Chiokike kparụ a iru. Nye wam nahịaru mkwna wam jiri otu nnwọ kpọi o nwernu kwa arịohna.  
\v 18 Ọ bụ n'ezi nụ Chiokike karụ, “Hite nụ Aziki, i jeenwe agịda rụmu.”  
\v 19 Ebereham kweru nụ Chiokike nwernu rikne mee Aziki hi n'ẹnwu lizọ, n'ezi ọka, ọ nahọru nnwọ a lele nye hi n'ẹnwu lizọ. 
\p  
\v 20 Hite n'ọkwnata ovu, Aziki gọziri Jekọpu nụ Isọ, nookwu ọka gbasịri ngọzi ke zị nụ ruwhnu.  
\v 21 Hite n'ọkwnata ovu, Jekọpu gọziri rụmu Josefu lawụru nga ọ nọonwu ẹnwu. Ọ dnabnernu nụ mkpara a kpọ risi ẹli nyee Chiokike. 
\p  
\v 22 Hite n'ọkwnata ovu, Josefu nga ọ nọonwu ẹnwu kwuru nhne gbasịri okwnehala ke rụmu Izirẹli n'ẹli Ijipiti, nyee be iwu gbasịri ọkpukpu a. 
\p  
\v 23 Hite n'ọkwnata ovu, ele mụrnu Mozizi tugwaru a ẹnwa ẹto kwnornu nụ ọ bụ nnwọ zị ichne, ogwnu iwu eze tụ́la be. 
\p  
\v 24 Hite n'ọkwnata ovu, Mozizi, nga o sopiyaru nụ badnụ, kwéle be sukwu a nnwọ adna Fero.  
\v 25 O snornu rụmu Chiokike ta awhnụwhnu kanụ a mma kakwo o nwe ovu ọso n'ọnu ke mmehie ige matị.  
\v 26 O gwnụrnu nhne iwhnerne ke Karaịsi nhne zị okne ọnu ahịa kakwo kpakara ẹkwnu ke Ijipiti, kwnornu nụ o neele anya ọgwo ẹrnu ke zị nụ ruwhnu.  
\v 27 Hite n'ọkwnata ovu, ọ sịgbasiri ẹli Ijipiti, ọ tụ́la ogwnu ovu owe ẹhni ke eze, kwnornu nụ o gwuzoru kwem lele nye whnụrnu Chiokike wam be whnụ́ anya, anya. 
\p  
\v 28 Hite n'ọkwnata ovu, o miteru Iriri Ọgawhe nụ ọvnarna be wesarụ ma enine izi ẹnwu wam ke gburu kpakara nnwọ mbọm be mụrnu gharụ o gbu nnwọ mbọm ele Izirẹli.  
\v 29 Hite n'ọkwnata ovu, rụmu Izirẹli wheru Osimini Ihie lele ẹli etekne, nga ele Ijipiti pioru ma be whe, mini riri be. 
\p  
\v 30 Hite n'ọkwnata ovu, oghiri mkpọ Jeriko dnarnụ, nga ele Izirẹli gbarụ a gburugburu ọbochi ẹsau. 
\p  
\v 31 Hite n'ọkwnata ovu, nwerinya ewhere Rehabụ zịri bụdnu, be gbúkọtala ya nụ ele irno Chiokike, kwnornu nụ o tugwaru ele znernu o nyokahịa ẹli wam. 
\p  
\v 32 Ndaa nhne me jookwu, kwnornu nụ ige zị́la me jookwu nhne gbasịri Gidiọni, nụ Barakị, nụ Samsịni, nụ Jẹfita, nụ Devidi nụ Samẹli, nụ kpakara ele ọwhnurninya.  
\v 33 Ele hiri n'ọkwnata ovu lugbu ẹli-eze, rnụ ẹrnu ọma, nahịa mkwna, kpusni ọnu odum,  
\v 34 kpachni bẹkwnu noonwu onwu, gbanahọru ama-ọgwnu, be nwée rikne, kọvu be ghọru ele dikne, ele dikne n'ọgwnu, chịhala ele ọgwnu ẹli berere.  
\v 35 Ele rinya nahịaru ele ke be hiri n'ẹnwu lizọ. Be tarụ ele berere awhnụwhnu, kọvu be kwéle be dọhia be, ma be lizọ n'ẹnwu ke ka mma.  
\v 36 Be mernu ele berere nhne rụmu, pnịa be hna, owe, be knernụ ele berere eriri, yisi be n'ikelu. 
\p  
\v 37 Be tụru be akaworugwu, be kwọbiri be ẹbo, be jiri ama-ọgwnu gbu be, be woru akpụkpo owu nụ atnụrnu gbagharị, be ghọ ele mboni, be kpakna be ẹhni, megidne be. 
\p  
\v 38 Ele ọwa kwésile ele ka. Be gagharị lele ele nwée ọro n'ẹli-ịkpa nụ rugwu matị, be wuru nụ rime mkpewu nụ ọnunu ẹli. 
\p  
\v 39 Kpakara ele ka nwernu ọtnutnu ọma kwnornu n'ọkwnata ovu be, kọvu be náhịage mkwna wam.  
\v 40 Chiokike bịtannu aị nhne ka mma. Chiokike mernu ma aị nụ be zukọta, ma a bụru ele zuru ozu n'otu. 
\c 12  
\s1 Chiokike naapnịa rụmu a  //  nhne 
\p  
\v 1 Kam kpayarụ, hne a nwernu agịda ele akebne gbarụ aị gburugburu, a tuwhu kpakara nhne ke noobnosni aị nụ mmehie ke naatakwnusi n'ẹhni aị, ma a gweru ọkasi mkpọma gba ẹso ke zị aị nụ ruwhnu.  
\v 2 A neelegidne Jizọsi anya, nye tụru ntụ-ẹli nụ nye mekwakworu ọkwnata ovu aị. Nye kwnornu ovu ọso n'ọnu ke zị a nụ ruwhnu lị nhne igbugbu ke ọgba, gweme iwhnerne, ọ dazịri ẹli kịtna n'akarikwnunga ngadna eze Chiokike.  
\v 3 Anụ tule nhne gbasịri nye wam ke lịri nhne igbugbu ke ọgba nụ omegidne ke ele mmehie, rikne bọ gwụ anụ, anụ dna n'apna.  
\v 4 Nụ rime ọgwnu anụ nọolu megidne mmehie, anụ yọ́oluge ọgwnu dụ n'ọwusa ọvnarna anụ n'ẹnwu.  
\v 5 Anụ chezuru ikwu-ọnu ọkasi ovu wam ke Chiokike nookwu anụ lele rụmu, 
\q1 “Nnwọ m, i lédna ọdo aka nụ nsnị ke Jihova anya, 
\q2 ovu lákwadia anụ mini nga o bigbọru anụ. 
\q1  
\v 6 Kwnornu nụ Jihova naata ele ọ whnụrnu n'anya awhnụwhnu, 
\q2 naapnịa nye ọbula o kwuru nnwọ a nhne.” 
\p  
\v 7 Anụ nabnarnụ awhnụwhnu anụ naata lele ọdo aka nụ nsnị ke nda nọodo rụmu a. Anụ whnụlele nnwọ ke nda a zá nọodo aka nụ nsnị sa?  
\v 8 Ọ bụru nụ Chiokike zá nọodo anụ aka nụ nsnị lele ele berere, anụ bụ́o rụmu a, kọvu anụ bụ rụmu ọyi.  
\v 9 Nda aị k'ọwa nọodo aị aka nụ nsnị, a noobnonu be nsnị. A kwesiri o bnonu Nda aị ke enine aị nsnị karụkwo ma a zịri bụdnu.  
\v 10 Nda aị k'ọwa naapnịa aị nhne ige matị n'ovu ọso n'ọnu be, kọvu Chiokike naapnịa aị nhne kwnornu mbnarna ke aị, ma a snornu a kehịa ọzi nsọ a.  
\v 11 Ọ zá ọdo aka nụ nsnị ọbula ke nọoso ọso n'ige wam, kọvu ọ zị igbugbu. Omekwo, ọ mịpiya ezi mkpụru ke ome mma nụ udno nụ rime ele gawheru nụ rime a. 
\p  
\v 12 Kam kpayarụ, anụ mee aka ke dnarnụ adna lizọ nụ mkpnerne ọchi ke nwée rikne gwuzoru kwem.  
\v 13 Anụ zne izne n'apna ke snịrni asnị ọ zị ele nwée ọchi ba dna n'apna, tnụnuma, be gwọ be. 
\s1 Ọ dọ aka nụ nsnị 
\p  
\v 14 Gbalị ma jị nụ kpakara ele badnụ zịri n'udno, zịri masị nsọ, kwnornu nụ ọ zá nye jọowhnu Chiokike anya sụ ọ zị́la nsọ.  
\v 15 Anụ whnụ nụ ọ zá nye dnahalaru n'oru ke Chiokike. Ọ zị nye nụ lele ẹgwnugwnu luga nlulu n'esilawụru anụ ke joovuyanu anụ mkpa, hite nụ a mejọ agịda badnụ.  
\v 16 Anụ whnụ nụ ọ zá nye neeme ọyi mọbu nye zá nọosonu Chiokike anya lele Isọ, nye kwnornu otu mgba wiri re ọnodi ọpnarna a.  
\v 17 Anụ mahịaru, omekwo, o pioru ọ nahọru ngọzi nda a, oghere zị́la kwnornu nụ o nwée rikne gbanwo nhne o mernu, ọ bụ n'ezi nụ o jiri anya-mini ẹkwna piosi ngọzi wam rikne. 
\p  
\v 18 Anụ váduge nụ rugwu ke anụ jeemetu aka, lele rugwu Saịna ke neerne bẹkwnu, nụ ọchichiri, okne ogwnu nụ okne ruwhere,  
\v 19 nụ ọdidna ke ọkwodu nụ ọdidna nkọli ke ele nụrnu a, rịasno nkọli wam kwúma berere.  
\v 20 Kwnornu nụ be gwúzolige iwu wam ke karụ, “Ọ bụbedi anọhia vadu rugwu wam metụ a aka, be gweru ara tugbu a.”  
\v 21 Nhne Mozizi whnụrnu zị okne ogwnu, ọ kaa, “Ogwnu tụru m, ẹhni nọoznu m biri biri.” 
\p  
\v 22 Kọvu anụ vaduru rugwu Zayọni, bụ Jerusẹlem ke oligwe, ẹli-ọhna ke Chiokike ke zị bụdnu, nụ ele enine izi, ọ zá nye nọogwnuli ọnu, ele neetne eri ọnwudna.  
\v 23 Anụ vadulem ọgbako Chiokike ke rụmu be beru ọsno mụ, ele be gbarụ rẹwhna be n'oligwe, vakwnusi masị Chiokike, nye neekpe kpakara ele badnụ ikpe, nụ enine ke ele ome mma zuru ozu.  
\v 24 Anụ vakwnusiri Jizọsi, nye ibno ke ọgba-njọ-ẹhni ikne, nụ ọvnarna ke owhesa, ke nookwu nhne ke ka mma kakwo ọvnarna Ebelị. 
\p  
\v 25 Anya dụ anụ ẹli, anụ whnụ nụ anụ ghárụla ọ nụrnu nhne nye wam nookwu. Ọ bụru nụ ikpe marnụ ele wam bnóne nsnị nhne nye wam zị nọodo be aka nụ nsnị n'ọwa kwuru, ndaa kpa a jaagbanahọru, ọ bụru nụ a bnóne nsnị nhne nye wam zị n'oligwe nọodo aị aka nụ nsnị nookwu?  
\v 26 Nkọli a mernu ọwa znụ biri biri n'ige wam, kọvu kịtna, o kweru mkwna kaa, “Berere kwno, m jeeme ọ bụ́o ọwa kpọi znụ biri biri, kọvu oligwe masị.”  
\v 27 “Berere kwno” neegesi nụ o jeegweme kpakara nhne nọoznu biri biri bụ nhne be keru eke, ma nhne ke zá nọoznu biri biri gwuzosi rikne. 
\p  
\v 28 Hne a nanahọru ẹli-eze ke zá nọoznu biri biri, a tụnu Chiokike mmamma, kwnakwu a kpa ọ jọoso a n'ọnu, nụ ogwnu nụ ọso anya.  
\v 29 Kwnornu nụ Chiokike bụ bẹkwnu neerne erne. 
\c 13  
\s1 Kpa be wu bụdnu  //  jaamasị Chiokike 
\p  
\v 1 Anụ nọowhnu ẹhni anụ n'anya lele rụmu nda.  
\v 2 Anụ chézu elekọta ele izne, kwnornu nụ agwna badnụ lekọtaru enine izi hne be máa.  
\v 3 Anụ chenwanya ele zị n'ikelu lele nụ anụ nụ be zị n'ikelu. Anụ chenwanya ele naata awhnụwhnu lele nụ anụ nụ be sno naata awhnụwhnu. 
\p  
\v 4 Anụ sọbisinu ọlulu nzi nụ nnwerne. Anụ méru ọkpata nzi nụ nnwerne kwnornu nụ Chiokike jeekpe ele neeme ọyi nụ ele ewhere ikpe.  
\v 5 Anụ kwé ọwhnun'anya ịwai nẹechi mkpọma anụ, nhne anụ nwernu ji anụ rụwho, kwnornu nụ Chiokike karụ, 
\q1 “M jáaghasa anụ rịa rịa, 
\q2 m jáasa anụ aka rịa rịa.” 
\m  
\v 6 Kam kpayarụ, a ji ovu siri rikne kaa, 
\q1 “Jihova bụ nye neenyinu m aka, 
\q2 ogwnu zá nọotu m nhne badnụ jeeme m.” 
\p  
\v 7 Anụ chenwanya ele risi anụ wheru ewhe, ele kwunnu anụ ikwu-ọnu Chiokike, kpa be wuru bụdnu be, kpa be nwụrnu ẹnwu, anụ snornu ọkwnata ovu be.  
\v 8 Jizọsi Karaịsi zị kpa ọ zị, ekile, tna, dụ ọkwnukokwnu. 
\p  
\v 9 Anụ kwékwadia iznizni ikne ọbula zị ichne ichne kwnapụ anụ n'apna. Ọ ka mma mkpọma aị gwuzosi rikne n'oru Chiokike, ọ bụ́o nụ omen'ẹli wiri zị ichne ichne ke zá naabnanụ ele neeri a mbnarna ọbula.  
\v 10 A nwernu ojo ke ele naakwa arịohna n'Ọro-Ẹka Nsọ nwée rikne ri nhne zị nụ olu a. 
\p  
\v 11 Kwnornu nụ nye risi arịohna neegwebna ọvnarna anọhia be gburu lele arịohna mmehie nụ rime Hne Kakwo Nsọ, kọvu be nọokporne ọkpna anọhia wam bẹkwnu n'aznụ ẹli-ọhna.  
\v 12 Kam kpayarụ, Jizọsi tarụ awhnụwhnu n'aznụ ẹli-ọhna ma o gweru ọvnarna a bịta ele badnụ nsọ.  
\v 13 Ngwa ma a znekwnusi a n'aznụ ẹli-ọhna vuru masị iwhnerne a.  
\v 14 Kwnornu nụ a nwée ẹli-ọhna ke jaadazịgidne hna, kọvu a neele anya ẹli ke naava nụ ruwhnu. 
\p  
\v 15 Ngwa ma a znarnị Chiokike ige ọbula, ma ọ bụru arịohna hite nụ Jizọsi, ka bụ nhne nkesi ke hi aị n'ovu, hite n'ọnu nookwuhịa nụ ọ bụ Nyenwe aị.  
\v 16 Anụ chenwanya, neeme nhne ọma ya nụ neekesi ele badnụ nhne anụ nwernu, kam bụ arịohna ke nọoso Chiokike ovu n'ọnu.  
\v 17 Anụ bno nsnị, anụ bịta ẹhni anụ nụ mkpururu ele risi anụ, kwnornu nụ be neelegidne anụ anya lele ele jaasa ajịji nụ ruwhnu Chiokike, ma be rnụ ẹrnu be n'ovu ọma, ọ bụ́o nụ ovu owe ẹhni, ke zá bnanụ anụ mbnarna ọbula. 
\s1 Obekwu ikwu ipne-aznụ 
\p  
\v 18 Anụ kpenu aị okpukpe. A magwụ nụ ovu aị zị rịchna kwnornu nụ a pioru o mee nhne bụru ọma ige ọbula.  
\v 19 M naarịasno anụ kpenu m okpukpe ma m vakwnusi m anụ wara wara. 
\p  
\v 20 Kịtna, Chiokike udno nye mernu Nyenwe aị Jizọsi hi n'ẹnwu lizọ, nye bụ Okne Nye Znụ Atnụrnu wam, hite n'ọvnarna ọgba-njọ-ẹhni kwó okwo,  
\v 21 nyee anụ kpakara nhne bụru ọma o mee echiche a. O gweru masị aị mee nhne masịri a, hite nụ Jizọsi Karaịsi nye nwe igwugwu ọkwnukokwnu. Amịm. 
\p  
\v 22 Rụmu nda m, anụ bno nsnị n'ikwu-ọnu ezni ke me kwuru, kwnornu nụ ọkwukwo me gbarụ zá ogologo. 
\p  
\v 23 Anụ mahịa nụ nnwọ nda aị Timoti whụyalam n'ikelu. Ọ bụru ọ va ngwa ngwa, me nụ a joosno va lekasi anụ. 
\p  
\v 24 Anụ bekwu kpakara ele risi anụ nụ kpakara rụmu Chiokike. Ele Ịtali neebekwu anụ. 
\p  
\v 25 Oru Chiokike dazịnu kpakara anụ.