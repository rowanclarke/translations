\id REV  
\h APOCALIPSIS 
\toc1 Jág₁ a₂ca₂jme₃jnia₅ Jesucristo ne₄ San Juan₅₄ 
\toc2 APOCALIPSIS 
\toc3 Ap. 
\mt1 Jág₁ a₂ca₂jme₃jnia₅ Jesucristo ne₄ San Juan₅₄ 
\c 1  
\s1 Jág₁ a₂ca₂jme₃jnia₅ Diú₄ 
\p  
\v 1 A₂la₂ bá₄ jág₁ a₂ca₂jme₃jnia₅ Diú₄ ne₄ Jesucristo, ia₁jaun₂ 'éi₂ në́₃ 'ë́'₃ táng₃ dsa₂ i₂jme₂ti₃ ne₅₄, ca₂juá'₂ ca₂le₃jë́₃ a₂tion₅₄ niog₅ lé₂ ŋi'₅₄ ta₁. Jaun₂ 'ŋiog₅ bá₄ 'éi₂ ca₂jmo₃ ca₂rë₃ŋi₅ ma₂ca₂jme₃jniai₂₃ të₂le₃ quian'₅₄ ángel quiáin₅ ne₄ Juan₅₄, jan₂ dsa₂ i₂jme₂ti₃ ta₁ ne₅₄.  
\v 2 Jniá₂ bá₄ 'éi₂ i₂jáng'₅ jág₁ dsau₅ la₂, ca₂le₃jë́₃ lia'₂ con'₂ lë́₅ a₂ca₂jág₃ ca₂të́₂ ne₃; ton'₂ jáng'₅ bá₄ jniá₂ jág₁ dsau₅ 'a₂ lia'₂ lë́₅ jág₁ dse₃ quió'₅ Diú₄, quian'₅₄ 'a₂ lia'₂ lɨ́n₅ Jesucristo. 
\p  
\v 3 'E₂ guë́₄ dsen₃ i₂'ɨ₅ si₂ la₂, a₂chi₁ton₅ jág₁ a₂'ë́₂ Diú₄. Le₂jaun₂ guë'₂ táng₃ juɨ₁lia'₂ i₂nag₅ jág₁ la₂ a₂'ë́₂ Diú₄; dsen₃ i₂tón'₂ juɨ₅ jág₁ a₂chi₁ton₅, ia₁ ma₂ja₂quián₃ jmɨg₄. 
\s1 Jmo₅ Juan₅₄ si₂ a₂ca₂chein₃ ne₄ ta₁guion₃ guá'₅ 
\p  
\v 4 Jniá₂ Juan₅₄ jmo₂₃ si₂ a₂dsiang'₅₄ ne₄ ta₁guion₃ guá'₅ i₂chan₂ le₂tan₅₄ 'uë₃ Asia. Juɨ₁jme₂gu'₅₄ Diú₄ 'nia'₂, juɨ₁chan'₂ bá₄ 'nia'₂ 'ei₅ tei₄ të₂le₃ quian'₅₄ Diú₄ i₂lɨ́n₅ jmɨg₄ në₃, i₂jme₁lɨ́n₄ tián₂ le₂jŋiá₅, i₂lén₂ ca₂lia'₂ co₂tan₅₄; ján₃ bá₄ juɨ₁jme₂gu'₅₄ Diú₄ 'nia'₂ të₂le₃ quian'₅₄ ta₁guion₃ jme₂dsí₂ i₂tion'₅₄ le₃ne₄ ne₄ta₁ ja₁guá₄;  
\v 5 ján₃ guë'₂ juɨ₁jme₂gu'₅₄ Diú₄ 'nia'₂ të₂le₃ quian'₅₄ Jesucristo, i₂tí₅ jág₁ dsau₅ quió'₅, i₂le₂ne₁ ma₂ca₂jen'₅₄ ne₄ 'mú₃, i₂gon₂ ne₄ rag₅₄ chan₂ gua'₅₄ 'uë₃. Le₃quió'₅ 'éi₂ bá₄ i₂ca₂rë₃'nio₃ jniog₄ ton'₂ ma₂ráng'₂ jniog₄ ne₄ 'uɨg₅₄ dsáu₁ jniog₄ quian'₅₄ jmɨ₂ 'ain₅₄ 'ŋiog₅;  
\v 6 le₃quió'₅ 'éi₂ në́₃ i₂ma₂jmo₃ a₂lág₅ jniog₄ rag₅₄, jme₂dsa₂ në́₃, a₂jme₁ti₁ jniog₄ ne₄ Diú₄ quiáin₅ i₂lɨ́n₅ Jmei₂. ¡Le₃quió'₅ 'éi₂ bá₄ ca₂tɨ́in₂ jme₃juag'₂ dsa₂, ca₂tɨ́in₂ goin₃ co₂tan₅₄! A₂méi₃. 
\q1  
\v 7 ¡Jag₄! ¡Ma₂já₅ jë₄ jnei₅! 
\q1 Ca₂le₃jɨ́n₃ bá₄ dsa₂ të₃ ne₅₄, 
\q2 ca₂le₂jiog₅ dsa₂ juɨg₂ i₂ca₂'ág'₂; 
\q1 ca₂le₃jɨ́n₃ dsa₂ chan₂ juɨg₂ ta₁caun₂ mɨ₂güɨ́g₃ 
\q2 tóin'₃ quɨ'₃-'o₃ jë₁ma₂ca₂jág₂. 
\q2 ¡Le₂jaun₂ lé₂, a₂méi₃! 
\p  
\v 8 “Jniá₂ bá₄ 'éi₂ i₂lɨ́ng₅ le₂'uɨg₅₄ juɨ₁lia'₂ letra Alfa jë₁ca₂rë₃lióg₃; jniá₂ bá₄ 'éi₂ i₂lɨ́ng₅ jë₁ca₂tó'₂ në́₃ juɨ₁lia'₂ letra Omega”, juá'₂ Te₁gui'₅₄ Diú₄. “Jniá₂ bá₄ lɨ́ng₅ rë₂në́₃, i₂lɨ́ng₅ ma₂i₁jáun₃, i₂lɨ́ng₅ co₂tan₅₄ ne₄ juɨ₅,\f + \fr 1:8 \ft 'Nio'₂ ja₁ton₅ Éxodo 3:14; Juan 8:58.\f* i₂'uan'₂ guë́₄ lɨn₃.”\f + \fr 1:8 \ft 'Nio'₂ ja₁ton₅ Isaías 41:4; 44:6; 48:12.\f* 
\s1 Jan₂ i₂lɨ́n₅ lia'₂ lɨ́n₅ Jaun₅ dsa₂ mɨ₂güɨ́g₃ 
\p  
\v 9 Jniá₂ Juan₅₄, lɨ́ng₅ rɨ́n'₂ 'nia'₂, ia₁ quein'₅₄ jniog₄ co₂dsia₅ ŋag₄ uɨg₅, le₂jaun₂ chi₁jŋia₁ jniog₄ ja₁gon₂ Diú₄, ton'₂ co₂dsia₅ guei₂ bí₂ a₂tián₂ jniog₄ juɨn'₂ dsɨ₅ le₃quió'₅ Jesús. Jme₁'eng₅₄ rë₂jnɨ́g₅ caun₂ 'uë₃ a₂rë₂quɨ́'₅ jë₄ jmɨ₁ŋí'₄ ja₁chei₂ Patmos, ne₄ 'uɨg₅₄ ia₁ a₂ma₂ca₂'ë́₃ jág₁ dse₃ quió'₅ Diú₄, ton'₂ ia₁ 'uɨg₅₄ a₂ma₂cuë₃ jniá₂ jág₁ dsau₅ 'ɨ́ng₅ Jesucristo.  
\v 10 Co₂ráun₂ në́₃ co₂jmɨg₄ quió'₅ Te₁gui'₅₄ ja₁'eng₅₄ jaun₂, ca₂lë₃ a₂jme₁'en₅₄ jniá₂ le₃quió'₅ Jme₂dsí₂. Jaun₂ ca₂nag₃ jág₁ a₂ca₂né'₂ le₃co'₅₄ lag₃ ca₂juá'₂ tiá₂ lɨn₃ juɨ₁lia'₂ jë₁i₂'ein₅₄ ŋí₁ trompeta,  
\v 11 ca₂juá'₂ tság₅ jniá₂: 
\p ―Jniá₂ bá₄ 'éi₂ i₂lɨ́ng₅ le₂'uɨg₅₄ juɨ₁lia'₂ letra Alfa jë₁ca₂rë₃lióg₃; jniá₂ bá₄ 'éi₂ i₂lɨ́ng₅ jë₁ca₂tó'₂ në́₃ juɨ₁lia'₂ letra Omega. Ne₄ si₂ rë₂bɨn₅, tiong₅ a₂jág'₂ ia₁jaun₂ qui₁dsiang'₅₄ ne₄ ta₁guion₃ guá'₅ ja₁tén₄ 'uë₃ Asia, co₂'nió'₄ le₃jua'₅₄ quió'₅ guá'₅ i₂chan₂ juɨg₂ Efeso, Esmirna, Pérgamo, Tiatira, Sardis, Filadelfia, quian'₅₄ Laodicea në́₃. 
\p  
\v 12 Ca₂jen'₄ jniá₂ jaun₂ në́₃, a₂jɨng₅₄ 'ein₂ 'éi₂ i₂juá'₂ jág₁ tság₅ jniá₂. Jme₁ca₂jeng'₅₄, ca₂jág₃ tióng₂ guio₃ tag₄ a₂lë́₅ jmá'₃ cu₄nióg₄ ja₁le₁guí'₂ si₂.  
\v 13 Jë₄ ta₁guio₃ mɨ₂tag₄ si₂ jaun₂ në́₃, jme₁chén'₄ jan₂ i₂lɨ́n₅ lia'₂ lɨ́n₅ Jaun₅ dsa₂ mɨ₂güɨ́g₃,\f + \fr 1:13 \ft 'Nio'₂ ja₁ton₅ Daniel 7:13.\f* i₂qui'₂ 'mɨ'₂ chen'₅₄ jang₄, mei'₂ tsá₃ tsáng₂ co'₅₄ tag₁₂. A₂jme₁rë₂jén'₅ le₁dsɨ́₅ guë'₂ në́₃, jme₁lë́₄ jmá'₃ cu₄nióg₄.  
\v 14 Jŋi₂ dsi₅₄ guë'₂ në́₃, jme₁tiog₂ lia'₂ ja₁tiog₂ jŋí₂ já'₂ cha'₂, a₂tiog₂ juɨ₁lia'₂ tiog₂ 'mu₂. Jme₁ne₁₂ guë'₂ në́₃ jme₁jniá₂ tág₅ juɨ₁lia'₂ jniá₂ ca₂jo'₅₄ si₂.  
\v 15 Mɨ₂tag₅₄ guë'₂ në́₃ jme₁jniá₂ tág₅ lia'₂ lë́₅ jmá'₃ nɨ₁ŋí₁ nióg₂ a₂rë₂ta₄ a₂ma₂jmág₂ né'₃ táu₃ si₂. Jág₁ quió'₅ guë'₂ në́₃ jme₁né'₂ tiá₂ lɨn₃ juɨ₁lia'₂ né'₂ caun₂ ja₁ta'₂ la'₅₄ pa₁ lɨn₃.\f + \fr 1:15 \ft o₃, “lia'₂ né'₂ 'lióng₂ jmɨg₂.” \f* 
\v 16 Gu₂ ne₁ guë'₂ në́₃ jme₁chan'₂ guio₃ nei₅; mɨ₂'o₅₄ guë'₂ në́₃ jme₁jniá₂ 'ia₂ lia'₂ lë́₅ caun₂ ŋi₁tág₂ chen'₂ a₂'mu₃ le₃tɨn₃ ton₂. Ne₅₄ guë'₂ në́₃ tág₅ jmá'₅, juɨ₁lia'₂ tág₅ 'iog₂. 
\p  
\v 17 Jme₁ca₂jág₃, ca₂tón₂ jniá₂ ja₁tióng₂ mɨ₂tag₅₄, lia'₂ tsá₃ léi₄ mei'₂. Jaun₂ ca₂quiog₂ gu₂ ne₁ ne₄ quió₃, jaun₂ ca₂juá'₂: 
\p ―Tsá₃ jmo₂ gang'₃, ia₁ jniá₂ bá₄ lɨ́ng₅ i₂le₂ne₁, ton'₂ jniá₂ bá₄ lɨ́ng₅ i₂jë₁ca₂tó'₂.  
\v 18 Jniá₂ bá₄ 'éi₂ i₂chan₂; jme₁rë₂'lɨn₄ bá₄ jniá₂, la₁ ¡jag₄! ma₂chang₂ bá₄ táng₃ ca₂le₃jë́₃ jmɨg₄, ca₂lia'₂ co₂tan₅₄.\f + \fr 1:18 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ ján₃ “A₂méi₃.” \f* Jniá₂ bá₄ chan'₄ ŋí₁ llaves quió'₅ 'mú₃ quian'₅₄ guë'₂ tau₂ 'ŋio₅.\f + \fr 1:18 \ft griego: hades, co₂'nió'₄ a₂juá'₂, ja₁quió'₄ 'lag₄.\f* 
\v 19 Jaun₂ lë₃, ne₄ si₂, tiong₅ juɨ₁lia'₂ 'e₂ a₂në₂jag'₅₄, 'a₂ lia'₂ niog₅ lë́₅ rë₂në́₃ quian'₅₄ guë'₂ a₂në₃ guë́₄ niog₅ lé₂.  
\v 20 A₂la₂ bá₄ jág₁ dsau₅ a₂jme₁rë₂'ma₄ le₂jŋiá₅: juɨ₁lia'₂ guio₃ nei₅ a₂në₂jag'₅₄ chi₁chan'₄ gu₃ ne₁, quian'₅₄ guë'₂ ta₁guio₃ tag₄ a₂lë́₅ quian'₅₄ cu₄nióg₄ ja₁le₁guí'₂ si₂. Jáng'₅ jág₁ ta₁guio₃ nei₅ co₂'nió'₄ guion₃ dsa₂ i₂i₃quian₄ jág₁\f + \fr 1:20 \ft griego: ángeles, co₂'nió'₄ i₂quian₅ jág₁. 'Nio'₂ ja₁ton₅ “ángel” ne₄ glosario.\f* quián₅ ta₁guion₃ guá'₅; guio₃ tag₄ ja₁le₁guí'₂ si₂ guë'₂ në́₃, co₂'nió'₄ ta₁guion₃ guá'₅. 
\c 2  
\s1 Jág₁ a₂chen₅ ne₄ le₂guion₃ guá'₅: Jág₁ a₂ŋó₃ ne₄ guá'₅ chan₂ Efeso 
\p  
\v 1 ’Jmo₄ si₂ ne₄ dsa₂ i₂'ë́₂ jág₁ guá'₅ i₂chan₂ juɨg₂ Efeso, chei'₅₄ le₂la₂: 
\p Le₂la₂ juá'₂ i₂chan'₂ le₃guio₃ nei₅ quian'₅₄ gu₂ ne₁, i₂ŋɨ₅ jë₄ ta₁guio₃ tag₄ a₂lë́₅ jmá'₃ cu₄nióg₄ ja₁le₁guí'₂ si₂:  
\v 2 Guion₄ bá₄ jniá₂ ca₂le₃jë́₃ ta₁ 'ua'₂ a₂jmo'₂ 'nia'₂, 'a₂ lia'₂ juɨn'₂ 'au'₂ në́₃. Guion₅₄ bá₄ ján₃ a₂tsá₃ ma₃tiang'₃ quiang'₅₄ dsa₂ i₂jmo₅ a₂'lɨg'₅₄. Guion₅₄ bá₄ ján₃ 'a₂ lia'₂ ma₂quion'₂ 'í₁ ja₁con₂ dsa₂ i₂i₂nio₄ a₂juá'₂ lɨ́in₅ dsa₂ i₂chen₄ quián₅ Jesús, la₁ tsá₃ guë'₂ lɨ́in₅. Ma₂ca₂jme₁jniai'₂ a₂lɨ́in₅ dsa₂ të₂jɨ́n₁.  
\v 3 Juɨn'₂ bá₄ 'au'₂ lɨ́ng'₅ ma₂ja₂nóg'₅ qui₂ŋag'₅₄ uɨg₅ jmo'₂ ta₁ 'ŋio₅ lɨn₃ o₄quió₃ jniá₂, tsá₃ ma₂qui₂ca₂'ú'₃ 'au'₂ 'nia'₂. 
\p  
\v 4 La₁ia₁ cha₂ guë́₄ caun₂ ja₁cong'₂, a₂tsá₃ të₅ dsɨ₃: ia₁ tsá₃ ma₃'nióg'₃ jniá₂ lia'₂ jme₁'nióg'₃ le₂ne₁.  
\v 5 Jaun₂ në́₃, dsá₂ 'au'₂ 'nia'₂ jmo₄, a₂já'₄ ma₂qui₂ma₂sén'₂ 'nia'₂. Juɨ₁dsi₂quén'₅ táng₃ 'au'₂ 'nia'₂, jmo₄ táng₃ lia'₂ jme₁jmo'₂ le₂ne₁. Ia₁ në₁jua'₂ tsá₃ le₂jaun₂ në́₃, ŋi'₅₄ ta₁ la₂ dsióg₄ i₁jŋiá'₃ tag₄ si₂ quiáng'₂ ja₁chí'₄, në₁jua'₂ tsá₃ ca₂jme₁tsɨ́ng'₄ 'au'₂.  
\v 6 Jŋia'₅₄ lia'₂ caun₂ a₂dse₃ la₂ bá₄ cha₂ ja₁cong'₂: a₂'ŋia'₅₄ 'nia'₂ 'a₂ lia'₂ lë́₅ jmo₅-dsáu₅ dsa₂ nicolaítas, a₂jaun₂ bá₄ 'io₄ guë'₂ jniá₂ ján₃. 
\p  
\v 7 Juɨ₁lia'₂ i₂le₁dsɨ₅₄ rë₂gua₄, juɨ₁nei₅₄ a₂juá'₂ Jme₂dsí₂ tsɨ́'₅ ca₂le₃jɨ́n₃ guá'₅. Juɨ₁lia'₂ i₂ca₂tió'₃, ŋei₂ guë́'₃ mɨ́g₂ 'ma₂ a₂chan₂ dsa₂ co₂tan₅₄, a₂chí'₅ Ja₁jlá'₁\f + \fr 2:7 \ft griego: paradeiso (Paraíso).\f* quió'₅ Diú₄. 
\s1 Jág₁ a₂ŋó₃ ne₄ guá'₅ chan₂ Esmirna 
\p  
\v 8 ’Jmo₄ si₂ ne₄ dsa₂ i₂'ë́₂ jág₁ guá'₅ i₂chan₂ juɨg₂ Esmirna chei'₅₄ le₂la₂: 
\p Le₂la₂ juá'₂ i₂le₂'uɨg₅₄, i₂lɨ́n₅ jë₁ca₂tó'₂ guë'₂ táng₃; i₂ca₂jon₃ 'éi₂, i₂ma₂ca₂jen'₅₄ guë'₂ táng₃:  
\v 9 Guion₅₄ bá₄ ca₂le₃jë́₃ 'a₂ lia'₂ lë́₅ chang'₂ ŋag'₅₄ uɨg₅, ton'₂ a₂te₂ŋég'₂ guë'₂ ján₃. La₁ on₃jua'₅₄ a₂dsɨ₂jó'₃ te₂ŋég'₂ jme₁né₄, ia₁ chang'₂ bá₄ dse₃ ján₃. Guion₅₄ bá₄ ján₃ 'a₂ lia'₂ 'ag₅ 'lɨg'₅₄ dsa₂ i₂juá'₂ lɨ́n₅ judíos, la₁ tsá₃ guë'₂ lɨ́in₅. Dsa₂ i₂tén₅ guá'₅ sinagoga quió'₅ Satanás bá₄ 'éi₂.  
\v 10 Tsá₃ jmo₂ 'nia'₂ gang'₃ 'e₂ niog₅ a₂dsi₁ŋɨ́g'₂, ia₁ tsáun'₂ i₂së₃dsen₃ toin'₂ né'₃ 'má₃ i₂lɨn₅₄ 'nia'₂ co₂'nió'₄ a₂cáun₂ táu₂, jaun₂ ŋag'₅₄ 'nia'₂ uɨg₅ guia₃ jmɨg₄. La₁ tiá₂ nau₂ 'nia'₂ o₁jŋia'₅₄ ca₂quɨ́n₂ 'mú₃, ia₁ jniá₂ bá₄ cuë₅₄ ja₁le₃chan'₂ 'nia'₂ co₂tan₅₄ co₂'nió'₄ caun₂ corona.  
\v 11 Juɨ₁lia'₂ i₂le₁dsɨ₅₄ rë₂gua₄, juɨ₁nei₅₄ a₂juá'₂ Jme₂dsí₂ tsɨ́'₅ ca₂le₃jɨ́n₃ guá'₅. Juɨ₁lia'₂ i₂ca₂tió'₃, 'i₁caun₂ uɨg₅ tsá₃ jén'₄ jë₁ca₂të́₂ tɨn₂ 'mú₃. 
\s1 Jág₁ a₂ŋó₃ ne₄ guá'₅ chan₂ Pérgamo 
\p  
\v 12 ’Jmo₄ si₂ ne₄ dsa₂ i₂'ë́₂ jág₁ guá'₅ i₂chan₂ juɨg₂ Pérgamo, chei'₅₄ le₂la₂: 
\p Le₂la₂ juá'₂ i₂'io₅ ŋi₁tág₂ 'mu₃ le₃tɨn₃ ton₂:  
\v 13 Guion₄ bá₄ jniá₂ ja₁tián'₅ 'nia'₂,\f + \fr 2:13 \ft A₂lɨn₅₄ chog₅₄ si₂: “Guion₅₄ bá₄ ca₂le₃jë́₃ 'e₂ a₂jmo'₂, ján₃ bá₄ guion₅₄ ja₁tián'₅ 'nia'₂.” \f* ja₁lë́₄ ne₄ta₁ ja₁gon₂ Satanás. La₁ lia'₂ tión'₂ jaun₂ bá₄ 'nia'₂ tiá₂ quian'₅₄ jág₁ quió₃. Tsá₃ ma₂tí'₃ a₂'éng'₂ le₃quió₃, ca₂lia'₂ jŋia'₅₄ jmɨg₄ lia'₂ con'₂ jme₁ca₂jŋɨ'₃ dsa₂ Antipas, dsa₂ i₂rë₂ti'₅₄ quiáng₃ i₂jme₁jáng'₅ jág₁ dsau₅, ca₂lë₃ jë₄ quián'₂ 'nia'₂, caun₂ juɨg₂ ja₁guá₄ Satanás.  
\v 14 La₁ia₁ cha₂ a₂lɨn₅₄ ja₁cong'₂, a₂tsá₃ të₅ dsɨ₃: jë₄ në₅ quián'₂ 'nia'₂ tion'₅₄ i₂lɨn₅₄ i₂tsá₃ tí₂ a₂'lɨg'₅₄ lia'₂ jme₁jmo₅ Bala'ama a₂ca₂toin'₂ jág₁ ca₂tsɨ́'₃ Balac\f + \fr 2:14 \ft Bala'am, Balac: 'Nio'₂ ja₁ton₅ Números 23 - 24.\f*, ca₂jmo₃ ca₂tsɨ₁sén'₂ dso₄ dsa₂ israelitas a₂ca₂guë́'₃ má₃ a₂rë₂jen'₅₄ ne₄ diú₄ lag₄ quiáin₅; ca₂jmo₃ ca₂can₃ dsa₂ 'éi₂ juɨ₅ qui₂ca₂nió'₃ jág₁ 'lɨg'₅₄.  
\v 15 Le₂në₅ bá₄ ján₃, tion'₅₄ jë₄ quián'₂ 'nia'₂ i₂lɨn₅₄ i₂jme₂tag₅ jág₁ quió'₅ dsa₂ nicolaítas.  
\v 16 Juɨ₁dsi₂quén'₅ 'au'₂ jaun₂ në́₃; ia₁ në₁jua'₂ tsá₃ ca₂tion'₂ 'nia'₂ juɨ₅, ŋi'₅₄ ta₁ la₂ dsióg₄ jniá₂ ja₁cong'₂ i₁quɨ́ng'₃ quian'₅₄ dsa₂ 'éi₂ quian'₅₄ ŋi₁tág₂ a₂'ia₂ mɨ₂'o₃.  
\v 17 Juɨ₁lia'₂ i₂le₁dsɨ₅₄ rë₂gua₄, juɨ₁nei₅₄ a₂juá'₂ Jme₂dsí₂ tsɨ́'₅ ca₂le₃jɨ́n₃ guá'₅. Juɨ₁lia'₂ i₂ca₂tió'₃, ŋei₂ maná a₂rë₂'ma₄, ton'₂ ŋei₂ jma₃ca₂mɨ́g₂ nɨ₁cang₁ tiog₂ ja₁chi₁ton₅ jág₁ 'mɨ́₂ 'a₂ lia'₂ chein₂, a₂tsá₃ 'ein₂ cuɨ́'₅; jmá'₃ lia'₂ con'₂ i₂gue₃ bá₄ ŋɨ́'₂. 
\s1 Jág₁ a₂ŋó₃ ne₄ guá'₅ chan₂ Tiatira 
\p  
\v 18 ’Jmo₄ si₂ ne₄ dsa₂ i₂'ë́₂ jág₁ guá'₅ i₂chan₂ juɨg₂ Tiatira, chei'₅₄ le₂la₂: 
\p Le₂la₂ juá'₂ Ja₁ŋi'₅₄ Diú₄ i₂tág₅ jme₁ne₁₂ lia'₂ tág₅ jo'₅₄ si₂, i₂lë́₅ mɨ₂tag₄ lia'₂ lë́₅ ŋí₁ nióg₂ a₂rë₂ta₄:  
\v 19 Guion₅₄ bá₄ ca₂le₃jë́₃ 'e₂ a₂jmo'₂, 'a₂ lia'₂ 'nióg'₃ rɨ́ng'₂, 'a₂ lia'₂ lë́₅ a₂'éng'₂ në́₃, ta₁ quiáng'₂ a₂jme₂tí'₁, juɨn'₂ bá₄ 'au'₂ chang'₂ në́₃; guion₄ bá₄ jniá₂, 'ŋio₅ guë́₄ jmo'₂ 'nia'₂ lia'₂ con'₂ guë́₄ le₂ne₁.  
\v 20 La₁ia₁ cha₂ guë́₄ caun₂ ja₁cong'₂ a₂tsá₃ të₅ dsɨ₃: ia₁ cuë'₂ 'nia'₂ jmɨg₄ 'en₅₄ jɨn'₄ 'nia'₂ 'io₅₄ Jezabel i₂juá'₂ i₂'ë́₂ jág₁ o₄quió'₄ Diú₄. Jme₂tag₂₃ a₂jŋia'₅₄ qui₂jme₂gain₂₃ dsa₂ quiáng₃ i₂jme₂ti₃ ne₃ ia₁jaun₂ cán₂ juɨ₅ jmo₃ dsáu₃ qui₃nió'₃ jág₁ 'lɨg'₅₄, ia₁jaun₂ ján₃ guë́₄ qui₃guë́'₃ má₃ a₂rë₂jen'₅₄ ne₄ diú₄ lag₄ quiáin₅.  
\v 21 Ma₂cuë́₃ jniá₂ 'io₅₄ 'éi₂ jmɨg₄ ne₄ tsa₁ dsi₁quén'₅ dsɨ́₅ 'lɨg'₅₄ a₂jmo₂₃, la₁ tsá₃ 'nio₃.  
\v 22 ¡Jag₄! Tóin₂ jniá₂ ne₄ tsɨ₁cama jaun₂ le₃dso'₅₄, ján₃ guë'₂ jmo₅₄ ŋág₃ uɨg₅ dsa₂ i₂qui₂'no₅ dso₄ quiain'₅₄, në₁jua'₂ tsá₃ ca₂dsi₃quén'₅ dsɨ́₅ a₂jmo₅-dsáu₅ 'io₅₄ 'éi₂,  
\v 23 ton'₂ jme₁dsian₅ jniá₂ chi'₂ quián₅ 'io₅₄ 'éi₂ në́₃. Jaun₂ bá₄ le₃ŋi₅ ca₂le₃jɨ́n₃ guá'₅, jniá₂ i₂con₂ 'í₁ 'a₂ lia'₂ lë́₅ jme₂dsí₂ quió'₅ dsa₂, ca₂le₃jë́₃ a₂qui₂dsɨ₂jiog₅ dsɨ́₅ dsa₂ në́₃; jaun₂ jniá₂ bá₄ cuë́₄ 'lian'₅₄ 'nia'₂ lia'₂ con'₂ lë́₅ qui₂ca₂jmo'₅₄.  
\v 24 La₁ juɨ́g₂ jniá₂ ca₂le₃jɨ́n₃ guë́₄ 'nia'₂ i₂tián'₅ juɨg₂ Tiatira i₂tsá₃ ma₂gue₃ jág₁ a₂jme₂tag₅ 'io₅₄ 'éi₂, on₃ guë'₂ cuɨ́'₅ a₂të́'₂ dsa₂ 'éi₂ jág₁ ca'₅₄ a₂rë₂'ma₄ quió'₅ Satanás: co₂në₅ bá₄ guei₂ a₂cuë́₄ jniá₂ 'nia'₂.  
\v 25 Jŋia'₅₄ lia'₂ caun₂ jmo'₂ 'nia'₂ a₂dse₃ a₂ma₂ja₂nóg'₅ jmo'₂, ca₂lia'₂ ca₂të́₂ jmɨg₄ i₁dsióg₄ táng₃.  
\v 26 Juɨ₁lia'₂ i₂ca₂tió'₃, i₂qui₂jmo₅ 'a₂ con'₂ 'nio₃ jniá₂ lé₂, ca₂lia'₂ i₁ca₂të́₂ jmɨg₄ jë₁ca₂tó'₂, cuë́₄ jniá₂ bí₂ jaun₂ jmo₃ 'éi'₃ ne₄ juɨg₂ a₂te₁'i₁ gua'₅₄ 'uë₃. 
\q1  
\v 27 Goin₃ ne₄ quió'₅ quian'₅₄ 'ma₂'ɨ'₅₄ 
\q2 a₂lë́₅ quian'₅₄ nɨ₁ŋí₁; 
\q1 qui₃dsia₃ le₁juɨg₁ në₂jag₄ bá₄ nɨ₁tɨ'₂,\f + \fr 2:27 \ft Salmo 2:9.\f* 
\m  
\v 28 lia'₂ con'₂ lë́₅ ma₂gue₃ jniá₂ 'éi'₃ ma₂cuë₃ Ŋe'₃. Cuɨ́in₄ jniá₂ ján₃ Nei₅ 'Ióg₁.\f + \fr 2:28 \ft Nei₅ 'Ióg₁ lë́₅ caun₂ 'a₂ lia'₂ chen₂ Jesús. 'Nio'₂ ja₁ton₅ 2 Pedro 2:21; Apocalipsis 22:16.\f* 
\v 29 Juɨ₁lia'₂ i₂le₁dsɨ₅₄ rë₂gua₄, juɨ₁nei₅₄ a₂juá'₂ Jme₂dsí₂ tsɨ́'₅ ca₂le₃jɨ́n₃ guá'₅. 
\c 3  
\s1 Jág₁ a₂ŋó₃ ne₄ guá'₅ chan₂ Sardis 
\p  
\v 1 ’Jmo₄ si₂ ne₄ dsa₂ i₂'ë́₂ jág₁ guá'₅ i₂chan₂ juɨg₂ Sardis, chei'₅₄ le₂la₂: 
\p Le₂la₂ juá'₂ i₂jiog₅ ta₁guion₃ jme₂dsí₂ quián₅ Diú₄, i₂chan'₂ guio₃ nei₅ në́₃: Guion₄ bá₄ jniá₂ ca₂le₃jë́₃ a₂jmo'₂, a₂dsia₅ dsa₂ a₂jén'₃ 'nia'₂, la₁ia₁ i₂rë₂'lɨn'₄ bá₄ 'nia'₂.  
\v 2 Jme₁jnio₂ ne'₅₄, tiong'₂ táng₃ bí₂ a₂jme₁ma₂i₁jón₂ quiáng'₂, ia₁ tsá₃ ma₂dsó'₂ jniá₂ jua'₅₄ a₂rë₂tán₄ a₂qui₂ma₂jmo'₅₄ 'nia'₂ le₃ne₄ Diú₄ quiáng₃.  
\v 3 Dsiog'₂ 'au'₂ 'nia'₂ jmo₄ jaun₂ në́₃, a₂qui₂ma₂gue'₅₄ 'nia'₂, a₂qui₂ma₂nei'₂ 'nia'₂, juɨ₁dsi₂quén'₅ 'au'₂. La₁ në₁jua'₂ tsá₃ ca₂jme₁jnio'₂ ne'₅₄, ŋi'₅₄ ta₁ dsióg₄ jniá₂ ja₁cong'₂ con'₂ tsá₃ rë₂jáng'₁, në₂jag₄ bá₄ jan₂ 'ang₂, ca₂lia'₂ jŋia'₅₄ tsá₃ ŋi'₅₄ 'nia'₂ 'e₂ hora dsióg₄.  
\v 4 La₁ chan₂ bá₄ guë́₄ i₂lɨn₅₄ jɨn'₄ 'nia'₂ guá'₅ Sardis në₅ i₂tsá₃ ma₂ca₂jme₃'ióg₃ tsɨn'₅₄; i₂'éi₂ në́₃ jme₃quiong'₅₄ jniá₂ i₃nioi₅₄ le₁qui'₂ 'mɨ'₂ tiog₂, ia₁ le₂jaun₂ ca₂tɨ́in₂.  
\v 5 Juɨ₁lia'₂ i₂ca₂tió'₃, tsɨn'₅₄ tiog₂ bá₄ qui₃quɨ́'₃, jaun₂ lia'₂ o₁lɨ́g'₂ tsá₃ 'én₄ lia'₂ chein₂ ja₁le₁toin₂₃ ne₄ si₂ a₂chan₂ dsa₂ co₂tan₅₄. Jaun₂ 'ɨ́n₄ jniá₂ 'éi₂ jme₁jniai₂₃ jniá₂ ne₄ Ŋe'₃, ne₄ ángeles quiáin₅ në́₃.  
\v 6 Juɨ₁lia'₂ i₂le₁dsɨ₅₄ rë₂gua₄, juɨ₁nei₅₄ a₂juá'₂ Jme₂dsí₂ tsɨ́'₅ ca₂le₃jɨ́n₃ guá'₅. 
\s1 Jág₁ a₂ŋó₃ ne₄ guá'₅ chan₂ Filadelfia 
\p  
\v 7 ’Jmo₄ si₂ ne₄ dsa₂ i₂'ë́₂ jág₁ guá'₅ i₂chan₂ juɨg₂ Filadelfia, chei'₅₄ le₂la₂: 
\p Le₂la₂ juá'₂ 'éi₂ i₂jŋió₅, i₂të₃dsón'₂ tí₅ jág₁ quió'₅, i₂'io₅ ŋí₁ llave quió'₅ Rag₅₄ David. Juɨ₁lia'₂ a₂niá₅ 'éi₂, 'i₁jan₂ tsá₃ lé₂ jnéi₃; ján₃ guë'₂ le₂jaun₂, juɨ₁lia'₂ a₂jnéi₅ 'éi₂, tsá₃ 'ein₂ lé₂ le₃niá₃ táng₃.  
\v 8 Guion₅₄ bá₄ jë₂ a₂jmo'₂. ¡Jag₄! Caun₂ o₄'né₄ a₂rë₂na₄ ma₂ca₂tsɨ́'₂ jniá₂ ne'₅₄; 'i₁jan₂ tsá₃ 'ein₂ lé₂ le₃jnéi₃. O₁jŋia'₅₄ la₂ tsá₃ ma₃lɨn₄ béng'₂,\f + \fr 3:8 \ft o₃, “tsá₃ lɨn₄ juɨn'₅ 'nia'₂.” \f* ma₂ca₂tion'₂ juɨ₅ jág₁ quió₃, on₃jua'₅₄ jaun₂ a₂tsá₃ ma₂'ag'₅₄ jniá₂.  
\v 9 ¡Jag₄! Juɨ₁lia'₂ dsa₂ quián₅ guá'₅ sinagoga quió'₅ Satanás, dsa₂ i₂juá'₂ lɨ́in₅ judíos la₁ tsá₃ guë'₂ lɨ́in₅, jmo₅₄ jniá₂ chi₃jné₃ 'éi₂ ne'₅₄, ia₁jaun₂ le₃ŋi₅ a₂'nió₃ jniá₂ 'nia'₂.  
\v 10 'Uɨg₅₄ ia₁ a₂ma₂jmo'₅₄ 'nia'₂ 'í₁ 'éi'₃ quió₃ a₂tion'₅₄ 'nia'₂ juɨn'₂ 'au'₂, jmo₅₄ bá₄ jniá₂ 'í₁ 'nia'₂ a₂tsá₃ jióg'₂ 'í₁ ja₁cong'₂ juɨ₁lia'₂ a₂dsɨ₃ŋɨ́₂ dsa₂ i₂chan₂ ta₁caun₂ gua'₅₄ 'uë₃.  
\v 11 Ŋi'₅₄ ta₁ bá₄ guióng₄. Jmo₄ 'í₁ a₂ma₂tɨng'₂ ia₁jaun₂ tsá₃ 'ein₂ jŋiá'₂ corona quiáng'₂.  
\v 12 Juɨ₁lia'₂ i₂ca₂tió'₃, jmo₅₄ jniá₂ a₂léin₂ në₂jag₄ bá₄ nɨ₁dsɨ₅ a₂chí'₅ dsi₂néi₂ guá'₅ templo quió'₅ Diú₄ quiáng₃. O₁lɨ́g'₂ jmɨg₄ tsá₃ ma₃'uɨ́in₃ ja₁jaun₂. Ne₄ quió'₅ 'éi₂, taun₅₄ lia'₂ chen₂ Diú₄ quiáng₃, quian'₅₄ guë'₂ 'a₂ lia'₂ chei₂ juɨg₂ quió'₅ Diú₄ quiáng₃ në́₃: juɨg₂ Jerusalén 'mɨ́₂ a₂sió₃ guei'₅₄ i₂juɨ́g₃ quió'₅ Diú₄ quiáng₃. Ján₃ guë'₂ le₂jaun₂ taun₅₄ jniá₂ ne₄ 'éi₂ jág₁ 'mɨ́₂ lia'₂ cheng₂.  
\v 13 Juɨ₁lia'₂ i₂le₁dsɨ₅₄ rë₂gua₅₄, juɨ₁nei₅₄ a₂juá'₂ Jme₂dsí₂ tsɨ́'₅ ca₂le₃jɨ́n₃ guá'₅. 
\s1 Jág₁ a₂ŋó₃ ne₄ guá'₅ chan₂ Laodicea 
\p  
\v 14 ’Jmo₄ si₂ ne₄ dsa₂ i₂'ë́₂ jág₁ guá'₅ i₂chan₂ juɨg₂ Laodicea, chei'₅₄ le₂la₂: 
\p Le₂la₂ juá'₂ i₂lɨ́n₅ të₃dsón'₂,\f + \fr 3:14 \ft lit. “Le₂la₂ juá'₂ juɨ₁lia'₂ i₂të́'₂ A₂méi₃.” \f* i₂jáng'₅ jág₁ dsau₅ i₂rë₂ti'₅₄, i₂lɨ́n₅ juɨg₅₄ ne₄ ca₂le₃jë́₃ a₂ca₂jmo₃ Diú₄:  
\v 15 Guion₄ bá₄ jniá₂ ca₂le₃jë́₃ 'a₂ lia'₂ lë́₅ jmo'₂ 'nia'₂. Guion₅₄ bá₄, a₂tsá₃ güɨ́ng'₂, on₃ guë'₂ dséng'₂ në́₃. ¡Jua'₅₄ co₂ŋei'₅₄ bá₄ guë'₂ güɨ́ng'₂, o₃ co₂ŋei'₅₄ bá₄ guë'₂ dséng'₂!  
\v 16 La₁ 'uɨg₅₄ ia₁ a₂jŋia'₅₄ dsión'₂ 'nia'₂, ia₁ tsá₃ güɨ́ng'₂ guë'₂ co₂ŋei'₅₄, on₃ guë'₂ dséng'₂ në́₃, jaun₂ ráun₂ i₁ŋí₄ jniá₂ 'nia'₂ juɨ₅ mɨ₂'o₃.  
\v 17 Ia₁ juá'₂ 'nia'₂ a₂ma₂chang'₂ dse₃ a₂ma₂qui₂ma₂dsia'₅₄ 'nia'₂ 'lióng₂ rë₂má'₂, ton'₂ tsá₃ 'e₂ 'nió'₅ quiáng'₂; la₁ tsá₃ jaun₂ len'₅₄ 'nia'₂ a₂lɨ́ng'₅ dsa₂ i₂lë₁ŋéi₂ dsɨ́₅, i₂te₂ŋé₂, i₂ten₄, i₂rë₂cuán'₃ në́₃.  
\v 18 'Uɨg₅₄ jaun₂ ton'₂ jniá₂ jág₁ 'nia'₂, i₂nó'₅ 'nia'₂ ja₁con₂ jniá₂ i₂liá₃ cu₄nióg₄ a₂rë₂lag₄ quian'₅₄ si₂, ia₁jaun₂ guë́₄ dsón'₂ le₃chang'₂ dse₃; i₂liá₃ 'nia'₂ tsɨ́ng'₂ tiog₂ a₂qui₁quɨ'₅₄, ia₁jaun₂ tsá₃ le₃jniá₂ a₂o₂guí'₃ a₂rë₂cuáng'₃. I₂liá₃ mɨ́₅ 'ág'₄ jme₁ne'₄ ia₁jaun₂ jnio₂, lé₂ jag'₅₄.  
\v 19 Të₂jén₅ jniá₂ tsɨ́ng'₂ táng₃ juɨ₅ dse₃ ca₂le₃jɨ́n₃ i₂'nióg₃. Juɨ₁len'₅₄ bá₄ 'nia'₂ dsa₂ i₂dsen₅₄ dsɨ́₅ jaun₂ në́₃, juɨ₁dsi₂quén'₅ 'au'₂.  
\v 20 ¡Jag₄! La₂ chén'₅ jniá₂ o₄'né₄ të́₅; chi₂jua'₂ chan₂ i₂ca₂nág₂ jág₁ quió₃, niá₅ o₄'né₄ në́₃, jaun₂ bá₄ 'ú₄ dsi₂néi₂ quió'₅, guë'₅₄ co₂lë₅ quiain'₅₄.  
\v 21 Juɨ₁lia'₂ i₂ca₂tió'₃, cuë́₄ jma₃caun₂ ja₁tiain'₃ cau₅ quió₃ ne₄ta₁ ja₁gua₄ jniá₂, juɨ₁lia'₂ ca₂tió₃ jniá₂, jaun₂ ca₂gua₃ con₂ Ŋe'₃ ne₄ta₁ quió'₅.  
\v 22 Juɨ₁lia'₂ i₂le₁dsɨ₅₄ rë₂gua₅₄, juɨ₁nei₅₄ a₂juá'₂ Jme₂dsí₂ tsɨ́'₅ ca₂le₃jɨ́n₃ guá'₅. 
\c 4  
\s1 'A₂ lia'₂ qui₂rë₂juɨn'₂ Diú₄ guei'₅₄ i₂juɨ́g₃ 
\p  
\v 1 Cang₂ guë́₄ jaun₂, ca₂jág₃ táng₃ jniá₂ caun₂ o₄'né₄ rë₂na₄ guei'₅₄ i₂juɨ́g₃. Jaun₂ ca₂nag₃ jág₁ jaun₂ a₂ca₂nag₃ le₂'uɨg₅₄ a₂né'₂ në₂jag₄ bá₄ jë₁i₂'ein₅₄ ŋí₁ trompeta, ca₂juá'₂ tság₅ jniá₂: 
\p ―Uɨ́g₂ ja₁lá₃, jaun₂ 'ë₅₄ ca₂le₃jë́₃ a₂niog₅ lé₂ cang₂ guë́₄ jë₁ma₂lë₅ a₂ma₂në₂jag'₅₄ në₅. 
\p  
\v 2 Jaun₂ ca₂lë₃ jme₁'en₅₄ jniá₂ le₃quió'₅ Jme₂dsí₂, jaun₂ ca₂jnia₃ caun₂ ne₄ta₁ chí'₅ guei'₅₄ i₂juɨ́g₃. Ne₄ ne₄ta₁ jaun₂ jme₁guá₄ jan₂ dsa₂.  
\v 3 Dsa₂ i₂jme₁guá₄ 'éi₂ në́₃, jme₁jniái₂ tág₅ 'ŋio₅ lɨn₃ në₂jag₄ bá₄ nɨ₁cang₁ tág₅ jaspe o₃ cornalina. Le₃lág'₃ ne₄ta₁ ja₁guá₄ jaun₂ jme₁jniá₂ mɨ₂jo'₅₄ si₂ a₂tág₅ lɨn₃, në₂jag₄ bá₄ nɨ₁cang₁ esmeralda.  
\v 4 Le₃lág'₃ ne₄ta₁ ja₁guá₄ dsa₂, ca₂jág₃ con'₂ guë́₄ guióg₂-quén₂ ne₄ta₁ ja₁tián'₄ guión₂-quén₂ gui'₅₄ can'₅₄ i₂le₁lɨn₁ le₁qui'₂ jmá'₃ 'mɨ'₂ tiog₂, tio'₅₄ coronas a₂lë́₅ jmá'₃ cu₄nióg₄ dsi₅₄.  
\v 5 Ja₁chí'₄ ne₄ta₁ jaun₂, qui₂lë́₂ si₁ŋí'₃, chí'₅ co₂mɨ'₅₄, quia'₂ ŋí'₃ në́₃. Ne₄ ja₁chí'₄ ne₄ta₁ jaun₂, jniá₂ guio₃ si₂ nɨ₁tsɨ́₅ a₂cau₂. A₂jaun₂ në́₃ lë́₅ ta₁guion₃ jme₂dsí₂ quián₅ Diú₄.  
\v 6 Të₂le₃ ne₄ juɨ₅ ne₄ta₁ në́₃, jniá₂ táng₃ lia'₂ lë́₅ jmɨ₁ŋí'₄ a₂lë́₅ uɨ'₂ lɨn₃ juɨ₁lia'₂ uɨ'₂ nɨ₁'ɨ₂. 
\p Dsi₂jo₂, le₂tan₅₄ le₃lág'₃ ja₁chí'₄ ne₄ta₁, jniá₂ táng₃ quén₂ i₂lɨ́n₅ lia'₂ lɨ́n₅ já'₂ i₂rë₂can'₂ jmá'₃ mɨ₂ne₄ lia'₂ le₃ne₅₄ lia'₂ le₃co'₅₄ lag₁₂ në́₃.  
\v 7 Jë₁le₂'uɨg₅₄ já'₂ quén₂ 'éi₂ në́₃, jniái₂ lia'₂ jniá₂ dsɨ₂'ia'₂ león. Jë₁ca₂të́₂ on₃, jme₁lɨ́n₄ lia'₂ lɨ́n₅ jan₂ guein₂ ca₁juɨ₅. Jë₁ca₂të́₂ ún₂, jniá₂ dsɨ₂ne₅₄ lia'₂ jniá₂ dsɨ₂ne₄ dsa₂ mɨ₂güɨ́g₃. I₂jë₁ca₂të́₂ quén₂ në́₃, jniái₂ lia'₂ jniá₂ i₁mɨg₂ i₂'en₅ güɨg₂.  
\v 8 Jë₁le₃quéin₂ le₂jaun₂ në́₃, le₁dsɨ₅₄ jma₃jŋéi₂ tsɨ₁rë₂cu₅ le₂jain₂ le₂jain₂. Qui₂rë₂lióin₃ mɨ₂ne₄ le₃co'₅₄ lia'₂ le₃né'₃ në́₃. Lia'₂ 'uë₂-jmɨ₂ bá₄ tsá₃ 'na₂ i₁juá'₄: 
\q1 Jŋió₅ bá₄, jŋió₅ bá₄, jŋió₅ bá₄, 
\q2 Te₁gui'₅₄ Diú₄ i₂'uan'₂ guë́₄ lɨn₃, 
\q1 i₂jme₁lɨ́n₄, i₂lɨ́n₅ rë₂në́₃, 
\q2 i₂lén₂ co₂tan₅₄ bá₄ ján₃. 
\p  
\v 9 Lia'₂ co₂ráun₂ cuë₅ já'₂ 'éi₂ cuë́'₅ ti₁'mag'₄ jme₂juɨin'₂ guë́₄ lɨn₃ i₂guá₅ ne₄ ne₄ta₁, i₂chan₂ co₂tan₅₄ në́₃,  
\v 10 jaun₂ guë́₄ qui₂tón₂ 'uë₃ ta₁guión₂-quén₂ gui'₅₄ can'₅₄ 'éi₂, ne₄ i₂guá₅ ne₄ ne₄ta₁, qui₂jme₂juɨin'₂ i₂chan₂ co₂tan₅₄, qui₂dsia₂₃ coronas quió'₅ 'uɨg₅₄ ne₄ta₁, juá'₂: 
\q1  
\v 11 Te₁gui'₅₄ Diú₄ quián₂, 
\q2 'ne₂ bá₄ ca₂tɨ́ng'₂ guéi'₁ a₂jme₃juag'₂ dsa₂, 
\q2 'ne₂ bá₄ ca₂tɨ́ng'₂ 'éi'₃, juɨ₅bí₂ në́₃. 
\q1 Ia₁ co₂jaun₂ ca₂rë₃'ŋió₃ 'au'₂ 
\q2 a₂ca₂rë₃chá₃ ca₂le₃jë́₃ a₂cha₂. 
\c 5  
\s1 Si₂ a₂rë₂bɨn₅ quian'₅₄ guë'₂ Guein₂ Já'₂ Cha'₂ 
\p  
\v 1 Jaun₂ ca₂jág₃ jniá₂ i₂guá₅ ne₄ ne₄ta₁ 'éi₂ chi₁chan'₂ quian'₅₄ gu₂ ne₁ caun₂ mɨ₂si₂ a₂rë₂bɨn₅ tio'₅₄ jág₁ lia'₂ le₃co'₅₄ lia'₂ le₃né'₃, a₂chi₁jnɨ₅ dse₃ quian'₅₄ guio₃ bë'₅₄ mɨ₄cuɨng₅.  
\v 2 Jaun₂ ca₂jɨng₅₄ jan₂ ángel i₂'uan'₂ lɨn₃ quián₅ Diú₄, jniái₂ chéin'₅ ŋag₂₃ juá'₂ tiá₂: 
\p ―¿'Ein₂ 'éi₂ i₂ca₂tɨ́n₂ niá₃ si₂ në₅, qui₃choin₃ mɨ₄cuɨng₅ quió'₅ në́₃? 
\p  
\v 3 La₁ on₃ guë'₂ guei'₅₄ i₂juɨ́g₃, on₃ guë'₂ ne₄ gua'₅₄ 'uë₃, on₃ guë'₂ le₃né'₃ guë́₄ gua'₅₄ 'uë₃, tsá₃ chan₂ 'i₁jan₂ i₂ca₂tɨ́n₂ niá₃ si₂ jaun₂, on₃ guë'₂ ca₂tɨ́in₂ jág₃.  
\v 4 'Ŋio₅ lɨn₃ ca₂'o₃ jniá₂ 'uɨg₅₄ ia₁ a₂tsá₃ 'ein₂ ca₂dsán'₂ 'i₁jan₂, i₂ca₂tɨ́n₂ jme₁niá₃ si₂ jaun₂,\f + \fr 5:4 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ ján₃: “on₃ guë'₂ 'ɨ₃.” \f* on₃ guë'₂ a₂jág₃.  
\v 5 Jaun₂ në́₃, jan₂ i₂lɨ́n₅ gui'₅₄ can'₅₄ 'éi₂ ca₂tság₃ jniá₂: 
\p ―Tsá₃ lë₁'au₂ 'ne₂, ia₁ i₂lɨ́n₅ 'ia'₂ león quián₅ tsɨ₁jon₂ Judá, i₂ca₂lɨn₃ cho'₅₄ Rag₅₄ David, 'éi₂ bá₄ ma₂ca₂tió'₃; 'éi₂ bá₄ ca₂tɨ́n₂ niá₃ si₂, le₂jiog₅ ta₁guio₃ mɨ₄cuɨng₅ quió'₅ në́₃. 
\p  
\v 6 Jaun₂ ja₁lë́₄ dsi₂jo₂ ne₄ta₁, jë₄ quió'₅ le₃quén₂ já'₂ 'éi₂, jë₄ quió'₅ gui'₅₄ can'₅₄ në́₃, ca₂jɨng₅₄ jan₂ i₂lɨ́n₅ lia'₂ lɨ́n₅ Guein₂ Já'₂ Cha'₂ chéin'₅, a₂léin₄ në₂jag₄ i₂ca₂jon₃ ca₂jŋag'₃ dsa₂. Le₁dsɨ₅₄ guio₃ mɨ₂juɨ́₁, guio₃ guë'₂ mɨ₂ne₅₄. Mɨ₂ne₅₄ jaun₂ në́₃ co₂'nió'₄ guion₃ jme₂dsí₂ quián₅ Diú₄ i₂ma₂'uɨn₂ a₂chein₅₄ ta₁caun₂ gua'₅₄ 'uë₃.  
\v 7 I₂lɨ́n₅ Guein₂ Já'₂ Cha'₂ 'éi₂ në́₃, ŋó₃ ca₂tɨ́in₂ mɨ₂si₂ rë₂bɨn₅ a₂jme₁chi₁chan'₂ le₂gu₂ ne₁ i₂guá₅ ne₄ta₁.  
\v 8 Jme₁ca₂can₃ mɨ₂si₂, jaun₂ qui₂ca₂tón₂ 'uë₃ le₃quén₂ já'₂ 'éi₂, quian'₅₄ guë'₂ ta₁guión₂-quén₂ gui'₅₄ can'₅₄ në́₃, ca₂tóin₂ ne₄ Guein₂ Já'₂ Cha'₂. Le₂jan₂ le₂jan₂ 'éi₂ në́₃ le₁chan'₂ jma₃cáun₃ tsɨ₁ton₅ arpa,\f + \fr 5:8 \ft griego: kithara.\f* le₁chan'₂ jma₃cáun₃ guë'₂ nɨ₁uɨng₅ jɨ'₂ a₂lë́₅ jmá'₃ cu₄nióg₄, a₂le₁can'₂ chen₂, a₂co₂'nió'₄ jág₁ a₂qui₂rë₂jen'₅₄ ne₄ Diú₄ a₂qui₂chi₂léi'₂ dsa₂ quiáin₅.\f + \fr 5:8 \ft lit. “dsa₂ jŋió₅.” \f* 
\v 9 Tioin'₅₄ 'ë₂₃ caun₂ canto 'mɨ́₂ la₂: 
\q1 'Ne₂ bá₄ ca₂tɨ́ng'₂ jma'₅₄ mɨ₂si₂, 
\q2 a₂chóng'₄ mɨ₄cuɨng₅ quió'₅; 
\q2 ia₁ 'ne₂ bá₄ i₂ca₂jŋag'₃ dsa₂. 
\q1 Quian'₅₄ jmɨ₂ 'ang'₅₄ a₂ca₂tein'₅₄, 
\q2 ca₂liáng'₃ dsa₂ mɨ₂güɨ́g₃ le₃quió'₅ Diú₄: 
\q1 ca₂le₃jɨ́n₃ ne₅₄ dsa₂ i₂chan₂, 
\q2 ca₂le₃jë́₃ jág₁ jmei₅, 
\q2 ca₂le₃jë́₃ juɨg₂ te₁'i₁ mɨ₂güɨ́g₃, 
\q2 ca₂le₃jë́₃ tsɨ₁jon₂ në́₃. 
\q1  
\v 10 Ma₂ca₂jmoi'₅₄ rag₅₄, jme₂dsa₂ në́₃, 
\q2 le₃quió'₅ Diú₄ quián₂. 
\q1 Jaun₂ 'éi₂ bá₄ le₃gon₂ ne₄ gua'₅₄ 'uë₃. 
\p  
\v 11 Jaun₂ jme₁ca₂jág₃, ca₂nag₃ jniá₂ jág₁ quió'₅ juɨn₅ ángeles, i₂lë́₂ të₂le₃ mei₅, i₂lë́₂ ca₂lia'₂ juɨn₅ lɨn₃. Jme₁tioin'₅₄ le₃lág'₃ ne₄ta₁ jaun₂, quian'₅₄ guë'₂ já'₂ quén₂ 'éi₂, gui'₅₄ can'₅₄ në́₃,  
\v 12 i₁juá'₄ tiá₂ lɨn₃: 
\q1 ¡I₂ca₂tɨ́n₂ Guein₂ Já'₂ Cha'₂ i₂ca₂jŋag'₃ dsa₂, 
\q2 a₂le₂goin₂₃, 'io₃ ca₂le₃jë́₃ a₂jlá'₁, 
\q2 a₂tɨin₂ a₂ŋɨ́'₂ dsɨ́₅, 
\q1 a₂gue₃ juɨ₅bí₂, a₂jme₃juag'₂ dsa₂, 
\q2 a₂léin₂ tág₅ co₂'né'₅, a₂jme₃go₃ dsa₂! 
\p  
\v 13 Ca₂nag₃ jniá₂ ján₃, ca₂le₃jɨ́n₃ i₂chan₂ i₂ca₂jmó'₂ Diú₄ guei'₅₄ mɨ₂güɨ́g₃ quian'₅₄ gua'₅₄ 'uë₃, quian'₅₄ le₃né'₃ 'uë₃; ne₄ jmɨ₁ŋí'₄, i₂chan₂ le₃né'₃ jmɨ₁ŋí'₄ në́₃, i₁juá'₄: 
\q1 ¡Le₃quió'₅ i₂guá₅ ne₄ ne₄ta₁, 
\q2 le₃quió'₅ Guein₂ Já'₂ Cha'₂ në́₃, 
\q1 juɨ₁jme₂go₃ dsa₂ juɨ₁jme₂juag'₂ dsa₂; 
\q1 juɨ₁gue₁₂ a₂tág₅ co₂'né'₅, 
\q1 juɨ₁gue₁₂ juɨ₅bí₂ në́₃ 
\q2 ca₂lia'₂ co₂tan₅₄! 
\p  
\v 14 Jaun₂ ca₂juá'₂ le₃quén₂ já'₂: 
\p ―¡A₂méi₃! 
\p Ta₁guión₂-quén₂ gui'₅₄ can'₅₄ në́₃ qui₂ca₂tóin₂ 'uë₃ qui₂ca₂jme₃juag'₂.\f + \fr 5:14 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “qui₂ca₂jme₃juɨin'₂ i₂chan₂ co₂tan₅₄.” \f* 
\c 6  
\s1 Ca₂niá₃ ta₁guio₃ mɨ₄cuɨng₅ 
\p  
\v 1 Ca₂jág₃ jniá₂ jme₁ca₂niá₃ Guein₂ Já'₂ Cha'₂ jë₁le₂'uɨg₅₄ mɨ₄cuɨng₅ guio₃ jaun₂, ca₂né'₂ i₁juá'₄ jan₂ rɨn'₅₄ i₂quén₂ já'₂ 'éi₂. Né'₂ lë́₅ jág₁ quió'₅ në₂jag₄ bá₄ jë₁quia'₂ ŋí'₃, a₂juá'₂: 
\p ―¡Ŋia₅, jaun₂ jag'₅₄! 
\p  
\v 2 Jaun₂ jme₁ca₂jág₃ jniá₂, jaun₂ ca₂jɨng₅₄ jan₂ i₁cua₁ tion₂. I₂jme₁co₂dsɨn₅₄ já'₂ 'éi₂ në́₃ jme₁chan'₂ caun₂ nɨ₁'ma₂ cág'₅. Jaun₂ ca₂ŋɨi₂ caun₂ corona, jaun₂ ca₂o₃'ɨ́in₃ ŋó₃ ne₄ 'nei₂ a₂tió'₃ a₂lí'₂ 'nei₂. 
\p  
\v 3 Jme₁ca₂niá₃ Guein₂ Já'₂ Cha'₂ jë₁ca₂të́₂ tɨn₃ mɨ₄cuɨng₅, jaun₂ ca₂nag₃ i₁juá'₄ jë₁ca₂të́₂ on₃ já'₂ 'éi₂: 
\p ―¡Ŋia₅, jaun₂ jag'₅₄! 
\p  
\v 4 Jaun₂ ca₂jnia₃ ca₂o₃'ɨ́n₃ táng₃ jan₂ dsɨ₂cua₁ guén₂; dsa₂ i₂jme₁co₂dsag₅₄ guë'₂ në́₃, ca₂ŋɨi₂ bí₂ a₂lé₂ jmo₃ a₂jŋia'₃ a₂'ei₅ tei₄ ta₁caun₂ gua'₅₄ 'uë₃, ia₁jaun₂ jme₃dsian₅ dsa₂ rɨin'₅₄. Jaun₂ 'éi₂ në́₃ ca₂ŋɨi₂ caun₂ ŋi₁tág₂ juë'₂. 
\p  
\v 5 Jme₁ca₂niá₃ Guein₂ Já'₂ Cha'₂ jë₁ca₂të́₂ 'nɨ₅ mɨ₄cuɨng₅, jaun₂ ca₂nag₃ táng₃ i₁juá'₄ i₂ca₂të́₂ ún₂ já'₂: 
\p ―¡Ŋia₅, jaun₂ jag'₅₄! 
\p Jaun₂ jme₁ca₂jág₃ táng₃ jniá₂, ca₂jnia₃ táng₃ jan₂ dsɨ₂cua₁ lian'₂; dsa₂ i₂jme₁co₂dsag₅₄ në́₃, caun₂ mɨ₂gu₂ jme₁chan'₂ caun₂ cua'₅₄ 'éi'₃.  
\v 6 Jaun₂ ca₂né'₂ jág₁ jë₄ quió'₅ le₃quén₂ já'₂, a₂juá'₂: 
\p ―Caun₂ kilo cuɨg₂ bá₄ le₂caun₂ denario; 'nɨ₅ kilo cebada le₂caun₂ denario. La₁ tsá₃ i₂'én₅ aceite quian'₅₄ vino. 
\p  
\v 7 Jme₁ca₂niá₃ Guein₂ Já'₂ Cha'₂ jë₁ca₂të́₂ quén₂ mɨ₄cuɨng₅, jaun₂ ca₂nag₃ i₁juá'₄ jë₁ca₂të́₂ quén₂ já'₂: 
\p ―¡Ŋia₅, jaun₂ jag'₅₄! 
\p  
\v 8 Jme₁ca₂jág₃ jniá₂, ca₂jnia₃ jan₂ dsɨ₂cua₁ nió₂; i₂jme₁co₂dsag₅₄ në́₃, jme₁chein₂ 'Mú₃. Chi₁co'₅₄ quió'₅ 'éi₂ guë'₂ në́₃ já₅ jan₂ i₂të́'₂ Tau₂ 'Ŋio₅.\f + \fr 6:8 \ft griego: hades, co₂'nió'₄ a₂juá'₂, ja₁quió'₄ 'lag₄.\f* Le₃on₃ 'éi₂ në́₃ ca₂ŋɨi₂ bí₂ ne₄ quió'₅ gua'₅₄ 'uë₃ caun₂ qui'₅₄ quió'₅ quén₂, a₂jme₃dsiain₂₃ dsa₂ quian'₅₄ ŋi₁tág₂, quian'₅₄ a₂le₃'on₄ dsa₂, quian'₅₄ jmɨ₁uɨg₅, quian'₅₄ já'₂ tsau₂ dsɨ́₅ në́₃, i₂chan₂ gua'₅₄ 'uë₃. 
\p  
\v 9 Jme₁ca₂niá₃ Guein₂ Já'₂ Cha'₂ jë₁ca₂të́₂ 'ŋiá₂ mɨ₄cuɨng₅, ca₂jág₃ jniá₂ né'₃ ne₄chei₂ ja₁tion'₅₄ jme₂dsí₂ quió'₅ dsa₂ mɨ₂güɨ́g₃ i₂ca₂jme₃dsian₅ dsa₂ ne₄ 'uɨg₅₄ quió'₄ jág₁ dse₃ quió'₅ Diú₄, quian'₅₄ ne₄ 'uɨg₅₄ quió'₄ jág₁ dsau₅ a₂qui₂ca₂can₃.  
\v 10 Jaun₂ tiá₂ né'₂ jág₁ quió'₅ 'éi₂, i₁juá'₄: 
\p ―¿Con'₂ je₂lɨ́g'₂ caun'₅₄ 'í₁, Te₁gui'₅₄ i₂jŋió₅ i₂tí₅ jág₁ quiáng'₂, ja₁con₂ dsa₂ i₂chan₂ gua'₅₄ 'uë₃, jaun₂ caun'₅₄ 'ma'₅₄ jmɨ₂ 'au₅₄ jnia'₅₄? 
\p  
\v 11 Jaun₂ qui₂ca₂ŋɨi₂ le₂jain₂ le₂jain₂ 'mɨ'₂ tiog₂. Jaun₂ ca₂né'₂ i₁juá'₄ a₂jŋia₃ guë́₄ co₂'na₂, të₁lia'₂ le₃'ŋia₅ rɨin'₅₄ i₂jme₂ti₃ ta₁ ne₄ Cristo, i₂'i₄ 'éi'₃ dsián₃ guë́₄, juɨ₁lia'₂ ca₂dsan₃ 'éi₂. 
\p  
\v 12 Jme₁ca₂niá₃ Guein₂ Já'₂ Cha'₂ jë₁ca₂të́₂ jŋéi₂ mɨ₄cuɨng₅, ca₂jág₃ jniá₂ ca₂i₁bi₅₄ 'uë₃ tiá₂ lɨn₃. Ca₂të₁tsɨ'₅₄ qui₁né'₃, ca₂rë₃liá'₃ 'iog₂ në₂jag₄ bá₄ tsɨ₁'mɨ'₂ taun₅ a₂lë́₅ quian'₅₄ nɨ₁jŋi₂, a₂quɨ́'₅ dsa₂ ja₁ron₅ 'lag₄. Tsɨ'₂ guë'₂ në́₃ ca₂jnia₃ guéin₂, lia'₂ jniá₂ jmɨ₂.  
\v 13 Nei₅ guë'₂ në́₃ qui₂tsɨ₂ca₂séi'₂ 'uë₃ në₂jag₄ bá₄ tsɨ₂séi'₂ mɨ́g₂ higo rë'₂ jë₁ma₂ca₂guiong'₃ dsí₂ tiá₂.  
\v 14 Guei'₅₄ dsi₂güɨg₂ në́₃ co₂dsia₅ ca₂i₃'én₂ ca₂bɨn₃ lia'₂ ja₁bɨn₅ mɨ₂si₂. Ca₂le₃jë́₃ nɨ₁má'₂, ca₂le₃jë́₃ 'uë₃ le₁quɨ́'₅ jë₄ jmɨ₁ŋí'₄ në́₃, qui₂ca₂jŋióg'₃ cau₅ ja₁jme₁niog₅.  
\v 15 Jaun₂ qui₂ca₂'ma₃ juɨ₅ né'₃ tau₂ 'lau₂, juɨ₅ jë₄ nɨ₁'lau₂ cha₂ má'₂, juɨ₁lia'₂ rag₅₄ i₂gon₂ gua'₅₄ 'uë₃, juɨ₁lia'₂ dsa₂ dsen₅₄, juɨ₁lia'₂ dsa₂ juɨg₅₄ 'lióg₂, juɨ₁lia'₂ dsa₂ i₂cha₂ cu₄, juɨ₁lia'₂ dsa₂ 'uan'₂, ca₂le₃jɨ́n₃ juɨ₁lia'₂ i₂jme₂ti₃ ta₁ ne₄ juɨg₅₄, juɨ₁lia'₂ dsa₂ i₂tsá₃ 'ein₂ ne₄ jme₂ti₃ në́₃;  
\v 16 qui₂ca₂juá'₂ ca₂tsɨ́'₃ má'₂, nɨ₁'lau₂: 
\p ―Sen'₅₄ 'nia'₂ ne₄ quián₂ jnia'₅₄, 'mog₅₄ jnia'₅₄ ia₁jaun₂ tsá₃ jág₂ i₂guá₅ ne₄ta₁ ó₃, tsá₃ cuë₂ jmɨg₄ a₂'ë́₂ Guein₂ Já'₂ Cha'₂ ó₃ uɨg₅ a₂'nei₂.  
\v 17 Ia₁ në₃ guë́₄ dsón'₂ gua₅ jmɨg₄ a₂'ŋio₅ jaun₂ a₂'ë́₂ uɨg₅ a₂'nei₂. ¿'Ein₂ bá₄ quɨ'₅₄ jmɨg₄ tió'₅? 
\c 7  
\s1 Dsa₂ tsɨ₁jon₂ Israel i₂lɨ́n₅ léi₄ 
\p  
\v 1 Jme₁ma₂ca₂lë₃ jaun₂, ca₂jɨng₅₄ quén₂ ángeles, tióin₂ le₃quén₂ qui'₅₄ mɨ₂güɨ́g₃, a₂jné₅ le₃quén₂ dsí₂ quió'₅ gua'₅₄ 'uë₃, ia₁jaun₂ tsá₃ ma₃lé₂ 'ag₃ dsí₂ ta₁caun₂ ne₄ gua'₅₄ 'uë₃, on₃ guë'₂ ne₄ jmɨ₁ŋí'₄, on₃ guë'₂ ne₄ 'i₁caun₂ nɨ₁'ma₂.  
\v 2 Jaun₂ guë́₄ ca₂jɨng₅₄ jan₂ ángel sián'₂, já₅ të₂le₃ ja₁'ia₂\f + \fr 7:2 \ft Co₂'nió'₄ le₃jua'₅₄, caun₂ cosa a₂tsá₃ 'i₄ jme₂dsí₂, a₂ca₂jmo₃ Diú₄. 'Nio'₂ ja₁ton₅ Salmo 8:3; Romanos 1:25.\f* 'iog₂, já₅ 'éi₂ quian₅ sello quió'₅ Diú₄ jén'₃. Ángel 'éi₂ guë́₄ në́₃ ca₂tsɨ́'₃ le₃quén₂ ángeles i₂jme₁ma₂ŋɨ₂ bí₂ a₂jmo₃ dain₅₄ 'uë₃ quian'₅₄ guë'₂ jmɨ₁ŋí'₄, ca₂juá'₂ tiá₂ lɨn₃: 
\p  
\v 3 ―'A₃ lë₁jmo₂ de'₂ dain₅₄ 'uë₃, on₃ guë'₂ jmɨ₁ŋí'₄, on₃ guë'₂ nɨ₁'ma₂ a₂cha₂ në́₃, ca₂lia'₂ ca₂tiong₅₄ jnia'₅₄ léi₄ quian'₅₄ sello ne₄ chi₁quí₃ dsa₂ i₂jme₂ti₃ ne₄ Diú₄ quián₂. 
\p  
\v 4 Jaun₂ ca₂nag₃ jniá₂ 'a₂ con'₂ tén₅ i₂ca₂lɨn₃ léi₄ 'éi₂; lë́₂ caun₂ 'ŋiá₂-láu₂ rë₂dsɨ́₂ të₂láu₃-quén₂ mei₅ (144,000), jmá'₃ dsa₂ tsɨ₁jon₂ dsa₂ juɨg₂ Israel. 
\q1  
\v 5 Guia₃-tɨ́n₂ mei₅ dsa₂ i₂ca₂lë₃ lén₄ dsa₂ tsɨ₁jon₂ Judá; 
\q2 guia₃-tɨ́n₂ mei₅ dsa₂ tsɨ₁jon₂ Rubén; 
\q2 guia₃-tɨ́n₂ mei₅ dsa₂ tsɨ₁jon₂ Gad; 
\q1  
\v 6 guia₃-tɨ́n₂ mei₅ dsa₂ tsɨ₁jon₂ Aser; 
\q2 guia₃-tɨ́n₂ mei₅ dsa₂ tsɨ₁jon₂ Neftalí; 
\q2 guia₃-tɨ́n₂ mei₅ dsa₂ tsɨ₁jon₂ Manasés; 
\q1  
\v 7 guia₃-tɨ́n₂ mei₅ dsa₂ tsɨ₁jon₂ Simeón; 
\q2 guia₃-tɨ́n₂ mei₅ dsa₂ tsɨ₁jon₂ Leví; 
\q2 guia₃-tɨ́n₂ mei₅ dsa₂ tsɨ₁jon₂ Isacar; 
\q1  
\v 8 guia₃-tɨ́n₂ mei₅ dsa₂ tsɨ₁jon₂ Zabulón; 
\q2 guia₃-tɨ́n₂ mei₅ dsa₂ tsɨ₁jon₂ José; 
\q2 guia₃-tɨ́n₂ mei₅ dsa₂ tsɨ₁jon₂ Benjamín në́₃. 
\s1 Dsa₂ i₂juɨn₅ lɨn₃ le₁qui'₂ 'mɨ'₂ tiog₂ 
\p  
\v 9 Jme₁ca₂lë₃ jaun₂, ca₂jág₃ táng₃ jniá₂, jaun₂ ca₂jnia₃ juɨn₅ lɨn₃ dsa₂, ca₂lia'₂ 'i₁jan₂ tsá₃ 'ein₂ quɨ'₅₄ jmɨg₄ 'ɨ₃ quió'₅: dsa₂ chan₂ ca₂le₃jë́₃ juɨg₂, ca₂le₃jë́₃ tsɨ₁jon₂, ca₂le₃jë́₃ go₄ dsa₂, ca₂le₃jë́₃ jág₁ jmei₅ në́₃. Tióin₂ 'uɨg₅₄ ne₄ta₁ quian'₅₄ ne₄ Guein₂ Já'₂ Cha'₂, i₂le₁qui'₂ 'mɨ'₂ tiog₂, i₂le₁chan'₂ jma₃ca₂nei'₅₄ mog'₅₄ 'ma₂tsɨ́n₅.  
\v 10 Tioin'₅₄ co₂mɨ'₅₄ juá'₂: 
\q1 Juɨ₁lia'₂ a₂lión₂ dsa₂, 
\q2 já₅ quió'₅ Diú₄ quián₂ bá₄ jniog₄ i₂guá₅ ne₄ta₁; 
\q2 já₅ quió'₅ Guein₂ Já'₂ Cha'₂ në́₃. 
\p  
\v 11 Jme₁tión₂ ca₂le₃jɨ́n₃ ángeles le₃lág'₃ ne₄ta₁, le₃lág'₃ quió'₅ gui'₅₄ can'₅₄ quian'₅₄ guë'₂ já'₂ quén₂ 'éi₂. Jaun₂ qui₂ca₂tóin₂ 'uë₃ rë₂'éin₂ co₂ŋei'₅₄, ca₂jme₃juɨin'₂ Diú₄,  
\v 12 a₂juá'₂: 
\q1 ¡A₂méi₃! 
\q1 Le₃quió'₅ Diú₄ quián₂ bá₄ ca₂tɨ́n₂ 
\q2 ca₂le₃jë́₃ a₂jme₃go₃ dsa₂, 
\q2 ca₂le₃jë́₃ a₂léin₂ tág₅ co₂'né'₅, 
\q2 ca₂le₃jë́₃ a₂ŋɨ́'₂ dsɨ́₅, 
\q2 ca₂le₃jë́₃ ti₁'mag'₄, 
\q2 ca₂le₃jë́₃ a₂jme₃juag'₂ dsa₂, 
\q2 ca₂le₃jë́₃ a₂le₃goin₂, 
\q2 ca₂le₃jë́₃ juɨ₅bí₂, 
\q1 ca₂lia'₂ co₂tan₅₄. A₂méi₃. 
\p  
\v 13 Jaun₂ në́₃, jan₂ gui'₅₄ can'₅₄ 'éi₂ ca₂ŋag₃ jniá₂ ca₂juá'₂: 
\p ―¿'Ein₂ bá₄ i₂le₁qui'₂ tsɨn'₅₄ tiog₂ tión₂ në₅? ¿Já'₄ ja₂léin₂? 
\p  
\v 14 Jaun₂ ca₂ŋag₄ jniá₂: 
\p ―Ŋi'₅₄ bá₄ 'ne₂, gui'₅₄. 
\p Jaun₂ ca₂ŋag₃ táng₃ gui'₅₄ 'éi₂: 
\p ―I₂në₅ bá₄ 'éi₂ i₂ma₂ŋɨ₅ Jmɨ₁uɨg₅ Juë'₂; ma₂qui₂ca₂rang₃ tsɨn'₅₄, ma₂jmo₃ tiog₂ në́₃ të₂le₃ quian'₅₄ jmɨ₂ 'an₅₄ Guein₂ Já'₂ Cha'₂.  
\v 15 'Uɨg₅₄ jaun₂ në́₃, 
\q1 tióin₂ ne₄ta₁ në₅ quió'₅ Diú₄, 
\q2 jme₂ti₃ ne₅₄ lia'₂ 'uë₂-jmɨ₂ dsi₂néi₂ guá'₅ në₅ quió'₅; 
\q1 i₂guá₅ ne₄ ne₄ta₁ ó₃ në́₃, 'éi₂ bá₄ jmo₃ 'í₁ 
\q2 në₂jag₄ a₂qui₃jlɨ́in₂ dsa₂ quian'₅₄ 'mɨ'₂ 'én'₁ quió'₅. 
\q1  
\v 16 Tsá₃ ma₃qui₂i₁cón'₅ lé₂, 
\q2 on₃ guë'₂ ma₃qui₃le₃quein₂ dsɨ́₅, i₁'ɨ́n'₂ jmɨg₂, 
\q2 on₃ guë'₂ ma₃qui₃ŋág₂ guë́₄ uɨg₅ 
\q2 jua'₅₄ a₂dséi₂ 'iog₂. 
\q1  
\v 17 Ia₁ Guein₂ Já'₂ Cha'₂ 
\q2 i₂guá₅ dsi₂jo₂ ne₄ta₁ në₅ bá₄ 
\q1 jmo₃ 'í₁ 
\q2 në₂jag₄ dsa₂ i₂jmo₅ 'í₁ já'₂ cha'₂ quián₅, 
\q2 jiog₃ juɨ₅ tu₁ jmɨg₂ ja₁'ia₂ jmɨg₂ jén'₃. 
\q1 Jaun₂ qui₃chí₃ Diú₄ jme₁ne₁₂ 
\q2 ca₂le₃jë́₃ jmɨg₂ a₂le₁'ág₄. 
\c 8  
\s1 Mɨ₄cuɨng₅ jë₁ca₂të́₂ guio₃ 
\p  
\v 1 Jme₁ca₂niá₃ guë'₂ táng₃ Guein₂ Já'₂ Cha'₂ jë₁ca₂të́₂ guio₃ mɨ₄cuɨng₅ quió'₅ mɨ₂si₂ a₂rë₂bɨn₅, jaun₂ ca₂të₁tsɨ'₅₄ tei₄ guei'₅₄ i₂juɨ́g₃ con'₂ ca₂jau₅₄ hora.  
\v 2 Ján₃ bá₄ ca₂jɨn₄ jniá₂ ta₁guion₃ ángeles i₂tión₂ ne₄ Diú₄. 'Éi₂ guë'₂ në́₃ ca₂ŋɨi₂ guio₃ ŋí₂ trompetas.  
\v 3 Cang₂ jaun₂ ca₂já₃ táng₃ jan₂ ángel ca₂o₃náu₃ ne₄chei₂, chi₁chan'₂ caun₂ ŋí₁ tó'₅ chen₂, a₂lë́₅ jmá'₃ cu₄nióg₄. Jaun₂ ca₂ŋɨi₂ 'lióng₂ chen₂, jaun₂ jén'₃ co₂dsia₅ quian'₅₄ jág₁ a₂chi₂lí'₂ ca₂le₃jɨ́n₃ dsa₂ i₂tén₅ le₃quió'₅ Diú₄,\f + \fr 8:3 \ft lit. “ca₂le₃jɨ́n₃ dsa₂ jŋió₅.” \f* dsia₃ ne₄ ne₄chei₂ a₂lë́₅ cu₄nióg₄ a₂chí'₅ 'uɨg₅₄ ne₄ta₁.  
\v 4 Jaun₂ ca₂jŋáu₂ jme₁ŋi₁ chen₂ lia'₂ jma₃quian'₅₄ jág₁ a₂chi₂lí'₂ dsa₂ quián₅ Diú₄, qui₂ca₂'uë₂ o₄gú₃ ángel le₃ne₄ Diú₄.  
\v 5 Jaun₂ ca₂tɨ́n₂ ángel ŋí₁ a₂tó'₅ chen₂, jaun₂ ca₂jme₃cain'₂ mɨ́g₂ si₂tá'₃ tio'₅₄ ne₄chei₂, jaun₂ ca₂guia'₃ jaun₂ në́₃, ne₄ gua'₅₄ 'uë₃. Jaun₂ ca₂lë₃ gau₂ ca₂quia'₂ ŋí'₃, ca₂të₁tsɨ'₅₄ co₂mɨ'₅₄, qui₂ca₂'né'₃ si₁ŋí'₃, ca₂i₁bi₅₄ 'uë₃ në́₃. 
\s1 Ŋí₁ trompetas 
\p  
\v 6 Jaun₂ në́₃, le₃guion₃ ángeles i₂le₁chan'₂ ŋí₁ trompetas, ca₂jmo₃ co₂jŋia₅₄ a₂jéi₂ ŋí₁ quió'₅. 
\p  
\v 7 Jaun₂ ca₂jéi₂ jë₁le₂'uɨg₅₄ ángel ŋí₁ quió'₅, jaun₂ dsɨ₂juɨ₅ le₂jaun₂ ca₂séi'₂ mɨ₂dsɨ́₅ quian'₅₄ mɨ́g₂ si₂tá'₃ a₂qui₂rë₂cón'₅ jmɨ₂, ca₂tang₂ ne₄ gua'₅₄ 'uë₃. Jaun₂ guë́₄ ca₂cáu₂ ca₂qui'₅₄ quió'₅ 'nɨ₅ quió'₅ gua'₅₄ 'uë₃; qui₂ca₂cáu₂ ca₂qui'₅₄ quió'₅ 'nɨ₅ quió'₅ nɨ₁'ma₂ a₂cha₂ 'ŋa₁; qui₂ca₂cáu₂ guë́₄ ca₂le₃jë́₃ nau₂ rë'₂. 
\p  
\v 8 Jaun₂ ca₂jéi₂ jë₁ca₂të́₂ on₃ ángel ŋí₁ quió'₅, jaun₂ ca₂jnia₃ ŋó₃ ca₂quɨ'₃ a₂lë́₅ lia'₂ lë́₅ má'₂ ne₄ jmɨ₁ŋí'₄, jniá₂ chi₁guí'₂ si₂ ŋó₃. Jaun₂ ca₂lë₃ jmɨ₂ ca₂qui'₅₄ quió'₅ 'nɨ₅ quió'₅ jmɨ₁ŋí'₄.  
\v 9 Jaun₂ ca₂dsan₃ ca₂qui'₅₄ quió'₅ 'nɨ₅ juɨ₁lia'₂ já'₂ i₂chan₂ jmɨ₁ŋí'₄, jaun₂ ca₂'en₃ ca₂qui'₅₄ quió'₅ 'nɨ₅ juɨ₁lia'₂ nɨ₁barcos ján₃. 
\p  
\v 10 Jaun₂ ca₂jéi₂ jë₁ca₂të́₂ ún₂ ángel ŋí₁ quió'₅, jaun₂ ca₂tá'₂ caun₂ nei₅ pa₁a chi₁guí'₂ si₂ ca₂tá'₂ guei'₅₄ dsi₂güɨg₂, qui₂cau₂ lia'₂ cau₂ nɨ₁quɨ₂; ca₂tá'₂ ne₄ ca₂qui'₅₄ quió'₅ 'nɨ₅ ca₂le₃jë́₃ cuá₃, ne₄ ca₂le₃jë́₃ o₄tu₁ jmɨg₂ në́₃.  
\v 11 Nei₅ jaun₂ chei₂ Nei₅\f + \fr 8:11 \ft Co₂'nió'₄ le₃jua'₅₄, caun₂ cosa a₂tsá₃ 'i₄ jme₂dsí₂, a₂ca₂jmo₃ Diú₄. 'Nio'₂ ja₁ton₅ Salmo 8:3; Romanos 1:25.\f* Dsi'₃. Jaun₂ ca₂lë₃ dsi'₃ ca₂qui'₅₄ quió'₅ 'nɨ₅ juɨ₁lia'₂ jmɨg₂ cha₂ gua'₅₄ 'uë₃. Jaun₂ juɨn₅ lɨn₃ dsa₂ i₂ca₂dsan₃ ia₁ ca₂'ɨn'₃ jmɨg₂ dsi'₃ jaun₂, 'uɨg₅₄ ia₁ a₂ca₂lë₃ dsi'₃ jmɨg₂. 
\p  
\v 12 Jaun₂ ca₂jéi₂ jë₁ca₂të́₂ quén₂ ángel ŋí₁ quió'₅, jaun₂ ca₂i₃ba₅₄ ca₂qui'₅₄ quió'₅ 'nɨ₅ quió'₅ 'iog₂, ca₂qui'₅₄ quió'₅ 'nɨ₅ quió'₅ tsɨ'₂, ca₂qui'₅₄ quió'₅ 'nɨ₅ juɨ₁lia'₂ nei₅ në́₃, ia₁jaun₂ néi₃ ca₂qui'₅₄ quió'₅ 'nɨ₅ ca₂le₃jë́₃ a₂jaun₂, ia₁jaun₂ tsá₃ ma₃jnia₃ ca₂qui'₅₄ quió'₅ 'nɨ₅ a₂jmɨ₂, ján₃ bá₄ le₂jaun₂ a₂'uë₂. 
\p  
\v 13 Jaun₂ ca₂jág₃ jniá₂ táng₃, ca₂jɨng₅₄ jan₂ i₁mɨg₂ i₂ŋɨ₅ 'en₅ dsi₂güɨg₂, ca₂né'₂ tiá₂ jág₁ quió'₅, i₁juá'₄: 
\p ―¡Juɨ́g₂! ¡Juɨ́g₂! ¡Juɨ́g₂ guë́₄ lɨn₃ juɨ₁lia'₂ i₂chan₂ ne₄ gua'₅₄ 'uë₃, 'uɨg₅₄ ŋí₁ trompetas a₂në₃ guë́₄ dsɨ₃'ein₅₄ a₂jéi₂ le₃ún₂ ángeles i₂'nió'₅ guë́₄ 'éi₂! 
\c 9  
\p  
\v 1 Jaun₂ ca₂jéi₂ jë₁ca₂të́₂ 'ŋiá₂ ángel ŋí₁ quió'₅, jaun₂ ca₂jɨn₄ jniá₂ jan₂ nei₅ i₂ca₂tán'₂ guei'₅₄ i₂juɨ́g₃ ca₂të₂ gua'₅₄ 'uë₃.\f + \fr 9:1 \ft 'Nio'₂ ja₁ton₅ Isaías 14:12-15; Lucas 10:18; Apocalipsis 12:9.\f* Ca₂ŋɨi₂ ŋí₁ llave a₂ca₂tɨ́n₂ quió'₅ ja₁ca₂jein₃ chi₁dsio₅₄.  
\v 2 Dsɨ₂juɨ₅ jme₁ca₂niá₃ 'éi₂ ja₁jaun₂, jaun₂ ca₂'ia₂ jme₁ŋi₁ 'ŋei₂ juɨ₁lia'₂ jme₁ŋi₁ a₂'uë₂ tau₂ si₂ pa₁ lɨn₃ ja₁jme₂jmág₂ dsa₂ nɨ₁ŋí₁. Jaun₂ co₂dsia₅ ca₂lë₃ qui₁né'₃ 'iog₂, dsɨ₄ mɨ₂güɨ́g₃ në́₃ quian'₅₄ jme₁ŋi₁ a₂ca₂'ia₂ ja₁jaun₂.  
\v 3 Jë₄ jme₁ŋi₁ jaun₂ ca₂'uɨn₂ i₁nɨ'₂ ca₂i₁nioi₁₂ tsɨ₁co₂jë́'₂ 'uë₃. I₁nɨ'₂ 'éi₂, ca₂ŋɨi₂ bí₂ a₂lɨ́in₅ juɨ₁lia'₂ lɨ́n₅ i₁'né₅ i₂chan₂ gua'₅₄ 'uë₃.  
\v 4 Jaun₂ ca₂ŋɨi₂ 'éi'₃ a₂tsá₃ dain₅₄ jmo₃ juɨ₁lia'₂ 'au₂ a₂cha₂ gua'₅₄ 'uë₃, on₃ guë'₂ 'i₁caun₂ a₂rë'₂ juɨ₁lia'₂ mog'₅₄ 'ma₂ a₂cha₂ në́₃. Bí₂ jaun₂ bá₄ ca₂ŋɨi₂, a₂jmo₃ dain₅₄ jmá'₃ lia'₂ dsa₂ i₂tsá₃ léi₄ quió'₅ Diú₄ le₁quian₅ chi₁quí₃.  
\v 5 La₁ tsá₃ 'éi'₃ jaun₂ ca₂ŋɨi₂ jua'₅₄ a₂co₂dsia₅ jme₃dsiain₂₃ dsa₂; a₂jŋia'₅₄ con'₂ 'ë₃ jmɨ₁uɨg₅ ca₂lia'₂ ca₂dsɨn₃ 'ŋiá₂ tsɨ'₂. Uɨg₅ a₂cuë₂₃ jaun₂ lë́₅ lia'₂ lë́₅ caun₂ uɨg₅ quɨ'₂ juɨ₁lia'₂ ja₁'ɨ́'₅ i₁'né₅ quió'₅ dsa₂.  
\v 6 Jmɨg₄ jaun₂ qui₃'no'₂ dsa₂ 'mú₃, la₁ tsá₃ a₁jaun₂ dsio'₂. 'Ɨ́n₅ dsɨ́₅ jua'₅₄ dsiáin₃ bá₄ co₂ŋei'₅₄, la₁ 'mú₃ në́₃, cuɨng₃ ja₁coin₂. 
\p  
\v 7 I₁nɨ'₂ 'éi₂ në́₃, jme₁lɨ́n₄ lia'₂ lɨ́n₅ dsɨ₂cua₁ i₂lë́₅ co₂jŋia₅₄ dsɨ₃léin₂ ne₄ 'nei₂. Mɨ₂dsi₅₄ guë'₂ në́₃ jme₁le₁quian₅ a₂lë́₅ lia'₂ lë́₅ coronas a₂lë́₅ cu₄nióg₄. Dsɨ₂ne₄ guë'₂ jme₁lë́₄ lia'₂ lë́₅ dsɨ₂ne₄ dsa₂ mɨ₂güɨ́g₃.  
\v 8 Jŋi₂ dsi₅₄ guë'₂ në́₃, jme₁lë́₄ lia'₂ lë́₅ jŋi₂ dsi₄ dsa₂ mɨ́₂. Mɨ₂jan₅₄ guë'₂ jme₁lë́₄ lia'₂ lë́₅ mɨ₂jan₄ 'ia'₂ león.  
\v 9 Guion₅₄ guë'₂ já'₂ qui₂rë₂lióin₃ rë₂, lë́₅ 'í₁ quian'₅₄ a₂lë́₅ lia'₂ lë́₅ nɨ₁ŋí₁. Mɨ'₅₄ a₂tó'₅ tsɨ₁rë₂cu₅ jë₁ma₂'ɨ́in₂ në́₃, jme₁lë́₄ juɨ₁lia'₂ lë́₅ mɨ'₅₄ a₂tó'₅ 'lióng₂ ŋí₁ carretas a₂'ɨ́n₅ dsɨ₂cua₁ co₂'ei₅ ne₄ 'nei₂.  
\v 10 Ne₁con₅ a₂le₁dsɨ₅₄ guë'₂ në́₃, jme₁lë́₄ juɨ₁lia'₂ lë́₅ ne₁con₅ i₁'né₅ le₁dsɨ₅₄ táun₂. Juɨ₅ nei'₅₄ con₅ jaun₂, 'io₅ bí₂ a₂le₃jmái'₂ dain₅₄ dsa₂, con'₂ 'ŋiá₂ tsɨ'₂.  
\v 11 Ne₄ i₁nɨ'₂ 'éi₂ jme₁gon₂ jan₂ rag₅₄, i₂lɨ́n₅ ángel i₂niog₅ ne₄ ja₁ca₂jein₃ chi₁dsio₅₄. Jme₁chein₂ Abadón quian'₅₄ jág₁ jmei₅ hebreo. Le₃quian'₅₄ jág₁ jmei₅ griego guë'₂, chein₂ Apolión, co₂'nió'₄ i₂të́'₂ I₂qui₂'én₂. 
\p  
\v 12 Le₂'uɨg₅₄ jmɨ₁uɨg₅ ma₂ca₂ŋag₅; la₁ 'ei₅ guë́₄ con'₂ guë́₄ tɨn₃, a₂në₅ guë́₄ ŋág₃ dsa₂. 
\p  
\v 13 Jaun₂ ca₂jéi₂ jë₁ca₂të́₂ jŋé₂ ángel ŋí₁ quió'₅. Jaun₂ ca₂nag₃ jág₁ a₂'ia₂ jë₄ ta₁quén₂ gua₄ a₂le₁dsɨ₅₄ ne₄chei₂ a₂lë́₅ cu₄nióg₄ a₂chí'₅ ne₄ Diú₄.  
\v 14 Ca₂juá'₂ ca₂tsɨ́'₃ ángel i₂jë₁ca₂të́₂ jŋé₂ 'éi₂, i₂chan'₂ ŋí₁ trompeta, ca₂juá'₂: 
\p ―'Uɨn'₅₄ le₃quén₂ ángeles i₂le₁'ŋe'₅₄ cau₅ cuá₃ juë'₂ Eufrates. 
\p  
\v 15 Jaun₂ qui₂ca₂'uɨn'₂ le₃quén₂ ángeles 'éi₂ i₂jme₁lë́₄ 'í₁ o₄quió'₄ hora la₂, jmɨg₄ në₃, tsɨ'₂ la₂, ŋi₂ la₂ në́₃, i₂jme₁lë́₄ co₂jŋia₅₄ ia₁jaun₂ i₂jme₁dsiain₂₃ ca₂qui'₅₄ quió'₅ 'nɨ₅ juɨ₁lia'₂ dsa₂ mɨ₂güɨ́g₃.  
\v 16 Jmá'₃ lia'₂ 'lióg₂ i₂co₁dsɨn₅₄ cua₁, tén₅ tɨn₃ 'ŋiá₂-lón₂ millón. Ca₂nag₃ bá₄ jniá₂ 'a₂ con'₂ téin₅ lë́₂. 
\p  
\v 17 Le₂në₅ bá₄ ca₂jág₃ a₂lë₁ca₂jág₃ jaun₂, qui₂ca₂jɨng₅₄ cua₁ quian'₅₄ dsa₂ i₂co₁dsag₅₄ 'éi₂. Le₁lióg₃ le₁dsɨ́₅ dsa₂ jma₃cáun₃ a₂lë́₅ 'í₁ a₂jniá₂ guéin₂, a₂lian₂, quian'₅₄ guë'₂ a₂nióg₂ lia'₂ nióg₂ azufre. Mɨ₂dsi₄ dsɨ₂cua₁ guë'₂ në́₃, jniá₂ lia'₂ jniá₂ mɨ₂dsi₄ 'ia'₂ león. Juɨ₅ mɨ₂'o₅₄ guë'₂ në́₃ 'ia₂ si₂, 'ia₂ jme₁ŋi₁, azufre në́₃.  
\v 18 Jaun₂ ca₂dsan₃ ca₂qui'₅₄ quió'₅ 'nɨ₅ juɨ₁lia'₂ dsa₂ mɨ₂güɨ́g₃ quian'₅₄ 'nɨ₅ jmɨ₁uɨg₅ a₂qui₂ca₂'uë₂ mɨ₂'o₄ dsɨ₂cua₁ 'éi₂: a₂lë́₅ si₂, jme₁ŋi₁, quian'₅₄ azufre në́₃.  
\v 19 Ia₁ bí₂ a₂jme₁le₁quian₅ dsɨ₂cua₁ jme₁'io₂₃ juɨ₅ mɨ₂'o₅₄ quian'₅₄ juɨ₅ ne₁con₅ në́₃. Ia₁ jme₁lë́₄ nei'₅₄ con₅ 'éi₂ lia'₂ lɨ́n₅ dsɨ₂mɨ'₂, a₂qui₂le₁dsɨ₅₄ mɨ₂dsi₅₄. Quian'₅₄ a₂jaun₂ jmo₂₃ dain₅₄. 
\p  
\v 20 Dsa₂ i₂ca₂chón₂, i₂tsá₃ ca₂dsan₃ quian'₅₄ jmɨ₁uɨg₅ a₂qui₂ca₂lë₃ jaun₂, tsá₃ jua'₅₄ jaun₂ qui₂ca₂tí₂ 'e₂ jmo₅-dsáu₅ gu₂-tag₅₄, jua'₅₄ a₂tsá₃ ma₃chi₂léin'₂ je₂na'₅₄, on₃ guë'₂ qui₂ca₂tí₂ a₂tsá₃ ma₃jme₂juɨin'₂ diú₄ lag₄ i₂lɨ́n₅ quian'₅₄ cu₄nióg₄ quian'₅₄ cu₄tiog₂, quian'₅₄ nɨ₁ŋí₁ nióg₂, quian'₅₄ nɨ₁cang₁, quian'₅₄ nɨ₁'ma₂ në́₃; on₃ i₂lé₂ ŋɨ₃, on₃ i₂lé₂ dsia₃ jág₁, on₃ i₂lé₂ jág₃, on₃ guë'₂ lé₂ nag₃ në́₃.  
\v 21 On₃ guë'₂ qui₂ca₂tí₂ jua'₅₄ a₂tsá₃ ma₃jme₃dsiain₂₃ dsa₂ mɨ₂güɨ́g₃ rɨin'₅₄, on₃ guë'₂ qui₂ca₂tí₂ ta₁ a₂jme₁jmo₂₃ mɨ́₅ a₂chan₂ dsɨ́₅.\f + \fr 9:21 \ft griego: farmakeía.\f* On₃ guë'₂ qui₂ca₂tí₂ jua'₅₄ tsá₃ ma₃nió'₅ jág₁ a₂tsá₃ dsi₂ten₅₄ nió'₃, on₃ guë'₂ qui₂ca₂tí₂ jua'₅₄ a₂tsá₃ ma₃'ang₃ në́₃. 
\c 10  
\s1 Mɨ₂si₂ pí'₁ rë₂bɨn₅ 
\p  
\v 1 Jaun₂ ca₂jɨng₅₄ táng₃ jan₂ ángel sián'₂, i₂'uan'₂ lɨn₃, ca₂jniai₃ já₅ ca₂sióin₃ guei'₅₄ i₂juɨ́g₃, rë₂lióin₃ jnei₅ rë₂lag₄ lí₁ lia'₂ jniá₂ mɨ₂jo'₅₄ si₂ mɨ₂dsi₅₄. Jme₁tág₅ dsɨ₂ne₅₄ lia'₂ tág₅ 'iog₂; mɨ₂tag₅₄ guë'₂ në́₃, jme₁lë́₄ lia'₂ lë́₅ tag₄ dsɨ₅ nɨ₁'ia'₂, a₂tág₅ si₂.  
\v 2 Jme₁chi₁chan'₂ caun₂ mɨ₂si₂ pí'₁ a₂rë₂bɨn₅, a₂rë₂na₄. Jaun₂ ca₂chi'₃ mɨ₂tag₅₄ ne₁ ne₄ jmɨ₁ŋí'₄, tag₅₄ jen₅ guë'₂ ca₂chi'₃ ne₄ 'uë₃.  
\v 3 Jaun₂ ca₂guió'₃ tiá₂, lia'₂ jë₁'ŋióg₁ 'ia'₂ león. Jaun₂ dsɨ₂juɨ₅ jme₁ca₂guió'₃, ca₂quia'₂ ta₁guio₃ ŋí'₃, qui₂ca₂'uë́'₃ jág₁ quió'₅.  
\v 4 Jme₁ma₂në₂dsia₃ jág₁ ta₁guio₃ ŋí'₃, jaun₂ guë́₄ jme₁ma₂taun₅₄ ne₄ si₂. La₁ ca₂né'₂ jág₁ a₂já₃ guei'₅₄ i₂juɨ́g₃, ca₂juá'₂ tság₅ jniá₂: 
\p ―'Ma₄ jág₁ a₂në₂juá'₂ guio₃ ŋí'₃ në₅, 'a₃ lë₁taun₂ de'₂ ne₄ si₂. 
\p  
\v 5 Jaun₂ ángel i₂ca₂jɨng₅₄, i₂chén'₅ chí'₅ caun₂ tag₅₄ ne₄ jmɨ₁ŋí'₄ caun₂ guë'₂ tag₅₄ ne₄ 'uë₃, ca₂chóg'₃ gu₂ ne₁ juɨ₅ guei'₅₄ i₂juɨ́g₃.  
\v 6 Jaun₂ ca₂juá'₂ ca₂'ɨin₃ i₂chan₂ co₂tan₅₄, i₂ca₂jmo₃ ca₂dsia₃ mɨ₂güɨ́g₃, quian'₅₄ ca₂le₃jë́₃ a₂tio'₅₄ ja₁jaun₂, i₂ca₂jmo₃ guei'₅₄ mɨ₂güɨ́g₃ quian'₅₄ ca₂le₃jë́₃ a₂tio'₅₄ ja₁jaun₂, i₂ca₂jmo₃ jmɨ₁ŋí'₄, quian'₅₄ ca₂le₃jë́₃ a₂tio'₅₄ ja₁jaun₂; ca₂juá'₂: 
\p ―Tsá₃ ma₂uë́₂ le₃'ag₄.  
\v 7 La₁ jë₁ma₂të́₂ jmɨg₄ jë₁ma₂ca₂jéi₂ ángel i₂ca₂të́₂ guion₃ 'éi₂ ŋí₁ trompeta quió'₅, jmɨg₄ jaun₂ dé₄ dsón'₂ le₃ti₃ jág₁ a₂rë₂'ma₄ quió'₅ Diú₄, a₂ca₂'ë́₂ ne₄ dsa₂ i₂jme₁'ë́₂ jág₁ quiáin₅, i₂ca₂jme₃ti₃ ta₁ ne₅₄. 
\p  
\v 8 Jaun₂ jág₁ a₂ca₂nag₃ a₂já₅ guei'₅₄ i₂juɨ́g₃ jaun₂, ca₂juá'₂ táng₃ ca₂tság₃ jniá₂: 
\p ―Gua₂, o₂quian₂ mɨ₂si₂ pí'₁ a₂rë₂na₄ a₂chi₁chan'₂ ángel i₂chén'₅ ne₄ jmɨ₁ŋí'₄, ne₄ gua'₅₄ 'uë₃. 
\p  
\v 9 Jaun₂ ŋó₃ jniá₂ ja₁chén'₄ ángel, jaun₂ ca₂juɨ́g₂ jniá₂ a₂cuë₃ mɨ₂si₂ pí'₁. Jaun₂ ca₂juá'₂ 'éi₂ ca₂tság₃ jniá₂: 
\p ―Ján'₅, tio'₂ mɨ₂'o'₅₄ co₂dsia₅ jme₁dsia₂ qué'₂. A₂jmá₂ rau₂ bá₄ në₅, la₁ jë₁ma₂dsióg₃ të₂'au'₂, le₃dsi'₃ bá₄. 
\p  
\v 10 Jaun₂ ca₂tɨ́ng₂ si₂ a₂ca₂cuë₃ ángel 'éi₂. Jaun₂ ca₂tó'₃ mɨ₂'o₃. Dsón'₂ bá₄ ráu₂ 'ŋio₅ lɨn₃, lë́₅ lia'₂ lë́₅ jmɨ₁tá'₄. La₁ jme₁ma₂në₂nág'₃ jniá₂ në́₃, ca₂rë₃léi₄ 'e₂ bá₄ dsi'₃ ca₂dsióg₃ të₂dsɨ₃.  
\v 11 Jaun₂ ca₂juá'₂ ca₂tság₃ jniá₂: 
\p ―Tion₅₄ 'nió'₅ o₁'ë́'₃ bá₄ táng₃ 'ne₂ jág₁ ne₄ ca₂le₃jɨ́n₃ ne₅₄ dsa₂, ne₄ 'lióng₂ juɨg₂, ne₄ 'lióng₂ jág₁ jmei₅, ne₄ juɨn₅ rag₅₄ në́₃. 
\c 11  
\s1 Le₃on₃ dsa₂ i₂jáng'₅ jág₁ dsau₅ 
\p  
\v 1 Jaun₂ ca₂ŋɨg₂ ca₂'nau₅₄ 'ma₂ta₅ a₂lë́₅ lia'₂ lë́₅ nɨ₁'ma₂ a₂quiog₂ dsa₂ 'éi'₃. Jaun₂ ca₂nag₃ ca₂juá'₂: 
\p ―Nau₂, o₂quiog₂ 'éi'₃ quió'₅ guá'₅ quió'₅ Diú₄, o₂quiog₂ 'éi'₃ ne₄chei₂ në́₃. O₁'én₁ dsa₂ i₂tón'₅ jme₂juɨn'₂ Diú₄ ja₁jaun₂.  
\v 2 Tsá₃ cán'₁ 'éi'₃ i₁dsi₅ guá'₅ a₂lë́₅ le₃ca₁'né₄, ia₁ a₂ma₂lë́₅ quió'₅ dsɨ₂nau₂ bá₄ ja₁jaun₂; jaun₂ 'éi₂ bá₄ dsa₂ i₂qui₃tsó'₃ ta₁caun₂ juɨg₂ jŋió₅ jaun₂ con'₂ ca₂dsɨn₃ të₂láu₃-tɨn₃ tsɨ'₂.  
\v 3 Tsɨn₅₄ bá₄ jniá₂ on₃ dsa₂ i₂jáng'₅ jág₁ dsau₅ o₄quió₃, a₂qui₃'ë́₂ jág₁ caun₂ mei₅ rë₂dsɨ́₂ tɨn₃ 'ŋiá₂-láu₂ rë₂dsɨ́₂ 'nag'₂ ne₂guióg₂ (1260) jmɨg₄, le₁qui'₂ 'mɨ'₂ lia'₂ juɨ₁lia'₂ a₂quɨ́'₅ dsa₂ ja₁ron₅ 'lag₄. 
\p  
\v 4 Co₂'nió'₄ dsa₂ on₃ i₂jáng'₅ jág₁ dsau₅, lë́₅ co₂'nió'₄ tɨn₃ nɨ₁'ma₂ olivos, quian'₅₄ guë'₂ tɨn₃ tag₄ ja₁le₁guí'₂ si₂, a₂tióng₂ ne₄ Te₁gui'₅₄ i₂lɨ́n₅ juɨg₅₄ gua'₅₄ 'uë₃.  
\v 5 Në₁jua'₂ 'ein₂ 'nio₃ jmóg'₂ dain₅₄, la₁ quian'₅₄ si₂ a₂'uë́'₅ 'o₄ bá₄ 'éi₂ co₂dsia₅ dság'₂ dsɨ́in'₂ ca₂le₃jɨ́n₃ i₂'iog₅₄. Jaun₂ le₂në₅ bá₄ ca₂tɨ́n₂ dsián₃ juɨ₁lia'₂ i₂'nio₃ jmá'₂ dain₅₄ 'éi₂.  
\v 6 I₂jáng'₅ jág₁ dsau₅ 'éi₂ në́₃ 'io₃ bí₂ a₂lé₂ jnéi₂ guei'₅₄ mɨ₂güɨ́g₃ ia₁jaun₂ tsá₃ ma₃lé₂ téin₃ jmɨ́₅ ca₂le₃jë́₃ jmɨg₄ të₁lia'₂ të₂i₃nioi₅₄ qui₃'ë́₂ jág₁ o₄quió'₄ Diú₄. Jaun₂ 'io₃ bí₂ ján₃ a₂lé₂ le₃jmo₃ lé₂ jmɨ₂ juɨ₁lia'₂ jmɨg₂, a₂lé₂ qui₃cuë₃ ca₂le₃jë́₃ ne₅₄ jmɨ₁uɨg₅ ne₄ gua'₅₄ 'uë₃ i₂gú'₃ ráun₂ 'a₂ con'₂ jŋia'₅₄ 'nio₃.  
\v 7 La₁ jë₁ma₂dsan₃ ta₁ quió'₅ 'éi₂ në́₃ a₂qui₃jáng'₃ jág₁ dsau₅, jaun₂ guë́₄ o₃'ɨn₅ Já'₂ 'Lɨn'₅₄\f + \fr 11:7 \ft 'Í₂ Apocalipsis 13; 'Nio'₂ ja₁ton₅ Apocalipsis 20:2-3 ján₃.\f* ja₁ca₂jein₃ chi₁dsio₅₄. 'Éi₂ guë́₄ cuë₃, jo₅₄, jme₃dsiog₂₃.  
\v 8 Jë₄ calle juɨg₂ dsen₅₄ jaun₂, le₁gain'₅₄ le₁'lɨin₁₂ lé₂, co₂'nió'₄ ja₁chei₂ quian'₅₄ jág₁ jáng'₅ léi₄, Sodoma quian'₅₄ Egipto, ján₃ bá₄ ja₁ca₂tion₃ dsa₂ cróg₄ Te₁gui'₅₄ quiáin₅.\f + \fr 11:8 \ft A₂lɨn₅₄ chog₅₄ si₂: “Te₁gui'₅₄ quián₂.” \f* 
\v 9 Con'₂ 'nɨ₅ jmɨg₄ rë₂tón₂ con'₂ dsi₃ŋí'₃, ca₂le₃jɨ́n₃ dsa₂ chan₂ le₂con₂ juɨg₂, ca₂le₃jɨ́n₃ ne₅₄ dsa₂, ca₂le₃jë́₃ ne₅₄ jag₄ dsa₂, jág₃ jɨ́in₂ 'lag₄ 'éi₂. La₁ tsá₃ 'ein₂ ŋe₂ jmɨg₄ jua'₅₄ a₂dsɨ₃'ó₃.  
\v 10 Ca₂le₃jɨ́n₃ dsa₂ i₂chan₂ guë́₄ gua'₅₄ 'uë₃, 'ŋio₅ tóin'₃ jmo₃ 'io'₂ o₄quió'₄ 'éi₂, jmo₃ jmɨg₄ a₂cha₂ qui₂dsɨ₃can₅ cuë́'₃ rɨin'₅₄. Ia₁ dsa₂ on₃ quián₅ Diú₄ i₂ca₂dsan₃ 'éi₂, 'ŋio₅ lɨn₃ jme₁le₁quian₅ jmɨ₁uɨg₅ ja₁con₂ dsa₂ i₂chan₂ gua'₅₄ 'uë₃.  
\v 11 La₁ jme₁ca₂dsɨn₃ 'nɨ₅ jmɨg₄ tón₂ con'₂ dsi₃ŋí'₃ jaun₂, Diú₄ në́₃ ca₂tó'₂ táng₃ jme₂dsí₂ quió'₅ dsa₂ 'éi₂, jaun₂ qui₂ca₂nau₂ táng₃. Jaun₂ ca₂i₃gó'₃ dsɨ́₅ 'ŋio₅ lɨn₃ dsa₂ i₂ca₂jág₂.  
\v 12 Jaun₂ qui₂ca₂nág₂ jág₁ tiá₂ a₂já₅ juɨ₅ guei'₅₄ i₂juɨ́g₃ a₂ca₂juá'₂: 
\p ―I₂nó'₅ 'nia'₂ guei'₅₄ la₂. 
\p Jaun₂ ca₂i₃léin₂ juɨ₅ guei'₅₄ i₂juɨ́g₃ rë₂lióin₃ jnei₅, të₃ jág₅ jaun₂ dsa₂ i₂jme₁'iog₅₄.  
\v 13 Hora jaun₂ dé₄ ca₂i₁bi₅₄ 'uë₃ tiá₂ lɨn₃. Jaun₂ qui₂ca₂gon₃ ca₂qui'₅₄ quió'₅ guia₃ juɨg₂ ciudad. Guio₃ mei₅ dsa₂ i₂ca₂dsan₃ jme₁ca₂jë́'₂ 'uë₃. Dsa₂ i₂ca₂chón₃ guë́₄ në́₃, qui₂ca₂can₃ juë́'₅ dsɨ́₅ 'ŋio₅ lɨn₃. Ca₂jme₃juɨin'₂ Diú₄ i₂guá₅ guei'₅₄ i₂juɨ́g₃. 
\p  
\v 14 Jaun₂ co₂në₅ ca₂lë₃ jë₁ca₂të́₂ tɨn₃ jmɨ₁uɨg₅ a₂ca₂i₃ŋɨ́₂ dsa₂ jaun₂. La₁ ŋi'₅₄ ta₁ jiá₃ táng₃ jë₁ca₂të́₂ 'nɨ₅. 
\s1 Jë₁ca₂të́₂ guio₃ trompeta 
\p  
\v 15 Jaun₂ ca₂jéi₂ táng₃ jë₁ca₂të́₂ guion₃ ángel ŋí₁ quió'₅, jaun₂ qui₂ca₂né'₂ jág₁ guei'₅₄ i₂juɨ́g₃ qui₂i₁juá'₄ tiá₂ lɨn₃: 
\q1 Ja₁gon₂ dsa₂ mɨ₂güɨ́g₃ ne₄ gua'₅₄ 'uë₃, 
\q2 ma₂ca₂lë₃ ja₁gon₂ Te₁gui'₅₄ quián₂ jniog₄, 
\q2 ja₂gon₂ dsa₂ I₂rë₂'ɨ́n₁ quiáin₅ në́₃. 
\q1 Jaun₂ 'éi₂ bá₄ i₂gon₃ ca₂lia'₂ co₂tan₅₄. 
\p  
\v 16 Jaun₂ ta₁guión₂-quén₂ i₂lɨ́n₅ dsa₂ can'₅₄ i₂tián'₅ ne₄ta₁ quió'₅ ne₄ Diú₄, qui₂ca₂tóin₂ të₂ 'uë₃ rë₂'éin₂ co₂ŋei'₅₄, ca₂jme₃juɨin'₂ Diú₄,  
\v 17 qui₂ca₂juá'₂: 
\q1 Cuë₂ jnia'₅₄ ti₁'mag'₄ 'ne₂, 
\q2 Te₁gui'₅₄ Diú₄ i₂'Uan'₂ guë́₄ lɨn₃, 
\q2 'ne₂ bá₄ i₂lɨ́ng'₅, 'ne₂ i₂jme₁lɨ́ng'₄,\f + \fr 11:17 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ ján₃: “'ne₂ bá₄ i₂lén'₂ ján₃.” \f* 
\q1 ia₁ ma₂ca₂jme₁'ŋió'₂ 'ne₂ bí₂ juë'₂ quiáng'₂, 
\q2 ma₂ca₂jme₁lióg'₄ gong'₂. 
\q1  
\v 18 Jme₁qui₂nau₂ 'nei₂ juɨg₂ gua'₅₄ 'uë₃, 
\q2 la₁ në₃ guë́₄ já₅ 'nei₂ a₂'i₄ 'au'₂, 
\q2 ia₁ ma₂ca₂të́₂ jmɨg₄ a₂qui₁dsɨ'₂ 'éi'₃ ja₁con₂ 'lag₄. 
\q1 Ton'₂ ca₂të́₂ jmɨg₄ ja₁quɨ'₅₄ 'lian'₅₄ dsa₂ quiáng'₂ 
\q2 i₂ca₂jme₃ti₃ ta₁ ne'₅₄ 
\q2 i₂qui₂ma₂'ë́₂ jág₁ quiáng'₂. 
\q1 Le₂jaun₂ guë'₂ i₂jme₂go₃ 'a₂ lia'₂ lɨ́n'₅ 'ne₂ 
\q2 lia'₂ dsa₂ can'₅₄, lia'₂ dsa₂ me'₂. 
\q1 Ján₃ guë'₂ ca₂të́₂ jmɨg₄ a₂'éng'₄ 
\q2 juɨ₁lia'₂ i₂qui₂'én₂ ne₄ gua'₅₄ 'uë₃. 
\p  
\v 19 Jaun₂ guë́₄ ca₂niá₃ dsi₂néi₂ guá'₅ quió'₅ Diú₄ guei'₅₄ i₂juɨ́g₃. Ca₂jnia₃ tsɨ₁gu₅ quió'₅ jág₁ a₂lɨ'₅₄ quian'₅₄ Diú₄ dsi₂néi₂ guá'₅ quió'₅. Të₃jë₄ jaun₂ qui₂ca₂lë₃ si₁ŋí'₃, qui₂ca₂né'₂ jág₁, qui₂ca₂quia'₂ ŋí'₃, qui₂ca₂i₁bi₅₄ 'uë₃, qui₂ca₂séi'₂ dsɨ́₅ ca'₅₄. 
\c 12  
\s1 Jan₂ dsa₂ mɨ́₂ quian'₅₄ cua₁ dragón 
\p  
\v 1 Jaun₂ ca₂jnia₃ guei'₅₄ i₂juɨ́g₃ caun₂ léi₄ juë'₂ a₂dsɨ₃gó'₃ dsɨ₅: jan₂ 'io₅₄ i₂rë₂lión₃ co₂tág₅ lia'₂ jniá₂ 'iog₂. Le₃né'₃ ja₁chéin'₄ ton₅ tsɨ'₂. Caun₂ guë'₂ corona 'i₄ dsi₅₄, le₁ton₅ guia₃-tɨ́n₂ nei₅.  
\v 2 'Io₅₄ 'éi₂ quiain₂₃ guein₂, a₂guió'₅ co₂mɨ'₅₄ a₂chain₂ uɨg₅ a₂le₃chan₂ guein₂.  
\v 3 Jaun₂ guë́₄ ca₂jnia₃ léi₄ siá'₂ táng₃ guei'₅₄ i₂juɨ́g₃: jan₂ cua₁ dragón\f + \fr 12:3 \ft griego: drakón (dsɨ₂mɨ'₂).\f* guén₂ i₂pan₅₄ lɨn₃ i₂quian₅ guio₃ mɨ₂dsi₄ quian'₅₄ guia₃ mɨ₂juɨ́₁. Jma₃cáun₃ corona tio'₅₄ lia'₂ ca₂mɨ́g₂ mɨ₂dsi₅₄.  
\v 4 Quian'₅₄ ne₁con₅ já'₂ 'éi₂ qui₂ca₂tsë́'₃ ca₂qui'₅₄ quió'₅ 'nɨ₅ juɨ₁lia'₂ nei₅ i₂jme₁le₁'ɨ́n₄ guei'₅₄, jaun₂ qui₂ca₂guiain'₃ ne₄ gua'₅₄ 'uë₃. Jaun₂ ca₂nau₂ cua₁ dragón ne₄ 'io₅₄ i₂jë₁ca₂rë₃chán₃ guein₂, ia₁jaun₂ quɨin'₂ guein₂ dsɨ₂juɨ₅ jë₁ma₂ca₂rë₃cháin₃.  
\v 5 Ca₂rë₃chán₃ rë'₂ guein₂ quiáin₅, jan₂ guein₂ dsa₂ ŋe'₂ i₂'i₄ 'éi'₃ gon₃ ne₄ ca₂le₃jë́₃ juɨg₂ quian'₅₄ 'ma₂'ɨ'₅₄ a₂lë́₅ nɨ₁ŋí₁ 'ua'₂.\f + \fr 12:5 \ft 'Nio'₂ ja₁ton₅ Salmo 2:9.\f* Jaun₂ ca₂jŋia'₃ bá₄ guein₂ 'éi₂ ca₂tág₃ Diú₄ i₃guá₃ ne₄ta₁ quió'₅.  
\v 6 Jaun₂ ca₂cuɨng₃ 'io₅₄ juɨ₅ 'uë₃ quein₂ co₂'ŋiog₅ ja₁ma₂lë́₅ co₂jŋia₅₄ quió'₅ Diú₄, ia₁jaun₂ le₃tain₅₄ ca₂lia'₂ ca₂dsɨn₃ caun₂ mei₅ rë₂tón₂ tɨn₃ 'ŋiá₂-láu₂ rë₂dsɨ́₂ 'nag'₂ ne₂guióg₂ (1260) jmɨg₄. 
\p  
\v 7 Jaun₂ ca₂lë₃ 'nei₂ guei'₅₄ i₂juɨ́g₃: ca₂jmo₃ 'nei₂ Mi₂gue₅₄ quiain'₅₄ ángeles quiáin₅, ca₂quɨ́in'₂ ca₂cuë́'₃ cua₁ dragón. Ján₃ guë'₂ le₂jaun₂ ca₂jéin'₃ dragón quiain'₅₄ ángeles quiáin₅.  
\v 8 La₁ tsá₃ ca₂tió'₃, jaun₂ tsá₃ ma₃ja₁ca₂rë₃chá₃ guë́₄ ja₁cuɨn₅ jmɨg₄ tóin'₃ guei'₅₄ i₂juɨ́g₃.  
\v 9 Jaun₂ ja₁jaun₂ ca₂jŋia'₃ cau₅ dragón juɨn'₂ 'éi₂, dsɨ₂mɨ'₂ gui'₅₄ i₂jme₁chan₂ ma₂lɨ́g'₂, i₂të́'₂ i₂së₃dsen₃, i₂chen₂ Satanás në́₃, i₂jme₂gan₅ dsa₂ ta₁caun₂ mɨ₂güɨ́g₃. Ca₂i₃gain'₅₄ ca₂të₂ gua'₅₄ 'uë₃, lia'₂ jma₃quiain'₅₄ ángeles quiáin₅.\f + \fr 12:9 \ft 'Nio'₂ ja₁ton₅ Isaías 14:12-15; Lucas 10:18; Apocalipsis 9:1.\f* 
\p  
\v 10 Jaun₂ ca₂né'₂ jág₁ tiá₂ guei'₅₄ i₂juɨ́g₃, i₁juá'₄: 
\q1 Në₃ guë́₄ ca₂të́₂ jmɨg₄ quió'₅ Diú₄ a₂lión₂ dsa₂, 
\q2 ca₂dsióg₃ jmɨg₄ ja₁lé₂ juɨ₅bí₂ 'éi'₃ quió'₅ Diú₄ quián₂ 
\q2 a₂gon₂ 'éi₂ quiain'₅₄ I₂rë₂'ɨ́n₁ quiáin₅. 
\q1 Ia₁ ca₂guiain'₃ 'uë₃ i₂jme₁bóg'₂ dso₄ quió'₅ rɨn'₅₄ jniog₄ 
\q2 le₃ne₄ Diú₄ lia'₂ 'uë₂-jmɨ₂. 
\q1  
\v 11 Ca₂tió'₃ bá₄ 'éi₂ 
\q2 të₂le₃ quian'₅₄ jmɨ₂ 'an₅₄ Guein₂ Já'₂ Cha'₂, 
\q2 të₂le₃ quian'₅₄ jág₁ dsau₅ në́₃ 
\q2 a₂ma₂qui₂ma₂jáng'₃ 'éi₂; 
\q1 ia₁ tsá₃ ca₂dsán₃ dsɨ́₅ jme₂dsí₂ quió'₅ 
\q2 o₁jŋia'₅₄ ca₂dsain₃. 
\q1  
\v 12 Jaun₂ lë₃, 'io'₂ jmo₄ 'nia'₂ i₂juɨ́g₃, 
\q2 quian'₅₄ guë'₂ 'nia'₂ i₂tián'₅ ja₁jaun₂. 
\q1 ¡La₁ 'e₂ guë́₄ juɨ́g₂ juɨ₁lia'₂ i₂chan₂ gua'₅₄ 'uë₃, 
\q2 quian'₅₄ guë'₂ i₂chan₂ né'₃ jmɨ₁ŋí'₄! 
\q1 Ia₁ ma₂sión₃ i₂së₃dsen₃ ja₁con'₂ 'nia'₂; 
\q2 ma₂'i₄ 'nei₂ dsɨ́₅, ia₁ ma₂ŋi₅ rë₂ bá₄, 
\q2 ca₂juɨg₄ jmá'₅ jmɨg₄ cha₂ guë́₄ quió'₅. 
\p  
\v 13 Jme₁ca₂rë₃lí'₄ dragón a₂ma₂ŋó₅ juɨ₅ gua'₅₄ 'uë₃, jaun₂ 'éi₂ në́₃ ca₂'ein₃ 'io₅₄ i₂ca₂rë₃chán₃ guein₂ dsa₂ ŋe'₂ quián₅.  
\v 14 La₁ 'io₅₄ 'éi₂ në́₃, ca₂ŋɨi₂ tsɨ₁rë₂cu₅ ca₁ca'₅₄ a₂lë́₅ lia'₂ lë́₅ tsɨ₁rë₂cu₅ i₁mɨg₂, ia₁jaun₂ 'ɨin₃ juɨ₅ ja₁quió'₄, ja₁lë́₄ 'uë₃ quein₂ co₂'ŋiog₅, ja₁lë́₄ 'í₁ 'nɨ₅ ŋi₂ të₂ ca₂jau₅₄ le₃ne₄ dsɨ₂mɨ'₂.  
\v 15 Jaun₂ ca₂'uë́'₃ dsɨ₂mɨ'₂ jmɨg₂ juɨ₅ mɨ₂'o₅₄, në₂jag₄ bá₄ caun₂ cuá₃ juë'₂, ia₁jaun₂ dsɨ₃ŋɨ₃ 'io₅₄ 'éi₂ quian'₅₄ jmɨg₂.  
\v 16 La₁ ca₂jme₃'o₅₄ gua'₅₄ 'uë₃, ca₂jme₃'oin₅₄ 'io₅₄, ca₂niá₃ 'uë₃ ca₂nág'₃ jmɨg₂ cuá₃ jaun₂ a₂ca₂'uë́'₃ dragón juɨ₅ mɨ₂'o₅₄.  
\v 17 Jaun₂ ca₂rë₃'né₃ dragón le₃ja₁con₂ 'io₅₄, jaun₂ ŋei₅₄ i₁quɨin'₅₄ quiain'₅₄ tsɨ₁jon₂ i₂ca₂chón₃ quián₅ 'io₅₄, co₂'nió'₄ i₂jme₂ti₃ 'éi'₃ quió'₅ Diú₄ i₂le₁quian₅ jág₁ dsau₅ quió'₅ Jesús në́₃. 
\p  
\v 18 Jaun₂ ca₂nau₂ 'éi₂ chei'₅₄ jmɨ₁ŋí'₄.\f + \fr 12:18 \ft A₂lɨn₅₄ chog₅₄ si₂, 'nió'₄ a₂jme₁ton₅ versículo 18, juá'₂ le₂la₂: “Jaun₂ ca₂no₃ chei'₅₄ jmɨ₁ŋí'₄”, a₂chi₁ton₅ jë₁le₂'uɨg₅₄ Capítulo 13.\f* 
\c 13  
\s1 Le₃on₃ Já'₂ 'Lɨn'₅₄ 
\p  
\v 1 Jaun₂ ca₂jág₃ ca₂'ŋio₂ ne₄ jmɨ₁ŋí'₄ jan₂ já'₂ i₂jniá₂ gau₂ jmá'₅, i₂le₁dsɨ₅₄ guio₃ mɨ₂dsi₄, guia₃ guë'₂ mɨ₂juɨ́₁. Ne₄ mɨ₂juɨ́₁ në́₃, jme₁le₁dsɨ₅₄ guia₃ coronas. Ne₄ mɨ₂dsi₅₄ në́₃, jme₁le₁ton₅ jág₁ lia'₂ chein₂ a₂jmo₂₃ a₂lɨ́in₅ Diú₄.  
\v 2 Jme₁lɨ́n₄ já'₂ i₂ca₂jɨng₅₄ 'éi₂ lia'₂ lɨ́n₅ dsɨ₂'ia'₂ leopardo. Le₁dsɨ₅₄ mɨ₂tag₅₄ lia'₂ lë́₅ gu₂-tag₄ oso. Mɨ₂'o₅₄ guë'₂ lë́₅ lia'₂ lë́₅ mɨ₂'o₄ 'ia'₂ león. Ca₂cuë₃ dragón juɨ₅bí₂ ca₂cuë́'₃ já'₂ 'éi₂ lia'₂ jma₃quian'₅₄ ne₄ta₁ quió'₅ në́₃, a₂qui₃dsɨ₂₃ 'éi'₃ a₂'uain'₂ lɨn₃.  
\v 3 Ca₂mɨ́g₂ mɨ₂dsi₄ Já'₂ 'Lɨn'₅₄ 'éi₂, lë́₅ lia'₂ lë́₅ a₂rë₂cuɨ́'₃ 'ŋio₅ lɨn₃, lë́₅ në₂jag₄ bá₄ a₂chain₂ join₅₄. La₁ia₁ ca₂'láu₂ bá₄. Ta₁caun₂ mɨ₂güɨ́g₃ bá₄ ca₂i₃gó'₃ dsɨ́₅ dsa₂, ca₂'ein₃ Já'₂ 'Lɨn'₅₄ 'éi₂.  
\v 4 Jaun₂ ca₂jme₃juag'₂ dsa₂ ca₂jme₃juɨin'₂ dragón, ia₁ ca₂cuë₃ 'éi'₃ ca₂cuë́'₃ Já'₂ 'Lɨn'₅₄. Ca₂jme₃juiin'₂ Já'₂ 'Lɨn'₅₄ në́₃, qui₂ca₂juá'₂ ca₂tóin'₂: 
\p ―¿'Ein₂ chan₂ i₂lɨ́n₅ lia'₂ lɨ́n₅ i₂në₅? ―'ɨin₂₃ Já'₂ 'Lɨn'₅₄ 'éi₂―. ¿'Ein₂ bá₄ tió'₅ jmo₃ 'nei₂ ja₁coin₂? 
\p  
\v 5 Ján₃ bá₄ ca₂ŋɨi₂ jág₁ a₂le₃róin₂ a₂qui₃jmo₃ a₂lɨ́in₅ Diú₄; ca₂ŋɨi₂ bí₂ në́₃ a₂qui₃dsɨ₂₃ 'éi'₃ con'₂ të₂láu₃-tɨn₃ tsɨ'₂.  
\v 6 Jaun₂ ca₂jáin₃ mɨ₂'o₅₄, ca₂ton₃ 'lɨg'₅₄ le₃quió'₅ Diú₄. Ca₂ton₃ rë'₂ 'lɨg'₅₄ ca₂'ë₃ ja₁guá₄ Diú₄; ca₂'ɨin₃ rë'₂ ca₂lia'₂ i₂tion'₅₄ guei'₅₄ i₂juɨ́g₃ në́₃.  
\v 7 Ca₂ŋɨi₂ bá₄ jmɨg₄ a₂jmo₃ 'nei₂ ja₁con₂ dsa₂ i₂tén₅ le₃quió'₅ Diú₄,\f + \fr 13:7 \ft lit. “ja₁con₂ dsa₂ jŋió₅.” \f* a₂jo₃ në́₃; ca₂ŋɨi₂ bí₂ a₂qui₃dsɨ₂₃ 'éi'₃ ne₄ quió'₅ ca₂le₃jë́₃ tsɨ₁jon₂, ca₂le₃jë́₃ go₄ dsa₂, ca₂le₃jë́₃ jág₁ jmei₅, ca₂le₃jë́₃ juɨg₂ në́₃.  
\v 8 Jme₃juag'₂ ca₂le₃jɨ́n₃ dsa₂ i₂chan₂ gua'₅₄ 'uë₃ jme₃juɨin'₂ Já'₂ 'Lɨn'₅₄ 'éi₂: ca₂le₃jɨ́n₃ i₂con'₂ tsá₃ le₁ton₅ ne₄ si₂ rë₂bɨn₅ a₂le₃chan₂ dsa₂, a₂ron₅ quió'₅ Guein₂ Já'₂ Cha'₂, i₂jme₁ma₂'i₄ 'éi'₃ a₂jŋag'₃ dsa₂, ca₂le₃ ca₂nio₃ mɨ₂güɨ́g₃. 
\q1  
\v 9 Në₁jua'₂ 'ein₂ le₁dsɨ₅₄ rë₂gua₄, rë₂ juɨ₁nei₅₄. 
\q1  
\v 10 Juɨ₁lia'₂ i₂jŋia₅ dsa₂ juɨ₅ né'₃ má₃, 
\q2 ján₃ bá₄ juɨ₅ né'₃ má₃ dsɨ₃léin₂; 
\q1 juɨ₁lia'₂ dsa₂ i₂jme₂dsian₅ dsa₂ quian'₅₄ ŋi₁tág₂, 
\q1 quian'₅₄ ŋi₁tág₂ dsiáin₃.\f + \fr 13:10 \ft o₃, “Chi₂jua'₂ chan₂ i₂'i₄ 'éi'₃ jnéi₂ dsa₂, juɨ₅ né'₃ 'má₃ bá₄ dsó₃; chi₂jua'₂ chan₂ i₂'i₄ 'éi'₃ jŋag'₃ dsa₂ quian'₅₄ ŋi₁tág₂, quian'₅₄ ŋi₁tág₂ guë'₂ jŋag'₃ dsa₂.” \f* 
\m 'Uɨg₅₄ në₅ në́₃, ca₂le₃jɨ́n₃ i₂tén₅ le₃quió'₅ Diú₄, 'nió'₅ jmo₃ tió'₃ dsɨ́₅, a₂tsá₃ qui₂dsɨ₃uɨ́in₂ a₂'éin₂. 
\p  
\v 11 Cang₂ jaun₂ ca₂jɨn₄ táng₃ jniá₂ jan₂ já'₂ 'lɨn'₅₄ sián'₂, ca₂'ŋioi₂ ne₄ gua'₅₄ 'uë₃. 'Éi₂ në́₃ jme₁le₁dsɨ₅₄ tɨn₃ mɨ₂juɨ́₁ lia'₂ lë́₅ mɨ₂juɨ́₁ jan₂ guein₂ já'₂ cha'₂. La₁, lia'₂ lë́₅ jág₁ quió'₅ dragón bá₄, jme₁lë́₄ jág₁ quió'₅.  
\v 12 Co₂jaun₂ bá₄ jme₁'io₂₃ bí₂ ján₃, juɨ₁lia'₂ Já'₂ 'Lɨn'₅₄ i₂le₂'uɨg₅₄, a₂qui₃dsɨ₂₃ 'éi'₃ o₄quió'₄; chi₃quióng₂ jmɨg₄ jme₃juag'₂ ta₁caun₂ mɨ₂güɨ́g₃ quian'₅₄ i₂chan₂ ja₁jaun₂, jme₃juɨin'₂ Já'₂ 'Lɨn'₅₄ i₂le₂'uɨg₅₄ i₂ca₂'lón₂ i₂jme₁rë₂cuɨ́n'₃ 'éi₂.  
\v 13 'Lióng₂ léi₄ juë'₂ a₂o₂dsain₂ ca₂jmo₃ ján₃. Ca₂jmo₃ ca₂tá'₂ si₂ guei'₅₄ mɨ₂güɨ́g₃ në₃, ca₂jmo₃ të₃ne₄ dsa₂ mɨ₂güɨ́g₃.  
\v 14 Të₂le₃ quian'₅₄ léi₄ juë'₂ a₂ca₂jmo₃ o₄quió'₄ i₂'lɨn'₅₄ i₂le₂ne₁ 'éi₂, ca₂jme₃gain₂₃ dsa₂ i₂chan₂ gua'₅₄ 'uë₃. Ca₂jmo₃ 'éi'₃ a₂chi'₃ dsa₂ caun₂ nió'₄ quió'₅ Já'₂ 'Lɨn'₅₄ i₂jme₁rë₂cuɨ́n'₃ quian'₅₄ ŋi₁tág₂ i₂ca₂'lón₂ 'éi₂.  
\v 15 Ca₂ŋɨi₂ bí₂ a₂toin'₂ jme₂dsí₂ nió'₄ quió'₅ Já'₂ 'Lɨn'₅₄, ia₁jaun₂ juá'₂ jág₁, ia₁jaun₂ jme₃dsiain₂₃ ca₂le₃jɨ́n₃ i₂tsá₃ gue₃ jme₃juɨn'₂ nió'₄ quió'₅ 'éi₂.  
\v 16 Ca₂chi₃quiáin₂ jmɨg₄ lia'₂ dsa₂ can'₅₄ lia'₂ dsa₂ me'₂, lia'₂ dsa₂ i₂cha₂ cu₄ lia'₂ dsa₂ te₂ŋé₂, lia'₂ dsa₂ i₂jme₂ti₃ ta₁ ne₄ juɨg₅₄ lia'₂ dsa₂ i₂tsá₃ 'ein₂ ne₄ jme₂ti₃ në́₃, a₂guein₃ léi₄ dso'₂ gu₂ ne₁, o₃ chi₁quí₃ 'e₂.  
\v 17 Jaun₂ tsá₃ ma₃lé₂ lá₃ 'i₁jan₂, on₃ guë'₂ ma₃lé₂ 'nag₃, jua'₅₄ tsá₃ lɨ́in₅ léi₄, o₃ tsá₃ le₁quian₅ jág₁ lia'₂ chen₂ Já'₂ 'Lɨn'₅₄, o₃ tsá₃ le₁quian₅ número quió'₅ lia'₂ chein₂.  
\v 18 Le₂la₂ bá₄ jág₁ a₂ŋɨ́'₂ dsɨ́₅: juɨ₁lia'₂ dsa₂ i₂'i₄ jág₁, juɨ₁chein'₄ cuentas 'a₂ lia'₂ lë́₅ número quió'₅ Já'₂ 'Lɨn'₅₄. Ia₁ número quió'₅ dsa₂ mɨ₂güɨ́g₃ bá₄ jaun₂. Le₂la₂ lë́₅ número quió'₅: jŋéi₂ 'ŋiá₂-láu₂ rë₂dsɨ́₂ 'nag'₂ ne₂guióg₂ rë₂dsɨ́₂ jŋéi₂ (666). 
\c 14  
\s1 Canto a₂ca₂'ë₃ caun₂ 'ŋiá₂-lón₂ rë₂dsɨ́₂ të₂láu₃-quén₂ mei₅ (144,000) dsa₂ 
\p  
\v 1 Cang₂ jaun₂ ca₂jɨng₅₄ táng₃ Guein₂ Já'₂ Cha'₂ jniái₂ chéin'₅ ne₄ Má'₂ Sión, quiain'₅₄ caun₂ 'ŋiá₂-lón₂ rë₂dsɨ́₂ të₂láu₃-quén₂ mei₅ dsa₂ i₂jme₁le₁quian₅ léi₄, i₂le₁ton₅ chi₁quí₃ lia'₂ chen₂ Guein₂ Já'₂ Cha'₂ quian'₅₄ 'a₂ lia'₂ chen₂ Jmei₂ në́₃.  
\v 2 Jaun₂ guë́₄ ca₂nag₃ caun₂ mɨ'₅₄ a₂já₅ guei'₅₄ i₂juɨ́g₃, a₂lë́₅ në₂jag₄ bá₄ caun₂ la'₅₄ juë'₂ lɨn₃,\f + \fr 14:2 \ft o₃ “lia'₂ né'₂ 'lióng₂ jmɨg₂.” \f* ton'₂ në₂jag₄ bá₄ ja₁dein₅ quia'₂ tiá₂ lɨn₃ ŋí'₃. Mɨ'₅₄ a₂ca₂nag₃ jaun₂ ca₂né'₂ juɨ₁lia'₂ ja₁jmo₅ dsa₂ son₅₄ quian'₅₄ tsɨ₁ton₅ arpas \f + \fr 14:2 \ft griego: kithara.\f* quió'₅.  
\v 3 Qui₂i₁'ë₂₃ caun₂ canto 'mɨ́₂ ne₄ ne₄ta₁, ne₄ le₃quén₂ já'₂, ne₄ gui'₅₄ can'₅₄ në́₃. Ca₂lia'₂ 'i₁jan₂ dsa₂ sián'₂ tsá₃ 'ein₂ lé₂ le₃tɨn₂ son₅₄ a₂'ë₅ dsa₂ jaun₂, jmá'₃ lia'₂ dsa₂ 'ŋiá₂-lón₂ rë₂dsɨ́₂ të₂láu₃-quén₂ mei₅ i₂rë₂'lian'₅₄ ne₄ gua'₅₄ 'uë₃ 'éi₂ bá₄.  
\v 4 Ca₂le₃jɨ́n₃ dsa₂ 'éi₂ i₂tsá₃ ca₂rë₃'iog₅ jme₂dsí₂ quió'₅ quian'₅₄ 'io₅₄ 'lɨn'₅₄, ia₁ qui₂ma₂ca₂rë₃cháin₃ ja₂léin₂ le₁jɨ́in₃. Quiain'₅₄ bá₄ Guein₂ Já'₂ Cha'₂ juɨ₁'a₂ guë́₃ ja₁dsó₃ 'éi₂. Qui₂le₁'liain₅₄ të₂le₃ jɨn₄ dsa₂ mɨ₂güɨ́g₃, co₂'nió'₄ i₂le₂'uɨg₅₄ i₂rë₂jen'₅₄ le₃ne₄ Diú₄, le₃ne₄ Guein₂ Já'₂ Cha'₂ në́₃.  
\v 5 'I₁caun₂ jág₁ të₂jág₁ tsá₃ ca₂'uë₂ mɨ₂'o₄ 'éi₂; tsá₃ dso₄ qui₂rë₂cáin'₄.\f + \fr 14:5 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₃ ján₃: “le₃ne₄ ne₄ta₁.” \f* 
\s1 Jág₁ quió'₅ le₃ún₂ ángeles 
\p  
\v 6 Jaun₂ ca₂jɨng₅₄ táng₃ jan₂ ángel sián'₂ a₂ŋɨ₂₃ dsi₂jo₂ dsi₄ güɨg₂, i₂quian₅₄ jág₁ dse₃ a₂le₃chan₂ dsa₂ co₂tan₅₄, já₅ ja₂'ë́₃ ja₂chi'₅₄ dsa₂ i₂tián'₅ ne₄ gua'₅₄ 'uë₃: ca₂le₃jë́₃ juɨg₂, ca₂le₃jë́₃ tsɨ₁jon₂ dsa₂, ca₂le₃jë́₃ jág₁ jmei₅, ca₂le₃jë́₃ go₄ dsa₂;  
\v 7 i₁juá'₄ tiá₂: 
\p ―Jme₁gan₃ 'nia'₂ Diú₄; jme₁juɨn'₂ 'nia'₂ 'éi₂. Ia₁ ma₂gua₅ hora a₂qui₃dsɨ₂₃ 'éi'₃. Jme₁juɨn'₂ 'nia'₂ i₂ca₂jmo₃ guei'₅₄ mɨ₂güɨ́g₃ quian'₅₄ gua'₅₄ 'uë₃, jmɨ₁ŋí'₄ në́₃, quian'₅₄ guë́₄ ca₂le₃jë́₃ o₄tu₁ jmɨg₂. 
\p  
\v 8 Chi₁quɨ́n₃ guë́₄ jaun₂ ján₃, ca₂já₃ jan₂ ángel sián'₂ i₂ca₂juá'₂: 
\p ―Ma₂ca₂i₃'én₂, ma₂ca₂i₃'én₂ Babilonia juë'₂, 'uɨg₅₄ ia₁ a₂ca₂jmo₃ a₂qui₂ca₂'ɨn'₃ ca₂le₃jë́₃ juɨg₂ vino a₂ca₂jme₃cón₂ dsɨ́₅ a₂qui₂nió'₃ jág₁ 'lɨg'₅₄ quió'₅. 
\p  
\v 9 Jaun₂ ca₂guan₃ táng₃ jë₁ca₂të́₂ ún₂ ángel, ján₃ guë'₂ tiá₂ ca₂juá'₂: 
\p ―Chi₂jua'₂ 'ein₂ ca₂guen₃ jme₃juɨn'₂ Já'₂ 'Lɨn'₅₄, quian'₅₄ nió'₄ quió'₅, o₃ në₁jua'₂ ca₂guein₃ cán₂ léi₄ dso'₂ chi₁quí₃, o₃ co'₅₄ gú₃ 'e₂,  
\v 10 ján₃ bá₄ 'ɨ́n'₂ 'éi₂ vino a₂'i₄ 'nei₂ dsɨ́₅ Diú₄ a₂ma₂i₂tang₄ a₂tsá₃ 'e₂ qui₂rë₂cón'₅ 'ŋió'₃ copa a₂cha₂ 'uɨg₅₄ a₂le₃'nei₂; qui₃ŋág₃ uɨg₅ quian'₅₄ si₂ quian'₅₄ azufre të₃ne₄ ángeles jŋió₅ quián₅ Diú₄ quian'₅₄ guë'₂ le₃ne₄ Guein₂ Já'₂ Cha'₂.  
\v 11 Jme₁ŋi₁ a₂tsáu₃ ja₁ŋág₃ uɨg₅ në́₃, dsi₅₄ co₂tan₅₄ lé₂, on₃ guë'₂ 'uë₂-jmɨ₂ bá₄ lé₂ jua'₅₄ a₂le₃jŋia₃ a₂tsá₃ ŋág₃ ca₂tiá₂ uɨg₅ ca₂le₃jɨ́n₃ i₂jme₃juɨn'₂ Já'₂ 'Lɨn'₅₄ 'éi₂ quian'₅₄ nió'₄ quió'₅, ca₂le₃jɨ́n₃ i₂ca₂guen₃ cán₂ léi₄ lia'₂ chein₂ në́₃. 
\p  
\v 12 Ja₁në₅ bá₄ 'nió'₅ jmo₃ juɨn'₂ dsɨ́₅ dsa₂ i₂tén₅ le₃quió'₅ Diú₄,\f + \fr 14:12 \ft lit. “dsa₂ jŋió₅.” \f* dsa₂ i₂tión₂ tiá₂ jme₂ti₃ 'éi'₃ quió'₅, a₂'éin₂ le₃quió'₅ Jesús në́₃. 
\p  
\v 13 Jaun₂ ca₂né'₂ táng₃ jág₁ a₂já₅ guei'₅₄ i₂juɨ́g₃, ca₂juá'₂ tság₅ jniá₂: 
\p ―Jmo₄ si₂ tiong₅ ca₂le₃jë́₃ a₂në₅ a₂juá'₂: “'E₂ guë́₄ 'ŋio₅ dsen₃ dsa₂ i₂dsián₃ le₃ne₄ juɨ₅ la₂, i₂'én₂ le₃quió'₅ Te₁gui'₅₄.” Ján₅, juá'₂ Jme₂dsí₂, ia₁jaun₂ jŋia₃ ca₂le₃jë́₃ ta₁ quió'₅, jaun₂ qui₃le₃quen₅ 'i₄ ta₁ ca₂le₃jë́₃ a₂ca₂jmo₃.” 
\s1 A₂ráu₃ ne₄ gua'₅₄ 'uë₃ 
\p  
\v 14 Jaun₂ ca₂jág₃ táng₃ ca₂jnia₃ caun₂ jnei₅ tiog₂ jmá'₅. Ne₄ jnei₅ jaun₂, guá₅ jan₂ i₂lɨ́n₅ lia'₂ lɨ́n₅ Jaun₅ dsa₂ mɨ₂güɨ́g₃.\f + \fr 14:14 \ft 'Nio'₂ ja₁ton₅ Daniel 7:13.\f* Chi₁'i₁ caun₂ corona a₂lë́₅ jmá'₃ cu₄nióg₄ mɨ₂dsi₅₄, chi₁chan'₂ caun₂ ŋí₁ hoz a₂'mu₃.  
\v 15 Jaun₂ o₂'ɨ́n₃ táng₃ jan₂ ángel dsi₂néi₂ guá'₅ templo, ca₂juá'₂ tiá₂ ca₂tsɨ́'₃ i₂guá₅ ne₄ jnei₅: 
\p ―Tiá₃ ŋí₁ hoz quiáng'₂, cag'₅₄; ia₁ ma₂gua₅ hora cag'₅₄, ia₁ ma₂ca₂ron₂ a₂ráu₃ ne₄ gua'₅₄ 'uë₃.  
\v 16 Jaun₂ ca₂tiá₂ hoz ne₄ gua'₅₄ 'uë₃, dsa₂ i₂guá₅ ne₄ jnei₅ 'éi₂, ca₂cág'₃ a₂ma₂ca₂rau₂ ja₁jaun₂. 
\p  
\v 17 Jaun₂ ca₂o₃'ɨ́n₃ táng₃ jan₂ ángel sián'₂ dsi₂néi₂ guá'₅ chí'₅ guei'₅₄ i₂juɨ́g₃; ján₃ bá₄ chi₁chan'₂ caun₂ ŋí₁ hoz a₂'mu₃.  
\v 18 Jaun₂ ca₂o₃'ɨ́n₃ táng₃ ne₄chei₂ jan₂ ángel sián'₂ guë́₄ táng₃, i₂'io₅ bí₂ ne₄ si₂. Jaun₂ ca₂juá'₂ tiá₂ ca₂tsɨ́'₃ i₂chan'₂ ŋí₁ hoz 'mu₃, ca₂juá'₂: 
\p ―Tiá₃ ŋí₁ 'mu₃ quiáng'₂; chi₁lo'₂ cag'₅₄ nɨ₁'mu'₂ a₂qui₂le₁'ág₄ nɨ₁uɨng₂ a₂cha₂ gua'₅₄ 'uë₃, ia₁ ma₂ca₂juɨg₂ mɨ́g₂ uvas quió'₅. 
\p  
\v 19 Jaun₂ ca₂tiá₂ 'éi₂ hoz quió'₅ ne₄ gua'₅₄ 'uë₃, ca₂cág'₃ mɨ́g₂ uvas quió'₅ gua'₅₄ 'uë₃. Ca₂tó'₂ caun₂ ja₁juë'₂ ja₁qui₂jlen'₃ dsa₂, co₂'nió'₄ le₃jua'₅₄, ja₁'i₄ 'nei₂ dsɨ́₅ Diú₄.  
\v 20 Jaun₂ ca₂rë₂tso'₄ a₂jaun₂ 'nɨ'₂ juɨg₂, ca₂'io₂ jmɨ₂. Jmɨ₂ jaun₂ në́₃ ca₂i₃'o₅₄ a₂jɨ'₂ con'₂ 'ei₅ rë₂'o₄ dsɨ₂cua₁, a₂juë'₂ ja₁ca₂'a₃ tí₅ con'₂ 'nɨ₅ 'ŋiá₂-láu₂ (300) kilómetros. 
\c 15  
\s1 Guion₃ ángeles i₂le₁quian₅ guio₃ jmɨ₁uɨg₅ jë₁ca₂tó'₂ 
\p  
\v 1 Ca₂jág₃ jniá₂ guei'₅₄ i₂juɨ́g₃ caun₂ léi₄ juë'₂ a₂dsɨ₂gó'₃ dsɨ₅: guion₃ ángeles i₂quian₅ guio₃ guë́₄ jmɨ₁uɨg₅ ja₁con₂ dsa₂. Co₂'nió'₄ a₂jaun₂ guë́₄ lë́₅ jë₁ca₂tó'₂, ia₁ co₂jaun₂ ca₂'ŋia₅ a₂'i₄ 'nei₂ dsɨ́₅ Diú₄. 
\p  
\v 2 Jaun₂ ca₂jág₃ jniá₂ juɨ₁lia'₂ caun₂ jmɨ₁ŋí'₄ a₂lë́₅ nɨ₁'ɨ₂ a₂rë₂cón'₅ quian'₅₄ si₂. Ne₄ jmɨ₁ŋí'₄ a₂lë́₅ nɨ₁'ɨ₂ jaun₂, jme₁tión₂ dsa₂ i₂ca₂tió'₃ ne₄ Já'₂ 'Lɨn'₅₄, ne₄ nió'₄ quió'₅, ne₄ número quió'₅ lia'₂ chein₂ në́₃. Qui₂le₁chan'₂ tsɨ₁ton₅ arpas\f + \fr 15:2 \ft griego: kithara.\f* a₂ca₂cuë₃ Diú₄.  
\v 3 Tióin₂ 'ë₂₃ canto quió'₅ Moisés\f + \fr 15:3 \ft canto quió'₅ Moisés: 'Nio'₂ ja₁ton₅ Éxodo 15; Deuteronomio 32.\f* dsa₂ i₂ca₂jme₂ti₃ quián₅ Diú₄, quian'₅₄ canto quió'₅ Guein₂ Já'₂ Cha'₂, a₂juá'₂: 
\q1 'E₂ guë́₄ juë'₂ a₂jlá'₁ lɨn₃ ca₂le₃jë́₃ a₂ma₂jmo'₅₄ 'ne₂, 
\q2 Te₁gui'₅₄ Diú₄ i₂'Uan'₂ guë́₄ lɨn₃. 
\q1 A₂dsau₅, a₂tí₅ lɨn₃ bá₄ juɨ₅ quiáng'₂, 
\q2 'Ne₂ Rag₅₄ quián₅ ca₂le₃jë́₃ juɨg₂. 
\q1  
\v 4 ¿'Ein₂ bá₄ 'éi₂ i₂tsá₃ jme₃gon₃ 'ne₂, Te₁gui'₅₄? 
\q1 ¿'Ein₂ bá₄ i₂tsá₃ jme₃juag'₂ guë'₂ ján₃? 
\q2 Ia₁ jan'₂ 'ne₂ bá₄ lɨ́ng'₅ i₂jŋió₅. 
\q1 Ca₂le₃jë́₃ juɨg₂ qui₂ja₃léin₂ qui₂jme₃juɨin'₂ 'ne₂, 
\q2 ia₁ ma₂ca₂rë₃jniá₂ 'éi'₃ a₂qui₂dsɨ́'₂ 'ne₂. 
\p  
\v 5 Cang₂ jaun₂ ca₂jág₃ jniá₂ guei'₅₄ i₂juɨ́g₃, ca₂niá₃ guá'₅, co₂'nió'₄ le₃jua'₅₄ ja₁jŋió₅ guë́₄, ja₁rë₂'ma₄ jág₁ dsau₅ a₂lɨ'₅₄ quian'₅₄ Diú₄.  
\v 6 Guá'₅ jaun₂, ca₂'uɨn₂ guion₃ ángeles i₂le₁quian₅ le₃guio₃ jmɨ₁uɨg₅. Le₁qui'₂ 'mɨ'₂ lino jlá'₁, a₂tág₅ lɨn₃. A₂jme₁rë₂jén'₅ le₁dsɨ́₅ guë'₂ në́₃, jme₁lë́₄ jmá'₃ cu₄nióg₄.  
\v 7 Jaun₂ guë́₄ jan₂ já'₂ quén₂ i₂tión₂ ne₄ ne₄ta₁, ca₂cuë́'₃ le₂jan₂ le₂jan₂ ta₁guion₃ ángeles jma₃cáun₃ nɨ₁uɨng₅ jɨ'₂ a₂lë́₅ cu₄nióg₄, le₁'a₁ co₂'nió'₄ a₂'nei₂ a₂'i₄ dsɨ́₅ Diú₄ i₂chan₂ ca₂lia'₂ co₂tan₅₄.  
\v 8 Jaun₂ ca₂can'₂ dsi₂néi₂ guá'₅ quian'₅₄ jme₁ŋi₁ a₂já₅ ja₁con₂ a₂jlá'₁ a₂'uan'₂ Diú₄. Ca₂lia'₂ 'i₁jan₂ tsá₃ lé₂ dsɨ₃ton'₅₄ ja₁jaun₂, ca₂lia'₂ ca₂rë₃'ŋia₅ le₃guio₃ jmɨ₁uɨg₅ a₂le₁quian₅ ta₁guion₃ ángeles. 
\c 16  
\s1 Ta₁guio₃ jmɨ₁uɨg₅ a₂'ë́₂ Diú₄ 
\p  
\v 1 Jaun₂ ca₂nag₃ jniá₂ jág₁ tiá₂ lɨn₃ i₁juá'₄ dsi₂néi₂ guá'₅, a₂tsɨ́'₅ le₃guion₃ ángeles 'éi₂: 
\p ―O₂nó'₅ 'nia'₂ o₂jen₄ ne₄ gua'₅₄ 'uë₃ 'nei₂ a₂'i₄ dsɨ́₅ Diú₄ a₂le₁'a₁ nɨ₁uɨng₅ në₅. 
\p  
\v 2 Jaun₂ ca₂o₃'ɨ́n₃ jë₁le₂'uɨg₅₄ ángel, jaun₂ ca₂jein₃ a₂chi₁'a₄ nɨ₁uɨng₅ quió'₅ ne₄ gua'₅₄ 'uë₃. Jaun₂ ca₂le₃jɨ́n₃ dsa₂ i₂le₁quian₅ léi₄ quió'₅ Já'₂ 'Lɨn'₅₄, i₂jme₂juɨn'₂ nió'₄ quió'₄ në́₃, qui₂ca₂'ŋiai₂ 'mé'₅ 'lɨg'₅₄ a₂quɨ'₂ guë́₄ lɨn₃. 
\p  
\v 3 Jaun₂ ca₂jen₃ jë₁ca₂të́₂ on₃ ángel a₂'a₄ nɨ₁uɨng₅ quió'₅ ne₄ jmɨ₁ŋí'₄. Jaun₂ ca₂lë₃ jmɨ₂, në₂jag₄ bá₄ jmɨ₂ 'an₅₄ jan₂ 'lag₄. Ca₂dsan₃ ca₂le₃jɨ́n₃ já'₂ i₂jme₁chan₂ jmɨ₁ŋí'₄ jaun₂. 
\p  
\v 4 Ján₃ bá₄ le₂jaun₂ ca₂jen₃ jë₁ca₂të́₂ ún₂ ángel a₂'a₄ nɨ₁uɨng₅ quió'₅, ne₄ jmɨg₂ cuá₃, ne₄ o₄tu₁ jmɨg₂ në́₃; jaun₂ jmá'₃ jmɨ₂ bá₄ qui₂ca₂lë₃ ján₃.  
\v 5 Jaun₂ ca₂nag₃ juá'₂ ángel i₂niog₅ gu₂ jmɨg₂, ca₂juá'₂: 
\q1 Rë₂ bá₄ cáun'₂ 'ne₂ 'í₁, Diú₄ Jŋió₅; 
\q2 'ne₂ i₂lɨ́n₅, i₂jme₁lɨ́n₄,\f + \fr 16:5 \ft A₂lɨn₅₄ chog₅₄ si₂ chi₁ton₅ ján₃: “i₂lén₂ co₂tan₅₄.” \f* 
\q2 ia₁ a₂në₂qui₁dsɨ'₂ 'éi'₃ le₂në₅. 
\q1  
\v 6 Ia₁ ca₂tein₃ 'éi₂ jmɨ₂ a₂jme₁'an₅₄ 
\q2 dsa₂ i₂jme₁tén₄ le₃quiáng'₂, 
\q2 dsa₂ i₂jme₁qui₂ca₂'ë́₂ jág₁ quiáng'₂ në́₃. 
\q1 Në₃ guë́₄ në́₃, në₂'ein'₅₄ jmɨ₂, 
\q2 ia₁ le₂në₅ 'en₄ quió'₅ bá₄. 
\p  
\v 7 Ca₂nag₃ jniá₂ ján₃ jë₄ ne₄chei₂, i₁juá'₄: 
\q1 Dsón'₂ le₂në₅, Te₁gui'₅₄ Diú₄ i₂'Uan'₂ guë́₄ lɨn₃, 
\q2 dsón'₂ bá₄ qui₂dsɨ́'₁ 'ne₂ 'éi'₃ lia'₂ con'₂ dsi₂ten₅₄. 
\p  
\v 8 Jaun₂ ca₂jen₃ jë₁ca₂të́₂ quén₂ ángel a₂'a₄ nɨ₁uɨng₅ quió'₅ ne₄ 'iog₂, jaun₂ ca₂ŋɨ₂ 'iog₂ bí₂ a₂dsɨ́in'₂ dsa₂ mɨ₂güɨ́g₃ quian'₅₄ si₂.  
\v 9 Jaun₂ ca₂dsɨn'₂ ca₂le₃jɨ́n₃ dsa₂ quian'₅₄ a₂dséi₂ gau₂ lɨn₃. Jaun₂ qui₂ca₂'ag₃ dsa₂ 'lɨg'₅₄ qui₂ca₂'ɨin₃ Diú₄ i₂'io₅ bí₂ ne₄ jmɨ₁uɨg₅ jaun₂. Tsá₃ ca₂jme₃tsɨ́in₃ dsɨ́₅, jua'₅₄ ca₂jme₃juɨin'₂ 'éi₂. 
\p  
\v 10 Jaun₂ ca₂jen₃ jë₁ca₂të́₂ 'ŋiá₂ ángel a₂'a₄ nɨ₁uɨng₅ quió'₅ ne₄ ne₄ta₁ quió'₅ Já'₂ 'Lɨn'₅₄, jaun₂ ca₂të₁tsɨ'₅₄ qui₁né'₃ ja₁goin₂ jaun₂. Dsa₂ në́₃ qui₂ca₂quɨg'₂ le₁tsɨ'₂ a₂ca₂jme₃uɨ́'₃.  
\v 11 Con'₂ siá'₂ ca₂'ɨin₃ 'lɨg'₅₄ Diú₄ i₂quió'₅ guei'₅₄ i₂juɨ́g₃, ne₄ 'uɨg₅₄ a₂le₁quian₂₃ jmɨ₁uɨg₅, 'uɨg₅₄ ia₁ a₂lɨ́in₅ 'mé'₅ në́₃. La₁ tsá₃ ca₂dsi₃quéin'₅ dsɨ́₅ jua'₅₄ ca₂tí₂ a₂jmo₂₃-dsáu₅. 
\p  
\v 12 Jaun₂ ca₂jen₃ jë₁ca₂të́₂ jŋé₂ ángel a₂'a₄ nɨ₁uɨng₅ quió'₅ ne₄ cuá₃ juë'₂ Eufrates. Jaun₂ co₂dsia₅ ca₂rë₃quéin₃ cuá₃ jaun₂, ia₁jaun₂ ma₂lë́₅ co₂jŋia₅₄ caun₂ juɨ₅ quein₂ ja₁i₃nio₄ rag₅₄ i₂ja₃lén₂ të₂le₃ ja₁'ia₂\f + \fr 16:12 \ft Co₂'nió'₄ le₃jua'₅₄, caun₂ cosa a₂tsá₃ 'i₄ jme₂dsí₂, a₂ca₂jmo₃ Diú₄. 'Nio'₂ ja₁ton₅ Salmo 8:3; Romanos 1:25.\f* 'iog₂. 
\p  
\v 13 Jaun₂ ca₂jág₃ ca₂'uɨn₂ ún₂ jme₂dsí₂ 'lɨn'₅₄, i₂jniá₂ lia'₂ jniá₂ i₁jë́'₅, ca₂'uɨin₂ jma₃ján₃ juɨ₅ mɨ₂'o₄ já'₂ dragón, mɨ₂'o₄ Já'₂ 'Lɨn'₅₄, quian'₅₄ mɨ₂'o₄ i₂të́'₂ dsa₂ i₂'ë́₂ jág₁ a₂juɨ₁gain₂ në́₃.  
\v 14 Jme₂dsí₂ i₂lɨ́n₅ je₂na'₅₄ bá₄ 'éi₂, i₂qui₃jmo₃ léi₄ juë'₂, i₂qui₂dsɨ₃lén₂ uɨ́ng₂ ja₁con₂ rag₅₄ quián₅ dsa₂ i₂chan₂ ta₁caun₂ mɨ₂güɨ́g₃, ia₁jaun₂ chi₃lo'₃ a₂dsia₃ 'nei₂ jmɨg₄ juë'₂ jaun₂ quió'₅ Diú₄ i₂'Uan'₂ guë́₄ lɨn₃. 
\p  
\v 15 “Rë₂ján'₁ 'nia'₂ ia₁ guión'₄ jniá₂ con'₂ tiá₂, në₂jag₄ bá₄ jan₂ 'ang₂. 'E₂ guë́₄ dsen₃ juɨ₁lia'₂ i₂rë₂jnio₄ ne₄, i₂lë́₅ 'í₁ tsɨn'₅₄, con'₂ tsá₃ ŋó₅ në₁jua'₂ i₃ŋɨ₅₄ rë₂ŋɨ́i₅ të₃ jág₅ dsa₂ o₂quí'₃ quió'₅.” 
\p  
\v 16 Jaun₂ qui₂ca₂liain'₃ rag₅₄ caun₂ ja₁chei₂ Armagedón quian'₅₄ jág₁ jmei₅ hebreo. 
\p  
\v 17 Jaun₂ ca₂jen₃ jë₁ca₂të́₂ guion₃ ángel a₂'a₄ nɨ₁uɨng₅ quió'₅, ca₂'éin₂ dsi₂güɨg₂. Jaun₂ ca₂né'₂ dsi₂néi₂ guá'₅ a₂chí'₅ guei'₅₄ i₂juɨ́g₃, jág₁ a₂juá'₂ tiá₂, a₂já₅ ne₄ta₁, i₁juá'₄: 
\p ―¡Ma₂ca₂lë₃ bá₄!\f + \fr 16:17 \ft 'Nio'₂ ja₁ton₅ Juan 19:30.\f* 
\p  
\v 18 Jaun₂ qui₂ca₂lë₃ si₁ŋí'₃, ca₂të₁tsɨ'₅₄ co₂mɨ'₅₄, ca₂quia'₂ ŋí'₃. Ta₁caun₂ gua'₅₄ 'uë₃ qui₂ca₂jë́'₂ ca₂i₁bi₅₄ 'uë₃ tiá₂ lɨn₃, ca₂lia'₂ 'i₁cón'₂ tsá₃ le₂jaun₂ jua'₅₄ a₂ma₂i₁bi₅₄ 'uë₃ ca₂le₃ ca₂rë₃chán₃ dsa₂ ne₄ gua'₅₄ 'uë₃, ia₁ a₂ŋɨ́₄ lë₃ gau₂ ca₂lë₃.  
\v 19 Ca₂lë₃ 'nɨ₅ dso'₅₄ ciudad dsen₅₄ jaun₂, jaun₂ qui₂ca₂i₃lé₂ juɨ₅ 'uë₃ ca₂le₃jë́₃ juɨg₂ ciudad jme₁te₁'i₁ mɨ₂güɨ́g₃. Jaun₂ guë́₄ ca₂dsáu'₃ dsɨ́₅ Diú₄ Babilonia juë'₂; ca₂cuë́'₃ copa a₂'a₄ vino a₂'i₄ 'nei₂ dséi₂ dsɨ́₅.  
\v 20 Jaun₂ qui₂ca₂cuɨng₃ ca₂le₃jë́₃ 'uë₃ a₂qui₂le₁quɨ́'₅ jë₄ jmɨ₁ŋí'₄; ca₂le₃jë́₃ nɨ₁má'₂ në́₃, co₂dsia₅ ca₂i₃có'₂.  
\v 21 Qui₂ca₂tang₂ ne₄ quió'₅ dsa₂ mɨ₂güɨ́g₃ dsɨ́₅ ca₁ca'₅₄ 'ŋio₅ lɨn₃, a₂guei₂ jma₃të₂láu₃ kilo lia'₂ ca₂mɨ́g₂.\f + \fr 16:21 \ft lit. “a₂guei₂ caun₂ talento lia'₂ ca₂mɨ́g₂.” \f* Ján₃ bá₄ le₂jaun₂ qui₂ca₂'ag₃ dsa₂ 'lɨg'₅₄ 'ɨin₂₃ Diú₄, 'uɨg₅₄ ia₁ a₂ca₂séi'₂ dsɨ́₅ jaun₂, ia₁ a₂ŋɨ́₄ lë₃ ca₂i₁juɨn₅₄ gau₂ jmɨ₁uɨg₅ a₂ca₂lë₃. 
\c 17  
\s1 Jë₁ca₂i₃'én₂ 'io₅₄ juɨn'₂ i₂'nag₅ quió'₅ 
\p  
\v 1 Jaun₂ ca₂já₃ jan₂ ángel i₂lë́₂ guion₃ i₂jme₁le₁chan'₂ nɨ₁uɨng₅ 'éi₂, ca₂tság₃ jniá₂: 
\p ―Ŋia₅, la₂ 'ë₅₄ 'a₂ lia'₂ lë́₅ jmɨ₁uɨg₅ a₂'ë́₂ Diú₄ ne₄ 'io₅₄ juɨn'₂ i₂'nag₅ quió'₅, i₂guá₅ ne₄ ja₁te₁'i₁ 'lióng₂ jmɨg₂.  
\v 2 Ca₂le₃jɨ́n₃ bá₄ rag₅₄ i₂chan₂ ne₄ gua'₅₄ 'uë₃ ma₂qui₂ca₂nió'₄ jág₁ quiain'₅₄ 'io₅₄ 'éi₂; ján₃ bá₄ le₂jaun₂ ma₂qui₂ca₂rë₃'en₅ dsa₂ i₂tián'₅ ne₄ gua'₅₄ 'uë₃, quian'₅₄ vino a₂co₂'nió'₄ dso₄ a₂ca₂jmo₃-dsáu₅ 'io₅₄ 'éi₂. 
\p  
\v 3 Jaun₂ ca₂jiog₃ ángel, të₁lia'₂ 'eng₅₄ le₃quió'₅ Jme₂dsí₂, caun₂ 'uë₃ quein₂ co₂'ŋiog₅. Ja₁jaun₂ ca₂të́₂ ne₃ ca₂jɨng₅₄ jan₂ 'io₅₄, co₂dsɨin₅₄ jan₂ já'₂ guén₂ i₂jniá₂ gau₂ jmá'₅, i₂le₁dsɨ₅₄ guio₃ mɨ₂dsi₄, guia₃ guë'₂ mɨ₂juɨ́₁, i₂jme₁quian₅ 'lióng₂ jág₁ 'lɨg'₅₄ lia'₂ chein₂ a₂jmo₂₃ a₂lɨ́in₅ Diú₄ në́₃.  
\v 4 'Io₅₄ 'éi₂ në́₃ rë₂lɨin₅₄ qui'₂ tsɨn'₅₄ guéin₂ si₂, quian'₅₄ a₂'uɨ'₃. A₂lë́₅ jlá'₁, tio'₅₄ cu₄nióg₄, nɨ₁cang₁ jlá'₁ quian'₅₄ mɨ́g₂ perlas në́₃. Ján₃ guë́₄ chi₁chan'₂ caun₂ copa a₂lë́₅ jmá'₃ cu₄nióg₄, rë₂'a₄ a₂'lɨg'₅₄ a₂jmo₅-dsáu₅, quian'₅₄ jág₁ 'lɨg'₅₄ a₂nió'₅.  
\v 5 Le₁ton₅ jág₁ ne₄ chi₁quí₃, a₂juá'₂: JÁG₁ A₂RË₂'MA₄ BABILONIA JUƗN'₂ CHOG₅₄ 'IO₅₄ I₂'NAG₅ QUIÓ'₅ CHOG₅₄ CA₂LE₃JË́₃ NE₅₄ A₂LƗ₁'IOG₅ NE₄ GUA'₅₄ 'UË₃. 
\p  
\v 6 Jaun₂ ca₂jɨn₄ jniá₂ 'io₅₄, a₂'ein₅ guá₅, quian'₅₄ jmɨ₂ 'an₅₄ i₂tén₅ le₃quió'₅ Diú₄,\f + \fr 17:6 \ft lit. “quian'₅₄ jmɨ₂ 'an₅₄ dsa₂ jŋió₅.” \f* quian'₅₄ guë'₂ jmɨ₂ 'an₅₄ i₂ma₂jáng'₃ jág₁ dsau₅ le₃quió'₅ Jesús. Jaun₂ ca₂i₃gó'₃ dsɨ₃ guë́₄ lɨn₃ jme₁ca₂të́₂ ne₃ a₂jaun₂.  
\v 7 Jaun₂ ca₂juá'₂ ángel tság₅ jniá₂: 
\p ―¿'E₂ lë₃ dsɨ₂gó'₃ 'au'₂? La₂ juá'₄ jniá₂ jág₁ rë₂'ma₄, co₂'nió'₄ 'e₂ léi₄ jáng'₅ 'io₅₄ ó₃, 'e₂ guë'₂ léi₄ jáng'₅ táng₃ Já'₂ 'Lɨn'₅₄ i₂jiog₅ i₂cha₂ guio₃ mɨ₂dsi₄, i₂le₁dsɨ₅₄ guio₃ mɨ₂juɨ́₁ në́₃.  
\v 8 Já'₂ 'Lɨn'₅₄ i₂në₂jɨng'₅₄ në₅, jme₁chan₂ le₂jŋiá₅, rë₂në́₃ në́₃ tsá₃ ma₃chain₂. La₁ jë₁ma₂o₃'ɨin₅ uɨ́g₂ ja₁ca₂jein₃ chi₁dsio₅₄, jaun₂ dsióg₄ ja₁dsɨ₃'éin₂. Dsɨ₃gó'₃ dsɨ́₅ dsa₂ i₂chan₂ ne₄ gua'₅₄ 'uë₃, ca₂le₃jɨ́n₃ i₂con'₂ tsá₃ le₁ton₅ ne₄ si₂ ca₂le₃ ca₂nio₃ mɨ₂güɨ́g₃, mɨ₂si₂ a₂rë₂bɨn₅ a₂le₃chan₂ dsa₂; dsɨ₂qui₂dsɨ₃gó'₃ dsɨ́₅ jë₁ma₂jɨ́in₂ Já'₂ 'Lɨn'₅₄, 'uɨg₅₄ ia₁ a₂jme₁chain₂, tsá₃ ma₃chain₂ rë₂në́₃, la₁ia₁ a₂guáin₂ táng₃. 
\p  
\v 9 ’Jág₁ la₂ cha₂ a₂lé₂ le₃ŋɨ́'₂ juɨ₁lia'₂ dsa₂ i₂ŋɨ́'₂ dsɨ́₅: jáng'₅ jág₁ dsau₅ guio₃ mɨ₂dsi₄ já'₂, co₂'nió'₄ guio₃ dsɨ₂con'₂ ja₁guá₄ 'io₅₄ 'éi₂.  
\v 10 Ján₃ bá₄ co₂'nió'₄ guion₃ rag₅₄ a₂jaun₂. Ma₂i₃gan'₅₄ cau₅ 'ŋiá₂ rag₅₄ 'éi₂; jan₂ bá₄ i₂gon₂ rë₂në́₃; jan₂ guë'₂ i₂tsá₃ ma₂guan₅ guë́₄. Jë₁ma₂të́₂ rë₁guá₃ 'éi₂ guë'₂ në́₃, ca₂tiá₂ bá₄ ca₂tɨ́in₂ guá₃.  
\v 11 Já'₂ 'Lɨn'₅₄ i₂jme₁chan₂, i₂tsá₃ chan₂ rë₂në́₃ 'éi₂ guë'₂ në́₃, lén₂ i₂gon₂ i₂ca₂të́₂ jŋia₃ i₂co₂'nió'₄ rɨn'₅₄ i₂guion₃ 'éi₂ bá₄. Ján₃ bá₄ dsióg₄ ja₁dsɨ₃'éin₂. 
\p  
\v 12 ’A₂lë́₅ guia₃ mɨ₂juɨ́₁ a₂në₂jag'₅₄ në́₃, co₂'nió'₄ guian₃ rag₅₄ i₂tsá₃ ma₂ŋɨ₂ ja₁le₃goin₂. La₁ ŋei₃ bí₂ 'éi'₃ ca₂tiá₂ le₂jaun₂, në₂jag₄ caun₂ hora, lia'₂ ma₂quiain'₅₄ Já'₂ 'Lɨn'₅₄.  
\v 13 Tóin'₃ caun₂ ta₁ co₂dsia₅, 'ei₅ caun₂ jág₁, ton'₂ qui₃cuë₃ juɨ₅bí₂ quian'₅₄ 'éi'₃ quió'₅ cuë́'₃ Já'₂ 'Lɨn'₅₄.  
\v 14 Qui₃jmo₃ 'nei₂ quɨ́in'₂ quian'₅₄ Guein₂ Já'₂ Cha'₂. La₁ Guein₂ Já'₂ Cha'₂ bá₄ i₂lí'₂, ia₁ 'éi₂ bá₄ lɨ́n₅ Juɨg₅₄ quián₅ ca₂le₃jɨ́n₃ juɨg₅₄ dsa₂; ton'₂ lɨ́in₅ Rag₅₄ quián₅ ca₂le₃jɨ́n₃ rag₅₄. Ca₂le₃jɨ́n₃ i₂quian'₅₄ Guein₂ Já'₂ Cha'₂ në́₃, lɨ́in₅ i₂ma₂quióin'₂ i₂ma₂të́'₃ Diú₄, tióin₂ lɨ́in₅ dsa₂ i₂rë₂ti'₅₄ quiáin₅. 
\p  
\v 15 Jaun₂ ca₂tság₃ jniá₂: 
\p ―Juɨ₁lia'₂ a₂lë́₅ 'lióng₂ jmɨg₂ ja₁guá₄ 'io₅₄ 'lɨn'₅₄ a₂në₂jag'₅₄ në₅, co₂'nió'₄ ca₂le₃jë́₃ go₄ dsa₂, ca₂le₃jë́₃ nió'₃ dsa₂, ca₂le₃jë́₃ juɨg₂, ca₂le₃jë́₃ jág₁ jmei₅ në́₃.  
\v 16 Jaun₂ jme₃'iog₅₄ dsa₂ i₂co₂'nió'₄ a₂lë́₅ guia₃ mɨ₂juɨ́₁ i₂në₂jag'₅₄, jme₃'iog₅₄ Já'₂ 'Lɨn'₅₄ guë'₂ në́₃, jme₃'ŋiai₅₄ 'io₅₄ 'éi₂. Co₂dsia₅ qui₃téi₂ co₂'nió'₄ të₃tsɨin'₅₄ rë₃ŋɨ́i₅; qui₃quɨ́g'₃ nɨ₁ŋɨ₁₂, jaun₂ guë́₄ dság'₂ quian'₅₄ si₂.  
\v 17 Ia₁ Diú₄ në́₃ ma₂jmo₃ dsɨ́₅ dsa₂ 'éi₂ juɨ₁jmo₁₂ ca₂le₃jë́₃ 'e₂ niog₅ dsɨ́₅ jmo₃, ia₁jaun₂ jmo₃ caun₂ jág₁ a₂cuë₃ juɨ₅bí₂ a₂goin₂, cuë́'₃ Já'₂ 'Lɨn'₅₄, ca₂lia'₂ ca₂dsióg₃ jmɨg₄ a₂le₃ti₃ jág₁ quió'₅ Diú₄ a₂ma₂ron₅.  
\v 18 'Io₅₄ i₂në₂jɨng'₅₄ në́₃, co₂'nió'₄ ciudad juë'₂ ja₁o₂'ag₅ 'éi'₃ ne₄ quió'₅ ca₂le₃jɨ́n₃ rag₅₄ i₂chan₂ mɨ₂güɨ́g₃. 
\c 18  
\s1 Jë₁ca₂ŋó₃ 'uë₃ bí₂ quió'₅ Babilonia 
\p  
\v 1 Cang₂ jaun₂, ca₂jɨng₅₄ táng₃ jan₂ ángel sián'₂, ca₂sióin₃ guei'₅₄ i₂juɨ́g₃ i₂'io₅ bí₂ 'éi'₃ a₂'uain'₂ lɨn₃. Ta₁caun₂ mɨ₂güɨ́g₃ bá₄ ca₂tág'₃ a₂co₂tág₅ co₂'né'₅ quió'₅.  
\v 2 Quian'₅₄ jág₁ tiá₂ lɨn₃, ca₂juá'₂: 
\q1 Ma₂ca₂i₃'én₂, ma₂ca₂i₃'én₂ Babilonia juë'₂, 
\q2 'ne₄ ca₂le₃jɨ́n₃ ne₅₄ je₂na'₅₄ bá₄ ca₂lë₃; 
\q2 'né₅ 'má₃ ja₁ŋɨ'₂ ca₂le₃jɨ́n₃ ne₅₄ jme₂dsí₂ 'lɨn'₅₄, 
\q2 ca₂le₃jɨ́n₃ ne₅₄ i₁tan₅ 'lɨn'₅₄ lë₁'ŋio₅. 
\q1  
\v 3 Ia₁ ma₂qui₂ma₂'ɨn'₃ ca₂le₃jë́₃ juɨg₂ 
\q2 vino a₂ca₂jme₃cón₂ dsɨ́₅ a₂qui₂nió'₃ jág₁ 'lɨg'₅₄ quió'₅. 
\q1 Ma₂qui₂ca₂nió'₃ jág₁ rag₅₄ i₂chan₂ gua'₅₄ 'uë₃ 
\q2 quiain'₅₄ 'io₅₄ 'éi₂. 
\q1 Ca₂le₃jɨ́n₃ juɨ₁lia'₂ dsa₂ i₂i₂nio₄ jmo₂₃ 'ma'₅₄, 
\q1 ma₂qui₂ca₂rë₃chá₃ cu₄ 'ŋio₅ lɨn₃ 
\q2 të₂le₃ quian'₅₄ juɨ₅bí₂ a₂ma₂i₁juɨn₅₄ ŋag₅₄ 
\q2 a₂jlá'₁ jmo₂₃ róin₂. 
\p  
\v 4 Jaun₂ ca₂nag₃ táng₃ caun₂ jág₁ a₂já₅ guei'₅₄ i₂juɨ́g₃, a₂juá'₂: 
\q1 'Uɨn'₂ 'nia'₂ jë₄ juɨg₂ në₅, 
\q2 con'₂ 'nia'₂ i₂lɨ́ng'₅ dsa₂ juɨg₂ quiáng₃, 
\q1 ia₁jaun₂ tsá₃ le₃quen'₄ 'nia'₂ dso₄ a₂'no₅ 'io₅₄ në₅, 
\q2 on₃ guë'₂ tɨn'₃ 'nia'₂ jmɨ₁uɨg₅ a₂já₅ ja₁coin₂. 
\q1  
\v 5 Ia₁ 'lióng₂ lɨn₃ dsáu₁ 'io₅₄ në₅ ma₂rë₂juɨ́₄, 
\q2 në₂jag₄ bá₄ ma₂të́₂ ca₂të₂ guei'₅₄ i₂juɨ́g₃. 
\q1 Jaun₂ Diú₄ në́₃ ma₂dsáu'₅ dsɨ́₅ 
\q2 ca₂le₃jë́₃ a₂'lɨg'₅₄ a₂ma₂rë₂cáin'₄. 
\q1  
\v 6 A₂le₂jaun₂ cuë'₅₄ 'nia'₂ 'io₅₄ në₅ 
\q2 juɨ₁lia'₂ lë́₅ a₂ma₂qui₂ma₂cuë́'₃ dsa₂ 'ŋiog₅. 
\q1 Qui'₄ 'nia'₂ tɨn₃ ju'₂ 
\q2 lia'₂ con'₂ guë́₄ a₂ma₂jmo₃. 
\q1 Co₂güɨn'₅₄ 'nia'₂ tɨn₃ ráun₂ a₂'ŋio₅ guë́₄ 
\q2 ŋió'₂ copa quió'₅ 'ŋiog₅, 
\q2 con'₂ guë́₄ a₂ma₂cuë́'₃ i₂sián'₂. 
\q1  
\v 7 Juɨ₁lia'₂ a₂ŋɨ́₄ lë₃ ma₂qui₂ma₂chain₂ jlá'₁ a₂róin₂, 
\q2 co₂jaun₂ cuë'₅₄ 'nia'₂ jmɨ₁uɨg₅ a₂quɨ'₂ dsɨ́₅. 
\q1 Ia₁ ma₂juá'₂ bá₄ juɨ₅ të₂dsɨ́₅: 
\q1 “La₂ gua₅₄ a₂lɨ́ng₅ jan₂ 'io₅₄ rag₅₄, 
\q2 tsá₃ dsa₂ 'nág₂ lɨ́ng₅. 
\q2 Tsá₃ o₁lɨ́g'₂ ŋag₅₄ uɨg₅ le₃quɨ'₂ dsɨ₃.” 
\q1  
\v 8 'Uɨg₅₄ jaun₂ në́₃, 
\q2 co₂nio₄ co₂jmɨg₄ bá₄ ja₃lé₂ jmɨ₁uɨg₅ ja₁coin₂; 
\q1 'mú₃, quɨ'₃-'o₃, le₃'oin₅₄ në́₃; 
\q2 jaun₂ guë́₄ dsɨin'₂ co₂ŋei'₅₄. 
\q1 Ia₁ i₂'uan'₂ lɨn₃ bá₄ Te₁gui'₅₄ Diú₄ 
\q2 i₂qui₃dsɨ₅ 'éi'₃ ja₁coin₂ jmɨg₄ jaun₂. 
\p  
\v 9 'Cán₂ go₂'i₃, quɨ'₃-'o₃ ca₂le₃jɨ́n₃ rag₅₄ quián₅ gua'₅₄ 'uë₃ i₂qui₂ca₂nió'₄ jág₁ quiain'₅₄ 'io₅₄ 'éi₂, i₂qui₂ma₂ca₂rë₃cháin₃ jlá'₁ quiain'₅₄, jë₁ma₂ca₂jág₃ tsau₂ jme₁ŋi₁ guei'₅₄ a₂ma₂qui₂cau₂ quió'₅ 'io₅₄.  
\v 10 La₁ uɨ́ng₂ bá₄ qui₂dsɨ₃náu₃, qui₃jág₃ gó'₃ 'ŋio₅ lɨn₃, jaun₂ juá'₂: 
\q1 ¡'E₂ guë́₄ juɨ́g'₂, 'e₂ guë́₄ juɨ́g'₂, 
\q2 'ne₂ ciudad juë'₂, 
\q1 'ne₂ Babilonia i₂jme₁'uang'₂ lɨn₃ në́₃! 
\q1 ¡Quian'₅₄ ca₂tiá₂ co₂lág₂ bá₄ 
\q2 gua₅ uɨg₅ a₂rë₂'ë́₂ ja₁cong'₂! 
\p  
\v 11 'Cán₂ go₂'i₃, quɨ'₃-'o₃ dsa₂ i₂jme₁i₂nio₄ jmo₅ 'ma'₅₄ ne₄ gua'₅₄ 'uë₃, o₄quió'₄ 'éi₂; ia₁ tsá₃ ma₂'ein₂ le₃chan₂ qui₃lá₃ guë́₄ 'e₂ lio₅₄ i₂quian₅₄:  
\v 12 lio₅₄ a₂lë́₅ cu₄nióg₄, cu₄tiog₂, cang₄ jlá'₁, mɨ́g₂ perlas, ca₂le₃jë́₃ ne₅₄ juɨ₁lia'₂ 'mɨ'₂ jlá'₁, juɨ₁lia'₂ lino quian'₅₄ seda a₂'lióng₂ ne₅₄ jniá₂, a₂'uɨ'₃, a₂guéin₂ në́₃; ca₂le₃jë́₃ ne₅₄ 'ma₂ jlá'₁ në́₃ a₂ja₂ mɨ₂juɨg₂ ma₂ro₂; lióng₂ ne₅₄ cosas jlá'₁ në́₃, juɨ₁lia'₂ a₂lë́₅ nɨ₁mu₅, a₂lë́₅ nɨ₁'ma₂ jlá'₁ a₂'mu'₅₄, a₂lë́₅ nɨ₁ŋí₁ 'ua'₂, a₂lë́₅ nɨ₁ŋí₁ nióg₂ në́₃, nɨ₁cang₁ mármol táng₃;  
\v 13 lio₅₄ canela, ca₂le₃jë́₃ guë́₄ a₂ja₂ mɨ₂juɨg₂ ma₂ro₂ juɨ₁lia'₂ chen₂, mirra, no'₅₄ mɨ₂juɨg₂ në́₃; vino quian'₅₄ no'₅₄ olivo; cuɨg₂ dse₃ quian'₅₄ trigo; já'₂ në́₃, juɨ₁lia'₂ ca₁juɨ₅, já'₂ cha'₂ quian'₅₄ cua₁; nɨ₁ŋí₁ carrozas në́₃. Ca₂le₂jiog₅ dsa₂ mɨ₂güɨ́g₃ rɨn'₅₄ dsa₂ i₂jme₂ti₃ ta₁ ne₅₄.  
\v 14 'La₁ jmɨg₄ jaun₂ guë́₄ në́₃, juá'₂ tsɨ́'₃ ciudad jaun₂: 
\q1 ¡Ma₂ca₂jŋia'₃ ja₁cong'₂, mɨ́g₂ jlá'₁ 
\q2 a₂ŋɨ́₄ lë₃ jme₁'ɨ́n₅ 'au'₂ quë'₅₄! 
\q1 ¡A₂co₂dsia₅ ca₂i₃'én₂ jaun₂ bá₄ 
\q2 ca₂le₃jë́₃ a₂jlá'₁ 
\q2 a₂jme₁quen₅ cu₄ a₂jme₁cha₂ quiáng'₂! 
\q1 Tsá₃ ma₃o₁lɨ́g'₂ jmɨg₄ dsiang'₂. 
\p  
\v 15 'Dsa₂ i₂qui₂ma₂jmo₃ 'ma'₅₄ ca₂le₃jë́₃ a₂në₅, i₂qui₂ca₂rë₃chá₃ cu₄ 'ŋio₅ lɨn₃ të₂le₃ quian'₅₄ 'io₅₄ 'éi₂, qui₂dsɨ₃náu₃ uɨ́ng₂, qui₃jág₃ gó'₃ 'uɨg₅₄ jmɨ₁uɨg₅ a₂go₂'i₃ jaun₂.  
\v 16 Jaun₂ juá'₂ tiá₂: 
\q1 ¡'E₂ guë́₄ juɨ́g'₂, 'e₂ guë́₄ juɨ́g'₂, 
\q2 'ne₂ ciudad juë'₂! 
\q1 ¡Ia₁ jme₁lë́₄ juɨ₁lia'₂ lɨ́n₅ jan₂ 'io₅₄ jlán'₁ 
\q2 i₂jme₁qui'₂ tsɨn'₅₄ jlá'₁ lɨn₃ 
\q1 a₂jme₁jniá₂ 'uɨ'₃ quian'₅₄ a₂guéin₂, 
\q2 i₂jme₁rë₂lɨn₄ jlán'₁ quian'₅₄ cu₄nióg₄, 
\q2 nɨ₁cang₁ jlá'₁, mɨ́g₂ perlas në́₃! 
\q1  
\v 17 ¡Quian'₅₄ ca₂tiá₂ co₂lág₂ bá₄, 
\q2 qui₂ca₂dsa₃ ca₂ag₂ a₂jlá'₁ a₂quen₅ 'lióng₂ lɨn₃! 
\p 'Ca₂le₃jɨ́n₃ juɨ₁lia'₂ i₂i₂quian₅ nɨ₁barcos, ca₂le₃jɨ́n₃ guë́₄ dsa₂ i₂i₂nio₄ ne₄ jmɨ₁ŋí'₄, ca₂le₃jɨ́n₃ guë́₄ dsa₂ i₂'no₅ a₂dsɨ₂ŋɨ́i₂ ne₄ jmɨ₁ŋí'₄, qui₂dsɨ₃náu₃ uɨ́ng₂,  
\v 18 jë₁ma₂ca₂jág₃ jme₁ŋi₁ a₂ma₂qui₂cau₂ quió'₅, qui₃juá'₂ tiá₂ tóin'₃: 
\p ―¿'E₂ bá₄ ciudad lé₂ le₃quɨn₃ quian'₅₄ ciudad juë'₂ në₅? 
\p  
\v 19 Jaun₂ qui₂tó'₃ ti₁juɨ₁ ne₄ mɨ₂dsi₅₄ guioin₅₄, quɨ'₂-'o₂₃, a₂juá'₂ tiá₂: 
\q1 ¡'E₂ guë́₄ juɨ́g₂, 'e₂ guë́₄ juɨ́g₂ 
\q2 ciudad juë'₂ në₅! 
\q1 Quian'₅₄ ca₂le₃jë́₃ a₂jme₁cha₂ quió'₅, 
\q2 ca₂rë₃chá₃ cu₄ ca₂le₃jɨ́n₃ dsa₂ 
\q2 i₂qui₂le₁'io₅ barcos ne₄ jmɨ₁ŋí'₄. 
\q1 ¡Quian'₅₄ ca₂tiá₂ co₂lág₂ bá₄ ca₂'en₃ jë₂! 
\q1  
\v 20 La₁ 'nia'₂ në́₃, 
\q2 i₂chan'₂ guei'₅₄ i₂juɨ́g₃, 
\q1 jmo₄ 'nia'₂ 'io'₂ ne₄ quió'₅ juɨg₂ jaun₂. 
\q2 Ca₂le₃jɨ́n'₃ guë'₂ 'nia'₂ i₂tén₅ le₃quió'₅ Diú₄, 
\q2 i₂chen₄ quiáin₅, i₂qui₂'ë́₂ jág₁ quió'₅ në́₃. 
\q1 Ia₁ ma₂në₂qui₃dsɨ₅ Diú₄ 'éi'₃ ja₁con₂ juɨg₂ jaun₂, 
\q2 ma₂në₂jme₃rë́₃ ca₂le₃jë́₃ a₂ma₂jmái'₂ 'nia'₂ jaun₂. 
\p  
\v 21 Jaun₂ ca₂chóg'₃ jan₂ ángel 'uan'₂ ca₂mɨ́g₂ nɨ₁cang₁ pa₁, a₂lë́₅ juɨ₁lia'₂ lë́₅ nɨ₁cang₁ éi'₅ cuɨg₂ 'í₅; ca₂ton₃ ne₄ jmɨ₁ŋí'₄, ca₂juá'₂: 
\q1 Quian'₅₄ 'nei₂ uɨg₅ le₂në₅ bá₄ 
\q2 dsó₃ 'uë₃ ján₃, 
\q1 Babilonia ciudad juë'₂, 
\q1 tsá₃ ma₃a₁jaun₂ jua'₅₄ le₃cha₂. 
\q1  
\v 22 O₁lɨ́g'₂ jmɨg₄ tsá₃ ma₃qui₂né'₂ a₂jmo₃ dsa₂ son₅₄ 
\q2 juɨ₁lia'₂ jë₄ calle quiáng'₂: 
\q1 juɨ₁lia'₂ son₅₄ tsɨ₁ton₅ arpas,\f + \fr 18:22 \ft griego: kithara.\f* 
\q2 son₅₄ 'ma₂, son₅₄ ŋí₁ trompeta në́₃. 
\q1 Tsá₃ ma₃le₃chan₂ të₅ 
\q2 i₂tɨn₂ ta₁ 'i₁jan₂, ja₁cong'₂; 
\q1 tsá₃ ma₃qui₃né'₂ mɨ'₅₄ 
\q2 nɨ₁cang₁ éi'₅ cuɨg₂ 'í₅, ja₁cong'₂; 
\q1  
\v 23 si₂ nng'₂; 
\q1 jág₁ quió'₅ 'io₅₄, 
\q1 quió'₅ dsa₂ ŋe'₂ i₂jen'₂ gu₂, 
\q2 tsá₃ ma₃o₁lɨ́g'₂ qui₃né'₂ ja₁cong'₂. 
\q1 Ia₁ dsa₂ dsen₅₄ jɨn₄ dsa₂ mɨ₂güɨ́g₃ 
\q2 jme₁lɨ́n₄ dsa₂ i₂qui₂jme₁jmo₅ 'ma'₅₄ quiáng'₂, 
\q1 ia₁ ca₂jme₁gang'₂ ca₂le₃jë́₃ juɨg₂ 
\q2 të₂le₃ quian'₅₄ a₂chan₂ 'au'₂. 
\q1  
\v 24 Ia₁ 'éi₂ bá₄ rë₂cán'₄ jmɨ₂ 'an₅₄ 
\q2 ca₂le₃jɨ́n₃ dsa₂ i₂tén₅ le₃quió'₅ Diú₄, 
\q2 i₂ma₂'ë́₂ jág₁ quió'₅ në́₃, 
\q1 quian'₅₄ ca₂le₃jɨ́n₃ i₂ca₂dsan₃ 
\q2 ca₂jme₃dsiog₅ dsa₂, ne₄ gua'₅₄ 'uë₃. 
\c 19  
\p  
\v 1 Cang₂ jaun₂, ca₂nag₃ lia'₂ lë́₅ jág₁ quió'₅ juɨn₅ lɨn₃ dsa₂ i₂tion'₅₄ guei'₅₄ i₂juɨ́g₃, i₁juá'₄ co₂mɨ'₅₄: 
\q1 ¡Aleluya!* 
\q1 Te₁gui'₅₄ Diú₄ quián₂ bá₄ jniog₄ i₂lió₂, 
\q2 i₂ca₂tɨ́n₂ gue₃ a₂jme₃juag'₂ dsa₂, 
\q2 i₂ca₂tɨ́n₂ juɨ₅bí₂ a₂náu₃ ne₄ 'éi'₃. 
\q1  
\v 2 Ia₁ dsau₅, ton'₂ dsi₂ten₅₄ bá₄ lë́₅ 
\q2 a₂qui₂dsɨ₂₃ 'éi'₃. 
\q1 Ia₁ ma₂në₂qui₂dsɨ₂₃ 'éi'₃ 
\q2 ja₁con₂ 'io₅₄ 'lɨn'₅₄ juɨn'₂, 
\q2 i₂ma₂ca₂jme₃'ióg₃ ta₁caun₂ mɨ₂güɨ́g₃ 
\q2 quian'₅₄ jág₁ 'lɨg'₅₄ a₂ma₂qui₂ma₂nió'₃. 
\q1 Jaun₂ 'ŋiog₅ bá₄ Diú₄ ma₂në₂quion₃ 'ma'₅₄ 
\q2 ja₁con₂ 'io₅₄ 'éi₂, 
\q1 ne₄ quió'₅ jmɨ₂ 'an₅₄ ca₂le₃jɨ́n₃ dsa₂ quián₅ Diú₄ 
\q2 i₂jme₂ti₃ ta₁ ne₅₄. 
\p  
\v 3 Con'₂ siá'₂ táng₃ ca₂juá'₂: 
\q1 ¡Aleluya! 
\q1 Tsau₂ jme₁ŋi₁ a₂con₂ 'io₅₄ 'éi₂ 
\q2 ca₂lia'₂ co₂tan₅₄. 
\p  
\v 4 Jaun₂ në́₃, le₃guión₂-quén₂ dsa₂ can'₅₄, quian'₅₄ guë'₂ le₃quén₂ já'₂ i₂tión₂ le₃ne₄ ne₄ta₁, qui₂ca₂tóin₂ 'uë₃ ca₂jme₃juɨin'₂ Diú₄ i₂guá₅ ne₄ta₁, qui₂ca₂juá'₂: 
\p ―¡A₂méi₃! ¡Aleluya! 
\p  
\v 5 Jaun₂ guë́₄ ca₂né'₂ jág₁ të₂ ne₄ta₁, i₁juá'₄: 
\q1 Jme₁juɨn'₂ 'nia'₂ Diú₄ quián₂ 
\q2 ca₂le₃jɨ́n'₃ 'nia'₂ i₂jme₂ti₃ ne₅₄ 
\q2 ca₂le₃jɨ́n'₃ 'nia'₂ i₂juɨn'₂ i₂me'₂ 
\q2 i₂go₃ gain₃ 'éi₂. 
\s1 Jmɨg₄ ja₁jen'₂ gu₂ Guein₂ Já'₂ Cha'₂ 
\p  
\v 6 Jaun₂ ca₂nag₃ jniá₂ co₂mɨ'₅₄ a₂né'₂ lia'₂ né'₂ jág₁ ja₁i₁tion'₅₄ dsa₂ juɨn₅, lia'₂ né'₂ ja₁ta'₂ la'₅₄ pa₁ lɨn₃,\f + \fr 19:6 \ft o₃ “lia'₂ né'₂ 'lióng₂ jmɨg₂.” \f* juɨ₁lia'₂ të₂tsɨ'₅₄ co₂mɨ'₅₄ quia'₂ ŋí'₃ tiá₂ lɨn₃, i₁juá'₄: 
\q1 ¡Aleluya! 
\q2 Ia₁ ma₂gon₂ Te₁gui'₅₄ Diú₄ quián₂ jniog₄ 
\q2 i₂'Uan'₂ guë́₄ lɨn₃. 
\q1  
\v 7 ¡Juɨ₁jmó₁ jniog₄ 'io'₂ 
\q2 o₂'ŋió₃ o₂jŋia₃ dsɨ₅, 
\q1 juɨ₁jme₁juɨn'₂ jniog₄ 'éi₂! 
\q1 Ia₁ ca₂të́₂ hora a₂jen'₂ gu₂ 
\q2 Guein₂ Já'₂ Cha'₂. 
\q1 Dsa₂ mɨ́₂ i₂jen'₂ gu₂ quiain'₅₄ në́₃ 
\q2 ma₂chain₂ co₂jŋiai₅₄. 
\q1  
\v 8 Ma₂ŋɨi₂ tsɨ₁'mɨ'₂ lino jlá'₁ 
\q2 a₂tág₅, a₂le₁jë́₃ lɨn₃, a₂rë₂lɨin₅₄. 
\m (Ia₁ juɨ₁lia'₂ tsɨ₁'mɨ'₂ lino jlá'₁ në́₃, co₂'nió'₄ juɨ₅ dsau₅ a₂ma₂quian₅ dsa₂ i₂tén₅ le₃quió'₅ Diú₄.)\f + \fr 19:8 \ft lit. “a₂ma₂quian₅ dsa₂ jŋió'₅.” \f* 
\p  
\v 9 Jaun₂ ca₂juá'₂ ángel ca₂tság₃ jniá₂: 
\p ―Jmo₄ si₂ tiong₅: “'E₂ guë́₄ dsen₃ ca₂le₃jɨ́n₃ dsa₂ i₂të́₄ jmɨg₄ ja₁jen'₂ gu₂ Guein₂ Já'₂ Cha'₂.” 
\p Jaun₂ ca₂juá'₂ táng₃: 
\p ―Jág₁ tí₅ të₃dsón'₂ bá₄ la₂ quió'₅ Diú₄. 
\p  
\v 10 Jaun₂ ca₂tón₂ jniá₂ ja₁tióng₂ tag₄ ángel 'éi₂ a₂jme₁jme₁juɨin'₂ jniá₂. La₁ ca₂juá'₂ në́₃: 
\p ―'A₃ jmo₂ le₂në₅. Ia₁ jan₂ rɨ́n'₂ 'ne₂ bá₄ lɨ́ng₅, i₂jme₂ti₃ ta₁ ne₄ Diú₄, ton'₂ lɨ́ng₅ jan₂ rɨn'₅₄ rɨ́n'₂ 'ne₂ i₂qui₂'ë́₂ jág₁ o₄quió'₄ Diú₄, quian'₅₄ i₂tón'₂ juɨ₅ jág₁ a₂rë₂'ë́₂ quió'₅ Diú₄ a₂tio'₅₄ ne₄ si₂ la₂. Jme₁juɨn'₂ Diú₄. Ia₁ jág₁ dsau₅ quió'₅ Jesús bá₄ a₂'i₄ jme₂dsí₂ quió'₅ juɨ₁lia'₂ i₂'ë́₂ jág₁ o₄quió'₄ Diú₄. 
\s1 Dsa₂ i₂ŋó₅ co₁dsɨn₅₄ cua₁ tion₂ 
\p  
\v 11 Jaun₂ ca₂jág₃ jniá₂ rë₂na₄ guei'₅₄ i₂juɨ́g₃, jaun₂ ca₂jnia₃ jan₂ dsɨ₂cua₁ tion₂. Dsa₂ i₂co₂dsag₅₄ guë'₂ chen₂ I₂rë₂ti'₅₄, I₂dsau₅ në́₃. Con'₂ dsi₂ten₅₄ bá₄ qui₂dsɨ₂₃ 'éi'₃, jmo₂₃ 'nei₂.  
\v 12 Tág₅ jme₁ne₁₂ lia'₂ tág₅ si₂; tio'₅₄ 'lióng₂ coronas mɨ₂dsi₅₄ ja₁le₁ton₅ lia'₂ chein₂, jŋia'₅₄ lia'₂ 'ŋiog₅ bá₄ ŋɨ́i'₂, tsá₃ 'ein₂ i₂sián'₂ ŋɨ́'₂.  
\v 13 Qui'₂ caun₂ 'mɨ'₂ chen'₅₄ a₂në₂jag₄ bá₄ ma₂i₂tia₃ jmɨ₂; a₂chen₂ 'éi₂ guë'₂ në́₃ Jág₁ quió'₅ Diú₄.\f + \fr 19:13 \ft 'Nio'₂ ja₁ton₅ Juan 1:1-14.\f* 
\v 14 Chi₁co'₅₄ quió'₅ 'éi₂, të₁ja₂lén₂ juɨn₅ lɨn₃ 'lióg₂ quián₅ guei'₅₄ i₂juɨ́g₃. Ca₂le₃jɨ́in₃ le₁qui'₂ jmá'₃ 'mɨ'₂ lino tiog₂ jlá'₁ a₂le₁jë́₃, a₂ca₂'uɨin₂ qui₂co₂dsɨin₅₄ cua₁ tion₂.  
\v 15 Mɨ₂'o₄ 'éi₂ dsi₅₄ caun₂ a₂lë́₅ lia'₂ lë́₅ ŋi₁tág₂ 'mu₃ lɨn₃ a₂jmái'₂ ca₂le₃jɨ́n₃ juɨg₂ ne₄ gua'₅₄ 'uë₃. “Goin₃ ne₄ 'éi₂ quian'₅₄ 'ma₂'ɨ'₅₄ a₂lë́₅ nɨ₁ŋí₁ 'ua'₂.”\f + \fr 19:15 \ft Salmo 2:9.\f* Qui₃tsó'₃ në₂jag₄ bá₄ mɨ́g₂ uvas a₂'i₄ 'nei₂ dséi₂ dsɨ́₅ Diú₄ 'Uan'₂.  
\v 16 Ne₄ tsɨ₁'mɨ'₂ chen'₅₄, ne₄ mɨ₂qui₅₄ në́₃, chi₁ton₅ 'a₂ lia'₂ chein₂: RAG₅₄ QUIÁN₅ CA₂LE₃JƗ́N₃ RAG₅₄ JUƗG₅₄ CA₂LE₃JƗ́N₃ JUƗG₅₄. 
\p  
\v 17 Jaun₂ ca₂jɨng₅₄ jan₂ ángel chéin'₅ dsi₂jo₂ 'iog₂. 'Éi₂ në́₃ ca₂juá'₂ tiá₂ lɨn₃ qui₂ca₂tsɨ́'₃ ca₂le₃jɨ́n₃ já'₂ i₂'ɨn₅ guei'₅₄ dsi₂güɨg₂: 
\p ―I₂nó'₅ 'nia'₂, tión'₂ 'nia'₂ lo'₂, ia₁ le₃cha₂ má₃ pa₁ cuë₃ Diú₄,  
\v 18 ia₁jaun₂ tón'₄ 'nia'₂ quë'₅₄ jmá'₃ ŋɨ́₅: ŋɨ₄ rag₅₄, ŋɨ₄ ca₂le₃jɨ́n₃ juɨg₅₄ 'lióg₂, ŋɨ₄ ca₂le₃jɨ́n₃ guë́₄ dsa₂ bén₂ në́₃. Ca₂lia'₂ ŋɨ₄ cua₁ në́₃, ŋɨ₄ dsa₂ i₂jme₁co₂dsag₅₄ në́₃; ŋɨ₄ ca₂le₃jɨ́n₃ guë́₄ dsa₂: lia'₂ dsa₂ i₂jme₂ti₃ ta₁ ne₄ juɨg₅₄, lia'₂ dsa₂ i₂tsá₃ 'ein₂ ne₄ jme₂ti₃; lia'₂ dsa₂ i₂juɨn'₂ lia'₂ dsa₂ me'₂. 
\p  
\v 19 Jaun₂ ca₂jɨng₅₄ i₂të́'₂ Já'₂ 'Lɨn'₅₄, quiain'₅₄ ca₂le₃jɨ́n₃ rag₅₄ chan₂ ta₁caun₂ gua'₅₄ 'uë₃, quiain'₅₄ ca₂le₃jɨ́n₃ 'lióg₂ quiáin₅. Ca₂liain'₃ rɨin'₅₄ ca₂jmo₃ caun₂ jág₁ a₂quɨ́in'₂ quiain'₅₄ i₂co₂dsɨn₅₄ cua₁ quiain'₅₄ ca₂le₃jɨ́n₃ 'lióg₂ i₂quiain'₅₄ në́₃.  
\v 20 Já'₂ 'Lɨn'₅₄ në́₃ ca₂'néi'₃ bá₄ co₂dsia₅ quiain'₅₄ dsa₂ i₂'ë́₂ jág₁ a₂juɨ₁gain₂ i₂ma₂jmo₃ 'lióng₂ léi₄ juë'₂ o₄quió'₄ 'éi₂; ia₁ të₂le₃ quian'₅₄ tsá₃ caun₂ o₂dsain₂ ca₂jme₃jniai₂₃ jɨn₄ dsa₂, ca₂jme₃gain₂₃ dsa₂ i₂ma₂lɨ́n₅ léi₄ quián₅ Já'₂ 'Lɨn'₅₄, i₂ma₂ca₂jme₃juɨn'₂ nió'₄ quió'₅ 'éi₂ në́₃. Le₃on₃ 'éi₂ co₂dsia₅ bá₄ ca₂të₁dsɨin₅₄ të₃jéin'₃ le₂jaun₂ ja₁'a₄ si₂ a₂cau₂ quian'₅₄ azufre, a₂juë'₂ lia'₂ juë'₂ jmɨ₁ŋí'₄.  
\v 21 Ca₂le₃jɨ́n₃ guë́₄ rɨn'₅₄ 'éi₂ në́₃ ca₂dsain₃ quian'₅₄ ŋi₁tág₂ a₂o₂'ag₅ mɨ₂'o₄ i₂co₂dsɨn₅₄ dsɨ₂cua₁ 'éi₂. Jaun₂ guë́₄ qui₂ca₂guë́'₃ ca₂le₃jɨ́n₃ já'₂ i₂'ɨn₅, lia'₂ mag'₂ dsɨ́₅, ŋɨ₄ i₂ca₂dsan₃ 'éi₂. 
\c 20  
\s1 Caun₂ mei₅ ŋi₂ 
\p  
\v 1 Jaun₂ ca₂jɨng₅₄ táng₃ jan₂ ángel, ca₂sióin₃ guei'₅₄ i₂juɨ́g₃. Chi₁chan'₂ ŋí₁ llave quió'₅ ja₁ca₂jein₃ chi₁dsio₅₄, caun₂ guë'₂ cadena pa₁ quian₅.  
\v 2 Jaun₂ ca₂jŋai'₃ i₂të́'₂ já'₂ dragón, dsɨ₂mɨ'₂ 'ón₅ 'éi₂, i₂lɨ́n₅ i₂së₃dsen₃ i₂chen₂ Satanás, jaun₂ ca₂'néi'₃ caun₂ mei₅ ŋi₂.  
\v 3 Ca₂'liog'₃ ja₁ca₂jein₃ chi₁dsio₅₄, ca₂jnéi₃ ja₁jaun₂, ton'₂ ca₂tióng₃ caun₂ sello ia₁jaun₂ tsá₃ ma₃lé₂ jme₃gain₂₃ guë́₄ juɨg₂ a₂cha₂ ne₄ gua'₅₄ 'uë₃, ca₂lia'₂ ca₂dsɨn₃ caun₂ mei₅ ŋi₂. Cang₂ jaun₂ jë₁ma₂ca₂dsɨn₃ caun₂ mei₅ ŋi₂, jaun₂ guë́₄ chein'₂ táng₃ co₂'na₂. 
\p  
\v 4 Jaun₂ ca₂jág₃ táng₃ jniá₂ ja₁tióng₂ ne₄ta₁; ja₁jaun₂ tián'₅ i₂ma₂ŋɨ₂ juɨ₅bí₂ a₂qui₃dsɨ₂₃ 'éi'₃. Ján₃ bá₄ ca₂jág₃ jme₂dsí₂ quió'₅ dsa₂ i₂qui₂ca₂quí'₃ dsa₂ dsɨ₂lag₄ ne₄ 'uɨg₅₄ ia₁ a₂qui₂ca₂jáng'₃ jág₁ dsau₅ quió'₅ Jesús, o₄quió'₄ jág₁ quió'₅ Diú₄ në́₃. Tsá₃ ca₂jme₃juɨin'₂ Já'₂ 'Lɨn'₅₄, on₃ guë'₂ ca₂gue₃ të₃ton₅₄ léi₄ quió'₅, dso'₂ chi₁quí₃, on₃ guë'₂ co'₅₄ gú₃ në́₃. Jaun₂ ca₂jen'₅₄ táng₃ 'éi₂, ca₂rë₃goin₂ quiain'₅₄ Cristo caun₂ mei₅ ŋi₂.  
\v 5 (La₁ ca₂le₃jɨ́n₃ guë́₄ 'lag₄ sián'₂ guë'₂ në́₃, tsá₃ ca₂jein'₅₄ ca₂lia'₂ ca₂dsɨn₃ caun₂ mei₅ ŋi₂.) Co₂'nió'₄ a₂jaun₂ bá₄ le₃jua'₅₄ jë₁le₂'uɨg₅₄ a₂jen'₅₄ 'lag₄.  
\v 6 ¡'E₂ guë́₄ dsen₃, 'e₂ guë́₄ jŋió₅, juɨ₁lia'₂ dsa₂ i₂quen'₄ jë₁le₂'uɨg₅₄ a₂jen'₅₄ dsa₂! Ia₁ ja₁con₂ 'éi₂ guë́₄ në́₃ tsá₃ ma₃juɨ₅bí₂ 'io₃ jë₁ca₂të́₂ táng₃ 'mú₃. Dsa₂ 'éi₂ guë́₄ në́₃ léin₂ jme₂dsa₂ le₃ne₄ Diú₄, quian'₅₄ le₃ne₄ Cristo, ton'₂ goin₃ ján₃ quiain'₅₄ 'éi₂ caun₂ mei₅ ŋi₂. 
\p  
\v 7 Jë₁ma₂ŋɨ́₂ caun₂ mei₅ ŋi₂ jaun₂, jaun₂ guë́₄ chen'₂ táng₃ Satanás ja₁rë₂jnɨ́i₅,  
\v 8 a₂o₃'ɨin₅, dsɨ₃jme₃gain₂₃ juɨg₂ ta₁quén₂ qui'₅₄ quió'₅ gua'₅₄ 'uë₃: ca₂të₂ ja₁chei₂ Gog quian'₅₄ Magog.\f + \fr 20:8 \ft o₃, “Magog ja₁gon₂ Gog”. 'Nio'₂ ja₁ton₅ Ezequiel 38:2 - 39:16.\f* Ja₁jaun₂ guë́₄ në́₃ chi₃liain'₃ a₂jmo₃ caun₂ jág₁ a₂jmo₃ 'nei₂. I₂juɨn₅ lɨn₃ lë́₂, lia'₂ ja₁lë́₄ mɨ₂tsag₄ a₂cha₂ chei'₅₄ jmɨ₁ŋí'₄. 
\p  
\v 9 Jaun₂ ca₂i₃léin₂ ta₁caun₂ juɨ₅ con'₂ lë́₅ 'ɨ́₂ gua'₅₄ 'uë₃, jaun₂ ca₂jë₂lɨ'₅₄ le₃lág'₃ ja₁tion'₅₄ dsa₂ i₂tén₅ le₃quió'₅ Diú₄, co₂'nió'₄ juɨg₂ ciudad a₂'nio₃ Diú₄. Jaun₂ qui₂ca₂séi'₂ si₂ guei'₅₄ i₂juɨ́g₃, ca₂dsɨin'₂ co₂ŋei'₅₄.  
\v 10 Jaun₂ i₂së₃dsen₃ i₂ca₂jme₃gau₅ quió'₅ dsa₂ 'éi₂ në́₃, i₂'ɨ́in₃ ja₁'a₄ si₂ a₂cau₂ quian'₅₄ azufre, ja₁ma₂'en₅₄ Já'₂ 'Lɨn'₅₄ quiain'₅₄ dsa₂ i₂'ë́₂ jág₁ a₂juɨ₁gain₂, a₂ŋág₃ uɨg₅ lia'₂ 'uë₂-jmɨ₂ ca₂lia'₂ co₂tan₅₄. 
\s1 Jë₁të₃dsɨ₅₄ 'éi'₃ ne₄ta₁ tiog₂ a₂juë'₂ 
\p  
\v 11 Jaun₂ ca₂jág₃ táng₃, ca₂jnia₃ caun₂ ne₄ta₁ juë'₂ tiog₂, jaun₂ ca₂jɨng₅₄ i₂guá₅ ne₄ta₁. Ne₄ 'éi₂ ca₂cuɨng₃ gua'₅₄ 'uë₃ quian'₅₄ guei'₅₄ dsi₂güɨg₂, ca₂lia'₂ tsá₃ ma₃ja₁ca₂dsáu'₂.  
\v 12 Ja₁jaun₂ guë́₄ ca₂jɨng₅₄ ca₂le₃jɨ́n₃ 'lag₄, lia'₂ i₂can'₅₄ lia'₂ i₂me'₂, jniái₂ tióin₂ ne₄ Diú₄. Jaun₂ qui₂ca₂niá₃ mɨ₂si₂ rë₂bɨn₅. Con'₂ siá'₂ ca₂niá₃ mɨ₂si₂ a₂le₃chan₂ dsa₂ co₂tan₅₄. Ca₂të₁dsɨ₅₄ 'éi'₃ ja₁con₂ 'lag₄ lia'₂ con'₂ lë́₅ ca₂jmo₃ le₂jain₂ le₂jain₂ con'₂ lë́₅ le₁ton₅ ne₄ mɨ₂si₂ jaun₂.  
\v 13 Ca₂jɨ́n'₂ jmɨ₁ŋí'₄ ca₂jɨ́in'₂ 'lag₄ i₂jme₁tion'₅₄ jë₄ jaun₂; qui₂ca₂jɨ́n'₂ 'Mú₃ quian'₅₄ guë'₂ Tau₂ 'Ŋio₅a qui₂ca₂jɨin'₂ 'lag₄ i₂jme₁tion'₅₄ ja₁jaun₂. Jaun₂ ca₂të₁dsɨ₅₄ 'éi'₃ quió'₅ le₂jain₂ le₂jain₂ lia'₂ con'₂ lë́₅ a₂ca₂jmo₃.  
\v 14 Jaun₂ qui₂i₃gan'₅₄ 'Mú₃ quian'₅₄ Tau₂ 'Ŋio₅\f + \fr 20:14 \ft griego: hades, co₂'nió'₄ a₂juá'₂, ja₁quió'₄ 'lag₄.\f* ja₁'a₄ si₂. Co₂'nió'₄ ja₁'a₄ si₂ jaun₂, lë́₅ jë₁ca₂të́₂ táng₃ 'mú₃.  
\v 15 Juɨ₁lia'₂ i₂tsá₃ ca₂dsán'₂ chi₁toin₂₃ ne₄ mɨ₂si₂ a₂chan₂ dsa₂ co₂tan₅₄, ja₁'a₄ si₂ bá₄ ca₂i₃'ɨ́in₃. 
\c 21  
\s1 Caun gua'₅₄ 'uë₃ 'mɨ́₂, quian'₅₄ caun₂ dsɨ₄ 'mɨ́₂ 
\p  
\v 1 Cang₂ jaun₂, ca₂jág₃ táng₃ jniá₂ caun₂ gua'₅₄ 'uë₃ 'mɨ́₂, caun₂ dsɨ₄ 'mɨ́₂ táng₃, ia₁ jë₁le₂'uɨg₅₄ dsɨ₄ quian'₅₄ guë'₂ le₂'uɨg₅₄ gua'₅₄ 'uë₃ co₂dsia₅ ca₂i₃'én₂ bá₄ jaun₂, on₃ guë'₂ jmá'₃ jmɨ₁ŋí'₄ ma₃cha₂ në́₃.  
\v 2 Jaun₂ ca₂jág₃ jniá₂\f + \fr 21:2 \ft Cha₂ a₂lɨn₅₄ chog₅₄ si₂ me'₂, a₂juá'₂: “jniá₂, Juan₅₄, ca₂jág₃.” \f* Juɨg₂ Ciudad Jŋió₅, Jerusalén 'mɨ́₂, a₂ca₂jnia₃ ca₂sio₃ guei'₅₄ i₂juɨ́g₃ ne₄ Diú₄. Jniá₂ ma₂lë́₅ co₂jŋia₅₄ jlá'₁ lɨn₃, në₂jag₄ bá₄ jan₂ dsa₂ mɨ́₂ i₂rë₂lɨn₄ quián₅ dsa₂ ŋe'₂ i₂lɨ'₅₄ jág₁ quiain'₅₄.  
\v 3 Jaun₂ ca₂nag₃ jág₁ a₂já₅ ne₄ta₁ ca₂juá'₂ tiá₂: 
\p ―Jag₄, ma₂guá₅ bá₄ Diú₄ jɨn₄ dsa₂ mɨ₂güɨ́g₃. Jɨn₄ 'éi₂ 'í₂ co₂tan₅₄ bá₄. Lén₂ dsa₂ 'éi₂ dsa₂ juɨg₂ quiáin₅, jaun₂ 'ŋiog₅ bá₄ Diú₄ jme₃quiong'₅₄ a₂léin₂ Diú₄ quiáin₅,  
\v 4 Jaun₂ qui₃chí₃ jme₁ne₁ 'éi₂ ca₂le₃jë́₃ jmɨg₂ a₂le₁'ág₄. Tsá₃ ma₃le₃cha₂ guë́₄ 'mú₃, on₃ guë'₂ jua'₅₄ në₅ qui₃tón'₃ guë́₄ dsa₂ quɨ'₂-'o₂₃, on₃ guë'₂ në₅ i₃nioi₅₄ guë́₄ chain₂ o₂i₁ dsɨ₅, on₃ guë'₂ le₃cha₂ jua'₅₄ quɨ'₂ uɨg₅ quió'₅. Ia₁ co₂dsia₅ ca₂ŋɨ́₂ bá₄ ca₂le₃jë́₃ 'e₂ a₂jme₁cha₂ le₂jŋiá₅. 
\p  
\v 5 Jaun₂ ca₂juá'₂ i₂guá₅ ne₄ta₁: 
\p ―La₂ jag₄, jmo₅₄ jniá₂ a₂'mɨ́₂ ca₂le₃jë́₃. 
\p Ca₂juá'₂ ján₃: 
\p ―Tiong₅ ne₄ si₂, ia₁ jág₁ dsau₅ a₂rë₂ti'₅₄ bá₄ la₂. 
\p  
\v 6 Jaun₂ ca₂tság₃ jniá₂: 
\p ―Ca₂lë₃. Jniá₂ bá₄ 'éi₂ i₂lɨ́ng₅ Alfa quian'₅₄ Omega: i₂lɨ́ng₅ i₂le₂ne₁, i₂lɨ́ng₅ jë₁ca₂tó'₂ në́₃. Juɨ₁lia'₂ i₂rë₂quein₂ dsɨ́₅, cuë₅₄ jniá₂ a₂'ɨ́n'₂ 'éi₂ jmɨg₂ a₂'ia₂ o₄tu₁ jmɨg₂ a₂le₃chan₂ dsa₂, on₃jua'₅₄ a₂cha₂ quɨn₃ 'i₁caun₂.  
\v 7 Juɨ₁lia'₂ i₂ca₂tió'₃, a₂lë₁ŋei₃ cuë₅₄ jniá₂ ca₂le₃jë́₃ a₂në₅, jaun₂ jniá₂ bá₄ léng₂ Diú₄ quiáin₅, 'éi₂ guë'₂ léin₂ chi'₂-guein₂ quiáng₃.  
\v 8 La₁ juɨ₁lia'₂ dsa₂ i₂tén'₅, juɨ₁lia'₂ dsa₂ i₂tsá₃ 'én₂, juɨ₁lia'₂ i₂lɨ₁'ŋio₅, juɨ₁lia'₂ i₂jme₂dsian₅ rɨn'₅₄, juɨ₁lia'₂ i₂nió'₅ jág₁ a₂tsá₃ dsi₂ten₅₄ nió'₃, juɨ₁lia'₂ i₂tɨn₂ mɨ́₅ a₂chan₂ dsɨ́₅, juɨ₁lia'₂ i₂jme₂juɨn'₂ diú₄ lag₄, ca₂le₃jɨ́n₃ i₂co₂jmo₅ jág₁ të₂jág₁ në́₃; ca₂le₃jɨ́n₃ dsa₂ në₅ tɨin₃ dsɨ₃léin₂ ja₁'a₄ si₂ a₂cau₂ quian'₅₄ azufre, a₂lë́₅ jë₁ca₂të́₂ táng₃ 'mú₃. 
\s1 Caun₂ Jerusalén 'mɨ́₂ 
\p  
\v 9 Jaun₂ ca₂guan₃ jan₂ ángel i₂lë́₂ i₂guion₃ i₂jme₁le₁chan'₂ guio₃ nɨ₁uɨng₅ le₁can'₂ le₃guio₃ jmɨ₁uɨg₅ jë₁ca₂tó'₂ 'éi₂, ca₂juá'₂ ca₂tság₃ jniá₂: 
\p ―Ŋia₅, la₂ 'ɨ́n₄ jniá₂ dsa₂ mɨ́₂ i₂lé₂ dsɨ₂i₂gu₂ Guein₂ Já'₂ Cha'₂. 
\p  
\v 10 Jaun₂ ca₂jiog₃ a₂'eng₅₄ le₃quió'₅ Jme₂dsí₂, ca₂të₂ ja₁lë́₄ má'₂ juë'₂ a₂ŋei₅. Ja₁jaun₂ ca₂'ë₃ Juɨg₂ Jŋió₅, Jerusalén, a₂sió₅ guei'₅₄ i₂juɨ́g₃ ne₄ Diú₄.  
\v 11 A₂jniá₂ tág₅ 'ŋio₅ lɨn₃ quian'₅₄ a₂co₂tág₅ quió'₅ Diú₄, a₂jniá₂ co₂tág₅ co₂'né'₅ juɨ₁lia'₂ jniá₂ nɨ₁cang₁ jlá'₁, juɨ₁lia'₂ nɨ₁cang₁ Jaspe a₂rë₂jë́₃ lia'₂ lë́₅ nɨ₁'ɨ₂.  
\v 12 Le₃lág'₃ juɨg₂ jaun₂, chí'₅ caun₂ nɨ₁'ia'₂ pa₁ lɨn₃ a₂ŋei₅, a₂le₁dsɨ₅₄ guia₃-tɨ́n₂ o₄'né₄, tión₂ guia₃-tɨ́n₂ ángeles o₄'né₄. Qui₂le₁ton₅ o₄'né₄ lia'₂ chen₂ le₃guia₃-tɨ́n₂ tsɨ₁jon₂ Israel.  
\v 13 'Nɨ₅ o₄'né₄ le₁dsɨ₅₄ të₂le₃ ja₁'ia₂\f + \fr 21:13 \ft Co₂'nió'₄ le₃jua'₅₄, caun₂ cosa a₂tsá₃ 'i₄ jme₂dsí₂, a₂ca₂jmo₃ Diú₄. 'Nio'₂ ja₁ton₅ Salmo 8:3; Romanos 1:25.\f* 'iog₂, 'nɨ₅ guë'₂ të₂le₃ ca₂ton₂ norte, 'nɨ₅ guë'₂ të₂le₃ ca₂ton₂ sur, 'nɨ₅ guë'₂ táng₃ të₂le₃ ja₁rɨn₂ 'iog₂.  
\v 14 Jme₁lë́₂ guia₃-tɨ́n₂ 'uɨg₅₄ nɨ₁'ia'₂ juɨg₂ ciudad jaun₂; ne₄ jaun₂ qui₂le₁ton₅ lia'₂ chen₂ dsa₂ guia₃-tɨ́n₂ i₂chen₄ quián₅ Guein₂ Já'₂ Cha'₂.  
\v 15 Chi₁chan'₂ ángel i₂dsia₅ jniá₂ jág₁ quiang'₅₄ caun₂ nɨ₁'ma₂ a₂quiog₂ dsa₂ 'éi'₃, a₂lë́₅ jmá'₃ cu₄nióg₄, a₂qui₃quióg₃ 'éi'₃ juɨg₂ jaun₂, ca₂le₃jë́₃ o₄'né₄ quió'₅, dso'₂ nɨ₁'ia'₂ në́₃.  
\v 16 Ta₁caun₂ juɨg₂ jaun₂ lë́₅ cha₂ qui'₅₄, co₂jaun₂ bá₄ 'ɨ́₂ con'₂ cu₂. Ca₂quiog₂ 'éi'₃ ta₁caun₂ juɨg₂ quian'₅₄ 'ma₂'éi'₃ jaun₂. Jaun₂ jme₁ca₂të₁ron₅₄ 'éi'₃, ca₂dsióg₃ tɨn₃ mei₅ rë₂dsɨ́₂ tɨn₃ 'ŋiá₂-láu₂ (2,200) kilómetros con'₂ të₂le₃ jang₄ juɨg₂. Con'₂ jaun₂ bá₄ ján₃, ca₂dsióg₃ të₂le₃ 'ɨ́₂ quian'₅₄ guë'₂ të₂le₃ ŋei₅ niog₅ juɨg₂.  
\v 17 Jaun₂ ca₂quiog₂ 'éi'₃ jmá'₃ nɨ₁'ia'₂. Jaun₂ ca₂dsióg₃ caun₂ 'ŋiá₂-láu₂ rë₂dsɨ́₂ të₂láu₃-quén₂ (144) lë₂, 'éi'₃ quió'₅ dsa₂ mɨ₂güɨ́g₃, 'éi'₃ a₂jmó'₂ ángel ta₁.\f + \fr 21:17 \ft o₃, “'éi'₃ quió'₅ dsa₂ mɨ₂güɨ́g₃, co₂'nió'₄ 'éi'₃ quió'₅ ángel.” \f* 
\p  
\v 18 Nɨ₁'ia'₂ në́₃, jme₁lë́₄ jmá'₃ quian'₅₄ nɨ₁cang₁ jaspe; ta₁caun₂ ciudad guë'₂ në́₃, jmá'₃ cu₄nióg₄ jmá'₅, a₂tág₅ lia'₂ tág₅ nɨ₁'ɨ₂ rë₂jë́₃.  
\v 19 'Uɨg₅₄ nɨ₁'ia'₂ ciudad në́₃, qui₂rë₂lag₄ quian'₅₄ ca₂le₃jë́₃ ne₅₄ nɨ₁cang₁ jlá'₁. 
\q1 Jë₁le₂'uɨg₅₄ rë₂lag₄ quian'₅₄ jaspe; 
\q2 jë₁ca₂të́₂ tɨn₃ në́₃, quian'₅₄ zafiro; 
\q1 jë₁ca₂të́₂ 'nɨ₅ në́₃, quian'₅₄ ágata; 
\q2 jë₁ca₂të́₂ quén₂ guë'₂, quian'₅₄ esmeralda; 
\q1  
\v 20 jë₁ca₂të́₂ 'ŋiá₂ rë₂lag₄ quian'₅₄ ónice; 
\q2 jë₁ca₂të́₂ jŋéi₂ guë'₂ në́₃, quian'₅₄ cornalina; 
\q1 jë₁ca₂të́₂ guio₃ táng₃, quian'₅₄ crisólito; 
\q2 jë₁ca₂të́₂ jŋia₃ në́₃, quian'₅₄ berilo; 
\q1 jë₁ca₂të́₂ ŋi₃ në́₃, quian'₅₄ topacio; 
\q2 jë₁ca₂të́₂ guia₃ guë'₂ në́₃, quian'₅₄ crisoprasa; 
\q1 jë₁ca₂të́₂ guia₃-cáun₃ në́₃, quian'₅₄ jacinto; 
\q2 jë₁ca₂të́₂ guia₃-tɨ́n₂ guë'₂ në́₃, rë₂lag₄ quian'₅₄ amatista. 
\p  
\v 21 Ta₁guia₃-tɨ́n₂ o₄'né₄ në́₃, jme₁lë́₄ mɨ́g₂ perlas, ia₁ jma₃cáun₃ o₄'né₄ jme₁lë́₄ jma₃ca₂mɨ́g₂ perla. Calle dsen₅₄ dsi₂jo₂ juɨg₂ ciudad jaun₂, jme₁lë́₄ cu₄nióg₄ a₂le₁jë́₃ në₂jag₄ bá₄ nɨ₁'ɨ₂ rë₂jë́₃. 
\p  
\v 22 Tsá₃ ca₂jág₃ jniá₂ 'i₁caun₂ guá'₅, jua'₅₄ chí'₅ jë₄ juɨg₂, ia₁ 'ŋiog₅ bá₄ Te₁gui'₅₄ Diú₄ i₂'Uan'₂ guë́₄ lɨn₃, 'éi₂ bá₄, quiain'₅₄ Guein₂ Já'₂ Cha'₂, lɨ́in₅ guá'₅ quió'₅.  
\v 23 Tsá₃ si₂ quió'₅ 'iog₂ on₃ guë'₂ si₂ quió'₅ tsɨ'₂ 'nió'₅ quió'₅ juɨg₂ jaun₂, ia₁ quian'₅₄ a₂co₂tág₅ co₂'ne'₂ quió'₅ 'ŋiog₅ bá₄ Diú₄, jmo₅ jniá₂ ja₁jaun₂, quian'₅₄ guë'₂ Guein₂ Já'₂ Cha'₂, i₂lɨ́n₅ co₂'nió'₄ si₂ nɨ₁tsɨ́₅.  
\v 24 Jaun₂ qui₂i₃nio₄ ca₂le₃jë́₃ juɨg₂\f + \fr 21:24 \ft A₂lɨn₅₄ chog₅₄ si₂: “ca₂le₃jë́₃ juɨg₂ a₂ma₂lón₂.” \f* ja₁tág₅ si₂ quió'₅ 'éi₂; qui₂ja₃lén₂ rag₅₄ chan₂ gua'₅₄ 'uë₃, qui₂le₁quian₅ a₂jlá'₁ quió'₅ jë₄ jaun₂.  
\v 25 Lia'₂ o₁lɨ́g'₂ jmɨg₄ tsá₃ jnág₃ o₄'né₄ a₂jmɨ₂, ia₁ tsá₃ ma₃a₂'uë₂ le₃cha₂.  
\v 26 Ja₁jaun₂ qui₂dsɨ₃to'₅₄ ca₂le₃jë́₃ a₂jlá'₁, a₂quen₅ quió'₅ juɨg₂ a₂te₁'i₁ gua'₅₄ 'uë₃.  
\v 27 La₁ ja₁jaun₂ tsá₃ qui₂dsɨ₃to'₅₄ 'i₁caun₂ a₂lë₁'iog₅, on₃ guë'₂ 'i₁jan₂ dsa₂ i₂qui₂jmo₅ a₂o₂guí'₃, i₂juɨ₁gan₂ në́₃. Jmá'₃ lia'₂ con'₂ i₂ma₂tion'₅₄ le₁ton₅ lia'₂ chein₂ ne₄ mɨ₂si₂ a₂le₃chan₂ dsa₂ co₂tan₅₄ quió'₅ Guein₂ Já'₂ Cha'₂ bá₄, jmá'₃ lia'₂ i₂'éi₂ bá₄ dsi₁len₃ ja₁jaun₂. 
\c 22  
\s1 Cuá₃ ja₁ŋɨ₅ jmɨg₂ a₂chan₂ dsa₂ 
\p  
\v 1 Jaun₂ ca₂'ë₃ ángel caun₂ cuá₃ ja₁ŋɨ₅ jmɨg₂ a₂chan₂ dsa₂, a₂rë₂jë́₃ lia'₂ lë́₅ nɨ₁'ɨ₂; a₂já₅ ja₁lë́₄ ne₄ta₁ quió'₅ Diú₄ quian'₅₄ Guein₂ Já'₂ Cha'₂,  
\v 2 a₂ŋɨ₅ dsi₂jo₂ jë₄ calle dsen₅₄ quió'₅ ciudad jaun₂. Lia'₂ ca₂ton₂ jmɨg₂ cuá₃ në́₃, dsi₅₄ nɨ₁'ma₂ a₂chan₂ dsa₂;\f + \fr 22:2 \ft o₃, “a₂já₅ ja₁lë́₄ ne₄ta₁ quió'₅ Diú₄ quian'₅₄ Guein₂ Já'₂ Cha'₂. Dsi₂jo₂ jë₄ calle dsen₅₄ quió'₅ ciudad jaun₂, con'₂ guë'₂ lia'₂ ca₂ton₂ jmɨg₂ cuá₃ në́₃, dsi₅₄ nɨ₁'ma₂ a₂chan₂ dsa₂.” \f* a₂'ag₅ guia₃-tɨ́n₂ ne₅₄ mɨ́g₂, jma₃ca₂ne₅₄ mɨ́g₂ le₂'í₁ tsɨ'₂.\f + \fr 22:2 \ft o₃, “a₂'ag₅ mɨ́g₂ guia₃-tɨ́n₂ ráun₂, co₂ráun₂ le₂'í₁ tsɨ'₂.” \f* Mog'₅₄ guë'₂ në́₃, jmo₅ ta₁ a₂'lón₂ ca₂le₃jë́₃ juɨg₂.  
\v 3 Ia₁ ja₁jaun₂ guë́₄ në́₃, tsá₃ ma₃jág₁ uɨg₅ le₃cha₂. Jë₄ juɨg₂ ciudad të₃tsɨ'₅₄ ne₄ta₁ quió'₅ Diú₄, quió'₅ Guein₂ Já'₂ Cha'₂ në́₃, jaun₂ qui₂jme₃ti₃ dsa₂ quiáin₅ ne₅₄.  
\v 4 Ja₁jaun₂ jág₂ dsi₁ne₁, qui₃cán₂ lia'₂ chen₂ 'éi₂ le₁ton₅ chi₁quí₃.  
\v 5 Tsá₃ ma₃a₂'uë₂ cha₂ ja₁jaun₂; le₂jaun₂ guë'₂ táng₃ juɨ₁lia'₂ i₂tián'₅ ja₁jaun₂ tsá₃ ma₃si₂ nɨ₁tsɨ́₅ 'nió'₅ quió'₅, on₃ guë'₂ si₂ quió'₅ 'iog₂. Ia₁ 'ŋiog₅ bá₄ Te₁gui'₅₄ Diú₄ téi₂ si₂ ja₁coin₂. Jaun₂ qui₃goin₃ ján₃ ca₂lia'₂ co₂tan₅₄. 
\p  
\v 6 Jaun₂ ca₂juá'₂ ángel ca₂tság₃ jniá₂: 
\p ―Jág₁ dsau₅ a₂rë₂ti'₅₄ bá₄ la₂ a₂juɨ́g₂ jniá₂ 'ne₂. 'Ŋiog₅ bá₄ Te₁gui'₅₄, i₂lɨ́n₅ Diú₄ i₂cuë₅ bí₂ jme₂dsí₂ quió'₅ dsa₂ i₂qui₂'ë́₂ jág₁ o₄quió'₄, 'éi₂ bá₄ ma₂ca₂chein₃ ángel quiáin₅ në́₃, a₂ca₂jme₃jniai₂₃ ne₄ dsa₂ i₂qui₂jme₂ti₃ ne₅₄, ca₂le₃jë́₃ 'e₂ niog₅ lé₂ ŋi'₅₄ ta₁. 
\s1 Ŋi'₅₄ ta₁ guan'₂ bá₄ Te₁gui'₅₄ Jesucristo 
\p  
\v 7 ―¡Jag₄! ¡Ŋi'₅₄ ta₁ la₂ bá₄ guióng'₄! ¡'E₂ guë́₄ dsen₃ i₂tón'₂ juɨ₅ jág₁ a₂rë₂'ë́₂ quió'₅ Diú₄ a₂tio'₅₄ ne₄ si₂ la₂! 
\p  
\v 8 Jniá₂, Juan₅₄, jniá₂ bá₄ lɨ́ng₅ i₂ca₂jág₃, i₂ca₂nag₃ ca₂le₃jë́₃ cosa në₅. Jaun₂ jme₁ma₂në₂jág₃ ma₂në₂nag₃, jaun₂ ca₂tón₂ jniá₂ 'uë₃ ja₁tión₂ mɨ₂tag₄ ángel, a₂jme₁jme₁juɨin'₂.  
\v 9 La₁ jaun₂ ca₂tság₃ jniá₂: 
\p ―'A₃ jmo₂ le₂në₅. Ia₁ jan₂ rɨ́n'₂ 'ne₂ bá₄ lɨ́ng₅, i₂jme₂ti₃ ta₁ ne₄ Diú₄, ton'₂ lɨ́ng₅ jan₂ rɨn'₅₄ rɨ́n'₂ 'ne₂ i₂qui₂'ë́₂ jág₁ o₄quió'₄ Diú₄, quian'₅₄ i₂tón'₂ juɨ₅ jág₁ a₂tio'₅₄ ne₄ si₂ la₂. Jme₁juɨn'₂ Diú₄. 
\p  
\v 10 Jaun₂ juá'₂ tság₅ jniá₂: 
\p ―Tsá₃ lë₁'ma₂ tei₄ jág₁ a₂rë₂'ë́₂ quió'₅ Diú₄ a₂tio'₅₄ mɨ₂si₂ rë₂bɨn₅ la₂. Ia₁ ma₂ja₂quián₃ jmɨg₄ jaun₂.  
\v 11 Juɨ₁lia'₂ i₂jmo₅ a₂'lɨg'₅₄, caun₂ juɨ₁jmo₂₃ a₂'lɨg'₁₂; juɨ₁lia'₂ i₂rë₂'ŋió₄, caun₂ juɨ₁jme₂'ŋiói₃. Le₂jaun₂ guë'₂ táng₃, juɨ₁lia'₂ i₂ŋɨ₅ juɨ₅ co₂dsau₅, juɨ₁ŋɨ₁₂ lia'₂ ma₂ŋɨ₂₃ jaun₂, juɨ₅ co₂dsau₅; jaun₂ juɨ₁lia'₂ i₂lɨ́n₅ i₂jŋió₅, caun₂ juɨ₁lein₅₄ bá₄ rë₂jŋiói₅. 
\p  
\v 12 ―¡Dsón'₂ bá₄ ŋi'₅₄ ta₁ guióng'₄! Quion₅₄ 'lia'₅₄ premio quió₃; dsió'₄ cuë́₄ le₂jan₂ le₂jan₂ lia'₂ con'₂ lë́₅ ma₂jmo₃.  
\v 13 Jniá₂ bá₄ lɨ́ng₅ Alfa quian'₅₄ Omega; i₂le₂ne₁, i₂jë₁ca₂tó'₂ në́₃; i₂le₂'uɨg₅₄, i₂jë₁ca₂dsan₃ táng₃.  
\v 14 'E₂ guë́₄ dsen₃ juɨ₁lia'₂ i₂ma₂le₁jë́₃ tsɨn'₅₄, ia₁jaun₂ bá₄ ŋei₃ bí₂ a₂tɨin₃ nɨ₁'ma₂ a₂le₃chan₂ dsa₂, a₂tɨin₃ dsɨ₃toin'₅₄ le₃o₄'né₄ juɨg₂ ciudad në́₃.  
\v 15 Ca₁'né₄ bá₄ tion'₅₄ juɨ₁lia'₂ i₂lɨ́n₅ lia'₂ lɨ́n₅ dsɨ₂jɨ'₅₄, juɨ₁lia'₂ i₂tɨn₂ mɨ́₅ a₂chan₂ dsɨ́₅,\f + \fr 22:15 \ft griego: farmakeía.\f* juɨ₁lia'₂ i₂qui₂nió'₅ jág₁ 'lɨg'₅₄, juɨ₁lia'₂ i₂jme₂dsian₅ rɨn'₅₄, juɨ₁lia'₂ i₂jme₂juɨn'₂ diú₄ lag₄, ca₂le₃jɨ́n₃ guë́₄ i₂të₅ dsɨ́₅ qui₂jme₂gan₅ rɨn'₅₄, a₂qui₂jmo₂₃ jág₁ të₂jág₁ në́₃. 
\p  
\v 16 ’Jniá₂ Jesús, ma₂ca₂tsɨ́ng₂ ángel quiáng₃, a₂jáng'₃ jág₁ dsau₅ në₅ ja₁con'₂ 'nia'₂ ne₄ ca₂le₃jɨ́n₃ guá'₅. Jniá₂ bá₄ lɨ́ng₅ lia'₂ cho'₅₄ lia'₂ tsɨ₁jon₂ Rag₅₄ David, ján₃ bá₄ lɨ́ng₅ Nei₅ 'Ióg₁ i₂tág₅ quió'₅. 
\p  
\v 17 Jme₂dsí₂ Jŋió₅, quian'₅₄ dsa₂ mɨ́₂ quián₅ Guein₂ Já'₂ Cha'₂ juá'₂: 
\p ―Ŋia₅. 
\p Le₂jaun₂ guë'₂ juɨ₁lia'₂ i₂nag₅ juá'₂ i₂në₅, juɨ₁jua'₅₄: 
\p ―Ŋia₅. 
\p Chi₂jua'₂ 'ein₂ i₂rë₂quein₂ dsɨ́₅, juɨ₁jia₂; chi₂jua'₂ 'ein₂ 'nio₃, juɨ₁ja₂'én'₃ jmɨg₂ a₂le₃chain₂, on₃jua'₅₄ cha₂ quɨn₃ 'i₁caun₂. 
\p  
\v 18 Ca₂le₃jɨ́n₃ i₂nag₅ jág₁ dse₃ a₂rë₂'ë́₄ quió'₅ Diú₄, a₂tio'₅₄ mɨ₂si₂ la₂, 'ë́₅ jniá₂ jág₁ dsau₅ la₂: chi₂jua'₂ 'ein₂ ca₂jmo₃ ŋag₅₄ con'₂ lë́₅ jág₁ a₂ma₂tio'₅₄, Diú₄ bá₄ jme₃juë'₂ jmɨ₁uɨg₅ quió'₅ lia'₂ con'₂ lë́₅ le₁ton₅ ne₄ mɨ₂si₂ la₂.  
\v 19 Në₁jua'₂ 'ein₂ guë'₂ ca₂jŋiá'₂, ca₂jmo₃ me'₂ jág₁ a₂rë₂'ë́₂ ne₄ si₂ la₂, Diú₄ bá₄ jŋiá'₂ a₂jme₁ca₂tɨ́in₂ quió'₅ nɨ₁'ma₂ a₂chan₂ dsa₂, quian'₅₄ guë́₄ quió'₅ ciudad jŋió₅ a₂le₁ton₅ ne₄ si₂ la₂. 
\p  
\v 20 I₂jáng'₅ jág₁ dsau₅ la₂ juá'₂: 
\p ―Dsón'₂ bá₄ ŋi'₅₄ ta₁ guióng'₄. 
\p A₂jaun₂ guë'₂ dsón'₂. ¡Ŋiá'₅ 'ne₂, Te₁gui'₅₄ Jesús! 
\p  
\v 21 Juɨ₁jme₂gu'₅₄ bá₄ Te₁gui'₅₄ Jesucristo ca₂le₃jɨ́n'₃ 'nia'₂. 
\p Co₂në₅.