\id PSA  
\h Saame 
\toc1 Ko E Tohi  Ľoe Ngaahi Saame 
\toc2 Saame 
\toc3 Sme 
\mt2 KO E TOHI  
\mt3  ĽOE NGAAHI  
\mt1 SAAME  
\cl SAAME  
\c 1  
\ms1 TOHI 1  
\mr (Saame 1‚ÄĒ41)  
\cd \it 1 Ko e monŇę Ľia  Ľoe mńĀ Ľoni Ľoni, 4 Mo e mala Ľia  Ľoe angakovi.\it*  
\q1
\v 1 ‚ÄĆ ĽOku monŇę Ľia  Ľae tangata  Ľoku  Ľikai  Ľeve Ľeva  Ľi he fakakaukau  Ľae angakovi,  
\q2 pe tu Ľu  Ľi he hala  Ľoe kau angahala,  
\q2 pe nofo  Ľi he nofo Ľa  Ľoe manuki.   
\q1
\v 2 Ka ko  Ľene fiefia  Ľoku  Ľi he fono  Ľa Sihova;  
\q2 pea ko  Ľene fono  Ľoku ne fakalaulauloto ai  Ľi he  Ľaho mo e pŇć.   
\q1
\v 3 Pea  Ľe tatau ia mo e  Ľakau kuo tŇć ki he ve Ľe vaitafe,  
\q2  Ľaia  Ľoku  Ľomi hono fua  Ľi hono fa Ľahita Ľu;  
\q2 pea ko hono lau foki  Ľe  Ľikai mae;  
\q2 pea ko ia kotoa pńď  Ľoku ne fai  Ľe monŇę Ľia.   
\q1
\v 4 ‚ÄĆ ĽOku  Ľikai pehńď  Ľae angakovi:  
\q2 ka  Ľoku tatau ia mo e kafukafu  Ľaia  Ľoku vilingia,  Ľi he matangi.   
\q1
\v 5 Ko ia  Ľe  Ľikai tu Ľu  Ľae angakovi  Ľi he fakamaau,  
\q2 pe ko e angahala  Ľi he fakataha  Ľoe mńĀ Ľoni Ľoni.   
\q1
\v 6 He  Ľoku  Ľilo  Ľe Sihova  Ľae hala  Ľoe mńĀ Ľoni Ľoni:  
\q2 ka ko e hala  Ľoe angakovi  Ľe  Ľauha ia.   
\c 2  
\cd \it 1 Ko e pule Ľanga  Ľo Kalaisi. 10 Ko e enginaki ki he ngaahi tu Ľi ke nau ma Ľu ia.\it*  
\q1
\v 1 Ko e hńĀ  Ľoku matalili ai  Ľae hiteni?  
\q2 Pea fakalaulauloto  Ľae kakai ki he me Ľa noa pńď?   
\q1
\v 2 ‚ÄĆ ĽOku tu Ľu hake fakataha  Ľae ngaahi tu Ľi  Ľo mńĀmani,  
\q2 pea fakakaukau fakataha  
\q2  Ľae kau pule kia Sihova mo ia kuo ne pani,  Ľo pehńď,   
\q1
\v 3 ‚ÄúKe tau motuhi  Ľena ngaahi ha Ľi  
\q2 pea li Ľaki  Ľena ngaahi afo  Ľiate kitautolu.‚ÄĚ   
\q1
\v 4 Ko ia  Ľoku nofo  Ľi he ngaahi langi  Ľe kata ia:  
\q2  Ľe manuki  Ľa Sihova kiate kinautolu.   
\q1
\v 5 Pea te ne toki folofola kiate kinautolu  Ľi hono houhau,  
\q2 pea fakamamahi Ľi  Ľakinautolu  Ľi hono tuputńĀmaki lahi.   
\q1
\v 6 Ka kuo u fakanofo  Ľeku tu Ľi ki Saione,  
\q2 ko e mo Ľunga  Ľo  Ľeku mńĀ Ľoni Ľoni.   
\q1
\v 7 ‚ÄúTe u fakahńĀ  Ľae tu Ľutu Ľuni:‚ÄĚ  
\q1 na Ľe pehńď  Ľe Sihova kiate au,  
\q2 ‚ÄúKo hoku  ĽAlo koe kuo u fakatupu koe  Ľi he  Ľaho ni.   
\q1
\v 8 Ke ke lea kiate au, pea te u foaki  Ľae ngaahi hiteni ko ho tofi Ľa,  
\q2 mo e ngaahi ngata Ľanga kotoa pńď  Ľo mńĀmani mo Ľou.   
\q1
\v 9 Te ke maumau Ľi  Ľakinautolu  Ľaki  Ľae va Ľa ukamea;  
\q2 pea te ke laiki ke lailai  Ľakinautolu  Ľo hangńď ko e ipu  Ľumea.   
\q1
\v 10 Pea ko eni, ke poto  Ľakimoutolu  Ľae ngaahi tu Ľi:  
\q2 pea ma Ľu  Ľae akonaki  Ľakimoutolu  Ľae kau fakamaau  Ľo mńĀmani.   
\q1
\v 11 Tauhi  Ľa Sihova  Ľi he manavahńď,  
\q2 pea fiefia  Ľi he tetetete.   
\q1
\v 12 ‚ÄĆ ĽUma ki he  ĽAlo, telia na Ľa houhau ia, pea te mou  Ľauha mei he hala,  
\q2  Ľoka tupu si Ľi pe hono houhau.  
\q2  ĽOku monŇę Ľia  Ľakinautolu kotoa pńď  Ľoku falala kiate ia.   
\c 3  
\cd \it 1‚Äď8 Ko e hŇęfanga malu  Ľa Sihova.\it*  
\d Ko e Saame  Ľa Tevita,  Ľi he Ľene hola meia  ĽApisalomi ko hono foha.  
\q1
\v 1 ‚ÄĆ ĽE Sihova, kuo tupu  Ľo tokolahi  Ľakinautolu  Ľoku fakamamahi Ľi au!  
\q2  ĽOku tokolahi  Ľakinautolu  Ľaia  Ľoku tu Ľu hake  Ľo angatu Ľu kiate au.   
\q1
\v 2 ‚ÄĆ ĽOku tokolahi  Ľakinautolu  Ľaia  Ľoku pehńď ki hoku laumńĀlie,  
\q2 ‚Äú ĽOku  Ľikai ha tokoni kiate ia  Ľi he  ĽOtua.‚ÄĚ \qs Sila.\qs*   
\q1
\v 3 Ka ko koe,  ĽE Sihova, ko e fakaŇę kiate au;  
\q2 ko hoku nńĀunau, mo e hiki hake  Ľa hoku  Ľulu.   
\q1
\v 4 Na Ľaku tangi kia Sihova  Ľaki hoku le Ľo,  
\q2 pea na Ľa ne ongo Ľi au mei hono mo Ľunga mńĀ Ľoni Ľoni. \qs Sila.\qs*   
\q1
\v 5 Ne u tokoto hifo  Ľo mohe; pea u  ĽńĀ hake;  
\q2 he ko Sihova na Ľa ne tokoni Ľi au.   
\q1
\v 6 ‚ÄĆ ĽE  Ľikai te u manavahńď  Ľi he ngaahi toko mano  Ľoe kakai,  
\q2  Ľaia  Ľoku angatu Ľu  Ľo kńĀpui au.   
\q1
\v 7 Tu Ľu hake,  ĽE Sihova;  
\q2 fakamo Ľui au,  ĽE hoku  ĽOtua:  
\q1 he kuo ke taa Ľi hoku ngaahi fili kotoa pńď  Ľi honau hui kou Ľahe  
\q2 kuo ke fesi Ľi  Ľae kau nifo  Ľoe angakovi.   
\q1
\v 8 ‚ÄĆ ĽOku  Ľia Sihova  Ľae fakamo Ľui:  
\q2 ko ho Ľo tńĀpuaki  Ľoku  Ľi ho Ľo kakai. \qs Sila.\qs*   
\c 4  
\cd \it 1 Ko e lotu  Ľa Tevita ke tokanga  Ľae  ĽEiki kiate ia. 2  ĽOku ne valoki mo enginaki ki hono ngaahi fili. 6  ĽOku  Ľi he  ĽOtua  Ľae monŇę Ľia  Ľoe tangata.\it*  
\d Ki he Takimu Ľa  Ľi he Nekina, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽO kau ka kole, fanongo mai kiate au,  ĽE  ĽOtua  Ľo  Ľeku mńĀ Ľoni Ľoni:  
\q2 na Ľa ke halahala Ľi au mei he mamahi;  
\q2 ke ke  Ľalo Ľofa mai kiate au, pea fanongo ki he Ľeku lotu.   
\q1
\v 2 ‚ÄĆ ĽAe ngaahi foha  Ľoe tangata,  Ľe ngata  Ľafńď ho Ľomou liliu hoku nńĀunau ko e me Ľa fakamńĀ?  
\q2  Ľe ngata  Ľafńď ho Ľomou  Ľofa ki he me Ľa va Ľinga pe,  Ľo kumi ki he loi? \qs Sila.\qs*   
\q1
\v 3 Ka mou  Ľilo kuo vahe Ľi  Ľe Sihova ma Ľana  Ľaia  Ľoku angalelei:  
\q2  Ľe fanongo  Ľe Sihova  Ľo kau ka kole kiate ia.   
\q1
\v 4 Mou manavahńď, pea  Ľoua na Ľa fai angahala:  
\q2 fakakaukau mo homou loto  Ľi homou mohenga, pea mou fakalongo pe. \qs Sila.\qs*   
\q1
\v 5 Feilaulau  Ľaki  Ľae ngaahi feilaulau mńĀ Ľoni Ľoni,  
\q2 pea mou falala kia Sihova.   
\q1
\v 6 ‚ÄĆ ĽOku pehńď  Ľe he tokolahi, ‚ÄúKo hai te ne fakahńĀ ha lelei kiate kitautolu?‚ÄĚ  
\q2  ĽE Sihova, ke ke hiki hake kiate kimautolu  Ľae maama  Ľo ho fofonga.   
\q1
\v 7 Kuo ke  Ľai ki hoku loto  Ľae fiefia lahi hake  Ľi he fiefia  
\q2  Ľi he kuonga na Ľe tupu  Ľo lahi ai  Ľenau uite mo e uaine.   
\q1
\v 8 Te u tokoto hifo  Ľi he fiemńĀlie,  Ľo mohe: he ko koe pńď,  
\q2  ĽE Sihova,  Ľoku ke pule ke u nofo lelei.   
\c 5  
\cd \it 1  ĽOku lotu  Ľa Tevita, pea fakahńĀ  Ľene fakalaulauloto  Ľi he lotu. 4  ĽOku  Ľikai fiemńĀlie  Ľae  ĽOtua ki he kau angahala. 7  ĽOku fakahńĀ  Ľe Tevita  Ľene tui, pea lotu ki he  ĽOtua ke ne tataki ia, 10 Pea faka Ľauha hono ngaahi fili, 11 Mo fakamo Ľui  Ľae mńĀ Ľoni Ľoni.\it*  
\d Ki he Takimu Ľa  Ľi he Nekiloti, ko e Saame  Ľa Tevita.  
\q1
\v 1 Ke ke fofonga mai ki he Ľeku ngaahi lea,  
\q2  ĽE Sihova,  
\q2 tokanga ki he Ľeku fakalaulauloto.   
\q1
\v 2 Ke ke fanongo ki he le Ľo  Ľo  Ľeku tangi,  ĽE hoku tu Ľi, mo hoku  ĽOtua:  
\q2 he te u lotu pe kiate koe.   
\q1
\v 3 Ko hoku le Ľo te ke ongo Ľi  ĽE Sihova,  Ľi he pongipongi;  
\q2  Ľi he pongipongi te u  Ľohake  Ľeku lotu kiate koe, pea u hanga hake.   
\q1
\v 4 He  Ľoku  Ľikai ko e  ĽOtua koe  Ľoku fiemńĀlie  Ľi he angahala:  
\q2 pea  Ľe  Ľikai nonofo mo koe  Ľae kovi.   
\q1
\v 5 ‚ÄĆ ĽE  Ľikai tu Ľu  Ľi ho  Ľao  Ľae kau vale:  
\q2  Ľoku ke fehi Ľa ki he kakai fai kovi kotoa pńď.   
\q1
\v 6 Te ke faka Ľauha  Ľakinautolu  Ľoku lea loi:  
\q2  Ľe fakalili Ľa  Ľa Sihova ki he tangata pani toto mo kńĀkńĀ.   
\q1
\v 7 Ka ko au, te u hŇę ki ho fale  Ľi he lahi  Ľo ho Ľo  Ľalo Ľofa:  
\q2 pea  Ľi he manavahńď kiate koe te u hŇę  Ľi he faletapu  Ľo ho Ľo mńĀ Ľoni Ľoni.   
\q1
\v 8 Tataki au,  ĽE Sihova,  Ľi ho Ľo mńĀ Ľoni Ľoni koe Ľuhi ko hoku ngaahi fili;  
\q2 fakatotonu ho hala  Ľi hoku mata.   
\q1
\v 9 He  Ľoku  Ľikai ha mo Ľoni  Ľi honau ngutu;  
\q2  Ľoku mńĀtu Ľaki kovi honau loto;  
\q2 ko honau kia ko e fonualoto kuo matangaki;  
\q2  Ľoku nau lapu  Ľaki honau  Ľelelo.   
\q1
\v 10 Ke ke faka Ľauha  Ľakinautolu,  ĽE  ĽOtua;  
\q2 tuku ke nau hinga  Ľi he Ľenau ngaahi fakakaukau  Ľanautolu;  
\q1 ke ke lńę kitu Ľa  Ľakinautolu  Ľi he lahi  Ľo  Ľenau talangata Ľa;  
\q2 he kuo nau angatu Ľu kiate koe.   
\q1
\v 11 Kae tuku ke fiefia  Ľakinautolu kotoa pńď  Ľaia  Ľoku falala kiate koe:  
\q2 ke nau kalanga ma Ľuaipńď  Ľi he fiefia, ko e me Ľa  Ľi ho Ľo malu Ľi  Ľakinautolu:  
\q1 tuku ke fiefia  Ľiate koe  Ľakinautolu  Ľoku  Ľofa ki ho huafa.   
\q2
\v 12 He ko koe,  ĽE Sihova, te ke tńĀpuaki  Ľae mńĀ Ľoni Ľoni;  
\q1 te ke kńĀpui  Ľaki ia  Ľae  Ľofa  Ľo hangńď ko e fakaŇę.   
\c 6  
\cd \it 1 Ko e tangi  Ľa Tevita  Ľi hono mahaki. 8  ĽI he Ľene tui  Ľoku ne fiefia ki hono ngaahi fili.\it*  
\d Ki he Takimu Ľa  Ľi he Nekina  Ľi he Semini, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE Sihova,  Ľoua na Ľa ke valoki Ľi au  Ľi ho houhau,  
\q2 pe tautea au  Ľi ho houhau vela.   
\q1
\v 2 ‚ÄĆ ĽAlo Ľofa mai kiate au,  ĽE Sihova; he  Ľoku ou vaivai:  
\q2  ĽE Sihova, fakamo Ľui au he kuo mamahi hoku ngaahi hui.   
\q1
\v 3 ‚ÄĆ ĽOku mamahi lahi foki mo hoku laumńĀlie:  
\q2 ka ko koe,  ĽE Sihova,  Ľe fńďfńď hono fuoloa?   
\q1
\v 4 Tafoki mai,  ĽE Sihova, fakahaofi hoku laumńĀlie:  
\q2  Ľoiauńď, fakamo Ľui au koe Ľuhi ko ho Ľo  Ľalo Ľofa.   
\q1
\v 5 He  Ľoku  Ľikai ha fakamanatu kiate koe  Ľi he mate:  
\q2 ko hai te ne fakafeta Ľi kiate koe  Ľi he fa Ľitoka?   
\q1
\v 6 Kuo u vaivai  Ľi he Ľeku fa Ľa to Ľe;  
\q2  Ľoku ou fakatńďtńď hoku mohenga  Ľi he pŇć kotoa;  
\q2  Ľoku ou fakaviviku  Ľa hoku mohenga  Ľaki hoku lo Ľimata.   
\q1
\v 7 Kuo tutue hoku mata ko e me Ľa  Ľi he mamahi;  
\q2  Ľoku faka Ľa Ľau ke motu Ľa ia koe Ľuhi ko hoku ngaahi fili.   
\q1
\v 8 ‚ÄĆ ĽAlu  Ľiate au,  Ľakimoutolu kotoa pńď  Ľoku fai kovi;  
\q2 he kuo ongo Ľi  Ľe Sihova  Ľae le Ľo  Ľo  Ľeku tangi.   
\q1
\v 9 Kuo fanongo  Ľa Sihova ki he Ľeku hŇę tńĀuma Ľu;  
\q2 pea  Ľe ma Ľu  Ľe Sihova  Ľa  Ľeku lotu.   
\q1
\v 10 Tuku ke mńĀ mo mamahi lahi  Ľa hoku ngaahi fili kotoa pńď:  
\q2 tuku ke nau foki pea mńĀ fakafokifńĀ pe.   
\c 7  
\cd \it 1  ĽOku lotu  Ľa Tevita koe Ľuhi ko e meheka  Ľo hono ngaahi fili,  Ľo fakahńĀ  Ľene mńĀ Ľoni Ľoni. 10  ĽOku ne mamata  Ľi he Ľene tui ki hono hŇęfanga mo e faka Ľauha  Ľo hono ngaahi fili.\it*  
\d Ko e Sikaiona  Ľa Tevita,  Ľaia na Ľa ne hiva  Ľaki kia Sihova, ko e me Ľa  Ľi he ngaahi lea  Ľa Kusi mei he fa Ľahinga  Ľo Penisimani.  
\q1
\v 1 ‚ÄĆ ĽE Sihova ko hoku  ĽOtua,  Ľoku ou falala pe kiate koe:  
\q2 ke ke fakamo Ľui au meiate kinautolu kotoa pńď  Ľoku fakatanga Ľi au, mo ke fakahaofi au.   
\q1
\v 2 Telia na Ľa ne haehae hoku laumńĀlie  Ľo hangńď ko e laione,  
\q2  Ľo haehae ia ke fakaikiiki,  Ľoka  Ľikai ha fakahaofi.   
\q1
\v 3 ‚ÄĆ ĽE Sihova ko hoku  ĽOtua, kapau na Ľaku fai eni;  
\q2 kapau  Ľoku ai ha angahala  Ľi hoku nima;   
\q1
\v 4 Kapau ne u totongi kovi kiate ia na Ľe nofo  Ľi he melino mo au;  
\q2  Ľio, na Ľaku fakamo Ľui ia  Ľaia kuo hoko ko hoku fili ta Ľehano Ľuhinga:   
\q1
\v 5 Tuku ke tuli hoku laumńĀlie  Ľe he fili, pea ma Ľu ia;  
\q2  Ľio, tuku ke ne molomoloki hifo  Ľeku mo Ľui  Ľi he kelekele,  
\q2 pea fakatokoto hoku ongoongolelei  Ľi he efu. \qs Sila.\qs*   
\q1
\v 6 Tu Ľu hake,  ĽE Sihova,  Ľi ho houhau,  
\q2 ke ke hiki hake koe, ko e me Ľa  Ľi he lili  Ľo hoku ngaahi fili:  
\q1 pea ke  ĽńĀ hake koe Ľuhi ko au ki he fakamaau  Ľaia na Ľa ke fekau.   
\q2
\v 7 Pehńď  Ľe kńĀpui koe  Ľe he fakataha  Ľoe kakai:  
\q2 ko ia ko e me Ľa  Ľiate kinautolu ke ke hńĀ Ľele hake ki  Ľolunga.   
\q1
\v 8 ‚ÄĆ ĽE fakamaau  Ľe Sihova  Ľae kakai:  
\q2 ke ke fakamaau au,  ĽE Sihova,  Ľo fakatatau ki he Ľeku mńĀ Ľoni Ľoni,  
\q2 pea hangńď ko  Ľeku angatonu  Ľoku  Ľiate au.   
\q1
\v 9 Tuku ke ngata  Ľae kovi  Ľoe angakovi,  
\q2 ka ke fakatu Ľuma Ľu  Ľae angatonu:  
\q2 he  Ľoku  Ľahi Ľahi Ľi  Ľe he  ĽOtua mńĀ Ľoni Ľoni  Ľae ngaahi loto mo e ngaahi konga loto.   
\q1
\v 10 ‚ÄĆ ĽOku  Ľi he  ĽOtua  Ľa hoku fakaŇę,  
\q2  Ľaia  Ľoku ne fakamo Ľui  Ľae kakai angatonu  Ľi loto.   
\q1
\v 11 ‚ÄĆ ĽOku fakamaau  Ľe he  ĽOtua  Ľae mńĀ Ľoni Ľoni,  
\q2 pea  Ľoku houhau  Ľae  ĽOtua ki he angakovi  Ľi he  Ľaho kotoa pńď.   
\q1
\v 12 Kapau  Ľe  Ľikai te ne tafoki, te ne fakamata  Ľa  Ľene heletńĀ;  
\q2 kuo ne teteke  Ľene kaufana,  Ľo teuteu ia.   
\q1
\v 13 Kuo ne teuteu foki kiate ia  Ľae ngaahi me Ľa fakapŇć;  
\q2  Ľoku ne tu Ľutu Ľuni  Ľene ngaahi ngahau ki he kau fakatanga.   
\q1
\v 14 Vakai,  Ľoku langńĀ ia  Ľi he angakovi,  
\q2 pea kuo ne tu Ľitu Ľia  Ľae angapau Ľu,  
\q2 pea fanau Ľi  Ľe ia  Ľae kńĀkńĀ.   
\q1
\v 15 Na Ľa ne ngaohi  Ľae luo,  Ľo keli ia,  
\q2 pea kuo tŇć ia ki he luo na Ľa ne ngaohi.   
\q1
\v 16 ‚ÄĆ ĽE foki ki hono  Ľulu  Ľo Ľona  Ľa  Ľene angapau Ľu,  
\q2 pea  Ľe tŇć hifo ki hono tumu Ľaki  Ľo Ľona  Ľa  Ľene ngńĀue fakamńĀlohi.   
\q1
\v 17 Te u fakafeta Ľi kia Sihova  Ľo fakatatau ki he Ľene mńĀ Ľoni Ľoni:  
\q2 pea te u hiva  Ľaki  Ľae fakafeta Ľi ki he huafa  Ľo Sihova  Ľoku mńĀ Ľolunga taha pe.   
\c 8  
\cd \it 1‚Äď9  ĽOku ongoongolelei ai  Ľae  ĽOtua  Ľi he Ľene ngaahi ngńĀue, pea  Ľi he Ľene  Ľofa ki he tangata.\it*  
\d Ki he Takimu Ľa  Ľi he Kitita, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE Sihova ko homau  ĽEiki,  Ľoku lelei lahi ho huafa  Ľi mńĀmani kotoa pńď!  
\q2 Kuo ke fokotu Ľu ho nńĀunau  Ľi  Ľolunga  Ľi he ngaahi langi.   
\q1
\v 2 Kuo ke tu Ľutu Ľuni mei he ngutu  Ľoe kau valevale mo e kei huhu  Ľae mńĀlohi,  
\q2 ko e me Ľa  Ľi ho ngaahi fili, koe Ľuhi ke ke pule ke fakalongo pńď  Ľae fili mo e fakafńĀsifasi.   
\q1
\v 3 ‚ÄĆ ĽO kau ka fakakaukau ki ho ngaahi langi, ko e ngńĀue  Ľo ho louhi Ľi nima,  
\q2 ko e mńĀhina mo e ngaahi fetu Ľu,  Ľaia na Ľa ke fokotu Ľu;   
\q1
\v 4 Ko e hńĀ  Ľae tangata  Ľoku ke tokanga ai kiate ia?  
\q2 Pe ko e foha  Ľae tangata,  Ľoku ke  Ľa Ľahi ai kiate ia?   
\q1
\v 5 He kuo ke ngaohi ia ke mńĀ Ľulalo si Ľi  Ľi he ngaahi  ĽńĀngelo,  
\q2 pea kuo ke tatńĀ Ľaki ia  Ľae nńĀunau mo e ongoongolelei.   
\q1
\v 6 Na Ľa ke fakanofo ia ke ne pule ki he ngaahi ngńĀue  Ľa ho nima;  
\q2 kuo ke tuku  Ľae me Ľa kotoa pńď ki hono lalo va Ľe:   
\q1
\v 7 ‚ÄĆ ĽAe fanga sipi kotoa pńď mo e fanga pulu,  
\q2  Ľio, mo e ngaahi manu  Ľoe fonua;   
\q1
\v 8 Ko e manupuna  Ľoe  ĽatńĀ, mo e ika  Ľoe tahi,  
\q2 mo e me Ľa kotoa pńď  Ľoku  Ľalu  Ľi he ngaahi  Ľalu Ľanga  Ľi he tahi.   
\q1
\v 9 ‚ÄĆ ĽE Sihova ko homau  ĽEiki,  
\q2  Ľoku lelei lahi ho huafa  Ľi mńĀmani kotoa pńď!   
\c 9  
\cd \it 1  ĽOku fakafeta Ľi  Ľa Tevita ki he  ĽOtua  Ľi he Ľene fai  Ľae fakamaau. 11  ĽOku ne ue Ľi  Ľae kakai ke fakafeta Ľi kiate ia. 18  ĽOku ne kole  Ľae tńĀpuaki koe Ľuhi ke ne fakafeta Ľi ai kiate ia.\it*  
\d Ki he Takimu Ľa  Ľi he Muti-Lapeni, ko e Saame  Ľa Tevita.  
\q1
\v 1 Te u fakafeta Ľi kiate koe,  ĽE Sihova,  Ľaki hoku loto kotoa;  
\q2 te u fakahńĀ atu ho Ľo ngńĀue fakaofo kotoa pńď.   
\q1
\v 2 Te u fiefia mo nekeneka  Ľiate koe:  
\q2 te u hiva fakamńĀlŇć ki ho huafa,  Ľa koe  Ľoku ke mńĀ Ľolunga lahi taha pe.   
\q1
\v 3 Pea ka foki kimui hoku ngaahi fili,  
\q2 te nau hinga  Ľo  Ľauha  Ľi ho fofonga.   
\q1
\v 4 He na Ľa ke langomia  Ľeku totonu mo  Ľeku ngńĀue;  
\q2 na Ľa ke nofo  Ľi he nofo Ľa,  Ľo fakamaau  Ľi he mńĀ Ľoni Ľoni.   
\q1
\v 5 Kuo ke valoki  Ľae hiteni,  
\q2 kuo ke faka Ľauha  Ľae angakovi,  
\q2 kuo ke tńĀmate Ľi honau hingoa ke ta Ľengata pea ta Ľengata.   
\q1
\v 6 Kuo hoko ke ngata  Ľaupito  Ľae ngaahi faka Ľauha  Ľoe fili:  
\q2 pea ko honau ngaahi kolo kuo ke faka Ľauha;  
\q2 kuo  Ľauha mo kinautolu honau fakamanatu.   
\q1
\v 7 Ka  Ľe mo Ľui ma Ľuaipńď  Ľa Sihova:  
\q2 kuo ne teu Ľi hono  Ľafio Ľanga ki he fakamaau.   
\q1
\v 8 Pea te ne fakamaau  Ľa mńĀmani  Ľi he mńĀ Ľoni Ľoni,  
\q2  Ľe  Ľatu  Ľe ia  Ľae fakamaau ki he kakai  Ľi he angatonu.   
\q1
\v 9 Pea ko e hŇęfanga foki  Ľa Sihova ki he mamahi,  
\q2 ko e kalofanga  Ľi he ngaahi  Ľaho fakamamahi.   
\q1
\v 10 Pea ko kinautolu  Ľoku  Ľilo ki ho huafa te nau falala kiate koe:  
\q2 he ko koe,  ĽE Sihova, na Ľe  Ľikai te ke si Ľaki  Ľakinautolu  Ľoku kumi kiate koe.   
\q1
\v 11 Hiva fakafeta Ľi kia Sihova,  Ľaia  Ľoku  Ľafio  Ľi Saione:  
\q2 fakahńĀ  Ľi he  Ľao  Ľoe kakai  Ľene ngaahi ngńĀue.   
\q1
\v 12 ‚ÄĆ ĽOka ne ka  Ľeke ki he toto,  Ľoku ne manatu Ľi  Ľakinautolu:  
\q2  Ľoku  Ľikai te ne fakangalongalo Ľi  Ľae tangi  Ľae angavaivai.   
\q1
\v 13 Ke ke  Ľalo Ľofa kiate au,  ĽE Sihova;  
\q2  Ľo tokanga ki he Ľeku mamahi meiate kinautolu  Ľoku fehi Ľa kiate au,  
\q1  Ľa koe  Ľoku ke hiki au ki  Ľolunga mei he ngaahi matapńĀ  Ľoe mate:   
\q2
\v 14 Koe Ľuhi ke u fakahńĀ ho ongoongolelei kotoa pńď.  
\q2  Ľi he ngaahi matapńĀ  Ľoe ta Ľahine  Ľo Saione: te u fiefia  Ľi ho Ľo fakamo Ľui.   
\q1
\v 15 Kuo ngalo hifo  Ľae hiteni  Ľi he luo na Ľa nau ngaohi:  
\q2  Ľi he tauhele na Ľa nau fakalilo kuo mo Ľua ai honau va Ľe.   
\q1
\v 16 ‚ÄĆ ĽOku  Ľilo Ľi  Ľa Sihova  Ľi he fakamaau  Ľoku ne fai:  
\q2 kuo hele Ľi  Ľae angakovi  Ľi he ngńĀue  Ľa hono nima  Ľo Ľona. \qs Hikaione. Sila.\qs*   
\q1
\v 17 ‚ÄĆ ĽE teke Ľi  Ľae angahala ki loto heli,  
\q2 mo e ngaahi pule Ľanga kotoa pńď  Ľoku fakangalongalo Ľi  Ľae  ĽOtua.   
\q1
\v 18 Koe Ľuhi  Ľe  Ľikai ngalo ma Ľuaipńď  Ľae masiva:  
\q2  Ľe  Ľikai  Ľauha ke ta Ľengata  Ľae  Ľamanaki  Ľae masiva.   
\q1
\v 19 Tu Ľu hake,  ĽE Sihova;  Ľoua na Ľa tuku ke mńĀlohi  Ľae tangata:  
\q2 tuku ke fakamaau  Ľae hiteni  Ľi ho  Ľao.   
\q1
\v 20 Fakamanavahńď Ľi  Ľakinautolu,  ĽE Sihova:  
\q2 koe Ľuhi ke  Ľilo  Ľe he ngaahi pule Ľanga ko e tangata pńď  Ľakinautolu. \qs Sila.\qs*   
\c 10  
\cd \it 1  ĽOku lńĀunga  Ľa Tevita ki he  ĽOtua  Ľi he angamńĀlohi  Ľoe angahala. 12  ĽOku ne kole  Ľae tokoni. 16  ĽOku ne fakahńĀ  Ľene tui.\it*  
\q1
\v 1 Ko e hńĀ  Ľoku ke fakamama Ľo ai,  ĽE Sihova?  
\q2 Ko e hńĀ  Ľoku ke fakafufŇę ai koe  Ľi he ngaahi  Ľaho  Ľoe mamahi?   
\q1
\v 2 ‚ÄĆ ĽI he fielahi  Ľae angakovi  Ľoku ne fakatanga Ľi  Ľae masiva:  
\q2 tuku ke mo Ľua  Ľakinautolu  Ľi he ngaahi filio Ľi  Ľaia kuo nau fakakaukau ki ai.   
\q1
\v 3 He  Ľoku polepole  Ľae angahala  Ľi he holi  Ľa hono loto,  
\q2  Ľo ne fakamńĀlŇć ki he manumanu  Ľaia  Ľoku fehi Ľa ki ai  Ľa Sihova.   
\q1
\v 4 Ko e angahala,  Ľi he fielahi  Ľa hono mata,  Ľe  Ľikai te ne kumi \add ki he  ĽOtua\add*:  
\q2  Ľoku  Ľikai kau ki he  ĽOtua  Ľene ngaahi mahalo kotoa pńď.   
\q1
\v 5 ‚ÄĆ ĽOku fakamamahi ma Ľuaipńď hono ngaahi  Ľalu Ľanga;  
\q2  Ľoku mńĀ Ľolunga lahi hake ho Ľo ngaahi fakamaau  Ľo  Ľulia  Ľiate ia:  
\q2 pea  Ľoku ne ifi atu ki hono ngaahi fili kotoa pńď.   
\q1
\v 6 Kuo pehńď  Ľe ia  Ľi hono loto, ‚Äú ĽE  Ľikai te u ngaue:  
\q2 koe Ľuhi  Ľe  Ľikai te u  Ľi he mamahi mei he to Ľutangata ki he to Ľutangata.‚ÄĚ   
\q1
\v 7 ‚ÄĆ ĽOku fonu hono ngutu  Ľi he kape, mo e kńĀkńĀ, mo e loi:  
\q2  Ľoku  Ľi hono lalo  Ľelelo  Ľae pau Ľu, mo e kovi.   
\q1
\v 8 ‚ÄĆ ĽOku nofo ia  Ľi he ngaahi toitoi Ľanga  Ľoe ngaahi potu kakai:  
\q2  Ľoku fakapoongi  Ľe ia  Ľae mńĀ Ľoni Ľoni  Ľi he ngaahi potu fakalilolilo:  
\q1  Ľoku siosio pau hono mata  Ľi he fufŇę ki he masiva.   
\q1
\v 9 ‚ÄĆ ĽOku tokoto tatali pe ia  Ľi he potu lilo,  Ľo hangńď ko e laione  Ľi hono  Ľana:  
\q2  Ľoku tali tokoto ia ke ne pŇć  Ľae masiva:  
\q2  Ľoku ne pŇć  Ľae masiva,  Ľi he Ľene fakatauvele Ľi ia ki he Ľene hele.   
\q1
\v 10 ‚ÄĆ ĽOku ne tulolo  Ľo fakavaivai ia,  
\q2 koe Ľuhi ke hinga ai  
\q2  Ľae masiva  Ľi he Ľene mńĀlohi.   
\q1
\v 11 Na Ľe pehńď  Ľe ia  Ľi hono loto, ‚ÄúKuo ngalo  Ľi he  ĽOtua:  
\q2  Ľoku fufŇę  Ľe ia hono fofonga  
\q2  Ľe  Ľikai  Ľaupito te ne mamata ki ai.‚ÄĚ   
\q1
\v 12 Tu Ľu hake,  ĽE Sihova;  
\q2  ĽE  ĽOtua, hiki hake ho nima:  
\q2  Ľoua na Ľa fakangalongalo Ľi  Ľae angavaivai.   
\q1
\v 13 Ko e hńĀ  Ľoku manuki ai  Ľe he angakovi ki he  ĽOtua?  
\q2 Na Ľe pehńď  Ľe ia  Ľi hono loto, ‚Äú ĽE  Ľikai te ke  Ľeke ki ai.‚ÄĚ   
\q1
\v 14 Kuo ke  Ľafio Ľi ia; he  Ľoku ke  Ľafio Ľi  Ľae pau Ľu mo e fakafńĀsifasi,  
\q2 ke totongi ia  Ľaki ho nima:  
\q2  Ľoku tuku ia kiate koe  Ľe he masiva;  
\q2 ko koe ko e tokoni  Ľoe tamai mate.   
\q1
\v 15 Fesi Ľi  Ľe koe  Ľae nima  Ľoe tangata angahala mo angakovi:  
\q2 kumi  Ľene ngaahi kovi kotoa pńď ke  Ľoua ke  Ľosi.   
\q1
\v 16 Ko e Tu Ľi  Ľa Sihova,  Ľo ta Ľengata pea ta Ľengata:  
\q2 kuo  Ľauha  Ľae hiteni mei hono fonua.   
\q1
\v 17 ‚ÄĆ ĽE Sihova, kuo ke ongo Ľi  Ľae holi  Ľae angavaivai:  
\q2 pea te ke teu Ľi honau loto,  
\q2 te ke  Ľange ho fofonga ke  Ľafio Ľi:   
\q1
\v 18 Ke fakamaau  Ľae ngaahi tamai mate mo e kakai kuo ta Ľomia,  
\q2 koe Ľuhi ke  Ľoua na Ľa toe fakailifia Ľi  Ľe he tangata  Ľoe fonua.   
\c 11  
\cd \it 1  ĽOku fakafiemńĀlie Ľi  Ľa Tevita  Ľe ia  Ľi he  ĽOtua koe Ľuhi ko hono ngaahi fili, 4 Ko e pule mo e angatonu  Ľae  ĽOtua.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽOku ou falala kia Sihova:  
\q2 pea  Ľoku fńďfńď ho Ľomou pehńď ki hoku laumńĀlie, ‚ÄúPuna  Ľo hangńď ko e manu ki ho mo Ľunga?   
\q1
\v 2 He  Ľoku teke  Ľe he angahala  Ľenau kaufana,  
\q2  Ľoku nau  Ľai  Ľenau ngaahi ngahau ki he uka,  
\q2 koe Ľuhi ke nau fana fakafufŇę pńď ki he angatonu  Ľi loto.   
\q1
\v 3 Kapau  Ľe  Ľauha  Ľae ngaahi tu Ľunga,  
\q2 ko e hńĀ  Ľe fa Ľa fai  Ľe he kakai mńĀ Ľoni Ľoni?‚ÄĚ   
\q1
\v 4 ‚ÄĆ ĽOku  Ľi hono fale mńĀ Ľoni Ľoni  Ľa Sihova,  
\q2 ko e  Ľafio Ľanga  Ľa Sihova  Ľoku  Ľi he langi:  
\q2  Ľoku  Ľafio Ľi  Ľe hono fofonga,  
\q2  Ľoku  Ľahi Ľahi Ľi  Ľe hono lau Ľifofonga,  
\q2  Ľae ngaahi fńĀnau  Ľae tangata.   
\q1
\v 5 ‚ÄĆ ĽOku  Ľahi Ľahi  Ľe Sihova  Ľae mńĀ Ľoni Ľoni:  
\q2 ka ko e angakovi mo ia  Ľoku manako ki he fakamńĀlohi  Ľoku fehi Ľa hono laumńĀlie ki ai.   
\q1
\v 6 Te ne faka Ľauha ki he ngaahi angahala  Ľae ngaahi tauhele,  
\q2 ko e afi, mo e sulifa, mo e afńĀ fakailifia  Ľaupito: ko e  Ľinasi ia  Ľo  Ľenau ipu.   
\q1
\v 7 He  Ľoku  Ľofa  Ľa Sihova ko e mńĀ Ľoni Ľoni ki he mńĀ Ľoni Ľoni;  
\q2  Ľoku  Ľafio  Ľe hono fofonga ki he angatonu.   
\c 12  
\cd \it 1  ĽOku kole  Ľa Tevita  Ľae tokoni mei he  ĽOtua  Ľi he Ľene masiva  Ľi he fiemńĀlie mei he tangata 3  ĽOku ne fakafiemńĀlie Ľi ia  Ľi he Ľene manatu ki he tautea  Ľi he  ĽOtua ki he angahala, pea  Ľi he Ľene tui ki he ngaahi tala Ľofa  Ľae  ĽOtua.\it*  
\d Ki he Takimu Ľa  Ľi he Semini, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE Sihova, ke ke fakamo Ľui; he kuo ngata  Ľae tangata anga faka Ľotua;  
\q2 he  Ľoku faka Ľa Ľau  Ľo tokosi Ľi  Ľae angatonu  Ľi he ngaahi fńĀnau  Ľae tangata.   
\q1
\v 2 ‚ÄĆ ĽOku nau taki taha lea loi ki hono kaungńĀ Ľapi:  
\q2  Ľoku nau lea  Ľi he loungutu lapu mo e kńĀkńĀ.   
\q1
\v 3 ‚ÄĆ ĽE faka Ľauha  Ľe Sihova  Ľae ngaahi loungutu lapu kotoa pńď,  
\q2 pea mo e  Ľelelo  Ľoku lea  Ľaki  Ľae ngaahi me Ľa fakafielahi:   
\q1
\v 4 ‚ÄĆ ĽAkinautolu na Ľe pehńď, ‚ÄúTe tau ikuna  Ľaki hotau  Ľelelo;  
\q2  Ľoku  Ľotautolu pe hotau loungutu:  
\q2 ko hai  Ľae  Ľeiki kiate kitautolu?   
\q1
\v 5 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚ÄúKo e me Ľa  Ľi he fakamńĀlohi Ľi  Ľoe masiva, mo e ngaahi mafulu  Ľoe vaivai,  
\q2 te u tu Ľu hake;  
\q1 te u fokotu Ľu mo Ľui ia meiate ia  Ľaia  Ľoku manuki kiate ia.‚ÄĚ   
\q1
\v 6 Ko e ngaahi folofola  Ľa Sihova ko e folofola ma Ľa ia:  
\q2  Ľo hangńď ko e siliva kuo  Ľahi Ľahi  Ľi he kulo  Ľumea, kuo tu Ľo fitu hono fakama Ľa.   
\q1
\v 7 ‚ÄĆ ĽE Sihova, te ke tauhi  Ľakinautolu,  
\q2 te ke fakamo Ľui  Ľakinautolu mei he to Ľutangata ni  Ľo ta Ľengata.   
\q1
\v 8 ‚ÄĆ ĽOku  Ľeve Ľeva  Ľae angakovi  Ľi he potu kotoa pńď,  
\q2  Ľoka hakeaki Ľi  Ľae kau tangata  Ľoku mńĀtu Ľaki kovi.   
\c 13  
\cd \it 1  ĽOku lńĀunga  Ľa Tevita  Ľi he fakatuai  Ľoe tokoni. 3  ĽOku ne lotu ke ma Ľu  Ľae  Ľofa. 5  ĽOku ne vikiviki  Ľi he  Ľalo Ľofa  Ľae  ĽOtua.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE Sihova,  Ľe fńďfńď hono fuoloa?  
\q2 Mo ho Ľo kei fakangalongalo Ľi au? Ke ta Ľengata?  
\q2  ĽE fńďfńď hono fuoloa  Ľo ho Ľo fufŇę ho fofonga  Ľiate au?   
\q1
\v 2 ‚ÄĆ ĽE fńďfńď hono fuoloa mo  Ľeku lauloto mo hoku laumńĀlie,  
\q2  Ľo loto mamahi pńď  Ľi he  Ľaho kotoa pńď?  
\q2  ĽE fńďfńď hono fuoloa mo e fielahi kiate au  Ľa hoku fili?   
\q1
\v 3 ‚ÄĆ ĽE Sihova ko hoku  ĽOtua, ke ke tokanga mai pea ongo Ľi au:  
\q2 fakamaama hoku mata, telia na Ľaku mohe  Ľi he mohe  Ľoe mate;   
\q1
\v 4 Telia na Ľa pehńď  Ľe hoku fili, ‚ÄúKuo u ikuna ia;‚ÄĚ  
\q2 pea fiefia  Ľakinautolu  Ľoku fakamamahi Ľi au  Ľo kau ka ngaue.   
\q1
\v 5 Ka kuo u falala ki ho Ľo  Ľalo Ľofa;  
\q2  Ľo fiefia hoku loto  Ľi ho Ľo fakamo Ľui.   
\q1
\v 6 Te u hiva kia Sihova,  
\q2 ko e me Ľa  Ľi he Ľene fai lelei lahi  Ľaupito kiate au.   
\c 14  
\cd \it 1  ĽOku fakamatala atu  Ľe Tevita hono kovi  Ľoe tangata fakakakano. 4  ĽOku ne faka Ľilo  Ľae kovi ki he angahala  Ľaki  Ľae maama  Ľi honau loto. 7  ĽOku ne vikiviki  Ľi he fakamo Ľui  Ľae  ĽOtua.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita.  
\q1
\v 1 Kuo pehńď  Ľe he vale  Ľi hono loto, ‚Äú ĽOku  Ľikai ha  ĽOtua.‚ÄĚ  
\q2 Kuo kovi  Ľakinautolu,  
\q2 kuo nau fai  Ľae ngaahi ngńĀue fakalielia,  
\q2  Ľoku  Ľikai ha tokotaha  Ľoku fai lelei.   
\q1
\v 2 Na Ľe  Ľafio hifo  Ľe Sihova mei he langi ki he fńĀnau  Ľae tangata,  
\q2 ke  Ľafio pńď  Ľoku ai ha ni Ľihi  Ľoku  Ľilo,  
\q2 mo kumi ki he  ĽOtua.   
\q1
\v 3 Kuo  Ľalu hńď kotoa pńď,  
\q2 kuo nau hoko  Ľo fakalielia kotoa pńď:  
\q2  Ľoku  Ľikai ha tokotaha  Ľoku fai lelei,  
\q2  Ľoku  Ľikai  Ľaupito ha taha.   
\q1
\v 4 ‚Äú ĽOku  Ľikai ha  Ľilo  Ľiate kinautolu kotoa pńď  Ľoku fai kovi?  
\q2  ĽAkinautolu  Ľoku kai  Ľo  Ľosi hoku kakai  Ľo hangńď ko  Ľenau kai mńĀ,  
\q2 pea  Ľoku  Ľikai te nau ui kia Sihova.‚ÄĚ   
\q1
\v 5 Pea na Ľa nau manavahńď ai  Ľi he manavahńď lahi:  
\q2 he  Ľoku  Ľi he to Ľutangata  Ľoe mńĀ Ľoni Ľoni  Ľae  ĽOtua.   
\q1
\v 6 Na Ľa mou manuki Ľi  Ľae fakakaukau  Ľoe masiva,  
\q2 ka ko hono hŇęfanga  Ľa Sihova.   
\q1
\v 7 Ko hai te ne foaki mei Saione  Ľae fakamo Ľui ki  ĽIsileli?  
\q2  ĽOka toe  Ľomi  Ľe Sihova hono kakai kuo pŇćpula,  
\q2  Ľe fiefia ai  Ľa Sńďkope, pea nekeneka  Ľa  ĽIsileli.   
\c 15  
\cd \it 1‚Äď5  ĽOku fakahńĀ  Ľe Tevita  Ľae tangata totonu  Ľoe kolo ko Saione.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE Sihova, ko hai te ne nofo  Ľi ho fale fehikitaki?  
\q2 Ko hai te ne nofoma Ľu  Ľi ho mo Ľunga mńĀ Ľoni Ľoni?   
\q1
\v 2 Ko ia ia  Ľoku  Ľeve Ľeva  Ľi he angatonu, pea ngńĀue  Ľi he mńĀ Ľoni Ľoni,  
\q2 mo lea  Ľaki  Ľae mo Ľoni  Ľi hono loto.   
\q1
\v 3 Ko ia  Ľoku  Ľikai lau Ľikovi  Ľaki hono  Ľelelo,  
\q2 pe fai kovi ki hono kaungńĀ Ľapi,  
\q2 pe to Ľo hake  Ľae lea kovi ki hono kaungńĀ Ľapi.   
\q1
\v 4 ‚ÄĆ ĽAia  Ľoku kovi ki hono mata  Ľae tangata fai kovi;  
\q2 ka  Ľoku ne faka Ľapa Ľapa kiate kinautolu  Ľoku manavahńď kia Sihova.  
\q2  ĽOku ne fuakava, pea kovi ai ia, ka  Ľe  Ľikai liliu ai.   
\q1
\v 5 Ko ia  Ľoku  Ľikai  Ľange  Ľene ngaahi pa Ľanga koe Ľuhi ko e totongi,  
\q2 pe to Ľo  Ľe ia  Ľae totongi ke fai kovi ki he mńĀ Ľoni Ľoni.  
\b  
\q1 Ko ia  Ľoku ne fai  Ľae ngaahi me Ľa ni  Ľe  Ľikai ue Ľi ia  Ľo ta Ľengata.   
\c 16  
\cd \it 1  ĽOku hola  Ľa Tevita ki he  ĽOtua ke ne fakamo Ľui ia. 5  ĽOku ne fakahńĀ  Ľene  Ľamanaki ki he toetu Ľu mo e mo Ľui ta Ľengata.\it*  
\d Ko e Saame mahu Ľinga  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE  ĽOtua, ke ke fakamo Ľui au: he  Ľoku ou falala kiate koe.   
\q1
\v 2 ‚ÄĆ ĽE hoku laumńĀlie, na Ľa ke pehńď kia Sihova, ‚ÄúKo hoku  ĽEiki koe:  
\q2  Ľoku  Ľikai a Ľu atu  Ľeku angalelei kiate koe;‚ÄĚ   
\q1
\v 3 Ka ki he kau mńĀ Ľoni Ľoni  Ľoku  Ľi mńĀmani,  
\q2 pea ki he angalelei,  Ľoku  Ľiate kinautolu  Ľeku fiefia kotoa pńď.   
\q1
\v 4 ‚ÄĆ ĽE  ĽńĀsili ai  Ľae mamahi  Ľokinautolu  Ľoku kumi  Ľotua kehe:  
\q2 ko  Ľenau ngaahi feilaulau inu  Ľoe toto  Ľe  Ľikai te u  Ľatu,  
\q2 pe to Ľo hake honau ngaahi hingoa ki hoku loungutu.   
\q1
\v 5 Ko hono lelei  Ľo hoku tofi Ľa mo  Ľeku ipu  Ľa Sihova:  
\q2  Ľoku ke tauhi hoku talotalo.   
\q1
\v 6 Kuo falŇć kiate au  Ľae ngaahi afo  Ľi he ngaahi potu matamatalelei;  
\q2  Ľio, kuo u ma Ľu  Ľae tofi Ľa lelei.   
\q1
\v 7 Te u fakafeta Ľi kia Sihova,  Ľaia kuo ne akonaki Ľi au:  
\q2 ko hoku kofuua foki  Ľoku na akonaki Ľi au  Ľi he ngaahi feitu Ľu pŇć.   
\q1
\v 8 Kuo u fokotu Ľu ma Ľuaipńď  Ľa Sihova  Ľi hoku  Ľao:  
\q2 ko e me Ľa  Ľi he Ľene  Ľi hoku nima to Ľomata Ľu,  Ľe  Ľikai ai te u ngaue.   
\q1
\v 9 Ko ia  Ľoku fiefia ai hoku loto, pea nekeneka mo hoku  Ľelelo:  
\q2  Ľe mńĀlŇćlŇć foki  Ľa hoku sino  Ľi he  Ľamanaki lelei.   
\q1
\v 10 Koe Ľuhi  Ľe  Ľikai te ke tuku hoku laumńĀlie  Ľi hńďtesi;  
\q2 pea  Ľe  Ľikai te ke tuku ho tokotaha mńĀ Ľoni Ľoni ke ne  Ľilo  Ľae  Ľau Ľauha.   
\q1
\v 11 Te ke fakahńĀ kiate au  Ľae hala  Ľoe mo Ľui:  
\q2  Ľoku fonu  Ľae fiefia  Ľi ho  Ľao;  
\q2  Ľoku  Ľi ho nima to Ľomata Ľu  Ľae ngaahi fiemńĀlie  Ľo ta Ľengata.   
\c 17  
\cd \it 1  ĽOku kole  Ľa Tevita  Ľi he Ľene angatonu ki he  ĽOtua ke ne malu Ľi ia mei hono ngaahi fili. 10  ĽOku ne fakahńĀ  Ľenau laukau, mo e kńĀkńĀ, mo e manavakavakava. 13  ĽOku ne kole koe Ľuhi ko kinautolu  Ľi he  Ľamanaki lelei.\it*  
\d Ko e Lotu  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE Sihova, ke ke fanongo ki he me Ľa totonu,  
\q2 tokanga ki he Ľeku tangi fakafanongo ki he Ľeku lotu,  Ľaia  Ľoku  Ľikai mei he loungutu kńĀkńĀ.   
\q1
\v 2 Ke ha Ľu mei ho  Ľao  Ľa hoku fakamaau;  
\q2 ke  Ľafio Ľi  Ľe ho fofonga  Ľaia  Ľoku totonu.   
\q1
\v 3 Na Ľa ke  Ľahi Ľahi Ľi hoku loto;  
\q2 na Ľa ke  Ľa Ľahi kiate au  Ľi he po Ľuli;  
\q2 kuo ke  Ľahi Ľahi Ľi au,  
\q2 ka  Ľe  Ľikai te ke  Ľilo ha me Ľa;  
\q2 kuopau pe hoku loto  Ľe  Ľikai hala hoku ngutu.   
\q1
\v 4 Pea ko e me Ľa  Ľi he ngaahi ngńĀue  Ľae tangata,  
\q2  Ľi he folofola  Ľo ho loungutu kuo u ta Ľofi  Ľaki au mei he ngaahi  Ľalu Ľanga  Ľoe faka Ľauha.   
\q1
\v 5 Ke ke tokoni  Ľeku  Ľalu atu  Ľi ho ngaahi hala,  
\q2 ke  Ľoua na Ľa hekea hoku va Ľe.   
\q1
\v 6 ‚ÄĆ ĽE  ĽOtua na Ľaku ui kiate koe, he te ke ongo Ľi au:  
\q2 ke ke fakatokanga Ľi ho telinga kiate au,  
\q2 pea fanongo ki he Ľeku lea.   
\q1
\v 7 FakahńĀ ho Ľo  Ľalo Ľofa fakamanavahńď,  
\q2  Ľa koe  Ľoku ke fakamo Ľui  Ľaki ho nima to Ľomata Ľu  Ľakinautolu  Ľoku falala kiate koe meiate kinautolu  Ľoku tu Ľu hake kiate kinautolu.   
\q1
\v 8 Ke ke tauhi au  Ľo hangńď ko e tama Ľimata,  
\q2 fakafufŇę au  Ľi he malu  Ľo ho kapakau,   
\q1
\v 9 Mei he kau angakovi  Ľaia  Ľoku nau ta Ľomia au,  
\q2 mei hoku ngaahi fili fakapŇć,  Ľoku nau kńĀpui au.   
\q1
\v 10 Kuo  ĽńĀ Ľi  Ľakinautolu  Ľaki honau fu Ľu sino:  
\q2  Ľoku nau lea fakafielahi  Ľaki honau ngutu.   
\q1
\v 11 Ko eni kuo nau kńĀpui  Ľakimautolu  Ľi homau ngaahi  Ľalu Ľanga:  
\q2 kuo nau fakamama Ľu honau mata  Ľo sio hifo ki he kelekele;   
\q1
\v 12 ‚ÄĆ ĽO hangńď ko e laione  Ľoku holi ki he kai,  
\q2 pea hangńď ko e laione mui  Ľoku toitoi  Ľi he ngaahi potu lilo.   
\q1
\v 13 Tu Ľu hake,  ĽE Sihova,  Ľo ta Ľofi ia,  
\q2 lńę ia ki lalo:  
\q2 fakahaofi hoku laumńĀlie mei he tangata angakovi,  Ľaia ko ho Ľo heletńĀ:   
\q2
\v 14 ‚ÄĆ ĽE Sihova, mei he kau tangata  Ľoku  Ľi ho nima,  
\q1 mei he kau tangata  Ľo mńĀmani,  Ľoku nau ma Ľu honau  Ľinasi  Ľi he mo Ľui ni,  
\q1  Ľakinautolu  Ľoku ke fakapito honau kete  Ľaki ho Ľo koloa fufŇę:  
\q2  Ľoku nau fonu  Ľi he ngaahi fńĀnau,  
\q2 pea  Ľoku nau tuku hono toe  Ľo  Ľenau koloa ki he Ľenau kau valevale.   
\q1
\v 15 Ka ko au, te u mamata ki ho fofonga  Ľi he mńĀ Ľoni Ľoni:  
\q2 te u fiemńĀlie au,  Ľo kau ka  ĽńĀ hake,  Ľi ho tatau.   
\c 18  
\cd \it 1‚Äď50  ĽOku fakafeta Ľi  Ľe Tevita ki he  ĽOtua koe Ľuhi ko  Ľene ngaahi tńĀpuaki lahi mo fakaofo.\it*  
\d Ki he Takimu Ľa ko e Saame  Ľa Tevita, ko e tamaio Ľeiki  Ľa Sihova,  Ľaia na Ľe lea  Ľaki kia Sihova  Ľae ngaahi lea  Ľoe hiva ni,  Ľi he  Ľaho ko ia na Ľe fakamo Ľui ia  Ľe Sihova mei he nima  Ľo hono ngaahi fili kotoa pńď, pea mei he nima  Ľo Saula:  Ľo pehńď,  
\q1
\v 1 Te u  Ľofa kiate koe,  ĽE Sihova, ko  Ľeku mńĀlohi.   
\q1
\v 2 Ko hoku makatu Ľu  Ľa Sihova, mo  Ľeku kolo, mo hoku fakamo Ľui;  
\q2 ko hoku  ĽOtua, ko hoku mńĀlohi,  Ľaia te u falala ki ai;  
\q2 ko hoku fakaŇę, mo e mńĀlohi  Ľo  Ľeku mo Ľui, mo hoku hŇęfanga mńĀ Ľolunga.   
\q1
\v 3 Te u ui kia Sihova,  Ľaia  Ľoku ngali mo ia  Ľae fakafeta Ľi:  
\q2 ko ia te u mo Ľui ai mei hoku ngaahi fili.   
\q1
\v 4 Na Ľe kńĀpui au  Ľe he ngaahi mamahi  Ľoe mate.  
\q2 pea na Ľe fakamanavahńď Ľi au  Ľe he lŇćmaki mai  Ľoe kau tangata angakovi.   
\q1
\v 5 Na Ľe kńĀpui au  Ľe he ngaahi mamahi  Ľo hńďtesi:  
\q2 na Ľe talia au  Ľe he ngaahi tauhele  Ľoe mate.   
\q1
\v 6 ‚ÄĆ ĽI he Ľeku mamahi na Ľaku ui kia Sihova,  
\q2 mo tangi ki hoku  ĽOtua:  
\q2 pea ne ongo Ľi hoku le Ľo mei hono faletapu,  
\q2 pea na Ľe a Ľu atu  Ľeku tangi ki hono  Ľao,  Ľio, ki hono fofonga.   
\q1
\v 7 Na Ľe ngalulu ai  Ľa mńĀmani  Ľo tetetete;  
\q2 na Ľe ngaue mo lulululu foki  Ľae tu Ľunga  Ľoe ngaahi mo Ľunga,  
\q2 koe Ľuhi ko  Ľene houhau.   
\q1
\v 8 Na Ľe  Ľalu hake  Ľae kohu  Ľi hono houhau,  
\q2 pea na Ľe keina  Ľe he afi mei hono ngutu:  
\q2 na Ľe tutu Ľaki ia  Ľae fefie.   
\q1
\v 9 Na Ľa ne ofe Ľi hifo foki  Ľae ngaahi langi,  Ľo hńĀ Ľele hifo:  
\q2 pea na Ľe  Ľi hono lalo va Ľe  Ľae po Ľuli.   
\q1
\v 10 Na Ľe heka ia ki he selupi, pea hńĀ Ľele ia:  
\q2  Ľio, na Ľe hńĀ Ľele ia  Ľi he ngaahi kapakau  Ľoe matangi.   
\q1
\v 11 Na Ľa ne ngaohi  Ľae po Ľuli ko hono fakalilolilo:  
\q2 ko hono  Ľafio Ľanga na Ľe kńĀpui ia  Ľe he vai fakapo Ľuli mo e ngaahi  Ľao matolu  Ľoe langi.   
\q1
\v 12 ‚ÄĆ ĽI he ulo mei hono  Ľao na Ľe mole atu ai  Ľa  Ľene ngaahi  Ľao matolu,  
\q2  Ľae  Ľuha maka mo e ngaahi malala Ľi afi.   
\q1
\v 13 Na Ľe mana foki  Ľe Sihova  Ľi he ngaahi langi,  
\q2 pea fakahńĀ hono le Ľo  Ľe he Fungani MńĀ Ľolunga;  
\q2 ko e  Ľuha maka mo e ngaahi malala Ľi afi.   
\q1
\v 14 ‚ÄĆ ĽIo, na Ľa ne fana atu  Ľene ngaahi ngahau, pea veteki  Ľakinautolu;  
\q2 pea ne fana  Ľaki  Ľae ngaahi  Ľuhila,  Ľo veuveuki  Ľakinautolu.   
\q1
\v 15 Na Ľe toki hńĀ ai  Ľae ngaahi tafe Ľanga  Ľoe vai,  
\q2 pea fakahńĀ ai  Ľae ngaahi tu Ľunga  Ľo mńĀmani  Ľi ho houhau,  ĽE Sihova,  
\q2  Ľi he matangi  Ľoe mńĀnava  Ľo ho houhau.   
\q1
\v 16 Na Ľa ne fekau mei  Ľolunga,  
\q2 na Ľa ne to Ľo au,  
\q2 na Ľa ne to Ľo hake au mei he ngaahi vai lahi.   
\q1
\v 17 Na Ľa ne fakahaofi au mei hoku fili   
\q1
\v 18 Na Ľa nau fakatanga Ľi au  Ľi he  Ľaho  Ľo  Ľeku tu ĽutńĀmaki:  
\q2 ka ko hoku tokoni  Ľa Sihova.   
\q1
\v 19 Na Ľa ne  Ľomi au ki he potu  Ľata ĽatńĀ lahi;  
\q2 na Ľa ne fakahaofi au, ko e me Ľa  Ľi he Ľene fiemńĀlie  Ľiate au.   
\q1
\v 20 Na Ľe totongi  Ľe Sihova kiate au  Ľo fakatatau ki he Ľeku mńĀ Ľoni Ľoni;  
\q2  Ľo fakatatau ki he ma Ľa  Ľa hoku nima kuo ne totongi kiate au.   
\q1
\v 21 He na Ľaku tauhi  Ľae ngaahi hala  Ľo Sihova,  
\q2 pea na Ľe  Ľikai te u  Ľalu  Ľi he angakovi mei hoku  ĽOtua.   
\q1
\v 22 He na Ľe  Ľi hoku  Ľao  Ľa  Ľene ngaahi fakamaau kotoa pńď,  
\q2 pea na Ľe  Ľikai te u li Ľaki  Ľene ngaahi fekau  Ľiate au.   
\q1
\v 23 Pea na Ľaku angatonu foki  Ľi hono  Ľao,  
\q2 pea ne u ta Ľofi au mei he Ľeku hia.   
\q1
\v 24 Ko ia kuo totongi ai au  Ľe Sihova  Ľo fakatatau ki he Ľeku mńĀ Ľoni Ľoni,  
\q2 pea fakatatau ki he ma Ľa  Ľa hoku nima  Ľi hono  Ľao.   
\q1
\v 25 ‚ÄĆ ĽI he kakai loto  Ľofa te ke fakahńĀ koe ko e  Ľalo Ľofa;  
\q2 ki he tangata angatonu te ke fakahńĀ koe ko e angatonu;   
\q1
\v 26 Ki he mńĀ Ľoni Ľoni te ke fakahńĀ koe  Ľae mńĀ Ľoni Ľoni;  
\q2 pea ki he tangata angatu Ľu temo fekuki mo ia.   
\q1
\v 27 He ko koe te ke fakamo Ľui  Ľae kakai mamahi:  
\q2 ka te ke  Ľohifo ki lalo  Ľae mata fielahi.   
\q1
\v 28 Pea te ke tutu  Ľeku maama:  
\q2  Ľo hulu Ľaki  Ľeku fakapo Ľuli  Ľe Sihova ko hoku  ĽOtua.   
\q1
\v 29 He ko e me Ľa  Ľiate koe na Ľaku halaua  Ľae tau  Ľo hao;  
\q2 pea  Ľi hoku  ĽOtua ne u puna kitu Ľa  Ľi he  ĽńĀ maka.   
\q1
\v 30 Pea ko e  ĽOtua,  
\q2  Ľoku haohaoa hono hala:  
\q2  Ľoku  Ľahi Ľahi Ľi  Ľae folofola  Ľa Sihova:  
\q2 ko e fakaŇę ia kiate kinautolu kotoa pńď  Ľoku falala kiate ia.   
\q1
\v 31 He ko hai  Ľoku  ĽOtua ka ko Sihova pńď?  
\q2 Pe ko hai  Ľae makatu Ľu ka ko hotau  ĽOtua pńď?   
\q1
\v 32 Ko e  ĽOtua ia  Ľoku ne nono Ľo  Ľaki au  Ľae mńĀlohi,  Ľo fakahaohaoa hoku  Ľalu Ľanga.   
\q1
\v 33 ‚ÄĆ ĽOku ne ngaohi hoku va Ľe ke hangńď ko e va Ľe  Ľoe hainiti,  
\q2  Ľo ne fokotu Ľu au ki hoku ngaahi potu mńĀ Ľolunga.   
\q1
\v 34 ‚ÄĆ ĽOku ne akonaki Ľi hoku nima ke tau,  
\q2 ko ia  Ľoku fesi Ľi ai  Ľe hoku nima  Ľae kaufana ukamea.   
\q1
\v 35 Pea kuo ke foaki foki kiate au  Ľae fakaŇę  Ľo ho Ľo fakamo Ľui:  
\q2 pea kuo poupou hake au  Ľe ho nima to Ľomata Ľu,  
\q2 pea  Ľi ho Ľo angamalŇę kuo ke hakeaki Ľi au.   
\q1
\v 36 Kuo ke faka Ľata ĽatńĀ hoku  Ľalu Ľanga  Ľi lalo  Ľiate au,  
\q2 ko ia na Ľe  Ľikai hekea ai hoku va Ľe.   
\q1
\v 37 Na Ľaku tuli hoku ngaahi fili  Ľo ma Ľu  Ľakinautolu:  
\q2 pea na Ľe  Ľikai te u toe foki kae Ľoua ke  Ľauha  Ľakinautolu.   
\q1
\v 38 Kuo nau makafokafo  Ľiate au,  
\q2 ko ia na Ľe  Ľikai ai tenau fa Ľa tu Ľu hake:  
\q2 kuo nau tŇć ki hoku lalo va Ľe.   
\q1
\v 39 He na Ľa ke nono Ľo  Ľaki au  Ľae mńĀlohi ki he tau:  
\q2 kuo ke fakavaivai ki lalo  Ľiate au  Ľakinautolu na Ľe tu Ľu hake kiate au.   
\q1
\v 40 Pea kuo ke foaki foki kiate au  Ľae kia  Ľo hoku ngaahi fili;  
\q2 koe Ľuhi ke u faka Ľauha  Ľakinautolu  Ľoku fehi Ľa kiate au.   
\q1
\v 41 Na Ľa nau tangi, ka na Ľe  Ľikai ha taha ke fakamo Ľui:  
\q2  Ľio, kia Sihova, ka na Ľe  Ľikai te ne talia  Ľakinautolu.   
\q1
\v 42 Pea ne u toki tali  Ľakinautolu  Ľo momosi  Ľo hangńď ko e efu  Ľoku vilingia  Ľi he matangi:  
\q2 na Ľaku lńę  Ľakinautolu kitu Ľa  Ľo hangńď ko e pelepela  Ľi he ngaahi hala.   
\q1
\v 43 Kuo ke fakamo Ľui au mei he ngaahi feke Ľike Ľi  Ľoe kakai;  
\q2 pea kuo ke ngaohi au ko e  Ľulu ki he hiteni:  
\q2 ko e kakai na Ľe  Ľikai te u  Ľilo Ľi te nau tauhi au.   
\q1
\v 44 ‚ÄĆ ĽOka nau ka fanongo kiate au,  
\q2 te nau talangofua leva kiate au:  
\q2 ko e kau muli te nau fakavaivai  Ľakinautolu kiate au.   
\q1
\v 45 ‚ÄĆ ĽE faka Ľa Ľau  Ľo  Ľosi  Ľae ngaahi muli,  
\q2 pea te nau manavahńď mei honau ngaahi potu lilo.   
\q1
\v 46 ‚ÄĆ ĽOku mo Ľui  Ľa Sihova; pea fakafeta Ľi ki hoku makatu Ľu;  
\q2 pea tuku ke hakeaki Ľi  Ľae  ĽOtua  Ľo  Ľeku mo Ľui.   
\q1
\v 47 Ko e  ĽOtua ia  Ľoku langomia au,  
\q2  Ľo ne fakavaivai  Ľae kakai kiate au.   
\q1
\v 48 ‚ÄĆ ĽOku ne fakamo Ľui au mei hoku ngaahi fili:  
\q2  Ľio,  Ľoku ke hiki au ke u mńĀ Ľolunga  Ľiate kinautolu  Ľoku angatu Ľu kiate au:  
\q2 kuo ke fakamo Ľui au mei he tangata angamńĀlohi.   
\q1
\v 49 Ko ia te u fakafeta Ľi ai kiate koe,  ĽE Sihova,  Ľi he  Ľao  Ľoe hiteni,  
\q2 pea te u hiva Ľaki  Ľae fakafeta Ľi ki ho huafa.   
\q1
\v 50 ‚ÄĆ ĽOku ne tuku  Ľae fakamo Ľui lahi ki he Ľene tu Ľi;  
\q2  Ľo ne fakahńĀ  Ľae  Ľalo Ľofa kiate ia kuo ne pani  Ľaki  Ľae lolo,  
\q2 kia Tevita, mo hono hako  Ľo ta Ľengata.   
\c 19  
\cd \it 1  ĽOku fakahńĀ  Ľe he ngaahi ngńĀue  Ľae  ĽOtua hono nńĀunau, 7 Mo  Ľene  Ľofa  Ľi he Ľene folofola. 12  ĽOku lotu  Ľa Tevita ke ne ma Ľu  Ľae  Ľofa.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽOku fakahńĀ  Ľe he ngaahi langi  Ľae nńĀunau  Ľoe  ĽOtua;  
\q2 pea  Ľoku fakahńĀ  Ľe he  ĽatńĀ  Ľae ngńĀue  Ľa hono nima.   
\q1
\v 2 ‚ÄĆ ĽOku lea  Ľe he  Ľaho ki he  Ľaho,  
\q2 pea fakahńĀ  Ľe he pŇć ki he pŇć  Ľae  Ľilo.   
\q1
\v 3 ‚ÄĆ ĽOku  Ľikai ha le Ľo pe ha lea,  
\q2  Ľoku ta Ľeongo Ľi honau le Ľo.   
\q1
\v 4 Kuo hoko  Ľenau fua ki he fonua kotoa pńď,  
\q2 mo  Ľenau ngaahi lea ki he ngata Ľanga  Ľo mńĀmani.  
\q2 Kuo fokotu Ľu  Ľe ia  Ľi ai  Ľae nofo Ľanga ki he la ĽńĀ,   
\q1
\v 5 ‚ÄĆ ĽAia  Ľoku hangńď ko e tangata ta Ľane  Ľoku ha Ľu mei hono potu teuteu,  
\q2 pea fiefia  Ľo hangńď ko e tangata mńĀlohi ke fakapuepue.   
\q1
\v 6 Ko hono hopo Ľanga  Ľoku mei he ngata Ľanga  Ľoe langi,  
\q2 mo hono  Ľalu Ľanga ki hono ngaahi ngata Ľanga:  
\q2 pea  Ľoku  Ľikai ha me Ľa  Ľe taha  Ľe lilo  Ľi hono mafana.   
\q1
\v 7 Ko e fono  Ľa Sihova  Ľoku haohaoa,  Ľoku ne liliu  Ľae laumńĀlie:  
\q2 ko e faka Ľilo  Ľa Sihova  Ľoku tu Ľuma Ľu,  Ľoku ne fakapoto Ľi  Ľae vale.   
\q1
\v 8 Ko e ngaahi tu Ľutu Ľuni  Ľa Sihova  Ľoku totonu,  Ľoku nau fakafiefia Ľi  Ľae loto:  
\q2 ko e fekau  Ľa Sihova  Ľoku mńĀ Ľoni Ľoni,  Ľoku ne fakamaama ki he mata.   
\q1
\v 9 Ko e manavahńď kia Sihova  Ľoku ma Ľa, pea tolonga ta Ľengata:  
\q2 ko e ngaahi fakamaau  Ľa Sihova  Ľoku mo Ľoni mo mńĀ Ľoni Ľoni kotoa pńď.   
\q1
\v 10 ‚ÄĆ ĽOku totonu ke lahi hake  Ľae holi ki ai  Ľi he holi ki he koula,  Ľio,  Ľi he koula lahi mo lelei:  
\q2  Ľoku hu Ľamelie lahi hake ia  Ľi he honi mo hono to Ľi  Ľae honi.   
\q1
\v 11 Pea kuo valokia ai foki  Ľa ho tamaio Ľeiki:  
\q2 pea  Ľi he tauhi ki ai  Ľoku lahi hono totongi.   
\q1
\v 12 Ko hai te ne fa Ľa  Ľilo  Ľene ngaahi hńď?  
\q2 Ke ke fakama Ľa au mei he ngaahi angahala fufŇę.   
\b  
\q1
\v 13 Pea ke ta Ľofi ho Ľo tamaio Ľeiki foki mei he ngaahi angahala  Ľoku fai  Ľi he  Ľilo;  
\q2 ke  Ľoua na Ľa nau pule Ľi au:  
\q2 ko ia te u angatonu ai,  
\q2 pea te u mńĀ Ľoni Ľoni mei he angahala lahi.   
\q1
\v 14 ‚ÄĆ ĽE Sihova, ko hoku mńĀlohi, mo hoku huhu Ľi,  
\q2 tuku ke lelei  Ľi ho  Ľao,  
\q2  Ľae ngaahi lea  Ľa hoku ngutu, mo e fakakaukau  Ľa hoku loto.   
\c 20  
\cd \it 1  ĽOku kole  Ľae tńĀpuaki ki he tu Ľi  Ľi he Ľene ngaahi ngńĀue. 7 Pea ne falala ki he fakamo Ľui  Ľae  ĽOtua.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita.  
\q1
\v 1 Ke ongo Ľi koe  Ľe Sihova  Ľi he  Ľaho  Ľoe mamahi; ke malu Ľi koe  Ľe he huafa  Ľoe  ĽOtua  Ľo Sńďkope;   
\q1
\v 2 ‚ÄĆ ĽO fekau ho Ľo tokoni mei he faletapu,  
\q2 mo fakamńĀlohi koe mei Saione;   
\q1
\v 3 ‚ÄĆ ĽO manatu Ľi ho Ľo me Ľa foaki kotoa pńď,  
\q2 pea finangalo lelei ki ho Ľo feilaulau tutu; \qs Sila.\qs*   
\q1
\v 4 Pea foaki kiate koe  Ľo hangńď ko ho loto,  
\q2  Ľo fakahoko  Ľaia  Ľoku ke fakakaukau ki ai.   
\q1
\v 5 Te mau fiefia  Ľi ho Ľo fakamo Ľui,  
\q2 pea  Ľi he huafa  Ľo homau  ĽOtua te mau fokotu Ľu  Ľemau ngaahi fuka:  
\q2 ke tuku kiate koe  Ľe Sihova  Ľa ho Ľo ngaahi kole kotoa pńď.   
\q1
\v 6 Pea ko eni,  Ľoku ou  Ľilo  Ľoku fakamo Ľui  Ľe Sihova  Ľa  Ľene pani;  
\q2 te ne ongo Ľi ia mei hono potu toputapu mńĀ Ľoni Ľoni  Ľaki  Ľae mńĀlohi fakamo Ľui  Ľo hono nima to Ľomata Ľu.   
\q1
\v 7 ‚ÄĆ ĽOku falala  Ľae ni Ľihi ki he ngaahi saliote, mo e ni Ľihi ki he fanga hoosi:  
\q2 ka te tau manatu Ľi  Ľae huafa  Ľo Sihova ko hotau  ĽOtua.   
\q1
\v 8 Kuo lńę ki lalo  Ľo tŇć  Ľakinautolu:  
\q2 ka kuo tau tu Ľuhake,  Ľo tu Ľu ki  Ľolunga.   
\q1
\v 9 ‚ÄĆ ĽE Sihova, ke ke fakamo Ľui  Ľae tu Ľi  
\q2 ke ke ongo Ľi  Ľakimautolu  Ľi he Ľemau ui atu.   
\c 21  
\cd \it 1 Ko e fakafeta Ľi  Ľi he tuku mai  Ľae mńĀlohi, 7 Mo e  Ľamanaki ki he tokoni  Ľamui.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE Sihova,  Ľe fiefia  Ľae tu Ľi  Ľi ho mńĀlohi;  
\q2 pea  Ľe fiefia lahi  Ľaupito ia  Ľi ho Ľo fakamo Ľui.   
\q1
\v 2 Kuo ke foaki kiate ia  Ľae holi  Ľa hono loto,  
\q2 pea na Ľe  Ľikai te ke ta Ľofi  Ľiate ia  Ľae kole  Ľa hono loungutu. \qs Sila.\qs*   
\q1
\v 3 He  Ľoku ke tokoni  Ľaki ia  Ľae ngaahi tńĀpuaki  Ľoe lelei:  
\q2  Ľoku ke  Ľai ki hono fofonga  Ľae tatńĀ fakatu Ľi  Ľoe koula lelei.   
\q1
\v 4 Na Ľa ne kole  Ľae mo Ľui  Ľiate koe, pea na Ľa ke foaki ia kiate ia,  
\q2  Ľio,  Ľae ngaahi  Ľaho lŇćloa  Ľo ta Ľengata pea ta Ľengata.   
\q1
\v 5 ‚ÄĆ ĽOku lahi  Ľene vikiviki  Ľi ho Ľo fakamo Ľui:  
\q2 kuo ke tuku kiate ia  Ľae faka Ľapa Ľapa mo e nńĀunau.   
\q1
\v 6 He kuo ke ngaohi ia ke mńĀtu Ľaki monŇę Ľia  Ľo ta Ľengata:  
\q2 kuo ke fakafiefia lahi  Ľaupito ia  Ľaki ho fofonga.   
\q1
\v 7 He  Ľoku falala  Ľae tu Ľi kia Sihova,  
\q2 pea ko e me Ľa  Ľi he  Ľalo Ľofa  Ľoe Fungani MńĀ Ľolunga  Ľe  Ľikai ue Ľi ia.   
\q1
\v 8 ‚ÄĆ ĽE  Ľilo  Ľe ho nima  Ľa ho ngaahi fili kotoa pńď:  
\q2 pea  Ľe  Ľilo  Ľe ho nima to Ľomata Ľu  Ľakinautolu  Ľoku fehi Ľa kiate koe.   
\q1
\v 9 Te ke ngaohi  Ľakinautolu ke hangńď ko e ngoto Ľumu vela  Ľi he  Ľaho  Ľo ho Ľo tuputńĀmaki:  
\q2  Ľe faka Ľauha  Ľakinautolu  Ľe Sihova  Ľi hono houhau,  
\q2  Ľe keina  Ľo  Ľosi  Ľakinautolu  Ľe he afi.   
\q1
\v 10 Te ke faka Ľauha honau fua mei he fonua,  
\q2 mo honau hako mei he ngaahi fńĀnau  Ľae tangata.   
\q1
\v 11 He na Ľa nau tokanga ke fai kovi kiate koe:  
\q2 na Ľa nau fakatupu  Ľae mahalo kovi,  Ľaia na Ľe  Ľikai te nau fa Ľa fai.   
\q1
\v 12 Ko ia te ke fai ke fulitu Ľa  Ľakinautolu,  
\q2  Ľoka ke ka  Ľai  Ľae ngaahi ngahau ki he uka ki he mata  Ľokinautolu.   
\q1
\v 13 Ke ke mńĀ Ľolunga,  ĽE Sihova,  Ľi he mńĀlohi  Ľo Ľou:  
\q2 ko ia te mau hiva mo fakamńĀlŇć ai ki ho Ľo mńĀfimafi.   
\c 22  
\cd \it 1  ĽOku lńĀunga  Ľa Tevita  Ľi he ngaahi fakavaivai. 9  ĽOku ne lotu  Ľi he mamahi lahi. 23  ĽOku ne fakafeta Ľi ki he  ĽOtua.\it*  
\d Ki he Takimu Ľa  Ľi he  ĽAilete-Sahala, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE hoku  ĽOtua,  ĽE hoku  ĽOtua, ko e hńĀ kuo ke li Ľaki ai au?  
\q2 Ko e hńĀ  Ľoku ke mama Ľo ai mei he tokoni kiate au, pea mei he ngaahi lea  Ľo  Ľeku tangi?   
\q1
\v 2 ‚ÄĆ ĽE hoku  ĽOtua,  Ľoku ou tangi  Ľi he  Ľaho, ka  Ľoku  Ľikai te ke ongo Ľi;  
\q2 pea  Ľi he pŇć,  Ľoku  Ľikai te u longo pńď.   
\q1
\v 3 Ka  Ľoku ke mńĀ Ľoni Ľoni,  
\q2  Ľa koe  Ľoku ke ma Ľu  Ľae ngaahi fakafeta Ľi  Ľo  ĽIsileli.   
\q1
\v 4 Na Ľe falala  Ľa  Ľemau ngaahi tamai kiate koe:  
\q2 na Ľa nau falala, pea na Ľa ke fakamo Ľui  Ľakinautolu.   
\q1
\v 5 Na Ľa nau tangi kiate koe, pea na Ľe fakamo Ľui  Ľakinautolu:  
\q2 na Ľa nau falala kiate koe, pea na Ľe  Ľikai te nau mńĀ.   
\q1
\v 6 Ka ko e kelemutu au, ka  Ľoku  Ľikai ko e tangata:  
\q2 ko e manuki Ľanga  Ľoe tangata, ko e fehi Ľanekina  Ľe he kakai.   
\q1
\v 7 Ko kinautolu kotoa pńď  Ľoku mamata kiate au  Ľoku nau kata manuki kiate au:  
\q2  Ľoku nau fakalili honau ngutu, mo kalokalo  Ľae  Ľulu, mo nau pehńď,   
\q1
\v 8 ‚ÄúNa Ľa ne falala kia Sihova ke ne fakamo Ľui ia:  
\q2 tuku ke ne fakamo Ľui ia, he na Ľa ne fiemńĀlie  Ľiate ia.‚ÄĚ   
\q1
\v 9 Ka ko koe ia na Ľe to Ľo au mei he manńĀva  Ľo  Ľeku fa Ľńď:  
\q2 na Ľa ke faka Ľamanaki Ľi au  Ľi he Ľeku kei  Ľi he huhu  Ľo  Ľeku fa Ľńď.   
\q1
\v 10 Na Ľe lńę au kiate koe mei he manńĀva:  
\q2 ko hoku  ĽOtua Koe talu  Ľeku ha Ľu mei he manńĀva  Ľo  Ľeku fa Ľńď.   
\q1
\v 11 ‚ÄĆ ĽOua na Ľa ke mama Ľo  Ľiate au: he  Ľoku ofi  Ľae mamahi;  
\q2 he  Ľoku  Ľikai ha taha ke tokoni.   
\q1
\v 12 Kuo kńĀpui au  Ľe he fanga pulu tangata lahi:  
\q2 kuo  ĽńĀ Ľi au  Ľe he fanga pulu tangata mńĀlohi mei Pesani.   
\q1
\v 13 Na Ľa nau fakamanga honau ngutu kiate au,  
\q2  Ľo hangńď ko e laione fekai mo ngungulu.   
\q1
\v 14 Kuo lilingi au  Ľo hangńď ko e vai,  
\q2 pea kuo homo hoku ngaahi hui kotoa pńď:  
\q1 kuo tatau hoku loto mo e pulu:  
\q2 kuo fakamolŇę ia  Ľi hoku loto fatu.   
\q1
\v 15 Kuo mŇćmoa  Ľo  Ľosi hoku mńĀlohi  Ľo hangńď ko e ipu kuo maumau;  
\q2 pea  Ľoku piki ma Ľu hoku  Ľelelo ki hoku  Ľao Ľi ngutu;  
\q2 pea kuo ke  Ľohifo au ki he efu  Ľoe mate.   
\q1
\v 16 He kuo kńĀpui au  Ľe he fanga kulńę:  
\q2 kuo  ĽńĀ Ľi au  Ľe he fakataha  Ľoe ngaahi angakovi:  
\q2 na Ľa nau hoka Ľi hoku nima mo hoku va Ľe.   
\q1
\v 17 ‚ÄĆ ĽOku ou fa Ľa lau hoku hui kotoa pńď:  
\q2  Ľoku nau mamata mo siosio pau kiate au.   
\q1
\v 18 ‚ÄĆ ĽOku nau tufa hoku ngaahi kofu  Ľiate kinautolu,  
\q2 mo fai  Ľae talotalo ki hoku pulupulu.   
\q1
\v 19 Kae Ľoua na Ľa ke mama Ľo  Ľiate au,  ĽE Sihova:  
\q2  ĽE hoku mńĀlohi, ke ke fakato Ľoto Ľo ke tokoni au.   
\q1
\v 20 Fakamo Ľui hoku laumńĀlie mei he heletńĀ;  
\q2 mo  Ľeku mo Ľui mei he mńĀlohi  Ľoe kulńę.   
\q1
\v 21 Fakamo Ľui au mei he ngutu  Ľoe laione:  
\q2 he kuo ke ongo Ľi au mei he ngaahi nifo  Ľoe fanga liimi.   
\q1
\v 22 Te u fakahńĀ ho huafa ki hoku ngaahi kńĀinga:  
\q2  Ľi he lotolotonga  Ľoe fakataha te u fakafeta Ľi kiate koe.   
\q1
\v 23 ‚Äú ĽAkimoutolu  Ľoku manavahńď kia Sihova, fakafeta Ľi kiate ia;  
\q2 faka Ľapa Ľapa kiate ia  Ľakimoutolu ko e hako  Ľo Sńďkope; pea manavahńď kiate ia,  
\q2  Ľakimoutolu kotoa pńď ko e hako  Ľo  ĽIsileli.   
\q1
\v 24 He na Ľe  Ľikai te ne manuki pe fehi Ľa ki he mamahi  Ľoe mamahi Ľia;  
\q2 pea na Ľe  Ľikai te ne fufŇę hono fofonga  Ľiate ia;  
\q2 ka  Ľi he Ľene tangi kiate ia na Ľa ne ongo Ľi.‚ÄĚ   
\q1
\v 25 ‚ÄĆ ĽE  Ľiate koe pe  Ľeku fakafeta Ľi  Ľi he fakataha lahi:  
\q2 te u fakamo Ľoni  Ľeku ngaahi fuakava  Ľi he  Ľao  Ľokinautolu  Ľoku manavahńď kiate ia.   
\q1
\v 26 ‚ÄĆ ĽE kai  Ľe he angamalŇę ke mńĀkona;  
\q2  Ľe fakafeta Ľi kia Sihova  Ľakinautolu  Ľoku kumi kiate ia:  
\q2  Ľe mo Ľui ta Ľengata homou laumńĀlie.   
\q1
\v 27 ‚ÄĆ ĽE manatu mo tafoki kia Sihova  Ľae ngaahi ngata Ľanga kotoa pńď  Ľo mńĀmani:  
\q2 pea  Ľe lotu  Ľi ho  Ľao  Ľae ngaahi fa Ľahinga kotoa pńď  Ľoe ngaahi pule Ľanga.   
\q1
\v 28 He  Ľoku  Ľo Sihova  Ľae pule Ľanga;  
\q2 pea ko e pule ia  Ľi he ngaahi pule Ľanga.   
\q1
\v 29 Ko kinautolu  Ľoku sino  Ľi mńĀmani te nau kai mo lotu:  
\q2  Ľe punou  Ľi hono  Ľao  Ľakinautolu kotoa pńď  Ľoku  Ľalu hifo ki he efu:  
\q2 pea  Ľoku  Ľikai ha taha te ne fa Ľa fakamo Ľui hono laumńĀlie  Ľo Ľona.   
\q1
\v 30 ‚ÄĆ ĽE tauhi ia  Ľe ha hako;  
\q2 pea  Ľe lau ia ko e to Ľutangata kia Sihova,   
\q1
\v 31 Te nau ha Ľu,  Ľo fakahńĀ  Ľene mńĀ Ľoni Ľoni ki ha kakai  Ľe fanau Ľi,  
\q2 ‚ÄúKuo fai  Ľe ia  Ľae me Ľa ni.‚ÄĚ   
\c 23  
\cd \it 1‚Äď6 Ko e tui  Ľa Tevita ki he  Ľalo Ľofa  Ľae  ĽOtua.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 Ko hoku tauhi  Ľa Sihova;  
\q2  Ľe  Ľikai te u masiva.   
\q1
\v 2 ‚ÄĆ ĽOku ne fakatokoto au  Ľi he ngaahi ngoue lau ma Ľui Ľui:  
\q2  Ľoku ne tataki au ki he ve Ľe vai  Ľoku tafetafemńĀlie.   
\q1
\v 3 ‚ÄĆ ĽOku ne fakamo Ľui hoku laumńĀlie:  
\q2  Ľoku ne tataki au  Ľi he ngaahi hala  Ľoe mńĀ Ľoni Ľoni koe Ľuhi ko hono huafa.   
\q1
\v 4 ‚ÄĆ ĽIo, neongo  Ľeku  Ľeve Ľeva  Ľi he tele Ľa  Ľoe malumalu  Ľoe mate,  
\q2  Ľe  Ľikai te u manavahńď ki ha kovi:  
\q2 he  Ľoku ke  Ľiate au; ko ho Ľo va Ľa  Ľakau mo ho tokotoko  Ľoku na fakafiemńĀlie Ľi au.   
\q1
\v 5 ‚ÄĆ ĽOku ke teuteu  Ľae keinanga Ľanga ma Ľaku  Ľi he  Ľao  Ľo hoku ngaahi fili:  
\q1  Ľoku ke pani  Ľaki hoku  Ľulu  Ľae lolo;  
\q2  Ľoku fonu mahuohua  Ľa  Ľeku ipu.   
\q1
\v 6 Ko e mo Ľoni  Ľe muimui  Ľiate au  Ľae lelei mo e  Ľalo Ľofa  Ľi he  Ľaho kotoa pńď  Ľo  Ľeku mo Ľui:  
\q2 pea te u nofo  Ľi he fale  Ľo Sihova  Ľo lauikuonga.   
\c 24  
\cd \it 1  ĽOku  ĽEiki  Ľae  ĽOtua ki mńĀmani. 3 Ko e kaungńĀ kolo  Ľi hono pule Ľanga fakalaumńĀlie. 7 Ko e enginaki ke ma Ľu ia.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽOku  Ľo Sihova  Ľae fonua kotoa pńď, mo hono mahu  Ľo ia;  
\q2  Ľa mńĀmani, mo kinautolu  Ľoku nofo  Ľi ai.   
\q1
\v 2 He kuo ne fokotu Ľu ia ki he ngaahi tahi,  
\q2 mo fakatu Ľuma Ľu ia ki he ngaahi vai lahi.   
\q1
\v 3 Ko hai  Ľe  Ľalu hake ki he mo Ľunga  Ľo Sihova?  
\q2 Pe ko hai  Ľe tu Ľu  Ľi hono potu mńĀ Ľoni Ľoni?   
\q1
\v 4 Ko ia  Ľoku nima ma Ľa, mo loto mńĀ Ľoni Ľoni;  
\q2  Ľaia na Ľe  Ľikai te ne hiki hono laumńĀlie ki he me Ľa va Ľinga,  
\q2 pe fuakava  Ľi he kńĀkńĀ.   
\q1
\v 5 Te ne ma Ľu  Ľe ia  Ľae tńĀpuaki meia Sihova,  
\q2 mo e mńĀ Ľoni Ľoni mei he  ĽOtua  Ľo  Ľene mo Ľui.   
\q1
\v 6 Ko e to Ľutangata eni  Ľokinautolu  Ľoku kumi kiate ia,  
\q2  Ľakinautolu  Ľoku kumi ki ho fofonga,  ĽE  ĽOtua  Ľo Sńďkope. \qs Sila.\qs*   
\q1
\v 7 Hiki hake homou  Ľulu,  Ľae ngaahi matapńĀ;  
\q2 pea ke hiki ke mńĀ Ľolunga,  Ľakimoutolu  Ľae ngaahi matapńĀ ta Ľengata;  
\q2 pea  Ľe hńĀ Ľele mai  Ľae Tu Ľi  Ľoe nńĀunau.   
\q1
\v 8 Ko hai  Ľae Tu Ľi ni  Ľoe nńĀunau?  
\q2 Ko Sihova  Ľoku mńĀlohi mo mńĀfimafi,  
\q2 ko Sihova  Ľoku mńĀlohi  Ľi he tau.   
\q1
\v 9 Hiki hake homou  Ľulu,  Ľae ngaahi matapńĀ;  
\q2  Ľio, hiki ki  Ľolunga,  Ľae ngaahi matapńĀ ta Ľengata;  
\q2 pea  Ľe hńĀ Ľele mai  Ľae Tu Ľi  Ľoe nńĀunau.   
\q1
\v 10 Ko hai  Ľae Tu Ľi ni  Ľoe nńĀunau?  
\q2 Ko Sihova  Ľoe ngaahi kautau,  
\q2 ko ia ia ko e Tu Ľi  Ľoe nńĀunau. \qs Sila.\qs*   
\c 25  
\cd \it 1 Ko e tui  Ľa Tevita  Ľi he Ľene lotu. 7  ĽOku ne kole  Ľae fakamolemole  Ľoe angahala, 16 Pea mo e tokoni  Ľi he Ľene mamahi.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE Sihova,  Ľoku ou hiki hake hoku laumńĀlie kiate koe.   
\q1
\v 2 ‚ÄĆ ĽE hoku  ĽOtua,  Ľoku ou falala kiate koe:  
\q2  Ľoua na Ľa ke tuku au ke u mńĀ,  
\q2 pea  Ľoua na Ľa fiefia hoku ngaahi fili  Ľiate au.   
\q1
\v 3 ‚ÄĆ ĽIo, ke  Ľoua na Ľa mńĀ ha tokotaha  Ľoku tatali kiate koe:  
\q2 tuku ke mńĀ  Ľakinautolu  Ľoku fai angahala ko e pau Ľu pńď.   
\q1
\v 4 FakahńĀ kiate au,  ĽE Sihova, ho ngaahi hala;  
\q2 ako kiate au ho ngaahi hńĀ Ľele Ľanga.   
\q1
\v 5 Tataki au  Ľi ho Ľo mo Ľoni, mo akonaki Ľi au:  
\q2 he ko koe ko e  ĽOtua  Ľo  Ľeku mo Ľui,  
\q2  Ľoku ou tatali kiate koe  Ľi he  Ľaho kotoa.   
\q1
\v 6 ‚ÄĆ ĽE Sihova, ke ke manatu ki ho Ľo ngaahi  Ľalo Ľofa mo ho Ľo  Ľofa mata ĽatńĀ pe;  
\q2 he  Ľoku talu mei mu Ľa ia.   
\q1
\v 7 ‚ÄĆ ĽOua na Ľa ke manatu Ľi  Ľae ngaahi angahala  Ľi he Ľeku kei si Ľi, mo  Ľeku ngaahi talangata Ľa:  
\q2 ka ke manatu kiate au,  
\q2  ĽE Sihova,  Ľo fakatatau ki ho Ľo  Ľalo Ľofa koe Ľuhi ko ho Ľo angalelei.   
\q1
\v 8 ‚ÄĆ ĽOku angalelei mo angatonu  Ľa Sihova,  
\q2 ko ia te ne akonaki Ľi ai  Ľae kau angahala  Ľi he hala.   
\q1
\v 9 Te ne tataki  Ľae angamalŇę  Ľi he fakamaau:  
\q2 te ne ako hono hala ki he angavaivai.   
\q1
\v 10 Ko e ngaahi hala kotoa pńď  Ľo Sihova ko e  Ľalo Ľofa mo e mo Ľoni  
\q2 kiate kinautolu  Ľoku tauhi  Ľene fuakava mo  Ľene ngaahi fakamo Ľoni.   
\q1
\v 11 ‚ÄĆ ĽE Sihova, ko e me Ľa  Ľi ho huafa,  
\q2 ke ke fakamolemole  Ľeku hia; he  Ľoku lahi ia.   
\q1
\v 12 Ko hai  Ľae tangata  Ľoku manavahńď kia Sihova?  
\q2 Te ne akonaki Ľi ia  Ľi he hala te ne fili.   
\q1
\v 13 ‚ÄĆ ĽE nofoma Ľu hono laumńĀlie  Ľi he lelei;  
\q2 pea  Ľe ma Ľu  Ľe hono hako  Ľae fonua.   
\q1
\v 14 Ko e finangalo fufŇę  Ľo Sihova  Ľoku  Ľiate kinautolu  Ľoku manavahńď kiate ia;  
\q2 pea te ne fakahńĀ kiate kinautolu  Ľene fuakava.   
\q1
\v 15 ‚ÄĆ ĽOku hanga atu ma Ľuaipńď hoku mata kia Sihova,  
\q2 he ko ia te ne to Ľo hoku va Ľe mei he kupenga.   
\q1
\v 16 Ke ke fofonga mai kiate au, mo ke  Ľalo Ľofa kiate au;  
\q2 he  Ľoku ou paea mo mamahi.   
\q1
\v 17 Kuo tupu  Ľo lahi  Ľae ngaahi mamahi  Ľo hoku loto;  
\q2 ke ke  Ľomi au mei he Ľeku ngaahi mamahi.   
\q1
\v 18 Ke ke  Ľafio ki hoku mahaki mo  Ľeku mamahi;  
\q2 pea fakamolemole  Ľeku angahala kotoa pńď.   
\q1
\v 19 ‚ÄĆ ĽAfio ki hoku ngaahi fili; he  Ľoku nau tokolahi;  
\q2 pea  Ľoku nau fehi Ľa kiate au  Ľi he fehi Ľa lahi.   
\q1
\v 20 Ke ke tauhi hoku laumńĀlie, mo fakamo Ľui au:  
\q2  Ľoua na Ľa ke tuku au ke u mńĀ; he  Ľoku ou falala kiate koe.   
\q1
\v 21 Ke fakamo Ľui au  Ľe he haohaoa mo e angatonu;  
\q2 he  Ľoku ou tatali kiate koe.   
\q1
\v 22 ‚ÄĆ ĽE  ĽOtua, ke ke huhu Ľi  Ľa  ĽIsileli  
\q2 mei he Ľene ngaahi mamahi kotoa pńď.   
\c 26  
\cd \it 1‚Äď12  ĽOku hŇę  Ľa Tevita ki he  ĽOtua  Ľi he Ľene  Ľilo  Ľene angatonu.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 Ke ke fakamaau au,  ĽE Sihova; he na Ľaku  Ľeve Ľeva  Ľi he Ľeku angatonu:  
\q2 na Ľaku falala foki kia Sihova; ko ia  Ľe  Ľikai ai te u hekea.   
\q1
\v 2 ‚ÄĆ ĽAhi Ľahi Ľi au,  Ľe Sihova,  Ľo  Ľilo Ľi au;  
\q2  Ľahi Ľahi Ľi hoku laumńĀlie mo hoku loto.   
\q1
\v 3 He  Ľoku  Ľi hoku  Ľao  Ľa ho Ľo  Ľalo Ľofa pea na Ľaku  Ľeve Ľeva  Ľi ho Ľo mo Ľoni.   
\q1
\v 4 Na Ľe  Ľikai te u nofo mo e kau tangata angakovi,  
\q2 pea  Ľe  Ľikai te u  Ľalu ki loto mo e kau mńĀlualoi.   
\q1
\v 5 ‚ÄĆ ĽOku ou fehi Ľa ki he fakataha  Ľoe kau fai kovi;  
\q2 pea  Ľe  Ľikai te u nofo mo e kau angahala.   
\q1
\v 6 Te u fanofano hoku nima  Ľi he mńĀ Ľoni Ľoni:  
\q2 pea  Ľe pehńď pe  Ľeku kńĀpui ho  Ľesifeilaulau,  ĽE Sihova:   
\q1
\v 7 Koe Ľuhi ke u fakahńĀ  Ľaki  Ľae le Ľo  Ľoe fakafeta Ľi,  
\q2 pea fakamatala ki ho Ľo ngaahi ngńĀue fakaofo kotoa pńď.   
\q1
\v 8 ‚ÄĆ ĽE Sihova, kuo u  Ľofa ki he nofo Ľanga  Ľo ho fale,  
\q2 mo e potu  Ľoku nofo ai  Ľa ho Ľo  Ľafio.   
\q1
\v 9 ‚ÄĆ ĽOua na Ľa ke fakataha hoku laumńĀlie mo e kau angahala,  
\q2 pe ko  Ľeku mo Ľui mo e kau tangata pani toto:   
\q1
\v 10 ‚ÄĆ ĽAkinautolu  Ľoku  Ľi honau nima  Ľae pau Ľu,  
\q2 pea  Ľoku fonu honau nima to Ľomata Ľu  Ľi he ngaahi me Ľa fakahńď.   
\q1
\v 11 Ka ko au, te u  Ľeve Ľeva  Ľi he Ľeku angatonu:  
\q2 ke ke huhu Ľi au, mo ke  Ľalo Ľofa kiate au.   
\q1
\v 12 ‚ÄĆ ĽOku tu Ľu hoku va Ľe  Ľi he potu tokamńĀlie:  
\q2  Ľi he ngaahi fakataha  Ľoe kakai te u fakafeta Ľi kia Sihova.   
\c 27  
\cd \it 1  ĽOku tokoni  Ľe Tevita  Ľene tui  Ľaki  Ľae mńĀlohi  Ľoe  ĽOtua, 4 Mo  Ľene  Ľofa ki he tauhi ki he  ĽOtua, 7 Mo  Ľene hŇę.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 Ko  Ľeku maama mo hoku fakamo Ľui  Ľa Sihova;  
\q2 te u manavahńď kia hai?  
\q2 Ko e mńĀlohi  Ľo  Ľeku mo Ľui  Ľa Sihova;  
\q2 pea te u manavahńď kia hai?   
\q1
\v 2 ‚ÄĆ ĽI he ha Ľu kiate au  Ľae kau angahala, ko hoku ngaahi fili mo e kau fakamamahi kiate au,  
\q2 ke kai  Ľo  Ľosi hoku kakano, na Ľa nau tŇękia  Ľo hinga.   
\q1
\v 3 Kapau  Ľe fakataha  Ľae kautau ke tau Ľi au,  
\q2  Ľe  Ľikai manavahńď hoku loto;  
\q2 neongo  Ľae tu Ľu mai  Ľae tau kiate au,  
\q2 te u falala pe  Ľi he me Ľa ni.   
\q1
\v 4 Ko e me Ľa  Ľe taha kuo u kole kia Sihova,  Ľaia te u kumi ki ai;  
\q2 koe Ľuhi ke u nofoma Ľu  Ľi he fale  Ľo Sihova  Ľi he  Ľaho kotoa pńď  Ľo  Ľeku mo Ľui,  
\q2 ke mamata ki he lelei  Ľo Sihova, mo fehu Ľi  Ľi hono faletapu.   
\q1
\v 5 He te ne fufŇę au  Ľi he  Ľaho  Ľoe mamahi  Ľi hono  Ľafio Ľanga:  
\q2 te ne fufŇę au  Ľi he potu lilo  Ľo hono fale fehikitaki;  
\q2 te ne fokotu Ľu au ki he funga maka.   
\q1
\v 6 Pea ko eni,  Ľe hiki ke mńĀ Ľolunga hake hoku  Ľulu ki hoku ngaahi fili  Ľoku takatakai au:  
\q2 ko ia te u  Ľohake  Ľi hono fale fehikitaki  Ľae ngaahi feilaulau  Ľae fiefia;  
\q2 te u hiva,  Ľio, te u hiva  Ľaki  Ľae fakafeta Ľi kia Sihova.   
\q1
\v 7 Ke ke ongo Ľi,  ĽE Sihova,  Ľo kau ka tangi  Ľaki hoku le Ľo:  
\q2 ke ke  Ľalo Ľofa mai foki kiate au,  Ľo talia au.   
\q1
\v 8  \add  ĽI ho Ľo folofola pehńď\add*, ‚ÄúMou kumi ki hoku fofonga;  
\q2 na Ľe pehńď leva  Ľe hoku loto kiate koe, Ko ho fofonga,  ĽE Sihova, te u kumi.‚ÄĚ   
\q1
\v 9 ‚ÄĆ ĽOua na Ľa ke fufŇę ho fofonga  Ľiate au;  
\q2  Ľoua na Ľa ke tukuange ho Ľo tamaio Ľeiki  Ľi ho houhau:  
\q2 na Ľa ke tokoni au;  
\q2  Ľoua na Ľa ke tuku au,  
\q2 pe si Ľaki au,  ĽE  ĽOtua  Ľo  Ľeku mo Ľui.   
\q1
\v 10 ‚ÄĆ ĽOka li Ľaki au  Ľe he Ľeku tamai mo  Ľeku fa Ľńď,  
\q2  Ľe to Ľo hake au  Ľe Sihova.   
\q1
\v 11 ‚ÄĆ ĽAko kiate au ho hala,  ĽE Sihova, mo tataki au  Ľi he hala  Ľilongofua, koe Ľuhi ko hoku ngaahi fili.   
\q1
\v 12 ‚ÄĆ ĽOua na Ľa ke tukuange au ki he loto  Ľo hoku ngaahi fili:  
\q2 he kuo tu Ľu hake  Ľo angatu Ľu kiate au  Ľae kau fakamo Ľoni loi,  
\q2 mo ia  Ľoku mńĀnava  Ľaki  Ľae fai kovi.   
\q1
\v 13 Ka ne  Ľikai te u tui ke u mamata  
\q2 ki he finangalo  Ľofa  Ľo Sihova  Ľi he fonua  Ľoe mo Ľui, pehńď kuo u ilifia.   
\q1
\v 14 ‚ÄĆ ĽAmanaki lelei kia Sihova:  
\q2 pea ke lototo Ľa, pea te ne fakamńĀlohi ho loto:  
\q2  Ľoku ou pehńď,  Ľamanaki lelei kia Sihova.   
\c 28  
\cd \it 1  ĽOku lotu  Ľa Tevita telia hono ngaahi fili. 6  ĽOku ne fakafeta Ľi ki he  ĽOtua. 9  ĽOku ne hŇęfia  Ľae kakai.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 Te u tangi kiate koe,  ĽE Sihova  
\q2 ko hoku makatu Ľu;  Ľoua na Ľa ke ta Ľe Ľafio Ľi au:  
\q2 telia,  Ľi ho Ľo ta Ľe Ľafio Ľi au,  
\q2 te u hoko  Ľo tatau mo kinautolu  Ľoku  Ľalu hifo ki he luo.   
\q1
\v 2 Ke ke ongo Ľi  Ľae le Ľo  Ľo  Ľeku lotu tńĀuma Ľu,  Ľo kau ka tangi kiate koe,  
\q2  Ľo kau ka hiki hake hoku nima ki ho folofola Ľanga mńĀ Ľoni Ľoni.   
\q1
\v 3 ‚ÄĆ ĽOua na Ľa ke toho au mo e kau angahala,  
\q2 pea mo kinautolu  Ľoku fai kovi,  
\q2  Ľakinautolu  Ľoku lea mńĀlie ki honau kaungńĀ Ľapi,  
\q2 ka  Ľoku  Ľi honau loto  Ľae kovi.   
\q1
\v 4 Te ke tuku kiate kinautolu  Ľo hangńď ko  Ľenau ngńĀue,  Ľo fakatatau ki he kovi  Ľo  Ľenau ngaahi faianga:  
\q2  Ľatu kiate kinautolu  Ľo hangńď ko e ngńĀue  Ľa honau nima;  Ľange kiate kinautolu honau  Ľinanga.   
\q1
\v 5 Ko e me Ľa  Ľi he Ľenau ta Ľetokanga ki he ngaahi ngńĀue  Ľa Sihova,  
\q2 mo e ngńĀue  Ľa hono nima,  
\q2 te ne faka Ľauha  Ľakinautolu, pea  Ľe  Ľikai langa hake  Ľakinautolu.   
\q1
\v 6 Fakafeta Ľi kia Sihova,  
\q2 ko e me Ľa  Ľi he Ľene ongo Ľi  Ľae le Ľo  Ľo  Ľeku lotu tńĀuma Ľu.   
\q1
\v 7 Ko hoku mńĀlohi mo hoku fakaŇę  Ľa Sihova;  
\q2 na Ľe falala kiate ia hoku loto, pea kuo tokoni Ľi au:  
\q1 ko ia  Ľoku fiefia lahi ai hoku loto;  
\q2 pea  Ľi he Ľeku hiva te u fakafeta Ľi kiate ia.   
\q1
\v 8 Ko e mńĀlohi  Ľa Sihova kiate kinautolu,  
\q2 pea ko e mńĀlohi fakamo Ľui ia  Ľo  Ľene pani.   
\q1
\v 9 Ke ke fakamo Ľui ho Ľo kakai,  
\q2 mo tńĀpuaki ho tofi Ľa:  
\q1 tauhi  Ľakinautolu foki,  
\q2 pea hiki hake  Ľakinautolu ke ta Ľengata.   
\c 29  
\cd \it 1  ĽOku enginaki Ľi  Ľe Tevita  Ľae hou Ľeiki ke nau faka Ľapa Ľapa ki he  ĽOtua, koe Ľuhi ko  Ľene mńĀfimafi, 11 Mo  Ľene malu Ľi hono kakai.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 Tuku kia Sihova,  Ľekimoutolu ko e ngaahi foha  Ľoe mńĀlohi,  
\q2 tuku kia Sihova  Ľae nńĀunau mo e mńĀfimafi.   
\q1
\v 2 Tuku kia Sihova  Ľae faka Ľapa Ľapa  Ľoku taau mo hono huafa;  
\q2 hŇę kia Sihova  Ľi he teunga matamatalelei  Ľoe mńĀ Ľoni Ľoni.   
\q1
\v 3 Ko e le Ľo  Ľo Sihova  Ľoku  Ľi  Ľolunga  Ľi he ngaahi vai:  
\q2  Ľoku mana  Ľe he  ĽOtua  Ľoe nńĀunau:  Ľoku  Ľi  Ľolunga  Ľi he ngaahi vai lahi  Ľa Sihova.   
\q1
\v 4 Ko e le Ľo  Ľo Sihova  Ľoku fonu  Ľi he mńĀlohi;  
\q2  Ľoku fonu  Ľae le Ľo  Ľo Sihova  Ľi he nńĀunau.   
\q1
\v 5 ‚ÄĆ ĽOku fesi Ľi  Ľe he le Ľo  Ľo Sihova  Ľae ngaahi sita.  
\q2  Ľio,  Ľoku fesi Ľi  Ľe Sihova  Ľae ngaahi sita  Ľo Lepanoni.   
\q1
\v 6 ‚ÄĆ ĽOku ngaohi  Ľe ia ke nau hopohopo  Ľo hangńď ko e  Ľuhiki Ľi pulu;  
\q2  Ľa Lepanoni mo Silione  Ľo hangńď ko e  Ľuhiki Ľi liimi.   
\q1
\v 7 ‚ÄĆ ĽOku vahevahe  Ľe he le Ľo  Ľo Sihova  Ľae ngaahi ulo  Ľoe afi.   
\q1
\v 8 ‚ÄĆ ĽOku lulu  Ľe he le Ľo  Ľo Sihova  Ľae toafa;  
\q2  Ľoku lulululu  Ľe Sihova  Ľae toafa  Ľo Ketesi.   
\q1
\v 9 ‚ÄĆ ĽOku fakafanau Ľi  Ľe he le Ľo  Ľo Sihova  Ľae fanga hainiti,  
\q2 pea ne fakahńĀ  Ľae ngaahi vao  Ľakau:  
\q2 pea  Ľi hono faletapu  Ľoku lea taki taha kotoa pńď ki hono nńĀunau.   
\q1
\v 10 ‚ÄĆ ĽOku nofo  Ľa Sihova ki he vai lahi;  
\q2  Ľio,  Ľoku nofo  Ľa Sihova ko e Tu Ľi  Ľo ta Ľengata.   
\q1
\v 11 ‚ÄĆ ĽE foaki  Ľe Sihova  Ľae mńĀlohi ki hono kakai;  
\q2  Ľe tńĀpuaki  Ľe Sihova  Ľa hono kakai  Ľaki  Ľae melino.   
\c 30  
\cd \it 1  ĽOku fakafeta Ľi  Ľe Tevita ki he  ĽOtua  Ľi he Ľene fakamo Ľui ia. 4  ĽOku ne enginaki Ľi  Ľae kakai kenau fakafeta Ľi ki he  ĽOtua koe Ľuhi ko  Ľene ngńĀue kiate ia.\it*  
\d Ko e Saame mo e Hiva  Ľi he hŇęfia  Ľae fale  Ľo Tevita.  
\q1
\v 1 Te u fakafeta Ľi kiate koe,  ĽE Sihova; he kuo ke hiki hake au,  
\q2 pea na Ľe  Ľikai te ke tuku ke fiefia  Ľa hoku ngaahi fili kiate au.   
\q1
\v 2 ‚ÄĆ ĽE Sihova ko hoku  ĽOtua, na Ľaku tangi kiate koe,  
\q1 pea kuo ke fakamo Ľui au.   
\q1
\v 3 ‚ÄĆ ĽE Sihova, kuo ke  Ľohake hoku laumńĀlie mei hńďtesi:  
\q2 kuo ke fakatolonga  Ľeku mo Ľui, ke  Ľoua na Ľaku  Ľalu hifo ki he luo.   
\q1
\v 4 Hiva kia Sihova,  Ľakimoutolu ko  Ľene kakai mńĀ Ľoni Ľoni,  
\q2 pea  Ľatu  Ľae fakafeta Ľi  Ľi he manatu ki he Ľene mńĀ Ľoni Ľoni.   
\q1
\v 5 He  Ľoku hangńď ko e kemo  Ľoe mata hono houhau;  
\q2  Ľoku ai  Ľae mo Ľui  Ľi he Ľene  Ľofa:  
\q1 kapau  Ľe ai ha tangi  Ľi he pŇć,  
\q2  Ľe hoko  Ľae fiefia  Ľi he pongipongi.   
\q1
\v 6 Pea  Ľi he Ľeku monŇę Ľia na Ľaku pehńď,  
\q2 ‚Äú ĽE  Ľikai te u ngaueue  Ľo lauikuonga.‚ÄĚ   
\q1
\v 7 ‚ÄĆ ĽE Sihova, kuo ke fokotu Ľuma Ľu  Ľi ho Ľo  Ľofa  Ľae mńĀlohi ki hoku mo Ľunga: na Ľa ke fufŇę ho fofonga, pea ne u mamahi ai.   
\q1
\v 8 Na Ľaku tangi kiate koe,  ĽE Sihova;  
\q2 pea ne u fai  Ľeku kole tńĀuma Ľu kia Sihova.   
\q1
\v 9 ‚ÄúKo e hńĀ hono  Ľaonga  Ľo hoku toto,  Ľo kau ka  Ľalu hifo ki he luo?  
\q2  ĽE fakafeta Ľi  Ľae efu kiate koe?  
\q2  Ľe fakahńĀ  Ľe ia ho Ľo mo Ľoni?   
\q1
\v 10 Fanongo mai,  ĽE Sihova, pea ke  Ľalo Ľofa mai kiate au:  
\q2  ĽE Sihova, ke ke hoko ko e tokoni kiate au.‚ÄĚ   
\q1
\v 11 Kuo ke liliu kiate au  Ľeku tangi ko e me Ľe hopohopo:  
\q2 kuo ke vete hoku tauanga Ľa, pea fakavala  Ľaki au  Ľae fiefia;   
\q1
\v 12 Koe Ľuhi ke hiva  Ľaki  Ľe hoku  Ľelelo  Ľae fakafeta Ľi kiate koe, pea  Ľoua na Ľa longo pńď.  
\q2  ĽE Sihova ko hoku  ĽOtua,  
\q1 te u  Ľatu  Ľae fakafeta Ľi kiate koe  Ľo ta Ľengata.   
\c 31  
\cd \it 1  ĽOku fakahńĀ  Ľe Tevita  Ľene falala ki he  ĽOtua, pea ne kole ke ne tokoni ia. 7  ĽOku ne fiefia  Ľi he Ľene  Ľalo Ľofa. 9  ĽOku ne lotu  Ľi he Ľene mamahi. 19  ĽOku ne fakafeta Ľi ki he  ĽOtua koe Ľuhi ko  Ľene angalelei.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽOku ou falala kiate koe,  ĽE Sihova;  
\q2  Ľoua na Ľa ke tuku au ke u mńĀ:  
\q2 fakamo Ľui au  Ľi ho Ľo mńĀ Ľoni Ľoni.   
\q1
\v 2 Fakatokanga Ľi ho telinga kiate au;  
\q2 ke vave ho Ľo fakamo Ľui au:  
\q1 ke ke  Ľiate au ko e maka mńĀlohi,  
\q2 ko e fale hŇęfanga ke fakamo Ľui au.   
\q1
\v 3 He ko koe ko hoku makatu Ľu mo  Ľeku kolo:  
\q2 ko ia, ko e me Ľa  Ľi ho huafa ke ke tataki au,  Ľo fakahinohino au.   
\q1
\v 4 Toho au mei he kupenga kuo nau  Ľa Ľau fakafufŇę kiate au:  
\q2 he ko koe ko hoku mńĀlohi.   
\q1
\v 5 ‚ÄĆ ĽOku ou tuku atu hoku laumńĀlie ki ho nima:  
\q2 kuo ke huhu Ľi au,  
\q2  ĽE Sihova ko e  ĽOtua  Ľoe mo Ľoni.   
\q1
\v 6 Na Ľaku fehi Ľa kiate kinautolu  Ľoku tokanga ki he ngaahi me Ľa va Ľinga loi pńď:  
\q2 ka  Ľoku ou falala kia Sihova.   
\q1
\v 7 Te u fiefia mo nekeneka  Ľi ho Ľo  Ľalo Ľofa:  
\q2 he kuo ke tokanga ki he Ľeku mamahi;  
\q2 kuo ke  Ľilo Ľi hoku laumńĀlie  Ľi he ngaahi mamahi;   
\q1
\v 8 Pea na Ľe  Ľikai te ke tńĀpuni au  Ľi he nima  Ľoe fili:  
\q2 kuo ke fokotu Ľu hoku va Ľe  Ľi he potu  Ľata ĽatńĀ lahi.   
\q1
\v 9 ‚ÄĆ ĽAlo Ľofa mai kiate au,  ĽE Sihova, he  Ľoku ou mo Ľua  Ľi he mamahi:  
\q2 kuo  Ľauha hoku mata  Ľi he tangi,  
\q2  Ľio, ko hoku laumńĀlie mo hoku kete.   
\q1
\v 10 He kuo  Ľosi  Ľeku mo Ľui  Ľi he tangi,  
\q2 mo hoku ngaahi ta Ľu  Ľi he mafulu:  
\q1 kuo faka Ľa Ľau ke  Ľosi hoku mńĀlohi ko e me Ľa  Ľi he Ľeku hia,  
\q2 pea kuo  Ľauha hoku ngaahi hui.   
\q1
\v 11 Ko e manuki Ľanga au  Ľo hoku ngaahi fili kotoa pńď, kae  ĽńĀsili pe ki hoku ngaahi kaungńĀ Ľapi,  
\q2 pea ko e ilifia Ľanga  Ľo hoku kaume Ľa:  
\q2 ko kinautolu na Ľe mamata kiate au  Ľi tua ĽńĀ na Ľa nau hola  Ľiate au.   
\q1
\v 12 Kuo fakangalongalo Ľi au mei he loto  Ľo hangńď ko e tangata kuo mate:  
\q2 kuo u tatau mo e ipu kuo maumau.   
\q1
\v 13 He na Ľaku fanongo ki he lau Ľikovi  Ľe he tokolahi: na Ľe  Ľi he potu kotoa pńď  Ľae manavahńď:  
\q2 lolotonga  Ľenau fakakaukau fakataha kiate au,  
\q2 na Ľa nau loto ke to Ľo  Ľeku mo Ľui.   
\q1
\v 14 Ka na Ľaku falala kiate koe,  ĽE Sihova:  
\q2 na Ľaku pehńď, Ko koe ko hoku  ĽOtua.   
\q1
\v 15 Ko hoku ngaahi kuonga  Ľoku  Ľi ho nima:  
\q2 ke ke fakahaofi au mei he nima  Ľo hoku ngaahi fili, pea mo kinautolu  Ľoku fakatanga Ľi au.   
\q1
\v 16 Tuku ke ulo mai ho fofonga ki ho Ľo tamaio Ľeiki:  
\q2 fakamo Ľui au koe Ľuhi ko ho Ľo  Ľalo Ľofa.   
\q1
\v 17 ‚ÄĆ ĽOua na Ľa ke tuku au ke u mńĀ,  Ľe Sihova; he na Ľaku ui kiate koe:  
\q2 tuku ke mńĀ  Ľae kau angahala,  
\q2 tuku ke nau longo pńď  Ľi he fa Ľitoka.   
\q1
\v 18 Tuku ke fakalongo pńď  Ľae ngaahi loungutu loi;  
\q2  Ľaia  Ľoku lea  Ľaki  Ľae me Ľa fakamamahi ki he kau mńĀ Ľoni Ľoni  Ľi he fielahi mo e manuki.   
\q1
\v 19 ‚ÄĆ ĽOku fńďfńď hono lahi  Ľo ho Ľo angalelei,  
\q2  Ľaia kuo ke hilifaki ma Ľanautolu  Ľoku manavahńď kiate koe;  
\q2  Ľaia kuo ke ngaohi ma Ľanautolu  Ľoku falala kiate koe  Ľi he  Ľao  Ľoe ngaahi foha  Ľoe tangata!   
\q1
\v 20 Te ke fufŇę  Ľakinautolu  Ľi he potu lilo  Ľo ho fofonga mei he fielahi  Ľae tangata:  
\q2 te ke tauhi fakafufŇę pe  Ľakinautolu  Ľi ha  Ľafio Ľanga mei he fakakikihi  Ľoe ngaahi  Ľelelo.   
\q1
\v 21 Fakafeta Ľi kia Sihova:  
\q2 he kuo ne fakahńĀ kiate au  Ľene angalelei fakaofo  Ľi he kolo mńĀlohi.   
\q1
\v 22 He na Ľaku pehńď  Ľi he Ľeku to Ľoto Ľo, ‚Äúkuo motuhi au mei he  Ľao  Ľo ho fofonga:‚ÄĚ  
\q2 ka na Ľa ke ongo Ľi  Ľae le Ľo  Ľo  Ľeku ngaahi lotu tńĀuma Ľu  Ľi he Ľeku tangi kiate koe.   
\q1
\v 23 Mou  Ľofa kia Sihova,  Ľakimoutolu ko  Ľene kakai mńĀ Ľoni Ľoni kotoa pńď:  
\q2 he  Ľoku tauhi  Ľe Sihova  Ľae kau angatonu,  
\q2 pea  Ľoku ne totongi lahi ki he kau fai fakafielahi.   
\q1
\v 24 Ke mou lototo Ľa, pea te ne fakamńĀlohi homou loto,  
\q2  Ľakimoutolu kotoa pńď  Ľoku  Ľamanaki lelei kia Sihova.   
\c 32  
\cd \it 1  ĽOku tu Ľu  Ľae monŇę Ľia  Ľi he fakamolemole  Ľoe angahala. 3  ĽOku tupu  Ľae fiemńĀlie ki he loto  Ľi he vete  Ľae angahala. 8  ĽOku tupu  Ľae fiefia  Ľi he ngaahi tala Ľofa  Ľae  ĽOtua.\it*  
\d Ko e Saame akonaki  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽOku monŇę Ľia ia  Ľaia kuo fakamolemole  Ľa  Ľene talangata Ľa, pea kuo  Ľufi Ľufi  Ľene angahala.   
\q1
\v 2 ‚ÄĆ ĽOku monŇę Ľia  Ľae tangata  Ľaia  Ľoku  Ľikai lau ki ai  Ľe Sihova ha hia,  
\q2 pea  Ľoku  Ľikai ha kńĀkńĀ  Ľi hono laumńĀlie.   
\q1
\v 3 ‚ÄĆ ĽI he Ľeku fakalongo pńď, na Ľe faka Ľa Ľau  Ľo motu Ľa hoku ngaahi hui  Ľi he Ľeku tangi  Ľi he  Ľaho kotoa.   
\q1
\v 4 He na Ľe mamafa ho nima kiate au  Ľi he  Ľaho mo e pŇć:  
\q2 na Ľe liliu hoku huhu Ľa ko e la ĽńĀina  Ľoe fa Ľahita Ľu mafana. \qs Sila.\qs*   
\q1
\v 5 Na Ľaku vete  Ľeku angahala kiate koe,  
\q2 pea na Ľe  Ľikai te u fufŇę  Ľeku hia.  
\q2 Na Ľaku pehńď, te u vete  Ľeku ngaahi talangata Ľa kia Sihova:  
\q2 pea na Ľa ke fakamolemole  Ľae hia  Ľo  Ľeku angahala. \qs Sila.\qs*   
\q1
\v 6 Ko ia  Ľe lotu ai kiate koe  Ľaia kotoa pńď  Ľoku anga faka Ľotua  Ľi he kuonga  Ľe  Ľilo Ľi ai koe:  
\q2 ko e mo Ľoni  Ľi he  Ľoho mai  Ľoe ngaahi vai lahi  Ľe  Ľikai tenau a Ľu  Ľo ofi kiate ia.   
\q1
\v 7 Ko koe ko hoku toitoi Ľanga;  
\q2 te ke fakamo Ľui au mei he mamahi;  
\q2 pea te ke kńĀpui  Ľaki au  Ľae ngaahi hiva  Ľoe fakamo Ľui. \qs Sila.\qs*   
\q1
\v 8 Ko au te u fakapoto Ľi koe mo akonaki Ľi koe  Ľi he hala  Ľaia te ke  Ľalu ai:  
\q2 te u fakahinohino koe  Ľaki hoku mata.   
\q1
\v 9 ‚ÄĆ ĽOua na Ľa mou hangńď ko e hoosi mo e miuli,  Ľoku masiva  Ľi he  Ľilo:  
\q2  Ľaia  Ľoku ta Ľofi  Ľaki honau ngutu  Ľae ukamea mo e no Ľo, koe Ľuhi ke nau ha Ľu  Ľo ofi kiate koe.   
\q1
\v 10 ‚ÄĆ ĽE hoko  Ľae ngaahi mamahi lahi ki he kakai angakovi:  
\q2 ka ko ia  Ľoku falala kia Sihova,  Ľe kńĀpui  Ľaki ia  Ľae  Ľalo Ľofa.   
\q1
\v 11 Mou fiefia  Ľia Sihova, pea nekeneka,  Ľakimoutolu  Ľoku mńĀ Ľoni Ľoni:  
\q2 pea kalanga  Ľi he fiefia,  Ľakimoutolu kotoa pńď  Ľoku angatonu  Ľi loto.   
\c 33  
\cd \it 1  ĽOku totonu ke fakafeta Ľi ki he  ĽOtua  Ľi he Ľene angalelei, 6 Mo  Ľene mńĀfimafi, 12 Pea mo  Ľene pule. 20  ĽOku totonu ke falala ki he  ĽOtua.\it*  
\q1
\v 1 Fiefia  Ľia Sihova,  Ľakimoutolu  Ľoku mńĀ Ľoni Ľoni:  
\q2 he  Ľoku taau mo e angatonu  Ľae fakafeta Ľi.   
\q1
\v 2 Fakafeta Ľi kia Sihova  Ľaki  Ľae ha Ľape:  
\q2 hiva kiate ia  Ľaki  Ľae saliteli  Ľoku filo  Ľe hongofulu.   
\q1
\v 3 Hiva kiate ia  Ľi he hiva fo Ľou;  
\q2 tńĀ ke mńĀlie mo le Ľo lahi.   
\q1
\v 4 He ko e folofola  Ľa Sihova  Ľoku totonu;  
\q2 pea  Ľoku fai  Ľene ngaahi ngńĀue kotoa pńď  Ľi he mo Ľoni.   
\q1
\v 5 ‚ÄĆ ĽOku  Ľofa ia ki he mńĀ Ľoni Ľoni mo e fakamaau:  
\q2  Ľoku fonu  Ľa mńĀmani  Ľi he  Ľalo Ľofa  Ľa Sihova.   
\q1
\v 6 Na Ľe ngaohi  Ľe he folofola  Ľa Sihova  Ľae ngaahi langi;  
\q2 mo honau nńĀunau kotoa pńď  Ľe he mńĀnava  Ľo hono fofonga.   
\q1
\v 7 ‚ÄĆ ĽOku ne tńĀnaki fakataha  Ľae vai  Ľoe tahi  Ľo hangńď ko e tafungofunga:  
\q2  Ľoku ne fa Ľoaki  Ľae moana  Ľi he ngaahi feleoko.   
\q1
\v 8 Ke manavahńď  Ľa mńĀmani kotoa pńď kia Sihova:  
\q2 ke malu Ľia  Ľae kakai kotoa pńď  Ľo mńĀmani kiate ia.   
\q1
\v 9 He na Ľe folofola ia, pea hoko leva;  
\q2 na Ľa ne fekau, pea tu Ľuma Ľu ia.   
\q1
\v 10 ‚ÄĆ ĽOku iku Ľi  Ľe Sihova  Ľae fakakaukau  Ľae hiteni:  
\q2  Ľoku ne fakata Ľe Ľaonga Ľi  Ľae ngaahi tu Ľutu Ľuni  Ľae kakai.   
\q1
\v 11 Ko e akonaki  Ľa Sihova  Ľoku tu Ľuma Ľu  Ľo ta Ľengata,  
\q2 mo e ngaahi mahalo  Ľo hono finangalo ki he to Ľutangata kotoa pńď.   
\q1
\v 12 ‚ÄĆ ĽOku monŇę Ľia  Ľae pule Ľanga ko ia  Ľoku  ĽOtua  Ľaki  Ľa Sihova;  
\q2 pea mo e kakai kuo ne fili ko e tofi Ľa  Ľo Ľona.   
\q1
\v 13 ‚ÄĆ ĽOku  Ľafio  Ľa Sihova mei he langi;  
\q2  Ľoku ne vakai ki he ngaahi foha  Ľoe tangata.   
\q1
\v 14 Mei he potu  Ľo hono  Ľafio Ľanga  Ľoku ne  Ľafio Ľi  Ľae kakai kotoa pńď  Ľo mńĀmani.   
\q1
\v 15 ‚ÄĆ ĽOku ne ngaohi honau loto kotoa pńď;  
\q2  Ľoku ne tokanga ki he Ľenau ngńĀue kotoa pńď.   
\q1
\v 16 ‚ÄĆ ĽOku  Ľikai ha tu Ľi  Ľoku mo Ľui  Ľi he fu Ľu tokolahi  Ľoe kautau:  
\q2 pea  Ľoku  Ľikai haohaofaki  Ľae tangata mńĀlohi  Ľe he mńĀlohi lahi.   
\q1
\v 17 Ko e me Ľa va Ľinga  Ľae hoosi ki he fakamo Ľui:  
\q2 pea  Ľe  Ľikai te ne fakamo Ľui ha tokotaha  Ľi he Ľene mńĀlohi lahi.   
\q1
\v 18 Vakai, ko e fofonga  Ľo Sihova  Ľoku  Ľiate kinautolu  Ľoku manavahńď kiate ia,  
\q2  Ľio, kiate kinautolu  Ľoku manavahńď lelei ki he Ľene  Ľalo Ľofa;   
\q1
\v 19 Ke fakahaofi honau laumńĀlie mei he mate,  
\q2 pea ke fakamo Ľui  Ľakinautolu  Ľi he honge.   
\q1
\v 20 ‚ÄĆ ĽOku tatali hotau laumńĀlie kia Sihova:  
\q2 ko hotau tokoni ia mo hotau fakaŇę.   
\q1
\v 21 Koe Ľuhi  Ľe fiefia hotau loto  Ľiate ia,  
\q2 he  Ľoku tau falala ki hono huafa mńĀ Ľoni Ľoni.   
\q1
\v 22 ‚ÄĆ ĽE Sihova, ke  Ľiate kimautolu  Ľa ho Ľo  Ľalo Ľofa,  
\q2  Ľo hangńď ko  Ľemau  Ľamanaki lelei kiate koe.   
\c 34  
\cd \it 1  ĽOku fakafeta Ľi  Ľa Tevita ki he  ĽOtua, pea ne enginaki Ľi  Ľae kakai ke fai ia. 8  ĽOku monŇę Ľia  Ľakinautolu  Ľoku falala ki he  ĽOtua. 11  ĽOku ne enginaki ke manavahńď ki he  ĽOtua. 15 Ko e lelei  Ľoku  Ľi he mńĀ Ľoni Ľoni.\it*  
\d Ko e Saame  Ľa Tevita,  Ľi he Ľene liliu  Ľene tŇć Ľonga  Ľi he  Ľao  Ľo  ĽApimeleki;  Ľaia na Ľa ne kapusi ia, pea  Ľalu ia  Ľo hao.  
\q1
\v 1 Te u fakafeta Ľi kia Sihova  Ľi he kuonga kotoa pńď:  
\q2  Ľe tu Ľuma Ľu pe  Ľene fakafeta Ľi  Ľi hoku ngutu.   
\q1
\v 2 ‚ÄĆ ĽE vikiviki hoku laumńĀlie  Ľia Sihova:  
\q2  Ľe fanongo ki ai  Ľae kakai angavaivai, pea fiefia ai.   
\q1
\v 3 Ketau fai mo au ke hapai hake  Ľa Sihova,  
\q2 pea ketau fakaongoongolelei fakataha hono huafa.   
\q1
\v 4 Na Ľaku kumi kia Sihova, pea ne ongo Ľi au,  
\q2  Ľo ne fakamo Ľui au mei he Ľeku manavahńď kotoa pńď.   
\q1
\v 5 Na Ľa nau vakai kiate ia, pea mńĀmangia ai:  
\q2 pea na Ľe  Ľikai mńĀ ai honau mata.   
\q1
\v 6 Na Ľe tangi  Ľae tangata masiva ni, pea na Ľe ongo Ľi ia  Ľe Sihova,  
\q2  Ľo ne fakamo Ľui ia mei he Ľene mamahi kotoa pńď.   
\q1
\v 7 ‚ÄĆ ĽOku nofo  Ľae  ĽńĀngelo  Ľa Sihova  Ľo takatakai  Ľakinautolu  Ľoku manavahńď kiate ia,  
\q2  Ľo ne fakamo Ľui  Ľakinautolu.   
\q1
\v 8 Mou kamata  Ľo vakai  Ľoku lelei  Ľa Sihova:  
\q2  Ľoku monŇę Ľia  Ľae tangata ko ia  Ľoku falala kiate ia.   
\q1
\v 9 Ke manavahńď kia Sihova,  Ľakimoutolu ko  Ľene kau mńĀ Ľoni Ľoni:  
\q2 he  Ľoku  Ľikai ha masiva kiate kinautolu  Ľoku manavahńď kiate ia.   
\q1
\v 10 ‚ÄĆ ĽOku masiva  Ľae fanga laione mui, mo fiekaia:  
\q2 ka ko kinautolu  Ľoku kumi kia Sihova  Ľe  Ľikai te nau masiva  Ľi ha me Ľa lelei  Ľe taha.   
\q1
\v 11 Ha Ľu,  Ľakimoutolu ko e fńĀnau,  Ľo fanongo kiate au:  
\q2 te u ako kiate kimoutolu  Ľae manavahńď kia Sihova.   
\q1
\v 12 Ko hai ha tangata  Ľoku holi ke mo Ľui,  
\q2  Ľo manako ki he ngaahi  Ľaho lahi, koe Ľuhi ke ne mamata ai ki he lelei?   
\q1
\v 13 Ta Ľofi ho  Ľelelo mei he kovi,  
\q2 mo ho loungutu mei he lea kńĀkńĀ.   
\q1
\v 14 Afe mei he kovi, mo ke fai lelei;  
\q2 kumi ki he melino, pea tuli ki ai.   
\q1
\v 15 ‚ÄĆ ĽOku  Ľafio ma Ľu  Ľae fofonga  Ľo Sihova ki he kakai mńĀ Ľoni Ľoni,  
\q2 pea  Ľoku ongo Ľi  Ľe hono telinga  Ľenau tangi.   
\q1
\v 16 ‚ÄĆ ĽOku houhau  Ľae fofonga  Ľo Sihova kiate kinautolu  Ľoku fai kovi,  
\q2 ke motuhi honau fakamanatu Ľi mei mńĀmani.   
\q1
\v 17 ‚ÄĆ ĽOku tangi  Ľae mńĀ Ľoni Ľoni, pea ongo Ľi  Ľe Sihova,  
\q2  Ľo ne fakamo Ľui  Ľakinautolu mei he Ľenau ngaahi mamahi kotoa pńď.   
\q1
\v 18 ‚ÄĆ ĽOku ofi  Ľa Sihova kiate kinautolu  Ľoku loto mafesi;  
\q2  Ľoku ne fakamo Ľui  Ľakinautolu  Ľoku laumńĀlie mafŇćfoa.   
\q1
\v 19 ‚ÄĆ ĽOku lahi  Ľae ngaahi mamahi  Ľoe mńĀ Ľoni Ľoni:  
\q2 ka  Ľoku fakamo Ľui ia mei ai kotoa pńď  Ľe Sihova.   
\q1
\v 20 ‚ÄĆ ĽOku ne tauhi hono ngaahi hui kotoa pńď:  
\q2  Ľe  Ľikai mafesi ha taha.   
\q1
\v 21 ‚ÄĆ ĽE fakapoongi  Ľe he kovi  Ľae kau angahala:  
\q2 pea ko kinautolu  Ľoku fehi Ľa ki he kau mńĀ Ľoni Ľoni te nau mala Ľia.   
\q1
\v 22 ‚ÄĆ ĽOku huhu Ľi  Ľe Sihova  Ľae laumńĀlie  Ľo  Ľene kau tamaio Ľeiki:  
\q2 pea  Ľe  Ľikai mala Ľia ha tokotaha  Ľokinautolu  Ľoku falala kiate ia.   
\c 35  
\cd \it 1  ĽOku lotu  Ľa Tevita ke mo Ľui ia, kae maveuveu hono ngaahi fili. 11  ĽOku ne lńĀunga ki he Ľenau fai ta Ľetotonu. 22 Ko ia  Ľoku ne kole ki he  ĽOtua koe Ľuhi ko kinautolu.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 Ke ke langomaki Ľi au,  ĽE Sihova, telia  Ľakinautolu  Ľoku fakatanga Ľi au:  
\q2 ke ke tau Ľi  Ľakinautolu  Ľoku nau tau Ľi au.   
\q1
\v 2 To Ľo  Ľae fakaŇę mo e pńĀ,  
\q2 pea tu Ľuhake ko hoku tokoni.   
\q1
\v 3 Unuhi mai foki  Ľae tao,  Ľo tńĀpuni  Ľae hala kiate kinautolu  Ľoku fakatanga Ľi au:  
\q2 pea tala ki hoku laumńĀlie, ‚Äúko au ko ho fakamo Ľui.‚ÄĚ   
\q1
\v 4 Tuku ke puputu Ľu mo mńĀ  Ľakinautolu  Ľoku kumi ki hoku laumńĀlie:  
\q2 tuku ke fakafoki ki mui mo ilifia  Ľakinautolu  Ľoku puleaki Ľi au.   
\q1
\v 5 Tuku ke nau hangńď ko e kafukafu Ľi  Ľakau  Ľi he  Ľao  Ľoe matangi:  
\q2 pea tuku ke tuli  Ľakinautolu  Ľe he  ĽńĀngelo  Ľa Sihova.   
\q1
\v 6 Tuku ke fakapo Ľuli honau hala pea hekeheke:  
\q2 pea ke fakatanga  Ľakinautolu  Ľe he  ĽńĀngelo  Ľa Sihova.   
\q1
\v 7 He kuo nau  Ľa Ľau fakafufŇę  Ľi he luo honau kupenga kiate au ta Ľehano Ľuhinga;  
\q2 kuo nau keli  Ľae luo ki hoku laumńĀlie ta Ľehano Ľuhinga.   
\q1
\v 8 Ke hoko  Ľae mala Ľia kiate ia fakafokifńĀ pe;  
\q2 pea ko e kupenga  Ľo Ľona  Ľaia kuo ne  Ľa Ľau fufŇę tuku ke mo Ľua ai ia:  
\q2 tuku ia ke tŇć ki he mala Ľia totonu ko ia.   
\b  
\q1
\v 9 Pea  Ľe fiefia hoku laumńĀlie  Ľia Sihova:  
\q2  Ľe nekeneka ia  Ľi he Ľene fakamo Ľui.   
\q1
\v 10 ‚ÄĆ ĽE pehńď  Ľe hoku ngaahi hui kotoa pńď, ‚Äú ĽE Sihova, ko hai  Ľoku hangńď ko koe,  
\q2  Ľa koe  Ľoku ke fakahaofi  Ľae masiva meiate ia  Ľoku mńĀlohi lahi  Ľiate ia,  
\q2  Ľio,  Ľae masiva mo e paea meiate ia  Ľoku ne fakamńĀlohi Ľi ia?‚ÄĚ   
\q1
\v 11 Na Ľe tu Ľu hake  Ľae kau fakamo Ľoni loi;  
\q2 na Ľa nau tuku kiate au  Ľae ngaahi me Ľa na Ľe  Ľikai te u  Ľilo.   
\q1
\v 12 Na Ľa nau totongi kovi ki he Ľeku lelei ke fakamasiva Ľi hoku laumńĀlie.   
\q1
\v 13 Ka ko au, na Ľaku kofu Ľaki  Ľae tauanga Ľa,  Ľi honau mahaki:  
\q2 na Ľaku fakavaivai hoku laumńĀlie  Ľi he  Ľaukai;  
\q2 pea na Ľe foki mai  Ľeku lotu ki hoku fatafata.   
\q1
\v 14 Na Ľaku fai  Ľo hangńď ko hoku kńĀinga ia, pe ko hoku tokoua:  
\q2 na Ľaku tulolo hifo fakamamahi pńď,  Ľo hangńď ko e tokotaha  Ľoku tangi koe Ľuhi ko  Ľene fa Ľńď.   
\q1
\v 15 Ka  Ľi he Ľeku tu ĽutńĀmaki na Ľa nau fiefia,  Ľonau fakakńĀtoa  Ľakinautolu:  
\q2  Ľio, na Ľe fakataha  Ľakinautolu  Ľae kakai fa Ľa tńĀ  Ľo tu Ľu kiate au, pea na Ľe  Ľikai te u  Ľiloa;  
\q2 na Ľa nau haehae, pea na Ľe  Ľikai longo pńď:   
\q1
\v 16 Na Ľa nau fakalili honau nifo kiate au,  
\q2 mo e kau mńĀlualoi  Ľoku manuki  Ľi he ngaahi kńĀtoanga.   
\q1
\v 17 ‚ÄĆ ĽE Sihova,  Ľe fńďfńď hono fuoloa mo ho Ľo  Ľafio ki ai?  
\q2 Fakamo Ľui hoku laumńĀlie mei he Ľenau ngaahi fakamala Ľia,  
\q2 mo  Ľeku mo Ľui mei he fanga laione.   
\q1
\v 18 Te u  Ľatu  Ľae fakafeta Ľi kiate koe  Ľi he fakataha lahi:  
\q2 te u fakaongoongolelei koe  Ľi he  Ľao  Ľoe kakai lahi.   
\q1
\v 19 ‚ÄĆ ĽOua na Ľa tuku ke fiefia kiate au  Ľakinautolu kuo hoko noa pńď ko hoku fili:  
\q2 pea  Ľoua na Ľa tuku ke lalama honau mata  Ľakinautolu  Ľoku fehi Ľa kiate au ta Ľehano Ľuhinga.   
\q1
\v 20 He  Ľoku  Ľikai te nau lea lelei:  
\q2 ka  Ľoku nau fakatupu  Ľae ngaahi me Ľa kńĀkńĀ kiate kinautolu  Ľoku nofo fiemńĀlie  Ľi he fonua.   
\q1
\v 21 ‚ÄĆ ĽIo, kuo nau fakamanga honau ngutu  Ľo lahi kiate au,  
\q2  Ľonau pehńď, ‚ÄúHa ha, kuo mamata ki ai homau mata.‚ÄĚ   
\q1
\v 22 Kuo ke  Ľafio Ľi eni,  ĽE Sihova:  Ľoua na Ľa ke fakalongo pńď:  
\q2  ĽE Sihova,  Ľoua na Ľa ke mama Ľo  Ľiate au.   
\q1
\v 23 ‚ÄĆ ĽE hoku  ĽOtua mo hoku  ĽEiki, ke ke tu Ľu hake,  
\q2 mo ke  ĽńĀ ki hoku fakamaau,  Ľio, ki hoku langomaki Ľi.   
\q1
\v 24 ‚ÄĆ ĽE Sihova ko hoku  ĽOtua, ke ke fakamaau au  Ľo hangńď ko  Ľeku mńĀ Ľoni Ľoni;  
\q2 pea ke  Ľoua te nau fiefia kiate au.   
\q1
\v 25 ‚ÄĆ ĽOua na Ľa pehńď  Ľekinautolu  Ľi honau loto, ‚ÄúHa, ko homau loto ia:‚ÄĚ  
\q2  Ľoua te nau pehńď, ‚ÄúKuo tau folo hifo ia.‚ÄĚ   
\q1
\v 26 Tuku ke mńĀ mo manavahńď fakataha  Ľakinautolu  Ľoku fiefia  Ľi hoku lavea:  
\q2 tuku ke kofu Ľaki  Ľae mńĀ mo e ta Ľefaka Ľapa Ľapa  Ľakinautolu  Ľoku fai fakafiefielahi kiate au.   
\q1
\v 27 Tuku ke kalanga fakafiefia, mo nekeneka,  Ľakinautolu  Ľoku loto lelei ki he Ľeku mńĀ Ľoni Ľoni:  
\q2  Ľio, tuku ke nau lea pehńď ma Ľuaipńď, ‚ÄúKe ongoongolelei  Ľa Sihova,  
\q2  Ľaia  Ľoku fiemńĀlie  Ľi he monŇę Ľia  Ľa  Ľene tamaio Ľeiki.‚ÄĚ   
\q1
\v 28 Pea  Ľe lea  Ľa hoku  Ľelelo ki ho Ľo mńĀ Ľoni Ľoni mo ho ongoongolelei  Ľi he  Ľaho kotoa.   
\c 36  
\cd \it 1 Ko e kovi  Ľae kakai angahala. 5 Ko hono lelei lahi  Ľoe  Ľalo Ľofa  Ľae  ĽOtua. 10  ĽOku lotu  Ľa Tevita ke ma Ľu  Ľae  Ľofa  Ľe he fńĀnau  Ľae  ĽOtua.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita ko e tamaio Ľeiki  Ľa Sihova.  
\q1
\v 1 ‚ÄĆ ĽOku lea  Ľae talangata Ľa  Ľae angakovi ki hoku loto,  
\q2 ‚Äú Ľoku  Ľikai ha manavahńď ki he  ĽOtua  Ľi hono  Ľao.‚ÄĚ   
\q1
\v 2 He  Ľoku ne fakaholoholo Ľi  Ľe ia ia  Ľi hono  Ľao,  
\q2 ke  Ľoua ke hoko  Ľo hńĀ mai  Ľae kovi  Ľo  Ľene hia.   
\q1
\v 3 Ko e ngaahi lea  Ľa hono ngutu ko e kovi mo e kńĀkńĀ:  
\q2 kuo tuku  Ľe ia  Ľene poto mo e fai lelei.   
\q1
\v 4 ‚ÄĆ ĽOku ne fifili ki he pau Ľu  Ľi hono mohenga;  
\q2  Ľoku ne fokotu Ľu  Ľe ia ia  Ľi he hala  Ľoku  Ľikai lelei;  
\q2  Ľoku  Ľikai te ne fehi Ľa ki he kovi.   
\q1
\v 5 Ko ho Ľo  Ľalo Ľofa,  ĽE Sihova,  Ľoku  Ľi he ngaahi langi;  
\q2 pea  Ľoku a Ľu hake ho Ľo angatonu ki he ngaahi  Ľao.   
\q1
\v 6 Ko ho Ľo mńĀ Ľoni Ľoni  Ľoku hangńď ko e ngaahi mo Ľunga  Ľoe  ĽOtua;  
\q2 ko ho Ľo ngaahi fakamaau ko e fu Ľu moana;  
\q2  ĽE Sihova,  Ľoku ke fakamo Ľui  Ľae tangata mo e manu.   
\q1
\v 7 ‚ÄĆ ĽE  ĽOtua, hono  Ľikai mahu Ľinga fau  Ľa ho Ľo  Ľalo Ľofa!  
\q2 Ko ia  Ľoku falala ai  Ľae fńĀnau  Ľae tangata ki he malu  Ľo ho kapakau.   
\q1
\v 8 Te nau fonu lahi  Ľi he mahu lelei  Ľo ho fale;  
\q2 pea te ke fakainu  Ľakinautolu  Ľi he vaitafe  Ľo ho Ľo fiemńĀlie.   
\q1
\v 9 He  Ľoku  Ľiate koe  Ľae matavai  Ľoe mo Ľui:  
\q2 temau mamata  Ľi ho Ľo maama ki he maama.   
\q1
\v 10 Ke tu Ľuma Ľu pe ho Ľo  Ľalo Ľofa kiate kinautolu  Ľoku nau  Ľilo koe;  
\q2 mo ho Ľo mńĀ Ľoni Ľoni ki he angatonu  Ľi loto.   
\q1
\v 11 ‚ÄĆ ĽOua na Ľa hoko kiate au  Ľae va Ľe  Ľoe laukau,  
\q2 pea  Ľoua na Ľa hiki au  Ľe he nima  Ľoe angakovi.   
\q1
\v 12 Kuo hinga  Ľi ai  Ľae kau fai kovi: kuo lńę ki lalo  Ľakinautolu,  
\q2 pea  Ľe  Ľikai te nau fa Ľa tu Ľu hake.   
\c 37  
\cd \it 1‚Äď40  ĽOku ako  Ľe Tevita ki he fa Ľa kńĀtaki mo e tui ki he  ĽOtua, koe Ľuhi ko e ngaahi me Ľa kehekehe  Ľoku  Ľi he angatonu mo e angahala.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽOua na Ľa ke fakamamahi Ľi koe koe Ľuhi ko e kau fai kovi,  
\q2 pea  Ľoua na Ľa ke meheka ki he kau ngńĀue  Ľi he angahala.   
\q1
\v 2 Koe Ľuhi  Ľe vave  Ľae tu Ľusi hifo  Ľakinautolu  Ľo hangńď ko e mohuku,  
\q2 pea mae  Ľo hangńď ko e  Ľakau mata.   
\q1
\v 3 Falala kia Sihova, pea ke fai lelei;  
\q2 ko ia te ke nofo ai  Ľi he fonua, pea ko e mo Ľoni  Ľe fafanga Ľi koe.   
\q1
\v 4 FakafiemńĀlie Ľi foki koe  Ľia Sihova;  
\q2 pea te ne foaki kiate koe  Ľae ngaahi holi  Ľo ho loto.   
\q1
\v 5 Tuku ho hala kia Sihova;  
\q2 pea falala foki kiate ia; pea te ne fakahoko ia.   
\q1
\v 6 Pea te ne fakahńĀ atu ho Ľo mńĀ Ľoni Ľoni  Ľo hangńď ko e maama,  
\q2 mo ho Ľo fakamaau  Ľo hangńď ko e ho ĽatńĀ  Ľoe  Ľaho.   
\q1
\v 7 Ke ke fakalongo pńď kia Sihova, pea tatali fa Ľa kńĀtaki pe kiate ia:  
\q2  Ľoua na Ľa ke fakamamahi Ľi koe koe Ľuhi ko ia  Ľoku monŇę Ľia  Ľi hono hala,  
\q2 koe Ľuhi ko e tangata  Ľoku fakahoko  Ľae ngaahi filio Ľi kovi.   
\q1
\v 8 Tukuange  Ľae  Ľita, pea li Ľaki  Ľae lili:  
\q2  Ľoua na Ľa ke fakamamahi Ľi foki koe  Ľi ha me Ľa ke fai kovi.   
\q1
\v 9 Koe Ľuhi  Ľe motuhi  Ľae ngaahi fai kovi:  
\q2 ka ko kinautolu  Ľoku tatali kia Sihova, te nau ma Ľu  Ľae fonua.   
\q1
\v 10 He  Ľoku toetoe si Ľi pńď, pea  Ľe  Ľikai  Ľae angakovi:  
\q2  Ľio, te ke tokanga lahi ki hono potu, ka  Ľe  Ľikai  Ľilo Ľi ia.   
\q1
\v 11 Ka ko e angamalŇę tenau ma Ľu  Ľae fonua;  
\q2  Ľonau fakafiemńĀlie Ľi  Ľakinautolu  Ľi hono lahi  Ľoe melino.   
\q1
\v 12 ‚ÄĆ ĽOku fakakaukau kovi  Ľe he angahala ki he angatonu,  
\q2 mo ngai Ľi kiate ia  Ľaki hono nifo.   
\q1
\v 13 ‚ÄĆ ĽE kata  Ľa Sihova kiate ia:  
\q2 he  Ľoku ne  Ľafio Ľi  Ľoku ha Ľu hono  Ľaho.   
\q1
\v 14 Kuo unuhi  Ľe he kau angakovi  Ľae heletńĀ, pea kuo nau teke  Ľenau kaufana,  
\q2 ke lńę ki lalo  Ľae mamahi mo e paea,  
\q2 pea ke tńĀmate Ľi  Ľakinautolu  Ľoku angatotonu.   
\q1
\v 15 ‚ÄĆ ĽE  Ľasi  Ľenau heletńĀ ki honau loto  Ľonautolu,  
\q2 pea  Ľe mafesi  Ľenau ngaahi kaufana.   
\q1
\v 16 ‚ÄĆ ĽOku lelei lahi hake  Ľae me Ľa si Ľi  Ľoku  Ľi he tangata mńĀ Ľoni Ľoni  
\q2  Ľi he koloa  Ľoe tokolahi  Ľoku angahala.   
\q1
\v 17 Koe Ľuhi  Ľe fesi Ľi  Ľae nima  Ľoe kau angahala:  
\q2 ka  Ľoku poupou  Ľe Sihova  Ľae mńĀ Ľoni Ľoni.   
\q1
\v 18 ‚ÄĆ ĽOku  Ľilo Ľi  Ľe Sihova  Ľae ngaahi  Ľaho  Ľoe kakai angatonu:  
\q2 pea ko honau tofi Ľa  Ľe tolonga ta Ľengata.   
\q1
\v 19 ‚ÄĆ ĽE  Ľikai te nau mńĀ  Ľi he kuonga kovi,  
\q2 pea  Ľi he ngaahi  Ľaho  Ľoe honge tenau mńĀkona.   
\q1
\v 20 Ka  Ľe  Ľauha  Ľae angakovi,  
\q2 pea  Ľe tatau  Ľae ngaahi fili  Ľo Sihova mo e ngako  Ľoe fanga lami:  
\q2  Ľe  Ľauha  Ľakinautolu;  
\q2  Ľi he kohu tenau mole  Ľo  Ľosi.   
\q1
\v 21 ‚ÄĆ ĽOku nŇć  Ľae angakovi, pea  Ľikai toe totongi:  
\q2 ka  Ľoku fakahńĀ  Ľae  Ľofa  Ľe he mńĀ Ľoni Ľoni,  Ľo foaki.   
\q1
\v 22 He ko kinautolu kuo tńĀpuekina  Ľiate ia tenau ma Ľu  Ľae fonua;  
\q2 pea ko kinautolu kuo mala Ľia  Ľiate ia  Ľe motuhi.   
\q1
\v 23 ‚ÄĆ ĽOku fakahinohino  Ľe Sihova  Ľae ngaahi laka  Ľae tangata lelei:  
\q2 pea  Ľoku fiemńĀlie ia  Ľi hono hala.   
\q1
\v 24 Neongo  Ľene tŇć ki lalo,  Ľe  Ľikai  Ľauha ia:  
\q2 he  Ľoku poupou hake ia  Ľe he nima  Ľo Sihova.   
\q1
\v 25 Na Ľaku talavou, pea kuo u motu Ľa;  
\q2 ka  Ľoku te Ľeki te u  Ľilo  Ľae mńĀ Ľoni Ľoni kuo li Ľaki,  
\q2 pe ko hono hako  Ľoku kole mńĀ.   
\q1
\v 26 ‚ÄĆ ĽOku anga Ľofa ma Ľuaipńď ia, pea fa Ľa  Ľatu;  
\q2 pea  Ľoku monŇę Ľia hono hako.   
\q1
\v 27 Afe mei he kovi, pea ke fai lelei,  
\q2 pea nofoma Ľu pńď  Ľo ta Ľengata.   
\q1
\v 28 He  Ľoku  Ľofa  Ľa Sihova ki he fakamaau,  
\q2 pea  Ľoku  Ľikai te ne li Ľaki hono kakai mńĀ Ľoni Ľoni;  
\q2 kuo fakamo Ľui ma Ľuaipńď  Ľakinautolu:  
\q2 ka  Ľe motuhi  Ľae hako  Ľoe angakovi.   
\q1
\v 29 ‚ÄĆ ĽE ma Ľu  Ľe he mńĀ Ľoni Ľoni  Ľa e fonua,  
\q2 pea tenau nofo ai  Ľo ta Ľengata.   
\b  
\q1
\v 30 Ko e ngutu  Ľoe mńĀ Ľoni Ľoni  Ľoku ne lea  Ľaki  Ľae poto,  
\q2 pea talanoa  Ľaki hono  Ľelelo  Ľae fakamaau.   
\q1
\v 31 ‚ÄĆ ĽOku  Ľi hono loto  Ľae fono  Ľa hono  ĽOtua;  
\q2  Ľe  Ľikai hekea ia  Ľi ha Ľane laka  Ľe taha.   
\q1
\v 32 ‚ÄĆ ĽOku lamasi  Ľe he angakovi  Ľae mńĀ Ľoni Ľoni,  
\q2  Ľo kumi ke fakapoongi ia.   
\q1
\v 33 ‚ÄĆ ĽE  Ľikai tukuange ia  Ľe Sihova  Ľi hono nima,  
\q2 pe tukuaki Ľi ia  Ľi hono fakamaau Ľi.   
\q1
\v 34 Tatali kia Sihova, pea tauhi hono hala,  
\q2 pea te ne hakeaki Ľi koe ke ma Ľu  Ľae fonua:  
\q2 pea ka  Ľosi hono motuhi  Ľae kakai angakovi, te ke mamata ki ai.   
\q1
\v 35 Na Ľaku mamata ki he angakovi kuo mńĀlohi lahi,  
\q2 pea mafola ia  Ľo hangńď ko e  Ľakau ma Ľui Ľui  Ľoku tupu  Ľi hono potu  Ľo Ľona.   
\q1
\v 36 Ka na Ľe mole atu ia, pea vakai, kuo  Ľikai ia:  
\q2  Ľio, ne u kumi ia, ka na Ľe  Ľikai fa Ľa  Ľilo Ľi ia.   
\q1
\v 37 Vakai ki he tangata haohaoa, mo tokanga ki he angatonu:  
\q2 he ko e ngata Ľanga  Ľoe tangata ko ia ko e melino.   
\q1
\v 38 Ka  Ľe faka Ľauha fakataha  Ľae kau angahala:  
\q2 ko e iku Ľanga  Ľoe angakovi  Ľe motuhi ia.   
\q1
\v 39 Ka ko hono fakamo Ľui  Ľoe mńĀ Ľoni Ľoni  Ľoku  Ľia Sihova:  
\q2 ko honau mńĀlohi ia  Ľi he kuonga  Ľoe mamahi.   
\q1
\v 40 Pea  Ľe tokoni  Ľakinautolu  Ľe Sihova, mo fakamo Ľui  Ľakinautolu:  
\q2 te ne fakahaofi  Ľakinautolu mei he kakai angakovi, mo fakamo Ľui  Ľakinautolu,  
\q2 ko e me Ľa  Ľi he Ľenau falala kiate ia.   
\c 38  
\cd \it 1‚Äď22  ĽOku lotu  Ľa Tevita ki he  ĽOtua ke  Ľalo Ľofa kiate ia  Ľi he Ľene mamahi lahi.\it*  
\d Ko e Saame  Ľa Tevita, ko e fakamanatu.  
\q1
\v 1 ‚ÄĆ ĽE Sihova,  Ľoua na Ľa ke valoki Ľi au  Ľi ho houhau:  
\q2 pea  Ľoua na Ľa ke valoki Ľi au  Ľi ho houhau vela.   
\q1
\v 2 He  Ľoku tau ma Ľu  Ľiate au ho Ľo ngaahi ngahau,  
\q2 pea  Ľoku ta Ľomia fakamamahi au  Ľe ho nima.   
\q1
\v 3 ‚ÄĆ ĽOku  Ľikai ha haohaoa  Ľi hoku kakano ko e me Ľa  Ľi ho houhau;  
\q2 pea  Ľoku  Ľikai ha fiemńĀlie  Ľi hoku hui ko e me Ľa  Ľi he Ľeku angahala.   
\q1
\v 4 He kuo hake  Ľa  Ľeku ngaahi hia  Ľo  Ľufi Ľufi hoku  Ľulu:  
\q2  Ľo hangńď ko e kavenga mamafa  Ľoku ta Ľomia ai au.   
\q1
\v 5 ‚ÄĆ ĽOku  Ľeho hoku ngaahi lavea  Ľo fakalielia koe Ľuhi ko  Ľeku vale.   
\q1
\v 6 ‚ÄĆ ĽOku ou mamahi;  Ľoku ou mapelu ki lalo  Ľaupito;  
\q2  Ľoku ou  Ľalu mamahi pe  Ľi he  Ľaho kotoa.   
\q1
\v 7 He  Ľoku fonu hoku sino  Ľi he mahaki kovi:  
\q2 pea  Ľoku  Ľikai ha mo Ľui haohaoa  Ľi hoku kakano.   
\q1
\v 8 ‚ÄĆ ĽOku ou vaivai mo mafesi  Ľi he mamahi:  
\q2 na Ľaku kalanga ko e me Ľa  Ľi he mamahi  Ľo hoku loto.   
\q1
\v 9 ‚ÄĆ ĽE  ĽEiki,  Ľoku  Ľi ho  Ľao  Ľeku holi kotoa pńď;  
\q2 mo  Ľeku ngaahi to Ľe  Ľoku  Ľikai fufŇę  Ľiate koe.   
\q1
\v 10 ‚ÄĆ ĽOku tatupe hoku mafu,  
\q2 kuo  Ľosi  Ľeku mńĀlohi:  
\q2 pea ko e maama  Ľo hoku mata kuo mole foki ia  Ľiate au.   
\q1
\v 11 Ko hoku kaume Ľa  Ľofa mo hoku ngaahi kńĀinga  Ľoku nau tutu Ľu  Ľi he mama Ľo mei hoku te Ľia;  
\q2 mo hoku kaungńĀ Ľapi  Ľoku nau tutu Ľu  Ľi he mama Ľo.   
\q1
\v 12 Ko kinautolu foki  Ľoku kumi ki he Ľeku mo Ľui  Ľoku nau tŇć  Ľae ngaahi tauhele kiate au:  
\q2 ko kinautolu  Ľoku kumi ke u kovi  Ľoku nau lea  Ľaki  Ľae ngaahi me Ľa kovi,  
\q2 mo nau fakakaukau ki he me Ľa kńĀkńĀ  Ľi he  Ľaho kotoa.   
\q1
\v 13 Ka ko au, hangńď ko ha tuli,  Ľoku  Ľikai te u ongo Ľi;  
\q2 pea na Ľaku hangńď ko e tangata  Ľoku noa  Ľaia  Ľoku  Ľikai mafa Ľa hono ngutu.   
\q1
\v 14 Pea na Ľaku hangńď ko e tangata ta Ľeongo Ľi,  
\q2 pea  Ľoku  Ľikai ha valoki  Ľi hono ngutu.   
\q1
\v 15 He  Ľoku ou  Ľamanaki lelei,  ĽE Sihova, kiate koe:  
\q2 te ke ongo Ľi,  ĽE  ĽEiki ko hoku  ĽOtua.   
\q1
\v 16 He na Ľaku pehńď, ‚ÄúFanongo kiate au, telia na Ľa nau fiefia kiate au:  
\q2  Ľi he hekea  Ľa hoku va Ľe,  Ľoku nau hiki hake  Ľakinautolu kiate au.‚ÄĚ   
\q1
\v 17 He  Ľoku ou meimei nofo,  
\q2 pea  Ľoku tu Ľuma Ľu pe  Ľeku mamahi  Ľi hoku  Ľao.   
\q1
\v 18 He te u fakahńĀ  Ľeku hia;  
\q2 pea u mamahi koe Ľuhi ko  Ľeku angahala.   
\q1
\v 19 Ka  Ľoku mo Ľui hoku ngaahi fili, pea  Ľoku nau mńĀlohi:  
\q2 pea  Ľoku faka Ľa Ľau  Ľo tokolahi  Ľakinautolu  Ľoku fehi Ľa ta Ľetotonu kiate au.   
\q1
\v 20 Pea ko hoku ngaahi fili foki  Ľakinautolu  Ľoku totongi kovi ki he lelei;  
\q2 koe Ľuhi  Ľoku ou muimui ki he lelei.   
\q1
\v 21 ‚ÄĆ ĽOua na Ľa ke li Ľaki au,  ĽE Sihova:  
\q2  ĽE hoku  ĽOtua,  Ľoua na Ľa ke mama Ľo  Ľiate au.   
\q1
\v 22 Ke ke fakato Ľoto Ľo ke tokoni au,  ĽE  ĽEiki ko hoku fakamo Ľui.   
\c 39  
\cd \it 1 Ko e tokanga  Ľa Tevita ki he Ľene ngaahi mahalo. 4 Ko  Ľene manatu ki he fuonouou mo e va Ľinga  Ľoe mo Ľui, 7 Mo e manavahńď ki he ngaahi fakamaau  Ľae  ĽOtua, 10 Mo e lotu, ko e ngaahi me Ľa ta Ľofi ia ki he ta Ľefa ĽakńĀtaki.\it*  
\d Ki he Takimu Ľa ko Situtuni, ko e Saame  Ľa Tevita.  
\q1
\v 1 Na Ľa ku pehńď, ‚ÄúTe u vakai ki hoku ngaahi hala, telia na Ľaku angahala  Ľi hoku  Ľelelo:  
\q2 te u  Ľai  Ľae no Ľo ki hoku ngutu,  Ľi he kei  Ľi hoku  Ľao  Ľae angakovi.‚ÄĚ   
\q1
\v 2 Na Ľaku noa,  Ľi he fakalongo pńď,  
\q2 na Ľaku ta Ľofi au mei he lea,  
\q2  Ľio, mei he lelei;  
\q2 pea na Ľe tupu ai  Ľeku mamahi.   
\q1
\v 3 Na Ľe vela hoku loto  Ľiate au,  
\q2 pea lolotonga  Ľeku fifili na Ľe vela  Ľae afi:  
\q2 pea u toki lea  Ľaki hoku  Ľelelo,   
\q1
\v 4 ‚Äú ĽE Sihova, ke ke faka Ľilo kiate au hoku ngata Ľanga,  
\q2 mo hono fuofua  Ľo hoku ngaahi  Ľaho, pe ko e hńĀ ia;  
\q2 koe Ľuhi ke u  Ľilo ki hono lahi  Ľo  Ľeku vaivai.‚ÄĚ   
\q1
\v 5 Vakai, kuo ke ngaohi hoku ngaahi  Ľaho ke tatau mo e  Ľaofinima pe taha;  
\q2 pea ko  Ľeku mo Ľui  Ľoku hangńď ko e me Ľa noa pńď  Ľi ho  Ľao:  
\q2 ko e mo Ľoni ko e tangata kotoa pńď  Ľi he Ľene tu Ľuma Ľu ko e mńĀtu Ľaki va Ľinga ia. \qs Sila.\qs*   
\q1
\v 6 Ko e mo Ľoni  Ľoku  Ľalu  Ľae tangata kotoa pńď  Ľi he  Ľata loi:  
\q2 ko e mo Ľoni kuo nau mamahi ta Ľe Ľaonga:  
\q2  Ľoku ne tńĀnaki  Ľae koloa, pea  Ľoku  Ľikai te ne  Ľilo pe ko hai te ne ma Ľu ia.   
\q1
\v 7 Pea ko eni, ‚Äú ĽE Sihova, ko e hńĀ  Ľoku ou tatali ai?  
\q2  ĽOku  Ľiate koe pńď  Ľeku  Ľamanaki lelei.   
\q1
\v 8 Fakamo Ľui au mei he Ľeku ngaahi talangata Ľa kotoa pńď:  
\q2  Ľoua na Ľa ke ngaohi au ko e manuki Ľanga  Ľoe vale.‚ÄĚ   
\q1
\v 9 Na Ľaku noa, na Ľe  Ľikai te u mafa Ľa hoku ngutu;  
\q2 koe Ľuhi ko koe na Ľa ke fai ia.   
\q1
\v 10 To Ľo atu ho Ľo tńĀ  Ľiate au:  
\q2 kuo u  Ľauha  Ľi he tńĀ  Ľaho nima.   
\q1
\v 11 ‚ÄĆ ĽOka ke ka tautea  Ľae tangata  Ľaki  Ľae tńĀkitala  Ľi he Ľene hia,  
\q2  Ľoku ke pule ke mole atu hono lelei  Ľo hangńď ko e ane:  
\q2 ko e mo Ľoni ko e va Ľinga  Ľae tangata kotoa pńď. \qs Sila.\qs*   
\q1
\v 12 Fanongo mai ki he Ľeku lotu,  ĽE Sihova, mo ke fakafanongo ki he Ľeku tangi;  
\q2  Ľoua na Ľa ke fakalongo pńď  Ľi hoku ngaahi lo Ľimata:  
\q2 he ko e muli au  Ľi ho  Ľao,  
\q2 mo e  ĽńĀunofo,  
\q2  Ľo hangńď ko  Ľeku ngaahi tamai kotoa pńď.   
\q1
\v 13 Tuku si Ľi ai pe au, koe Ľuhi ke u toe ma Ľu  Ľeku mńĀlohi,  
\q2  Ľi he te Ľeki ai te u  Ľalu  Ľi heni, pea te u  Ľikai leva.   
\c 40  
\cd \it 1 Ko hono  Ľaonga  Ľoe falala ki he  Ľotua. 6 Ko e feilaulau lelei lahi  Ľae talangofua. 11  ĽOku  ĽńĀsili ai  Ľae lotu  Ľa Tevita  Ľi he Ľene manatu ki he Ľene kovi.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita.  
\q1
\v 1 Na Ľa ku tatali fa Ľa kńĀtaki pe kia Sihova;  
\q2 pea ne tokanga kiate au,  Ľone ongo Ľi  Ľeku tangi.   
\q1
\v 2 Pea na Ľa ne to Ľo hake au mei he luo fakailifia,  
\q2 mei he  Ľumea pelepela,  
\q2  Ľo ne fokotu Ľu hoku va Ľe ki he maka,  
\q2  Ľo fakama Ľu hoku ngaahi  Ľalu Ľanga.   
\q1
\v 3 Pea kuo ne  Ľai  Ľae hiva fo Ľou ki hoku ngutu,  Ľio,  Ľae fakafeta Ľi ki hotau  ĽOtua:  
\q2  Ľe mamata ki ai  Ľae tokolahi, pea manavahńď, pea tenau falala kia Sihova.   
\q1
\v 4 ‚ÄĆ ĽOku monŇę Ľia  Ľae tangata ko ia  Ľoku falala kia Sihova,  
\q2 pea  Ľikai tokanga ia ki he kakai laukau, mo kinautolu  Ľoku afe ki he loi.   
\q1
\v 5 ‚ÄĆ ĽE Sihova ko hoku  ĽOtua,  Ľoku lahi ho Ľo ngaahi ngńĀue fakaofo  Ľaia kuo ke fai,  
\q2 mo ho finangalo lelei kiate kimautolu:  
\q2  Ľe  Ľikai fa Ľa lau fakaholo ia kiate koe:  
\q2 kapau te u fie fakahńĀ  Ľo lea ki ai,  Ľoku lahi  Ľaupito ia,  Ľe  Ľikai fa Ľa laua.   
\q1
\v 6 Ko e feilaulau mo e me Ľa foaki na Ľe  Ľikai te ke finangalo ki ai;  
\q2 ka ko hoku telinga kuo ke fakaava:  
\q2 ko e feilaulau tutu mo e feilaulau koe Ľuhi ko e angahala na Ľe  Ľikai te ke fekau.   
\q1
\v 7 Pea na Ľaku toki pehńď, ‚ÄúVakai,  Ľoku ou ha Ľu:  
\q2 kuo tohi  Ľi he tohi tńĀkai  Ľiate au,   
\q1
\v 8 ‚ÄĆ ĽE hoku  ĽOtua,  Ľoku ou fiefia ke fai ho finangalo:  
\q2  Ľio,  Ľoku  Ľi hoku loto ho Ľo fono.‚ÄĚ   
\q1
\v 9 Na Ľaku malanga Ľaki  Ľae mńĀ Ľoni Ľoni  Ľi he fakataha lahi:  
\q2 vakai, na Ľe  Ľikai te u ta Ľofi hoku loungutu,  ĽE Sihova,  Ľoku ke  Ľilo Ľi.   
\q1
\v 10 Na Ľe  Ľikai te u fakafufŇę ho Ľo mńĀ Ľoni Ľoni  Ľi hoku loto;  
\q2 na Ľaku fakahńĀ ho Ľo angatonu mo ho Ľo fakamo Ľui:  
\q2 na Ľe  Ľikai te u fakalilolilo  Ľa ho Ľo  Ľalo Ľofa mo ho Ľo mo Ľoni mei he fakataha lahi.   
\q1
\v 11 ‚ÄĆ ĽE Sihova,  Ľoua na Ľa ke ta Ľofi ho Ľo ngaahi  Ľalo Ľofa ongongofua  Ľiate au:  
\q2 tuku ke tauhi ma Ľuaipńď au  Ľe ho Ľo  Ľalo Ľofa mo ho Ľo mo Ľoni.   
\q1
\v 12 He kuo kńĀpui au  Ľe he ngaahi kovi ta Ľefa Ľalaua:  
\q2 kuo puke au  Ľe he Ľeku ngaahi hia, ko ia  Ľoku  Ľikai ai te u fa Ľa hanga hake;  
\q2  Ľoku lahi hake ia  Ľi he ngaahi tu Ľoni lou Ľulu  Ľo hoku  Ľulu:  
\q2 ko ia kuo li Ľaki au  Ľe hoku loto.   
\q1
\v 13 ‚ÄĆ ĽE Sihova, ke ke finangalo lelei ke fakamo Ľui au:  
\q2  ĽE Sihova, ke ke fai vave ke tokoni Ľi au.   
\q1
\v 14 Tuku ke mńĀ mo puputu Ľu fakataha  Ľakinautolu kotoa pńď  Ľoku nau kumi hoku laumńĀlie ke faka Ľauha ia;  
\q2 tuku ke fakafoki kimui mo mńĀ  Ľakinautolu  Ľoku nau holi ke u kovi.   
\q1
\v 15 Tuku ke paea  Ľakinautolu ko e totongi  Ľo  Ľenau kovi,  Ľakinautolu  Ľoku pehńď kiate au, ‚ÄúHa ha.‚ÄĚ   
\q1
\v 16 Tuku ke fiefia mo nekeneka  Ľiate koe  Ľakinautolu kotoa pńď  Ľoku kumi kiate koe:  
\q2 tuku ke lea pehńď ma Ľuaipńď  Ľakinautolu  Ľoku  Ľofa ki ho Ľo fakamo Ľui,  
\q2 ‚ÄúKe ongoongolelei  Ľa Sihova.‚ÄĚ   
\q1
\v 17 Ka ko au  Ľoku ou masiva mo paea;  
\q2 ka  Ľoku finangalo  Ľae  ĽEiki kiate au:  
\q2 ko koe ko hoku tokoni mo hoku fakamo Ľui;  
\q2  Ľoua na Ľa ke fakatuai,  
\q2  ĽE hoku  ĽOtua.   
\c 41  
\cd \it 1 Ko e tokanga  Ľae  ĽOtua ki he masiva. 4  ĽOku lńĀunga  Ľa Tevita  Ľi he kńĀkńĀ  Ľa hono ngaahi fili. 10  ĽOku ne hola ki he  ĽOtua ke ne malu Ľi ia.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽOku monŇę Ľia ia  Ľaia  Ľoku tokanga ki he masiva:  
\q2  Ľe fakamo Ľui ia  Ľe Sihova he  Ľaho  Ľoe kovi.   
\q1
\v 2 ‚ÄĆ ĽE tauhi ia  Ľe Sihova, mo pule ke mo Ľui ia;  
\q2 pea te ne monŇę Ľia  Ľi mńĀmani:  
\q2 pea  Ľe  Ľikai te ke tukuange ia ki he loto  Ľo hono ngaahi fili.   
\q1
\v 3 ‚ÄĆ ĽE fakamńĀlohi ia  Ľe Sihova  Ľi he tokoto Ľanga fakamamahi:  
\q2 te ke ngaohi hono mohenga kotoa pńď  Ľi hono mahaki.   
\q1
\v 4 Na Ľaku pehńď, ‚Äú ĽE Sihova, ke ke  Ľalo Ľofa mai kiate au:  
\q2 fakamo Ľui hoku laumńĀlie; he kuo u fai angahala kiate koe.‚ÄĚ   
\q1
\v 5 ‚ÄĆ ĽOku lau Ľikovi Ľi au  Ľe hoku ngaahi fili:  
\q2  ĽE mate  Ľafńď ia, pea  Ľauha hono hingoa?   
\q1
\v 6 Pea kapau  Ľe ha Ľu ia ke vakai au,  Ľoku ne lea loi:  
\q2  Ľoku tńĀnaki  Ľe hono loto kiate ia  Ľae kovi;  
\q2  Ľoku  Ľalu ia kitua ĽńĀ,  Ľo fakahńĀ ia.   
\q1
\v 7 ‚ÄĆ ĽOku fefanafanahi kiate au  Ľakinautolu kotoa pńď  Ľoku fehi Ľa kiate au:  
\q2  Ľoku nau fakakaukau kovi kiate au.   
\q1
\v 8 ‚ÄĆ ĽOku nau pehńď, ‚Äú ĽOku piki ma Ľu kiate ia  Ľae mahaki kovi:  
\q2 pea ko  Ľene tokoto ni  Ľe  Ľikai te ne toetu Ľu hake mei ai.‚ÄĚ   
\q1
\v 9 ‚ÄĆ ĽIo, ko hoku kaume Ľa mo Ľoni,  Ľaia na Ľaku falala ki ai,  
\q2  Ľaia na Ľa ne kai  Ľi he Ľeku mńĀ,  
\q2 kuo hiki hake  Ľe ia hono mui va Ľe kiate au.   
\q1
\v 10 Ka ko koe,  ĽE Sihova, ke ke  Ľalo Ľofa kiate au, mo fokotu Ľu hake au,  
\q2 pea te u totongi kiate kinautolu.   
\q1
\v 11 ‚ÄĆ ĽOku ou  Ľilo  Ľi he me Ľa ni  Ľoku ke finangalo lelei kiate au,  
\q2 koe Ľuhi  Ľoku  Ľikai kalanga  Ľi he fiefia  Ľa hoku fili kiate au.   
\q1
\v 12 Pea ko au,  Ľoku ke poupou hake au  Ľi he Ľeku angatonu,  
\q2 pea te ke fokotu Ľu au  Ľi ho  Ľao  Ľo ta Ľengata.   
\q1
\v 13 Fakafeta Ľi kia Sihova ko e  ĽOtua  Ľo  ĽIsileli,  
\q1 talu mei mu Ľa,  Ľo ta Ľengata.  
\q1  ĽEmeni mo  ĽEmeni.   
\c 42  
\ms1 TOHI 2  
\mr (Saame 42‚ÄĒ72)  
\cd \it 1 Ko e holi  Ľa Tevita ke tauhi  Ľae  ĽOtua  Ľi hono faletapu. 5  ĽOku ne enginaki Ľi hono laumńĀlie ke falala ki he  ĽOtua.\it*  
\d Ki he Takimu Ľa, ko e akonaki ki he ngaahi foha  Ľo Kola.  
\q1
\v 1 ‚ÄĆ ĽOku hangńď ko e holi  Ľae hainiti ki he ngaahi tafe Ľanga vai,  
\q2  Ľoku pehńď  Ľae holi  Ľa hoku laumńĀlie kiate koe,  ĽE  ĽOtua.   
\q1
\v 2 ‚ÄĆ ĽOku holi hoku laumńĀlie ki he  ĽOtua, ki he  ĽOtua mo Ľui:  
\q2 te u hoko  Ľafńď  Ľo fakahńĀ au  Ľi he  Ľao  Ľoe  ĽOtua?   
\q1
\v 3 Ko  Ľeku me Ľakai  Ľi he  Ľaho mo e pŇć  Ľa hoku ngaahi lo Ľimata,  
\q2 lolotonga  Ľoku nau pehńď ma Ľuaipńď kiate au, ‚ÄúKo e fńď ho  ĽOtua?‚ÄĚ   
\q1
\v 4 ‚ÄĆ ĽI he Ľeku manatu ki he ngaahi me Ľa ni,  Ľoku ou lilingi hoku laumńĀlie  Ľiate au:  
\q2 he na Ľaku fa Ľa  Ľalu mo e tokolahi, na Ľaku  Ľalu mo kinautolu ki he fale  Ľoe  ĽOtua,  
\q2  Ľi he le Ľo  Ľoe fiefia mo e fakafeta Ľi, mo e tokolahi na Ľe tauhi  Ľae  Ľaho tapu.   
\q1
\v 5 Ko e hńĀ  Ľoku ke mapelu ai ki lalo,  ĽE hoku laumńĀlie?  
\q2 pea ko e hńĀ kuo ke maveuveu ai  Ľi loto  Ľiate au?  
\q2 Ke ke  Ľamanaki lelei ki he  ĽOtua?  
\q2 He ko e mo Ľoni te u fakafeta Ľi kiate ia  Ľi he ngaahi fakamo Ľui  Ľo hono fofonga.   
\q1
\v 6 ‚ÄĆ ĽE hoku  ĽOtua,  Ľoku mapelu ki lalo hoku laumńĀlie  Ľi loto  Ľiate au:  
\q2 ko ia te u manatu ai kiate koe mei he fonua  Ľo Sioatani,  
\q2 pea mo Heamoni, mo e mo Ľunga si Ľi ko Maisa.   
\q1
\v 7 ‚ÄĆ ĽOku ui  Ľae loloto ki he loloto  Ľi he longoa Ľa  Ľo ho Ľo ngaahi  Ľahiohio vai:  
\q2  Ľoku lŇćmaki Ľi au  Ľe ho Ľo ngaahi peau kotoa pńď mo ho Ľo ngaahi ngalu.   
\q1
\v 8 Ka ko e mo Ľoni  Ľe fekau mai  Ľe Sihova  Ľa  Ľene  Ľalo Ľofa  Ľi he  Ľaho,  
\q2 pea  Ľe  Ľiate au  Ľene hiva  Ľi he po Ľuli,  
\q2 mo  Ľeku lotu ki he  ĽOtua  Ľo  Ľeku mo Ľui.   
\q1
\v 9 Te u pehńď ki he  ĽOtua ko hoku makatu Ľu, ‚ÄúKo e hńĀ kuo ke fakangalo Ľi ai au?  
\q2 Ko e hńĀ  Ľoku ou  Ľalu mamahi pńď  Ľi he ta Ľomia  Ľe he fili?‚ÄĚ   
\q1
\v 10 Ko e manuki  Ľa hoku ngaahi fili,  Ľoku hangńď ko e heletńĀ kuo uhu ki hoku ngaahi hui;  
\q2  Ľi he Ľenau pehńď mai kiate au  Ľi he  Ľaho kotoa pńď, ‚ÄúKo e fńď ho  ĽOtua?‚ÄĚ   
\q1
\v 11 Ko e hńĀ  Ľoku ke mapelu ai ki lalo,  ĽE hoku laumńĀlie?  
\q2 Pea ko e hńĀ  Ľoku ke maveuveu ai  Ľi loto  Ľiate au?  
\q1 Ke ke  Ľamanaki lelei ki he  ĽOtua: he ko e mo Ľoni te u fakafeta Ľi kiate ia,  
\q2  Ľaia ko e fakamo Ľui  Ľo hoku mata, mo hoku  ĽOtua.   
\c 43  
\cd \it 1  ĽOku lotu  Ľa Tevita ke toe  Ľomi ia ki he falelotu lahi, pea ne fakahńĀ te ne tauhi fiefia ai  Ľae  ĽOtua. 5  ĽOku ne enginaki Ľi hono laumńĀlie ke falala ki he  ĽOtua.\it*  
\q1
\v 1 ‚ÄĆ ĽE  ĽOtua, ke ke fakamaau au,  Ľo langomaki Ľi au telia  Ľae pule Ľanga angakovi:  
\q2 ke ke fakamo Ľui au mei he tangata kńĀkńĀ mo ta Ľeangatonu.   
\q1
\v 2 He ko koe ko e  ĽOtua  Ľo  Ľeku mńĀlohi: ko e hńĀ  Ľoku ke li Ľaki ai au?  
\q2 Ko e hńĀ  Ľoku ou  Ľalu mamahi pe  Ľi he ta Ľomia  Ľe he fili?   
\q1
\v 3 Ke ke fekau atu ho Ľo maama mo ho Ľo mo Ľoni:  
\q2 tuku ke na tataki au;  
\q2 tuku ke na  Ľomi au ki ho mo Ľunga mńĀ Ľoni Ľoni,  
\q2 mo ho ngaahi fale fehikitaki.   
\q1
\v 4 Ko ia te u toki  Ľalu atu ki he feilaulau Ľanga  Ľoe  ĽOtua,  
\q2 ki he  ĽOtua ko hoku fiefia Ľanga lahi  Ľaupito:  
\q2  Ľio,  Ľi he ha Ľape te u fakamńĀlŇć kiate koe,  ĽE  ĽOtua ko hoku  ĽOtua.   
\q1
\v 5 Ko e hńĀ  Ľoku ke mapelu ai ki lalo,  ĽE hoku laumńĀlie?  
\q2 pea ko e hńĀ  Ľoku ke maveuveu ai  Ľi loto  Ľiate au?  
\q2  ĽAmanaki lelei ki he  ĽOtua:  
\q2 he ko e mo Ľoni te u fakafeta Ľi kiate ia,  
\q2  Ľaia ko e fakamo Ľui  Ľo hoku mata, mo hoku  ĽOtua.   
\c 44  
\cd \it 1 Ko e fakamanatu  Ľe he siasi ki he Ľene lelei  Ľi mu Ľa. 7  ĽOku lńĀunga ia  Ľi he Ľene tu ĽutńĀmaki ni. 17  ĽOku fakahńĀ  Ľe ia  Ľene angatonu, 24 Pea ne kole fakamńĀtoato ke malu Ľi ia.\it*  
\d Ki he Takimu Ľa, ko e akonaki ki he ngaahi foha  Ľo Kola.  
\q1
\v 1 ‚ÄĆ ĽE  ĽOtua, na Ľa mau fanongo  Ľaki homau telinga,  
\q2 pea kuo tala kiate kimautolu  Ľe he Ľemau ngaahi tamai,  
\q2  Ľae ngńĀue na Ľa ke fai  Ľi honau ngaahi  Ľaho,  
\q2  Ľi he ngaahi kuonga  Ľi mu Ľa.   
\q1
\v 2 Na Ľa ke kapusi kitu Ľa  Ľae hiteni  Ľaki ho nima,  
\q2 mo ke tŇć  Ľakinautolu:  
\q2 na Ľa ke tautea  Ľae kakai,  
\q2 pea mafola atu  Ľakinautolu.   
\q1
\v 3 He na Ľe  Ľikai te nau ma Ľu  Ľae fonua  Ľi he heletńĀ  Ľanautolu,  
\q2 pea na Ľe  Ľikai fakamo Ľui  Ľakinautolu  Ľe honau nima:  
\q2 ka ko ho  Ľaofi nima, mo ho nima to Ľomata Ľu, mo e maama  Ľo ho fofonga,  
\q2 koe Ľuhi na Ľa ke  Ľofa kiate kinautolu.   
\q1
\v 4 He ko koe ko hoku Tu Ľi,  
\q2  ĽE  ĽOtua ke ke fekau  Ľae fakamo Ľui kia Sńďkope.   
\q1
\v 5 Ko e me Ľa  Ľiate koe temau tulaki homau ngaahi fili:  
\q2 ko e me Ľa  Ľi ho huafa temau malamalaki ki lalo  Ľakinautolu  Ľoku tu Ľu hake kiate kimautolu.   
\q1
\v 6 Koe Ľuhi  Ľe  Ľikai te u falala ki he Ľeku kaufana,  
\q2 pea  Ľe  Ľikai fakamo Ľui au  Ľe he Ľeku heletńĀ.   
\q1
\v 7 Ka ko koe kuo ke fakamo Ľui  Ľakimautolu mei homau ngaahi fili,  
\q2 pea kuo ke tuku ke mńĀ  Ľakinautolu na Ľe fehi Ľa kiate kimautolu.   
\q1
\v 8 ‚ÄĆ ĽOku mau vikiviki  Ľi he  ĽOtua  Ľi he  Ľaho kotoa,  
\q2  Ľo fakamńĀlŇć ki ho huafa  Ľo ta Ľengata. \qs Sila.\qs*   
\q1
\v 9 Ka kuo ke li Ľaki, pea tuku ke mńĀ  Ľakimautolu;  
\q2 pea  Ľikai te ke  Ľalu atu mo  Ľemau ngaahi kongakau.   
\q1
\v 10 ‚ÄĆ ĽOku ke pule ke mau foki mai mei he fili:  
\q2 pea ko kinautolu  Ľoku fehi Ľa kiate kimautolu  Ľoku nau maumau ma Ľanautolu.   
\q1
\v 11 Kuo ke foaki  Ľakimautolu  Ľo hangńď ko e fanga sipi kuo fili ki he kai;  
\q2 pea kuo ke fakahńď Ľi  Ľakimautolu ki he hiteni.   
\q1
\v 12 ‚ÄĆ ĽOku ke fakatau ho Ľo kakai ta Ľehatotongi,  
\q2 pea  Ľoku  Ľikai te ke fakalahi ho Ľo koloa  Ľaki honau totongi.   
\q1
\v 13 ‚ÄĆ ĽOku ke ngaohi  Ľakimautolu ko e manuki Ľanga  Ľo homau ngaahi kaungńĀ Ľapi,  
\q2 ko e me Ľa manuki mo e taukae Ľanga  Ľokinautolu  Ľoku nofo takatakai  Ľiate kimautolu.   
\q1
\v 14 ‚ÄĆ ĽOku ke ngaohi  Ľakimautolu ko e luma Ľanga  Ľoe hiteni,  
\q2 ko e kalokalo Ľanga  Ľoe  Ľulu  Ľi he  Ľao  Ľoe kakai.   
\q1
\v 15 ‚ÄĆ ĽOku  Ľi hoku  Ľao ma Ľuaipńď  Ľeku kovi,  
\q2 pea kuo  Ľufi Ľufi  Ľaki au  Ľae mńĀ  Ľo hoku mata,   
\q1
\v 16 Koe Ľuhi ko e le Ľo  Ľo ia  Ľoku ne taukae mo kape;  
\q2 ko e me Ľa  Ľi he fili mo e fakafńĀsifasi.   
\q1
\v 17 Kuo hoko  Ľae me Ľa ni kotoa pńď kiate kimautolu;  
\q2 ka na Ľe  Ľikai te mau fakangalongalo Ľi koe,  
\q2 pea na Ľe  Ľikai te mau fai kńĀkńĀ  Ľi ho Ľo fuakava.   
\q1
\v 18 ‚ÄĆ ĽOku  Ľikai foki kimui homau loto,  
\q2 pe afe mei ho hala homau  Ľalu Ľanga;   
\q1
\v 19 Kuo ke fesifesi  Ľakimautolu  Ľi he potu  Ľoe fanga talńĀkoni,  
\q2 mo  Ľufi Ľufi  Ľaki  Ľakimautolu  Ľae  Ľata  Ľoe mate.   
\q1
\v 20 Kapau kuo mau fakangalo Ľi  Ľae huafa  Ľo homau  ĽOtua,  
\q2 pe mafao atu homau nima ki ha  Ľotua kehe;   
\q1
\v 21 ‚ÄĆ ĽIkai  Ľe  Ľeke ia  Ľe he  ĽOtua?  
\q2 He  Ľoku ne  Ľilo Ľi  Ľae ngaahi me Ľa fufŇę  Ľoe loto.   
\q1
\v 22 ‚ÄĆ ĽIo, koe Ľuhi ko koe  Ľoku tńĀmate Ľi  Ľakimautolu  Ľi he  Ľaho kotoa pńď;  
\q2  Ľoku lau  Ľakimautolu  Ľo hangńď ko e fanga sipi ke tńĀmate Ľi.   
\q1
\v 23 Ke ke  ĽńĀ, ko e hńĀ  Ľoku ke mohe ai,  ĽE Sihova?  
\q2 Tu Ľu hake,  
\q2  Ľoua na Ľa ke li Ľaki  Ľakimautolu  Ľo ta Ľengata.   
\q1
\v 24 Ko e hńĀ  Ľoku ke fufŇę ai ho fofonga,  
\q2  Ľo fakangalo Ľi homau tautea mo homau ta Ľomia?   
\q1
\v 25 He kuo lolohifo homau laumńĀlie ki he efu:  
\q2 kuo hiki homau kete ki he kelekele.   
\q1
\v 26 Tu Ľu hake ko homau tokoni,  
\q2 pea huhu Ľi  Ľakimautolu koe Ľuhi ko ho Ľo  Ľalo Ľofa.   
\c 45  
\cd \it 1 Ko e mńĀfimafi mo e  Ľofa  Ľoe pule Ľanga  Ľo Kalaisi. 10 Ko e ngńĀue  Ľae siasi mo hono lelei  Ľo ia.\it*  
\d Ki he Takimu Ľa  Ľi he Sosanimi, ko e akonaki ki he ngaahi foha  Ľo Kola, ko e Hiva ki he ngaahi  Ľofa.  
\q1
\v 1 ‚ÄĆ ĽOku mapuna hake  Ľi hoku loto  Ľae me Ľa lelei:  
\q2 te u lea ki he me Ľa kuo u ngaohi ki he tu Ľi:  
\q2 ko hoku  Ľelelo ko e peni ki he tohi vave.   
\q1
\v 2 ‚ÄĆ ĽOku ke faka Ľofo Ľofa lahi  Ľi he ngaahi fńĀnau  Ľae tangata:  
\q2 kuo lilingi  Ľae  Ľofa ki ho loungutu:  
\q2 ko ia kuo fakamonŇę Ľia ai koe  Ľe he  ĽOtua  Ľo lauikuonga.   
\q1
\v 3 ‚ÄĆ ĽE Fungani MńĀfimafi ke ke nono Ľo ho Ľo heletńĀ ki ho tu Ľatenga,  
\q2  Ľi ho nńĀunau mo ho mńĀlohi.   
\q1
\v 4 Pea  Ľi ho Ľo mńĀfimafi ke ke hńĀ Ľele monŇę Ľia,  
\q2 ko e me Ľa  Ľi he mo Ľoni mo e angavaivai mo e mńĀ Ľoni Ľoni;  
\q2 pea  Ľe ako kiate koe  Ľe ho nima to Ľomata Ľu  Ľae ngaahi me Ľa fakailifia.   
\q1
\v 5 ‚ÄĆ ĽOku mńĀsila ho Ľo ngaahi ngahau  Ľi he loto  Ľoe ngaahi fili  Ľoe tu Ľi;  
\q2  Ľoku tŇć ki lalo  Ľae kakai  Ľiate koe.   
\q1
\v 6 ‚ÄĆ ĽE  ĽOtua, ko ho nofo Ľanga  Ľoku lauikuonga pea ta Ľengata:  
\q2 ko e tokotoko  Ľo ho pule Ľanga ko e tokotoko mńĀ Ľoni Ľoni ia.   
\q1
\v 7 ‚ÄĆ ĽOku ke  Ľofa ki he mńĀ Ľoni Ľoni, pea fehi Ľa ki he angahala:  
\q2 ko ia ko e  ĽOtua ko ho  ĽOtua, kuo ne tńĀkai  Ľaki koe  Ľae lolo  Ľoe fiefia  Ľo lahi hake  Ľi ho kńĀinga.   
\q1
\v 8 ‚ÄĆ ĽOku namu mula, mo  Ľalosi, mo kńĀsia,  Ľa ho ngaahi kofu kotoa pńď,  
\q2 mei he ngaahi fale lei,  Ľaia kuo nau fakafiefia Ľi koe.   
\q1
\v 9 Na Ľe  Ľi ho Ľo kau fefine ongolelei  Ľae ngaahi  Ľofefine  Ľoe ngaahi tu Ľi:  
\q2 na Ľe tu Ľu  Ľae tu Ľi fefine  Ľi ho nima to Ľomata Ľu  Ľi he koula mei Ofeli.   
\q1
\v 10 Fakafanongo,  ĽE  Ľofefine, pea tokanga,  Ľo fakatokanga Ľi ho telinga;  
\q2 fakangalo Ľi foki ho Ľo kakai  Ľa Ľau, mo e fale  Ľo ho Ľo tamai;   
\q1
\v 11 Ko ia  Ľe manako lahi ai  Ľae tu Ľi ki ho hoihoifua:  
\q2 he ko ho  ĽEiki ia; pea ke hŇę kiate ia.   
\q1
\v 12 Pea  Ľe  Ľi ai  Ľae  Ľofefine  Ľo Taia mo e me Ľa Ľofa;  
\q2 ko e kau koloa Ľia  Ľi he kakai te nau kumi lahi ki ho Ľo  Ľofa.   
\q1
\v 13 Ko e  Ľofefine  Ľoe tu Ľi  Ľoku lelei lahi  Ľi loto;  
\q2 ko hono ngaahi kofu kuo lalanga  Ľaki  Ľae koula.   
\q1
\v 14 ‚ÄĆ ĽE  Ľomi ia ki he tu Ľi  Ľi he kofu  Ľoku matamatalelei hono tuitui:  
\q2 ko e kau tńĀupo Ľou ko hono kaume Ľa  Ľaia  Ľoku muimui kiate ia  Ľe omi  Ľakinautolu kiate koe.   
\q1
\v 15 ‚ÄĆ ĽE omi  Ľakinautolu  Ľi he fiefia mo e nekeneka:  
\q2 te nau hŇę ki he fale  Ľoe tu Ľi.   
\q1
\v 16 ‚ÄĆ ĽE fetongi ho Ľo ngaahi tamai  Ľe ho Ľo fńĀnau,  
\q2  Ľaia te ke fakanofo ko e ngaahi  Ľeiki  Ľi mńĀmani kotoa pńď.   
\q1
\v 17 Te u fai ke manatu Ľi  Ľa ho huafa  Ľi he to Ľutangata kotoa pńď:  
\q2 ko ia  Ľe fakafeta Ľi  Ľae kakai kiate koe  Ľo lauikuonga pea ta Ľengata.   
\c 46  
\cd \it 1 Ko e tui  Ľae siasi ki he  ĽOtua, 8 Mo e enginaki ke vakai ki ai.\it*  
\d Ki he takimu Ľa  Ľoe ngaahi foha  Ľo Kola, ko e hiva  Ľi he  ĽAlamoti.  
\q1
\v 1 Ko e  ĽOtua ko hotau hŇęfanga mo e mńĀlohi, ko e tokoni lahi pea ofi  Ľi he mamahi.   
\q1
\v 2 Ko ia  Ľe  Ľikai ai te tau manavahńď,  Ľo kapau  Ľe hiki  Ľa mńĀmani,  
\q2 pea kapau  Ľe hiki  Ľae ngaahi mo Ľunga ki he loto tahi;   
\q1
\v 3 Kapau  Ľe  Ľu Ľulu pea hou  Ľa hono ngaahi vai,  
\q2 pea ngalulu  Ľae ngaahi mo Ľunga  Ľi he Ľene mahakehake. \qs Sila.\qs*   
\q1
\v 4 ‚ÄĆ ĽOku ai ha vaitafe, ko hono manga Ľivai  Ľo ia te ne fakafiefia Ľi  Ľae kolo  Ľoe  ĽOtua,  
\q2 ko e potu mńĀ Ľoni Ľoni  Ľoe ngaahi fale fehikitaki  Ľoe Fungani MńĀ Ľolunga.   
\q1
\v 5 ‚ÄĆ ĽOku  Ľi loto  Ľiate ia  Ľae  ĽOtua;  Ľe  Ľikai ue Ľi ia:  
\q2  Ľe tokoni ia  Ľe he  ĽOtua,  Ľi he hoko mai  Ľae pongipongi.   
\q1
\v 6 Na Ľe matalili  Ľae hiteni, na Ľe ngaueue  Ľae ngaahi pule Ľanga:  
\q2 na Ľa ne fakaongo atu hono le Ľo, pea vela  Ľo vai  Ľa mńĀmani.   
\q1
\v 7 Ko Sihova  Ľoe ngaahi kautau  Ľoku  Ľiate kitautolu;  
\q2 ko e  ĽOtua  Ľo Sńďkope ko hotau hŇęfanga. \qs Sila.\qs*   
\q1
\v 8 Ha Ľu,  Ľo vakai ki he ngaahi ngńĀue  Ľa Sihova,  
\q2  Ľae ngaahi faka Ľauha kuo ne fai  Ľi mńĀmani.   
\q1
\v 9 ‚ÄĆ ĽOku ne faka Ľosi  Ľae ngaahi tau  Ľo a Ľu ki he ngata Ľanga  Ľo mńĀmani;  
\q2  Ľoku ne fesi Ľi  Ľae kaufana,  Ľo ne tutu Ľu ke motuua  Ľae tao;  
\q2  Ľoku ne tutu  Ľae saliote  Ľi he afi.   
\q1
\v 10 ‚ÄúMou longo pńď, pea  Ľilo ko au ko e  ĽOtua:  
\q2 te u hakeaki Ľi au  Ľi he lotolotonga  Ľoe hiteni,  
\q2 te u hakeaki Ľi au  Ľi mńĀmani.‚ÄĚ   
\q1
\v 11 Ko Sihova  Ľoe ngaahi kautau  Ľoku  Ľiate kitautolu;  
\q2 ko e  ĽOtua  Ľo Sńďkope ko hotau hŇęfanga. \qs Sila.\qs*   
\c 47  
\cd \it 1‚Äď9 Ko e enginaki ki he ngaahi pule Ľanga kenau fiefie ma Ľu  Ľae pule Ľanga  Ľo Kalaisi.\it*  
\d Ki he Takimu Ľa, ko e Saame ki he ngaahi foha  Ľo Kola.  
\q1
\v 1 Mou pasipasi homou nima,  Ľae kakai kotoa pńď;  
\q2 kalanga ki he  ĽOtua  Ľi he le Ľo  Ľoe fiefia.   
\q1
\v 2 He ko Sihova fungani mńĀ Ľolunga  Ľoku fakailifia ia;  
\q2 ko e Tu Ľi lahi ia ki mńĀmani kotoa pńď.   
\q1
\v 3 Te ne fakavaivai  Ľae kakai kiate kitautolu,  
\q2 mo e ngaahi pule Ľanga ki hotau lalo va Ľe.   
\q1
\v 4 Te ne fili hotau tofi Ľa ma Ľatautolu,  
\q2 ko e lelei  Ľo Sńďkope  Ľaia  Ľoku ne  Ľofa ki ai. \qs Sila.\qs*   
\q1
\v 5 Kuo hńĀ Ľele hake  Ľae  ĽOtua  Ľi he mavava,  
\q2 ko Sihova mo e le Ľo  Ľoe me Ľa lea.   
\q1
\v 6 Hiva fakamńĀlŇć ki he  ĽOtua, hiva fakamńĀlŇć:  
\q2 hiva fakamńĀlŇć ki hotau Tu Ľi, hiva fakamńĀlŇć.   
\q1
\v 7 He ko e  ĽOtua ko e Tu Ľi ia  Ľo mńĀmani kotoa pńď:  
\q2 mou hiva fakamńĀlŇć  Ľi he poto.   
\q1
\v 8 ‚ÄĆ ĽOku pule  Ľae  ĽOtua ki he hiteni:  
\q2  Ľoku  Ľafio  Ľae  ĽOtua  Ľi he  Ľafio Ľanga  Ľo  Ľene mńĀ Ľoni Ľoni.   
\q1
\v 9 Kuo kńĀtoa fakataha  Ľae hou Ľeiki  Ľoe kakai,  
\q2  Ľio, ko e kakai  Ľae  ĽOtua  Ľo  ĽEpalahame:  
\q2  Ľoku  Ľi he  ĽOtua  Ľae ngaahi fakaŇę  Ľo mńĀmani:  
\q2  Ľoku mńĀ Ľolunga lahi  Ľaupito ia.   
\c 48  
\cd \it 1‚Äď14 Ko e teunga mo e lelei  Ľoe siasi.\it*  
\d Ko e Hiva mo e Saame ki he ngaahi foha  Ľo Kola.  
\q1
\v 1 ‚ÄĆ ĽOku lahi  Ľa Sihova, pea  Ľoku lelei ke fakamńĀlŇć lahi kiate ia,  
\q2  Ľi he kolo  Ľa hotau  ĽOtua,  Ľi he mo Ľunga  Ľo  Ľene mńĀ Ľoni Ľoni.   
\q1
\v 2 Ko e tu Ľunga matamatalelei  Ľae mo Ľunga ko Saione,  
\q2 ko e fiefia Ľanga  Ľo mńĀmani kotoa pńď,  
\q2  Ľoku  Ľi hono potu tokelau  Ľae kolo  Ľoe Tu Ľi lahi.   
\q1
\v 3 ‚ÄĆ ĽOku  Ľilo  Ľae  ĽOtua ko e hŇęfanga  Ľi hono ngaahi fale lahi  Ľo ia.   
\q1
\v 4 Pea vakai, na Ľe fakataha  Ľae ngaahi tu Ľi,  
\q2 na Ľa nau  Ľalu atu fakataha.   
\q1
\v 5 Na Ľa nau mamata ai, pea nau ofo;  
\q2 na Ľa nau mamahi,  
\q2 pea hola.   
\q1
\v 6 Na Ľe tuia  Ľakinautolu  Ľi ai  Ľi he manavahńď,  
\q2 mo e mamahi,  Ľo hangńď ko e fefine  Ľoku langńĀ.   
\q1
\v 7 ‚ÄĆ ĽOku ke maumau Ľi  Ľae ngaahi vaka  Ľo Tasisi  Ľaki  Ľae matangi hahake.   
\q1
\v 8 Hangńď ko ia na Ľa mau fanongo, kuo pehńď  Ľemau mamata  
\q2  Ľi he kolo  Ľa Sihova  Ľoe ngaahi kautau,  Ľi he kolo  Ľa hotau  ĽOtua:  
\q2  Ľe fakatu Ľuma Ľu ia  Ľe he  ĽOtua  Ľo ta Ľengata. \qs Sila.\qs*   
\q1
\v 9 Kuo mau manatu ki ho Ľo  Ľalo Ľofa,  ĽE  ĽOtua,  
\q2  Ľi ho loto faletapu.   
\q1
\v 10 ‚ÄĆ ĽO hangńď ko ho huafa,  ĽE  ĽOtua,  
\q2  Ľoku pehńď ho ongoongolelei ki he ngaahi ngata Ľanga  Ľo mńĀmani;  
\q2  Ľoku pito ho nima to Ľomata Ľu  Ľi he mńĀ Ľoni Ľoni.   
\q1
\v 11 Tuku ke fiefia  Ľae mo Ľunga ko Saione,  
\q2 tuku ke nekeneka  Ľae ngaahi  Ľofefine  Ľo Siuta,  
\q2 ko e me Ľa  Ľi ho Ľo ngaahi fakamaau.   
\q1
\v 12 Mou  Ľeve Ľeva takatakai  Ľi Saione,  Ľo  Ľalu fakatakamilo  Ľiate ia:  
\q2 lau hono ngaahi fale mńĀ Ľolunga  Ľo ia.   
\q1
\v 13 Mou vakai lelei ki hono ngaahi puke,  
\q2 tokanga ki hono ngaahi fale lahi;  
\q2 koe Ľuhi ke mou tala ia ki he to Ľutangata  Ľe hoko.   
\q1
\v 14 ‚ÄúHe ko e  ĽOtua ni ko hotau  ĽOtua  Ľo lauikuonga pea ta Ľengata:  
\q2 te ne tauhi  Ľakitautolu  Ľo a Ľu ki he mate.‚ÄĚ   
\c 49  
\cd \it 1 Ko e enginaki ke fokotu Ľu  Ľae tui ki he toetu Ľu  Ľi he  ĽOtua, kae  Ľikai  Ľi he mńĀlohi fakamaama. 16  ĽOua na Ľa  Ľofa ki he monŇę Ľia fakamaama.\it*  
\d Ki he Takimu Ľa, ko e Saame ki he ngaahi foha  Ľo Kola.  
\q1
\v 1 Mou fanongo ki he me Ľa ni,  Ľae kakai kotoa pńď;  
\q2 fakafanongo,  Ľakimoutolu kotoa pńď  Ľoku nofo  Ľi mńĀmani:   
\q1
\v 2 ‚ÄĆ ĽAe mńĀ Ľulalo mo e mńĀ Ľolunga,  
\q2  Ľae ma Ľume Ľa mo e masiva, fakataha.   
\q1
\v 3 ‚ÄĆ ĽE lea hoku ngutu  Ľi he poto;  
\q2 pea  Ľe kau ki he  Ľilo  Ľae fakakaukau  Ľa hoku loto.   
\q1
\v 4 Te u fakatokanga Ľi hoku telinga ki he lea fakatńĀtńĀ:  
\q2 te u fakahńĀ  Ľi he ha Ľape  Ľeku lea  Ľilongata Ľa.   
\q1
\v 5 Ko e hńĀ te u manavahńď ai  Ľi he ngaahi  Ľaho  Ľoe kovi,  
\q2  Ľoka takatakai au  Ľe he hia  Ľo hoku va Ľe?   
\q1
\v 6 Ko kinautolu  Ľoku falala ki he Ľenau mńĀlohi,  
\q2  Ľo polepole  Ľi hono lahi  Ľo  Ľenau koloa;   
\q1
\v 7 ‚ÄĆ ĽOku  Ľikai  Ľaupito fa Ľa fai  Ľe hanau tokotaha ke huhu Ľi hono tokoua,  
\q2 pe  Ľatu ki he  ĽOtua hano totongi:   
\q1
\v 8 He ko e huhu Ľi  Ľo honau laumńĀlie  Ľoku mahu Ľinga lahi,  
\q2 pea  Ľoku tuku ai pe ia  Ľo ta Ľengata:   
\q1
\v 9 Koe Ľuhi ke ne kei mo Ľui ma Ľuaipńď,  
\q2 pea  Ľikai  Ľilo  Ľae  Ľau Ľauha.   
\q1
\v 10 He  Ľoku ne mamata  Ľoku mate  Ľae kau tangata poto,  
\q2 pea  Ľoku  Ľauha foki  Ľae tangata vale pea mo e ta Ľe Ľilo,  
\q2  Ľonau tuku  Ľenau koloa ki he kakai kehe.   
\q1
\v 11 ‚ÄĆ ĽOku mahalo  Ľa honau loto,  Ľe tu Ľuma Ľu pńď honau fale  Ľo ta Ľengata,  
\q2 mo honau ngaahi nofo Ľanga ki he to Ľutangata kotoa pńď;  
\q2  Ľoku nau fakahingoa honau  Ľapi ki honau hingoa  Ľonautolu.   
\q1
\v 12 Ka ko e mo Ľoni ko e tangata  Ľoku mńĀ Ľolunga  Ľoku  Ľikai tu Ľuma Ľu ia:  
\q2  Ľoku tatau ia mo e fanga manu  Ľoku  Ľauha.   
\q1
\v 13 Pea ko honau hala ni ko  Ľenau vale ia:  
\q2 ka  Ľoku mńĀlie Ľia honau hako  Ľi he Ľenau ngaahi lea. \qs Sila.\qs*   
\q1
\v 14 Kuo tuku  Ľakinautolu ki he fa Ľitoka  Ľo hangńď ko e fanga sipi;  
\q2  Ľe fafanga  Ľaki  Ľae mate  Ľakinautolu;  
\q1 pea  Ľe ma Ľu  Ľae mńĀlohi kiate kinautolu  Ľe he kakai angatonu  Ľi he pongipongi;  
\q2 pea  Ľe  Ľauha honau matamatalelei  Ľi he fa Ľitoka mei honau nofo Ľanga.   
\q1
\v 15 Ka  Ľe huhu Ľi hoku laumńĀlie  Ľe he  ĽOtua mei he mńĀlohi  Ľoe fa Ľitoka:  
\q2 he te ne ma Ľu au. \qs Sila.\qs*   
\q1
\v 16 ‚ÄĆ ĽOua na Ľa ke manavahńď koe  Ľoka hoko  Ľo koloa Ľia ha tokotaha,  
\q2  Ľi he tupu pńď  Ľae nńĀunau  Ľo hono fale;   
\q1
\v 17 He  Ľoka mate ia  Ľe  Ľikai te ne fua  Ľo  Ľave ha me Ľa  Ľe taha:  
\q2  Ľe  Ľikai muimui hifo  Ľiate ia hono nńĀunau.   
\q1
\v 18 Ka  Ľi he Ľene mo Ľui na Ľa ne tńĀpuaki hono laumńĀlie:  
\q2 pea  Ľe fakamńĀlŇć  Ľae kakai kiate koe,  Ľoka ke ka fai lelei kiate koe.   
\q1
\v 19 ‚ÄĆ ĽE  Ľalu ia ki he to Ľutangata  Ľo  Ľene ngaahi tamai;  
\q2  Ľe  Ľikai tenau mamata ki he maama.   
\q1
\v 20 Ko e tangata  Ľoku mńĀ Ľolunga, ka  Ľoku  Ľikai poto,  
\q2  Ľoku tatau ia mo e fanga manu  Ľoku  Ľauha.   
\c 50  
\cd \it 1 Ko e nńĀunau  Ľoe  ĽOtua  Ľi he siasi, 5 Mo  Ľene fekau ke tńĀnaki  Ľae kakai mńĀ Ľoni Ľoni. 7  ĽOku  Ľikai fiemńĀlie  Ľae  ĽOtua  Ľi he ngaahi feilaulau, 14 Ka  Ľi he mo Ľoni  Ľoe talangofua.\it*  
\d Ko e Saame  Ľa  ĽAsafi.  
\q1
\v 1 Kuo folofola  Ľa Sihova, ko e  ĽOtua MńĀfimafi,  
\q2  Ľo ui ki mńĀmani ki he potu hopo Ľanga  Ľoe la ĽńĀ  Ľo a Ľu atu ki hono tŇć Ľanga.   
\q1
\v 2 Mei Saione, ko e fungani  Ľoe matamatalelei haohaoa,  
\q2 kuo ulo  Ľae  ĽOtua.   
\q1
\v 3 ‚ÄĆ ĽE hńĀ Ľele mai hotau  ĽOtua, pea  Ľe  Ľikai fakalongo pńď:  
\q2  Ľe faka Ľauha  Ľe he afi  Ľi hono  Ľao,  
\q2 pea  Ľe takatakai ia  Ľe he afńĀ lahi.   
\q1
\v 4 Te ne ui ki he ngaahi langi mei  Ľolunga,  
\q2 pea ki mńĀmani, koe Ľuhi ke ne fakamaau hono kakai.   
\q1
\v 5 ‚ÄúTńĀnaki fakataha kiate au  Ľeku kakai mńĀ Ľoni Ľoni;  Ľakinautolu kuo fai  Ľae fuakava mo au  Ľi he feilaulau.‚ÄĚ   
\q1
\v 6 Pea  Ľe fakahńĀ  Ľe he ngaahi langi  Ľene mńĀ Ľoni Ľoni:  
\q2 he ko e  ĽOtua pńď ko e fakamaau. \qs Sila.\qs*   
\q1
\v 7 ‚ÄúFanongo mai,  ĽE hoku kakai, pea te u lea;  
\q2 pea te u fakapapau kiate koe,  ĽE  ĽIsileli:  
\q2 ko au ko e  ĽOtua,  Ľio, ko ho  ĽOtua.   
\q1
\v 8 ‚ÄĆ ĽE  Ľikai te u valoki Ľi koe koe Ľuhi ko ho Ľo ngaahi feilaulau,  
\q2 pe ko ho Ľo ngaahi feilaulau tutu, ke fai ma Ľu pe  Ľi hoku  Ľao.   
\q1
\v 9 ‚ÄĆ ĽE  Ľikai te u to Ľo ha pulu mei ho fale,  
\q2 pe ha kosi tangata mei ho ngaahi loto ĽńĀ.   
\q1
\v 10 He  Ľoku  Ľa Ľaku  Ľae manu kotoa pńď  Ľoe vao,  
\q2 mo e fanga manu  Ľi he mo Ľunga  Ľe afe.   
\q1
\v 11 ‚ÄĆ ĽOku ou  Ľilo  Ľae manupuna kotoa pńď  Ľoe ngaahi mo Ľunga:  
\q2 pea  Ľoku  Ľa Ľaku  Ľae ngaahi manu kaivao kotoa pńď  Ľoe ngoue.   
\q1
\v 12 ‚ÄúKapau te u fiekaia,  Ľe  Ľikai te u tala kiate koe:  
\q2 he  Ľoku  Ľa Ľaku  Ľa mńĀmani, mo hono mahu  Ľo ia.   
\q1
\v 13 He te u kai  Ľeau  Ľae kakano  Ľoe fanga pulu tangata,  
\q2 pe inu  Ľae toto  Ľoe fanga kosi?   
\q1
\v 14 ‚ÄĆ ĽAtu  Ľae fakafeta Ľi ki he  ĽOtua;  
\q2 mo ke fai ho Ľo ngaahi fuakava ki he Fungani MńĀ Ľolunga:   
\q1
\v 15 Pea ke ui kiate au  Ľi he  Ľaho  Ľoe mamahi:  
\q2 te u fakamo Ľui koe, pea te ke fakaongoongolelei Ľi au.‚ÄĚ   
\q1
\v 16 Ka  Ľoku pehńď  Ľe he  ĽOtua ki he angakovi,  
\q2 ‚ÄúKo e hńĀ  Ľoku ke kau ai koe ke tala  Ľeku ngaahi fekau,  
\q2 pea ke  Ľai  Ľi ho ngutu  Ľeku fuakava?   
\q1
\v 17 He  Ľoku ke fehi Ľa ki he akonaki,  
\q2 mo ke li Ľaki  Ľeku ngaahi lea ki ho tu Ľa.   
\q1
\v 18 ‚ÄĆ ĽI ho Ľo mamata ki ha kaiha Ľa, na Ľa ke loto leva kiate ia,  
\q2 pea na Ľa ke kau mo e kau tono fefine.   
\q1
\v 19 ‚Äú ĽOku ke tuku ho ngutu ki he kovi,  
\q2 pea  Ľoku fakatupu  Ľe ho  Ľelelo  Ľae kńĀkńĀ.   
\q1
\v 20 ‚ÄĆ ĽOku ke nofo  Ľo lau Ľikovi Ľi ho tokoua;  
\q2  Ľoku ke fakakovi Ľi  Ľae tama  Ľa ho Ľo fa Ľńď  Ľa Ľau.   
\q1
\v 21 Na Ľa ke fai  Ľae ngaahi me Ľa ni, pea ne u fakalongo pńď;  
\q2 na Ľa ke mahalo  Ľoku ou hangńď tofu pe ko koe: ka te u valoki Ľi koe,  Ľo fokotu Ľu ia  Ľi ho  Ľao.   
\q1
\v 22 Ko eni, mou tokanga ki he me Ľa ni,  Ľakimoutolu  Ľoku fakangalongalo Ľi  Ľae  ĽOtua,  
\q2 telia na Ľaku haehae ke fakaikiiki  Ľakimoutolu, pea  Ľe  Ľikai ha taha ke fakamo Ľui.   
\q1
\v 23 ‚ÄúKo ia  Ľoku ne  Ľatu  Ľae fakafeta Ľi  Ľoku ne fakaongoongolelei Ľi au:  
\q2 pea ko ia  Ľoku ne fakatonutonu hono hala te u fakahńĀ kiate ia  Ľae fakamo Ľui  Ľoe  ĽOtua.‚ÄĚ   
\c 51  
\cd \it 1  ĽOku lotu  Ľa Tevita ke ne ma Ľu  Ľae fakamolemole,  Ľo ne vete  Ľene angahala. 6  ĽOku ne kole ki he mńĀ Ľoni Ľoni. 16  ĽOku  Ľikai fiemńĀlie  Ľae  ĽOtua  Ľi he feilaulau, ka  Ľi he mo Ľoni. 18  ĽOku ne hŇęfia  Ľae siasi.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita,  Ľi he ha Ľu kiate ia  Ľae palŇćfita ko Natani, hili  Ľene fai kovi mo Patisepa.  
\q1
\v 1 ‚ÄĆ ĽAlo Ľofa mai kiate au,  ĽE  ĽOtua,  Ľo fakatatau ki ho Ľo manava Ľofa:  
\q2 ke ke tńĀmate Ľi  Ľeku ngaahi angahala  Ľo fakatatau ki hono lahi  Ľo ho Ľo ngaahi  Ľalo Ľofa ongongofua.   
\q1
\v 2 Ke ke fufulu  Ľaupito au mei he Ľeku hia,  
\q2 mo fakama Ľa au mei he Ľeku angahala:   
\q1
\v 3 He  Ľoku ou fakamo Ľoni  Ľeku ngaahi talangata Ľa:  
\q2 pea  Ľoku tu Ľuma Ľu aipńď  Ľi hoku  Ľao  Ľeku angahala.   
\q1
\v 4 Na Ľaku fai angahala kiate koe,  
\q2  Ľio, kiate koe pńď kuo u fai  Ľae kovi ni  Ľi ho  Ľao;  
\q1 koe Ľuhi ke tonuhia pe  Ľa koe  Ľoka ke ka folofola,  
\q2 pea mńĀ Ľoni Ľoni  Ľoka ke ka fai  Ľae fakamaau.   
\q1
\v 5 Vakai, na Ľe fanau Ľi au  Ľi he angakovi pea na Ľe tu Ľitu Ľia  Ľeku fa Ľńď  Ľiate au ko e angahala.   
\q1
\v 6 Vakai,  Ľoku ke finangalo ki he mo Ľoni  Ľi loto:  
\q2 pea  Ľi he fufŇę te ke ngaohi ai au ke u  Ľilo  Ľae poto.   
\q1
\v 7 Ke ke fakama Ľa au  Ľaki  Ľae  Ľisope, pea te u ma Ľa ai:  
\q2 fufulu au, pea te u hinehina lahi  Ľi he  Ľuha hinehina.   
\q1
\v 8 Tuku ke u fanongo ki he fiefia mo e nekeneka;  
\q2 ke fiemńĀlie ai  Ľae ngaahi hui kuo ke fesi Ľi.   
\q1
\v 9 Ke ke fufŇę ho fofonga mei he Ľeku angahala,  
\q2 mo ke tńĀmate Ľi  Ľeku ngaahi hia kotoa pńď.   
\q1
\v 10 ‚ÄĆ ĽE  ĽOtua, ke ke fakatupu  Ľiate au  Ľae loto ma Ľa;  
\q2 mo ke fakafo Ľou  Ľiate au ha laumńĀlie tu Ľuma Ľu.   
\q1
\v 11 ‚ÄĆ ĽOua na Ľa ke li Ľaki au mei ho  Ľao pea  Ľoua na Ľa ke to Ľo  Ľiate au ho laumńĀlie mńĀ Ľoni Ľoni.   
\q1
\v 12 Toe  Ľomi kiate au  Ľae fiefia  Ľo ho Ľo fakamo Ľui;  
\q2 mo ke poupou  Ľaki au ho laumńĀlie tau ĽatńĀina.   
\q1
\v 13 Pea te u akonaki  Ľaki  Ľae kau talangata Ľa  Ľa ho ngaahi hala;  
\q2 pea  Ľe liliu kiate koe  Ľae kau angahala.   
\q1
\v 14 ‚ÄĆ ĽE  ĽOtua, ko e  ĽOtua  Ľo  Ľeku mo Ľui, ke ke fakamo Ľui au mei he hia  Ľoe toto:  
\q2 pea  Ľe hiva kalanga  Ľa hoku  Ľelelo  Ľi ho Ľo mńĀ Ľoni Ľoni.   
\q1
\v 15 ‚ÄĆ ĽE  ĽEiki ke ke fa Ľai hoku loungutu,  
\q2 pea  Ľe fakahńĀ atu  Ľe hoku ngutu  Ľa ho Ľo fakamńĀlŇć.   
\q1
\v 16 He  Ľoku  Ľikai te ke finangalo ki he feilaulau,  
\q2 koe Ľuhi ke u  Ľatu ia:  Ľoku  Ľikai te ke fiemńĀlie  Ľi he feilaulau tutu.   
\q1
\v 17 Ko e ngaahi feilaulau  Ľoe  ĽOtua ko e laumńĀlie mafesi:  
\q2 ko e loto mafesi mo mńĀfofoa,  
\q2  ĽE  ĽOtua,  Ľe  Ľikai te ke manuki Ľi.   
\q1
\v 18 Fai lelei  Ľi ho finangalo lelei ki Saione:  
\q2 ke ke fokotu Ľu hake  Ľae ngaahi  ĽńĀ  Ľo SelŇęsalema.   
\q1
\v 19 Pea te ke fiemńĀlie  Ľi he ngaahi feilaulau  Ľoe mńĀ Ľoni Ľoni,  
\q2 mo e feilaulau tutu, mo e ngaahi feilaulau tutu kotoa:  
\q2 pea te nau toki  Ľatu  Ľae fanga pulu ki ho Ľo feilaulau Ľanga.   
\c 52  
\cd \it 1  ĽOku fakahńĀ  Ľe Tevita  Ľae meheka  Ľa Toeki,  Ľo ne kikite  Ľe  Ľauha ia. 6  ĽE fiefia ai  Ľae kakai mńĀ Ľoni Ľoni. 8  ĽOku fakafeta Ľi  Ľa Tevita  Ľi he Ľene tui ki he  Ľalo Ľofa  Ľae  ĽOtua.\it*  
\d Ki he Takimu Ľa, ko e Saame akonaki  Ľa Tevita,  Ľi he ha Ľu  Ľa Toeki ko e tangata  ĽItomi,  Ľo tala kia Saula,  Ľo ne pehńď kiate ia, kuo ha Ľu  Ľa Tevita ki he fale  Ľo  ĽAhimeleki.  
\q1
\v 1 ‚ÄĆ ĽAe tangata mńĀlohi, ko e hńĀ  Ľoku ke polepole ai koe  Ľi he fai pau Ľu?  
\q2  Ľoku tolonga ma Ľuaipńď  Ľae  Ľalo Ľofa  Ľae  ĽOtua.   
\q1
\v 2 ‚ÄĆ ĽOku langa Ľi  Ľe ho  Ľelelo  Ľae ngaahi me Ľa kovi;  
\q2  Ľo ne fai kńĀkńĀ,  Ľo hangńď ko e tele mńĀsila.   
\q1
\v 3 ‚ÄĆ ĽOku ke  Ľofa lahi ki he kovi  Ľi he lelei;  
\q2 pea ki he loi  Ľi he lea mńĀ Ľoni Ľoni. \qs Sila.\qs*   
\q1
\v 4 ‚ÄĆ ĽAe  Ľelelo kńĀkńĀ,  
\q2  Ľoku ke manako ki he ngaahi lea faka Ľauha.   
\q1
\v 5 Pea  Ľe faka Ľauha foki koe  Ľe he  ĽOtua  Ľo ta Ľengata,  
\q2 te ne to Ľo  Ľo  Ľave koe, pea ta Ľaki koe mei ho nofo Ľanga,  
\q2  Ľo ta Ľaki fu Ľu hake koe mei he fonua  Ľoe mo Ľui. \qs Sila.\qs*   
\q1
\v 6 ‚ÄĆ ĽE mamata foki ki ai  Ľae kakai mńĀ Ľoni Ľoni, pea manavahńď,  
\q2 pea nau kata manuki kiate ia:   
\q1
\v 7 ‚ÄúVakai, ko eni  Ľae tangata na Ľe  Ľikai ma Ľu  Ľae mńĀlohi mei he  ĽOtua;  
\q2 ka na Ľe falala ki he lahi  Ľo  Ľene koloa,  
\q2  Ľo ne fakamńĀlohi ia  Ľi he Ľene kovi.‚ÄĚ   
\q1
\v 8 Ka  Ľoku ou tatau mo e  Ľolive lauma Ľui Ľui  Ľi he fale  Ľoe  ĽOtua:  
\q2  Ľoku ou falala ki he  Ľalo Ľofa  Ľae  ĽOtua  Ľo ta Ľengata pea ta Ľengata.   
\q1
\v 9 Te u fakamńĀlŇć kiate koe  Ľo ta Ľengata, koe Ľuhi kuo ke fai ia  Ľe koe:  
\q2 pea te u tatali ki ho huafa;  
\q2 he  Ľoku lelei ia  Ľi he  Ľao  Ľo ho kakai mńĀ Ľoni Ľoni.   
\c 53  
\cd \it 1  ĽOku fakahńĀ  Ľe Tevita hono kovi  Ľae tangata fakakakano. 4  ĽOku ne faka Ľilo  Ľae kovi ki he angahala  Ľaki  Ľae maama  Ľi honau loto. 6  ĽOku ne vikiviki  Ľi he fakamo Ľui  Ľae  ĽOtua.\it*  
\d Ki he Takimu Ľa  Ľi he Mahalati, ko e Saame akonaki  Ľa Tevita.  
\q1
\v 1 Kuo pehńď  Ľe he vale  Ľi hono loto, ‚Äú ĽOku  Ľikai ha  ĽOtua.‚ÄĚ  
\q2 Kuo kovi  Ľakinautolu, pea kuo nau fai  Ľae kovi fakalielia:  
\q2  Ľoku  Ľikai ha tokotaha  Ľoku fai lelei.   
\q1
\v 2 Na Ľe  Ľafio hifo  Ľae  ĽOtua mei he langi ki he fńĀnau  Ľae tangata, ke vakai pe  Ľoku ai ha ni Ľihi  Ľoku  Ľilo,  
\q2 mo kumi ki he  ĽOtua.   
\q1
\v 3 Kuo foki kotoa pńď kimui  Ľakinautolu:  
\q2 kuo nau hoko  Ľo fakalielia kotoa pńď:  
\q2  Ľoku  Ľikai ha tokotaha  Ľoku fai lelei,  Ľoku  Ľikai  Ľaupito ha taha.   
\q1
\v 4 ‚Äú ĽOku  Ľikai ha  Ľilo  Ľiate kinautolu  Ľoku fai kovi?  
\q2  ĽAkinautolu  Ľoku kai  Ľo  Ľosi hoku kakai  Ľo hangńď ko  Ľenau kai mńĀ:  
\q2 na Ľe  Ľikai te nau ui ki he  ĽOtua.‚ÄĚ   
\q1
\v 5 Pea na Ľe manavahńď lahi ai  Ľakinautolu, ka na Ľe  Ľikai ha me Ľa ke manavahńď ai:  
\q2 he kuo laku kehekehe  Ľe he  ĽOtua  Ľae ngaahi hui  Ľo ia na Ľa ne tau Ľi koe:  
\q1 Kuo ke fakamaa Ľi  Ľakinautolu,  
\q2 he kuo fehi Ľa  Ľae  ĽOtua kiate kinautolu.   
\q1
\v 6 Ko hai te ne foaki mei Saione  Ľae fakamo Ľui ki  ĽIsileli?  
\q2  ĽOka toe  Ľomi  Ľe he  ĽOtua hono kakai kuo pŇćpula,  
\q2  Ľe fiefia ai  Ľa Sńďkope,  
\q2 pea nekeneka  Ľa  ĽIsileli.   
\c 54  
\cd \it 1  ĽOku lńĀunga  Ľa Tevita  Ľi he kakai Sifi,  Ľoku lotu ia ke mo Ľui. 5  ĽI he Ľene tui ki he tokoni  Ľae  ĽOtua,  Ľoku ne fakahńĀ te ne fai  Ľae feilaulau.\it*  
\d Ki he Takimu Ľa  Ľi he Nekina ko e Saame akonaki  Ľa Tevita,  Ľi he ha Ľu  Ľae kakai Sifi,  Ľonau pehńď kia Saula,  ĽIkai  Ľoku fufŇę  Ľa Tevita  Ľiate kimautolu?  
\q1
\v 1 Fakamo Ľui au,  ĽE  ĽOtua,  Ľi ho huafa,  
\q2 mo ke fakamaau au  Ľi ho mńĀlohi.   
\q1
\v 2 Fanongo mai ki he Ľeku lotu,  
\q2  ĽE  ĽOtua fakafanongo ki he ngaahi lea  Ľa hoku ngutu.   
\q1
\v 3 He kuo tu Ľu hake kiate au  Ľae kau muli,  
\q2 pea  Ľoku kumi hoku laumńĀlie  Ľe he kau fakamńĀlohi:  
\q2  Ľoku  Ľikai te nau fokotu Ľu  Ľae  ĽOtua  Ľi honau  Ľao. \qs Sila.\qs*   
\q1
\v 4 Vakai, ko hoku tokoni  Ľae  ĽOtua:  
\q2  Ľoku  Ľiate kinautolu  Ľoku poupou hoku laumńĀlie  Ľae  ĽEiki.   
\q1
\v 5 ‚ÄĆ ĽE totongi  Ľe ia  Ľaki  Ľae kovi ki hoku ngaahi fili:  
\q2 ke ke motuhi  Ľakinautolu  Ľi ho mo Ľoni.   
\q1
\v 6 Te u  Ľatu fiemńĀlie pńď  Ľae feilaulau kiate koe:  
\q2 te u fakamńĀlŇć ki ho huafa,  ĽE Sihova he  Ľoku lelei ia.   
\q1
\v 7 He kuo ne fakamo Ľui au mei he mamahi kotoa pńď:  
\q2 pea kuo mamata  Ľe hoku mata ki hoku ngaahi fili.   
\c 55  
\cd \it 1  ĽOku hanu  Ľa Tevita  Ľi he Ľene lotu  Ľi he Ľene tu ĽutńĀmaki lahi. 9  ĽOku lotu ia koe Ľuhi ko e kovi mo e kńĀkńĀ  Ľa hono ngaahi fili. 16  ĽOku ne fakafiemńĀlie Ľi ia  Ľi he  ĽOtua  Ľi he Ľene fakamo Ľui ia, mo veuveuki hono ngaahi fili.\it*  
\d Ki he Takimu Ľa  Ľi he Nekina, ko e Saame akonaki  Ľa Tevita.  
\q1
\v 1 Fakafanongo ki he Ľeku lotu,  ĽE  Ľotua;  
\q2 pea  Ľoua na Ľa ke fufŇę koe mei he Ľeku lotu tńĀuma Ľu.   
\q1
\v 2 ‚ÄĆ ĽAfio mai kiate au, mo ke ongo Ľi au:  
\q2  Ľoku ou lńĀunga  Ľi he Ľeku mamahi, pea tangi kalanga;   
\q1
\v 3 Koe Ľuhi ko e le Ľo  Ľoe fili,  
\q2 koe Ľuhi ko e ta Ľomia  Ľe he kau angakovi:  
\q1 he kuo nau tuku  Ľae hia kiate au,  
\q2 pea  Ľi he  Ľita  Ľoku nau fehi Ľa kiate au.   
\q1
\v 4 ‚ÄĆ ĽOku mamahi lahi hoku loto  Ľiate au:  
\q2 pea kuo tŇć kiate au  Ľae ngaahi fakailifia  Ľoe mate.   
\q1
\v 5 Kuo hoko kiate au  Ľae manavahńď mo e tetetete,  
\q2 pea kuo lŇćmaki Ľi au  Ľe he lilika.   
\q1
\v 6 Pea na Ľaku pehńď, TaumaińĀ ke u ma Ľu  Ľae kapakau  Ľo hangńď ko e lupe!  
\q2 Koe Ľuhi ke u puna atu, pea fiemńĀlie ai.   
\q1
\v 7 Vakai, te u  Ľalu  Ľo hńď ki he mama Ľo, pea u nofo  Ľi he toafa. \qs Sila.\qs*   
\q1
\v 8 Te u  Ľalu fakato Ľoto Ľo,  
\q2  Ľo hao mei he matangi lahi mo e afńĀ.   
\q1
\v 9 Faka Ľauha,  ĽE Sihova, pea vahevahe honau  Ľelelo:  
\q2 he na Ľaku mamata ki he fakamńĀlohi mo e feke Ľike Ľi  Ľi he kolo.   
\q1
\v 10 ‚ÄĆ ĽOku nau  Ľalu fano ai  Ľi he ngaahi  ĽńĀ  Ľo ia  Ľi he  Ľaho mo e pŇć:  
\q2  Ľoku  Ľi loto  Ľi ai  Ľae pau Ľu mo e mamahi.   
\q1
\v 11 ‚ÄĆ ĽOku  Ľi ai  Ľae kovi:  
\q2  Ľoku  Ľikai mahu Ľi mei hono ngaahi hala  Ľae fakamńĀlohi mo e kńĀkńĀ.   
\q1
\v 12 He na Ľe  Ľikai ko ha fili  Ľaia na Ľa ne lau Ľikovi Ľi au;  
\q2 ka ne pehńď, te u fa Ľa kńĀtaki ia:  
\q1 pea na Ľe  Ľikai ko ia  Ľoku ne fehi Ľa kiate au  Ľaia kuo hiki hake ia kiate au ka ne pehńď,  
\q2 te u fa Ľa fufŇę au meiate ia.   
\q1
\v 13 Ka ko koe ia, ko e tangata  Ľoku ta tatau,  
\q2 ko hoku fakahinohino, mo hoku kaume Ľa.   
\q1
\v 14 Na Ľa ta alea lelei mo au,  
\q2 pea  Ľalu fakataha ki he fale  Ľoe  ĽOtua.   
\q1
\v 15 Ke puke  Ľakinautolu  Ľe he mate,  
\q2 pea tuku ke  Ľalu vave hifo  Ľakinautolu ki hńďtesi:  
\q2 he  Ľoku  Ľi honau ngaahi nofo Ľanga, pea  Ľiate kinautolu  Ľae kovi.   
\q1
\v 16 Ka ko au te u ui ki he  ĽOtua;  
\q2 pea  Ľe fakamo Ľui au  Ľe Sihova.   
\q1
\v 17 ‚ÄĆ ĽI he efiafi, mo e pongipongi, mo e ho ĽatńĀ, te u lotu, mo tangi le Ľo lahi:  
\q2 pea te ne ongo Ľi hoku le Ľo.   
\q1
\v 18 Kuo ne fakamo Ľui hoku laumńĀlie  Ľi he melino mei he tau na Ľe tu Ľu hake kiate au:  
\q2 he na Ľe  Ľiate au  Ľae tokolahi.   
\q1
\v 19 ‚ÄĆ ĽE ongo Ľi  Ľe he  ĽOtua,  Ľaia  Ľoku  Ľafio talu mei mu Ľa,  
\q2 pea te ne tautea  Ľakinautolu. \qs Sila.\qs*  
\q2 Koe Ľuhi  Ľoku  Ľikai te nau feliliu Ľaki,  
\q2 ko ia  Ľoku  Ľikai te nau manavahńď ai ki he  ĽOtua.   
\q1
\v 20 Na Ľa ne mafao atu hono nima kiate kinautolu  Ľaia na Ľe nonofo  Ľi he melino mo ia:  
\q2 kuo maumau Ľi  Ľe ia  Ľene fuakava.   
\q1
\v 21 Ko e ngaahi lea  Ľa hono ngutu na Ľe molemole lahi hake  Ľi he pota,  
\q2 ka na Ľe  Ľi hono loto  Ľae tau:  
\q2 na Ľe molŇę lahi  Ľene ngaahi lea  Ľi he lolo,  
\q2 ka ko e mo Ľoni ko e ngaahi heletńĀ ia kuo unuhi.   
\q1
\v 22 Ke ke tuku ho Ľo kavenga kia Sihova, pea te ne poupou koe:  
\q2  Ľe  Ľikai  Ľaupito te ne tuku ke ngaue  Ľae kakai mńĀ Ľoni Ľoni.   
\q1
\v 23 Ka ko koe,  ĽE  ĽOtua te ke  Ľohifo  Ľakinautolu ki he luo  Ľoe faka Ľauha:  
\q2 ko e kau tangata pani toto mo ngńĀue kńĀkńĀ  Ľe  Ľikai tenau a Ľusia hono vaeua Ľanga  Ľo honau ngaahi  Ľaho;  
\q2 ka te u falala kiate koe.   
\c 56  
\cd \it 1  ĽOku lotu  Ľa Tevita ki he  ĽOtua,  Ľo tui ki he Ľene folofola, pea hanu koe Ľuhi ko hono ngaahi fili. 9  ĽOku fakahńĀ  Ľene falala ki he folofola  Ľae  ĽOtua,  Ľo ne pehńď, te ne fakamńĀlŇć kiate ia.\it*  
\d Ki he Takimu Ľa  Ľi he Sonatilemi-Lehokimi, ko e Saame mahu Ľinga  Ľa Tevita,  Ľi he puke ia  Ľe he kakai Filisitia  Ľi Kata.  
\q1
\v 1 Ke ke  Ľalo Ľofa kiate au,  ĽE  ĽOtua: he  Ľoku fie folo hifo au  Ľe he tangata;  
\q2  Ľoku ne tau Ľi au  Ľi he  Ľaho kotoa,  Ľo ne ta Ľomia au.   
\q1
\v 2 Ko e loto  Ľo hoku ngaahi fili  Ľi he  Ľaho kotoa pńď ke folo hifo au:  
\q2 he  Ľoku tokolahi  Ľakinautolu  Ľoku tau Ľi au,  ĽE Fungani MńĀ Ľolunga.   
\q1
\v 3 ‚ÄĆ ĽI he  Ľaho  Ľoku ou manavahńď ai,  
\q2 te u falala kiate koe.   
\q1
\v 4 Te u fakamńĀlŇć ki he  ĽOtua  Ľi he Ľene folofola;  
\q2  Ľoku ou falala ki he  ĽOtua;  
\q2  Ľe  Ľikai te u manavahńď ki he me Ľa  Ľe fa Ľa fai  Ľe he kakai kiate au.   
\q1
\v 5 ‚ÄĆ ĽOku nau fakakehe  Ľeku ngaahi lea  Ľi he  Ľaho kotoa pńď:  
\q2 ko  Ľenau fakakaukau kotoa pńď ke u kovi ai au.   
\q1
\v 6 ‚ÄĆ ĽOku nau fakataha  Ľakinautolu,  Ľoku nau fakafufŇę  Ľakinautolu,  
\q2  Ľoku nau vakai hoku  Ľalu Ľanga,  Ľi he Ľenau holi ki he Ľeku mo Ľui.   
\q1
\v 7 Te nau hao końĀ  Ľi he Ľenau hia?  
\q2  ĽE  ĽOtua, ke ke lńę ki lalo  Ľae kakai  Ľi he houhau.   
\q1
\v 8 ‚ÄĆ ĽOku ke lau  Ľa  Ľeku  Ľalu fano pńď:  
\q2 ke ke  Ľutu hoku ngaahi lo Ľimata ki ho Ľo hina:  
\q2  Ľikai  Ľoku nau tu Ľu  Ľi ho Ľo tohi?   
\q1
\v 9 ‚ÄĆ ĽO kau ka tangi kiate koe,  Ľe foki kimui ai  Ľa hoku ngaahi fili:  
\q2  Ľoku ou  Ľilo  Ľae me Ľa ni; he  Ľoku  Ľiate au  Ľae  ĽOtua.   
\q1
\v 10 Te u fakamńĀlŇć ki he  ĽOtua  Ľi he Ľene folofola:  
\q2 te u fakamńĀlŇć kia Sihova  Ľi he Ľene folofola.   
\q1
\v 11 Kuo u falala ki he  ĽOtua:  
\q2  Ľe  Ľikai te u manavahńď ki ha me Ľa  Ľe fa Ľa fai  Ľe he tangata kiate au.   
\q1
\v 12 ‚ÄĆ ĽE  ĽOtua,  Ľoku  Ľiate au ho Ľo ngaahi fuakava:  
\q2 te u  Ľatu  Ľae fakamńĀlŇć kiate koe,   
\q1
\v 13 He kuo ke fakamo Ľui hoku laumńĀlie mei he mate:  
\q2 pea  Ľikai te ke fakahaofi hoku va Ľe mei he hinga,  
\q2 koe Ľuhi ke u  Ľeve Ľeva  Ľi he  Ľao  Ľoe  ĽOtua  Ľi he maama  Ľoe kakai mo Ľui?   
\c 57  
\cd \it 1  ĽOku hola  Ľa Tevita ki he  ĽOtua  Ľo lotu, pea hanu  Ľi he Ľene tu ĽutńĀmaki. 7  ĽOku ne enginaki Ľi ia ke falala ki he  ĽOtua.\it*  
\d Ki he Takimu Ľa,  ĽAli-Tasikiti, ko e Saame mahu Ľinga  Ľa Tevita,  Ľi he Ľene hola meia Saula  Ľi he  Ľana.  
\q1
\v 1 Ke ke  Ľalo Ľofa kiate au,  ĽE  ĽOtua, ke ke  Ľalo Ľofa kiate au:  
\q2 he  Ľoku falala hoku laumńĀlie kiate koe:  
\q1  Ľio, pea te u hŇęfanga  Ľi he malu  Ľo ho kapakau,  
\q2 ke  Ľoua ke mole  Ľo ngata  Ľae ngaahi kovi ni.   
\q1
\v 2 Te u tangi ki he  ĽOtua fungani mńĀ Ľolunga,  
\q2 ki he  ĽOtua  Ľoku fai  Ľae ngaahi me Ľa kotoa pńď ma Ľaku.   
\q1
\v 3 Pea te ne fekau mei he langi,  Ľo fakamo Ľui au,  
\q2 mei he lau Ľikovi  Ľo ia  Ľoku ne fie folo au ke  Ľosi. \qs Sila.\qs*  
\q1  ĽE fekau atu  Ľe he  ĽOtua  Ľene  Ľalo Ľofa mo  Ľene mo Ľoni.   
\q1
\v 4 ‚ÄĆ ĽOku  Ľi he lotolotonga  Ľoe fanga laione hoku laumńĀlie:  
\q2 pea  Ľoku ou tokoto mo kinautolu kuo vela,  
\q2  Ľio,  Ľae ngaahi foha  Ľoe tangata, ko honau nifo ko e ngaahi tao mo e ngahau,  
\q2 pea ko honau  Ľelelo ko e heletńĀ mńĀsila.   
\q1
\v 5 ‚ÄĆ ĽE  ĽOtua, ke mńĀ Ľolunga lahi hake koe  Ľi he ngaahi langi;  
\q2 tuku ke mńĀ Ľolunga hake ho nńĀunau  Ľi mńĀmani kotoa pńď.   
\q1
\v 6 Kuo nau teuteu  Ľae kupenga ki hoku tu Ľunga va Ľe;  
\q2 kuo mapelu ki lalo hoku laumńĀlie:  
\q2 na Ľa nau keli  Ľae luo  Ľi hoku  Ľao,  
\q2 pea kuo tŇć ki ai  Ľakinautolu. \qs Sila.\qs*   
\q1
\v 7 ‚ÄĆ ĽOku ma Ľu hoku loto,  ĽE  ĽOtua,  Ľoku ma Ľu hoku loto:  
\q2 te u hiva mo  Ľatu  Ľae fakamńĀlŇć.   
\q1
\v 8 Ke  ĽńĀ hake,  Ľa hoku nńĀunau;  ĽńĀ hake,  Ľae saliteli mo e ha Ľape:  
\q2 te u  ĽńĀ hengihengi hake pe au.   
\q1
\v 9 ‚ÄĆ ĽE  ĽEiki, te u fakamńĀlŇć kiate koe  Ľi he  Ľao  Ľoe kakai:  
\q2 te u hiva kiate koe  Ľi he ngaahi pule Ľanga.   
\q1
\v 10 He  Ľoku lahi ho Ľo  Ľalo Ľofa  Ľo a Ľu ki he ngaahi langi,  
\q2 mo ho Ľo mo Ľoni ki he ngaahi  Ľao.   
\q1
\v 11 ‚ÄĆ ĽE  ĽOtua, ke mńĀ Ľolunga lahi hake koe  Ľi he ngaahi langi:  
\q2 tuku ke mńĀ Ľolunga hake ho nńĀunau  Ľi mńĀmani kotoa pńď.   
\c 58  
\cd \it 1  ĽOku valoki  Ľe Tevita  Ľae kau fakamaau angakovi. 3  ĽOku ne fakahńĀ  Ľae anga  Ľoe kakai angahala. 6  ĽOku tuku  Ľakinautolu ki he fakamaau  Ľae  ĽOtua. 10 Ko e fiefia ai  Ľae kakai mńĀ Ľoni Ľoni.\it*  
\d Ki he Takimu Ľa,  ĽAli-Tasikiti, ko e Saame mahu Ľinga  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽAe fakataha,  Ľoku mo Ľoni  Ľa ho Ľomou lea mńĀ Ľoni Ľoni  Ľakimoutolu?  
\q2  ĽAe ngaahi foha  Ľoe tangata,  Ľoku mou fakamaau totonu końĀ?   
\q1
\v 2 ‚ÄĆ ĽIo,  Ľoku mou fai kovi  Ľi loto;  
\q2  Ľoku mou fakamamafa  Ľae kovi  Ľo homou nima  Ľi mńĀmani.   
\q1
\v 3 Talu  Ľae mńĀvae  Ľae angakovi mo e manńĀva mo  Ľenau hńď:  
\q2  Ľoku nau  Ľalu hńď leva talu  Ľenau fanau Ľi,  Ľi he lea loi.   
\q1
\v 4 Ko honau kona  Ľoku hangńď ko e kona  Ľoe ngata:  
\q2  Ľoku nau tatau mo e ngata tuli  Ľoku ne tńĀpuni hono telinga;   
\q1
\v 5 ‚ÄĆ ĽAia  Ľe  Ľikai tokanga ki he le Ľo  Ľoe kau fakafiemńĀlie,  
\q2 neongo  Ľae poto lahi  Ľoe tangata faiva.   
\q1
\v 6 ‚ÄĆ ĽE  ĽOtua, ke ke sili honau kau nifo  Ľi honau ngutu:  
\q2  ĽE Sihova, paki Ľi  Ľo to Ľo kitu Ľa  Ľae kau nifo lahi  Ľoe fanga laione mui.   
\q1
\v 7 Tuku ke vela  Ľo vai  Ľakinautolu  Ľo hangńď ko e vai  Ľoku tafe ma Ľuaipńď:  
\q2  Ľoka teteke  Ľe ia  Ľene kau fana ke fana  Ľaki  Ľene ngaahi ngahau, tuku ke tu Ľutu Ľu  Ľakinautolu.   
\q1
\v 8 Ke mole  Ľo  Ľosi  Ľakinautolu  Ľo hangńď ko e sineli:  
\q2 tuku ke nau hangńď ko e tama ta Ľehoko  Ľae fefine, koe Ľuhi ke  Ľoua na Ľa nau mamata ki he la ĽńĀ.   
\q1
\v 9 ‚ÄĆ ĽI he te Ľeki vela ki ho Ľomou kulo  Ľae okooko  Ľakau talatala,  
\q2  Ľe  Ľosi  Ľene  Ľave mo Ľui  Ľakinautolu  Ľi hono houhau,  Ľo hangńď ko e  Ľahiohio.   
\q1
\v 10 ‚ÄĆ ĽE fiefia  Ľae mńĀ Ľoni Ľoni  Ľi he Ľene mamata ki he totongi:  
\q2  Ľe fufulu  Ľe ia hono va Ľe  Ľi he toto  Ľoe angakovi.   
\q1
\v 11 Ko ia  Ľe pehńď ai  Ľe he tangata, ‚ÄúKo e mo Ľoni  Ľoku ai  Ľae totongi ki he mńĀ Ľoni Ľoni:  
\q2 ko e mo Ľoni ko e  ĽOtua ia  Ľoku fakamaau  Ľi mńĀmani.‚ÄĚ   
\c 59  
\cd \it 1  ĽOku lotu  Ľa Tevita ke mo Ľui ia mei hono ngaahi fili. 6  ĽOku hanu ia  Ľi he Ľenau fai fakamamahi. 8  ĽOku ne falala ki he  ĽOtua. 11  ĽOku lotu ia telia  Ľakinautolu, 16 Pea fakamńĀlŇć ki he  ĽOtua.\it*  
\d Ki he Takimu Ľa,  ĽAli-Tasikiti, ko e Saame mahu Ľinga  Ľa Tevita,  Ľi he fekau  Ľa Saula ke nau le Ľohi  Ľae fale ke tńĀmate Ľi ia.  
\q1
\v 1 ‚ÄĆ ĽE hoku  ĽOtua, ke ke fakahaofi au mei hoku ngaahi fili:  
\q2 malu Ľi au meiate kinautolu  Ľoku tu Ľu hake kiate au.   
\q1
\v 2 Ke ke fakahaofi au mei he kau fai kovi mo ke fakamo Ľui au mei he kau tangata pani toto.   
\q1
\v 3 Vakai,  Ľoku nau tatali  Ľo lama ki hoku laumńĀlie:  
\q2  ĽE Sihova, kuo kńĀtoa fakataha  Ľae kau mńĀlohi kiate au:  
\q2 ka  Ľoku  Ľikai  Ľi he Ľeku talangata Ľa, pe ko  Ľeku angahala.   
\q1
\v 4 ‚ÄĆ ĽOku nau felele Ľi  Ľo teu Ľi  Ľakinautolu, ka  Ľoku  Ľikai ha Ľaku kovi:  
\q2 ke ke  ĽńĀ ke tokoni au, pea ke  Ľafio Ľi.   
\q1
\v 5 Pea ko koe,  ĽE Sihova, ko e  ĽOtua,  Ľoe ngaahi tokolahi, ko e  ĽOtua  Ľo  ĽIsileli,  
\q2 ke ke  ĽńĀ hake  Ľo  Ľahi Ľahi ki he hiteni kotoa pńď:  
\q2  Ľoua na Ľa ke  Ľalo Ľofa ki he kau angakovi kńĀkńĀ. \qs Sila.\qs*   
\q1
\v 6 ‚ÄĆ ĽOku nau liu mai  Ľi he efiafi:  Ľoku nau longoa Ľa  Ľo hangńď ko e kulńę,  
\q2 pea  Ľalu fakatakamilo  Ľi he kolo.   
\q1
\v 7 Vakai,  Ľoku nau hake  Ľi honau ngutu:  
\q2  Ľoku  Ľi honau loungutu  Ľae ngaahi heletńĀ:  
\q2 he  Ľoku nau pehńď, ‚Äúko hai  Ľoku ne fanongo?‚ÄĚ   
\q1
\v 8 Ka ko koe,  ĽE Sihova, te ke kata kiate kinautolu;  
\q2 te ke manuki ki he hiteni kotoa pńď.   
\q1
\v 9 Pea koe Ľuhi ko  Ľene mńĀlohi ko ia te u tatali ai kiate koe:  
\q2 he ko hoku hŇęfanga  Ľae  ĽOtua.   
\q1
\v 10 Ko e  ĽOtua  Ľoku  Ľalo Ľofa kiate au te ne tokoni au:  
\q2  Ľe tuku kiate au  Ľe he  ĽOtua ke u mamata ki he Ľeku holi ki hoku ngaahi fili.   
\q1
\v 11 ‚ÄĆ ĽOua na Ľa ke tńĀmate Ľi  Ľakinautolu, telia na Ľa ngalo  Ľi hoku kakai;  
\q2 fakahńď Ľi  Ľakinautolu ke mama Ľo  Ľi ho mńĀlohi;  
\q2 pea  Ľohifo ki lalo  Ľakinautolu,  ĽE  ĽEiki, ko homau fakaŇę.   
\q1
\v 12 Ko e me Ľa  Ľi he angahala  Ľa honau ngutu, mo e ngaahi lea  Ľa honau loungutu,  
\q2 tuku ke mo Ľua ai  Ľakinautolu  Ľi he Ľenau laukau:  
\q2 koe Ľuhi ko e kape mo e loi  Ľoku nau lea  Ľaki.   
\q1
\v 13 Faka Ľauha  Ľakinautolu  Ľi he houhau,  
\q2 faka Ľauha  Ľakinautolu ke  Ľoua na Ľa kei ai  Ľakinautolu:  
\q1 pea tuku ke  Ľilo  Ľekinautolu  Ľoku pule,  Ľae  ĽOtua,  Ľia Sńďkope,  
\q2  Ľo a Ľu ki he ngaahi ngata Ľanga  Ľo mńĀmani. \qs Sila.\qs*   
\q1
\v 14 Pea tuku kenau liu mai  Ľi he efiafi;  
\q2 tuku kenau longoa Ľa  Ľo hangńď ko e kulńę,  Ľo  Ľalu fakatakamilo  Ľi he kolo.   
\q1
\v 15 Tuku kenau  Ľalu  Ľo hńď fano ai pńď  Ľo kumi kai,  
\q2 pea lńĀunga  Ľo kapau  Ľe  Ľikai tenau mńĀkona.   
\q1
\v 16 Ka te u hiva au ki ho mńĀlohi;  
\q2  Ľio, te u hiva mńĀlohi  Ľi ho Ľo  Ľalo Ľofa  Ľi he pongipongi:  
\q1 he ko hoku unga Ľanga koe,  
\q2 mo e hŇęfanga kiate au  Ľi he  Ľaho  Ľo  Ľeku mamahi.   
\q1
\v 17 ‚ÄĆ ĽE hoku mńĀlohi, te u hiva kiate koe:  
\q2 he ko hoku kalofanga  Ľae  ĽOtua, ko e  ĽOtua  Ľoku  Ľalo Ľofa kiate au.   
\c 60  
\cd \it 1  ĽOku hanu  Ľa Tevita ki he  ĽOtua  Ľi he fakamaau  Ľi mu Ľa. 4  ĽOku ne lotu ke mo Ľui, pea  Ľamanaki lelei ki ai. 6  ĽOku ne fakafiemńĀlie Ľi ia  Ľi he ngaahi tala Ľofa  Ľae  ĽOtua,  Ľaia  Ľoku ne falala ki ai.\it*  
\d Ki he Takimu Ľa  Ľi he Susani-Etuta, ko e Saame mahu Ľinga  Ľa Tevita, ke ako  Ľaki;  Ľi he Ľene tau Ľi  Ľa  ĽElama-Nahalaimi mo  ĽElama-Sopa, pea liu mai  Ľa Soape,  Ľo ne tńĀmate Ľi  Ľi he luo  Ľoe mńĀsima  Ľae tokotaha mano ma toko ua afe  Ľoe kakai  ĽItomi.  
\q1
\v 1 ‚ÄĆ ĽE  ĽOtua, kuo ke li Ľaki  Ľakimautolu;  
\q2 kuo ke veteki  Ľakimautolu;  
\q2 na Ľa ke houhau;  
\q2 ke ke toe tafoki mai kiate kimautolu.   
\q1
\v 2 Kuo ke lulu  Ľae fonua ke tetetete;  
\q2 kuo mafahifahi ia:  
\q2 ke ke fakalelei hono ngaahi maumau;  
\q2 he  Ľoku ngalulu ia.   
\q1
\v 3 Kuo ke fakahńĀ  Ľae ngaahi me Ľa faingata Ľa ki ho Ľo kakai;  
\q2 kuo ke fakainu  Ľaki  Ľakimautolu  Ľae uaine fakaofo.   
\q1
\v 4 Kuo ke foaki  Ľae fuka kiate kinautolu na Ľe manavahńď kiate koe,  
\q2 ke fakahńĀ ia koe Ľuhi ko e mo Ľoni. \qs Sila.\qs*   
\q1
\v 5 Koe Ľuhi ke hao  Ľaia  Ľoku ke  Ľofa ai;  
\q2 ke ke fakamo Ľui  Ľaki ho nima to Ľomata Ľu,  
\q2  Ľo fanongo kiate au.   
\q1
\v 6 Kuo folofola  Ľae  ĽOtua  Ľi he Ľene mńĀ Ľoni Ľoni;  
\q2 ‚ÄúTe u fiefia, te u vaeua  Ľa Sikemi,  
\q2  Ľo fuofua  Ľae luo  Ľo Sukote.   
\q1
\v 7 ‚ÄĆ ĽOku  Ľo Ľoku  Ľa Kiliati, pea  Ľo Ľoku mo Manase;  
\q2 ko e mńĀlohi foki  Ľo hoku  Ľulu  Ľa  ĽIfalemi;  
\q2 ko  Ľeku fai fono  Ľa Siuta;   
\q1
\v 8 Ko  Ľeku ipu kaukau Ľanga  Ľa Moape;  
\q2 te u lńę hoku topuva Ľe ki  Ľolunga ki  ĽItomi:  
\q2 Filisitia, ke ke vikiviki koe koe Ľuhi ko au.‚ÄĚ   
\q1
\v 9 Ko hai te ne  Ľomi au ki he kolo mńĀlohi?  
\q2 Ko hai te ne a Ľutaki au ki  ĽItomi?   
\q1
\v 10 ‚ÄĆ ĽE  ĽOtua,  Ľe  Ľikai te ke fai ia,  Ľa koe kuo ke li Ľaki  Ľakimautolu?  
\q2  ĽA koe,  ĽE  ĽOtua, na Ľe  Ľikai te ke  Ľalu mo  Ľemau ngaahi kautau?   
\q1
\v 11 Ke ke tuku kiate kimautolu  Ľae tokoni mei he mamahi:  
\q2 he  Ľoku ta Ľe Ľaonga  Ľae tokoni  Ľae tangata.   
\q1
\v 12 Ko e me Ľa  Ľi he  ĽOtua te tau fai mńĀlohi ai:  
\q2 he ko ia ia te ne malaki hifo hotau ngaahi fili.   
\c 61  
\cd \it 1  ĽOku hola  Ľa Tevita ki he  ĽOtua  Ľi he Ľene  Ľilo  Ľene fa Ľa tokoni kiate ia. 4  ĽOku ne fuakava ke tauhi ma Ľuaipńď kiate ia, koe Ľuhi ko  Ľene ngaahi tala Ľofa.\it*  
\d Ki he Takimu Ľa  Ľi he Nekina, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE  ĽOtua, ke ke fanongo ki he Ľeku tangi;  
\q2 tokanga ki he Ľeku lotu.   
\q1
\v 2 Te u tangi kiate koe mei he ngata Ľanga  Ľo mńĀmani,  Ľoka ta Ľomia hoku loto:  
\q2 ke ke tataki au ki he maka  Ľoku mńĀ Ľolunga hake  Ľiate au.   
\q1
\v 3 He na Ľa ke hoko ko hoku ungaki Ľi,  
\q2 ko e fale mńĀ Ľolunga pea mńĀlohi ki he fili.   
\q1
\v 4 Te u nofoma Ľu  Ľi ho fale fehikitaki  Ľo ta Ľengata:  
\q2 te u falala ki he malu  Ľo ho kapakau. \qs Sila.\qs*   
\q1
\v 5 He kuo ke fanongo ki he Ľeku ngaahi fuakava,  ĽE  ĽOtua:  
\q2 kuo ke foaki kiate au  Ľae tofi Ľa  Ľokinautolu  Ľoku manavahńď ki ho huafa.   
\q1
\v 6 Te ke fakatolonga  Ľae mo Ľui  Ľae tu Ľi,  
\q2 mo hono ngaahi ta Ľu  Ľo hangńď mei he to Ľutangata ki he to Ľutangata.   
\q1
\v 7 ‚ÄĆ ĽE nofoma Ľu ia  Ľi he  Ľao  Ľoe  ĽOtua ta Ľengata:  
\q2 ke ke teuteu  Ľae  Ľalo Ľofa mo e mo Ľoni  Ľaia te na fakamo Ľui ia.  
\q1 Ko ia te u hiva fakamńĀlŇć ai ki ho huafa  Ľo ta Ľengata,  
\q2 koe Ľuhi ke u fai ki he Ľeku ngaahi fuakava  Ľi he  Ľaho kotoa pńď.   
\q1
\v 8 Ko ia te u hiva fakamńĀlŇć ai ki ho huafa  Ľo ta Ľengata,  
\q2 koe Ľuhi ke u fai ki he Ľeku ngaahi fuakava  Ľi he  Ľaho kotoa pńď.   
\c 62  
\cd \it 1  ĽOku fakahńĀ  Ľe Tevita  Ľene falala ki he  ĽOtua, pea ne valoki hono ngaahi fili. 5  ĽOku fie tokoni ki he angalelei. 9  ĽOku ta Ľe Ľaonga ke falala ki he ngaahi me Ľa fakamaama. 11  ĽOku  Ľi he  ĽOtua  Ľae mńĀfimafi mo e  Ľalo Ľofa.\it*  
\d Ki he Takimu Ľa ko Situtuni, ko e Saame  Ľa Tevita.  
\q1
\v 1 Ko e mo Ľoni  Ľoku tatali hoku laumńĀlie ki he  ĽOtua:  
\q2  Ľoku meiate ia hoku fakamo Ľui.   
\q1
\v 2 Ko ia pńď ko hoku makatu Ľu mo hoku fakamo Ľui; ko hoku hŇęfanga ia;  
\q2  Ľe  Ľikai fa Ľa ue Ľi lahi au.   
\q1
\v 3 ‚ÄĆ ĽE fńďfńď hono fuoloa mo ho Ľomou kei filio Ľi kovi ki he tangata?  
\q2  Ľe tńĀmate Ľi  Ľakimoutolu kotoa pńď:  
\q2 te mou hangńď ko e  ĽńĀ kuo malele, mo e  ĽńĀ  Ľoku tu Ľu tetetete.   
\q1
\v 4 ‚ÄĆ ĽOku nau fakakaukau ke tulaki hifo ia mei he Ľene lelei:  
\q2  Ľoku nau fiemńĀlie pe  Ľi he loi:  
\q2  Ľoku nau tńĀpuaki  Ľaki honau ngutu, ka  Ľoku nau kape  Ľi loto. \qs Sila.\qs*   
\q1
\v 5 ‚ÄĆ ĽE hoku laumńĀlie, ke ke tatali pe ki he  ĽOtua;  
\q2 he  Ľoku meiate ia  Ľeku  Ľamanaki lelei.   
\q1
\v 6 Ko ia pe ko hoku makatu Ľu mo hoku fakamo Ľui: ko hoku hŇęfanga ia;  
\q2  Ľe  Ľikai fa Ľa ue Ľi au.   
\q1
\v 7 ‚ÄĆ ĽOku  Ľi he  ĽOtua  Ľa hoku fakamo Ľui mo  Ľeku fiefia:  
\q2 ko e makatu Ľu  Ľo hoku mńĀlohi, mo hoku hŇęfanga  Ľoku  Ľi he  ĽOtua.   
\q1
\v 8 Falala ma Ľuaipńď kiate ia;  Ľakimoutolu  Ľae kakai,  
\q2 lilingi homou loto  Ľi hono  Ľao:  
\q2 ko e hŇęfanga  Ľae  ĽOtua kiate kitautolu. \qs Sila.\qs*   
\q1
\v 9 Ko e mo Ľoni ko e me Ľa va Ľinga pe  Ľae kau tangata mńĀ Ľulalo,  
\q2 pea ko e me Ľa loi  Ľae kau tangata mńĀ Ľolunga:  
\q2 kapau  Ľe  Ľai ki he me Ľa fakamamafa,  
\q2  Ľoku nau ma Ľama Ľa lahi hake kotoa pńď  Ľi he me Ľa va Ľinga.   
\q1
\v 10 ‚ÄĆ ĽOua na Ľa falala ki he fakamńĀlohi pea  Ľoua na Ľa viki  Ľi he kaiha Ľa:  
\q2 kapau  Ľoku tupu  Ľae koloa,  
\q2  Ľoua na Ľa tuku homou loto ki ai.   
\q1
\v 11 Kuo folofola  Ľae  ĽOtua  Ľo tu Ľo taha;  
\q2 pea na Ľe tu Ľo ua  Ľa  Ľeku fanongo eni;  
\q2  Ľoku  Ľi he  ĽOtua  Ľae mńĀlohi.   
\q1
\v 12 Pea  Ľoku  Ľiate koe foki,  ĽE  ĽEiki,  Ľae  Ľalo Ľofa:  
\q2 he  Ľoku ke  Ľange ki he tangata taki taha kotoa pńď  Ľo fakatatau ki he Ľene ngńĀue.   
\c 63  
\cd \it 1 Ko e holi  Ľa Tevita ki he  ĽOtua. 5 Ko e anga  Ľo  Ľene fakafeta Ľi ki he  ĽOtua. 9 Ko  Ľene  Ľamanaki ki he mala Ľia  Ľa hono ngaahi fili, kae mo Ľui pe ia.\it*  
\d Ko e Saame  Ľa Tevita,  Ľi he Ľene  Ľi he toafa  Ľo Siuta.  
\q1
\v 1 ‚ÄĆ ĽE  ĽOtua, ko hoku  ĽOtua koe;  
\q2 te u kumi vave kiate koe:  
\q2  Ľoku fieinu hoku laumńĀlie kiate koe,  
\q2  Ľoku holi hoku kakano kiate koe  Ľi he fonua mŇćmoa mo fieinua,  Ľaia  Ľoku  Ľikai ha vai  Ľi ai;   
\q1
\v 2 Ke mamata ki ho Ľo mńĀfimafi mo ho nńĀunau,  
\q2  Ľo hangńď ko  Ľeku mamata ai kiate koe  Ľi he faletapu.   
\q1
\v 3 ‚ÄĆ ĽOku lelei lahi hake  Ľa ho Ľo  Ľalo Ľofa  Ľi he mo Ľui,  
\q2 ko ia  Ľe fakafeta Ľi ai  Ľa hoku loungutu kiate koe.   
\q1
\v 4 Ko ia  Ľe pehńď pe  Ľeku fakafeta Ľi kiate koe lolotonga  Ľeku mo Ľui:  
\q2 te u hiki hake hoku nima  Ľi ho huafa.   
\q1
\v 5 ‚ÄĆ ĽE mńĀkona lelei hoku laumńĀlie  Ľo hangńď ko e me Ľa  Ľi he ngako mo e me Ľa momona;  
\q2 pea  Ľe fakafeta Ľi kiate koe  Ľa hoku ngutu  Ľi he loungutu fiefia.   
\q1
\v 6 ‚ÄĆ ĽI he Ľeku manatu kiate koe  Ľi hoku mohenga,  
\q2  Ľo fakalaulauloto kiate koe  Ľi he ngaahi lakanga le Ľo  Ľi he po Ľuli.   
\q1
\v 7 Ko e me Ľa  Ľi ho Ľo fa Ľa tokoni au,  
\q2 ko ia te u fiefia ai  Ľi he malu  Ľo ho kapakau.   
\q1
\v 8 ‚ÄĆ ĽOku pikitai ma Ľu pńď hoku laumńĀlie kiate koe:  
\q2  Ľoku poupou au  Ľe ho nima to Ľomata Ľu.   
\q1
\v 9 Ka ko kinautolu  Ľoku kumi hoku laumńĀlie ke faka Ľauha ia,  
\q2 tenau  Ľalu hifo ki he ngaahi potu  Ľi lalo  Ľi he fonua.   
\q1
\v 10 Tenau tŇć  Ľi he heletńĀ:  
\q2 tenau hoko ko e  Ľinasi  Ľoe fanga fokisi.   
\q1
\v 11 Ka  Ľe fiefia  Ľae tu Ľi  Ľi he  ĽOtua;  
\q2 ko ia kotoa pńď  Ľoku fuakava  Ľiate ia  Ľe fiefia ia;  
\q2 ka  Ľe tńĀpuni  Ľae ngutu  Ľokinautolu kotoa pńď  Ľoku lea loi.   
\c 64  
\cd \it 1  ĽOku lotu  Ľa Tevita ke ne mo Ľui, pea hanu ia koe Ľuhi ko hono ngaahi fili. 7  ĽOku  Ľamanaki ia ke mamata ki he faka Ľauha  Ľo hono ngaahi fili, pea  Ľe fiefia ai  Ľae mńĀ Ľoni Ľoni.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita.  
\q1
\v 1 Fanongo ki hoku le Ľo,  ĽE  ĽOtua,  Ľi he Ľeku lotu:  
\q2 fakahaofi  Ľeku mo Ľui mei he manavahńď ki he fili.   
\q1
\v 2 FakafufŇę au mei he filio Ľi  Ľae kau angahala;  
\q2 mei he angatu Ľu fakamaveuveu  Ľoe kau fai kovi:   
\q1
\v 3 ‚ÄĆ ĽOku nau fakamata honau  Ľelelo  Ľo hangńď ko e heletńĀ,  
\q2  Ľonau teke  Ľenau kaufana ke fana Ľi  Ľenau ngaahi ngahau,  Ľio, ko e ngaahi lea kona.   
\q1
\v 4 Koe Ľuhi ke nau fana  Ľi he lilo ki he haohaoa:  
\q2  Ľoku nau fana fakafokifńĀ pe kiate ia,  Ľo ta Ľemanavahńď.   
\q1
\v 5 ‚ÄĆ ĽOku nau fetokoni Ľaki  Ľakinautolu  Ľi he me Ľa kovi:  
\q2  Ľoku nau fakakaukau ke tau  Ľae ngaahi tauhele  Ľi he lilo;  
\q2  Ľoku nau pehńď, ‚ÄúKo hai te ne mamata kiate kimautolu?‚ÄĚ   
\q1
\v 6 ‚ÄĆ ĽOku nau kumi ke  Ľilo  Ľae ngaahi kovi  Ľoku nau fa Ľa  Ľeke ke lahi:  
\q2  Ľoku taumama Ľo  Ľae mahalo mo e loto  Ľokinautolu kotoa pńď.   
\q1
\v 7 Ka  Ľe fana  Ľe he  ĽOtua kiate kinautolu  Ľaki  Ľae ngahau;  
\q2 te nau lavea fakafokifńĀ pe.   
\q1
\v 8 Ko ia tenau ngaohi honau  Ľelelo ke tŇć kiate kinautolu:  
\q2  Ľe hola  Ľakinautolu kotoa pńď  Ľoku mamata kiate kinautolu.   
\q1
\v 9 Pea  Ľe manavahńď  Ľae tangata kotoa pńď,  
\q2  Ľonau fakahńĀ  Ľae ngńĀue  Ľae  ĽOtua;  
\q2 he tenau fakakaukau poto ki he Ľene ngńĀue.   
\q1
\v 10 ‚ÄĆ ĽE fiefia  Ľae mńĀ Ľoni Ľoni  Ľi he  ĽEiki,  
\q2 pea falala kiate ia;  
\q2 pea vikiviki ai  Ľakinautolu kotoa pńď  Ľoku angatonu  Ľi loto.   
\c 65  
\cd \it 1  ĽOku fakamńĀlŇć  Ľa Tevita ki he  ĽOtua koe Ľuhi ko  Ľene  Ľofa. 4 Ko e monŇę Ľia  Ľakinautolu kuo fili  Ľe he  ĽOtua koe Ľuhi ko e ngaahi foaki.\it*  
\d Ki he Takimu Ľa, ko e Saame mo e Hiva  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE  ĽOtua,  Ľoku tatali  Ľae fakamńĀlŇć kiate koe  Ľi Saione:  
\q2 pea  Ľe fai kiate koe  Ľae fuakava.   
\q1
\v 2 ‚ÄĆ ĽA koe  Ľoku ke ongo Ľi  Ľae lotu,  
\q2  Ľe a Ľu atu kiate koe  Ľae kakai kotoa pńď.   
\q1
\v 3 ‚ÄĆ ĽOku mńĀlohi kiate au  Ľae ngaahi hia:  
\q2 pea ko  Ľemau ngaahi talangata Ľa te ke fakama Ľa ia ke  Ľosi.   
\q1
\v 4 ‚ÄĆ ĽOku monŇę Ľia ia  Ľaia  Ľoku ke fili,  
\q2 mo ke fakaofi ia kiate koe,  
\q2 koe Ľuhi ke ne nofo  Ľi ho loto ĽńĀ:  
\q2 temau fiemńĀlie  Ľi he lelei  Ľo ho fale,  
\q2  Ľio,  Ľo ho faletapu mńĀ Ľoni Ľoni.   
\q1
\v 5 ‚ÄĆ ĽE  ĽOtua ko homau fakamo Ľui,  
\q2 te ke talia  Ľakimautolu  Ľi he ngaahi me Ľa fakamanavahńď  Ľi he mńĀ Ľoni Ľoni;  
\q2  Ľa koe ko e  Ľamanaki lelei Ľanga  Ľoe ngaahi ngata Ľanga kotoa pńď  Ľo mńĀmani,  
\q2 pea mo kinautolu  Ľoku mama Ľo atu  Ľi he tahi:   
\q1
\v 6 ‚ÄĆ ĽAia  Ľoku ne fokotu Ľuma Ľu  Ľae ngaahi mo Ľunga  Ľi hono mńĀlohi;  
\q2 kuo nono Ľo  Ľaki  Ľae mńĀfimafi:   
\q1
\v 7 ‚ÄĆ ĽAia  Ľoku ne lolomi  Ľae longoa Ľa  Ľoe ngaahi tahi,  
\q2 ko e longoa Ľa  Ľoe ngaahi peau,  
\q2 mo e maveuveu  Ľoe kakai.   
\q1
\v 8 Pea  Ľoku manavahńď  Ľi ho ngaahi faka Ľilonga  Ľakinautolu  Ľoku nofo  Ľi he ngaahi potu mama Ľo:  
\q2  Ľoku ke fakafiefia Ľi  Ľae ngaahi  Ľalu Ľanga  Ľoe pongipongi mo e efiafi.   
\q1
\v 9 ‚ÄĆ ĽOku ke  Ľa Ľahi ki he fonua,  
\q2  Ľo fakaviviku ia:  
\q2  Ľoku ke fakakoloa lahi  Ľaki ia  Ľae vaitafe  Ľoe  ĽOtua,  
\q2  Ľaia  Ľoku pito  Ľi he vai:  
\q2  Ľoku ke teu Ľi  Ľenau me Ľakai, hili ho Ľo tokonaki pehńď ki ai.   
\q1
\v 10 ‚ÄĆ ĽOku ke fakaviviku lahi hono tafungofunga  Ľo ia:  
\q2  Ľoku ke pule ke tŇć  Ľae  Ľuha ki hono ngaahi keli:  
\q2  Ľoku ke fakamolŇę  Ľaki ia  Ľae  Ľuha tu Ľu mo tŇć:  
\q2  Ľoku ke tńĀpuaki hono tupu  Ľo ia.   
\q1
\v 11 ‚ÄĆ ĽOku ke tatńĀ  Ľaki  Ľae ta Ľu  Ľa ho Ľo angalelei;  
\q2 pea  Ľoku ngangana mei ho ngaahi hala  Ľae momona.   
\q1
\v 12 ‚ÄĆ ĽOku ngangana ia ki he ngaahi potu mohuku  Ľoe toafa:  
\q2 pea fiefia  Ľae ngaahi tafungofunga  Ľi he potu kotoa pńď.   
\q1
\v 13 Kuo fakakofu Ľaki  Ľae fanga sipi  Ľae ngaahi potu mohuku;  
\q2 pea kuo  Ľufi Ľufi foki  Ľae ngaahi luo  Ľaki  Ľae uite;  
\q2  Ľoku nau kalanga  Ľi he fiefia,  
\q2  Ľoku nau hiva foki.   
\c 66  
\cd \it 1  ĽOku enginaki Ľi  Ľe Tevita ke fakamńĀlŇć ki he  ĽOtua, 5 Ke tokanga ki he Ľene ngaahi ngńĀue lahi, 8 Ke fakafeta Ľi kiate ia  Ľi he Ľene ngaahi tńĀpuaki. 12  ĽOku fuakava ia ke ne tauhi  Ľae  ĽOtua. 16  ĽOku ne fakahńĀ  Ľae angalelei  Ľae  ĽOtua kiate ia.\it*  
\d Ki he Takimu Ľa, ko e Hiva pe ko e Saame.  
\q1
\v 1 Mou kalanga fiefia ki he  ĽOtua,  Ľae fonua kotoa pńď:   
\q1
\v 2 Hiva  Ľaki  Ľae ongoongolelei  Ľo hono huafa:  
\q2 fakaongoongolelei  Ľae fakamńĀlŇć kiate ia.   
\q1
\v 3 Mou pehńď ki he  ĽOtua, ‚Äú ĽOku ke fakamanavahńď koe  Ľi ho Ľo ngaahi ngńĀue!  
\q2 Ko e me Ľa  Ľi hono lahi  Ľo ho Ľo mńĀfimafi  Ľe fakamo Ľulaloa ai  Ľekinautolu  Ľe ho ngaahi fili kiate koe.   
\q1
\v 4 ‚ÄĆ ĽE hŇę  Ľa mńĀmani kotoa pńď kiate koe,  
\q2  Ľonau hiva kiate koe;  
\q2 te nau hiva ki ho huafa.‚ÄĚ \qs Sila.\qs*   
\q1
\v 5 Ha Ľu  Ľo mamata ki he ngaahi ngńĀue  Ľae  ĽOtua:  
\q2  Ľoku fakamanavahńď ia  Ľi he Ľene ngńĀue ki he ngaahi fńĀnau  Ľae tangata.   
\q1
\v 6 Na Ľa ne liliu  Ľae tahi ko e fonua mŇćmoa:  
\q2 na Ľa nau  Ľalu  Ľi he fu Ľu vaitafe  Ľi honau va Ľe:  
\q2 na Ľa tau fiefia  Ľiate ia  Ľi ai.   
\q1
\v 7 ‚ÄĆ ĽOku pule ia  Ľi he Ľene mńĀfimafi  Ľo ta Ľengata;  
\q2  Ľoku vakai  Ľe hono fofonga ki he ngaahi pule Ľanga:  
\q2  Ľoua na Ľa hiki hake  Ľakinautolu  Ľe he kau angatu Ľu. \qs Sila.\qs*   
\q1
\v 8 ‚ÄĆ ĽAkimoutolu  Ľae kakai, mou fakafeta Ľi ki hotau  ĽOtua,  
\q2 pea fai ke ongo  Ľae le Ľo  Ľoe fakamńĀlŇć kiate ia:   
\q1
\v 9 ‚ÄĆ ĽAia  Ľoku ne poupou hotau laumńĀlie  Ľi he mo Ľui,  
\q2 pea  Ľikai tuku hotau va Ľe ke ngaue.   
\q1
\v 10 He kuo ke  Ľilo Ľi  Ľakimautolu,  ĽE  ĽOtua:  
\q2 kuo ke  Ľahi Ľahi Ľi  Ľakimautolu,  Ľo hangńď ko e  Ľahi Ľahi Ľi  Ľoe siliva.   
\q1
\v 11 Na Ľa ke  Ľomi  Ľakimautolu ki he kupenga;  
\q2 na Ľa ke  Ľai  Ľae mahaki ki homau kongaloto.   
\q1
\v 12 Na Ľa ke tuku ke laka  Ľae kakai  Ľi homau  Ľulu;  
\q2 na Ľa mau  Ľalu pe  Ľi he afi mo e vai:  
\q2 ka na Ľa ke  Ľomi  Ľakimautolu ki he potu mahu.   
\q1
\v 13 Te u hŇę ki ho fale mo e ngaahi feilaulau tutu:  
\q2 te u  Ľatu kiate koe  Ľo hangńď ko  Ľeku ngaahi fuakava,   
\q1
\v 14 ‚ÄĆ ĽAia kuo ongo atu mei hoku loungutu,  
\q2 pea lea  Ľaki  Ľe hoku ngutu,  Ľi he Ľeku  Ľi he mamahi.   
\q1
\v 15 Te u  Ľatu kiate koe  Ľae ngaahi feilaulau tutu  Ľae fanga manu sino,  
\q2 mo e me Ľa namu kakala  Ľoe fanga sipitangata;  
\q2 te u  Ľatu  Ľae fanga pulu mo e fanga kosi. \qs Sila.\qs*   
\q1
\v 16 Ha Ľu  Ľo fanongo,  Ľakimoutolu kotoa pńď  Ľoku manavahńď ki he  ĽOtua,  
\q2 pea te u fakahńĀ  Ľaia kuo ne fai ki hoku laumńĀlie.   
\q1
\v 17 Na Ľaku tangi kiate ia  Ľaki hoku ngutu,  
\q2 pea na Ľe fakamńĀlŇć  Ľa hoku  Ľelelo kiate ia.   
\q1
\v 18 Kapau te u tokanga ki he kovi  Ľi hoku loto,  
\q2  Ľe  Ľikai fanongo  Ľae  ĽEiki kiate au:   
\q1
\v 19 Ka ko e mo Ľoni kuo ongo Ľi au  Ľe he  ĽOtua;  
\q2 na Ľe tokanga ia ki he le Ľo  Ľo  Ľeku lotu.   
\q1
\v 20 Fakafeta Ľi ki he  ĽOtua,  Ľaia na Ľe  Ľikai te ne li Ľaki  Ľeku lotu,  
\q2 pe ko  Ľene  Ľalo Ľofa  Ľiate au.   
\c 67  
\cd \it 1 Ko e lotu ke fakalahi ki he pule Ľanga  Ľoe  ĽOtua. 3 Ke fiefia ai  Ľae kakai, 6 Mo hono tupulaki  Ľoe tńĀpuaki  Ľae  ĽOtua.\it*  
\d Ki he Takimu Ľa  Ľi he Nekina, ko e Saame pe ko e Hiva.  
\q1
\v 1 Ke  Ľalo Ľofa  Ľae  ĽOtua kiate kimautolu,  
\q2  Ľo tńĀpuaki  Ľakimautolu;  
\q2 pea tuku ke ulo mai hono fofonga kiate kimautolu. \qs Sila.\qs*   
\q1
\v 2 Koe Ľuhi ke  Ľilo ai ho hala  Ľi mńĀmani,  
\q2 mo ho Ľo fakamo Ľui  Ľi he ngaahi pule Ľanga kotoa pńď.   
\q1
\v 3 Tuku ke fakamńĀlŇć  Ľae kakai kiate koe,  ĽE  ĽOtua;  
\q2 ke fakamńĀlŇć kiate koe  Ľae kakai kotoa pńď.   
\q1
\v 4 Tuku ke fiefia  Ľae ngaahi pule Ľanga, pea hiva  Ľi he nekeneka:  
\q2 he te ke fakamaau mńĀ Ľoni Ľoni  Ľae kakai,  
\q2 pea tataki  Ľae ngaahi pule Ľanga  Ľi mńĀmani. \qs Sila.\qs*   
\q1
\v 5 Tuku ke fakamńĀlŇć  Ľae kakai kiate koe,  ĽE  ĽOtua;  
\q2 ke fakamńĀlŇć kiate koe  Ľae kakai kotoa pńď.   
\q1
\v 6 Pea  Ľe toki tuku mai  Ľe he fonua hono tupu;  
\q2 pea ko e  ĽOtua,  Ľio, ko hotau  ĽOtua, te ne tńĀpuaki  Ľakitautolu.   
\q1
\v 7 ‚ÄĆ ĽE tńĀpuaki  Ľakitautolu  Ľe he  ĽOtua;  
\q2 pea  Ľe manavahńď kiate ia  Ľae ngata Ľanga kotoa pńď  Ľo mńĀmani.   
\c 68  
\cd \it 1 Ko e lotu  Ľi he hiki  Ľae puha  Ľoe fuakava 4 Ko e enginaki ke fakafeta Ľi ki he  ĽOtua  Ľi he Ľene ngaahi  Ľalo Ľofa, 7  ĽI he Ľene tokanga ki he siasi, 19 Mo  Ľene ngaahi ngńĀue lahi.\it*  
\d Ki he Takimu Ľa, ko e Saame pe ko e Hiva  Ľa Tevita.  
\q1
\v 1 Ke tu Ľu hake  Ľae  ĽOtua, tuku ke veteki hono ngaahi fili:  
\q2 tuku ke puna foki mei hono  Ľao  Ľakinautolu  Ľoku fehi Ľa kiate ia.   
\q1
\v 2 Hangńď ko e vilingia  Ľo mole  Ľae kohu,  
\q2 ke pehńď pe hono vilingia  Ľakinautolu:  
\q2 hangńď ko e pulu  Ľoku vela  Ľo vai  Ľi he afi,  
\q2 ke  Ľauha pehńď pe  Ľae kau angahala  Ľi he  Ľao  Ľoe  ĽOtua.   
\q1
\v 3 Ka  Ľe tuku ke fiefia  Ľae mńĀ Ľoni Ľoni;  
\q2 ke nekeneka  Ľakinautolu  Ľi he  Ľao  Ľoe  ĽOtua:  
\q2  ĽIo, ke fiefia lahi  Ľaupito  Ľakinautolu.   
\q1
\v 4 Hiva ki he  ĽOtua, hiva fakamńĀlŇć ki hono huafa:  
\q2 fakaongoongolelei ia  Ľoku hńĀ Ľele  Ľi he ngaahi toafa  
\q1  Ľi hono huafa ko SIHOVA,  
\q2 pea fiefia  Ľi hono  Ľao.   
\q1
\v 5 Ko e tamai  Ľae  ĽOtua ki he tamai mate,  
\q2 mo e fakamaau ia  Ľi hono  Ľafio Ľanga mńĀ Ľoni Ľoni,  
\q2 ki he kau fefine kuo mate honau husepńĀniti.   
\q1
\v 6 ‚ÄĆ ĽOku  Ľai  Ľe he  ĽOtua  Ľae kau paea  Ľi he ngaahi fale:  
\q2  Ľoku ne  Ľomi kitu Ľa  Ľakinautolu kuo ha Ľi  Ľaki  Ľae ukamea fihifihi:  
\q2 ka  Ľoku nofo  Ľae kau angatu Ľu  Ľi he fonua mŇćmoa.   
\q1
\v 7 ‚ÄĆ ĽE  ĽOtua,  Ľi ho Ľo mu Ľomu Ľa atu ki ho kakai,  
\q2  Ľi ho Ľo hńĀ Ľele  Ľi he toafa; \qs Sila.\qs*   
\q1
\v 8 Na Ľe ngalulu  Ľa mńĀmani, pea ngangana mo e ngaahi langi foki  Ľi he  Ľao  Ľoe  ĽOtua:  
\q2  Ľio, na Ľe ngaueue  Ľa Sainai  Ľi he  Ľao  Ľoe  ĽOtua, ko e  ĽOtua  Ľo  ĽIsileli.   
\q1
\v 9 ‚ÄĆ ĽE  ĽOtua, na Ľa ke tuku hifo  Ľae  Ľuha lahi,  
\q2  Ľaia na Ľa ke fakamńĀlohi  Ľaki ho tofi Ľa,  Ľi he Ľene vaivai.   
\q1
\v 10 Na Ľe nofo ki ai  Ľa ho kakai:  
\q2  ĽE  ĽOtua, kuo ke tokonaki  Ľi ho Ľo angalelei ki he masiva.   
\q1
\v 11 Na Ľe foaki mai  Ľe he  ĽEiki  Ľae folofola pea na Ľe tokolahi  Ľakinautolu na Ľe fakahńĀ ia.   
\q1
\v 12 ‚ÄúNa Ľe hola vave  Ľae ngaahi tu Ľi  Ľoe kautau:‚ÄĚ  
\q2 pea na Ľe tufa  Ľae vete  Ľe he fefine na Ľe nofo  Ľo le Ľo.   
\q1
\v 13 Neongo ho Ľomou nofo  Ľi he lotolotonga  Ľoe ngaahi kulo,  
\q2 ka temou hangńď ko e kapakau  Ľoe lupe  Ľoku  Ľufi Ľufi  Ľaki  Ľae siliva, mo hono fulufulu ko e koula melomelo.   
\q1
\v 14 ‚ÄĆ ĽI he veteki  Ľi ai  Ľe he MńĀfimafi  Ľae ngaahi tu Ľi,  
\q2 na Ľe hinehina ia  Ľo hangńď ko e  Ľuha hinehina  Ľi Salimoni.   
\q1
\v 15 Ko e mo Ľunga  Ľoe  ĽOtua  Ľoku hangńď ko e mo Ľunga ko Pesani;  
\q2 ko e mo Ľunga mńĀ Ľolunga  Ľo hangńď ko e mo Ľunga ko Pesani,   
\q1
\v 16 Ko e hńĀ  Ľoku mou hopohopo ai,  Ľakimoutolu ko e ngaahi mo Ľunga mńĀ Ľolunga?  
\q2 Ko e mo Ľunga eni  Ľoku fili  Ľe he  ĽOtua ke nofo ki ai;  
\q2  Ľio,  Ľe nofo ki ai  Ľa Sihova  Ľo ta Ľengata.   
\q1
\v 17 Ko e ngaahi saliote  Ľae  ĽOtua  Ľoku ua mano,  
\q2  Ľio, ko e ngaahi toko afe  Ľoe  ĽńĀngelo:  
\q2  Ľoku  Ľiate kinautolu  Ľae  ĽEiki,  
\q2  Ľio,  Ľo hangńď ko  Ľene  Ľi Sainai,  
\q2  Ľi he potu mńĀ Ľoni Ľoni.   
\q1
\v 18 Kuo ke hńĀ Ľele hake ki  Ľolunga,  
\q2 kuo u angatu Ľu foki,  
\q2 koe Ľuhi ke nofo kiate kinautolu  Ľa Sihova ko e  ĽOtua.   
\q1
\v 19 Fakafeta Ľi ki he  ĽEiki,  
\q2  Ľaia  Ľoku ne hili kiate kitautolu  Ľae kavenga  Ľoe me Ľa lelei  Ľi he  Ľaho kotoa pńď,  
\q2  Ľio, ko e  ĽOtua  Ľo hotau fakamo Ľui. \qs Sila.\qs*   
\q1
\v 20 Ko ia, ko hotau  ĽOtua ko e  ĽOtua ia  Ľoe fakamo Ľui;  
\q2 pea  Ľoku  Ľia Sihova ko e  ĽEiki  Ľae mo Ľui mei he mate.   
\q1
\v 21 Ka  Ľe taa Ľi  Ľe he  ĽOtua  Ľae  Ľulu  Ľo hono ngaahi fili,  
\q2 mo e tumu Ľaki fulufulu  Ľo ia  Ľoku  Ľalu pńď  Ľi he Ľene ngaahi talangata Ľa.   
\q1
\v 22 Na Ľe pehńď  Ľe he  ĽEiki, ‚ÄúTe u toe  Ľomi mei Pesani,  
\q2 te u toe  Ľomi hoku kakai mei he loloto  Ľo e ngaahi tahi.   
\q1
\v 23 Koe Ľuhi ke kulokula ho va Ľe  Ľi he toto  Ľo ho ngaahi fili,  
\q2 pea mo e  Ľelelo  Ľo ho Ľo fanga kulńę  Ľi ai.‚ÄĚ   
\q1
\v 24 Kuo nau mamata ki ho ngaahi hńĀ Ľele Ľanga,  ĽE  ĽOtua;  
\q2  Ľio, ko e ngaahi hńĀ Ľele Ľanga  Ľo hoku  ĽOtua, mo hoku Tu Ľi,  Ľi he faletapu.   
\q1
\v 25 ‚ÄĆ ĽOku mu Ľomu Ľa  Ľae kau hiva, pea hoko mo e kau pulotu tńĀ mńĀlie  Ľoe ngaahi me Ľa faiva;  
\q2 pea  Ľoku  Ľiate kinautolu  Ľae kau ta Ľahine  Ľoku tńĀ  Ľae lali iiki.   
\q1
\v 26 ‚ÄúMou fakafeta Ľi ki he  ĽOtua  Ľi he ngaahi fakataha,  
\q2  Ľio, ki he  ĽEiki,  Ľakimoutolu mei he matavai  Ľo  ĽIsileli.‚ÄĚ   
\q1
\v 27 ‚ÄĆ ĽOku  Ľi ai  Ľa Penisimani si Ľi mo honau pule,  
\q2  Ľae hou Ľeiki  Ľo Siuta mo  Ľenau fakataha,  
\q2 mo e hou Ľeiki  Ľo Sepuloni, pea mo e hou Ľeiki  Ľo Nafitali.   
\q1
\v 28 Ko ho  ĽOtua kuo ne tu Ľutu Ľuni ho mńĀlohi:  
\q2 ke ke fakamńĀlohi,  ĽE  ĽOtua,  Ľaia na Ľa ke fai kiate kimautolu.   
\q1
\v 29 Ko e me Ľa  Ľi ho faletapu  Ľi SelŇęsalema,  
\q2  Ľe  Ľomi ai  Ľe he ngaahi tu Ľi  Ľae ngaahi me Ľa Ľofa kiate koe.   
\q1
\v 30 Ke ke tautea  Ľae fanga manu  Ľoe vao kaho,  
\q2  Ľae fu Ľu tokolahi  Ľoe fanga pulu tangata, mo e ngaahi  Ľuhiki Ľi pulu  Ľoe kakai,  
\q2 ke  Ľoua kenau fakavaivai  Ľakinautolu  Ľaki  Ľae ngaahi konga siliva:  
\q2 ke ke veteki  Ľae kakai  Ľoku manako ki he tau.   
\q1
\v 31 ‚ÄĆ ĽE ha Ľu  Ľae ngaahi hou Ľeiki mei  ĽIsipite;  
\q2  Ľe mafao vave atu  Ľae nima  Ľo  ĽItiopea ki he  ĽOtua.   
\q1
\v 32 ‚ÄĆ ĽAe ngaahi pule Ľanga  Ľo mńĀmani,  
\q2 mou hiva ki he  ĽOtua;  
\q2 hiva  Ľaki  Ľae fakamńĀlŇć ki he  ĽEiki: \qs Sila.\qs*   
\q1
\v 33 Kiate ia  Ľoku heka ki he langi  Ľoe ngaahi langi,  Ľaia na Ľe  Ľi mu Ľa pe;  
\q2 vakai,  Ľoku ne fakaongo atu hono le Ľo, pea ko e le Ľo mńĀfimafi ia.   
\q1
\v 34 Mou tuku ki he  ĽOtua  Ľae mńĀlohi:  
\q2  Ľoku  Ľi  Ľolunga  Ľi  ĽIsileli  Ľa hono nńĀunau,  
\q2 mo  Ľene mńĀfimafi  Ľoku  Ľi he ngaahi langi.   
\q1
\v 35 ‚ÄĆ ĽE  ĽOtua,  Ľoku fakamanavahńď ko e  Ľitu Ľa  Ľi ho ngaahi faletapu:  
\q2 ko e  ĽOtua  Ľo  ĽIsileli ko ia  Ľoku ne foaki  Ľae mńĀlohi mo e fa Ľa fai ki hono kakai.  
\q2 Fakafeta Ľi ki he  ĽOtua.   
\c 69  
\cd \it 1  ĽOku hanu  Ľa Tevita  Ľi he Ľene mamahi. 13  ĽOku lotu ia ke mo Ľui ai. 22  ĽOku tuku  Ľe ia hono ngaahi fili kenau mala Ľia. 30  ĽOku ne fakamńĀlŇć ki he  ĽOtua  Ľi he fakafeta Ľi.\it*  
\d Ki he Takimu Ľa  Ľi he Sosanimi, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE  ĽOtua, ke ke fakamo Ľui au;  
\q2 he kuo hŇę ki loto  Ľae ngaahi vai ki hoku laumńĀlie.   
\q1
\v 2 ‚ÄĆ ĽOku ou ngalo hifo  Ľi he pela loloto,  Ľaia  Ľoku  Ľikai ha potu ke tu Ľu ai:  
\q2 kuo u hoko ki he vai loloto, pea  Ľoku lŇćmaki Ľi au  Ľe he vai lahi.   
\q1
\v 3 Kuo u vaivai  Ľi he Ľeku tangi:  
\q2 kuo mŇćmoa hoku kia:  
\q2  Ľoku faka Ľa Ľau  Ľo  Ľosi hoku mata  Ľi he Ľeku tatali ki hoku  ĽOtua.   
\q1
\v 4 Ko kinautolu  Ľoku fehi Ľa kiate au ta Ľehano Ľuhinga  Ľoku nau tokolahi hake  Ľi he tu Ľoni lou Ľulu  Ľo hoku  Ľulu:  
\q2 ko kinautolu  Ľoku loto ke faka Ľauha au,  
\q2  Ľaia ko hoku ngaahi fili ta Ľetotonu,  Ľoku nau mńĀlohi;  
\q2 pea ne u toki  Ľange  Ľaia na Ľe  Ľikai te u  Ľave.   
\q1
\v 5 ‚ÄĆ ĽE  ĽOtua,  Ľoku ke  Ľilo Ľi  Ľeku vale;  
\q2 pea  Ľoku  Ľikai lilo  Ľiate koe  Ľeku ngaahi angahala.   
\q1
\v 6 ‚ÄĆ ĽE  ĽEiki Sihova  Ľoe ngaahi kautau,  Ľoua na Ľa tuku ke mńĀ  Ľakinautolu  Ľoku tatali kiate koe koe Ľuhi ko au:  
\q2  ĽE  ĽOtua  Ľo  ĽIsileli,  Ľoua na Ľa puputu Ľu  Ľakinautolu  Ľoku kumi kiate koe koe Ľuhi ko au.   
\q1
\v 7 He ko e me Ľa  Ľiate koe kuo u kńĀtaki ai  Ľae lau Ľikovi;  
\q2 kuo  Ľufi Ľufi  Ľaki hoku mata  Ľae mńĀ.   
\q1
\v 8 Kuo u hoko ko e muli ki hoku ngaahi kńĀinga,  
\q2 mo e  ĽńĀuhe ki he fńĀnau  Ľa  Ľeku fa Ľńď.   
\q1
\v 9 He kuo u  Ľosi Ľosiloto  Ľi he fai feinga ki ho fale;  
\q2 pea ko e ngaahi manuki  Ľanautolu na Ľe manuki Ľi koe kuo tŇć kiate au.   
\q1
\v 10 ‚ÄĆ ĽI he Ľeku tangi,  Ľo tautea hoku laumńĀlie  Ľaki  Ľae  Ľaukai,  
\q2 na Ľe manuki Ľi ai au.   
\q1
\v 11 Na Ľaku kofu Ľaki  Ľae tauanga Ľa;  
\q2 pea ne u hoko ko honau luma Ľanga.   
\q1
\v 12 ‚ÄĆ ĽOku lau Ľikovi Ľi au  Ľekinautolu  Ľoku nofo  Ľi he matapńĀ;  
\q2 pea  Ľoku hiva  Ľaki au  Ľe he kau konńĀ  Ľi he kava.   
\q1
\v 13 Ka ko au,  ĽE Sihova,  Ľe a Ľu atu kiate koe  Ľeku lotu  Ľi he  Ľaho tu ĽumńĀlie:  
\q2  ĽE  ĽOtua, ke ke fanongo kiate au  Ľi hono lahi fau  Ľo ho Ľo  Ľalo Ľofa,  Ľi hono mo Ľoni  Ľo ho Ľo fakamo Ľui.   
\q1
\v 14 Fakamo Ľui au mei he pela, pea  Ľoua na Ľa tuku au ke u ngalo hifo:  
\q2 tuku ke fakamo Ľui au meiate kinautolu  Ľoku fehi Ľa kiate au, pea mei he ngaahi vai loloto.   
\q1
\v 15 ‚ÄĆ ĽOua na Ľa tuku ke lŇćmaki Ľi au  Ľe he vai lahi,  
\q2 pea  Ľoua na Ľa folo hifo au  Ľe he loloto,  
\q2 pea  Ľoua na Ľa tńĀpuni  Ľe he luo hono ngutu kiate au.   
\q1
\v 16 Fanongo kiate au,  ĽE Sihova, he  Ľoku lelei ho Ľo manava Ľofa:  
\q2 ke ke tafoki mai kiate au  Ľo fakatatau ki hono lahi  Ľo ho Ľo  Ľalo Ľofa ongongofua.   
\q1
\v 17 Pea  Ľoua na Ľa ke fufŇę ho fofonga mei ho Ľo tamaio Ľeiki;  
\q2 he  Ľoku ou mamahi:  
\q2 fanongo vave kiate au:   
\q1
\v 18 Ke ke  Ľunu Ľunu mai ke ofi ki hoku laumńĀlie, pea huhu Ľi ia:  
\q2 fakamo Ľui au koe Ľuhi ko hoku ngaahi fili.   
\q1
\v 19 Kuo ke  Ľilo Ľi hoku lau Ľikovi, mo  Ľeku mńĀ, mo hoku manukia:  
\q2  Ľoku  Ľi ho  Ľao  Ľa hoku ngaahi fili kotoa pńď.   
\q1
\v 20 Kuo fesi Ľi hoku loto  Ľe he lau Ľikovi pea kuo u fonu  Ľi he mamahi:  
\q2 pea na Ľaku kumi ki ha ni Ľihi ke  Ľofa mai, ka na Ľe  Ľikai ha tokotaha;  
\q2 mo e kau fakafiemńĀlie, tńĀ na Ľe  Ľikai te u  Ľilo ha taha.   
\q1
\v 21 Na Ľa nau foaki foki kiate au  Ľae  Ľahu ko  Ľeku me Ľakai;  
\q2 pea  Ľi he Ľeku fieinu na Ľa nau tuku mai  Ľae vaimahi ke u inu.   
\q1
\v 22 Ke hoko honau keinanga Ľanga ko e hele  Ľi honau  Ľao:  
\q2 mo ia na Ľe totonu kenau lelei ai, ke hoko ia ko e tauhele.   
\q1
\v 23 Ke fakapo Ľuli honau mata, ke  Ľoua na Ľa nau mamata;  
\q2 pea ke tetetete ma Ľuaipńď honau kongaloto.   
\q1
\v 24 Te ke lilingi ho houhau kiate kinautolu,  
\q2 pea puke  Ľakinautolu  Ľe ho houhau vela.   
\q1
\v 25 Tuku ke lala honau nofo Ľanga;  
\q2 ke  Ľoua na Ľa nofo ha tokotaha  Ľi honau fale fehikitaki.   
\q1
\v 26 He  Ľoku nau fakatanga Ľi ia  Ľaia kuo ke taa Ľi;  
\q2 pea  Ľoku nau talanoa fakamamahi kiate kinautolu kuo ke tautea.   
\q1
\v 27 Fakalahi  Ľaki  Ľae nunu Ľa  Ľoe hia ki he Ľenau hia:  
\q2 pea ke  Ľoua na Ľa nau hoko ki ho Ľo mńĀ Ľoni Ľoni.   
\q1
\v 28 Tuku ke tńĀmate Ľi mei he tohi  Ľoe mo Ľui,  
\q2 pea  Ľoua na Ľa tohi fakataha  Ľakinautolu mo e kau mńĀ Ľoni Ľoni.   
\q1
\v 29 Ka ko au  Ľoku ou masiva mo mamahi:  
\q2  ĽE  ĽOtua, tuku ke hiki ki  Ľolunga au  Ľe ho Ľo fakamo Ľui.   
\q1
\v 30 Teu fakamńĀlŇć ki he huafa  Ľoe  ĽOtua  Ľaki  Ľae hiva,  
\q2 pea te u hiki hake ia  Ľaki  Ľae fakafeta Ľi.   
\q1
\v 31 Pea  Ľe fiemńĀlie lahi hake ai  Ľa Sihova  Ľi he me Ľa ni,  
\q2  Ľi he pulu tangata pe ko e pulu  Ľoku ai hono nifo mo e nge Ľesi va Ľe.   
\q1
\v 32 ‚ÄĆ ĽE mamata ki he me Ľa ni  Ľae angavaivai, pea fiefia ai:  
\q2 pea  Ľe mo Ľui homou loto  Ľaia  Ľoku kumi ki he  ĽOtua.   
\q1
\v 33 He  Ľoku ongo Ľi  Ľe Sihova  Ľae masiva,  
\q2 pea  Ľoku  Ľikai te ne manuki Ľi  Ľene kau pŇćpula.   
\q1
\v 34 Tuku ke fakamńĀlŇć kiate ia  Ľae langi mo mńĀmani,  
\q2  Ľae ngaahi tahi, mo e me Ľa kotoa pńď  Ľoku ngaue  Ľi ai.   
\q1
\v 35 Koe Ľuhi  Ľe fakamo Ľui  Ľe he  ĽOtua  Ľa Saione,  
\q2 pea langa  Ľae ngaahi kolo  Ľo Siuta:  
\q2 koe Ľuhi ke nau nofo  Ľi ai,  Ľo ma Ľu ia ko honau tofi Ľa.   
\q1
\v 36 ‚ÄĆ ĽE ma Ľu foki ia  Ľe he hako  Ľo  Ľene kau tamaio Ľeiki:  
\q2 pea  Ľe nofo ki ai  Ľakinautolu  Ľoku  Ľofa ki hono huafa.   
\c 70  
\cd \it 1‚Äď5  ĽOku kole  Ľa Tevita ki he  ĽOtua ke  Ľauha vave  Ľae kau angahala, kae fakahaofi  Ľae mo Ľui  Ľae angalelei.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita, ko e fakamanatu.  
\q1
\v 1 ‚ÄĆ ĽE  ĽOtua, ke ke fakamo Ľui au;  
\q2  ĽE Sihova, ke ke fai vave ke tokoni au.   
\q1
\v 2 Tuku ke mńĀ mo puputu Ľu  Ľakinautolu  Ľoku kumi hoku laumńĀlie:  
\q2 tuku ke fakafoki kimui, mo fakamaveuveu,  Ľakinautolu  Ľoku holi ke u kovi.   
\q1
\v 3 Tuku ke foki kimui  Ľakinautolu, ko e totongi  Ľo  Ľenau kovi,  
\q2  Ľakinautolu  Ľoku pehńď, Ha ha.   
\q1
\v 4 Tuku ke fiefia mo nekeneka  Ľiate koe  Ľakinautolu kotoa pńď  Ľoku kumi kiate koe:  
\q2 tuku ke lea pehńď ma Ľuaipńď  Ľakinautolu  Ľoku  Ľofa ki ho Ľo fakamo Ľui,  
\q2 ‚ÄúKe ongoongolelei  Ľae  ĽOtua.‚ÄĚ   
\q1
\v 5 Ka ko au  Ľoku ou masiva mo paea:  
\q2  ĽE  ĽOtua, ke ke ha Ľu vave kiate au:  
\q2 ko koe ko hoku tokoni mo hoku fakamo Ľui;  
\q2  ĽE Sihova,  Ľoua na Ľa ke tatali.   
\c 71  
\cd \it 1 Ko e ma Ľu lelei  Ľe Tevita  Ľae tui mo e falala ki he  ĽOtua,  Ľo ne lotua ia, mo  Ľene lotu telia  Ľae ngaahi fili  Ľo hono laumńĀlie. 14  ĽOku ne fakahńĀ hono loto ma Ľu. 17 Pea lotu ia ke ne tu Ľuma Ľu. 19  ĽOku fakamńĀlŇć ia ki he  ĽOtua, pea ne tala te ne fai ia  Ľi he fiefia.\it*  
\q1
\v 1 ‚ÄĆ ĽE Sihova,  Ľoku ou falala kiate koe  Ľoua na Ľa tuku au ke u mńĀ  Ľo ta Ľengata.   
\q1
\v 2 Fakamo Ľui au  Ľi ho Ľo mńĀ Ľoni Ľoni, pea tuku ke u hao:  
\q2 fakatokanga Ľi ho fofonga kiate au,  Ľo fakamo Ľui au.   
\q1
\v 3 Ke ke  Ľiate au ko e nofo Ľanga mńĀlohi  Ľaia te u hŇę ma Ľuaipńď ki ai:  
\q2 kuo ke fekau ke fakamo Ľui au;  
\q2 he ko koe ko hoku makatu Ľu mo hoku hŇęfanga.   
\q1
\v 4 ‚ÄĆ ĽE hoku  ĽOtua, ke ke fakamo Ľui au mei he nima  Ľoe kau angahala,  
\q2 mei he nima  Ľoe kau tangata ta ĽemńĀ Ľoni Ľoni mo angamńĀlohi.   
\q1
\v 5 He ko koe,  ĽE  ĽEiki Sihova, ko  Ľeku  Ľamanaki lelei:  
\q2 ko koe ko hoku falala Ľanga talu  Ľeku kei si Ľi.   
\q1
\v 6 Kuo ke poupou au talu  Ľeku \add mńĀvae \add*mei he manńĀva: ko koe ia na Ľe to Ľo au mei he fatu  Ľo  Ľeku fa Ľńď:  
\q2 te u fakafeta Ľi ma Ľuaipńď kiate koe.   
\q1
\v 7 ‚ÄĆ ĽOku ou hangńď ko e me Ľa fakaofo ki he tokolahi:  
\q2 ka ko koe ko hoku hŇęfanga mńĀlohi.   
\q1
\v 8 Tuku ke pito hoku ngutu  Ľaki ho Ľo fakamńĀlŇć mo ho Ľo faka Ľapa Ľapa  Ľi he  Ľaho kotoa pńď.   
\q1
\v 9 Pea  Ľoua na Ľa si Ľaki au  Ľi he  Ľaho  Ľo  Ľeku motu Ľa;  
\q2  Ľoua na Ľa li Ľaki au  Ľoka mole  Ľiate au  Ľeku mńĀlohi.   
\q1
\v 10 He  Ľoku lea kovi kiate au  Ľa hoku ngaahi fili;  
\q2 pea ko kinautolu  Ľoku lamasi hoku laumńĀlie  Ľoku nau fakakaukau fakataha,   
\q1
\v 11 ‚ÄĆ ĽO nau pehńď, ‚ÄúKuo li Ľaki ia  Ľe he  ĽOtua:  
\q2 fakatanga  Ľo puke ia; he  Ľoku  Ľikai ha tokotaha ke fakamo Ľui ia.‚ÄĚ   
\q1
\v 12 ‚ÄĆ ĽE  ĽOtua,  Ľoua na Ľa ke mama Ľo  Ľiate au:  
\q2  ĽE hoku  ĽOtua, ke ke fai vave ke tokoni au.   
\q1
\v 13 Tuku ke puputu Ľu mo  Ľauha  Ľakinautolu  Ľoku nofo ko e fili ki hoku laumńĀlie;  
\q2 ke  Ľufi Ľufi  Ľaki  Ľae mńĀ mo e manuki  Ľakinautolu  Ľoku kumi ke u kovi.   
\q1
\v 14 Ka te u  Ľamanaki lelei ma Ľuaipńď,  
\q2 pea  Ľe tupulekina pe  Ľeku fakamńĀlŇć kiate koe.   
\q1
\v 15 ‚ÄĆ ĽE fakahńĀ atu  Ľe hoku ngutu  Ľa ho Ľo mńĀ Ľoni Ľoni mo ho Ľo fakamo Ľui  Ľi he  Ľaho kotoa pńď;  
\q2 he  Ľoku  Ľikai te u  Ľilo ki hono lau  Ľo ia.   
\q1
\v 16 Te u  Ľalu  Ľi he mńĀlohi  Ľae  ĽEiki ko Sihova:  
\q2 te u fakahńĀ ho Ľo mńĀ Ľoni Ľoni,  Ľio,  Ľo Ľou pe.   
\q1
\v 17 ‚ÄĆ ĽE  ĽOtua, kuo ke akonaki Ľi au talu  Ľeku kei si Ľi:  
\q2 pea talu mei mu Ľa mo  Ľeku fakahńĀ atu  Ľa ho Ľo ngaahi ngńĀue fakaofo.   
\q1
\v 18 Pea ko eni foki,  ĽE  ĽOtua,  Ľi he Ľeku motu Ľa mo  ĽuluhinńĀ,  Ľoua na Ľa ke li Ľaki au;  
\q2 kae Ľoua ke u fakahńĀ ho mńĀlohi ki he to Ľutangata ni,  
\q2 mo ho Ľo mńĀfimafi kiate kinautolu kotoa pńď  Ľe ha Ľu.   
\q1
\v 19 Ko ho Ľo mńĀ Ľoni Ľoni foki,  ĽE  ĽOtua,  Ľoku mńĀ Ľolunga  Ľaupito,  
\q2  Ľa koe na Ľa ke fai  Ľae ngaahi me Ľa lahi:  
\q2  ĽE  ĽOtua, ko hai  Ľoku hangńď ko koe!   
\q1
\v 20 ‚ÄĆ ĽA koe, kuo ke fakahńĀ kiate au  Ľae ngaahi mamahi  Ľoku lahi mo kovi,  
\q2 te ke toe fakaake au,  
\q2  Ľo toe  Ľohake au mei he loto kelekele.   
\q1
\v 21 Te ke fakatupulekina hoku nńĀunau Ľia,  
\q2  Ľo fakafiemńĀlie Ľi au  Ľi he potu kotoa pńď.   
\q1
\v 22 ‚ÄĆ ĽE hoku  ĽOtua, te u fakamńĀlŇć foki kiate koe,  Ľio, ki ho Ľo mo Ľoni  Ľaki  Ľae saliteli:  
\q2 te u hiva kiate koe  Ľaki  Ľae ha Ľape,  Ľa koe koe tokotaha mńĀ Ľoni Ľoni  Ľa  ĽIsileli.   
\q1
\v 23 ‚ÄĆ ĽE fiefia lahi hoku loungutu  Ľo kau ka hiva kiate koe;  
\q2 mo hoku laumńĀlie  Ľaia kuo ke huhu Ľi.   
\q1
\v 24 ‚ÄĆ ĽE talanoa  Ľa hoku  Ľelelo foki ki ho Ľo mńĀ Ľoni Ľoni  Ľi he  Ľaho kotoa pńď:  
\q2 he kuo puputu Ľu, kuo hoko  Ľo mńĀ,  Ľakinautolu  Ľoku kumi ke u kovi.   
\c 72  
\cd \it 1 Ko Tevita  Ľi he Ľene hŇęfia  Ľa Solomone  Ľoku ne fakahńĀ ko  Ľene pule ko e faka Ľilonga  Ľoe angalelei, mo hono nńĀunau, mo e mo Ľoni  Ľoe pule  Ľa Kalaisi. 18  ĽOku fakafeta Ľi ia ki he  ĽOtua.\it*  
\d Ko e Saame ma Ľa Solomone.  
\q1
\v 1 ‚ÄĆ ĽE  ĽOtua, tuku ki he tu Ľi  Ľa ho Ľo ngaahi fakamaau,  
\q2 mo ho Ľo mńĀ Ľoni Ľoni ki he foha  Ľoe tu Ľi.   
\q1
\v 2 Te ne fakamaau ho Ľo kakai  Ľi he mńĀ Ľoni Ľoni,  
\q2 mo ho Ľo kau masiva  Ľaki  Ľae fakamaau.   
\q1
\v 3 ‚ÄĆ ĽE  Ľomi  Ľe he ngaahi mo Ľunga  Ľae melino ki he kakai,  
\q2 mo e mńĀ Ľoni Ľoni mei he ngaahi tafungofunga.   
\q1
\v 4 ‚ÄĆ ĽE fakamaau  Ľe ia  Ľae kakai mamahi,  
\q2 te ne fakamo Ľui  Ľae fńĀnau  Ľae masiva,  
\q2 pea te ne fesifesi  Ľae fakamńĀlohi.   
\q1
\v 5 Te nau manavahńď kiate koe  Ľi he lolotonga  Ľae kei tu Ľu  Ľae la ĽńĀ,  
\q2 mo e mńĀhina,  Ľi he to Ľutangata kotoa pńď.   
\q1
\v 6 ‚ÄĆ ĽE  Ľalu hifo ia  Ľo hangńď ko e  Ľuha ki he mohuku kuo tutu Ľu:  
\q2  Ľo hangńď ko e  Ľuha tu Ľu mo tŇć  Ľoku fakaviviku  Ľae fonua.   
\q1
\v 7 ‚ÄĆ ĽE tupu pńď  Ľae kau mńĀ Ľoni Ľoni  Ľi hono ngaahi  Ľaho;  
\q2 mo e melino lahi  Ľaupito  Ľi he kei tolonga  Ľae mńĀhina.   
\q1
\v 8 ‚ÄĆ ĽE pule  Ľe ia foki mei he tahi ki he tahi,  
\q2 pea mei he vaitafe  Ľo a Ľu ki he ngaahi ngata Ľanga  Ľo mńĀmani.   
\q1
\v 9 ‚ÄĆ ĽE punou  Ľi hono  Ľao  Ľakinautolu  Ľoku nofo  Ľi he toafa;  
\q2 pea  Ľe  Ľemo  Ľae efu  Ľe hono ngaahi fili.   
\q1
\v 10 ‚ÄĆ ĽE  Ľomi  Ľae ngaahi me Ľa Ľofa  Ľe he ngaahi tu Ľi  Ľo Tasisi pea mo e ngaahi motu:  
\q2  Ľe  Ľatu  Ľae ngaahi me Ľa foaki  Ľe he ngaahi tu Ľi  Ľo Sipa mo Sepa.   
\q1
\v 11 ‚ÄĆ ĽIo,  Ľe punou  Ľi hono  Ľao  Ľae ngaahi tu Ľi kotoa pńď:  
\q2  ĽE tauhi ia  Ľe he pule Ľanga kotoa pńď.   
\q1
\v 12 He te ne fakamo Ľui  Ľae masiva  Ľi he Ľene tangi;  
\q2  Ľae mamahi foki, mo ia  Ľoku  Ľikai hano tokoni.   
\q1
\v 13 Te ne fakamo Ľui  Ľae vaivai mo e masiva,  
\q2  Ľo fakamo Ľui  Ľae laumńĀlie  Ľoe kau masiva.   
\q1
\v 14 ‚ÄĆ ĽE huhu Ľi  Ľe ia honau laumńĀlie mei he kńĀkńĀ mo e fakamńĀlohi:  
\q2 pea  Ľe mahu Ľinga honau toto  Ľi hono  Ľao.   
\q1
\v 15 Pea  Ľe mo Ľui pe ia, pea  Ľe foaki kiate ia  Ľae koula  Ľo Sipa:  
\q2  ĽE fai ma Ľuaipńď  Ľae lotu koe Ľuhi ko ia;  
\q2 pea  Ľe fakamńĀlŇć kiate ia  Ľi he  Ľaho kotoa pńď,   
\q1
\v 16 Pea  Ľe  Ľi ai  Ľae falukunga  Ľoe uite  Ľi he fonua  Ľi he tumutumu  Ľoe ngaahi mo Ľunga,  
\q2  Ľe ngaueue hono fua  Ľo ia  Ľo hangńď ko Lepanoni:  
\q2 pea ko kinautolu  Ľi he kolo  Ľe tupu pe  Ľo hangńď ko e mohuku  Ľoe fonua.   
\q1
\v 17 ‚ÄĆ ĽE tu Ľuma Ľu hono huafa  Ľo ta Ľengata,  
\q2  Ľe tolonga ma Ľuaipńď hono huafa  Ľo hangńď ko e la ĽńĀ:  
\q1 pea  Ľe monŇę Ľia  Ľae kakai  Ľiate ia:  
\q2  Ľe ui ia ko e monŇę Ľia  Ľe he pule Ľanga kotoa pńď.   
\q1
\v 18 Fakafeta Ľi kia Sihova ko e  ĽOtua, ko e  ĽOtua  Ľo  ĽIsileli,  
\q2  Ľaia tokotaha pe  Ľoku fai  Ľae ngaahi me Ľa fakaofo.   
\q1
\v 19 Pea fakafeta Ľi ma Ľuaipńď ki hono huafa ongoongolelei  Ľo ta Ľengata:  
\q2 pea tuku ke pito  Ľa mńĀmani kotoa pńď  Ľi hono nńĀunau;  
\q2  ĽEmeni, mo  ĽEmeni.   
\q1
\v 20 Kuo ngata  Ľae ngaahi lotu  Ľa Tevita ko e foha  Ľo Sese.   
\c 73  
\ms1 TOHI 3  
\mr (Saame 73‚ÄĒ89)  
\cd \it 1 Ko e iku Ľi  Ľe he palŇćfita  Ľae  Ľahi Ľahi kovi. 2  ĽOku ne fakahńĀ hono tupu Ľanga,  Ľaia ko e monŇę Ľia  Ľoe kau angakovi, 13 Mo hono lavea,  Ľaia ko e ta Ľetui. 15  ĽOku ne ikuna  Ľaki  Ľene  Ľilo ki he tu Ľutu Ľuni  Ľae  ĽOtua,  Ľi he faka Ľauha  Ľoe kau angahala, mo e fakamo Ľui  Ľoe mńĀ Ľoni Ľoni.\it*  
\d Ko e Saame  Ľa  ĽAsafi.  
\q1
\v 1 Ko e mo Ľoni  Ľoku angalelei  Ľae  ĽOtua ki  ĽIsileli,  
\q2  Ľio, kiate kinautolu  Ľoku loto ma Ľa.   
\q1
\v 2 Ka ko au na Ľe meimei mole hoku va Ľe:  
\q2 na Ľaku meimei hekea  Ľi he Ľeku ngaahi laka.   
\q1
\v 3 He na Ľaku meheka  Ľi he kau vale,  
\q2  Ľi he Ľeku mamata ki he fiemńĀlie  Ľae angakovi.   
\q1
\v 4 He  Ľoku  Ľikai hanau mamahi  Ľi he Ľenau mate:  
\q2 ka  Ľoku ma Ľu pe honau mńĀlohi.   
\q1
\v 5 ‚ÄĆ ĽOku  Ľikai mo Ľua  Ľi he mamahi  Ľakinautolu  Ľo hangńď ko e kakai kehe;  
\q2 pea  Ľoku  Ľikai  Ľahi Ľahi Ľi  Ľakinautolu  Ľo hangńď ko e kakai ni Ľihi.   
\q1
\v 6 Ko ia  Ľoku takatakai ai  Ľakinautolu  Ľe he laukau  Ľo hangńď ko e ukamea fihifihi;  
\q2  Ľoku  Ľufi Ľufi  Ľakinautolu  Ľe he angamńĀlohi  Ľo hangńď ko e kofu.   
\q1
\v 7 ‚ÄĆ ĽOku hohopo honau mata  Ľi he Ľenau sino:  
\q2  Ľoku nau ma Ľu me Ľa  Ľo lahi hake  Ľi he holi  Ľoe loto.   
\q1
\v 8 Kuo kovi  Ľakinautolu, pea lea kovi  Ľi he fakamńĀlohi:  
\q2  Ľoku nau lea fakafiefielahi.   
\q1
\v 9 ‚ÄĆ ĽOku nau hangatonu atu honau ngutu  Ľo angatu Ľu ki he ngaahi langi,  
\q2 pea  Ľoku  Ľeve Ľeva honau  Ľelelo  Ľi mńĀmani.   
\q1
\v 10 Ko ia  Ľoku liu mai ai ki heni hono kakai: pea  Ľoku tatau  Ľae vai kiate kinautolu ke pito  Ľae ipu.   
\q1
\v 11 Pea  Ľoku nau pehńď, ‚Äú ĽOku  Ľilo fńďfńď  Ľe he  ĽOtua?  
\q2 Pea  Ľoku ai ha  Ľilo  Ľi he Fungani MńĀ Ľolunga?‚ÄĚ   
\q1
\v 12 Vakai, ko eni  Ľae kau angakovi  Ľoku fiemńĀlie  Ľi he mńĀmani;  
\q2  Ľoku tupu pńď  Ľenau koloa.   
\q1
\v 13 Ko e mo Ľoni  Ľoku ta Ľe Ľaonga  Ľeku fakama Ľa hoku loto,  
\q2 mo  Ľeku fanofano hoku nima  Ľi he mńĀ Ľoni Ľoni.   
\q1
\v 14 He kuo  Ľahi Ľahi Ľi au  Ľi he  Ľaho kotoa pńď,  
\q2 pea kuo tautea au  Ľi he pongipongi kotoa pńď,   
\q1
\v 15 Kapau te u tala, te u lea pehńď;  
\q2 vakai, ko  Ľeku fai hala ki he to Ľutangata  Ľo ho Ľo fńĀnau.   
\q1
\v 16 Pea  Ľi he Ľeku  Ľahi Ľahi ke  Ľilo  Ľae me Ľa ni,  
\q2 na Ľe faingata Ľa ia kiate au;   
\q1
\v 17 Ka  Ľi he Ľeku hŇę ki he faletapu  Ľoe  ĽOtua;  
\q2 na Ľaku toki  Ľilo ai honau iku Ľanga.   
\q1
\v 18 Ko e mo Ľoni na Ľa ke tuku  Ľakinautolu  Ľi he ngaahi potu hekeheke:  
\q2 kuo ke laku hifo  Ľakinautolu ki he ngaahi faka Ľauha.   
\q1
\v 19 Kuo  Ľomi vave  Ľakinautolu ki he mala Ľia,  
\q2  Ľo hangńď ko e kemo pe taha  Ľoe mata!  
\q2 Kuo faka Ľauha  Ľaupito  Ľakinautolu  Ľi he ngaahi ilifia.   
\q1
\v 20 Hangńď ko e misi  Ľoka  ĽńĀ hake ha taha;  
\q2 ke pehńď pe,  ĽE  ĽEiki,  Ľoka ke ka  ĽńĀ hake, te ke manuki Ľi honau tatau.   
\q1
\v 21 Na Ľe mamahi pehńď pe hoku laumńĀlie,  
\q2 pea na Ľe mahuhuhuhu ai hoku loto.   
\q1
\v 22 Na Ľe pehńď  Ľeku vale, pea na Ľe  Ľikai te u  Ľilo:  
\q2 na Ľaku hangńď ko e manu  Ľi ho  Ľao.   
\q1
\v 23 Ka ko e mo Ľoni  Ľoku ou  Ľiate koe ma Ľuaipńď:  
\q2 pea kuo ke puke au  Ľi hoku nima to Ľomata Ľu.   
\q1
\v 24 Te ke tataki au  Ľi ho Ľo poto,  
\q2 pea hili ia te ke ma Ľu au ki ho nńĀunau.   
\q1
\v 25 He ko hai mo koe  Ľoku ou ma Ľu  Ľi he loto langi?  
\q2 Pea  Ľoku  Ľikai ha tokotaha  Ľi mńĀmani  Ľoku ou holi ki ai, ka ko koe pńď.   
\q1
\v 26 ‚ÄĆ ĽOku vaivai hoku kakano mo hoku loto:  
\q2 ka ko e makatu Ľu  Ľo hoku loto  Ľae  ĽOtua,  
\q2 mo hoku  Ľinasi  Ľo ta Ľengata.   
\q1
\v 27 Vakai,  Ľe  Ľauha  Ľakinautolu  Ľoku mama Ľo  Ľiate koe:  
\q2 kuo ke faka Ľauha  Ľakinautolu kotoa pńď  Ľoku  Ľalu meiate koe  Ľo fai kovi.   
\q1
\v 28 Ka  Ľoku lelei kiate au  Ľeku  Ľunu Ľunu ke ofi ki he  ĽOtua:  
\q2 kuo u falala ki he  ĽEiki ko Sihova, koe Ľuhi ke u fakahńĀ ai ho Ľo ngńĀue kotoa pńď.   
\c 74  
\cd \it 1  ĽOku hanu  Ľae palŇćfita  Ľi he maumau  Ľoe faletapu. 10  ĽOku ne kole ki he  ĽOtua ke ne tokoni koe Ľuhi ko hono mńĀlohi lahi, 18 Mo e lau Ľikovi  Ľa hono ngaahi fili, pea koe Ľuhi ko  Ľene fńĀnau, mo  Ľene fuakava.\it*  
\d Ko e Saame akonaki  Ľa  ĽAsafi.  
\q1
\v 1 ‚ÄĆ ĽE  ĽOtua, ko e hńĀ kuo ke li Ľaki ai  Ľakimautolu  Ľo ta Ľengata?  
\q2 Ko e hńĀ  Ľoku kohu ai ho houhau ki he fanga sipi  Ľo ho Ľo ngoue?   
\q1
\v 2 Manatu ki he fakataha  Ľo ho Ľo kakai,  Ľaia na Ľa ke fakatau  Ľi mu Ľa;  
\q2 ko e fa Ľahinga  Ľo ho tofi Ľa,  Ľaia kuo ke huhu Ľi;  
\q2  Ľae mo Ľunga ni ko Saione,  Ľaia na Ľa ke nofo ai.   
\q1
\v 3 Hiki hake ho va Ľe ki hono ngaahi maumau kuo tu Ľuma Ľu pe;  
\q2  Ľio, ki he me Ľa kotoa pńď kuo fai  Ľi he angakovi  Ľe he fili  Ľi he faletapu.   
\q1
\v 4 ‚ÄĆ ĽOku  Ľioho  Ľa ho ngaahi fili  Ľi he lotolotonga  Ľo ho Ľo ngaahi fakataha;  
\q2  Ľoku nau fokotu Ľu  Ľenau ngaahi fuka ko e ngaahi faka Ľilonga.   
\q1
\v 5 Na Ľe ongoongo  Ľae tangata  Ľo fakatatau mo  Ľene fa Ľa fai  
\q2 ke hiki ki  Ľolunga  Ľae ngaahi toki ki he ngaahi  Ľakau lahi.   
\q1
\v 6 Ka ko eni, kuo nau maumau Ľi  Ľaki  Ľae ngaahi toki mo e hamala  Ľae ngaahi me Ľa tongitongi kotoa pńď.   
\q1
\v 7 Kuo nau lńę  Ľae afi ki ho faletapu,  
\q2 kuo nau  Ľuli Ľi  Ľae  Ľafio Ľanga  Ľo ho huafa  Ľo holoki hifo ia ki he kelekele.   
\q1
\v 8 Na Ľa nau pehńď  Ľi honau loto, ‚ÄúKetau faka Ľauha fakataha  Ľakinautolu:‚ÄĚ  
\q2 kuo nau tutu  Ľo  Ľosi  Ľae ngaahi falelotu  Ľoe  ĽOtua  Ľi he fonua.   
\q1
\v 9 ‚ÄĆ ĽOku  Ľikai temau kei mamata ki he Ľemau ngaahi faka Ľilonga:  
\q2  Ľoku  Ľikai ha palŇćfita  Ľe toe:  
\q2 pea  Ľoku  Ľikai ha tokotaha  Ľiate kitautolu  Ľoku ne  Ľilo pe  Ľe fńďfńď hono fuoloa.   
\q1
\v 10 ‚ÄĆ ĽE  ĽOtua,  Ľe fńďfńď hono fuoloa  Ľoe lau Ľikovi  Ľae fili?  
\q2  ĽE kape ki ho huafa  Ľe he fili  Ľo ta Ľengata?   
\q1
\v 11 Ko e hńĀ  Ľoku ke to Ľo atu ai ho nima,  Ľio, ho nima to Ľomata Ľu?  
\q2 To Ľo mai ia mei ho fatafata.   
\q1
\v 12 He ko e  ĽOtua ko hoku Tu Ľi talu mei mu Ľa,  
\q2  Ľoku ne fai  Ľae fakamo Ľui  Ľi he lotolotonga  Ľo mńĀmani.   
\q1
\v 13 Na Ľa ke vaeua  Ľae tahi  Ľi ho mńĀlohi:  
\q2 na Ľa ke foa Ľi  Ľae  Ľulu  Ľoe ngaahi talńĀkoni  Ľi he ngaahi vai,   
\q1
\v 14 ‚ÄĆ ĽOku ke foa Ľi  Ľo laiki  Ľae ngaahi  Ľulu  Ľoe levaiatani,  
\q2  Ľo ke  Ľange ia ko e me Ľakai ki he kakai  Ľoku nofo  Ľi he toafa.   
\q1
\v 15 Na Ľa ke vaeua  Ľae matavai mo e vaitafe lahi:  
\q2 na Ľa ke fakamŇćmoa  Ľae ngaahi vaitafe lahi.   
\q1
\v 16 ‚ÄĆ ĽOku  Ľo Ľou  Ľae  Ľaho, pea  Ľoku  Ľo Ľou foki mo e pŇć:  
\q2 kuo ke teuteu  Ľae maama mo e la ĽńĀ.   
\q1
\v 17 Kuo ke  Ľai  Ľae ngaahi ngata Ľanga kotoa pńď  Ľoe fonua;  
\q2 kuo ke ngaohi  Ľae fa Ľahita Ľu mafana mo e fa Ľahita Ľu momoko.   
\q1
\v 18 ‚ÄĆ ĽE Sihova, manatu ki he me Ľa ni, kuo lau Ľikovi  Ľe he fili,  
\q2 pea kuo kape ki ho huafa  Ľae kakai vale.   
\q1
\v 19 ‚ÄĆ ĽOua na Ľa tukuange  Ľae laumńĀlie  Ľo ho  Ľofa Ľanga ki he fu Ľu tokolahi  Ľoe kau angakovi:  
\q2  Ľoua na Ľa ngalo  Ľiate koe  Ľae fakataha  Ľo ho kakai masiva  Ľo ta Ľengata.   
\q1
\v 20 Ke ke tokanga ki he fuakava:  
\q2 he  Ľoku pito  Ľae ngaahi potu fakapo Ľuli  Ľo mńĀmani  Ľi he ngaahi nofo Ľanga  Ľoe angamńĀlohi.   
\q1
\v 21 ‚ÄĆ ĽOua na Ľa ke tuku ke liu mai kuo mńĀ  Ľae kakai kuo ta Ľomia:  
\q2 tuku ke fakamńĀlŇć ki ho huafa  Ľae kau masiva mo e vaivai.   
\q1
\v 22 ‚ÄĆ ĽE  ĽOtua, ke ke tu Ľu hake,  Ľo langomaki Ľi ho Ľo ngńĀue  Ľa Ľau:  
\q2 manatu ki he lau Ľikovi Ľi koe  Ľe he tangata vale  Ľi he  Ľaho kotoa pńď.   
\q1
\v 23 ‚ÄĆ ĽOua na Ľa ngalo  Ľae le Ľo  Ľo ho ngaahi fili:  
\q2 ko e maveuveu  Ľokinautolu  Ľoku tu Ľu hake kiate koe  Ľoku tupulekina  Ľi he  Ľaho kotoa pńď.   
\c 75  
\cd \it 1  ĽOku fakamńĀlŇć  Ľae palŇćfita ki he  ĽOtua. 2  ĽOku ne pehńď, te ne fakamaau mńĀ Ľoni Ľoni. 4  ĽOku ne valoki  Ľae laukau ko e me Ľa  Ľi he pule  Ľae  ĽOtua. 9  ĽOku ne fakamńĀlŇć ki he  ĽOtua,  Ľo tokanga ke fai totonu.\it*  
\d Ki he Takimu Ľa,  ĽAli-Tasikiti, ko e Saame pe ko e Hiva  Ľa  ĽAsafi.  
\q1
\v 1 ‚ÄĆ ĽOku mau  Ľatu  Ľae fakafeta Ľi kiate koe,  
\q2  ĽE  ĽOtua,  Ľoku mau  Ľatu  Ľae fakafeta Ľi kiate koe:  
\q2 he  Ľoku fakahńĀ  Ľe ho Ľo ngaahi ngńĀue lahi  Ľoku ofi ho huafa.   
\q1
\v 2 ‚Äú ĽO kau ka ma Ľu  Ľae fakataha te u fakamaau mńĀ Ľoni Ľoni.   
\q1
\v 3 Kuo movetevete  Ľae fonua mo hono kakai:  
\q2  Ľoku ou poupou hake hono ngaahi pou. \qs Sila.\qs*   
\q1
\v 4 Na Ľaku pehńď ki he kau vale,  Ľoua na Ľa mou fai fakavalevale:  
\q2 pea ki he kau angakovi,  Ľoua te mou hiki hake  Ľae nifo.   
\q1
\v 5 ‚ÄĆ ĽOua na Ľa hiki ki  Ľolunga homou nifo:  
\q2  Ľoua te mou lea  Ľi he kia kekeva.‚ÄĚ   
\q1
\v 6 He  Ľoku  Ľikai ha Ľu mei he potu hahake, pe mei he potu lulunga,  
\q2 pe mei he potu tonga  Ľae hakeaki Ľi.   
\q1
\v 7 He ko e fakamaau  Ľae  ĽOtua:  
\q2  Ľoku  Ľohifo  Ľe ia  Ľae tokotaha, kae fokotu Ľu hake  Ľae tokotaha.   
\q1
\v 8 He  Ľoku  Ľi he nima  Ľo Sihova  Ľae ipu,  
\q2 pea  Ľoku kulokula  Ľae uaine:  
\q2 kuo pito ia  Ľi he me Ľa kuo hu Ľi ki ai;  
\q2 pea  Ľoku lilingi  Ľe ia mei ai:  
\q2 ka ko hono efe  Ľo ia,  Ľe tatau ia  Ľe he angakovi kotoa pńď  Ľo mńĀmani,  Ľo inu ia.   
\q1
\v 9 Ka ko au te u fakahńĀ  Ľo ta Ľengata;  
\q2 te u hiva  Ľaki  Ľae fakamńĀlŇć ki he  ĽOtua  Ľo Sńďkope.   
\q1
\v 10 Te u tutu Ľu ke motu  Ľae ngaahi nifo  Ľoe kau angahala;  
\q2 ka  Ľe hakeaki Ľi  Ľae ngaahi nifo  Ľoe kau mńĀ Ľoni Ľoni.   
\c 76  
\cd \it 1 Ko e fakahńĀ  Ľae mńĀfimafi  Ľoe  ĽOtua  Ľi he siasi, 11 Mo e enginaki ke tauhi ia  Ľi he faka Ľapa Ľapa.\it*  
\d Ki he Takimu Ľa  Ľi he Nekina, ko e Saame pe ko e Hiva  Ľa  ĽAsafi.  
\q1
\v 1 ‚ÄĆ ĽOku  Ľilo  Ľae  ĽOtua  Ľi Siuta:  
\q2  ĽOku lahi hono huafa  Ľi  ĽIsileli.   
\q1
\v 2 ‚ÄĆ ĽOku  Ľi Selemi foki hono fale fehikitaki,  
\q2 mo hono  Ľafio Ľanga  Ľi Saione.   
\b  
\q1
\v 3 Na Ľe fesifesi  Ľe ia  Ľi ai  Ľae ngaahi ngahau  Ľoe kaufana,  
\q2  Ľae fakaŇę, mo e heletńĀ, mo e tau. \qs Sila.\qs*   
\q1
\v 4 ‚ÄĆ ĽOku ke nńĀunau Ľia mo lelei lahi hake  Ľa koe  
\q2  Ľi he ngaahi mo Ľunga  Ľoe fakamńĀlohi.   
\q1
\v 5 Kuo ikuna  Ľae kau loto mńĀlohi,  
\q2 kuo nau mohe  Ľi he Ľenau mohe:  
\q2 pea  Ľoku  Ľikai ha tokotaha  Ľi he kau tangata mńĀlohi  Ľoku  Ľilo honau nima.   
\q1
\v 6 ‚ÄĆ ĽE  ĽOtua  Ľo Sńďkope,  
\q2  Ľi ho Ľo tautea kuo ke lńę fakatou Ľosi pńď  Ľae saliote mo e hoosi ki he mohe  Ľoe mate.   
\q1
\v 7 Ko koe,  Ľio, ko koe, ko e manavahńď Ľia:  
\q2 pea ko hai  Ľe fa Ľa tu Ľu  Ľi ho  Ľao  Ľoka ke ka houhau?   
\q1
\v 8 Na Ľa ke fakaongo Ľi  Ľae fakamaau mei he langi;  
\q2 na Ľe manavahńď ai  Ľa mńĀmani,  Ľo tu Ľu ta Ľengaue,   
\q1
\v 9 ‚ÄĆ ĽI he tu Ľu hake  Ľae  ĽOtua ki he fakamaau,  
\q2 ke fakamo Ľui  Ľae kau angavaivai kotoa pńď  Ľo mńĀmani. \qs Sila.\qs*   
\q1
\v 10 Ko e mo Ľoni  Ľe fakaongolelei koe  Ľe he  Ľita  Ľae tangata:  
\q2 pea ko hono toe  Ľoe  Ľita te ke lolomi.   
\q1
\v 11 Mou fuakava,  Ľo fai ia kia Sihova ko homou  ĽOtua:  
\q2 tuku ke  Ľomi  Ľae ngaahi me Ľa Ľofa kiate ia  Ľoku totonu ke manavahńď ki ai,  Ľakinautolu kotoa pńď  Ľoku nofo  Ľo takatakai ia.   
\q1
\v 12 ‚ÄĆ ĽE motuhi  Ľe ia  Ľae loto lahi  Ľoe hou Ľeiki:  
\q2  Ľoku fakailifia ia ki he ngaahi tu Ľi  Ľo mńĀmani.   
\c 77  
\cd \it 1  ĽOku fakahńĀ  Ľe he tangata tohi Saame  Ľena fekuki mńĀlohi mo e fakata Ľeta Ľetui. 10 Na Ľa ne ikuna  Ľi he Ľene tokanga ki he ngaahi ngńĀue lahi mo lelei  Ľae  ĽOtua.\it*  
\d Ki he Takimu Ľa ko Situtuni, ko e Saame  Ľa  ĽAsafi.  
\q1
\v 1 Na Ľa ku tangi ki he  ĽOtua  Ľaki hoku le Ľo;  
\q2  Ľio, ki he  ĽOtua  Ľaki hoku le Ľo pea ne tokanga kiate au.   
\q1
\v 2 ‚ÄĆ ĽI he  Ľaho  Ľo  Ľeku mamahi na Ľaku kumi ki he  ĽEiki:  
\q2 na Ľe a Ľu pe  Ľeku mamahi  Ľi he po Ľuli, pea  Ľikai tuku:  
\q2 na Ľe li Ľaki  Ľe hoku laumńĀlie  Ľae fakafiemńĀlie.   
\q1
\v 3 Na Ľaku manatu ki he  ĽOtua, pea u mamahi ai:  
\q2 na Ľaku fakalaulauloto, pea na Ľe lŇćmekina hoku laumńĀlie. \qs Sila.\qs*   
\q1
\v 4 ‚ÄĆ ĽOku ke pule ke  ĽńĀ hoku mata:  
\q2  Ľoku lahi  Ľeku mamahi,  
\q2 ko ia  Ľoku  Ľikai ai te u fa Ľa lea.   
\q1
\v 5 Na Ľaku fakamanatu ki he ngaahi  Ľaho  Ľi mu Ľa,  
\q2 ki he ngaahi ta Ľu  Ľi he ngaahi kuonga  Ľi mu Ľa.   
\q1
\v 6 ‚ÄĆ ĽOku ou fakamanatu, ki he Ľeku hiva  Ľi he po Ľuli:  
\q2  Ľoku ou fakakaukau mo hoku loto:  
\q2 pea na Ľe  Ľeke lahi  Ľa hoku laumńĀlie.   
\q1
\v 7 ‚Äú ĽE li Ľaki ma Ľuaipńď  Ľe Sihova?  
\q2 Pea  Ľe  Ľikai te ne toe finangalo  Ľofa mai?   
\q1
\v 8 Kuo mole  Ľaupito  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa?  
\q2 Pe kuo ta Ľehoko  Ľene tala Ľofa ki he to Ľutangata mo e to Ľutangata?   
\q1
\v 9 Kuo ngalo  Ľi he  ĽOtua ke fai  Ľofa?  
\q2 Kuo ne tńĀpuni  Ľi he houhau  Ľa  Ľene ngaahi  Ľalo Ľofa ongongofua?‚ÄĚ \qs Sila.\qs*   
\q1
\v 10 Pea ne u pehńď, ‚ÄúKo  Ľeku vaivai eni ka te u manatu  
\q2 ki he ngaahi ta Ľu  Ľoe nima to Ľomata Ľu  Ľoe Fungani MńĀ Ľolunga.‚ÄĚ   
\q1
\v 11 Te u manatu ki he ngaahi ngńĀue  Ľa Sihova:  
\q2 ko e mo Ľoni te u manatu ki ho Ľo ngaahi mana  Ľi mu Ľa.   
\q1
\v 12 Te u fakalaulauloto foki ki ho Ľo ngńĀue kotoa pńď,  
\q2  Ľo talanoa ki ho Ľo ngaahi faianga.   
\q1
\v 13 ‚ÄĆ ĽE  ĽOtua, ko ho hala  Ľoku  Ľi he faletapu:  
\q2 ko hai ha  ĽOtua  Ľoku lahi  Ľo hangńď ko hotau  ĽOtua!   
\q1
\v 14 Ko koe ko e  ĽOtua  Ľoku fai  Ľae ngaahi me Ľa fakaofo:  
\q2 kuo ke fakahńĀ ho mńĀlohi  Ľi he lotolotonga  Ľoe kakai.   
\q1
\v 15 Na Ľa ke huhu Ľi  Ľaki ho nima  Ľa ho kakai,  
\q2 ko e ngaahi foha  Ľo Sńďkope mo Siosefa. \qs Sila.\qs*   
\q1
\v 16 Na Ľe mamata kiate koe  Ľae ngaahi vai,  ĽE  ĽOtua,  
\q2 na Ľe mamata kiate koe  Ľae ngaahi vai; pea na Ľa nau manavahńď:  
\q2 na Ľe ngaueue foki  Ľae ngaahi loloto.   
\q1
\v 17 Na Ľe lilingi  Ľae vai  Ľe he ngaahi  Ľao:  
\q2 na Ľe faka Ľu Ľulu mei he langi  Ľae longoa Ľa:  
\q2 pea na Ľe puna foki ho Ľo ngaahi ngahau ki he mama Ľo.   
\q1
\v 18 Na Ľe  Ľi he langi  Ľae le Ľo  Ľo ho Ľo mana:  
\q2 na Ľe fakamaama  Ľaki  Ľa mńĀmani  Ľae ngaahi  Ľuhila:  
\q2 na Ľe tetetete mo ngalulu  Ľae fonua.   
\q1
\v 19 Ko ho hala  Ľoku  Ľi he tahi,  
\q2 mo ho hńĀ Ľele Ľanga  Ľoku  Ľi he vai lahi,  
\q2 pea  Ľoku  Ľikai  Ľilonga  Ľa ho ngaahi  Ľalu Ľanga.   
\q1
\v 20 Na Ľa ke tataki atu ho kakai  Ľo hangńď ko e fanga sipi  
\q2  Ľi he nima  Ľo MŇćsese mo  ĽElone.   
\b  
\c 78  
\cd \it 1 Ko e enginaki ke tokanga ki he fono  Ľae  ĽOtua, pea malanga Ľaki ia. 9 Ko e fakamatala ki he houhau  Ľoe  ĽOtua ki he ta Ľetui mo e talangata Ľa. 67 Kuo li Ľaki  Ľe he  ĽOtua  Ľae kakai  ĽIsileli, pea fili  Ľe ia  Ľa Siuta, mo Saione, mo Tevita.\it*  
\d Ko e Saame akonaki  Ľa  ĽAsafi.  
\q1
\v 1 Fakafanongo  Ľa hoku kakai ki he Ľeku akonaki:  
\q2 fakatokanga Ľi homou telinga ki he ngaahi lea  Ľa hoku ngutu.   
\q1
\v 2 Te u mafa Ľa hoku ngutu  Ľi he fakatńĀtńĀ:  
\q2 te u fakahńĀ  Ľae ngaahi lea fufŇę mei mu Ľa:   
\q1
\v 3 ‚ÄĆ ĽAia kuo tau fanongo ki ai pea  Ľilo Ľi,  
\q2 pea na Ľe tala ia kiate kitautolu  Ľe he Ľetau ngaahi tamai.   
\q1
\v 4 ‚ÄĆ ĽE  Ľikai te tau fufŇę ia mei he Ľenau fńĀnau,  
\q2 ka  Ľe fakahńĀ ki he to Ľutangata  Ľe hoko  Ľae ongoongolelei  Ľo Sihova,  
\q2 mo hono mńĀlohi, mo e ngaahi ngńĀue mana na Ľa ne fai.   
\q1
\v 5 He na Ľa ne fokotu Ľuma Ľu  Ľae fono  Ľia Sńďkope,  
\q2  Ľo ne tu Ľutu Ľuni  Ľae akonaki  Ľi  ĽIsileli,  
\q2  Ľaia na Ľa ne fekau Ľi  Ľetau ngaahi tamai,  
\q2 koe Ľuhi ke nau faka Ľilo ia ki he Ľenau fńĀnau:   
\q1
\v 6 Koe Ľuhi ke  Ľilo ia  Ľe he to Ľutangata  Ľe hoko,  Ľio,  Ľae fńĀnau  Ľe fanau Ľi;  
\q2  Ľaia tenau tupu hake  Ľo fakahńĀ ia ki he Ľenau fńĀnau:   
\q1
\v 7 Koe Ľuhi kenau  Ľamanaki lelei ma Ľuaipńď ki he  ĽOtua,  
\q2 pea  Ľoua na Ľa fakangalongalo Ľi  Ľae ngaahi ngńĀue  Ľae  ĽOtua,  
\q2 ka e tauhi  Ľene ngaahi fekau:   
\q1
\v 8 Kae Ľoua na Ľa tatau mo  Ľenau ngaahi tamai,  
\q2 ko e to Ľutangata paongata Ľa mo angatu Ľu;  
\q2 ko e to Ľutangata na Ľe  Ľikai tenau teuteu honau loto ke lelei,  
\q2 pea na Ľe  Ľikai tu Ľuma Ľu honau laumńĀlie  Ľi he  ĽOtua.   
\q1
\v 9 Ko e fńĀnau  Ľa  ĽIfalemi na Ľe to Ľo mahafutau,  
\q2 mo e ngaahi kaufana,  
\q2 na Ľa nau hola  Ľi he  Ľaho  Ľoe tau.   
\q1
\v 10 Na Ľe  Ľikai tenau fai ki he fuakava  Ľae  ĽOtua,  
\q2 pea na Ľe  Ľikai si Ľi tenau loto ke  Ľa Ľeva  Ľi he Ľene akonaki;   
\q1
\v 11 Pea na Ľa nau fakangalongalo Ľi  Ľene ngaahi ngńĀue,  
\q2 mo  Ľene ngaahi mana na Ľa ne fakahńĀ kiate kinautolu.   
\q1
\v 12 Na Ľa ne fai  Ľae ngaahi me Ľa fakaofo  Ľi he  Ľao  Ľo  Ľenau ngaahi tamai,  
\q2  Ľi he fonua ko  ĽIsipite,  Ľi he ngoue  Ľo Soani.   
\q1
\v 13 Na Ľe vaeua  Ľe ia  Ľae tahi, pea ne pule kenau  Ľalu atu ai;  
\q2 pea ne ngaohi  Ľae tahi ke tu Ľu fakatafungofunga pńď.   
\q1
\v 14 Na Ľa ne tataki foki  Ľakinautolu  Ľi he  Ľaho  Ľaki  Ľae  Ľao,  
\q2 pea  Ľi he pŇć  Ľaki  Ľae maama  Ľoe afi.   
\q1
\v 15 Na Ľe fahi Ľi  Ľe ia  Ľae ngaahi makatu Ľu  Ľi he toafa,  
\q2 pea  Ľange  Ľae inu kiate kinautolu  Ľo hangńď  Ľoku mei he loloto lahi.   
\q1
\v 16 Na Ľa ne  Ľomi foki kiate kinautolu  Ľae ngaahi vaitafe mei he makatu Ľu,  
\q2  Ľo ne pule ke tafe hifo  Ľae ngaahi vai  Ľo hangńď ko e ngaahi vaitafe lahi.   
\q1
\v 17 Pea na Ľa nau toe fai angahala kiate ia,  
\q2  Ľi he Ľenau fakahouhau ki he Fungani MńĀ Ľolunga  Ľi he toafa.   
\q1
\v 18 Pea na Ľa nau  Ľahi Ľahi Ľi  Ľae  ĽOtua  Ľi honau loto,  
\q2  Ľi he Ľenau lea ke ma Ľu  Ľae kakano  Ľi he Ľenau holi kovi.   
\q1
\v 19 ‚ÄĆ ĽIo, na Ľa nau lau Ľikovi Ľi  Ľae  ĽOtua;  
\q2 na Ľa nau pehńď, ‚Äú ĽE fa Ľa teuteu  Ľe he  ĽOtua  Ľae keinanga Ľanga  Ľi he toafa?   
\q1
\v 20 Vakai, na Ľe taa Ľi  Ľe ia  Ľae makatu Ľu, pea puna mei ai  Ľae ngaahi vai,  
\q2 pea pito  Ľo fetńĀfeaki  Ľae ngaahi vaitafe;  
\q1 te ne fa Ľa tuku mai foki  Ľae mńĀ?  
\q2  ĽE fa Ľa tokonaki  Ľe ia  Ľae kakano ma Ľa hono kakai?‚ÄĚ   
\q1
\v 21 Ko ia na Ľe fanongo ki ai  Ľa Sihova, pea houhau ia:  
\q2 ko ia na Ľe tutu ai  Ľae afi kia Sńďkope,  
\q2 pea na Ľe tupu hake foki  Ľae tuputńĀmaki ki  ĽIsileli;   
\q1
\v 22 Koe Ľuhi na Ľe  Ľikai tenau tui ki he  ĽOtua,  
\q2 pea na Ľe  Ľikai ha falala ki he Ľene fakamo Ľui:   
\q1
\v 23 Neongo  Ľene fekau Ľi  Ľae ngaahi  Ľao  Ľi  Ľolunga,  
\q2 mo  Ľene to Ľo  Ľae ngaahi matapńĀ  Ľoe langi,   
\q1
\v 24 ‚ÄĆ ĽO ne tuku ke tŇć hifo  Ľae mana kiate kinautolu kenau kai,  
\q2 pea ne foaki kiate kinautolu  Ľae uite  Ľoe langi.   
\q1
\v 25 Na Ľe kai  Ľe he tangata  Ľae me Ľakai  Ľae kau  ĽńĀngelo:  
\q2 na Ľa ne tuku atu  Ľae me Ľakai kenau mńĀkona ai.   
\q1
\v 26 Na Ľe pule  Ľe ia ke ma Ľili  Ľae matangi hahake  Ľi he langi:  
\q2 pea ne  Ľomi mo e matangi tonga  Ľi he Ľene mńĀfimafi.   
\q1
\v 27 Na Ľe fakatŇć hifo  Ľe ia  Ľae kakano kiate kinautolu  Ľo tatau mo e efu,  
\q2 mo e fanga manu kapakau  Ľo hangńď ko e  Ľone Ľone  Ľoe tahi:   
\q1
\v 28 Pea na Ľa ne tuku ke tŇć ia  Ľi he lotolotonga  Ľo honau fale fehikitaki,  
\q2  Ľo takatakai  Ľi honau ngaahi nofo Ľanga.   
\q1
\v 29 Ko ia na Ľa nau kai, pea nau mńĀkona:  
\q2 he na Ľa ne  Ľange kiate kinautolu  Ľenau holi.   
\q1
\v 30 Na Ľe  Ľikai te nau mavahe mei he Ľenau holi kovi.  
\q2 Ka  Ľi he kei  Ľi honau ngutu  Ľae ma Ľanga,   
\q1
\v 31 Na Ľe hoko  Ľae houhau  Ľoe  ĽOtua kiate kinautolu,  
\q2  Ľo ne tńĀmate Ľi  Ľae fungani kakai sino  Ľiate kinautolu,  
\q2 pea ne tńĀ hifo  Ľae kau tangata kuo fili  Ľi  ĽIsileli.   
\q1
\v 32 Na Ľe hoko  Ľae ngaahi me Ľa ni, ka na Ľa nau kei fai angahala pńď,  
\q2  Ľo  Ľikai tui ki he Ľene ngaahi ngńĀue mana.   
\q1
\v 33 Ko ia na Ľa ne faka Ľosi ai honau ngaahi  Ľaho  Ľi he me Ľa va Ľinga pńď,  
\q2 mo honau ngaahi ta Ľu  Ľi he mamahi.   
\q1
\v 34 Pea  Ľi he Ľene tńĀmate Ľi  Ľakinautolu, na Ľa nau toki kumi kiate ia:  
\q2  Ľonau tafoki  Ľo fehu Ľi fakavave ki he  ĽOtua.   
\q1
\v 35 Pea na Ľa nau manatu ko honau maka  Ľae  ĽOtua,  
\q2 pea ko honau huhu Ľi  Ľae  ĽOtua mńĀ Ľolunga.   
\q1
\v 36 Ka na Ľa nau lapu kiate ia  Ľi honau ngutu,  
\q2  Ľonau loi kiate ia  Ľaki honau  Ľelelo.   
\q1
\v 37 He na Ľe  Ľikai totonu honau loto kiate ia,  
\q2 pea na Ľe  Ľikai tenau tu Ľuma Ľu  Ľi he Ľene fuakava.   
\q1
\v 38 Ka na Ľe fonu ia  Ľi he  Ľalo Ľofa,  Ľo ne fakamolemole  Ľenau hia, pea na Ľe  Ľikai faka Ľauha  Ľakinautolu:  
\q2  ĽIo, na Ľe liunga lahi  Ľene fakaafe hono houhau,  
\q2 pea na Ľe  Ľikai te ne ue Ľi hake hono houhau kotoa pńď.   
\q1
\v 39 He na Ľa ne manatu ko e kakano pńď  Ľakinautolu;  
\q2 ko e matangi  Ľoku mole atu, pea  Ľikai toe ha Ľu.   
\q1
\v 40 Na Ľe liunga fiha  Ľenau fakahouhau kiate ia  Ľi he toafa,  
\q2 pea fakamamahi Ľi ia  Ľi he potu lala!   
\q1
\v 41 ‚ÄĆ ĽIo, na Ľa nau foki kimui pea  Ľahi Ľahi Ľi  Ľae  ĽOtua,  
\q2  Ľonau hŇęhŇęmama Ľi  Ľae tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli.   
\q1
\v 42 Na Ľe  Ľikai tenau manatu ki hono nima,  
\q2 pe ko e  Ľaho na Ľa ne fakamo Ľui ai  Ľakinautolu mei he fili.   
\q1
\v 43 Mo  Ľene fai  Ľene ngaahi faka Ľilonga  Ľi  ĽIsipite,  
\q2 mo  Ľene ngaahi me Ľa mana  Ľi he ngoue  Ľo Soani:   
\q1
\v 44 Na Ľa ne liliu honau ngaahi vaitafe ko e toto;  
\q2 mo honau ngaahi vai lahi, na Ľe  Ľikai tenau fa Ľa inu ai.   
\q1
\v 45 Na Ľe fekau atu  Ľe ia kiate kinautolu  Ľae ngaahi lango kehekehe,  Ľaia na Ľe keina  Ľakinautolu;  
\q2 mo e fanga poto,  Ľaia na Ľe fakakovi Ľi  Ľakinautolu.   
\q1
\v 46 Na Ľe tuku foki  Ľe ia  Ľae fua  Ľo  Ľenau ngoue ki he  Ľunufe,  
\q2 mo  Ľenau ngńĀue ki he fanga he Ľe.   
\q1
\v 47 Na Ľa ne tńĀmate Ľi  Ľenau ngaahi vaine  Ľaki  Ľae  Ľuhamaka,  
\q2 mo  Ľenau  Ľakau ko e sukamino  Ľaki  Ľae momoko lahi.   
\q1
\v 48 Na Ľe tuku foki  Ľe ia  Ľenau fanga manu ki he  Ľuhamaka,  
\q2 mo  Ľenau fanga sipi ki he ngaahi faisisili vela.   
\q1
\v 49 Na Ľe lńę  Ľe ia  Ľae kakaha  Ľo  Ľene  Ľita kiate kinautolu,  
\q2  Ľae houhau lahi, mo e tuputńĀmaki, mo e mamahi,  
\q2  Ľi he Ľene fekau atu kiate kinautolu  Ľae kau  ĽńĀngelo  Ľoe kovi.   
\q1
\v 50 Na Ľa ne tofa  Ľae hala ki hono houhau;  
\q2 pea na Ľe  Ľikai te ne fakahaofi  Ľenau mo Ľui mei he mate,  
\q2 ka na Ľa ne tukuange  Ľenau mo Ľui ki he mahaki lahi;   
\q1
\v 51 ‚ÄĆ ĽO ne tńĀ Ľi  Ľae  Ľuluaki fńĀnau kotoa pńď  Ľi  ĽIsipite;  
\q2 ko e fungani mńĀlohi  Ľi he ngaahi nofo Ľanga  Ľo Hami.   
\q1
\v 52 Ka na Ľa ne pule ke  Ľalu atu  Ľa hono kakai  Ľo Ľona  Ľo hangńď ko e fanga sipi,  
\q2  Ľo ne fakahinohino  Ľakinautolu  Ľi he toafa  Ľo hangńď ko e fu Ľu fanga sipi.   
\q1
\v 53 Pea na Ľe tataki fiemńĀlie atu  Ľe ia  Ľakinautolu, ko ia na Ľe  Ľikai ai tenau manavahńď:  
\q2 ka na Ľe lŇćmekina  Ľe he tahi  Ľa honau ngaahi fili.   
\q1
\v 54 Pea na Ľe  Ľomi  Ľe ia  Ľakinautolu  Ľo ofi ki hono faletapu,  
\q2  Ľio, ki he mo Ľunga ni  Ľaia kuo fakatau  Ľe hono nima to Ľomata Ľu.   
\q1
\v 55 Na Ľe kapusi foki  Ľe ia  Ľae hiteni mei honau  Ľao,  
\q2  Ľo ne vahe Ľi kiate kinautolu  Ľae tofi Ľa  Ľaki  Ľae afo,  
\q2 pea ne pule ke nofo  Ľae ngaahi fa Ľahinga  Ľo  ĽIsileli  Ľi honau ngaahi fale fehikitaki.   
\q1
\v 56 Ka na Ľa nau kei  Ľahi Ľahi Ľi mo fakahouhau Ľi  Ľae  ĽOtua fungani mńĀ Ľolunga,  
\q2  Ľo  Ľikai tauhi  Ľene ngaahi fekau:   
\q1
\v 57 Ka na Ľa nau foki kimui,  Ľo fai ta Ľeangatonu  Ľo hangńď ko  Ľenau ngaahi tamai:  
\q2 na Ľe  Ľalu kehe  Ľakinautolu  Ľo hangńď ko e kaufana taka kehe.   
\q1
\v 58 Na Ľa nau fakahouhau ia  Ľaki honau ngaahi potu mńĀ Ľolunga  Ľonau fakafua Ľa ia  Ľaki  Ľenau ngaahi tamapua kuo tńĀ.   
\q1
\v 59 Pea  Ľi he ongo Ľi  Ľe he  ĽOtua  Ľae me Ľa ni, na Ľe houhau ai ia,  
\q2  Ľo fehi Ľa lahi ki  ĽIsileli:   
\q1
\v 60 Ko ia na Ľa ne li Ľaki ai  Ľae fale fehikitaki  Ľo Sailo,  
\q2  Ľae nofo Ľanga ko ia na Ľe fokotu Ľu  Ľe ia  Ľi he lotolotonga  Ľoe kakai;   
\q1
\v 61 ‚ÄĆ ĽO ne tukuange hono mńĀlohi ke pŇćpula,  
\q2 mo hono nńĀunau ki he nima  Ľoe fili.   
\q1
\v 62 Na Ľe fakatukutuku Ľi foki  Ľe ia hono kakai ki he heletńĀ;  
\q2 pea na Ľe houhau ia ki hono tofi Ľa.   
\q1
\v 63 Na Ľe kai ke  Ľosi  Ľe he afi honau kau talavou;  
\q2 pea na Ľe  Ľikai mali  Ľenau kau ta Ľahine.   
\q1
\v 64 Na Ľe tŇć  Ľenau kau taula Ľeiki  Ľi he heletńĀ;  
\q2 pea na Ľe  Ľikai fai ha tangi  Ľe honau uaifi.   
\q1
\v 65 Pea na Ľe toki  ĽńĀ ai  Ľae  ĽEiki  Ľo hangńď ko ha taha na Ľe mohe,  
\q2 pea hangńď ko e tangata mńĀlohi  Ľoku kalanga ko e me Ľa  Ľi he uaine.   
\q1
\v 66 Pea na Ľe taa Ľi  Ľe ia hono ngaahi fili  Ľi honau potu kimui:  
\q2 na Ľa ne tuku  Ľakinautolu ke manukia ma Ľuaipńď.   
\q1
\v 67 Pea na Ľa ne li Ľaki  Ľae fale fehikitaki  Ľo Siosefa,  
\q2 pea na Ľe  Ľikai te ne fili  Ľae fa Ľahinga  Ľo  ĽIfalemi:   
\q1
\v 68 Ka na Ľa ne fili  Ľae fa Ľahinga  Ľo Siuta,  
\q2 ko e mo Ľunga ko Saione  Ľaia na Ľa ne  Ľofa ki ai.   
\q1
\v 69 Pea na Ľa ne langa hono faletapu  Ľo hangńď ko e ngaahi fale mńĀ Ľolunga,  
\q2  Ľo hangńď ko e fonua  Ľaia kuo fokotu Ľuma Ľu ke ta Ľengata.   
\q1
\v 70 Na Ľe fili foki  Ľe ia  Ľa Tevita ko  Ľene tamaio Ľeiki,  
\q2  Ľo ne to Ľo ia mei he ngaahi loto ĽńĀ sipi:   
\q1
\v 71 Na Ľa ne  Ľomi ia mei he Ľene muimui  Ľi he fanga sipi fefine na Ľe talitali pŇć,  
\q2 ke ne fafanga  Ľa Sńďkope ko hono kakai,  
\q2 mo  ĽIsileli ko hono tofi Ľa.   
\q1
\v 72 Pea na Ľa ne fafanga  Ľakinautolu  Ľo fakatatau ki he angatonu  Ľo hono loto;  
\q2  Ľo ne tataki  Ľakinautolu  Ľi he poto  Ľo hono nima.   
\c 79  
\cd \it 1  ĽOku hanu  Ľae tangata tohi saame  Ľi he maumau  Ľo SelŇęsalema. 8  ĽOku ne lotu kenau mo Ľui, 13 Mo fakahńĀ te ne  Ľatu  Ľae fakafeta Ľi.\it*  
\d Ko e Saame  Ľa  ĽAsafi.  
\q1
\v 1 ‚ÄĆ ĽE  ĽOtua, kuo hoko  Ľae hiteni ki ho tofi Ľa;  
\q2 kuo nau faka Ľuli Ľi ho faletapu mńĀ Ľoni Ľoni;  
\q2 kuo nau fakalala  Ľa SelŇęsalema ke tafungofunga ia.   
\q1
\v 2 Kuo nau  Ľange  Ľae sino mate  Ľo ho Ľo kau tamaio Ľeiki ko e me Ľakai ki he manupuna  Ľoe langi,  
\q2 mo e kakano  Ľo ho Ľo kakai mńĀ Ľoni Ľoni ki he fanga manu  Ľoe fonua.   
\q1
\v 3 Kuo nau lilingi honau toto  Ľo hangńď ko e vai  Ľo takatakai  Ľi SelŇęsalema;  
\q2 pea na Ľe  Ľikai ha ni Ľihi ke tanu  Ľakinautolu.   
\q1
\v 4 Kuo mau hoko ko e manuki Ľanga  Ľo homau ngaahi kaungńĀ Ľapi,  
\q2 ko e me Ľa manuki mo e taukae Ľanga  Ľokinautolu  Ľoku nofo takatakai  Ľiate kimautolu.   
\q1
\v 5 ‚ÄĆ ĽE Sihova,  Ľe fńďfńď hono fuoloa?  
\q2 Te ke houhau  Ľo ta Ľengata?  
\q2 pea vela ho fua Ľa  Ľo hangńď ko e afi?   
\q1
\v 6 Ke ke lilingi ho houhau ki he hiteni  Ľoku te Ľeki ai  Ľilo koe,  
\q2 pea mo e ngaahi pule Ľanga  Ľoku te Ľeki ai ui ki ho huafa.   
\q1
\v 7 He kuo nau kai  Ľo  Ľosi  Ľa Sńďkope,  
\q2  Ľo maumau Ľi ke lala hono nofo Ľanga.   
\q1
\v 8 ‚ÄĆ Ľoua na Ľa ke fakamanatu kiate kimautolu  Ľemau ngaahi mu Ľaki hia:  
\q2 tuku ke tokoni vave  Ľakimautolu  Ľe ho Ľo  Ľalo Ľofa ongongofua:  
\q2 he kuo  Ľohifo ki lalo  Ľaupito  Ľakimautolu.   
\q1
\v 9 ‚ÄĆ ĽE  ĽOtua ko homau fakamo Ľui, ke ke tokoni  Ľakimautolu, koe Ľuhi ko e ongoongolelei  Ľo ho huafa:  
\q2 pea fakahaofi  Ľakimautolu,  Ľo fakama Ľa ke  Ľosi  Ľemau ngaahi angahala, koe Ľuhi ko ho huafa.   
\q1
\v 10 Koe Ľuma ĽńĀ  Ľae lea pehńď mai  Ľe he hiteni, ‚ÄúKo e fńď honau  ĽOtua?‚ÄĚ  
\q2 Tuku ke  Ľilo ia  Ľi he lotolotonga  Ľoe hiteni  Ľi homau  Ľao  Ľi he totongi  Ľoe toto  Ľo ho Ľo kau tamaio Ľeiki  Ľaia kuo hua Ľi.   
\q1
\v 11 Tuku ke a Ľu ki ho  Ľao  Ľae ngaahi mafulu  Ľae kau nofo pŇćpula;  
\q2 ke ke fakamo Ľui  Ľakinautolu kuo tu Ľutu Ľuni ke mate  Ľo fakatatau mo hono lahi  Ľo ho Ľo mńĀfimafi.   
\q1
\v 12 ‚ÄĆ ĽE  ĽEiki, ke ke  Ľange ke liunga fitu ki he fatafata  Ľo homau kaungńĀ Ľapi  Ľenau lau Ľikovi,  
\q2  Ľaia na Ľa nau lau Ľikovi Ľi  Ľaki koe.   
\q1
\v 13 Pea ko kimautolu ko ho kakai mo e fanga sipi  Ľo ho Ľo ngoue,  
\q2 temau  Ľatu  Ľae fakafeta Ľi kiate koe  Ľo ta Ľengata:  
\q2 temau fakahńĀ atu ho ongoongolelei ki he to Ľutangata kotoa pńď.   
\c 80  
\cd \it 1  ĽOku hanu  Ľae tangata tohi saame  Ľi he Ľene lotu  Ľi he ngaahi mamahi  Ľoe siasi. 8 Kuo liliu  Ľae me Ľa Ľofa  Ľi mu Ľa  Ľae  ĽOtua ko e me Ľa fakamamahi. 13  ĽOku lotu ia ke ne mo Ľui.\it*  
\d Ki he Takimu Ľa  Ľi he Sosanimi  ĽEtuta, ko e Saame  Ľa  ĽAsafi.  
\q1
\v 1 Fakafanongo  Ľae Tauhi  Ľo  ĽIsileli,  
\q2  Ľa koe  Ľoku ke tataki  Ľa Siosefa  Ľo hangńď ko e fanga sipi;  
\q2  Ľa koe  Ľoku ke  Ľafio  Ľi he vaha Ľa  Ľoe selupimi, ke ke ulo mai.   
\q1
\v 2 ‚ÄĆ ĽI he  Ľao  Ľo  ĽIfalemi mo Penisimani mo Manase ke ke ue Ľi hake ho mńĀlohi,  
\q2 pea hńĀ Ľele mai  Ľo fakamo Ľui  Ľakimautolu.   
\q1
\v 3 ‚ÄĆ ĽE  ĽOtua, ke ke toe fakatafoki  Ľakimautolu,  
\q2 pea tuku ke ulo mai ho fofonga;  
\q2 pea te mau mo Ľui ai.   
\q1
\v 4 ‚ÄĆ ĽE Sihova ko e  ĽOtua  Ľoe ngaahi kautau,  
\q2  Ľe fńďfńď hono fuoloa mo ho Ľo kei houhau ki he lotu  Ľa ho kakai?   
\q1
\v 5 ‚ÄĆ ĽOku ke fafanga  Ľaki  Ľakinautolu  Ľae mńĀ  Ľoe lo Ľimata; pea  Ľoku  Ľange kiate kinautolu  Ľae lo Ľimata lahi kenau inu.   
\q1
\v 6 ‚ÄĆ ĽOku ke ngaohi  Ľakimautolu ko e feke Ľike Ľi Ľanga  Ľo homau kaungńĀ Ľapi:  
\q2 pea  Ľoku katakata homau ngaahi fili  Ľiate kinautolu.   
\q1
\v 7 ‚ÄĆ ĽE  ĽOtua  Ľoe ngaahi kautau,  
\q2 ke ke toe fakatafoki  Ľakimautolu,  
\q2 pea tuku ke ulo mai ho fofonga;  
\q2 pea te mau mo Ľui ai.   
\q1
\v 8 Na Ľa ke lńę kitu Ľa  Ľae hiteni;  
\q2 ka na Ľa ke  Ľomi  Ľae vaine mei  ĽIsipite,  Ľo tŇć ia.   
\q1
\v 9 Na Ľa ke faka Ľata ĽatńĀ \add  Ľae potu \add* Ľi hono  Ľao,  
\q2 pea na Ľa ke fakaaka mńĀ Ľulalo ia, pea na Ľa ne fakapito  Ľae fonua.   
\q1
\v 10 Na Ľe  Ľufi Ľufi  Ľae ngaahi mo Ľunga  Ľi hono malumalu,  
\q2 pea ko hono ngaahi va Ľa na Ľe hangńď ko e ngaahi sita  Ľae  ĽOtua.   
\q1
\v 11 Na Ľa ne tuku atu hono ngaahi va Ľa ki he tahi,  
\q2 mo hono ngaahi  Ľulu Ľulu ki he vaitafe.   
\q1
\v 12 Ko e hńĀ kuo ke hae hifo ai hono ngaahi  ĽńĀ,  
\q2 ke toli ia  Ľekinautolu kotoa pńď  Ľoku  Ľalu atu  Ľi he hala?   
\q1
\v 13 ‚ÄĆ ĽOku maumau Ľi ia  Ľe he puaka tau mei he vao,  
\q2  Ľoku kai ke  Ľosi ia  Ľe he fanga manu kaivao.   
\q1
\v 14 ‚ÄĆ ĽE  ĽOtua  Ľoe ngaahi kautau,  Ľoku mau kole kiate koe ke ke foki mai:  
\q2  Ľafio hifo mei he langi,  Ľo vakai, mo  Ľa Ľahi ki he vaine ni;   
\q1
\v 15 Mo e ngoue vaine  Ľaia kuo tŇć  Ľe ho nima to Ľomata Ľu,  
\q2 mo e va Ľa  Ľaia na Ľa ke ngaohi ke mńĀlohi ma Ľau.   
\q1
\v 16 Kuo tutu ia  Ľaki  Ľae afi, kuo tńĀ hifo ia:  
\q2 kuo nau  Ľauha  Ľi he tautea  Ľe ho fofonga.   
\q1
\v 17 Tuku ke hili ho nima ki he tangata  Ľo ho nima to Ľomata Ľu,  
\q2 ki he foha  Ľoe tangata  Ľaia na Ľa ke fakamńĀlohi ma Ľau.   
\q1
\v 18 Pea  Ľe  Ľikai ai te mau foki kimui meiate koe:  
\q2 ke ke fakaakeake  Ľakimautolu, pea temau ui ki ho huafa.   
\q1
\v 19 ‚ÄĆ ĽE Sihova ko e  ĽOtua  Ľoe ngaahi kautau, ke ke toe fakatafoki  Ľakimautolu,  
\q2 pea tuku ke ulo mai ho fofonga; pea temau mo Ľui ai.   
\c 81  
\cd \it 1 Ko e enginaki ke fakamńĀlŇć ki he  ĽOtua. 4  ĽOku totonu ke fai ia ki he  ĽOtua koe Ľuhi ko  Ľene ngaahi me Ľa Ľofa. 8  ĽOku enginaki Ľi  Ľe he  ĽOtua kenau talangofua,  Ľo ne fakahńĀ  Ľenau talangata Ľa,  Ľaia  Ľoku nau kovi ai.\it*  
\d Ki he Takimu Ľa  Ľi he Kitita, ko e Saame  Ľa  ĽAsafi.  
\q1
\v 1 Hiva kalanga ki he  ĽOtua ko hotau mńĀlohi,  
\q2 kalanga fakafiefia ki he  ĽOtua  Ľo Sńďkope.   
\q1
\v 2 To Ľo mai  Ľae saame, pea  Ľomi  Ľae kihi Ľi lali,  
\q2 mo e ha Ľape mńĀlie mo e saliteli.   
\q1
\v 3 Ifi mńĀlohi  Ľae me Ľa lea  Ľi he mńĀhina fo Ľou,  
\q2  Ľi he  Ľaho kuo tu Ľutu Ľuni,  Ľi hotau  Ľaho kńĀtoanga mamalu.   
\q1
\v 4 He ko e fekau eni ki  ĽIsileli,  
\q2 mo e fono  Ľae  ĽOtua  Ľo Sńďkope.   
\q1
\v 5 Na Ľa ne tu Ľutu Ľuni eni  Ľia Siosefa ko e fakamo Ľoni,  
\q2  Ľi he Ľene  Ľalu atu  Ľi he fonua ko  ĽIsipite:  
\q2  Ľaia na Ľaku fanongo ai ki he lea na Ľe  Ľikai te u  Ľiloa.   
\q1
\v 6 ‚ÄúNa Ľaku hiki  Ľae kavenga mei hono uma:  
\q2 na Ľe hao hono nima mei he ngaahi kato.   
\q1
\v 7 Na Ľa ke ui  Ľi he mamahi, pea ne u fakamo Ľui koe:  
\q2 na Ľaku talia koe  Ľi he potu lilo  Ľoe mana: ne u  Ľahi Ľahi Ľi koe  Ľi he vai  Ľo Melipa. \qs Sila.\qs*   
\q1
\v 8 Fanongo,  ĽE hoku kakai,  
\q2 pea te u fakapapau kiate koe:  
\q2  ĽE  ĽIsileli, kapau te ke tokanga mai kiate au;   
\q1
\v 9 ‚ÄĆ ĽOua na Ľa fokotu Ľu ha  Ľotua fo Ľou kiate koe:  
\q2 pea  Ľe  Ľikai te ke hŇę ki ha  Ľotua fo Ľou.   
\q1
\v 10 Ko au Sihova ko ho  ĽOtua,  
\q2 na Ľaku  Ľomi koe mei he fonua ko  ĽIsipite:  
\q2 fakamanga ho ngutu ke lahi, pea te u fakafonu ia.   
\q1
\v 11 ‚ÄúKa na Ľe  Ľikai fie tokanga  Ľa hoku kakai ki hoku le Ľo;  
\q2 pea na Ľe  Ľikai manako  Ľa  ĽIsileli kiate au.   
\q1
\v 12 Ko ia ne u fakatukutuku Ľi ai  Ľakinautolu ki he holi kovi  Ľa honau loto:  
\q2 pea na Ľa nau  Ľa Ľeva  Ľi he Ľenau ngaahi filio Ľi.   
\q1
\v 13 ‚ÄĆ ĽAmusiaange  Ľeau kuo tokanga  Ľa hoku kakai kiate au,  
\q2 pea  Ľeve Ľeva  Ľa  ĽIsileli  Ľi hoku ngaahi hala!   
\q1
\v 14 Pehńď, kuo u fakavaivai Ľi leva honau ngaahi fili,  
\q2  Ľo mafao atu hoku nima ki honau kau fakamamahi.   
\q1
\v 15 Pea ko e kau fehi Ľa kia Sihova kuo nau fakavaivai  Ľakinautolu kiate ia:  
\q2 ka  Ľe tolonga  Ľo ta Ľengata honau ngaahi  Ľaho.   
\q1
\v 16 Kuo ne fafanga foki  Ľakinautolu  Ľaki  Ľae uite mńĀtu Ľaki lelei:  
\q2 pea u fakamńĀkona  Ľaki  Ľakinautolu  Ľae hone mei he maka.‚ÄĚ   
\c 82  
\cd \it 1  ĽOku enginaki Ľi  Ľe he tangata tohi saame  Ľae kau fakamaau, 5 Pea ne valoki  Ľenau ta Ľetokanga. 9  ĽOku ne kole ki he  ĽOtua ke ne fakamaau.\it*  
\d Ko e Saame  Ľa  ĽAsafi.  
\q1
\v 1 ‚ÄĆ ĽOku  Ľafio  Ľae  ĽOtua  Ľi he fakataha  Ľoe kau mńĀlohi;  
\q2  Ľoku ne fakamaau  Ľi he lotolotonga  Ľoe ngaahi  Ľotua.   
\q1
\v 2 ‚Äú ĽE fńďfńď hono fuoloa mo ho Ľomou fakamaau ta Ľetotonu,  
\q2 pea filifilimńĀnako ki he kakai angahala?‚ÄĚ \qs Sila.\qs*   
\q1
\v 3 ‚ÄúFakamaau  Ľae paea mo e tamai mate:  
\q2 fai angatonu ki he mamahi mo e masiva.   
\q1
\v 4 Fakahaofi  Ľae masiva mo e paea:  
\q2 fakamo Ľui  Ľakinautolu mei he nima  Ľoe kau angahala.‚ÄĚ   
\q1
\v 5 ‚ÄĆ ĽOku  Ľikai te nau  Ľilo,  
\q2 pea  Ľoku  Ľikai te nau fie  Ľilo;  
\q2  Ľoku nau  Ľalu pńď  Ľi he po Ľuli:  
\q2 kuo ue Ľi  Ľae ngaahi tu Ľunga kotoa pńď  Ľo mńĀmani.   
\q1
\v 6 Na Ľaku pehńď, ‚ÄúKo e ngaahi  Ľotua  Ľakimoutolu;  
\q2 pea ko e fńĀnau  Ľae Fungani MńĀ Ľolunga  Ľakimoutolu kotoa pńď.   
\q1
\v 7 Ka temou mate  Ľo hangńď ko e kau tangata,  
\q2 pea tŇć  Ľo hangńď ko e tokotaha  Ľoe hou Ľeiki.‚ÄĚ   
\q1
\v 8 Tu Ľu hake,  ĽE  ĽOtua, fakamaau  Ľa mńĀmani:  
\q2 he te ke ma Ľu  Ľae pule Ľanga kotoa pńď.   
\c 83  
\cd \it 1 Ko e lńĀunga ki he  ĽOtua  Ľi he angatu Ľu  Ľae ngaahi fili. 9 Ko e lotu koe Ľuhi ko kinautolu  Ľoku ta Ľomi  Ľae siasi.\it*  
\d Ko e Hiva pe ko e Saame  Ľa  ĽAsafi.  
\q1
\v 1 ‚ÄĆ ĽE  ĽOtua,  Ľoua na Ľa ke fakalongo pńď:  
\q2  ĽE  ĽOtua,  Ľoua na Ľa ke ta Ľe Ľafio Ľi, pea  Ľoua na Ľa ke nofo pńď.   
\q1
\v 2 Vakai,  Ľoku fakatupu maveuveu  Ľe ho ngaahi fili:  
\q2 pea ko kinautolu  Ľoku fehi Ľa kiate koe kuo nau hiki hake honau  Ľulu.   
\q1
\v 3 Na Ľa nau alea fakalilolilo ki ho Ľo kakai,  
\q2 pea nau fakakaukau fakataha ki he kakai  Ľoku ke malu Ľi.   
\q1
\v 4 Na Ľa nau pehńď, ‚ÄúHa Ľu, ketau faka Ľauha  Ľakinautolu ke  Ľoua na Ľa toe ui  Ľakinautolu ko e pule Ľanga;  
\q2 ke  Ľoua na Ľa kei manatu ki he hingoa  Ľo  ĽIsileli.‚ÄĚ   
\q1
\v 5 He kuo nau fakakaukau  Ľi he loto taha:  
\q2  Ľoku nau fuakava  Ľo angatu Ľu kiate koe:   
\q1
\v 6 Ko e ngaahi fale fehikitaki  Ľo  ĽItomi, mo e kau  ĽIsime Ľeli;  
\q2  Ľa Moape, mo e hako  Ľo Heka ĽńĀ;   
\q1
\v 7 ‚ÄĆ ĽA Kepale, mo  ĽAmoni, mo  ĽAmaleki,  
\q2 ko e kau Filisitia mo e kakai  Ľo Taia;   
\q1
\v 8 ‚ÄĆ ĽOku fakataha mo kinautolu foki  Ľa  ĽAsilia:  
\q2 kuo nau tokoni ki he fńĀnau  Ľa Lote. \qs Sila.\qs*   
\q1
\v 9 Fai kiate kinautolu  Ľo hangńď ko ho Ľo fai ki he kau Mitiani;  
\q2  Ľo hangńď ko Sisela, mo Sapini,  Ľi he vaitafe  Ľo Kisoni:   
\q1
\v 10 ‚ÄĆ ĽAia na Ľe  Ľauha  Ľi Enitoa:  
\q2 na Ľa nau hoko  Ľo hangńď ko e kinoha Ľa ki he kelekele.   
\q1
\v 11 Ngaohi honau ngaahi  Ľeiki ke hangńď ko Olipi, pea tatau mo Siipi:  
\q2  Ľio,  Ľa  Ľenau hou Ľeiki kotoa pńď  Ľo hangńď ko Sipaa, mo Salimuna.   
\q1
\v 12 ‚ÄĆ ĽAia na Ľa nau pehńď, ‚ÄúKetau ma Ľu  Ľae ngaahi fale  Ľoe  ĽOtua mo Ľotautolu.‚ÄĚ   
\q1
\v 13 ‚ÄĆ ĽE hoku  ĽOtua, ke ke ngaohi  Ľakinautolu ke hangńď ko e teka;  
\q2 ke hangńď ko e veve  Ľoku vilingia  Ľi he matangi.   
\q1
\v 14 ‚ÄĆ ĽO hangńď ko e vela  Ľoe vao  Ľakau  Ľi he afi,  
\q2 pea hangńď kuo tutu  Ľae ngaahi mo Ľunga  Ľe he ulo afi.   
\q1
\v 15 Ke fakatanga pehńď  Ľakinautolu  Ľaki ho Ľo fu Ľu taufa,  
\q2 pea fakamanavahńď Ľi  Ľakinautolu  Ľaki ho Ľo afńĀ.   
\q1
\v 16 ‚ÄĆ ĽE Sihova, fakafonu honau mata  Ľi he mńĀ;  
\q2 koe Ľuhi kenau kumi ki ho huafa.   
\q1
\v 17 Tuku kenau puputu Ľu mo mamahi  Ľo ta Ľengata;  
\q2  Ľio, tuku ke mńĀ mo  Ľauha  Ľakinautolu.   
\q1
\v 18 Koe Ľuhi ke  Ľilo  Ľe he kakai ko koe, ko ho huafa  Ľo Ľou ko Sihova,  
\q2 ko e Fungani MńĀ Ľolunga  Ľi mńĀmani kotoa pńď.   
\c 84  
\cd \it 1  ĽOku holi  Ľae palŇćfita ki he fakataha  Ľi he falelotu, 4 Pea ne fakahńĀ  Ľae monŇę Ľia  Ľokinautolu  Ľoku nofo ai. 8  ĽOku lotu ke ne toe kau ai.\it*  
\d Ki he Takimu Ľa  Ľi he Kitita, ko e Saame ki he ngaahi foha  Ľo Kola.  
\q1
\v 1 ‚ÄĆ ĽE Sihova  Ľoe ngaahi kautau,  
\q2  Ľoku lelei lahi ho ngaahi fale fehikitaki!   
\q1
\v 2 ‚ÄĆ ĽOku holi hoku laumńĀlie,  Ľio,  Ľoku ou vaivai  Ľi he fie  Ľalu ki he ngaahi loto ĽńĀ  Ľo Sihova;  
\q2  Ľoku tangi kalanga hoku loto mo hoku kakano ki he  ĽOtua mo Ľui.   
\q1
\v 3 ‚ÄĆ ĽIo, kuo  Ľilo  Ľe he hiki Ľi manupuna  Ľae fale,  
\q2 mo e kulukulu ha pununga ma Ľana,  Ľaia te ne tuku ki ai  Ľene fńĀnau,  
\q2  Ľio, ko ho ngaahi feilaulau Ľanga,  ĽE Sihova  Ľoe ngaahi kautau, ko hoku Tu Ľi, mo hoku  ĽOtua.   
\q1
\v 4 ‚ÄĆ ĽOku monŇę Ľia  Ľakinautolu  Ľoku nofo  Ľi ho fale:  
\q2 tenau kei fakafeta Ľi pe kiate koe. \qs Sila.\qs*   
\q1
\v 5 ‚ÄĆ ĽOku monŇę Ľia  Ľae tangata  Ľoku  Ľiate koe hono mńĀlohi;  
\q2  Ľoku  Ľi hono loto  Ľae ngaahi hala.   
\q1
\v 6 Pea  Ľi he Ľenau  Ľalu  Ľi he toafa  Ľo Peka  Ľoku ngaohi ia ko e matavai;  
\q2  Ľoku fakafonu foki  Ľe he  Ľuha  Ľae ngaahi lepa.   
\q1
\v 7 ‚ÄĆ ĽOku nau  Ľalu  Ľi he mńĀlohi ki he mńĀlohi,  
\q2  Ľo fakahńĀ taki taha kotoa pńď ia  Ľi he  Ľao  Ľoe  ĽOtua  Ľi Saione.   
\q1
\v 8 ‚ÄĆ ĽE Sihova ko e  ĽOtua  Ľoe ngaahi kautau,  
\q2 ke ke fanongo ki he Ľeku lotu:  
\q2 fakafanongo,  ĽE  ĽOtua  Ľo Sńďkope. \qs Sila.\qs*   
\q1
\v 9 Vakai,  ĽE  ĽOtua ko homau fakaŇę,  
\q2 mo ke  Ľafio ki he fofonga  Ľo ho Ľo pani.   
\q1
\v 10 He  Ľoku lelei lahi hake  Ľae  Ľaho pe taha  Ľi ho ngaahi loto  ĽńĀ,  
\q2  Ľi he  Ľaho  Ľe taha afe.  
\q2  ĽOku ou fili mu Ľa ke u nofo ko e le Ľo matapńĀ  Ľi he fale  Ľo hoku  ĽOtua,  
\q2  Ľi he Ľeku nofo  Ľi he ngaahi nofo Ľanga  Ľoe kovi.   
\q1
\v 11 He ko Sihova ko e  ĽOtua ko e la ĽńĀ ia mo e fakaŇę:  
\q2  Ľe foaki  Ľe Sihova  Ľae  Ľalo Ľofa mo e nńĀunau:  
\q2  Ľe  Ľikai te ne ta Ľofi ha me Ľa lelei  Ľe taha meiate kinautolu  Ľoku  Ľa Ľeva totonu.   
\q1
\v 12 ‚ÄĆ ĽE Sihova  Ľoe ngaahi kautau,  
\q2  Ľoku monŇę Ľia  Ľae tangata  Ľoku falala kiate koe.   
\c 85  
\cd \it 1  ĽOku ongo Ľi  Ľe he tangata tohi saame  Ľae  Ľofa  Ľae  ĽOtua, pea  Ľoku ne kole ke ma Ľu pe kiate ia. 8  ĽOku ne fuakava te ne tatali ki ai,  Ľi he loto falala ki he angalelei  Ľae  ĽOtua.\it*  
\d Ki he Takimu Ľa, ko e Saame ki he ngaahi foha  Ľo Kola.  
\q1
\v 1 ‚ÄĆ ĽE Sihova, kuo ke finangalo lelei ki ho fonua:  
\q2 kuo ke toe  Ľomi  Ľa Sńďkope mei he pŇćpula.   
\q1
\v 2 Kuo ke fakamolemole  Ľae hia  Ľa ho Ľo kakai,  
\q2 kuo ke  Ľufi Ľufi  Ľenau angahala kotoa pńď. \qs Sila.\qs*   
\q1
\v 3 Kuo ke to Ľo  Ľo  Ľave ho houhau kotoa pńď:  
\q2 kuo ke fakatafoki koe mei he kakaha  Ľo ho houhau.   
\q1
\v 4 Fakatafoki  Ľakimautolu,  ĽE  ĽOtua  Ľo  Ľemau mo Ľui,  
\q2 pea ke fakangata ho houhau kiate kimautolu.   
\q1
\v 5 Te ke houhau kiate kimautolu ke ta Ľengata?  
\q2 Te ke toloi atu ho houhau ki he to Ľutangata kotoa pńď?   
\q1
\v 6 ‚ÄĆ ĽIkai te ke toe fakaakeake  Ľakimautolu:  
\q2 koe Ľuhi ke fiefia ho Ľo kakai  Ľiate koe?   
\q1
\v 7 FakahńĀ kiate kimautolu ho Ľo  Ľalo Ľofa,  ĽE Sihova,  
\q2 mo ke tuku kiate kimautolu  Ľa ho Ľo fakamo Ľui.   
\q1
\v 8 Te u fanongo ki he folofola  Ľae  ĽOtua ko Sihova:  
\q2 he te ne folofola Ľaki  Ľae melino ki hono kakai, pea ki he Ľene kau mńĀ Ľoni Ľoni:  
\q2 kae Ľoua na Ľa nau toe tafoki ki he kovi.   
\q1
\v 9 Ko e mo Ľoni  Ľoku ofi  Ľene fakamo Ľui kiate kinautolu  Ľoku manavahńď kiate ia,  
\q2 koe Ľuhi ke nofo  Ľae monŇę Ľia  Ľi hotau fonua.   
\q1
\v 10 Kuo fakafetaulaki  Ľae  Ľalo Ľofa mo e mo Ľoni;  
\q2 ko e mńĀ Ľoni Ľoni mo e melino kuo na toutou fekita.   
\q1
\v 11 ‚ÄĆ ĽE tupu hake  Ľae mo Ľoni mei he kelekele;  
\q2 pea  Ľe sio hifo  Ľae mńĀ Ľoni Ľoni mei he langi.   
\q1
\v 12 ‚ÄĆ ĽIo,  Ľe foaki  Ľe Sihova  Ľaia  Ľoku lelei;  
\q2 pea  Ľe tuku mai hono fua  Ľe hotau fonua.   
\q1
\v 13 ‚ÄĆ ĽE mu Ľomu Ľa  Ľiate ia  Ľae mńĀ Ľoni Ľoni,  
\q2  Ľo ne fokotu Ľu hotau va Ľe  Ľi hono hala.   
\c 86  
\cd \it 1 Ko e tokoni  Ľaki  Ľe Tevita  Ľene hŇę  Ľi he Ľene  Ľilo Ľi  Ľae  Ľofa, mo e angalelei, mo e mńĀlohi  Ľae  ĽOtua. 11  ĽOku ne holi ke ne ma Ľu pe  Ľae hala  Ľo ia. 14  ĽOku hanu ia  Ľi he kau fielahi, pea ne kole faka Ľilonga ki he angalelei  Ľae  ĽOtua.\it*  
\d Ko e Lotu  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE Sihova, ke ke fofonga mai,  Ľo fanongo kiate au:  
\q2 he  Ľoku ou masiva mo mamahi.   
\q1
\v 2 Fakamo Ľui hoku laumńĀlie; he  Ľoku ou mńĀ Ľoni Ľoni:  
\q2  Ľa koe ko hoku  ĽOtua, fakamo Ľui ho Ľo tamaio Ľeiki  Ľaia  Ľoku falala kiate koe.   
\q1
\v 3 ‚ÄĆ ĽE  ĽEiki, ke ke  Ľalo Ľofa kiate au:  
\q2 he  Ľoku ou tangi kiate koe  Ľi he  Ľaho kotoa pńď.   
\q1
\v 4 ‚ÄĆ ĽE  ĽEiki, fakafiefia Ľi  Ľae laumńĀlie  Ľo ho Ľo tamaio Ľeiki:  
\q2 he  Ľoku ou hiki hake hoku laumńĀlie kiate koe.   
\q1
\v 5 He ko koe,  ĽE  ĽEiki  Ľoku ke angalelei, pea fa Ľa fakamolemole;  
\q2 pea mohu  Ľalo Ľofa kiate kinautolu kotoa pńď  Ľoku ui kiate koe.   
\q1
\v 6 Fanongo,  ĽE Sihova, ki he Ľeku lotu  
\q2 pea tokanga ki he le Ľo  Ľo  Ľeku ngaahi lotu tńĀuma Ľu.   
\q1
\v 7 ‚ÄĆ ĽI he  Ľaho  Ľo  Ľeku mamahi te u ui kiate koe;  
\q2 he te ke talia au.   
\q1
\v 8 ‚ÄĆ ĽE  ĽEiki,  Ľoku  Ľikai ha tokotaha  Ľi he ngaahi  Ľotua  Ľoku tatau mo koe;  
\q2 pea  Ľoku  Ľikai ha ngńĀue  Ľe hangńď ko ho Ľo ngaahi ngńĀue.   
\q1
\v 9 ‚ÄĆ ĽE  ĽEiki,  Ľe ha Ľu  Ľo hŇę  Ľi ho  Ľao  Ľae ngaahi pule Ľanga kotoa pńď na Ľa ke ngaohi;  
\q2 pea tenau fakaongoongolelei Ľi ho huafa.   
\q1
\v 10 He  Ľoku ke lahi, pea  Ľoku ke fai  Ľae ngaahi me Ľa mana:  
\q2 ko koe pńď ko e  ĽOtua.   
\q1
\v 11 ‚ÄĆ ĽE Sihova, ako kiate au ho hala;  
\q2 te u  Ľeve Ľeva  Ľi ho Ľo mo Ľoni:  
\q2 ngaohi ke taha pńď hoku loto ke manavahńď ki ho huafa.   
\q1
\v 12 ‚ÄĆ ĽE  ĽEiki ko hoku  ĽOtua, te u fakafeta Ľi kiate koe  Ľaki hoku loto kotoa:  
\q2 pea te u fakaongoongolelei ho huafa  Ľo ta Ľengata.   
\q1
\v 13 He  Ľoku lahi ho Ľo  Ľalo Ľofa kiate au:  
\q2 pea kuo ke fakamo Ľui hoku laumńĀlie mei he loto heli.   
\q1
\v 14 ‚ÄĆ ĽE  ĽOtua, kuo tu Ľu hake kiate au  Ľae kau fielahi,  
\q2 pea na Ľe kumi hoku laumńĀlie  Ľe he ngaahi fakataha  Ľoe kau fakamńĀlohi;  
\q2 pea  Ľoku  Ľikai tenau fokotu Ľu  Ľa ho Ľo  Ľafio  Ľi honau  Ľao.   
\q1
\v 15 Ka ko koe,  ĽE  ĽEiki, ko e  ĽOtua  Ľoku fonu  Ľi he manava Ľofa, mo e angalelei,  
\q2  Ľoku ke kńĀtaki fuoloa, pea mohu  Ľalo Ľofa mo e mo Ľoni.   
\q1
\v 16 Ke ke tafoki mai kiate au, pea  Ľalo Ľofa kiate au;  
\q2 foaki ho mńĀlohi ki ho Ľo tamaio Ľeiki,  
\q2 pea fakamo Ľui  Ľae tama  Ľa ho Ľo kaunanga.   
\q1
\v 17 FakahńĀ kiate au  Ľae faka Ľilonga  Ľoe lelei;  
\q2 koe Ľuhi ke mamata ki ai  Ľakinautolu  Ľoku fehi Ľa kiate au, pea mńĀ ai:  
\q2 koe Ľuhi kuo ke tokoni Ľi au,  ĽE Sihova,  Ľo fakafiemńĀlie Ľi au.   
\c 87  
\cd \it 1 Ko e anga mo e nńĀunau  Ľoe siasi. 4 Ko e tupulaki, mo e ongoongolelei, mo e fiemńĀlie  Ľoe kau lotu.\it*  
\d Ko e Saame pe ko e Hiva ki he ngaahi foha  Ľo Kola.  
\q1
\v 1 Ko hono tu Ľunga  Ľoku  Ľi he ngaahi mo Ľunga mńĀ Ľoni Ľoni.   
\q1
\v 2 ‚ÄĆ ĽOku  Ľofa lahi hake  Ľa Sihova ki he ngaahi matapńĀ  Ľo Saione,  
\q2  Ľi he ngaahi nofo Ľanga kotoa pńď  Ľo Sńďkope.   
\q1
\v 3 ‚ÄĆ ĽA e kolo  Ľoe  ĽOtua,  Ľoku talanoa  Ľaki  Ľae ngaahi me Ľa ongoongolelei  Ľiate koe. \qs Sila.\qs*   
\q1
\v 4 ‚ÄúTe u fakahńĀ  Ľa Lehapi mo Papilone kiate kinautolu  Ľoku  Ľilo Ľi au:  
\q2 vakai, ko Filisitia, mo Taia, mo  ĽItiopea;  
\q2 ‚Äúna Ľe fanau Ľi  Ľi ai  Ľae tangata ni.‚ÄĚ   
\q1
\v 5 Pea  Ľe lau pehńď ki Saione,  
\q2 ‚ÄúKo e tangata ni mo e tangata na na Ľe fanau Ľi  Ľi ai‚ÄĚ:  
\q2 pea  Ľe fakatu Ľuma Ľu ia  Ľe he Fungani MńĀ Ľolunga.   
\q1
\v 6 ‚ÄĆ ĽE lau  Ľe Sihova,  Ľi he Ľene tohi  Ľae kakai,  
\q2 ‚Äúko e tangata ni na Ľe fanau Ľi  Ľi ai.‚ÄĚ \qs Sila.\qs*   
\q1
\v 7 ‚ÄĆ ĽE  Ľi ai fakatou Ľosi  Ľae kau hiva mo e kau pulotu  Ľoe ngaahi me Ľa faiva:  
\q2 ‚Äúko  Ľeku ngaahi matavai kotoa pńď  Ľoku  Ľiate koe.‚ÄĚ   
\c 88  
\cd \it 1‚Äď8 Ko e lotu  Ľi he mamahi lahi.\it*  
\d Ko e Hiva pe ko e Saame ki he ngaahi foha  Ľo Kola, ki he Takimu Ľa  Ľi he Mahalati Leanoti, ko e akonaki  Ľa Hemani  Ľi he fa Ľahinga  Ľo Esela.  
\q1
\v 1 ‚ÄĆ ĽE Sihova ko e  ĽOtua  Ľo  Ľeku mo Ľui,  
\q2 na Ľaku tangi  Ľi he  Ľaho mo e pŇć  Ľi ho  Ľao:   
\q1
\v 2 Tuku ke a Ľu atu  Ľeku lotu ki ho  Ľao ke ke fofonga mai ki he Ľeku tangi;   
\q1
\v 3 He  Ľoku fonu hoku laumńĀlie  Ľi he mamahi:  
\q2 pea  Ľoku faka Ľa Ľau  Ľeku mo Ľui ki he fa Ľitoka.   
\q1
\v 4 ‚ÄĆ ĽOku lau fakataha au mo kinautolu  Ľoku  Ľalu hifo ki he luo:  
\q2  Ľoku ou hangńď ha tangata  Ľoku  Ľikai hano mńĀlohi:   
\q1
\v 5 ‚ÄĆ ĽO tau ĽatńĀina mo e kakai mate,  
\q2  Ľo hangńď ko e kakai kuo tńĀmate Ľi  Ľoku tokoto  Ľi he fa Ľitoka,  
\q2  Ľakinautolu  Ľoku  Ľikai te ke kei manatu Ľi:  
\q2 pea kuo motuhi  Ľakinautolu  Ľe ho nima.   
\q1
\v 6 Kuo ke tuku au  Ľi he luo taumama Ľo,  
\q2  Ľi he fakapo Ľuli,  
\q2  Ľi he ngaahi loloto.   
\q1
\v 7 ‚ÄĆ ĽOku tata Ľo mamafa ho houhau  Ľiate au,  
\q2 pea kuo ke fakamamahi Ľi au  Ľaki ho Ľo ngaahi peau kotoa pńď. \qs Sila.\qs*   
\q1
\v 8 Kuo ke fakamama Ľo atu hoku ngaahi kaume Ľa;  
\q2 kuo ke ngaohi au ko e me Ľa fakalielia kiate kinautolu:  
\q2 kuo  ĽńĀkilotoa au, pea  Ľoku  Ľikai te u fa Ľa  Ľalu atu.   
\q1
\v 9 ‚ÄĆ ĽOku vaivai hoku mata ko e me Ľa  Ľi he mamahi:  
\q2  ĽE Sihova,  Ľoku ou ui kiate koe  Ľi he  Ľaho kotoa pńď,  
\q2 kuo u mafao atu hoku nima kiate koe.   
\q1
\v 10 Te ke fakahńĀ  Ľae ngaahi me Ľa mana ki he mate?  
\q2  ĽE tu Ľu hake  Ľae mate  Ľo fakafeta Ľi kiate koe? \qs Sila.\qs*   
\q1
\v 11 ‚ÄĆ ĽE fakahńĀ atu  Ľa ho Ľo  Ľalo Ľofa  Ľi he fa Ľitoka?  
\q2 Pe ko ho Ľo mo Ľoni  Ľi he faka Ľauha?   
\q1
\v 12 ‚ÄĆ ĽE  Ľilo Ľi ho Ľo ngaahi ngńĀue fakaofo  Ľi he po Ľuli?  
\q2 Mo ho Ľo mńĀ Ľoni Ľoni  Ľi he fonua  Ľoe fakangalo?   
\q1
\v 13 Ka na Ľaku tangi kiate koe,  ĽE Sihova;  
\q2 pea  Ľi he pongipongi  Ľe a Ľu atu kiate koe  Ľeku lotu.   
\q1
\v 14 ‚ÄĆ ĽE Sihova, ko e hńĀ  Ľoku ke li Ľaki ai  Ľa hoku laumńĀlie?  
\q2 Ko e hńĀ  Ľoku ke fufŇę ai ho fofonga  Ľiate au?   
\q1
\v 15 ‚ÄĆ ĽOku ou mamahi, pea meimei mate talu  Ľeku kei talavou:  
\q2  Ľi he Ľeku kńĀtaki ho Ľo ngaahi me Ľa fakailifia  Ľoku ou feinga ai  Ľaupito.   
\q1
\v 16 Kuo lŇćfia au  Ľe ho houhau lahi;  
\q2 kuo motuhi au  Ľe ho Ľo ngaahi fakailifia.   
\q1
\v 17 Na Ľa nau kńĀpui au  Ľi he  Ľaho kotoa pńď  Ľo hangńď ko e vai;  
\q2 na Ľa nau fakataha  Ľo takatakai au.   
\q1
\v 18 Ko e kaume Ľa Ľofa mo e kńĀinga kuo ke fakamama Ľo atu  Ľiate au,  
\q2 mo hoku kaume Ľa ki he po Ľuli.   
\c 89  
\cd \it 1  ĽOku fakamńĀlŇć  Ľe he tangata tohi saame ki he  ĽOtua koe Ľuhi ko  Ľene fuakava, 5 Mo hono mńĀlohi lahi, 15 Mo  Ľene tokanga ki hono siasi, 19 Mo  Ľene  Ľofa ki he pule Ľanga  Ľo Tevita. 38  ĽOku ne lńĀunga koe Ľuhi ko e ngaahi me Ľa kovi. 46  ĽOku ne  Ľeke, mo lotu, pea fakafeta Ľi ki he  ĽOtua.\it*  
\d Ko e Saame akonaki  Ľa Itani  Ľi he fa Ľahinga  Ľo Esela.  
\q1
\v 1 Te u hiva  Ľaki  Ľae ngaahi  Ľalo Ľofa  Ľa Sihova  Ľo ta Ľengata:  
\q2 te u faka Ľilo  Ľaki hoku ngutu  Ľa ho Ľo mo Ľoni ki he to Ľutangata kotoa pńď.   
\q1
\v 2 He na Ľaku pehńď, ‚Äú ĽE fokotu Ľuma Ľu pńď  Ľa e  Ľalo Ľofa  Ľo ta Ľengata:  
\q2 ko ho Ľo mo Ľoni te ke fakatu Ľuma Ľu  Ľi he ngaahi langi.‚ÄĚ   
\b  
\q1
\v 3 Kuo u fai  Ľae fuakava mo  Ľeku fili,  
\q2 kuo u fuakava ki he Ľeku tamaio Ľeiki ko Tevita.   
\q1
\v 4 ‚ÄúTe u fakatu Ľuma Ľu ho hako  Ľo ta Ľengata,  
\q2 te u fokotu Ľu ho pule Ľanga ki he to Ľutangata kotoa pńď.‚ÄĚ \qs Sila.\qs*   
\q1
\v 5 Pea  Ľe fakamńĀlŇć  Ľe he ngaahi langi ki ho Ľo ngaahi ngńĀue fakaofo,  ĽE Sihova:  
\q2 mo ho Ľo mo Ľoni foki  Ľi he fakataha  Ľoe kau mńĀ Ľoni Ľoni.   
\q1
\v 6 He ko hai  Ľi he langi  Ľe fakatatau ia kia Sihova?  
\q2 Ko hai  Ľi he ngaahi foha  Ľoe mńĀlohi  Ľe fa Ľa fakatatau kia Sihova?   
\q1
\v 7 ‚ÄĆ ĽOku totonu ke manavahńď lahi ki he  ĽOtua  Ľi he fakataha  Ľoe kau mńĀ Ľoni Ľoni,  
\q2 pea ke faka Ľapa Ľapa  Ľakinautolu kotoa pńď  Ľoku tu Ľu takatakai kiate ia.   
\q1
\v 8 ‚ÄĆ ĽE Sihova ko e  ĽOtua  Ľoe ngaahi kautau, ko hai  Ľoku tatau mo koe ko Sihova mńĀfimafi?  
\q2 Pea ko ho Ľo mo Ľoni  Ľoku kńĀpui koe.   
\q1
\v 9 ‚ÄĆ ĽOku ke pule Ľi  Ľae ngaue mńĀlohi  Ľoe tahi:  
\q2  Ľoka hou hono ngaahi peau,  Ľoku ke fakatofukńę ia.   
\q1
\v 10 Kuo ke fesi Ľi  Ľa Lehapi ke lailai,  Ľo hangńď ha taha kuo tńĀmate Ľi;  
\q2 kuo fakahńď Ľi ho ngaahi fili  Ľaki ho nima mńĀlohi.   
\q1
\v 11 ‚ÄĆ ĽOku  Ľo Ľou  Ľae ngaahi langi,  
\q2 pea  Ľoku  Ľo Ľou foki mo e fonua: ko mńĀmani mo hono fonu  
\q2  Ľo ia kuo ke fakatu Ľuma Ľu ia.   
\q1
\v 12 Kuo ke ngaohi  Ľae potu tokelau mo e potu tonga:  
\q2 ko Tepoa mo Heamoni  Ľe fiefia  Ľi ho huafa.   
\q1
\v 13 ‚ÄĆ ĽOku  Ľiate koe  Ľae nima mńĀfimafi  Ľoku mńĀlohi ho nima,  
\q2 pea mńĀ Ľolunga ho nima to Ľomata Ľu.   
\q1
\v 14 Ko e angatonu mo e fakamaau ko e tu Ľunga ia  Ľo ho  Ľafio Ľanga:  
\q2  Ľe mu Ľomu Ľa  Ľi ho  Ľao  Ľae  Ľalo Ľofa mo e mo Ľoni.   
\q1
\v 15 ‚ÄĆ ĽOku monŇę Ľia  Ľae kakai  Ľoku nau  Ľilo Ľi  Ľae ongoongo fakafiefia:  
\q2 tenau  Ľa Ľeva,  ĽE Sihova,  Ľi he maama  Ľo ho fofonga.   
\q1
\v 16 Te nau fiefia  Ľi ho huafa  Ľi he  Ľaho kotoa pńď:  
\q2 pea  Ľi ho Ľo mńĀ Ľoni Ľoni  Ľe hakeaki Ľi ai  Ľakinautolu.   
\q1
\v 17 He ko koe ko e vikiviki Ľanga  Ľo honau mńĀlohi:  
\q2 pea  Ľi ho Ľo  Ľofa  Ľe hiki ai ki  Ľolunga honau nifo.   
\q1
\v 18 He ko homau hŇęfanga  Ľa Sihova;  
\q2 pea ko e tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli ko homau tu Ľi.   
\q1
\v 19 Pea na Ľa ke toki folofola  Ľi he me Ľa ha mai ki ho Ľo tokotaha mńĀ Ľoni Ľoni,  
\q2  Ľo pehńď, ‚ÄúKuo u hilifaki  Ľae tokoni ki ha tokotaha  Ľoku mńĀlohi;  
\q2 kuo u fakahikihiki  Ľae tokotaha kuo fili mei he kakai.   
\q1
\v 20 Kuo u  Ľilo Ľi  Ľa Tevita ko  Ľeku tamaio Ľeiki;  
\q2 pea kuo u tńĀkai  Ľaki ia  Ľa  Ľeku lolo mńĀ Ľoni Ľoni:   
\q1
\v 21 ‚ÄĆ ĽE tu Ľuma Ľu hoku nima mo ia:  
\q2 ko hoku nima foki  Ľe fakamńĀlohi Ľi ia.   
\q1
\v 22 ‚ÄĆ ĽE  Ľikai fai fakamńĀlohi kiate ia  Ľe he fili;  
\q2 pe fakamamahi Ľi ia  Ľe he foha  Ľoe angakovi.   
\q1
\v 23 Pea te u taa Ľi hifo hono ngaahi fili  Ľi hono  Ľao,  
\q2 pea tautea  Ľakinautolu  Ľoku fehi Ľa kiate ia.   
\q1
\v 24 Ka  Ľe  Ľiate ia  Ľa  Ľeku mo Ľoni mo  Ľeku  Ľalo Ľofa:  
\q2 pea  Ľi hoku huafa  Ľe hiki ki  Ľolunga ai  Ľa hono nifo.   
\q1
\v 25 Te u  Ľai foki hono nima ki he tahi,  
\q2 mo hono nima to Ľomata Ľu ki he ngaahi vaitafe.   
\q1
\v 26 ‚ÄĆ ĽE tangi ia kiate au, ‚ÄėKo koe ko  Ľeku Tamai,  
\q2 ko hoku  ĽOtua, mo e maka  Ľo hoku fakamo Ľui.‚Äô   
\q1
\v 27 Pea te u ngaohi foki ia ko hoku  Ľuluaki foha,  
\q2  Ľe mńĀ Ľolunga lahi ia  Ľi he ngaahi tu Ľi  Ľo mńĀmani.   
\q1
\v 28 Te u tuku  Ľeku  Ľalo Ľofa ma Ľana  Ľo ta Ľengata,  
\q2 pea  Ľe tu Ľuma Ľu  Ľeku fuakava mo ia.   
\q1
\v 29 Te u ngaohi foki hono hako kenau tolonga  Ľo ta Ľengata,  
\q2 mo hono nofo Ľa  Ľo hangńď ko e ngaahi  Ľaho  Ľoe langi.   
\q1
\v 30 ‚ÄúKapau  Ľe li Ľaki  Ľeku akonaki  Ľe he Ľene fńĀnau,  
\q2  Ľo  Ľikai  Ľa Ľeva  Ľi he Ľeku ngaahi fakamaau;   
\q1
\v 31 Kapau tenau maumau Ľi  Ľeku ngaahi tu Ľutu Ľuni,  
\q2 pea  Ľikai tauhi  Ľeku ngaahi fekau;   
\q1
\v 32 Pea te u toki  Ľa Ľahi  Ľenau ngaahi talangata Ľa  Ľaki  Ľae me Ľa kini,  
\q2 mo  Ľenau hia  Ľaki  Ľae ngaahi tńĀ.   
\q1
\v 33 Ka  Ľe  Ľikai te u hiki  Ľaupito  Ľeku manava Ľofa  Ľiate ia,  
\q2 pe tuku ta Ľehoko  Ľa  Ľeku mo Ľoni.   
\q1
\v 34 ‚ÄĆ ĽE  Ľikai te u li Ľaki  Ľeku fuakava,  
\q2 pe fakakehe  Ľae me Ľa kuo  Ľalu atu  Ľi hoku loungutu.   
\q1
\v 35 ‚ÄúKuo u fuakava tu Ľo taha  Ľi he Ľeku mńĀ Ľoni Ľoni  Ľe  Ľikai te u loi kia Tevita.   
\q1
\v 36 ‚ÄĆ ĽE tolonga  Ľene fńĀnau  Ľo ta Ľengata,  
\q2 mo hono nofo Ľa  Ľo hangńď ko e la ĽńĀ  Ľi hoku  Ľao.   
\q1
\v 37 ‚ÄĆ ĽE fakatu Ľuma Ľu ia ke ta Ľengata  Ľo hangńď ko e mńĀhina,  
\q2 pea hangńď ko e fakamo Ľoni  Ľi he langi.‚ÄĚ \qs Sila.\qs*   
\q1
\v 38 Ka kuo li Ľaki mo fńĀkalili Ľa,  
\q2 mo ke houhau kiate ia na Ľa ke pani.   
\q1
\v 39 Kuo ke fakata Ľe Ľaonga Ľi  Ľae fuakava  Ľa ho Ľo tamaio Ľeiki:  
\q2 kuo ke fakakovi Ľi hono tatńĀ  Ľi ho Ľo lńę ia ki he kelekele.   
\q1
\v 40 Kuo ke maumau Ľi hifo hono ngaahi  ĽńĀ kotoa pńď;  
\q2 kuo ke faka Ľauha hono ngaahi potu mńĀlohi.   
\q1
\v 41 Ko kinautolu kotoa pńď  Ľoku  Ľalu  Ľi he hala  Ľoku nau kaiha Ľa  Ľiate ia:  
\q2 ko e manuki Ľanga ia  Ľo hono ngaahi kaungńĀ Ľapi.   
\q1
\v 42 Kuo ke hiki hake  Ľae nima to Ľomata Ľu  Ľo hono ngaahi fili;  
\q2 kuo ke fakafiefia Ľi  Ľa hono ngaahi fili kotoa pńď.   
\q1
\v 43 Kuo ke liliu foki  Ľae mata  Ľo  Ľene heletńĀ,  
\q2 pea  Ľe  Ľikai te ke ngaohi ia ke tu Ľu  Ľi he tau.   
\q1
\v 44 Kuo ke faka Ľosi hono nńĀunau,  
\q2 pea lńę hono nofo Ľa ki he kelekele.   
\q1
\v 45 Kuo ke fakafuonounou  Ľae ngaahi  Ľaho  Ľo  Ľene talavou:  
\q2 kuo ke  Ľufi Ľufi  Ľaki ia  Ľae mńĀ. \qs Sila.\qs*   
\q1
\v 46 ‚ÄĆ ĽE Sihova,  Ľe fńďfńď hono fuoloa?  
\q2 Te ke fakafufŇę koe  Ľo ta Ľengata?  
\q2  ĽE vela ho houhau  Ľo hangńď ko e afi?   
\q1
\v 47 Manatu ki hono fuonounou  Ľo  Ľeku mo Ľui:  
\q2 ko e hńĀ kuo ke ngaohi  Ľae kakai kotoa pńď ke ta Ľe Ľaonga?   
\q1
\v 48 Ko hai  Ľae tangata ko ia  Ľoku mo Ľui,  
\q2 pea  Ľe  Ľikai te ne mamata ki he mate?  ĽE fakamo Ľui  Ľe ia  Ľa hono laumńĀlie mei he nima  Ľoe fa Ľitoka? \qs Sila.\qs*   
\q1
\v 49 ‚ÄĆ ĽE  ĽEiki, ko e fńď ho Ľo ngaahi  Ľalo Ľofa  Ľi mu Ľa,  
\q2  Ľaia na Ľa ke fuakava  Ľaki kia Tevita  Ľi ho Ľo mo Ľoni?   
\q1
\v 50 Manatu,  ĽE  ĽEiki, ki he manuki Ľi  Ľo ho Ľo kau tamaio Ľeiki;  
\q2 mo  Ľeku fua  Ľi hoku fatafata  Ľae manuki  Ľae kakai mńĀlohi kotoa pńď;   
\q1
\v 51 ‚ÄĆ ĽAia kuo manuki  Ľaki  Ľe ho ngaahi fili,  
\q2  ĽE Sihova;  Ľaia kuo nau manuki  Ľaki  Ľae ngaahi  Ľalu Ľanga  Ľo ia kuo ke pani.   
\q1
\v 52 Fakafeta Ľi kia Sihova  Ľo ta Ľengata.  
\q2  ĽEmeni, mo  ĽEmeni.   
\c 90  
\ms1 TOHI 4  
\mr (Saame 90‚ÄĒ106)  
\cd \it 1  ĽOku fakahńĀ  Ľe MŇćsese  Ľae pule  Ľae  ĽOtua, 3 Mo e vaivai  Ľoe tangata, 7 Mo e tautea  Ľe he  ĽOtua, 10 Mo e molengofua  Ľoe mo Ľui. 12  ĽOku ne kole ke ne  Ľilo Ľi  Ľae pule lelei  Ľae  ĽOtua.\it*  
\d Ko e Lotu  Ľa MŇćsese ko e tangata  Ľoe  ĽOtua.  
\q1
\v 1 ‚ÄĆ ĽE Sihova, ko koe ko homau hŇęfanga  Ľi he to Ľutangata kotoa pńď.   
\q1
\v 2 ‚ÄĆ ĽI he te Ľeki ai fakatupu  Ľae ngaahi mo Ľunga,  
\q2 pea te Ľeki ai te ke ngaohi  Ľae fonua mo mńĀmani,  
\q2  Ľio, talu mei mu Ľa  Ľo a Ľu  Ľo ta Ľengata, ko koe pe ko e  ĽOtua.   
\q1
\v 3 ‚ÄĆ ĽOku ke liliu  Ľae tangata ke  Ľauha; pea ke pehńď,  
\q2 ‚ÄúTafoki,  Ľakimoutolu  Ľae fńĀnau  Ľae tangata.‚ÄĚ   
\q1
\v 4 He  Ľoku tatau  Ľi ho  Ľao  Ľae ta Ľu  Ľe afe mo e  Ľaneafi  Ľi hono hili ange ia,  
\q2 pea mo e le Ľo  Ľi he pŇć.   
\q1
\v 5 ‚ÄĆ ĽOku ke  Ľave  Ľakinautolu  Ľo hangńď ko e  Ľave  Ľe he vaitafe;  Ľoku nau hangńď ko e mohe:  
\q2  Ľi he pongipongi  Ľoku nau tatau mo e mohuku  Ľoku tupu hake.   
\q1
\v 6 ‚ÄĆ ĽI he pongipongi  Ľoku lau ma Ľui Ľui ia, pea tupu hake:  
\q2  Ľi he efiafi  Ľoku tu Ľusi hifo ia, pea mae.   
\q1
\v 7 He  Ľoku mau  Ľauha  Ľi ho houhau,  
\q2 pea  Ľoku mau mamahi  Ľi ho tuputńĀmaki.   
\q1
\v 8 Kuo ke tuku  Ľemau ngaahi hia  Ľi ho  Ľao,  
\q2 pea mo  Ľemau ngaahi angahala fufŇę  Ľi he maama  Ľo ho fofonga.   
\q1
\v 9 He  Ľoku  Ľosi atu homau ngaahi  Ľaho kotoa pńď  Ľi ho houhau:  
\q2  Ľoku mau faka Ľosi homau ngaahi ta Ľu  Ľo hangńď ko e talanoa  Ľoku lau.   
\q1
\v 10 Ko e ngaahi  Ľaho  Ľo homau ta Ľu ko e ta Ľu  Ľe fitungofulu;  
\q2 pea kapau  Ľe hoko ia  Ľi hono mńĀlohi ke valungofulu,  
\q2 ko hono mńĀlohi ko e ngńĀue mo e mamahi;  
\q2 he  Ľoku tu Ľusi vave ia, pea  Ľoku mau puna atu.   
\q1
\v 11 Ko hai  Ľoku ne  Ľilo Ľi  Ľae mńĀlohi  Ľo ho houhau?  
\q2  ĽO hangńď ko ho manavahńď Ľia,  Ľoku pehńď ho houhau.   
\q1
\v 12 Ke pehńď ho Ľo akonaki Ľi  Ľakimautolu ke mau lau homau ngaahi  Ľaho,  
\q2 koe Ľuhi ke mau fakatokanga Ľi homau loto ki he poto.   
\q1
\v 13 Tafoki,  ĽE Sihova,  
\q2  Ľe fńďfńď hono fuoloa?  
\q2 Pea ke lolou koe Ľuhi ko ho Ľo kau tamaio Ľeiki.   
\q1
\v 14 Ke ke fakamńĀkona vave  Ľakimautolu  Ľaki ho Ľo  Ľalo Ľofa;  
\q2 koe Ľuhi ke mau fiefia mo nekeneka  Ľi homau  Ľaho fulipńď.   
\q1
\v 15 Ke ke fakafiefia Ľi  Ľakimautolu  Ľo fakatatau ki he ngaahi  Ľaho ne ke fakamamahi Ľi ai  Ľakimautolu,  
\q2 pea mo e ngaahi ta Ľu kuo mau mamata ai ki he kovi.   
\q1
\v 16 Pea ke tuku ke hńĀ ki ho Ľo kau tamaio Ľeiki  Ľa ho Ľo ngńĀue,  
\q2 pea mo ho nńĀunau ki he Ľenau fńĀnau.   
\q1
\v 17 Pea ke  Ľiate kimautolu  Ľae lelei  Ľo Sihova ko homau  ĽOtua:  
\q2 pea ke fokotu Ľu ke ma Ľu  Ľae ngńĀue  Ľa homau nima kiate kimautolu;  
\q2  Ľio, ko e ngńĀue  Ľa homau nima ke fakamaau ia.   
\c 91  
\cd \it 1 Ko e fakahńĀ  Ľae monŇę Ľia  Ľae kakai angafaka Ľotua, 3 Mo  Ľenau fiemńĀlie, 9 Mo honau nofo Ľanga, 11 Mo honau kau tauhi, 14 Mo honau kńĀinga  Ľofa.\it*  
\q1
\v 1 Ko ia  Ľoku nofo  Ľi he potu lilo  Ľi he fungani mńĀ Ľolunga,  Ľe nofoma Ľu ia he malumalu  Ľoe MńĀfimafi.   
\q1
\v 2 Te u pehńď, ‚ÄúKo Sihova, ko hoku hŇęfanga ia mo  Ľeku kolo:  
\q2 ko hoku  ĽOtua te u falala kiate ia.‚ÄĚ   
\q1
\v 3 Ko e mo Ľoni te ne fakamo Ľui koe mei he hele  Ľae tangata tauhele,  
\q2 pea mei he mahaki faka Ľauha.   
\q1
\v 4 Te ne  ĽŇć ĽŇćfaki koe  Ľaki hono fulufulu,  
\q2 pea te ke falala ki hono lalo kapakau:  
\q2 ko  Ľene mo Ľoni ko ho fakaŇę mo ho pńĀ ia.   
\q1
\v 5 ‚ÄĆ ĽE  Ľikai te ke manavahńď koe Ľuhi ko e me Ľa fakailifia  Ľi he pŇć;  
\q2 pe koe Ľuhi ko e ngahau  Ľoku puna atu  Ľi he  Ľaho;   
\q1
\v 6 Pe koe Ľuhi ko e mahaki lahi  Ľoku  Ľeve Ľeva  Ľi he po Ľuli;  
\q2 pe koe Ľuhi ko e faka Ľauha  Ľoku faka Ľosi Ľosi  Ľi he ho ĽatńĀ.   
\q1
\v 7 ‚ÄĆ ĽE tŇć  Ľae toko afe  Ľi ho tafa Ľaki,  
\q2 pea ko e toko mano  Ľi ho nima to Ľomata Ľu ka  Ľe  Ľikai hoko ia  Ľo ofi kiate koe.   
\q1
\v 8 Ka te ke vakai  Ľo mamata  Ľaki ho mata ki he totongi  Ľoe angahala.   
\q1
\v 9 Koe Ľuhi kuo ke fili  Ľa Sihova  Ľaia ko hoku hŇęfanga,  
\q2  Ľio, ko e fungani mńĀ Ľolunga ko ho nofo Ľanga:   
\q1
\v 10 ‚ÄĆ ĽE  Ľikai tŇć ha kovi kiate koe,  
\q2 pea  Ľe  Ľikai hoko ha mamahi faka Ľauha ke ofi ki ho nofo Ľanga.   
\q1
\v 11 He te ne fekau  Ľene kau  ĽńĀngelo kenau vakai koe,  
\q2 ke tauhi koe  Ľi ho ngaahi hala kotoa pńď.   
\q1
\v 12 Tenau hapai hake koe  Ľi he nima,  
\q2 telia na Ľa tŇękia ho va Ľe ki ha maka.   
\q1
\v 13 Te ke molomoloki  Ľae laione mo e ngata:  
\q2 ko e laione mui mo e talńĀkoni te ke malaki hifo ia.   
\q1
\v 14 ‚ÄúKoe Ľuhi kuo ne tuku  Ľene  Ľofa kiate au, ko ia te u fakamo Ľui ia:  
\q2 te u fokotu Ľu ia ke mńĀ Ľolunga, koe Ľuhi kuo ne  Ľilo Ľi hoku huafa.   
\q1
\v 15 Te ne ui kiate au, pea te u talia ia:  
\q2 te u  Ľiate ia  Ľi he mamahi;  
\q2 te u fakamo Ľui ia, pea hakeaki Ľi ia.   
\q1
\v 16 Te u fakafiemńĀlie Ľi  Ľaki ia  Ľae mo Ľui fuoloa,  
\q2 pea fakahńĀ kiate ia  Ľeku fakamo Ľui.‚ÄĚ   
\c 92  
\cd \it 1  ĽOku enginaki he palŇćfita ke fakamńĀlŇć ki he  ĽOtua, 4 Koe Ľuhi ko  Ľene ngńĀue lahi, 6 mo  Ľene tautea ki he angahala, 10 Pea mo  Ľene angalelei ki he mńĀ Ľoni Ľoni.\it*  
\d Ko e Saame pe ko e Hiva ki he  Ľaho tapu.  
\q1
\v 1 ‚ÄĆ ĽOku lelei ke  Ľatu  Ľae fakafeta Ľi kia Sihova,  
\q2 pea ke hiva fakamńĀlŇć ki ho huafa,  ĽE fungani mńĀ Ľolunga:   
\q1
\v 2 Ke fakahńĀ atu ho Ľo  Ľalo Ľofa  Ľi he pongipongi,  
\q2 mo ho Ľo mo Ľoni  Ľi he pŇć kotoa pńď,   
\q1
\v 3 ‚ÄĆ ĽAki  Ľae me Ľa faiva  Ľoku hongofulu hono filo, pea mo e saliteli;  
\q2  Ľaki  Ľae le Ľo mamafa  Ľi he ha Ľape.   
\q1
\v 4 He kuo ke fakafiefia Ľi au,  ĽE Sihova,  Ľi ho Ľo ngńĀue:  
\q2 te u vikiviki  Ľi he ngaahi ngńĀue  Ľa ho nima.   
\q1
\v 5 ‚ÄĆ ĽE Sihova,  Ľoku mńĀtu Ľaki lahi ho Ľo ngaahi ngńĀue!  
\q2 pea  Ľoku loloto  Ľaupito ho Ľo ngaahi fakakaukau.   
\q1
\v 6 ‚ÄĆ ĽOku  Ľikai  Ľilo Ľi  Ľe he tangata anga fakamanu;  
\q2 pea  Ľoku  Ľikai  Ľilo eni  Ľe he vale.   
\q1
\v 7 ‚ÄĆ ĽOka tupu  Ľae kau angahala  Ľo hangńď ko e mohuku,  
\q2 pea  Ľoka mo Ľui lelei  Ľae kau fai kovi kotoa pńď;  
\q2 ko e me Ľa ia ke faka Ľauha ai  Ľakinautolu  Ľo ta Ľengata:   
\q1
\v 8 Ka ko koe,  ĽE Sihova,  Ľoku ke fungani mńĀ Ľolunga  Ľo ta Ľengata.   
\q1
\v 9 Pea vakai, ko ho ngaahi fili,  ĽE Sihova, ko e mo Ľoni  Ľe  Ľauha ho ngaahi fili;  
\q2  Ľe fakahńď Ľi  Ľae kau fai kovi kotoa pńď.   
\q1
\v 10 Ka te ke hiki hake hoku nifo  Ľo hangńď ko e nifo  Ľoe liimi:  
\q2  Ľe tńĀkai  Ľaki au  Ľae lolo fo Ľou.   
\q1
\v 11 Pea  Ľe mamata foki  Ľa hoku mata ki hoku ngaahi fili,  
\q2 pea  Ľe fanongo  Ľa hoku telinga, ki he angahala  Ľoku tu Ľu hake  Ľo angatu Ľu kiate au.   
\q1
\v 12 ‚ÄĆ ĽE lau ma Ľui Ľui  Ľae angatonu  Ľo hangńď ko e  Ľakau ko e ponga:  
\q2  Ľe tupu ia  Ľo hangńď ko e sita  Ľi Lepanoni.   
\q1
\v 13 Ko kinautolu kuo tŇć  Ľi he fale  Ľo Sihova tenau lau ma Ľui Ľui  Ľi he ngaahi loto ĽńĀ  Ľo hotau  ĽOtua.   
\q1
\v 14 ‚ÄĆ ĽE kei tupu  Ľae fua  Ľiate kinautolu  Ľi he Ľenau motu Ľa;  
\q2 tenau sino lelei mo lau ma Ľui Ľui.   
\q1
\v 15 Ke fakahńĀ  Ľoku angatonu  Ľa Sihova:  
\q2 ko hoku maka ia,  
\q2 pea  Ľoku  Ľikai ha ta ĽemńĀ Ľoni Ľoni  Ľiate ia.   
\c 93  
\cd \it 1‚Äď5 Ko e lahi, mo e mńĀfimafi mo e mńĀ Ľoni Ľoni  Ľoe pule Ľanga  Ľo Kalaisi.\it*  
\q1
\v 1 ‚ÄĆ ĽOku pule  Ľa Sihova,  Ľoku kofu Ľaki ia  Ľae nńĀunau lahi;  
\q2  Ľoku kofu Ľaki  Ľa Sihova  Ľae mńĀfimafi,  
\q2  Ľaia kuo ne nono Ľo  Ľaki ia kuo fokotu Ľuma Ľu foki  Ľa mńĀmani,  
\q2 pea  Ľe  Ľikai fa Ľa ue Ľi ia.   
\q1
\v 2 KUO fokotu Ľuma Ľu ho  Ľafio Ľanga talu mei mu Ľa:  
\q2  Ľoku talu mei mu Ľa  Ľae  Ľafiona.   
\q1
\v 3 ‚ÄĆ ĽE Sihova, kuo hiki hake  Ľe he ngaahi vaitafe,  
\q2 kuo hiki hake  Ľe he ngaahi vaitafe honau le Ľo;  
\q2  Ľoku hiki hake  Ľe he ngaahi vaitafe lahi honau ngaahi peau.   
\q1
\v 4 Ko Sihova  Ľoku  Ľi  Ľolunga  Ľoku mńĀlohi lahi hake ia  Ľi he  Ľu Ľulu  Ľoe ngaahi vai lahi,  
\q2  Ľio,  Ľi he ngaahi peau mńĀlohi  Ľoe tahi.   
\q1
\v 5 ‚ÄĆ ĽOku mo Ľoni  Ľaupito ho Ľo ngaahi fakamo Ľoni:  
\q2  ĽE Sihova,  Ľoku taau mo ho fale  Ľae mńĀ Ľoni Ľoni  Ľo lauikuonga.   
\c 94  
\cd \it 1  ĽOku kole  Ľe he palŇćfita ki he  ĽEiki ke fie fai  Ľae fakamaau, pea ne lńĀunga koe Ľuhi ko e fakamńĀlohi mo e angakovi  Ľae kakai. 8  ĽOku ne akonaki  Ľaki  Ľae pule  Ľae  ĽOtua. 13  ĽOku ne fakahńĀ hono  Ľaonga  Ľoe mamahi. 16 Ko e  ĽOtua ko e fakamo Ľui  Ľoe kakai mamahi.\it*  
\q1
\v 1 ‚ÄĆ ĽE Sihova ko e  ĽOtua,  Ľoku  Ľa Ľau  Ľae totongi;  
\q2  ĽE  ĽOtua,  Ľoku  Ľa Ľau  Ľae totongi: ke ke ulo mai.   
\q1
\v 2 Ke ke hiki hake koe,  Ľa koe ko e fakamaau  Ľo mńĀmani;  
\q2  Ľange  Ľae totongi ki he laukau.   
\q1
\v 3 ‚ÄĆ ĽE Sihova,  Ľe fńďfńď hono fuoloa  Ľoe fielahi  Ľae angahala,  
\q2  Ľe fńďfńď hono fuoloa  Ľoe polepole  Ľae angahala?   
\q1
\v 4 ‚ÄĆ ĽE fńďfńď hono fuoloa  Ľo  Ľenau fakahńĀ mo lea  Ľaki  Ľae ngaahi me Ľa faingata Ľa?  
\q2 Pea vikiviki ai  Ľae kakai kotoa pńď  Ľoku fai kovi?   
\q1
\v 5 ‚ÄĆ ĽE Sihova,  Ľoku nau fesi Ľi  Ľo lailaiki ho kakai,  
\q2 mo fakamamahi Ľi ho tofi Ľa.   
\q1
\v 6 ‚ÄĆ ĽOku nau tńĀmate Ľi  Ľae muli mo e fefine kuo mate hono husepńĀniti,  
\q2 pea fakapoongi  Ľae tamai mate.   
\q1
\v 7 Ka  Ľoku nau pehńď, ‚Äú ĽE  Ľikai  Ľafio Ľi  Ľe Sihova,  Ľe  Ľikai tokanga ki ai  Ľe he  ĽOtua  Ľo Sńďkope.‚ÄĚ   
\q1
\v 8 Mou  Ľilo  Ľekimoutolu  Ľoku anga fakamanu  Ľi he kakai:  
\q2 pea ko kimoutolu  Ľae kau vale, te mou poto  Ľafńď?   
\q1
\v 9 Ko ia na Ľa ne ngaohi  Ľae telinga,  Ľikai te ne fanongo?  
\q2 Ko ia na Ľa ne ngaohi  Ľae mata,  Ľikai te ne  Ľafio Ľi?   
\q1
\v 10 Ko ia  Ľoku ne tautea  Ľae hiteni,  Ľikai te ne tautea?  
\q2 Ko ia  Ľoku ne akonaki Ľi  Ľae tangata ke poto,  Ľikai te ne  Ľilo Ľi?   
\q1
\v 11 ‚ÄĆ ĽOku  Ľilo Ľi  Ľe Sihova  Ľae ngaahi mahalo  Ľae tangata,  
\q2  Ľoku nau va Ľinga pńď.   
\q1
\v 12 ‚ÄĆ ĽE Sihova,  Ľoku monŇę Ľia  Ľae tangata  Ľoku ke tautea,  
\q2 mo ke ako kiate ia  Ľaki ho Ľo fono;   
\q1
\v 13 Koe Ľuhi te ke foaki kiate ia  Ľae mńĀlŇćlŇć mei he ngaahi  Ľaho  Ľoe mamahi,  
\q2 kae Ľoua ke keli  Ľae luo ki he kau angahala.   
\q1
\v 14 Koe Ľuhi  Ľe  Ľikai li Ľaki  Ľe Sihova hono kakai,  
\q2 pea  Ľe  Ľikai te ne fakatukutuku Ľi hono tofi Ľa.   
\q1
\v 15 Ka  Ľe foki  Ľae fakamaau ki he mńĀ Ľoni Ľoni:  
\q2 pea  Ľe angimui ki ai  Ľakinautolu kotoa pńď  Ľoku angatonu  Ľi loto.   
\q1
\v 16 Ko hai  Ľe tu Ľu hake ma Ľaku  Ľo ta Ľofi  Ľae kau fai kovi?  
\q2 Pe ko hai  Ľe tu Ľu hake ma Ľaku  Ľo ta Ľofi  Ľakinautolu  Ľoku ngńĀue  Ľi he angahala?   
\q1
\v 17 Ka ne  Ľikai tokoni au  Ľe Sihova, pehńď,  
\q2 kuo vave  Ľae nofo  Ľa hoku laumńĀlie  Ľi he fakalongo pńď.   
\q1
\v 18 ‚ÄĆ ĽI he Ľeku pehńď, ‚Äú ĽOku hekea hoku va Ľe;‚ÄĚ  
\q2 ko ho Ľo  Ľalo Ľofa,  ĽE Sihova, na Ľe poupou hake au.   
\q1
\v 19 ‚ÄĆ ĽI hono lahi  Ľo  Ľeku ngaahi mahalo  Ľiate au,  
\q2  Ľoku fakafiefia Ľi au  Ľi ho Ľo ngaahi me Ľa fakafiemńĀlie.   
\q1
\v 20 ‚ÄĆ ĽE feohi końĀ mo koe  Ľae nofo Ľa  Ľoe angahala,  
\q2  Ľaia  Ľoku fakatupu  Ľae pau Ľu  Ľaki  Ľae fono?   
\q1
\v 21 ‚ÄĆ ĽOku nau fakataha  Ľo angatu Ľu ki he laumńĀlie  Ľoe angatonu,  
\q2 mo fakahalaia  Ľae toto tonuhia.   
\q1
\v 22 Ka ko hoku ungaki Ľi  Ľa Sihova pea ko hoku  ĽOtua ko e maka ia  Ľo hoku hŇęfanga.   
\q1
\v 23 Pea  Ľe  Ľomi  Ľe ia kiate kinautolu  Ľa  Ľenau hia,  
\q2 pea te ne faka Ľauha  Ľakinautolu  Ľi he Ľenau angahala;  
\q2  Ľio, ko Sihova ko hotau  ĽOtua te ne faka Ľauha  Ľakinautolu.   
\c 95  
\cd \it 1 Ko e enginaki ke fakamńĀlŇć ki he  ĽOtua, 3 Koe Ľuhi ko hono lahi, 6 Mo  Ľene angalelei, 8 Pea  Ľoua na Ľa  Ľahi Ľahi Ľi ia.\it*  
\q1
\v 1 Ha Ľu, ketau hiva kia Sihova:  
\q2 ketau kalanga  Ľi he fiefia ki he maka  Ľo  Ľetau mo Ľui.   
\q1
\v 2 Ketau ha Ľu ki hono  Ľao mo e fakafeta Ľi,  
\q2 mo kalanga  Ľi he fiefia kiate ia  Ľaki  Ľae ngaahi saame.   
\q1
\v 3 He ko Sihova ko e  ĽOtua lahi,  
\q2 pea ko e Tu Ľi lahi hake ia  Ľi he ngaahi  Ľotua kotoa pńď.   
\q1
\v 4 ‚ÄĆ ĽOku  Ľi hono nima  Ľae ngaahi potu mńĀ Ľulalo  Ľo mńĀmani:  
\q2 ko e mńĀlohi  Ľoe ngaahi mo Ľunga  Ľoku  Ľo Ľona foki.   
\q1
\v 5 ‚ÄĆ ĽOku  Ľo Ľona  Ľae tahi, he na Ľa ne ngaohi ia:  
\q2 pea na Ľe ngaohi  Ľe hono nima  Ľae fonua mŇćmoa.   
\q1
\v 6 Ha Ľu, ketau lotu mo punou:  
\q2 ketau tŇę Ľulutui  Ľi he  Ľao  Ľo Sihova ko hotau tupu Ľanga.   
\q1
\v 7 He ko hotau  ĽOtua ia;  
\q2 pea ko e kakai  Ľakitautolu  Ľo  Ľene ngoue,  
\q2 mo e fanga sipi  Ľa hono nima.  
\q2 Ko e  Ľaho ni,  Ľo kapau te mou fanongo ki hono le Ľo,   
\q1
\v 8 ‚Äú ĽOua na Ľa mou fakafefeka homou loto,  
\q2  Ľo hangńď ko ia  Ľi he fakahouhau lahi,  
\q2 pea  Ľi he  Ľaho  Ľoe  Ľahi Ľahi  Ľi he toafa:   
\q1
\v 9 ‚ÄĆ ĽAia na Ľe  Ľahi Ľahi Ľi au  Ľe ho Ľomou ngaahi tamai,  
\q2 pea nau  Ľahi Ľahi kiate au,  
\q2  Ľonau mamata ki he Ľeku ngńĀue.   
\q1
\v 10 Na Ľaku fehi Ľa ki he to Ľutangata ko ia  Ľi he ta Ľu  Ľe fńĀngofulu,  
\q2 pea na Ľaku pehńď, ‚ÄėKo e kakai eni  Ľoku hńď  Ľi honau loto,  
\q2 pea  Ľoku  Ľikai te nau  Ľilo hoku ngaahi hala:   
\q1
\v 11 Pea ne u fuakava kiate kinautolu  Ľi hoku houhau,  
\q2 ‚Äė ĽE  Ľikai tenau hŇę ki hoku mńĀlŇćlŇć Ľanga.‚Äô‚ÄĚ   
\c 96  
\cd \it 1 Ko e enginaki ke fakamńĀlŇć ki he  ĽOtua, 4 Koe Ľuhi ko  Ľene mńĀfimafi, 8 Mo hono pule Ľanga, 13 Pea mo  Ľene fai  Ľae fakamaau.\it*  
\q1
\v 1 Hiva kia Sihova  Ľaki  Ľae hiva fo Ľou:  
\q2 hiva kia Sihova  Ľa mńĀmani kotoa pńď.   
\q1
\v 2 Hiva kia Sihova, fakafeta Ľi ki hono huafa;  
\q2 fakahńĀ atu  Ľene fakamo Ľui mei he  Ľaho ki he  Ľaho.   
\q1
\v 3 FakahńĀ hono nńĀunau  Ľi he  Ľao  Ľoe hiteni,  
\q2 mo  Ľene ngaahi ngńĀue fakaofo ki he kakai kotoa pńď.   
\q1
\v 4 He  Ľoku lahi  Ľa Sihova, pea totonu ke fakamńĀlŇć lahi kiate ia:  
\q2  Ľoku lelei ke manavahńď lahi hake kiate ia  Ľi he ngaahi  Ľotua kotoa pńď.   
\q1
\v 5 He ko e  Ľotua kotoa pńď  Ľoe ngaahi pule Ľanga ko e ngaahi tamapua ia:  
\q2 ka ko Sihova na Ľe ngaohi  Ľe ia  Ľae ngaahi langi.   
\q1
\v 6 ‚ÄĆ ĽOku  Ľi hono  Ľao  Ľae faka Ľapa Ľapa mo e mńĀfimafi:  
\q2  Ľoku  Ľi hono faletapu  Ľae mńĀlohi mo e nńĀunau.   
\q1
\v 7 Tuku kia Sihova,  Ľakimoutolu  Ľae ngaahi fa Ľahinga  Ľoe kakai,  
\q2 tuku kia Sihova  Ľae nńĀunau mo e mńĀfimafi.   
\q1
\v 8 Tuku kia Sihova  Ľae ongoongolelei  Ľoku taau mo hono huafa:  
\q2  Ľomi  Ľae feilaulau, pea ha Ľu ki hono ngaahi loto ĽńĀ.   
\q1
\v 9 Lotu kia Sihova  Ľi he teunga matamatalelei  Ľoe mńĀ Ľoni Ľoni:  
\q2 mou manavahńď  Ľi hono  Ľao,  Ľa mńĀmani kotoa pńď.   
\q1
\v 10 Mou pehńď  Ľi he  Ľao  Ľoe hiteni  Ľoku pule  Ľa Sihova:  
\q2 ‚Äú ĽE fokotu Ľuma Ľu foki  Ľa mńĀmani,  
\q2 pea  Ľe  Ľikai ngaueue ia:  
\q2 te ne fakamaau  Ľae kakai  Ľi he mńĀ Ľoni Ľoni.‚ÄĚ   
\q1
\v 11 Tuku ke fiefia  Ľae ngaahi langi,  
\q2 pea nekeneka mo mńĀmani; tuku ke  Ľu Ľulu  Ľae tahi,  
\q2 mo hono fonu  Ľo ia.   
\q1
\v 12 Ke fiefia  Ľae ngoue,  
\q2 mo e me Ľa kotoa pńď  Ľoku  Ľi ai:  
\q2 pea  Ľe toki fiefia  Ľae ngaahi  Ľakau kotoa pńď  Ľoe vao,   
\q1
\v 13 ‚ÄĆ ĽI he  Ľao  Ľo Sihova: he  Ľoku ne hńĀ Ľele mai, he  Ľoku hńĀ Ľele mai ia ke fakamaau  Ľa mńĀmani:  
\q2 te ne fakamaau  Ľa mńĀmani  Ľi he mńĀ Ľoni Ľoni, mo e kakai  Ľi he Ľene mo Ľoni.   
\c 97  
\cd \it 1 Ko e mńĀfimafi  Ľoe pule Ľanga  Ľoe  ĽOtua. 7  ĽOku fiefia  Ľae siasi  Ľi he tautea  Ľe he  ĽOtua  Ľae kau tauhi tamapua. 10 Ko e enginaki ke mńĀ Ľoni Ľoni mo fiefia.\it*  
\q1
\v 1 ‚ÄĆ ĽOku pule  Ľa Sihova;  
\q2 tuku ke fiefia  Ľa mńĀmani;  
\q2 pea nekeneka  Ľae ngaahi  Ľotu motu.   
\q1
\v 2 ‚ÄĆ ĽOku takatakai ia  Ľe he ngaahi  Ľao mo e fakapo Ľuli:  
\q2 ko e angatonu mo e fakamaau ko e tu Ľunga ia  Ľo hono  Ľafio Ľanga.   
\q1
\v 3 ‚ÄĆ ĽOku mu Ľomu Ľa  Ľae afi  Ľiate ia,  
\q2 pea vela ke  Ľosi hono ngaahi fili  Ľoku takatakai.   
\q1
\v 4 Na Ľe fakamaama  Ľaki  Ľa mńĀmani  Ľa hono ngaahi  Ľuhila:  
\q2 na Ľe mamata  Ľae fonua, pea tetetete.   
\q1
\v 5 Na Ľe vela  Ľo vai  Ľae ngaahi mo Ľunga  Ľo hangńď ko e pulu  Ľi he  Ľao  Ľo Sihova,  Ľi he  Ľao  Ľoe  ĽEiki  Ľo mńĀmani kotoa pńď.   
\q1
\v 6 ‚ÄĆ ĽOku fakahńĀ  Ľe he ngaahi langi  Ľene mńĀ Ľoni Ľoni,  
\q2 pea mamata  Ľae kakai kotoa pńď ki hono nńĀunau.   
\q1
\v 7 Ke puputu Ľu  Ľakinautolu kotoa pńď  Ľoku nau tauhi  Ľae ngaahi fakatńĀtńĀ kuo tńĀ,  
\q2 mo nau polepole  Ľi he ngaahi tamapua:  
\q2 lotu kiate ia,  Ľakimoutolu kotoa pńď  Ľae ngaahi  Ľotua.   
\q1
\v 8 Na Ľe fanongo  Ľa Saione,  
\q2 pea fiefia ai pea na Ľe fiefia  Ľae ngaahi  Ľofefine  Ľo Siuta,  
\q2 koe Ľuhi ko ho Ľo ngaahi fakamaau,  ĽE Sihova.   
\q1
\v 9 He ko koe,  ĽE Sihova,  Ľoku ke mńĀ Ľolunga hake ki mńĀmani kotoa pńď:  
\q2  Ľoku ke mńĀ Ľolunga lahi  Ľaupito  Ľi he ngaahi  Ľotua kotoa pńď.   
\q1
\v 10 ‚ÄĆ ĽAkimoutolu  Ľoku  Ľofa kia Sihova, mou fehi Ľa ki he kovi:  
\q2  Ľoku fakamo Ľui  Ľe ia  Ľae laumńĀlie  Ľo  Ľene kakai mńĀ Ľoni Ľoni;  
\q2  Ľoku ne fakamo Ľui  Ľakinautolu mei he nima  Ľoe kau angahala.   
\q1
\v 11 Kuo tŇętuu Ľi  Ľae maama ma Ľae mńĀ Ľoni Ľoni,  
\q2 mo e fiefia ma Ľae angatonu  Ľi loto.   
\q1
\v 12 Mou fiefia  Ľia Sihova  Ľae kau angatonu;  
\q2 pea fakafeta Ľi  Ľi he manatu ki he Ľene mńĀ Ľoni Ľoni.   
\c 98  
\cd \it 1  ĽOku enginaki Ľi  Ľe he tangata tohi saame  Ľae kakai Siu, 4 Mo e Senitaile, 7 Mo e me Ľa kotoa pńď kenau fakamńĀlŇć ki he  ĽOtua.\it*  
\d Ko e Saame.  
\q1
\v 1 Hiva kia Sihova  Ľaki  Ľae hiva fo Ľou;  
\q2 he kuo fai  Ľe ia  Ľae ngaahi me Ľa fakaofo:  
\q2 kuo ne ikuna  Ľaki hono nima to Ľomata Ľu, mo hono nima mńĀ Ľoni Ľoni.   
\q1
\v 2 Kuo fakahńĀ  Ľe Sihova  Ľa  Ľene fakamo Ľui:  
\q2 kuo ne fakahńĀ atu  Ľene mńĀ Ľoni Ľoni  Ľi he  Ľao  Ľoe hiteni.   
\q1
\v 3 Kuo ne manatu ki he Ľene  Ľalo Ľofa mo  Ľene mo Ľoni ki he fale  Ľo  ĽIsileli:  
\q2 kuo mamata  Ľe he ngaahi ngata Ľanga  Ľo mńĀmani ki he fakamo Ľui  Ľa hotau  ĽOtua.   
\q1
\v 4 Kalanga  Ľi he fiefia kia Sihova,  Ľa mńĀmani kotoa pńď:  
\q2 kalanga  Ľi he le Ľo lahi, mo fiefia, pea hiva fakamńĀlŇć.   
\q1
\v 5 Hiva kia Sihova  Ľaki  Ľae ha Ľape;  
\q2  Ľaki  Ľae ha Ľape, pea mo e le Ľo  Ľoe saame.   
\q1
\v 6 Mou kalanga fakafiefia  Ľaki  Ľae ngaahi me Ľalea mo e le Ľo  Ľoe me Ľalea,  
\q2  Ľi he  Ľao  Ľo Sihova ko e Tu Ľi.   
\q1
\v 7 Tuku ke  Ľu Ľulu  Ľae tahi, mo hono fonu  Ľo ia;  
\q2  Ľa mńĀmani, mo kinautolu  Ľoku nofo ai.   
\q1
\v 8 Ke pasipasi  Ľe he ngaahi vai  Ľa honau nima:  
\q2 tuku ke fiefia fakataha  Ľae ngaahi mo Ľunga,   
\q1
\v 9 ‚ÄĆ ĽI he  Ľao  Ľo Sihova;  
\q2 he  Ľoku hńĀ Ľele mai ia ke fakamaau  Ľa mńĀmani:  
\q2 te ne fakamaau  Ľa mńĀmani  Ľi he mńĀ Ľoni Ľoni,  
\q2 pea mo e kakai  Ľi he angatonu.   
\c 99  
\cd \it 1  ĽOku fakahńĀ  Ľe he palŇćfita  Ľae pule  Ľae  ĽOtua  Ľi Saione, 5  ĽO ne enginaki ki he kakai kotoa pńď ke fa Ľifa Ľitaki ki he kau mńĀtu Ľa  Ľi mu Ľa, pea lotu ki he  ĽOtua  Ľi hono mo Ľunga mńĀ Ľoni Ľoni.\it*  
\q1
\v 1 ‚ÄĆ ĽOku pule  Ľa Sihova;  
\q2 tuku ke tetetete  Ľae kakai:  
\q2  Ľoku  Ľafio ia  Ľi he vaha Ľa  Ľoe ongo selupi;  
\q2 tuku ke ngalulu  Ľa mńĀmani.   
\q1
\v 2 ‚ÄĆ ĽOku lahi  Ľa Sihova  Ľi Saione;  
\q2 pea  Ľoku mńĀ Ľolunga lahi ia  Ľi he kakai kotoa pńď.   
\q1
\v 3 Tuku kenau fakamńĀlŇć ki ho huafa lahi mo fakailifia;  
\q2 he  Ľoku mńĀ Ľoni Ľoni ia.   
\q1
\v 4 ‚ÄĆ ĽOku  Ľofa foki  Ľae mńĀlohi  Ľoe tu Ľi ki he fakamaau;  
\q2  Ľoku ke fokotu Ľuma Ľu  Ľae fai totonu,  
\q2  Ľoku ke fai  Ľae fakamaau mo e mńĀ Ľoni Ľoni  Ľia Sńďkope.   
\q1
\v 5 Mou fakahikihiki  Ľa Sihova ko hotau  ĽOtua, pea lotu  Ľi hono tu Ľunga va Ľe;  
\q2 he  Ľoku mńĀ Ľoni Ľoni ia.   
\q1
\v 6 Ko MŇćsese mo  ĽElone  Ľi he Ľene kau taula Ľeiki,  
\q2 pea mo Samuela  Ľiate kinautolu  Ľoku ui ki hono huafa;  
\q2 na Ľa nau ui kia Sihova, pea ne talia  Ľakinautolu.   
\q1
\v 7 Na Ľa ne folofola kiate kinautolu  Ľi he pou  Ľoe  Ľao:  
\q2 na Ľa nau tauhi  Ľene ngaahi fakamo Ľoni,  
\q2 mo e tu Ľutu Ľuni na Ľa ne fokotu Ľu kiate kinautolu.   
\q1
\v 8 ‚ÄĆ ĽE Sihova ko homau  ĽOtua, na Ľa ke talia  Ľakinautolu:  
\q2 ko koe ko e  ĽOtua na Ľa ke fakamolemolea  Ľakinautolu,  
\q2 neongo ho Ľo totongi koe Ľuhi ko  Ľenau ngaahi fakakaukau.   
\q1
\v 9 Fakahikihiki  Ľa Sihova ko hotau  ĽOtua, pea lotu  Ľi hono mo Ľunga tapu;  
\q2 he  Ľoku mńĀ Ľoni Ľoni  Ľa Sihova ko hotau  ĽOtua.   
\c 100  
\cd \it 1 Ko e enginaki ke fakamńĀlŇć ki he  ĽOtua  Ľi he fiefia, 3 Koe Ľuhi ko  Ľene mńĀfimafi, 4 Mo  Ľene angalelei.\it*  
\d Ko e Saame  Ľoe fakafeta Ľi.  
\q1
\v 1 Mou mavava  Ľi he fiefia kia Sihova,  Ľae ngaahi fonua kotoa pńď.   
\q1
\v 2 Tauhi  Ľa Sihova  Ľi he fiefia:  
\q2 ha Ľu mo e hiva ki hono  Ľao.   
\q1
\v 3 Mou  Ľilo ko Sihova ko ia pe ko e  ĽOtua:  
\q2 ko ia pe na Ľa ne ngaohi  Ľakitautolu,  
\q2 ka na Ľe  Ľikai te tau ngaohi  Ľakitautolu;  
\q2 ko hono kakai  Ľakitautolu,  
\q2 mo e fanga sipi  Ľo  Ľene ngoue.   
\q1
\v 4 HŇę  Ľi hono ngaahi matapńĀ mo e fakafeta Ľi,  
\q2 pea ki hono ngaahi loto ĽńĀ mo e fakamńĀlŇć:  
\q2 mou fakafeta Ľi kiate ia, pea fakamńĀlŇć ki hono huafa.   
\q1
\v 5 He  Ľoku angalelei  Ľa Sihova;  
\q2  Ľoku ta Ľengata  Ľene  Ľalo Ľofa;  
\q2 pea  Ľoku tolonga ma Ľuaipńď  Ľene mo Ľoni mei he to Ľutangata ki he to Ľutangata.   
\c 101  
\cd \it 1‚Äď8  ĽOku fuakava  Ľa Tevita mo fakahńĀ te ne fai mńĀ Ľoni Ľoni.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 Te u hiva  Ľaki  Ľae  Ľalo Ľofa mo e fakamaau:  
\q2 ‚ÄĆ ĽE Sihova, te u hiva kiate koe.   
\q1
\v 2 Te u fai fakapotopoto  Ľi he hala haohaoa.  
\q2 Te ke hńĀ Ľele mai  Ľafńď kiate au?  
\q2 Te u  Ľeve Ľeva  Ľi hoku fale  Ľi he loto haohaoa.   
\q1
\v 3 ‚ÄĆ ĽE  Ľikai te u tuku ha me Ľa kovi  Ľi hoku  Ľao:  
\q2  Ľoku ou fehi Ľa ki he ngńĀue  Ľanautolu kuo nau afe;  
\q2  ĽE  Ľikai pipiki ia kiate au.   
\q1
\v 4 ‚ÄĆ ĽE  Ľalu  Ľiate au  Ľaia  Ľoku loto kovi:  
\q2  ĽE  Ľikai te u  Ľilo Ľi ha taha  Ľoku kovi.   
\q1
\v 5 Ko ia  Ľoku fakakovi fakafufŇę hono kaungńĀ Ľapi, te u tu Ľusi ia:  
\q2 ko ia  Ľoku fiematamu Ľa mo loto laukau  Ľe  Ľikai te u kńĀtaki Ľi.   
\q1
\v 6 ‚ÄĆ ĽE sio ma Ľu hoku mata ki he kakai angatonu  Ľi he fonua,  
\q2 koe Ľuhi ke mau nonofo mo au:  
\q2 ko ia  Ľoku  Ľeve Ľeva  Ľi he hala haohaoa,  
\q2 ko ia ia  Ľe tauhi au.   
\q1
\v 7 Ko ia  Ľoku ne fai kńĀkńĀ  Ľe  Ľikai nofo ia  Ľi hoku fale:  
\q2 ko ia  Ľoku fa Ľa loi  Ľe  Ľikai te ne nofo  Ľi hoku  Ľao.   
\q1
\v 8 ‚ÄĆ ĽE vave  Ľeku faka Ľauha  Ľae kau angahala kotoa pńď  Ľoe fonua;  
\q2 koe Ľuhi ke u tu Ľusi  Ľae kakai fai kovi kotoa pńď mei he kolo  Ľa Sihova.   
\c 102  
\cd \it 1  ĽOku fakahńĀ  Ľe he palŇćfita  Ľi he Ľene lotu  Ľa  Ľene mamahi lahi. 12 Ka  Ľoku ne fiemńĀlie  Ľi he ta Ľengata  Ľae  ĽOtua mo  Ľene  Ľalo Ľofa. 18  ĽOku lelei ke faka Ľilonga Ľi  Ľae ngaahi me Ľa Ľofa  Ľae  ĽOtua. 23  ĽOku ne poupou  Ľaki  Ľene vaivai  Ľae ta Ľefa Ľaliliu  Ľae  ĽOtua.\it*  
\d Ko e Lotu  Ľae mamahi  Ľi hono lŇćmekina, pea ne lilingi  Ľene mamahi  Ľi he  Ľao  Ľo Sihova.  
\q1
\v 1 ‚ÄĆ ĽE Sihova, fanongo ki he Ľeku lotu,  
\q2 pea tuku ke a Ľu atu  Ľeku tangi kiate koe.   
\q1
\v 2 ‚ÄĆ ĽOua na Ľa ke fufŇę ho fofonga  Ľiate au  Ľi he  Ľaho  Ľoku ou mamahi ai;  
\q2 fakatokanga Ľi ho fofonga kiate au:  
\q2  Ľi he  Ľaho  Ľoku ou ui ai ke vave ho Ľo talia au.   
\q1
\v 3 He kuo faka Ľosi hoku ngaahi  Ľaho  Ľo hangńď ko e kohu,  
\q2 pea kuo vela hoku ngaahi hui  Ľo hangńď ko e ve Ľe tofunanga.   
\q1
\v 4 Kuo taa Ľi hoku loto, pea kuo mae  Ľo hangńď ko e mohuku;  
\q2 ko ia kuo ngalo ai  Ľiate au ke kai  Ľeku mńĀ.   
\q1
\v 5 Koe Ľuhi ko e le Ľo  Ľo  Ľeku to Ľe,  
\q2 ko ia  Ľoku piki ai hoku ngaahi hui ki hoku kili.   
\q1
\v 6 ‚ÄĆ ĽOku ou tatau mo e pelikani  Ľoe toafa:  
\q2  Ľoku ou hangńď ko e lulu  Ľoe potu lala.   
\q1
\v 7 ‚ÄĆ ĽOku ou le Ľo, pea u tatau mo e kihi Ľi manupuna  Ľoku tokotaha pńď  Ľi he tu Ľahivi  Ľoe fale.   
\q1
\v 8 ‚ÄĆ ĽOku manuki kiate au  Ľa hoku ngaahi fili  Ľi he  Ľaho kotoa pńď;  
\q2 pea ko kinautolu  Ľoku mata lili kiate au kuo nau fuakava ke angatu Ľu kiate au.   
\q1
\v 9 He kuo u kai  Ľae efuefu  Ľo hangńď ko e mńĀ,  
\q2 mo hu Ľi  Ľaki hoku inu  Ľae lo Ľimata,   
\q1
\v 10 Koe Ľuhi ko ho tuputńĀmaki mo ho houhau:  
\q2 he kuo ke hiki hake au, pea lńę au ki lalo.   
\q1
\v 11 ‚ÄĆ ĽOku tatau hoku ngaahi  Ľaho mo e  Ľata  Ľoku mole atu;  
\q2 pea kuo u mae  Ľo hangńď ko e mohuku.   
\q1
\v 12 Ka ko koe,  ĽE Sihova, te ke tolonga  Ľo ta Ľengata;  
\q2 mo ho Ľo faka Ľilonga ki he ngaahi to Ľutangata kotoa pńď.   
\q1
\v 13 Te ke tu Ľu hake,  
\q2 mo ke  Ľalo Ľofa ki Saione:  
\q2 he ko e  Ľaho ke tokoni ia,  
\q2  Ľio, ko e  Ľaho kuo tu Ľutu Ľuni kuo hoko mai.   
\q1
\v 14 He  Ľoku fiemńĀlie  Ľa ho Ľo kau tamaio Ľeiki  Ľi hono ngaahi maka,  
\q2 pea  Ľoku nau  Ľofa ki hono efu  Ľo Ľona.   
\q1
\v 15 Ko ia  Ľe manavahńď ai  Ľae hiteni ki he huafa  Ľo Sihova,  
\q2 pea ko e ngaahi tu Ľi kotoa pńď  Ľo mńĀmani ki ho nńĀunau.   
\q1
\v 16 ‚ÄĆ ĽOka toe langa hake  Ľe Sihova  Ľa Saione,  
\q2  Ľe fakahńĀ ia  Ľi hono nńĀunau.   
\q1
\v 17 Te ne tokanga ki he lotu  Ľae masiva,  
\q2 pea  Ľe  Ľikai manuki Ľi  Ľenau hŇę.   
\q1
\v 18 ‚ÄĆ ĽE tohi eni ma Ľae to Ľutangata  Ľe ha Ľu:  
\q2 pea ko e kakai  Ľe fakatupu te nau fakamńĀlŇć kia Sihova.   
\q1
\v 19 He kuo  Ľafio hifo ia mei he mńĀ Ľolunga  Ľo hono faletapu;  
\q2 na Ľe  Ľafio  Ľa Sihova mei he langi ki mńĀmani;   
\q1
\v 20 Ke ne fanongo ki he to Ľe  Ľoe pŇćpula;  
\q2 ke vete  Ľakinautolu kuo tu Ľutu Ľuni ke mate;   
\q1
\v 21 Ke fakahńĀ  Ľae huafa  Ľo Sihova  Ľi Saione,  
\q2 mo  Ľene fakamńĀlŇć  Ľi SelŇęsalema;   
\q1
\v 22 ‚ÄĆ ĽOka fakataha  Ľae kakai,  
\q2 pea mo e ngaahi pule Ľanga, ke tauhi  Ľa Sihova.   
\q1
\v 23 Na Ľa ne fakavaivai Ľi hoku mńĀlohi  Ľi he hala;  
\q2 na Ľa ne fakanounou hoku ngaahi  Ľaho.   
\q1
\v 24 Na Ľaku pehńď,  ĽE hoku  ĽOtua,  Ľoua na Ľa  Ľave au  Ľi he lotolotonga  Ľo hoku ngaahi  Ľaho:  
\q2 ko ho ngaahi ta Ľu  Ľoku tolonga ki he to Ľutangata kotoa pńď.   
\q1
\v 25 Na Ľa ke  Ľai  Ľi he kamata Ľanga  Ľae tu Ľunga  Ľo mńĀmani;  
\q2 pea koe ngaahi langi koe ngaue ia  Ľa ho nima.   
\q1
\v 26 ‚ÄĆ ĽE  Ľauha ia, ka  Ľe pehńď ai pe  Ľa koe,  
\q2  Ľio,  Ľe faka Ľa Ľau kotoa pńď ia ke motu Ľa  Ľo hangńď ko e kofu;  
\q2 pea hangńď ko e pulupulu te ke fatufatu ia,  
\q2 pea  Ľe fakakehe ia:   
\q1
\v 27 Ka  Ľe pehńď ai pe  Ľa koe,  
\q2 pea  Ľe  Ľikai hano ngata Ľanga  Ľo ho ngaahi ta Ľu.   
\q1
\v 28 ‚ÄĆ ĽE tolonga  Ľae fńĀnau  Ľa ho Ľo kau tamaio Ľeiki,  
\q2 pea  Ľe fokotu Ľuma Ľu honau hako  Ľi ho  Ľao.   
\c 103  
\cd \it 1 Ko e enginaki ke fakamńĀlŇć ki he  ĽOtua koe Ľuhi ko  Ľene  Ľalo Ľofa, 15 Pea koe Ľuhi ko hono tu Ľuma Ľu  Ľo ia.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 Fakafeta Ľi kia Sihova  Ľa hoku laumńĀlie:  
\q2 pea mo ia kotoa pńď  Ľoku  Ľiate au,  
\q2 fakafeta Ľi ki hono huafa mńĀ Ľoni Ľoni.   
\q1
\v 2 Fakafeta Ľi kia Sihova,  Ľa hoku laumńĀlie,  
\q2 pea  Ľoua na Ľa ngalo  Ľa  Ľene ngaahi me Ľa Ľofa kotoa pńď:   
\q1
\v 3 ‚ÄĆ ĽAia  Ľoku ne fakamolemole ho Ľo ngaahi hia kotoa pńď;  
\q2 mo ne fakamo Ľui ho ngaahi mahaki kotoa pńď;   
\q1
\v 4 ‚ÄĆ ĽAia  Ľoku ne huhu Ľi ho Ľo mo Ľui mei he faka Ľauha;  
\q2  Ľo ne tatńĀ  Ľaki koe  Ľae manava Ľofa mo e  Ľalo Ľofa ongongofua;   
\q1
\v 5 ‚ÄĆ ĽAia  Ľoku ne fakamńĀkona  Ľaki ho ngutu  Ľae ngaahi me Ľa lelei;  
\q2 ko ia kuo toe tupulaki ai ho talavou  Ľo hangńď ko e  Ľikale.   
\q1
\v 6 ‚ÄĆ ĽOku fai  Ľe Sihova  Ľae mńĀ Ľoni Ľoni mo e fakamaau kiate kinautolu kotoa pńď kuo fakamńĀlohia.   
\q1
\v 7 Na Ľa ne fakahńĀ hono ngaahi hala kia MŇćsese,  
\q2 mo  Ľene ngaahi ngńĀue ki he fńĀnau  Ľa  ĽIsileli.   
\q1
\v 8 ‚ÄĆ ĽOku manava Ľofa mo angalelei  Ľa Sihova,  Ľoku fa Ľa kńĀtaki,  
\q2 pea mohu  Ľalo Ľofa.   
\q1
\v 9 ‚ÄĆ ĽE  Ľikai te ne valoki ma Ľuaipńď:  
\q2 pea  Ľe  Ľikai tuputńĀmaki  Ľo ta Ľengata.   
\q1
\v 10 Na Ľe  Ľikai fai  Ľe ia kiate kitautolu  Ľo fakatatau mo  Ľetau ngaahi angahala;  
\q2 pe totongi kiate kitautolu  Ľo fakatatau mo  Ľetau ngaahi hia.   
\q1
\v 11 Kae hangńď ko hono mńĀ Ľolunga  Ľoe langi ki mńĀmani,  
\q2  Ľoku pehńď hono lahi  Ľo  Ľene  Ľalo Ľofa kiate kinautolu  Ľoku nau manavahńď kiate ia.   
\q1
\v 12 ‚ÄĆ ĽOku hangńď ko hono vńĀ mama Ľo  Ľoe potu hahake mei he potu lulunga,  
\q2  Ľoku pehńď hono mama Ľo  Ľo  Ľene  Ľave  Ľetau ngaahi angahala  Ľiate kitautolu.   
\q1
\v 13 Pea hangńď  Ľoku manava Ľofa  Ľae tamai ki he Ľene fńĀnau,  
\q2  Ľoku pehńď  Ľae manava Ľofa  Ľa Sihova kiate kinautolu  Ľoku nau manavahńď kiate ia.   
\q1
\v 14 He  Ľoku ne  Ľilo Ľi hotau anga;  
\q2  Ľoku ne manatu ko e efu pe  Ľakitautolu.   
\q1
\v 15 Pea ko e tangata,  Ľoku tatau hono ngaahi  Ľaho mo e mohuku:  
\q2 pea hangńď ko e fisi Ľi  Ľakau  Ľoe ngoue hono lau ma Ľui Ľui.   
\q1
\v 16 He  Ľoku  Ľalu atu ki ai  Ľae matangi, pea kuo  Ľikai ia;  
\q2 pea  Ľe  Ľikai si Ľi toe  Ľilo ia  Ľi hono potu.   
\q1
\v 17 Ka ko e  Ľalo Ľofa  Ľa Sihova  Ľoku talu mei mu Ľa  Ľo a Ľu  Ľo ta Ľengata kiate kinautolu  Ľoku nau manavahńď kiate ia,  
\q2 pea ko  Ľene mńĀ Ľoni Ľoni ki he fńĀnau  Ľae fńĀnau;   
\q1
\v 18 Kiate kinautolu  Ľoku nau tauhi  Ľene fuakava,  
\q2 pea mo kinautolu  Ľoku nau manatu ki he Ľene ngaahi fekau ke fai ki ai.   
\q1
\v 19 Kuo teuteu  Ľe Sihova hono  Ľafio Ľanga  Ľi he ngaahi langi;  
\q2 pea  Ľoku pule hono pule Ľanga ki he me Ľa kotoa pńď.   
\q1
\v 20 Fakafeta Ľi kia Sihova  Ľakimoutolu ko  Ľene kau  ĽńĀngelo,  
\q2  Ľoku lahi homou mńĀlohi,  
\q2 pea  Ľoku mou fai  Ľene ngaahi fekau,  
\q2  Ľo fakafanongo ki he le Ľo  Ľo  Ľene folofola.   
\q1
\v 21 Fakafeta Ľi kia Sihova,  Ľakimoutolu kotoa pńď ko  Ľene ngaahi kautau;  
\q2  Ľakimoutolu ko  Ľene kau faifekau,  
\q2  Ľoku mou fai ki hono finangalo.   
\q1
\v 22 Fakafeta Ľi kia Sihova,  Ľa  Ľene ngaahi ngńĀue kotoa pńď  
\q2  Ľi he potu kotoa pńď  Ľo hono pule Ľanga:  
\q2 fakafeta Ľi kia Sihova,  Ľa hoku laumńĀlie.   
\c 104  
\cd \it 1 Ko e fakalaulauloto ki he mńĀfimafi  Ľoe  ĽOtua, 7 Mo  Ľene pule fakaofo. 31  ĽOku ta Ľengata  Ľae nńĀunau  Ľoe  ĽOtua. 33  ĽOku fuakava  Ľae palŇćfita ke ne fakamńĀlŇć ma Ľuaipńď ki he  ĽOtua.\it*  
\q1
\v 1 Fakafeta Ľi kia Sihova,  Ľa hoku laumńĀlie.  
\q2  ĽE Sihova ko hoku  ĽOtua,  Ľoku ke lahi  Ľaupito;  
\q2 kuo kofu Ľaki koe  Ľae faka Ľapa Ľapa mo e mńĀfimafi.   
\q1
\v 2 ‚ÄĆ ĽOku ke  Ľufi Ľufi  Ľaki koe  Ľae maama  Ľo hangńď ko e kofu:  
\q2  Ľoku ke fofola atu  Ľae ngaahi langi  Ľo hangńď ko e puipui:   
\q1
\v 3 ‚ÄĆ ĽOku ne  Ľai  Ľae ngaahi utupoto  Ľo hono ngaahi fale  Ľi he ngaahi vai:  
\q2 pea ko  Ľene saliote  Ľae ngaahi  Ľao:  
\q2 pea  Ľoku hńĀ Ľele ia  Ľi he ngaahi kapakau  Ľoe matangi:   
\q1
\v 4 ‚ÄĆ ĽOku ne ngaohi  Ľene kau  ĽńĀngelo ke hangńď ko e matangi;  
\q2 mo  Ľene kau faifekau ko e afi  Ľoku ulo:   
\q1
\v 5 Na Ľa ne  Ľai  Ľae ngaahi tu Ľunga  Ľo mńĀmani,  
\q2 ke  Ľoua na Ľa ue Ľi ia  Ľo lauikuonga.   
\q1
\v 6 ‚ÄĆ ĽOku ke  Ľufi Ľufi  Ľaki ia  Ľae loloto  Ľo hangńď ko e kofu:  
\q2 na Ľe tu Ľu  Ľae ngaahi vai  Ľo mńĀ Ľolunga hake  Ľi he ngaahi mo Ľunga.   
\q1
\v 7 ‚ÄĆ ĽI ho Ľo valoki na Ľa nau puna;  
\q2  Ľi he le Ľo  Ľo ho Ľo fatulisi na Ľa nau hola ai.   
\q1
\v 8 ‚ÄĆ ĽOku nau  Ľalu hake  Ľi he ngaahi mo Ľunga,  
\q2 pea nau  Ľalu hifo  Ľi he ngaahi vaha Ľa mo Ľunga,  
\q2 ki he potu kuo ke teuteu ki ai.   
\q1
\v 9 Kuo ke  Ľai hono ngata Ľanga ke  Ľoua na Ľa  Ľalu atu ia  Ľi ai;  
\q2 koe Ľuhi ke  Ľoua na Ľa toe ha Ľu ia ke lŇćfia  Ľa mńĀmani.   
\q1
\v 10 ‚ÄĆ ĽOku ne fekau atu  Ľae ngaahi matavai  Ľi he ngaahi luo,  
\q2  Ľaia  Ľoku tafe  Ľi he lotolotonga  Ľoe ngaahi fo Ľi mo Ľunga.   
\q1
\v 11 ‚ÄĆ ĽOku inu mei ai  Ľae fanga manu kotoa pńď  Ľoe vao:  
\q2 pea  Ľoku inu  Ľo fiu ai  Ľae fanga  Ľasi hehengi.   
\q1
\v 12 ‚ÄĆ ĽOku ma Ľu  Ľi ai  Ľe he manupuna  Ľoe  ĽatńĀ honau nofo Ľanga,  
\q2  Ľoku nau hiva  Ľi he ngaahi va Ľa.   
\q1
\v 13 ‚ÄĆ ĽOku ne fakaviviku  Ľae ngaahi fo Ľi mo Ľunga mei hono fale  Ľafio Ľanga:  
\q2  Ľoku mńĀkona  Ľae kelekele  Ľi he fua  Ľo ho Ľo ngaahi ngńĀue.   
\q1
\v 14 ‚ÄĆ ĽOku fakatupu  Ľe ia  Ľae mohuku ma Ľae fanga manu,  
\q2 mo e  Ľakau ke  Ľaonga ki he tangata:  
\q2 koe Ľuhi ke ne  Ľomi  Ľae me Ľakai mei he kelekele;   
\q1
\v 15 Mo e uaine  Ľaia  Ľoku fakafiefia Ľi  Ľae loto  Ľoe tangata,  
\q2 mo e lolo ke fakangingila hono mata,  
\q2 mo e mńĀ ke fakamńĀlohi  Ľae loto  Ľoe tangata.   
\q1
\v 16 ‚ÄĆ ĽOku fonu  Ľi he huhu Ľa  Ľae ngaahi  Ľakau  Ľo Sihova;  
\q2 ko e ngaahi sita  Ľo Lepanoni,  Ľaia kuo ne tŇć;   
\q1
\v 17 ‚ÄĆ ĽOku ngaohi  Ľi ai  Ľe he fanga manupuna honau pununga:  
\q2 pea ko e sitoaka,  
\q2 ko hono fale ko e ngaahi  Ľakau ko e paini.   
\q1
\v 18 Ko e ngaahi fo Ľi mo Ľunga mńĀ Ľolunga ko e hŇęfanga ia  Ľoe fanga kosi hehengi;  
\q2 pea mo e ngaahi maka ki he fanga koni.   
\q1
\v 19 Na Ľa ne tu Ľutu Ľuni  Ľae mńĀhina ki he ngaahi fa Ľahita Ľu:  
\q2  Ľoku  Ľilo Ľi  Ľe he la ĽńĀ hono tŇć Ľanga.   
\q1
\v 20 ‚ÄĆ ĽOku ke ngaohi  Ľae po Ľuli, pea ko e pŇć ia:  
\q2 pea  Ľoku totolo atu  Ľi ai  Ľae fanga manu kotoa pńď  Ľoe vao.   
\q1
\v 21 ‚ÄĆ ĽOku ngungulu  Ľae fanga laione mui ke ma Ľu  Ľenau me Ľa,  
\q2 pea nau kumi  Ľenau me Ľakai mei he  ĽOtua.   
\q1
\v 22 ‚ÄĆ ĽOku hopo hake  Ľae la ĽńĀ, pea  Ľoku nau fakataha ai,  
\q2  Ľonau tokoto  Ľi honau ngaahi  Ľana.   
\q1
\v 23 ‚ÄĆ ĽOku  Ľalu atu  Ľae tangata ki he Ľene ngńĀue,  
\q2 mo  Ľene ngoue  Ľo a Ľu ki he efiafi.   
\q1
\v 24 ‚ÄĆ ĽE Sihova, hono  Ľikai lahi  Ľa ho Ľo ngaahi ngńĀue!  
\q2 Kuo ke ngaohi kotoa pńď ia  Ľi he poto:  
\q2  Ľoku fonu  Ľa mńĀmani  Ľi ho Ľo koloa.   
\q1
\v 25 Pea  Ľoku pehńď  Ľae tahi lahi ni mo laulahi,  Ľa ia  Ľoku ai  Ľae ngaahi me Ľa totolo ta Ľefa Ľalaua,  Ľae fanga ika iiki mo e lalahi.   
\q1
\v 26 ‚ÄĆ ĽOku  Ľalu  Ľi ai  Ľae ngaahi vaka:  
\q2  Ľoku  Ľi ai  Ľae levaiatani ko ia,  Ľaia kuo ke ngaohi ke ne fakavńĀ ai.   
\q1
\v 27 ‚ÄĆ ĽOku tatali  Ľakinautolu ni kotoa pńď kiate koe:  
\q2 koe Ľuhi ke ke foaki kiate kinautolu  Ľenau me Ľakai  Ľi he feitu Ľula ĽńĀ totonu.   
\q1
\v 28 Ko ia  Ľoku ke foaki kiate kinautolu  Ľoku nau tńĀnaki:  
\q2  Ľoku ke mafola ho nima, pea  Ľoku pito  Ľakinautolu  Ľi he lelei.   
\q1
\v 29 ‚ÄĆ ĽOku ke fufŇę ho fofonga, pea nau mamahi ai:  
\q2  Ľoku ke to Ľo atu  Ľenau mńĀnava, pea nau mate, pea foki ki honau efu.   
\q1
\v 30 ‚ÄĆ ĽOku ke fekau atu ho LaumńĀlie, pea  Ľoku fakatupu ai  Ľakinautolu:  
\q2 pea  Ľoku ke fakafo Ľou  Ľae funga  Ľo mńĀmani.   
\q1
\v 31 ‚ÄĆ ĽE tolonga  Ľo ta Ľengata  Ľae nńĀunau  Ľo Sihova:  
\q2  Ľe fiefia  Ľa Sihova  Ľi he Ľene ngaahi ngńĀue.   
\q1
\v 32 ‚ÄĆ ĽOku  Ľafio ia ki mńĀmani, pea tetetete ia:  
\q2  Ľoku ala ia ki he ngaahi fo Ľi mo Ľunga,  
\q2 pea  Ľoku nau kohu ai.   
\q1
\v 33 Te u hiva kia Sihova  Ľi he Ľeku kei mo Ľui:  
\q2 te u hiva fakamńĀlŇć ki hoku  ĽOtua  Ľi he lolotonga  Ľo  Ľeku mo Ľui.   
\q1
\v 34 ‚ÄĆ ĽE melie  Ľa  Ľeku fakakaukau kiate ia:  
\q2 te u fiefia  Ľia Sihova.   
\q1
\v 35 Tuku ke  Ľosi ĽosingamńĀlie  Ľae kakai angahala mei mńĀmani,  
\q2 pea  Ľoua na Ľa kei toe  Ľae kau angakovi.  
\q2 Fakafeta Ľi kia Sihova,  Ľa hoku laumńĀlie.  
\q2 Mou fakamńĀlŇć kia Sihova.   
\c 105  
\cd \it 1 Ko e enginaki ke fakamńĀlŇć ki he  ĽOtua, pea kumi ke  Ľilo  Ľa  Ľene ngńĀue. 7 Ko e fakamatala ki he pule  Ľae  ĽOtua kia  ĽEpalahame, 16 mo Siosefa, 23 Mo Sńďkope  Ľi  ĽIsipite, 26 Mo MŇćsese  Ľi he Ľene fakamo Ľui  Ľa  ĽIsileli, 37 Pea ki he kakai  ĽIsileli kuo ne  Ľomi mei  ĽIsipite,  Ľo fafanga  Ľi he toafa, pea nau ma Ľu  Ľa Kńďnani.\it*  
\q1
\v 1 Mou  Ľatu  Ľae fakafeta Ľi kia Sihova; ui ki hono huafa:  
\q2 fakahńĀ  Ľene ngaahi ngńĀue  Ľi he  Ľao  Ľoe kakai.   
\q1
\v 2 Hiva kiate ia, hiva  Ľaki  Ľae ngaahi saame kiate ia:  
\q2 mou talanoa  Ľaki  Ľene ngaahi ngńĀue fakaofo kotoa pńď.   
\q1
\v 3 Mou vikiviki  Ľi hono huafa mńĀ Ľoni Ľoni:  
\q2 tuku ke fiefia  Ľae loto  Ľokinautolu  Ľoku nau kumi kia Sihova.   
\q1
\v 4 Kumi kia Sihova, mo hono mńĀlohi:  
\q2 kumi ma Ľuaipńď ki hono fofonga.   
\q1
\v 5 Manatu ki he Ľene ngaahi ngńĀue fakaofo  Ľaia kuo ne fai;  
\q2  Ľa  Ľene ngaahi mana, mo e ngaahi fakamaau  Ľa hono fofonga;   
\q1
\v 6 ‚ÄĆ ĽAkimoutolu  Ľae hako  Ľo  ĽEpalahame ko  Ľene tamaio Ľeiki,  
\q2  Ľakimoutolu  Ľae fńĀnau  Ľa Sńďkope  Ľaia kuo ne fili.   
\q1
\v 7 Ko ia, ko Sihova ko hotau  ĽOtua,  
\q2  Ľoku  Ľi mńĀmani kotoa pńď  Ľa  Ľene ngaahi fakamaau.   
\q1
\v 8 Kuo manatu  Ľe ia ki he Ľene fuakava  Ľo lauikuonga,  
\q2 ko e folofola  Ľaia na Ľa ne fekau ki he to Ľutangata  Ľe taha afe.   
\q1
\v 9 ‚ÄĆ ĽA e fuakava  Ľaia na Ľa ne fai mo  ĽEpalahame,  
\q2 pea mo  Ľene fuakava kia  ĽAisake;   
\q1
\v 10 Pea ne fokotu Ľuma Ľu ia kia Sńďkope ko e fono,  
\q2 pea kia  ĽIsileli ko e fuakava ta Ľengata:   
\q1
\v 11 ‚ÄĆ ĽO ne pehńď, ‚ÄúTe u foaki kiate koe  Ľae fonua ko Kńďnani,  
\q2 ko e fuofua  Ľo homou tofi Ľa:‚ÄĚ   
\q1
\v 12 ‚ÄĆ ĽI he lolotonga na Ľe tokosi Ľi pe honau kau tangata;  
\q2  Ľio, ko e tokosi Ľi  Ľaupito, mo e kau muli  Ľi ai.   
\q1
\v 13 Lolotonga  Ľa  Ľenau  Ľalu mei he fa Ľahinga  Ľe taha ki ha fa Ľahinga kehe,  
\q2 pea mei he pule Ľanga  Ľe taha ki he kakai kehe;   
\q1
\v 14 Na Ľe  Ľikai tuku  Ľe ia ke fai kovi  Ľe ha tangata  Ľe taha kiate kinautolu:  
\q2  Ľio, na Ľa ne valoki  Ľae ngaahi tu Ľi koe Ľuhi ko kinautolu;   
\q1
\v 15  ĽO ne pehńď, ‚Äú ĽOua na Ľa ala kiate ia kuo u pani,  
\q2 pea  Ľoua na Ľa fai kovi ki he Ľeku kau palŇćfita.‚ÄĚ   
\q1
\v 16 Pea na Ľa ne ui foki ke hoko  Ľae honge ki he fonua:  
\q2 na Ľa ne fesi Ľi  Ľae tokotoko kotoa pńď  Ľoe mńĀ,   
\q1
\v 17 Na Ľa ne fekau  Ľae tangata ke mu Ľomu Ľa  Ľiate kinautolu,  
\q2  Ľio, ko Siosefa  Ľaia na Ľe fakatau ke tamaio Ľeiki:   
\q1
\v 18 Pea na Ľa nau fakamamahi Ľi hono va Ľe  Ľaki  Ľae ngaahi ha Ľi:  
\q2 na Ľe tuia ia  Ľe he ukamea:   
\q1
\v 19 ‚ÄĆ ĽO a Ľu ki he  Ľaho na Ľe hoko ai  Ľene lea:  
\q2 na Ľe  Ľahi Ľahi Ľi ia  Ľe he folofola  Ľa Sihova.   
\q1
\v 20 Na Ľe fekau  Ľe he tu Ľi ke vete ia;  
\q2  Ľio,  Ľe he pule  Ľoe kakai, pea na Ľa ne tukuange ia ke tau ĽatńĀina pe.   
\q1
\v 21 Na Ľa ne fakanofo ia ko e  Ľeiki  Ľo hono fale,  
\q2 mo e pule  Ľo  Ľene koloa kotoa pńď:   
\q1
\v 22 Ke ha Ľisia hono ngaahi  Ľeiki ko  Ľene fa Ľiteliha;  
\q2 mo akonaki Ľi  Ľa  Ľene kau mńĀtu Ľa  Ľi he poto.   
\q1
\v 23 Na Ľe ha Ľu foki  Ľa  ĽIsileli ki  ĽIsipite pea na Ľe  ĽńĀunofo  Ľa Sńďkope  Ľi he fonua  Ľo Hami.   
\q1
\v 24 Pea na Ľa ne fakatupu  Ľo tokolahi  Ľaupito  Ľa hono kakai;  
\q2 pea ne ngaohi  Ľakinautolu kenau mńĀlohi hake  Ľi honau ngaahi fili.   
\q1
\v 25 Na Ľa ne liliu honau loto kenau fehi Ľa ki hono kakai,  
\q2 kenau fai kńĀkńĀ ki he Ľene kau tamaio Ľeiki.   
\q1
\v 26 Na Ľa ne fekau atu  Ľa MŇćsese ko  Ľene tamaio Ľeiki;  
\q2 mo  ĽElone  Ľaia na Ľa ne fili.   
\q1
\v 27 Na Ľa ne fakahńĀ hono ngaahi faka Ľilonga  Ľiate kinautolu,  
\q2 mo e ngaahi me Ľa mana  Ľi he fonua  Ľo Hami.   
\q1
\v 28 Na Ľe fekau  Ľe ia ki he fakapo Ľuli, pea ngaohi ia ko e po Ľuli;  
\q2 pea na Ľe  Ľikai angatu Ľu  Ľakinautolu ki he Ľene folofola.   
\q1
\v 29 Na Ľa ne liliu honau ngaahi vai ko e toto,  
\q2 mo tńĀmate Ľi  Ľenau ika.   
\q1
\v 30 Na Ľe tupu  Ľi honau fonua  Ľae fanga poto  Ľo lahi  Ľaupito,  
\q2  Ľi he ngaahi loki  Ľo honau ngaahi tu Ľi.   
\q1
\v 31 Na Ľe folofola ia, pea na Ľe ha Ľu  Ľae ngaahi lango kehekehe,  
\q2 mo e fanga kutu  Ľi honau fonua.   
\q1
\v 32 Na Ľa ne  Ľomi  Ľae  Ľuha maka kiate kinautolu ko e fetongi  Ľoe  Ľuha,  
\q2 mo e afi  Ľoku ulo  Ľi honau fonua.   
\q1
\v 33 Na Ľa ne taa Ľi foki  Ľenau ngaahi vaine, mo  Ľenau ngaahi  Ľakau ko e fiki;  
\q2 pea fesi Ľi  Ľae ngaahi  Ľakau  Ľo honau fonua.   
\q1
\v 34 Na Ľa ne folofola, pea na Ľe ha Ľu ai  Ľae fanga he Ľe,  
\q2 mo e ngaahi  Ľunufe  Ľoku ta Ľefa Ľalaua.   
\q1
\v 35 Pea na Ľa nau kai ke  Ľosi  Ľae ngaahi  Ľakau kotoa pńď  Ľi honau fonua,  
\q2 pea nau faka Ľauha  Ľae fua  Ľo  Ľenau ngoue.   
\q1
\v 36 Na Ľa ne taa Ľi foki  Ľae  Ľuluaki fńĀnau kotoa pńď  Ľi honau fonua,  
\q2 ko e fungani  Ľo  Ľenau mńĀlohi kotoa pńď.   
\q1
\v 37 Na Ľa ne  Ľomi foki  Ľakinautolu mo e siliva mo e koula:  
\q2 pea na Ľe  Ľikai ai ha tokotaha na Ľe vaivai  Ľi honau ngaahi fa Ľahinga.   
\q1
\v 38 Na Ľe fiefia  Ľa  ĽIsipite  Ľi he Ľenau  Ľalu hńď na Ľe tŇć kiate kinautolu  Ľae manavahńď koe Ľuhi ko kinautolu.   
\q1
\v 39 Na Ľa ne fofola  Ľae  Ľao ko e fakamalu pea mo e afi ke fakamaama  Ľi he pŇć.   
\q1
\v 40 Na Ľe kole  Ľe he kakai, pea na Ľa ne  Ľomi  Ľae fanga manupuna,  
\q2 mo ne fakamńĀkona  Ľaki  Ľakinautolu  Ľae mńĀ  Ľoe langi.   
\q1
\v 41 Na Ľa ne fakaava  Ľae maka,  
\q2 pea  Ľoho mai  Ľae ngaahi vai;  
\q2 pea na Ľe tafe ia  Ľi he ngaahi potu mŇćmoa  Ľo hangńď ko e vaitafe.   
\q1
\v 42 He na Ľa ne manatu ki he Ľene tala Ľofa mńĀ Ľoni Ľoni,  
\q2 mo  ĽEpalahame ko  Ľene tamaio Ľeiki.   
\q1
\v 43 Pea ne  Ľomi hono kakai  Ľi he fiefia,  
\q2 mo kinautolu kuo ne fili  Ľi he nekeneka:   
\q1
\v 44 Pea ne foaki kiate kinautolu  Ľae ngaahi fonua  Ľoe hiteni, pea na Ľa nau ma Ľu  Ľae ngńĀue  Ľae kakai   
\q1
\v 45 Koe Ľuhi kenau tokanga ki he Ľene ngaahi tu Ľutu Ľuni,  
\q2 mo tauhi  Ľene ngaahi fekau.  
\q2 Mou fakamńĀlŇć kia Sihova.   
\c 106  
\cd \it 1  ĽOku enginaki  Ľe he tangata tohi saame ke fakamńĀlŇć ki he  ĽOtua. 4  ĽOku ne kole  Ľae fakamolemole  Ľoe angahala,  Ľo hangńď na Ľe fai  Ľe he  ĽOtua ki he ngaahi mńĀtu Ľa. 7 Ko e fakamatala ki he angatu Ľu  Ľae kakai, mo e  Ľalo Ľofa  Ľae  ĽOtua. 47 Ko e lotu mo e fakafeta Ľi.\it*  
\q1
\v 1 Mou fakamńĀlŇć kia Sihova.  
\q2 Mou  Ľatu  Ľae fakafeta Ľi kia Sihova; he  Ľoku angalelei ia:  
\q2 koe Ľuhi  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 2 Ko hai  Ľe fa Ľa fakamatala ki he ngaahi ngńĀue lahi  Ľa Sihova?  
\q2 Ko hai  Ľe fa Ľa fakahńĀ  Ľae fakamńĀlŇć kotoa pńď kiate ia?   
\q1
\v 3 ‚ÄĆ ĽOku monŇę Ľia  Ľakinautolu  Ľoku tokanga ki he fakamaau,  
\q2 mo ia  Ľoku fai mńĀ Ľoni Ľoni  Ľi he  Ľaho kotoa pńď.   
\q1
\v 4 ‚ÄĆ ĽE Sihova, ke ke manatu Ľi au  Ľaki  Ľae  Ľofa  Ľaia  Ľoku ke  Ľofa  Ľaki ki ho Ľo kakai: ke ke  Ľa Ľahi mai kiate au  Ľaki ho Ľo fakamo Ľui;   
\q1
\v 5 Koe Ľuhi ke u mamata ki he lelei  Ľo ia kuo ke fili,  
\q2 koe Ľuhi ke u fiefia  Ľi he fiefia  Ľo ho pule Ľanga,  
\q2 pea u vikiviki ai fakataha mo ho tofi Ľa.   
\q1
\v 6 Ko kimautolu mo  Ľemau ngaahi tamai kuo mau fai angahala,  
\q2 kuo mau fai  Ľae ngaahi hia,  
\q2 kuo mau fai kovi.   
\q1
\v 7 Na Ľe  Ľikai  Ľilo  Ľe he Ľemau ngaahi tamai ho Ľo ngaahi ngńĀue fakaofo  Ľi  ĽIsipite;  
\q2 na Ľe  Ľikai tenau manatu ki hono lahi  Ľo ho Ľo ngaahi  Ľalo Ľofa;  
\q2 ka na Ľa nau fakahouhau kiate ia  Ľi he tahi,  Ľio,  Ľi he Tahi Kulokula.   
\q1
\v 8 Ka na Ľa ne fakamo Ľui  Ľakinautolu koe Ľuhi ko hono huafa,  
\q2 koe Ľuhi ke ne faka Ľilo  Ľa hono mńĀlohi lahi.   
\q1
\v 9 Na Ľe valoki foki  Ľe ia  Ľae Tahi Kulokula, pea mŇćmoa ia:  
\q2 ko ia na Ľa ne tataki  Ľakinautolu  Ľi he loloto,  Ľo hangńď ko e toafa.   
\q1
\v 10 Pea na Ľa ne fakamo Ľui  Ľakinautolu mei he nima  Ľo ia na Ľe fehi Ľa kiate kinautolu,  
\q2 mo ne huhu Ľi  Ľakinautolu mei he nima  Ľoe fili.   
\q1
\v 11 Pea na Ľe lŇćmaki Ľi honau ngaahi fili  Ľaki  Ľae ngaahi vai:  
\q2 pea na Ľe  Ľikai hao ha tokotaha  Ľiate kinautolu.   
\q1
\v 12 Pea na Ľa nau toki tui ki he Ľene folofola;  
\q2 na Ľa nau hiva  Ľaki  Ľae fakamńĀlŇć kiate ia.   
\q1
\v 13 Na Ľe ngalo leva  Ľiate kinautolu  Ľene ngaahi ngńĀue;  
\q2 pea na Ľe  Ľikai tenau tatali ki he Ľene akonaki:   
\q1
\v 14 Ka na Ľa nau holi kovi  Ľaupito  Ľi he toafa,  
\q2 pea  Ľahi Ľahi Ľi  Ľae  ĽOtua  Ľi he potu lala.   
\q1
\v 15 Pea na Ľa ne foaki kiate kinautolu  Ľaia na Ľa nau kole;  
\q2 ka na Ľa ne fekau  Ľae tutue ki honau laumńĀlie.   
\q1
\v 16 Na Ľa nau meheka foki kia MŇćsese  Ľi he loto  Ľapitanga,  
\q2 mo  ĽElone ko e tokotaha mńĀ Ľoni Ľoni  Ľa Sihova.   
\q1
\v 17 Na Ľe mafahi  Ľae kelekele pea folo hifo ai  Ľa Tatani,  
\q2 mo  Ľufi Ľufi ai  Ľae kakai  Ľo  ĽEpilami.   
\q1
\v 18 Pea na Ľe tutu ai  Ľae afi  Ľi honau kakai;  
\q2 pea vela ke  Ľosi  Ľe he ulo afi  Ľae kau angahala.   
\q1
\v 19 Na Ľa nau ngaohi  Ľae fakatńĀtńĀ  Ľoe  Ľuhiki Ľi pulu  Ľi Holepi,  
\q2 pea lotu ki he fakatńĀtńĀ koula.   
\q1
\v 20 Na Ľe pehńď  Ľenau liliu honau nńĀunau,  
\q2 ki he fakatńĀtńĀ  Ľoe pulu  Ľaia  Ľoku kai mohuku.   
\q1
\v 21 Na Ľa nau fakangalongalo Ľi  Ľae  ĽOtua ko honau fakamo Ľui,  
\q2  Ľaia na Ľe fai  Ľae ngaahi me Ľa lahi  Ľi  ĽIsipite;   
\q1
\v 22 Ko e ngaahi ngńĀue fakaofo  Ľi he fonua  Ľo Hami,  
\q2 mo e ngaahi me Ľa fakailifia  Ľi he Tahi Kulokula.   
\q1
\v 23 Ko ia na Ľa ne pehńď te ne faka Ľauha  Ľakinautolu,  
\q2 ka ne  Ľikai tu Ľu  Ľi hono  Ľao  Ľi he vaha Ľa  Ľa MŇćsese  Ľaia kuo ne fili,  
\q2 ke fakatafoki hono houhau,  
\q2 telia na Ľa faka Ľauha  Ľe ia  Ľakinautolu.   
\q2
\v 24 ‚ÄĆ ĽIo, na Ľa nau fehi Ľa ki he fonua lelei,  
\q2 na Ľe  Ľikai tenau tui ki he Ľene folofola:   
\q1
\v 25 Ka na Ľa nau lńĀunga  Ľi honau ngaahi fale fehikitaki,  
\q2  Ľo ta Ľetokanga ki he le Ľo  Ľo Sihova.   
\q1
\v 26 Ko ia na Ľa ne hiki hake ai hono nima kiate kinautolu,  
\q2 ke tulaki  Ľakinautolu  Ľi he toafa:   
\q1
\v 27 Ke tulaki foki honau hako  Ľi he  Ľao  Ľoe ngaahi pule Ľanga,  
\q2 mo fakahńď Ľi  Ľakinautolu  Ľi he ngaahi fonua.   
\q1
\v 28 Na Ľa nau ului foki kia Peali-Peoli,  
\q2 mo nau kai  Ľae ngaahi feilaulau  Ľoe mate.   
\q1
\v 29 Ko ia na Ľa nau fakahouhau Ľi ia  Ľaki  Ľenau ngaahi filio Ľi:  
\q2 pea na Ľe  Ľoho mai  Ľae mahaki faka Ľauha kiate kinautolu.   
\q1
\v 30 Pea na Ľe toki tu Ľu hake  Ľa Finiasi,  Ľo fai  Ľae fakamaau:  
\q2 pea na Ľe lolomi ai  Ľae mahaki faka Ľauha.   
\q1
\v 31 Pea na Ľe lau ia kiate ia ko e mńĀ Ľoni Ľoni  Ľi he ngaahi to Ľutangata kotoa pńď  Ľo lauikuonga.   
\q1
\v 32 Na Ľa nau fakahouhau kiate ia foki  Ľi he ngaahi vai  Ľoe feke Ľike Ľi,  
\q2 pea hoko  Ľae kovi kia MŇćsese koe Ľuhi ko kinautolu:   
\q1
\v 33 Ko e me Ľa  Ľi he Ľenau fakatupu hono loto,  
\q2 ko ia na Ľa ne lea  Ľaki  Ľae lea ta Ľengali  Ľe hono loungutu.   
\q1
\v 34 Na Ľe  Ľikai tenau faka Ľauha  Ľae ngaahi pule Ľanga,  
\q2  Ľaia na Ľe fekau  Ľe Sihova kiate kinautolu:   
\q1
\v 35 Ka na Ľa nau nofo fakataha mo e hiteni,  
\q2 pea nau  Ľilo  Ľenau ngaahi ngńĀue.   
\q1
\v 36 Pea na Ľa nau tauhi honau ngaahi tamapua:  
\q2  Ľaia na Ľe hoko ko e tauhele kiate kinautolu.   
\q1
\v 37 ‚ÄĆ ĽIo, na Ľa nau feilaulau  Ľaki honau ngaahi foha mo honau ngaahi  Ľofefine ki he kau tńďvolo,   
\q1
\v 38 Mo lilingi  Ľae toto mńĀ Ľoni Ľoni,  
\q2 ko e toto  Ľo honau ngaahi foha mo honau ngaahi  Ľofefine,  
\q2  Ľakinautolu na Ľa nau feilaulau  Ľaki ki he ngaahi tamapua  Ľo  Ľi he toto.   
\q1
\v 39 Pea na Ľe faka Ľuli Ľi pehńď  Ľakinautolu  Ľi he Ľenau ngaahi ngńĀue,  
\q2 pea nau fai fe Ľauaki  Ľi he Ľenau ngaahi filio Ľi.   
\q1
\v 40 Ko ia na Ľe tupu ai  Ľae houhau  Ľo Sihova ki hono kakai,  
\q2 pea ne fńĀkalili Ľa ai ki hono tofi Ľa  Ľo Ľona.   
\q1
\v 41 Pea na Ľa ne tukuange  Ľakinautolu ki he nima  Ľoe hiteni;  
\q2 pea na Ľe pule kiate kinautolu  Ľakinautolu na Ľe fehi Ľa kiate kinautolu.   
\q1
\v 42 Pea na Ľe fakamńĀlohi Ľi  Ľakinautolu  Ľe honau ngaahi fili,  
\q2 pea fakamo Ľulaloa  Ľakinautolu ki honau lalo nima.   
\q1
\v 43 Na Ľe liunga lahi  Ľene fakamo Ľui  Ľakinautolu;  
\q2 ka na Ľa nau fakahouhau Ľi ia  Ľi he Ľenau fakakaukau,  
\q2 pea na Ľe fakavaivai Ľi  Ľakinautolu koe Ľuhi ko  Ľenau hia.   
\q1
\v 44 Ka na Ľa ne tokanga ki he Ľenau mamahi,  
\q2  Ľi he Ľene ongo Ľi  Ľenau tangi:   
\q1
\v 45 Pea ne manatu Ľi  Ľa  Ľene fuakava mo kinautolu,  
\q2 pea ne fakatomala  Ľo fakatatau mo hono lahi  Ľo  Ľene  Ľalo Ľofa.   
\q1
\v 46 na Ľa ne pule foki ke manava Ľofa kiate kinautolu  
\q2  Ľakinautolu kotoa pńď na Ľe  Ľave pŇćpula  Ľakinautolu.   
\q1
\v 47 Fakamo Ľui  Ľakimautolu,  ĽE Sihova ko homau  ĽOtua,  
\q2 pea tńĀnaki  Ľakimautolu mei he lotolotonga  Ľoe hiteni,  
\q2 ke mau fakafeta Ľi ki ho huafa mńĀ Ľoni Ľoni,  
\q2 pea hanuhanu  Ľi he fakamńĀlŇć kiate koe.   
\q1
\v 48 Fakafeta Ľi kia Sihova koe  ĽOtua  Ľo  ĽIsileli talu mei mu Ľa  Ľo a Ľu  Ľo ta Ľengata;  
\q2 pea tuku ke lea pehńď  Ľe he kakai kotoa pńď  ĽEmeni.  
\q2 Mou fakamńĀlŇć kia Sihova.   
\c 107  
\ms1 TOHI 5  
\mr (Saame 107‚ÄĒ150)  
\cd \it 1  ĽOku enginaki  Ľe he tangata tohi saame ki he kakai kuo huhu Ľi kenau tokanga,  Ľi he Ľenau fakamńĀlŇć ki he  ĽOtua, ki he Ľene pule lelei, 4 Ki he kau fononga, 10 Ki he kau pŇćpula, 17 Ki he kakai mahaki, 23 Ki he kau toutai, 33 Pea  Ľi he ngaahi anga kehekehe  Ľoe mo Ľui.\it*  
\q1
\v 1 ‚ÄúMou  Ľatu  Ľae fakafeta Ľi kia Sihova, he  Ľoku angalelei ia:  
\q2 koe Ľuhi  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.‚ÄĚ   
\q1
\v 2 Ke lea pehńď  Ľe he kakai kuo huhu Ľi  Ľe Sihova,  Ľakinautolu kuo ne huhu Ľi mei he nima  Ľoe fili;   
\q1
\v 3 Pea tńĀnaki  Ľakinautolu mei he ngaahi fonua,  
\q2 mei he potu hahake, pea mei he potu lulunga,  
\q2 mei he potu tokelau, pea mei he feitu Ľu tonga.   
\q1
\v 4 Na Ľa nau  Ľalu fano pńď  Ľi he toafa  Ľi he hala li Ľaki; na Ľe  Ľikai tenau  Ľilo ha kolo ke nofo ai.   
\q1
\v 5 Pea  Ľi he fiekaia mo e fieinua,  
\q2 na Ľe pongia ai honau laumńĀlie  Ľiate kinautolu.   
\q1
\v 6 Pea na Ľa nau toki tangi kia Sihova  Ľi he Ľenau tu ĽutńĀmaki,  
\q2 pea ne ne fakamo Ľui  Ľakinautolu mei he Ľenau ngaahi mamahi.   
\q1
\v 7 Pea na Ľa ne tataki atu  Ľakinautolu  Ľi he hala totonu,  
\q2 koe Ľuhi kenau hoko ki he kolo na Ľe kakai.   
\q1
\v 8 TaumaińĀ ke fakamńĀlŇć  Ľae kakai kia Sihova koe Ľuhi ko  Ľene  Ľalo Ľofa,  
\q2 pea koe Ľuhi ko  Ľene ngaahi ngńĀue fakaofo ki he fńĀnau  Ľae tangata!   
\q1
\v 9 He  Ľoku ne fakamńĀkona  Ľae laumńĀlie  Ľoku holi,  
\q2 mo ne fakapito  Ľaki  Ľae lelei  Ľae laumńĀlie  Ľoku fiekaia.   
\q1
\v 10 Ko kinautolu  Ľoku nofo  Ľi he fakapo Ľuli pea mo e  Ľata  Ľae mate,  
\q2 kuo ha Ľi  Ľaki  Ľae mamahi mo e ukamea;   
\q1
\v 11 Koe Ľuhi na Ľa nau angatu Ľu ki he ngaahi folofola  Ľae  ĽOtua,  
\q2 mo nau fehi Ľa ki he akonaki  Ľae fungani MńĀ Ľolunga:   
\q1
\v 12 Ko ia na Ľa ne fakavaivai Ľi honau loto  Ľi he ngńĀue;  
\q2 na Ľa nau tŇć ki lalo, pea na Ľe  Ľikai ha taha ke tokoni.   
\q1
\v 13 Pea na Ľa nau toki tangi kia Sihova  Ľi he Ľenau tu ĽutńĀmaki,  
\q2 pea ne fakamo Ľui  Ľakinautolu mei he Ľenau ngaahi mamahi.   
\q1
\v 14 Na Ľa ne  Ľomi  Ľakinautolu mei he fakapo Ľuli mo e  Ľata  Ľoe mate,  
\q2  Ľo ne motuhi honau ngaahi ha Ľi.   
\q1
\v 15 TaumaińĀ ke fakamńĀlŇć  Ľae kakai kia Sihova koe Ľuhi ko  Ľene  Ľalo Ľofa,  
\q2 pea koe Ľuhi ko  Ľene ngaahi ngńĀue fakaofo ki he fńĀnau  Ľae tangata!   
\q1
\v 16 He kuo ne maumau Ľi  Ľae ngaahi matapńĀ palasa,  
\q2 pea ne tutu Ľu  Ľae ngaahi ukamea fakama Ľu.   
\q1
\v 17 ‚ÄĆ ĽOku mamahi  Ľae kau vale koe Ľuhi ko  Ľenau talangata Ľa,  
\q2 pea mo  Ľenau ngaahi hia.   
\q1
\v 18 ‚ÄĆ ĽOku fehi Ľa honau laumńĀlie ki he me Ľakai kotoa pńď;  
\q2 pea  Ľoku nau faka Ľa Ľau ki he ngaahi matapńĀ  Ľoe mate.   
\q1
\v 19 Pea  Ľoku nau toki tangi kia Sihova  Ľi he Ľenau tu ĽutńĀmaki,  
\q2 pea  Ľoku ne fakamo Ľui  Ľakinautolu mei he Ľenau ngaahi mamahi.   
\q1
\v 20 Na Ľa ne fekau  Ľene folofola, pea ne fakamo Ľui  Ľakinautolu,  
\q2 mo ne fakahaofi  Ľakinautolu mei he Ľenau ngaahi me Ľa faka Ľauha.   
\q1
\v 21 TaumaińĀ ke fakamńĀlŇć  Ľae kakai kia Sihova koe Ľuhi ko  Ľene  Ľalo Ľofa,  
\q2 pea koe Ľuhi ko  Ľene ngaahi ngńĀue fakaofo ki he fńĀnau  Ľae tangata!   
\q1
\v 22 Pea tuku kenau feilaulau  Ľaki  Ľae ngaahi feilaulau  Ľoe fakafeta Ľi,  
\q2 mo fakahńĀ  Ľene ngaahi ngńĀue  Ľi he fiefia.   
\q1
\v 23 Ko kinautolu  Ľoku  Ľalu hifo ki he tahi  Ľi he ngaahi vaka,  
\q2 mo fai  Ľae ngńĀue  Ľi he ngaahi vai lahi;   
\q1
\v 24 ‚ÄĆ ĽOku nau mamata ki he ngaahi ngńĀue  Ľa Sihova,  
\q2 mo  Ľene ngaahi me Ľa fakaofo  Ľi he moana.   
\q1
\v 25 He  Ľoku fekau  Ľe ia, pea  Ľoku fakatupu  Ľae matangi mńĀlohi,  
\q2  Ľaia  Ľoku tupu hake ai hono ngaahi peau.   
\q1
\v 26 ‚ÄĆ ĽOku nau  Ľalu hake ki he langi,  Ľoku nau toe  Ľalu hifo ki he ngaahi loloto:  
\q2 kuo vela  Ľo vai honau laumńĀlie koe Ľuhi ko e mamahi.   
\q1
\v 27 ‚ÄĆ ĽOku nau tasipa, pea luelue  Ľo hangńď ko e tangata konńĀ,  
\q2 pea kuo mole honau poto kotoa pńď.   
\q1
\v 28 ‚ÄĆ ĽOku nau toki tangi kia Sihova  Ľi he Ľenau tu ĽutńĀmaki,  
\q2 pea  Ľoku ne  Ľomi  Ľakinautolu mei he Ľenau ngaahi mamahi.   
\q1
\v 29 ‚ÄĆ ĽOku ne ngaohi  Ľae afńĀ ke tofukńę,  
\q2 ko ia  Ľoku  Ľikai ngaue ai hono peau.   
\q1
\v 30 Pea  Ľoku nau toki fiefia koe Ľuhi  Ľoku nau fiemńĀlie ai;  
\q2 pea  Ľoku ne  Ľomi  Ľakinautolu ki he taulanga kuo nau holi ki ai.   
\q1
\v 31 TaumaińĀ ke fakamńĀlŇć  Ľae kakai kia Sihova koe Ľuhi ko  Ľene  Ľalo Ľofa,  
\q2 pea koe Ľuhi ko  Ľene ngaahi ngńĀue fakaofo ki he fńĀnau  Ľae tangata!   
\q1
\v 32 Tuku kenau fakahikihiki  Ľa  Ľene  Ľafio  Ľi he fakataha  Ľoe kakai, mo fakamńĀlŇć   
\q1
\v 33 ‚ÄĆ ĽOku liliu  Ľe ia  Ľae ngaahi vaitafe ko e toafa,  
\q2 mo e ngaahi matavai ko e kelekele mŇćmoa;   
\q1
\v 34 Mo e fonua mahu ko e hongea,  
\q2 koe Ľuhi ko e angakovi  Ľae kakai  Ľoku nofo ai.   
\q1
\v 35 ‚ÄĆ ĽOku ne liliu  Ľae toafa ko e ano vai,  
\q2 mo e fonua mŇćmoa ko e ngaahi matavai.   
\q1
\v 36 Pea  Ľoku ne pule ke nofo ai  Ľae fiekaia,  
\q2 koe Ľuhi kenau teuteu  Ľae kolo ke nofo ai;   
\q1
\v 37 Mo tŇętuu Ľi  Ľae ngaahi ngoue,  
\q2 pea tŇć  Ľae ngaahi ngoue vaine,  
\q2  Ľaia  Ľoku fa Ľa  Ľomi  Ľae ngaahi fua kuo tupu.   
\q1
\v 38 ‚ÄĆ ĽOku ne fakamonŇę Ľia foki  Ľakinautolu, ko ia kuo nau tupu  Ľo tokolahi  Ľaupito;  
\q2 pea  Ľoku  Ľikai te ne tuku ke faka Ľa Ľau ke si Ľi  Ľenau fanga manu.   
\q1
\v 39 Pea  Ľoku toe faka Ľa Ľau ke tokosi Ľi mo vaivai  Ľakinautolu  
\q2  Ľi he fakamńĀlohi, mo e mahaki, mo e mamahi.   
\q1
\v 40 ‚ÄĆ ĽOku ne lilingi  Ľae manuki ki he ngaahi  Ľeiki,  
\q2 pea  Ľoku ne pule kenau  Ľalu fano  Ľi he toafa,  Ľaia  Ľoku  Ľikai ha hala  Ľi ai.   
\q1
\v 41 Ka  Ľoku ne hiki hake  Ľae masiva mei he mamahi,  
\q2 pea  Ľoku ne ngaohi ma Ľana  Ľae ngaahi kńĀinga  Ľo hangńď ko e fanga sipi.   
\q1
\v 42 ‚ÄĆ ĽE mamata ki ai  Ľae angatonu, pea fiefia;  
\q2 pea  Ľe tńĀpuni  Ľe he angahala kotoa pńď hono ngutu.   
\q1
\v 43 Ko hai  Ľoku poto, pea tokanga ki he ngaahi me Ľa ni,  
\q2 tenau  Ľilo Ľi  Ľae  Ľalo Ľofa ongongofua  Ľa Sihova.   
\c 108  
\cd \it 1  ĽOku enginaki Ľi  Ľe Tevita hono loto ke fakamńĀlŇć ki he  ĽOtua. 5  ĽOku ne kole ki he tokoni  Ľae  ĽOtua  Ľo fakatatau mo  Ľene tala Ľofa. 11 Ko  Ľene tui ki he tokoni mei he  ĽOtua.\it*  
\d Ko e Hiva pe ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE  ĽOtua, kuo ma Ľu hoku loto;  
\q2 te u hiva mo  Ľatu  Ľae fakamńĀlŇć  Ľaki hoku nńĀunau.   
\q1
\v 2 Ke  ĽńĀ hake  Ľae saliteli mo e ha Ľape:  
\q2 te u  Ľa hengihengi hake pe au.   
\q1
\v 3 ‚ÄĆ ĽE Sihova, te u fakamńĀlŇć kiate koe  Ľi he  Ľao  Ľoe kakai:  
\q2 pea te u hiva fakamńĀlŇć kiate koe  Ľi he ngaahi pule Ľanga.   
\q1
\v 4 He  Ľoku lahi ho Ľo  Ľalo Ľofa  Ľo mńĀ Ľolunga hake  Ľi he ngaahi langi:  
\q2 mo ho Ľo mo Ľoni  Ľoku a Ľu atu ki he ngaahi  Ľao.   
\q1
\v 5 ‚ÄĆ ĽE  ĽOtua, ke mńĀ Ľolunga lahi hake koe  Ľi he ngaahi langi:  
\q2 pea ke mńĀ Ľolunga hake ho nńĀunau  Ľi mńĀmani kotoa pńď;   
\q1
\v 6 Koe Ľuhi ke hao  Ľaia  Ľoku ke  Ľofa ai ke ke fakamo Ľui  
\q2  Ľaki ho nima to Ľomata Ľu,  Ľo talia au.   
\q1
\v 7 Kuo folofola  Ľae  ĽOtua  Ľi he Ľene mńĀ Ľoni Ľoni; te u fiefia,  
\q2 ‚ÄúTe u vaeua  Ľa Sikemi,  Ľo fuofua  Ľae luo  Ľo Sukote.   
\q1
\v 8 ‚ÄĆ ĽOku  Ľo Ľoku  Ľa Kiliati;  Ľoku  Ľo Ľoku mo Manase;  
\q2 ko hono mńĀlohi foki  Ľo hoku  Ľulu  Ľa  ĽIfalemi;  
\q2 ko  Ľeku fai fono  Ľa Siuta.   
\q1
\v 9 Ko  Ľeku ipu kaukau Ľanga  Ľa Moape;  
\q2 te u lńę hoku topuva Ľe ki  Ľolunga ki  ĽItomi;  
\q2 te u vikiviki koe Ľuhi ko Filisitia.‚ÄĚ   
\q1
\v 10 Ko hai te ne  Ľomi au ki he kolo mńĀlohi?  
\q2 Ko hai te ne a Ľutaki au ki  ĽItomi?   
\q1
\v 11 ‚ÄĆ ĽE  ĽOtua,  Ľe  Ľikai, te ke fai ia,  Ľa koe kuo ke li Ľaki  Ľakimautolu?  
\q2 Pea  Ľikai te ke  Ľalu atu,  ĽE  ĽOtua, mo  Ľemau ngaahi kautau?   
\q1
\v 12 Ke ke tuku kiate kimautolu  Ľae tokoni  Ľi he mamahi:  
\q2 he  Ľoku ta Ľe Ľaonga  Ľae tokoni  Ľae tangata.   
\q1
\v 13 Ko e me Ľa  Ľi he  ĽOtua te tau fai mńĀlohi ai:  
\q2 he ko ia ia te ne malaki hifo hotau ngaahi fili.   
\c 109  
\cd \it 1  ĽOku lńĀunga  Ľa Tevita ki he lau Ľikovi  Ľa hono ngaahi fili,  Ľoku ne fakatukutuku Ľi  Ľakinautolu  Ľi he tangata ko Siutasi. 16  ĽOku ne fakahńĀ  Ľenau hia. 21  ĽOku fakahńĀ  Ľene mamahi,  Ľo kole  Ľae tokoni. 29  ĽOku pehńď  Ľe ia te ne fakafeta Ľi.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE  ĽOtua  Ľo  Ľeku fakamńĀlŇć,  Ľoua na Ľa ke fakalongo pńď;   
\q1
\v 2 He kuo mafa Ľa  Ľae ngutu  Ľoe angahala mo e ngutu  Ľoe kńĀkńĀ kiate au:  
\q2 kuo nau lea kovi kiate au  Ľaki  Ľae  Ľelelo loi.   
\q1
\v 3 Na Ľa nau kńĀpui foki au  Ľaki  Ľae ngaahi lea  Ľoe taufehi Ľa;  
\q2 mo nau tau Ľi au ta Ľehano Ľuhinga.   
\q1
\v 4 Ko e me Ľa  Ľi he Ľeku  Ľofa kuo hoko  Ľakinautolu ko hoku ngaahi fili:  
\q2 ka te u hangahanga lotu pe au.   
\q1
\v 5 Pea kuo nau totongi  Ľaki kiate au  Ľae kovi ki he lelei,  
\q2 mo e fehi Ľa ki he Ľeku  Ľofa.   
\q1
\v 6 Ke ke fakanofo  Ľae tangata angakovi ke pule kiate ia:  
\q2 pea tuku ke tu Ľu  Ľa Sńďtane  Ľi hono nima to Ľomata Ľu.   
\q1
\v 7 ‚ÄĆ ĽOka fakamaau ia,  
\q2 tuku ke halaia ia pea tuku ke hoko  Ľene lotu ko e angahala.   
\q1
\v 8 Tuku ke si Ľi pńď hono ngaahi  Ľaho;  
\q2 pea ke ma Ľu  Ľe ha taha kehe  Ľene ngńĀue.   
\q1
\v 9 Tuku ke tamai mate  Ľene fńĀnau,  
\q2 pea hoko  Ľa hono uaifi ko e fefine kuo mate hono husepńĀniti.   
\q1
\v 10 Tuku ke ne ma Ľuaipńď  Ľene fńĀnau, mo kole:  
\q2 pea tuku kenau kumi foki  Ľenau mńĀ mei honau ngaahi potu  Ľoku lala.   
\q1
\v 11 Tuku ke ma Ľu  Ľe he fakamńĀlohi  Ľae me Ľa kotoa pńď  Ľoku  Ľa Ľana;  
\q2 pea maumau Ľi  Ľe he kau muli  Ľene ngńĀue.   
\q1
\v 12 ‚ÄĆ ĽOua na Ľa tuku ha taha ke manava Ľofa kiate ia:  
\q2 pea  Ľoua na Ľa tuku ha taha ke  Ľofa ki he Ľene fńĀnau  Ľoku tamai mate.   
\q1
\v 13 Tuku ke tu Ľusi hono hako;  
\q2 pea  Ľi he to Ľutangata  Ľe ha Ľu tuku ke tńĀmate Ľi honau hingoa.   
\q1
\v 14 Ke manatu Ľi  Ľe Sihova  Ľae hia  Ľa  Ľene ngaahi tamai;  
\q2 pea  Ľoua na Ľa tńĀmate Ľi  Ľae angahala  Ľa  Ľene fa Ľńď.   
\q1
\v 15 Tuku ma Ľuaipńď ia  Ľi he  Ľao  Ľo Sihova, koe Ľuhi ke ne tu Ľusi honau fakamanatu Ľi mei mńĀmani.   
\q1
\v 16 Koe Ľuhi na Ľe  Ľikai manatu Ľi  Ľe ia ke fakahńĀ  Ľae  Ľofa,  
\q2 ka na Ľa ne fakatanga  Ľae tangata masiva mo paea,  
\q2 koe Ľuhi ke ne tńĀmate Ľi  Ľaia  Ľoku mafesi hono loto.   
\q1
\v 17 Ko e me Ľa  Ľi he Ľene  Ľofa ki he kapekape, ko ia ke hoko ia kiate ia:  
\q2 ko e me Ľa  Ľi he Ľene ta Ľefiefia  Ľi he tńĀpuaki, ko ia ke mama Ľo ia  Ľiate ia.   
\q1
\v 18 Ko e me Ľa  Ľi he Ľene fakakofu Ľaki ia  Ľae kape  Ľo hangńď ko e kofu,  
\q2 ko ia ke hoko ia ki hono kete  Ľo hangńď ko e vai,  
\q2 pea hangńď ko e lolo ki hono ngaahi hui.   
\q1
\v 19 Ke tatau ia kiate ia mo e kofu  Ľaia  Ľoku  Ľufi Ľufi  Ľaki ia,  
\q2 pea mo e no Ľo  Ľaia  Ľoku nono Ľo  Ľaki ma Ľuaipńď ia.   
\q1
\v 20 Tuku eni ko e totongi ki hoku ngaahi fili meia Sihova, pea kiate kinautolu  Ľoku nau lea  Ľaki  Ľae kovi ki hoku laumńĀlie.   
\q1
\v 21 Ka ke fai  Ľe koe ma Ľaku,  ĽE Sihova ko e  ĽEiki,  
\q2 koe Ľuhi ko ho huafa: koe Ľuhi  Ľoku lelei ho Ľo  Ľalo Ľofa, ke ke fakamo Ľui au.   
\q1
\v 22 He  Ľoku ou masiva mo paea,  
\q2 pea kuo lavea hoku loto  Ľiate au.   
\q1
\v 23 Kuo u mole atu  Ľo hangńď ko e  Ľata  Ľoka faka Ľa Ľau ke  Ľosi ia:  
\q2 kuo fe Ľave Ľaki au  Ľo hangńď ko e fanga he Ľe.   
\q1
\v 24 ‚ÄĆ ĽOku vaivai hoku tui  Ľi he  Ľaukai:  
\q2 pea kuo mole  Ľae sino  Ľo hoku kakano.   
\q1
\v 25 Ne u hoko foki ko e manuki Ľanga kiate kinautolu:  
\q2  Ľi he Ľenau sio mai kiate au,  
\q2 na Ľa nau kalokalo honau  Ľulu.   
\q1
\v 26 Tokoni Ľi au,  ĽE Sihova ko hoku  ĽOtua:  
\q2 ke ke fakamo Ľui au  Ľo hangńď ko ho Ľo  Ľalo Ľofa:   
\q1
\v 27 Koe Ľuhi ke nau  Ľilo ko ho nima eni;  
\q2 pea ko koe,  ĽE Sihova, kuo ke fai ia.   
\q1
\v 28 Tuku kenau kape, ka ke fakamonŇę Ľia  Ľe koe:  
\q2  Ľoka nau ka tu Ľu hake, tuku ke nau mńĀ;  
\q2 kae tuku ke fiefia  Ľa ho Ľo tamaio Ľeiki.   
\q1
\v 29 Tuku ke kofu  Ľa hoku ngaahi fili  Ľaki  Ľae mńĀ,  
\q2 pea tuku kenau  Ľufi Ľufi  Ľaki  Ľakinautolu  Ľa  Ľenau puputu Ľu,  Ľo hangńď ko e pulupulu.   
\q1
\v 30 Te u fakamńĀlŇć lahi kia Sihova  Ľaki hoku ngutu;  
\q2  Ľio, te u fakamńĀlŇć kiate ia  Ľi he lotolotonga  Ľoe tokolahi.   
\q1
\v 31 Koe Ľuhi  Ľe tu Ľu ia  Ľi he nima to Ľomata Ľu  Ľoe masiva,  
\q2 ke fakamo Ľui ia meiate kinautolu  Ľoku nau fakahalaia hono laumńĀlie.   
\c 110  
\cd \it 1 Ko e pule Ľanga, 4 Mo e ngńĀue fakataula Ľeiki, 5 Mo e mńĀfimafi, 7 Pea mo e mamahi  Ľa Kalaisi.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 Na Ľe pehńď  ĽE Sihova ki hoku  ĽEiki, ‚ÄúNofo koe ki hoku nima to Ľomata Ľu,  
\q2 kae Ľoua ke u ngaohi ho ngaahi fili ko ho tu Ľungava Ľe.‚ÄĚ   
\q1
\v 2 ‚ÄĆ ĽE fekau  Ľe Sihova  Ľae tokotoko  Ľo ho mńĀlohi mei Saione:  
\q2 ‚ÄúKe ke pule  Ľi he lotolotonga  Ľo ho ngaahi fili.‚ÄĚ   
\q1
\v 3 ‚ÄĆ ĽE loto matala  Ľa ho Ľo kakai  Ľi he  Ľaho  Ľo ho mńĀlohi,  Ľi he ngaahi teunga matamatalelei  Ľoe mńĀ Ľoni Ľoni mei he manńĀva  Ľoe pongipongi:  
\q2  Ľoku  Ľiate koe  Ľae hahau  Ľo ho Ľo talavou.   
\q1
\v 4 Kuo fuakava  Ľa Sihova, pea  Ľe  Ľikai liliu ia,  
\q2 ‚ÄúKo e taula Ľeiki koe  Ľo lauikuonga  Ľi he lakanga  Ľo Melikiseteke.‚ÄĚ   
\q1
\v 5 Ko e  ĽEiki  Ľaia  Ľoku  Ľi ho nima to Ľomata Ľu,  
\q2 te ne taa Ľi  Ľae ngaahi tu Ľi  Ľi he  Ľaho  Ľo hono houhau.   
\q1
\v 6 Te ne fakamaau  Ľi he  Ľao  Ľoe hiteni,  
\q2 te ne fakapito  Ľae ngaahi potu  Ľaki  Ľae ngaahi  Ľanga Ľanga;  
\q2  Ľe lavea  Ľiate ia  Ľae  Ľulu  Ľoe ngaahi fonua lahi.   
\q1
\v 7 ‚ÄĆ ĽE inu ia  Ľi he vaitafe  Ľi he hala: ko ia te ne hiki hake ai  Ľae  Ľulu.   
\c 111  
\cd \it 1  ĽOku ue Ľi  Ľe he tangata tohi saame  Ľae kakai kenau fa Ľifa Ľitaki kiate ia, pea fakamńĀlŇć ki he  ĽOtua koe Ľuhi ko  Ľene ngńĀue ongoongolelei, 5 Mo  Ľalo Ľofa. 10  ĽOku tupu  Ľae poto mo Ľoni  Ľi he manavahńď ki he  ĽOtua.\it*  
\q1
\v 1 Mou fakamńĀlŇć kia Sihova.  
\q2 Te u fakamńĀlŇć kia Sihova  Ľaki hoku loto kotoa pńď,  
\q2  Ľi he fakataha  Ľoe angatonu, pea  Ľi he lotolotonga  Ľoe kakai.   
\q1
\v 2 ‚ÄĆ ĽOku lahi  Ľae ngńĀue  Ľa Sihova,  Ľoku kumi ki ai  Ľakinautolu kotoa pńď  Ľoku fiefia ai.   
\q1
\v 3 ‚ÄĆ ĽOku ongoongolelei mo nńĀunau Ľia  Ľa  Ľene ngńĀue:  
\q2 pea  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene mńĀ Ľoni Ľoni.   
\q1
\v 4 Kuo ne fai  Ľene ngaahi ngńĀue fakaofo ke manatu ia  Ľe he kakai:  
\q2  Ľoku manava Ľofa  Ľa Sihova, pea fonu  Ľi he  Ľalo Ľofa.   
\q1
\v 5 Kuo foaki  Ľe ia  Ľae me Ľakai kiate kinautolu  Ľoku nau manavahńď kiate ia:  
\q2 te ne manatu Ľi ma Ľuaipńď  Ľa  Ľene fuakava.   
\q1
\v 6 Kuo ne fakahńĀ ki hono kakai  Ľae mńĀlohi  Ľo  Ľene ngaahi ngńĀue,  
\q2 koe Ľuhi ke ne foaki kiate kinautolu  Ľae tofi Ľa  Ľoe hiteni.   
\q1
\v 7 Ko e ngaahi ngńĀue  Ľa hono nima ko e mo Ľoni mo e fakamaau:  
\q2  Ľoku mo Ľoni  Ľa  Ľene ngaahi fekau kotoa pńď.   
\q1
\v 8 ‚ÄĆ ĽOku tu Ľuma Ľu ia  Ľo lauikuonga pea ta Ľengata,  
\q2 pea kuo fai ia  Ľi he mo Ľoni mo e angatonu.   
\q1
\v 9 Na Ľa ne fekau atu  Ľae huhu Ľi ki hono kakai:  
\q2 kuo ne fokotu Ľu  Ľene fuakava  Ľo lauikuonga:  
\q2  Ľoku mńĀ Ľoni Ľoni mo ngeia  Ľa hono huafa.   
\q1
\v 10 Ko e manavahńď kia Sihova ko e kamata Ľanga ia  Ľoe poto:  
\q2  Ľoku poto  Ľakinautolu kotoa pńď  Ľoku fai ki he Ľene fekau:  
\q2  Ľoku tolonga  Ľo ta Ľengata  Ľae fakamńĀlŇć kiate ia.   
\c 112  
\cd \it 1 Kuo ma Ľu  Ľe he anga faka Ľotua  Ľae tala Ľofa  Ľae mo Ľui ni, 4 Pea  Ľoe mo Ľui  Ľe hoko. 10  ĽE mamahi  Ľae angahala  Ľi he Ľenau mamata ki he monŇę Ľia  Ľoe mńĀ Ľoni Ľoni.\it*  
\q1
\v 1 Mou fakamńĀlŇć kia Sihova.  
\q2  ĽOku monŇę Ľia  Ľae tangata  Ľoku ne manavahńď kia Sihova,  
\q2 mo ne fiefia lahi  Ľi he Ľene ngaahi fekau.   
\q1
\v 2 ‚ÄĆ ĽE mńĀlohi hono hako  Ľi mńĀmani:  
\q2 ko e to Ľutangata  Ľoe angatonu tenau monŇę Ľia.   
\q1
\v 3 ‚ÄĆ ĽE  Ľi hono fale  Ľae koloa mo e nńĀunau:  
\q2 pea  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene angatonu.   
\q1
\v 4 ‚ÄĆ ĽOku tupu  Ľae maama ki he angatonu  Ľi he po Ľuli:  
\q2  Ľoku anga Ľofa ia, pea fonu  Ľi he manava Ľofa, pea mńĀ Ľoni Ľoni.   
\q1
\v 5 ‚ÄĆ ĽOku fakahńĀ  Ľe he tangata angalelei  Ľae  Ľofa, pea  Ľoku fa Ľa  Ľatu:  
\q2 te ne pule ki he Ľene me Ľa  Ľi he poto.   
\q1
\v 6 Ko e mo Ľoni  Ľe  Ľikai ue Ľi ia  Ľo lauikuonga:  
\q2  Ľe ta Ľengata  Ľae fakamanatu ki he kakai mńĀ Ľoni Ľoni.   
\q1
\v 7 ‚ÄĆ ĽE  Ľikai te ne manavahńď ki he ongoongo kovi:  
\q2 kuo ma Ľu hono loto  Ľi he falala kia Sihova.   
\q1
\v 8 Kuo fokotu Ľuma Ľu  Ľa hono loto:  
\q2  Ľe  Ľikai te ne manavahńď, ka  Ľe mamata ia ki hono ngaahi fili.   
\q1
\v 9 Kuo tufa  Ľe ia, kuo ne foaki ki he masiva;  
\q2  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene angatonu;  
\q2  Ľe hiki hake hono nifo  Ľi he ongolelei.   
\q1
\v 10 ‚ÄĆ ĽE mamata ki ai  Ľae angahala, pea tenau mamahi:  
\q2  Ľe fengai Ľitaki hono nifo, pea  Ľe mole atu ia:  
\q2  Ľe  Ľauha  Ľae holi  Ľae angahala.   
\c 113  
\cd \it 1 Ko e enginaki ho fakamńĀlŇć ki he  ĽOtua koe Ľuhi ko  Ľene lelei, 6 Mo  Ľene  Ľalo Ľofa.\it*  
\q1
\v 1 Mou fakamńĀlŇć kia Sihova.  
\q2 FakamńĀlŇć,  Ľakimoutolu ko e kau tamaio Ľeiki  Ľa Sihova,  
\q2 fakamńĀlŇć ki he huafa  Ľo Sihova.   
\q1
\v 2 Fakafeta Ľi ki he huafa  Ľo Sihova mei he  Ľaho ni  Ľo ta Ľengata.   
\q1
\v 3 Ke fakamńĀlŇć ki he huafa  Ľo Sihova, mei he hopo hake  Ľoe la ĽńĀ  Ľo a Ľu ki he Ľene tŇć hifo.   
\q1
\v 4 ‚ÄĆ ĽOku mńĀ Ľolunga hake  Ľa Sihova  Ľi he ngaahi pule Ľanga kotoa pńď, mo hono nńĀunau  Ľoku mńĀ Ľolunga hake  Ľi he ngaahi langi.   
\q1
\v 5 Ko hai  Ľoku na tatau mo Sihova ko hotau  ĽOtua,  Ľaia  Ľoku  Ľafio  Ľi  Ľolunga,   
\q1
\v 6 ‚ÄĆ ĽOku ne fakamo Ľulaloa Ľi ia ke  Ľafio ki he ngaahi me Ľa  Ľoku  Ľi he langi, pea mo mńĀmani!   
\q1
\v 7 ‚ÄĆ ĽOku ne fokotu Ľu hake  Ľae masiva mei he efu,  
\q2 mo ne hiki hake  Ľae paea mei he tu Ľunga  Ľoto Ľota;   
\q1
\v 8 Koe Ľuhi ke ne fakataha mo e ngaahi  Ľeiki,  
\q2 pea ke kautaha mo e hou Ľeiki  Ľo hono kakai.   
\q1
\v 9 ‚ÄĆ ĽOku ne ngaohi  Ľae fefine pa Ľa ke tauhi  Ľae fale,  
\q2 pea ke hoko  Ľi he fiefia ko e fa Ľńď  Ľae fńĀnau.  
\q2 Mou fakamńĀlŇć kia Sihova.   
\c 114  
\cd \it 1‚Äď8 Ko e enginaki ke fa Ľifa Ľitaki ki he ngaahi me Ľa kuo ngaohi, pea manavahńď ki he  ĽOtua  Ľi hono siasi.\it*  
\q1
\v 1 ‚ÄĆ ĽI he  Ľalu atu  Ľa  ĽIsileli mei  ĽIsipite,  
\q2 ko e fale  Ľo Sńďkope mei he kakai  Ľoe lea kehe;   
\q1
\v 2 Ko hono faletapu  Ľa Siuta,  
\q2 mo hono pule Ľanga  Ľa  ĽIsileli.   
\q1
\v 3 Na Ľe mamata ki ai  Ľae tahi, pea hola ai:  
\q2 na Ľe teke Ľi atu  Ľo fakaholomui  Ľa Sioatani.   
\q1
\v 4 Na Ľe hopohopo  Ľae ngaahi mo Ľunga  Ľo hangńď ko e fanga sipitangata,  
\q2 mo e ngaahi fo Ľi mo Ľunga  Ľo hangńď ko e fanga lami.   
\q1
\v 5 Ko e hńĀ na Ľe hoko kiate koe,  Ľa koe ko e tahi, koe Ľuhi na Ľa ke hola ai?  
\q2  ĽA koe Sioatani, koe Ľuhi ke teke Ľi atu  Ľo fakaholomui koe?   
\q1
\v 6 ‚ÄĆ ĽAe ngaahi mo Ľunga, koe Ľuhi na Ľa mou hopohopo ai  Ľo hangńď ko e fanga sipitangata;  
\q2 mo kimoutolu  Ľae ngaahi fo Ľi mo Ľunga,  Ľo hangńď ko e fanga lami?   
\q1
\v 7 ‚ÄĆ ĽA koe ko mńĀmani, ke ke tetetete  Ľi he  Ľao  Ľoe  ĽEiki,  
\q2  Ľi he  Ľao  Ľoe  ĽOtua  Ľo Sńďkope;   
\q1
\v 8 ‚ÄĆ ĽAia na Ľa ne liliu  Ľae maka ko e anovai,  
\q2 mo e maka afi ko e matavai.   
\c 115  
\cd \it 1  ĽOku ne enginaki ke loto tui ki he  ĽOtua, koe Ľuhi  Ľoku ongoongolelei  Ľae  ĽOtua, pea  Ľoku va Ľinga pe  Ľae tamapua. 12  ĽOku totonu ke fakafeta Ľi ki he  ĽOtua koe Ľuhi ko  Ľene ngaahi tńĀpuaki.\it*  
\q1
\v 1 ‚ÄĆ ĽOua na Ľa tuku kiate kimautolu,  
\q2  ĽE Sihova,  Ľoua na Ľa tuku kiate kimautolu,  
\q2 ka ki ho huafa  Ľae ongoongolelei, koe Ľuhi ko ho Ľo  Ľalo Ľofa, pea mo ho Ľo mo Ľoni.   
\q1
\v 2 Ko e hńĀ  Ľe pehńď ai  Ľe he hiteni,  
\q2 ‚ÄúKo e fńď honau  ĽOtua?‚ÄĚ   
\q1
\v 3 Ka ko hotau  ĽOtua  Ľoku  Ľi he ngaahi langi:  
\q2 kuo ne fai  Ľaia kuo ne finangalo ki ai.   
\q1
\v 4 Ko honau ngaahi tamapua ko e siliva mo e koula,  
\q2 ko e ngńĀue  Ľae nima  Ľoe tangata.   
\q1
\v 5 ‚ÄĆ ĽOku ai honau ngutu, ka  Ľoku  Ľikai tenau lea:  
\q2  Ľoku nau ma Ľu  Ľae mata, ka  Ľoku  Ľikai tenau mamata:   
\q1
\v 6 ‚ÄĆ ĽOku nau telinga, ka  Ľoku  Ľikai tenau ongo Ľi:  
\q2  Ľoku ai honau ihu, ka  Ľoku  Ľikai tenau nanamu:   
\q1
\v 7 ‚ÄĆ ĽOku nau ma Ľu  Ľae nima, ka  Ľoku  Ľikai tenau ala ki ha me Ľa:  
\q2  Ľoku ai honau va Ľe, ka  Ľoku  Ľikai tenau  Ľa Ľeva:  
\q2 pea  Ľoku  Ľikai tenau lea  Ľaki honau kia.   
\q1
\v 8 Ko kinautolu  Ľoku ngaohi  Ľakinautolu  Ľoku nau tatau mo kinautolu:  
\q2 pea  Ľoku pehńď pe  Ľakinautolu kotoa pńď  Ľoku falala ki ai.   
\q1
\v 9 ‚ÄĆ ĽE  ĽIsileli, ke ke falala kia Sihova ko honau tokoni ia mo honau fakaŇę.   
\q1
\v 10 ‚ÄĆ ĽE fale  Ľo  ĽElone, ke ke falala kia Sihova:  
\q2 ko honau tokoni ia mo honau fakaŇę.   
\q1
\v 11 ‚ÄĆ ĽAkimoutolu  Ľoku manavahńď kia Sihova, mou falala kia Sihova:  
\q2 ko honau tokoni ia mo honau fakaŇę.   
\q1
\v 12 Kuo manatu Ľi  Ľe Sihova  Ľakitautolu: te ne tńĀpuaki  Ľakitautolu;  
\q2 te ne tńĀpuaki  Ľae fale  Ľo  ĽIsileli;  
\q2 te ne tńĀpuaki  Ľae fale  Ľo  ĽElone.   
\q1
\v 13 Te ne tńĀpuaki  Ľakinautolu  Ľoku nau manavahńď kia Sihova,  Ľae iiki mo e lalahi.   
\q1
\v 14 ‚ÄĆ ĽE fakatokolahi  Ľakimoutolu  Ľe Sihova, pea te mou tupu pe,  
\q2  Ľakimoutolu mo ho Ľomou fńĀnau.   
\q1
\v 15 ‚ÄĆ ĽOku mou monŇę Ľia  Ľia Sihova,  Ľaia na Ľa ne ngaohi  Ľae langi mo mńĀmani.   
\q1
\v 16 ‚ÄĆ ĽOku  Ľo Sihova  Ľae langi,  Ľio, ko e ngaahi langi:  
\q2 pea kuo ne foaki  Ľa mńĀmani ki he fńĀnau  Ľae tangata.   
\q1
\v 17 ‚ÄĆ ĽOku  Ľikai fakamńĀlŇć kia Sihova  Ľae mate,  
\q2 pe ha taha  Ľoku  Ľalu hifo ki he fakalongo pńď.   
\q1
\v 18 Ka te tau fakafeta Ľi kia Sihova mei he  Ľaho ni  Ľo ta Ľengata.  
\q2 Mou fakamńĀlŇć kia Sihova.   
\c 116  
\cd \it 1  ĽOku fakahńĀ  Ľe he tangata tohi saame  Ľa  Ľene  Ľofa mo  Ľene talangofua ki he  ĽOtua koe Ľuhi ko  Ľene fakamo Ľui ia. 12  ĽOku ne tokanga ke ne fakafeta Ľi.\it*  
\q1
\v 1 ‚ÄĆ ĽOku ou  Ľofa kia Sihova, koe Ľuhi kuo ne ongo Ľi hoku le Ľo  
\q2 mo  Ľeku lotu tńĀuma Ľu.   
\q1
\v 2 Koe Ľuhi kuo ne fakatokanga Ľi hono fofonga kiate au,  
\q2 ko ia te u ui ai ki he Ľene  Ľafio  Ľi hoku ngaahi  Ľaho.   
\q1
\v 3 Na Ľe kńĀpui au  Ľe he ngaahi mamahi  Ľoe mate,  
\q2 pea na Ľe puke au  Ľe he ngaahi mamahi  Ľo heli:  
\q2 na Ľaku  Ľilo ai  Ľae tu ĽutńĀmaki mo e mamahi.   
\q1
\v 4 Pea na Ľaku toki ui ki he huafa  Ľo Sihova;  
\q2 ‚Äú ĽE Sihova,  Ľoku ou kole kiate koe, ke ke fakamo Ľui hoku laumńĀlie.‚ÄĚ   
\q1
\v 5 ‚ÄĆ ĽOku manava Ľofa  Ľa Sihova, mo mńĀ Ľoni Ľoni;  
\q2  Ľio,  Ľoku  Ľalo Ľofa  Ľa hotau  ĽOtua.   
\q1
\v 6 ‚ÄĆ ĽOku fakamo Ľui  Ľe he  ĽOtua  Ľae ta ĽekńĀkńĀ:  
\q2 na Ľaku vaivai pea na Ľa ne tokoni Ľi au.   
\q1
\v 7 ‚ÄĆ ĽE hoku laumńĀlie, ke ke foki ki ho mńĀlŇćlŇć Ľanga;  
\q2 he kuo lahi  Ľae foaki  Ľa Sihova kiate koe.   
\q1
\v 8 He kuo ke fakamo Ľui hoku laumńĀlie mei he mate,  
\q2 mo hoku mata mei he lo Ľimata,  
\q2 mo hoku va Ľe ke  Ľoua na Ľa hinga.   
\q1
\v 9 Te u  Ľeve Ľeva,  Ľi he  Ľao  Ľo Sihova  Ľi he fonua  Ľoe mo Ľui.   
\q1
\v 10 Na Ľaku tui, ko ia kuo u lea ai:  
\q2 ‚ÄúNa Ľaku mahaki lahi:‚ÄĚ   
\q1
\v 11 Na Ľaku pehńď  Ľi he Ľeku to Ľoto Ľo,  
\q2 ‚Äú ĽOku loi  Ľae kakai kotoa pńď.‚ÄĚ   
\q1
\v 12 Ko e hńĀ te u  Ľatu kia Sihova koe Ľuhi ko  Ľene ngaahi me Ľa Ľofa kotoa pńď kiate au?   
\q1
\v 13 Te u to Ľo  Ľae ipu  Ľoe fakamo Ľui,  
\q2 pea te u ui ki he huafa  Ľo Sihova.   
\q1
\v 14 Te u fai ni  Ľeku ngaahi fuakava kia Sihova  Ľi he  Ľao  Ľo hono kakai kotoa pńď.   
\q1
\v 15 ‚ÄĆ ĽOku mahu Ľinga  Ľi he  Ľao  Ľo Sihova  Ľae pekia  Ľo  Ľene kakai mńĀ Ľoni Ľoni.   
\q1
\v 16 ‚ÄĆ ĽE Sihova, ko e mo Ľoni ko ho Ľo tamaio Ľeiki au;  
\q2 ko ho Ľo tamaio Ľeiki au, mo e tama  Ľa ho Ľo kaunanga:  
\q2 kuo ke vete hoku ngaahi ha Ľi.   
\q1
\v 17 Te u  Ľatu kiate koe  Ľae feilaulau  Ľoe fakafeta Ľi,  
\q2 pea ui ki he huafa  Ľo Sihova.   
\q1
\v 18 Te u fai ni  Ľeku ngaahi fuakava kia Sihova  Ľi he  Ľao  Ľo hono kakai kotoa pńď,   
\q1
\v 19 ‚ÄĆ ĽI he ngaahi loto ĽńĀ  Ľoe fale  Ľo Sihova,  
\q2  Ľi he lotolotonga  Ľo Ľou,  ĽE SelŇęsalema.  
\q2 Mou fakamńĀlŇć kia Sihova.   
\c 117  
\cd \it 1‚Äď2 Ko e enginaki ke fakamńĀlŇć ki he  Ľotua koe Ľuhi ko  Ľene  Ľalo Ľofa mo  Ľene mo Ľoni.\it*  
\q1
\v 1 Mou fakamńĀlŇć kia Sihova,  Ľae ngaahi pule Ľanga kotoa pńď:  
\q2 fakamńĀlŇć ki he Ľene  Ľafio,  
\q2  Ľakimoutolu  Ľae kakai kotoa pńď.   
\q1
\v 2 He  Ľoku lahi  Ľa  Ľene  Ľalo Ľofa kiate kitautolu:  
\q2 pea  Ľoku tolonga  Ľo ta Ľengata  Ľae mo Ľoni  Ľa Sihova.  
\q2 Mou fakamńĀlŇć kia Sihova.   
\c 118  
\cd \it 1 Ko e enginaki ke fakamńĀlŇć ki he  ĽOtua koe Ľuhi ko  Ľene  Ľalo Ľofa. 5  ĽOku fakahńĀ  Ľe he tangata tohi saame ko e me Ľa lelei ke falala ki he  ĽOtua. 19 Pea  Ľi he fakatńĀtńĀ kiate ia,  Ľoku ne fakahńĀ  Ľae hńĀ Ľele mai  Ľa Kalaisi, pea mo  Ľene pule.\it*  
\q1
\v 1 Mou  Ľatu  Ľae fakafeta Ľi kia Sihova he  Ľoku angalelei ia:  
\q2 koe Ľuhi  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 2 Ke lea ni  Ľe  ĽIsileli,  
\q2 ‚Äú ĽOku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.‚ÄĚ   
\q1
\v 3 Ke lea ni  Ľae fale  Ľo  ĽElone,  
\q2 ‚Äú ĽOku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.‚ÄĚ   
\q1
\v 4 Tuku ke lea ni  Ľakinautolu  Ľoku nau manavahńď kia Sihova,  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 5 Na Ľaku ui kia Sihova  Ľi he mamahi:  
\q2 pea na Ľe talia au  Ľe Sihova, mo ne tuku au ki he potu  Ľata ĽatńĀ.   
\q1
\v 6 ‚ÄĆ ĽOku kau ma Ľaku  Ľa Sihova;  Ľe  Ľikai te u manavahńď ko e hńĀ  Ľe fa Ľa fai  Ľe he tangata kiate au.   
\q1
\v 7 ‚ÄĆ ĽOku fai ma Ľaku  Ľa Sihova mo kinautolu  Ľoku nau tokoni au:  
\q2 ko ia te u mamata ai kiate kinautolu  Ľoku nau fehi Ľa kiate au.   
\q1
\v 8 ‚ÄĆ ĽOku lelei lahi  Ľae falala kia Sihova  Ľi he falala ki he tangata.   
\q1
\v 9 ‚ÄĆ ĽOku lelei lahi  Ľae falala kia Sihova  Ľi he falala ki he ngaahi  Ľeiki.   
\q1
\v 10 Na Ľe kńĀpui au  Ľe he ngaahi pule Ľanga kotoa pńď:  
\q2 ka  Ľi he huafa  Ľo Sihova te u faka Ľauha  Ľakinautolu.   
\q1
\v 11 Na Ľa nau takatakai au;  Ľio, na Ľa nau kńĀpui au:  
\q2 ka  Ľi he huafa  Ľo Sihova te u faka Ľauha  Ľakinautolu.   
\q1
\v 12 Na Ľa nau kńĀpui au  Ľo hangńď ko e fanga pi;  
\q2 kuo tńĀmate Ľi  Ľakinautolu  Ľo hangńď ko e afi  Ľi he  Ľakau talatala:  
\q2 he te u faka Ľauha  Ľakinautolu  Ľi he huafa  Ľo Sihova.   
\q1
\v 13 Kuo ke teke Ľi mńĀlohi au koe Ľuhi ke u hinga ai:  
\q2 ka na Ľe tokoni au  Ľe Sihova   
\q1
\v 14 Ko hoku mńĀlohi  Ľa Sihova mo  Ľeku hiva,  
\q2 pea kuo hoko ia ko hoku fakamo Ľui.   
\q1
\v 15 Ko e lea  Ľoe fiefia mo e fakamo Ľui  Ľoku  Ľi he ngaahi fale fehikitaki  Ľoe angatonu:  
\q2  Ľoku fai mńĀlohi  Ľae nima to Ľomata Ľu  Ľo Sihova.   
\q1
\v 16 Kuo hiki hake  Ľae nima to Ľomata Ľu  Ľo Sihova:  
\q2  Ľoku fai mńĀlohi  Ľae nima to Ľomata Ľu  Ľo Sihova.   
\q1
\v 17 ‚ÄĆ ĽE  Ľikai te u mate, kae mo Ľui,  
\q2  Ľo fakahńĀ  Ľae ngaahi ngńĀue  Ľa Sihova.   
\q1
\v 18 Kuo tautea fakamamahi Ľi au  Ľe Sihova:  
\q2 ka  Ľoku te Ľeki ai te ne tukuange au ki he mate.   
\q1
\v 19 To Ľo kiate au  Ľae ngaahi matapńĀ  Ľoe mńĀ Ľoni Ľoni:  
\q2 te u hŇę ai, pea u fakamńĀlŇć kia Sihova:   
\q1
\v 20 Ko e matapńĀ eni  Ľo Sihova,  Ľaia  Ľe hŇę ai  Ľae angatonu.   
\q1
\v 21 Te u fakamńĀlŇć kiate koe: he kuo ke ongo Ľi au,  
\q2 pea kuo ke hoko ko hoku fakamo Ľui.   
\q1
\v 22 Ko e maka na Ľe li Ľaki  Ľe he kau tufunga kuo hoko ia ko e fungani maka  Ľoe tuliki.   
\q1
\v 23 Ko e ngńĀue eni  Ľa Sihova;  
\q2 pea ko e me Ľa fakaofo  Ľi hotau  Ľao.   
\q1
\v 24 Ko e  Ľaho eni kuo ngaohi  Ľe Sihova;  
\q2 te tau fiefia pea nekeneka ai.   
\q1
\v 25 ‚ÄĆ ĽE Sihova,  Ľoku ou kole kiate koe, ke ke fakamo Ľui ni:  
\q2  ĽE Sihova,  Ľoku ou kole kiate koe, ke ke tuku mai ni  Ľae monŇę Ľia.   
\q1
\v 26 Ke monŇę Ľia ia  Ľoku ha Ľu  Ľi he huafa  Ľo Sihova:  
\q2 kuo mau tńĀpuekina  Ľakimoutolu mei he fale  Ľo Sihova.   
\q1
\v 27 Ko e  ĽOtua ko Sihova ia,  Ľaia kuo ne fakahńĀ  Ľae maama kiate kitautolu:  
\q2 mou nono Ľo  Ľae feilaulau  Ľaki  Ľae ngaahi afo ki he ngaahi nifo,  Ľoe feilaulau Ľanga.   
\q1
\v 28 Ko koe ko hoku  ĽOtua, pea te u fakamńĀlŇć kiate koe:  
\q2 ko koe ko hoku  ĽOtua, te u fakahikihiki Ľi koe.   
\q1
\v 29 Mou  Ľatu  Ľae fakafeta Ľi kia Sihova he  Ľoku angalelei ia:  
\q2 koe Ľuhi  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\c 119  
\cd \it 1‚Äď176  ĽOku fakahńĀ  Ľe he saame ni  Ľae ngaahi lotu, mo e ngaahi fakamńĀlŇć, pea mo e ngaahi faka Ľilonga  Ľoe talangofua.\it*  
\qa  ĽALIFA  
\q1
\v 1 ‚ÄĆ ĽOku monŇę Ľia  Ľae haohaoa  Ľi he hala,  
\q2  Ľaia  Ľoku  Ľeve Ľeva  Ľi he fono  Ľa Sihova.   
\q1
\v 2 ‚ÄĆ ĽOku monŇę Ľia  Ľakinautolu  Ľoku tauhi  Ľene ngaahi fakamo Ľoni,  
\q2 pea kumi kiate ia  Ľaki honau loto kotoa pńď.   
\q1
\v 3 ‚ÄĆ ĽOku  Ľikai foki tenau fai ha kovi:  
\q2  Ľoku nau  Ľa Ľeva  Ľi hono ngaahi hala.   
\q1
\v 4 Kuo ke fekau mai ke mau tauhi ma Ľu ho Ľo ngaahi akonaki.   
\q1
\v 5 ‚ÄĆ ĽOku  Ľamusiaange  Ľeau kuo fakahinohino ki hoku ngaahi hala,  
\q2 ke fai ki ho Ľo ngaahi tu Ľutu Ľuni.   
\q1
\v 6 Pea  Ľe  Ľikai te u mńĀ,  
\q2  Ľo kau ka tokanga ki ho Ľo ngaahi fekau kotoa pńď.   
\q1
\v 7 Te u fakamńĀlŇć kiate koe  Ľi he angatonu  Ľoe loto,  
\q2  Ľo kau ka  Ľilo ho Ľo ngaahi fakamaau mńĀ Ľoni Ľoni.   
\q1
\v 8 Te u fai ki ho Ľo ngaahi tu Ľutu Ľuni:  
\q2  Ľoua na Ľa ke si Ľaki  Ľaupito au.   
\b  
\qa PETA  
\q1
\v 9 ‚ÄĆ ĽE fakama Ľa  Ľe he tangata talavou hono hala  Ľi he hńĀ?  
\q2  ĽI he Ľene tokanga ki ai  Ľo hangńď ko ho Ľo folofola.   
\q1
\v 10 Kuo u kumi kiate koe  Ľaki hoku loto kotoa pńď:  
\q2  Ľoua na Ľa tuku au ke u hńď mei ho Ľo ngaahi fekau.   
\q1
\v 11 Kuo u fufŇę ho Ľo folofola  Ľi hoku loto,  
\q2 koe Ľuhi ke  Ľoua na Ľaku angahala kiate koe.   
\q1
\v 12 ‚ÄĆ ĽE Sihova,  Ľoku monŇę Ľia  Ľa ho Ľo  Ľafio:  
\q2 ako kiate au ho Ľo ngaahi tu Ľutu Ľuni.   
\q1
\v 13 Kuo u fakahńĀ  Ľaki hoku loungutu,  
\q2  Ľae ngaahi fakamaau kotoa pńď  Ľa ho fofonga.   
\q1
\v 14 Na Ľaku fiefia  Ľi hono  Ľalunga  Ľo ho Ľo ngaahi fakamo Ľoni,  
\q2  Ľo tatau mo e ngaahi koloa kotoa pńď.   
\q1
\v 15 Te u fakalaulauloto ki ho Ľo ngaahi akonaki,  
\q2 pea te u tokanga ki ho ngaahi hala.   
\q1
\v 16 Te u fakafiefia Ľi au  Ľi ho Ľo ngaahi tu Ľutu Ľuni:  
\q2  Ľe  Ľikai ngalo  Ľiate au ho Ľo folofola.   
\b  
\qa KIMELA  
\q1
\v 17 Foaki ke lahi ki ho Ľo tamaio Ľeiki,  
\q2 koe Ľuhi ke u mo Ľui, pea te u tauhi ki ho Ľo folofola.   
\q1
\v 18 Ke ke faka ĽńĀ hoku mata,  
\q2 koe Ľuhi ke u mamata ki he ngaahi me Ľa fakaofo  Ľi ho Ľo fono.   
\q1
\v 19 Ko e muli au  Ľi mńĀmani:  
\q2  Ľoua na Ľa fufŇę ho Ľo ngaahi fekau  Ľiate au.   
\q1
\v 20 ‚ÄĆ ĽOku mafesi hoku laumńĀlie koe Ľuhi ko  Ľene holi ki ho Ľo ngaahi fakamaau  Ľi he  Ľaho kotoa pńď.   
\q1
\v 21 Kuo ke valoki Ľi  Ľae laukau,  Ľakinautolu  Ľoku mala Ľia,  
\q2  Ľaia kuo hńď mei ho Ľo ngaahi fekau.   
\q1
\v 22 ‚ÄĆ ĽAve  Ľiate au  Ľae taukaea mo e manukia;  
\q2 he kuo u fai ki ho Ľo ngaahi fakamo Ľoni.   
\q1
\v 23 Na Ľe nofo foki  Ľae ngaahi  Ľeiki  Ľo lau Ľikovi Ľi au:  
\q2 ka na Ľe fakalauloto  Ľa ho Ľo tamaio Ľeiki ki ho Ľo ngaahi tu Ľutu Ľuni.   
\q1
\v 24 Ko ho Ľo ngaahi fakamo Ľoni foki ko hoku fiefia Ľanga ia,  
\q2 mo hoku ngaahi akonaki Ľi.   
\b  
\qa TALETA  
\q1
\v 25 ‚ÄĆ ĽOku pikitai  Ľa hoku laumńĀlie ki he efu:  
\q2 ke ke fakamo Ľui au  Ľo hangńď ko ho Ľo folofola.   
\q1
\v 26 Kuo u fakahńĀ hoku ngaahi hala, pea na Ľa ke ongo Ľi au:  
\q2 ako kiate au ho Ľo ngaahi tu Ľutu Ľuni.   
\q1
\v 27 Ngaohi au ke u  Ľilo  Ľae hala  Ľo ho Ľo ngaahi akonaki:  
\q2 pea te u lea ki ho Ľo ngaahi ngńĀue fakaofo.   
\q1
\v 28 Kuo vai  Ľa hoku laumńĀlie koe Ľuhi ko e ongosia:  
\q2 fakamńĀlohi Ľi au  Ľo hangńď ko ho Ľo folofola.   
\q1
\v 29 Ke ke hiki  Ľiate au  Ľae hala  Ľoe loi,  
\q2 pea ke tuku mai ho Ľo fono kiate au  Ľi he  Ľofa.   
\q1
\v 30 Kuo u fili  Ľae hala  Ľoe mo Ľoni:  
\q2 pea kuo u fokotu Ľu ho Ľo ngaahi fakamaau  Ľi hoku  Ľao.   
\q1
\v 31 Kuo u pikitai ki ho Ľo ngaahi fakamo Ľoni;  
\q2  ĽE Sihova,  Ľoua na Ľa ke fakamaa Ľi au.   
\q1
\v 32 Te u lele  Ľi he hala  Ľo ho Ľo ngaahi fekau,  
\q2  Ľoka ke ka faka Ľata ĽatńĀ hoku loto.   
\b  
\qa HE  
\q1
\v 33 ‚ÄĆ ĽE Sihova, ke ke ako kiate au  Ľae hala  Ľo ho Ľo ngaahi tu Ľutu Ľuni;  
\q2 pea te u fai ki ai  Ľo a Ľu ki he ngata Ľanga.   
\q1
\v 34 Foaki mai kiate au  Ľae fa Ľa  Ľilo, pea te u fai ki ho Ľo fono;  
\q2  Ľio, te u tokanga ki ai  Ľaki hoku loto kotoa pńď.   
\q1
\v 35 Ngaohi au ke u  Ľalu  Ľi he hala  Ľo ho Ľo ngaahi fekau;  
\q2 he  Ľoku ou fiefia ai.   
\q1
\v 36 Fakatokanga Ľi hoku loto ki ho Ľo ngaahi fakamo Ľoni,  
\q2 kae  Ľikai ki he manumanu.   
\q1
\v 37 Ta Ľofi hoku mata mei he vakai ki he me Ľa va Ľinga;  
\q2 pea ke fakaakeake au  Ľi ho hala.   
\q1
\v 38 Fakamo Ľoni ho Ľo folofola ki ho Ľo tamaio Ľeiki,  
\q2  Ľaia  Ľoku faka Ľapa Ľapa kiate koe.   
\q1
\v 39 Ta Ľofi atu hoku manukia  Ľaia  Ľoku ou manavahńď ai:  
\q2 he  Ľoku lelei ho Ľo ngaahi fakamaau.   
\q1
\v 40 Vakai,  Ľoku ou holi ki ho Ľo ngaahi akonaki:  
\q2 fakamo Ľui au  Ľi ho mńĀ Ľoni Ľoni.   
\b  
\qa VAU  
\q1
\v 41 ‚ÄĆ ĽE Sihova, tuku ke hoko foki ho Ľo ngaahi  Ľalo Ľofa kiate au,  
\q2  Ľio, ko ho Ľo fakamo Ľui,  Ľo hangńď ko ho Ľo folofola.   
\q1
\v 42 Pehńď te u ma Ľu ha me Ľa ke tali  Ľaki kiate ia  Ľoku manuki Ľi au: he  Ľoku ou falala ki ho Ľo folofola.   
\q1
\v 43 Pea  Ľoua na Ľa to Ľo  Ľaupito  Ľae folofola  Ľoe mo Ľoni mei hoku ngutu;  
\q2 he kuo u  Ľamanaki lelei ki ho Ľo ngaahi fakamaau.   
\q1
\v 44 Pea te u fai ma Ľuaipńď ki ho Ľo fono  Ľo lauikuonga pea ta Ľengata.   
\q1
\v 45 Pea te u  Ľeve Ľeva  Ľi he tau ĽatńĀina:  
\q2 he  Ľoku ou kumi ki ho Ľo ngaahi akonaki.   
\q1
\v 46 Te u lea foki ki ho Ľo ngaahi fakamo Ľoni  Ľi he  Ľao  Ľoe ngaahi tu Ľi,  
\q2 pea  Ľe  Ľikai te u mńĀ ai.   
\q1
\v 47 Pea te u fakafiefia Ľi au  Ľi ho Ľo ngaahi fekau,  
\q2  Ľaia kuo u  Ľofa ki ai.   
\q1
\v 48 Te u hiki hake foki hoku nima ki ho Ľo ngaahi fekau,  
\q2  Ľaia kuo u  Ľofa ki ai pea te u fakalaulauloto ki ho Ľo ngaahi tu Ľutu Ľuni.   
\b  
\qa SAINI  
\q1
\v 49 Manatu Ľi  Ľae folofola ki ho Ľo tamaio Ľeiki,  
\q2  Ľaia kuo ke faka Ľamanaki Ľi au ki ai.   
\q1
\v 50 Ko hoku fiemńĀlie Ľanga eni  Ľi he Ľeku mamahi:  
\q2 he ko ho Ľo folofola kuo ne fakamo Ľui au.   
\q1
\v 51 Kuo manuki lahi kiate au  Ľae laukau:  
\q2 ka na Ľe  Ľikai te u afe mei ho Ľo fono.   
\q1
\v 52 ‚ÄĆ ĽE Sihova, na Ľaku manatu ki ho Ľo ngaahi fakamaau  Ľi mu Ľa;  
\q2 pea u fakafiemńĀlie Ľi au.   
\q1
\v 53 Kuo pukea au  Ľe he ilifia koe Ľuhi ko e angahala kuo nau si Ľaki ho Ľo fono.   
\q1
\v 54 Ko ho Ľo ngaahi tu Ľutu Ľuni ko  Ľeku hiva ia  Ľi he fale  Ľo  Ľeku  ĽńĀunofo.   
\q1
\v 55 ‚ÄĆ ĽE Sihova, kuo u manatu ki ho huafa  Ľi he pŇć,  
\q2 pea u fai ki ho Ľo fono.   
\q1
\v 56 Na Ľaku ma Ľu eni,  
\q2 ko e me Ľa  Ľi he Ľeku fai ki ho Ľo ngaahi akonaki.   
\b  
\qa KETA  
\q1
\v 57 ‚ÄĆ ĽE Sihova, ko hoku  Ľinasi  Ľa koe:  
\q2 na Ľaku pehńď te u fai ki ho Ľo ngaahi folofola.   
\q1
\v 58 Na Ľaku kole ki ho Ľo  Ľofa  Ľaki hoku loto kotoa pńď:  
\q2 ke ke  Ľalo Ľofa mai kiate au  Ľo hangńď ko ho Ľo folofola.   
\q1
\v 59 Na Ľaku fifili ki hoku ngaahi  Ľalu Ľanga,  
\q2 pea u fakaafe hoku va Ľe ki ho Ľo ngaahi fakamo Ľoni.   
\q1
\v 60 Ne u fakato Ľoto Ľo, pea  Ľikai tuai,  
\q2  Ľeku fai ki ho Ľo ngaahi fekau.   
\q1
\v 61 Kuo kaiha Ľasia au  Ľe he ngaahi kaiha Ľakau  Ľoe kau angahala:  
\q2 ka na Ľe  Ľikai ngalo  Ľiate au  Ľa ho Ľo fono.   
\q1
\v 62 Te u tu Ľu hake  Ľi he tu ĽuapŇć mńĀlie ke fakafeta Ľi kiate koe,  
\q2 koe Ľuhi ko ho Ľo ngaahi fakamaau mńĀ Ľoni Ľoni.   
\q1
\v 63 ‚ÄĆ ĽOku ou kaume Ľa mo kinautolu kotoa pńď  Ľoku manavahńď kiate koe,  
\q2 mo kinautolu  Ľoku fai ki ho Ľo ngaahi fekau.   
\q1
\v 64 ‚ÄĆ ĽE Sihova,  Ľoku fonu  Ľa mńĀmani  Ľi ho Ľo  Ľalo Ľofa:  
\q2 ke ke ako kiate au  Ľa ho Ľo ngaahi tu Ľutu Ľuni.   
\b  
\qa TETA  
\q1
\v 65 ‚ÄĆ ĽE Sihova, kuo ke fie fai lelei ki ho Ľo tamaio Ľeiki,  
\q2  Ľo hangńď ko ho Ľo folofola.   
\q1
\v 66 Ke ke ako kiate au  Ľae fakamaau lelei mo e fa Ľa  Ľilo:  
\q2 he  Ľoku ou tui ki ho Ľo ngaahi fekau.   
\q1
\v 67 ‚ÄĆ ĽI he te Ľeki ai te u mahaki na Ľaku hńď:  
\q2 ka ko eni kuo u fai ki ho Ľo folofola.   
\q1
\v 68 ‚ÄĆ ĽOku ke angalelei, pea  Ľoku ke fai lelei;  
\q2 ke ke ako kiate au  Ľa ho Ľo ngaahi tu Ľutu Ľuni.   
\q1
\v 69 Kuo fakatupu  Ľe he fielahi  Ľae loi kiate au:  
\q2 ka te u fai ki ho Ľo ngaahi akonaki  Ľaki hoku loto kotoa pńď.   
\q1
\v 70 ‚ÄĆ ĽOku tatau honau loto mo e ngako,  
\q2 ka  Ľoku ou fiefia  Ľi ho Ľo fono.   
\q1
\v 71 Kuo  Ľaonga kiate au  Ľa hoku mahaki;  
\q2 koe Ľuhi ke u  Ľilo ai ho Ľo ngaahi tu Ľutu Ľuni.   
\b  
\qa IOTA  
\q1
\v 72 ‚ÄĆ ĽOku lelei lahi kiate au  Ľae fono  Ľaho fofonga  Ľi he ngaahi afe  Ľoe kuonga koula mo e siliva.   
\q1
\v 73 Ko ho nima na Ľa ne ngaohi au mo fakatonutonu: foaki mai  Ľae poto,  
\q2 koe Ľuhi ke u  Ľilo Ľi ho Ľo ngaahi fekau.   
\q1
\v 74 Ko kinautolu  Ľoku manavahńď kiate koe tenau fiefia  Ľoka nau ka mamata kiate au;  
\q2 koe Ľuhi na Ľaku  Ľamanaki ki ho Ľo folofola.   
\q1
\v 75 ‚ÄĆ ĽE Sihova,  Ľoku ou  Ľilo  Ľoku totonu ho Ľo ngaahi fakamaau,  
\q2 pea  Ľi he angatonu kuo ke fakamamahi Ľi au.   
\q1
\v 76 ‚ÄĆ ĽOku ou kole kiate koe, tuku ke fakafiemńĀlie Ľi au  Ľe ho Ľo  Ľalo Ľofa,  
\q2  Ľo hangńď ko ho Ľo folofola ki ho Ľo tamaio Ľeiki.   
\q1
\v 77 Tuku ke hoko kiate au ho Ľo ngaahi  Ľalo Ľofa ongongofua,  
\q2 koe Ľuhi ke u mo Ľui ai:  
\q2 he ko ho Ľo fono ko hoku fiefia Ľanga ia.   
\q1
\v 78 Tuku ke mńĀ  Ľae fielahi; he na Ľa Tuku ke tafoki mai kiate au  Ľakinautolu  Ľoku manavahńď kiate koe,  
\q2 pea mo kinautolu kuo nau  Ľilo Ľi ho Ľo ngaahi fakamo Ľoni.   
\q1
\v 79 Tuku ke tafoki mai kiate au  Ľakinautolu  Ľoku manavahńď kiate koe,  
\q2 pea mo kinautolu kuo nau  Ľilo Ľi ho Ľo ngaahi fakamo Ľoni.   
\q1
\v 80 Tuku ke haohaoa hoku loto  Ľi ho Ľo ngaahi tu Ľutu Ľuni;  
\q2 koe Ľuhi ke  Ľoua na Ľaku mńĀ ai.   
\b  
\qa KAFA  
\q1
\v 81 ‚ÄĆ ĽOku pongia hoku laumńĀlie  Ľi he fiema Ľu ho Ľo fakamo Ľui:  
\q2 ka  Ľoku ou  Ľamanaki ki ho Ľo folofola.   
\q1
\v 82 ‚ÄĆ ĽOku vaivai hoku mata koe Ľuhi ko ho Ľo folofola,  
\q2  Ľoku ou pehńď, ‚ÄúTe ke fakafiemńĀlie Ľi au  Ľafńď?‚ÄĚ   
\q1
\v 83 He kuo u hoko  Ľo tatau mo e hina  Ľi he  Ľohuafi;  
\q2 ka  Ľoku  Ľikai ngalo  Ľiate au ho Ľo ngaahi tu Ľutu Ľuni.   
\q1
\v 84 ‚ÄĆ ĽOku fiha  Ľae ngaahi  Ľaho  Ľo ho Ľo tamaio Ľeiki?  
\q2 Te ke fakamaau  Ľafńď  Ľakinautolu  Ľoku fakatanga Ľi au?   
\q1
\v 85 Kuo keli  Ľe he fielahi  Ľae ngaahi luo kiate au  Ľaia  Ľoku  Ľikai tatau mo ho Ľo fono.   
\q1
\v 86 ‚ÄĆ ĽOku tu Ľuma Ľu ho Ľo ngaahi fekau kotoa pńď:  
\q2  Ľoku ta Ľetotonu  Ľenau fakatanga Ľi au; ke ke tokoni Ľi au,   
\q1
\v 87 Na Ľa nau meimei faka Ľauha au  Ľi mńĀmani ka na Ľe  Ľikai te u si Ľaki ho Ľo ngaahi akonaki.   
\q1
\v 88 Fakamo Ľui au  Ľo hangńď ko ho Ľo  Ľalo Ľofa;  
\q2 ko ia te u tauhi ai  Ľae fakamo Ľoni  Ľa ho fofonga.   
\b  
\qa LAMETA  
\q1
\v 89 ‚ÄĆ ĽE Sihova,  Ľoku tu Ľuma Ľu ho Ľo folofola  Ľi he langi  Ľo lauikuonga.   
\q1
\v 90 ‚ÄĆ ĽOku a Ľu atu ho Ľo mo Ľoni ki he ngaahi to Ľutangata kotoa pńď:  
\q2 kuo ke fokotu Ľu  Ľa mńĀmani, pea  Ľoku tu Ľuma Ľu ia.   
\q1
\v 91 ‚ÄĆ ĽOku nau tolonga he  Ľaho ni  Ľo hangńď ko ho Ľo ngaahi tu Ľutu Ľuni:  
\q2 he ko ho Ľo kau tamaio Ľeiki  Ľae me Ľa kotoa pńď.   
\q1
\v 92 Ka ne  Ľikai ko hoku fiefia Ľanga  Ľa ho Ľo fono,  
\q2 pehńď, ne u mate  Ľi hoku mahaki.   
\q1
\v 93 ‚ÄĆ ĽE  Ľikai si Ľi ngalo  Ľiate au ho Ľo ngaahi akonaki  Ľo lauikuonga:  
\q2 he ko ia kuo ke fakamo Ľui ai au.   
\q1
\v 94 ‚ÄĆ ĽOku  Ľa Ľau au,  
\q2 ke ke fakamo Ľui au he kuo u kumi ki ho Ľo ngaahi akonaki.   
\q1
\v 95 Kuo tatali  Ľae angahala kiate au ke tńĀmate Ľi au:  
\q2 ka te u fifili ki ho Ľo ngaahi fakamo Ľoni.   
\q1
\v 96 Kuo u mamata ki hono ngata Ľanga  Ľoe haohaoa kotoa pńď:  
\q2 ka  Ľoku laulahi  Ľaupito  Ľa ho Ľo fekau.   
\b  
\qa MEMA  
\q1
\v 97 ‚ÄĆ ĽOku ou  Ľofa lahi ki ho Ľo fono:  
\q2  Ľoku ou fakalaulauloto ki ai  Ľi he  Ľaho kotoa pńď.   
\q1
\v 98 Kuo ke ngaohi au  Ľi ho Ľo ngaahi fekau ke u poto hake  Ľi hoku ngaahi fili:  
\q2 he  Ľoku  Ľiate au ma Ľuaipńď ia.   
\q1
\v 99 ‚ÄĆ ĽOku ou poto lahi hake  Ľi he Ľeku kau akonaki kotoa pńď:  
\q2 he ko ho Ľo ngaahi fakamo Ľoni ko hoku fakakaukau Ľanga ia.   
\q1
\v 100 ‚ÄĆ ĽOku ou  Ľilo lahi hake  Ľi he kau mńĀtu Ľa,  
\q2 koe Ľuhi  Ľoku ou tauhi ho Ľo ngaahi akonaki.   
\q1
\v 101 Na Ľaku ta Ľofi hoku va Ľe mei he hala kovi kotoa pńď,  
\q2 koe Ľuhi ke u fai ki ho Ľo folofola.   
\q1
\v 102 Na Ľe  Ľikai te u afe mei ho Ľo ngaahi fakamaau:  
\q2 he kuo ke akonaki Ľi au.   
\q1
\v 103 ‚ÄĆ ĽOku hu Ľamelie lahi ho Ľo ngaahi folofola ki hoku ifo!  
\q2  ĽIo,  Ľoku melie lahi  Ľi he hone ki hoku ngutu!   
\q1
\v 104 ‚ÄĆ ĽOku ou ma Ľu  Ľae poto  Ľi ho Ľo ngaahi akonaki:  
\q2 ko ia  Ľoku ou fehi Ľa ai ki he hala kotoa pńď  Ľoe loi.   
\b  
\qa NUNA  
\q1
\v 105 Ko ho Ľo folofola ko e tŇęhulu ia ki hoku va Ľe,  
\q2 mo e maama ki hoku hala.   
\q1
\v 106 Kuo u fuakava, pea te u fai ki ai,  
\q2 ke u fai ki ho Ľo ngaahi fakamaau mńĀ Ľoni Ľoni.   
\q1
\v 107 ‚ÄĆ ĽOku lahi  Ľaupito hoku mahaki:  
\q2 fakamo Ľui au,  ĽE Sihova,  Ľo hangńď ko ho Ľo folofola.   
\q1
\v 108 ‚ÄĆ ĽE Sihova,  Ľoku ou kole kiate koe, ke ke ma Ľu  Ľae ngaahi feilaulau loto lelei  Ľa hoku ngutu,  
\q2 pea ke ako kiate au ho Ľo ngaahi fakamaau.   
\q1
\v 109 ‚ÄĆ ĽOku  Ľi hoku nima ma Ľuaipńď  Ľa  Ľeku mo Ľui:  
\q2 ka  Ľoku  Ľikai ngalo  Ľiate au ho Ľo fono.   
\q1
\v 110 Kuo  Ľai  Ľe he angahala  Ľae tauhele kiate au:  
\q2 ka na Ľe  Ľikai te u hńď mei ho Ľo ngaahi akonaki.   
\q1
\v 111 Kuo u ma Ľu  Ľa ho Ľo ngaahi fakamo Ľoni ko hoku tofi Ľa  Ľo lauikuonga:  
\q2 he ko e fiefia Ľanga ia  Ľo hoku loto.   
\q1
\v 112 Kuo u fakatokanga Ľi hoku loto ke fai ma Ľuaipńď ki ho Ľo ngaahi tu Ľutu Ľuni,  
\q2  Ľo a Ľu ki he ngata Ľanga.   
\b  
\qa SAMEHA  
\q1
\v 113 ‚ÄĆ ĽOku ou fehi Ľa ki he ngaahi mahalo kovi:  
\q2 ka  Ľoku ou  Ľofa ki ho Ľo fono.   
\q1
\v 114 Ko koe ko hoku toitoi Ľanga, mo hoku fakaŇę;  
\q2  Ľoku ou  Ľamanaki lelei  Ľi ho Ľo folofola.   
\q1
\v 115 ‚ÄĆ ĽAlu  Ľiate au,  Ľakimoutolu  Ľoku fai kovi:  
\q2 he te u fai ki he ngaahi fekau  Ľa hoku  ĽOtua.   
\q1
\v 116 Poupou hake au  Ľo hangńď ko ho Ľo folofola, koe Ľuhi ke u mo Ľui ai.  
\q2 Pea  Ľoua na Ľa tuku au ke u mńĀ  Ľi he Ľeku  Ľamanaki.   
\q1
\v 117 Ke ke poupou hake au, pea te u hao ai:  
\q2 pea te u tokanga ma Ľuaipńď ki ho Ľo ngaahi tu Ľutu Ľuni.   
\q1
\v 118 Kuo ke malaki hifo  Ľakinautolu kotoa pńď  Ľoku hńď mei ho Ľo ngaahi tu Ľutu Ľuni:  
\q2 he ko  Ľenau kńĀkńĀ ko e loi ia.   
\q1
\v 119 ‚ÄĆ ĽOku ke si Ľaki  Ľae kau angahala kotoa pńď  Ľo mńĀmani  Ľo hangńď ko e  Ľoto Ľota:  
\q2 ko ia  Ľoku ou  Ľofa ai ki ho Ľo ngaahi fakamo Ľoni.   
\q1
\v 120 ‚ÄĆ ĽOku tetetete hoku kakano ko e me Ľa  Ľi he Ľeku manavahńď kiate koe;  
\q2 pea  Ľoku ou manavahńď ki ho Ľo ngaahi fakamaau.   
\b  
\qa OINI  
\q1
\v 121 Kuo u fai  Ľae fakamaau mo e angatonu:  
\q2  Ľoua na Ľa tukuange au ki he kau fakamńĀlohi kiate au.   
\q1
\v 122 Ke ke hoko ko e ungaki Ľi ki ho Ľo tamaio Ľeiki ke u lelei ai;  
\q2  Ľoua na Ľa tuku ke ta Ľomia au  Ľe he fielahi.   
\q1
\v 123 ‚ÄĆ ĽOku vaivai hoku mata koe Ľuhi ko ho Ľo fakamo Ľui,  
\q2 pea mo e folofola  Ľo ho Ľo mńĀ Ľoni Ľoni.   
\q1
\v 124 Fai ki ho Ľo tamaio Ľeiki  Ľo hangńď ko ho Ľo  Ľalo Ľofa,  
\q2 pea ke ako kiate au  Ľa ho Ľo ngaahi tu Ľutu Ľuni.   
\q1
\v 125 Ko ho Ľo tamaio Ľeiki au; foaki mai  Ľae poto,  
\q2 koe Ľuhi ke u  Ľilo ai ho Ľo ngaahi fakamo Ľoni.   
\q1
\v 126 ‚ÄĆ ĽE Sihova, kuo hoko  Ľae kuonga ke ke ngńĀue ai:  
\q2 he kuo nau fakata Ľe Ľaonga Ľi ho Ľo fono.   
\q1
\v 127 Ko ia  Ľoku ou  Ľofa lahi hake ki ho Ľo ngaahi fekau  Ľi he koula;  
\q2  Ľio,  Ľi he koula lelei.   
\q1
\v 128 Ko ia  Ľoku ou pehńď  Ľoku totonu ho Ľo ngaahi akonaki kotoa pńď;  
\q2 pea  Ľoku ou fehi Ľa ki he hala kotoa pńď  Ľoe loi.   
\b  
\qa PE  
\q1
\v 129 ‚ÄĆ ĽOku fakamanavahńď ho Ľo ngaahi fakamo Ľoni:  
\q2 ko ia  Ľoku fai ki ai  Ľa hoku laumńĀlie.   
\q1
\v 130 Ko e hŇę loto  Ľa ho Ľo ngaahi folofola  Ľoku foaki ai  Ľae maama;  
\q2  Ľoku  Ľomi  Ľe ia  Ľae poto ki he ta ĽekńĀkńĀ.   
\q1
\v 131 Ne u mafa Ľa hoku ngutu,  
\q2 pea u holi he  Ľoku ou feinga ki ho Ľo ngaahi fekau.   
\q1
\v 132 Ke ke  Ľafio mai kiate au, mo ke  Ľalo Ľofa kiate au,  
\q2  Ľo hangńď ko ho Ľo fa Ľa fai kiate kinautolu  Ľoku  Ľofa ki ho huafa.   
\q1
\v 133 Tu Ľutu Ľuni  Ľeku ngaahi laka  Ľi ho Ľo folofola:  
\q2 pea  Ľoua na Ľa tuku ke pule kiate au ha hia  Ľe taha.   
\q1
\v 134 Fakamo Ľui au mei he fakamńĀlohi  Ľae tangata:  
\q2 pea te u fai ki ho Ľo ngaahi akonaki.   
\q1
\v 135 Tuku ke ulo mai ho fofonga ki ho Ľo tamaio Ľeiki;  
\q2 pea ke ako kiate au ho Ľo ngaahi tu Ľutu Ľuni.   
\q1
\v 136 ‚ÄĆ ĽOku tafe hifo  Ľae ngaahi vaitafe  Ľi hoku mata,  
\q2 koe Ľuhi  Ľoku  Ľikai tenau tokanga ki ho Ľo fono.   
\b  
\qa SATI  
\q1
\v 137 ‚ÄĆ ĽE Sihova,  Ľoku ke angatonu,  
\q2 pea  Ľoku totonu ho Ľo ngaahi fakamaau.   
\q1
\v 138 ‚ÄĆ ĽOku mńĀ Ľoni Ľoni pea  Ľoku tu Ľuma Ľu  Ľaupito ho Ľo ngaahi fakamo Ľoni,  
\q2  Ľaia kuo ke fekau mai.   
\q1
\v 139 Kuo u  Ľosi Ľosiloto  Ľi he Ľeku fai feinga,  
\q2 koe Ľuhi kuo ngalo  Ľi hoku ngaahi fili ho Ľo ngaahi folofola.   
\q1
\v 140 ‚ÄĆ ĽOku haohaoa  Ľaupito ho Ľo folofola:  
\q2 ko ia  Ľoku  Ľofa ki ai  Ľa ho Ľo tamaio Ľeiki.   
\q1
\v 141 ‚ÄĆ ĽOku ou si Ľi au mo manukia:  
\q2 ka  Ľoku  Ľikai ngalo  Ľiate au ho Ľo ngaahi akonaki.   
\q1
\v 142 Ko ho Ľo mńĀ Ľoni Ľoni ko e mńĀ Ľoni Ľoni ta Ľengata,  
\q2 pea ko ho Ľo fono ko e mo Ľoni ia.   
\q1
\v 143 Kuo pukea au  Ľe he mamahi mo e feinga:  
\q2 ka ko ho Ľo ngaahi fekau ko hoku fiefia Ľanga ia.   
\q1
\v 144 ‚ÄĆ ĽOku ta Ľengata  Ľae mńĀ Ľoni Ľoni  Ľo ho Ľo ngaahi fakamo Ľoni:  
\q2 ke ke foaki mai  Ľae poto, pea te u mo Ľui ai.   
\b  
\qa KOFI  
\q1
\v 145 Na Ľaku tangi  Ľaki hoku loto kotoa;  
\q2 ke ke ongo Ľi au,  ĽE Sihova:  
\q2 te u fai ki ho Ľo ngaahi tu Ľutu Ľuni.   
\q1
\v 146 Ne u tangi kiate koe; fakamo Ľui au,  
\q2 koe Ľuhi ke u fai ki ho Ľo ngaahi fakamo Ľoni.   
\q1
\v 147 Na Ľaku mu Ľomu Ľa  Ľi he ma Ľa  Ľae  Ľaho, pea u tangi:  
\q2 ne u  Ľamanaki  Ľi ho Ľo folofola.   
\q1
\v 148 ‚ÄĆ ĽOku mu Ľomu Ľa  Ľa hoku mata ki he ngaahi le Ľo  Ľoe pŇć,  
\q2 koe Ľuhi ke u fakakaukau ki ho Ľo folofola.   
\q1
\v 149 Ke ke fanongo ki hoku le Ľo  Ľo hangńď ko ho Ľo  Ľalo Ľofa:  
\q2  ĽE Sihova, fakamo Ľui au  Ľo hangńď ko ho Ľo fakamaau.   
\q1
\v 150 ‚ÄĆ ĽOku  Ľunu Ľunu mai  Ľakinautolu  Ľoku nau angimui ki he kovi:  
\q2  Ľoku nau mama Ľo mei ho Ľo fono.   
\q1
\v 151 ‚ÄĆ ĽOku ke ofi mai,  ĽE Sihova;  
\q2 pea  Ľoku mo Ľoni ho Ľo ngaahi fekau kotoa pńď.   
\q1
\v 152 Koe Ľuhi ko ho Ľo ngaahi fakamo Ľoni,  
\q2 kuo fuoloa  Ľeku  Ľilo kuo ke fakamaau ia  Ľo lauikuonga.   
\b  
\qa LESA  
\q1
\v 153 Ke ke tokanga ki hoku mahaki, pea ke fakamo Ľui au:  
\q2 he  Ľoku  Ľikai ngalo  Ľiate au ho Ľo fono.   
\q1
\v 154 Ke ke fakamatala  Ľeku me Ľa, mo fakahaofi au:  
\q2 fakamo Ľui au  Ľo hangńď ko ho Ľo folofola.   
\q1
\v 155 ‚ÄĆ ĽOku mama Ľo  Ľae fakamo Ľui mei he angahala:  
\q2 he  Ľoku  Ľikai tenau kumi ki ho Ľo ngaahi tu Ľutu Ľuni.   
\q1
\v 156 ‚ÄĆ ĽOku lahi ho Ľo ngaahi  Ľalo Ľofa ongongofua,  ĽE Sihova:  
\q2 fakamo Ľui au  Ľo hangńď ko ho Ľo ngaahi fakamaau.   
\q1
\v 157 ‚ÄĆ ĽOku tokolahi hoku kau fakatanga mo hoku ngaahi fili;  
\q2 ka  Ľoku  Ľikai te u afe mei ho Ľo ngaahi fakamo Ľoni.   
\q1
\v 158 Na Ľaku mamata ki he kau talangata Ľa, pea u mamahi ai;  
\q2 koe Ľuhi na Ľe  Ľikai tenau fai ki ho Ľo folofola.   
\q1
\v 159 Ke ke  Ľafio ki hono anga  Ľo  Ľeku  Ľofa ki ho Ľo ngaahi akonaki:  
\q2 fakamo Ľui au,  ĽE Sihova,  Ľo hangńď ko ho Ľo  Ľalo Ľofa.   
\q1
\v 160 ‚ÄĆ ĽOku mo Ľoni ho Ľo folofola mei hono kamata Ľanga:  
\q2 pea  Ľoku tolonga  Ľo ta Ľengata ho Ľo ngaahi fakamaau mńĀ Ľoni Ľoni kotoa pńď.   
\b  
\qa SINI.  
\q1
\v 161 Kuo fakatanga au ta Ľehano Ľuhinga  Ľe he ngaahi  Ľeiki:  
\q2 ka  Ľoku faka Ľapa Ľapa  Ľa hoku loto ki ho Ľo folofola.   
\q1
\v 162 ‚ÄĆ ĽOku ou fiefia  Ľi ho Ľo folofola,  
\q2  Ľo hangńď ko e taha  Ľoku ne  Ľilo  Ľae koloa lahi.   
\q1
\v 163 ‚ÄĆ ĽOku ou fehi Ľa mo fńĀkalili Ľa ki he loi:  
\q2 ka  Ľoku ou  Ľofa ki ho Ľo fono.   
\q1
\v 164 ‚ÄĆ ĽOku ou fakamńĀlŇć kiate koe  Ľo liunga fitu  Ľi he  Ľaho,  
\q2 koe Ľuhi ko ho Ľo ngaahi fakamaau mńĀ Ľoni Ľoni.   
\q1
\v 165 ‚ÄĆ ĽOku ma Ľu  Ľae fiemńĀlie lahi  Ľekinautolu  Ľoku  Ľofa ki ho Ľo fono:  
\q2 pea  Ľe  Ľikai tŇękia  Ľakinautolu  Ľi ha me Ľa.   
\q1
\v 166 ‚ÄĆ ĽE Sihova, kuo u  Ľamanaki ki ho Ľo fakamo Ľui,  
\q2 pea kuo u fai ki ho Ľo ngaahi fekau.   
\q1
\v 167 Kuo tauhi  Ľe hoku laumńĀlie  Ľa ho Ľo ngaahi fakamo Ľoni;  
\q2 pea  Ľoku ou  Ľofa lahi  Ľaupito ki ai.   
\q1
\v 168 Kuo u fai ki ho Ľo ngaahi akonaki mo ho Ľo ngaahi fakamo Ľoni:  
\q2 he  Ľoku  Ľi ho  Ľao hoku ngaahi  Ľalu Ľanga kotoa pńď.   
\b  
\qa TAU  
\q1
\v 169 ‚ÄĆ ĽE Sihova, tuku ke a Ľu atu  Ľeku tangi  Ľo ofi kiate koe:  
\q2 ke ke foaki mai  Ľae poto  Ľo hangńď ko ho Ľo folofola.   
\q1
\v 170 Tuku ke a Ľu atu  Ľeku lotu tńĀuma Ľu ki ho  Ľao:  
\q2 fakamo Ľui au  Ľo hangńď ko ho Ľo folofola.   
\q1
\v 171 ‚ÄĆ ĽE hua Ľaki  Ľe hoku loungutu  Ľae fakamńĀlŇć,  
\q2  Ľoka ke ka ako ho Ľo ngaahi tu Ľutu Ľuni kiate au.   
\q1
\v 172 ‚ÄĆ ĽE lea  Ľaki  Ľe hoku  Ľelelo ho Ľo folofola:  
\q2 he  Ľoku mńĀ Ľoni Ľoni ho Ľo ngaahi fekau kotoa pńď.   
\q1
\v 173 Ke tokoni au  Ľe ho nima;  
\q2 he kuo u fili ho Ľo ngaahi akonaki.   
\q1
\v 174 ‚ÄĆ ĽE Sihova,  Ľoku ou holi ki ho Ľo fakamo Ľui;  
\q2 pea ko ho Ľo fono ko hoku fiefia Ľanga ia.   
\q1
\v 175 Tuku ke mo Ľui  Ľa hoku laumńĀlie, pea  Ľe fakamńĀlŇć ia kiate koe;  
\q2 pea ke tokoni au  Ľe ho Ľo ngaahi fakamaau.   
\q1
\v 176 Na Ľaku hńď  Ľo hangńď ko e sipi kuo mole;  
\q2 ke ke kumi ho Ľo tamaio Ľeiki;  
\q2 he  Ľoku  Ľikai ngalo  Ľiate au ho Ľo ngaahi fekau.   
\c 120  
\cd \it 1 Ko e lau  Ľa Tevita  Ľi he fai kovi  Ľa Toeki. 3  ĽOku ne valoki ki hono  Ľelelo. 5  ĽOku ne mamahi koe Ľuhi ko  Ľene nonofo mo e angahala.\it*  
\d Ko e Hiva  Ľae  Ľalu hake.  
\q1
\v 1 Na Ľaku tangi kia Sihova  Ľi he Ľeku mamahi,  
\q2 pea na Ľa ne ongo Ľi au.   
\q1
\v 2 ‚ÄĆ ĽE Sihova, fakahaofi hoku laumńĀlie mei he loungutu loi,  
\q2 pea mei he  Ľelelo kńĀkńĀ.   
\q1
\v 3 Ko e hńĀ  Ľe  Ľatu kiate koe?  
\q2 He ko e hńĀ  Ľe fai kiate koe,  Ľa koe ko e  Ľelelo kńĀkńĀ?   
\q1
\v 4 ‚ÄĆ ĽAe ngaahi ngahau mńĀsila  Ľae tangata mńĀlohi,  
\q2 mo e ngaahi malala Ľi afi  Ľoe sunipa.   
\q1
\v 5 ‚ÄĆ ĽOku ou mala Ľia, ko e me Ľa  Ľi he Ľeku  ĽńĀunofo  Ľi Meseki,  
\q2 koe Ľuhi ko  Ľeku nofo  Ľi he ngaahi fale fehikitaki  Ľo Keta!   
\q1
\v 6 Kuo nofo  Ľo fuoloa  Ľa hoku laumńĀlie  
\q2 fakataha mo ia  Ľoku ne fehi Ľa ki he melino.   
\q1
\v 7 ‚ÄĆ ĽOku ou loto ki he melino:  
\q2 ka  Ľi he Ľeku lea  Ľoku nau fie tau.   
\c 121  
\cd \it 1‚Äď8 Ko e MonŇę Ľia  Ľoe kakai angalelei,  Ľakinautolu  Ľoku falala ki he malu Ľi  Ľe he  ĽOtua.\it*  
\d Ko e Hiva  Ľae  Ľalu hake.  
\q1
\v 1 Te u hanga hake hoku mata ki he ngaahi mo Ľunga,  
\q2  Ľaia  Ľoku ha Ľu mei ai hoku tokoni.   
\q1
\v 2 ‚ÄĆ ĽOku ha Ľu hoku tokoni meia Sihova,  
\q2  Ľaia ne ne ngaohi  Ľae langi mo mńĀmani.   
\q1
\v 3 ‚ÄĆ ĽE  Ľikai tuku  Ľe ia ke hiki ho va Ľe:  
\q2 ko ia  Ľoku ne tauhi koe  Ľe  Ľikai tulemohe ia.   
\q1
\v 4 Vakai, ko ia  Ľoku ne tauhi  Ľa  ĽIsileli  
\q2  Ľe  Ľikai te ne tulemohe pe mohe.   
\q1
\v 5 Ko Sihova ko ho tauhi:  
\q2 ko Sihova ko ho fakamalu ia  Ľi ho nima to Ľomata Ľu.   
\q1
\v 6 ‚ÄĆ ĽE  Ľikai taa Ľi koe  Ľe he la ĽńĀ  Ľi he  Ľaho,  
\q2 pe  Ľe he mńĀhina  Ľi he pŇć.   
\q1
\v 7 ‚ÄĆ ĽE fakahaofi koe  Ľe Sihova mei he kovi kotoa pńď:  
\q2 te ne fakamo Ľui ho laumńĀlie.   
\q1
\v 8 ‚ÄĆ ĽE tauhi  Ľe Sihova ho Ľo  Ľalu kitu Ľa mo ho Ľo liu  
\q2 mai mei he  Ľaho ni, pea ta Ľengata.   
\c 122  
\cd \it 1  ĽOku fakahńĀ  Ľe Tevita  Ľene fiefia koe Ľuhi ko e siasi, 6 Pea  Ľoku ne lotu ke fiemńĀlie ia.\it*  
\d Ko e Hiva  Ľa Tevita ma Ľae  Ľalu hake.  
\q1
\v 1 Na Ľaku fiefia  Ľi he Ľenau pehńď mai kiate au,  
\q2 ‚ÄúKe tau Ňć ki he fale  Ľo Sihova.‚ÄĚ   
\q1
\v 2 ‚ÄĆ ĽE tu Ľu homau va Ľe ki loto ĽńĀ  Ľi ho ngaahi matapńĀ,  
\q2  ĽE SelŇęsalema.   
\q1
\v 3 Kuo langa  Ľa SelŇęsalema  Ľo hangńď ko e kolo  Ľoku mńĀ Ľopo Ľopo:   
\q1
\v 4 ‚ÄĆ ĽAia  Ľoku  Ľalu hake ki ai  Ľae ngaahi fa Ľahinga,  
\q2  Ľae ngaahi fa Ľahinga  Ľo Sihova, ki he fakamo Ľoni  Ľa  ĽIsileli,  
\q2 ke  Ľatu  Ľae fakafeta Ľi ki he huafa  Ľo Sihova.   
\q1
\v 5 He  Ľoku fokotu Ľu  Ľi ai  Ľae ngaahi nofo Ľa  Ľoe fakamaau,  
\q2 ko e ngaahi nofo Ľa  Ľoe fale  Ľo Tevita.   
\q1
\v 6 Mou hŇęfia ke melino  Ľa SelŇęsalema:  
\q2 ‚Äú ĽE monŇę Ľia  Ľakinautolu  Ľoku nau  Ľofa kiate koe.   
\q1
\v 7 Ke  Ľai  Ľae melino  Ľi ho ngaahi loto ĽńĀ maka,  
\q2 mo e monŇę Ľia  Ľi ho ngaahi fale faka Ľei Ľeiki.‚ÄĚ   
\q1
\v 8 Pea koe Ľuhi ko hoku ngaahi kńĀinga mo hoku ngaahi kaume Ľa,  
\q2 te u lea ni, ‚ÄúKe  Ľiate koe  Ľae melino.‚ÄĚ   
\q1
\v 9 Koe Ľuhi ko e fale  Ľo Sihova ko hotau  ĽOtua,  
\q2 te u kumi ke ke lelei ai.   
\c 123  
\cd \it 1  ĽOku fakahńĀ  Ľe he kakai angalelei  Ľenau tui ki he  ĽOtua, 3 Pea  Ľoku nau lotu kenau hao mei he manuki.\it*  
\d Ko e Hiva  Ľae  Ľalu hake.  
\q1
\v 1 ‚ÄĆ ĽOku ou hanga hake hoku mata ki ho Ľo  Ľafio,  
\q2  Ľa koe  Ľoku ke  Ľafio  Ľi he ngaahi langi.   
\q1
\v 2 Vakai,  Ľoku hangńď ko e sio  Ľae mata  Ľoe kau tamaio Ľeiki ki he nima  Ľo  Ľenau ngaahi  Ľeiki,  
\q2 pea hangńď ko e mata  Ľo ha kaunanga ki he nima  Ľo  Ľene  Ľeiki fefine;  
\q2  Ľoku tatali pehńď  Ľa homau mata kia Sihova ko homau  ĽOtua,  
\q2 kae Ľoua ke ne  Ľalo Ľofa mai kiate kimautolu.   
\q1
\v 3 ‚ÄĆ ĽE Sihova, ke ke  Ľalo Ľofa mai kiate kimautolu, ke ke  Ľalo Ľofa mai kiate kimautolu:  
\q2 he kuo mau fonu  Ľaupito  Ľi he manukia.   
\q1
\v 4 ‚ÄĆ ĽOku fonu  Ľaupito homau laumńĀlie  Ľi he manuki  Ľanautolu  Ľoku anga fakafiemńĀlie,  
\q2 pea mo e fehi Ľa  Ľae fielahi.   
\c 124  
\cd \it 1‚Äď8  ĽOku fakamńĀlŇć  Ľe he siasi ki ke  ĽOtua koe Ľuhi ko  Ľene fakamo Ľui lahi.\it*  
\d Ko e Hiva  Ľa Tevita ma Ľae  Ľalu hake.  
\q1
\v 1 Kapau na Ľe  Ľikai kau  Ľa Sihova mo kitautolu,  
\q2  Ľoku totonu ke lea ni  Ľa  ĽIsileli;   
\q1
\v 2 ‚ÄúKapau na Ľe  Ľikai kau  Ľa Sihova mo kitautolu,  
\q2  Ľi he tu Ľu hake  Ľae kakai kiate kitautolu:   
\q1
\v 3 Pehńď, kuo nau folo hifo leva  Ľakitautolu,  
\q2  Ľi he tupu  Ľenau  Ľita kiate kitautolu;   
\q1
\v 4 Pehńď, kuo lŇćfia  Ľakitautolu  Ľe he ngaahi vai,  
\q2 kuo tafe  Ľae vaitafe  Ľi he funga  Ľo hotau laumńĀlie:   
\q1
\v 5 Pea  Ľalu  Ľae ngaahi vai  Ľoe laukau  Ľi he funga  Ľo hotau laumńĀlie.‚ÄĚ   
\q1
\v 6 Fakafeta Ľi kia Sihova,  
\q2  Ľaia na Ľe  Ľikai te ne tukuange  Ľakitautolu ko e me Ľakai ki honau nifo.   
\q1
\v 7 Kuo hao hotau laumńĀlie  Ľo hangńď ko e manupuna mei he hele  Ľae tangata tauhele:  
\q2 kuo maumau Ľi  Ľae tauhele, pea kuo tau hao ai.   
\q1
\v 8 Ko hotau tokoni  Ľoku  Ľi he huafa  Ľo Sihova,  Ľaia na Ľa ne ngaohi  Ľae langi mo mńĀmani.   
\c 125  
\cd \it 1 Ko e monŇę Ľia  Ľakinautolu  Ľoku falala ki he  ĽOtua. Ko e hŇęfia ma Ľae angalelei; kae mala Ľia  Ľae angahala.\it*  
\d Ko e Hiva  Ľae  Ľalu hake.  
\q1
\v 1 Ko kinautolu  Ľoku falala kia Sihova tenau tatau mo e mo Ľunga ko Saione,  
\q2  Ľaia  Ľoku  Ľikai si Ľi fa Ľa hiki, kae tu Ľuma Ľu pe  Ľo ta Ľengata.   
\q1
\v 2 Hangńď ko e takatakai  Ľe he ngaahi mo Ľunga  Ľa SelŇęsalema,  
\q2  Ľoku takatakai pehńď  Ľe Sihova  Ľa hono kakai mei he  Ľaho ni  Ľo lauikuonga.   
\q1
\v 3 Koe Ľuhi  Ľe  Ľikai tuku ma Ľu  Ľae tokotoko  Ľoe angahala  Ľi he tofi Ľa  Ľoe angatonu;  
\q2 telia na Ľa mafao atu  Ľe he angatonu honau nima ki he angahala.   
\q1
\v 4 ‚ÄĆ ĽE Sihova, ke ke fai lelei kiate kinautolu  Ľoku angalelei,  
\q2 pea kiate kinautolu  Ľoku angatonu  Ľi honau loto.   
\q1
\v 5 Ka ko kinautolu  Ľoku nau afe ki honau ngaahi hala pikopiko,  
\q2  Ľe tataki atu  Ľakinautolu  Ľe Sihova fakataha mo e kakai fai kovi:  
\q2 ka  Ľe hoko  Ľae melino ki  ĽIsileli.   
\c 126  
\cd \it 1  ĽOku fakamanatu  Ľe he siasi  Ľene toe ha Ľu mei he pŇćpula  Ľoku hŇęfia ia, pea kikite ki he lelei  Ľe hoko ki ai.\it*  
\d Ko e Hiva  Ľae  Ľalu hake.  
\q1
\v 1 ‚ÄĆ ĽI he toe liliu  Ľe Sihova  Ľae pŇćpula  Ľo Saione,  
\q2 na Ľa tau tatau mo kinautolu  Ľoku misi.   
\q1
\v 2 Pea na Ľe toki fakapito  Ľaki hotau ngutu  Ľae kata,  
\q2 mo hotau  Ľelelo  Ľi he hiva:  
\q2 pea na Ľe toki pehńď  Ľe he hiteni, ‚ÄúKuo fai  Ľe Sihova  Ľae ngaahi me Ľa lahi ma Ľanautolu.‚ÄĚ   
\q1
\v 3 Kuo fai  Ľe Sihova  Ľae ngaahi me Ľa lahi ma Ľatautolu;  
\q2 pea  Ľoku tau fiefia ai.   
\q1
\v 4 ‚ÄĆ ĽE Sihova, ke ke toe liliu  Ľemau pŇćpula,  Ľo hangńď ko e ngaahi vaitafe  Ľi he feitu Ľu tonga.   
\q1
\v 5 Ko kinautolu  Ľoku tŇętuu Ľi  Ľi he lo Ľimata te nau tu Ľusi  Ľi he fiefia.   
\q1
\v 6 Ko ia  Ľoku ne  Ľalu atu  Ľo tangi, pea  Ľave  Ľae tenga mahu Ľinga,  
\q2 te ne toe ha Ľu  Ľi he fiefia, mo  Ľomi  Ľene ngaahi Ňę uite fakataha mo ia.   
\c 127  
\cd \it 1 Ko hono  Ľaonga  Ľoe tńĀpuaki  Ľae  ĽOtua. 3 Ko e fńĀnau  Ľae angalelei ko  Ľene foaki ia.\it*  
\d Ko e Hiva  Ľae  Ľalu hake ma Ľa Solomone.  
\q1
\v 1 Kapau  Ľe  Ľikai langa  Ľe Sihova  Ľae fale,  
\q2  Ľoku ta Ľe Ľaonga  Ľae ngńĀue  Ľanautolu  Ľoku nau langa ia:  
\q2 kapau  Ľe  Ľikai tauhi  Ľe Sihova  Ľae kolo,  
\q2  Ľoku ta Ľe Ľaonga  Ľae  ĽńĀ  Ľae tangata le Ľo.   
\q1
\v 2 ‚ÄĆ ĽOku ta Ľe Ľaonga ho Ľomou tu Ľu hake hengihengi pńď,  
\q2 mo nofo pńď  Ľo fuoloa  Ľi he pŇć,  
\q2 ke kai  Ľae mńĀ  Ľoe mamahi:  
\q2 he  Ľoku ne foaki  Ľae mohe ki he Ľene pele.   
\q1
\v 3 Vakai, ko e fńĀnau ko e tofi Ľa meia Sihova:  
\q2 pea ko e fua  Ľoe manńĀva ko  Ľene totongi.   
\q1
\v 4 Hangńď ko e ngaahi ngahau  Ľi he nima  Ľoe tangata mńĀlohi;  
\q2  Ľoku pehńď  Ľae fńĀnau  Ľae talavou.   
\q1
\v 5 ‚ÄĆ ĽOku monŇę Ľia  Ľae tangata  Ľaia  Ľoku fonu  Ľene hŇćfangahau  Ľiate kinautolu:  
\q2  Ľe  Ľikai tenau mńĀ, ka tenau lea ki he ngaahi fili  Ľi he matapńĀ.   
\c 128  
\cd \it 1‚Äď6 Ko e ngaahi tńĀpuaki  Ľoku muimui  Ľiate kinautolu  Ľoku manavahńď ki he  ĽOtua.\it*  
\d Ko e Hiva  Ľae  Ľalu hake.  
\q1
\v 1 ‚ÄĆ ĽOku monŇę Ľia  Ľakinautolu kotoa pńď  Ľoku manavahńď kia Sihova;  
\q2  Ľaia  Ľoku  Ľa Ľeva  Ľi hono ngaahi hala.   
\q1
\v 2 He te ke kai  Ľae ngńĀue  Ľa ho nima:  
\q2 te ke monŇę Ľia, pea  Ľe hoko  Ľae lelei kiate koe.   
\q1
\v 3 ‚ÄĆ ĽE tatau ho uaifi mo e vaine  Ľoku fa Ľa fua  Ľi ho ve Ľe fale:  
\q2  Ľe tatau ho Ľo fńĀnau mo e ngaahi va Ľa  Ľolive  Ľoku kńĀpui ho Ľo keinanga Ľanga.   
\q1
\v 4 Vakai,  Ľe pehńď  Ľae monŇę Ľia  Ľoe tangata  Ľaia  Ľoku ne manavahńď kia Sihova.   
\q1
\v 5 ‚ÄĆ ĽE tńĀpuaki koe  Ľe Sihova mei Saione:  
\q2 pea te ke mamata ki hono lelei  Ľo SelŇęsalema  Ľi he ngaahi  Ľaho kotoa pńď  Ľo ho Ľo mo Ľui.   
\q1
\v 6 ‚ÄĆ ĽIo, te ke mamata ki he fńĀnau  Ľa ho Ľo fńĀnau pea mo e melino  Ľi  ĽIsileli.   
\c 129  
\cd \it 1 Ko e enginaki ke fakamńĀlŇć ki he  ĽOtua koe Ľuhi ko  Ľene fakamo Ľui  Ľa  ĽIsileli  Ľi he Ľenau mamahi lahi. 5  ĽOku mala Ľia  Ľakinautolu  Ľoku fehi Ľa ki he siasi.\it*  
\d Ko e Hiva  Ľae  Ľalu hake.  
\q1
\v 1 ‚ÄĆ ĽOku totonu ke lea ni  Ľa  ĽIsileli,  
\q2 Kuo liunga lahi  Ľenau fakamamahi Ľi au talu  Ľeku kei talavou:   
\q1
\v 2 ‚ÄúKuo liunga lahi  Ľenau fakamamahi Ľi au talu  Ľeku talavou:  
\q2 ka na Ľe  Ľikai tenau mńĀlohi kiate au.   
\q1
\v 3 Na Ľe keli  Ľae kau tangata keli  Ľi hoku tu Ľa:  
\q2 na Ľa nau ngaohi ke lŇćloa  Ľenau ngaahi keli.   
\q1
\v 4 ‚ÄĆ ĽOku angatonu  Ľa Sihova:  
\q2 kuo tu Ľusi  Ľe ia  Ľae ngaahi afo  Ľae kakai angahala.‚ÄĚ   
\q1
\v 5 Tuku ke puputu Ľu pea foki kimui  Ľakinautolu kotoa pńď  Ľoku fehi Ľa ki Saione.   
\q1
\v 6 Tuku kenau tatau mo e mohuku  Ľi he tatńĀ  Ľoe fale,  
\q2  Ľaia  Ľoku mae  Ľi he te Ľeki ai ke lahi ia:   
\q1
\v 7 ‚ÄĆ ĽAia  Ľoku  Ľikai fakapito  Ľaki  Ľe he tangata tu Ľusi  Ľa hono nima;  
\q2 pe ko e fatafata  Ľo ia  Ľoku ne nono Ľo  Ľae ngaahi  ĽŇę mohuku.   
\q1
\v 8 Pea  Ľoku  Ľikai lea  Ľakinautolu  Ľoku  Ľalu  Ľi ai,  
\q2  Ľo pehńď, ‚ÄúKe  Ľiate kimoutolu  Ľae monŇę Ľia meia Sihova:  
\q2  Ľoku mau tńĀpuaki  Ľakimoutolu  Ľi he huafa  Ľo Sihova.‚ÄĚ   
\c 130  
\cd \it 1‚Äď8  ĽOku fakahńĀ  Ľe he tangata tohi saame  Ľene  Ľamanaki  Ľi he Ľene lotu, 5 Mo  Ľene kńĀtaki  Ľi he Ľene  Ľamanaki. 7  ĽOku ne enginaki Ľi  Ľa  ĽIsileli ke nau  Ľamanaki lelei ki he  ĽOtua.\it*  
\d Ko e Hiva  Ľae  Ľalu hake.  
\q1
\v 1 ‚ÄĆ ĽE Sihova, na Ľaku tangi kiate koe mei he ngaahi moana.   
\q1
\v 2 ‚ÄĆ ĽE  ĽEiki, ke ke ongo Ľi hoku le Ľo:  
\q2 fakatokanga Ľi ho fofonga ki he le Ľo  Ľo  Ľeku ngaahi lotu tńĀuma Ľu.   
\q1
\v 3 Kapau te ke faka Ľilonga,  ĽE Sihova,  Ľae ngaahi hia,  
\q2  ĽE  ĽEiki, ko hai  Ľe fa Ľa tu Ľu?   
\q1
\v 4 Ka  Ľoku  Ľiate koe  Ľae fakamolemole,  
\q2 koe Ľuhi ke manavahńď ai kiate koe.   
\q1
\v 5 ‚ÄĆ ĽOku ou tatali kia Sihova,  
\q2  Ľoku tatali  Ľa hoku laumńĀlie,  
\q2 pea  Ľoku ou  Ľamanaki lelei ki he Ľene folofola.   
\q1
\v 6 ‚ÄĆ ĽOku tatali  Ľa hoku laumńĀlie kia Sihova  Ľo lahi hake  Ľiate kinautolu  Ľoku nau le Ľo ki he pongipongi:  
\q2  Ľoku ou pehńď,  Ľo lahi hake  Ľiate kinautolu  Ľoku nau le Ľo ki he pongipongi.   
\q1
\v 7 Ke  Ľamanaki  Ľa  ĽIsileli kia Sihova:  
\q2 he  Ľoku  Ľia Sihova  Ľae  Ľalo Ľofa,  
\q2 pea  Ľoku  Ľiate ia  Ľae huhu Ľi lahi.   
\q1
\v 8 Pea te ne huhu Ľi  Ľa  ĽIsileli mei he Ľene ngaahi hia kotoa pńď.   
\c 131  
\cd \it 1  ĽOku fakahńĀ  Ľe Tevita  Ľene angavaivai, 3 pea  Ľoku enginaki Ľi  Ľa  ĽIsileli kenau  Ľamanaki lelei ki he  ĽOtua.\it*  
\d Ko e Hiva  Ľa Tevita ma Ľae  Ľalu hake.  
\q1
\v 1 ‚ÄĆ ĽE Sihova,  Ľoku  Ľikai fielahi hoku loto, pe fie Ľeiki hoku mata:  
\q2 pea  Ľoku  Ľikai te u kau  Ľi he ngaahi me Ľa lalahi,  
\q2 pe  Ľi he ngaahi me Ľa  Ľoku mńĀ Ľolunga hake  Ľiate au.   
\q1
\v 2 Ko e mo Ľoni kuo u fakafiemńĀlie Ľi mo fakana Ľana Ľa Ľi au,  
\q2  Ľo hangńď ko e tamasi Ľi kuo fakamńĀvae mei he Ľene fa Ľńď:  
\q2  Ľoku tatau hoku laumńĀlie mo e tamasi Ľi kuo fakamńĀvae.   
\q1
\v 3 Tuku ke  Ľamanaki lelei  Ľa  ĽIsileli kia Sihova,  
\q2 mei he  Ľaho ni pea ta Ľengata.   
\c 132  
\cd \it 1  ĽOku fakahńĀ  Ľe Tevita  Ľi he Ľene lotu ki he  ĽOtua  Ľa  Ľene tokanga lahi ki he puha  Ľoe fuakava. 9 Ko  Ľene lotu  Ľi he hiki  Ľae puha  Ľoe fuakava, 11 Mo  Ľene lea  Ľaki  Ľae ngaahi tala Ľofa  Ľae  ĽOtua.\it*  
\d Ko e Hiva  Ľae  Ľalu hake.  
\q1
\v 1 ‚ÄĆ ĽE Sihova, ke ke manatu kia Tevita, mo  Ľene mamahi kotoa pńď:   
\q1
\v 2 ‚ÄĆ ĽA  Ľene fuakava kia Sihova, mo  Ľene lea fakapapau ki he  ĽOtua mńĀlohi  Ľa Sńďkope;   
\q1
\v 3 ‚ÄúKo e mo Ľoni  Ľe  Ľikai te u  Ľalu ki hoku fale nofo Ľanga,  
\q2 pe  Ľalu hake ki hoku mohenga;   
\q1
\v 4 ‚ÄĆ ĽE  Ľikai te u tuku  Ľae mohe ki hoku mata,  
\q2 pe ko e tulemohe ki hoku laumata,   
\q1
\v 5 Kae Ľoua ke u  Ľilo ha potu mo Ľo Sihova, ko e  Ľafio Ľanga ki he  ĽOtua mńĀlohi  Ľo Sńďkope.‚ÄĚ   
\q1
\v 6 Vakai, na Ľa tau fanongo ki ai  Ľi  ĽEfalata:  
\q2 pea na Ľa tau  Ľilo ia  Ľi he ngaahi ngoue  Ľoe vao.   
\q1
\v 7 ‚ÄúTe tau hŇę ki hono ngaahi fale fehikitaki:  
\q2 te tau lotu  Ľi hono tu Ľunga va Ľe.‚ÄĚ   
\q1
\v 8 Tu Ľu hake,  ĽE Sihova, ki ho mńĀlŇćlŇć Ľanga;  
\q2  Ľa koe, mo e puha  Ľoe fuakava  Ľo ho mńĀlohi.   
\q1
\v 9 Ke kofu Ľaki  Ľe ho Ľo kau taula Ľeiki  Ľae angatonu;  
\q2 pea ke kalanga  Ľi he fiefia  Ľa ho Ľo kakai mńĀ Ľoni Ľoni.   
\q1
\v 10 Koe Ľuhi ko ho Ľo tamaio Ľeiki ko Tevita,  
\q2  Ľoua na Ľa ke fakatafoki  Ľae mata  Ľo ho Ľo pani.   
\q1
\v 11 Kuo fuakava  Ľa Sihova  Ľi he mo Ľoni kia Tevita;  
\q2  Ľe  Ľikai te ne liliu mei ai;  
\q2 ‚ÄúTe u fokotu Ľu ki ho nofo Ľa  Ľae fua  Ľo ho sino.   
\q1
\v 12 Kapau  Ľe fai  Ľe ho Ľo fńĀnau ki he Ľeku fuakava  
\q2 mo  Ľeku fakamo Ľoni  Ľaia te u ako kiate kinautolu,  
\q2  Ľe nofo foki  Ľenau fńĀnau  Ľi ho nofo Ľa faka Ľei Ľeiki  Ľo lauikuonga.‚ÄĚ   
\q1
\v 13 He kuo fili  Ľe Sihova  Ľa Saione;  
\q2 kuo ne finangalo ki ai ko hono  Ľafio Ľanga.   
\q1
\v 14 ‚ÄúKo hoku mńĀlŇćlŇć Ľanga eni  Ľo ta Ľengata:  
\q2 te u nofo  Ľi heni; he na Ľaku finangalo ki ai.   
\q1
\v 15 Ko e mo Ľoni te u tńĀpuaki lahi hono me Ľakai:  
\q2 te u fakamńĀkona  Ľa hono kau masiva  Ľaki  Ľae mńĀ.   
\q1
\v 16 Te u fakakofu foki  Ľene kau taula Ľeiki  Ľaki  Ľae fakamo Ľui:  
\q2 pea ko  Ľene kau mńĀ Ľoni Ľoni tenau kalanga  Ľo le Ľo lahi  Ľi he fiefia.   
\q1
\v 17 Te u ngaohi ke moto ai  Ľae nifo  Ľo Tevita:  
\q2 kuo u tu Ľutu Ľuni  Ľae maama  Ľa  Ľeku pani.   
\q1
\v 18 Te u fakakofu Ľaki hono ngaahi fili  Ľae mńĀ:  
\q2 ka  Ľe ma Ľui Ľui  Ľa hono tatńĀ  Ľiate ia.‚ÄĚ   
\c 133  
\cd \it 1‚Äď3 Ko hono  Ľaonga  Ľoe feohi  Ľoe kakai mńĀ Ľoni Ľoni.\it*  
\d Ko e Hiva  Ľa Tevita ma Ľae  Ľalu hake.  
\q1
\v 1 Vakai ki hono lelei pea mo hono fakafiemńĀlie,  
\q2  Ľoe nofo fakataha  Ľae kńĀinga  Ľi he fe Ľofo Ľofani!   
\q1
\v 2 ‚ÄĆ ĽOku tatau ia mo e lolo mahu Ľinga ki he  Ľulu,  
\q2  Ľaia na Ľe tafe hifo ki he halakava,  
\q2  Ľio, ko e halakava  Ľo  ĽElone:  
\q2 pea  Ľalu hifo ki he kapa  Ľo hono ngaahi kofu;   
\q1
\v 3 ‚ÄĆ ĽOku hangńď ko e hahau  Ľo Heamoni,  
\q2 pea hangńď ko e hahau na Ľe tŇć ki he ngaahi mo Ľunga  Ľo Saione,  
\q2 he na Ľe fekau  Ľi ai  Ľe Sihova  Ľae monŇę Ľia,  
\q2  Ľio, ko e mo Ľui ta Ľengata.   
\c 134  
\cd \it 1‚Äď4 Ko e enginaki ke fakamńĀlŇć ki he  ĽOtua.\it*  
\d Ko e Hiva  Ľae  Ľalu hake.  
\q1
\v 1 Ko eni, mou fakafeta Ľi kia Sihova,  
\q2  Ľakimoutolu kotoa pńď ko e kau tamaio Ľeiki  Ľa Sihova,  
\q2  Ľoku mou tu Ľu  Ľi he pŇć  Ľi he fale  Ľo Sihova.   
\q1
\v 2 Hiki hake homou nima  Ľi he faletapu,  
\q2 mou fakafeta Ľi kia Sihova.   
\q1
\v 3 Ke tńĀpuaki koe mei Saione  Ľe Sihova;  
\q2  Ľaia na Ľa ne ngaohi  Ľae langi mo mńĀmani.   
\c 135  
\cd \it 1 Ko e enginaki ke fakamńĀlŇć ki he  ĽOtua koe Ľuhi ko  Ľene  Ľalo Ľofa, 5 Mo  Ľene mńĀfimafi, 8 pea mo  Ľene ngaahi fakamaau. 15 Ko e me Ľa va Ľinga pńď  Ľae ngaahi tamapua. 19 Ko e me Ľa enginaki ke fakafeta Ľi ki he  ĽOtua.\it*  
\q1
\v 1 Mou fakamńĀlŇć kia Sihova.  
\q2 Mou fakamńĀlŇć ki he huafa  Ľo Sihova;  
\q2 fakamńĀlŇć kiate ia,  Ľakimoutolu ko e kau tamaio Ľeiki  Ľa Sihova.   
\q1
\v 2 ‚ÄĆ ĽAkimoutolu  Ľoku tu Ľu  Ľi he fale  Ľo Sihova,  Ľi he ngaahi loto ĽńĀ  Ľoe fale  Ľo hotau  ĽOtua,   
\q1
\v 3 FakamńĀlŇć kia Sihova; he  Ľoku angalelei  Ľa Sihova:  
\q2 hiva fakamńĀlŇć ki hono huafa; he  Ľoku mńĀlie ia.   
\q1
\v 4 He kuo fili  Ľe Sihova  Ľa Sńďkope ma Ľana,  
\q2 mo  ĽIsileli ko hono tofi Ľa  Ľo Ľona.   
\q1
\v 5 He  Ľoku ou  Ľilo  Ľoku lahi  Ľa Sihova,  
\q2 pea  Ľoku mńĀ Ľolunga hake hotau  ĽEiki  Ľi he ngaahi  Ľotua kotoa pńď.   
\q1
\v 6 Ko e me Ľa kotoa pńď na Ľe finangalo ki ai  Ľa Sihova, ko ia na Ľa ne fai  Ľi he langi,  
\q2 mo mńĀmani,  Ľi he ngaahi tahi, mo e ngaahi potu loloto kotoa pńď.   
\q1
\v 7 ‚ÄĆ ĽOku pule  Ľe ia ke  Ľalu hake  Ľae kakapu mei he ngaahi ngata Ľanga  Ľo mńĀmani,  
\q2  Ľoku ne ngaohi  Ľae ngaahi  Ľuhila mo e  Ľuha  Ľoku  Ľomi,  
\q2  Ľe ia  Ľae matangi mei hono ngaahi feleoko.   
\q1
\v 8 Ko ia ia na Ľe taa Ľi  Ľae  Ľuluaki fńĀnau  Ľo  ĽIsipite,  
\q2  Ľae tangata mo e manu.   
\q1
\v 9 Mo ne fekau atu  Ľae ngaahi faka Ľilonga,  
\q2 mo e ngaahi me Ľa fakaofo  Ľi he lotolotonga  Ľo Ľou,  
\q2  ĽE  ĽIsipite, kia Felo, pea mo  Ľene kau tamaio Ľeiki kotoa pńď.   
\q1
\v 10 Ko ia na Ľe taa Ľi  Ľae ngaahi pule Ľanga lahi,  
\q2 mo tńĀmate Ľi  Ľae ngaahi tu Ľi mńĀlohi;   
\q1
\v 11 Ko Sihoni ko e tu Ľi  Ľoe kau  ĽAmoli,  
\q2 mo Oki ko e tu Ľi  Ľo Pesani,  
\q2 mo e ngaahi pule Ľanga kotoa pńď  Ľo Kńďnani:   
\q1
\v 12 Pea na Ľe foaki honau fonua ko e tofi Ľa,  
\q2 ko e tofi Ľa ki  ĽIsileli ko hono kakai.   
\q1
\v 13 ‚ÄĆ ĽE Sihova,  Ľoku tolonga  Ľo ta Ľengata ho huafa;  
\q2 mo ho fakamanatu,  
\q2  ĽE Sihova, ki he ngaahi to Ľutangata kotoa pńď.   
\q1
\v 14 Koe Ľuhi  Ľe fakamaau  Ľe Sihova hono kakai,  
\q2 pea  Ľe lolou ia koe Ľuhi ko  Ľene kau tamaio Ľeiki.   
\q1
\v 15 Ko e ngaahi tamapua  Ľoe hiteni ko e siliva mo e koula,  
\q2 ko e ngńĀue  Ľae nima  Ľoe tangata.   
\q1
\v 16 ‚ÄĆ ĽOku ai honau ngutu, ka  Ľoku  Ľikai tenau lea;  
\q2  Ľoku nau ma Ľu  Ľae mata, ka  Ľoku  Ľikai tenau mamata;   
\q1
\v 17 ‚ÄĆ ĽOku nau ma Ľu  Ľae telinga,  
\q2 ka  Ľoku  Ľikai tenau fanongo;  
\q2 pea  Ľoku  Ľikai ha mńĀnava  Ľi honau ngutu.   
\q1
\v 18 Ko kinautolu  Ľoku ngaohi  Ľakinautolu  Ľoku nau tatau mo kinautolu:  
\q2 pea  Ľoku pehńď pe  Ľakinautolu  Ľoku falala ki ai.   
\q1
\v 19 ‚ÄĆ ĽE fale  Ľo  ĽIsileli, ke ke fakafeta Ľi kia Sihova:  
\q2  ĽE fale  Ľo  ĽElone, ke ke fakafeta Ľi kia Sihova:   
\q1
\v 20 ‚ÄĆ ĽE fale  Ľo Livai, ke ke fakafeta Ľi kia Sihova:  
\q2  Ľakimoutolu  Ľoku manavahńď kia Sihova, mou fakafeta Ľi kia Sihova.   
\q1
\v 21 Mou fakafeta Ľi kia Sihova mei Saione,  
\q2  Ľaia  Ľoku  Ľafio  Ľi SelŇęsalema.  
\q2 Mou fakamńĀlŇć kia Sihova.   
\c 136  
\cd \it 1‚Äď26 Ko e enginaki ke  Ľalu  Ľae fakafeta Ľi ki he  ĽOtua koe Ľuhi ko  Ľene ngaahi  Ľalo Ľofa.\it*  
\q1
\v 1 Mou  Ľatu  Ľae fakafeta Ľi kia Sihova he  Ľoku angalelei ia:  
\q2 koe Ľuhi  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 2 Mou  Ľatu  Ľae fakafeta Ľi ki he  ĽOtua  Ľoe ngaahi  Ľotua:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 3 Mou  Ľatu  Ľae fakafeta Ľi ki he  ĽEiki  Ľoe ngaahi  Ľeiki:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 4 Kiate ia  Ľaia tokotaha pe  Ľoku fai  Ľae ngaahi me Ľa fakaofo lahi:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 5 Kiate ia  Ľaia na Ľe ngaohi  Ľi he poto  Ľae ngaahi langi:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 6 Kiate ia  Ľaia na Ľe folahi  Ľa mńĀmani  Ľi  Ľolunga  Ľi he ngaahi vai:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 7 Kiate ia  Ľaia na Ľe ngaohi  Ľae ngaahi maama lahi he  Ľoku tolonga,  
\q2  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa   
\q1
\v 8 Ko e la ĽńĀ ke pule  Ľi he  Ľaho:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa:   
\q1
\v 9 Ko e mńĀhina mo e ngaahi fetu Ľu ke pule  Ľi he pŇć:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 10 Kiate ia  Ľaia na Ľe taa Ľi  Ľa  ĽIsipite  Ľi he Ľenau  Ľuluaki fńĀnau:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa   
\q1
\v 11 Mo ne  Ľomi  Ľa  ĽIsileli meiate kinautolu:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa:   
\q1
\v 12 ‚ÄĆ ĽAki  Ľae nima mńĀlohi, mo e nima kuo mafao atu:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 13 Kiate ia na Ľe vahe Ľi ke vaeua  Ľae Tahi Kulokula:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa:   
\q1
\v 14 Pea ne pule ke  Ľalu  Ľa  ĽIsileli  Ľi hono vaha Ľa:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa   
\q1
\v 15 Ka na Ľe tulaki  Ľa Felo mo  Ľene kautau  Ľi he Tahi Kulokula:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 16 Kiate ia  Ľaia na Ľe tataki hono kakai  Ľi he toafa:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 17 Kiate ia  Ľaia na Ľe taa Ľi  Ľae ngaahi tu Ľi lahi:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 18 Pea tńĀmate Ľi  Ľae ngaahi tu Ľi na Ľe ongoongo:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa   
\q1
\v 19 Ko Sihoni ko e tu Ľi  Ľoe kau  ĽAmoli:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa:   
\q1
\v 20 Mo Oki ko e tu Ľi  Ľo Pesani:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa   
\q1
\v 21 Pea ne foaki honau fonua ko e tofi Ľa:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa:   
\q1
\v 22 Ko e tofi Ľa kia  ĽIsileli ko  Ľene tamaio Ľeiki:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 23 ‚ÄĆ ĽAia na Ľe manatu kiate kitautolu  Ľi he Ľetau masiva:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa:   
\q1
\v 24 Pea ne huhu Ľi  Ľakitautolu mei hotau ngaahi fili:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 25 ‚ÄĆ ĽOku ne foaki  Ľae me Ľakai ki he kakano kotoa pńď:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 26 Mou  Ľatu  Ľae fakafeta Ľi ki he  ĽOtua  Ľoe langi:  
\q2 he  Ľoku tolonga  Ľo ta Ľengata  Ľa  Ľene  Ľalo Ľofa.   
\c 137  
\cd \it 1 Ko e loto ma Ľu  Ľae kakai Siu  Ľi he Ľenau pŇćpula. 7 Ko e fakamala Ľia  Ľa  ĽItomi mo Papilone  Ľe he palŇćfita.\it*  
\q1
\v 1 Na Ľa mau nofo ki lalo  Ľi he ve Ľe vaitafe  Ľo Papilone,  
\q2  Ľio, na Ľa mau tangi  Ľi he Ľemau manatu ki Saione.   
\q1
\v 2 Na Ľa mau tautau  Ľemau ngaahi ha Ľape,  
\q2  Ľi he ngaahi uilou  Ľi he lotolotonga  Ľo ia.   
\q1
\v 3 He na Ľe fekau Ľi ai  Ľekinautolu na Ľa nau fakapŇćpula Ľi  Ľakimautolu ke mau hiva;  
\q2 pea ko kinautolu na Ľe faka Ľosi Ľosi  Ľakimautolu na Ľa nau fekau ke mau fiefia,  
\q2  Ľonau pehńď, ‚ÄúHiva mai kiate kimautolu  Ľi he ngaahi hiva  Ľo Saione.‚ÄĚ   
\q1
\v 4 ‚ÄĆ ĽE fńďfńď  Ľemau hiva  Ľaki  Ľae hiva  Ľa Sihova  Ľi he fonua  Ľoe muli?   
\q1
\v 5 Kapau te u fakangalongalo Ľi koe,  ĽE SelŇęsalema,  
\q2 tuku ke ngalo  Ľi hoku nima to Ľomata Ľu hono faiva.   
\q1
\v 6 Kapau  Ľe  Ľikai te u manatu kiate koe, tuku ke pikitai  Ľa hoku  Ľelelo ki hoku  Ľao Ľingutu;  
\q2  Ľo kapau  Ľe  Ľikai te u hiki mńĀ Ľolunga hake  Ľa SelŇęsalema  Ľi hoku fungani fiefia Ľanga.   
\q1
\v 7 Manatu,  ĽE Sihova, ki he fńĀnau  Ľa  ĽItomi,  
\q2  Ľi he  Ľaho  Ľo SelŇęsalema;  
\q2 na Ľa nau pehńď, ‚ÄúFaka Ľauha ia!  
\q2 Faka Ľauha ia,  Ľo a Ľu ki hono tu Ľunga!‚ÄĚ   
\q1
\v 8 ‚ÄĆ ĽE  Ľofefine  Ľo Papilone,  Ľe faka Ľauha koe;  
\q2  Ľe monŇę Ľia ia,  Ľaia te ne totongi kiate koe,  
\q2  Ľo hangńď ko ho Ľo fai kiate kimautolu.   
\q1
\v 9 ‚ÄĆ ĽE monŇę Ľia ia,  
\q2  Ľaia te ne to Ľo  Ľo laiki ho Ľo fńĀnau iiki ki he maka.   
\c 138  
\cd \it 1  ĽOku fakafeta Ľi  Ľe Tevita ki he  ĽOtua koe Ľuhi ko e mo Ľoni  Ľo  Ľene folofola. 4  ĽOku ne kikite  Ľo fakamńĀlŇć ki he  ĽOtua  Ľae ngaahi tu Ľi  Ľa mńĀmani. 7  ĽOku fakahńĀ  Ľene tui ki he  ĽOtua.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 Te u fakamńĀlŇć kiate koe  Ľaki hoku loto kotoa pńď:  
\q2  Ľi he  Ľao  Ľoe ngaahi  Ľotua te u hiva fakamńĀlŇć kiate koe.   
\q1
\v 2 Te u lotu  Ľo hanga atu ki ho faletapu mńĀ Ľoni Ľoni,  
\q2 mo fakamńĀlŇć ki ho huafa koe Ľuhi ko ho Ľo  Ľalo Ľofa mo ho Ľo mo Ľoni:  
\q2 he kuo ke hiki ke mńĀ Ľolunga hake ho Ľo folofola  Ľi ho huafa kotoa pńď.   
\q1
\v 3 ‚ÄĆ ĽI he  Ľaho ne u tangi ai na Ľa ke talia au,  
\q2 mo fakamńĀlohi  Ľaki au  Ľae mńĀlohi  Ľi hoku laumńĀlie.   
\q1
\v 4 ‚ÄĆ ĽE Sihova,  Ľe fakamńĀlŇć kiate koe  Ľae ngaahi tu Ľi kotoa pńď  Ľo mńĀmani,  
\q2  Ľoka nau ka fanongo ki he ngaahi folofola  Ľo ho fofonga.   
\q1
\v 5 ‚ÄĆ ĽIo, tenau hiva  Ľi he ngaahi hala  Ľo Sihova:  
\q2 he  Ľoku lahi  Ľae nńĀunau  Ľo Sihova.   
\q1
\v 6 Ko e mo Ľoni  Ľoku mńĀ Ľolunga  Ľa Sihova, ka  Ľoku  Ľofa ia ki he angavaivai:  
\q2 ka  Ľoku  Ľilo  Ľe ia  Ľae laukau ki he mama Ľo.   
\q1
\v 7 Neongo  Ľeku  Ľeve Ľeva  Ľi he lotolotonga  Ľoe mamahi, te ke fakaakeake au:  
\q2 te ke mafao atu ho nima ke ta Ľofi ki he  Ľita  Ľa hoku ngaahi fili,  
\q2 pea ko ho nima to Ľomata Ľu te ne fakamo Ľui au.   
\q1
\v 8 ‚ÄĆ ĽE fakahaohaoa  Ľe Sihova  Ľaia  Ľoku kau kiate au:  
\q2 ko ho Ľo  Ľalo Ľofa,  ĽE Sihova  Ľoku tolonga  Ľo ta Ľengata:  
\q2  Ľoua na Ľa ke li Ľaki  Ľae ngaahi ngńĀue  Ľa ho nima  Ľo Ľou.   
\c 139  
\cd \it 1‚Äď24  ĽOku fakamńĀlŇć  Ľa Tevita ki he  ĽOtua koe Ľuhi ko  Ľene  Ľafio Ľi  Ľae me Ľa kotoa pńď, 17 mo  Ľene ngaahi  Ľalo Ľofa lahi. 19 Ko  Ľene fehi Ľa ki he angahala. 23  ĽOku ne kole ke ne mńĀ Ľoni Ľoni.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE Sihova, na Ľa ke  Ľahi Ľahi Ľi au,  
\q2 pea kuo ke  Ľilo Ľi au.   
\q1
\v 2 ‚ÄĆ ĽOku ke  Ľilo Ľi  Ľeku nofo hifo mo  Ľeku tu Ľu hake,  
\q2  Ľoku ke  Ľilo Ľi  Ľeku ngaahi mahalo  Ľoku kei mama Ľo.   
\q1
\v 3 ‚ÄĆ ĽOku ke  ĽńĀ Ľi hoku hala mo hoku tokoto Ľanga,  
\q2 pea  Ľoku ke  Ľilo Ľi hoku hala kotoa pńď.   
\q1
\v 4 He  Ľoku  Ľikai ha lea  Ľi hoku  Ľelelo,  
\q2 ka ko koe,  ĽE Sihova,  Ľoku ke  Ľilo Ľi kotoa pńď.   
\q1
\v 5 Na Ľa ke kńĀpui au  Ľi hoku tu Ľa mo hoku  Ľao,  
\q2  Ľo ke hilifaki ho nima kiate au.   
\q1
\v 6 Ko e  Ľilo pehńď  Ľoku fakaofo lahi kiate au;  
\q2  Ľoku mńĀ Ľolunga ia,  
\q2  Ľoku  Ľikai te u fa Ľa lava Ľi ia.   
\q1
\v 7 Te u  Ľalu ki fńď mei ho LaumńĀlie?  
\q2 Pe te u hola ki fńď mei ho  Ľao?   
\q1
\v 8 Kapau te u  Ľalu hake ki he loto langi,  Ľoku ke  Ľi ai:  
\q2 kapau te u ngaohi hoku mohenga  Ľi heli,  
\q2 vakai,  Ľoku ke  Ľi ai.   
\q1
\v 9 Kapau te u to Ľo mai  Ľae ngaahi kapakau  Ľoe pongipongi,  
\q2 pea nofo  Ľi he ngaahi ngata Ľanga  Ľoe tahi;   
\q1
\v 10 ‚ÄĆ ĽE tataki foki au  Ľe ho nima  Ľi ai,  
\q2 pea ko ho nima to Ľomata Ľu te ne puke au.   
\q1
\v 11 Kapau te u pehńď, Ko e mo Ľoni  Ľe  Ľufi Ľufi au  Ľe he po Ľuli;  
\q2  Ľe hoko  Ľae pŇć foki ko e maama  Ľo takatakai  Ľiate au.   
\q1
\v 12 ‚ÄĆ ĽIo,  Ľoku  Ľikai fakafufŇę meiate koe  Ľe he po Ľuli,  
\q2 ka  Ľoku malama  Ľae pŇć  Ľo hangńď ko e  Ľaho:  
\q2 ko e po Ľuli mo e maama  Ľoku na tatau pe kiate koe.   
\q1
\v 13 He kuo ke ma Ľu hoku kongaloto:  
\q2 na Ľa ke  Ľufi Ľufi au  Ľi he manńĀva  Ľo  Ľeku fa Ľńď.   
\q1
\v 14 Te u fakamńĀlŇć kiate koe;  
\q2 he  Ľoku fakamanavahńď mo fakaofo hoku ngaohi:  
\q2  Ľoku fakaofo ho Ľo ngaahi ngńĀue;  
\q2 pea  Ľoku  Ľilo pau ki ai  Ľe hoku laumńĀlie.   
\q1
\v 15 Na Ľe  Ľikai fufŇę  Ľa hoku sino meiate koe,  
\q2  Ľi he ngaohi au  Ľi he lilo,  
\q2 mo teuteu lelei au  Ľi he ngaahi potu mńĀ Ľulalo  Ľoe fonua.   
\q1
\v 16 Na Ľe  Ľafio ho fofonga ki hoku sino  Ľoku te Ľeki ai faka Ľosi;  
\q2 pea na Ľe tohi  Ľi ho Ľo tohi hoku ngaahi kupu Ľi sino kotoa pńď,  
\q2  Ľaia na Ľe fakatupu fakaholo,  
\q2  Ľi he te Ľeki ai ha kupu  Ľe taha.   
\q1
\v 17 ‚ÄĆ ĽE  ĽOtua, hono  Ľikai mahu Ľinga  Ľa ho Ľo ngaahi fakakaukau kiate au!  
\q2  ĽOku fńďfńď nai hono lahi  Ľo ia!   
\q1
\v 18 Kapau te u lau ia,  Ľoku lahi hake hono lau  Ľi he  Ľone Ľone:  
\q2  Ľo kau ka  ĽńĀ hake  Ľoku ou kei  Ľiate koe.   
\q1
\v 19 ‚ÄĆ ĽE  ĽOtua, ko e mo Ľoni te ke tńĀmate Ľi  Ľae angahala:  
\q2 ko ia mou  Ľalu  Ľiate au,  Ľakimoutolu  Ľae kau tangata pani toto.   
\q1
\v 20 He  Ľoku nau lea kovi  Ľi he angatu Ľu kiate koe,  
\q2 pea ko ho ngaahi fili  Ľoku nau takuanoa \add ho huafa\add*.   
\q1
\v 21 ‚ÄĆ ĽE Sihova,  Ľikai  Ľoku ou fehi Ľa kiate kinautolu  Ľoku nau fehi Ľa kiate koe?  
\q2 Pea  Ľikai  Ľoku ou mamahi  Ľiate kinautolu  Ľoku nau tu Ľu hake  Ľo angatu Ľu kiate koe?   
\q1
\v 22 ‚ÄĆ ĽOku ou fehi Ľa kiate kinautolu  Ľaki  Ľae fehi Ľa  Ľaupito:  
\q2  Ľoku ou lau  Ľakinautolu ko hoku ngaahi fili.   
\q1
\v 23 ‚ÄĆ ĽE  ĽOtua,  Ľafio Ľi au, pea ke  Ľilo Ľi hoku loto:  
\q2  Ľahi Ľahi Ľi au, mo ke  Ľilo Ľi  Ľeku ngaahi mahalo:   
\q1
\v 24 Pea ke vakai pe  Ľoku ai ha hala kovi  Ľiate au,  
\q2 pea ke tataki au  Ľi he hala ta Ľengata.   
\c 140  
\cd \it 1  ĽOku lotu  Ľa Tevita ke ne hao meia Saula mo Toeki, 8 Pea ke fakahoko  Ľe he  ĽEiki  Ľae totongi ki ai. 12  ĽOku ne fakafiemńĀlie Ľi hono loto  Ľi he Ľene tui ki he  ĽOtua.\it*  
\d Ki he Takimu Ľa, ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE Sihova, fakamo Ľui au mei he tangata angakovi:  
\q2 fakamo Ľui au mei he tangata fakamńĀlohi;   
\q1
\v 2 ‚ÄĆ ĽAia  Ľoku mahalo kovi  Ľi honau loto;  
\q2  Ľoku nau fakataha ma Ľuaipńď ke tau.   
\q1
\v 3 Kuo nau fakamńĀsila honau  Ľelelo  Ľo hangńď ko e ngata;  
\q2  Ľoku  Ľai  Ľae kona  Ľoe ngata  Ľi honau lalo loungutu. \qs Sila.\qs*   
\q1
\v 4 Fakahaofi au,  ĽE Sihova, mei he nima  Ľoe angahala;  
\q2 fakamo Ľui au mei he tangata fakamńĀlohi,  
\q2  Ľaia kuo ne fakakaukau ke tulaki hifo hoku va Ľe.   
\q1
\v 5 Kuo tau fufŇę  Ľe he laukau  Ľae tauhele kiate au, mo e ngaahi afo;  
\q2 kuo nau  Ľa Ľau  Ľae kupenga  Ľi he ve Ľe hala;  
\q2 kuo nau teuteu  Ľae ngaahi hele kiate au. \qs Sila.\qs*   
\q1
\v 6 Na Ľaku pehńď kia Sihova, ‚ÄúKo koe ko hoku  ĽOtua:‚ÄĚ  
\q2  ĽE Sihova, ke ke ongo Ľi  Ľae le Ľo  Ľo  Ľeku ngaahi lotu tńĀuma Ľu.   
\q1
\v 7 ‚ÄĆ ĽE Sihova ko e  ĽEiki, ko e mńĀlohi  Ľo  Ľeku fakamo Ľui,  
\q2 kuo ke malu Ľi hoku  Ľulu  Ľi he  Ľaho  Ľoe tau.   
\q1
\v 8 ‚ÄĆ ĽE Sihova,  Ľoua na Ľa ke fai ki he ngaahi holi  Ľae angahala:  
\q2  Ľoua na Ľa ke tokoni  Ľene fakakaukau kovi, telia na Ľa nau hiki hake  Ľakinautolu. \qs Sila.\qs*   
\q1
\v 9 Ka ko e  Ľulu  Ľokinautolu  Ľoku nau kńĀpui au,  
\q2 tuku ke  Ľufi Ľufi  Ľaki  Ľakinautolu  Ľae kovi  Ľo honau loungutu.   
\q1
\v 10 Ke tŇć kiate kinautolu  Ľae malala Ľi afi  Ľoku vela: tuku ke lńę  Ľakinautolu ki he afi;  
\q2 ki he ngaahi luo tau mama Ľo, koe Ľuhi ke  Ľoua na Ľa nau toetu Ľu hake.   
\q1
\v 11 ‚ÄĆ ĽOua na Ľa tuku ha tangata lea kovi ke tu Ľuma Ľu  Ľi mńĀmani:  
\q2  Ľe tuli  Ľe he kovi  Ľae tangata fakamńĀlohi ke tulaki ia.   
\q1
\v 12 ‚ÄĆ ĽOku ou  Ľilo  Ľe fakamaau  Ľe Sihova  Ľae me Ľa  Ľae mamahi,  
\q2 mo e  Ľinasi totonu  Ľoe masiva.   
\q1
\v 13 Ko e mo Ľoni  Ľe  Ľatu  Ľae fakafeta Ľi  Ľe he mńĀ Ľoni Ľoni ki ho huafa:  
\q2  Ľe nofo  Ľae angatonu  Ľi ho  Ľao.   
\c 141  
\cd \it 1 Ko e lotu  Ľa Tevita ke ma Ľu  Ľene kole  Ľe he  ĽOtua, 3 Ke mńĀ Ľoni Ľoni hono loto, 7 Pea ke hao  Ľa  Ľene mo Ľui mei he ngaahi tauhele.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE Sihova,  Ľoku ou tangi kiate koe:  
\q2 ke ke ha Ľu vave kiate au;  
\q2 fakafanongo ki hoku le Ľo,  Ľo kau ka tangi kiate koe.   
\q1
\v 2 Ke a Ľu atu  Ľeku lotu ki ho  Ľao  Ľo hangńď ko e me Ľa namu kakala;  
\q2 mo e hiki hake  Ľo hoku nima  Ľo hangńď ko e feilaulau  Ľoe efiafi.   
\q1
\v 3 ‚ÄĆ ĽE Sihova, fakanofo  Ľae le Ľo ki hoku ngutu;  
\q2 tauhi  Ľae matapńĀ  Ľo hoku loungutu.   
\q1
\v 4 ‚ÄĆ ĽOua na Ľa ue Ľi hoku loto ki ha me Ľa kovi  Ľe taha,  
\q2 ke fai  Ľae ngaahi ngńĀue kovi mo e kau tangata  Ľoku fai kovi:  
\q2 pea  Ľoua na Ľa tuku ke u kai  Ľi he Ľenau ngaahi me Ľa lelei.   
\q1
\v 5 Ke taa Ľi au  Ľe he angatonu; pea ko e  Ľofa ia:  
\q2 pea tuku ke ne valoki Ľi au; ko e lolo lelei ia,  Ľaia  Ľe  Ľikai foa ai hoku  Ľulu:  
\q2 he ko  Ľeku lotu foki  Ľe fai ia  Ľi he Ľenau ngaahi mamahi.   
\q1
\v 6 ‚ÄĆ ĽOka hinga  Ľenau kau fakamaau  Ľi he ngaahi potu tokatńĀmaki,  
\q2 tenau fanongo ki he Ľeku ngaahi lea; he  Ľoku melie ia.   
\q1
\v 7 Kuo movetevete hotau ngaahi hui  Ľi he ngutu  Ľoe fa Ľitoka,  
\q2  Ľo hangńď ko e taa Ľi  Ľo mafahi  Ľe he taha  Ľae  Ľakau  Ľi he funga  Ľoe fonua.   
\q1
\v 8 Ka  Ľoku hanga hoku mata kiate koe,  
\q2  ĽE Sihova ko e  ĽEiki:  Ľoku ou falala kiate koe;  
\q2  Ľoua na Ľa ke si Ľaki hoku laumńĀlie.   
\q1
\v 9 Ta Ľofi au mei he ngaahi tauhele kuo nau  Ľai kiate au,  
\q2 mo e ngaahi me Ľa fakau Ľu,  Ľae kakai fai kovi.   
\q1
\v 10 Tuku ke tŇć  Ľae angahala ki he ngaahi kupenga  Ľanautolu,  
\q2  Ľi he lolotonga  Ľo  Ľeku hao mei ai.   
\c 142  
\cd \it 1‚Äď7  ĽOku fakahńĀ  Ľe Tevita  Ľoku fiemńĀlie ia  Ľi he Ľene mamahi  Ľi he Ľene lotu ki he  ĽOtua.\it*  
\d Ko e Saame akonaki  Ľa Tevita. Ko  Ľene Lotu  Ľi he  Ľana.  
\q1
\v 1 Na Ľaku tangi kia Sihova  Ľaki hoku le Ľo;  
\q2 ne u kole tńĀuma Ľu kia Sihova  Ľaki hoku le Ľo.   
\q1
\v 2 Na Ľaku lilingi  Ľeku fakakaukau  Ľi hono  Ľao;  
\q2 ne u fakahńĀ  Ľi hono  Ľao  Ľeku mamahi.   
\q1
\v 3 ‚ÄĆ ĽI he ta Ľomia  Ľa hoku laumńĀlie,  
\q2 ne ke  Ľilo ai hoku  Ľalu Ľanga.  
\q2  ĽI he hala ne u  Ľeve Ľeva ai kuo nau  Ľai fufŇę  Ľae tauhele kiate au.   
\q1
\v 4 Ne u sio, mo vakai  Ľi hoku nima to Ľomata Ľu,  
\q2 ka na Ľe  Ľikai ha tangata te ne  Ľilo Ľi au:  
\q2 na Ľe  Ľikai ha Ľaku hŇęfanga;  
\q2 na Ľe  Ľikai tokanga ha tangata ki hoku laumńĀlie.   
\q1
\v 5 Na Ľaku tangi kiate koe,  
\q2  ĽE Sihova; ne u pehńď,  
\q2 Ko koe ko hoku hŇęfanga,  
\q2 mo hoku  Ľinasi  Ľi he fonua  Ľoe mo Ľui.   
\q1
\v 6 Ke ke tokanga ki he Ľeku tangi;  
\q2 he  Ľoku ou vaivai  Ľaupito:  
\q2 fakamo Ľui au mei hoku kau fakatanga;  
\q2 he  Ľoku nau mńĀlohi hake kiate au.   
\q1
\v 7 ‚ÄĆ ĽOmi hoku laumńĀlie mei he fale fakapŇćpula,  
\q2 koe Ľuhi ke u fakamńĀlŇć ai ki ho huafa:  
\q1  Ľe kńĀpui au  Ľe he angatonu;  
\q2 he te ke fai lelei lahi kiate au.   
\c 143  
\cd \it 1  ĽOku kole  Ľa Tevita kia Sihova ke ne fakamaau ia  Ľi he  Ľofa. 3  ĽOku ne fakahńĀ  Ľa  Ľene ngaahi mamahi. 5  ĽOku ne fakamńĀlohi  Ľene tui  Ľi he fakalaulauloto mo e lotu. 7  ĽOku ne kole ke ma Ľu  Ľae  Ľofa, 9 Mo e fakamo Ľui, 10 Mo e mńĀ Ľoni Ľoni, 12 Pea ke  Ľauha  Ľa hono ngaahi fili.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 ‚ÄĆ ĽE Sihova, fanongo ki he Ľeku lotu,  
\q2 fakafanongo ki he Ľeku ngaahi lotu tńĀuma Ľu:  
\q2 pea  Ľi ho Ľo mo Ľoni mo ho Ľo mńĀ Ľoni Ľoni, ke ke talia au.   
\q1
\v 2 Pea  Ľoua na Ľa ke fakamaau Ľi ho Ľo tamaio Ľeiki:  
\q2 koe Ľuhi  Ľe  Ľikai tonuhia  Ľi ho  Ľao ha tangata mo Ľui  Ľe tokotaha.   
\q1
\v 3 He kuo fakatanga hoku laumńĀlie  Ľe he fili;  
\q2 kuo ne taa Ľi hifo  Ľeku mo Ľui ki he kelekele;  
\q2 kuo ne pule ke u nofo  Ľi he po Ľuli,  
\q2  Ľo hangńď ko kinautolu kuo fuoloa  Ľenau mate.   
\q1
\v 4 Ko ia kuo ta Ľomia ai  Ľa hoku laumńĀlie;  
\q2 kuo lala hoku loto  Ľiate au.   
\q1
\v 5 ‚ÄĆ ĽOku ou manatu ki he ngaahi  Ľaho  Ľi mu Ľa;  
\q2  Ľoku ou fakalaulauloto ki ho Ľo ngńĀue kotoa pńď;  
\q2  Ľoku ou fifili ki he ngńĀue  Ľa ho nima.   
\q1
\v 6 ‚ÄĆ ĽOku ou mafao atu hoku nima kiate koe:  
\q2  Ľoku holi  Ľa hoku laumńĀlie kiate koe,  
\q2  Ľo hangńď ko e fonua fieinua. \qs Sila.\qs*   
\q1
\v 7 ‚ÄĆ ĽE Sihova,  Ľafio vave kiate au:  
\q2 kuo vaivai  Ľa hoku laumńĀlie:  
\q2  Ľoua na Ľa fufŇę ho fofonga  Ľiate au,  
\q2 telia na Ľaku tatau mo kinautolu  Ľoku nau  Ľalu hifo ki he luo.   
\q1
\v 8 Ke ke fakatokanga Ľi au ke u fanongo ki ho Ľo  Ľalo Ľofa  Ľi he pongipongi;  
\q2 he  Ľoku ou falala kiate koe:  
\q2 faka Ľilo mai kiate au  Ľae hala  Ľaia  Ľoku totonu ke u  Ľalu ai;  
\q2 he  Ľoku ou hiki hake hoku laumńĀlie kiate koe.   
\q1
\v 9 Fakamo Ľui au,  ĽE Sihova, mei hoku ngaahi fili:  
\q2  Ľoku ou hola kiate koe ke fakafufŇę au,   
\q1
\v 10 Akonaki Ľi au ke u fai ki ho finangalo;  
\q2 he ko koe ko hoku  ĽOtua;  
\q2 tuku ke tataki au  Ľe ho LaumńĀlie lelei,  
\q2 ki he fonua  Ľoe angatonu.   
\q1
\v 11 ‚ÄĆ ĽE Sihova, fakamo Ľui au koe Ľuhi ko ho huafa:  
\q2 koe Ľuhi ko ho Ľo mńĀ Ľoni Ľoni ke ke  Ľomi hoku laumńĀlie mei he mamahi.   
\q1
\v 12 Pea  Ľi ho Ľo  Ľalo Ľofa ke ke motuhi hoku ngaahi fili,  
\q2 mo faka Ľauha  Ľakinautolu  Ľoku nau fakamamahi ki hoku laumńĀlie: he ko ho Ľo tamaio Ľeiki au.   
\c 144  
\cd \it 1  ĽOku fakafeta Ľi  Ľe Tevita ki he  ĽOtua koe Ľuhi ko  Ľene  Ľalo Ľofa kiate ia pea ki he tangata. 5  ĽOku ne hŇę ke fakamo Ľui ia  Ľe he  ĽOtua mei hono ngaahi fili. 9  ĽOku ne fakahńĀ te ne fakamńĀlŇć ki he  ĽOtua. 11  ĽOku ne lotu ke hoko  Ľae monŇę Ľia ki he pule Ľanga.\it*  
\d Ko e Saame  Ľa Tevita.  
\q1
\v 1 Ke monŇę Ľia pńď  Ľa Sihova ko hoku makatu Ľu,  
\q2  Ľaia  Ľoku ne ako ki hoku nima ketau,  
\q2 mo hoku louhi Ľi nima ke tau:   
\q1
\v 2 Ko hoku lelei Ľanga, mo  Ľeku kolo:  
\q2 mo hoku fale mńĀ Ľolunga, mo hoku fakamo Ľui;  
\q2 ko hoku fakaŇę, pea ko ia  Ľoku ou falala ki ai;  
\q2  Ľoku ne fakamo Ľulaloa Ľi hoku kakai kiate au.   
\q1
\v 3 ‚ÄĆ ĽE Sihova, ko e hńĀ  Ľae tangata,  Ľoku ke tokanga ai kiate ia!  
\q2 Pe ko e foha  Ľoe tangata, koe Ľuhi  Ľoku ke finangalo kiate ia!   
\q1
\v 4 ‚ÄĆ ĽOku tatau  Ľae tangata mo e me Ľa va Ľinga:  
\q2 ko hono ngaahi  Ľaho  Ľoku hangńď ko e  Ľata  Ľoku mole atu.   
\q1
\v 5 Ofe Ľi hifo,  ĽE Sihova, ho ngaahi langi, pea ke hńĀ Ľele hifo:  
\q2 ala ki he ngaahi mo Ľunga, pea tenau kohu ai.   
\q1
\v 6 Lńę atu  Ľae  Ľuhila, pea fakamovete  Ľakinautolu:  
\q2 fana Ľi atu ho Ľo ngaahi ngahau, mo faka Ľauha  Ľakinautolu.   
\q1
\v 7 Fekau mai ho nima mei  Ľolunga;  
\q2 fakamo Ľui au, mo fakahaofi au mei he ngaahi vai lahi,  
\q2 mei he nima  Ľoe fńĀnau  Ľae muli;   
\q1
\v 8 ‚ÄĆ ĽAkinautolu  Ľoku lea  Ľaki  Ľe honau ngutu  Ľae va Ľinga,  
\q2 pea ko honau nima to Ľomata Ľu ko e nima to Ľomata Ľu  Ľoe loi.   
\q1
\v 9 ‚ÄĆ ĽE  ĽOtua, te u hiva  Ľaki  Ľae hiva fo Ľou kiate koe:  
\q2 te u hiva fakamńĀlŇć kiate koe  Ľaki  Ľae saliteli mo e me Ľa faiva  Ľoku filo  Ľe hongofulu.   
\q1
\v 10 Ko ia ia  Ľoku ne foaki  Ľae fakamo Ľui ki he ngaahi tu Ľi:  
\q2  Ľoku ne fakamo Ľui  Ľa Tevita ko  Ľene tamaio Ľeiki mei he heletńĀ  Ľoe kovi.   
\q1
\v 11 Fakamo Ľui au,  
\q2 mo fakahaofi au mei he nima  Ľoe fńĀnau  Ľae muli;  
\q2  Ľakinautolu  Ľoku lea  Ľaki  Ľe honau ngutu  Ľae va Ľinga,  
\q2 pea ko honau nima to Ľomata Ľu ko e nima to Ľomata Ľu  Ľoe loi:   
\q1
\v 12 Koe Ľuhi ke tatau homau ngaahi foha mo e ngaahi  Ľakau na Ľe tupu  Ľi he Ľenau talavou;  
\q2 ke tatau homau ngaahi  Ľofefine mo e ngaahi maka  Ľoe tuliki, kuo tńĀ  Ľo fakatatau mo e fale faka Ľei Ľeiki:   
\q1
\v 13 Koe Ľuhi ke pito ai homau ngaahi feleoko,  
\q2  Ľoku  Ľomi mei ai  Ľae me Ľakai kehekehe kotoa pńď:  
\q2 ke fńĀnau  Ľemau ngaahi fanga sipi  Ľi he lau Ľi afe mo e lau Ľi mano  Ľi homau ngaahi hala:   
\q1
\v 14 Ke mńĀlohi ai  Ľemau fanga pulu tangata ke ngńĀue;  
\q2 ke  Ľoua na Ľa ai  Ľae  Ľoho mai, pńď  Ľae hola kitua ĽńĀ;  
\q2 ke  Ľoua na Ľa ai ha lńĀunga  Ľi homau ngaahi hala.   
\q1
\v 15 ‚ÄĆ ĽOku monŇę Ľia  Ľae kakai ko ia,  Ľaia  Ľoku pehńď:  
\q2  Ľio,  Ľoku monŇę Ľia  Ľae kakai ko ia,  Ľoku  ĽOtua  Ľaki  Ľa Sihova.   
\c 145  
\cd \it 1  ĽOku fakamńĀlŇć  Ľa Tevita ki he  ĽOtua koe Ľuhi ko hono ongoongolelei, 8 Mo  Ľene angalelei 11 Mo hono pule Ľanga, 14 Mo  Ľene pule lelei, 17 Pea mo  Ľene  Ľalo Ľofa fakamo Ľui.\it*  
\d Ko e Saame  Ľoe fakamńĀlŇć  Ľa Tevita.  
\q1
\v 1 Te u fakahikihiki koe, ko hoku  ĽOtua, ko e tu Ľi;  
\q2 pea te u fakafeta Ľi ki ho huafa  Ľo lauikuonga pea ta Ľengata.   
\q1
\v 2 Te u fakafeta Ľi kiate koe  Ľi he  Ľaho kotoa pńď;  
\q2 pea te u fakamńĀlŇć ki ho huafa  Ľo lauikuonga pea ta Ľengata.   
\q1
\v 3 ‚ÄĆ ĽOku lahi  Ľa Sihova, pea  Ľoku ngali ke fa Ľa fakamńĀlŇć kiate ia;  
\q2 pea ko hono lahi  Ľoku ta Ľefa Ľa Ľilo Ľi.   
\q1
\v 4 ‚ÄĆ ĽE fakamńĀlŇć  Ľae to Ľutangata  Ľe taha ki ho Ľo ngaahi ngńĀue  Ľo a Ľu ki he taha,  
\q2 pea tenau fakahńĀ ho Ľo ngaahi ngńĀue lahi.   
\q1
\v 5 Te u lea ki hono ongoongolelei lahi  Ľo ho Ľo  Ľafio,  
\q2 pea mo ho Ľo ngaahi ngńĀue fakaofo.   
\q1
\v 6 Pea  Ľe lea \add  Ľae \add*kakai ki hono mńĀlohi  Ľo ho Ľo ngaahi ngńĀue fakailifia:  
\q2 pea te u fakahńĀ ho Ľo mńĀfimafi.   
\q1
\v 7 Tenau fa Ľa fakahńĀ  Ľae fakamanatu  Ľo ho Ľo  ĽulungńĀanga lelei lahi,  
\q2 pea tenau hiva  Ľaki ho Ľo mńĀ Ľoni Ľoni.   
\q1
\v 8 ‚ÄĆ ĽOku angalelei  Ľa Sihova, pea fonu  Ľi he manava Ľofa;  
\q2  Ľoku tŇć Ľohi hono houhau, pea  Ľoku lahi  Ľa  Ľene  Ľalo Ľofa.   
\q1
\v 9 ‚ÄĆ ĽOku angalelei  Ľa Sihova ki he kakai kotoa pńď:  
\q2 pea  Ľoku kńĀpui  Ľene ngńĀue kotoa pńď  Ľe he Ľene ngaahi  Ľalo Ľofa ongongofua.   
\q1
\v 10 ‚ÄĆ ĽE Sihova,  Ľe fakamńĀlŇć kiate koe  Ľa ho Ľo ngaahi ngńĀue kotoa pńď;  
\q2 pea  Ľe fakafeta Ľi kiate koe  Ľa ho Ľo kakai mńĀ Ľoni Ľoni.   
\q1
\v 11 Tenau lea ki he nńĀunau  Ľo ho pule Ľanga,  
\q2 pea talanoa ki ho Ľo mńĀfimafi;   
\q1
\v 12 Ke faka Ľilo ki he ngaahi foha  Ľoe tangata  Ľene ngaahi ngńĀue lahi,  
\q2 pea mo e ongoongolelei lahi  Ľo hono pule Ľanga.   
\q1
\v 13 Ko ho pule Ľanga ko e pule Ľanga ta Ľengata,  
\q2 pea ko ho Ľo pule  Ľoku tolonga ia  Ľi he ngaahi to Ľutangata kotoa pńď.   
\q1
\v 14 ‚ÄĆ ĽOku poupou hake  Ľe Sihova  Ľakinautolu kotoa pńď kuo hinga,  
\q2 pea  Ľoku ne fokotu Ľu  Ľakinautolu kotoa pńď kuo mapelu ki lalo.   
\q1
\v 15 ‚ÄĆ ĽOku hanga  Ľae ngaahi mata kotoa pńď kiate koe;  
\q2 pea  Ľoku ke foaki  Ľenau me Ľakai  Ľi he feitu Ľula ĽńĀ totonu.   
\q1
\v 16 ‚ÄĆ ĽOku ke mafola ho nima,  
\q2 mo fakamńĀkona  Ľae holi  Ľae me Ľa mo Ľui kotoa pńď.   
\q1
\v 17 ‚ÄĆ ĽOku angatonu  Ľa Sihova  Ľi hono hala kotoa pńď,  
\q2 pea mńĀ Ľoni Ľoni  Ľi he Ľene ngaahi ngńĀue kotoa pńď.   
\q1
\v 18 ‚ÄĆ ĽOku ofi  Ľa Sihova kiate kinautolu kotoa pńď kuo ui ki he Ľene  Ľafio,  
\q2 kiate kinautolu kotoa pńď  Ľoku nau ui kiate ia  Ľi he mo Ľoni.   
\q1
\v 19 Te ne fai ki he holi  Ľanautolu  Ľoku manavahńď kiate ia:  
\q2  Ľe fanongo foki ia ki he Ľenau tangi, pea te ne fakamo Ľui  Ľakinautolu.   
\q1
\v 20 ‚ÄĆ ĽOku fakamo Ľui  Ľe Sihova  Ľakinautolu kotoa pńď  Ľoku nau  Ľofa kiate ia:  
\q2 ka ko e angakovi kotoa pńď te ne faka Ľauha.   
\q1
\v 21 ‚ÄĆ ĽE lea  Ľaki  Ľe hoku ngutu  Ľae fakamńĀlŇć kia Sihova:  
\q2 pea tuku ke fakafeta Ľi  Ľae kakano kotoa pńď ki hono huafa mńĀ Ľoni Ľoni  Ľo lauikuonga pea ta Ľengata.   
\c 146  
\cd \it 1  ĽOku fuakava  Ľae tangata tohi saame te ne fakamńĀlŇć ma Ľuaipńď ki he  ĽOtua. 3  ĽOku ne enginaki ke  Ľoua na Ľa falala ki he tangata. 5  ĽOku totonu ke falala pe ki he  ĽOtua, koe Ľuhi ko  Ľene mńĀfimafi, mo  Ľene angatonu, mo  Ľene  Ľalo Ľofa, pea mo  Ľene pule.\it*  
\q1
\v 1 Mou fakamńĀlŇć kia Sihova.  
\q2 FakamńĀlŇć kia Sihova,  ĽE hoku laumńĀlie.   
\q1
\v 2 Te u fakamńĀlŇć kia Sihova  Ľi he Ľeku kei mo Ľui:  
\q2 te u hiva fakamńĀlŇć ki hoku  ĽOtua  Ľi he lolotonga  Ľo  Ľeku mo Ľui.   
\q1
\v 3 ‚ÄĆ ĽOua na Ľa mou falala ki he ngaahi  Ľeiki,  
\q2 pe ki he foha  Ľoe tangata,  Ľaia  Ľoku  Ľikai ha fakamo Ľui  Ľiate ia.   
\q1
\v 4 ‚ÄĆ ĽOku mole atu  Ľene mńĀnava, pea  Ľoku foki ia ki he kelekele;  
\q2  Ľoku mole ai  Ľi he  Ľaho ko ia  Ľene ngaahi mahalo.   
\q1
\v 5 ‚ÄĆ ĽOku monŇę Ľia ia  Ľaia  Ľoku ne ma Ľu  Ľae  ĽOtua  Ľo Sńďkope ko hono tokoni,  
\q2 pea ko  Ľene  Ľamanaki lelei  Ľoku  Ľia Sihova ko hono  ĽOtua:   
\q1
\v 6 ‚ÄĆ ĽAia na Ľa ne ngaohi  Ľae langi, mo mńĀmani,  
\q2  Ľae tahi mo e me Ľa kotoa pńď  Ľoku  Ľi ai:  
\q2 pea  Ľoku ne tauhi  Ľae mo Ľoni  Ľo lauikuonga:   
\q1
\v 7 ‚ÄĆ ĽAia  Ľoku ne fai  Ľae fakamaau koe Ľuhi ko e kakai fakamńĀlohia:  
\q2  Ľoku ne foaki  Ľae me Ľakai ki he fiekaia.  ĽOku vete  Ľe Sihova  Ľae kau pŇćpula:   
\q1
\v 8 ‚ÄĆ ĽOku faka ĽńĀ  Ľe Sihova  Ľae kui:  
\q2  Ľoku fokotu Ľu  Ľe Sihova  Ľakinautolu kuo mapelu ki lalo:  
\q2  Ľoku  Ľofa  Ľa Sihova ki he angatonu:   
\q1
\v 9 ‚ÄĆ ĽOku fakamo Ľui  Ľe Sihova  Ľae kakai muli;  
\q2  Ľoku ne fakafiemńĀlie Ľi  Ľae tamai mate mo e fefine kuo mate hono husepńĀniti:  
\q2 ka ko e hala  Ľoe angahala  Ľoku ne fulihi ia.   
\q1
\v 10 ‚ÄĆ ĽE pule  Ľa Sihova  Ľo ta Ľengata,  
\q2  Ľio, ko ho  ĽOtua,  ĽE Saione,  
\q2  Ľi he ngaahi to Ľutangata kotoa pńď.  
\q2 Mou fakamńĀlŇć kia Sihova.   
\c 147  
\cd \it 1 Ko e enginaki  Ľae palŇćfita ke fakamńĀlŇć ki he  ĽOtua koe Ľuhi ko  Ľene tauhi ki he siasi, 4 Mo  Ľene mńĀfimafi, 6 Mo  Ľene  Ľalo Ľofa, 7 Pea mo  Ľene pule: 12 Ke fakamńĀlŇć kiate ia koe Ľuhi ko  Ľene tńĀpuaki  Ľa  ĽIsileli, 15 Mo hono mńĀlohi  Ľi he langi, 19 Pea koe Ľuhi ko  Ľene tu Ľutu Ľuni ki he siasi.\it*  
\q1
\v 1 Mou fakamńĀlŇć kia Sihova:  
\q2 he  Ľoku lelei ke hiva fakamńĀlŇć ki hotau  ĽOtua;  
\q2 he  Ľoku mńĀlie ia; pea  Ľoku ngali  Ľae fakamńĀlŇć.   
\q1
\v 2 ‚ÄĆ ĽOku langa hake  Ľe Sihova  Ľa SelŇęsalema:  
\q2  Ľoku ne tńĀnaki fakataha  Ľae kau  ĽIsileli na Ľe fakahńď Ľi   
\q1
\v 3 ‚ÄĆ ĽOku ne fakamo Ľui  Ľakinautolu  Ľoku loto mafesi,  
\q2  Ľo ne nono Ľo honau ngaahi lavea.   
\q1
\v 4 ‚ÄĆ ĽOku ne tala hono lau  Ľoe ngaahi fetu Ľu;  
\q2  Ľoku ne ui  Ľakinautolu kotoa pńď  Ľi honau ngaahi hingoa.   
\q1
\v 5 Ko hotau  ĽEiki  Ľoku lahi ia,  
\q2 pea lahi hono mńĀlohi:  
\q2 ko  Ľene  Ľilo  Ľoku ta Ľengata.   
\q1
\v 6 ‚ÄĆ ĽOku hiki hake  Ľe Sihova  Ľae angamalŇę:  
\q2  Ľoku lńę  Ľe ia  Ľae angahala ki he kelekele.   
\q1
\v 7 Hiva kia Sihova  Ľaki  Ľae fakafeta Ľi;  
\q2 hiva fakamńĀlŇć  Ľi he ha Ľape ki hotau  ĽOtua:   
\q1
\v 8 ‚ÄĆ ĽAia  Ľoku ne  Ľufi Ľufi  Ľaki  Ľae langi  Ľae ngaahi  Ľao,  
\q2  Ľoku ne teuteu  Ľae  Ľuha ki he kelekele,  
\q2 mo ne fakatupu  Ľae mohuku  Ľi he ngaahi mo Ľunga.   
\q1
\v 9 ‚ÄĆ ĽOku ne foaki ki he manu  Ľene me Ľakai,  
\q2 pea ki he fanga leveni iiki  Ľaia  Ľoku tangi.   
\q1
\v 10 ‚ÄĆ ĽOku  Ľikai fiefia ia  Ľi he mńĀlohi  Ľoe hoosi:  
\q2  Ľoku  Ľikai fiefia ia  Ľi he kau va Ľe  Ľoe tangata.   
\q1
\v 11 ‚ÄĆ ĽOku fiefia  Ľa Sihova  Ľiate kinautolu  Ľoku nau manavahńď kiate ia,  
\q2  Ľiate kinautolu  Ľoku nau  Ľamanaki ki he Ľene  Ľalo Ľofa.   
\q1
\v 12 FakamńĀlŇć kia Sihova,  ĽE SelŇęsalema;  
\q2 fakamńĀlŇć ki ho  ĽOtua,  ĽE Saione.   
\q1
\v 13 He kuo ne fakamńĀlohi  Ľae ngaahi songo  Ľo ho ngaahi matapńĀ;  
\q2 kuo ne tńĀpuaki Ľi ho Ľo fńĀnau  Ľi loto  Ľiate koe.   
\q1
\v 14 ‚ÄĆ ĽOku fakatupu  Ľe ia  Ľae melino  Ľi ho ngaahi potu,  
\q2 pea  Ľoku ne fakamahu  Ľaki koe  Ľae uite  Ľoku fungani lelei.   
\q1
\v 15 ‚ÄĆ ĽOku ne tuku atu  Ľene fekau ki mńĀmani:  
\q2  Ľoku vave  Ľaupito  Ľae lele atu  Ľo  Ľene folofola,   
\q1
\v 16 ‚ÄĆ ĽOku ne foaki  Ľae  Ľuha hinehina  Ľo hangńď ko e fulufulu Ľi sipi:  
\q2  Ľoku ne tŇętuu Ľi  Ľae hahau kuo fefeka  Ľo hangńď ko e efuefu.   
\q1
\v 17 ‚ÄĆ ĽOku ne laku atu  Ľae  Ľuha maka  Ľo hangńď ko e ngaahi momo Ľi me Ľa si Ľi:  
\q2 ko hai  Ľe fa Ľa kńĀtaki hono momoko?   
\q1
\v 18 ‚ÄĆ ĽOku ne fekau atu  Ľene folofola, pea  Ľoku vai ai ia:  
\q2  Ľoku ne pule ke angi  Ľene matangi, pea  Ľoku tafe atu  Ľae ngaahi vai.   
\q1
\v 19 ‚ÄĆ ĽOku ne fakahńĀ  Ľene folofola kia Sńďkope,  
\q2  Ľa  Ľene ngaahi tu Ľutu Ľuni mo  Ľene ngaahi fakamaau ki  ĽIsileli.   
\q1
\v 20 Na Ľe  Ľikai te ne fai pehńď ki ha pule Ľanga  Ľe taha:  
\q2 pea ko  Ľene ngaahi fakamaau, na Ľe  Ľikai tenau  Ľilo ki ai.  
\q2 Mou fakamńĀlŇć kia Sihova.   
\c 148  
\cd \it 1 Ko e enginaki  Ľe he tangata taki saame ki he ngaahi me Ľa  Ľi he langi, 7 Mo mńĀmani, 11 Mo e kakai kenau fakamńĀlŇć ki he  ĽOtua.\it*  
\q1
\v 1 Mou fakamńĀlŇć kia Sihova. Mou fakamńĀlŇć kia Sihova mei he ngaahi langi:  
\q2 fakamńĀlŇć ki he Ľene  Ľafio  Ľi he ngaahi potu mńĀ Ľolunga.   
\q1
\v 2 Mou fakamńĀlŇć kiate ia,  Ľa  Ľene kau  ĽńĀngelo kotoa pńď:  
\q2 mou fakamńĀlŇć kiate ia,  Ľa  Ľene ngaahi kautau kotoa pńď.   
\q1
\v 3 Mo fakamńĀlŇć kiate ia,  Ľae la ĽńĀ mo e mńĀhina:  
\q2 mou fakamńĀlŇć kiate ia,  Ľae ngaahi fetu Ľu kotoa pńď  Ľoe maama.   
\q1
\v 4 Mou fakamńĀlŇć kiate ia,  Ľae ngaahi langi  Ľoe ngaahi langi,  
\q2 mo e ngaahi vai  Ľoku mńĀ Ľolunga  Ľi he ngaahi langi.   
\q1
\v 5 Kenau fakamńĀlŇć ki he huafa  Ľo Sihova:  
\q2 he na Ľe fekau  Ľe ia, pea na Ľe fakatupu  Ľakinautolu.   
\q1
\v 6 Pea kuo ne fokotu Ľuma Ľu  Ľakinautolu  Ľo lauikuonga pea ta Ľengata.  
\q2 Kuo ne tu Ľutu Ľuni pea  Ľe  Ľikai mole ia.   
\q1
\v 7 FakamńĀlŇć kia Sihova mei mńĀmani,  
\q2  Ľae fanga talńĀkoni, mo e ngaahi loloto kotoa pńď:   
\q1
\v 8 ‚ÄĆ ĽAe afi, mo e  Ľuha maka;  Ľae  Ľuha hinehina, mo e ngaahi kakapu;  
\q2  Ľae matangi mńĀlohi  Ľoku fakamo Ľoni ki he Ľene folofola:   
\q1
\v 9 ‚ÄĆ ĽAe ngaahi mo Ľunga, mo e ngaahi fo Ľi mo Ľunga kotoa pńď;  
\q2  Ľae ngaahi  Ľakau fua, mo e ngaahi sita kotoa pńď:  
\v 10 ‚ÄĆ ĽAe fanga manu hehengi,  
\q2 mo e manu lalata kotoa pńď;  
\q2  Ľae ngaahi me Ľa totolo, mo e manupuna:   
\q1
\v 11 ‚ÄĆ ĽAe ngaahi tu Ľi  Ľo mńĀmani, mo e kakai kotoa pńď;  
\q2  Ľae ngaahi  Ľeiki, mo e kau fakamaau kotoa pńď  Ľo mńĀmani:   
\q1
\v 12 ‚ÄĆ ĽAe kau tangata talavou, mo e kau ta Ľahine;  
\q2  Ľae kau mńĀtu Ľa, mo e fńĀnau:   
\q1
\v 13 Ke nau fakamńĀlŇć ki he huafa  Ľo Sihova:  
\q2 he ko hono huafa pńď  Ľoku mńĀ Ľolunga;  
\q2 mo hono nńĀunau  Ľoku mńĀ Ľolunga hake ia  Ľi mńĀmani mo e langi.   
\q1
\v 14 ‚ÄĆ ĽOku hiki hake foki  Ľe ia  Ľae nifo  Ľo hono kakai,  
\q2 ko ia  Ľoku fakamńĀlŇć ai  Ľa  Ľene kakai mńĀ Ľoni Ľoni kotoa pńď;  
\q2  Ľio,  Ľa hono kakai ko  ĽIsileli,  
\q2 ko e kakai  Ľoku ofi kiate ia.  
\q2 Mou fakamńĀlŇć kia Sihova.   
\c 149  
\cd \it 1 Ko e enginaki  Ľae palŇćfita ke fakamńĀlŇć ki ho  ĽOtua koe Ľuhi ko  Ľene  Ľofa ki he siasi, 5 Pea koe Ľuhi ko e mńĀlohi kuo ne foaki ki he siasi.\it*  
\q1
\v 1 Mou fakamńĀlŇć kia Sihova.  
\q2 Hiva kia Sihova  Ľaki  Ľae hiva fo Ľou,  
\q2 mo e fakamńĀlŇć kiate ia  Ľi he fakataha  Ľoe kakai mńĀ Ľoni Ľoni.   
\q1
\v 2 Ke fiefia  Ľa  ĽIsileli  Ľiate ia na Ľa ne ngaohi ia:  
\q2 ke fiefia  Ľae fńĀnau  Ľa Saione  Ľi honau Tu Ľi.   
\q1
\v 3 Kenau fakamńĀlŇć ki hono huafa  Ľi he me Ľe:  
\q2 kenau hiva fakamńĀlŇć kiate ia  Ľaki  Ľae lali iiki mo e ha Ľape.   
\q1
\v 4 He  Ľoku fiefia  Ľa Sihova  Ľi hono kakai  
\q2 te ne teuteu  Ľae angamalŇę  Ľaki  Ľae fakamo Ľui.   
\q1
\v 5 Ke fiefia  Ľae kakai mńĀ Ľoni Ľoni  Ľi he nńĀunau:  
\q2 kenau hiva kalanga,  
\q2  Ľi honau ngaahi mohenga.   
\q1
\v 6 Ke  Ľi honau ngutu  Ľae fakamńĀlŇć lahi ki he  ĽOtua, pea  Ľi honau nima  Ľae heletńĀ  Ľoku fakatoumata;   
\q1
\v 7 Ke  Ľatu  Ľae totongi ki he hiteni,  
\q2 mo e ngaahi tautea ki he kakai:   
\q1
\v 8 Ke ha Ľisia honau ngaahi tu Ľi  Ľaki  Ľae ukamea fihifihi,  
\q2 mo honau hou Ľeiki  Ľaki  Ľae ngaahi ha Ľi ukamea;   
\q1
\v 9 Ke fai kiate kinautolu  Ľae fakamaau kuo tohi:  
\q2 kuo pehńď  Ľae hakeaki Ľi  Ľo  Ľene kakai mńĀ Ľoni Ľoni kotoa pńď.  
\q2 Mou fakamńĀlŇć kia Sihova.   
\c 150  
\cd \it 1 Ko e enginaki ke fakamńĀlŇć ki he  ĽOtua 3  ĽAki  Ľae ngaahi me Ľa faiva kotoa pńď.\it*  
\q1
\v 1 Mou fakamńĀlŇć kia Sihova.  
\q2 FakamńĀlŇć kia Sihova  Ľi hono faletapu:  
\q2 fakamńĀlŇć ki he Ľene  Ľafio  Ľi he  ĽatńĀ  Ľo hono mńĀlohi.   
\q1
\v 2 FakamńĀlŇć kiate ia koe Ľuhi ko  Ľene ngaahi ngńĀue lahi:  
\q2 fakamńĀlŇć kiate ia  Ľo fakatatau mo hono lahi  Ľo  Ľene mńĀfimafi.   
\q1
\v 3 FakamńĀlŇć kiate ia  Ľaki  Ľae le Ľo  Ľoe me Ľa lea:  
\q2 fakamńĀlŇć kiate ia  Ľaki  Ľae saliteli mo e ha Ľape.   
\q1
\v 4 FakamńĀlŇć kiate ia  Ľaki  Ľae lali iiki mo e me Ľe:  
\q2 fakamńĀlŇć kiate ia  Ľaki  Ľae ngaahi me Ľa faiva mo e ngaahi me Ľa ifi.   
\q1
\v 5 FakamńĀlŇć kiate ia  Ľaki  Ľae simipale tatangi:  
\q2 fakamńĀlŇć ki he Ľene  Ľafio  Ľaki  Ľae ngaahi simipale  Ľoku le Ľo lahi.   
\q1
\v 6 Ke fakamńĀlŇć kia Sihova  Ľae me Ľa kotoa pńď  Ľoku mńĀnava.  
\q2 Haleluia.   