\v 12 \w Yo|strong="H6213"\w* también \w os|strong="H5869"\w* destinaré \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w espada|strong="H2719"\w*, y \w todos|strong="H3605"\w* \w vosotros|strong="H8085"\w* \w os|strong="H5869"\w* arro­dillaréis al degolladero: \w por|strong="H3282"\w* \w cuanto|strong="H3282"\w* \w llamé|strong="H7121"\w*, y \w no|strong="H3808"\w* \w respondisteis|strong="H6030"\w*; \w hablé|strong="H1696"\w*, y \w no|strong="H3808"\w* \w oisteis|strong="H8085"\w*; \w sino|strong="H3808"\w* \w que|strong="H3808"\w* \w hicisteis|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w* \w delante|strong="H5869"\w* \w de|strong="H5869"\w* mis \w ojos|strong="H5869"\w*, y escogisteis \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w a|strong="H3068"\w* \w mí|strong="H6030"\w* desagrada.   
\m
\v 13 \w Por|strong="H3651"\w* \w tanto|strong="H3651"\w* \w así|strong="H3541"\w* dijo el Señor \w DIOS|strong="H3069"\w*: He \w aquí|strong="H2009"\w* \w que|strong="H3541"\w* mis \w siervos|strong="H5650"\w* comerán, \w y|strong="H3541"\w* vosotros tendréis \w hambre|strong="H7456"\w*; he \w aquí|strong="H2009"\w* \w que|strong="H3541"\w* mis \w siervos|strong="H5650"\w* \w beberán|strong="H8354"\w*, \w y|strong="H3541"\w* vosotros tendréis \w sed|strong="H6770"\w*; he \w aquí|strong="H2009"\w* \w que|strong="H3541"\w* mis \w siervos|strong="H5650"\w* \w se|strong="H3651"\w* ale­grarán, \w y|strong="H3541"\w* vosotros seréis aver­gonzados;   
\m
\v 14 He \w aquí|strong="H2009"\w* que mis \w siervos|strong="H5650"\w* can­tarán por júbilo del \w corazón|strong="H3820"\w*, y vosotros \w clamaréis|strong="H6817"\w* por el dolor del \w corazón|strong="H3820"\w*, y por el quebranta­miento de \w espíritu|strong="H7307"\w* \w aullaréis|strong="H3213"\w*.   
\m
\v 15 \w Y|strong="H3068"\w* dejaréis vuestro \w nombre|strong="H8034"\w* por maldición \w a|strong="H3068"\w* mis escogidos, y el Señor \w DIOS|strong="H3069"\w* te \w matará|strong="H4191"\w*; y \w a|strong="H3068"\w* sus \w siervos|strong="H5650"\w* \w llamará|strong="H7121"\w* por otro \w nombre|strong="H8034"\w*.   
\m
\v 16 \w El|strong="H3588"\w* \w que|strong="H3588"\w* se bendijere \w en|strong="H3588"\w* \w la|strong="H3588"\w* tie­rra, \w en|strong="H3588"\w* \w el|strong="H3588"\w* Dios \w de|strong="H3588"\w* verdad se ben­decirá; \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w jurare|strong="H7650"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra, \w por|strong="H3588"\w* \w el|strong="H3588"\w* Dios \w de|strong="H3588"\w* verdad jurará; \w por|strong="H3588"\w*­\w que|strong="H3588"\w* las \w angustias|strong="H6869"\w* \w primeras|strong="H7223"\w* serán olvidadas, \w y|strong="H3588"\w* serán cubiertas \w de|strong="H3588"\w* mis \w ojos|strong="H5869"\w*.   
\m
\v 17 \w Porque|strong="H3588"\w* he \w aquí|strong="H2005"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* creo \w nuevos|strong="H2319"\w* \w cielos|strong="H8064"\w* \w y|strong="H3588"\w* \w nueva|strong="H2319"\w* tierra: \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w lo|strong="H3808"\w* \w primero|strong="H7223"\w* \w no|strong="H3808"\w* habrá \w memoria|strong="H2142"\w*, \w ni|strong="H3808"\w* \w más|strong="H3588"\w* \w vendrá|strong="H5927"\w* \w al|strong="H5921"\w* \w pensamiento|strong="H3820"\w*.   
