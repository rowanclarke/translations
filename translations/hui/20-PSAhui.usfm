\q2 lalu hayuago i̱ hale haabo haru.  
\q1 Anduane Homogo-o wali agali bibahendeme biabe bialu harimadagua  
\q2 í̠na ina hangu hanguhondo emena karulape ngiadai biaga kegoni.   
\c 63  
\s1 Mbirali ibu Ngode Datagaliwabe heba hole hameore lowa iba gana lenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o í̠ i̱naga Ngode Datagaliwabe kegoni.\x + \xo 63.1 \xt 1 Sml 23.14\x*\x + \xo 63.1 \xt Iba 42.2, 84.2, 143.6\x*  
\q1 I̱na í̠ handa walia hole lowa  
\q2 miniha hongo howaore hai bialu kogoni.  
\q1 I̱naga minimebi tinginimebi  
\q2 í̠ hebaore hole hame timbuniore lo kogoni.  
\q1 Wali agalime dindi koore yobi iba nabereni howa  
\q2 iba noa timbuni halu hége lebolaho hagadagua  
\q2 i̱ni í̠ hebaore hoa howa hame timbuniore lo kogoni.   
\q1
\v 2 Í̠ í̠ninaga anda loma biahene kagoha haga kego  
\q2 í̠ kegoniore i̱ de hondoa ho kogoni.  
\q1 I̱na í̠naga hongo holene gibiore ngegobi  
\q2 í̠naga wá holene tara baya agiore loabe tobahe ngegobi  
\q2 de hondoleore hameledo.   
\q1
\v 3 Dindini holiyanaga holene ngirigo yuwa bayale dege turuho kogoyu  
\q2 ogoni goyane lowa í̠na i̱ gubalini haho wiaabo hariligo baya daligaore ngegoni.  
\q1 Í̠ ani biaga kegonaga i̱na í̠naga mini mo yaraga holebero.   
\q1
\v 4 I̱ dindini emabu kongi í̠hondo ka̱i̱ lalu  
\q2 í̠naga mini mo yaraga haabo halu kone dege i̱ni homalu waholebero.  
\q1 I̱naga gi í̠hondo yaraga halu bi lolebero.   
\q1
\v 5 Tomo bayaleru karulapeore nowa tombe howa dungu lo holenedagua  
\q2 i̱naga dininime dinini tomo karulapeore nowa dunguore lowa holebero.  
\q1 Ani bialu i̱na iba gana baya turubiru turuore howa  
\q2 í̠naga mini mo yaraga halu lolebero.   
\b  
\q1
\v 6 I̱ mbiraga tamuni paluwa í̠ore mitangi biruli.\x + \xo 63.6 \xt Iba 42.8, 119.55, 149.5\x*  
\q1 Mbiraga lu biagoniha i̱naga minime í̠ hangu mitangitangi biruli.   
\q1
\v 7 Ani mitangitangi biaabo haruligo irane\x + \xo 63.7 \xt Iba 61.4\x*  
\q2 í̠na i̱ biamogo biaaboore hariligonaga  
\q2 i̱na ani mitangitangi biruli.  
\q1 Ega angibunime ibu iginiru ibuninaga babaganeme minu tongo biagadagua  
\q2 í̠naga babagane andane gumba kagoha howa  
\q2 i̱ turu halu iba gana turubiru laruli.   
\q1
\v 8 I̱na í̠ni yu paraguabu ngogola\x + \xo 63.8 \xt Ais 26.9\x*  
\q2 í̠naga gime i̱ baya hanguore yaniho haga kegoni.   
\b  
\q1
\v 9 Agali marume i̱ bo waholeore manda bialu karuni  
\q2 tini homalu humbirini andaga homene dinini pu haga ngagoha pu holebira.   
\q1
\v 10 Agali odaruni waiangi agali waime homelo bo yongobu wahalu pedaria  
\q2 biango dudurume ti buduyu pugu pugu bulebira.   
\q1
\v 11 Ani bulebiragoyu ai i̱ kini kogoni howa wai bigi berongi\x + \xo 63.11 \xt Man 6.13, Ais 45.23\x*  
\q2 Ngode Datagaliwabehanda i̱ wayali holiya biamogo biaganegonaga  
\q2 i̱ turu ho holebero.  
\q1 Wali agali maru Ngode Datagaliwabenaga mini lalu,  
\q1 Í̠ore talima ibule, laga karume  
\q2 turu halu í̠naga mini mo yaraga holebira.  
\q1 Wali agali ke̱ haga karunaga ne hariga í̠na mo ndibu lolebere.   
\c 64  
\s1 Ngode Datagaliwabehondo handayaho habe lalu bi lenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o i̱na genda timbuniore howa  
\q2 í̠hondo bi larogo hale habe.  
\q1 I̱ waitigi karu hondowa gi ho kogoni.  
\q1 Tigua i̱ bo waholigo í̠na i̱ handayaho habe laro.   
\q1
\v 2 Agali ko biaga karume ndelalu hariga tai bialu  
\q2 i̱ bo wahole mo mogobu kagoni.  
\q1 Tigua i̱ mo ko nahelo í̠na i̱ handayaho habe.   
\q1
\v 3 Tinaga hége ayu tibu ne gadelehe ale howa  
\q2 tigua bi ko lararume i̱ timume bogole edaho hagadagua kagoni.   
\q1
\v 4 Tigua ha do ho howa agali bayale kagoha  
\q2 timu bo pelagadagua ndelalu kagoni.  
\q1 Agali urunime gi nahaga howa ke̱ gibi hararume  
\q2 timu ala baga biagadagua balu kagoni.   
\q1
\v 5 Tigua mana ko uruni bulenaga\x + \xo 64.5 \xt Iba 10.11, 59.7, Min 1.11\x*  
\q2 tini mo hongo hagahaga bialu ka.  
\q1 Agali bayale karu gonoha delonaga  
\q2 tigua gono ogoha wimi̱ya laga bialu kagoni.  
\q1 Tigua gono wuwa lo mitangi bialu,  
\q2 O beremagoni mbiralime nahondolebira, laga ka.   
\q1
\v 6 Mana ko ngaru bule tigua pongo bo wialu howa lalu,  
\q2 Iname mana ko gibiore mbira bulene hariga handa walia harimagoni, lalu ka.  
\q1 Agalinaga bu habaneha mini wia do ho kago o gibihego  
\q2 iname handabe naheore kamagoni.   
\b  
\q1
\v 7 Agali korume bi ogonibi laragoyu Ngode Datagaliwabehanda ibunaga timume ti baragola  
\q2 ti abale ibira holebira.   
\q1
\v 8 Tigua agali maru karu bo wahole layagonaga  
\q2 Ngode Datagaliwabehanda tini bo wahai holebira.  
\q1 Wali agali maru karume ti de handaya howa  
\q2 mege bialu tinaga ma bonge laga bulebira.   
\q1
\v 9 Wali agali bibahendeme Ngode Datagaliwabehondo gi hai holebira.  
\q1 Tigua Ngode Datagaliwabehanda biyarunaga te laga bialu howa  
\q2 mitangi bu haabo holebira.   
\q1
\v 10 Wali agali tigabi biaga karume\x + \xo 64.10 \xt Iba 32.11, 58.10, 68.3\x*  
\q2 Anduane Homogohanda biyarunaga turu holebira.  
\q1 Tigua ibuha ha do ho howa bayale holebira.  
\q1 Wali agali mini bayale karume  
\q2 Ngode Datagaliwabenaga mini yaraga haabo helo laro.   
\c 65  
\s1 Ngode Datagaliwabenaga mini mo yaraga halu ka̱i̱ lenego ogo  
\q1
\v 1-3 Ngode Datagaliwabe-o iname Saiono tanoni í̠naga mini yaraga holene karulapeore nga.  
\q1 Iname í̠hondo bi laramago hale halu ladai biaga kegonaga  
\q2 í̠hondo buleore lalu lo wirimaru biaore buleberama.  
\q1 Wali agali dindi tara tarani karume ko bigi biyarunaga  
\q2 í̠ keria ibugu bulebira.  
\q1 Iname ko beremarume inane bope haga biragola kamaria  
\q2 í̠na domo wahaga biriligoni.   
\q1
\v 4 Wali agali í̠nime dabaga bialu\x + \xo 65.4 \xt Iba 33.12, 36.8, 84.4\x*  
\q2 í̠naga andaha í̠ni kegoria helo dabaga bereru  
\q2 ti turuore ho ka.  
\q1 Í̠na ti haru anda eberegola mbirale bayale tara tara damene  
\q2 í̠naga anda loma binigo kagoha bu ngaru hondowa  
\q2 ina miniha hina ale tombe howa dungulo holeberema.   
\b  
\q1
\v 5 Ngode Datagaliwabe-o iname í̠hondo bi laramago hale halu  
\q2 í̠na gi migi biriligoni.  
\q1 Í̠na ina pele ngulenaga mbirale baya tara tara nahendene aleru bigi biriligoni.  
\q1 Wali agali dindi bibahendeni paluyu pedarubi  
\q2 iba solowara domalu dindi kaundiani bu karubi  
\q1 ti bibahendeme í̠hondo mini mbiraore wialu í̠ha mini hana ho haga ka.   
\q1
\v 6 Í̠ hongo gibihe kegome dindi hari gibi wa yu pedaruni  
\q2 í̠na wene wedagoni.  
\q1 Í̠naga hongo timbuni ngego mo walia halu ani wedagoni.   
\q1
\v 7 Iba solowarame bi timbuni tigi tugua lararubi  
\q2 yaribu bialu lararubi mo hundia halu  
\q2 wali agalime bi timbuni awa lalu ladagadaga bialu karu mo hundia haga kegoni.   
\q1
\v 8 Í̠na gibi urunidagua bigi bialu kego hondowa  
\q2 ina wali agali dindi bibahendeni bu hama pedamarunaga bi nawidagola  
\q2 í̠na bigi berego dege hondole bame ne angala howa de handaya ho hama pedamagoni.  
\q1 Í̠na bigi berego handalu turu halu ogodagua biya lalu loyogo laramagola  
\q2 wali agali pali maro bidarumebi heba bi ladagadaga bialu holebira.   
\b  
\q1
\v 9 Í̠na wali agali palu ngamaru handaya ho ko lalu  
\q2 hariha howa dalu ngialu\x + \xo 65.9 \xt Man 32.2, Iba 46.4, 72.6, 104.13, 104.24, 147.8, 147.14\x*  
\q2 inanaga dindiru mo baya halu mo ibane berela halu kegoni.  
\q1 Iba nagane gendo ngamaruha iba duguaho wiaabo helalu  
\q2 iba maru piagaru hundia nabi pia ho wiaabo heledagoni.  
\q1 Inanaga tomo hengedamarubi baya gumbile wiaabo heledegola  
\q2 bu dawalu naabo haramagolabi  
\q2 tene haho wiaabo kagoni.  
\q1 Urunidagua bialu kegome ina wali agali dara howa biamogo bule handaya ho ko lalu walia halu kegoni.   
\q1
\v 10 Tomo hongole howa dindi alu ngamaria  
\q2 hariha howa daluore ngigi birili.  
\q2 Dalu ibilaregome dindi damiai haga.  
\q1 Dalu emene haburalu ibilaga biriligomebi  
\q2 dindi ibane biralu mo gomba haga beregola  
\q2 tomo hengedamaru bayuwa anda haga.   
\q1
\v 11 Í̠na ani bigi beregome tomo au lolebe tara gibi bu ngaria bu hono puwa dawaga beramali.  
\q1 Í̠na biamogo berego damene bibahende ani biai haregola  
\q2 tomo nolene bu payabu wiaabo haga.   
\q1
\v 12 Nogo sibi bulumagaru hagaha nogo wabuni haabo halu  
\q2 dindi hombenerunaga wá hondo holene bayaore ngagoni.   
\q1
\v 13 Tagira nogo sibiru tanini bu haame halu  
\q2 dindi ulini guagua ngaruha tomo tara tara anda halu gumbilo tagiho ngagoni.  
\q1 Uruni bibahendeore inahondo ngiridarumebi  
\q2 wali agali bibahendemebi í̠hondo turu timbuniore howa  
\q2 iba gana dalimu ladaga halu í̠hondo lo ngeremagoni.   
\c 66  
\s1 Ngode Datagaliwabehondo turu howa ka̱i̱ lalu iba gana lenego ogo  
\q1
\v 1 Wali agali dindi bibahendeni bu kamiru-o  
\q2 tí turu halu hongo howa ladaga halu\x + \xo 66.1 \xt Iba 100.1\x*  
\q2 Ngode Datagaliwabenaga mini yaraga halimu.   
\q1
\v 2 Iba ganaru lalu ibu mini leneore kago lalu  
\q2 latagi holene nga.  
\q1 Ibunaga mini timbuni ngago mo yaragaore holene nga.   
\q1
\v 3 Tígua Ngode Datagaliwabehondo lamialu lalu,  
\q1 Mbirale í̠na biagago damene bibahende  
\q2 dunini hangu biai haga kegoni.  
\q1 Í̠ hongo timbuni daligaore kego hondowa  
\q2 í̠naga waitigi bu karume mogo lalu  
\q2 í̠ wanakuihayagi ibalu bulupaligi bialu haga ka.   
\q1
\v 4 Wali agali dindi bibahendeha bu karume\x + \xo 66.4 \xt Iba 67.3, 96.1-2, 117.1\x*  
\q2 í̠ mitangi bialu lotu lalu ka.  
\q1 Tigua í̠hondo iba ganaru lalu  
\q2 í̠naga mini yaraga halu ka, lalu lamilimu.   
\b  
\q1
\v 5 Ngode Datagaliwabehanda biyadaru tí de hondole ibidaba.\x + \xo 66.5 \xt Iba 46.8\x*  
\q1 Wali agali bu hearu dombeneha howa  
\q2 tarale timbuni biyadaru de handadaba.   
\q1
\v 6 Ibugua iba solowara timbuni bereago hundiai helalu\x + \xo 66.6 \xt Har 14.21, Yos 3.14-17\x*  
\q2 dindi mo yobia haya.  
\q1 Dindi yobialu pani helayagola  
\q2 inanaga mamaliru ti geni dindi dindi ibiyagoni.  
\q1 Ibugua biyagonaga iname ogoriani ibuhondo turu timbuni hene.   
\q1
\v 7 Ngode Datagaliwabe ibu hongo gibihe howa  
\q2 ibu kini haluhe haabo haga ka.  
\q1 Ibugua hameigini tara tara hama pedaru bibahende  
\q2 ibunaga deme de handa amu haga ka.  
\q1 Wali agali maru ibunaga mana hale howa doga haga karu  
\q2 ti mini timbuni bolanguahe kama loligo henge namilimu.   
\q1
\v 8 Wali agali hameigini tara tarani palima pedemiru  
\q2 tí bibahendeme inanaga Ngode Datagaliwabe kagonaga mini yaraga hadaba.  
\q1 Wali agali bibahendeme hale hai helo  
\q2 tígua ibunaga mini mo yaraga hai hadaba.   
\q1
\v 9 Ina koha pi naloloma̱ya  
\q2 ibunimeore baya hangu handayaho hayagome\x + \xo 66.9 \xt Iba 121.3\x*  
\q2 ina homa nabi bayale kamagoni.   
\b  
\q1
\v 10 Ngode Datagaliwabe í̠nime ina ba handarigoni.\x + \xo 66.10 \xt Iba 17.3, Ais 48.10, Seg 13.9, 1 Pi 1.6-7\x*  
\q1 Agalime siliba dodo para kago do taulo wahelonaga  
\q2 irani deledagola baya tara wiagadagua  
\q2 í̠na ina kamaruhondo ani biridagoni.   
\q1
\v 11 Í̠nime ina wena nu aleha minu hanarigoni.  
\q1 Inanaga erembirani genda timbuni mo ya harigoni.   
\q1
\v 12 Waitigi bu hearume ina bo hengedelo waharigoni.  
\q1 Ina ira deagoriabi iba li timbuni peagohabi  
\q2 ibagabu harimagoni.  
\q1 Í̠na ani birigoyu ai ina dindi bayale ngagoria  
\q2 haru íbu heledegoni.   
\b  
\q1
\v 13-14 Bamba genda i̱ha tagira ibiyangi  
\q2 i̱na í̠hondo loma mbira irani dai helo bo delole lalu bi lo wirugoni.  
\q1 I̱na bi ogoni larugo mitangi bialu  
\q2 ai loma uruni bu yalu ibulebero.  
\q1 I̱na nogoru í̠naga andaha haru ibalu  
\q2 irani bo delolebero.   
\q1
\v 15 Nogo sibi habatigiru i̱na í̠nihondo lomabu ngialu irani bo delolebero.  
\q1 I̱na bulumaga wangabe karubi meme wangabe karubi  
\q2 í̠hondo loma bialu irani bo delolebero.  
\q1 Uruni delarogola nga bayale birago í̠ nga ho holebere.   
\b  
\q1
\v 16 Wali agali Ngode Datagaliwabe andaneha haga bu kamiru-o  
\q2 tí i̱na bi larogo hale hole ibidaba.  
\q1 Ngode Datagaliwabehanda i̱ biamogo biyaru bibahende  
\q2 langiai holiya ibidaba.   
\q1
\v 17 I̱na ibuhondo i̱ biamogo bia lalu olalu harugoni.  
\q1 Ibunaga mini yaraga halu i̱na iba ganarubi larugoni.   
\q1
\v 18 Mana ko birugo bu donge ho kole nde\x + \xo 66.18 \xt Ais 1.15, Yo 9.31, Ya 4.3\x*  
\q2 Anduane Homogohanda i̱naga bi larugo hale nakale.   
\q1
\v 19 Ngode Datagaliwabehanda i̱na ibuhondo bi larugo haleore haya.\x + \xo 66.19 \xt Iba 116.1-2\x*  
\q1 Ibugua i̱naga bi larugo heneneore hale howa ladai biya.   
\b  
\q1
\v 20 Ngode Datagaliwabehanda i̱ erembira nangi.  
\q1 Ibugua i̱naga bi larugo hale halu  
\q2 i̱ gubalini hayago wanahe haabo hayagonaga  
\q2 i̱na ibu mini yaraga harogoni.   
\c 67  
\s1 Ngode Datagaliwabehondo ka̱i̱ lalu lenego ogo  
\q1
\v 1-2 Ngode Datagaliwabe-o í̠na ina dara nahabehego\x + \xo 67.1-2 \xt Dag 6.25, Iba 31.16, 119.135\x*  
\q2 harugo lowa dara halu biamogoore bibe.  
\q1 Ina de hondo halu pele ngulene ngadagua pele ngibe.  
\q1 Ani beregola wali agali dindi bibahendeni karumebi  
\q2 í̠naga hame ogobi wiyada manda bilo ani bibe.  
\q1 Hameigini tara tara paluyu pedaru bibahendemebi  
\q2 í̠na ti pele mirida manda bilonaga ani bibe.   
\b  
\q1
\v 3 Ngode Datagaliwabe-o wali agali karume  
\q2 í̠naga mini mo yaraga helo hameledo.  
\q1 Wali agali bibahendeoreme í̠naga mini mo yaragaore helo hameledo.   
\b  
\q1
\v 4 Hameigini tara tara paluyu pedarume\x + \xo 67.4 \xt Iba 96.10, 96.13, 98.9\x*  
\q2 tinaga miniha turu halu yanga lowa iba gana lelo.  
\q1 Í̠na wali agali tale nabi bibahendehondo ogobi dege dege biaga kegonaga ani lelo.  
\q1 Dindi bibahendeni hameigini paluyu pedamaru  
\q2 í̠na bayuwaore haru hariligonaga iba gana lo ngilo hameledo.   
\b  
\q1
\v 5 Ngode Datagaliwabe-o wali agali karume  
\q2 í̠naga mini mo yaraga helo hameledo.  
\q1 Wali agali bibahendeoreme  
\q2 í̠naga mini mo yaragaore helo hameledo.   
\b  
\q1
\v 6 Dindini tomo hangaramaru damene bibahende anda haragola nalu kamagoni.\x + \xo 67.6 \xt LBM 26.4, Iba 85.12\x*  
\q1 Ngode Datagaliwabe inanaga Ngode Datagaliwabeore kago  
\q2 ibugua ina mo gumbila hayagome  
\q2 ina turu halu dungulo kamagoni.   
\b  
\q1
\v 7 Ngode Datagaliwabehanda inahondo turu howa mo gumbila halu kagoni.  
\q1 Wali agali ona kaware karumebi dindi lene leneha paluyu pedarumebi  
\q2 bibahendeme ibunaga mini mo yaraga haiore helo hameledo.   
\c 68  
\s1 Isaraele wali agali ti Ngode Datagaliwabehanda biamogo biyagonaga turu halu iba gana lenego ogo  
\q1
\v 1 Ngode Datagaliwabe ibuni abale heyalu ibunaga waitigi bu karu talia togo laragoni.  
\q2 Ibuhondo handabe manga haga karu ti ibida piai haragoni.   
\q1
\v 2 Puyabume hagua pulo yalu purogo lagadagua dege  
\q2 Ngode Datagaliwabehanda waitigi bu karu bo taliatogo lai haragoni.  
\q1 Wagaya ira dene hondowa elalu ereba hagadagua  
\q2 wali agali ko karu Ngode Datagaliwabenaga deni howa mo ko hai haga.   
\q1
\v 3 Wali agali mini tigabi karu ti dege turubiore howa  
\q2 Ngode Datagaliwabenaga deni miniha dungulo halu ti turu timbuni ho haga.   
\b  
\q1
\v 4 Ngode Datagaliwabehondo iba gana ladaba.  
\q2 Ibunaga mini yaraga halu iba ganaru lalu holene nga.  
\q1 Ibu hari beralibani biralu piaga kago ibilo  
\q2 hariga mo tiga bia holene nga.  
\q1 Ibunaga mini Anduane Homogo ka.  
\q1 Iname ibunaga deni howa turu hami̱ya.   
\b  
\q1
\v 5 Ngode Datagaliwabe ibu ibuni andagaha howa\x + \xo 68.5 \xt Iba 10.14, 10.18, 146.9\x*  
\q2 ibugua waneigini aba ai̱yala homene karubi  
\q2 wali dalo agalini homene bedarubi  
\q2 ti bibahende handayaho haga ka.   
\q1
\v 6 Wali agali tini hangu haga karu\x + \xo 68.6 \xt 1 Sml 2.5, Iba 107.10, 107.34, Ab 12.6\x*  
\q2 ti anda mo migi bialu bayale berelaga ka.  
\q1 Wali agali garabaya bu helene karu ti golope howa  
\q2 ibugua tini daluha haru dai bialu ti turu ho helo helaga biaga.  
\q1 Agali doga haga bu karu ti dindi ko yobi iba dalu naibaga ngagoha  
\q2 pu haabobo bu holebira.   
\b  
\q1
\v 7 Ngode Datagaliwabe-o bamba í̠na í̠naga wali agali haru tagira ibalu  
\q2 ti dindi ko wali agali nahaga wiagoha haru halu ibirigoni.   
\q1
\v 8 Horo ogoningi Ngode Datagaliwabe ibu Hari Sainai ala íbu hariligoria áyu íbu kegoni.\x + \xo 68.8 \xt Har 19.18\x*  
\q1 Isaraele wali agalinaga Ngode Datagaliwabe í̠ni ibirigola dindi dumbirumbi bialu  
\q2 hari daligaha howa iba dalu timbuniore ibiniya.   
\q1
\v 9 Ngode Datagaliwabe í̠nime í̠naga dindini iba dalu timbuniore ibilarigola  
\q2 dindi ala ko wiyago lone mo bayale harigoni.   
\q1
\v 10 Í̠naga wali agali ti dindi ogoni karulayagoni.\x + \xo 68.10 \xt Man 26.5, 26.9, Iba 74.19\x*  
\q1 Í̠ baya gibiore kegome  
\q2 wali agali burupale hearuhondo tomo dabudaburubi migi birigoni.   
\b  
\q1
\v 11 Anduane Homogohanda bi layagola  
\q2 wali dewa biru wiarume bi te uruni lamima piyagoni.   
\q1
\v 12 Bi te lamima piyadagoni ogodagua,  
\q2 Kini karu heba tinaga ami bu karubi bibahende ibida piai haragoni.  
\q1 Agali tigua wai labuha howa mbirale mo yalu ibiyaru  
\q2 wali andaga berearu baba talebu ta haga biya.   
\q1
\v 13 Ega malibu ale silibame wabiniru babagane ngolome hoai laradaguabi wiaru  
\q2 tigua mo tale bigi bini.  
\q1 Ainde irane agome agali maru wai nape  
\q2 pabeha nogo sibi heba hayabe, laga biya.   
\q1
\v 14 Ngode Datagaliwabe Hongo Haiheore kagome  
\q2 Hari Salamono ogoniha kini hearu bo taliatagi halu purogo lelowa  
\q2 ibugua dalu dindi guni timbuni hari ogoniha ibilaya.   
\b  
\q1
\v 15 Hari Basananaga ibu hari timbuniore weda.  
\q1 Hari ogoninaga hombene bolebolene dalidali bigi bida.   
\q1
\v 16 Hari timbuni hombene dewa bolebolene hagahagabi kego-o  
\q2 í̠na hari emene Ngode Datagaliwabe ibuni birulenaga dabo heledago de hondowa  
\q2 irane aginaga henge larebe.  
\q1 Anduane Homogo ibu hari ibuni dabenego ogoniha haabobo bu holebira.   
\b  
\q1
\v 17 Anduane Homogo ibuni Hari Sainai wahalu  
\q2 ibuni anda loma bia hene biagoha íbu kagoni ndobe.  
\q1 Ibunaga ami agaliru wai biaga garo ale nogo hosime gililo yalu piaga mini karisiru  
\q2 daosini dagalabe nahe dewaoreni hagahaga bialu ti haru ibiyagoni.   
\q1
\v 18 Ngode Datagaliwabe ibu ibunaga hari daligaore wiagoria iraga halu\x + \xo 68.18 \xt Eb 4.8\x*  
\q2 agali dewaore minalu haru halu piya.  
\q1 Agali dogahe wai biaga hearume  
\q2 ibu mo turu halu mbirale migi biyaru mo yaya.  
\q1 Anduane Homogo Ngode Datagaliwabe ibuni hari daligaore ogoniha haabo holebira.   
\b  
\q1
\v 19 Iname Anduane Homogonaga mini yaraga hami̱ya.\x + \xo 68.19 \xt Iba 55.22, 65.5, Ais 46.4\x*  
\q1 Ibugua inanaga genda ngelo kamaru  
\q2 horo bibahendengi ya haga kagoni.  
\q1 Ina pele ngialu mo wiaga Ngode Datagaliwabe ibuni hanguore kagoni ndobe.   
\q1
\v 20 Inanaga Ngode Datagaliwabe ibunime ina pele ngialu haabo kagome\x + \xo 68.20 \xt Man 32.39, Iba 49.15, 56.13, 106.43\x*  
\q2 ina bayale kamagoni.  
\q1 Anduane Homogo ibu inanaga Anduane Homogo kago  
\q2 ibugua ina homa nabi bayale holoma̱yanaga pele ngiaga kagoni.   
\b  
\q1
\v 21 Ngode Datagaliwabehanda ibula waitigi haga karubi  
\q2 mana ko ngaru hangu mo tene haga karubi  
\q2 ti bibahende bo wahai holebira.   
\q1
\v 22 Anduane Homogohanda lalu,  
\q2 Tínaga waitigi amu Basana dindini bu karu minu yudai bulebero.  
\q1 Ti unuraore iba solowara timbuni bedago andanehaore heaguabi  
\q2 harugo lowa i̱na minu yudaiore bulebero.   
\q1
\v 23 Tínaga waitigi uruni baiore howa tí bu miniha dungulo halimulo  
\q2 tínaga biango bu karume waitigi uruninaga darama na dege bialu no karulapelobi  
\q1 i̱na ani minu yudai bulebero, laya.   
\b  
\q1
\v 24 I̱naga Ngode Datagaliwabe-o í̠na wai bialu wayali harigo de hondowa  
\q2 manda bu kama.  
\q1 Ngode Datagaliwabe i̱naga kini kego  
\q2 í̠ninaga anda loma bia heneha turu halu anda porego  
\q2 ina bibahendeme de handai ho kama.   
\q1
\v 25 Iba gana lagarume bamba halu  
\q2 ngida ale lagaru ti maha ibiragoni.  
\q1 Wandarime irabitele ale maru yuwa tigua bama dombeni ibiragoni.   
\q1
\v 26 Tigua iba gana laraga halu howa lalu,  
\q1 Wali agali íbu ngoaiho kamarume  
\q2 inanaga Ngode Datagaliwabenaga mini yaraga hama.  
\q1 Ina Isaraele wali agali bu kamarume  
\q2 Anduane Homogonaga mini mo yaraga hama, lama ibiragoni.   
\q1
\v 27 Beniyamini hameigini emene hayaru tigua mo bamba hara.  
\q1 Yuda hameigininaga agali haguane bu hearu  
\q2 tigua Beniyamini hameigini erembiraha pora.  
\q1 Sebulunu hameiginibi Nabadali hameigini tinaga haguane bu hearubi  
\q2 tigua o piyaru mama talima poragoni.   
\b  
\q1
\v 28 Ngode Datagaliwabe-o í̠ninaga hongo inahondo mo walia habe.  
\q1 Bamba í̠naga hongo ogonime ina mo wirigonigo áyu walia habe.   
\q1
\v 29 Í̠ni anda Yarusalemeha kagoria  
\q2 kini tara tara bu hearume í̠ mo turu hole  
\q2 mbirale mbirale bame í̠hondo ngule mo yalu ibiragoha howa  
\q1 í̠na í̠naga hongo walia habe.   
\q1
\v 30 Nogo gabua timbuni iba puguaha haga biago hongo howa talibe.\f + \fr 68.30 \ft Agali marume mitangibu handalu hearia nogo gabua iba puguaha haga layadagoni Iyibi dindihondo lene bada lomanda biya.\f*  
\q1 Nogo bulumaga wangaberu bulumaga igini heba haradagua helaga karubi  
\q2 hongo howa talibe.  
\q1 Tinaga muni siliba yu karu í̠hondo ngialu í̠ni kegoha ibalu  
\q2 bulupalialu ge duli hanga helonagaore  
\q2 í̠na hongo howa talibe.  
\q1 Hameigini tara tara wai bule hamelo karu  
\q2 ibida bilibulu purogo lelo bo taliatagi hai habe.   
\q1
\v 31 Iyibinaga kinime ibunaga agali haguane bu karu ti  
\q2 í̠naga bi larego hale helo Yarusalemeni ibilaga bulebira.  
\q1 Idiobialirume gi yaragaho howa í̠hondo bi lolebira.   
\b  
\q1
\v 32 Wali agali dindi tara tarani bu kamiru aibe.  
\q1 Tígua Ngode Datagaliwabehondo iba ganaru lagalaga bidaba.  
\q2 Anduane Homogonaga mini yaraga halu iba gana ladaba.   
\q1
\v 33 Mbirali ibu hari daligaha beralibani ge halu piaga kago  
\q2 ibunaga mini yaraga hadaba.  
\q1 Ibunaga bi hongo howa hari kulu laradagua biaruago hale hadaba.   
\q1
\v 34 Wali agali bu kamiruni bibahendeme  
\q2 Ngode Datagaliwabenaga hongo timbuni kago lalu latagi halu hadaba.  
\q1 Isaraele wali agalirunaga kini daligaore ibu kagoni.  
\q1 Ibunaga hongo taraore hari daligani walia harane de hondo kama.   
\q1
\v 35 Ngode Datagaliwabe-o í̠ tara baya burugule gibiore howa  
\q2 í̠ninaga anda loma bia heneha kegoni.  
\q1 Isaraele wali agalirunaga Ngode Datagaliwabe ibugua  
\q2 ibunaga wali agali bu karuhondo hongo miaga ka ndobe.  
\q1 Ina Ngode Datagaliwabe mini yaraga hai hami̱ya.   
\c 69  
\s1 Mbiralime Ngode Datagaliwabehondo biamogo bia lalu bi lenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o i̱ gi mibe.\x + \xo 69.1 \xt Iba 69.2, 69.14-15, Yna 2.5\x*  
\q1 Iba birama irayagola ai ibame namu lelo ma paho kogonigo gi mibe.   
\q1
\v 2 Waru lumburani hewaria unura waruha yalu anda porane kogoni.\x + \xo 69.2 \xt Iba 40.2\x*  
\q1 Ge hade holene dindi giambe mbira nawida.  
\q1 Iba uli bereagoha ge hape halu ko.  
\q1 Ani bialu koria iba yaribu bu yu ibalu i̱ bu dambi haragola  
\q2 iba nalu homole kogoni.   
\q1
\v 3 Ai homaore biruda handala Ngode Datagaliwabe-o  
\q2 í̠na i̱ biamogo bibelonaga i̱na í̠ o dege lalu hewane ai i̱naga kembobe pu kagoni.  
\q1 Í̠ eberebe hondole lowa  
\q2 de handayaho wia dege biwane  
\q2 ai i̱naga de tandaga bialu hongo bibahende pirilipe kagoni.   
\b  
\q1
\v 4 Wali agalime irane nawioreni i̱ bame handabe manga haga karu  
\q2 ti dewaore daga labe nahe kagoni.  
\q1 I̱naga haguaneni mandari li bu karuni goyane lowa  
\q2 ti dewaore daga labe nahe kagoni.  
\q1 I̱naga waitigi urunime tindule i̱na agua biya lalu ti bi degeme mo para halu kagoni.  
\q1 Tigua hongo gibi howa i̱ bo waore hole manda bialu kagoni.  
\q1 Ti bi degeme i̱ kayu nabini wiwago tindule, Í̠ kayu biri, lalu ka.  
\q1 Ti bime mo para hayagola mbirale i̱naga wiwago irane nawini bameore ti mirugoni.   
\q1
\v 5 Ngode Datagaliwabe-o i̱na i̱ ko nabiaga kogoni lalu ndo laro.  
\q1 I̱ ko biaga dege ha kogonigoyu nde i̱na ko biruruni mbira í̠ deni wia do hene nawi  
\q2 tigatiga binigobi lapani hai harugoni ndobe.  
\q1 I̱ mini nawi howa birurubi í̠ manda biai ho kegoni.   
\q1
\v 6 Anduane Homogo í̠ Hongo Haiheore howa Bibahende Haru Haame Ho Haga kegoni.  
\q1 I̱na mana ko mbira berogome wali agali í̠ni hana ho karu taga helo mbira buligo  
\q2 í̠naga gime i̱ yaniore habe.  
\q1 Isaraele wali agalinaga Ngode Datagaliwabe í̠ kegonigo  
\q2 i̱na mana ko berorume wali agali í̠ mitangi bialu lotu laga karu  
\q2 taga halu de handa dindi hai helo i̱na mbira buligo  
\q2 í̠na i̱ mamage habe.   
\q1
\v 7 I̱na í̠ talima ibalu kogonaga wali agalime i̱ lo guralu mege bialu i̱ mo taga halu kagoni.   
\q1
\v 8 I̱ninaga hameneorerume i̱ kogoni agali tara dindi tarali ka manda bidagola kogoni.  
\q1 I̱ninaga aba ai̱ya hamene mbalinirume i̱ kogoni tiha howa tagira peneda ndo  
\q2 agali tara mbira dindi kaundiali íbu kagoni ledaha kogoni.   
\b  
\q1
\v 9 Í̠naga anda bayale haabo helo i̱na hame timbuni lalu kogome\x + \xo 69.9 \xt Yo 2.17, Lm 15.3\x*  
\q2 i̱naga bu habaneha ira daradagua biragola haruli.  
\q1 Wali agali karume í̠ mege bialu bi laga biragoni i̱ni laba halu kagoni.   
\q1
\v 10 Í̠naga deni i̱nime i̱ni mo dindiha halu \w tomo\w* nane haruli.  
\q1 Ani berogola wali agalime hondowa i̱ mege bialu lo guraga.   
\q1
\v 11 Dara howa duguanda howa aga biaganedagua bu kogola  
\q2 tigua i̱ hondo oba halu lo guraga.   
\q1
\v 12 Ti hariga hariga mo mogobu kago howa i̱ kedalu dege lalu kagoni.  
\q1 Lulu iba nowa tibaga lowa karumebi  
\q2 ti ne harigaha howa iba gana ende haga bialu laga birago  
\q2 i̱ lo guralu hangu laga biragoni.   
\b  
\q1
\v 13 Ti ani lo helowa i̱na Anduane Homogo í̠hondo bi lolebero.  
\q1 Ani larogo hale halu Ngode Datagaliwabe-o í̠nime ogoangi ladai bule lo manda bidengi ladai bibe.  
\q1 Í̠na hale halu ladai bulebeda lo manda bidogo irane  
\q2 í̠na i̱ gubalini timbuniore ho kego manda bidogome.  
\q1 Ani bialu í̠ ke̱ nahagaore kego manda buwa  
\q2 heneneore i̱ pele ngulebereda lo manda bu kogoni.   
\q1
\v 14 Waru lumburani kogola ge namulai halu i̱ni waruha anda piai habehe bu hinarago  
\q2 í̠na i̱ gi mibe.  
\q1 I̱naga waitigirume i̱ bo waholigo  
\q2 í̠na i̱ de hondo habe.  
\q1 Iba uli ngagoha i̱ ibaha namulai holigo  
\q2 í̠na i̱ de hondo habe.   
\q1
\v 15 Iba li timbuni ibiragome i̱ namu lalu hilu yalu poligo  
\q2 í̠na i̱ de hondo habe.  
\q1 Iba uli bedagoha i̱ namu lolani  
\q2 í̠na i̱ de hondo habe.  
\q1 Homalime i̱ mo mbedogo buligo í̠na i̱ de hondo habe laro.   
\b  
\q1
\v 16 Anduane Homogo í̠na i̱ horo bibahendengi gubalini haho wiaaboore haga kegome  
\q2 i̱na bibe larogo hale halu ladai bibe.  
\q1 Í̠naga gubalini haho wiaabo holene ogoni mana bayaore gibi ogoniya.  
\q1 Í̠naga dara holene gibi ngegome i̱ handaya halu  
\q2 i̱na bibe larogo hale halu ladai bibe.   
\q1
\v 17 Í̠naga biabe bia haga o kogo ko handala í̠ ha do nahabe.  
\q1 I̱ genda timbuniore yu kogonigo  
\q2 i̱na bi larogo hale halu áyu ogoni abale ladai bibe.   
\q1
\v 18 Áyu ogoni i̱ kogoria kaware ibalu i̱ gini mibe.  
\q1 I̱naga waitigi karume ibalu i̱ yani nakaore  
\q2 í̠na abale ibalu i̱ gini mibe.   
\b  
\q1
\v 19 Agali bu karume i̱ mege bialu lo guralu karu í̠ mandabide.  
\q1 Tigua i̱ mo taga halu mo yo hondo wahalu ti ge waraha heledagoni í̠ de hendedegoni.  
\q1 I̱naga waitigi bibahende karu í̠ de handaiore ho kegoni.   
\q1
\v 20 Tigua i̱ mege biyago mitangi bialu hewaria\x + \xo 69.20 \xt Yob 16.2, Iba 142.4, Ais 63.5\x*  
\q2 i̱naga miniha genda gibi halu i̱naga gubaliniore tumbudu bidagoni.  
\q1 Hongo mbira hole ndo aiore hongo pirilipe haiho kogoni.  
\q1 Ai i̱ darahe mbiraorebi nde holebira lo manda biwaria mbira naholeoreya.  
\q1 I̱naga mini mo dungulo dai bulene bi lolene mbira holebirabe toba hewaria  
\q2 mbiraoreorebi mbira naholeoreyane handaru.   
\q1
\v 21 I̱ tomo garibilo hewaria tomo kaubi tara mbira na lalu ngiya.\x + \xo 69.21 \xt Md 27.48, Mg 15.36, Lg 23.26, Yo 19.28-29\x*  
\q1 Iba noaho harugola \w waini\w* iba ko kaubi na lalu hambu ngiya.   
\b  
\q1
\v 22 Ani biyago ti turu halu tomo timbuni dawa payabu nalu bedaria tini ogoningi homai nahara.\x + \xo 69.22 \xt Lm 11.9-10\x*  
\q1 Turu ogoriani hairi halu tomo loma bini ngaru narolo manda bidaria  
\q2 bibahende homa hilai nahara.   
\q1
\v 23 Uruni bibahende arumaha luluyu helo ti bibahendenaga de mo ndibulai habe.  
\q1 Ti bibahende ere pode ulahe helo  
\q2 tinaga erene kuni mo gedaore haabo habe.   
\q1
\v 24 Í̠na tihondo keba timbuniore halu ti mini wilo mana halu mbira labe.  
\q1 Í̠naga keba holeneme ti bo ereba hai helabe.   
\q1
\v 25 Ti balai anda karuha mbiraorebi mbira yu waheloleni.\x + \xo 69.25 \xt Ab 1.20\x*  
\q1 Bibahende bo mburi labe.  
\q1 Balai andaru ti haradago bame dabulu ngelabe.   
\q1
\v 26 Agali maru ti ala ko biyagola í̠na ti pani mini hayaruni  
\q2 ai agali ko biaga karume agali o biaruni lone áyu mo tandaga halu ka.  
\q1 Ani bialu agali maru ala ko biyagola  
\q2 í̠na ti pani mialu tinginini motudu wilarigo  
\q2 agali biaruni áyu agali ko biaga karu tigua lone mege bialu mo tandaga halu ka.   
\q1
\v 27 Agali ko biaga uruni tigua ko biraru bibahende  
\q2 í̠na baya hangu de hondo howa ilu wigi bibe.  
\q1 Ko biaga uruni mbiraligo í̠naga waneigini pele miniyi karuhayagi anda ibulani.   
\q1
\v 28 Ko biaga uruni tinaga mini haabo holenenaga mbugani gilibu wulani domo wahabe.\x + \xo 69.28 \xt Har 32.32, Mo 3.5, 13.8, 17.8\x*  
\q1 Í̠naga wali agali mini tigabiwi karunaga mini gilibu ngegoria  
\q2 ko biaga uruninaga miniore mbira mbuga ogoriani gilibu wulani.   
\b  
\q1
\v 29 Ai i̱ genda timbuniore yuwa tandaga nalu kogoni.  
\q1 Ngode Datagaliwabe-o í̠na i̱ gini mialu lone mo heyu helabe.   
\q1
\v 30 I̱na iba gana mbira lalu Ngode Datagaliwabenaga mini mo yaraga holebero.  
\q1 I̱na ibuhondo ka̱i̱ lalu ibu timbuni daligaore gibi ogobi ka lalu maru lamulebero.   
\q1
\v 31 Ogonidagua berogo hondowa Anduane Homogo ibu turuore holebira.  
\q1 Nogo bulumaga dewaru bo lomabu merogo hondowa turu hagadagua ndo  
\q2 ibugua turu timbuniore holebira.  
\q1 Bulumaga wangabe habaheore timbunigo bo lomabu mialu delaruyaguabi hondowa  
\q2 ibugua turu emene holebirago  
\q2 o larogodaguaore biruyagua turu timbuniore holebira.   
\q1
\v 32 Wali agali gendayu karume ogonidagua berogo hondowa ti turu holebira.  
\q1 Wali agali Ngode Datagaliwabe dunini kago mitangi bialu lotu laga karu  
\q2 ti turu halu miniha elahe holebira.   
\q1
\v 33 Anduane Homogo ibugua wali agali mbirale buru pale karume  
\q2 ibuhondo bi larago hale halu biamogo biaga ka.  
\q1 Ibugua ibunaga waneigini garabaya andaha karubi embeda nahaga ka.   
\b  
\q1
\v 34 Hari daligabi dindibi iba solowarabi mbirale iba solowaraha bedarubi  
\q2 tí bibahendeme Ngode Datagaliwabenaga mini mo yaraga hai halimu.   
\q1
\v 35 Ngode Datagaliwabehanda ibunaga Yarusaleme wali agali pele mialu  
\q2 Yudanaga tano mo ko hene ngaru lone bia aribia holebiragonaga  
\q2 tigua ibunaga mini mo yaraga holene nga.  
\q1 Ibunaga wali agali ti turu halu tano odaruniha ho halu  
\q2 dindi ogoni ti karulalu tinagaore holebira.   
\q1
\v 36 Ibunaga biabe biaga karunaga waneigini aguane mani hararume  
\q2 dindi ogoni karulolebira.  
\q1 Wali agali ibu gubalini heneneore haga karume  
\q2 dindi ogoni karulowa haabo holebira.   
\c 70  
\s1 Ngode Datagaliwabehanda biamogo bilonaga bi lenego ogo  
\r (Iba Gana 40.13-17)  
\q1
\v 1 Ngode Datagaliwabe-o ainde i̱ore pele ngibe.\x + \xo 70.1 \xt Iba 40.17, 141.1\x*  
\q1 Anduane Homogo-o í̠na áyu ogoni i̱ biamogo bule íbu.   
\q1
\v 2 Agali marume i̱ homelo bo wahole karu tiore taga halu pelo  
\q2 í̠na ti bope halu mo luluya habe.  
\q1 Agali marume i̱ genda yu kogonaga turuho karu  
\q2 í̠na ti taliai halu tinaga mini bope halu mo dindiha ho helabe.   
\q1
\v 3 Agali i̱ mege bima ibaga bialu karuni  
\q2 mana tinime bialu karu nagalone bialu harimada lowa mogolo hendelo  
\q2 í̠na ti mo taga habe.   
\b  
\q1
\v 4 Wali agali í̠ keria ibaga karu  
\q2 ti dege turubi howa í̠niha mini hanaho helo.  
\q1 Wali agali í̠nime pele mirigonaga turu haga karu  
\q2 uruni tigua bibahendengi laabo halu lalu,  
\q2 Ngode Datagaliwabe ibu duniniore ka, lalu helo.   
\b  
\q1
\v 5 Ngode Datagaliwabe-o i̱ninaga hongo nakarulape kogonigo  
\q2 i̱ koria abale ibabe.  
\q1 I̱naga Anduane Homogobi Pele Ngiagabi í̠niore kego  
\q2 i̱ biamogo bule emene handayaha nabi abaleore ibabe.   
\c 71  
\s1 Agali waheme bi lenego ogo  
\q1
\v 1 Anduane Homogo-o i̱ í̠la mandagi haabo kogola\x + \xo 71.1 \xt Iba 31.1-3\x*  
\q2 waitigi karume i̱ mo ko habe nahe ko.  
\q1 Tigua i̱ bope halu wayali helo yupe nahabe.   
\q1
\v 2 Í̠ tigabiore kegonigo  
\q2 i̱ waitigirunaga giha koria pele ngialu haru dai bibe.  
\q1 I̱na bi larogo hale halu i̱ pele ngibe.   
\q1
\v 3 I̱naga wai pabe hongohe alebi anda hongohe alebi í̠ habe.\x + \xo 71.3 \xt Iba 18.2, 42.8, 90.1, 91.9\x*  
\q1 I̱ ibida pialu í̠ha dege ha do hole eberogola handayaho habe.  
\q1 Í̠nime dege i̱ baya hangu handayaho kegola i̱ bayale holebero.   
\b  
\q1
\v 4 I̱naga Ngode Datagaliwabe-o agali mini kowi karunaga giha koria  
\q2 i̱ haru dai bibe.  
\q1 Agali hongoheore tara howa mana koorene ko ngago biaga karunaga giha kogola pele ngibe.   
\q1
\v 5 Anduane Homogo Bibahende Haru Hame Ho Haga-o  
\q2 i̱ í̠ha mini dunubia ho kogoni.  
\q1 I̱na igiri daliaheni howa í̠hondo mini mbiraore wu henego kogoni.   
\q1
\v 6 Bibahendengi i̱na í̠ha hanaho harugo kogoni.  
\q1 I̱ ai̱yahanda taba hanayangi howa í̠na i̱ handayaho haabo harigoni.  
\q1 Ani harigonaga i̱na í̠naga mini yaraga halu haabo holebero.   
\b  
\q1
\v 7 Wali agali bu hearu dewalime i̱ de hondowabi  
\q2 í̠na i̱hondo biriru hondowabi  
\q2 í̠na i̱ hongo howaore handayaho kagonida lomanda biai ho ka.   
\q1
\v 8 Horo bibahendengi i̱na wali agali bu karu hendelo í̠naga mini yaraga halu  
\q2 í̠ mini leneore kegoni latagi halu haabo haruli.   
\q1
\v 9 Áyu i̱ agali waheore howa hongo hodai bule ndo biru ngogo\x + \xo 71.9 \xt Iba 92.14, Ais 46.4\x*  
\q2 í̠na i̱ erembira ngialu yu waholeni nahabe laro.   
\q1
\v 10 I̱ waitigi bu hearu tigua i̱ bo waholenaga  
\q2 mo mogobu howa ndelalu kagoni.   
\q1
\v 11 Tigua lalu, Ngode Datagaliwabehanda agali ogoni yu wahayadago abale minami̱ya.  
\q1 Ibu biamogo bulene mbira naheoredago  
\q2 iname abale talima pugupugu bialu minu yania hami̱ya,  
\q1 laga bialu kagoni.   
\b  
\q1
\v 12 Ngode Datagaliwabe-o i̱ hangu helalu í̠ kaundia nahabe.\x + \xo 71.12 \xt Iba 22.11, 38.21-22, 70.5\x*  
\q1 I̱naga Ngode Datagaliwabe-o í̠na i̱ biamogo bule abale ibabe.   
\q1
\v 13 Agali i̱hondo bi laedede bialu karuni  
\q2 í̠nime ti bope halu ereba hai helabe.  
\q1 Tigua i̱ mo ko hole wai hanalu kago  
\q2 ai tini taga helo mo ko hai halu mo luluya ho helabe.   
\q1
\v 14 Anigo í̠na i̱ biamogo bibelonaga í̠hondo mini dunubia ho kogoni.\x + \xo 71.14 \xt Iba 130.7\x*  
\q1 I̱na í̠naga mini yaragaore haabo holebero.   
\q1
\v 15 Í̠na mana tigabi bigi biriruni wali agali bu karu lamialu holebero.  
\q1 Í̠na pele ngialu haru dai biriruninaga tene i̱ manda biai nahego  
\q2 nde harugo lowa te ogoni horo bibahendengi tihondo lamiaabo holebero.   
\q1
\v 16 Anduane Homogo Ngode Datagaliwabe kego í̠ hongo timbuniore kegonaga  
\q2 i̱na í̠naga mini yaraga halu holebero.  
\q1 Í̠ni hangu mana bayale tigabiore biaga kego lalu  
\q2 i̱na latagi halu holebero.   
\b  
\q1
\v 17 Ngode Datagaliwabe-o i̱ bamba igiri emeneni hewangi  
\q2 í̠na i̱ lawai haabo hariligoni.  
\q1 Áyubi nde í̠na mbirale bayale tara tara bererunaga  
\q2 i̱na latagi halu haabo kogoni.   
\q1
\v 18 Ainde i̱ agali waheore halu i̱naga mandariru daguame be duguame haradagua biyadago\x + \xo 71.18 \xt Iba 22.31, 78.4-6\x*  
\q2 Ngode Datagaliwabe-o í̠na i̱ yu wanahabe laro.  
\q1 I̱na wali agali mani holobadaruhondo í̠naga hongo timbuni ogobiore ka lalu lamigi buliya  
\q2 í̠ni i̱la haabo habe.   
\b  
\q1
\v 19 Ngode Datagaliwabe-o í̠na mana bayale tigabi biriruni  
\q2 wali agali bibahendenaga deni panigi wiai ka.  
\q1 Í̠na biabe hongohe timbuniore bini ngegoni ndobe.  
\q1 Agali dindini hene karu í̠ ale mbira nahe  
\q2 í̠ni hangu bolangua haiheore kegoni.   
\q1
\v 20 Í̠na i̱ha genda tandagabi tara tara ibilaga birigoni.  
\q1 Í̠nime i̱ lone mo hongo holebere lo manda bu kogoni.  
\q1 I̱ homaliha ngoria í̠nime i̱ lone mo heya holebere.   
\q1
\v 21 Í̠na i̱ mini lene winigo mo yaragaore ho ngelalu  
\q2 i̱naga bu miniha mo palia holebere.   
\b  
\q1
\v 22 I̱naga Ngode Datagaliwabe-o í̠naga mini bilinahe haabo kegonaga  
\q2 i̱na ngida ale balu í̠naga mini yaraga halu iba gana lolebero.  
\q1 Isaraele wali agalinaga Ngode Datagaliwabe baya buruguleore kego  
\q2 i̱na ngida ale balu í̠naga mini yaraga halu iba ganaru lalu holebero. \fig Ngode Datagaliwabe ... i̱na ngida ale balu í̠naga mini yaraga halu iba ganaru lalu holebero.|src="Lear 045.tif" size="1" ref="(71.22)" \fig*   
\q1
\v 23 I̱na lalu howa turu timbuniore halu bi hongo howa ladaga holebero.  
\q1 Í̠na i̱ pele ngialu mo wirigonaga  
\q2 i̱na ne hariga hangume ndo  
\q2 i̱naga minimebi gubalinimebi í̠hondo iba gana lalu latagi holebero.   
\q1
\v 24 Agalime i̱ mo ko hole wai hanalu henego  
\q2 ai tini ko halu mo taga hai hayagonaga  
\q2 i̱na horo bibahendengi í̠naga mana bayale tigabi biaga kego lalu  
\q2 wali agali bu karuhondo lamiai holebero.   
\c 72  
\s1 Kini kagonaga Ngode Datagaliwabehondo bi lahenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o kini kagome í̠naga mana tigabi bulene ngeru bayuwa manda bilo biawai habe.  
\q1 Mana tigabi bulenego bayuwa manda buwa wali agalime godi lararu  
\q2 ibugua hale howa tigabiore dabaki bilo biawai habe.  
\q1 Í̠na tigabiore dabaga kedagua kini ibuguabi wali agalinaga godi larago hale halu  
\q2 tigabi dege dabaga helo biawai habe.   
\q1
\v 2 Í̠na biawai haregola ibugua mana tigabi bulene manda buwa  
\q2 í̠naga wali agali karu ibugua bayuwa hondo helo.  
\q1 Wali agali yagibano darabi karu agali hongohe karume hengedope haragola  
\q2 dindiha haga karuhondo mana tigabi bialu haru helo.   
\q1
\v 3 Wali agali tinime mbirale bigi birago bayale helobi  
\q2 tinaga mini dungulo haabo helobi biamogo bibe.  
\q1 Tigua mana tigabi hangu bigi bigi bialu haabo helo helabe.   
\q1
\v 4 Kini kagome wali agali yagibano darabi karunaga genda yu karu handalu yamogo bialu  
\q2 yagibanorume buru pale ka aleru biamogo bialu mo milo hameore ledo.  
\q1 Wali agali yagibano darabi uruni hengedope haga agali ko karuni tinde kini agali ibugua warape halu hengedo mbaralo wahelo hameore ledo.   
\q1
\v 5 Ni dedago dalu kaore ege dedagobi dalu wá kaore  
\q2 í̠naga wali agali bu karume í̠ mo dunini halu mitangi bialu lotu laabo helo hameledo.   
\q1
\v 6 Kini ibugua mana bayale biragome dalu ibuwa mabuni tomo hengedaru damume haragola tomo bayale anda hagadagua  
\q2 wali agali bu karu ibunaga maname anda helo í̠na kini kago mo bayale habe.   
\q1
\v 7 Ibu kini kangi wali agali bu karuha mana tigabi bulene dungume halu anda helo.  
\q1 Ege dalu kangi mbirale bigi birago lini dalu bayale haga bilo biamogo bibe.   
\b  
\q1
\v 8 Kini ibugua handame howa haru holenego  
\q2 wali agali iba solowara biru paluyu pedaru bibahendeoreyagi howa paluyu pialu\x + \xo 72.8 \xt Seg 9.10\x*  
\q2 solowara ange ederayagi karu bibahende ibugua handairi holebira.  
\q1 Wali agali dindini paluyu pedarubi bibahende iba Yuberedisi duguaragoria howa paluyu pialu  
\q2 dindi wia maroha wali agali palumaro bidagoria handairi holebira.   
\q1
\v 9 Wali agali dindi ko ege kelekele wini haga karume  
\q2 kini ogonihondo bulu palialu ti kini ogoni ibu andaneha holebira.  
\q1 Kini ogoni ibunaga waitigi karu tinime dindini mbala puwa mo ko howa palipe holebira.   
\q1
\v 10 Sebenanaga kini kagomebi kini maru iba solowara biruyu mabu bilowa dindi dombeneha ngarunaga karumebi  
\q2 tigua kini ogonihondo mbirale debene maru ibu mo turu halu mulebira.  
\q1 Arebia dindinaga kini kagomebi Idiobia dindinaga kini kagomebi  
\q2 libugua mbirale debeneru mo mogobu yalu ibuwa kini ogoni dege mulebira.   
\q1
\v 11 Kini bibahendeore karume ibu wanakuiha tinaga ge duli podalu bulu paliai holebira.  
\q1 Hameigini tara tara dindi bibahendeni hoyu pedaru bibahendeoreme  
\q2 kini ogoni ibunaga biabe bia hai holebira.   
\b  
\q1
\v 12 Ani bulebirago irane wali agali yagibano darabi karume kini ogoni olaragola  
\q2 ibugua tinaga bi hale halu biamogo biagaore ka.  
\q1 Wali agali maru buru paleore marume namiaga hondo wahene karu  
\q2 kini ogoni ibunime de handalu migi biaga ka.   
\q1
\v 13 Kini ogoni ibugua wali agali hongo naheru mbirale nawi yagibano darabi karu daraore halu  
\q2 ibunime ti biamogo biaga ka.  
\q1 Wali agali mbirale nawi buru paleore karu  
\q2 ibunime ti gi miaga ka.   
\q1
\v 14 Maru mini kowi karume wali agali darabi urunibi karu hengedope halu mo ko hole bialu karia\x + \xo 72.14 \xt Iba 116.15\x*  
\q2 kini ogoni ibunime ti gini miaga ka.  
\q1 Kini ibugua wali agali uruni gubalini timbuniore ho kagome ti ani biamogo biaga ka.   
\b  
\q1
\v 15 Ani biaga kago manda buwa kini baya ogoni ibuore ha ho wiaaboore helo hameledo.  
\q1 Muni ngoloru Arebia tawego kini ogoni turu halu milo hameore ledo.  
\q1 Wali agali bu karume kini ogoninaga Ngode Datagaliwabehondo bi la helo hameledo.  
\q1 Kini ogoni biamogo biaabo helonaga wali agali karume habe lalu lamulebira.  
\q1 Ani larago hale halu Ngode Datagaliwabe ibugua kini ogonihondo bayale dege bialu  
\q2 ibu bayale helo biamogo bilo hameledo.   
\q1
\v 16 Dindi bibahende ngaruha widi balirubi tomo nema maru alebi anda hagahaga bialu  
\q2 dindi bare bare ngaruni nema hangume andaho namu lelo.  
\q1 Lebanono dindiha mbira tomo anda haga ngadagua anda heloore hameledo.  
\q1 Tano ngaruha wali agali dewa palu to̱ lalu bo dene ngagoria  
\q2 dangi anda hagahagadagua anda halu to̱lotagi helo hameledo.   
\q1
\v 17 Wali agali bu karume kini baya ogoninaga miniore embeda nahelo.\x + \xo 72.17 \xt Pig 22.18, Yar 4.2, Lg 1.48\x*  
\q1 Ibunaga mana baya biaga kini ogoni ka lalu lolenego lairi nahe  
\q2 honani li harini daho ngadagua  
\q2 wali agalime kini ogoninaga mini mo yaraga haho wiaaboore helo hameledo.  
\q1 Ani bialu wali agali dindi tara tarani palu ngarume Ngode Datagaliwabehondo bi lamialu,  
\q1 Kini biagohondo bayale dege bialu bu anda helo mo bayale hiridagua  
\q2 inabi nde bayale holoma̱ya mo bayale habe,  
\m lalu lamigi bilo hameledo.   
\b  
\q1
\v 18 Anduane Homogo Isaraele wali agalinaga Ngode Datagaliwabe kago ibunaga mini mo yaragaore halimu.  
\q1 Ibuni hangume mbirale bayaleore turubi o laruruni bigi biaga kagoni.   
\q1
\v 19 Ngode Datagaliwabe ibunaga mana bayaore gibi biaga kago  
\q2 ibunaga mini baya taraore ogoni mo yaraga haho wiaaboboore wilo.  
\q1 Ibunaga mini mo yaraga holenemebi  
\q2 ibunaga wá holenemebi  
\q2 dindi bibahendeha dungume halu to̱lotagi heloore hameledo.  
\q1 Henene aniore bilo bi labe.   
\b  
\q1
\v 20 Yasi igini Debidihanda Ngode Datagaliwabehondo bi laga binigo ai lairi ogoni.   
\b  
\ms1 MBUGA TEBONE  
\mr (Iba Gana 73-89)  
\c 73  
\s1 Ko biaga karu mini wilo Ngode Datagaliwabenaga mana laga kago ogo  
\q1
\v 1 Ngode Datagaliwabehanda Isaraele wali agalihondo bayaore gibi turubini hangu biaga kagoni.  
\q1 Ibugua wali agali tinaga bu habaneha mana ko mbira nawi tigabiore karuhondo  
\q2 baya turubiniore bigi biaga kagoni.   
\q1
\v 2 Ibugua ani biaga kagoyu ai i̱ore mana ko bialu pilalu penego habo laru.  
\q1 I̱ ge gundu lalu pilope halu mini mbiraore wu harugoni  
\q2 hadogoea lowa yu wahalu tagira pobehe haru.   
\q1
\v 3 Ani harudagoni irane i̱na handalu hewaria  
\q2 wali agali mini kowi hearu tigua mbirale bigi biyaru bayale haga bialu\x + \xo 73.3 \xt Iba 37.1, Yar 12.1\x*  
\q2 ti homogo hama piyago hondowa ani haru.  
\q1 Tigua biyago handarugola tinaga wiago degeni i̱naga miniha i̱ nayido agini henge lolenego hongohe tagira ibiya.  
\q1 Ani biyagome i̱ mini mbiraore wu harugoni yu wahalu tagira pobehe haru.   
\b  
\q1
\v 4 Ani handalu hewariabi wali agali ko biaga uruni ti warago bolenebi tandaga nolenebi mbira nahende  
\q2 tinaga tinginibi bayaore hongohe hearia handaru.   
\q1
\v 5 Wali agali maru karume tandaga nalu kadagua  
\q2 wali agali ko biaga uruni ti kagoria tandaga nane kane handaga biruli.  
\q1 Wali agali maru kagoria genda bulene tara tara íbu wigi biagadagua  
\q2 wali agali ko biaga uruni ti kagoria naíbu wiraya.   
\q1
\v 6 Ti genda mbira nahende howa mine timbuni halu tinaga tingini ganini wialu balagala hama ibaga biaga ka.  
\q1 Ani bialu tigua wali agali maru karu bame irane nawinini motudu wini balu mo ko haga ka.   
\q1
\v 7 Tinaga bu miniha mana ko ngubi tara tara buleneru hangu wai hanalu  
\q2 tinaga bu habaneha ko buleneme to̱lotagihe ka.   
\q1
\v 8 Tigua wali agali maru karu mege bialu hondo oba halu  
\q2 bi ko tara tara biaga ka.  
\q1 Tigua mine gibiore halu wali agali maru karu hengedope halu  
\q2 mo tandaga holenego agua habehedabe hondole hariga hai bialu haga ka.   
\q1
\v 9 Ani bialu tigua Ngode Datagaliwabe dahuliya andaga kago lalubi lo guralu haga ka.  
\q1 Tininaga mini mo yaraga halu  
\q2 tigua hame ledadagua hangu wali agali marume bilo  
\q2 bidaba lalu hongo howa lamiaga ka.   
\q1
\v 10 Anidagua lamiragola nde Ngode Datagaliwabenaga wali agali karumebi heba mini kowi urunime bi larago hale halu  
\q2 turu howa yu tiga biaga ka.   
\q1
\v 11 Agali ko urunime bi urudagua laga ka.  
\q1 Iname mbirale bigi beremaruni Ngode Datagaliwabe ibu manda nabulebira.  
\q1 Ngode Datagaliwabe Daligaorene Daliga kago ibugua iname beremarubi laramarubi goarialu  
\q2 handa walia holenego hariga nawiore laga ka.   
\q1
\v 12 Wali agali mini kowi karu tigua mana urunibi bigi biaga ka.  
\q1 Tinaga mbirale dewa bu payabu wia ngagoyu  
\q2 uruni ngelowa dege maru lone mo te dege bule hai bialu kagoni.   
\b  
\q1
\v 13 Ko biaga uruni ti ani bialu kagodago ai i̱ mana ko mbira nabiore  
\q2 i̱nime i̱ni mini haru halu ko nabi tigabi harugoni o kogoni.  
\q1 Ai ti ko biyadagua i̱ nde bua nale hogoralebu harudagoni nde irane nawini aginaga haruyabe.   
\q1
\v 14 Ngode Datagaliwabe-o í̠na mbiraga horombebi i̱ tandaga dege ngiaho wialu  
\q2 egerebagi bibahendengi í̠na i̱ minu baho ngegoni irane aginagabe.   
\b  
\q1
\v 15 Wali agali mini kowi biaru tigua layadagua i̱na mbira lenedale  
\q2 i̱na í̠naga wali agalime lolenedagua ndo ledole.   
\q1
\v 16 Ko biaga uruni tigua mbirale bigi biragonaga teneorego agidabe hondole lowa  
\q2 handalu hewaria i̱na handa walia habe nahe erekuibioreyane handaru.   
\q1
\v 17 Mitangi bialu tenego minime daba dege bialu howa handa walia nahe henego\x + \xo 73.17 \xt Iba 27.4, 37.38, 77.13\x*  
\q2 maniore Ngode Datagaliwabe í̠naga andaha anda pirugola tenego handa walia haru.  
\q1 Í̠naga andaha anda pirugola i̱naga mini biagoni wá layagola mbirale bayuwa manda bibehe haru.  
\q1 Wali agali ko biaga uruni tibi nde mani ogobini tagira polobada lalubi  
\q2 mitangi tagira íbu dege biya.   
\b  
\q1
\v 18 Ngode Datagaliwabe í̠na wali agali mini kowi uruni ti hariga gindigunduleore ngarunaga pelo pelolebere.  
\q1 Hariga gindigundule uruninaga pialu karia ge kundu lowa  
\q2 mo paraho pilope halu homo tongolo milolebere.   
\q1
\v 19 Ti abaleore homo tongolo mu daga holebira.  
\q1 Agali homaradagua ndo mo koore howa homolebira.   
\q1
\v 20 Anduane Homogo-o ko biaga uruni ti bame mbiraga emaga andaha mbaria dange harigi yu haganedagua yu kago  
\q2 egerebagi gao laragola ereba haganedagua yu karu ereba hai holebira.   
\b  
\q1
\v 21 I̱naga miniha tandaga bialu  
\q2 tinibi toga layagola   
\q1
\v 22 i̱ bu habaneha keba dege dindi halu nogo gabua mini nawi hagadagua howa  
\q2 í̠ mitangi bulene ereba halu  
\q2 i̱na mana biruru í̠ deni ogonibi bialu harugoni.   
\q1
\v 23 Ani bialu howa dege i̱na Ngode Datagaliwabe í̠ yu wanahe  
\q2 í̠ hegoha kaware haparaho harugola  
\q2 í̠na nde i̱naga gini yaniho hariligoni.   
\q1
\v 24 Í̠na i̱ aguaore habe lalu í̠naga bi mana bayaoreru langialu mo tiga bialu kegoni.\x + \xo 73.24 \xt Iba 48.14, 49.15, 58.11\x*  
\q1 Ani mo tiga bialu howa i̱ hamaro berongi nde í̠na i̱hondo turu halu habiya íbu lole kegoni.   
\q1
\v 25 I̱ de handayaho haga dahuliya andagani mende ai kabe.\x + \xo 73.25 \xt Iba 16.2\x*  
\q1 Mendeali nahe Ngode Datagaliwabe í̠ hangu kegoni.  
\q1 Í̠ hangu kego manda buwa i̱na í̠ gubalini timbuniore ho kogoni.  
\q1 Mbirale dindini bu payabu ngaru gubalini holene agi ngabe.  
\q1 I̱na í̠ore gubaliniho kogoni.   
\q1
\v 26 I̱naga minibi tinginibi hongo nahe gedaore hayaguabi\x + \xo 73.26 \xt Iba 16.5, 40.12, 84.2\x*  
\q2 Ngode Datagaliwabe í̠ i̱naga hongo holene tene kegome  
\q2 i̱ karulapeore haabo holebero.   
\b  
\q1
\v 27 Ngode Datagaliwabe í̠ yu wahalu piaga karu ti pu erebaho wahalu homolebira.  
\q1 Wali agali ala í̠hondo mini mbiraore wuwa í̠ talima ibaga howa  
\q2 áyu í̠ erembira ngialu tagira pu karu heneneore pani mialu ereba hai helolebere.   
\q1
\v 28 Uruni ani buleberegoyu i̱ dege Ngode Datagaliwabe í̠ kegoha hapara ho kogome\x + \xo 73.28 \xt Iba 14.6, 40.5, Hi 10.22, Ya 4.8\x*  
\q2 bayaore turubi i̱ hoale ngagoria kogoni.  
\q1 Anduane Homogo Bibahende Haru Haame Ho Haga-o  
\q2 i̱naga pabe tigila í̠ni kegome kogoni howa  
\q2 mbirale í̠na bigi biriru agua biri lalu latagi hai holebero.   
\c 74  
\s1 Isaraele wali agaliru biamogo bibe lalu Ngode Datagaliwabehondo bi lenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o í̠na inahondo erembira ngialu kego irane agibe.  
\q1 Í̠naga wali agali bu kamaruhondo keba ho haabo holeberebe.   
\q1
\v 2 Í̠na í̠naga wali agali bu kamaru mitangi bibe.  
\q1 Bambaore howa í̠na í̠ninaga wali agaliore ina holoma̱ya dabo helarigoni.  
\q1 Í̠nime ina haru dai birigome í̠naga wali agaliore kamagoni ndobe.  
\q1 Hari Saiono í̠ni hene biago mitangi bibe.   
\q1
\v 3 Ina waitigi bu hearume í̠naga anda hayago mo ko hai hayagoni.  
\q1 Mbirale mo ko hayadaruni í̠ni hondole ibabe.   
\b  
\q1
\v 4 Í̠la waitigi biarume í̠naga anda í̠ ina baba lola haga biagoha howa  
\q2 wai bi dalimu lalu mambolo balu mbirale wiaruni mebia haya.  
\q1 Í̠naga mbirale wiruni mo batagi halu tininaga mbirale wiaru wia aribia ka.   
\q1
\v 5 Agalime irabuha ayume ira dibu paya biagadagua  
\q2 tigua í̠naga andaha ani biyagoni.   
\q1
\v 6 Ira pelo mbaraleni giligili bialu kau wuwa  
\q2 anda ogoniha mo yaribiaho helaga bini hearuni  
\q2 waitigi biaru tigua ayume diba hamame bo giala bigi biya.   
\b  
\q1
\v 7 Tigua í̠naga anda biago giala baga bialu irame heda haya.  
\q1 Dindi andabi í̠ni holene lomabia ho wini biago  
\q2 tigua mebia hai haya.   
\q1
\v 8 Urunime ina bopeore holene mitangi bialu anidagua biya.  
\q1 Ina dindiha Ngode Datagaliwabe mitangi bialu lotu lolenaga loma biahene bibahende hearu anidagua biya.   
\b  
\q1
\v 9 Iname í̠ mitangi bulenaga manane waliaho wini biaru bibahende mo wahai haya.  
\q1 Í̠naga bi mana \w latagi\w* haga agali mbira áyu nahe kamagoni ndobe.  
\q1 Ina ogonibi dege kamaore genda uruni angi ereba holobadabe  
\q2 ina kamarume manda bibe nahe kamagoni ndobe.   
\q1
\v 10 Ngode Datagaliwabe-o waitigi uruni tigua í̠ hondo oba halu lu agua holobadabe.  
\q1 Tigua í̠naga mini lo mege bialu bi ko lalu haabo holebirabe.   
\q1
\v 11 Í̠na ina biamogo nabi kego irane agibe.  
\q1 Í̠ bame bira dege bidego agibe.   
\b  
\q1
\v 12 Anigo Ngode Datagaliwabe-o bambaore howa í̠ inanaga kini henego haabo kegoni.  
\q1 Í̠na pele ngiaabo harigola ina waime ba nabi harimagoni.   
\q1
\v 13 Í̠ninaga hongo timbuni gibihegome iba solowara timbuni bereagoha\x + \xo 74.13 \xt Har 14.21\x*  
\q2 hanuni ina poloma̱yanaga iba bira migimigi bilarigoni.  
\q1 Iyibi agali wena timbuni solowaraha biraraligobi hearia bo wahai hari.   
\q1
\v 14 Ani bialu í̠na abagua ale timbuni mini Lebiadananaga\f + \fr 74.14 \ft ogoni mbuga maruha ibu abagua ale nga lalu gilibu nga. Maruha ibu iba ibia ale gibi hiriribi beda lalu gilibu nga. Hobane ogoni gilibu ngago bi yobage ale lalu ibu Iyibinaga agali haguane hearu mitangi bialu leda. Ais 27.1, Ese 29.3, Yob 41.1 de handabe.\f* haguaneru bo tagadaga birigoni.\x + \xo 74.14 \xt Yob 41.1, Iba 104.26, Ais 27.1\x*  
\q1 Ibunaga tingini dindi ko iba dalu naibaga wiagoha  
\q2 nogo gabua hearu nelo mirigoni.   
\q1
\v 15 Í̠na iba dindiha howa ibilarigola dugualu pugu biya.  
\q1 Iba timbuni pialu hearu hundu tegelope helaga birigoni.   
\q1
\v 16 Í̠na mbiraga horombela tu wialu\x + \xo 74.16 \xt Pig 1.14\x*  
\q2 ni egela hari daligaha helaga biriya.   
\q1
\v 17 Í̠na iba dindila tubari ngelalu bigi biriyagoni.\x + \xo 74.17 \xt Pig 8.22, Ab 17.26\x*  
\q1 Mali bibahendenaga gaea bulene horobi dalu ibulene horobi  
\q2 tuwu ngelariyagoni.   
\b  
\q1
\v 18 Anduane Homogo-o í̠na ani birigola í̠la waitigi bu karume  
\q2 í̠ hondo oba halu karuni mitangi bibe.  
\q1 Tini mini nawi kariane tigua mitangi bialu  
\q2 í̠ kego bame degeda lomanda bialu mege biaga ka.   
\q1
\v 19 Í̠naga wali agaliru hongo nahe bu kamagonigo  
\q2 waitigi bu karume ina bope halu mo ko holigo  
\q2 í̠na ina yu wa nahabe.  
\q1 Waitigi karume í̠naga wali agali kamaru mo ko halu kago  
\q2 í̠na erembira nangi ina mitangibu haabo habe laro.   
\b  
\q1
\v 20 Inanaga dindi lenelene ngamaru bibahendeha  
\q2 waitigime wai mo ko howaore biaga kago manda bialu  
\q2 í̠na habo nalolene bi ina baba lo wirigoni manda bibe.   
\q1
\v 21 Agali ko karume wali agali hongo nahe bo hengedene karu  
\q2 í̠na ti yu wanahabe.  
\q1 Wali agali yagibano burupale bu karume  
\q2 í̠naga mini mo yaraga halu helo í̠nime ti biamogo bigi bibe.   
\b  
\q1
\v 22 Ngode Datagaliwabe-o í̠nime abale ibalu  
\q2 waitigi karuhondo bi hongo howa labe.  
\q1 Agali ko minehe bu karume  
\q2 í̠ mege bialu hondo oba haabo haga kago mitangi bibe.   
\q1
\v 23 Í̠ waitigi bu karume bi ko hongo howa lalu í̠ mege bialu kagoni.  
\q1 Tigua ga̱ lama ibaga bialu haabo haga kago  
\q1 Ngode Datagaliwabe-o  
\q2 tigua ani bialu karu hondo donge nahabe.   
\c 75  
\s1 Ngode Datagaliwabehanda wali agali tigatiga dabaki biagago ogo  
\q1
\v 1 Ngode Datagaliwabe-o iname í̠hondo ka̱i̱ lalu kama.  
\q1 Í̠hondoore iname ka̱i̱ laabo halu kamagoni.  
\q1 Iname í̠ mini leneore kego latagi halu  
\q2 mbirale bayale tara tara í̠na biriru te lalu kamagoni.   
\b  
\q1
\v 2 Ngode Datagaliwabehanda lalu,  
\q1 Godi lolene horo mbira daba bagiho ngeledo.  
\q1 I̱na godi larogo tigabiore lalu  
\q2 wali agali ta nabihondo ogobi dege dege laruli.   
\q1
\v 3 Wali agalibi nogo tara tarabi dindini bu karuni bibahende gi hai howa duru layaguabi  
\q2 dindibi dumbirumbi bialu ema biyaguabi  
\q1 i̱na dindinaga gene dunini karu yania ho kogola hongohe wiaabo holebira.   
\q1
\v 4 I̱na wali agali mana ko biaga hearuhondo,  
\q2 Tíore mine nahe halimu, lalu  
\q1 wali agali balagala haga hearuhondo,  
\q1 Tíninaga mini yaraga nahe halimu.   
\q1
\v 5 Tígua tíni mandabi tingi howa mine nahalimu, lalu laragoni.   
\b  
\q1
\v 6 Wali agalime bialu karu manani dabaki bule  
\q2 ni tagira ibiragohayagi howabi ni paliragohayagi howabi  
\q2 uyurahayagi howabi unurahayagi howabi ndo ibaga.   
\q1
\v 7 Ngode Datagaliwabe ibunimeore daba ki biaga ka.\x + \xo 75.7 \xt 1 Sml 2.7, Iba 50.6, 147.6, Dan 2.21\x*  
\q1 Ibugua agali mendego mo dindiha halu mendego mo yaraga haga ka.   
\q1
\v 8 Anduane Homogohanda ibunaga gini gabo be mbira yu haga.  
\q2 Gabo be ogoniha ibunaga keba holene \w waini\w* iba ale biru to̱leda.  
\q1 Ibunime odope haragola wali agali ko biaga karume naiore haga.   
\b  
\q1
\v 9 I̱na horo bibahendengi Yagabanaga Ngode Datagaliwabe kagonaga mini lalu howa  
\q2 ibunaga mini yaraga halu iba gana lalu haabo holebero.   
\q1
\v 10 Ibugua wali agali ko biaga karunaga hongo bo ereba halu  
\q2 wali agali tigabi karunaga hongo holene ibugua mo tago halu timbuniore helolebira.   
\c 76  
\s1 Ngode Datagaliwabehanda wai bialu wayali haga ka lenego ogo  
\q1
\v 1 Yuda dindiha karu tigua Ngode Datagaliwabe ibu kaore lalu manda biai ho ka.  
\q1 Isaraele dindiha karubi tigua ibu mini leneore ka lalu mo yaraga haga ka.   
\q1
\v 2 Ibunaga anda Yarusalemeha ka.  
\q1 Ibu Hari Saiono kagoha haabo haga kagoni.   
\q1
\v 3 Ibu ogoniha howa ibugua waitigirunaga danda timuru bo gingirulo wahaya.  
\q2 Yandarerubi humbibi wai biagane ale dameneru bibahendeore  
\q2 ibugua bo gingirulo wahai haya.   
\b  
\q1
\v 4 Ngode Datagaliwabe-o í̠ wá holene taraore kegoni.  
\q1 Í̠ mini lene howa kini duniniore kegoni.  
\q1 Í̠ daligaore howa hari mini lene timbuni wedaru dindiha lowa  
\q2 í̠ bolanguahe daligaore kegoni.  
\q1 Hari uruniha howa í̠na waitigi baba wai bialu wayali halu dai bu kegoni.   
\q1
\v 5 Tigua ti baba wai bialu wayali hayarume  
\q2 ami agali hongohe hearunaga wai biagane mbirale karulo hayaru  
\q2 yu wahai hayiya.  
\q1 Ani bialu ti homaiore hayiya.  
\q1 Tinaga hongobi wai bulenaga mugube yu hayarubi  
\q2 bameore habane nabulene haya.   
\q1
\v 6 Yagabanaga Ngode Datagaliwabe-o í̠na tihondo bi hongo howa larigola  
\q2 tinaga nogo hosibi agali nogo hosini berearubi  
\q2 ti bibahende homai halu tingini dindini wima piyiya.   
\b  
\q1
\v 7 Anigo Ngode Datagaliwabe-o ina bibahende í̠hondo giore haga bu kamaruni ndobe.  
\q1 Í̠ keba ho kegola mbirali ai ibugua í̠naga deni íbu holobadabe.  
\q1 Mbirali naholebira ndobe.   
\q1
\v 8 Í̠ dahuliya andagaha howa wali agali ko birimi lalu latagi harigola  
\q2 ti bibahendeore hearume gi timbuni howa  
\q2 bi nale ema nabi haya.   
\q1
\v 9 Horo ogoningi wali agali marume mo ko hene hearu  
\q2 í̠na biamogo bule heyu hariya.   
\b  
\q1
\v 10 Agali keba timbuni haragome\x + \xo 76.10 \xt Har 18.11, Iba 65.7\x*  
\q2 wali agali maru karu tigua í̠naga mini mo yaraga helo haga.  
\q1 Agali waiha homa nabi karume  
\q2 í̠ mitangi bialu lotu lolene ngadagua lalu holebira.   
\b  
\q1
\v 11 Tígua Anduane Homogo tínaga Ngode Datagaliwabehondo  
\q2 mbirale mbira mule lalu lo wirimidagua  
\q2 ibuhondo miaore bilimu.  
\q1 Wali agali tara tara dindi kawareni kamiru  
\q2 tíguabi ibuhondo mbiraleru turu halu milimu.  
\q1 Ngode Datagaliwabehanda wali agali ibuhondo gi helo mo gi haga ka.   
\q1
\v 12 Ibugua kini mine haga karu mo dindiha halu  
\q2 kini maru dindi tara tarani karubi ibugua ti mo gi haga ka.   
\c 77  
\s1 Genda íbu wiyagola Ngode Datagaliwabe olenego ogo  
\q1
\v 1 I̱na Ngode Datagaliwabehondo hongo howa olalu kogoni.\x + \xo 77.1 \xt Iba 3.4, 142.1\x*  
\q1 I̱na ibuhondo bi larogo hale habe lalu olalu kogoni.   
\q1
\v 2 Genda anda ibirangi i̱na Anduane Homogohondo bi laruli.  
\q1 Mbiraga bibahendengi i̱na gi yaraga halu Anduane Homogohondo bi laruligoyu  
\q2 i̱ha mo palia holene nawi dege kogoni.   
\q1
\v 3 I̱na Ngode Datagaliwabe mitangi biaabo halu koria  
\q2 i̱naga bu miniha dugu bialu haruli.  
\q1 I̱na mitangitangi bialu mini hurula bialu kogola  
\q2 i̱naga miniha genda dege dindi ho haruli.   
\b  
\q1
\v 4 Ibugua i̱ palia hondo nahe mo yangayangabu helaga kagoni.  
\q1 I̱naga bu miniha genda yu kogome bi labe naheore kogoni.   
\q1
\v 5 Ainde i̱ni bamba bayale hama ibiniru mitangibu dai bialu haruli.  
\q1 Mali ala bolangua halu peneru mitangiore bialu haruli.   
\q1
\v 6 Mbiraga paluwa i̱na mitangitangi dege biruli.\x + \xo 77.6 \xt Iba 4.4, 42.8\x*  
\q1 I̱naga miniha mini hurula bu howa i̱nihondo bi ogobi laruli,   
\q1
\v 7 Anduane Homogohanda inahondo erembira ngialu haabo holebiradabe.  
\q1 Inahondo turu lone naholobadabe.   
\q1
\v 8 Ibugua ina dara howa gubalini haraligo hairi áyu kagonidabe.  
\q1 Ibugua buleore lalu bi lo wiyaru habo layadabe.   
\q1
\v 9 Ngode Datagaliwabehanda ina dara howa biamogo bulene embeda hayabe tobaheda.  
\q1 Ibunaga dara holene winigo ai keba holene wia aribia hayadabe, lo mitangi bu harugoni.   
\q1
\v 10 I̱na urunidagua mitangibu howa lalu, Ngode Datagaliwabe Daligaorene Daliga kago  
\q2 ibugua ina áyu pele ngulenego manga hayada.  
\q1 Ibu ogonibi haruada mitangi bialu  
\q2 i̱naga bu miniha tandaga timbuniore ho kogoni ndobe, larugoni.   
\b  
\q1
\v 11 Anduane Homogo-o biabe timbuni í̠na biriruni mitangibu dai bulebero.  
\q2 Bambaore í̠na mbirale tara nahendene ale bigi biriru mitangi budai bulebero.   
\q1
\v 12 Biabe bibahendeore í̠na biriru damene mitangi biaiore holebero.  
\q2 Í̠na biabe hongohe taraore bigi biriruni mitangi biai holebero.   
\b  
\q1
\v 13 Ngode Datagaliwabe-o í̠na bigi biriligo bibahende bayale tigabiore birili.  
\q1 Mbirale bi pupu wule dama mitangi bialu gime wabini ngaruni  
\q2 bibahendeore í̠ ale mbira nawiore.  
\q1 Í̠na uruni bolangua haihe kegoni.   
\q1
\v 14 Ngode Datagaliwabe-o mbirale nahendene ale agalime bibe nahe ngaru  
\q2 biai haga í̠ni hanguore kegoni.  
\q1 Bamba í̠na wali agali dindi tara tarani bu hearuhondo  
\q2 í̠ninaga hongo timbuni walia harigoni.   
\q1
\v 15 Yagaba Yosebelanaga aguanene  
\q2 í̠ninaga wali agali mani andaho aribia hene hearu  
\q2 í̠ninaga hongooreme pele mialu haru dai birigoni.   
\b  
\q1
\v 16 Ngode Datagaliwabe-o bamba iba berearume í̠ hondowa gi hai haya.  
\q1 Iba solowara timbuni berearumebi duru lalu biraya.   
\q1
\v 17 Beralibame iba dalu timbuniore ibira halu  
\q2 hari kilikulu timbuniore layuagobi  
\q2 hari daba migimege laga bialubi uruni bibahende biai haya.   
\q1
\v 18 Humbirini wai biyago dombeneha howa hari kilikulu timbuni lelarigoni.  
\q1 Hari daba migimege lelarigome dindi bibahendeha wá hagimbu biyagola  
\q2 dindi ogo mogo lalu dumbirumbi biagimbu biya.   
\q1
\v 19 Iba yaribu biyagoria í̠ni iba daligani pirigoni.  
\q1 Iba solowara timbuni bereagoha hariga bo wialu pirigoni.  
\q1 Í̠ penegoha ge ngane nahandabeheya.   
\q1
\v 20 Í̠ni haru haganeore howa bamba halu pirigola  
\q2 í̠naga wali agali í̠ talima ibagaya.  
\q1 Mosese Aronola haru haga helarigome  
\q2 libugua wali agaliru haru howa handayaho hayagoni.   
\c 78  
\s1 Ngode Datagaliwabe ibunaga wali agaliru baba bi lenego ogo  
\q1
\v 1 I̱naga wali agaliru-o i̱na tíhondo bi lawai harogo  
\q2 tígua bayuwa hale haiore halimu.  
\q1 I̱na bi larogo hale dugua halu baya hangu hale halimu.   
\q1
\v 2 I̱na bi yobageru hangu lolebero.\x + \xo 78.2 \xt Md 13.35\x*  
\q1 Mbirale nahendene ale tara tara bamba wia do ho winiru  
\q2 i̱na áyu garea lalu manane walia halu langulebero.   
\q1
\v 3 Bamba ina mamalirume te uruni inahondo langiyagola  
\q2 iname hale howa mandabu harima.   
\q1
\v 4 Iname nde bi uruni ina waneiginiruhondo lamia nabi ya do holene nakarulapeore.  
\q1 Anduane Homogonaga hongo timbuniorehe kagonagabi  
\q2 biabe hongohe damene binigonagabi agalime nabiaga ale bigi binigonagabi  
\q2 iname ina waneigini aguanene mani holebiraru lamuleberema.   
\b  
\q1
\v 5 Ibugua ibunaga bi mana lowinigo  
\q2 Isaraele wali agaliruhondo lamigi bini.  
\q1 Ibunaga mana bulene winigo Yagaba aguanenerume taluwa bialu helo lamini.  
\q1 Ibugua bamba ina mamaliruhondo lalu,  
\q2 Tígua tínaga waneiginihondo i̱naga bi mana ogoni lawai halimu, lalu lamini.   
\q1
\v 6 Tí waneigini aguaneru mani holobadarume hale halu lo manda bilo.  
\q2 Tigua ti waneiginiru maniore hama polobadaru lawai hama puabo haragola ti manda biai helobi lawai halimu, lene.   
\q1
\v 7 Tigua anidagua lawai hama puabo hayagua nde  
\q2 mani holobadaru tigua Ngode Datagaliwabehondo mini mbiraore wu halu  
\q2 ibugua biabe hongohe bialu henedaru embeda nahe yu haabo holebira.  
\q1 Yu haabo howa tigua ibunaga mana bulene ngaru taluwa bialu haabo holebira.   
\q1
\v 8 Tinaga mamalime ala bialu henedagua naholebira.  
\q1 Tinaga mamalime doga haga howa Ngode Datagaliwabenaga bi mo wahalu  
\q2 ibuhondo mini mbiraore hongo howa nawi halu  
\q2 mini bilina nahe hene.   
\b  
\q1
\v 9 Bamba Eberaimi hameigini tigua danda timu yandarerume  
\q2 wai hongo howa bule pialu hearia baya handala ibida piai hene.   
\q1
\v 10 Ngode Datagaliwabehanda habo nalolene bi lowinigo tigua habo lalu  
\q2 ibunaga bi mana bulene winirubi talialu bia nabi hene.   
\q1
\v 11 Ibugua tininaga deniore howa mbirale biyaru damenebi  
\q2 agalime nabiagane ale biyaru bibahendebi  
\q2 tigua embeda hai heneya.   
\q1
\v 12 Tinaga mamaliru Iyibi dindiha dindi emene mbira mini Soana wiagoria heagola\x + \xo 78.12 \xt Har 7.8–12.32\x*  
\q2 ti de hendeaore dege Ngode Datagaliwabehanda agalime nabiagane ale dewa biniya.   
\q1
\v 13 Ibugua iba solowara timbuni bereago mo bira li ni bilowa\x + \xo 78.13 \xt Har 14.21-22\x*  
\q2 Isaraele wali agaliru dombeni haru pene.  
\q1 Iba bira li ni biyagola iba ibuni bira amu nana bialu pabe ale hene.   
\q1
\v 14 Horombe ibuni hari beraliba mbiraha howa ti haru bamba halu\x + \xo 78.14 \xt Har 13.21-22\x*  
\q2 mbiraga ibuni ira hungu mbiraha howa ti haru halu pu bamba haga biniya.   
\q1
\v 15 Ibugua dindi ko iba naibaga wiagoria howa ege to̱le̱ bayagola\x + \xo 78.15 \xt Har 17.1-7, Dag 20.2-13\x*  
\q2 iba duguatagi helayagola wali agali ti iba ogoni nalu hene.   
\q1
\v 16 Ibugua ege to̱le̱ha howa iba ibilayagola  
\q2 iba timbuni piagagobi pupe halu piya.   
\b  
\q1
\v 17 Ibugua ani biyagolabi tigua Ngode Datagaliwabe kagohondo mana ko hangu bialu haabo haya.  
\q1 Dindi ko iba dalu naibaga wiagoha howa  
\q2 tigua Daligaorene Daliga kagohondo mine halu doga haabo haya.   
\q1
\v 18 Tigua Ngode Datagaliwabe ba handalu\x + \xo 78.18 \xt Har 16.2-15, Dag 11.4-23, 11.31-35\x*  
\q2 tomo ti hame timbuni layaru ibuhondo hongo howa ngi lalu haya.   
\q1
\v 19 Tigua Ngode Datagaliwabe mege bialu lalu,  
\q1 Ngode Datagaliwabehanda ina dindi ko ogoria kamagoha  
\q2 tomo dewa ngia ngulebadabe, lalu heneya.   
\q1
\v 20 Ibugua abale heneneore ege to̱le̱ bayagola  
\q2 iba bayale timbuni tagira ibilayagodago  
\q1 ai dindi ko ogoriabi nogo ega mberediru ngulene karulapedabe, laga bialu hene.   
\b  
\q1
\v 21 Tigua bi ogoni lalu heago hale howa  
\q2 Anduane Homogo ibu keba ho hene.  
\q1 Ibugua keba halu Yagaba aguane biaru bu heagoha ira hedope hene.  
\q2 Ani buwa ibugua keba ala hayago timbuniore ho hene.   
\q1
\v 22 Keba henedagoni irane tigua ibuhondo mini mbiraore nawiyagonaga ibu keba hene.  
\q1 Ti bayale holenaga ibuhondo ina pele ngi lalubi  
\q2 mini mbiraorebi nawiore hene.   
\q1
\v 23 Uruni biyadaruni waha lowa ibugua hari li kagohondo bi layagola  
\q2 hari haedene bialu henge winiya.   
\q1
\v 24 Ibugua hariha howa tomo ibira helayagola\x + \xo 78.24 \xt Yo 6.31\x*  
\q2 tomo ogoni dahuliya andaga tawe mini \w mena\w* ti nelo mini.   
\q1
\v 25 Tigua dahuliyalinaga tomo ogoni mialu nene.  
\q1 Ngode Datagaliwabehanda tihondo tomo dewaore miyagola  
\q2 ti nalu no karula pene.   
\q1
\v 26 Mani ibugua puyabu hongohe ni tagira ibiragohayagi howa puloyu ibilene.  
\q1 Ibunaga hongome dege puyabu dindi abene unurahayagi howa puloyu ibilene.   
\q1
\v 27 Ibugua ega dewaore be abalu dugupe haradagua bialu  
\q2 iba angeni iba mu wiradagua bialu  
\q2 ti heagoria odo ibira ibira bilene.   
\q1
\v 28 Ngode Datagaliwabehanda ega uruni ti heagoria ibira helalu  
\q2 ti balai anda bu hemigoha manda manda tagira wiaru bibahendeha biru mabu bilene.   
\q1
\v 29 Wali agali tigua tomo uruni nalu no karula pene.  
\q1 Mbirale uruni ngi lalu wali agalime dugu bialu hayaruni  
\q2 Ngode Datagaliwabehanda mini.   
\q1
\v 30 Tigua tomo uruni na nalu hayagoyu  
\q2 tinaga noa holene hame ereba nahe tomo na dege bialu heaore   
\q1
\v 31 Ngode Datagaliwabehanda tihondo keba timbuniore ho howa  
\q2 Isaraeleali miniwi hongohe bu hearubi  
\q2 igiri daliahe hearubi bibahende bo wahaiore hene.   
\b  
\q1
\v 32 Ngode Datagaliwabehanda tihondo agalime nabiagane ale uruni biyago hondowa  
\q2 wali agali bu hearume mana ko dege bialu haya.  
\q1 Tigua ibuhondo mini mbiraore nawi dege haya.   
\q1
\v 33 Tigua ani bialu heagola ibugua ti abaleore ne harigaha howa  
\q2 buhe̱ latagi haradagua bialu bo wahaiore hene.  
\q1 Ibugua ti heagoria ko gibi anda ibilayagome  
\q2 ti dindini holene winigo abaleore mo ereba ho wahai hene.   
\q1
\v 34 Ngode Datagaliwabehanda maru ani bo wahai hayago de hondowa  
\q2 maru hearume ibu mitangibu dai bialu tinaga mini beregedalu  
\q2 mini mbiraore wiai halu ibuhondo bi hongo howaore lalu hene.   
\q1
\v 35 Ngode Datagaliwabe ibunime ti haru hagaore howa\x + \xo 78.35 \xt Har 15.13, Man 7.8, Ais 41.14, 63.9\x*  
\q2 tigua ibu tinaga humbi ale ka lo mandabu hene.  
\q1 Ibu Daligaorene Daliga kago ibugua ti biamogo biagaore kalo  
\q2 manda bu hai hene.   
\q1
\v 36 Tigua ani manda biyagoyu  
\q2 tinaga ne harigaha howa ibuhondo bi henene ndo bame bi degeme lalu hene.   
\q1
\v 37 Tinaga bu miniha ibula mini hana haga nabi hene.\x + \xo 78.37 \xt Ab 8.21\x*  
\q1 Tigua ibunaga habo nalolene bi lo wiyaru  
\q2 pugualu ha dege bini.   
\b  
\q1
\v 38 Ani biyago bialu helowa Ngode Datagaliwabe ibugua ti dara howa  
\q2 tinaga ko wiago domo wahai halu ti bo wa nahe helene.  
\q1 Tigua ko biyago hondowa ibugua keba ho donge howa  
\q2 ibunaga mini haru haga bialu wahaga bini.   
\q1
\v 39 Ibugua mitangi budai bialu ti wali agali ha kagonigo\x + \xo 78.39 \xt Iba 103.14-16, Yo 3.6-8, Ya 4.14\x*  
\q2 ti bame puyabu mbira abaleore ibalu pu bolangua hagagobi dege kagonidalo mitangi bini.   
\b  
\q1
\v 40 Horo bibahendengi tigua dindi ko iba dalu naibaga wiagoha howa  
\q2 ibunaga bi mo wahalu ti doga haga hene.  
\q1 Tigua halu dewaore ibu mo genda haga bialu hene.   
\q1
\v 41 Tigua Ngode Datagaliwabe ba handalu haabo haga hene.  
\q1 Isaraelealinaga Ngode Datagaliwabe mini tigabi baya burugule kago  
\q2 tigua mo genda haga bini.   
\q1
\v 42 Tigua ibu hongo gibihe kago embeda halu  
\q2 ibugua ti waitigi giha hearia haru dai biyagobi mitangi nabi hene.   
\q1
\v 43 Ogoningi ibugua Iyibi dindiha dindi emene mini Soana wiagoria  
\q2 agalime nabiagane ale dewaore bialu hayagobi ti embeda hene.   
\q1
\v 44 Iba bibahende peago ibugua mo darama bume hai helayagola\x + \xo 78.44 \xt Har 7.17-21\x*  
\q2 Iyibi wali agali hearume iba nolene nawini.   
\q1
\v 45 Bunguna tawalina dewa ibilayarume ti hayaga bini.\x + \xo 78.45 \xt Har 8.1-6, 8.20-24\x*  
\q1 Yago dewabi ibilayagola yago biarume  
\q2 tinaga mabuha tomo hengearu mo ko hai hene.   
\q1
\v 46 Ngode Datagaliwabehanda pagaya ale tara dewa ti hearia ibilayagola\x + \xo 78.46 \xt Har 10.12-15\x*  
\q2 Iyibi wali agalirunaga mabuni tomo hengearu damene nai hene.   
\q1
\v 47 Ibugua dalu dindiguni timbuni ibilayagome\x + \xo 78.47 \xt Har 9.22-25\x*  
\q2 tinaga pu mbira lini daga mini \w gerebi\w* hearu  
\q2 bibahende bo gindulo wahaiore helene.  
\q1 Ira poge ale bu hearubi kewaro ibirahayagome  
\q2 bo gilo wahai helene.   
\q1
\v 48 Dalu dindiguni timbuni ibilayagome tinaga nogo bulumaga bo homelalu  
\q2 hari daba ibilalu nogo sibi damenerubi bo wahaiore helene.   
\q1
\v 49 Ibugua Iyibi wali agali biaruhondo keba timbuniore ha ho wiaabo halu  
\q2 dahuliyalirume ti mo ko holene tara tara ibilaga bini.   
\q1
\v 50 Ibugua ibunaga keba holene wanahe  
\q2 tiha warago timbuni mbira ibilayagome  
\q2 wali agali homa dege dindi hene.   
\q1
\v 51 Iyibi wali agalinaga igiri wahene damene bibahende bu hearu\x + \xo 78.51 \xt Har 12.29\x*  
\q2 ibugua homelo bo wahai hene.   
\b  
\q1
\v 52 Mani ibugua ibuni nogo sibi haru haga ale howa\x + \xo 78.52 \xt Har 13.17-22\x*  
\q2 ibunaga wali agali biaru haru tagira pialu  
\q1 dindi ko iba dalu naibaga wiagoha howa ibuni bamba halu  
\q2 hariga walia hama pene.   
\q1
\v 53 Ibugua ti haru halu piyagola\x + \xo 78.53 \xt Har 14.26-28\x*  
\q2 tiha gi holene mbira nawi howa bayaleore hene.  
\q1 Ti waitigi biaru dege iba solowarame bo nai helene.   
\q1
\v 54 Ibugua ti ibunaga dindi loma biaho wiagoha haru halu ibini.\x + \xo 78.54 \xt Har 15.17, Yos 3.14-17\x*  
\q1 Dindi ogoni dindi hari ibuninaga hongomeore mo wini.   
\q1
\v 55 Ibunaga wali agaliru haru ibalu howa\x + \xo 78.55 \xt Yos 11.16-23\x*  
\q2 wali agali tara tara dindi ogoriani hene bu hearu bo talia togolene.  
\q1 Dindi ogoni Isaraele hameigini bibahendehondo tu wa tahalu  
\q2 ibugua dindi andabi ti helo mo migi bini.   
\b  
\q1
\v 56 Ibugua ogoni biai hayagola\x + \xo 78.56 \xt Hgn 2.11-15\x*  
\q2 Isaraele wali agali tigua Ngode Datagaliwabe Daligaorene Daliga kagohondo doga howa  
\q2 ibu ba hendene.  
\q1 Tigua ibunaga mana bulene winigo talia nabi dege hene.   
\q1
\v 57 Tinaga mamalirume bamba bialu henedagua tiguabi nde doga howa  
\q2 ibunaga bi mo wahaga bialu hene.  
\q1 Wali agali uruni ti tiga nabiore timu yole ngaligobi hene.   
\q1
\v 58 Dama mitangi bialu mbirale gime wabini wiaruhondo bi pupu wulenaga anda bu helaga biyagome  
\q2 Ngode Datagaliwabe mo keba haya.  
\q1 Tigua dama mitangi bialu mbirale bi pupu wulenaga gime wabigi biyagome  
\q2 Ngode Datagaliwabe mo keba ha haya.   
\q1
\v 59 Ngode Datagaliwabehanda tigua mana bialu hearu hondowa  
\q2 ibu keba timbuniore ho howa  
\q2 Isaraele wali agali erembira mialu wahene.   
\q1
\v 60 Ibugua ibunaga \w Balai\w* Anda Silo tanoni heagobi wahene.\x + \xo 78.60 \xt Yos 18.1, Yar 7.12-14, 26.6\x*  
\q1 Anda ogoniha howa ibu wali agali dege dombeneha haabo haga henego  
\q2 wa dege hene.   
\q1
\v 61 Ina baba waitigi hearume ibunaga Habo Nalolene Bi lo winigonaga Mbogoyi biago\x + \xo 78.61 \xt 1 Sml 4.4-22\x*  
\q2 mo yalu pelo wahene.  
\q1 Mbogoyi ogoriani howa ibunaga hongo holenebi wá holenebi timbuniore  
\q2 tihondo walia haga wini.   
\q1
\v 62 Ibunaga wali agaliru baba keba timbuniho howa  
\q2 ti waitigime ibalu bo wahai helo yupe ho hene.   
\q1
\v 63 Igiri daliahe hearu waime bo wahai hayagola  
\q2 wandari mabuage berearu ti dabu bulene igiri mbira nahene.   
\q1
\v 64 Agali \w loma\w* binigo mo miaga hearu bo wahai hayagola  
\q2 ti oneme dara howa dugu bialu birulene henge nawini.   
\b  
\q1
\v 65 Aniore biagola Anduane Homogo ibu agali dagiani palene heyaradagua bialu  
\q2 agali hongoheme \w waini\w* iba dewa nalu bi hongo howa lagadagua lalu biya.   
\q1
\v 66 Ibugua waitigi hearu baba wai bialu ti bo talia dai bini.  
\q1 Ti bopeore hayagola tigua taga timbuni halu  
\q2 wai lone bibe nahe hene.   
\q1
\v 67 Yosebe aguanene bu hearu erembira mialu  
\q2 ibugua Eberaimi hameigini hearu ariabi mbira dabo hela nabi wahene.   
\q1
\v 68 Ti wahalu ibugua Yuda hameigini aria dabo helalu  
\q2 hari ibuniore gubalini ho haga Saiono biagobi dabene.   
\q1
\v 69 Hari hombene ogoriani ibugua ibunaga anda Dahuliya andagaha kagobi bini.  
\q1 Ibunaga anda ogoni hongohe  
\q2 dindi ogo hongohe ngagobi haabo helo  
\q2 ibugua bu helene.   
\b  
\q1
\v 70 Ngode Datagaliwabehanda ibunaga biabe biahaga helo Debidi dabaya.\x + \xo 78.70 \xt 1 Sml 16.11-12, 2 Sml 7.8, 1 Bit 17.7\x*  
\q1 Ibugua Debidi nogo sibiru haru haga hearia dabo helayiya.   
\q1
\v 71 Ngode Datagaliwabehanda Debidi ibu Isaraele wali agaliru haru haga kini helo dabo helayiya.   
\q1
\v 72 Debidi ibu mini tigabi howa wali agaliru haru haga hene.\x + \xo 78.72 \xt 1 Kin 9.4\x*  
\q1 Ibugua haru holene mugube yu howa  
\q2 ti baya hangu haru halu handayaho hayiya.   
\c 79  
\s1 Isaraele wali agali biamogo bilo Ngode Datagaliwabehondo bi la henego ogo  
\q1
\v 1 Ngode Datagaliwabe-o wali agali tara tara í̠ mitangi nabiaga karume\x + \xo 79.1 \xt 2 Kin 25.8-10, 2 Bit 36.17-19, Yar 52.12-14\x*  
\q2 í̠naga dindi wai bialu karulole íbu ka.  
\q1 Tigua anda í̠nagaore helo loma biaho helarigoha anda puwa mebia haya.  
\q1 Yarusalemebi mo ko halu bo gialo wahai haya.   
\q1
\v 2 Tigua í̠naga wali agali bo wahalu ega bodo hariawe aleme nelo  
\q2 tinaga tingini ngelalu pene.  
\q1 Í̠naga biabe biahaga wali agali hearu bo wahai hayagola  
\q2 nogo gabua bu hearume tinaga tingini nalu kagoni ndobe.   
\q1
\v 3 Waitigi biarume í̠naga wali agali biaru bo wahayagola  
\q2 uruninaga darama Yarusaleme tanoha iba poradagua pialu kagoni.  
\q1 Homayaru mo horo holene agali mbira naheoreya.   
\q1
\v 4 Hameigini tara tara ina kamagoria kaware bu karume  
\q2 ina mege buwa hondo oba halu bi koru laga bialu ka.   
\q1
\v 5 Anduane Homogo í̠na inahondo keba ho haabo holeberebe.\x + \xo 79.5 \xt Iba 85.5, Ese 38.19\x*  
\q1 Í̠naga kebago hongohe ira hungu ale dalu hundia nabulene kebe be agua bidebe.   
\q1
\v 6 Hameigini tara tara í̠ mitangi bialu lotu nalagabi í̠nihondo bi nalagabi karu  
\q2 tihondo keba hariyagua nde karulapeda.   
\q1
\v 7 Wali agali uruni tigua í̠naga wali agali hearu bo wahai halu  
\q2 í̠naga dindi andaru mo ko halu mo labu hai haya.   
\b  
\q1
\v 8 Inanaga mamalirume mana ko bialu hayagonaga pani nolene winigo  
\q2 inahondo nguleni nangibe.  
\q1 Ina mini dege dindi ho kamago hondowa dara halu  
\q2 inanaga mini mbiraore ngamago mo hongo habe.\x + \xo 79.8 \xt Iba 106.6, Ais 64.9\x*   
\q1
\v 9 Ngode Datagaliwabe-o ina pele ngiaga í̠ore kegoni.\x + \xo 79.9 \xt 2 Bit 14.11, Iba 25.11, 31.3\x*  
\q1 Í̠ mini leneore kegome ina mitangi bialu biamogo bibe.  
\q1 Iname ko birimaru domo wahalu ina haru dai bibe.   
\q1
\v 10 Hameigini tara tara bu karume lalu,  
\q2 Tínaga Ngode Datagaliwabe agoha kabe, laga bialu kago  
\q2 irane aginaga í̠na ti ani leledebe.  
\q1 Hameigini tara tara uruni tigua wali agali í̠naga biabe biahaga bu hearu  
\q2 bo wahai halu tinaga darama piyadagua tininaga darama ani pelo  
\q1 í̠na tini bo waharego ina hondole hamelo kama.   
\b  
\q1
\v 11 Garabaya andaha bu karume dugu biaruago hale habe.  
\q1 Waitigi bu karume inanaga wali agali garabaya karu  
\q2 ti homelo bolene nga layago nahomelo  
\q2 í̠ninaga hongo timbuni ngegome ti haru dai bibe.   
\q1
\v 12 Anduane Homogo-o waitigi agali uruni tigua í̠hondo bi ko laabo hayagonaga  
\q2 í̠na tihondo pani ka halu miadai bibe.   
\q1
\v 13 Í̠na ani beregola ina nogo sibi ale howa í̠naga wali agali bu kamarume  
\q2 í̠hondo ka̱i̱ laabo holeberema.  
\q1 Inanaga waneigini aguaneneru mani hama polobadaru tiguabi  
\q2 í̠naga mini yaraga halu hadege bulebira.   
\c 80  
\s1 Isaraele wali agalime Ngode Datagaliwabehondo bi lalu ti lone hongo howa holoma̱ya biamogo bibe lenego ogo  
\q1
\v 1 Isaraele wali agalinaga Haru Haga-o iname bi langeremaru hale habe.\x + \xo 80.1 \xt Har 25.22\x*  
\q1 Ina nogo sibi ale bu kamarunaga haru haga í̠ni kegonigo  
\q2 iname dugu bialu laramaru hale habe.  
\q1 Dahuliyali babaganehe kirali kago labo dindiha helowa  
\q2 í̠ni de handape howa handayaho kegoni.   
\q1
\v 2 Ina Eberaimi hameiginibi Beniyamini hameiginibi Manase hameiginibi bu kamaruhondo í̠ni mo walia halu  
\q2 í̠naga dara holene ogoni inahondo mo walia habe.  
\q1 I̱naga hongo holene timbuniore ngegoni mo walia halu  
\q2 ina bayale holoma̱ya biamogo bibe.   
\q1
\v 3 Ngode Datagaliwabe-o ina lone í̠ni keria haru dai bibe.  
\q1 Ina bayuwa holoma̱ya í̠naga dara holene walia halu  
\q2 ina biamogo bibe.   
\b  
\q1
\v 4 Anduane Homogo Ngode Datagaliwabe Hongo Haiheore-o  
\q2 i̱naga wali agali kamarume í̠hondo bi laramago hale howa  
\q2 í̠ dara nahe handa taraho kegoni dege  
\q2 keba haho wiaaboore hole kebe.   
\q1
\v 5 Dara holene ngirigo tomo ale nalu de iba ngirigo iba ale nalu kamagoni.   
\q1
\v 6 Hameigini tara tara ina baba mandagi handa a̱i na̱i palearume anda ibalu  
\q2 inanaga dindi wimago ti i̱ hole lowa garere bilo  
\q2 í̠na mo garere bia harigoni.  
\q1 Ani biyago handayagola inanaga waitigi bu hearume  
\q2 inanaga dongone hondo wahalu mege bialu hondo oba hayagoni.   
\b  
\q1
\v 7 Ani biyago Ngode Datagaliwabe Hongo Haiheore-o  
\q2 í̠naga dara holene walia halu ina lone haru dai bibe.  
\q1 Í̠na ina dara halu lone pu ereba naholoma̱ya haru daibu helabe.   
\b  
\q1
\v 8 Pu mbira lini daga mini \w gerebi\w* mbira Iyibi dindini hearia egene dogodo yalu ibuwa\x + \xo 80.8 \xt Ais 5.1-7\x*  
\q2 maru dindi ogoriani hene hearu dugu ba tagitagi buwa  
\q2 gerebi lini daga pu ogoni dugu ba tagi hariru henedagoria hongo aribia harigoni.   
\q1
\v 9 Gerebi lini daga pu ogoni ibu bayuwa anda helonaga hama ba a̱i̱ na̱i̱ buwa hangarigoni.  
\q1 Hengegola pu o biagoni anda halu  
\q2 pini dindiha unuraore dalipe halu bayaore anda hayagoni.  
\q1 Pu biagonaga yuni maganeru yulume hayagola  
\q2 dindi bibahende namulai hayagoni.   
\q1
\v 10 Ibunaga maganerume hari wiaru angua hai halu  
\q2 ibunaga maganeme ira tamia timbuni gibi hearu angua hai hayagoni.   
\q1
\v 11 Gerebi lini daga pu ogoni ibunaga magane yulu yalu pialu  
\q2 amu iba solowara mini Medidereniana bedagoria dogolo paga hayagoni.  
\q1 Ani bialu hoyulo yalu pialu puni Iba Yuberedisi poragoria yulu paga hayagoni.   
\q1
\v 12 Bayaore ani anda hayagoyu  
\q2 ai gerebi lini mabu ogoninaga pabe ho mabu biago aginaga podope haribe.  
\q1 Pabe biagoni podope hariyagome  
\q2 ai wali agali ti hariga o biagoniha pume halu  
\q2 gerebi lini do wiaruni bame gi dege palia habehe ngagoni.   
\q1
\v 13 Nogo gabua bu karume geme hengedo ngagola  
\q2 ema bialu piaga ale karume nama aribia halu kagoni.   
\b  
\q1
\v 14 Ani bidago Ngode Datagaliwabe Hongo Haiheore-o  
\q2 ainde lone mini wiadai bialu ina darabi o bu kamagoni  
\q2 lone daraho dai bibe.  
\q1 Í̠na Dahuliya andagani kegoni howa ina kamago de handadali halu  
\q2 ina biamogo bule ibabe.  
\q1 Irane ina í̠naga pu gerebi lini daga ale í̠nime hangarigo kamagoni.   
\q1
\v 15 Pu mbira lini daga mini gerebi biago í̠ninaga hongome hangarigoni  
\q2 ina o bu kamagonigo ina pele ngule ibabe.  
\q1 Pu o biagoni áyu dege hongone hongo halu anda helo  
\q2 mo anda harigonibi kamagoni.   
\b  
\q1
\v 16 Inanaga waitigi hearume gerebi lini daga pu biagoni dibupe howa ira bo delalu kagoni.  
\q1 Tigua ani bialu kago  
\q2 Ngode Datagaliwabe í̠na inanaga waitigi uruni handabe manga halu  
\q2 bibahendeore bo mburilai habe.   
\q1
\v 17 Uruni ani bo mburi lalu ina í̠ninaga waneigini holoma̱ya dabene biago kamaruni  
\q2 ina mo anda halu mo hongo harigoni kamago  
\q2 ai áyu ina de hondo halu biamogoore bibe.   
\q1
\v 18 Í̠na ani biamogo biriyagua iname í̠ helo wahalu lone napoleore beremagoni.  
\q1 Ani buleberemago í̠na ina hongohe helabe.  
\q1 Í̠na ani heledegola iname í̠naga mini mo yaraga halu haabo holeberema.   
\b  
\q1
\v 19 Anduane Homogo Ngode Datagaliwabe Hongo Haiheore-o  
\q2 í̠na í̠ni keria ina haru dai bibe.  
\q1 Ina nahome yo pialu poloma̱ya  
\q2 ina dara halu biamogo bibe.   
\c 81  
\s1 Turu halu mandagi ngoai howa lotu lolene horongi iba gana lenego ogo  
\q1
\v 1 Ina mo hongo haga Ngode Datagaliwabe kagohondo turu howa bi dalimu lama.  
\q1 Yagabanaga Ngode Datagaliwabe kagonaga mini yaraga halu  
\q2 iba gana lami̱ya.   
\q1
\v 2 Irabitele kilingele lalu bayuwa bami̱ya.  
\q1 Ga̱wa̱ ale yugulelerubi baya hangu hibu howa mo bila hama.   
\q1
\v 3 Ege pigane ngabu laragolabi ege do hanuni haragolabi\x + \xo 81.3 \xt Dag 10.10\x*  
\q2 turu halu mandagi ngoai howa lotu lolene horo tagira ibiragonaga  
\q2 biguliru pu lolene nga.   
\q1
\v 4 Ina Isaraele wali agalime mana bulene ngago ogoni.  
\q1 Yagabanaga Ngode Datagaliwabe ibunime mana ogoni bulene inahondo nginigo  
\q2 anidagua bulene nga.   
\q1
\v 5 Horo mbiru Ngode Datagaliwabe ibugua Iyibiali baba wai bu piyangi mana ogoni tehinuwa  
\q2 ina Isaraele wali agali kamaruhondo ngiya.  
\b  
\q1 Mbiralime bi mbira laruago hale kogo aiwa laruabe i̱ manda nabi ko.   
\q1
\v 6 Bi laruagome lalu,  
\q1 Tínaga payani mbirale gendabi yu harimiruni i̱na mo wahai haru.  
\q1 Tígua erekui biabe timbuni biaga kamiru  
\q2 dindini ibiraho ngeladaba laru.   
\q1
\v 7 Tígua genda yu howa i̱ olarimingi i̱na tí biamogo birugoni.\x + \xo 81.7 \xt Har 17.7, Dag 20.13\x*  
\q1 Hari kilikulu larago dombeneha howa  
\q2 i̱na tínaga bi larimigo hale haru.  
\q1 Bamba tí Meriba iba bereagoria hemingi  
\q2 i̱na tí ba handarugoni.   
\q1
\v 8 I̱naga wali agaliru-o i̱na tíhondo bi hongohe mbira langerogo hale halimu.  
\q1 Isaraele wali agaliru-o tígua i̱naga bi larogo hale halimulo hamelo kogoni.   
\q1
\v 9 Wali agali tara tara bu karunaga dama mitangi bialu mbirale gime wabini ngaru\x + \xo 81.9 \xt Har 20.2-3, Man 5.6-7, 32.12, Iba 44.20, Ais 43.12\x*  
\q2 tígua talima napilimu.  
\q1 Mbirale uruni alehondo bi pupubi nawilimu larogoni.   
\q1
\v 10 Anduane Homogo tínaga Ngode Datagaliwabe i̱ni hangu kogoni.\x + \xo 81.10 \xt Har 20.2, Iba 37.4, 107.9\x*  
\q1 Tí Iyibi dindiha hemiria i̱nioreme haru tagira ibirugoni.  
\q1 Tínaga ne harigaha tomo yaanda haga buliya ai ne ha̱ladaba larugoni.   
\b  
\q1
\v 11 I̱na bi larugola i̱naga wali agalime hale habe manga haya.  
\q1 Isaraele wali agali tigua i̱na bi larugo talialu bia nabi haya.   
\q1
\v 12 Tigua ani bialu heagola\x + \xo 81.12 \xt Yob 8.4, Ab 7.42, Lm 1.24-26\x*  
\q2 i̱na ti mini giambe haabo hayagola helo waharu.  
\q1 Wali agali urunime tini hameleago ale bialu helo  
\q2 yupe ho waharugoni.   
\q1
\v 13 I̱naga wali agali bu karume i̱naga bi hale helo i̱ hameore ledo.  
\q1 Isaraele wali agali tigua i̱na hameledogo talialu bilo hamelo kogoni.   
\q1
\v 14 Tigua anidagua bidale nde i̱na ti waitigi karu abaleore bope hai kole.  
\q2 Ti waitigi bibahende karu baba wai bialu bopeore hai kole.   
\q1
\v 15 Wali agali i̱ handabe manga haga karume i̱hondo gi timbuni howa  
\q2 i̱naga buha ibalu bulu palialu ge duli hanga ho bedale.  
\q1 Tigua ko biyarunaga pani nelo mirugoni nalu haabo kale.   
\q1
\v 16 I̱na tíhondo ladi ale mini widi bayaleore nalu halimulo ngialu  
\q2 irabuha mone tara dedarunaga ibanerubi nalu halimulo ngia dege berogola  
\q1 tígua karulapeore nalu kamile,  
\m lalu layuane hale haru.   
\c 82  
\s1 Ngode Datagaliwabe ibu Haguane Duniniore kago ogo  
\q1
\v 1 Dahuliya andagani dahuliyali hondo hagaru ngoai ho bedagoria  
\q2 Ngode Datagaliwabe ibuni duniniore howa haru ka.  
\q1 Ibugua dahuliyali o biarume bi lararu hale howa  
\q2 tinaga bi dabaki bialu lamiaga ka.   
\q1
\v 2 Ibugua lalu, Tígua godi dabaramiligo  
\q2 tigatiga ndo ke̱ howa daba ko haramiligo nahalimu.  
\q1 Tígua agali ko biaga karunaga laharamiligo wahalimu.   
\q1
\v 3 Tígua wali agali yagibano karubi waneigini ti ai̱ya abala homene karubi  
\q2 biamogo bialu halimu.  
\q1 Wali agali maru genda yu howa hako karubi hongo nahe karubi  
\q2 ti mitangi bialu tihondo mana bayale bialu halimu.   
\q1
\v 4 Wali agali uruni mbirale burupale howa  
\q2 ti agali ko biaga karunaga giha karia haru daibu helalimu.   
\b  
\q1
\v 5 Tí mini nawi howa manda nabiore bu kamigoni.\x + \xo 82.5 \xt Iba 11.3, 75.3\x*  
\q1 Tí ko biaga howa arumaha ibagabu kamigola  
\q2 wali agalime mana tigabi talialu bulene ngago nabiaga ka.   
\q1
\v 6 Tí dahuliyali howa\x + \xo 82.6 \xt Yo 10.34\x*  
\q2 Daligaorene Daliga i̱ kogonaga iginiore kamigoni ndobe laro.   
\q1
\v 7 Tí ani kamigoyu  
\q2 wali agali dindini karu homagadagua dege homoleberemi.  
\q1 Kini waneiginiru homagadagua dege tíbi homoleberemi, lene.   
\b  
\q1
\v 8 Ngode Datagaliwabe-o dindi bibahendeni wali agali bu karu  
\q2 handameho hole í̠ abale ibabe.  
\q1 Wali agali hameigini tara tara padaru bibahende í̠naga dege kagoni.   
\c 83  
\s1 Ngode Datagaliwabehanda Isaraele wali agali baba waitigi karu bope helo bi lenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o í̠naga ne ndibulo nahabe.  
\q1 Í̠ore bi nale nahabe. Í̠ ema nabi nahabe.   
\q1
\v 2 Í̠ waitigi biarume í̠la wai bule kagoni de handa.  
\q1 Agali í̠ handabe manga haga karume í̠hondo doga halu kagoni.   
\q1
\v 3 Tigua bira do howa í̠naga wali agali mo ko holenaga  
\q2 ohowa ndindelalu kagoni.  
\q1 Í̠naga wali agali uruni í̠na handayaho haga kego  
\q2 mo ko hole miniha magoyu kagoni ndobe.   
\q1
\v 4 Tigua lalu, Isaraele wali agali bu karuni  
\q2 mani holobadarume abogo hene lalu manda nabilo bo wahai hami̱ya, lalu ka.   
\b  
\q1
\v 5 Tigua ogonidagua bulenaga mini mo mbiraore ho ka.  
\q1 Ti mandagiore howa í̠ bope hole kagoni.   
\q1
\v 6 Urunidagua bule haruaruni  
\q2 Idomoalirubi Isimaelealirubi  
\q2 Moabalirubi Hagarialirubi   
\q1
\v 7 Gebalailirubi Amonoalirubi  
\q2 Amalegealirubi Pilidialirubi  
\q2 Taialibi uruni bibahendeme í̠ bope hole kagoni.   
\q1
\v 8 Asiria wali agali tibi nde uruni baba hamagamagabu dege ka.  
\q1 Hameigini hongohe uruni tigua Lode aguanene Amonoalibi Moabalibi  
\q2 biamogo bule hamagamagabu ka.   
\b  
\q1
\v 9 Tigua anidagua bule kago í̠na uruni pani mialu\x + \xo 83.9 \xt Hgn 4.6-22, 7.1-23\x*  
\q2 bamba Midianalihondo biridaguabi  
\q2 Sisera Yabinialilahondo Iba Kisono poragoria howa biridaguabi bialu  
\q2 ti bo wahai habe.   
\q1
\v 10 Í̠na ogoningi Endoni tano howa agali bo wahai harigola  
\q2 tinaga tingini dindini wu togo bialu ngu biai haya.   
\q1
\v 11 Tinaga ami agali haru haga bu karuhondo\x + \xo 83.11 \xt Hgn 7.25, 8.12\x*  
\q2 í̠na abale agali Orebe Sebelahondo biridagua bibe.  
\q1 Tinaga agali haguane bu karuhondo í̠na Seba Salamunala bo waharidagua bo wahabe.   
\q1
\v 12 Agali uruni tigua lalu, Iname Ngode Datagaliwabenaga dindi ogo  
\q2 inanaga dindi dege ngelo karulami̱ya, layago bo waharigoni.   
\b  
\q1
\v 13 I̱naga Ngode Datagaliwabe-o agali uruni bo purogo lelalu  
\q2 be abalu taulotogo laradaguabi  
\q2 puyabume widi aeane yuniru pu lo yu purogo laradaguabi  
\q2 bialu bo taliatogo lelabe.   
\q1
\v 14 Irame irabu ngaru bo dai hagadaguabi  
\q2 dindi hombeneni dangi bu karu bo dagadaguabi   
\q1
\v 15 agali o bu karuni ti gi halu ibida purogo lelo  
\q2 í̠na iba dalu timbuni ibilalu  
\q2 puyabu hongohe ti kagoha pelo pelabe.   
\q1
\v 16 Anduane Homogo-o tigua í̠naga hongo hondowa taga halu  
\q2 í̠ni kegoha dai bilo í̠na ti bope hai habe.   
\q1
\v 17 Tigua í̠hondo gi timbuni ho haabo helo  
\q2 í̠na ti bope habelo hamelo kogoni.  
\q1 Tigua taga timbuni halu tini homade helo hameledogoni.   
\q1
\v 18 Í̠ni hanguore Anduane Homogo howa Daligaorene Daligabi kego manda bilobi\x + \xo 83.18 \xt Har 6.3, Iba 59.13, 92.8\x*  
\q2 í̠na dindi bibahendeha handameho howa  
\q2 í̠ni hanguore heneda lomanda biai helobi  
\q1 hame timbuni lo kogoni.   
\c 84  
\s1 Mbirali ibu Ngode Datagaliwabenaga andani hole hameore lenego ogo  
\q1
\v 1 Anduane Homogo Hongo Haihe-o i̱na í̠naga andaore gubalini timbuniore ho kogoni.   
\q1
\v 2 Í̠naga anda ogoniha i̱ ho palu holeneore hame timbuni lo kogoni.\x + \xo 84.2 \xt Iba 42.2, 63.1\x*  
\q1 I̱ mbirale marunaga hame nawigo  
\q2 Anduane Homogo í̠naga andaha holenegoorenaga hame bibahende ogoniha piai helowa kogoni.  
\q1 I̱naga minimebi tinginimebi bibahendeme i̱na turuore halu  
\q2 iba gana turubiru bibahendeorenaga holene tene  
\q2 Ngode Datagaliwabe haluhe kagohondo lo mialu kogoni.   
\q1
\v 3 Anduane Homogo í̠ Hongo Haihe i̱naga kinibi i̱naga Ngode Datagaliwabebi í̠ hangu kegoni.  
\q1 Ngode Datagaliwabe í̠naga andaha bo lomabu miaga dabu ngagoria  
\q2 ega emene yatagoberu anda bia para howa tini palu ngagoni.  
\q1 Tinaga iginiru ogoniha palelonaga ma palia kagoni. \fig Ngode Datagaliwabe í̠naga andaha bo lomabu miaga dabu ngagoria ega emene yatagoberu anda bia para howa tini palu ngagoni.|src="HK 7a.tif" size="1" ref="(84.3)" \fig*   
\q1
\v 4 Wali agali í̠naga andaha haga karu ti baya turubiore kagoni.  
\q1 Tigua turu howa í̠naga mini yaraga halu iba ganaru laabo halu kagoni.   
\b  
\q1
\v 5 Wali agali Hari Saiono kagoria pole turu howa kulo karu\x + \xo 84.5 \xt Iba 81.1, 86.11, 122.1, Yar 31.6\x*  
\q2 tinaga hongo holene tene í̠ kegonigo lowa  
\q2 uruni ti turu haaboho holebira.   
\q1
\v 6 Ti Hari Saiono pole pialu Baga dindi ulini iba nabere mbira ngagoria tagira poragola  
\q2 dindi yobi iba nabere wiyagoni ndo iba tagira ibulebira.  
\q1 Dindi ulini ngarunaga iba birumaga ladaga halu  
\q2 iba gendo ngarunaga iba dugutagi hagahaga bulebira.   
\q1
\v 7 Ti iba ani bedaria nama pialu ti hongo ho yalu polebira.\x + \xo 84.7 \xt Iba 42.2, Ais 40.31, Yo 1.16, 2 Ko 3.18\x*  
\q1 Ti Hari Saiono anda pialu howa Ngode Datagaliwabe karia hondolebira.  
\q1 Ngode Datagaliwabe ibu wali agalime bi pupu wule mbirale gime wabini heledaru ale ndo  
\q2 ibu daligaore gibi henedane ti hondolebira.   
\b  
\q1
\v 8 Anduane Homogo Hongo Haihe Ngode Datagaliwabe-o  
\q2 i̱na í̠hondo bi larogo hale habe.  
\q1 Yagabanaga Ngode Datagaliwabe-o  
\q2 i̱na bi larogo bayuwaore hale habe.   
\q1
\v 9 Ngode Datagaliwabe-o í̠nime inanaga kini helo dabo helene kagoni  
\q2 ibugua ina de hondo mamage haga kago  
\q2 í̠na ibuhondo bayuwa turubini dege bigi bibe.   
\b  
\q1
\v 10 Í̠naga andaha horo mbiru hangu andapu harogome\x + \xo 84.10 \xt 1 Bit 23.5, Iba 27.4\x*  
\q2 horo daosini mbira tagira maruha haroruni bolangua hai holebira.  
\q1 Ai wali agali mini kowi karu baba mandagi ti andagani palu holenego i̱ hame nale kogoni.  
\q1 I̱naga Ngode Datagaliwabenaga anda panga harabaniore heyu haabo hole hamelo kogoni.   
\q1
\v 11 Anduane Homogo Ngode Datagaliwabe ibu inanaga mamage haganebi inanaga kini howa wá haganebi kagoni.\x + \xo 84.11 \xt Iba 34.10, 85.9, Ais 60.19-20, Mal 4.2\x*  
\q1 Ibugua inahondo bayale turubini dege bigi bialu ina mo yaraga halu kagoni.  
\q1 Ibunaga deni wali agali mana tigabi hangu bialu haga karuhondo  
\q2 ibugua mbirale bayale ngaru mbira nangule nalaga kagoni.   
\q1
\v 12 Anduane Homogo Hongo Haiheore-o wali agali í̠hondo mini mbiraore wuwa  
\q2 í̠ni hanaho karu ti turuoreho kagoni.   
\c 85  
\s1 Ngode Datagaliwabehanda Isaraeleali haru dai bilonaga bi lenego ogo  
\q1
\v 1 Anduane Homogo-o í̠ninaga dindi ngago hondowa  
\q2 dara halu biamogo birigoni.  
\q1 Isaraele wali agali bayaleore helo  
\q2 í̠na ti mo bayale hodai bilarigoni.   
\q1
\v 2 Tiha ko wiaru domo wahalu  
\q2 tigua mana ko biyarubi domo wahai harigoni.   
\q1
\v 3 Bamba í̠na tihondo keba timbuni ho harigo wahalu  
\q2 í̠na tandagaore ala harigobi ai nahe kegoni.   
\b  
\q1
\v 4 Ngode Datagaliwabe-o inanaga Pele Ngiaga í̠ kego  
\q2 ina haru dai bibe.  
\q1 Inahondo kebaore holeni nahabe.   
\q1
\v 5 Inahondo keba ho haabo holeberebe.  
\q1 Í̠ keba ho kegoni ereba naholebirabe.   
\q1
\v 6 Ina wali agali kamaru turu holoma̱ya\x + \xo 85.6 \xt Hab 3.2\x*  
\q2 inanaga holene mo hongo habe.  
\q1 Í̠na ani beregola iname í̠naga mini yaraga halu holeberema.   
\q1
\v 7 Anduane Homogo-o í̠nime ina gubalini ho haabo kego  
\q2 hondoloma̱ya walia habe.  
\q1 Ina bayale holoma̱yabi í̠na pele ngialu haru dai bibe.   
\b  
\q1
\v 8 Anduane Homogo Ngode Datagaliwabehanda bi larago  
\q2 i̱na hale ho haga kogoni.  
\q1 Iname mana ko ala bialu harimadagua lone biadai nabi harimayagua  
\q2 ibugua ibunaga wali agali ina kamaruhondo mo paliaho holene ngialu  
\q2 bayale holoma̱ya helolebira.   
\q1
\v 9 Wali agali ibunaga mini mo dunini ho haga karu  
\q2 ibugua ti pele mialu haru dai buleore mandabu kagoni ndobe.  
\q1 Ibugua ina haru dai bialu inanaga dindi ngagoria  
\q2 ibunaga pele mulene ina heba mandagi wiaabo holebira.   
\b  
\q1
\v 10 Horo ogoningi Anduane Homogonaga gubalini holenebi mini bilinahe holenebi  
\q2 lola halu hogimbu bialu mbiraore holebira.  
\q1 Anduane Homogonaga mini tigabi wulenebi mo palia holenebi  
\q2 biamaga howa tiha wulebira.   
\q1
\v 11 Wali agali Anduane Homogohondo mini bilina ho haragome  
\q2 dindini howa hama iraga holebira.  
\q1 Ngode Datagaliwabenaga mini tigabiwi kagome  
\q2 dahuliya andaga howa handadali holebira.   
\q1
\v 12 Anduane Homogohanda ina mo bayale ho helaragola  
\q2 mbirale iname beremaru bayale hai holebira.  
\q1 Inanaga dindiha tomoru bayale andaho hai holebira.   
\q1
\v 13 Wali agali tigua mana tigabi biragome Anduane Homogo ibilonaga  
\q2 hariga mo manda mandabu wulebira.   
\c 86  
\s1 Anduane Homogohanda biamogo bilo bi lenego ogo  
\q1
\v 1 Anduane Homogo-o i̱na bi larogo hale howa ladai bibe.  
\q1 I̱ hongo nahe howa i̱ni biamogo bibe naheore kogo  
\q2 í̠na i̱ biamogo bibelo hamelo ko.   
\q1
\v 2 I̱na í̠ talima ibalu haga kogonigo i̱ homoligo  
\q2 pele ngialu abale gi mibe.  
\q1 I̱ í̠naga biabe biahaga howa í̠hondo mini mbiraore wu kogonigo  
\q2 í̠nime i̱ pele ngibe laro.   
\b  
\q1
\v 3 I̱naga Anduane Homogo í̠ni hangu kego  
\q2 í̠na i̱ dara howa biamogo bia habe laro.  
\q1 Egerebagi alendobi bibahendengi howa i̱na í̠hondo bi laabo haruli.   
\q1
\v 4 Anduane Homogo-o i̱na í̠hondo bi laabo haga kogonigo  
\q2 í̠naga biabe biahaga i̱ kogo mo turu habe.   
\q1
\v 5 Í̠ni bayale biaga howa iname ko birimaru domo wahaga ke.\x + \xo 86.5 \xt Neh 9.17, Iba 25.8, Yol 2.13, Yna 4.2\x*  
\q1 Wali agali í̠hondo bi laga karu  
\q2 tihondo í̠na gubalini timbuni haabo ho kegoni.   
\b  
\q1
\v 6 Anduane Homogo-o i̱naga bi larogo bayuwa hale haore bibe.  
\q1 I̱ biamogo bia lalu í̠ olalu kogo hale habe.   
\q1
\v 7 I̱ biamogo bia larogola í̠na i̱ biamogo biaga kego mitangi bialu\x + \xo 86.7 \xt Iba 17.6, 50.15, 77.2\x*  
\q2 i̱ genda yu kongi biamogo bia lalu í̠nihondo bi laruli.   
\b  
\q1
\v 8 Anduane Homogo-o í̠ni ale mende naheore bibahende bolangua haiheore kegoni.\x + \xo 86.8 \xt Man 3.24, 2 Sml 7.22, Yar 10.6\x*  
\q1 Biabe í̠na biriligodagua bulene agali mbira naheore.   
\q1
\v 9 Hameigini tara tara í̠nime wabu helariru bibahendeme\x + \xo 86.9 \xt Iba 66.4, Ais 66.23, Mo 15.4\x*  
\q2 í̠nihondo ge duli hanga hole ibuwa  
\q2 tigua í̠ timbuniore kego lalu í̠ninaga mini yaraga halu holebira.   
\q1
\v 10 Í̠ni hanguore hongo timbunihe howa\x + \xo 86.10 \xt Iba 72.18, Ais 44.6-8, Mg 12.29\x*  
\q2 mbirale baya gibi tara tara ngaru í̠nime biaga kegoni.  
\q1 Ngode Datagaliwabe henene í̠ni hanguore kegoni.   
\b  
\q1
\v 11 Anduane Homogo-o mana i̱na bialu holiya hamelo kego biawai habe.\x + \xo 86.11 \xt Iba 25.5, Yar 32.39\x*  
\q1 I̱na horo bibahendengi mini bilinahe howa  
\q2 í̠na laredagua bialu holiya ani biawai habe.  
\q1 I̱naga mini í̠ha paga howa í̠naga biabe biaabo halu holiyabi  
\q2 í̠na i̱ biamogo bigi bibe.   
\q1
\v 12 Anduane Homogo i̱naga Ngode Datagaliwabe-o i̱naga miniha howa  
\q2 í̠naga mini yaraga haabo holebero.  
\q1 Ngode Datagaliwabe í̠ timbuniorebi mini lenebi kego, lalu  
\q2 i̱na wali agali karuhondo lamiaabo holebero.   
\q1
\v 13 Bibahendengi í̠na i̱hondo gubalini ho haabo kegoni.  
\q1 Í̠nime i̱ homolilono pele ngialu haru dai birigome  
\q2 i̱ homalu humbirini andaga nape kogoni.   
\q1
\v 14 Ngode Datagaliwabe-o wali agali minehe bu karume  
\q2 i̱la wai bule íbu kagoni ndobe.  
\q1 Agali ko mendeali kago dara nahaga karume  
\q2 i̱ homelo bo wahole bialu kagoni.  
\q1 Uruni tigua í̠naga bi hale habe manga haga kagoni.   
\q1
\v 15 Tigua ani biagagoyu Anduane Homogo í̠na dara holene irane nawini  
\q2 dara holene timbuni í̠ha to̱ledagome keba abale nahaga kegoni.  
\q1 Í̠na ina gubalini timbuniore ho howa  
\q2 bi ledego lone lo iriari nabiagaore í̠ mini bilinahe kegoni.   
\q1
\v 16 Í̠na i̱ koria dai bialu dara habe.  
\q1 I̱ ai̱yahanda biabe biaga wiyadagua bialu kogonigo  
\q2 i̱ mo hongo halu pele ngibe.   
\q1
\v 17 Anduane Homogo-o í̠naga mana bayaleore biaga ngego  
\q2 i̱hondo walia habe.  
\q1 I̱ waitigi bu karume manane ogoni de hondowa  
\q2 í̠nime i̱ biamogo bialu mo hongo ho heledagonida lo manda bialu  
\q2 tini taga timbuniore ho holebirago helo ani bibe.   
\c 87  
\s1 Yarusaleme tano mo yaraga halu iba gana lenego ogo  
\q1
\v 1 Anduane Homogo ibugua ibuninaga tano mbira hari hombene loma bini winigoria bini.   
\q1
\v 2 Ibugua Isaraelenaga dindi maru bu ngaru gubalini ho kagobi ndo  
\q2 Yarusaleme tanoore gubalini timbuniore ho kagoni.   
\q1
\v 3 Ngode Datagaliwabenaga tano odagoriani wali agali bu kamiru-o  
\q2 Ngode Datagaliwabe ibugua tí lalu bi baya turubioreru mbira laga birago hale halimu.   
\b  
\q1
\v 4 Ngode Datagaliwabe ibugua ogodagua laya.  
\q1 Wali agali i̱naga bi larogo hale halu biaga karu damenego dagalama porongi  
\q2 i̱na Iyibi wali agalibi Babilonia wali agalibi dagalamaga dege holebero, leda.  
\q1 Pilidia wali agalibi Taia wali agalibi Idiobia wali agalibi  
\q2 uruni tibi Yarusaleme wali agali heba dege dagalamaga holebero, leda.   
\b  
\q1
\v 5 Yarusaleme tano lalu agua lolebira.  
\q1 Hameigini tara tara paluyu pedaru  
\q2 ti bibahendenaga dindi duniniore ogoni holebira, leda.  
\q1 Ngode Datagaliwabe Hongo Haiheore kagome Yarusaleme heyu helalu  
\q2 dindi ogoni hongoheore helo mo hongoho helolebira.   
\q1
\v 6 Anduane Homogo ibugua wali agali maru dindi tara tarani karunaga minibi gili buwa  
\q2 Yarusaleme wali agalinaga minibi heba gilibumaga howa daga lamaga holebira.   
\q1
\v 7 Yarusaleme wali agali bu karume turuore howa iba gana lalu,  
\q1 Iname mbirale bayale bayale yu kamarunaga tene Yarusalemeha ngagoni, lalu holebira.   
\c 88  
\s1 Ngode Datagaliwabehondo biamogo bia lalu olenego ogo  
\q1
\v 1 Anduane Homogo Ngode Datagaliwabe-o i̱naga pele ngiagaore í̠ni kegoni.  
\q1 Horo bibahendengi i̱ biamogo bia lalu olaabo haruli.  
\q1 Mbiraga ngagoha howabi í̠hondo bi laabo haruli.   
\q1
\v 2 I̱naga bi larogo hale ha.  
\q1 I̱ pele ngi lowa olalu kogoni hale habe.   
\b  
\q1
\v 3 I̱ha genda damene dewaore íbu ngagome  
\q2 i̱ homolene kawareni pu kogoni ndobe.   
\q1
\v 4 I̱naga hongo holene ereba hai halu  
\q2 i̱ agali áyu dege homole bu karu ale homole kogonida.   
\q1
\v 5 Tigua i̱ yu wahayagola agali homeneru baba mandagi kogonida.  
\q2 I̱ agali marume bo wahalu pene ale howa  
\q2 homaliha wiradagua bidogoni.  
\q1 Agali mbira mbirali abogo lalu embedaho wahene  
\q2 biamogo bibe nahe aibe tobahe hagadagua i̱ haruda laro.   
\q1
\v 6 Í̠na i̱ gundu uli timbuni unuraore arumahe wiagoha bape ho waharigonida.   
\q1
\v 7 Í̠naga keba holene timbuni wigome i̱ dambi halu  
\q2 iba solowara timbuni bedagome dambi haradagua bu heledegonida.   
\b  
\q1
\v 8 Í̠na i̱naga nenegerume i̱ erembira ngialu piai heledegonida.  
\q1 Í̠na i̱ mo koorene ko howa hiriri bini heledegola  
\q2 tigua i̱ handa tara haga ka.  
\q1 Í̠na ani bidegome i̱ dariba ho heledegola  
\q2 hadalu pobe nahe kogoni.   
\q1
\v 9 I̱ genda yu kogome i̱naga de ko halu au hara.  
\q1 Anduane Homogo-o i̱na horo bibahendengi i̱naga gi yaraga howa í̠ olalu  
\q2 i̱ biamogo bia lalu haabo kogoni.   
\b  
\q1
\v 10 Í̠na wali agali homene ngaru mo heya halu  
\q2 agalime nabiagane aleru birilibe.  
\q2 Wali agali homenerume lone heyu howa í̠naga mini yaraga hagabe.   
\q1
\v 11 Wali agali homaliha ngarume, Í̠na gubaliniore ho kegoni, lagabe.  
\q2 Dindi mo ko heneha karume, Í̠ mini bilinahe kego, lagabe.   
\q1
\v 12 Arumaha karume í̠na agalime nabiaga ale biriliru de handagabe.  
\q2 Dindi ina embedaho waheneha pu karume  
\q2 í̠na mana bayale tigabi bereru de handagabe.   
\b  
\q1
\v 13 Anduane Homogo-o í̠na i̱ biamogo bibelo í̠ olalu ko.  
\q2 Egerebagi bibahendengi i̱na í̠hondo bi lalu haabo haruli.   
\q1
\v 14 Bi ani laruligo Anduane Homogo í̠na irane aginaga i̱ erembira ngialu kebe.  
\q1 Í̠na irane aginaga i̱ handa tara halu ha do kebe.   
\q1
\v 15 Bamba i̱ igiri emeneni hewangi genda dege yama ibalu henego  
\q2 áyu nde homolene kawareni haabo kogoni.  
\q1 Í̠na i̱ pani ngirirume i̱naga hongo holene bo pirilape henego kogoni ndobe.   
\q1
\v 16 Í̠naga keba holene timbuni ngegome  
\q2 i̱ bo dambi henego kogoni.  
\q1 Í̠na i̱hondo pani ngirigo nguwa dege babi bo baulo waharigoni ndobe.   
\q1
\v 17 Horombe mbiragabi urunidagua biaabo harigola  
\q2 iba li timbuni ibalu bibahende dambi hai hagadagua kome i̱ bo dambi helarigoni.  
\q1 Dindi bibahendeha howa waitigime i̱ bole ho mabu bu hagadagua  
\q2 ko dewa uruni i̱ koria ibaabo haga.   
\q1
\v 18 I̱naga nenegealiore hearume i̱ erembira ngialu í̠na piai helarigola  
\q2 ainde i̱naga nenege aruma holene dege ngeledegonida.   
\c 89  
\s1 Isaraele wali agali ti dindiha íbu ngangi tigua iba gana laga winigo ogo  
\q1
\v 1 Anduane Homogo-o í̠na ina gubalini haho wiaaboore haga kegonaga\x + \xo 89.1 \xt 1 Kin 4.31\x*\x + \xo 89.1 \xt Iba 101.1\x*  
\q1 i̱na iba ganaru lalu laaboore holebero.  
\q1 Í̠na mbirale mbira bigi bulebero lalu lowirigo pugua nabi biaiore haga kegonaga lalubi  
\q2 i̱na latagi halu laaboore holebero.   
\q1
\v 2 Í̠naga wali agali gubaliniho haga kegoni haho wiaaboore holebira manda bido.  
\q1 Í̠na bi lo wigi bideruni mbira lo aribia halu mendeale nalagaore  
\q2 hari ema bibe nahe li de hendedemagobi hongohe wiaabo ho ngagoni.   
\q1
\v 3 Í̠na lalu, I̱na agali mbira dabenego ogoni ibula habo nalolene bi mbira lowinigo ngo, lariyagoni.  
\q1 I̱naga biabe biahaga Debidihondo bi lowirigo pugua nabulebiraore lalu lamido, lariyagoni.   
\q1
\v 4 Isaraele wali agalinaga kini maha hama polebiraru bibahendeore  
\q2 Debidi í̠ha howa tagira pene hangume haga bulebira.\x + \xo 89.4 \xt 2 Sml 7.12-16, 1 Bit 17.11-14, Iba 132.11, Ab 2.30\x*  
\q1 Hameigini mendeme hapugua nabulebiraore, lamiriyagoni.   
\b  
\q1
\v 5 Ani laga biriyago Anduane Homogo-o dahuliyali dahuliya andagani bu karume  
\q2 í̠na mbirale baya gibi hangu bigi biriligonaga laga bialu  
\q2 turu howa iba ganame í̠naga mini mo yaraga halu kagoni.  
\q1 Anduane Homogo í̠ mini bilinahe howa mbira bulebero lo ngego biagaore kegonaga lalu  
\q2 iba ganaru tigua laga bialu kagoni.   
\q1
\v 6 Anduane Homogo-o dahuliya andagani bu karuni í̠ ale mbira nahe.\x + \xo 89.6 \xt Iba 40.5, 86.8, 113.5\x*  
\q1 Dahuliyali bu karunibi í̠ ale mbira naheore.   
\q1
\v 7 Dahuliyali haguane tini dege dege ngoaiho biruwabi  
\q2 tigua Anduane Homogo í̠ hondowa gi timbuniore haga ka.  
\q1 Dahuliyali Anduane Homogo í̠ ho mabubu haga karu  
\q2 tibi nde gi timbuni howa pandi hinu haga kagoni.   
\b  
\q1
\v 8 Anduane Homogo Ngode Datagaliwabe Hongo Haiheore-o  
\q2 hongo gibiorehe í̠ kegobi mbirali naheore.  
\q1 Anduane Homogo-o í̠na mbirale mbira bule ledego lo beregeda nabi biaore biaga howa í̠ mini bilinahe kegoni.   
\q1
\v 9 Iba solowara hongohe bedaru í̠na de hondo haga kegoni.  
\q1 Iba solowara ibu yaribu hongohe bialu bi lalu li̱le̱ laragola  
\q2 bi nale ema nabi berelo í̠na mo palia haga kegoni.   
\q1
\v 10 Iyibi wali agalinaga hongo holene tene gibi biago bo podalu  
\q2 bibahende mo ko haiore harigoni.  
\q1 Í̠naga hongo holene gibime í̠naga waitigi hearu bibahende bope hai harigoni.   
\q1
\v 11 Dahuliya andagabi dindi bibahendebi í̠ninaga dege nga.\x + \xo 89.11 \xt 1 Bit 29.11, Iba 24.1-2, 50.12\x*  
\q1 Í̠nime dindi timbuni ogo wabialu mbirale bibahendeore dindini wilo wabu wiriyarunibi  
\q2 í̠ninaga dege o bu ngaruni.   
\q1
\v 12 Mbirale uyurayagi ngarubi karubi unurayagi ngarubi karubi bibahendeore í̠nime wabini nga.  
\q1 Hari Tabo Hari Hemonolame Anduane Homogo í̠hondo turuore gibi halu iba gana lo ngiragoni.   
\q1
\v 13 Anduane Homogo í̠ hongo gibiorehe kegoni nde aguada.  
\q1 Í̠naga hongo holenego magi manda bibe nahe hongo gibiorehe kegoni aguadabe.   
\q1
\v 14 Í̠ kini howa wali agali bibahende haru kegonigo  
\q2 mana tigabi bulenenibi mana tigatiga dabolenenibi  
\q2 tiagaho biruwa haru kegoni.  
\q1 Í̠na mbirale bibahende bigi beregoria  
\q2 í̠naga gubalini holenebi mini bilinahe howa bulebero laridagua bulenegobi  
\q2 walia haabo halu haga kegoni.   
\b  
\q1
\v 15 Wali agalime í̠ duniniore kego mitangi bialu í̠hondo iba gana lo ngiaga karu  
\q2 ti í̠naga dara halu biamogo buleneni ibagabu ka.  
\q1 Wali agali uruni ti wá holeneha ibagabu haradagua bidago ti turuore au ho haruadabe.   
\q1
\v 16 Anigo í̠na tihondo baya turubini dege bigi bialu kegonaga  
\q2 tigua egerebagibi alendobi mbiragabi  
\q2 bibahendengi í̠naga mini mo yaraga halu haabo kagoni.   
\q1
\v 17 Inanaga hongo holene tene í̠ kegonaga iname í̠hondo turu timbuniore ho kama.  
\q1 Inanaga waitigi karu baba wai bialu kamaria  
\q2 í̠na ina gubalini halu dara howa  
\q2 wai buluma̱ya mo hongo haregola  
\q2 inanaga waitigiru bope halu ina wayali haga beremali.   
\q1
\v 18 Anduane Homogo-o í̠na waitigime bolilono ina mamage holene mbira í̠nime dabo helariya.  
\q1 Í̠ mana bayale tigabiorego hangu biaga ina Isaraele wali agalinaga Ngode Datagaliwabe baya buruguleore kegoni.  
\q1 Inanaga kini mbira ina haru helogo í̠nime ngirigoni.   
\b  
\s1 Ngode Datagaliwabehanda Debidihondo buleore lalu bi lowinigo ogo  
\q1
\v 19 Ala bambaore í̠na í̠naga biabe biahaga mini bilinaheore heago  
\q2 de gandeba mbira hendelo mialu  
\q2 de gandeba ogoniha howa í̠na bi ogodagua lariya.  
\q1 Wai biagane ami agali mini lene mbira i̱na dabaru.  
\q2 Wali agali bu hearu helowa ibu hangu dabalu  
\q2 ibunaga haguaneni kininaga manda mo karula haru.  
\q1 Karula howa haru haga kininaga dagiani berelaru, lariya.   
\q1
\v 20 I̱naga biabe biahaga Debidi hearia hondowa\x + \xo 89.20 \xt 1 Sml 13.14, 16.12, Ab 13.22\x*  
\q2 i̱na ibu tinaga kini helo dabo helalu  
\q2 weli loma binime ibu haguaneni odo wiru.   
\q1
\v 21 I̱na ani buwa i̱naga hongo holene ibu heba haaboore helolebero.  
\q2 I̱naga gime ibu mo hongo harogola ibu hongoheore haabo holebira.   
\q1
\v 22 Ani berogola ibunaga waitigirume ibu baba wai bialu  
\q2 ibu bope halu mo taga habe nahe holebira.  
\q1 Wali agali mini kowi karumebi ibu minupe habe naheore holebira.   
\q1
\v 23 I̱na ibunaga waitigi karuni geme hengedo mbaraho wahalu  
\q2 i̱naga kini ogoni handabe manga haga karuni bibahende homelo bo wahai holebero.   
\q1
\v 24 I̱na ibu gubalini timbuniore halu ibu heba haho wiaaboore holebero.  
\q1 Ibugua ibunaga waitigiru baba wai bigi birangi  
\q2 ibu wayali hangu haabo helolebero.   
\q1
\v 25 Dindi iba solowara mini Medidereniana bedagoria howa wima pialu  
\q2 iba timbuni mini Yuberedisi poragoria wiape kagoni  
\q2 bibahendeore Kini Debidi ibunaga halu ibugua handa gimbu bilo mulebero.   
\q1
\v 26 I̱na ani berogola ibugua i̱hondo ogodagua lolebira.  
\q2 I̱naga ababi i̱naga Ngode Datagaliwabebi í̠ kegoni.  
\q1 I̱ de handayaho howa mamage hagabi  
\q2 i̱naga pele ngiagabi í̠ hangu kegoni, lolebira.   
\q1
\v 27 I̱na ibu i̱ igini wahene helolebero.\x + \xo 89.27 \xt Mo 1.5\x*  
\q2 Kini maru karubi ndo ibu mo duniniore helolebero.   
\q1
\v 28 I̱naga gubalini haho wiaabo kogome ibu yu wa naholebero.  
\q2 I̱na ibula habo nalolene bi lo wuleberogo  
\q2 bi ogoni pugua nabi wiaabobo bu wilonaga lo wulebero.   
\q1
\v 29 Bibahendengi ibu damene hangume kini haabo holebira.  
\q1 Isaraelenaga kini hameigini mendeme ha pugua nabi  
\q2 Debidi ibuniha howa tagira pene hangume ho aribia haga biaabo holebira.  
\q2 Hari damindini haabo hene li kadagua haaboore hama polebira.   
\b  
\q1
\v 30 Ani ani bulebirago ai mani Debidi ibunaga aguanene hama porarume  
\q2 i̱na mana lo ngogo hale halu bia nabi mo wahalu  
\q2 i̱na bilimu lalu bi ledodagua nabiyaguabi   
\q1
\v 31 i̱na bi laga berogo hale howa mo yo handaga bialu  
\q2 tigua i̱naga erembira ngialu puguabo hayaguabi   
\q1
\v 32 nde i̱na tigua ko biraruni ilu wu ha dege buwa pani mulebero.  
\q2 Tigua mana liahe dewaore biyagonaga tandaga nalu howa manda bilo  
\q2 i̱na gewa tibume mana lalu bolebero.   
\q1
\v 33 Ani ba boleberogoyu  
\q2 i̱na Debidi gubaliniho kogoni nde ogoningibi gubalini haho wiaaboore holebero.  
\q1 I̱na ibu yu wanahe ibuhondo habo nalolene bi lo wirugobi pugua nabulebero.   
\q1
\v 34 I̱na ibula habo nalolene bi lo wirugobi napugulebero.\x + \xo 89.34 \xt Dag 23.19, Man 7.9, Yar 33.20-21\x*  
\q1 Bulebero lalu lo wirugo ariabi mbiraore hangubi habo nalolebero.   
\b  
\q1
\v 35 I̱ Ngode Datagaliwabe mana bayale tigabioreru hangu biaga kogo howa  
\q2 habo nalolene bi ogoni lo wirugoni.  
\q1 I̱na bi halu mbira hangu lo ngogoni mani wia ai̱ai̱ bilonaga lo ngeledogoni.  
\q1 I̱na Debidihondo bi lowirugo ke̱ halu habole naloleberoore.   
\q1
\v 36 Debidinaga aguanene ti ho tawe hama puaboore holebira.  
\q1 Kini Debidinaga haru holene ngagoria  
\q2 ibunaga aguanene maha hararu mbiragome mia aribia haga bima piaho ngane  
\q2 honani dalu haho ngadagua  
\q2 tigua wali agali haru haho wiaaboore holebira.  
\q1 Ti ani haru helonaga i̱na handayaho holebero.   
\q1
\v 37 Kini Debidi ibu ariame dege wali agali haru haho ngane  
\q2 ege mbiraga tagira ibuwa dalu wáho kalidagua haru haaboore holebira.  
\q1 Ege li harini kagonime mbirale bibahende de handai ho howa  
\q2 wali agali bibahendehondo i̱na bi lo ngoruni  
\q2 henene hanguore leda lalu lo pana haga ege ibu li harini kagoni.   
\b  
\s1 Kininaga waitigirume ibu bope hayagola dugu binigo ogo  
\q1
\v 38 Anigo áyu í̠naga kini í̠nime dabo helarigo ibula kebaho kegoni.  
\q2 Kini ibuni hangu helo wahalu í̠ erembira mialu pedegoni.   
\q1
\v 39 Í̠naga biabe biahaga biagola habo nalolene bi lo wirigoni í̠nime puguarigoni.  
\q2 Pugualu kininaga manda golo muwa waruha ba horo helarigome  
\q2 ai kininaga manda biagoni mebia halu angu to̱lobu wahayagoni.   
\q1
\v 40 Ibunaga tanonaga ege pabe biaruni gialo payabu waharigome  
\q2 ai ibunaga anda hongohe bu helearuni bibahende mo ko hai hayada.   
\q1
\v 41 Ani bidagola ibunaga dabudabu panigi bu payabu ngaria  
\q2 wali agali hariga puíbu birarume mo page yalu pugu bira.  
\q2 Wali agali ibula mandagi handa ai̱ na̱i padarume ani birago handaragola  
\q2 ibuhondo mege bialu oba halu kagoni.   
\q1
\v 42 Í̠na ibunaga waitigirume kini biagoni balu bope helalu  
\q2 waitigi biaru ti miniha turu halu mambolo bama pelariyagoni.   
\q1
\v 43 Kini biagonaga wai biagane ami agali hayarunaga hongobi  
\q2 tinaga wai biagane ale wiaru bibahendenaga hongobi  
\q2 pirilipe hai helariya.  
\q1 Ibu wai bialu hearia bope helalu dari helariyagoni.   
\q1
\v 44 Ani helalu ibu kini howa wali agali haru haga hayagoni ogoningi hairi helalu  
\q2 ibuni dindiha minupeho berelariyagoni.   
\q1
\v 45 Í̠na ibunaga mali gadia dai bialu ibuni abaleore mo agali wahe helarigome  
\q2 ibu mo taga holene gibioreme dambiho heledegoni.   
\b  
\s1 Ngode Datagaliwabehanda ibu gi milo ibuhondo bi lenego ogo  
\q1
\v 46 Anduane Homogo-o í̠ ha do ho kegoni nde ani haaboore hole kebe.  
\q1 Í̠naga keba holene gibi  
\q2 ira daradagua dalu kagoni dairi agoangi holebirabe.   
\q1
\v 47 Anduane Homogo-o ina wali agali dindini bu kamaruni  
\q2 nde lu ndo emene tigimandi hangu halu  
\q2 homaga kamagonidago manda bibe laro.  
\q1 Í̠na ina bu kamaruni wabiriyago  
\q2 áyu nde ina bibahende bu kamaruni mini homa biago kamago  
\q2 homalu ereba hai hole kamagonidago manda bibe.   
\q1
\v 48 Mbirali nahome haho wiaaboore holego ai kabe.  
\q2 Mbogoyi heba uliha yaanda haragola i̱ mangabago  
\q2 heyalu poro labehe mbirali ai kabe.   
\b  
\q1
\v 49 Anduane Homogo-o ainde agua berebe.  
\q1 Ai áyu ina gubalini naheore kebe.  
\q2 Debidihondo habo nalolene bi lo wialu  
\q2 ogoale bulebero lo wigi biriruni agua buleberebe.   
\q1
\v 50 Anduane Homogo-o í̠naga biabe biahaga o kogo nde mitangi bibe.  
\q2 Wali agali í̠ mitangi nabiaga bu karume i̱ mege bialu kagoni.  
\q1 Tigua i̱hondo bi ko tara tara lalu  
\q2 tandaga ngiragola i̱ genda yu howa dongeho haruli.   
\q1
\v 51 Anduane Homogo-o í̠na i̱ kini holiya dabo helarigoni kogola  
\q2 í̠naga waitigi karume i̱hondo bi ko lalu ka.  
\q1 I̱ porogoha bayale mbira nawi  
\q2 i̱ mege bialu mo ko haga karia dege iraga haga bialu kogoni.   
\b  
\q1
\v 52 Iname Anduane Homogonaga mini mo yaraga haaboore halu hami̱ya hameledo.  
\q1 Ani bilo. Aniore bilo laro.   
\c 90  
\s1 Mbiralime Ngode Datagaliwabehondo bi lenego ogo  
\q1
\v 1 Anduane Homogo-o í̠ inanaga andaore haradagua bidegoni.\x + \xo 90.1 \xt Man 33.27\x*  
\q1 Inanaga mamali heneyaru tibi í̠ha dege howa heneyago  
\q2 ai áyu inabi í̠ha dege howa bu kamagoni.   
\q1
\v 2 Dindini hari wedarubi nawe howa mbirale bibahende dindini ngarubi nawabi howa\x + \xo 90.2 \xt Min 8.25-26\x*  
\q2 Ngode Datagaliwabe í̠niore ala haabo heneyago  
\q2 áyubi haabo kego manibi haho wiaaboore hole kegoni.   
\b  
\q1
\v 3 Wali agali bu kamaruni homalu lone dindi tagobi lelariligoni.  
\q1 Í̠na inahondo, Dindi wali agali bu kamiruni tí dindime wabinigo homalu  
\q2 lone dindiho dai bilimu, lalu kegoni.   
\q1
\v 4 Iname mali daosini (1,000) mbira bolangua hayago lu laramaligo\x + \xo 90.4 \xt 2 Pi 3.8\x*  
\q2 í̠na ogoni lu ndo bame abe harimago handaradagua birili.  
\q1 Mbiraga agalime mamage ho ariari bialu  
\q2 mbiraoregome mamage tigimandi haraligobi tigimandidane handaga kegoni.   
\q1
\v 5 Iba li ibalu wali agali hiliyalu poragola iba nalu homagadagua  
\q2 í̠na wali agali hiliyalu pirili.  
\q1 Ina emene tigimandi hanguni emaga handaradagua bialu halu homaramali.  
\q1 Ina egerebagi tani mbira áyu dege delatagi howa   
\q1
\v 6 ala anda haga bialu lini dalu  
\q2 ni handaragola yo bialu  
\q2 alendo gaulo daga hagadagua ina ani bialu kamagoni.   
\b  
\q1
\v 7 Í̠na inahondo handabe mangaho kegonaga  
\q2 iname í̠ hondowa gi timbuniore ho kamagoni.  
\q1 Í̠naga keba holeneme ina handayaho kegome  
\q2 ina bibahende do ereba hai haramagoni.   
\q1
\v 8 Inanaga mana ko tara tara beramaliruni  
\q2 bibahendeore í̠ de handaiho kegoni.  
\q1 Mana ko maru ohowa bia do hene birimarubi  
\q2 bibahendeore í̠ deni panigi mo ngelowa kegoni.   
\b  
\q1
\v 9 Ina wali agali dindini lu holenego í̠naga keba holeneme mo tubagi halu  
\q2 inanaga bu̱he bame halu mbira hangu laradagua abaleore lalu bolangua haragoni.   
\q1
\v 10 Ina wali agali dindini mali pira karia hangu haramali.  
\q1 Hongohe harimayagua nde mali pira halira haramali.  
\q1 Anigo áyu o haramadagoniha genda bulene erekui biabe bulenela dege ngaria handalu haramali.  
\q1 Mali podo nginidadagua hai halu bialu  
\q2 inane abaleore pu ereba haramali.   
\b  
\q1
\v 11 Í̠naga keba holenenaga hongo gibi ngegoni de handai hene ai kabe.  
\q1 Wali agalime mana ko biraru hondowa í̠na handabe mangaho kegola  
\q2 wali agalinaga bu miniha gi timbuni bulene tagira ibaganego aiwa manda bidabe.   
\q1
\v 12 Ina dindini lu ndo emene tigimandi hangu hole harimada manda buluma̱ya\x + \xo 90.12 \xt Iba 39.4\x*  
\q2 í̠na lawaiha biawaiha bibe.  
\q1 Inanaga horo dagalo wia heneni harimada manda bialu  
\q2 miniwi holoma̱ya í̠naga mini dingi dangia lolenego inanaga bu habaneha wia habe.   
\b  
\q1
\v 13 Anduane Homogo-o í̠na inahondo kebaho haabo kegoni agoangi hairi hole kebe.\x + \xo 90.13 \xt Har 32.12-13\x*  
\q1 Ina í̠naga biabe biahaga kamaru hondowa dara habe.   
\q1
\v 14 Ina horo bibahendengi dindini hama poramangi  
\q2 miniha turu halu dungu lowa iba gana lalu haabo holoma̱ya  
\q2 í̠na egerebagi bibahendengi í̠naga gubalini haho wiaabo holeneme inaha to̱lotagiho helaga bibe.   
\q1
\v 15 Í̠na mali dewani ina genda yu dindihaore warapeho helarigonigo  
\q2 ai áyu ina lone mo turuho helabe.  
\q1 Ina genda yu hemane mali piyago daga lowa  
\q2 mali o biagoni taheni turuho hama poloma̱ya ina mo turu habe.   
\q1
\v 16 Í̠na biabe hongohe gibi beredaru í̠naga biabe biahaga kamaru ina hondoloma̱ya walia habe.  
\q2 Inanaga waneigini maha hararu tibi í̠naga hongo holene baya tara tara ngeru hendelo mo walia habe.   
\q1
\v 17 Anduane Homogo inanaga Ngode Datagaliwabe-o  
\q2 iname í̠ duniniore ke mitangi bialu haramaligo\x + \xo 90.17 \xt Iba 27.4, Ais 26.12\x*  
\q2 í̠na inahondo dara halu baya turubini bigi bibe.  
\q1 Iname mbirale bigi beramaru bayale haga bialu  
\q2 lini daga bilo buluma̱ya mo hongo habe.   
\c 91  
\s1 Anduane Homogo ibu inanaga mamage haga kagonigo ogo  
\q1
\v 1 Mbirali Anduane Homogo Daligaorene Daliga kagoha ha do hole porago\x + \xo 91.1 \xt Iba 31.20, 121.5, Ais 25.4, 32.2\x*  
\q2 ibu Anduane Homogo Bibahende Hongo Haiheore kagonaga tuha puwa  
\q2 baya turubini pu holebira.   
\q1
\v 2 Anduane Homogonaga tuha howa ibugua ibuhondo ogodagua lolebira.\x + \xo 91.2 \xt Iba 14.6, 18.2, 56.4, Yar 16.19\x*  
\q2 Í̠na i̱ bu dambi halu i̱naga pabe tigila í̠ howa i̱ baya hangu handayaho hariligoni.  
\q1 I̱naga Ngode Datagaliwabe í̠ kegoni.  
\q2 I̱na í̠ni hanaho kogoni, lolebira.   
\q1
\v 3 Heneneore Ngode Datagaliwabe ibugua í̠ baya hangu handayaho halu mamage holebira.\x + \xo 91.3 \xt 1 Kin 8.37, Iba 124.7, Min 6.5\x*  
\q2 Damame agalimeyaguabi gono wia do hene ngaruha í̠ do wia nabulebere.  
\q1 Warago hiriribi tara tara wali agali bo home laganeale ngarumebi í̠ ela naholebira.   
\q1
\v 4 Ega angibunime ibunaga babaganeme ibu igini bu dambi hagadagua\x + \xo 91.4 \xt Iba 36.7, 40.11, 63.7, Ais 51.16\x*  
\q2 Anduane Homogo ibugua í̠ bu dambiho holebira.  
\q1 Ani biragola í̠ ibunaga tuha howa bayaleore holebere.  
\q1 Anduane Homogohanda bule ledago biaga mini bilinahe kago  
\q2 ibugua í̠naga humbi howa ibu erembiraha mo ngelowa hatali wu holebira.   
\q1
\v 5 Mbirale mbira mbiraga bulubada lowa í̠ miniha gigi howa palulene nawi.\x + \xo 91.5 \xt Yob 5.19-23, Iba 23.4, 27.1, 64.4\x*  
\q1 Horombe howabi í̠ nahende keria abale ibuwa í̠ balu polobada lowa  
\q2 í̠ gigi howabi holene nawi.   
\q1
\v 6 Dama ko tara tara bu karume mbiraga horombebi wali agali bo wahama ibaga bialu kago\x + \xo 91.6 \xt 2 Kin 19.35, Yob 5.22\x*  
\q2 í̠na dama uruni hondowabi gi holene nawi.   
\b  
\q1
\v 7 Áyu dege í̠ deni wali agali daosini mbira (1,000) bibahende homa hilayaguabi\x + \xo 91.7 \xt Yos 14.10\x*  
\q2 daosini pira (10,000) í̠ kegohayagi homai hayaguabi  
\q2 í̠ ela naholebirago giho holene nawi.   
\q1
\v 8 Anduane Homogohanda wali agali ko biaga karume mana ko biyagonaga pani mirago\x + \xo 91.8 \xt Iba 37.34, 58.10\x*  
\q2 í̠ni deme handalu hondolebere.   
\b  
\q1
\v 9 Í̠na Anduane Homogo í̠naga mamage haga helalu  
\q2 í̠naga Ngode Datagaliwabe Daligaorene Daliga kago hatali wiagane humbi helarigoni.   
\q1
\v 10 Ani helo waharigome mo ko holene tara tara ngarume í̠ kegoria anda naibulebira.  
\q1 Warago ko tara tara gendabi ngarubi í̠ andagani anda naibulebira.   
\q1
\v 11 Ngode Datagaliwabe ibugua ibunaga dahuliyaliru lamialu\x + \xo 91.11 \xt Iba 34.7, Md 4.6, Lg 4.10\x*  
\q2 í̠ ibagabu kegoha, Tí mamage hama ibagabu hole pudaba, lalu lamulebira.   
\q1
\v 12 Ege to̱le̱ ngagome í̠naga ge nabehedagola  
\q2 dahuliyali uruni tinaga gime í̠ taba yaraga holebira.\x + \xo 91.12 \xt Md 4.6, Lg 4.11\x*   
\q1
\v 13 Í̠naga geme laionobi nogombibi\x + \xo 91.13 \xt Hgn 14.6, Dan 6.22, Lg 10.19\x*  
\q2 laiono hungubaluabi puya tomia palebi  
\q2 bibahende hengeda hai holebere.   
\b  
\q1
\v 14 Ngode Datagaliwabehanda ogodagua larago,\x + \xo 91.14 \xt Iba 9.10, 59.1, 145.20\x*  
\q1 Wali agali i̱ gubalini heneneore ho karu  
\q2 i̱nime ti haru dai bialu pele mulebero.  
\q1 I̱ tinaga Anduane Homogo ka lowa henene yu tigabu karu  
\q2 tinaga hatali wiaga humbi i̱nime holebero.   
\q1
\v 15 Tigua i̱ olaragola i̱na tinaga bi larago hale halu ladai bulebero.\x + \xo 91.15 \xt 1 Sml 2.30, Yob 12.4, Yo 12.26\x*  
\q2 Ti kagoria gendabi íbu ngangi i̱ni ti heba haabo holebero.  
\q2 Ina ti gi mialu haru dai bialu ti mo yaragaho helolebero.   
\q1
\v 16 Tinaga holene lu hama pelo tinaga mali mo tago holebero.  
\q2 Tigua bima ibiyagonaga yolo uruni mulebero.  
\q2 Ina ti pele mialu i̱ni ti heba haabo holebero, lene.   
\c 92  
\s1 Anduane Homogonaga mini yaraga halu iba gana lenego ogo  
\q1
\v 1 Anduane Homogo-o í̠hondo ka̱i̱ lolene bayaleoreda.  
\q1 Í̠ Ngode Datagaliwabe Daligaorene Daliga kegoni lalu  
\q2 í̠ mini yaraga halu iba gana lolene bayaleore ngagoni.   
\q1
\v 2 Egerebagi bibahendengi í̠na i̱ gubalini ho haabo kegonaga lolene karulape ogoni.  
\q1 Mbiraga bibahendengi i̱na í̠ mini bilinahe kegonaga lolebero.   
\q1
\v 3 I̱na ngida ale tara tararu balu í̠naga mini yaraga holebero.   
\q1
\v 4 Anduane Homogo-o í̠na biabe hongohe biriru mitangi bialu i̱ turuho kogoni.  
\q1 Í̠na bayaleore dewa birigonaga  
\q2 i̱na turuore halu iba ganaru lolebero.   
\b  
\q1
\v 5 Anduane Homogo-o í̠na biabe biriliru timbuniore hongohe biaga ke.\x + \xo 92.5 \xt Iba 139.17, Ais 28.29, 55.8-9, Lm 11.33-34\x*  
\q1 Í̠naga miniha mitangi bideru iname manda bibe nahe kamagoni.   
\q1
\v 6 Wali agali mini nawi karumebi mini giga nabi karumebi  
\q2 mbirale uru manda nabibehe ka.   
\q1
\v 7 Wali agali mini kowi bu karu ti datani bu hagagobi ka.  
\q2 Ko biaga bu karume mbirale ngago damene yu howa homogo ha holebira.  
\q1 Ani bulebiragoyu ti mo ko hai halu erebaore holebira.   
\q1
\v 8 Anduane Homogo-o í̠ni kini haluhe haabobo hagaore kegome ti ani bulebira.   
\b  
\q1
\v 9 Agali í̠la waitigiho karu ti homalu  
\q2 agali mini kowi karu bope hai holeberego ina mandabu kamagoni.   
\q1
\v 10 Í̠na nogo bulumaga wangabe gabuanaga hongo kaligobi i̱ha hongo timbuni helari.  
\q1 Í̠na i̱hondo bayale birigonaga turuore ho kogoni.   
\q1
\v 11 I̱ waitigi bu hearu mo ko hai harigo de handalu  
\q2 agali ko hearu yiya lalu dugu biayuago hale haru.   
\b  
\q1
\v 12 Wali agali mini tigabi bu karu ti ayage timbuni andaho karubi holebira.\x + \xo 92.12 \xt Iba 1.3, 52.8, Ais 65.22, Hos 14.5-6\x*  
\q2 Ti Lebanono irabuha ira tamia bayale timbuni bu karubi holebira.   
\q1
\v 13 Ti Anduane Homogonaga anda haneni ira hengene mbira haradagua bida.\x + \xo 92.13 \xt Iba 100.4, 135.2\x*  
\q1 Inanaga Ngode Datagaliwabe ibunaga andaha howa ti bayaleore holebira.   
\q1
\v 14 Ti lu ho waheneore heaguabi lini bayale daabo haga kagoni.\x + \xo 92.14 \xt Iba 1.3, Yo 15.2\x*  
\q2 Tinaga yuniru gahenge halu  
\q2 ti hongohe haabo howa gabu nahaga ka.   
\q1
\v 15 Ti ogonibi kagome Anduane Homogo ibu mini tigabiore kago hendelo mo walia ka.  
\q2 I̱naga hapai haga kago ibuha lehe mbira nawiore.   
\c 93  
\s1 Anduane Homogo ibu kini kagonigo ogo  
\q1
\v 1 Anduane Homogo ibu kini kagoni.  
\q1 Ibunaga mini mo yaraga holenebi hongo gibihe holenebi karulowa kagoni.  
\q1 Dindi timbuni o ngagoni ibunime wabu winiyadagua  
\q2 ema bialu girigurabi mbira bule ndoore ngagoni.   
\q1
\v 2 Anduane Homogo-o bambaore mbirale bibahende nawiangi\x + \xo 93.2 \xt Iba 45.6, 90.2, Dug 5.19\x*  
\q2 í̠na handame ho haabo hene kegoni.  
\q1 Í̠ ala henerunagabi áyu kamarunagabi  
\q2 mani holebirarunagabi kini haluhe haabo kegoni.   
\b  
\q1
\v 3 Anduane Homogo-o iba solowararu uli unuraoreha berenerume  
\q2 ai áyu bi timbuniore hongo howa tilitula lalu la ho nga.   
\q1
\v 4 Anduane Homogo í̠na mbirale bibahende dahuliya andagani ngagoni  
\q2 í̠naga hongo gibihe kegome yani howa handayaho kegoni.  
\q1 Iba solowara tilitula lalu kadu bararaga bialu karuni  
\q2 hongo emene bamedago lowa í̠ hongo gibiorehe kegoni.  
\q1 Iba solowara yaribu buyu ibalu iba angeni hongo howa haealo bade haga bialu karuni  
\q2 emene bamedago lowa í̠ hongo gibiorehe kegoni.   
\b  
\q1
\v 5 Anduane Homogo í̠naga mana lo ngeruni bibahendeore wialu wiaabobore bulebira.\x + \xo 93.5 \xt Iba 19.7, 29.2, 96.9, 1 Ko 3.17\x*  
\q2 Í̠naga anda loma biniore kagoni ibu haho wiaaboore holebira.   
\c 94  
\s1 Anduane Homogohanda wali agali ko biagabi bayale biagabi tigatiga dabolebirago ogo  
\q1
\v 1 Anduane Homogo í̠ Ngode Datagaliwabeore howa\x + \xo 94.1 \xt Ais 35.4, Nah 1.2, Lm 12.19\x*  
\q2 wali agali mana ko biaga karume biyarunaga pani nelo mirili.  
\q2 Áyu í̠naga lembo holene ngego tihondo mo walia habe.   
\q1
\v 2 Wali agali bibahende í̠naga deni íbu hai helolebere.  
\q2 Wali agali mine haga karume mana ko biyarunaga pani nelo abale mule ibabe.   
\q1
\v 3 Mana ko biaga bu karume mana ko bialu turuho helo henge agua agima muleberebe.\x + \xo 94.3 \xt Yob 20.5, Iba 13.2\x*  
\q2 Anduane Homogo-o tinaga henge agira ngabe.   
\q1
\v 4 Agali ko biaga karume mana ko biyagonaga turu haga bialu  
\q2 mine ho helo horo agiru heloleberebe.   
\b  
\q1
\v 5 Anduane Homogo-o uruni tigua í̠naga wali agali bo hengedape halu  
\q2 genda timbuni mo mialu kagoni ndobe.   
\q1
\v 6 Wali dalo berearubi waneigini ai̱ya abala homene karubi  
\q2 tigua bo wahai haga ka.  
\q2 Wali agali dindi taraha howa inanaga dindini íbu hene karu  
\q2 homelo bo wahai halu biaga.   
\q1
\v 7 Tigua lalu, Anduane Homogohanda ina de nahendeda.  
\q2 Isaraele wali agalinaga Ngode Datagaliwabehanda iname bialu kamarunaga manda nabi  
\q2 bame kago waha, laga ka.   
\b  
\q1
\v 8 I̱naga wali agaliru-o tígua mana ko dege biaabo halu kamigo agua beremibe.  
\q2 Tí wali agali mini nawi lulu ale kamigo angi mini wiadai buleberemibe.   
\q1
\v 9 Ngode Datagaliwabehanda inanaga hale wabu helenego  
\q2 ibu bi hale habe nahe kabe.\x + \xo 94.9 \xt Har 4.11, Min 20.12\x*  
\q2 Ibugua inanaga de wabinigo  
\q2 ai ibu de handabe nahedabe.   
\q1
\v 10 Hameigini tara tara dindi bibahendeha karume ko biragola\x + \xo 94.10 \xt Yob 35.11, Iba 44.2, Ais 28.26\x*  
\q2 ibugua ti mo tiga bialu pani namulebirabe.  
\q2 Ibugua wali agali lawai haga kago ibuha manda mbira nawi kabe.   
\q1
\v 11 Anduane Homogo ibugua wali agalinaga miniha bibahende ngaru manda biaiho ka.\x + \xo 94.11 \xt Yob 11.11, 1 Ko 3.20\x*  
\q2 Tigua ogoale bule lomanda manda bu kago hondowa  
\q2 ibugua mbirale uruni bibahende tagira napolebira mandabu ka.   
\b  
\q1
\v 12 Anduane Homogo-o í̠na wali agali mo tiga biriru ti turuho ka.\x + \xo 94.12 \xt Yob 5.17, Min 3.11, 1 Ko 11.32, Hi 12.5\x*  
\q2 Í̠naga mana lowini ngego lawai hene karu tibi turuho ka.   
\q1
\v 13 Í̠na ogonidagua bini karu ti miniha dungulo kane dege  
\q2 agali ko biaga karu ti homai halu homaliha piai helo  
\q2 í̠ maliaho haga ke.   
\q1
\v 14 Anduane Homogohanda ibunaga wali agali yu wa nahaga ka.\x + \xo 94.14 \xt 1 Sml 12.22, Lm 11.1-2\x*  
\q2 Heneneore ibugua ibunaga wali agali bu karu  
\q2 erembira mialu yu wanahagaore ka.   
\q1
\v 15 Mani howa agali godi lararume tigatiga dege lolebira.  
\q2 Ani laragola hale howa wali agali tigabi karume  
\q2 bi ogoni talialu bialu holebira.   
\b  
\q1
\v 16 Mbiralime i̱ biamogo bialu agali ko hearu bope hayago aibe.  
\q1 Mbirali i̱la mandagi howa agali ko biaga hearu ko nabilonaga  
\q2 i̱ biamogo biyago aiwabe.   
\q1
\v 17 Anduane Homogohanda i̱ biamogo nabinidale  
\q2 nde i̱ homene dininiru piagagoha abale pu kole.   
\q1
\v 18 I̱na lomanda bialu koria i̱ ge harogoria gondo lalu i̱ pilarogonigo laru.\x + \xo 94.18 \xt Iba 38.16\x*  
\q2 Ai Anduane Homogo-o í̠naga gubalini haabo hariligome  
\q2 í̠naga gime yania harigola i̱ pi nale bayale kogoni.   
\q1
\v 19 Horo i̱ genda ho kongi howabi ko ngarunaga mini dege dindiho hewagolabi  
\q2 í̠nime i̱naga mini mo palia halu i̱ turuho helarigoni.   
\b  
\q1
\v 20 Agali haguane tigabi ndo ko dabaga karu baba  
\q2 í̠ biabe mandagi nabiaga kegoni.  
\q2 Agali ko uruni tigua wali agalime mana ko biraru hondowa  
\q2 karulape dege bira lalu ani bialu helo wahaga ka.   
\q1
\v 21 Tigua wali agali ko nabi bayale biaga karu mo ko hole ndinde laga ka.  
\q2 Wali agali tiha ko nawi karu homelo bo wahole  
\q2 ko biaga urunime manani helalu kagua dabaga ka.   
\q1
\v 22 Anigo Anduane Homogohanda hongoheore howa i̱ biamogo biaga ka.\x + \xo 94.22 \xt Iba 59.9, 62.2, 62.6\x*  
\q2 I̱naga Ngode Datagaliwabehanda i̱ baya hanguore handayaho haga kagoni.   
\q1
\v 23 Tigua mana ko dewaore biyagonaga ibugua emena ko ngaru tihondo mo mulebira.  
\q2 Tinaga ko biyaru mitangi bialu tini homelo ibugua ti bo wahai holebira.  
\q1 Anduane Homogo inanaga Ngode Datagaliwabehanda ti bo wahaiore holebira.   
\c 95  
\s1 Anduane Homogonaga mini mo yaraga halu iba gana lenego ogo  
\q1
\v 1 Uru-o ti ibidaba.  
\q1 Anduane Homogonaga mini mo yaraga halu iba gana lami̱ya ibidaba.  
\q1 Ngode Datagaliwabe ibugua ibunaga hongome ina haru dai bialu pele ngiyago mitangi bialu  
\q2 ibuhondo turu halu iba gana lo mimi̱ya ibidaba.   
\q1
\v 2 Iname ibu kagoria kaware hapara howa ibuhondo ka̱i̱ lo mali̱ya ibidaba.  
\q2 Iba gana baya turubiru ibunaga mini mo yaraga halu  
\q2 ibuhondo lo mimi̱ya ibidaba.   
\q1
\v 3 Anduane Homogo ibu Ngode Datagaliwabe hongohe kagoni.  
\q2 Ibu kini hongo gibihe howa  
\q2 dama mitangi bialu wali agali gime wabini karubi ndo  
\q2 ibu daligaore gibi kagoni.   
\q1
\v 4 Ibugua gundu uli unura wiape karuha howa  
\q2 handame hama iralu hari daligaore wedarunaga neneni handairi howa  
\q2 dindi bibahendeha handame ho kagoni.   
\q1
\v 5 Ibugua wabini iba solowara bedarubi dindi bibahende ngarubi  
\q2 bibahende ibunime dege handame ho kagoni.   
\b  
\q1
\v 6 Uru-o ti ibidaba.  
\q1 Iname inanaga ma podope halu Anduane Homogo ibu duniniore kago mitangi bialu ibuhondo lotu lami̱ya.  
\q1 Anduane Homogo ibu ina Wabiaga kago  
\q2 iname ibu kagoria kaware ibuwa ge duli hangaho biruwa  
\q2 ibu mitangi bialu lotu lami̱ya ibidaba.   
\q1
\v 7 Ibu inanaga Ngode Datagaliwabe kagoni.\x + \xo 95.7 \xt Iba 80.1, 100.3\x*\x + \xo 95.7 \xt Hi 3.15, 4.7\x*\x + \xo 95.7 \xt Hi 3.7-11\x*  
\q2 Ibugua ibunaga wali agali bu kamaru nogo sibi haru haradagua haru haga kagoni.  
\q2 Ina tomo noloma̱ya ibugua ngiaga kagoni.  
\q1 Ibugua áyu bi o larago hale hadaba.   
\b  
\q1
\v 8-9 Ngode Datagaliwabehanda tihondo bi lamialu lalu,\x + \xo 95.8-9 \xt Dag 14.22, Man 6.16\x*\x + \xo 95.8-9 \xt Har 17.1-7, Dag 20.2-13\x*  
\q2 Tinaga mamali ala henerume i̱naga bi hale howa nahe tingi halu  
\q2 tinaga bu miniha anda polani hondowa i̱la waitigi ho hene.  
\q1 Tigua dindi ko wali agali nahaga mini Meriba Masala wiagoria  
\q2 i̱na ti biamogo timbuni birugo de hendene.  
\q1 Ani anigo i̱na ti haru halu hewagola  
\q2 tigua i̱naga hongo ba handalu hene.  
\q2 Ti ani binigo i̱na bi larogo tígua áyu hale howa tínaga mamali binidagua bulemini nabilimu.   
\q1
\v 10 Dindi ko o biagoria mali pira mariani (40) i̱na ti haru howa bima ibiruru  
\q2 bibahende handai dege howa tigua i̱ abi haruabe hondole ba handalu hene.  
\q1 Wali agali urunime horo bibahendengi hariga koha pialu haabo halu  
\q2 i̱naga bi lo wirugoni hale halu bibe manga haga karunida lowa   
\q1
\v 11 i̱na tihondo lemboore howa bi hongohe mbira bule lalu lo wirugo ogo.\x + \xo 95.11 \xt Dag 14.20-23, Man 1.34-36, 12.9-10, Hi 4.3-5\x*  
\q2 Wali agali uruniore i̱na ti mini íbu ha̱lo birulene muleberogoria anda napolebiraore,  
\m lalu Ngode Datagaliwabehanda ani lene.   
\c 96  
\s1 Ngode Datagaliwabe ibu kini daligaore howa bibahende handame ho kago ogo  
\q1
\v 1 Anduane Homogohondo iba gana gahenge lo mulene nga.  
\q1 Dindi bibahendeni bu kamirume Anduane Homogohondo iba gana lo mulene nga.   
\q1
\v 2 Anduane Homogohondo iba gana lo mialu ibunaga mini mo yaraga halimu.  
\q2 Ibugua ina haru dai bialu pele ngiyagoni lalu  
\q2 horo bibahendengi wali agali bibahendeme hale hai helo lamiaaboore halimu.   
\q1
\v 3 Ibu daliga gibiore ka lalu  
\q2 hameigini bibahende paluyu pedaru hale hai helo lamilimu.  
\q1 Ibugua biabe timbuni bayale bima piyarunaga lalu  
\q2 wali agali bibahende lamiai halimu.   
\b  
\q1
\v 4 Anduane Homogo ibu daliga gibiore kagoni.  
\q2 Iname ibunaga mini uyura mo yaraga haabo halu hami̱ya.  
\q2 Mbirale wali agalime dama mitangi bialu gime wabini ngaru hondowa  
\q2 ina gi holene nawi.  
\q1 Anduane Homogo ibu dege daliga gibi kago  
\q2 iname ibu hondowa dege giho holene nga.   
\q1
\v 5 Wali agali hameigini tara tarame mbirale dama mitangi bialu tini gime wabiniruhondo bi pupu wiagaru  
\q2 uruni bibahende ke̱ howa hangu bialu kagoni.  
\q1 Inanaga Anduane Homogo ibugua hari daligabi mbirale bibahende hariha karubi ngarubi wabinigo  
\q2 ibuni hangu daliga gibiore kagoni.   
\q1
\v 6 Anduane Homogo ibu kini howa wá holenebi mini mo yaraga holenebi ibunaga hangu ngagoni.  
\q1 Ibunaga anda lomabu heleneni mbirale bu ngarume  
\q2 Anduane Homogo ibuni hongohe howa ibuni baya buruguleore gibi  
\q2 agi loabe tobahe kagobi walia ho nga.   
\b  
\q1
\v 7 Wali agali dindini bu kamiru bibahendeme\x + \xo 96.7 \xt Iba 29.1-2\x*  
\q2 Anduane Homogonaga mini mo yaraga halimu.  
\q1 Ibunaga wá holenebi hongo holenebi daliga gibiore nga lalu  
\q2 ibunaga miniore mo yaraga halimu.   
\q1
\v 8 Anduane Homogonaga mini timbuni daligaore ngago mo yaraga halimu.  
\q2 Ibuhondo mbirale mbira lomabu migi bule giha yaga bialu  
\q2 ibunaga andaha anda ibugu bilimu.   
\q1
\v 9 Wali agali bibahende kamiru Anduane Homogo ibu baya buruguleore kagoria ibalu\x + \xo 96.9 \xt 2 Bit 20.21, Iba 33.8, 93.5, 114.7\x*  
\q2 bulu palialu ibunaga lotu lalu halimu.  
\q2 Wali agali dindi bibahendeni kamiru tígua ibu gibiore kago hondowa duru ala lalu halimu.   
\b  
\q1
\v 10 Wali agali hameigini tara tara bibahende bu hama pedaru lamialu,\x + \xo 96.10 \xt Iba 9.8, 67.4, 93.1, 98.9\x*  
\q2 Anduane Homogo ibu kini ka, lalimu.  
\q2 Dindi timbuni o ngagoni ibunime wabu winidagua  
\q2 ema bialu girigurabi mbira nabuleore ngagoni.  
\q1 Ani kago howa mani ibugua ibalu  
\q2 wali agali bibahende baba godi lalu tigatigaore dabolebira, lalu lamilimu.   
\q1
\v 11 Dindi timbuni ogo í̠bi hari li kego í̠bi libu nde turu halibu.  
\q1 Iba solowara í̠nde tigitugu lalu í̠ninaga bi dalimu labe.  
\q1 Mbirale iba solowaraha biru ngamiru tínde bi ladagadaga bialu tíninaga bi ladaba.   
\q1
\v 12-13 Mabu wima pedamirubi mbirale mabuni andaho hama pedamirubi\x + \xo 96.12-13 \xt Iba 98.9\x*  
\q2 tí bibahende turu timbuniore ho halimu.  
\q1 Anduane Homogo ibuni dindi ogo bibahende handagimbu buwa  
\q2 haru hole ibulene tu harangi mbirale urunime bi urunidagua lagalaga bulebira.  
\q2 Ira teha ira bu karume turu gibiore howa  
\q2 tininaga bi lalu bi dalimu lagalaga bulebira.  
\q2 Ibugua dindini wali agali bu kamaru mana tigabiore buleneni haru holebira.  
\q1 Bi heneneore loleneni howa ti dabolebira.   
\c 97  
\s1 Anduane Homogo ibu kiniore kago ogo  
\q1
\v 1 Anduane Homogo ibu kiniore howa handame ho ka.  
\q1 Dindi o ngego í̠na turu holene nga.  
\q2 Dindi iba dege dombeneha ngamiru tíguabi turu haga bidaba.   
\q1
\v 2 Beraliba arumalame ibu ho mabu bida.  
\q2 Ibugua wali agali ta nabi karu mana tigabi ngagome haru howa handaya ho haga ka.   
\q1
\v 3 Ira hungu bamba halu puwa  
\q2 waitigi ho mabu bidaru dai helaga ka.   
\q1
\v 4 Ibugua hari daba migimege lalu  
\q2 dindi bibahende ngago wá hame helaga ka.  
\q1 Dindi ngarume uruni hondowa duru laga.   
\q1
\v 5 Anduane Homogo ibu dindi bibahende ngarunaga Anduane ka.  
\q2 Dindi hari ngarume Anduane Homogonaga deni wagaya do elagadagua  
\q2 do elai haga nga.   
\q1
\v 6 Hari daliga li karume ibunaga mini tigabiore nga lalu latagi ka.  
\q1 Hameigini tara tara dindi bibahendeni karume  
\q2 ibunaga wá taraore harago de handai haga ka.   
\b  
\q1
\v 7 Wali agali mbirale dama mitangi bialu gime wabini ngaruhondo bi pupu wiaga karu\x + \xo 97.7 \xt Har 20.4, Man 5.8, 27.15, Yar 10.14, Hi 1.6, Ya 2.19\x*  
\q2 ti mo taga timbuniore holebira.  
\q1 Gime wabini ngarume Anduane Homogo hondowa bulu paliai holebire.   
\q1
\v 8 Anduane Homogo-o í̠naga mana tigabi hangu ngegome wali agali dabaga kego manda buwa  
\q2 wali agali Saiononi karubi Yuda dindiha tano dewa wima pedaruha bu karubi  
\q2 ti bibahendeme í̠hondo turu halu miniha dungulo haga ka.   
\q1
\v 9 Anduane Homogo Hongo Haiheore-o  
\q2 í̠na dindi bibahende handameho kegoni.\x + \xo 97.9 \xt Har 18.11, Iba 83.18, 95.3, 96.4\x*  
\q1 Í̠ore mini lene daligaorene daliga howa  
\q2 bi pupu wulenaga gime wabu ngaru bibahende bolangua haihe kegoni.   
\b  
\q1
\v 10 Anduane Homogohanda wali agali mana ko ngaru hame nalaga karu  
\q2 tihondo gubalini ho haga ka.  
\q1 Ibunaga wali agali karu handayaho haga ka.  
\q1 Ibugua ti agali ko biaga karunaga giha karia gingila mialu  
\q2 haru dai biaga ka.   
\q1
\v 11 Anduane Homogonaga wá holeneme wali agali mini tigabi karuni wá hadali haga ka.  
\q1 Turu holeneme wali agali bayale biaga karu  
\q2 tinaga bu miniha mo turuho helaga ka.   
\q1
\v 12 Wali agali mini tigabiwi kamiru tí turu ho hadaba.  
\q1 Tígua Anduane Homogohanda bayale biyarunaga turuho hadaba.  
\q1 Ngode Datagaliwabe ibu mini baya buruguleore kago  
\q2 ibugua uruni biyaru mitangi bialu tígua ibuhondo turu halu ka̱i̱ ladaba.   
\c 98  
\s1 Anduane Homogo ibu wali agali bibahende handame ho haga kago ogo  
\q1
\v 1 Anduane Homogohondo iba gana gahenge lama.\x + \xo 98.1 \xt Har 15.6, Iba 33.3, 40.5, Ais 52.10\x*  
\q1 Ibugua mbirale baya tara tara biai hayagoni.  
\q1 Ibuninaga hongo timbuni kagomebi ibunaga mana baya burugule ngagomebi  
\q2 ibugua waitigi bope hai hayagoni.   
\q1
\v 2 Anduane Homogohanda wai buwa i̱na wayali haru lalu latagi haya.  
\q1 Ibugua Isaraele wali agaliru pele mialu haru dai bulenaga  
\q2 hongo timbuni wali agali tara tara bu hearuhondo walia hayagoni.   
\q1
\v 3 Ibugua ibunaga bi lowiniru mitangi bialu\x + \xo 98.3 \xt Iba 22.27, Lg 1.54, 1.72\x*  
\q2 Isaraele wali agalihondo gubalini haabo halu ti yu wanaheore heneya.  
\q1 Inanaga Ngode Datagaliwabehanda ina waitigi bope halu ina haru dai biyago  
\q2 wali agali dindi bibahendeha bu hearume hale halu manda biaiore haya.   
\b  
\q1
\v 4 Wali agali dindi bibahendeni kamiru  
\q2 tígua Anduane Homogohondo turu halu iba gana ladaba.  
\q1 Bu miniha dungulo holenaga iba gana turu howa dalimu lalu  
\q2 ibunaga mini yaraga hadaba.   
\q1
\v 5 Anduane Homogonaga mini yaraga halu iba gana ladaba.  
\q1 Ngida aleru baya hangu balu bi bayaleru lelo badaba.   
\q1
\v 6 Pilipe biguliru pu lalu bi hongo howa ladaga halu  
\q1 Anduane Homogo ibuni inanaga kini kago lalu  
\q2 ibunaga mini yaraga hadaba.   
\b  
\q1
\v 7 Iba solowara bedego í̠bi ibaha wena tara tara bedamirubi  
\q2 tígua bi hongo howa ladaga hadaba.  
\q1 Dindi í̠bi wali agali dindini kamirubi  
\q2 tí bibahendeme iba gana ladaba.   
\q1
\v 8 Iba timbuni poramiru tíguabi nde gi habe badaba.  
\q1 Dindi hari wedemiru tíguabi nde turu howa  
\q2 Anduane Homogonaga deni iba ganaru ladaba.   
\q1
\v 9 Irane ibugua dindi bibahendeni handameho howa haru hole ibiragonaga ani bidaba.  
\q1 Ibugua ibunaga mini bayale tigabi ngagome  
\q2 wali agali bibahende haru haabo holebira.   
\c 99  
\s1 Anduane Homogo ibu kini duniniore kago ogo  
\q1
\v 1 Anduane Homogo ibu kiniore howa handame ho ka.\x + \xo 99.1 \xt Har 25.22\x*  
\q1 Wali agalirume ibuhondo gi howa duru lalu haga.  
\q1 Dahuliyali babaganehe kirali kago labo dindiha helowa  
\q2 ibu de handape howa handayaho kagola  
\q2 dindi dumbirumbi bialu haga.   
\q1
\v 2 Anduane Homogo ibu Saiononi howa hongo timbunihe kagoni.  
\q2 Ibugua hameigini tara tara dindi bibahendeha karu  
\q2 handame howa haru hai ka.   
\q1
\v 3 Wali agali bibahendeme ibu kini duniniore howa mini lene ka lalu  
\q2 ibunaga mini yaraga holebira.  
\q1 Ibu mini tigabi baya buruguleore kagoni.   
\b  
\q1
\v 4 Kini hongo haiheore-o í̠ mana bayale tigabi ngago dege hame laga kegoni.  
\q2 Í̠na mana bayale tigabi lo ngegoni  
\q2 ina Isaraele wali agalirume bialu haabo holoma̱ya ngirigoni.  
\q1 Wali agali tara karume biraru hondowa  
\q2 iname tigatiga mo tale bialu holoma̱ya mo walia hari.   
\q1
\v 5 Anduane Homogo inanaga Ngode Datagaliwabe kagonaga mini yaraga holene nga.  
\q2 Ibuni kagoha hapara howa ibu mitangi bialu lotu lalimu.  
\q2 Ibu mini tigabi baya buruguleore kagoni.   
\b  
\q1
\v 6 Mosese Aronola libu Anduane Homogonaga \w loma\w* binigo mo miaga agali hene.  
\q2 Samuele ibugua ibuhondo bi laga hene.  
\q1 Uruni tigua Anduane Homogo olayagola  
\q2 ibugua tinaga bi hale haga hene.   
\q1
\v 7 Ibuni hari beraliba timbuni heagoha howa\x + \xo 99.7 \xt Har 33.9\x*  
\q2 ibugua tihondo bi lamigi bini.  
\q2 Ibugua ibunaga mana bulene winiru ti lamigi biyagola  
\q2 tigua hale halu biai haga hene.   
\b  
\q1
\v 8 Anduane Homogo inanaga Ngode Datagaliwabe-o\x + \xo 99.8 \xt Dag 14.20, Man 9.20, Yar 46.28, Seb 3.7\x*  
\q2 í̠naga wali agalirume í̠hondo bi layaru hale halu ladai birigoni.  
\q1 Tigua mana ko birarunaga pani nelo miaga kego howa dege  
\q2 í̠ni Ngode Datagaliwabeore howa ko uruni domo wahai haga kego ti walia harigoni.   
\q1
\v 9 Anduane Homogo inanaga Ngode Datagaliwabe kagonaga mini yaraga hama.  
\q1 Ibunaga hari loma bini kagoria howa ibu mitangi bialu lotu lama.  
\q1 Anduane Homogo inanaga Ngode Datagaliwabe ibu tigabi howa baya buruguleore kagoni.   
\c 100  
\s1 Anduane Homogonaga mini mo yaraga halu iba gana lalu lenego ogo  
\q1
\v 1 Wali agali dindi bibahendeni paluyu pedamirume  
\q2 Anduane Homogohondo turu howa iba gana lo milimu.   
\q1
\v 2 Turu howa iba gana turubiru lama lama  
\q2 ibu mitangi bialu lotu lole ibunaga wanakuini íbu halimu.   
\b  
\q1
\v 3 Anduane Homogo ibu Ngode Datagaliwabeore ka manda bilimu.\x + \xo 100.3 \xt Iba 79.13, 95.7, Ese 34.30-31, Eb 2.10\x*  
\q1 Ibugua ina wabinigo ina ibunagaore kama.  
\q1 Ibunaga wali agali howa ina ibunaga nogo sibi kamagoni.  
\q1 Anigo ibugua nogo sibi haru hagadagua ina haru haga ka.   
\b  
\q1
\v 4 Ibunaga anda loma bia henegonaga harabani anda ibalu  
\q2 ibuhondo ka̱i̱ lalu iba ganaru lama lama anda mali̱ya.  
\q1 Ibunaga mini yaraga hama hama anda tamuha anda mali̱ya.  
\q2 Ibuhondo ka̱i̱ lalu ibunaga mini mo yaraga hami̱ya.   
\b  
\q1
\v 5 Anduane Homogo ibu bayaore gibi kago ibunaga gubalini holene ngagome\x + \xo 100.5 \xt 1 Bit 16.34, 2 Bit 5.13, 7.3, Esr 3.11, Iba 106.1, 107.1, 118.1, 136.1, Yar 33.11\x*  
\q2 ina gubalini haho wiaabo kagoni.  
\q1 Ibugua ibunaga wali agaliruhondo,  
\q1 Bulebero, lowiniru mbira mo habo nale  
\q2 ibu mini bilinahe howa biaiore haga kago  
\q2 ibunaga mini yaraga hami̱ya.   
\c 101  
\s1 Kini Debidi ibugua buleore lalu bi lowinigo ogo  
\q1
\v 1 Anduane Homogo-o i̱na iba gana lalu bi lo wirugo buleore lalu larudaguabi  
\q2 í̠naga mana tigabi bulene ngadagua bulebi  
\q2 i̱na í̠ mitangi bialu iba gana ogo í̠hondo lalu kogoni.   
\q1
\v 2 I̱na mana ko nabi bayale dege bialu holeberogo  
\q2 Anduane Homogo-o í̠na biamogo bule i̱ koria angi ibuleberebe.  
\q1 I̱ damenerunaga deni howa mana tigabi dege biaabo holebero.   
\b  
\q1
\v 3 I̱na mana ko bulene ngago bibe mangaore holebero.\x + \xo 101.3 \xt Man 15.9, Iba 5.5, 40.4\x*  
\q2 Wali agali Ngode Datagaliwabehondo erembira mialu haga karuhondo  
\q2 turu naheore kogoni.  
\q1 I̱ ti heba mandagi ibagabu naholebero.   
\q1
\v 4 Ke̱ hagane mana biaga ngagobi i̱na nabulebero.  
\q2 Agalime mana ko biaga ngagobi mitangi naholebero.   
\q1
\v 5 Wali agali mendeali ndelalu haga karu i̱na ti bope holebero.\x + \xo 101.5 \xt Iba 18.27, 50.20, Yar 9.4\x*  
\q2 Mine haga karubi i̱na handabe manga holebero.   
\b  
\q1
\v 6 Ngode Datagaliwabehondo mini bilinahe karu tihondo i̱na turu haabo holebero.\x + \xo 101.6 \xt Iba 119.1\x*  
\q2 Mana bayale bialu henene laga karu  
\q2 ti degeme i̱naga biabe biaga helo i̱ andagaha helolebero.   
\b  
\q1
\v 7 Wali agali ke̱ haga bu karu\x + \xo 101.7 \xt Iba 43.1, 52.2-5\x*  
\q2 ti i̱naga anda timbuni kagoha naholebira.  
\q1 Wali agali tombene hondokihe karu ti i̱la naholebiraore.   
\q1
\v 8 Horo bibahendengi i̱naga dindi ngagoha ko biaga karu  
\q2 i̱na mo ko halu bo batagi haga bulebero.  
\q1 Wali agali ko biaga karu damene  
\q2 Anduane Homogonaga tano ngagoria nahelo  
\q2 i̱na ti bo talu pelai holebero.   
\c 102  
\s1 Igiri daliaheme genda yu howa bi lenego ogo  
\q1
\v 1 Anduane Homogo-o i̱na í̠hondo bi larogo hale habe.  
\q1 Í̠na i̱ biamogo bibelonaga í̠ olalu kogo hale habe.   
\q1
\v 2 I̱ genda timbuni yu kongi  
\q2 í̠na i̱ yu wahalu napobe.  
\q1 I̱na í̠ olarogola bi larogo hale halu abale biamogo bibe.   
\b  
\q1
\v 3 I̱naga holene emene tigi mbira hangu ira hagua bialu abaleore pu ereba hagagobi kogoni ndobe.  
\q1 I̱naga tingini poboyogo bialu  
\q2 ira timbuni dedagola poboyogo biraligobi bialu helo kogoni ndobe.   
\q1
\v 4 Datani gaule agalime hengedalu piagadagua  
\q2 Ngode Datagaliwabehanda i̱ hengedo wahenego kogoni.  
\q2 I̱naga tiniha tomo nolene garibi nale ko.   
\q1
\v 5 I̱ tandaga timbuni howa e̱ lalu ngogoni.  
\q2 I̱naga tingini timbuni nahe yólalu kuni hangu haragonida.   
\q1
\v 6 I̱ mo ko henego koore  
\q2 dindi ko wali agali nahaga ngagoha ega e̱wa̱tia biragagobi  
\q2 dindi labu ngagoha ega halengau biragagobi bedogonida.   
\q1
\v 7 I̱ dagiani palia padogoyu  
\q2 ai i̱ paliahondo nahe yangayanga bu wiaabo kogoni ndobe.  
\q1 Ega warakuli anda dangini hangu biragadagua  
\q2 i̱ni hanguore bedogonida.   
\q1
\v 8 Mbiraga horombebi waitigi bu karume  
\q2 i̱hondo bi ko dege lalu haabo ka.  
\q1 Tigua i̱ mini lowa mege bialu ha haga bialu ka.   
\b  
\q1
\v 9-10 Í̠na i̱hondo keba timbuni ho kegome  
\q2 i̱ nde beru dugu nalu  
\q2 de iba pugulope halu  
\q2 gabo beha iba biraradagua bedago nalu bedogonida.  
\q1 Í̠na i̱ minalu mbirale ko ngaru mo wahagadagua  
\q2 mo wahenego bedogonida.   
\q1
\v 11 I̱ dindini lu holene nawi  
\q2 tubagiore alendo halu ni dadai biraligobi kogoni.  
\q2 Datani gaule ngaligobi bedogonida.   
\b  
\q1
\v 12 I̱ ogonibigoyu nde Anduane Homogo-o í̠ kini haluheore kegoni.  
\q1 Wali agali maha ho aribia holebirarume  
\q2 í̠ manda biai holebiragoni ndobe.   
\q1
\v 13 Í̠na Saiono tano ngago mitangi bialu dara holeberego manda bido.  
\q2 Í̠na dara howa biamogo bulene horo biagoni abale tagira ibiyada.  
\q2 Horo ogoni áyu ngagoniore ndobe.   
\q1
\v 14 Saiono tano bo gialabagabu wahayago  
\q2 í̠naga biabe biahaga karume tano ogoni mitangi timbuni bialu hamelo ka.  
\q2 Áyu tano ogoni mo ko hai hene ngagoyu  
\q2 tigua dara ho haabo ka.   
\b  
\q1
\v 15 Hameigini tara tara dindi bibahendeni palima pedarume  
\q2 Anduane Homogohondo gi hai holebira.  
\q1 Dindi bibahendeni kini karume  
\q2 ibunaga hongo timbuni kago hondowa  
\q2 ti gi hai holebira.   
\q1
\v 16 Mani howa Anduane Homogohanda Saiono tano lone biadai birangi  
\q2 ibunaga hongo ogobi lalu walia holebira.   
\q1
\v 17 Ibugua ibunaga wali agali yu wahene karume olaragola hale holebira.  
\q2 Tigua ibuhondo bi lararu hale howa erembira mialu napolebira.   
\b  
\q1
\v 18 Anduane Homogohanda mbirale áyu inahondo biraruni  
\q2 ina waneigini aguanene mani holobadarume hendelo mbugani gilibu widaba.  
\q1 Wali agali mani holebirarume Anduane Homogohanda biniru te hale howa  
\q2 ibunaga mini yaraga halu holebira.   
\q1
\v 19 Iname bi ogodagua gilibu wimi̱ya.  
\q1 Anduane Homogo ibuni haga daligaoreha howa handape haya.  
\q2 Ibu dahuliya andagani howa dindiha handadaliho haya.   
\q1
\v 20 Wali agali garabaya bini hearume  
\q2 tandaga nalu howa dugu biayuago hale haya.  
\q2 Hale howa ibugua agali godi hale hagame bo waholene nga lene hearu  
\q2 ti homa nabilonaga biamogo bialu golope haya, lalu gili bulene nga.   
\q1
\v 21 Ibugua ani biyago hale howa Saiono dindini wali agali bu karume  
\q2 Anduane Homogonaga mini latagi halu  
\q2 Yarusalemeni howa ibunaga mini yaraga halu holebira.   
\q1
\v 22 Hameigini tara tara dindi bibahendeni palima pedarubi tinaga kini karubi  
\q2 ti bibahendeme Anduane Homogo mitangi bialu  
\q2 lotu lole íbu ngoai harangi ani lalu holebira.   
\b  
\q1
\v 23 I̱ wene igiri daliahe dege hewaria  
\q2 Anduane Homogohanda i̱naga hongo bope ho heledagonida.  
\q2 Ibugua i̱ dindi ogoriani lu naholiya  
\q2 i̱naga holene mo tubagi ho heledagoni ndobe.   
\q1
\v 24 I̱naga Ngode Datagaliwabe-o í̠ haluhe haabobo bu kegoni.\x + \xo 102.24 \xt Yob 36.26, Iba 90.2, Ais 38.10, Hab 1.12\x*  
\q2 I̱ agali wahe ndo wene igiri daliahe dege kogonigo  
\q2 í̠na i̱ áyu ogoni yamia nabibe.   
\q1
\v 25 Bambaore í̠na dindi bibahende wabiniyagoni.\x + \xo 102.25 \xt Hi 1.10-12\x*  
\q1 Í̠ninaga gimeore hari daliga li kago wabialu  
\q2 mbirale karubi ngarubi bibahende wabiai hariya.   
\q1
\v 26 Aga labolaboru goba halu budahole biagadagua  
\q2 dindi harila mo ko holebiragoyu  
\q2 í̠ni hangu haabobo bu haga kegoni.  
\q1 Agalime aga labolabo goba haragola wahagadagua  
\q2 dindi harila ereba hai haragola lone nahondoleberemaore.   
\q1
\v 27 Í̠naga holene ala henegobi dege haho wiaabo haga kegoni.\x + \xo 102.27 \xt Ais 43.10, Mal 3.6, Ya 1.17\x*   
\q1
\v 28 Í̠ ani kegoni howa inanaga waneiginiru ti bayale helo  
\q2 í̠na handaya ho holebere.  
\q1 Tinaga aguanene maniore hama polobadarubi  
\q2 ti í̠ni andaneha bayale haabo holebira.   
\c 103  
\s1 Anduane Homogohanda ibunaga wali agali gubalini haga kago ogo  
\q1
\v 1 I̱na Anduane Homogonaga mini mo yaraga holebero.  
\q1 I̱naga minimebi tinginimebi mbirale i̱ha kago damenego  
\q2 bibahendeme ibunaga mini baya buruguleore kago mo yaraga haabo holebero.   
\q1
\v 2 I̱na Anduane Homogonaga mini mo yaraga holebero.  
\q1 Ibugua i̱hondo turu halu bayale dege bigi biaga kago embeda naholeorebero.   
\q1
\v 3 Ibugua i̱na ko beroru bibahendeore domo wahai haga ka.\x + \xo 103.3 \xt Ais 33.24, Yar 17.14\x*  
\q2 I̱ni warago tara tara anda íbu wigi bidangi  
\q2 mo dabi haga kagoni.   
\b  
\q1
\v 4 Anduane Homogo ibugua i̱ore homoliya yupe nahe haru dai biaga ka.\x + \xo 103.4 \xt Iba 34.22, 56.13\x*  
\q2 Haru dai bialu ibugua i̱ gubalini halu dara timbuni haga kagoni.   
\q1
\v 5 I̱ ani ho ko lalu walia halu i̱ dindini kongi\x + \xo 103.5 \xt Ais 40.31\x*  
\q2 ibugua mbirale bayale dewa bu hombedo ngiragola  
\q2 i̱ karulapeore wu haabo haruli.  
\q1 Ibugua ani bigi biragome i̱ lone igiriho dai bialu  
\q2 hongohe ega bodo hariawe ale haruli.   
\b  
\q1
\v 6 Wali agali darabi dindiha haga karu maru karume ti hengedope haragola  
\q2 Anduane Homogohanda tinaga bi tigatiga lahaga ka.  
\q2 Ibugua ti mo yaraga halu ti holene ngadagua helolebira.   
\q1
\v 7 Anduane Homogo ibugua Isaraele wali agali biamogo bulenenaga  
\q2 ibu miniha manda manda bu yu heago damenego Mosese walia hene.  
\q1 Walia halu Anduane Homogo ibugua biabe hongohe bigi biyaru  
\q2 Isaraele wali agali ti de hendelene.   
\q1
\v 8 Anduane Homogo ibugua ina dara howa biamogo biagabi\x + \xo 103.8 \xt Ya 5.11\x*  
\q2 gubalini timbuniore hagabi ka.  
\q1 Ibu keba ala awane nahaga howa  
\q2 ibugua ibunaga gubalini haho wiaabo holeneme  
\q2 ina yaniho wiaabo helowa haga kagoni.   
\q1
\v 9 Iname mana ko liahebi beramarunaga  
\q2 Anduane Homogo ibugua ina ba talia bia biaganegoyu  
\q2 ani bialu haabo nahaga.  
\q1 Ibugua ibunaga wali agalihondo handabe manga howa  
\q2 keraho haabo nahaga kagoni.   
\q1
\v 10 Iname mana ko gibi dewaore bidamaria\x + \xo 103.10 \xt Esr 9.13\x*  
\q2 ko birimarunaga pani ogonibi tahe ngulene ngadagua ndo  
\q2 ibugua pani emene hangu ngiaga kagoni.  
\q1 Iname mana ko liahebi birimarunaga pani timbuniore nabehegoyu  
\q2 ibugua ina yopialu pelaga bialu kagoni.   
\q1
\v 11 Hari daliga li kagome dindi bibahende ngagoni dambi hai kadagua\x + \xo 103.11 \xt Iba 57.10, Eb 3.18\x*  
\q2 Anduane Homogo ibugua wali agali ibuhondo mitangi bialu giho haga karu  
\q2 ibunaga gubalini holene timbuniore ogonibime ti gubalini ho kagoni.   
\q1
\v 12 Uyu ni tagira ibagagoha howa namu ni paliagagoha polenego\x + \xo 103.12 \xt Ais 43.25, Mai 7.18\x*  
\q2 kaware ndo kaundiaore gibi ngagoni.  
\q1 Ani ngadagua Anduane Homogohanda iname ko birimaru bu wu kamaria  
\q2 ibugua domalu hiliyalu pialu  
\q2 kaundiaore gibi namura ona agima ndooreni yalu pu wahaga kagoni.   
\q1
\v 13 Abame ibunaga waneigini gubalini howa baya hanguore handayaho hagadagua\x + \xo 103.13 \xt Mal 3.17\x*  
\q2 Anduane Homogohanda wali agali ibuhondo mitangi bialu giho haga karu  
\q2 baya hangu ogonidaguaore gubalini howa ibuni handayaho haga kagoni.   
\q1
\v 14 Ibugua ina ogo aleme wabirugo ni bu karuni lalu ibuni manda bidagoni.\x + \xo 103.14 \xt Pig 3.19, Iba 78.39, Aga 12.7\x*  
\q2 Bame dindi dugualu wabirugo ni bu kagoni lalu ibuni manda bu kagoni.   
\b  
\q1
\v 15 Ina wali agali bu kamaruni inanaga holenego\x + \xo 103.15 \xt Yob 14.1-2, Ya 1.10-11, 1 Pi 1.24\x*  
\q2 emene tubagi tigimandi hangu tani mbuambua andaho kalidagua kamagoni.  
\q1 Tani mbuambua minalu anda howa lini do haganedagua ina bu kamagoni.   
\q1
\v 16 Tani mbuambua lini biago dedaria puyabume pulo ba haragola  
\q2 dindini dogolope haga.  
\q1 Dindini dogolope hayagua o piyagoni haga.  
\q2 Dogolope henego lone dene biagoria dodai bidaria nahandaga.   
\q1
\v 17 Ani biagagoyu ai wali agali Anduane Homogo andaneha howa\x + \xo 103.17 \xt Lg 1.50\x*  
\q2 ibuhondo mitangi bialu giho haga karu  
\q2 ibugua ti dara halu gubalini haho wiaaboore haga kagoni.  
\q1 Uruni tinaga waneigini dabane mani hama polebirarubi  
\q2 ibugua ti gubalini halu tihondo bayale dege biaabo halu holebira.   
\q1
\v 18 Anduane Homogonaga habo nalolene bi lo winidagua bialu karu  
\q2 ibugua bia lenedagua hale halu birarubi  
\q2 nde tihondo bayale dege biaabo halu holebira.   
\b  
\q1
\v 19 Anduane Homogo ibu dahuliya andagani kini biruwa  
\q2 mbirale bibahende ibugua handame ho kagoni.   
\q1
\v 20 Dahuliyali hongo gibihe kamiru  
\q2 Anduane Homogo ibugua bi larago baya hanguore hale halu bia larago biaga kamiruni  
\q2 tíbi turuore gibi halu Anduane Homogonaga mini mo yaraga hadaba.   
\q1
\v 21 Dahuliya andaga howa Anduane Homogohanda laradagua hale halu  
\q2 ibunaga biabe biahaga kamiru tiguabi  
\q2 turuore halu Anduane Homogonaga mini mo yaraga hadaba.   
\q1
\v 22 Mbirale bibahendeore Anduane Homogo ibuni wabini ngamirubi kamirubi  
\q2 tí bibahendeorenaga kini ibuni howa ibugua tí handame ho kago  
\q2 tígua turuore halu ibunaga mini mo yaraga hadaba.  
\q1 Ani bidaba.  
\q1 I̱nabi Anduane Homogonaga miniore mo yaraga holebero.   
\c 104  
\s1 Ngode Datagaliwabehanda bibahende wabiai henego iname ibunaga mini mo yaragaore holene ngago ogo  
\q1
\v 1 I̱na Anduane Homogonaga mini mo yaraga holebero.  
\q1 Anduane Homogo i̱naga Ngode Datagaliwabe-o í̠ daliga gibiore kegoni.  
\q1 Í̠ kini daliga gibiore howa mini mo yaraga holenebi duniniore holenebi  
\q2 aga karularadagua karulo kegoni.   
\q1
\v 2 Wá holene gibioreme í̠ni aga karu laradagua karulo howa haru kegoni.\x + \xo 104.2 \xt Ais 40.22, Dan 7.9\x*  
\q1 Agalime balai anda dungume howa anda biagadagua  
\q2 í̠na hari daliga li kagoni wabuwa dungume ho heledegoni.   
\q1
\v 3 Ani buwa í̠ninaga andaga iba bedago yarali howa uyuraore daligani bu kegoni.\x + \xo 104.3 \xt Iba 18.10\x*  
\q1 Í̠ hari beraliba ngarunaga biralu eberegola  
\q2 puyabume í̠ yalu ibirayagoni.   
\q1
\v 4 Puyaburume í̠naga bi yalu ina kamaria pu lareya.\x + \xo 104.4 \xt Hi 1.7\x*  
\q1 Hari daba biralirubi í̠naga biabe dege bia ha lareya.   
\b  
\q1
\v 5 Dindi timbuni ogo í̠nime wabuwa winiyagobiore hongohe ngagoni.  
\q2 Dindi ogo imi ema emene mbira nabi girigurabi mbira nabulebiraore.   
\q1
\v 6 Iba solowarame dindi timbuni ogo bibahende bu dambi haiho winiya.  
\q2 Iba ogonime hari hearubi bibahende biru namulaiho winiya.   
\q1
\v 7 Ani dambi haiho wiaria í̠naga bi hongoheme iba solowara taliriya.  
\q2 Taliri handala iba ibu gerai ibida puabo hayiya.  
\q1 Iba solowara ibu í̠naga bi hongohe biago hale halu  
\q2 bia laridagua bialu ibida piyiya.   
\q1
\v 8 Ibida pialu hari hearu yu wahalu porabu pebe bialu  
\q2 dindi ulini wiaruha í̠nime tini berelo wabu winiyarunaga pu birayiya.   
\q1
\v 9 Iba uruni biru bolangua nahelonaga  
\q2 í̠nime tu winiyagoriani iba áyu ogoriani birairi kagoni.  
\q1 Áyu ibame ala bibahende namulaiho winiyadagua  
\q2 lone namulai naholebira.\x + \xo 104.9 \xt Yar 5.22\x*   
\b  
\q1
\v 10 Dindi uliniruha howa iba dugutagi helalu  
\q2 hari labo dombeneruha howa iba duguaga duguaga bilalu  
\q2 unura pugulu pebe biledegoni.   
\q1
\v 11 Ani biledegoria nogo gabua tara tara karume  
\q2 iba uruni naga naga bialu kagoni.  
\q1 Nogo dongi gabua karumebi iba noa howa  
\q2 hége lebolaho henedagobi karulapeore nalu kagoni.   
\q1
\v 12 Iba uruni angeni ira bu karuha egarume tininaga anda bigi bigi bialu biruwa  
\q2 iba ganaru turu howa laga laga bialu biru ngagoni.   
\b  
\q1
\v 13 Hariha howa dalu hari hombene ngarunaga dalipe helaga bialu kegoni.  
\q1 Ani bigi beregome dindini mbirale bayale bayale bu paya bu ngagoni.   
\q1
\v 14 Nogo bulumagarume nelo tani mo anda helalu  
\q2 ina wali agalime nalu holoma̱yanaga  
\q2 tomo inaneme hengedamaru mo anda haga beregola nalu kamagoni.   
\q1
\v 15 Ani bialu iname ina mabuni pu mbira lini daga mini \w gerebi\w* hangalu  
\q2 linime pingidowa \w waini\w* iba wabu nalu  
\q2 ina miniha turuore halu dungu lo kamagoni.  
\q1 Ira olibe lininaga ibane hambuwa denguinibi haguanibi haiho kamagola  
\q2 inanaga dengui haihe wále bu kamagoni.  
\q1 Widi hangalu dowa mberedi wabuwa  
\q2 dawa no kamagola ina tinginiha hongo ngidagola kamagoni.   
\b  
\q1
\v 16 Lebanono dindini ira tamia bu karuni  
\q2 hariha howa dalu ibaabo haragome damiaabo haga kagoni.  
\q2 Ira tamia uruni Anduane Homogo ibugua bamba hengenego  
\q2 ibuninaga ira bu kagoni.   
\q1
\v 17 Ira tamia uruniha egarume tininaga anda bigi bigi biaga beda.  
\q1 Ai ega ma luhe mbira bedarume tinaga anda ira guraya ale karuha biaga bedagoni.   
\q1
\v 18 Meme gabua karu ti hari timbuni wedarunaga neneni ibagabu haga kagoni.  
\q2 Tia amala horia ale bedaru ti egeandaha bira do haga bedagoni.   
\b  
\q1
\v 19 Harini ege wabu helariyagome tagira ibuwa ngoaho haga bialu  
\q2 mali mbiragonaga ege biagoni ogoaleneda lalu ibuni langialu kagoni.  
\q1 Ai ni ibu nde ogoangi anda pialu dadai bialu  
\q2 palue ibuni manda bu kagoni.   
\q1
\v 20 Í̠na aruma helaregola mbiraga nogo ega gabua tara tara  
\q2 ti bibahende tagira ibuwa ibaga bu haga kagoni.   
\q1
\v 21 Laiono hungubaluarume tomo taya bialu howa  
\q2 ne noani bi hongo howa ladaga halu larayagoni.  
\q1 Ngode Datagaliwabe í̠na tomo ti nelo mereyago  
\q2 ogoni mbira agini ngabe hondole taya bialu howa bi ani larayagoni.   
\q1
\v 22 Ti ani bialu howa ni dara handala  
\q2 uliha tini paliradagoha palima dai biaga.   
\q1
\v 23 Ani pedaha wali agali ti heyalu biabe bu puwa  
\q2 biabe bialu kane dege alendo ni palira handala ti andaga piaga.   
\b  
\q1
\v 24 Anduane Homogo-o í̠na mbirale dewaore wabiriyagoni.  
\q2 Í̠ mini gigabiwi gibiore kegome  
\q2 mbirale uruni bibahende í̠nime wabiriyagoni.  
\q1 Dindi timbuni ogoni mbirale tara tara í̠ni wabiriyarunime  
\q2 wu to̱lotagi kagoni.   
\q1
\v 25 Iba solowara timbuniore gibi bedagoni.  
\q2 Iba o bedagoniha wena timbuniore gibirubi  
\q2 wena emenebi dewa daga labenaheore biralu  
\q2 mbirale marualebi ogoniha dege biru ngagoni.   
\q1
\v 26 Iba solowara daligani iba sibi puíbu daibu biaga.\x + \xo 104.26 \xt Yob 41.1, Iba 74.14, Ais 27.1\x*  
\q2 Iba unura dindiha wena gibi hiriribi bamba í̠ni wabu berelene  
\q2 o bedagome gini biaga bedagoni.\f + \fr 104.26 \ft Iba Gana 74.14 de handabe\f*   
\b  
\q1
\v 27 Uruni bibahendeme ti tomo noa biaruangi  
\q2 í̠na dege mibelo í̠naga gi handayaho biraga bedagoni.   
\q1
\v 28 Í̠na ti tomo nolene meregola ti naga.  
\q2 Ti tomo merego karulapeore nalu tombeore hara handala piaga.   
\q1
\v 29 Í̠na ti erembira meregola ti giho haga.  
\q2 Í̠naga buhe̱ tiha helarigo yameregola  
\q2 ti homo tongolo daga halu lone dindi tago biaga.   
\q1
\v 30 Í̠na ti buhe̱ lolene meregola ti emabu haga.  
\q2 Í̠na dindini mbirale bibahende gahenge hangu tagira íbu helaga bialu kegoni.   
\b  
\q1
\v 31 Anduane Homogonaga hongo holenebi  
\q2 ibunaga wá holenebi wiaaboore helo hame ledo.  
\q1 Anduane Homogo ibugua mbirale ibunime wabu helaga biyadaru handaga bialu  
\q2 ibuni turuore helo hame ledogoni.   
\q1
\v 32 Anduane Homogo ibugua dindi timbuni o ngagoni de handaya haragola  
\q2 dindi ogoni duru laga.  
\q1 Ibunaga gime hari karuni ela haragola  
\q2 hari karuni hagua hungula bulebira.   
\b  
\q1
\v 33 I̱ dindini emabu kongi  
\q2 i̱na Anduane Homogohondo iba ganaru lo mulebero.  
\q1 I̱na i̱naga Ngode Datagaliwabe kagonaga mini mo yaraga halu iba ganaru laho ngoore dege  
\q2 i̱ni homalu lairi holebero.   
\q1
\v 34 Anduane Homogo ibugua i̱ mo turu haga biragola haruligo  
\q2 i̱na iba gana lo meroruore ibu hale halu turuore helo hame ledo.   
\q1
\v 35 Anduane Homogo-o wali agali mana ko biaga bu karuniore  
\q2 dindini nahelo balu bo ereba habelo hame ledo.  
\q2 Wali agali ko ngubiore uruni ereba hai helo hame ledo.  
\q1 I̱na Anduane Homogonaga miniore mo yaraga holebero.  
\q2 Anduane Homogonaga mini mo yaraga hama.   
\c 105  
\s1 Anduane Homogo ibunaga wali agali pele minigo ogo  
\r (1 Bi Te 16.8-22)  
\q1
\v 1 Iname Anduane Homogohondo turu howa ka̱i̱ lalu  
\q2 ibu daliga gibiore ka lalu lamiai hami̱ya.  
\q1 Wali agali hameigini dindi tara tarani paluyu pedaru  
\q2 ti bibahendehondo ibugua gibiore uruale biya laga bialu  
\q2 hale hai helo loyogo laga bimi̱ya.   
\q1
\v 2 Iname ibunaga mini mo yaraga halu iba gana lalu hami̱ya.  
\q1 Ibugua mbirale bayale bigi biyarunaga  
\q2 bibahende hale hai helo laraga halu lamiai hami̱ya.   
\q1
\v 3 Anduane Homogo ibu mini tigabiore kago  
\q2 ina ibunaga kamago iname ibuhondo turu hami̱ya.  
\q1 Wali agali Anduane Homogohanda hame ledadagua biaga kamaru  
\q2 ina turuho holene nga.   
\q1
\v 4 Anduane Homogohanda ina biamogo bilonaga ibu karia puabo hami̱ya.  
\q1 Iname Anduane Homogo ibu kagoha kaware haparaho haabo hami̱ya.   
\q1
\v 5-6 Abarahama aguanene Anduane Homogonaga biabe bia hagane kamirubi  
\q2 Yagabanaga aguanene Anduane Homogo ibunime dabene kamirubi  
\q2 tígua Anduane Homogohanda manane tara tara agalime nabiagane ale bigi biyarubi  
\q2 wali agali ko biaga hearuhondo pani migi biyarubi  
\q2 mitangiore biaabo halimu.   
\b  
\q1
\v 7 Anduane Homogo ibu inanaga Ngode Datagaliwabe kagoni.  
\q2 Ibunaga mana lo ngaruni wali agali dindi bibahendeha bu karume bilonaga lo nga.   
\q1
\v 8 Ibugua habo nalolene bi lowinigo ngaruni wia ai̱ ai̱ore bulebira.  
\q2 Ibugua bi lo wialu ogoale bulebero laga bialu lo ngaruni  
\q2 mani hama porarume handaga bialu karia wia ai̱ ai̱ore bulebira.   
\q1
\v 9 Ibugua Abarahamala habo nalolene bi lo wialu\x + \xo 105.9 \xt Pig 12.7, 17.8, 26.3\x*  
\q2 Aisagahondo ogoale bulebero lenegobi heneneore bulebira.   
\q1
\v 10 Anduane Homogo ibugua Isaraelehondo habo nalolene bi lowinigo\x + \xo 105.10 \xt Pig 28.13\x*  
\q2 ogoni wali agalirume bialu haabo helonaga lowini.   
\q1
\v 11 Anduane Homogo ibugua Isaraelehondo lalu,  
\q2 I̱na tíhondo Kenana dindi karulalimulo ngulebero.  
\q1 Dindi ogoni tíbi tínaga waneigini mani holebirarubi  
\q2 tíninaga dindi ogoniore halimulo ngulebero, lene.   
\b  
\q1
\v 12 Ala Ngode Datagaliwabenaga wali agali dewa ndo henedaruni  
\q2 ti emene mbira hangu Kenana dindini hene.  
\q1 Ti dindi tene ndo mendeali dindini bame igiri yango pu haradagua bini.   
\q1
\v 13 Ti dindi mbirani baya hangu ho dambolo hene ndo.  
\q1 Ti togolo yalu pialu dindi wiaruni bibahendeha ge hai haga hene.  
\q1 Kini mbiragonaga dindiha puwa emene tigimandi dege halu  
\q2 lone hili yalu pialu kini mende heagonaga dindiha pu halu  
\q2 ani bigi bialu hene.   
\q1
\v 14 Ti ani bu ha heagolabi  
\q2 hameigini maru hongohe hearume ibunaga wali agali uruni hengedope holilono\x + \xo 105.14 \xt Pig 20.3-7\x*  
\q2 Ngode Datagaliwabe ibugua ti mamage hene.  
\q1 Mamage howa ibugua kini hearu talialu  
\q2 ibunaga wali agali urunihondo kagua mbira bulumini lalu lamini.   
\q1
\v 15 Ibugua lalu, I̱naga biabe bia haga i̱nime dabene karu mo ko holemini.  
\q2 I̱naga mana \w latagi\w* haga karuore mbira ela nahalimu, lene.   
\b  
\q1
\v 16 Anduane Homogohanda ti dindini tomo wiago damene bibahende mo yu ereba hai halu\x + \xo 105.16 \xt Pig 41.53-57\x*  
\q2 hina gariore gibi tagira pelene.   
\q1
\v 17 Ani ibilole howa dege ti maha ibilonaga\x + \xo 105.17 \xt Pig 37.28, 45.5\x*  
\q2 ibugua Yosebe ala bamba halu Iyibi dindi pu helene.  
\q1 Ibu hamene biarume Yosebe ti muni tagu wialu agali maru hearu  
\q2 tinaga garabaya biabe ale bia haga helo minu mini.   
\q1
\v 18 Tigua ibunaga ge kirabali pu senime minu huba biagola\x + \xo 105.18 \xt Pig 39.20–40.23\x*  
\q2 ge tandaga timbuni hene.  
\q1 Ani bialu aeane gendabi mbira ibunaga mani hende hene.   
\q1
\v 19 O biyadaruni Anduane Homogo ibugua ala Yosebehondo emagaha howa bulebira lamiyadagua  
\q2 henene tagira pene.   
\q1
\v 20 Ani biyagola Iyibi dindinaga kini heagome Yosebe gololenaga\x + \xo 105.20 \xt Pig 41.14\x*  
\q2 agali mbira heagome lama pu lene.  
\q1 Iyibi dindinaga kini wali agali dewaore haru haga heagome Yosebe golope hene.   
\q1
\v 21 Golope howa kini biagome ibunaga gabumane agali haguane helo\x + \xo 105.21 \xt Pig 41.39-41\x*  
\q2 Yosebe dabo helene.  
\q1 Dabi helowa Yosebe ibu Iyibi dindi bibahende hearunaga haguane helo helene.   
\q1
\v 22 Kininaga gabumane haru haga hearubi  
\q2 kinihondo mitangi talebu miaga hearubi  
\q2 uruni bibahende de hondowa haru holene hongo ibugua Yosebehondo mini.   
\b  
\q1
\v 23 Mani Yagaba ibu Iyibi dindi pialu\x + \xo 105.23 \xt Pig 46.6, 47.11\x*  
\q2 ogoriani ho ibira howa hene.   
\q1
\v 24 Ibu ani hearia Anduane Homogohanda Yagaba hameigini biamogo bialu\x + \xo 105.24 \xt Har 1.7-14\x*  
\q2 ti waneigini dewa tagira íbu helene.  
\q1 Yagaba hameigini uruni ti hongoheore helalu  
\q2 tinaga waitigi hearunaga hongo dindiha helo helene.   
\q1
\v 25 Anduane Homogo ibugua Iyibi wali agalime ibunaga wali agali handabe manga helo helene.  
\q1 Ani helayagola Iyibi wali agali tigua Anduane Homogonaga biabe biahaga hearu mo hondo hole  
\q2 henge taya bialu helo helene.   
\b  
\q1
\v 26 Mani Anduane Homogohanda ibunaga biabe biahaga ala dabene Mosesebi Aronobi heba libu haru Iyibi dindi pelene.\x + \xo 105.26 \xt Har 3.1–4.17\x*   
\q1
\v 27 Puwa libugua Iyibi dindini howa Ngode Datagaliwabenaga biabe hongoheore bialu  
\q2 manane tara tara agalime nabiagane ale dewa bialu hene.   
\q1
\v 28 Ngode Datagaliwabehanda aruma holeneme Iyibinaga dindi bu dambi hayagola\x + \xo 105.28 \xt Har 10.21-23\x*  
\q2 wali agali hearu ti arumaha hene.  
\q1 Iyibi wali agali arumaha hayagoyu tigua Ngode Datagaliwabehanda bidaba layadagua nabi  
\q2 ibunaga bi mo wahene.   
\q1
\v 29 Ibugua tinaga iba berearuni mo darama biai halu\x + \xo 105.29 \xt Har 7.17-21\x*  
\q2 wena ibaha berearuni bibahende bo homelai hene.   
\q1
\v 30 Yago dewaore gibi tidi yalu ibilalu  
\q2 tinaga dindini yago dege birame helalu\x + \xo 105.30 \xt Har 8.1-6\x*  
\q2 kininaga andaga hearuhabi heba yago degeme to̱lotagi helene.   
\q1
\v 31 Ngode Datagaliwabehanda bungunabi hinabibi alebi tidi yalu pudaba layagola\x + \xo 105.31 \xt Har 8.16-17, 8.20-24\x*  
\q2 ti tidi yalu puwa Iyibi dindi damenego pedegone mbira wuwa nahe  
\q2 bibahendeoreha to̱lotagi hene.   
\q1
\v 32 Ibugua tinaga dindini dalu ibuni ibi nale\x + \xo 105.32 \xt Har 9.22-25\x*  
\q2 dalu dindi kunibi hari dababi gibiore ibilene.   
\q1
\v 33 Ogoni ibiyagome Iyibi wali agalinaga mabuni pu mbira lini daga mini \w gerebi\w* hongo wiarubi podai halu  
\q2 poge ira hearubi podai halu  
\q2 ti dindini ira hearu damenego bibahendeore podai hene.   
\q1
\v 34 Ibugua bi hangu layagola pagaya ale dewaore gibi daga labe nahe tidi yalu tagira ibini.\x + \xo 105.34 \xt Har 10.12-15\x* \fig ... pagaya ale dewaore gibi daga labe nahe tidi yalu tagira ibini.|src="HK 8f.tif" size="2" ref="(105.34)" \fig*   
\q1
\v 35 Tagira ibuwa tigua dindini tomo bibahende hengearu damenegonaga yuni tugu naiore halu  
\q2 mbirale andaho hearu damene tene heba na anda hene.   
\q1
\v 36 Ngode Datagaliwabe ibugua Iyibi wali agalinaga igini wahene damenego bibahende\x + \xo 105.36 \xt Har 12.29\x*  
\q2 homelo bo wahai hene.   
\b  
\q1
\v 37 Mani ibugua Isaraele wali agali Iyibi dindi yu wahalu haru tagira pene.\x + \xo 105.37 \xt Har 12.33-36\x*  
\q2 Tinaga giha muni ngoloru silibaru yalu tagira pene.  
\q2 Isaraele wali agali ti bibahendeore bayale hongohe hangu tagira pene.   
\q1
\v 38 Iyibi wali agalime Isaraele wali agali hondowa giho henego  
\q2 Isaraele wali agali tagira pialu piyagola  
\q2 ti turuore halu dungulo daibu hene.   
\q1
\v 39 Ngode Datagaliwabehanda hari daligani ibunaga wali agali hearu tigatiga hari beraliba mbira ngelowa\x + \xo 105.39 \xt Har 13.21-22\x*  
\q2 ibunaga wali agali uruni andaneha helene.  
\q1 Mbiraga harini ira hangu delayagola  
\q2 ogonime wá hadali hayagola Isaraele wali agali ti wáni bayale hene.   
\q1
\v 40 Tigua Ngode Datagaliwabehondo tomo noa kama layagola\x + \xo 105.40 \xt Har 16.2-15\x*  
\q2 ibugua ti nelo hariha howa ega de̱wa̱re ale ibilayagola  
\q2 ti ega uruni balu nene.  
\q1 Ti tomo nelonaga ibugua dahuliya andaga howa mberedi dalilayagola  
\q2 ti karulapeore nowa tombeho hene.   
\q1
\v 41 Ti iba nelonaga to̱le̱ timbuni mbiraha howa iba tagira pelene.\x + \xo 105.41 \xt Har 17.1-7, Dag 20.2-13\x*  
\q2 Dindi ko dalu naibagaha iba timbuni biagoni tayandaha dugutagi haradagua bialu  
\q2 o biagoriani gerai yupe helene.   
\q1
\v 42 Anduane Homogo ibugua ala bamba howa habo nalolene bi hongohe mbira  
\q2 ibunaga biabe biahaga Abarahamahondo lowinigo  
\q2 ogoningi mitangi bini.   
\b  
\q1
\v 43 Anduane Homogo ibugua anidagua bialu  
\q2 ibunaga wali agali dabeneru haru halu tagira pene.  
\q1 Haru tagira piyagola ti turu hama iba gana ladaga halu mambolo bama pene.   
\q1
\v 44 Anduane Homogo ibugua wali agali hameigini tara maru hearunaga dindi wiaru muwa\x + \xo 105.44 \xt Yos 11.16-23\x*  
\q2 ibunaga wali agali uruni mo mini.  
\q1 Wali agali tara uruninaga mabu wiarubi muwa  
\q2 ibunaga wali agali uruni ti karulelene.   
\q1
\v 45 Ibugua ogonidagua binidagoni irane  
\q2 Anduane Homogohanda bi lenedarubi  
\q2 ibunaga mana lowinidarubi bibahende  
\q2 Isaraele wali agalime talialu biai helonaga ani bini.  
\q1 Anduane Homogonaga mini mo yaragaore hama.   
\c 106  
\s1 Anduane Homogohanda ibunaga wali agalihondo mana bayale biaga ka lenego ogo  
\q1
\v 1 Anduane Homogonaga mini yaraga hama.\x + \xo 106.1 \xt 1 Bit 16.34, 2 Bit 5.13, 7.3, Esr 3.11, Iba 100.5, 107.1, 118.1, 136.1, Yar 33.11\x*  
\q1 Ibugua mana bayale biaabo haga kagonagabi  
\q2 ibunaga gubalini holene ha ho wiaabo haga kagonagabi  
\q2 iname Anduane Homogohondo ka̱i̱ lama.   
\q1
\v 2 Ibugua mbirale timbuni bigi binirunaga garealalu aiwa lai habehedabe.  
\q2 Mana bayale biniru mitangi bialu  
\q2 ibunaga mini yaraga karulapeore hai habehe aiwadabe.   
\q1
\v 3 Wali agali ibunaga bi hale halu bia laradagua biaga karubi  
\q2 mana tigabi ngaru biaga karubi  
\q2 ti turu ho holene nga.   
\b  
\q1
\v 4 Anduane Homogo-o í̠naga wali agali biamogo berengi  
\q2 i̱bi nde mitangi bibe.  
\q1 Í̠na ti pele mialu haru dai berengi  
\q2 i̱bi nde haru dai bibelo hameledo.   
\q1
\v 5 Í̠naga wali agali ti bayale howa mbirale bayale damene ngaru mo wuwa  
\q2 tigua turu haga bialu kadagua  
\q2 i̱bi nde ti heba turu hamaga ho holeneore hamelo ko.  
\q1 Ina turu holene ogoni irane ina í̠ninaga wali agaliore henene kamagome  
\q2 mini mbiraore halu mandagi howa turu haga bu holeberama.   
\b  
\q1
\v 6 Bamba ina mamalirume mana ko bialu heneyadagua  
\q2 inamebi nde mana ko tara tara dewa wiaru bialu harimagoni.   
\q1
\v 7 Inanaga mamalirume Iyibi dindini heangi\x + \xo 106.7 \xt Har 14.10-12\x*  
\q2 í̠na biabe nahendene ale biriruni ti manda nabi haya.  
\q1 Í̠na í̠naga gubalini holene walia halu ti biamogo biriruni  
\q2 tigua embeda hai halu  
\q2 iba solowara Daramabi bereagoria heangi  
\q2 tigua Anduane Homogo Hongo Haiheore haabo kego í̠ni erembira ngiya.   
\q1
\v 8 Tigua ani biyagoyu Anduane Homogohanda ibunaga hongo timbuni winigo mo walia halu  
\q2 ibugua ti biamogo bule lalu bi lowinidagua pele mialu gi mini.   
\q1
\v 9 Ibugua iba solowara Daramabi bereagohondo bi lamiyagola\x + \xo 106.9 \xt Har 14.21-31\x*  
\q2 iba biagome bira migimigi bialu dindi pani hene.  
\q2 Pani hayagola ibugua wali agali haru halu ti iba biraga biagoria  
\q2 bame dindi hanguni poradagua bini.   
\q1
\v 10 Agali ti handabe manga haga hearume ti mo ko holebiyaria  
\q2 ibugua ti pele mini.  
\q2 Ti waitigi hearunaga giha hearia  
\q2 ibugua pele mialu haru dai bini.   
\q1
\v 11 Iba solowara timbuni biagome waitigi biaru bo tangu dambi hai halu ibame nai helene.  
\q2 Mbiraoreli hangubi mbira pora bialu napene.   
\q1
\v 12 Anduane Homogohanda anidagua biyagola ibunaga wali agali biarume\x + \xo 106.12 \xt Har 15.1-21\x*  
\q2 ibugua buleore lalu lowigi biniru heneneore biragonida manda bini.  
\q2 Manda bialu ibuhondo mini mbiraore wiai halu  
\q2 tigua ibunaga mini yaraga halu iba ganaru lalu hene.   
\b  
\q1
\v 13 Ibugua ani biyago bilowa dege  
\q2 tigua uruni biyaru abaleore embeda hai hene.  
\q2 Tigua mbirale bule manda biyaria Anduane Homogohondo haleha nabi  
\q2 tini miniha tagira ibiyaru ale dege bialu hene.   
\q1
\v 14 Dindi ko iba dalu naibaga wiagoria howa tinaga miniha tomo noa dege halu\x + \xo 106.14 \xt Dag 11.4-34\x*  
\q2 tigua Ngode Datagaliwabe ba hendene.   
\q1
\v 15 Tigua ibuhondo bi haya halu ngi laabo hayagola  
\q2 ibugua ngi layago mialu tiha warago timbunibi tagira ibilene.   
\b  
\q1
\v 16 Ti dindi ko iba dalu naibaga wiagoria howa tigua Mosesebi\x + \xo 106.16 \xt Dag 16.1-35\x*  
\q2 Anduane Homogonaga biabe biahaga helo loma bia hene Aronobi  
\q2 libuhondo henge lalu hene.   
\q1
\v 17 Ti ani bialu hemigola dindi mo gaibuki hayagola  
\q2 gundu uli timbuni mbira o biagoria wu pehene.  
\q1 Ani biyagola Dadanabi Abiramabi libu one waneigini damene bu hearubi  
\q2 bibahendeore gundu uli o biagoha uli piai hene.  
\q2 Uli piai hayagola dindi ibunime lone mo gegebu dambi hene.   
\q1
\v 18 Wali agali maru ko biaga biaru talima pialu hearuni  
\q2 ira hedo ibira halu ti dai helene.   
\b  
\q1
\v 19 Tigua Hari Horebe wiagoria howa nogo bulumaga ale mbira ngolome wabu ngelowa\x + \xo 106.19 \xt Har 32.1-14\x*  
\q2 dama ogonida lowa bi pupu wialu hene.   
\q1
\v 20 Tigua Ngode Datagaliwabe ibu duniniore mini lene kago mitangi bialu lotu laga henego wahalu  
\q2 nogo bulumaga datani nalu haga heago ale wabu ngelowa  
\q2 ogoni mitangi bia aribia halu ibuhondo bi pupu wialu hene.   
\q1
\v 21 Ngode Datagaliwabehanda ti Iyibi dindini hearia  
\q2 ibugua nahendene ale tara tara bialu  
\q2 Isaraele wali agali Iyibialirunaga giha hearia mo wini.  
\q1 Ibugua ani biyagoyu Isaraele wali agalirume ibu mo embeda ho hene.   
\q1
\v 22 Ngode Datagaliwabehanda Iyibi dindini agalime nabiagane ale timbuni dunini wiaru bialu  
\q2 iba solowara Daramabi bereagoria ibugua nahendene ale tara tara biyagola  
\q2 wali agali tigua mogolo hendene.   
\q1
\v 23 Ngode Datagaliwabehanda ibunaga wali agaliru bo wahole layagola  
\q2 ibunaga biabe biahaga helo dabo helene Mosese ibugua Ngode Datagaliwabenaga deni heyu howa  
\q2 Isaraele wali agali biamogo bialu Ngode Datagaliwabehanda bo wanahelo  
\q2 ibunaga keba holene wiago ha pai hayagola  
\q2 Ngode Datagaliwabehanda ibunaga wali agali ba nabi wahene.   
\b  
\q1
\v 24 Ngode Datagaliwabehanda bulebero lalu lowiyago tigua yu tiga nabi howa\x + \xo 106.24 \xt Dag 14.1-35\x*  
\q2 dindi bayale ibugua ti ngulebero layago mo waho hene.   
\q1
\v 25 Tigua tinaga balai andaha ho palu howa bi gomogomo lalu  
\q2 Anduane Homogohanda tihondo bi layago talialu bia nabi wahene.   
\q1
\v 26 Ti ani heagola Ngode Datagaliwabehanda tihondo bi hongohe lalu,  
\q2 Tí dindi ko ege to̱le̱ hangu wiaga ngagoha i̱na tí home lelolebero.   
\q1
\v 27 Tínaga waneigini aguanene mani holobadaru ti dindi taratara ngaruha talia togo lelarogola\x + \xo 106.27 \xt LBM 26.33\x*  
\q2 ti hameigini tara tara Anduane Homogo manda nabi bu karu heba howa  
\q2 dindi tara ogoniha halu homolebira, lene.   
\b  
\q1
\v 28 Mani tigua Peo dindini howa dama mitangi bialu gime wabu wini mini Balahondo bi pupu wialu hene.\x + \xo 106.28 \xt Dag 25.1-13\x*  
\q2 Tigua mbirale ema nabulene bi nalaga ogonihondo lomabu mini tomo wiaru nalu hene.   
\q1
\v 29 Tigua mana ogonidagua bialu hayagome Anduane Homogo mo keba hayagola  
\q2 ibugua warago koore mbira tiha anda ibilaya.   
\q1
\v 30 Warago ogoni ibilayagola Piniasahanda heyuwa mana ko bialu hearu bibahende minu baga biyagola  
\q2 warago timbuni biago ereba haya.   
\q1
\v 31 Piniasahanda mbirale o binidaruni bayale biya lalu wali agalime mitangi biaho kadagua  
\q2 maniore wali agali holebirarumebi anidagua dege mitangi biaabo holebira.   
\b  
\q1
\v 32 Isaraele wali agalime iba Meriba peagoria howa\x + \xo 106.32 \xt Dag 20.2-13\x*  
\q2 Anduane Homogo mo keba halu heneya.  
\q2 Tigua ani biyagome pani tini nolene winigo  
\q2 genda ogoni Mosesehanda tinaga yu aribia heneya.   
\q1
\v 33 Tigua Mosese mo tandaga timbuni hayagola  
\q2 ibugua bayuwa mitangi nabi howa bi bayale ndo mbira lene.   
\b  
\q1
\v 34 Anduane Homogohanda tihondo wali agali tara karu homelo bo wahai halimu lalu lamiyago\x + \xo 106.34 \xt Hgn 2.1-3, 3.5-6\x*  
\q2 tigua nabe wahene.   
\q1
\v 35 Isaraeleali tigua wali tara berearu dabu bigi buwa  
\q2 tinaga mana ko wiago taluwa bialu haga heneya.   
\q1
\v 36 Tigua dama mitangi bialu gime wabu wiaruhondo bi pupu wialu hayagome  
\q2 Ngode Datagaliwabehanda tini mo ko helo helene.   
\q1
\v 37 Tigua dama mitangi bialu gime wabini Kenana dindini wiaruhondo\x + \xo 106.37 \xt 2 Kin 17.17\x*  
\q2 tinaga waneiginiru bu hearu bo lomabu miaga heneya.   
\q1
\v 38 Ti waneigini urunime ko bini mbira nawioregoyu\x + \xo 106.38 \xt Dag 35.33\x*  
\q2 tigua bameore homelo beneyago  
\q2 waneigininaga daramame Ngode Datagaliwabenaga deni dindi ogoni mebiahe winiya.   
\q1
\v 39 Tigua mana ko ogonidagua biyagome  
\q2 tini Ngode Datagaliwabenaga deni dodohe halu  
\q2 ibu erembira mialu ibuni talima nape wahene.   
\b  
\q1
\v 40 Anduane Homogohanda ibunaga wali agali urunihondo keba timbuni howa  
\q2 ibugua ti handabe mangaore heneya.\x + \xo 106.40 \xt Hgn 2.14-18\x*   
\q1
\v 41 Anduane Homogohanda Isaraele wali agali yupe howa  
\q2 ti hameigini tara tara hearunaga giha helene.  
\q2 Ani biyagola ti waitigi biarunaga andaneha hene.   
\q1
\v 42 Waitigi urunime ti genda dewaore mo ya heagola  
\q2 ti waitiginaga andaneha haabo hene.   
\q1
\v 43 Anduane Homogohanda ibunaga wali agali biamogo biaabo hayagoyu  
\q2 ti doga howa ibugua bi layago mo wahalu mana ko dewaore bialu hene.   
\q1
\v 44 Tigua ani biaabo hayago helowa Anduane Homogo olalu ibuhondo bi layagola  
\q2 ibugua hale howa tiha genda wiago de handalu ti dara haga biniya.   
\q1
\v 45 Ibugua tihondo dara timbuni halu habo nalolene bi ala lowiyago mitangi biniya.  
\q2 Ibugua tihondo gubalini haabo hayagome lone mitangi bialu ti dara heneya.   
\q1
\v 46 Anduane Homogohanda ti waitigi bu hearunaga miniha mo wála hayagola  
\q2 tigua Isaraeleali hondowa daraho dai bini.   
\b  
\q1
\v 47 Anduane Homogo inanaga Ngode Datagaliwabe kego  
\q2 í̠na ina waitigi karunaga giha howa yamialu  
\q2 inanaga dindini lone holoma̱ya haru dai bu helabe.  
\q1 Í̠na anidagua beregola iname í̠hondo turu halu ka̱i̱ lalu  
\q2 í̠naga mini baya buruguleore yaraga halu haabo holeberema.   
\b  
\q1
\v 48 Anduane Homogo Isaraele wali agalinaga Ngode Datagaliwabe kago  
\q2 ibu mini yaraga hami̱ya.  
\q1 Áyubi maniore howabi ibunaga mini yaraga haaboore hami̱ya.  
\q1 Ina wali agali bibahendeme lalu,  
\q1 Heneneore Anduane Homogonaga mini yaragaore hama, lalu  
\q2 aniore laabo hami̱ya.   
\ms1 MBUGA DAUNI  
\mr (Iba Gana 107-150)  
\c 107  
\s1 Anduane Homogo ibu bayale gibiore biaga kagonaga mini mo yaraga henego ogo  
\q1
\v 1 Anduane Homogo ibugua inahondo baya gibi dege bigi biaga ka.\x + \xo 107.1 \xt 1 Bit 16.34, 2 Bit 5.13, 7.3, Esr 3.11, Iba 100.5, 106.1, 118.1, 136.1, Yar 33.11\x*  
\q2 Ibugua ina gubalini haho wiaaboore haga kagoni.  
\q2 Ibugua ani biaga kagonaga iname ibuhondo ka̱i̱ lolene nga.   
\q1
\v 2 Ala tínaga waitigi hearunaga gime tí minu yaniho hearia  
\q2 Anduane Homogohanda gingila mialu haru dai bini kamiru  
\q2 tígua i̱na larodagua dege lalu  
\q2 ina haru Anduane Homogonaga mini mo yaraga hami̱ya.   
\q1
\v 3 Tí dindi haluni taraha hemiria ibugua haru dai biyagoni.  
\q2 Dindi tara tara ni tagira ibiragohayagibi ni paliragohayagibi  
\q2 uyurahayagibi unurahayagibi dindi uruni bibahendeni hemiria  
\q2 ibugua tí haru dai biai hayagoni.   
\b  
\q1
\v 4 Wali agali maru dindi ko wali agali nahaga wiagoha pupe halu pene.  
\q2 Piyago puwa hariga nawiaha pu lulu yuwa  
\q2 wali agali pale andahe mbira nawiaha iraga howa pu taluaho hene.   
\q1
\v 5 Pu taluaho howa hina gari gibiore bialu  
\q2 iba noa howa hége lebolaho daga hayagola  
\q2 ai tongoore lole ogonida lo manda bini.   
\q1
\v 6 Tini darabi ogonibiore howa Anduane Homogo olayagola  
\q2 ibugua ti biamogo bigi bialu  
\q2 genda yu hearuni yamuwa mo wahaga bini.   
\q1
\v 7 Ani bialu ibugua ti hariga tigabini pelo haru pialu  
\q2 tano mbira ti holene winiyagoria haru pu helene.   
\q1
\v 8 Anduane Homogohanda ti gubalini haho wiaabo halu  
\q2 tinaga mbirale baya gibi turubini hangu bia haga bialu hayagonaga  
\q2 tigua Anduane Homogohondo ka̱i̱ore lolene nga.   
\q1
\v 9 Wali agali iba noa howa hége yobu karu iba nelo ibugua miragola\x + \xo 107.9 \xt Iba 34.10, Lg 1.53\x*  
\q2 ti iba karulapeore nowa dungulo helo miaga ka.  
\q2 Wali agali tomo noaho karu nelo tomo dewaore miragola  
\q2 ti haruore nowa tombe to̱lo haga kagoni.   
\b  
\q1
\v 10 Wali agali maru arumaore dumbiliniha howa\x + \xo 107.10 \xt Yob 36.8, Ais 9.2, 42.16, Lg 1.79\x*  
\q2 pu senime gi ge minu hubabu wiagola  
\q2 garabayaore howa gendaho hene.   
\q1
\v 11 Ti ogonibiha henedagoni irane  
\q2 tinime Ngode Datagaliwabe Hongo Haiheore kagome  
\q2 ogoale bibe nabibe lalu laga biyagola  
\q2 tigua ibunaga bi erembira mialu piyagome tini ogonibiha pu hene.   
\q1
\v 12 Pu howa ti erekui biabe biadege bialu  
\q2 hongo bibahende pirilipe hai hayagola hene.  
\q2 Hongo bibahende ereba hai halu dindini pilo ibira haga biyagola  
\q2 ti gi mulene mbirali nahene.   
\q1
\v 13 Tini darabi ogonibiore howa Anduane Homogo olayagola  
\q2 ibugua ti biamogo bigi bialu genda yu hearuni yamuwa mo wahaga bini.   
\q1
\v 14 Anduane Homogohanda ti arumaha mini burugule ogoniha hearia\x + \xo 107.14 \xt Iba 68.6, 146.7, Ab 12.7\x*  
\q2 pu seni biaru hadape halu  
\q2 ti garabaya hayago lone hodai nabilo golope halu pelene.   
\q1
\v 15 Anduane Homogohanda ti gubalini haho wiaabo halu  
\q2 tinaga mbirale baya gibi turubini hangu bia haga bialu hayagonaga  
\q2 tigua Anduane Homogohondo ka̱i̱ore lolene nga.   
\q1
\v 16 Ibugua aeane hongohe mini boronosime panga payadaruni duanialu  
\q2 aeaneme garabaya anda hobanda karuni podo gingirulo bagabu ibira ibira bile laga ka.   
\b  
\q1
\v 17 Wali agali maru ti kedange howa tinime mana ko tara tara dewa bigi biyagome  
\q2 warago balu tandaga nalu hene.   
\q1
\v 18 Ti tomo noa nahe magu gibi halu tomoore de handaya haga biyagola  
\q2 tongolo mialu dai bigi bini.   
\q1
\v 19 Tini darabi ogonibiore howa Anduane Homogo olayagola  
\q2 ibugua ti biamogo bigi bialu genda yu hearuni yamuwa mo wahaga bini.   
\q1
\v 20 Anduane Homogo ibunaga bime ogoale bia layagola  
\q2 tinaga tingini biaruni lone mo dabiho dai bialu  
\q2 homalihaore anda pole biyaria  
\q2 ibugua ti gililo mu yudai bigi biyagoni.   
\q1
\v 21 Anduane Homogohanda ti gubalini haho wiaabo halu  
\q2 tinaga mbirale baya gibi turubini hangu bia haga bialu hayagonaga  
\q2 tigua Anduane Homogohondo ka̱i̱ore lolene nga.   
\q1
\v 22 Tigua Anduane Homogohondo ka̱i̱ lalu  
\q2 mbirale ibuhondo bo lomabu mulene nga.  
\q1 Tigua iba gana turu halu lalu wali agali maru karu hale helo  
\q2 Anduane Homogohanda mana bayaore bigi biyarunaga mo yaraga halu lamiaga bulene nga.   
\b  
\q1
\v 23 Agali maru ti iba sibini palu howa  
\q2 iba solowara angeni gago taguape hama ibaga bialu  
\q2 dindi ngagoha ibaga biai halu  
\q1 tinde muni biabe ogoni biaga hene.   
\q1
\v 24 Agali iba sibini biabe bialu haga uruni tiguabi  
\q2 Anduane Homogohanda bigi biyago handaga bini.  
\q1 Anduane Homogo ibugua iba solowarani mbirale bayaore bigi biyago handaga bini.   
\q1
\v 25 Anduane Homogo ibugua ani bia layagola  
\q2 puyabu hongoheore pu lalu iba solowara yaribu gibiore bini.   
\q1
\v 26 Ani biyagome iba sibiru uyura daligaore mo baraga halu  
\q2 lone unura mo baraliore haga bini.  
\q1 Hiriribi ogonidagua bigi biyago handayagola  
\q2 agali iba sibini biabe biaga biarume  
\q2 aiore áyu homarimadagoni manda buwa gi timbuniore ho hene.   
\q1
\v 27 Tinaga mini bibahende puguai halu homolene anda ibiyagola  
\q2 lulu iba nowa mini ereba howa sibaga lo haradagua  
\q2 ti iba sibi biagoriani ibagabu hene.   
\q1
\v 28 Tini darabi ogonibiore howa Anduane Homogo olayagola  
\q2 ibugua ti biamogo bigi bialu  
\q2 genda yu hearuni yamuwa mo wahaga bini.   
\q1
\v 29 Anduane Homogo ibugua puyabu hongohe pu layagoni pulairi helalu  
\q2 iba yaribu gibiore biyagoni mo hundia halu  
\q2 iba solowara ema nabi bayale berelene.   
\q1
\v 30 Iba solowarame ema nabi bayaore birape hayago hondowa  
\q2 agali biaru ti turuore halu hene.  
\q1 Anduane Homogo ibugua ti bayuwa haru pialu  
\q2 iba sibi anda pu wiaga wiagoria ubandaho ngelene.   
\q1
\v 31 Anduane Homogohanda ti gubalini haho wiaabo halu  
\q2 tinaga mbirale baya gibi turubini hangu bia haga bialu hayagonaga  
\q2 tigua Anduane Homogohondo ka̱i̱ore lolene nga.   
\q1
\v 32 Uruni tigua Ngode Datagaliwabenaga wali agali mandagi ngoaiho bedagoria  
\q2 Anduane Homogo ibu daligaore gibi kagoni lalu  
\q2 bibahende hale hai helo lope holene nga.  
\q1 Agali haguane dege dege ngoaiho bedarubi hale hai helo  
\q2 ogoriani ibunaga mini laraga holene nga.   
\b  
\q1
\v 33 Anduane Homogo ibugua iba poraruni hundilai helalu  
\q2 iba dindiha howa dugualu karuni bibahende hundi tege lelaga hene.   
\q1
\v 34 Dindi bene bere mbirale anda holene ngaruni mo beregedowa  
\q2 mbirale mbira anda habe nahe koore ibi dindi kuni panaho ngelaga hene.  
\q1 Ogonidagua biaganego irane wali agali dindi ogoriani hearume ko gibiore biyagola  
\q2 ti genda ogoni yilo Anduane Homogo ibugua miaga hene.   
\q1
\v 35 Dindi ko mbirale mbira anda nahaga ngarunaga iba goroyane tagira íbu berelalu  
\q2 dindi yobu dagahe ngarunaga iba dugutagi helaga bini.   
\q1
\v 36 Ibugua dindi bene bere ogoriani wali agali ala tomo nolene nawi buru palu haga hearu  
\q2 dindi ogoriani haru ibalu tigua anda bu hene.   
\q1
\v 37 Ti ogoriani hope ho howa ti mabuni tomo hangalu  
\q2 pu mbira lini daga mini \w gerebi\w* dewa hongo wini.  
\q1 Hongowa tomo dewaore ti mabuni bu ngaria bialu  
\q2 gerebi lini dewaorebi daga hene.   
\q1
\v 38 Anduane Homogo ibugua ibunaga wali agalihondo baya gibiore bialu  
\q2 ti mo gumbila hayagola  
\q2 tinaga waneigini dewaore hene.  
\q1 Ibugua tinaga nogo tara tara hearubi dewaore ho dame bilene.   
\b  
\q1
\v 39 Anduane Homogonaga wali agali biaru tinaga waitigi hearume bo hengedalu  
\q2 mo taga hayagola tandaga nalu dindihaore darabi hearia hondowa   
\q1
\v 40 ibugua ibunaga wali agali biaru bope haga agali haguane hearu mo habane nabulene helalu  
\q2 ti dindi ko hariga nawi wiagoha luluyu ibagabu helo helene.   
\q1
\v 41 Ani biyagoyu wali agali yagibano darabi ha ko howa hearu  
\q2 ibunime ti biamogo bigi bini.  
\q1 Tinaga waneigini dewaore nogo sibi ale tagira íbu helo biamogo bini.   
\q1
\v 42 Wali agali mini tigabiwi karume  
\q2 Anduane Homogohanda baya turubi urunibi bigi biaga kago hondowa  
\q2 ti turuore halu miniha dunguore lo haga ka.  
\q1 Wali agali mini kowi karu tinaga bi mbira lolenego nawioredagola  
\q2 ti bame ne hambu ndibu lowa hama pedagoni.   
\b  
\q1
\v 43 Anigo ai wali agali mini gigabiwi karume bi o laruruni damenego bibahendeore  
\q2 baya hangu mitangi biai helo hameledo.  
\q1 Anduane Homogo ibugua ti gubalini gibiore haho wiaabo haga kago  
\q2 ogoninaga laluore maru karu hale hai helo hameledo.   
\c 108  
\s1 Ngode Datagaliwabehanda ibunaga wali agali biamogo bilonaga bi lenego ogo  
\r (Iba Gana 57.7-11, 60.5-12)  
\q1
\v 1 Ngode Datagaliwabe-o i̱ mini bilinahe howa  
\q2 í̠hondo mini mbiraore hongohe wu kogonigo  
\q2 i̱na iba ganaru lalu  
\q2 í̠naga mini yaraga halu holebero.   
\q1
\v 2 I̱ni padogoria heyuwa i̱na ngida aleru barogome  
\q2 ni tagira ibilo mo heya holebero.   
\q1
\v 3 Anduane Homogo-o i̱ dindi tara tara ngaruha pu howa  
\q2 í̠hondo ka̱i̱ laabo holebero.  
\q1 Hameigini tara tarabu karuha pialu  
\q2 i̱na í̠naga mini yaraga hama polebero.   
\q1
\v 4 Anduane Homogo-o í̠naga gubalini haabo holene emene ndoore  
\q2 hari daliga elahe wu kegoni.  
\q1 Í̠naga mini bilinahe ngego timbuni yangale howa  
\q2 hari mindini elahe wu kegoni.   
\b  
\q1
\v 5 Ngode Datagaliwabe-o í̠ni timbuniore dunini kego wali agalime handai helo  
\q2 hari daligani mo walia habe.  
\q1 Dindi bibahendeha í̠naga wá holenebi mini lene holenebi  
\q2 panigi mo walia habe.   
\q1
\v 6 Í̠na ina gubalini timbuni ho haga kegonigo  
\q2 bayale hai holoma̱ya i̱naga bi larogo hale habe.  
\q1 Í̠naga hongo timbuni ho kegome ina pele ngibe laro.   
\b  
\q1
\v 7 Ngode Datagaliwabehanda ibuninaga andaha howa lalu,  
\q1 I̱na wai bialu bo podahana hai halu wayali harugo  
\q2 Segeme dindibi Sugodo dindiha dindi ulini bugubugu wuyu pedarubi  
\q2 dindi uruni i̱naga wali agaliru ti helo  
\q1 i̱na ti tu wu ta hai holebero.   
\q1
\v 8 Gileada dindibi Manase dindibi i̱ninagaore nga.  
\q2 Eberaimi ibu i̱naga ege manda ale nga.  
\q2 Yuda ibu kininaga haru haga halimbu ale nga.   
\q1
\v 9 Moaba dindi i̱naga wayawaya biaga ndisibe ale wialu  
\q2 Idomo dindi i̱nagaore ngo lalu i̱na i̱naga ge su golowa  
\q2 dindi ogoriani ba amu holebero.  
\q1 I̱na Pilidialiru balu wayali howa  
\q2 turu halu ga̱ lalu harugoni, laya.   
\b  
\q1
\v 10 Ngode Datagaliwabe-o pabe hongohe bu mabubi tano ngagoha  
\q2 i̱ aiwa haru anda polobadabe.  
\q1 Idomo dindiha i̱ aiwa haru polobadabe.   
\q1
\v 11 Ngode Datagaliwabe í̠na ina erembira ngiribe.  
\q2 Í̠na inanaga ami agali karu biamogo nabuleorebe.   
\q1
\v 12 Agalinaga hongome ina biamogo bulene emene nakarulapego  
\q2 ina waitigi bu karu baba wai buluma̱ya  
\q2 í̠nioreme ina biamogo bibe.   
\q1
\v 13 Ngode Datagaliwabe ibu ina heba kayagua nde  
\q2 iname wai bialu wayali holeberema.  
\q2 Waitigi karu ibunime bope hai holebira.   
\c 109  
\s1 Agalime genda yu howa Anduane Homogo olenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o i̱na í̠naga mini yaraga halu  
\q2 bi larogo haleore howa ladai bibe.   
\q1
\v 2 Agali ko bu karumebi ke̱ hagane bu karumebi i̱ handabe manga howa  
\q2 ke̱ halu i̱ mege bialu kagoni ndobe.   
\q1
\v 3 Tigua i̱ mini lalu ke̱ howa bi koore lalu ka.  
\q1 Tigua irane mbira nayi howa bi ko ogoni lalu ka.   
\q1
\v 4 I̱na nde ti gubalini ho howa Anduane Homogohondo tinaga bi lahalu kogoni.  
\q1 I̱na ani berogo bilowa tigua nde i̱ handabe manga haga ka.   
\q1
\v 5 I̱na tihondo mana bayaleru bialu kogola  
\q2 tigua i̱hondo mana ko biadai biaga ka.  
\q1 I̱na tihondo gubalini ho kogola  
\q2 tigua i̱hondo gubalini nahe handabe manga haga ka.   
\b  
\q1
\v 6 I̱ waitigi kagonaga bi larago mo tale bilonaga  
\q2 agali ko mbira dabo helabe.  
\q1 Ibuninaga waitigi kagome ibuni godini haru pu helelo helabe.   
\q1
\v 7 Agali godi hale haga kagome agali godini pu kagola  
\q2 ko bini mbira ngane handalu garabaya helelo hameledo.  
\q1 Agali ogonime Ngode Datagaliwabehondo bi laradagobi  
\q2 ko dege bini lalu walia holebira.   
\q1
\v 8 Ibu dindini lu nahe abale homelo hameledo.\x + \xo 109.8 \xt Ab 1.20\x*  
\q1 Biabe ibugua bialu haga ngaru  
\q2 agali mendealime bia aribia halu helo hameledo.   
\q1
\v 9 Agali ogoninaga waneigini ti aba nahe helo  
\q2 ibu onebi wali dalo berelo hame ledogoni.   
\q1
\v 10 Ibunaga waneiginiore tinaga anda mbira nahe yagibanoore howa  
\q2 ibaga hangu bialu ngi ngi laabo haga helo hamelo kogoni.  
\q1 Ti anda koha palu karia agali marume ibalu  
\q2 ti bo taliatagi helo hamelo kogoni.   
\q1
\v 11 Waitigi agali ogoni ibu baba agali maru dano ho heneme  
\q2 ibunaga dindibi mbirale wiyadarubi ti karulai helo hameledo.  
\q1 Agali dindi taraha howa íbu hene karume  
\q2 ibunaga biabe bialu hayagonaga yolo ti mo nelo hameledo.   
\q1
\v 12 Maru karume agali ogoni biamogo nabilo  
\q2 ibu waneigini helalu homeneru mbiralime dara howa biamogobi nabilo hamelo kogoni.   
\q1
\v 13 Ibunaga waneigini aguanenerubi homai halu  
\q2 dabane mani holebirarume ibunaga mini embedaho wahelo hamelo kogoni.   
\q1
\v 14 Anduane Homogohanda agali biagonaga mamali bamba henerume  
\q2 ko biyaru mitangi bu wiaabo halu  
\q2 ibu ai̱yahanda ko biyarubi domo wanahelo hameledo.   
\q1
\v 15 Anduane Homogo ibugua urunime ko bibahende biyaru mitangi bu wiaabo halu  
\q2 marume ti hameigini heneru embeda ho wahelo hameledo.   
\b  
\q1
\v 16 Agali o biago ibugua mendeali kago  
\q2 dara holene mitangi nabiaga hene.  
\q1 Ibugua yagibano hearubi mbirale nayi burupale hearubi  
\q2 hongo nahe genda yu hearubi ti mo tandaga halu bo wahaga hene.   
\q1
\v 17 Bamba ibugua agali maru hearu mo ko helonaga ha haga hene.  
\q2 Áyu marume nde ibuni ha helo hameledo.  
\q1 Ibugua Ngode Datagaliwabehondo agali mende kago  
\q2 biamogo bibe lalu bi laholene mangaho haga hene.  
\q1 Ibuni nde maru karume turu howa biamogo nabilo hameledo.   
\q1
\v 18 Horo bibahendengi ibugua aga karulo haabo hagadagua  
\q2 ibu mendeali kago ha holene mugube hene.  
\q1 Ibugua maruhondo ha haragome ibuni tinginiha iba ale anda pialu  
\q2 ibu kuniha weli ale anda pelo hameledo.   
\q1
\v 19 Ha holene bi ogonime ibuni tingini aga biadambi haradagua bialu  
\q2 ibuni mandibu wu haradagua bilo hameledo.   
\b  
\q1
\v 20 Anduane Homogo-o waitigime i̱hondo bi ko ogonibi laga kago  
\q2 tini ko helo pani ogonidagua nelo mibe.   
\q1
\v 21 I̱naga Anduane Homogo Bibahende Haru Hame Ho Haga-o  
\q2 í̠na i̱ biamogo bulebero lalu lo wiridagua  
\q2 biamogo bibelo hamelo kogoni.  
\q1 Í̠naga gubalini holenemebi bayaleore bulenemebi  
\q2 i̱ pele ngialu haru dai bibelo hamelo kogoni.   
\q1
\v 22 I̱ bu miniha genda tandagabi yu haabo kogome  
\q2 i̱ yagibano howa burupale kogoni.   
\q1
\v 23 Alendo ni anda poragola ni munini biago abale ereba haralidagua  
\q2 i̱ abale pu wahole kogoni ndobe.  
\q1 I̱ore bame hinabibi ale bedoria  
\q2 puyabume pulo wahabehe kogoni ndobe.   
\q1
\v 24 I̱ tomo nane kogome i̱naga ge duli hongo nahe kogoni.  
\q1 I̱ni obu wahalu i̱naga kuni bibahende pirilape hai ka.   
\q1
\v 25 Wali agali i̱ de handararume i̱ hondo oba halu\x + \xo 109.25 \xt Md 27.39, Mg 15.29\x*  
\q2 mege bialu ma tandalaga bialu kagoni ndobe.   
\b  
\q1
\v 26 Anduane Homogo i̱naga Ngode Datagaliwabe-o i̱ biamogo bibe.  
\q1 Í̠na i̱hondo gubalini timbuni ho haabo haga kegome  
\q2 i̱ pele ngibe.   
\q1
\v 27 I̱ waitigi bu karume i̱ pele ngiaga í̠ni kegonida  
\q2 manda bilo walia habe.   
\q1
\v 28 Tigua i̱ Ngode Datagaliwabehanda mo ko helo laga bialu ha holebiragoyu  
\q2 í̠na i̱ biamogo biaabo haga kegoni.  
\q1 Agali i̱ mo tandaga haga karu  
\q2 tini mo tandaga habelo hamelo kogoni.  
\q1 Í̠naga biabe biahaga i̱ kogo  
\q2 i̱naga miniha dungulo holiya mo dungula habe.   
\q1
\v 29 I̱ waitigi biaru ti taga pani timbuni nalu helo hameledo.  
\q2 Tigua aga lu biagimbubi karulagadagua  
\q2 ti taga harago wali agali karume hendelo  
\q2 í̠na taga holeneme ti karulagimbu bu helabelo hamelo kogoni.   
\b  
\q1
\v 30 I̱na bi hongo howa ladaga halu Anduane Homogohondo turu howa  
\q2 ka̱i̱ timbuni lalu holebero.  
\q1 Wali agali dewali Anduane Homogo mitangi bialu lotu lole ngoai ho kagoria  
\q2 i̱na Anduane Homogonaga mini yaraga holebero.   
\q1
\v 31 Ibugua wali agali yagibano karu biamogo biaga ka.  
\q2 Wali agali marume godi deni haru tagira puwa uruni ti bo waholene nga nalelobi  
\q2 ibugua ti handayaho halu tinaga lahaga ka.   
\c 110  
\s1 Anduane Homogola kini mbira ibunime dabenegola iba gana lenego ogo  
\q1
\v 1 Anduane Homogohanda i̱naga Anduane Homogo kinihondo ogodagua laya.\x + \xo 110.1 \xt Md 22.44, Mg 12.36, Lg 20.42-43, Ab 2.34-35, 1 Ko 15.25, Eb 1.20-22, Kl 3.1, Hi 1.13, 8.1, 10.12-13\x*  
\q1 Í̠ waitigi karu í̠naga geme hengedai habelo i̱na mo heloliya  
\q2 í̠ i̱naga gi tigahayagi ogoria birabe, laya.   
\q1
\v 2 Anduane Homogo ibugua í̠na handayaho habelo  
\q2 Saiono howa dindi dewaore mo tago holebira.  
\q1 Ibugua ogodagua lalu,  
\q1 Í̠na í̠ waitigi karuni í̠ andaneha í̠na handayaho habe, leda.   
\q1
\v 3 Í̠na í̠ waitigi karu bo pole wai tagira porengi  
\q2 í̠naga wali agali karume wai í̠ha anda ibalu  
\q2 tini hameme wai ina haru bu ma lolebira.  
\q1 Mbiraga dadimba ibiragome tanini damiragola  
\q2 tani ibuha hongo gahenge anda ibagadagua dege  
\q2 í̠naga igiri daliaheru tiha hongo holene gahenge anda ho howa  
\q1 Ngode Datagaliwabenaga hari kago iraga halu í̠ keria ibulebira.   
\b  
\q1
\v 4 Anduane Homogohanda í̠hondo bulebero lowialu mbira ogodagua layagoni.\x + \xo 110.4 \xt Hi 5.6, 6.20, 7.17, 7.21\x*  
\q1 \w Loma\w* binigo mo miaga mbirali Ngode Datagaliwabehondo loma binigo mo miaga Melegesedege heneyagobi dege  
\q2 í̠ haho wiaabo holebere, lalu lowini.  
\q1 Anduane Homogohanda bi ogoni heneneore henene ledago  
\q2 ibugua bi ogoni lone mende ale lo aribia naholebira.   
\b  
\q1
\v 5 Anduane Homogo ibugua í̠naga gi tigahayagi mo hongo holenaga  
\q2 ibuni í̠ heba hapara ho kagoni.  
\q1 Ibu keba harangi ibugua kini tara tara karu balu bope hai holebira.   
\q1
\v 6 Ibugua wali agali dindi tara tarani bu karume  
\q2 ko biyarunaga pani tini nelo dabo mulebira.  
\q1 Ani bialu wai biagane wai hamani  
\q2 agali dewaore homene bo payapaya bulebira.  
\q1 Dindi bibahendenaga kini hama pedaruni bibahende  
\q2 ibugua bope hai holebira.   
\q1
\v 7 Ani bialu kini ogoni ibu agali balu pialu  
\q2 iba kaware hariga teneni poragoni dalipe howa hambu nolebira.  
\q1 Ani bigi biyarume kini ibu hongohe halu  
\q2 wai bigi biragola wayali haabo holebira.   
\c 111  
\s1 Iname Anduane Homogonaga mini yaraga hami̱ya lalu lenego ogo  
\q1
\v 1 Anduane Homogonaga mini yaraga hami̱ya.  
\q1 I̱na ibunaga wali agali ngoaiho kagoria pialu  
\q2 ibuhondo gubalini timbuni howa ka̱i̱ lalu holebero.   
\q1
\v 2 Anduane Homogohanda biabe nahendene ale gibiore biaga ka.  
\q2 Wali agalime biabe uruni birago hondowa turuho haga bu karu  
\q2 tigua biabe uruni bayuwa manda bule begelo handaga ka.   
\q1
\v 3 Ibugua biabe biraru damene bibahendeme  
\q2 ibu mini leneorebi  
\q2 ibu haru haga kiniorebi ka lalu walia haga nga.  
\q1 Ibunaga mana tigabi ngagoni wiaabobo bu wulebira.   
\b  
\q1
\v 4 Anduane Homogo ibunime mbirale biniru damene wali agalime mitangi biaabo helo  
\q2 ibugua tinaga miniha mo wála halu haabo haga ka.  
\q1 Ibugua inahondo dara holene nawi howa  
\q2 ina dara halu bayale biamogo biaabo haga ka.   
\q1
\v 5 Ibugua wali agali ibu mo dunini ho karuhondo tomo nelo miaabo haga ka.  
\q1 Ibugua wali agalihondo habo nalolene bi bamba lowinigo embeda nahagaore ka.   
\q1
\v 6 Ibugua i̱ hongo ogobi ko lalu walia halu  
\q2 wali agali maru bu hearunaga dindi wiaru  
\q2 ibunaga wali agaliruhondo mo mini.   
\b  
\q1
\v 7 Ibugua mana biaga ngaru damene bibahende mini bilinahe howa  
\q2 tigabiore biai haga ka.  
\q1 Ibugua mana bulene nga leneru  
\q2 iname mo dunu bia howa talialu bulene nga.   
\q1
\v 8 Anduane Homogo ibugua bi mana urunibi lo wiyaru  
\q2 ibu heneneorebi bayale tigabibi howa lowiyago  
\q2 bi uruni wiaabobo bu wulebira.   
\q1
\v 9 Ibunaga wali agaliru ibunime golope halu haru dai bialu  
\q2 tihondo habo nalolene bi wiaaboore helo lowini.  
\q1 Anduane Homogo ibu baya burugule mini leneore ka.   
\q1
\v 10 Mbirali ibu mini bayale gigabiwi hoa hayagua\x + \xo 111.10 \xt Yob 28.28, Min 1.7, 9.10\x*  
\q2 ala Anduane Homogo gibiore ka lalu ibu mo dunini holene nga.  
\q1 Wali agalime ibuni hamelo kago bialu kane hendedagohondo  
\q2 ibugua mini bayale gigabi wuleneru talebu miaga ka.  
\q1 Ibu ogonibi ka manda bialu  
\q2 ibunaga mini yaraga haaboore holene nga.   
\c 112  
\s1 Wali agali bayale bu karume turu holene ngago ogo  
\q1
\v 1 Anduane Homogonaga mini yaraga holene nga.  
\q1 Mbirali ibu Anduane Homogo mitangi bialu mo dunini haga kago  
\q2 ibu turuore ho haga ka.  
\q1 Anduane Homogonaga bi mana talialu bulene hamelo haga kago  
\q2 ibu turuore ho ka.   
\q1
\v 2 Agali bayale biaga kagonaga waneiginiru  
\q2 ti wali agali maru bu karuha howa mini lene haga bulebira.  
\q1 Agali ogoninaga aguane holebiraru  
\q2 Ngode Datagaliwabehanda ti biamogo bialu bayale biaabo holebira.   
\q1
\v 3 Ibu damene ti muni mbiraleru dewawi howa  
\q2 ibu homogo bayale haabo holebira.   
\b  
\q1
\v 4 Arumaho ngagoha wali agali bayaleru\x + \xo 112.4 \xt Yob 11.17, Iba 97.11\x*  
\q2 biamogo bulenaga wá holene tagira ibaga.  
\q1 Wali agali mendeali dara howa biamogo biagabi  
\q2 maruhondo bayale biagabi tigatiga hangu biagabi  
\q2 ti kagoha wá haabo holebira.   
\q1
\v 5 Mbirali ibu mbirale dewawi kagome ibunaga mbirale ngaru  
\q2 maru karume dano helo turu howa miagabi  
\q2 ibunaga biyinaya birago tigabi hangu biagabi howa  
\q2 ibu turubiore haga ka.   
\q1
\v 6 Wali agali bayale biaga kago ibu pinale mini bilinahe kagola  
\q2 wali agali marume ibu embeda nahe mitangi bu haabo holebira.   
\b  
\q1
\v 7 Genda timbuni mbira yu anda ibira larago hale howa\x + \xo 112.7 \xt Iba 57.7, 64.10\x*  
\q2 ogoni ibugua gi nahe haga ka.  
\q1 Ibugua Anduane Homogohondo mini mbiraore hongo ho wu haga ka.   
\q1
\v 8 Ibugua mbirale biraru hondowa mogolalu gi nahaga ka.  
\q1 Waitigi ibirarume wai bialu wayali nahe  
\q2 bame degedane ibu de hondolebira.   
\q1
\v 9 Ibugua yagibano karuhondo mbirale dewa talebu miaga ka.\x + \xo 112.9 \xt 2 Ko 9.9\x*  
\q2 Ibugua wali agali maru dara howa biamogo biagago wiaaboore holebira.  
\q1 Ibu dindini mini lene mbira kagola  
\q2 wali agalime ibunaga mini yaraga halu holebira.   
\q1
\v 10 Wali agali ko biaga karume bayale biaga o biago hondowa  
\q2 ti keba ho holebira.  
\q1 Tigua wali agali bayale o biagobi handabe manga haragome  
\q2 mani tinibi mo ko holebira.  
\q1 Ko biaga karu ti mbirale bayale mo yule hamelo hayaruni  
\q2 nayi dege howa pu ereba holebira.   
\c 113  
\s1 Wali agalime Anduane Homogohanda tihondo bayale biyagonaga turu henego ogo  
\q1
\v 1 Anduane Homogonaga mini yaraga holene nga.  
\q1 Ibunaga biabe biahaga kamiru  
\q2 tígua Anduane Homogonaga mini yaraga hadaba.   
\q1
\v 2 Ibunaga mini áyubi manibi yaraga haaboore holene nga.   
\q1
\v 3 Ni tagira ibiragohayagi howabi ni paliragohayagi howabi  
\q2 wali agali bibahendeme Anduane Homogonaga mini yaraga holene nga.   
\q1
\v 4 Anduane Homogohanda hameigini tara tara dindi bibahendeni karu  
\q2 handayaho howa haru haame haga kagoni.  
\q1 Ibunaga wá holene hari daliga bolangua howa daligaorene daliga kagoni.   
\b  
\q1
\v 5 Mbirali Anduane Homogo inanaga Ngode Datagaliwabe ale mbira naheore.  
\q2 Ibu daligaorene daligaha kagoni.   
\q1
\v 6 Ibu de handadali halu  
\q2 hari daligabi dindibi handape haga kagoni.   
\q1
\v 7 Ibugua yagibano dindiha karu mo yaraga halu  
\q2 wali agali maru burupale karu ti gendayu karia  
\q2 mo heyu howa bayale helaga ka.   
\q1
\v 8 Ibugua wali agali urunibi mini lene helalu  
\q2 ibunaga wali agali haguane karu baba mandagi helo helaga biaga ka.   
\q1
\v 9 Wali waneigini nataba hanaga bedaru biamogo buwa  
\q2 ibugua wali urunibi turuore ho berelo waneigini dewaore miaga ka.  
\q1 Anduane Homogonaga mini yaraga hama.   
\c 114  
\s1 Isaraele wali agalime Iyibi dindi wahalu tagira piyangi iba gana lenego ogo  
\q1
\v 1 Bamba Isaraele wali agalime Iyibi dindi wahalu tagira pene.\x + \xo 114.1 \xt Har 12.51\x*  
\q1 Yagaba aguaneru ti dindi tarani howa wahalu tagira pene.   
\q1
\v 2 Ogonidagua piyangi Yuda wali agali ti Anduane Homogonaga helo dabo helene.  
\q2 Isaraele wali agali tibi nde ibunaga wali agaliore helene.   
\b  
\q1
\v 3 Iba solowara Daramabi bereagome de hondowa ibida pene.\x + \xo 114.3 \xt Har 14.21, Yos 3.16\x*  
\q2 Iba Yodana ibu ema bialu pu nabi berene.   
\q1
\v 4 Dindi hari timbuni wearume nogo memerume pogolama ibaga biradagua bialu  
\q2 hari emene wearume nogo sibi iginime pogo laradagua bini.   
\b  
\q1
\v 5 Iba solowara Daramabi-o í̠ agua biyane ibida piribe.  
\q2 Iba Yodana í̠bi nde agua biyagola pu nabi biraribe.   
\q1
\v 6 Hari timbuni wedemiru-o  
\q2 tígua nogo memerume pogolama ibaga biradagua bialu harimigo irane agibe.  
\q2 Hari emene wedemiru-o  
\q2 tíbi nogo sibi iginime pogo laradagua bialu harimigo aginagabe.   
\b  
\q1
\v 7 Dindi-o Anduane Homogo áyu o ibiragonigo  
\q2 í̠ gi howa duru lalu wia.  
\q1 Yagabanaga Ngode Datagaliwabe o ibiragoni hondowa  
\q2 í̠ duru lalu ema bialu wulene nga.   
\q1
\v 8 Ibugua ege to̱le̱ timbuni ngago mo iba hambiaga goriane berelalu\x + \xo 114.8 \xt Har 17.1-7, Dag 20.2-13\x*  
\q2 dindi hariha ege to̱le̱ timbuni kago mo iba timbuni pelaga kagoni.   
\c 115  
\s1 Ngode Datagaliwabe mbiraore howa ibuni hangu heneneore kagoni ogo  
\q1
\v 1 Anduane Homogo-o í̠na ina horo bibahendengi gubalini haho wiaaboore halu  
\q2 mini bilinahe howa ina yu wanahagaore kegoni.  
\q1 Í̠ aniore biaga kegonaga iname inanenaga mini mo yaraga holene nawiore.  
\q2 Iname í̠naga mini hanguore mo yaraga haabo holene nga.   
\b  
\q1
\v 2 Wali agali hameigini tara tara paluyu pedarume inahondo hale halu,  
\q1 Tínaga Ngode Datagaliwabe hayuagoni agoha kabe,  
\q2 lalu kagoni irane aginagadabe.   
\q1
\v 3 Inanaga Ngode Datagaliwabe ibu dahuliya andagani kagoni.  
\q2 Ibu hongo haihe howa  
\q2 ibuni mbirale mbira bule manda biyagua  
\q2 ta nabi biai habehe kagoni.   
\q1
\v 4 Wali agali tara tara karume muni ngolomebi silibamebi\x + \xo 115.4 \xt Iba 135.15-18, Yar 10.5, Mo 9.20\x*  
\q2 mbirale mbira gime wabuwa tinaga bi pupu wiagane uruni laga ka.  
\q1 Bame wali agali tini degeme wabu helene urunihondo  
\q2 tinaga bi pupu wiagane laga kagoni.   
\q1
\v 5 Mbirale gime wabini uruni  
\q2 ti ne hariga wia ngagoyu bi nalabehe.  
\q2 De kagoyu tinaga deme nahandabehe.   
\q1
\v 6 Tinaga hale kagoyu hale nahabehe.  
\q2 Ngui hariga ngagoyu nguime nga nahabehe.   
\q1
\v 7 Tinaga gi kagoyu ema bialu mbirale mbira ela nahabehe.  
\q2 Ge kagoyu ibaga bialu pobe nahe.  
\q2 Tinaga ne harigaha howa bi mbira latagi habe nahe kagoni.   
\q1
\v 8 Wali agali uruni wabiaga karumebi mo dunini haga karu tinibi  
\q2 mbirale tini wabini urunibi dege helo hame ledo.   
\b  
\q1
\v 9 Isaraele wali agali kamiru  
\q2 tí Anduane Homogohondo mini pagaho halimu.  
\q2 Ibugua tí biamogo bialu de handayaho haga kagoni.   
\q1
\v 10 Ngode Datagaliwabenaga \w loma\w* binigo mo miaga Arono aria kamiru  
\q2 tí Anduane Homogohondo mini pagaho halimu.  
\q2 Ibugua ti biamogo bialu de handayaho haga kagoni.   
\q1
\v 11 Wali agali ibu mitangi bialu lotu laga kamiru  
\q2 tí Anduane Homogohondo mini pagaho halimu.  
\q2 Ibugua ti biamogo bialu de handayaho haga kagoni.   
\b  
\q1
\v 12 Anduane Homogo ibugua ina mbirale burupale kama aleru mitangi bialu biamogo biaga kagoni.  
\q2 Ibugua Isaraele wali agalibi  
\q2 Ngode Datagaliwabenaga loma binigo mo miaga karu ariabi  
\q2 ibunime ti mo gumbila holebira.   
\q1
\v 13 Anduane Homogo ibugua wali agali emene timbunibi\x + \xo 115.13 \xt Mo 11.18, 19.5\x*  
\q2 ibu mitangi bialu ibu andaneha haga karu  
\q2 ibunime ti mo gumbila holebira.   
\b  
\q1
\v 14 Anduane Homogo ibugua tíhondo waneigini dewaore ngialu  
\q2 tinaga waneigini mani hama poraru tihondobi  
\q2 waneigini dewaore milo hamelo kogoni.   
\q1
\v 15 Anduane Homogo dindibi hari daligabi bibahende wabini kagome  
\q2 tí mo gumbilaore helo hamelo kogoni.   
\b  
\q1
\v 16 Hari daliga bibahende Anduane Homogo ibuni hangunaga ngagonigo  
\q2 ai dindi timbuni o ngagoni ina wali agali holoma̱yanaga ngini.   
\q1
\v 17 Wali agali homalu dinini humbirini andaga pugu biyagoni  
\q2 tigua humbirini andaga pu howa Anduane Homogonaga mini mo yaraga nahaga.   
\q1
\v 18 Ai ina wali agali dindini dére emabu kamaru  
\q2 iname Anduane Homogonaga mini mo yaraga halu ibuhondo ka̱i̱ lami̱ya.  
\q1 Áyu kamangibi manibi ka̱i̱ laaboore hami̱ya.  
\q1 Anduane Homogonaga mini mo yaragaore haabo holene nga.   
\c 116  
\s1 Homolene wiagoria howa gi miyagola yo pialu peneme Ngode Datagaliwabenaga mini yaraga henego ogo  
\q1
\v 1 I̱na Anduane Homogohondo bi larugo ibugua hale halu biaga kagonaga  
\q2 i̱na ibuhondo gubalini ho kogoni.  
\q2 I̱na ibuhondo bi larogo haleore haga ka.   
\q1
\v 2 I̱na ibu olarongi ta nabi haleore halu biaga ka.\x + \xo 116.2 \xt Iba 17.6, 40.1\x*  
\q2 Ibu ani biagagodago i̱ dére emabu kongi ibu olaho wiaabo holebero.   
\q1
\v 3 I̱ homoleneore gi biyagome mo dombe wia hayagola dombeneha haru.\x + \xo 116.3 \xt Iba 18.4-6\x*  
\q1 Homaliha horo heago hondowa homali hondowabi  
\q2 gi ogonibi dege biyagola haru.  
\q2 Miniha gi dege dindiho mini tumutumu bu ho wiru.   
\q1
\v 4 I̱ aniore howa nde i̱na Anduane Homogo olalu,  
\q1 Anduane Homogo-o homaore bidogo gi mia, lalu olaru.   
\b  
\q1
\v 5 Anduane Homogo ibugua i̱na dara nahabehego  
\q2 dara howa biamogo biagabi bayaore bigi biagabi ka.  
\q2 Inanaga Ngode Datagaliwabe ibu wali agali dara hagaore kagoni.   
\q1
\v 6 Wali agali ko hongo nahe paipai biadai bibe nahe karu  
\q2 Anduane Homogo ibugua ti biamogo biaga ka.  
\q2 I̱ homolene wiagoria hewaria ibugua i̱ gi miya.   
\q1
\v 7 Ai i̱ de dege dindiho naholebero.  
\q2 Miniha dungulo dai buwa bu ibira ho holebero.  
\q2 Anduane Homogohanda i̱hondo bayaore biyago manda bialu ani holebero.   
\b  
\q1
\v 8 Anduane Homogohanda i̱ homolene wiagoria hewaria  
\q2 gi mialu i̱naga de iba domaya.  
\q2 I̱ pilole hewaria ibugua i̱ gini yani ho haya.   
\q1
\v 9 Ibugua ani binigome ai áyu i̱ Anduane Homogonaga deni howa  
\q2 wali agali maru dére karu kadagua mandagi kamagoni.   
\q1
\v 10 I̱ homolene kawareore wiago hondowa\x + \xo 116.10 \xt 2 Ko 4.13\x*  
\q2 aiore nde homaruda manda buwa dege  
\q2 i̱na Anduane Homogohondo mini mbiraore wiaaboore haru.   
\q1
\v 11 Homolene giore halu  
\q2 wali agali bu harimaruni mbiraligomebi i̱ pele ngulenego mbira nahayuago, lalu  
\q2 hanguore i̱ homoleda manda buwa dege  
\q2 Anduane Homogohondo mini mbiraore wiaaboore haru.   
\b  
\q1
\v 12 Anduane Homogohanda i̱hondo bayale dege bima ibiyagonaga  
\q2 i̱na ibuhondo agi muledabe.   
\q1
\v 13 I̱ homoleore kaware hewaria gi miyagonaga ka̱i̱ lalu  
\q2 i̱na \w waini\w* iba lomabu mule ibu karia hambu yalu ibulebero.   
\q1
\v 14 Ibunaga wali agaliru mo mogobu biru ngagoria puwa  
\q2 i̱na ibuhondo mulebero lalu lowirugo miaore bulebero.   
\b  
\q1
\v 15 Anduane Homogo ibugua ibunaga wali agali mbirago homaga biragola\x + \xo 116.15 \xt Iba 72.14\x*  
\q2 ibu miniha tandaga haore biaga ka.   
\q1
\v 16 Anduane Homogo-o i̱ í̠naga biabe biahaga kogoni.  
\q2 I̱ ai̱yahanda í̠naga biabe biahalu bereneyadagua  
\q2 áyu i̱na í̠naga biabe biahalu ko.  
\q2 I̱ homoleore hewaria í̠na i̱ gini mialu bayale heledagoni.   
\q1
\v 17 I̱na í̠hondo ka̱i̱ore lalu mbirale mbira lomabu ngialu  
\q2 í̠hondo bi lolebero.   
\q1
\v 18-19 Yaruseleme í̠naga anda ngagoria anda puwa  
\q2 í̠naga wali agali bibahende íbu ngoai ho bedaria  
\q2 i̱na í̠hondo, Ngulebero, lalu lowirugo lomabu ngiaore bulebero.  
\q1 Anduane Homogonaga mini mo yaragaore holene nga.   
\c 117  
\s1 Anduane Homogonaga mini yaraga holene nga lenego ogo  
\q1
\v 1 Wali agali hameigini tara tara bu kamiru\x + \xo 117.1 \xt Lm 15.11\x*  
\q2 tí bibahendeme Anduane Homogonaga mini yaraga hadaba.  
\q1 Wali agali dindi tara tara bibahendeha bu kamiru  
\q2 tígua ibunaga mini yaraga hadaba.   
\q1
\v 2 Ibugua ina gubalini timbuniore ho haabo haga kagoni.  
\q2 Ibugua bi lowiyago habo nale mini bilinaho haabo haga kagoni.  
\q1 Iname ibunaga mini yaraga hama.   
\c 118  
\s1 Ngode Datagaliwabehanda biamogoore biyagonaga ibuhondo ka̱i̱ lenego ogo  
\q1
\v 1 Iname Anduane Homogohondo ka̱i̱ore lalu hami̱ya.\x + \xo 118.1 \xt 1 Bit 16.34, 2 Bit 5.13, 7.3, Esr 3.11, Iba 100.5, 106.1, 107.1, 136.1, Yar 33.11\x*  
\q1 Ibugua inahondo mana bayale hangu bigi biyagonaga ani lalu hami̱ya.  
\q2 Ibugua ina gubalini ho kago haho wiaaboore hole kagonaga  
\q2 ibuhondo ka̱i̱ore lalu hami̱ya.   
\q1
\v 2 Isaraele wali agali kamirume,  
\q1 Anduane Homogo ibugua horo bibahendengi  
\q2 ina gubalini ho kago haho wiaaboore haga kagoni, lalimulo hameledo.   
\q1
\v 3 Ngode Datagaliwabenaga \w loma\w* binigo mo miaga kamirume,  
\q1 Anduane Homogo ibugua horo bibahendengi  
\q2 ina gubalini ho kago haho wiaaboore haga kagoni, lalimulo hameledo.   
\q1
\v 4 Wali agali Anduane Homogo mitangi halu lotu laga kamirume,  
\q1 Anduane Homogo ibugua horo bibahendengi  
\q2 ina gubalini ho kago haho wiaaboore haga kagoni, lalimulo hameore ledo.   
\b  
\q1
\v 5 I̱ genda gibiore yu hewangi Anduane Homogo olarugola\x + \xo 118.5 \xt Iba 18.19, 120.1\x*  
\q2 ibugua hale halu i̱naga genda yu hewagoni mo wahalu i̱ golope hayagoni.   
\q1
\v 6 Anduane Homogo ibu i̱ heba hapara ho haabo haga kagonigo\x + \xo 118.6 \xt Iba 56.4, 56.11, Ais 51.12, Hi 13.6\x*  
\q2 i̱ gi naholebero.  
\q1 Wali agalime i̱hondo mbirale mbira agi bulubadabe.   
\q1
\v 7 I̱ biamogo biaga Anduane Homogo ibuni kagoni.  
\q1 Ibu ani kagome i̱naga waitigi karu Anduane Homogo ibugua bope haragola  
\q2 i̱ de hondolebero.   
\q1
\v 8 Wali agali tini dege dege hanaho holenego goyane lowa  
\q2 Anduane Homogoniore hanaho holenego duniniore nga.   
\q1
\v 9 Dindini haru haga karubi agali haguane karubi  
\q2 tini hanaho holenego goyane dege lowa  
\q2 Anduane Homogoni hanaho holenego duniniore nga.   
\b  
\q1
\v 10 I̱naga waitigi dewaoreme i̱ bole homabu bupe hearia  
\q2 Anduane Homogonaga hongome i̱na uruni bibahende bope hai haru.   
\q1
\v 11 Ti bibahendeme i̱ bole ho mabu bupe howa i̱ mo dombe wia hearia  
\q2 Anduane Homogonaga hongome i̱na uruni bibahende bope hai haru.   
\q1
\v 12 Mone tidu yalu ibiradagua waitigi bibahende tidu yalu ibuwa i̱ni mbulupe hayagoyu  
\q2 o biaruni irame gaeangi bo daradagua bialu bibahende bo mburi lai haya.  
\q1 Anduane Homogonaga hongome i̱na uruni bibahende bope hai haru.   
\q1
\v 13 Tigua i̱ bole anda ibalu mo ko howaore bayagola i̱ bope habehegoyu  
\q2 Anduane Homogo ibugua i̱ biamogo biya.   
\q1
\v 14 Anduane Homogo ibugua i̱ mo hongo helagaore ka.\x + \xo 118.14 \xt Har 15.2, Ais 12.2\x*  
\q2 Ibunime i̱ gi mialu biamogo biyagoni.   
\b  
\q1
\v 15 Ngode Datagaliwabenaga wali agali karume agali balu ibuwa  
\q2 tinaga balai anda tamuha tini wai mambolo baruago hale hadaba.  
\q1 Anduane Homogonaga hongo gibigome ina mo hongo hayagola  
\q2 bibahende bai harimagoniyago, lalu biraruago hale hadaba.   
\q1
\v 16 Anduane Homogonaga hongo gibi biagome ina biamogo biyagola  
\q2 ina wai bialu wayali harimagoni.   
\b  
\q1
\v 17 I̱ ala awane nahomolebero.  
\q2 Nahome howa dére emabu kongi  
\q2 Anduane Homogohanda bigi biyaru ogodagua biya lalu  
\q2 te laga bulebero.   
\q1
\v 18 Anduane Homogo ibugua i̱ mini wuliya mana lalu  
\q2 pani hiriribiore ngia nguwa i̱ bo home nalayagoni.   
\b  
\q1
\v 19 I̱ Anduane Homogonaga mini mo yaraga halu ibuhondo ka̱i̱ lo poleberogo  
\q2 ibunaga anda panga karuni dugupe hadaba.   
\b  
\q1
\v 20 Anduane Homogonaga anda anda pole panga haraba o kagoni.  
\q1 Wali agali mini tigabiwi karu hangume  
\q2 panga o duguaho ngagoniha anda pobehe ka.   
\q1
\v 21 Anduane Homogo-o í̠na i̱na bi larugo hale halu biamogo birigome  
\q2 i̱ wayali ho kogoni.  
\q1 Biamogo birigonaga i̱na í̠naga mini mo yaraga holebero.   
\b  
\q1
\v 22 Ege to̱le̱ mbira anda biagame galone nabibehedago lowa dabo wahenego\x + \xo 118.22 \xt Lg 20.17, Ab 4.11, 1 Pi 2.7\x*\x + \xo 118.22 \xt Md 21.42, Mg 12.10-11\x*  
\q2 ege to̱le̱ ogoniore mo timbuni duniniore ho heleda.   
\q1
\v 23 Ogoni Anduane Homogo ibunioreme mo yu daibu helenego  
\q2 iname de handalu handawa bu kamagoni.   
\q1
\v 24 Áyu ogoni Anduane Homogohanda inanaga waitigi bope hayagonaga  
\q2 iname ibuhondo turu gibiore halu bi te lalu mitangi biaabo hami̱ya.   
\q1
\v 25 Anduane Homogo-o ina gi mialu haru dai bia, larama.\x + \xo 118.25 \xt Md 21.9, Mg 11.9, Yo 12.13\x*  
\q1 Iname mbirale bigi beremago damene bibahendeore  
\q2 bayale halu lini daga bilo buluma̱ya  
\q2 Anduane Homogo-o biamogo bibe, larama.   
\b  
\q1
\v 26 Mbirali Anduane Homogonaga minini howa ibirago\x + \xo 118.26 \xt Md 21.9, 23.39, Mg 11.9, Lg 13.35, 19.38, Yo 12.13\x*  
\q2 Ngode Datagaliwabehanda ogoni ibuhondo turu halu bayale bilo larama.  
\q2 Anduane Homogonaga andani howa iname ibunaga mini mo yaraga harama.   
\q1
\v 27 Anduane Homogo ibu hangu Ngode Datagaliwabe heneneore kagoni.  
\q2 Ibugua ina baya hanguore de hondo hayagoni.  
\q1 Ira magane giha podo yagayaga bialu  
\q2 bo lomabu miaga dabu ngagoria pu mabu bidaba.   
\b  
\q1
\v 28 Í̠ i̱naga Ngode Datagaliwabe kegonigo  
\q2 i̱na í̠hondo ka̱i̱ore lalu ko.  
\q1 Í̠ i̱naga Ngode Datagaliwabe kegonigo  
\q2 i̱na í̠ timbuniore kego wali agali lamialu  
\q2 í̠naga miniore mo yaraga holebero.   
\b  
\q1
\v 29 Iname Anduane Homogohondo ka̱i̱ore lalu hami̱ya.  
\q2 Ibugua inahondo mana bayale hangu bigi biyagonaga ani lalu hami̱ya.  
\q2 Ibugua ina gubalini ho kago haho wiaaboore hole kagonaga  
\q2 ibuhondo ka̱i̱ore lalu hami̱ya.   
\c 119  
\s1 Anduane Homogonaga bi mana bayale lo ngago ogo  
\q1
\v 1 Wali agali tiha ko mbira nawiore howa tigatigaore ibaga bu karu\x + \xo 119.1 \xt Iba 128.1\x*  
\q2 ti turu ho haga ka.  
\q1 Tigua Anduane Homogonaga bi mana lo ngadagua bialu haga kago  
\q2 ti turuore haga kagoni.   
\q1
\v 2 Wali agali ti Anduane Homogohanda mana urubi bulene nga lene ngaru  
\q2 minime talialu bialu haga karu  
\q2 ti turuore ho haga ka.   
\q1
\v 3 Wali agali urunidagua biaga karu tigua mana ko ngaru nabiaga howa  
\q2 Anduane Homogonaga mana lo ngaru hangu biaga ka.   
\q1
\v 4 Anduane Homogo-o í̠nime inahondo í̠naga bi mana damenego langiai halu lalu,  
\q2 I̱naga bi uruni bayuwa taluwa biaabo halu halimu, larigoni.   
\q1
\v 5 I̱naore mini bilinahe howa í̠naga bi mana ogoni taluwa  
\q2 bialu haabo holenego hamelo ko.   
\q1
\v 6 I̱na í̠naga bi mana taluwa bialu haabo haruyagua  
\q2 i̱ha taga holene emeneorebi mbira nawulebira lo manda bido.   
\q1
\v 7 I̱na í̠naga mana bayale tigabi ngego manda bialu kongi  
\q2 i̱naga bu miniha ko mbira nawi howa  
\q2 í̠naga mini yaraga halu holebero.   
\q1
\v 8 Í̠naga bi mana debene bibahende ngeru taluwa bialu holebero.  
\q2 I̱na ani bialu holiyago í̠na i̱ yu wanahabe.   
\s1 Anduane Homogonaga bi mana lo ngadagua hale halu bulenego ogo  
\q1
\v 9 Wandari igiri daliaherume tini mo dodo nahe tigabiore agua habehebe.  
\q1 Í̠na ogo bibe lalu laga birigo hale halu bigi biyagua  
\q2 ti tigabi ogonibi holebira.   
\q1
\v 10 I̱naga gubalinioreme Anduane Homogo í̠naga biabe bule bialu ko.\x + \xo 119.10 \xt Iba 119.2, 119.21, 119.118, 119.145\x*  
\q2 Í̠naga bi mana lo ngego mbira i̱na puguligo haru habe.   
\q1
\v 11 I̱na í̠ deni ko mbira nabulenaga  
\q2 í̠naga bi mana lo ngegoni i̱naga gubalinini mo hengedo.   
\q1
\v 12 Anduane Homogo-o í̠naga mini mo yaraga harogo  
\q2 í̠naga hame ngego i̱hondo biawai habe.   
\q1
