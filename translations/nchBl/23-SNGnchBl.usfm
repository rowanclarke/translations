\id SNG
\h CANTARES
\toc1 Cantares
\toc2 CANTARES
\toc3 Cnt.
\mt1 Cantares
\c 1
\p 
\v 1 Ya ni nopa huicat cati más yejyectzi cati quicualtali Salomón.
\s1 Nopa achtohui huicat
\q1 
\v 2 \f + \fr 1:2 \ft Nopa ichpocat huica:\f* “Techtzoponisquía ica mocamac pampa más cuali motaicnelil que xocomecat iayo.
\v 3 Nelía ajhuiyac motaajhuiyacayo. Motoca nojquiya ajhuiyac quej se taajhuiyacayot pampa nochi quimatij tijchijtihualajtoc cati senquisa cuali. Yeca tahuel mitzicnelíaj nochi sihuame.
\v 4 Tanahuatijquet, techhuicasquía mohuaya. Techhuicasquía ipan mochaj.”
\q1 \f + \fr 1:4 \ft Sihuame ten Jerusalén huicaj:\f* “Tipaquij miyac para totanahuatijca. Itaicnelilis eltoc más cuali que xocomecat iayo. Yeca tahuel quiicnelíaj nochi sihuame ipan icaltanahuatil.”
\q1 
\v 5 \f + \fr 1:5 \ft Nopa ichpocat quinilhuía nopa sihuame:\f* “Ansihuame ten altepet Jerusalén, na niyayahuic, pero niyejyectzi. Nelía niyayahuic quej iniyoyoncalhua iixhuihua Cedar, pero niyejyectzi quej icortinas Salomón.
\q1 
\v 6 “Amo techcualancaitaca pampa niyayahuic pampa techtatijtoc tonati. Noicnihua cualanque ica na huan techtalijque para ma niquinmocuitahui xocomeca milme huan yeca amo huelqui nimomocuitahui na.”
\q1 
\v 7 \f + \fr 1:7 \ft Nopa ichpocat quicamanalhuía nopa telpocat masque yaya huejca itztoc:\f* “Techilhuisquía ta cati nimitzicnelía, ¿canque tiquinmocuitahuía moborregojhua? ¿Canque tiquinsiyajquetza ica tajcotona? Pampa amo quinamiqui nimocuapolojtinemis quej se nitacanenca sihuat huan fiero ninesis quema niajsis campa inintapiyalhua mohuampoyohua.”
\q1 
\v 8 \f + \fr 1:8 \ft Sihuame ten Jerusalén huicaj para nopa ichpocat:\f* “Sinta amo tijmati canque itztoc, ta cati más tiyejyectzi ten nochi yejyectzitzi sihuame, xiquintoquili iniicxihua nopa borregojme hasta campa itztoque nopa sequinoc tamocuitahuiani. Nopona xiquinmocuitahui moborregojhua campa quichijchijtoque inixajcal para tijmatis canque itztoc yaya cati tiquicnelía.”
\q1 
\v 9 \f + \fr 1:9 \ft Quema quipantijque nopa ichpocat, nopa telpocat quiijtohua:\f* “Ta cati nimitzicnelía, nimitzita para tahuel tiyejyectzi. Tiitztoc cati más yejyectzi ten nochi ichpocame quej icahuayo Faraón eltoc más cuali ten nochi cahuayojme huan quitilanaj icarro.
\v 10 Nelía yejyectzi mocampa. Huan mopijpilol achi más quinextía moyejca. Moquechcuayo nesi yejyectzi ica nopa costi cati timotalilijtoc ica nopa piltetzitzi cati nelcuajcualtzi.
\v 11 Timitzchihuilise pijpiloli cati tahuel yejyectzi ica oro huan campa hueli tijtatzquiltilise plata para timotalilis.”
\q1 
\v 12 \f + \fr 1:12 \ft Nopa ichpocat moilhuía ten nopa tanahuatijquet huan quiijtohua:\f* “Quema nopa tanahuatijquet noja mosehuijtoya campa imesa, notaajhuiyacayo ten nardo mijyotiyaya yejyectzi huan tamahuayaya campa hueli.
\v 13 Para na, yaya cati niquicnelía eltoc quej se quechti ten nopa taajhuiyacayot mirra cati nochipa huiyontoc noyolixco.
\v 14 Itztoc quej se tzonti nopa xochit ten alheña ten nopa xochimili ipan altepet En Gadi.”
\q1 
\v 15 \f + \fr 1:15 \ft Nopa telpocat quiijtohua:\f* “Tahuel tipilyejyectzi, ta cati nimitzicnelía. Quena, tahuel tiyejyectzi. Moixteyolhua nesi quej ome pilpalomajtzitzi.”
\q1 
\v 16 \f + \fr 1:16 \ft Nopa ichpocat quiijtohua:\f* “Nelía tiyejyectzi ta cati na nimitzicnelía. Quena, nelía ticuali.”
\q1 \f + \fr 1:16 \ft Nopa telpocat quiijtohua:\f* “Yejyectzi campa timotecaj para timosiyajquetzaj ipan ni sacapetat cati xoxohuic.
\v 17 Ni tiocuame eltoc quej nopa cuatetomit ten tochaj huan nopa tapamit eltoc ni cuame ten ciprés.”
\c 2
\q1 
\v 1 \f + \fr 2:1 \ft Nopa ichpocat quiijtohua:\f* “Na niitztoc quej se xochit ten Sarón. Quena, niitztoc quej nopa xochit lirio cati onca ipan tamayamit.”
\q1 
\v 2 \f + \fr 2:2 \ft Nopa telpocat quiijtohua:\f* “Quema ta cati nimitzicnelía timopantía inihuaya sequinoc ichpocame, tiitztoc quej se xochit lirio cati mopantía campa huitzti.”
\q1 
\v 3 \f + \fr 2:3 \ft Nopa ichpocat quiijtohua:\f* “Quema ta cati nimitzicnelía timopantía tatajco sequinoc tacame, tiitztoc quej se manzana cuahuit cati mopantía inihuaya sequinoc cuame. Nelía techpactía nimosehuis itantita nopa manzana cuahuit para ma techecahuili. Huan nelía tzopelic nijmachilía itajca.
\v 4 Ta techhuicac ipan mochaj cati yejyectzi campa onca nochi cati cuali para ma nijcua hasta niixhuis. Nopona techtachili ica motaicnelijcayo para nochi quimatise techicnelía.
\v 5 Techfuerzajmaca ica tortas ten xocomecat itajca cati huactoc huan techtamaca ica manzanas pampa tahuel nijnequi motaicnelilis.
\v 6 Xijtali momaarraves tatzinta ten notzonteco huan ica momanejmat technajnahua.”
\q1 
\v 7 \f + \fr 2:7 \ft Nopa telpocat quincamanalhuía nopa sihuame ipan ichaj:\f* “Ansihuame ten altepet Jerusalén, xiquintestigojquetzaca nopa masame huan cuachacaltzitzi cati nemij cuatita para amo anquicochsosolose nopa ichpocat cati niquicnelía. Xijcahuaca ma cochi hasta quema yaya quinequis isas.”
\s1 Nopa ompa huicat
\q1 
\v 8 \f + \fr 2:8 \ft Nopa ichpocat huica para cati quiijtantoc:\f* “Ya huala yaya cati niquicnelía. Xiquitaca, ya huala. Nijcaqui para huitontihuala ipan cuatitamit huan campa tepeme.
\v 9 Yaya cati niquicnelía itztoc quej se oquich masat o se oquich cuachacaltzi. Xiquitaca, ya ajsico huan moquetztoc nocalixpa. Hualtachixtoc ipan noventana.
\q1 
\v 10 “Huan yaya techilhui: ‘Ximijquehua ta cati nimitzicnelía, ta cati tipilyejyectzi huan ma tiyaca.
\v 11 Ya panoc tonali quema tahuel taseseya huan ayecmo taquiyahui.
\v 12 Nochi xochime ya cahuanij ipan cuatitamit. Ya ajsic tonali para huicase pilpalomajtzitzi. Quena, ya ajsic tonali para tatotoniyas.
\v 13 Nopa higuera cuahuit ya quipixtoc itajca huan nopa xocomeca milme ya xochiyohuaj huan ajhuiyac mijyotíaj. Huajca ximijquehua ta cati nimitzicnelía, ta cati tahuel tiyejyectzi huan ma tiyaca.’ ”
\q1 
\v 14 \f + \fr 2:14 \ft Nopa telpocat quiijtohua:\f* “Tinopaloma cati timotatía ipan nopa teme cati huejhueyi huan campa mahuilili. Techcahuili ma niquita moxayac. Techcahuili ma nijcaqui motoscac cati eltoc quej nijcuasquía se tatzopelcayot. Quena, tahuel techpactía nijcaquis motoscac huan niquitas moxayac.”
\q1 
\v 15 \f + \fr 2:15 \ft Nopa telpocat huan nopa ichpocat huicaj:\f* “Xiquinmasiltica nopa cayochime cati pisiltzitzi cati quisosolohuaj toxocomecamil pampa toxocomecamil ya xochiyohua. Ma amo teno quisosolo totaicnelijcayo se ica seyoc.”
\q1 
\v 16 \f + \fr 2:16 \ft Nopa ichpocat quiijtohua:\f* “Nijmati yaya cati niquicnelía noaxca huan na niiaxca ya. Yaya quinmocuitahuía iborregojhua campa onca miyac xochit ten lirios.
\v 17 Xihuala ta cati nimitzicnelía huan ximocahua hasta tanesis huan mijcuenis tzintayohuilot, xihuala ta cati nimitzicnelía. Xiitzto quej se oquich masat o se oquich cuachacaltzi cati motalohua ipan tepeme.”
\c 3
\q1 
\v 1 \f + \fr 3:1 \ft Nopa ichpocat temiqui para quitemohua nopa telpocat:\f* “Ica tayohua nijtemo ipan notapech yaya cati techicnelía. Nijtemo, pero amo nijpanti.
\v 2 Huajca nijmatqui nimijquejqui huan nijtemojtiyajqui ipan nochi nopa altepet. Nijtemo yaya cati niquicnelía ipan nochi calles huan campa tianquis. Nijtemo, pero amo nijpanti.
\v 3 Huajca niquintatzintoquili nopa tacame cati quimocuitahuíaj nopa altepet huan niquinilhui: ‘¿Amo anquiitztoque yaya cati niquicnelía?’
\v 4 Huan sanoc nipanotoya campa nopa tamocuitahuiani huan nijpanti yaya cati niquicnelía. Huajca niquitzqui ipan imax huan ayecmo nijmalacani huan nijcalaquito ipan ichaj nonana.
\q1 
\v 5 “Ansihuame ten altepet Jerusalén, xiquintestigojquetzaca nopa masame huan cuachacaltzitzi cati nemij cuatita para amo anquicochsosolose nopa telpocat cati niquicnelía. Xijcahuaca ma cochi hasta quema yaya quinequis isas.”
\s1 Nopa expa huicat
\q1 
\v 6 \f + \fr 3:6 \ft Sihuame ten Jerusalén huicaj:\f* “¿Ajquiya ne cati huala ipan huactoc tali cati nejnentihuala tatajco pocti cati moquetztoc? Motalilijtoc miyac tamanti taajhuiyacayot ihuaya mirra huan copali.
\v 7 Xiquitaca. Ya ne icuacarro Salomón. Quiyahualojtihualahui 60 soldados cati más yolchicahuaque huan más tapejpenilme ten tali Israel.
\v 8 Quinmachtijtoque nochi inijuanti cati quihualicaj machetas quenicatza tatehuise. Sesen ten inijuanti motzinquechilpitoc imacheta para momanahuise ica tayohua quema mahuilili.
\q1 
\v 9 “Nopa Tanahuatijquet Salomón mochihuili nopa cuacarro ica nopa cuame cati más cuajcualtzi ten tali Líbano.
\v 10 Nopa taquetzalme ipan icuacarro quichijchijqui ten plata huan icuitapantetonijca ica oro. Campa mosehuía quitali yoyomit cati moradojtic. Huan nochi calijtic ipan nopa cuacarro quipiya se yoyomit tahuel yejyectzi cati nopa sihuame ten altepet Jerusalén quichihuilijque ica inintaicnelijcayo.”
\q1 
\v 11 \f + \fr 3:11 \ft Nopa ichpocat quiijtohua:\f* “Ansihuame ten altepet Jerusalén\f + \fr 3:11 \ft 3:11 O Sion.\f*, xipanquisaca huan xijtachiliquij ne Tanahuatijquet Salomón. Yaya quihuica ipan itzonteco nopa corona cati inana quichijchihuili para ma quitequihuis ipan ni tonali quema mosihuajtis. Ni tonali elis quema más quipiyas paquilisti.”
\c 4
\q1 
\v 1 \f + \fr 4:1 \ft Nopa telpocat quiijtohua:\f* “Nelía tiyejyectzi ta cati nimitzicnelía. Tahuel tiyejyectzi. Moixteyolhua nesi quej ome palomajme cati motatijtoque iica moixtzajca. Motzoncal eltoc yejyectzi quej chivojme cati mahuiltíaj ipan nopa cuatitamit ten tali Galaad.
\v 2 Motancochhua eltoc nelchipahuac quej iniijhuiyo nopa borregojme cati yancuic quinxintoque huan quipajpactoque. Eltoc senquisa cuali huan ajsitoc. Sesen ten inijuanti quipiya iixnamic huan yon se amo mopantía iseltitzi.
\v 3 Motenxipal nelía chichiltic quej icpat cati chichiltic. Mocamac tahuel yejyectzi. Mocampa nesi quej quitajcotejque se granada huan quitalijtoque ipan sesen lado para motatise iica moixtzajca.
\v 4 Moquechcuayo eltoc quej nopa huejcapantic torre cati nelía cuali quichijchijqui David para ipan quiajocuise tatehuijca teposme. Nopona quicuapilojtoque mil tepostzajcayome cati iniaxca itequipanojcahua cati más mosemacayayaj tatehuise.
\v 5 Nopa ome mochichijhua eltoc quej ome cuachacaltzitzi cati cuateme cati tacuajtinemij campa onca nopa xochit lirio.
\v 6 Na niixtejcos ipan nopa tepet campa onca mirra huan nopa tachiquili campa onca copali hasta tanesis cuali huan ya panotos tzintayohuilot.
\v 7 Nelía tiyejyectzi, ta cati nimitzicnelía. Tiyejyectzi ten moicxihua hasta ipan motzonteco. Huan amo onca yon se tamanti cati amo cuali ipan ta.
\q1 
\v 8 “Xihuala nohuaya, tinosihua. Xihuala nohuaya ten tali Líbano. Xitemo ten nopa tepet Amana huan tepet Senir huan tepet Hermón. Xitemo ten nopa cuatitamit campa onca leones huan leopardos. Xihuala nohuaya.
\v 9 Techichtequili noyolo, tinosihua, ta cati nimitzicnelía. Techichtequili san ica motachiyalis huan ica nopa costi cati timotalilijtoc moquechta.
\v 10 Nelía techpactía motaicnelijcayo, tinosihua, ta cati nimitzicnelía. Nelía tzopelic motaicnelijcayo hasta quipano nopa xocomecat iayo. Motaajhuiyacayo noja más ajhuiyac que nochi sequinoc taajhuiyacayome.
\v 11 Tinosihua, motenxipal nelía tzopelic quej necti. Huan tatzinta ten monenepil quisa necti huan lechi. Huan moyoyo mijyotía ajhuiyac quej nopa cuatitamit huan tiocuame ten tali Líbano.
\q1 
\v 12 “Tinosihua, tiitztoc quej se xochimili cati cuali tatzacti san para na. Tiitztoc quej se ameli cati cuali tzactoc huan quej se ameyalot cati san na noaxca.
\v 13 Tiitztoc quej se yejyectzi xochimili campa chamani nopa granada huan temaca itajca cati ajhuiyac para ma nijcua. Tiitztoc quej se cuamili ten alheña huan sequinoc tatzopelcayot cati más ajhuiyac,
\v 14 quej nardo huan azafrán, ohuat cati mijyotía ajhuiyac huan canela, huan nochi tamanti cuame cati temaca copali, mirra huan áloes. Nochi cati más ajhuiyac nijpantía ipan ta.
\v 15 Ta tiitztoc quej se ameli campa meya tahuel miyac at para quiatequis nopa xochimili. Tiitztoc quej se ameli cati temaca at cati cuali huan quimaca yancuic nemilisti cati quiis. Techseseltía quej nopa at ten nopa pilatajtzitzi cati meya ipan tali Líbano.”
\q1 
\v 16 \f + \fr 4:16 \ft Nopa ichpocat quiijtohua:\f* “Ma pehua ajaca nopa ajacat cati huala ica ajco huan nopa ajacat cati huala ica tatzinta. Ma tailpitzaquij ipan noxochimil. Ma quichihuaca ma momoyahua iajhuiyaca notacayo para quinotzas yaya cati niquicnelía ma huala huan ma quicua cati más tzopelic ten itajca.”
\c 5
\q1 
\v 1 \f + \fr 5:1 \ft Nopa telpocat quiijtohua:\f* “Nica niitztoc. Nosihua, na niquita motacayo quej noxochimil cati san para na. Ta cati más niquicnelía huan nijpatiita. Se paquilisti para nijcuis notaajhuiyacayo ten mirra huan ten nochi sequinoc taajhuiyacayome cati nica nijpantía. Nijyecohua nopa necti ten na nosayolhua, huan niqui nopa xocomecat iayo huan nopa lechi cati noaxca.” \f + \fr 5:1 \ft Nopa sihuame ten Jerusalén quiijtohuaj:\f*
\q1 “Antohuampoyohua cati anmoicnelíaj, xitacuaca huan xiquica nochi cati anquinequij se ica seyoc.”
\s1 Nopa najpa huicat
\q1 
\v 2 \f + \fr 5:2 \ft Nopa ichpocat huica ten itemic:\f* “Se tayohua na nicochtoya, pero noyolo amo cochtoya. Huan nijcochcajqui para yaya cati niquicnelía techtzajtziliyaya ipan caltemit, huan techilhuiyaya: ‘Techcaltapo, ta cati nimitzicnelía, tinopaloma cati más yejyectzi, ta cati más niquicnelía huan nijpatiita. Notzonteco huan notzoncal xolontoc ica nopa ajhuechti cati huetzi tayohua.’
\q1 
\v 3 “Pero na niquilhui: ‘Na ya nimoquixtili noyoyo, huajca monequis sempa nimoyoyontis. Ya nimoicxipajpajqui, huajca ¿tijnequi ma niquinsoquihui sempa?’
\q1 
\v 4 “Pero yaya cati techicnelía quicalaqui imax para caltapos huan ya nopa tahuel techyoltacani.
\v 5 Huajca nimoquetzqui para nijcaltapos yaya cati niquicnelía. Huan ipan nomax huan nomacpilhua chipiniyaya taajhuiyacayot ten mirra hasta motalo ipan nopa teposti cati ica tijtzacuaj nopa caltemit.
\v 6 Huan quema nijcaltapo cati niquicnelía, yaya ayecmo itztoya. Huajca nijmachili para nimiquis. Teipa nijtemo, pero amo nijpanti. Nijtzajtzili, pero amo technanquili.
\v 7 Huan techpantijque nopa tacame cati quimocuitahuíaj nopa altepet huan techhuitejque huan techcocojque pampa amo quimachilijque para ten ninemiyaya tayohua. Huan nopa tacame cati quimocuitahuiyayaj nopa caltemit techcuilijque noyoyo cati ica nimopictoya.”
\q1 
\v 8 \f + \fr 5:8 \ft Nopa ichpocat quinilhuía nopa sihuame:\f* “Ansihuame ten altepet Jerusalén, sinta anquipantíaj yaya cati niquicnelía, xiquilhuica para nijmati nimococohua pampa tahuel nijnequi itaicnelil.”
\q1 
\v 9 \f + \fr 5:9 \ft Sihuame ten Jerusalén quiijtohuaj:\f* “Ta tisihuat cati más tinelyejyectzi ten nochi sihuame, techilhui ¿taya más quipiya yaya cati tiquicnelía cati sequinoc amo quipiyaj para techilhuía ya ni?”
\q1 
\v 10 \f + \fr 5:10 \ft Nopa ichpocat quihueyitalía ihuehue, quiijtohua:\f* “Cati niquicnelía yaya chipactic huan san yaya cati más yejyectzi ten majtacti mil tacame.
\v 11 Itzonteco nesi quej senquisa oro, huan itzoncal ijilacatztic huan yayahuic quej iijhuiyo nopa cacalot.
\v 12 Iixteyol nesi quej ome pilpalomajtzitzi cati moquetztoque iteno se hueyat huan maltíaj ipan lechi. Tahuel yejyectzi iixteyol quej piltetzitzi cati quinquetztoque ipan itencuayo.
\v 13 Icampa eltoque quej xochime cati ajhuiyac mijyotíaj, huan itenxipal nesi quej se xochit lirio campa quisa taajhuiyacayot ten mirra.
\v 14 Iajcolhua eltoque quej teposti ten oro cati quiyejyecchijtoque ica piltetzitzi cati itoca topacio. Huan itacayo eltoc quej marfil cati quicualchijchijtoque ica zafiros.
\v 15 Imetz eltoc quej nopa taquetzali ten mármol cati moquetztoc ipan senquisa oro. Quipiya fuerza quej nopa cuatitamit ten tali Líbano. Amo aqui seyoc quej ya.
\v 16 Nelía tzopelic icamac. Nochi ten ya senquisa cuali. Ansihuame ten altepet Jerusalén, quej nopa yaya cati niquicnelía. Yaya cati nohuampo.”
\c 6
\q1 
\v 1 \f + \fr 6:1 \ft Sihuame ten Jerusalén quiijtohuaj:\f* “Ta cati más tiyejyectzi ten nochi sihuame, ¿canque yajqui yaya cati tiquicnelía? ¿Canque mocajqui yaya cati tiquicnelía? Tojuanti tiyase mohuaya tijtemotij.”
\q1 
\v 2 \f + \fr 6:2 \ft Nopa ichpocat huica:\f* “Yaya cati niquicnelía yajtoc campa ixochimil campa nochi taajhuiyaxtoc. Yajqui quintamacato iborregojhua huan quitequito xochit.
\v 3 Na niiaxca ya cati techicnelía huan yaya noaxca na. Yaya quintamaca iborregojhua campa nopa xochimili ten lirios.”
\s1 Nopa macuilpa huicat
\q1 
\v 4 \f + \fr 6:4 \ft Nopa telpocat quiijtohua:\f* “Ta cati nimitzicnelía, nelía tiyejyectzi quej nopa altepet Tirsa. Quena, tinelyejyectzi quej altepet Jerusalén. Tahuel techyoltilana para ma nimitzsentachilijto quej soldados cati yahuij para tatehuitij.
\v 5 Ayecmo techtachili pampa moixteyolhua techtantoque. Motzoncal eltoc quej nopa chivojme cati mahuiltíaj ipan nopa cuatitamit ten tali Galaad.
\v 6 Motancochhua nochi eltoc cuali. Sesen motancoch quipiya ihuical huan yon se amo polihui. Eltoque chipahuaque quej nopa borregojme cati ya maltijtoque huan yahuij para quinximase.
\v 7 Mocampa chichiltic quej se granada cati motajcoitztoc. Quena, nelía ajhuiyac mocampa cati tijtatijtoc itantita moixtzajca.
\v 8 Masque nihuelisquía nijtapejpenisquía ten 60 sihua tanahuatiani, o 80 noompa sihuajhua o tahuel miyac ichpocame,
\v 9 san ta nimitztapejpenisquía, ta tinopaloma. San ta tiiyojtzi ten nochi sihuame nijnequisquía, ta cati tieltoc quej tiiyojtzi cone monana. Quema mitzitaque nopa ichpocame ten altepet Jerusalén san mitztachilijque. Nojquiya nopa sihua tanahuatiani huan nopa ompa sihuame mitzhueyimatque. Quiijtojque:
\v 10 ‘¿Ajquiya ne cati monextía quej nopa tonati cati pejtoc quisa ica ijnaloc? Nelía yejyectzi quej nopa metzti cati noja monextía ipan ilhuicac. Teipa hualpetani quej itaahuil ne tonati. Tahuel techyoltilana para ma nijsentachilijto quej soldados cati yahuij para tatehuitij.’
\q1 
\v 11 “Na niyajqui campa nopa cuamili ten nueces para niquitas sinta taxoxohuiya ipan nopa tamayamit. Nijnejqui niquinitas sinta chamaniyayaj nopa xocomeca milme huan sinta ya quistoc ixochiyo nopa granadas.
\v 12 Teipa ayecmo nijmatqui taya panoc huan nimomacac cuenta para niyahuiyaya ipan notepos cahuayo cati nomasehualhua quipixtoyaj para niinintanahuatijca.”
\q1 
\v 13 \f + \fr 6:13 \ft Sihuame ten Jerusalén quiijtohuaj:\f* “Ximocuepa, tisulamita ichpocat, ximocuepa. Ximocuepa pampa tijnequij timitzitase.”
\q1 \f + \fr 6:13 \ft Nopa telpocat quiijtohua:\f* “¿Para ten anquinequij anquiitase ne sulamita?”
\q1 \f + \fr 6:13 \ft Sihuame ten Jerusalén quiijtohuaj:\f* “Tijnequij tiquitase quenicatza yejyectzi mijtotía.”
\c 7
\q1 
\v 1 \f + \fr 7:1 \ft Nopa telpocat quiijtohua:\f* “Nelía yejyectzi nesi moicxihua ipan motecac, ta tiichpocat cati nimitzicnelía. Quinamiqui tiitztos ipan ichaj se tanahuatijquet. Motzinquechta nesi quej se tacualnescayot cati quichijchijtoque ica cati senquisa oro. Nesi quej quicualtali se cati nelía quimati.
\v 2 Moxic nesi quej se taza cati nochipa temitoc ica xocomecat iayo. Moijti nesi quej se tamontomit ten trigo cati quiyahualojtoque ica xochit.
\v 3 Mochichijhua nesij quej ome cuachacaltzitzi cati cuateme.
\v 4 Moquechcuayo nesi quej se torre huejcapantic ten marfil. Moixteyolhua cahuanij quej nopa ome piletas cati eltoc ipan altepet Hesbón, nechca nopa caltemit Bat Rabim. Moyacatzol eltoc quej nopa torre huejcapantic ipan tali Líbano cati tachixtoc ica campa altepet Damasco.
\v 5 Motzonteco nesi yejyectzi quej nopa tepet Carmelo. Motzoncal nesi quej icpat cati chichiltic. Ica motzoncal cati tijxinepalojtoc techmasiltijtoc na, nitanahuatijquet.
\q1 
\v 6 “Ta cati nimitzicnelía, nelía tiyejyectzi huan nelía techpactía motaicnelil.
\v 7 Timoquetza yejyectzi quej se epachi cuahuit huan mochichijhua eltoque quej ome quechti ten itajca xocomecat.
\v 8 Na nimoilhui: ‘Nitejcos ipan ne apachij cuahuit huan nimoaxcatis itajca. Huajca mochichijhua elise quej itajca apachi cuahuit huan moijyoyo mijyotis quej manzanas cati ajhuiyac.
\v 9 Mocamac nelía tzopelic quej nopa xocomecat iayo cati más ajhuiyac cati hualtemo ipan motenxipal huan motancoch.’ ”
\q1 
\v 10 \f + \fr 7:10 \ft Nopa ichpocat quiijtohua:\f* “Na niiaxca yaya cati techicnelía, huan yaya tahuel quinequi itztos nohuaya.
\v 11 Xihuala nohuaya ta cati nimitzicnelía. Ma tiyaca campa cuatitamit. Ma titonilitij campa onca miyac xochit ten alheña.
\v 12 Ica ijnaloc tiyase campa toxocomeca milhua para tiquitase sinta ya quipixtoc itajca. Tiquitase sinta ya xochiyohua nopa granada. Huan nopona na nimitzmacas notaicnelijcayo.
\v 13 Nopa mandrágoras mijyotía yejyectzi huan techfuerzajmacase. Huelis tijchihuase ten hueli tamanti cati tijnequise pampa miyac tamanti cuatacti mochiya. Huelis tijchihuase cati yancuic o cati ya ipa tijchijtoque. Nochi cati cuali nicajoctoc para ta cati nimitzicnelía.”
\c 8
\q1 
\v 1 \f + \fr 8:1 \ft Nopa ichpocat quiijtohua:\f* “Nelía cuali sinta tieltosquía tinoicni cati quichichitijtosquía nonana. Quej nopa, quema nimitzpantisquía campa hueli nimitztzoponisquía huan amo aqui techpinajtisquía.
\v 2 Huan na nimitzhuicasquía huan nimitzcalaquisquía ichaj nonana huan ta techmachtisquía. Huan na nimitzmacasquía nopa xocomecat iayo cati quipiya taajhuiyacayot. Huan nimitzmacasquía iayo nogranadas cati más tzopelic.
\v 3 Huan momaarraves tijtalisquía tatzinta ten notzonteco huan ica momanejmat technajnahuasquía.”
\q1 
\v 4 \f + \fr 8:4 \ft Nopa ichpocat quincamanalhuía nopa sihuame:\f* “Ansihuame ten altepet Jerusalén, nimechilhuía amo xijcochsosoloca cati niquicnelía. Xijcahuaca ma cochi hasta quema yaya quinequis isas.”
\s1 Nopa chicuasempa huicat
\q1 
\v 5 \f + \fr 8:5 \ft Nopa sihuame ten Jerusalén quiijtohuaj:\f* “¿Ajquiya ne cati motatzquilijtihuala iajcoltipa yaya cati quiicnelía?”
\q1 \f + \fr 8:5 \ft Nopa ichpocat quiijtohua:\f* “Na nimitzixiti itzala se manzana cuahuit campa monana quipixqui tacuajcualocayot quema mitztacatilti.
\v 6 Techtatzquilti ipan moyolo quej se sello huan techhuica nochipa ipan moajcol quej se tanextilijcayot para techicnelía. Pampa nelía chicahuac nopa taicnelijcayot cati nijmachilía huan eltoc quej miquilisti pampa amo hueli nijtzacuilis. Tahuel nimitznequi huan nopa taicnelijcayot eltoc quej se tit cati cahuani ixochiyo pampa tahuel tata.
\v 7 Masque quitequilisquíaj tahuel miyac at amo huelis quisehuise nopa tilelemecti ten taicnelijcayot. Yon amo huelis quisehuise masque hualasquíaj ipani nochi pilatajtzitzi. Huan sinta se tacat quinequisquía quicohuas nopa taicnelijcayot cati nijmachilía huan techtaxtahuisquía ica nochi iricojyo cati quipiya, amo quiaxilisquía huan san nijpinahualtisquía.”
\q1 
\v 8 \f + \fr 8:8 \ft Iicnihua nopa ichpocat quiijtohuaj:\f* “Tijpiyaj se tosihua icni cati noja pisiltzi. Ayemo chichihualquisa. Huajca ¿taya tijchihuase sinta hualase quiijtaniquij?
\v 9 Sinta yaya momocuitahuía ica telpocame, huajca tijfuerzajmacase. Sinta yaya quinselía telpocame, tijyahualose ica huapalme ten tiocuahuit para amo huelis quiajsise.”
\q1 
\v 10 \f + \fr 8:10 \ft Nopa ichpocat quiijtohua:\f* “Na nimomocuitahuijtoc huan ama nijpiya nochichijhua quej torres cati huejcapantique. Huan yeca yaya cati techicnelía paqui ica na.
\q1 
\v 11 “Salomón, tijpixqui se xocomeca mili ipan Baal Hamón cati tiquincahuili sequinoc ma quimocuitahuica ica se taxtahuili. Huan quema ajsiyaya tonali para quitequise itajca, sesen ten inijuanti mitzmacaj mil plata tomi.
\v 12 Pero ica nopa xocomeca mili cati noaxca na, nica eltoc ni mil plata tomi cati nijpiya, nochi eltoc para ta Salomón. Huan nopa 200 plata tomi ya niquinmacac nopa tacame cati quimocuitahuiyayaj.”
\q1 
\v 13 \f + \fr 8:13 \ft Nopa telpocat quiijtohua:\f* “Ta cati nimitzicnelía, ta cati tiitztoc ipan xocomeca milme, nochi mohuampoyohua quipajcacaquij motoscac pampa tahuel yejyectzi. Huan na nojquiya techcahuili ma nijcaqui.”
\q1 
\v 14 \f + \fr 8:14 \ft Nopa ichpocat quiijtohua:\f* “Ximoisihuilti ta cati nimitzicnelía. Ximotalojtihuala quej se hueyi masat o quej se cuachacaltzi ipan nopa cuatitamit cati temitoc ica taajhuiyacayot.”
