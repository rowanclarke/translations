\id ZEP
\h Knjiga proroka Sofonije
\toc1 Knjiga proroka Sofonije
\toc2 Sofonija
\toc3 Sof
\mt1 Knjiga proroka Sofonije
\c 1
\s1 Dan gneva.
\p 
\v 1 Reč Gospodnja koja dođe Sofoniji, sinu Husija sina Godolije sina Amarije sina Jezekijinog, za vremena Josije, sina Amonovog, cara Judinog.
\b
\q1 
\v 2 Sve ću uzeti sa zemlje,
\q2 govori Gospod;
\q1 
\v 3 Uzeću ljude i stoku,
\q2 uzeću ptice nebeske i ribe morske
\q2 i sablazni s bezbožnicima,
\q1 i istrebiću ljude sa zemlje,
\q2 govori Gospod.
\q1 
\v 4 Jer ću mahnuti rukom svojom na Judu
\q2 i na sve stanovnike jerusalimske,
\q1 i istrebiću iz mesta ovog ostatak Valov
\q2 i ime sveštenika idolskih s drugim sveštenicima,
\q1 
\v 5 I one koji se klanjaju na krovovima vojsci nebeskoj
\q2 i koji se klanjaju i kunu se Gospodom
\q2 i koji se kunu Melhomom.
\q1 
\v 6 I one koji se odvraćaju od Gospoda
\q2 i koji ne traže Gospoda niti pitaju za Nj.
\b
\q1 
\v 7 Ćuti pred Gospodom Gospodom,
\q2 jer je blizu dan Gospodnji,
\q1 jer je Gospod prigotovio žrtvu
\q2 i pozvao svoje zvanice.
\q1 
\v 8 I u dan žrtve Gospodnje
\q2 pohodiću knezove i carske sinove i sve koji nose tuđinsko odelo.
\q1 
\v 9 I pohodiću u taj dan sve koji skaču preko praga,
\q2 koji pune kuću gospodara svojih grabežom i prevarom.
\b
\q1 
\v 10 I u taj će dan, veli Gospod,
\q2 biti vika od ribljih vrata,
\q1 i jauk s druge strane,
\q2 i polom velik s humova.
\q1 
\v 11 Ridajte koji živite u Maktesu,
\q2 jer izgibe sav narod trgovački,
\q2 istrebiše se svi koji nose srebro.
\q1 
\v 12 I u to ću vreme razgledati Jerusalim sa žišcima,
\q2 i pohodiću ljude koji leže na svojoj droždini,
\q1 koji govore u srcu svom:
\q2 Gospod ne čini ni dobro ni zlo.
\q1 
\v 13 I blago će se njihovo razgrabiti
\q2 i kuće njihove opustošiti;
\q1 grade kuće, ali neće sedeti u njima;
\q2 i sade vinograde, ali neće piti vino iz njih.
\b
\q1 
\v 14 Blizu je veliki dan Gospodnji,
\q2 blizu je i ide vrlo brzo;
\q1 glas će biti dana Gospodnjeg,
\q2 gorko će tada vikati junak.
\q1 
\v 15 Taj je dan, dan kada će biti gnev,
\q2 dan, kada će biti tuga i muka,
\q1 dan, kada će biti pustošenje i zatiranje,
\q2 dan, kada će biti mrak i tama,
\q2 dan, kada će biti oblak i magla.
\q1 
\v 16 Dan, kada će biti trubljenje
\q2 i poklič na tvrde gradove i na visoke uglove.
\b
\q1 
\v 17 I pritesniću ljude,
\q2 te će ići kao slepi,
\q2 jer zgrešiše Gospodu;
\q1 i krv će se njihova prosuti kao prah
\q2 i telesa njihova kao gnoj.
\q1 
\v 18 Ni srebro njihovo ni zlato njihovo neće ih moći izbaviti
\q2 u dan gneva Gospodnjeg;
\q1 i svu će zemlju proždreti oganj revnosti Njegove;
\q2 jer će brzo učiniti kraj svima stanovnicima zemaljskim.
\c 2
\s1 Opomena narodu da se pokaje. Kazna nad narodom.
\q1 
\v 1 Saberite se,
\q2 saberite se, narode nemili.
\q1 
\v 2 Dok nije izašao sud,
\q2 i dan prošao kao pleva,
\q1 dok nije došao na vas ljuti gnev Gospodnji,
\q2 dok nije došao na vas dan gneva Gospodnjeg.
\q1 
\v 3 Tražite Gospoda svi koji ste krotki u zemlji,
\q2 koji činite šta je naredio;
\q1 tražite pravdu,
\q2 tražite krotost,
\q2 eda biste se sakrili na dan gneva Gospodnjeg.
\q1 
\v 4 Jer će se Gaza ostaviti
\q2 i Askalon će opusteti;
\q1 Azot će se odagnati u podne
\q2 i Akaron će se iskoreniti.
\b
\q1 
\v 5 Teško onima koji žive po bregovima morskim,
\q2 narodu heretejskom:
\q1 reč je Gospodnja na vas,
\q2 Hanane, zemljo filistejska,
\q1 ja ću te zatrti
\q2 da ne bude stanovnika u tebi.
\q1 
\v 6 I bregovi će morski biti stanovi i jame pastirske i torovi za stada.
\q1 
\v 7 I taj će kraj biti ostatku doma Judinog;
\q1 onde će pasti;
\q2 u domovima će askalonskim legati uveče;
\q1 jer će ih pohoditi Gospod Bog njihov
\q2 i povratiti roblje njihovo.
\b
\q1 
\v 8 Čuo sam rug Moavov
\q2 i ukore sinova Amonovih
\q1 kojima ružiše moj narod,
\q2 i raširiše se preko međa njihovih.
\q1 
\v 9 Zato, tako ja bio živ,
\q2 govori Gospod nad vojskama,
\q2 Bog Izrailjev,
\q1 Moav će biti kao Sodom
\q2 i sinovi Amonovi kao Gomor,
\q1 mesto koprivama,
\q2 i slanica i večna pustoš;
\q1 ostatak naroda mog opleniće ih,
\q2 i koji ostanu od naroda mog naslediće ih.
\q1 
\v 10 To će im biti za ponositost njihovu;
\q2 jer ružiše narod Gospoda nad vojskama
\q2 i podizaše se na Nj.
\q1 
\v 11 Strašan će im biti Gospod,
\q2 jer će istrebiti sve bogove zemaljske,
\q1 i Njemu će se klanjati svaki iz svog mesta,
\q2 sva ostrva narodna.
\b
\q1 
\v 12 I vi, Etiopljani,
\q2 bićete pobijeni mačem mojim.
\b
\q1 
\v 13 I dignuće ruku svoju na sever,
\q2 i zatrće Asirsku,
\q1 i Nineviju će opusteti
\q2 da bude suva kao pustinja.
\q1 
\v 14 I u njoj će ležati stada,
\q2 svakojako zverje između naroda,
\q2 i gem i ćuk noćivaće na dovratnicima njenim;
\q1 glasom će pevati na prozorima;
\q2 pustoš će biti na pragovima,
\q2 jer će se poskidati kedrovina.
\q1 
\v 15 Takav će biti veseli grad,
\q2 koji sedi bez brige,
\q1 koji govori u srcu svom:
\q2 Ja sam, i osim mene nema drugog.
\q1 Kako opuste!
\q2 Posta loža zverju!
\q1 Ko god prođe mimo nj
\q2 zviždaće i mahati rukom.
\c 3
\s1 Pretnja Jerusalimu. Utešno obricanje Mesijskoga vremena.
\q1 
\v 1 Teško gradu odmetničkom i oskvrnjenom,
\q2 nasilničkom!
\q1 
\v 2 Ne sluša glas,
\q2 ne prima nauk,
\q1 ne uzda se u Gospoda,
\q2 ne pristupa k Bogu svom.
\b
\q1 
\v 3 Knezovi su mu u njemu lavovi koji riču;
\q2 sudije su mu vuci večernji,
\q2 koji ne glođu kosti do jutra.
\q1 
\v 4 Proroci su mu hvališe, varalice;
\q2 sveštenici njegovi skvrne svetinju,
\q2 izvrću zakon.
\q1 
\v 5 Gospod je pravedan usred njega,
\q2 ne čini nepravde,
\q1 svako jutro iznosi sud svoj na videlo,
\q2 ne izostaje,
\q1 ali bezbožnik ne zna za stid.
\b
\q1 
\v 6 Istrebih narode,
\q2 kule im se razoriše,
\q1 ulice im opusteh,
\q2 te niko ne prolazi;
\q1 gradovi im se raskopaše,
\q2 da nema nikoga, nema stanovnika.
\q1 
\v 7 Rekoh: Pobojaćeš me se,
\q2 primićeš nauk;
\q1 neće mu se zatrti stan ničim
\q2 sa čim bih ga pohodio;
\q1 ali oni uraniše
\q2 te pokvariše sva dela svoja.
\b
\q1 
\v 8 Zato čekajte me, govori Gospod,
\q2 do dana kad ću se podignuti na plen;
\q1 jer je sud moj da saberem narode
\q2 i pokupim carstva,
\q1 da izlijem na njih gnev svoj,
\q2 svu žestinu jarosti svoje,
\q1 jer će oganj revnosti moje proždreti svu zemlju.
\b
\q1 
\v 9 Jer ću tada promeniti narodima usne,
\q2 te će biti čiste,
\q1 da bi svi prizivali ime Gospodnje
\q2 i služili Mu složnim ramenima.
\q1 
\v 10 Ispreko reka huskih koji se meni mole,
\q2 rasejani moji,
\q2 doneće mi dare.
\b
\q1 
\v 11 Tada se nećeš više stideti ni jednog od svojih dela,
\q2 kojima si mi zgrešio;
\q1 jer ću onda uzeti iz tebe one koji se hvale slavom tvojom,
\q2 i nećeš se više veličati na svetoj gori mojoj.
\q1 
\v 12 I ostaviću u tebi narod nevoljan i siromašan,
\q2 i oni će se uzdati u ime Gospodnje.
\q1 
\v 13 Ostatak Izrailjev neće činiti bezakonja
\q2 niti će govoriti laži,
\q2 niti će se naći u ustima njihovim jezik prevaran;
\q1 nego će pasti i ležati
\q2 i neće biti nikoga da ih plaši.
\b
\q1 
\v 14 Pevaj, kćeri sionska;
\q2 klikuj, Izrailju;
\q1 raduj se i veseli se iz svega srca,
\q2 kćeri jerusalimska!
\q1 
\v 15 Ukloni Gospod sudove tvoje,
\q2 odvrati neprijatelje tvoje;
\q1 car Izrailjev Gospod usred tebe je,
\q2 nećeš se više bojati zla.
\q1 
\v 16 U onaj dan reći će se gradu Jerusalimu: Ne boj se;
\q2 Sionu: Nemoj da ti klonu ruke.
\q1 
\v 17 Gospod Bog tvoj, koji je usred tebe,
\q2 silni, spašće te;
\q1 radovaće ti se veoma,
\q2 umiriće se u ljubavi svojoj,
\q2 veseliće se tebe radi pevajući.
\q1 
\v 18 Koji tuže za praznicima,
\q2 sabraću ih,
\q1 koji su iz tebe,
\q2 radi teške sramote koja je na tebi.
\q1 
\v 19 Gle, uništiću u ono vreme sve koji te muče,
\q2 i izbaviću hrome i sabrati odagnane,
\q1 i dobaviću im hvalu i slavu po svoj zemlji,
\q2 gde su bili pod sramotom.
\q1 
\v 20 U ono vreme dovešću vas,
\q2 u ono vreme sabraću vas;
\q1 jer ću vam dobaviti slavu i hvalu po svim narodima na zemlji,
\q2 kad povratim roblje vaše pred vašim očima,
\q2 govori Gospod. 
