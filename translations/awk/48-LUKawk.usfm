\id LUK
\toc3 Luka
\toc2 Luka
\toc1 EUANGELION UNNI TA JESU-ÚMBA CHRIST-KO-BA UPATOARA LUKA-UMBA
\mt1 EUANGELION UNNI TA JESU-ÚMBA CHRIST-KO-BA UPATOARA LUKA-UMBA
\c 1
\p 
\v 1 WONTO ba kauwȧllo mankulla unnoa tara túġunbilliko ġurránto ġéen kinba,
\p 
\v 2 Yanti bo ġearun kin bara ġukulla, unnoa tara nakillikan kurri-kurri kabiruġ ġatun mankillikan wiyellikanne koba.
\p 
\v 3 Murrȧrȧġ tia kȧtan yantibo, koito baġ ba tuiġ ko ġirouġ, Teopolo murrȧrȧġ ta,
\p 
\v 4 Ġurra-uwil koa bi tuloa, unnoa tara wiyatoara banuġ ba.
\p 
\v 5 Yanti-kȧlai ta Herod noa kakulla, Piriwȧl noa kakulla Iudaia ka, kakulla noa tarai hiereu Dhakaria yitirra, Abia-u̇mba konara: ġatun nukuġ ġikoúmba yinálkun koba Aaron-úmba, ġiakai bountoa yitirra Elidhabet.
\p 
\v 6 Buloara bula kakulla murrȧrȧġ Eloi kin, mikan ta ġurraiyelléu̇n bula Yehóa-ko noa ba wiyellikanne yarakai ma korien.
\p 
\v 7 Keawaran bula wonnai korien kulla, bountoa Elidhabet ġurrauwai; ġatun bula ba ġurróġbai kakulla.
\p 
\v 8 Ġatun yakita kakulla, umulliela noa ba Eloi kin makan ta, yirruġ ka ġikouġ kin hiereu koba,
\p 
\v 9 Yanti kiloa hiereu koba uman, yirruġ ka ġikoúmba ta upulliko bon porapora koiyuġ ko uwá noa ba nao koba Yehóa kai koba.
\p 
\v 10 Ġatun yanti bo yantinto konara ku̇ri wiyelliela warai ta yakita winelliela ba porapora.
\p 
\v 11 Ġatun paipéa noa aġelo Yehóa-úmba ġikouġ kin, ġarokilliela noa túġkaġkirri ka koiyuġ kón ta porapora ka.
\p 
\v 12 Ġatun nakulla bon noa ba Dhakaria ko, unma bon noa ba, kinta ġaiya noa ba kakulla.
\p 
\v 13 Wonto ba aġelo wiya noa, Kinta kora bi kauwa, Dhakaria; kulla ġurra ta wiyellikanne ġiroúmba, ġatun nukuġ ko ġiroúmba ko wonnai kȧnu̇n ġiroúmba, ġatun wiyȧnu̇n bi ġiakai yitirra Ioanne.
\p 
\v 14 Ġatun pitȧl bi kȧnu̇n, pitȧl kauwȧlkan kȧnu̇n pórkullinu̇n ġikouġ kinbiruġ.
\p 
\v 15 Kauwȧl wal noa kȧnu̇n, mikan ta Yehóa kin, ġatun keawai wal noa wain pitȧnu̇n, keawai tarere, ġatun warakaġ wal noa witellinu̇n Marai yirriyirri kan biruġ ko, waraka biruġ tunkán ta biruġ.
\p 
\v 16 Ġatun noa wiyȧnu̇n wal barun kauwȧl-kauwȧl wonnai Ithȧrael-úmba Yehóa-kin ko Eloi ta barúnba.
\p 
\v 17 Ġatun wal noa uwȧnu̇n ġikouġ kin mikan ta kaiyu ka Marai ta Elia-uúmba, warbuġgulliko bu̇lbúl biyuġbai tara koba wonnai kolaġ, ġatun barun kinko tuloa kako; uma-uwil koa barun ku̇ri kurrikurri Yehóa kinko.
\p 
\v 18 Ġatun noa Dhakariako wiya bon aġelonuġ, Yakoai kan baġ ġurrȧnu̇n unni? kulla baġ ġurroġbai, ġatun nukuġ emmoúmba ġurróġ ġéen.
\p 
\v 19 Ġatun noa aġeloto wiya bon, Ġatoa Gabriel, ġakillin Eloi kin mikan ta; ġatun yuka tia wiyelliko ġirouġ, ġatun túġunbilliko ġali tara ko pitȧlmullikanne ko.
\p 
\v 20 A! ġurrulla bi, ġóġ ko wal bi kȧnu̇n, ġatun kaiyu korien wal bi kȧnu̇n wiyelli ta, yaki-kȧlai tako purreȧġ kako unni tara kȧnún ba, kulla bi ba ġurra korien wiyellikanne emmoúmba, kabo kȧnu̇n wal unni tara.
\p 
\v 21 Ġatun bara ku̇ri ko mittia Dhakarianuġ, ġatun kotelliela minnuġ-bulliela noa tunkéa noa nao ka.
\p 
\v 22 Ġatun noa ba paikulléún warrai ta, kaiyu korien noa wiyelli ko barun; ġatun bara ġurra Marai noa nakulla nao ba; kulla noa wauwȧl-wauwȧl umá barun ġatun, ġarokilliela noa ġóġ ko.
\p 
\v 23 Ġatun kirun kabulla purreȧġ ġikoúmba umullikanne, waita ġaiya noa uwá kokerá ko ġikouġ ka tako.
\p 
\v 24 Ġatun yukita purreȧġ ka Elidhabet ġikoúmba nukuġ warakȧġ bountoa, ġatun yuropulléu̇n bountoa warán yellenna ka, wiyelliela bountoa,
\p 
\v 25 Yanti noa tia Yehóako umá nakulla noa tia ba purreȧġ ka, mankilliko barun ba béelmulli tin ku̇ri tin.
\p 
\v 26 Tarai-ta yellenna ka hek ka, Gabriel ta aġelo ta puntimai ta wiyabunbia bon Eloi kinbiruġ uwolliko, purrai kolaġ, Galilaia koba, ġiakai Nadharet,
\p 
\v 27 Mirrȧl lako wiyatoara ko, ku̇ri kako Yothep kinko yitirra ko, wonnai taro noa Dabidúmba; ġatun mirrȧl ġiakai yitirra Mari.
\p 
\v 28 Ġatun noa aġelo uwa bounnoun kin, ġatun wiyelliela, A! murrȧrȧġ umatoara bi Yehóa kȧtan ġirouġ katoa ba; murrȧrȧġ umatoara bi nukuġ ka.
\p 
\v 29 Ġatun bountoa ba nakulla bon, kinta bountoa kakulla wiyellita ġikouġ kin, ġatun kotelliela bountoa minariġ unni totóġ kȧtan.
\p 
\v 30 Ġatun aġeloko wiya bounnoun, Kinta kora bi, Mari: kulla bin pitȧlmatoara Eloito noa.
\p 
\v 31 A, ġurralia bi, warakáġ bi kȧnu̇n, wonnai kan ġirouġ kin pika ka, ġatun yinal pórkullinu̇n, ġatun bi ġiakai yitirra IETHU.
\p 
\v 32 Ġatun wal noa kauwȧl kȧnu̇n, ġatun wal bon wiyȧnu̇n ġia kai Yinal ta wokka ka ko; ġatun noa Yehóako Eloito gúnu̇n wa bon yellawollikanne biyuġbai koba Dabidúmba ġikoúmba:
\p 
\v 33 Ġatun noa wiyȧnu̇n wal yanti-katai barun Yakobúmba; ġatun ġikoúmba piriwȧlkanne keawai wal kȧnu̇n wirán.
\p 
\v 34 Wiya ġaiya bountoa bon aġelonuġ Mariko, Yakoai ke unni kȧnu̇n, kulla baġ ku̇ri korien?
\p 
\v 35 Ġatun noa aġeloko wiya bounnoun, Tanan wal noa uwȧnu̇n Maraikan murrȧrȧġkan ġirouġ kinko, ġatun kaiyuko wokka tinto wutinu̇n wal ġirouġ, koito ba unnoa ta murrȧrȧġ pórkullinu̇n ġirouġ kin; wiyȧnu̇n ġiakai yinal ta Eloi koba.
\p 
\v 36 A, ġurralia, ġiroúmba wuġgunbai Elidhabet, warakaġ bountoa yinal ġurroġéen koba bounnoun ba; ġatun unni ta yellenna hek ta bounnoun-kai-kan wiyatoara ġurra-uwai.
\p 
\v 37 Kulla ġurakito ke noa Eloito kaiyukanto ke.
\p 
\v 38 Ġatun bountoa Mariko wiya, Kauwá yanti kámúnbilla tia wiya bi ba; ġatoa mankillikan Yehóa-u̇mba. Ġatun noa aġelo púntirkulléu̇n bounnoun kinbiruġ.
\p 
\v 39 Ġatun bountoa Mari buġkulléu̇n unti-tara purreȧġ ka, ġatun uwa bountoa karakai bulkȧra kolaġ, kokerá ko Yuda kako;
\p 
\v 40 Ġatun bountoa uwa kokera ko Dhakaria-úmba kako, ġatun búġbúġ ka bounnoun Elidhabetnuġ.
\p 
\v 41 Ġatun yakita ġaiya ġurrá bountoa ba Elidhabetto pulli Mariúmba, tulutilléu̇n ġaiya wonnai bounnoun kin pika ka; ġatun warapál bounnoun ba Elidhabet kin Maraikanto murrȧrȧġko:
\p 
\v 42 Ġatun bountoa wiyelléu̇n pulli wokka wiyelliela, murrȧrȧġ umatoara bi nukuġ ba; ġatun murrȧrȧġ umatoara peil ġiroúmba pika koba.
\p 
\v 43 Ġatun minariġ tin tia unni, tanan uwa tunkan piriwȧl koba emmoúmba?
\p 
\v 44 Kullȧ baġ ba ġurrá pulli ġiroúmba ġurréuġ ka emmouġ kin, wonnai ġaiya tia tulutilléu̇n emmouġ kin pika ka pitȧl ko.
\p 
\v 45 Ġatun murrȧrȧġ umatoara bountoa ġurrá; kulla unnoa tara kȧnu̇n umatoara, wiyatoara bounnoun kin Yehóa kinbiruġ.
\p 
\v 46 Ġatun Mariko bountoa wiya, “Maraito emmoúmba ko wiyan murrai bon Yehóanuġ,
\p 
\v 47 Ġatun maraito emmoúmba ko pitȧl umulléu̇n Eloi kin Miroma emmoúmba.
\p 
\v 48 Kulla noa nakulla mirrȧl bountoa ba umullikan ġikoúmba; A, unti biruġ yantinto tia wiyȧnu̇n murrȧrȧġ upatoara.
\p 
\v 49 Kulla noa tia kaiyukanto unnoa tara kauwȧl uma; ġatun yitirroa ġikoúmba murrȧrȧġ upatoara kȧtan.
\p 
\v 50 Ġatun murrai ġikoúmba barun kinba kintakan bon kȧtan willuġġél ku̇ri kabiruġ tarai ku̇ri kabiruġ.
\p 
\v 51 Túġunbilléu̇n noa kaiyukan turruġ ġikoúmba; wupéa noa barun ġaruġ ġara yaroyaro búlbúl ban kotellikanne.
\p 
\v 52 Upéa noa barán parrán kaiyukan yellawolliġél labiruġ barúnba, ġatun wupéa noa barun mirrȧl wokka laġ.
\p 
\v 53 Ġukulla noa kapirrikan ko mu̇rrȧrȧġ ta, ġatun noa barun parólkan yuka mirrȧl ko.
\p 
\v 54 Umulléu̇n noa ġikoúmba umullikan Ithȧraelnuġ, ġurrulli biruġ ġikouġ kinbiruġ murrai ta ġikoúmba;
\p 
\v 55 Yanti wiya noa ba barun biyuġbai to ġearúnba, Abȧramnuġ, ġatun barun wonnai tara ġikoúmba yanti katai.”
\p 
\v 56 Ġatun Mari bountoa kakulla bounnoun katoa ġoro ka yellenna ka, ġatun willuġ ba ġaiya bountoa bounnoun ka tako kokera ko.
\p 
\v 57 Yakita ġaiya Elidhabetúmba kakulla wonnai pórkullinu̇n; ġatun yinal bounnoun ba pórkulléu̇n.
\p 
\v 58 Ġatun ġurra bara kótita ko bounnoun bako, yanti Yehóako noa ba murrȧrȧġ umá bounnoun kin; ġatun bara pitȧl kakulla ġatun bountoa
\p 
\v 59 Ġatun yakita ġaiya purreȧġ ka, uwa ġaiya bara kullabulliko wonnai ko; ġatun bara wiya bon ġiakai Dhakaria, biyuġbai tin yitirra tin
\p 
\v 60 Ġatun tunkanto wiya bountoa, Yanoa; kulla bon wiyȧnu̇n ġiakai Ioanne.
\p 
\v 61 Ġatun bara bounnoun wiya, Keawaran ġiroúmba kótita wiya ba ġiakai unni yitirra
\p 
\v 62 Gatun bara túġa umulléu̇n bon biyuġbai ko ġikoúmba ko, wonnén noa bon yitirra wiyȧnu̇n?
\p 
\v 63 Ġatun noa wiya upulliġél ko, ġatun noa upa wiyelliela, Yitirra noa ġiakai Ioanne. Ġatun bara yantinto kota.
\p 
\v 64 Ġatun tanoa-kȧl-bo kurraka buġkulléu̇n ġikoúmba, ġatun bon ġikoúmba tállȧġ balbal kakulla, ġatun noa wiya, ġatun noa wiya murrai Eloinuġ.
\p 
\v 65 Ġatun bara kinta kakulla yantin ta untakȧl; ġatun unni tara wiyellikanne totóġ kakulla yantin ta kaloġ koa bulkaroa Yuda ka.
\p 
\v 66 Ġatun bara yantinto unnoa tara ġurra wúnkulla barun kin búlbúl la, wiyelliela, Yakoai unni ta wonnai kȧnu̇n! Ġatun mȧttȧra Yehóa-úmba ġikouġ kin kȧtan.
\p 
\v 67 Ġatun noa Dhakaria ko biyuġbai ġikoúmba, warapal bon wupéa Marai to yirriyirri to, ġatun noa wiyelliela ġiakai,
\v 68 “Kȧmu̇nbilla bon Yehóanuġ Eloinuġ Ithȧrael koba pitȧlliko; kulla noa uwa barun nakilliko, ġatun wirrilliko kúri ko ġikouġ kaiko.
\p 
\v 69 Ġatun bouġbuġġa noa nulka-nulka ġolomullikan ġearun, kokerá Dabid-úmba ka ġikoúmba mankillikan;
\p 
\v 70 Yanti noa ba wiya kurraka ko propet koba ko yirriyirrikan to yantin to, purrai yantin kurrikurri kabiruġ:
\p 
\v 71 Ġoloma-uwil koa ġearun ġearúnba bukka tukulla biru̇ġ, ġatun mȧttȧra biruġ barun kinbiruġ yantin tabiruġ yarakai willuġ kabiruġ,
\p 
\v 72 Umulliko murrai ko wiyatoara barun kin biyuġbai ko ġearúnba, ġatun ġurrulliko ġikoúmba wiyatoara yirriyirri ta;
\p 
\v 73 Pirral-man noa ġali wiyelliela bon Abȧramnuġ biyuġbai ġearúnba,
\p 
\v 74 Ġúwil koa ġearun noa, mankilliko ġearun mȧttȧra biruġ bukkakan tabiruġ ġearúnba, ġurra-uwil koa ġéen bon kinta korien ko,
\p 
\v 75 Yirriyirrikan ġatun murrȧrȧġkan mikan ta ġikouġ kin, yantin ta purreȧġ ka moron ġearúnba.
\p 
\v 76 Ġatun ġintoa, wonnai ta, wiyȧnu̇n bin yitirra propet ta wokka kako; kulla bi uwȧnu̇n ġanka mikan ta Yehóa kin, upulliko yapuġ ko ġikoúmba;
\p 
\v 77 Ġukilliko ġurrulliko moron ko ġikouġ kaiko ku̇ri ko, warewarekan yarakai barúnba,
\p 
\v 78 Murrai tin kanwollin Eloi koba tin ġearúnba, ġurrakan wokka kabiruġ tanan uwa ġearun kinko,
\p 
\v 79 Ġukilliko purreȧġ barun ko yellawolli ta ba ko ġoroġorȧ ba ko, ġatun komirra kaba tetti koba, yutilliko tinna ko ġearúnba ko yapuġ koa pitȧl koba koa.”
\p 
\v 80 Ġatun wonnai poaikulléu̇n, ġatun ġuraki noa maraikan ko, kulla noa koruġ koa yakita ko purreȧġ kako paipéa noa ba Ithȧrael kinko.
\c 2
\p 
\v 1 YAKITA purreȧġ ka, wiya noa Kaithariko Augútoko, upa-uwil koa barayantin ku̇ri murrapulliko.
\p 
\v 2 Ġatun unni murrapullikanne una yakita Kurinio noa ba kobȧna kakulla Thuria ka.
\p 
\v 3 Ġatun yantin bara uwa murrapulliko barun ka tako.
\p 
\v 4 Ġatun noa Yothep uwa wokka-laġ Ġalilaia kabiruġ, kokerá biruġ Nadharet tabiruġ, Iudaia kolaġ, kokera kolaġ Dabidúmba kolaġ, ġiakai yitirra Bethlehem; (kulla noa kokerá koba ġatun kotita koba Dabidúmba;)
\p 
\v 5 Murrapulliko bon ġatun Mari bounnoun katoa, wiyatoara nukuġ ġikoúmba, wonnai kan bountoa warakaġ.
\p 
\v 6 Ġatun yakita kakulla, kakulla bara ba unta, purreȧġ ka kȧtan pórkulli koa bountoa ba wonnai.
\p 
\v 7 Ġatun bountoa pórbuġgulléún kurri-kurri yinal, ġatun bountoa muġgama bon kirikin to, ġatun bon wúnkulla takilliġélla buttikaġ koba ka; kulla wal tantullan kokera takilliġél.
\p 
\v 8 Ġatun bara éipu-kȧl untoa kakulléún, tumimillin wirrȧl barun ba tokoi ta
\p 
\v 9 Ġatun noa aġelo Yehóa-úmba tanan uwa barun kin, ġatun kullaburra Yehóa-úmba kakulla barun katoa; kinta ġaiya bara kakulla.
\p 
\v 10 Ġatun noa aġeloko wiya barun, Kinta kora; kulla nurun baġ wiyan murrȧrȧġ totóġ kakilliko pitȧl ko, kakilliko yantin ko ku̇ri ko.
\p 
\v 11 Kulla nurúnba pórkulléu̇n unni purreȧġ, kokerá Dabidúmba ka, Ġolomullikan ta, noa Kritht ta Piriwȧl ta.
\p 
\v 12 Ġatun unni túġa kȧnu̇n nurúnba; nanu̇n boboġnuġ ġamatoara kirikin taba, kakillin ba takilliġél laba
\p 
\v 13 Ġatun tanoa kal bo paipéa konara morokokȧl ġikouġ katoa aġelo katoa, murrȧrȧġ wiyellin bon Eloinuġ, ġiakai,
\p 
\v 14 Wiyabunbilla bon murrȧrȧġ Eloinuġ wokka kaba moroko kaba, ġatun kȧmu̇nbilla pitȧl purrai tako, murrȧrȧġ umatoara barun ku̇ri ko.
\p 
\v 15 Ġatun kakulla ba, waita uwa bara ba, aġelo barun kinbiruġ moroko kolaġ, wiyellan bara éipu-kȧl taraikan-taraikan, Waita ġéen yakita Bethlehem kolaġ, na-uwil koa unnuġ tara kakulla ba, ġala Yehóako noa wiya ġéarun
\p 
\v 16 Ġatun bara uwa kurrakai, ġatun nakulla Marinuġ, ġatun boboġ pirikilliela takilliġél laba.
\p 
\v 17 Ġatun nakulla bara ba, wiyabu̇nbéa bara yantin ta purrai ta unnoa wiyellikanne wiyatoara barun wonnai tin.
\p 
\v 18 Ġatun bara yantinto ġurra, kotelliela unnuġ tara, wiya barun bara éipu-kȧl-lo.
\p 
\v 19 Wonto ba bountoa Mariko miromá unni tara, ġatun kota bountoa minki ka búlbúl-la bounnoun kin.
\p 
\v 20 Ġatun bara éipu-kȧl willuġ ba kakulla, murrȧrȧġ wiyellin ġatun pitȧlmullin bon Eloinuġ ġala biruġ natoara biruġ ġurratoara biruġ bara yantita wiyatoara ba barun kai.
\p 
\v 21 Ġatun purreȧġ ét ta kakulla ba, kullintiela ko túġa-witia wonnai, ġiakai bon wiya Iéthu, ġala ba wiya noa aġeloko kurrikurri noa ba pika ka kakulla kunto ka.
\p 
\v 22 Ġatun purreȧġ ka ġoloin ta killibinbin bounnoun ba, yanti Mothé-ko noa ba wiya, mankulla bara bon Hierothalem kolaġ, ġukilliko bon Yehóa kin;
\p 
\v 23 (Yanti wupa ba wiyellikanne ta Yehóa-úmba ġiakai, Yantin ku̇ri tara ġanka-ġanka pika kabiruġ yirri-yirri wal kȧnu̇n yitirroa Yehóa koba;)
\p 
\v 24 Ġatun ġukilliko ġutoara, ġala wupa ba wiyellikanne taba Yehóa-úmba, ġiakai, Buloara purrouġkan ġa keawai wuroġ buloara poppolameri.
\p 
\v 25 A! ġatun kakulla noa tarai ku̇ri Hierothalem kaba, ġiakai noa yitirra Thimeon; ġatun unnoa ku̇ri wiyellikan tuloakan, ġatun ġurrullikan, mittillin pitȧl ko Ithȧrael-úmba ko; ġatun Marai yirri-yirri-kan kakulla ġikouġ kin.
\p 
\v 26 Ġatun bon wiyatoara Maraito yirri-yirri-kan-to, keawai noa nanu̇n tettibullikanne, na-uwil koa noa Krithtnuġ Yehóa-úmba.
\p 
\v 27 Ġatun noa uwa Marai toa hieron kako: ġatun bula ba porikullaito puruma wonnai Iethu kin, umulliko bon yanti ko upatoara ko wiyellikanne tako,
\p 
\v 28 Mankulla ġaiya bon noa ġikouġ kin turruġ ka, ġatun pitȧlma noa bon Eloinuġ, ġatun wiyelliela,
\p 
\v 29 “Wamu̇nbilla bi tia Yehóa yakita pitȧlkan, yanti wiya bi ba:
\p 
\v 30 Kulla baġ nakulla ġaikuġ ko ġolomullikan ġiroúmba,
\v 31 Ġali ko kakilliko ġintoa yantin ko kúri ko mikan tako;
\p 
\v 32 Kaibuġ kakilliko barun ethȧnékal ko, ġatun pitȧl kakilliko ku̇ri ko Ithȧrael ġiroúmba ko.”
\p 
\v 33 Ġatun bula Yothep ġatun Mari kotelliela unnoa wiyatoara ġikouġ kai.
\p 
\v 34 Ġatun Thimeon ta noa pitȧlma barun, ġatun wiyelliela Marinuġ tunkan ġikoúmba, “A! kȧtan noa unni wonnai kakilliko puntimulliko, ġatun bouġkulliko kauwȧl-kauwȧl barúnba Ithȧrael koba; ġatun túġa ko wiyéa kȧnu̇n;
\p 
\v 35 (Kauwa, yirrako bin turȧnu̇n wal marai ġiroúmba kóti,) paipi-uwil koa kotatoara búlbúl labiruġ kauwȧl-kauwȧl labiruġ.”
\p 
\v 36 Ġatun kakulla wakȧl Anna, propetkun, yinálkun Panuel koba, konara koba Ather koba; bountoa ta ġurroġéen ġaġkakȧlin, ġatun kakulla bountoa poribai ta wunȧl la hepta ta, murrakin tabiruġ bountoa katalla;
\p 
\v 37 Ġatun bountoa maboġun kukulla wunȧl la éty-warra yantikalai tabiruġ, waita uwa korien bountoa hieron kabiruġ, wonto ba ġurrulliela Eloinuġ bon purreȧġ ka ġatun tokoi ta ta-korien.
\p 
\v 38 Ġatun bountoa uwolliela tanoa-kal-bo, wiyapaiyéȧn bon Yehóanuġ, ġatun wiyelliela yantin barun ġikouġ kin barun, nakillikan ġupaiyiko Hierothalem kako.
\p 
\v 39 Ġatun upá bara ba unni tara yanti wiyatoara Yehóa koba, willuġbo ġaiya bara kakulla Galilaia kako, barun ka tako kóti kako Nadharet tako.
\p 
\v 40 Ġatun wonnai poaikulléu̇n ġuraki noa maraikan kȧtan; ġatun pitȧlmatoara bon Eloi koba.
\p 
\v 41 Waita uwa bula ġikoúmba tunkan ġatun biyuġbai Hierothalem kolaġ yanti-katai wunál la takilliġél lako kaiwitoara wokka koa.
\p 
\v 42 Ġatun noa ba wunȧl la dodeka ka, waita ġaiya uwa bara Hierothalem kolaġ wirikai ko takilli ko.
\p 
\v 43 Ġatun kirun kakulla purréȧġ, willuġbo bara ba, wonnai Iéthu noa minka willuġ ka Hierothalem ka; ġatun noa Yothepko ġatun tunkanto ġurra korien bula.
\p 
\v 44 Wonto bara ba punta bon barun kin konara, uwa purreȧġ ka wakȧl la; ġatun bara bon tiwa kóti ta ka.
\p 
\v 45 Ġatun bara na korien bon ba, willuġbo ġaiya bara katéakún Hierothalem kolaġ tiwolliko bon.
\p 
\v 46 Ġatun purreȧġ ka ġoro kulla, nakulla ġaiya bara bon murruġ ka hieron ka, yellawolliela willi ka barun kin didathkaloi ka, ġurrulliela barun wiyelliela barun wiyellikanne pulli.
\p 
\v 47 Ġatun yantinto bara bon ba, ġurra, kotelliela bara bon ġuraki ġatun wiyatoara ġikoúmba.
\p 
\v 48 Ġatun nakulla bara bon ba, unma ġaiya barun; ġatun tunkanto ġikoúmba-ko wiya bon, Nai, minariġ tin bi kakulla ġearun kai? a! biyuġ ta uwa bali, tiwolliela bali bin, minki-kan-to.
\p 
\v 49 Ġatun noa wiya barun, Minariġ tin nura tia tiwolliela? keawai nura ba ġurran-upa-uwil koa baġ pintunúmba-kan wiya noa tia ba?
\p 
\v 50 Ġatun bara ġurra korien unnoa wiyelli ta wiya noa ba barun,
\p 
\v 51 Ġatun noa uwa barun katoa barán Nadharet tako, ġatun ġurrullikan noa kakulla barun kin: wonto bountoa ba tunkan to ġikoúmba miromá unni tara wiyellikanne murruġ ka búlbúl la bounnoun kin.
\p 
\v 52 Ġatun noa Iéthuko poaikulléu̇n ġuraki kakilliko, ġatun kauwȧl kakilliko, ġatun pitȧlmulliko bon Eloito ġatun ku̇riko.
\c 3
\p 
\v 1 Yakita kakulla wunȧl la pipátin ta piriwȧl koba Tiberio Kaithar koba, kobȧna noa Pontio Pilato Iudaia ka, ġatun tetrák noa Herod Galilaia ka, ġatun ġikoúmba kóti Pilip tetrák noa Ituréa ka, ġatun yantin tako Trakoniti ka, ġatun Luthanio tetrák noa Abiléné ka,
\p 
\v 2 Annath ġatun Kaiapath hiereu piriwál bula kakulla, wiyellianne Eloi koba uwa Ioanne kinko bon, yinal Dhakaria koba, koruġ kaba.
\p 
\v 3 Gatun noa uwa yantin toa purrai toa Iorȧdan toa, wiyelliela korimulliko kanumaiko, warekulliko yarakai;
\p 
\v 4 Yanti wupaitoara biblion ka wiyellikanne Ethaia koba propet koba, ġiakai, Pulli wakȧl koba wiyelléu̇n koruġ kaba, Yapuġ Yehóa koba murráráġ umulla nura, tuloa kakillikoyapuġ ġikoúmba.
\p 
\v 5 Yantin ta pilabai warapal upinún, ġatun yantin ta bulkȧra umȧnu̇n puntiġ; ġatun warin-warin ta umánún tuloa, ġatun yapuġ yarakai wolluġbiara umánún poitoġ;
\p 
\v 6 Gatun yantinto nanún wal ġolomullikanne Eloi koba.
\p 
\v 7 Wiya ġaiya noa barun konara uwa bara korimulliko ġikouġ kinko, Ela béara! konara maiya kiloa nura! ġanto nurun wiya murralliko bukka tin tanan ba uwánún?
\p 
\v 8 Koito nura ba umullia murrȧrȧġ minki kabiruġ; ġatun kota yikora nura kóti ka minki ka nurun kin wiyelliko, Abáram ġearun noa ġearúnba biyuġbai; kulla baġ wiyan nurun, Eloi noa kaiyukan kátan umulliko unti tara biruġ tunúġ kabiruġ wonnai kakilliko Abáram kinko.
\p 
\v 9 Ġatun yakita baibai wúnkulla kúlai ta wirrá ka; koito ba yantin kúlai keawai kátan murráráġ kólbúntillȧnún wal barán, warekulliko koiyuġ kako.
\p 
\v 10 Ġatun kúriko bon wiya, wiyelliela, Minnuġ banún ġaiya ġéen?
\p 
\v 11 Wiya noa barun, wiyelliela, Niuwoa kót-kan buloarakan ġikoúmba, ġumunbilla bon keawai ko; ġatun niuwoa kuntokan ġumúnbilla bon yanti kiloa.
\p 
\v 12 Uwá ġaiya bara telóné korimulliko, ġatun wiya bon, Piriwál, minnuġ banún ġéen?
\p 
\v 13 Ġatun noa wiya barun, Manki yikora untoa-kȧl unnoabo mara wiyatoara nurúnba.
\p 
\v 14 Ġatun bara army-kanko wiya bon wiyelliela, Minnuġ banún ġéen? ġatun noa wiya barun, Bukkamai yikora yantin kúri, ġatun wiyéa-yemmai yikora ġakoyellaikan yantin kúri; ġatun murrai kauwa nura ġaloakan ġutoarakan nurúnba.
\p 
\v 15 Ġatun bara ba ku̇ri kotelliela, ġatun yantinto ku̇riko kotelliela murruġ ka ba ko, búlbúl la ba ko barun kin ba ko ġikóuġ Ioannenuġ, minariġ noa Kritht ta, mirka keawaran.
\p 
\v 16 Ioanneto noa wiya barun yantin ta, wiyelliela, Korimulliko baġ kȧtan nurun bato ko; wonto ba wakȧl kaiyukan kauwȧl-kau wȧlkan ġatoa kiloa uwȧnu̇n, murráráġ korien baġ poruġbuġgulliko tu̇ġganu̇ġ ko ġikoúmba ko; niuwoa ta korimanu̇n nurun Marai to yirri-yirri ko ġatun koiyuġ ko:
\p 
\v 17 Pituon ġikoúmba mankillin mȧttȧra ba, ġatun murkun noa umȧnu̇n bu̇nkilliġél laba ġikoúmba, ġatun noa ka-umȧnún wiet ġikoúmba tako kokerá ko; wonto ba tirri koiyuġ-banu̇n wal noa koiyuġ ka talokulli korien ta.
\p 
\v 18 Tarai ta yantin kauwȧl-kauwȧl wiya noa: ġatun wiyelli ta ba ko barun ku̇ri.
\p 
\v 19 Wonto noa ba Herodnuġ tetráknuġ piralma bon, noa boun noun kin Herodia kin nukuġ ka Pilip-úmba ġikou̇mba kóti koba, ġatun yantin yarakai noa ba uma Herodto,
\p 
\v 20 Yanti unni uma, wirriġbakulla bon noa Ioannenuġ jail ka.
\p 
\v 21 Yakita barunbo karima yantin ku̇ri, kakulla ġaiya korimulliela bon Iéthunuġ, ġatun wiyelliela, moroko ġaiya waruġkalléu̇n,
\p 
\v 22 Ġatun uwa barán Maraikan yirri-yirrikan murrin kiloa purrouġkan kiloa, ġikouġ kin; ġatun wakȧl pulli kakulla moroko tin, wiyelliela, Ġintoa ta emmoúmba yinal pitȧlmullikanne; pitȧlman baġġirouġ.
\p 
\v 23 Ġatun niuwoa bo Iéthu kakilliliela wunȧl la triakonta ka ġiko-úmba, puntelliela bon yinal Yothepúmba, wonto yinal Eli-úmba;.......
\p 
\v 38 Wonto yinal Enoth-úmba, wonto yinal Thet-úmba, wonto yinal Adam-úmba, wonto yinal Eloi-úmba.
\c 4
\p 
\v 1 ĠATUN noa Iéthu warapȧlkan Maraikan yirri-yirri-kan, willuġbo kakulla Iorȧdan tabiruġ, ġatun bon yatéa Maraito koruġ kolaġ,
\p 
\v 2 Nupitoara bon purreȧġ ka tettarakonta ka diabollo. Ġatun unta tara purreȧġ ka keawai noa ta ba: ġatun ġoloin ba unta tara kakulla, kapirri ġaiya noa kakulla.
\p 
\v 3 Ġatun noa diabollo wiya bon, Wiya, bi ba yinal Eloi koba, wiyellia unni tunuġ ka-uwil koa kunto.
\p 
\v 4 Ġatun noa Iéthuko bon wiya, wiyelliela, Wupatoara ta, Keawai kúri kȧnún moron kunto kabiruġ, wonto ba Eloi koba pulli tabiruġ.
\p 
\v 5 Ġatun noa diabollo yutéa bon waita bulkȧrȧ ko, nanunbéa bon yantin piriwȧl koba purrai ta ba tanoa-kȧl-bo kurrakai.
\p 
\v 6 Ġatun noa diabollo wiya bon, yantin kaiyu kako ġunu̇n bag ġirouġ, ġatun pitȧlmulliko ġali tara ko; koito ba ġukulla tia emmouġ; ġatun bag ġutan ganúmbo pitȧl bag ba kȧtan.
\p 
\v 7 Ġintoa ba wiyȧnu̇n tia, kȧnu̇n bin yantin ġiroúmba.
\p 
\v 8 Ġatun noa Iéthuko wiya bon, Kauwa bi, Thátan, willuġ ka emmouġ kin; koito ba wupatoara, Wiyȧnu̇n wal bi Yehóanuġ ġiroúmba Eloinuġ, ġatun ġikouġ bo ġurrȧnu̇n wal bi.
\p 
\v 9 Ġatun noa bon yutéa Hierothalem kolaġ, ġatun wúnkulla bo búlwarra ka hieron ka, ġatun wiya bon, Yinalla bi ba unni Eloikoba, warekulla bi unti biruġ barán:
\p 
\v 10 Kulla ba wupatoara ta, Wiyȧnu̇n noa barun aġelo ko nakilliko ġirouġ, ġolomulliko ġirouġ;
\p 
\v 11 Ġatun bara bin manu̇n mȧttȧrró wokka lag, tinna koa ġirouġ pultéa-ku̇n tunuġ ko yantin ta.
\p 
\v 12 Ġatun Iéthuko, wiyelliela, wiya bon, Wiyatoara ta, Yanoa wal bi numa yikora bon Yehóanuġ Eloinuġ ġirou̇mba.
\p 
\v 13 Ġatun noa diabollo ġoloin kakulla unni tara nupatoara, waita ġaiya noa uwa ġikouġ kinbiruġ yakita ko.
\p 
\v 14 Ġatun noa Iéthuko willuġ ko kakulla, kaiyukan Maraikan, Galilaia kako: ġatun totóġ bon kakulla yantin ta purrai kariġ ka.
\p 
\v 15 Ġatun noa wiyelliela thunagóg ka barun ka ta, pitȧl wiyatoara bon yantinto.
\p 
\v 16 Ġatun noa uwa Nadharet tako, kakulla noa poaikulléu̇n unta; ġatun, yanti katai noa ba, uwa noa thunagóg kako purreȧġ ka thabbat, ġatun ġarokéa wokka laġ wiyelliko.
\p 
\v 17 Ġatun ġukulla bon biblion ta propet koba Ethaia koba: ġatun buġbuġġa noa ba biblion, nakulla ġaiya noa ġiakai upatoara,
\p 
\v 18 Marai ta unni Yehóa koba emmouġ kinba, kulla noa tia putia wiyelliko Euagelion barun kin mirrȧl la; yuka noa tia turon umulliko minkikan ko, wiyelliko barun wúntoara ko wamunbilliko, ġatun na-uwil koa bara munmin to, buruġ buġgulliko barun búntoara,
\p 
\v 19 Wiyelliko * * * ġurrabunbilliko wunȧl la pitȧlmullikanne Yehóa koba.
\p 
\v 20 Ġatun noa wirriġ-buġġa biblion,ġatun noaġutéa kan bon umullikan ko, ġatun yellawa barán. Ġatun bara bon pimilliela ġaikuġ ko, yantin thunagóg ka ba ko.
\p 
\v 21 Ġatun noa barun tanoa bo wiya, Turin-pai-béa unni wiya upatoara nurun kin ġurréuġ ka unti purreȧġ ka.
\p 
\v 22 Ġatun yantinto bara ġurrulliela bon, ġatun kota bara pulli murrai kurraka kabiruġ ġikouġ kinbiruġ. Gatun bara wiya, Wiya, unni ta Yothepúmba yinal?
\p 
\v 23 Ġatun noa barun wiya, Nura ta wiyánu̇n tia unni wiyellikanne, Karákal, turon bi umulla gintoa bo; ġurra ġéen ba umatoara Kapernaum ka, umulla bi unti yantin ta purrai ta ġiroúmba ka.
\p 
\v 24 Ġatun noa wiya, Tuloa nurun bag wiyan, keawai propet ġurrá korien ġikouġ ka ta purrai ta kóti ka
\p 
\v 25 Wonto baġ ba nurun wiyan tuloa, kauwȧl-kauwȧl ta mabogun Ithȧrael kulléu̇n purreȧġ ka Elia-úmba ka, yakita wirriġbakulla moroko ta wunȧl ta ġoro ġatun yellenna hek ta, tara-wará kakulla yantin ta purrai kariġ ka;
\p 
\v 26 Keawai Elianuġ yuka ba barun kinko, wonto ba Tbarepta kako Thidoni kako nukuġ kako mabogun tako.
\p 
\v 27 Gatun kauwȧhkauwȧlkan leprokan Ithȧrael ka, yaki-kȧlai Eliéu koba propet koba; keawaran wakál barun kinbiruġ turon umatoara, wonto ba noa Naaman Thuriakȧl.
\p 
\v 28 Ġatun yantin bara kakulla thunagóg ka, ġurra bara unni tara, bukka kauwȧl kakulla
\p 
\v 29 Ġatun bouġkulleu̇n,ġatun yipa bon kokerá biruġ,ġatun bon yutéa pita kako bulkȧrá ko kokerá ko wittitoara ko, wareka uwil koa bara bon walluġgón barán.
\p 
\v 30 Wonto noa ba uwolliela Willi koa barun katoa, waita uwa.
\p 
\v 31 Ġatun noa uwa barán Kapernaum kako, kokerá ko Galilaia kako, ġatun wiyelliela barun purreáġ ka thabbat ka.
\p 
\v 32 Ġatun bara kota wiyellikanne tin ġikoúmba tin; kulla ġikoúmba pulli kaiyukan.
\p 
\v 33 Ġatun kakulla wakȧl ku̇ri thunagóg ka, ġikouġ kin minki ka marai kakulla diabol koba yarakai koba, ġatun noa kaipulléu̇n wokka,
\p 
\v 34 Wiyelliela, Kȧmunbilla ġearun; minnuġ banu̇n ġéen bin ġintoa Iéthu Nadharetkȧl? uwa bi ġearun tetti-umulli kolaġ? ġimillin banuġ ġintoa ta; wakȧl bo ta yirri-yirri-kan Eloi koba.
\p 
\v 35 Ġatun bon Iéthuko koakulla, wiyelliela, Kaiyellia bi, ġatun paikulléa ġikouġ kinbiruġ. Ġatun bon ba wareka willi ka diabollo, paikulléu̇n noa ġikouġ kinbiruġ, ġatun keawai bon tetti búntima ba.
\p 
\v 36 Ġatun bara yantinto kota, ġatun wiyelliela barabo-barabo, Minariġ unni wiyellikanne! kulla noa wiya kaiyu-kan-to barun diabolnuġ yarakaikan, ġatun barun paikulléu̇n warrai tako.
\p 
\v 37 Ġatun totóġ ġikoúmba kakulla yantin toa purrai kariġ koa.
\p 
\v 38 Ġatun noa uwa thunagóg kabiruġ, ġatun polóġkulléún Thimon kinko kokerá ko. Ġatun tunkán Thimonúmba nukuġ koba munni kakulla karinkan; ġatun bon bara wiya bounnoun kai kolaġ.
\p 
\v 39 Ġatun noa ġarokéa bounnoun kin turruġ ka, ġatun noa koakulla karin; ġatun wareka ġaiya bounnoun karinto; ġatun bountoa bouġkulléu̇n tanoa-kȧl-bo, ġatun umulliela barun kaiko.
\p 
\v 40 Ġatun punnȧl ba pulóġ-kulliléu̇n, yantin bara mankulla munni-munni-kan ġikouġ kinko; ġatun noa wunpilléu̇n barun kin mȧttȧra yantin ta, ġatun turon uma barun.
\p 
\v 41 Ġatun diabol kauwȧl-kauwȧl paikulléu̇n kauwȧl-kauwal labiruġ, kaibulliela, ġintoa ta Kritht ta, yinal ta Eloi-koba. Ġatun noa barun koakulla wiya korien; kulla wal bara ġimilléu̇n bon Kritht ta noa unnoa.
\p 
\v 42 Ġatun purreȧġ ba kakulla, waita noa uwa korariġ; ġatun bara kúriko tiwa bon, ġatun uwa ġikouġ kin, ġatun mima bara bon, keawai noa waita wapa barun kinbiruġ.
\p 
\v 43 Ġatun noa wiya barun, Wiyȧnún bo ta wal bag piriwȧlġél la Eloi koba taraikan ta kokerá; kulla wal tia ġaliko yuka.
\c 5
\p 
\v 1 ĠATUN yakita kakulla, warapa bon ba bara kuriko, ġurrulliko wiyellikanne Eloi koba,ġarokéa noa pitta ka waraka Gennetharet ta,
\p 
\v 2 Ġatun nakulla buloara murrinauwai kakilliela wara ka; wonto ba bara makoroban waita uwa murrinauwai tabiruġ, ġatun bara umulliela pika mirkun.
\p 
\v 3 Ġatun noa uwa wakȧl la murrinauwai ta Thimon koba ka, ġatun wiya bon yóġyóġ umullia purrai tabiruġ. Ġatun noa yellawa barán, ġatun wiyelliella barun ku̇ri murrinauwai kabiruġ.
\p 
\v 4 Ġatun ġoloin noa ba wiya, wiya noa Thimónnuġ bon, Tuirkullia pirriko kako, ġatun wura pika nurúnba mankilliko.
\p 
\v 5 Ġatun Thimónto, wiyelliela, wiya bon, Piriwȧl, uma ġéen tokoi ta yanti-katai, ġatun man korien; kulla bi wiyán wupinu̇n wal baġ barán pika.
\p 
\v 6 Ġatun uma bara ba unni, kokoi-kokoi bara uma makoro katai kal, ġatun pika kilpaiya.
\p 
\v 7 Ġatun bara wokkaimulléu̇n barúnba tarai taba murrinauwai taba; wa-uwil koa barun wintamulliko. Ġatun bara uwa, ġatun warapál bara wupéa buloara murrinauwai, pillukulliela ġaiya bara.
\p 
\v 8 Nakulla noa ba Thimónto Peterko, puntimulléȧn noa Iéthu kin warómbuġ ka, wiyelliela, Ela Piriwȧl! yuriġ bi wolla emmouġ kinbiruġ; kulla baġ yarakairán ku̇ri kȧtan.
\p 
\v 9 Kulla noa kota, ġatun yantin bara ġikouġ katoa ba, kauwȧllin makorrin mankulla bara ba.
\p 
\v 10 Ġatun yantibo bara Yakobo ġatun Ioanne, yinal ta Lebedaio koba, mankillai bula ba Thimon katoa. Ġatun Iéthako noa wiya bon Thimóunuġ, Kinta kora bi; yakita biruġ manún wal bi barun ku̇ri.
\p 
\v 11 Ġatun mankulla bara ba murrinauwai barán purrai tako, wúnkulla bara yantin, wirroba bon bara.
\p 
\v 12 Ġatun yakita kakulla, kakulla noa ba tarai ta kokerá, a! wakȧl kúri kauwȧl leprokan; nakilliela noa Iéthunuġ puntimulléu̇n ġoarrá ko, ġatun wiya bon, wiyelliela, Piriwȧl, wiya, bi ba kalyukan kȧnún, umȧnu̇n bi tia turon.
\p 
\v 13 Ġatun noa bon wupilléu̇n mȧttȧra ġikouġ kin, wiyelliela, Kauwá; turon bi kauwa. Ġatun tanoa-kȧl-bo leprota wareka ġikouġ kinbiruġ ko.
\p 
\v 14 Ġatun noa bon wiya, wiyéaku̇n koa noa barun ku̇ri; wonto ba yiruġ uwa tu̇ġunbilliko ġintoa bo hiereu kinko, ġatun ġu̇wa kulla bi turon umatoara, yanti to Mothé ka noa ba wiya, ġurrulliko kakilliko barun.
\p 
\v 15 Wonta ba yantin kakulla totóġ ġikouġ yantin toa purrai toa: ġatun kauwȧlko naro uwa ġurrulliko, ġatun turon kakilliko barun munni-munni ġikouġ kinbiruġ ko.
\p 
\v 16 Ġatun noa uwa koruġ kako, ġatun wiyelliela.
\p 
\v 17 Yakita kakulla tarai ta purreȧġ ka, wiyelliela noa ba, yellawa ba Parithaioi ġatun didathkaloi wiyellikanne koba, yantin tabiruġ kokerá biruġ Galilaia kabiruġ, ġatun Iudaia kabiruġ, ġatun Hierothalem kabiruġ; ġatun kaiynto Yehóa-úmba kakulla turon umulliko barun.
\p 
\v 18 A! ġatun bara ku̇ri wakȧl ku̇ri kurréa pirrikilliġél la munnikan karál; ġatun numa bara bon kurrilliko kokerá kolaġ, ġatun wu̇nkilliko bon ġikouġ kinko mikan tako.
\p 
\v 19 Ġatun keawai bara napa wonnén kurrilliko murruġ kolaġ konara tin, uwa bara wokka laġ kokerá bu̇lwarra ka, ġatun wupéa bon barán kulla koa willi-willi kako pirrikilliġélkan Iéthu kin mikan ta.
\p 
\v 20 Ġatun nakulla noa ba kotellikanne barúnba, wiya noa bon, Ela ku̇ri, yarakai ġirou̇mba wareka ġirouġ kinbiruġ.
\p 
\v 21 Ġatun bara gȧrammateu ġatun Parithaioi kota, wiyelliela, Ġan-ke unni wiyan ba yarakai? Ġanto kaiyu-kan-to warekulliko yarakai, wonto ba wakȧllo Eloito?
\p 
\v 22 Wonto noa ba Iéthuko ġurra kotatoara barúnba, niuwoa wiya wiyelliela barun, Minariġ tin nura kotelliela búlbúl lako nurun kin ba ko.
\p 
\v 23 Wonnén murrȧrȧġ wiyelliko,ġiroúmba ko yarakaito wareka ġirouġ kinbiruġ; ġa wiyelliko, Bouġkullia ġatun uwolliko?
\p 
\v 24 Wonto ba ġurra-uwil koa nura kaiyukan noa yinal ku̇ri koba purrai taba yarakai warekulliko (wiya noa munni karál), Wiyan banuġ, bouġkullia ġatun mara ġirou̇mba pirrikilliġél, ġatun waita unwolla ġirouġ ka tako kokerá ko.
\p 
\v 25 Ġatun tanoa-kȧl-bo bouġulléu̇n noa barun kin mikan ta, ġatun mánkulla unnuġ ġikoúmba pirrikéa noa ba, ġatun waita uwa ġikouġ ka tako kokerá ko koti kako, pitȧlmulliela bon Eloinuġ.
\p 
\v 26 Ġatun yantin bara kotelliela, ġatun bara ġaiya pitȧlma bon Eloinuġ, ġatun kinta laġ bara kauwál, kȧtan wiyelliela, Nakulla ġéen minariġ konéin buġgai.
\p 
\v 27 Ġatun yakita yukita waita uwa noa, ġatun nakulla wakál telónénuġ,ġiakai yitirra Lebi, yellawollin wu̇nkilliġél la; ġatun noa wiya bon, Yettiwolla tia.
\p 
\v 28 Ġatun noa wúnkulla yanti bo bouġkulléu̇n, ġatun noa bon yettiwa.
\p 
\v 29 Ġatun Lebiko bon noa upéa kauwȧl takillikanne ġikouġ ka ta koti ka kokerá: ġatun kauwál kakulla konara telónai ko ġatun tarai to yellawa barun katoa
\p 
\v 30 Wonto ba barúnba gárammateu ġatun Parithaioi koakillan bara barun wirrobullikan ġikoúmba, wiyelliela, Minariġ tin nura tatan ġatun pittan barun katoa telónai koa ġatun yarakai toa?
\p 
\v 31 Ġatun noa Iéthuko wiya barun, wiyelliela, Bara ba moron tai kátan keawai bara wiyan karákál; wonto ba bara munni kátan.
\p 
\v 32 Uwa bag wiya korien ko murroġ taiko, wonto ba yarakai willuġ ko minki kakilliko.
\p 
\v 33 Ġatun wiya bon bara, Minariġ tin bara mupai kátan murrinmurrin wirrobullikan Ioanne-úmba, ġatun wiyan wiyellikanne, ġatun yantibo bara Parithaioi koba; wonto ba ġiroúmba ko tatan ġatun pittan?
\p 
\v 34 Ġatun noa wiya barun, Wiya, nura kaiyukan mupai umulliko barun wonnai kakillaikanne, yakita-kȧlai poribai ba kátan barun katoa ba?
\p 
\v 35 Wonto ba purreȧġ kȧnu̇n wal, mánu̇n wal bon ba poribai barun kinbiruġ, ġatun yakita ġaiya bara mupai-kakillinún purreȧġ ka unta tara.
\p 
\v 36 Ġatun wiya noa barun wakȧl parabol ġiakai: Keawai ku̇ri ko wupillinu̇n buġgaikȧl korokȧl la; ġa ba, yanti buġgaikȧl yiirbuġganu̇n ġaiya wal, ġatun pontol buġgaikȧl labiruġ keawai korokȧl kiloa kȧtan.
\p 
\v 37 Ġatun keawai kúri ko wupinu̇n buġgaikȧl wain pika ka korokȧl la; kulla buġgaikȧllo potopai-yanu̇n wal pika ka, ġatun kiroabullinu̇n, ġatun pika kȧnu̇n yarakai.
\p 
\v 38 Wonto ba buġgaikȧl wain wunu̇n wal buġgaikȧl la pika ka; ġatun buloara murrȧrȧġ kȧtan.
\p 
\v 39 Ġatun keawai ku̇ri koba pittȧnu̇n korokȧl wain keawai noa mánu̇n buġgaikȧl wain, kulla noa wiyan korokȧl ta murrȧrȧġ.
\c 6
\p 
\v 1 ĠATUN yakita thabbat ka buloara, yukita thabbat ka kurri-kurri, uwa ġaiya noa murruġ koa yeaiġél loa; ġatun bara wirrobulli-kan-to ġikouġ ka to tittia wolluġ yeai, ġatun takulla mirro-mirromá mȧttȧra barun kin.
\p 
\v 2 Ġatun taraikanto Parithaioi koba wiya barun, Minariġ tin nura uman unnoa keawaran murrȧrȧġ umulliko unti tara purreȧġ ka thabbat ka?
\p 
\v 3 Ġatun noa Iéthoko wiya, wiyelliela, Wiya nura, wiya nura, wiya ba unni, Dabid-to noa ba upa, niuwoabo ba kapirri kakilla ġatun bara ġikouġ katoa;
\p 
\v 4 Uwa noa ba kokerá kai Eloi koba, ġatun mankulla takulla nulai nakillilkanne, ġatun ġukulla barun ġikouġ katoa ba ko, keawaran murrȧrȧġ takilliko, wonto ba barúnba ko hiereu koba?
\p 
\v 5 Ġatun noa barun wiya, Yinal ta ku̇ri koba, piriwál noa kȧtan yantin ko thabbat ko.
\p 
\v 6 Ġatun yakita kakulla tarai ta thabbat ta, uwa ġaiya noa thunagóg ka ġatun wiyelliela: ġatun wakȧl kúri unta kakulla, mȧttȧra ġikoúmba túġkaġkeri tirrai kakulla.
\p 
\v 7 Ġatun bara gȧrammateuko ġatun Parithaioiko tumiméa bon, wiya bon noa ba turon umulla purreáġ ka thabbat ta; wiyayemma-uwil koa bara bon.
\p 
\v 8 Wonto noa ba kota barúnba ġurrulliela, wiya bon noa mȧttȧrakan tirraikan, Bouġkullia, ġatun ġarokilla Willi ka. Ġatun noa bouġkulléu̇n, ġatun ġarokéa.
\p 
\v 9 Wiya ġaiya noa Iéthuko barun, Wiyánún wal bag nurun unni; wiya tuloa ta umulliko, murrárág ġa yarakai umulliko purreáġ, ka thabbat ta? moron umulliko, ġa warekulliko?
\p 
\v 10 Ġatun nakilliela kari-kari yantin barun, wiya bon noa, Tutullia bi mȧttȧra ġiroúmba. Gatun upulléu̇n ġaiya noa, ġatun mȧttȧra ġaiya bon turon uma yanti tarai ba.
\p 
\v 11 Ġatun bara warapalkan bukkakan kakulla; ġatun murrȧrȧg wiyellan barabo-barabo, minnuġ banún bara bon ba Iéthunuġ.
\p 
\v 12 Yakita unta purreȧġ ka, uwa noa bulkára kolaġ wiyelliko, yanti-katai noa tokoi ta wiyelliela bon Eloi-nuġ.
\p 
\v 13 Ġatun yakita purreȧġ ta, kaai ba noa barun wirrobullikan ġikoúmba; ġirimulléu̇n noa barun kinbiruġ dodeka niuwoa, barun wiya ġiakai yitirra apothol;
\p 
\v 14 Thimónnuġ (wiya noa ġiakai yitirra Peternuġ), ġatun ġikou̇mba kurrakóġ Andrea, ġatun Yakobo ġatun Ioanne, ġatun Pilip ġatun Bátolomai,
\p 
\v 15 Mattaio ġatun Thoma, ġatun Yakobo Alpai-úmba, ġatun Thimon ġiakai wiya yitirra Dheloté,
\p 
\v 16 Ġatun Iudath kurrakóġ ta Yakobo-úmba, ġatun Iudath Ithȧkariot, ninwoa ġakoiyayé noa.
\p 
\v 17 Ġatun noa uwa barán barun katoa, ġatun ġarawan tako ġarokéa noa, ġatun konaró wirrobullikan ġikou̇mba, ġatun kauwȧl konara ku̇ri Iudaiakȧl, ġatun Hierothalemkȧl, ġatun korowȧtari Turokȧl ġatun Thidonikȧl, uwa bara ġurrulliko bon, ġatun turon umulliko barun ba munni;
\p 
\v 18 Ġatun bara wonkȧlman yarakai to marai to: ġatun barun umá turon.
\p 
\v 19 Ġatun yantinto konaró numulla bon bara; kulla murrȧrȧġ paibéa ġikouġ kinbiruġ, ġatun noa turon umá yantin barun.
\p 
\v 20 Gatun noa wokkalan nakulla ġaikuġ ko ġikoúmba wirrobullikan, ġatun wiya, Murrȧrȧg umatoara mirrȧlko; kulla nurun ba piriwȧlġél la Eloi koba.
\p 
\v 21 Murrȧrȧg umatoara nura kapirrikan yakita: kulla nura warapan wal kakilliko. Murrȧrȧg umatoara nura túnkillin yakita, kulla nura kintellinu̇n wal.
\p 
\v 22 Murrȧrȧg umatoara nura, yarakai umȧnu̇n ġaiya nurun ku̇ri ko, ġatun warekanu̇n nurun, ġatun yarakai wiyȧnu̇n nurun, ġatun warekanu̇n yitirra nuru̇nba yanti yarakai ba, ġikouġ kin biruġ yinal ku̇ri koba kabiruġ.
\p 
\v 23 Pitál nura kauwa ġatun úntellia unta purreáġ ka; kulla nurúnba ġukillikanne kauwȧl kátan moroko kaba; yanti umá bara biyuġbai tako barun ka to barun propetnuġ.
\p 
\v 24 Yapal nura porólkan kȧtan! kulla nura mankulla ta pitȧl nurúnba.
\p 
\v 25 Yapál nura warakan! kulla nura kapirrikȧnu̇n. Yapal nura kintellan yakita! kulla nura ġirellinun ġatun túnkillinu̇n.
\p 
\v 26 Yapal nura, murrȧrȧg wiyȧnu̇n ba yantinto kuriko nurun! yantibo barúnba biyuġbai ta ko barun ġakoyaye propetnuġ.
\p 
\v 27 Ġiakai baġ wiyan nurun ġurrullikan, Pitȧlumulla barun yarakai willuġ nurúnba; murrȧrȧg umulla barun yarakai nurúnba uman,
\p 
\v 28 Murrȧrȧg barun wiyella koatan nurúnba; ġatun wiyella bon Eloinuġ wiyella barun yarakai nurúnba uman.
\p 
\v 29 Ġatun bu̇nnu̇n ba wakȧl ġan kulló tarai to, tarai ġukillia; ġatun niuwoa manu̇n wurabil ġiroúmba, wiya yikora wiwi manki yikora unni doan.
\p 
\v 30 Ġuwa barun yantin ko wiyellinu̇n ba ġirouġ kin; ġatun niuwoa ba mankulla tullokán ġiroúmba wiya yikora kari bon.
\p 
\v 31 Ġatun unnoa la kotan nura la murrȧrȧg umulliko barun ku̇ri nurun, umulla nura yantibo ta barun.
\p 
\v 32 Kulla nura pitȧlman barun pitȧlman nurun, minariġko-ke unnoa? kulla bara yarakai-kan-to yantibo uman.
\p 
\v 33 Ġatun murrȧrȧg nura umȧnu̇n ba barun ġali murrȧrȧg nurun uman, minariġko-ke unnoa? kulla bara yarakai-kan-to yantibo uman.
\p 
\v 34 Ġatun mumbinu̇n nura ba barun kotan nura willuġbo upilliko barun, minariġko-ke unnoa? kulla bara yarakai willuġ mumbillan barun willuġbo upilliko yantibo.
\p 
\v 35 Wonto ba nura pitȧlumulla barun yarakai willuġ nurúnba; ġatun murrȧrȧġ umulla, ġatun mumbilla kotan keawai willuġbo upulliko; ġatun ġutoara kauwȧl kȧnu̇n nurúnba, ġatun nura wonnai kȧnu̇n wokka koba; kulla noa murrȧrȧġ uman barun wiyapaiye korien ġatun barun yarakai.
\p 
\v 36 Kauwa nura minkikan, yantibo Biyuġbai nurúnba minki kȧtan.
\p 
\v 37 Kota yikora yarakai, ġatun keawai nurun kotȧnu̇n yarakai: pirriralmai yikora nura, ġatun keawai nurun pirriralmanún: warekilla nura, ġatun nurúnba warekȧnu̇n.
\p 
\v 38 Ġuwa, ġatun ġunu̇n wal nurun; warapál, upulla barán, ġatun tolomulla kaumulliko, ġatun kiroabullin barȧn, ġunu̇n wal ku̇ri nurun ġielkaġ ka nurun kin. Kulla yantibo upitoara nura upullin, upéa kȧnu̇n nurun.
\p 
\v 39 Ġatun noa wiya barun wakȧl parabol; wiya, munminto yutinu̇n tarai munmin? wiya, wal bula-buloarabo warakullinu̇n barán kirun tako?
\p 
\v 40 Wirrobullikan ta keawaran noa kauwȧl korien ġikouġ kin piriwȧl la; wonto ba tuloa kȧtan, kȧnu̇n noa yanti piriwȧl ba ġikouġ ba.
\p 
\v 41 Ġatun minariġ tin bi natan moriġ ġirouġ ka ta ba ġaikuġ kaba kurrikóġ kaba, wonto ba na korien bi tulkirri ġaikuġ kaba ġirouġ kinba kóti kaba?
\p 
\v 42 Ġa, yakoai bi wiyan bon kurrikóġ ġirouġ ba, Biġgai, yakoai tia poruġbuġgabunbilla moriġ ġirouġ kinba ġaikuġ kaba, keawai bi ba nakillin tulkirri ġirouġ kaba? ġintoa ġakoiyaye! buruġbuġ ġala kurri-kurri tulkirri ġaikuġ kaba ġirouġ kinba kóti kaba, ġatun nanún ġaiya bi murra-murrȧrȧġ umulliko moriġ ġaikuġ kaba kurrikóġ kaba ġirouġ ka ta ba.
\p 
\v 43 Kulla ba kúlai murrȧrȧġ ta kȧtan, keawai yeai yarakai upin; ġa keawai ku̇lai yarakai ta kȧtan, yeai murrȧrȧġ upin.
\p 
\v 44 Wonto ba yantin ku̇lai ġimilliko kóti tin yeai tin; kulla bara ku̇ri mán korien kokuġ tulkirri-tulkirri tin, ġa titi korien bara botru maro tin.
\p 
\v 45 Murrȧrȧgko noa ku̇riko wupillin noa murrȧrȧġ wunkilligél labiruġ minki kabiruġ búlbúl labiruġ ġikouġ kinbiruġ; ġatun noa yarakai wupullin noa yarakai wunkilliġel labiruġ yarakai ta biruġ minki kabiruġ búlbúl labiruġ ġikouġ kinbiruġ; kulla ġikoúmba ko kurraka ko wiyan kauwȧl labiruġ ko búlbúl labiruġ ko.
\p 
\v 46 Ġatun minariġ tin nura tia wiyan, Piriwȧl, Piriwȧl, ġatun uwa korien nura unnoa tara wiyan nurun baġ ba.
\p 
\v 47 Ġan tia ba uwȧnu̇n emmouġ kin, ġatun ġurran wiyellita emmoúmba, ġatun ġaloa uman, túġunbinu̇n baġ nurun ġan kiloa noa:
\p 
\v 48 Niuwoa ba wakȧl yanti ku̇ri kiloa, wittia noa kokerá ġatun pinnia pirriko, ġatun wupéa tuġga tunuġ ka; ġatun poaikulléu̇n ba tunta-tunta, waiumbul murrá koribibi kokeroa, ġatun ġeawai tolomȧ pa; kulla wal wittia tunuġ ka.
\p 
\v 49 Wonto ba ġurran ġatun uma korien, ku̇ri kiloa noa wittia kokera tuġġa korien purrai ta: waiumbul murrá koribibi ġali, ġatun warakulléu̇n tanoa-kȧl-bo; kauwȧlla unnoa warakullin kokerá koba.
\c 7
\p 
\v 1 WIYA noa ba ġoloin ġikou̇mba wiyellikanne, mikan ta yantin ta ku̇ri ka, uwá noa Kapernaun kako.
\p 
\v 2 Ġatun tarai koba kapȧtin koba umullikan munni kakilliela muluġkilliliela tetti, pitȧl umatoara noa ġikoúmba.
\p 
\v 3 Ġatun, ġurrá noa ba Iéthunuġ, wiyabunbéa noa barun ġarokȧl Hebȧraioi koba, wiyelliela bon uwa-uwil koa noa pirbuġgulliko ġikoúmba ko, umullikan ko.
\p 
\v 4 Ġatun uwá bara ba Iéthu kin, wiya ġaiya bon bara tanoa-kȧlbo wiyelliela, Murrȧrȧġ noa uma-uwil koa noa bon yanti:
\p 
\v 5 Kulla noa pitȧlman ġearúnba ku̇ri, ġatun noa wittia ġearun thunagóg.
\p 
\v 6 Uwa ġaiya noa Iéthu barun katoa. Ġatun kaloġ korien ta noa ba kakulla kokerá kolaġ, yuka noa barun kapȧtinto kóti ta ġikouġ kin wiyelliela bon, Piriwȧl, yanoa bi; kulla bag keawaran murrȧrȧġ korien uwa-uwil koa bi emmouġ kin kokerá:
\p 
\v 7 Yaki tin baġ kota murrȧrȧġ korien bag uwolliko ġirouġ kinko; wonto ba wiyella wakȧl wiyellikanne, ġatun emmoúmba umullikan pirkullinu̇n wal.
\p 
\v 8 Kulla baġ ba kaiyukan wiyelliko, emmouġ kinba bara kakillin army-kan; ġatun baġ wiya wakȧl, Yuriġ, ġatun waita ġaiya noa uwa; ġatun tarai, Kaai, ġatun noa uwa tanan; ġatun emmoúmba umullikan, Umulla unni, ġatun umȧ ġaiya noa.
\p 
\v 9 Iéthuko noa ba ġurrá unni tara, kotelliela noa ġikouġ, ġatun warrakulléu̇n noa, wiya ġaiya noa barun wirroba bon ba, Wiyan baġ nurun, keawaran baġ na pa yanti ġurrullikanne kauwȧl, keawai yanti Ithȧrael la kȧtan.
\p 
\v 10 Gatun bara yukatoara, willuġbo uwolliela kokerá kolaġ, nakulla bon umullikan munni biruġ pirbuġgatoara.
\p 
\v 11 Gatun yakita purreáġ ka yukita, uwa noa kokeroa,ġiakai yitirra Nain; ġatun kauwȧl uwa ġikoúmba wirrobullikan ġatun taraikan kúri ġikouġ katoa.
\p 
\v 12 Ġatun uwa noa ba papai puloġkulliġél la kokerá kolaġ, ġa, tetti kulwon kurrilliela ku̇ri warai kolaġ, wakȧl bo ta yinal tunkán koba bounnoun ba, ġatun maboġun bountoa, ġatun kauwál-kauwál kúri kokerá biruġ uwa bounnoun katoa.
\p 
\v 13 Ġatun nakulla bounnoun noa ba Piriwȧllo, ġurrirra bounnoun noa kakulla, ġatun wiya ġaiya noa bounnoun, Túġki yikora.
\p 
\v 14 Ġatun uwa ġaiya noa, numa kurrilliġél; ġatun bara kurriá bon ba ġakéa korun. Gatun noa wiya, Wuġġurra, wiyan banuġ, Bouġkullia.
\p 
\v 15 Ġatun niuwoa tetti kabiruġ yellawa, ġatun tanoa-kál-bo wiya. Ġatun willuġbo bon noa ġukulla bounnoun kin ġikoúmba ka tunkán ta.
\p 
\v 16 Ġatun bara kakulla kinta yantin; ġatun bara bon pitȧlman Eloinuġ, wiyelliela, Kauwȧl propet ta paipéa ġearun kin, ġatun noa Eloito nakulla ġikoúmba ku̇ri.
\p 
\v 17 Ġatun unni totóġ ġikoúmba kakulla yantin to Iudaia koa, ġatun yantin toa purrai kariġ koa.
\p 
\v 18 Ġatun Ioanne-úmba-ko wirrobullikanto wiya bon unni tara.
\p 
\v 19 Ġatun noa Ioanneto wiya bulun wirrobullikan ġikoúmba, yuka bulun Iéthu kinko, wiyelliko, ġintoa ta uwȧnu̇n? ġa, na-téa kȧnu̇n ġéen taraikan?
\p 
\v 20 Uwa bara ba kúri ġikouġ kinko wiya bara, Ioanneto korimullikanto ġearun yuká ġirouġ kinko, wiyelliko, ġintoa ta uwȧnún? ġa, na-téa kȧnún taraikan?
\p 
\v 21 Ġatun tanoa-kȧl-bo hora ka pirbuġġa noa kauwȧl-kauwȧl munni-munni, ġatun marai yarakaikan; ġatun kauwȧl-kauwȧl munmin umȧ noa barun nakilliko.
\p 
\v 22 Wiya ġaiya noa barun Iéthu, wiyelliela, Waita lag nura, ġatun wiyella bon Iȯannenuġ unni tara nakulla nura ba ġatun ġurra; munmin-tabiruġ-ko natan, wiirwiir-biruġ-ko uwan, wamun-wamun-tabiruġ turon kakulla, woġkȧl-labiruġ ġurran, tetti-kabiruġ bouġkulléu̇n, barun mirrȧl ko wiyan ta Euaġelion.
\p 
\v 23 Ġatun pitȧl-umatoara yantinto niuwara korien kȧnu̇n emmouġ kin.
\p 
\v 24 Ġatun waita ka ba bara ba puntimai Ioanne-úmba, wiya ġaiya noa barun ku̇ri Ioannenuġ bon, Minariġ tin nura koruġ kolaġ nakilliko? koġka toloman wibbi ko?
\p 
\v 25 Minariġ ko nura uwa koruġ kolaġ nakilliko? wakȧl upulléu̇n ku̇ri poitoġ korikin to? A! bara upulléu̇n konéin to ġatun bara murrȧrȧġ kȧtan takilliko, yellawa bara piriwȧlġél la.
\p 
\v 26 Minariġ ko nura uwa koruġ kolaġ nakilliko? wakȧl propet Kauwa, wiyan nurun baġ kauwȧllan noa ba propet kiloa.
\p 
\v 27 Ġali noa wiyatoara upa unni, A! yukan baġ puntimai emmoúmba ġirouġ kin mikan ta, umȧnun wal noa yapuġ ġirouġ.
\p 
\v 28 Kulla baġ wiyan nurun, Keawai propet kauwȧl kȧtan yanti Ioanne noa ba korimullikan porkullitoara nukuġ labiruġ: niuwoa waréa ta kȧtan piriwȧlġél la Eloi koba ka, kauwȧl noa kȧtan ninwoa kiloa.
\p 
\v 29 Ġatun yantinto ku̇riko ġurra bon, ġatun bara telónai, pitȧlma bon Eloi-nuġ, korimatoara kȧtan bara Ioanne kaibiruġ karimulli biruġ.
\p 
\v 30 Wonto ba bara Parithaioi ġatun bara nomikoi ġurramaiġa wiyellikanne Eloi koba barun kin, keawai korimatoara korien Ioanne kai.
\p 
\v 31 Ġatun noa Piriwȧllo wiya, Yakoai kiloa bara ku̇ri untikȧl willuġġél? ġatun minariġ kiloa bara?
\p 
\v 32 Bara yanti wonnai kiloa yellawollin ġukilliġél la, ġatun kaipullin taraikan, ġatun wiyellin, Tirkima ġéen nurun, ġatun keawai nura úntelli korien; minki ġéen kakulla nurun, ġatun keawai nura tuġkilli korien.
\p 
\v 33 Kulla noa Ioanne korimullikan uwa, keawai kunto ta pa, ġa wain keawai pitta pa; ġatun nura wiyan, diabol noa ġikouġ katoa ba.
\p 
\v 34 Yinal ta ku̇ri koba uwa takilliko ġatun pittelliko, ġatun nura wiyan, A! mataye ku̇ri unni, ġatun wain pittaye, kóti ta telónai koba ġatun yarakai willuġ koba!
\p 
\v 35 Wonto ba yautinto wonnaito ġuraki koba ko piralman bon ġuraki.
\p 
\v 36 Ġatun wakȧllo Parithaioi koba ko wiya bon ta-uwil koa noa ġikouġ katoa. Ġatun uwa noa kokerá Parithaio koba, ġatun yellawa noa barȧn takilliko.
\p 
\v 37 Ġatun, a! ġapal wakȧl yarakaikun bountoa ġurrá bountoa ba Téthunuġ bon yellawai takilli taba kokerá Parithaio koba ka, mankulla bountoa wu̇nkilliġél alabathro putillikanne,
\p 
\v 38 Ġatun ġarokéa bountoa tinna ka bulka ka ġikoung kin, túġkillin, ġatun bountoa puntia bounnoun ka to ġurrun to tinna ġikouúmba, ġatun pirripa bounnoun ka to kittuġ ko wolluġ koba ko bounnoun ka to, ġatun búġbúġka bon tinna ġikou̇mba, ġatun putia bon putilliġél lo.
\p 
\v 39 Yakita nakulla noa ba unni ġali Parithaio, wiya bon ba, wiyelléu̇n ġaiya noa ninwoabo minki ka, wiyelliela, Unni ku̇ri propet ba noa ġurra pa noa wonta-kan-to ka ġapallo numa bon; kulla bountoa yaraikan.
\p 
\v 40 Ġatun Iéthuko noa wiyayelléu̇n, wiyelliela bon, Thimón, wiya-uwil koa banuġ. Ġatun noa wiya, Piriwȧl, wiyellia.
\p 
\v 41 Tarai ta kakulla ġukillikan wakȧl buloara mumbitoara ġikoúmba; wakȧllo noa mumbilléu̇n pentakothioi denari, ġatun tarai ta pentékonta mumbilléu̇n.
\p 
\v 42 Ġatun keawai bula ġupaiye pa ba yaruġ ka bon, wareká ġaiya noa bulun ba. Wonta kin bulun kinbiruġ pitȧlmanu̇n kauwȧl bon!
\p 
\v 43 Thimónto noa wiya, wiyelliella, Mirka ġikouġ wareka noa ba kauwȧl. Ġatun noa wiya bon, Kota bi tuloa.
\p 
\v 44 Ġatun noa warrakulléu̇n ġapal ko, ġatun wiya Thimónnuġ Natan bi unni ġapal? uwa baġ kokerá ko ġirouġ ka ta ko, keawai bi tia ġupa bato tinna ko; wonto bountoa ba puntia tia tinna bounnoun ka to ġurrun to, ġatun watia bounnoun ka to wolluġ kabiruġ ko kittuġ ko.
\p 
\v 45 Keawai bi tia bu̇ġbúġ ka pa: wonto ba unni ġapal, búġbúġ-kulliela tia tinna yakita biruġ uwa baġ ba.
\p 
\v 46 Keawai bi puti pa emmou̇mba wolluġ kipai to, wonto ba unni ġapal putia emmoúmba tinna kipai to.
\p 
\v 47 Ġiakai tin banuġ wiyan, Yarakai umatoara bounnoun ba kauwál ta warekatoara bounnoun ba; kulla bounnoun pitál-ma kauwál: kulla barúnba warekatoara waréa, pitál-ma bara warea.
\p 
\v 48 Ġatun noa bounnoun wiya, Wareká umatoara ġiroúmba yarakai.
\p 
\v 49 Ġatun bara yellawan ġikouġ kinba takilli taba, bara bo wiyatan minki ka, ġan-ke unni warekan noa yarakai.
\p 
\v 50 Ġatun noa bounnoun wiya, ġurrulli ta biruġ ġiroúmba moron bi kátan; yuruġ bi pitál kakilliko.
\c 8
\p 
\v 1 ĠATUN yakita yukita uwa noa yantin toa purrai toa kokerá, wiyelliela ġatun túġunbilliela totóġ pitálmullikanne bathileia koba Eloi koba: ġatun bara dodeka ta ġikouġ katoa ba.
\p 
\v 2 Ġatun bara nukuġ taraikan, turon umatoara marai yarakai tabiruġ ġatun munni kabiruġ, Mari yitirra ġiakai Magdalakálin, bounnoun kinbiruġ paipéa diabol hepta ta,
\p 
\v 3 Ġatun Ioanna porikunbai Kutha-úmba, Herod-úmba umullikan, ġatun Thuhanna, ġatun taraikan kauwȧl, gala bara ġukulla bon untakȧl tullokan ba biruġ barun kai.
\p 
\v 4 Ġatun uwittillin bara ba ku̇ri kauwȧl-kauwȧl, ġatun uwa ġikouġ kinko, yantin tabiruġ kokerá biruġ, wiya noa unni parabol:
\p 
\v 5 Upillikan noa uwa yeai ko upulliko ġikoúmba ko; ġatun upulliela noa ba, winta porkulléu̇n kaiyinkon ta yapuġ ka; ġatun waita-wa barán, ġatun tibbinto takulla moroko tinto.
\p 
\v 6 Ġatun winta porkulléu̇n tunuġ ka; ġatun poaikulléu̇n ba wokka lag tetti ġaiya kakulla, koito ba bato korien ta.
\p 
\v 7 Ġatun winta porkulléu̇n tulkirri-tulkirrá; ġatun poaikulléu̇n tulkirri-tulkirri matti, ġatun murruġkama.
\p 
\v 8 Ġatun tarai ta pórkulléu̇n purrai murrárȧġ purrai ta, ġatun poaikulléuu̇n wokka lag, ġatun yeai kurria hekaton ta. Ġatun noa ba wiya unni tara, kaaipulléu̇n ġaiya noa, Niuwoa ba ġurréuġ kan kȧtan ġurrulliko ġurrunbunbilla bon.
\p 
\v 9 Ġatun wirrobulli-kan-to ġikoúmba ko wiya bon, wiyelliela, Minariġ ke unni parabol?
\p 
\v 10 Ġatun noa wiya, ġutan ġurrulliko nurun pirriral bathileia koba Eloi-úmba; wonto barun tarai ta parabol la; natan bara keawai bara na pa, ġatun ġurran bara keawai bara ġimilli pa.
\p 
\v 11 Ġiakai ta unni parabol: Yeai ta wiyellikanne ta Eloi koba.
\p 
\v 12 Bara kaiyinkon taba yapuġ kaba ġurrullikan bara; uwa ġaiya noa diabol,ġatun mankulla wiyellikanne barun ba minki kabiruġ búlbúl labiruġ, ġurréa-kún koa bara ġatun moron koa bara katéa-ku̇n.
\p 
\v 13 Bara tunuġ kaba ġurra bara ba wiyellikanne pitálkan to; ġatun unni tara wirra korien kȧtan, kota bara waréa ba, ġatun yakita numullikanne ta waraka ġaiya bara.
\p 
\v 14 Ġatun unnoa tara pórkulléu̇n tulkirri-tulkirrá, bara ba ġurra, waita uwa ġaiya, ġatun murruġkanna umullikannéto ġatun porollo ġatun pirunto moron koba, ġatun yeai kurri korien murrȧrȧġ kakilliko.
\p 
\v 15 Wonto ba unnoa murrȧraġ kaba purrai taba, bara ba ġurra wiyellikanne, tuloakan ġatun murrȧrȧġkan búlbúlkan, tuman bara, ġatun yeai kurrin murroi to.
\p 
\v 16 Keawai kúriko wirroġbanu̇n kalbuġ, wutinu̇n ġaiya tenti ko, ġa wutinu̇n bara ka pinkilliġélla; wonto ba wupinu̇n kaibuġġél la, na-uwil koa bara uwollita ba ko kaibuġ.
\p 
\v 17 Kulla yantin ta ġetti biruġ ġurranu̇n wal kakilliko; ġatun yantin ta yuropatoara biruġ ġurranu̇n wal kakilliko, ġatun paipinu̇n wal.
\p 
\v 18 Yakoai nura ġurrulla; kulla ġikouġ kinba ġunu̇n wal ġikouġ kin; ġatun keawai noa ka korien, mantillinu̇n wal bon ġikouġ kinbiruġ unnoa ta paipitoara ġikouġ kinba.
\p 
\v 19 Ġatun tunkán ġikouġ kinko ġatun bara kóti ta ġikoúmba uwa, ġatun keawai bara wa pa ġikouġ kinko konarrin, kulla kauwȧl waitawollan.
\p 
\v 20 Wintako bon wiya ġiakai, Garokillin bara warrai taba ġikoúmba tunkán ġatun kóti ta, na-uwil koa bara ġirouġ.
\p 
\v 21 Ġatun noa wiyayelléu̇n barun, wiyelliela, Unni tara tia kȧtan emmoúmba tunkán ġatun kóti ta, ġurrullikan wiyellikanne Eloi koba ġatun umullikan.
\p 
\v 22 Ġatun yakita tarai ta purreȧġ ka, uwa noa murrinauwai ta ko ġikouġ katoa wirrobullikan toa ġikoúmba; ġatun noa barun wiya, Waita ġéen waiġa-uwil kaiyin kolaġ wara kolaġ. Ġatun bara tolka mureuġ kolaġ.
\p 
\v 23 Wonto ba bara uwolliela, pirrikéa noa kóġóġ; ġatun wibbi kauwȧl kakulla wara ka; ġatun bara warapál, ġatun kinta kakilliela.
\p 
\v 24 Ġatun bara uwa ġikouġ kin, bouġbuġġa ġaiya bon, wiyellielia, Piriwȧl, piriwȧl, tetti kolaġ ġéen! Bouġkulléu̇n ġaiya noa, ġatun wiya noa wibbi, ġatun tulkun wombul koba; ġatun korun kakulla, ġatun yuraġ ġaiya kakulla.
\p 
\v 25 Ġatun noa wiya barun, Wonnuġ-ke nurun kotellita? Ġatun bara kinta kakulla, kotelliela, wiyalan taraikan-taraikan, Wontakan unni ku̇ri! kulla noa wiyan wibbi ġatun bato, ġatun ġurra ġaiya bon.
\p 
\v 26 Ġatun bara uwa purrai tako Gadarén tako, kaiyin taba Galilaia kaba.
\p 
\v 27 Ġatun noa ba yankulléu̇n purrai tako, nuġgurrawa bon wakállo ku̇riko kokerá biruġ ko, diabolkan noa katalla yuraki, ġatun keawai noa upillipa kirrikin to, keawai noa kȧtan kokerá, nikki ka noa kakulla.
\p 
\v 28 Nakulla noa ba Iéthunuġ, kaaibulléu̇n ġaiya noa, ġatun puntimulléu̇n ġikouġ kin mikan ta, ġatun wokka wiyelléu̇n wiyelliela, Minnuġ banu̇n ke bi tia, Iéthu, Yinal ta Eloi koba wokka kaba koba? Yanoa bi tia piralmai yikora.
\p 
\v 29 (Kulla noa wiya marai yarakaikan paikulliko kúri kabiruġ. Kulla bon mankulla murrin-murrin; ġatun wirria bon tibon ko; ġatun noa tiirbuġġa tibon, ġatun yuaipéa bon diabollo koruġ kolaġ).
\p 
\v 30 Ġatun Iéthuko noa wiya bon, wiyelliela, Wonnén bi yitirra? Gatun noa wiya, Léjun baġ; kulla kauwȧl-kauwȧl diabol uwa murrariġ ġikouġ kinko minki kako.
\p 
\v 31 Ġatun bara bon wiya, Yanoa, wiya yikora ġearun bi pirriko kolaġ kakilliko.
\p 
\v 32 Ġatun kakulla untakȧl wirrul takilliela bulkȧra ba ko; ġatun bara wiya bon pulóġkulliko barun minki kako porȧk kako. Ġatun noa wamunbéa barun.
\p 
\v 33 Uwa ġaiya bara waita diabol minki tabiruġ ku̇ri kabiruġ, ġatun pulógkulléu̇n porȧk ka koiro ka; ġatun wirrul murra barán karakai pirriko koba wara kako, kurrin to ġaiya bara.
\p 
\v 34 Nakulla bara ba tamunbéa unnoa tara umatoara, murra ġaiya bara, ġatun waita uwa kokerá kolaġ, ġatun ġoruġ kolaġ; wiya ġaiya ġaloa.
\p 
\v 35 Uwa ġaiya bara nakilliko umatoara ko; ġatun uwa Iéthu kin, ġatun nakulla bara bon unnoa ku̇ri, paipitoara biruġ bara waita uwa, yellawolliela Iéthu ka ta tinna ka, kirrikinkan ġatun tuloa ġurrullikan; ġatun kinta bara kakulla.
\p 
\v 36 Yantinto nakulla unnoa wiya barun, yanti bon ba turon uma diabolkan kauwȧlkan.
\p 
\v 37 Ġatun yantinto konaró purrai tako Gadarén tako wiya gaiya bon waita uwolliko barun kinbiruġ; kulla bara kintakan kauwȧl kakulla. Ġatun noa uwa murrinauwai tako, ġatun wulluġbo kakulla.
\p 
\v 38 Ġatun unnoa ku̇ri kabiruġ diabol bara waita uwa, wiya bon ka-uwil koa noa ġikouġ katoa: wonto noa Iéthuko yuka bon waita, wiyelliela,
\p 
\v 39 Willuġbo bi wolla ġirouġ ka tako kokerá ko, ġatun gurrabunbilliko unnoa tara uma noa ba Eloito ġirouġ. Ġatun noa waita uwa, ġatun wiya yantin toa kokeroa, yanti Iéthuko noa uma bon.
\p 
\v 40 Ġatun yakita kakulla, willuġbo noa ba Iéthu kakulla, pitȧl tara kakilliela ku̇ri, kulla bara bon mittilliela yantinto.
\p 
\v 41 Ġatun yakita uwa wakȧl ku̇ri tanan,ġiakai yitirra Yaeiro, wiyellikan noa thunagóg kako; ġatun noa puntimulléu̇n Iéthu kin tinna ka, ġatun wiya uwolliko ġikouġ kinko kokerá ko;
\p 
\v 42 Kulla bon wakȧl yinálkun kakulla, dodeka wunȧl ta bounnoun ba, ġatun bountoa pirrikilliela tetti kakilliela. Gatun uwa ġaiya noa, ku̇riko bon murruġkama.
\p 
\v 43 Ġatun wakál nukuġ, kumarakan dodeka wunȧl ta bounnoun ba, ġukilléu̇n bountoa kirun tullokan bounnoúnba karákȧl ko, keawai bara bounnoun turon uma pa,
\p 
\v 44 Uwa bountoa bulka kako, ġatun numa pita ġikoúmba kirrikin: ġatun tanoa-kȧl-bo kumara ġaiya kakulla korun.
\p 
\v 45 Ġatun noa Iéthuko wiya ġaiya, Ġanto tia numa? Yantinto wiya keawai, wiya ġaiya noa Peterko ġatun bara ġikouġ katoa, Piriwȧl, konaro bin murruġkama ġatun waita wa, ġatun bi wiyan, Ġanto tia numa?
\p 
\v 46 Ġatun noa Iéthuko wiya, Wakȧllo ta tia numa: kulla baġ ġurran waita ka ba kaiyu emmouġ kinbiruġ.
\p 
\v 47 Ġatun bountoa ba nukuġko nakulla yuropa korien bountoa, uwa bountoa pulul-pulul, ġatun puntimulléu̇n ġikouġ kin mikan ta, wiya bon bountoa mikan ta yantin ta ku̇ri ka, minariġ tin bountoa numa bon, ġatun tanoa-kȧl-bo bountoa kakulla turon.
\p 
\v 48 Ġatun noa bounnoun wiya, Yinálkun, kauwa bi pitȧl; ġurrullito ġiroúmba-ko turon bin uma; yuriġ waita pitȧl kakilliko.
\p 
\v 49 Ġatun wiyelliela noa ba, tanan uwa wakállo wiyellikan ta biruġ kokerá biruġ, wiyelliela bon, Ġiroúmba yinálkun tetti kakulla; yanoa, Piriwȧl pirriralmai yikora bon.
\p 
\v 50 Wonto noa ba Iéthuko ġurra, wiyayelléu̇n noa bon wiyelliela, Kinta kora bi; ġurrulla wal bi, ġatun turon ġaiya wal bountoa kȧnu̇n.
\p 
\v 51 Ġatun noa ba uwa kokerá ko ba murriraġ, keawai noa tarai kan wommumbi pa ġikouġ kin, wonto ba Peternuġ ġatun Yakobonuġ, ġatun Ioannenuġ, ġatun biyuġbai ġatun tunkán murrakin koba.
\p 
\v 52 Ġatun yantin tuġkilléu̇n ġatun minki kakulla bounnoun kai: wonto noa ba wiya, Tuġki yikora; keawaran bountoa tetti korien, wonto ba ġarabo kakillin.
\p 
\v 53 Ġatun bara bon béelma, nakilliela tetti bountoa kakulla.
\p 
\v 54 Ġatun noa kirun barun yipa warai tako, ġatun noa mankulla bounnoun muttȧrrin, ġatun wiya, Murrakin, bouġkullia.
\p 
\v 55 Ġatun bounnoun ba marai katéakan, ġatun bountoa bouġkulléu̇n tanoa-kȧl-bo: ġatun noa wiya bounnoun takilliko.
\p 
\v 56 Ġatun kintakan biyuġbai ġatun tunkán bounnoun ba: wonto noa ba wiya barun, yanoa wiya yikora taraikan ku̇ri unni umatoara.
\c 9
\p 
\v 1 WIYA ġaiya noa barun dodeka ta ġikou̇mba kaumulliko, ġatun ġukulla barun kaiyu kakilliko ġatun wiyellikan kakilliko yantin ko diabol ko, ġatun turon umulliko yantin munnikan ko.
\p 
\v 2 Ġatun noa barun yuka wiyelliko bathileia Eloi koba, ġatun turon umulliko munni ko.
\p 
\v 3 Ġatun noa wiya barun, Manki yikora waita kolaġ, keawai tupa-tupa mánu̇n, keawai yinuġ, keawai kunto, keawai money, keawai buloara mánu̇n kirrikin taraiko-taraiko.
\p 
\v 4 Ġatun uwȧnu̇n nura ba tarai ta kokerá, tanoa kauwa, ġatun waita uwolla untoa biruġ.
\p 
\v 5 Ġatun bara keawai nurun wommunbi korien, waita nura ba uwȧnu̇n untoa biruġ kokerá biruġ, tirri-tirrillia yullo kabiruġ moriġ tinna kabiruġ nurun kinbiruġ, túġa kakilliko barun kinko.
\p 
\v 6 Ġatun waita bara uwa, ġatun uwa kokeroa Willi koa, wiyelliela Euaġelion, ġatun turon umulliela yantin ta purrai ta.
\p 
\v 7 Ġatun noa Herodto tetrákko ġurra unni tara umá noa ba; ġatun koteiliela niuwoa bo, kulla wiyatoara tarai-kan-to Ioanne noa bouġkulléa tetti kabiruġ;
\p 
\v 8 Ġatun winta ka, paipéa noa Elia; ġatun tarai-kan-to, wakȧl ġaġka-kȧl propet tabiruġ bouġkalléu̇n.
\p 
\v 9 Ġatun noa Herod wiya, Kolbu̇ntia baġ bon Iaonnenuġ wolluġ; ġan-ke unni ġurran baġ unni tara? ġatun noa na-uwil koa bon.
\p 
\v 10 Ġatun bara apothollo willuġbo bara ba kakulla, wiya ġaiya bon yantin unni tara uwa bara ba. Ġatun noa barun yutéa, ġatun kara uwa mirrulla ko, kokerá ko yitirra Betáthaida kako.
\p 
\v 11 Ġatun bara ku̇ri ġurra bara ba, wirropa bara bon; ġarokéa noa wiyelliko barun bathileia Eloi koba, ġatun umá barun turon kakilliko munnikan.
\p 
\v 12 Ġatun purreȧġ kakilliela yaréakȧl, uwa ġaiya bara dodeka ta, ġatun wiya bon, Yukulla barun konara waita laġ, uwa-uwil koa bara yantin toa purrai kariġ koa, yellawolliko, ġatun takilliko; kulla ġéen kȧtan unti mirrul la.
\p 
\v 13 Wonto noa ba barun wiya, Ġuwa barun ġaloa ko takilliko. Ġatun bara wiya, Keawai ġearu̇nba kulla unni pente kunto ġatun buloara makoro; wiya ġéen wirrilla barun ġali ko takilliko yantin ko ku̇ri ko.
\p 
\v 14 Kulla wal ku̇ri kauwȧl pentakikilioi ta. Ġatun noa wiya barun wirrobullikan, Yellawabunbilla barun konara kakilliko pentékonta tarai taba kakilliko.
\p 
\v 15 Ġatun uma ġaiya bara yanti, ġatun yellawabunbéa barun yantin barán.
\p 
\v 16 Mankulla ġaiya noa unnoa tara kunto pente ġatun makoro buloara; ġatun nakilliela wokka laġ moroko koba, murroi wiyelliela unni tara, ġatun yiirbuġga, ġatun ġukulla barun wirrobullikan ko wunkilliko barun kin mikan ta konara.
\p 
\v 17 Ġatun takulla bara, ġatun warakan ġaiya bara kuttawan yantin; ġatun mankulla bara wanan dodeka ka wimbi ka wuntawai biruġ barun kai.
\p 
\v 18 Ġatun yakita wiyelliela noa ba niuwoa-bo púnbai, ġikoúmba wirrobullikan ġikouġ katoa; ġatun noa wiya barun, wiyelliela, Ġannuġ wiyan ku̇ri ko ġan baġ ba.
\p 
\v 19 Wiyayelléu̇n bara; wiyelliela, Ioanne ta bi korimullikan wonto ba taraito wiyan Elia ta ba; ġatun taraito wiyan wakȧl ġaġka-kȧl propet koba, bouġkulliakan katéa-kȧn.
\p 
\v 20 Wiya noa barun, ġanto tia nura wiyan ġan baġ ba? Peterko noa wiyayelléu̇n, wiyelliela, Kritht ta bi Eloi-úmba.
\p 
\v 21 Ġatun noa barun piralma, wiyéa-kȧn koa bara unnoa tara tarai ko ku̇ri ko;
\p 
\v 22 Wiyelliela, Yinal ta ku̇ri koba yarakai kauwȧl wal bon umȧnu̇n, ġatun warekȧnu̇n wal bon bara ġaġkakal ġatun bara hiereukan piriwȧl, ġatun bara gȧrammateukan, ġatun búnnu̇n wal tetti, ġatun bouġgánu̇n ġaiya bon tarai ta purreȧġ ġoro ka.
\p 
\v 23 Ġatun wiya noa barun yantin, Wanu̇n tia ba taraikan ku̇ri uwȧnu̇n, ġurrullia noa niuwoa-bo, ġatun mara-uwil koa noa taliġkabillikanne ġikoúmba yantin ta purreȧġ ka, ġatun wirrobulla tia.
\p 
\v 24 Ġanto ba miromȧnu̇n moron ġikoúmba, warekȧnu̇n wal noa? kulla noa warekȧnu̇n moron ġikoúmba emmouġ kin, ġaloa noa moron umȧnu̇n.
\p 
\v 25 Wonnuġ-ke murrȧrȧġ ku̇ri ko, mankilliko purrai kariġ ko, ġatun noa tetti wal ġaiya kȧnu̇n niuwoa-bo, ġa warekȧnu̇n wal?
\p 
\v 26 Ġan tia ba koiyun kȧnu̇n emmouġ kai, ġatun wiyellikanne emmoúmba, Yinal ku̇ri koba koiyun ġikouġ kai, uwȧnu̇n noa ba killibinbinkan kóti ġikouġ kinba, ġatun Biyuġbai koba, ġatun aġelo yirri-yirri-kan koba barúnba.
\p 
\v 27 Kulla bag wiyan nurun tuloa, unni winta ġarokéu̇n ba, keawai bara tetti kȧnu̇n, kabo na-uwil koa bara bathileia-nuġ Eloi koba.
\p 
\v 28 Ġatun yakita kakulla purreȧġ ka ét ta yurika-ta unni tara wiyellikanne, yutéa noa barun Peternuġ, ġatun Ioannenuġ, ġatun Yakobonuġ, ġatun uwa wokka laġ bulkȧra kolaġ wiyelliko.
\p 
\v 29 Ġatun noa ba wiyelliela, takin bon tarai warrakulléu̇n, ġatun ġikoúmba kirrikin purrul kakulla, ġatun killibinbin kakulla.
\p 
\v 30 Ġatun wiyelliela bon ku̇riko Mothéko ġatun Eliako:
\p 
\v 31 Paipéa bula killibinbin, ġatun wiya bula ġikoúmba (tetti?) tin ka-uwil koa Hierothalem ko.
\p 
\v 32 Wonto ba Peter noa ġatun bara ġikouġ katoa porrólkan bara birikéa kóġóġ; ġatun bara kakulla tiraġ, nakulla bara gikoúmba killibinbin, ġatun buloara bula ku̇ri ġarokéa ġikouġ katoa.
\p 
\v 33 Ġatun kakulla yakita bula ba waita uwolliela ġikouġ kinbiruġ, Peterko noa wiya bon Iéthunuġ, A! Piriwȧl, murrȧrȧġ ġearun unti ko kakilliko; ġatun umabunbilla ġoro kokerá; wakȧl bin, ġatun wakȧl Mothénuġ, ġatun wakȧl Elianuġ, ġurra korien minariġ noa wiya.
\p 
\v 34 Wiyelliela noa ba, yareil kakulla, ġatun wutéa barun; ġatun bara kinta kakulla, waita bara ba wolliela murrariġ yareil la.
\p 
\v 35 Ġatun pulli kakulla yareil labiruġ, wiyelliela, Unni ta emmoúmba kóti yinal pitȧlmullikan; ġurrulla bon.
\p 
\v 36 Ġatun pulli ba kakulla korun, Iéthu noa kakilliela pu̇nbai. Keawai bara unni tara wiya pa untatoara, natoara purreȧġ ka taraikan ta.
\p 
\v 37 Ġatun yakita kakulla purreȧġ ka tarai ta unta, uwa bara ba barán bulkȧra biruġ, kauwȧllo ku̇riko nuġgurra wa bon.
\p 
\v 38 A! ġatun wakȧl ku̇ri konara koba kaaibulléu̇n, wiyelliela, Piriwȧl, kai bi, na-uwillia yinal emmoúmba; kulla noa emmou̇mba wakȧl wonnai.
\p 
\v 39 A! ġatun maraito bon mankulla, ġatun ġaiya noa kaaibulléu̇n wokka; ġatun yiirbuġga bon, ġatun kurraġtoanbuġġa; ġatun búntoara noa, waita ġaiya ġikouġ kinbiruġ uwa.
\p 
\v 40 Ġatun baġ wiya barun wirrobullikan ġiroúmba warekulliko bon; keawai bara kaiyu korien.
\p 
\v 41 Ġatun noa Iéthuko wiya, wiyelliela, A! ġurra korien ġatun pirriral unni willuġ-ġél! Yakounta-laġ baġ kȧnu̇n nurun kin, ġatun wal baġ kȧmunbinu̇n nurun? Mara bon tanan ġiroúmba yinal unti ko.
\p 
\v 42 Ġatun uwolliela noa ba tanan diabollo bon puntima barán ġatun yiiryiir uma. Ġatun noa Iéthuko koakulla bon marai yarakai ka, ġatun bon wonnai turon uma, ġatun ġutéakan ġaiya bon biyuġbai ta ġikoúmba tin.
\p 
\v 43 Gatun yantin bara kinta kakulla kaiyu tin kauwȧl lin Eloi koba tin; ġatun kotelliela bara ba yantin unni tara Iéthuko noa ba uma, wiya ġaiya noa barun wirrobullikan ġikoúmba,
\p 
\v 44 Kȧmúnbilla unni tara wiyellikanne murriraġ ġurréuġ kako nurun kin; kulla noa Yinal ku̇ri koba wupinún wal bon mattȧra ku̇ri ka.
\p 
\v 45 Keawai bara ġurra pa unni wiyellikanne, ġatun yuropa ġali barun kinbiruġ, keawai bara ġimilli korien; ġatun bara kinta kakulla wiyelliko bon ġali tin wiyellikanne tin.
\p 
\v 46 Yakita ġaiya bara wiyellan barabo-barabo, ġan-ke kȧnu̇n kauwȧl piriwȧl barun kinbiruġ.
\p 
\v 47 Ġatun Iéthuko noa ġimilléu̇n kotatoara bu̇lbúl labiruġ barun kinbiruġ mankulla noa wonnai, ġatun yellawabunbéa bon ġikouġ kin taruġ ka,
\p 
\v 48 Ġatun noa barun wiya, Ġanto ba unni wonnai pitȧlmanu̇n kinba, pitȧl manu̇n ġaiya tia; ġatun ġanto ba tia pitȧlmanu̇n, pitȧlmanu̇n bon ġala yuka tia ba; ġatun niuwoa kȧtan waréa nurun kinba yantin taba, yantibo ta wal noa kauwȧl kȧnu̇n.
\p 
\v 49 Ġatun noa Ioanneto wiya, wiyelliela, Piriwȧl, nakulla ġéen wakȧllo paibuġgulliela barun diabol ġirouġ katoa biruġ yitirra biruġ; wiya ġéen bon yanoa, koito ba keawai noa wa pa ġearun katoa.
\p 
\v 50 Ġatun noa Iéthuko bon wiya, Wiwi yikora; koito noa ba keawai bukka korien ġearun, niuwoa ġearun katoa ba.
\p 
\v 51 Ġatun yakita kakulla purreaġ mánu̇n bon ba wokka kolaġ, pirral noa kakilliela waita Hierothalem kolaġ,
\p 
\v 52 Ġatun noa yuka barun puntimai ġikoúmba ġanka; ġatun bara uwa kokerá kolaġ Thamaria kako, umulliko ġikouġ.
\p 
\v 53 Ġatun bara bon keawai pitȧlma pa, kulla noa pirral kakulla wa pa Hierothalem kolaġ.
\p 
\v 54 Ġatun bula wirrobullikan ġikoúmba, Yakobo ġatun Ioanne, nakulla bula unni, wiya bula, Piriwȧl, wiya bi, wiya-uwil koa ġéen koiyuġ koa kauwȧl barán moroko kabiruġ wina-uwil koa barun, yanti Elia noa ba unnoa?
\p 
\v 55 Wonto noa ba wakulléu̇n, koakulla ġaiya barun noa, ġatun wiya, Keawaran nura gimilli korien nurúnba kóti búlbúl.
\p 
\v 56 Koito ba noa yinal kúri koba keawaran noa tanan wa pa, búnkilliko kúri ko barun, wonto ba murrin umulliko. Ġatun bara uwa tarai tako kokerá ko.
\p 
\v 57 Ġatun yakita kakulla, uwolliela bara ba yuriġ yapuġ koa, taraito bon wiya, Piriwál, wirrobuġbinu̇n banuġ, wontariġ bi ba uwȧllu̇n,
\p 
\v 58 Ġatun noa Iéthuko bon wiya, Murroġ-kai-ko kumiri barúnba, ġatun tibbin moroko ka koba kunta barúnba, wonto ba yinal kúri koba keawaran bon ġikoúmba birrikilli-ġél walluġ ko ġikoúmba ko.
\p 
\v 59 Ġatun noa tarai wiya, Wirrobulla tia. Wonta noa ba wiya, Piriwál, wamunbilla tia ġanka bapa-uwil koa baġ emmoúmba biyuġbai.
\p 
\v 60 Wiya bon noa Iéthuko, Bapabunbilla barun tetti-tetti barúnba; ġintoa yuriġ bi wolla wiyelliko piriwȧl koba Eloi koba.
\p 
\v 61 Ġatun taraito wiya, Piriwȧl, wirrobanún banuġ; wamunbilla tia ġanka wiyellikoa barun baġ unni emmouġ kinba kokerá ba.
\p 
\v 62 Ġatun noa Iéthuko bon wiya, Keawai tarai-kan-to upillinu̇n mȧttȧra purrai-ġél lo, ġatun willuġ-wuminún, keawaran noa murrȧrȧġ korien kakilliko piriwȧl ko Eloi koba ko.
\c 10
\p 
\v 1 YAKITA ġaiya kakulla unni tara, Piriwȧllo noa ġearimulléu̇n thebenty taraikan ta, ġatun yuka barun buloara-buloara ġikouġ kin mikan ta, yantin tako kokerá ko uwȧnun noa ba niuwoa-bo.
\p 
\v 2 Ġatun noa barun wiya, Kauwȧl-lan unni nulai kȧtan, keawai bo katillikan ku̇ri kauwȧlkȧl; ġali tin wiyella nura bon, Piriwȧl nulai-ġél koba yuka-uwil koa noa barun katillikan nulai ko katilliko ġikouġ kaiko.
\p 
\v 3 Waita nura yuriġ wolla: A! yukan nurun baġ waita kolaġ yanti kiloa waréa ta éipu barun kin murroġ ka ta.
\p 
\v 4 Kurri yikora yanoa munniġél, ġatun yinuġ, keawai tuġganuġ; ġatun yanoa wiya yikora yapuġ koa taraikan ku̇ri.
\p 
\v 5 Ġatun uwȧnu̇n nura ba kokerá ko taraikan tako, wiyella, kurri ġiakai, Pitȧl kauwa unni kokerá ba.
\p 
\v 6 Ġatun ba yinal koba pitál koba kánu̇n unta, nurúnba pitȧl kánu̇n ġaiya unta; keawai ba nurun kin katéa kánu̇n willuġbo.
\p 
\v 7 Ġatun yellawȧnu̇n nura unta kokerá, takilliko ġatun pittelliko,ġunu̇n bara ba nurun; kulla noa umulli-kan-to man ba ġutoara ġikoúmba. Uwai yikora kokerá kolaġ kokerá kolaġ.
\p 
\v 8 Ġatun uwȧnu̇n nura ba yantin ta kokeroa, ġatun bara nurun pitȧlmanu̇n, ta-uwa untoa tara wunu̇n ba mikan ta nurun kin.
\p 
\v 9 Ġatun turon barun umulla unta tara; ġatun wiyella barun, Piriwȧl koba Eloi koba papai uwa nurun kinba.
\p 
\v 10 Uwȧnu̇n nura ba tarai ta kokeroa, ġatun bara keawai pitȧlma korien nurun, uwéa ka nura warai tako yapuġ kako, ġatun wiyella,
\p 
\v 11 Umulléún ġéen punul untikȧl ġearun kinba nurun kin; A! kotellia nura unni ta uwan ta papai kȧtan nurun kin piriwȧl koba Eloi koba.
\p 
\v 12 Wiyan nurun baġ, murrȧrȧġ kȧnu̇n unta ta tarai ta purreȧġ, ka Thodom kako, keawaran ġala ko kokerá ko.
\p 
\v 13 Yapallun bi Koradhin! yapallun bi Betȧthaida! kulla umatoara ba kauwȧl-kauwȧl kaiyu biruġ ka pa Turo ka ġatun Thidoni ka uma ġirouġ kin, minki bara ka pa yuraki, yellawa pa bara pirral la kirrikin ta ġatun bonoġ ka.
\p 
\v 14 Murrȧrȧġ buloara kȧnu̇n Turo ġatun Thidoni unta purreȧġ wiyellaikanne ta keawaran bi.
\p 
\v 15 Ġatun ġintoa, Kapernaum, wunkulla wokka laġ moroko ka, yuaipinu̇n wal barán pirri kako.
\p 
\v 16 Niuwoa ġurran nurun ba, ġurran ta noa tia; ġatun niuwoa waitiman nurun ba, waitiman noa tia; ġatun niuwoa tia waitiman, waitiman noa bon yuka noa tia ba.
\p 
\v 17 Ġatun bara thebenty ta willuġbo kakulla pitȧlkan, wiyelliela, A Piriwȧl! ġurrullikan bara diabollo ġearun ġirouġ katoa yitirroa.
\p 
\v 18 Ġatun noa barun wiya, Nakulla bon baġ Thatannuġ puntimulléu̇n barán moroko tin yanti málma kiloa.
\p 
\v 19 A! ġutan baġ nurun kaiyu waitawolliko maiya ko ġatun wuarai ko, ġatun yantin ko kaiyu bukkakan ko; ġatun keawai wal nurun yarakai umulliko.
\p 
\v 20 Pitȧl-mai yikora nura-nura,ġali tin ġurullikan tin bara marai nurun ba; unti biruġ pitȧlma nura, kulla yitirra nurúnba upatoara moroko ka ba.
\p 
\v 21 Yakita ta noa pitȧl-lan kakulla marai ta,ġatun wiyelliela, Kauwa tia yanti, Biyuġ, Piriwȧl ta moroko koba ġatun purrai koba, kulla bi ba unnoa tara yuropa ġali unti biruġ ġuraki ta biruġ, ġatun bi túġkaiya unnoa tara barun boboġ ko; kauwa yanti, Biyuġ, koito ba murrȧrȧġ ta ġirouġ kin kȧtan mikan ta.
\p 
\v 22 Yantin ta tia wupéa emmouġ kinko Biyuġbaito; ġatun keawai ku̇riko bon yinal ġimilli pa, wonto ba Biyuġbaito; ġatun Biyuġbai yinallo ġimilléu̇n, ġatun niuwoa yinallo tu̇ġunbinu̇n bon Biyuġbai.
\p 
\v 23 Ġatun noa willariġ kakulla ġikouġ kai koba wirrobullikan, koba, ġatun wiyelliela kara, Kauwa yanti murrȧrȧġ ta natan ġaikuġ ko unni tara natan nura ba:
\p 
\v 24 Kulla baġ nurun wiyan, kauwȧllo propetto ġatun piriwȧllo na pa unni tara natan nura ba, ġatun bara keawai na korien; ġatun ġurra pa unni tara ġurran nura ba, ġatun keawai ġurra korien.
\p 
\v 25 A! tarai wakȧl nomiko ġarokéa wokka laġ, ġatun wiya bon, wiyelliela, Piriwȧl, minnuġ banu̇n baġ moron kakilliko yantikatai?
\p 
\v 26 Wiya bon noa, Minariġ upa wiyellikanne? yakoai bi wiyan?
\p 
\v 27 Ġatun noa wiyayelléu̇n, wiyelliela, Pitȧl kakilliko bi Piriwȧl ko Eloi ko ġiroúmba ko yantin to búlbuúl lo ġiroúmba ko, ġatun yantin to marai to ġiroúmba ko, ġatun yantin to kaiyu ko ġiroúmba ko, ġatun yantin to kotellitó ġiroúmba ko; ġatun kóti ta ġiroúmba yanti ġintoa bo ba.
\p 
\v 28 Ġatun noa wiya bon, ġintoa wiyayelléu̇n tuloa; unni ta umulla ġatun moron koa bi kauwȧl
\p 
\v 29 Wonto noa ba kotelliela tuloa ko ninwoa bo, wiya bon noa Iéthunuġ, Ġan-ke tia kóti ta emmoúmba?
\p 
\v 30 Ġatun noa Iéthuko wiya, Taraikan waita uwa barán Hierothalem kabiruġ Jeriko kako, ġatun nuġgurrawa mankiye, mantilléu̇n bon kirrikin, ġatun búnkulla, ġatun bara waita uwa wareka ġaiya bon bu̇ntoara.
\p 
\v 31 Yakita ġati uwa wakȧl hiereu barán yapuġ koa; ġatun nakulla bon noa ba, uwa noa taruġ koa kaiyin ta koa.
\p 
\v 32 Ġanti yanti kiloa wakál Lebikan kakulla noa ba unta, uwa nakulla ġaiya bon, ġatun noa uwa taruġ koa kaiyin ta koa.
\p 
\v 33 Wonto ba wakál ku̇ri Thamariakȧl uwolliela ba, uwa yapariġ kakilliela noa ba; ġatun nakulla bon noa ba, minki bon noa kakulla ġikouġ kai,
\p 
\v 34 Ġatun uwa ġikouġ kai koba, ġatun ġira bon búntoara ġikoúmba, kiroabulliela kipai ġatun wain, ġatun yellawabunbéa bon ġikouġ ka ta kóti ka buttikaġ, ġatun yutéa bon takilliġél lako, ġatun miroma bon.
\p 
\v 35 Ġatun tarai ta purreȧġ ka wakȧl la waita noa ba uwa, mankulla ġaiya noa buloara denari, ġatun ġukulla kokeratin ko, ġatun bon wiya, Golomulla bon; kirun bi ba upinún, uwéa kȧnu̇n baġ ba willuġbo, ġutéa kȧnu̇n ġaiya banuġ.
\p 
\v 36 Wonnuġ-ke kóti ta ġikoúmba nuġgurrawa mankiye unti biruġ ġoro kabiruġ ku̇ri kabiruġ, kotella bi?
\p 
\v 37 Ġatun noa wiya, Niuwoa ġoloma bon. Wiya noa bon Iéthu ko, Yuriġ, yanti kiloa umulla bi.
\p 
\v 38 Ġatun yakita kakulla, uwa bara ba, uwa noa murruġ koa kokeroa; ġatun taraito nukuġko, Marȧthako yitirra, wamunbéa bon bounnoun kin kokerá.
\p 
\v 39 Wúġgunbai bounnoun ba ġaiya kai, yitirra Mari, yellawa bountoa Iéthu kin yallo ka, ġatun ġurra bon wiyellita
\p 
\v 40 Wonto ba Marȧtha kȧmullan buntoa marai-marai umullita, ġatun uwa bountoa ġikouġ kin, ġatun wiya, Piriwál, kora bi natan tia wareka tia wúġgunbai emmoúmba umulliko wakȧllo? wiyella bounnoun umulli koa bountoa tia.
\p 
\v 41 Ġatun noa Iéthako wiyelléún, ġatun wiya bounnoun, Ela! Marȧtha, Marȧtha, ġintoa kȧmullan marai-marai minnambo-minnambo ka;
\p 
\v 42 Wonto ba wakȧl murrȧrȧġ kȧtan: ġatun Mariko bountoa ġeremulléu̇n unnoa murrȧrȧġbo, keawai wal mantillinún bounnoun kinbiruġ.
\c 11
\p 
\v 1 ĠATUN yakita kakulla, wiyelliela noa ba tarai ta purrai ta, kaiulléu̇n noa ba wiyelli ta, wakȧllo bon wiya ġikouġ-ka-to wirrobullikanto, Piriwȧl, wiyella ġearun bi wiyelliko, yanti kiloa Ioanneto noa wiya barun ġikoúmba wirrobullikan.
\p 
\v 2 Ġatun noa wiya barun, wiyȧnu̇n nura ba, ġiakai nura wiyanu̇n nura, Biyuġbai ġearúmba wokka ka ba moroko ka ba kȧtan, Kȧmu̇nbilla yitirra ġiroúmba yirri-yirri kakilliko. Paipibunbilla Piriwȧl koba ġiroúmba. Ġurrabunbilla wiyellikanne ġiroúmba, yanti moroko ka ba, yanti ta purrai ta ba.
\p 
\v 3 Ġuwoa ġearun purreȧġ ka takilliko.
\p 
\v 4 Ġatun warekilla ġearúnba yarakai umatoara, kulla ġéen yanti ta wareka yanti ta wiyapaiyeún ġearúnba. Ġatun yuti yikora ġearun yarakai umullikan kolaġ; miromulla ġearun yarakai tabiruġ.
\p 
\v 5 Ġatun noa barun wiya, Ġan nurun kinbiruġ kóti ġikoúmba, ġatun uwȧnu̇n ġikouġ kin tokoi ta, ġatun bon wiyȧnu̇n, Ela! kóti, mumbilla tia wokkai to ġoro ko;
\p 
\v 6 Kulla noa emmoúmba kóti uwa kaloġ tin emmouġ kinko, ġatun keawai baġ wún korien ġikouġ kin mikan ta takilliko?
\p 
\v 7 Niuwoa murruġ ka ba ko wiyánún, Wai tia wiyellan; kulla unni kurraka wirriġbakulla, kulla wonnai tara emmoúmba emmouġ katoa ba birrikilliġél laba; keawaran baġ bouġkulli korien ġukilliko ġirouġ.
\p 
\v 8 Wiyan nurun baġ, Keawai noa bouġkulli korien ġulliko bon, kulla noa ba ġikoúmba kóti; kulla wal noa bon pirriral-mulli tin bouġkullinún ġaiya noa ġulliko bon wiyellinún noa ba.
\p 
\v 9 Ġatun nurun baġ wiyan, Wiyella, ġatun ġunu̇n ġaiya nurun; ġatun tiwolla, ġatun karawollinun ġaiya nura; wirrillia, ġatun umanu̇n ġaiya nurun.
\p 
\v 10 Yantin ba wiyellinu̇n, manu̇n wal; ġatun noa tiwollinu̇n, karawollinu̇n ġaiya noa; ġatun ġikouġ wirrillinu̇n noa ba, umȧnu̇n ġaiya wal.
\p 
\v 11 Yinallo ba wiyȧnu̇n nulai yantin ta nurun kin, biyuġbai ta ba, wiya, noa ġunu̇n tunuġ? ġa makoro, wiya, noa maiya ġunu̇n makoró?
\p 
\v 12 Ga ba wiyellan noa ba yarro, wiya, noa bon ġupaiyinu̇n wuarai?
\p 
\v 13 Nura ba yarakaikan kȧtan, ġukilliko ġutoara murrȧrȧġ wonnai ko nurúnba ko; kauwa yanti ġunu̇n noa Biyuġbaito moroko ka ba ko Marai murrȧrȧġ barun wiya bon ba?
\p 
\v 14 Ġatun noa ba paibuġgulliela wakȧl diabol, ġatun noa ġoġo. Ġatun yakita ġaiya kakulla, waita ba uwa diabol, wiya ġaiya noa ġoġo kabiruġ ko; ġatun bara ku̇ri kotelliela.
\p 
\v 15 Wonto ba tarai-kan-to wiya, Paibuġġa noa barun diabol Béeldhebul kȧtan biruġ, piriwȧlloa biruġ diabol koba ko.
\p 
\v 16 Ġatun tarai-kan-to wiyelliela, wiya bon túġa moroko tin.
\p 
\v 17 Wonto noa ba ġimilléu̇n barúnba kotellikanne, wiya barun, Yantin piriwȧl koba ġaruġgara umulla barabo tetti bara kȧnu̇n; ġatun kokerá koba barabo warakullia bara.
\p 
\v 18 Thatan noa ba ġaruġgara kȧnu̇n niuwoa-bo, yakoai ġikoúmba piriwȧl koba kȧnu̇n? kulla nura wiyan paibuġga bag ba barun diabol Béeldhebul katoa biruġ.
\p 
\v 19 Ġatun ġatoa ba paibuġgȧanu̇n barun diabol Béeldhebul biruġ, ġan katoa biruġ nurúnba-ko yinal-lo paibuġga?
\p 
\v 20 Gatoa paibuġgȧnu̇n mȧttȧrroa biruġ Eloi koba ko barun diabol, kauwa tuloa uwa ġaiya piriwȧl koba Eloi koba nurun kin ba.
\p 
\v 21 Ġolomȧnu̇n noa ba tarai ku̇ri mokȧl porrol ġikouġ kin kokerá, ġikoúmba tullokan murroi kȧtan.
\p 
\v 22 Wonto ba tanan uwȧnun tarai mokȧl porrolkan kauwȧl kan ġikouġ kin, ġatun kéakéa-ma noa bon, mantillinu̇n ġaiya wal bon kirun mokȧl ġikoúmba pirriral-matoara; ġatun ġutillinu̇n noa mokȧl ġikoúmba.
\p 
\v 23 Niuwoa keawai emmouġ katoa, niuwoa kȧtan kóti korien; ġatun noa keawai boa-ma korien emmouġ katoa, ware-ware-kan.
\p 
\v 24 Paikullinu̇n ba marai yarakai ku̇ri kabiruġ, uwan noa yuriġ purroi toa tarawaroa, nakilliko korilliko; ġatun noa keawai na korien, wiyan noa, Willuġbanu̇n wal baġ willuġbo kokerá ko emmouġ ka ta ko, unta biruġ uwa baġ ba.
\p 
\v 25 Gatun uwȧnún noa ba, nakulla ġaiya noa ba wiréa kiriiri ġatun konéin.
\p 
\v 26 Uwan ġaiya noa ġatun yutéa taraikan theben ta marai yarakai kauwȧl yanti niuwoa ba; ġatun bara uwa murrariġ ġatun kakulla ġaiya bara unta; ġatun yarakai kauwȧl noa unnoa kȧtan yakita, kakulla noa ba kurri-kurri.
\p 
\v 27 Ġatun yakita kakulla, wiyelliela noa ba, kaaibulléu̇n tarai nukuġ ġali koba konara koba, ġatun wiya bon bountoa, Murrȧrȧg kauwa yanti pika kurréa bon ba, ġatun paiyil pitta bi ba.
\p 
\v 28 Wonto noa bo wiya, Kauwa yanti, murrȧrȧġ kauwȧl kȧtan bara ġurrullikan wiyellikanne Eloi koba, ġatun mirromulli-ko.
\p 
\v 29 Ġatun yakita kakulla, wittillan bara ba ku̇ri, wiya noa kurri-kurri, Unni ta yarakai kȧtan willuġġél; nakillin bara tu̇ġa; keawai wal barun ġunu̇n, unni bo ta wal tuúġa Iona-u̇mba propet koba.
\p 
\v 30 Yanti kiloa Iona túġa kakulla noa barun ku̇ri Ninebi ka, yanti bo ta wal kȧnu̇n noa yinal ku̇ri koba barun ġali ko willuġgél ko.
\p 
\v 31 Bouġkullinu̇n wal piriwȧl kirin pakai biruġ purreȧġ ka wiyelliġél la ku̇ri koa untikȧl loa willuġgél loa, ġatun pirralmanu̇n barun; kulla bountoa uwa kaloġ kabiruġ purrai tabiruġ wirán tabiruġ ġurrulli bon ġuraki ko Tholomón ko; A! kauwȧl kȧtan Tholomón kiloa unnibo.
\p 
\v 32 Bouġkullinu̇n wal bara ku̇ri Ninebikȧl purreȧġ ka wiyelliġél la ku̇ri koa untikȧl loa willuġgél loa, ġatun pirral-manu̇n barun; kulla bara minki kakulla wiyelli ta Iona-úmba ka; A! kauwȧl kȧtan Iona kiloa unnibo.
\p 
\v 33 Keawai ku̇riko tarai-kan-to wirrouġ buġgȧnu̇n kaibuġ wunu̇n ġaiya ġati ta, keawai baria ka wimbi ka, wonto ba kaibugġél la, bara ba uwȧnu̇n na-uwil koa bara kaibuġ.
\p 
\v 34 Kaibuġ ta murrin koba ġaikuġ; wonto ba ġiroúmba ġaikuġ tuloa kȧtan, yantin bin kȧtan murrin kaibuġkan; wonto bin ba ġaikuġ yarakai, kȧnu̇n murrin bin warapa tokoi to.
\p 
\v 35 Yakoai bi, mirka unnoanuġ kaibuġ ġirouġ kinba tokoi ta ba kȧtan.
\p 
\v 36 Kulla ba yantin ta ġiroúmba murrin ta ba warapan kaibuġ ko, keawai taraikan tokoi, kȧnu̇n yantinbo ta wal warapan kaibuġ ko, yanti kaibuġ koba wupin ġatun binkirréu̇n.
\p 
\v 37 Ġatun wiyelliela noa ba, taraito Parithaioko wiya bon tauwil koa noa ġikouġ katoa; ġatun noa uwa murrariġ ġatun yellawa takilliko.
\p 
\v 38 Ġatun noa ba Parithaioko nakulla, umulli korien noa bato ka kurri-kurri takilli kolaġ, kotelliela noa.
\p 
\v 39 Ġatun bon noa Piriwȧllo wiya, Yakita nura Parithaioiko umullia mirkun karai-ġon tunti ġatun pikirri; wonto ba nurúnba murrin warapan williró ġatun yarakai to.
\p 
\v 40 Woġkȧl nura! yan ta noa uma unnoa yanti unnoa ba warrai ta ba, yantibo uma noa murruġ ka ba?
\p 
\v 41 Guwa nura untoakȧl nurun kinbiruġ, ġatun yantin nurun ba tuloa ka kȧtan.
\p 
\v 42 Yapal nura Parithaioi! kulla nura ġukillan wintakȧl mentha tabiruġ, ġatun ruta tabiruġ, ġatun yaki tara, ġatun ġurramaiġan tuloa ġatun pitȧlumullikanne Eloi koba: unni tara nura uma pa, ġatun keawai taraikan wareka pa uma korien.
\p 
\v 43 Yapal nura Parithaioi! kulla nura pitȧlman yellawollikanne wokka kaba thunagóg kaba, ġatun umullikanne ġukilliġél lako.
\p 
\v 44 Yapal nura ġarammateu ġatun Parithaioi, ġakoiyaye! kulla nura yanti tulmun kiloa paipi korien, ġatun bara ku̇ri uwan wokka laġ tulmun toa, keawaran bara na korien.
\p 
\v 45 Wiyayelléu̇n ġaiya wakȧllo nomiko-ko wiyelliela bon, Piriwȧl, ġiakai bi wiyan, pirralman bi ġearun.
\p 
\v 46 Ġatun noa wiya, Yapal nura nomikoi yantinbo! kulla nura wuntan ku̇ri ka porrol ta lo kauwȧl porrol kurrilliko, ġatun keawai nura unnoa porrol numa korien nurun ka to mȧttȧrró.
\p 
\v 47 Yapal nura! kulla nura ba wittiman tulmun barúnba propet koba, ġatun biyugbaito nurúnba-ko bunkulla barun tetti kulwon.
\p 
\v 48 Kauwa tuloa ta pirralman nura umatoara biyuġbai koba nurúnba; kulla bara yuna bo ta barun búnkulla tetti, gatun nura wittillin tulmun barúnba.
\p 
\v 49 Yaki tin wiya ġurakita Eloi koba ko, Yukȧnún wal baġ barun propet ġatun apothol barun kin, ġatun winta barun kinbiruġ búnnu̇n wal bara ġatun yarakai umȧnu̇n;
\p 
\v 50 Wiya-uwil koa ġoroġ yantin koba propet koba kiroabatoara yaki tabiruġ kurri-kurri tabiruġ purrai tabiruġ, unni barun willuġgél;
\p 
\v 51 Ġoroġ kabiruġ Abelúmba kabiruġ, ġoroġ kako Dhakariaúmba kako búntoara Willi ka bómo ta ġatun hieron; kauwa tuloa to wiyan nurun baġ, wiya-uwil koa unni barun willuġgél.
\p 
\v 52 Yapal nura nomikoi! kulla nura mankulla wirriġbakilliġél ġurakita koba; keawai nura wa pa, ġatun nura miya barun uwa bara ba.
\p 
\v 53 Ġatun wiya noa ba unni tara barun, pirriralma bon bara gȧrammateuto ġatun Parithaioiko, wiya-uwil koa noa minnambo wiyelliko;
\p 
\v 54 Mittillin bara bon, ġatun nakillin ġurrulliko ġikouġ kin ba ko kurraka ba ko, wiyayeún koa bara bon.
\c 12
\p 
\v 1 YAKITA kakulla, wittillan bara ba yantibo konara kúri, wata-watawollan barabo, wiya noa kurri-kurri barun wirrobullikan ġikoúmba, Yakoai nura lebben barúnba Parithaioi koba,ġakoiyaye ta unnoa.
\p 
\v 2 Yantin ba wutéa ta túġunbinu̇n ġaiya wal; ġatun yantin yuropa ta namunbinu̇n ġaiya wal.
\p 
\v 3 Yaki tin, wiyellan nura tokoi ta ġurrabunbinún wal kaibuġ ka; ġatun unni ta wiya nura ba ġurréuġ ka waiyakan ta, wiyellinu̇n wal wokka ka kokera.
\p 
\v 4 Ġatun baġ nurun wiyan kóti ta emmoúmba, Kinta kora nura barun kin búnkillikan tin murrin tin, ġatun yukita tantoa bo ta wal bara kaiyukanto banu̇n.
\p 
\v 5 Túġunbinún wal baġ nurun ġan-kai nura kinta wal kȧnu̇n: Kinta bon kauwa ġikouġ kai, yukita noa ba búnkulla kaiyukan noa warekulliko koiyuġ kako pirriko kako; kauwa wiyan baġ nurun, Kinta bon kauwa ġikouġ kai.
\p 
\v 6 Wiya, pente tibbin waréa ta ġupaiye ko buloara assari, ġatun keawai wakȧl unti biruġ woġgunti korien ġikouġ kin Eloi kin?
\p 
\v 7 Kulla yantin wolluġ kaba kittuġ murrapatoara kȧtan. Kinta kora nura ġali tin; kulla nura murrȧrȧġ kauwȧlkan kȧtan, keawaran ġali tarako tibbinko waréa-ta-ko kauwȧl-kauwȧl-ko.
\p 
\v 8 Unni ta nurun baġ wiyan, Yantinto emmouġ wiyȧnu̇n mikan ta ku̇ri ka, ġikouġ wiyȧnu̇n noa Yinal ku̇ri koba mikan ta aġelo ka Eloi koba ko.
\p 
\v 9 Wonto ba niuwoa ġanbullinu̇n tia emmouġ mikan ta ku̇ri ka, ġanbullinu̇n wal bon mikan ta aġelo ka Eloi koba ka.
\p 
\v 10 Ġatun ġanto ba yarakai wiyȧnu̇n ġikouġ Yinal ku̇ri koba, kȧmunbinu̇n wal bon; wonto bon ba yarakai wiyellikan Maraikan yirri-yirri-kan, keawai bon kȧmunbinu̇n.
\p 
\v 11 Ġatun manu̇n nurun bara thunagóg kako ġatun wiyellikan tako, ġatun kaiyukan tako, kota yikora nura wonnuġ nura ba wiyayellinu̇n, ġa minnuġ nura wiyȧnu̇n.
\p 
\v 12 Kulla nurun Marai-kan-to yirri-yirri-kan-to wiyȧnu̇n wal yakita bo ġaiya minnuġ wal nura wiyȧnu̇n.
\p 
\v 13 Ġatun wiya bon wakȧllo konara biruġ ko, Piriwȧl, wiyella emmoúmba biġgainuġ,ġukulli koa noa purrai emmouġ kai.
\p 
\v 14 Ġatun noa bon wiya, Ku̇ri, ġanto tia uma wiyellikan, ġa ġukillikan ġirouġ kin?
\p 
\v 15 Ġatun noa barun wiya, Yakoai ġatun murroi kauwa williri koba; kulla moron ku̇ri koba ka korien ta kauwȧl-kauwȧl la tul lokan ka ġikouġ ka ta.
\p 
\v 16 Ġatun noa wiya barun unni parabol, wiyelliela, Purrai ta porrólkan koba poaikulléu̇n kauwȧl:
\p 
\v 17 Ġatun noa kotelléu̇n niuwoabo, wiyelliela, Minnuġ banu̇n baġ, kulla wal unni tuntan uwa, wiya wal baġ wonta wura-uwil unni tara emmoúmba?
\p 
\v 18 Ġatun noa wiya, Unni baġ umȧnu̇n; umȧnu̇n wal baġ barán wunkilliġél emmoúmba, ġatun wittia kȧnu̇n kauwȧl; ġatun unta baġ wunu̇n yantin emmoúmba nulai ġatun tullokan.
\p 
\v 19 Ġatun baġ wiyȧnún emmoúmba marai, A marai! Kauwȧl tullokan ġiroúmba wúnkulla kauwȧl lako wunȧl lako; yellawolla murroi bi, tauwa, pittella, ġatun pitȧl kauwa.
\p 
\v 20 Wonto ba Eloito bon wiya, Woġkȧl-lan bi! unti tokoi ta ġiroúmba marai mantillinu̇n wal ġirouġ, kinbiruġ; ġanto ġaiya unnoa tara tullokan manu̇n tuiġko bi ba uma?
\p 
\v 21 Yanti niuwoa ba wupéakan tullokan ġikoúmba ko, ġatun keawai porrol korien Eloi kai koba.
\p 
\v 22 Ġatun noa wiya barun wirrobullikan, Yaki tin wiyan baġ nurun, Yanoa, kota yikora nurúnba moron takilliko; ġa keawai murrin ko wupulliko.
\p 
\v 23 Moron ta kauwȧl kȧtan murrȧrȧġ takillikanne keawaran, ġatun murrin ta kauwȧl kȧtan murrȧrȧġ kirrikin keawaran.
\p 
\v 24 Kotella wákun barun; koito bara ba keawai wupa korien, ġatun keawai kol bunti korien; keawai barúnba tuiġko wupilliġál, keawai barúnba kokera; ġatun noa Eloito ġiratiman barun; kauwȧl-kauwȧl nura kȧtan murrȧrȧġ tibbin bara keawaran.
\p 
\v 25 Ġatun ġan nurun kinbiruġ kotellita kȧnu̇n, uméa kȧnu̇n moron ġikoúmba waréa ka kakilliko kubit kako?
\p 
\v 26 Wiya nura ba kaiyu korien to umulliko unni waréa, minariġ tin nura kotellin unnoa tara?
\p 
\v 27 Kotella nura kenuku̇n turukin bara ba; keawai bara uma korien wupi korien bara; ġatun baġ wiyan nurun, Tholomón noa ba, konéinkan keawai bon wupa korien yanti kiloa wakȧl unti tara biruġ.
\p 
\v 28 Upȧnu̇n noa ba Eloito woiyo yanti, yakita purreȧġ ka unta ba purrai ta kȧtan, ġatun kumba warekakin murruġ ka wollo ka; wiya, nurun noa upȧnu̇n, A! nura ġurrullikan waréakan?
\p 
\v 29 Ġatun na-ki yikora nura minariġ nurúnba takilliko ġatun pittelliko, ġa kota yikora nura minki ko.
\p 
\v 30 Koito ba bara yantinto purrai ta ba ko natan yantin unni tara; ġatun nurúnba-to-Biyuġbai-to ġurran unni tara ġukillikanne nurun ba murrȧrȧġ kakilliko.
\p 
\v 31 Wonto ba nura nauwa piriwȧl koba Eloi koba, ġatun yantin unni rara ġunun nurun kin.
\p 
\v 32 Kinta kora, wirrul waréa; kulla pitȧlman bon Biyuġbai nurúnba ġukilliko piriwȧl-ġél ta nurun kin.
\p 
\v 33 Ġukilléa nurúnba, ġatun ġuwa ġukillikanne: umulla nura yinuġ nurúnba, keawai koa korokȧl katéa-ku̇n, porrólkan ta moroko ka ba kakilliko ka korien kakilliko, keawai ba unta ko uwa korien mankiye, ġatun keawai ba yarakai puntaye.
\p 
\v 34 Wonnun ta nurúnba tullokan, untabo kȧnu̇n nurúnba búlbúl yantibo.
\p 
\v 35 Ġirullia nura winnal nurúnba, ġatun nurúnba kaibuġ winabunbilla;
\p 
\v 36 Ġatun nurabo yanti kiloa ku̇ri ba mittillin barúnba ko Piriwȧl ko willuġ-banu̇n noa ba mankilliġél labiruġ; uwȧnu̇n noa ba ba tanan ġatun wirrillinu̇n, umȧnu̇n ġaiya bon tanoa-kal-bo.
\p 
\v 37 Pitȧlmatoara kȧnu̇n bara unnoa tara mankillikan, yakita Piriwȧl noa ba uwȧnu̇n, noa ba barun kin nanún noa ba barun nakilli ta; wiyan bag tuloa nurun, ġirullinu̇n noa kótibo, ġatun yellawabumbéa barun takilli kolaġ, ġatun uwȧnu̇n noa ġukilliko barun.
\p 
\v 38 Ġatun tanan uwȧnún noa ba, yakita buloara nakillikan ta, yakita ġoro ka nakillikan ta, ġatun nanu̇n barun yantibo nakilli ta, pitȧlmatoara bara unnoa tara mankillikan.
\p 
\v 39 Ġatun ġurrulla unni, wiya noa ba kokera-tin-to ġurra pa, yakounta ba uwa pa mankiye na pa noa, keawai ġaiya kokera ġikoúmba potobunti pa.
\p 
\v 40 Yanti tin kauwa nura nakilliko; kulla noa Yinal ku̇ri koba uwȧnu̇n yakita kota korien nura ba.
\p 
\v 41 Wiya ġaiya noa bon Peterko, Piriwȧl, wiyan bi unni parabol ġearunbo, ġa ġearun yantin?
\p 
\v 42 Ġatun noa Piriwȧllo wiya, Gan-ke noa mankillikan murrȧrȧġ ġatun ġuraki, piriwȧllo noa umȧnu̇n bon wiyellikan kakilliko kokera ko ġikoug ka ta ko, ġu-uwil koa noa takilliko yakita ġukilliġél la?
\p 
\v 43 Pitȧlmatoara kȧtan unnoa mankillikan, umȧnu̇n noa ba ġikoúmba piriwȧl nanu̇n ġaiya noa bon umulli ta yanti.
\p 
\v 44 Wiyan baġ tuloa, umȧnu̇n bon noa wiyellikan kakilliko yantin tako.
\p 
\v 45 Wonto noa ba wiyȧnu̇n gala mankilli-kan-to, búlbúl la, Emmoúmba piriwȧl minkin uwa korien; ġatun ġaiya noa búnkilli kolaġ barun ku̇ri mankillikan ġatun ġapal, ġatun takilli kolaġ, ġatun pittelli kolaġ, ġatun kuttawai kolaġ;
\p 
\v 46 Piriwȧl ġala koba mankillikan koba uwȧnún wal noa purreȧġ ka na korien ta, ġatun yakita ġaiya kota korien ta bon, ġatun bu̇nnu̇n bon buloarakan, ġatun ġunu̇n bon winta ġikouġ kai barun kin ġurra korien ta.
\p 
\v 47 Ġatun unnoa mankillikan ġurran noa kotelli ta piriwȧl koba ġikoúmba, ġatun keawai uma korien, keawai noa uma pa yanti kotelli ta ġikoúmba, búnnún wal ġaiya bon kauwȧl-kauwȧl.
\p 
\v 48 Wonto noa ba niuwoa ġurra korien, ġatun yarakai umatoara yaki tin bún ba bon, búnnún wal waréa. Kulla bon ġupa kauwȧl, wiyapaiyȧnu̇n wal kauwȧl ġikouġ kinbiruġ; ġatun kúriko ġukulla kauwȧl, wiyellia kȧnún bara ġaiya kauwȧl-kauwȧl ġikouġ kinbiruġ.
\p 
\v 49 Uwan ta baġ unni yukulliko koiyuġ ko purrai ta ko; minnuġ-bullinún baġ kauwa ba tanoa-kal-bo wirroġ-kulléa?
\p 
\v 50 Kulla tia korimullikanne emmouġ kinba korimulliko; ġatun yakoai baġ kȧtan ġoloin koa ka-uwil kakilliko!
\p 
\v 51 Kotan nura, uwa baġ ba pitȧl ġukilliko purrai ta ko? wiyan baġ ba, keawai; wonto ba ġurruġgurra kakilliko;
\p 
\v 52 Kulla wal unti biruġ kȧnu̇n kakilliko pente kokerá wakȧl la, ġurruġgurra biruġ, ġoro bulun kinbiruġ, ġatun buloara ġoro kabiruġ.
\p 
\v 53 Biyuġbai ġurruġgurra kȧnu̇n yinal labiruġ, ġatun yinal biyuġbai tabiruġ; ġatun tunkan yinȧlkun tabiruġ, ġatun yinȧlkun tunkán tabiruġ, túnġaikun bounnoun ba kurrinanbai tabiruġ, ġatun kurrinanbai bounnoun ba túnġaikun tabiruġ.
\p 
\v 54 Ġatun noa barun ku̇ri wiya, Nanún nura ba yareil wokka laġ punnȧl ba pulóġkulliġél lin, wiyȧnu̇n ġaiya nura koiwon tanan ba; ġatun kauwa yanti.
\p 
\v 55 Ġatun kareawuġ ba kȧnu̇n, wiyellinún ġaiya nura, karol kȧnu̇n; ġatun yanti ġaiya kȧnu̇n.
\p 
\v 56 A nura nakoiyaye! natan nura tarkin moroko koba ġatun purrai koba; minariġ tin koa nura na korien unti yakita?
\p 
\v 57 Kauwa, kora koa nura kota ba nurun kinbiruġ tuloa?
\p 
\v 58 Uwȧnu̇n bi ba ġikouġ katoa bukkakan toa ġikouġ kinko wiyellikan tako, yapuġ koa nuiyellia bi bon, wamunbi-uwil koa biloa murroi kakilliko ġikouġ kinbiruġ; yutéa-ku̇n koa biloa wiyellikan kauwȧl lako, ġatun wiyellikanto kauwállo wamunbinu̇n biloa yarakan tako, ġatun yarakanto wupinún biloa jail kako.
\p 
\v 59 Wiyan banuġ, keawai bi waita uwa korien unta biruġ, ġukillinun bi ba lepton ta kirun waréa ta.
\c 13
\p 
\v 1 KAKULLA bara unta yakita taraikan, wiya bon barun Galilaiakȧl, ġoroġ barúnba taroġkama Pilato-to thuhia barun barúnba.
\p 
\v 2 Ġatun noa Iéthuko wiyayelléu̇n, wiyelliela noa barun, Wiya, nura kotellin unnoa tara Galilaiakȧl yarakai bara kakulla kauwȧl barun kinbiruġ Galilaiakȧl labiruġ, kulla barun ba mankulla unnoa tara?
\p 
\v 3 Wiyan nurun baġ, Keawai; kulla nura keawai minki kȧtan, yantin ġaiya nura tetti tetti kȧnu̇n.
\p 
\v 4 Ga barun etin ta wunkulléún kokera barán, ġatun tetti-tetti barun wirria, wiya, nura kotellin barun yarakai bara ba kakulla kauwȧl barun ku̇ri kabiruġ kakillin Hierothalem ka?
\p 
\v 5 Wiyan nurun baġ, Keawai; kulla nura keawai minki kȧtan, yantin ġaiya nura tetti-tetti kȧnu̇n.
\p 
\v 6 Wiya noa unni yanti parabol: Taraikan ta ku̇riko wupéa yirriwilbin purrai ta ġikouġ ka ta; ġatun noa uwa yeai ko nakilliko, ġatun noa keawai ġaiya na pa.
\p 
\v 7 Wiya ġaiya noa bon upullikan, Ela! ġoro ka wunȧl la unti, uwa baġ nakilliko yeai ko unti biruġ ko yirriwiltabin tako, ġatun keawai ġaiya baġ na pa; kólbúntilla unnoa barán; minariġ, tin unnoa kȧtan purrai ta?
\p 
\v 8 Ġatun noa wiyayeléu̇n, wiyelliela bon, Piriwȧl, kȧmunbilla unnoa unti wunȧl la, pinni-uwil koa baġ untoakȧl ko, ġatun konuġ koa baġ wupi-uwil;
\p 
\v 9 Ġatun yeai ba kȧnu̇n, murrȧrȧġ ġaiya kȧnu̇n; ġatun ka korien ba, ġatun yukita ġaiya kólbúntinu̇n; wal bi unni barán.
\p 
\v 10 Ġatun noa wiyelliela wakȧl la thunagóg ka purreȧġ ka thabbat ka.
\p 
\v 11 Ġatun, a! kakulla unta wakȧl nukuġ munni-lan bountoa ba kauwȧl-kauwȧl wunȧl étin ta, ġatun woinu bountoa, ġatun keawai bountoa kaiyu korien wokka-lan kakilliko.
\p 
\v 12 Ġatun nakulla noa ba Iéthuko bounnoun, kaaipa bounnoun noa, ġatun wiyelliela bounnoun, Nukuġ, ġintoa buruġ-kulléu̇n woinu kabiruġ ġirouġ kinbiruġ.
\p 
\v 13 Ġatun noa upilléu̇n mȧtȧra bounnoun kin; ġatun tanoakal-bo bounnoun tuloa uma, ġatun bountoa pitȧlma bon Eloinuġ.
\p 
\v 14 Ga-tun piriwȧllo thunagóg kako, wiyayelléu̇n bukka-kan-to, kulla noa Iéthuko turon uma purreȧġ ka thabbat ka, ġatun wiya barun ku̇ri, Hek ta purréȧġ ka umilliko ku̇ri ko; unti tara purreȧġ ka tanan uwolla turon umullilo, ġatun keawai thabbat ta purreȧġ ka.
\p 
\v 15 Piriwȧllo noa bon wiyayelléȧn ġatun wiyelliela, Ġintoa ġakoiyaye! wiya, yantinto nura buruġbuġgan ġikoúmba boo ġatun athino, purreȧġ ka thabbat ka, unta biruġ kokerá biruġ, yemmama-uwil koa kokoin kolaġ pittelliko?
\p 
\v 16 Ġatun keawai wal unni ġapal, yinálkun ta Abu̇ramúmba, ġiratoara bounnoun Thatánto noa unni tara étin ta wunȧl la, buruġbuġgulliko yanti biruġ, unti thabbat ta purreȧġ ka?
\p 
\v 17 Ġatun wiya noa ba unni tara, koiyun bara ġaiya kȧtan yantin bukkamaiye ġikouġ kai; ġatun yantin ku̇ri pitȧl kakulla yantin tin umatoarrin kauwȧl lin ġikouġ, biruġ.
\p 
\v 18 Wiya ġaiya noa, Minariġ kiloa Piriwȧl koba Eloi koba? Ġatun yakoai kiloa paġgunbinu̇n?
\p 
\v 19 Yanti kiloa ta yeai ba mutard koba, mankulla ku̇riko, ġatun meapa purrai ta ġikouġ, kai ta; ġatun boaikulléu̇n wokka laġ, ġatun kakulla kauwȧl ku̇lai; ġatun tibbin moroko tin yellawa wiran ta.
\p 
\v 20 Ġatun noa wiyéa-ku̇n, Yakoai kiloa baġ tu̇ġunbinu̇n piriwȧl koba Eloi koba?
\p 
\v 21 Yanti lebben kiloa, mankulla ġapallo ġatun yuropa ġoro ka ġukilliġél la nulai ta, kakulla wal yantibo lebben kiloa.
\p 
\v 22 Ġatun noa uwa kokeroa ġatun kauwȧl loa kokeroa, wiyatin, ġatun uwollin Hierothalem kolaġ.
\p 
\v 23 Wiya ġaiya bon wakȧllo, Piriwȧl, wiya, warai moron kakilliko? Ġatun noa wiya barun,
\p 
\v 24 Nuwolla pulóġkulli kolaġ tuloa tin yapuġ tin: kulla baġ nurun wiyan, kauwȧl-kauwȧllo nuwanu̇n murrȧraġ pulóġkulli kolaġ ġatun keawai wal kaiyu korien.
\p 
\v 25 Bouġkullinu̇n noa ba kokeratin wokka laġ, ġatun wirriġbakulla pulóġkulliġél, ġatun nura ġarokéa warrai ta, ġatun wirrilléu̇n toto pulóġkulliġél, wiyellin, Piriwȧl, Piriwȧl, umulla ġearun; ġatun noa wiyayellinu̇n ġatun wiyȧnu̇n, Keawaran baġ nurun ġimilli korien wonta biruġ wal nura:
\p 
\v 26 Wiyánu̇n ġaiya wal nura, Takéu̇n ġéen ġatun pittakéu̇n ġirouġ kin mikan ta, ġatun ġintoa wiyakéu̇n ġearun kin yapuġ ka.
\p 
\v 27 Wonto wal noa ba wiyȧnu̇n, Wiyan baġ nurun, keawaran baġ nurun ġimilli korien, wonta biruġ wal nura; yuriġ tia uwolla emmouġ kinbiruġ, yantin nura yarakai umullikan.
\p 
\v 28 Unta ta wal tuġkillinu̇n ġatun tirra-ġatpuntullinu̇n, nanu̇n ġaiya nura ba barun, Abȧramnuġ, ġatun Ithȧknuġ, ġatun Yacóbnuġ, ġatun yantin propetnuġ, kakillin bara ba piriwȧl koba ka Eloi koba, ġatun nurunbo yuaipéa warrai tako.
\p 
\v 29 Ġatun bara uwȧnu̇n muriuġ tin, ġatun krai tin, ġatun kummari tin, ġatun pakai tin, ġatun yellawȧnu̇n wal piriwȧl koba ka Eloi koba ka.
\p 
\v 30 Ġatun, a! bara willuġ kȧtan, kabo wal bara ġanka kȧnu̇n ġatun bara ġanka kȧtan, kabo wal bara willuġ kȧnu̇n.
\p 
\v 31 Unta purreȧġ ka winta uwa Parithaioi kabiruġ wiyellin bon, Yuriġ ba waita wolla unta biruġ, kulla noa Herodto biloa buúnnu̇n tetti.
\p 
\v 32 Ġatun noa barun wiyá, Yuriġ nura wolla, wiya-uwil koa bon unnoa alópék, A! paibuġgan baġ barun diabol, ġatun turon baġ uman buġgai ġatun kúmba, ġatun kúmba-ken-ta wal ġoloin tia kȧnu̇n.
\p 
\v 33 Yantin tin uwȧnu̇n wal baġ buġgai ġatun kúmba, ġatun kúmba-ken-ta; kulla wal keawaran wal wakȧl propet ka korien tetti Hierothalem kabiruġ.
\p 
\v 34 Yapallun Hierothalem, Hierothalem! búnkiye tetti wirriye barun propet, ġatun pintia barun tunuġ ko yupitoara ġirouġ kinko; murrin-murrin baġ kauma pa baġ barun wonnai tara ġiroúmba, yanti kiloa tibbinto ba kauma-uwil yirriġ ka bara ka bounnoun ba waréa tara, ġatun keawaran nura kauma korien.
\p 
\v 35 A! nuru̇nba kokera kakillin mirrȧl kakilliko: ġatun baġ wiyan tuloa nurun, Keawai nura tia nanu̇n, yakita ko kȧnu̇n ba wiyȧnu̇n wal nura ba, Pitȧlkȧmunbilla bon uwan noa ba yitirroa Piriwȧl koba koa.
\c 14
\p 
\v 1 ĠATUN yakita kakulla, uwa noa ba murrariġ kokerȧ piriwȧl koba ka Parithaioi koba takilliko nulai ko purreȧġ ka thabbat ka, tumiméa ġaiya bon bara.
\p 
\v 2 Ġatun, a! ġaroka ba kakulla wakȧl ku̇ri kokoin-kan warakaġ.
\p 
\v 3 Ġatun Iéthuko noa wiyayelléu̇n wiya barun nomikoinuġ ġatun Parithaioinuġ, wiyelliela, Wiya, murrȧrȧġ turon umulliko purreȧġ ka thabbat ka?
\p 
\v 4 Ġatun bara tullama pulli. Ġatun noa bon turon uma, ġatun wamunbéa bon;
\p 
\v 5 Ġatun wiyayelléu̇n noa barun, wiyelliela, Ġanto nurun kinbiruġ-ko puntimanu̇n buttikaġ ba athino ba ġa boo ba nuru̇nba kirai ta, ġatun keawai ġaiya bon manu̇n wokka laġ purreȧġ ka thabbat ka?
\p 
\v 6 Ġatun keawai bara bon wiyayelli pa unni tara.
\p 
\v 7 Ġatun noa wiya wakȧl parabol barun ġala ko wiyatora ko, nakulla noa ba ġiriméa bara murrȧrȧġ waiyakan; wiyelliela barun,
\p 
\v 8 Wiyȧnu̇n bin ba taraito ku̇riko uwa-uwil koa bi mankilli kolaġ nukuġ kolaġ, yellawa yikora wokka waiyakanto, mirka ta tarai ku̇ri piriwȧl wlyatoara ta;
\p 
\v 9 Ġatun noa ninwoa wiya biloa ġatun ġikouġ tanan uwolliko ġatun wiyelliko bin, Ġuwa bon ġali ko; ġatun ġintoa koiyun bi ba kȧnu̇n waita uwȧnu̇n waiyakan kolaġ bará ka bo.
\p 
\v 10 Wonto ba bin wiyȧnu̇n ba, yuriġ bi yellawolli ta ka barȧ kako waiyakan kako; ġatun uwȧnu̇n noa ba wiya biloa ba wiyȧnu̇n biloa, Kóti, yuriġ wokka laġ uwolla: yakita ġaiya pitȧlmȧnu̇n bin mikan ta barun kin tanu̇n ba kunto ġirouġ katoa.
\p 
\v 11 Ġan umullinu̇n ninwoa bo wokka kako, umȧnu̇n wal bon bará kako; ġatun ninwoa umullinu̇n niuwoa ba bará kako, umullinu̇n wal wokka kako.
\p 
\v 12 Wiya ġaiya noa ġala wiya bon noa ba, Ġunu̇n bi ba takilliko búlwára ka ġa yaréa ka, wiya yikora bi ġirou̇mba kóti, ġa kótita, ġa porrólkan; wiyéa kȧnu̇n bin ba bara, ġatun ġupaiyéa kȧnu̇n bin yaruġ ka.
\p 
\v 13 Wonto bi ba umȧnu̇n takilliko, wiyella barun mirrȧl-mirrȧlkan, ġatun munni-munni-kan, ġatun wiir-wiirkan, ġatun munminkan:
\p 
\v 14 Ġatun bin pitȧlmanu̇n; kulla bara keawai ġupaiye korien yaruġ ka; kulla bin ġupaiyéa kȧnu̇n yaruġ ka, yakita ba moron kȧnu̇n murrȧrȧġ-tai tetti-tetti kabiruġ.
\p 
\v 15 Ġatun wakȧl barun kinbiruġ yellawa ġikouġ kin takilliela,ġurra noa ba unni tara, wiya bon noa, Pitȧlmatoara noa tanu̇n wal kunto piriwȧl lako Eloi koba ka.
\p 
\v 16 Wiya ġaiya noa bon, Taraito ku̇riko wupéa kauwȧl takilliko yaréa ka, ġatun wiya barun kauwȧl-kauwȧl kuri:
\p 
\v 17 Ġatun yarea ka yuka noa bon ġikoúmba mankillikan, wiyelliko barun wiyatoara ko, Tanan; kulla yantin unnuġ tara wupea yakita.
\p 
\v 18 Ġatun bara yantin wiyellan wakȧl-wakȧl ġakoiyellan. Kurri-kurrito wakȧllo wiya ġikouġ, Ġukilléu̇n baġ winta purrai, ġatun waita wal baġ uwȧnu̇n nakilliko ġala ko; wiyan biloa wamunbilliko tia.
\p 
\v 19 Ġatun taraito wiyȧ, Ġukilléu̇n baġ pente tumba boo buttikaġ, ġatun baġ waita uwan numulliko barun; wiyan biloa wamunbilliko tia.
\p 
\v 20 Ġatun taraito wiyá, Mankulla baġ nukuġ emmoúmba, yaki tin keawai baġ uwa korien.
\p 
\v 21 Uwa ġaiya noa unni mankillikan, ġatun wiya bon piriwȧl ġikoúmba unni tara. Wiya bon ġaiya noa kokeratinto bukka-kanto ġikou̇mba mankillikan, Yuriġ wolla kurrakai yapuġ koa kokeroa, ġatun yutilla barun tanan untiko mirrȧl-mirrȧl-kai, ġatun munni-munni-kai, ġatun wiir-wiir-kai, ġatun munmin-kai.
\p 
\v 22 Ġatun noa mankillikanto wiyȧ, Piriwȧl, upatoara ta yanti bi ba wiya, ġatun kauwȧl-kauwȧl lako ka untiko.
\p 
\v 23 Ġatun noa bon piriwȧllo wiya mankillikan, Yuriġ, uwolla yapuġ koa ġatun koruġ koa, ġatun pirriralmulla barun tanan uwolliko, emmoúmba koa kokera warapa-uwil.
\p 
\v 24 Kulla baġ wiyan nurun, Keawai wal bara untoakállo wiyatoara nutunún emmoúmba kunto.
\p 
\v 25 Ġatun ku̇ri kauwȧl-kauwȧl uwa ġikouġ katoa: ġatun noa willariġ, warkulléu̇n, ġatun wiya ġaiya barun,
\p 
\v 26 Uwȧnún tia ba taraikan kúri emmou̇ġ kin, ġatun wareka korien ġikoúmba biyuġbai ġatun tunkan, ġatun nukuġ, ġatun wonnai tara, ġatun kóti tara, ġatun wuġgunbai, kauwa, ġikoúmba kata moron, keawai noa kȧnu̇n emmoúmba wirrobullikan.
\p 
\v 27 Ġanto-bo ba kurri korien ġikoúmba taliġ-kabillikanne, ġatun uwolla emmouġ katoa, keawai noa kȧnu̇n emmoúmba wirrobullikan.
\p 
\v 28 Ġanto nurun kinbiruġ-ko, kotellin wittimulliko kokera, wiya, noa yellawȧnu̇n kurri-kurri, ġatun tuiġko umulliko, mirka keawai ġoloin witti korien?
\p 
\v 29 Mirroma, yukita wupéa noa ba tuġġa, ġatun keawai noa kaiyu korien ġoloin wittilliko, yantinto ba nanu̇n béelmȧnu̇n ġaiya bon,
\p 
\v 30 Wiyellinún, Ġali ku̇riko nutéa wittimulliko, ġatun kaiyu korien noa ġoloin wittimulliko.
\p 
\v 31 Ġa, ġan piriwȧl uwȧnún noa ba wuruwai kolaġ, tarai ko piriwȧl ko, yellawa noa kurri-kurri, ġatun kotelliela, wiya, noa ba kaiyukan uwa-uwil koa dekem-millia to nuġgurrawa-uwil koa bon taimin to ke bith-dekem-millia to?
\p 
\v 32 Ġa ba, kaloġ ka ba noa piriwȧl taraito, yuka noa wakȧl puntima wiyelliko pitȧl koa kakillai.
\p 
\v 33 Yanti kiloa, yantinto nurun kinbiruġ-ko wareka korien noa yantin ġikoúmba, keawai noa kȧnu̇n emmoúmba wirrobullikan.
\p 
\v 34 Pulli ta unni murrȧrȧġ; wonto ba pulli ka korien, yakoai kȧnu̇n upilliko!
\p 
\v 35 Keawai murrȧrȧġ, korien ta purrai ko, ġa ba konuġġél ko; wareka ġaiya ku̇riko. Niuwoabo ġurréuġkan ġurrulliko, ġurrabilla bon.
\c 15
\p 
\v 1 PAPAI ġaiya bara uwa ġikouġ kin yantin telónai ġatun yarakaiwilluġ, ġurrulliko bon.
\p 
\v 2 Ġatun koiya bara Parithaioiko ġatun ġarammateuko, wiyelliela, Unni ku̇ri murrȧrȧġ korien, noa uman barun yarakai-willuġ ġatun tatan noa barun katoa.
\p 
\v 3 Ġatun noa wiya barun unni parabol, wiyelliela,
\p 
\v 4 Ġan ku̇ri nurun kinbiruġ, hekaton ta ćipu ġikoúmba, wȧkȧl noa ba yuréa umȧmu̇n barun kinbiruġ, wiya, noa wunún barun nainty-nain ta koruġ ka, ġatun waita noa uwȧnu̇n na-uwil koa noa yuréa-matoara, kara-uwilli koa noa?
\p 
\v 5 Ġatun karawolléu̇n noa ba, wúnkilléu̇n ġaiya noa bamirruġ ka ġikoug kin, pitȧllo ba.
\p 
\v 6 Ġatun uwa noa ba ġura kako, wiya noa barun kótita ġatun taraikan wiyellin barun, Pitȧllia kanwa emmouġ katoa; kulla baġ karawolléu̇n ćipu ta emmoúmba unni, yuréa ba kakulla.
\p 
\v 7 Wiyan baġ nurun, yanti kiloa pitȧl kȧnȧn kauwȧllan moroko ka ba minki noa ba wakȧl yarakaikan, keawai barun kai murrȧrȧġ-tai tin nainty-nain ta tin, minki korien.
\p 
\v 8 Ġa wonnuġ-ke nukuġ púndol arguro ten ta bounnoun kinba, yuréa bountoa ba umȧnu̇n wakȧl púndol, wiya, bountoa wirroġ-banún kaipuġ ġatun wirrillinu̇n wirrillikanneto kirra-kirra-uwilli koa bountoa?
\p 
\v 9 Ġatun karawolléu̇n bountoa ba, wiya ġaiya bountoa ba kóti-ta ġatun taraikan tuiġko, wiyellin, Pitȧllia kauwa emmouġ katoa; kulla baġ karawolléu̇n yuréa bag ba umá.
\p 
\v 10 Yanti kiloa, wiyan baġ, nurun, unnuġ, ta pitȧl kȧtan mikan ta aġelo ka Eloi koba wakȧl lin ba yarakai-willuġ minki kȧnu̇n.
\p 
\v 11 Ġatun noa wiya, Taraito ku̇riko yinal bula-buloara ġikoúmba:
\p 
\v 12 Ġatan mittiko bulun kinbiruġ-ko wiya bon biyuġbai ġikoúmba, Biyuġ, ġuwa tia winta tullokan ka-uwil koa emmoúmba. Ġatun túnbilliela noa bulun tullokan.
\p 
\v 13 Ġatun keawai kauwȧl-kauwȧl, korien ta purreȧġ ka yukita, kauma noa mittiko yinallo, ġatun waita noa uwa kaloġ koba, ġatun unta noa wari-wareka tullokan ġikoúmba pittelliġél la.
\p 
\v 14 Ġatun wari-wareka noa ba kirun, kauwȧl kakulla unta kunto korien; ġatun tanoa-kȧl-bo kakulla ġaiya noa kapirrikan.
\p 
\v 15 Ġatun uwa ġaiya noa umulliko ku̇ri kako unta ko purrai ta ko; ġatun noa bon yuka ġikouġ, ka tako purrai tako ġiratimulliko buttikaġ, ko porȧk ko.
\p 
\v 16 Pitȧl ġaiya noa kakulla takilliko, ta-uwil ba buttikaġko: ġatun keawai ku̇riko bon ġupa.
\p 
\v 17 Ġatun noa kakilliela ba niuwoabo, wiyelliela ġaiya noa, Kauwȧl-kauwȧlla umullikan biyuġbai koba emmoúmba koba kunto kauwȧl barúnba takilliko ġatun ġukilliko, ġatun ġatoa kapirró wirribanbillin!
\p 
\v 18 Bouġkullinún wal baġ, waita biyuġbai tako, ġatun wiyȧnu̇n wal bon, Biyuġ, yarakai baġ umá mikan ta moroko ka, ġatun ġirouġ kin,
\p 
\v 19 Ġatun keawai baġ murrȧrȧġ korien wiya-uwil koa tia ġiroúmba yinal yitirra: umulla tia wakȧl yanti umullikan ġiroúmba.
\p 
\v 20 Ġatun noa bouġkulléu̇n, uwa ġaiya noa biyuġbai tako. Wonto noa ba kaloġ ka kauwȧl kakulla, nakulla noa bon biyuġbai-to ġikoúmba-ko, minki ġaiya noa kakulla, murrá ġaiya noa, puntimulléu̇n ġaiya noa ġikouġ kin wuroka, ġatun búmbúmbea-kan ġaiya bon.
\p 
\v 21 Ġatun noa bon yinallo wiyá, Biyuġ, yarakai baġ umulléu̇n mikan ta moroko ka ġatun ġirouġ kin, keawai bag murrȧrȧġ korien wiya-uwil koa tia ġiroúmba yinal yitirra.
\p 
\v 22 Wonto noa ba biyuġbaito wiya barun mankillikan ġiroúmba, Mara unnoa-unnuġ upilligél, ġatun upilla bon konéin kako, ġatun upilla riġ ġikouġ kin mȧttȧra, ġatun upilla bon tuġganoġ yulo ka ġikouġ kin:
\p 
\v 23 Ġatun mara tanan untiko buttikaġ italo ġiratimatoara kipai, ġatun turulla; tamunbilla ġearun, ġatun pitȧl koa ġéen kauwȧl:
\p 
\v 24 Koito ba unni emmoúmba yinal tetti kakulla, yakita ġaiya noa moron kȧtan: ġarawatilléún noa, ġatun yakita bummilléu̇n ġaiya bon. Ġatun pitȧl bara kakilli kolaġ.
\p 
\v 25 Unta ta ġarro ġikoúmba kakilliela upulliġél la purrai ta; ġatun uwolliela noa ba papai kokerȧ koba, ġurra noa tekki ġatun untelli ta.
\p 
\v 26 Ġatun noa kaaipa wakȧl mankillikan, ġatun wiya minnuġ-ban ġali tara minariġ tin.
\p 
\v 27 Ġatun wiya bon noa, Unni ta uwan ġiroúmba biġgai; ġatun ġiroúmba-ko biyuġbaito tura ġiratimatoara buttikaġ italo kipai ta, kulla wal pitȧl noa ġikouġ kai moron tin kȧtan.
\p 
\v 28 Ġatun noa niuwara kakulla, keawai noa murruġ kolaġ uwa pa; yaki tin noa biyuġbai ġikoúmba uwa ġatun pirriralma bon.
\p 
\v 29 Ġatun noa bon wiyayelliela ġikoúmba biyuġbai, Ela! kauwȧl-kauwȧlla wunȧlla umala baġ ġirouġ; keawai bag ġiroúmba wiyellikanne umá korien; ġatun keawai bi tia ġupa waréa buttikaġ kid, pitȧl koa tia ka-uwil baraj emmoúmba kótita:
\p 
\v 30 Wonto ba tanoa-bo ġiroúmba yinal uwa ġali, wari-wareka ġiroúmba tullokan yarakai-willuġ koa ko ġapal loa, tura ġaiya bi ġikouġ buttikaġ italo ġiratimatoara.
\p 
\v 31 Ġatun noa wiya bon, Yinal, yellawan bi emmouġ kin yantikatai, ġatun yantin unni tara emmoúmba ġirouġ kin kȧnu̇n.
\p 
\v 32 Murrȧrȧġ ta kakulla takilliko ġatun pittelliko; koito ba unni ġiroúmba umbeara-kóġ tetti kakulla, ġatun moron katéakan; ġatun ġarawatilléún, ġatun bummilléún bon yakita.
\c 16
\p 
\v 1 ĠATUN noa wiya barun ġikoúmba wirrobullikan, Untoa ta tarai ta wakȧl kúri tullokan porrólkan, mankillan piriwȧl ġikoúmba; ġatun wiyayéma bon ġikouġ wareka noa ġikoúmba tullokan.
\p 
\v 2 Ġatun noa wiya bon, wiyelliela, Yakoa baġ ġurra ġirouġ kinba? wiyella bi tia minariġ bi ba umulliela; keawai bi kara kȧnún umullikan.
\p 
\v 3 Wiyelléu̇n ġaiya noa mankillikan niuwoabo, Minnuġ, banu̇n baġ? kulla wal lia piriwȧllo emmoúmba ko mantilléún keawai bag mankillikan kȧnu̇n; keawai baġ pinninu̇n; koiyun baġ poiyelliko.
\p 
\v 4 Ġali wal baġ umulliko, yipanu̇n tia ba emmoúmba mankilliġél labiruġ, wamunbi-uwil koa tia bara kóti ko kokerá ko.
\p 
\v 5 Yanti ba wiya noa barun wiyatoara piriwȧl koba ġikoúmba, ġatun noa wiya wakȧl kurri-kurri ka, Minnan ba wiyapaiyéu̇n emmoúmba piriwȧl koba?
\p 
\v 6 Ġatun noa wiya, Hekaton ta wimbi ka karauwa. Ġatun noa wiya bon, Mara bi unni, yellawa kurrakai, upulla pentékonta koa ka-uwil.
\p 
\v 7 Wiya ġaiya noa tarai, Minnan bi wiyapaiyéu̇n piriwȧl koba? Ġatun noa wiyá, Hekaton ta wimbi wiet. Ġatun bon noa wiyá, Mara bi unni, upulla éty koa ka-uwil.
\p 
\v 8 Ġatun noa piriwallo murrȧrȧġ bon wiya unnoa mankillikan yarakai ka, kulla noa umá ġurakito; kulla bara wonnai tara unti ko purrai tako barúnba willuġġél koba ġuraki bara, keawai bara wonnai kaibuġ koba.
\p 
\v 9 Ġatun ġatoa nurun wiyan, Umulla nura bo kótita kakilliko tullo-yarakai tabiruġ; tetti nura ba kȧnu̇n, wamunbilla ġaiya nurun kokerá yuraki ba kȧtan yanti-katai.
\p 
\v 10 Niuwoa miroman ġali waréa ta, yanti miroman noa kauwȧl ġali ta; ġatun niuwoa yarakai-maye ġali waréa ta, yanti yarakaimaye ġali kauwȧl ta.
\p 
\v 11 Yaki tin keawai nura ba miroma pa tullo yarakai ta, ġanto wal nurun ġunu̇n tullo tuloa ta miromulliko?
\p 
\v 12 Ġatun keawai nura ba miroma pa tarai koba, ġanto wal ġunu̇n nurúnba kóti tako?
\p 
\v 13 Keawai wal mankillikanto umȧnu̇n buloara-bulun piriwȧl bula; kulla noa yarakai umȧnu̇n wakȧl bon, ġatun murrȧrȧġ umȧnu̇n tarai; ġa ba kȧnu̇n noa wakálla, ġatun béelmȧnu̇n bon tarai. Keawai nura kaiyu korien umulliko Eloi ko ġatun tullokan ko yarakai ko.
\p 
\v 14 Ġatun unni tara bara ġurra Parithaioiko, willirrikan bara kȧtan, ġatun bon bara béelma.
\p 
\v 15 Ġatun noa barun wiyá, Kauwa murrȧrȧġ koa nura ka-uwil mikan ta barun kin ku̇ri ka; wonto noa ba Eloito ġurran nurúnba búlbúl la ba; kulla unni tara murrȧrȧġ ta kȧtan barun kinba kȧri ko, yakaran ta kȧtan mikan ta Eloi kin.
\p 
\v 16 Wiyellikanne-ta ġatun bara propet kakulla loanne noa ba paipéa; yaki tabiruġ piriȧl koba Eloi koba wiyabunbéa,ġatun yantin ku̇ri waita-waitawolléu̇n murruġ kolaġ.
\p 
\v 17 Ġatun moroko ta ġatun purrai ta kaiyukan kánu̇n waita kolaġ, keawai waréa ta wiyellikanne koba ka korien kakilliko.
\p 
\v 18 Ġanto ba warekullinún porikunbai ġikouúmba ġatun tarai búmbéa ka, yarakai bu̇mbéa noa: ġatun ġanto ba buúmbinu̇n warekatoara poribal tabiruġ, yarakai búmbéa noa.
\p 
\v 19 Kakulla ta noa wakȧl porrólkan, upulléún noa ġoroġ-ġoroġ ko ġatun murrȧrȧġ ko kariġkareuġ ko, ġatun bon kakulla minnuġbo-minnuġbo kauwȧl takilliko ġatun pittelliko yantin ta pureȧġ ka:
\p 
\v 20 Ġatun kakulla ta wakȧl poiyaye ġiakai yitirra Ladharo, wúnkulla bon ba yapugġġél ġikouġ ka ta, warapál mita-mitaġ,
\p 
\v 21 Ġatun wiya bon ba mutuġ ko takilliko ġikouġ kai porroólbin tin takilliġél labiruġ; ġatun warikȧl uwa bara, woatȧ ġaiya bon mita-mitaġ.
\p 
\v 22 Yakita-kȧlai tetti kakulla poiyaye, ġatun kurriá bara bon aġelo-ko Abȧram kinko parraġ kako: tetti ġaiya noa porrólkan kakulla, ġatun bon núlká.
\p 
\v 23 Ġatun noa unta koiyuġ ka hell ka bouġkulléún ġikoúmba ġaikuġ, kakilliela tirriki ka, ġatun nakilliela bon Abȧramnuġ kaloġ ka, ġatun noa Ladharo parraġ ka kakilliela Abȧram kin.
\p 
\v 24 Ġatun noa kaaibulléu̇n, wiyelliela, Biyuġ Abȧram, ġurrara tia kauwa, ġatun yukulla bon Ladharonuġ, kurrimulli koa noa kokoin to, ġatun moiya koa tia tȧllȧġ wupi-uwil; kulla wal baġ kirrin kȧtan unti tirriki ka koiyuġ ka.
\p 
\v 25 Wonto noa ba Abaramko wiyá, Yinal, ġurrulla ġintoa yakita moron ta mantala murrȧrȧġ-tai ġiroúmba, wonto noa ba Ladharo yakaran mantala ġatun noa yakita pitȧl kȧtan, wonto bi ba kirrin kȧtan.
\p 
\v 26 Ġatun yanti umni ba, ġearun kinba willika ba pirriko wún-kulla; keawai uwȧnu̇n untikȧl untoa kolaġ: keawai bara unta biruġ, uwȧnu̇n untiko ġearun kinko.
\p 
\v 27 Wiya ġaiya noa, Wiyan banuġ, Biyuġ, yuka-uwil koa bon bintun kinko kokerá kolaġ:
\p 
\v 28 Kulla wal lia emmoúmba kotita pente; wiya-uwil koa noa barun yanoa bara ba tanan uwánún unti kolaġ tirriki-tirriki kako.
\p 
\v 29 Abȧramko noa wiya bon, Mothé noa ġatun bara propet barun katoa ba; ġurrabunbilla barun.
\p 
\v 30 Ġatun noa wiyá, Keawaran, biyuġ Abȧram; wakȧl ba uwolla barun kin unta biruġ tetti kabiruġ,ġurrȧnu̇n ġaiya wal bara.
\p 
\v 31 Ġatun noa bon wiyá, Keawai bara ba ġurrȧnu̇n bon Mothénuġ ġatun barun propetnuġ; keawai wal bara ġurrȧnu̇n wakȧl ba paikullinún moron tetti kabiruġ.
\c 17
\p 
\v 1 WIYA ġaiya noa barun wirrobullikan ġikoúmba, Kauwa yanti kȧnu̇n bo ta wal yarakai; yapalla noa ġikouġ kinbiruġ yarakai tabiruġ!
\p 
\v 2 Murrȧi ka ba noa ġira-uwil kea kulleuġ koa bon tunuġ, ġatun wareka uwil koa bon korowa ka, unni noa yanoa yarakai umabunbi yikora unti tara biruġ wakȧl wonnai tara biruġ.
\p 
\v 3 Yakoai nura kauwa: Kótiko ba ġirouġ, yarakai umȧnu̇n ġirouġ ka to, wiyella bon; ġatun minki noa ba kȧnu̇n, kȧmunbilla bon.
\p 
\v 4 Ġatun kauwál-kauwȧl-la biloa ba yarakai umȧnu̇n wakȧl la purreȧġ ka, ġatun kauwál-kauwȧl-la biloa willariġ noa kȧnu̇n wakȧl la purreȧġ ka, wiyellinu̇n biloa, Minki baġ kȧtan; kȧmunbinu̇n wal binuġ.
\p 
\v 5 Ġatun bon bara apothol wiyá, Piriwȧl, kauwȧl koa ġearúnba ġurrulli-ta ka-uwil kakilliko.
\p 
\v 6 Ġatun noa Piriwȧllo wiyá, Ka ba nuru̇nba ġurrulli-ta yanti kiloa mitti yeai mutard koba, wiyella wal nura ba unni ku̇lai thukamin, Wokka laġ bi kauwa wirrakan-bo, ġatun meapullia bi korowa ka; ġatun gala nurun ġurrȧnu̇n ġaiya wal.
\p 
\v 7 Ġan nurun kinbiruġ-ko upullin purrai nurun ka to mankillikan-to,ġa tamunbin buttikaġ, wiyȧnu̇n bon kabo, uwȧnu̇n noa ba upulliġġél labiruġ, Yuriġ bi wolla, yellawolliko ta-uwil koa?
\p 
\v 8 Ġatun wiya bon noa wiyȧnu̇n, Kurrakai umulla ta-uwil koa baġ, ġatun ġirullia bi ġintoabo, ġatun mara-uwil koa bi tia ta-uwil koa baġ ġatun pitta-uwil; ġatun willuġ ġaiya bi tanu̇n ġatun pittȧnu̇n?
\p 
\v 9 Wiya noa, wiyapaiyéu̇n bon mankillikan, koito noa ba uma unni tara wiya bon ba? Kotan baġ kearan.
\p 
\v 10 Yanti nura wiyella, umȧnu̇n nura ba yantin unni tara wiyatoara nurun, Umullikan ġéen murrȧrȧġ korien kȧtan; umá ta ġéen unni wiyatoara umulliko ġearun.
\p 
\v 11 Ġatun yakita kakulla, uwolliela noa ba Hierothalem kolaġ, uwa willi koa noa Thamaria koa ġatun Galilaia koa.
\p 
\v 12 Ġatun noa uwolliela ba tarai toa kokeróa, nuġgarawa bon bara ku̇ri ten ta purrul-wommun-wommun, ġarokéa kaloġ ka;
\p 
\v 13 Ġatun bara paibuġga pulli, ġatun wiya Iéthu, Piriwȧl, ġurrȧramulla ġearun.
\p 
\v 14 Ġatun nakulla noa barun, wiya barun noa, Yuriġ nura wolla, túġunbillia nura barun kin hiereu ko. Ġatun yakita kakulla, uwolliela bara ba, turon bara kakulla tanoa-kȧl-bo.
\p 
\v 15 Ġatun wakȧllo barun kinbiruġ-ko, nakilléu̇n noa ba turon noa kakulla, willuġbo noa uwa, ġatun kaaipulléu̇n noa wokka, pitȧlmulliela bon Eloinuġ,
\p 
\v 16 Ġatun puntimulléu̇n noa barán ġoara ko ġikouġ kin tinna ka, murrárȧġ noa bon wiyelléu̇n; ġatun noa Thamaria-kȧl.
\p 
\v 17 Ġatun noa Iéthuko wiyayelléu̇n, wiyelliela, Wiya, ten ta turon kakulla? ġa wonnuġ-ke bara taraikan nain ta?
\p 
\v 18 Keawai bara willuġ pa ba pitȧlmulliko bon Eloinuġ, wakȧl ba noa unni ġowikan ko.
\p 
\v 19 Ġatun noa wiya bon, Bouġkullia, yuriġ bi wolla; ġirouġ ka ba ko ġurrulli biruġ ko turon bi kȧtan.
\p 
\v 20 Ġatun wiya bon ba Parithaioiko, yakounta-ke paipinu̇n piriwȧl koba Eloi koba, wiyayelléu̇n noa barun, wiyelliela, Tanan uwan piriwȧl koba Eloi koba keawai na korien.
\p 
\v 21 Keawai bara wiyȧnu̇n wal, A unni ta! ġa unta ta! kulla, a! piriwȧl koba Eloi koba murruġ kaba kȧtan nurun kinba.
\p 
\v 22 Ġatun noa wiya barun wirrobullikan, A! purreȧġ ta wal kȧnu̇n, na-uwil koa nura wakȧl purreȧġ Yinal koba ku̇ri koba, ġatun keawai wal nura nanu̇n.
\p 
\v 23 Ġatun bara nurun wiyȧnu̇n wal, Na-uwa unni; ġa, na-uwa unnuġ: yanoa barun uwa yikora, wirroba yikora.
\p 
\v 24 Yanti kiloa pirruġgun-to uwan tarai tabiruġ ko moroko biruġ ko, tarai ta kako moroko kako; kauwa yanti kiloa wal kȧnu̇n Yinal ku̇ri koba purreu̇g ka ġikouġ ka ta.
\p 
\v 25 Ġatun kurri-kurri ta bon umȧnu̇n minnuġbo-minnuġbo, ġatun warekatéa wal bon ġali koba willuġġél koba.
\p 
\v 26 Ġatun yakita ba kakulla purreȧġ ka Noe-úmba ka, yanti bo ta wal kȧnu̇n purreȧġ ka Yinal koba ku̇ri koba.
\p 
\v 27 Takillala bara, pittellala bara, búmbillala bara nukuġ, ġukillala búmbilli ka, yakita purreȧġ ka kakulla noa ba Noe uwa murrariġ murrinauwai ka, ġatun tunta-tunta kakulla, ġatun kirun ġaipa barun nuropa.
\p 
\v 28 Ġatun yanti yakita ba kakulla purreȧġ ka Lot-úmba, takillala bara, pittellala bara, wirrilliala bara, ġukillala bara, meapala bara, wittiala bara;
\p 
\v 29 Wonto ba yakita unta purreȧġ ka Lot noa uwa Thodóm kabiruġ, patéa ġaiya koiyuġ-ko ġatun brimtón-ko wokka tin moroko tin, ġatun kiyupa barun yantin kirun tetti-tetti.
\p 
\v 30 Yanti kiloa kȧnu̇n yakita purreȧġ ka paipinu̇n noa ba Yinal ku̇ri koba.
\p 
\v 31 Unta yakita purreȧġ ka kȧtan noa ba wokka kokerá, ġatun ġikoúmba tullokan murruġ kaba kokera ba, keawai bon uwabunbi yikora barán mankilliko tullokan ko; ġatun kȧtan noa ba upulliġél laba, keawai bon uwabunbi yikora willuġ, kolaġ.
\p 
\v 32 Kotella bounnoun kai nukuġ Lot-úmba tin.
\p 
\v 33 Ġanto ba ġikoúmba moron miromȧnu̇n moron kakilliko, woġúntinún wal noa; ġatun ġanto ba woġúntinún ġikoúmba moron, kȧnu̇n wal moron kakilliko.
\p 
\v 34 Wiya nurun baġ, yakita unta-unta tokoi ta buloara ta kȧnu̇n birrikilliġél la wakȧl la; manu̇n wal wakȧl, ġatun tarai ġaiya wunu̇n.
\p 
\v 35 Buloara umullinún bula; mánún wal wakȧl, ġatun tarai ġaiya wunún.
\p 
\v 36 Buloara katéa-kȧnu̇n upulliġél la; mánu̇n wal wakȧl, ġatun tarai ġaiya wunu̇n.
\p 
\v 37 Ġatun wiyelléu̇n bon bara, wiyelliela, Piriwȧl, wonnuġ-ke? Gatun noa wiya barun, Unta wonto ba katéa-kȧnu̇n murrin ta, unta kolaġ ba kautillinu̇n bara porowi.
\c 18
\p 
\v 1 ĠATUN noa wiya barun wakȧl parabol, wiya-uwil koa bon bara ku̇riko Eloinuġ, ġatun yari koa bara kaiyaléa-ku̇n;
\p 
\v 2 Wiyelliela, Unta ta kokerá tarai ta wakȧl wiyellikan piriwȧl kakulla, kinta korien kakulla noa bon Eloi kai, ġatun keawai noa tuma korien barun ku̇ri:
\p 
\v 3 Ġatun kakulla wakȧl mabogun unta kokerá; ġatun bountoa uwa ġikouġ kin, wiyelliela, Timbai kakillia tia emmoúmba bukkakaye.
\p 
\v 4 Ġatun keawai wal noa ġurra pa kabo kakullai tako; wonto noa ba yukita wiya ġikouġ kinko minki ka, Keawai baġ kinta korien bon Eloi kail kȧtan, ġa keawai ku̇ri tuman korien;
\p 
\v 5 Kulla bountoa tia unni mabogunto pirralman, ġatoa timbai kȧnu̇n bounnoun kin, murrin-murrin koa bountoa tia uwa-uwil kumburrobawanl bountoa tia.
\p 
\v 6 Ġatun noa Piriwȧllo wiya, Gurrulla bon unni yarakai wiyellikan piriwȧl wiyan ba.
\p 
\v 7 Ġatun wiya noa Eloito timbai katillinu̇n barun ġikoúmba ġirimatoara bara wiyan bon purreȧġ ka ġatun tokoi ta, ġurralin noa barun wiyelli ta kaloġ tinto?
\p 
\v 8 Wiyan nurun baġ, timbai wal noa katillinȧn barun kurrakai. Wonto noa ba uwȧnu̇n wal Yinal ku̇ri koba tanan, wiya, noa nanu̇n ġurrullikanne purrai taba?
\p 
\v 9 Ġatun noa wiya barun unni parabol tarai tako kotelléu̇n bara ba murrȧrȧġ-tai barabo, ġatun yarakai bara kotellin taraikan:
\p 
\v 10 Buloara-bula ku̇ri uwa hieron kolaġ wiyelliko: wakȧl la noa Parithaio ġatun tarai ta teloné;
\p 
\v 11 Ġarokéa noa Parithaio ġatun noa yanti wiyelliela niuwoabo ġiakai: A Eloi! pitȧlman baġ ġirouġ, kulla baġ ka korien yanti tarai ba kȧtan, bara kau-maye, tuloa uma korien mankiye nukuġ ka, ġa ka korien bag yanti unni noa ba telóne:
\p 
\v 12 Ta korien baġ buloarakȧl kȧtan wakál la thabbat biruġ ka, ġutan baġ winta untikȧl emmouġ kai yantin tabiruġ.
\p 
\v 13 Ġatun noa telóné ġarokilliela ba kaloġ ka, keawai noa ġaikuġ ka wokka laġ na pa moroko koba, wonto noa ba minki motilliela wiyelliela ba, A Eloi! miromulla bi tia, yarakai bag ba kȧtan.
\p 
\v 14 Wiyan nurun baġ, unni noa kúri uwa barȧn kokerá koba ġikouġ ka tako ġurrȧmatoara, keawai tarai ta: kulla yantin bara piriwȧl-buntelliko, kȧnu̇n wal bara koiyun-barátoaro; ġatun niuwoa bo koai-koai korien bon, umȧnu̇n kauwȧl bon kakilliko.
\p 
\v 15 Ġatun mankulla bara ġikouġ kinko wonnai tara numa-uwil koa barun noa: wonto ba nakulla bara ba wirrobullikanto, yipa bara barun.
\p 
\v 16 Wonto ba noa Iéthuko wiya barun, wiyelliela, Wamunbilla barun wonnai tara emmouġ kinko, ġatun yanoa barun yipai yikora; kulla barun-kai-kȧl katéa-kȧnu̇n piriwȧl koba Eloi koba.
\p 
\v 17 Wiyan baġ tuloa nurun, Ganto ba ġurra korien piriwȧl koba Eloi koba yanti wonnai waréa ba, keawai wal noa pulóġkullinu̇n unta kolaġ.
\p 
\v 18 Ġatun taraito umullikanto piriwȧllo wiya bon, wiyelliela, Piriwȧl murrȧrȧġ-tai, minnuġ-bullinu̇n bag moron kakilliko yantikatai?
\p 
\v 19 Ġatun noa Iéthuko wiya bon, Minariġ tin bi tia wiyan murrȧrȧġ-tai emmouġ? keawai wal wakȧl murrȧrȧġ-tai, wonto noa ba wakȧlbo, Eloi ta.
\p 
\v 20 Ġurran bi yantin wiyellikanne, Yanoa manki yikora nukuġ taraikan koba, Yanoa búnki yikora tetti, Yanoa manki yikora, Yanoa nakoiya yikora, Ġurulla bon biyuġbai ġatun tunkán ġiroúmba.
\p 
\v 21 Ġatun noa wiya, ġurra bag unni tara wiyellikanne yakikalai tabiruġ, wonnai baġ ba kakulla.
\p 
\v 22 Ġatun yakita ġurra noa ba Iéthuko unnoa tara, wiya bon noa, Wakȧl unnoa-unnuġ uma korien bi ba; ġukillia yantin tullokan ġirou̇mba, ġu-uwil koa barun mirrȧl ko, ġatun tullokan ġiroúmba kȧnu̇n wal wokka ka moroko ka; ġatun kaai, wirroba-uwil koa bi tia.
\p 
\v 23 Ġatun ġurra noa ba unni, minki noa kakulla kauwȧl; kulla noa porrol kakulla kauwȧlkan.
\p 
\v 24 Ġatun noa ba Iéthuko nakulla bon minki noa ba kakulla kauwȧl-lan, wiya ġaiya noa, Pirral ta pulóġkulliko bara tullokan ta ba piriwȧl koba kako Eloi koba kako!
\p 
\v 25 Kamel noa kaiyukan kȧtan pulóġkakilliko tiġkuġkoa ko aku lako, keawai porrólkan pulóġkakilliko piriwȧl koba kako Eloi koba kako.
\p 
\v 26 Ġatun bara ba ġurrȧ, wiya bara, Ġan-ke wal moron kȧnu̇n kakilliko?
\p 
\v 27 Ġatun noa wiyá, Unni tara kaiyu korien ku̇ri ko umulliko, kaiyu-kan-to Eloito noa umulliko.
\p 
\v 28 Ġatun Peterko noa wiyá, Ela! wúnkulla ġéen yantin ta, ġatun wirroba ġéen bin.
\p 
\v 29 Gatun noa wiya barun, Wiyȧnu̇n baġ tuloa, Niuwoa wareka kokera ġikoúmba, ġa biyuġbai, ġa tunkán, ġa ġapal, ġa wonnai, ġikouġ, kinko piriwȧl koba tin Eloi koba tin,
\p 
\v 30 Mȧnu̇n wal noa kauwál unti yakita, ġatun untoa tarai ta purrai ta tanan kakilliko, moron noa kánún yanti-katai.
\p 
\v 31 Mankulla ġaiya noa barun dodeka ta wirrobullikan,ġatua wiya barun, A! waita ġéen wokka kolaġ Hierothalem kolaġ, ġatun yantin tara wiyatoara propet to ġikouġ, kai Yinal lin kúri koba tin kȧnu̇n wal umatoara kakilliko.
\p 
\v 32 Ġatun bon ġunu̇n wal barun kin ethȧnékȧl kinko, ġatun bon bukka-manu̇n wal, ġatun karaġkobinu̇n:
\p 
\v 33 Ġatun wélkorinún wal bara bon, ġatun wal bon wirrinu̇n; ġatun kúmba-ken-ta bouġkullinún ġaiya noa willuġbo.
\p 
\v 34 Ġatun keawai bara ġurrapa unni tara wiyatoara: ġatun unni wiyellikanne yuropa barun kai, keawai bara ġurrápa unni tara wiyatoara.
\p 
\v 35 Ġatun yakita kakulla, uwolliela noa ba papai Yeriko ka, wakȧl munmin ku̇ri yellawolliela yapuġ ka bitta ka, poiyelliela:
\p 
\v 36 Ġatun ġurrulliela noa barun konara yapuġ koa, wiya noa minariġ unni?
\p 
\v 37 Ġatun bara bon wiyá, Uwan noa Iéthu Nadharet-kȧl.
\p 
\v 38 Ġatun noa kaaipulléu̇n, wiyelliela, Ela Iéthu! yinal Dabidúmba, ġurrȧra-mulla bi tia.
\p 
\v 39 Ġatun bara uwa ġanka, wiya bon koiyelli koa noa: wonto noa ba butti paiyelléu̇n, Yinal Dabidúmba gintoa, ġurrȧra-mulla bi tia.
\p 
\v 40 Ġatun ġarokéa noa Iéthu, ġatun wiya bon yutilliko bon ġikouġ kinko; ġatun uwa noa ba papai, wiya bon noa,
\p 
\v 41 Wiyelliela, Minnuġ-bulliko bi tia wiyan? Gatun noa wiyan, Piriwȧl, namunbilliko tia umulla.
\p 
\v 42 Ġatun noa Iéthuko wiya bon, Kȧmunbilla bin nakilliko; ġiroumba tin ġurrulli tin moron uma.
\p 
\v 43 Ġatun noa tanoa-kȧl-bo nakulla, ġatun bon noa wirropa, pitȧlmulliela bon Eloinuġ; ġatun yantin unni ku̇ri nakulla bara ba, pitȧlma bon Eloinuġ.
\c 19
\p 
\v 1 ĠATUN noa Iethu uwa Willi koa Yeriko koa.
\p 
\v 2 Ġatun kakulla untakȧl wakȧl ku̇ri ġiakai Dhakké yitirra, piriwȧl telónékȧl noa kakulla, ġatun noa porrólkan.
\p 
\v 3 Ġatun noa numéa nakilliko Iéthunuġ, ġan noa ba; ġatun noa keawai, kulla konaró núntima, kulla noa waréa ġoiyoġ.
\p 
\v 4 Ġatun noa murra ġanka, ġatun noa kulliwa wokka-laġ, ku̇lai tin nakilliko bon, kulla noa unta kolaġ uwolli kolaġ.
\p 
\v 5 Ġatun Iéthu noa ba uwa untako, nakulla noa wokka-laġ, ġatun bon nakulla, ġatun bon wiyá, Ela Dhakké! tanan kurrakai tirabulla, kulla buġgai koa baġ yellawȧnu̇n ġirouġ ka ta kokerȧ.
\p 
\v 6 Ġatun tiraba noa kurrakai barán, ġatun pitȧl ma-uwa bon.
\p 
\v 7 Ġatun nakulla bara ba, wiyellan niuwarakan bara yantinto, wiyelliela, Waita noa uwa yarakai toa kóti kakilliko.
\p 
\v 8 Ġatun noa Dhakké ġarokéa, ġatun wiya bon Piriwȧlnuġ, Ela Piriwȧl! winta baġ ġutan emmou̇mba tullokan kabiruġ mirrȧl kai ko; ġatun mankulla baġ ba tullokan taraikan tabiruġ yaki tin ġakoiyaye tin, wupinu̇n ġaiya bon baġ willuġbo warán tako.
\p 
\v 9 Ġatun noa Iéthuko bon wiyá, Tanan uwa moron unti buġgai purreȧġ ka unti ko kokera ko, kulla noa kȧtan yinal ta Abȧramuúmba.
\p 
\v 10 Kulla Yinal ku̇ri koba uwa tiwolliko ġatun tumulliko woġu̇ntitoara ko.
\p 
\v 11 Ġatun ġurra bara ba unni tara, wiyéakan butti noa ġatun wiya wakȧl parabol, kulla noa papai ta ba Hierothalem ka, ġatun kulla bara kota paipillinu̇n piriwȧl koba Eloi koba tanoa-kȧl-bo.
\p 
\v 12 Yaki tin noa wiyá, Tarai ta piriwȧl uwa tarai tako purrai tako kaloġ kako, mankilliko ġikouġbo piriwȧlkanne-ta, ġatun willuġbulliko.
\p 
\v 13 Ġatun wiya noa barun ġikoúmba mankillikan ten ta, ġatun ġukulla noa barun kin mina ta ten ta, ġatun wiya barun, Miromulla uwȧnu̇n baġ ba willuġbo.
\p 
\v 14 Wonto ba ġikou̇mba-ko konara niuwama bon, ġatun yuka bon puntimai ġikouġ, wiyelliela, Keawai wal noa unni piriwȧl katillinu̇n ġearun.
\p 
\v 15 Ġatun kakulla yakita, willuġ ba noa ba, mantoara piriwȧlkoba, wiya ġaiya noa barun unnoa mankillikan ġan kin noa ba ġukulla money, tanan ġikouġ kin, ġurra-uwil koa noa minnan barun kinba ġutoara ġukilli tabiruġ.
\p 
\v 16 Tanan ġaiya uwa kurri-kurri wakȧl, wiyelliela, Ela Piriwȧl! ġiroúmba ta mina unni wittia kauwȧl ten mina ta.
\p 
\v 17 Ġatun bon noa wiyá, Kauwa yanti, ġintoa mankillikan murrȧrȧġ; kulla bi miroma unnoa waréa ta, kaiyukan bi kanwa ten ta kokera.
\p 
\v 18 Ġatun tarai uwa, wiyelliela, Ela Piriwȧl! ġiroúmba ta mina unni wittia kauwȧl pente mina ta.
\p 
\v 19 Ġatun noa wiya ġaiya bon, Kauwa bi kaiyukan pente ta kokera.
\p 
\v 20 Ġatun tarai uwa, wiyelliela, Ela Piriwȧl! na-uwa unni ta mina ġiroúmba, wúnkulla baġ ba koroka wurobilla:
\p 
\v 21 Kulla baġ kinta kakulla ġirouġ kai, kulla bi bukka kauwȧl; mantan bi wokka-laġ keawai bi ba wunpa barán, ġatun kólbúntia bi unnoa keawai bi ba meapa ba.
\p 
\v 22 Ġatun noa bon wiyá, ġirouġ kinbiruġ kóti ko kurraka ko wiyan pirriral-manu̇n banuġ, ġintoa ta mankillikan yarakai. Ġurra bi tia bukka kauwál baġ; mantillin wokka-laġ keawai baġ wunpa barán, ġatun kólbu̇ntillin unnoa keawai baġ ba meapa ba:
\p 
\v 23 Kora koa bi ġupa emmoúmba money ġukilliġél lako, marauwil koa baġ emmoúmba kóti ġatun kopatoara ta, emmouġ ka ta uwolli ta?
\p 
\v 24 Ġatun noa wiya barun ġarokilliela bara ba taruġ ka, Mantillia unnoa mina unti biruġ bon, ġatun ġuwa bon gala ko tenkan ko ġikouġ.
\p 
\v 25 (Gatun bara wiya bon, Piriwȧl, ten ta mina mantan noa).
\p 
\v 26 Wiyan nurun baġ, Yantinko barun mantan bara ba ġunu̇n wal butti; ġatun keawaran noa ba, unnoa ta mantan noa ba mantillinún wal bon ġikouġ, kinbiruġ.
\p 
\v 27 Kulla bara unnoa emmoúmba niuwa-maye, keawai bara emmouġ kȧnu̇n bi ba piriwȧl barun, mara barun, bú-uwil koa barun emmouġ kin mikan ta
\p 
\v 28 Ġatun wiya noa ba unnoa, waita ġaiya noa ġanka uwa wokka-laġ Hierothalem kolaġ.
\p 
\v 29 Ġatun kakulla yakita, uwa noa ba papai Bethȧbage tako ġatun Bethany tako, bulkȧra ta ġiakai yitirra Elaión ka la, yakunbéa noa buloara-bulun ġikoúmba wirrobullikan,
\p 
\v 30 Wiyelliela, Yuriġ nura wolla kokeraá ko kaiyin tako; uwollinu̇n nura ba untariġ, nanu̇n ġaiya nura wirritoara waréa buttikaġ keawai yellawa pa kúri bulka ka: buruġbuġgulla unnoa, ġatun yemmamulla untiko.
\p 
\v 31 Ġatun tarai-kan-to ba wiyȧnu̇n, Minariġ tin nura unnoa ta buruġbuġgan? ġiakai nura wiyella bon, Kulla noa Piriwȧllo wiyá.
\p 
\v 32 Ġatun bara ba yukatoara, waita uwa, ġatun nakulla ġaiya bara yanti noa ba wiya barun ba.
\p 
\v 33 Ġatun buruġbuġgulliela bara ba unnoa waréa buttikaġ, ġikoúmba-ko wiya barun, Minariġ tin nura buruġbuġgan unni waréa buttikaġ?
\p 
\v 34 Ġatun bara wiyá, Piriwȧllo noa wiya ġala.
\p 
\v 35 Ġatun bara yemmama bon kinko: ġatun bara wupéa barun ba kirrikin bulka ka buttikaġ ka, ġatun wupéa bon bara Iéthunuġ wokka ka.
\p 
\v 36 Ġatun uwolliela noa ba, wupéa bara yapuġ ka kirrikinkan nurúnba.
\p 
\v 37 Ġatun uwa noa ba papai, bará ka Elaión ka ba koba bulkára koba, yantin konara wirrobullikan pitȧl ġaiya kakulla, ġatun pitȧlmulliela bon Eloinuġ kauwȧl lo pulli to, yantin tin kauwȧl Iin uma ba nakulla bara ba;
\p 
\v 38 Wiyelliela, Pitȧlmabunbilla bon Piriwȧl ta uwan noa ba Yehóa-úmba koa yitirroa: pital-kȧmunbilla moroko ka, ġatun killibinbin kȧmunbilla wokka ka.
\p 
\v 39 Ġatun winta-ko Parithaioi kabiruġ konara biruġ wiya bon, Piriwȧl, koawa bi barun ġiroúmba wirrobullikan.
\p 
\v 40 Ġatun noa wiyayelléún barun, wiyelliela, Wiyan nurun baġ, wiya, bara ba kaiyellinún mupai, kaibullinún wal ġaiya unni tara tunuġ tanoa-kȧl-bo.
\p 
\v 41 Ġatun uwa noa ba papai, nakulla noa kokera kariġ, ġatun noa tuġkillimilléu̇n ġaloa rin,
\p 
\v 42 Wiyelliela, Ġurrapa bi ba, ġintoa ta, unti purreȧġ ka ġirouġ ka ta unni tara pitȧl-kakilliko ġiroúmba ko! wonto ba yakita yuropa ta ġirouġ, kai nakilli tin ġaikuġ tin.
\p 
\v 43 Kulla purreȧġ, ta kánún ġirouġ kin, bukka-kan-to ġirouġ wirrinu̇n wal bara kirrai kirai-karai ġirouġ, ġatun karai-karai wirrinún ġirouġ, ġatun mirrámanún bin willi ka yantin ta kaiyinkaiyin ta,
\p 
\v 44 Ġatun pirikibunpinún bin purrai ta, ġatun ġiroúmba wonnai tara murruġ kaba ġirouġ, kinba; ġatun keawai bara wupinu̇n tunuġ tarai ta wokka ka; kulla keawai bi ba ġurra pa yakita natala ba ġiroúmba.
\p 
\v 45 Ġatun noa uwa murrariġ kolaġ, ġatun yipa ġaiya noa barun ġukillikan, ġatun barun mankillikan unta biruġ;
\p 
\v 46 Wiyelliela barun, Upatoara unni, Emmoúmba kokera ta wiyelliġél kokera; wonto ba nura uma unni wollo kakilliko barun nankiye-ko.
\p 
\v 47 Ġatun wiyelliela noa purreȧġ ka yantin ta murruġ ka hieron ka. Wonto ba piriwȧl hiereu, ġatun bara ġȧrammateu, ġatun bara piriwȧl ku̇ri koba, numa bara bon búnkilli kolaġ;
\p 
\v 48 Yakoai bara ba umulliko ġatun keawai bara, kulla yantin ta ku̇ri pitȧl kakilliela ġurrulliko bon.
\c 20
\p 
\v 1 ĠATUN yakita kakulla, wakȧl la tarai ta purreȧġ ka, wiyelliela noa ba barun ku̇ri ka, ġatun wiyelliela euaġelion, uwa ġaiya bon bara piriwȧl ġatun bara gȧrammateu ġatun bara pȧrethbuteroi,
\p 
\v 2 Ġatun wiya bon, wiyelliela, Wiyella ġearun, minariġ tin kaiyu tin umullia bi unni tara? ġa ġanto-ke noa bin unni ta kaiyu ġukulla ġirouġ?
\p 
\v 3 Ġatun noa wiyayelléu̇n, ġatun wiyelliela barun, Ġatoa wiyȧnu̇n nurun unni ta wakȧl; ġatun wiyayelléa tia;
\p 
\v 4 Korimullikanne-ta Ioanne-úmba, wiya, ta morokó kabiruġ, ġa ku̇ri koba?
\p 
\v 5 Ġatun bara wiyatan barabo, wiyelliela, Wiyȧnu̇n ġéen ba, Morokó kabiruġ ta; wiyȧnu̇n, ġaiya noa, Kora koa nura ġurrapa bon?
\p 
\v 6 Kulla ġéen wiyȧnu̇n ba, Ku̇ri koba ta; yantinto ġaiya ġearun ku̇riko pintinu̇n tunuġ ko: kulla bara kotan bon Ioannenuġ propet ta kakulla.
\p 
\v 7 Ġatun bara wiyá, keawai bara ġurrapa wonta biruġ ta.
\p 
\v 8 Ġatun noa barun Iéthuko wiya, Keawai baġ, wiyánu̇n nurun minariġ tin kaiyu tin uman baġ unni tara.
\p 
\v 9 Ġatun potopaiyá ġaiya non barun ku̇ri wiyelliko unni-ta parabol: Taraito ku̇riko meapa wain-ġel la, ġatun wu̇nkulla barun kin upullikan ta, ġatun uwa ġaiya noa kalog kolaġ, yuraki.
\p 
\v 10 Ġatun yakita poaikulléu̇n ba, yuka noa bon wakȧl umullikan barun kin upullikan ta, ġu-uwil koa bara bon yeai wainġél labiruġ; wonto bara ba bu̇nkulla bon, ġatun yuka bara bon waita yeai korien.
\p 
\v 11 Ġatun noa toanta yukéa-kan tarai umullikan: ġatun bara bon búntéa-kan yantibo, ġatun yarakai uma bara bon, ġatun bon bara yuka waita yeai korien.
\p 
\v 12 Ġatun noa toanta yukéa-kan ġoro-ta, ġatun bara bon mularéa-kan, ġatun wareka bara bon warrai tako.
\p 
\v 13 Wiya ġaiya noa piriwállo wain-gél koba, Minnuġ banu̇n kan baġ? Yukȧnu̇n wal baġ emmoúmba yinal pitȧlmatoara; mirka bara bonġurránu̇n, nanu̇n bon bara ba.
\p 
\v 14 Wonto bara ba upulli-kan-to nakulla bon ba, barabo ġaiya wiyellan, wiyelliela, Unni ta wúġgurra piriwál: kaai ġéen bu̇wil bon, purrai koa ka-uwil ġearúnba.
\p 
\v 15 Yanti bon bara wareka wain-ġél labiruġ, ġatun búnkulla ġaiya bon tetti. Minnuġ banu̇n noa barun piriwállo wain-ġél koba ko?
\p 
\v 16 Uwȧnu̇n wal noa tanan búnkilliko barun upillikan-ko, ġatu̇n ġunu̇n wal wain-ġél taraikan ko. Ġatun ġurra bara ba unni, wiya ġaiya bara, Kámunbi yikora Eloito.
\p 
\v 17 Ġatun noa barun nakilliela, ġatun wiyá, Minariġ-ke unni upatoara yanti, Tunuġ ta wareka wittilli-kán-to, unnoa ta katéakȧnu̇n wokka ka waiyakan ta wolluġ?
\p 
\v 18 Ġan-ba puntimullinún untoa tunuġ ka tiirpuntimullinún, wal; ġan kinba puntimullinún, minbinu̇n wal bon muta-mutan.
\p 
\v 19 Ġatun tanoa-kȧl-bo kota bara piriwállo hiereuko ġatun gȧrammateuko mankilliko bon; ġatun bara kinta kakulla konará tin; kulla bara ġurrá, wiya noa ba unni parabol barun kin.
\p 
\v 20 Ġatun bara bon tuminéa, ġatun yuka barun ġakoiyellikan, ġakoġkilliko barunbo ku̇ri murrarȧġ-tai, ġurra-uwil koa bara ġikoúmba wiyellikanne, yaki tin mara-uwil koa bara bon kaiyu kabo kobȧna kinko.
\p 
\v 21 Ġatun wiya bon bara, wiyelliela, Piriwȧl, ġurran ġéen wiyan bi ba tuloa, kinta kora bi kauwa taraikan tin ku̇ri kurriġ tin, wonto bi ba wiyan tuloa wiyellikanne Eloi koba:
\p 
\v 22 Wiya tuloa ta ġukilliko ġearun tullokan ġikouġ kin Kaithari kin, ġa keawai?
\p 
\v 23 Wonto noa ba ġurra ġakoiya baru̇nba, ġatun wiya barun, Yakoai nura tia numan?
\p 
\v 24 Túġunbilla tia wakȧl denari. Gan kiloa unnoa ġoara ġatun upatoara unni ta? Wiyayelléu̇n bon bara ġatun wiyelliela, Kaitharúmba ta.
\p 
\v 25 Ġatun noa wiya barun, Koito Kaithari kinko ġuwa Kaitharúmba ta, ġatun Eloi kinko unnoa tara Eloi-úmba ta.
\p 
\v 26 Ġatun keawai bara man pa ġikoúmba wiyelli-ta mikan ta barun kin ku̇ri ka: ġatun mupai kakulla bara.
\p 
\v 27 Uwa ġaiya taraikan barun kinbiruġ Thadukaioi kabiruġ bara ġurramaiġaye moron ta katéa-kȧnu̇n tetti kabiruġ; ġatun bara bon wiyá,
\p 
\v 28 Wiyelliela, Ela Piriwȧl Mothéto noa upa ġearun, Taraikan koba ba kóti tetti kȧnu̇n ba porikunbai ġikou̇mba ta, ġatun tetti noa ba kȧnu̇n, wonnai korien, mara-uwil koa ġikoúmba kóti bounnoun ġikoúmt porikunbai ka-uwil koa wonnai ġikoúmba koti koba.
\p 
\v 29 Yakita ġaiya warán kakulla kótita theben ta: ġatun kurri biruġ ko búmbéa porikunbai kakilliko, ġatun tetti kakulla, wonnai korien.
\p 
\v 30 Ġatun willi-kaba-ko deutero-to búmbéa bounnoun porikun bai kakilliko, ġatun tetti noa kakulla, wonnai korien.
\p 
\v 31 Ġatun willi-kaba-ko trito-to búmbéa bounnoun porikunbai kakilliko; ġatun yaki-bo thebento; ġatun bara keawai wimba wonnai, ġatun tetti bara kakulla.
\p 
\v 32 Willuġ ta tetti ba bountoa nukuġ.
\p 
\v 33 Ġanúmba barun kinba unnoa porikunbai kȧnu̇n kakilliko moron ba katéa-kȧnu̇n tetti kabiruġ? kulla bara thebento bounnoun búmbéa porikunbai kakilliko.
\p 
\v 34 Ġatun noa Iéthuko wiyayelléu̇n, wiyelliela barun, Wonnai ta untikȧl búmbillan porikunbai ġatun ġukillaiko búmbilliko:
\p 
\v 35 Wonto ba bara murrárȧġ-tai kȧnu̇n uwolliko unta kolaġ tanai tako purrai tako, ġatun moron kakilliko tetti kabiruġ, keawai bara búmbúmbillan, keawai ġukitan búmbilliko:
\p 
\v 36 Keawai wal bara tetti banún yukita; kulla bara yanti kȧtan aġelo kiloa; ġatun wonnai tara kȧtan Eloi-úmba, kȧtan bara wonnai tara ġali koba moron kȧnu̇n tetti kabiruġ.
\p 
\v 37 Ġatun Mothéko noa ba túġaiya wakȧl la ku̇lai ta, bouġbuġga barun tetti-tetti kabiruġ, wiya noa ba bon Yehóanuġ, Eloi ta Abȧramúmba, ġatun Eloi ta Itháku̇mba, ġatun Eloi ta Yacobu̇mba.
\p 
\v 38 Keawai noa Eloi ta barúnba tetti-tetti koba, wonto ba barúnba moron koba; kulla yantin moron kȧtan ġikouġ kin.
\p 
\v 39 Taraito bara gȧrammateukȧllo wiya ġaiya, Piriwȧl, murrȧ rȧġ bi wiyan.
\p 
\v 40 Ġatun yukita keawai bara bon wiya pa kinta-kan-to.
\p 
\v 41 Ġatun noa barun wiyá, Yakoai bara wiya Kritht ta yinal ta Dabidúmba?
\p 
\v 42 Ġatun Dabidto noa niuwoabo wiyá, biblion kaba tehillim koba, Yehóako noa wiya bon Piriwȧl emmoúmba, Yellawolla bi túġkaġkeri ka emmouġ kin,
\p 
\v 43 Uma-uwil koa baġ barun bukkakan ġikoúmba yuloġél ko kakilliko ġikouġ.
\p 
\v 44 Dabidto noa ba wiya bon Piriwȧl yitirra, yakoai ġaiya noa yinal ta ġikoúmba?
\p 
\v 45 Wiya ġaiya noa barun ġikoúmba wirrobullikan mikan ta yantin ta ku̇ri ka,
\p 
\v 46 Yakoai nura barun kai gȧrammateu tin, pitȧl koa bara uwa-uwil kurrawitaikan, ġatun umulliko ġukilliġél laba ko, ġatun yellawolliġél la wokka ka thunagóg ka, ġatun piriwȧl-ġél takilliġél laba;
\p 
\v 47 Mantan bara kokera ba mabogun koba, ġatun umȧnu̇n wiyellikanne-ta kurra-uwai tu̇ġunbilliko: yaki tin bara kȧnu̇n kauwȧl tetti kakilliko.
\c 21
\p 
\v 1 ĠATUN noa nakulla wokka-laġ, ġatun nakulla barun porrólkan wúnkilliela ġutoara baru̇nba wúnkilliġél la.
\p 
\v 2 Ġatun noa nakulla tarai mabogun mirrálkan wúnkilliela bountoa lepto buloara unta ko taroġ kako.
\p 
\v 3 Ġatun noa wiya barun, Wiyan baġ nurun tuloa, ġali mabogunto mirrȧllo wúnkulla kauwȧl ta bara yantin kearan.
\p 
\v 4 Kulla yantin ġali wúnkulla bara tullokan barúnba kauwȧl labiruġ ġutoara Eloi koba ko: wonto bountoa ba bounnoun kinbiruġ mirrál koba wúnkulla yantin tullokan bounnou̇nba.
\p 
\v 5 Ġatun winta koba wiyelliela hieron tin, umatoara unni korien tunuġ ko murrȧrȧġ ko ġatun ġutoara, wiya noa,
\p 
\v 6 Unni tara natan nura ba, uwanȧn ta purreȧġ kariġ ka; korien ġaiya ba wakȧl tunuġ wokka-ka-wokka-ka, yantin wal warekullinún barán.
\p 
\v 7 Ġatun bara bon wiyá, wiyelliela, Piriwȧl, yakounta-ke unni tara kánu̇n? ġatun minariġ túġa kánún unni tara ba ġaiya kȧnu̇n?
\p 
\v 8 Ġatun noa wiyá, Yakoai nura, ġakoiya kora koa nura ka-uwil; kulla kauwȧl-kauwállo tanan uwánún emmouġ kin yitirra, wiyellinu̇n, ġatoa ta (Kritht ta); ġatun papai ta kakillin; yanoa uwa yikora nura barun.
\p 
\v 9 Ġurrȧnu̇n ġaiya nura ba wurawai kauwȧl ġatun koakillai ta ba, kinta kora nura: kulla unni tara kȧnu̇n wal kurri-kurri, kulla wirán keawai kȧnu̇n kabo.
\p 
\v 10 Wiya ġaiya noa barun, Bara ku̇riko wuruwai wal kȧnu̇n barun ku̇riko, ġatun bara piriwȧl koba barun piriwȧl koba ko:
\p 
\v 11 Ġatun purrai tako pulululu kakilliko winta ka bo, ġatun kunto korien ta ko, ġatun munni kauwȧlkan; ġatun kinta nakilli tara ġatun kauwȧl kȧnu̇n túġa morokó kabiruġ.
\p 
\v 12 W onto ba kurri-kurri ka unni tara ba kȧnu̇n, manu̇n wal bara mȧttȧrro nurun, ġatun yarakai nurun umánu̇n, ġumullinu̇n nurun thunagóg kako, ġatun jail ko, mantoaro nurun mikan ta ko piriwȧl lako, ġatun wiyellikan tako emmouġ kinko yitirra ko.
\p 
\v 13 Ġatun unni ta kȧnu̇n nurun túġa kakilliko.
\p 
\v 14 Yanoa nura kota yikora minki ko, minariġ nura wiyayellinu̇n.
\p 
\v 15 Kulla baġ ġunu̇n nurun kurraka ġatun ġuraki kakilliko, keawai wal yantin bara nurúnba bukka-kan-to kaiyu kȧnu̇n wiyayelliko ġa pirriral umulliko.
\p 
\v 16 Ġatun nura ġakoiyellinún wal nurun biyuġbaito ġatun kóti tako kariġ ko, ġatun winta nurun kinbiruġ búnnu̇n wal tetti barun kai.
\p 
\v 17 Ġatun nurun yarakai umȧnu̇n yantinto, emmoúmba tin yitirra tin
\p 
\v 18 Wonto ba keawai wal wakȧl kittuġ ġikouġ, kinbiruġ wolluġ kabiruġ tetti kȧnúu̇n.
\p 
\v 19 Murrȧi kakillikanne nurúnba ka, miromulla nura marai nurúnba?
\p 
\v 20 Ġatun nanu̇n nura ba Hierothalem kirrai-kirrai ta ba konara ba ġurrulla papai ta ba ġaiya wari-warekulli ta ba unnuġ.
\p 
\v 21 Murrabunbilla ġaiya barun Iudaia kaba waita bulkȧrá kolaġ; ġatu uwabunbilla barun willi kaba waita warai tako; ġatun uwabunbi yikora barun tanan koruġ kaba untako.
\p 
\v 22 Kulla yakita unti tara purreȧġ ka bukka kakillikanne, kauwil koa yantin upatoara kȧnu̇n wal kakilliko.
\p 
\v 23 Yapallun bara wonnaikun ġatun bara pittallikun, yakita ġaiya purreȧġ ka! kulla wal kȧnu̇n kauwȧl yarakai purrai ta, ġatun bukka unti yantin ta ku̇ri ka.
\p 
\v 24 Ġatun bara tetti kapaiyinu̇n yirrá biruġ, ġatun barun yutinu̇n wal mantoara kakilliko yantin tako purrai kariġ kako: ġatun Hierothalem wattawȧnu̇n barán bara ethȧnékȧl-lo, yakita kalai tako barúnba koba ġoloin kȧnu̇n ethȧnékȧl.
\p 
\v 25 Ġatun ġaiya kȧnu̇n wal túġa punnȧl la, ġatun yellana ka, ġatun mirri ka; ġatun purrai taba yarakai ta barun kin ku̇ri ka, ġatun kinta kauwȧl korowa ta ġatun bókkaloġ kólbilaġbullin;
\p 
\v 26 Ku̇ri koba búlbúllo kotan kinta-kan-to, ġatun nakilli tabiruġ ġaloa tara kotanan ba uwȧnu̇n purrai kolaġ; kulla wal barun tolomȧnu̇n wal kaiyukan ta moroko koba.
\p 
\v 27 Ġatun yakita ġaiya wal nanu̇n Yinal ta kúri koba tanan uwollillu̇n yareil loa kaiyu koa, ġatun killibinbin koa kauwȧl loa.
\p 
\v 28 Ġatun kȧnu̇n ba unni tara paipinún, na-uwa wokka-laġ, ġatun wokka-laġ kauwa kia-kia nurúnba wolluġ; kulla tanan uwȧnu̇n paipai nurúnba wommunbillikanne-ta.
\p 
\v 29 Ġatun noa wiya barun wakȧl parabol; Na-uwa kokuġ ta, ġatun yantin ku̇lai ta;
\p 
\v 30 Paikullinu̇n bara ba, nanu̇n nura ġatun ġuurrȧnu̇n nura nurun kinbiruġ wunȧl kȧtan paipai taba.
\p 
\v 31 Yaki kiloa nura, nanu̇n nura ba unni tara paikulliko, ġurulla ġaiya nura piriwȧl koba Eloi koba kátan papai taba.
\p 
\v 32 Wiyan tuloa nurun baġ, Keawai unni willuġġél tetti-tetti kȧnu̇n, yakita-ko ġoloin ba kȧnu̇n.
\p 
\v 33 Moroko ta ġatun purrai ta kánún wal waita uwȧnu̇n, wonto ba keawai wal emmoúmba wiyellikanne unni tara keawai wal waita uwȧnu̇n.
\p 
\v 34 Ġatun yakoai nura nurabo, kauwa ba yantin ta nurúnba bu̇lbúl matayel koa katéa-ku̇n ġatun kuttawaiban koa katéa-ku̇n, ġatun umillikéu̇n koa katéa-ku̇n ġali koba moron koba, ġatun yanti ta purreȧġ ka paipinu̇n ġati nurun kin.
\p 
\v 35 Kulla pika kiloa yanti uwȧnu̇n untoa purreȧġ ka barun kin yellawan yintin ta yaki tin purrai ta.
\p 
\v 36 Tumimilla nura, ġatun wiyellia yanti-katai to, ka-uwil koa nura murrȧrȧġ kakilliko moron ko unti tara biruġ paikullinu̇n wal ġatun ġarokilliko mikan tako yinal lako ku̇ri koba ko.
\p 
\v 37 Ġatun purreȧġ ka wiyelliela noa murruġ ka hieron la; ġatun noa uwa waita tokoi ta, ġatun yellawa noa bulkȧra ġiakai yitirra Elaión ka la.
\p 
\v 38 Ġatun yantin bara ku̇ri uwa ġorokan ta ġikouġ kinko hieron lako, ġurrulliko bon.
\c 22
\p 
\v 1 YAKITA kakulla papai takillikanne nulai lebben korien koba, ġiak yittira Pathak.
\p 
\v 2 Ġatun bara piriwȧl hiereuko ġatun ġȧrammateuko nukilliela búnkilli kolaġ bon tetti wirrilliko; kulla bȧra kinta kakulla ku̇ri tin
\p 
\v 3 Pulóġkulléu̇n noa Thatánto murruġ ka bon Iudathkin, tarai yitirra ġiakai Ithȧkariot, wakȧl noa dodeka kabiruġ.
\p 
\v 4 Gatun noa waita uwá, ġatun wiyelliela barun piriwál hiereunuġ ġat barun kapátin, yakoai noa ba ġakoyánún bon barun kin.
\p 
\v 5 Ġatun pitál kakulla, ġatun bara wiya ġukilliko bon arguro.
\p 
\v 6 Ġatun noa wiyai, ġatun mittilliela noa ġakomulliko bon barun kin, yakita bara ba konara waita ġaiya uwa.
\p 
\v 7 Kakulla ġaiya purreȧġ nulai lebben korien ta, yakita Pathak bunnu̇m wal ba tetti.
\p 
\v 8 Ġatun noa yuka Peternuġ ġatun Ioannenuġ, wiyelliela, Yuriġ uwolla umulliko Pathak ta, ta-uwil koa ġéen.
\p 
\v 9 Ġatun bara bon wiyá Wonta-ke ġéen umȧnu̇n?
\p 
\v 10 Ġatun noa barun wiyá, A! nauwa nura, yakita uwánún nura ba kokerá kariġ ka, unta ġaiya nurun wakȧllo ku̇riko wimbi-kaba-kan-to kokoin-kan-to nuġgurra uwȧnu̇n nurun; wirrobulla bula bon murruġ kolag kokerá kolaġ unta-ko pulóġkullinu̇n noa ba.
\p 
\v 11 Ġatun wiyȧnu̇n nura bon kokeratin, Piriwallo wiyan bin, Wonnuġ waiyakan takilliġél, untoa baġ ba tanun Pathak ta emmoúmba katoa wirrobullikan toa?
\p 
\v 12 Ġatun nurun túġkaiyȧnu̇n wal noa kauwȧl ta waiyakan wokka kaba wupitoara: unnuġ umulla.
\p 
\v 13 Ġatan bara waita uwa, ġatun nakulla bara unni tara yantin ba wiya barun: ġatun bara upéa Pathak ta.
\p 
\v 14 Ġatun yakita kakulla hóra ba, yellawa noa barán, ġatun dodeka ta apothol ta ġikouġ katoa.
\p 
\v 15 Ġatun noa barun wiyá, Kauwȧl ta emmoúmba kotatoara takilliko unni Pathak ta nurun katoa, ta-uwil koa kurri-kurri tetti kolaġ ke baġ:
\p 
\v 16 Kulla baġ wiyan nurun, Keawai wal baġ tanu̇n unta-kȧl kabo ba kȧnu̇n piriwȧl koba ka Eloi koba.
\p 
\v 17 Ġatun noa mankulla wimbi, ġatun pitȧlma ġaiya noa, wiyelliela, Mara unni ġukillai koa nurabo:
\p 
\v 18 Kulla baġ wiyan nurun, Keawai wal baġ pittȧnu̇n yeai tabiruġ ampelo tabiruġ, kabo koa uwa-uwil piriwȧl koba Eloi koba tanan.
\p 
\v 19 Ġatun noa mankulla arto ta, ġatun pitȧlma ġaiya noa, ġatun yiirbuġga, ġatun ġukulla barun, wiyelliela, Unni ta emmoúmba murrin ġutoara nurun kin: umulla unni yanti ġurrulliko tia.
\p 
\v 20 Yantibo wimbi takilli biruġ yaréa ka, wiyelliela, Unni wimbi ta wiyatoara ta buġgaikȧl emmouġ kinbiruġ ġoroġ kiroapa nurun kai.
\p 
\v 21 A! na-uwa, unni ta mȧttȧra ġikoúmba ġakoyelli-kan-to tia, emmouġ katoa ba takilliġél laba.
\p 
\v 22 Yuna bo ta wal noa uwȧnún Yinal ku̇ri koba, yanti wiyatoara; yapallun unnoa kúri ġakoyelli-kan-to bon ba!
\p 
\v 23 Ġatun bara wiyellan barabo, ġan-to barun kinbiruġ-ko umȧnu̇n ta unni.
\p 
\v 24 Ġatun koakillan bara barabo, ġan-ke kȧnu̇n piriwȧl barun kinbiruġ.
\p 
\v 25 Ġatun noa wiya barun, Bara ta piriwȧl ethȧnékȧl koba katilléu̇n bara; ġatun bara ta katillikan ġiakai yitirra murroġ-tai.
\p 
\v 26 Wonto nura ba keawai yanti kȧnu̇n; wonto noa kurrikóġ nurun kinba, kȧmunbilla bon yanti mitti; ġatun noa piriwȧl kȧtan, yanti umullikan ta.
\p 
\v 27 Wonnuġ-ke kauwȧl unnuġ, niuwoa yellawan noa ba takilli ta, niuwoa umȧnún noa ba? wiya, unni ta noa yellawollin ba takilli taba? wonto baġ ba kȧtan nurun kinba yanti niuwoa ba umullikan ta.
\p 
\v 28 Nura ta emmouġ kin minkéa emmouġ ka ta numatoara:
\p 
\v 29 Ġatun ġutan nurun baġ kakilliko piriwȧlġél lako, yanti tia emmoúmba Biyuġbaito ġukulla tia;
\p 
\v 30 Ta-uwil koa nura ġatun pitta-uwil emmouġ ka ta takilliġél la emmouġ ka ta piriwȧlġél la, ġatun yellawa-uwil yellawolliġél la piriwȧl koba ka, wiyellin barun konara dodeka ta Ithȧrael koba.
\p 
\v 31 Ġatun noa piriwȧllo wiyá, Ela Thimon, Thimon! ġurrulla, Thantánto noa wiyan bin mankilliko kirrai-kirrai koa biloa uma uwil yanti wiet kiloa:
\p 
\v 32 Wonto baġ ba wiyelléu̇n ġirouġ kai ġurra-uwil koa bi; ġatun minki bi ba kȧnu̇n, pirralmulla ġaiya barun bi kóti ta ġiroúmba.
\p 
\v 33 Ġatun noa wiya bon, Piriwȧl, kȧtan baġ unni miriġil uwolli kolaġ ġikouġ katoa ko jail kolaġ ġatun tetti kakilli kolaġ.
\p 
\v 34 Ġatun noa wiyá, Wiyan banuġ, Peter, keawai wal mukkaka ko tibbinto wiyȧnu̇n unti purreȧġ ka, kurri-kurri ka bi ba ġakoyȧnu̇n tia ġoro-ka ġimillin bi tia ba.
\p 
\v 35 Ġatun noa wiya barun, Yuka nurun baġ ba yinuġ korien, ġatun pika korien, ġatun tuġganóġ korien, wiya, nura minariġ lo? ġatun bara wiyá, Keawai.
\p 
\v 36 Wiya ġaiya noa barun, Wonto ba yakita unti, niuwoa ba yinuġkan, mamunbilla bon unnoa, ġatun yanti pika; ġatun niuwoa yirra korien, ġumunbilla kirrikin ġikoúmba, wakȧl koa noa ġukilli ko.
\p 
\v 37 Wonto baġ ba wiyan nurum, unni ta upatoara ka-uwil koa emmouġ kin kakilliko ġiakai, Tumbitoara noa barun kin yarakai willuġ ka: kulla unni tara emmouġ kin ba kakillinu̇n ġoloin ko.
\p 
\v 38 Ġatun bara wiyá, Piriwu̇l, na-uwa unni tuloa buloara yirra. Ġatun noa wiya barun, Tantoa-bo-ta
\p 
\v 39 Ġatun noa uwa warrai koba, ġatun waita uwa uwolli kolaġ bulkȧra kolaġ Elaión ko la kako; ġatun ġikoúmba wirrobulli-kan wirroba bon.
\p 
\v 40 Ġatun uwa noa ba unta, wiya ġaiya noa barun, Wiyella, keawai koa nura pulóġkulli korien yarakai kolaġ.
\p 
\v 41 Ġatun noa waita uwa barun kinbiruġ yanti kiloa tunuġ koba pintia, ġatun waroġbugko upullin barán, ġatun wiyá,
\p 
\v 42 Wiyelliela, Biyuġ, wiya bi unni wimbi manu̇n emmouġ kinbiruġ: yanoa emmoúmba kotellikanne ġiroúmba ta kȧmunbilla kakilliko.
\p 
\v 43 Ġatun paipéa wakál aġelo moroko kabiruġ pirriralmullin bon.
\p 
\v 44 Ġatun kirrinkan noa kanwȧlkan, wiyelliela noa pirriral butti; ġatun ġikoúmba kurrol upulléu̇n barán purrai kolaġ yanti kiloa komonba kauwȧl ġoroġ koba.
\p 
\v 45 Ġatun bouġkulléún noa ba wiyelli tabiruġ, ġatun uwa ġikoúmba tako wirrobullikan tako, nakulla ġaiya noa barun birriki birriki minkikan,
\p 
\v 46 Ġatun noa wiya barun, Minariġ tin nura birrikin? Bouġkullia ġatun wiyella, uwéa-kun koa nura yarakai kolaġ.
\p 
\v 47 Ġatun yakita wiyelliela noa ba, a! konara, ġatun noa yitirra ġiakai Iudath, wakȧl ta dodeka kabiruġ, uwa ġanka barun kin, ġatun uwa ġaiya noa papai Iéthu kin, búmbúmkakilliko.
\p 
\v 48 Wonto noa ba Iéthuko bon wiya, Ela Iudath! ġakoman binuġ Yinal ku̇ri koba búmbuġgullito?
\p 
\v 49 Nakulla bara ba ġikouġ kinba minnuġ-bulli kolaġ, wiyabon bara, Ela piriwal! wiya, ġéen búntan yirra ko?
\p 
\v 50 Ġatun wakȧl barun kinbiruġ kunbuntéa wakȧl umullikan hiereu koba piriwȧl koba, ġatun kunbuntéa bon túġkaġ-keri ġurréuġ.
\p 
\v 51 Ġatun Iéthuko noa wiyayelléu̇n, ġatun wiyelliela, Kamunbilla nura unni. Gatun bon noa numa ġurréuġ ġatun turon bon uméa-kan
\p 
\v 52 Wiya ġaiya Iéthuko barun piriwál hiereu koba, ġatun barun kapȧtin hieron koba, ġatun barun ġarrokȧl, uwa bara ġikouġ kin, Wiya, nura tia uwan yanti mankiye ko yarakaikan ta, yirrakan ġatun kotarakan?
\p 
\v 53 Kakulla baġ ba nurun kin yanti-katai purreȧġ ka hieron ka, keawai nura tia manpa mȧttȧrro: wonto ba unni yakita ta katan nurúnba ġatun kaiyukan tokoi tako.
\p 
\v 54 Mankulla ġaiya bara bon, ġatun yutéa bon, mankulla ġaiya bon kokera ko piriwȧl koba kako hiereu koba kako. Gatun Peterko noa wirroba kaloġ kolaġ.
\p 
\v 55 Ġatun upilléu̇n bara ba koiyuġ ko willi ka kokera, ġatun yellawa yantin, Peter ġaiya noa yellawa barun kin.
\p 
\v 56 Ġatun taraito murrakinto nakulla bon, yellawa noa ba koiyuġ ka ġatun pimmilliela bon pirrallo, ġatun wiya, Unni noa ku̇ri kakulla ġikouġ katoa.
\p 
\v 57 Ġatun noa ġakoiya bon, wiyelliela, Ela murrakin! keawai bon baġ ġimilli korien.
\p 
\v 58 Ġatun toanta taraito bon nakulla, ġatun wiyelliela, Gintoa ta yanti bo barúnba. Gatun noa Peterko wiyá, Ku̇ri, keawaran baġ.
\p 
\v 59 Ġatun, yakita toanta, wakál hora ta yukita, taraito wiya pirralma wiyelliela, Yuna bo ta unni kuri kakulla ġikouġ katoa; kulla noa Galilaiakȧl.
\p 
\v 60 Ġatun noa Peterko wiyá, Ela ku̇ri! keawai baġ ġurran yakoai bi ba wiyan. Ġatun wiyelliela noa ba, tanoa-kal-bo muk-kaka-ko ġaiya wiya tibbinto.
\p 
\v 61 Ġatun noa Piriwȧl warkulléu̇n,ġatun nakilléu̇n bon Peternuġ. Ġatun Peterko noa ġurra wiyellita Piriwȧl koba, wiya bon noa ba ġiakai, Gikoyȧnu̇n wal bi tia kurri-kurri tibbinto mukkaka ko wiyȧnu̇n ġoro-ka.
\p 
\v 62 Ġatun Peter noa uwa warrai koba, ġatun tu̇ġkilléu̇n ġaiya noa kauwȧl.
\p 
\v 63 Ġatun bara ku̇riko mankulla bon Iéthunuġ béelma bon, ġatun bu̇nkulla bon.
\p 
\v 64 Ġatun munmin bara ba upéa bon, bu̇nkulla ġaiya bon bara ġoará, gatun wiya bon, wiyelliela, Wiyella bi, ġanto-ke bin búnkulla?
\p 
\v 65 Ġatun kauwȧl-kauwȧl taraikan yarakai wiya bara ġikouġ kin.
\p 
\v 66 Ġatun purreȧġ ba kakulla, kau-umullan ġaiya bara ġarrotai ku̇ri koba, ġatun bara piriwȧl hiereu koba, ġatun bara ġȧrammateu, ġatun yutéa ġaiya bon kau-umulliġél lako barúnba tako,
\p 
\v 67 Wiyelliela, Kritht ta bi unni? wiyella ġearun. Ġatun noa wiya barun, Wiyȧnu̇n nurun baġ ba, keawai ġaiya wal nura ġurrȧnu̇n:
\p 
\v 68 Ġatun wiyánún nurun baġ ba, keawai wal nura wiyaiyellinún tia, keawai wal nura tia wamunbinu̇n.
\p 
\v 69 Kabo noa Yinal ku̇ri koba yellawȧnu̇n túġkaġ ka kaiyukan ta Eloi koba ka.
\p 
\v 70 Wiya ġaiya bara yantinto, Yinal ta bi unni Eloi koba? Gatun noa wiya barun, Wiyan nura ġatoa ta unni.
\p 
\v 71 Ġatun bara wiya tantoa ta, Yanoa ġearun kin ġurrullikanto taraito? kulla ġéen ġurra ġéebo kurraka kabiruġ, ġikouġ kinbiruġ kóti kabiruġ.
\c 23
\p 
\v 1 ĠATUN bara yantin konara bouġkulléu̇n, ġatun yutéa bon Pilato kin.
\p 
\v 2 Ġatun bon bara pirralma, wiyelliela, Ġurra ġéen bon unni ġakoyelliela noa ba barun ku̇ri willuġġél, ġatun wiyelliela, yanoa ġuki yikora tullokan Kaitharinuġ, wiyelliela, niuwoa-bo-ta Kritht ta wakȧl ta Piriwȧl.
\p 
\v 3 Ġatun Pilato-to wiya bon, wiyelliela, Ġa ġintoa ta Piriwál kátan baru̇nba Iudaioi koba? Ġatun noa wiyayelléún bon, ġatun wiyá, Ġintoa ta wiyan.
\p 
\v 4 Wiya ġaiya noa Pilato-to barun piriwál hiereu ġatun barun ku̇ri, Keawai baġ ġurra pa yarakai unti ku̇ri ka.
\p 
\v 5 Ġatun bara bukka-buttibuġkéa, wiyelliela, Pirralman noa barun ku̇ri wiyellin, yantin ta Iudaia ka, Galilaia tinto unti kolaġ.
\p 
\v 6 Ġurra noa ba Pilato-to Galilaia ka, wiya noa, Unni kúri Galilaiakȧl?
\p 
\v 7 Ġatun ġurra noa ba Herodúmba-kan noa wottaikan, yuka bon noa Herod kinko, yakita ġaiya niuwoabo kakulla Hierothalem ka.
\p 
\v 8 Ġatun nakulla bon noa ba Herodto Iéthunuġ, pitȧl ġaiya noa kȧtan kauwȧl, kulla noa natelli ba bon yuraki tabiruġ, kulla noa ġurra kauwȧllan ġikouġ kinba; ġatun nakilliko tarai umatoara ġikouġ kai.
\p 
\v 9 Wiya ġaiya bon noa wiyellikanne kauwȧl-kauwȧl; wonto noa ba keawai wiyelli pa bon.
\p 
\v 10 Ġatun bara piriwȧl hiereu ġatun bara ġȧrammateu ġarokilliela, ġatun pirralmulliela bon kauwȧl.
\p 
\v 11 Ġatun Herod katoa ba bara wuruwai koba ġurramaiġa bon bara, ġatun béelma bon, ġatun wuda bon konéin to kirrikin to, ġatun yukéa-kan bon Pilato kinko.
\p 
\v 12 Ġatun unta purreȧġ ka wakȧl la, Pilato ġatun Herod kóti bula umullan: yakita unta kakillan bula bukkakan bula-bo.
\p 
\v 13 Ġatun Pilato-to noa kau-wiya noa ba barun piriwȧl hiereu, ġatun barun piriwȧl, ġatun barun ku̇ri,
\p 
\v 14 Wiya ġaiya barun, Mankulla nura bon unni ku̇ri eummouġ kinko yanti wakȧl noa ġakoya-uwil ba ku̇ri; ġatun, a! ġurulla, nuiya ta bon baġ unni mikan ta nurun kin keawai baġ ġurrapa yarakai ġikouġ kin, ġinoa-tara tin pirralma bon nura:
\p 
\v 15 Keawaran, keawai Herodto: kulla baġ yuka nurun ġikouġ kin; ġatun nauwa, keawai ġali tin tetti korien noa kȧnu̇n.
\p 
\v 16 Wélkorinu̇n wal bon baġ, ġatun wamunbinún ġaiya bon.
\p 
\v 17 (Kulla noa buruġbuġgȧnu̇n wal wakȧl yakita ta takillikan ne ta.)
\p 
\v 18 Ġatun bara kaaibulléu̇n wakȧlla purawai, wiyelliela, Yuriġ unni kúri; ġatun buruġbuġgulla bon Barabbanuġ ġearun kinko:
\v 19 (Ġali noa wakȧl wuruwai tin kokerá ġatun búnkilli tin tetti tin wúnkulla bon jail ka.)
\p 
\v 20 Koito noa ba Pilato-to kotelliela buruġbuġgulliko bon Iéthunuġ, wiyéa ka barun.
\p 
\v 21 Wonto bara ba wiyá, wiyelliela, Buwa bon tetti, buwa bon tetti.
\p 
\v 22 Ġatun noa barun wiya yukita ġoro-ka, Minariġ tin? minariġ noa yarakai umá? keawai baġ ġurrapa taraikan ġikouġ kin ġaloa kolaġ búnkilli kolaġ tetti wirrilliko; wélkorinu̇n wal bon baġ, ġatun wamunbinu̇n bon.
\p 
\v 23 Ġatun bara tanoa-kȧl-bo pulli kakulla kauwȧl, wiyelliela, búwil koa bon tetti. Ġatun pulli baru̇nba ġatun barúnba piriwȧl hiereu pirral kakulla.
\p 
\v 24 Ġatun Pilato-to noa wiyá, ka-uwil koa yanti wiya bara ba.
\p 
\v 25 Ġatun noa bon buruġbuġga barun kin unni bon wuruwai tin ġatun bunkilli tin tetti tin wúnkulla bon jail ka wiyatoara barúnba; ġatun noa bon Iéthunuġ wamunbéa barun kin.
\p 
\v 26 Ġatun yutéa bon bara ba yuriġ, mankulla ġaiya bara wakál Thimónnuġ Kureniakȧl ta, tanan uwolliela koruġ tin, ġatun wupéa bara ġikouġ kin taliġkabillikanne, kurri-uwil koa noa willuġ tin Iéthu katoa.
\p 
\v 27 Ġatun wirroba bon bara kauwállo konaro, ġatun bara nukuġ-ko, túġkilliela ġatun minki kakilliela ġikouġ kai.
\p 
\v 28 Wonto noa ba Iéthu warkulléu̇n barun kai koba, wiyá, Yinálkun Hierotilalemkȧlin, túġki yikora emmouġ kai, wonto ba túġkillia nura nurunbo, ġatun nurun kaiko wonnai tara ko.
\p 
\v 29 A! na-uwa, purreuȧġ kariġ tanan uwollinu̇n, yakita unta wiyȧnu̇n bara ba, Murrȧru̇ġ bara wonnai korien, ġatun unnuġ tara pika keawai pórkulli korien, ġatun paiyil keawai pittelliko.
\p 
\v 30 Yakita ġaiya bara wiyellan bulkȧra kariġ, Puntimullia ġearun kin, ġatun yúnko ko, Wutilla ġearun.
\p 
\v 31 Ġatun uwullinu̇n bara ba unni tara ku̇lai ta kiruġ ka, minnuġ banu̇n wal ku̇lai ta turrȧl la?
\p 
\v 32 Ġatun unnuġ bula taraikan yarakai willuġ, yutéa ġikouġ katoa wúnkilliko tetti wirrilliko.
\p 
\v 33 Ġatun uwa bara ba unta ko, ġiakai yitirra Kalȧbary, unta ġaiya bara búnkulla bon ġatun bulun yarakai bula, wakȧl ta túġkaġ-keri ka ġatun tarai ta wunto-keri ka.
\p 
\v 34 Wiya ġaiya noa Iéthuko, Biyuġ, kȧmu̇nbilla barun, kulla bara keawai ġurra korien umulli ta. Ġatun toinbillan bara kirrikin ġikoúmba, ġatun wupillan woiyo.
\p 
\v 35 Ġatun bara nakilliela ġarokito. Ġatun bara piriwȧl yantibo barun katoa béelmulliela, wiyelliela, Miromá noa taraikan; miromabunbillia bon ġikouġ kóti, wiya noa ba Kritht ta, ġirimatoara Eloi-úmba.
\p 
\v 36 Ġatun bara militiko béelma bon, uwolliela ġikouġ kin, ġatun nupilliela bon aket,
\p 
\v 37 Ġatun wiyelliela, Wiya bi ba piriwál Iudaioi koba, miromullia bi ġintoabo kóti.
\p 
\v 38 Ġatun upulléu̇n wakȧl upatoara wokka ka ġikouġ kin pulli Hellenik koba, ġatun Latin koba, ġatun Hebȧraio koba, ġiakai, Unni ta Piriwál Iudaioi koba.
\p 
\v 39 Ġatun wakȧllo yarakai bulun kinbiruġ-ko, kakilliela ba ku̇lai ta, béelmulliela bon, wiyelliela, Wiya bi ba Kritht ta, miromullia bi ġintoabo ġatun ġearun.
\p 
\v 40 Wonto ba taraito wiyayelléuu̇n, koakilliela bon, wiyelliela, Keawai bi kinta korien Eloi kai, ġatun ġintoa ta kȧtan wakȧl la umatoara?
\p 
\v 41 Ġatun ġalin yakita murrȧrȧġ umá; yaki tin ġalin kai umatoara tin: wonto noa ba ġali ku̇riko, keawai noa yarakai umá pa.
\p 
\v 42 Ġatun noa wiya Iéthunuġ, Piriwȧl, ġurrulla bi tia, uwȧnu̇n ġaiya bi ba piriwȧlġél lako ġirouġ ka tako.
\p 
\v 43 Ġatun noa Iéthuko wiya bon, Yuna bo ta wal baġ wiyan ġirouġ, Unti buġgai purreȧġ ka kȧnu̇n bi tia emmouġ katoa Parȧdeith ka tako.
\p 
\v 44 Ġatun yakita kakulla hora ka hekto ta, tokoi ta kakulla yantin ta purrai ta katéa ka hóra kako nain tako.
\p 
\v 45 Ġatun punnȧl ta tokoi kakulla, ġatun kirrikin ta hieron kako yiirkulléu̇n búlwa koa.
\p 
\v 46 Ġatun noa ba Iéthuko kaaibulléu̇n wokka wiya noa, Biyuġ, wunu̇n baġ emmoúmba marai ġirouġ kin mȧttȧra; ġatun wiyelléu̇n noa ba unni, wu̇nkulla ġaiya noa marai
\p 
\v 47 Yakita ġaiya noa ba kenturionko nakulla unni umatoara, pitȧlma noa Eloinuġ, wiyelliela, Yuna bo ta wal murrȧrȧġ unni ku̇ri.
\p 
\v 48 Ġatun bara yantin ku̇ri uwa nakilliko ġala ko umatoara ko, wirrilléu̇n bara wapara, ġatun willuġbo bara uwa.
\p 
\v 49 Ġatun yantin ġikoúmba kóti ta, ġatun bara nukuġ wirroba bon Galilaia kabiruġ, ġarokéa kaloġ ka, nakilliela unni tara.
\p 
\v 50 Ġatun kakulla wakȧl ku̇ri, ġiakai yitirra Yothep, wiyellikan kȧtan; murrȧrȧġ kakillikan, ġatun tuloa kakillikan:
\p 
\v 51 Ġali keawai noa pitȧl korien barúnba ko wiyellikanne ko ġatun barúnba umatoara ko; Arimathéakȧl noa, wakȧl ta kokera Iudaioi koba; niuwoa ba mittilliela piriwál lako Eloi koba kako.
\p 
\v 52 Unni noa uwa Pilato kin, bon wiyelliko murrin ko Iéthu koba ko.
\p 
\v 53 Ġatun noa mankulla barán, ġatun muġgama kirrikin ta, ġatun wúnkulla tulmun ta umatoara tunuġ ta; keawai ba unta ku̇ri wúntelli ta.
\p 
\v 54 Ġatun unta purreȧġ ka tupoi-tupoi-kanne-ta, ġatun papai kakulla thabbat ta.
\p 
\v 55 Ġatun bara nukuġ uwa ġikouġ katoa Galilaia kabiruġ wirroba yukita, ġatun nakulla tulmun, yakoai ba wúnkulla murrin.
\p 
\v 56 Ġatun bara willuġbo, ġatun mankulla aromata ġatun mura; ġatun koréa purreȧġ ka thabbat ta, yaki tin wiyatoara tin.
\c 24
\p 
\v 1 YAKITA kakulla puneȧġ ka yukita thabbat biruġ ka,ġoiokan ta, uwa bara unti ko tulmun tako, mankillin aromata umá bara ba, ġatun taraikan uwa barun katoa
\p 
\v 2 Ġatun bara nakulla tunuġ umatoara kurrai-kurrai biruġ kurraka ko tulmun tabiruġ.
\p 
\v 3 Ġatun bara uwa murrariġ, ġatun keawai bara na korien murrin ta Piriwál koba Iéthu koba.
\p 
\v 4 Ġatun yakita kakulla, kotelliela bara ba ġe tin, a! buloara ku̇ri bula ġarokéa barun kin killibinbin kaba kirrikin taba,
\p 
\v 5 Ġatun bara ba kinta kakilliela, ġatun wu̇nkulliela barúnba ġoara baran purrai tako, wiya bula barun, Minariġ tin nura nakillin moron-kan ta unti tetti-tetti ka?
\p 
\v 6 Keawai noa unti, kulla noa waita ka ba bouġkulléún: ġurrulla nura yanti wiya nurun noa ba, yakita noa ba kakulla Galilaia ka,
\p 
\v 7 Wiyelliela, Yinal ta ku̇ri koba wunu̇n wal bon mȧttȧra yarakai-willuġ koba ka, ġatun búnnu̇n wal tetti, ġatun purreȧġ ka tarai ka kúmba-ken bouġkullia kȧnu̇n noa.
\p 
\v 8 Ġatun ġaiya bara kotelliela ġikoúmba wiyelli tara,
\p 
\v 9 Ġatun willuġbo bara uwa tulmun tabiruġ, ġatun wiya unni tara barun kin dódeka ta, ġatun barun yantin ta.
\p 
\v 10 Ġala bountoa Mari-ko Magdalakȧlin-to, ġatun bountoa Ioanna-ko, ġatun bountoa Mari-ko tunkan-to Yacóbo-úmba-ko, ġatun taraikan-to bara nukuġ-ko barun katoa, wiya unni tara barun apotholnuġ.
\p 
\v 11 Ġatun bara ba wiyelli tara kakulla barun kin yanti kiloa ġakoyelli tara, ġatun bara keawai ġurraiyelli pa barun.
\p 
\v 12 Peter ġaiya noa ġarokéa, ġatun murra tulmun tako; ġatun woinkulliela barán, nakulla noa kirrikin wuntoara pitaka, ġatun waita noa uwa, kotelliela unni tara kátan ba.
\p 
\v 13 Ġatun yakita purreȧġ ka yantibo, buloara-bula barun kinbiruġ uwa kokerá kolaġ, ġiakai yitirra Emmaou, yakita kaloġ Hierothalem kabiruġ purloġ hekékonta ta.
\p 
\v 14 Ġatun bara wiyellan unni tara kakulla ba.
\p 
\v 15 Ġatun yakita kakulla, wiyelliela ba, ġatun kotelliela bara ba, Iéthu noa niuwoabo uwa papai barun kin, ġatun uwa barun katoa.
\p 
\v 16 Wonto ba ġaikuġ barúnba tullamá, ġimilli korien koa bara bon.
\p 
\v 17 Ġatun noa wiya barun, Minariġ, nura unni tara wiyellan, uwollin nura ba, ġatun minki kátan?
\p 
\v 18 Ġatun wakȧl bulun kinbiruġ, ġiakai noa yitirra Kleopa, wiyayelléu̇n, wiyelliela bon, Ġintoa bo ta wakȧl ġowikan Hierothalemkál, ġatun keawai unni tara ġurrapa kakulla ba unti tara purreȧġ ka?
\p 
\v 19 Ġatun noa wiya barun, Minariġ-ke unni wonnuġ? Gatun bon bara wiyá, Gikouġ kin Iéthu kin Nadharetkȧl unni kakulla propet ta kaiyukan umulliko ġatun wiyelliko mikan ta Eloi koba kin, ġatun yantin ta barun kin ku̇ri ka:
\p 
\v 20 Ġatun yakoai bara ba piriwál hiereu, ġatun ġearúnba piriwál kariġ wúnkulla bon wiyayelliko tetti kolaġ, ġatun bara bon búnkulla tetti.
\p 
\v 21 Wonto ġéen ba kota niuwoa miromulliko Ithȧraelnuġ: ġatun yantin unni tara ba, unni buġgai kúmba-ken-ta kȧtan unnoa tara umatoara biruġ
\p 
\v 22 Kauwa, tarai bara nukuġ ġearúnba konara biruġ kota bunbéa bala ġearun, bara ġoiokéen kȧtan tulmun ta:
\p 
\v 23 Ġatun keawai bara ba na pa ġikoúmba murrin, uwa ġaiya bara, wiyelliela, nakéu̇n bara natoara aġelo kariġ koba wiya moron noa kakulla.
\p 
\v 24 Ġatun taraikan barúnba ġearun kinba uwa tulmun kolaġ, ġatun nakulla yanti bara nukuġko wiya; keawai bon bara na korien.
\p 
\v 25 Wiya ġaiya noa barun, A! woġkȧl nura, ġatun pirriral búbúl ġurrulliko yantin ta wiyatoara bara ba propet to!
\p 
\v 26 Keawai noa Kritht kȧmu̇nġinbia ta umatoara ba unni tara, ġatun uwolliko kirrikin kolaġ ġikouġ ka tako?
\p 
\v 27 Ġatun kurri-kurri Mothe ko noa ba wiya, ġatun yantin to propet kariġ ko, ġurrabunéa ġaiya noa barun unnoa tara upatoara biruġ ġikouġ kai.
\p 
\v 28 Ġatun bara papai uwa unta kolaġ kokerá kolaġ, unta kolaġ bara: ġatun noa puntelliela kaloġ kolaġ.
\p 
\v 29 Wonto bara ba pirralma bon, wiyelliela, Kauwa ġearun katoa; kulla wal yaréa kakillilin, ġatun purreȧġ ta waita uwollilin. Ġatun noa uwa murrariġ kakilliko barun katoa.
\p 
\v 30 Ġatun yakita kakulla, yellawa noa ba barun katoa takilliko, mankulla noa arto, ġatun pitȧlma noa, ġatun yiirbuġga, ġatun ġukulla ġaiya barun.
\p 
\v 31 Ġatun ġaikuġ barúnba buġkulléu̇n, ġatun ġimilléu̇n ġaiya bara bon; noa ġati kakulla barun kinbiruġ.
\p 
\v 32 Ġatun bara wiyellan barabo, Wiya, ġearúnba búlbúl winna ba ġearun kinba ko murruġ kaba ko, wiyelliléu̇n noa ba ġearun katoa, ġatun ġurrabunbéu̇n noa ba ġearun upatoara ta?
\p 
\v 33 Ġatun bouġkulléu̇n tanoa-kȧl-bo ġatun willuġ ba kakulla Hierothalem kolaġ, ġatun nakulla barun hendeka ta, ġatun barun taraikan barun katoa,
\p 
\v 34 Wiyelliela, Bouġkulléu̇n bo ta yuna Piriwȧl ta, ġatun paikulléu̇n Thimon kin.
\p 
\v 35 Ġatun bara wiya unni tara upatoara yapiġ koa, ġatun ġimilléu̇n bara bon yiirbuġgulliela noa ba arto.
\p 
\v 36 Ġatun bara ba wiyelliela, Iéthuko noa niuwoabo ġarokéa willi ka barun kin, ġatun wiya barun noa, Pitȧl nura kauwa.
\p 
\v 37 Wonto bara ba pulul-pulul kakulla ġatun kinta-kan, ġatun kotelliela bara marai ta bara nakulla.
\p 
\v 38 Ġatun noa wiya barun, Minariġ tin nura kinta kȧtan? ġatun minariġ tin nurúnba búlbúllo kotan?
\p 
\v 39 Nauwa tia máttára emmoúmba, ġatun yulo emmoúmba, Gatoa bo: numulla tia, ġatun nauwa; kulla keawai marai koba purriu̇ġ korien ġatun tibun korien, yanti nakulla nura tia ba emmoúmba.
\p 
\v 40 Ġatun wiya noa ba unni, túġumbéa barun noa ġikoúmba mȧttȧra ġatun yulo.
\p 
\v 41 Ġatun keawai bara ba ġurra pitȧl ko, ġatun kotelliko, wiya noa barun, Wiya, nuruúnba kunto unti?
\p 
\v 42 Ġatun bara bon ġukulla pundol koiyubatoara makoro biruġ, ġatun pundol nuparai kabiruġ.
\p 
\v 43 Ġatun noa mankulla, ġatun takulla barun kin mikan ta.
\p 
\v 44 Ġatun noa wiya barun, Unni tara wiyellikanne-ta wiya nurun baġ ba, kakulla baġ ba nurun katoa, yantin koa ka-uwil kakilliko upatoara wiyellikanne-ta Mothé-úmba, ġatun barun ba propet koba, ġatun tehillim kaba, emmouġ kai.
\p 
\v 45 Ġurrabunbéa ġaiya noa barun, ġurra-uwil koa bara upatoara ta;
\p 
\v 46 Ġatun wiya noa barun, Yaki upatoara, ġatun yaki murrȧraġ ta Kritht ko ġikouġ kakilliko tetti ko, ġatun bouġkulliko kúmba-ken-ta purreȧġ ka tetti kabiruġ:
\p 
\v 47 Ġatun wiyabunbi-uwil koa minkikanne-ta ġatun warekullikanne-ta yarakai umullikan ko ġikouġ katoa biruġ yitirra biruġ yantin ta konara, kurri-kurri kabiruġ Hierothalem kabiruġ.
\p 
\v 48 Ġatun nura nakillikan kȧtan ġali tara ko.
\p 
\v 49 Ġatun, ġurrulla, wupin baġ nurun kin wiyatoara emmoúmba koba Biyuġbai koba: wonto nura ba minkéa kokerá Hierothalem ka, kaiyu koa nurun kauwȧl búlwára tin.
\p 
\v 50 Ġatun yutéa noa barun kaloġ kolaġ Bethany ka bo, ġatun noa wupiléu̇n mȧttȧra ġikoúmba wokka-laġ, ġatun pitȧlma noa barun.
\p 
\v 51 Ġatun yakita kakulla, yaki pitȧlmulliela noa ba barun, mantilléu̇n ġaiya bon barun kinbiruġ, ġatun kurréa bon wokka-laġ moroko kako.
\p 
\v 52 Ġatun bara bon murrȧrȧġ koiyelliela, ġatun willuġ ba kakulla Hierothalem kolaġ kauwȧl-kan pitȧl-kan:
\p 
\v 53 Ġatun kakilliela murruġ hieron ka, murrȧrȧġ wiyelliela ġatun pitȧlmulliela bon Eloinuġ.
\p AMEN. 
