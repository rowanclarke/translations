\v 24 \w five|strong="G2453"\w* \w times|strong="G3999"\w* \w from|strong="G3844"\w* \w the|strong="G2983"\w* \w Jews|strong="G2453"\w* \w I|strong="G2453"\w* \w received|strong="G2983"\w* \w the|strong="G2983"\w* ‘\w forty|strong="G5062"\w* lashes minus \w one|strong="G1520"\w*’;\f + \fr 11:24 \ft Deuteronomy 25:3 forbids exceeding forty blows, so the Jews always stopped one short, just in case they had miscounted.\f*
\v 25 \w three|strong="G5151"\w* \w times|strong="G5151"\w* \w I|strong="G1722"\w* \w was|strong="G3588"\w* \w beaten|strong="G4463"\w* \w with|strong="G1722"\w* \w rods|strong="G4463"\w*; once \w I|strong="G1722"\w* \w was|strong="G3588"\w* \w stoned|strong="G3034"\w*; \w three|strong="G5151"\w* \w times|strong="G5151"\w* \w I|strong="G1722"\w* \w was|strong="G3588"\w* \w shipwrecked|strong="G3489"\w* (\w I|strong="G1722"\w* \w spent|strong="G4160"\w* twenty-four hours \w in|strong="G1722"\w* \w the|strong="G1722"\w* open sea)—
\v 26 \w in|strong="G1722"\w* \w frequent|strong="G4178"\w* \w journeys|strong="G3597"\w*, \w in|strong="G1722"\w* \w danger|strong="G2794"\w* \w from|strong="G1537"\w* \w rivers|strong="G4215"\w*, \w in|strong="G1722"\w* \w danger|strong="G2794"\w* \w from|strong="G1537"\w* \w robbers|strong="G3027"\w*, \w in|strong="G1722"\w* \w danger|strong="G2794"\w* \w from|strong="G1537"\w* \w my|strong="G1722"\w* \w countrymen|strong="G1085"\w*, \w in|strong="G1722"\w* \w danger|strong="G2794"\w* \w from|strong="G1537"\w* \w Gentiles|strong="G1484"\w*, \w in|strong="G1722"\w* \w danger|strong="G2794"\w* \w in|strong="G1722"\w* \w cities|strong="G4172"\w*, \w in|strong="G1722"\w* \w danger|strong="G2794"\w* \w in|strong="G1722"\w* wildernesses, \w in|strong="G1722"\w* \w danger|strong="G2794"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w sea|strong="G2281"\w*, \w in|strong="G1722"\w* \w danger|strong="G2794"\w* \w among|strong="G1722"\w* \w false|strong="G5569"\w* brothers;
\v 27 \w in|strong="G1722"\w* \w toil|strong="G2873"\w* \w and|strong="G2532"\w* \w hardship|strong="G3449"\w*, \w in|strong="G1722"\w* \w many|strong="G4178"\w* sleepless nights, \w in|strong="G1722"\w* \w hunger|strong="G3042"\w* \w and|strong="G2532"\w* \w thirst|strong="G1373"\w*, \w in|strong="G1722"\w* \w frequent|strong="G4178"\w* \w fastings|strong="G3521"\w*, \w in|strong="G1722"\w* \w cold|strong="G5592"\w* \w and|strong="G2532"\w* \w nakedness|strong="G1132"\w*\f + \fr 11:27 \ft When the Lord told Ananias to go and restore Saul's sight, and he protested, the Lord continued, “For I will show him how many things he must suffer for my name's sake” (Acts 9:16). Paul paid for what he did against the early Church. By the way, we usually have to pay for our misdeeds down here (how can you pay in Heaven?).\f*—
