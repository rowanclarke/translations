\c 26  
\s1 Organización de los porteros y otros funcionarios  
\p
\v 1 La distribución \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w porteros|strong="H7778"\w* fue así: \w de|strong="H4480"\w* \w los|strong="H1121"\w* coreítas, Meselemías, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Coré|strong="H7145"\w*, \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Asaf.   
\p
\v 2 Meselemías tuvo \w hijos|strong="H1121"\w*: \w Zacarías|strong="H2148"\w* \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w*, \w Jediael|strong="H3043"\w* \w el|strong="H1121"\w* \w segundo|strong="H8145"\w*, \w Zebadías|strong="H2069"\w* \w el|strong="H1121"\w* \w tercero|strong="H7992"\w*, Jatniel \w el|strong="H1121"\w* \w cuarto|strong="H7243"\w*,  
\v 3 \w Elam|strong="H5867"\w* el \w quinto|strong="H2549"\w*, \w Johanán|strong="H3076"\w* el \w sexto|strong="H8345"\w*, Elioenai el \w séptimo|strong="H7637"\w*.   
\p
\v 4 También \w Obed-edom|strong="H5654"\w* tuvo \w hijos|strong="H1121"\w*: \w Semaías|strong="H8098"\w* \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w*, \w Jozabad|strong="H3075"\w* \w el|strong="H1121"\w* \w segundo|strong="H8145"\w*, Joa \w el|strong="H1121"\w* \w tercero|strong="H7992"\w*, Sacar \w el|strong="H1121"\w* \w cuarto|strong="H7243"\w*, Natanael \w el|strong="H1121"\w* \w quinto|strong="H2549"\w*;  
\v 5 Amiel \w el|strong="H3588"\w* \w sexto|strong="H8345"\w*, Isacar \w el|strong="H3588"\w* \w séptimo|strong="H7637"\w* \w y|strong="H3588"\w* Peultai \w el|strong="H3588"\w* \w octavo|strong="H8066"\w*, \w porque|strong="H3588"\w* \nd ʼElohim\nd* lo \w bendijo|strong="H1288"\w*.   
\p
\v 6 También \w a|strong="H3068"\w* \w su|strong="H1992"\w* \w hijo|strong="H1121"\w* \w Semaías|strong="H8098"\w* le \w nacieron|strong="H3205"\w* \w hijos|strong="H1121"\w* \w que|strong="H3588"\w* fueron jefes \w en|strong="H3588"\w* \w sus|strong="H1992"\w* \w casas|strong="H1004"\w* paternas, \w porque|strong="H3588"\w* eran \w varones|strong="H3588"\w* \w valientes|strong="H1368"\w* \w y|strong="H3588"\w* \w esforzados|strong="H1368"\w*.  
\v 7 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Semaías|strong="H8098"\w*: Otni, Rafael, \w Obed|strong="H5744"\w*, Elzabad, y sus hermanos, \w hombres|strong="H1121"\w* \w esforzados|strong="H2428"\w*; también Eliú y Samaquías.  
\v 8 \w Todos|strong="H3605"\w* \w éstos|strong="H1992"\w* fueron \w de|strong="H1121"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Obed-edom|strong="H5654"\w*, \w ellos|strong="H1992"\w* con \w sus|strong="H1992"\w* \w hijos|strong="H1121"\w* y \w sus|strong="H1992"\w* hermanos, \w hombres|strong="H1121"\w* \w robustos|strong="H2428"\w* y \w fuertes|strong="H2428"\w* para \w el|strong="H3605"\w* servicio: 62, \w de|strong="H1121"\w* \w Obed-edom|strong="H5654"\w*.   
\p
\v 9 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Meselemías y sus hermanos: 18 \w hombres|strong="H1121"\w* \w valientes|strong="H2428"\w*.   
\p
\v 10 También Hosa, uno \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Merari|strong="H4847"\w*, \w tuvo|strong="H1961"\w* \w hijos|strong="H1121"\w*: \w Simri|strong="H8113"\w* \w el|strong="H3588"\w* \w jefe|strong="H7218"\w*. \w Aunque|strong="H3588"\w* \w no|strong="H3808"\w* \w era|strong="H1961"\w* \w el|strong="H3588"\w* \w primogénito|strong="H1060"\w*, \w su|strong="H3588"\w* padre \w lo|strong="H3808"\w* colocó \w de|strong="H4480"\w* \w jefe|strong="H7218"\w*,  
\v 11 \w Hilcías|strong="H2518"\w* \w el|strong="H3605"\w* \w segundo|strong="H8145"\w*, Tebalías \w el|strong="H3605"\w* \w tercero|strong="H7992"\w*, \w Zacarías|strong="H2148"\w* \w el|strong="H3605"\w* \w cuarto|strong="H7243"\w*. \w Todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Hosa y sus hermanos fueron 13.   
\p
\v 12 Entre éstos se hizo la distribución de los \w porteros|strong="H7778"\w*, y se alternaban los \w principales|strong="H7218"\w* de los \w varones|strong="H1397"\w* en la guardia con sus hermanos, para ministrar en la \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 13 \w Echaron|strong="H5307"\w* \w suertes|strong="H1486"\w* para cada \w puerta|strong="H8179"\w*: \w el|strong="H5307"\w* \w pequeño|strong="H6996"\w* con \w el|strong="H5307"\w* \w grande|strong="H1419"\w*, según sus \w casas|strong="H1004"\w* paternas.   
\p
\v 14 La \w suerte|strong="H1486"\w* para la \w oriental|strong="H4217"\w* \w cayó|strong="H5307"\w* \w a|strong="H3068"\w* Selemías. \w Metieron|strong="H5307"\w* \w en|strong="H3318"\w* las \w suertes|strong="H1486"\w* \w a|strong="H3068"\w* \w Zacarías|strong="H2148"\w* su \w hijo|strong="H1121"\w*, \w consejero|strong="H3289"\w* \w entendido|strong="H7922"\w*. La \w suerte|strong="H1486"\w* \w suya|strong="H1486"\w* \w salió|strong="H3318"\w* para la del \w norte|strong="H6828"\w*.  
\v 15 Para \w Obed-edom|strong="H5654"\w* la puerta del sur, y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* provisiones del \w Templo|strong="H1004"\w*.  
\v 16 \w Para|strong="H5973"\w* Supim y Hosa, la \w del|strong="H5973"\w* \w occidente|strong="H4628"\w*, \w junto|strong="H5973"\w* \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w* \w de|strong="H5973"\w* Salequet, \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w camino|strong="H4546"\w* \w de|strong="H5973"\w* la subida.  
\p Guardia \w con|strong="H5973"\w* guardia se correspondían.  
\v 17 Al \w oriente|strong="H4217"\w* \w seis|strong="H8337"\w* \w levitas|strong="H3881"\w*, al \w norte|strong="H6828"\w* cuatro de \w día|strong="H3117"\w*, al sur cuatro de \w día|strong="H3117"\w*, y en los almacenes de \w dos|strong="H8147"\w* en \w dos|strong="H8147"\w*.  
\v 18 En el patio, al \w occidente|strong="H4628"\w*, cuatro en el \w camino|strong="H4546"\w*, y \w dos|strong="H8147"\w* en el mismo patio.   
\p
\v 19 Tales fueron las distribuciones \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w porteros|strong="H7778"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Coré|strong="H7145"\w* y \w de|strong="H1121"\w* \w Merari|strong="H4847"\w*.   
\s1 Funcionarios de los levitas  
\p
\v 20 \w De|strong="H5921"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w*, Ahías \w estaba|strong="H1004"\w* encargado \w de|strong="H5921"\w* \w los|strong="H5921"\w* tesoros \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* tesoros \w de|strong="H5921"\w* \w las|strong="H5921"\w* cosas consagradas.   
\p
