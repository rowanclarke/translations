\v 7  Nineveh \w is|strong="H8179"\w* taken \w into|strong="H5104"\w* exile \w and|strong="H8179"\w* \w is|strong="H8179"\w* led \w away|strong="H4127"\w*;  
\q1 \w her|strong="H6605"\w* slave girls moan like doves while \w they|strong="H8179"\w* beat their breasts.   
\q1
\v 8  \w Nineveh|strong="H5324"\w* \w was|strong="H3824"\w* \w like|strong="H5927"\w* \w a|strong="H3068"\w* pool \w of|strong="H6963"\w* water \w throughout|strong="H5921"\w* \w her|strong="H1540"\w* days,  
