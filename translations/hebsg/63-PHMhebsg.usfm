\id PHM
\h פילימון
\toc1 אִגֶּרֶת פּוֹלוֹס אֶל־פִּילֵימוֹן
\toc2 אִגֶּרֶת פּוֹלוֹס אֶל־פִּילֵימוֹן
\toc3 פילימון
\mt1 אִגֶּרֶת פּוֹלוֹס אֶל־פִּילֵימוֹן
\c 1
\cp א
\cl פרק א
\p 
\v 1 \vp א\vp* פּוֹלוֹס אֲסִיר יֵשׁוּעַ הַמָּשִׁיחַ וְטִימוֹתִיּוֹס אָחִי אֶל־פִּילֵימוֹן אֹהֵב לָנוּ וְתֹמֵךְ בְּיָדֵינוּ׃
\v 2 \vp ב\vp* וְאֶל־אַפִּיָּה אֲחֹתִי וְאֶל־אַרְכִפּוֹס גֶּבֶר עֲמִיתִי בְּמִלְחֲמֹתֵינוּ וְאֶל־הַקָּהָל אֲשֶׁר בְּבֵיתֶךָ׃
\v 3 \vp ג\vp* חֶסֶד לָכֶם וְשָׁלוֹם מֵאֵת אֱלֹהִים אָבִינוּ וּמֵאֵת יֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ׃
\v 4 \vp ד\vp* אֲבָרְכָה אֶת־אֱלֹהָי וְאַזְכִּירְךָ תָמִיד בִּתְפִלָּתִי׃
\v 5 \vp ה\vp* לִשְׁמֻעַת הָאַהֲבָה וְהָאֱמוּנָה אֲשֶׁר תִּנְצֹר בְּנַפְשְׁךָ אֶל־יֵשׁוּעַ אֲדֹנֵינוּ וְאֶל־כָּל־קְדשָׁיו׃
\v 6 \vp ו\vp* וּתְפִלָּתִי כִּי אֱמוּנָתְךָ תּוֹסִיף אֹמֶץ בַּאֲגֻדָּתָהּ עַל־יְדֵי הַדַּעַת מַה־טּוֹב בָּכֶם לִפְנֵי הַמָּשִׁיחַ יֵשׁוּעַ׃
\v 7 \vp ז\vp* כִּי אַהֲבָתְךָ הָיְתָה לִּי לְשָׂשׂוֹן רָב וְתַנְחוּמִים אַחֲרֵי אֲשֵׁר אַתָּה אָחִי הָיִיתָ לְמֵשִׁיב נֶפֶשׁ בְּקֶרֶב הַקְּדוֹשִׁים׃
\v 8 \vp ח\vp* וְעַתָּה אַף כִּי רָחַב לִבִּי בַּמָּשִׁיחַ לְצַוֹּת עָלֶיךָ אֶת־הַטּוֹב לָךְ׃
\v 9 \vp ט\vp* בְּכָל־זֹאת לְמַעַן אַהֲבָתֵנוּ אֲנִי פּוֹלוֹס הַזָּקֵן וַאֲסִיר יֵשׁוּעַ הַמָּשִׁיחַ כַּיּוֹם הִנְנִי לְהַפְגִּיעַ בָּךְ׃
\v 10 \vp י\vp* כִּי אַפְגִּיעַ בְּעַד בְּנִי אֲשֶׁר בְּבֵית הָאֲסוּרִים הוֹלַדְתִּיהוּ הֲלֹא הוּא אֳנִסִימוֹס בְּנִי׃
\v 11 \vp יא\vp* אֲשֶׁר לֹא לְיִתְרוֹן הָיָה לְךָ מִלְּפָנִים אֲבָל מֵעַתָּה גַּם־לְךָ גַּם־לִי הוּא לְיִתְרוֹן גָּדוֹל׃
\v 12 \vp יב\vp* וַאֲנִי הִנְנִי מְשִׁיבוֹ אֵלֶיךָ כַּיּוֹם שָׂא נָא אֶת־פָּנָיו כִּי כְּבֶן־מֵחֲלָצַי הוּא׃
\v 13 \vp יג\vp* אַף כִּי חִמַּדְתִּי לְהַחֲזֵק־בּוֹ כִּי יַעֲמֹד לְשָׁרְתֵנִי תַּחְתֶּיךָ בְּעוֹד אֲנִי אָסוּר בְּכַבְלֵי הַבְּשׂרָה׃
\v 14 \vp יד\vp* אֲבָל לֹא חָפַצְתִּי לַעֲשׂוֹת דָּבָר בִּבְלִי דַעְתֶּךָ לְמַעַן יִהְיֶה גְמוּל טוּבְךָ לֹא כְמוֹ בְאֹנֶס כִּי אִם־בִּנְדָבָה׃
\v 15 \vp טו\vp* וְאוּלַי בַּעֲבוּר זֹאת נִפְרַד מִמְּךָ לִזְמָן קָצוּב לְמַעַן יִהְיֶה לְפָנֶיךָ לְעוֹלָם וָעֶד׃
\v 16 \vp טז\vp* וְלֹא עוֹד כְּעֶבֶד כִּי אִם־רַב מֵעֶבֶד כְּאָח יַקִּיר כִּי יַקִּיר הוּא לִי עַד־מְאֹד וּמַה־גַּם כִּי כֵן יְהִי לְךָ גַּם־נֶגֶד פְּנֵי אֲנָשִׁים וְגַם נֶגֶד פְּנֵי אֲדֹנֵינו׃
\v 17 \vp יז\vp* וְעַל־כֵּן אִם לְחָבֵר לְךָ תַּחְשְׁבֵנִי קַבֶּל־נָא פָּנָיו כְּפָנָי׃
\v 18 \vp יח\vp* וְאִם עָשַׁק אֹתְךָ אוֹ אֲשָׁמוֹ בְרֹאשׁוֹ מִיָּדִי תִדְרְשֶׁנּוּ׃
\v 19 \vp יט\vp* אֲנִי פוֹלוֹס כָּתַבְתִּי זֶה בְּיָדִי אֲנִי אֲשַׁלֵּם וְלֹא אֹמַר אֵלֶיךָ כִּי חוֹב עָלֶיךָ לְשַׁלֶּם־לִי גַּם־בְּעַד נַפְשֶׁךָ׃
\v 20 \vp כ\vp* אָנָּא אָחִי אֶמְצָא בְּךָ רְוָחָה זוּ בַּאֲדֹנֵינוּ הָשִׁיבָה־נָּא לִבִּי וְכִלְיוֹתַי בַּמָּשִׁיחַ׃
\v 21 \vp כא\vp* בְּךָ בָטַחְתִּי כִּי תַעֲנֶה וָאֶכְתֹּב אֵלֶיךָ וְגַם יָדַעְתִּי כִּי־תוֹסִף לַעֲשׂוֹת מֵאֲשֶׁר אָמָרְתִּי׃
\v 22 \vp כב\vp* נוֹסָף עַל־זֶה תָּכֶן־לִי בֵּית מָלוֹן כִּי הִנְנִי מְיַחֵל לְהִנָּתֵן לָכֶם כְּפִי תְפִלַּתְכֶם׃
\v 23 \vp כג\vp* אֵלֶּה שֹׁאֲלִים לִשְׁלוֹמֶךָ אֶפַּפְרָס אֲשֶׁר הוּא עָצוּר אִתִּי בְּיֵשׁוּעַ הַמָּשִׁיחַ׃
\v 24 \vp כד\vp* וּמַרְקוֹס וַאֲרִסְטַרְכוֹס וְדִימָס וְלוּקָס הַתֹּמְכִים בְּיָדִי׃
\v 25 \vp כה\vp* חֶסֶד יֵשׁוּעַ הַמָשִׁיחַ אֲדֹנֵינוּ עִם־רוּחֲכֶם אָמֵן׃ 
