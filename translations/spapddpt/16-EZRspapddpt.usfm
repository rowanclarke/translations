\v 20 y \w de|strong="H4480"\w* \w los|strong="H3605"\w* servidores, \w a|strong="H3068"\w* quienes \w David|strong="H1732"\w* y \w los|strong="H3605"\w* \w jefes|strong="H8269"\w* destinaron \w para|strong="H4480"\w* \w el|strong="H3605"\w* servicio \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w levitas|strong="H3881"\w*, \w fueron|strong="H1732"\w* 220 servidores \w del|strong="H4480"\w* Templo, \w todos|strong="H3605"\w* designados \w por|strong="H4480"\w* \w nombres|strong="H8034"\w*.   
\p
\v 21 \w Y|strong="H3068"\w* \w allí|strong="H8033"\w*, \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w río|strong="H5104"\w* \w de|strong="H4480"\w* Ahava, proclamé un \w ayuno|strong="H6685"\w* \w para|strong="H5921"\w* humillarnos \w delante|strong="H6440"\w* \w de|strong="H4480"\w* nuestro \nd ʼElohim\nd*, \w a|strong="H3068"\w* fin \w de|strong="H4480"\w* suplicar \w de|strong="H4480"\w* \w Él|strong="H5921"\w* un buen \w viaje|strong="H1870"\w* \w para|strong="H5921"\w* \w nosotros|strong="H3605"\w*, nuestros pequeños \w y|strong="H5921"\w* también \w toda|strong="H3605"\w* nuestra \w hacienda|strong="H7399"\w*.  
\v 22 Tuve vergüenza \w de|strong="H4480"\w* pedir infantería \w y|strong="H3588"\w* caballería \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w nos|strong="H5921"\w* protegiera \w del|strong="H4480"\w* enemigo \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w*. \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w* hablamos \w al|strong="H5921"\w* \w rey|strong="H4428"\w*: \w La|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H4480"\w* nuestro \nd ʼElohim\nd* \w está|strong="H5921"\w* \w a|strong="H3068"\w* favor \w de|strong="H4480"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* \w lo|strong="H5921"\w* \w buscan|strong="H1245"\w*, \w pero|strong="H3588"\w* \w su|strong="H3588"\w* \w poder|strong="H3027"\w* \w y|strong="H3588"\w* \w su|strong="H3588"\w* ira están \w contra|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* \w lo|strong="H5921"\w* \w abandonan|strong="H5800"\w*.  
