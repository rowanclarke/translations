\v 27 \w A|strong="H3068"\w* sus \w dos|strong="H8147"\w* \w lados|strong="H6654"\w* \w hizo|strong="H6213"\w* \w dos|strong="H8147"\w* argollas \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w debajo|strong="H8478"\w* \w de|strong="H5921"\w* su moldura \w en|strong="H5921"\w* sus \w dos|strong="H8147"\w* \w esquinas|strong="H6763"\w* \w por|strong="H5921"\w* \w ambos|strong="H8147"\w* \w lados|strong="H6654"\w*, \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* introducir \w por|strong="H5921"\w* \w ellas|strong="H5921"\w* \w las|strong="H5921"\w* varas \w para|strong="H5921"\w* transportarlo.  
