\v 8 \w No|strong="G3756"\w* \add lo\add* \w digo|strong="G3004"\w* \w como|strong="G2532"\w* \w un|strong="G3588"\w* \w mandamiento|strong="G2003"\w*, sino \w también|strong="G2532"\w* \w para|strong="G1223"\w* someter \w a|strong="G2596"\w* prueba \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1223"\w* \w la|strong="G3588"\w* \w diligencia|strong="G4710"\w* \w de|strong="G1223"\w* \w otros|strong="G2087"\w*, \w la|strong="G3588"\w* autenticidad \w del|strong="G3588"\w* amor \w de|strong="G1223"\w* ustedes.  
\v 9 \w Porque|strong="G1063"\w* \w conocen|strong="G1097"\w* \w la|strong="G3588"\w* \w gracia|strong="G5485"\w* \w de|strong="G1223"\w* \w nuestro|strong="G2249"\w* \w Señor|strong="G2962"\w* \w Jesucristo|strong="G2424"\w*, \w Quien|strong="G3588"\w* \w era|strong="G1510"\w* \w rico|strong="G4145"\w* \w y|strong="G1063"\w* empobreció \w por|strong="G1223"\w* amor \w a|strong="G2443"\w* ustedes \w para|strong="G2443"\w* \w que|strong="G3754"\w* ustedes, \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1223"\w* \w su|strong="G3588"\w* \w pobreza|strong="G4432"\w*, fueran \w ricos|strong="G4145"\w*.   
