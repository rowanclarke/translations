\id AMO  
\h عَننَبِ عَمٌسِ 
\toc1 عَلَ شَ مَسٍنيِ عَننَبِ عَمٌسِ بّ 
\toc2 عَننَبِ عَمٌسِ 
\toc3 عَمٌ 
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ عَمٌسِ بّ 
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ 
\ip عَننَبِ عَمٌسِ نَمِحْنمّ نَن نُ عَ رَ نَشَن كَوَندِ تِ يُدَيَ مَنفّ يُسِيَ شَ وَشَتِ. نَ تّمُي عِسِرَيِلَ بْشِ، عَلَ نَشَن قِشِ عَ شَ حَمَ مَ كَبِ عَننَبِ مُنسَ شَ تّمُي، عَ نُ بَرَ تَشُن دْشْ قِرِن. عَ يِرٍقَنيِ سّيتِ شِلِ يُدَيَ، عَ كْولَ سّيتِ شِلِ عِسِرَيِلَ. مَنفّ يٍرٌبٌوَ مِ نُ نَ عِسِرَيِلَ بْشِ مَ. عَ مُ تِن بِرَدٍ عَلَ شَ سّرِيّ قْشْ رَ، عَ شَ حَمَ قَن مُ لُ كِرَ قَنيِ شْن مَ. 
\ip عَننَبِ عَمٌسِ نَشَ كَوَندِ تِ عِسِرَيِلَكَيٍ بّ، عَلَكٌ عٍ شَ فبِلٍن عٍ شَ يُنُبِيٍ قْشْ رَ. عَ نَشَ تْنيِ دْشْ كُيٍيٍ بَتُقٍ رَ. عٍ مُ عَلَتَلَ بَتُقٍ رَبّحِن، كْنْ عٍ نُ بَرَ كُيٍ بَتُي قَن سَ نَ قَرِ. نَ نَن عَ رَ عَلَ نَشَ عَ مَسٍن عٍ بّ عَننَبِ عَمٌسِ سَابُي رَ، عَ عٍ شَ سَلِ بِرِن بَرَ قِندِ سَلِ قُقَقُ رَ. عَلَ مُ وَ مَ عَ قِرِن ندٍ شْن مَ. 
\ip نَ وَشَتِ عِسِرَيِلَكَ وُيَشِيٍ نُ بَرَ نَاقُلِ فبٍفبٍ سْتْ. عٍ نَشَ عَ مَحْشُن عَ نَ بِرِن قِندِشِ عَلَ شَ بَرَكّ نَن نَ عٍ تَن مَبِرِ. عَننَبِ عَمٌسِ نَشَ عَ مَسٍن عٍ بّ عَ نَ نَاقُلِ مُ نُ كٍلِشِ عَلَ شَ مَ، عَ كٍلِشِ عٍ شَ قٍ كٌبِيٍ نَن مَ عٍ نَشٍيٍ رَبَشِ سٍتَرٍيٍ رَ. 
\ip عَننَبِ عَمٌسِ تٌ فّ عٍ كَلَمُدٍ نَ قٍ مَ، عَ نَشَ عَ قَلَ عٍ بّ عَ عَلَتَلَ قَمَ نّ عٍ حَشَنكَتَدٍ عَ حَاشِ رَ عٍ شَ يُنُبِيٍ شَ قٍ رَ. عِسِرَيِلَكَيٍ نُ عَ مَحْشُنشِ نّ عَ قٍ شْرْشْي يٌ مُ نْمَ عٍ لِدٍ، كْنْ عَمٌسِ نَشَ عٍ مَيَندِ عٍ شَ فبِلٍن عَلَ شَ سّرِيّ مَ، شَ نَ مُ عَ رَ عٍ بِرِن قَمَ نّ هَلَكِدٍ. 
\ip عَلَتَلَ نَشَ عِسِرَيِلَكَيٍ حَشَنكَتَ عَلْ عَننَبِ عَمٌسِ عَ قَلَ عٍ بّ كِ نَشّ. عٍ يَشُييٍ نَشَ عٍ فٍرٍ عَ حَاشِ رَ. عِسِرَيِلَكَ نَشٍيٍ مُ قَشَ سَنتِدّفّمَ رَ، عٍ نَشَ لُ كٌنيِيَ كُي حَمَنّ مَ. عَلَتَلَ شَ مَسٍنيِ بِرِن نَشَ كَمَلِ. 
\ip يِ كِتَابُي شَ مَسٍنيِ تِدٍ فبٌ تٌ مِشِيٍ بّ. عَ لَنمَ وٌن شَ وٌن تُلِ مَتِ يِ كَوَندِ رَ عَلَكٌ وٌن شَ دَنشَنِيَ عَلَ مَ عَلْ عَ وَ مَ عَ شْن مَ كِ نَشّ. شَ نَ مُ عَ رَ وٌن قَن قَمَ نّ حَشَنكَتّ سْتْدٍ عَلْ عِسِرَيِلَكَيٍ. عَلَ شَ وٌن نَتَنفَ نَ مَ. عَمِنَ. 
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ عَمٌسِ بّ 
\c 1  
\s1 عَننَبِ عَمٌسِ شَ مَسٍنيِ 
\p  
\v 1 عَننَبِ عَمٌسِ، تٍكٌوَكَ شُرُ سٍ كَنيِ، نَشَ لَامَتُنيِ تٌ عِسِرَيِلَ شَ قٍ رَ يُدَيَ مَنفّ يُسِيَ نُن عِسِرَيِلَ مَنفّ يٍرٌبٌوَ مِ، يٌوَ سِ شَ دِ شَ وَشَتِ، حّ قِرِن بٍينُن بْشِ شَ سّرّن. 
\q1 عَننَبِ عَمٌسِ شَ مَسٍنيِ نَن يَ؛ 
\q1  
\v 2 «عَلَتَلَ عَ شَاحّ شُي رَ مِنِمَ سِيٌنِ مَ عَلْ يّتّ، 
\q1 عَ عَ شُي عِتٍشِ رَ مِنِمَ كٍلِ دَرِ سَلَمُ. 
\q1 سّشّ مُ نَ قِيلِيٍ مَ شُرُ سٍيٍ نَشَن دٌنمَ، 
\q1 كَرٍ مٍلٍ فٍيَ قَن بَرَ شَرَ.» 
\s1 دَ مَسِ شَ يُنُبِ سَرٍ 
\q1  
\v 3 عَلَتَلَ نَشَ عَ مَسٍن، 
\q1 «دَ مَسِ شَ يُنُبِ رَبَشِ سَشَنيِ، 
\q1 شَ نَ مُ عَ رَ نَانِ شَ قٍ رَ، 
\q1 ﭑ مُ فبِلٍنمَ ﭑ مَ نَتّ قْشْ رَ. 
\q1 عٍ بَرَ فَلَدِ كَنَ عَ حَاشِ رَ، 
\q1 عَلْ بْشِ بُشَمَ كِ نَشّ. 
\q1  
\v 4 ﭑ تّ دِنمَ شَسَيٍلِ شَ بَنشِ رَ نَ نَن مَ. 
\q1 نَ تّ نَن قَمَ بٍن هَدَدَ شَ يِرٍ مَكَنتَشِيٍ فَندٍ. 
\q1  
\v 5 ﭑ دَ مَسِ شَ نَادّ بَلَن سٍ فِرَ مَ نّ. 
\q1 ﭑ عَوٍنِكَيٍ هَلَكِمَ نّ فُلُنبَ كُي، 
\q1 عَ نُن مَنفّ نَشَن نَ بٍتِ عٍدٍن. 
\q1 سِرِيَ حَمَ شَنِنمَ نّ كِرِيَ كٌنيِيَ كُي.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\s1 فَسَ شَ يُنُبِ سَرٍ 
\q1  
\v 6 عَلَتَلَ نَشَ عَ مَسٍن، 
\q1 «فَسَ شَ يُنُبِ رَبَشِ سَشَنيِ، 
\q1 شَ نَ مُ عَ رَ نَانِ شَ قٍ رَ، 
\q1 ﭑ مُ فبِلٍنمَ ﭑ مَ نَتّ قْشْ رَ. 
\q1 عٍ بَرَ تَا ندٍيٍ شَ حَمَ بِرِن شَنِن عٍدٌن كٌنيِيَ كُي. 
\q1  
\v 7 ﭑ تّ دِنمَ فَسَ تّتّ رَ نَ نَن مَ. 
\q1 نَ قَمَ نّ عَ يِرٍ مَكَنتَشِيٍ فَندٍ. 
\q1  
\v 8 ﭑ عَسِدٌدِكَيٍ هَلَكِمَ نّ، 
\q1 عَ نُن مَنفّ نَشَن نَ عَسِكَلْن. 
\q1 ﭑ عٍكِرٌن حَشَنكَتَمَ نّ، 
\q1 قِلِسِتَكَيٍ بِرِن قَشَمَ نّ.» 
\q1 مَرِفِ عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\s1 تِرٍ شَ يُنُبِ سَرٍ 
\q1  
\v 9 عَلَتَلَ نَشَ عَ مَسٍن، 
\q1 «تِرٍ شَ يُنُبِ رَبَشِ سَشَنيِ، 
\q1 شَ نَ مُ عَ رَ نَانِ شَ قٍ رَ، 
\q1 ﭑ مُ فبِلٍنمَ ﭑ مَ نَتّ قْشْ رَ. 
\q1 عٍ بَرَ تَا ندٍيٍ شَ حَمَ بِرِن شَنِن عٍدٌن كٌنيِيَ كُي، 
\q1 عٍ سَاتّ كَنَ عٍ نَشَن تٌنفٌ عٍ نُن عٍ نفَشَكٍرٍنيِ عِسِرَيِلَكَيٍ تَفِ. 
\q1  
\v 10 ﭑ تّ دِنمَ تِرٍ تّتّ رَ نَ نَن مَ. 
\q1 نَ تّ قَمَ نّ عَ يِرٍ مَكَنتَشِيٍ فَندٍ.» 
\s1 عٍدٌن شَ يُنُبِ سَرٍ 
\q1  
\v 11 عَلَتَلَ نَشَ عَ مَسٍن، 
\q1 «عٍدٌن شَ يُنُبِ رَبَشِ سَشَنيِ، 
\q1 شَ نَ مُ عَ رَ نَانِ شَ قٍ رَ، 
\q1 ﭑ مُ فبِلٍنمَ ﭑ مَ نَتّ قْشْ رَ. 
\q1 عٍ بَرَ عٍ نفَشَكٍرٍنيِيٍ فٍرٍ سَنتِدّفّمَ رَ. 
\q1 عٍ مُ كِنِكِنِ عٍ مَ، 
\q1 عٍ شَ شْنّ شُن نَن تُن مَسَمَ. 
\q1  
\v 12 ﭑ تّ دِنمَ نّ تٍمَن نَ. 
\q1 نَ تّ نَن قَمَ بٌسَرَ يِرٍ مَكَنتَشِيٍ فَندٍ.» 
\s1 عَمٌنِ شَ يُنُبِ سَرٍ 
\q1  
\v 13 عَلَتَلَ نَشَ عَ مَسٍن، 
\q1 «عَمٌنِكَيٍ شَ يُنُبِ رَبَشِ سَشَنيِ، 
\q1 شَ نَ مُ عَ رَ نَانِ شَ قٍ رَ، 
\q1 ﭑ مُ فبِلٍنمَ ﭑ مَ نَتّ قْشْ رَ. 
\q1 عٍ بَرَ فَلَدِ فِنّ قُرُشِيٍ قُرِيٍ رَبْو سَنتِدّفّمَ رَ، 
\q1 عَلَكٌ عٍ شَ بْشِ شُن شَ مَسَ. 
\q1  
\v 14 ﭑ تّ رَدّشّمَ رَابَ تّتّ رَ نَ نَن مَ. 
\q1 نَ تّ نَن قَمَ عَ يِرٍ مَكَنتَشِيٍ فَندٍ. 
\q1  
\v 15 عٍ شَ مَنفّ نُن عَ شَ كُنتِفِيٍ قَمَ نّ شَنِندٍ كٌنيِيَ كُي، 
\q1 فٍرٍ سْنشْي رَتٍ فٍرٍ سٌ لْشْي، 
\q1 تُرُننَادّ قٌيٍ مِنِ شُي لْشْي.» 
\q1 عَلَ شَ مَسٍنيِ نَن نَ كِ. 
\c 2  
\s1 مٌوَبَ شَ يُنُبِ سَرٍ 
\q1  
\v 1 عَلَتَلَ نَشَ عَ مَسٍن، 
\q1 «مٌوَبَ شَ يُنُبِ رَبَشِ سَشَنيِ، 
\q1 شَ نَ مُ عَ رَ نَانِ شَ قٍ رَ، 
\q1 ﭑ مُ فبِلٍنمَ ﭑ مَ نَتّ قْشْ رَ. 
\q1 عٍ بَرَ عٍدٌن مَنفّ شْرِيٍ فَن هَن عٍ بَرَ قِندِ شُبٍ رَ. 
\q1  
\v 2 ﭑ تّ دِنمَ مٌوَبَ رَ نَ نَن مَ. 
\q1 نَ تّ قَمَ نّ كٍرِيٌتِ يِرٍ مَكَنتَشِيٍ فَندٍ. 
\q1 مٌوَبَ شَ قٍ حْنمَ فٍرٍ سْنشْي نَن كُي، 
\q1 فٍرٍ قٍرِ قٍ شُي كُي. 
\q1  
\v 3 ﭑ عٍ شَ كِيتِسَ شُنفبٍ هَلَكِمَ نّ 
\q1 نُن عَ شَ كُنتِفِيٍ رَ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\s1 يُدَيَ شَ يُنُبِ سَرٍ 
\q1  
\v 4 عَلَتَلَ نَشَ عَ مَسٍن، 
\q1 «يُدَيَ شَ يُنُبِ رَبَشِ سَشَنيِ، 
\q1 شَ نَ مُ عَ رَ نَانِ شَ قٍ رَ، 
\q1 ﭑ مُ فبِلٍنمَ ﭑ مَ نَتّ قْشْ رَ. 
\q1 عٍ بَرَ ﭑ مَ سّرِيّ مَتَندِ، 
\q1 عٍ مُ ﭑ مَ يَامَرِيٍ سُشُ، 
\q1 بَرِ مَ عٍ بَرَ عٍ يّتّ رَلْي لَقٍ رَ عَلَ وُلٍ دَاشِيٍ رَ، 
\q1 عٍ بَبَيٍ لَ نَشٍيٍ رَ. 
\q1  
\v 5 ﭑ تّ دِنمَ يُدَيَ رَ نَ نَن مَ. 
\q1 نَ تّ نَن قَمَ دَرِ سَلَمُ يِرٍ مَكَنتَشِيٍ فَندٍ.» 
\s1 عِسِرَيِلَ شَ يُنُبِ سَرٍ 
\q1  
\v 6 عَلَتَلَ نَشَ عَ مَسٍن، 
\q1 «عِسِرَيِلَ شَ يُنُبِ رَبَشِ سَشَنيِ، 
\q1 شَ نَ مُ عَ رَ نَانِ شَ قٍ رَ، 
\q1 ﭑ مُ فبِلٍنمَ ﭑ مَ نَتّ قْشْ رَ. 
\q1 عٍ تِنشِنتْي مَتِمَ كْبِرِ رَ، 
\q1 عٍ مِسِكِينّ مَتِمَ سَنكِرِ سَرٍ شَ قٍ رَ. 
\q1  
\v 7 عٍ تْورْ مِشِيٍ شَ قٍ مَيٌ، 
\q1 عٍ تٌندِ سٍتَرٍ شَ كِيتِ سَدٍ. 
\q1 بَبّ نُن عَ شَ دِ، فِنّدِ مّدِ كٍرٍن مَسَمَ. 
\q1 نَ كُي عٍ بَرَ ﭑ شِلِ سّنِيّنشِ رَ سْتْ. 
\q1  
\v 8 عٍ دُفِ عِتَلَمَ عٍ نَشَن نَسُشُشِ سّيكّ رَ، 
\q1 عٍ عٍ سَ نَ مَ سّرّشّبَدٍ قّ مَ. 
\q1 عٍ وّنِ سْتْمَ تِنشِنتَرٍيَ رَ، 
\q1 عٍ نَ مِن عٍ شَ عَلَيٍ شَ بَنشِيٍ كُي.» 
\b  
\q1  
\v 9 «عٍ نَ قِنسِرِوَلِيَ بِرِن نَبَمَ ﭑ يَ عِ، 
\q1 ﭑ تَن نَشَن عَمٌرِكَيٍ هَلَكِ عٍ بّ، 
\q1 عَمٌرِكَيٍ نَشٍيٍ شُنفبٌ عٍ سّنبّ فبٌ عَلْ كٌندٍ بِلِ. 
\q1 ﭑ نَشَ عَمٌرِكَيٍ قْشِ بِرِن بَ نَا، 
\q1 عَلَكٌ عٍ نَشَ نْ سّنبّ سْتْدٍ سْنْن. 
\q1  
\v 10 ﭑ مَن نَشَ وٌ رَ مِنِ مِسِرَ بْشِ رَ، 
\q1 ﭑ قَ وٌ رَحّرّ حّ تٌنفٌ نَانِ بُن مَ فبٍنفبٍرٍنيِ مَ، 
\q1 عَلَكٌ وٌ شَ عَمٌرِ بْشِ سْتْ. 
\q1  
\v 11 ﭑ نَشَ نَمِحْنمّيٍ رَكٍلِ وٌ يَ مَ، 
\q1 عَ نُن نَسَرِ سّفّتَلَيٍ نَشٍيٍ بَرَ قِ ﭑ مَ. 
\q1 عِسِرَيِلَكَيٍ، عَ مُ نَ نَ كِ شّ؟» 
\q1 عَلَتَلَ شَ وْيّنيِ نَن نَ كِ. 
\q1  
\v 12 «كْنْ وٌ تَن بَرَ بٍيرٍ سٌ نَسَرِ مِشِيٍ يِ رَ. 
\q1 وٌ بَرَ تْنيِ دْشْ نَمِحْنمّيٍ رَ 
\q1 عَ عٍ نَشَ عَلَ شَ مَسٍنيِ مَسٍن.» 
\b  
\q1  
\v 13 «ﭑ قَمَ وٌ بُتُشُندٍ نَ نَن مَ، 
\q1 عَلْ كٌتٍ بِنيٍ عَ مَشَنِن سٍ بُتُشُنمَ كِ نَشّ. 
\q1  
\v 14 مِشِ شُلُنشِ مُ نْمَ عَ فِدٍ. 
\q1 سّنبّمَ سّنبّ بَمَ نّ عَ يِ رَ. 
\q1 فٍرٍ سٌي قَشَمَ نّ فٍرٍ كُي. 
\q1  
\v 15 تَنبّ وٌلِ مُ تِمَ. 
\q1 نَشَن شُلُن عَ فِدٍ نَ سَنيِ مُ عَ بَمَ عٍ عِ. 
\q1 سٌي رَفِ مُ كِسِمَ. 
\q1  
\v 16 نَ لْشْي فٍرٍ سٌي سُو سَشِ عَ فِمَ عَ مَفٍلِ نَن نَ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\c 3  
\s1 عَلَ نَشَن حَنِفٍشِ عِسِرَيِلَ بّ 
\q1  
\v 1 وٌ وٌ تُلِ مَتِ يِ مَسٍنيِ رَ، 
\q1 عَلَتَلَ نَشَن مَسٍنمَ عِسِرَيِلَكَيٍ بّ، 
\q1 عَ شَبِلّ نَشَن نَمِنِ مِسِرَ بْشِ رَ. 
\q1  
\v 2 «ﭑ وٌ تَن نَن فبَنسَن سُفَندِ دُنِحَ شَبِلّيٍ بِرِن يَ مَ. 
\q1 نَ نَن عَ رَ، ﭑ عَ حَنِفٍشِ وٌ شَ حَشَنكَتّ سْتْ وٌ شَ يُنُبِيٍ شَ قٍ رَ.» 
\b  
\q1  
\v 3 مِشِ قِرِن نْمَ حّرّ رَلَندٍ 
\q1 شَ عٍ مُ لَنشِ نَ مَ؟ 
\q1  
\v 4 يّتّ عَ شُي رَ مِنِمَ وُلَ عِ 
\q1 شَ عَ مُ سُبٍ ندٍ سْتْشِ؟ 
\q1  
\v 5 شْنِ فٌرٌ مَ يّلّ كُي 
\q1 شَ دٌنسٍ مُ نَ يّلّ رَ؟ 
\q1 فَنتَنيِ نْمَ قُلَدٍ 
\q1 شَ شْنِ مُ سُشُشِ عَ رَ؟ 
\q1  
\v 6 قٍرِ قٍمَ تَا ندٍ كُي حَمَ كُي مُ عِقُ؟ 
\q1 فبَلٌي تَا ندٍ لِمَ، شَ عَلَتَلَ شَ مُ عَ رَفِرِ؟ 
\q1  
\v 7 مَرِفِ عَلَتَلَ مُ قٍقٍ رَبَمَ، 
\q1 عَ مُ عَ شَ فُندٌ مَسٍن عَ شَ كٌنيِ نَمِحْنمّيٍ بّ. 
\q1  
\v 8 يّتّ نَ عَ شُي رَ مِنِ، ندٍ مُ فَاشُمَ؟ 
\q1 مَرِفِ عَلَتَلَ نَ وْيّن، ندٍ تٌندِ مَ نَ مَسٍندٍ؟ 
\b  
\q1  
\v 9 وٌ شَ يِ قَلَ عَسِدٌدِ يِرٍ مَكَنتَشِيٍ كُي، 
\q1 وٌ مَن شَ يِ قَلَ مِسِرَ يِرٍ مَكَنتَشِيٍ كُي، 
\q1 «وٌ شَ وٌ مَلَن سَمَرِ فٍيَيٍ قَرِ، 
\q1 وٌ شَ عَ مَتٌ مّننِكَيٍ كْنتْقِلِشِ كِ نَشّ، 
\q1 عَ نُن عٍ عٍ بٌورٍ تْورْ مَ كِ نَشّ.» 
\q1  
\v 10 عَلَتَلَ شَ مَسٍنيِ نَن يَ؛ 
\q1 «عٍ مُ تِنشِنيِ يٌ كٌلٌن، 
\q1 عٍ شَ قٍ حَاشِ نُن مُحّ شُن نَن تُن مَسَقٍ. 
\q1 عٍ نَشَن سْتْمَ، عٍ نَ مَلَنمَ عٍ شَ يِرٍ مَكَنتَشِيٍ نَن كُي.» 
\b  
\q1  
\v 11 مَرِفِ عَلَتَلَ نَشَن مَسٍن، نَ نَن يِ كِ. 
\q1 «وٌ وٌ يَ رَبِ، وٌ يَشُي نَ قَقٍ وٌ شَ بْشِ كَنَدٍ. 
\q1 عٍ قَمَ نّ وٌ شُن نَكَنَدٍ، 
\q1 عٍ قَ وٌ شَ يِرٍ مَكَنتَشِيٍ كَنَ.» 
\b  
\q1  
\v 12 عَلَتَلَ نَشَ عَ مَسٍن، 
\q1 «يّتّ نَ يّشّي عِبْو، 
\q1 شُرُ سٍ دّ مَدٌنيِ نْمَ يّشّي سَنيِ قِرِن، 
\q1 شَ نَ مُ عَ رَ عَ تُلِ شُنتُنيِ رَكِسِدٍ يّتّ مَ. 
\q1 عِسِرَيِلَكَيٍ قَن كِسِمَ نَ كِ نّ. 
\q1 سَمَرِكَ نَشٍيٍ عٍ مَلَبُمَ سَدٍ مَ، 
\q1 نَشٍيٍ عٍ مَفٌرٌ مَ دَ مَسِ مَفٌرٌ سٍيٍ كُي، 
\q1 وٌ تَن مُ كِسِمَ.» 
\b  
\q1  
\v 13 مَنفّ عَلَتَلَ شَ مَسٍنيِ نَن يَ؛ 
\q1 «وٌ وٌ تُلِ مَتِ ﭑ نَ، 
\q1 وٌ نَ مَسٍن يَشُبَ بْنسْي بّ. 
\q1  
\v 14 ﭑ نَ عِسِرَيِلَ حَشَنكَتَ 
\q1 عَ شَ يُنُبِيٍ شَ قٍ رَ تّمُي نَشّ، 
\q1 ﭑ مَن عٍ حَشَنكَتَمَ نّ عٍ شَ سّرّشّبَدٍيٍ شَ قٍ رَ نَشٍيٍ نَ بٍتٍلِ. 
\q1 نَ سّرّشّبَدٍ سُشُسٍيٍ بِرَ مَ نّ بْشِ. 
\q1  
\v 15 ﭑ مَن عٍ شَ بَنشِ تٌقَنيِيٍ رَبِرَ مَ نّ، 
\q1 حّمّ نُن سٌفٌقُرٍ بَنشِ بِرِن، 
\q1 نَشٍيٍ رَتٌقَنشِ سِلِ حِنيِ رَ. 
\q1 ﭑ نَ بِرِن كَنَمَ نّ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\c 4  
\s1 عَلَ نَشَن نَبَشِ عَلَكٌ عِسِرَيِلَ شَ فبِلٍن عَ مَ 
\q1  
\v 1 وٌ وٌ تُلِ مَتِ يِ مَسٍنيِ رَ، 
\q1 وٌ تَن فِنّ نَشٍيٍ لُشِ عَلْ نِنفٍيٍ، 
\q1 نِنفٍ تٌقَنيِيٍ نَشٍيٍ نَ بَسَن بْشِ مَ. 
\q1 وٌ تَن نَشٍيٍ سَبَتِشِ سَمَرِ فٍيَ قَرِ، 
\q1 وٌ تَن نَشٍيٍ مِسِكِينّ تْورْ مَ، 
\q1 وٌ تَن نَشٍيٍ تِمَ سٍتَرٍيٍ قَرِ. 
\q1 وٌ نُ قَ عَ قَلَمَ وٌ شَ مْرِيٍ بّ، 
\q1 «وٌ قَ بٍيرٍ رَ، وٌن نَشَن مِنمَ.» 
\q1  
\v 2 مَرِفِ عَلَتَلَ بَرَ عَ كَلِ عَ شَ سّنِيّنيِ رَ، 
\q1 «كِيتِ لْشْي نَ قَقٍ. 
\q1 عٍ قَمَ نّ وٌ سُشُدٍ وُرٍ كْنكْرْنشِيٍ رَ، 
\q1 عٍ وٌ نُن وٌ شَ دِيٍ شَنِن. 
\q1  
\v 3 وٌ مِنِمَ نّ وٌ شَ تّتّ كَنَشِ كُي، 
\q1 كَنكَن تِشِ عَ بٌورٍ شَنبِ رَ. 
\q1 عٍ وٌ شَنِنمَ نّ يِرٍ مَكَنتَشِ.» 
\q1 عَلَتَلَ شَ وْيّنيِ نَن نَ كِ. 
\b  
\q1  
\v 4 «وٌ سِفَ بٍتٍلِ، عَلَكٌ وٌ شَ يُنُبِ رَبَ نَا. 
\q1 وٌ سِفَ فِلِفَلِ، عَلَكٌ وٌ مَن شَ يُنُبِ سْتْ. 
\q1 وٌ شَ سّرّشّ بَ فّيسّفّ بِرِن، 
\q1 وٌ مَن شَ قَرِلّ بَ حّ سَشَن يٌ حّ سَشَن. 
\q1  
\v 5 وٌ لّبِنِ تَامِ بَ تَنتُي سّرّشّ رَ. 
\q1 وٌ وٌ شَ حَنِفٍ سّرّشّ مَسٍن بِرِن بّ، 
\q1 بَرِ مَ نَ قٍ مْولِيٍ رَقَن وٌ مَ، وٌ تَن عِسِرَيِلَكَيٍ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\b  
\q1  
\v 6 «ﭑ نُ بَرَ كَامّ رَ سٌ وٌ شَ تَايٍ كُي. 
\q1 تَامِ يٌ مُ لُ وٌ شْنيِ. 
\q1 كْنْ هَلِ ﭑ تٌ نَ بِرِن نَبَ، وٌ مُ تُوبِ ﭑ بّ.» 
\q1 عَلَتَلَ شَ وْيّنيِ نَن نَ كِ. 
\b  
\q1  
\v 7 «كِكٍ سَشَن تٌ نُ لُشِ شّ شَ شَبَ، 
\q1 ﭑ تٌندِ نّ تُنّ رَفٌرٌدٍ وٌ مَ. 
\q1 ﭑ بَرَ عَ نِيَ تَا ندٍيٍ شَ تُنّ سْتْ، 
\q1 تَا ندٍيٍ نَشَ عَ سْتْ. 
\q1 ﭑ بَرَ عَ رَفِرِ ندٍيٍ شَ تُنّ سْتْ، 
\q1 شّ ندٍيٍ نَشَ تُنّ سْتْ. 
\q1  
\v 8 مِشِيٍ بَرَ كٍلِ تَا ندٍيٍ، 
\q1 عٍ سِفَ يٍ قٍندٍ تَا فبّتّ كُي، 
\q1 كْنْ يٍ شْلِ مُ بَ عٍ مَ. 
\q1 هَلِ ﭑ تٌ نَ بِرِن نَبَ، وٌ مُ تُوبِ ﭑ بّ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\b  
\q1  
\v 9 «ﭑ بَرَ قُرٍ رَفٌرٌ وٌ شَ سَنسِيٍ مَ، 
\q1 ﭑ بَرَ عٍ شَرَ قٌيٍ رَ. 
\q1 كَتٌييٍ بَرَ وٌ شَ لَاكْي كَنَ، 
\q1 عَ نُن وٌ شَ وّنِ سَنسِيٍ، وٌ شَ شْرّ سَنسِيٍ، نُن وٌ شَ عٌلِوِ سَنسِيٍ. 
\q1 هَلِ ﭑ تٌ نَ بِرِن نَبَ، وٌ مُ تُوبِ ﭑ بّ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\b  
\q1  
\v 10 «ﭑ بَرَ قُرٍ حَاشِيٍ رَفٌرٌ وٌ مَ، 
\q1 عَلْ ﭑ عَ رَبَشِ مِسِرَ بْشِ مَ كِ نَشّ. 
\q1 ﭑ بَرَ وٌ شَ سّفّتَلَيٍ قَشَ سَنتِدّفّمَ رَ، 
\q1 عٍ بْرْ شِرِ نَشَ تٍ وٌ رَ. 
\q1 وٌ يَشُييٍ بَرَ عٍ شَ سٌييٍ تٌنفٌ. 
\q1 هَلِ ﭑ تٌ نَ بِرِن نَبَ، وٌ مُ تُوبِ ﭑ بّ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\b  
\q1  
\v 11 «ﭑ بَرَ وٌ حَشَنكَتَ، 
\q1 عَلْ ﭑ سٌدٌ مَ نُن فٌمٌرَ حَشَنكَتَشِ كِ نَشّ. 
\q1 وٌ لُشِ نّ عَلْ وُرِ نَشَن نَمِنِشِ تّ. 
\q1 هَلِ ﭑ تٌ نَ بِرِن نَبَ، وٌ مُ تُوبِ ﭑ بّ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\b  
\q1  
\v 12 «ﭑ قَمَ عِ تَن عِسِرَيِلَ حَشَنكَتَدٍ نَ نَن مَ. 
\q1 ﭑ نَ يِ رَبَ عِ رَ، عِ قَمَ نّ عِ مَرِفِ عَلَ كٌلٌندٍ.» 
\q1  
\v 13 نَشَن فٍيَيٍ نُن قٌيٍ دَاشِ، 
\q1 نَشَن عَدَ مَ شَ مَحْشُنيِ بِرِن كٌلٌن، 
\q1 نَشَن سُبَشّ قِندِ مَ كْي رَ، 
\q1 نَشَن حّرّ مَ يِرٍ عِتٍشِ قَرِ، 
\q1 عَ شِلِ مَنفّ عَلَتَلَ. 
\c 5  
\s1 عَلَ وَ مَ نَشَن شْن 
\q1  
\v 1 وٌ وٌ تُلِ مَتِ يِ مَسٍنيِ رَ. 
\q1 ﭑ بَرَ يِ بّيتِ بَ عِسِرَيِلَ بْنسْي حْن قٍ مَ. 
\q1  
\v 2 «عِسِرَيِلَ سّنِيّنتْي بَرَ قَشَ، عَ مُ كٍلِمَ سْنْن، 
\q1 عَ بَرَ بِرَ، مِشِ يٌ مُ عَ رَكٍلِمَ.» 
\b  
\q1  
\v 3 مَرِفِ عَلَتَلَ نَشَ عَ مَسٍن، 
\q1 «عِسِرَيِلَ بْنسْي، 
\q1 تَا نَشَن شّمّ وُلُ كٍرٍن شّيمَ فٍرٍ سٌدٍ، 
\q1 عَ شّمّ كّمّ نَن فبَنسَن تٌمَ فبِلٍن نَ. 
\q1 تَا نَشَن شّمّ كّمّ شّيمَ فٍرٍ سٌدٍ، 
\q1 عَ شّمّ قُ نَن فبَنسَن تٌمَ فبِلٍن نَ.» 
\b  
\q1  
\v 4 عَلَتَلَ نَشَ عَ مَسٍن عِسِرَيِلَ بْنسْي بّ، 
\q1 «وٌ قَ ﭑ قٍن عَلَكٌ وٌ شَ كِسِ. 
\q1  
\v 5 وٌ نَشَ ﭑ قٍن بٍتٍلِ، 
\q1 وٌ نَشَ سِفَ فِلِفَلِ، 
\q1 شَ نَ مُ عَ رَ بٍرِ سٍيبَ، 
\q1 بَرِ مَ فِلِفَلِكَ بِرِن سِفَمَ نّ كٌنيِيَ كُي، 
\q1 بٍتٍلِ قَن هَلَكِمَ نّ.» 
\b  
\q1  
\v 6 وٌ عَلَتَلَ قٍن عَلَكٌ وٌ شَ كِسِ. 
\q1 شَ نَ مُ عَ رَ، يُسُقُ بْنسْي، 
\q1 عَلَتَلَ وٌ سْنتْمَ نّ تّ رَ. 
\q1 بٍتٍلِكَ يٌ مُ نَ نَشَن نَ تّ رَشُبٍنمَ. 
\q1  
\v 7 وٌ تَن بَرَ تِنشِنيِ مَقِندِ ﭑ نَشْنقٍ رَ، 
\q1 وٌ بَرَ يٌ سّرِيّ مَ. 
\b  
\q1  
\v 8 عَلَتَلَ نَن تُنبُييٍ سَ كٌورٍ مَ، 
\q1 عَ دِ مِ عِيَلَن سُبَشّ مَ، 
\q1 عَ سٌفٍ رَدُلَ، كْي شَ سٌ، 
\q1 عَ يٍ تٌنفٌ بَا مَ، 
\q1 عَ نَ قِندِ تُنّ رَ، عَ فٌرٌ بْشِ مَ. 
\q1 نَشَن نَ بِرِن نَبَمَ، عَ شِلِ نّ عَلَتَلَ. 
\b  
\q1  
\v 9 عَلَتَلَ مِشِ شُنفبٍيٍ هَلَكِمَ نّ، 
\q1 عَ عٍ شَ يِرٍ مَكَنتَشِيٍ كَنَ. 
\q1  
\v 10 عٍ مِشِ شْنمَ نَشَن كِيتِ سَمَ سّرِيّ رَ، 
\q1 نْندِ قَلّ مُ رَقَن عٍ مَ. 
\q1  
\v 11 وٌ مِسِكِينّ تْورْ مَ، 
\q1 وٌ بَلٌي بَمَ عٍ يِ رَ دُوتِ رَ. 
\q1 وٌ بَرَ بَنشِ تٌقَنيِيٍ تِ فّمّيٍ رَ، 
\q1 كْنْ وٌ مُ قَمَ سَبَتِدٍ نٍيٍ كُي. 
\q1 وٌ بَرَ وّنِ سَنسِ قَنيِيٍ سِ، 
\q1 كْنْ وٌ مُ قَمَ نَ وّنِ مِندٍ. 
\q1  
\v 12 ﭑ عَ كٌلٌن وٌ شَ هَاكّ نُن وٌ شَ يُنُبِ فبٌ. 
\q1 وٌ تِنشِنتْي تْورْ مَ، 
\q1 وٌ سّرِيّ بّحِنمَ كْبِرِ شَ قٍ رَ، 
\q1 وٌ مُ سٍتَرٍيٍ مَكِيتِمَ نْندِ رَ. 
\q1  
\v 13 نَ نَن عَ تٌشِ شَشِلِمَ دُندُ مَ، 
\q1 بَرِ مَ يِ وَشَتِ مُ قَن. 
\q1  
\v 14 وٌ قٍ قَنيِ قٍن، وٌ وٌ يِ بَ قٍ حَاشِ رَ، 
\q1 عَلَكٌ وٌ شَ كِسِ، مَنفّ عَلَتَلَ شَ لُ وٌ سّيتِ مَ، 
\q1 عَلْ وٌ عَ قَلَمَ كِ نَشّ. 
\q1  
\v 15 وٌ شَ قٍ حَاشِ شْن. 
\q1 قٍ قَنيِ شَ رَقَن وٌ مَ. 
\q1 وٌ شَ كِيتِ شَ تِنشِن. 
\q1 شَ وٌ نَ رَبَ، تّمُندٍ، 
\q1 مَنفّ عَلَتَلَ كِنِكِنِمَ نّ وٌ تَن يُسُقُ بْنسْي دْنشْييٍ مَ. 
\b  
\q1  
\v 16 نَ نَن عَ تٌشِ وٌن مَرِفِ عَلَتَلَ، 
\q1 دُنِحَ دَا مَنفّ نَشَ عَ مَسٍن، 
\q1 «عٍ عٍ وَ شُي عِتٍمَ نّ تَا كُي، 
\q1 عٍ عٍ وَ شُي عِتٍمَ نّ كِرَ شْن مَ. 
\q1 عٍ شّ سَ شِلِمَ نّ عٍ شَ عٍ وَ شُي عِتٍ حْن قٍ مَ، 
\q1 عٍ بّيتِبَيٍ شِلِمَ نّ عٍ شَ قَشّ بّيتِ بَ. 
\q1  
\v 17 ﭑ نّ دَنفِمَ شّ رَ تّمُي نَشّ، 
\q1 ﭑ وَ شُي نَن تُن مّمَ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\s1 حَشَنكَتّ دِينّلَيٍ بّ 
\q1  
\v 18 حَشَنكَتّ نَ مِشِ بّ 
\q1 نَشَن وَ مَ عَلَتَلَ شَ كِيتِ لْشْي شَ قَ. 
\q1 وٌ وَ مَ مُنسٍ شْن مَ نَ لْشْي؟ 
\q1 نَ قِندِ مَ دِ مِ نَن نَ وٌ بّ، 
\q1 نَ مُ قِندِ مَ نَءِيَلَنيِ شَ رَ. 
\q1  
\v 19 نَ لُمَ نّ عَلْ مِشِ نَشَن عَ فِمَ يّتّ يَ رَ، 
\q1 عَ قَ سْحّ لِ. 
\q1 عَ نَ سٌ بَنشِ كُي، عَ عَ كِلْن بَنشِ رَ، 
\q1 بْشِمَسٍ قَ عَ شِن. 
\q1  
\v 20 عَلَتَلَ شَ كِيتِ لْشْي مُ قِندِشِ دِ مِ شَ رَ؟ 
\q1 نَءِيَلَنيِ يٌ مُ نَ وٌ بّ نَ لْشْي. 
\q1  
\v 21 «ﭑ بَرَ وٌ شَ سَلِ شْن، 
\q1 عٍ مُ رَقَن ﭑ مَ قٍقٍ مَ. 
\q1 ﭑ مُ وَ مَ عٍ شْن قٍوٌ. 
\q1  
\v 22 وٌ شَ سّرّشّ فَن دَاشِ يٌ، 
\q1 وٌ شَ قَرِلّ سّرّشّ يٌ، 
\q1 وٌ شَ شَنُنتٍيَ سّرّشّ يٌ، 
\q1 عٍ سٍسٍ مُ رَقَن ﭑ مَ. 
\q1 ﭑ مُ تِنمَ عٍ رَ سُشُدٍ، هَلِ كٍرٍن. 
\q1  
\v 23 وٌ بّيتِ شُي مَكُيَ ﭑ نَ. 
\q1 ﭑ مُ وَ مَ وٌ شَ كْرَ بّيتِ شُي رَ مّقٍ. 
\q1  
\v 24 ﭑ وَ مَ نَشَن شْن، 
\q1 تِنشِنتْييٍ شَ فبٌ وٌ يَ مَ عَلْ يٍ نَشَن نَ بَا مَ. 
\q1 وٌ شَ قٍ قَنيِ شَ لُ عَلْ شُرٍ نَشَن مُ شْرِ مَ. 
\q1  
\v 25 وٌ تٌ نُ نَ فبٍنفبٍرٍن يِرٍ حّ تٌنفٌ نَانِ بُن مَ، 
\q1 وٌ سّرّشّيٍ بَ نّ؟ عَدٍ. 
\q1  
\v 26 وٌ كُيٍ مَشَنِن نّ، 
\q1 عَلْ وٌ شَ مَنفّ عَلَ، نَشَن شِلِ سِكٌتِ، 
\q1 شَ نَ مُ عَ رَ وٌ شَ تُنبُي عَلَ، نَشَن شِلِ كِيُن، 
\q1 وٌ نَشٍيٍ يَءِلَنشِ وٌ يّتّ رَ؟ عَدٍ. 
\q1  
\v 27 ﭑ قَمَ نّ وٌ شَنِندٍ كٌنيِيَ كُي دَ مَسِ شَنبِ رَ.» 
\q1 مَنفّ عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\c 6  
\s1 حَشَنكَتّ بَننَ مِشِيٍ بّ 
\q1  
\v 1 حَشَنكَتّ نَ وٌ بّ، 
\q1 وٌ تَن نَشٍيٍ لَشِ وٌ يّتّ رَ سِيٌنِ نُن سَمَرِ فٍيَيٍ قَرِ، 
\q1 عِسِرَيِلَ بْنسْي عَ شَشِلِ تِمَ وٌ تَن نَشٍيٍ رَ. 
\q1  
\v 2 وٌ سَ كَلٍنٍ مَتٌ، عَ نُن شَمَتَ، نَ تَا شُنفبٍيٍ. 
\q1 وٌ مَن شَ فٌرٌ قِلِسِتَ بْشِ مَ فَتِ مَتٌدٍ. 
\q1 نٍيٍ قِسَ وٌ بّ؟ 
\q1 عٍ شَ بْشِ فبٌ وٌ فبٍ بّ؟ 
\q1  
\v 3 وٌ عَ مَحْشُنشِ نّ عَ حَشَنكَتّ لْشْي مُ وٌ لِمَ، 
\q1 كْنْ وٌ عَ نِيَمَ نّ قٍ حَاشِ شَ وٌ سْتْ. 
\q1  
\v 4 وٌ وٌ مَلَبُمَ سَدٍ تٌقَنيِ مَ، 
\q1 وٌ يّشّي نُن نِنفٍ قَنيِ دٌنمَ، 
\q1  
\v 5 وٌ سِفِ سَ كْرَ رَ. 
\q1 وٌ حْشْ عَ مَ عَ وٌ قَتَ نَ رَبَدٍ عَلْ عَننَبِ دَوُدَ. 
\q1  
\v 6 وٌ وّنِ فبٍفبٍ مِنمَ، 
\q1 وٌ تُرٍ قَنيِ مَسٌ وٌ قَتٍ مَ. 
\q1 نَ كُي، وٌ مُ كْنتْقِلِمَ يُسُقُ بْنسْي شَ حَشَنكَتّ شَ قٍ رَ. 
\q1  
\v 7 نَ نَن عَ تٌشِ، وٌ سِنفٍ سِفَمَ كٌنيِيَ كُي. 
\q1 وٌ شَ شُلُنيِيٍ دَنمَ نّ. 
\b  
\q1  
\v 8 مَرِفِ عَلَتَلَ بَرَ عَ كَلِ عَ يّتّ رَ. 
\q1 مَنفّ عَلَتَلَ شَ مَسٍنيِ نَن يَ؛ 
\q1 «ﭑ يَشُبَ بْنسْي شَ يّتّ عِفبٌحَ شْنشِ. 
\q1 عٍ شَ يِرٍ مَكَنتَشِيٍ مُ رَقَن ﭑ مَ. 
\q1 ﭑ قَمَ نّ عٍ بِرِن هَلَكِدٍ.» 
\b  
\q1  
\v 9 شَ شّمّ قُ نَ بَنشِ ندٍ كُي، 
\q1 عٍ بِرِن قَمَ نّ قَشَدٍ. 
\q1  
\v 10 عٍ بَرٍنيِ نَ سٌ نَ بَنشِ كُي عٍ قُرٍيٍ تٌنفٌدٍ، عَ شَ عٍ فَن، 
\q1 عَ قَمَ نّ مِشِ مَشْرِندٍ نَشَن نْشُنشِ بَنشِ كُي، 
\q1 «مِشِ فبّتّ نَ بٍ بَقٍ عِ تَن نَ؟» 
\q1 عَ عَ يَابِمَ نّ، «عَدٍ.» 
\q1 عَ مَن فبِلٍنمَ نّ عَ قَلَ رَ، «عِ سَبَرِ، 
\q1 عَ مُ لَنمَ عَلَتَلَ شِلِ شَ قَلَ، 
\q1  
\v 11 بَرِ مَ عَلَتَلَ نَن يَامَرِ قِمَ 
\q1 عَ بَنشِ شُنفبٍ يٌ، بَنشِ لَنمَ يٌ، 
\q1 عٍ بِرِن شَ رَبِرَ، عٍ شَ كَنَ.» 
\b  
\q1  
\v 12 سٌييٍ نْمَ عٍ فِدٍ فّمّ يِرٍ؟ 
\q1 نِنفٍيٍ نْمَ مّننِ بُشَدٍ؟ 
\q1 عَوَ، مُنقٍ رَ وٌ تِنشِنيِ مَقِندِ مَ تِنشِنتَرٍيَ رَ، 
\q1 وٌ سّرِيّ مَقِندِ قٍ حَاشِ رَ؟ 
\q1  
\v 13 وٌ سّيوَ مَ قٍ قُقَقُ رَ. 
\q1 وٌ نَشّ عَ وٌ شَ قٍ بَرَ سْونّيَ وٌ يّتّ سّنبّ رَ. 
\q1  
\v 14 مَنفّ عَلَتَلَ شَ مَسٍنيِ نَن يَ؛ 
\q1 «نَ نَن عَ تٌشِ، ﭑ قَمَ كٍلِدٍ وٌ شِلِ مَ، عِسِرَيِلَ بْنسْي. 
\q1 وٌ تَن نَشٍيٍ نَ شَمَتَ هَن عَرَبَ شُرٍ، 
\q1 سِ ندٍ قَمَ نّ وٌ تْورْدٍ.» 
\c 7  
\s1 عَلَ شَ لَامَتُنيِ سِنفٍ عَننَبِ عَمٌسِ بّ 
\q1  
\v 1 مَرِفِ عَلَتَلَ نَشَ يِ لَامَتُنيِ مَسٍن ﭑ بّ؛ 
\q1 شّ تٌ شَبَ، مَنفّ شَ سَنسِ نّينّ قَن نُ نَ مِنِقٍ، 
\q1 عَلَتَلَ نَشَ كَتٌي رَ مِنِ. 
\q1  
\v 2 عٍ تٌ فّ سَنسِ بِرِن دٌندٍ بْشِ مَ، 
\q1 ﭑ نَشَ عَ قَلَ، 
\q1 «مَرِفِ عَلَتَلَ، ﭑ بَرَ عِ مَيَندِ، 
\q1 عِ شَ عٍ شَ يُنُبِ شَقَرِ، 
\q1 شَ نَ مُ عَ رَ يَشُبَ بْنسْي قَ بَلٌمَ دِ؟ 
\q1 عَ سّنبّ مُ فبٌ.» 
\q1  
\v 3 عَلَتَلَ نَشَ كِنِكِنِ عٍ مَ، عَ قَ عَ مَسٍن، 
\q1 «عَوَ، يِ مُ رَبَمَ كْرّ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\s1 عَلَ شَ لَامَتُنيِ قِرِن ندٍ عَننَبِ عَمٌسِ بّ 
\q1  
\v 4 مَرِفِ عَلَتَلَ نَشَ يِ لَامَتُنيِ مَسٍن ﭑ بّ؛ 
\q1 مَرِفِ عَلَتَلَ نَشَ عَ حَنِفٍ تّ شَ دّشّ. 
\q1 تّ نَشَ بْشِ بِرِن فَن، بْشِ يٍ بِرِن نَشَ شَرَ. 
\q1  
\v 5 ﭑ نَشَ عَ قَلَ، 
\q1 «مَرِفِ عَلَتَلَ، ﭑ بَرَ عِ مَيَندِ، دَن مّننِ، 
\q1 شَ نَ مُ عَ رَ يَشُبَ بْنسْي قَ بَلٌمَ دِ؟ 
\q1 عَ سّنبّ مُ فبٌ.» 
\q1  
\v 6 عَلَتَلَ نَشَ كِنِكِنِ عٍ مَ، عَ قَ عَ قَلَ، 
\q1 «عَوَ، يِ مُ رَبَمَ كْرّ.» 
\q1 مَرِفِ عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ. 
\s1 عَلَ شَ لَامَتُنيِ سَشَن ندٍ عَننَبِ عَمٌسِ بّ 
\q1  
\v 7 مَرِفِ عَلَتَلَ نَشَ يِ لَامَتُنيِ مَسٍن ﭑ بّ؛ 
\q1 مَرِفِ نُ تِشِ بِلِشِ تِنشِنشِ قَرِ، 
\q1 بِرِكِ مَتِنشِن سٍ نُ سُشُشِ عَ يِ رَ. 
\q1  
\v 8 عَلَتَلَ نَشَ ﭑ مَشْرِن، 
\q1 «عَمٌسِ، عِ مُنسٍ تٌشِ؟» 
\q1 ﭑ نَشَ عَ يَابِ، «بِرِكِ مَتِنشِن سٍ.» 
\q1 مَرِفِ نَشَ عَ مَسٍن، 
\q1 «ﭑ وَ مَ ﭑ مَ حَمَ شَ مَتِنشِن. 
\q1 ﭑ مُ دِحّمَ سْنْن. 
\q1  
\v 9 كُيٍ بَتُدٍيٍ كَنَمَ نّ عِسِيَفَ شَ بْشِ مَ. 
\q1 عِسِرَيِلَ شَ سَلِدٍيٍ رَبِرَ مَ نّ. 
\q1 ﭑ كٍلِمَ نّ يٍرٌبٌوَ مِ بْنسْي شِلِ مَ سَنتِدّفّمَ رَ.» 
\s1 عَمٌسِ نُن عَمَسِيَ 
\p  
\v 10 بٍتٍلِ سّرّشّدُبّ عَمَسِيَ، نَشَ عَ مَسٍن عِسِرَيِلَ مَنفّ يٍرٌبٌوَ مِ بّ، «عَمٌسِ نَ عِ يَنقَقٍ عِسِرَيِلَ بْنسْي يَ مَ. عَ نَشَن قَلَمَ عَ مُ قَن بْشِ بّ.  
\v 11 عَمٌسِ نَشّ، ‹يٍرٌبٌوَ مِ قَمَ نّ قَشَدٍ سَنتِدّفّمَ رَ. عِسِرَيِلَ سِفَمَ نّ كٌنيِيَ كُي حَمَنّ مَ.›» 
\p  
\v 12 عَمَسِيَ نَشَ عَ قَلَ عَمٌسِ بّ، «عِ تَن نَشَن لَامَتُنيِ تٌمَ، كٍلِ بٍ عِ سِفَ يُدَيَ. عِ شَ سَ عِ بَلٌي قٍن مّننِ نَمِحْنمّ وَلِ كُي،  
\v 13 كْنْ عِ نَشَ نَمِحْنمّ مَسٍنيِ تِ بٍتٍلِ دٍ، بَرِ مَ مَنفّ شَ سَلِدٍ نَ مّننِ نّ، عَ شَ مَنفَتَا نَن نَا رَ.» 
\p  
\v 14 عَمٌسِ نَشَ عَمَسِيَ يَابِ، «نَمِحْنمّ مُ نَ ﭑ نَ. ﭑ بَبَ قَن نَمِحْنمّ مُ عَ رَ. شُرُ سٍ كَنيِ نَن ﭑ نَ. ﭑ سِكٌمٌرٌ سَنسِ قَن نَوَلِمَ.  
\v 15 عَلَتَلَ نَشَ ﭑ شِلِ شُرُ سٍيٍ تَفِ، عَ قَ عَ مَسٍن ﭑ بّ، ‹سِفَ، عِ سَ نَمِحْنمّ مَسٍنيِ تِ ﭑ مَ حَمَ عِسِرَيِلَ بّ.›  
\v 16 يَكْسِ، عِ تُلِ مَتِ عَلَتَلَ شَ مَسٍنيِ رَ، عِ تَن نَشَن عَ قَلَمَ ﭑ بّ، ‹عِ نَشَ نَمِحْنمّ مَسٍنيِ تِ عِسِرَيِلَ بّ، عِ نَشَ وْيّن عِسِيَفَ بْنسْي بّ.›  
\v 17 نَ وْيّنيِ مَ، عَلَتَلَ نَشّ، ‹عِ شَ فِنّ قِندِ مَ نّ لَنفٌي رَ تَا كُي. عِ شَ دِيٍ قَشَمَ نّ سَنتِدّفّمَ رَ. عِ شَ بْشِ بَمَ نّ عِ يِ رَ، عَ عِتَشُن مِشِ فبّتّيٍ مَ. عِ تَن، عِ قَشَمَ نّ بْشِ سّنِيّنتَرٍ مَ. عِسِرَيِلَ قَن شَنِنمَ نّ يِرٍ، نَشَن مَكُيَ عَ شَ بْشِ رَ.›» 
\c 8  
\s1 عَلَ شَ لَامَتُنيِ نَانِ ندٍ عَننَبِ عَمٌسِ بّ 
\q1  
\v 1 مَرِفِ عَلَتَلَ نَشَ يِ لَامَتُنيِ مَسٍن ﭑ بّ؛ 
\q1 دٍبٍ نَن نُ عَ رَ نَشَن نَقٍشِ سَنسِ بٌفِ مْشِ رَ. 
\q1  
\v 2 عَ نَشَ ﭑ مَشْرِن، 
\q1 «عَمٌسِ، عِ مُنسٍ تٌشِ بٍ؟» 
\q1 ﭑ نَشَ عَ يَابِ، 
\q1 «دٍبٍ رَقٍشِ سَنسِ بٌفِ مْشِ رَ.» 
\q1 عَلَتَلَ نَشَ عَ مَسٍن ﭑ بّ، 
\q1 «ﭑ مَ حَمَ عِسِرَيِلَ قَن بَرَ مْ. 
\q1 ﭑ مُ دِحّمَ سْنْن.» 
\q1  
\v 3 عَلَتَلَ شَ مَسٍنيِ نَن يَ؛ 
\q1 «نَ لْشْييٍ سِفِ نَشَن سَمَ مَنفّ شَ بَنشِ كُي، 
\q1 نَ مَسَرَ مَ نّ وَ شُي رَ. 
\q1 قُرٍيٍ رَلَنتَنمَ نّ يِرٍ بِرِن، 
\q1 بِرِن دُندُ مَ نّ نَ لْشْي.» 
\b  
\q1  
\v 4 وٌ وٌ تُلِ مَتِ يِ مَسٍنيِ رَ، 
\q1 وٌ تَن نَشٍيٍ سٍتَرٍ تْورْ مَ، 
\q1 وٌ تَن نَشٍيٍ تْورْ مِشِ حَشَنكَتَمَ. 
\q1  
\v 5 وٌ نَشّ، «كِكٍ نّينّ سَلِ حْنمَ مُن تّمُي، 
\q1 عَلَكٌ وٌن شَ سَرٍ مَتِ؟ 
\q1 مَلَبُي لْشْي حْنمَ مُن تّمُي، 
\q1 عَلَكٌ وٌن شَ مَالٍ مَتِ؟ 
\q1 وٌن شَ ندٍ بَ وٌن مَ سٍ مَنِيَ سٍيٍ رَ، 
\q1 وٌن شَ ندٍ سَ وٌن مَ سَرٍ سٌي شُن مَ. 
\q1 وٌن شَ سِكٍيلِ كَمَلِتَرٍ يَءِلَن. 
\q1  
\v 6 وٌن شَ مِسِكِينّ مَتِ كْبِرِ رَ، 
\q1 وٌن سٍتَرٍ مَتِ سَنكِرِ سَرٍ رَ. 
\q1 وٌن شَ مَالٍ شْرِ مَتِ عَ لَفِ رَ عَ شُن مَ.» 
\b  
\q1  
\v 7 عَلَتَلَ نَشَ عَ كَلِ عَ يّتّ رَ، 
\q1 يَشُبَ بْنسْي عَ يّتّ عِفبٌمَ عَلَ نَشَن نَ؛ 
\q1 «ﭑ مُ نّيمُمَ عٍ رَبَ قٍيٍ مَ، 
\q1 هَن دُنِحَ حْن. 
\q1  
\v 8 يِ بْشِ قَمَ كَنَدٍ نَ نَن مَ. 
\q1 بٍكَيٍ بِرِن لُمَ سُننُنيِ نَن كُي. 
\q1 بْشِ سّرّنمَ نّ عَلْ مِسِرَ شُرٍ، 
\q1 نَشَن بَنبَرَنمَ، عَ مَن فبِلٍن.» 
\b  
\q1  
\v 9 مَرِفِ عَلَتَلَ شَ مَسٍنيِ نَن يَ؛ 
\q1 «ﭑ قَمَ نّ عَ رَفِرِدٍ نَ لْشْي، 
\q1 سٌفٍ فٌرٌ عَ فٌرٌ تّمُي مُ عَ لِشِ، 
\q1 دِ مِ سِن بْشِ مَ يَنيِ رَ. 
\q1  
\v 10 وٌ شَ سَلِيٍ مَسَرَ مَ حْن سٌي نَن نَ، 
\q1 وٌ شَ سِفِيٍ مَسَرَ مَ وَ شُي نَن نَ. 
\q1 ﭑ سُننُن دٌنمَ رَفٌرٌ مَ نّ وٌ مَ، 
\q1 ﭑ وٌ شُنيِ بِ سُننُن قٍ مَ. 
\q1 ﭑ قَمَ نّ سُننُنيِ شُنفبٍ رَفٌرٌدٍ بْشِ مَ، 
\q1 عَلْ دِ كٍرٍنيِ نَ قَشَ. 
\q1 نَ شْنّ مُ بَمَ وٌ مَ عَبَدَن.» 
\b  
\q1  
\v 11 مَرِفِ عَلَتَلَ شَ مَسٍنيِ نَن يَ؛ 
\q1 «نَ لْشْييٍ كَامّ سِنمَ نّ بْشِ مَ، 
\q1 كْنْ دٌنيِ كَامّ مُ عَ رَ، يٍ شْلِ قَن مُ عَ رَ. 
\q1 وٌ كَامّمَ عَلَتَلَ شَ مَسٍنيِ نَن مَ قٍ رَ. 
\q1  
\v 12 وٌ بْشِ بِرِن عِفِرِ مَ نّ، كٍلِقٍ كْولَ مَ هَن سٌفٍتٍدٍ، 
\q1 عَلَتَلَ شَ مَسٍنيِ قٍندٍ، 
\q1 كْنْ وٌ مُ عَ تٌمَ. 
\q1  
\v 13 نَ لْشْي وٌ شَ فِنّدِ مّدِيٍ نُن وٌ شَ سّفّتَلَيٍ قَشَمَ نّ نَ كَامّ مَ. 
\q1  
\v 14 سِنفٍ، عٍ نُ عٍ كَلِمَ سَمَرِ شَ عَلَ وُلٍ دَاشِ نَن نَ. 
\q1 عٍ نُ عَ قَلَ، ‹ﭑ بَرَ ﭑ كَلِ دَنَ شَ عَلَ رَ.› 
\q1 ‹ﭑ بَرَ ﭑ كَلِ بٍرِ سٍيبَ شَ عَلَ رَ.› 
\q1 كْنْ عٍ قَمَ نّ بِرَدٍ، عٍ مُ كٍلِمَ عَبَدَن.» 
\c 9  
\s1 عَلَ شَ لَامَتُنيِ دْنشْي عَننَبِ عَمٌسِ بّ 
\q1  
\v 1 ﭑ نَشَ لَامَتُنيِ ندٍ تٌ، 
\q1 مَرِفِ نُ نَ سّرّشّبَدٍ قَرِ. 
\q1 عَ نَشَ عَ يَمَرِ، 
\q1 «سَلِدٍ شُنيِ رَبِرَ، 
\q1 سَلِدٍ سَنيِ عِتَلَ. 
\q1 عَ بِرِن شَ بِرَ مِشِيٍ شُن مَ. 
\q1 ﭑ عٍ شَ دِيٍ هَلَكِمَ نّ سَنتِدّفّمَ رَ. 
\q1 مِشِ كٍرٍن مُ كِسِمَ. 
\q1 مِشِ كٍرٍن مُ عَ نْشُنمَ ﭑ مَ. 
\q1  
\v 2 هَلِ عٍ فٌرٌ عَلِفِيَمَ، ﭑ نٍيٍ سُشُمَ نّ. 
\q1 شَ عٍ تٍ كٌورٍ مَ، ﭑ نٍيٍ رَفٌرٌ مَ نّ. 
\q1  
\v 3 شَ عٍ عٍ نْشُن ﭑ مَ كَرٍ مٍلٍ فٍيَ قَرِ، 
\q1 ﭑ عٍ قٍنمَ نّ، ﭑ عٍ سُشُ. 
\q1 شَ عٍ عٍ نْشُن ﭑ مَ بَا بُن مَ، 
\q1 ﭑ بْشِمَسٍيٍ يَمَرِ مَ نّ عَ شَ عٍ شِن. 
\q1  
\v 4 شَ عٍ يَشُييٍ عٍ شَنِن كٌنيِيَ كُي، 
\q1 ﭑ يَامَرِ قِمَ نّ عٍ شَ عٍ قَشَ سَنتِدّفّمَ رَ. 
\q1 ﭑ نَن ﭑ يَ تِمَ نّ عٍ رَ، 
\q1 كْنْ نَ مُ قِندِ مَ مُنَقَنيِ رَ عٍ بّ، 
\q1 عَ قِندِ مَ حَشَنكَتّ نَن نَ عٍ بّ.» 
\b  
\q1  
\v 5 مَرِفِ عَلَتَلَ، نَشَن نَ مَنفّ رَ، 
\q1 شَ عَ عَ حَنِفٍ عَ شَ دِن بْشِ رَ، 
\q1 بْشِ سّرّنمَ نّ، 
\q1 مِشِ بِرِن لُ سُننُنيِ كُي، 
\q1 عَ عِتٍمَ نّ، عَ مَن عَ عِفٌرٌ عَلْ مِسِرَ شُرٍ نِلِ نَ بَنبَرَن حّ. 
\q1  
\v 6 عَ بَرَ عَ شَ لِنفِرَ تِ كٌورٍ مَ. 
\q1 عَ بَرَ كٌورٍ وَلَشّ لُ بْشِ شُن مَ. 
\q1 عَ يٍ رَكٍلِمَ بَا مَ، عَ رَدِن بْشِ مَ. 
\q1 عَ شِلِ نّ عَلَتَلَ. 
\b  
\q1  
\v 7 عَلَتَلَ شَ مَسٍنيِ نَن يَ؛ 
\q1 «عِسِرَيِلَكَيٍ، وٌ تِدٍ مُ فبٌ ﭑ بّ عَلْ عٍتِيٌثِكَيٍ؟ 
\q1 ﭑ مُ وٌ رَ مِنِ شّ مِسِرَ بْشِ رَ، 
\q1 عَلْ ﭑ قِلِسِتَكَيٍ رَ مِنِ كَقَتٌرٌ كِ نَشّ؟ 
\q1 ﭑ مُ وٌ رَ مِنِ شّ مِسِرَ بْشِ رَ، 
\q1 عَلْ ﭑ سِرِيَكَيٍ رَ مِنِ كِرٌ كِ نَشّ؟ 
\q1  
\v 8 وٌ وٌ يَيٍ رَبِ؛ 
\q1 مَرِفِ عَلَتَلَ بَرَ يُنُبِتْييٍ شَ مَنفّيَ تٌ، 
\q1 عَ قَمَ نّ نَ هَلَكِدٍ يِ دُنِحّ بّندّ قُحِ قَرِ.» 
\b  
\q1  
\v 9 عَلَتَلَ شَ مَسٍنيِ نَن يَ؛ 
\q1 «كْنْ ﭑ مُ يَشُبَ بْنسْي بِرِن هَلَكِمَ. 
\q1 ﭑ يَامَرِ قِمَ نّ عَلَكٌ عِسِرَيِلَ بْنسْي شَ مَيٍفٍتِ. 
\q1 ﭑ عَ عِقٍمَ نّ عَلْ مَالٍ عِقٍمَ كِ نَشّ، 
\q1 عَلَكٌ شْرِ قَنيِ كٍرٍن نَشَ بِرَ. 
\q1  
\v 10 كْنْ يُنُبِتْييٍ نَشٍيٍ بِرِن نَ ﭑ مَ حَمَ يَ مَ، 
\q1 ﭑ عٍ قَشَمَ نّ سَنتِدّفّمَ رَ، 
\q1 عٍ تَن نَشٍيٍ عَ قَلَمَ، 
\q1 ‹عِ مُ قَمَ مُشُ حَشَنكَتَدٍ، 
\q1 نَ حَشَنكَتّ مُ مُشُ لِمَ.›» 
\s1 عِسِرَيِلَ شَ كِسِ 
\q1  
\v 11 «نَ لْشْي ﭑ دَوُدَ شَ مَنفّيَ كَنَشِ عِتٍمَ نّ. 
\q1 ﭑ قَمَ نّ نَ يَءِلَندٍ، 
\q1 ﭑ قَمَ نّ عَ رَكٍلِدٍ عَلْ عَ سِنفٍ. 
\q1  
\v 12 عٍ مَن عٍدٌن مَسْتْمَ نّ، 
\q1 عَ نُن سِ بِرِن ﭑ شِلِ سَشِ نَشٍيٍ شُن مَ.» 
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ، 
\q1 عَ قَمَ نّ نَ بِرِن نَكَمَلِدٍ. 
\q1  
\v 13 عَلَتَلَ شَ مَسٍنيِ نَن يَ؛ 
\q1 «وٌ وٌ يَيٍ رَبِ؛ 
\q1 لْشْييٍ قَمَ عَ لِدٍ، 
\q1 شّ سَيٍ نُن شّ شَبَيٍ وَلِمَ وَشَتِ كٍرٍن نّ. 
\q1 وّنِ بَيٍ نُن شّ سَيٍ، قَن وَلِمَ وَشَتِ كٍرٍن نّ. 
\q1 وّنِ فبٌمَ نّ فٍيَيٍ قَرِ، 
\q1 هَن فٍيَيٍ بِرِن بُندَ. 
\q1  
\v 14 ﭑ نَن ﭑ مَ حَمَ رَفبِلٍنمَ نّ عَ شْنيِ كٍلِقٍ رَ كٌنيِيَ كُي. 
\q1 عٍ قَمَ نّ تَا كَنَشِيٍ تِدٍ، عٍ سَبَتِمَ دّننَشّ. 
\q1 عٍ وّنِ بِلِيٍ سِمَ نّ، عٍ عَ وّنِ مِن. 
\q1 عٍ لَاكْي سَمَ نّ، عٍ عَ بٌفِ دٌن. 
\q1  
\v 15 ﭑ مَن عٍ رَ سَبَتِمَ نّ عٍ شَ بْشِ مَ. 
\q1 عٍ مُ كٍلِمَ بْشِ مَ سْنْن 
\q1 ﭑ دّننَشّ قِشِ عٍ مَ.» 
\q1 وٌ مَرِفِ عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.