\v 11 \w En|strong="H5921"\w* \w estas|strong="H5975"\w* cartas \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w concedía|strong="H5414"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* \w judíos|strong="H3064"\w* \w que|strong="H5921"\w* \w estaban|strong="H5975"\w* \w en|strong="H5921"\w* \w cada|strong="H3605"\w* \w ciudad|strong="H5892"\w* \w se|strong="H5921"\w* reunieran \w para|strong="H5921"\w* defender sus \w vidas|strong="H5315"\w*, \w y|strong="H5921"\w* destruyeran, \w mataran|strong="H2026"\w* \w y|strong="H5921"\w* exterminaran \w a|strong="H3068"\w* \w cualquier|strong="H3605"\w* fuerza armada \w que|strong="H5921"\w* \w los|strong="H5921"\w* atacara \w a|strong="H3068"\w* \w ellos|strong="H5921"\w*, \w a|strong="H3068"\w* sus \w niños|strong="H2945"\w* \w y|strong="H5921"\w* sus mujeres, \w y|strong="H5921"\w* \w para|strong="H5921"\w* tomar \w los|strong="H5921"\w* bienes \w de|strong="H5921"\w* \w los|strong="H5921"\w* enemigos \w como|strong="H5921"\w* \w despojo|strong="H7998"\w*
