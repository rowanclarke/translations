\id ZEP - Biblica® Open Kurdi Sorani Standard Version 
\h سەفەنیا 
\toc1 سەفەنیا 
\toc2 سەفەنیا 
\toc3 سەفەنیا 
\mt1 سەفەنیا 
\c 1  
\p  
\v 1 پەیامی یەزدان بۆ سەفەنیای کوڕی کووشی کوڕی گەدەلیاهوی کوڕی ئەمەریای کوڕی حەزقیا، لە سەردەمی یۆشیای کوڕی ئامۆنی پاشای یەهودا: 
\b  
\s1 ئاگادارکردنەوە بۆ هاتنی وێرانکاری 
\q1  
\v 2 «هەموو شتێک لەسەر ڕووی زەوی 
\q2 بە تەواوەتی دادەماڵم.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\q1  
\v 3 «مرۆڤ و ئاژەڵ دادەماڵم، 
\q2 باڵندەکانی ئاسمان و 
\q2 ماسییەکانی دەریا دادەماڵم. 
\q1 بەدکاران تووشی کۆسپ دەکەم و 
\q2 مرۆڤ لەسەر ڕووی زەوی بنبڕ دەکەم.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\s1 پێشبینییەک سەبارەت بە یەهودا 
\q1  
\v 4 «دەستم بۆ سەر یەهودا و 
\q2 بۆ سەر هەموو دانیشتووانی ئۆرشەلیم درێژ دەکەم. 
\q1 ئەو بەعل پەرستانەی ماونەتەوە لەم شوێنە بنبڕیان دەکەم، 
\q2 ناوی کاهینە بتپەرستەکان و کاهینە هەڵگەڕاوەکان، 
\q1  
\v 5 ئەوانەی لە سەربانەکان کڕنۆش دەبەن 
\q2 بۆ ئەستێرەکانی ئاسمان، 
\q1 ئەوانەی کڕنۆش دەبەن و سوێند بە یەزدان دەخۆن، 
\q2 هەروەها سوێند بە مۆلەخیش\f + \fr 1:5 \ft خوداوەندێکی کەنعانییە بتپەرستەکان بووە، بۆ پەرستنی هەستاون بە تێپەڕاندنی منداڵەکانیان بەناو ئاگردا. بڕوانە دووەم هەواڵی ڕۆژان 28‏:3.‏\f* دەخۆن، 
\q1  
\v 6 لەگەڵ ئەوانەی لە یەزدان هەڵگەڕاونەتەوە و 
\q2 ئەوانەی ڕوو لە یەزدان ناکەن و پرسیاری لێ ناکەن.» 
\b  
\q1  
\v 7 لەبەردەم یەزدانی باڵادەست بێدەنگ بە، 
\q2 چونکە ڕۆژی یەزدان\f + \fr 1:7 \ft ڕۆژی سزادانی گوناهباران و ڕزگارکردنی گەلی خودا.‏\f* نزیکە. 
\q1 یەزدان قوربانی ئامادە کردووە، 
\q2 بانگکراوانی خۆی تەرخان دەکات. 
\b  
\q1  
\v 8 لە ڕۆژی قوربانی یەزدان 
\q2 میران سزا دەدەم 
\q2 هەروەها کوڕانی پاشا و 
\q1 هەموو ئەوانەی جلوبەرگی نامۆیان لەبەرە. 
\q1  
\v 9 لەو ڕۆژەدا هەموو ئەوانە سزا دەدەم 
\q2 کە خۆیان لەوە دەپارێزن پێ لە سەکۆی دەروازەکە بنێن،\f + \fr 1:9 \ft باز دەدەن: نەریتێکی بتپەرستانە، بڕوانە \xt یەکەم ساموئێل 5‏:5‏\ft ‏.‏\f* 
\q1 ئەوانەی پەرستگای خوداوەندەکانیان پڕ دەکەن 
\q2 لە ستەم و فێڵبازی. 
\b  
\q1  
\v 10 یەزدان دەفەرموێت: «لەو ڕۆژەدا، 
\q2 دەنگی هاوار لە دەروازەی ماسی بەرزدەبێتەوە، 
\q2 ناڵەناڵ لە ”گەڕەکی نوێ“ دێت، 
\q2 دەنگی تێکشکانێکی گەورەش لە گردەکانەوە. 
\q1  
\v 11 ئەی دانیشتووانی ناوچەی مەکتیش\f + \fr 1:11 \ft گەڕەکێک بووە لەناو بازاڕی گەورەی ئۆرشەلیم.‏\f* بناڵێنن، 
\q2 هەموو بازرگانەکانتان لەناودەچن، 
\q2 هەموو بازرگانەکانی زیو بنبڕ دەکرێن. 
\q1  
\v 12 لەو سەردەمەدا، بە چرا ئۆرشەلیم دەپشکنم و 
\q2 ئەو کەسانە سزا دەدەم کە لەخۆڕازین، 
\q2 ئەوانە وەک شەرابن بەسەر خڵتەکەیەوە، 
\q1 لە دڵی خۆیاندا دەڵێن: 
\q2 ”یەزدان نە چاکە دەکات و نە خراپە.“ 
\q1  
\v 13 ئەوانە سامانیان تاڵان دەکرێت، 
\q2 ماڵیان وێران دەبێت. 
\q1 ماڵ بنیاد دەنێن و 
\q2 تێیدا دانانیشن؛ 
\q1 ڕەز دەچێنن و 
\q2 لە شەرابەکەی ناخۆنەوە. 
\s1 ڕۆژی گەورەی یەزدان 
\q1  
\v 14 «ڕۆژی گەورەی یەزدان نزیکە، 
\q2 نزیکە و زۆر بە پەلەیە. 
\q1 هاواری ڕۆژی یەزدان تاڵ دەبێت، 
\q2 پاڵەوانە مەزنەکە نەعرەتەی جەنگ دەکێشێت. 
\q1  
\v 15 ئەو ڕۆژە ڕۆژی تووڕەییە، 
\q2 ڕۆژی تەنگانە و ئازارە، 
\q1 ڕۆژی کاولبوون و وێرانییە، 
\q2 ڕۆژی تاریکی و ئەنگوستەچاوە، 
\q2 ڕۆژی هەور و تەمی چڕە، 
\q1  
\v 16 ڕۆژی کەڕەنا لێدان و نەعرەتەی جەنگە 
\q2 لە دژی شارە قەڵابەندەکان و 
\q2 لە دژی قوللە بەرزەکان. 
\b  
\q1  
\v 17 «تەنگ بە مرۆڤ هەڵدەچنم، 
\q2 وەک کوێر بە پەلکوتان دەڕۆن، 
\q2 چونکە دەرهەق بە یەزدان گوناهیان کرد. 
\q1 ئینجا خوێنیان وەک خۆڵ دەڕژێت و 
\q2 هەناویشیان وەک زبڵ. 
\q1  
\v 18 نە زیو و نە زێڕەکەیان 
\q2 ناتوانن دەربازیان بکەن، 
\q2 لە ڕۆژی تووڕەیی یەزدان. 
\b  
\q1 «بە ئاگری ئیرەییەکەی\f + \fr 1:18 \ft ئیرەیی: واتای هەڵوێستی توندی خودا بەرامبەر بە بتپەرستی، چونکە خودا دەیەوێت تەنها ئەو بپەرسترێت.‏\f* 
\q2 هەموو زەوی هەڵدەلووشێت، 
\q1 چونکە لەناوچوونێکی کتوپڕ دروستدەکات 
\q2 بۆ هەموو دانیشتووانی زەوی.» 
\c 2  
\q1  
\v 1 ئەی نەتەوە بێ شەرمەکە، 
\q2 خۆت کۆبکەرەوە، خۆت کۆبکەرەوە، 
\q1  
\v 2 بەر لەوەی کاتی دیاریکراوتان لەدەست بچێت، 
\q2 بەر لەوەی ئێوە وەک پوشوپەڵاشی بەردەم باتان بەسەربێت، 
\q1 پێش ئەوەی گڕی تووڕەیی یەزدان بێتە سەرتان، 
\q2 پێش ئەوەی ڕۆژی تووڕەیی یەزدان بێتە سەرتان. 
\q1  
\v 3 ئەی هەموو بێفیزەکانی سەر زەوی، ڕوو لە یەزدان بکەن، 
\q2 ئێوە ئەوانەی حوکمەکانی ئەو جێبەجێ دەکەن. 
\q1 داوای ڕاستودروستی بکەن، داوای بێفیزی بکەن، 
\q2 بەڵکو لە ڕۆژی تووڕەیی یەزدان دابپۆشرێن. 
\s1 سەبارەت بە فەلەستیە 
\q1  
\v 4 غەزە چۆڵ دەکرێت و 
\q2 ئەسقەلان وێران دەبێت، 
\q1 ئەشدۆد لە نیوەڕۆدا کاول دەکرێت و 
\q2 عەقرۆنیش ڕیشەکێش دەکرێت. 
\q1  
\v 5 قوڕبەسەر دانیشتووانی کەناری دەریا، 
\q2 نەتەوەی کریتییەکان! 
\q1 فەرمایشتی یەزدان لە دژی ئێوەیە، 
\q2 ئەی کەنعان، خاکی فەلەستییەکان، 
\q1 یەزدان دەفەرموێت: «لەناوت دەبەم، 
\q2 کەست ناهێڵمەوە.» 
\q1  
\v 6 کەناری دەریاش دەبێتە لەوەڕگا، 
\q2 دەبێتە شوێنی شوانەکان، بۆ پشتیری\f + \fr 2:6 \ft پشتیر: گەوڕ، شوێنێکی تایبەت بووە بە پەروەردەکردنی ئاژەڵ.‏\f* مەڕ. 
\q1  
\v 7 دەبێتە موڵکی پاشماوەی بنەماڵەی یەهودا، 
\q2 لەسەری دەلەوەڕێنن، 
\q2 ئێواران لە ماڵەکانی ئەسقەلان لادەدەن، 
\q1 چونکە یەزدانی پەروەردگاریان بەسەریان دەکاتەوە، 
\q2 ڕاپێچکراوەکانیان دەگەڕێنێتەوە. 
\s1 سەبارەت بە مۆئاب و عەمۆن 
\q1  
\v 8 «گوێم لە جنێوەکانی مۆئاب و 
\q2 قەشمەرییەکانی عەمۆنییەکان بوو، 
\q1 ئەوانەی جنێویان بە گەلەکەم دا و 
\q2 هەڕەشەیان لە خاکەکەیان کرد.» 
\q1  
\v 9 یەزدانی سوپاسالار، خودای ئیسرائیل دەفەرموێت: 
\q2 «بە گیانی خۆم، لەبەر ئەوە 
\q1 بێگومان مۆئاب وەک سەدۆمی لێدێت، 
\q2 عەمۆنییەکانیش وەک عەمۆرا، 
\q1 هەتاهەتایە دەبێتە شوێنی گەزگەزکە و 
\q2 چاڵی خوێ و وێرانییە. 
\q1 پاشماوەی گەلەکەم تاڵانیان دەکەن و 
\q2 پاشماوەی نەتەوەکەم دەبنە میراتگری خاکەکەیان.» 
\b  
\q1  
\v 10 لە بەرامبەر لووتبەرزییان ئەمەیان بەسەردێت، 
\q2 لەبەر جنێودان و سووکایەتییان بە گەلی یەزدانی سوپاسالار. 
\q1  
\v 11 یەزدان ترسناک دەبێت بۆیان، 
\q2 چونکە هەموو خوداوەندەکانی سەر زەوی تێکدەشکێنێت. 
\q1 هەموو خەڵک هەریەکە و لە شوێنی خۆیەوە کڕنۆشی بۆ دەبەن، 
\q2 هەریەکە و لە خاکەکەی خۆی. 
\s1 سەبارەت بە کوش 
\q1  
\v 12 «ئێوەش ئەی کوشییەکان\f + \fr 2:12 \ft کوش وڵاتێک بووە لە سەرووی ڕووباری نیل.‏\f*، 
\q2 بە شمشێری من دەکوژرێن.» 
\s1 سەبارەت بە ئاشور 
\q1  
\v 13 دەستی بۆ باکوور درێژ دەکات و 
\q2 ئاشوریش لەناودەبات، 
\q1 نەینەوا وێران دەکات 
\q2 وەک بیابان وشک دەبێت. 
\q1  
\v 14 ئینجا لەوێدا مێگەلەکان خۆیان دەکێشنەوە، 
\q2 هەموو جۆرە ئاژەڵێک. 
\q1 هەم کوندەپەپووی بیابان و هەم بایەقووش، 
\q2 لەسەر ستوونەکانی شەو بەسەردەبەن، 
\q1 لە پەنجەرەکانیەوە دەنگیان دێت، 
\q2 کاول بوون لە بەردەرگایە، 
\q2 چونکە دار ئورزەکانی ڕووت کراونەتەوە. 
\q1  
\v 15 ئەمە شارە دڵخۆشەکەیە 
\q2 کە لە ئاسوودەییدا دەژیا. 
\q1 ئەوەی لە دڵی خۆیدا دەیگوت: 
\q2 «تەنها من، کەسی دیکە هاوتای من نییە.» 
\q1 ئاخ، چۆن وێران بوو، 
\q2 لانەی گیانلەبەران! 
\q1 هەموو ئەوانەی بەلایدا تێدەپەڕن گاڵتەی پێ دەکەن و 
\q2 فیکە لێدەدەن. 
\c 3  
\s1 داهاتووی ئۆرشەلیم 
\q1  
\v 1 قوڕبەسەر شاری ستەمکارەکان 
\q2 ئەوەی یاخی بووە و گڵاوە! 
\q1  
\v 2 گوێی لە کەس نەگرت، 
\q2 تەمبێ نەبوو، 
\q1 پشتی بە یەزدان نەبەست، 
\q2 لە خودای خۆی نزیک نەبووەوە. 
\q1  
\v 3 میرەکانی ناوەڕاستی شێرن دەنەڕێنن، 
\q2 دادوەرەکانی گورگی ئێوارانن، 
\q2 هیچ بۆ بەیانی ناهێڵنەوە. 
\q1  
\v 4 پێغەمبەرەکانی لەخۆبایین، 
\q2 خەڵکانێکی ناپاکن، 
\q1 کاهینەکانی پیرۆزگایان گڵاو کردووە، 
\q2 تەوراتیان پێشێل کردووە. 
\q1  
\v 5 یەزدان لەو شارەدا ڕاستودروستە، 
\q2 ناڕەوایی ئەنجام نادات. 
\q1 بەیانییان دادپەروەرییەکەی پەیڕەو دەکات، 
\q2 کەموکوڕی تێدا نییە، 
\q2 بەڵام ستەمکار واتای سەرشۆڕی نازانێت. 
\s2 تۆبەنەکردنی ئۆرشەلیم 
\q1  
\v 6 «نەتەوەکانم ڕیشەکێش کرد، 
\q2 قەڵاکانیان وێران بوون، 
\q1 شەقامەکانی ئەوانم چۆڵ کرد، 
\q2 بەبێ ڕێبوارن، 
\q1 شارەکانیان وێران کران، 
\q2 بەبێ مرۆڤن، بێ دانیشتووان. 
\q1  
\v 7 ئینجا سەبارەت بە ئۆرشەلیم گوتم: 
\q2 ”بێگومان ئیتر لێم دەترسیت و 
\q2 تەمبێ دەبیت!“ 
\q1 هەتا نشینگەکەی ڕیشەکێش نەکرێت، 
\q2 هەموو سزای خۆم بەسەریدا ناسەپێنم. 
\q1 بەڵام چالاک بوون 
\q2 لە گەندەڵکردنی هەموو کردەوەکانیان.» 
\q1  
\v 8 یەزدان دەفەرموێت: «لەبەر ئەوە چاوەڕێم بکەن، 
\q2 هەتا ئەو ڕۆژەی هەڵدەستم بۆ شایەتیدان، 
\q1 چونکە بڕیارم دا نەتەوەکان کۆبکەمەوە، 
\q2 پاشایەتییەکان خڕبکەمەوە، 
\q1 بۆ ئەوەی هەڵچوونم بەسەریاندا هەڵبڕێژم، 
\q2 هەموو گڕی تووڕەییم، 
\q1 بە ئاگری ئیرەییم 
\q2 هەموو زەوی هەڵدەلووشێت. 
\s1 چاکسازی پاشماوەی ئیسرائیل 
\q1  
\v 9 «ئینجا لێوی هەموو گەلان پاک دەکەمەوە، 
\q2 هەتا هەموویان بە ناوی یەزدانەوە نزا بکەن، 
\q2 تاکو هاوشانی یەکتر خزمەتی بکەن. 
\q1  
\v 10 لەوبەری ڕووبارەکانی کوشەوە 
\q2 ئەوانەی دەمپەرستن، گەلە پەرتوبڵاوکراوەکەم، 
\q2 دیارییەکانم پێشکەش دەکەن. 
\q1  
\v 11 لەو ڕۆژەدا بەهۆی کردەوەکانت سەرشۆڕ نابیت 
\q2 کە پێیان لە من یاخی بوویت، 
\q1 چونکە من لەم شارە دایاندەماڵم، 
\q2 ئەوانەی بە لووتبەرزییان دڵخۆشن. 
\q1 ئیتر ناگەڕێیتەوە بۆ سەر لووت بەرزی 
\q2 لە کێوی پیرۆزم. 
\q1  
\v 12 بەڵام گەلێکت تێدا دەهێڵمەوە 
\q2 سادە و ساکار، 
\q2 پشت بە ناوی یەزدان دەبەستێت. 
\q1  
\v 13 پاشماوەی ئیسرائیلیش چیدی خراپە ناکەن، 
\q2 درۆ ناکەن، 
\q2 لە دەمیاندا زمانی هەڵخەڵەتێنەر نامێنێت، 
\q1 چونکە بە ئاسوودەیی دەخۆن و ڕادەکشێن، 
\q2 کەسیش نییە بیانترسێنێت.» 
\b  
\q1  
\v 14 ئەی سییۆنی کچ، گۆرانی بڵێ، 
\q2 ئەی ئیسرائیل، هاواری خۆشی بکە! 
\q1 بە هەموو دڵتەوە شادمان و دڵخۆشبە، 
\q2 ئەی ئۆرشەلیمی کچ! 
\q1  
\v 15 یەزدان سزاکەی تۆی داماڵی، 
\q2 دوژمنەکەت کشایەوە. 
\q1 یەزدان، پاشای ئیسرائیل، لەگەڵ تۆیە، 
\q2 جارێکی دیکە لە خراپە ناترسیت. 
\q1  
\v 16 لەو ڕۆژەدا بە ئۆرشەلیم دەگوترێت: 
\q2 «ئەی سییۆن مەترسە، 
\q2 دەستت شل مەکە. 
\q1  
\v 17 یەزدانی پەروەردگارت لەگەڵتدایە، 
\q2 لە ڕزگارکردن قارەمانە. 
\q1 بە شادییەوە پێت دڵخۆش دەبێت، 
\q2 لەناو خۆشەویستییەکەی دەتبووژێنێتەوە، 
\q2 بە گۆرانییەوە پێت شاد دەبێت.» 
\b  
\q1  
\v 18 «ئەوانەی بۆ نەمانی جەژن دەگریێن 
\q2 لە تۆ دایاندەماڵم، 
\q2 لەمەودوا شەرمەزاری هەڵناگریت. 
\q1  
\v 19 لەو کاتەدا من سزایان دەدەم 
\q2 هەموو ئەوانەی زەلیلیان کردیت؛ 
\q1 شەلەکە ڕزگار دەکەم و 
\q2 ئەوانەی دوورخراوبوونەوە کۆیان دەکەمەوە. 
\q1 ستایش و ناوبانگیان پێ دەبەخشم 
\q2 لە هەموو خاکێک کە شەرمەزار بوون. 
\q1  
\v 20 لەو کاتەدا کۆتان دەکەمەوە، 
\q2 لەو کاتەدا دەتانگەڕێنمەوە خاکی خۆتان. 
\q1 ستایش و ناوبانگتان پێ دەبەخشم 
\q2 لەنێو هەموو گەلانی زەوی، 
\q1 کاتێک ڕاپێچکراوەکانتان و بەختیاریتان 
\q2 لەبەرچاوتان دەگەڕێنمەوە.» 
\q4 ئەوە فەرمایشتی یەزدانە.