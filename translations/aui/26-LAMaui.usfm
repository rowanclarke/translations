\id LAM - Anuki 
\h Nuwapoya Ayidi 
\toc1 Nuwapoya Ayidi 
\toc2 Nuwapoya Ayidi 
\mt1 Nuwapoya Ayidi  
\mt2 (Lamentations)  
\is1 Wonawiiakowa  
\ip Mmko bukana na Isrel damdi yadi wiinuwabero ghamana raghanine, kadi aviya bodu 586 BC kamone sipiika da Jerusalem siviberona, bi kate kana wawaya da kana sawara miimiisedi teya sikawara na yisisiyeni. Bi getayakovi da iiyabo mmko bukana igirumi, bi wawaya mududi sanoghonoghosi da augunai Jerimaiya igirumi.  
\c 1  
\s1 Nuwavisi Jerusalem kamone  
\q1
\v 1 Naghove, na wawaya korotodi Jerusalem kamone,  
\q2 bi katana noko kwanatuna ikwebu.  
\q1 Roro kubura debane na kwanatu tupadi kamodiye,  
\q2 na touna kwanatu maragasina tana,  
\q1 bi katana tanaduma ware wasike kwabukwaburina naboni.  
\q2 Roro na touna ware kiiwawo wasikena naboni,  
\q2 bi katana touna wiibagubagurana.   
\b  
\q1
\v 2 Nubabasuve na yaduu raghani,  
\q2 matadoga mayiyinagha sitototo sayowogha.  
\q1 Kana tomotomogha tupadi subukwari kuyoveni,  
\q2 gerubana siniororogha mayenina.  
\q1 Turaturana sigiyaguveni bi nuwanuwadi sipughu touna biidi  
\q2 da katana toudi na kana aviya.   
\b  
\q1
\v 3 Aviya sigeghomiiri da Jiuda damdi siburavidi bi sikabidi sinaghotaveyana,  
\q2 bi situpedi da yadi bagubagurana bi nuwapoya ghamadi debadiye sitoura.  
\q1 Katana toudi dam wiibata yadi kubure samakamake,  
\q2 bi getana gawara meme siyabanani da siyiyawiitaveyanana.  
\q1 Kadi aviya sigeghomiiri da sirukwavinidi bi sikabitawatawanidi,  
\q2 toudi gerubana da kadi aviya gwabidima sinaverataveyanana.   
\b  
\q1
\v 4 Keda sanono Zaiyonma na sibubu,  
\q2 kiiravine getana iiyabo gabudara kabikabikuwayidiye  
\q1 namagha iyanono God kabepepina kiiravine.  
\q2 Getana iiyabo kwanatu matamketadigha iyarughurughuna,  
\q1 bi \k prist\k* ere nuwaberodi sakabikabida.  
\q2 Wasiwasike woudi saduudu,  
\q2 bi kwanatu kana wawaya tupadi kabikwarakwara ghamaghamadi sabanabanana.   
\b  
\q1
\v 5 Katana kadi aviya sigeghomiiri da sibadedi,  
\q2 bi sawara tupadi sakayokayovedina gwabidiye.  
\q1 Yawe God igeghomiiri da Jerusalem  
\q2 yana tamumu peyaridi kiiravidiye na aro ivereni.  
\q1 Aviya sigeghomiiri da natunatudi siburavidi  
\q2 bi sikabidi sinagho kubura rabarabae.   
\b  
\q1
\v 6 Naghove, Jerusalem na maragasina bi wiinuwakayowanina,  
\q2 bi katana nokodi tupadi sikovi.  
\q1 Kana babada na ware ribiribi kadi waghawagha diya\f + \fr 1:6 \ft Diya na ribiribi tana bi touna rei yakamkam, bi wawaya touna ribiribina sayebayebayeni iyuwa kiiravine.\f* vitonana sirabobo  
\q2 na kam sininoghana naboni.  
\q1 Toudi panapana irouvidi da sinoganoga,  
\q2 gerubana kadi aviya gwabidima sinaverataveyanana.   
\b  
\q1
\v 7 Katana Jerusalem damdi kabikwarakwara sabanabanana,  
\q2 da yadi wiikedakeda kubura mududiye,  
\q1 na yadi noghota yaveramagha da naghove sawara miisedi tupadi rapediye na sanoghosidi.  
\q2 Wasina bi aviya sipiika da siburavidi,  
\q1 bi getana iiyabo da iyiwiitedi.  
\q2 Nokodi aviya kwanatuna sikitani,  
\q2 bi raghanina siyibero na simaniveni.   
\c 3  
\s1 Wiitumaghana God yana wiiwiita kamone  
\q1
\v 19 Raghanina yagu kabikwarakwara,  
\q3 da yagu wiikedakeda kubura rabarabae anoghosidi,  
\q2 na noko damina ware rarima kawaororana naboni.   
\q1
\v 20 Nokodi sawara anoghosidi,  
\q2 na nuwanuwagu yabero kirakii.   
\q1
\v 21 Bi gegha da yagu noghota yaveramagha da Yawe God anoghosi  
\q2 na wiigeruwana adagumayeni.   
\b  
\q1
\v 22 Yawe God yana nuwamonika kiiravidaye na getughurinana,  
\q2 bi yana wiinuwaghaneyana gegha iyakovikovina;   
\q1
\v 23 didibara patepatena yanavereyana na yanono wiikarukaru,  
\q2 touna nonowa yaberabera ware metagha ivisuwonana naboni.   
\q1
\v 24 Tagumani awonena mayegu bo, “Yawe God na nonowa gwabiguve,  
\q3 na getana awaki ayakayokayoveni,  
\q2 noko kiiravine tagu anitumaghanena kirakiiyeni.”   
\b  
\q1
\v 25 Raghanina wawaya yadi tumagha Yawe God gwabine bi sinoyeni,  
\q2 na touna miisena yabera toudi biiyadi.   
\q1
\v 26 Na noko biidi imiise da touda tanikoyakoyagha wiiraborabobo touna kiiravine,  
\q2 basuna touna iniyawiida.   
\q1
\v 27 Imiise bi touda akowa tana kabi da Yawe God tanakabisisireni,  
\q2 raghanina touda patana woudayena.   
\b  
\q1
\v 28 Raghanina Yawe God piropiro debadae yatoura,  
\q2 na touda duma tayamakeyowogha tayiraborabobo,   
\q2
\v 29 touda tayituwapore oghogheyana,  
\q2 bi mayiyida siyayowogha dobodobove na,  
\q3 meboda God iyiwiiteda.   
\q1
\v 30 Raghanina wawaya tana nawanawam inarouvi, bo inisisiya berovem,  
\q2 na kiwaghasineni da awaki ibera.   
\b  
\q1
\v 31 Kiiravine Yawe God geyana wawaya iyamiimiiri kubutena wagiyedina.   
\q1
\v 32 Raghani mududiye na kabikwarakwara yapiikeni,  
\q2 bi kate bada wiinuwanuwaneyana yidebeni touda biiyadi,  
\q2 basuna yana nuwamonika touda kiiravidaye na getughurinana.   
\q1
\v 33 Wiisuwona, raghani mududiye na sinivisi da nuwapoya yapiikedi wawaya biiyadi,  
\q2 bi gegha, touna geiyinuwamiise da nokodi bera inaberana.   