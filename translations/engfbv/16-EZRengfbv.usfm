\v 8 Furthermore, \w this|strong="H1791"\w* \w is|strong="H1768"\w* \w my|strong="H1768"\w* \w decree|strong="H2942"\w* \w as|strong="H1768"\w* \w to|strong="H2942"\w* \w what|strong="H1768"\w* \w you|strong="H1768"\w* \w are|strong="H1768"\w* \w to|strong="H2942"\w* \w do|strong="H5648"\w* \w for|strong="H1768"\w* \w these|strong="H4481"\w* \w Jewish|strong="H3062"\w* leaders regarding \w the|strong="H4481"\w* \w rebuilding|strong="H1124"\w* \w of|strong="H4481"\w* \w this|strong="H1791"\w* \w Temple|strong="H1005"\w* \w of|strong="H4481"\w* God. \w The|strong="H4481"\w* full expense involved \w is|strong="H1768"\w* \w to|strong="H2942"\w* \w be|strong="H1934"\w* \w paid|strong="H3052"\w* \w from|strong="H4481"\w* \w royal|strong="H4430"\w* income, \w the|strong="H4481"\w* \w tribute|strong="H4061"\w* \w of|strong="H4481"\w* \w the|strong="H4481"\w* province west \w of|strong="H4481"\w* \w the|strong="H4481"\w* Euphrates, \w so|strong="H1768"\w* \w that|strong="H1768"\w* \w the|strong="H4481"\w* work \w will|strong="H1768"\w* \w not|strong="H3809"\w* \w be|strong="H1934"\w* delayed.
