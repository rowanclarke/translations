\v 10 \w Then|strong="H1571"\w* \w your|strong="H3605"\w* \w other|strong="H3605"\w* \w soldiers|strong="H2428"\w*, \w even|strong="H1571"\w* \w if|strong="H3588"\w* \w they|strong="H3588"\w* \w are|strong="H1121"\w* \w as|strong="H1571"\w* fearless [SIM, IDM] \w as|strong="H1571"\w* lions, \w they|strong="H3588"\w* \w will|strong="H3478"\w* become \w very|strong="H3045"\w* afraid. \w Do|strong="H3605"\w* \w not|strong="H3045"\w* forget \w that|strong="H3588"\w* \w everyone|strong="H3605"\w* \w in|strong="H3478"\w* \w Israel|strong="H3478"\w* \w knows|strong="H3045"\w* \w that|strong="H3588"\w* \w your|strong="H3605"\w* \w father|strong="H1121"\w* \w is|strong="H1931"\w* \w a|strong="H3068"\w* \w great|strong="H1368"\w*/\w strong|strong="H2428"\w* soldier, \w and|strong="H1121"\w* \w that|strong="H3588"\w* \w the|strong="H3605"\w* \w soldiers|strong="H2428"\w* \w who|strong="H3605"\w* \w are|strong="H1121"\w* \w with|strong="H3045"\w* \w him|strong="H3605"\w* \w are|strong="H1121"\w* \w also|strong="H1571"\w* \w very|strong="H3045"\w* \w brave|strong="H2428"\w*/courageous.
\p 
\v 11 “\w So|strong="H1980"\w* \w what|strong="H3588"\w* \w I|strong="H3588"\w* suggest \w is|strong="H3478"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w* summon \w all|strong="H3605"\w* \w the|strong="H3605"\w* Israeli soldiers, \w from|strong="H6440"\w* \w Dan|strong="H1835"\w* \add in the far north\add* \w to|strong="H5704"\w* Beersheba \add in the far south\add*. \w They|strong="H3588"\w* \w will|strong="H3478"\w* \w be|strong="H3478"\w* \w as|strong="H5704"\w* \w many|strong="H7230"\w* \w as|strong="H5704"\w* \w the|strong="H3605"\w* grains \w of|strong="H6440"\w* \w sand|strong="H2344"\w* \w on|strong="H5921"\w* \w the|strong="H3605"\w* \w seashore|strong="H3220"\w* [HYP]. \w And|strong="H1980"\w* \w then|strong="H1980"\w* \w you|strong="H3588"\w* \w yourself|strong="H5921"\w* \w lead|strong="H1980"\w* \w us|strong="H5921"\w* \w into|strong="H1980"\w* \w the|strong="H3605"\w* \w battle|strong="H7128"\w*.
