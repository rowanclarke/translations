\p 
\v 32 \w Pero|strong="H3588"\w* \w Jonadab|strong="H3122"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Simea, hermano \w de|strong="H5921"\w* \w David|strong="H1732"\w*, dijo: \w No|strong="H3588"\w* piense \w mi|strong="H5921"\w* \tl ʼadón\tl* \w que|strong="H3588"\w* \w mataron|strong="H4191"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* jóvenes \w hijos|strong="H1121"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*, \w pues|strong="H3588"\w* solo \w murió|strong="H4191"\w* Amnón, \w porque|strong="H3588"\w* Absalón \w lo|strong="H5921"\w* decidió \w desde|strong="H5921"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w cuando|strong="H3588"\w* Amnón violó \w a|strong="H3068"\w* \w su|strong="H3588"\w* hija Tamar.
\v 33 \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, \w que|strong="H3588"\w* mi \tl ʼadón\tl* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w no|strong="H3588"\w* acepte \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w corazón|strong="H3820"\w* \w el|strong="H3588"\w* rumor \w que|strong="H3588"\w* \w dice|strong="H1697"\w* \w que|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* del \w rey|strong="H4428"\w* \w murieron|strong="H4191"\w*, \w porque|strong="H3588"\w* solo \w murió|strong="H4191"\w* Amnón.
\p 
\v 34 Absalón \w huyó|strong="H1272"\w*.
\p El esclavo \w centinela|strong="H6822"\w* \w levantó|strong="H5375"\w* los \w ojos|strong="H5869"\w* y \w vio|strong="H7200"\w* \w que|strong="H5971"\w* \w mucha|strong="H7227"\w* \w gente|strong="H5971"\w* llegaba \w por|strong="H1870"\w* el \w camino|strong="H1870"\w* \w de|strong="H5971"\w* la región montañosa \w que|strong="H5971"\w* \w estaba|strong="H2009"\w* detrás \w de|strong="H5971"\w* él.
\p 
\v 35 \w Jonadab|strong="H3122"\w* dijo \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: ¡\w Aquí|strong="H2009"\w* llegan \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* del \w rey|strong="H4428"\w*! Según la \w palabra|strong="H1697"\w* \w de|strong="H1121"\w* tu esclavo, \w así|strong="H3651"\w* \w sucedió|strong="H1961"\w*.
\p 
\v 36 \w Aconteció|strong="H1961"\w* \w que|strong="H1571"\w* \w cuando|strong="H1571"\w* \w él|strong="H3605"\w* \w acabó|strong="H3615"\w* \w de|strong="H1121"\w* \w hablar|strong="H1696"\w*, \w ciertamente|strong="H1571"\w* llegaron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* del \w rey|strong="H4428"\w*, \w alzaron|strong="H5375"\w* su \w voz|strong="H6963"\w* \w y|strong="H1571"\w* \w lloraron|strong="H1058"\w*. \w También|strong="H1571"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w y|strong="H1571"\w* \w todos|strong="H3605"\w* sus esclavos \w lloraron|strong="H1058"\w* \w muy|strong="H3966"\w* \w amargamente|strong="H1058"\w*.
\p 
\v 37 \w David|strong="H4428"\w* lloraba \w por|strong="H5921"\w* su \w hijo|strong="H1121"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w días|strong="H3117"\w*. Absalón \w huyó|strong="H1272"\w* \w y|strong="H5921"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* Talmai, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Amiud, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Gesur.
\p 
\v 38 Absalón \w huyó|strong="H1272"\w* y \w se|strong="H1961"\w* \w fue|strong="H1961"\w* \w a|strong="H3068"\w* Gesur, y \w estuvo|strong="H1961"\w* \w allí|strong="H8033"\w* \w tres|strong="H7969"\w* \w años|strong="H8141"\w*.
\v 39 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* anhelaba ver \w a|strong="H3068"\w* Absalón, \w pues|strong="H3588"\w* ya estaba consolado \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w muerte|strong="H4191"\w* \w de|strong="H5921"\w* Amnón.
\c 14
\s1 El regreso de Absalón
\p 
\v 1 \w Entonces|strong="H3588"\w* \w Joab|strong="H3097"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Sarvia, \w entendió|strong="H3045"\w* \w que|strong="H3588"\w* \w el|strong="H5921"\w* \w corazón|strong="H3820"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w se|strong="H3045"\w* inclinaba \w hacia|strong="H5921"\w* Absalón.
\v 2 \w Joab|strong="H3097"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* Tecoa, \w tomó|strong="H3947"\w* \w de|strong="H5921"\w* \w allá|strong="H8033"\w* una mujer \w astuta|strong="H2450"\w* \w y|strong="H5921"\w* \w le|strong="H5921"\w* dijo: Finge \w ahora|strong="H4994"\w* \w que|strong="H4994"\w* \w estás|strong="H2088"\w* \w de|strong="H5921"\w* luto, \w y|strong="H5921"\w* viste ropas \w de|strong="H5921"\w* duelo. \w No|strong="H1961"\w* \w te|strong="H5921"\w* unjas \w con|strong="H5921"\w* \w aceite|strong="H8081"\w*, \w más|strong="H5921"\w* bien aparenta ser una mujer \w que|strong="H4994"\w* hace \w tiempo|strong="H3117"\w* \w está|strong="H2088"\w* \w de|strong="H5921"\w* luto \w por|strong="H5921"\w* un \w muerto|strong="H4191"\w*.
\v 3 Vé \w al|strong="H4428"\w* \w rey|strong="H4428"\w* y háblale \w estas|strong="H2088"\w* \w palabras|strong="H1697"\w*. \w Y|strong="H3068"\w* \w Joab|strong="H3097"\w* colocó las \w palabras|strong="H1697"\w* en su \w boca|strong="H6310"\w*.
\p 
\v 4 \w La|strong="H5921"\w* mujer \w de|strong="H5921"\w* \w Tecoa|strong="H8621"\w* fue \w al|strong="H5921"\w* \w rey|strong="H4428"\w*, \w cayó|strong="H5307"\w* \w en|strong="H5921"\w* tierra \w sobre|strong="H5921"\w* su rostro, \w hizo|strong="H5307"\w* reverencia \w y|strong="H5921"\w* dijo: ¡Auxilio, oh \w rey|strong="H4428"\w*!
\p 
\v 5 El \w rey|strong="H4428"\w* le preguntó: ¿\w Qué|strong="H4100"\w* tienes?
\p \w Y|strong="H3068"\w* ella respondió: En verdad soy una mujer viuda, \w pues|strong="H4100"\w* mi esposo \w murió|strong="H4191"\w*.
\v 6 Tu esclava tenía \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w* y \w los|strong="H1121"\w* \w dos|strong="H8147"\w* pelearon \w en|strong="H5221"\w* \w el|strong="H1121"\w* \w campo|strong="H7704"\w*, y como no hubo alguien \w que|strong="H1121"\w* \w los|strong="H1121"\w* separara, \w el|strong="H1121"\w* uno \w hirió|strong="H5221"\w* al otro y lo \w mató|strong="H5221"\w*.
