\p \w Then|strong="H1961"\w* \w the|strong="H5414"\w* \w people|strong="H3808"\w* said, “\w This|strong="H5414"\w* \w is|strong="H4100"\w* \w what|strong="H4100"\w* \w we|strong="H3068"\w* \w want|strong="H3808"\w* \w to|strong="H4191"\w* \w do|strong="H4100"\w*. \w We|strong="H4191"\w* \w will|strong="H1961"\w* \w give|strong="H5414"\w* \w you|strong="H5414"\w* \w our|strong="H5414"\w* land \w and|strong="H3899"\w* \w ourselves|strong="H5414"\w*. \w Then|strong="H1961"\w* \w all|strong="H5414"\w* \w the|strong="H5414"\w* land \w that|strong="H5414"\w* \w belongs|strong="H1961"\w* \w to|strong="H4191"\w* \w us|strong="H5414"\w* \w will|strong="H1961"\w* \w belong|strong="H1961"\w* \w to|strong="H4191"\w* \w Pharaoh|strong="H6547"\w*. \w And|strong="H3899"\w* \w we|strong="H3068"\w* \w will|strong="H1961"\w* \w belong|strong="H1961"\w* \w to|strong="H4191"\w* \w Pharaoh|strong="H6547"\w* \w too|strong="H1571"\w*, \w we|strong="H3068"\w* \w will|strong="H1961"\w* \w become|strong="H1961"\w* \w his|strong="H5414"\w* workers. \w Then|strong="H1961"\w* \w you|strong="H5414"\w* \w give|strong="H5414"\w* \w us|strong="H5414"\w* \w food|strong="H3899"\w* \w to|strong="H4191"\w* \w eat|strong="H3899"\w* \w and|strong="H3899"\w* \w seeds|strong="H2233"\w* \w to|strong="H4191"\w* \w plant|strong="H5414"\w*, \w so|strong="H1961"\w* \w that|strong="H5414"\w* \w we|strong="H3068"\w* \w can|strong="H4100"\w* grow \w food|strong="H3899"\w* plants \w on|strong="H1961"\w* \w the|strong="H5414"\w* land \w again|strong="H1961"\w*. \w It|strong="H5414"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w like|strong="H1961"\w* \w we|strong="H3068"\w* \w are|strong="H5869"\w* paying \w for|strong="H5650"\w* \w that|strong="H5414"\w* \w food|strong="H3899"\w* \w and|strong="H3899"\w* \w those|strong="H6547"\w* \w seeds|strong="H2233"\w* \w with|strong="H3899"\w* \w ourselves|strong="H5414"\w* \w and|strong="H3899"\w* \w our|strong="H5414"\w* land. \w That|strong="H5414"\w* way, \w we|s