\v 8 Hlang he \w pakhat|strong="H0259"\w* bueng \w om|strong="H3426"\w* \w tih|strong="H9999"\w* a \w pabae|strong="H8145"\w* a om \w moenih|strong="H0369"\w*. \w Capa|strong="H1121"\w* \w neh|strong="H9999"\w* \w manuca|strong="H0251"\w* \w khaw|strong="H1571"\w* \w a|strong="H9909"\w* \w taengah|strong="H9997"\w* a om \w moenih|strong="H0369"\w*. Te \w dongah|strong="H9999"\w* \w a|strong="H9909"\w* \w thakthaenah|strong="H5999"\w* \w cungkuem|strong="H3605"\w* \w dongah|strong="H9997"\w* a \w bawtnah|strong="H7093"\w* om \w pawh|strong="H0369"\w*. \w A|strong="H9909"\w* \w mik|strong="H5869"\w*, \w a|strong="H9909"\w* \w mik|strong="H5869"\w* ah \w khuehtawn|strong="H6239"\w* khaw \w hah|strong="H7646"\w* \w pawh|strong="H3808"\w*. \w U|strong="H4310"\w* \w ham|strong="H9997"\w* nim \w thakthaenah|strong="H6001"\w* \w ka|strong="H0589"\w* om \w tih|strong="H9999"\w*, \w hnothen|strong="H2896"\w* \w lamloh|strong="H4480"\w* \w ka|strong="H9901"\w* \w hinglu|strong="H5315"\w* \w he|strong="H0853"\w* a \w vaitah|strong="H2637"\w*? \w He|strong="H2088"\w* \w khaw|strong="H1571"\w* a \w honghi|strong="H1892"\w* \w neh|strong="H9999"\w* \w boethae|strong="H7451"\w* \w bibi|strong="H6045"\w* coeng ni.  
\v 9 \w Pakhat|strong="H0259"\w* \w lakah|strong="H4480"\w* \w panit|strong="H8147"\w* he \w then|strong="H2896"\w*, \w amih|strong="H9908"\w* \w ham|strong="H9997"\w* tah \w a|strong="H9908"\w* \w thakthaenah|strong="H5999"\w* \w dongah|strong="H9996"\w* khaw \w thapang|strong="H7939"\w* \w then|strong="H2896"\w* \w om|strong="H3426"\w* coeng.  
