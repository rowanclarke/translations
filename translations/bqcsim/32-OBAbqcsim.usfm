\id OBA Obadiah in Boko, Ross Jones, 2/08 
\h Abadia 
\toc1 Abadia 
\toc2 Abadia 
\toc3 Abd 
\mt1 ABADIA 
\imt1 Yã́ pↄ́ kú láɛ bee guuↄ 
\ip Lá nɛ́naɛ beeá yã́ pↄ́ Lua ò Ɛdↄ̃uↄ (Esau buiↄ) yã́ musu làasoo pↄ́ aa kɛ̀ Isailiↄ (Esau dãuna Yakubu buiↄ) yã́ musu yã́i. Ɛdↄ̃uↄ zↄ̃lɛa ísida wiside saɛ gɛↄmidↄkĩi oi, ↄ̃ aaìↄ íbɛlɛsɛ ń Isailiↄ gↄↄpii. Gↄↄ pↄ́ wà zĩblè Yuda bùsuwa mɛ́ wà Yelusalɛũ sì, an íbɛlɛ gɛ̀ e a lɛ́waɛ. I kɛ kɛ́ aai mↄ dↄi ń gbɛ̃́ↄlɛo ado no, aa ń bùsu saalo sɛ̀ ń pↄ́ ũɛ, ↄ̃ aa gɛ̀ Yelusalɛũdeↄ pↄ́ↄ sɛ̀lɛ. 
\ip Wà lápi kɛ̃̀ Babilonideↄ Yelusalɛũ sia gbɛa e wàↄ gɛ́ Yesu Kilisi ii wɛ̃̀ 587. A guu ãnabi Abadia ò Ɛdↄũↄnɛ aa kaalɛ ń Isailiↄ ibɛɛ kĩniↄ sãnuɛ. Beewa à Isailiↄ nↄ̀sɛ nìninɛ́. Lua mɛ́ a yã́ gbɛzã o, a mↄ́ yã́kpalɛkɛi ń bui píio! 
\c 1  
\s1 Yãdaa Ɛdↄũↄla 
\p  
\v 1 Yã́ pↄ́ Abadia èn kɛ: 
\q1 Yã́ pↄ́ Dii Lua ò Ɛdↄũↄ\f + \fr 1.1 \ft Isa 34.5-17, 63.1-6, Zel 49.7-22, Eze 25.12-14, 35.1-15, Amↄ 1.11-12, Mal 1.2-5\f* musuɛ. 
\q1 Wa baomà à bↄ̀ Dii kĩ́i, 
\q1 à gbɛ̃́ zĩ̀ buiↄwa aà onɛ́: 
\q1 À fɛlɛ! Wà gɛ́ Ɛdↄũↄwa zĩu. 
\q1  
\v 2 Ɛdↄũↄ, à ma! 
\q1 Má tó à gↄ̃ kpɛɛ buiↄ guuɛ, 
\q1 wa sakaágu à kɛ zài. 
\q1  
\v 3 Á kàamai mɛ́ á sãsã. 
\q1 Á gbɛ̃́ pↄ́ a gbɛ kɛ̀ á kpɛ́ ũ 
\q1 á zↄ̃lɛu musumusuↄ, 
\q1 i o á sↄ̃ guu à mɛ, 
\q1 i gbɛ̃e e à fↄ̃ á bua à á nɛ́ zĩ́lɛo. 
\q1  
\v 4 Baa kɛ́ á da musumusu lán baɛwa, 
\q1 mɛ́ a á sakpɛ dà saanaↄ sↄ̀ↄu, 
\q1 má á bãɛ za weɛ. 
\q1 Ma Dii mámɛ má ò. 
\q1  
\v 5 Tó kpã́iↄ mɛ́ gɛ̃̀ázi gwã́, 
\q1 ge tó kpã́iwɛliwɛↄ sìázi yãa, 
\q1 pↄ́ pↄ́ an pↄ dↄwà ↄ̃ aa sɛ adoo lò? 
\q1 Tó vɛ̃ɛkↄzↄ̃zↄ̃naↄ mↄ̀ sì á búu sↄ̃, 
\q1 vɛ̃ɛ kↄ̃na ↄ̃ aa tóɛ́o lò? 
\q1 Kási á kaalɛɛ. 
\q1  
\v 6 Esau buiↄ, wa á pↄ́ↄ naaaɛ míↄ, 
\q1 wa á àizɛɛ pↄ́ ulɛaↄ sɛ́lɛ. 
\q1  
\v 7 Bui pↄ́ an lɛ́ doũánↄↄ á yá á bùsuu, 
\q1 gbɛ̃́ pↄ́ naánↄↄ á sã́sã, aai zĩblewá, 
\q1 gbɛ̃́ pↄ́ i ↄkãaaↄ filifilimbakpaɛ́, 
\q1 áↄ a yã́ dↄ̃o. 
\q1  
\v 8 Ma Dii ma mɛ̀, 
\q1 má Ɛdↄũ bui ↄ̃nↄnaↄ dɛdɛ gↄↄ bee, 
\q1 yãdↄ̃nae a gↄ̃ Esau gbɛ̀sĩsĩ musuo. 
\q1  
\v 9 Gili a gɛ̃ Temani nɛgↄ̃naↄgu, 
\q1 aa midɛ ḿpii Esau gbɛ̀sĩsĩdeↄ dɛdɛau. 
\q1  
\v 10 Á gↄ̃ ń wío, 
\q1 wi á midɛ, áↄ ku lↄo, 
\q1 yãpãsĩ pↄ́ á kɛ̀ 
\q1 á dãuna Yakↄbu buiↄnɛ yã́i. 
\q1  
\v 11 Kɛ́ buipãleↄ lɛ́ ń àizɛɛ sɛ́lɛ, 
\q1 kɛ́ bui zĩ̀lopiↄ gɛ̃̀ Yelusalɛũ, 
\q1 aalɛ líkpa a yã́ musu, 
\q1 á kú we lá á doũńnↄwaɛ. 
\q1  
\v 12 A maa yãa á dãuna buiↄ gwaa kɛɛ́ na an wɛtãgↄↄo. 
\q1 I kṹ á pↄ kɛ na Yudaↄ kaalɛgↄↄo, 
\q1 i kũ à yamↄsɛkpa an taasikɛapi guuo. 
\q1  
\v 13 A maa yãa à si ma gbɛ̃́ↄ wɛ̃́lɛu an yã'eapi guuo. 
\q1 I kũ an gwaa kɛɛ́ na an yã'eapi guuo, 
\q1 i kũ à ń àizɛɛ naaa an yã'eapi guuo, 
\q1  
\v 14 A maa yãa àↄ zɛa zɛnankpaau an gbɛ̃́ pↄ́ lɛ́ bàalɛ dɛa yã́io. 
\q1 I kũ à ń gbɛ̃́ pↄ́ bↄ̀ↄ kṹkũ à kpámá an wɛ́tɛ̃agↄↄpio. 
\q1  
\v 15 Ma fɛlɛa ń bui píio gↄↄ kà kãi, 
\q1 mí kɛɛ́ lá á kɛ̀nɛ́wa. 
\q1 Á yãkɛaↄ wi á musu. 
\q1  
\v 16 Lá a imì ma sĩ̀sĩ pↄ́ a kua adoa musu, 
\q1 màa bui píi a imi we zɛsai. 
\q1 Aa ma pↄkũmabↄbↄma ípi gbɛ̃, 
\q1 aai gↄ̃ lán wi ń i yãaowa. 
\q1  
\v 17 Má gbɛ̃́ↄ suaba Siↄna gbɛ musu. 
\q1 Aↄ dɛ ma pↄ́ ũ, 
\q1 Yakↄbu buiↄ i ɛa ń pↄ́ sí. 
\q1  
\v 18 Yakↄbu buiↄ aaↄ dɛ lán tɛ́wa, 
\q1 Yosɛfu buiↄ aaↄ dɛ lán tɛ́vuawa, 
\q1 Esau buiↄ iↄ dɛ lán sɛ̃̀ giiwa. 
\q1 Aa kũ Esau buipiↄwaɛ míↄmiↄ, 
\q1 an gbɛ̃e a bↄo. 
\q1 Ma Dii mámɛ má ò. 
\q1  
\v 19 Ma gbɛ̃́ pↄ́ kú Nɛgɛvɛↄ i gↄ̃ Esau gbɛ̀sĩsĩↄ vĩ, 
\q1 an gusalaladeↄ i Filitɛ̃ↄ bùsu sí 
\q1 ń Ɛflaiũ bùsuo ń Samali bùsuo. 
\q1 Bɛ̃yãmɛɛ buiↄ sↄ̃ aai gↄ̃ Galada bùsu vĩ. 
\q1  
\v 20 Isaili zĩ̀zↄↄ i gↄ̃ Kanaa bùsu vĩ e za Salɛpa, 
\q1 Yelusalɛũ zĩ̀zↄ pↄ́ kú Sefalaↄ i gↄ̃ Nɛgɛvɛ wɛ̃́lɛↄ vĩ. 
\q1  
\v 21 Suabanaↄ dɛdɛ Siↄna gbɛ̀sĩsĩwa, 
\q1 aai yã́kpalɛkɛ ń Esau gbɛ̀sĩsĩdeↄ, 
\q1 kpala i gↄ̃ Diiɛ.