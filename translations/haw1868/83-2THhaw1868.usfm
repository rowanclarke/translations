\id 2TH  
\h Tesalonike II. 
\toc1 Tesalonike II. 
\toc2 Tesalonike II. 
\toc3 Tesalonike II. 
\mt1 Tesalonike II.  
\c 1  
\s1 O KA EPISETOLE  
\q1
\v 1 NA Paulo aku, a me Silevano, a me Timoieo, i ka ekalesia o ko Tesalonike, iloko o ke Akua o ko kakou Makua, a me ka Haku Iesu Kristo:   
\q1
\v 2 Ia oukou ke aloha, a me ka malu, mai ke Akua mai o ko kakou Makua, a me ka Haku Iesu Kristo.   
\b  
\q1
\v 3 E pono no makou e hoomaikai mau aku i ke Akua no oukou, e na hoahanau; he mea maikai no ia, no ka ulu nui ana o ko oukou paulele, a o ke aloha o oukou a pau loa, ua mahuahua ae ia i kekahi i kekahi.   
\q1
\v 4 Oia ka makou e mahalo ai ia oukou, iloko o na ekalesia o ke Akua, no ko oukou ahonui, a me ko oukou manao kupaa i ko oukou hoomaauia mai, a me na ehaeha a pau a oukou e hoomanawanui ai.   
\q1
\v 5 O ka hoailona akaka ia o ka hoopai pono ana mai o ke Akua, i manaoia mai oukou he poe pono no ke aupuni o ke Akua, no ko oukou mea i hoinoiai.   
\q1
\v 6 He mea pono no hoi ia i ke Akua ke hoihoi i ka poino i ka poe i hoopoino mai ia oukou;   
\q1
\v 7 A ia oukou hoi ka poe i hoopoinoia, i ka hoomaha pu me makou, i ka wa e hoikeia mai ai o ka Haku o Iesu, mai ka lani mai, me kona poe anela mana,   
\q1
\v 8 Me ko ahi e lapalapa ana, e hoopai ana i ka make maluna o ka poe ike ole i ke Akua, a me ka malama ole i ka euanelio o ko kakou Haku o Iesu Kristo:   
\q1
\v 9 O lakou ke hoopaiia'na i ka make mau loa, mai ke alo mai o ka Haku a me kona mana nani;   
\q1
\v 10 Ia la, i kona hiki ana mai e hoonaniia'ku ai e kona poe hoano a pau, a e mahaloia aku ai iwaena o ka poe a pau i manaoio ia ia, (no ka mea, ua manaoioia mai ka makou hoike ana e oukou.)   
\q1
\v 11 Nolaila hoi makou i pule mau aku ai no oukou, i manao mai ai ko kakou Akua ia oukou he poe pono e hoopomaikaiia, a e hooko mai oia i ke aloha a pau o kona maikai, a me ka hana o ka manaoio me ka mana;   
\q1
\v 12 I hoonaniia'ku ka inoa o ko kakou Haku o Iesu Kristo, iloko o oukou, a o oukou hoi iloko ona, mamuli o ke aloha ana mai o ko kakou Akua, a me ka Haku Iesu Kristo.   
\c 2  
\b  
\q1
\v 1 KE nonoi aku nei makou ia oukou, e na hoahanau, no ka hiki ana mai o ko kakou Haku o Iesu Kristo, a me ko kakou akoakoa ana aku io na la;   
\q1
\v 2 Mai hoonaue koke oukou i ko oukou manao, mai pihoihoi i kekahi uhane, a i kekahi olelo, a i kekahi episetole paha a makou aku, me he mea e hiki koke mai ana la ka la o Kristo.   
\q1
\v 3 Mai puni oukou i kekahi i kela mea a i keia mea; no ka mea, e hiki e mai ana no mamua ka haule ana, a e hoikeia'e hoi ua kanaka la o ka hewa, ke keiki o ka make;   
\q1
\v 4 O ka mea i ku e mai, a hookiekie ae la ia ia iho maluna o na mea a pau i kapaia he Akua, a me ka mea i hoomanaia; oia hoi, me he Akua la e noho ana ia iloko o ka luakini o ke Akua, e hoike ana ia ia iho oia ke Akua.   
\q1
\v 5 Aole anei oukou i hoomanao i ko'u hai ana'ku ia oukou i keia mau mea i ka wa i noho pu ai au me oukou?   
\q1
\v 6 A ke ike nei hoi oukou i ka mea alalai no kona ikea ana mai i kona manawa.   
\q1
\v 7 No ka mea, ke hooikaika nei ka pohihihi o ua hewa la; aka, o ka mea alalai, e keakea aku ana no ia a hiki i kona wa e laweia'ku ai.   
\q1
\v 8 Alaila, e hoikeia mai ua Hewa la, o ka ka Haku ia e kinai aku ai me ka ha o kona waha, a e luku ai hoi me ka olinolino nui o kona hiki ana mai.   
\q1
\v 9 O ka hiki ana mai o ua mea la, mamuli no ia o ka Satana hana ana, me ka mana a pau, a me na hoailona, a me na mea kupanaha hoopunipuni;   
\q1
\v 10 A me kela hoowalewale ana, a me keia hoowalewale ana a pau ma ka hewa, iwaena o ka poe e make ana; no ka mea, aole i loaa ia lakou ka makemake i ka olelo oiaio, i ola'i lakou.   
\q1
\v 11 No ia mea, e hooili mai no ke Akua i ka hoopunipuni ikaika maluna o lakou, i manao ai lakou i ka mea wahahee he oiaio;   
\q1
\v 12 I make pu ai hoi lakou a pau ka poe i manaoio ole i ka olelo oiaio, aka, ua olioli no i ka mea pono ole.   
\b  
\q1
\v 13 Aka, e pono makou e hoomaikai mau aku i ke Akua no oukou, e na hoahanau i alohaia mai e ka Haku, no ko ke Akua wae ana mai ia oukou, mai ke kumu mai, i ola oukou ma ka huikala ana mai o ka Uhane, a ma ka manaoio aku i ka olelo oiaio;   
\q1
\v 14 Malaila hoi oia i hea mai ai ia oukou, ma ka makou euanelio, i loaa ia oukou ka nani o ko kakou Haku, o Iesu Kristo.   
\q1
\v 15 Nolaila, e na hoahanau, e kupaa, a e hoopaa loa i ka haawina i aoia'ku ai ia oukou ma ka olelo, a ma ka makou episetole.   
\b  
\q1
\v 16 Eia hoi, na ko kakou Haku o Iesu Kristo a me ke Akua ko kakou Makua, ka mea i aloha mai ia kakou, a i haawi wale mai hoi ia kakou i ka oluolu mau loa, a me ka manaolana maikai, ma ka lokomaikaiia mai,   
\q1
\v 17 E hooluolu mai i ko oukou mau naau, ae hookupaa ia oukou i na olelo a me na hana maikai a pau.   
\c 3  
\b  
\q1
\v 1 NO na mea i koe, e pule oukou, e na hoahanau, no makou, i holo leaai ka olelo a ka Haku, a i hoonaniia'i hoi, e like me ia iwaena o oukou;   
\q1
\v 2 A i hoopakeleia'e ai hoi makou i kanaka haihaia a me ka hana hewa; no ka mea, aole pau na kanaka i ka manaoio.   
\q1
\v 3 Aka, he oiaio ka Haku, nana oukou e hookupaa mai, a e hoopakele hoi i ka mea hewa.   
\q1
\v 4 He manao ko makou iloko o ka Haku ia oukou, e, ke hana mai nei no oukou, a e hana no i na mea a makou e kauoha aku nei ia oukou.   
\q1
\v 5 Na ka Haku hoi e alakai i ko oukou naau iloko o ke aloha o ke Akua, a me ke ahonui o Kristo.   
\b  
\q1
\v 6 Ke kauoha aku nei hoi makou ia oukou, e na hoahanau, ma ka inoa o ko kakou Haku, o Iesu Kristo, e hookaawale ia oukou iho, mai kela hoahanau a me keia hoahanau e hele hokai ana, aole mamuli o ka haawina i kauohaia'ku ai e makou.   
\q1
\v 7 Ua ike no hoi oukou, e pono oukou e hoohalike me makou; no ka mea, aole makou i hele hokai iwaena o oukou.   
\q1
\v 8 Aole hoi makou i ai i ka berena a kekahi me ka uku ole aku; aka, ua hooikaika no makou ma ka hana, a me ka luhi i ka po a me ke ao, i ole ai makou e lilo i mea e luhi ai kekahi o oukou.   
\q1
\v 9 Aole no ka pono ole ia makou, aka, no ka hoolilo ana ia makou iho i kumu hoohalike, i hahai mai ai oukou mamuli o makou.   
\q1
\v 10 No ka mea hoi, la makou i noho ai me oukou, ua olelo aku makou ia oukou peneia, Ina aole e hana kekahi, aole hoi ia e pono ke ai.   
\q1
\v 11 Ua lohe hoi makou, e, aia hoi iwaena o oukou kekahi poe e hele hokai ana, aole e hana maoli ana, aka, he poe hana lapuwale.   
\q1
\v 12 A oia poe, o ka makou ia e kauoha aku nei me ka hooikaika aku, ma ko kakou Haku, ma o Iesu Kristo la, e hana maoli lakou me ka noho malie, a e ai hoi i ka lakou ai ponoi iho.   
\q1
\v 13 O oukou hoi, e na hoahanau, mai hoonawaliwali i ka hana pono ana.   
\q1
\v 14 A ina hoolohe ole mai kekahi i ka makou olelo ma keia episetole, e hoailona oukou ia ia, aole hoi e hoolauna pu me ia, i hilahila ia.   
\q1
\v 15 Mai kapa hoi oukou ia ia he enemi; aka, e ao aku ia ia me he hoahanau la.   
\b  
\q1
\v 16 Na ka Haku nona ka malu e hoomalu mau mai ia oukou, i na mea a pau. O ka Haku pu kekahi me oukou a pau loa.   
\b  
\q1
\v 17 O ke aloha o'u o Paulo nako'u lima no ia, oia ka hoailona i na episetole a pau; pela wau e palapala aku nei.   
\q1
\v 18 A ia oukou a pau ke aloha o ko kakou Haku o Iesu Kristo. Amene.   