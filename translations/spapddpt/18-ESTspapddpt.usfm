\v 13 \w Los|strong="H3605"\w* decretos fueron enviados \w por|strong="H5704"\w* \w medio|strong="H3027"\w* \w de|strong="H5704"\w* mensajeros especiales \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las \w provincias|strong="H4082"\w* del \w rey|strong="H4428"\w*, \w con|strong="H5704"\w* \w la|strong="H1931"\w* orden \w de|strong="H5704"\w* \w destruir|strong="H8045"\w*, asesinar \w y|strong="H5704"\w* exterminar \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w judíos|strong="H3064"\w*, tanto jóvenes \w como|strong="H5704"\w* \w viejos|strong="H2205"\w*, \w niños|strong="H2945"\w* \w y|strong="H5704"\w* \w mujeres|strong="H5704"\w*, \w en|strong="H5704"\w* un \w mismo|strong="H1931"\w* \w día|strong="H3117"\w*, \w el|strong="H1931"\w* 13 del \w mes|strong="H2320"\w* \w duodécimo|strong="H8147"\w*, \w el|strong="H1931"\w* \w mes|strong="H2320"\w* \w de|strong="H5704"\w* Adar, \w y|strong="H5704"\w* saquear \w sus|strong="H1931"\w* bienes \w como|strong="H5704"\w* \w despojo|strong="H7998"\w*.
\v 14 Una copia del documento \w que|strong="H5971"\w* debía darse \w como|strong="H1961"\w* ley en \w cada|strong="H3605"\w* \w provincia|strong="H4082"\w* \w sería|strong="H1961"\w* publicada \w para|strong="H5414"\w* \w cada|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w a|strong="H3068"\w* fin \w de|strong="H5971"\w* \w que|strong="H5971"\w* estuvieran preparados \w para|strong="H5414"\w* \w aquel|strong="H2088"\w* \w día|strong="H3117"\w*.
\p 
\v 15 \w Los|strong="H3427"\w* mensajeros \w salieron|strong="H3318"\w* con prisa \w por|strong="H1697"\w* mandato \w del|strong="H8354"\w* \w rey|strong="H4428"\w*, pues \w el|strong="H3427"\w* edicto fue promulgado \w en|strong="H3318"\w* Susa, la \w capital|strong="H1002"\w*. \w El|strong="H3427"\w* \w rey|strong="H4428"\w* y \w Amán|strong="H2001"\w* se \w sentaron|strong="H3427"\w* \w a|strong="H3068"\w* \w beber|strong="H8354"\w*, mientras la \w ciudad|strong="H5892"\w* \w de|strong="H1697"\w* Susa \w estaba|strong="H3427"\w* perpleja.
\c 4
\s1 Duelo de los judíos
\p 
\v 1 Mardoqueo \w supo|strong="H3045"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3045"\w* \w se|strong="H3045"\w* \w hizo|strong="H6213"\w*. Entonces Mardoqueo \w rasgó|strong="H7167"\w* sus ropas y \w se|strong="H3045"\w* \w vistió|strong="H3847"\w* \w de|strong="H3847"\w* tela áspera con ceniza. Fue al centro \w de|strong="H3847"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w*, y \w clamó|strong="H2199"\w* \w a|strong="H3068"\w* \w gran|strong="H1419"\w* \w voz|strong="H1419"\w* con \w amargura|strong="H4751"\w*.
\v 2 \w Luego|strong="H5704"\w* fue \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* frente \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w puerta|strong="H8179"\w* del palacio \w real|strong="H4428"\w*, \w pues|strong="H3588"\w* \w no|strong="H3588"\w* era permitido entrar \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w puerta|strong="H8179"\w* del palacio \w real|strong="H4428"\w* cubierto \w de|strong="H3588"\w* tela áspera.
\v 3 En \w cada|strong="H3605"\w* \w provincia|strong="H4082"\w* \w a|strong="H3068"\w* \w donde|strong="H4725"\w* \w llegaba|strong="H5060"\w* \w la|strong="H3605"\w* orden del \w rey|strong="H4428"\w* y su edicto, hubo \w gran|strong="H1419"\w* duelo entre \w los|strong="H3605"\w* \w judíos|strong="H3064"\w*: \w ayuno|strong="H6685"\w*, \w llanto|strong="H1065"\w* y lamentación. \w La|strong="H3605"\w* tela áspera y \w la|strong="H3605"\w* ceniza fueron \w la|strong="H3605"\w* cama para \w muchos|strong="H7227"\w*.
\p 
\v 4 \w Las|strong="H5921"\w* \w doncellas|strong="H5291"\w* \w de|strong="H5921"\w* Ester \w y|strong="H5921"\w* sus \w eunucos|strong="H5631"\w* fueron \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w lo|strong="H3808"\w* comunicaron. \w La|strong="H5921"\w* \w reina|strong="H4436"\w* \w se|strong="H5921"\w* estremeció \w y|strong="H5921"\w* \w se|strong="H5921"\w* afligió muchísimo. \w Envió|strong="H7971"\w* ropas \w para|strong="H5921"\w* \w que|strong="H3808"\w* Mardoqueo \w se|strong="H5921"\w* vistiera, \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w quitara|strong="H5493"\w* su tela áspera, pero \w él|strong="H5921"\w* \w no|strong="H3808"\w* \w las|strong="H5921"\w* aceptó.
\v 5 Entonces Ester \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* Hatac, uno \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w eunucos|strong="H5631"\w* \w que|strong="H4100"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* asignó \w al|strong="H5921"\w* servicio \w de|strong="H5921"\w* \w ella|strong="H5921"\w*, \w y|strong="H5921"\w* \w lo|strong="H4100"\w* \w envió|strong="H6680"\w* \w a|strong="H3068"\w* Mardoqueo \w para|strong="H5921"\w* averiguar \w qué|strong="H4100"\w* \w era|strong="H2088"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* sucedía \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w qué|strong="H4100"\w*.
\p 
\v 6 Hatac \w salió|strong="H3318"\w* \w hacia|strong="H6440"\w* Mardoqueo, \w a|strong="H3068"\w* la plaza \w de|strong="H6440"\w* la \w ciudad|strong="H5892"\w*, que estaba frente \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w* del palacio del \w rey|strong="H4428"\w*.
\v 7 Mardoqueo \w le|strong="H5921"\w* refirió \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w le|strong="H5921"\w* sucedía, \w y|strong="H5921"\w* \w la|strong="H5921"\w* suma exacta \w de|strong="H5921"\w* \w plata|strong="H3701"\w* \w que|strong="H5921"\w* \w Amán|strong="H2001"\w* prometió pesar \w para|strong="H5921"\w* \w los|strong="H5921"\w* tesoros \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* fin \w de|strong="H5921"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* \w judíos|strong="H3064"\w* fueran destruidos.
\v 8 \w Además|strong="H5921"\w* \w le|strong="H5921"\w* \w dio|strong="H5414"\w* una copia \w del|strong="H5921"\w* edicto \w que|strong="H5921"\w* fue promulgado \w en|strong="H5921"\w* Susa \w para|strong="H5921"\w* \w que|strong="H5921"\w* fueran \w destruidos|strong="H8045"\w*. Esperaba \w que|strong="H5921"\w* \w la|strong="H5921"\w* \w mostrara|strong="H7200"\w* \w a|strong="H3068"\w* Ester \w y|strong="H5921"\w* \w le|strong="H5921"\w* contara todo. \w Le|strong="H5921"\w* encargó \w que|strong="H5921"\w* acudiera \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w e|strong="H3068"\w* intercediera \w por|strong="H5921"\w* su \w pueblo|strong="H5971"\w* \w ante|strong="H6440"\w* \w él|strong="H5921"\w*.
\p 
\v 9 \w Y|strong="H3068"\w* regresó Hatac y \w declaró|strong="H5046"\w* \w a|strong="H3068"\w* Ester las \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* Mardoqueo.
\v 10 Entonces Ester habló con Hatac y lo \w envió|strong="H6680"\w* \w a|strong="H3068"\w* Mardoqueo:
\v 11 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* servidores del \w rey|strong="H4428"\w* y \w la|strong="H3605"\w* \w gente|strong="H5971"\w* \w de|strong="H5971"\w* las \w provincias|strong="H4082"\w* del \w rey|strong="H4428"\w*, \w saben|strong="H3045"\w* \w que|strong="H3808"\w* \w para|strong="H5971"\w* \w cualquier|strong="H3605"\w* persona, sea hombre \w o|strong="H3068"\w* mujer, \w que|strong="H3808"\w* \w entre|strong="H3808"\w* \w al|strong="H4428"\w* \w patio|strong="H2691"\w* \w interior|strong="H6442"\w* del \w rey|strong="H4428"\w* \w sin|strong="H3808"\w* ser \w llamado|strong="H7121"\w*, hay una sola ley: Debe \w morir|strong="H4191"\w*, excepto \w aquél|strong="H2088"\w* \w a|strong="H3068"\w* \w quien|strong="H3605"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* extienda \w el|strong="H3605"\w* cetro \w de|strong="H5971"\w* \w oro|strong="H2091"\w* \w para|strong="H5971"\w* \w que|strong="H3808"\w* \w viva|strong="H2421"\w*. \w Y|strong="H3068"\w* yo \w no|strong="H3808"\w* \w fui|strong="H3808"\w* llamada \w para|strong="H5971"\w* ir ante \w el|strong="H3605"\w* \w rey|strong="H4428"\w* en \w estos|strong="H2088"\w* 30 \w días|strong="H3117"\w*.
\p 
\v 12 Él le informó \w a|strong="H3068"\w* Mardoqueo \w lo|strong="H1697"\w* \w que|strong="H1697"\w* \w dijo|strong="H5046"\w* Ester.
\v 13 \w Y|strong="H3068"\w* Mardoqueo mandó \w que|strong="H3605"\w* se respondiera \w a|strong="H3068"\w* Ester: No creas dentro de ti \w que|strong="H3605"\w* \w escaparás|strong="H4422"\w* en \w la|strong="H3605"\w* \w casa|strong="H1004"\w* del \w rey|strong="H4428"\w*, mejor \w que|strong="H3605"\w* \w cualquier|strong="H3605"\w* otro \w judío|strong="H3064"\w*.
\v 14 \w Porque|strong="H3588"\w*, \w si|strong="H3588"\w* \w en|strong="H3588"\w* \w este|strong="H2063"\w* momento callas, socorro \w y|strong="H3588"\w* liberación vendrá \w de|strong="H3588"\w* alguna otra \w parte|strong="H4725"\w* \w para|strong="H3588"\w* \w los|strong="H3588"\w* \w judíos|strong="H3064"\w*, \w pero|strong="H3588"\w* tú \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* tu padre perecerán, \w y|strong="H3588"\w* ¿\w quién|strong="H4310"\w* \w sabe|strong="H3045"\w* \w si|strong="H3588"\w* \w para|strong="H3588"\w* un \w tiempo|strong="H6256"\w* \w como|strong="H3588"\w* \w éste|strong="H2063"\w* llegaste \w al|strong="H6256"\w* \w reino|strong="H4438"\w*?
\s1 Decisión de Ester
\p 
\v 15 Ester dijo que respondieran \w a|strong="H3068"\w* Mardoqueo:
\v 16 \w Vé|strong="H3212"\w* \w y|strong="H1571"\w* reúne \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w judíos|strong="H3064"\w* \w que|strong="H3808"\w* están \w en|strong="H5921"\w* Susa. Ayunen \w por|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H1571"\w* \w no|strong="H3808"\w* coman \w ni|strong="H3808"\w* \w beban|strong="H8354"\w* durante \w tres|strong="H7969"\w* \w días|strong="H3117"\w*, \w ni|strong="H3808"\w* \w de|strong="H5921"\w* \w noche|strong="H3915"\w* \w ni|strong="H3808"\w* \w de|strong="H5921"\w* \w día|strong="H3117"\w*. Yo \w también|strong="H1571"\w* \w ayunaré|strong="H6684"\w* \w igualmente|strong="H1571"\w* \w con|strong="H5921"\w* mis \w doncellas|strong="H5291"\w*, \w y|strong="H1571"\w* \w entonces|strong="H3117"\w* \w iré|strong="H3212"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w*, \w aunque|strong="H1571"\w* es \w contra|strong="H5921"\w* \w la|strong="H5921"\w* ley, ¡\w y|strong="H1571"\w* \w si|strong="H1571"\w* perezco, \w que|strong="H3808"\w* perezca!
\p 
\v 17 Entonces Mardoqueo \w se|strong="H5921"\w* fue \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w según|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* Ester \w le|strong="H5921"\w* encomendó.
\c 5
\s1 Primer banquete de Ester
\p 
\v 1 \w Al|strong="H5921"\w* tercer \w día|strong="H3117"\w* \w sucedió|strong="H1961"\w* \w que|strong="H5921"\w* Ester \w vistió|strong="H3847"\w* sus atavíos \w reales|strong="H4428"\w* \w y|strong="H5921"\w* \w se|strong="H1961"\w* presentó \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w patio|strong="H2691"\w* \w interior|strong="H6442"\w* \w del|strong="H5921"\w* palacio \w del|strong="H5921"\w* \w rey|strong="H4428"\w*, frente \w a|strong="H3068"\w* \w la|strong="H5921"\w* cámara \w real|strong="H4428"\w*. \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w estaba|strong="H1961"\w* \w sentado|strong="H3427"\w* \w en|strong="H5921"\w* su \w trono|strong="H3678"\w* \w real|strong="H4428"\w*, frente \w a|strong="H3068"\w* \w la|strong="H5921"\w* entrada principal \w del|strong="H5921"\w* palacio.
\v 2 \w Sucedió|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* el \w rey|strong="H4428"\w* \w vio|strong="H7200"\w* \w a|strong="H3068"\w* la \w reina|strong="H4436"\w* Ester, \w que|strong="H1961"\w* \w estaba|strong="H1961"\w* \w en|strong="H5975"\w* \w pie|strong="H5975"\w* \w en|strong="H5975"\w* el \w patio|strong="H2691"\w*, ella halló \w gracia|strong="H2580"\w* ante él. El \w rey|strong="H4428"\w* \w extendió|strong="H3447"\w* \w a|strong="H3068"\w* Ester el cetro \w de|strong="H5869"\w* \w oro|strong="H2091"\w* \w que|strong="H1961"\w* \w tenía|strong="H1961"\w* \w en|strong="H5975"\w* su \w mano|strong="H3027"\w*. Entonces Ester \w se|strong="H1961"\w* acercó y \w tocó|strong="H5060"\w* la punta del cetro.
\p 
\v 3 El \w rey|strong="H4428"\w* le preguntó: ¿\w Qué|strong="H4100"\w* deseas, \w reina|strong="H4436"\w* Ester? ¿\w Cuál|strong="H4100"\w* es tu petición? \w Hasta|strong="H5704"\w* la mitad \w del|strong="H2677"\w* \w reino|strong="H4438"\w* \w se|strong="H4100"\w* te \w dará|strong="H5414"\w*.
\p 
\v 4 Ester respondió: \w Si|strong="H5921"\w* \w place|strong="H2895"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w*, venga \w hoy|strong="H3117"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w con|strong="H5921"\w* \w Amán|strong="H2001"\w* \w al|strong="H5921"\w* \w banquete|strong="H4960"\w* \w que|strong="H5921"\w* preparé \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w*.
\p 
\v 5 \w El|strong="H6213"\w* \w rey|strong="H4428"\w* ordenó: Llamen \w pronto|strong="H4116"\w* \w a|strong="H3068"\w* \w Amán|strong="H2001"\w*, para \w que|strong="H1697"\w* se \w haga|strong="H6213"\w* como dijo Ester.
\p Así \w que|strong="H1697"\w* \w el|strong="H6213"\w* \w rey|strong="H4428"\w* fue con \w Amán|strong="H2001"\w* \w al|strong="H4428"\w* \w banquete|strong="H4960"\w* \w que|strong="H1697"\w* preparó Ester.
\v 6 \w Al|strong="H5704"\w* brindar \w vino|strong="H3196"\w* \w en|strong="H5704"\w* \w el|strong="H6213"\w* \w banquete|strong="H4960"\w*, \w el|strong="H6213"\w* \w rey|strong="H4428"\w* dijo \w a|strong="H3068"\w* Ester: ¿\w Cuál|strong="H4100"\w* es \w tu|strong="H6213"\w* \w petición|strong="H7596"\w*? \w Pues|strong="H4100"\w* te \w será|strong="H5414"\w* concedida. ¿\w Cuál|strong="H4100"\w* es \w tu|strong="H6213"\w* \w demanda|strong="H1246"\w*? ¡\w Hasta|strong="H5704"\w* la mitad \w del|strong="H2677"\w* \w reino|strong="H4438"\w* \w se|strong="H4100"\w* te concederá!
\p 
\v 7 \w Y|strong="H3068"\w* Ester \w respondió|strong="H6030"\w*: \w Mi|strong="H6030"\w* \w petición|strong="H7596"\w* y \w mi|strong="H6030"\w* \w demanda|strong="H1246"\w* es:
\v 8 \w Si|strong="H5921"\w* \w hallé|strong="H4672"\w* \w gracia|strong="H2580"\w* ante \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w y|strong="H5921"\w* \w si|strong="H5921"\w* \w place|strong="H2895"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w* conceder \w mi|strong="H5921"\w* \w petición|strong="H7596"\w* \w y|strong="H5921"\w* cumplir \w mi|strong="H5921"\w* \w demanda|strong="H1246"\w*, \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* venga \w con|strong="H5921"\w* \w Amán|strong="H2001"\w* \w al|strong="H5921"\w* \w banquete|strong="H4960"\w* \w que|strong="H5921"\w* \w les|strong="H5921"\w* prepararé, \w y|strong="H5921"\w* \w mañana|strong="H4279"\w* \w haré|strong="H6213"\w* \w según|strong="H5921"\w* \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*.
\p 
\v 9 \w Amán|strong="H2001"\w* \w salió|strong="H3318"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* gozoso \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w corazón|strong="H3820"\w* \w alegre|strong="H8056"\w*. Pero \w cuando|strong="H3117"\w* \w Amán|strong="H2001"\w* \w vio|strong="H7200"\w* \w a|strong="H3068"\w* Mardoqueo \w en|strong="H5921"\w* \w la|strong="H1931"\w* \w puerta|strong="H8179"\w* \w del|strong="H4480"\w* palacio \w del|strong="H4480"\w* \w rey|strong="H4428"\w*, \w quien|strong="H1931"\w* \w se|strong="H1931"\w* negaba \w a|strong="H3068"\w* \w levantarse|strong="H6965"\w* \w o|strong="H3068"\w* mostrar temor \w delante|strong="H5921"\w* \w de|strong="H4480"\w* \w él|strong="H1931"\w*, \w se|strong="H1931"\w* \w llenó|strong="H4390"\w* \w de|strong="H4480"\w* \w ira|strong="H2534"\w* \w contra|strong="H5921"\w* Mardoqueo,
\v 10 pero se refrenó.
