\id OBA OBO - Cishingini Agwara Kambari [asg]
\h Obodiya
\toc3 Obo
\toc2 Obodiya
\toc1 Katagarda ko Obodiya
\mt1 Katagarda ko
\mt2 Obodiya
\imt1 Kuɓa̱yuwa̱
\im Katagarda ke kenu ka nampa a ɗana ta̱ kaꞋa ayin atakaci, ana Urushelima u yikpa̱i a̱ ka̱ya̱ ka (586) kafu a matsa Yesu Kirisiti. Aza a Edom a na i a uɓon u ɗakai n tsugaɗi n Urushelima, ele irala ya aza a Yahuda i ɗa. A makyan ma na Urushelima u yikpa̱i, a yaꞋin ma̱za̱nga̱ n atakaci aza e le, a na a kupana asuvayali e le. Nannai koci ba ɗa a uwai a̱ pura̱i ucanuku u likuci wa, a̱ ɓa̱nka̱i aza a na a̱ tuka̱i likuci ya n kuvon. Obodiya u yaꞋin kene u danai, i ta̱ a kutakacika Edom, i ta̱ a kulyaꞋa yi n kuvon tsu na a kuyaꞋanka kagimi ka irala yi Isaraila.
\iot Ili i na yi punu udari a katagarda ka nampa
\iot 1 Atakaci aza a Edom 1:1-14
\iot 1 Kanna ka Vuzavaguɗu 1:15-21
\c 1
\s1 Kene ku uyikpi u Edom
\p 
\v 1 Na ɗa akaka a Vuzavaguɗu MalaꞋimili a na Obodiya wu enei tsa alatani a ukuna wu iɗika i Edom.\x - \xo 1:1 \xt Ish 34:5-17; 63:1-6; Ij 25:12-14; 35:1-15; Em 1:11-12; Mal 1:2-5\x*
\q1 A̱ suki vuza vu usuki uduniyan,
\q2 ɗa kpamu tsu panai akaka u Vuzavaguɗu a danai,
\q1 <<Ɗenga̱i tsu bana ci yaꞋan kuvon n iɗika i Edom.>>
\q1 
\v 2 Vuzavaguɗu u danai,
\q2 La̱na̱, n kubonoko wu ta̱ vu okpo kenu a̱ ka̱tsuma̱ ku uduniyan u na u buwai,
\q2 i ta̱ o goyo wu ko kenu ba.
\q1 
\v 3 A̱ra̱ɗi a̱ nu o doro wu ta̱ avu Edom,
\q2 avu na vi a̱ ida̱shi a kaɓatsu,
\q2 avu na vi a̱ ida̱shi a gaɗi vu nsasan m gbagbaꞋin,
\q1 a ku dana a̱ ka̱ɗu ka̱ nu,
\q2 <<Yayi u kufuɗa kucipa̱ka̱ mu a iɗika?>>
\q1 
\v 4 Ko vi ishi baci vi ɗimkpai gaɗi tsu mashangi,
\q2 ko vi ishi vu yaꞋan kpaꞋa a̱ ka̱tsuma̱ ka azangata,
\q2 mi ta̱ o kurono wu ɗe n cipa̱ka̱ a iɗika.
\q1 
\v 5 Ɗa baci oboki a uwai a kpaꞋa ku nu,
\q2 ɗa baci kpamu aza a̱ ma̱ga̱la̱ka̱ a̱ ta̱wa̱i nu n kayin,
\q2 i ta̱ a kuɗika ili i na a cigai ɗa.
\q1 ɗa baci kpamu oboki a umaci wu nɗanga a uwai a kashina ka̱ nu,
\q2 kuɗayu ku ɗa a̱ kuka̱sukpa̱ka̱ wu koci,
\q1 
\v 6 Ama a̱ɗa̱ uma e Edom, kumaci ku Isuwa,
\q2 a una wu ta̱,
\q2 uciyi u ɗa̱ ra̱ka̱ a̱ pura̱ ta̱ u ɗa.
\q1 
\v 7 Uduniyan u na vu gbaɓai kaci n e le,
\q2 i ta̱ o kuloko wu a iɗika i nu.
\q2 i ta̱ a̱ kuya̱nsa̱ wu ka̱ta̱ a lyaꞋa wu n kuvon.
\q1 a̱ja̱Ꞌa̱ a na vi a kulyaꞋa ilikulya koɓolo n e le,
\q2 i ta̱ a ku azuku wu maza,
\q2 ka̱ta̱ a dana vi n ugboji ba.
\q1 
\v 8 Mpa Vuzavaguɗu n dana ta̱,
\q1 a kanna ka na n kutakacika Edom,
\q2 mi ta̱ a ku una aza a ugboji a Edom,
\q2 mi ta̱ a ku takpa aza e kuyeve a nsansa n Isuwa.
\q1 
\v 9 Teman, ovonshi a utsura a̱ nu i ta̱ a kupana wovon,
\q2 i ta̱ a ku una yaba dem a kusan ku Isuwa.
\s1 Unushi u Edom
\q1 
\v 10 Adama o kuyongo ku wuya ku na vu yaꞋankai vuza nu Yakubu,
\q2 vi ta̱ o ku okpo n wono,
\q2 i ta̱ a ku una wu ra̱ka̱-ra̱ka̱.
\q1 
\v 11 A kanna ka nanlo vu shamgbai a kakambu a kinda,
\q2 a makyan ma na irala a̱ pura̱i u uciyi u ni,
\q2 omoci kpamu o ɓosoi a̱ utsutsu u ni,
\q2 ɗa a taɗuki kazagba adama a Urushelima,
\q2 avu feu vu okpoi tsu vuza te a̱ ka̱tsuma̱ ke le.
\q1 
\v 12 U gaꞋan vu yaꞋan ma̱za̱nga̱ adama atakaci a na vuza nu u uwai ba.
\q2 U gaꞋan vu yaꞋan ma̱za̱nga̱ adama atakaci aza a Yahuda a kanna ka na i a ku una le ba.
\q1 U gaꞋan vu zoꞋoso le a kanna ka a atakaci e le ba.
\q1 
\v 13 U gaꞋan vu uwa a̱ likuci i uma a̱ va̱,
\q2 a kanna ka na i atakaci ba,
\q2 u gaꞋan vu yaꞋan ma̱za̱nga̱ adama a̱ ma̱dukpa̱ ma na ma̱ ciya̱i vuza nu ba.
\q1 
\v 14 U gaꞋan vu shamgba a nsanji mu uye vu una aza a na a cigai a laꞋaka ba.
\q2 u gaꞋan vu neke aza a na a sumai a laꞋakai ekiye a irala i le,
\q2 a kanna ka na atakaci ke le ba.
\s1 Kanna ka Vuzavaguɗu ki ta̱ ɗevu
\q1 
\v 15 Kanna ka na mpa Vuzavaguɗu n kuyaꞋanka, uduniya ra̱ka̱ afada ka yawa ta̱ ɗevu.
\q1 Avu Edom ili i na vu yaꞋin, i ta̱ feu a kuyaꞋanka wu i ɗa.
\q2 Ili i na vu yaꞋin, yi ta̱ o kubono a ka̱ci ka̱ nu.
\q1 
\v 16 Tsu na i soꞋi atakaci,
\q2 a kusan ku ciɗa ku va̱,
\q1 ta feu uduniya u na u buwai a kutakacika nannai,
\q2 i ta̱ o ku soꞋo atakaci,
\q2 ali okpo adanshi ka̱ta̱ a yaꞋan le ba.
\s1 UlyaꞋi wa aza Isaraila a ukocishi
\q1 
\v 17 Ama i ta̱ a̱ kuciya̱ aza a na a laꞋakai a kusan ku Sihiyona,
\q2 wi ta̱ o ko okpo ubuta̱ wu ida̱shi i ciɗa.
\q2 Ka̱ta̱ kumaci ku Yakubu ku doku ku ciya̱ ili yi uka̱ni i le.
\q1 
\v 18 Kumaci ku Yakubu ki ta̱ kokpo tsa akina,
\q2 kpaꞋa ku Isufu tsu melentsu ma akina,
\q1 kpaꞋa ku Isuwa ko okpo ciꞋiwa̱,
\q2 i ta̱ o kusongu le una le.
\q1 Ko vuza u kulaꞋaka ba,
\q2 mpa Vuzavaguɗu n dansai.
\p 
\v 19 Aza a Isaraila a na i a Negebu,
\q2 i ta̱ a̱ kuka̱na̱ kusan ku Isuwa,
\q1 aza a na i a idashi aginda aza a Yahuda,
\q2 i ta̱ a ku isa iɗika ya aza a Filisitiya,
\q1 aza a Isaraila i ta̱ a kulyaꞋa uka̱ni,
\q2 wu uɓon wi iɗika ya aza a Ifirayimu n Samariya.
\q2 kumaci ku Bayami kpamu ku lyaꞋa Giliyadu.
\v 20 Kabunda̱i ko osoji ka Isaraila a na a bankai ugbashi,
\q2 i ta̱ o kubono a̱ ka̱na̱ iɗika ya aza KanaꞋana, ali a kubana a zarefatu.
\q1 Agbashi a na i a Urushelima a uɓon u Sefaradu
\q2 i ta̱ a ku isa likuci i Negebu.
\q1 
\v 21 Aza na a laꞋakai n wuma i ta̱ a ku gaɗukpa,
\q2 a kubana a kusan ku Sihiyona a Urushelima,
\q1 a̱ ka̱na̱ kusan ku Isuwa,
\q2 Vuzavaguɗu n ka̱ci ka̱ ni ɗa u kulyaꞋa tsugono ɗe.
