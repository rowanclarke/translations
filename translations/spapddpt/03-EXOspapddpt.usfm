\p
\v 22 \w Bezaleel|strong="H1212"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Uri, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hur|strong="H2354"\w*, \w de|strong="H1121"\w* \w la|strong="H3605"\w* \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*, \w hizo|strong="H6213"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.  
\v 23 \w Y|strong="H3068"\w* con \w él|strong="H1121"\w* estaba Oholiab, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahisamac, \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* \w Dan|strong="H1835"\w*, \w artífice|strong="H2796"\w*, diseñador y bordador en \add tela\add* azul, púrpura y carmesí y cordoncillo \w de|strong="H1121"\w* lino fino.   
\p
\v 24 \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w oro|strong="H2091"\w* \w empleado|strong="H6213"\w* \w para|strong="H1961"\w* \w el|strong="H3605"\w* trabajo, en \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w* del \w Santuario|strong="H6944"\w*, \w el|strong="H3605"\w* \w oro|strong="H2091"\w* de \w la|strong="H3605"\w* \w ofrenda|strong="H8573"\w* mecida, \w fue|strong="H1961"\w* de 965 kilogramos.\f + \fr 38:24 \ft Lit. 29 talentos y 730 \+tl siclo\+tl*s, según el \+tl siclo\+tl* del Santuario. \f*   
\p
\v 25 La \w plata|strong="H3701"\w* \w de|strong="H2568"\w* los censados \w de|strong="H2568"\w* la congregación ascendió \w a|strong="H3068"\w* 3,32 toneladas.\f + \fr 38:25 \ft Lit. 100 talentos, y 1.775 \+tl siclo\+tl*s, según el \+tl siclo\+tl* del Santuario.\f*  
\v 26 \add Esto representaba\add* 5,5 gramos \w de|strong="H5921"\w* plata \w por|strong="H5921"\w* \w cada|strong="H3605"\w* uno \w de|strong="H5921"\w* \w los|strong="H1121"\w* empadronados mayores \w de|strong="H5921"\w* 20 \w años|strong="H8141"\w*, \w los|strong="H1121"\w* cuales fueron 603.550.  
\v 27 \w Se|strong="H1961"\w* emplearon 3,3 toneladas de \w plata|strong="H3701"\w* \w para|strong="H1961"\w* fundir las basas del \w Santuario|strong="H6944"\w* y las basas del velo. \w Para|strong="H1961"\w* 100 basas \add emplearon\add* 3,3 toneladas, 33 kilogramos por basa.  
\v 28 Con 19,5 kilogramos \w hizo|strong="H6213"\w* los capiteles \w de|strong="H2568"\w* las \w columnas|strong="H5982"\w* y las molduras.   
\p
\v 29 El bronce de la \w ofrenda|strong="H8573"\w* mecida ascendió \w a|strong="H3068"\w* 2,3 toneladas.  
\v 30 Con \w él|strong="H3605"\w* \w hizo|strong="H6213"\w* las basas de \w la|strong="H3605"\w* \w puerta|strong="H6607"\w* \w del|strong="H4196"\w* Tabernáculo de Reunión, \w el|strong="H3605"\w* \w altar|strong="H4196"\w* de bronce y su rejilla de bronce, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios \w del|strong="H4196"\w* \w altar|strong="H4196"\w*,  
\v 31 las basas del \w patio|strong="H2691"\w* \w que|strong="H2691"\w* \w lo|strong="H3605"\w* rodeaba, las basas de \w la|strong="H3605"\w* entrada al \w patio|strong="H2691"\w*, \w todas|strong="H3605"\w* las estacas del \w Tabernáculo|strong="H4908"\w* y \w todas|strong="H3605"\w* las estacas del \w patio|strong="H2691"\w* \w que|strong="H2691"\w* \w lo|strong="H3605"\w* rodeaba.   
\c 39  
\s1 Las ropas sacerdotales  
\p
\v 1 \w Con|strong="H4480"\w* hilo \w de|strong="H4480"\w* \add azul\add*, púrpura y carmesí, \w hicieron|strong="H6213"\w* las ropas \w de|strong="H4480"\w* tejido \w para|strong="H4480"\w* ministrar \w en|strong="H4480"\w* \w el|strong="H6213"\w* \w Santuario|strong="H6944"\w* \w e|strong="H3068"\w* \w hicieron|strong="H6213"\w* las ropas \w sagradas|strong="H6944"\w* \w para|strong="H4480"\w* Aarón, como \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.   
\p
\v 2 \w Hicieron|strong="H6213"\w* también \w el|strong="H6213"\w* \tl efod\tl* de \w oro|strong="H2091"\w* y \add tela\add* azul, púrpura y carmesí y cordoncillo de lino fino.  
\v 3 \w Hicieron|strong="H6213"\w* láminas de \w oro|strong="H2091"\w* y las cortaron \w en|strong="H8432"\w* filamentos para tejerlos \w entre|strong="H8432"\w* \w el|strong="H6213"\w* azul, la púrpura, \w el|strong="H6213"\w* carmesí y \w el|strong="H6213"\w* cordoncillo de lino fino con \w labor|strong="H4639"\w* primorosa.  
\v 4 \w Le|strong="H5921"\w* \w hicieron|strong="H6213"\w* \w hombreras|strong="H3802"\w* \w unidas|strong="H2266"\w* \w en|strong="H5921"\w* sus \w dos|strong="H8147"\w* extremos.  
\v 5 \w La|strong="H1931"\w* faja tejida \w que|strong="H4480"\w* \w el|strong="H1931"\w* \tl efod\tl* llevaba \w encima|strong="H5921"\w* \w era|strong="H1931"\w* \w del|strong="H4480"\w* \w mismo|strong="H1931"\w* material \w y|strong="H5921"\w* \w de|strong="H4480"\w* \w la|strong="H1931"\w* \w misma|strong="H1931"\w* hechura: \w de|strong="H4480"\w* \w oro|strong="H2091"\w* \w y|strong="H5921"\w* \add tela\add* azul, púrpura \w y|strong="H5921"\w* carmesí \w y|strong="H5921"\w* cordoncillo \w de|strong="H4480"\w* lino fino, \w como|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.   
\p
