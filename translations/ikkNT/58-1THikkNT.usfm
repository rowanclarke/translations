\id 1TH Ika New Testament 2009
\h 1 Ndị Tẹsalonika
\toc1 Ẹkụkwọ-Ozi Ibuzọ Pọlụ Dejẹnni Ndị Tẹsalonika Ndị Tẹsalonika, Nke Ibuzọ
\toc2 Ndị Tẹsalonika, Nke Ibuzọ
\toc3 1Tẹ
\mt2 Ẹkụkwọ-Ozi Ibuzọ Pọlụ Dejẹnni
\mt2 Ndị Tẹsalonika
\mt1 Ndị Tẹsalonika, Nke Ibuzọ
\c 1
\cl Isi Nke Ohu
\p 
\v 1 Pọlụ lẹ Sivanọsị\f + \fr 1:1 \ft Saịlasị\f* lẹ Timoti de ẹhụhụọ-ozini. Ẹnyi dejẹnni ụka Tẹsalonika hụn rị imẹ Osolobuẹ Nẹdi ẹnyi lẹ Di-nwọnni-ẹnyi wụ Jesu Kristi ya. Ẹfọma lẹ udọn ya rịnị ụnụ.
\s1 Ezigbo Okukwe Ndị Tẹsalonika
\p 
\v 2 Ogẹn ile kẹ ẹnyi gi a kpanmịn Osolobuẹ makẹ ụnụ ile, a kpọ ẹfan ọnụ ogẹn ile ẹnyi gha e mẹ ekpere.
\v 3 Makẹni, ogẹn ile kẹ ẹnyi gi a nyanhan ụnụ ebe Osolobuẹ ẹnyi wụ Nẹdi ẹnyi rị. Ẹnyi a nyanhan ọrụn ọnụ rị a rụn makẹni ọnụ kweri ekweri lẹ ihiẹn-ọma ile ọnụ rị e mẹ makẹ ihiẹn-ọsụsụọ ọnụ nwẹ, lẹzi kẹ ụnụ dọn wuzokẹnmẹ makẹni ụnụ nwẹ olile-ẹnya ebe Di-nwọnni-ẹnyi wụ Jesu Kristi rị.
\p 
\v 4 Umunẹ ẹnyi hụn rị Osolobuẹ obi, ẹnyi a marịnghọ nị Osolobuẹ a họrịgụọ ụnụ nke-esi.
\v 5 Makẹni, oziọma ẹnyi zi ụnụ egini oku-ọnụ sụọ bịanị ụnụ, kama, o gizi ikẹn lẹ ihiẹn Mmọn-nsọ e mẹ bịa; ọ nọ ruchanrịn ụnụ akpakalị obi, wechanrịn ụnụ ẹnya nị ezioku k'ọ wụ.
\p Ẹlẹdẹ ọhụn sụọ: ụnụ a marịngụọzị kẹ ẹnyi dọn bi ogẹn ẹnyi gi rị imẹ igunrun ụnụ. Ẹnyi bi ẹrịra kẹn'ọ rịnị ụnụ mma.
\v 6 Ụnụ ile nọ kịnrịn ẹnyi lẹ Onyẹ-nwọnni-ẹnyi, gi ịghọghọ hụn gha ẹka Mmọn-nsọ bịa nabanhan oku-Chuku—ọ sụọn'a n'o wẹhẹni ụnụ afụnfụn ọda-ọda.
\v 7 Nke wụ nị ụnụ nọ hẹnrin ihiẹn ndị kwerini rịsọnmẹ Masẹdonia lẹ Akaya e leri.
\v 8 Makẹni, oku Onyẹ-nwọnni-ẹnyi a ghagụọ ẹka ụnụ ghagbarị—ẹlẹdẹ imẹ Masẹdonia lẹ Akaya sụọ, a nụchanrịngụọ wẹ banyeni okukwe ụnụ nwẹ imẹ Osolobuẹ ebe ile—nke wụ nị ọrịzịnị mkpa nị ẹnyi kumẹ ẹ.
\v 9 Makẹni, wẹ hụ e ku oku ẹnyi; wẹ hụ e ku kẹ ọnụ dọn nabanhan ẹnyi ogẹn ẹnyi gi bịa d'e zi ọnụ oziọma. Wẹ hụ e kuzi kẹ ọnụ dọn gha ifee-mmọn gbehutọ d'e femẹ ezigbo Osolobuẹ hụn rị ndụn,
\v 10 e che Nwa a hụn k'a gha elu-igwee bịa. Nwa a, hụn ọ gha ọnwụn weli—ya wụ Jesu, Jesu hụn a zụọfụhanị ẹnyi, amamgbe iwe-lẹ-ọnụma Osolobuẹ hụn lalanị e kunrun ẹnyi.
\c 2
\cl Isi Nke Ẹbụọ
\s1 Ọrụn Pọlụ Wẹ Rụn Imẹ Tesalonika
\p 
\v 1 Umunẹ, ụnụ lẹ enwẹn ụnụ a marịngụọ nị ijẹn ẹnyi bịa ebe ụnụ rị alanị iwi.
\v 2 Ụnụ a marịnghọ afụnfụn ẹnyi ta imẹ Filipi lẹ kẹ wẹ dọn gbe ifẹnrẹn ye ẹnyi ihun ebẹhụ nị ẹnyi d'a bịa Tẹsalonika d'e zi ụnụ oziọma. Kanị, ọsụọn'a nị wẹ kpokpo ẹnyi ọda, ndụn agụnị ẹnyi, egun atụnị ẹnyi—makẹni ẹnyi rị imẹ Osolobuẹ ẹnyi—ẹnyi nọzị zi ụnụ oziọma Osolobuẹ.
\p 
\v 3 Ẹnyi ezini oziọma nị ẹnyi gi ẹ dufie ịhịan mọbụ nị ẹnyi chọkọ ihiẹn zinlẹni mọbụ nị ẹnyi gi ẹ tụnarịn ịhịan ihiẹn ẹ.
\v 4 Mba! Kama, kẹ Osolobuẹ dọn weri ẹnyi kẹ ndị furu o gi e dọn ẹnya, bu ọrụn izi-oziọma che ẹnyi ẹka, ẹrịra kẹ ẹnyi e kuzi oku kẹ ndị furu wẹ gi e dọn ẹnya. Ẹnyi ara ku n'ọ sụọ ịhịan—kama, ẹnyi e ku n'ọ sụọ Osolobuẹ hụn e lele obi ẹnyi.
\p 
\v 5 Osolobuẹ wụ ọshẹri ẹnyi, kanị ụnụ lẹ enwẹn ụnụ a marịnghọzịkwọ—nị ẹnyi egini oku a sụọnị wẹ gi e dufie ịhịan bịa, ẹnyi egizikwọnị ẹnya-uku bịa—gi ihiẹn ọzọ kpuru ihun!
\v 6 Ẹnyi emẹni nị ịhịan ja ẹnyi mma—kẹ ụnụ kẹ ndị ọzọ.
\v 7 Ọsụọn'a nị ẹnyi nwọn ikẹn sị ụnụ ye ẹnyi ihiẹn runi ẹnyi nọkẹ ndị-ozi pụ-ichẹn Kristi, ẹnyi emẹni ẹrịra. Kama, ẹnyi gụn agụngụn ụmụẹka imẹ ụnụ, e gi ẹka-alụlụa e sọn ụnụ nọkẹ ebe nnẹ-ọmụmụ rị a zụn ụmụ a.
\v 8 Makẹni ụnụ rị ẹnyi obi ọda ẹnịna, ẹnyi nọ kwademẹ ni ẹlẹ oziọma Osolobuẹ sụọ kẹ ẹnyi k'e ye ụnụ, kama, nị ẹnyi k'e yezikwọ ụnụ enwẹn ẹnyi, makẹni ọ sụọ ẹnyi asụọ—makẹni ụnụ a rịgụọ ẹnyi obi ọda-ọda!
\p 
\v 9 Umunẹ, ụnụ a nyanhanghọ kẹ ẹnyi dọn a rụn ọrụn, a rụngbu enwẹn ẹnyi ogẹn hụ. Ẹnyi a rụn kẹ uhinhin kẹ efinnaị, amamgbe ẹnyi gha a wụrụ nị onyẹ ọwụlẹ ibu imẹ ụnụ ebe ẹnyi rị e zi ụnụ oziọma Osolobuẹ.
\p 
\v 10 Ụnụ wụ ọshẹri ẹnyi; Osolobuẹ wụzịkwọ ọshẹri—nị ẹnyi mẹsọn ụnụ ndị kwerini omumẹ rị nsọ, rị mma ẹnya Osolobuẹ lẹ omumẹ nwọnlẹni nkọrịanị.
\v 11 Ụnụ a marịnghọ nị ẹnyi gi ẹka nẹdi gi e sọn ụmụ a sọn onyẹ ọwụlẹ imẹ ụnụ:
\v 12 a dụn ọnụ ọdụn, a gba ọnụ umẹ, a rịọ ọnụ—nị ụnụ e bi obibi furu Osolobuẹ hụn kpọ ụnụ d'e sọn ẹ nọdị imẹ Alị-eze ẹ lẹ ọghọ a.
\p 
\v 13 Ẹnyi a kpanmịnzịkwọ Osolobuẹ ogẹn ile, nị, ogẹn ụnụ gi nabanhan oku-Osolobuẹ ụnụ nụ ọnụ ẹnyi, ụnụ anabanhann'a kẹ oku ịhịan, kama, ọnụ nabanhan a kẹ ihiẹn ọ wụ nke-esi—oku Osolobuẹ; ya wụ oku-osolobuẹ rị nwan ọrụn imẹ ndụn ọnụ ndị kwerini.
\p 
\v 14 Umunẹ, nke ụnụ rịzị kẹ nke ndị ụka rịsọnmẹ Azụụn Judia, alị ndị Ju—makẹni, ụdị afụnfụn ohu hụ ụnụ ta ẹka ndị alị ụnụ kẹ wẹ lẹ enwẹn wẹ ta ẹka ndị Ju.
\v 15 Ndị Ju, hụn gbu Di-nwọnni-ẹnyi wụ Jesu Kristi lẹ ndị-amụma, chụfụzịkwọ ẹnyi. W'e mẹsọnmẹ ihiẹn ghalẹni a sụọ Osolobuẹ; a lụsọn onyẹ ọwụlẹ—
\v 16 ghahanị igbọndọn ẹnyi ezilẹ ndị anị ọzọ ozi wẹ k'e gi nwọn nzụọrị! Ẹrịra kẹ w'e mẹ ogẹn ile hụn wẹ gi e mẹjun mkpu njọ wẹ ile. Kanị, iwe-lẹ-ọnụma Osolobuẹ e kunrungụọ wẹ nwan ịkpazụụnnị.
\s1 Kẹ Wẹ Dahan Pọlụ Wẹ!
\p 
\v 17 Umunẹ, o mẹ nke ẹnyi, ẹkẹrẹ ogẹn ahụn ẹnyi lẹ ụnụ gilẹni hụn, obi ẹnyi hụkwọ ebe ụnụ rị; kanị, makẹni ẹnyi ahụnnị ụnụ elee-m, elee-i, o te rị ẹnyi kẹ sị ẹnyi wụ ụmụ wẹ latọ. Ya kẹ ụnụ nọ dama ẹnyi, dama ẹnyi ọda-ọda!
\v 18 Ẹnyi te chọ nị ẹnyi bịazị d'a hụn ụnụ—tụmadụ mmẹ nwẹn wụ Pọlụ: a nwanghọ m mgbe ole-lẹ-ole nị m bịa—kanị Ekwensụ gbọndọn ẹnyi.
\p 
\v 19 Ẹghẹẹ, kị wụzị nwan olile-ẹnya ẹnyi? Kị wụzị nwan ịghọghọ ẹnyi? Kị wẹ k'e gi tu ẹnyi ugọn? Onyẹ kẹ ẹnyi k'e gi nyan isi ihun Di-nwọnni-ẹnyi wụ Jesu ogẹn o k'e gi bịa? Ẹlẹ ụnụ?
\v 20 Eziẹ, ụnụ wụ ọghọ ẹnyi lẹ ịghọghọ ẹnyi!
\c 3
\cl Isi Nke Ẹtọ
\s1 Ọ Rịnị Ụka Mma, Ndụn A Ban Ndị-isi Wẹ
\p 
\v 1 Mgbe ẹnyi gilẹni nwan sazị ẹka din ẹ, ẹnyi nọ sị nị ọsụọn'a nị ẹnyi sụọ k'a nọdị Atẹnsị, ẹnyi a nọdị.
\v 2 Ẹnyi nọ gwẹrụ zi Timoti nwẹnẹ ẹnyi hụn ẹnyi lẹ ịya gba a rụnnị Osolobuẹ ọrụn izisọnmẹ oziọma Kraịstị d'a gba ụnụ umẹ, mẹ ụnụ zekẹnmẹ imẹ okukwe ụnụ—
\v 3 amamgbe ukpokpo ndịnị gha e mẹhunmẹ onyẹ ọwụlẹ imẹ ụnụ. Ụnụ lẹ enwẹn ụnụ a marịnghọ ezioku-ezioku nị ukpokpo ndịnị wụ okeri ẹnyi imẹ Kraịstị.
\v 4 Ezioku-ezioku, ẹnyi gwatọ ụnụ ya ogẹn ẹnyi lẹ ọnụ gi rị ụzọ ohu, nị wẹ jẹnkọ d'e kpokpo ẹnyi. Ụnụ lẹ enwẹn ọnụ a marịnghọ n'o mẹọlẹ nwan ẹrịra.
\v 5 Makẹ ukpokponi bịanị nị ụnụ, asazịnị m ẹka din. M nọ zi ozi, nị m marịn kẹ okukwe ụnụ nọ, makẹni egun rị a tụn m nị, ikẹnkwọ, onyẹ-ọnwụnwan a nwangụọ ụnụ, ihiẹn ẹnyi rụn a la iwi.
\p 
\v 6 Kanị, Timoti a ghagụọ nwan ebe ụnụ rị lụa; o wẹhẹgụọ nị ẹnyi ozi rị mma banyeni okukwe ụnụ lẹ ihiẹn-ọsụsụọ ụnụ nwẹ. O kugụọzị kẹ ụnụ dọn a nyanhan ẹnyi ọhụnma-ọhụnma, kuzikwọ nị ẹnyi hụ a da ụnụ—kẹ ụnụ dọn a da ẹnyi.
\p 
\v 7 Umunẹ, ya wụ nị e gigụọ wẹ nwan okukwe ụnụ gba ẹnyi umẹ imẹ nsọngbu lẹ ukpokpo ẹnyi ile.
\v 8 Ndụn a bangụọ nwan ẹnyi—ebe o mẹ ni ụnụ turuhụ imẹ Di-nwọnni-ẹnyi.
\p 
\v 9 Euu, nanị kẹ ẹnyi a dọn saẹka kelegụụ Osolobuẹ makẹ ụnụ, makẹ ịghọghọ ile ẹnyi rị e nwọn ebe Osolobuẹ rị makẹ owuzo ụnụ wuzo imẹ Kraịstị?
\v 10 Ẹnyi e mẹshi ekpere ikẹn uhinhin lẹ efinnaị nị ẹnyi lẹ ụnụ hụntarị ẹnya, kẹni ẹnyi hụn ụzọ ye ụnụ ihiẹn ọwụlẹ rị a kọnị ụnụ ebe okukwe ụnụ rị.
\s1 Ekpere Pọlụ Wẹ Mẹni Wẹ
\p 
\v 11 Chuku ẹnyi wụ Nẹdi ẹnyi lẹ enwẹn ẹ ya dodo duhẹ ẹnyi nwan ebe ụnụ rị, ịya lẹ Di-nwọnni-ẹnyi wụ Jizọsị!
\v 12 Di-nwọnni-ẹnyi ya mẹzikwọ ihiẹn-ọsụsụọ ụnụ bawaye ụba ẹgbata ọnụ lẹ ibe ọnụ lẹ ẹgbata ọnụ lẹ ndị ọzọ ile—rịkẹ kẹ ihiẹn-ọsụsụọ ẹnyi nwọn ebe ụnụ rị gi a bawaye.
\v 13 Ya mẹ obi ụnụ zekẹnmẹ ebe ịrị-nsọ rị, amamgbe ụnụ gha e nwọn nkọrịanị ihun ẹnya Chuku Nẹdi ẹnyi ogẹn hụ Di-nwọnni-ẹnyi wụ Jesu lẹ ndị nke ẹ, ndị nsọ a, k'e gi bịa.
\c 4
\cl Isi Nke Ẹnọ
\s1 Obibi Hụn A Sụọ Osolobuẹ
\p 
\v 1 Umunẹ ẹnyi, igi mẹkin, ẹnyi gi ẹfan Di-nwọnni-ẹnyi wụ Jizọs' a rịọ ụnụ: bisọnmẹ ni obibi hụ ụnụ mụnarịn ẹnyi nị 'ya a sụọ Osolobuẹ ụsụọ—obibi ahụn ụnụ rị nwan e bi; bikẹnmẹ ni ẹrịra.
\v 2 Makẹni, ụnụ a marịngụọ iwu ẹnyi gisọnmẹ ẹfan Di-nwọnni-ẹnyi wụ Jesu ye ụnụ.
\p 
\v 3 Makẹni, uche Osolobuẹ wụ nị ụnụ rị nsọ; nị ụnụ jụchanrịn ughẹrẹ;
\v 4 nị onyẹ-onyẹ imẹ ụnụ marịn k'o dọn kwọndọn ẹhụ a, dọnmẹ ẹ nsọ, mẹ ẹ nwẹ mgbaye;
\v 5 ẹlẹ hụn imẹ-mgba e gi lagbu ẹ ẹnya lẹkẹ ndị hụn marịnlẹni Osolobuẹ;
\v 6 nị ịhịan ewerikọ ihiẹn nwẹnẹ ẹ mọbụ mẹgbu nwẹnẹ ẹ imẹ ihiẹnni. Ẹnyi a gwagụọ ụnụ ya mbụ, gba ụnụ mkpịnsịn-ẹka, nị Di-nwọnni-ẹnyi e mẹgwarịkwọ ụdị ihiẹn ndịnị ile.
\v 7 Makẹni, ẹlẹ obibi ru unyin kẹ Osolobuẹ kpọ ẹnyi d'e bi, kanị obibi rị ọchan.
\p 
\v 8 Ya wụ, onyẹ ọwụlẹ jụ n'o gikọ iwu ndịnị bi, ẹlẹ iwu ịhịan k'ọ jụ, kanị nke Osolobuẹ, bụ Osolobuẹ nwẹn e ye ụnụ Mmọn-nsọ a.
\p 
\v 9 O mẹ nke inwẹtarị ihiẹn-ọsụsụọ nọkẹ umunẹ imẹ Kraịstị, ọ rịnị mkpa nị wẹ deni ụnụ ihiẹn ọwụlẹ. Makẹni, Osolobuẹ e gigụọ ẹka a kuzi ụnụ inwẹ ihiẹn-ọsụsụọ ibe ụnụ.
\p 
\v 10 Eziẹ rọ nị ụnụ hụ e nwẹ ihiẹn-ọsụsụọ ndị ile kwerini rị Azụụn Masẹdonia. Kanị, ẹnyi rị a rịọ ụnụ, umunẹ, nị ụnụ e mẹkẹnmẹ ẹrịra,
\v 11 nị ụnụ a chọkẹnmẹzị ni nị ụnụ e bi obibi mẹ jụụ, e bu ẹnya e zimẹ ọrụn ụnụ, e gi ẹka ụnụ a lụrụ—rịkẹ kẹ ẹnyi dọn gwa ụnụ mbụ.
\v 12 Ụnụ e gi ẹ mẹ ndị kwerilẹni a gbaye obibi ụnụ, gi ẹ hụn nị o nwọnni ihiẹn a kọnị ụnụ.
\s1 Ọbịbịa Jesu
\p 
\v 13 Umunẹ, ẹnyi chọ nị ụnụ marịn ihiẹn k'e mẹ ndị rị ụran (ndị nwụnnị), makẹ ụnụ gha a kwan kẹ ndị hụ nwọnlẹni olile-ẹnya dọn a kwan.
\v 14 Makẹni, ebe o mẹ ni ẹnyi kweri nị Jesu nwụn, lihizi, ẹrịra kẹ ẹnyi gizi kweri nị Osolobuẹ k'e wekinhẹn ya lẹ ndị hụn kwerini n'ẹ hụn rị ụran (ndị nke ẹ nwụnhụnnị).
\p 
\v 15 Nị ẹnyi gwa ụnụ ọnwan makẹni oku Di-nwọnni-ẹnyi rọ: ẹnyi ndị hụn rị ndụn, hụn kelẹni nwụnhụn ogẹn Di-nwọnni-ẹnyi k'e gi bịa, ebukọnị ndị hụ rị ụran ụzọ d'e kunrun Di-nwọnni-ẹnyi.
\v 16 Makẹni, o ru ogẹn hụ, Di-nwọnni-ẹnyi k'e gi okẹn olu ku oku; wẹ k'a nụ olu onyẹ-isi ndị mmọn-ozi; opi Osolobuẹ k'a han—Di-nwọnni-ẹnyi wụ Kraịstị a gha elu-igwee hidan; ndị nke Kraịstị hụn ranhịngụnị e bugụụ ụzọ gha ọnwụn lihi.
\v 17 Ogẹn hụ, wẹ k'a jụrụ ẹnyi ndị họdụnị, ndị rịkwọ ndụn, cheni wẹ imẹ orukpu, ẹnyi e shi elu d'e kunrun Di-nwọnni-ẹnyi imẹ-elu—ẹrịra kẹ ẹnyi k'a dọn buru Di-nwọnni-ẹnyi d'e sọn ẹ nọdị jẹnrin ejẹn.
\v 18 E gi ni nwan oku ndịnị a kasị ibe ụnụ obi.
\c 5
\cl Isi Nke Isẹn
\s1 Kwademẹ Ni Ọbịbịa Jesu
\p 
\v 1 Kanị, umunẹ—o mẹ nke ogẹn lẹ udu o k'e gi mẹ—ọ rịnị mkpa nị wẹ deni ụnụ ihiẹn ọwụlẹ.
\v 2 Makẹni, ụnụ lẹ enwẹn ụnụ a marịngụọ ọhụnma-ọhụnma nị Ụhụọhịn hụ Di-nwọnni-ẹnyi k'e gi bịa, o k'a bịa idẹnmizi kẹ ohin a bịa imẹ abalị.
\v 3 Ogẹn hụ wẹ k'e gi rị a sị, “Udọn a rịgụọ! Nsọngbu arịzị a!” ya kẹ ntikpọ k'e gi kunrun wẹ idẹnmize, nọkẹ ebe imẹ nọ mẹmẹhụ okpoho! Mwanahịn arịkọzị a!
\p 
\v 4 Kanị nke ụnụ, umunẹ, ọnụ arị imẹ ishi, hụn Ụhụọhịn hụ e gi kunrun ọnụ idẹnmize nọkẹ ohin.
\v 5 Makẹni, ụmụ ukpẹ lẹ ndị e bi ebe eki rị enu kẹ ụnụ wụ; ẹnyi ẹlẹ ụmụ ukinkin mọbụ ụmụ ishi.
\v 6 Ya wụ, ẹnyi aranhịnkọ nị kẹ ndị ọzọ; kama, nị ẹnyi mụnrụn nị ẹnya, nị ẹnyi dọnrin ẹnya.
\v 7 Makẹni, uhinhin kẹ ndị a ranhịn ụran gi a ranhịn; uhinhin kẹ ndị a ra manya a tụ gizi a ra a tụ.
\v 8 Kanị, ebe ẹnyi wụ ndị e bi ebe eki rị elu, nị ẹnyi dọnrin ni nwan ẹnya; nị ẹnyi yiri okukwe lẹ ihiẹn-ọsụsụọ kẹ ẹwuru igwe onyẹ-agha gi e gbọndọn obi ẹ, ẹnyi e yiri olile-ẹnya nzụọpụha nọkẹ okpu onyẹ-agha gi e gbọndọn isi ẹ.
\v 9 Makẹni, Osolobuẹ etumẹni ẹnyi d'a narịn afụnfụn iwe-lẹ-ọnụma a; kama, ọ kpọ ẹnyi d'e nwọnrin nzụọpụha ghahanị Di-nwọnni-ẹnyi wụ Jesu Kristi.
\v 10 Makẹni, Di-nwọnni-ẹnyi wụ Jesu Kristi nwụnnị ẹnyi ọnwụn kẹni ẹnyi hụn ụzọ sọn ẹ rị ndụn—kẹ ẹnyi rị ndụn ogẹn o gi bịa kẹ ẹnyi a nwụnhụngụọ.
\p 
\v 11 Ya wụ, a gba nị nwan ibe ụnụ umẹ—kẹ ụnụ dọn rị e mẹ; e yeni ni ibe ụnụ ẹka nị w'e sue—kẹ ụnụ dọn rị e mẹ.
\s1 Ndụnmọdụn Ịkpazụụn Lẹ Ekele
\p 
\v 12 Kanị, umunẹ, ẹnyi rị a rịọ ụnụ nị ụnụ gbaye ndị rị a rụnshi ọrụn ikẹn imẹ ụnụ, hụn e lepụ ọnụ ẹnya imẹ Di-nwọnni-ẹnyi, a dụn ọnụ ọdụn.
\v 13 E nwẹ ni ihiẹn-ọsụsụọ wẹ, e gi ifiri ẹ e ye wẹ mgbaye kachanrịnnị—makẹ ọrụn wẹ rị a rụn. Udọn ya rịsọnmẹ ẹgbata ọnụ lẹ ibe ọnụ.
\p 
\v 14 Umunẹ, ẹnyi rị a dụn ụnụ ọdụnnị: a gba nị ndị nọdị mmaka mkpịnsịn-ẹka; a kasị nị ndị-ụjọ obi; e yeni ni ndị zelẹni ẹka—ka gi ni ndidi e sọn onyẹ ọwụlẹ.
\v 15 Hụn n'a n'o nwọnni onyẹ ọwụlẹ imẹ ụnụ e gi njọ a kụ njọ, kama, a chọ nị nị ụnụ e mẹ ni ibe ụnụ lẹ ndị ọzọ ile ihiẹn rị mma.
\p 
\v 16 A ghọghọ nị ogẹn ile.
\v 17 E mẹ ni ekpere ogẹn ile.
\v 18 E ye ni ekele imẹ ọnọdị ọwụlẹ, makẹni ọnwan kẹ Osolobuẹ chọ ẹka ụnụ imẹ Kristi wụ Jesu.
\p 
\v 19 Etinyụnlẹ ni ihiẹn Mmọn-nsọ rị e mẹ.
\v 20 Elelịalẹ ni amụma lẹ ozi ịhịan sị Osolobuẹ sị a zi—
\v 21 kama, e lele ni ihiẹn ile, ụnụ e kwọnkẹnmẹ hụn rị mma.
\v 22 Gba nị nị ụdị eje-ihiẹn ọwụlẹ ọsọ.
\p 
\v 23 Osolobuẹ lẹ enwẹn ẹ, hụn udọn gha ẹka a bịa, ya dodo dọnchanrịn ihiẹn ile rị imẹ ndụn ụnụ nsọ: ya dọnmẹchanrịn mmọn ụnụ lẹ umẹ-ndụn ụnụ lẹ ẹhụ ọnụ ọhụnma—amamgbe ọnụ gha e nwọn nkọrịanị ogẹn Di-nwọnni-ẹnyi wụ Jesu Kristi k'e gi bịa.
\v 24 Onyẹ hụn kpọ ọnụ furu wẹ gi e dọn ẹnya, o jẹnkọ d'e mẹ ẹ!
\p 
\v 25 Umunẹ, e mẹ ni ni ẹnyi ekpere!
\p 
\v 26 Dide ni umunẹ ẹnyi ile odide rị nsọ.
\p 
\v 27 M rị e gi ẹfan Di-nwọnni-ẹnyi a sị ọnụ gụnnị ndị ile kwerini ẹhụhụọ-ozini.
\p 
\v 28 Ẹfọma Onyẹ-nwọnni-ẹnyi wụ Jesu ya nọyeni ụnụ.
