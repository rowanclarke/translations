\v 2 “\w BOEIPA|strong="H3068"\w* loh \w he|strong="H3541"\w* ni a \w thui|strong="H0559"\w*. \w He|strong="H2063"\w* \w khopuei|strong="H5892"\w* \w kah|strong="H9996"\w* \w khosa|strong="H3427"\w* rhoek te \w cunghang|strong="H2719"\w* \w neh|strong="H9996"\w*, \w khokha|strong="H7458"\w* \w neh|strong="H9996"\w*, \w duektahaw|strong="H1698"\w* \w neh|strong="H9996"\w* \w duek|strong="H4191"\w* uh ni. \w Tedae|strong="H9999"\w* \w Khalden|strong="H3778"\w* \w taengah|strong="H0413"\w* aka \w mop|strong="H3318"\w* tah hing rhoe \w hing|strong="H2421"\w* ni. \w A|strong="H9909"\w* \w hinglu|strong="H5315"\w* te \w a|strong="H9909"\w* \w taengah|strong="H9997"\w* \w kutbuem|strong="H7998"\w* \w bangla|strong="H9997"\w* \w om|strong="H1961"\w* \w vetih|strong="H9999"\w* \w hing|strong="H2421"\w* ni.  
