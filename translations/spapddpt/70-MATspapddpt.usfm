\c 15  
\s1 Tradición de los ancianos  
\p
\v 1 \w Entonces|strong="G5119"\w* \w unos|strong="G3588"\w* \w fariseos|strong="G5330"\w* \w y|strong="G2532"\w* \w escribas|strong="G1122"\w* \w de|strong="G3588"\w* Jerusalén \w se|strong="G2532"\w* acercaron a \w Jesús|strong="G2424"\w*, \w y|strong="G2532"\w* \add le\add* preguntaron:  
\v 2 ¿\w Por|strong="G1223"\w* \w qué|strong="G3588"\w* \w tus|strong="G3588"\w* \w discípulos|strong="G3101"\w* quebrantan \w la|strong="G3588"\w* \w tradición|strong="G3862"\w* \w de|strong="G1223"\w* \w los|strong="G3588"\w* \w ancianos|strong="G4245"\w*? \w Porque|strong="G1063"\w* \w no|strong="G3756"\w* se lavan \w las|strong="G3588"\w* \w manos|strong="G5495"\w* \w cuando|strong="G3752"\w* \w comen|strong="G2068"\w* pan.   
\p
\v 3 \w Él|strong="G3588"\w* les replicó: \wj ¿\+w Por|strong="G1223"\+w* \+w qué|strong="G3588"\+w* \+w también|strong="G2532"\+w* ustedes quebrantan \+w el|strong="G3588"\+w* \+w Mandamiento|strong="G1785"\+w* \+w de|strong="G1223"\+w* \+w Dios|strong="G2316"\+w* \+w por|strong="G1223"\+w* \+w causa|strong="G1223"\+w* \+w de|strong="G1223"\+w* \+w su|strong="G3588"\+w* \+w tradición|strong="G3862"\+w*?\wj*  
\v 4 \wj \+w Porque|strong="G1063"\+w* \+w Dios|strong="G2316"\+w* \+w dijo|strong="G3004"\+w*: \wj*  
\m \wj \+w Honra|strong="G5091"\+w* \+w al|strong="G3588"\+w* \+w padre|strong="G3962"\+w* \+w y|strong="G2532"\+w* a \+w la|strong="G3588"\+w* \+w madre|strong="G3384"\+w*. \wj*  
\p \wj \+w Y|strong="G2532"\+w*: \wj*  
\m \wj \+w El|strong="G3588"\+w* \+w que|strong="G3588"\+w* maldiga \+w al|strong="G3588"\+w* \+w padre|strong="G3962"\+w* \+w o|strong="G2228"\+w* a \+w la|strong="G3588"\+w* \+w madre|strong="G3384"\+w*, \+w muera|strong="G5053"\+w* \+w sin|strong="G2532"\+w* perdón.\wj*   
\p
\v 5 \wj \+w Pero|strong="G1161"\+w* ustedes \+w dicen|strong="G3004"\+w*: \+w Cualquiera|strong="G3739"\+w* \+w que|strong="G3588"\+w* diga \+w al|strong="G3588"\+w* \+w padre|strong="G3962"\+w* \+w o|strong="G2228"\+w* \+w a|strong="G1537"\+w* \+w la|strong="G3588"\+w* \+w madre|strong="G3384"\+w*: \+w Es|strong="G3756"\+w* \+w ofrenda|strong="G1435"\+w* \+w lo|strong="G3588"\+w* \+w que|strong="G3588"\+w* pudieras recibir \+w de|strong="G1537"\+w* \+w mí|strong="G3588"\+w* \+w como|strong="G3739"\+w* beneficio,\wj*  
\v 6 \wj \+w de|strong="G1223"\+w* ningún modo tendrá \+w que|strong="G3588"\+w* honrar \+w a|strong="G1223"\+w* \+w su|strong="G3588"\+w* \+w padre|strong="G3962"\+w*. \+w Así|strong="G2532"\+w* invalidaron ustedes \+w la|strong="G3588"\+w* \+w Palabra|strong="G3056"\+w* \+w de|strong="G1223"\+w* \+w Dios|strong="G2316"\+w* \+w por|strong="G1223"\+w* \+w su|strong="G3588"\+w* \+w tradición|strong="G3862"\+w*.\wj*  
\v 7 \wj ¡\+w Hipócritas|strong="G5273"\+w*! \+w Bien|strong="G2573"\+w* \+w profetizó|strong="G4395"\+w* \+w Isaías|strong="G2268"\+w* \+w con|strong="G4012"\+w* \+w respecto|strong="G4012"\+w* a ustedes: \wj*   
\m
\v 8 \wj \+w Este|strong="G3778"\+w* \+w pueblo|strong="G2992"\+w* \+w me|strong="G1473"\+w* \+w honra|strong="G5091"\+w* \+w con|strong="G1161"\+w* \+add sus\+add* \+w labios|strong="G5491"\+w*, \+w pero|strong="G1161"\+w* \+w su|strong="G3588"\+w* \+w corazón|strong="G2588"\+w* \+w está|strong="G3778"\+w* muy \+w lejos|strong="G4206"\+w* \+w de|strong="G3588"\+w* \+w Mí|strong="G3588"\+w*.\wj*  
\v 9 \wj En vano \+w me|strong="G1473"\+w* adoran, \+w y|strong="G1161"\+w* \+w enseñan|strong="G1321"\+w* preceptos \+w de|strong="G1161"\+w* hombres como \+w doctrinas|strong="G1319"\+w*.\wj*   
