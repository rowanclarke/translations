\c 13
\s1 Amnon loh Tamar A Poeih
\p 
\v 1 \w Te|strong="H3651"\w* \w phoeiah|strong="H0310"\w* \w om|strong="H1961"\w* tih \w David|strong="H1732"\w* \w capa|strong="H1121"\w* \w Absalom|strong="H0053"\w* tah a \w ngannu|strong="H0269"\w* \w sakthen|strong="H3303"\w* om. \w Anih|strong="H9907"\w* \w ming|strong="H8034"\w* tah \w Tamar|strong="H8559"\w* \w tih|strong="H9999"\w* \w David|strong="H1732"\w* \w capa|strong="H1121"\w* \w Amnon|strong="H0550"\w* loh a \w lungnah|strong="H0157"\w*.
\v 2 \w A|strong="H9909"\w* \w ngannu|strong="H0269"\w* \w Tamar|strong="H8559"\w* \w kong|strong="H5668"\w* \w ah|strong="H9996"\w* \w Amnon|strong="H0550"\w* \w te|strong="H9997"\w* \w tloh|strong="H2470"\w* \w la|strong="H9997"\w* a \w yuek|strong="H6887"\w*. \w Anih|strong="H1931"\w* te a \w oila|strong="H1330"\w* pueng \w dongah|strong="H9999"\w* \w khat|strong="H3972"\w* khat a \w saii|strong="H6213"\w* \w ham|strong="H9997"\w* \w Amnon|strong="H0550"\w* \w mik|strong="H5869"\w* \w ah|strong="H9996"\w* \w rhaisang|strong="H6381"\w*.
\v 3 Te \w vaengah|strong="H9999"\w* \w David|strong="H1732"\w* \w maya|strong="H0251"\w* \w Shimeah|strong="H8093"\w* \w capa|strong="H1121"\w*, \w a|strong="H9909"\w* \w ming|strong="H8034"\w* ah \w Jonadab|strong="H3122"\w* tah \w Amnon|strong="H0550"\w* kah a \w paya|strong="H7453"\w* la om. \w Jonadab|strong="H3122"\w* tah \w bahoeng|strong="H3966"\w* aka \w cueih|strong="H2450"\w* \w hlang|strong="H0376"\w* la om.
\v 4 Te \w dongah|strong="H9999"\w* \w anih|strong="H9909"\w* \w te|strong="H9997"\w*, “\w Ba|strong="H4069"\w* aih lae \w mincang|strong="H1242"\w* bal, \w mincang|strong="H1242"\w* bal \w nang|strong="H0859"\w* \w manghai|strong="H4428"\w* \w capa|strong="H1121"\w* he na \w tattloel|strong="H1800"\w* aih. \w Kai|strong="H9901"\w* \w taengah|strong="H9997"\w* na \w thui|strong="H5046"\w* \w mahpawt|strong="H3808"\w* \w a|strong="H9994"\w*?” a \w ti|strong="H0559"\w* nah.
\p Te \w daengah|strong="H9999"\w* \w Amnon|strong="H0550"\w* loh, \w Ka|strong="H9901"\w* \w manuca|strong="H0251"\w* \w Absalom|strong="H0053"\w* \w ngannu|strong="H0269"\w* \w Tamar|strong="H8559"\w* \w ka|strong="H0589"\w* \w ngaih|strong="H0157"\w*,” a \w ti|strong="H0559"\w* nah.
\p 
\v 5 Te \w dongah|strong="H9999"\w* \w anih|strong="H9909"\w* \w te|strong="H9997"\w* \w Jehonadab|strong="H3082"\w* loh, “\w Na|strong="H9905"\w* \w thingkong|strong="H4904"\w* \w dongah|strong="H5921"\w* \w satlo|strong="H2470"\w* bangla \w yalh|strong="H7901"\w*. \w Nang|strong="H9905"\w* te \w sawt|strong="H7200"\w* \w hamla|strong="H9997"\w* \w na|strong="H9905"\w* \w pa|strong="H0001"\w* ha \w pawk|strong="H0935"\w* \w vaengah|strong="H9999"\w* \w amah|strong="H9909"\w* \w taengah|strong="H0413"\w*, '\w Ka|strong="H9901"\w* \w ngannu|strong="H0269"\w* \w Tamar|strong="H8559"\w* ha \w pawk|strong="H0935"\w* \w laeh|strong="H4994"\w* \w vetih|strong="H9999"\w* \w kai|strong="H9901"\w* \w buh|strong="H3899"\w* n'\w tuh|strong="H1262"\w* lah mako. \w Ka|strong="H9901"\w* \w mikhmuh|strong="H5869"\w* \w ah|strong="H9997"\w* \w buhmaeh|strong="H1279"\w* a \w saii|strong="H6213"\w* te ka \w hmu|strong="H7200"\w* dae eh. Te \w daengah|strong="H9999"\w* ni \w a|strong="H9907"\w* \w kut|strong="H3027"\w* \w dongkah|strong="H4480"\w* ka \w caak|strong="H0398"\w* eh?,’ \w ti|strong="H0559"\w* nah,” a \w ti|strong="H0559"\w* nah.
\p 
\v 6 \w Amnon|strong="H0550"\w* te \w satlo|strong="H2470"\w* bangla \w yalh|strong="H7901"\w* \w toengloeng|strong="H9999"\w* \w tih|strong="H9999"\w* \w anih|strong="H9909"\w* te \w sawt|strong="H7200"\w* \w hamla|strong="H9997"\w* \w manghai|strong="H4428"\w* \w te|strong="H9998"\w* ha \w pawk|strong="H0935"\w*. Te \w vaengah|strong="H9999"\w* \w Amnon|strong="H0550"\w* loh \w manghai|strong="H4428"\w* \w taengah|strong="H0413"\w*, “\w Ka|strong="H9901"\w* \w ngannu|strong="H0269"\w* \w Tamar|strong="H8559"\w* ha \w pawk|strong="H0935"\w* \w laeh|strong="H4994"\w* saeh \w lamtah|strong="H9999"\w* \w ka|strong="H9901"\w* \w mikhmuh|strong="H5869"\w* \w ah|strong="H9997"\w* \w vaidam|strong="H3834"\w* \w panit|strong="H8147"\w* ah \w saii|strong="H3823"\w* saeh. Te \w daengah|strong="H9999"\w* ni \w anih|strong="H9907"\w* \w kut|strong="H3027"\w* \w lamkah|strong="H4480"\w* te ka \w caak|strong="H1262"\w* eh?,” a \w ti|strong="H0559"\w* nah.
\p 
\v 7 Te \w dongah|strong="H9999"\w* \w David|strong="H1732"\w* loh \w Tamar|strong="H8559"\w* \w te|strong="H0413"\w* a \w im|strong="H1003"\w* \w la|strong="H9911"\w* a \w tah|strong="H7971"\w* tih, “\w Na|strong="H9903"\w* \w nganpa|strong="H0251"\w* \w Amnon|strong="H0550"\w* \w im|strong="H1003"\w* la \w cet|strong="H1980"\w* \w lamtah|strong="H9999"\w* \w anih|strong="H9909"\w* \w ham|strong="H9997"\w* \w buhmaeh|strong="H1279"\w* \w saii|strong="H6213"\w* pah \w laeh|strong="H4994"\w*,” a \w ti|strong="H0559"\w* nah.
\p 
\v 8 \w Tamar|strong="H8559"\w* te \w a|strong="H9907"\w* \w nganpa|strong="H0251"\w* \w Amnon|strong="H0550"\w* \w im|strong="H1003"\w* la a \w caeh|strong="H1980"\w* \w vaengah|strong="H9999"\w* \w anih|strong="H1931"\w* te ana \w yalh|strong="H7901"\w* pah. \w Vaidamtlam|strong="H1217"\w* \w te|strong="H0853"\w* a \w loh|strong="H3947"\w* tih a \w duep|strong="H3888"\w*, a \w duep|strong="H3888"\w* \w phoeiah|strong="H9999"\w* \w a|strong="H9909"\w* \w mikhmuh|strong="H5869"\w* \w ah|strong="H9997"\w* a \w saii|strong="H3823"\w* pah. Te \w phoeiah|strong="H9999"\w* \w vaidam|strong="H3834"\w* \w te|strong="H0853"\w* a \w thong|strong="H1310"\w* pah.
\v 9 \w Thi-am|strong="H4958"\w* \w te|strong="H0853"\w* a \w loh|strong="H3947"\w* \w tih|strong="H9999"\w* \w a|strong="H9909"\w* \w mikhmh|strong="H6440"\w* \w ah|strong="H9997"\w* a \w poep|strong="H3332"\w* pah \w hatah|strong="H9999"\w* \w caak|strong="H0398"\w* \w hamla|strong="H9997"\w* a \w aal|strong="H3985"\w*. Te \w phoeiah|strong="H9999"\w* \w Amnon|strong="H0550"\w* loh, “\w Ka|strong="H9901"\w* \w taeng|strong="H5921"\w* \w lamkah|strong="H4480"\w* \w hlang|strong="H0376"\w* he \w boeih|strong="H3605"\w* \w tueih|strong="H3318"\w* uh,” a \w ti|strong="H0559"\w* nah.
\p Te \w dongah|strong="H9999"\w* \w hlang|strong="H0376"\w* \w boeih|strong="H3605"\w* te \w anih|strong="H9909"\w* \w taeng|strong="H5921"\w* \w lamloh|strong="H4480"\w* \w nong|strong="H3318"\w* uh.
\v 10 Te \w phoeiah|strong="H9999"\w* \w Amnon|strong="H0550"\w* loh \w Tamar|strong="H8559"\w* \w te|strong="H0413"\w*, “\w Imkhui|strong="H2315"\w* la \w buhmaeh|strong="H1279"\w* hang \w khuen|strong="H0935"\w* \w lamtah|strong="H9999"\w* \w na|strong="H9903"\w* \w kut|strong="H3027"\w* dongah ka \w ca|strong="H1262"\w* eh?,” a \w ti|strong="H0559"\w* nah.
\p Te \w dongah|strong="H9999"\w* \w vaidam|strong="H3834"\w* a \w saii|strong="H6213"\w* \w te|strong="H0834"\w* \w Tamar|strong="H8559"\w* loh a \w loh|strong="H3947"\w* \w tih|strong="H9999"\w* \w imkhui|strong="H2315"\w* \w kah|strong="H9911"\w* \w a|strong="H9907"\w* \w nganpa|strong="H0251"\w* \w Amnon|strong="H0550"\w* \w taengla|strong="H9997"\w* a \w kun|strong="H0935"\w* puei.
\v 11 A \w caak|strong="H0398"\w* \w ham|strong="H9997"\w* \w a|strong="H9909"\w* \w taengah|strong="H0413"\w* a \w tawn|strong="H5066"\w* pah \w vaengah|strong="H9999"\w* tah \w amah|strong="H9907"\w* \w te|strong="H9996"\w* vik a \w tuuk|strong="H2388"\w* \w tih|strong="H9999"\w*, “\w Ka|strong="H9901"\w* \w ngannu|strong="H0269"\w* \w halo|strong="H0935"\w* lamtah \w kamah|strong="H9901"\w* \w neh|strong="H5973"\w* \w yalh|strong="H7901"\w* sih,” a \w ti|strong="H0559"\w* nah.
\p 
\v 12 \w Tedae|strong="H9999"\w* \w anih|strong="H9909"\w* \w te|strong="H9997"\w*, “\w Ka|strong="H9901"\w* \w nganpa|strong="H0251"\w* aw te tlam \w moenih|strong="H0408"\w*, \w kai|strong="H9901"\w* m'\w poeih|strong="H6031"\w* \w boeh|strong="H0408"\w*, \w Israel|strong="H3478"\w* \w khuiah|strong="H9996"\w* \w te|strong="H3651"\w* bang te a \w saii|strong="H6213"\w* noek \w moenih|strong="H3808"\w*. \w Boethaehalang|strong="H5039"\w* \w he|strong="H2063"\w* \w saii|strong="H6213"\w* \w boeh|strong="H0408"\w*.
\v 13 \w Kai|strong="H0589"\w* he \w kamah|strong="H9901"\w* \w kah\w* \w kokhahnah|strong="H2781"\w* \w neh\w* \w melam|strong="H0575"\w* ka \w caeh|strong="H1980"\w* eh. \w Namah|strong="H0859"\w* \w khaw|strong="H9999"\w* \w Israel|strong="H3478"\w* \w khuiah|strong="H9996"\w* hlang \w ang|strong="H5036"\w* \w boeiloeih|strong="H0259"\w* \w bangla|strong="H9995"\w* na \w om|strong="H1961"\w* ve. \w Manghai|strong="H4428"\w* \w taengah|strong="H0413"\w* \w thui|strong="H1696"\w* kanoek lamtah \w nang|strong="H9905"\w* \w taengah|strong="H4480"\w* tah \w kai|strong="H9901"\w* khaw n'\w hloh|strong="H4513"\w* \w mahpawh|strong="H3808"\w*,” \w a \w*\w ti|strong="H0559"\w* \w nah\w*.
