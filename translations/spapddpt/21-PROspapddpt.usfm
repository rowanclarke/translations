\q1 \w Que|strong="H1961"\w* trae su \w pan|strong="H3899"\w* desde lejos.   
\q1
\v 15 Se levanta cuando \w aún|strong="H5750"\w* es \w noche|strong="H3915"\w*,  
\q1 \w Da|strong="H5414"\w* \w alimento|strong="H2964"\w* \w a|strong="H3068"\w* su \w familia|strong="H1004"\w*,  
\q1 \w Y|strong="H3068"\w* la porción asignada \w a|strong="H3068"\w* sus criadas.   
\q1
\v 16 Evalúa un \w campo|strong="H7704"\w* y lo compra,  
\q1 \w Y|strong="H3068"\w* del \w fruto|strong="H6529"\w* de sus \w manos|strong="H3709"\w* planta una \w viña|strong="H3754"\w*.   
\q1
\v 17 \w Ciñe|strong="H2296"\w* con firmeza su cintura,  
\q1 \w Y|strong="H3068"\w* esfuerza sus \w brazos|strong="H2220"\w*.   
\q1
\v 18 Ve \w que|strong="H3588"\w* sus negocios van \w bien|strong="H2896"\w*.  
\q1 \w Su|strong="H3588"\w* \w lámpara|strong="H5216"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* apaga \w de|strong="H3588"\w* \w noche|strong="H3915"\w*.   
\q1
\v 19 Aplica sus \w manos|strong="H3027"\w* \w a|strong="H3068"\w* la rueca,  
\q1 \w Y|strong="H3068"\w* sus dedos manejan el huso.\f + \fr 31:19 \ft Rueca: Instrumento para hilar. Huso: Instrumento para hilar torciendo la hebra.\f*   
\q1
\v 20 \w Extiende|strong="H6566"\w* su \w mano|strong="H3027"\w* al \w pobre|strong="H6041"\w*,  
\q1 Sí, alarga sus \w manos|strong="H3027"\w* al necesitado.   
\q1
\v 21 \w No|strong="H3808"\w* tiene \w temor|strong="H3372"\w* \w por|strong="H3588"\w* \w su|strong="H3588"\w* \w familia|strong="H1004"\w* \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* \w la|strong="H3588"\w* nieve,  
\q1 \w Porque|strong="H3588"\w* \w toda|strong="H3605"\w* \w su|strong="H3588"\w* \w familia|strong="H1004"\w* lleva ropas dobles \w de|strong="H3588"\w* color escarlata.   
\q1
\v 22 Teje tapices para sí.  
\q1 \w De|strong="H4765"\w* lino fino y púrpura es su \w vestido|strong="H3830"\w*.   
\q1
\v 23 Su esposo es \w conocido|strong="H3045"\w* \w en|strong="H5973"\w* la \w puerta|strong="H8179"\w*  
\q1 Cuando \w se|strong="H3045"\w* sienta \w con|strong="H5973"\w* \w los|strong="H3427"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5973"\w* la tierra.   
\q1
\v 24 \add Ella\add* \w hace|strong="H6213"\w* ropa \w de|strong="H5414"\w* lino y la \w vende|strong="H4376"\w*,  
\q1 \w Y|strong="H3068"\w* provee cinturones al mercader.   
\q1
\v 25 Está vestida de fuerza \w y|strong="H5797"\w* dignidad,  
\q1 \w Y|strong="H3068"\w* sonríe ante el mañana.   
\q1
\v 26 \w Abre|strong="H6605"\w* su \w boca|strong="H6310"\w* \w con|strong="H5921"\w* \w sabiduría|strong="H2451"\w*,  
\q1 \w Y|strong="H3068"\w* \w la|strong="H5921"\w* \w ley|strong="H8451"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* clemencia \w está|strong="H5921"\w* \w en|strong="H5921"\w* su \w lengua|strong="H3956"\w*.   
\q1
\v 27 Vigila la marcha de su \w casa|strong="H1004"\w*,  
\q1 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* come su \w pan|strong="H3899"\w* de ociosidad.   
\q1
\v 28 Sus \w hijos|strong="H1121"\w* crecen, y la consideran inmensamente feliz,  
\q1 Su esposo también la \w alaba|strong="H1984"\w* y dice:   
\q1
\v 29 \w Muchas|strong="H7227"\w* \w mujeres|strong="H1323"\w* \w hicieron|strong="H6213"\w* \w el|strong="H5921"\w* bien,  
\q1 Pero \w tú|strong="H6213"\w* \w las|strong="H5921"\w* superaste \w a|strong="H3068"\w* \w todas|strong="H3605"\w*.   
\q1
\v 30 \w Engañosa|strong="H8267"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w gracia|strong="H2580"\w* y vana \w la|strong="H1931"\w* \w hermosura|strong="H3308"\w*,  
\q1 \w La|strong="H1931"\w* mujer \w que|strong="H1931"\w* \w teme|strong="H3373"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w será|strong="H1931"\w* alabada.   
\q1
\v 31 ¡Denle del \w fruto|strong="H6529"\w* \w de|strong="H5414"\w* sus \w manos|strong="H3027"\w*,  
\q1 \w Y|strong="H3068"\w* \w que|strong="H3027"\w* sus mismas \w obras|strong="H4639"\w* la \w alaben|strong="H1984"\w* en la \w puerta|strong="H8179"\w*!   