\id EPH stc-50EPH-Nat.sfm, Ephesians, Natqgu (Santa Cruz) STC, Daniel Boerger, 11/07/2007
\ide UTF-8
\h Efiszs
\toc3 Efiszs
\toc1 Nzryr-krbz Pol Mz Lr Efiszs
\toc2 Efiszs
\mt1 Nzryr-krbz Pol Mz Lr Efiszs
\imt1 Natq Ngr Nzaplxtqngr Mz Nzryr-krbz Pol Mz Lr Efiszs
\ip Aposol Pol yrle letz lc mzli kc tqmnc-ngrde mz presin mrkc Rom. \x + \xo 1:0 \xt Aposol 28:30-31\x* Yrle mz mzlir yiz 60—62 AD mz nibr nzrmcngr mz Jiszs. Mzli lc yr-kzpzle letz mz Filimon, lr Kolosia, x lr Filipae. Letz lcng amrlx dzbede esz' kx nzyrng mz presin. Yrbzle letz lc mz kxnzrlxngiting kxtrngiulrJiu kcng tzmncng Provins kc Esia, mz taon kc Efiszs, yc-aepztrpz mz taon kcng Kolosia x Laodisea. Mzli ka mrlcde nzrpipebz kandre kc Trki.
\ip Pol tryrleu letz lc mz nzatubqti-krde drtwr kx vz-rbr, a' mz nzpipx-krbzle da kxmrlzting amrlx kcng tqkam Gct bagu mz nzaxvctr-krbzku mz Mrlxde. Mz nzvz-nqblq-krgu lrpzki rde x nzmnclz-krbzku mz zmatq ngrde, zmatq lc ycpxm bagu, murde na-aovxioku alwx x Setzn badr drka' nedeng.
\iot Mrkcng Mz Letz Lc
\io1 Da kxmrlzting kcng tzvzpxmqng mz nzaxvctr-krbzku mz Kraes. \ior [1:1—2:10]\ior*
\io1 Kxnzrlxngiting amrlx dzbede kxesz' mz nzaxvctr-krbzlr mz Kraes, kxmule-esz' lr Jiu o kxtrngiulrJiu. \ior [2:11—3:21]\ior*
\io1 Nqmq krdr x nzmnc-krdr natakitrde nzngini-krdr doa neng Gct. \ior [4:1—6:9]\ior*
\io1 Nayrlqbzku dalr vea amrlx kcng tqkam Gct bagu, murde natu-amqngi-ngrgu, mzli kc tqvecku badr Setzn. \ior [6:10-20]\ior*
\io1 Pol ayrkrpxle letz lc mz natq ngr nzarlr-lzbqngr. \ior [6:21-24]\ior*
\is1 Mz letz lc Pol pipx-kzpzle nzycmne-ebzpxngr tq mz nzmnc-krgu badr Kraes:
\io1 Nigu lrmakxtr nrkrdrtq Kraes x nide nargu. \ior [1:22-23; 4:15-16]\ior*
\io1 Apuku ma nyz Gct kc tqtr, tqmncpx-ngrm Mqngrkxtr, x Jiszs nide nou rplz kx myatxpx-zlwzbz mz ma lc. \ior [2:21-22]\ior*
\io1 Jiszs apule ncblo kxyrlz x nigu lrmakxtr apuku olvz rde kc tqmrlzti-zlwzle. \ior [5:23-32]\ior*
\c 1
\p 
\v 1 Ninge Pol kc tqmcpx Gct mz nzngini-krnge aposol ne Mevalu Jiszs. Ryrbo bamu leplz kxnztr neng Gct kcng tzmncng Efiszs, x tzvz-nqblq-angidrlr Mevalu Jiszs.
\v 2 Krka'-ngrbo mz Gct, Trtegu badr Kxetu rgu Jiszs Kxnzmcpx, kx nakabzlr bamu zmrlz ngrdr kxmyalz x nzmnc-zpwxngr.
\s1 Da Kxmrlzting Kcng Tzvzpxmqng Mz Nzaxvctr-krbzku Mz Kraes
\p 
\v 3 Na-awibzku mz Gct, kc tqngi Trte Kxetu rgu Jiszs Kxnzmcpx. Murde mz nzaxvctr-krbzku mz Kraes, Gct kc Heven kapemle bagu da kxmrlzting amrlx elr, mz nzokatr-krde nabzgu mz nzmncngr kxtr.
\v 4 Murde mzli kc nrlc trnzwzka-ngrde, mcpxpele nigu mz nzngini-krgu leplz nedeng x mz nzaxvctr-krbzku mz Kraes, murde nanginigu leplz kxnztrng kxnztubqng mz nzobq-krde.
\v 5 Mz nivz lrde, pnzpe kai drtwr Gct kx naotile nigu mz nzngini-krgu doa angidr nedeng mz Jiszs, murde mrlzbz bade.
\v 6 X naglqlz-ngrgu nide zmrlz ngrde kxmyalz-esz'ngr, kc tqka-nrbalqmle bagu mz nzaxvctr-krbzle nigu mz Mrlxde Kxnzmrlzti. \x + \xo 1:6 \xt Matiu 3:17\x*
\v 7 Jiszs xpele nigu mz mepyr ngrde mz nzarlapx-krde nigu mz zmatq ngr alwx. X dekc tqipqngr Gct nigu mz alwx rgung, mz nzvz-nqblq-krde zmrlz ngrde myalz-esz'ngr.
\v 8 X pulio-ebir-ngrmle zmrlz ngrde lc bagu, mz nzvz-nqblq-krde nzetukr nzyrplapx-krde x nzrkrlz-krde.
\p 
\v 9-10 X mzli ka abrtzlvz Gct nzaelwapx-krmle bagu drtwr kxmyapxbz kc tqyrlq-kaile mzli kc bqnc, tqyc-kapqbz mz kxnzlung amrlx krlzmle mzli ka. Kraes nide nou drtwr lc x atutrle. Murde mz nzkrlz-krbzle mzli kx mcpx Gct, Gct sa na-ayrlwr-lxblrle mz dzbede kxesz' kxnzlung amrlx mrkc Heven x mz nrlc ka, murde namnclzbzng mz Kraes kc nangi nardr.
\v 11 X mcpx Gct nigu x yrlq-pnzle drtwr kx nanginigu doa nedeng mz nzaxvctr-krbzku mz Kraes. X Gct batrpzle da amrlx kx prtzm mz nzvz-nqblq-krde nzyrplapx-krde mz drtwr kc tqyrlqle.
\v 12 Murde nigr lr Jiu, mz nzbrti-kaikr drtwrgr Kraes, nabatrpzkr mz leplz nzglqpx-krdr Gct.
\v 13 X nimu kxtrngiulrJiu nzaxvctrpe-kzpzmu mz Kraes, murde mzli kc tqxlr-ngrnamu natq angidr, sc tqlxngitipe-kzamu Nrpakxmrlz lc. X mz nzbrtikr drtwrmu Kraes nzarlapx-krde nimu, Gct sc tqyrlqtrpebzle bamu rkx ngr nzngini-krmu leplz nedeng. Krlc Mqngrkxtr kc tqpipx-pnzle kx nakabzle mz leplz nedeng.
\v 14 Mqngrkxtr apule trau kx nzka kai mz nzaelwapxngr kx sa naka-kzle da amrlx kcng tqesalz-ngrde. Murde Gct ka-kaipzle Mqngrkxtr mz nzaelwapx-krde kx sa naka-kzpzle da kxmrlzting amrlx kx nzvzpxmqng mz nzngini-krgu leplz nedeng. Murde naglqpxku nide mz nzmrlzkr nqmq krde.
\s1 Pol Krka'-ngrde Lr Efiszs Kxnzrlxngiting
\p 
\v 15-16 Mz nztwz-krgu da kxmrlzting lcng, sc tqkrka'pe-ngrne nimu, abzo mzli kx xlrx kx brtipe drtwrmu Kxetu rgu, Jiszs Kxnzmcpx, x mrlztiamu leplz kxnztrng ne Gct amrlx. X awi-zvz-ngrbo mz Gct nimu.
\v 17 Gct nide Trte Kxetu rgu, Jiszs Kxnzmcpx, x nqmq krdeng amrlx myapx zlwz. X rlxti-zvzbo mz Gct kx nzyrplapxngr x nzrkrlzngr kx kabz Mqngrkxtr naetunepx-zvzng mz nabzmu, murde nzkrlz-krmu Gct naetunepx kz.
\v 18 X nakrlz-kzamu da kxmrlzting kx nakabzle bamu. Murde sa nakabzle da lcng, tqobqtipxamu, mz nzkqle-krde nimu mz nzngini-krmu leplz nedeng. X krka'-ngrne kx nakrlz-angidramu kx nzngini-krmu leplz nedeng ngi da kxmrlz kxmyapxbz mz nabzde.
\p 
\v 19-20 X krka'-ngrne kx naxngi-angidramu zmatq ngrde kxetu-esz'ngr kc tqwz zvz mz nabzgu, mz nzngini-krgu kxnzrlxngiting. Murde mz zmatq kcpwz tqatulz-mou-ngrm Gct Jiszs mz nzbz-krde, x dekcpwz tqawxbuo-ngrmle nide me matq-esz'ngr mz nrlar Gct kxrtc kc Heven. \x + \xo 1:19-20 \xt Sam 110:1\x*
\v 21 X mz nzaclve-krde kc Heven, Jiszs myaszlz-zlwzle kxnzetung amrlx kxmule-esz' mz nrlc ka o mzlilxlr. Myaszlzle nidr mz nzxplr-krde, zmatq ngrde, zmrlue ngrde, x drtqde, kxmule-esz' mzli ka o mzli kc navzm. \f + \fr 1:21 \ft \em 1:18\em* Kzdung leplz mz drtwrdr natq lc tqrmnr-ngrbz natekqtr-kzlr mz nzrpi-krde kx, ‘Krka'-ngrne kx nakrlz-angidramu nzetukr da kxmrlzting kx nakabzle bamu.’ \em 1:21\em* Mz mzli nyz Pol, leplz nzrpir kx enjrl x drka' nzaclveng badr kxnzetu ngr kandre x mztea amrlx. X nzota-etrng mz nztwz-krdr leplz mz nrlarde nyz Gct o Setzn. krkcng tzaovxiolr mrnyzdr batrpzle da mz nrlc ka. Kzdung Kristin nzlxngiti-kzlr drtwr lc, mz nzrlwx-krdr Daniel 4:25 x 10:13. Mc kz Hibru 2:5. \f*
\m 
\v 22 X Gct yrlqlzbzle doa x da amrlx mz zmatq ngr Kraes, \x + \xo 1:22 \xt Sam 8:6\x* (kxmule-esz' leplz, enjrl, drka', animol, o da kxtrnzluung), mz nzmetx-krbzlr bade. \x + \xo 1:22 \xt Sam 110:1\x* Murde nanginide nar leplz amrlx kcng tzprtrng mz lrmakxtr.
\v 23 X lrmakxtr lcng nzaesz'tilr nide, murde nide nardr x nidr nrkrdrtqde. X nide kc tqesz'-ngrde da amrlx.
\c 2
\s1 Nzlungr Vzpxm Mz Nzaxvctr-krbzku Mz Kraes
\p 
\v 1 A' mzli lc trlxngitikalamu Kraes, mqngrmu bz, murde vz-rbr-zvzamu mz nzale-krmu alwx.
\v 2 X mzli lcde, apuamu kxnzmnc-mrbrng mz nrlc, mz nzvz-nqblq-krmu Setzn, kc tqngi kxetu r drka' amrlx kcng tzmncng mrnyzdr mzlilxlr. X nide kc tqvz zvz nzbatr-krbzle mz leplz nzxpqbrlr-krdr Gct.
\v 3 Mzli lc tqmnc-nqblq-kzkr nqmq nr drtwr kxtrka kcng tqyclzm mz nabzgr, mz nzrtrngzti-zvz-krbzkr da kznikeng mrlzm bagr. Nigr leplz kxdrka'-ngrng mz nzapu-krgr leplz amrlx, x takitrde Gct nzayrplapx-krde nigr mz zngya ngr drtwrde.
\p 
\v 4 Kxmule-esz', a' Gct yc zlwz mz drtwrde nigu leplz amrlx, murde aodu-zlwzle nigu.
\v 5 Mzli lcde mqngrgu bz mz nzale-zvz-krgu alwx, a' Gct sc tqalupemle mqngrgu mz nzaxvctr-krbzle nigu mz Kraes. Arlapxle nigu mz nzvz-nqblq-krde zmrlz ngrde kxmyalz.
\v 6 X mz nzaxvctr-krbzku mz Mevalu Jiszs, Gct atulz-kzple nigu mz nzbzngr, x wxbuo-kzku badr me matq Heven. \f + \fr 2:6 \ft Drtwr lc angidatile mqngr kxnzrlxngiting mzli ka x nrkrdrtqdr kx mrna Heven kalr. \f*
\m 
\v 7 Alele da lc murde mzli kc navzm na-aelwapx-angidr-ngrbzle nzetukr zmrlz ngrde kxmyalz-esz'ngr, mz da kx mrlzting amrlx kcng nzvzpxmqng mz nzaxvctr-krbzle nigu mz Kraes.
\v 8-9 Murde nzrlapx-krmu vzpxm mz zmrlz ngr Gct kxmyalz, mz nzokatr-krde nimu mz nzabrtr-krbz drtwrmu mz Kraes. A' nzrlapxngr lc trvzpxpuu mz nimu esz'-krmu. A' Gct kx rka-nrbalqbz bamu, murde ma tqglqpx-lzbq-ngrnamu kx wz-ngrnamu da lc mz zmatq ngrmu esz'-krmu.
\v 10 Gct wz-ngrde nigu mz nzmnc-krgu mz nrlc ka mzli ka. X alule mqngrgu mz nzaxvctr-krbzle nigu mz Mevalu Jiszs. X mzli kc pnz, yrlqle drtwr mz da kxmrlzting kx suti drtwrde nzale-krguleng.
\s1 Lr Jiu X KxtrngiulrJiu Nzngini-krdr Dzbede Kx Esz' Mz Kraes
\p 
\v 11 Nimu kxtrngiulrJiu nadcpx mz drtwrmu kx mzli kc pnz, nzrpi lr Jiu nimu kxtrnzpakrung, a' nidr kxnzpakrng mz nzvz-nqblq-krdr Loukxtr. Nzrpakrngr lc dalr nrkrdrtq, a' tr-rngiscu zmatq ngr nztekqtr-krde nabz leplz.
\v 12 Mzli lcde, nzmnc-krmu trka, murde mnc-rlrubzmu mz Kraes. X ni-kzpu' lr mrkzbleng murde trpnzngr nzprtr-krmu mz nqvi lr Israel, leplz kcng tqmcpx Gct. X trprtr-kzpwamuu mz Nzesz'tikr Drtwrdr badr. X trpnz-kzngr nzkrlz-krmu Gct angidr x drtwrmu kc tqmatxpe nzobqtipxngr da.
\v 13 A' nimu kcng ena nzmnc-rlrubzng mz Gct, mzli ka vec-aepztrpemle nimu bade, mz mepyr ngr Kraes kc tqyrleo mz nzbz-krde nimu.
\v 14-15 X Kraes batrpzle nzmnc-lxblr-krgu mz nrwx, nimu kxtrngiulrJiu x nigr lr Jiu. Kzdung natq x nqmq x nzryr-ngrng mz Lou sc Mosis nzapulr drkq kx akipxle nigu x batrpzle nzngyati-lzbqkr drtwrgu. A' Kraes awxole drkq lc, x sc tqmape lou lcng mz nzrlrpx-krbzle nrkrdrtqde nzbz-krde nigu, murde nanginigu dzbede kxesz' kxmrna mz nzaxvctr-krmle nigu bade. Delc nide nou nrwx ngrgu.
\v 16 Murde yzlumi-kzpzle nigu mz Gct mz dzbede kc esz' mz nzbz-krde nigu mz kros. X mz nzrnibqngr Kraes, awxobzle zngya kx yc mz mzlir nigr lr Jiu x nimu kxtrngiulrJiu, murde namnc-zpwx-ngrgu badr Gct. \f + \fr 2:16 \ft \em 2:14-15\em* Mwx Pol rpile ‘drkq’ mz nzaotikr drtwrde drkq ngr Mangr-nzangiongr Yawe kx akipxle kxtrngiulrJiu mz nzprtr-krdr mrnyz lr Jiu. KxtrngiulrJiu nzkrlzlr nzprtr-krdr mrnyz lr Jiu mz nztekqtr-krdr nzrlxngitingr x mz nzngini-krdr lr Jiu mz nzrpakrngr. Lou kxnzmulr lcng nzakipxngr leplz. Kzdq rpile kx nzmu lr Jiu nzmncng badr kxtrngiulrJiu, sa nabatrpzle mz lr Jiu trnztakitrdeu nzprtrngr mz nzangiongr. Mzli lc pnz, pris neng lr Jiu na-ale-zvzng blz, murde Gct naipqpxle alwx ngr leplz nedrng. A' mzli ka, sc tqangidatipe Jiszs lou lcng, mz nzngini-krde Nei sip ne Gct, kc tqngi blz kxrmnr-ngrbz. \f*
\p 
\v 17 Kraes vzm mz nzryapwxtipx-krde lrpzki r nzmnc-zpwxngr badr Gct. Pibzle bamu, nimu kxnzmnc-rlrubzng mz Gct, x pi-kzple bagr, nigr kxnzmnc-aepztrpzng bade. \x + \xo 2:17 \xt Asaea 57:19\x*
\v 18 Murde mzli ka, mz nzwzkr Kraes, nigu amrlx ngrgu nzaxvctrpzng mz Mqngrkxtr kcpwz, kxmule-esz' lr Jiu o kxtrngiulrJiu, x takitrpegu nztutr-krbzku mz mz Gct Trte.
\v 19 Mz nzmu-krde lcde, nimu kxtrngiulrJiu trpengr nzngini-krmu lrnarnrlc x doa lr mrkzble. Murde mzli ka nipemu lr mztea nyz Gct badr leplz kxnztr nedeng amrlx. X nimu neidu lrde x prtrpe-kzpzmu mz lr ma nyzde.
\v 20-22 X wz-ngrde ma nyzde lc tqtr mz nou rplz kx ngi nzalvztrkr aposol x profet. X Mevalu Jiszs nide rplz lc tqetu tqmyatxpx-zlwzbz, murde nide rplz kc tzatuo kai, tqngi nou bute', x atu-amqngile ma kc. X rplz amrlx ngr ma kc nzaxvctrpzng bade. X apuku rplz lcng tqmwitr lxblr, tqngi drkq ngr ma lc tqtr. X Mqngrkxtr mncpxm elr. \x + \xo 2:20-22 \xt Sam 118:22\x*
\c 3
\s1 Nzwzkr Pol Mz Nzyapwxtipx-krbzle Nrpakxmrlz Mz Leplz KxtrngiulrJiu
\p 
\v 1 Mevalu Jiszs yrlqle ninge nzyapwxtipx-krbo Nrpakxmrlz bamu, nimu kxtrngiulrJiu. X dekc tqmnc-ngrne mrka mz presin, murde alex da lc mz nzokatr-krnge nimu.
\v 2 Mwx xlrpeamu kx Gct aprcmle nzwzngr lc bange, murde napipxbo bamu zmrlz ngrde kxmyalz.
\v 3 Krlc da kx yc-kapq pnz kc tqaelwapx-ngrmle bange, da kc tqwai nzyrpe-krbo mz letz ka.
\v 4 Mz nzrlwx-krmu letz lc, nakrlzamu nzaotikr drtwrnge drtwr kc tqyrlq kai Gct mz nzarlapxngr leplz mz nzbzkr Kraes.
\v 5 Murde traelwapx-ngrpwzleu drtwr lcde badr leplz kcng pnz. A' mzli ka, atwzlr-ngrmle Mqngrkxtr mz aposol x profet kxnztr nedeng mz nzaelwapxpe-krbzlele badr.
\p 
\v 6 Drtwr lcde tqyc-kapq pnz nide sele. Lr Jiu x kxtrngiulrJiu nipedr dzbede kx esz' mz nzlxngiti-krdr Mevalu Jiszs. X nzprtrng rlilrdr mz da kxmrlzting kcng tqesalz-ngrbz Gct kx navzpxmqng mz nzngini-krdr nrkrdrtq Kraes.
\v 7 Mz nzvz-nqblq-krde zmrlz ngr Gct kxmyalz, kamle bange zmatq ngrde, murde nawztrpo bade mz nzyapwxtipx-krnge Nrpakxmrlz.
\v 8 Kxmule esz' leplz nedeng amrlx nzmyaszpxlr ninge, a' mz zmrlz ngrde kxmyalz rlr-ngrmle bange nzyapwxtipx-krbo mz kxtrngiulrJiu da kxmrlzting kx twzku mz Kraes, kx trnzkrlzu me yrkrkipxle. \f + \fr 3:8 \ft Pol rpile kx leplz neng Gct amrlx nzmyaszpxlr nide, murde xngitr-zlwzle nzatrkati-kai-krde kxnzlxngitilr Jiszs. \f*
\p 
\v 9 X Gct kc tqwz-ngrde doa x da amrlx, yrlq-kaile drtwr mzli kc bqnc x yrlq-kapqle krlzmle mzli ka. X suti drtwrde kx nayokaetipxpebo mz leplz, kx mzli ka sc tqvzpe nzatutr-krde drtwr lc.
\v 10 X suti kz drtwr Gct kx nigu lrmakxtr na-aelwapx-ngrbzku nzetukr nzyrplapx-krde mz enjrl x drka' kxnzetung kxnzrngiscng zmatq mrnyzdr mzlilxlr.
\v 11 Da lcng tqale Gct mz nzvz-nqblq-krde me pnz drtwrde kx yrlq-pnzle mzli kc trwzka-ngrde nrlc. X mzli ka angidatipeleng mz nzwzkr Mevalu Jiszs, Kxetu rgu.
\v 12 X mzli ka trmwxlrpekuu nzvz-krbzku mz Gct mz nzkrka'ngr. Murde krlzku kx abrtzlvzle nigu mz nzabrtr-krbzku drtwrgu mz Jiszs x nzaxvctr-krbzku bade.
\v 13 Mz nzmu-krde lcde, bzkq nabzmu talvzo mz nzetqkr drtqnge mz nzyapwxtipx-krbo Nrpakxmrlz bamu, nimu kxtrngiulrJiu. Murde da kx prtzm bange ngi dalr nzokatrngr nimu.
\s1 Pol Krka'-ngrde Lr Efiszs
\p 
\v 14 Mz nzaotikr drtwrnge da lcng tqmrlzting, tzvzpxmqng mz nzaxvctr-krbzmu mz Kraes, atuobo zpr mz nzkrka'-krbo mz mz Gct Trtegu.
\v 15 Murde nide Trte neidu amrlx kx nzmncng Heven x kx nzmncng mrka mz nrlc ka.
\v 16 Mz da lcng tqmrlzting, rlxtibo bade nzka-krbzle bamu zmatq ngr Mqngrkxtr mz nzaxplr-krde nimu navzo la mz nabzmu.
\v 17 Murde namnc zvz mz nabzmu, mz nzbrkr drtwrmu. X krka'-ngrne kx nivz lr Gct nangi dzbr x nou nzmnc-krmu.
\v 18 Murde mz zmatq ngrde nakrlz-angidramu nzetukr nivz lr Kraes. Murde nzyryz-krde, nzboi-krde, nzvzo-krde, x nzmyalz-krde tqvzpe tqvzpe.
\v 19 X krka'-ngrne kx sa naxngibzmu nzetukr nivz lrde mz nabzmu, kxmule-esz' trpnzngr kxrkrlz angidr. Murde na-aelwapx-zpwx-ngrnamu nivz lrde mz nqmq krmung amrlx.
\p 
\v 20-21 Mzli ka takitrde nzglqlz-krgu Gct. Murde krlzle nzalengr da kx myaszpx-zlwzle da amrlx kx rlxtibzku bade x myaszpx-kzle da amrlx kx aoti drtwrgu. X alele da lcng mz zmatq ngr Mqngrkxtr kc tqalu-zvzle nabzgu. Murde nigu lrmakxtr, mz nzaxvctr-krbzku mz Mevalu Jiszs, na-amrlue-zvzku nide, tqvzpe tqvzpe. Eu, angida.
\c 4
\s1 Drtwr Kxnzlxngitilr Kraes Naesz'ti
\p 
\v 1 Lalztqmamu bange. Mncpxmc mz presin murde wztrpo mz Kxetu. Naxplrmibz natqnge mz nzpi-angidr-krbo bamu kx nqmq krmu x nzmnc-krmu natakitrde nzkqlekr Gct nimu mz nzngini-krmu doa nedeng.
\v 2 Lrpzki kx navz-nqblqamu nide sele. Avzo-lzbqamu. Nanginimu leplz ngr nrwx. X bzkq drtwrmu ngya-anibz mz leplz kx nzatrkatilr nimu. A' mz nivz, rlr-ngrbzmu badr mzli r nztekqtr-krdr nqmq nr drtwrdr.
\v 3 Mnc-zvzamu mz nrwx x mz nzesz'tikr drtwrmu mz nzmnclz-krbzmu mz Mqngrkxtr.
\v 4 Murde nanginigu dzbede kxesz' mz da amrlx. Prtrku mz nrkrdrtq kcpwz. Twzku Mqngrkxtr kcpwz. X obqtipxku da kxmrlzting kcpwz mz nzkqlekr Gct nzngini-krgu leplz nedeng.
\v 5 X vz-nqblqku Kxetu kcpwz, mz nzrlxngitingr kcpwz. X mz drtq Gct kc tqngi Trte, Mrlxde, x Mqngrkxtr, prtrku mz nzwrkxtrngr kcpwz. \f + \fr 4:5 \ft Mzli kc Pol tqyr-ngrde letz lc, lrmakxtr trpnzngr nzakipx-lzbq-krdr mz nzwrkxtrngr. \f*
\m 
\v 6 Angioku Gct kcpwz, tqngi Trte leplz amrlx, tqmyaszlzle nigu amrlx, tqmncpxm bagu amrlx, x tqmcpxle nigu amrlx mz nzale-krgu nzwz-krde.
\p 
\v 7 Kxmule-esz', a' Kraes kamle bagu zmatq ngr nzwzngr kx bletipx-lxblrng mz nzwztr-krbzku bade, mz nzvz-nqblq-krde me pnz drtwrde.
\v 8 Da kc tqpingr Nzryrngrkxtr le, kx mz nzvzdzkr Kxetu wq aovxiole enqmi kang kqlu. X kabzle da kxmrlzting mz ncblo. \x + \xo 4:8 \xt Sam 68:18\x*
\v 9 Mz nzxlr-krgu natq lc, ‘vzdz wq,’ nakrlz-kzku kx vzo-kaip yu mz nrlc.
\v 10 Mrlx kc tqvzom, nide kcpwz tqvzdz wq me matq esz'ngr, murde naesz'-ngrde da amrlx mz nrlc atwrnrngr.
\v 11 Nide kcpwz tqyrlqle leplz mz nzwz-krdr murde na-aclvelr lrmakxtr, mz nztwz-krdr nzwzkr aposol, o profet, o kxnzrlepxng Nrpakxmrlz, o kxnzaclvelr leplz nedeng, o kxnzalvztr-ngrdr natqde,
\v 12 mz nzoliqti-krdr leplz neng Gct murde nawztrpzng bade. X mz nzwz-krdr lcng, sa na-axplrlr leplz kcng tqngi nrkrdrtq Kraes,
\v 13 vz vz mzli kx drtwrgu esz'ti mz nzlxngiti-krgu Mrlx Gct x nzkrlz-krgu nide. Murde nzmnc-krgu badr nabr x na-apupwzku Kraes mz nqmq krgu amrlx.
\v 14 Mzli lcpe nzmnc-krgu trapupeleu doa kxnztopwzng kx nztekqtr-ebir-ngrdr drtwrdr apule drtwrdr lcng tqtwzne nrc. Doa lcng tztwzlr nzalvztrngr kzbleng mzli kznikeng nzxlr-ngrdrle, apule da kx tqtwzne nenq. A' trapupekuu nidr, murde mzli ka rblxbz mz kxnzalvztr-rbrng nzesabrti-krdr nigu murde mc-zpwxku nzpokia-krdrng. \x + \xo 4:14 \xt Jud 12-13\x*
\v 15 X mz nzvz-nqblq-krgu nivz angidr, napipx-etrku nzalvztr-ngrng angidr, murde naetunepx-zvzku mz da amrlx mz nzapu-krgu Kraes kc tqngi nargu.
\v 16 X mz nzngini-krde nargu, amwitr-lxblrle leplz nedeng mz nrkrdrtqde, apule neli kxetu kc tqaxvctrle mrkcng kqlu mz nrkrdrtq ncblo. Murde mzli kc doa kxesz' tqale-zpwx-ngrde nzwz-krde mz nzvz-nqblq-krde nivz lr Gct, doa lc aetunepxle nzxplr-krgu, nigu amrlx mz nrkrdrtq Kraes.
\s1 Nqmq Kr Leplz Neng Gct
\p 
\v 17 Mz nzmu-krde lcde, pibo bamu mz drtq Kxetu rgu x mz nzngini-krnge aposol nede, kx bzkq apupeamu kxtrnzrlxngitiung, murde nzaoti zvz drtwrdr da kxmane x trpnzngr nrade. \f + \fr 4:17 \ft Kzdung da kxmane nidr seleng: nzangio-krm drka', nzmnc-xgle-krm zmatq ngrm esz'-krm, nzvz-nqblq-krm nqmq kr leplz kx nzrpwa'-ngrdr nzwzkr Gct, nzpxtxpx-krm natq Gct, x kzdung kz da kxnzmulr lcng. \f*
\m 
\v 18 Rblxbz badr nzkrlz-zpwx-krdr nzalvztrngr angidr, murde nqmq nr drtwrdr lc tqvz-rbr akamrbr-ngrde da mz nabzdr. X nzpxtxpx-ngrdr nzlukr Gct kxmrna murde nardr mqngi x trnzkrlzlru nqmq krde.
\v 19 Trnzclupeung mz da kx myangr drtq, mz nzrlrpx-lzbq-krdr nzvz-nqblq-zvz-krdr da kx mrlzbz mz nrkrdrtqdr. X nzamqmiti-rbrlr nrkrdrtqdr mz nzrmwimi-abeane-krdr leplz kx trngiu krnalzdr. X drtwrdr tresapxu mz nzale-rbr-krdr da lcng.
\p 
\v 20 A' nimu, trngiu da kx nzalvztr-ngrmu lc, mzli kc kai tqxlr-ngrnamu Nrpa ngr Kraes.
\v 21 Murde mzli lc tqxlrpe-ngrnamu kx nzmnc-krmu navz-nqblq-zvzle natq angidr kc tqalvztrngr Jiszs.
\v 22 Rpile kx na-axtxpeamu nqmq kcng pnz tqvz-nqblqamu mzli kc trkrlzka-ngrnamu Gct. Murde nqmq kxdrka'ngr lcdeng nzatrkatilr drtwrmu x nabzmu.
\v 23 A' narlr-ngrbzmu mz Gct nztekqtr-krde nimu, murde nanginimu leplz kxmrna kcng nzao-krmu drtwrmu tqmrna kz.
\v 24 X mz zbq kang kqlu narlrpx-lzbq-ngrnamu mz nzngini-krmu leplz kxmrna, murde navz-nqblq-angidramu Gct x nzmnc-krmu natubq zpwx x nalqngi mz nzobq-krde.
\p 
\v 25 Mz nzmu-krde lcde, bzkq pokiapebzmu mz kztemung, a' rpi-etramu da angidr. \x + \xo 4:25 \xt Sekaraea 8:16\x* Murde nigu amrlx ngrgu leplz ngr nrkrdrtq kcpwz.
\v 26 Kzdung zngya ngr drtwr leplz trngiu alwx. A' aclvetio-lzbqm mzli kc tqngyangr drtwrm, ma tqvz-rbrq. \x + \xo 4:26 \xt Sam 4:4\x* Murde tr-rblxu nzvz-rbrngr mzli kc tqngyangr drtwrm. X bzkq zngya ngr drtwrm boi nzkrlz-krbzle nzmwi-krm mz nrlckxbq. \x + \xo 4:26 \xt Hosia 7:6\x*
\v 27 A' ipq ani kztem murde ma tqrlr-ngrbzme mz Setzn nzatrkati-krde nabzm.
\p 
\v 28 Mrlx kx pna da, bzkq pnape da. A' nawz-kato mz nzatatr-krmle da kx takitrde nide badr lr ma nyzde, vzmi nzokatr-krde nra-nzlu ngr leplz.
\v 29 Bzkq ycmne-atrkatiamu leplz mz nzrpibqti-krmu x nzrlcbqti-krmu nidr. A' rpi-txpwzmu natq kx takitrde nzaxplr-krde nabz leplz neng Kraes, murde na-amrlz-zvzamu krkcng tzlalztqng.
\v 30 Bzkq avzbzmu drtwr Mqngrkxtr, murde ma tqrblxbz bade nzokatr-krde nimu. Murde Mqngrkxtr lc tqmncpxm mz nabzmu ngi rkx ngr nzngini-krmu leplz neng Gct. X nzwz-krde nzokatr-krde nimu nakrlzbzle mzli kc Gct na-arlapx-atwrnr-ngrde nimu mz zmatq ngr alwx, mz nzyzlu-krm Jiszs o mz nzbz-krmu.
\p 
\v 31 Naesakiamu nzrtrngz-ngrbz drtwr kxtrka lcde seleng: nzlolvz-amqngi-krmu zngya ngr drtwrmu kx vz nabu, zngya kxetu, nztalwz-krmu, nzpibqti-krmu leplz, x nzmwatikr drtwrmu leplz.
\v 32 A' nivz lrmu namrlz x naycngr drtwrmu leplz kxnzkxpung x naokatramu nidr. X ipq-lzbqamu, da kc tqwai Gct mz nzipq-krde nimu mz nzaxvctr-krbzmu mz Kraes.
\c 5
\p 
\v 1 Abzamu nzvz-nqblq-zvz-krmu lrpzki r Gct, murde nimu doa nedeng kcng tqmrlzti-zlwzleng.
\v 2 Namrlzti-zvzamu leplz, da kc tqwai Kraes nzmrlzti-krde nigu. Murde rlrpx-lzbq-ngrde nzbz-krde nigu, mz nzngini-krde blz kx myapx-esz'ngr kx abrtzlvz Gct.
\p 
\v 3 X mz nznginipe-krmu lc leplz kxnztrng ne Gct, nzmnc-krmu natubq-zvzpwz, murde ma tzpikitingr leplz nimu nqmq krmu. Bzkq rwmimiamu doa kx trngiu krnalzmu, x bzkq aleamu da kx myangr drtq, x bzkq trkibramu. Murde nqmq kxnzmulr lcng trtakitrpleu leplz nedeng.
\v 4 Murde trtakitr-kzdeu nzryapwx-krmu kxtrka. Bzkq yapwxtipxamu be kx amyale drtq. Bzkq ycmne-lukurnr-ngrnamu x rwxtiamu leplz. A' awi-ngrbzmu mz Gct nivz lrde, mz nzycmne-krmu amrlx.
\v 5 Leplz kcng tzprtrng mz nzrmwingr leplz kx trngiu krnalzdrng, x mz nzalengr da kx myangr drtq, x mz nzngini-krdr trkibr, leplz kxnzmulr lcng trnamncung Heven badr Kraes x Gct Trte, x trnatwzlru da kcng tzvzpxmqng mz Gct nzngini-krde King rdr. Murde mz nzale-krdr da lcng trnzangiolru Gct angidr, a' nzangiolr nidr esz'-krdr.
\v 6 Bzkq rlr-ngrbzmu mz leplz nzesabrti-krdr nimu, mz nzrpi-krbzlr kx Gct rlrpx-ngrde da lcng tqtrka. Murde natq kxnzmulr lcng nzvz-rbrng. X zngya ngr drtwr Gct kalr sa natutitrle leplz amrlx kcng tzxpqbrlr-ngrdr natqde.
\v 7 Mz nzmu-krde lcde, bzkq prtrpzmu badr, a' kapx-lzbq-zvzmamu badr.
\p 
\v 8 Murde mzli kc ena, apuamu leplz kcng tzmncng mz nzlo, murde alwx ngrmung nzakamrbr-ngrdr da mz nabzmu. A' mzli ka apupeamu leplz kcng tzmncng mz zyzlr, murde da angidr kx vzpxm mz Kxetu pnamilxtipele nabzmu. Mz nzmu-krde lcde, mnc-nqblqamu da angidr lc. \x + \xo 5:8 \xt Asaea 9:1-2\x*
\v 9 Murde leplz kcng tzmnc-nqblqlr da angidr lc, nqmq krdr sa namrlz, nalqngi, x natubq.
\v 10 X abzamu nzkrlz-krmu da kx abrtzlvz Kxetu, x vz-nqblqamu me pnz drtwrde. \f + \fr 5:10 \ft Naglxku nike abrtzlvz Gct mz nzrlwx-krgu Nzryrngrkxtr, murde pipxle da kx mrlzbz bade x da kx trkabz bade. \f*
\m 
\v 11 Kapx-lzbqmamu mz da kxmane kcng tqtrka. X pibzmu mz leplz kx da lcng ngi alwx.
\v 12 Murde myangr drtq leplz nzryapwxtinengr da kx nzrtrngzti-kapqbz leplz kxdrka'-ngrng.
\v 13 A' mzli kc alwx kcng tqyc-kapq tzaelwapx-ngrdr, leplz nakrlzlr da kx ngi drka'-ngrng.
\v 14 Murde da angidr kx vzpxm mz Gct apule zyzlr kc tqaelwapx-ngrde da kxtubq x da kxvz-rbr. Delc, leplz nzngr-ngrdr kx,
\li1 “Ei! Melzmq! Bzkq mwibqpeq!
\li1 A' tulzm mz nzbzngr mzli ka.
\li1 X rlr-ngrbz zyzlr ngr Kraes
\li1 Nzpnamilxti-zvz-krde nabzm.” \f + \fr 5:14 \ft Nabz lc nangr-ngrgu mz #110 ‘Lod, Glqlzkr’ mz Buk R Nzangiongr. \f*
\p 
\v 15 Mz nzmu-krde lcde, obq-angidramu mz nzmnc-krmu. Bzkq apuamu ncblo kxngqngu, a' na-apuamu ncblo kxyrplapx.
\v 16 Oliqti-zvzamu nzamrlz-krmu leplz, murde mzli ka leplz kxnzkqlung nzale-txpwzng da kxtrka.
\v 17 Dekc tqrpi-ngrbo bamu kx bzkq apuamu ncblo kxngqngu, a' abzamu nzkrlz-krmu me pnz drtwr Kxetu.
\p 
\v 18 Bzkq rlr-ngrbzmu mz nzrmnqngr nzatrkati-krde nimu. Murde nzrmnq-katongr rkatrpz mz leplz nzrtrngz-abeane-krdr da kxdrka'ngr kx myangr drtq. A' rlr-ngrbzmu mz Mqngrkxtr nzokatr-krde nimu, murde narkatrpz bamu nzale-krmu da kxtubq.
\v 19 X mz nzokatrkr Mqngrkxtr, ycmne-etramu badr kztemung mz natq ngr Sam, him, x nabz kxtrng. \x + \xo 5:19 \xt Kolosia 3:16\x* X angrlvzamu Kxetu mz nabzmu atwrnrngr.
\v 20 X awi-zvz-ngrbzmu da amrlx mz Trtegu Gct, mz nzngini-krmu leplz neng Kxetu rgu Jiszs Kxnzmcpx.
\s1 Olvz Kxnzyrlzng X Ncblo Ngrdrng
\p 
\v 21 Doa ne Kraes namnclzbz mz zmatq ngr kztedeng kxnzrlxngiting mz nzamrlue-krde Kraes.
\v 22 Mz nzmu-krde lcde, nimu olvz kxnzyrlzng namnclzbzmu mz zmatq ngr ncblo ngrmung, mz nzmnclz-krbzmu mz Kxetu rgu.
\v 23 Kraes nide nargu kx aclve-angidrle nigu lrmakxtr mz nzngini-krgu nrkrdrtqde. X nide kc tqarlapxle nigu. Mz nqmq lcpwz, ncblo kxyrlz nangi nar olvz rde mz nzaclve-angidr-krdele.
\v 24 Mz nzmu-krde lcde, nimu olvz narlr-lzbq-ngrbzmu mz nzmnclz-krbzmu mz ncblo ngrmung, da kc tqwai lrmakxtr nzmnclz-krbzlr mz Kraes.
\p 
\v 25 X nimu ncblo kxnzyrlzng namrlztiamu olvz ngrmung, da kc tqwai Kraes nzmrlzti-krde lrmakxtr mz nzbz-krdeleng.
\v 26 Bz-ngrde nidr murde na-alqngile nidr mz lue ngr nzwrkxtrngr x mz nzlxngiti-krdr natqde.
\v 27 Murde lrmakxtr sa na-apule olvi kx nayrlzti Kraes kalr. X mzli ka sc tqatubqtile nide, murde natakitrde nide nztutr-krbzle mz mzte, mz nzngini-krde olvi kxluli, kxlqngipx, kxtr, x kxtubq-esz'ngr mz nzobq-krde, kx trtxpnzngr alwx ngrde x trpnzngr da kxvz-rbrtrpz bade.
\v 28 X nimu ncblo namrlztiamu olvz ngrmu da kc tqwai nzmrlzti-krmu nrkrdrtqmu. Murde mz nzmnc-lxblrngr, ncblo kc tqmrlztile olvz rde mrlzti-lzbq kz.
\v 29-30 X trpnzngr kx trkalr-ngrde nrkrdrtqde. A' aclve-angidrle x aputrle dakxnzng, da kc tqwai Kraes nzaclve-krde nigu lrmakxtr, mz nzngini-krgu nrkrdrtqde.
\v 31 Da kc tqwai nzpikr Nzryrngrkxtr le kx, \qt “Mzli kc ncblo x olvz tzetupe-ngrdr, nayrlzng. X nzamatq-lzbq-krdr namyaszpxle nzamatq-krdr kxnginidrng. X ncblo namnctr-amqngipebz mz olvz rde. Murde doa lcng li nznginipedr nrkrdrtq x leplz kxesz'.”\qt* \x + \xo 5:31 \xt Nou 2:24; Matiu 19:5; Mak 10:7-8; 1 Korint 6:16\x*
\p 
\v 32 X mz nqmq lcpwz Kraes ncdr lrmakxtr nidr nrkrdrtq x leplz kxesz'. Krlc da kx myapxbz kx trkrlz-angidrkaku.
\v 33 Kxmule-esz', a' ncblo kxyrlz kxesz' namrlztile olvz rde, da kc tqwai nzmrlzti-lzbq-krde. X olvz kxyrlz na-amatqle ncblo ngrde. \f + \fr 5:33 \ft \em 5:25\em* Nivz lc ngi dalr nzrka-zvzngr da, a' trngiu dalr nzrtwz-zvzngr da. \em 5:33\em* Gct yrlqle nzyrlzngr murde ncblo x olvz naokatr-lzbqng mz nzyrlz-krdr. \f*
\c 6
\s1 Doa Kxnztopwzng Badr Trtedr X Lxedr
\p 
\v 1 Nimu doa kxnztopwzng, lxngitibzmu natq trtemu badr lxemu, murde axvctr-lzbqpebzmu mz Kxetu x krlc me pnz drtwrde.
\v 2-3 Da kc tqwai nzpikr Nzryrngrkxtr le kx, \qt “Amrlue zvz trtem x lxem, murde na-amrlz Gct nim x namnc-zpwxq mz nrlc ka mzli kxboi.”\qt* \x + \xo 6:2-3 \xt Nzrlaszngr 20:12; Lou Kcpwz 5:16\x* Krlc lou sc Gct ayrnrngr kx amnqlzle kc tqvzmi nzesalz-krde.
\p 
\v 4 A' nimu trte x lxe doa kxnztopwzng, bzkq angyatibzmu drtwr doa nemung. A' aclve-angidramu x alvztr-angidramu nidr, murde navz-nqblqlr me pnz drtwr Kxetu mz nzyrlvzlz-krmlr.
\s1 Kxnzawzng X Kxnzetu Rdrng
\p 
\v 5 Nimu kxnzawzng, navz-nqblqamu natq kxnzetu rmung mrka mz nrlc. X navzdzm mz nabzmu atwrnrngr nzamrlue-krmu nidr mz nzamatqngr, na-apule kx wztrpzmu mz Kraes.
\v 6 Bzkq wz-angidrtx-ngrpwzmu mzli kx nztulvz-ngrdr nimu kxnzetu rmung, murde naglqlz-ngrdr nimu. A' napq mz nabzmu nzvz-nqblq-angidr-krmu natqdr, mz nzapu-krmu kxnzwztrpzng mz Kraes, murde krlc me pnz drtwr Gct.
\v 7 Abrtzlvzamu nzwz-krmu, na-apule kx wztrpzmu mz Kxetu, a' trngiu ncblo.
\v 8 Nadcpx mz drtwrmu kx Kxetu sa na-ayzlumle nzwz-krgu kxmrlz mz da kxmrlz, kxmule-esz' nigu kxnzawzng o trtingr.
\v 9 X nimu kxnzetung, kx namusr-kz-ngrnamu kxnzawz nemung lcpwz. Bzkq rpibzmu natq kx naxngitrlr x natq ngr nzviplangr nidr. Nadcpx mz drtwrmu kx nimu badr Kxetu rmu esz' kc Heven, x mz nzobq-krde leplz amrlx kxnzmu-txpwzlr esz'.
\s1 Dalr Vea Kx Kam Gct Bagu Mz Nzaovxio-krgu Setzn Badr Drka' Kztedeng
\p 
\v 10 Natqnge kx nzrmnr-ngrbzng nidr seleng. Mnctr-amqngibzmu mz Kxetu rgu, murde narngiscmu zmatq mz nzaxplr-krde nimu.
\v 11 Vecku badr Setzn kc tqsuti drtwrde nzaovxio-krde nigu. Mz nzmu-krde lcde, yrlqbzmu dalr vea amrlx kcng tqkabz Gct bamu, murde natu-amqngi-ngrnamu mzli kc Setzn na-atalz-ngrde x naesabrti-ngrde nimu.
\v 12 Mz vea lc trveckuu badr leplz. A' vecku badr drka' kxnzetung, kxnzrmailzng, x kxnzmatqng kcng tzmncng mrnyzdr. Murde sc tzrbatrpzng alwx x da kxtrka mz nrlc ka, mz nzrngisc-krdr zmatq kxdrka'ngr.
\v 13 Mz nzmu-krde lcde, mzli ka nayrlqbzmu dalr vea amrlx kcng tqkabz Gct bamu, murde mzli kc navec-ngrgu badr, natu-pz'li-ngrnamu nidr. X natu-amqngiamu nakrlzbzle mzli kc nayrkrpxngr nzvecngr lc.
\p 
\v 14 Oliqti-lzbqamu mz nzngini-krmu ncblo ngr vea neng Gct. Murde ncblo ngr vea nzamqngitrlr nrkalodr, murde naoliqng mz nzvecngr. X mz nqmq lcpwz, nzkrlz-krmu da angidrng amrlx kx nzvzpxmqng mz Gct na-apule nrkalomu, murde naoliqamu mz nzaovxio-krmu nzpokiangr amrlx. X ncblo ngr vea nzyrlqbzlr temz ngr lomrdr kc tqyrputrngr nipna, murde enqmi rdrng ma tzluplxtrpzlr lomrdr. Mz nqmq lcpwz, nzkrlz-krmu kx tubqpebzmu mz nzobqkr Gct na-apule temz ngr lomrmu, murde Setzn ma tqbatrpzle nztalvzokr nabzmu, mzli kc tqrpi-ngrbzle bamu kx vz-rbramu. \x + \xo 6:14 \xt Asaea 59:17\x*
\v 15 X ncblo ngr vea nzyrlq-kzpzlr but ngr nanycdr, murde natu-amqngi-ngrdr mz mzli r vea. X mz nqmq lcpwz, nzkrlz-krmu kx mncamu mz nrwx badr Gct mz nzvz-nqblq-krde Nrpakxmrlz, na-apule but ngr nanycmu, murde natu-amqngiamu mz nzrlxngiti-krmu x mz nzpipx-krbzmu Nrpakxmrlz badr leplz.
\v 16 X ncblo ngr vea nzaotr-kzng mz mqdr kxmc da kxmqngi scdr kc tqyrputrngr nipna. Mz nqmq lcpwz nzbrtikr drtwrmu Jiszs, na-apule da kxmqngi scmu kc tqyrputrngr nipna kxngc kc tqpnzngr Setzn nimu mz nzatrkati-krde nimu. Murde nzbrtikr drtwrmu Jiszs sa na-amz-zvzbzle nipna kxngc sc Krkc Tqdrka'ngr amrlx.
\v 17 X ncblo ngr vea nzyrlq-kzpzlr abx ngr vea kc tqayrbqpxle nardr. X nzmale-kzlr toki r vea mz mqdr kxrtc mz nzvec-krdr badr enqmi rdrng. \x + \xo 6:17 \xt Asaea 59:17\x* X mz nqmq lcpwz, nzkrlz-krmu kx Gct arlapxpele nimu na-apule da kxmqngi kx nalalvzle narmu, murde nzao-krmu drtwrmu natubq x naopx, murde ma tqesabrti Setzn nimu. X nzkrlz-krmu natq Gct x nzpipx-krbzmule na-apule toki r vea kc tqkabz Mqngrkxtr, nangi dalr nzaovxio-krmu Setzn. \fig Yrlqbzmu dalr vea amrlx.|alt="111 soldier in full armor" src="111-WA04009b.tif" size="COL" loc="EPH 6:14-18" copy="Graham Wade" ref="6:14-18"\fig*
\v 18 X mz nzvec-krmu, krka'-zvz-ngrbzmu mz Gct nzokatr-krde nimu. X mz da amrlx krka'-zvzamu navz-nqblqle kxmu nzpi-krbz Mqngrkxtr le mz nabzmu. Mz nzkrka'-krmu aclvetio-angidramu, murde drtwrmu bzkq ma mz nzkrka'-krmu leplz neng Gct amrlx mrkang kqlu. X bzkq esaki nzkrka'-krmu, navz nakrlzbzle mzli kx ayzlu-ngrbz Gct natqmu.
\p 
\v 19 X krka'-kz-ngrnamu ninge, murde nakam Gct bange natqdeng mzli kznike naycmne-ngrne, x nelznge nabr, mz nzyokaetipx-angidr-krbo Nrpakxmrlz kc tqyc-kapqbz mz leplz.
\v 20 Kraes aprcmle bange nzwzkr menrpa nede mz nzyapwxtipx-krbo natqdeng. Dekc tzadwatrpe-ngrne mz presin. A' krka'-ngrnamu ninge, murde napipx-angidrbo mz nelznge kxbr.
\s1 Natq Ngr Nzarlr-lzbqngr
\p 
\v 21 Atwzlr-ngrbo bamu Tikikzs, mzlegu kxnzmrlzti, kx wztr-angidrbz mz Kxetu rgu, murde nayapwxti-krlzpwzle ninge bamu x da kx rtrngztibong.
\v 22 X na-apqtrpzle drtwrmu mz nzkrlz-krmu nrpa ngrgrng amrlx.
\p 
\v 23 Krka'-ngrne kx Trtegu Gct x Kxetu rgu Jiszs Kxnzmcpx na-amnc-zpwxlr nimu badr mz nrwx. X nabatrpzlr nzmrlzti-lzbq-krmu x nzbrti-zvzkr drtwrmu Kraes.
\v 24 X rlxti-kzpo mz Gct kx nakabzle zmrlz ngrde kxmyalz mz leplz amrlx kcng tzmrlztilr Kxetu rgu Jiszs Kxnzmcpx mz nivz kc tqvztx alo.
\cls Delape. Ninge \sig Pol. \sig* 
