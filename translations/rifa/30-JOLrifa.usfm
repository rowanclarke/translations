\id JOL
\h يُووِيلْ
\toc1 يُووِيلْ
\toc2 يُووِيلْ
\toc3 يُووِ.
\mt1 يُووِيلْ
\c 1
\s1 أَسّْ ن سِيذِي إِقَارّبْ-د
\m 
\v 1 أَوَاڒْ ن سِيذِي إِ د-يُوسِينْ غَارْ يُووِيلْ، مِّيسْ ن فَاثُو‘إِلْ. \f ◼ \fr 1:‏1 \ft \bd ’يُووِيلْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي أَربِّي نّسْ سِيذِي‘. \bd ’فَاثْوِييِيلْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’نّيّثْ يَارزْمنْ ن أَربِّي‘.\f*
\b
\m 
\v 2 ”سْڒمْ أَيَا، \add أَ\add* إِوسُّورَا، سْحسّمْ، مَارَّا \add كنِّيوْ\add* إِمزْذَاغْ ن ثمُّورْثْ! مَا إِمْسَارْ ؤُيَا \add عمَّارْصْ\add* ذڭْ وُوسَّانْ نْومْ نِيغْ ذڭْ وُوسَّانْ ن ڒجْذُوذْ نْومْ؟ \f ◼ \fr 1:‏2 \ft \bd ’إِوسُّورَا‘\bd* - خْزَارْ عَاوذْ أَعَوذ. 32‏:7. \bd ’إِمزْذَاغْ ن ثمُّورْثْ‘\bd* - نِيثْنِي ذ إِمزْذَاغْ ن يَاهُوذَا (خْزَارْ يُووِيلْ 3‏:1،20).\f*
\v 3 حَاجَامْ إِحنْجِيرنْ نْومْ خْ ؤُيَا ؤُ \add جّمْ\add* إِحنْجِيرنْ نْومْ \add أَذْ ث حَاجَانْ\add* إِ إِحنْجِيرنْ نْسنْ ؤُ إِحنْجِيرنْ نْسنْ إِ جِّيڒْ إِ د غَا يَاسنْ.
\v 4 مِينْ إِجَّا بُو-وقْضعْ، ثشَّا إِ-ث ثْمُورْغِي، مِينْ ثجَّا ثْمُورْغِي، إِشَّا إِ-ث بُو-وڒْسَاحْ، مِينْ إِجَّا بُو-وڒْسَاحْ، إِشَّا إِ-ث بُو-ؤُصَارْذْ.“
\m 
\v 5 ”فَاقمْ، \add كنِّيوْ\add* إِسْكَارْجِييّنْ، ثْرُومْ، سْغُويّمْ، مَارَّا إِنِّي إِسسّنْ بِينُو، زِي سِّيبّثْ ن بِينُو ژمّنْ ث جْذِيذْ، مَاغَارْ إِتّْوَاقْضعْ زڭْ ؤُقمُّومْ نْومْ.
\v 6 مَاغَارْ إِجّْ ن ڒْڭنْسْ إِڭعّذْ ضِيدّْ إِ ثمُّورْثْ إِنُو. غَارسْ ثِيزمَّارْ ؤُ \add ڒْقدّْ نّسْ\add* بْڒَا ڒحْسَابْ. ثِيغْمَاسْ نّسْ \add أَمْ\add* ثغْمَاسْ ن وَايْرَاذنْ ؤُ ثِيغْمَاسْ ن ثغْمَارْثْ نّسْ \add أَمْ\add* ثِينِّي ن ثيْرَاذْثْ.
\v 7 أَقَا يَارَّا ثْزَايَارْثْ إِنُو ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ ؤُ يَارْزَا وَارْثُو إِنُو، يَارَّا إِ-ث قَاعْ ذ أَقشَّارْ ؤُشَا إِنْضَارْ إِ-ث، ثِيسضْوِينْ نّسْ ذوْڒنْثْ ذ ثِيشمْڒَاڒِينْ.
\v 8 شثْشَاثْ أَمْ يِيشْثْ ن ثعْزَارشْثْ ثنِّي إِبيْسنْ س إِشْثْ ن ثْخَانْشثْ \add ن وشْضَانْ\add* خْ ورْيَازْ ن ثمْژِي نّسْ.
\v 9 ثتّْوَاقْضعْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبْثْ ن ؤُسيّبْ زِي ثَادَّارْثْ ن سِيذِي. إِكهَّاننْ، إِمْسخَّارنْ ن سِيذِي، شطّنْ.
\v 10 أَقَا إِتّْوَاردّدْجْ يِييَّارْ، ثشْضنْ ثمُّورْثْ، مِينْزِي إِمنْذِي إِضيّعْ، يُوژغْ بِينُو ن جْذِيذْ، ثجْمذْ زّشْثْ.
\v 11 سضْحَامْ، كنِّيوْ إِفدْجَاحنْ، سْغُويمْ، كنِّيوْ أَيْثْ ن ثْزَايَارْثْ، خْ يِيرْذنْ ذ إِمنْذِي، مَاغَارْ صَّابثْ ن يِييَّارْ ثْودَّارْ.
\v 12 ثَازَايَارْثْ ثُوژغْ، أَرْثُو ن ثَازَارْثْ إِسْڒَاوْ، ثَاشجَّارْثْ ن أَرمَّانْ، ؤُڒَا ذ ثِينِي ذ ثْشجَّارْثْ ن تّفَّاحْثْ، \add وَاهْ،\add* مَارَّا ثِيشجُّورَا ن يِييَّارْ سْڒَاونْثْ، عَاذْ ڒفْرَاحثْ ن ثَارْوَا ن بْنَاذمْ ثْرُوحْ.“
\m 
\v 13 ”بيْسمْ إِخفْ نْومْ ؤُ وْثمْ أَڭجْذُورْ، \add كنِّيوْ\add* إِكهَّاننْ! سْيُويّمْ \add كنِّيوْ\add* إِمْسخَّارنْ ن ؤُعَالْطَارْ، أَسمْ-د ؤُ ثسّنْسمْ ذِي ثْخُونْشَايْ \add ن وشْضَانْ\add*، \add كنِّيوْ\add* إِمْسخَّارنْ ن أَربِّي، مَاغَارْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذ ثوْهِيبْثْ ن ؤُسيّبْ تّْوَاكّْسنْثْ إِ ثَادَّارْثْ ن أَربِّي نْومْ.
\v 14 عڒْممْ إِ يِيجّْ ن ؤُژُومِّي إِقدّسْ، بَارّْحمْ س يِيجّْ ن ؤُمُونِي إِفَارْزنْ، سْمُونمْ إِمْغَارنْ ذ مَارَّا إِمزْذَاغْ ن ثمُّورْثْ ذِي ثَادَّارْثْ ن سِيذِي، أَربِّي نْومْ، ؤُ ڒَاغَامْ غَارْ سِيذِي.“ \x ◘ \xo 1:‏14 \xt يُووِ. 2‏:‏15\x*
\m 
\v 15 ”وِيهْ، أَسّْ نِّي! مِينْزِي يُوذسْ-د وَاسّْ ن سِيذِي ؤُ أَذْ د-يَاسْ \add أَسّْ نِّي\add* أَمْ يِيجّْ ن ؤُردّدْجْ ن ؤُزمَّارْ خْ كُوڒْشِي. \x ◘ \xo 1:‏15 \xt إِشا. 13‏:‏6\x*
\v 16 مَا وَارْ ذ أَنغْ ثتّْوَاكّسْ مَاشَّا جَارْ ثِيطَّاوِينْ نّغْ؟ ؤُڒَا ذ ڒفْرَاحثْ ذ أَرْشُوقْ زِي ثَادَّارْثْ ن أَربِّي نّغْ.
\v 17 إِعقَّاينْ ن زَّارِيعثْ ؤُژْغنْ سَاذُو إِپُورْسَا، إِخَّامنْ ن ڒخْزنْ تّْوَاردّْدْجنْ، ڒهْرِيثْ هذْمنْ، مِينْزِي إِمنْذِي إِنْژغْ.
\v 18 مَامّشْ إِسّْمُوهْرُوثْ ڒْمَارْ! ثِيحِيمْرِيوِينْ ن إِفُونَاسنْ ذ ثْفُونَاسِينْ قِّيمنْثْ حَايَارْ، مَاغَارْ وَارْ غَارْسنْثْ بُو دّمْنثْ ن ثَاروْسَا! ؤُڒَا ذ ثِيحِيمْرِيوِينْ ن وُودْجِي فْنَانْثْ.“
\m 
\v 19 ”غَاركْ إِ تّْڒَاغِيغْ نشّْ، \add أَ\add* سِيذِي، مِينْزِي ثِيمسِّي ثشَّا دّْمَانِي ن ڒخْڒَا ؤُ يِيجّْ ن ؤُشعَّاڒْ أَقَا إِسّشْمضْ مَارَّا ثِيشجُّورَا ن يِييَّارْ.“
\v 20 ؤُرَا ذ ڒْمَاڒْ ذڭْ إِيَّارْ سكّْوْضنْ-د غَاركْ، مِينْزِي ثْغزْرَاثِينْ ؤُژْغنْثْ ؤُ ثِيمسِّي ثشَّا دّْمَانِي ن ڒخْڒَا.“
\b
\b
\c 2
\m 
\v 1 ”سُوضمْ ذڭْ ؤُيِيشّْ ن إِشَارِّي ذِي صِيهْيُونْ، صُوذمْ ذَايسْ س جّهْذْ خْ وذْرَارْ إِنُو إِقدّْسنْ، جّمْ مَارَّا إِمزْذَاغْ ن ثمُّورْثْ أَذْ أَرْجِيجنْ، مَاغَارْ يُوذسْ وَاسّْ ن سِيذِي، \add وَاهْ،\add* أَقَا-ث يُوذسْ. \x ◘ \xo 2:‏1 \xt يُووِ. 1‏:‏15؛ صَاف. 1‏:‏14، 15\x*
\v 2 إِجّْ ن وَاسّْ ن ثَادْجسْثْ ذ ثُوبَّارْشنْثْ، إِجّْ ن وَاسّْ ن إِسيْنُوثنْ ؤُ ن يِيجّْ ن ؤُسيْنُو إِبُّومْبسْ. أَمْ ثُوفُّوثْ ن ڒْحَاڒْ إِڭُّورنْ خْ إِذُورَارْ أَذْ د-يَاسْ إِجّْ ن ڒْڭنْسْ ذ أَمقّْرَانْ ؤُ إِجْهذْ! أَمْ وَانِيثَاعمَّارْصْ وَارْ إِدْجِي زِي مشْحَاڒْ ؤُيَا ؤُ أَوَارْنِي أَسْ وَارْ إِتِّيڒِي عَاوذْ، ذڭْ إِسڭّْوُوسَا \add أَوَارْنِي أَسْ\add* زِي جِّيڒْ أَڒْ جِّيڒْ نّغْنِي.
\v 3 زَّاثْ إِ وُوذمْ نّسْ ثتّتّْ ثْمسِّي ؤُ أَوَارْنِي أَسْ إِشمّضْ ؤُشعَّاڒْ. زَّاثسْ ثَامُّورْثْ ثڭَّا أَمْ وحْوِيشْ ن عَاذْنْ، \add مَاشَا\add* أَوَارْنِي أَسْ أَقَا \add ذِينْ\add* إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ. وَارْ إِزمَّارْ أَذْ زَّايسْ إِنْجمْ.
\v 4 شُّوفْ نْسنْ أَمْ شُّوفْ ن يِييْسَانْ ؤُ نِيثْنِي تَّازّْڒنْ أَمْ يِييْسَانْ ن ثَازْڒَا.
\v 5 أَمْ ؤُقَارْقبْ ن إِكَارُّوثنْ ن ؤُمنْغِي خْ ثْقِيشِّيثِينْ ن إِذُورَارْ، \add أَمُّو\add* نڭّْزنْ نِيثْنِي، أَمْ ڒْحسّْ ن ؤُشعَّاڒْ ن ثْمسِّي إِتّتّنْ إِغدْجْ، أَمْ يِيجّْ ن ڒْڭنْسْ إِجهْذنْ إِسدّنْ إِ ؤُمنْغِي.
\v 6 زَّاثْ إِ وُوذمْ نْسنْ تَّارْجِيجنْ ڒڭْنُوسْ، مَارَّا إِغمْبَابْ ذوْڒنْ ذ إِشمْڒَاڒنْ.“
\m 
\v 7 ”نِيثْنِي تَّازّْڒنْ أَمْ أَيْثْ ن بُو-ثغْرُوضْثْ، أَمْ يِيعسْكَارِييّنْ تّْڭعَّاذنْ نِيثْنِي ڒْحِيضْ، كُوڒْ إِجّْ إِڭُّورْ أَبْرِيذْ نّسْ ؤُ نِيثْنِي وَارْ د-تّفّْغنْ شَا زڭْ ؤُمسْرُوقْ نْسنْ.
\v 8 ؤُڒَا ذ إِجّنْ وَارْ إِعَارّنْ ونّغْنِي، كُوڒْ بُو-طغْڒُوضْثْ \add إِڭُّورْ\add* ذڭْ وبْرِيذْ نّسْ، ؤُ وَاخَّا نِيثْنِي وْضَانْ س لَانْسَا، وَارْ تّمْسْبعِّيذنْ
\v 9 نِيثْنِي وطَّانْ خْ ثنْذِينْثْ، تَّازّْڒنْ خْ ڒْحِيضْ، تّْڭعَّاذنْ غَارْ ثُوذْرِينْ، تَّاذْفنْ زِي ڒكْوَازَا أَمْ ؤُخوَّانْ.
\v 10 ثتَّارْجِيجِي ثمُّورْثْ زَّاثْ إِ وُوذمْ نْسنْ، إِجنْوَانْ تّنْهزَّانْ، ثَافُوشْثْ ذ ثْزِيرِي بَّارْشْننْثْ ؤُ إِثْرَانْ أَرِّينْ ثَافَاوْثْ نْسنْ. \x ◘ \xo 2:‏10 \xt إِشا. 13‏:‏10؛ حِز. 32‏:‏7\x*
\v 11 سِيذِي يَارَّا ثْمِيجَّا نّسْ أَذْ ثفّغْ زَّاثْ إِ ڒْعسْكَارْ نّسْ، مَاغَارْ ڒْعسْكَارْ نّسْ ذ أَمقّْرَانْ أَطَّاسْ، مَاغَارْ س صُّولْطَا إِتّْكمَّاڒْ نتَّا أَوَاڒْ نّسْ، مَاغَارْ أَسّْ ن سِيذِي ذ أَمقّْرَانْ، إِسَّاڭّْوَاذْ أَطَّاسْ. وِي إِزمَّارنْ أَذْ ث إِكْسِي؟“ \x ◘ \xo 2:‏11 \xt إِرْم. 30‏:‏7؛ عَام. 5‏:‏18؛ صَاف. 1‏:‏15\x*
\b
\s1 أَڒَاغِي إِ تُّوبثْ ذ ؤُژُومِّي ذ وشْضَانْ
\m 
\v 12 ”ؤُڒَا ڒخُّو \add عَاذْ\add* إِقَّارْ سِيذِي،عقْبمْ-د غَارِي س مَارَّا ؤُڒْ نْومْ، س ؤُژُومِّي ؤُ س إِمطَّاونْ ؤُ س ثْغُويِّيثْ ن وشْضَانْ. \x ◘ \xo 2:‏12 \xt إِرْم. 4‏:‏1\x*
\v 13 شَارّْڭمْ ؤُڒْ نْومْ، وَارْ إِدْجِي أَرُّوضْ نْومْ، ؤُ ذوْڒمْ-د غَارْ سِيذِي، أَربِّي نْومْ، مَاغَارْ نتَّا ذ أَحْنِينْ ذ أَرْحِيمْ ؤُ غَارسْ تَّاسِيعْ ن ڒْخَاضَارْ ذ ثْمخْسِيوْثْ ثَامقّْرَانْثْ إِشوَّارنْ ؤُ نتَّا إِندّمْ خْ ڒْغَارْ. \x ◘ \xo 2:‏13 \xt ؤُف. 34‏:‏6؛ إِزهد. 86‏:‏15؛ يُون. 4‏:‏2\x*
\v 14 وِي إِسّْننْ أَقَا نتَّا أَذْ د-إِذْوڒْ أَذْ إِنْذمْ ؤُ أَذْ يجّْ إِشْثْ ن لْبَارَاكَا. أَوَارْنِي أَسْ: إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ؤُ إِشْثْ ن ثوْبِيبْثْ ن ؤُسيّبْ إِ سِيذِي، أَربِّي نْومْ.“ \x ◘ \xo 2:‏14 \xt يُون. 3‏:‏9\x*
\b
\m 
\v 15 ”سُوضمْ ذڭْ ؤُيِيشّْ ن إِشَارِّي ذِي صِيهْيُونْ، قدّْسمْ إِجّْ ن ؤُژُومِّي، بَارّْحمْ س يِيجّْ ن ؤُمُونِي إِفَارْزْ. \x ◘ \xo 2:‏15 \xt يُووِ. 1‏:‏14\x*
\v 16 سْمُونمْ ڒْڭنْسْ، قدّْسمْ أَڭْرَاوْ \add ن ڒْڭنْسْ\add*، جَارْومْ إِمْغَارنْ، سْمُونمْ إِحنْجِيرنْ إِمژْيَاننْ ؤُڒَا ذ إِسيْمَانْ نِّي عَاذْ إِتّطّْضنْ. أجّْ مُوڒَايْ أَذْ إِفّغْ زڭْ وخَّامْ نّسْ ن ذَاخڒْ ذ ثسْڒِيثْ زڭْ ؤُقِيضُونْ نّسْ.
\v 17 جّمْ إِكهَّاننْ، إِمْسخَّارنْ ن سِيذِي، أَذْ رُونْ جَارْ وسْقِيفْ ذ ؤُعَالْطَارْ ؤُ جّمْ إِ-ثنْ أَذْ إِنِينْ: ’سْعِيزّْ خْ ڒْڭنْسْ نّشْ، \add أَ\add* سِيذِي، ؤُ وَارْ تّجِّي ثَاسْغَارْثْ نّشْ أَذْ زَّايسْ سْثهزَّانْ ؤُ أَذْ ت ڭّنْ ذ إِجّْ ن ڒْمَاثَالْ جَارْ أَسنْ، \add جَارْ\add* ڒڭْنُوسْ. مَايمِّي غَا قَّارنْ جَارْ ڒڭْنُوسْ: مَانِي إِدْجَا أَربِّي نْسنْ؟‘ “\x ◘ \xo 2:‏17 \xt إِزهد. 42‏:‏11؛ 79‏:‏10؛ 115‏:‏2\x*
\b
\s1 مَامّشْ إِ د-يَارَّا سِيذِي خْ ونِّي ذ أَسْ إِتّْژَادْجَانْ
\m 
\v 18 \add خنِّي\add* يُوسمْ سِيذِي خْ ثمُّورْثْ نّسْ ؤُ إِحِينّْ خْ ڒْڭنْسْ نّسْ.
\v 19 سِيذِي يَارَّا-د، إِنَّا إِ ڒْڭنْسْ نّسْ: ”خْزَارْ، نشّْ سّكّغْ أَومْ-د إِمنْذِي ذ بِينُو ن جْذِيذْ ذ زّشْثْ، حِيمَا كنِّيوْ أَذْ زَّايْسنْ ثجَّاوْنمْ، ؤُ نشّْ وَارْ كنِّيوْ تِّيشغْ عَاذْ إِ ؤُسحْقَارْ جَارْ ڒڭْنُوسْ.
\v 20 ونِّي \add د-يُوسِينْ\add* زِي شَّامَالْ أَذْ ث سِّيڭّْوجغْ خَاومْ ؤُ أَذْ ث سُّوفّْغغْ غَارْ إِشْثْ ن ثمُّورْثْ يُوژْغنْ ثتّْوَاكحّضْ. أَغمْبُوبْ نّسْ \add أَذْ ث سُّوفّْغغْ\add* غَارْ ڒبْحَارْ ن شَّارْقْ ؤُ ضفَّارْ نّسْ غَارْ ڒبْحَارْ ذِي شَّارْقْ. أَذْ ثْڭعّذْ أَرِّيحثْ نّسْ، \add وَاهْ،\add* أَذْ ثْڭعّذْ أَرِّيحثْ ن ثرْصُوضِي نّسْ، وَاخَّا نتَّا أَقَا إِڭَّا ثِيمسْڒَايِينْ ثِيمقّْرَانِينْ.“
\m 
\v 21 ”وَارْ تّڭّْوذْ، \add أَ\add* ثَامُّورْثْ، سْڒِيوْڒوْ ذ ثْفَارْحذْ، مَاغَارْ سِيذِي إِڭَّا ثِيمسْڒَايِينْ ثِيمقّْرَانِينْ.
\v 22 وَارْ تّڭّْوذمْ شَا، \add أَ\add* ڒْمَاڒْ ن يِييَّارْ، مَاغَارْ دّْمَانِي ن ڒخْڒَا أَذْ زّيْزُونْ، ثِيشجُّورَا أَذْ وْشنْثْ ڒْغِيدْجثْ نْسنْثْ، ثَازَايَارْثْ ذ وَارْثُو ن ثَازَارْثْ أَذْ وْشنْ ڒْغِيدْجثْ نْسنْ.
\v 23 إِحنْجِيرنْ ن صِيهْيُونْ، سْڒِيوْڒومْ ؤُ فَارْحمْ ذِي سِيذِي، أَربِّي نْومْ، مَاغَارْ نتَّا أَذْ أَومْ إِوْشْ أَمْسغَّارْ ن ثْسڭْذَا ؤُ نتَّا أَذْ د-إِسّهْوَا أَنْژَارْ إِ كنِّيوْ، أَنْژَارْ ن ڒخْرِيفْ ذ ونْژَارْ ن أَرْبِيعْ غَارْ ؤُمزْوَارُو \add ن يِيمِيرْ\add*. \f ◼ \fr 2:‏23 \ft \bd ’ڒخْرِيفْ‘\bd* - نِيغْ ’أَمْوَانْ‘. \bd ’أَرْبِيعْ‘\bd* - نِيغْ ’ثَافْسُوثْ‘. \bd ’إِمِيرْ‘\bd* - إِخْسْ أَذْ يِينِي س ثْعِيبْرَانِيثْ ’لْفَاصْلْ‘ أَمشْنَاوْ ’أَنبْذُو‘ ذ ’أَرّْبِيعْ‘.\f*
\v 24 إِنذْرَارْ أَذْ شُّورنْ س إِمنْذِي ؤُ ثِيسَارْفِينْ \add ن ؤُضِيڒْ\add* أَذْ سّفْينْثْ س بِينُو ن جْذِيذْ ذ زّشْثْ.
\v 25 نشّْ أَذْ أَومْ خڒْفغْ إِسڭّْوُوسَا إِ شِّينْثْ ثْمُورْغِي - بُو-وڒْسَاحْ ذ بُو-ؤُصَارْضْ ذ بُو-وقْضعْ - ڒْعسْكَارْ إِنُو أَمقّْرَانْ نِّي سّكّغْ جَارْ أَومْ. \x ◘ \xo 2:‏25 \xt يُووِ. 1‏:‏4\x*
\v 26 كنِّيوْ أَذْ ثشّمْ أَڒْ غَا ثْفيّْضمْ، أَڒْ غَا ثجَّاوْنمْ ؤُ كنِّيوْ أَذْ ثْصبّْحمْ إِسمْ ن سِيذِي، أَربِّي نْومْ، ونِّي أَكِيذْومْ إِڭِّينْ ڒعْجبْ، ؤُشَا ڒْڭنْسْ إِنُوعمَّارْصْ أَذْ إِسضْحَا عَاذْ.
\v 27 كنِّيوْ أَذْ ثسّْنمْ أَقَا نشّْ ذِي ڒْوسْثْ ن إِسْرَائِيل إِ دْجِيغْ ؤُ ذ نشّْ ذ سِيذِي، أَربِّي نْومْ، وَارْ \add ذِينْ\add* إِدْجِي حذْ نّغْنِي ؤُ ڒْڭنْسْ إِنُو وَارْ إِتّْسضْحَاعمَّارْصْ إِ ڒبْذَا.“
\b
\b
\c 3
\s1 أَسْفَارّغْ ن أَرُّوحْ ن أَربِّي ذ ڒعْڒَامَاثْ ن وَاسّْ ن سِيذِي
\m 
\v 1 ”أَوَارْنِي ؤُيَا أَذْ إِمْسَارْ، أَقَا نشّْ أَذْ زدْجْعغْ أَرُّوحْ إِنُو خْ مَارَّا بْنَاذمْ ؤُ إِحنْجِيرنْ نْومْ ذ يسِّيثْومْ أَذْ نبَّانْ، إِوسُّورَا نْومْ أَذْ ؤُرْجَانْ ثِيرْجَا ؤُ إِحُوذْرِييّنْ نْومْ أَذْ ژَترنْ إِوحَّانْ. \x ◘ \xo 3:‏1 \xt إِشا. 44‏:‏3؛ حِز. 39‏:‏29؛ ڒخ. 2‏:‏17\x*
\v 2 ذڭْ وُوسَّانْ نِّي نشّْ أَذْ فَارّْغغْ أَرُّوحْ إِنُو ؤُڒَا خْ إِسمْغَانْ ؤُ خْ ثِييَّا.
\v 3 نشّْ أَذْ ڭّغْ لْمُوعْجِيزَاثْ ذڭْ إِجنْوَانْ ؤُ خْ ثمُّورْثْ: إِذَامّنْ ذ ثْمسِّي ذ إِقلِّيجنْ ن دّخَّانْ.
\v 4 ثَافُوشْثْ أَذْ ثذْوڒْ ذ ثَادْجسْثْ، ؤُ ثَازِيرِي \add أَذْ ثذْوڒْ\add* ذ إِذَامّنْ قْبڒْ مَا إِ د غَا يَاسْ وَاسّْ أَمقّْرَانْ ذ إِسِّيڭّْوِيذنْ ن سِيذِي. \x ◘ \xo 3:‏4 \xt يُووِ. 4‏:‏15\x*
\v 5 أَذْ إِمْسَارْ أَقَا كُوڒْ  إِجّْ ونِّي إِ غَا إِڒَاغَانْ إِسمْ ن سِيذِي أَذْ إِنْجمْ، مَاغَارْ خْ وذْرَارْ ن صِيهْيُونْ ؤُ ذِي ؤُرْشَالِيمْ أَذْ يِيڒِي ؤُسنْجمْ أَمْ مَامّشْ إِنَّا سِيذِي، ؤُ غَارْ إِنِّي يَاروْڒنْ إِ خفْ غَا إِڒَاغَا سِيذِي.“ \x ◘ \xo 3:‏5 \xt عُوب.17؛ رُوم. 10‏:‏13\x*
\b
\b
\c 4
\s1 ڒْحُوكْمْ خْ ڒڭْنُوسْ ذِي ثغْزُورْثْ ن يَاهُوشَافَاطْ
\m 
\v 1 ”مَاغَارْ، خْزَارْ، ذڭْ وُوسَّانْ نِّي ؤُ ذِي ڒْوقْثْ نِّي، خْمِي غَا سّنْقڒْبغْ ثَامحْبَاسْثْ ن يَاهُوذَا ذ ؤُرْشَالِيمْ،
\v 2 أَذْ سّْمُونغْ مَارَّا ڒڭْنُوسْ، أَذْ ثنْ نذْهغْ غَارْ ثغْزُورْثْ ن يَاهُوشَافَاطْ. ذِينِّي أَذْ أَكِيذْسنْ مْشَارَّاعغْ مِينْزِي نِيثْنِي زُوزَّارنْ ڒْڭنْسْ إِنُو ذ ثسْغَارْثْ إِنُو جَارْ ڒڭْنُوسْ ؤُ \add مِينْزِي\add* نِيثْنِي بْضَانْ ثَامُّورْثْ إِنُو.
\v 3 نِيثْنِي ڭِّينْ ثَاقدُّوحْثْ خْ ڒْڭنْسْ إِنُو ؤُ وْشِينْ إِجّْ ن وحْرَامْ \add ذ تّخْڒِيصثْ\add* إِ ثمْغَارْثْ ن فَارْقْ-شّْغڒْ ؤُ إِشْثْ ن ثحْرَامْثْ ثمّنْزْ إِ بِينُو، حِيمَا نِيثْنِي زمَّارنْ أَذْ سْونْ.
\m 
\v 4 ؤُ عَاوذْ، مِينْ غَارْومْ أَكِيذِي، صُورْ ذ صِيذُونْ ذ مَارَّا جّْوَايهْ ن فِيلِيشِيثْ. مَا ثخْسمْ أَذْ أَيِي ثْخدْجْصمْ مِينْ ڭِّيغْ؟ مَاڒَا ثخْسمْ أَذْ أَيِي ثْخدْجْصمْ، نشّْ أَذْ سّْعقْبغْ ذغْيَا ؤُ س ثَازْڒَا مِينْ ثڭِّيمْ خْ إِزدْجِيفنْ نْومْ،
\v 5 مِينْزِي كنِّيوْ ثكّْسِيمْ نُّوقَارْثْ ذ وُورغْ إِنُو ؤُ \add مِينْزِي\add* كنِّيوْ ثِيوْيمْ ڒقْشُوعْ إِنُو يِيغْڒَانْ غَارْ ثْزَاوِييِّينْ نْومْ.
\v 6 كنِّيوْ ثزّنْزمْ إِحنْجِيرنْ ن يَاهُوذَا ذ إِحنْجِيرنْ ن ؤُرْشَالِيمْ إِ إِحنْجِيرنْ ن يَاوَانْ، حِيمَا أَذْ ثنْ ثسِّيڭّْوجمْ خْ ثمُّورْثْ نْسنْ.
\v 7 خْزَارْ، نشّْ أَذْ ثنْ سّكَّارغْ زڭْ ومْشَانْ مَانِي ثنْ ثزّنْزمْ ؤُ أَذْ سّْعقْبغْ مِينْ ثڭِّيمْ خْ إِزدْجِيفنْ نْومْ.
\v 8 أَذْ زّنْزغْ إِحنْجِيرنْ نْومْ ذ يسِّيثْومْ ذڭْ ؤُفُوسْ ن إِحنْجِيرنْ ن يَاهُوذَا ؤُ يِينَا أَذْ ثنْ زّنْزنْ إِ إِسَابَائِيّنْ، إِجّْ ن ڒْڭنْسْ إِڭّْوجْ أَطَّاسْ، مَاغَارْ سِيذِي أَقَا إِسِّيوڒْ.“
\m 
\v 9 ”ڒَْاغَامْ أَيَا جَارْ ڒڭْنُوسْ، قدّْسمْ أَمنْغِي، سكَّارمْ أَيْثْ ن بُو-ثغْرُوضْثْ، جّمْ مَارَّا إِعسْكَارِييّنْ أَذْ د-قَارّْبنْ، أَذْ ڭعّْذنْ \add إِ ؤُمنْغِي\add*.
\v 10 حدّمْ دُّوزَانْ نْومْ ذ ڒسْيُوفْ ؤُڒَا ذ ڒمْوَاسْ نْومْ ن وزْبَارْ \add أَڒْ غَا ذوْڒنْ\add* ذ فْڒِيثْشَاثْ، أجّْ ونِّي إِضعْفنْ أَذْ يِينِي: ’نشّْ ذ بُو-ثغْرُوضْثْ!‘
\v 11 أَزّْڒمْ ؤُ ثَاسمْ-د، \add أَ\add* مَارَّا ڒڭْنُوسْ إِ د-إِنّْضنْ. سْندّهْ غَارْ ذِينِّي، \add أَ\add* سِيذِي، أَيْثْ نّشْ ن بُو-ثغْرُوضْثْ!
\v 12 جّمْ ڒڭْنُوسْ أَذْ كَّارنْ أَذْ ڭعّْذنْ غَارْ ثغْزُورْثْ ن يَاهُوشَافَاطْ. مَاغَارْ ذِينِّي أَذْ قِّيمغْ نشّْ حِيمَا أَذْ شَارّْعغْ مَارَّا ڒڭْنُوسْ إِ-د-إِنّْضنْ.
\v 13 ڭّمْ أَمْجَارْ ذَايسْ، مَاغَارْ صَّابثْ ثنّْڭْوَا، أَسمْ-د، هْوَامْ، مِينْزِي ثَاسِيرْثْ ن ؤُضِيڒْ ثشُّورْ ؤُ صّْوَارجْ ن ثْسِيرْثْ فيّْضنْ، مَاغَارْ ثَاعفَّانْثْ نْسنْ ذ ثَامقّْرَانْثْ.“ \x ◘ \xo 4:‏13 \xt أَسَا. 14‏:‏15\x*
\b
\m 
\v 14 ”إِبَارُّوثنْ، إِبَارُّوثنْ ذِي ثغْزُورْثْ ن ثڒْوِيحْثْ إِتّحْرُودْجُوضنْ ن ؤُسَارْوثْ، مَاغَارْ أَسّْ ن سِيذِي يُوذسْ، ذِي ثغْزُورْثْ ن ثڒْوِيحْثْ إِتّحْرُودْجُوضنْ إِ ؤُسَارْوثْ.
\v 15 ثَافُوشْثْ ذ ثْزِيرِي بَّارْشْننْثْ، إِثْرَانْ أَرِّينْ ثَافَاوْثْ نْسنْ. \x ◘ \xo 4:‏15 \xt يُووِ. 2‏:‏10؛ 3‏:‏4. \x*
\v 16 سِيذِي أَذْ إِزهَّارْ زِي صِيهْيُونْ ؤُ أَذْ يَارّْ ثْمِيجَّا نّسْ أَذْ إِتّْوَاسڒْ زِي ؤُرْشَالِيمْ \add أَڒَامِي\add* إِجنْوَانْ ذ ثمُّورْثْ أَذْ أَرْجِيجنْ، \add مَاشَا\add* سِيذِي ذ أَذُورِّي إِ ڒْڭنْسْ نّسْ ذ لْبُورْجْ إِ أَيْثْ ن إِسْرَائِيل.“
\b
\m 
\v 17 ”أَذْ ثسّْنمْ، أَقَا نشّْ ذ سِيذِي، أَربِّي نْومْ، ونِّي إِزدّْغنْ خْ صِيهْيُونْ، أَذْرَارْ إِنُو إِقدّْسنْ ؤُ \add ثَانْذِينْثْ ن\add* ؤُرْشَالِيمْ أَذْ ثِيڒِي ثْقدّسْ.عمَّارْصْ أَذْ ت شُوقنْ \add عَاذْ\add* إِبَارَّانِييّنْ.“ \x ◘ \xo 4:‏17 \xt أَسَا. 21‏:‏27\x*
\b
\m 
\v 18 ”ذڭْ وَاسّْ نِّي أَذْ إِمْسَارْ أَقَا إِذُورَارْ أَذْ ؤُذْمنْ س بِينُو ژمّنْ ث جْذِيذْ ؤُ ثِيوْرِيرِينْ أَذْ سّفْينْثْ س ؤُغِي ذ مَارَّا ثِيغزْرَاثِينْ ن يَاهُوذَا أَذْ ذَايْسنْ تَّازّْڒنْ وَامَانْ ؤُ يِيشْثْ ن ثَاڒَا أَذْ ثدُّوقّزْ ذِي ثَادَّارْثْ ن سِيذِي، أَذْ ثْفيّضْ ثغْزُورْثْ ن شِيطِّيمْ. \x ◘ \xo 4:‏18 \xt عَام. 9‏:‏13\x*
\v 19 مِيصْرَا أَذْ ثذْوڒْ ذ إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ ؤُ إِذُومْ ذ إِشْثْ ن ثمُّورْثْ إِخْڒَانْ زِي سِّيبّثْ ن لْعُونْفْ \add إِ ڭِّينْ ضِيدّْ إِ\add* أَيْثْ ن يَاهُوذَا نِّي زِي سِّيزّْڒنْ نِيثْنِي إِذَامّنْ إِمزْذَاڭنْ ذِي ثمُّورْثْ نْسنْ.
\v 20 \add ثَامُّورْثْ ن\add* يَاهُوذَا \add مَاشَا\add* أَذْ ثقِّيمْ إِ ڒبْذَا ؤُ ؤُرْشَالِيمْ زِي جِّيڒْ أَڒْ جِّيڒْ.
\v 21 نشّْ أَذْ حسْبغْ إِذَامّنْ نْسنْ، إِنِّي ثْيْغَا حسَّابغْ وَارْ إِزْذِيڭنْ، ذ إِمزْذَاڭنْ.
\m ؤُشَا سِيذِي أَذْ إِزْذغْ ذِي صِيهْيُونْ.“ 
