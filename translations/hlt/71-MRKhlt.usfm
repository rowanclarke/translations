\c 8  
\s1 Hlang Thawng Li a Kok  
\p
\v 1 \w Te|strong="G1565"\w* \w khohnin|strong="G2250"\w* \w ah|strong="G1722"\w* \w hlangping|strong="G3793"\w* te \w hut|strong="G4183"\w* \w koep|strong="G3825"\w* \w om|strong="G5607"\w* \w tih|strong="G2532"\w* \w caak|strong="G5315"\w* koi \w ba|strong="G5101"\w* khaw \w khueh|strong="G2192"\w* uh \w pawh|strong="G3361"\w*.  
\v 2 \w Hnukbang|strong="G3101"\w* rhoek \w te|strong="G3588"\w* a \w khue|strong="G4341"\w* tih, \wj “ \+w Kai|strong="G3427"\+w* taengah \+w hnin|strong="G2250"\+w* \+w thum|strong="G5140"\+w* \+w rhaeh|strong="G4357"\+w* uh \+w coeng|strong="G2235"\+w* \+w tih|strong="G2532"\+w* \+w caak|strong="G5315"\+w* \+w bakhaw|strong="G5101"\+w* a \+w khueh|strong="G2192"\+w* uh voel \+w pawt|strong="G3756"\+w* \+w dongah|strong="G3754"\+w* he \+w hlangping|strong="G3793"\+w* \+w ham|strong="G1909"\+w* ka \+w thinphat|strong="G4697"\+w*\wj*.  
\v 3 \wj Te \+w dongah|strong="G2532"\+w* \+w a|strong="G0846"\+w* \+w im|strong="G3624"\+w* \+w ah|strong="G1519"\+w* buhmueh \+w rhathih|strong="G3523"\+w* la \+w amih|strong="G0848"\+w* ka \+w tueih|strong="G0630"\+w* \+w koinih|strong="G1437"\+w* \+w longpueng|strong="G3598"\+w* \+w ah|strong="G1722"\+w* \+w tawnba|strong="G1590"\+w* uh ni. \+w Amih|strong="G0846"\+w* khuikah \+w hlangvang|strong="G5100"\+w* \+w tah|strong="G2532"\+w* \+w khohla|strong="G3113"\+w* \+w lamkah|strong="G0575"\+w* ha \+w pawk|strong="G2240"\+w* uh,” \wj* a \w ti|strong="G3004"\w* nah.   
\p
