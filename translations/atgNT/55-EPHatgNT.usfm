\id EPH - Okphela
\h Ẹfisha
\toc1 Ẹfisha
\toc2 Ẹfisha
\toc3 Ẹfi
\mt2 Ebe ni iPọlu ọ kẹkẹ ghi ẹgbọ
\mt1 Ẹfisha
\mt2 Eni e miesuọ
\c 1
\s1 IPọlu ọ tsẹ eni e mie iJesu suọ ne la Efesọsi
\p 
\v 1 Mhẹmhẹ iPọlu, aghiusomhi na kẹẹ ọyi iJesu iKirisiti ni Ẹshinẹgba ọ zẹ mhi khi.\f + \fr 1:1 \ft Li zẹ \fq Ika 18.19-21; 19.1\f*
\p Ẹgbọ eyi Ẹshinẹgba ni e la ekẹ Efesọsi, eni e regbenga iJesu iKirisiti mhi kẹkẹ ebe ona a ghi.
\v 2 Mhi lema Ẹshinẹgba ita awa ali iJesu iKirisiti Ọnọmhuẹ, e ka mhuẹ isomhelemhi na ẹ, e gbo ri opfọmhẹ na ẹ.
\s1 Ẹshinẹgba ọ she te obọ oyi iKirisiti riẹlẹ eminete na awa
\p 
\v 3 Awa kuẹghiẹ Ẹshinẹgba. Lọli ọ khi Ẹshinẹgba ali ita iJesu iKirisiti Ọnọmhuẹ ọyi awa. Lọli ọ ri ikhivọsẹ ni o te iloghie bhale na awa, ikhivọsẹ oni ọ kpaghiẹ ayẹmhẹ oyi awa obọ. Ikugbe ni ọ ku awa ali iKirisiti gbe ọ rọ riẹlẹ ona.
\v 4 Neni Ẹshinẹgba ọ ma agbọ, ọ she kpẹ zẹ awa eni ẹ khi ẹgbọ eyọli, rọte obọ oyi iJesu iKirisiti, ini awa khi eni e pfuasẹ ni ẹa mhuẹ umha-guẹkia shi odalo oyi Ẹshinẹgba. Itobọ khi ọọ nono ingme oyawa ọ rọ lighọ riẹlẹ ọli.
\v 5 Neni Ẹshinẹgba ọ ma agbọ, ọ she te ekẹ gba li khi lọli ya ri awa mele imi ọli-a, itobọ emini iJesu iKirisiti ọ riẹlẹ, ni o de shi ọ abi o ghọle Ẹshinẹgba.
\v 6 Eri ọ lina riẹlẹ ọli ini awa kuẹghiẹ ọli shi okhale oniẹmhi ni ọ mhuẹ na awa, itobọ emini omi ọli ọtuọghuo kpe ni ọ nono ingme oyọli, ọ riẹlẹ.
\p 
\v 7 Obọ oyi iKirisiti awa te mhọli ipfashekẹ, itobọ ọlia eyọli ni ọ ku shi ekẹ abi ọ rọ ghu-a na awa. Ona a te ri olamhẹ topfa awa. Itobọ ẹpfue oyi okhale oyi Ẹshinẹgba ni o gbeku ọ, ọ rọ riẹlẹ ona.\f + \fr 1:7 \ft Li zẹ \fq iKolo 1.14\f*
\v 8 Oni okhale ona ọ tutu ku awa, rọte ilẹsingme ali ẹgbhẹ ọ te riẹlẹ ọli.
\v 9 Ẹshinẹgba Ọ́ khueghie osheli emini ọ gba shi ekẹ-a khasẹ awa, ikhi emini ọ rọte obọ oyi iJesu iKirisiti rọ tse, abi o ghọle ọli.
\v 10 Emini Ẹshinẹgba ọ gba khi lọli ya pfuse riẹlẹ khi, ini o ramhi oni ẹghẹghẹ te, ọ ya ku emhi na agbọ ali ena iloghie gbe khi oghuo, ọ̀ ya ri iKirisiti le oghie wẹwẹ nya.
\v 11 Itobọ khi Ẹshinẹgba ọ ku anye ali Ikirisiti gbe, anye she mie ugu obọ oyi Ẹshinẹgba. Irari khi ọ she kpẹ te ekẹ gba li khi lọli lighọ ya riẹlẹ ọli, ọ rọ lighọ riẹlẹ ọli. Ọ ri emhikpa tsẹ shi abi o ghọle ọli shi.
\v 12 Isheghọ ni anye iJu ni e khi ẹgbọ eni ododẹ ni e kpẹ regbenga iKirisiti, e kuẹghiẹ Ẹshinẹgba shi ufumhi oyọli.
\v 13 Eri a li ku ẹ ma iKirisiti abi a rọ suọ oni ungmemhi igẹsikia, oni o khi usomhi onete oyi Ẹshinẹgba, abi ọ mie ẹ pfuese. Abi a rọ mie iKirisiti suọ, Ẹshinẹgba ọ rọ shi ọlẹlẹ shi ẹ egbe. Ayẹmhẹ-nọ-pfuasẹ ni Ọ kie kpẹ rọ nga na awa o khi oni ọlẹlẹ.
\v 14 Itobọ Ayẹmhẹ-nọ-pfuasẹ ni Ẹshinẹgba ọ kpẹ rọ na awa, awa rọ mhọli ọ shi udu khi Ẹshinẹgba ọ ya ri emini ọ rọ nga na ẹgbọ eyọli gbo na awa. Ẹghẹghẹ ni Ẹshinẹgba ọ́ rọ pfa awa ẹgbọ eyọli shi ekẹ nya, awa rọ mhọli eni emhi ena. Ona o ya ri ẹgbọ eyọli kuẹghiẹ oli shi ufumhi oyọli.
\s1 IPọlu ọ lema na eni e mie iJesu suọ ni e la Efesọsi
\p 
\v 15 Itobọ emhi ena nya ni Ẹshinẹgba ọ riẹlẹ, ali abi mhi te suọ abi a mie iJesu iKirisiti Ọnọmhuẹ suọ ni a gbo mhọli inono shi ẹgbọ eyi Ẹshinẹgba nya ọ,
\v 16 mhia tigbe yẹmhẹ ikphẹmhi-a, ni mhi ri itobọ oyẹ ẹ kphẹmhi na Ẹshinẹgba, ini mhi da lema na ẹ.
\v 17 Eri mhia lema Ẹshinẹgba ọyi iJesu iKirisiti Ọnọmhuẹ ọyawa, ọni ọ khi ita awa ni ọ mhọli ufumhi oniẹmhi, ọ rẹ ẹ mhọli ayẹmhẹ ilẹsingme. Ọ gbo ri egbe ọli khasẹ ẹ ni a lolo lẹsẹ ọli egbegbọ.
\v 18 Mhi gbo lema Ẹshinẹgba ọ khueghie ẹ udu-a ini a lẹsẹ oni igẹsikia oyọli, ini a gbo lẹsẹ irudushi ni a regbenga, ni Ẹshinẹgba ọ lu ẹ shi. Ni a gbo mẹ ẹpfue oyi ugu oniẹmhi oyọli ni eni e mie ọli suọ e mhọli.
\v 19 Mhi gbo lema li ọ zẹ ni a lẹsẹ ekpabọ ni e funẹ eyọli, ni ẹa mhuẹ irọkhọkhọ, ni a rọ na awa eni e miesuọ.
\v 20 Eni ekpabọ ena ọ rọ gbe akanya abi ọ rọ guise iKirisiti eghuli le abi ọ rọ ghua. Wẹwẹ ọ rọ ri iKirisiti shitọ obọ ita oyọli obini iloghie.\f + \fr 1:20 \ft Li zẹ \fq Iwolo 110.1\f*
\v 21 Oobọ iJesu iKirisiti ọ la mhẹsẹ na ekpabọ, ali itoto ali igẹni, ghe enete ghe eni ẹa ti, ghe eni a mẹ agbọ ona ne, ghe ena agbọ ni aa mẹ ne.
\v 22 Emhi nya Ẹshinẹgba ọ rọ shi ufuẹgẹ oyọli ni ọ mhẹsẹ shi. Lọli ọ zẹ iJesu ọzukhomhi emhi nya ni o pfọmhẹ igbaa oyi eni e mie iJesu iKirisiti suọ eyọli egbe.
\v 23 Ẹgbọ ni e mie iJesu suọ e khi idiegbe oyi iJesu, iJesu ọ khi ukhomhi. Ekpabọ ali agbọ oyi iJesu iKirisiti o vọsẹ agbọ eyi eni e mie ọli suọ. Ufumhi oyọli o gasẹ agbọ ali emhikpa odẹkhodẹ nya.\f + \fr 1:23 \ft Li zẹ \fq Iwolo 8.6; iKolo 1.18\f*
\c 2
\s1 Okhale oyi Ẹshinẹgba ọ rọ mie awa pfuese
\p 
\v 1 Ẹghẹghẹ ni o dọsẹ ni a rọ kpẹ la agbọ olamhẹ, a la agbọ umha-suọesọ, a khi ẹgbọ eni e ghu shi olamhẹ ni ẹa mhọli Ayẹmhẹ oyi Ẹshinẹgba.
\v 2 Ẹghẹghẹ aghọ ingeli agbọ a ngeli, a ri ungmemhi oyi ọkphaghiẹ ọni ọ khi oghie ayẹmhẹ alo ebili i gbe akanya. Oni ayẹmhẹ ona o kiele la agbọ oyi ẹgbọ ni ẹa ya suọ esọ na Ẹshinẹgba a gbe akanya.
\v 3 Ighọ awa nya awa kpẹ li ngeli. Awa ri ọghuẹmhẹ egbe, ali usamhi ebe ni udu oyi awa o gueyẹ awa a riẹlẹ emhikpa. Abi ẹgbọẹse na agbọ ni ẹa ya suọ esọ na Ẹshinẹgba e li ya pfua, awa kha li pfua.
\v 4 Ama Ẹshinẹgba ọ̌ nono ingme oyi awa gba, ighọ ilẹlemhi oyọli óó gbẹdi.
\v 5 Lọli o zẹ ni ọ rọ rọte obọ oyi iJesu iKirisiti ni ọ guise le ri agbọ ayẹmhẹ onogbọ na awa, aboriẹkhia khi eni umha-guẹkia o kẹsẹ-a awa khi. Okhale oyi Ẹshinẹgba a rọ mie ẹ pfuese.\f + \fr 2:5 \ft Li zẹ \fq iKolo 2.13\f*
\v 6 Eri ọ ri agbọ onogbọ oyi iKirisiti na awa, ọ ri awa nu iKirisiti shitọ obini iloghie, nu ọ li ẹ mhẹsẹ, itobọ emini iKirisiti ọ riẹlẹ na awa.
\v 7 Rọte iJesu iKirisiti Ẹshinẹgba ọ́ te ri okhale ni ọ mhọli na awa khasẹ, ogbenakọ ni ẹgbọ e mẹ ashini okhale oyọli o fu ramhi, ni ọa mhọli irọkhọkhọ.
\v 8 Okhale oyi Ẹshinẹgba a rọ mie ẹ pfuese abi u rọ miesuọ, ọa khi ingeli enete ni u ngeli e mie ẹ pfuese. Afuẹ-afuẹ ọ mie ẹ pfuese.
\v 9 Ẹshinẹgba ọa ri itobọ ingeli enete ni u ngeli mie ẹ pfuese, ini ọgbọkhọghuo ọ khi vuse ike.
\v 10 Ẹshinẹgba ọ ma awa. Ikanya enete ọ ma awa awa ke gbe abi awa ali iJesu iKirisiti awa rọ da ke khi ọghuo eghọ.
\s1 Ẹshinẹgba ọ she te iKirisiti ku ẹgbọ iJu ali ẹgbọ iJẹta gbe
\p 
\v 11 A yelele ẹgbọ enabi a khi ẹlẹlẹ, khi aa khi iJu. Ẹgbọ iJu e ma kpẹ ri ukpẹloe gbe ẹ, itobọ khi aa shẹlẹ a, ali itobọ khi aa khi ẹgbọ iJu. Ama ee lu egbe wẹ eni e khi egbegbi ẹgbọ, itobọ khi a shẹlẹ wẹ-a. Oshẹlẹ ni o khi akanya ni ẹgbọ e ri abọ gbe idiegbe.
\v 12 Yelele khi ẹghẹghẹ aghọ khi aa kpẹ ku ma iJesu iKirisiti ọ, a khi ọpfẹse shi ishiobọ ni Ẹshinẹgba ọ rọ nga na ẹgbọ iZirẹni. A khi eni ẹa mhọli iregbenga ni ẹa mhọli Ẹshinẹgba shi elemhi agbọ.
\v 13 Ama, memena, ẹẹ ni a kpẹ nuata shi Ẹshinẹgba ọ, ọ ri ọlia eyi iKirisiti ti ẹ mama egbe.
\p 
\v 14 IJesu iKirisiti ọ ri ẹgbọ iJẹta ali ẹgbọ iJu riẹlẹ. Ọ rue ugbe ibiselemhi ni o kpẹ la wẹ iteva odẹ-a, ọ rẹwẹ mele ẹgbọ eghuo-a.
\v 15 Eghuli ni ọ ghu ọ rọ shishi ishi ni e la wẹ iteva-a, Ini ọ mẹ asha ri ẹgbọ iJu ali ẹgbọ iJẹta khi ẹgbọ enegbọ eghuo. Ona ọ rọ rẹwẹ riẹlẹ ini e khi ke biselemhi egbe.\f + \fr 2:15 \ft Li zẹ \fq iKolo 2.14\f*
\v 16 Eghuli ni ọ ghu-a shi ọọra apfida ọ rọ ku ẹgbọ ena gbe, ọ gbo rẹwẹ ali Ẹshinẹgba riẹlẹ. Aghọ ibiselemhi egbewẹ o pfo shi.\f + \fr 2:16 \ft Li zẹ \fq iKolo 1.20\f*
\v 17 Usomhi onete oyi Ẹshinẹgba oyi opfọmhẹ, iJesu ọ bhale ya tsẹ abọ gueyẹ ẹgbọ iJẹta ni e nuata shi Ẹshinẹgba ọ, ali ẹgbọ iJu ni e timama Ẹshinẹgba.\f + \fr 2:17 \ft Li zẹ \fq Aza 57.19\f*
\v 18 Obọ oyi iJesu iKirisiti awa te mhọli Ayẹmhẹ oghuo ni o zẹ khi awa ga rọ dobẹ a lẹ deba Ẹshinẹgba.
\p 
\v 19 Itobọ ighọ ẹẹ ẹgbọ iJẹta, aa ke khi epfẹse, ama a she ku ma ẹgbọ eyi Ẹshinẹgba. Ena ọmhuẹ-apfẹ oghuo a ke ga khi.
\v 20 Oni idiegbe owa a li khi. Ighiusomhi na kẹ ni iKirisiti ọ ze ali emekẹguele eyi Ẹshinẹgba e khi igbaekẹle oyi oni owa. IJesu iKirisiti ọ mu oni owa mhuẹ.
\v 21 IKirisiti ọ zẹ ni echẹ ni a rọ ma oni owa nya e rọ toma, ni oni owa o rọ mele owa oniẹmhi a. Ọ rọ li khi oni o pfuasẹ na Ọnọmhuẹ.
\v 22 Itobọ khi a ku ma iJesu ọ, ọ rọ rẹ ẹ ma eni e mie ọli suọ. U ya mele owa ni Ayẹmhẹ oyi Ẹshinẹgba ọ ya ke la-a.
\c 3
\s1 Ẹshinẹgba ọ ghi iPọlu ghi ẹgbọ iJẹta
\p 
\v 1 Itobọ ona, mhẹmhẹ iPọlu mhi rọ lema na ẹ. Mhẹmhẹ ni a ri itobọ khi mhia gbe akanya na iJesu iKirisiti mu shi owa ighumha. Akanya abi mhi liẹ tse abọ usomhi onete oyi Ẹshinẹgba yẹ ẹ ẹgbọ iJẹta.
\v 2 O limhẹ ẹloe khi ẹẹ ẹgbọ iJẹta, khi a she kpẹ suọ khi Ẹshinẹgba ọ́ ghie mhẹ ghi ẹ mhi bhale ya tse abọ ye ẹ. Itobọ okhale oyọli ọ rọ ghie mhẹ usomhi ona, ni mhi kpaghiẹ ẹ obọ.
\v 3 Oni usomhi khi, ugbamhi ni Ẹshinẹgba ọ gba ni o khi oyi osheli, ni ọ́ khueghie-a khasẹ mhẹ. Mhi kpẹ khueghie ukukuọ li-a khasẹ ẹ elemhi ebe ni mhi kpẹ kẹkẹ ghi ẹ.
\v 4 Ini a zẹ ebe onana, a ya mẹ emini mhi lẹsẹ osheli oniẹmhi ni o khi osheli na iJesu iKirisiti, ni Ẹshinẹgba o gba.
\v 5 Ẹshinẹgba ọa kpẹ khueghie osheli emini ọ ya riẹlẹ ni ọ gba shi ekẹ khasẹ ẹgbọ na agbọ ena ẹlẹlẹ. Ama ọ she rọte elemhi Ayẹmhẹ-nọ-pfuasẹ khueghie ọli-a khasẹ ighiusomhi na kẹẹ ali emekẹguele eyi Ẹshinẹgba.
\v 6 Emini Ẹshinẹgba ọ gba khi, a ya rọte itsabọ usomhi onete oyi iJesu iKirisiti ri ẹgbọ iJẹta ni e miesuọ nu ẹgbọ iZirẹni ni e miesuọ le ugu oghuo, abi ẹgbọ ni e khi idiegbe oghuo. Ẹghẹghẹ aghọ ni a bhale ya ẹ khi ẹẹ ni aa khi ẹgbọ iJu, a nu ẹgbọ iJu mhuẹ obọ shi emini Ẹshinẹgba ọ rọte iJesu iKirisiti rọ nga na iJu.\f + \fr 3:6 \ft Li zẹ \fq iKolo 1.26-27\f*
\p 
\v 7 Ẹshinẹgba ọ ri akanya ni mhi rọ ọ tse abọ usomhi onete oyọli na mhẹ. Itobọ okhale oyọli ọ rọ ri oni akanya na mhẹ. Ọ ri ekpabọ eyọli rẹ mhẹ ẹ gbe oni akanya.
\v 8 Ini Ẹshinẹgba ọ̌ pfi ukpẹloe bino uwali ọgbọ ni mhi kpẹ khi ẹlẹlẹ lọ, ọa kha zẹ́ mhẹ́, mhi ke tse abọ usomhi onete oyọli. Ama itobọ okhale oyọli ọ́ rọ́ ri akanya ona na mhẹ mhi ka tse abọ usomhi onete oyi upfuemhi ni o la iKirisiti yẹ ẹ ẹgbọ iJẹta. Upfuemhi ni ọgbọ ọa dobẹ lẹsẹ udi ọli ẹ pfo.
\v 9 Ọ gbo zẹ mhẹ mhi ka khueghie-a khasẹ agbọ kpa abi ọ li ri oni osheli ni ọ gba nya ya tsẹ. Ẹshinẹgba ni ọ ma emhi nya ọ kpẹ rọ te igbaekẹle ri osheli ona sheli agbọ nya.
\v 10 Eri Ẹshinẹgba ọọ nono ni lọli rọte igbaa oyi eni e mie iJesu iKirisiti suọ ri ilẹsingme odẹ ebubu eyẹluẹ khasẹ igẹni ali ekpabọ na idane.
\v 11 Ina Ẹshinẹgba ọ te ekẹ gba li neni ọ ma agbọ. Rọ te iJesu iKirisiti Ọnọmhuẹ ọyi awa ọ te rọli tsẹ.
\v 12 Itobọ khi awa mie iJesu suọ, ali khi awa gbo ku gbe ọli ọ, awa rọ a mhuẹ igbedu rọ a lo deba Ẹshinẹgba.
\v 13 Itobọ ighọ, a khi zẹ ni egbe pfọ ẹ-a ini a suọ abi mhi liẹ mẹ osue shi itobọ khi mhia tse abọ usomhi onete oyi Ẹshinẹgba yẹ ẹ. Ochoghọ, a zẹ ni osue ni mhia mẹ o ri ufumhi oyi Ẹshinẹgba ghi ẹ.
\p 
\v 14 Lọli o zẹ ni mhi rọ wugha odalo oyi Ẹshinẹgba ni ọ khi ita awa a sọ iromhi na ẹ.
\v 15 Rọ te ayi ọli unuẹkpẹ nya ni e la agbọ ali iloghie e te le eva.
\v 16 Ẹshinẹgba ọ mhọli ikhivọsẹ eniẹmhi ni ọ rọ ọ na ẹgbọ eyọli, itobọ ighọ mhi rọ lema li, ọ ri Ayẹmhẹ oyọli ri udu oyẹ ẹ toto a,
\v 17 ini iKirisiti ọ lo ẹ udu shitọ kpẹ abi a mie ọli suọ. Mhi gbo lema Ẹshinẹgba ọ rẹ ẹ migha abi ọọra ni o pfi imhili lo ekẹ egbegbọ, ni a nono ingme oyi Ẹshinẹgba ali ingme egbe ẹ, ini a khi de.
\v 18 Mhi gbo lema Ẹshinẹgba ọ zẹ ni ẹẹ ali ẹgbọ eyi Ẹshinẹgba nya a dobẹ lẹsẹ abi inono oyi Ẹshinẹgba o gba ramhi.
\v 19 Ẹshinẹgba ọ zẹ ni a lẹsẹ inono ni iKirisiti ọ nono awa, inono ni o ghọ fu dọsẹ odẹ ni ọa mhọli ukpẹsẹ, ẹghẹghẹ aghọ ni ingeli eyi ẹẹ, e li abi eyi Ẹshinẹgba.
\p 
\v 20 A kphẹmhi na Ẹshinẹgba ni ọ mhọli ekpabọ rọ riẹlẹ emhi eniẹmhi, eni e fu dọsẹ emini awa mhila li, ali emini awa da dobẹ sa. Ekpabọ eyọli eni e la awa ayẹmhẹ ẹ gbe akanya, ọ deba a riẹlẹ eni emhi na awa.
\v 21 A zẹ ni awa ẹgbọ eyọli ni awa ali iJesu iKirisiti e khi ọghuo, e kuẹghiẹ Ẹshinẹgba, ogbe na akọ ali agbọagbọ, ya ramhi ukpẹsẹ. Atsẹ.
\c 4
\s1 Ikugbe onayi eni e miesuọ
\p 
\v 1 Mhẹmhẹ ni mhi ri itobọ khi mhia ga Ọnọmhuẹ la owa ighumha, mhi lema ẹ, a ke ngeli ingeli enete, enabi Ẹshinẹgba ọ́ ọ a ke ngeli ẹghẹghẹ ni ọ rọ lu ẹ.
\v 2 Emini a riẹlẹ nya, a ke ti egbe ẹ tiemhi ekẹ, a ri ọfiẹ ali ikuegbe-a nu egbe ke ngeli. A ri inono ni a nono egbe ri ipfọmhẹ-udu ke ngeli.\f + \fr 4:2 \ft Li zẹ \fq iKolo 3.12-13\f*
\v 3 A rọshẹka mu ikugbe ni Ayẹmhẹ-nọ-pfuasẹ o ku awa gbe mhuẹ ali elemhi opfọmhẹ ni o gẹnọ awa kugbe.
\v 4 Idiegbe oghuo awa khi, Ayẹmhẹ-nọ-pfuasẹ ọghuo ọ la awa egbe, Ighọ awa gbo li ri ẹloe shi ekẹ ẹ khẹ iregbenga oghuo oyi imiepfuese ni Ẹshinẹgba ọ rọ nga na awa abi ọ rọ lu awa.
\v 5 Ọnọmhuẹ ọghuo ni ọ khi iKirisiti, ali irudunga oghuo, ali ibatizi oghuo, awa mhọli.
\v 6 Ẹshinẹgba ni ọ khi itawa nya, awa a ga, lọli ọ mhẹsẹ a na awa nya, lọli ọ ri awa a gbe akanya oyọli, lọli ọ gbo la agbọ oyawa nya.
\p 
\v 7 Ama iKirisiti ọ́ kemhi afu ọdọda kẹ a na ọgbọgbọ ni ọ rọ ke gbe akanya oyọli. Lọlighuo ọ mhẹsẹ abi ọ li kemhi wẹ.
\v 8 Ona o zẹ ni ungmemhi oyi Ẹshinẹgba o rọ ọ. “Abi ọ rọ khọli ebe ọli pfuse-a nya, ọ nga obini o yagha nẹ nya, ọ ri ebe ọli ni ọ mu ọ le la orọlọ, ee deba li ukhu-khokho abi eni a mu okhọli. Ọ tigbe kemhi isomhopfa enete na ẹgbọ.”\f + \fr 4:8 \ft Li zẹ \fq Iwolo 68.18\f*
\v 9 Emini a ri ungmemhi oyi Ẹshinẹgba ona ngme, ni ọọ, “Ọ nga obini o yagha,” lọli khi, eri iKirisiti ọ kpẹ tiemhie agbọ ona, neni ọ nga idane obini o yagha.
\v 10 IJesu iKirisiti ọni ọ tiemhie agbọ ona, ọ gbo nga obini idane iloghie ni o yagha nẹ nya, ini ọ zẹ emhikpa ukhomhi ni e guẹ ga ti.
\v 11 IKirisiti ọ kemhi afu na kẹ na ọgbọgbọ. Ọ zẹ eghuo ighiusomhi na kẹẹ eyọli, ọ zẹ eghuo emekẹguele eyi Ẹshinẹgba, Ọ zẹ eghuo eni e kia tse abọ ungmemhi oyi Ẹshinẹgba, ọ zẹ eghuo eni eri ukpẹloe ẹ khu ẹgbọ eyi Ẹshinẹgba ali eni ẹ sẹsẹ wẹ.
\v 12 Eri ọ lina kemhi afu na wẹ ni e rẹwẹ ke gbe ikanya eyọli, ini eni e khi idiegbe oyọli e ke fu shọ, isheghọ ni idiegbe oyi iKirisiti o totoa elemhi ugamhi oyọli.
\v 13 Ina a li ya ke mẹ ọli, ramhi ẹghẹghẹ ni awa nya awa rọ kugbe ẹ khi ọghuo (abi awa mie Ẹshinẹgba suọ, ni awa gbo lẹsẹ omi ọli), ya ramhi ni awa rọ fu shi imiesuọ mele eni e womhẹloe shi imiesuọ, ramhi ni awa rọ ya womhẹloe nya abi iKirisiti.
\v 14 Ẹghẹghẹ aghọ awa aa ke ẹa li abi eniyẹ, ini ẹgbọ eni ẹ di ẹgbọ e khi dobẹ di awa ya mie emini ẹa khi egbegbingme suọ. Awa aa ke ya li abi ọkọ-okẹ oniẹmhi ni akpekpeli oniẹmhi o tsua gasẹ ukhomhi okẹ oniẹmhi,
\v 15 ni awa ri ochoghọ ke ngme igẹsikia elemhi inono, ni awa womhẹloe shi emhikpa, ni awa li abi iKirisiti Ọnọmhuẹ, ọni ọ li abi ukhomhi, awa li abi idiegbe oyọli.
\v 16 IKirisiti ọ ku ẹgbọ eyọli nya gbe abi idiegbe ọgbọ o tono elamhi manọ khi oghuo, ni uguabọ ọgbọgbọ o liẹ gbe akanya oyọli. Ẹghẹghẹ aghọ oni idiegbe nya o fu, o totoa, o womhẹloe shi ọ, ẹgbọ e mhọli inono na egbe.\f + \fr 4:16 \ft Li zẹ \fq iKolo 2.19\f*
\s1 Awa mu ingeli eyi awa pfi
\p 
\v 17 Itobọ ona, mhi lo ye ẹ ude, itobọ eva oyi Ọnọmhuẹ, a khi gbo ngeli abi ẹgbọ ni ẹa lẹsẹ Ẹshinẹgba, ni usamhi ni ẹẹ sa ọa mu amẹ.
\v 18 Ẹgbọ eghọghọ ẹa ya dobẹ lẹsẹ udi emhi eyi Ẹshinẹgba gboo. Ẹa mhuẹ obọ shi agbọ onogbọ oyi Ẹshinẹgba, itobọ umha lẹsẹ Ẹshinẹgba oyẹwẹ, igbe udu oyẹwẹ o tsua ghi wẹ.
\v 19 Egbe ẹa kẹ lili wẹ ini ẹ riẹlẹ ingme ebe. E she ri egbe wẹ na ikanya ebe eni ẹ ghọle wẹ dẹ. Ingeli khi ingeli eyi itsẹbọ ẹẹ ngeli. Ingeli eghọghọ ẹ ghọle wẹ ẹghẹghẹ kpa e ke ngeli.
\p 
\v 20 Ama, ọa khi ina a sẹsẹ ẹ a li ke ngeli abi a rọ lẹsẹ mie iKirisiti suọ.
\v 21 Mhi lẹsẹ khi a she suọ ingme oyọli, a gbo sẹsẹ ẹ igẹsikia ni o la ingme oyọli.
\v 22 Emini a sẹsẹ ẹ khi, a khi ke ngeli eni ingeli ni a kpẹ ngeli, ni ọghuẹmhẹ egbe ni ẹa ti eghọ e rẹ ẹ ngeli, ni e yese ẹ agbọ-a.\f + \fr 4:22 \ft Li zẹ \fq iKolo 3.9\f*
\v 23 A zẹ ni Ẹshinẹgba ọ mu isamhi ali ingeli eyi ẹ pfi ya khi enegbọ.
\v 24 Ẹshinẹgba ọ she ri ingeli enegbọ enabi eyọli na ẹ. Itobọ ighọ a ke ngeli abi Ẹshinẹgba, elemhi ingeli enete ali ipfuasẹ.\f + \fr 4:24 \ft Li zẹ \fq Igbae 1.26; iKolo 3.10\f*
\p 
\v 25 Irarighọ, a khi ke gbo lo ẹgbhọli, ama a ke gue igẹsikia ye egbe, itobọ khi eri awa li abi iguabọ ọdọda eyi idiegbe oghuo.\f + \fr 4:25 \ft Li zẹ \fq iZaka 8.16\f*
\v 26 Ini u mẹ elemhi ibibi, khi lamhẹ, khi zẹ obili o bi ya ẹ elemhi-ibibi oyẹ shi ẹ elemhi,\f + \fr 4:26 \ft Li zẹ \fq Iwolo 4.4\f*
\v 27 Khi ri ẹghẹghẹ na ọkphaghiẹ ni ọ mu ẹ fẹ.
\v 28 Ọni ọ kpẹ ẹ do ughiatọ ọ khi ke gbo do, ama ọ ri abọ eyọli ke gbe akanya ni ọ te mẹ ẹ ke le, ni ọ́ gbo te mẹ ẹ ke kemhi na eni ẹa mhọli.
\p 
\v 29 A khi ke ngme ingmemhi ichimhi unu, ama a ke ngme ungmemhi onete ni e ri egbe ẹ mu ọgbọ ni e ri ọgbọ ẹ fu shi imiesuọ. Zobẹ ni ungmemhi oyi ẹ o guẹ ke de shi ẹghẹghẹ ni a kha rọ ngme ọli, ni o mhọli ikpaghiobọ na eni e suọ li.
\v 30 A khi ri egbe pfọ Ayẹmhẹ-nọ-pfuasẹ oyi Ẹshinẹgba-a. Itobọ khi Ayẹmhẹ-nọ-pfuasẹ khi ọlẹlẹ ni Ẹshinẹgba ọ shi shi ẹ egbe, ni o rẹ lẹsẹ ọli shi udu gboo khi ogbẹlẹ ọọ bhale ni ọ ya pfa ẹ olamhẹ eyẹ ẹ shi ekẹ.
\v 31 Zobẹ ni, iyese-a, ofu, elemhi ibibi, okhọli, ali iyese egbe eva, ghe imuegbe ọbe kpa, ali ikanya ebe nya, e lase ẹ udu le.
\v 32 A ke mhọli ilẹlemhi na egbe ẹ. A rọ ke topfa egbe abi Ẹshinẹgba ọ ri itobọ iKirisiti rọ topfa ẹ.\f + \fr 4:32 \ft Li zẹ \fq iKolo 3.13\f*
\c 5
\s1 Angeli oyi ọni ọ miesuọ
\p 
\v 1 Irarighọ, a rọshẹka ke khọnya Ẹshinẹgba abi a rọ da khi imi ọli ni ọ nono egbegbọ eghọ.
\v 2 A la agbọ inono, ẹzẹzẹ abi iKirisiti ọ nono awa ni ọ rọ ghu-a na awa abi iluasobo ni ẹ kphela ni e ghọle Ẹshinẹgba.\f + \fr 5:2 \ft Li zẹ \fq Okiali 29.18; Iwolo 40.6\f*
\p 
\v 3 Abi a rọ khi ẹgbọ eni e pfuasẹ eghọ, a khi riẹlẹ emini ọa gbe akanya nabi itsẹbọ, ukẹliẹ emini ọọ pfi omama. A khi khi ena-emhi-ituegbe. Emhi enana ẹa khi emini a suọ khi a mẹ iteva oyẹ ẹ ẹgbọ eyi Ẹshinẹgba ni e khi eni e pfuasẹ.
\v 4 A khi gbo ngme ingmemhi omama ali ungmemhi ọyẹghẹ unu, wẹ khi eri a gbudu li iwẹghiẹ ali iba izẹzẹ ni e wẹ-a. Ochoghọ, a ke kuẹghiẹ Ẹshinẹgba.
\v 5 A lẹsẹ khi, ghe ẹgbọ ena itsẹbọ, ali ọna ingeli omama, ali ọna emhi ituegbe, khi ẹa ya mhọli okemhi shi iloghie oyi iKirisiti ali oyi Ẹshinẹgba. Eri ọna emhi-ituegbe ọ li abi ọni ọọ ga ikhumhi.
\p 
\v 6 A khi zẹ ni ọgbọkhọghuo ọ ri ingmemhi afuẹ di ẹ, itobọ khi ẹgbọ eni ẹ ngeli ingeli olamhẹ eghọghọ, Ẹshinẹgba ọ ya na wẹ ali ẹgbọ ni ẹa ya suọ esọ na li osue.
\v 7 Irarighọ, khi ku ma ẹgbọ eni ẹ ngeli ingeli olamhẹ eghọghọ ọ.
\v 8 Ẹlẹlẹ a kpẹ la alo ebili, ama memena elemhi ákpá a ke la, itobọ khi, a ku ma Ọnọmhuẹ ọ. Irarighọ, a ke ngeli abi eni e la elemhi ákpá.
\v 9 Itobọ khi onete ali ipfuasẹ, ghe igẹsikia e khi umọmhi ni ákpá o rọ lasele.
\v 10 Rọshẹka ni u wẹna emini ẹ ti Ọnọmhuẹ ẹloe, ni u ke riẹlẹ wẹ.
\v 11 Khi ke nu ẹgbọ na alo ebili gbe ikanya afuẹ na alo ebili, ni ẹa mhuẹ eleli. Ri ochoghọ ke khueghie osheli oyẹwẹ-a.
\v 12 Emhi omama ọọ khi, ini a ta unu emini ẹgbọ ena alo ebili ẹ riẹlẹ elemhi osheli.
\v 13 Ama, ini ákpá o khueghie ikanya eghọghọ-a gbo o, ẹgbọ e ya lẹsẹ emini e khi,
\v 14 itobọ khi ákpá ọọ khueghie emhi nya-a, ni a ke mẹ gbo o. Lọli Ebe-no-pfuasẹ o rọ, “A guale eni ẹ lesẹ a, a khi li abi ọni ọ ghua, ni ákpá oyi iKirisiti o la ẹ egbe ke gẹ.”
\p 
\v 15 Itobọ ighọ lẹsẹ abi u ke li ya ke ngeli. Khi ke ngeli abi ọyẹghẹ, ama ke ngeli abi ọlẹsingme.
\v 16 Ini u da mhọli ẹghẹghẹ rọ ya riẹlẹ onete ne, nyanya riẹlẹ ọli, itobọ khi agbọ ingme-obe awa ke la.\f + \fr 5:16 \ft Li zẹ \fq iKolo 4.5\f*
\v 17 Itobọ ighọ a khi khi eyẹghẹ, ama a zẹ ni a lẹsẹ emini ẹ ghọle Ọnọmhuẹ ni a ke riẹlẹ.
\v 18 Khi da onyọ pfuẹchẹ egbe-a, ochoghọ zẹ ni Ayẹmhẹ-nọ-pfuasẹ o ke vọ agbọ oyẹ.
\v 19 A ke to iwolo ena irudunga khasẹ egbe, ke to uwolo eni e te ẹ́ udu lase ke kuẹghiẹ Ọnọmhuẹ.
\v 20 Ẹghẹghẹ kpa, ke kuẹghiẹ Ẹshinẹgba ita awa shi emhikpa, itobọ iJesu iKirisiti Ọnọmhuẹ ọyi awa.\f + \fr 5:20 \ft Li zẹ \fq iKolo 3.16-17\f*
\s1 Ingeli oyi emọse ali ikpotso ni e la ughuẹ
\p 
\v 21 A ri egbe tiemhie na egbe ẹ pfo nya itobọ khi u mu ekpẹ na iKirisiti.
\v 22 Ẹẹ ikpotso ni a la ughuẹ, a ri egbe ẹ tiemhie na ọdọ ẹ, abi u li ri egbe ẹ tiemhie na Ọnọmhuẹ.\f + \fr 5:22 \ft Li zẹ \fq iKolo 3.18; 1 iPit 3.1\f*
\v 23 Itobọ khi ọmọse ọ khi ukhomhi oyi ọkpotso ọni ọ rọ shi ughuẹ, ẹzẹzẹ abi iKirisiti ọ khi ukhomhi oyi igba oyi ẹgbọ eni e mie ọli suọ. Eni e mie ọli suọ e khi idiegbe oyọli ni ọ mie pfuese.
\v 24 Itobọ ighọ ọkpotso ọgbọgbọ ni ọ mhuẹ ọdọ, ọ nyẹsẹ ukhomhi na ọdọ li pfo, elemhi emhi nya, abi igba oyi eni e mie iKirisiti suọ e li ri egbe wẹ na li.
\p 
\v 25 Ẹẹ emọse eni e ri ikpotso shi, a mhọli inono ni o te ekẹ elemhi udu lasele shi ighuẹ ẹ ọ, ẹzẹzẹ abi iKirisiti ọ nono igba oyi eni e mie ọli suọ, ni o zẹ khi ọ ghu-a na wẹ.\f + \fr 5:25 \ft Li zẹ \fq iKolo 3.19; 1 iPit 3.7\f*
\v 26 Ọ ri itoto oyi ungmemhi oyi Ẹshinẹgba ri eni e miesuọ khi eni e pfuasẹ, ọ ri amẹ khuẹsẹ wẹ-a ni e dala.
\v 27 Eri ọ riẹlẹ ona na igba oyi eni e mie ọli suọ, ni ọ rọ ri ẹwẹ somhi otse, ni e zẹ ọli rọ migha odalo oyọli, ni e khi ẹgbọ ni uchimhi ọa ta ma egbe, wẹkhi eni e mhọli ichinya, u kẹ liẹ khi emhi olese ni ọa ti, ama ni e khi eni e pfuasẹ ni ẹa mhọli umha-guẹkia.
\v 28 Ina, ẹ́ẹ́ emọse e li nono ingme oyi ughuẹ wẹ abi e nono ingme oyi idiegbe oyẹwẹ. Ọni ọ nono ingme oyi ughuẹ ọli ingme egbe ọli ọ nono.
\v 29 Ini a mema bino ọ bie, a ya mẹ khi ọgbọkhọghuo ọa ya biselemhi egbe ọli, ama eri ọ ri emhi na egbe ọli ẹ le, ọ ri ukpẹloe ẹ khu egbe ọli, ẹzẹzẹ abi iKirisiti o li ri ukpẹloe ẹ khu igba oyi eni e mie ọli suọ oyọli.
\v 30 Uguabọ idiegbe oyi iKirisiti awa khi.
\v 31 “Onana o zẹ ni ọmọse ọ rọ ri ita li ali inyọ li ẹ shi ekẹ, ọ ya toma ughuẹ ọli ọ, ẹghẹghẹ aghọ wẹwẹ aava e mele ọgbọ ọghuo a.”\f + \fr 5:31 \ft Li zẹ \fq Igbae 2.24\f*
\v 32 Ukpokpomhi osheli na ni mhi gue ẹ le, ni o la iteva iKirisiti ali igba oyi eni e mie ọli suọ.
\v 33 Ama, ni mhi rọ gbe ọli ukhomhi, ọmọse ọgbọgbọ ọ lolo nono ingme oyi ughuẹ ọli abi ọ li nono ingme egbe ọli, yẹyẹ ọkpotso ni u la ughuẹ, lolo mu ekpẹ ke na ọdọ ẹ.
\c 6
\s1 IPọlu ọ ye eniyẹ ali eni e bia wẹ ude
\p 
\v 1 Eniyẹ, a ri ungmemhi oyi eni e bia ẹ ke gbe akanya, itobọ khi lọli o ti ni eni e mie Ọnọmhuẹ suọ e ke riẹlẹ.\f + \fr 6:1 \ft Li zẹ \fq iKolo 3.20\f*
\v 2 “Mu ekpẹ na ita ẹ ali inyẹ ẹ.” Ona o khi ushi oni ododẹ ni Ẹshinẹgba ọ shi ni ọ ri ishiobọ ma.
\v 3 “Ini u mu ekpẹ na eni e bia ẹ, agbọ oyẹ o ya ke je odalo egbegbọ, u ya gbo li agbọ tẹsẹ agbọ ona.”\f + \fr 6:3 \ft Li zẹ \fq Okiali 20.12; iDẹut 5.16\f*
\v 4 Ẹẹ ita eniyẹ, a khi riẹlẹ emini o ri elemhi ẹ ke bi imiẹ, a ri ochoghọ ke ri ukpẹloe khu wẹ, a ke sẹsẹ wẹ odẹ oni o ghọle Ọnọmhuẹ.\f + \fr 6:4 \ft Li zẹ \fq iKolo 3.21\f*
\s1 IPọlu ọ ye ighumha ali eni e mhọli wẹ ude
\p 
\v 5 Ẹẹ ighumha, a ri ungmemhi oyi ọni ọ mhọli ẹ ni ọ la agbọ ona ke gbe akanya. A rọte ekelemhi udu ke mu ekpẹ na wẹ. A ri ukpẹloe oni o fu ke bino wẹ abi a kha li ri ungmemhi oyi iKirisiti gbe akanya.
\v 6 A ke ri ingme oyi ẹwẹ gbe akanya ẹghẹghẹ kpa, ọa khi ini ẹ bino ẹ tsẹ a rọ ri ingme oyẹwẹ ke gbe akanya ini e ba ke kuẹghiẹ ẹ. Ama a ke li abi ighumha eyi iKirisiti e li mu ekpẹ ẹ na li, ikhi eni e rọte ekelemhi-udu oyẹwẹ ẹ riẹlẹ emini Ẹshinẹgba ọọ a ke riẹlẹ.
\v 7 Rọte elemhi udu oyẹ ke gbe akanya abinẹ khi Ọnọmhuẹ wa ga, itobọ ọ́ a khi ẹgbọ tsẹ awa ga.
\v 8 Rọli shi udu khi Ọnọmhuẹ ọ̀ ya somhi ọgbọgbọ opfa shi ikanya enete ni ọ gbe, shi oghumha o, shi ọni ọ́ a khi oghumha.\f + \fr 6:8 \ft Li zẹ \fq iKolo 3.22-25\f*
\v 9 Ẹẹ eni e mhọli ighumha, a li guẹ ke ngeli deba ighumha eyi ẹẹ, A khi sọ wẹ ulishi khi a ya nasẹ wẹ. A lẹsẹ khi ọni ọ mhọli ẹ, mhọli ighumha eyi ẹẹ, ọ la iloghie. Lọli ọ khi ọni ọa mhuẹ khi ọna ọ kpe mhẹ dọsẹ ọghọ.\f + \fr 6:9 \ft Li zẹ \fq iDẹut 10.17; iKolo 3.25; 4.1\f*
\s1 Abi eni e miesuọ e li nu ọkphaghiẹ ẹ khọli
\p 
\v 10 Ni mhi rọ gbe oni ungmemhi oyẹmhẹ ukhomhi, a rọte obọ oyi Ọnọmhuẹ mie itoto eniẹmhi. Rọte ekpabọ eniẹmhi eyọli mie itoto.
\v 11 Rue itsua okhọli nya ni Ẹshinẹgba ọ rọ nẹ sọ, ni u dobẹ nu (ekpabọ ali odẹ ebubu ni ọkphaghiẹ ọ rọte ẹ lasele shi ọgbọ ọ) khẹ abọ pfuse a.
\v 12 Itobọ khi ọa khi ẹgbọ nabi awa, awa nu ẹ khọli, ama itoto ali ekpabọ ali ighie eyẹwẹ ni ẹ mhẹsẹ agbọ ona alo ebili, ali ayẹmhẹ ebe eyi ọkphaghiẹ ena irarogbe ni awa a ya mẹ.
\v 13 Itobọ ighọ ri itsua okhọli eni Ẹshinẹgba ọ rọ nẹ nya sọ, ini u dobẹ khọli ẹlẹ ni ekpabọ ebe e mu okhọli ẹ vule shi ẹ ọ. Ini u khọli se nya, gbe lighi.\fig Itsua Okhọli|src="hk00194c.tif" size="col" loc="EPH 6.13" copy="TIF" ref="6.13"\fig*
\p 
\v 14 Mu egbe ni u rọ khọli okhọli elemhi ayẹmhẹ. Ẹghẹghẹ kpa, mie emini e khi igẹsikia suọ. Eri ona o li abi ọgbẹnẹ ni ọkhọli-okhuẹ ọ rọ mu oku. Ke ngeli ingeli eni e migha shi ipfuasẹ odalo oyi Ẹshinẹgba. Ona o migha shi awulu akhuli ni a rọ mu aye ini a ya khọli.\f + \fr 6:14 \ft Li zẹ \fq Aza 11.5; 59.17\f*
\v 15 Ke mu egbe ẹghẹghẹ kpa ni u rọ gue usomhi onete oyi Ẹshinẹgba oyi opfọmhẹ le, onana o li abi ẹkuẹ ni ọkhọli-okhuẹ ọọ sọ shi awẹ.\f + \fr 6:15 \ft Li zẹ \fq Aza 52.7\f*
\v 16 Ke regbenga Ẹshinẹgba, ona o ya khukhu ẹ obọ oyi ikuatse ni ọkphaghiẹ ọọ nono ni lọli kuali ẹ, eri ona o li abi ofiasẹ ni ọkhọli-okhuẹ ọ rọ mhọli obọ rọ ke fiase ote-osuẹ erali kua.
\v 17 Yelele khi Ẹshinẹgba ọ mie ẹ pfuese. Onana o li abi arula akhuli ni ọkhọli-okhuẹ ọ rọ rughu ẹ ye okhọli. Rue ungmemhi oyi Ẹshinẹgba ni Ayẹmhẹ-nọ-pfuasẹ ọ rọ nẹ mhuẹ obọ ke khọli, eri o li abi ọgbhọrọ ni a rọ khọli okhọli.\f + \fr 6:17 \ft Li zẹ \fq Aza 59.17\f*
\v 18 Rọ te elemhi Ayẹmhẹ no pfuasẹ ke lema ẹghẹghẹ kpa. U kha lema, ke sọ iromhi ọdọda. Ke liẹ Ẹshinẹgba ọ kpaghiẹ ẹ obọ. Abi u liẹ lema, ke tọkpẹ. Ke lema na ẹgbọ eyi Ẹshinẹgba ẹghẹghẹ kpa.
\v 19 A gbo li ke lema na mhẹ ni Ẹshinẹgba ọ ri ungmemhi shi mhẹ unu ẹghẹghẹ kpa ini mhi ya khueghie unu a ngme, ni mhi dobẹ khueghie osheli ni o la usomhi onete oyi Ẹshinẹgba-a khasẹ ẹgbọ, ini mhi khaa ngme, ni ulishi o khi mu mhẹ.
\v 20 Ọni ọ to-ẹoli iKirisiti ẹ tse abọ usomhi onete oyi Ẹshinẹgba ona mhi khi. Ona o zẹ ni mhi rọ la owa ighumha. Itobọ ighọ, a ke lema na mhẹ ni Ẹshinẹgba ọ ri udu na mhẹ ke tse abọ usomhi onete oyọli abi mhi kha li tse ọli.
\s1 IPọlu ọ lema Ẹshinẹgba ọ khivọsẹ na eni e miesuọ
\p 
\v 21 Inyọghuo awa ni awa nono ingme oyọli, ni ọ gbe akanya oyi Ọnọmhuẹ te odẹ igẹsikia, iTakikọsi ọ khi. Ọ ya gue ingme eyẹmhẹ nya yẹ ẹ, ni a rọ gbo lẹsẹ abi o li mhẹ egbe ali emini mhia riẹlẹ.\f + \fr 6:21 \ft Li zẹ \fq Ika 20.4; 2 iTimo 4.12\f*
\v 22 Itobọ ighọ mhi rọ ghie ọli ghi ẹ, ni a rọ lẹsẹ abi anye li la ọ shi, ni ọ gbo ri udu shi ẹ ọ.\f + \fr 6:22 \ft Li zẹ \fq iKolo 4.7-8\f*
\v 23 Ẹshinẹgba ita awa ali iJesu iKirisiti Ọnọmhuẹ, e ri opfọmhẹ na ẹ ni a miesuọ. E ka rẹ ẹ nono ingme egbe ẹ, ali ni a kie ke mie iJesu suọ
\v 24 Ẹshinẹgba ọ ka li okhale na ẹgbọ nya ni e nono ingme oyi iJesu iKirisiti Ọnọmhuẹ ọyi awa, ikhi inono ni ọa ya pfo ghue.
