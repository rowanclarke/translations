\id PHM Sanskrit Bible (NT) in Velthuis Script (satyaveda.h ।) 
\h Philemon 
\toc1 philomona.m patra.m 
\toc2 philomona.h 
\toc3 philomona.h 
\mt1 philomona.m patra.m 
\c 1  
\p  
\v 1 khrii.s.tasya yii"so rbandidaasa.h paulastiithiyanaamaa bhraataa ca priya.m sahakaari.na.m philiimona.m 
\p  
\v 2 priyaam aappiyaa.m sahasenaam aarkhippa.m philiimonasya g.rhe sthitaa.m samiti nca prati patra.m likhata.h| 
\p  
\v 3 asmaaka.m taata ii"svara.h prabhu ryii"sukhrii.s.ta"sca yu.smaan prati "saantim anugraha nca kriyaastaa.m| 
\p  
\v 4 prabhu.m yii"su.m prati sarvvaan pavitralokaan prati ca tava premavi"svaasayo rv.rttaanta.m ni"samyaaha.m 
\p  
\v 5 praarthanaasamaye tava naamoccaarayan nirantara.m mame"svara.m dhanya.m vadaami| 
\p  
\v 6 asmaasu yadyat saujanya.m vidyate tat sarvva.m khrii.s.ta.m yii"su.m yat prati bhavatiiti j naanaaya tava vi"svaasamuulikaa daana"siilataa yat saphalaa bhavet tadaham icchaami| 
\p  
\v 7 he bhraata.h, tvayaa pavitralokaanaa.m praa.na aapyaayitaa abhavan etasmaat tava premnaasmaaka.m mahaan aananda.h saantvanaa ca jaata.h| 
\p  
\v 8 tvayaa yat karttavya.m tat tvaam aaj naapayitu.m yadyapyaha.m khrii.s.tenaatiivotsuko bhaveya.m tathaapi v.rddha 
\p  
\v 9 idaanii.m yii"sukhrii.s.tasya bandidaasa"scaivambhuuto ya.h paula.h so.aha.m tvaa.m vinetu.m vara.m manye| 
\p  
\v 10 ata.h "s.r"nkhalabaddho.aha.m yamajanaya.m ta.m madiiyatanayam onii.simam adhi tvaa.m vinaye| 
\p  
\v 11 sa puurvva.m tavaanupakaaraka aasiit kintvidaanii.m tava mama copakaarii bhavati| 
\p  
\v 12 tamevaaha.m tava samiipa.m pre.sayaami, ato madiiyapraa.nasvaruupa.h sa tvayaanug.rhyataa.m| 
\p  
\v 13 susa.mvaadasya k.rte "s.r"nkhalabaddho.aha.m paricaarakamiva ta.m svasannidhau varttayitum aiccha.m| 
\p  
\v 14 kintu tava saujanya.m yad balena na bhuutvaa svecchaayaa.h phala.m bhavet tadartha.m tava sammati.m vinaa kimapi karttavya.m naamanye| 
\p  
\v 15 ko jaanaati k.sa.nakaalaartha.m tvattastasya vicchedo.abhavad etasyaayam abhipraayo yat tvam anantakaalaartha.m ta.m lapsyase 
\p  
\v 16 puna rdaasamiva lapsyase tannahi kintu daasaat "sre.s.tha.m mama priya.m tava ca "saariirikasambandhaat prabhusambandhaacca tato.adhika.m priya.m bhraataramiva| 
\p  
\v 17 ato heto ryadi maa.m sahabhaagina.m jaanaasi tarhi maamiva tamanug.rhaa.na| 
\p  
\v 18 tena yadi tava kimapyaparaaddha.m tubhya.m kimapi dhaaryyate vaa tarhi tat mameti viditvaa ga.naya| 
\p  
\v 19 aha.m tat pari"sotsyaami, etat paulo.aha.m svahastena likhaami, yatastva.m svapraa.naan api mahya.m dhaarayasi tad vaktu.m necchaami| 
\p  
\v 20 bho bhraata.h, prabho.h k.rte mama vaa nchaa.m puuraya khrii.s.tasya k.rte mama praa.naan aapyaayaya| 
\p  
\v 21 tavaaj naagraahitve vi"svasya mayaa etat likhyate mayaa yaducyate tato.adhika.m tvayaa kaari.syata iti jaanaami| 
\p  
\v 22 tatkara.nasamaye madarthamapi vaasag.rha.m tvayaa sajjiikriyataa.m yato yu.smaaka.m praarthanaanaa.m phalaruupo vara ivaaha.m yu.smabhya.m daayi.sye mameti pratyaa"saa jaayate| 
\p  
\v 23 khrii.s.tasya yii"saa.h k.rte mayaa saha bandiripaaphraa 
\p  
\v 24 mama sahakaari.no maarka aari.s.taarkho diimaa luuka"sca tvaa.m namaskaara.m vedayanti| 
\p  
\v 25 asmaaka.m prabho ryii"sukhrii.s.tasyaanugraho yu.smaakam aatmanaa saha bhuuyaat| aamen|