\id EZR  
\h  ĽEsela 
\toc1 Ko E Tohi  Ľa  ĽEsela 
\toc2  ĽEsela 
\toc3  ĽEsl 
\mt2 KO E TOHI  
\mt3  ĽA  
\mt1  ĽESELA  
\cl KO E VAHE  
\c 1  
\cd \it 1 Ko e fono  Ľa Kolesi ke langa  Ľae faletapu. 5  ĽOku tokonaki  Ľe he kakai ki he Ľenau liu hake. 7  ĽOku  Ľatu  Ľe Kolesi  Ľae ngaahi ipu  Ľoe faletapu kia Sesipasa.\it*  
\p
\v 1 Pea ko eni,  Ľi he  Ľuluaki ta Ľu  Ľo Kolesi ko e tu Ľi  Ľo Peasia, pea koe Ľuhi ke fakamo Ľoni ai  Ľae folofola  Ľa Sihova  Ľi he ngutu  Ľo Selemaia, na Ľe ue Ľi  Ľe Sihova  Ľae laumńĀlie  Ľo Kolesi ko e tu Ľi  Ľo Peasia, pea na Ľe fanongonongo  Ľe ia  Ľae fono  Ľi hono pule Ľanga kotoa pńď, pea na Ľe tohi ia foki,  Ľo pehńď,  
\v 2 ‚ÄĆ ĽOku pehńď  Ľe Kolesi ko e tu Ľi  Ľo Peasia, ‚ÄúKuo tuku kiate au  Ľe Sihova ko e  ĽOtua  Ľoe langi  Ľae ngaahi pule Ľanga kotoa pńď  Ľo mńĀmani: pea kuo fekau  Ľe ia kiate au ke u langa  Ľae fale mo Ľona  Ľi SelŇęsalema,  Ľaia  Ľoku  Ľi Siuta.  
\v 3 Ko hai ia  Ľiate kimoutolu  Ľi hono kakai kotoa pńď? Ke  Ľiate ia  Ľa hono  ĽOtua, pea ke  Ľalu hake ia ki SelŇęsalema,  Ľaia  Ľoku  Ľi Siuta, pea ke langa  Ľae fale kia Sihova ko e  ĽOtua  Ľo  ĽIsileli, (ko ia ia ko e  ĽOtua,)  Ľaia  Ľoku  Ľi SelŇęsalema.  
\v 4 Pea mo ia fulipńď  Ľoku toe  Ľi ha potu  Ľaia  Ľoku  ĽńĀunofo ia ki ai, tuku ke tokoni ia  Ľe he kau tangata  Ľo hono potu  Ľaki  Ľae siliva, pea mo e koula, pea mo e ngaahi koloa pea mo e fanga manu, ko hono fakalahi ia  Ľoe ngaahi me Ľa  Ľoku foaki loto lelei ki he fale  Ľoe  ĽOtua  Ľoku  Ľi SelŇęsalema.‚ÄĚ   
\p
\v 5 ¬∂ Pea na Ľe toki tu Ľu hake ai  Ľae kau tu Ľukimu Ľa  Ľi he mńĀtu Ľa  Ľo Siuta mo Penisimani, mo e kau taula Ľeiki, pea mo e kau Livai, pea mo kinautolu kotoa pńď na Ľe fakaakeake honau laumńĀlie  Ľe he  ĽOtua, ke  Ľalu hake ke langa  Ľae fale  Ľo Sihova  Ľaia  Ľoku  Ľi SelŇęsalema.  
\v 6 Pea na Ľe fakamńĀlohi honau nima  Ľekinautolu kotoa pńď na Ľe nonofo fakataha mo kinautolu,  Ľaki  Ľae ngaahi ipu siliva, mo e koula, mo e ngaahi koloa, mo e fanga manu, pea mo e ngaahi me Ľa ma Ľongo Ľonga, ka  Ľoku lau kehe  Ľae ngaahi me Ľa kotoa pńď na Ľe  Ľatu loto  Ľofa pe.   
\p
\v 7 ¬∂ Pea na Ľe fetuku mai foki  Ľe Kolesi ko e tu Ľi  Ľae ngaahi ipu  Ľoe fale  Ľo Sihova,  Ľaia na Ľe fetuku  Ľe Nepukanesa mei SelŇęsalema, pea na Ľa ne tuku ia  Ľi he fale  Ľo hono ngaahi  Ľotua;  
\v 8 ‚ÄĆ ĽIo, na Ľe  Ľomi ia \add kotoa pńď \add* Ľe Kolesi ko e tu Ľi  Ľo Peasia  Ľi he nima  Ľo Mitilitati ko e tauhi koloa, pea lau ia kia Sesipasa, ko e  Ľeiki  Ľo Siuta.  
\v 9 Pea ko hono lau eni: ko e ipu lafalafa koula  Ľe tolungofulu, mo e ipu lafalafa siliva  Ľe taha afe, mo e hele  Ľe uofulu ma hiva,  
\v 10 Ko e ipu luoluo koula  Ľe tolungofulu, mo e ipu luoluo siliva  Ľoe anga  Ľe taha ko e fńĀngeau mo e hongofulu, pea ko e ngaahi ipu kehe  Ľe taha afe.  
\v 11 Ko e ngaahi ipu koula mo e siliva kotoa pńď ko e nima afe mo e nimangeau. Na Ľe fetuku eni kotoa pńď  Ľe Sesipasa fakataha mo kinautolu  Ľoe kau pŇćpula  Ľaia na Ľe  Ľohake mei Papilone ki SelŇęsalema.   
\c 2  
\cd \it 1 Ko hono lau  Ľoe kakai na Ľe toe ha Ľu. 36  ĽOe kau taula Ľeiki. 40  ĽOe kau Livai, 43  ĽOe kau Netenimi. 55 Ko e kau tamaio Ľeiki  Ľa Solomone. 67 Ko e kau taula Ľeiki na Ľe  Ľikai fa Ľa fakahńĀ honau hohoko. 64 Ko hono lau kńĀtoa  Ľokinautolu, mo  Ľenau ngaahi me Ľa. 68 Ko  Ľenau ngaahi me Ľa Ľofa.\it*  
\p
\v 1 Pea ko e fńĀnau eni  Ľae fonua  Ľaia na Ľe  Ľalu hake mei he fakapŇćpula,  Ľiate kinautolu na Ľe fetuku ke mama Ľo,  Ľaia na Ľe fetuku  Ľe Nepukanesa ko e tu Ľi  Ľo Papilone ki Papilone, pea nau toe ha Ľu ki SelŇęsalema, mo Siuta,  Ľo taki taha ki he Ľene kolo   
\li1
\v 2 Ko kinautolu na Ľe ha Ľu mo Selupepeli: ko Sesua, mo Nehemaia, mo Selaia, mo Lielaia, mo Moatikei, mo Pilisani, mo Misipa, mo Pikivai, mo Lihumi, mo Peana. Ko hono lau eni  Ľoe kau tangata  Ľi he kakai  Ľo  ĽIsileli:   
\li1
\v 3 Ko e fńĀnau  Ľa Palosi, ko e toko ua afe, mo e toko teau, mo e fitungofulu ma ua.   
\li1
\v 4 Ko e fńĀnau  Ľa Sifatia, ko e toko tolungeau mo e toko fitungofulu ma ua.   
\li1
\v 5 Ko e fńĀnau  Ľa  ĽAla, ko e toko fitungeau mo e toko fitungofulu ma ua.   
\li1
\v 6 Ko e fńĀnau  Ľa Pehati-Moape;  Ľi he fńĀnau  Ľa Sesua mo Soape, ko e toko ua afe mo e toko valungeau mo e toko hongofulu ma toko ua.   
\li1
\v 7 Ko e fńĀnau  Ľa  ĽIlami ko e taha afe mo e toko uangeau mo e toko nimangofulu ma toko fńĀ.   
\li1
\v 8 Ko e fńĀnau  Ľa Satu, ko e toko hivangeau mo e toko fńĀngofulu ma toko nima.   
\li1
\v 9 Ko e fńĀnau  Ľa Sakai, ko e toko nimangeau mo e toko onongofulu.   
\li1
\v 10 Ko e fńĀnau  Ľa Pani, ko e toko onongeau mo e toko fńĀngofulu ma ua.   
\li1
\v 11 Ko e fńĀnau  Ľa Pepai, ko e toko onongeau mo e toko uofulu ma toko tolu.   
\li1
\v 12 Ko e fńĀnau  Ľa  ĽAsikati, ko e taha afe, mo e toko uangeau mo e toko uofulu ma ua.   
\li1
\v 13 Ko e fńĀnau  Ľa  ĽAtonikami, ko e toko onongeau mo e toko onongofulu ma ono.   
\li1
\v 14 Ko e fńĀnau  Ľa Pikivai, ko e toko ua afe mo e toko nimangofulu mo e toko ono.   
\li1
\v 15 Ko e fńĀnau  Ľa  ĽAtini, ko e toko fńĀngeau, mo e toko nimangofulu mo e toko fńĀ.   
\li1
\v 16 Ko e fńĀnau  Ľa  ĽAteli  Ľo Hesekaia, ko e toko hivangofulu mo e toko valu.   
\li1
\v 17 Ko e fńĀnau  Ľa Pisai, ko e toko tolungeau mo e toko uofulu mo e toko tolu.   
\li1
\v 18 Ko e fńĀnau  Ľa Sola, ko e toko teau mo e toko hongofulu mo e toko ua.   
\li1
\v 19 Ko e fńĀnau  Ľa Hasumi, ko e toko uangeau mo e toko uofulu ma toko tolu.   
\li1
\v 20 Ko e fńĀnau  Ľa Kipa, ko e toko hivangofulu ma toko nima.   
\li1
\v 21 Ko e fńĀnau  Ľa Petelihema, ko e toko teau mo e uofulu ma toko tolu.   
\li1
\v 22 Ko e kau tangata  Ľo Nitofa, ko e toko nimangofulu, mo e toko ono.   
\li1
\v 23 Ko e kau tangata  Ľo  ĽAnatoti, ko e toko teau mo e toko uofulu ma toko valu.   
\li1
\v 24 Ko e fńĀnau  Ľa  ĽAsimaveti, ko e toko fńĀngofulu mo e toko ua.   
\li1
\v 25 Ko e fńĀnau  Ľa Kesa-Sialimi, ko Kifila mo Piheloti, ko e toko fitungeau mo e toko fńĀngofulu ma toko tolu.   
\li1
\v 26 Ko e fńĀnau  Ľa Lama mo Kepa, ko e toko onongeau mo e toko uofulu mo e tokotaha.   
\li1
\v 27 Ko e kau tangata  Ľo Mikimasi, ko e toko teau mo e toko uofulu ma toko ua.   
\li1
\v 28 Ko e kau tangata  Ľo Peteli mo  ĽAi, ko e toko uangeau mo e toko uofulu ma toko tolu.   
\li1
\v 29 Ko e fńĀnau  Ľa Nipo, ko e toko nimangofulu mo e toko ua.   
\li1
\v 30 Ko e fńĀnau  Ľa Makipisi, ko e toko teau mo e toko nimangofulu ma toko ono.   
\li1
\v 31 Ko e fńĀnau  Ľae  ĽIlami  Ľe taha, ko e taha afe, mo e uangeau mo e toko nimangofulu ma fńĀ.   
\li1
\v 32 Ko e fńĀnau  Ľa Halimi, ko e toko tolungeau, mo e toko uofulu.   
\li1
\v 33 Ko e fńĀnau  Ľa Loti, mo Hatiti, mo Ono, ko e toko fitungeau mo e toko uofulu ma nima.   
\li1
\v 34 Ko e fńĀnau  Ľa Seliko, ko e toko tolungeau mo e toko fńĀngofulu ma nima.   
\li1
\v 35 Ko e fńĀnau  Ľa Sina Ľa, ko e toko tolu afe mo e toko onongeau ma tolungofulu.   
\li1
\v 36 Ko e kau taula Ľeiki eni: ko e fńĀnau  Ľa Sitaia,  Ľi he fale  Ľo Sesua, ko e toko hivangeau mo e toko fitungofulu ma tolu.   
\li1
\v 37 Ko e fńĀnau  Ľa Imeli, ko e taha afe, mo e toko nimangofulu ma ua.   
\li1
\v 38 Ko e fńĀnau  Ľa Pasuli, ko e taha afe mo e toko uangeau mo e toko fńĀngofulu ma fitu.   
\li1
\v 39 Ko e fńĀnau  Ľa Halimi, ko e taha afe, mo e toko hongofulu ma fitu.   
\li1
\v 40 Ko e kau Livai eni: ko e fńĀnau  Ľa Sesua mo e Katimieli,  Ľi he fńĀnau  Ľa Hotevia, na Ľe toko fitungofulu ma fńĀ.   
\li1
\v 41 Ko e kau hiva eni: ko e fńĀnau  Ľa  ĽAsafi ko e toko teau mo e toko uofulu ma valu.   
\li1
\v 42 Ko e fńĀnau eni  Ľae kau le Ľo matapńĀ: ko e fńĀnau  Ľa Salumi, ko e fńĀnau  Ľa  ĽAteli, ko e fńĀnau  Ľa Talimoni, ko e fńĀnau  Ľo  ĽAkupi, ko e fńĀnau  Ľa Hetita, ko e fńĀnau  Ľo Sopai, ko kinautolu kotoa pńď ko e toko teau mo e toko tolungofulu ma hiva.   
\li1
\v 43 Ko e kau Netenimi eni: ko e fńĀnau  Ľa Siha, ko e fńĀnau  Ľa Hasufa, ko e fńĀnau  Ľa Tapaoti,   
\li1
\v 44 Ko e fńĀnau  Ľa Kilosi, ko e fńĀnau  Ľa Sia, ko e fńĀnau  Ľa Patoni,   
\li1
\v 45 Ko e fńĀnau  Ľa Lipana, ko e fńĀnau  Ľa Hakapa, ko e fńĀnau  Ľa  ĽAkupi,   
\li1
\v 46 Ko e fńĀnau  Ľa Hakapi, ko e fńĀnau  Ľa Salimei, ko e fńĀnau  Ľa Hanani,   
\li1
\v 47 Ko e fńĀnau  Ľa Kiteli, ko e fńĀnau  Ľa Kaha, ko e fńĀnau  Ľa Liaia,   
\li1
\v 48 Ko e fńĀnau  Ľa Lesini, ko e fńĀnau  Ľa Nikota, ko e fńĀnau  Ľa Kasami,   
\li1
\v 49 Ko e fńĀnau  Ľa Usa, ko e fńĀnau  Ľa Pasea, ko e fńĀnau  Ľa Pesai.   
\li1
\v 50 Ko e fńĀnau  Ľa  ĽAsina, ko e fńĀnau  Ľa Mehunimi, ko e fńĀnau  Ľa Nifisimi.   
\li1
\v 51 Ko e fńĀnau  Ľa Pakipuki, ko e fńĀnau  Ľa Hakufa, ko e fńĀnau  Ľa Hahua.   
\li1
\v 52 Ko e fńĀnau  Ľa Pasiliti, ko e fńĀnau  Ľa Mehita, ko e fńĀnau  Ľa Halisa,   
\li1
\v 53 Ko e fńĀnau  Ľa Pakosi, ko e fńĀnau  Ľa Sisila, ko e fńĀnau  Ľa Tama,   
\li1
\v 54 Ko e fńĀnau  Ľa Nisia, ko e fńĀnau  Ľa Hatifa.   
\li1
\v 55 Ko e fńĀnau eni  Ľae kau tamaio Ľeiki  Ľa Solomone: ko e fńĀnau  Ľa Sotei, ko e fńĀnau  Ľa Sofeleti, ko e fńĀnau  Ľa Pelita,   
\li1
\v 56 Ko e fńĀnau  Ľa Sala, ko e fńĀnau  Ľa Takoni, ko e fńĀnau  Ľa Kiteli,   
\li1
\v 57 Ko e fńĀnau  Ľa Sifatia, ko e fńĀnau  Ľa Hatili, ko e fńĀnau  Ľa Pokileti  Ľo Sipemi, ko e fńĀnau  Ľa  ĽAmi.   
\li1
\v 58 Ko e kau Netenimi kotoa pńď, mo e ngaahi fńĀnau  Ľae kau tamaio Ľeiki  Ľa Solomone, na Ľe toko tolungeau mo e toko hivangofulu ma ua.   
\li1
\v 59 Pea ko kinautolu ni ia na Ľe  Ľalu hake mei Telimela, mo Telihalesa, mo Kilupi, mo  ĽAtani, mo Imeli: ka na Ľe  Ľikai te nau fa Ľa fakahńĀ  Ľae fale  Ľo  Ľenau tamai, mo honau hohoko, pe kuo  Ľo  ĽIsileli  Ľakinautolu pe  Ľikai:   
\li1
\v 60 Ko e fńĀnau  Ľa Tilaia, ko e fńĀnau  Ľa Topaia, ko e fńĀnau  Ľa Nikota, ko e toko onongeau mo e toko nimangofulu ma ua.   
\li1
\v 61 Pea  Ľi he fńĀnau  Ľae kau taula Ľeiki ko e fńĀnau  Ľa Hopaia, ko e fńĀnau  Ľa Kose, ko e fńĀnau  Ľa Pasilai;  Ľaia na Ľa ne ma Ľu  Ľae uaifi  Ľi he ngaahi  Ľofefine  Ľo Pasilai ko e tangata Kiliati, pea na Ľe ui ia  Ľi hono hingoa.  
\v 62 Na Ľe kumi  Ľekinautolu honau hohoko fakataha mo kinautolu na Ľe lau  Ľi he hokohoko, ka na Ľe  Ľikai fa Ľa  Ľilo ia: ko ia na Ľe tukuange ai  Ľakinautolu  Ľo hangńď ha ta Ľema Ľa, mei he ngńĀue  Ľoe taula Ľeiki.  
\v 63 Pea na Ľe tala  Ľe he  Ľeiki pule kiate kinautolu, ke  Ľoua na Ľa nau kai  Ľi he ngaahi me Ľa mńĀ Ľoni Ľoni lahi, kae Ľoua ke tu Ľu hake ha taula Ľeiki  Ľaki  Ľae  ĽUlimi mo e Tumemi.   
\p
\v 64 ¬∂ Ko e kakai  Ľoe fakataha kotoa pńď ko e toko fńĀ mano, mo e toko ua afe, mo e tolungeau ma onongofulu,  
\v 65 Ka  Ľoku lau kehe  Ľenau kau tamaio Ľeiki mo  Ľenau ngaahi kaunanga, ko e toko fitu afe, mo e toko tolungeau ma tolungofulu ma fitu: pea na Ľe  Ľiate kinautolu  Ľae kau tangata hiva mo e kau fefine hiva  Ľe toko uangeau.  
\v 66 Ko  Ľenau fanga hoosi ko e fitungeau mo e tolungofulu ma ono: ko  Ľenau fanga miuli, ko e uangeau mo e fńĀngofulu ma nima;  
\v 67 Ko  Ľenau fanga kńĀmeli, ko e fńĀngeau mo e tolungofulu ma nima; ko  Ľenau fanga  Ľasi, ko e ono afe mo e fitungeau mo e uofulu.   
\p
\v 68 ¬∂ Pea  Ľi he hoko  Ľae ni Ľihi na Ľe tu Ľukimu Ľa  Ľi he ngaahi tamai ki he fale  Ľo Sihova  Ľaia  Ľoku  Ľi SelŇęsalema, na Ľa nau  Ľatu fiemńĀlie pea mo e fale  Ľoe  ĽOtua ke fokotu Ľu hake ia  Ľi hono potu:  
\v 69 Na Ľa nau foaki  Ľo fakatatau ki he Ľenau mafai ki he koloa ma Ľae ngńĀue, ko e talami koula  Ľe ono mano mo e taha afe, pea mo e siliva ko e paunite  Ľe nima afe, mo e kofu  Ľe teau ki he kau taula Ľeiki.  
\v 70 Ko ia na Ľe nofo  Ľae kau taula Ľeiki, mo e kau Livai, mo e ni Ľihi  Ľi he kakai, mo e kau hiva, mo e kau le Ľo matapńĀ, mo e kau Netenimi,  Ľi honau ngaahi kolo, pea mo  ĽIsileli kotoa pńď ki honau ngaahi kolo  Ľonautolu.   
\c 3  
\cd \it 1  ĽOku fokotu Ľu  Ľae feilaulau Ľanga. 4  ĽOku fa Ľa fai  Ľae feilaulau. 7 Kuo tokonaki  Ľae kau tangata ngńĀue. 8 Kuo  Ľai  Ľae ngaahi tu Ľunga ki he faletapu  Ľi he fiefia lahi mo e tangi mamahi.\it*  
\p
\v 1 Pea  Ľi he Ľene hoko mai hono fitu  Ľoe mńĀhina, pea nofo  Ľi honau ngaahi kolo  Ľae fńĀnau  Ľa  ĽIsileli, na Ľe fakakńĀtoa fakataha  Ľe he kakai ki SelŇęsalema,  Ľo hangńď ko e tangata pe taha.  
\v 2 Pea na Ľe tu Ľu hake ai  Ľa Sesua ko e foha  Ľo Sosataki, mo hono ngaahi kńĀinga ko e kau taula Ľeiki, mo Selupepeli ko e foha  Ľo Sialiteli mo hono ngaahi kńĀinga,  Ľonau langa  Ľae feilaulau Ľanga  Ľoe  ĽOtua  Ľo  ĽIsileli, ke  Ľatu  Ľi ai  Ľae ngaahi feilaulau,  Ľo hangńď ko ia kuo tohi  Ľi he fono  Ľa MŇćsese ko e tangata  Ľae  ĽOtua.  
\v 3 Pea na Ľa nau fokotu Ľu  Ľae feilaulau Ľanga ki hono ngaahi tu Ľunga; he na Ľe  Ľiate kinautolu  Ľae manavahńď koe Ľuhi ko e kakai  Ľoe ngaahi fonua ko ia: pea na Ľa nau  Ľatu  Ľi ai  Ľae ngaahi feilaulau tutu kia Sihova,  Ľio,  Ľae ngaahi feilaulau tutu  Ľi he pongipongi mo e efiafi.  
\v 4 Na Ľa nau fai  Ľae kńĀtoanga foki  Ľoe ngaahi fale fehikitaki,  Ľo hangńď ko ia kuo tohi, pea na Ľe  Ľatu lau pe  Ľi he  Ľaho kotoa pńď  Ľae ngaahi feilaulau tutu;  Ľo fakatatau ki hono anga,  Ľo taau mo e ngńĀue  Ľae  Ľaho kotoa pńď;  
\v 5 Pea na Ľa nau toki  Ľatu  Ľae feilaulau tutu fai ma Ľu pe,  Ľi he ngaahi tu Ľu efiafi, mo e ngaahi kńĀtoanga kotofa kotoa pńď  Ľa Sihova  Ľaia na Ľe fakatapui, pea meiate ia kotoa pńď na Ľe  Ľatu loto  Ľofa  Ľae feilaulau kia Sihova.  
\v 6 Mei he  Ľuluaki  Ľaho  Ľo hono fitu  Ľoe mńĀhina na Ľa nau kamata ke  Ľatu  Ľae ngaahi feilaulau tutu kia Sihova. Ka na Ľe te Ľeki fakatoka  Ľae tu Ľunga  Ľoe faletapu  Ľo Sihova.  
\v 7 Na Ľa nau  Ľatu  Ľae ngaahi pa Ľanga foki ki he kau tufunga maka, pea ki he kau tufunga  Ľakau, mo e me Ľa kai, mo e inu, mo e lolo, kiate kinautolu  Ľo Saitoni, pea kiate kinautolu  Ľo Taia, ke fetuku  Ľae ngaahi  Ľakau ko e sita mei Lepanoni ki he tahi  Ľo Sopa,  Ľo fakatatau ki hono tu Ľutu Ľuni meia Kolesi ko e tu Ľi  Ľo Peasia.   
\p
\v 8 ¬∂ Pea ko eni,  Ľi hono ua ta Ľu  Ľo  Ľenau ha Ľu ki he fale  Ľoe  ĽOtua  Ľi SelŇęsalema,  Ľi hono ua  Ľoe mńĀhina, na Ľe kamata  Ľe Selupepeli ko e foha  Ľo Sialiteli, mo Sesua ko e foha  Ľo Sosataki, mo hono toe  Ľo honau kńĀinga ko e kau taula Ľeiki, mo e kau Livai, mo kinautolu kotoa pńď na Ľe ha Ľu mei he nofo pŇćpula ki SelŇęsalema;  Ľonau fakanofo  Ľae kau Livai, mei he ta Ľu  Ľe uofulu  Ľo honau motu Ľa  Ľo fai hake, ke kamata  Ľae ngńĀue  Ľoe fale  Ľo Sihova.  
\v 9 Pea na Ľe tu Ľu fakataha ai  Ľa Sesua mo hono ngaahi foha mo hono ngaahi kńĀinga, mo Katimieli mo hono ngaahi foha, ko e ngaahi foha  Ľo Siuta, ke fakahoko  Ľae kau tangata ngńĀue  Ľi he fale  Ľoe  ĽOtua: ko e ngaahi foha  Ľo Henatati, mo honau ngaahi foha mo honau ngaahi kńĀinga ko e kau Livai.  
\v 10 Pea  Ľi he  Ľai  Ľe he kau langa fale  Ľae tu Ľunga  Ľoe faletapu  Ľo Sihova, na Ľa nau tuku ke tu Ľu  Ľae kau taula Ľeiki  Ľi honau ngaahi kofu mo e ngaahi me Ľalea, mo e kau Livai ko e ngaahi foha  Ľo  ĽAsafi mo e ngaahi me Ľa pakihi ke fakaongolelei  Ľa Sihova,  Ľo fakatatau ki he tu Ľutu Ľuni  Ľo Tevita ko e tu Ľi  Ľo  ĽIsileli.  
\v 11 Pea na Ľa nau hiva kotoa pńď  Ľo fai fakalakanga  Ľi he fakaongolelei mo e fakafeta Ľi kia Sihova: ‚ÄúKo e me Ľa  Ľi he Ľene angalelei, he  Ľoku tolonga  Ľene anga Ľofa ki  ĽIsileli  Ľo ta Ľengata.‚ÄĚ Pea na Ľe kalanga  Ľae kakai kotoa pńď  Ľi he kalanga lahi,  Ľi he Ľenau fakafeta Ľi kia Sihova, koe Ľuhi kuo  Ľai  Ľae tu Ľunga  Ľoe fale  Ľo Sihova.  
\v 12 Ka ko e tokolahi  Ľoe kau taula Ľeiki, mo e kau Livai mo e kau tu Ľu ki mu Ľa  Ľi he ngaahi tamai,  Ľaia ko e kau tangata motu Ľa, na Ľe mamata ki he  Ľuluaki fale,  Ľi he ai  Ľae tu Ľunga  Ľoe fale ni  Ľi honau  Ľao, na Ľa nau tangi le Ľo lahi; pea kalanga  Ľae tokolahi  Ľi he fiefia.  
\v 13 Ko ia na Ľe  Ľikai fa Ľa ongo Ľi ke  Ľilo  Ľe he kakai  Ľae kalanga  Ľoe fiefia mei he longoa Ľa  Ľoe tangi  Ľae kakai: he na Ľe kalanga  Ľe he kakai  Ľi he kalanga lahi, pea na Ľe ongo Ľi  Ľae longoa Ľa ki he mama Ľo.   
\c 4  
\cd \it 1 Ko e fie ta Ľofi  Ľe he ni Ľihi  Ľae langa hake  Ľoe faletapu. 17 Ko e tu Ľutu Ľuni  Ľa  ĽAtakisekisi. 23 Kuo ta Ľofi  Ľae langa fale.\it*  
\p
\v 1 Pea  Ľi he fanongo  Ľe he ngaahi fili  Ľo Siuta mo Penisimani  Ľoku langa  Ľae faletapu kia Sihova ko e  ĽOtua  Ľo  ĽIsileli  Ľe he fńĀnau na Ľe fakapŇćpula:  
\v 2 Na Ľa nau ha Ľu ai kia Selupepeli, pea ki he kau tu Ľukimu Ľa  Ľi he kau mńĀtu Ľa,  Ľonau pehńď kiate kinautolu, ‚ÄúTuku ke mau langa mo kimoutolu: he  Ľoku mau kumi ki homou  ĽOtua,  Ľo hangńď ko kimoutolu; pea kuo mau feilaulau kiate ia talu  Ľae ngaahi  Ľaho  Ľo Esahatoni ko e tu Ľi  Ľo  ĽAsilia,  Ľaia na Ľe  Ľomi  Ľakimautolu ki heni.‚ÄĚ  
\v 3 Ka na Ľe lea  Ľa Selupepeli, mo Sesua, mo hono toe  Ľoe kau mńĀtu Ľa tu Ľukimu Ľa  Ľo  ĽIsileli,  Ľo pehńď kiate kinautolu, ‚Äú ĽOku  Ľikai te mou kau si Ľi mo kimautolu  Ľi he langa  Ľae fale ki homau  ĽOtua; ka temau fai fakataha  Ľekimautolu pe  Ľae langa fale kia Sihova ko e  ĽOtua  Ľo  ĽIsileli,  Ľo hangńď ko e fekau  Ľae tu Ľi ko Kolesi ko e tu Ľi  Ľo Peasia kiate kimautolu.‚ÄĚ  
\v 4 Pea na Ľe toki fakavaivai  Ľe he kakai  Ľoe fonua  Ľae nima  Ľoe kakai  Ľo Siuta,  Ľo fakamamahi  Ľakinautolu  Ľi he langa fale,  
\v 5 Pea na Ľa nau totongi ki he kau fakakaukau ke ta Ľofi kiate kinautolu, mo fakata Ľe Ľaonga  Ľenau tu Ľutu Ľuni,  Ľi he ngaahi  Ľaho kotoa pńď  Ľo Kolesi ko e tu Ľi  Ľo Peasia,  Ľo hoko mo e pule  Ľa Talaiasi ko e tu Ľi  Ľo Peasia.  
\v 6 Pea  Ľi he pule  Ľa  ĽAhasivelo,  Ľi hono kamata Ľanga  Ľo  Ľene pule, na Ľa nau tohi kiate ia  Ľae tohi talakovi Ľi  Ľae kakai  Ľo Siuta mo SelŇęsalema.   
\p
\v 7 ¬∂ Pea na Ľe tohi  Ľi he ngaahi  Ľaho  Ľo  ĽAtakisekisi  Ľe Pisilami, mo Mitilitati mo Tapeli, mo hono toe  Ľo  Ľenau kaume Ľa, kia  ĽAtakisekisi ko e tu Ľi  Ľo Peasia; pea na Ľe fai  Ľae tohi  Ľi he lea fakaSilia, pea na Ľe fakamatala ia  Ľi he lea fakaSilia.  
\v 8 Na Ľe tohi  Ľe he  Ľeiki fakamaau ko Lihumi mo Simisai ko e tangata tohi  Ľae tohi fakakovi Ľi  Ľo SelŇęsalema kia  ĽAtakisekisi ko e tu Ľi  Ľo pehńď:  
\v 9 ‚ÄúPea na Ľe tohi ai  Ľe Lihumi ko e  Ľeiki fakamaau mo Simisai ko e tangata tohi, mo hono toe  Ľo  Ľenau kaume Ľa: ko e kau Tinaie mo e kau  ĽAfasatikai, ko e kau Tapilai mo e kau  ĽAfalisai, ko e kau  ĽAkivi, mo e kau Papilone, mo e kau Susa, mo e kau Tehavi, mo e kau  ĽElami,  
\v 10 Mo hono toe  Ľoe ngaahi pule Ľanga  Ľaia na Ľe  Ľomi  Ľe he  Ľeiki lahi mo ongolelei ko  ĽAsinapa, pea tuku ki he ngaahi kolo  Ľo Samńďlia, mo hono toe  Ľoku  Ľi he potu kauvai ni  Ľoe vaitafe, pea  Ľi he kuonga ko ia.‚ÄĚ   
\p
\v 11 ¬∂ Ko hono hiki eni  Ľoe tohi  Ľaia na Ľa nau  Ľave kiate ia, ‚Äú Ľio, kia  ĽAtakisekisi ko e tu Ľi: ‚ÄúKo ho Ľo kau tamaio Ľeiki ko e kau tangata  Ľi he potu kauvai ni  Ľoe vaitafe, pea  Ľi he kuonga ko eni.  
\v 12 Ke  Ľilo  Ľe he tu Ľi, koe Ľuhi ko e kau Siu na Ľe  Ľalu hake meiate koe kiate kimautolu kuo nau hoko ki SelŇęsalema, pea  Ľoku nau langa  Ľae kolo angakovi mo Ľo fa Ľa angatu Ľu, pea kuo nau fokotu Ľu hake hono ngaahi  ĽńĀ maka, pea kuo nau fakahoko hono ngaahi tu Ľunga.  
\v 13 Ko eni ke  Ľilo  Ľe he tu Ľi, kapau  Ľe langa  Ľae kolo ni, pea toe fokotu Ľu  Ľa hono ngaahi  ĽńĀ maka,  Ľe  Ľikai te nau kei totongi, pea tukuhau, pe totongi fakatau, pea te ke maumau ai  Ľae tukuhau ki he ngaahi tu Ľi.  
\v 14 Pea ko eni, ko e me Ľa  Ľi he Ľemau ma Ľu homau tokoni mei he fale  Ľoe tu Ľi, pea na Ľe  Ľikai taau mo kimautolu ke mamata ki he fakaongokovi  Ľoe tu Ľi, ko ia kuo mau fekau ai  Ľo fakahńĀ ia ki he tu Ľi;  
\v 15 Koe Ľuhi ke fai  Ľae kumi  Ľi he tohi fakamanatu  Ľa ho Ľo ngaahi tamai: ko ia te ke  Ľilo ai  Ľi he tohi  Ľoe tohi fakamanatu, mo ke  Ľilo ko e kolo ni ko e kolo angatu Ľu, pea kovi ki he ngaahi tu Ľi mo e ngaahi fonua, pea na Ľa nau langa Ľi  Ľae angatu Ľu  Ľi ai  Ľi mu Ľa: ko e me Ľa ko ia na Ľe faka Ľauha ai  Ľae kolo ni.  
\v 16 ‚ÄĆ ĽOku mau fakapapau ki he tu Ľi, kapau  Ľe toe langa  Ľae kolo ni, pea fokotu Ľu hono  ĽńĀ maka, ko e me Ľa ko ia  Ľe  Ľikai te ke ma Ľu ai ha tofi Ľa  Ľi he potu kauvai ni  Ľoe vaitafe.‚ÄĚ   
\p
\v 17 ¬∂ Pea na Ľe  Ľave  Ľe he tu Ľi  Ľa hono tali kia Lihumi ko e  Ľeiki fakamaau, mo Simisai ko e tangata tohi, pea ki hono toe  Ľo  Ľenau kaume Ľa na Ľe nofo  Ľi Samńďlia, pea ko hono toe na Ľe nofo ki he kauvai  Ľe taha  Ľoe vaitafe, \add  Ľo pehńď\add*, ‚ÄúMou fiemńĀlie pe  Ľi he kuonga ni.   
\pi1
\v 18 ‚ÄúKo e tohi na Ľa mou fai  Ľo  Ľomi kiate au na Ľe lau totonu ia  Ľi hoku  Ľao.  
\v 19 Pea ne u fekau, pea na Ľe fai  Ľae kumi, pea kuo  Ľilo ko e kolo ni na Ľe fai  Ľae angatu Ľu  Ľi mu Ľa ki he ngaahi tu Ľi, pea na Ľe fai  Ľi ai  Ľae angatu Ľu mo e angakovi.  
\v 20 Pea na Ľe  Ľi ai  Ľi mu Ľa  Ľae ngaahi tu Ľi mńĀlohi lahi foki na Ľe pule  Ľi SelŇęsalema,  Ľaia na Ľe pule ki he ngaahi fonua kotoa pńď  Ľi he kauvai  Ľe taha  Ľoe vaitafe; pea na Ľe  Ľatu kiate kinautolu  Ľae totongi, mo e tukuhau, mo e totongi fakatau.  
\v 21 Pea ko eni mou fekau ki he kau tangata ke tuku, pea ke  Ľoua na Ľa langa  Ľae kolo ni, kae Ľoua ke hoko atu ha fekau  Ľe taha meiate au,  
\v 22 Pea ko eni, vakai,  Ľoua na Ľa mou li Ľaki  Ľae me Ľa ni: ko e hńĀ ka tupu ai  Ľae kovi ke kovi ai  Ľae ngaahi tu Ľi?‚ÄĚ   
\p
\v 23 ¬∂ Pea ko eni  Ľi he lau hono hiki  Ľoe tohi  Ľae tu Ľi ko  ĽAtakisekisi  Ľi he  Ľao  Ľo Lihumi mo Simisai ko e tangata tohi, mo honau kaume Ľa, na Ľa nau  Ľalu fakato Ľoto Ľo hake ki SelŇęsalema ki he kakai Siu, pea ta Ľofi fakamńĀlohi pe  Ľakinautolu ke tuku.  
\v 24 Pea na Ľe toki tuku ai  Ľae ngńĀue ki he fale  Ľoe  ĽOtua  Ľaia  Ľoku  Ľi SelŇęsalema. Ko ia na Ľe tuku ia  Ľo a Ľu ki hono ua ta Ľu  Ľoe pule  Ľa Talaiasi ko e tu Ľi  Ľo Peasia.   
\c 5  
\cd \it 1  ĽI he tokoni  Ľa Hakeai mo Sakalia, na Ľe toe fekau  Ľa Selupepeli mo Sesua,  Ľae langa  Ľoe faletapu. 3 Na Ľe  Ľikai mafai  Ľa Tatinei mo Sita-Posinei ke ta Ľofi. 6 Ko  Ľenau tohi kovi kia Talaiasi ki he kakai Siu.\it*  
\p
\v 1 Pea koe ongo palŇćfita, ko Hakeai ko e palŇćfita, mo Sakalia ko e foha  Ľo Ito, na Ľa na lea ki he kakai Siu na Ľe  Ľi Siuta mo SelŇęsalema  Ľi he huafa  Ľoe  ĽOtua  Ľo  ĽIsileli,  Ľio, kiate kinautolu.  
\v 2 Pea na Ľe tu Ľu hake  Ľa Selupepeli ko e foha  Ľo Sialiteli, mo Sesua ko e foha  Ľo Sosataki, pea kamata langa  Ľae fale  Ľoe  ĽOtua  Ľaia  Ľoku  Ľi SelŇęsalema; pea na Ľe  Ľiate kinautolu  Ľae kau palŇćfita  Ľoe  ĽOtua ke tokoni Ľi  Ľakinautolu.   
\p
\v 3 ¬∂ Pea na Ľe ha Ľu kiate kinautolu  Ľi he kuonga ko ia  Ľa Tatinei, ko e pule  Ľi he potu kauvai ni  Ľoe vaitafe, mo Sita-Posinei, mo hona ngaahi kaume Ľa,  Ľonau lea pehńď kiate kinautolu, ‚ÄúKo hai kuo ne fekau  Ľakimoutolu ke langa  Ľae fale ni, pea ke fakama Ľopo Ľopo  Ľae  ĽńĀ maka ni?‚ÄĚ  
\v 4 Pea na Ľa mau tala kiate kinautolu  Ľo pehńď ni, ‚ÄúKo e hńĀ  Ľae hingoa  Ľae kau tangata,  Ľoku fai  Ľae langa fale ni?  
\v 5 Ka ko e fofonga  Ľo honau  ĽOtua na Ľe  Ľi he kau mńĀtu Ľa  Ľoe kakai Siu, ko ia na Ľe  Ľikai te nau fa Ľa fai ke ta Ľofi, kae Ľoua ke hoko atu ia kia Talaiasi: pea na Ľa nau toki  Ľave hono tali tohi ki he me Ľa ni.   
\p
\v 6 ¬∂ ‚ÄúKo hono hiki eni  Ľoe tohi  Ľaia na Ľe fai mo  Ľatu kia Talaiasi ko e tu Ľi,  Ľe Tatinei ko e pule  Ľi he potu kauvai ni  Ľoe vaitafe, mo Sita-Posinei, mo hono kaume Ľa ko e kau  ĽAfasatikai,  Ľaia na Ľe  Ľi he potu kauvai ni  Ľoe vaitafe.  
\v 7 ‚ÄúNa Ľa nau  Ľave  Ľae tohi kiate ia,  Ľaia na Ľe tohi  Ľi ai  Ľo pehńď; Ke  Ľia Talaiasi ko e tu Ľi  Ľae fiemńĀlie lahi.   
\pi1
\v 8 ‚ÄúKe  Ľilo  Ľe he tu Ľi, na Ľa mau  Ľalu ki he fonua ko Siuta, ki he fale  Ľoe  ĽOtua lahi,  Ľaia  Ľoku langa  Ľaki  Ľae ngaahi maka lalahi, pea kuo  Ľai  Ľae ngaahi  Ľakau  Ľi he ngaahi  ĽńĀ maka, pea  Ľoku fai fakavave  Ľae ngńĀue ni, pea  Ľoku monŇę Ľia ia  Ľi honau nima.  
\v 9 ‚ÄúPea na Ľa mau fehu Ľi ai ki he kau mńĀtu Ľa ko ia,  Ľo mau pehńď kiate kinautolu, Ko hai na Ľa ne fekau kiate kimoutolu ke langa  Ľae fale ni, pea ke fakama Ľopo Ľopo  Ľae ngaahi  ĽńĀ maka ni?  
\v 10 Pea na Ľa mau fehu Ľi ki honau hingoa foki, koe Ľuhi ke fakapapau kiate koe, pea ke mau tohi  Ľae hingoa  Ľoe kau tangata  Ľoku tu Ľukimu Ľa  Ľiate kinautolu.  
\v 11 Pea na Ľa nau tali mai,  Ľo pehńď, ‚ÄėKo e kau tamaio Ľeiki  Ľakimautolu  Ľoe  ĽOtua  Ľoe langi mo mńĀmani, pea  Ľoku mau langa  Ľae fale  Ľaia na Ľe langa  Ľi he ta Ľu lahi kuo hili,  Ľaia na Ľe langa  Ľe he tu Ľi lahi  Ľo  ĽIsileli pea fokotu Ľu.  
\v 12 Kae hili  Ľae fakatupu  Ľe he Ľemau ngaahi tamai  Ľae houhau lahi  Ľoe  ĽOtua  Ľoe langi, na Ľa ne tuku  Ľakinautolu ki he nima  Ľo Nepukanesa ko e tu Ľi  Ľo Papilone, ko e tangata Kalitia,  Ľaia na Ľa ne maumau Ľi  Ľae fale ni, pea ne fetuku  Ľae kakai ki he mama Ľo ki Papilone.  
\v 13 Ka  Ľi he  Ľuluaki ta Ľu  Ľo Kolesi ko e tu Ľi  Ľo Papilone ko e tu Ľi ko ia ko Kolesi na Ľa ne fai  Ľae fono ke langa  Ľae fale ni  Ľoe  ĽOtua.  
\v 14 Pea ko e ngaahi ipu koula foki mo e siliva  Ľoe fale  Ľoe  ĽOtua,  Ľaia na Ľe to Ľo  Ľo  Ľave  Ľe Nepukanesa mei he faletapu  Ľaia na Ľe  Ľi SelŇęsalema, pea  Ľomi ki he faletapu  Ľo Papilone, na Ľe to Ľo ia  Ľe Kolesi ko e tu Ľi mei he faletapu  Ľo Papilone, pea na Ľe tuku ia ki he nima  Ľoe tokotaha ko hono hingoa ko Sesipasa,  Ľaia na Ľa ne fakanofo ko e pule.  
\v 15 ‚ÄĆ ĽO ne pehńď kiate ia, To Ľo  Ľae ngaahi nńĀunau ni, pea  Ľalu,  Ľo fetuku ia ki he faletapu  Ľaia  Ľoku  Ľi SelŇęsalema, pea tuku ke langa  Ľae fale  Ľoe  ĽOtua  Ľi hono potu.  
\v 16 Pea na Ľe ha Ľu ai  Ľae Sesipasa ko ia, pea ne  Ľai hono tu Ľunga  Ľoe fale  Ľo Sihova  Ľaia  Ľoku  Ľi SelŇęsalema: pea talu  Ľae kuonga ko ia  Ľo fai mai kuo langa ia, ka  Ľoku te Ľeki ai  Ľosi ia.‚Äô   
\pi1
\v 17 ‚ÄúPea ko eni, kapau  Ľoku matalelei ki he tu Ľi, tuku ke kumi  Ľi he fale koloa  Ľoe tu Ľi,  Ľaia  Ľoku  Ľi Papilone, pe kuo pehńď pe, \add pe  Ľikai\add*, pe na Ľe fai ha fono  Ľo Kolesi ke langa  Ľae fale ni  Ľoe  ĽOtua  Ľi SelŇęsalema, pea ke fekau  Ľe he tu Ľi  Ľaia  Ľoku lelei hono loto ki ai  Ľi he me Ľa ni.‚ÄĚ   
\c 6  
\cd \it 1 Ko e  Ľilo  Ľe Talaiasi  Ľae fono  Ľa Kolesi, pea fai  Ľe ia  Ľae fono fo Ľou ke fakavavevave  Ľae langa fale. 13 Pea  Ľi he tokoni  Ľae ngaahi fili, mo e fakahinohino  Ľoe kau palŇćfita, kuo faka Ľosi  Ľae faletapu. 16 Ko e kńĀtoanga  Ľoe hŇęfia  Ľae fale. 19 Mo e kńĀtoanga  Ľoe Lakaatu.\it*  
\p
\v 1 Pea na Ľe toki fai ai  Ľe Talaiasi ha fono, pea na Ľe kumi  Ľi he fale  Ľoe ngaahi tohi  Ľaia na Ľe hili ai  Ľae ngaahi koloa  Ľo Papilone.  
\v 2 Pea na Ľe  Ľilo  Ľi  ĽAkimita,  Ľi he fale lahi  Ľaia  Ľoku  Ľi he fonua ko Mitia,  Ľae takainga \add tohi\add*, pea na Ľe  Ľi ai  Ľae tohi na Ľe pehńď:   
\pi1
\v 3 ‚Äú ĽI hono tolu ta Ľu  Ľo Kolesi ko e tu Ľi, na Ľe fai  Ľe Kolesi ko e tu Ľi  Ľae fono ki he fale  Ľoe  ĽOtua  Ľi SelŇęsalema, Tuku ke langa  Ľae fale, ko e potu na Ľa nau fai ai  Ľae ngaahi feilaulau, pea ke  Ľai hono ngaahi tu Ľunga  Ľo ia ke mńĀlohi: ko hono mńĀ Ľolunga  Ľo ia ko e hanga  Ľe teau ma uofulu, mo hono mńĀukupu  Ľo ia ko e hanga  Ľe teau ma uofulu;  
\v 4 Mo e  Ľotu  Ľe tolu  Ľoe fu Ľu maka lahi, mo e  Ľotu  Ľe taha  Ľoe  Ľakau fo Ľou; pea ke  Ľatu hono totongi ki ai mei he fale  Ľoe tu Ľi;  
\v 5 Pea ko e ngaahi ipu koula mo e siliva  Ľoe fale  Ľoe  ĽOtua,  Ľaia na Ľe to Ľo  Ľo  Ľave  Ľe Nepukanesa mei he faletapu  Ľaia  Ľoku  Ľi SelŇęsalema,  Ľo fetuku ki Papilone, ke toe  Ľatu, pea toe  Ľave ki he faletapu  Ľaia  Ľoku  Ľi SelŇęsalema, ke taki taha ki hono potu, pea tuku ia ki he fale  Ľoe  ĽOtua.‚ÄĚ   
\pi1
\v 6 Pea ko eni, ‚Äú ĽE Tatinei, ko e pule  Ľi he kauvai  Ľe taha  Ľoe vaitafe, mo Sita-Posinei, mo homou kaume Ľa ko e kau  ĽAfasatikai,  Ľaia  Ľoku  Ľitu Ľa  Ľi he vaitafe, ke mou fakamama Ľo mo e potu ko ia:  
\v 7 ‚ÄúTuku ai pe  Ľae ngńĀue  Ľoe fale ni  Ľoe  ĽOtua; tuku  Ľae pule  Ľoe kakai Siu mo e kau mńĀtu Ľa  Ľoe kakai Siu ke nau langa  Ľae fale ni  Ľoe  ĽOtua  Ľi hono potu.  
\v 8 Pea koe Ľuhi  Ľoku ou fai  Ľae fono ni ki he me Ľa te mou fai ki he kau mńĀtu Ľa  Ľoe ngaahi Siu ni  Ľi he langa  Ľae fale ni  Ľoe  ĽOtua: ke mou fai leva  Ľo  Ľatu  Ľae totongi ki he kau tangata ni, mei he ngaahi me Ľa  Ľae tu Ľi,  Ľio,  Ľae me Ľa tukuhau  Ľi he tu Ľa vaitafe,  Ľo fai ai pe, ke  Ľoua na Ľa fakatuai  Ľakinautolu.  
\v 9 Pea ko ia  Ľoku nau masiva ai, pe ko e fanga pulu mui, mo e fanga sipitangata, mo e fanga lami, ma Ľae ngaahi feilaulau tutu ki he  ĽOtua  Ľoe langi, ko e uite, mo e mńĀsima, mo e uaine, mo e lolo,  Ľo fakatatau ki he tu Ľutu Ľuni  Ľae kau taula Ľeiki  Ľaia  Ľoku  Ľi SelŇęsalema, tuku ke  Ľatu ia kiate kinautolu  Ľi he  Ľaho hokohoko pe, pea  Ľoua na Ľa li Ľaki.  
\v 10 Koe Ľuhi ke nau  Ľatu  Ľae ngaahi feilaulau namu kakala ki he  ĽOtua  Ľoe langi pea hŇęfia  Ľae mo Ľui  Ľae tu Ľi, mo hono ngaahi foha.  
\v 11 Pea kuo u fai  Ľae fono foki, koe Ľuhi ko ia te ne fakakehe  Ľae lea ni, ke to Ľo  Ľae ngaahi  Ľakau mei hono fale, pea ke fokotu Ľu ia, pea tuku ke tautau ia ki ai: pea tuku ke ngaohi hono fale  Ľi he me Ľa ni, ko e fale vao.  
\v 12 Pea ko e  ĽOtua  Ľaia na Ľe pule ke nofo ki ai hono huafa, ke faka Ľauha  Ľe ia  Ľae ngaahi tu Ľi mo e kakai,  Ľaia te nau  Ľai honau nima ke fakakehe, pe ke maumau  Ľae fale ni  Ľoe  ĽOtua  Ľaia  Ľoku  Ľi SelŇęsalema. Ko au Talaiasi kuo u fai  Ľae fono ni: tuku ke fai ia ke fakato Ľoto Ľo.‚ÄĚ   
\p
\v 13 ¬∂ Pea na Ľe fai vave  Ľe Tatinei, ko e pule  Ľi he potu kauvai ni  Ľoe vaitafe, mo Sita-Posinei, mo honau kaume Ľa,  Ľo fakatatau ki he me Ľa  Ľaia na Ľe fekau  Ľe Talaiasi ko e tu Ľi.  
\v 14 Pea na Ľe langa  Ľe he kau mńĀtu Ľa  Ľoe kakai Siu, pea na Ľa nau monŇę Ľia, ko e me Ľa  Ľi he akonaki  Ľa Hakeai ko e palŇćfita mo Sakalia ko e foha  Ľo Ito. Pea na Ľa nau langa ia ke  Ľosi,  Ľo fakatatau ki he fekau  Ľae  ĽOtua  Ľo  ĽIsileli, pea fakatatau ki he fekau  Ľa Kolesi, mo Talaiasi, mo  ĽAtakisekisi ko e tu Ľi  Ľo Peasia.  
\v 15 Pea na Ľe faka Ľosi  Ľae fale ni  Ľi hono tolu  Ľoe  Ľaho  Ľoe mńĀhina ko  ĽAtali  Ľi hono ono  Ľoe ta Ľu  Ľoe pule  Ľa Talaiasi ko e tu Ľi.   
\p
\v 16 ¬∂ Pea ko e fńĀnau  Ľa  ĽIsileli, ko e kau taula Ľeiki, mo e kau Livai, pea mo kinautolu na Ľe toe  Ľi he fńĀnau  Ľae fakapŇćpula, na Ľa nau fai hono fakatapui  Ľoe fale  Ľoe  ĽOtua  Ľi he fiefia lahi,  
\v 17 Pea na Ľe  Ľatu  Ľi he fakatapui  Ľoe fale ni  Ľoe  ĽOtua  Ľae fanga pulu  Ľe teau, mo e sipitangata  Ľe uangeau, mo e fanga lami  Ľe fńĀngeau; pea ko e feilaulau  Ľi he angahala ma Ľa  ĽIsileli kotoa pńď, ko e kosi tangata  Ľe hongofulu ma ua,  Ľo fakatatau ki hono lau  Ľoe fa Ľahinga  Ľo  ĽIsileli.  
\v 18 Pea na Ľa nau fokotu Ľu  Ľae kau taula Ľeiki  Ľi honau lakanga, mo e kau Livai  Ľi honau hoko Ľanga,  Ľi he ngńĀue  Ľae  ĽOtua,  Ľaia  Ľoku  Ľi SelŇęsalema;  Ľo hangńď ko ia kuo tohi  Ľi he tohi  Ľa MŇćsese.  
\v 19 Pea na Ľe fai  Ľae kńĀtoanga  Ľoe Lakaatu  Ľe he fńĀnau  Ľae fakapŇćpula  Ľi hono  Ľaho hongofulu ma fńĀ  Ľoe mńĀhina.  
\v 20 He na Ľe fakama Ľa fakataha  Ľakinautolu  Ľe he kau taula Ľeiki mo e kau Livai, na Ľe ma Ľa  Ľakinautolu kotoa pńď, mo nau tńĀmate Ľi  Ľae Lakaatu ma Ľae fńĀnau kotoa pńď  Ľoe fakapŇćpula, pea ma Ľa honau kńĀinga ko e kau taula Ľeiki, pea ma Ľanautolu.  
\v 21 Pea ko e fńĀnau  Ľa  ĽIsileli,  Ľaia na Ľe toe ha Ľu mei he fakapŇćpula, pea mo kinautolu kotoa pńď na Ľe vahe  Ľakinautolu ke kau kiate kinautolu mei he ngaahi  Ľuli kovi  Ľoe hiteni  Ľoe fonua, ke kumi kia Sihova ko e  ĽOtua  Ľo  ĽIsileli, na Ľa nau kai ai,  
\v 22 ‚ÄĆ ĽO nau fai  Ľae kńĀtoanga  Ľoe mńĀ ta Ľefakalńďvani  Ľi he  Ľaho  Ľe fitu  Ľi he fiefia lahi: he na Ľe fakafiefia Ľi  Ľakinautolu  Ľe Sihova,  Ľo ne fakatafoki  Ľae loto  Ľoe tu Ľi  Ľo  ĽAsilia kiate kinautolu, ke fakamńĀlohi honau nima  Ľi he ngńĀue  Ľoe fale  Ľoe  ĽOtua, ko e  ĽOtua  Ľo  ĽIsileli.   
\c 7  
\cd \it 1  ĽOku  Ľalu hake ki SelŇęsalema  Ľa Esela. 11 Ko e fekau anga Ľofa  Ľa  ĽAtakisekisi kia Esela. 27  ĽOku fakafeta Ľi  Ľe Esela ki he  ĽOtua  Ľi he Ľene  Ľofa.\it*  
\p
\v 1 Pea hili  Ľae ngaahi me Ľa ni,  Ľi he pule  Ľa  ĽAtakisekisi ko e tu Ľi  Ľo Peasia, ko Esela ko e foha  Ľo Selaia, ko e foha  Ľo  ĽAsalia, ko e foha  Ľo Hilikia,   
\li1
\v 2 Ko e foha  Ľo Salumi, ko e foha  Ľo Satoki, ko e foha  Ľo  ĽAhitupe,   
\li1
\v 3 Ko e foha  Ľo  ĽAmalia, ko e foha  Ľo  ĽAsalia, ko e foha  Ľo Milaioti,   
\li1
\v 4 Ko e foha  Ľo Selaia, ko e foha  Ľo Usa, ko e foha  Ľo Puki,   
\li1
\v 5 Ko e foha  Ľo  ĽApisua, ko e foha  Ľo Finiasi, ko e foha  Ľo  ĽEliesa, ko e foha  Ľo  ĽElone ko e taula Ľeiki lahi:   
\li1
\v 6 Ko e Esela ni na Ľe  Ľalu hake ia mei Papilone; pea ko e tangata tohi ia na Ľe poto  Ľi he fono  Ľo MŇćsese,  Ľaia na Ľe foaki kiate ia  Ľe Sihova ko e  ĽOtua  Ľo  ĽIsileli: pea na Ľe tuku kiate ia  Ľe he tu Ľi  Ľaia kotoa pńď na Ľa ne kole,  Ľo fakatatau ki he kau  Ľae nima  Ľo Sihova ko hono  ĽOtua kiate ia.   
\li1
\v 7 Pea na Ľe  Ľalu hake  Ľae ni Ľihi  Ľoe fńĀnau  Ľa  ĽIsileli, pea  Ľoe kau taula Ľeiki mo e kau Livai, mo e kau hiva, mo e kau le Ľo matapńĀ, mo e kau Netenimi, ki SelŇęsalema,  Ľi hono fitu ta Ľu  Ľo  ĽAtakisekisi ko e tu Ľi.   
\li1
\v 8 Pea na Ľe ha Ľu ia ki SelŇęsalema  Ľi hono nima  Ľoe mńĀhina,  Ľi hono fitu ta Ľu  Ľoe tu Ľi.   
\li1
\v 9 He na Ľe kamata  Ľene fononga hake, mei Papilone  Ľi he  Ľuluaki  Ľaho  Ľi hono  Ľuluaki  Ľoe mńĀhina, pea  Ľi hono  Ľuluaki  Ľaho  Ľi hono nima  Ľoe mńĀhina na Ľe hoko ia ki SelŇęsalema,  Ľo fakatatau, ki he kau lelei  Ľae nima  Ľo hono  ĽOtua kiate ia.  
\v 10 He na Ľe  Ľosi hono teu Ľi hono loto  Ľe Esela ke kumi  Ľi he fono  Ľa Sihova, pea ke fai ia, pea ke akonaki  Ľi  ĽIsileli  Ľae ngaahi tu Ľutu Ľuni, mo e ngaahi fakamaau.   
\p
\v 11 ¬∂ Pea ko hono hiki eni  Ľoe tohi na Ľe  Ľatu  Ľe he tu Ľi ko  ĽAtakisekisi kia Esela ko e taula Ľeiki, ko e tangata tohi ia,  Ľio, ko e tangata tohi  Ľae ngaahi lea  Ľoe ngaahi fekau  Ľa Sihova, pea mo  Ľene ngaahi tu Ľutu Ľuni ki  ĽIsileli.   
\mi
\v 12 ‚ÄúKo  ĽAtakisekisi, ko e tu Ľi  Ľoe ngaahi tu Ľi,  
\mi kia Esela ko e taula Ľeiki, ko e tangata tohi  Ľoe fono  Ľae  ĽOtua  Ľoe langi, ke  Ľiate koe  Ľae fiemńĀlie lelei,  
\pi1  Ľi he kuonga ko eni.  
\v 13 ‚Äú ĽOku ou fai  Ľae fono, koe Ľuhi ko kinautolu  Ľoe kakai  Ľo  ĽIsileli, pea mo  Ľene kautaula Ľeiki, mo e kau Livai,  Ľi hoku pule Ľanga,  Ľaia  Ľoku tokanga  Ľi honau loto lelei ke  Ľalu hake ki SelŇęsalema, ke nau  Ľalu mo koe.  
\v 14 Pea ko e me Ľa  Ľi he  Ľalu koe mei he tu Ľi pea mo  Ľene kau fakakaukau  Ľe toko fitu, ke fehu Ľi ki Siuta mo SelŇęsalema,  Ľo fakatatau ki he fono  Ľa ho  ĽOtua  Ľaia  Ľoku  Ľi ho nima;  
\v 15 Pea ke fetuku  Ľae siliva mo e koula,  Ľaia kuo  Ľatu fiemńĀlie pe  Ľe he tu Ľi mo  Ľene kau fakakaukau ki he  ĽOtua  Ľo  ĽIsileli,  Ľaia  Ľoku  Ľi SelŇęsalema hono fale nofo Ľanga.  
\v 16 Pea mo e siliva mo e koula kotoa pńď  Ľaia ke ke fa Ľa  Ľilo  Ľi he potu kotoa pńď  Ľo Papilone, mo e me Ľa  Ľatu loto lelei pe  Ľae kakai, pea mo e kau taula Ľeiki,  Ľoku  Ľatu loto lelei pe ma Ľae fale  Ľo honau  ĽOtua  Ľaia  Ľoku  Ľi SelŇęsalema:  
\v 17 ‚ÄúKoe Ľuhi ke ke fakatau vave  Ľaki  Ľae ngaahi pa Ľanga ni  Ľae fanga pulu, mo e fanga sipitangata, mo e fanga lami, mo honau ngaahi feilaulau me Ľakai, mo e ngaahi feilaulau me Ľainu, pea ke  Ľatu ia ki he funga  Ľoe feilaulau Ľanga  Ľoe fale  Ľo homou  ĽOtua  Ľaia  Ľoku  Ľi SelŇęsalema.  
\v 18 Pea ko ia  Ľe mata lelei kiate koe, mo ho ngaahi kńĀinga ke fai ki hono toe  Ľoe siliva mo e koula, mou fai ia  Ľo fakatatau ki he finangalo  Ľo homou  ĽOtua.  
\v 19 Ko e ngaahi ipu foki na Ľe tuku kiate koe ki he ngńĀue  Ľoe fale  Ľo ho  ĽOtua, ke ke  Ľatu ia  Ľi he  Ľao  Ľoe  ĽOtua  Ľo SelŇęsalema.  
\v 20 Pea mo ia kotoa pńď  Ľoku  Ľaonga ki he fale  Ľo ho  ĽOtua,  Ľaia te ke loto ki ai ke foaki, foaki ia mei he fale koloa  Ľoe tu Ľi.  
\v 21 ‚ÄúPea ko au,  Ľio, ko au  ĽAtakisekisi ko e tu Ľi,  Ľoku ou fai  Ľae fono ki he kau tauhi koloa kotoa pńď  Ľaia  Ľoku  Ľi he potu kitu Ľa  Ľi he vaitafe, ke  Ľilonga  Ľaia  Ľoku fiema Ľu  Ľe Esela ko e taula Ľeiki, ko e tangata tohi  Ľoe fono  Ľae  ĽOtua  Ľoe langi, ke fai vave ia kiate ia,  
\v 22 ‚ÄĆ ĽO fai hake ki he taleniti siliva  Ľe teau, mo e puha fua  Ľoe uite  Ľe teau, pea ki he kaloni  Ľe fitungeau ma nimangofulu  Ľoe uaine, pea ki he kaloni  Ľe fitungeau ma nimangofulu  Ľoe lolo, mo e mńĀsima  Ľe  Ľikai lau ki hono lahi.  
\v 23 Ko ia kotoa pńď  Ľoku fekau  Ľe he  ĽOtua  Ľoe langi, tuku ke fai vave ia ma Ľae fale  Ľoe  ĽOtua  Ľoe langi he ko e hńĀ ka tu Ľu ai  Ľae houhau ki he pule Ľanga  Ľoe tu Ľi pe ki hono ngaahi foha?   
\pi1
\v 24 Pea  Ľoku mau fakapapau foki kiate kimoutolu, ko e me Ľa ki he kau taula Ľeiki mo e kau Livai, mo e kau hiva, mo e kau le Ľo matapńĀ, mo e kau Netenimi, pe ko e kau tauhi  Ľoe fale ni  Ľoe  ĽOtua,  Ľoku  Ľikai ngofua ke tala totongi, pe ha tukuhau, pe ha fakafatongia, kiate kinautolu.   
\pi1
\v 25 ‚ÄúPea ko koe,  Ľe Esela,  Ľo hangńď ko e poto  Ľa ho  ĽOtua,  Ľoku  Ľi ho nima, ke ke fakanofo  Ľae kau pule, mo e kau fakamaau,  Ľaia ke nau fakamaau  Ľae kakai kotoa pńď  Ľoku  Ľi he tu Ľa vaitafe,  Ľakinautolu  Ľoku  Ľilo lelei  Ľae fono  Ľa ho  ĽOtua; pea mou ako ia, kiate kinautolu  Ľoku  Ľikai te nau  Ľilo ki ai.  
\v 26 Pea  Ľilonga  Ľaia  Ľoku  Ľikai fai ki he fono  Ľo ho  ĽOtua, mo e fono  Ľae tu Ľi, ke fakahoko vave  Ľae fakamaau kiate ia, pe ko ha me Ľa ki he mate, pe ki he kapusi ia, pe ki he fa Ľao  Ľo  Ľene ngaahi me Ľa, pe ki he fakahŇę ki he fale fakapŇćpula.‚ÄĚ   
\p
\v 27 ¬∂ ‚ÄúFakafeta Ľi kia Sihova ko e  ĽOtua  Ľo  Ľetau ngaahi tamai,  Ľaia kuo ne  Ľai  Ľae me Ľa pehńď ni ki he loto  Ľoe tu Ľi, ke fakamatamatalelei ki he fale  Ľo Sihova  Ľaia  Ľoku  Ľi SelŇęsalema:  
\v 28 Pea kuo ne tuku  Ľae anga Ľofa kiate au  Ľi he  Ľao  Ľoe tu Ľi, mo  Ľene kau fakakaukau, pea  Ľi he  Ľao  Ľoe hou Ľeiki ongoongo lahi  Ľae tu Ľi. Pea na Ľe fakamńĀlohi Ľi au  Ľi he  Ľiate au  Ľae nima  Ľo Sihova ko hoku  ĽOtua, pea ne u tńĀnaki fakataha mei  ĽIsileli  Ľae kau tangata tu Ľu ki mu Ľa ke mau  Ľalu hake mo au.‚ÄĚ   
\c 8  
\cd \it 1 Ko e kau fononga  Ľa Esela, na Ľe toe ha Ľu mei Papilone. 15 Na Ľa ne fekau kia Ito ki he kau taula Ľeiki ki he faletapu, 21  ĽOku fekau ke  Ľaukai. 24 Na Ľa ne tuku  Ľae ngaahi koloa ke tauhi  Ľe he kau taula Ľeiki. 31 Na Ľa nau ha Ľu mei  ĽAheva ki SelŇęsalema. 33 Ko e fakatatau  Ľae koloa  Ľi he faletapu. 36 Ko e  Ľatu  Ľae fekau.\it*  
\p
\v 1 Pea ko e kau tu Ľukimu Ľa  Ľi he ngaahi tamai eni, pea ko e tohi hokohoko eni  Ľokinautolu na Ľa mau  Ľalu hake mo au mei Papilone,  Ľi he pule  Ľa  ĽAtakisekisi ko e tu Ľi.   
\li1
\v 2 ‚ÄĆ ĽI he ngaahi foha  Ľo Finiasi; ko Kesomi:  
\li1  Ľi he ngaahi foha  Ľo  ĽItama, ko Taniela:  
\li1  Ľi he ngaahi foha  Ľo Tevita; ko Hatusi.   
\li1
\v 3 ‚ÄĆ ĽI he ngaahi foha  Ľo Sikania,  
\li1  Ľi he ngaahi foha  Ľo Falosi, ko Sakalia:  
\li1 pea na Ľe lau mo ia  Ľi he hokohoko  Ľoe kau tangata ko e toko teau ma nimangofulu.   
\li1
\v 4 ‚ÄĆ ĽI he ngaahi foha  Ľo Pehati-Moape;  
\li1 ko Ilionei ko e foha  Ľo Selaia,  
\li1 pea na Ľe  Ľiate ia  Ľae kau tangata  Ľe toko uangeau.   
\li1
\v 5 ‚ÄĆ ĽI he ngaahi foha  Ľo Sikania;  
\li1 ko e foha  Ľo Saesieli,  
\li1 pea na Ľe  Ľiate ia  Ľae kau tangata  Ľe toko tolungeau.   
\li1
\v 6 ‚ÄĆ ĽI he ngaahi foha  Ľo  ĽAtini foki;  
\li1 ko Epeti ko e foha  Ľo Sioatani,  
\li1 pea na Ľe  Ľiate ia  Ľae kau tangata  Ľe toko nimangofulu.   
\li1
\v 7 Pea  Ľi he ngaahi foha  Ľo  ĽIlami ko Sisaia ko e tama  Ľo  ĽAtalia,  
\li1 pea na Ľe  Ľiate ia  Ľae kau tangata  Ľe toko fitungofulu.   
\li1
\v 8 Pea  Ľi he ngaahi foha  Ľo Sifatia;  
\li1 ko Sepatia ko e foha  Ľo Mikaeli,  
\li1 pea na Ľe  Ľiate ia  Ľae kau tangata  Ľe toko valungofulu.   
\li1
\v 9 ‚ÄĆ ĽI he ngaahi foha  Ľo Soape:  
\li1 ko  ĽOpataia ko e foha  Ľo Sehieli,  
\li1 pea na Ľe  Ľiate ia  Ľae kau tangata  Ľe toko uangeau ma hongofulu ma valu.   
\li1
\v 10 Pea  Ľi he ngaahi foha  Ľo Silomiti ko e foha  Ľo Sosifia,  
\li1 pea na Ľe  Ľiate ia  Ľae kau tangata  Ľe toko teau ma onongofulu.   
\li1
\v 11 Pea  Ľi he ngaahi foha  Ľo Pepai, ko Sakalia ko e foha  Ľo Pepai,  
\li1 pea na Ľe  Ľiate ia  Ľae kau tangata  Ľe toko uofulu ma toko valu.   
\li1
\v 12 Pea  Ľi he ngaahi foha  Ľo  ĽAsikati;  
\li1 ko Sohanani ko e foha  Ľo Hakatani,  
\li1 pea na Ľe  Ľiate ia  Ľae kau tangata  Ľe toko teau ma hongofulu.   
\li1
\v 13 Pea  Ľi he ngaahi foha ki mui  Ľo  ĽAtonikami,  
\li1  Ľaia ko honau hingoa eni, ko Ilifileti, ko Sieli, mo Simaia,  
\li1 pea na Ľe  Ľiate kinautolu  Ľae kau tangata  Ľe toko tolungofulu.   
\li1
\v 14 ‚ÄĆ ĽI he ngaahi foha foki  Ľo Pikivai: ko Utei, mo Saputi,  
\li1 pea na Ľe  Ľiate kinaua  Ľae kau tangata  Ľe toko fitungofulu.   
\li1
\v 15 Pea na Ľaku fakakńĀtoa fakataha  Ľakinautolu  Ľi he vaitafe  Ľaia  Ľoku tafe ki  ĽAheva;  
\li1 pea na Ľa mau nofo ai  Ľi he ngaahi fale fehikitaki  Ľi he  Ľaho  Ľe tolu:  
\li1 pea ne u vakai  Ľae kakai, mo e kau taula Ľeiki,  
\li1 pea ne u  Ľilo na Ľe  Ľikai ha ni Ľihi  Ľi he ngaahi foha  Ľo Livai.   
\li1
\v 16 Pea ne u fekau ke ha Ľu  Ľa  ĽEliesa, mo Elieli, mo Simaia,  
\li1 pea mo Elinatani, pea mo Salipe, pea mo Elinatani,  
\li1 pea mo Natani, pea mo Sakalia, pea mo Mesulami, ko e kau tangata tu Ľukimu Ľa;  
\li1 pea mo Soialipe, pea mo Elinatani, ko e kau tangata loto poto.   
\li1
\v 17 Pea ne u fekau  Ľakinautolu ke  Ľave  Ľeku fekau kia Ito ko e  Ľeiki  Ľi he potu ko Kasifia,  
\li1 pea ne u tala kiate kinautolu  Ľaia te nau lea  Ľaki kia Ito, pea ki hono ngaahi kńĀinga ko e kakai Netenimi,  
\li1  Ľi he potu ko Kasifia, koe Ľuhi ke nau  Ľomi kiate kimautolu  Ľae kau taula Ľeiki ki he fale  Ľo hotau  ĽOtua.   
\li1
\v 18 Pea  Ľi he kau lelei  Ľae nima  Ľo hotau  ĽOtua  Ľiate kitautolu na Ľa nau  Ľomi ha tangata loto poto ma Ľamautolu,  
\li1  Ľi he ngaahi foha  Ľo Mali, ko e foha  Ľo Livai, ko e foha  Ľo  ĽIsileli;  
\li1 mo Selipea, mo hono ngaahi foha mo hono ngaahi kńĀinga, ko e toko hongofulu ma valu:   
\li1
\v 19 Pea ko Hasapea, pea fakataha mo ia  Ľa Sisaia  
\li1  Ľi he ngaahi foha  Ľo Melali, ko hono ngaahi kńĀinga mo honau ngaahi foha, ko e toko uofulu;   
\li1
\v 20 Pea  Ľoe kau Netenimi foki,  Ľaia na Ľe fakanofo  Ľe Tevita mo e hou Ľeiki ki he ngńĀue  Ľoe kau Livai, ko e Netenimi  Ľe toko uangeau ma uofulu: na Ľe lau  Ľakinautolu kotoa pńď  Ľi honau hingoa.   
\p
\v 21 ¬∂ Pea ne u fanongonongo  Ľae  Ľaukai  Ľi ai,  Ľi he ve Ľe vaitafe ko  ĽAheva, koe Ľuhi ke mau tautea  Ľakimautolu  Ľi he  Ľao  Ľo homau  ĽOtua, ke kumi  Ľiate ia  Ľae hala totonu kiate kimautolu, pea mo Ľo  Ľemau fńĀnau iiki, pea ki he Ľemau me Ľa kotoa pńď.  
\v 22 He na Ľaku mńĀ  Ľo  Ľikai fa Ľa kole ki he tu Ľi ha kautau mo e kau tangata heka hoosi ke tokoni  Ľakimautolu telia  Ľae ngaahi fili  Ľi he hala: koe Ľuhi na Ľa mau lea ki he tu Ľi,  Ľo pehńď, Ko e nima  Ľo homau  ĽOtua  Ľoku  Ľiate kinautolu kotoa pńď  Ľoku kumi kiate ia ke nau lelei ai; ka ko  Ľene mńĀlohi mo  Ľene houhau  Ľe tu Ľu kiate kinautolu kotoa pńď  Ľoku li Ľaki ia.  
\v 23 Ko ia na Ľa mau  Ľaukai ai pea kole ki homau  ĽOtua koe Ľuhi ko e me Ľa ni pea na Ľa ne talia lelei  Ľakimautolu.   
\p
\v 24 ¬∂ Pea ne u fili  Ľae toko hongofulu ma toko ua  Ľoe kau tu Ľukimu Ľa  Ľoe kau taula Ľeiki, ko Selipea, mo Hasapea, mo hona kńĀinga  Ľe toko hongofulu,  
\v 25 Pea na Ľaku fakatatau  Ľae siliva kiate kinautolu, mo e koula, mo e ngaahi ipu,  Ľio,  Ľae me Ľa foaki  Ľoe fale  Ľo hotau  ĽOtua,  Ľaia na Ľe  Ľatu  Ľe he tu Ľi, mo  Ľene kau fakakaukau, pea mo  ĽIsileli kotoa pńď na Ľe  Ľi ai:  
\v 26 ‚ÄĆ ĽIo, na Ľaku fakatatau ki honau nima  Ľae taleniti siliva  Ľe onongeau mo e nimangofulu, mo e ngaahi ipu siliva ko e taleniti  Ľe teau, pea  Ľi he koula ko e taleniti  Ľe teau;  
\v 27 Mo e ipu luoluo koula foki  Ľe uofulu,  Ľoe talami  Ľe taha afe: mo e ipu  Ľe ua  Ľoe kapa lelei,  Ľo tatau mo e koula hono ma Ľongo Ľonga.  
\v 28 Pea ne u pehńď kiate kinautolu, ‚Äú ĽOku mńĀ Ľoni Ľoni  Ľakimoutolu kia Sihova;  Ľoku mńĀ Ľoni Ľoni mo e ngaahi ipu foki; pea ko e siliva mo e koula ko e me Ľa  Ľatu loto lelei pe ia kia Sihova ko e  ĽOtua  Ľo  Ľetau ngaahi tamai.  
\v 29 Ko ia mou le Ľohi, mo tauhi ia, kae Ľoua ke toe fakatatau ia  Ľi he  Ľao  Ľoe kau taula Ľeiki lahi mo e kau Livai, mo e kau tu Ľukimu Ľa  Ľoe ngaahi mńĀtu Ľa  Ľo  ĽIsileli  Ľi SelŇęsalema,  Ľi he ngaahi potu fale  Ľoe fale  Ľo Sihova.‚ÄĚ  
\v 30 Pea na Ľe pehńď pe  Ľae ma Ľu  Ľe he kau taula Ľeiki mo e kau Livai hono mamafa  Ľoe siliva, mo e koula, mo e ngaahi ipu ke  Ľomi ia ki SelŇęsalema ki he fale  Ľo hotau  ĽOtua.   
\p
\v 31 ¬∂ Pea na Ľa mau toki hiki mei he vaitafe  Ľo  ĽAheva  Ľi hono hongofulu ma ua  Ľoe  Ľaho  Ľoe  Ľuluaki mńĀhina, ke  Ľalu ki SelŇęsalema: pea na Ľe  Ľiate kimautolu  Ľae nima  Ľo homau  ĽOtua, pea na Ľa ne taukapo Ľi  Ľakimautolu mei he nima  Ľoe fili, pea mo kinautolu na Ľe toitoi Ľi  Ľakimautolu  Ľi he hala.  
\v 32 Pea na Ľa mau hoko ki SelŇęsalema, pea nofo ki ai  Ľi he  Ľaho  Ľe tolu.   
\p
\v 33 ¬∂ Pea ko eni  Ľi hono fńĀ  Ľoe  Ľaho na Ľe fakatatau ai  Ľae siliva, mo e koula, mo e ngaahi ipu,  Ľi he fale  Ľo hotau  ĽOtua  Ľi he nima  Ľo Milemoti ko e foha  Ľo  ĽUlia ko e taula Ľeiki: pea na Ľe  Ľiate ia  Ľa  ĽEliesa ko e foha  Ľo Finiasi; pea na Ľe  Ľiate kinaua  Ľa Sosapati ko e foha  Ľo Sesua, mo Noatia ko e foha  Ľo Pinui, ko e kau Livai;  
\v 34 Na Ľe lau  Ľae mamafa  Ľoe me Ľa taki taha kotoa pńď: pea na Ľe tohi hono mamafa kotoa pńď  Ľi he  Ľaho ko ia.  
\v 35 Pea ko e ngaahi fńĀnau foki  Ľakinautolu na Ľe fetuku ke pŇćpula,  Ľaia kuo ha Ľu mei he Ľenau nofo pŇćpula, na Ľa nau  Ľatu  Ľae ngaahi feilaulau tutu ki he  ĽOtua  Ľo  ĽIsileli, ko e fanga pulu  Ľe hongofulu ma ua ma Ľa  ĽIsileli kotoa pńď, mo e sipitangata  Ľe hivangofulu ma ono, ko e fanga lami  Ľe fitungofulu ma fitu, ko e fanga kosi tangata  Ľe hongofulu ma ua ko e feilaulau koe Ľuhi ko e angahala: ko e me Ľa ni kotoa pńď ko e feilaulau tutu kia Sihova.   
\p
\v 36 ¬∂ Pea na Ľa nau  Ľatu  Ľae ngaahi fekau  Ľae tu Ľi ki he kau talafekau  Ľae tu Ľi mo e kau pule fonua  Ľi he kauvai ni  Ľoe vaitafe: pea na Ľa nau tokoni ki he kakai, mo e fale  Ľoe  ĽOtua.   
\c 9  
\cd \it 1 Ko e tangi  Ľe Esela  Ľi he fakakńĀinga  Ľae kakai mo e ngaahi muli. 5 Na Ľe lotu ia ki he  ĽOtua mo vete  Ľae ngaahi angahala.\it*  
\p
\v 1 Pea  Ľi he fai  Ľo  Ľosi  Ľae ngaahi me Ľa ni, na Ľe ha Ľu ai  Ľae ngaahi hou Ľeiki kiate au,  Ľo pehńď,  ĽOku te Ľeki vahevahe  Ľakinautolu  Ľe he kakai  Ľo  ĽIsileli, mo e kau taula Ľeiki, mo e kau Livai, mei he kakai  Ľoe ngaahi fonua,  Ľi he fai  Ľo fakatatau ki he Ľenau ngaahi angakovi,  Ľio,  Ľoe kakai Kńďnani, mo e kakai Heti, mo e kakai Pelesi, mo e kakai Sepusi, mo e kakai  ĽAmoni, mo e kakai  ĽAmoli.  
\v 2 He kuo nau  Ľomi honau ngaahi  Ľofefine mo Ľonautolu, pea mo honau ngaahi foha: ko ia kuo fakafehako Ľaki  Ľakinautolu  Ľe he hako mńĀ Ľoni Ľoni mo e kakai  Ľoe ngaahi fonua ko ia:  Ľio, kuo kau lahi  Ľae nima  Ľoe hou Ľeiki mo e ngaahi pule  Ľi he me Ľa hala ni.  
\v 3 Pea  Ľi he Ľeku fanongo ki he me Ľa ni, na Ľaku hae hoku kofu mo hoku pulupulu, peau fusi hoku ngaahi fulufulu Ľi  Ľulu mei hoku  Ľulu, pea mo  Ľeku kava, peau nofo ki lalo  Ľo tńĀfu Ľua.  
\v 4 Pea na Ľe kńĀtoa kiate au  Ľakinautolu taki taha kotoa pńď na Ľe tetetete ki he ngaahi folofola  Ľae  ĽOtua  Ľo  ĽIsileli, ko e me Ľa  Ľi he talangata Ľa  Ľokinautolu na Ľe fetuku fakapŇćpula: peau nofo tńĀfu Ľua pe  Ľo a Ľu ki he feilaulau fakaefiafi.   
\p
\v 5 ¬∂ Pea  Ľi he feilaulau fakaefiafi ne u tu Ľu hake mei he Ľeku mńĀfasia; peau hae hoku kofu mo hoku pulupulu, peau tŇę Ľulutui  Ľi hoku tui, peau mafao atu hoku nima kia Sihova ko hoku  ĽOtua,  
\v 6 Pea na Ľaku pehńď, ‚Äú ĽE hoku  ĽOtua,  Ľoku ou mńĀ pea kula hoku mata ke hiki hake hoku mata kiate koe,  Ľe hoku  ĽOtua: he kuo tupu  Ľo lahi hake  Ľemau ngaahi hia  Ľi  Ľolunga ki homau  Ľulu, pea ko  Ľemau fai hala kuo tupu hake ki he ngaahi langi.  
\v 7 Talu mei he ngaahi  Ľaho  Ľo  Ľemau ngaahi tamai kuo mau mo Ľua  Ľi he hala lahi  Ľo a Ľu ki he  Ľaho ni; pea ko e me Ľa  Ľi he Ľemau ngaahi hia, na Ľe tukuange ai  Ľakimautolu, mo homau ngaahi tu Ľi, mo homau ngaahi taula Ľeiki, ki he nima  Ľoe ngaahi tu Ľi  Ľoe ngaahi fonua, ki he heletńĀ, pea ki he pŇćpula, pea ki he maumau, pea ki he puputu Ľu  Ľoe mata,  Ľo hangńď  Ľi he  Ľaho ni.  
\v 8 Pea ko eni kuo fakahńĀ  Ľae  Ľofa kiate kimautolu  Ľi he kuonga si Ľi meia Sihova ko homau  ĽOtua, ke tuku kiate kimautolu ha toenga \add kakai\add*, ke hoa, pea ke tuku kiate kimautolu  Ľae fa Ľo  Ľi hono potu mńĀ Ľoni Ľoni, koe Ľuhi ke fakamaama homau mata  Ľe homau  ĽOtua, pea foaki kiate kimautolu  Ľae fakaakeake si Ľi  Ľi homau nofo pŇćpula.  
\v 9 He ko e kau tangata hopoate  Ľakimautolu; ka na Ľe  Ľikai li Ľaki  Ľakimautolu  Ľe homau  ĽOtua  Ľi he Ľemau nofo pŇćpula, ka kuo fakahoko  Ľae  Ľofa kiate kimautolu  Ľi he  Ľao  Ľoe ngaahi tu Ľi  Ľo Peasia, ke tuku kiate kimautolu  Ľae fakaakeake, ke fokotu Ľu  Ľae fale  Ľo homau  ĽOtua, pea ke fakafo Ľou hono ngaahi potu maumau pea ke foaki kiate kimautolu  Ľae  ĽńĀ maka  Ľi Siuta pea  Ľi SelŇęsalema.  
\v 10 Pea ko eni,  ĽE homau  ĽOtua, ko e hńĀ te mau lea \add  Ľaki \add*hili  Ľae me Ľa ni kotoa pńď? He kuo mau li Ľaki ho Ľo ngaahi fekau,  
\v 11 ‚ÄĆ ĽAia na Ľa ke fekau  Ľi ho Ľo kau tamaio Ľeiki ko e kau palŇćfita,  Ľo pehńď, Ko e fonua  Ľoku mou  Ľalu ke ma Ľu, ko e fonua ta Ľema Ľa ia  Ľi he ngaahi anga Ľuli  Ľoe kakai  Ľoe ngaahi fonua, mo  Ľenau ngaahi angakovi,  Ľaia kuo nau fakafonu  Ľaki ia mei hono potu  Ľe taha ki hono potu  Ľe taha  Ľi he Ľenau anga ta Ľema Ľa;  
\v 12 Pea ko eni,  Ľoua na Ľa mou foaki homou ngaahi  Ľofefine ki honau ngaahi foha, pea  Ľoua na Ľa mou to Ľo honau ngaahi  Ľofefine mo homou ngaahi foha, pea  Ľoua na Ľa mou kumi ki he Ľenau melino pe ki he Ľenau koloa  Ľo ta Ľengata: koe Ľuhi ke mou mńĀlohi, pea kai  Ľae lelei  Ľoe fonua, pea tuku ia ko e  Ľapi tofi Ľa ki ho Ľomou fńĀnau ke ta Ľengata.  
\v 13 Pea hili  Ľae me Ľa kotoa pńď kuo tŇć kiate kimautolu  Ľi he Ľemau ngaahi ngńĀue kovi, pea  Ľi he Ľemau hala lahi, he ko koe ko homau  ĽOtua kuo si Ľi hifo hao tautea  Ľakimautolu kae lahi  Ľemau ngaahi hia, pea kuo ke tuku kiate kimautolu  Ľae ngaahi fakamo Ľui pehńď ni;  
\v 14 He te mau toe li Ľaki ho Ľo ngaahi fekau, pea hoko  Ľo fakataha  Ľakimautolu mo e kakai  Ľoe ngaahi angakovi ni? Pea  Ľikai te ke houhau ai kiate kimautolu ke  Ľoua ke faka Ľauha  Ľakimautolu, pea  Ľe  Ľikai ha ni Ľihi  Ľe toe, pe ha me Ľa ke hao ai?  
\v 15 ‚ÄĆ ĽE Sihova ko e  ĽOtua  Ľo  ĽIsileli,  Ľoku ke mńĀ Ľoni Ľoni koe: he  Ľoku mau kei nofo hao pe,  Ľo hangńď ko e  Ľaho ni: vakai,  Ľoku mau  Ľi ho  Ľao  Ľi he Ľemau ngaahi angahala: he  Ľoku  Ľikai te mau fa Ľa tu Ľu  Ľi ho  Ľao koe Ľuhi ko e me Ľa ni.‚ÄĚ   
\c 10  
\cd \it 1  ĽOku tokoni  Ľa Esela  Ľe Sikania, ke fakatonutonu  Ľae ngaahi fakama Ľu mali hala. 6  ĽOku tangi  Ľa Esela pea fakataha  Ľae kakai, 9  ĽOku tokanga  Ľae kakai ki he akonaki  Ľa Esela  Ľonau fakatomala, pea nau fakahńĀ te nau fai fo Ľou. 15 Ko  Ľenau tokanga ke fai ia. 18 Ko e hingoa  Ľokinautolu na Ľe fakama Ľu mo e ngaahi uaifi kehe.\it*  
\p
\v 1 Pea  Ľi he hili  Ľae lotu  Ľa Esela, pea hili  Ľene vete,  Ľo tangi mo fakatŇćmape Ľe ia  Ľi he mata fale  Ľoe  ĽOtua, na Ľe ha Ľu kiate ia mei  ĽIsileli  Ľae fu Ľu kakai tokolahi  Ľoe kau tangata mo e kau fefine mo e fńĀnau: he na Ľe tangi mamahi  Ľaupito  Ľae kakai.  
\v 2 Pea ko Sikania ko e foha  Ľo Sehieli, ko e tokotaha  Ľi he ngaahi foha  Ľo  ĽIlami, na Ľe lea ia  Ľo ne pehńď kia Esela, ‚ÄúKuo mau fai hala ki hotau  ĽOtua, pea kuo mau ma Ľu  Ľae ngaahi uaifi kehe  Ľi he kakai  Ľoe fonua: ka ko eni  Ľoku ai  Ľae  Ľamanaki lelei  Ľi  ĽIsileli  Ľoku kau ki he me Ľa ni.  
\v 3 Pea ko eni ke tau fai  Ľae fuakava ki hotau  ĽOtua ke mau tukuange  Ľae ngaahi uaifi kehe kotoa pńď, mo kinautolu kuo fńĀnau  Ľiate kinautolu,  Ľo fakatatau ki he fakakaukau  Ľa hoku  Ľeiki, mo kinautolu  Ľoku tetetete ki he fekau  Ľa hotau  ĽOtua; pea tuku ke fai ia  Ľo fakatatau mo e fono.  
\v 4 Tu Ľu hake: he  Ľoku kau  Ľae me Ľa ni kiate koe: pea ke loto mńĀlohi, pea fai ia.‚ÄĚ  
\v 5 Pea na Ľe tu Ľu ai  Ľa Esela, pea fakafuakava  Ľe ia  Ľae kau taula Ľeiki lahi, mo e kau Livai, mo  ĽIsileli kotoa pńď koe Ľuhi ke nau fai  Ľo fakatatau ki he lea ni. Pea na Ľa nau fuakava.   
\p
\v 6 ¬∂ Pea na Ľe tu Ľu hake  Ľa Esela mei he mata fale  Ľoe  ĽOtua, pea ne  Ľalu ki he fale  Ľo Sohanani ko e foha  Ľo Iliasipi: pea  Ľi he Ľene hoko ki ai, na Ľe  Ľikai te ne kai ha mńĀ, pe inu ha vai: he na Ľe tangi pe ia ko e me Ľa  Ľi he angahala  Ľanautolu  Ľaia na Ľe fetuku  Ľo  Ľave pŇćpula.  
\v 7 Pea na Ľa nau fanongonongo  Ľae fono  Ľi Siuta kotoa pńď mo SelŇęsalema ki he fńĀnau kotoa pńď  Ľoe fakapŇćpula, koe Ľuhi ke nau fakataha  Ľakinautolu  Ľi SelŇęsalema.  
\v 8 Pea  Ľilonga  Ľaia  Ľe  Ľikai ha Ľu  Ľi he  Ľaho  Ľe tolu,  Ľo fakatatau mo e fakakaukau  Ľae hou Ľeiki mo e kau mńĀtu Ľa,  Ľe fa Ľoa  Ľene me Ľa kotoa pńď, pea  Ľe vahe Ľi ia mei he fakataha  Ľokinautolu na Ľe fetuku ki he mama Ľo.   
\p
\v 9 ¬∂ Pea na Ľe toki fakakńĀtoa fakataha  Ľakinautolu ki SelŇęsalema  Ľae kau tangata kotoa pńď  Ľo Siuta mo Penisimani,  Ľi he  Ľaho  Ľe tolu. Ko hono hiva ia  Ľoe mńĀhina,  Ľi hono  Ľaho  Ľe uofulu  Ľoe mńĀhina; pea na Ľe nofo  Ľae kakai kotoa pńď  Ľi he hala lahi  Ľoe fale  Ľoe  ĽOtua, pea tetetete koe Ľuhi ko e me Ľa ni, pea koe Ľuhi ko e  Ľuha lahi.  
\v 10 Pea na Ľe tu Ľu hake  Ľa Esela ko e taula Ľeiki,  Ľo ne pehńď kiate kinautolu, ‚ÄúKuo mou fai talangata Ľa; pea kuo mou ma Ľu  Ľae ngaahi uaifi kehe, ke fakalahi ki he hala  Ľa  ĽIsileli.  
\v 11 Pea ko eni mou fai  Ľae vete kia Sihova ko e  ĽOtua  Ľo ho Ľomou ngaahi tamai, pea \add mou \add*fai ki hono finangalo: pea fakamavae  Ľakimoutolu mei he kakai  Ľoe fonua, pea mei homou ngaahi uaifi kehe.‚ÄĚ  
\v 12 Pea na Ľe lea ai  Ľae kakai kotoa pńď na Ľe fakataha  Ľo pehńď  Ľaki  Ľae le Ľo lahi, ‚ÄúHangńď ko ia kuo ke tala,  Ľoku totonu ke mau fai.  
\v 13 Ka  Ľoku tokolahi  Ľae kakai, pea ko e  Ľaho eni  Ľoe  Ľuha lahi, pea  Ľoku  Ľikai te mau fa Ľa fai ke tu Ľu  Ľi tua ĽńĀ, pea  Ľoku  Ľikai ko e ngńĀue eni ki he  Ľaho pe taha pe ua: he  Ľoku mau tokolahi kuo fai hala  Ľi he me Ľa ni.  
\v 14 Pea ko eni ke tu Ľu hake homau kau pule  Ľoe fakataha kotoa pńď, pea ke ha Ľu  Ľakinautolu kotoa pńď,  Ľaia kuo nau ma Ľu  Ľae ngaahi uaifi kehe,  Ľi hotau ngaahi kolo,  Ľi he ngaahi  Ľaho  Ľe kotofa, pea ke ha Ľu mo kinautolu  Ľae kau mńĀtu Ľa  Ľoe kolo kotoa pńď, mo e kau fakamaau  Ľi ai, koe Ľuhi ke fakafoki  Ľae houhau lahi  Ľo hotau  ĽOtua  Ľi he me Ľa ni meiate kimautolu.‚ÄĚ   
\p
\v 15 ¬∂ Ko Sonatani pe ko e foha  Ľo  ĽAsaeli mo Sehasia ko e foha  Ľo Tikiva na Ľe fakakau  Ľakinaua  Ľi he me Ľa ni: pea na Ľe tokoni  Ľakinaua  Ľe Mesulami, mo Sapitei ko e Livai.  
\v 16 Pea na Ľe fai pehńď pe  Ľe he fńĀnau  Ľae kau pŇćpula. Pea na Ľe nofo hifo  Ľa Esela ko e taula Ľeiki, mo e ni Ľihi  Ľoe kau tu Ľukimu Ľa  Ľi he kau mńĀtu Ľa,  Ľo fakatatau ki he fale  Ľo  Ľenau ngaahi tamai, pea na Ľe vahevahe  Ľakinautolu kotoa pńď  Ľi honau hingoa,  Ľi he  Ľuluaki  Ľaho  Ľi hono hongofulu  Ľoe mńĀhina ke fakamaau Ľi  Ľae me Ľa ni.  
\v 17 Pea na Ľa nau fai  Ľo  Ľosi  Ľi he  Ľuluaki  Ľaho  Ľoe  Ľuluaki mńĀhina ki he kau tangata kotoa pńď na Ľa nau ma Ľu  Ľae uaifi kehe.   
\p
\v 18 ¬∂ Pea na Ľe  Ľilo  Ľi he ngaahi foha  Ľoe kau taula Ľeiki,  Ľae ni Ľihi na Ľe ma Ľu  Ľae ngaahi uaifi kehe:  
\li1 koe Ľuhi,  Ľi he ngaahi foha  Ľo Sesua ko e foha  Ľo Sosataki, mo hono ngaahi kńĀinga;  
\li1 ko MńĀseia, mo  ĽEliesa, mo Salipe, mo Ketalia.   
\li1
\v 19 Pea na Ľa nau foaki honau nima ke nau tukuange honau ngaahi uaifi;  
\li1 pea  Ľi he Ľenau halaia, na Ľa nau  Ľatu  Ľae sipitangata mei he fanga sipi  Ľi he Ľenau angahala.   
\li1
\v 20 Pea  Ľi he ngaahi foha  Ľo Imeli ko Hanani, mo Sepatia.   
\li1
\v 21 Pea  Ľi he ngaahi foha  Ľo Halimi;  
\li1 ko MńĀseia, mo  ĽIlaisińĀ, mo Simaia, mo Sehieli, mo  ĽUsia.   
\li1
\v 22 Pea  Ľi he ngaahi foha  Ľo Pasuli;  
\li1 Ilionei, mo MńĀseia, mo  ĽIsime Ľeli,  
\li1 mo Netanili, mo Sosapati, mo Elasa.   
\li1
\v 23 Pea  Ľi he kau Livai foki:  
\li1 ko Sosapati, mo Simi, mo Kelaia, ( Ľaia ko Kilita),  
\li1 ko Pitaia, mo Siuta, mo  ĽEliesa.   
\li1
\v 24 ‚ÄĆ ĽI he kau hiva foki ko Iliasipi:  
\li1 pea  Ľi he kau le Ľo matapńĀ ko Salumi, mo Telemi, mo Uli.   
\li1
\v 25 Pea koe Ľuhi ko  ĽIsileli:  Ľi he ngaahi foha  Ľo Palosi;  
\li1 ko Limaia, mo Sesia, mo Malikia, mo Miamini,  
\li1 mo  ĽEliesa, mo Malikisa mo Penaia.   
\li1
\v 26 Pea  Ľi he ngaahi foha  Ľo  ĽIlami;  
\li1 ko Matania, mo Sakalia, mo Sehieli,  
\li1 mo  ĽApiti, mo Selimoti, mo Elia.   
\li1
\v 27 Pea  Ľi he ngaahi foha  Ľo Satu;  
\li1 Ilionei, mo Iliasipi, mo Matania,  
\li1 mo Selimoti, mo Sapati, mo  ĽAsisa.   
\li1
\v 28 ‚ÄĆ ĽI he ngaahi foha foki  Ľo Pepai;  
\li1 ko Sihohanani, mo Hanania, mo Sapei, mo  ĽAtilai.   
\li1
\v 29 Pea  Ľi he ngaahi foha  Ľo Pani;  
\li1 ko Mesulami, mo Maluki, mo  ĽAtaia,  
\li1 mo Sasupi, mo Siali, mo Lemoti.   
\li1
\v 30 Pea  Ľi he ngaahi foha  Ľo Pehati-Moape;  
\li1 ko  ĽAtina, mo Kilali, mo Penaia, mo MńĀseia,  
\li1 mo Matania, mo Pesalili, mo Pinui, mo Manase.   
\li1
\v 31 Pea  Ľi he ngaahi foha  Ľo Halimi; ko  ĽEliesa, mo Isisa,  
\li1 mo Malikia, mo Simaia, mo Simione,   
\li1
\v 32 Mo Penisimani, mo Maluki, mo Simalia.   
\li1
\v 33 Pea  Ľi he ngaahi foha  Ľo Hasumi;  
\li1 ko Matinei, mo Matata, mo Sapati,  
\li1 mo Ilifileti, mo Silemai, mo Manase, mo Simi.   
\li1
\v 34 Pea  Ľi he ngaahi foha  Ľo Pani; ko Mahetai, mo  ĽAmilami mo Ueli.   
\li1
\v 35 Mo Penaia, mo Petia, mo Kilu,   
\li1
\v 36 Mo Vania, mo Milemoti, mo Iliasipi,   
\li1
\v 37 Mo Matania, mo Matinei, mo Saesai,   
\li1
\v 38 Mo Pani, mo Pinui, mo Simi,   
\li1
\v 39 Mo Selemia, mo Natani, mo  ĽAtaia,   
\li1
\v 40 Mo Makanatipei, mo Sasei, mo Salei,   
\li1
\v 41 Mo  ĽAsalili, mo Selemia, mo Simalia,   
\li1
\v 42 Mo Salumi, mo  ĽAmalia, mo Sosefa.   
\li1
\v 43 Pea  Ľi he ngaahi foha  Ľo Nipo; ko Sieli,  
\li1 mo Matitia, mo Sapati, mo Sipina,  
\li1 mo Satavi, mo Soeli, mo Penaia.   
\p
\v 44 Ko kinautolu ni kotoa pńď na Ľe  Ľiate kinautolu  Ľae ngaahi uaifi kehe: pea na Ľe  Ľi ai  Ľae uaifi ni Ľihi na Ľe ma Ľu  Ľae fńĀnau.   