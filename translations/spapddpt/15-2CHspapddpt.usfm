\v 13 \w los|strong="H1961"\w* trompetistas \w y|strong="H3588"\w* \w los|strong="H1961"\w* \w cantores|strong="H7891"\w* \w se|strong="H1961"\w* unieron \w para|strong="H3588"\w* proclamar \w a|strong="H3068"\w* una \w voz|strong="H6963"\w*. Alababan \w y|strong="H3588"\w* daban gracias \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\p Al alzar \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w con|strong="H3588"\w* las \w trompetas|strong="H2689"\w*, \w los|strong="H1961"\w* \w címbalos|strong="H4700"\w* \w y|strong="H3588"\w* \w los|strong="H1961"\w* otros \w instrumentos|strong="H3627"\w* musicales, alababan \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*: \w Porque|strong="H3588"\w* \w es|strong="H1961"\w* \w bueno|strong="H2896"\w*, \w porque|strong="H3588"\w* \w para|strong="H3588"\w* \w siempre|strong="H5769"\w* \w es|strong="H1961"\w* \w su|strong="H3588"\w* \w misericordia|strong="H2617"\w*, una \w nube|strong="H6051"\w* \w llenó|strong="H4390"\w* \w la|strong="H3588"\w* \w Casa|strong="H1004"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
