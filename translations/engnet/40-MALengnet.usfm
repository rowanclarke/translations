\c 1  
\s1 Introduction and God’s Election of Israel  
\p
\v 1  \w What|strong="H1697"\w* follows \w is|strong="H3068"\w* divine revelation. \w The|strong="H3068"\w* \w word|strong="H1697"\w* \w of|strong="H3068"\w* \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w came|strong="H3478"\w* \w to|strong="H3478"\w* \w Israel|strong="H3478"\w* \w through|strong="H3027"\w* \w Malachi|strong="H4401"\w*:   
\p
\v 2 “\w I|strong="H3808"\w* \w have|strong="H3068"\w* shown love \w to|strong="H3068"\w* \w you|strong="H3808"\w*,” \w says|strong="H5002"\w* \w the|strong="H5002"\w* \nd \+w Lord|strong="H3068"\+w*\nd*, \w but|strong="H3808"\w* \w you|strong="H3808"\w* say, “\w How|strong="H4100"\w* \w have|strong="H3068"\w* \w you|strong="H3808"\w* shown love \w to|strong="H3068"\w* us?”  
\p “\w Esau|strong="H6215"\w* \w was|strong="H3068"\w* \w Jacob|strong="H3290"\w*’s brother,” \w the|strong="H5002"\w* \nd \+w Lord|strong="H3068"\+w*\nd* explains, “\w yet|strong="H3068"\w* \w I|strong="H3808"\w* chose \w Jacob|strong="H3290"\w*  
\v 3  \w and|strong="H2022"\w* rejected \w Esau|strong="H6215"\w*. \w I|strong="H7760"\w* \w turned|strong="H7760"\w* \w Esau|strong="H6215"\w*’s \w mountains|strong="H2022"\w* \w into|strong="H7760"\w* \w a|strong="H3068"\w* deserted \w wasteland|strong="H4057"\w* \w and|strong="H2022"\w* \w gave|strong="H7760"\w* \w his|strong="H7760"\w* territory \w to|strong="H5159"\w* \w the|strong="H7760"\w* wild jackals.”   
\p
\v 4  Edom \w says|strong="H3541"\w*, “\w Though|strong="H3588"\w* \w we|strong="H3068"\w* \w are|strong="H1992"\w* devastated, \w we|strong="H3068"\w* \w will|strong="H3068"\w* \w once|strong="H7725"\w* \w again|strong="H7725"\w* \w build|strong="H1129"\w* \w the|strong="H3588"\w* \w ruined|strong="H2040"\w* \w places|strong="H2723"\w*.” \w So|strong="H3541"\w* \w the|strong="H3588"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H5971"\w* \w rules|strong="H5769"\w* \w over|strong="H3068"\w* \w all|strong="H5704"\w* \w responds|strong="H1366"\w*, “\w They|strong="H1992"\w* \w indeed|strong="H3588"\w* \w may|strong="H3068"\w* \w build|strong="H1129"\w*, \w but|strong="H3588"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w overthrow|strong="H2040"\w*. \w They|strong="H1992"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* known \w as|strong="H5704"\w* \w the|strong="H3588"\w* \w land|strong="H1366"\w* \w of|strong="H3068"\w* \w evil|strong="H7564"\w*, \w the|strong="H3588"\w* \w people|strong="H5971"\w* \w with|strong="H3068"\w* \w whom|strong="H1992"\w* \w the|strong="H3588"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w is|strong="H3068"\w* \w permanently|strong="H5769"\w* \w displeased|strong="H2194"\w*.  
\v 5  \w Your|strong="H3068"\w* \w eyes|strong="H5869"\w* \w will|strong="H3068"\w* \w see|strong="H7200"\w* \w it|strong="H5921"\w*, \w and|strong="H3478"\w* \w then|strong="H7200"\w* \w you|strong="H5921"\w* \w will|strong="H3068"\w* \w say|strong="H3478"\w*, ‘\w May|strong="H3068"\w* \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w be|strong="H3068"\w* \w magnified|strong="H1431"\w* \w even|strong="H5869"\w* \w beyond|strong="H5921"\w* \w the|strong="H5921"\w* \w border|strong="H1366"\w* \w of|strong="H3068"\w* \w Israel|strong="H3478"\w*!’”   
\s1 The Sacrilege of Priestly Service  
\p
\v 6 “\w A|strong="H3068"\w* \w son|strong="H1121"\w* naturally \w honors|strong="H3513"\w* \w his|strong="H3068"\w* \w father|strong="H1121"\w* \w and|strong="H1121"\w* \w a|strong="H3068"\w* \w slave|strong="H5650"\w* respects \w his|strong="H3068"\w* master. \w If|strong="H1121"\w* \w I|strong="H5650"\w* \w am|strong="H3068"\w* \w your|strong="H3068"\w* \w father|strong="H1121"\w*, \w where|strong="H4100"\w* \w is|strong="H3068"\w* \w my|strong="H3068"\w* \w honor|strong="H3519"\w*? \w If|strong="H1121"\w* \w I|strong="H5650"\w* \w am|strong="H3068"\w* \w your|strong="H3068"\w* master, \w where|strong="H4100"\w* \w is|strong="H3068"\w* \w my|strong="H3068"\w* \w respect|strong="H4172"\w*? \w The|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H3068"\w* \w all|strong="H3068"\w* asks \w you|strong="H4100"\w* \w this|strong="H3068"\w*, \w you|strong="H4100"\w* \w priests|strong="H3548"\w* \w who|strong="H3068"\w* \w make|strong="H3513"\w* light \w of|strong="H1121"\w* \w my|strong="H3068"\w* \w name|strong="H8034"\w*! \w But|strong="H3513"\w* \w you|strong="H4100"\w* reply, ‘\w How|strong="H4100"\w* \w have|strong="H3068"\w* \w we|strong="H3068"\w* \w made|strong="H3513"\w* light \w of|strong="H1121"\w* \w your|strong="H3068"\w* \w name|strong="H8034"\w*?’  
\v 7  \w You|strong="H5921"\w* \w are|strong="H4100"\w* \w offering|strong="H3068"\w* \w improper|strong="H1351"\w* \w sacrifices|strong="H3899"\w* \w on|strong="H5921"\w* \w my|strong="H3068"\w* \w altar|strong="H4196"\w*, \w yet|strong="H3068"\w* \w you|strong="H5921"\w* ask, ‘\w How|strong="H4100"\w* \w have|strong="H3068"\w* \w we|strong="H3068"\w* offended \w you|strong="H5921"\w*?’ \w By|strong="H5921"\w* treating \w the|strong="H5921"\w* \w table|strong="H7979"\w* \w of|strong="H3068"\w* \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w as|strong="H3068"\w* \w if|strong="H1931"\w* \w it|strong="H1931"\w* \w is|strong="H3068"\w* \w of|strong="H3068"\w* no importance!  
\v 8  \w For|strong="H3588"\w* \w when|strong="H3588"\w* \w you|strong="H3588"\w* \w offer|strong="H7126"\w* \w blind|strong="H5787"\w* animals \w as|strong="H3068"\w* \w a|strong="H3068"\w* \w sacrifice|strong="H2076"\w*, \w is|strong="H3068"\w* \w that|strong="H3588"\w* \w not|strong="H3588"\w* \w wrong|strong="H7451"\w*? \w And|strong="H3068"\w* \w when|strong="H3588"\w* \w you|strong="H3588"\w* \w offer|strong="H7126"\w* \w the|strong="H6440"\w* \w lame|strong="H6455"\w* \w and|strong="H3068"\w* \w sick|strong="H2470"\w*, \w is|strong="H3068"\w* \w that|strong="H3588"\w* \w not|strong="H3588"\w* \w wrong|strong="H7451"\w* \w as|strong="H3068"\w* well? \w Indeed|strong="H3588"\w*, try \w offering|strong="H2076"\w* \w them|strong="H6440"\w* \w to|strong="H3068"\w* \w your|strong="H3068"\w* \w governor|strong="H6346"\w*! \w Will|strong="H3068"\w* \w he|strong="H3588"\w* \w be|strong="H3068"\w* \w pleased|strong="H7521"\w* \w with|strong="H3068"\w* \w you|strong="H3588"\w* \w or|strong="H3068"\w* \w show|strong="H5375"\w* \w you|strong="H3588"\w* \w favor|strong="H6440"\w*?” asks \w the|strong="H6440"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H6440"\w* \w all|strong="H5375"\w*.  
\v 9  \w But|strong="H1961"\w* \w now|strong="H6258"\w* \w plead|strong="H2470"\w* \w for|strong="H6440"\w* \w God|strong="H3068"\w*’s \w favor|strong="H6440"\w* \w that|strong="H3068"\w* \w he|strong="H3068"\w* \w might|strong="H3068"\w* \w be|strong="H1961"\w* \w gracious|strong="H2603"\w* \w to|strong="H3068"\w* \w us|strong="H4994"\w*. “\w With|strong="H3068"\w* \w this|strong="H2063"\w* \w kind|strong="H2470"\w* \w of|strong="H3068"\w* \w offering|strong="H3068"\w* \w in|strong="H3068"\w* \w your|strong="H3068"\w* \w hands|strong="H3027"\w*, \w how|strong="H4994"\w* \w can|strong="H4994"\w* \w he|strong="H3068"\w* \w be|strong="H1961"\w* \w pleased|strong="H5375"\w* \w with|strong="H3068"\w* \w you|strong="H6440"\w*?” asks \w the|strong="H6440"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H3027"\w* \w all|strong="H4480"\w*.   
\p
\v 10 “\w I|strong="H1571"\w* \w wish|strong="H4310"\w* \w that|strong="H3068"\w* \w one|strong="H3808"\w* \w of|strong="H3068"\w* \w you|strong="H3808"\w* \w would|strong="H4310"\w* \w close|strong="H5462"\w* \w the|strong="H3068"\w* temple \w doors|strong="H1817"\w*, \w so|strong="H3808"\w* \w that|strong="H3068"\w* \w you|strong="H3808"\w* \w no|strong="H3808"\w* \w longer|strong="H3808"\w* \w would|strong="H4310"\w* light \w useless|strong="H3808"\w* fires \w on|strong="H3027"\w* \w my|strong="H3068"\w* \w altar|strong="H4196"\w*. \w I|strong="H1571"\w* \w am|strong="H3068"\w* \w not|strong="H3808"\w* \w pleased|strong="H7521"\w* \w with|strong="H3068"\w* \w you|strong="H3808"\w*,” says \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H4310"\w* rules \w over|strong="H3027"\w* \w all|strong="H3068"\w*, “\w and|strong="H3068"\w* \w I|strong="H1571"\w* \w will|strong="H3068"\w* \w no|strong="H3808"\w* \w longer|strong="H3808"\w* \w accept|strong="H7521"\w* \w an|strong="H3068"\w* \w offering|strong="H4503"\w* \w from|strong="H3027"\w* \w you|strong="H3808"\w*.  
\v 11  \w For|strong="H3588"\w* \w from|strong="H1471"\w* \w the|strong="H3605"\w* \w east|strong="H4217"\w* \w to|strong="H5704"\w* \w the|strong="H3605"\w* \w west|strong="H3996"\w* \w my|strong="H3605"\w* \w name|strong="H8034"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* \w great|strong="H1419"\w* \w among|strong="H8034"\w* \w the|strong="H3605"\w* \w nations|strong="H1471"\w*. \w Incense|strong="H6999"\w* \w and|strong="H3068"\w* \w pure|strong="H2889"\w* \w offerings|strong="H4503"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* \w offered|strong="H6999"\w* \w in|strong="H3068"\w* \w my|strong="H3605"\w* \w name|strong="H8034"\w* \w everywhere|strong="H3605"\w*, \w for|strong="H3588"\w* \w my|strong="H3605"\w* \w name|strong="H8034"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* \w great|strong="H1419"\w* \w among|strong="H8034"\w* \w the|strong="H3605"\w* \w nations|strong="H1471"\w*,” says \w the|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3605"\w* rules \w over|strong="H3068"\w* \w all|strong="H3605"\w*.  
\v 12 “\w But|strong="H1931"\w* you \w are|strong="H7979"\w* \w profaning|strong="H2490"\w* \w it|strong="H1931"\w* by saying \w that|strong="H1931"\w* \w the|strong="H2490"\w* \w table|strong="H7979"\w* \w of|strong="H7979"\w* \w the|strong="H2490"\w* Lord \w is|strong="H1931"\w* common \w and|strong="H7979"\w* \w its|strong="H2490"\w* offerings despicable.  
\v 13  \w You|strong="H3027"\w* \w also|strong="H3068"\w* say, ‘\w How|strong="H2009"\w* tiresome \w it|strong="H5301"\w* \w is|strong="H3068"\w*.’ \w You|strong="H3027"\w* turn \w up|strong="H5301"\w* \w your|strong="H3068"\w* nose \w at|strong="H3068"\w* \w it|strong="H5301"\w*,” says \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H3027"\w* \w all|strong="H2009"\w*, “\w and|strong="H3068"\w* \w instead|strong="H2009"\w* bring what \w is|strong="H3068"\w* stolen, \w lame|strong="H6455"\w*, \w or|strong="H3027"\w* \w sick|strong="H2470"\w*. \w You|strong="H3027"\w* bring these things \w for|strong="H3027"\w* \w an|strong="H3068"\w* \w offering|strong="H4503"\w*! \w Should|strong="H3068"\w* \w I|strong="H2009"\w* \w accept|strong="H7521"\w* \w this|strong="H3068"\w* \w from|strong="H3027"\w* \w you|strong="H3027"\w*?” asks \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd*.  
\v 14 “\w There|strong="H3426"\w* \w will|strong="H3068"\w* \w be|strong="H3426"\w* harsh condemnation \w for|strong="H3588"\w* \w the|strong="H3588"\w* hypocrite \w who|strong="H3068"\w* \w has|strong="H3068"\w* \w a|strong="H3068"\w* valuable \w male|strong="H2145"\w* \w animal|strong="H7843"\w* \w in|strong="H3068"\w* \w his|strong="H3068"\w* \w flock|strong="H5739"\w* \w but|strong="H3588"\w* \w vows|strong="H5087"\w* \w and|strong="H3068"\w* \w sacrifices|strong="H2076"\w* something inferior \w to|strong="H3068"\w* \w the|strong="H3588"\w* \w Lord|strong="H3068"\w*. \w For|strong="H3588"\w* \w I|strong="H3588"\w* \w am|strong="H3068"\w* \w a|strong="H3068"\w* \w great|strong="H1419"\w* \w king|strong="H4428"\w*,” says \w the|strong="H3588"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3068"\w* \w rules|strong="H4428"\w* \w over|strong="H4428"\w* \w all|strong="H7843"\w*, “\w and|strong="H3068"\w* \w my|strong="H3068"\w* \w name|strong="H8034"\w* \w is|strong="H3068"\w* \w awesome|strong="H3372"\w* \w among|strong="H8034"\w* \w the|strong="H3588"\w* \w nations|strong="H1471"\w*.”   
\c 2  
\p
\v 1 “\w Now|strong="H6258"\w*, \w you|strong="H6258"\w* \w priests|strong="H3548"\w*, \w this|strong="H2063"\w* \w commandment|strong="H4687"\w* \w is|strong="H4687"\w* \w for|strong="H3548"\w* \w you|strong="H6258"\w*.  
\v 2  \w If|strong="H3588"\w* \w you|strong="H3588"\w* \w do|strong="H3068"\w* \w not|strong="H3808"\w* \w listen|strong="H8085"\w* \w and|strong="H3068"\w* \w take|strong="H7760"\w* \w seriously|strong="H3820"\w* \w the|strong="H5921"\w* need \w to|strong="H3068"\w* \w honor|strong="H3519"\w* \w my|strong="H8085"\w* \w name|strong="H8034"\w*,” says \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H5921"\w* \w all|strong="H5414"\w*, “\w I|strong="H3588"\w* \w will|strong="H3068"\w* \w send|strong="H7971"\w* judgment \w on|strong="H5921"\w* \w you|strong="H3588"\w* \w and|strong="H3068"\w* \w turn|strong="H7760"\w* \w your|strong="H3068"\w* \w blessings|strong="H1293"\w* \w into|strong="H5921"\w* \w curses|strong="H3994"\w* – \w indeed|strong="H3588"\w*, \w I|strong="H3588"\w* \w have|strong="H3068"\w* already \w done|strong="H7760"\w* \w so|strong="H7971"\w* \w because|strong="H3588"\w* \w you|strong="H3588"\w* \w are|strong="H3068"\w* \w not|strong="H3808"\w* \w taking|strong="H7760"\w* \w it|strong="H5414"\w* \w to|strong="H3068"\w* \w heart|strong="H3820"\w*.  
\v 3  \w I|strong="H2005"\w* \w am|strong="H2005"\w* \w about|strong="H5921"\w* \w to|strong="H5921"\w* discipline \w your|strong="H5921"\w* \w children|strong="H2233"\w* \w and|strong="H6440"\w* \w will|strong="H2233"\w* \w spread|strong="H2219"\w* \w offal|strong="H6569"\w* \w on|strong="H5921"\w* \w your|strong="H5921"\w* \w faces|strong="H6440"\w*, \w the|strong="H6440"\w* very \w offal|strong="H6569"\w* produced \w at|strong="H5921"\w* \w your|strong="H5921"\w* \w festivals|strong="H2282"\w*, \w and|strong="H6440"\w* \w you|strong="H6440"\w* \w will|strong="H2233"\w* \w be|strong="H5375"\w* \w carried|strong="H5375"\w* \w away|strong="H5375"\w* \w along|strong="H5921"\w* \w with|strong="H5921"\w* \w it|strong="H5921"\w*.  
\v 4  \w Then|strong="H1961"\w* \w you|strong="H3588"\w* \w will|strong="H3068"\w* \w know|strong="H3045"\w* \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w sent|strong="H7971"\w* \w this|strong="H2063"\w* \w commandment|strong="H4687"\w* \w to|strong="H3068"\w* \w you|strong="H3588"\w* \w so|strong="H7971"\w* \w that|strong="H3588"\w* \w my|strong="H3068"\w* \w covenant|strong="H1285"\w* \w may|strong="H1961"\w* \w continue|strong="H1961"\w* \w to|strong="H3068"\w* \w be|strong="H1961"\w* \w with|strong="H3068"\w* \w Levi|strong="H3878"\w*,” says \w the|strong="H3588"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H3068"\w* rules \w over|strong="H3068"\w* \w all|strong="H3045"\w*.  
\v 5 “\w My|strong="H5414"\w* \w covenant|strong="H1285"\w* \w with|strong="H1285"\w* \w him|strong="H5414"\w* \w was|strong="H8034"\w* designed \w to|strong="H1961"\w* \w bring|strong="H5414"\w* \w life|strong="H2416"\w* \w and|strong="H6440"\w* \w peace|strong="H7965"\w*. \w I|strong="H5414"\w* \w gave|strong="H5414"\w* \w its|strong="H5414"\w* statutes \w to|strong="H1961"\w* \w him|strong="H5414"\w* \w to|strong="H1961"\w* fill \w him|strong="H5414"\w* \w with|strong="H1285"\w* \w awe|strong="H3372"\w*, \w and|strong="H6440"\w* \w he|strong="H1931"\w* \w indeed|strong="H5414"\w* \w revered|strong="H3372"\w* \w me|strong="H5414"\w* \w and|strong="H6440"\w* \w stood|strong="H2865"\w* \w in|strong="H6440"\w* \w awe|strong="H3372"\w* \w before|strong="H6440"\w* \w me|strong="H5414"\w*.  
