\id AMO - Biblica® Open Kurdi Sorani Standard Version 
\h ئامۆس 
\toc1 ئامۆس 
\toc2 ئامۆس 
\toc3 ئامۆس 
\mt1 ئامۆس 
\c 1  
\p  
\v 1 ئەمە پەیامی ئامۆسە کە یەکێک بوو لە شوانەکانی شارۆچکەی تەقۆعە، دوو ساڵ پێش بوومەلەرزەکە لە سەردەمی عوزیای پاشای یەهودا و لە سەردەمی یارۆڤعامی کوڕی یەهۆئاشی پاشای ئیسرائیل، ئەم بینینەی دەربارەی ئیسرائیل بۆ ئاشکرا کرا. 
\b  
\p  
\v 2 گوتی: 
\q1 «یەزدان لە سییۆنەوە دەنەڕێنێت، 
\q2 لە ئۆرشەلیمەوە دەنگی دێت، 
\q1 لەوەڕگای شوانەکان شیوەن دەگێڕن و 
\q2 لووتکەی کارمەل وشک دەبێت.» 
\s1 حوکم بەسەردادانی وڵاتانی دەوروبەر 
\p  
\v 3 یەزدان ئەمە دەفەرموێت: 
\q1 «دیمەشق یاخی بوو، لە یاخیبوونەکەی بەردەوامە، 
\q2 سزاکەیان بەسەردا تێناپەڕێنم، 
\q2 لەبەر ئەوەی بە جەنجەڕی ئاسن گلعادیان شێلا، 
\q1  
\v 4 ئاگر دەنێرمە سەر ماڵی حەزائێل، 
\q2 قەڵاکانی بەن‌هەدەد دەخوات. 
\q1  
\v 5 شەوبەندی دەروازەکانی دیمەشق دەشکێنم، 
\q2 فەرمانڕەواکە لە دۆڵی ئاڤەن ڕیشەکێش دەکەم، 
\q1 هەروەها گۆچان بەدەست لە بێت‌عەدەن. 
\q2 گەلی ئارام بۆ قییر ڕاپێچ دەکرێن.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\p  
\v 6 یەزدان ئەمە دەفەرموێت: 
\q1 «غەزە یاخی بوو، لە یاخیبوونەکەی بەردەوامە، 
\q2 سزاکەیان بەسەردا تێناپەڕێنم، 
\q1 لەبەر ئەوەی چەند کۆمەڵگایەکی بە تەواوەتی بە دیل گرت و 
\q2 بە ئەدۆمی فرۆشت، 
\q1  
\v 7 ئاگر دەنێرمە سەر شووراکانی غەزە، 
\q2 قەڵاکانی دەخوات. 
\q1  
\v 8 فەرمانڕەواکە لە ئەشدۆد ڕیشەکێش دەکەم و 
\q2 گۆچان بەدەست لە ئەسقەلان. 
\q1 دەستم دەگەڕێنمەوە سەر عەقرۆن، 
\q2 پاشماوەی فەلەستییەکان لەناودەچن.» 
\q4 ئەوە فەرمایشتی یەزدانی باڵادەستە. 
\p  
\v 9 یەزدان ئەمە دەفەرموێت: 
\q1 «سور یاخی بوو، لە یاخیبوونەکەی بەردەوامە، 
\q2 سزاکەیان بەسەردا تێناپەڕێنم، 
\q1 لەبەر ئەوەی تەواوی چەند کۆمەڵگایەکی بە دیلگیراوی فرۆشتە ئەدۆم و 
\q2 پەیمانی برایەتییان نەهێنایەوە یادیان، 
\q1  
\v 10 ئاگر دەنێرمە سەر شووراکانی سور، 
\q2 قەڵاکانی دەخوات.» 
\p  
\v 11 یەزدان ئەمە دەفەرموێت: 
\q1 «لەبەر ئەوەی ئەدۆم یاخی بوو، لە یاخیبوونەکەی بەردەوامە، 
\q2 سزاکەیان بەسەردا تێناپەڕێنم، 
\q1 لەبەر ئەوەی بە شمشێرەوە دوای براکەی کەوت، 
\q2 بەبێ دەربڕینی بەزەیی. 
\q1 هەروەها لەبەر ئەوەی تووڕەییەکەی بەردەوام لە جۆش بوو، 
\q2 قینیشی بۆ هەتاهەتایە هەڵدەگرت، 
\q1  
\v 12 هەر لەبەر ئەوە ئاگر دەنێرمە سەر تێمان، 
\q2 قەڵاکانی بۆزرا دەخوات.» 
\p  
\v 13 یەزدان ئەمە دەفەرموێت: 
\q1 «عەمۆن یاخی بوو، لە یاخیبوونەکەی بەردەوامە، 
\q2 سزاکەیان بەسەردا تێناپەڕێنم، 
\q1 لەبەر ئەوەی سکپڕەکانی گلعادیان هەڵدڕی، 
\q2 بۆ ئەوەی سنوورەکانیان بەرفراوان بکەن، 
\q1  
\v 14 ئاگر لە شووراکانی ڕەبە بەردەدەم 
\q2 قەڵاکانی دەخوات، 
\q1 بە هاتوهاوارەوە لە ڕۆژی جەنگدا، 
\q2 بە زریانەوە لە ڕۆژی باوباراندا. 
\q1  
\v 15 پاشاکەیان ڕاپێچ دەکرێت، 
\q2 ئەو و هەموو کاربەدەستەکانی بە یەک جار.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\c 2  
\p  
\v 1 یەزدان ئەمە دەفەرموێت: 
\q1 «مۆئاب یاخی بوو، لە یاخیبوونەکەی بەردەوامە، 
\q2 سزاکەیان بەسەردا تێناپەڕێنم، 
\q1 لەبەر ئەوەی ئێسکەکانی پاشای ئەدۆمی سووتاند 
\q2 هەتا ئەوەی بووە گەچ، 
\q1  
\v 2 هەر لەبەر ئەوە ئاگر دەنێرمە سەر مۆئاب، 
\q2 قەڵاکانی قەریۆت دەخوات. 
\q1 مۆئاب لەناو هاژەهاژ دەمرێت، 
\q2 لەنێو هاتوهاوار و دەنگی کەڕەنا. 
\q1  
\v 3 فەرمانڕەوا لە ناوەڕاستیدا ڕیشەکێش دەکەم و 
\q2 هەموو کاربەدەستەکانی لەگەڵیدا دەکوژم.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\p  
\v 4 یەزدان ئەمە دەفەرموێت: 
\q1 «یەهودا یاخی بوو، لە یاخیبوونەکەی بەردەوامە، 
\q2 سزاکەیان بەسەردا تێناپەڕێنم، 
\q1 لەبەر ئەوەی فێرکردنی یەزدانیان ڕەتکردەوە و 
\q2 فەرزەکانی ئەویان بەجێنەهێنا، 
\q1 چونکە درۆکانیان فریوی دان 
\q2 ئەوەی باوکانیان دوایان کەوتن، 
\q1  
\v 5 هەر لەبەر ئەوە ئاگر دەنێرمە سەر یەهودا، 
\q2 قەڵاکانی ئۆرشەلیم دەخوات.» 
\s1 حوکم بەسەردادانی ئیسرائیل 
\p  
\v 6 یەزدان ئەمە دەفەرموێت: 
\q1 «ئیسرائیل یاخی بوو، لە یاخیبوونەکەی بەردەوامە، 
\q2 سزاکەیان بەسەردا تێناپەڕێنم، 
\q1 کەسانی ڕاستودروست بە زیو دەفرۆشن، 
\q2 نەداریش بۆ جووتێک پێڵاو. 
\q1  
\v 7 سەری هەژاران لەسەر خۆڵی زەوی پێشێل دەکەن، 
\q2 ڕێگای کڵۆڵان خوار دەکەنەوە. 
\q1 پیاوێک و باوکی بۆ لای یەک کچ دەچن، 
\q2 تاکو ناوی پیرۆزم بزڕێنن. 
\q1  
\v 8 لەسەر جلوبەرگێک ڕادەکشێن کە بە بارمتە وەریانگرتووە 
\q2 لە پاڵ هەموو قوربانگایەک، 
\q1 شەرابی بە سەرانە وەرگیراو دەخۆنەوە 
\q2 لەناو ماڵی خوداوەندیان. 
\b  
\q1  
\v 9 «من بووم کە ئەمۆرییەکانم لەپێشیان لەناوبرد، 
\q2 ئەوانەی باڵایان وەک باڵای دار ئورز بوو، 
\q2 وەک دار بەڕوو بەهێز بوون. 
\q1 بەروبوومی ئەوانم لە سەرەوە لەناوبرد و 
\q2 ڕەگوڕیشاڵیان لە ژێرەوە. 
\q1  
\v 10 من بووم کە لە خاکی میسرەوە دەرمهێنان، 
\q2 چل ساڵ لە چۆڵەوانیدا بەڕێم خستن، 
\q2 بۆ ئەوەی دەست بەسەر خاکی ئەمۆرییەکاندا بگرن. 
\b  
\q1  
\v 11 «لەنێو کوڕەکانتان پێغەمبەرانم بۆ دانان و 
\q2 لەنێو لاوەکانتان ئەوانەی نەزریان لە خۆیان گرتبوو\f + \fr 2:11 \ft بڕوانە \xt سەرژمێری 6‏:1‏-21.‏\ft ‏\f*. 
\q2 ئەی نەوەی ئیسرائیل، ئایا وا نەبوو؟» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\q1  
\v 12 «بەڵام ئێوە شەرابتان دەرخواردی ئەوانە دا کە نەزریان لە خۆیان گرتبوو، 
\q2 فەرمانتان بە پێغەمبەران کرد پێشبینی نەکەن. 
\b  
\q1  
\v 13 «ئەوەتا من لە شوێنی خۆتان دەتانچەقێنم 
\q2 وەک چۆن جەنجەڕ دەچەقێت 
\q2 لەبەر پڕی گوڵەگەنمەکان. 
\q1  
\v 14 ئەوەی خێرایە هەڵنایەت، 
\q2 بەهێز هێزی خۆی توندوتۆڵ ناکات و 
\q2 پاڵەوان گیانی خۆی دەرباز ناکات. 
\q1  
\v 15 تیرهاوێژ خۆی ڕاناگرێت، 
\q2 ئەوەی پێیەکانی سووک بێت هەڵنایەت و 
\q2 ئەسپ سواریش گیانی خۆی دەرباز ناکات. 
\q1  
\v 16 ئەوەی بەجەرگە لەنێو پاڵەوانان 
\q2 لەو ڕۆژەدا بە ڕووتی هەڵدێت.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\c 3  
\s1 بانگکردنی شایەتەکان لە دژی ئیسرائیل 
\p  
\v 1 ئەی نەوەی ئیسرائیل، گوێتان لەم فەرمایشتە بێت کە یەزدان فەرموویەتی، لە دژی ئێوە و هەموو ئەو خێڵەی لە خاکی میسرەوە دەریهێنان، کە فەرمووی: 
\q1  
\v 2 «تەنها ئێوەم ناسی 
\q2 لە هەموو خێڵەکانی زەوی، 
\q1 لەبەر ئەوە سزاتان دەدەم، 
\q2 لەسەر هەموو تاوانەکانتان.» 
\b  
\q1  
\v 3 ئایا دووان پێکەوە هاتوچۆ دەکەن، 
\q2 بێ ئەوەی ڕێک بکەون؟ 
\q1  
\v 4 ئایا شێر لە دارستان دەنەڕێنێت، 
\q2 ئەگەر نێچیری نەبێت؟ 
\q1 ئایا بەچکە شێر لە لانەکەیەوە دەنگی دێت، 
\q2 بێ ئەوەی هیچی ڕفاندبێت؟ 
\q1  
\v 5 ئایا باڵندە دەکەوێتە ناو داوی زەوییەوە، 
\q2 لە کاتێکدا تەڵەی بۆ نەنرابێتەوە؟ 
\q1 ئایا تەڵە لەسەر زەوی هەڵدەگیرێتەوە، 
\q2 ئەگەر هیچی نەگرتبێت؟ 
\q1  
\v 6 ئەگەر کەڕەنا لە شاردا لێبدرێت، 
\q2 ئایا گەل ناترسێت؟ 
\q1 ئەگەر بەڵایەک لە شاردا ڕوو بدات، 
\q2 ئایا یەزدان نەیکردووە؟ 
\b  
\q1  
\v 7 بێگومان یەزدانی باڵادەست هیچ کارێک ناکات 
\q2 بێ ئەوەی نهێنییەکەی بۆ بەندە پێغەمبەرەکانی ئاشکرا بکات. 
\b  
\q1  
\v 8 شێر نەڕاندی، 
\q2 کێ ناترسێت؟ 
\q1 یەزدانی باڵادەست دەفەرموێت، 
\q2 کێ هەیە بتوانێت پەیامی خودا ڕانەگەیەنێت؟ 
\b  
\q1  
\v 9 بە قەڵاکانی ئەشدۆد و خاکی میسر ڕایبگەیەنن و 
\q2 پێیان بڵێن: 
\q1 «لەسەر چیاکانی سامیرە کۆببنەوە، 
\q2 ئەو هاتوهاوارە زۆرەی ناوەڕاستی ببینن، 
\q2 ئەو زۆردارییەی لەناویدا هەیە.» 
\b  
\q1  
\v 10 یەزدان دەفەرموێت: «نازانن کاری باش بکەن، 
\q2 ئەوانەی بەرهەمی تاڵان و ستەمکاری لە قەڵاکانیان ئەمبار دەکەن.» 
\p  
\v 11 لەبەر ئەوە یەزدانی باڵادەست ئەمە دەفەرموێت: 
\q1 «دوژمن دێنە چواردەوری خاکەکە و 
\q2 هێزتان لێ کەم دەکاتەوە و 
\q2 قەڵاکانتان تاڵان دەکرێن.» 
\p  
\v 12 یەزدان ئەمە دەفەرموێت: 
\q1 «وەک چۆن شوان دوو قاچ یان پارچە گوێیەک 
\q2 لە دەمی شێر دەردەهێنێت، 
\q1 ئاواش ئیسرائیلییەکانی دانیشتووی سامیرە 
\q2 بە گۆشەی قەرەوێڵەیەک و 
\q2 بە پارچە پێخەفێک دەردەکرێن.» 
\p  
\v 13 «گوێ بگرن و شایەتی لەسەر بنەماڵەی یاقوب بدەن،» ئەوە فەرمایشتی یەزدانی پەروەردگار، خودای سوپاسالارە. 
\q1  
\v 14 «لەو ڕۆژەی کە سزای ئیسرائیل دەدەم لەسەر یاخیبوونەکانی، 
\q2 سزای قوربانگاکانی بێت‌ئێلیش دەدەم، 
\q1 جا قۆچی قوربانگاکان دەبڕێنەوە و 
\q2 دەکەونە سەر زەوی. 
\q1  
\v 15 کۆشکی زستانە دادەڕمێنم، 
\q2 هەروەها کۆشکی هاوینەش، 
\q2 کۆشکە عاجەکانیش لەناودەچن و 
\q2 هەموو کۆشکەکان کۆتاییان پێدێت.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\c 4  
\s1 نەگەڕانەوەی ئیسرائیل بۆ لای خودا 
\q1  
\v 1 ئەی مانگاکانی باشان، ئەوانەی لە کێوی سامیرەن، 
\q2 ئەی خاتوونەکان، ئەی ئەو ژنانەی ستەم لە هەژاران دەکەن، 
\q2 نەداران وردوخاش دەکەن و 
\q1 بە مێردەکانیان دەڵێن، «خواردنەوەمان بۆ بهێنن!» 
\q2 گوێتان لەم پەیامە بێت: 
\q1  
\v 2 یەزدانی باڵادەست سوێندی بە پیرۆزی خۆی خوارد: 
\q2 «بێگومان ڕۆژێک دێت، 
\q1 خۆتان بە قولاپ دەگیرێن و 
\q2 دوا کەسیشتان بە قولاپی ماسی. 
\q1  
\v 3 هەریەکە و لەپێش خۆیەوە 
\q2 بەناو کەلێنی دیوارێکدا دەبردرێن و 
\q2 فڕێدەدرێنە هەرمۆن.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\q1  
\v 4 «وەرن بۆ بێت‌ئێل و یاخی ببن، 
\q2 لە گلگال یاخیبوون زۆر بکەن. 
\q1 هەموو بەیانییەک قوربانییەکانتان بهێنن، 
\q2 هەر سێ ساڵ جارێک دەیەکەکانتان. 
\q1  
\v 5 ئەی نەوەی ئیسرائیل، لە هەویرترشەوە\f + \fr 4:5 \ft هەویرترش: لە جیاتی خومرە بۆ هەوێن بەکارهاتووە.‏\f* قوربانی سوپاسگوزاری بسووتێنن، 
\q2 بانگەواز بۆ بەخشینی ئازاد بکەن و ڕایبگەیەنن، 
\q2 چونکە واتان پێ خۆش بوو.» 
\q4 ئەوە فەرموودەی یەزدانی باڵادەستە. 
\b  
\q1  
\v 6 «هەروەها منیش لە هەموو شارۆچکەکانتان سک بەتاڵی و 
\q2 لە هەموو شوێنەکانتان کەمی نانم پێدان، 
\q2 بەڵام ئێوە بۆ لای من نەگەڕانەوە.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\b  
\q1  
\v 7 «هەروەها بارانم لێ گرتنەوە 
\q2 هێشتا سێ مانگی مابوو بۆ دروێنە. 
\q1 بارانم بەسەر شارۆچکەیەکدا باراند و 
\q2 بەسەر شارۆچکەیەکی دیکەدا نەمباراند. 
\q1 بەسەر کێڵگەیەکدا باری و 
\q2 ئەو کێڵگەش کە بەسەریدا نەباری وشک بوو. 
\q1  
\v 8 خەڵکی دوو سێ شارۆچکە بۆ ئاو خواردنەوە چوونە شارۆچکەیەکی دیکە، 
\q2 تینووێتییان نەشکا، 
\q2 بەڵام ئێوە بۆ لای من نەگەڕانەوە.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\b  
\q1  
\v 9 «زۆر جار باخ و ڕەزەمێوی ئێوەم هەڵپڕووکاندووە، 
\q2 بە بای گەرمەسێر و کەڕوو. 
\q1 کوللە دار هەنجیر و دار زەیتوونیان خواردووە، 
\q2 بەڵام ئێوە بۆ لای من نەگەڕاونەتەوە.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\b  
\q1  
\v 10 «دەردم ناردە سەر ئێوە، 
\q2 وەک ئەوەی ناردبوومە سەر میسر. 
\q2 بە شمشێر لاوەکانی ئێوەم کوشت، 
\q2 لەگەڵ ئەسپە ڕاپێچکراوەکان، 
\q1 وام کرد بۆنی بۆگەنی تەرمەکانی ناو ئۆردوگاکەتان بکەن، 
\q2 بەڵام ئێوە بۆ لای من نەگەڕانەوە.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\b  
\q1  
\v 11 «هەندێکتانم هەڵگەڕاندەوە، 
\q2 وەک چۆن سەدۆم و عەمۆرام هەڵگەڕاندەوە، 
\q1 وەک پارچە دارێکی گڕگرتووتان لێهات کە لەناو ئاگرەوە دەرهێنرابێت، 
\q2 بەڵام ئێوە بۆ لای من نەگەڕانەوە.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\b  
\q1  
\v 12 «ئەی ئیسرائیل، ئاوات پێ دەکەم، 
\q2 ئەی ئیسرائیل، لەبەر ئەوەی ئەمەت پێ دەکەم، 
\q1 ئامادەبە بۆ ڕووبەڕووبوونەوەی خوداکەت.» 
\b  
\q1  
\v 13 شێوەداڕێژی چیاکان و 
\q2 بەدیهێنەری با، 
\q2 ئەوەی بیرکردنەوەی خۆی بە مرۆڤ ڕادەگەیەنێت، 
\q1 ئەوەی بەرەبەیان دەکاتە تاریکی، 
\q2 بەسەر بەرزاییەکانی زەویدا دەڕوات، 
\q2 ناوی یەزدانی پەروەردگاری سوپاسالارە. 
\c 5  
\s1 لاوانەوە و بانگەوازی تۆبەکردن 
\p  
\v 1 ئەی بنەماڵەی ئیسرائیل، گوێ لەم پەیامە بگرن، ئەم لاوانەوەیە کە من بەسەر ئێوەیدا هەڵدەدەم: 
\q1  
\v 2 «ئیسرائیلی پاکیزە کەوت، 
\q2 جارێکی دیکە هەڵناستێتەوە، 
\q1 فڕێدرایە سەر خاکەکەی، 
\q2 کوا ئەوەی هەڵیدەستێنێتەوە؟» 
\p  
\v 3 سەبارەت بەمەش یەزدانی باڵادەست بەم جۆرە دەفەرموێت: 
\q1 «ئەو شارەی لە ماڵی ئیسرائیل هەزار سەرباز دەنێرێت، 
\q2 سەد سەربازی بۆ دەمێنێتەوە، 
\q1 ئەو شارۆچکەیەی سەد سەرباز دەنێرێت، 
\q2 دە سەربازی بۆ دەمێنێتەوە.» 
\p  
\v 4 لەبەر ئەوە یەزدان ئاوا بە بنەماڵەی ئیسرائیل دەفەرموێت: 
\q1 «ڕوو لە من بکەن و بژین، 
\q2  
\v 5 ڕوو لە بێت‌ئێل مەکەن و 
\q1 مەچن بۆ گلگال و 
\q2 بۆ بیری شابەع مەپەڕنەوە، 
\q1 چونکە گلگال بە دیل گیراوی ڕاپێچ دەکرێت و 
\q2 بێت‌ئێل دەبێتە نەبوو\f + \fr 5:5 \ft نەبوو: عیبری \+tl ئاڤن‏\+tl*، واتا بێت‌ئاڤن، کە ناوێکی سووکە بۆ بێت‌ئێل.‏\f*.» 
\q1  
\v 6 ڕوو لە یەزدان بکەن و بژین، 
\q2 ئەگینا وەک ئاگر پڕدەداتە بنەماڵەی یوسف، 
\q1 ئاگرەکەش دانیشتووانی بێت‌ئێل دەخوات و 
\q2 کەس ناتوانێت بیکوژێنێتەوە. 
\b  
\q1  
\v 7 ئەی ئەوانەی دادپەروەریتان کردە زەقنەبووت، 
\q2 ڕاستودروستیش بە زەویدا دەدەن! 
\b  
\q1  
\v 8 ئەوەی کەلووەکانی حەوتەوانە و ڕاوچی دروستکردووە، 
\q2 سێبەری مەرگ بۆ بەیان دەگۆڕێت و 
\q2 ڕۆژ وەک شەو تاریک دەکات، 
\q1 ئاوی دەریا بانگ دەکات و 
\q2 بەسەر ڕووی زەویدا دەیڕێژێت، 
\q2 ناوی یەزدانە، 
\q1  
\v 9 ئەوەی وێرانی بەسەر قەڵادا دەبارێنێت و 
\q2 وێرانی بەسەر شاری قەڵابەنددا دێت. 
\b  
\q1  
\v 10 ئەوان لە دادگا ڕقیان لە سەرزەنشتکار دەبێتەوە و 
\q2 قێزیان لە کەسی ڕاستگۆ دەبێتەوە. 
\b  
\q1  
\v 11 لەبەر ئەوەی ئێوە هەژار پێشێل دەکەن و 
\q2 بەشە گەنمی لێ دەستێنن، 
\q1 ئەوا ئەو کۆشکەی کە لە بەردی داتاشراو بنیاد نراوە، 
\q2 تێیاندا دانانیشن، 
\q1 ئەو ڕەزەمێوە بەردارەی چاندووتانە، 
\q2 لە شەرابەکەی ناخۆنەوە. 
\q1  
\v 12 دەزانم یاخیبوونەکانتان زۆرن، 
\q2 گوناهەکانتان گەورەن. 
\b  
\q1 ستەمکارانی ڕاستودروست و بەرتیلخۆران، 
\q2 مافی هەژاران لە دادگادا دادەماڵن. 
\q1  
\v 13 لەبەر ئەوە لەو کاتەدا کەسی وریا بێدەنگ دەبێت، 
\q2 چونکە کاتێکی خراپە. 
\b  
\q1  
\v 14 دوای چاکە بکەون نەک خراپە، 
\q2 بۆ ئەوەی بژین، 
\q1 جا وا دەبێت، یەزدانی پەروەردگاری سوپاسالار لەگەڵتاندا دەبێت، 
\q2 وەک خۆتان گوتتان. 
\q1  
\v 15 ڕقتان لە خراپە بێتەوە و حەزتان لە چاکە بێت، 
\q2 دادپەروەری لە دادگادا بچەسپێنن، 
\q1 ڕەنگە یەزدانی پەروەردگاری سوپاسالار 
\q2 لەگەڵ پاشماوەی یوسف میهرەبان بێت. 
\p  
\v 16 لەبەر ئەوە یەزدانی پەروەردگاری سوپاسالار، پەروەردگار ئەمە دەفەرموێت: 
\q1 «لە هەموو گۆڕەپانەکاندا شیوەن دەگێڕن و 
\q2 لە هەموو شەقامەکاندا دەڵێن: ”ئای! ئای!“ 
\q1 جوتیارەکان بۆ گریان بانگ دەکەن و 
\q2 ئەوانەی وەستای لاوانەوەشن بۆ شیوەن گێڕان. 
\q1  
\v 17 لە هەموو ڕەزەمێوەکاندا شیوەن دەبێت، 
\q2 چونکە بە ناوەڕاستتدا تێدەپەڕم.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\s1 ڕۆژی یەزدان 
\q1  
\v 18 قوڕبەسەر ئەوانەی تامەزرۆی 
\q2 ڕۆژی یەزدانن!\f + \fr 5:18 \ft ڕۆژی سزادانی گوناهباران و ڕزگارکردنی گەلی خودا.‏\f* 
\q1 بۆچی تامەزرۆی ڕۆژی یەزدانن؟ 
\q2 ئەو ڕۆژە تاریکییە نەک ڕووناکی. 
\q1  
\v 19 وەک پیاوێک لەبەردەم شێر هەڵبێت و 
\q2 تووشی ورچێک بێت، 
\q1 یان بێتە ماڵەوە و دەستی لەسەر دیوارەکە دابنێت و 
\q2 مار پێوەی بدات. 
\q1  
\v 20 ئایا ڕۆژی یەزدان تاریک و بێ ڕووناکی نابێت؟ 
\q2 ئایا ئەنگوستەچاو و بێ تروسکایی نابێت؟ 
\b  
\q1  
\v 21 «ڕقم لە جەژنەکانتان دەبێتەوە و ڕەتیان دەکەمەوە، 
\q2 چێژ لە کۆڕەکانتان نابینم. 
\q1  
\v 22 تەنانەت ئەگەر قوربانی سووتاندنەکان و 
\q2 پێشکەشکراوەکانی دانەوێڵەتان پێشکەش بکەن ڕازی نابم، 
\q2 ئاوڕ لە قوربانی هاوبەشی\f + \fr 5:22 \ft قوربانی هاوبەشی: ئەم قوربانییە هاودەمی قوربانی سووتاندن بوو. تەنها یەک کەس هەڵدەستا بە دابینکردنی ئەم قوربانییە، بەڵام لەگەڵ خەڵکی دیکە بەشی زۆری ئەم قوربانییەیان لەبەردەم خودا دەخوارد وەک هێمایەک بۆ پێکەوە ژیان. بڕوانە \xt لێڤییەکان 7‏:11‏-15.‏\ft ‏\f* نادەمەوە، لە دابەستەکانتان. 
\q1  
\v 23 ژاوەژاوی گۆرانییەکانتانم لێ دووربخەنەوە! 
\q2 گوێ لە ئاوازی سازەکانتان ناگرم. 
\q1  
\v 24 لەبری ئەوە با دادپەروەری وەک زێ بڕوات و 
\q2 ڕاستودروستیش وەک ڕووبارێکی هەمیشەیی. 
\b  
\q1  
\v 25 «ئەی بنەماڵەی ئیسرائیل، ئایا بۆ ماوەی چل ساڵ لە چۆڵەوانی 
\q2 قوربانی سەربڕاو و پێشکەشکراوتان بۆ هێنام؟ 
\q1  
\v 26 بەڵکو نزرگەی پاشای خۆتان، 
\q2 بنکەی بتەکانتان هەڵگرت، 
\q2 پەیکەرەکانتان بۆ کەیوان\f + \fr 5:26 \ft کەیوان ناوی هەسارەیەکە و خوداوەندی ئاشورییەکان بووە.‏\f*، ئەستێرەی خوداوەندەکەتان، 
\q2 کە بۆ خۆتان دروستتان کرد.» 
\q1  
\v 27 لەبەر ئەوە یەزدان کە ناوی خودای سوپاسالارە، دەفەرموێت: 
\q2 «من بۆ شوێنێک ڕاپێچتان دەکەم کە لە دیمەشق دوورترە.» 
\c 6  
\s1 قوڕبەسەر لەخۆڕازییەکان 
\q1  
\v 1 ئەی لەخۆڕازییەکانی سییۆن، 
\q2 ئەی ئەوانەی کە بە ئاسوودەیی لەسەر کێوی سامیرە دەژین، 
\q1 ئەی پیاوماقوڵانی پێشەنگی گەلان 
\q2 کە بنەماڵەی ئیسرائیل دێنە لاتان، قوڕبەسەرتان! 
\q1  
\v 2 بۆ کەلنێ بپەڕنەوە و تەماشا بکەن، 
\q2 لەوێوە بڕۆنە حەماتی گەورە و 
\q2 پاشان بۆ گەتی فەلەستییەکان دابەزن. 
\q1 ئایا دۆخی ئێوە لەم شانشینانە باشترە؟ 
\q2 یان ئایا سنوورەکانیان لە سنوورەکانتان فراوانترە؟ 
\q1  
\v 3 ئێوە ڕۆژی بەڵا بە دوور دەزانن و 
\q2 تەختی ستەم نزیک دەخەنەوە، 
\q1  
\v 4 لەسەر قەرەوێڵەی عاج ڕادەکشێن و 
\q2 لەسەر نوێنەکانتان پاڵدەکەون. 
\q1 ئێوە بەرخی ناو ڕان و 
\q2 جوانەگای قەڵەو دەخۆن. 
\q1  
\v 5 لەگەڵ دەنگی ساز دەنگەدەنگتانە 
\q2 وەک داود ئامێری مۆسیقا بۆ خۆتان دادەهێنن. 
\q1  
\v 6 بە قەڕابە شەراب دەخۆنەوە و 
\q2 بە باشترین زەیت خۆتان چەور دەکەن، 
\q2 بەڵام بۆ وێرانی نەوەی یوسف خەفەت ناخۆن. 
\q1  
\v 7 لەبەر ئەوە ئێستا لە یەکەمی ڕاپێچکراوان دەبن و 
\q2 چوونە داوەت و تەوەزەلیتان کۆتایی دێت. 
\s1 قێزی یەزدان لە شانازی ئیسرائیل 
\p  
\v 8 یەزدانی باڵادەست سوێندی بە گیانی خۆی خواردووە، یەزدانی پەروەردگاری سوپاسالار دەفەرموێت: 
\q1 «من قێزم لە شانازی یاقوب دەبێتەوە و 
\q2 ڕقم لە قەڵاکانییەتی، 
\q2 ئینجا شار و هەموو ئەوەی تێیدایە بەدەستەوەی دەدەم.» 
\p  
\v 9 وای لێدێت، ئەگەر دە کەس لە خانووێکدا بمێننەوە ئەوانیش دەمرن.  
\v 10 ئەگەر خزمێک هات بۆ دەرهێنانی تەرم لە خانووێک بۆ ئەوەی بیسووتێنێت، لە کەسێکی ناو خانووەکە بپرسێت، «ئایا کەسی دیکەت لەگەڵ ماوە؟» ئەو وەڵامی دەداتەوە «کەس نەماوە،» هەروەها دەڵێت: «وسبە، چونکە نابێت ناوی یەزدان بهێنین.» 
\q1  
\v 11 لەبەر ئەوەی یەزدان فەرمان دەدات، 
\q2 لە ماڵی گەورە دەدات و وردوخاشی دەکات، 
\q2 ماڵی بچووکیش پارچەپارچە دەکات. 
\b  
\q1  
\v 12 ئایا ئەسپ لەسەر بەردەڵان ڕادەکات؟ 
\q2 یان کەس لەوێ بە گا کێڵان دەکات؟ 
\q1 بەڵام ئێوە دادپەروەریتان ژەهراوی کرد و 
\q2 بەری ڕاستودروستیشتان کردە زەقنەبووت. 
\q1  
\v 13 ئێوە بە لۆدەڤار دڵخۆشن، 
\q2 دەڵێن: «ئایا بە توانای خۆمان قەرنایممان وەرنەگرت؟» 
\b  
\q1  
\v 14 یەزدانی پەروەردگاری سوپاسالار دەفەرموێت: 
\q2 «ئەی بنەماڵەی ئیسرائیل، ئەوەتا نەتەوەیەکتان لێ ڕاست دەکەمەوە، 
\q1 لە دەروازەی حەماتەوە هەتا شیوی عەراڤا 
\q2 تەنگتان پێهەڵچنن.» 
\c 7  
\s1 شێوەی کوللە و ئاگر و شاووڵێک 
\p  
\v 1 یەزدانی باڵادەست ئاوای پیشان دام، لە سەرەتای سەرهەڵدانی گژوگیا شێوەی کوللەی دەکێشا، گژوگیاکە پاش دروێنەی بەشەکەی پاشایە.  
\v 2 پاش ئەوەی لە خواردنی گژوگیای خاکەکە بووەوە، گوتم: «ئەی یەزدانی باڵادەست، تکایە ببەخشە! یاقوب چۆن هەستێتەوە، چونکە بچووکە!» 
\p  
\v 3 یەزدان لەمە پاشگەز بووەوە و فەرمووی: «ئەمە ڕوونادات.» 
\p  
\v 4 یەزدانی باڵادەست ئاوای پیشان دام: ئەوەتا یەزدانی باڵادەست بۆ دادگاییکردن بە ئاگر بانگەشەی کرد، ئاگرەکە دەریا گەورەکەی ژێر زەوی\f + \fr 7:4 \ft بەپێی بیروباوەڕی خەڵکی ڕۆژهەڵاتی کۆن (دەریای ژێر زەوی) هەبوو کە سەرچاوەی کانیاو و ڕووبارەکان بوو.‏\f* لووشدا، خاکەکەشی خوارد.  
\v 5 ئینجا گوتم: «یەزدانی باڵادەست، تکایە با بەس بێت! یاقوب چۆن هەستێتەوە، چونکە بچووکە!» 
\p  
\v 6 یەزدان لەمە پاشگەز بووەوە. 
\p یەزدانی باڵادەست فەرمووی: «هەروەها ئەمەش ڕوونادات.» 
\b  
\p  
\v 7 ئاوای پیشان دام: پەروەردگار لەسەر دیوارێکی دروستکراو ڕاوەستاوە و شاووڵێکی لەدەست بوو.  
\v 8 یەزدان پێی فەرمووم: «ئامۆس تۆ چی دەبینیت؟» 
\p منیش گوتم: «شاووڵ.» 
\p ئینجا پەروەردگار فەرمووی: «ئەوەتا من شاووڵێک لە ناوەڕاستی ئیسرائیلی گەلمدا دادەنێم، پاش ئەمە چیتر دەستی لێ ناپارێزم! 
\q1  
\v 9 «نزرگەکانی ئیسحاق لەسەر بەرزاییەکان چۆڵ دەبن و 
\q2 پیرۆزگاکانی ئیسرائیل وێران دەبن، 
\q2 بە شمشێرەوە هەڵدەکوتمە سەر ماڵی یارۆڤعام.» 
\s1 ئامۆس و ئەمەسیا 
\p  
\v 10 جا ئەمەسیای کاهینی بێت‌ئێل پەیامی بۆ یارۆڤعامی پاشای ئیسرائیل نارد و گوتی: «ئامۆس لە ناوەڕاستی ماڵی ئیسرائیلدا پیلانی لە دژت گێڕاوە، خاکەکە ناتوانێت بەرگەی هەموو قسەکانی بگرێت،»  
\v 11 چونکە ئامۆس وای گوتووە: 
\q1 «”یارۆڤعام بە شمشێر دەکوژرێت، 
\q2 ئیسرائیل لە خاکەکەی خۆی 
\q2 بێگومان ڕاپێچ دەکرێت.“» 
\p  
\v 12 ئینجا ئەمەسیا بە ئامۆسی گوت: «ئەی پێشبینیکەر، بڕۆ ڕابکە بۆ خاکی یەهودا، لەوێ نان بخۆ و لەوێ پێشبینی بکە.  
\v 13 بەڵام چیتر لە بێت‌ئێل پێشبینی مەکە، چونکە پیرۆزگای پاشایە و پەرستگای پاشایەتییە.» 
\p  
\v 14 ئامۆسیش وەڵامی دایەوە و بە ئەمەسیای گوت: «من پێغەمبەر نەبووم و کوڕی پێغەمبەریش نیم، بەڵکو من گاوانم و باخەوانی دار هەنجیری کێویم.  
\v 15 بەڵام یەزدان لەسەر مێگەلەکەوە هەڵیگرتم، یەزدان پێی فەرمووم: ”بڕۆ پێشبینی بۆ ئیسرائیلی گەلی من بکە.“  
\v 16 ئێستاش گوێ لە فەرمایشتی یەزدان بگرە، تۆ دەڵێیت: 
\q1 «”پێشبینی لەسەر ئیسرائیل مەکە، 
\q2 لێدووان لە دژی بنەماڵەی ئیسحاق مەدە.“ 
\p  
\v 17 «لەبەر ئەوە یەزدان ئەمە دەفەرموێت: 
\q1 «”ژنەکەت لە شاردا لەشفرۆشی دەکات، 
\q2 کوڕ و کچەکانت بە شمشێر دەکوژرێن، 
\q1 زەوییەکەت بە گوریس دابەش دەکرێت، 
\q2 خۆشت لەسەر خاکێکی گڵاودا دەمریت، 
\q1 ئیسرائیلیش لە خاکەکەی خۆی 
\q2 بە دیلی ڕاپێچ دەکرێت.“» 
\c 8  
\s1 سەبەتەیەک میوەی گەییو 
\p  
\v 1 یەزدانی باڵادەست ئاوای پیشان دام، سەبەتەیەک میوەی گەییو.  
\v 2 جا فەرمووی: «ئەی ئامۆس، چی دەبینیت؟» 
\p منیش گوتم: «سەبەتەیەک میوەی گەییو.» 
\p ئینجا یەزدان پێی فەرمووم: «ئیسرائیلی گەلی من گەیشتە کۆتایی. پاش ئەمە چیتر دەستی لێ ناپارێزم! 
\p  
\v 3 «لەو ڕۆژەدا گۆرانییەکانی پەرستگا دەبن بە ناڵین، تەرمەکان زۆرن و لە هەموو شوێنێکدا فڕێدراون، سەراپا کپە!» ئەوە فەرمایشتی یەزدانی باڵادەستە. 
\q1  
\v 4 ئەی ئەوانەی هەناسەبڕکێتانە بەدوای نەدارانەوە، 
\q2 هەتا کۆتایی بە هەژارانی زەوی بهێنن، 
\q2 گوێتان لەمە بێت: 
\p  
\v 5 ئێوە دەڵێن، 
\q1 «کەی جەژنی سەرەمانگ بەسەردەچێت 
\q2 تاکو ئێمە دانەوێڵە بفرۆشین، 
\q1 کەی ڕۆژی شەممە تەواو دەبێت، 
\q2 تاکو گەنم بخەینە بازاڕەوە؟» 
\q1 بۆ ئەوەی پێوانە کەم بکەنەوە و 
\q2 نرخ زیاد بکەن و 
\q2 فێڵ لە تەرازوو بکەن، 
\q1  
\v 6 بۆ ئەوەی هەژاران بە زیو بکڕن و 
\q2 نەداران بە جووتێک پێڵاو و 
\q2 بن بێژنگی گەنم بفرۆشن. 
\p  
\v 7 یەزدان سوێندی بە شانازی یاقوب خوارد: «هەتاهەتایە کردەوەکانیان لەیاد ناکەم. 
\q1  
\v 8 «ئایا لەبەر ئەمە زەوی نالەرزێت و 
\q2 هەموو دانیشتووانەکەی شیوەن ناگێڕن؟ 
\q1 هەموو خاکەکە وەک ڕووباری نیل هەڵدەکشێت، 
\q2 وەک ڕووباری میسر هەڵدەکشێت و دادەکشێتەوە.» 
\p  
\v 9 یەزدانی باڵادەست دەفەرموێت: 
\q1 «جا لە نیوەڕۆی ئەو ڕۆژەدا خۆر ئاوا دەکەم و 
\q2 لە ڕۆژی ڕووناکدا زەوی تاریک دەکەم. 
\q1  
\v 10 جەژنەکانتان دەگۆڕم بە شیوەن و 
\q2 هەموو گۆرانییەکانتان بە لاوانەوە. 
\q1 جلوبەرگی گوش\f + \fr 8:10 \ft لە کاتی ماتەمگێڕان و تۆبەکردندا جلوبەرگی لە گوش دروستکراویان لەبەرکردووە کە ئەزیەتی پێستیانی داوە.‏\f* دەکەمە بەر هەمووتان و 
\q2 قژ بەسەرتانەوە ناهێڵم. 
\q1 دەیکەم بە شیوەنی تاقانە و 
\q2 کۆتاییەکەشی وەک ڕۆژێکی تاڵ.» 
\b  
\q1  
\v 11 یەزدانی باڵادەست دەفەرموێت: «سەردەمێک دێت، 
\q2 قاتوقڕی دەنێرمە سەر خاکەکە، 
\q1 نەک قاتوقڕی بۆ نان و تینووێتی بۆ ئاو، 
\q2 بەڵکو بۆ گوێگرتن لە وشەکانی یەزدان. 
\q1  
\v 12 جا لە دەریایەکەوە بۆ دەریایەک و 
\q2 لە باکوورەوە بۆ ڕۆژهەڵات وێڵ دەبن، 
\q1 بەدوای پەیامی یەزداندا دەگەڕێن، 
\q2 بەڵام نایدۆزنەوە. 
\q1  
\v 13 لەو ڕۆژەدا پاکیزە جوانەکان و کوڕە لاوەکان 
\q2 لە تینووێتیدا دەبوورێنەوە. 
\q1  
\v 14 ئەوانەی سوێند بە تاوانی سامیرە دەخۆن و 
\q2 دەڵێن: ”ئەی دان، سوێند بە خوداوەندەکەت کە زیندووە…“ و 
\q2 ”سوێند بە خوداوەندی بیری شابەع کە زیندووە…“ 
\q1 جا دەکەون و 
\q2 ئیتر هەڵناستنەوە.» 
\c 9  
\s1 ڕووخاندنی ئیسرائیل 
\p  
\v 1 پەروەردگارم بینی لەلای قوربانگاکەوە ڕاوەستابوو و فەرمووی: 
\q1 «لە سەری کۆڵەکەکان بدە 
\q2 هەتا بەردەرگاکان بلەرنەوە، 
\q1 بیانشکێنە بەسەر سەری هەموویاندا و 
\q2 ئەوانەی لێیان ماونەتەوە بە شمشێر دەیانکوژم. 
\q1 کەسیان لێ هەڵنایەت و 
\q2 کەسیشیان لێ دەرباز نابێت. 
\q1  
\v 2 ئەگەر بەرەو جیهانی مردووان هەڵبکۆڵن، 
\q2 لەوێوە دەستم دەیانگرێت؛ 
\q1 ئەگەر بۆ ئاسمانیش سەربکەون، 
\q2 لەوێوە دایاندەگرمە خوارەوە؛ 
\q1  
\v 3 ئەگەر لە لووتکەی کارمەل خۆیان بشارنەوە، 
\q2 لەوێ بە شوێنیاندا دەگەڕێم و دەیانگرم؛ 
\q1 ئەگەر لە بنی دەریا خۆیان لەبەرچاوم بشارنەوە، 
\q2 لەوێ فەرمان بە مار دەدەم و پێیانەوە دەدات. 
\q1  
\v 4 ئەگەر لەپێش دوژمنەکانیانەوە ڕاپێچ کران، 
\q2 لەوێ فەرمان بە شمشێر دەدەم و دەیانکوژێت. 
\b  
\q1 «چاوەکانم دەبڕمە سەریان 
\q2 بۆ خراپە نەک بۆ چاکە.» 
\b  
\q1  
\v 5 یەزدانیش، پەروەردگاری سوپاسالار، 
\q2 ئەوەی دەست لە زەوی دەدات، زەوی دەتوێتەوە و 
\q2 هەموو دانیشتووانەکەی شیوەن دەگێڕن، 
\q1 هەموو خاکەکە وەک ڕووباری نیل هەڵدەکشێت، 
\q2 وەک ڕووباری میسر دادەکشێت. 
\q1  
\v 6 ئەوەی لە ئاسمان کۆشکی خۆی بنیاد دەنێت و 
\q2 لە زەویش بناغەی خۆی دادەمەزرێنێت، 
\q1 ئەوەی بانگی ئاوی دەریا دەکات و 
\q2 بەسەر ڕووی زەویدا دەیڕژێنێت، 
\q2 ناوی یەزدانە. 
\b  
\q1  
\v 7 «ئەی نەوەی ئیسرائیل، 
\q2 ئایا ئێوە بۆ من وەک نەوەی کوشییەکان\f + \fr 9:7 \ft کووش وڵاتێک بووە لە سەرووی ڕووباری نیل.‏\f* نین؟» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\q1 «ئایا ئیسرائیلم لە خاکی میسرەوە نەهێنایە دەرەوە و 
\q2 فەلەستییەکان لە کریتەوە و 
\q2 ئارامییەکان لە قییرەوە؟ 
\b  
\q1  
\v 8 «بە دڵنیاییەوە چاوەکانی یەزدانی باڵادەست 
\q2 لەسەر پاشایەتییە گوناهبارەکەن. 
\q1 لەناوی دەبەم لەسەر ڕووی زەوی، 
\q2 بەڵام بنەماڵەی یاقوب بە تەواوی لەناو نابەم.» 
\q4 ئەوە فەرمایشتی یەزدانە. 
\q1  
\v 9 «من فەرمان دەدەم و 
\q2 لەنێو هەموو نەتەوەکان بنەماڵەی ئیسرائیل لە بێژنگ دەدەم، 
\q1 وەک چۆن بە بێژنگ لە بێژنگ دەدرێت 
\q2 بێ ئەوەی دەنکێک بکەوێتە سەر زەوی. 
\q1  
\v 10 هەموو گوناهبارانی گەلەکەم 
\q2 بە شمشێر دەکوژرێن، 
\q1 هەموو ئەوانەی دەڵێن: 
\q2 ”بەڵا نزیک نابێتەوە و نایەتە ناومان.“ 
\s1 بنیادنانەوەی ئیسرائیل 
\q1  
\v 11 «لەو ڕۆژەدا چادرە ڕووخاوەکەی داود 
\q2 هەڵدەدەمەوە. 
\q1 شوورابەندە شکێنراوەکانی بنیاد دەنێمەوە، 
\q2 ڕووخاوییەکانی دروستدەکەمەوە، 
\q2 وەک ڕۆژانی ڕابردوو بنیادی دەنێمەوە، 
\q1  
\v 12 تاکو ئەوەی دەبنە خاوەنی پاشماوەی نەتەوەی ئەدۆم و 
\q2 هەموو ئەو نەتەوانەی ناوی منیان هەڵگرتووە.» 
\q4 ئەوە فەرمایشتی یەزدانە، ئەوەی ئەم کردارانە ئەنجام دەدات. 
\p  
\v 13 یەزدان دەفەرموێت: 
\q1 «سەردەمێک دێت جوتیار بە سەپان دەگاتەوە و 
\q2 شێلەری ترێش بە چێنەری تۆو. 
\q1 چیاکان خۆشاوی ترێیان لێ دەتکێت و 
\q2 هەموو گردەکانیش لێیان دەچۆڕێتەوە. 
\q1  
\v 14 ڕاپێچکراوانی ئیسرائیلی گەلەکەم دەگەڕێنمەوە. 
\b  
\q1 «شارە کاولکراوەکان بنیاد دەنێنەوە و تێیدا نیشتەجێ دەبن. 
\q2 ڕەزەمێو دەچێنن و شەرابەکەی دەخۆنەوە، 
\q2 باخ دەچێنن و لە بەرەکەی دەخۆن. 
\q1  
\v 15 لە خاکەکەیاندا دەیانچێنم، 
\q2 هەرگیز لەو خاکەی کە پێم داون هەڵناکەنرێن.» 
\q4 یەزدانی پەروەردگارت دەفەرموێت.