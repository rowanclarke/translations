\id PHM
\h فِيلِيمُونْ 
\toc1 فِيلِيمُونْ 
\toc2 فِيلِيمُونْ 
\toc3 فلمن. 
\mt1 فِيلِيمُونْ  
\c 1
\s1 أَسدْجمْ غَارْ ؤُمزْوَارُو ذ ثْژَادْجِيثْ ن ؤُقَاذِي  
\m
\v 1 بُولُوسْ، أَمحْبُوسْ ن يَاسُوع لْمَاسِيحْ، ذ ثَاوْمَاثْ ثِيمُوثِييُو، إِ فِيلِيمُونْ إِعِيزّنْ ونِّي ذ أَمْسخَّارْ أَكِيذْنغْ، \f ◼ \fr 1:‏1 \ft \+bd أَفسَّارْ\+bd* - ثَانِيثَا ذ إِشْثْ ن ثبْرَاثْ إِ يُورِي رَّاسُولْ بُولُوسْ غَارْ ؤُمدُّوكّڒْ نّسْ فِيلِيمُونْ خْ إِجّْ ن ؤُحنْجِيرْ قَّارنْ أَسْ ’ؤُنِيسِيمُوسْ‘. ؤُنِيسِيمُوسْ ثُوغَا-ث قْبڒْ ذ إِسْمغْ ن فِيلِيمُونْ. يَارْوڒْ زِي فِيلِيمُونْ ؤُ أَوَارْنِي مَانْ أَيَا إِسّنْ إِ-ث رَّاسُولْ بُولُوسْ ذِي ڒحْبسْ، ؤُ إِذْوڒْ ؤُنِيسِيمُوسْ ذ ڒْمُومنْ (إِنّغْنِي قَّارنْ أَسْ ’وَانِيسَامُو‘). ؤُڒَا ذ فِيلِيمُونْ ثُوغَا إِذْوڒْ ذ ڒْمُومنْ خْ تّبْشِيرْ ن بُولُوسْ. ڒخُّو رَّاسُولْ بُولُوسْ إِسّكّْ-د ؤُنِيسِيمُوسْ غَارْ فِيلِيمُونْ حِيمَا أَذْ ذِينْ يِيڒِي وصْڒَاحْ جَارْ أَسنْ أَمْ وَاوْمَاثنْ ذِي يَاسُوع لْمَاسِيحْ.\f*  \x ◘ \xo 1:‏1 \xt أَفا. 3‏:‏1؛ 4‏:‏1. \x*  
\v 2 إِ \add ؤُتْشْمَاثْنغْ\add* أَبْفِييَا إِعِيزّنْ، إِ أَرْخِيبُّوسْ، ونِّي ذ أَمْسخَّارْ أَكِيذْنغْ، ؤُ إِ ثْمسْمُونْثْ ذِي ثَادَّارْثْ نّشْ: \x ◘ \xo 1:‏2 \xt رُوم. 16‏:‏5؛ 1 كُور. 16‏:‏19؛ كُول. 4‏:‏15، 17. \x*  
\v 3 أَرْضَا ذ ڒهْنَا أَذْ كِيذْومْ إِڒِينْ زِي أَربِّي، بَابَاثْنغْ، ؤُ \add زِي\add* سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.   
\b  
\m
\v 4 نشّْ تّْقَاذِيغْ أَربِّي إِنُو ڒبْذَا ؤُ تّْفكَّارغْ ذَايكْ ذِي ثْژَادْجِيثِينْ إِنُو، \x ◘ \xo 1:‏4 \xt 1 تس. 1‏:‏2؛ 2 تس. 1‏:‏3. \x*  
\v 5 خْزَارْ، \add عَاذْ\add* زڭْ وَامِي نشّْ سْڒِيغْ خْ لْ-إِيمَانْ ذ ثَايْرِي نّشْ إِ ذَايكْ إِدْجَانْ زِي جِّيهثْ ن سِيذِيثْنغْ يَاسُوع ؤُ زِي جِّيهثْ ن مَارَّا إِمْقدَّاسنْ،  
\v 6 حِيمَا أَذْ ذِينْ يِيڒِي إِجّْ ن ؤُقَارِّي يُودْجْغنْ ن لْ-إِيمَانْ نّشْ أَڒْ غَا ثَاوْيذْ ڒْغِيدْجثْ ذِي ڒخْذَايمْ ؤُ ذِي ثُوسّْنَا ن مَارَّا ڒْخَارْ إِ غَارْومْ ذِي يَاسُوع لْمَاسِيحْ.  
\v 7 مَاغَارْ نشِّينْ أَقَا غَارْنغْ ڒفْرَاحثْ ثَامقّْرَانْثْ ذ ؤُفوّجْ، مِينْزِي زِي سِّيبّثْ ن ثَايْرِي نّشْ تّْوَاسَّاريّْحنْ ؤُڒَاونْ ن إِمْقدَّاسنْ.   
\b  
\m  
\s1 پُولُوسْ إِتّْشفّعْ ذِي ثْمسْڒَاشْثْ ن ؤُنِيسِيمُوسْ  
\m
\v 8 س ؤُينِّي، \add وَاخَّا\add* نشّْ غَارِي ثَارْيَاسْثْ أَطَّاسْ ذِي لْمَاسِيحْ حِيمَا أَذْ شكْ ؤُمُورغْ مِينْ إِشُووَّارنْ،  
\v 9 أَقَا نشّْ غَارِي حْسنْ، ذِي سِّيبّثْ ن ثَايْرِي، أَذْ زَّايكْ تَّارغْ. نشّْ بُولُوسْ، أَقَا أَيِي ذ أَوسَّارْ أَمْ مَامّشْ ثسّْنذْ، ؤُشَا ڒخُّو عَاوذْ ذ أَمحْبُوسْ ن يَاسُوع لْمَاسِيحْ،  
\v 10 نشّْ غَارِي إِشْثْ ن ثُوثْرَا زِي جِّيهثْ ن مِّي ؤُنِيسِيمُوسْ، ونِّي د-جِّيغْ ذِي سّْنَاسڒْ \add ذَا ذِي ڒحْبسْ\add*. \x ◘ \xo 1:‏10 \xt 1 كُور. 4‏:‏15. ڭال. 4‏:‏19؛ كُول. 4‏:‏9. \x*  
\v 11 نتَّا ثُوغَا وَارْ شكْ إِنفّعْ زِيشْ، مَاشَا ڒخُّو أَقَا إِنفّعْ شكْ ذ نّشْ أَطَّاسْ.  
\v 12 نشّْ أَقَا أَرِّيغْ أَشْ ث-إِ-د غَاركْ، مَاشَا قْبڒْ إِ-ث أَمْ مِّي.  
\v 13 مَاغَارْ نشّْ مْڒِي ؤُفِيغْ إِڒِي أَقَا جِّيغْ ث ذَانِيثَا أَكِيذِي مَاحنْذْ أَذْ خَافِي إِسخَّارْ ذڭْ ومْشَانْ نّشْ مِينْ ذَا غَا كّغْ ذِي سّْنَاسڒْ خْ سِّيبّثْ ن لْ-إِنْجِيلْ.  
\v 14 مَاشَا نشّْ وَارْ خْسغْ شَا أَذْ ڭّغْ وَالُو بْڒَا مَا إِ غَا مْشَاوَارغْ أَكِيذكْ، حِيمَا ثْشُونِي إِ ثڭِّيذْ وَارْ ثتِّيڒِي س ؤُغِيڒْ، مَاشَا س ڒْخَاضَارْ.  
\v 15 مِينْزِي نِيشَانْ ثُوغَا إِمّْسبْضَا خَاكْ إِ ذْرُوسْ ن ڒْوقْثْ، حِيمَا أَذْ غَاركْ يِيڒِي عَاوذْ إِ ڒبْذَا،  
\v 16 زِي سَّا ذ ثْسَاونْثْ وَارْ إِدْجِي عَاذْ أَمْ ؤُمْسخَّارْ، مَاشَا أَمْ يِيجّنْ إِ إِدْجَانْ كْثَارْ زڭْ ؤُمْسخَّارْ، أَمْ وُومَا إِعِيزّنْ، \add إِ نشّْ بعْذَا\add*، مَاهُو إِ شكْ، أَمْ ذِي دَّاثْ أَمْ ذِي سِيذِيثْنغْ!   
\m
\v 17 مَاڒَا ثدْجِيذْ ذ أَمْعَاشَارْ أَكِيذِي \add ذِي لْ-إِيمَانْ\add*، قبْڒْ إِ-ث أَمْ ونِّي نّشْ.  
\v 18 مَاڒَا نتَّا ثُوغَا إِضَّارِّي شكْ نِيغْ زعْمَا ذَايسْ أَمَارْوَاسْ، أڭّْ إِ-ث خَافِي!  
\v 19 نشّْ، بُولُوسْ، ؤُرِيغْ س ؤُفُوسْ إِنُو، أَقَا أَذْ ث خدْجْصغْ! مَاحنْذْ وَارْ قَّارغْ شَا، أَقَا ؤُڒَا ذ شكْ ثتُّورْسذْ أَيِي إِخفْ نّشْ.  
\v 20 وَاهْ، \add أَ\add* ثَاوْمَاثْ إِنُو، أَقَا تّْوَاسَّاريّْحغْ زَّايكْ ذِي سِيذِيثْنغْ، سَاريّحْ ثَايْرِي إِنُو ذِي لْمَاسِيحْ.   
\b  
\m  
\s1 أَوَاڒْ غَارْ ؤُنڭَّارُو ذ ؤُسدْجمْ  
\m
\v 21 نشّْ تِّيقّغْ أَذْ أَيِي ثسْڒِيذْ. ؤُرِيغْ أَشْ-د، ؤُشَا سّْنغْ أَقَا شكْ أَذْ ثڭّذْ مَاهُو مِينْ ذ \add أَشْ\add* إِنِيغْ.  
\v 22 سوْجذْ أَيِي أَمْشَانْ مَانِي غَا سّنْسغْ، مِينْزِي سِّيثِيمغْ أَذْ غَارْومْ د-أَرزْفغْ س ثْژَادْجِيثْ نْومْ. \x ◘ \xo 1:‏22 \xt فِيل. 1‏:‏25. \x*   
\m
\v 23 إِبَافْرَاسْ، ونِّي أَكِيذِي ذَا ذِي ڒحْبسْ ذِي يَاسُوع لْمَاسِيحْ، أَقَا إِسدْجمْ خَاكْ س ڒهْنَا، \x ◘ \xo 1:‏23 \xt كُول. 1‏:‏7؛ 4‏:‏12. \x*  
\v 24 ؤُڒَا ذ مَارْكُوسْ ذ أَرِيسْثَارْخُوسْ ذ ذِيمَاسْ ذ لُوكَا إِنِّي ذ أَيِي إِتِّيشنْ أَفُوسْ. \x ◘ \xo 1:‏24 \xt ڒخ. 12‏:‏12، 25؛ 15‏:‏37؛ كُول. 4‏:‏10؛ 2 تِيم. 4‏:‏11؛ 1 بُط. 5‏:‏13؛ ڒخ. 19‏:‏29؛ 20‏:‏4؛ 27‏:‏2؛ كُول. 4‏:‏10، 14؛ 2 تِيم. 4‏:‏10، 11. \x*   
\m
\v 25 أَرْضَا ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ أَذْ يِيڒِي أَكْ-ذ بُوحْبڒْ نْومْ. أَمِينْ!   