\v 19 \w And|strong="H6213"\w* \w if|strong="H3588"\w* \w one|strong="H3588"\w* person \w injures|strong="H5414"\w* \w another|strong="H5997"\w* person, \w the|strong="H3588"\w* \w injured|strong="H5414"\w* person \w is|strong="H3651"\w* \w allowed|strong="H5414"\w* \w to|strong="H6213"\w* injure \w the|strong="H3588"\w* person \w who|strong="H3588"\w* \w injured|strong="H5414"\w* \w him|strong="H5414"\w* \w in|strong="H6213"\w* \w the|strong="H3588"\w* \w same|strong="H3651"\w* \w way|strong="H3651"\w*:
