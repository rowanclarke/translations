\m
\v 1 \w Now|strong="G1161"\w* \w after|strong="G1161"\w* \w Jesus|strong="G2424"\w* \w was|strong="G3588"\w* \w born|strong="G1080"\w* \w in|strong="G1722"\w* Bethlehem \w of|strong="G2250"\w* \w Judea|strong="G2449"\w*, \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w days|strong="G2250"\w* \w of|strong="G2250"\w* \w Herod|strong="G2264"\w* \w the|strong="G1722"\w* \w king|strong="G3588"\w*, \w behold|strong="G2400"\w*, \w wise|strong="G3854"\w* \w men|strong="G3097"\w* [\it magi\it*] \w from|strong="G3588"\w* \w the|strong="G1722"\w* East \w came|strong="G3854"\w* \w into|strong="G1519"\w* \w Jerusalem|strong="G2414"\w*,  
\v 2 \w saying|strong="G3004"\w*: “\w Where|strong="G4226"\w* \w is|strong="G1510"\w* \w he|strong="G2532"\w* \w who|strong="G3588"\w* \w has|strong="G3708"\w* \w been|strong="G1510"\w* \w born|strong="G5088"\w* \w King|strong="G3588"\w* \w of|strong="G2532"\w* \w the|strong="G1722"\w* \w Jews|strong="G2453"\w*? \w For|strong="G1063"\w* \w we|strong="G1063"\w* \w saw|strong="G3708"\w* \w his|strong="G1722"\w* star \w in|strong="G1722"\w* \w the|strong="G1722"\w* East \w and|strong="G2532"\w* \w have|strong="G2532"\w* \w come|strong="G2064"\w* \w to|strong="G2532"\w* \w worship|strong="G4352"\w* \w him|strong="G3588"\w*.”  
\v 3 \w When|strong="G1161"\w* \w Herod|strong="G2264"\w* \w the|strong="G2532"\w* \w king|strong="G3588"\w* heard \w it|strong="G2532"\w* \w he|strong="G2532"\w* \w became|strong="G3588"\w* agitated, \w and|strong="G2532"\w* \w all|strong="G3956"\w* \w Jerusalem|strong="G2414"\w* \w with|strong="G3326"\w* \w him|strong="G3588"\w*.  
\v 4 \w And|strong="G2532"\w* \w gathering|strong="G4863"\w* \w all|strong="G3956"\w* \w the|strong="G2532"\w* \w chief|strong="G2532"\w* priests \w and|strong="G2532"\w* \w scribes|strong="G1122"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w people|strong="G2992"\w*, \w he|strong="G2532"\w* \w inquired|strong="G4441"\w* \w of|strong="G2532"\w* \w them|strong="G3588"\w* \w where|strong="G4226"\w* \w the|strong="G2532"\w* \w Christ|strong="G5547"\w* \w was|strong="G3588"\w* \w to|strong="G2532"\w* \w be|strong="G2532"\w* \w born|strong="G1080"\w*.\f + \fr 2:4 \ft The magi said, “King of the Jews”; Herod said, “Messiah”. Evidently he knew something about OT prophecy.\f*  
\v 5 \w So|strong="G3779"\w* \w they|strong="G1161"\w* \w said|strong="G3004"\w* \w to|strong="G3004"\w* \w him|strong="G3588"\w*: “\w In|strong="G1722"\w* Bethlehem \w of|strong="G1223"\w* \w Judea|strong="G2449"\w*, \w for|strong="G1063"\w* \w thus|strong="G3779"\w* \w it|strong="G1161"\w* stands \w written|strong="G1125"\w* \w by|strong="G1223"\w* \w the|strong="G1722"\w* \w prophet|strong="G4396"\w*:   
