\id ROM - IKWERRE
\h Ele Rom
\toc1 Ọkwukwo izi Pọlu gbaznennu Ele Rom
\toc2 Ele Rom
\toc3 Rom
\mt2 Ọkwukwo izi Pọlu
\mt2 gbaznennu
\mt1 Ele Rom
\imt1 Nhne gbasịri ọkwukwo izi ka
\im \bk Ọkwukwo izi Pọlu gbaznennu ele Rom\bk* bụ ma be jiknernu ọ nabnanya Pọlu nụ Rom. Echiche a bụ ma ọ rnụ ẹrnu n'esilawụru be ige matị, hite n'oyi aka be, o zne Sipeni. Ọkwukwo izi ele Rom neegesi kpa Chiokike nọogwnu ele badnụ ele ikpe mána, mee ya nụ be zịri n'udno. Chiokike mernu ele badnụ nụ a zịri n'udno hite n'ọkwnata mkpọma ke zị nụ Jizọsi Karaịsi. Nye Karaịsi ọbula nwernu udno kwnornu nụ Chiokike mernu badnụ nwernu ẹhni a, whọga nụ rikne ke mmehie nụ ẹnwu. Pọlu kwuru nụ ele Ju nụ ele bụ́o ele Ju nwernu igwe n'oru Chiokike hite nụ Jizọsi Karaịsi.
\iot Nhne zị n'ọkwukwo ka
\io1 Ọpanizo \ior (1:1-17) \ior*
\io1 Ọznohia hite nụ mmehie zị mkpa \ior (1:18---3:20) \ior*
\io1 Apna Chiokike kwnornu ọznohia \ior (3:21---4:25) \ior*
\io1 Bụdnu ikne nụ rime Karaịsi \ior (5:1---8:39) \ior*
\io1 Izirẹli zị nụ mmụma Chiokike \ior (9:1---11:36) \ior*
\io1 Agwa nye Karaịsi \ior (12:1---15:13) \ior*
\io1 Okwukwo nụ obekwu ikwu \ior (15:14---16:27) \ior*
\c 1
\p 
\v 1 Mawa Pọlu, nye izi Karaịsi Jizọsi, nye Chiokike sukwuru, ma m bụru m nye izi Jizọsi, họhia masị a ma m bụru m nye zni izi ọma a, naagba ọkwukwo izi ka.
\v 2 Ka bụ izi ọma Chiokike kweru mkwna ogologo ige wheru ewhe hite n'ọnu ele ọwhnurninya, lele kpa be gbarụ a n'ọkwukwo nsọ.
\v 3 Izi ọma ka gbasịri Nnwọ a, Nyenwe aị Jizọsi Karaịsi, nye ghọru badnụ, be mụ a n'avnụrnu Devidi.
\v 4 Chiokike gesiri nụ Jizọsi Karaịsi bụ Nnwọ a, nga o mernu o hi n'ẹnwu lizọ hite nụ rikne ke Enine Nsọ.
\v 5 Hite n'aka a, Chiokike nyernu aị oru ọ bụru ele izi kwnornu Karaịsi, ma a sukwu kpakara mba ma be kweru nụ ya, bno a masị nsnị.
\v 6 Kpakara anụ ele zị nụ Rom, zị n'esilawụru ele Chiokike sukwuru ma be bụru ke Jizọsi Karaịsi.
\v 7 M naagbanụ anụ ele zị nụ Rom ọkwukwo, ele Chiokike whnụrnu n'anya, sukwu ma be bụru ele ke a,
\p Oru nụ udno ke Chiokike Nda aị nụ Nyenwe aị Jizọsi Karaịsi dazịnu anụ.
\s1 Okpukpe ọtu mmamma
\p 
\v 8 Ke mbọm, m nọotunu Chiokike mmamma hite nụ Jizọsi Karaịsi kwnornu anụ, nụ ọkwnata mkpọma anụ gazuru ọwa.
\v 9 Chiokike, nye me ji kpakara mkpọma m naakwanụ, hite n'ọkpo okwo izi ọma Nnwọ a, bụ nye akebne m, nụ m neechenwanya anụ ige ọbula.
\v 10 Ige ọbula me neekpe okpukpe, m nọorio Chiokike ma hite n'echiche ọma a, o nyee m oghere me va lekasi anụ.
\p 
\v 11 Kwnornu nụ m pioru m ọ whnụ anụ anya ma me nụ anụ keri ngọzi ke enine, ke jeeme anụ gwuzosi rikne.
\v 12 Ke bụ me va, a kasirita ẹhni aị ovu, ọkwnata ovu m jaakasi anụ ovu, ọkwnata anụ jaakasi m ovu.
\v 13 Rụmu nda m, m pioru anụ mahịa nụ agịda ige, m pioru m ọ va lekasi anụ, kọvu m nwée m rikne dụ kịtna. M pioru m o rihịa mkpụru ovu n'esilawụru anụ lele kpa me rihịaru mkpụru ovu n'esilawụru ele bụ́o ele Ju.
\v 14 Kwnornu nụ m ji m kpakara ele badnụ ọgwo ọkpo okwo izi ọma, ma ele Giriki, ma ele bụ́o ele Giriki, ele nwernu akọ, ma ele nwée akọ.
\v 15 Ke bụ nụ ọ zị m mkpa o zni anụ ele zị nụ Rom izi ọma.
\s1 Iknernema ke izi ọma
\p 
\v 16 Iwhnerne izi ọma ka zá nọotu m, ọ bụ rikne Chiokike dụ ọznohia kpakara ele kweru, ele Ju ke mbọm, nụ ele bụ́o ele Ju.
\v 17 Kwnornu nụ ome mma ke Chiokike whụyaru iwhne n'izi ọma, hite n'ọkwnata ovu dụ ọkwnata ovu, lele kpa be gbarụ a n'ọkwukwo nsọ, “Nye mee mma jeehi nụ ọkwnata ovu a zịri bụdnu.”
\s1 Ọnuma Chiokike // megidne badnụ
\p 
\v 18 Kwnornu nụ ovu owe ẹhni Chiokike hiri n'oligwe whụya iwhne megidne kpakara ele máa Chiokike, ele hi nụ risi rikne arụru-ẹli be naakpagidne ezi ọka.
\v 19 Chiokike neewe ẹhni megidne be, kwnornu nụ nhne be kwesiri ọ mahịa gbasịri Chiokike whụyaru iwhne. Ọ bụ Chiokike n'iwhuru a gesiri be ẹhni a.
\v 20 Hite n'okike ọwa, nhne be whnụ́ anya gbasịri Chiokike, nụ rikne a zị ọkwnukokwnu, nụ oyiyi a zị nsọ bụ ke badnụ whnụrnu anya, be whnụrnu be nụ kpakara nhne Chiokike keru, ke bụ nụ badnụ nwée nhne o ji gọnahoru ẹhni a.
\p 
\v 21 Be marnụ Chiokike, kọvu be nyéne a igwugwu kwesiri a, be tụ́ mmamma, kọvu echiche be bụ nhne etekne, mkpọma iwhnirniwhno be jihịaru n'ọchichiri.
\v 22 Be kaa nụ be bụ ele nwernu akọniche, be bụ ele iwhnirniwhno.
\v 23 Tnụnuma be jaakwanụ Chiokike ke nwụ́ ọnwu, be nọokpo risi ẹli nyee nhne be pnịornu ọpnio lele badnụ ke nọonwu ọnwu, nụ ọnunu, nụ anọhia nụ agwọ.
\p 
\v 24 Chiokike gweru be nyewhete n'aka nhne zị́la rịchna hite nụ ome nhne ovu ọjo be pioru, be gweru ẹhni be mee nhne tụ iwhnerne n'esilawụru ẹhni be.
\v 25 Be gweru aghalaghala gbanwo ezi ọka Chiokike, be nọokpo risi ẹli nyee nhne be keru eke tnụnuma nye keru nhne n'iwhuru a, nye nwe ọznarni ọkwnukokwnu. Amịm.
\p 
\v 26 Kam kpayarụ, Chiokike nyernu be n'aka ome nhne tụ iwhnerne. Ele rinya gharụ o mee nhne lele kpa omen'ẹli omekọrita nyerukna nụ nyerinya zị, be be neemekọrita.
\v 27 Kpam masị, ele rukna sịgbasiri ọ dnanyị ele rinya, be naadnanyịtaru ẹhni be. Be neeme nhne tụ iwhnerne n'esilawụru be, be naata awhnụwhnu nhne ọjo be mernu.
\p 
\v 28 Kpa be kwéle ọ marnụ Chiokike nụ mkpọma be, Chiokike nyewhete be n'aka ovu rụru ọru, ma be mee nhne be kwésile o mee.
\v 29 Arụru-ẹli zị ọdo nụ ọdo jihịaru mkpọma be, mmehie, ọwho-anya, okne nhne ọjo, ntaknarnama ovu, ogbu badnụ, ọlu ọgwnu, aghịgho, nụ osno irno, ozno izno.
\v 30 Ele naakaja ẹhni be, be snornu Chiokike irno, ele sọ́ anya, ele noolu ọnu, ele neechehịa apna ikne kpa be jeeme nhne ọjo, ele zá noobnonu ele mụrnu be nsnị,
\v 31 ele nwée ọghohia, ele zá naabịta ọgba-njọ-ẹhni, ele nwée ovu ọma, ele zá nọodonu ele berere obirizi.
\v 32 Be magwụ nụ iwu Chiokike kwuru nụ ele neeme nhne ọjo ka jọonwu ẹnwu, ọ bụ́o nụ be neeme nhne ele ka kpọi, kọvu be naadasịnu ele neeme nhne ele ka n'ikwnu.
\c 2
\s1 Ikpe zị snam ke Chiokike
\p 
\v 1 Jị badnụ, i nwée rikne gọnahoru ẹhni ị, jị nye neekpe nye berere ikpe, kwnornu nụ hne ị zị neekpe nye berere ikpe bụ hne ikpe zị naama ị, kwnornu nụ i neeme otu nhne wam.
\v 2 A magwụ nụ Chiokike neekpe ikpe zị snam nụ risi ele neeme kpakara nhne ka.
\v 3 Jị badnụ etekne ke neeme nhne ke i kwno neekpe ele berere ikpe, i che nụ i jaagbanahọru ikpe Chiokike sa?
\v 4 Mọbu i neeledna okne ovu ọma Chiokike anya, nụ ọnabnanya a, nụ ogologo ọsnuta ovu a? N'ezi, Chiokike neemenu i nhne ọma ka ma o dubna ị nụ ọtuhnasna ovu.
\v 5 Kọvu hite nụ ovu rikne nụ ovu kwé ọbniaji ị, ị naabịtanu ẹhni ị awhnụwhnu ke kakwo n'ọbochi ovu owe ẹhni Chiokike nụ okpume ikpe a zị snam.
\v 6 Chiokike jọokwu nye ọbula ọgwo lele kpa ẹrnu a jiri zị.
\v 7 Ele gwuzosi rikne neeme nhne ọma, noopio igwugwu nụ ọsobisi, nụ nkọli bụdnu, Chiokike jeenye be bụdnu kwó okwo.
\v 8 Kọvu, ele noopio nhne ke aka be, ele kwéle ezi ọka, ele noosno nhne ọjo, Chiokike jọowukwasi be ovu owe ẹhni a nụ ọnuma a.
\v 9 Okne awhnụwhnu nụ nhne igbugbu jaazịnu kpakara ele neeme nhne ọjo, ke mbọm ele Ju, ma ele bụ́o ele Ju.
\v 10 Kọvu igwugwu, ọsobisinu nụ udno jaazịnu nye ọbula neeme nhne ọma, ke mbọm ele Ju, nụ ele bụ́o ele Ju.
\v 11 Kwnornu nụ Chiokike zá neele badnụ anya nụ ruwhnu.
\p 
\v 12 Kpakara ele mernu mmehie hne be nwée Iwu Mozizi jọonwu hne Iwu zị́la, ele mehieru hne Iwu zị, Iwu jeekpe be ikpe.
\v 13 Ọ bụ́o ele nọonu Iwu bụ ele zị snam nụ ruwhnu Chiokike, kọvu ele neeme nhne Iwu kwuru.
\v 14 Nga ele bụ́o ele Ju ele nwée Iwu hiri n'ovu be mee nhne Iwu kwuru, kam bụnu be Iwu, ọ bụ n'ezi nụ be nwée Iwu.
\v 15 Bụdnu be neegesi nụ be gbagwụ Iwu n'ovu be, ovu be naagbanụ be akebne, noobno be nhne, mọbu nọogomanu be.
\v 16 Ka jọobu n'ọbochi Chiokike jeekpe nhne tugwaru otugwa ke badnụ ikpe, hite n'aka Karaịsi Jizọsi lele kpa izi ọma me neezni kwuru.
\s1 Ele Ju nụ Iwu
\p 
\v 17 I noosukwu ẹhni ị nye Ju, nọotukwasi ovu n'Iwu, neeji Chiokike naanya risi.
\v 18 Ị magwụ echiche a, i nahọru nhne ke kakwo mma, kwnornu nụ ị mụhiaru a n'iwu.
\v 19 Ị kwnatarụ ovu nụ i bụ nye noodu nye isni, iwhne ele zị n'ọchichiri,
\v 20 nye neezni ele iwhnirniwhno nhne, nye neezni rụmu takịri nhne, nye nwegwu akọniche zuru ozu, nụ ezi ọka.
\v 21 Jị nye neezni ele berere nhne, i zní ẹhni i nhne sa? I neezni ọ zá nye znu buznu, jị n'iwhuru i znú buznu sa?
\v 22 Ị kaa, “Ọ zá nye mee ọyi,” jịwa, i mée ọyi sa? I snornu chi berere irno, kọvu i znú buznu nụ ruwhnu rẹnwu?
\v 23 Jị nye ji iwu Chiokike noolu ọnu, ọ bụ ị zá neeme Chiokike nhne iwhnerne hite n'olulu iwu a?
\v 24 Lele kpa be gbarụ a n'ọkwukwo nsọ, “Ele bụ́o ele Ju naakaja rẹwhna Chiokike kwnornu anụ ele Ju.”
\p 
\v 25 Ọ bụru nụ ị bịta iwu, ọkpa nka ị bụ nhne, kọvu ọ bụru nụ ị bị́tage iwu, ọkpa nka ị bụ nhne etekne.
\v 26 Ọ bụru nụ ele bụ́o ele Ju be kpáge nka, bịta Iwu, be jeegweru be lele ele be kparụ nka.
\v 27 Nye be kpáge nka n'anọ-ẹhni kọvu ọ bịtaru Iwu jaama ị ikpe, jị nye nwegwu Iwu be gbarụ n'ọkwukwo nụ nye be kparụ nka, kọvu ị zá naabịta Iwu.
\v 28 Badnụ bụ́o nye Ju n'anọ-ẹhni kpọi, ọkpa nka bụ́o masị ke anọ-ẹhni kpọi.
\v 29 Nye Ju n'ezi bụ nye Ju n'ovu. Ọkpa nka bụ ke be kparụ n'ovu hite n'enine Chiokike, ọ bụ́o n'Iwu be gbarụ n'ọkwukwo. Ọznarni badnụ wam híge n'aka badnụ, kọvu n'aka Chiokike.
\c 3
\s1 Chiokike kwesiri // ọ kwnata ovu
\p 
\v 1 Kịni bụ nhne ele Ju nwernu kakwo ele bụ́o ele Ju? Ọ zị mbnarna zị nụ ọkpa nka?
\v 2 Owe! K'agịda n'apna ọbula. Ke mbọm, Chiokike nyernu ele Ju ikwu-ọnu a.
\v 3 Ọ bụru nụ agwna be nwée ọkwnata ovu? O jeeme Chiokike bụru nye kwésile ọ tụkwasi ovu?
\v 4 Ọ́za rịa rịa! Chiokike jọoburiri nye ezi ọka, ọ bụbedi nụ kpakara badnụ jọoburu ele aghalaghala. Lele kpa ọkwukwo nsọ kwuru,
\q1 “Ma i gesi nụ ị bụ nye nookwu ezi ọka,
\q2 Ikpe jáama ị nga be neekpe i ikpe.”
\p 
\v 5 Ọ bụru nụ a mernu nhne bụ́o ọma, ke jeegesi ome mma Chiokike ke zị snam, kịni bụ nhne a jookwu? Nụ Chiokike mernu nhne ọjo nụ ọ ta aị awhnụwhnu nụ ovu owe ẹhni sa? (M nookwu lele badnụ etekne.)
\v 6 Ọ́za rịa rịa! Ọ bụru nụ Chiokike bụ́o nye mee mma, ndaa kpa o jeeji kpe ọwa ikpe?
\v 7 Ọ bụru nụ aghalaghala m jeenye Chiokike igwugwu hite nụ ome ezi ọka a whụya iwhne, ndaa kpa be jaama m ikpe lele nye mmehie?
\v 8 Ọ bụru nụ anụ neeche kpam, anụ jaakaa, “Ngwa ma a mee nhne ọjo ma nhne bụru ọma va”? Agwna ele badnụ nyernu m mkparị, noobno m nụ ka bụ nhne me neezni ele badnụ. Be jaama be ikpe lele kpa o kwesiri.
\s1 Nye mee mma zá
\p 
\v 9 Ndaa, a ka ele bụ́o ele Ju mma? Ọ́za rịa rịa. M karụ m nụ ele Ju ma ele bụ́o ele Ju n'otu zị nụ mkpururu mmehie.
\v 10 Lele kpa ọkwukwo nsọ kwuru,
\q1 “Ọ zá nye bụ nye mee mma, ọ bụbedi otu.
\q2 
\v 11 Ọ zá nye nwernu akọniche,
\q2 ọ zá nye noopio Chiokike.
\q1 
\v 12 Kpakara ele badnụ dasịnnu Chiokike aznụ,
\q1 ọ zá iru be bnarnụ,
\q2 ọ zá nye neeme nhne ọma
\q2 ọ bụbedi otu.
\q2 
\v 13 Ọnu be nụ lele ilili gberu anya,
\q1 riro be nookwu ọka aghịgho,
\q2 ọka ọjo lele njulu agwọ neehi nụ mgbele-ọnu be whụya.
\q1 
\v 14 Ọvu ọnu nụ okne ọnu ọjo jihịaru be nụ mkpọma.
\q2 
\v 15 Ọchi be zị snarna snarna n'ọwusa ọvnarna.
\q1 
\v 16 Olulu nhne nụ nhne anya-mini noosno be n'apna be.
\q1 
\v 17 Be máa apna udno.
\q2 
\v 18 Ogwnu Chiokike zá be n'anya.”
\p 
\v 19 Kịtna a magwụ nụ kpakara nhne Iwu kwuru zịnu ele zị nụ mkpururu Iwu, ma be kpusni kpakara ọnu ele badnụ, ma kpakara ọwa bna n'ikpe Chiokike.
\v 20 Kwnornu nụ ọ zá nye mee mma n'anya Chiokike hite nụ ome nhne Iwu kwuru, kọvu Iwu neeme ele badnụ mahịa nụ be mehieru.
\s1 Ome mma hite // n'ọkwnata mkpọma
\p 
\v 21 Kọvu ome mma Chiokike whụyaru iwhne hne Iwu zị́la, ọ bụ ezi ọka nụ Iwu nụ ele ọwhnurninya naagbanụ a akebne.
\v 22 Ome mma Chiokike ka hiri n'ọkwnata ovu nụ Jizọsi Karaịsi zịnu kpakara ele kwehịaru, kwnornu nụ ọkpa ike zị́la nụ rime a rịa rịa.
\v 23 Kwnornu nụ kpakara ele badnụ mehieru, be nwée rikne dụ igwugwu Chiokike.
\v 24 Kọvu nkesi ke oru Chiokike mernu kpakara badnụ bụru ele ikpe mámana hite n'ọgbahia aị ke hi n'aka Karaịsi Jizọsi.
\v 25 Chiokike nyernu a lele nkesi ọwhaji-ẹli hite n'ọkwnata ovu, ka bụ ma Chiokike gesi ome mma a. N'ige wheru ewhe Chiokike jiri ogologo ọsnuta ovu lewhuru mmehie ke badnụ anya.
\v 26 O mernu kam ma o gesi ikpe a zị snam n'ige ka, ma ọ bụru nye mee mma nga ọ neegweru badnụ lele nye ikpe mámana hite n'ọkwnata ovu nụ Jizọsi.
\p 
\v 27 Ọ bụru kpam, ndaa hne mpako zị? Ọ zị́la! Kịni kpayarụ a? Ọ bụ nụ hite n'ọbita nhne Iwu kwuru? Ọ́za! Kọvu a kwnatarụ ovu.
\v 28 A nookwusi a rikne nụ be neegweru badnụ lele nye ikpe mámana hite n'ọkwnata ovu, ọ bụ́o hite n'ẹrnu ke Iwu.
\v 29 Chiokike, ọ bụ Chiokike ke ele Ju kpọi? Ọ bụ́o Chiokike ke ele bụ́o ele Ju sa? Owe! Ọ bụ ya.
\v 30 Hne ọ bụ otu Chiokike, ọ jọogwnu ele be kparụ nka lele ele ikpe mámana hite n'ọkwnata ovu be, nụ ele be kpála nka hite n'ọkwnata ovu be.
\v 31 A jaakaa nụ ka neegesi n'Iwu bnáge nụ nhne hite n'ọkwnata ovu ka? Ọ́za rịa rịa, kọvu a neeme Iwu gwuzosi rikne.
\c 4
\s1 Ọkwnata ovu Ebereham
\p 
\v 1 Ndaa nhne a jaakaa gbasịri Ebereham nda aị? Kịni bụ nhne o piohịaru?
\v 2 Ọ bụru nụ be hiri n'ẹrnu Ebereham gwnụsi a nụ nye mee mma, o znernu anyaa risi nụ ka. Kọvu o nwée rikne mee oknomokno nụ ruwhnu Chiokike.
\v 3 Ọkwukwo nsọ kwuru kịni? “Ebereham kweruru Chiokike, Chiokike gwnụsinu a nụ ọ bụ nye mee mma.”
\v 4 Nye be kwụru ọgwo ẹrnu a, ọgwo ẹrnu a bụ́la nkesi, kọvu nhne ọ rnụhiaru n'ẹrnu.
\v 5 Kọvu nye rnụ́ge ẹrnu, ke kwnatarụ Chiokike, nye nọogwnu ele ọjo lele ele ikpe mána ovu, Chiokike ji ọkwnata ovu a gwnụ a nye mee mma.
\v 6 Ka bụ nhne Devidi kwuru gbasịri nye ọwa ọma, nye Chiokike híge n'ẹrnu a gwnụ nụ nye mee mma,
\q1 
\v 7 “Nye ọwa ọma bụ nye Chiokike gbarụnu mmehie,
\q2 nye be kpusnirni arụru-ẹli a.
\q1 
\v 8 Nye ọwa ọma bụ nye Chiokike zá nọogwnu mmehie a megidne a.”
\p 
\v 9 Ngọzi ka, ọ zịnu ele be kparụ nka kpọi sa? Ọ́za, ma ele be kpála nka. Kwnornu nụ a karụ nụ Ebereham kweruru Chiokike, Chiokike gwnụsinu a nụ ọ bụ nye mee mma.
\v 10 Ndaa hne nhne ka mernu? Ọ nga be kparụ a nka, sụ ọ bụ nga be kpála a nka? Ọ bụ nga be kpála nka.
\v 11 Be kparụ a nka ma ọ bụru nhne elekema ke ome mma nụ ọ kwnatarụ Chiokike ovu nga be kpála a nka, ma ọ bụru nda kpakara ele kweru, ma be gwnụsi be n'ele mee mma, ọ bụ n'ezi nụ be kpála be nka.
\v 12 Ọ bụ masị nda ele be kparụ nka, ọ bụ́la nụ be kparụ be nka kpọi, kọvu nụ be noowu bụdnu ọkwnata ovu lele nda aị Ebereham wuru sụ be kparụ a nka.
\s1 Mkwna Chiokike
\p 
\v 13 Mkwna Chiokike kweru Ebereham nụ avnụrnu a nụ be jeekehịa ọwa bụ́o hite n'ọbita Iwu, kọvu ome mma ke hiri n'ọkwnata.
\v 14 Ọ bụru nụ ele zị nụ mkpururu Iwu jeekehịa mkwna wam, ọkwnata ovu bụ nhne etekne, mkwna Chiokike kweru bnána iru.
\v 15 Iwu neegweya ovu owe ẹhni Chiokike. Hne Iwu zị́la, ọ zá nye jaadna Iwu.
\p 
\v 16 Mkwna wam hiri n'ọkwnata mkpọma. O mernu o hite n'oru gwuzoru kwem nụ rime kpakara rụmu Ebereham. Ọ bụ́o ele zị n'Iwu kpọi, kọvu ma ele sno ọkwnata ovu Ebereham, kwnornu nụ ọ bụ nda kpakara aị.
\v 17 Lele kpa be gbarụ a n'ọkwukwo nsọ, “M mernu m jị nda agịda mba.” Ọ bụ nda aị n'anya Chiokike, nye ọ kwnatarụ ovu, Chiokike ke naakpatne nye nwụrnu ọnwu, nye neeme nhne zị́gele a whụya iwhne.
\p 
\v 18 Nga olile anya zị́la a, Ebereham kwnatarụ ovu, ọ bụru nda agịda mba, lele kpa ọkwukwo nsọ kwuru, “Mkpụru ị jaazị agịda kpa.”
\v 19 Ọkwnata ovu a dnáge adna, nga ọ whnụrnu nụ anọ-ẹhni a bụ nhne nwụrnu ọnwu, hne ọ bụ otu riwhu awha, nụ rẹkpa-nnwọ Sera nwụrnu ọnwu.
\v 20 Kọvu ọkwnata ovu a dnáge adna hite nụ ókwe ekwe mọbu onwe mkpọma lawụru gbasịri nhne Chiokike kweru a mkwna, ọkwnata ovu a mernu o gwuzosi rikne naaznarnị Chiokike.
\v 21 Ovu siri a rikne nụ Chiokike nwernu rikne o mezu nhne o kweru mkwna.
\v 22 Kam kpayarụ, “Chiokike gwnụsinu a nụ ọ bụ nye mee mma.”
\v 23 Nụ be gwnụsiri a nụ nye mee mma, bụ́o nhne ke zịnu a kpọi.
\v 24 Ọ zị masịnu aị ele be jọogwnusi n'ele mee mma, ele kweru nụ nye wam mernu Jizọsi Nyenwe aị hi n'ẹnwu lizọ.
\v 25 Be nyernu a ma ọ nwụ kwnornu mmehie aị, o hiri n'ẹnwu lizọ ma Chiokike gwnụsi aị lele ele ikpe mámana.
\c 5
\s1 Snarnịma nụ udno
\p 
\v 1 Kịtna, hne Chiokike gwnụrnu aị lele ele ikpe mána hite n'ọkwnata ovu, a nwernu udno nụ Chiokike hite n'aka Nyenwe aị Jizọsi Karaịsi.
\v 2 Jizọsi bụ nye a hiri n'aka a, hite n'ọkwnata ovu gwuzoru n'oru Chiokike. A nọonwudna ọnwudna nụ a nwernu olile anya nụ a jeekehịa igwugwu Chiokike.
\v 3 Ọ bụ́o kam kpọi, a nọonwudna nụ rime awhnụwhnu, kwnornu nụ awhnụwhnu neegweya ọsnuta ovu,
\v 4 ọsnuta ovu neegweya agwa ọma, agwa ọma gweya olile anya.
\v 5 Olile anya aị jọ́obu nhne etekne, kwnornu nụ Chiokike wụkwasiri aị ọwhnun'anya a n'ovu aị hite n'Enine Nsọ, ke o kesiri aị.
\p 
\v 6 Kwnornu nụ nga a nwée rikne, Karaịsi nwụrnu kwnornu aị ele ọjo máa Chiokike.
\v 7 Ọ bụ nhne siri rikne nụ badnụ jookwno nye ọma nwụ ẹnwu. Kọvu badnụ eleghi anya jeenwe rikne kwnornu nye mee mma nwụ.
\v 8 Kọvu Chiokike gesiri aị ọwhnun'anya a ke bụ nụ Karaịsi kwnornu aị nwụma kpa a zị kọriri nụ rime mmehie.
\p 
\v 9 Be hiri n'ọvnarna a gwnụ aị lele ele ikpe mána, ọ jọoznohia aị n'ovu owe ẹhni Chiokike.
\v 10 Kwnornu nụ a bụ ele irno Chiokike nụ mbọm, kọvu aị nụ Chiokike mernu udno hite n'ẹnwu Nnwọ a. Kịtna, a bụ ele enyi Chiokike, ọ jọoznohia a hite nụ bụdnu Nnwọ a.
\v 11 Ọ bụ́o kam kpọi, kọvu a nọonwudna ọnwudna nụ rime Chiokike hite nụ Nyenwe aị Jizọsi Karaịsi, nye mernu aị nụ Chiokike zịri n'udno.
\s1 Adam nụ Karaịsi
\p 
\v 12 Lele kpa mmehie hiri n'aka otu badnụ bna nụ rime ọwa, mmehie vuyarụ ẹnwu, ẹnwu wam zuru kpakara ọwa, kwnornu nụ kpakara badnụ mehieru.
\v 13 Mmehie zị n'ọwa sụ be nyernu Iwu, kọvu mmehie zị́la ire nga Iwu zị́la a.
\v 14 Ẹnwu hiteru n'Adam dụ n'ige Mozizi nẹechi kpakara badnụ, ma ele méhiele lele kpa Adam mehieru. Adam bụ nye bị́tala nhne Chiokike nyernu n'iwu.
\p Adam bụ oyiyi nye wam jaava.
\v 15 Kọvu nkesi wam nụ́na lele mmehie. Kwnornu ọ bụru nụ agịda badnụ nwụrnu hite nụ mmehie otu badnụ, oru nụ nkesi Chiokike zị agịda kakwo, ke gazuru kpakara ele badnụ hite n'oru otu nye wam bụ Jizọsi Karaịsi.
\v 16 Nkesi Chiokike zị ichne nụ hne mmehie otu badnụ zị. Ikpe snornu otu mmehie wam ke vuyarụ ọmuma ikpe, kọvu nkesi wam sno agịda mmehie ke vuyarụ ọgwnusi badnụ lele nye ikpe mámana.
\v 17 Mmehie otu badnụ ka, Adam, mernu ẹnwu nẹechi ọwa, kọvu kpakara ele nahịaru nkesi oru zị agịda ke Chiokike nụ ome mma a, jeemegbu mmehie nụ ẹnwu hite nụ otu badnụ wam ke bụ Jizọsi Karaịsi.
\p 
\v 18 Owe! Otu mmehie Adam vuyarụ ọmuma ikpe nụ risi kpakara ele badnụ, kọvu, otu ẹrnu ome mma Karaịsi mernu ele badnụ bụru ele ikpe mámana n'anya Chiokike, ke nyernu be bụdnu.
\v 19 Hite nụ risi rikne otu badnụ kpakara ele badnụ ghọru ele mmehie, otu aka wam masị, obno nsnị otu badnụ jeeme kpakara ele badnụ bụru ele mee mma.
\p 
\v 20 Iwu varụ ma nhne ọjo zị agịda, kọvu hne mmehie zị agịda, oru Chiokike barụ aba k'agịda.
\v 21 Hne mmehie nẹechi hite n'ẹnwu, oru Chiokike nẹechi hite n'ome mma ke noodubna nụ bụdnu kwó okwo hite nụ Jizọsi Karaịsi Nyenwe aị.
\c 6
\s1 Nwụ nụ mmehie, // zịri bụdnu nụ Karaịsi
\p 
\v 1 Kịni bụ nhne a jaakaa? Ọ bụ ma a zị kọriri nụ neeme mmehie ma oru Chiokike ba ọba?
\v 2 Ọ́za rịa rịa! Ndaa kpa aị ele nwụrnu ọnwu nụ rime mmehie jaazị kọriri bụdnu nụ rime a?
\v 3 Ọ bụ nụ anụ máa sa, be wụru aị mini ma aị nụ Karaịsi Jizọsi bụru otu, nụ be wụru aị mini ma aị nụ Karaịsi bụru masị otu n'ẹnwu a?
\v 4 Hite nụ mini be wụru aị, be likọtaru aị nụ Karaịsi n'ẹnwu a, ma a nụ lele Karaịsi nga o hiri n'ẹnwu lizọ hite n'igwugwu ke Nda, a joowu bụdnu ikne.
\p 
\v 5 Kwnornu nụ ọ bụru nụ aị nụ a bụ otu n'ẹnwu a, kpam masị, aị nụ a jọoburu otu n'olizọ n'ẹnwu a.
\v 6 A magwụ nụ ẹhni ọknani aị bụ ke be kpọgidnernu ya nụ Karaịsi n'olu ọgba a, ma be lulu ẹhni mmehie, ma a gharụ ọ bụru ọhi ke mmehie.
\v 7 Kwnornu nga badnụ nwụrnu, mmehie nwéma iknernema n'ẹhni a berere.
\v 8 Ọ bụru a snornu Karaịsi nwụ ẹnwu, a kweru nụ a joosno a zịri bụdnu.
\v 9 A magwụ nụ Chiokike mernu Karaịsi hi n'ẹnwu lizọ, ọ jọ́onwu kwno berere, ẹnwu nwéma iknernema hne ọ zị berere.
\v 10 Ẹnwu ọ nwụrnu, ọ nwụrnu kwnornu mmehie otu mgba, ọ zị bụdnu kịtna, ọ zịnu Chiokike bụdnu.
\p 
\v 11 Kpam masị, anụ gwnụ ẹhni anụ lele ele nwụrnu ọnwu kwnornu mmehie, kọvu ele zị bụdnu nyee Chiokike hite nụ Karaịsi Jizọsi.
\v 12 Anụ kwé mmehie nẹechi anọ-ẹhni anụ, neeme anụ noobno nsnị nhne ọjo anọ-ẹhni noopio.
\v 13 Anụ kwékọ o gweru ẹhni anụ nyee mmehie ma ọ bụru nhne ẹrnu ke risi rikne. Kọvu anụ gweru ẹhni anụ nyee Chiokike, lele ele hiri n'ẹnwu bna nụ bụdnu, anụ gweru kpakara ẹhni anụ nyee ma be bụru nhne ẹrnu ke nhne ọma.
\v 14 Kwnornu nụ mmehie zá nẹechi anụ, anụ zị́la nụ mkpururu Iwu, kọvu nụ mkpururu oru ke Chiokike.
\s1 Ele ọhi ke ome mma
\p 
\v 15 Kịni bụ ka? A jaazị neeme mmehie kwnornu nụ a zá nụ mkpururu Iwu, kọvu mkpururu oru ke Chiokike? Ọ́za rịa rịa.
\v 16 Anụ magwụ nụ nye anụ noobno nsnị nhne o nookwu, anụ bụ ele ọhi nye anụ noobno nsnị. Anụ bụ ọhi ke mmehie ke noodubna n'ẹnwu, mọbu ọhi obno nsnị ke noodubna n'ome mma.
\v 17 Kọvu ọznarni zịnu Chiokike, kwnornu nụ mbọm anụ bụ ọhi ke mmehie, kọvu anụ bnornu nsnị hite nụ mkpọma anụ bna n'ezi ọka wam anụ nahịaru.
\v 18 Be dọhiaru anụ nụ mmehie anụ, ma anụ bụru ọhi ke ome mma.
\p 
\v 19 M nookwu lele badnụ, kwnornu nụ anụ zá rikne. Nụ mbọm, anụ gweru ẹhni anụ nyee nhne zị́la rịchna nụ risi rikne o mee nhne ọjo, kpam masị, anụ gweru ẹhni anụ bụru ọhi ome mma bna n'ẹrnu zị nsọ.
\v 20 Nga anụ bụ ọhi ke mmehie, anụ nwée igwe n'ome mma.
\v 21 Ndaa mbnarna anụ nwehịaru hite nhne kam nọotu iwhnerne? Risi kpakara nhne kam, bụ ẹnwu.
\v 22 Kọvu kịtna, be dọhiaru anụ nụ rime mmehie, anụ bụru ele ọhi ke Chiokike, mbnarna anụ jeenwehịa jeeme anụ zịri nsọ ke joodubna nụ bụdnu kwó okwo.
\v 23 Kwnornu nụ ọgwo ẹrnu mmehie bụ ẹnwu, kọvu nkesi ke Chiokike bụ bụdnu kwó okwo hite nụ Karaịsi Jizọsi Nyenwe aị.
\c 7
\s1 Nhne atụ ke ọlulu nzi // nụ nnwerne
\p 
\v 1 Rụmu nda m, m nookwunu anụ ọka lele ele magwụ Iwu, anụ magwụ nụ Iwu jigwu badnụ hne nye wam zị bụdnu.
\v 2 Nyerinya nwernu nzi zị n'iwu nga nzi a zị bụdnu, kọvu ọ bụru nzi a nwụ, ọ zị́ma iwu jigwu a lele nye zị nụ nzi.
\v 3 Ka neegesi, ọ bụru nụ nzi a zị bụdnu, nyerinya wam gbọ nzi berere, be jookwu a nye neeme ọyi. Kọvu ọ bụru nụ nzi a nwụrnu ọnwu, iwu jígele a, ọ bụru nụ ọ gbọru nzi berere. O méne ọyi.
\p 
\v 4 Rụmu nda m, otu aka wam, bụ kpa ọ zịnu anụ. Anụ nwụrnu ọnwu n'Iwu hite n'ẹhni Karaịsi. Anụ bụ ke nye wam hiri n'ẹnwu lizọ, ma anụ bụru mgwna ẹrnu ke bnarnụ iru n'aka Chiokike.
\v 5 Nga a zị bụdnu n'anọ-ẹhni, nhne ọjo ke Iwu Mozizi vuyarụ bụ nhne a noosno, kpakara nhne a mernu dubnarnụ aị n'ẹnwu.
\v 6 Kọvu kịtna, a nwernunem ẹhni aị n'Iwu, kwnornu nụ a agbụrulam n'iwu wam jigwu aị, a kpenu Chiokike n'apna ikne ke Enine, ọ bụ́o n'apna ọknani ke Iwu be gbarụ n'ọkwukwo.
\s1 Iwu nụ mmehie
\p 
\v 7 Kịni bụ nhne a jookwu? Iwu wam ọ bụ mmehie sa? Ọ́za rịa rịa. Kọvu iwu mernu m mahịa mmehie. M znégele m amahịa nhne bụ a ọwho-anya ọ bụru n'Iwu kwúle, “I nwékọ ọwho-anya.”
\v 8 Kọvu mmehie hite nụ nhne be nyernu n'iwu nwehịaru oghere ọ kpakne ọwho-anya zị ichne ichne. Kwnornu nụ mmehie nwụrnu ọnwu hne iwu zị́la.
\v 9 M zị m bụdnu hne iwu zị́la, kọvu nga nhne be nyernu n'iwu varụ, mmehie zịri bụdnu nụ rime m, m nwụma.
\v 10 Nhne be nyernu n'iwu ke kwesiri o gweya bụdnu, vuyanu m ẹnwu.
\p 
\v 11 Mmehie hite nụ nhne be nyernu n'iwu duwhuru m, hite nhne be nyernu n'iwu, gbu m.
\v 12 Iwu wam zị nsọ, nhne be nyernu n'Iwu zị masị nsọ, ọ zị kwem, ọ bụru ọma.
\v 13 Ka o neegesi nụ nhne bụru ọma vuyanu m ẹnwu? Ọ́za rịa rịa. Ọ bụ mmehie ke kpayarụ a. Mmehie gweruru nhne bụru ọma mee a o vuyanu m ẹnwu, ma mmehie whụya iwhne nụ ọ bụ mmehie n'ezi. Hite nụ nhne be nyernu n'iwu be jeegesi nụ mmehie bụ́o ọma rịa rịa.
\p 
\v 14 A magwụ nụ Iwu bụ nhne enine. Kọvu m bụ m badnụ etekne, nye be reru lele ọhi ke mmehie.
\v 15 M máam nhne me neeme, kwnornu nụ nhne me noopio o mee, m nwée m rikne mee a, kọvu nhne me píole o mee, bụ nhne me neeme.
\v 16 Nga me neeme nhne me píole o mee, ka neegesi nụ Iwu wam bụru ọma.
\v 17 Kọvu ọ bụ́o me neeme nhne ka, kọvu ọ bụ mmehie ke wu nụ rime m.
\v 18 M magwụ m nụ ọ zá nhne ọma ọbula zị nụ rime m (ke bụ n'anọ-ẹhni m). Kwnornu nụ ọ naamasị m o mee nhne bụru ọma, kọvu m nwée m rikne o mee a.
\v 19 M mée m nhne ọma me pioru o mee, kọvu nhne bụ́o ọma me píole o mee, bụ nhne me neeme.
\v 20 Ọ bụru nụ me mee nhne me píole o mee, ka neegesi nụ ọ bụ́o me bụ nye neeme a, kọvu ọ bụ mmehie wam ke wu nụ rime m.
\p 
\v 21 M magwụ m nụ iwu nọornu ẹrnu, nga me pioru o mee nhne bụru ọma, nhne ọjo zị nụ ruwhnu m.
\v 22 Nụ rime enine m, m noopio iwu Chiokike.
\v 23 Kọvu m nọowhnu iwu berere nọornu ẹrnu nụ rime m, iwu ke nọolusi iwu ke ovu ọgwnu. O neeme m bụru ọhi iwu ke mmehie ke nọornu ẹrnu nụ anọ-ẹhni m.
\v 24 M bụ m badnụ ke nọowhnuji anya. Nyele jọodohia m n'anọ-ẹhni ke ẹnwu ka?
\v 25 A nọotunu Chiokike mmamma hite nụ Nyenwe aị Jizọsi Karaịsi.
\p Hite n'echiche m, m bụ m ọhi ke iwu ke Chiokike, kọvu, anọ-ẹhni m bụ ọhi iwu ke mmehie.
\c 8
\s1 Bụdnu hite n'Enine
\p 
\v 1 Kịtna, ọ zá ikpe naama ele zị nụ rime Karaịsi Jizọsi. \f + \fr 8:1 \ft Agwna ọkwukwo ọknani kwuru: ele zá noowu bụdnu lele kpa mmehie pioru, kọvu lele kpa enine noopio. \f*
\v 2 Kwnornu nụ iwu ke Enine ke neegweya bụdnu nụ Karaịsi Jizọsi, mernu m whọga n'ọhi iwu ke mmehie nụ ẹnwu.
\v 3 Nhne Iwu nwée rikne meli kwnornu nụ anọ-ẹhni badnụ zị́la rikne, Chiokike mernu a, o ziyaru Nnwọ a lele badnụ ke mmehie ma ọ bụru arịohna mmehie. Hite nụ ya ọ ma bụdnu mmehie ke badnụ ikpe.
\v 4 Chiokike mernu ka ma nhne ziri ezi ke Iwu zu ozu nụ rime aị ele noowu bụdnu lele kpa Enine noopio, ọ bụ́o kpa anọ-ẹhni noopio.
\v 5 Ele noowu bụdnu n'anọ-ẹhni neeme nhne anọ-ẹhni noopio, ele noowu bụdnu n'Enine neeme nhne Enine noopio.
\v 6 Nye anọ-ẹhni nẹechi nwụrnu ọnwu, kọvu nye Enine nẹechi nwernu bụdnu nụ udno.
\v 7 Kwnornu nụ nye anọ-ẹhni nẹechi bụ nye irno Chiokike, o nwée rikne bịta iwu Chiokike, n'ezi, o jéenwe rikne bịta a.
\v 8 Ele anọ-ẹhni nẹechi jéenwe rikne mee nhne jọoso Chiokike n'ọnu.
\p 
\v 9 Anọ-ẹhni zá nẹechi anụ, kọvu Enine, ọ bụru nụ Enine Chiokike wu nụ rime anụ. Nye ọbula ke nwée Enine Karaịsi, bụ́o ke Karaịsi.
\v 10 Ọ bụru nụ Karaịsi zị nụ rime anụ, ọ bụ n'ezi nụ anọ-ẹhni anụ nwụrnu ọnwu kwnornu mmehie, kọvu enine anụ zị bụdnu kwnornu ome mma.
\v 11 Ọ bụru nụ Enine Chiokike ke mernu Jizọsi hi n'ẹnwu lizọ wuru nụ rime anụ, nye wam ke mernu Karaịsi hi n'ẹnwu lizọ jeeme anọ-ẹhni anụ zịri bụdnu hite n'Enine a ke wu nụ rime anụ.
\p 
\v 12 Kam kpayarụ, rụmu nda m, a jigwu ọgwo o wu bụdnu aị, ọ bụ́o kpa anọ-ẹhni noopio.
\v 13 Kwnornu nụ ọ bụru nụ anụ wu lele kpa anọ-ẹhni anụ noopio, anụ jọonwu ẹnwu, kọvu ọ bụru nụ anụ jeehi n'enine gbu kpakara ẹrnu ọjo ke anọ-ẹhni, anụ jaazị bụdnu.
\v 14 Kpakara ele Enine Nsọ Chiokike nẹechi bụ rụmu Chiokike.
\v 15 Kwnornu nụ Enine Chiokike nyernu anụ méne anụ ele ọhi, ke neeme anụ bụru ele ogwnu. Kọvu Enine neeme anụ bụru rụmu Chiokike, anụ jeenwe rikne kwnakwu a, “Papa, Nda m.”
\v 16 Enine Nsọ Chiokike naagbanụ enine aị akebne nụ a bụ rụmu Chiokike.
\v 17 Ọ bụru nụ a bụ rụmu Chiokike, a bụ ele neekehịa mkpe, ele neekehịa mkpe Chiokike, ele be nụ Karaịsi neekerikọta mkpe. Ọ bụru a snornu a ta awhnụwhnu, a joosno a kehịa igwugwu a masị.
\s1 Igwugwu ke zị nụ ruwhnu
\p 
\v 18 M whnụrnu m nụ awhnụwhnu ke ige ka bụ nhne a jéeji tụsinu igwugwu ke be jookpumenu aị.
\v 19 Kpakara nhne be keru eke ji olile anya siri rikne neese nga be jeegesi rụmu Chiokike.
\v 20 Kwnornu nụ nhne be keru eke ghọru nhne etekne, ọ bụ́o nụ rikne aka ke be, kọvu kpa Chiokike mernu be, be zị kọriri neele anya,
\v 21 nụ nhne be keru eke jeenwernu ẹhni be whọga n'ẹhni oro oro, kehịa igwe nụ o nwernu ẹhni zị igwugwu ke be bịtannu rụmu Chiokike.
\p 
\v 22 A magwụ dụ kịtna nụ kpakara nhne be keru eke nọosnu idne lele nye rime ọmumu nnwọ neeme.
\v 23 Kọvu ọ bụ́o nhne be keru eke kpọi, ma aị masị ele nwernu Enine ke bụ nkesi mbọm ke Chiokike, a nọosnu idne nụ rime ovu aị, neese nga Chiokike jeeme a bụru rụmu a, ma ọ gbahịa anọ-ẹhni aị.
\v 24 Kwnornu be znọhiaru aị hite n'olile anya, kọvu ọ bụru a whnụ nhne a neele anya a, ọ bụ́ma olile anya n'ezi. Ọ zá nye neele anya nhne ke ọ whnụgwu anya.
\v 25 Kọvu ọ bụru a neele anya nhne a zá nọowhnu anya, a jeeji nkasi ovu neese a.
\p 
\v 26 Kpam masị, Enine Nsọ neeyinu aị aka, ọ bụ ezi nụ a zá rikne. Kwnornu nụ a máa kpa a jeekpe okpukpe, kọvu Enine Nsọ Chiokike neekpehịanu aị, hite n'ọsnu idne ke ọnu jóokwuli.
\v 27 Kwnornu nụ Chiokike nye noonyosna mkpọma badnụ magwụ echiche Enine, ọ bụ Enine Nsọ nọorio arịrio nụ risi ele nsọ lele kpa echiche Chiokike jiri zị.
\s1 A kakwo ele mmeri
\p 
\v 28 A magwụ nụ Chiokike neeme kpakara nhne nọornuko ẹrnu ọma n'otu kwnornu ele whnụrnu Chiokike n'anya, ele o sukwuru ma be mee echiche a.
\v 29 Kwnornu nụ ele Chiokike mahịamarnu, ọ bịtaru be ichne, ma be nụ lele Nnwọ a, ma Nnwọ wam bụru Ọpnarna n'esilawụru agịda rụmu nda.
\v 30 Ele Chiokike bịtaru ichne, o sukwuru be, ele o sukwuru, o mee be ele ikpe mámana, ele o mernu ikpe ele mámana, o mernu be kehịa igwugwu a.
\p 
\v 31 Ndaa nhne a jookwu nụ kpakara nhne ka? Ọ bụru nụ Chiokike dasị aị n'ikwnu, nyele jeemegidne aị?
\v 32 Nye wam ke bị́tala Nnwọ a, kọvu kesi aị ya, ndaa kpa o jéenye aị kpakara nhne?
\v 33 Nyele joobno ele Chiokike họhiaru nhne? Ọ bụ Chiokike bụ nye neeme ele badnụ ele ikpe mámana.
\v 34 Nyele bụ nye naama aị ikpe? Ọ bụ́o Karaịsi Jizọsi, nye nwụrnu ẹnwu, nye hiri n'ẹnwu lizọ, dazịri n'akarikwnunga Chiokike nọorionu aị arịrio.
\v 35 Nyele jeekewa aị n'ọwhnun'anya ke Karaịsi? Ọ bụ mkpa, sọbu nhne osi rikne sa, sọbu okne ọkpagbu, sọbu ọknunyo, sọbu ọgba-ẹto, sọbu aghọm, sọbu ama-ọgwnu?
\v 36 Lele kpa be gbarụ a n'ọkwukwo nsọ,
\q1 “Kwnornu anụ, ẹnwu neeche aị aka nụ ruwhnu kpakara ọbochi,
\q2 be nọopnughari aị lele atnụrnu be noogbu ogbu.”
\p 
\v 37 Ọ́za! A nwernu omeri nụ kpakara nhne ka hite nụ nye wam ke whnụrnu aị n'anya.
\v 38 Kwnornu nụ m magwụ m nụ ẹnwu mọbu bụdnu, mọbu enine izi, mọbu rẹnwu ọjo, mọbu nhne ke zị kịtna, mọbu nhne ke jaava, mọbu rikne ọbula,
\v 39 mọbu olu mọbu nhne zị nụ rime ẹli, mọbu nhne berere be keru eke, jéenwe rikne kewama aị n'ọwhnun'anya ke Chiokike ke zị nụ rime Karaịsi Jizọsi.
\c 9
\s1 Chiokike nụ ele ke // ọ họhoruru
\p 
\v 1 M nookwu ezi ọka nụ rime Karaịsi, ọ bụ́o aghalaghala, Enine Nsọ naagbanụ ovu m akebne nụ m zá m naagha aghalaghala.
\v 2 Anya-mini zị m nụ mkpọma, nhne igbugbu zị m nụ mkpọma kpakara ige.
\v 3 Ọ jaamasị m, ọ bụru nụ Chiokike vụru m ọnu, kewama m nụ hne Karaịsi zị, kwnornu rụmu nda m, ele ẹli m,
\v 4 ele Izirẹli. Chiokike mernu be bụru rụmu a, o okpumennu be igwugwu a, ya nụ be gbarụ njọ-ẹhni, o nyernu be Iwu, be nwernu okpukpe ọma, nụ kpakara mkwna Chiokike,
\v 5 be bụ avnụrnu kwu ele nda ọknani, Karaịsi hiri n'avnụrnu be va n'anọ-ẹhni. Ọznarni zịnu Chiokike ke nẹechi kpakara nhne ọkwnukokwnu. Amịm.
\v 6 Ọ bụ́o nụ Chiokike mézule ikwu-ọnu a, kwnornu nụ ọ bụ́o kpakara ele hi n'avnụrnu Izirẹli bụ rụmu Izirẹli n'ezi.
\v 7 Kpakara be bụ́o rụmu Ebereham n'ezi, ọ bụbedi nụ be hi n'avnụrnu Ebereham. Kwnornu nụ ọkwukwo nsọ kwuru, “Kọvu be jọogwnu rụmu ị hite n'Aziki.”
\v 8 Ka bụ nụ ọ bụ́o rụmu be mụrnu n'anọ-ẹhni bụ rụmu Chiokike, kọvu ele be mụrnu lele kpa Chiokike kweru Ebereham nụ mkwna bụ rụmu a n'ezi.
\v 9 Kwnornu nụ ka bụ nhne mkwna wam kwuru, “N'ige be karụ aka, m jeehiehna, Sera jọomu nnwọ rukna.”
\p 
\v 10 Ọ bụ́o ka kpọi, rụmu Ribeka nwernu otu nda, ke bụ nda ọknani aị Aziki.
\v 11 Sụ ọ mụrnu rụmu ejima rukna lawụru wam, nga be mége nhne ọma mọbu ke ọjo, ma nhne Chiokike kwuru gwuzosi rikne,
\v 12 ọ bụ́o hite n'ẹrnu kọvu kwnornu nụ o sukwu ikwu a, Chiokike kannụ Ribeka, “Nye ke okno badnụ jeeznenu nye ke matị izi.”
\v 13 Lele kpa be gbarụ a n'ọkwukwo nsọ, “M whnụrnu m Jekọpu n'anya, sno Isọ irno.”
\p 
\v 14 Ndaa nhne a jookwu? Ọ bụ nụ Chiokike bụ nye ndala sa? Ọ́za rịa rịa.
\v 15 Kwnornu nụ ọ kannụ Mozizi,
\q1 “M jọodonu nye me jọodonu obirizi, obirizi,
\q2 mee masịnu nye masịri m oru.”
\p 
\v 16 Ka neegesi nụ ọ bụ́o hite nụ nhne badnụ noopio mọbu nhne be nọornu, kọvu ọ bụ obirizi Chiokike.
\v 17 Kwnornu nụ ọkwukwo nsọ kannụ Fero, “Ka bụ nhne me kwno gwuzote i, ma m gesi m iknernema m n'ẹhni ị, ma kpakara ọwa mahịa rẹwhna m.”
\v 18 Chiokike nọodonu nye masịri a obirizi, neemenu nye o pioru ma o knesni mkpọma, knesni mkpọma a.
\s1 Ikpe nụ obirizi Chiokike
\p 
\v 19 Otu badnụ jaakanụ m, “Ndaa kpa Chiokike naama aị ikpe? Nyele nwernu rikne o gwuzogidne echiche a?”
\v 20 Jị badnụ etekne, ị bụ nyele naasa Chiokike ọka? Nhne be kpụru ọkpu ọ jaasịkwa nye kpụru a ajịji, “I kwno kịni kpụ m kpa?”
\v 21 Ọ bụ nye nọokpu ite o nwée rikne n'ẹhni otu ọrura wam kpụ ite lawụru, otu bna n'ẹrnu zị okne mkpa, ke berere be ji a rnụ ẹrnu kpakara ige?
\p 
\v 22 Ọ zị Chiokike n'aka o gesi ikpe nụ iknernema a, kọvu, ọ zị kwno a n'aka o gesi ogologo ọsnuta ovu n'ẹhni ele o neekpe ikpe, bụ ele ọ bịtaru ma ọ la be n'iyi.
\v 23 Ọ zị masị n'aka a ọ wụkwasi ọkwnamarna igwugwu a nụ bụdnu ele ọ bịtannu obirizi a.
\v 24 Kwnornu nụ a bụ ele o sukwuru, ọ bụ́o hite n'avnụrnu ele Ju kpọi, kọvu ma hite n'ẹli ele bụ́o ele Ju.
\v 25 Ka bụ nhne o kwuru n'ọkwukwo Hosiya,
\q1 “M jookwu be ele ke m, ele wam bụ́o ele ke m,
\q2 ele wam me whnụ́ge n'anya, m jookwu be ele me whnụrnu n'anya.
\q1 
\v 26 Ọ jọobu nụ hne be zị kaa,
\q2 nụ be bụ́o ele ke m,
\q1 jọobu hne be jookwu be rụmu Chiokike ke zị bụdnu.”
\p 
\v 27 “Azaya siri okokoba gbasịri rụmu Izirẹli, kaa,
\q1 Ọ bụ n'ezi nụ rụmu Izirẹli nụ lele rịzna ke ngeri osimini,
\q2 ele be jọoznohia jaazị matị k'agịda.
\q1 
\v 28 Kwnornu nụ Jihova jeekpebi ikpe ọwa wara wara n'ome mma.”
\p 
\v 29 Lele kpa Azaya kwuru nụ mbọm,
\q1 “Ọ bụru nụ Chiokike ke Meli Nhne Dum
\q2 dọ́nu aị obirizi ghasanụ aị agwna rụmu,
\q1 a znernu ọnu lele Sọdom,
\q2 a znernu ọnu lele Gọmora.”
\s1 Ele Izirẹli kwéle // ọ nabnarnụ izi ọma
\p 
\v 30 Ndaa nhne a jookwu? Ọ bụ nụ ele bụ́o ele Ju ele zá noosno ome mma Chiokike, nwehịaru ome mma ke hi n'ọkwnata mkpọma?
\v 31 Kọvu ele Izirẹli, noosno iwu ome mma nwée nhne iwu ome mma karụ, be píohịala a.
\v 32 Kịni kpayarụ ka? Kwnornu nụ be jíge ọtukwasi ovu pio a, kọvu lele nụ ọ bụ n'ẹrnu. Be dna n'olu rugwu nọokpobi ọchi.
\v 33 Lele kpa be gbarụ a n'ọkwukwo nsọ, kaa,
\q1 “Le, m bịtaru m otu akaworugwu nụ rime Zayọni
\q2 ke jeeme ele badnụ kpọbi ọchi,
\q2 rugwu ke jeeme be dna.
\q1 Kọvu nye ọbula ke tụkwasiri a mkpọma,
\q2 be jéekwe iwhnerne tụ a.”
\c 10
\p 
\v 1 Rụmu nda m, nhne nọogwnu m nụ mkpọma, m neekpe masịnu Chiokike gbasịri ele ke m bụ Izirẹli, bụ ma be znọhia be.
\v 2 M jaagbanụ be akebne nụ be nwegwu mkpọma o kpenu Chiokike, kọvu be nwée ọghohia.
\v 3 Kwnornu nụ be máa ome mma ke Chiokike, be bete noogwuzote ome mma ke be, be bị́tala ẹhni be nụ mkpururu ome mma Chiokike.
\v 4 Karaịsi bụ mbimambi Iwu, nye ọbula ke tụkwasiri a mkpọma, jeenwehịa ome mma.
\s1 Ọznohia zịnu // kpakara badnụ
\p 
\v 5 Ka bụ nhne Mozizi kwuru gbasịri ome mma ke hi n'Iwu, “Nye ọbula ke bịtaru Iwu jaazị bụdnu nụ rime be.”
\v 6 Kọvu ome mma ke hiri n'ọtukwasi mkpọma karụ kpa, “I kwúkọ nụ mkpọma ị, ‘Nyele jeezne oligwe?’ (zne gwedna Karaịsi).
\v 7 Mọbu, ‘Nyele jeezne nụ rime ẹli?’ (zne gwelizọ Karaịsi n'ẹnwu).”
\v 8 Kọvu ndaa nhne o kwuru? “Ikwu-ọnu wam zị ị ndụndu, ọ zị n'ọnu ị ma n'ovu ị.” Kam bụ ikwu-ọnu ọtukwasi ovu ke a nọokpo okwo.
\v 9 Ọ bụru nụ i jeeji ọnu ị kwuhịa nụ Jizọsi bụ Nyenwe aị, gweru mkpọma ị kweru nụ Chiokike mernu o hi n'ẹnwu lizọ, be jọoznohia ị.
\v 10 Kwnornu nụ badnụ ji ovu a kweru, be gwnụsi a nụ nye ikpe mána, o ji ọnu a kwuhịa, o nwehịa ọznohia.
\v 11 Ọkwukwo nsọ kwuru kpa, “Iwhnerne zá nọotu ele kwnatarụ a ovu.”
\v 12 Ọ zá nhne zị ichne hne nye Ju nụ nye bụ́o nye Ju zị. Chiokike bụ Nyenwe kpakara badnụ, nọowukwasi ngọzi a nụ risi ele naakwnakwu a.
\v 13 Kwnornu nụ be jọoznohia kpakara ele noosukwu rẹwhna Nyenwe aị.
\p 
\v 14 Kọvu ndaa kpa be joosukwu a, ọ bụru nụ be kwéle nụ ya? Ndaa kpa be jeekweru, ọ bụru nụ be nụ́na nhne gbasịri a sa? Mọbu ndaa kpa be jọonu, hne ọ zá nye nọokpo okwo izi ọma?
\v 15 Ndaa kpa be jọokpo okwo hne ọ zá nye ziznernu be? Lele kpa be gbarụ a n'ọkwukwo nsọ, kaa, “Le kpa ọchi be marnụ mma bụ ele neezni izi ọma.”
\v 16 Kọvu, ọ bụ́o kpakara be kweru izi ọma wam, kwnornu nụ Azaya karụ, “Nyenwe aị, nyele kweru izi a ziri?”
\v 17 Ka neegesi nụ ọkwnata mkpọma jeehi nụ ọnurnu izi ọma va, ọnurnu jeehi n'ọkpo okwo izi ọma Karaịsi.
\v 18 Kọvu m nẹesikwa, ọ bụ ezi nụ be nụ́na izi ọma wam? Be nụrnu a. Lele kpa ọkwukwo nsọ kwuru,
\q1 “Nkọli be gazuru kpakara ọwa,
\q2 ikwu-ọnu be dụru hne ọwa sọtoru.”
\p 
\v 19 M nẹesikwa kwno, ọ bụ nụ ele Izirẹli máa? Mozizi n'iwhuru a beru ọsno kaa,
\q1 “M jeeji ele mba ọ zá nhne be bụ mee anụ nwe anya-kwu,
\q2 m jeeji mba ke nwée akọniche kpasu anụ iwe.”
\p 
\v 20 Azaya kwusiri a rikne kaa,
\q1 “Ele zá noopio m, piohịaru m,
\q2 m mernu m ele zá nẹesikwa ajịji gbasịri m whnụ m anya.”
\p 
\v 21 Ka bụ nhne o kwuru gbasịri Izirẹli,
\q1 “Kpakara ọbochi, m gbasarụ m aka m lawụru o kwubnanya
\q2 ele risi rikne nụ ele zá noobno nsnị.”
\c 11
\s1 Chiokike ghásala ele ke a
\p 
\v 1 M sịkwa kwno, ọ bụ nụ Chiokike ghasarụ ele ke a sa? Ọ́za! Ma n'iwhuru m bụ nye Izirẹli, ke avnụrnu Ebereham, eriri rụwho Bẹnjamini.
\v 2 Chiokike ghásala ele ke a ọ mahịamarnu nụ mbọm. Anụ magwụ nhne ọkwukwo nsọ kwuru nụ hne Ẹlaija naarịasno Chiokike megidne Izirẹli,
\v 3 “Nyenwe aị, be gburu ele ọwhnurninya ị, be kwnadna ojo arịohna ị, me nụ nsnụnu m gwnarnụ, be noopio o gbu m.”
\v 4 Kịni bụ nhne Chiokike kannụ a? “M bịtannu m ẹhni m pokwu ele rukna ẹsau, ele kpọ́nna Balị risi ẹli.”
\v 5 Kpam masị, n'ige ka, Chiokike, hite n'oru a họhiaru ele ke gwnarnụ.
\v 6 Kwnornu nụ ọ bụ oru a, ọ bụ́o n'ẹrnu, ọ bụru nụ ọ bụ hite n'ẹrnu, oru bụ́ma oru.
\p 
\v 7 Kịni kwno? Ele Izirẹli píohịala nhne be noopio, kọvu ele wam ọ họhiaru piohịaru a, ovu kpọru ele berere bẹkwnu.
\v 8 Lele kpa be gbarụ n'ọkwukwo nsọ, kaa,
\q1 “Chiokike nyernu be enine iwhnirniwhno
\q2 be nwernu anya, kọvu be whnụ́ ọsno,
\q2 be nwernu nsnị, kọvu be nụ́ nhne,
\q1 dụ tna.”
\p 
\v 9 Devidi karụ,
\q1 “Iriri be ghọ mbịta nụ nhne joogbu be,
\q2 be dna n'olu a, ta awhnụwhnu.
\q1 
\v 10 Isni kpu be, be whnụ́ ọsno,
\q2 ivu rịnya nyịgbu be ọkwnukokwnu.”
\s1 Ọznohia ele bụ́o ele Ju
\p 
\v 11 M nẹesikwa, ele Izirẹli be dnarnụ ma be la n'iyi sa? Ọ́za rịa rịa. Kwnornu nụ mmehie be, ele bụ́o ele Ju nwehịaru ọznohia, ke jeeme ele Izirẹli nwe anya-kwu.
\v 12 Ọ bụru nụ mmehie be mernu kpakara ọwa nwe ngọzi, be dnarnụ mboni ma ele bụ́o ele Ju nwehịa ngọzi, kpakara ọwa jeenwe agịda ngọzi nga be jeekweru nụ Karaịsi.
\p 
\v 13 M nookwunu anụ ọka kịtna ele bụ́o ele Ju. Hne me bụ nye izi ele bụ́o ele Ju, m jeeji ẹrnu m kpa nganga.
\v 14 Nyele ma, m nwernu rikne mee ele ẹli m nwe anya-kwu, ma m nwernu m rikne znọhia agwna be.
\v 15 Kwnornu nụ nga Chiokike ghasarụ be, kpakara ọwa nụ Chiokike mernu udno. Kịni jeeme nga Chiokike jookwubnanya be? Ọ jọobu nụ ele nwụrnu ọnwu jaazị bụdnu.
\v 16 Ọ bụru nụ mpekele brẹdi mbọm be nyernu Chiokike zị nsọ, kpakara ke gwnarnụ zị nsọ. Ọ bụru nụ ẹgwnugwnu isisi zị nsọ, kpakara nkala a zị masị nsọ.
\v 17 Ọ bụru nụ be o gbukwahalarụ agwna nkala olivu, be gweru anụ bụ nkala olivu ọhia nyakwnusi a, anụ neeri nhne ọma ke hi n'isisi olivu wam.
\v 18 Anụ ménu nkala wam oknomokno, chenwanya nụ ọ bụ́o anụ vu ẹgwnugwnu, kọvu ẹgwnugwnu vugwu anụ.
\v 19 Kọvu kwu kpa, “Be gbukwahalarụ nkala isisi gweru aị nyakwnusi.”
\v 20 Owe! Be gbukwahalarụ be kwnornu nụ be kwé ekwe, kọvu, anụ gwuzo kwnornu nụ anụ tụkwasiri ovu. Anụ vúlizọ ẹhni anụ olu, tnụnuma, anụ tụ ogwnu.
\v 21 Kwnornu nụ ọ bụru nụ Chiokike gharụla ọ ta nkala isisi olivu ke ruhịaru awhnụwhnu, ọ jáagharụ ọ ta anụ awhnụwhnu.
\p 
\v 22 Le mkpọma ọma nụ nhne rikne ke Chiokike, nụ o mesiri ele dnarnụ adna rikne, kọvu ọ dọnu anụ obirizi, ọ bụru nụ anụ jaadazịgidne nụ mkpọma ọma a. Ọ bụru nụ anụ jáadazịgidne nụ mkpọma a, o joogbukwahala anụ.
\v 23 Ọ bụru nụ ele Ju jeehi n'ókwe ekwe be whụya, Chiokike jaanyakwnusi be berere, kwnornu nụ Chiokike nwernu rikne ọ nyakwnusi be.
\v 24 Anụ bụ nkala isisi olivu ọhia, ke Chiokike nyakwnusiri n'ẹhni isisi olivu be znụrnu ọznu, lele kpa o kwésile. Ọ bụru nụ Chiokike mernu kpa, anụ mahịa nụ o nwernu rikne nyakwnuhnasi nkala isisi olivu be znụrnu ọznu n'ẹhni isisi olivu kam be zị.
\s1 Obirizi Chiokike // zịnu kpakara badnụ
\p 
\v 25 Rụmu nda m, o nwernu nhne omimi me noopio anụ mahịa, ma anụ gharụ eche nụ anụ bụ ele akọ n'anya anụ. Nhne omimi kam bụ nụ risi rikne rụmu Izirẹli jáazị ọkwnukokwnu. Kọvu ọ jaazị tem ọnu ọgwnugwnu ele bụ́o ele Ju ele jaavakwnusi Chiokike zute.
\v 26 Kpam masị, be jọoznohia kpakara ele Izirẹli, lele kpa be gbarụ a n'ọkwukwo nsọ,
\q1 “Nye Ọznohia jeehi nụ Zayọni va,
\q2 o joovume kpakara mmehie rụmu Jekọpu.
\q1 
\v 27 Me nụ be jaagba njọ-ẹhni,
\q2 nga me vumernu mmehie be.”
\p 
\v 28 Ele Ju bụ ele irno izi ọma. Ka bụ mbnarna ke anụ ele bụ́o ele Ju. Kọvu be bụ ele ọ họhiaru, whnụ be n'anya kwnornu ele nda be ọknani.
\v 29 Chiokike zá naagbanwo echiche a n'ẹhni ele ọ họhiaru, gọzi masị.
\v 30 Hne anụ ele bụ́o ele Ju zị, anụ bnóge Chiokike nsnị nụ mbọm, kọvu kịtna, anụ nwernu obirizi Chiokike kwnornu ele Ju ele bnóge nsnị.
\v 31 Kpam masị, anụ nwehịaru obirizi Chiokike mernu ele Ju bnóge Chiokike nsnị ma be nwehịa masị obirizi Chiokike.
\v 32 Kwnornu nụ Chiokike mernu kpakara ele badnụ bụru ele risi rikne ma be nwehịa obirizi a.
\s1 Ọznarni zịnu Chiokike
\p 
\v 33 A! Le kpa ẹkwnu nụ akọniche nụ nhne ọmuma Chiokike hna omimi.
\q1 Kpa a nwée rikne nyosna a echiche a,
\q2 badnụ nwée rikne piohịali apna a.
\q1 
\v 34 “Nyele magwụ mkpọma Nyenwe aị?
\q2 Nyele nwernu rikne zni a ezni?”
\q1 
\v 35 “Nyele nyeleru Chiokike nhne,
\q2 ma Chiokike kwụ a ọgwo?”
\p 
\v 36 Ya keru kpakara nhne, kpakara nhne ke zị bụ ke a, ya nwe kpakara nhne.
\q1 Ọznarni zịnu a ọkwnukokwnu. Amịm.
\c 12
\s1 Bụdnu nye ẹrnu Chiokike
\p 
\v 1 Rụmu nda m, kam kpayarụ, m ji m obirizi Chiokike naarịasno anụ, anụ gweru ẹhni anụ yisi n'aka Chiokike lele arịohna zị bụdnu, zị nsọ, ke nọoso Chiokike n'ọnu, bụ ke anụ kwannụ Chiokike n'ezi.
\v 2 Anụ nụ́ko lele ele ọwa ka, kọvu Chiokike gbanwo echiche anụ ma ọ zịri ikne ikne, ma anụ mahịa nhne bụ echiche Chiokike, echiche ọma a, ke nọoso a n'ọnu, ke zuru ozu.
\v 3 Kwnornu nụ oru Chiokike nyernu m, me kanụ anụ, ọ zá nye vulizọ ẹhni a olu n'ọriri a karụ kpa o kwesiri, kọvu anya dno anụ nụ risi n'okpe ẹhni anụ ikpe. Anụ gweru ọkwnata ovu Chiokike tụsinnu anụ kpe ẹhni anụ ikpe.
\v 4 Lele kpa a nwernu agịda nhne ke zị ẹhni, ke ọbula nwernu ẹrnu ke a.
\v 5 Kpam masị, ọ bụ n'ezi nụ a zị agịda, a bụ otu nụ rime Karaịsi, be knekọtaru aị n'otu lele nhne zị ọdo nụ ọdo n'otu anọ-ẹhni.
\v 6 Nye ọbula nwernu nkesi ke a lele kpa oru Chiokike nyernu a. Ọ bụru nụ nkesi otu badnụ bụ whnụ ọwhnurninya, nye wam gweru ọtukwasi ovu mee a.
\v 7 Ọ bụru nụ nkesi a bụ o zne izi, o zne a, ọ bụru o zni nhne, o zni nhne.
\v 8 Ọ bụru ọ gba ele badnụ inwe, o mee kpam. Nye neekesi ele berere nhne, o mee a nụ mkpọma ọma, nye noodu ele badnụ, ọ rnụsi ẹrnu a rikne. Nye nọodo obirizi, o gweru mkpọma ọma mee a.
\s1 Iznizni gbasịru // ọwhnun'anya
\p 
\v 9 Ọwhnun'anya kwesiri ọ zị snam. Anụ sno nhne ọjo irno, anụ knekwaru nhne ọma aka rikne.
\v 10 Anụ gweru ọwhnun'anya rụmu nda whnụ ibne anụ n'anya nụ rime Karaịsi, anụ sọbisinu ibne anụ karụ ẹhni anụ.
\v 11 Anụ bụ́o ele ime mgwụ, anụ rnụsi ẹrnu rikne, anụ gweru mkpọma zị snam neeznenu Nyenwe aị izi.
\v 12 Anụ nwụdna n'olile anya, anụ snụta mkpọma nụ rime ọkpagbu, neekpe okpukpe kpakara ige.
\v 13 Anụ nụ ele nwée nhne kerita ẹkwnu anụ, anụ lekọta ele izne.
\p 
\v 14 Anụ nọogozi ele naakpagbu anụ, anụ nọogozi, anụ vụ́ko be ọnu.
\v 15 Anụ snornu ele nọonwudna ọnwudna, nwụdnahoru, anụ snornu ele naagba mkpe, gba mkpe.
\v 16 Nhne gbasịri ele berere metụ anụ nụ mkpọma. Anụ bụ́ko ele oknomokno, anụ snornu ele ovu dụru ẹli mekọ nhne. Anụ bụ́o ele akọ n'anya anụ.
\p 
\v 17 Anụ jíkọ nhne ọjo kwụ nye mernu anụ nhne ọjo ọgwo. Anụ mee nhne bụru ọma n'anya ele badnụ.
\v 18 Anụ nụ kpakara ele badnụ zịri n'udno, ọ bụru nụ o kwe omume, kpa anụ nwernu rikne.
\v 19 Ele me whnụrnu n'anya, anụ mégwnarnụ, kọvu gharụ ọnuma Chiokike rnụ ẹrnu a, kwnornu nụ ọkwukwo nsọ kwuru, nụ Nyenwe aị kwuru, “Mawa nwe mmegwnahịa, m jeemegwnarnụ.”
\p 
\v 20 Kọvu lele nhne ọkwukwo nsọ kwuru,
\q1 “Ọ bụru nụ wiri nọogwnu nye irno i, nyee a wiri,
\q2 ọ bụru nụ akpịri nọokpo a bẹkwnu, kwute a mini, o nwọrnu,
\q1 kpam, ị naaghakwasị esekere bẹkwnu n'olu risi a.”
\m 
\v 21 Anụ kwé nhne ọjo megbu anụ, kọvu anụ gweru nhne ọma megbu nhne ọjo.
\c 13
\s1 Mkpururu ele ọchichi
\p 
\v 1 Nye ọbula bịta ẹhni a nụ mkpururu ọchichi, kwnornu nụ ọ zá ele nẹechi ọchichi ke Chiokike bị́tala, Chiokike bịtaru kpakara ele nẹechi ọchichi.
\v 2 Nye ọbula ke neemegidne ọchichi neemegidne nhne Chiokike bịtaru, nye mernu kpam jeegweyanụ ẹhni a ikpe.
\v 3 Ele neeme nhne ọma zá nọotu ogwnu ele ọchichi, kọvu ele neeme nhne ọjo jọotu ogwnu. I pioru ogwnu ele nẹechi ẹchi gharụ ọ tụ ị? Mee nhne bụru ọma, be jaaznarnị ị.
\v 4 Kwnornu nụ ọ bụ nnwọ izi Chiokike neeme nhne ọma. Kọvu ọ bụru nụ ị mee nhne ọjo, ogwnu a tụ ị, kwnornu nụ o vúle ama-ọgwnu a etekne. Ọ bụ nnwọ izi Chiokike, neemegwnahịanu a ovu owe ẹhni a n'ẹhni ele neeme nhne ọjo.
\v 5 Kam kpayarụ, i joobno nsnị ele ọchichi, ọ bụ́o kwnornu nụ ovu owe ẹhni Chiokike kpọi, kọvu kwnornu nụ mkpọma ị.
\v 6 Ke bụ anụ jọotu ntụ-ẹli, kwnornu nụ ele ọchichi bụ rụmu izi Chiokike nọornu ẹrnu zịnu be, ele ji kpakara ige be nẹechi ọchichi.
\v 7 Anụ kwụ ọgwo anụ ji be, tụ ntụ-ẹli ọ bụru anụ ji ọgwo ntụ-ẹli, tụ ntụ ahịa ọ bụru nụ anụ ji ọgwo ntụ ahịa, sọ nye kwesiri anya, bisinu nye kwesiri.
\s1 Whnụ ibne anụ n'anya
\p 
\v 8 Anụ jí nye ọbula ọgwo, kọvu anụ whnụrita ẹhni anụ n'anya. Nye ọbula ke nọowhnu badnụ ibne a n'anya mezuru Iwu.
\v 9 Iwu wam, “I mékọ ọyi, i gbúkọ badnụ, i znúkọ buznu, i nwékọ ọwho-anya.” Ka nụ kpakara iwu berere jikọgwu aka n'otu iwu ka, “Whnụ nye agbatibi i n'anya lele ẹhni ị.”
\v 10 Nye ọbula ke whnụrnu nye agbatibi a n'anya jéeme a nhne ọjo. Ọwhnun'anya bụ o mezu kpakara Iwu.
\p 
\v 11 Anụ mee kpa, anụ magwụ nhne ige ka bụ. Ka bụ ige anụ jeetnenya n'anyarna, kwnornu nụ ọznohia aị zị ndụndu kịtna karụ nga a kweru nụ mbọm.
\v 12 Chi jiminem, chi ọbubo zị masị ndụndu, a gharụ ẹrnu ọchichiri, woru mgwna ọgwnu ke iwhne.
\v 13 Ngwa ma a kpa agwa lele ele zị n'iwhne ke ọbochi, ọ bụ́o ele okne iriri nụ ele ẹra manya naagba, ọ bụ́o nụ nhne rune nụ nhne tụ iwhnerne, ọ bụ́o ọlu ọgwnu, nụ anya-kwu.
\v 14 Kọvu anụ woru Nyenwe aị Jizọsi Karaịsi lele iwo, anụ nyée anọ-ẹhni anụ oghere o mee nhne ọjo ke nọogwnu a.
\c 14
\s1 Anụ kpé rụmu nda anụ // ikpe
\p 
\v 1 Anụ kwubnanya nye zá rikne nụ ọkwnata ovu, kọvu anụ nụ a dọ́gbuta kwnornu nhne o kweru.
\v 2 Ọkwnata ovu otu badnụ kweru a, o ri kpakara nhne, kọvu nye berere, ọkwnata ovu a zá rikne, neeri ọkwukwo ọhia kpọi.
\v 3 Nye ke neeri kpakara nhne lédna nye zá neeri anya, nye zá neeri kpakara nhne kpé nye neeri kpakara nhne ikpe kwnornu nụ Chiokike nakweruru a.
\v 4 Ị bụ nyele ke neekpe ọhi nye berere ikpe? Ọ bụ nyenwe a jaakaa ma ọ mekwahịaru mọbu o mékwahịala. O jeemekwahịa, kwnornu nụ Nyenwe aị jeeme a o gwuzoru kwem.
\p 
\v 5 Otu badnụ kanụ otu ọbochi zị mkpa k'agịda n'esilawụru ọbochi berere, nye berere jaakaa nụ kpakara ọbochi bụ otu. Echiche nye ọbula ji a rụwho.
\v 6 Nye karụ nụ otu ọbochi zị mkpa k'agịda neeme a nọosobisinu Nyenwe aị, nye neeri nhne ọbula nọosobisinu Nyenwe aị, kwnornu nụ ọ nọotunu Chiokike mmamma nụ wiri wam. Nye zá neeri agwna nhne nọosobisinu Nyenwe aị, nọotunu Chiokike mmamma.
\v 7 Ọ zá nye zịnu ẹhni a bụdnu kpọi, ọ zá nye nọonwunu ẹhni a ẹnwu.
\v 8 Ọ bụru nụ a zị bụdnu, a zịnu Nyenwe aị bụdnu, a nwụrnu ẹnwu, a nwụnu Nyenwe aị, ma a zị bụdnu ma a nwụrnu ọnwu, a bụ ke Nyenwe aị.
\p 
\v 9 Kwnornu nụ Karaịsi nwụrnu, hi n'ẹnwu lizọ ma ọ bụru Nyenwe ele zị bụdnu nụ ele nwụrnu ọnwu.
\v 10 Jịwa, i kwno kịni neekpe nnwọ nda ị ikpe? I kwno kịni neeledna nnwọ nda ị anya? Kpakara aị joogwuzo nụ ruwhnu ngadna ikpe Chiokike.
\v 11 Lele kpa be gbarụ a n'ọkwukwo nsọ,
\q1 “Nyenwe aị kwuru kpa, ‘Kpa me zị bụdnu
\q2 kpakara mpnerne ọchi joogbunu m n'ẹli,
\q2 kpakara riro jookwupịya nụ mawa bụ Chiokike.’ ”
\m 
\v 12 Kpakara aị n'otu n'otu jaakahịa nhne a mernu nụ ruwhnu Chiokike.
\p 
\v 13 A gharụ o kpe ẹhni aị ikpe, tnụnuma, ị bị́ta nhne jọokpo nnwọ nda ị ọchi, mọbu nhne jeeme ọ dna.
\v 14 M magwụ m nụ hite nụ mmekọrita ke me nụ Nyenwe aị Jizọsi, ọ zá nhne ke zị́la rịchna, ọ bụru nụ badnụ kaa nụ otu wiri zị́la rịchna, ọ zị́la rịchna hne ọ zị.
\v 15 Ọ bụru nụ nhne i riri jeemekasi nnwọ nda ị ẹhni, ị zá neezne izne n'ọwhnun'anya. I kwékọ nhne i riri lulu nye Karaịsi kwnornu nwụ ẹnwu.
\v 16 I kwékọ be kaa nụ nhne ọma ị bụ nhne ọjo.
\v 17 Kwnornu nụ ẹli-eze Chiokike bụ́o nhne oriri nụ ọnwunwo, kọvu ọ bụ ome mma, udno nụ snarnịma nụ rime Enine Nsọ.
\v 18 Kwnornu nụ nye neeznenu Karaịsi izi kpa neeme nhne nọoso Chiokike n'ọnu ma nụ ruwhnu ele badnụ.
\v 19 Ngwa ma a neeme nhne jeegweya udno, nụ ke joowuli aị olu lele ọro.
\v 20 I kwnó wiri lulu ẹrnu aka Chiokike. Kpakara wiri zị rịchna, kọvu ọ bụ́o ọma o ri nhne jeeme badnụ dna.
\v 21 Ọ bụru ọma ị gharụ o ri wiri, mọbu nwọ manya, mọbu mee nhne ọbula ke jeeme nnwọ nda ị dna.
\p 
\v 22 Kpakara nhne i kweru nụ rime nhne ele ka, dazịnum jị nụ Chiokike. Nye ikpe máge nụ nhne o kweru bụ nye ọwa ọma.
\v 23 Kọvu ọ bụru nụ mkpọma badnụ marnụ a ikpe nụ nhne o riri, Chiokike jaama a ikpe ma o ri a, kwnornu nụ ọ kwnátala mkpọma nụ nhne o neeme. Nhne ọbula ke híge n'ọkwnata mkpọma bụ mmehie.
\c 15
\s1 Mee nhne jọoso ele berere // n'ọnu
\p 
\v 1 Aị ele zị rikne nụ ọkwnata mkpọma kwesiri o vuru ekperi ele zá rikne. Ọ bụ́o neeme nhne nọoso aị n'ọnu.
\v 2 Nye ọbula menu badnụ ibne a nhne bụru ọma, ke jọoso a n'ọnu, ma o wulizọ a olu lele ọro.
\v 3 Kwnornu nụ Karaịsi méne nhne jọoso ẹhni a n'ọnu, lele kpa be gbarụ a n'ọkwukwo nsọ, “Nhne iwhnerne ele naakpasị ị iwhnerne dnakwasịri m.”
\v 4 Kpakara nhne be gbarụ n'ọkwukwo nsọ n'ọbochi wheru ewhe zịnu aị, neezni aị nhne, ma a nwernu olile anya hite n'ndidi nụ ọgba inwe ke ọkwukwo nsọ nyernu aị.
\p 
\v 5 Chiokike ke neenye ndidi nụ ọgba inwe mee anụ nwernu enine ọziri n'otu kpa anụ noosno Karaịsi Jizọsi,
\v 6 ma kpakara anụ n'otu jeegweru otu ọnu znarnị Chiokike nụ Nda Nyenwe aị Jizọsi Karaịsi.
\p 
\v 7 Anụ kwubnanya ibne anụ lele kpa Karaịsi kwubnanyarnụ anụ ma anụ znarnị Chiokike.
\v 8 M naakanụ nụ Karaịsi ghọru nnwọ izi ele Ju ma o gesi ezi ọka Chiokike, mezu mkwna o kweru nda be ọknani,
\v 9 ma ele bụ́o ele Ju nyee Chiokike igwugwu kwnornu obirizi a, lele kpa be gbarụ a n'ọkwukwo nsọ,
\q1 “Ka bụ nhne me kwno znarnị ị n'esilawụru ele bụ́o ele Ju,
\q2 m jọogwnunu rẹwhna ị eri.”
\m 
\v 10 Ọ kaa, berere,
\q1 “Anụ snornu rụmu Chiokike nwụdna, anụ ele bụ́o ele Ju.”
\m 
\v 11 Ọ kaa, berere,
\q1 “Anụ ja Nyenwe aị, kpakara ele bụ́o ele Ju,
\q2 kpakara ele badnụ gwnụnu a eri ọznarni.”
\m 
\v 12 Berere kwno, Azaya karụ,
\q1 “Otu Badnụ jeehi n'ẹbnurnu Jesi va,
\q2 o jeelizọ chị kpakara mbam,
\q1 ele bụ́o ele Ju jeelekwasị a anya.”
\p 
\v 13 Kịtna, Chiokike ke olile anya gweru ovu ọso nụ udno mejite ọkwnata mkpọma anụ nụ rime a, ma olile anya anụ nooso oso hite nụ rikne Enine Nsọ.
\s1 Pọlu nye izi ele bụ́o ele Ju
\p 
\v 14 Rụmu nda m, m magwụ m nụ nhne ọma zị nụ mkpọma anụ. Anụ magwụ kpakara nhne ka nkarị nkarị, ke jeeme anụ nwernu rikne neeznitaru ẹhni anụ nhne.
\v 15 M ji m anya siri rikne gbanụ anụ ọkwukwo, ma anụ chenwanya agwna nhne, kwnornu nụ oru Chiokike nyernu m.
\v 16 Chiokike mernu m nye izi Karaịsi Jizọsi, nye nọornunu ele bụ́o ele Ju ẹrnu, nye naakwa arịohna, nọokpo okwo izi ọma Chiokike, ma ele bụ́o ele Ju bụru nhne arịohna Chiokike jeegweru, ke Enine Nsọ bịtaru nsọ.
\p 
\v 17 Kam kpayarụ, m ji m ẹrnu m naanya risi nụ rime Karaịsi Jizọsi nhne gbasịri Chiokike.
\v 18 M jóokwu nhne berere karụ nhne Karaịsi mernu hite n'aka m, o duru ele bụ́o ele Ju be bụru ele noobnonu Chiokike nsnị hite n'ikwu-ọnu m nụ ẹrnu m.
\v 19 Hite nụ rikne nhne ọgba akebne nụ ẹrnu ndu-ẹhni ke Enine Chiokike hite nụ Jerusẹlem du Ilirikom, m nọokpo okwo izi ọma gbasịri Karaịsi n'apna zuru ozu.
\p 
\v 20 Ọ bụ nhne zị nụ mkpọma m o zni izi ọma hne be nụ́na nhne gbasịri Karaịsi, ma m gharụ m o wu ọro n'olu ntụ-ẹli ọro nye berere.
\v 21 Lele kpa be gbarụ a n'ọkwukwo nsọ,
\q1 “Ele be kánnụ be nhne gbasịri a jọowhnurnu,
\q2 ele nụ́na nhne gbasịri a jọoghohia.”
\p 
\v 22 Kam kpayarụ, be kwéle me vakwnusi anụ.
\s1 Pọlu marnụ mmụma // o zne Rom
\p 
\v 23 Kọvu kịtna, ọ zá nhne me jọornu nụ kpakara ẹli ka, ọ nọogwnu m ọ whnụ anụ anya agịda awha ka.
\v 24 M jeeme kpam kịtna, m jọowhnu anụ kpa me neezne Sipeni. Anụ jeeyinu m aka n'izne m, ma me nụ anụ dazịkwole ige matị.
\v 25 Kọvu kịtna, m neezne Jerusẹlem kwnornu ele ke Chiokike zị pịi.
\v 26 Kwnornu nụ ọ masịri ọgbako Chiokike ke zị nụ Masidonia nụ Akaya o gweya nhne be jeekesi ele mboni zị n'esilawụru rụmu Chiokike ke zị nụ Jerusẹlem.
\v 27 Ọ masịri be o yinu be aka, kọvu ezi ọka zị a bụ ka, ọ bụ ẹrnu zịnu be o yinu ele mboni wam aka, kwnornu nụ ele Ju nụ ele bụ́o ele Ju neekerita ngọzi ke enine, ele bụ́o ele Ju kwesiri o kesi ele Ju ngọzi ke ẹkwnu be.
\v 28 Nga me rnụkparu ẹrnu ka, nyega be nhne be tụhiaru, m jọowhnu anụ nga me neezne Sipeni.
\v 29 M magwụ m nụ nga me jaava, m jeeji agịda ngọzi Karaịsi va.
\p 
\v 30 M naarịasno anụ, rụmu nda m, hite nụ Nyenwe aị Jizọsi Karaịsi nụ ọwhnun'anya ke Enine Nsọ, anụ snornu m kpesi okpukpe rikne nụ ruwhnu Chiokike kwnornu nhne me nọowhnu.
\v 31 Anụ kpe okpukpe ma be dọhia m n'aka ele kwé ekwe zị nụ Judiya, ma ele Chiokike zị nụ Jerusẹlem nabnarnụ ẹrnu m n'esilawụru be,
\v 32 ma hite n'echiche Chiokike, m jeeji snarnịma vakwnusi anụ, ma me nụ anụ dazịrikota nụ mkpọma ọma.
\v 33 Chiokike ke udno dazịnu kpakara anụ. Amịm.
\c 16
\s1 Obekwu ikwu Pọlu
\p 
\v 1 M neegesi anụ nwene aị rinya Febi, ke nọornunu ọgbako Chiokike ke zị nụ Kẹnkiria ẹrnu.
\v 2 Anụ bikno nabnanya a nụ rẹwhna Nyenwe aị lele kpa rụmu Chiokike kwesiri, anụ yisinu a aka nụ nhne ọbula zị mkpa, kwnornu nụ ọ bụ nye ovu ọma neeyinu agịda ele berere aka ma me masị.
\p 
\v 3 Anụ bekwu Prisila nụ Akwịla, ele ẹrnu ibne m, ele me nụ be sno nọornunu Karaịsi Jizọsi ẹrnu.
\v 4 Be gweru bụdnu be bịta nụ nhne oze bụdnu nụ risi m, m nọotnu be mmamma, ọ bụ́o me nụ nsnụnu m kpọi, kọvu kpakara ọgbako Chiokike zị n'ẹli ele bụ́o ele Ju nọotu masịnu be mmamma.
\v 5 Anụ bekwu ọgbako Chiokike zị n'ọro be. Anụ bekwu enyi m me whnụrnu n'anya Epenetusi, nye mbọm ke hi n'Esia kweru nụ Karaịsi.
\p 
\v 6 Anụ bekwu Meri nye rnụnu anụ agịda ẹrnu.
\p 
\v 7 Anụ bekwu Andọronikusi nụ Junịasi, ele Ju ibne m me nụ be zị n'ikelu, be bụ ele badnụ marnụ nkarị nkarị n'esilawụru ele izi, be beru m ọsno mahịa Karaịsi.
\p 
\v 8 Anụ bekwu Ampilatusi, nye me whnụrnu n'anya nụ rime Nyenwe aị.
\v 9 Anụ bekwu Uribanusi nye ẹrnu ibne aị n'ẹrnu Karaịsi, nụ Sitakisi enyi ọma m.
\p 
\v 10 Anụ bekwu Apẹlesi nye be kparụ iru, o whe nụ Karaịsi.
\p Anụ bekwu ezi-nụ-ọro Arịsitobulosi.
\p 
\v 11 Anụ bekwu Erodiọni nye Ju ibne m. Anụ bekwu ele ezi-nụ-ọro Nakisọsi, ele zị nụ rime Nyenwe aị.
\p 
\v 12 Anụ bekwu Terifena nụ Terifosa ele ẹrnu nụ rime Nyenwe aị, nụ nye me whnụrnu n'anya bụ Pesisi nye ẹrnu nụ rime Nyenwe aị.
\p 
\v 13 Anụ bekwu Rufọsi, nye ẹrnu Nyenwe aị họhiaru. Anụ bekwu nne a, nye bụ masị nne m.
\p 
\v 14 Anụ bekwu Asịkiritosi, Filegọni, Hẹmisi, Patirọbasi, Hẹmasi nụ kpakara rụmu nda anụ nụ be zị.
\p 
\v 15 Anụ bekwu Filologosi nụ Julịa, nụ Nerusi nụ nwene a rinya, nụ Olimpasi nụ kpakara rụmu Chiokike be nụ be zị.
\v 16 Anụ gweru obekwu ikwu nsọ ke rụmu nda bekwurita ẹhni anụ. Kpakara ọgbako Chiokike neebekwu anụ.
\s1 Ezni ipne-aznụ Pọlu
\p 
\v 17 Rụmu nda m, anụ bikno, anya dụ anụ ẹli gbasịri ele neegweya okewa nụ naakpahie ọkwnata ovu ele badnụ anya, ele neezni nhne ke neemegidne iznizni anụ nahịaru. Anụ neeze be.
\v 18 Kwnornu nụ ele nụ kpam zá nọornunu Karaịsi ẹrnu, kọvu rụwho be. Hite n'ọnu bịri bịri be nụ ọka sọ n'ọnu, be nooduwhu ele zị snam nụ mkpọma.
\v 19 Kpakara ọhna nụrnu obno nsnị anụ, ke mernu mkpọma sọ m n'ọnu k'agịda kwnornu anụ. Kọvu m pioru m anụ bụru ele nwernu akọniche hne nhne ọma zị, ele ikpe mána hne nhne ọjo zị.
\p 
\v 20 N'ige matị Chiokike ke udno jọozogbu Ekwensu nụ mkpururu ọchi anụ. Oru ke Nyenwe aị Jizọsi dazịnu anụ.
\p 
\v 21 Timoti nye ẹrnu ibne m neebekwu anụ, ya nụ Lusọsi, nụ Jasoni nụ Sọsipata ele Ju ibne m.
\p 
\v 22 Mawa, Tetiọsi, nye gbarụ ọkwukwo ka neebekwu anụ nụ rime Nyenwe aị.
\p 
\v 23 Gayọsi nye me zị n'ọro a, nye ọgbako Chiokike zị n'ọro a, neebekwu anụ. Ọchi-ịwai ọhna bụ Erasịtosi nụ nwene aị rukna Kwatusi neebekwu anụ. [
\v 24 Oru ke Nyenwe aị Jizọsi Karaịsi dazịnu kpakara anụ. Amịm.]
\p 
\v 25 Ọznarni zịnu Chiokike nye nwernu rikne mee anụ gwuzoru lele kpa izi ọma me neezni kwuru, nụ ọkpo okwo Jizọsi Karaịsi, lele kpa okpume nhne gwnarnụ agwna ke zị omimi ogologo ige wheru ewhe.
\v 26 Kọvu be kpumernu a hite nụ nhne ele ọwhnurninya gbarụ n'ọkwukwo hite n'iwu Chiokike zị ọkwnukokwnu. O mernu kpakara mbam mahịa, ma be kweru bnonu a nsnị.
\v 27 Ọznarni zịnu Chiokike nye nụ nsnụnu a bụ nye akọ hite nụ Jizọsi Karaịsi ọkwnukokwnu. Amịm.
