\v 20 \w Jehoiada|strong="H3077"\w*’s \w son|strong="H1121"\w* \w Benaiah|strong="H1141"\w*, \w from|strong="H3381"\w* \w Kabzeel|strong="H6909"\w* \add town\add*, \w also|strong="H1121"\w* \w did|strong="H3117"\w* \w great|strong="H7227"\w* \w deeds|strong="H6467"\w*. \w He|strong="H1931"\w* \w killed|strong="H5221"\w* \w two|strong="H8147"\w* \w of|strong="H1121"\w* \w the|strong="H5221"\w* best \w warriors|strong="H1121"\w* \w from|strong="H3381"\w* \w the|strong="H5221"\w* \w Moab|strong="H4124"\w* people-group. \w Also|strong="H1121"\w*, \w he|strong="H1931"\w* \w went|strong="H3381"\w* \w down|strong="H3381"\w* \w into|strong="H3381"\w* \w a|strong="H3068"\w* pit \w on|strong="H3117"\w* \w a|strong="H3068"\w* \w day|strong="H3117"\w* \w when|strong="H3117"\w* \w snow|strong="H7950"\w* \w was|strong="H1931"\w* falling, \w and|strong="H1121"\w* \w killed|strong="H5221"\w* \w a|strong="H3068"\w* lion \w there|strong="H3117"\w*.
\v 21 \w He|strong="H1931"\w* \w also|strong="H3027"\w* \w killed|strong="H2026"\w* \w a|strong="H3068"\w* huge soldier \w from|strong="H3381"\w* \w Egypt|strong="H4713"\w* \w who|strong="H1931"\w* \w carried|strong="H1497"\w* \w a|strong="H3068"\w* \w spear|strong="H2595"\w*. Benaiah \add had only\add* \w his|strong="H5221"\w* \w club|strong="H7626"\w*, \w but|strong="H5221"\w* \w he|strong="H1931"\w* \w attacked|strong="H5221"\w* \w the|strong="H5221"\w* giant \w with|strong="H3381"\w* \w it|strong="H1931"\w*. \w Then|strong="H5221"\w* \w he|strong="H1931"\w* \w snatched|strong="H1497"\w* \w the|strong="H5221"\w* \w spear|strong="H2595"\w* \w from|strong="H3381"\w* \w the|strong="H5221"\w* man’s \w hand|strong="H3027"\w* \w and|strong="H3027"\w* \w killed|strong="H2026"\w* \w him|strong="H5221"\w* \w with|strong="H3381"\w* \w his|strong="H5221"\w* \w own|strong="H3027"\w* \w spear|strong="H2595"\w*.
\v 22 \w Those|strong="H1121"\w* \w are|strong="H1121"\w* \add some of\add* \w the|strong="H6213"\w* \w things|strong="H7969"\w* \w that|strong="H1121"\w* \w Benaiah|strong="H1141"\w* \w did|strong="H6213"\w*. \w As|strong="H6213"\w* \w a|strong="H3068"\w* result, \w he|strong="H6213"\w* became \w famous|strong="H8034"\w*, \w like|strong="H6213"\w* \w the|strong="H6213"\w* \w three|strong="H7969"\w* greatest \w warriors|strong="H1368"\w* \w were|strong="H1121"\w*.
