\s1 Cangti aka Tuh  
\p
\v 4 \w Khopuei|strong="G4172"\w* \w takuem|strong="G2596"\w* kah \w hlangping|strong="G3793"\w* te \w muep|strong="G4183"\w* \w capit|strong="G4896"\w* uh tih \w a|strong="G0846"\w* \w taengla|strong="G4314"\w* ha \w pawk|strong="G1975"\w* uh.  
\v 5 Te vaengah \w nuettahnah|strong="G3850"\w* \w neh|strong="G1223"\w*, \wj “Cangti aka \+w tuh|strong="G4687"\+w* \+w tah|strong="G3588"\+w* \+w a|strong="G0846"\+w* \+w cangtii|strong="G4703"\+w* \+w tuh|strong="G4687"\+w* hamla \+w cet|strong="G1831"\+w*. \+w Tedae|strong="G2532"\+w* \+w a|strong="G0846"\+w* \+w tuh|strong="G4687"\+w* \+w vaengah|strong="G1722"\+w* a \+w ngen|strong="G3303"\+w* \+w tah|strong="G3739"\+w* \+w long|strong="G3598"\+w* \+w taengah|strong="G3844"\+w* \+w tla|strong="G4098"\+w*. Te \+w dongah|strong="G2532"\+w* a \+w taelh|strong="G2662"\+w* uh \+w tih|strong="G2532"\+w* \+w vaan|strong="G3772"\+w* \+w kah|strong="G3588"\+w* \+w vaa|strong="G4071"\+w* \+w loh|strong="G3588"\+w* a \+w kueh|strong="G2719"\+w*\wj*.  
