\v 10 \w Por|strong="G1223"\w* \w eso|strong="G1223"\w*, \w si|strong="G1437"\w* voy, \w recordaré|strong="G5279"\w* \w las|strong="G3588"\w* \w obras|strong="G2041"\w* \w que|strong="G3588"\w* \w hace|strong="G4160"\w*: habla \w contra|strong="G1909"\w* \w nosotros|strong="G2249"\w* \w con|strong="G1223"\w* \w malas|strong="G4190"\w* \w palabras|strong="G3056"\w*. \w Y|strong="G2532"\w* \w no|strong="G3361"\w* contento \w con|strong="G1223"\w* \w esto|strong="G3778"\w*, \w no|strong="G3361"\w* \w recibe|strong="G1926"\w* \w a|strong="G1909"\w* \w los|strong="G3588"\w* hermanos; \w además|strong="G2532"\w*, \w impide|strong="G2967"\w* \w que|strong="G3588"\w* \w los|strong="G3588"\w* reciban \w los|strong="G3588"\w* \w que|strong="G3588"\w* quieren hacerlo, \w y|strong="G2532"\w* \w los|strong="G3588"\w* expulsa \w de|strong="G1909"\w* \w la|strong="G3588"\w* \w iglesia|strong="G1577"\w*.   
\p
\v 11 Amado, \w no|strong="G3756"\w* imites \w lo|strong="G3588"\w* \w malo|strong="G2556"\w*, \w sino|strong="G3361"\w* \w lo|strong="G3588"\w* bueno. \w El|strong="G3588"\w* \w que|strong="G3588"\w* hace \w lo|strong="G3588"\w* bueno \w es|strong="G3756"\w* \w de|strong="G1537"\w* \w Dios|strong="G2316"\w*; \w el|strong="G3588"\w* \w que|strong="G3588"\w* hace \w lo|strong="G3588"\w* \w malo|strong="G2556"\w* \w no|strong="G3756"\w* ha visto \w a|strong="G1537"\w* \w Dios|strong="G2316"\w*.   
