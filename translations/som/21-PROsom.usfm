\id PRO  
\h MAAHMAAHYADII 
\mt1 MAAHMAAHYADII 
\c 1  
\s1 Dulucda Kitaabka 
\q1  
\v 1 Kuwanu waa maahmaahyadii Sulaymaan ina Daa'uud oo ahaa boqorkii reer Binu Israa'iil, 
\q1  
\v 2 Wuxuu u qoray si loo ogaado xigmadda iyo edbinta, 
\q1 Oo loo garto erayada waxgarashada, 
\q1  
\v 3 In la helo edbinta ku saabsan xigmadda, 
\q1 Iyo xaqnimada iyo garta iyo caaddilnimada; 
\q1  
\v 4 Si miyir loo siiyo garaadlaawaha, 
\q1 Oo aqoon iyo digtoonaanna loo yeelo ninka dhallinyarada ah. 
\q1  
\v 5 Ninkii caqli lahu wuu maqli doonaa, oo wuxuu korodhsan doonaa waxbarasho, 
\q1 Oo ninkii garaad lahuna wuxuu qabsan doonaa talada wanaagsan, 
\q1  
\v 6 Si lagu garto maahmaahda, iyo micnaynta, 
\q1 Iyo hadallada kuwa caqliga leh iyo xujooyinkooda. 
\q1  
\v 7 Waxaa aqoonta ugu horreeya Rabbiga ka cabsashadiisa; 
\q1 Laakiinse nacasyadu waxay quudhsadaan xigmadda iyo edbinta. 
\s1 Guubaabinta Xigmadda 
\s2 Ka-digidda Soo Jiidashada Xun 
\q1  
\v 8 Wiilkaygiiyow, edbinta aabbahaa maqal, 
\q1 Oo amarka hooyadaana ha ka tegin, 
\q1  
\v 9 Waayo, waxay madaxaaga u noqon doonaan wax sharraxsan, 
\q1 Oo waxay kuu noqon doonaan silsilado qoorta kuu sudhan. 
\q1  
\v 10 Wiilkaygiiyow, haddii dembilayaal ku sasabtaan, 
\q1 Ha oggolaan. 
\q1  
\v 11 Hadday kugu yidhaahdaan, Na soo raac, 
\q1 Aan gaadno inaynu dhiig daadinno, 
\q1 Oo aynu sababla'aan kuwa aan eedda lahayn si qarsoon ugu dhuumanno; 
\q1  
\v 12 Oo iyagoo nool aynu u liqno sida qabriga oo kale, 
\q1 Dhammaantoodna aan juq siinno sida kuwa yamayska ku dhaca; 
\q1  
\v 13 Waxaynu heli doonnaa maal qaali ah oo cayn kasta ah, 
\q1 Oo guryaheennana waxaynu ka buuxsan doonnaa booli; 
\q1  
\v 14 Nasiibkaaga iskula kaaya soo dar, 
\q1 Oo kulligeenna aynu kiishad qudha wada lahaanno; 
\q1  
\v 15 Wiilkaygiiyow, iyaga jidka ha la marin; 
\q1 Oo cagtaadana wadiiqadooda dib uga jooji; 
\q1  
\v 16 Waayo, cagahoodu waxay u ordaan shar, 
\q1 Oo waxay u degdegaan inay dhiig daadiyaan. 
\q1  
\v 17 Waayo, waa waxtarla'aan dabinka loo dhigaa 
\q1 Iyadoo ay shimbirtu u jeeddo; 
\q1  
\v 18 Iyagu waxay u gaadaan si dhiiggooda loo daadiyo, 
\q1 Oo waxay si qarsoon ugu dhuuntaan si naftooda looga qaado. 
\q1  
\v 19 Sidaas oo kalay yihiin jidadka mid kasta oo faa'iido u hunguri weyn, 
\q1 Oo nafta ka qaada kuwa leh. 
\s2 Dhiirrigelinta Xigmad-Qaadashada 
\q1  
\v 20 Xigmaddu aad bay uga qaylisaa jidka; 
\q1 Oo codkeedana waxay kor uga qaaddaa bannaanka; 
\q1  
\v 21 Waxay ka qaylisaa meesha suuqa ugu weyn; 
\q1 Oo iridda magaalada laga soo galo 
\q1 Ayay erayadeeda kaga hadashaa, iyadoo leh, 
\q1  
\v 22 Kuwiinna garaadlaawayaasha ahow, ilaa goormaad garaadla'aanta sii jeclaanaysaan? 
\q1 Oo kuwa wax quudhsadaana, ilaa goormay quudhsashadooda ku sii farxayaan? 
\q1 Nacasyaduna, ilaa goormay aqoonta sii necbaanayaan? 
\q1  
\v 23 Canaantayda u soo noqda; 
\q1 Bal eega, anigu waxaan idinku shubi doonaa ruuxayga, 
\q1 Oo waxaan idin ogeysiin doonaa erayadayda. 
\q1  
\v 24 Anigu waan idiin yeedhay, laakiinse waad i diiddeen; 
\q1 Oo anigu gacantaydaan soo fidiyey, oo ninnana dan kama yeelan; 
\q1  
\v 25 Laakiinse idinku taladaydii oo dhan waad fududaysateen, 
\q1 Oo canaantaydiina ma aydin doonaynin; 
\q1  
\v 26 Sidaas daraaddeed aniguna waan idinku qosli doonaa markay belaayo idinku dhacdo; 
\q1 Waanan idinku majaajiloon doonaa markay cabsiyu idinku soo degto; 
\q1  
\v 27 Markay cabsidiinnu u timaado sida duufaan oo kale, 
\q1 Oo belaayadiinnuna u timaado sida dabayl cirwareen ah; 
\q1 Oo dhibaato iyo cidhiidhi idinku yimaadaan. 
\q1  
\v 28 Markaasay ii yeedhan doonaan, laakiinse anigu uma aan jawaabi doono; 
\q1 Oo horay ii doondooni doonaan, laakiinse ima ay heli doonaan; 
\q1  
\v 29 Waayo, waxay nebcaadeen aqoonta, 
\q1 Oo Rabbiga ka cabsashadiisana ma ay dooran; 
\q1  
\v 30 Iyagu taladaydii innaba ma ay doonaynin; 
\q1 Oo canaantaydii oo dhanna way quudhsadeen; 
\q1  
\v 31 Haddaba iyagu waxay cuni doonaan midhihii jidkooda, 
\q1 Oo waxay ka dhergi doonaan taladoodii. 
\q1  
\v 32 Waayo, garaadlaawayaasha dibunoqoshadooda ayaa iyaga dili doonta, 
\q1 Oo nacasyadana waxaa baabbi'in doonta barwaaqadooda. 
\q1  
\v 33 Laakiinse ku alla kii aniga i maqlaa, ammaan buu u fadhiyi doonaa, 
\q1 Wuuna xasilloonaan doonaa, isagoo aan shar ka cabsanaynin. 
\c 2  
\s2 Faa'iidada Xigmadda 
\q1  
\v 1 Wiilkaygiiyow, haddaad erayadayda aqbashid, 
\q1 Oo aad amarradayda qalbigaaga ku haysatid, 
\q1  
\v 2 Si aad dhegta xigmadda ugu dhigtid, 
\q1 Oo aad qalbigaagana waxgarashada ugu qabatid; 
\q1  
\v 3 Haddaad wax-kala-garashada ka daba qaylisid, 
\q1 Oo aad codkaaga waxgarashada kor ugu qaaddid; 
\q1  
\v 4 Haddaad iyada u raadisid sida lacagta oo kale, 
\q1 Oo aad u doondoontid sida maal qarsoon, 
\q1  
\v 5 Markaas waxaad garan doontaa Rabbiga ka cabsashadiisa, 
\q1 Oo waxaad heli doontaa aqoonta Ilaah. 
\q1  
\v 6 Waayo, Rabbigu isagaa bixiya xigmadda, 
\q1 Oo afkiisa waxaa ka soo baxa aqoonta iyo waxgarashada. 
\q1  
\v 7 Isagu kuwa xaqa ah xigmad buu u kaydiyaa, 
\q1 Oo kuwa daacadnimada u socdana waa u gaashaan. 
\q1  
\v 8 Isagu wuxuu dhawraa waddooyinka garta, 
\q1 Oo wuxuu xannaaneeyaa jidka quduusiintiisa. 
\q1  
\v 9 Markaasaad garan doontaa xaqnimada, iyo garta, 
\q1 Iyo caaddilnimada, iyo jid kasta oo wanaagsan. 
\q1  
\v 10 Waayo, waxaa qalbigaaga soo geli doonta xigmadda, 
\q1 Oo aqoontuna waxay ka farxin doontaa naftaada; 
\q1  
\v 11 Digtoonaanta baa ku xanaanayn doonta, 
\q1 Oo waxaa ku dhawri doonta waxgarashada, 
\q1  
\v 12 Si lagaaga samatabbixiyo jidka kan sharka ah, 
\q1 Iyo dadka waxyaalaha qalloocan ku hadla, 
\q1  
\v 13 Oo qummanaanta waddooyinkeeda ka taga, 
\q1 Si ay jidadka gudcurka ugu socdaan, 
\q1  
\v 14 Oo ay ku reyreeyaan inay xumaan falaan, 
\q1 Oo ay qalloocnaanta kan sharkaa ku farxaan; 
\q1  
\v 15 Oo jidadkoodu maroorsan yihiin, 
\q1 Oo waddooyinkooduna qalloocan yihiin, 
\q1  
\v 16 In lagaa samatabbixiyo naagta qalaad, 
\q1 Xataa naagta qalaad oo hadalladeeda kugu sasabata, 
\q1  
\v 17 Taasoo ka tagta horseedkii yaraanteeda, 
\q1 Oo illowda axdigii Ilaaheeda; 
\q1  
\v 18 Waayo, gurigeedu wuxuu ku foororaa dhimasho, 
\q1 Oo waddooyinkeeduna waxay ku dhaadhacaan kuwii dhintay. 
\q1  
\v 19 Kuwa iyada u gala midkoodna sooma noqdo, 
\q1 Oo waddooyinka noloshana ma ay helaan. 
\q1  
\v 20 Waa inaad ku socotid jidka dadka wanaagsan, 
\q1 Oo aad dhawrtid waddooyinka kuwa xaqa ah. 
\q1  
\v 21 Waayo, kuwa qummanu dhulkay fadhiyi doonaan, 
\q1 Oo kuwa kaamilka ahuna way sii joogi doonaan. 
\q1  
\v 22 Laakiinse kuwa sharkaa waa laga gooyn doonaa dhulka, 
\q1 Oo khaayinnadana waa laga rujin doonaa. 
\c 3  
\s2 Faa'iidada Kale Ee Xigmadda 
\q1  
\v 1 Wiilkaygiiyow, waxbariddayda ha illoobin, 
\q1 Laakiin qalbigaagu amarradayda ha hayo, 
\q1  
\v 2 Waayo, iyagu waxay kuu kordhin doonaan 
\q1 Maalmo badan iyo cimri dheer iyo nabad. 
\q1  
\v 3 Naxariista iyo runtu yaanay kaa tegin, 
\q1 Iyaga qoorta ku xidh, 
\q1 Oo looxa qalbigaaga ku qor, 
\q1  
\v 4 Sidaasaad Ilaah iyo dadka hortooda 
\q1 Nicmo iyo sharaf uga heli doontaa. 
\q1  
\v 5 Qalbigaaga dhammaantii Rabbiga ku aamin, 
\q1 Oo waxgarashadaadana ha isku hallayn. 
\q1  
\v 6 Jidadkaaga oo dhan isaga ku qiro, 
\q1 Oo isna waddooyinkaaguu toosin doonaa. 
\q1  
\v 7 Ha isla weynaan; 
\q1 Rabbiga ka cabso; oo sharka ka fogow. 
\q1  
\v 8 Taasu waxay xundhurtaada u noqon doontaa caafimaad, 
\q1 Oo lafahaagana waxay u noqon doontaa dhuux. 
\q1  
\v 9 Rabbiga ku murwee maalkaaga 
\q1 Iyo midhaha ugu horreeya waxa kuu kordha oo dhan; 
\q1  
\v 10 Sidaasay maqsinnadaadu barwaaqo uga buuxsami doonaan, 
\q1 Macsarooyinkaaguna waxay la buuxdhaafi doonaan khamri cusub. 
\q1  
\v 11 Wiilkaygiiyow, Rabbiga edbintiisa ha quudhsan, 
\q1 Oo canaantiisana ha ka daalin, 
\q1  
\v 12 Waayo, Rabbigu ninkuu jecel yahay wuu canaantaa 
\q1 Sida aabbe u canaanto wiilkii uu ku faraxsan yahay. 
\q1  
\v 13 Waxaa barakaysan ninkii xigmadda hela, 
\q1 Iyo ninkii waxgarashada mulkiya. 
\q1  
\v 14 Waayo, baayacmushtarigeedu waa ka sii wanaagsan yahay baayacmushtariga lacagta, 
\q1 Oo faa'iidadeeduna waa ka sii wanaagsan tahay dahabka saafiga ah. 
\q1  
\v 15 Way ka sii qaalisan tahay luulka, 
\q1 Oo waxaad jeclaan kartid oo dhanna iyada lalama simo. 
\q1  
\v 16 Gacanteeda midig waxaa ku jira cimri dheeri; 
\q1 Gacanteeda bidixna waxaa ku jira hodonnimo iyo sharaf. 
\q1  
\v 17 Jidadkeedu waa jidad farxadeed, 
\q1 Oo waddooyinkeeda oo dhammuna waa nabad. 
\q1  
\v 18 Kuwii iyada qabsada waxay u tahay geed nololeed; 
\q1 Oo waxaa barakaysan ku alla kii iyada xajista. 
\q1  
\v 19 Rabbigu wuxuu dhulka ku aasaasay xigmadda, 
\q1 Oo samooyinkana wuxuu ku dhisay waxgarashada. 
\q1  
\v 20 Aqoontiisa ayaa moolalku ku dillaaceen, 
\q1 Oo cirkuna wuxuu soo daadiyaa sayax. 
\q1  
\v 21 Wiilkaygiiyow, waxyaalahanu yaanay indhahaaga ka tegin. 
\q1 Xigmadda iyo digtoonaanta xajiso. 
\q1  
\v 22 Sidaasay naftaada nolol ugu noqon doonaan, 
\q1 Qoortaadana nimco. 
\q1  
\v 23 Markaasaad jidkaaga ammaan ku mari doontaa, 
\q1 Oo cagtaaduna ma turunturoon doonto. 
\q1  
\v 24 Markaad jiifsatidna ma cabsan doontid; 
\q1 Haah, waad jiifsan doontaa, oo hurdadaaduna way kuu macaanaan doontaa. 
\q1  
\v 25 Ha ka baqin cabsi kedis ah, 
\q1 Iyo baabbi'inta kuwa sharka leh toona markii ay timaado. 
\q1  
\v 26 Waayo, Rabbigu wuxuu kuu ahaan doonaa Kan aad ku kalsoonaan karto. 
\q1 Oo cagtaadana wuu dhawri doonaa si aan loo qabsan. 
\q1  
\v 27 Wanaag ha u diidin kuwa uu ku habboon yahay in loo sameeyo, 
\q1 Markaad awood u leedahay inaad u samayso. 
\q1  
\v 28 Deriskaaga ha ku odhan, Tag oo soo noqo, 
\q1 Berri baan ku siin doonaaye, 
\q1 Haddii aad markaas haysid. 
\q1  
\v 29 Deriskaaga innaba xumaan ha u fikirin, 
\q1 Maxaa yeelay, isagu nabadgelyo buu kuu ag fadhiyaa. 
\q1  
\v 30 Ninna sababla'aan ha kula diririn, 
\q1 Haddaanu xumaan kugu samayn. 
\q1  
\v 31 Ha ka hinaasin nin dadka dulmiya, 
\q1 Oo jidadkiisana midnaba ha dooran. 
\q1  
\v 32 Maxaa yeelay, kuwa qalloocanu waa u karaahiyo Rabbiga, 
\q1 Laakiinse wuxuu sir la leeyahay kuwa qumman. 
\q1  
\v 33 Rabbigu wuxuu inkaaraa guriga kii shar leh, 
\q1 Laakiinse rugta kuwa xaqa ah wuu barakeeyaa. 
\q1  
\v 34 Hubaal kuwa wax quudhsada ayuu isagu quudhsadaa, 
\q1 Kuwa is-hoosaysiiyase nicmuu siiyaa. 
\q1  
\v 35 Kuwa xigmadda leh waxay dhaxli doonaan sharaf, 
\q1 Laakiinse nacasyadu waxay u dallici doonaan ceeb. 
\c 4  
\s2 Xigmaddu Waa Sarraysaa 
\q1  
\v 1 Wiilashoy, aabbe edbintiisa maqla, 
\q1 Oo u jeesta inaad wax garataan. 
\q1  
\v 2 Waayo, anigu waxaan idin siiyaa tacliin wanaagsan, 
\q1 Haddaba cilmigayga ha ka tegina. 
\q1  
\v 3 Waayo, aniguba waxaan aabbahay u ahaa wiil, 
\q1 Oo mid yar oo bacbac ah oo madi ah ayaan u ahaa hooyaday. 
\q1  
\v 4 Isagu wax buu i baray, oo wuxuu igu yidhi, 
\q1 Qalbigaagu erayadayda ha xajisto; 
\q1 Amarradaydana dhawr, oo waad noolaan doontaa. 
\q1  
\v 5 Xigmadda doono, waxgarashadana doono; 
\q1 Hana illoobin, oo erayada afkaygana dib ha uga noqon. 
\q1  
\v 6 Xigmadda ha ka tegin, oo way ku nabad gelin doontaa. 
\q1 Jeclow, oo way ku dhawri doontaa. 
\q1  
\v 7 Xigmaddu wax walbay ugu horraysaa, sidaas daraaddeed xigmadda doono; 
\q1 Wax kastoo aad hesho weliba waxgarasho doono. 
\q1  
\v 8 Iyada sarraysii, oo iyana way ku dallicin doontaa; 
\q1 Oo sharaf bay kuu yeeli doontaa markaad iyada isku duubtid. 
\q1  
\v 9 Iyadu waxay madaxaaga siin doontaa wax sharraxsan, 
\q1 Oo waxayna kuu yeeli doontaa taaj quruxsan. 
\q1  
\v 10 Wiilkaygiiyow, maqal oo hadalladayda aqbal. 
\q1 Oo sannadaha cimrigaaguna way badnaan doonaan. 
\q1  
\v 11 Anigu waxaan ku baray jidkii xigmadda; 
\q1 Oo waxaan kugu hoggaamiyey waddooyinkii qummanaanta. 
\q1  
\v 12 Markii aad socotid tallaabooyinkaagu cidhiidhi ma noqon doonaan, 
\q1 Oo haddaad oroddidna ma turunturoon doontid. 
\q1  
\v 13 Edbinta xajiso, oo ha iska sii deyn; 
\q1 Hayso, waayo, iyadu waa noloshaada, 
\q1  
\v 14 Waddada kuwa sharka leh ha gelin, 
\q1 Oo jidka xumaanfalayaashana ha qaadin. 
\q1  
\v 15 Ka leexo, hana marin, 
\q1 Ka noqo oo hareer ka mar. 
\q1  
\v 16 Waayo, iyagu ma seexdaan haddaanay xumaan falin, 
\q1 Oo hurdadoodana waa laga qaadaa iyagoo cid kufiya mooyaane. 
\q1  
\v 17 Waayo, iyagu waxay cunaan kibistii sharnimada, 
\q1 Oo waxay cabbaan khamrigii dulmiga. 
\q1  
\v 18 Laakiinse waddada kuwa xaqa ahu waa sida iftiinka waaberiga oo kale, 
\q1 Kaas oo hadba soo kordha ilaa uu noqdo maalin cad. 
\q1  
\v 19 Jidka kuwa sharka lahuna waa sida gudcurka oo kale. 
\q1 Oo iyagu garan maayaan waxay ku turunturoodaan. 
\q1  
\v 20 Wiilkaygiiyow, erayadayda dhegayso, 
\q1 Oo hadalladaydana dhegta u dhig. 
\q1  
\v 21 Indhahaaga hortooda yaanay ka fogaan, 
\q1 Oo qalbigaaga dhexdiisa ku hayso, 
\q1  
\v 22 Waayo, iyagu waa u nolol kuwa hela, 
\q1 Oo jidhkooda oo dhanna waa u caafimaad. 
\q1  
\v 23 Digtoonaan qalbigaaga u dhawr, 
\q1 Waayo, isagay noloshu ka soo baxdaaye. 
\q1  
\v 24 Af qalloocan iska saar, 
\q1 Oo bushimo maroorsanna iska fogee. 
\q1  
\v 25 Indhahaagu qummaati wax ha u fiiriyeen, 
\q1 Oo indhahaaga daboolkooduna si toosan hortaada ha u eegeen. 
\q1  
\v 26 Waddada cagahaaga aad ugu fiirso, 
\q1 Oo jidadkaaga oo dhammuna ha toosnaadeen. 
\q1  
\v 27 Xagga midigta iyo xagga bidixda toona ha u leexan, 
\q1 Oo cagtaadana xumaanta ka fogee. 
\c 5  
\s2 Digniin Ka Gees Ah Gogoldhaafka 
\q1  
\v 1 Wiilkaygiiyow, xigmaddayda dhegayso, 
\q1 Oo waxgarashadaydana dhegta u dhig; 
\q1  
\v 2 Si aad digtoonaan u dhawrtid, 
\q1 Oo ay bushimahaaguna aqoon u xejiyaan. 
\q1  
\v 3 Waayo, naagta qalaad bushimaheedu waxay daadiyaan malab, 
\q1 Oo afkeeduna saliid buu ka sii macaan yahay, 
\q1  
\v 4 Laakiinse aakhirkeedu wuxuu u qadhaadh yahay sida geed dacareed oo kale, 
\q1 Wuuna af badan yahay sida seef laba af leh. 
\q1  
\v 5 Cagaheedu dhimashay ku dhaadhacaan, 
\q1 Oo tallaabooyinkeeduna waxay u jeedaan xagga She'ool, 
\q1  
\v 6 Waddada nolosha iyadu aad uguma fiirsato. 
\q1 Jidadkeedu waa leexleexdaan, oo garan kari maysid, 
\q1  
\v 7 Haddaba sidaas daraaddeed, wiilashoy, bal i maqla, 
\q1 Oo erayada afkayga ha ka tegina. 
\q1  
\v 8 Jidkaaga ka fogee iyada, 
\q1 Oo albaabka gurigeeda ha u dhowaan, 
\q1  
\v 9 Si aanad sharaftaada kuwa kale u siin, 
\q1 Oo aanad sannadahaaga kuwa caloosha adag u siin, 
\q1  
\v 10 Si aan shisheeyayaal maalkaaga uga dhergin; 
\q1 Oo aanay wixii aad u hawshootay guri ajnabi u gelin, 
\q1  
\v 11 Si aanad ugu dambaysta u barooran, 
\q1 Markay hilibkaaga iyo jidhkaaguba baabba'aan, 
\q1  
\v 12 Oo aad tidhaahdaan, Sidee baan edbin u nebcaaday, 
\q1 Oo qalbigayguna canaantii u quudhsaday! 
\q1  
\v 13 Codkii macallimiintaydii ma aan addeecin, 
\q1 Oo dhegtana uma aan dhigin kuwii wax i baray! 
\q1  
\v 14 Anigu waxaan u dhowaa inaan shar kasta falo 
\q1 Anigoo ku dhex jira shirka iyo ururka. 
\q1  
\v 15 Berkeddaada biyo ka cab, 
\q1 Oo ceelkaagana biyo qulqulaya ka cab. 
\q1  
\v 16 Ma hagaag baa in ilahaagu dibadda u daataan. 
\q1 Oo ay durdurraduna dariiqyada maraan? 
\q1  
\v 17 Iyagu ha ahaadeen kuwaaga oo keliya, 
\q1 Oo yaanay u ahaan shisheeyayaal adiga kula jira. 
\q1  
\v 18 Ishaadu ha barakaysnaato, 
\q1 Oo naagtaadii aad yaraanta ku guursatay ku faraxsanow. 
\q1  
\v 19 Iyadu ha kuu ahaato sida deerada jacaylka badan iyo sida cawsha quruxsan, 
\q1 Goor walbana naasaheedu ha ku deeqeen 
\q1 Oo had iyo goorna jacaylkeeda ku faraxsanow. 
\q1  
\v 20 Haddaba wiilkaygiiyow, bal maxaad naag qalaad ugu faraxsanaanaysaa, 
\q1 Maxaadse naag shisheeye ah naasaheeda u qabsanaysaa? 
\q1  
\v 21 Waayo, jidadka dadku waxay hor yaalliin indhaha Rabbiga 
\q1 Oo isagaa fiiriya waddooyinkiisa oo dhan. 
\q1  
\v 22 Kan sharka leh waxaa qabsan doonta xumaantiisa, 
\q1 Oo waxaa isaga lagu soo xidhi doonaa xadhkaha dembigiisa. 
\q1  
\v 23 Wuxuu u dhiman doonaa edbinla'aanta, 
\q1 Oo isagu wuxuu ku dhex amban doonaa badnaanta nacasnimadiisa. 
\c 6  
\s2 Digniin Ku Saabsan Nacasnimada 
\q1  
\v 1 Wiilkaygiiyow, haddaad deriskaaga dammiin u noqotid, 
\q1 Ama haddaad shisheeye gacanta dhaar ugu dhiibtid, 
\q1  
\v 2 Markaas waxaa lagugu dabay erayada afkaaga, 
\q1 Oo waxaa lagugu qabtay erayada afkaaga. 
\q1  
\v 3 Haddaba, wiilkaygiiyow, bal waxan samee oo isa samatabbixi, 
\q1 Waayo, gacantii deriskaagii waad gashay; 
\q1 U tag, oo is-hoosaysii, oo deriskaaga bari. 
\q1  
\v 4 Indhahaaga hurdo ha isugu keenin, 
\q1 Oo indhahaaga daboolkoodana lulo ha isugu qaban. 
\q1  
\v 5 Isu samatabbixi sida cawl gacanta ugaadhsadaha uga baxsato, 
\q1 Iyo sida shimbir gacanta shimbirdabaha uga baxsato. 
\q1  
\v 6 Kaaga caajiska ahow, bal qudhaanjada u tag, 
\q1 Oo bal jidadkeeda u fiirso oo caqli yeelo, 
\q1  
\v 7 Iyadoo aan lahayn madaxweyne, 
\q1 Sirkaal iyo taliye toona, 
\q1  
\v 8 Ayay guga cuntadeeda soo diyaarsataa, 
\q1 Oo quudkeedana waxay soo urursataa wakhtiga beeraha la goosto. 
\q1  
\v 9 Haddaba kaaga caajiska ahow, ilaa goormaad hurdaysaa? 
\q1 Goormaadse hurdadaada ka toosaysaa? 
\q1  
\v 10 Weliba, in yar baad seexataa, in yar baad lulootaa, 
\q1 Oo in yar baad gacmaha hurdo aawadeed u laabataa, 
\q1  
\v 11 Hadda caydhinimadaadu waxay u iman doontaa sida mid dad dhaca, 
\q1 Oo baahidaaduna waxay u iman doontaa sida nin hub wata. 
\q1  
\v 12 Qofkii waxmatare ah, iyo ninkii sharrow ahuba, 
\q1 Wuxuu ku socdaa af qalloocan; 
\q1  
\v 13 Indhihiisuu ku baaqaa, oo cagihiisuu ku hadlaa, 
\q1 Oo faruhuu wax ku baraa; 
\q1  
\v 14 Qalbigiisa qalloocnaan baa ku jirta, had iyo goorna wuxuu ku fikiraa shar, 
\q1 Oo wuxuu beeraa muran. 
\q1  
\v 15 Haddaba sidaas daraaddeed masiibadiisu degdeg bay u iman doontaa, 
\q1 Oo dhaqso buu u jabi doonaa, dawona ma leh. 
\q1  
\v 16 Waxaa jira lix waxyaalood oo uu Rabbigu neceb yahay, 
\q1 Haah, toddoba ayaa naftiisu aad u karahdaa, 
\q1  
\v 17 Waana indho kibir badan, carrab been sheega, 
\q1 Iyo gacmo dhiig aan eed lahayn daadiya, 
\q1  
\v 18 Qalbi male shar ah hindisa, 
\q1 Iyo cago xumaan ku degdega, 
\q1  
\v 19 Markhaati been ah oo been sheega, 
\q1 Iyo kii muran dad walaalo ah ku dhex beera. 
\s2 Digniin Ku Saabsan Sinada 
\q1  
\v 20 Wiilkaygiiyow, qaynuunka aabbahaa xaji, 
\q1 Oo amarka hooyadaana ha ka tegin. 
\q1  
\v 21 Had iyo goorba qalbiga ku sido, 
\q1 Oo qoortana ku xidho. 
\q1  
\v 22 Markaad socotid wuu ku hoggaamin doonaa, 
\q1 Oo markaad seexatidna wuu ku dhawri doonaa, 
\q1 Markaad toostidna wuu kula hadli doonaa. 
\q1  
\v 23 Waayo, qaynuunku waa laambad, amarkuna waa iftiin, 
\q1 Oo canaanashada edbintuna waa jidkii nolosha, 
\q1  
\v 24 Inay kaa dhawraan naagta sharka ah, 
\q1 Iyo sasabashada carrabka naagta qalaad. 
\q1  
\v 25 Quruxdeeda qalbigaaga ha ka damcin, 
\q1 Oo yaanay indhaheeda daboolkooda kugu sasaban. 
\q1  
\v 26 Waayo, naag dhillo ah aawadeed waxaa nin la gaadhsiiyaa go' kibis ah, 
\q1 Oo dhilladuna waxay ugaadhsataa nafta qaaligaa. 
\q1  
\v 27 Miyuu nin laabta dab ku qaadi karaa, 
\q1 Iyadoo aan dharkiisu guban? 
\q1  
\v 28 Miyuu mid dhuxul kulul ku kor socon karaa, 
\q1 Iyadoo aan cagihiisu guban? 
\q1  
\v 29 Haddaba sidaas oo kaluu noqdaa kii naagta deriskiisa u tagaa, 
\q1 Oo ku alla kii iyada taabtaaba ma taqsiir la'aan doono. 
\q1  
\v 30 Dadku tuug ma quudhsadaan hadduu wax xado 
\q1 Inuu naftiisa dhergiyo markuu gaajoodo, 
\q1  
\v 31 Laakiinse haddii isaga la qabto waa inuu toddoba jibbaar u magdhabaa, 
\q1 Waa inuu ku bixiyaa waxa gurigiisa yaal oo dhan. 
\q1  
\v 32 Kii naag ka sinaystaa wuu caqli daranyahay, 
\q1 Oo kii sidaas yeelaa naftiisuu halligaa. 
\q1  
\v 33 Oo wuxuu heli doonaa dhaawacyo iyo sharafdarro; 
\q1 Oo ceebtiisana lama tirtiri doono innaba. 
\q1  
\v 34 Waayo, hinaaso waa nin cadhadiis. 
\q1 Maalinta aarsashadana isagu ma tudhi doono. 
\q1  
\v 35 Isagu innaba mag kaa qaadan maayo, oo sinaba kuula heshiin maayo, 
\q1 In kastoo aad hadiyado badan siisid. 
\c 7  
\s2 Digniin Ka Gees Ah Naagta Gogoldhaafta 
\q1  
\v 1 Wiilkaygiiyow, erayadayda xaji, 
\q1 Oo amarradaydana xaggaaga ku kaydso. 
\q1  
\v 2 Amarradayda xaji aad noolaatide, 
\q1 Oo sharcigaygana sida ishaada inankeeda u dhawr. 
\q1  
\v 3 Farahaaga ku xidho, 
\q1 Oo looxa qalbigaagana ku qoro. 
\q1  
\v 4 Waxaad xigmadda ku tidhaahdaa, Adigu waxaad tahay walaashay, 
\q1 Oo waxgarashadana waxaad ugu yeedhaa, saaxiibadday gacalisoy, 
\q1  
\v 5 Si ay iyagu kaaga celiyaan naagta qalaad, 
\q1 Taasoo erayadeeda kugu sasabata. 
\q1  
\v 6 Waayo, anigoo jooga daaqadda gurigayga 
\q1 Ayaan shabagga daaqadda wax ka fiiriyey, 
\q1  
\v 7 Oo kuwa garaadka daran ayaan fiiriyey, oo waxaan barbaarrada ku dhex arkay 
\q1 Nin dhallinyaraa oo aan innaba waxgarasho lahayn, 
\q1  
\v 8 Isagoo maraya dariiqa xaafaddeeda u dhow, 
\q1 Oo wuxuu raacay jidkii gurigeeda, 
\q1  
\v 9 Oo waxay ahayd gabbaldhac oo makhribka ah, markii habeenkii madoobaanayay oo gudcur noqonayay. 
\q1  
\v 10 Oo bal eeg, waxaa isagii ka hor timid naag 
\q1 Sidii dhillo u lebbisan, oo qalbigeedu khiyaano miidhan yahay. 
\q1  
\v 11 Iyadu waa rabshad badan tahay, waana caasiyad, 
\q1 Oo gurigeeda cag sooma dhigto. 
\q1  
\v 12 Mar dibadday joogtaa, marna dariiqyaday maraysaa, 
\q1 Oo rukun kasta wax bay ku sugtaa. 
\q1  
\v 13 Haddaba isagii way qabsatay, oo dhunkatay; 
\q1 Iyadoo aan wejigeedu xishood lahayn ayay waxay isagii ku tidhi, 
\q1  
\v 14 Anigu waxaan hayaa allabaryo nabdeed, 
\q1 Oo maanta ayaan nidarradaydii bixiyey. 
\q1  
\v 15 Haddaba waxaan u soo baxay inaan kula kulmo, 
\q1 Oo aan aad iyo aad wejigaaga u doondoono, waanan ku helay. 
\q1  
\v 16 Sariirtaydii waxaan ku goglay durraaxado daabac leh, 
\q1 Iyo marooyin duntii Masar laga sameeyey. 
\q1  
\v 17 Waxaan sariirtaydii ku cadariyey 
\q1 Malmal iyo cuud iyo qorfe. 
\q1  
\v 18 Kaalay, oo aan caashaq ka dheregno ilaa aroorta, 
\q1 Oo aynu jacayl ku faraxsanaanno. 
\q1  
\v 19 Waayo, ninkaygii guriga ma joogo, 
\q1 Oo meel fog buu u sodcaalay, 
\q1  
\v 20 Kiish lacag ahna wuu qaatay, 
\q1 Oo wuxuu guriga ku soo noqon doonaa markuu dayaxu caddaado. 
\q1  
\v 21 Hadalkeedii badnaa oo macaanaa ayay isagii isku yeelsiisay, 
\q1 Oo waxay isagii ku qasabtay faankii beenta ahaa oo bushimeheeda. 
\q1  
\v 22 Oo haddiiba iyadii buu daba galay, 
\q1 Sidii dibi loo wado in la gowraco, 
\q1 Ama sidii nacas loo wado in silsilado lagu jebiyo, 
\q1  
\v 23 Jeer fallaadh beerka lagaga wareemo, 
\q1 Sida shimbiru dabinka degdeg ku gasho, 
\q1 Iyadoo aan ogayn in loo dhigay si nafteeda loo qaado. 
\q1  
\v 24 Haddaba sidaas daraaddeed, wiilashoy, bal i maqla, 
\q1 Oo erayada afkayga dhegaysta. 
\q1  
\v 25 Qalbigiinnu yaanu jidadkeeda u leexan, 
\q1 Oo waddooyinkeedana ha ku dhex habaabina. 
\q1  
\v 26 Waayo, iyadu waxay ridday kuwa badan oo dhaawacan, 
\q1 Sida xaqiiqada kuway laysay aad bay u badan yihiin. 
\q1  
\v 27 Gurigeedu waa jidkii She'ool, 
\q1 Oo wuxuu hoos ugu dhaadhacaa dhimashada qolladaheeda. 
\c 8  
\s2 Baaqii Xigmadda 
\q1  
\v 1 Haddaba xigmaddu sow ma dhawaaqin? 
\q1 Waxgarashaduna codkeedii sow kor uma qaadin? 
\q1  
\v 2 Waxay taagan tahay meelaha sarreeya 
\q1 Oo jidka agtiisa ah, meesha waddooyinku ku kulmaan. 
\q1  
\v 3 Oo waxay ka qaylisaa irdaha agtooda, 
\q1 Meesha magaalada laga soo galo, 
\q1 Iyo meesha albaabbada laga soo galoba. 
\q1  
\v 4 Nimanyahow, idinkaan idiin dhawaaqayaa, 
\q1 Oo codkayguna wuxuu u yeedhayaa binu-aadmiga. 
\q1  
\v 5 Garaadlaawayaashow, miyir lahaada, 
\q1 Nacasyadoy, waxgarasho qalbiga ku haysta. 
\q1  
\v 6 I maqla, waayo, waxaan ku hadlayaa waxyaalo wanaagsan, 
\q1 Oo waxaan bushimaha u kala qaadayaa waxyaalo qumman. 
\q1  
\v 7 Maxaa yeelay, afkaygu run buu ku hadlayaa; 
\q1 Oo bushimahayguna shar bay karhaan. 
\q1  
\v 8 Erayada afkayga oo dhammi waa xaq, 
\q1 Oo innaba wax qalloocan ama maroorsan lagama helo. 
\q1  
\v 9 Iyagu dhammaantood waa u cad yihiin kii wax garanaya, 
\q1 Oo waana u qumman yihiin kuwa aqoonta hela. 
\q1  
\v 10 Edbintayda qaata, lacagse ha qaadanina, 
\q1 Oo aqoontana ka hor doorta dahabka saafiga ah. 
\q1  
\v 11 Waayo, xigmaddu waa ka sii wanaagsan tahay luulka, 
\q1 Oo wax alla waxa la damci karo oo dhanna iyada lalama simi karo. 
\q1  
\v 12 Anigoo xigmad ahu, waxaan la fadhiyaa miyir, 
\q1 Oo waxaan helaa aqoon iyo digtoonaan. 
\q1  
\v 13 Rabbiga ka cabsashadiisu waa in sharka la naco. 
\q1 Kibirka, iyo madaxweynaanta, iyo jidka sharka, 
\q1 Iyo afka qalloocan ayaan anigu necbahay. 
\q1  
\v 14 Talo iyo xigmad anigaa iska leh, 
\q1 Oo waxaan ahay waxgarasho, xoogna waan leeyahay. 
\q1  
\v 15 Boqorradu gacantayday wax ku xukumaan, 
\q1 Oo amiirraduna amarkaygay garta ku gooyaan. 
\q1  
\v 16 Taliyayaasha iyo saraakiisha iyo weliba xaakinnada dunida oo dhammuna 
\q1 Anigay wax iigu taliyaan. 
\q1  
\v 17 Anigu kuwa i jecel waan jeclahay, 
\q1 Oo kuwa aad iyo aad ii doonaana way i heli doonaan. 
\q1  
\v 18 Anigaa iska leh taajirnimo iyo sharaf. 
\q1 Iyo weliba maal raagaya iyo xaqnimoba. 
\q1  
\v 19 Midhahaygu way ka sii wanaagsan yihiin dahab, haah, oo xataa dahab aad u wanaagsan way ka sii wanaagsan yihiin, 
\q1 Oo waxa ii kordhaana way ka sii wanaagsan yihiin lacag la doortay. 
\q1  
\v 20 Anigu waxaan ku socdaa jidka xaqnimada, 
\q1 Iyo waddooyinka garta dhexdooda, 
\q1  
\v 21 Si aan kuwa i jecel uga dhigo inay maal dhaxlaan, 
\q1 Oo aan khasnadahooda ugu buuxiyo. 
\q1  
\v 22 Rabbigu wuxuu i lahaan jiray bilowgii jidkiisa 
\q1 Iyo shuqulladiisii hore ka hor. 
\q1  
\v 23 Aniga aakhirada hore waa lay taagay, waxaan jiray bilowgii ugu horreeyey, 
\q1 Ama intaan dunidu jirin ka hor. 
\q1  
\v 24 Anigu waxaan dhashay intaan moolal jirin ka hor, 
\q1 Iyo intaanay jirin ilo biyo ka buuxaan. 
\q1  
\v 25 Intaan la qotomin buuraha 
\q1 Iyo kuraha ka hor ayaan anigu dhashay, 
\q1  
\v 26 Intaanuu isagu samayn dhulka iyo berrimmada, 
\q1 Amase ciiddii dunida ugu horraysay. 
\q1  
\v 27 Markuu samooyinka hagaajiyey anigu waan joogay, 
\q1 Markuu xariijinta ku wareejiyey moolka dushiisa, 
\q1  
\v 28 Markuu cirka sare taagay, 
\q1 Markii ilaha moolku xoog yeesheen, 
\q1  
\v 29 Markuu badda xad u yeelay 
\q1 Si aan biyuhu amarkiisa ugu xadgudbin, 
\q1 Markuu aasaaskii dhulka dhigay, 
\q1  
\v 30 Markaas anigu isagaan dhinac joogay, anigoo ah sidii hawlhoggaamiye, 
\q1 Oo anigu maalin kasta faraxiisaan ahaa, 
\q1 Oo mar kasta hortiisaan ku rayrayn jiray; 
\q1  
\v 31 Waxaan ku rayrayn jiray inta dhulkiisa la degay, 
\q1 Oo waxaan ku farxi jiray binu-aadmiga. 
\q1  
\v 32 Haddaba sidaas daraaddeed, wiilashoy, bal i maqla; 
\q1 Waayo, waxaa barakaysan kuwa jidadkayga xajiya. 
\q1  
\v 33 Edbinta dhegaysta, oo caqli yeesha, 
\q1 Oo ha diidina. 
\q1  
\v 34 Waxaa barakaysan ninka i maqla, 
\q1 Oo maalin kasta irdahayga igu dhawra, 
\q1 Oo albaabbadayda igu suga. 
\q1  
\v 35 Waayo, ku alla kii i helaa wuxuu helaa nolol, 
\q1 Oo Rabbiguna raalli buu ka ahaan doonaa. 
\q1  
\v 36 Laakiinse kii igu dembaabaa naftiisuu wax yeelaa, 
\q1 Kuwa aniga i neceb oo dhammu waxay jecel yihiin dhimasho. 
\c 9  
\s2 Casuumaddii Xigmadda Iyo Tii Nacasnimada 
\q1  
\v 1 Xigmaddu gurigeeday dhisatay, 
\q1 Toddobadeedii tiirna way xaradhay. 
\q1  
\v 2 Neefafkeedii ayay qashay, oo waxay isku dartay khamrigeedii; 
\q1 Miiskeediina way diyaarisay. 
\q1  
\v 3 Oo gabdhaheedii midiidinnada ahaa ayay dirtay, oo waxay ka qaylinaysaa 
\q1 Magaalada meelaha ugu sarreeya, iyadoo leh, 
\q1  
\v 4 Ku alla kii garaaddaranu, halkan ha u soo leexdo. 
\q1 Oo kii waxgarasho u baahanna waxay ku leedahay, 
\q1  
\v 5 Kaalaya oo kibistayda wax ka cuna, 
\q1 Oo khamriga aan isku darayna wax ka cabba. 
\q1  
\v 6 Garaadlaawayaashow, nacasnimada iska daaya, oo noolaada, 
\q1 Oo jidka waxgarashadana mara. 
\q1  
\v 7 Kii mid wax quudhsada toosiyaa, cay buu isu soo jiidaa, 
\q1 Oo kii kan sharka leh canaantana, ceeb baa ku dhacda. 
\q1  
\v 8 Mid wax quudhsada ha canaanan, waaba intaas oo uu ku necbaadaaye, 
\q1 Nin caqli leh canaano, oo isna wuu ku jeclaan doonaa. 
\q1  
\v 9 Nin caqli leh wax bar, oo isna caqli wuu sii yeelan doonaa. 
\q1 Nin xaq ah wax bar, oo isna waxbarasho wuu sii korodhsan doonaa. 
\q1  
\v 10 Rabbiga in laga cabsado waa xigmadda bilowgeeda, 
\q1 Oo Kan quduuska ah in la aqoonsadona waa waxgarasho. 
\q1  
\v 11 Waayo, maalmahaagu anigay igu badan doonaan, 
\q1 Oo cimrigaaguna waa sii kordhi doonaa. 
\q1  
\v 12 Haddaad caqli leedahay naftaadaad caqli u leedahay, 
\q1 Laakiinse haddaad wax quudhsato, adiga uun baa waxquudhsashadaada xambaaran doona. 
\q1  
\v 13 Naagta nacasadda ahu waa qaylo badan tahay, 
\q1 Iyadu way garaaddaran tahay, oo waxba ma taqaan. 
\q1  
\v 14 Waayo, waxay fadhiisataa illinka gurigeeda, 
\q1 Oo kursi bay ku fadhiisataa meelaha sarsare ee magaalada, 
\q1  
\v 15 Inay u yeedho kuwa jidka maraya, 
\q1 Iyagoo jidadkooda iska sii soconaya, 
\q1  
\v 16 Ku alla kii garaaddaranu halkan ha u soo leexdo, 
\q1 Oo kii waxgarasho u baahanna waxay ku leedahay, 
\q1  
\v 17 Biyo la soo xaday way macaan yihiin. 
\q1 Oo cunto qarsoodi loo cunaana wax bay ka farxisaa. 
\q1  
\v 18 Laakiinse isagu garan maayo in kuwii dhintay ay halkaas joogaan, 
\q1 Iyo in martideedii ay She'ool guntiisa ku jiraan. 
\c 10  
\s1 Maahmaahyadii Sulaymaan 
\q1  
\v 1 Maahmaahyadii Sulaymaan. 
\q1 Wiilka caqliga lahu aabbihiisuu ka farxiyaa, 
\q1 Laakiinse wiilka nacaska ahu waa u caloolxumo hooyadiis. 
\q1  
\v 2 Qasnadaha sharnimadu faa'iido ma leh, 
\q1 Laakiinse xaqnimada ayaa dhimasho kaa samatabbixisa. 
\q1  
\v 3 Kii xaq ah naftiisu inay gaajooto Rabbigu u oggolaan maayo, 
\q1 Laakiinse doonista kuwa sharka leh ayuu ridaa. 
\q1  
\v 4 Kii gacan caajis ah lahu wuu caydhoobaa, 
\q1 Laakiinse kuwa dadaala gacantoodu hodan bay ka dhigtaa. 
\q1  
\v 5 Kii guga wax soo urursadaa waa wiil caqli leh, 
\q1 Laakiinse kii wakhtiga beergooyska seexdaa waa wiil ceeb sameeya. 
\q1  
\v 6 Barako waxay saaran tahay kan xaqa ah madaxiisa, 
\q1 Laakiinse kuwa sharka leh afkooda dulmi baa qariya. 
\q1  
\v 7 Kan xaqa ah xusuustiisu barako bay leedahay, 
\q1 Laakiinse kuwa sharka leh magacoodu waa qudhmi doonaa. 
\q1  
\v 8 Kii qalbiga caqli ku lahu amarro buu aqbalaa, 
\q1 Laakiinse kan bushimaha ka nacaska ahu afgembi buu u dhacaa. 
\q1  
\v 9 Kii qummanaan ku socdaa ammaan buu ku socdaa; 
\q1 Laakiinse kii jidadkiisa qalqalloociya waa la ogaan doonaa. 
\q1  
\v 10 Kii indhaha ku baaqaa murug buu keenaa. 
\q1 Laakiinse kan bushimaha ka nacaska ahu afgembi buu u dhacaa. 
\q1  
\v 11 Ninkii xaq ah afkiisu waa il nololeed, 
\q1 Laakiinse kuwa sharka leh afkooda dulmi baa qariya. 
\q1  
\v 12 Necbaantu waxay kicisaa isqabashada, 
\q1 Laakiinse jacaylku xadgudubyada oo dhan buu qariyaa. 
\q1  
\v 13 Kii waxgarasho leh bushimihiisa waxaa laga helaa xigmad, 
\q1 Laakiinse ushu waxay u taal kan garaadka daran dhabarkiisa. 
\q1  
\v 14 Dadkii caqli lahu waxay kaydsadaan aqoon, 
\q1 Laakiinse nacaska afkiisu waa baabba' dhow. 
\q1  
\v 15 Ninkii hodan ah maalkiisu waa u magaalo xoog leh, 
\q1 Laakiinse masaakiinta caydhnimadoodu waa u baabba'. 
\q1  
\v 16 Kuwa xaqa ah hawshoodu waxay u waddaa nolol, 
\q1 Laakiinse waxa kan sharka leh u kordhaa, dembi bay u sii kexeeyaan. 
\q1  
\v 17 Kii edbinta xajistaa wuxuu ku socdaa jidka nolosha, 
\q1 Laakiinse kii canaanta diidaa wuu qaldamaa. 
\q1  
\v 18 Kii necbaanta qariyaa wuxuu leeyahay bushimo been badan, 
\q1 Oo kii xanta ku hadlaana waa nacas. 
\q1  
\v 19 Hadal badan dembi lagama waayo, 
\q1 Laakiinse kii bushimihiisa ceshaa caqli buu leeyahay. 
\q1  
\v 20 Kii xaq ah carrabkiisu waa sida lacag la doortay, 
\q1 Laakiinse kuwa sharka leh qalbigoodu waa qiimo yar yahay. 
\q1  
\v 21 Kii xaq ah bushimahiisu waxay masruufaan kuwa badan, 
\q1 Laakiinse nacasyadu waxgarashola'aantooda ayay u dhintaan. 
\q1  
\v 22 Rabbiga barakadiisu hodan bay kaa dhigtaa, 
\q1 Oo isna caloolxumo kuma daro. 
\q1  
\v 23 Nacasku inuu xumaan sameeyo waa u sidii cayaareed, 
\q1 Laakiinse ninka garaadka lahu xigmad buu leeyahay. 
\q1  
\v 24 Kii shar leh wuxuu ka cabsado ayaa ku soo dul degi doona, 
\q1 Laakiinse kuwa xaqa ah waxay doonayaan waa la siin doonaa. 
\q1  
\v 25 Markii dabaysha cirwareenta ahu dhaafto, ka sharka leh mar dambe la arki maayo, 
\q1 Laakiinse kii xaq ahu waa aasaas weligiis waaraya. 
\q1  
\v 26 Khalku siduu ilkaha u yahay, iyo sida qiiqu indhaha u yahay, 
\q1 Ayaa kan caajiska ahu u yahay kuwa isaga dirta. 
\q1  
\v 27 Rabbiga ka cabsashadiisu cimrigay dheeraysaa, 
\q1 Laakiinse kuwa sharka leh cimrigoodu waa soo gaaban doonaa. 
\q1  
\v 28 Kuwa xaqa ah rajadoodu waa farxad, 
\q1 Laakiinse kuwa sharka leh filashadoodu way baabbi'i doontaa. 
\q1  
\v 29 Rabbiga jidkiisu waa u qalcad kuwa qumman; 
\q1 Laakiinse xumaanfalayaasha waa u baabba'. 
\q1  
\v 30 Kan xaqa ah weligiis la dhaqaajin maayo, 
\q1 Laakiinse kuwa sharka lahu dhulka ma fadhiyi doonaan. 
\q1  
\v 31 Kan xaqa ah afkiisa waxaa ka soo baxda xigmad, 
\q1 Laakiinse carrabkii qalloocan waa la gooyn doonaa. 
\q1  
\v 32 Kan xaqa ah bushimahiisu waxay yaqaaniin waxa la aqbali karo, 
\q1 Laakiinse kan sharka leh afkiisu qallooc buu ku hadlaa. 
\b  
\c 11  
\q1  
\v 1 Kafaddii khiyaano ah Rabbigu aad buu u karhaa, 
\q1 Laakiinse dhagaxii miisaanka oo xaq ah wuu ku farxaa. 
\q1  
\v 2 Markuu kibir yimaado, waxaa timaada ceeb; 
\q1 Laakiinse xigmaddu waxay la jirtaa kuwa is-hoosaysiiya. 
\q1  
\v 3 Kuwa qumman waxaa kaxayn doonta daacadnimadooda, 
\q1 Laakiinse khaayinnada qalloocnaantoodu waa baabbi'in doontaa iyaga. 
\q1  
\v 4 Maalinta cadhada maal faa'iido ma leh, 
\q1 Laakiinse xaqnimada ayaa dhimasho kaa samatabbixisa. 
\q1  
\v 5 Ninkii kaamil ah xaqnimadiisu jidkiisay toosisaa, 
\q1 Laakiinse kan sharka lahu wuxuu ku kufi doonaa sharkiisa. 
\q1  
\v 6 Kuwa qumman xaqnimadoodaa samatabbixin doonta, 
\q1 Laakiinse khaayinnada waxaa qabsan doona damacooda xun. 
\q1  
\v 7 Nin shar lahu markuu dhinto, wuxuu filanayay way baabbi'i doontaa, 
\q1 Oo xumaanfalayaasha rajadooduna way baabba'daa. 
\q1  
\v 8 Kii xaq ah waxaa laga samatabbixiyaa dhibaato, 
\q1 Oo meeshiisana waxaa yimaada kii shar leh. 
\q1  
\v 9 Labawejiilahu afkiisuu deriskiisa ku halligaa, 
\q1 Laakiinse kan xaqa ahu aqoon buu ku samatabbixi doonaa. 
\q1  
\v 10 Kuwa xaqa ahu markay barwaaqoobaan, magaaladu way rayraysaa, 
\q1 Laakiin kuwa sharka lahu markay halligmaan farax baa lagu dhawaaqaa. 
\q1  
\v 11 Kuwa qumman ducadooda magaaladu sare bay ugu kacdaa, 
\q1 Laakiinse kuwa sharka leh afkoodu magaaladuu dumiyaa. 
\q1  
\v 12 Kii deriskiisa quudhsadaa waa caqli daranyahay, 
\q1 Laakiinse ninkii garaadka lahu wuu iska aamusaa. 
\q1  
\v 13 Kii sida mid xan badan u warwareegaa wuxuu daaha ka qaadaa waxyaalo qarsoon, 
\q1 Laakiinse kii ruuxiisu aamin yahay xaalkuu qariyaa. 
\q1  
\v 14 Markaanay talo jirin, dadku waa dhacaa, 
\q1 Laakiinse taliyayaasha badnaantoodu waxay leedahay nabadgelyo. 
\q1  
\v 15 Kii qof qalaad dammiintaa, xumaan buu ka helaa, 
\q1 Laakiinse kii dammiinashada necebu ammaan buu u fadhiyaa. 
\q1  
\v 16 Naag nimcaysan sharaf bay haysataa, 
\q1 Oo niman xoog lahuna maal bay haystaan. 
\q1  
\v 17 Ninkii naxariis badanu naftiisuu wanaag u sameeyaa, 
\q1 Laakiinse kii aan naxariis lahaynu jidhkiisuu dhibaa. 
\q1  
\v 18 Kan sharka lahu wuxuu shaqaystaa mushahaaro khiyaano miidhan ah, 
\q1 Laakiinse kii xaqnimada beeraa wuxuu heli doonaa abaalgud la hubo. 
\q1  
\v 19 Xaqnimadu waxay u kacdaa xagga nolosha, 
\q1 Sidaas oo kalena kii sharka raacaa wuxuu u raacaa dhimashadiisa. 
\q1  
\v 20 Kuwa qalbigoodu qalloocan yahay Rabbigu aad buu u karhaa; 
\q1 Laakiinse kuwa jidkooda ku qumman wuu ku farxaa. 
\q1  
\v 21 Waxaan aad idiinku xaqiijinayaa inaan kan sharka lahu taqsiirla'aan doonayn. 
\q1 Laakiinse farcanka kuwa xaqa ah waa la samatabbixin doonaa. 
\q1  
\v 22 Naag qurux badan oo aan digtoonaan lahaynu 
\q1 Waa sida dahab gafuurka doofaarka ku jira. 
\q1  
\v 23 Kuwa xaqa ah waxay doonayaan wanaag keliya, 
\q1 Laakiinse kuwa sharka ah filashadoodu waa cadho. 
\q1  
\v 24 Waxaa jira mid wax firdhiya, oo haddana sii korodhsada; 
\q1 Oo waxaa jira mid ceshada wax ka sii badan in ku habboon, oo haddana sii caydhooba. 
\q1  
\v 25 Qofkii deeqsi ah baa la barwaaqaysiin doonaa, 
\q1 Oo kii wax waraabiyana, isna waa la waraabin doonaa. 
\q1  
\v 26 Kii hadhuudh ceshada, dadka ayaa habaari doona, 
\q1 Laakiinse kii iibiya, duco ayaa ku dhici doonta. 
\q1  
\v 27 Kii wanaag aad u doonaa wuxuu doonayaa raallinimo, 
\q1 Laakiinse kii xumaan doona, way u iman doontaa. 
\q1  
\v 28 Kii maalkiisa isku halleeyaa wuu dhici doonaa, 
\q1 Laakiinse kii xaq ahu wuxuu u barwaaqoobi doonaa sida caleen cagaar ah. 
\q1  
\v 29 Kii gurigiisa dhibaa dabayshu dhaxli doonaa, 
\q1 Oo nacaskuna wuxuu midiidin u ahaan doonaa kan qalbigiisu caqliga leeyahay. 
\q1  
\v 30 Kan xaqa ah midhihiisu waa geed nololeed, 
\q1 Oo kii nafo soo hanuuniyaana caqli buu leeyahay. 
\q1  
\v 31 Bal eega, kan xaqa ahu abaalkiisuu dhulka ku heli doonaa, 
\q1 Haddaba immisa abaalgud oo ka sii badan bay heli doonaan kan sharka leh iyo dembiluhu. 
\b  
\c 12  
\q1  
\v 1 Ku alla kii edbinta jecelu aqoon buu jecel yahay, 
\q1 Laakiinse kii canaanta necebu waa doqon. 
\q1  
\v 2 Rabbigu ninka wanaagsan raalli buu ka ahaan doonaa. 
\q1 Laakiinse khaayinka wuu xukumi doonaa. 
\q1  
\v 3 Ninna shar kuma dhismi doono, 
\q1 Laakiinse kuwa xaqa ah xididkooda weligiis lama dhaqaajin doono. 
\q1  
\v 4 Naagtii toolmoonu waxay ninkeeda u tahay taaj, 
\q1 Laakiinse tii ceebalay ahu waa sida qudhun isaga lafaha kaga jira. 
\q1  
\v 5 Kuwa xaqa ah fikirradoodu waa qumman yihiin, 
\q1 Laakiinse kuwa sharka leh taladoodu waa khiyaano. 
\q1  
\v 6 Kuwa sharka leh erayadoodu waa gabbasho ay u gabbadaan si ay dhiig u daadiyaan, 
\q1 Laakiinse kuwa qumman afkooda ayaa samatabbixin doona. 
\q1  
\v 7 Kuwa sharka leh waa la afgembiyaa, oo mar dambena lama arki doono, 
\q1 Laakiinse kuwa xaqa ah gurigoodu waa sii taagnaan doonaa. 
\q1  
\v 8 Nin waxaa loogu bogi doonaa sida xigmaddiisu tahay, 
\q1 Laakiinse kii qalbigiisu qalloocan yahay waa la quudhsan doonaa. 
\q1  
\v 9 Kii la fudaydsado oo midiidin lahu 
\q1 Waa ka wanaagsan yahay kii isweyneeya oo cunto u baahan. 
\q1  
\v 10 Nin xaq ahu waa u tudhaa neefkiisa, 
\q1 Laakiinse kuwa sharka leh naxdintoodu waa naxariisla'aan oo keliya. 
\q1  
\v 11 Kii dhulkiisa beertaa cunto badan buu ka dhergi doonaa, 
\q1 Laakiinse kii waxmatarayaal raacaa waa garaad daranyahay. 
\q1  
\v 12 Kan sharka lahu wuxuu damcaa dabinka xumaanfalayaasha, 
\q1 Laakiinse xididka kuwa xaqa ahu midhuu dhalaa. 
\q1  
\v 13 Kan sharka leh waxaa u dabin ah xadgudubka bushimihiisa, 
\q1 Laakiinse kan xaqa ahu dhibaatada wuu ka bixi doonaa. 
\q1  
\v 14 Nin wuxuu wanaag kaga dhergi doonaa midhaha afkiisa, 
\q1 Oo nin walbana waxa gacmihiisu sameeyaan ayaa loo abaalgudi doonaa. 
\q1  
\v 15 Nacaska jidkiisu waa la qumman yahay isaga, 
\q1 Laakiinse kii caqli lahu taladuu maqlaa. 
\q1  
\v 16 Nacaska xanaaqiisa haddiiba waa la gartaa, 
\q1 Laakiinse ninkii miyir lahu ceebtuu qariyaa. 
\q1  
\v 17 Kii runta ku hadlaa wuxuu muujiyaa xaqnimada, 
\q1 Laakiinse markhaatiga beenta ahu wuxuu muujiyaa khiyaanada. 
\q1  
\v 18 Waxaa jira mid u hadla sida seef wax mudaysa, 
\q1 Laakiinse kan caqliga leh carrabkiisu waa caafimaad. 
\q1  
\v 19 Bushintii runta sheegtaa weligeedba way sii taagnaan doontaa, 
\q1 Laakiinse carrabkii beenta sheegaa daqiiqad buu joogaa. 
\q1  
\v 20 Kuwa sharka ku fikira qalbigooda khiyaanaa ku jirta, 
\q1 Laakiinse taliyayaasha nabaddu farxad bay leeyihiin. 
\q1  
\v 21 Sharna kan xaqa ah ku dhici maayo, 
\q1 Laakiinse kuwa sharka leh xumaan baa ka buuxsami doonta. 
\q1  
\v 22 Bushimaha beenta sheega Rabbigu wuu karhaa. 
\q1 Laakiinse kuwa runta ku shaqeeya wuu ku farxaa. 
\q1  
\v 23 Ninkii miyir lahu aqoontuu qariyaa, 
\q1 Laakiinse qalbiga nacasyadu wuxuu naadiyaa nacasnimo. 
\q1  
\v 24 Kuwa dadaala gacantoodu wax bay xukumi doontaa, 
\q1 Laakiinse caajisiinta hawl baa la saari doonaa. 
\q1  
\v 25 Ninkii caloolxumo gashaa wuu soo gotaa, 
\q1 Laakiinse eray wanaagsanu waa ka farxiyaa isaga. 
\q1  
\v 26 Kan xaqa ahu deriskiisuu hanuuniyaa, 
\q1 Laakiinse kuwa sharka leh jidkoodu wuu ambiyaa iyaga. 
\q1  
\v 27 Ninkii caajis ahu ma dubto wuxuu soo ugaadhsaday, 
\q1 Laakiinse ninkii dadaala maalkiisu waa qaali. 
\q1  
\v 28 Jidka xaqnimada nolol baa taal; 
\q1 Oo waddadeedana dhimasho kuma jirto. 
\b  
\c 13  
\q1  
\v 1 Wiilkii caqli lahu wuxuu maqlaa edbinta aabbihiis, 
\q1 Laakiinse kii wax quudhsadaa canaanta ma maqlo. 
\q1  
\v 2 Nin wuxuu wax wanaagsan ku cuni doonaa midhaha afkiisa, 
\q1 Laakiinse khaayinnada naftoodu waxay cuni doontaa midhaha dulmiga. 
\q1  
\v 3 Kii afkiisa dhawraa wuxuu dhawraa naftiisa, 
\q1 Laakiinse kii bushimihiisa aad u kala qaadaa wuu baabbi'i doonaa. 
\q1  
\v 4 Kii caajis ah naftiisu wax bay damacdaa, mana hesho, 
\q1 Laakiinse nafta kii dadaala waa la barwaaqaysiin doonaa. 
\q1  
\v 5 Ninkii xaq ahu beenta wuu neceb yahay, 
\q1 Laakiinse ninkii shar lahu waa karaahiyo, wuuna ceeboobaa. 
\q1  
\v 6 Xaqnimadu kii jidkiisu qumman yahay ayay ilaalisaa, 
\q1 Laakiinse sharnimadu dembilaha ayay afgembidaa. 
\q1  
\v 7 Waxaa jira nin hodan iska dhiga laakiinse aan waxba haysan, 
\q1 Oo waxaa jira mid miskiin iska dhiga laakiinse maal badan leh. 
\q1  
\v 8 Nin wuxuu noloshiisa ku furtaa maalkiisa, 
\q1 Laakiinse miskiinku canaanta ma maqlo. 
\q1  
\v 9 Iftiinka kuwa xaqa ahu weligii wuu reyreeyaa, 
\q1 Laakiinse laambadda kuwa sharka leh waa la bakhtiin doonaa. 
\q1  
\v 10 Isqabasho oo keliya ayaa kibir ka timaada, 
\q1 Laakiinse kii waanada qaata waxaa la jirta xigmad. 
\q1  
\v 11 Maalkii degdeg lagu helaa wuu dhinmi doonaa, 
\q1 Laakiinse kan hawl wax ku soo urursadaa waa sii korodhsan doonaa. 
\q1  
\v 12 Rajadii raagtaa qalbigay bukaysiisaa, 
\q1 Laakiinse markii wixii la doonayay la helo waa geed nololeed. 
\q1  
\v 13 Ku alla kii erayga quudhsadaa halligaad ayuu isu keenaa, 
\q1 Laakiinse kii amarka ka cabsada waa loo abaalgudi doonaa. 
\q1  
\v 14 Ninkii caqli leh waxbariddiisu waa il nololeed, 
\q1 In dabinnada dhimashada laga leexdo. 
\q1  
\v 15 Waxgarashadii wanaagsan raalli baa laga noqdaa, 
\q1 Laakiinse jidka khaayinnadu waa xun yahay. 
\q1  
\v 16 Nin kasta oo miyir lahu aqoon buu ku shaqeeyaa, 
\q1 Laakiinse nacasku nacasnimuu fidiyaa. 
\q1  
\v 17 Wargeeyihii shar lahu xumaan buu ku dhex dhacaa, 
\q1 Laakiinse ergadii aamin ahu waa caafimaad. 
\q1  
\v 18 Caydhnimo iyo ceebba waxaa lahaan doona kii edbinta diida, 
\q1 Laakiinse kii canaanta maqla waa la murwayn doonaa. 
\q1  
\v 19 Wixii la doonayay oo la gaadhay nafta way u macaan tahay, 
\q1 Laakiinse nacasyadu aad bay u karhaan inay sharka ka fogaadaan. 
\q1  
\v 20 Kii kuwa caqliga leh la socdaa, caqli buu yeelan doonaa, 
\q1 Laakiinse kii nacasyada raacaa waa baabbi'i doonaa. 
\q1  
\v 21 Dembilayaasha waxaa eryada shar, 
\q1 Laakiinse kuwa xaqa ah abaal wanaagsan baa loo gudi doonaa. 
\q1  
\v 22 Ninkii wanaagsanu dhaxal buu uga tagaa carruurta carruurtiisa, 
\q1 Oo maalka dembilahana waxaa loo kaydiyaa kuwa xaqa ah. 
\q1  
\v 23 Beerta masaakiinta waxaa ku taal cunto badan, 
\q1 Laakiinse gardarro aawadeed in baa loo baabbi'iyaa. 
\q1  
\v 24 Kii ushiisa ceshadaa wiilkiisuu neceb yahay; 
\q1 Laakiinse kii wiilkiisa jecelu aad buu u edbiyaa. 
\q1  
\v 25 Kan xaqa ahu wax buu cunaa ilaa naftiisu dheregto, 
\q1 Laakiinse caloosha kuwa sharka lahu way baahnaan doontaa. 
\b  
\c 14  
\q1  
\v 1 Naag kastoo caqli lahu gurigeeday dhistaa, 
\q1 Laakiinse nacasaddu gacmaheeday ku dumisaa. 
\q1  
\v 2 Kii qummanaantiisa ku socda ayaa Rabbiga ka cabsada, 
\q1 Laakiinse kii jidkiisa ku qalloocan wuu quudhsadaa isaga. 
\q1  
\v 3 Afka nacasyada waxaa ka soo biqla kibir; 
\q1 Laakiinse kuwa caqliga leh bushimahooda ayaa iyaga dhawri doona. 
\q1  
\v 4 Meeshii aan dibi joogin qabaalkii ay wax ka cuni jireen waa baabbah; 
\q1 Laakiinse kordhinta badanu waxay ku timaadaa xoogga dibiga. 
\q1  
\v 5 Markhaatigii aamin ahu been ma sheego, 
\q1 Laakiinse markhaatigii been ahu been buu ku hadlaa. 
\q1  
\v 6 Kii wax quudhsadaa xigmad buu doondoonaa, mana helo, 
\q1 Laakiinse aqoontu waa u fudud dahay kii waxgarasho leh. 
\q1  
\v 7 Nacaska hortiisa ka fogow, 
\q1 Waayo, bushimihiisa aqoon ka heli maysid. 
\q1  
\v 8 Ninkii miyir leh xigmaddiisu waa inuu jidkiisa gartaa, 
\q1 Laakiinse nacasyada nacasnimadoodu waa khiyaano. 
\q1  
\v 9 Nacasyadu dembigay ku majaajiloodaan, 
\q1 Laakiinse kuwa qumman waxaa ku dhex jirta raallinimo. 
\q1  
\v 10 Qalbigu qadhaadhnimadiisuu yaqaan, 
\q1 Oo shisheeyena farxaddiisa lama qaybsado. 
\q1  
\v 11 Guriga kuwa sharka leh waa la afgembiyi doonaa, 
\q1 Laakiinse taambuugga kuwa qummanu waa barwaaqoobi doonaa. 
\q1  
\v 12 Waxaa jirta waddo dadka la hagaagsan, 
\q1 Laakiinse dhammaadkeedu waa waddooyinka dhimashada. 
\q1  
\v 13 Qalbigu xataa qosol waa ku murugoodaa, 
\q1 Oo farxad dhammaadkeeduna waa caloolxumo. 
\q1  
\v 14 Kii xaqnimada qalbigiisa dib ugaga noqdaa jidkiisuu ka dhergi doonaa, 
\q1 Oo ninkii wanaagsanuna wuxuu ka dhergi doonaa naftiisa. 
\q1  
\v 15 Kii garaaddaranu eray kasta wuu rumaystaa, 
\q1 Laakiinse kii miyir lahu socodkiisa aad buu u fiiriyaa. 
\q1  
\v 16 Ninkii caqli lahu waa cabsadaa, oo sharka wuu ka noqdaa; 
\q1 Laakiinse nacasku waa ciishoodaa, wuuna isku kalsoon yahay. 
\q1  
\v 17 Kii degdeg u cadhoodaa nacasnimuu wax ku sameeyaa, 
\q1 Oo ninkii sharnimo hindisana waa la neceb yahay. 
\q1  
\v 18 Garaadlaawayaashu nacasnimay dhaxlaan, 
\q1 Laakiinse kuwii miyir leh waxaa madaxa loo saaraa taaj aqoon ah. 
\q1  
\v 19 Kuwa sharka lahu kuwa wanaagsan hortooda ayay ku foororsadaan, 
\q1 Oo kuwa xunxunna waxay ku foororsadaan irdaha kuwa xaqa ah. 
\q1  
\v 20 Miskiinka xataa deriskiisu waa neceb yahay, 
\q1 Laakiinse taajirku saaxiibbo badan buu leeyahay. 
\q1  
\v 21 Kii deriskiisa quudhsadaa wuu dembaabaa, 
\q1 Laakiinse kii miskiinka u naxariistaa waa barakaysan yahay. 
\q1  
\v 22 Kuwa sharka ku fikiraa sow ma qaldamaan? 
\q1 Laakiinse kuwa wanaagga ku fikira waxaa u ahaan doona naxariis iyo run. 
\q1  
\v 23 Hawl kasta faa'iidaa ku jirta, 
\q1 Laakiinse hadalka bushimuhu wuxuu keenaa caydhnimo keliya. 
\q1  
\v 24 Kuwa caqliga leh taajkoodu waa maalkooda, 
\q1 Laakiinse nacasyada nacasnimadoodu waa nacasnimo keliya. 
\q1  
\v 25 Markhaatigii run ahu nafuu samatabbixiyaa, 
\q1 Laakiinse kii been sheegaa waa khaayin. 
\q1  
\v 26 Rabbiga ka cabsashadiisu waxay leedahay kalsoonaan xoog leh, 
\q1 Oo carruurtiisuna waxay lahaan doonaan meel ay magangalaan. 
\q1  
\v 27 Rabbiga ka cabsashadiisu waa il nololeed, 
\q1 Si dabinnada dhimashada looga leexdo. 
\q1  
\v 28 Sharafta boqorku waxay ku jirtaa dadka badnaantiisa, 
\q1 Laakiinse baabba'a amiirku wuxuu ku jiraa dadka yaraantiisa. 
\q1  
\v 29 Kii cadhada u gaabiyaa waa garasho badan yahay; 
\q1 Laakiinse kii degdeg u cadhoodaa nacasnimuu sarraysiiyaa. 
\q1  
\v 30 Qalbigii degganu waa nolosha jidhka, 
\q1 Laakiinse hinaaso waa qudhunka lafaha. 
\q1  
\v 31 Kii miskiinka dulmaa wuxuu caayaa Kan sameeyey, 
\q1 Laakiinse kii ka baahan u naxariistaa wuu murweeyaa. 
\q1  
\v 32 Kii shar leh waxaa lagu afgembiyaa sharnimadiisa, 
\q1 Laakiinse kan xaqa ahu rajuu leeyahay markuu dhinto. 
\q1  
\v 33 Xigmaddu waxay taal kii garasho leh qalbigiisa, 
\q1 Laakiinse wixii nacasyada uurkooda ku jiraa waa ismuujiyaa. 
\q1  
\v 34 Xaqnimadu quruun way sarraysiisaa, 
\q1 Laakiinse dembigu waa u ceeb dad kasta. 
\q1  
\v 35 Boqorka raallinimadiisa waxaa leh midiidinkii caqli ku shaqeeya, 
\q1 Laakiinse wuxuu u cadhoon doonaa kii ceeb sameeya. 
\b  
\c 15  
\q1  
\v 1 Jawaabta qaboobu cadhada way qaboojisaa, 
\q1 Laakiinse hadalkii qallafsanu xanaaq buu kiciyaa. 
\q1  
\v 2 Kuwa caqliga leh carrabkoodu aqoon buu ku hadlaa, 
\q1 Laakiinse afka nacasyadu wuxuu shubaa nacasnimo. 
\q1  
\v 3 Rabbiga indhihiisu meel kastay jiraan, 
\q1 Iyagoo fiirinaya kuwa xun iyo kuwa wanaagsan. 
\q1  
\v 4 Carrabka wanaagsanu waa geed nololeed 
\q1 Laakiinse carrabka qalloocan ayaa qalbigu ku jabaa. 
\q1  
\v 5 Nacasku edbinta aabbihiis wuu quudhsadaa, 
\q1 Laakiinse kii canaanta maqlaa miyir buu yeeshaa. 
\q1  
\v 6 Kan xaqa ah gurigiisa khasnad weyn baa taal, 
\q1 Laakiinse waxa kan sharka leh u kordhaa waa dhib. 
\q1  
\v 7 Kuwa caqliga leh bushimahoodu aqoon bay faafiyaan, 
\q1 Laakiinse qalbiga nacasyadu sidaas ma aha. 
\q1  
\v 8 Allabariga kuwa sharka lahu Rabbiga waa u karaahiyo, 
\q1 Laakiinse kuwa qumman baryadoodu isagay ka farxisaa. 
\q1  
\v 9 Jidka kan sharka lahu Rabbiga waa u karaahiyo, 
\q1 Laakiinse isagu waa jecel yahay kii xaqnimada raaca. 
\q1  
\v 10 Kii jidka ka taga waa u taqsiir kulul, 
\q1 Oo kii canaanta necebuna wuu dhiman doonaa. 
\q1  
\v 11 She'ool iyo halligaaduba Rabbiga hortiisay yaalliin, 
\q1 Haddaba intee in ka sii badan buu arkaa qalbiga binu-aadmiga? 
\q1  
\v 12 Kii wax quudhsadaa ma jecla in la canaanto, 
\q1 Oo dooni maayo inuu kuwa caqliga leh u tago. 
\q1  
\v 13 Qalbigii faraxsanu wejiguu nuuriyaa, 
\q1 Laakiinse caloolxumaanta ayaa qalbigu ku jabaa. 
\q1  
\v 14 Kii garasho leh qalbigiisu aqoon buu doondoonaa, 
\q1 Laakiinse nacasyada afkoodu wuxuu cunaa nacasnimo. 
\q1  
\v 15 Kuwa dhibaataysan maalmahooda oo dhammu waa xunxun yihiin, 
\q1 Laakiinse kii qalbigiisu faraxsan yahay had iyo goorba waa u iid. 
\q1  
\v 16 Wax yar oo Rabbiga ka cabsashadiisu la jirto 
\q1 Ayaa ka wanaagsan khasnado badan oo dhib la jirto. 
\q1  
\v 17 Cunto khudaareed oo jacayl la jiro 
\q1 Ayaa ka wanaagsan dibi la cayiliyey oo nacayb la jiro. 
\q1  
\v 18 Ninkii cadho badanu muran buu kiciyaa, 
\q1 Laakiinse kii cadhada u gaabiyaa murankuu qaboojiyaa. 
\q1  
\v 19 Ninkii caajis ah jidkiisu waa sida meel qodxan leh oo kale, 
\q1 Laakiinse kii xaq ah jidkiisu waa dariiq bannaan. 
\q1  
\v 20 Wiilkii caqli lahu aabbihiisuu ka farxiyaa, 
\q1 Laakiinse ninkii nacas ahu hooyadiisuu quudhsadaa. 
\q1  
\v 21 Nacasnimadu waa u farxad ninkii caqlidaran, 
\q1 Laakiinse ninkii garasho lahu si qumman buu u socdaa. 
\q1  
\v 22 Meeshii aan talo jirin xaajooyinku waa baabba', 
\q1 Laakiinse taliyayaashii badan ayay ku hagaagaan. 
\q1  
\v 23 Nin wuxuu farxad ka helaa jawaabta afkiisa, 
\q1 Oo eraygii wakhti ku habboon la yidhaahdaana sidee buu u wanaagsan yahay! 
\q1  
\v 24 Jidka noloshu waa u kor kii caqli leh, 
\q1 Si uu uga tago She'oolka hoose. 
\q1  
\v 25 Rabbigu wuu dumin doonaa guriga kuwa kibirka leh, 
\q1 Laakiinse dhulka carmalka xadkiisa wuu adkayn doonaa. 
\q1  
\v 26 Rabbigu fikirrada sharka ah aad buu u karhaa, 
\q1 Laakiinse kuwa daahirkaa hadal wanaagsan bay ku hadlaan. 
\q1  
\v 27 Kan faa'iido u hunguri weynu reerkiisuu dhibaa, 
\q1 Laakiinse kii hadiyadaha necebu wuu noolaan doonaa. 
\q1  
\v 28 Kan xaqa ah qalbigiisu wuxuu ka fikiraa sida loo jawaabo, 
\q1 Laakiinse kuwa sharka leh afkoodu wuxuu shubaa waxyaalo shar ah. 
\q1  
\v 29 Rabbigu kuwa sharka leh wuu ka fog yahay, 
\q1 Laakiinse kuwa xaqa ah baryadooduu maqlaa. 
\q1  
\v 30 Indhaha nuurkoodu qalbiguu ka farxiyaa, 
\q1 Oo warkii wanaagsanuna lafahuu barwaaqaysiiyaa. 
\q1  
\v 31 Dhegtii canaanta nolosha maqashaa 
\q1 Waxay joogi doontaa kuwa caqliga leh dhexdooda. 
\q1  
\v 32 Kii edbinta diidaa naftiisuu quudhsadaa, 
\q1 Laakiinse kii canaanta maqlaa waxgarashuu helaa. 
\q1  
\v 33 Rabbiga ka cabsashadiisu waa edbinta xigmadda, 
\q1 Oo sharaftana waxaa ka horreeya is-hoosaysiinta. 
\b  
\c 16  
\q1  
\v 1 Qalbiga qasdiyadiisa dadkaa leh, 
\q1 Laakiinse carrabka jawaabtiisu xagga Rabbigay ka timaadaa. 
\q1  
\v 2 Nin jidadkiisa oo dhammu waa la nadiifsan yihiin isaga, 
\q1 Laakiinse Rabbigu ruuxyaduu miisaamaa. 
\q1  
\v 3 Shuqulladaada Rabbiga ku aamin, 
\q1 Oo fikirradaaduna way taagnaan doonaan. 
\q1  
\v 4 Rabbigu wax kastuu isu abuuray, 
\q1 Haah, oo xataa ka sharka leh wuxuu u abuuray maalinta sharkaa. 
\q1  
\v 5 Ku alla kii qalbiga ka kibirsanu Rabbiga waa u karaahiyo, 
\q1 Waxaan aad idiin ku xaqiijinayaa inaan isagu taqsiir la'aan doonayn. 
\q1  
\v 6 Waxaa dembiga lagu kafaaraggudaa naxariis iyo run, 
\q1 Oo dadkuna waxay sharka kaga fogaadaan Rabbiga ka cabsashadiisa. 
\q1  
\v 7 Markii Rabbigu ku farxo nin jidadkiis, 
\q1 Wuxuu nabad dhex dhigaa isaga iyo xataa cadaawayaashiisa. 
\q1  
\v 8 Wax yar oo xaqnimo la jirto 
\q1 Ayaa ka wanaagsan wax badan oo kordha oo xaqdarro la jirto. 
\q1  
\v 9 Nin walba qalbigiisaa jidkiisa u fiirsada, 
\q1 Laakiinse Rabbigaa tallaabooyinkiisa toosiya. 
\q1  
\v 10 Xukunka Rabbigu wuxuu ku jiraa bushimaha boqorka, 
\q1 Afkiisuna kuma xadgudbo garsooridda. 
\q1  
\v 11 Miisaankii iyo kafadihii xaq ah Rabbigaa leh, 
\q1 Dhagaxyada miisaanka oo kiishka ku jira oo dhammuna waa shuqulkiisa. 
\q1  
\v 12 Waa u karaahiyo boqorrada inay xumaan falaan. 
\q1 Waayo, carshigu xaqnimuu ku dhismaa. 
\q1  
\v 13 Boqorradu bushimaha xaqa ah way ku farxaan, 
\q1 Oo kii si qumman u hadlana way jecel yihiin. 
\q1  
\v 14 Boqor cadhadiisu waa sida warqaadayaal geeriyeed, 
\q1 Laakiinse nin caqli leh ayaa qaboojin doona. 
\q1  
\v 15 Nuurka wejiga boqorka nolol baa ku jirta, 
\q1 Oo raallinimadiisuna waa sida daruurta roobka dambe. 
\q1  
\v 16 In xigmad la helaa intee bay ka sii wanaagsan tahay in dahab la helo! 
\q1 In waxgarasho la helaana waa laga doortaa in lacag la helo. 
\q1  
\v 17 Kuwa qumman jidkoodu waa inay sharka ka leexdaan, 
\q1 Kii jidkiisa dhawraa naftiisuu ilaaliyaa. 
\q1  
\v 18 Kibirku wuxuu hor socdaa baabba', 
\q1 Oo madaxweynaanuna waxay hor socotaa dhicid. 
\q1  
\v 19 In kuwa kibirsan booli lala qaybsado 
\q1 Waxaa ka sii wanaagsan in kuwa hooseeya laysla sii hoosaysiiyo. 
\q1  
\v 20 Kii hadalka dhegaystaa wax wanaagsan buu heli doonaa, 
\q1 Oo ku alla kii Rabbiga aaminaana waa barakaysan yahay. 
\q1  
\v 21 Kii qalbigiisu caqli leeyahay waxaa loogu yeedhi doonaa mid miyir leh, 
\q1 Oo bushimaha macaankooduna waxbarashuu kordhiyaa. 
\q1  
\v 22 Waxgarashadu waa u il nololeed kii haysta, 
\q1 Laakiinse edbinta nacasyadu waa nacasnimo. 
\q1  
\v 23 Kii caqli leh qalbigiisu afkiisuu wax baraa, 
\q1 Oo waxbarashuu bushimihiisa u kordhiyaa. 
\q1  
\v 24 Hadalkii wacanu waa sida awlallo shinniyeed oo kale, 
\q1 Nafta wuu u macaan yahay, oo lafahana waa u caafimaad. 
\q1  
\v 25 Waxaa jirta waddo dadka la qumman, 
\q1 Laakiinse dhammaadkeedu waa jidadkii dhimashada. 
\q1  
\v 26 Kii hawshooda gaajadiisuu u hawshoodaa, 
\q1 Waayo, afkiisaa qasba isaga. 
\q1  
\v 27 Ninkii waxmatare ahu xumaan buu qodqodaa, 
\q1 Oo bushimihiisana waxaa ku jira dab wax gubaya. 
\q1  
\v 28 Ninkii qalloocanu muran buu beeraa, 
\q1 Oo kii xan badanuna wuxuu kala kaxeeyaa saaxiibbo. 
\q1  
\v 29 Ninka wax dulmaa deriskiisuu sasabtaa, 
\q1 Oo wuxuu u kaxeeyaa jid aan wanaagsanayn. 
\q1  
\v 30 Kii indhaha isugu qabta inuu wax qalloocan hindiso, 
\q1 Oo bushimihiisa qaniinaa, shar buu soo wadaa. 
\q1  
\v 31 Madaxa cirro lahu waa taaj sharfeed 
\q1 Haddii laga helo jidka xaqnimada. 
\q1  
\v 32 Kii cadhada u gaabiyaa waa ka wanaagsan yahay kii xoog badan, 
\q1 Oo kii ruuxiisa xukumaana waa ka wanaagsan yahay kii magaalo qabsada. 
\q1  
\v 33 Saamiga waxaa lagu tuuraa dhabta, 
\q1 Laakiinse go'aankiisa oo dhan Rabbigaa leh. 
\b  
\c 17  
\q1  
\v 1 Wuxoogaa cunto qallalan ah oo xasilloonaanu la jirto 
\q1 Ayaa ka wanaagsan guri hilib allabari ka buuxo oo diriru la jirto. 
\q1  
\v 2 Addoonkii caqli lahu wuxuu xukumi doonaa wiilkii ceeb soo jiida, 
\q1 Oo walaalaha ayuu la dhaxal geli doonaa. 
\q1  
\v 3 Weelka lacagta lagu safeeyo lacagtaa iska leh, oo foornadana dahabkaa iska leh, 
\q1 Laakiinse Rabbigu qalbiyaduu imtixaamaa. 
\q1  
\v 4 Xumaanfaluhu wuxuu maqlaa bushimaha shar leh, 
\q1 Oo beenaaluhuna wuxuu dhegaystaa carrabka xun. 
\q1  
\v 5 Ku alla kii miskiinka ku majaajiloodaa wuxuu caayaa Kan sameeyey, 
\q1 Kii belaayooyin ku farxaana ma taqsiir la'aan doono. 
\q1  
\v 6 Odayaasha waxaa taaj u ah carruurta carruurtooda, 
\q1 Oo sharafta carruurtuna waa aabbayaashood. 
\q1  
\v 7 Hadalkii weynu nacas uma eka, 
\q1 Sidaas oo kalena bushimihii been sheegaa amiir uma eka. 
\q1  
\v 8 Hadiyaddu waxay kii haysta la tahay sida dhagax qaali ah, 
\q1 Oo meel alla meeshay u leexataba way ku barwaaqowdaa. 
\q1  
\v 9 Kii xadgudub qariyaa jacayl buu doondoonaa, 
\q1 Laakiinse kii xaal ku noqnoqdaa saaxiibbuu kala kaxeeyaa. 
\q1  
\v 10 Canaantu waxay ninkii garasho leh u tartaa 
\q1 In ka badan boqol jeedal oo nacas lagu dhuftay ay u taraan. 
\q1  
\v 11 Ninkii shar lahu wuxuu doondoonaa caasinimo keliya, 
\q1 Sidaas daraaddeed waxaa isaga lagu diri doonaa farriingeeye aan naxariis lahayn. 
\q1  
\v 12 Nin ha la kulmo orso dhasheeda laga xaday, 
\q1 Intuu nacas nacasnimo samaynaya la kulmi lahaa. 
\q1  
\v 13 Ku alla kii wanaag xumaan ku celiyaa, 
\q1 Gurigiisa xumaanu ka fogaan mayso. 
\q1  
\v 14 Muranka bilowgiisu waa sida biyo la soo faruuray. 
\q1 Haddaba isqabashada iska daa intaan lays ilaaqin. 
\q1  
\v 15 Kii kan sharka leh xaq ka dhiga, iyo kii kan xaqa ah gardarro ku xukuma, 
\q1 Labadaba Rabbigu aad buu u karhaa. 
\q1  
\v 16 Lacagta nacaska gacantiisa ku jirtaa bal maxay u tartaa inuu xigmad ku soo iibsado, 
\q1 Waayo, isagu garasho ma leh? 
\q1  
\v 17 Had iyo goor saaxiibba saaxiibkii wuu jecel yahay, 
\q1 Walaalna wuxuu u dhashay dhibaato. 
\q1  
\v 18 Ninkii garaaddaranu gacan buu dhaar ugu dhiibaa, 
\q1 Oo wuxuu dammiin ku noqdaa deriskiisa hortiisa. 
\q1  
\v 19 Kii xadgudub jecelu muran buu jecel yahay, 
\q1 Oo kii iriddiisa sarraysiiyaana wuxuu doondoontaa baabba'. 
\q1  
\v 20 Kii qalbi qalloocan lahu wanaag ma helo, 
\q1 Oo kii carrab maroorsan lahuna wuxuu ku dhex dhacaa belaayo. 
\q1  
\v 21 Kii nacas dhalaa murugtiisuu u dhalaa, 
\q1 Oo nacas aabbihiisna farxad ma leh. 
\q1  
\v 22 Qalbigii faraxsanu waa dawo wanaagsan, 
\q1 Laakiinse qalbigii jabanu lafahuu engejiyaa. 
\q1  
\v 23 Ninkii shar lahu laabtuu laaluush ka qaataa, 
\q1 Si uu jidadka garta u qalloociyo. 
\q1  
\v 24 Xigmaddu waxay hor joogtaa kii garasho leh; 
\q1 Laakiinse nacaska indhihiisu waxay eegaan dhulka darafkiisa. 
\q1  
\v 25 Wiilkii nacas ahu waa u murug aabbihiis, 
\q1 Waana u qadhaadh tii dashay. 
\q1  
\v 26 Weliba ma wanaagsana in kii xaq ah la taqsiiro, 
\q1 Ama in kuwa sharafka leh qummanaantooda aawadeed wax loogu dhufto. 
\q1  
\v 27 Kii hadalkiisa yareeyaa, aqoon buu leeyahay, 
\q1 Oo kii qalbigiisu qabow yahayna waa nin garasho leh. 
\q1  
\v 28 Xataa nacasku markuu iska aamusan yahay waxaa loo yaqaan mid caqli leh, 
\q1 Kii bushimihiisa isku qabtana nin miyir leh. 
\b  
\c 18  
\q1  
\v 1 Kii gooni isu soocaa, wuxuu doondoonaa damaciisa, 
\q1 Oo xigmadda oo dhanna wuu ku kacaa. 
\q1  
\v 2 Nacasku waxgarashada kuma farxo, 
\q1 Laakiinse wuxuu ku farxaa uun inuu waxa qalbigiisa ku jira muujiyo. 
\q1  
\v 3 Markii kii shar lahu yimaado waxaa kaloo timaada quudhsasho, 
\q1 Sharafla'aantana waxaa la timaada ceeb. 
\q1  
\v 4 Nin afkiis erayada ku jiraa waa sida biyo gun dheer, 
\q1 Oo isha xigmadduna waa sida durdur socda. 
\q1  
\v 5 Ma wanaagsana in kan sharka leh loo eexdo, 
\q1 Ama in kan xaqa ah garta lagu afgembiyo. 
\q1  
\v 6 Nacaska bushimihiisu waxay keenaan muran, 
\q1 Oo afkiisuna wuxuu u yeedhaa karbaash. 
\q1  
\v 7 Nacaska afkiisu waa u baabba', 
\q1 Oo bushimihiisuna naftiisay dabin u noqdaan. 
\q1  
\v 8 Kii xan badan erayadiisu waa sida cunto macaan, 
\q1 Oo waxay ku degaan meelaha caloosha ugu hooseeya. 
\q1  
\v 9 Kii shuqulkiisa caajis ku ahu, 
\q1 Wuxuu walaal u yahay kii wax kharriba. 
\q1  
\v 10 Rabbiga magiciisu waa noobiyad xoog leh, 
\q1 Kii xaq ahu iyaduu ku cararaa, meel sarena wuu ku nabad galaa. 
\q1  
\v 11 Ninkii taajir ah maalkiisu waa u magaalo xoog leh, 
\q1 Oo waa u derbi dheer sida ay la tahay isaga. 
\q1  
\v 12 Dadka qalbigiisu waa kibraa intaanu baabbi'in ka hor, 
\q1 Oo sharaftana waxaa ka horraysa is-hoosaysiinta. 
\q1  
\v 13 Kii xaajo ka jawaabaa isagoo aan maqlin, 
\q1 Waa u nacasnimo iyo ceeb. 
\q1  
\v 14 Nin qalbigiisu waa u adkaysan karaa cudurkiisa, 
\q1 Laakiinse qalbi jaban bal yaa u dulqaadan kara? 
\q1  
\v 15 Kii miyir leh qalbigiisu wuxuu helaa aqoon, 
\q1 Oo kuwa caqliga leh dhegtooduna waxay doondoontaa aqoon. 
\q1  
\v 16 Nin hadiyaddiisu meel bay u bannaysaa. 
\q1 Oo waxay isaga hor keentaa rag waaweyn. 
\q1  
\v 17 Kii dacwaddiisa u hor mara, mid xaq ah baa la moodaa, 
\q1 Laakiinse deriskiisaa ka daba yimaada oo imtixaama isaga. 
\q1  
\v 18 Saamigu wuxuu joojiyaa murammo, 
\q1 Oo wuxuu kala kaxeeyaa kuwa xoogga badan. 
\q1  
\v 19 In walaal la xumeeyey la soo celiyo waa ka sii adag tahay in magaalo xoog leh la qabsado, 
\q1 Oo murammona waa ka xoog badan yihiin qalcad biraheeda. 
\q1  
\v 20 Nin calooshiisu waxay ka buuxsami doontaa midhaha afkiisa, 
\q1 Oo wuxuu isagu ka dhergi doonaa waxa bushimihiisa u kordha. 
\q1  
\v 21 Geeri iyo nololuba waxay ku jiraan itaalka carrabka, 
\q1 Oo kuwa jeceluna waxay cuni doonaan midhihiisa. 
\q1  
\v 22 Ku alla kii afo helaa wuxuu helaa wax wanaagsan, 
\q1 Oo Rabbigana raallinimuu ka helaa. 
\q1  
\v 23 Miskiinku baryootan buu ku hadlaa, 
\q1 Laakiinse taajirku si qallafsan buu ugu jawaabaa. 
\q1  
\v 24 Ninkii saaxiibbo badsadaa naftiisuu kharribaa, 
\q1 Laakiin waxaa jira saaxiib walaalkaa kaaga dhow. 
\b  
\c 19  
\q1  
\v 1 Miskiinka daacadnimadiisa ku socda ayaa ka wanaagsan 
\q1 Nacaska bushimihiisu qalloocan yihiin. 
\q1  
\v 2 Oo weliba in naftu aqoon la'aato ma wanaagsana, 
\q1 Oo kii cagihiisu degdegaanna wuu ambadaa. 
\q1  
\v 3 Nin nacasnimadiisu jidkiisay qalloocisaa, 
\q1 Oo isagu qalbigiisa ayuu Rabbiga uga cadhoodaa. 
\q1  
\v 4 Maalku wuxuu badiyaa saaxiibbo, 
\q1 Laakiinse miskiinku saaxiibkiisa buu ka soocmaa. 
\q1  
\v 5 Markhaatigii been ahu ma taqsiir la'aan doono, 
\q1 Oo kii been ku hadlaana ma baxsan doono. 
\q1  
\v 6 Kuwa badan ayaa deeqsiga raallinimo ka baryi doona, 
\q1 Oo nin kastaaba waa u saaxiib kii hadiyado bixiya. 
\q1  
\v 7 Miskiinka walaalihiis oo dhammu way neceb yihiin, 
\q1 Haddaba saaxiibbadiisuna intee bay ka fogaan doonaan! 
\q1 Isagu hadal buu kala daba tagaa iyaga, laakiinse way tageen. 
\q1  
\v 8 Kii xigmadda helaa naftiisuu jecel yahay, 
\q1 Oo kii waxgarashada xajistaana wax wanaagsan buu heli doonaa. 
\q1  
\v 9 Markhaatigii been ahu ma taqsiir la'aan doono, 
\q1 Oo kii been ku hadlaana wuu halligmi doonaa. 
\q1  
\v 10 Nacaska raaxo uma eka, 
\q1 Waxaana taas ka sii liita in addoon amiirro xukumo. 
\q1  
\v 11 Nin miyirkiisu cadho buu ka celiyaa, 
\q1 Oo waxaa isaga ammaan u ah inuu xadgudub dhaafo. 
\q1  
\v 12 Boqorka cadhadiisu waa sida libaaxa cidiisa, 
\q1 Laakiinse raallinimadiisu waa sida sayaxa cawska ku dega. 
\q1  
\v 13 Wiilkii nacas ahu waa u belaayo aabbihiis, 
\q1 Oo naag murammadeeduna waa sida dhibicyo aan kala go'in. 
\q1  
\v 14 Hoy iyo hanti aabbayaashaa laga dhaxlaa, 
\q1 Laakiinse afo miyir leh xagga Rabbigaa laga helaa. 
\q1  
\v 15 Caajisnimo waxay keentaa hurdo weyn, 
\q1 Oo qofkii caajis ahuna wuu gaajoon doonaa. 
\q1  
\v 16 Kii amarka dhawraa naftiisuu dhawraa, 
\q1 Laakiinse kii jidadkiisa fudaydsadaa wuu dhiman doonaa. 
\q1  
\v 17 Kii miskiinka u naxaa Rabbiguu wax amaahiyaa, 
\q1 Oo wanaaggii uu sameeyeyna wuu u celin doonaa. 
\q1  
\v 18 Wiilkaaga edbi intay rajo jirto, 
\q1 Laakiinse naftaada ha ku qasbin si uu u dhinto. 
\q1  
\v 19 Ninkii cadho badan waa la taqsiiri doonaa, 
\q1 Waayo, haddaad mar isaga samatabbixiso, haddana waa inaad mar kale sidii oo kale ku samaysaa. 
\q1  
\v 20 Talada maqal, oo edbinta qaado, 
\q1 Si aad ugu dambaystaada caqli u yeelatid. 
\q1  
\v 21 Nin qalbigiisa waxaa ku jira hindisooyin badan, 
\q1 Habase ahaatee waxaa taagnaan doonta talada Rabbiga. 
\q1  
\v 22 Nin waxaa loo doonayaa waa raxmaddiisa, 
\q1 Oo miskiinkuna waa ka wanaagsan yahay beenaalaha. 
\q1  
\v 23 Kii Rabbiga ka cabsada waxaa loo kaxeeyaa xagga nolosha, 
\q1 Wuuna sii dheregsanaan doonaa, 
\q1 Oo sharna loo keeni maayo. 
\q1  
\v 24 Ninkii caajis ahu wuxuu gacanta geliyaa xeedhada, 
\q1 Oo mar dambe xagga afkiisa uma soo celiyo. 
\q1  
\v 25 Kan wax quudhsada garaac, oo garaadlaawaha ayaa miyir yeelan doona, 
\q1 Oo kii garasho leh canaano, oo isna aqoon buu sii korodhsan doonaa. 
\q1  
\v 26 Kii aabbihiis kharriba, hooyadiisna erya, 
\q1 Waa wiil ceeb keena oo cay soo jiida. 
\q1  
\v 27 Wiilkaygiiyow ka joogso in markaad edbinta maqashid 
\q1 Aad dabadeed hadalka aqoonta ka ambatid. 
\q1  
\v 28 Markhaatigii waxmatare ahu gartuu quudhsadaa, 
\q1 Oo kan sharka leh afkiisuna wuxuu liqaa xumaan. 
\q1  
\v 29 Kuwa wax quudhsada waxaa loo diyaariyey xukunno, 
\q1 Oo dhabarka nacasyadana waxaa loo diyaariyey karbaash. 
\b  
\c 20  
\q1  
\v 1 Khamri waa dadquudhsade, waxa lagu sakhraamona waa qaylokiciye, 
\q1 Oo ku alla kii ku qaldamaana caqli ma laha. 
\q1  
\v 2 Boqorka cabsigeliddiisu waa sida libaaxa cidiisa, 
\q1 Oo ku alla kii ka xanaajiyaa, naftiisuu ku dembaabaa. 
\q1  
\v 3 Nin inuu dirir ka joogsado waa u sharaf, 
\q1 Laakiinse nacas waluba wuu ilaaqtamaa. 
\q1  
\v 4 Kii caajis ahu qabowga aawadiis beer ma jeexo, 
\q1 Oo sidaas daraaddeed wakhtiga beergooyska wuu baryootami doonaa, oo waxba ma heli doono. 
\q1  
\v 5 Talada dadka qalbigiisa ku jirtaa waa sida biyo gun dheer, 
\q1 Laakiinse ninkii garasho leh ayaa ka soo dhaansan doona. 
\q1  
\v 6 Dadka intooda badanu waxay naadiyaan raxmaddooda, 
\q1 Laakiinse nin aamin ah bal yaa heli kara? 
\q1  
\v 7 Ninka xaqa ah oo daacadnimadiisa ku socda, 
\q1 Carruurtiisu way barakaysnaadaan isaga dabadiis. 
\q1  
\v 8 Boqorkii carshiga garsooridda ku fadhiyaa 
\q1 Indhihiisuu sharka oo dhan ku kala firdhiyaa. 
\q1  
\v 9 Bal yaa odhan kara, Qalbigayga waan nadiifiyey, 
\q1 Oo dembigayga waan ka daahirsanahay? 
\q1  
\v 10 Miisaanno kala cayn ah iyo qiyaaso kala cayn ah, 
\q1 Labaduba Rabbiga waa u karaahiyo. 
\q1  
\v 11 Xataa ilmo yar waxaa lagu yaqaan falimihiisa, 
\q1 Inuu shuqulkiisu daahir yahay iyo inuu hagaagsan yahayba. 
\q1  
\v 12 Dhegta wax maqasha iyo isha wax aragtaba, 
\q1 Labadaba Rabbigaa sameeyey. 
\q1  
\v 13 Hurdo ha jeclaan, waaba intaas oo aad caydhowdaaye. 
\q1 Indhaha kala qaad, oo cuntaad ka dhergi doontaa. 
\q1  
\v 14 Kan wax iibsadaa wuxuu yidhaahdaa, Waa xun yahay, waa xun yahay, 
\q1 Laakiinse markuu tago ayuu faanaa. 
\q1  
\v 15 Waxaa jira dahab iyo luul badan, 
\q1 Laakiinse bushimihii aqoon lahu waa jawharad qaali ah. 
\q1  
\v 16 Kii qof qalaad dammiinta dharkiisa ka qaad, 
\q1 Oo markuu shisheeyayaal dammiinto, isaga rahmad ahaan u hay. 
\q1  
\v 17 Cuntadii khiyaano lagu helaa dadka way u macaan tahay, 
\q1 Laakiinse dabadeed afkiisa waxaa ka buuxsami doona quruurux. 
\q1  
\v 18 Qasdi kasta waxaa lagu taagaa talo, 
\q1 Oo waano wanaagsan ku dagaallan. 
\q1  
\v 19 Kii sida mid xan badan u warwareegaa wuxuu daaha ka qaadaa waxyaalo qarsoon, 
\q1 Haddaba sidaas daraaddeed kii bushimihiisa kala qaada ha ku darsamin. 
\q1  
\v 20 Kii aabbihiis ama hooyadiis caaya, 
\q1 Laambaddiisa waxaa lagu bakhtiin doonaa gudcur dam ah. 
\q1  
\v 21 Dhaxalkii markii hore degdeg lagu helay, 
\q1 Ugu dambaysta ma barakoobi doono. 
\q1  
\v 22 Ha odhan, Shar baan ka abaalgudayaa. 
\q1 Rabbiga sug, oo isna wuu ku badbaadin doonaa. 
\q1  
\v 23 Miisaanno kala cayn ahu Rabbiga waa u karaahiyo, 
\q1 Oo kafaddii khiyaano ahuna ma wanaagsana. 
\q1  
\v 24 Nin socodkiisu waa xagga Rabbiga, 
\q1 Haddaba sidaas daraaddeed dad sidee buu jidkiisa u garan karaa? 
\q1  
\v 25 Waa u dabin nin inuu nacasnimo ku yidhaahdo, Waa quduus, 
\q1 Oo uu dabadeed u nidraa inuu wax weyddiiyo. 
\q1  
\v 26 Boqorkii caqli lahu kuwa sharka leh wuu hufaa, 
\q1 Oo wuxuu dushooda marsiiyaa giringirta. 
\q1  
\v 27 Dadka ruuxiisu waa laambaddii Rabbiga, 
\q1 Oo wuxuu baadhaa caloosha meelaha ugu hooseeya oo dhan. 
\q1  
\v 28 Naxariista iyo runtu boqorkay ilaaliyaan, 
\q1 Oo carshigiisuna wuxuu ku taagnaadaa naxariis. 
\q1  
\v 29 Dhallinyarada xooggoodu waa ammaantooda, 
\q1 Oo cirrada odayaashuna waa quruxdooda. 
\q1  
\v 30 Garaaciddii nabro yeeshaa waxay dadka ka nadiifisaa sharka, 
\q1 Oo dilidda karbaashkuna sidaas oo kalay u gashaa caloosha meelaha ugu hooseeya. 
\b  
\c 21  
\q1  
\v 1 Boqorka qalbigiisu wuxuu ku jiraa gacanta Rabbiga sida webiyada biyaha ah, 
\q1 Oo wuxuu u leexiyaa meel alla meeshuu doonayo. 
\q1  
\v 2 Nin jidkiis waluba waa la qumman yahay isaga, 
\q1 Laakiinse Rabbigu qalbiyaduu miisaamaa. 
\q1  
\v 3 Waxaa Rabbigu allabari ka sii jecel yahay 
\q1 In xaqnimo iyo gar la sameeyo. 
\q1  
\v 4 Indho qab weyn iyo qalbi kibirsan, 
\q1 Kuwaas oo ah kuwa sharka leh laambaddoodu waa dembi. 
\q1  
\v 5 Kuwa dadaala fikirradoodu waxay u geeyaan barwaaqo. 
\q1 Laakiinse ku alla kii degdeg badanu wuxuu u degdegaa inuu wax u baahdo oo keliya. 
\q1  
\v 6 Khasnadihii carrab been badan lagu helaa waa sida ceeryaamo hor iyo dib loo kaxeeyey, 
\q1 Oo kuwa doondoontaana dhimashay doonaan. 
\q1  
\v 7 Kuwa sharka leh dhacoodu iyaguu baabbi'in doonaa, 
\q1 Maxaa yeelay, iyagu waxay diidaan inay gar sameeyaan. 
\q1  
\v 8 Ninkii eed badan qaba jidkiisu aad buu u qalloocan yahay, 
\q1 Laakiinse kii daahirsan shuqulkiisu waa hagaagsan yahay. 
\q1  
\v 9 In guriga dushiisa dhinac laga joogo ayaa ka roon 
\q1 In guri weyn naag muran badan lala joogo. 
\q1  
\v 10 Kii shar leh naftiisu xumaan bay doonaysaa, 
\q1 Oo deriskiisuna raallinimo kama helo hortiisa. 
\q1  
\v 11 Markii mid wax quudhsada la taqsiiro, garaadlaawahu wuu caqliyaystaa, 
\q1 Oo kii caqli leh marka la edbiyona aqoon buu helaa. 
\q1  
\v 12 Kii xaq ahu wuxuu ka fikiraa kii shar leh gurigiisa, 
\q1 Iyo sida kuwa sharka leh loogu afgembiyo sharnimadooda daraaddeed. 
\q1  
\v 13 Kii dhegihiisa u fureeyaa si aanu qaylada miskiinka u maqlin, 
\q1 Isaga qudhiisuna wuu qaylin doonaa, laakiinse lama maqli doono. 
\q1  
\v 14 Hadiyaddii qarsoodi lagu bixiyaa xanaaqay qabowjisaa, 
\q1 Oo laaluushkii laabta laysu geliyaana cadho kulul buu qabowjiyaa. 
\q1  
\v 15 Kii xaq ahu inuu gar sameeyo waa u farxad, 
\q1 Laakiinse kuwa xumaanta ka shaqeeya waa u baabba'. 
\q1  
\v 16 Ninkii jidka waxgarashada ka habaabaa 
\q1 Wuxuu la joogi doonaa ururka kuwii dhintay. 
\q1  
\v 17 Kii raaxaysi jecelu miskiin buu ahaan doonaa, 
\q1 Oo kii khamri iyo saliid jeceluna taajir ma noqon doono. 
\q1  
\v 18 Kii shar lahu wuxuu furasho u noqon doonaa kii xaq ah, 
\q1 Khaayinkuna wuxuu furasho u noqon doonaa kii qumman. 
\q1  
\v 19 In lamadegaanka la joogo ayaa ka roon 
\q1 In naag muran iyo cadho badan lala joogo. 
\q1  
\v 20 Khasnad qaali ah iyo saliid baa ku jira kan caqliga leh gurigiisa, 
\q1 Laakiinse nacasku wixiisa wuu wada liqaa. 
\q1  
\v 21 Kii xaqnimo iyo naxariis raacaa 
\q1 Wuxuu helaa nolol iyo xaqnimo iyo sharaf. 
\q1  
\v 22 Kii caqli lahu kor buu ugu baxaa magaalada kuwa xoogga badan derbigeeda, 
\q1 Oo weliba xoogga ay isku hallaynayaan oo dhan ayuu hoos u ridaa. 
\q1  
\v 23 Ku alla kii afkiisa iyo carrabkiisa dhawraa 
\q1 Naftiisuu dhibaatooyin ka dhawraa. 
\q1  
\v 24 Ninkii kibirsan ee qab weyn waxaa magiciisa la yidhaahdaa quudhsade, 
\q1 Oo wuxuu ku shaqeeyaa cadhada kibirka. 
\q1  
\v 25 Ninkii caajis ah waxaa dila damaciisa, 
\q1 Waayo, gacmihiisu waxay diidaan inay hawshoodaan. 
\q1  
\v 26 Waxaa jira kuwo maalinta oo dhan si hunguri weyn wax u damca, 
\q1 Laakiinse kii xaq ahu wax buu bixiyaa oo ma ceshado. 
\q1  
\v 27 Ka sharka leh allabarigiisu waa karaahiyo, 
\q1 Oo markuu niyo xun ku bixiyona way ka sii daran tahay! 
\q1  
\v 28 Markhaatifuraha beenta ahu waa baabbi'i doonaa, 
\q1 Laakiinse ninkii wax maqla hadalkiisu waa raagi doonaa. 
\q1  
\v 29 Ninkii shar lahu wejigiisuu adkeeyaa, 
\q1 Laakiinse kii qummanu jidadkiisuu u fiirsadaa. 
\q1  
\v 30 Ma jirto xigmad ama waxgarasho 
\q1 Ama talo Rabbiga ka gees ah. 
\q1  
\v 31 Faraska waxaa loo diyaariyaa maalinta dagaalka, 
\q1 Laakiinse guusha waxaa leh Rabbiga. 
\b  
\c 22  
\q1  
\v 1 Magac wanaagsan baa laga doortaa maal badan, 
\q1 Oo nimcana waa ka wanaagsan tahay lacag iyo dahab. 
\q1  
\v 2 Taajirka iyo miskiinku way wada kulmaan, 
\q1 Oo Rabbigu waa kii kulligood sameeyey. 
\q1  
\v 3 Ninkii miyir lahu sharkuu arkaa, wuuna dhuuntaa, 
\q1 Laakiinse garaadlaawayaashu way iska sii maraan, waana la taqsiiraa. 
\q1  
\v 4 Is-hoosaysiinta iyo Rabbiga ka cabsashadiisa abaalgudkoodu 
\q1 Waxaa weeyaan hodantinimo iyo sharaf iyo nolol. 
\q1  
\v 5 Qodxan iyo dabinnaba waxay yaalliin jidka ninka qalloocan, 
\q1 Laakiinse kii naftiisa dhawraa waa ka fogaan doonaa iyaga. 
\q1  
\v 6 Ilmo u rabbee siduu ku socon lahaa, 
\q1 Oo isna xataa markuu gaboobo kama leexan doono. 
\q1  
\v 7 Taajirku masaakiintuu u taliyaa 
\q1 Oo kii wax amaahdaana midiidin buu u yahay kii wax amaahiya. 
\q1  
\v 8 Kii xumaan beeraa wuxuu goosan doonaa belaayo, 
\q1 Oo usha cadhadiisuna way dhammaan doontaa. 
\q1  
\v 9 Kii il deeqsiya lahu wuu barakoobi doonaa, 
\q1 Waayo, isagu wuxuu cuntadiisa wax ka siiyaa masaakiinta. 
\q1  
\v 10 Kan wax quudhsada eri, oo muranku wuu bixi doonaa, 
\q1 Dirirta iyo cayduna way dhammaan doonaan. 
\q1  
\v 11 Kii daahirsanaanta qalbiga jecel, 
\q1 Oo bushimihiisu nimco leeyihiin, xataa boqorka ayaa saaxiibkiis ahaan doona. 
\q1  
\v 12 Indhaha Rabbigu waxay dhawraan ka aqoonta leh, 
\q1 Laakiinse isagu wuxuu afgembiyaa erayada khaayinka. 
\q1  
\v 13 Kii caajis ahu wuxuu yidhaahdaa, Libaax baa dibadda jooga, 
\q1 Oo jidka dhexdiisa ayaa laygu dili doonaa. 
\q1  
\v 14 Naago qalaad afkoodu waa god dheer, 
\q1 Oo waxaa ku dhici doona kii xagga Rabbiga laga nacay. 
\q1  
\v 15 Nacasnimadu waxay ku xidhan tahay qalbiga ilmaha. 
\q1 Laakiinse usha edbintu way ka fogayn doontaa. 
\q1  
\v 16 Kii miskiinka u dulma inuu maal korodhsado, 
\q1 Iyo kii taajirka wax siiyaaba hubaal way baahnaan doonaan. 
\s1 Erayada Kuwa Caqliga Leh 
\q1  
\v 17 Dhegta u dhig, oo erayada kuwa caqliga leh maqal, 
\q1 Oo qalbigana aqoontayda u jeedi. 
\q1  
\v 18 Waayo, waa wax wanaagsan haddii aad uurka ku haysatid, 
\q1 Oo hadday dhammaantood bushimahaaga diyaar ku ahaadaan. 
\q1  
\v 19 Bal eeg, adigaan maanta iyaga ku ogeysiiyey, 
\q1 Inaad Rabbiga aaminsan tahay. 
\q1  
\v 20 Miyaanan waxyaalo wanaagsan kuugu qorin 
\q1 Talooyinka iyo aqoonta, 
\q1  
\v 21 Si aan kuu ogeysiiyo hubaasha erayada runta, 
\q1 Inaad erayada runta uga jawaabtid kuwii ku soo diray? 
\q1  
\v 22 Miskiinka ha dhicin, waayo, isagu waa miskiin, 
\q1 Oo kan dhibaataysanna meesha iridda ha ku dulmin, 
\q1  
\v 23 Waayo, Rabbiga ayaa dacwadooda u qaadi doona, 
\q1 Oo kuwa iyaga dhaca naftoodana wuu dhici doonaa. 
\q1  
\v 24 Ha la saaxiibin nin xanaaq badan, 
\q1 Oo nin cadho kululna waa inaanad la socon, 
\q1  
\v 25 Waaba intaas oo aad jidkiisa baratid, 
\q1 Oo aad naftaadana dabin ku riddid. 
\q1  
\v 26 Ha noqonin sida kuwa gacanta dhaar ugu dhiiba, 
\q1 Ama sida kuwa deyman u dammiinta. 
\q1  
\v 27 Haddaanad haysan wax aad bixiso, 
\q1 Bal muxuu sariirtaada hoostaada uga la bixi? 
\q1  
\v 28 Soohdinta hore oo ay awowayaashu dhigeen 
\q1 Innaba ha durkin. 
\q1  
\v 29 Miyaad aragtaa nin shuqulkiisa ku dadaala? 
\q1 Isagu wuxuu istaagi doonaa boqorro hortood. 
\q1 Oo kuwa hoose hortoodana ma istaagi doono. 
\b  
\c 23  
\q1  
\v 1 Markaad u fadhiisatid inaad taliye wax la cuntid, 
\q1 Aad uga fiirso waxa hortaada yaal, 
\q1  
\v 2 Oo mindi cunaha iska saar 
\q1 Haddaad tahay nin hunguri weyn. 
\q1  
\v 3 Cuntadiisa macaan ha damcin, 
\q1 Waayo, waa cunto khiyaaneed. 
\q1  
\v 4 Ha isku daalin si aad taajir ku noqotid. 
\q1 Oo xigmaddaadana ka joogso. 
\q1  
\v 5 Ma waxaad indhaha ku dayaysaa wax aan jirin? 
\q1 Waayo, hubaal maalku wuxuu yeeshaa baalal, 
\q1 Sida gorgor samada u duula oo kale. 
\q1  
\v 6 Kan isha sharka leh kibistiisa ha cunin, 
\q1 Cuntadiisa macaanna ha damcin, 
\q1  
\v 7 Waayo, isagu waxaa weeye siduu qalbiga kaga fikiro; 
\q1 Wuxuu kugu leeyahay, Cun oo cab, 
\q1 Laakiinse qalbigiisu kulama jiro. 
\q1  
\v 8 Wixii aad cuntay waad soo mantagi doontaa, 
\q1 Oo erayadaadii macaanaana way kaa lumi doonaan. 
\q1  
\v 9 Nacas waxba ha kula hadlin, 
\q1 Waayo, isagu xigmadda hadalkaaga wuu quudhsan doonaa. 
\q1  
\v 10 Soohdintii hore ha durkin, 
\q1 Beeraha agoommadana ha dhex gelin, 
\q1  
\v 11 Waayo, bixiyahoodu waa xoog badan yahay; 
\q1 Oo isaga ayaa dacwadooda kugu qaadi doona. 
\q1  
\v 12 Qalbigaaga edbinta u jeedi, 
\q1 Oo dhegahana erayada aqoonta. 
\q1  
\v 13 Ilmaha edbin ha u diidin, 
\q1 Waayo, haddaad isaga ul ku garaacdid, ma dhiman doono. 
\q1  
\v 14 Ul baad isaga ku garaaci doontaa, 
\q1 Oo naftiisaad She'ool ka samatabbixin doontaa. 
\q1  
\v 15 Wiilkaygiiyow, haddii qalbigaagu caqli leeyahay, 
\q1 Qalbigayguna wuu farxi doonaa. 
\q1  
\v 16 Haah, oo xataa uurkaygu wuu rayrayn doonaa, 
\q1 Markay bushimahaagu wax qumman ku hadlaan. 
\q1  
\v 17 Qalbigaagu yaanu dembilayaal ka hinaasin, 
\q1 Laakiinse maalinta oo dhan Rabbiga ka cabso. 
\q1  
\v 18 Waayo, hubaal waxaa jira abaalgud, 
\q1 Oo rajadaaduna kaama go'i doonto. 
\q1  
\v 19 Wiilkaygiiyow, i maqal, oo caqli yeelo, 
\q1 Oo qalbigaagana jidka ku toosi. 
\q1  
\v 20 Ha dhex joogin khamriyacabyada 
\q1 Iyo kuwa hunguriweynaanta hilibka u cuna, 
\q1  
\v 21 Waayo, kii sakhraan ah iyo kii hunguri weynuba way caydhoobi doonaan, 
\q1 Oo lulona nin calal bay u xidhi doontaa. 
\q1  
\v 22 Dhegayso aabbahaagii ku dhalay, 
\q1 Oo hooyadaana ha quudhsan markay gabowdo. 
\q1  
\v 23 Runta soo iibso, oo ha sii iibin, 
\q1 Oo weliba waxaad ku sii darsataa xigmadda iyo edbinta iyo waxgarashada. 
\q1  
\v 24 Kii xaq ah aabbihiis aad buu u farxi doonaa, 
\q1 Oo kii ilmo caqli leh dhalaana farxad buu ka heli doonaa. 
\q1  
\v 25 Aabbahaa iyo hooyadaaba ha farxeen, 
\q1 Oo tii ku dhashayna ha rayrayso. 
\q1  
\v 26 Wiilkaygiiyow, qalbigaaga i sii, 
\q1 Oo indhahaaguna jidadkayga ha dhawreen. 
\q1  
\v 27 Waayo, dhillo waa booraan dheer, 
\q1 Oo naag qalaadna waa god cidhiidhi ah. 
\q1  
\v 28 Sida tuug oo kale ayay u gabbataa, 
\q1 Oo waxay dadka ku dhex badisaa khaayinnada. 
\q1  
\v 29 Bal yaa hoog leh? Oo yaa caloolxumo leh? Oo yaa murammo leh? 
\q1 Oo yaa calaacal badan leh? Oo yaa u dhaawacan sababla'aan? 
\q1 Oo yaa indho casaan ah leh? 
\q1  
\v 30 Waa kuwa wakhti dheer ku raaga khamriga, 
\q1 Waana kuwa u taga inay doondoontaan khamri laysku daray. 
\q1  
\v 31 Ha fiirin khamrigu markuu casaado, 
\q1 Markuu koobka ka dhex dhalaalo, 
\q1 Iyo markuu si wanaagsan u shubmayoba. 
\q1  
\v 32 Ugu dambaysta wuxuu wax u qaniinaa sida abeesada, 
\q1 Oo sida jilbiskana wax buu u qaniinaa. 
\q1  
\v 33 Indhahaagu waxay arki doonaan naago qalaad, 
\q1 Oo qalbigaaguna wuxuu ku hadli doonaa waxyaalo qalloocan. 
\q1  
\v 34 Oo waxaad ahaan doontaa sida kan badda dhexdeeda jiifsada, 
\q1 Ama sida ka dakhalka dhaladiisa sare seexda. 
\q1  
\v 35 Waxaad odhan doontaa, Wax bay igu dhufteen, laakiin waxba ima yeelin. 
\q1 Way i garaaceen, iskamana aanan garan; 
\q1 Bal goormaan toosi doonaa? Weli mar kalaan doonan doonaa. 
\b  
\c 24  
\q1  
\v 1 Dad shar leh ha ka masayrin, 
\q1 Hana jeclaysan inaad iyaga la joogtid. 
\q1  
\v 2 Waayo, qalbigoodu wuxuu ka fikiraa kharribaad, 
\q1 Oo bushimahooduna waxay ku hadlaan belaayo. 
\q1  
\v 3 Guri wuxuu ku dhismaa xigmad, 
\q1 Wuxuuna ku taagnaadaa waxgarasho, 
\q1  
\v 4 Qawladuhuna aqoontay kaga buuxsamaan 
\q1 Maal kasta oo qaali ah oo qurux badan. 
\q1  
\v 5 Ninkii caqli lahu xoog buu leeyahay, 
\q1 Oo ninkii aqoon lahuna itaal buu sii korodhsadaa. 
\q1  
\v 6 Waayo, waa inaad talo wanaagsan ku dagaallantaa, 
\q1 Oo waxaa taliyayaal badan la jirta nabadgelyo. 
\q1  
\v 7 Xigmaddu nacaska way ka dheer tahay, 
\q1 Isagu xagga iridda afkiisa kuma kala qaado. 
\q1  
\v 8 Kii ku fikira inuu xumaan sameeyo, 
\q1 Waxaa loogu yeedhi doonaa belaayo-sameeye. 
\q1  
\v 9 Fikirka nacasnimadu waa dembi, 
\q1 Kii wax quudhsadaana waa u karaahiyo dadka. 
\q1  
\v 10 Maalinta dhibaatada haddaad liicdid, 
\q1 Itaalkaagu waa yar yahay. 
\q1  
\v 11 Samatabbixi kuwa dhimashada loo wadayo, 
\q1 Kuwa ku dhow in la gowracona dib uga qabo. 
\q1  
\v 12 Haddaad tidhaahdid, Bal eeg, waxan ma aannu garanayn, 
\q1 Kan qalbiyada miisaamaa miyaanu ka fiirsanayn? 
\q1 Oo kan naftaada dhawraa miyaanu ogayn? 
\q1 Oo miyaanu isagu nin walba ugu abaalgudayn sida shuqulkiisu yahay? 
\q1  
\v 13 Wiilkaygiiyow, malab cun, waayo, wuu wanaagsan yahay, 
\q1 Oo waxaad cuntaa awlallada malabka, taas oo kuu dhadhan macaan. 
\q1  
\v 14 Oo xigmadda aqoonteeduna sidaasoo kalay naftaada u ahaan doontaa, 
\q1 Oo haddaad iyada heshid waxaa jiri doona abaalgud, 
\q1 Oo rajadaaduna ma go'i doonto. 
\q1  
\v 15 Sida nin shar leh, ha u gabban kan xaqa ah gurigiisa, 
\q1 Oo rugtiisa nasashadana ha kharribin. 
\q1  
\v 16 Waayo, nin xaq ahu toddoba goor buu dhacaa, wuuna soo sara kacaa haddana, 
\q1 Laakiinse kuwa sharka leh waxaa lagu afgembiyaa belaayo. 
\q1  
\v 17 Ha rayrayn markuu cadowgaagu dhaco, 
\q1 Oo qalbigaaguna yaanu farxin markuu turunturoodo, 
\q1  
\v 18 Waayo, waaba intaas oo Rabbigu taas arkaa, oo ay shar la ahaato indhihiisa, 
\q1 Oo uu dabadeedna cadhadiisa ka soo celiyaa isaga. 
\q1  
\v 19 Xumaanfalayaasha aawadood ha isku dhibin, 
\q1 Kuwa sharka lehna ha ka masayrin, 
\q1  
\v 20 Waayo, kii shar leh abaalgud ma heli doono, 
\q1 Oo laambadda xumaanfalayaashana waa la bakhtiin doonaa. 
\q1  
\v 21 Wiilkaygiiyow, Rabbiga iyo boqorkaba ka cabso, 
\q1 Oo ha ku darsamin kuwa isrogrog badan, 
\q1  
\v 22 Waayo, belaayadoodu si degdeg ah ayay u soo kici doontaa, 
\q1 Oo bal yaa yaqaan baabbi'inta labadoodaba? 
\s1 Erayada Kale Oo Kuwa Caqliga Leh 
\q1  
\v 23 Oo weliba waxyaalahanuna waa wixii ay kuwa caqliga lahaa yidhaahdeen. 
\q1 In dadka garsooridda loogu kala eexdaa ma wanaagsana. 
\q1  
\v 24 Kii kan shar leh ku yidhaahda, Xaq baad tahay, 
\q1 Dadyowga ayaa habaari doona, oo quruumuhuna way karhi doonaan isaga, 
\q1  
\v 25 Laakiinse kuwii isaga canaantaa farxad bay yeelan doonaan, 
\q1 Oo dushoodana waxaa ku soo degi doonta barako wanaagsan. 
\q1  
\v 26 Kii jawaab qumman ku jawaabaa 
\q1 Bushimuhuu dhunkadaa. 
\q1  
\v 27 Shuqulkaaga dibadda ku hagaajiso, 
\q1 Oo beerta ku diyaarso, 
\q1 Oo dabadeedna gurigaaga dhiso. 
\q1  
\v 28 Deriskaaga sababla'aan markhaati ha ku furin, 
\q1 Oo bushimahaagana ha ku khiyaanayn. 
\q1  
\v 29 Hana odhan, Wixii uu igu sameeyey oo kale ayaan ku samayn doonaa, 
\q1 Oo ninkii sidii shuqulkiisu ahaa ayaan u abaalmarin doonaa. 
\q1  
\v 30 Waxaan ag maray ninka caajiska ah beertiisa, 
\q1 Iyo ninka garaadka daran beercanabkiisa, 
\q1  
\v 31 Oo bal eeg, kulligood waxaa ka baxay qodxan, 
\q1 Oo dhammaantoodna waxaa qariyey maraboob, 
\q1 Oo derbigoodii dhagaxa ahaana waa dumay. 
\q1  
\v 32 Markaasaan eegay oo aad uga fiirsaday, 
\q1 Waan fiiriyey oo wax ka bartay. 
\q1  
\v 33 Weliba in yar baad seexanaysaa, oo in yar baad gam'aysaa, 
\q1 Oo in yar baad gacmaha hurdo u laabaysaa, 
\q1  
\v 34 Haddaba caydhnimo waa kuu iman doontaa sida tuug oo kale, 
\q1 Oo baahina sida nin hub sita oo kale. 
\c 25  
\s1 Maahmaahyadii Kale Ee Sulaymaan 
\q1  
\v 1 Oo weliba kuwanuna waa maahmaahyadii Sulaymaan, 
\q1 Oo boqorkii Yahuudah oo Xisqiyaah ahaa raggiisii ay soo guuriyeen. 
\q1  
\v 2 Waa u ammaan Ilaah inuu xaal qariyo, 
\q1 Laakiinse waa u ammaan boqorrada inay xaal baadhaan. 
\q1  
\v 3 Sida samadu u sarrayso, oo dhulkuna u gun dheer yahay, 
\q1 Ayaan qalbiga boqorrada loo baadhi karin. 
\q1  
\v 4 Lacagta wasakhda ka qaad, 
\q1 Oo dabadeedna waxaa lacagshubaha uga soo bixi doona weel. 
\q1  
\v 5 Boqorka hortiisa kuwa sharka leh ka fogee, 
\q1 Oo carshigiisuna xaqnimuu ku taagnaan doonaa. 
\q1  
\v 6 Ha isweynweynayn boqorka hortiisa, 
\q1 Oo kuwa waaweyn meeshoodana ha istaagin. 
\q1  
\v 7 Amiirkii aad indhahaaga ku aragtay 
\q1 Intii hortiisa lagu hoosaysiin lahaa, 
\q1 Waxaa kuu wanaagsan iyadoo lagu yidhaahdo, Halkan sare kaalay. 
\q1  
\v 8 Dirir degdeg ha ugu bixin, 
\q1 Waaba intaasoo aad ugu dambaysta garan weydaa waxaad samayn lahayd, 
\q1 Markii uu deriskaagu ku ceebeeyey dabadeed. 
\q1  
\v 9 Dacwadaada deriskaaga kala dood, 
\q1 Laakiinse mid kale xaalkiisa qarsoon ha sheegin, 
\q1  
\v 10 Waaba intaas oo uu ku caayaa kii maqlaa, 
\q1 Oo aanay ceebtaadu kaa hadhin. 
\q1  
\v 11 Hadalkii si hagaagsan loogu hadlaa 
\q1 Wuxuu la mid yahay tufaaxyo dahab ah oo lagu dhex sameeyey taswiiro lacag ah. 
\q1  
\v 12 Kii caqli leh oo wax canaantaa wuxuu dhegta wax maqasha oo addeecda ula mid yahay 
\q1 Hilqado dahab ah iyo wax laysku sharraxo oo dahab saafiya ah. 
\q1  
\v 13 Wargeeyihii aamin ahu wuxuu kuwii isaga soo diray ula mid yahay 
\q1 Qabowga barafka cad oo wakhtiga beergooyska, 
\q1 Waayo, isagu wuxuu qabowjiyaa nafta sayidyadiisa. 
\q1  
\v 14 Ku alla kii hadiyad been ah isku faaniyaa 
\q1 Wuxuu la mid yahay daruuro iyo dabayl aan roob lahayn. 
\q1  
\v 15 Waxaa xaakin wax lagu oggolaysiiyaa dulqaadasho badan, 
\q1 Carrab macaanuna laftuu jebiyaa. 
\q1  
\v 16 Malab ma heshay? In kugu filan oo keliya ka cun, 
\q1 Waaba intaas oo intaad ka dheregto aad soo hunqaacdaaye. 
\q1  
\v 17 Cagtaadu ha ku yaraato guriga deriskaaga, 
\q1 Waaba intaasoo uu kaa daalaa oo uu ku necbaadaaye. 
\q1  
\v 18 Ninkii deriskiisa marag been ah ku furaa 
\q1 Waa sida budh iyo seef iyo fallaadh af badan oo kale. 
\q1  
\v 19 In wakhtiga dhibaatada nin aaminlaawe ah laysku halleeyo 
\q1 Waa sida ilig jaban iyo cag murkacatay oo kale. 
\q1  
\v 20 Kii qalbi murugaysan u gabyaa 
\q1 Waa sida mid maalin qabow huwiska iska qaada iyo sida khal soodhe lagu shubo oo kale. 
\q1  
\v 21 Cadowgaagu hadduu gaajaysan yahay, wax uu cuno sii, 
\q1 Hadduu harraadsan yahayna waraabi, 
\q1  
\v 22 Waayo, dhuxulo dab ah ayaad madaxiisa ku tuuli doontaa, 
\q1 Oo Rabbiguna waa kuu abaalgudi doonaa. 
\q1  
\v 23 Dabaysha woqooyi roob bay keentaa, 
\q1 Sidaas oo kale carrabkii xan badanna weji cadhaysan buu keenaa. 
\q1  
\v 24 In guriga dushiisa dhinac laga joogo ayaa ka roon 
\q1 In guri weyn naag muran badan lala joogo. 
\q1  
\v 25 Warkii wanaagsan oo dal fog ka yimaadaa 
\q1 Waa sida biyo qabow ay naf harraadsan u yihiin oo kale. 
\q1  
\v 26 Ninkii xaq ah ee kii shar leh isu dhiibaa 
\q1 Waa sida durdur qasmay iyo sida il biyood oo wasakhowday oo kale. 
\q1  
\v 27 In malab badan la cunaa ma wanaagsana, 
\q1 Sidaas oo kalena in ammaan la doondoontaa ammaan ma aha. 
\q1  
\v 28 Kii aan ruuxiisa u talin karinu 
\q1 Waa sida magaalo duntay oo aan derbi lahayn oo kale. 
\b  
\c 26  
\q1  
\v 1 Sida wakhtiga kulul aan baraf cad ugu habboonayn, oo wakhtiga beergooyska aan roob ugu habboonayn, 
\q1 Ayaan sharaf nacas ugu habboonayn. 
\q1  
\v 2 Sida shimbir iska wareegaysa iyo sida dabafallaadh iska duulaysa, 
\q1 Ayaan habaarkii sababla'aan ahu cidna ugu dhacayn. 
\q1  
\v 3 Jeedal faras buu ku habboon yahay, dacayna dameer, 
\q1 Ulina dhabarka nacaska. 
\q1  
\v 4 Nacas ha ugu jawaabin sida nacasnimadiisu tahay, 
\q1 Waaba intaasoo aad sidiisa oo kale noqotaaye. 
\q1  
\v 5 Nacas ugu jawaab sida nacasnimadiisu tahay, 
\q1 Waaba intaasoo uu isla caqli weynaadaaye. 
\q1  
\v 6 Kii nacas gacantiis farriin u sii dhiibaa 
\q1 Cagahuu iska gooyaa oo khasaaruu cabbaa. 
\q1  
\v 7 Sida lugaha curyaanku u laalaadaan 
\q1 Ayuu masaalkuna u yahay afka nacasyada. 
\q1  
\v 8 Kii nacas sharaf siiyaa 
\q1 Wuxuu la mid yahay mid wadhaf dhagax ku xidha oo kale. 
\q1  
\v 9 Sida qodaxdu u dhex gasho sakhraan gacantiis, 
\q1 Ayuu masaalkuna u yahay afka nacasyada. 
\q1  
\v 10 Kii nacaska ama kuwa jidka maraya kiraystaa 
\q1 Waa sida qaansoole dadka oo dhan dhaawaca oo kale. 
\q1  
\v 11 Nacas nacasnimadiisa ku noqnoqdaa 
\q1 Waa sida eey mantaggiisa ku noqnoqda oo kale. 
\q1  
\v 12 Nin isla caqli weyn ma aragtay? 
\q1 Waxaa isaga ka rajo roon nacas. 
\q1  
\v 13 Ninkii caajis ahu wuxuu yidhaahdaa, Libaax baa waddada jooga; 
\q1 Libaax baa jidka taagan. 
\q1  
\v 14 Sida albaabku birihiisa ugu noqnoqdo, 
\q1 Ayaa kii caajis ahuna sariirtiisa isugu rogrogaa. 
\q1  
\v 15 Kii caajis ahu wuxuu gacantiisa geliyaa xeedhadiisa, 
\q1 Oo inuu afkiisa ku soo celiyona waa ku dhib isaga. 
\q1  
\v 16 Kii caajis ahu waa iskala caqli badan yahay 
\q1 Toddoba nin oo xigmad ku jawaabi karta. 
\q1  
\v 17 Kii isagoo jidka iska maraya isku dhex dara dirir aanu waxba ku lahayn, 
\q1 Wuxuu la mid yahay mid eey dhegaha qabta oo kale. 
\q1  
\v 18 Sida nin waalan oo rida dab, 
\q1 Iyo fallaadho, iyo dhimasho, 
\q1  
\v 19 Ayuu yahay kii intuu deriskiisa khiyaaneeyo, 
\q1 Haddana yidhaahda, Miyaanan cayaarayn? 
\q1  
\v 20 Xaabola'aanta dabku waa bakhtiyaa, 
\q1 Oo meeshii aan mid xan badanu jooginna muranku waa ka joogsadaa. 
\q1  
\v 21 Sida dhuxuli raran u sii shiddo, qoryona dab u sii belbeliyaan, 
\q1 Ayuu ninkii muran badanuna dirir u sii kiciyaa. 
\q1  
\v 22 Kii xan badan erayadiisu waa sida cunto macaan, 
\q1 Oo waxay ku degaan meelaha caloosha ugu hooseeya. 
\q1  
\v 23 Bushimihii macaan iyo qalbigii shar lehba 
\q1 Waxay la mid yihiin weel dhoobo ah oo lagu dahaadhay lacag wasakhdeed. 
\q1  
\v 24 Kii wax necebu bushimihiisuu isku yeelyeelaa, 
\q1 Laakiinse uurkiisuu khiyaano ku kaydsadaa. 
\q1  
\v 25 Markuu si wacan u hadlo ha rumaysan, 
\q1 Waayo, waxaa qalbigiisa ku jira toddoba karaahiyo. 
\q1  
\v 26 In kastoo nacaybkiisu khiyaano isku daboolo, 
\q1 Xumaantiisa ayaa shirka lagu hor muujin doonaa. 
\q1  
\v 27 Ku alla kii bohol qodaaba isagaa ku dhex dhici doona, 
\q1 Oo kii dhagax giringiriyana, isaguu ku soo rogman doonaa. 
\q1  
\v 28 Carrabkii been sheega wuxuu neceb yahay kuwuu dhaawacay, 
\q1 Oo afkii wax faaniyaana wuxuu ka shaqeeyaa baabba'. 
\b  
\c 27  
\q1  
\v 1 Berrito ha ku faanin, 
\q1 Waayo, ma ogid waxay maalinu keeni doonto. 
\q1  
\v 2 Mid kale ha ku faaniyo oo yaanu afkaagu ku faanin, 
\q1 Shisheeye ha ku ammaano, oo yaanay bushimahaagu ku ammaanin. 
\q1  
\v 3 Dhagax waa culus yahay, oo cammuuduna way miisaan weyn tahay, 
\q1 Laakiinse waxaa labadoodaba ka sii culus nacas cadhadiis. 
\q1  
\v 4 Cadho waa naxariisdarro, xanaaqna waa daad, 
\q1 Laakiinse bal yaa hinaaso is-hor taagi kara? 
\q1  
\v 5 Canaantii bayaan ahu 
\q1 Waa ka wanaagsan tahay jacaylkii qarsoon. 
\q1  
\v 6 Saaxiib nabrihiisu waa daacadnimo, 
\q1 Laakiinse cadow dhunkashooyinkiisu waa khiyaano miidhan. 
\q1  
\v 7 Naftii dheregsanu xataa awlallada malabka waa ka yaqyaqsataa, 
\q1 Laakiinse naftii gaajaysan wax kasta oo qadhaadhuba way u macaan yihiin. 
\q1  
\v 8 Ninkii hoygiisa ka warwareegaa 
\q1 Waa sida shimbir buulkeeda ka warwareegta oo kale. 
\q1  
\v 9 Saliidda iyo cadarku qalbigay ka farxiyaan, 
\q1 Sidaas oo kalena waxaa nin ka farxiya macaanka saaxiibkiis oo ka yimaada talada qalbiga. 
\q1  
\v 10 Ha ka tegin saaxiibkaa iyo aabbahaa saaxiibkiis toona, 
\q1 Oo maalintii masiibadaadana guriga walaalkaa ha tegin, 
\q1 Deris kuu dhowu waa ka wanaagsan yahay walaal kaa fog. 
\q1  
\v 11 Wiilkaygiiyow, caqli yeelo, oo qalbigayga ka farxi, 
\q1 Si aan ugu jawaabo kii i caayaba. 
\q1  
\v 12 Ninkii miyir lahu sharkuu arkaa, wuuna dhuuntaa, 
\q1 Laakiinse garaadlaawayaashu way iska sii maraan, oo waana la taqsiiraa. 
\q1  
\v 13 Kii qof qalaad dammiinta dharkiisa ka qaad, 
\q1 Oo kii naag qalaad dammiintana isaga rahmad ahaan u hay. 
\q1  
\v 14 Kii intuu aroor hore kaco saaxiibkiis cod dheer ugu duceeya, 
\q1 Waxaa loo qaadan doonaa habaar. 
\q1  
\v 15 Maalin roobaabeed dhibicyadeeda aan kala go'in 
\q1 Iyo naag muran badanu waa isku mid. 
\q1  
\v 16 Ku alla kii iyada celiyaa, dabayshuu celiyaa. 
\q1 Gacantiisa midigna saliid bay qabataa. 
\q1  
\v 17 Bir baa bir afaysa, 
\q1 Oo sidaas oo kale nin baa saaxiibkiis afeeya. 
\q1  
\v 18 Ku alla kii berde xannaanaystaa midhihiisuu cuni doonaa. 
\q1 Oo kii sayidkiisa dhawrana waa la murwayn doonaa. 
\q1  
\v 19 Sida fool biyaha dhexdooda fool uga muuqdo, 
\q1 Ayaa nin qalbigiisu nin kale ugu muuqdaa. 
\q1  
\v 20 She'ool iyo halligaadu weligood ma dhergaan, 
\q1 Dadka indhihiisu weligood ma dhergaan. 
\q1  
\v 21 Weelka lacagta lagu safeeyo lacagtaa iska leh, oo foornadana dahabkaa iska leh, 
\q1 Sidaas oo kalena nin waxaa lagu tijaabiyaa ammaantiisa. 
\q1  
\v 22 In kastoo aad nacas tib iyo mooye hadhuudh kula tuntid, 
\q1 Weliba nacasnimadiisu ka tegi mayso isaga. 
\q1  
\v 23 Aad ugu dadaal inaad ogaatid xaalka adhigaaga, 
\q1 Oo lo'daadana si wanaagsan u ilaali. 
\q1  
\v 24 Waayo, maalku weligiis siima raago, 
\q1 Taajkuna ab ka ab miyuu waaraa? 
\q1  
\v 25 Cawska qallalan markii la gooyo mid cagaar ah oo jilicsan baa soo muuqda, 
\q1 Oo dhalatada buurahana waa la soo urursadaa. 
\q1  
\v 26 Baraarku waa kuu dhar, 
\q1 Oo adhiguna waa kuu qiimihii beerta. 
\q1  
\v 27 Waxaa jiri doona caano riyaad oo cunto ugu filan adiga iyo reerkaagaba, 
\q1 Iyo weliba masruufka gabdhaha kuu shaqeeya. 
\b  
\c 28  
\q1  
\v 1 Kuwa sharka lahu waxay cararaan iyadoo aan ciduna eryanayn, 
\q1 Laakiinse kuwa xaqa ahu waxay u dhiirran yihiin sida libaax oo kale. 
\q1  
\v 2 Waddan xadgudubkiisa aawadiis amiirradu way badan yihiin, 
\q1 Laakiinse ninkii waxgarasho iyo aqoon leh dowladdiisu way sii raagtaa. 
\q1  
\v 3 Miskiin masaakiinta dulmaa 
\q1 Waa sida roob dhulka xaadha oo aan cunto ka tegin. 
\q1  
\v 4 Kuwa sharciga ka tagaa waxay ammaanaan kuwa sharka leh, 
\q1 Laakiinse kuwa sharciga dhawra ayaa iyaga la dirira. 
\q1  
\v 5 Nimanka sharka lahu garsooridda ma gartaan, 
\q1 Laakiinse kuwa Rabbiga doondoonaa wax walbay gartaan. 
\q1  
\v 6 Kii jidad qalloocan ku socda, in kastoo uu taajir yahay, 
\q1 Waxaa ka roon miskiinka daacadnimadiisa ku socda. 
\q1  
\v 7 Ku alla kii sharciga dhawraa waa wiil caqli leh, 
\q1 Laakiinse kii raaca kuwa cirta weyn, aabbihiisuu ceebeeyaa. 
\q1  
\v 8 Kii korsaar iyo ribo maalkiisa ku korodhsadaa, 
\q1 Wuxuu u ururin doonaa mid masaakiinta u naxariista. 
\q1  
\v 9 Kii dhegtiisa ka leexiya inuu sharciga maqlo, 
\q1 Xataa baryootankiisu waa karaahiyo. 
\q1  
\v 10 Ku alla kii kuwa xaqa ah jid shar ah ku ambiyaa, 
\q1 Isagaa ku dhici doona godkiisa, 
\q1 Laakiinse kuwa qummanu wax wanaagsan bay dhaxli doonaan. 
\q1  
\v 11 Taajirku waa isla caqli weyn yahay, 
\q1 Laakiinse miskiinka waxgarashada leh ayaa isaga kashifa. 
\q1  
\v 12 Kuwa xaqa ahu markay guulaystaan, waxaa jirta ammaan weyn, 
\q1 Laakiinse markii kuwa sharka lahu sara kacaan dadku waa dhuuntaa. 
\q1  
\v 13 Kii xadgudubyadiisa qariyaa ma liibaani doono, 
\q1 Laakiinse kii qirta oo haddana ka tagaa, naxariis buu heli doonaa. 
\q1  
\v 14 Ninkii mar kasta cabsadaa waa barakaysan yahay, 
\q1 Laakiinse kii qalbigiisa sii adkeeyaa masiibuu ku dhici doonaa. 
\q1  
\v 15 Taliyihii shar lahu wuxuu dadka masaakiintaa ku yahay 
\q1 Sida libaax ciyaya iyo sida orso weerar ah oo kale. 
\q1  
\v 16 Amiirkii garaaddaranu waa nin dulun weyn, 
\q1 Laakiinse kii neceb faa'iidada xaqdarrada ah cimrigiisuu dheerayn doonaa. 
\q1  
\v 17 Ninkii nin dhiiggiis qabaa 
\q1 Wuxuu u carari doonaa godka, oo ninna yaanu ka joojin. 
\q1  
\v 18 Ku alla kii si qumman u socda waa la samatabbixin doonaa, 
\q1 Laakiinse kii si qalloocan laba jid ugu socdaa haddiiba wuu dhici doonaa. 
\q1  
\v 19 Kii dhulkiisa beertaa, cunto badan buu ka dhergi doonaa, 
\q1 Laakiinse kii waxmatarayaal raacaa wuxuu ka dhergi doonaa caydhnimo. 
\q1  
\v 20 Ninkii aamin ahu aad buu u barakoobi doonaa, 
\q1 Laakiinse kii taajirnimo ku degdegaa ma taqsiir la'aan doono. 
\q1  
\v 21 Ma wanaagsana in dadka loo kala eexdo, 
\q1 Iyo inuu nin xabbad kibis ah u xadgudbo toona. 
\q1  
\v 22 Kii taajirnimo ku degdegaa waa qumay, 
\q1 Mana oga inuu caydhoobi doono. 
\q1  
\v 23 Kii nin canaantaa wuxuu marka dambe heli doonaa 
\q1 Raallinimo ka badan kan carrabka ku faaniya. 
\q1  
\v 24 Kii aabbihiis ama hooyadiis wax ka dhaca oo haddana yidhaahda, 
\q1 Taasu xadgudub ma aha, 
\q1 Wuxuu saaxiib la yahay kii wax dumiya. 
\q1  
\v 25 Kii hunguri weynu muran buu kiciyaa, 
\q1 Laakiinse kii Rabbiga isku halleeya waa la barwaaqaysiin doonaa. 
\q1  
\v 26 Kii qalbigiisa isku halleeyaa waa nacas, 
\q1 Laakiinse ku alla kii si caqli ah u socda waa la samatabbixin doonaa. 
\q1  
\v 27 Kii miskiinka wax siiyaa ma baahan doono, 
\q1 Laakiinse kii indhaha ka qarsada aad baa loo habaari doonaa. 
\q1  
\v 28 Markii kuwa sharka lahu kacaan dadku waa dhuuntaa, 
\q1 Laakiinse markay halligmaan, kuwa xaqa ahu way sii kordhaan. 
\b  
\c 29  
\q1  
\v 1 Kii inta wax badan la canaanto ka madax adkaadaa, 
\q1 Dhaqso buu u jabi doonaa, dawona ma leh. 
\q1  
\v 2 Markii kuwa xaqa ahu amarka haystaan, dadku wuu reyreeyaa, 
\q1 Laakiinse markii kuwa sharka lahu xukunka wataan, dadku wuu taahaa. 
\q1  
\v 3 Kii xigmad jecelu aabbihiisuu ka farxiyaa, 
\q1 Laakiinse kii dhillooyin raacaa maalkiisuu khasaariyaa. 
\q1  
\v 4 Boqorku gar buu dalka ku dhisaa, 
\q1 Laakiinse kii laaluush jecelu wuu dumiyaa. 
\q1  
\v 5 Ninkii deriskiisa faaniyaa 
\q1 Shabag dabin ah ayuu cagihiisa hor dhigaa. 
\q1  
\v 6 Ninkii shar ah xadgudubkiisa waxaa ku jira dabin, 
\q1 Laakiinse kii xaq ahu waa iska heesaa oo reyreeyaa. 
\q1  
\v 7 Kii xaq ahu wuxuu ka war hayaa dacwadda masaakiinta, 
\q1 Laakiinse kii shar ahu ma yaqaan aqoontaas. 
\q1  
\v 8 Kuwa wax quudhsadaa magaalay dab qabadsiiyaan, 
\q1 Laakiinse kuwa caqliga lahu cadhay qabowjiyaan. 
\q1  
\v 9 Haddii nin caqli leh nin nacas ah la doodo, 
\q1 Nasasho ma jirto hadduu cadhoodo iyo hadduu qosloba. 
\q1  
\v 10 Dhiigyocabyadu kii kaamil ah way neceb yihiin, 
\q1 Laakiinse kuwa qumman waxay doondoonaan inay naftiisa badbaadshaan. 
\q1  
\v 11 Nacasku cadhadiisa oo dhan buu soo saaraa, 
\q1 Laakiinse kii caqli lahu dib buu u ceshadaa, wuuna aamusnaadaa. 
\q1  
\v 12 Haddii taliye been dhegaysto, 
\q1 Midiidinyadiisa oo dhammu waa wada shar miidhan. 
\q1  
\v 13 Miskiinka iyo khaayinku way wada kulmaan, 
\q1 Oo labadoodaba Rabbigu indhahooduu iftiimiyaa. 
\q1  
\v 14 Boqorkii daacadnimo masaakiinta ugu xukuma, 
\q1 Carshigiisu wuu dhisnaan doonaa weligiisba. 
\q1  
\v 15 Usha iyo canaantu caqli bay keenaan, 
\q1 Laakiinse ilmihii layska daayaa ceeb buu hooyadiis u soo jiidaa. 
\q1  
\v 16 Markii kuwa sharka lahu bataan, xadgudub baa sii kordha, 
\q1 Laakiinse kuwa xaqa ah ayaa dhiciddooda arki doona. 
\q1  
\v 17 Wiilkaaga edbi, oo isna wuu ku nasin doonaa, 
\q1 Haah, naftaada wuu ka farxin doonaa. 
\q1  
\v 18 Markii aan muujinu jirin dadku waa halligmaa, 
\q1 Laakiinse kii sharciga dhawraa waa barakaysan yahay. 
\q1  
\v 19 Addoon hadal kuma edeb yeesho, 
\q1 Waayo, in kastoo uu garanayo ka jawaabi maayo. 
\q1  
\v 20 Ma aragtay nin hadalkiisa ku degdega? 
\q1 Kaas waxaa ka rajo roon nacas. 
\q1  
\v 21 Kii addoonkiisa si wanaagsan u soo koriya tan iyo yaraantiisa, 
\q1 Ugu dambaysta wiil buu u noqon doonaa. 
\q1  
\v 22 Ninkii xanaaq badanu muran buu kiciyaa. 
\q1 Ninkii cadho kululuna xadgudub buu badsadaa. 
\q1  
\v 23 Nin kibirkiisu hoos buu u dejin doonaa, 
\q1 Laakiinse kii is-hoosaysiiyaa sharaf buu heli doonaa. 
\q1  
\v 24 Ku alla kii tuug la shirkoobaa naftiisuu nacaa, 
\q1 Habaarkuu maqlaa, laakiinse waxba kama sheego. 
\q1  
\v 25 Dadka ka cabsashadiisu wax bay dabtaa, 
\q1 Laakiinse kii Rabbiga isku halleeyaa wuu nabad geli doonaa. 
\q1  
\v 26 Kuwo badan baa taliyaha raallinimo ka doona, 
\q1 Laakiinse dadka garsooriddiisu waxay ka timaadaa xagga Rabbiga. 
\q1  
\v 27 Ninkii xaqdaranu waa u karaahiyo kuwa xaqa ah, 
\q1 Oo kii jidka ku qummanuna waa u karaahiyo kii shar ah. 
\c 30  
\s1 Erayadii Aguur 
\q1  
\v 1 Kuwanu waa erayadii Aaguur ina Yaaqeh, oo ahaa reer Masaa. 
\q1 Ninku wuxuu la hadlay Iitii'eel, iyo xataa Iitii'eel iyo Ukaal, oo ku yidhi, 
\q1  
\v 2 Hubaal anigu waan ka doqonnimo weynahay nin kastaba, 
\q1 Oo dad waxgarashadiisana ma lihi. 
\q1  
\v 3 Xigmad ma aan baran, 
\q1 Aqoonta Kan quduuska ahna ma aqaan. 
\q1  
\v 4 Yaa samada u baxay, oo ka soo degay? 
\q1 Yaa dabaysha gacmihiisa ku soo ururshay? 
\q1 Yaa biyaha dharkiisa ku guntay? 
\q1 Yaa dhulka darafyadiisa oo dhan dhisay? 
\q1 Magicii, wiilkiisana magicii, haddaad taqaan? 
\q1  
\v 5 Eray kasta oo Ilaah waa daahir; 
\q1 Oo isagu wuxuu gaashaan u yahay kuwa isaga aaminsan. 
\q1  
\v 6 Erayadiisa waxba ha ku darin, 
\q1 Waaba intaas oo uu ku canaantaa, oo lagu ogaadaa inaad beenaaleh tahay. 
\q1  
\v 7 Laba waxyaalood ayaan ku weyddiistay, 
\q1 Iyaga ha ii diidin intaanan dhiman. 
\q1  
\v 8 Wax aan waxtar lahayn iyo been iga fogee, 
\q1 Oo caydhnimo iyo taajirnimo midna ha i siin. 
\q1 Igu quudi cunto aanan ka maarmin, 
\q1  
\v 9 Waaba intaasoo intaan dhergo, aan adiga ku inkiraaye, oo aan idhaahdaa, Waa ayo Rabbigu? 
\q1 Amase waaba intaasoo aan miskiin noqdaa, oo intaan wax xado, 
\q1 Aan magaca Ilaahayga si been ah ugu hadal qaadaaye. 
\q1  
\v 10 Addoon sayidkiisa xan ha uga sheegin, 
\q1 Waaba intaas oo uu ku habaaraa, oo eed lagugu helaaye. 
\q1  
\v 11 Waxaa jira farcan aabbahood inkaara, 
\q1 Oo aan hooyadoodna u ducayn. 
\q1  
\v 12 Waxaa jira farcan isla daahirsan, 
\q1 Oo weliba aan nijaastoodii ka maydhmin. 
\q1  
\v 13 Waxaa jira farcan indhahoodu aad u sarreeyaan! 
\q1 Oo daboolka indhahoodana kor bay u qaadaan. 
\q1  
\v 14 Waxaa jira farcan ilkahoodu sida seefo oo kale yihiin, oo gowsahooduna sida mindiyo oo kale yihiin, 
\q1 Si ay masaakiinta dhulka uga baabbi'iyaan, oo ay kuwa baahanna dadka dhexdiisa uga dhammeeyaan. 
\q1  
\v 15 Culaacushu waxay leedahay laba gabdhood, oo leh, Na sii, Na sii. 
\q1 Waxaa jira saddex waxyaalood oo aan weligood dhergin, 
\q1 Haah, oo afar aan odhan, Bes, nagu filan; 
\q1  
\v 16 Waxaana weeye qabriga, iyo maxalka aan wax dhalayn, 
\q1 Iyo dhulka aan biyo ka dhergayn, 
\q1 Iyo dabka aan odhan, Bes, igu filan. 
\q1  
\v 17 Isha aabbaheed ku majaajiloota, 
\q1 Oo quudhsata inay hooyadeed addeecdo, 
\q1 Waxaa la soo bixi doona tukayaasha dooxada, 
\q1 Oo waxaa cuni doona gorgorrada. 
\q1  
\v 18 Waxaa jira saddex waxyaalood oo anigu aan aad ula yaabo, 
\q1 Haah, afar baan garan waayay, 
\q1  
\v 19 Oo iyana waxaa weeye siduu gorgor hawada u duulo, 
\q1 Siduu masna dhagax ugu socdo, 
\q1 Siday doonnina badda u maaxdo, 
\q1 Iyo siduu nin gabadh ula macaamiloodo. 
\q1  
\v 20 Sidaas oo kale waxaa ah naag dhillo ah sideeda, 
\q1 Taasoo intay wax cunto afka tirtirta, 
\q1 Oo haddana tidhaahda, Anigu waxba xumaan ma aan samayn. 
\q1  
\v 21 Saddex waxyaalood ayaa dhulku la gariiraa, 
\q1 Oo afar baanu qaadan karin, 
\q1  
\v 22 Waxaana weeye addoon markuu boqor noqdo, 
\q1 Iyo nacas markuu cunto ka dhergo, 
\q1  
\v 23 Iyo naag la nacay markay guursato, 
\q1 Iyo gabadh addoon ahu markay sayidaddeedii meesheeda gasho. 
\q1  
\v 24 Waxaa jira afar waxyaalood oo dhulka ku yaryar, 
\q1 Laakiinse aad iyo aad u caqli badan. 
\q1  
\v 25 Qudhaanjadu waa sida dad aan xoog badnayn, 
\q1 Laakiinse waxay cuntadooda soo diyaarsadaan guga. 
\q1  
\v 26 Walooyinku waa qoon taagdaran, 
\q1 Oo haddana waxay guryahooda ka samaystaan dhagaxyada dhexdooda; 
\q1  
\v 27 Ayaxu boqor ma leh, 
\q1 Weliba dhammaantood guuto guuto ayay u socdaan. 
\q1  
\v 28 Qorratadu waa wax gacanta lagu qaban karo, 
\q1 Weliba waxay joogtaa guryaha boqorrada. 
\q1  
\v 29 Waxaa jira saddex waxyaalood oo si fiican u socda, 
\q1 Haah, oo afar waa socod wanaagsan yihiin. 
\q1  
\v 30 Aar libaax oo ah kan xayawaanka ugu xoogga badan, 
\q1 Oo aan weliba midna dib uga noqon, 
\q1  
\v 31 Diiqa xarragoonaya, iyo orgiga; 
\q1 Iyo boqorka aanay dadku gees ka ahayn. 
\q1  
\v 32 Haddaad nacasnimo samaysay adoo isa sarraysiinaya, 
\q1 Ama aad wax shar ah ka fikirtay, 
\q1 Gacanta afka saar. 
\q1  
\v 33 Waayo, caanihii la lulaa subag bay soo saaraan, 
\q1 Sankii la maroojiyaana dhiig buu keenaa, 
\q1 Sidaas oo kalena cadhadii la qasbaa dirir bay keentaa. 
\c 31  
\s1 Erayadii Boqor Lemuu'eel 
\q1  
\v 1 Kuwanu waa erayadii Lemuu'eel oo ahaa boqorkii Masaa ay hooyadiis bartay isaga. 
\q1  
\v 2 Waa maxay, wiilkaygiiyow? 
\q1 Waa maxay, wiilkii uurkaygow? 
\q1 Waa maxay, wiilkii nidarradaydow? 
\q1  
\v 3 Xooggaaga naago ha siinin, 
\q1 Dawyadaadana ha siinin kuwa boqorrada dumiya. 
\q1  
\v 4 Lemuu'eelow, uma eka boqorrada, uma eka boqorradu inay khamri cabbaan, 
\q1 Oo amiirradana uma eka inay waxa lagu sakhraamo damcaan, 
\q1  
\v 5 Waaba intaasoo ay cabbaan, oo ay sharciga illoobaan, 
\q1 Oo ay kuwa dhibaataysan midkood gartiisa qalloociyaan. 
\q1  
\v 6 Waxa lagu sakhraamo siiya ka dhimashada ku dhow, 
\q1 Oo khamrigana waxaad siisaan kuwa naftoodu la qadhaadhaatay. 
\q1  
\v 7 Ha cabbo, oo caydhnimadiisa ha illoobo, 
\q1 Oo dhibaatadiisana yaanu mar dambe soo xusuusan innaba. 
\q1  
\v 8 Afka u fur carrablaawaha aawadiis, 
\q1 Si aad kuwa baabba'aya oo dhan u xaq mariso. 
\q1  
\v 9 Afka fur, oo si xaq ah u garsoor, 
\q1 Oo miskiinka iyo saboolka baahanba gartooda u qaad. 
\s1 Naagta Dabiicadda Wanaagsan Leh 
\q1  
\v 10 Bal yaa heli kara naag wanaagsan? 
\q1 Waayo, qiimaheedu waa ka sii badan yahay xataa luul. 
\q1  
\v 11 Waayo, qalbiga ninkeedu iyaduu isku halleeyaa, 
\q1 Oo isagu innaba uma baahnaan doono wax booli ah. 
\q1  
\v 12 Cimrigeeda oo dhan isaga wanaag bay u samayn doontaa, 
\q1 Oo innaba xumaan kuma samayn doonto. 
\q1  
\v 13 Waxay doondoontaa dhogor idaad iyo geed linen la yidhaahdo. 
\q1 Oo iyadoo raalli ku ah ayay gacmaheeda ku shaqaysaa. 
\q1  
\v 14 Iyadu waa sida doonniyaha baayacmushtariga, 
\q1 Oo cuntadeeda waxay ka keentaa meel fog. 
\q1  
\v 15 Waxay kacdaa iyadoo weli ay habeennimo tahay, 
\q1 Oo dadka reerkeeda ayay cunto siisaa, 
\q1 Oo gabdhaheedana hawshooday siisaa, 
\q1  
\v 16 Iyadu waxay ka fikirtaa beer, wayna soo iibsataa, 
\q1 Oo midhaha gacmaheeda ayay beercanab ku beerataa. 
\q1  
\v 17 Waxay dhexda ku xidhataa xoog, 
\q1 Oo gacmaheedana way xoogaysaa. 
\q1  
\v 18 Waxay eegtaa in baayacmushtarigeedu wanaagsan yahay; 
\q1 Laambaddeeduna habeenkii ma bakhtido. 
\q1  
\v 19 Waxay gacmaheeda ku fidisaa dunmiiqa, 
\q1 Oo sacabbadeeduna waxay qabtaan usha wareegta. 
\q1  
\v 20 Waxay sacabkeeda u furtaa miskiinka, 
\q1 Oo gacmaheedana waxay u fidisaa saboolka baahan. 
\q1  
\v 21 Dadka reerkeeda ugama cabsato dhaxanta barafka cad, 
\q1 Waayo, xaaskeeda oo dhammu waxay wada qabaan dhar labanlaab ah. 
\q1  
\v 22 Waxay samaysataa durraaxado daabac leh, 
\q1 Oo dharkeeduna waxaa weeye dhar aad u wanaagsan oo guduudan. 
\q1  
\v 23 Ninkeedana waxaa laga yaqaan irdaha magaalada, 
\q1 Markuu dhex fadhiisto waayeellada waddanka. 
\q1  
\v 24 Waxay samaysaa dhar wanaagsan, wayna iibisaa, 
\q1 Oo baayacmushtarigana waxay ka iibisaa boqorro dhexda lagu xidho. 
\q1  
\v 25 Xoog iyo sharaf ayaa iyada dhar u ah; 
\q1 Oo wakhtiga soo socda way ku qososhaa. 
\q1  
\v 26 Afkeeda waxay u kala qaaddaa xigmad; 
\q1 Oo carrabkeedana waxaa saaran sharciga raxmadda. 
\q1  
\v 27 Waxay aad u xannaanaysaa reerkeeda, 
\q1 Oo kibista caajisnimadana ma cunto. 
\q1  
\v 28 Carruurteedu way kacaan oo waxay ugu yeedhaan tan barakaysan, 
\q1 Oo weliba ninkeeduna wuu ammaanaa, isagoo leh; 
\q1  
\v 29 Dumar badan baa wanaag sameeyey, 
\q1 Laakiinse adigu waad ka sii wanaagsan tahay dhammaantood. 
\q1  
\v 30 Suuradwacnaantu waa khiyaano miidhan, oo quruxduna waa ceeryaamo oo kale, 
\q1 Laakiinse naagtii Rabbiga ka cabsata waa la ammaani doonaa. 
\q1  
\v 31 Midhihii gacmaheeda wax ka siiya, 
\q1 Oo shuqulladeeduna iyada ha ku ammaaneen irdaha magaalada.