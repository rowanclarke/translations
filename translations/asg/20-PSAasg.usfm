\id PSA ISHP Agwara Kambari [asg]
\toc3 Ishp
\toc2 Ishipa
\toc1 Ishipa
\mt2 KATAGARDA
\mt1 ISHIPA
\imt1 KUƁA̱YUWA̱
\im Katagarda ki Ishipa, ɗaɗa katagarda ki i ishipa n ka avasa a katagarda ka ciɗa. Uma kakau ɗa a ɗanai a̱ ka̱tsuma̱ ka makyan n a̱bunda̱i. Ishipa i nampa n avasa a, aza a Isaraila o ɓolongu ta̱ i ɗa a̱ ka̱na̱i kuyaꞋan ulinga n i ɗa a̱ ubuta̱ u kucikpa u le. A ukocishi, o ɓolongi i ɗa n atagarda o kutoni.
\ip Ishipa yi uɗani i nampa n ya avasa i ta̱ u pecekushi. Ishipa i kucikpa Ka̱shile yi ta̱ lo, n yi una̱singai u Ka̱shile. Avasa a̱ kula̱nsa̱ uɓa̱nki i ta̱ lo, n a̱ kula̱nsa̱ ukeɗi n wishi. Avasa a̱ kula̱nsa̱ kucinukpa ku unushi, n a̱ kula̱nsa̱ a takacika irala. Avasa a̱ kula̱nsa̱ ugboji wi ida̱shi i ta̱ lo. Avasa a nwalu a kubana a̱ ubuta̱ u kucikpa i ta̱ lo n a kuzuwa ku mogono.
\ip Avasa a nampa ra̱ka̱ adama a vuma te n uma ra̱ka̱ ɗa. Aza o yoku a kudana tsu na vuma wi a kupana a̱ ka̱ɗu ka̱ ni, aza o yoku tankpamu a kudana ili i na uma a̱ Ka̱shile i a kuciga n tsu na uma i a kupana.
\ip Yesu u yaꞋan ta̱ ulinga n ishipa. Aza a na a ɗanai uzuwakpani u savu a yaꞋan ta̱ ulinga n i ɗa, kpamu a yaꞋan ta̱ ulinga n i ɗa a iɗanishi i le. Ili i na i ɗikai a makyan ma na a̱ ciya̱i aza o kutoni, ɗa katagarda ka ishipa ko okpoi katagarda ka tsugbayin n ka kucikpa.
\iot Ili i na yi punu
\ip Ishipa amangatawun n amangerenkupa i ɗa, ɗa kpamu e peciki katagarda ka ugboku u tawun, tsu na i ugeri ɗanna.
\io1 Ishipa 1-41
\io1 Ishipa 42-72
\io1 Ishipa 73-89
\io1 Ishipa 90-106
\io1 Ishipa (107-150)
\c 1
\ms1 Katagarda ka iyain
\mr (Ishp 1--41)
\s1 Ma̱za̱nga̱ ma mayun
\q1 
\v 1 Vuza vu ma̱za̱nga̱ ɗa,
\q2 vuza na u tsu tono odoki a uma a gbani-gbani ba,
\q1 ko u tono uye wa aza a unushi ba,
\q2 ko u gbaɓa kaci n aza ulami ba.
\q1 
\v 2 Ama wi ta̱ a kupana uyoꞋo u tono wila̱ u Vuzavaguɗu,
\q2 wi ta̱ e kusheshe ku wila̱ wa a̱ ka̱ɗu ka̱ ni kanna n kayin.
\q1 
\v 3 Wi ta̱ tsu maɗanga,
\q2 ma na a̱ shikpa̱i a̱ iga̱Ꞌin i mini,
\q1 ma na ma tsu matsa a makyan ma̱ ni,
\q2 kpamu a̱vuku a̱ ni e ci ɗekpe ba,
\q1 u tsu ciya̱ ta̱ ulyaꞋi a ili i na u yaꞋin dem.
\q1 
\v 4 Ama uma a gbani-gbani i nannai ba,
\q2 I ta̱ tsu kopo ka na wunla̱i u tsu pura̱ngu.
\q1 
\v 5 Ka̱shile ta na ki ta̱ a kutakacika uma a gbani-gbani,
\q2 aza a unushi tamkpamu u pece le n uma a singai.
\q1 
\v 6 Adama a na Vuzavaguɗu wi ta̱ a̱ kula̱na̱ ukuna u uma a usuɓi,
\q2 Ama ulinga u uma a gbani-gbani wi ta̱ a kubanka le a̱ ukpisa̱.
\c 2
\s1 Mogono ma na Ka̱shile ka zagbai
\q1 
\v 1 Yiɗa̱i i zuwai uduniyan wi e kusheshe ka gbani-gbani?
\q2 Yiɗa̱i i zuwai ɗa uma i o kufoɓuso ka a gbani-gbani ka na a̱ kuciya̱ ili ba?
\q1 
\v 2 Yiɗa̱i i zuwai ɗa ngono ma aduniyan o foɓusoi kuvon?
\q2 Yiɗa̱i i zuwai ɗa aza o tsugono o ɓolongi ka̱ci ke le,
\q2 a kuyaꞋanka Vuzavaguɗu ugbami u kaci m mogono ma na wu erengi.
\q1 
\v 3 A danai,<<YaꞋan tsu uta̱ka̱ ka̱ci ka̱ tsu o tsugono ci le,
\q2 n tsugono tsu Vuzavaguɗu koɓolo n mogono ma na u zagbai,
\q2 tsu fa̱ta̱tsa̱ ekiye e le.>>
\q1 
\v 4 Ama ɗa Vuzavaguɗu u zoꞋosoi le ɗe gaɗi a kakuba ko tsugono ci ni,
\q2 u bonokoi le ili yi izoshi.
\q1 
\v 5 Ɗa u ɓarangi le n wupa,
\q2 wupa u ni u zuwai le a̱ rikpa̱i.
\q1 
\v 6 U danai, <<A Sihiyona kusan ku ciɗa ku va̱,
\q2 ɗa n zuwai mogono ma̱ va̱.>>
\q1 
\v 7 Ɗa mogono ma, ma danai, mi ta̱ a kusala ili i na Vuzavaguɗu u danai.
\q2 U danai mu,<<Avu maku ma̱ va̱ maꞋa,
\q2 anana mo okpo ta̱ esheku a̱ nu.
\q1 
\v 8 Folono mu, mi ta̱ e kuneke wu iɗika ra̱ka̱ yi okpo ili yi uka̱ni i nu,
\q1 Ka̱ta̱ aduniyan okpo upecu u nu.
\v 9 Vi ta̱ a kulyaꞋaka le tsugono n kalangu ka̱ viyum,
\q2 vu ɓoso le miri-miri tsu mogbodo ma̱ ciꞋin.>>
\q1 
\v 10 Adama a nannai, yaꞋin cicoꞋo, a̱ɗa̱ ngono,
\q2 i vaꞋanku a̱ɗu a̱ ɗa̱, a̱ɗa̱ aza o tsugono.
\q2 I bonoko a̱ɗu a̱ ɗa̱ ubuta̱ u te,
\q2 a̱ɗa̱ aza o tsugono tsa aduniyan.
\q1 
\v 11 YaꞋankai Vuzavaguɗu tsugbashi n wovon,
\q2 i yaꞋan ma̱za̱nga̱ n i jeꞋekei ikyamba,
\q1 
\v 12 Kuɗa̱ngi i lyaꞋaka maku ma\f + \fr 2:12 \fq maku ma \ft N kelentsu ka Yahuda kakuna ka ka̱ uta̱ e keteshe ba\f* kayala,
\q2 adama a na ka̱ta̱ u yaꞋan wupa i kuwa̱ ba,
\q2 adama a na wupa u ni wi ta̱ a kufuɗa kuɗa̱nga̱ n kute,
\q1 Aza a̱ ma̱za̱nga̱ a ɗa aza a na a banai wa̱ a̱ ni kula̱nsa̱ ubuta̱ u kusheɗeku.
\c 3
\s1 Avasa a usana a̱ kula̱nsa̱ uɓa̱nki
\d Vishipa vu Dawuda a makyan ma na u sumai a̱ a̱shi a Abusalom kolobo ka̱ ni.
\q1 
\v 1 Vuzavaguɗu, irala i va̱ yi ta̱ n a̱bunda̱i,
\q2 aza a na i a tsurala nu mpa a yimkpa ta̱.
\q1 
\v 2 n a̱bunda̱i i ta̱ a kadanshi ka̱ va̱, a kudana,
\q2 <<Ka̱shile ka ku isa yi ba.>>\qs Kuvuka\qs*
\q1 
\v 3 Ama avu Vuzavaguɗu, avu ɗa vi a̱ kula̱na̱ mu a̱ ubuta̱ dem,
\q2 avu ɗa vi ci neke mu ulyaꞋi,
\q2 vi kpamu e kuneke mu utsura u ka̱ɗu.
\q1 
\v 4 N ci yaꞋan ta̱ meɗevile u Vuzavaguɗu adama a̱ uɓa̱nki,
\q2 u tsu ushuki mu ta̱ ta na a kusan ku ciɗa ku ni.\qs Kuvuka\qs*
\q1 
\v 5 N tsu vaku ta̱ n lata,
\q2 ka̱ta̱ n ɗa̱nga̱ gbaga,
\q2 adama a na Vuzavaguɗu ɗa wi a̱ kula̱na̱ mu.
\q1 
\v 6 Mi a kupana wovon u uma a̱kpa̱n-a̱kpa̱n ba,
\q2 aza a na i a tsurala nu mpa ukambu dem.
\q1 
\v 7 Ɗa̱nga̱, Vuzavaguɗu!
\q2 Vu isa mu Ka̱shile ka̱ va̱!
\q1 Vu lyaꞋa irala i va̱,
\q2 vu una uma a gbani-gbani ra̱ka̱.
\q1 
\v 8 Wishi u tsu ta̱wa̱ ta̱ u Vuzavaguɗu,
\q2 yaꞋan u zuwaka uma a̱ ni una̱singai.\qs Kuvuka\qs*
\c 4
\s1 Avasa a̱ kulivi adama a uɓa̱nki
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n aꞋin a umolu. Vishipa vu Dawuda
\q1 
\v 1 Ushuku mu a ayin a na baci n yaꞋin meɗevile,
\q2 Ka̱shile ka̱ va̱!
\q1 Makyan ma na mi a̱ ka̱tsuma̱ ka atakaci,
\q2 vu okpo ka̱ɓa̱nki ka̱ va̱.
\q2 YaꞋanka mu kasingai, vu pana avasa a̱ va̱.
\q1 
\v 2 A̱ɗa̱ uma a nampa, wannai ɗai i ku ka̱sukpa̱ kula̱nga̱sa̱ kula ku va̱?
\q2 Ali n wannai ɗai i ku ka̱sukpa̱ ku ciga ili gbani,
\q2 n kutono ki ili ya aꞋuwa? \qs Kuvuka\qs*
\q1 
\v 3 I yeve a na Vuzavaguɗu ɗa,
\q2 u zagbakai ka̱ci ka̱ ni aza a usuɓi,
\q2 Vuzavaguɗu wi ta̱ a kupana ka mu ayin a na baci n ɗekei ni.
\q1 
\v 4 I yaꞋan baci wupa, ka̱ta̱ i ka̱sukpa̱ u zuwa ɗa̱ i yaꞋan unushi ba.
\q2 i sheshe mayin a̱ɗu a̱ ɗa̱,
\q2 a makyan ma na baci i vaki a ivaꞋamkpatsu i ɗa̱.\qs Kuvuka\qs*
\q1 
\v 5 Nekei Vuzavaguɗu alyuka a na o yotsoi,
\q2 ka̱ta̱ i zuwa a̱ɗu a̱ ɗa̱ wa̱ a̱ ni.
\q1 
\v 6 Uma n a̱bunda̱i i ta̱ lo a kudansa,
\q2 <<Ishi baci a ku zuwaka tsu una̱singai?>>
\q2 Vuzavaguɗu, indana tsu n asuvayali a̱ nu.
\q1 
\v 7 Ma̱za̱nga̱ ma na vu nekei mu mi ta̱ n a̱bunda̱i,
\q2 ali ma laꞋi aza a na i n ilikulya n ma̱kya̱n n a̱bunda̱i.
\q1 
\v 8 Mi ta̱ a kuvaku, n lata m ma̱ta̱na̱,
\q2 adama a na avu ɗa koci Vuzavaguɗu vi e ku ere mu.
\c 5
\s1 Avasa a̱ kula̱nsa̱ uɓa̱nki
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda: a kubana u ma̱zuɓi ma kulika̱ igbala.
\q1 
\v 1 Vuzavaguɗu, zuwa atsuvu vu pana kadanshi ka̱ va̱,
\q2 Ka̱ta̱ vu la̱na̱ kusheshe ku ka̱ɗu ka̱ va̱.
\q1 
\v 2 Mogono ma̱ va̱ n Ka̱shile ka̱ va̱,
\q2 pana ma̱shi ma̱ va̱ ma̱ kula̱nsa̱ uɓa̱nki,
\q2 adama a na wa̱ a̱ nu u ɗa mi a kuyaꞋan avasa.
\q1 
\v 3 Mi ta̱ a kuyaꞋan avasa wa̱ a̱ nu Vuzavaguɗu,
\q2 m kpasani vi ta̱ a kupana avasa a̱ va̱,
\q2 n kanna vi ta̱ a kupana ufolu u va̱,
\q2 ka̱ta̱ n vana wu ushuki.
\q1 
\v 4 Adama a na avu Ka̱shile,
\q2 vu tsu pana uyoꞋo u ka gbani-gbani ba,
\q2 vu tsu ka̱sukpa̱ uma a gbani-gbani a̱ ta̱wa̱ wa̱ a̱ nu ba.
\q1 
\v 5 Aza a̱ra̱ɗi a kushamgba e kelime ka̱ nu ba,
\q2 vu tsu iwan ta̱ aza a kuyaꞋan kagbanigbani.
\q1 
\v 6 Vu tsu una ta̱ aza aꞋuwa dem,
\q2 vu tsu ene ta̱ unata wa aza a munuka,
\q2 n aza o modoruko.
\q1 
\v 7 Ama mpa, adama a ucigi u nu u na u tsu sabaꞋa ba,
\q2 mi ta̱ a kuꞋuwa a kpaꞋa ku nu.
\q1 n uwa A̱Ꞌisa̱ a gbayin a ciɗa a̱ nu n cikpa wu,
\q2 n kuɗa̱ngu e kelime ka̱ nu.
\q1 
\v 8 Vuzavaguɗu, tono nu mpa a uye wu usuɓi u nu,
\q2 adama a na irala i va̱ i yimkpa ta̱,
\q2 yotsongu mu uye u nu e keteshe ciya̱ n tono.
\q1 
\v 9 I n kamayun a una̱ u le ba,
\q2 a̱ɗu e le i ta̱ tukpa n ukuna u munuka,
\q1 ogboroli e le asaun a ɗa,
\q2 elentsu e le kpamu kadanshi ka aꞋuwa kaꞋa koci.
\q1 
\v 10 Ka̱shile, kece le aza a unushi,
\q2 yaꞋan kagbanigbani ke le ko bono a kaci ke le.
\q1 Loko le kelime ka̱ nu, adama a unushi wa̱ a̱bunda̱i u le,
\q2 adama a na a yaꞋanka wu ta̱ ugbamukaci.
\q1 
\v 11 YaꞋan aza a na e sheɗeki wa̱ a̱ nu, a yaꞋan ma̱za̱nga̱.
\q2 yaꞋan a̱ ka̱na̱ kuyaꞋan ishipa adama a̱ ma̱za̱nga̱.
\q1 Vu inda le n ka̱ci ka̱ nu,
\q2 adama aza a na a cigai kula ku nu dem
\q2 a yaꞋan ma̱za̱nga̱ adama a̱ nu.
\q1 
\v 12 Mayun, Vuzavaguɗu vu zuwaka ta̱ aza a usuɓi una̱singai,
\q2 kasingai ka̱ nu kaꞋa ka kanzai le tsu ma̱ra̱ga̱.
\c 6
\s1 Avasa a̱ kula̱nsa̱ uɓa̱nki a makyan ma atakaci
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n aꞋin a umolu. A yaꞋan vu ɗa n ka̱la̱ka̱tsu ka Shimenitu. Vishipa vu Dawuda.
\q1 
\v 1 Vuzavaguɗu ka̱ta̱ vu ɓarangu mu a̱ ka̱tsuma̱ ka wupa u nu ba,
\q2 ka̱ta̱ vu gbara mu a̱ ka̱tsuma̱ ka wupa wu usuɗukpi u nu ba.
\q1 
\v 2 Pana asuvayali a̱ va̱ adama a na mo oꞋwo ta̱ ka̱u,
\q2 neke mu utsura adama a na mo okpo ta̱ luɓa̱.
\q1 
\v 3 Vuzavaguɗu, ka̱ɗu ka̱ va̱ ko voɗotso ta̱ ka̱u,
\q2 ali wannai ɗai n kuka̱na̱ kuvana wu?
\q1 
\v 4 Ta̱wa̱, Vuzavaguɗu vu isa mu,
\q2 isa mu adama ucigi u nu u na u tsu sabaꞋa ba.
\q1 
\v 5 A̱ ka̱tsuma̱ ka̱ a̱kpisa̱ yayi u kuciɓa n avu?
\q2 Ko vuza u kucikpa wu a kasaun ba.
\q1 
\v 6 Mo oꞋwo ta̱ ka̱u adama una̱mgbi u ka̱tsuma̱,
\q2 Kayin dem ivaꞋamkpatsu i va̱ i tsu ta̱na̱ ta̱ adama a̱ ma̱shi,
\q2 ubuta̱ u ku gbasatangu kaci ka̱ va̱ u ta̱na̱i adama a kujilya.
\q1 
\v 7 A̱shi a̱ va̱ a shitasa ta̱ adama a̱ ma̱shi ma̱ a̱bunda̱i,
\q2 ali a̱shi a̱ va̱ o doku ene uye ba, adama a irala i va̱.
\q1 
\v 8 Ka̱sukpa̱i mu, a̱ɗa̱ aza a ka gbani-gbani,
\q2 adama a na Vuzavaguɗu u pana ta̱ ma̱shi ma̱ va̱.
\q1 
\v 9 Vuzavaguɗu u pana ta̱ ufolu u va̱,
\q2 wu isa ta̱ avasa a̱ va̱.
\q1 
\v 10 Irala i va̱ ra̱ka̱ i ta̱ a kupana wono ali e jeꞋeke ikyamba.
\q2 I ta̱ a kukpatala n kafura, adama o wono wa̱ a̱bunda̱i.
\c 7
\s1 Avasa a̱ kula̱nsa̱ afada a usuɓi.
\d A yaꞋan vu ɗa n ka̱la̱ka̱tsu ka Shigiyonotu. Vishipa vu Dawuda vu na u yaꞋankai Vuzavaguɗu adama a̱ Kushi vuza vu aza a Bayami.
\q1 
\v 1 Vuzavaguɗu Ka̱shile ka̱ va̱, wa̱ a̱ nu u ɗa mi a̱ kula̱nsa̱ ubuta̱ u kusheɗeku,
\q2 Wawa mu ka̱ta̱ vu isa mu ekiye aza a na i a̱ kula̱nsa̱ wuma u va̱,
\q1 
\v 2 Ta baci nannai ba,
\q2 i ta̱ a kubanka mu a̱ ubuta̱ u na babu vuza na u ku isa mu.
\q2 Ta ɗe a ku sazasa mu tsu na kawu u tsu saza vuma.
\q1 
\v 3 Vuzavaguɗu Ka̱shile ka̱ va̱, ɗa baci n yaꞋin ili i ite a̱ ka̱tsuma̱ ki ili i nampa,
\q2 ali a̱ ciya̱ mu n unushi,
\q1 
\v 4 ko n yaꞋankai ka̱ja̱Ꞌa̱ ka̱ va̱ ka gbani-gbani,
\q2 ko ɗa baci n lyaꞋi utsura u vurala vu va̱ babu unushi.
\q1 
\v 5 YaꞋan Irala i va̱ i guva mu ali a̱ ka̱na̱ mu,
\q2 ka̱ta̱ a dasa mu a iɗika,
\q2 a̱ ka̱sukpa̱ mu punu a iɗika ya ukpa̱.\qs Kuvuka\qs*
\q1 
\v 6 Vuzavaguɗu, ɗa̱nga̱ n wupa u nu,
\q2 vu yaꞋan tsurala n wupa wu irala i va̱.
\q2 Ɗa̱nga̱ vu isa mu, vu yaꞋan afada a usuɓi.
\q1 
\v 7 YaꞋan o ɓolongu uduniyan ra̱ka̱ wa̱ a̱ nu,
\q2 vu lyaꞋa tsugono tsu le ɗe gaɗi.
\q1 
\v 8 Vuzavaguɗu avu ɗa vu ci yaꞋanka uma afada,
\q2 Vuzavaguɗu yaꞋanka mu afada tsu usuɓi u va̱
\q2 adama a na mi n unushi ba,
\q2 mi ta̱ kpamu n ma̱riki.
\q1 
\v 9 Avu Ka̱shile ka ciɗa,
\q2 avu na vu tsu la̱na̱ kusheshe ku vuma n ka̱ɗu ka̱ ni.
\q1 Vu shamgbatangu ka gbani-gbani ka uma,
\q2 ka̱ta̱ vu zuwa uma a̱ usuɓi a tsurukpa.
\q1 
\v 10 Ka̱shile kaꞋa ma̱ra̱ga̱ ma̱ va̱,
\q2 u tsu isa ta̱ aza a na o tsu tono yi.
\q1 
\v 11 Ka̱shile kayaꞋinkafada ka̱ usuɓi kaꞋa,
\q2 u tsu takacika ta̱ uma a gbani-gbani makyan dem.
\q1 
\v 12 Ɗa baci uma a̱ kpa̱ɗa̱i kushika̱ unushi u le,
\q2 Ka̱shile ki ta̱ e ku temgbe kotokobi ka̱ ni.
\q2 u lapula ta̱ ɗe utan u ni.
\q1 
\v 13 U foɓuso ta̱ ɗe ucanuku u kuvon u ni u tsukono,
\q2 Ɗa u gisanki ayaꞋa akina a̱ ni.
\q1 
\v 14 La̱na̱ tsu na uma a gbani-gbani e kusheshe a̱ɗu e le,
\q2 O kufoɓuso ukuna wa atakaci kpamu a kuyaꞋan aꞋuwa.
\q1 
\v 15 A̱ ga̱va̱ ta̱ kpenle ku uga̱vi,
\q2 ɗa a kucikpa a̱ yikpa̱i punu.
\q1 
\v 16 O foɓusokoi aza o yoku kawuya,
\q2 ama ɗa ko bonoi a kaci ke le.
\q2 o foɓusoi vishili, ɗanna vu bonoi a kaci ke le.
\q1 
\v 17 N cikpa ta̱ Vuzavaguɗu adama afada e mejege a̱ ni,
\q2 mi ta̱ a kuyaꞋan ishipa i kucikpa u Vuzavaguɗu MalaꞋimili.
\c 8
\s1 Tsugbayin tsu Ka̱shile n vuma
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda: a kubana u ma̱zuɓi a yaꞋan vu ɗa tsu na <<Giti.>>
\q1 
\v 1 Vuzavaguɗu, Vuzavaguɗu tsu,
\q2 e yeve ta̱ tsugbayin tsu nu a̱ ubuta̱ dem aduniyan,
\q1 avu na ucikpi u nu u yawai ɗe gaɗi,
\q2 
\v 2 Muku nu nreɓu a kucikpa wu.
\q1 ucikpi u nu wo okpo ta̱ mashilya a irala i nu,
\q2 adama a na a shamgbatangu irala i nu,
\q2 n aza a na i a kuciga kutsupa.
\q1 
\v 3 Ana mi indai gaɗi,
\q2 ulinga we ekiye a̱ nu,
\q2 wotoi n azangata,
\q2 a na vu zuwai a̱ ubuta̱ wi ida̱shi i le.
\q1 
\v 4 Ɗa n danai, yayi vuma ali vi a̱ kusa̱Ꞌa̱ yi?
\q2 Yayi vuma vu lima̱ ali vi a̱ kula̱na̱ yi?\x - \xo 8:4 \xt Ishp 144:3; A Ib 2:6\x*
\q1 
\v 5 N nannai dem, avu ɗa baci ba,
\q2 babu ili i na i laꞋi vuma,
\q2 ali vu nekei ni tsugbayin n ucikpi.
\q1 
\v 6 Vu zuwai ni u lyaꞋa tsugono ci ili i na vu yaꞋin dem,
\q2 Vu zuwai ili ra̱ka̱ yi okpoi ekiye a vuma,\x - \xo 8:6 \xt 1 Kor 15:27; Af 1:22; A Ib 2:8\x*
\q1 
\v 7 nu nlala n anaka,
\q2 nu nnama n kakamba feu,
\q1 
\v 8 nu nnu n adan,
\q2 ni ili i wuma i mini ra̱ka̱.
\q1 
\v 9 Vuzavaguɗu, Vuzavaguɗu tsu,
\q2 e yeve ta̱ tsugbayin tsu nu a̱ ubuta̱ dem aduniyan.
\c 9
\s1 Ucikpi u Ka̱shile adama afada a mayun.
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda: a kubana u ma̱zuɓi, a yaꞋan vu ɗa tsu ka̱la̱ka̱tsu ka <<Ukpa̱ u maku ma̱ va̱.>>
\q1 
\v 1 Vuzavaguɗu, mi ta̱ a kucikpa wu n ka̱ɗu ka̱ va̱ ra̱ka̱,
\q2 mi ta̱ a kudansa ili i mereve i na vu yain.
\q1 
\v 2 MalaꞋimili dem, mi ta̱ a kuyaꞋan ma̱za̱nga̱ adama a̱ nu.
\q2 Mi ta̱ a kuyaꞋan ishipa n cikpa kula ku nu.
\q1 
\v 3 Irala i va̱ i bono ta̱ n ka̱ca̱pa̱ ana ene nu,
\q2 a̱ yikpa̱i ɗa a̱ kuwa̱i.
\q1 
\v 4 Avu na vi kayaꞋinkafada ka usuɓi,
\q2 vu da̱sa̱ngi a kakuba ko tsugono ka̱ nu.
\q2 vu yaꞋin afada a na a yaꞋin mu derere.
\q1 
\v 5 Vu ɓarangi uduniyan.
\q2 ɗa vu unai uma a gbani-gbani,
\q2 vu urai ula e le ko wannai.
\q1 
\v 6 Unai irala i tsu ko wannai,
\q2 vu mutsukpa̱i likuci-likuci i le,
\q2 a cinukpai n ula e le gbende-gbende.
\q1 
\v 7 Ama Vuzavaguɗu mogono maꞋa ko wannai,
\q2 u zuwa ta̱ kakuba ko tsugono ci ni adama afada.
\q1 
\v 8 Wi ta̱ a kuyaꞋanka aduniyan afada a usuɓi,
\q2 a kukiɗaka uduniyan afada derere.
\q1 
\v 9 Vuzavaguɗu ɗa ubuta̱ u kusheɗeku wa aza a na a takacikai,
\q2 ubuta̱ u kusheɗeku u ɗa a makyan ma atakaci.
\q1 
\v 10 Vuzavaguɗu, aza a na e yevei nu,
\q2 i ta̱ a kuzuwa a̱ɗu e le wa̱ a̱ nu,
\q2 vu tsu varuku vuza na u ta̱wa̱i wa̱ a̱ nu ba.
\q1 
\v 11 Cikpai Vuzavaguɗu,
\q2 vuza na wi o tsugono tsu Sihiyona,
\q2 danai uduniyan ili i na u yain.
\q1 
\v 12 Ka̱shile ki ta̱ a kuciɓa n aza a na i atakaci,
\q2 u tsu cinukpa m ma̱shi me le ba,
\q2 ama u tsu takacika ta̱ aza a na i o kudoro le.
\q1 
\v 13 Vuzavaguɗu, pana asuvayali a̱ va̱,
\q2 la̱na̱ tsu na irala i va̱ yi a kuyaꞋanka mu.
\q2 Isa mu a̱ ubuta̱ wu ukpa̱, Vuzavaguɗu,
\q1 
\v 14 adama a na n cikpa wu,
\q2 e kelime ka uma a Sihiyona,
\q2 ka̱ta̱ n yaꞋan ma̱za̱nga̱ adama a wishi u nu.
\q1 
\v 15 Uma a̱ ga̱va̱ ta̱ kpenle, ɗa a̱ yikpa̱i punu,
\q2 a dasai ayakuru e le,
\q2 ɗa ene e le a̱ cila̱i punu.
\q1 
\v 16 Vuzavaguɗu u zuwa ta̱ e yeve ni,
\q2 a̱ ubuta̱ u kuyaꞋan ka afada a usuɓi,
\q2 uma a gbani-gbani a̱ ka̱na̱i ka̱ci ke le n ka na a yaꞋin.\qs Kuvuka\qs*
\q1 
\v 17 Uma a gbani-gbani i ta̱ a̱ gida̱la̱ a kubana asaun e le,
\q2 ta feu nannai uduniyan u na u iwain Ka̱shile.
\q1 
\v 18 Makyan dem ɗa a kucinukpa n aza na i a kuciga uɓa̱nki ba,
\q2 e kupece vuza vu u unambi n kukeɗe a̱pa̱Ꞌa̱ ba, ko wannai.
\q1 
\v 19 Vuzavaguɗu, ɗa̱nga̱!
\q2 adama a na ka̱ta̱ uma a̱ ciya̱ ulyaꞋi wa̱ a̱ nu ba,
\q2 yaꞋan a yaꞋanka uma a gbani-gbani afada e kelime ka̱ nu,
\q1 
\v 20 Vuzavaguɗu, zuwa le e jeꞋeke ikyamba adama o wovon.
\q2 vu zuwa le e yeve a na e le uma a ɗa koci. \qs Kuvuka\qs*
\c 10
\s1 Ma̱shi adama uma a gbani-gbani
\q1 
\v 1 Vuzavaguɗu yiɗa̱i i zuwai vu shamgbai daꞋin?
\q2 Yiɗa̱i i zuwai ɗa vu sokongi ka̱ci ka̱ nu a makyan ma na ci atakaci?
\q1 
\v 2 Uma a gbani-gbani i ta̱ a̱ra̱ɗi
\q2 a kutakacika aza a unambi,
\q2 zuwa ka gbani-gbani ka na o foɓusoi ko bono a kaci ke le.
\q1 
\v 3 Uma a gbani-gbani a̱ra̱ɗi n kawuya ka na e sheshei a̱ɗu e le,
\q2 aza a ulyopi a tsu shika ta̱ Vuzavaguɗu,
\q2 kpamu o tsu goyo yi ta̱.
\q1 
\v 4 Uma a gbani-gbani i ta̱ ugbamukaci,
\q2 a tsu ciɓa n Ka̱shile ba.
\q1 E kusheshe ku le dem, a tsu dana ta̱,
\q2 <<Ka̱shile kilo ba.>>
\q1 
\v 5 Uma a gbani-gbani a ci lyaꞋa ta̱ kelime a ili i na i a kuyaꞋan dem.
\q2 E kuyeve afada a̱ Ka̱shile ba,
\q2 o tsu goyo ta̱ irala i le.
\q1 
\v 6 E kusheshe ku le a tsu dana ta̱,
\q2 <<Kawuya ka̱ kuciya̱ tsu ba,
\q2 ci tana a kutakacika ba.>>
\q1 
\v 7 Una̱ u le wi ta̱ tukpa n ishikushi, n aꞋuwa n mavura,
\q2 elentsu e le i ta̱ n ufa̱ka̱ u kadanshi ka gbani-gbani n kavama.
\q1 
\v 8 O tsu bopo ta̱ a n likuci n wawaꞋa,
\q2 una aza a babu unushi.
\q1 A̱shi e le i ta̱ a̱ ubuta̱ wa aza a babu utsura.
\q2 
\v 9 A tsu vana ta̱ a̱ ubuta̱ u na o bopoi tsu kawu,
\q1 a kuvana aza a babu utsura,
\q2 n ayakuru e le a ɗa a̱ tsu ka̱na̱ aza a babu utsura,
\q2 ka̱ta̱ a laza n e le.
\q1 
\v 10 A tsu dasa ta̱ aza a babu utsura e kpete le,
\q2 o yotsongu le utsura ali a lyaꞋa le.
\q1 
\v 11 E ci sheshe ta̱ a dana, <<Kabura Ka̱shile ba,
\q2 u pala ta̱ a̱shi a̱ ni wi e kene tsu ba.>>
\q1 
\v 12 Vuzavaguɗu, ta̱wa̱ vu wawa mu,
\q2 Ka̱shile, ka̱ta̱ vu cinukpa n aza a na i a kutakacika ba.
\q1 
\v 13 Yiɗa̱i i zuwai ɗa uma a gbani-gbani o ogoyoi Ka̱shile?
\q2 Ali i e kusheshe n a danai, <<Wi a kutakacika tsu ba.>>
\q1 
\v 14 Ama Vuzavaguɗu vi ta̱ e kene,
\q2 vi ta̱ kpamu a̱ kula̱na̱ aza atakaci n aza a una̱mgbi u ka̱tsuma̱,
\q2 a makyan dem vi ta̱ ufoɓushi vu ɓa̱nka̱.
\q1 Wa̱ a̱ nu u ɗa aza a babu utsura a tsu zuwa a̱ɗu,
\q2 avu ɗa vu tsu ɓa̱nka̱ mkpaꞋan.
\q1 
\v 15 Jebe utsura u uma a gbani-gbani,
\q2 takacika le adama a unushi u na a yaꞋin,
\q2 ali uta̱ka̱ ka gbani-gbani ke le e keteshe.
\q1 
\v 16 Vuzavaguɗu, mogono maꞋa ko wannai.
\q2 uduniyan u na u tonoi a̱ma̱li,
\q2 i ta̱ a ku una le a iɗika ya.
\q1 
\v 17 Vuzavaguɗu, pana ma̱shi ma aza a babu utsura,
\q2 pana avasa e le, vu neke le utsura u ka̱ɗu.
\q1 
\v 18 Vu pana ta̱ ma̱shi ma mkpaꞋan n aza na i n utsura ba,
\q2 vu yaꞋanka le afada a usuɓi,
\q2 adama a na ka̱ta̱ uma o doku e neke le wovon ba.
\c 11
\s1 Ku zuwa ku ka̱ɗu u Vuzavaguɗu
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda: a kubana u ma̱zuɓi.
\p 
\v 1 Vuzavaguɗu ɗa ubuta̱ u kusheɗeku u va̱,
\q2 adama a̱ n yiɗa̱i va ku dana mu:
\q2 <<Imkpa tsu manunu a kubana a nsasan,
\q1 
\v 2 Uma a gbani-gbani a lapula ta̱ utan u le,
\q2 kpamu a gisangi ayaꞋa e le,
\q2 adama a na a tawa uma a̱ ma̱riki punu a̱ ka̱yimbi.
\q1 
\v 3 Aza a usuɓi i a kufuɗa kuyaꞋan ili ba,
\q2 Ɗa baci ili dem i na̱mgba̱i.>>
\q1 
\v 4 Vuzavaguɗu wi ta̱ A̱Ꞌisa̱ a gbayin a ciɗa a̱ ni,
\q2 kakuba ko tsugono ci ni ki ta̱ ɗe gaɗi.
\q1 a̱shi a̱ ni a kindana uma a̱ ubuta̱ dem,
\q1 a̱ kula̱na̱ ili i na uma i a kuyaꞋan dem.
\q1 
\v 5 Vuzavaguɗu u tsu kondo ta̱ vuza vu usuɓi,
\q2 n vuza gbani-gbani,
\q2 u tsu iwan ta̱ aza a na a cigai kawuya,
\q1 
\v 6 Wi ta̱ a̱ kusuku akina n Farinwuta,
\q2 u uma a gbani-gbani,
\q2 wunla̱i wu usuɗukpi u ɗa u ko okpo upecu u le.
\q1 
\v 7 Adama a na Vuzavaguɗu vuza vu usuɓi ɗa,
\q2 u ciga ta̱ ulinga wu usuɓi,
\q2 uma a usuɓi i ta̱ e kene a̱shi a̱ ni.
\c 12
\s1 Avasa a̱ kula̱nsa̱ uɓa̱nki
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda: a kubana u ma̱zuɓi, a yaꞋan vu ɗa tsu ka̱la̱ka̱tsu ka<<Shiminitu>>
\q1 
\v 1 Wawa tsu Vuzavaguɗu,
\q2 babu aza a̱ ma̱riki a na a buwai tsu Ka̱shile,
\q2 aza a usuɓi o kotso ta̱ a̱ ka̱tsuma̱ ka aduniyan.
\q1 
\v 2 Yaba dem a kuyaꞋanka toku aꞋuwa,
\q2 o modoronoi n una̱ wa singai.
\q1 
\v 3 Vuzavaguɗu, zuwa elentsu aza o modoruko a paɗa bini,
\q2 vu zuwa una̱ wa aza a̱ra̱ɗi u paɗa bini.
\q1 
\v 4 Aza a na a tsu dana, <<Ci ta̱ a̱ kuciya̱ ulyaꞋi n elentsu a̱ tsu,
\q2 ci ta̱ a kudansa ili i na tsu cigai,
\q2 yayi u kusa̱nka̱ tsu?>>
\q1 
\v 5 Vuzavaguɗu u danai,
\q2 <<Mi ta̱ a̱ kuta̱wa̱ gogo na,
\q2 adama a na i ta̱ o kudoro aza a unambi.
\q2 aza a na a takacikai kpamu a̱ yura̱ adama atakaci.
\q2 Mi ta̱ e kuneke le ida̱shi i ma̱ta̱na̱ i na i a̱ kula̱nsa̱.>>
\q1 
\v 6 Kadanshi ka Vuzavaguɗu ki ta̱ ciɗa,
\q2 kadanshi ka̱ ni ki ta̱ tsa azurufa koci,
\q2 azurufa a na a̱ luwa̱i n akina ali kucindere.
\q1 
\v 7 Vuzavaguɗu ere tsu,
\q2 ere tsu ekiye a uma a gbani-gbani,
\q2 vu ere tsu ko wannai
\q1 
\v 8 Adama a na uma a gbani-gbani i ta̱ lo a̱ kuka̱ra̱Ꞌa̱ a̱ ubuta̱ dem,
\q1 a kucikpa ili i na yi i gbani-gbani.
\c 13
\s1 Avasa a̱ kula̱nsa̱ uɓa̱nki
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda: a kubana u ma̱zuɓi.
\q1 
\v 1 Vuzavaguɗu, ali n wannai ɗai va kucinukpa nu mpa?
\q2 Ali n wannai ɗai va ku sokongu ku mu a̱shi a̱ nu?
\q2 Ali ko wannai ɗa?
\q1 
\v 2 Ali n wannai ɗai n kugbama asuvu n atakaci a nampa?
\q2 Kanna dem o kuyongo n una̱mgbi u ka̱tsuma̱.
\q2 Ali wannai ɗai irala i va̱ i kuka̱na̱ kuciya̱ ulyaꞋi?
\q1 
\v 3 Indana mu Vuzavaguɗu Ka̱shile ka̱ va̱,
\q2 zuwa mu n yongo n wuma,
\q2 ka̱ta̱ vu ka̱sukpa̱ mu n kuwa̱ ba.
\q1 
\v 4 Ka̱ta̱ vu ka̱sukpa̱ irala i va̱ a dana,
\q2 <<Ci lyaꞋa ta̱ kelime ka̱ ni.>>
\q1 Ka̱ta̱ vu ka̱sukpa̱ a yaꞋan ma̱za̱nga̱,
\q2 adama a uyikpi u va̱ ba.
\q1 
\v 5 Ama mpa n neke ta̱ ka̱ɗu ka̱ va̱,
\q2 a ucigi u nu u na u tsu sabaꞋa ba.
\q1 ka̱ɗu ka̱ va̱ ki ta̱ m ma̱za̱nga̱
\q2 adama a na vu isa mu ta̱.
\q1 
\v 6 Mi ta̱ a kuyaꞋan ishipa, u Vuzavaguɗu,
\q2 adama a kasingai ka na wi a kuyaꞋanka mu.
\c 14
\s1 Kagbanigbani ka uma n tsulau tsu le
\r (Ishp 53:1-6)
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda: a kubana u ma̱zuɓi.
\q1 
\v 1 Alau a tsu dansa ta̱ a̱ɗu e le,
\q2 <<Babu Ka̱shile.>>
\q1 A̱ na̱mgba̱ ta̱ ra̱ka̱ vu le, ulinga u le ili yi unata i ɗa,
\q2 babu vuza na u ci yaꞋan ili i na yi derere.\x - \xo 14:1 \xt Ishp 10:4\x*
\q1 
\v 2 Vuzavaguɗu wu indanai uma ɗe gaɗi,
\q1 we ene ko aza e kuyeve i ta̱ punu,
\q2 vuza a na wi a̱ kula̱nsa̱ u yeve Ka̱shile.
\q1 
\v 3 Ra̱ka̱ vi le a̱ ka̱sukpa̱ ta̱ uye,
\q2 dem vi le a̱ puwa̱nka̱ ta̱,
\q2 babu vuza na wi a kuyaꞋan ka̱ ma̱riki,
\q2 ko vuza te.
\q1 
\v 4 Ko i n kuyeve ba?
\q2 Aza a na i kuyaꞋan ka gbani-gbani ka,
\q2 i n kuyeve ba?
\q1 A tsu takuma ta̱ uma tsu boroji,
\q2 kpamu a ci yaꞋan avasa u Vuzavaguɗu ba.
\q1 
\v 5 Ama a̱ rikpa̱ ta̱ adama o wovon,
\q2 adama a na Ka̱shile ki ta̱ koɓolo n uma a usuɓi.
\q1 
\v 6 A̱ɗa̱ uma a gbani-gbani,
\q2 i tsu la̱nga̱sa̱ ta̱ ulinga wa aza a unambi,
\q2 ama Vuzavaguɗu ɗa ubuta̱ u kusheɗeku u le.
\q1 
\v 7 Ishi baci a dana wishi wi Isaraila,
\q2 wu uta̱ ta̱ a Sihiyona.
\q1 ayin ana Vuzavaguɗu u bonokoi uma a̱ ni una̱singai u le,
\q2 ntsukaya n Yakubu mi ta̱ a kuyaꞋan ma̱za̱nga̱.
\q2 aza a Israila a pana u yoꞋo.
\c 15
\s1 Aza a na i a̱ idashi a kusan ku ciɗa ku Ka̱shile
\d Vishipa vu Dawuda.
\q1 
\v 1 Vuzavaguɗu,
\q2 yayi u ku uwa a̱ Ma̱va̱li mo oɓolo ma̱ nu?
\q1 Yayi u kuda̱sa̱ngu a Sihiyona,
\q2 kusan ku ciɗa?
\q1 
\v 2 Sai vuza na wi a kuyaꞋan kamayu,
\q2 vuza na wi a kuyaꞋan ili yi usuɓi,
\q1 vuza na kpamu wi a kudansa kamayu
\q2 a̱ ka̱ɗu ka̱ni,
\q1 
\v 3 Vuza na u tsu la̱nga̱sa̱ kula ku vuza yoku ba,
\q2 Vuza na u ci yaꞋanka a̱ja̱Ꞌa̱ a̱ ni ka gbani-gbani ba,
\q2 ko u yaꞋan kadanshi ka gbani-gbani
\q2 adama vuza na i a̱ ida̱shi ɗeɗevu ba.
\q1 
\v 4 Vuza na u tsu goyo aza a na Ka̱shile ka inwai,
\q2 ama u tsu neke ta̱ tsugbayin wa aza na o kutono Vuzavaguɗu.
\q2 U tsu shatangu ta̱ uzuwakpani u ni,
\q2 ko niniɗai baci ka yaꞋin,
\q1 
\v 5 Vuza na u tsu neke okopu babu kodokpotsu,
\q2 u ci isa kalyaꞋa adama a na wo okpo magan ma aꞋuwa,
\q2 u vuza babu unushi ba.
\q2 Vuza na baci u yaꞋin nannai wi ta̱ a kushamgba mayin ko wannai.
\c 16
\s1 Kuzuwa ka̱ɗu u Vuzavaguɗu
\d Vishipa vu Dawuda.
\p 
\v 1 Ere mu Ka̱shile,
\q2 adama a na avu ɗa ubuta̱ u kusheɗeku u va̱.
\q1 
\v 2 Ɗa n danai Vuzavaguɗu,
\q2 <<Avu ɗa Vuzavaguɗu vu va̱,
\q2 ili i singai i na mi n i ɗa ra̱ka̱, wa̱ a̱ nu u ɗa yi uta̱i.>>
\q1 
\v 3 Adama aza a ciɗa a iɗika ya,
\q2 ele ɗa i n tsugbayin,
\q2 ele ɗa a zuwai mu ma̱za̱nga̱.
\q1 
\v 4 Aza a na a zagbai o tono a̱ma̱li o yoku,
\q2 o tsu ronoko ta̱ ka̱ci ka̱ le atakaci ka̱u.
\q1 Mi o kuɓolongu n e le,
\q2 a̱ ubuta̱ u kuyaꞋan ka alyuka ba.
\q2 Mi a kucikpa a̱ma̱li e le ba.
\v 5 Vuzavaguɗu avu ɗa ili i na mi n i ɗa koci,
\q2 avu ɗa vu nekei mu ili i na n cigai dem,
\q2 wuma u va̱ wi ta̱ ekiye a̱ nu.
\v 6 KuneꞋe ku na vu yaꞋankai mu,
\q2 ki ta̱ n ugain ka̱u,
\q2 mayun ku singai ku ɗa.
\v 7 N cikpa ta̱ Vuzavaguɗu, a na wi o kutono nu mpa,
\q2 n kayin kpamu ka̱ɗu ka̱ va̱ ke ci neke mu ta̱ kadanshi.
\q1 
\v 8 N yeve ta̱ makyan dem Vuzavaguɗu wi ta̱ nu mpa.
\q2 Adama a na wi ta̱ e kukiye ku singai ku va̱,
\q2 mi a̱ kurikpa̱ ba.
\v 9 Adama a nannai ka̱ɗu ka̱ va̱ ki ta̱ m ma̱za̱nga̱,
\q2 wuma u va̱ kpamu wi ta̱ a̱ ma̱za̱nga̱,
\q2 ikyamba i va̱ feu yi ta̱ a kuyongo babu koyoku.
\q1 
\v 10 Adama a na va̱ ku ka̱sukpa̱ mu,
\q2 n yongo a kasaun ba,
\q2 ko vu ka̱sukpa̱ vuza vu usuɓi u shama ba.\x - \xo 16:10 \xt Azu 13:35\x*
\q1 
\v 11 Vi ta̱ a̱ ku yotsongu mu uye,
\q2 uye u na u kubana a̱ ubuta̱ u wuma,
\q1 kuyongo ku nu koɓolo nu mpa ili i ma̱za̱nga̱ i ɗa,
\q2 ida̱shi e kukiye ku usingai ku nu,
\q2 uyoꞋo u ɗa ko wannai.
\c 17
\s1 Ma̱shi ma vuza vu babu unushi
\d Avasa a Dawuda.
\q1 
\v 1 Vuzavaguɗu pana ufolu u va̱ a̱ kula̱nsa̱ kamayun,
\q2 pana ma̱shi ma̱ va̱, ma̱ kula̱nsa̱ uɓa̱nki.
\q2 Zuwa atsuvu vu pana avasa a̱ va̱,
\q2 adama a na mpa vuza va aꞋuwa ɗa ba.
\q1 
\v 2 YaꞋan afada a na va kuyaꞋan o yotsongu mi ta̱ n usuɓi,
\q2 adama a na vi yeve ta̱ ili i na yi derere.
\q1 
\v 3 Vu la̱na̱ baci ka̱ɗu ka̱ va̱,
\q2 ɗa vu ta̱wa̱i wa̱ a̱ va̱ n kayin,
\q2 vu kondo mu ba ci,
\q2 vi a kuciya̱ ili i gbani-gbani wa̱ a̱ va̱ ba,
\q2 n sheshe ta̱ a̱ ka̱ɗu ka̱ va̱ una̱ uva̱ wi a ku nusaka wu ba.
\q1 
\v 4 Tsu na uma o yoku a ci yaꞋan,
\q2 mpa n tono ta̱ kadanshi ka̱ nu,
\q2 n tono uye u uma a kavama ba.
\q1 
\v 5 Ene a̱ va̱ i ta̱ o kutono uye u nu makyan dem,
\q2 n saꞋwa kukatsukpa ba.
\q1 
\v 6 N yaꞋan ta̱ avasa wa̱ a̱ nu Ka̱shile,
\q2 adama a na avu vu tsu ushuku mu ta̱,
\q1 zuwa atsuvu vu pana avasa a̱ va̱.
\q1 
\v 7 Yotsongu ucigi u mereve u nu,
\q2 ucigi u nu u na u tsu sabaꞋa ba,
\q1 avu ɗa vu tsu isa aza a na i a̱ kula̱nsa̱ ubuta̱ u kusheɗeku,
\q2 aza a na i a̱ kula̱nsa̱ ubuta̱ u kusheɗeku e kukiye ku usingai ku nu,
\q2 a̱ ubuta̱ wi irala i le.
\q1 
\v 8 Ere mu tsu maku ma̱ ka̱shi,
\q2 sokongu mu a ɗaka ve evelyu a̱ nu,
\q1 
\v 9 wa aza a gbani-gbani a na a cigai ku una mu,
\q2 n irala i va̱ aza a na i uka̱ra̱Ꞌi nu mpa.
\q1 
\v 10 I na asuvayali a̱ɗu e le ba,
\q2 una̱ u le sai kadanshi ka̱ a̱ra̱ɗi.
\q1 
\v 11 Gogo na i ta̱ uka̱ra̱Ꞌi nu mpa a̱ ubuta̱ u na n vadalukpai dem,
\q2 a̱ kula̱nsa̱ ka̱ba̱nga̱ adama a na o polo mu a iɗika.
\q1 
\v 12 Ana ikawu a̱ kula̱nsa̱ mu adama a na a sazasa,
\q1 a na ikawu yi utsura,
\q2 a kuvana a̱ ubuta̱ u na i ubopi.
\q1 
\v 13 Ta̱wa̱, Vuzavaguɗu vu yaꞋan kuvon n irala i va̱, vu lyaꞋa le,
\q2 vu isa mu n kotokobi ka̱ nu wa aza a gbani-gbani.
\v 14 Vuzavaguɗu, isa mu n kukiye ku nu a icuꞋu i uma a nanlo,
\q2 isa mu a̱ ubuta̱ u uma aduniyan a nampa,
\q2 a na i n ili i na a cigai dem,
\q1 takacika le n ili i na vu zuwakai le,
\q2 ya muku n le feu n takacika,
\q2 ali a kubana a n tsukaya n le.
\q1 
\v 15 Mi ta̱ e kene wu, adama a na mpa vuza vu usuɓi ɗa,
\q2 ɗa baci n jimgbai dem n ci yaꞋan ta̱ ma̱za̱nga̱ adama a na vi ta̱ koɓolo nu mpa.
\c 18
\s1 Vishipa vu ulyaꞋi vu Dawuda
\r (2 Sam 22:1-51)
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda.
\q1 
\v 1 N ciga wu ta̱ Vuzavaguɗu,
\q2 avu ɗa utsura u va̱.
\q1 
\v 2 Vuzavaguɗu, avu ɗa katali ke kusheɗeku ka̱ va̱, mashilya ma̱ va̱ n kishi ka̱ va̱,
\q2 Ka̱shile kaꞋa katali ke kusheɗeku ka̱ va̱, wa̱ a̱ ni u ɗa n tsu sheɗeku.
\q2 ma̱ra̱ga̱ ma̱ va̱ n kishi ka̱ va̱,
\q2 ubuta̱ u kusheɗeku u va̱ kpamu.
\q1 
\v 3 N tsu ɗeke ta̱ Vuzavaguɗu,
\q2 a̱yi na u yotsoi kucikpa,
\q2 kpamu u tsu wawa mu ta̱ ekiye a irala i va̱.
\q1 
\v 4 Ukpa̱ u shiya mu ta̱ kpankpaꞋan n awin a̱ ni,
\q2 ka gbani-gbani ka aya ta̱ ali ka laꞋi utsura u va̱.
\q1 
\v 5 Kasaun ka shiya mu ta̱ n awin a̱ ni,
\q2 ukpa̱ u zuwaka mu ta̱ maza.
\q1 
\v 6 A̱ ka̱tsuma̱ ka atakaci a̱ va̱, n ɗeke ta̱ Vuzavaguɗu,
\q2 N ɗeke ta̱ Ka̱shile ka̱ va̱ adama a̱ kula̱nsa̱ uɓa̱nki,
\q1 A̱Ꞌisa̱ a gbayin a̱ ni u panai ka̱la̱ka̱tsu ka̱ va̱,
\q2 ma̱shi ma̱ va̱ ma uwa ta̱ atsuvu a̱ ni.
\q1 
\v 7 Aduniyan ejeꞋi ali a̱ gba̱ɗa̱i,
\q2 ɗa a̱miꞋin a nsasan ejeꞋi ɗa a̱ gba̱ɗa̱i,
\q2 adama a wupa u Ka̱shile.
\q1 
\v 8 Ka̱nga̱ ka̱ ka̱na̱i ku uta̱ a̱ vunu vi ni,
\q2 melentsu ma akina n a̱ga̱ruwa̱shi a̱ ku uta̱ una̱ u ni,
\q1 
\v 9 U ɓa̱yuwa̱i gaɗi, ɗa u cipa̱i a iɗika,
\q2 eleshu a̱ lima̱ ka̱u a ɗaka vu ene a̱ ni.
\q1 
\v 10 U kumbai gaɗi ve evelyu i Corobi u imkpai,
\q2 a̱ kucipa̱ n ilaɗi.
\q1 
\v 11 U zuwai ka̱yimbi ko okpoi kapalatsu ka̱ ni,
\q2 u sheɗeki eleshu a̱ lima̱.
\q1 
\v 12 Ɗa ulaɗi wu uta̱i eleshu a̱ ni,
\q2 ɗa mini ma atali n melentsu ma akina,
\q2 uta̱i e kelime ka̱ ni.
\q1 
\v 13 Vuzavaguɗu u lapai ɗe kakpanga gaɗi,
\q2 ɗa a panai ka̱la̱ka̱tsu ka MalaꞋimili.
\q1 
\v 14 U tawai ayaꞋa a̱ ni, u wacuwai irala ni,
\q2 n ulaɗi u ni u ɗa u lokoi le.
\q1 
\v 15 A palukpai kumiꞋi ku mala e keteshe,
\q2 kumiꞋi ka aduniyan ku uta̱i e keteshe,
\q1 ana vu ɓarangi irala i va̱, Vuzavaguɗu,
\q2 ana kpamu vu ɓarangi le n wupa.
\q1 
\v 16 Vuzavaguɗu u ba̱rukpa̱i kukiye ku ni ɗe gaɗi u ɗikai mu,
\q2 wu utuka̱i mu a̱ mini mu uga̱vi.
\q1 
\v 17 Wu isa mu ekiye a irala i va̱ yi utsura,
\q2 n wa aza a na o kovoi mu,
\q2 adama a na a laꞋa ta̱ utsura u va̱.
\q1 
\v 18 A kanna ka atakaci a̱ va̱, ɗa a̱ ta̱wa̱i a̱ shilika̱i nu mpa,
\q2 ama ɗa vuzavaguɗu u wawai mu.
\q1 
\v 19 Wu utuka̱i mu a̱ ka̱tsuma̱ ka atakaci,
\q2 ɗa wi isai mu adama a na wi ta̱ a kupana uyoꞋo u va̱.
\q1 
\v 20 Vuzavaguɗu u tsu tsupa mu ta̱, adama a na mpa vuza vu usuɓi ɗa,
\q2 ɗa u zuwakai mu una̱singai adama a usuɓi u va̱.
\q1 
\v 21 N tono ta̱ uye u Vuzavaguɗu, n ka̱sukpa̱ Vuzaguɗu Ka̱shile ka̱ va̱, adama a kuyaꞋan ka gbani-gbani ba.
\q1 
\v 22 N tono ta̱ wila̱ u ni ra̱ka̱,
\q2 n kpa̱ɗa̱ kutono ili i na u dansai ba.
\q1 
\v 23 Ɗa mo okpoi vuza vu babu unushi a̱ ubuta̱ ni.
\q2 Ɗa kpamu me erei ka̱ci ka̱ va̱ a̱ ubuta̱ u kuyaꞋan unushi.
\q1 
\v 24 Adama a nannai ɗa Vuzavaguɗu u nekei mu katsupu adama a usuɓi u va̱,
\q2 adama a na u yeve ta̱ mi na unushi a̱ ni ba.
\q1 
\v 25 Vuzavaguɗu avu vuza vu uneki u ka̱ɗu ɗa, wa aza a na e nekei u a̱ɗu,
\q2 vuza vu ma̱riki ɗa kpamu wa aza a̱ ma̱riki.
\q1 
\v 26 Wa aza a̱ɗu a ciɗa, vu tsu yotsongu le ta̱ vi ta̱ ciɗa,
\q2 ama vi ta̱ a tsurala n aza a ka gbani-gbani.
\q1 
\v 27 Vu tsu isa ta̱ aza a na o goyoi ka̱ci ka̱ le,
\q2 ama vu tsu goyo ta̱ aza a̱ra̱ɗi.
\q1 
\v 28 Vuzavaguɗu, avu ɗa vu tsu neke mu kutashi,
\q2 avu ɗa vu lokoi ka̱yimbi ka̱ va̱.
\q1 
\v 29 N utsura u nu, mi ta̱ a ku una ka̱tsura̱ ko osoji,
\q2 n utsura u Ka̱shile ka̱ va̱ mi ta̱ a kupasa mashilya dem.
\q1 
\v 30 Uye u Ka̱shile wi ta̱ derere,
\q2 uzuwakpani u Vuzavaguɗu mayun ɗa.
\q2 a̱yi ma̱ra̱ga̱ maꞋa wa aza a na e sheɗeki wa̱ a̱ ni.
\q1 
\v 31 Vuzavaguɗu koci, a̱yi ɗa Ka̱shile,
\q2 Ka̱shile kaꞋa koci ubuta̱ u kusheɗeku u tsu.
\q1 
\v 32 A̱yi ɗa Ka̱shile ka na ke ci neke mu utsura u ka̱ɗu,
\q2 u tsu ere mu ta̱ a uye wu nwalu n va̱.
\q1 
\v 33 U tsu zuwa mu ta̱ n wala n ilaɗi ko ma̱ta̱ɗa̱,
\q2 tsu mesheun e kere mu a gaɗi vu nsasan.
\q1 
\v 34 U tsu gbara mu adama o kuvon,
\q2 ciya̱ n fuɗa kuyaꞋan ulinga n utan u viyum vi shili.
\q1 
\v 35 Vuzavaguɗu vu ere mu ta̱, ɗa vu isai mu,
\q2 mo okpoi vuzagbayin, adama a na vu la̱na̱ mu ta̱,
\q2 utsura u nu kpamu we erei mu,
\q1 
\v 36 Vu zuwa mu ta̱ a̱ ubuta̱ u na wi n ma̱ta̱ɗa̱ ba,
\q2 n saꞋwa kuyikpa̱ ba.
\q1 
\v 37 N guvai irala i va̱ ali n remei le,
\q2 mi a kushamgba ba sai mu una le ra̱ka̱.
\q1 
\v 38 Ɗa n lapai le ali a iɗika, a fuɗa a̱ ɗa̱nga̱ ba,
\q2 a̱ yikpa̱i a ɗaka vu ene a̱ va̱.
\q1 
\v 39 Avu ɗa vu nekei mu utsura u kuyaꞋan kuvon,
\q2 vu zuwai irala i va̱ a ɗaka vu va̱.
\q1 
\v 40 Vu zuwai irala i va̱ a kpatalai a sumai,
\q2 ɗa mu unai aza a na i a tsurala nu mpa.
\q1 
\v 41 A̱ shika̱i, ama babu vuza na wa ku isa le,
\q2 e ɗekei Vuzavaguɗu, ama ɗa u kpa̱ɗa̱i ku ushuku le.
\q1 
\v 42 Ɗa n lapai le luɓa̱ luɓa̱ ali okpoi tsu kubuta̱,
\q2 n dasai le tsu kolyoꞋo ku uye.
\q1 
\v 43 Vu isai mu a̱ ubuta̱ wa aza a ugbamiwasuvu,
\q2 vu zuwai mu mo okpo vuza vu kelime vu uduniyan,
\q2 uma a na n saꞋwai kuyeve ba,
\q2 okpoi aza a ulinga a̱ va̱.
\q1 
\v 44 Ɗa baci a panai ukuna u va̱,
\q2 o tsu tono mu ta̱.
\q2 Omoci a̱ kuta̱wa̱ n e nekei mu tsugbayin,
\q1 
\v 45 a nambai utsura u ka̱ɗu,
\q2 n kujeꞋe ki ikyamba ɗa a̱ uta̱i a̱ ubuta̱ u na e sheɗeki.
\q1 
\v 46 Vuzavaguɗu wi ta̱ n wuma, una̱singai u katali ke kusheɗeku ka̱ va̱,
\q2 ucikpi a kubana a̱ Ka̱shile kishi ka̱ va̱.
\q1 
\v 47 A̱yi ɗa Ka̱shile ka na ka kutsupaka mu,
\q2 a̱yi ɗa u zuwai uduniya wo okpoi ɗaka vu va̱,
\q2 
\v 48 u tsu isa mu ta̱ e kiye a irala i va̱.
\q1 u tsu neke mu ta̱ tsugbayin a̱ ubuta̱ wi irala i va̱,
\q2 u tsu isa mu ta̱ ekiye a uma a kavama.
\q1 
\v 49 Adama a nannai, Vuzavaguɗu,
\q2 mi ta̱ a kucikpa wu a̱ ka̱tsuma̱ ku uduniyan,
\q2 mi ta̱ a kuyaꞋan ishipa n cikpa kula ku nu.
\q1 
\v 50 Makyan dem Ka̱shile ke ci neke ta̱ mogono ma na u zagbai ulyaꞋi,
\q2 u tsu yotsongu ta̱ ucigi u na u tsu sabaꞋa ba u mazagbi ma̱ ni,
\q2 u Dawuda nu ntsukaya n ni ko wannai.
\c 19
\s1 Ulinga u Ka̱shile n afada a̱ ni
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda.
\q1 
\v 1 La̱na̱ biꞋi tsu na gaɗi a̱da̱nga̱shile i a kusala tsugbayin tsu Ka̱shile,
\q2 la̱na̱ biꞋi kpamu tsu na eleshu i o kuyotsongu ulinga u na u yaꞋin e keteshe.
\q1 
\v 2 Kanna dem ka tsu dana ta̱ kanna ke ire tsugbayin ci ni,
\q2 kayin dem ko tsu tonuko ta̱ kayin ke ire kuyeve ku ni.
\q1 
\v 3 Babu ka̱la̱ka̱tsu ko kadanshi ka na a dansai,
\q2 babu ka̱la̱ka̱tsu ka na a panai.
\q1 
\v 4 Ama akaka e le a̱ ka̱ra̱Ꞌa̱ ta̱ aduniyan dem,
\q2 kadanshi ke le ka̱ ka̱ra̱Ꞌa̱ ta̱ a̱ ubuta̱ dem aduniyan.\x - \xo 19:4 \xt Rom 10:18\x*
\q1 Ka̱shile ka yaꞋanka ta̱ kanna kpaꞋa ɗe gaɗi,
\q2 
\v 5 Kuta̱ ku kanna ki ta̱ tsu vali vu savu a̱ ku uta̱ a̱ kunu ku ni,
\q2 n ma̱za̱nga̱ tsu vuza vu na u ciya̱i ulyaꞋi a ugulani u malamanai.
\q1 
\v 6 U tsu uta̱ ta̱ a uteku wa̱ a̱da̱nga̱shile,
\q2 ka̱ta̱ u ka̱ra̱Ꞌa̱ a kubana a kapashi ka nan ɗe,
\q2 ko ili i kusheɗeku adama a usuɗukpi u ni ba.
\q1 
\v 7 Wila̱ u Vuzavaguɗu wi ta̱ derere,
\q2 u tsu bonoko ta̱ wuma u savu.
\q1 Kadanshi ka Vuzavaguɗu ili i kutono i ɗa,
\q2 ke tsu neke ta̱ kuyeve u vuza na wi n kuyeve ba.
\q1 
\v 8 Wila̱ u Vuzavaguɗu wi ta̱ mejege,
\q2 u tsu tuka̱ ta̱ m ma̱za̱nga̱ a̱ ka̱ɗu.
\q1 Kadanshi ka Vuzavaguɗu,
\q2 ki n kadama ke kuyeve ba,
\q2 ka tsu zuwa ta̱ ka̱ɗu kuyeve.
\q1 
\v 9 Wovon u Vuzavaguɗu u tsu zuwa ta̱ ka̱ɗu ko yongo ciɗa ko wannai.
\q1 Wila̱ u Vuzavaguɗu mayun ɗa,
\q2 makyan dem wi ta̱ mejege.
\q1 
\v 10 U laꞋa ta̱ azanariya ugaꞋin,
\q2 ali a laꞋi azanariya a na a̱ luwa̱i koci,
\q1 a laꞋa ta̱ ishigi uyoꞋo,
\q2 ali a laꞋi ishigi i na a pishai.
\q1 
\v 11 We e le u ɗa kagbashi ka̱ nu ka̱ tsu ciya̱ odoki,
\q2 kutono ku wila̱ ki ta̱ n katsupu ka̱ a̱bunda̱i.
\q1 
\v 12 Yayi u kuyeve unushi u ni?
\q2 Cinukpaka mu unushi u na n yevei n e le ba.
\q1 
\v 13 Ere mu ka̱ta̱ n yaꞋan unushi wu ucigi u ka̱ɗu ba,
\q2 ka̱ta̱ vu ka̱sukpa̱ lyaꞋaka mu tsugono ba.
\q1 Ta m ko okpo vuza vu babu unushi nannai,
\q2 ka̱ta̱ n laꞋaka n kuyaꞋan ka gbani-gbani.
\q1 
\v 14 YaꞋan kadanshi ka̱ va̱ n kusheshe ku va̱,
\q2 ko okpo ili i ku isa wa̱ a̱ nu,
\q2 Vuzavaguɗu, ubuta̱ u kusheɗeku u va̱ n ka̱shibi ka̱ va̱.
\c 20
\s1 Avasa a̱ kula̱nsa̱ ulyaꞋi
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda.
\q1 
\v 1 YaꞋan Vuzavaguɗu wu ushuku wu a ayin atakaci,
\q2 yaꞋan kula ku Ka̱shile ka Yakubu ke ere wu,
\q1 
\v 2 YaꞋan u suꞋuku n uɓa̱nki ɗe a̱ ubuta̱ u ciɗa u ni,
\q2 ka̱ta̱ u zuwaka wu kukiye a Sihiyona.
\q1 
\v 3 YaꞋan u ciɓa n alyuka a̱ nu ra̱ka̱,
\q2 ka̱ta̱ kpamu u pana uyoꞋo u kuneꞋe ku kusongu ku nu. \qs Kuvuka\qs*
\q1 
\v 4 YaꞋan u neke wu ili i na ka̱ɗu ka̱ nu ka cigai dem,
\q2 ka̱ta̱ u zuwa vu lyaꞋa kelime n ili i na vu sheshei kuyaꞋan dem.
\q1 
\v 5 A̱tsu ci ta̱ a kuyaꞋan yoroli i ma̱za̱nga̱ adama a ulyaꞋi u kelime u nu,
\q2 ci yaꞋan ka̱ɗiva̱ adama a ulyaꞋi u kelime u nu,
\q1 n kucikpa ku Vuzavaguɗu Ka̱shile ka̱ tsu.
\q2 Ka̱shile ka isa ta̱ ufolu u nu.
\q1 
\v 6 Gogo na n yeve ta̱ Vuzavaguɗu u tsu ere ta̱ mogono ma na u zagbai,
\q2 u tsu ushuki yi ta̱ ɗe gaɗi a̱ ubuta̱ u ciɗa u ni,
\q2 n utsura u gbayin u ni u ɗa u tsu zuwa yi u lyaꞋa kelime.
\q1 
\v 7 Aza o yoku a tsu zuwa ta̱ a̱ɗu e le wu ekeke odoku e le.
\q2 aza o yoku wu odoku e le
\q2 Ama a̱tsu tsu zuwa ta̱ a̱ɗu a̱ tsu u Vuzavaguɗu Ka̱shile ka̱ tsu.
\q1 
\v 8 IcuꞋu i uma a nanlo i ta̱ a̱ kuta̱ɗa̱tsa̱ a̱ yikpa̱,
\q2 ama a̱ tsu ci ta̱ a̱ kuɗa̱nga̱ ci shamgba n utsura.
\q1 
\v 9 Vuzavaguɗu ɓa̱nka̱ mogono adama a na u ciya̱ ulyaꞋi,
\q2 yaꞋan vu panaka tsu a makyan ma na ci ɗekei.
\c 21
\s1 Ucikpi adama a ulyaꞋi
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda.
\q1 
\v 1 Vuzavaguɗu, adama a utsura u nu,
\q2 mogono ma yaꞋan ta̱ a̱ ma̱za̱nga̱,
\q2 wi ta̱ a̱ ma̱za̱nga̱ n a̱bunda̱i adama a na vu neke yi ta̱ ulyaꞋi.
\q1 
\v 2 Vu neke yi ta̱ ili i na ka̱ɗu ka̱ ni ka cigai,
\q2 vu kpa̱ɗa̱ ku ushuku yi ufolu u ni ba. \qs Kuvuka\qs*
\q1 
\v 3 Vu tuka̱i ni n ili i singai n a̱bunda̱i,
\q2 ɗa vu zuwakai ni oroliko azanariya a kaci ka̱ ni.
\q1 
\v 4 U folono wu ta̱ wuma,
\q2 ɗa vu nekei ni wuma, n wuma wu ugaɗi.
\q1 
\v 5 Adama a̱ uɓa̱nki u nu, u ciya̱ ta̱ ucikpi u gbayin
\q2 ucikpi n tsugbayin tsu na vu nekei ni.
\q1 
\v 6 Vu zuwai ni wo okpoi vuza una̱singai ko wannai,
\q2 kuyongo ku nu n a̱yi u tsu zuwa yi ta̱ ma̱za̱nga̱.
\q1 
\v 7 Adama a na mogono ma, ma zuwa ta̱ ka̱ɗu wa̱ a̱ ni,
\q2 Vuzavaguɗu MalaꞋimili.
\q1 Adama a ucigi u nu u na u tsu sabaꞋa ba,
\q2 wi ta̱ o ko okpo mogono ko wannai.
\q1 
\v 8 Kukiye ku nu ki ta̱ e kureme irala i nu ra̱ka̱,
\q2 kukiye ku usingai ku nu ki ta e kureme aza a na a iwain nu.
\q1 
\v 9 Vi ta̱ a kulyaꞋa le tsu melentsu ma akina,
\q2 ayin a na baci vu yotsongi ka̱ci ka̱ nu, Vuzavaguɗu.
\q1 vi ta̱ a ku una le a̱ ka̱tsuma̱ ka wupa u nu,
\q2 akina i ta̱ o kusongu le ra̱ka̱.
\q1 
\v 10 Mogono mi ta̱ a ku una ntsukaya n le aduniyan ra̱ka̱,
\q2 n muku n le a̱ ka̱tsuma̱ ku uduniyan.
\q1 
\v 11 Ko ishi baci e sheshe kuyaꞋanka wu ka gbani-gbani,
\q2 ko o foɓusoi kuyaꞋanka wu kawuya,
\q1 i a̱ kuciya̱ ulyaꞋi ba.
\q1 
\v 12 Adama a na vi ta̱ a kuzuwa le a kpatala a suma,
\q2 a makyan ma na baci vu taɗuki ayaꞋa a̱ nu.
\q1 
\v 13 YaꞋan a cikpa wu adama a utsura u nu, Vuzavaguɗu.
\q2 Ci ta̱ a kuyaꞋan ishipa tsu cikpa utsura u nu.
\c 22
\s1 Ma̱shi ma̱ una̱mgbuka̱tsuma̱ n ishipa i kucikpa
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda.
\q1 
\v 1 Ka̱shile ka̱ va̱, Ka̱shile ka̱ va̱, yiɗa̱i i zuwai ɗa vu ka̱sukpa̱i mu?
\q2 N shika̱ ta̱ ka̱u adama a̱ kula̱nsa̱ uɓa̱nki, ama ali n gogo na vu ta̱wa̱ ba.\x - \xo 22:1 \xt Mat 27:46; Mar 15:34\x*
\q1 
\v 2 Ka̱shile ka̱ va̱ n ɗeke wu ta̱ n kanna,
\q2 vu ushuku mu ba,
\q2 n ɗeke wu ta̱ n kayin, n nannai dem asuvu a̱ va̱ i a̱ ida̱shi ba.
\q1 
\v 3 Ama n nannai dem avu vuza ciɗa ɗa,
\q2 vuza na aza a Isaraila i a kucikpa.
\q1 
\v 4 Ikaya i tsu a zuwa ta̱ a̱ɗu ele wa̱ a̱ nu,
\q2 a zuwa ta̱ a̱ɗu e le wa̱ a̱ nu, ɗa tana vu wawai le.
\q1 
\v 5 A banka ta̱ n ma̱shi me le wa̱ a̱ nu, ɗa vu wawai le,
\q2 wa̱ a̱ nu u ɗa a zuwai a̱ɗu e le, tana vu neke le wono ba.
\q1 
\v 6 Ama mpa vuma ɗa ba, mpa kazun kaꞋa koci,
\q2 mu okpoi ili yi izoshi n ili i ma̱ka̱n u yaba dem.
\q1 
\v 7 Vuza na baci wu enei mu dem,
\q2 ka̱ta̱ u bonoko mu ili yi izoshi.
\q2 o tsu goyo mu ta̱ n a̱ gba̱ɗa̱i aci e le,
\q1 
\v 8 a dana,<<Vu zuwa ta̱ ka̱ɗu ka̱ nu u Vuzavaguɗu ba̱ya̱?
\q2 YaꞋan wi isa wu,
\q1 yaꞋan Vuzavaguɗu u wawa wu,
\q2 wi baci a kupana uyoꞋo u nu.>>
\q1 
\v 9 N nannai dem avu ɗa vu utuka̱i mu a̱ ka̱tsuma̱ ka̱ a̱na̱ku a̱ va̱,
\q2 avu ɗa vu zuwai n yongoi n ma̱ta̱na̱ ali mpa a ku apa mani.
\q1 
\v 10 Ili i na i ɗikai a kanna ka na a matsai mu,
\q2 ɗa mi a kuzuwa ka̱ɗu ka̱ va̱ wa̱ a̱ nu,
\q1 avu ɗa Ka̱shile ka̱ va̱,
\q2 ali a kanna ka na a̱na̱ku a̱ va̱ a matsai mu.
\q1 
\v 11 Ka̱ta̱ vu yaꞋan daꞋangi nu mpa ba,
\q2 adama a na atakaci i ta̱ ɗevu,
\q2 kpamu ko ka̱ɓa̱nki ki lo ba.
\q1 
\v 12 Irala i va̱ i ka̱ra̱Ꞌa̱ mu ta̱ tsu obomburon,
\q2 a na obomburon a utsura a iɗika i Bashan.
\q1 
\v 13 Apukai una̱ u le a na i kawu,
\q2 ci i kawu i na yi a̱ yura̱ a̱ kula̱nsa̱ mu,
\q2 adama a na a karasa mu.
\q1 
\v 14 Utsura u va̱ u kotsoi,
\q2 mo okpoi tsu mini ma na ma̱ va̱ma̱i a iɗika,
\q1 etele a̱ va̱ dem a̱ shirikpa̱ ta̱,
\q2 ka̱ɗu ka va̱ ke derikpei a na abashi ishigi
\q1 
\v 15 Gboroli vu va̱ vu ɗekpe ta̱ tsu kubuta̱,
\q2 kelentsu ka̱ va̱ ka paɗai punu a kalakpani ka̱ va̱.
\q2 Vu ka̱sukpa̱i mu ukpa̱ a iɗika.
\q1 
\v 16 Ka̱tsura̱ ki irala i va̱ ka̱ ka̱ra̱Ꞌi mu,
\q2 tsu koɓolo ke nsheꞋe,
\q2 ɗa e wejelei ekiye a̱ va̱ n ene a̱ va̱.
\q1 
\v 17 Ali etele dem okpoi e keteshe.
\q2 Irala i va̱ i goyo mu ta̱, ɗa a zuwakai mu a̱shi.
\q1 
\v 18 Ɗa a yaꞋin kazagba n akashi a̱ va̱,
\q2 ɗa e pecekei ka̱ci ke le akashi a̱ va̱.
\q1 
\v 19 Vuzavaguɗu, ka̱ta̱ vu shamgba daꞋin nu mpa ba
\q2 ta̱wa̱ gogoꞋo vi isa mu, avu kawawi ka̱ va̱.
\q1 
\v 20 Wawa a̱ ubuta̱ u kotokobi,
\q2 isa a̱ ubuta̱ wu nsheꞋe n nampa.
\q1 
\v 21 Isa mu ekiye a irala i va̱,
\q2 isa mu adama a na i ta̱ a̱ kusuwa̱n mu n avana e le tsu njuma.
\q1 
\v 22 Mi ta̱ a kudana uma a̱ va̱ ili i na vu yaꞋin,
\q2 mi ta̱ a kucikpa wu a̱ ka̱tsuma̱ ko koɓolo ka uma.
\q1 
\v 23 Cikpai ni, a̱ɗa̱ na yi a kupana wovon u Vuzavaguɗu,
\q2 nekei ni tsugbayin a̱ɗa̱ kumaci ku Yakubu,
\q2 cikpai ni, a̱ɗa̱ aza a Isaraila ra̱ka̱.
\q1 
\v 24 Adama a na u goyo aza a unambi wu utsura ba,
\q2 ko u kpa̱ɗa̱ kula̱na̱ le ba.
\q1 U zuwaka le kucina̱ ba,
\q2 ama u tsu ushuku le ta̱ ɗa baci e ɗekei ni.
\q1 
\v 25 Mi ta̱ a ku cikpa wu e kelime ko koɓolo ka uma
\q2 adama ili i na vu yaꞋin.
\q1 E kelime ka aza na i o kutono wu ra̱ka̱,
\q2 Ka̱ta̱ n shatangu uzuwakpani u na n yaꞋin.
\q1 
\v 26 Aza a unambi i ta̱ a kulyaꞋa ali a̱ cuwa̱.
\q2 Aza a na i a̱ kula̱nsa̱ Vuzavaguɗu i ta̱ a kucikpa yi,
\q1 a̱ɗu e le i ta̱ a̱ okpo m ma̱za̱nga̱,
\q2 ko wannai.
\q1 
\v 27 Aduniyan i ta̱ a kuciɓa,
\q2 i ta̱ o kubono a̱ ubuta̱ u Vuzavaguɗu,
\q1 kumaci ku uma ra̱ka̱ i ta̱ a kucikpa yi.
\q1 
\v 28 adama a na tsugono tsu Vuzavaguɗu tsu ɗa,
\q2 Wi ta̱ o tsugono tsu uma ra̱ka̱.
\q1 
\v 29 Aza a uciyi ra̱ka̱ i ta̱ a̱ ku kuɗa̱nki,
\q2 n aza a na i o kubono kubuta̱ ki iɗika,
\q1 n aza a na a kufuɗa kuɓa̱na̱ wuma u le ba,
\q2 i ta̱ a̱ ku kuɗa̱ngu kelime ka̱ni.
\q1 
\v 30 kumaci ku na ka̱ kuta̱wa̱ ki ta̱ a kucikpa yi.
\q2 Ntsukaya n na mi a̱ kuta̱wa̱ i ta̱ a kupana arabali a Vuzavaguɗu.
\q1 
\v 31 ele feu ta̱ a kusala ukuna u Vuzavaguɗu,
\q2 wa aza a na ka̱ta̱ a matsai ba
\q1 i ta̱ a kudana le,
\q2 Vuzavaguɗu ɗa u wawai uma a̱ ni.
\c 23
\s1 Vuzavaguɗu ɗa maguɓi ma̱ va̱,
\d Vishipa vu Dawuda.
\q1 
\v 1 Vuzavaguɗu maguɓi ma̱ va̱ maꞋa,
\q2 mi a ku namba ili ba.
\q1 
\v 2 U tsu zuwa mu ta̱ n yongo a̱ ubuta̱ u na wi n ijanu i ta̱ku,
\q2 u tsu tono ta̱ nu mpa a uɓon wu nyeneke n na mi e ku yene sawu.
\q1 
\v 3 U tsu doku mu ta̱ utsura.
\q1 U tsu tono ta̱ nu mpa a uye wu usuɓi,
\q2 adama a na a cikpa kula ku ni.
\q1 
\v 4 Ko ɗa baci n tonoi n kpenle ku ka̱yimbi ku ukpa̱,
\q1 mi a kupana wovon ba,
\q2 adama a na vi ta̱ koɓolo nu mpa,
\q1 kalangu ka nwalu ka̱ nu,
\q1 n kalangu ka kaguɓa ka̱ nu,
\q2 i ta̱ a̱ kula̱na̱ mu,
\q2 i ta̱ e ku ere wuma u va̱.
\q1 
\v 5 Vu foɓuso ko mu ta̱ ka̱ɗiva̱,
\q2 e kelime ki irala i va̱,
\q1 vu erengu mu ta̱ n maniꞋin me kerengu,
\q2 meyelyu ma̱ va̱ ma shanai ali ma ɓarakpai.
\q1 
\v 6 Mayun, kasingai ka̱ nu n ucigi u nu,
\q2 wi ta̱ o kuyongo nu mpa a ayin a wuma u va̱ dem,
\q2 ka̱ta̱ n da̱sa̱ngu a kpaꞋa ku Vuzavaguɗu ko wannai.
\c 24
\s1 Mogono ma gbayin
\d Vishipa vu Dawuda.
\q1 
\v 1 Iɗika i Vuzavaguɗu i ɗa,
\q2 n ili na yi punu dem,
\q1 aduniyan a̱ ni a ɗa,
\q2 n aza a na i punu ida̱shi dem.\x - \xo 24:1 \xt 1 Kor 10:26\x*
\q1 
\v 2 Adama a na u maꞋa ta̱ a ɗa a gaɗi vu mala,
\q2 u varai kumiꞋi ku ni a gaɗi vu mini.
\q1 
\v 3 Yayi u yawai u kumba kusan ku Vuzavaguɗu?
\q2 Yayi u yawai u uwa a̱ Ma̱va̱li mo oɓolo ma̱ ni?
\q1 
\v 4 Sai vuza na ulinga we ekiye a̱ ni u ciɗa u ɗa,
\q1 kpamu ka̱ɗu ka̱ ni ki ta̱ ciɗa,
\q2 n vuza na u tsu tono oboci ba,
\q2 ko u yaꞋan akucina a uwa ba.\x - \xo 24:4 \xt Mat 5:8\x*
\q1 
\v 5 Vuzavaguɗu wi ta̱ a kuzuwaka yi una̱singai.
\q2 Ka̱shile kawawi ka̱ ni ki ta̱ a ku isa yi.
\q1 
\v 6 IcuꞋu i uma a nanlo a ɗa,
\q2 a̱ tsu la̱nsa̱ e yeve Ka̱shile,
\q2 aza a na a tsu bana e kelime ka̱ Ka̱shile ka Yakubu.\qs Kuvuka\qs*
\q1 
\v 7 Ɓa̱yuwa̱i utsutsu wa n wanshi,
\q2 ɓa̱yuwa̱i utsutsu u cau,
\q2 Adama a na mogono ma gbayin mi ta̱ a kuꞋuwa punu.
\q1 
\v 8 Yayi mogono ma gbayin ma nampa?
\q2 A̱yi ɗa Vuzavaguɗu, vuza vu utsura m MalaꞋimili,
\q2 Vuzavaguɗu ɗa kalyaꞋi ko kuvon.
\q1 
\v 9 Ɓa̱yuwa̱i utsutsu wa n wanshi,
\q2 ɓa̱yuwa̱i utsutsu u cau,
\q2 Adama a na mogono ma gbayin mi ta̱ a kuꞋuwa,
\v 10 Yayi mogono ma gbayin ma nampa?
\q2 A̱yi ɗa Vuzavaguɗu, vuza vu utsura MalaꞋimili,
\q2 a̱yi ɗa mogono ma gbayin ma. \qs Kuvuka\qs*
\c 25
\s1 Avasa a̱ kula̱nsa̱ ucunukpi wu unushi // n we eri
\d Vishipa vu Dawuda.
\q1 
\v 1 Vuzavaguɗu, n neke ta̱ wuma u va̱ wa̱ nu.
\v 2 Ka̱shile ka̱ va̱, wa̱ a̱ nu u ɗa n zuwai ka̱ɗu ka̱ va̱,
\q1 ka̱ta̱ vu ka̱sukpa̱ mu m pana wono ba,
\q2 ka̱ta̱ vu ka̱sukpa̱ irala i va̱ i yaꞋanka mu kindi ku kugoyi ba.
\q1 
\v 3 Aza a na a zuwai a̱ɗu e le wa̱ a̱ nu,
\q2 i kupana wono ba,
\q1 ama yaꞋan aza a unambi wu usuɓi a pana wono.
\q1 
\v 4 Vuzavaguɗu vu yotsongu mu uye u nu,
\q2 vu piꞋisaka mu ukuna u nu.
\q1 
\v 5 Tono nu mpa tsu na n kuyaꞋan kamayun,
\q2 ka̱ta̱ vu piꞋisaka mu,
\q1 adama a na avu ɗa Ka̱shile kishi ka̱ va̱,
\q2 makyan dem n tsu zuwa ta̱ ka̱ɗu wa̱ a̱ nu.
\q1 
\v 6 Vuzavaguɗu, ciɓa n kasingai ka̱ nu,
\q2 n ucigi u nu u na u tsu sabaꞋa ba,
\q2 u na vu yotsongi ali n ayin a cau ɗe.
\q1 
\v 7 Cinukpa n unushi wu ucigi u ka̱ɗu u va̱,
\q2 n unushi u na n yaꞋin a ayin a na mi ishi kolobo,
\q1 adama a ucigi u nu una u tsu sabaꞋa ba n kasingai ka̱ nu,
\q2 vu ciɓa nu mpa Vuzavaguɗu.
\q1 
\v 8 Vuzavaguɗu vuza vu usuɓi ɗa, n kasingai kpamu,
\q2 u tsu yotsongu ta̱ aza a unushi uye u na o kutono.
\q1 
\v 9 U tsu tono ta̱ n aza na o ogoyoi ka̱ci ke le, a ukuna u mejege,
\q2 wi ta̱ a kupiꞋisaka le tsu na o kutono yi,
\q1 
\v 10 Uye u Vuzavaguɗu ra̱ka̱,
\q2 ucigi u ɗa u na u tsu sabaꞋa ba n usuɓi,
\q2 wa aza a na i o kutono uzuwakpani u ni n wila̱ u ni.
\q1 
\v 11 Vuzavaguɗu, shatangu uzuwakpani u nu,
\q2 vu cinukpaka mu unushi u va̱,
\q2 adama a na wi ta̱ n a̱bunda̱i.
\q1 
\v 12 Aza a na i a kupana wovon u Vuzavaguɗu,
\q2 wi ta̱ o kuyotsongu le uye u na o kutono.
\q1 
\v 13 I ta̱ a kulyaꞋa kelime makyan dem,
\q2 ntsukaya n e le mi ta̱ a kulyaꞋa uka̱ni wi iɗika ya.
\q1 
\v 14 Vuzavaguɗu wu ushuku ta̱ n aza na i a kupana wovon u ni,
\q2 u tsu zuwa le ta̱ e yeve uzuwakpani u ni.
\q1 
\v 15 Makyan dem a̱shi a̱ va̱ i ta̱ a̱ ubuta̱ u Vuzavaguɗu a̱ kula̱nsa̱ uɓa̱nki,
\q2 adama a na a̱yi ɗa koci u ku ere mu a̱ ubuta̱ u gbani-gbani.
\q1 
\v 16 Vadalukpa uɓon u va̱ Vuzavaguɗu,
\q2 vu yaꞋanka mu kasingai,
\q1 adama a na mi n vuza ba,
\q2 kpamu ko utsura.
\q1 
\v 17 Una̱mgbuka̱tsuma̱ u ka̱ɗu ka̱ va̱ o doku ta̱ a̱bunda̱i,
\q2 wawa mu a̱ ka̱tsuma̱ ka atakaci a̱ va̱.
\q1 
\v 18 Zuwaka n una̱mgbuka̱tsuma̱ u va̱,
\q2 vu ene atakaci a̱ va̱,
\q2 ka̱ta̱ vu cinukpaka mu unushi u va̱.
\q1 
\v 19 La̱na̱ ka̱bunda̱i ka irala i va̱,
\q2 la̱na̱ tsu na o kovoi mu.
\q1 
\v 20 Ere mu ka̱ta̱ vu wawa mu,
\q2 ka̱ta̱ vu ka̱sukpa̱ m pana wono ba,
\q2 adama a na wa̱ a̱ nu u ɗa n ta̱wa̱i kusheɗeku.
\q1 
\v 21 YaꞋan kasingai n kamayun ke ere mu,
\q2 adama a na n zuwa ta̱ ka̱ɗu ka̱ va̱ wa̱ a̱ nu.
\q1 
\v 22 Ka̱shile, shiba̱ aza a Isaraila,
\q2 a̱ ka̱tsuma̱ ka atakaci e le.
\c 26
\d Vishipa vu Dawuda.
\p 
\v 1 Vuzavaguɗu, yotsongu a na mpa mi n unushi ba,
\q2 adama a na n yaꞋan ta̱ ili na yi derere,
\q1 n neke ta̱ Vuzavaguɗu ka̱ɗu ka̱ va̱,
\q2 ko munla̱i.
\q1 
\v 2 Vuzavaguɗu, kondo mu,
\q2 vu kondo kusheshe ku ka̱ɗu ka̱ va̱,
\q1 
\v 3 Adama a na n yeve ta̱ ucigi u nu u na u tsu sabaꞋa ba,
\q2 wi ta̱ o kutono nu mpa,
\q2 kamayun ka̱ nu kaꞋa mi o kutono ayin tutu.
\q1 
\v 4 N ci yongo n uma a kavama ba,
\q2 kabura mu n aza a kapalaka̱shi ba,
\q1 
\v 5 N kovo ta̱ koɓolo ka uma a gbani-gbani,
\q2 n tsu yongo n uma a gbani-gbani ba,
\q1 
\v 6 Vuzavaguɗu, n saꞋa ta̱ ekiye a̱ va̱,
\q2 adama a na n yotsongu mi n unushi ba,
\q2 n kucikpa ku ɗa n tsu dasa n ka̱ra̱Ꞌa̱ katalikalyuka ka̱ nu.
\q1 
\v 7 Mi ta̱ a kucanana ishipa i kucikpa n ka̱la̱ka̱tsu ka̱u,
\q2 nu n dansai ili mereve i na vu yaꞋin ra̱ka̱.
\q1 
\v 8 Vuzavaguɗu, n ciga ta̱ kpaꞋa ku na vi a̱ ida̱shi,
\q2 ubuta̱ u na tsugbayin tsu nu ci a̱ ida̱shi.
\q1 
\v 9 Ka̱ta̱ vu una mu koɓolo n aza a unushi ba,
\q2 ko vu una mu koɓolo n aza a munuka ba,
\q1 
\v 10 Aza a na i a kuyaꞋan ka gbani-gbani a makyan dem,
\q2 i ta̱ ufoɓushi adama a na isa kalyaꞋa.
\q1 
\v 11 Ama mpa, mi ta̱ a kuyaꞋan ili i na yi mejege,
\q2 pana asuvayali a̱ va̱ vu shiba̱ mu.
\q1 
\v 12 N laꞋaka ta̱ a̱ ubuta̱ ka gbani-gbani dem,
\q2 a̱ ka̱tsuma̱ ko koɓolo ka uma,
\q1 mi ta̱ a kucikpa Vuzavaguɗu.
\c 27
\s1 Vuzavaguɗu ɗa kutashi ku va̱ n kishi ka̱ va̱
\d Vishipa vu Dawuda.
\p 
\v 1 Vuzavaguɗu ɗa kutashi ku va̱ n kishi ka̱ va̱,
\q2 wovon u yayi n kupana?
\q1 Vuzavaguɗu ɗa ubuta̱ u kusheɗeku va̱,
\q2 wovon u yayi n kupana?
\q1 
\v 2 Ɗa baci uma a gbani-gbani a̱ ta̱wa̱i wa̱ a̱ va̱,
\q2 adama a na una mu,
\q2 i ta̱ a̱ kuta̱ɗa̱tsa̱ a̱ yikpa̱.
\q1 
\v 3 Ko ɗa baci ka̱tsura̱ ko osoji ka̱ ka̱ra̱Ꞌi mu,
\q2 mi a kupana wovon ba,
\q1 ko ɗa baci irala i va̱ a̱ tuka̱i mu n kuvon,
\q2 n nannai dem mi ta̱ o kuyongo n ka̱ɗu ida̱shi.
\q1 
\v 4 Ili i te i ɗa n folonoi u Vuzavaguɗu,
\q2 ili i na n cigai i ɗanna,
\q1 ɗaɗa n da̱sa̱ngu a kpaꞋa ku Vuzavaguɗu,
\q2 a ayin a wuma u va̱ ra̱ka̱,
\q1 ka̱ta̱ m pana uyoꞋo u Vuzavaguɗu
\q2 ka̱ta̱ kpamu n folono yi ɗe A̱Ꞌisa̱ a gbayin a̱ ni.
\q1 
\v 5 A makyan ma atakaci,
\q2 wi ta̱ o kufoɓo mu a̱ ubuta̱ wi ida̱shi i ni,
\q2 wi ta̱ a kuzuwa mu gaɗi vu kusan ku ugaɗi.
\q1 
\v 6 Ta n kulyaꞋa kelime ka irala i va̱ i na i ka̱ra̱Ꞌi nu mpa nannai,
\q2 n ma̱za̱nga̱ maꞋa n kuneke alyuka A̱Ꞌisa̱ a gbayin,
\q2 mi ta̱ a kuyaꞋan vishipa, n cikpa Vuzavaguɗu.
\q1 
\v 7 Panaka mu Vuzavaguɗu, makyan ma na baci n ɗekei nu,
\q2 pana asuvayali a̱ va̱, vu ushuku mu.
\q1 
\v 8 Vu danai, <<Ta̱wa̱ wa̱ a̱ va̱.>>
\q2 <<Mi ta̱ ta na a̱ kuta̱wa̱ wa̱ a̱ nu, Vuzavaguɗu.>>
\q1 
\v 9 Vuzavaguɗu,
\q2 ka̱ta̱ vu sokongu ku mu a̱shi a̱ nu ba,
\q1 ka̱ta̱ vu loko kagbashi ka̱ nu,
\q2 a̱ ka̱tsuma̱ ka wupa u nu ba,
\q2 avu ɗa vi a̱ kuɓa̱nka̱ mu,
\q1 ali a makyan ma ɗe,
\q2 Ka̱ta̱ vu ka̱sukpa̱ mu ba,
\q1 ka̱ta̱ vu varuku mu ba,
\q2 Ka̱shile ka̱ va̱ kishi ka̱ va̱.
\q1 
\v 10 Ko ɗa baci esheku a̱ va̱ n a̱na̱ku a̱ va̱ a variki mu,
\q2 Vuzavaguɗu wi ta̱ a̱ kula̱na̱ mu.
\q1 
\v 11 PiꞋisaka mu ili i na n kuyaꞋan,
\q2 Vuzavaguɗu,
\q1 vu tono nu mpa a uye u mejege,
\q2 adama a na mi ta̱ n irala na̱ a̱bunda̱i.
\q1 
\v 12 Ka̱ta̱ vu ka̱sukpa̱ mu n yikpa̱ ekiye a irala i va̱ ba,
\q2 aza a na i a kuyaꞋansaka mu kadanshi ka aꞋuwa,
\q2 n kadanshi ka kavama.
\q1 
\v 13 N neke ta̱ ka̱ɗu, mi ta̱ o kuyongo n wuma,
\q2 adama a na me ene kasingai ka Vuzavaguɗu,
\q2 ka na u kuyaꞋanka uma a̱ ni.
\q1 
\v 14 Zuwa ka̱ɗu u Vuzavaguɗu,
\q2 vu gbama asuvu, vu yaꞋan utsura u ka̱ɗu
\q2 zuwa ka̱ɗu u Vuzavaguɗu.
\c 28
\s1 Avasa a ufolu n ucikpi
\d Vishipa vu Dawuda.
\q1 
\v 1 Vuzavaguɗu avu ɗa mi a kuɗeke, katali ke kusheɗeku ku va̱,
\q2 pana ma̱shi ma̱ va̱,
\q1 vu ushuku mu baci ba,
\q2 mi ta̱ o kokpo a̱ ka̱tsuma̱ ka aza a na a̱ gida̱la̱i a kubana ukpisa̱.
\q1 
\v 2 Panaka mu,
\q2 a makyan ma na mi a̱ ma̱shi
\q1 a̱ kula̱nsa̱ uɓa̱nki,
\q1 ɗa baci n ɗa̱ngusa̱i ekiye a̱ va̱,
\q2 a kindana A̱Ꞌisa̱ a gbayin a̱ nu.
\q1 
\v 3 Ka̱ta̱ vu una mu n uma a gbani-gbani ba,
\q2 koɓolo n aza a na a ci yaꞋan ka gbani-gbani ba,
\q1 aza a na kadanshi ke le adanshi ka̱ ma̱ta̱na̱ kaꞋa,
\q2 ama a̱ɗu e le i ta̱ tukpa n tsurala.
\q1 
\v 4 Tsupa le derere ci ili i na a yaꞋin,
\q2 takacika le tsu ka gbani-gbani ke le,
\q2 neke le i na yi untsai le derere.
\q1 
\v 5 A zuwaka n ulinga u na Vuzavaguɗu u yaꞋin ba,
\q2 n ili i na ekiye a̱ ni a yaꞋin ba,
\q1 adama a nannai wi ta̱ a kutakacika le,
\q2 wu una le ra̱ka̱.
\q1 
\v 6 Cikpai Vuzavaguɗu,
\q2 adama a na u pana ta̱ ma̱shi ma̱ kula̱nsa̱ uɓa̱nki ma̱ va̱.
\q1 
\v 7 Vuzavaguɗu ɗa utsura u va̱,
\q2 n ma̱ra̱ga̱ ma̱ va̱,
\q1 n zuwa ta̱ ka̱ɗu ka̱ va̱ wa̱ a̱ ni,
\q2 u ɓa̱nka̱ mu ta̱, n yaꞋan ta̱ ma̱za̱nga̱,
\q2 n vishipa vu va̱ ɗa n kucikpa yi.
\q1 
\v 8 Vuzavaguɗu ɗa katsura ka uma a̱ ni,
\q2 mashilya ma wishi maꞋa u mogono ma na u zagbai.
\q1 
\v 9 Isa uma a̱ nu Vuzavaguɗu,
\q2 vu zuwaka uma a̱ uka̱ni a̱ nu una̱singai.
\q2 vu okpo maguɓi me le,
\q1 vu la̱na̱ le ko wannai.
\c 29
\s1 Ka̱la̱ka̱tsu ka Vuzavaguɗu a uguyi
\d Vishipa vu Dawuda.
\q1 
\v 1 Cikpai Vuzavaguɗu, a̱ɗa̱ ili i wuma i gaɗi,
\q2 cikpai tsugbayin ci ni n utsura u ni.
\q1 
\v 2 Cikpai kula ku gbayin ku Vuzavaguɗu,
\q2 i kuɗa̱ngu e kelime ka vuza ciɗa ɗa baci uɓa̱tsa̱i.
\q1 
\v 3 A pana ta̱ ka̱la̱ka̱tsu ka Vuzavaguɗu a mala,
\q2 Ka̱shile ka tsugbayin ka̱ giruwa̱ ta̱,
\q2 ka̱la̱ka̱tsu ka̱ tsugiruwi ka̱ ni ka̱ ɗumgba̱ ta̱ a mala.
\q1 
\v 4 Ka̱la̱ka̱tsu ka Vuzavaguɗu,
\q2 ki ta̱ n utsura,
\q1 ka̱la̱ka̱tsu ka Vuzavaguɗu,
\q2 ki ta̱ n tsugbayin.
\q1 
\v 5 Ka̱la̱ka̱tsu ka Vuzavaguɗu ko tsu koɗo ta̱ nɗanga n Sida,
\q2 ali nu nɗanga n sida n Lebano.
\q1 
\v 6 U tsu zuwa ta̱ nsansa n Lebano n ɗikpangu tsu ndendem,
\q2 ka̱ta̱ kpamu u zuwa kusan ku Hamon ku ɗikpangu tsu medendem.
\q1 
\v 7 Ka̱la̱ka̱tsu ka Vuzavaguɗu,
\q2 ka zuwa ta̱ tsulaɗi tsu akana.
\q1 
\v 8 Ka̱la̱ka̱tsu ka Vuzavaguɗu,
\q2 ka̱ tsu gba̱ɗa̱ ta̱ kakamba,
\q1 ka̱la̱ka̱tsu ka Vuzavaguɗu,
\q2 ka tsu gba̱ɗa̱ ta̱ kakamba ka Kadeshi.
\q1 
\v 9 Ka̱la̱ka̱tsu ka Vuzavaguɗu,
\q2 ka zuwa ta̱ nɗanga n gbagbaꞋin n gba̱ɗa̱i,
\q1 u zuwai nɗanga n kutsu n sa̱ruwa̱i,
\q1 a na a yaꞋin isali i ma̱za̱nga̱ punu AꞋisa̱ a gbayin a̱ ni,
\q2 a danai,<<Tsugbayin u Ka̱shile.>>
\q1 
\v 10 Vuzavaguɗu wi ta̱ o tsugono tsu mala ma gbayin,
\q2 wi ta̱ a kulyaꞋa tsugono tsu mogono ko wannai.
\q1 
\v 11 YaꞋan Vuzavaguɗu u neke uma a̱ ni utsura,
\q2 YaꞋan Vuzavaguɗu u zuwaka le una̱singai n ma̱ta̱na̱.
\c 30
\s1 Ishipa i kucikpa adama a kupotsokpo
\d Vishipa vu Dawuda.
\q1 
\v 1 Vuzavaguɗu, mi ta̱ a kucikpa wu,
\q2 adama a na vu wawa mu ta̱,
\q2 ɗa vu sa̱nka̱i irala i va̱ i lyaꞋa mu.
\q1 
\v 2 N folono ta̱ uɓa̱nki wa̱ nu,
\q2 Vuzavaguɗu Ka̱shile ka̱ va̱,
\q2 ɗa tana vu potsokpoi mu.
\q1 
\v 3 Vuzavaguɗu, vu isa mu ta̱ a̱ ubuta̱ wu ukpisa̱,
\q2 adama a na n ka̱na̱ ta̱ ɗe uye a̱ kugida̱la̱ e kpenle,
\q2 ama ɗa vu isai mu.
\q1 
\v 4 Cananai ishipa i kucikpa Vuzavaguɗu,
\q2 a̱ɗa̱ uma a̱ ma̱riki.
\q2 Ciɓai, n ili i na vuza ciɗa u yaꞋin,
\q2 i cikpa yi.
\q1 
\v 5 Wupa u ni u tsu geshe ba,
\q2 ama kasingai ka̱ ni ki ta̱ lo ko wannai,
\q1 a̱ kushika̱ ta̱ n kayin,
\q2 ama ka̱ta̱ ma̱za̱nga̱ ma̱ ta̱wa̱ n usana.
\q1 
\v 6 Mpa n ka̱ɗu a̱ ida̱shi, ɗa n danai,
\q2 <<Ko vuza u kulyaꞋa kelime ka̱ va̱ ba.>>
\q1 
\v 7 Vuzavaguɗu, adama a kasingai ka̱ nu,
\q2 u ɗa vu shikpa̱i mu tsu katali ka gbayin ku utsura.
\q1 Ama ayin a na baci vu sokongu ki mu a̱shi a̱ nu,
\q2 ka̱ta̱ wovon u ka̱na̱ mu ka̱u.
\q1 
\v 8 N ɗeke wu ta̱, Vuzavaguɗu,
\q2 n folono ta̱ uɓa̱nki u nu.
\q1 
\v 9 <<Yiɗa̱i a̱ kuciya̱ n kuwa̱ baci?
\q2 Kodokpotsu ke ne ka i a̱ kuciya̱,
\q1 ɗa baci n gida̱la̱i a kubana a kasaun?
\q2 A̱kpisa̱ i ta̱ a kufuɗa kucikpa wu?
\q2 I ta̱ a kusala usuɓi u nu?
\q1 
\v 10 Vuzavaguɗu, panaka mu,
\q2 pana asuvayali a̱ va̱,
\q2 Ɓa̱nka̱ mu, Vuzavaguɗu.>>
\q1 
\v 11 Vu bonokoi una̱mgbuka̱tsuma̱ u va̱,
\q2 wo okpoi kujeꞋe ku ma̱za̱nga̱,
\q1 vu foɗoi mu akashi a kpalu,
\q2 vu ukai mu a̱ ma̱za̱nga̱.
\q1 
\v 12 Adama a nannai, mi a kupaɗa bini ba,
\q2 mi ta̱ a kucikpa wu n ishipa.
\q1 Vuzavaguɗu, avu ɗa Ka̱shile ka̱va̱,
\q2 mi ta̱ a kucikpa wu ko wannai.
\c 31
\s1 Avasa a uneki u ka̱ɗu u Ka̱shile
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda.
\q1 
\v 1 N ta̱wa̱ ta̱ wa̱ a̱ nu Vuzavaguɗu,
\q2 adama a na vu ere mu,
\q2 ka̱ta̱ vu ka̱sukpa̱ a̱ ciya̱ ulyaꞋi a̱ va̱ ba,
\q2 avu Ka̱shile ka usuɓi kaꞋa,
\q2 wawa mu mi ta̱ ufolu u nu.
\q1 
\v 2 Pana ka mu, vu wawa mu gogo na,
\q2 vu okpo ubuta̱ u kusheɗeku u va̱,
\q1 mashilya ma utsura,
\q2 ma na ma ku isa mu.
\q1 
\v 3 Avu ɗa ubuta̱ u kusheɗeku u va̱, n mashilya ma̱ va̱,
\q2 tono nu mpa tsu na vu yaꞋin uzuwakpani.
\q1 
\v 4 Ere mu a maza ma na a zuwakai mu,
\q2 adama a na avu ɗa ubuta̱ u kusheɗeku u va̱.
\q1 
\v 5 Ekiye a̱ nu a ɗa n zuwai wuma u va̱,
\q2 avu ɗa vu shiba̱i mu,
\q2 Vuzavaguɗu, Ka̱shile ku usuɓi.
\q1 
\v 6 N iwan ta̱ aza a na i o kutono a̱ma̱li,
\q2 ama n mpa n zuwa ta̱ ka̱ɗu u Vuzavaguɗu.
\q1 
\v 7 Mi ta̱ a kuyaꞋan ma̱za̱nga̱,
\q2 adama a ucigi u nu u na u tsu sabaꞋa ba,
\q2 vu ene ta̱ atakaci a̱ va̱,
\q2 Vu yeve ta̱ mɓa̱la̱ n va̱.
\q1 
\v 8 Vu neke mu ekiye irala i va̱ ba.
\q2 ama vu zuwa mu ta̱ a ubuta̱ u singai.
\q1 
\v 9 Vuzavaguɗu pana asuvayali a̱ va̱,
\q2 adama a na mi ta̱ a̱ ka̱tsuma̱ ka atakaci.
\q1 a̱shi a̱ va̱ a shitasa ta̱ adama a̱ ma̱shi,
\q2 wuma u va̱ n ikyamba yi oꞋwoi yo okpoi luɓa̱.
\q1 
\v 10 Una̱mgbuka̱tsuma̱ u jebe ta̱ ayin a̱ va̱,
\q2 ma̱shi kpamu me jebe ta̱ a̱ya̱ a̱ va̱,
\q1 utsura u va̱ u kotso ta̱,
\q2 adama a̱ ka̱bunda̱i atakaci a̱ va̱,
\q2 ali etele a̱ va̱ a̱ kuwa̱i.
\q1 
\v 11 Ɗa mo okpoi ili ma̱ka̱n,
\q2 e kelime ki irala i va̱,
\q1 ili i kugoyi a̱ ubuta̱ wa aza a na ci ida̱shi ɗeɗevu,
\q2 ili i wovon wa aza na e yevei mu,
\q1 ene mu baci a uye, ka̱ta̱ a suma.
\q1 
\v 12 A cinukpai nu mpa tsu vuza na u kuwa̱i,
\q2 mo okpoi ci ili i na a variki.
\q1 
\v 13 M pana ta̱ irala i va̱ a̱ kuyun,
\q2 ɗa wovon u ka̱ra̱Ꞌi mu,
\q2 e kusheshe adama a na a una mu.
\q1 
\v 14 Ama mpa n zuwa ta̱ ka̱ɗu ka̱ va̱ wa̱ nu, Vuzavaguɗu,
\q2 <<Avu ɗa Ka̱shile ka̱ va̱.>>
\q1 
\v 15 Makyan dem vi ta̱ a̱ kula̱na̱ mu,
\q2 vu isa mu ta̱ a̱ ubuta̱ wi irala i va̱,
\q2 ekiye aza a na i a kutakacika mu.
\q1 
\v 16 Mpa kagbashi ka̱ nu kaꞋa,
\q2 indana mu n a̱shi a singai,
\q2 isa mu adama a ucigi u nu u na u tsu sabaꞋa ba.
\q1 
\v 17 Ka̱ta̱ vu ka̱sukpa̱ m pana wono ba,
\q2 Vuzavaguɗu, adama a na n ɗeke wu ta̱.
\q1 zuwa uma a gbani-gbani a pana wono,
\q2 a̱ gida̱la̱ n ka̱bini a kubana a̱ ubuta̱ wa̱ a̱kpisa̱.
\q1 
\v 18 Kuya̱ngu una̱ wa aza aꞋuwa,
\q2 aza o kugoyi ra̱ka̱ n aza a̱ra̱ɗi,
\q2 a na i a kuyaꞋanka aza a usuɓi kadanshi ko kugoyi.
\q1 
\v 19 Ka̱bunda̱i ka̱ yiɗa̱i a kugisanku n kasingai ka̱ nu,
\q2 kasingai ka na vu yaꞋankai aza a na i a kupana wovon u nu,
\q2 kasingai ka na vu yaꞋin a̱ a̱shi a uma,
\q1 wa aza a na i a̱ kula̱nsa̱ ubuta̱ u kusheɗeku wa̱ a̱ nu.
\q1 
\v 20 Vu tsu sokongu le ta̱ a̱ ubuta̱ u nu,
\q2 a nsata n uma.
\q1 Vu tsu zuwa le ta̱ m ma̱ta̱na̱ a̱ ubuta̱ wi ida̱shi i nu.
\q2 ka̱ta̱ a pana ishikushi i uma ba.
\q1 
\v 21 Cikpai Vuzavaguɗu,
\q2 adama a na u yotsongu mu ta̱ ucigi u ni,
\q2 ucigi u ni u na u tsu sabaꞋa ba
\q1 a makyan ma na a kanji mu n kuvon,
\q1 
\v 22 M panai wovon,
\q2 mpa n sheshe ta̱ vu loko mu ta̱ wa̱ a̱ nu,
\q1 Ama ɗa vu panai ma̱shi ma̱ va̱,
\q2 a makyan ma na n ɗekei nu kula̱nsa̱ uɓa̱nki,
\q1 
\v 23 Cigai Vuzavaguɗu, a̱ɗa̱ uma a usuɓi a̱ ni,
\q2 Vuzavaguɗu wi ta̱ e kere aza a usuɓi,
\q2 ama u tsu takacika ta̱ aza a̱ra̱ɗi.
\q1 
\v 24 tsurukpai ka̱ta̱ i gbama asuvu,
\q2 ra̱ka̱ vu ɗa̱ na i keɗei a̱pa̱Ꞌa̱ u Vuzavaguɗu.
\c 32
\s1 Kushika̱ ku unushi n kucinukpa ku unushi.
\d VicuꞋu vu tsuwaꞋi tsu Dawuda.
\q1 
\v 1 Vuza vu ma̱za̱nga̱ ɗa,
\q2 vuza na a cinukpai unushi u ni,
\q2 vuza na a takpai unushi u ni.\x - \xo 32:1 \xt Rom 4:7-8\x*
\q1 
\v 2 Vuza vu ma̱za̱nga̱ ɗa,
\q2 vuza na Vuzavaguɗu wi a ku ula yi n unushi ba,
\q2 kpamu a̱ ciya̱ ka gbani-gbani wa̱ a̱ ni ba.
\q1 
\v 3 Ana n shika̱i unushi u va̱ ba,
\q2 Mo oꞋusoi ka̱ci ka̱ va̱ kanna dem a̱ ma̱shi.
\q1 
\v 4 Vuzavaguɗu, vu takacika mu ta̱ kanna n kayin,
\q2 utsura u va̱ u kotsoi ra̱ka̱,
\q1 tsu na mita̱ me ci ɗekpe,
\q2 adama a usuɗukpi u kanna ka ayin a kpandari. \qs Kuvuka\qs*
\q1 
\v 5 Ɗa n shika̱i unushi u va̱ wa̱ a̱ nu,
\q2 n sokongu unushi u va̱ ba.
\q1 N danai, <<Mi ta̱ a̱ kushika̱ unushi u va̱ u Vuzavaguɗu.>>
\q2 Ɗa tana vu cinukpakai mu unushi u va̱. \qs Kuvuka\qs*
\q1 
\v 6 Adama a nannai yaba dem na wi o kutono wu,
\q2 wi ta̱ a kuvasa wa̱ a̱ nu, a makyan ma atakaci,
\q1 a makyan ma na kawuya ka̱ ta̱wa̱i le tsu mini ma na ma ayai,
\q2 mi a kuyawa wu e le ba.
\q1 
\v 7 Avu ɗa ubuta̱ u kusheɗeku u va̱,
\q2 vi ta̱ a ku wawa mu atakaci,
\q1 mi ta̱ a kucanana ishipa,
\q2 adama a wishi u nu.\qs Kuvuka\qs*
\q1 
\v 8 Vuzavaguɗu u danai,
\q2 mi ta̱ o kuyotsongu wu uye u na vu kutono,
\q1 mi ta̱ e kuneke wu kadanshi n neke wu odoki kpamu.
\q1 
\v 9 Ka̱ ta̱ vo okpo n tsulau tsu kodoku ko makparagi ba,
\q2 ele na sai n iryangama,
\q2 ka̱ta̱ yeve o tono wu.
\q1 
\v 10 Mayun ɗa aza a gbani-gbani a takacika,
\q2 ama aza a na e nekei ka̱ɗu u Vuzavaguɗu,
\q2 ucigi u ni u na u tsu sabaꞋa ba wi ta̱ e kere le.
\q1 
\v 11 YaꞋin ma̱za̱nga̱, a̱ɗa̱ aza a usuɓi ra̱ka̱,
\q2 yaꞋin ma̱za̱nga̱ adama a ili i na Vuzavaguɗu u yaꞋin,
\q2 ra̱ka̱ vu ɗa̱ na yi o kutono yi,
\q1 yaꞋin isali i ma̱za̱nga̱.
\c 33
\s1 Vishipa vu ucikpi
\d Vishipa vu Dawuda.
\q1 
\v 1 YaꞋin ma̱za̱nga̱, a̱ɗa̱ aza a usuɓi ra̱ka̱,
\q2 adama a ili i na Vuzavaguɗu u yaꞋin,
\q2 cikpai ni a̱ɗa̱ na yi o kutono yi.
\q1 
\v 2 Cikpai Vuzavaguɗu n umolu,
\q2 yaꞋankai ni ishipa n umolu u na wi n anꞋin kupa.
\q1 
\v 3 YaꞋankai ni vishipa vu savu,
\q2 waꞋakai ni umolu mayin,
\q2 i yaꞋan ishipa i ma̱za̱nga̱ n kacaꞋa!
\q1 
\v 4 Adama a na kadanshi ka Vuzavaguɗu mayun ɗa,
\q2 kpamu ulinga u ni ra̱ka̱ wu usuɓi u ɗa.
\q1 
\v 5 Vuzavaguɗu u tsu ciga ta̱ kamayun n usuɓi,
\q2 aduniyan a shana ta̱ n ucigi u Vuzavaguɗu u na u tsu sabaꞋa ba.
\q1 
\v 6 N uneki u kadanshi kaꞋa Vuzavaguɗu u yaꞋin gaɗi,
\q2 n kadanshi ka̱ ni kaꞋa, u yaꞋin kanna, wotoi n azangata.
\q1 
\v 7 U ɓolongi mini ma mala a̱ ubuta̱ ute,
\q2 u zuwai mala ma uga̱vi ma,
\q2 tsu vuza na u foɓoi ishina o mopon,
\q1 
\v 8 YaꞋan aduniyan ra̱ka̱ a pana wovon u Vuzavaguɗu,
\q2 panai wovon u ni uma aduniyan.
\q1 
\v 9 N kadanshi kaꞋa u yaꞋin aduniyan,
\q2 kadanshi kaꞋa u nekei ɗa ili ra̱ka̱ i shamgbai.
\q1 
\v 10 Vuzavaguɗu u tsu la̱nga̱sa̱ ta̱ ofoɓuso a uma aduniyan,
\q2 u tsu sabaꞋasaka ta̱ kusheshe ku uma.
\q1 
\v 11 Ama kusheshe ku Vuzavaguɗu ki ta̱ lo ko wannai,
\q2 kusheshe ku ka̱ɗu ku ni kpamu a makyan dem.
\q1 
\v 12 Uduniyan u ma̱za̱nga̱ u ɗa u na Vuzavaguɗu ɗa Ka̱shile ka̱ ni,
\q2 uma a na u zagbai okpo uma uka̱ni a̱ ni.
\q1 
\v 13 Ɗe gaɗi ɗa Vuzavaguɗu u tsu indana,
\q2 ka̱ta̱ wene uma dem.
\q1 
\v 14 Ɗe a̱ ubuta̱ wi ida̱shi i ni u ɗa u tsu indana,
\q2 u tsu ene ta̱ uma a na i a̱ ida̱shi aduniyan ra̱ka̱,
\q2 
\v 15 a̱yi ɗa u yaꞋin a̱ɗu e le dem,
\q2 kpamu u tsu yeve ta̱ i na a ci yaꞋansa dem.
\q1 
\v 16 Mogono ma tsu ciya̱ wishi adama ovonshi a̱bunda̱i a̱ ni ba,
\q2 keyevi ko kuvon ka tsu laꞋaka adama a utsura u gbayin u ni ba.
\q1 
\v 17 Kuneke ku ka̱ɗu o kodoku ko kuvon, ili gbani i ɗa,
\q2 n utsura u ni ra̱ka̱, wi a ku isa vuma ba.
\q1 
\v 18 Ama a̱shi a Vuzavaguɗu i ta̱ a ku inda aza a na i a kupana wovon u ni,
\q2 aza a na e keɗei a̱pa̱Ꞌa̱ e le
\q2 a ucigi u ni u na u tsu sabaꞋa ba.
\q1 
\v 19 U tsu isa le ta̱ a̱ ubuta̱ wu ukpa̱,
\q2 ka̱ta̱ u zuwa le o yongo n wuma a ayin a kambulu.
\q1 
\v 20 U Vuzavaguɗu u ɗa tsu keɗei a̱pa̱Ꞌa̱,
\q2 a̱yi ɗa ma̱ra̱ga̱ ma̱ tsu n ka̱ɓa̱nki ka̱ tsu.
\q1 
\v 21 Adama a̱ ni a ɗa ci a̱ ma̱za̱nga̱,
\q2 adama a na tsu neke ta̱ a̱ɗu a̱ tsu a kula ku ciɗa ku ni.
\q1 
\v 22 Vuzavaguɗu yaꞋan ucigi u ni u na u tsu sabaꞋa ba u yongo n a̱ tsu,
\q2 a na tsu keɗei a̱pa̱Ꞌa̱ a̱ tsu wa̱ a̱ nu.
\c 34
\s1 Ucikpi adama a wishi
\d Vishipa vu Dawuda.
\q1 
\v 1 Mi ta̱ a kucikpa Vuzavaguɗu makyan dem,
\q2 ucikpi u ni wi ta̱ o kuyongo a̱ una̱ u va̱ makyan dem.
\q1 
\v 2 Mi ta̱ a kucikpa Vuzavaguɗu,
\q2 yaꞋan aza ayali a pana ka̱ta̱ a yaꞋan ma̱za̱nga̱.
\q1 
\v 3 Salai tsugbayin tsu Vuzavaguɗu nu mpa,
\q2 tsu cikpa kula ku ni koɓolo.
\q1 
\v 4 N folonoi Vuzavaguɗu, ɗa tana wu ushuki mu,
\q2 ɗa wu utuka̱i mu a̱ ka̱tsuma̱ ko wovon u va̱ dem.
\q1 
\v 5 Aza a na i o kudoro,
\q2 a zuwai a̱shi e le wa̱ a̱ ni, a yaꞋin ma̱za̱nga̱,
\q2 i o kudoku ku na̱mgba̱ ka̱tsuma̱ ba.
\q1 
\v 6 Aza a unambi a yaꞋin meɗevile,
\q2 ɗa ta na Vuzavaguɗu u panakai le,
\q2 ɗa wi isai le a̱ ka̱tsa̱ma̱ ka atakaci e le.
\q1 
\v 7 Kalingata ka̱ ni ki ta̱ e kere,
\q2 aza a na i a kupana wovon u Vuzavaguɗu,
\q2 wu isai le a̱ ka̱tsuma̱ ka atakaci e le.
\q1 
\v 8 Kondoi yene n ka̱ci ka̱ ɗa̱ Vuzavaguɗu vuza kasingai ɗa.
\q2 vuza vu una̱singai ɗa a̱yi na u ciya̱i ubuta̱ u kusheɗeku wa̱ a̱ ni.
\q1 
\v 9 Yevei n ka̱ci ka̱ ɗa̱ tsu na
\q2 Vuzavaguɗu wi n kasingai,
\q2 vuza vu ma̱za̱nga̱ vuza na u ciya̱i
\q2 ida̱shi i ma̱ta̱na̱ wa̱ ni.
\q1 
\v 10 Ali ikawu feu, i tsu namba ta̱ ilikulya a pana kambulu,
\q2 ama aza a na i o kutono Vuzavaguɗu,
\q2 i a kunamba ili i singai ba.
\q1 
\v 11 Ta̱wa̱i, a̱ɗa̱ muku n va̱, i panaka mu,
\q2 mi ta̱ o kuyotsongu ɗa̱,
\q2 tsu na i kupana wovon u Vuzavaguɗu.
\q1 
\v 12 Yayi wi a kuciga u pana u yoꞋo u wuma u ni?
\q2 Yayi u cigai wu ene ayin a singai?
\q1 
\v 13 Sai, u ka̱na̱ kelentsu ka̱ ni a̱ ubuta̱ u ka gbani-gbani
\q2 ka̱ta̱ kpamu u ka̱na̱ una̱ u ni a̱ ubuta̱ u kuyaꞋan ka aꞋuwa.
\q1 
\v 14 U ka̱sukpa̱ ka gbani-gbani ka̱ ni, u yaꞋan kasingai,
\q2 u la̱nsa̱ ma̱ta̱na̱ n ka̱ɗu ka̱ ni ra̱ka̱.
\q1 
\v 15 A̱shi a Vuzavaguɗu i ta̱ a kinda aza a usuɓi,
\q2 atsuvu a̱ ni kpamu i ta̱ a kupana ma̱shi me le.
\q1 
\v 16 A̱shi a Vuzavaguɗu,
\q2 i ta̱ a tsurala n aza a na a ci yaꞋan ka gbani-gbani,
\q1 adama a na,
\q2 i ta̱ a kucinukpa n ukuna u le punu aduniyan ra̱ka̱.
\q1 
\v 17 Aza a usuɓi a̱ tsu shika̱ ta̱,
\q2 Vuzavaguɗu tana u tsu panaka le ta̱,
\q1 ka̱ta̱ wi isa le
\q2 a̱ ka̱tsa̱ma̱ ka atakaci e le dem.
\q1 
\v 18 Vuzavaguɗu u tsu yongo ta̱ ɗevu n aza a ugushi u ka̱ɗu,
\q2 u tsu isa ta̱ aza a na utuka̱i a̱ɗu.
\q1 
\v 19 Vuma vu usuɓi vu tsu takacika ta̱ ka̱u,
\q2 ama Vuzavaguɗu u tsu isai ta̱ a̱ ka̱tsuma̱ ke le dem.
\q1 
\v 20 Adama a na Vuzavaguɗu u tsu ere le ra̱ka̱,
\q2 ko ketele ke le ke te ka na o kukoɗo.
\q1 
\v 21 Ka gbani-gbani ki ta̱ a ku una vuma gbani-gbani,
\q2 i ta̱ a kutakacika aza a na i a kuꞋiwan aza a usuɓi.
\q1 
\v 22 Vuzavaguɗu wi ta̱ a̱ kushiba̱ wuma wa agbashi a̱ ni.
\q2 aza a na a banai wa̱ a̱ ni kula̱nsa̱ ubuta̱ u kusheɗeku, i ta̱ a̱ ku ka̱sukpa̱ le n wuma.
\c 35
\s1 Avasa a̱ kula̱nsa̱ uɓa̱nki
\d Vishipa vu Dawuda.
\q1 
\v 1 Vuzavaguɗu, yaꞋan vu shilika̱ n aza a na i a̱ vishili nu mpa,
\q2 yaꞋan kuvon n aza a na i o kuvon nu mpa.
\q1 
\v 2 Vu ɗika ma̱ra̱ga̱ n ucanuku u kuvon u nu,
\q2 vu ta̱wa̱ vu ɓa̱nka̱ mu.
\q1 
\v 3 Ɗa̱ngusa̱ masara ma̱ nu n kabata,
\q2 vu shilika̱ n aza a na i a ku guva mu!
\q1 yaꞋan m panaka wu a kudana,
\q2 <<Mpa ɗa kishi ka̱ nu.>>
\q1 
\v 4 YaꞋan aza a na i a̱ kula̱nsa̱ wuma u va̱, a pana wono,
\q2 zuwa aza a na i a kuyaꞋanka mu nsata a lukanasa le okpo n wono a̱ ripula̱.
\q1 
\v 5 Zuwa le okpo kopo ka na wunla̱i u tsu pura̱,
\q2 tsu aza a na kalingata ka Vuzavaguɗu ki o kuloko.
\q1 
\v 6 YaꞋan uye u le wo okpo ka̱yimbi,
\q2 wo okpo n kederi,
\q2 a makyan ma na kalingata ka Vuzavaguɗu ki a ku guva le.
\q1 
\v 7 Adama a na babu unushi ɗa a zuwakai mu maza,
\q2 a̱ ga̱va̱ka̱i mu kpenle ku uga̱vi,
\q2 adama a na n yikpa̱ punu.
\q1 
\v 8 YaꞋan atakaci a cinika le babu uyevi.
\q1 Ka̱sukpa̱ maza ma na azuki ma aza le.
\q2 ka̱ta̱ kpamu a̱ yikpa̱ punu e kpenle ka ali a ukpisa̱.
\q1 
\v 9 Ka̱ta̱ n yaꞋan ma̱za̱nga̱ adama a Vuzavaguɗu,
\q2 mi ta̱ a kuyaꞋan ma̱za̱nga̱ adama a na wi isa mu ta̱.
\q1 
\v 10 N ka̱ɗu kete mi ta̱ a kudana Vuzavaguɗu,
\q2 <<Vuza wi lo tsu nu ba,
\q1 vu tsu wawa ta̱ aza a unambi wa aza a utsura,
\q2 aza a unambi n ofoloni ekiye aza a na i o kudoro le.>>
\q1 
\v 11 Uma a gbani-gbani a kuyaꞋan aꞋuwa adama a̱ va̱,
\q2 a bankai n kadanshi ka unushi u na n yevei ba.
\q1 
\v 12 A kutsupa kasingai ka̱ va̱ n ka gbani-gbani,
\q2 ali ɗa n nambai i na n kuyaꞋan n wuma.
\q1 
\v 13 Ama a makyan ma na i a mɓa̱la̱,
\q2 mpa n tsu uka ta̱ akashi a kpalu,
\q2 n iwain kulyaꞋa ilikulyaꞋa,
\q1 n vasai n kaci ka̱ va̱ uza̱liki,
\q2 
\v 14 tsu na n kuyaꞋanka ka̱ja̱Ꞌa̱ ko vuza va̱ avasa,
\q2 mu uta̱i a̱shi u la̱nga̱shi adama a una̱mgbi u ka̱tsuma̱,
\q2 tsu vuza na wi a̱ ma̱shi ma̱ a̱na̱ku a̱ ni.
\q1 
\v 15 Ama ɗa baci n ta̱ɗa̱tsa̱i,
\q2 o ɓolongu a̱ ma̱za̱nga̱,
\q2 irala i va̱ o ɓolongi ka̱ci ke le adama a̱ va̱ n yeve ba,
\q2 a̱ ka̱na̱i ku zoꞋoso mu babu kuka̱sukpa̱.
\q1 
\v 16 Tsu aza a na i kupana wovon u Ka̱shile ba,
\q2 a yaꞋankai mu ma̱ka̱n ka̱u,
\q1 n a lunganai mu,
\q2 adama tsurala tsu na i a tsu ɗa nu mpa.
\q1 
\v 17 Vuzavaguɗu,
\q2 ali wannai ɗa va̱ ka̱na̱ kinda le koci?
\q1 Isa mu ekiye e le,
\q2 wawa wuma u va̱ a̱ ubuta̱ wi ikawu i nampa.
\q1 
\v 18 Ka̱ta̱ n cikpa wu o koɓolo ka uma ka̱ a̱bunda̱i,
\q2 e kelime ka uma a̱bunda̱i mi ta̱ a kucikpa wu.
\q1 
\v 19 Ka̱ta̱ vu ka̱sukpa̱ irala i va̱, aza aꞋuwa a nan lo, ene uyikpi uva̱ ba.
\q1 ka̱ta̱ vu ka̱sukpa̱ irala i va̱ i babu unushi,
\q2 n cigipi tsu a̱shi a yaꞋan ma̱za̱nga̱,
\q2 a pana uyoꞋo adama atakaci a̱ va̱ ba.
\q1 
\v 20 A ci yaꞋan kadanshi kasingai ba,
\q2 ama ka̱ta̱ a kucikpa a yaꞋan kadanshi ka aꞋuwa
\q2 wa aza a na i a̱ ida̱shi i ma̱ta̱na̱.
\q1 
\v 21 Ɗa a shikai mu a danai, <<Ehen! Ehen
\q2 tsu ene wu ta̱ n a̱shi a̱ tsu.>>
\q1 
\v 22 Ama avu Vuzavaguɗu vu ene ta̱ ili nampa,
\q2 adama a nannai, ka̱ta̱ vu ka̱sukpa̱ le ba.
\q2 Vuzavaguɗu ka̱ta̱ vu bana daꞋangi nu mpa ba.
\q1 
\v 23 Vuzavaguɗu ɗa̱nga̱, vu ere mu,
\q2 Ka̱shile ka̱ va̱, isa ka mu ili i na yi i va̱.
\q1 
\v 24 Avu vuza vu usuɓi ɗa,
\q2 Vuzavaguɗu yotsongu le unambi wu unushi u va̱,
\q1 ka̱ta̱ vu ka̱sukpa̱ irala i va̱,
\q2 a yaꞋan ma̱za̱nga̱ adama a̱ va̱ ba.
\q1 
\v 25 Ka̱ta̱ vu ka̱sukpa̱ le a danaka ka̱ci ke le, <<Ehen! ili i na tsu cigai i ɗanna.>>
\q2 Ka̱ta̱ vu ka̱sukpa̱ le a dana,
\q2 <<Tsu fuɗa yi ta̱.>>
\q1 
\v 26 Ka̱sukpa̱ yaba dem na u yaꞋin ma̱za̱nga̱ adama atakaci a̱ va̱,
\q2 a fuɗa le ali a̱ ripula̱,
\q1 yaꞋan aza a na i a kuɗika a laꞋa mu ta̱,
\q2 okpo n wono n kugoyi.
\q1 
\v 27 YaꞋan aza a na i a̱ ma̱za̱nga̱ adama a wishi u va̱,
\q2 a sala m ma̱za̱nga̱, n a danai,
\q1 <<Vuzavaguɗu vuza gbayin ɗa!
\q2 wi ta̱ a̱ ma̱za̱nga̱ adama ulyaꞋi u kagbashi ka̱ ni.>>
\q1 
\v 28 Ka̱ta̱ n sala ukuna wu usuɓi u nu,
\q2 kanna lakam mi ta̱ a kucikpa wu.
\c 36
\s1 Ka gbani-gbani ka vuma
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda.
\q1 
\v 1 Unushi wu ucigi u ka̱ɗu u tsu yaꞋan ta̱ kadanshi n uma a gbani-gbani a̱ɗu e le,
\q2 i n wovon u Ka̱shile a̱ a̱shi e le ba,
\q1 
\v 2 Adama a na i ta̱ a kuɗika ka̱ci ke le,
\q2 ele ili i yoku i ɗa,
\q1 e kene ku le,
\q1 unushi u le wi a̱ ku uta̱ e keteshe ba.
\q2 ali e neke le unushi.
\q1 
\v 3 Kadanshi ke le ki ta̱ tukpa n ka gbani-gbani n aꞋuwa,
\q2 a buwa n ugboji u na a kuyaꞋan kasingai ba.
\q1 
\v 4 E ci sheshe ta̱ ka gbani-gbani a makyan ma na i a ivaꞋin ajiba ele,
\q2 kuyongo kugaꞋan le ba,
\q2 a ci iwan ka gbani-gbani ba.
\q1 
\v 5 Vuzavaguɗu ucigi u nu u na u tsu sabaꞋa ba,
\q2 u yawa ta̱ ali gaɗi a̱da̱nga̱shile,
\q2 usuɓi u nu u yawa ta̱ a gaɗi vu eleshu.
\q1 
\v 6 Usuɓi u nu wi ta̱ tsu nsasan n Ka̱shile,
\q2 afada a̱ nu i ta̱ tsu uga̱vi u mala magbayin,
\q2 Vuzavaguɗu a vu ɗa vi a̱ kula̱na̱ uma nu nnama dem.
\q1 
\v 7 Ka̱shile,
\q2 nu n yiɗa̱i a ku gisanku ugain wu ucigi u nu u na u tsu sabaꞋa ba?
\q2 Uma a̱ tsu ciya̱ ta̱ ubuta̱ u kusheɗeku a ɗaka vu evelyu a̱ nu.
\q1 
\v 8 A ci yaꞋan ta̱ ka̱ɗiva̱ n ka̱bunda̱i ki ilikulyaꞋa i na yi A̱Ꞌisa̱ a gbayin a̱ nu,
\q2 vu tsu neke le ta̱ mini moku soꞋo o kuɗolu ku kasingai ku nu.
\q1 
\v 9 Avu ɗa a̱shi a̱ mini a na e ci neke wuma,
\q2 n kutashi ku nu ku ɗa tsu ce ene kutashi.
\q1 
\v 10 LyaꞋa kelime n ucigi u nu u na u tsu sabaꞋa ba,
\q2 wa aza a na e yevei nu,
\q2 lyaꞋa kelime n kasingai ka̱ nu wa aza a na i n kamayun a̱ɗu.
\q1 
\v 11 Ka̱ta̱ vu ka̱sukpa̱ ene aza a ugbamukaci a dasa mu ba,
\q2 ko kpamu vu ka̱sukpa̱ ekiye aza a gbani-gbani o loko mu ba.
\q1 
\v 12 La̱na̱ ubuta̱ u na aza a gbani-gbani a̱ yikpa̱i,
\q2 ta ɗe a vaki a fuɗa a̱ ɗa̱nga̱ ba.
\c 37
\s1 Ukocishi wa aza a gbani-gbani n aza a usuɓi
\d Vishipa vu Dawuda.
\q1 
\v 1 Ka̱ta̱ vu na̱mgba̱ ka̱tsuma̱ adama a uma a gbani-gbani ba,
\q2 ko kpamu vu yaꞋan cisheꞋe tsa aza a na i a kuyaꞋan ka gbani-gbani ba.
\q1 
\v 2 Adama a na, megeshe kenu i ta̱ a̱ kupuwa̱nka̱ tsu mita̱ ma na me ɗekpei
\q2 i ta̱ a ku lumba tsu mita̱ ma savu,
\q1 
\v 3 Neke ka̱ɗu u Vuzavaguɗu,
\q2 ka̱ta̱ vu yaꞋan kasingai,
\q2 ka̱ta̱ vu da̱sa̱ngu a iɗika ya, vu ciya̱ ma̱ta̱na̱.
\q1 
\v 4 La̱nsa̱ ma̱za̱nga̱ u Vuzavaguɗu,
\q2 a̱yi tana wi ta̱ e kuneke wu i na ka̱ɗu ka̱ nu ka cigai.
\q1 
\v 5 Neke ka̱ci ka̱ nu u Vuzavaguɗu,
\q2 vu neke ka̱ɗu ka̱ nu wa̱ a̱ ni,
\q2 wi ta̱ tana a̱ kuɓa̱nka̱ wu.
\q1 
\v 6 Wi ta̱ a kuzuwa kasingai ka̱ nu ka tasa tsu kutashi,
\q2 usuɓi u nu kpamu wa akana tsu kanna a kaci.
\q1 
\v 7 Shamgba shiriri u Vuzavaguɗu,
\q2 ka̱na̱ ka̱ɗu ka̱ nu vu vana yi,
\q1 ka̱ta̱ vu na̱mgba̱ ka̱tsuma̱,
\q2 adama a ulyaꞋi u kelime u vuza ba,
\q1 ko u vuza vu ulyaꞋi,
\q2 a̱ ka̱tsuma̱ ka̱ a ubuta̱ wo ofoɓuso a ka gbani-gbani ka̱ ni ba.
\q1 
\v 8 Ka̱ta̱ vu yaꞋan wupa, ko vu na̱mgba̱ ka̱ɗu ba.
\q2 ka̱ta̱ vu na̱mgba̱ ka̱tsuma̱ ba,
\q1 adama a na, nannai va u tsu tuka̱ n koyoku ba,
\q2 sai ka gbani-gbani.
\q1 
\v 9 Aza a na a zuwai a̱ɗu u Vuzavaguɗu,
\q2 i ta̱ a kuyaꞋan ida̱shi i le m ma̱ta̱na̱ a iɗika ya,
\q1 ama i ta̱ o kuloko aza a gbani-gbani,
\q1 
\v 10 M megeshe kenu, uma a gbani-gbani i ta̱ a̱ kupuwa̱nka̱,
\q2 vi ta̱ a̱ kula̱nsa̱ le, ama vi a̱ ku ciya̱ le ba.
\q1 
\v 11 Ama aza a na a ɗikai ka̱ci ke le ili ba, i ta̱ a kulyaꞋa uka̱ni wi iɗika ya,
\q2 a pana uyoꞋo u ma̱ta̱na̱ mayin.
\q1 
\v 12 Vuma vu gbani-gbani u tsu foɓusoko ta̱ vuma vu usuɓi kawuya,
\q2 ka̱ta̱ u ka̱na̱ ku lungana yi adama a tsurala,
\q1 
\v 13 ama Vuzavaguɗu u tsu zoꞋoso ta̱ vuza vu gbani-gbani,
\q2 adama a na u yeve ta̱ makyan ma na a ku una yi, mi ta̱ lo a̱ kuta̱wa̱.
\q1 
\v 14 Aza a gbani-gbani a tsu tala ta̱ otokobi ele,
\q2 o rono ta̱ utan u le,
\q2 adama a na a una aza a unambi,
\q2 una aza a usuɓi.
\q1 
\v 15 ama otokobi ele i ta̱ a ku una le,
\q2 i ta̱ kpamu o koɗoso utan u le.
\q1 
\v 16 Ili i kenu i na vuza vu usuɓi wi n i ɗa,
\q2 i laꞋa ta̱ uciyi u vuma vu gbani-gbani.
\q1 
\v 17 Adama a na Vuzavaguɗu wi ta̱ o kukoɗo utsura u vuza vu gbani-gbani,
\q2 ama u tsu ere ta̱ vuza vu usuɓi.
\q1 
\v 18 Vuzavaguɗu u tsu la̱na̱ ta̱ aza a na i o kutono yi,
\q2 iɗika ya yi ta̱ okpo ili yi uka̱ni i le ko wannai,
\q1 
\v 19 I a kupana wono a makyan ma atakaci ba.
\q2 i ta̱ a̱ kuciya̱ ilikulyaꞋa ba̱ri a ayin a kambulu.
\q1 
\v 20 Ama uma gbani-gbani i ta̱ a̱ ku kuwa̱.
\q2 aza na a iwain Vuzavaguɗu i ta̱ a̱ kupuwa̱nka̱ tsu a̱pa̱lu,
\q2 i ta̱ kupuwa̱nka̱ an ka̱nga̱ a laza.
\q1 
\v 21 Vuza vu gbani-gbani u ci lyaꞋa ta̱ kutan ka̱ta̱ u iwan ku tsupa,
\q2 ama vuza vu usuɓi vuza kasingai ɗa,
\q2 vuza na u ci neke n ka̱ɗu ba̱ri.
\q1 
\v 22 Aza a na Vuzavaguɗu u zuwakai una̱singai,
\q2 i ta̱ a̱ kuciya̱ ida̱shi i ma̱ta̱na̱ a iɗika ya,
\q2 ama aza a na u yaꞋankai una̱wuya i ta̱ o kuloko le.
\q1 
\v 23 Vuzavaguɗu u tsu tono ta̱ n vuma,
\q2 a uye u na u gaꞋin u tono,
\q2 u tsu pana ta̱ uyoꞋo u kuyongo ku ni,
\q1 
\v 24 ko u ta̱ɗa̱tsa̱ baci, wi a̱ kuyikpa̱ a iɗika ba,
\q2 adama a na Vuzavaguɗu u tsu ka̱na̱ yi ta̱ n kukiye ku ni,
\q1 
\v 25 Ali ayin a na mi ishi maku, ama gogo na n kutsa ta̱,
\q2 n saꞋawa kene Vuzavaguɗu u vakangi vuza vu usuɓi ba,
\q2 ko ene muku n ni ufolu wi ilikulya ba.
\q1 
\v 26 Makyan dem u tsu neke ta̱ ili ba̱ri,
\q2 u tsu neke ta̱ okopu wa aza o yoku,
\q2 muku n ni una̱singai u ɗa,
\q1 
\v 27 Ka̱sukpa̱i ka gbani-gbani i yaꞋan kasingai.
\q2 yi ta̱ o kuyongo a iɗika ya ko wannai.
\q1 
\v 28 Adama a na Vuzavaguɗu u ciga ta̱ ili i na yi derere,
\q2 u tsu ka̱sukpa̱ uma a usuɓi a̱ ni ba.
\q1 e kere le makyan dem,
\q2 ama kumaci ku uma a gbani-gbani i ta̱ o kuloko le.
\q1 
\v 29 Aza a usuɓi i ta̱ a kulyaꞋa uka̱ni wi iɗika ya,
\q2 ka̱ ta̱ a̱ da̱sa̱ngu punu i ɗa ko wannai.
\q1 
\v 30 Una̱ u vuza vu usuɓi u tsu dansa ta̱ kakuna ke kuyeve,
\q2 kelentsu ka̱ ni ka tsu dansa ta̱ ili i na yi derere.
\q1 
\v 31 Wila̱ u Ka̱shile ka̱ ni wi ta̱ a̱ ka̱ɗu ka̱ ni,
\q2 u tsu ka̱sukpa̱ u ɗa ba ko wannai.
\q1 
\v 32 Aza a gbani-gbani a̱ tsu puta̱ ta̱ aza a usuɓi,
\q2 a̱ tsu la̱nsa̱ le ta̱ adama a na a una le.
\q1 
\v 33 Ama Vuzavaguɗu wi a̱ ku ka̱sukpa̱ le ekiye i irala i le ba,
\q2 ko kpamu u ka̱sukpa̱ a yaꞋanka le afada a gbani-gbani ba.
\q1 
\v 34 Neke ka̱ɗu u Vuzavaguɗu,
\q2 ka̱ ta̱ kpamu vu yongo a uye u ni,
\q2 a̱yi tana wi ta̱ a kuzuwa wu vu ciya̱ uka̱ni wi iɗika ya,
\q2 vi ta̱ e kene o kuloko uma a gbani-gbani.
\q1 
\v 35 Me ene ta̱ vuma gbani-gbani ko asuvayali,
\q2 u laꞋa ta̱ yaba dem ugaɗi,
\q2 a na nɗanga n Lebano.
\q1 
\v 36 Ama makyan kenu,
\q2 a na m bonoi, me ene yi ba.
\q2 n la̱nsa̱ ni, ama me ene yi ba.
\q1 
\v 37 Indana uma a̱ ma̱riki, vu la̱na̱ uma a usuɓi,
\q2 vuza vu ma̱ta̱na̱ u tsu ciya̱ ta̱ ntsukaya.
\q1 
\v 38 Ama i ta̱ a ku una aza a unushi gbende,
\q2 ka̱ta̱ a̱ pura̱ngu ntsukaya n le.
\q1 
\v 39 Vuzavaguɗu u tsu isa ta̱ aza a usuɓi,
\q2 a̱yi ɗa ubuta̱ u kusheɗeku u le a ayin atakaci.
\q1 
\v 40 Vuzavaguɗu u tsu ɓa̱nka̱ le ta̱ ka̱ta̱ kpamu wu isa le,
\q2 u tsu isa le ta̱ ekiye aza a gbani-gbani,
\q2 adama a na a̱ la̱nsa̱ ta̱ ubuta̱ u ku sheɗeku wa̱ a̱ ni.
\c 38
\s1 Avasa a vuza va atakaci
\d Vishipa vu Dawuda. Adama a ku ciɓasa.
\q1 
\v 1 Vuzavaguɗu, ka̱ta̱ vu ɓarangu mu a̱ ka̱tsuma̱ ka wupa u nu ba,
\q2 ka̱ta̱ vu takacika mu n asuvu a usuɗukpi a̱ nu ba,
\q1 
\v 2 Vu yaꞋanka mu ta̱ usa̱n n ayaꞋa a̱ nu,
\q2 ɗa feu vu lapai mu ali a iɗika.
\q1 
\v 3 Adama a wupa u nu,
\q2 ikyamba i va̱ yi ta̱ a̱ mɓa̱la̱.
\q1 ikyamba i va̱ ra̱ka̱ i ka̱ na̱ ta̱ mɓa̱la̱,
\q2 adama a unushi u va̱.
\q1 
\v 4 Unushi u va̱ u laꞋa ta̱ utsura u va̱,
\q2 an nu ucanuku wa̱ a̱miki, u na u laꞋi utsura u va̱.
\q1 
\v 5 Adama a tsulau tsu va̱ n yaꞋin unushi,
\q2 untsu a̱ va̱ a shamai ali a̱ ku uta̱ ushami,
\q1 
\v 6 Mɓa̱la̱ n va̱ n yaꞋan ta̱ a̱bunda̱i,
\q2 ali m poloi mu, kanna ka̱ɓula̱ mpa a̱ ma̱shi.
\q1 
\v 7 Ma̱vuna̱ ma̱ ka̱na̱ mu ta̱ wuya-wuya,
\q2 mi ta̱ ka̱ mɓa̱la̱ ka̱u.
\q1 
\v 8 Mo oꞋwoi ka̱u,
\q2 ali mo okpoi luɓa̱,
\q2 ka̱ɗu ka̱ va̱ ka̱ na̱mgba̱i ka̱u,
\q2 ɗa n ka̱na̱i yura̱ adama a usuɗukpi.
\q1 
\v 9 Vuzavaguɗu, vu yeve ta̱ ili i na mi a kuciga.
\q2 vi ta̱ kpamu a kupana yura̱ i va̱ ra̱ka̱.
\q1 
\v 10 Ka̱ɗu ka̱ va̱ ki ta̱ a̱ ku muɗa̱sa̱,
\q2 utsura u va̱ u kotsoi,
\q2 ɗa a̱shi a̱ va̱ a̱ ka̱na̱i kene yimbi-yimbi.
\q1 
\v 11 A̱ja̱Ꞌa̱ a̱ va̱ n aza a na ci a̱ ida̱shi ɗeɗevu,
\q2 o doku a yawa ɗevu nu mpa ba,
\q2 adama a̱ untsu a̱ va̱,
\q2 ali muku n va̱ dem n sumai mu.
\q1 
\v 12 Aza a na a cigai ku una mu,
\q2 azuki mu maza.
\q2 aza a na kpamu a cigai o doro mu,
\q2 e kusheshe a yaꞋanka mu koli,
\q2 kanna ka̱ɓula̱ o kufoɓuso ka gbani-gbani adama a̱ va̱.
\q1 
\v 13 Mi ta̱ tsu kagulani n tsu pana ba,
\q2 mi ta̱ tsu kebebe n tsu fuɗa n dansa ba.
\q1 
\v 14 Mo okpoi tsu kagulani n tsu pana ba,
\q2 adama a na n tsu ushuku n kadanshi ba.
\q1 
\v 15 Vuzavaguɗu, n zuwa ta̱ ka̱ɗu wa̱ a̱ nu,
\q2 Vuzavaguɗu Ka̱shile ka̱ va̱, avu ɗa va̱ ku ushuku mu.
\q1 
\v 16 <<Ka̱ta̱ vu ka̱sukpa̱ irala i va̱,
\q2 a yaꞋan ma̱za̱nga̱ adama atakaci a̱ va̱ ba,
\q1 ka̱ta̱ vu ka̱sukpa̱ le a lapa ma̱ka̱nga̱,
\q2 adama a uyikpi u va̱ ba.>>
\q1 
\v 17 Mi ta̱ ɗevu n kuyikpa̱,
\q2 mi ta̱ a̱ ka̱tsuma̱ ka atakaci ayin dem.
\q1 
\v 18 N shika̱ ta̱ u nushi u va̱.
\q2 unushi u va̱ u zuwa mu ta̱ atakaci.
\q1 
\v 19 Aza a tsurala nu mpa ko unushi i ta̱ n utsura,
\q2 aza a na a iwain mu ko unushi i ta̱ lo n a̱bunda̱i.
\q1 
\v 20 Aza a na a tsu tsupa kasingai n ka gbani-gbani,
\q2 i ta̱ a tsurala nu mpa,
\q2 adama a na n ciga ta̱ kuyaꞋan kasingai.
\q1 
\v 21 Vuzavaguɗu, ka̱ta̱ vu ka̱sukpa̱ mu ba,
\q2 Ka̱shile ka̱ va̱, ka̱ta̱ vu yaꞋan daꞋin nu mpa ba.
\q1 
\v 22 YaꞋan gogoꞋo vu ɓa̱nka̱ mu,
\q2 Vuzavaguɗu kishi ka̱ va̱.
\c 39
\s1 Ma̱shi ma asuvayali
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n ka̱la̱ka̱tsu ka Jedutun. Vishipa vu Dawuda.
\q1 
\v 1 Ɗa n danai, <<Mi ta̱ a ku zuwaka n ili i na mi a kuyaꞋan,
\q2 adama a na ka̱ta̱ kelentsu ka̱ va̱,
\q2 ka yaꞋan unushi ba.
\q1 mi e kukeɓece ukuna ba,
\q2 a makyan ma na uma a gbani-gbani i ɗevu nu mpa.>>
\q1 
\v 2 M paɗai bini, n dansa ukuna ba.
\q2 ko a ili i na yi i singai,
\q1 ama n nannai dem atakaci a̱ va̱ o kudokusu.
\q2 
\v 3 Ka̱ɗu ka̱ va̱ ka shanai n atakaci.
\q1 tsu ka̱bunda̱i ka aciɓa a̱ va̱, ta atakaci a̱ va̱ okpoi nannai,
\q2 mayun ɗa n yaꞋan kadanshi.
\q1 
\v 4 <<Vuzavaguɗu, ayin a yain a ɗai n kuyongo aduniyan?
\q2 Wanai ɗai n kukuwa̱?
\q2 Yotsongu mu n yeve tsu na ayin a̱ va̱ i a kulaza gogoꞋo lo.
\q1 
\v 5 La̱na̱, vu jebe ta̱ ka̱bunda̱i ka ayin a̱ va̱,
\q2 ka̱bunda̱i ayin a̱ va̱ wa̱ a̱ nu,
\q2 adanshi ili i yoku i ɗa ba,
\q1 mayun wuma u vuza dem u laꞋa ayinviki ba.\qs Kuvuka\qs*
\q2 
\v 6 Wuma u vuma dem wi ta̱ a ku vadalukpasa tsu kulu,
\q2 kubana n kubono ku ni dem gbani ɗa.
\q2 u tsu ɓolongu ta̱ uciyi,
\q2 ama u tsu yeve ko yayi u kulyaꞋa uyoꞋo wu uɗa ba.
\q1 
\v 7 Vuzavaguɗu, gogo na a̱ yiɗa̱i n kuzuwa ka̱ɗu ka̱ va̱?
\q2 Wa̱ a̱ nu u ɗa n zuwai ka̱ɗu ka̱ va̱.
\q1 
\v 8 Wawa mu a̱ ka̱tsuma̱ ka unushi u va̱,
\q2 Ka̱ta̱ vu ka̱sukpa̱ alau o zoꞋoso mu ba̱.
\q1 
\v 9 Mi ta̱ a kupaɗa bini. mi a kudansa ukuna ba,
\q2 adama a na vu zuwa mu ta̱ n takacikai tsu nampa.
\q1 
\v 10 Ka̱ta̱ vu doku vu takacika mu ba.
\q2 n yaꞋan ta̱ ɗevu n ku kuwa̱,
\q2 adama a ulapi u na vi a kuyaꞋanka mu.
\q1 
\v 11 Vu tsu ɓarangu ta̱,
\q2 ka̱ ta̱ kpamu vu takacika vuma adama a unushi u ni,
\q1 tsu kayan,
\q2 vu tsu la̱nga̱sa̱ ta̱ ili i na vuma u laꞋi n kuciga,
\q2 mayun, vuza vu wuma dem wi ta̱ tsu wunla̱i u na u tsu laza.\qs Kuvuka\qs*
\q1 
\v 12 Vuzavaguɗu, pana avasa a̱ va̱,
\q2 vu pana ma̱shi ma̱ va̱ kpamu,
\q2 ura ma̱shi ma̱ va̱,
\q2 adama a na mi ta̱ koɓolo n avu,
\q2 tsu komoci ka na ka kulaza,
\q1 mpa komoci kaꞋa,
\q2 tsu na ikaya i va̱ yi ishi cau.
\q1 
\v 13 Ka̱sukpa̱ mu ko ka̱ɗu ka̱ va̱ ki ta̱ a kuvaku,
\q2 kafu n laza, n ka̱sukpa̱ ubuta̱ u nampa.>>
\c 40
\s1 Vishipa vu kucikpa
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda.
\q1 
\v 1 N vana ta̱ uɓa̱nki u Vuzavaguɗu,
\q2 u zuwakai mu atsuvu a̱ ni,
\q2 ɗa u panai ma̱shi ma̱ va̱.
\q1 
\v 2 Wu utuka̱i mu e kpenle ku kederi,
\q2 a̱ ciꞋin n kolyoꞋo,
\q2 u kiyangi ene a̱ va̱ a gaɗi vu katali,
\q2 u takpakai mu wovon.
\q1 
\v 3 U zuwai n cananai vishipa vu savu a̱ una̱ u va̱,
\q2 vishipa vu kucikpa u Ka̱shile ka̱ tsu.
\q1 Uma n a̱bunda̱i ene baci nannai, i ta̱ kupana wovon,
\q2 ka̱ta̱ e neke a̱ɗu e le u Vuzavaguɗu.
\q1 
\v 4 Vuza vu una̱singai ɗa,
\q2 vuza na u zuwai ka̱ɗu u Vuzavaguɗu,
\q1 vuza na u tsu tono a̱ma̱li ba,
\q2 ko u gbaɓa kaci n aza a na a̱ tsu tono a̱ma̱li ba.
\q1 
\v 5 Vu yaꞋanka tsu ta̱ ili n a̱bunda̱i,
\q2 Vuzavaguɗu Ka̱shile ka̱ va̱,
\q2 vuza wi lo tsu nu ba,
\q2 n dana baci n dansa ili i mereve i nu ra̱ka̱,
\q2 i laꞋa ta̱ utsura u kudansa.
\q1 
\v 6 Vu ciga kuneꞋe n alyuka ba,
\q2 vu ciga tana e neke wu alyuka o kusongu,
\q1 a nnama a gaɗi vu katalikalyuka ba,
\q1 ko kuneꞋe adama a kutakpa unushi ba
\q2 kucikpa ɗa vu nekei mu atsuvu a na n ku panaka wu.
\q1 
\v 7 Ɗa n danai,<<Mpa ɗa na, kadanshi ka̱ nu adama a̱ va̱,
\q2 ki ta̱ a katagarda ka̱ wila̱.
\q1 
\v 8 Ka̱shile n ciga ta̱ kutono ku sheshe ku nu ka̱u,
\q2 n zuwa ta̱ wila̱ u nu a̱ ka̱ɗu ka̱ va̱.>>
\q1 
\v 9 Vuzavaguɗu, o koɓolo ka uma a usuɓi a̱ nu ra̱ka̱,
\q2 n dansa ta̱ ukuna wu usuɓi u nu.
\q1 Vu yeve ta̱,
\q2 mi a̱ kukpa̱ɗa̱ kudansa ukuna u nu ba.
\q1 
\v 10 M ɓa̱na̱ arabali a wishi a̱ nu,
\q2 adama a̱ ka̱ci ka̱ va̱ koci ba.
\q1 makyan dem n tsu dansa ta̱,
\q2 kamayun ka̱ nu n wishi u nu,
\q1 o koɓolo ka uma usuɓi a̱ nu dem,
\q2 n tsu paɗa bini ba
\q1 ama n tsu dansa ta̱ kamayun ka̱ nu,
\q2 n ucigi u nu u na u tsu sabaꞋa ba.
\q1 
\v 11 Vuzavaguɗu,
\q2 ka̱ta̱ vu ka̱sukpa̱ kupana asuvayali a̱ va̱ ba.
\q1 ucigi u nu u na u tsu sabaꞋa ba n kamayun ka̱ nu,
\q2 i ta̱ e ku ere mu makyan dem.
\q1 
\v 12 Adama a na atakaci a̱ ka̱ra̱Ꞌa̱ mu ta̱,
\q2 a laꞋa ta̱ ku kece.
\q1 unushi u va̱ u laꞋa ta̱ utsura u va̱,
\q2 ali n doku n fuɗa me ene ubuta̱ ba.
\q1 u laꞋa ta̱ ka̱nji ka kaci ka̱ va̱ a̱bunda̱i,
\q2 ali n takpai ka̱ɗu.
\q1 
\v 13 Vuzavaguɗu, wawa mu,
\q2 yaꞋan gogoꞋo vu ɓa̱nka̱ mu.
\q1 
\v 14 YaꞋan aza a na a cigai ku una mu,
\q2 a yaꞋan wono a̱ ripula̱.
\q1 yaꞋan kpamu aza a na i a̱ ma̱za̱nga̱ adama atakaci a̱ va̱,
\q2 okpo n wono.
\q1 
\v 15 YaꞋan aza a na i a kuyaꞋanka mu ma̱ka̱n,
\q2 <<A namba ili i kudansa adama o wono.>>
\q1 
\v 16 YaꞋan aza a na a̱ ta̱wa̱i wa̱ a̱ nu ra̱ka̱,
\q2 a yaꞋan ma̱za̱nga̱, babu una̱mgbuka̱tsuma̱,
\q1 yaꞋan aza a na a cigai wishi u nu,
\q2 makyan dem a dana, <<Vuzavaguɗu vuzagbayin ɗa.>>
\q1 
\v 17 Neke mu utsura, mi n ka̱ɓa̱nki ba,
\q2 Vuzavaguɗu ta̱wa̱ wa̱ a̱ va̱ gogoꞋo,
\q1 avu ɗa kishi ka̱ va̱ n ka̱ɓa̱nki ka̱ va̱,
\q2 Vuzavaguɗu vu va̱, ka̱ta̱ vu geshe ba.
\c 41
\s1 Avasa a̱ kula̱nsa̱ upotsokpi
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda.
\q1 
\v 1 Vuza vu ma̱za̱nga̱ ɗa,
\q2 vuza na u tsu la̱na̱ aza a unambi,
\q2 Vuzavaguɗu wi ta̱ a ku wawa yi,
\q2 a makyan ma atakaci.
\q1 
\v 2 Vuzavaguɗu wi ta̱ e ku ere yi, u foɓo wuma u ni.
\q2 Vuzavaguɗu wi ta̱ a kuzuwa yi u pana uyoꞋo a iɗika ya.
\q2 wi a̱ ku ka̱sukpa̱ yi ekiye a irala i ni ba.
\q1 
\v 3 Vuzavaguɗu wi ta̱ a̱ kuɓa̱nka̱ yi a ayin a na wi a̱ mɓa̱la̱.
\q2 wi ta̱ o ku bonoko yi n ma̱ta̱na̱ mi ikyamba ma̱ ni mayin.
\q1 
\v 4 N danai, <<Vuzavaguɗu, n yaꞋanka wu ta̱ unushi.
\q2 pana asuvayali a̱ va̱ ka̱ ta̱ vu potsokpo mu.>>
\q1 
\v 5 Irala i va̱ yi ta̱ a kuyaꞋansa
\q2 kadanshi ka gbani-gbani adama a̱ va̱,
\q1 A kudana, <<Wannai ɗai u ku kuwa̱,
\q2 a cinukpa n a̱yi?>>
\q1 
\v 6 Aza a na a̱ tsu ta̱wa̱ n a̱ kya̱sa̱i mu,
\q2 n ka̱ɗu kete kaꞋa a̱ tsu ta̱wa̱ ba,
\q2 o tsu ɓolongu su ta̱ arabali aꞋuwa adama a̱ va̱,
\q2 ka̱ta̱ a bana a̱ ka̱na̱ kudansa kaꞋa a̱ ubuta̱ dem.
\q1 
\v 7 Irala i va̱ ra̱ka̱ i ta̱ a̱ kuyun n otoku ele adama a̱ va̱,
\q2 e kusheshe ku le n laꞋa ta̱ yaba dem ka gbani-gbani.
\q1 
\v 8 A kudansa, <<Mɓa̱la̱ n ka̱na̱ yi ta̱ gbani-gbani,
\q2 wi a kufuɗa ku ɗa̱nga̱ a̱ ubuta̱ mɓa̱la̱ n ni ba.>>
\q1 
\v 9 Ali ka̱ja̱Ꞌa̱ ke ɗevu ka̱ va̱, vuza na n laꞋi kuneke ka̱ɗu ka̱ va̱,
\q2 vuza na tsu ci lyaꞋa koɓolo, u bonoi a tsurala nu mpa.
\q1 
\v 10 Vuzavaguɗu, pana asuvayali a̱ va̱,
\q2 vu bonoko mu m ma̱ta̱na̱ mi ikyamba ma̱ va̱,
\q2 adama a na n tsupa ili i na irala i va̱ i yaꞋankai mu.
\q1 
\v 11 Mi ta̱ e kuyeve vi ta̱ a kupana uyoꞋo u va̱,
\q2 adama a na i a kufuɗa kulyaꞋa kelime ka̱ va̱ ba.
\q1 
\v 12 Vi ta̱ a̱ kuɓa̱nka̱ mu adama a na mi ta̱ a kuyaꞋan ili i na yi derere,
\q2 Vi ta̱ a ku zuwa mu n yongo e kelime ka̱ nu ko wannai.
\q1 
\v 13 YaꞋan tsu cikpa Vuzavaguɗu, Ka̱shile ka aza Israila,
\q2 cikpa ni gogo na a kubana ko wannai Tanannai, Tanannai.
\c 42
\ms1 Katagarda ke ire
\r (Ishp 42--72)
\s1 Ma̱shi ma aza a na i a ugbashi
\d Kadanshi a kubana u vuza vu kelime vi ishipa: VicuꞋu vu tsuwaꞋi tsu muku n Kora,
\q1 
\v 1 Tsu na mereꞋe mi a mali ma̱ mini mo kuɗolu,
\q2 ta feu wuma u va̱ wi a mali ma̱ nu nannai, Ka̱shile.
\q1 
\v 2 Mi ta̱ a kakuli ka̱ nu,
\q2 Ka̱shile, Ka̱shile ka wuma.
\q1 Wannai ɗai n kubana e kelime ka̱ nu n cikpa wu?
\q1 
\v 3 Kanna n kayin dem mi ta̱ a̱ ma̱shi,
\q2 kujilya ku ɗa koci ili kulyaꞋa i va̱,
\q1 makyan dem irala i va̱ e ku ece mu,
\q2 <<Te ɗai Ka̱shile ka̱ nu ka?>>
\q1 
\v 4 Ka̱ɗu ka̱ va̱ ka̱ tsu na̱mgba̱ ta̱,
\q2 n ciɓa baci n ili i na i lazai ɗe,
\q1 a makyan ma na n tsu bana koɓolo n uma A̱Ꞌisa̱ a gbayin,
\q2 mi o kutono n e le ugeri.
\q1 koɓolo ka uma aza a̱ ma̱za̱nga̱, a ku canana i ishipa,
\q2 a̱ kuɗa̱ngusa̱ a̱la̱ka̱tsu a kucikpa Ka̱shile.
\q1 
\v 5 Yiɗa̱i i zuwai mi una̱mgbi ka̱tsuma̱ tsu nampa?
\q2 Yiɗa̱i i zuwai mi a atakaci nannai?
\q1 Mi ta̱ a kuzuwa ka̱ɗu ka̱ va̱ u Ka̱shile,
\q2 mi ta̱ o kudoku kucikpa yi,
\q2 kishi ka̱ va̱ n Ka̱shile ka̱ va̱.
\q1 
\v 6 N na̱mgba̱ ta̱ ka̱tsuma̱ ka̱u,
\q1 adama nannai mi ta̱ a kuciɓa n kasingai ka̱ nu,
\q1 a uɓon u Urdu, n kusan kugbayi Hamon,
\q2 n kusan ku Miza.
\q1 
\v 7 Atakaci a̱ va̱ i ta̱ tsu mini ma̱ uga̱vi,
\q2 mini ma o kuɓolongu adama a na ma̱ pura̱ mu,
\q1 aɓau ra̱ka̱,
\q2 a kulyaꞋa utsura u va̱.
\q1 
\v 8 Vuzavaguɗu u yotsongu ta̱ ucigi u ni u na u tsu sabaꞋa ba kanna lakam,
\q2 mpa feu n canana ishipa i kucikpa yi kayin dem,
\q2 n yaꞋan avasa u Ka̱shile, vuza na u nekei mu wuma.
\q1 
\v 9 N danai Ka̱shile, ubuta̱ u kusheɗeku u va̱,
\q2 <<Yiɗa̱i i zuwai vu cinukpai nu mpa?
\q1 Yiɗa̱i i zuwai n kulyaꞋa kelime n una̱mgbuka̱tsuma̱?
\q2 Adama ka gbani-gbani ka irala i va̱?>>
\q1 
\v 10 Kadanshi ki irala i va̱, ka sapa mu tsu kotokobi a etele a̱ va̱,
\q2 a makyan ma na i a kudana mu,
\q2 <<Teɗei Ka̱shile ka̱ nu ka?>>
\q1 
\v 11 Yiɗa̱i i zuwai mi una̱mgbi ka̱tsuma̱ tsu nampa?
\q2 Yiɗa̱i i zuwai mi a atakaci nannai?
\q1 Mi ta̱ a kuzuwa ka̱ɗu ka̱ va̱ u Ka̱shile,
\q2 mi ta̱ o kudoku kucikpa yi,
\q2 kishi ka̱ va̱ n Ka̱shile ka̱ va̱.
\c 43
\s1 Avasa a vuza a bankai ugbashi
\d Vishipa vu Dawuda.
\q1 
\v 1 Ka̱shile, yotsongu unambi wu unushi u va̱,
\q2 vu isaka mu ili i na yi i va̱,
\q1 wa aza a na a̱ kpa̱ɗa̱i kupana wovon u nu,
\q2 isa mu a ekiye aza o modoruko,
\q2 n aza a gbani-gbani
\q1 
\v 2 Ka̱shile avu ɗa vi a ku inda mu.
\q2 yiɗa̱i i zuwai ɗa vu variki mu?
\q1 Yiɗa̱i i zuwai mi o kusoꞋo atakaci,
\q2 adama a ka gbani-gbani ka irala i va̱?
\q1 
\v 3 Suku kutashi ku nu n kamayun ka̱ nu,
\q2 o tono nu mpa.
\q1 vu zuwa o bono nu mpa a ka kaginda ka ciɗa ka̱ nu,
\q2 o bono nu mpa a̱ ubuta̱ wi ida̱shi i nu.
\q1 
\v 4 Ka̱ta̱ m bana a katalikalyuka ka̱ nu Ka̱shile,
\q2 Ka̱shile, wa̱ a̱ nu ɗa, ugiti u ma̱za̱nga̱ u va̱.
\q1 mi ta̱ a cikpa wu n umolu,
\q2 Ka̱shile, Ka̱shile ka̱ va̱.
\q1 
\v 5 Yiɗa̱i i zuwai mi una̱mgbi ka̱tsuma̱ tsu nampa?
\q2 Yiɗa̱i i zuwai mi a atakaci nannai?
\q1 Mi ta̱ a kuzuwa ka̱ɗu ka̱ va̱ u Ka̱shile,
\q2 mi ta̱ o kudoku kucikpa yi,
\q2 kishi ka̱ va̱ n Ka̱shile ka̱ va̱.
\c 44
\s1 Avasa a̱ kula̱nsa̱ wishi
\d Kadanshi a kubana u vuza vu kelime vi ishipa: VicuꞋu vu tsuwaꞋi tsu muku n Kora.
\q1 
\v 1 Ka̱shile, tsu pana ta̱ na atsuvu a̱ tsu,
\q2 ikaya i tsu i dana tsu ta̱,
\q1 ili i gbagbaꞋin i na vu yaꞋin a makyan me le,
\q2 a ayin a cau.
\q1 
\v 2 Tsu na avu n ka̱ci ka̱ nu vu lokoi aza o kutono a̱ma̱li,
\q2 ɗa vu zuwai uma a̱ nu a iɗika i le.
\q1 tsu na vu lokoi uduniyan u na u buwai,
\q2 ama ɗa vu zuwai uma a̱ nu o yongo ba̱ri.
\q1 
\v 3 N otokobi e le a ɗa a lyaꞋi iɗika ya ba,
\q2 n utsura u le u ɗa a lyaꞋi iɗika ya ba,
\q1 ama n utsura u nu u ɗa,
\q2 tsu na vu yotsongi le vi ta̱ koɓolo n ele,
\q1 vi o kuyotsongu le vu ciga le ta̱.
\q1 
\v 4 Avu ɗa mogono ma̱ va̱ n Ka̱shile ka̱ va̱,
\q2 vu zuwai uma a Yakubu a̱ ciya̱i ulyaꞋi.
\q1 
\v 5 N utsura u nu u ɗa tsu unai irala i tsu.
\q2 N kula ku nu ku ɗa tsu dasasai irala i tsu.
\q1 
\v 6 N zuwa ka̱ɗu ka̱ va̱ a utan u va̱ ba,
\q2 kotokobi ka̱ va̱ ki a ku isa mu ba.
\q1 
\v 7 Ama vu isa tsu ta̱ ekiye a irala i tsu,
\q2 vu lokoi aza a na a iwain tsu.
\q1 
\v 8 Ka̱shile, ci ta̱ a ku cikpa wu makyan dem,
\q2 ka̱ta̱ kpamu tsu cikpa kula ku nu ko wannai.\qs Kuvuka\qs*
\q1 
\v 9 Ama gogo na Ka̱shile vu vakangu tsu ta̱,
\q2 vu ka̱sukpa̱i o lokoi tsu,
\q2 vu doku vu uta̱ vu yaꞋan nwalu n osoji a̱ tsu ba.
\q1 
\v 10 Vu zuwai tsu sumai e kelime ka irala i tsu,
\q2 ɗa isai ili i na ci ni i ɗa yo okpoi i le.
\q1 
\v 11 Vu ka̱sukpa̱i a kiɗai tsu tsu nlala,
\q2 ɗa vu wacuwai tsu a̱ ka̱tsuma̱ ka iɗika i yoku.
\q1 
\v 12 Vu dengei uma a̱ nu,
\q2 n ikebe kenu,
\q2 vu ciya̱ kodokpotsu ka tsulaga tsa ba.
\q1 
\v 13 Aza a na ci ida̱shi ɗeɗevu o ku zoꞋoso tsu adama a̱ nu,
\q2 a kuyaꞋanka tsu ulami, o bonokoi tsu ili yi ugulani,
\q1 
\v 14 Vu zuwai tsu tsu okpoi ili ya agisana a̱ ka̱tsuma̱ ku uduniyan,
\q2 uduniyan a̱ kugba̱ɗa̱sa̱ ka̱ tsu aci,
\q2 n o goyoi tsu,
\q1 
\v 15 Makyan dem mi ta̱ a̱ ka̱tsuma̱ ko wono,
\q2 wono u kimba̱ mu ta̱ ra̱ka̱.
\q1 
\v 16 Adama aza a kadanshi ka gbani-gbani n ishikushi,
\q2 n adama a irala i va̱ aza a na a tsu ciga ku tsupa kutan.
\q1 
\v 17 Ili i nampa ya ra̱ka̱ i gita̱ ta̱ n a̱tsu,
\q2 ko a na wo okpoi tsu cinukpa n avu ba,
\q2 tsu koɗo kpamu uzuwakpani u na vu yaꞋin n a̱tsu ba.
\q1 
\v 18 Tsu yaꞋanka wu unambi wu usuɓi ba,
\q2 tsu ka̱sukpa̱ tana kutono kadanshi ka̱ nu ba.
\q1 
\v 19 N nannai dem vu kpa̱ɗa̱i kuɓa̱nka̱ tsu,
\q2 a nnama n kakamba n nanlo ma,
\q2 vu ka̱sukpa̱i tsu a̱ ka̱yimbi ka kpaɓam.
\q1 
\v 20 Ishi baci tsu ka̱sukpa̱ ta̱ kutono Ka̱shile ka̱ tsu,
\q2 ci yaꞋin avasa wa̱ a̱ma̱li,
\q1 
\v 21 mayun vi ta̱ e kuyeve,
\q2 adama a na vu yeve ta̱ kusheshe ku uma.
\q1 
\v 22 Ka̱shile, adama a̱ nu a ɗa i a ku una tsu makyan dem.
\q2 o bonokoi tsu a na nkyon n na a kukiɗa.
\q1 
\v 23 Ɗa̱nga̱! Vuzavaguɗu, yiɗa̱i ɗa vi alavu?
\q2 Ɗa̱nga̱! Ka̱ta̱ vu iwan tsu ko wannai ba.
\q1 
\v 24 Yiɗa̱i i zuwai ɗa vi o ku sokongu a̱shi a̱ nu?
\q2 Yiɗa̱i i zuwai ɗa vi a kucinukpa n atakaci a̱ tsu?
\q2 Adama a̱ yiɗa̱i vu zuwaka n tsu na i a kutakacika tsu ba.
\q1 
\v 25 Ci yikpa̱ ta̱, ɗa a tsugbai tsu a iɗika
\q2 a̱ ka̱sukpa̱i tsu ivaꞋin a̱ kubuta̱.
\q1 
\v 26 Ɗa̱nga̱, vu ɓa̱nka̱ tsu,
\q2 vu shiba̱ tsu,
\q2 adama a ucigi u nu una u tsu sabaꞋa ba.
\c 45
\s1 Vishipa vu kushiya ku yolo i mogono
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n ka̱la̱ka̱tsu ka <<Lili>> Vishipa vu muku n Kora. VicuꞋu vu tsuwaꞋi tsu vishipa vu yolo.
\q1 
\v 1 Ka̱ɗu ka̱ va̱ ka shana ta̱ n kadanshi ka singai.
\q2 Makyan ma na mi a̱ ku zuɓa̱ vishipa vu mogono.
\q2 Kelentsu ka̱ va̱ tsu kayakiɗani kaꞋa u kaɗani.
\q1 
\v 2 A̱ ka̱tsuma̱ ka uma ra̱ka̱ avu ɗa vu laꞋi n ugaꞋin,
\q2 avu vuza vu ufuɗi u kadanshi kasingai kaꞋa.
\q2 Ka̱shile ka zuwaka wu ta̱ una̱singai makyan dem.
\q1 
\v 3 Shiya kotokobi ka̱ nu,
\q2 mogono ma tsugbayin,
\q2 avu vuza vu utsura ɗa.
\q1 
\v 4 A̱ ka̱tsuma̱ ka tsugbayin tsu nu yaꞋan nwalu n kulyaꞋa kelime,
\q2 vu shamkpa kamayun n ku usuɓi.
\q2 adama a utsura u nu, vi ta̱ a kulyaꞋa kelime.
\q1 
\v 5 AyaꞋa a̱ nu i ta̱ lyalyaꞋan,
\q2 a tsu sapa ta̱ a̱ɗu a irala i nu,
\q2 uma a̱ ku yikpa̱sa̱ a ɗaka vu e ene a̱ nu.
\q1 
\v 6 Ka̱shile, kakuba ko tsugono ka̱ nu,
\q2 ki ta̱ o kuyongo ko wannai.
\q1 Vi ta̱ a kulyaꞋa tsugono tsu uma a̱ nu n usuɓi.
\q2 
\v 7 Vu tsu ciga ta̱ ili i na yi mejege,
\q2 vu ci iwan ta̱ ili i gbani-gbani.
\q1 Adama a nannai Ka̱shile, Ka̱shile ka̱ nu ka zagba wu ta̱,
\q2 ɗa u tsunki nu n maniꞋin me kerengu m ma̱za̱nga̱ ma̱ a̱bunda̱i ali vu laꞋa yaba dem.
\q2 
\v 8 Akashi a̱ nu a̱ ku uta̱ ma̱gula̱ni mi ili ma̱gula̱ni i Mariti n aloyes n kashiya kpamu,
\q2 tsuwaꞋi a iꞋuwa yi ngono,
\q1 a iꞋuwa i na a kalai n anga a kagiwa dem,
\q2 a kuzuwa wu ma̱za̱nga̱.
\q1 
\v 9 Muku mu nkere mo ngono,
\q2 i ta̱ punu a̱ ka̱tsuma̱ ka̱ a̱ma̱ci a na a̱ ciya̱i tsugbayin,
\q1 e kukiye ku usingai ku kakuba ko tsugono tsu nu,
\q2 egbere wi ta̱ kisani,
\q1 a uki na u canuku u singai,
\q2 wa azanariya u na u laꞋi nu ugaꞋin ra̱ka̱.
\q1 
\v 10 Pana ili i na n kudansa, avu vuka vu savu vu mogono,
\q2 vu cinukpa n uma a̱ nu n kumaci ku nu.
\q2 
\v 11 Adama a na avu vi ta̱ n ugaꞋin,
\q2 mogono mi ta̱ a kuciga wu,
\q2 a̱yi ɗa vali vu nu, ka̱ta̱ vu tono yi.
\q1 
\v 12 Uma a Taya i ta̱ a̱ kutuka̱ wu n kuneꞋe,
\q2 aza a̱ uciyi i ta̱ a̱ kuta̱wa̱ a̱ la̱nsa̱ mapasa ma singai wa̱ a̱ nu.
\q1 
\v 13 Vuka vu savu vu mogono,
\q2 wi ta̱ a ku uwa a kpaꞋa ku mogono,
\q2 yiɗa̱i a kugisanku n ugaꞋin u ni,
\q2 n tsugbere tsa azanariya tsu ɗa a caꞋi motogu ma̱ ni,
\q1 
\v 14 A bankai ni a̱ ubuta̱ u mogono u uki na aminya a singai,
\q2 a̱ja̱Ꞌa̱ ni nkere o kutono, a̱ tuka̱i le a̱ ubuta̱ u mogono.
\q1 
\v 15 N ma̱za̱nga̱ maꞋa a̱ ta̱wa̱i,
\q2 a uwai e kefeku ko mogono.
\q1 
\v 16 Vi ta̱ a kumatsa muku n ali n a̱bunda̱i,
\q2 aza a na a̱ ku ka̱na̱ tsugbayin ci ikaya i nu,
\q2 vi ta̱ a kuzuwa le a lyaꞋa tsugono tsa aduniyan dem.
\q1 
\v 17 Vishipa vu va̱ vi ta̱ a kuzuwa,
\q2 a̱ ka̱na̱ kuciɓasa n kula ku nu ko wannai,
\q2 ka̱ta̱ uma ra̱ka̱ a cikpa wu,
\q1 ali a tsukaya tsu na tsa̱ kuta̱wa̱.
\c 46
\s1 Ka̱shile kaꞋa ubuta̱ u kusheɗeku n katsura ka̱ tsu
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu muku n Kora.
\q1 
\v 1 Ka̱shile kaꞋa ubuta̱ u kusheɗeku u tsu n katsura ka̱ tsu,
\q2 a makyan dem ufoɓushi u ɗa wi u ɓa̱nka̱ tsu a ayin atakaci.
\q1 
\v 2 Adama nannai ci a kupana wovon ba,
\q2 ko ɗa baci aduniyan i a̱ kugba̱ɗa̱,
\q2 atali kpamu a̱ yikpa̱i a mala mu uga̱vi,
\q1 
\v 3 Ko a dana baci mala mi ta̱ a kuyaꞋan yura̱ ma̱ putsuwa̱i,
\q2 ko ɗa baci n sansan m gba̱ɗa̱i adama ugba̱ɗi u mala.\qs Kuvuka\qs*
\q1 
\v 4 Kuɗolu ki ta̱ lo ku na ku tsu tuka̱,
\q2 n ma̱za̱nga̱ a̱ likuci i Ka̱shila̱,
\q2 n ubuta̱ wa̱ A̱Ꞌisa̱ a ciɗa a MalaꞋimili.
\q1 
\v 5 Ka̱shile ki ta̱ a̱ ida̱shi punu a̱ likuci ya,
\q2 mayun, i tana a ku una likuci ya ba,
\q2 n kpasani Ka̱shile ki ta̱ a̱ kutuka̱ le n uɓa̱nki.
\q1 
\v 6 Uduniyan u panai wovon,
\q2 tsugono tsu gba̱ɗa̱i,
\q1 a na Ka̱shile ka lapai kakpanga,
\q2 aduniyan e derikpei
\q1 
\v 7 Vuzavaguɗu MalaꞋimili wi ta̱ koɓolo n a̱ tsu.
\q2 Ka̱shile ka Yakubu kaꞋa ubuta̱ u ku sheɗeku u tsu. \qs Kuvuka\qs*
\q1 
\v 8 Ta̱wa̱i yi ene ili i na Vuzavaguɗu u yaꞋin,
\q2 indana biꞋi ili mereve i na u yaꞋin aduniyan.
\q1 
\v 9 U sa̱nka̱i kuvon ubuta̱ dem aduniyan.
\q2 u koɗosoi utan dem, ɗa u la̱nga̱sa̱i nsara.
\q2 o kusongu ekeke o odoku n akina.
\q1 
\v 10 <<U danai, paɗai bini, i yeve mpa Ka̱shile kaꞋa.
\q2 MalaꞋimili maꞋa a̱ ka̱tsuma̱ ka aduniyan a na a buwai,
\q2 MalaꞋimili kpamu aduniyan.>>
\q1 
\v 11 Vuzavaguɗu MalaꞋimili wi ta̱ koɓolo n a̱tsu,
\q2 Ka̱shile ka Yakubu, a̱yi ɗa ubuta̱ u kusheɗeku u tsu. \qs Kuvuka\qs*
\c 47
\s1 Ka̱shile mogono ma aduniyan ra̱ka̱
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu muku n Kora.
\q1 
\v 1 Ɓasai ekiye, adama a̱ ma̱za̱nga̱,
\q2 a̱ɗa̱ uma ra̱ka̱!
\q2 YaꞋin ishipa n utsura,
\q2 cikpai Ka̱shile.
\q1 
\v 2 Vuzavaguɗu MalaꞋimili,
\q2 ili i wovon i ɗa,
\q2 a̱yi mogono ma gbayin maꞋa,
\q2 vuza vu tsugono tsa aduniyan ra̱ka̱.
\q1 
\v 3 U nekei tsu ulyaꞋi a̱ ubuta̱ u uma ra̱ka̱,
\q2 u zuwai uduniyan a ɗaka vu ene a̱ tsu.
\q1 
\v 4 U zagbakai tsu iɗika yi uka̱ni i tsu,
\q2 i ɗaɗa ili ya̱ a̱ra̱ɗi i uma a̱ ni,
\q2 kumaci ku yakubu ku na wi a kuciga. \qs Kuvuka\qs*
\q1 
\v 5 Ka̱shile ka kumba ta̱ a gaɗi vu kakuba ko tsugono ci ni,
\q2 a̱ ka̱na̱i yoroli i ma̱za̱nga̱ n a̱ lika̱i ishari,
\q2 a makyan ma na Ka̱shile ki a ku kumba.
\q1 
\v 6 Cananai ishipa i kucikpa Ka̱shile.
\q2 cananai ishipa i kucikpa mogono ma̱ tsu.
\q1 
\v 7 Ka̱shile mogono ma,
\q2 aduniyan maꞋa ra̱ka̱.
\q2 canana ka yi ni ishipa i kucikpa.
\q1 
\v 8 Ka̱shile ki ta̱ ida̱shi a kakuba ko tsugono ka ciɗa ka̱ ni,
\q2 Ka̱shile ki ta̱ a kulyaꞋa tsugono tsa aduniyan.
\q1 
\v 9 Aza e kelime a kumaci ka aduniyan o ɓolongi,
\q2 a gasai koɓolo n a̱ tsu,
\q1 a̱ tsu uma a̱ Ka̱shile ki Ibirahi,
\q2 adama a na ngono ma aduniyan ra̱ka̱,
\q2 n Ka̱shile n ɗa,
\q1 Ka̱shile ka na i a kucikpa mayin.
\c 48
\s1 Sihiyona likuci i Ka̱shile
\d Vishipa vu muku n Kora.
\q1 
\v 1 Vuzavaguɗu vuza gbayin ɗa,
\q2 u yawa ta̱ a cikpa yi,
\q2 a̱ likuci i gbayin Ka̱shile ka̱ tsu,
\q1 a kusan ku ciɗa.
\q1 
\v 2 Kusan ku Sihiyona ki ta̱ n ugaɗi,
\q1 ili i ma̱za̱nga̱ ma aduniyan ra̱ka̱,
\q2 likuci i mogono ma gbayin,
\q1 tsu kusan ku uɓon u gaɗi,
\q2 ku na ku laꞋi nu mgbayin.
\q1 
\v 3 Ka̱shile ki ta̱ punu a̱ likuci yi nshilya ma,
\q2 adama a na a̱yi n ka̱ci ka̱ ni,
\q2 ubuta̱ u kusheɗeku u ɗa.
\q1 
\v 4 Ɗa ngono n gbaɓai aci e le,
\q2 adama a na a̱ tuka̱ n kuvon a kusan ku Sihiyona.
\q1 
\v 5 Ama a na enei ni,
\q1 a̱ rikpa̱i ɗa a yaꞋin mereve,
\q2 a panai wovon, ɗa a sumai.
\q1 
\v 6 E jeꞋekei ikyamba,
\q2 ɗa a takacikai,
\q2 tsu vuka vu na vi a̱ga̱nda̱ a limata.
\q1 
\v 7 Tsu wunla̱i u kasana,
\q2 u na u tsu ɓososo antsu a̱ mini a Tarishi.
\q1 
\v 8 Tsu na tsu panai arabali ili i nanlo,
\q2 gogo na tana tsu ene ta̱ i ɗa,
\q2 a̱ likuci i Ka̱shile ka̱ tsu MalaꞋimili,
\q1 wi ta̱ a ku ere likuci ya m ma̱ta̱na̱ ko wannai, \qs Kuvuka\qs*
\q1 
\v 9 Ka̱shile, punu A̱Ꞌisa̱ a gbayin a̱ nu,
\q2 ci ta̱ a kusheshe ucigi u nu u na u tsu sabaꞋa ba,
\q1 
\v 10 Ka̱shile, tsu na kula ku nu ki,
\q2 ucikpi u nu u ka̱ra̱Ꞌa ta̱ aduniyan ra̱ka̱.
\q1 Kukiye ku usingai ku nu,
\q2 ki ta̱ a kuyaꞋan afada a usuɓi.
\q1 
\v 11 YaꞋan uma a Sihiyona a yaꞋan ma̱za̱nga̱,
\q2 likuci i wawaꞋa i Yahuda i yaꞋan ma̱za̱nga̱,
\q2 adama afada a usuɓi.
\q1 
\v 12 Banai i ka̱ra̱Ꞌa̱ likuci i Sihiyona,
\q2 ka̱ta̱ i kece nshilya mu ugaɗi n ni,
\q1 
\v 13 I la̱na̱ asaka a,
\q2 ka̱ta̱ kpamu i coꞋoko n nshilya ma,
\q1 adama a na i ciya̱ i na i ku dana,
\q2 ntsukaya n ɗa̱ n na n kuta̱wa̱.
\q2 
\v 14 Ta Ka̱shile ka̱ tsu ki nannai,
\q1 Ka̱shile ka ko wannai,
\q2 vuza na u tsu tono n a̱ tsu ko wannai.
\c 49
\s1 Kuzuwa ku ka̱ɗu a̱ uciyi tsulau tsu ɗa
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu muku n Kora.
\q1 
\v 1 Panai ili i nampa, yaba dem,
\q2 zuwai atsuvu uma a̱ ubuta̱ dem,
\q1 
\v 2 Aza a̱ gba̱ra̱-gba̱ra̱ n muku,
\q1 aza a uciyi n aza a unambi ra̱ka̱.
\q1 
\v 3 Mi ta̱ a kuyaꞋan kadanshi n kuyeve,
\q2 mi ta̱ a kuyaꞋan kusheshe ku singai.
\q1 
\v 4 Mi ta̱ o kubonoko ka̱ɗu ka̱ va̱,
\q2 a̱ ubuta̱ u asan,
\q1 ka̱ta̱ n dana ili i na asan a i a kadanshi,
\q2 a makyan ma na mi a kuwaꞋa umolu.
\q1 
\v 5 Adama a̱ yiɗa̱i ɗa n kupana wovon,
\q2 a makyan ma atakaci?
\q2 A makyan ma na,
\q2 uma a gbani-gbani a̱ ka̱ra̱Ꞌi mu,
\q1 
\v 6 uma a na a zuwai a̱ɗu a̱ uciyi u le,
\q2 aza a na i a̱ra̱ɗi,
\q2 adama a̱ ka̱bunda̱i ka̱ uciyi u le?
\q1 
\v 7 Mayun, vuza wi lo a̱ ka̱tsuma̱ ke le,
\q2 vuza na wi a kufuɗa kushiba̱ vuza ni ba,
\q2 ko u fuɗa u tsupa Ka̱shile ikebe,
\q2 adama a̱ ka̱ci ka̱ ni ba.
\q1 
\v 8 Adama a na ikebe i kushiba̱ wuma u vuma,
\q2 i laꞋa ta̱ agisana,
\q2 a ili i na vuma u kufuɗa ku tsupa,
\q2 ko i ɗa yi a kuyawa ba,
\q1 
\v 9 Yi tana kuzuwa yi u yongo n wuma ba,
\q2 ko i sa̱nka̱ yi ukpa̱ u ko wannai ba.
\q1 
\v 10 U tsu zuwa ta̱ aza e kuyeve a̱ kuwa̱,
\q2 ta feu nannai alau n uma a kavama a̱ ku kuwa̱,
\q2 a̱ ka̱sukpa̱ uciyi u le wu ntsukaya n le.
\q1 
\v 11 Asaun e le i ta̱ o kokpo le iꞋuwa ko wannai,
\q2 ta punu o kuyongo ayin dem,
\q2 ko a na wo okpoi n tsu cau,
\q2 ishi ta̱ n iɗika i ka̱ci ke le.
\q1 
\v 12 Tsugbayin tsu vuma ci a̱ ku sa̱nka̱ yi ku kuwa̱ ba,
\q2 wi ta̱ a̱ ku kuwa̱ tsu manama.
\q1 
\v 13 La̱na̱ ili i na i kuciya̱ aza a na,
\q2 zuwakai ka̱ci ke le a̱ɗu,
\q2 n aza a na a̱ cuwa̱i n uciyi u le. \qs Kuvuka\qs*
\q1 
\v 14 Tsu nlala,
\q2 i ta̱ o kurono le a kubanka a̱ ubuta̱ wi ida̱shi wa̱ a̱kpisa̱,
\q2 ukpa̱ uɗa maguɓi me le,
\q1 n usana aza a usuɓi a ɗa a kulyaꞋaka le tsugono,
\q2 Ikyamba i le kpamu yi ta̱ a kushama a kasaun,
\q2 a̱ ubuta̱ wi ida̱shi wa̱ a̱kpisa̱ u ɗa wi o ko okpo kpaꞋa ku le.
\q1 
\v 15 Ama Ka̱shile ki ta̱ a̱ kushiba̱ mu,
\q2 wi ta̱ a ku isa mu a utsura wu ukpa̱.\qs Kuvuka\qs*
\q1 
\v 16 Ka̱ta̱ vu na̱mgba̱ ka̱tsuma̱ ba,
\q2 ɗa baci vuza wo okpoi vuza vu uciyi,
\q2 ko kpamu uciyi u ni u yimkpa baci.
\q1 
\v 17 Adama a na wi a kuɗika u ɗa ba,
\q2 a makyan ma na u kuwa̱i,
\q2 uciyi u ni wi a ku uwa a kasaun n a̱yi ba.
\q1 
\v 18 Ko ishi baci vuma ciya̱ ili ba̱ri a wuma u nampa,
\q2 ana i a kcikpa yi adama a ulyaꞋi u ni.
\q1 
\v 19 N nannai dem wi ta̱ a ku cina ikaya i ni i na i kuwa̱i ɗe,
\q2 a̱ ubuta̱ u na ka̱yimbi ki ko wannai.
\q1 
\v 20 Tsugbayin tsu vuma ci a ku sa̱nka̱ yi ku kuwa̱ ba.
\q2 wi ta̱ a̱ ku kuwa̱ tsu manama.
\c 50
\s1 Ka̱shile kaꞋa vuza va afada
\d Vishipa vu Asafa.
\q1 
\v 1 Ka̱shile MalaꞋimili, Vuzavaguɗu u yaꞋin kadanshi,
\q2 e kuɗeke aduniyan ra̱ka̱,
\q2 a kasana a kubana a̱ ka̱livi.
\q1 
\v 2 Ka̱shile ki ta̱ a ku akana a Sihiyona,
\q2 a̱ likuci i singai i Sihiyona.
\b
\q1 
\v 3 Ka̱shile ka̱ tsu ka̱ ta̱wa̱ ta̱, u sokongi u ɗa wi ba.
\q2 akina a munuka a̱ kuta̱wa̱ e kelime ka̱ ni,
\q2 uguyi u gbayin kpamu u ka̱ra̱Ꞌi n a̱yi.
\q1 
\v 4 U ɗekei gaɗi n aduniyan okpo ngan,
\q2 ene tsu na wi a kuyaꞋanka uma a̱ ni afada.
\q1 
\v 5 U danai, <<Ɓolongu ku mu uma a usuɓi a̱ va̱,
\q2 aza a na a shatangi uzuwakpani u na mi nu u ɗa n ele,
\q2 a̱ ubuta̱ u kuneꞋe ka alyuka.>>
\q1 
\v 6 Gaɗi a̱da̱nga̱shile a kusala usuɓi u Ka̱shile,
\q2 adama a na a̱yi ɗa wi a kuyaꞋan afada. \qs Kuvuka\qs*
\b
\q1 
\v 7 <<Panai, a̱ɗa̱ uma a̱ va̱,
\q2 mi ta̱ a kuyaꞋan kadanshi,
\q2 mi ta̱ a kuyaꞋan kadanshi n dana,
\q1 Isaraila yi ta̱ n unushi.
\q2 Mpa ɗa Ka̱shile, Ka̱shile ka̱ ɗa̱.
\q1 
\v 8 M ɓarangu ɗa̱ adama alyuka a̱ ɗa̱ ba.
\q2 ko adama e kuneꞋe ku kusongu ku na yi e kuneke mu makyan dem ba.
\q1 
\v 9 Mi a kuciga kobomburon ushiga u ɗa̱ ba,
\q2 ko nlala a ushiga u ɗa̱ ba.
\q1 
\v 10 Adama a na nnama n kakamba dem n va̱ n ɗa,
\q2 a̱kpa̱n anaka a na i aginda ra̱ka̱ a̱ va̱ a ɗa.
\q1 
\v 11 Nnu n na mi a ciɗinkpi gaɗi dem n va̱ n ɗa,
\q2 n ili i wuma i na yi a iɗika ra̱ka̱.
\b
\q1 
\v 12 <<Ko ishi baci mi ta̱ a kupana kambulu,
\q2 mi a kudana ɗa̱ ba,
\q2 adama a na aduniyan n ili i na yi punu dem i va̱ i ɗa.
\q1 
\v 13 n tsu takuma ta̱ inyama yi obomburon ɗa?
\q2 Ko n tsu soꞋo ta̱ mpasa mu nraɗika?
\q1 
\v 14 YaꞋan i neke Ka̱shile kuneꞋe ku kucikpa ku ɗa̱,
\q2 ka̱ta̱ i neke malaꞋimili kuneꞋe ra̱ka̱ ku na i yaꞋin uzuwakpani.
\q1 
\v 15 YaꞋin meɗevile wa̱ a̱ va̱,
\q2 a makyan ma atakaci,
\q2 mi ta̱ a ku isa ɗa̱,
\q2 a̱ɗa̱ kpamu yi ta̱ a kucikpa mu.>>
\b
\q1 
\v 16 Ama Ka̱shile ka dana ta̱ uma a gbani-gbani,
\q2 <<Yiɗa̱i i zuwai yi e kukece wila̱ uva̱?
\q2 Yiɗa̱i ɗa yi a kuyaꞋan kadanshi ka uzuwakpani u va̱?
\q1 
\v 17 I iwain m ɓarangu ɗa̱,
\q2 ɗa kpamu i variki kadanshi ka̱ va̱.
\q1 
\v 18 Yi ene baci koboki, i ci yaꞋan ta̱ cija̱Ꞌa̱ n a̱yi,
\q2 i tsu gbaɓa ta̱ kaci n aza a tsugbani.
\b
\q1 
\v 19 <<Makyan dem yi ta̱ foɓushi,
\q2 i dansa ka gbani-gbani,
\q2 i tsu pana munla̱i ma kudansa aꞋuwa ba.
\q1 
\v 20 A ufoɓushi u ɗa yi,
\q2 i dansa ka gbani-gbani wa̱ aza a̱ ɗa̱,
\q2 i neke le unushi.
\q1 
\v 21 I yaꞋan ta̱ ili i nanlo dem,
\q2 ama mpa n keɓecei ukuna ba.
\q2 adama a nannai i zuwa ta̱ tsu ɗa̱ tsu ɗa mi,
\q1 ama gogo na mi ta̱ a ku ɓarangu ɗa̱,
\q2 mu utuka̱ n unushi u ɗa̱ e keteshe.
\b
\q1 
\v 22 <<Panai na, a̱ɗa̱ na i cinukpai nu mpa,
\q2 ta baci nannai ba, mi ta̱ a ku karasa ɗa̱,
\q2 ko vuza wi a ku isa ɗa̱ ba.
\q1 
\v 23 Vuza na u tsu cikpa mu,
\q2 a makyan ma na wi e kuneke alyuka a̱ ni,
\q1 wi ta̱ e kuneke mu tsugbayin,
\q2 n vuza na kpamu wi o kutono kadanshi ka̱ va̱,
\q2 mi ta̱ o kuyotsongu yi wi ishi u va̱.>>
\c 51
\s1 Avasa adama a kucinukpa unushi
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda ana keneki Natan u banai wa̱ ni a makyan ma na Dawuda u vaki n Besheba vuka vu Uriya.
\q1 
\v 1 Ka̱shile pana asuvayali a̱ va̱,
\q2 adama a ucigi u nu u na u tsu sabaꞋa ba.
\q1 adama a kasingai ka̱ a̱bunda̱i ka̱ nu
\q2 vu cinukpa n unushi u va̱.
\q1 
\v 2 Vu SaꞋa ka gbani-gbani ka̱ va̱ ra̱ka̱,
\q2 vu bonoko mu ciɗa
\q1 
\v 3 Adama a na n yeve ta̱ unushi u va̱,
\q2 makyan dem unushi u va̱ wi ta̱ e kelime ka̱ va̱.
\q1 
\v 4 Avu ɗa koci n nusakai,
\q2 n yaꞋan ta̱ ka gbani-gbani a̱ a̱shi a̱ nu,
\q1 derere ɗa afada a na vu kiɗakai mu.
\q2 derere ɗa vu takacika mu.
\q1 
\v 5 Mayun mpa vuza vu unushi ɗa,
\q2 ali a makyan ma na a̱na̱ku a̱ va̱ a ɗikai ka̱tsuma̱ ka̱ va̱.
\q1 Mayun mpa vuma vu gbani-gbani ɗa,
\q2 ili i na i ɗikai a makyan ma na a matsai mu.
\q1 
\v 6 Mayun ka̱ɗu kamayun ka̱ va̱ kaꞋa vu cigai,
\q2 shatangu ka̱ɗu ka̱ va̱ n kuyeve ku nu.
\q1 
\v 7 Vu za̱Ꞌa̱ ta̱ unushi u va̱ n hisop\f + \fr 51:7 \fq hisop \ft A̱vuku a ɗa a na aza a Yahuda a tsu zuwa a̱ mini adama a na ma̱ kira̱.\f*, mi ta̱ o kokpo ciɗa,
\q2 vu za̱Ꞌa̱ mu, mi ta̱ a ku laꞋa tsukongoi wa̱ri.
\q1 
\v 8 Ka̱ta̱ m pana uyoꞋo n ma̱za̱nga̱,
\q2 yaꞋan etele a na vu yokumoi a yaꞋan ma̱za̱nga̱.
\q1 
\v 9 Takpa unushi u va̱,
\q2 ka̱ta̱ vu pura̱ngu ka gbani-gbani ka̱ va̱ ra̱ka̱.
\q1 
\v 10 Ka̱shile, zuwaka mu ka̱ɗu ka ciɗa,
\q2 vu sabaꞋaka mu ayinviki a savu o kutoni.
\q1 
\v 11 Ka̱ta̱ vu loko mu kelime ka̱ nu ba,
\q2 ka̱ta̱ vu takpa ayinviki a ciɗa a̱ nu wa̱ va̱ ba.
\q1 
\v 12 Zuwa mu ma̱za̱nga̱ tsu na vu yaꞋin ana vu wawai mu,
\q2 ka̱ ta̱ vu neke mu kadanshi n ka̱ɗu ka na n kutono wu.
\q1 
\v 13 N piꞋisaka aza a unushi wila̱ u nu,
\q2 ka̱ta̱ aza a unushi o bono wa̱ a̱ nu.
\q1 
\v 14 Wawa wuma u va̱,
\q2 a̱ ubuta̱ unushi u ku tsuwa̱n ku mpasa,
\q2 Ka̱shile kishi ka̱ va̱,
\q2 mi ta̱ tana a kusala kamayun ka̱ nu n ma̱za̱nga̱.
\q1 
\v 15 Vuzavaguɗu, ɓa̱nka̱ mu adama a na n yaꞋan kadanshi,
\q2 ka̱ta̱ n cikpa wu.
\q1 
\v 16 Alyuka a na n kuneke wu i a kuyawa wu ba,
\q2 vi tana a kupana uyoꞋo u, kuneꞋe ku kusongu ba.
\q1 
\v 17 Ka̱shile, alyuka a̱ va̱ ɗaɗa ka̱ɗu ku usuɓi,
\q2 ka̱ɗu ko kutoni,
\q2 Ka̱shile vi a ku iwan a ɗa ba.
\q1 
\v 18 Ka̱shile yaꞋanka Sihiyona kasingai, vu ɓa̱nka̱ yi,
\q2 vu maꞋasaka nshilya n Urushelima.
\q1 
\v 19 Ka̱ta̱ vu pana uyoꞋo wa alyuka a usuɓi,
\q2 n alyuka o kusongu ra̱ka̱
\q2 i ta̱ ku kuneke obomburon kuneꞋe ka alyuka a katalikalyuka ka̱ nu.
\c 52
\s1 Afada a̱ Ka̱shile n kasingai ka̱ ni
\d Kadanshi a kubana u vuza vu kelime vi ishipa: VicuꞋu vu tsuwaꞋi tsu Dawuda. A makyan ma na Dowegi vuza va aza a Edom u banai u mogono Shawulu a na Ahimeleki ganu sokongi Dawuda a kpaꞋa ku ni.
\q1 
\v 1 Yiɗa̱i i zuwai ɗa vi a̱ra̱ɗi n kawuya ka na vi a kuyaꞋan,
\q2 avu vuzagbayin?
\q2 Yiɗa̱i i zuwai vi a̱ra̱ɗi makyan dem,
\q2 a̱ɗa̱ na i yaꞋin ili i wono a̱ a̱shi a̱ Ka̱shile?
\q1 
\v 2 Kelentsu ka̱ nu e kusheshe ka gbani-gbani,
\q2 adama a na vu la̱nga̱sa̱ aza o yoku,
\q2 ki ta̱ an kutanu ka alyu,
\q2 makyan dem a kuyaꞋan aꞋuwa.
\q1 
\v 3 Vu laꞋa ta̱ n ku ciga kawuya n kasingai,
\q2 vu laꞋa ta̱ n ku ciga ka aꞋuwa n kamayun. \qs Kuvuka\qs*
\q1 
\v 4 Vu tsu ciga ta̱ kudoro uma n kadanshi ka̱ nu,
\q2 avu kayaꞋin ka aꞋuwa.
\q1 
\v 5 Adama a nannai Ka̱shile ki ta̱ a̱ kula̱nga̱sa̱ wu ko wannai,
\q2 wi ta̱ e kureme wu ka̱ta̱ wu utuka̱ wu a kpaꞋa ku nu,
\q2 wi ta̱ kpamu a kutakpa wu a iɗika i wuma.\qs Kuvuka\qs*
\q1 
\v 6 Aza a usuɓi ene baci ili i wovon i nanlo,
\q2 i ta̱ o ku zoꞋoso wu, a dana,
\q1 
\v 7 <<Inda biꞋi vuza na u kpa̱ɗa̱i kula̱nsa̱ ubuta̱ u kusheɗeku u Ka̱shile,
\q1 adama a na u ciya̱ ida̱shi i ma̱ta̱na̱ ba,
\q2 kucikpa u zuwai ka̱ɗu a̱ ubuta̱ wu uciyi u ni,
\q2 a̱ kula̱nsa̱ ida̱shi i ma̱ta̱na̱ a ka gbani-gbani ka̱ ni>>
\q1 
\v 8 Ama mpa mi ta̱ tsu maɗanga ma zaitu,
\q2 ma na mo topoi mayin a kpaꞋa ku Ka̱shile.
\q2 N neke ta̱ ka̱ɗu a ucigi u ni u na u tsu sabaꞋa ba ko wannai.
\q1 
\v 9 Mi ta̱ a kucikpa wu Vuzavaguɗu,
\q2 adama ili na vu yaꞋin.
\q1 mi ta̱ e kuneke ka̱ɗu ka̱ va̱ wa̱ a̱ nu,
\q2 mi ta̱ a ku sala kula ku nu,
\q2 e kelime ka uma a usuɓi a̱ nu,
\q2 adama a na avu vuza vu kasingai ɗa.
\c 53
\s1 Kawuya ka vuma
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n ka̱la̱ka̱tsu ka <<Mahalatu.>> VicuꞋu vu tsuwaꞋi tsu Dawuda.
\r (Ishp 14:1-7)
\q1 
\v 1 Alau a tsu dansa ta̱ a̱ɗu e le,
\q2 <<Ka̱shile ki lo ba.>>
\q1 A̱ na̱mgba̱ ta̱ ra̱ka̱ vu le, ulinga u le ili yi unata i ɗa,
\q2 babu vuza na u ci yaꞋan ili i na yi derere.
\q1 
\v 2 Vuzavaguɗu wu indanai uma ɗe gaɗi,
\q2 we ene ko aza e kuyeve i ta̱ punu,
\q2 vuza a na wi a̱ kula̱nsa̱ u yeve Ka̱shile.
\q1 
\v 3 Ra̱ka̱ vi le a̱ ka̱sukpa̱ ta̱ uye,
\q2 dem vi le a̱ puwa̱nka̱ ta̱,
\q2 babu vuza na wi a kuyaꞋan ka̱ ma̱riki,
\q2 ko vuza te.
\q1 
\v 4 Aza a na i a kuyaꞋan ka gbani-gbani ka,
\q2 i n kuyeve ba?
\q2 A tsu takuma ta̱ uma tsu boroji,
\q2 kpamu a ci yaꞋan avasa u Vuzavaguɗu ba.
\q1 
\v 5 Ama i ta̱ a̱ kurikpa̱ ka̱u,
\q2 tsu na a saꞋwai kuyaꞋan ba,
\q2 Ka̱shile ki ta̱ a ku wacuwa etele i irala i uma a̱ ni.
\q1 aza a Isaraila i ta̱ o kuloko le, adama a na u iwan le ta̱.
\q1 
\v 6 Ishi baci a dana wishi wi Isaraila,
\q2 wu uta̱ ta̱ a Sihiyona.
\q1 ana Ka̱shile ko bonokoi uma a̱ ni una̱singai u le,
\q2 Yakubu wi ta̱ a kuyaꞋan ma̱za̱nga̱,
\q2 ka̱ta̱ Isaraila a̱ za̱nga̱na̱.
\c 54
\s1 Avasa a̱ kula̱nsa̱ uɓa̱nki ekiye a irala i va̱
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n aꞋin a umolu. VicuꞋu vu tsuwaꞋi tsu Dawuda. Ana vuza va aza a Zefata u banai u danai Shawulu <<Dawuda ɗa wi usheɗeki wa̱ tsu ba?>>
\q1 
\v 1 Ka̱shile, wawa mu n utsura u kula ku nu,
\q2 vu bonuko mu vuza vu babu unushi
\q2 n utsura u nu.
\q1 
\v 2 Ka̱shile, Pana avasa a̱ va̱,
\q2 vu pana kadanshi ka una̱ ka̱ va̱.
\q1 
\v 3 Omoci a̱ tuka̱ mu ta̱ n kuvon.
\q2 uma a gbani-gbani i ta̱ a̱ kula̱nsa̱ mu una.
\q2 ele ɗa aza a na e yevei a na Ka̱shile ki lo ba. \qs Kuvuka\qs*
\q1 
\v 4 N yeve ta̱ Ka̱shile kaꞋa ka̱ɓa̱nki ka̱ va̱.
\q2 Vuzavaguɗu ɗa wi a̱ kula̱na̱ mu.
\q1 
\v 5 Ka̱shile ki ta̱ a kutakacika irala i va̱ tsu ka gbani-gbani ke le,
\q2 Wi ta̱ a ku una le adama a na a̱yi vuza vu usuɓi ɗa.
\q1 
\v 6 N ucigi u ka̱ɗu mi ta̱ e kuneke wu alyuka,
\q2 mi ta̱ a kucikpa wu, Vuzavaguɗu,
\q2 adama a na ta ugaꞋin nannai.
\q1 
\v 7 Adama a na wu ere mu ta̱ a̱ ubuta̱ wa atakaci a̱ va̱ ra̱ka̱,
\q2 ɗa me enei o lokoi irala i va̱.
\c 55
\s1 Avasa a̱ kula̱nsa̱ uɓa̱nki
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n aꞋin a umolu. VicuꞋu vu tsuwaꞋi tsu Dawuda.
\q1 
\v 1 Ka̱shile, pana avasa a̱ va̱,
\q2 ka̱ ta̱ vu iwan kupana ufolu u va̱ ba.
\q2 
\v 2 Panaka mu, vu ushuku mu,
\q1 adama a na una̱mgbuka̱tsuma̱ u va̱ woꞋuso mu ta̱ ka̱u,
\q2 
\v 3 Ka̱ɗu ka̱ va̱ ka̱ ɗa̱nga̱ ta̱, adama kacaꞋa ka irala i va̱,
\q2 adama o modoruko ma uma a gbani-gbani,
\q1 o tsu ronoko mu ta̱ atakaci,
\q2 a kupana wupa u va̱ i a ku iwan mu.
\q1 
\v 4 ka̱ɗu ka̱ va̱ ki ta̱ tukpa n una̱mgbuka̱tsuma̱,
\q2 wovon wu ukpa̱ u ka̱na̱i mu.
\q1 
\v 5 Wovon u ka̱na̱i mu ka̱u, n kujeꞋeke ki ikyamba,
\q2 n rikpa̱i ka̱u.
\q1 
\v 6 Ɗa n danai, <<Ishi baci mi ta̱ n evelyu tsu moɗoi,
\q2 mi shi ta̱ a ku imkpa m bana n la̱nsa̱ ubuta̱ u kuvuka.
\q1 
\v 7 m bana daꞋangi,
\q2 n yaꞋan ɗe kpaꞋa ku va̱ e meremune. \qs Kuvuka\qs*
\q1 
\v 8 Mi ta̱ a kuyaꞋan moloko n la̱nsa̱ ubuta̱ u kusheɗeku,
\q2 a gaɗi daꞋangi n wunla̱i wu utsura n uguyi.>>
\q1 
\v 9 Vuzavaguɗu, la̱nga̱sa̱ kusheshe ku le,
\q2 ka̱ ta̱ kpamu vu ripula̱ kadanshi ke le.
\q2 adama a na me ene ta̱ ugbamukaci a̱ kuɗa̱nga̱ a̱ likuci ya.
\q1 
\v 10 Kanna n kayin a̱ kuka̱ra̱Ꞌa̱sa̱ a nshilya n likuci ma,
\q2 likuci ya tana yi ta̱ tukpa n unushi n ka gbani-gbani.
\q1 
\v 11 Ukuna u kula̱nga̱su u shana ta̱ a̱ ubuta̱ dem a̱ likuci ya.
\q2 modoruko n kawuya ka shana ta̱ a̱ ubuta̱ dem.
\q1 
\v 12 Ishi baci vurala vu va̱ ɗa vi o ku zoꞋoso mu,
\q2 mi shi ta̱ a ku gbama asuvu,
\q1 ishi baci a dana a̱yi ɗa vuza kelime vu va̱,
\q2 mi shi ta̱ a kukpaꞋwan adama a̱ ni.
\q1 
\v 13 Ama avu ɗa ka̱ja̱Ꞌa̱ ka̱ va̱,
\q2 vuma va̱, ka̱ja̱Ꞌa̱ ka gbagu ka̱ va̱ kpamu.
\q1 
\v 14 Cau ci ishi ta̱ tsu ci yongo,
\q2 tsu tsu bana ta̱ A̱Ꞌisa̱ a gbayin koɓolo.
\q1 
\v 15 Ka̱shile ka zuwa ukpa̱ u ta̱wa̱ wi irala i va̱ babu uyevi,
\q2 yaꞋan a bana iɗika yi ukpisa̱ n wuma u le,
\q2 ka gbani-gbani ki ta̱ aꞋuwa i le n unata̱ u le.
\q1 
\v 16 Ama n ɗeke ta̱ Ka̱shile ka̱ ɓa̱nka̱ mu,
\q2 Vuzavaguɗu tana wi ta̱ a ku wawa mu.
\q1 
\v 17 Kanna n kayin,
\q2 n shika̱i n mavura,
\q2 ɗa tana u panai ka̱la̱ka̱tsu ka̱ va̱.
\q1 
\v 18 Wi ta̱ a̱ kushiba̱ mu,
\q2 a̱ ubuta̱ u kuvon ku na n ci yaꞋan,
\q2 n irala i va̱ ya̱ a̱bunda̱i.
\q1 
\v 19 Ka̱shile, vuza na wi o tsugono ali n tsu cau,
\q2 wi ta̱ a kupanaka mu, ka̱ta̱ u loko le, \qs Kuvuka\qs*
\q1 uma a na a tsu sabaꞋa kuyongo ku le ba.
\q2 adama a na a tsu pana wovon u Ka̱shile ba.
\q1 
\v 20 Ka̱ja̱Ꞌa̱ ka̱va̱, ka banka ta̱ a̱ja̱Ꞌa̱ ni vishili,
\q2 u koɗoi uzuwakpani u ni.
\q1 
\v 21 Kadanshi ka̱ ni ka laꞋa ta̱ maniꞋin me epeshe n pete,
\q2 ama maꞋiwanai mi ta̱ punu a̱ ka̱ɗu ka̱ ni,
\q1 Kadanshi ka̱ ni ka laꞋa ta̱ maniꞋin n leku,
\q2 ama ki ta̱ n alyu tsu una̱ u kotokobi.
\q1 
\v 22 Banka Vuzavaguɗu atakaci a̱ nu,
\q2 wi ta̱ a̱ kuɓa̱nka̱ wu.
\q2 wi a̱ ku ka̱sukpa̱, a lyaꞋa kelime ka vuza vu usuɓi ba.
\q1 
\v 23 Ama avu, Ka̱shile vi ta̱ a ku taɗuku aza a gbani-gbani,
\q2 punu a iɗika a̱ ubuta̱ wu uga̱vi,
\q2 aza aꞋuwa n aza a̱ kutsuwa̱n ku mpasa,
\q1 babu e pece ayin e le a duniya,
\q2 ama mpa mi ta̱ e kuneke ka̱ɗu ka̱ va̱ wa̱ a̱ nu.
\c 56
\s1 Avasa a vuza na u zuwai ka̱ɗu u Ka̱shile
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n ka̱la̱ka̱tsu ko <<Moɗoi a gaɗi vu maɗanga ma Oku.>> Vishipa vu Dawuda. Ana aza a Filisitiya e remei ni a Gatu.
\q1 
\v 1 Ka̱shile, pana asuvayali a̱ va̱,
\q2 adama a na uma a̱ tuka̱ mu ta̱ n kuvon,
\q2 irala i va̱ yi ta̱ a kutakacika mu kanna dem.
\q1 
\v 2 Kanna dem irala i va̱ yi ta̱ a ku guva mu,
\q2 n ka̱bunda̱i ke le i ta̱ a̱ vishili nu mpa.
\q1 
\v 3 Makyan ma na baci m panai wovon,
\q2 mi ta̱ a kuzuwa ka̱ɗu ka̱ va̱ wa̱ a̱ nu.
\q1 
\v 4 N zuwa ta̱ ka̱ɗu ka̱ va̱ u Ka̱shile,
\q2 mi ta̱ a kucikpa uzuwakpani u ni.
\q1 wa̱ a̱ ni u ɗa n zuwai ka̱ɗu, mi a ku pana wovon ba.
\q2 Yiɗa̱i vuma vu lima̱ u kuyaꞋanka mu?
\q1 
\v 5 Irala i va̱ i tsu oꞋuso mu ta̱ kanna dem,
\q2 makyan dem i ta̱ e kusheshe,
\q2 tsu na o kudoro mu.
\q1 
\v 6 O tsu ɓolongu ta̱ u sokongi,
\q2 a ku inda nwalu n va̱,
\q2 a kuvana tsu na a ku una mu.
\q1 
\v 7 Ka̱shile, ka̱ta̱ vu ka̱sukpa̱ le a laꞋaka a ka gbani-gbani ke le ba,
\q2 a wupa u nu una uduniyan u nampa.
\q1 
\v 8 Ɗana una̱mgbuka̱tsuma̱ u va̱,
\q2 kece ka̱bunda̱i ka kujilya ka̱ va̱,
\q2 i a katagarda ka̱ nu ba?
\q1 
\v 9 A kanna ka na baci n ɗekei nu,
\q2 irala i va̱ yi ta̱ o kubono n ka̱ca̱pa̱.
\q2 adama a na n yeve ta̱ Ka̱shile ki ta̱ koɓolo nu mpa.
\q1 
\v 10 Ka̱shile, mi ta̱ a kucikpa kadanshi ka̱ nu,
\q2 Vuzavaguɗu, mi ta̱ a kucikpa kadanshi ka̱ nu.
\q1 
\v 11 Ka̱shile, wa̱ nu u ɗa n zuwai ka̱ɗu,
\q2 mi tana a kupana wovon ba.
\q2 Yiɗa̱i vuma vu lima̱ u kuyaꞋan ka mu?
\q1 
\v 12 Ka̱shile, mi ta̱ e kuneke wu ili i na n yaꞋin uzuwakpani.
\q2 mi ta̱ e kuneke wu kuneꞋe ku kucikpa.
\q1 
\v 13 Adama a na vu wawa mu ta̱ a̱ ubuta̱ wu ukpa̱,
\q2 vu erei ene a̱ va̱ a̱ ubuta̱ u ma̱ta̱ɗa̱,
\q1 adama a na n wala e kelime ka̱ Ka̱shile,
\q2 a kutashi ku na ku tsu neke wuma.
\c 57
\s1 Avasa a̱ kula̱nsa̱ uɓa̱nki atakaci
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n ka̱la̱ka̱tsu ka<<Ka̱ta̱ a yaꞋan munuka ba.>> Vishipa vu Dawuda. Ana u sumai u Shawulu u uwai a kaɓatsu.
\r (Ishp 108:1-5)
\q1 
\v 1 Pana asuvayali a̱ va̱ Ka̱shile, pana asuvayali a̱ va̱,
\q2 adama a na wa̱ a̱ nu u ɗa n la̱nsa̱i ubuta̱ u kusheɗeku.
\q1 Mi ta̱ e kusheɗeku a ɗaka vu evelyu a̱ nu.
\q2 ali mita ra̱ka̱ ma laza.
\q1 
\v 2 Mi ta̱ e kuɗeke Ka̱shile, MalaꞋimili,
\q2 a̱yi Ka̱shile ka na ka ci shatangu ku mu ili dem.
\q1 
\v 3 Ɗe gaɗi Ka̱shile ki ta̱ a̱ ku suꞋuku mu n wishi.
\q2 o kuloko aza a na i a̱ vishili nu mpa. \qs Kuvuka\qs*
\q2 Ka̱shile ki ta̱ o ku yotsongu mu ucigi,
\q2 u ni u na tsu sabaꞋa ba n usuɓi u ni.
\q1 
\v 4 Wuma u va̱ wi ta̱ e mere ma ikawu,
\q2 n vaki e mere ma nnama n na n tsu takuma uma.
\q1 anga e le i ta̱ a na osovu n ayaꞋa,
\q2 elentsu e le i ta̱ n alyu tsu otokobi.
\q1 
\v 5 Ka̱shile, yaꞋan a cikpa wu a gaɗi vu eleshu,
\q2 yaꞋan tsugbayin tsu nu kpamu tsu yongo aduniyan dem.
\q1 
\v 6 Irala i va̱ i zuwaka mu ta̱ maza adama a na aza mu.
\q2 atakaci a laꞋa ta̱ utsura u va̱.
\q1 A̱ ga̱va̱ka̱i mu kpenle a uye u va̱,
\q2 ama ɗa a kucikpa o bono a̱ yikpa̱i punu n ka̱ci ka̱le. \qs Kuvuka\qs*
\q1 
\v 7 Ka̱shile, ka̱ɗu ka̱ va̱ ka̱ muɗa̱ ba,
\q2 ka̱ɗu ka̱ va̱ ki ta̱ ida̱shi,
\q1 mi ta̱ a kuyaꞋan ishipa n cikpa wu.
\q2 
\v 8 Jimgba, wuma u va̱
\q1 jimgba umolu u va̱,
\q2 mi ta̱ a ku jimgba n usana n ishipa i va̱.
\q1 
\v 9 Vuzavaguɗu, mi ta̱ a kucikpa wu a̱ ka̱tsuma̱ ka uduniyan,
\q2 mi ta̱ a kucanana ishipa i kucikpa wu a̱ ka̱tsuma̱ ka uma.
\q1 
\v 10 Ucigi u gbayin u nu u yawa ta̱ gaɗi,
\q2 usuɓi u nu u yawa ta̱ eleshu.
\q1 
\v 11 Ka̱shile, yaꞋan a cikpa wu a gaɗi vu eleshu,
\q2 yaꞋan tsugbayin tsu nu kpamu tsu yongo aduniyan dem.
\c 58
\s1 Avasa adama a na a takacika uma a gbani-gbani
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n ka̱la̱ka̱tsu <<Ka̱ta̱ a yaꞋan munuka ba.>> Vishipa vu Dawuda.
\p 
\v 1 A̱ɗa̱ aza o tsugono yi ta̱ e kuneke kadanshi ka mayun?
\q2 Yi ta̱ a kuyaꞋanka uma afada a singai?
\q1 
\v 2 A̱Ꞌa̱, a̱ɗu a̱ ɗa̱ kusheshe ku gbani-gbani ku ɗa koci yi a kuyaꞋan.
\q2 yi a kuyaꞋan unushi u kuɗa̱ngusa̱ vishili a iɗika.
\q1 
\v 3 Ili i na i ɗikai ele punu a̱ ka̱tsuma̱, uma a gbani-gbani a̱ ka̱sukpa̱i uye,
\q2 babu a matsai le ɗa aza aꞋuwa a̱ ka̱sukpa̱i uye.
\q1 
\v 4 I ta̱ tukpa n tsukono a na tsu koko,
\q2 o tsu votsuku ta̱ atsuvu e le tsu kagulani ka kagbaturu,
\q1 
\v 5 ka na ka tsu pana ka̱la̱ka̱tsu ka vuza vu a̱da̱bu ba.
\q2 Ko u panaka ma̱zuɓi ma̱ a̱da̱bu ba.
\q1 
\v 6 Ka̱shile, koɗoso anga e le ana i a malumuka n aɗa.
\q2 koɗoso anga i muku mi ikawu ma, Vuzavaguɗu,
\q1 
\v 7 YaꞋan a̱ puwa̱nka̱ tsu na mini me ci yene a kulaza.
\q2 yaꞋan o koɗoso ayaꞋa e le, ayin a na baci a katsuki a utan u le.
\q1 
\v 8 YaꞋan e derikpe tsu na kokoto ke tsu wala u ka̱sukpa̱ kederi,
\q2 yaꞋan okpo tsu mereɓu ma na a matsai ukpa̱,
\q2 ma na u saꞋwai kene kanna ba.
\q1 
\v 9 Babu uyevi u le Ka̱shile ki ta̱ a̱ kupura̱ngu le tsu mita̱,
\q2 a̱ ka̱tsuma̱ ka wupa wu usuɗukpi u ni,
\q2 Ka̱shile ki ta̱ a̱ kupura̱ngu le ele biꞋi n wuma.
\q1 
\v 10 Aza a usuɓi i ta̱ a̱ kuyaꞋan ma̱za̱nga̱,
\q2 ayin a na baci enei a takacikai uma a gbani-gbani.
\q1 i ta̱ a kuyaꞋan ma̱za̱nga̱
\q2 ayin a na baci a unai irala i le ra̱ka̱.
\q1 
\v 11 Ka̱ ta̱ uma a dana,
\q2 <<Mayun katsupu ki ta̱ lo a vuza vu usuɓi,
\q2 mayun Ka̱shile ki ta̱ lo ka na ki a kuyaꞋanka aduniyan afada.>>
\c 59
\s1 Avasa a̱ kula̱nsa̱ wishi a̱ ubuta̱ wi irala
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n ka̱la̱ka̱tsu <<Ka̱ta̱ a yaꞋan munuka ba.>> Vishipa vu Dawuda. Ana Shawulu u suki uma a bana inda kpaꞋa ku Dawuda adama a na una yi.
\q1 
\v 1 Ka̱shile ka̱ va̱, wawa mu a̱ ubuta̱ wi irala i va̱,
\q2 ere mu wa aza na i a̱ ku tuka̱ mu n vishili makyan dem.
\q1 
\v 2 Wawa mu a̱ ubuta̱ uma a na a ci yaꞋan ka gbani-gbani,
\q2 wawa mu a̱ ka̱tsuma̱ ka aza a̱ ku tsuwa̱n ku mpasa.
\q1 
\v 3 La̱na̱, o bopoi a kuvana adama a na una mu,
\q2 uma a gbani-gbani o tsu ɓolongu ta̱ adama a na a yaꞋan tsurala nu mpa.
\q1 a̱ ma̱ta̱ɗa̱ ko unushi wi ili i yoku ba, Vuzavaguɗu.
\q1 
\v 4 N yaꞋan unushi ba, n nannai dem i ta̱ ufoɓushi a̱ shilika̱ nu mpa.
\q2 ɗa̱nga̱ vu ɓa̱nka̱ mu, vu la̱na̱ atakaci a̱ va̱.
\q1 
\v 5 Avu Vuzavaguɗu Ka̱shile MalaꞋimili Ka̱shile ki Isaraila,
\q2 ɗa̱nga̱ vu takacika uduniyan,
\q1 ka̱ ta̱ vu pana asuvayali a uma a gbani-gbani
\q2 aza o modoruko a nanlo ba. \qs Kuvuka\qs*
\q1 
\v 6 O tsu bono ta̱ n kulivi,
\q2 a̱ ka̱na̱ wali a na nsheꞋe
\q2 n na mi a̱ ka̱ ka̱ra̱sa̱ a̱ likuci.
\q1 
\v 7 Pana kadanshi ki ishikushi ka na ki a̱ ku uta̱ una̱ u le,
\q2 kadanshi ke le ki ta̱ a na otokobi,
\q2 ali, a kudana, <<Yayi, u kupanaka tsu?>>
\q1 
\v 8 Ama avu Vuzavuguɗu, zoꞋoso le,
\q2 Vu tsu yaꞋanka ta̱ uduniyan dem ulami.
\q1 
\v 9 Avu vuza vu utsura u va̱, Ka̱shile, n zuwa ta̱ katsura ka̱va̱ wa̱ nu,
\q2 avu ɗa ubuta̱ u kusheɗeku u va̱.
\q1 
\v 10 Ka̱shile vuza vu ucigi u na u tsu sabaꞋa ba.
\q2 Ka̱shile ki ta̱ a ku wawa mu,
\q2 ka̱ ta̱ u zuwa mu n zoꞋoso irala i va̱.
\q1 
\v 11 Ka̱ta̱ vu una le ba, Vuzavaguɗu ke keɗetsu ka̱ va̱
\q2 adama a na ka̱ta̱ uma a̱ va̱ a cinukpa ba.
\q1 n utsura u nu zuwa le a̱ ka̱na̱ ka̱ ka̱ra̱sa̱,
\q2 ka̱ta̱ vu la̱nga̱sa̱ le,
\q1 
\v 12 Unushi wu una̱ u le,
\q2 n kadanshi ku una̱ u le,
\q2 yaꞋan e reme le adama a̱ra̱ɗi e le.
\q1 Adama a ishikushi n aꞋuwa a na a ci yaꞋan,
\q2 
\v 13 La̱nga̱sa̱ le a̱ ka̱tsuma̱ ka wupa u nu.
\q2 la̱nga̱sa̱ le ali o kotso ra̱ka̱,
\q1 nannai ɗa e kuyeve a na Ka̱shile kaꞋa ki o tsugono ci Isaraila
\q2 ali a uteku wa aduniyan. \qs Kuvuka\qs*
\q1 
\v 14 O tsu bono ta̱ n kulivi,
\q2 a̱ ka̱na̱ wali a na nsheꞋe
\q2 n na mi a̱ ka̱ ka̱ra̱sa̱ a̱ likuci,
\q1 
\v 15 a̱ ka̱ka̱ra̱sa̱ a̱ ubuta̱ dem a̱ kula̱nsa̱ ilikulyaꞋa
\q2 a̱ ka̱na̱ ma̱shi ɗa baci a̱ cuwa̱i ba.
\q1 
\v 16 Ama mpa mi ta̱ a kucanana ishipa a ukuna wu utsura u nu,
\q2 usana mi ta̱ a kucanana ishipa adama a ucigi u nu u na u tsu sabaꞋa ba.
\q1 Adama a na avu ɗa ubuta̱ wu ukanji va̱,
\q2 ubuta̱ u kusheɗeku u va̱ a makyan ma atakaci.
\q1 
\v 17 Mi ta̱ a ku cikpa wu, avu katsura ka̱va̱,
\q2 avu Ka̱shile, ubuta̱ wu ukanji uva̱, Ka̱shile ka na ka cigai mu.
\c 60
\s1 Avasa adama a̱ kula̱nsa̱ uɓa̱nki
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n ka̱la̱ka̱tsu <<Lili vu uzuwakpani.>> Vishipa vu Dawuda. Ana u shilika̱i n Aram Naharami n Aram vu Zoba n ayain a na Jowabu u banai wu unai aza a Edom a̱kpa̱n kupa n ere a̱ ka̱ra̱Ꞌa̱ ka mkpaɗi.
\q1 
\v 1 Ka̱shile vu iwan tsu ta̱, ali ɗa ka̱sukpa̱i a lyaꞋi utsura u tsu,
\q2 vu yaꞋan ta̱ wupa n a̱ tsu,
\q2 ama gogo na bonoko tsu.
\q1 
\v 2 Vu zuwai iɗika i gba̱ɗa̱i ɗa i ɓatsai,
\q2 gogo na ciɗa̱ngu enle a, adama a na i tsurukpa kpamu.
\q1 
\v 3 Vu zuwa ta̱ uma a̱ nu a takacikai ka̱u,
\q2 vu nekei tsu ma̱kya̱n ma na ma lamkpai
\q2 ali ma zuwai tsu ku tangala.
\q1 
\v 4 Ama vu ɗa̱ngusa̱ ta̱ urotu u kakashi wa aza a na i ku pana wovon u nu,
\q2 adama a na a laꞋaka a utan. \qs Kuvuka\qs*
\q1 
\v 5 Wawa tsu vu ɓa̱nka̱ tsu n utsura u nu,
\q2 adama a uma a na vu cigai a̱ ciya̱ wishi u nu,
\q1 
\v 6 Ka̱shile ka yaꞋan ta̱ kadanshi a̱ ubuta̱ u ciɗa u ni.
\q2 <<N ulyaꞋi mi ta̱ e kupece Shekem,
\q2 ka̱ta̱ m pecukusu ka̱ra̱Ꞌa̱ ka Sukotu.
\q1 
\v 7 Giliyadu vu va̱ vu ɗa, Manasa feu vu va̱ vu ɗa.
\q2 Ifirayimu ɗa ma̱kuꞋun ma̱ viyum ma̱ va̱.
\q2 Yahuda kalangu ko tsugono ka̱ va̱.
\q1 
\v 8 Mi ta̱ o kubonoko Mowabu tsu kasasu ka̱ kuza̱Ꞌa̱ ka̱ va̱,
\q2 Edom wi ta̱ o ko okpo a ɗaka vu ene a̱ va̱,
\q2 Ka̱ ta̱ n yaꞋan yoroli yi ulyaꞋi wa aza a Filisitiya.>>
\q1 
\v 9 Yayi u kubanka mu a̱ likuci yi u ukanji?
\q2 Yayi u kutono nu mpa a kubana a iɗika i Edom?
\q1 
\v 10 Ka̱shile avu ɗa vu variki tsu,
\q2 Vu kpa̱ɗa̱i kudoku kuwala n osoji a̱ tsu ba?
\q1 
\v 11 Ɓa̱nka̱ tsu, tsu shilika̱ ni irala i tsu,
\q2 adama a na uɓa̱nki u vuma gbani ɗa.
\q1 
\v 12 Ka̱shile ki baci n a̱tsu ci ta̱ a̱ kuciya̱ ulyaꞋi,
\q2 wi ta̱ a kulyaꞋa irala i tsu.
\c 61
\s1 Uzuwi u ka̱ɗu a wu eri u Ka̱shile
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n anꞋin a umolu. Vishipa vu Dawuda.
\p 
\v 1 Ka̱shile, pana ma̱shi ma̱ va̱,
\q2 zuwa atsuvu wa avasa a̱ va̱.
\q1 
\v 2 A uteku wa aduniyan, n ɗekei nu,
\q2 n ɗeke wu ta̱ ana n takpai ka̱ɗu,
\q1 vu banka mu a̱ ubuta̱ u kusheɗeku u na u laꞋi.
\q1 
\v 3 Adama a na avu ɗa ubuta̱ u kusheɗeku ali ɗe,
\q2 avu ɗa ubuta̱ wu ukanji e kelime ka irala i va̱.
\q1 
\v 4 YaꞋan n da̱sa̱ngu a̱ ma̱va̱li ma̱ nu ko wannai.
\q2 yaꞋan n ciya̱ ubuta̱ wu ida̱shi a ɗaka vu evelyu a̱ nu. \qs Kuvuka\qs*
\q1 
\v 5 Ka̱shile, vu pana ta̱ akucina a̱ va̱,
\q2 ɗa vu nekei mu ili yi uka̱ni ya aza a na i a kucikpa wu.
\q1 
\v 6 Zuwa wuma u mogono u geshe;
\q2 vu zuwa yi u yongo n wuma ali a kubana a tsukaya.
\q1 
\v 7 YaꞋan u lyaꞋa tsugono e kelime ka̱ nu, Ka̱shile, ko wannai,
\q2 zuwa ucigi u nu u na u tsu sabaꞋa ba n usuɓi u nu wu ere yi.
\q1 
\v 8 Adama a nannai mi ta̱ a kucanana ishipa n cikpa kula ku nu,
\q2 n shatangu uzuwakpani u va̱ u kanna dem.
\c 62
\s1 Ka̱shile kaꞋa koci ubuta̱ u kusheɗeku
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n ka̱la̱ka̱tsu ka Jedutun. Vishipa vu Dawuda
\q1 
\v 1 A̱ Ka̱shile kaꞋa koci wuma u va̱ u ciya̱i kuvuka,
\q2 wishi u va̱ wu uta̱ ta̱ wa̱ ni.
\q1 
\v 2 Ka̱shile kaꞋa koci katali ka̱va̱ n kishi ka̱ va̱,
\q2 a̱yi ɗa ubuta̱ wu ukanji u va̱, mi a kupana wovon ba.
\q1 
\v 3 Ali n wannai ɗai ra̱ka̱ vu ɗa̱ i ku shilika̱ n vuma vu te?
\q2 Adama a na yi una yi,
\q2 mashilya ma u tsubaki ma nampa,
\q2 ko an mashilya ma na mi a ukuna u kuyikpa̱?
\q1 
\v 4 Kusheshe ku ɗa̱ ku ɗa i cipuka̱ yi
\q2 a̱ ubuta̱ u tsugbayin ci ni,
\q1 I tsu pana ta̱ uyoꞋo u kuyaꞋan aꞋuwa.
\q2 i tsu zuwaka ta̱ vuma una̱singai n una̱ u ɗa̱,
\q2 ama a̱ɗu a̱ ɗa̱ una̱ u wuya u ɗa. \qs Kuvuka\qs*
\q1 
\v 5 A̱ Ka̱shile kaꞋa koci wuma u va̱ u ciya̱i kuvuka,
\q2 wa̱ a̱ ni u ɗa n keɗei a̱pa̱Ꞌa̱.
\q1 
\v 6 A̱yi ɗa koci katali ka̱ va̱ n kishi ka̱ va̱,
\q2 a̱yi ɗa ubuta̱ wu ukanji u va̱,
\q2 mi a kupana wovon ba.
\q1 
\v 7 Wishi u va̱ n tsugbayin tsu va̱ tsu uta̱ ta̱ u Ka̱shile,
\q2 a̱yi ɗa katali ka gbayin ka̱ va̱,
\q2 ubuta̱ u kusheɗeku u va̱.
\q1 
\v 8 Uma, zuwai a̱ɗu a̱ ɗa̱ wa̱ ni makyan dem,
\q2 i dana yi ili i na yi a̱ɗu a̱ ɗa̱ ra̱ka̱.
\q2 adama a na Ka̱shile kaꞋa ubuta̱ u kusheɗeku u tsu. \qs Kuvuka\qs*
\q1 
\v 9 Aza a unambi i ta̱ tsu ayinviki,
\q2 aza a uciyi ukuna wa aꞋuwa u ɗa.
\q1 a gisanku le baci ele ili i ɗa ba,
\q2 ra̱ka̱ vu le ayinviki a ɗa koci.
\q1 
\v 10 Ka̱ta̱ i zuwa a̱ɗu a̱ ɗa̱ a ukuna u modoruko ba,
\q2 ko i ka̱na̱ a̱ra̱ɗi n ucanuku wu uboki ba.
\q1 ko a na uciyi u yimkpai,
\q2 ka̱ta̱ i zuwa a̱ɗu a̱ ɗa̱ a u ɗa ba.
\q1 
\v 11 Ili i te i ɗa Ka̱shile kadanai,
\q2 ama ili i re i ɗa m panai,
\q1 utsura u Ka̱shile u ɗa,
\q2 
\v 12 n ucigi u na u tsu sabaꞋa ba, Vuzavaguɗu
\q1 Mayun vi ta̱ a kutsupa yaba dem
\q2 derere vu ulinga u ni.
\c 63
\s1 Uzuwi u ka̱ɗu a̱ ubuta̱ u Ka̱shile
\d Vishipa vu Dawuda. A makyan ma na wi a kakamba ka Yahuda.
\q1 
\v 1 Ka̱shile, avu ɗa Ka̱shile ka̱ va̱,
\q2 mayun, n la̱nsa̱ wu ta̱.
\q1 Ka̱ɗu ka̱ va̱ ki ta̱ a kakuli ka̱ nu,
\q2 ikyamba i va̱ i geshe ta̱ a kuvana wu,
\q1 a iɗika i woꞋi nu uɗekpu,
\q2 ubuta̱ u na wi n mini ba.
\q1 
\v 2 YaꞋan me ene wu a̱ ubuta̱ u ciɗa u nu,
\q2 ka̱ta̱ mi inda utsura u nu n tsugbayin tsu nu.
\q1 
\v 3 Adama a ucigi u nu u na u tsu sabaꞋa ba u laꞋa ta̱ wuma,
\q2 adama a nannai mi ta̱ a ku cikpa wu n una̱ u va̱.
\q1 
\v 4 Mi ta̱ a kucikpa wu, a ayin a wuma va̱ ra̱ka̱
\q2 mi ta̱ a̱ kuɗa̱ngusa̱ ekiye mi baci a kuyaꞋan avasa.
\q1 
\v 5 Mi ta̱ a̱ kucuwa̱ tsu vuza na u lyaꞋi ilikulyaꞋa i ka̱ɗiva̱,
\q2 ka̱ta̱ n canana ishipa i ma̱za̱nga̱ n cikpa wu.
\q1 
\v 6 Mpa a ivaꞋin a kajiba ka̱ va̱ n ciɓai n avu,
\q1 kayin n ka̱ɓula̱ n ka̱na̱i aciɓa a̱ nu,
\q1 
\v 7 adama a na avu ɗa ka̱ɓa̱nki ka̱ va̱,
\q2 n ma̱za̱nga̱ mi ta̱ a kuyaꞋan ishipa a ɗaka vu evelyu a̱ nu.
\q1 
\v 8 Ka̱ɗu ka̱ va̱ ki ta̱ gbagu n avu,
\q2 kukiye ku singai ku nu ki ta̱ uɓa̱ni nu mpa.
\q1 
\v 9 Aza a na i a̱ kula̱nsa̱ wuma u va̱ i ta̱ a kuyaꞋan wuni,
\q2 i ta̱ a̱ ku gida̱la̱ a kubana a̱ ubuta̱ wi ida̱shi ya̱ a̱kpisa̱,
\q1 
\v 10 i ta̱ a kubana ukpa̱ u kotokobi,
\q2 ikyamba i le yi ta̱ o kokpo ilikulya yi nsheꞋe n kakamba.
\q1 
\v 11 Mogono mi ta̱ a kuyaꞋan ma̱za̱nga̱ n Ka̱shile,
\q2 aza a na a yaꞋin uzuwakpani,
\q2 n kula ku Ka̱shile i ta̱ a kucikpa yi,
\q2 Ka̱shile ki ta̱ a̱ kuɓa̱ya̱ngu una̱ wa aza aꞋuwa.
\c 64
\s1 Avasa adama a uɓa̱nki
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda.
\q1 
\v 1 Ka̱shile, panaka mu, n tuka̱ baci n mavura ma̱ va̱ gogo na
\q2 ere wuma u va̱ a̱ ka̱rikpa̱ni ka irala i va̱ i na yi a kutakacika mu.
\q1 
\v 2 Ere mu a nsata n uma a gbani-gbani,
\q2 n koɓolo ka aza a kawuya.
\q1 
\v 3 O tsu gboro ta̱ elentsu e le a na otokobi,
\q2 ka̱ta̱ a gisanku ayaꞋa e le a na i kadanshi ka una̱mgbi u ka̱tsuma̱,
\q1 
\v 4 ka̱ta̱ o bopo a tawa aza babu unushi n ayaꞋa,
\q2 a tsu tawa vuza gogoꞋo lo ko wovon.
\q1 
\v 5 E ci nekpenei ta̱ kadanshi
\q2 a̱ ubuta̱ u kuyaꞋan ka gbani-gbani ke le.
\q1 O ci yongo ta̱ a kadanshi
\q2 tsu na a ku azuku ayakuru e le,
\q2 e kusheshe, <<Ko vuza u kene le ba.>>
\q1 
\v 6 A̱ tsu ka̱na̱ ta̱ kusheshe tsu na a kuyaꞋan kawuya, a dana,
\q2 <<Tsu kotso ta̱ kusheshe mayin.>>
\q2 Ka̱ɗu ka vuma ki ta̱ n awuya e kuyeve.
\q1 
\v 7 Ama Ka̱shile ki ta̱ a ku tawa le n kayaꞋa ka̱ ni,
\q2 wi ta̱ a kulapa le gogoꞋo lo.
\q1 
\v 8 Kadanshi ke kelentsu ke le, ki ta̱ o kubono a kaci ke le ka una le,
\q2 Vuzana baci we enei le dem wi ta̱ a̱ ku gba̱ɗa̱ kaci ka̱ ni.
\q1 
\v 9 Ka̱ta̱ uma ra̱ka̱ a pana wovon,
\q2 i ta̱ a kudansa ulinga u Ka̱shile,
\q1 ka̱ta̱ a̱ ka̱na̱ aciɓa adama ili i na u yaꞋin.
\q1 
\v 10 Vuza vu usuɓi wi ta̱ a kuyaꞋan ma̱za̱nga̱ u Vuzavaguɗu,
\q2 wi ta̱ a̱ kuciya̱ ubuta̱ u kusheɗeku wa̱ a̱ ni,
\q2 aza a̱ ma̱riki ra̱ka̱ i ta̱ a̱ kuciya̱ ucikpi.
\c 65
\s1 Ucikpi n ma̱za̱nga̱
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda. Vishipa.
\p 
\v 1 Ka̱shile mayun ɗa uma a cikpa wu a Sihiyona,
\q2 ka̱ta̱ e neke ili i na a kucinai kuneke.
\q1 
\v 2 Uma ra̱ka̱ i ta̱ a̱ kuta̱wa̱ wa̱ a̱ nu,
\q2 avu na vu tsu pana avasa.
\q1 
\v 3 Ɗa baci unushi u tsu u laꞋi utsura u tsu,
\q2 vu takpaka tsu u ɗa.
\q1 
\v 4 Aza a una̱singai a ɗa aza a na vu zagbai,
\q2 ɗa vu tuka̱i le ɗevu o yongo a ulanga u nu.
\q1 Ci ta̱ a̱ kucuwa̱ n kasingai ka̱ a̱ ubuta̱ wi ida̱shi i nu,
\q2 n una̱singai wa̱ A̱Ꞌisa̱ a gbayin a ciɗa a̱ nu.
\q1 
\v 5 Ka̱shile kishi ka̱ tsu,
\q2 vu ushuku tsu ta̱ a̱ ubuta̱ u kuyaꞋan ili i mereve,
\q2 n kuyaꞋan ili yi usuɓi.
\q1 Avu a̱pa̱Ꞌa̱ a uma a̱ ubuta̱ dem aduniyan,
\q2 ali a upashi u mala.
\q1 
\v 6 Avu na vu zuwai nsasan n shamgbai n utsura u nu,
\q2 ana vu foɓusoi ka̱ci ka̱ nu n utsura.
\q1 
\v 7 Avu na vu tsu vaꞋanka kacaꞋa ka mala,
\q2 n kacaꞋa ka aɓau a mala,
\q2 vu tsu vaꞋanka ta̱ ujari wu uduniyan.
\q1 
\v 8 Uma a na i a ida̱shi a uteku wa aduniyan dem,
\q2 a pana ta̱ wovon
\q2 adama ili i mereve i na vu yaꞋin.
\q1 Vu zuwa ta̱ ma̱za̱nga̱,
\q2 u uma a na i a ida̱shi a kasana n aza na i a idashi a̱ ka̱livi.
\q1 
\v 9 Vu tsu la̱na̱ ta̱ iɗika ka̱ta̱ vu yoꞋo ko i ɗa mini,
\q2 vu tsu zuwa ta̱ i ɗa yo okpo n tsuta̱ ka̱u.
\q1 Nɗolu n Ka̱shile n shanai tukpa m mini.
\q1 Vu zuwa ta̱ iɗika i nekei uma ili i kashina,
\q2 ta vu foɓusoi nannai.
\q1 
\v 10 Vu zuwai aɓakanla a̱ ta̱na̱i n mini,
\q2 ɗa vu ɓosoi yolo ya,
\q1 ɗa vu zuwa i ɗa i ta̱na̱i n ijaꞋashi,
\q2 vu zuwakai ica̱Ꞌa̱shi una̱singai.
\q1 
\v 11 Vu zuwa ta̱ ka̱ya̱ ka ko okpoi ka vukyaꞋa n a̱bunda̱i,
\q2 mpon n nu n shanai n ili kashina ali n m pasai.
\q1 
\v 12 Vu zuwai mita̱ ma̱ uta̱i gbani a kakamba adama a kalina,
\q2 ɗa aginda dem a shanai m ma̱za̱nga̱.
\q1 
\v 13 Ushiga wu nlala u palai ubuta̱ dem a̱pula̱ka̱,
\q2 a̱ra̱Ꞌa̱ a shanai n alkama.
\q1 O yoroli n cananai ishipa i ma̱za̱nga̱ tsu uma.
\c 66
\s1 Vishipa vu kucikpa adama a kasingai ka̱ Ka̱shile
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa. Ishipa.
\q1 
\v 1 A̱ɗa̱ aduniyan ra̱ka̱,
\q2 yaꞋin yoroli i ma̱za̱nga̱ u Ka̱shile.
\q1 
\v 2 Cananai ukuna u tsugbayin tsu kula ku ni,
\q2 yaꞋan ucikpi u ni u ciya̱ tsugbayin.
\q1 
\v 3 Danai Ka̱shile,
\q2 <<Yiɗa̱i a ku gisanku n ili mereve i na vi a kuyaꞋansa.
\q1 Adama a utsura ugbayin u nu,
\q2 irala i nu yi ta̱ a̱ ku kuɗa̱ngu ku wu adama o wovon.
\q1 
\v 4 Uma aduniyan dem a̱ kuɗa̱nku wu ta̱,
\q1 a ku canana ka wu ishipa,
\q2 a ku canana ishipa i kucikpa kula ku nu.>> \qs Kuvuka\qs*
\q1 
\v 5 Ta̱wa̱i ye ene ili i na Ka̱shile ka yaꞋin,
\q2 ili i mereve i na u yaꞋin adama a uma.
\q1 
\v 6 U bonokoi mala mokpoi iɗika i ɗekpu,
\q2 uma a pasai kuyene ka n e ene,
\q2 ta ɗe tsu kuyaꞋan ma̱za̱nga̱ u Ka̱shile.
\q1 
\v 7 Wi ta̱ a kulyaꞋa tsugono n utsura u ni ko wannai,
\q2 a̱shi a̱ ni i ta̱ a ku inda uduniyan.
\q2 ka̱ta̱ aza a ugbamiwasuvu ene i ta̱ n tsugbayin ba. \qs Kuvuka\qs*
\q1 
\v 8 Cikpai Ka̱shile ka̱ tsu, a̱ɗa̱ uduniyan dem,
\q2 cikpai ni n a̱la̱ka̱tsu ka̱u.
\q1 
\v 9 A̱yi ɗa u tsu foɓo wuma u tsu,
\q2 u ka̱sukpa̱ ene a̱ tsu e derece ba.
\q1 
\v 10 Adama a na avu Ka̱shile, vu kondo tsu ta̱,
\q2 vu luwa̱ tsu ta̱ tsa azurufa a na a̱ luwa̱i akina.
\q1 
\v 11 Vu tuka̱ tsu ta̱ a maza.
\q2 Vu zuwaka tsu ta̱ ucanuku wa̱ a̱miki a avangatsu a̱ tsu.
\q1 
\v 12 Vu zuwai uma a dasai tsu,
\q2 tsu tonoi e mere ma akina m mini,
\q2 ama gogo na vu utuka̱ tsu ta̱,
\q2 vu tuka̱i tsu a̱ ubuta̱ wu ida̱shi i ba̱ri.
\q1 
\v 13 Mi ta̱ a̱ kuta̱wa̱ a kpaꞋa ku nu,
\q2 n kuneꞋe ku kusongu,
\q2 ka̱ta̱ n neke ili i na n kucinai,
\q1 
\v 14 n danai mi ta̱ e kuneke wu,
\q2 a makyan ma na mi o kusoꞋo atakaci.
\q1 
\v 15 Mi ta̱ e ku neke wu kuneꞋe ku kusongu ku nnama mi ikyamba,
\q2 n ili i ma̱gula̱ i kuneꞋe ku ka̱giri,
\q2 mi ta̱ a kulyuka obomburon n nga̱ji. \qs Kuvuka\qs*
\q1 
\v 16 Ta̱wa̱i i pana, a̱ɗa̱ na yi a kupana wovon u Ka̱shile ra̱ka̱,
\q2 yaꞋan n dana ɗa̱ ili i na u yaꞋankai mu.
\q1 
\v 17 N banka ta̱ m ma̱shi ma̱ va̱ wa̱ nu,
\q2 n kelentsu ka̱ va̱ n neke wu ta̱ tsugbayin.
\q1 
\v 18 Ishi baci n zuwa ta̱ unushi a̱ ka̱ɗu ka̱ va̱,
\q2 Vuzavaguɗu wishi a kupana ka mu ba,
\q1 
\v 19 ama mayun ɗa Ka̱shile ka panakai mu,
\q2 ɗa kpamu u panai avasa a̱ va̱.
\q1 
\v 20 Una̱singai u Ka̱shile,
\q2 vuza na u iwain avasa a̱ va̱ ba,
\q2 ko u kpa̱ɗa̱i kuyotsongu mu ucigi u ni u na tsu sabaꞋa ba.
\c 67
\s1 Vishipa vu kucikpa
\d Kadanshi a kubana u vuza vu kelime vi ishipa: N anꞋin a umolu. Ishipa Vishipa
\q1 
\v 1 YaꞋan tsu ciya̱ mapasa ma singai u Ka̱shile,
\q2 u zuwaka tsu una̱singai,
\q2 ka̱ta̱ u inda tsu n a̱shi a singai a̱ ni. \qs Kuvuka\qs*
\q1 
\v 2 Adama a na aduniyan dem e yeve uye u nu,
\q2 ka̱ta̱ kpamu uduniyan u yeve wishi u nu.
\q1 
\v 3 Ka̱shile, yaꞋan uduniyan u cikpa wu,
\q2 yaꞋan uduniyan ra̱ka̱ u cikpa wu.
\q1 
\v 4 YaꞋan uduniyan u yaꞋan ma̱za̱nga̱,
\q2 a canana ishipa i ma̱za̱nga̱.
\q1 Adama a na vi ta̱ a kuyaꞋanka uduniyan afada a mayun,
\q2 ka̱ta̱ vu tono n uduniyan ra̱ka̱. \qs Kuvuka\qs*
\q1 
\v 5 Ka̱shile, yaꞋan uduniyan u cikpa wu,
\q2 yaꞋan uduniyan ra̱ka̱ u cikpa wu.
\q1 
\v 6 Iɗika i neke ta̱ ili i kashina.
\q2 YaꞋan Ka̱shile, Ka̱shile ka̱ tsu, u zuwaka tsu una̱singai.
\q1 
\v 7 YaꞋan Ka̱shile ka zuwaka tsu una̱singai,
\q2 ka̱ta̱ uma a uteku wa aduniyan ra̱ka̱, a pana wovon u ni.
\c 68
\s1 Vishipa vu lyaꞋi va aza a Isaraila
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n ka̱la̱ka̱tsu ka <<Lili>> Vishipa vu Dawuda.
\q1 
\v 1 YaꞋan Ka̱shile ka̱ ɗa̱nga̱,
\q2 yaꞋan irala i ni i wacuwa,
\q2 ka̱ta̱ aza a na a iwain ni, a suma e kelime ka̱ ni.
\q1 
\v 2 Tsu na ka̱nga̱ ka̱ tsu puwa̱nka̱,
\q2 yaꞋan vu zuwa le a̱ puwa̱nka̱ nannai.
\q1 Tsu na kabashi ki ishigi ke tsu derikpe akina,
\q2 yaꞋan una uma a gbani-gbani nannai e kelime ka̱ Ka̱shile.
\q1 
\v 3 Ama aza a usuɓi i ta̱ a kuyaꞋan ma̱za̱nga̱,
\q2 ka̱ta̱ a̱ za̱nga̱na̱ e kelime ka̱ Ka̱shile.
\q2 YaꞋan a pana uyoꞋo ka̱u.
\q1 
\v 4 Cananai ishipa u Ka̱shile,
\q2 yaꞋin ishipa i kucikpa kula ku ni,
\q2 lapulai uye adama a̱ ni, vuzana wi e ku wala eleshu.
\q1 Kula ku ni ku ɗa Vuzavaguɗu,
\q2 i za̱nga̱na̱ e kelime ka̱ ni.
\q1 
\v 5 Ka̱shile vuza na wi a ida̱shi a̱ ubuta̱ u ciɗa u ni,
\q2 esheku a mkpaꞋan a ɗa,
\q2 n ke eri ka agapa a̱ma̱ci.
\q1 
\v 6 Ka̱shile ke ci neke ta̱ aza a na i a ida̱shi endeꞋin iꞋuwa,
\q2 u tsu utuka̱ ta̱ aza a ugbashi a kubana a̱ ubuta̱ wu ida̱shi i ba̱ri.
\q1 Ama aza a ugbamiwasuvu,
\q2 i ta̱ a̱ kuda̱sa̱ngu a iɗika i na yi lekeɗi.
\q1 
\v 7 Ka̱shile, ana vu uta̱i e kelime ka uma a̱ nu,
\q2 ana vu walai a̱ ka̱pula̱ka̱, \qs Kuvuka\qs*
\q1 
\v 8 aduniya a̱ gba̱ɗa̱i
\q2 ɗa gaɗi u tuka̱i n mini,
\q2 ali n kusan ku Sinai ku gba̱ɗa̱i,
\q2 e kelime ka̱ Ka̱shile ki Isaraila.
\q1 
\v 9 Ka̱shile vu yoꞋi mini ma̱ a̱bunda̱i,
\q2 a iɗika yi uka̱ni i nu,
\q2 vu bonokoi ka̱pula̱ka̱ ubuta̱ u tsuta̱.
\q1 
\v 10 Ta ɗe uma a̱ nu a̱ da̱sa̱ngi,
\q2 Ka̱shile, vu yaꞋankai aza a unambi kasingai.
\q1 
\v 11 Vuzavaguɗu u nekei kadanshi,
\q2 ka̱kuma̱ ka̱ a̱ma̱ci ka na ka salai ukuna wa ki ta̱ n a̱bunda̱i.
\q2 
\v 12 <<Ngono mo osoji n sumai kpakaru.>>
\q2 A̱ma̱ci a na i a iꞋuwa e peciki ucanuku u na a̱ pura̱i gbani.
\q2 
\v 13 A̱ɗa̱ na i tsu asa a ushiga wu nlala,
\q2 yi ta̱ a kufuɗa kupala ka̱ci ka̱ ɗa̱,
\q2 tsu na evelyu o moɗoi a tsu pala yi,
\q2 n ucanuku wa azurufa n azanariya a kutasa.
\q1 
\v 14 Makyan ma na MalaꞋimili dem,
\q2 u zuwai ngono a iɗika,
\q2 yaꞋan egele sa̱ruwa̱ a kusan ku Zalimonu.
\q1 
\v 15 Avu kusan ku gbayin, kusan ku Bashan,
\q2 kusan ku ugaɗi, kusan ku Bashan!
\q1 
\v 16 Yiɗa̱i i zuwai avu kusan ku ugaɗi,
\q2 vi o kugoyo kusan ku Ka̱shile?
\q1 Kusan ku na Ka̱shile ki a mali,
\q2 adama a̱ ubuta̱ wu ida̱shi i ni,
\q2 ta ɗe Vuzavaguɗu u kuda̱sa̱ngu ko wannai.
\q1 
\v 17 Ekeke odoku o kuvon a̱ Ka̱shile
\q2 a laꞋa ta̱ ku kece,
\q2 a̱kpa̱n-a̱kpa̱n.
\q1 Vuzavaguɗu u ta̱wa̱i n e le,
\q2 a kusan ku Sinai ubuta̱ u ciɗa u ni.
\q1 
\v 18 Vu gaɗukpai gaɗi,
\q2 vu tonoi n ka̱bunda̱i ka agbashi a na vu ka̱na̱i,
\q2 a ku isa kuneꞋe kakau a̱ ubuta̱ uma,
\q1 ali aza a ugbamiwasuvu,
\q2 adama a na avu Vuzavaguɗu Ka̱shile vu kuda̱sa̱ngu ɗe.
\q1 
\v 19 Una̱singai u Vuzavaguɗu,
\q2 a̱yi na u ci ɗika a̱miki a̱ tsu a kanna dem,
\q2 a̱yi ɗa Ka̱shile vuza na u wawai tsu. \qs Kuvuka\qs*
\q1 
\v 20 Ka̱shile ka̱ tsu, Ka̱shile ka wishi kaꞋa,
\q2 a̱yi ɗa Vuzavaguɗu, Vuzavaguɗu vu tsu,
\q2 vuza na u tsu zuwa tsu laꞋaka a̱ ubuta̱ wu ukpa̱.
\q1 
\v 21 Mayun Ka̱shile ki ta̱ o kuɓoso aci a irala i ni,
\q2 n okolokolo aza a na a gbagbalai kutono uye wu unushi u le.
\q1 
\v 22 Vuzavaguɗu u danai, <<Mi ta̱ a̱ kuta̱wa̱ n irala a Bashan,
\q1 mi ta̱ a̱ ku kuta̱wa̱ n ele a mala ma uga̱vi.
\q1 
\v 23 Adama a na i wala a gaɗi va even a ikyamba irala i ɗa̱,
\q2 nsheꞋe n ɗa̱ feu m peɗe mpasa tsu na a cigai.>>
\q1 
\v 24 Ka̱shile uma ene ta̱ nwalu n nu mu ulyaꞋi,
\q2 nwalu n Ka̱shile ka̱ va̱, mogono ma̱ va̱, a kubana ubuta̱ u ciɗa.
\q1 
\v 25 Aza a ishipa e kelime,
\q2 aza a tsuwaꞋi tamkpamu ka̱ca̱pa̱,
\q2 e mere me le nkere a ku waꞋa nka̱la̱.
\q1 
\v 26 <<Cikpai Ka̱shile a̱ ka̱tsuma̱ ko koɓolo ka uma,
\q2 cikpai Vuzavaguɗu a̱ ɗa̱ aza a Isaraila.>>
\q1 
\v 27 Kumaci ku Bayami, ku na ku laꞋi n kenu ele ɗa kelime,
\q2 aza e kelime a Yahuda tankpamu n ka̱tsura̱ ke le,
\q2 ɗa aza e kelime a Zabalun n aza a Nafutali o kutono le.
\q1 
\v 28 Ka̱shile, ɗa̱ngusa̱ utsura u nu,
\q2 Ka̱shile yotsongu utsura u nu adama a̱ tsu,
\q1 
\v 29 A̱Ꞌisa̱ a gbayin a̱ nu a Urushelima.
\q2 Ngono mi ta̱ a̱ kutuka̱ wu n kuneꞋe.
\q1 
\v 30 Ɓarangu nnama n na mi a̱ ka̱ga̱Ꞌin ka̱ mini,
\q2 ɓarangu uduniyan u na u buwai,
\q2 koɓolo ko obomburon nu ndendem n le.
\q1 Ali a̱ kuɗa̱ngu ka̱ta̱ e neke wu azurufa e le,
\q2 vu wacuwa uduniyan,
\q2 u na u tsu ciga kuvon!
\q1 
\v 31 Anan taji uta̱i a Masar,
\q2 aza a Itopiya i ta̱ a̱ ku ɗa̱ngusa̱ ekiye e le gaɗi u Ka̱shile.
\q1 
\v 32 Cananai ishipa u Ka̱shile, a̱ɗa̱ tsugono tsa aduniyan,
\q2 yaꞋin ishipa i kucikpa Vuzavaguɗu, \qs Kuvuka\qs*
\q1 
\v 33 a̱yi vu na u kumbai gaɗi vu a̱da̱nga̱shile a ayain a cau,
\q2 zuwakai n ka̱la̱ka̱tsu ka utsura ka̱ ni.
\q1 
\v 34 Salai utsura u Ka̱shile,
\q2 vuza na tsugbayin ci ni ci a Isaraila,
\q2 vuza na utsura u ni wi a gaɗi vu eleshu.
\q1 
\v 35 Ka̱shile ili i wovon i ɗa a ubuta̱ u ciɗa u ni,
\q2 Ka̱shile ki Isaraila,
\q2 ki ta̱ e kuneke utsura a uma a̱ ni.
\q1 Una̱singai u Ka̱shile.
\c 69
\s1 Wawa mu Ka̱shile
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Tsu ka̱la̱ka̱tsu ka̱ <<A̱pa̱lu.>>Vishipa vu Dawuda.
\q1 
\v 1 Ka̱shile wawa mu,
\q2 adama a na mini ma yawa mu ta̱ e kuɗeku.
\q1 
\v 2 Mi ta̱ a kuliɓa a̱ ubuta̱ o kolyoꞋo ka̱u,
\q2 babu ubuta̱ u kudasa,
\q1 n yikpa̱ ta̱ a̱ mini mu uga̱vi,
\q2 aɓau kpamu i ta̱ a̱ ku kimba̱ mu.
\q1 
\v 3 Mo oꞋwo ta̱ m meɗevile, a̱ kula̱nsa̱ uɓa̱nki,
\q2 ali ka̱la̱ka̱tsu ka̱ va̱ ka paɗai.
\q1 A̱shi a̱ va̱ ra̱ka̱ a̱ ga̱la̱i,
\q2 adama a na n zuwa ta̱ a̱shi a̱ kula̱nsa̱ Ka̱shile ka̱ va̱.
\q1 
\v 4 Aza a na a iwain mu ko ili,
\q2 a laꞋa ta̱ ka̱nji ka kaci ka̱ va̱ a̱bunda̱i.
\q1 Aza a na a cigai ku una mu ko ili i ta̱ n utsura,
\q2 a gutsakai mu n tsupa ili i na m bokoi ba.
\q1 
\v 5 Ka̱shile, vu yeve ta̱ tsulau tsu va̱,
\q2 unushi u va̱ wi usokongi wa̱ a̱ nu ba.
\q1 
\v 6 Ka̱ta̱ vu ka̱sukpa̱ mu n neke
\q2 aza a na a zuwai ka̱ɗu wa̱ nu a pana wono ba,
\q2 Vuzaguɗu, Ka̱shile MalaꞋimili,
\q1 ka̱ta̱ vu ka̱sukpa̱ mu n tuka̱ n ili wono
\q2 wa aza a na i a̱ kula̱nsa̱ Ka̱shile ki Isaraila ba.
\q1 
\v 7 Adama a̱ nu a ɗa mo okpoi ili yi ishikushi,
\q2 ali wono u kimba̱i mu.
\q1 
\v 8 Tsu komoci kaꞋa mi wa̱ aza a̱ va̱,
\q2 ali n aza a kpaꞋa a̱ va̱ dem mo okpoi o limoci we le.
\q1 
\v 9 Mali ma A̱Ꞌisa̱ a gbayin a̱ nu,
\q2 ma zuwa mu ta̱ a̱ ku kula̱ tsa akina
\q2 ishikushi i na i a kuyaꞋanka wu yi okpo ta̱ a kaci ka̱ va̱.
\q1 
\v 10 Ana shika̱i n yaꞋin kakuli,
\q2 ɗa wo okpoi mu ili yi ishikushi.
\q1 
\v 11 N ukai akashi a kpalu,
\q2 ɗa mo okpoi ili ya agivi.
\q1 
\v 12 Mo okpoi ili i kadanshi a uye dem,
\q2 osoꞋi kpamu a kuyaꞋanka mu ishipa.
\q1 
\v 13 Ama mpa mi ta̱ a kuvasa wa̱ a̱ nu, Vuzavaguɗu,
\q2 ushuku mu Ka̱shile, a makyan ma na wu untsai nu,
\q2 adama ucigi u gbayin u nu u na u tsu sabaꞋa ba,
\q2 adama a na vi ta̱ a kushatangu ukuna u wishi wu usuɓi u nu.
\q1 
\v 14 Wawa mu o kolyoꞋo adama a na ka̱ta̱ n liɓa ba,
\q2 wawa mu ekiye aza a na a iwain mu,
\q2 a̱ mini mu uga̱vi ma nampa kpamu.
\q1 
\v 15 Ka̱ta̱ vu ka̱sukpa̱ aɓau a̱ kimba̱ mu ba,
\q2 ka̱ta̱ vu ka̱sukpa̱ mini mu uga̱vi ma lyaꞋa mu ba,
\q2 ka̱ta̱ vu ka̱sukpa̱ kpenle ku ukpa̱ ku tsugba mu ba.
\q1 
\v 16 Vuzavaguɗu, adama a ucigi u singai u nu u na u tsu sabaꞋa ba,
\q2 ushuku mu,
\q2 adama asuvayali a̱bunda̱i a̱ nu, panaka mu.
\q1 
\v 17 Ka̱ta̱ vu sokongu ka̱ci ka̱ nu u kagbashi ka̱ nu ba,
\q2 mi ta̱ o kusoꞋo atakaci,
\q2 yaꞋan gogoꞋo vu ushuku mu.
\q1 
\v 18 Ta̱wa̱ ɗevu vu shiba̱ mu,
\q2 adama a irala i va̱.
\q1 
\v 19 Vu yeve ta̱ tsu na i a kushika mu,
\q2 n tsu na i a ku lukanasa mu, n tsu na o goyoi mu,
\q2 vu yeve ta̱ aza a na i a kutakaci mu ra̱ka̱.
\q1 
\v 20 Ka̱ɗu ka̱ va̱ ka̱ gusa̱ ta̱ adama a ishikushi i na i a kuyaꞋanka mu,
\q2 ali n takpai asuvu.
\q1 N zuwa ta̱ ka̱ɗu i ta̱ a̱ kusa̱Ꞌa̱ mu,
\q2 ama ko vuza.
\q1 N zuwai ka̱ɗu ko mi ta̱ a̱ kuciya̱ vuza na u kuneke mu kadanshi,
\q2 ama n ciya̱ ba.
\q1 
\v 21 Makyan ma na m panai kambulu,
\q2 ɗa e nekei mu yaza,
\q2 ana kakuli ka̱ ka̱na̱i mu,
\q2 ɗa e nekei mu mini ma kalam.
\q1 
\v 22 Ka̱shile, yaꞋan ka̱ɗiva̱ ke le ko okpo le yakuru,
\q2 yaꞋan ida̱shi i ma̱ta̱na̱ i le yo okpo le maza.\f + \fr 69:22 \ft Ubuta̱ wa wi ta̱ a kadanshi ugboku u re, aza a yoku e yevei ta̱, yaꞋan ka̱ɗiva̱ ke le ko okpo maza wa̱ a̱ja̱Ꞌa̱ e le, aza a yoku tankpamu e yevei ta̱, yaꞋan ida̱shi i ma̱ta̱na̱ i le yo okpo le maza.\f*
\q1 
\v 23 Zuwa a̱shi ele a yaꞋan rumbu-rumbu
\q2 ali a̱ kukpa̱ɗa̱ ku ene,
\q2 ka̱ta̱ vu zuwa a̱cina̱ e le o kogo ko wannai.
\q1 
\v 24 Tsuwa̱nka̱ le wupa u nu,
\q2 yaꞋan asuvu a usuɗukpi a̱ nu a lyaꞋa utsura u le.
\q1 
\v 25 Ka̱shile, yaꞋan ka̱tsura̱ ke le ko okpo lekeɗi,
\q2 ka̱ta̱ vuza u da̱sa̱ngu punu a̱pa̱m e le ba.
\q1 
\v 26 Adama a na a takacika ta̱ aza a na vu yaꞋankai usa̱n,
\q2 i a kadanshi ka̱ mɓa̱la̱ ma aza a na vu lapai.
\q1 
\v 27 Doku le unushi a̱ ka̱tsuma̱ ka̱ unushi u le,
\q2 ka̱ta̱ vu ka̱sukpa̱ le a̱ ciya̱ upecu wu ili yi usuɓi i nu ba,
\q1 
\v 28 Zuwa a takpa kula ku le a katagarda ka wuma,
\q2 ka̱ta̱ vu kece le a̱ ka̱tsuma̱ ka uma a usuɓi ba.
\q1 
\v 29 Ama mi ta̱ a̱ ka̱tsuma̱ ka atakaci nu mɓa̱la̱,
\q2 Ka̱shile, yaꞋan wishi u nu wu ere mu.
\q1 
\v 30 Mi ta̱ a kucikpa kula ku Ka̱shile n ishipa,
\q2 mi ta̱ a kusala tsugbayin ci ni a̱ ubuta̱ u kucikpa yi.
\q1 
\v 31 Nannai va wi ta̱ a kuzuwa Vuzavaguɗu u pana uyoꞋo,
\q2 u laꞋa alyuka e medendem,
\q2 u laꞋa kuneꞋe ku kobomburon.
\q1 
\v 32 Ayin a na baci aza a na o goyoi ka̱ci ke le enei nannai,
\q2 i ta̱ a kuyaꞋan ma̱za̱nga̱.
\q1 Aza a na i a̱ kula̱nsa̱ Ka̱shile,
\q2 i ta̱ a̱ kuciya̱ utsura u ka̱ɗu.
\q1 
\v 33 Vuzavaguɗu u panaka ta̱ aza a unambi,
\q2 u tsu goyo uma a̱ ni a na i a ugbashi ba.
\q1 
\v 34 Cikpai Ka̱shile, gaɗi n iɗika, cikpai ni,
\q2 mala n ili i wuma i na yi punu dem.
\q1 
\v 35 Adama a na Ka̱shile ki ta̱ a ku wawa Sihiyona,
\q2 u maꞋasaka likuci ya aza a Yahuda,
\q2 uma a̱ ni i ta̱ a̱ kuda̱sa̱ngu ɗe a lyaꞋa uka̱ni wi iɗika ya.
\q1 
\v 36 Ntsukaya ma agbashi a̱ ni i ta̱ a kulyaꞋa uka̱ni wi i ɗa,
\q2 aza a na i a kuciga yi i ta̱ a̱ kuyongo ɗe.
\c 70
\s1 Avasa a̱ kula̱nsa̱ uɓa̱nki
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda. Adama a ku ciɓasa.
\r (Ishp 40:13-17)
\q1 
\v 1 Ka̱shile, yaꞋan moloko vu wawa mu,
\q2 Vuzavaguɗu, yaꞋan moloko vu ɓa̱nka̱ mu.
\q1 
\v 2 YaꞋan aza a na i a̱ kula̱nsa̱ wuma u va̱,
\q2 okpo n wono ali a̱ ripula̱.
\q1 YaꞋan aza a na a cigai ene mu atakaci,
\q2 okpo nu nlukana.
\q1 
\v 3 YaꞋan aza a na i a kudana, <<U yaꞋan ta̱, u yaꞋan ta̱,>>
\q2 a kpatala n wono.
\q1 
\v 4 Ama yaꞋan aza a na i a̱ kula̱nsa̱ wu ra̱ka̱,
\q2 a pana uyoꞋo a yaꞋan kpamu ma̱za̱nga̱ wu nu.
\q1 YaꞋan aza a na i a kuciga wishi u nu ko wannai,
\q2 a dana, <<Ka̱shile vuzagbayin ɗa.>>
\q1 
\v 5 Ama mpa vuza vu unambi ɗa, n vuza vu yali,
\q2 Ka̱shile, yaꞋan moloko,
\q1 adama a na avu ɗa ka̱ɓa̱nki ka̱ va̱ n kishi ka̱ va̱,
\q2 Vuzavaguɗu ka̱ta̱ vu geshe ba.
\c 71
\s1 Avasa a vuza vu gba̱ra̱
\q1 
\v 1 Vuzavaguɗu, yaꞋan n sheɗekeu wa̱ nu,
\q2 ka̱ta̱ vu ka̱sukpa̱ mu m pana wono ba.
\q1 
\v 2 Uta̱ka̱ mu, vu ɓa̱nka̱ mu n laꞋaka,
\q2 adama a usuɓi u nu,
\q2 zuwaka mu atsuvu, vu wawa mu.
\q1 
\v 3 Vu okpo ubuta̱ u kusheɗeku u va̱,
\q2 ubuta̱ u na n kubansa makyan dem.
\q1 Neke kadanshi a wawa mu,
\q2 adama a na avu ɗa ubuta̱ u kusheɗeku u va̱,
\q2 m mashilya me ku ere mu.
\q1 
\v 4 Ka̱shile ka̱ va̱, uta̱ka̱ mu e ekiye aza a kawuya,
\q2 a utsura wa aza asuvawuya n ka gbani-gbani.
\q1 
\v 5 Adama a na wa̱ nu ɗa n keɗei a̱pa̱Ꞌa̱, Vuzavaguɗu,
\q2 Vuzavaguɗu, wa̱ nu ɗa n zuwai ka̱ɗu ali mpa maku me kenu.
\q1 
\v 6 N gbasatangu ta̱ wa̱ nu kafu a matsa mu,
\q2 avu ɗa vu utuka̱i mu a̱ ka̱tsuma̱ ka̱ a̱na̱ku a̱ va̱,
\q2 mi ta̱ a kucikpa wu makyan dem.
\q1 
\v 7 Mo okpoi ili yi urotu a̱ ubuta̱ uma n a̱bunda̱i,
\q2 adama a na avu ɗa
\q2 ubuta̱ u kusheɗeku wu utsura u va̱.
\q1 
\v 8 Una̱ u va̱ wi ta̱ a kucikpa wu, kanna ka̱ɓula̱,
\q2 a kusala tsugbayin tsu nu.
\q1 
\v 9 Gogo na ana n kutsai na,
\q2 ka̱ta̱ vu varuku mu ba,
\q2 ana utsura u va̱ u kotsoi na,
\q2 ka̱ta̱ vu ka̱sukpa̱ mu ba.
\q1 
\v 10 Irala i va̱ yi ta̱ a kadanshi ka̱ va̱,
\q2 aza a na cigai ku una mu o ɓolongu ta̱ a nsata adama a̱ va̱.
\q1 
\v 11 A danai, <<Ka̱shile ka̱ ka̱sukpa̱ yi ta̱,
\q2 yaꞋan tsu guva yi tsu reme yi,
\q2 adama a na vuza u kuɓa̱nka̱ yi u laꞋaka ba.>>
\q1 
\v 12 Ka̱shile, ka̱ta̱ vu bana daꞋangi nu mpa ba,
\q2 Ka̱shile ka̱ va̱, ta̱wa̱ gogoꞋo vu ɓa̱nka̱ mu.
\q1 
\v 13 YaꞋan aza a na i e ku neꞋeshe mu unushi,
\q2 okpo n wono ka̱ta̱ a̱ kuwa̱.
\q1 YaꞋan aza a na a cigai ene mu atakaci,
\q2 a̱ ciya̱ kugoyi nu nlukana.
\q1 
\v 14 Ama mpa mi ta̱ a kuzuwa ka̱ɗu ka̱ va̱ wa̱ nu makyan dem,
\q2 mi ta̱ a kulyaꞋa kelime n kucikpa wu.
\q1 
\v 15 Una̱ u va̱ wi ta̱ a kudansa ukuna wu usuɓi u nu,
\q2 kanna ka̱ɓula̱ mpa a kudansa ukuna u wishi u nu,
\q2 ko a na wo okpoi mi a kufuɗa kuyeve le dem ba.
\q1 
\v 16 Vuzavaguɗu Ka̱shile, mi ta̱ a̱ kuta̱wa̱,
\q2 adama a na n sala ulinga u gbayin u nu,
\q2 ka̱ta̱ n ciɓaka uma ukuna wu usuɓi u nu, avu endeꞋin.
\q1 
\v 17 Ka̱shile, avu ɗa vu piꞋisakai mu ali mpa maku me kenu,
\q2 ali n anana mi ta̱ a kudansa ukuna u mereve u nu.
\q1 
\v 18 Ko gogoꞋo na ana n kutsai n yaꞋin ka̱nji ka̱ri,
\q2 Ka̱shile, ka̱ta̱ vu ka̱sukpa̱ mu ba,
\q1 ali n dansa ukuna wu utsura u nu n tsugbayin tsu nu
\q2 a kubana a ntsukaya n na n kuta̱wa̱.
\q1 
\v 19 Ka̱shile, usuɓi u nu,
\q2 u yawa ta̱ gaɗi vu eleshu.
\q1 Vu yaꞋan ta̱ ili i gbagbaꞋin.
\q2 Ka̱shile, vuza wi lo tsu nu ba.
\q1 
\v 20 Ko ana wo okpoi vu ka̱sukpa̱ mu ta̱ me enei atakaci m ma̱dukpa̱ ka̱u,
\q2 vi ta̱ o kubonoko mu n wuma u va̱ ayin tutu.
\q1 Punu a kasaun,
\q2 vi ta̱ a̱ kuɗa̱ngusa̱ mu kpamu ayin tutu.
\q1 
\v 21 Vi ta̱ o kudoku mu tsugbayin,
\q2 ka̱ta̱ vu kparasa mu kpamu.
\q1 
\v 22 Ka̱shile ka̱ va̱, mi ta̱ kpamu a kucikpa wu n umolu,
\q2 adama a kamayun ka̱ nu.
\q1 N umolu u va̱ mi ta̱ a kuyaꞋanka wu ishipa,
\q2 vuza ciɗa vi Isaraila.
\q1 
\v 23 Mi ta̱ a̱ ku ɗa̱ngusa̱ ka̱la̱ka̱tsu n isali i ma̱za̱nga̱,
\q2 ayin ana mi a kucikpa wu n ishipa,
\q2 adama a na vu shiba̱ mu ta̱.
\q1 
\v 24 Ka̱ta̱ kelentsu ka̱ va̱ ka dansa ukuna wu usuɓi u nu kanna ka̱ɓula̱.
\q1 Aza a na a cigai ene mu atakaci
\q2 okpo n wono n kugoyi.
\c 72
\s1 Mogono ma na Ka̱shile ka zagbai
\d Vishipa vu Sulemanu.
\q1 
\v 1 Ka̱shile, yotsongu mogono tsu na u kuyaꞋan afada a mayun,
\q2 vu zuwa maku mo mogono ma yaꞋan ukuna wu usuɓi.
\q1 
\v 2 YaꞋan u yaꞋanka uduniyan u nu afada a usuɓi,
\q2 u yaꞋanka uma u nu aza a unambi ukuna u mayun.
\q1 
\v 3 YaꞋan nsasan n tuka̱ n ma̱ta̱na̱ a̱ ubuta̱ u uma,
\q2 ka̱ta̱ aginda a̱ tuka̱ n ukuna wu usuɓi.
\q1 
\v 4 YaꞋan mogono ma yaꞋanka aza a unambi afada a mayun,
\q2 u ɓa̱nka̱ muku mo ofoloni,
\q2 ka̱ta̱ u takacika aza o modoruko.
\q1 
\v 5 YaꞋan a pana wovon u nu kanna ki baci lo ko wannai,
\q2 wotoi kpamu wi baci lo tsukaya a kubana a tsukaya.
\q1 
\v 6 YaꞋan mogono mo okpo tsu mini ma na o yoꞋi a̱ mita̱ ma na a kiꞋwain,
\q2 wo okpo ci ijaꞋashi a iɗika.
\q1 
\v 7 YaꞋan aza a usuɓi o gbonguro tsu nɗanga a ayin e le,
\q2 yaꞋan a̱ ciya̱ ma̱ta̱na̱ ba̱ri ko wannai wotoi wi baci e kuneke kutashi.
\q1 
\v 8 YaꞋan tsugono ci ni ci yawa
\q2 a mala ma nampa a kubana a ma nanɗe,
\q2 ili i na i ɗikai e kuyene ku Yufiretu, ali a kubana uteku wa aduniyan.
\q1 
\v 9 YaꞋan kumaci ku na ki a kakamba ku kuɗa̱ngu e kelime ka̱ ni,
\q2 yaꞋan irala i ni i ku kuɓa̱ n kubuta̱ ki iɗika.
\q1 
\v 10 YaꞋan ngono n Tarishi n na mi o kotogu,
\q2 a̱ tuka̱ yi n kuneꞋe,
\q1 yaꞋan ngono n Sheba nu n Seba
\q2 n neke yi n kuneꞋe.
\q1 
\v 11 YaꞋan ngono ra̱ka̱ n ku kuɗa̱nku yi,
\q2 yaꞋan uduniyan ra̱ka̱ a yaꞋanka yi a̱ga̱nda̱.
\q1 
\v 12 Adama a na wi ta̱ a ku wawa aza a unambi,
\q2 ayin a na baci e ɗekei ni,
\q2 aza atakaci, n aza a na i n ka̱ɓa̱nki ba.
\q1 
\v 13 Wi ta̱ a̱ kusa̱Ꞌa̱ aza a babu utsura n aza a unambi,
\q2 ka̱ta̱ u wawa wuma wa aza a na i a kula̱nsa̱ uɓa̱nki.
\q1 
\v 14 Wi ta̱ a̱ kushiba̱ le ekiye aza o modoruko n a̱shiliki,
\q2 wuma u le wi ta̱ n tsuloboi a̱ a̱shi a̱ ni.
\q1 
\v 15 YaꞋan wuma u mogono u geshe,
\q2 yaꞋan e neke yi azanariya a Sheba,
\q1 yaꞋan uma a yaꞋanka yi avasa,
\q2 a zuwaka yi una̱singai makyan dem.
\q1 
\v 16 YaꞋan a̱ ciya̱ ishina yi a̱bunda̱i a iɗika ya,
\q2 yaꞋan ishina i gbugba̱ aginda dem.
\q1 YaꞋan umaci u le u yimkpa tsu nɗanga n Lebano,
\q1 yaꞋan likuci i shana n uma,
\q2 tsu mita̱ ma na mi a kakamba.
\q1 
\v 17 YaꞋan a ciɓasa n kula ku mogono ko wannai,
\q2 u lyaꞋa kelime n kuyaꞋan kula, kanna ki baci lo ko wannai,
\q1 yaꞋan uduniyan ra̱ka̱ u ciya̱ una̱singai wa̱ ni,
\q2 ka̱ta̱ e ɗeke yi vuza vu una̱singai.
\q1 
\v 18 Una̱singai a kubana u Vuzavaguɗu Ka̱shile, Ka̱shile ki Isaraila,
\q2 vuza na a̱yi ɗa koci u ci yaꞋan ili i mereve.
\q1 
\v 19 Una̱singai a kubana u kula ku tsugbayin ku ni ko wannai,
\q2 yaꞋan tsugbayin ci ni ci shana aduniyan ra̱ka̱.
\q2 Ta nannai! Ta nannai!
\b
\q1 
\v 20 Na ɗa ukocishi wa avasa a Dawuda maku Jesi.
\c 73
\ms1 Katagarda ka tatsu
\mr (Ishp 73--89)
\s1 Kasingai ka̱ Ka̱shile
\d Vishipa vu Asafa.
\q1 
\v 1 Mayun Ka̱shile ki ta̱ a kuyaꞋanka Isaraila kasingai,
\q2 wa aza a na a̱ɗu e le i ciɗa.
\q1 
\v 2 Ama mpa n yaꞋan ta̱ ɗevu n kutakpa asuvu,
\q2 ali ka̱ɗu ka̱ va̱ ka yaꞋin ɗevu n ku uta̱.
\q1 
\v 3 Adama a na mi ta̱ e cisheꞋe n aza a ugbamukaci,
\q2 ɗa baci me enei uma a gbani-gbani a lyaꞋi kelime n kuciya̱ ma̱ta̱na̱.
\q1 
\v 4 A tsu takacika ba,
\q2 ikyamba i le yi ta̱ gbaga n utsura.
\q1 
\v 5 A tsu takacika tsu uma a na a buwai ba,
\q2 kawuya ka̱ tsu ciya̱ le tsu aza a na buwai ba.
\q1 
\v 6 Adama a nannai ɗa a ɗikai a̱ra̱ɗi okpoi le itali i kuɗeku,
\q2 ɗa a zuwai vishili vu okpoi le tsu motogu.
\q1 
\v 7 Ka gbani-gbani ka tsu ta̱ a̱ɗu e le,
\q2 kusheshe ku le dem nsata n ɗa.
\q1 
\v 8 O tsu zoꞋoso ta̱ aza o yoku,
\q2 ka̱ ta̱ a dansa ka gbani-gbani,
\q2 e kusheshe n a̱ra̱ɗi tsu na o kudoro aza o yoku.
\q1 
\v 9 A tsu dansa ta̱ kadanshi ka ishikushi u Ka̱shile ka gaɗi,
\q2 Elentsu e le i ta̱ a kadanshi ka̱ a̱ra̱ɗi a ili i na a yaꞋin aduniyan.
\q1 
\v 10 Adama a na uma a̱ Ka̱shile o bono we le,
\q2 ushuku n ili i na a dansai.
\q1 
\v 11 A tsu dana ta̱, <<Nini ɗai Ka̱shile ke kuyeve?
\q2 MalaꞋimili mi ta̱ e kuyeve?>>
\q1 
\v 12 Ta uma a gbani-gbani i nannai,
\q2 makyan dem i n kadama ba,
\q2 uciyi u le o kudoku.
\q1 
\v 13 Mayun, gbani ɗa m bonokoi ka̱ɗu ka̱ va̱ ciɗa,
\q2 gbani ɗa mu uta̱ka̱i ekiye a̱ va̱.
\q1 
\v 14 Kanna dem mpa e kene kadama,
\q2 usana lakam mpa atakaci.
\q1 
\v 15 Ishi baci n dana ta̱, <<Mi ta̱ a kudansa nannai.>> Mi ishi ta̱ a̱ ku vakangu muku n nu.
\q1 
\v 16 Ana n yaꞋin tsu na n kuyaꞋan
\q2 adama a na n yeve,
\q2 yiɗa̱i i zuwai ɗa uma a gbani-gbani i a kulyaꞋa kelime,
\q1 ɗa wo okpoi mu n atakaci ka̱u.
\q1 
\v 17 Ama ana n uwai ubuta̱ u ciɗa u Ka̱shile,
\q2 ɗa n yevei ili i na i kuciya̱ uma gbani-gbani.
\q1 
\v 18 Mayun ɗa vi ta̱ a kuzuwa le a̱ ubuta̱ u kederi,
\q2 vu zuwai le a̱ yikpa̱i ɗa a̱ kuwa̱i ra̱ka̱.
\q1 
\v 19 GogoꞋo lo ɗa unai le,
\q2 wovon u pura̱ngi le n ku te.
\q1 
\v 20 Vuzavaguɗu, i ta̱ o ko okpo tsa alatani,
\q2 a na a tsu cinukpa n usana,
\q2 tsu na vuza u tsu cinukpa a ɗa u jimgba baci.
\q1 
\v 21 Makyan ma na baci ka̱ɗu ka̱ va̱ ka̱ na̱mgba̱i,
\q2 ɗa ka̱ɗu ka̱ va̱ ka̱ ɗa̱nga̱i,
\q1 
\v 22 Ka̱ta̱ yeve a na mpa kalau kaꞋa ko ugboji,
\q2 ɗa mo okpoi tsu manama e kelime ka̱ nu.
\q1 
\v 23 N nannai dem mi ta̱ koɓolo n avu makyan dem,
\q2 vi ta̱ uɓa̱ni n kukiye ku u singai ku va̱.
\q1 
\v 24 Vi o kutono nu mpa n odoki a̱ nu,
\q2 a ukocishi kpamu vi ta̱ a ku isa mu n tsugbayin.
\q1 
\v 25 Avu ɗa mi n a̱yi koci gaɗi,
\q2 a na mi n avu, yiɗa̱i kpamu mi a̱ kula̱nsa̱ aduniyan?
\q1 
\v 26 Ikyamba n ka̱ɗu ka̱ va̱,
\q2 i ta̱ a kufuɗa ku kuwa̱,
\q2 ama Ka̱shile avu ɗa utsura u ka̱ɗu u va̱,
\q2 n ili i na mi n i ɗa ko wannai.
\q1 
\v 27 Mayun aza a na i daꞋangi n avu i ta̱ a̱ ku kuwa̱,
\q2 vi ta̱ a ku una aza a cishakanlai o kutono a̱ma̱li.
\q1 
\v 28 Ama n tsu va̱,
\q2 u laꞋaka mu ta̱ n kugaꞋan n yongo ɗevu n Ka̱shile,
\q2 m bonoko ta̱ Vuzavaguɗu Ka̱shile ubuta̱ u kusheɗeku u vu,
\q2 adama a na n sala ili i na u yaꞋin ra̱ka̱.
\c 74
\s1 Avasa a̱ kula̱nsa̱ wishi
\d VicuꞋu vu tsuwaꞋi tsu Asafa
\q1 
\v 1 Ka̱shile, yiɗa̱i i zuwai ɗa vu variki tsu ko wannai?
\q2 A̱tsu ushiga wu nkyon wu ubuta̱ u kalina u nu u ɗa,
\q2 yiɗa̱i i zuwai ɗa vi asuvu a usuɗukpi n a̱tsu?
\q1 
\v 2 Ciɓa n koɓolo ka uma a̱ nu a na vu tsulai ali n ayin a cau ɗe,
\q2 a na vu shiba̱i okpo kumaci ku uka̱ni ku nu,
\q2 ciɓa n Kusan ku Sihiyona ubuta̱ u na vu da̱sa̱ngi.
\q1 
\v 3 Ta̱wa̱ vu ka̱ra̱Ꞌa̱ ubuta̱ u na a̱ la̱nga̱sa̱i na ra̱ka̱ ra̱ka̱.
\q2 Irala i la̱nga̱sa̱ ta̱ ili i na yi punu ra̱ka̱ a̱ ubuta̱ u ciɗa.
\q1 
\v 4 Aza a na a iwain nu i ta̱ o yoroli yi ulyaꞋi,
\q2 a̱ ubuta̱ u na vu tsu gasa n a̱tsu,
\q2 a zuwai urotu u le ɗe.
\q1 
\v 5 I ta̱ tsu aza a na i a kukapa nɗanga a̱ kutsun
\q2 n ogovu e le.
\q1 
\v 6 N ogovu e le nu ntalaka n le
\q2 a̱ la̱nga̱sa̱i ili i na e sheꞋwei.
\q1 
\v 7 Ɗa o songi A̱Ꞌisa̱ a gbayin a̱ nu ra̱ka̱,
\q2 a natukpai ubuta̱ wu ida̱shi i kula ku nu.
\q1 
\v 8 A danai ka̱ci ke le <<Ci ta̱ a̱ kuka̱na̱ i ɗa gbende,>>
\q2 ɗa o songi ubuta̱ u na a tsu gasa n Ka̱shile dem, a iɗika ya.
\q1 
\v 9 Tsu doku tsu ene urotu ba,
\q2 eneki kpamu a buwa ba,
\q2 kpamu ko vuza a̱ ka̱tsuma̱ ka̱ tsu u yeve,
\q2 ko wannai ɗai ili i nampa i kukotso.
\q1 
\v 10 Ka̱shile, ali n wannai ɗai irala i ku ka̱na̱ ku zoꞋoso tsu?
\q2 I ta̱ a̱ kuka̱na̱ kugoyo kula ku nu ko wannai ɗa?
\q1 
\v 11 Yiɗa̱i i zuwai ɗa vu oɓongi ekiye a̱ nu?
\q2 Ɗa̱ngusa̱ kukiye ku usingai ku nu vu una le.
\q1 
\v 12 Ama Ka̱shile, avu ɗa mogono ma̱ va̱ ali n cau ɗe,
\q2 vu tsu tuka̱ ta̱ n wishi aduniyan.
\q1 
\v 13 Avu ɗa vu pecei mala n utsura u tsugbayin u nu,
\q2 vu ɓosoi aci oroꞋo a̱ mini.
\q1 
\v 14 Avu ɗa vu minjarai kaci ka̱ ka̱di ka mala,
\q2 ɗa vu nekei ni wo okpoi ilikulyaꞋa yi nnama n kakamba.
\q1 
\v 15 Avu ɗa vu ta̱sa̱i a̱shi a̱ mini n ayinva,
\q2 vu zuwai kuyene ku ɗekpei.
\q1 
\v 16 Kanna n kayin ka̱nu kaꞋa,
\q2 avu ɗa vu zuwai wotoi n kanna a̱ ubuta̱ u le.
\q1 
\v 17 Avu ɗa vu zuwakai aduniyan kureꞋe,
\q2 avu ɗa vu yaꞋin lyushi n irana.
\q1 
\v 18 Vuzavaguɗu, ciɓa n tsu na irala i nu yi o ku zoꞋoso wu,
\q2 n tsu na kpamu alau i o kugoyo kula ku nu.
\q1 
\v 19 Ka̱ta̱ vu neke wuma wu nkyon n nu
\q2 wa̱ a̱kunzu ba,
\q2 ka̱ta̱ vu cinukpa n uma a̱ nu a na a takacikai ba, ko wannai.
\q1 
\v 20 Ciɓa n uzuwakpani u na vu yaꞋankai tsu,
\q2 obogozu a na i n ka̱yimbi a iɗika dem,
\q2 i ta̱ tukpa n aza a ujari.
\q1 
\v 21 Ka̱ta̱ vu ka̱sukpa̱ aza a na a takacikai
\q2 okpo n wono ba,
\q1 yaꞋan aza a unambi n aza a̱ kula̱nsa̱ uɓa̱nki
\q2 a cikpa kula ku nu.
\q1 
\v 22 Ka̱shile, ɗa̱nga̱ vu utuka̱ ka̱ci ka̱ nu,
\q2 ciɓa tsu na alau i o ku zoꞋoso wu kanna dem.
\q1 
\v 23 Ka̱ta̱ vu cinukpa n kadanshi ka kacaꞋa ka aza a na a iwai nu ba,
\q2 ka̱ta̱ vu cinukpa m mololo ma aza a na i a kuyaꞋanka wu ugbamiwasuvu ba.
\c 75
\s1 Ka̱shile ki ta̱ a kuyaꞋan afada derere
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Asafa, a yaꞋan vu ɗa n Ka̱la̱ka̱tsu, <<Ka̱ta̱ a yaꞋan munuka ba.>>
\q1 
\v 1 Ka̱shile, tsu cikpa wu ta̱,
\q2 tsu cikpa ta̱ kula ku nu adama a na vi ta̱ lo,
\q2 tsu dansai ili i mereve i na vu yaꞋin.
\q1 
\v 2 Vuzavaguɗu Ka̱shile u danai, <<N zuwa ta̱ makyan ma afada,
\q2 mi ta̱ tana a kuyaꞋan afada a na i derere.
\q1 
\v 3 Ko ɗa baci aduniyan e jengeɗei, ali uma a̱ ni e jeꞋekei ikyamba,
\q2 mpa ɗa n zuwai kumiꞋi u ni u shamgbai n utsura. \qs Kuvuka\qs*
\q1 
\v 4 N dana ta̱ aza a̱ra̱ɗi,<Ka̱ta̱ i yaꞋan a̱ra̱ɗi ba.>
\q2 uma a gbani-gbani kpamu,
\q2 n danai, <Ka̱ta̱ i yaꞋan ugbamiwasuvu ba.
\q1 
\v 5 Ka̱ta̱ i yaꞋanka Ka̱shile ugbamiwasuvu ba,
\q2 ka̱ta̱ i lapa nka̱nga̱ n ɗa̱ ba.> >>
\q1 
\v 6 Ko vuza wi a̱ ku uta̱ a kasana ko a̱ ka̱livi,
\q2 ko a kakamba u ta̱wa̱ u neke aza o yoku tsugbayin ba.
\q1 
\v 7 Ama Ka̱shile kaꞋa kayaꞋinkafada,
\q2 u tsu goyo ta̱ aza o yoku,
\q2 ka̱ta̱ u neke aza o yoku tsugbayin.
\q1 
\v 8 Vuzavaguɗu wi ta̱ uɓa̱ni n mokoꞋo e kukiye ku ni,
\q2 tukpa n ma̱kya̱n ma kalam ma na mi n kusasu,
\q1 u ɓelei maꞋa, ɗa uma a gbani-gbani aduniyan,
\q2 o soꞋi maꞋa gbende.
\q1 
\v 9 Ama mpa mi ta̱ a kusala ukuna u nampa ko wannai,
\q2 mi ta̱ a kucanana ishipa n cikpa Ka̱shile ka Yakubu.
\q1 
\v 10 A̱yi ɗa u ku goyo aza a ugbamiwasuvu,
\q2 ama wi ta̱ e kuneke aza a usuɓi tsugbayin.
\c 76
\d Kadanshi a kubana u vuza vu kelime vi ishipa: N tsuwaꞋi tsu anꞋin a umolu. Vishipa vu Asafa.
\s1 Yayi u kushamgba e kelime ka̱ nu?
\q1 
\v 1 Ka̱shile vuza vu uyevi ɗa a yahuda,
\q2 kula ku ni ku gbayin ku ɗa a Isaraila.
\q1 
\v 2 Ubuta̱ wu ida̱shi i ni yi ta̱ a Urushelima,
\q2 Sihiyona ɗa ubuta̱ wu ida̱shi i ni.
\q1 
\v 3 Taɗe u koɗosoi ayaꞋa a irala,
\q2 nu nra̱ga̱ n le, n otokobi e le, ali n ucanuku u kuvon u le.\qs Kuvuka\qs*
\q1 
\v 4 Ka̱shile, avu vuzagbayin ɗa
\q2 vi ta̱ tsu mogono ɗa baci vu bonoi,
\q2 a nsansa a̱ ubuta̱ u na vu lyaꞋi irala i nu.
\q1 
\v 5 Una ta̱ osoji a utsura
\q2 ɗa a̱ pura̱i ucanuku u na i n uɗa,
\q1 ko kovonshi ka buwa ba,
\q2 ka na ka kufuɗa ku ɗa̱ngusa̱ kukiye ku ni.
\q1 
\v 6 Ka̱shile ka Yakubu, tsu na vu ɓarangi le,
\q2 ekeke odoku n akumbi e le ra̱ka̱ a̱ yikpa̱i a̱ kuwa̱i.
\q1 
\v 7 Avu ɗa koci a kupana wovon u nu,
\q2 yayi u kushamgba e kelime ka̱ nu,
\q2 a makyan ma na baci vu yaꞋin wupa?
\q1 
\v 8 Ɗe gaɗi ɗa vu kiɗai afada,
\q2 aduniyan a panai wovon ɗa a paɗai bini,
\q1 
\v 9 Ka̱shile, vu ɗa̱nga̱ baci kuyaꞋan afada,
\q2 adama a na vu wawa aza a na i atakaci aduniyan.\qs Kuvuka\qs*
\q1 
\v 10 Mayun wupa u nu u vuma wi ta̱ a̱ ku tuka̱ wu n ucikpi,
\q2 aza a na a lakai a wupa u nu,
\q2 i ta̱ a kuyaꞋanka wu a̱ga̱nda̱.
\q1 
\v 11 YaꞋin akucina u Vuzavaguɗu Ka̱shile ka̱ ɗa̱,
\q2 ka̱ta̱ i neke i na i kucinai kuneke,
\q2 yaꞋan iɗika i na yi ɗeɗevu, a̱ tuka̱ n kuneꞋe ku le,
\q2 u Vuza na a kupana wovon.
\q1 
\v 12 U zuwa ta̱ aza o tsugono tsa̱ a̱ra̱ɗi okpo n wono,
\q2 ka̱ta̱ u zuwa ngono ma aduniyan a pana wovon.
\c 77
\s1 N la̱nsa̱ ta̱ Vuzavaguɗu a ayin atakaci
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n ka̱la̱ka̱tsu ka Jedutun. Vishipa vu Asafa.
\q1 
\v 1 N shika̱i n ka̱la̱ka̱tsu ka̱u u Ka̱shile,
\q2 n ɗengusa̱i ka̱la̱ka̱tsu ka̱u n shika̱i,
\q2 adama a na u panaka mu.
\q1 
\v 2 A makyan ma atakaci n tsu vasa ta̱ u Vuzavaguɗu,
\q2 kayin dem n tsu ɗengusa̱ ta̱,
\q2 ekiye a̱ va̱ gaɗi n yaꞋan a avasa,
\q1 ama ka̱ɗu ka̱ va̱ ka̱ ciya̱ ma̱ta̱na̱ ba.
\q1 
\v 3 Makyan ma na n ciɓai n Ka̱shile ɗa n yaꞋin yura̱,
\q2 a makyan ma na baci mi aciɓa,
\q2 n ci yaꞋan ta̱ adanshi n takpa asuvu.\qs Kuvuka\qs*
\q1 
\v 4 U tsu ka̱sukpa̱ mu n lata ba,
\q2 n na̱mgba̱i ka̱tsuma̱ ali n kpa̱ɗa̱i kufuɗa kudansa.
\q1 
\v 5 N ciɓasai n ayin a na a lazai ɗe,
\q2 n tsu ciɓa ta̱ kpamu n a̱ya̱ a na a lazai ɗe m makyan.
\q1 
\v 6 N ciɓai n vishipa vu va̱ kayin ka̱ɓula̱,
\q2 n sheshei a̱ ka̱ɗu ka̱ va̱.
\q1 
\v 7 Ɗa n danai,<<Ayin tutu ɗa Vuzavaguɗu u ku iwan mu?
\q2 Wi kpamu o kudoku kupana asuvayali a̱ va̱ ba?
\q1 
\v 8 Ucigi u nu u na u tsu sabaꞋa ba
\q2 u kotso ta̱ ko wannai?
\q2 Wi ta̱ a̱ kukpa̱ɗa̱ kushatangu
\q2 uzuwakpani u ni makyan dem?
\q1 
\v 9 Ka̱shile ka cinukpa ta̱ kupana asuvayali ɗa?
\q2 Ko wupa u ni u zuwa yi ta̱ u kpa̱ɗa̱i kusa̱Ꞌa̱ tsu?>>\qs Kuvuka\qs*
\q1 
\v 10 <<Ili i na i laꞋi n kuɓa̱la̱ mu a̱ ka̱ɗu i ɗaɗa,
\q2 kukiye ku MalaꞋimili ku ka̱sukpa̱ ta̱ kuɓa̱nka̱ tsu.>>
\q1 
\v 11 Mi ta̱ a kuciɓa n ulinga u na vu yaꞋansai Vuzavaguɗu,
\q2 mi ta̱ a kuciɓa n ili mereve i na vu yaꞋin cau ɗe.
\q1 
\v 12 Mi ta̱ a̱ kuka̱na̱ kusheshe ili i na vu yaꞋin ra̱ka̱,
\q2 mi ta̱ a̱ ka̱na̱ kusheshe a ukuna wu ulinga u nu.
\q1 
\v 13 Ka̱shile, uye u nu u ciɗa u ɗa.
\q2 Ka̱ma̱li ki lo n tsugbayin tsu Ka̱shile ka̱ tsu ba.
\q1 
\v 14 Avu ɗa Ka̱shile ka na ka ci yaꞋan ili mereve,
\q2 vu yotsongu ta̱ utsura u nu a̱ ka̱tsuma̱ ka uma.
\q1 
\v 15 N utsura u nu ɗa vu shiba̱i uma a̱ nu,
\q2 ntsukaya n Yakubu nu n Isufu. \qs Kuvuka\qs*
\q1 
\v 16 Ka̱shile, ana mini me enei nu,
\q2 ana mini me enei nu ɗa ma panai wovon,
\q2 mala mu uga̱vi ma vuzakpai adama o wovon.
\q1 
\v 17 Eleshu o yoꞋi mini,
\q2 ɗa a lapai kakpanga ɗe gaɗi,
\q2 ɗa ulaɗi wu akanai ubuta̱ dem.
\q1 
\v 18 Izumgbi i kakpanga i nu i ka̱ra̱Ꞌi a̱ ubuta̱ dem,
\q2 kutashi ku ulaɗi ku akanai aduniyan ra̱ka̱,
\q2 aduniyan a panai wovon ɗa a̱ gba̱ɗa̱i.
\q1 
\v 19 Vu walai a mala,
\q2 vu pasamgbanai mala mu uga̱vi ka̱u,
\q2 ama e ne ura̱Ꞌa̱ u ene a̱ nu ba.
\q1 
\v 20 Vu tonoi n uma a̱ nu tsu maguɓi,
\q2 e kiye a Musa n Haruna.
\c 78
\s1 Usuɓi u Ka̱shile a uma a̱ ni
\d VicuꞋu vu tsuwaꞋi tsu Asafa
\q1 
\v 1 Uma a̱ va̱, zuwai atsuvu,
\q2 i pana kuyotsongusu ku va̱,
\q2 zuwakai n ili i na mi a kudansa.
\q1 
\v 2 Mi ta̱ a kuyaꞋan kadanshi n asan,
\q2 n tonuko ɗa̱ ili i na yi usokongi ayin a cau,
\q1 
\v 3 Ili i na tsu panai ɗa kpamu tsu yevei,
\q2 ili i na ikaya i tsu i danai tsu.
\q1 
\v 4 Ci o kusokongu ku muku n le i ɗa ba,
\q2 ama ci ta̱ a kudana tsukaya tsu na tsa̱ kuta̱wa̱,
\q1 Tsugbayin tsu Vuzavaguɗu n ulinga u gbagbaꞋin u ni,
\q2 n ili i mereve i na u yaꞋansai.
\q1 
\v 5 U nekei Yakubu ili i kutono
\q2 ɗa u zuwai wila̱ a Isaraila,
\q1 u na u danai ikaya i tsu,
\q2 a piꞋisaka muku n le u ɗa.
\q1 
\v 6 Adama a na ntsukaya n na n kuta̱wa̱ e yeve u ɗa,
\q2 ali n muku n na a kumatsa,
\q2 e le tamkpamu feu a dana muku n le.
\q1 
\v 7 Adama a na a zuwa a̱ɗu e le u Ka̱shile,
\q1 ka̱ta̱ a cinukpa n ulinga u na u yaꞋin ba,
\q2 ama a̱ ka̱na̱ kutono kadanshi ka̱ ni,
\q1 
\v 8 Ka̱ta̱ okpo ci ikaya i le ba,
\q2 ntsukaya mu ugbamukaci n aza a ugbamiwasuvu,
\q1 aza a na e neke Vuzavaguɗu a̱ɗu e le ba,
\q2 aza a na a a̱ɗu e le i m ma̱riki u Ka̱shile ba.
\q1 
\v 9 Aza a Ifirayimu, aza a na a uta̱i vishili n ayaꞋa,
\q2 a kpatalai a sumai a kanna ko kuvon.
\q1 
\v 10 A shatangu uzuwakpani u le n Ka̱shile ba,
\q2 a̱ kpa̱ɗa̱i kutono wila̱ u ni.
\q1 
\v 11 A cinukpai n ulinga u na u yaꞋin,
\q2 n ili i mereve i na u yotsongi le dem.
\q1 
\v 12 U yaꞋin ili i mereve a̱ a̱shi a ikaya i le,
\q2 a uɓon u Zowan a iɗika i Masar.
\q1 
\v 13 U pecei mala ɗa u tonoi n ele punu,
\q2 u zuwai mini ma shamgbai tsu mashilya.
\q1 
\v 14 N kanna ɗa u tonoi n ele n keleshu,
\q2 n kayin ka̱ɓula̱ u tonoi n ele n kutashi ka akina.
\q1 
\v 15 U ɓatsai atali e meremune,
\q2 ɗa̱ u nekei le mini n a̱bunda̱i tsu mala mu uga̱vi.
\q1 
\v 16 U zuwai nyeneke mu uta̱i a katali,
\q2 u zuwai mini ma̱ ka̱na̱i kuyene tsu kuyene.
\q1 
\v 17 Ama ɗa a lyaꞋi kelime
\q2 n kuyaꞋanka yi unushi,
\q2 a yaꞋankai MalaꞋimili
\q2 ugbamiwasuvu ɗe e kakamba.
\q1 
\v 18 N ucigi u ka̱ɗu u le u ɗa o kondoi Ka̱shile,
\q2 a na a danai u neke le ilikulyaꞋa i na a cigai.
\q1 
\v 19 A yaꞋankai Ka̱shile kadanshi ka gbani-gbani, a danai,
\q2 <<Ko Ka̱shile ki ta̱ o kufoɓuso ka̱ɗiva̱ e meremune?
\q1 
\v 20 Ko ana u lapai katali ɗa mini ma̱ uta̱i gbani,
\q2 ɗa mini ma̱ uta̱i n a̱bunda̱i,
\q1 ama wi ta̱ kpamu e kuneke tsu ilikulyaꞋa?
\q2 Wi ta̱ kpamu a̱ kuciya̱ka̱ uma a̱ ni inyama?>>
\q1 
\v 21 Adama a nannai ana Vuzavaguɗu
\q2 u panakai le ɗa u yaꞋin wupa ka̱u,
\q2 u suꞋuki uma a Yakubu n akina a usuɗukpi ka̱u,
\q2 u va̱sa̱i n wupa wa aza a Isaraila,
\q1 
\v 22 Adama a na ushuku n Ka̱shile ba,
\q2 kpamu e neke ka̱ɗu n wishi u ni ba.
\q1 
\v 23 N nannai dem u nekei eleshu kadanshi gaɗi,
\q2 ɗa u zuwai le a̱ ɓa̱yuwa̱i utsutsu u gaɗi.
\q1 
\v 24 U tsuwa̱nka̱i le Mana tsu mini a lyaꞋa,
\q2 ɗa u nekei le ili i kashina i gaɗi.
\q1 
\v 25 Ɗa a lyaꞋi ilikulyaꞋa ya alingata a̱ Ka̱shile,
\q2 Ka̱shile ke nekei le ilikulyaꞋa
\q2 n a̱bunda̱i a lyaꞋi ali a̱ cuwa̱i.
\q1 
\v 26 U zuwai wunla̱i u vugula̱i ɗe a kasana,
\q2 n utsura u ni ɗa u zuwai wunla̱i
\q2 wu uɓonɗakai u ɗa̱nga̱i,
\q1 
\v 27 u tsuwa̱nka̱i le inyama tsu kubuta̱,
\q2 nnunu n ciꞋimkpi,
\q2 tsu kayala ka̱ iga̱Ꞌin i mala,
\q1 
\v 28 U zuwai le a̱ yikpa̱sa̱i e mere ma̱ ka̱tsura̱ ke le,
\q2 uka̱ra̱Ꞌi n a̱pa̱m e le.
\q1 
\v 29 Ɗa uma a takumai ali a̱ cuwa̱i ka̱u,
\q2 adama a na u neke le ta̱ ili i na i mali.
\q1 
\v 30 Ama babu a̱ cuwa̱ n ili i na i a mali
\q2 i ɗa biꞋi punu a una̱ u le,
\q1 
\v 31 ana Ka̱shile ka panai,
\q2 ɗa wupa u ni u va̱sa̱i wa aza a Isaraila,
\q2 wu unai uma a utsura a̱ ka̱tsuma̱ ke le,
\q2 ɗa u lapai a̱ɗa̱nga̱ni aza a Israila.
\q1 
\v 32 N ili i nampa ra̱ka̱,
\q2 a lyaꞋi kelime n kuyaꞋan unushi,
\q1 n li i mereve i na u yaꞋin dem,
\q2 ushuku n a̱yi ba.
\q1 
\v 33 Ta u zuwai ayin e le o kotsoi nannai gbani,
\q2 a̱ya̱ e le okpoi tukpa n atakaci.
\q1 
\v 34 Ana Ka̱shile ka unai aza o yoku,
\q2 a̱ shika̱i unushi u le,
\q2 a̱ la̱nsa̱i Ka̱shile o bonoi wa̱ ni kpamu.
\q1 
\v 35 A ciɓai a na Ka̱shile kaꞋa ubuta̱ u kusheɗeku u le,
\q2 a ciɓai a na Ka̱shile MalaꞋimili maꞋa ka̱shibi ke le.
\q1 
\v 36 Ama ɗa a̱ ya̱nsa̱i ni kadanshi ka̱ una̱ u le,
\q2 a kuyaꞋanka yi aꞋuwa n elentsu e le.
\q1 
\v 37 A̱ɗu ele o tono kadanshi ka̱ ni ba,
\q2 o tono uzuwakpani u ni ba.
\q1 
\v 38 N nannai dem Ka̱shile ka panai
\q2 asuvayali a uma a̱ ni,
\q2 u cinukpakai le unushi u le,
\q2 ɗa u kpa̱ɗa̱i ku una le,
\q1 makyan dem u tsu reme ta̱ ka̱ɗu ka̱ ni,
\q2 ka̱ta̱ u vaꞋanka wupa u ni.
\q1 
\v 39 U tsu ciɓa ta̱ ele uma a gbani ɗa i koci,
\q2 tsu wunla̱i u na u tsu laza kpamu u tsu bono ba.
\q1 
\v 40 A yaꞋansaka yi ta̱ ugbamiwasuvu e meremune,
\q2 a zuwai ni una̱mgbuka̱tsuma̱ a kakamba!
\q1 
\v 41 Makyan dem a̱ ka̱na̱i kukondo Ka̱shile,
\q2 ɗa a zuwai vuza ciɗa vi Israila kuyaꞋan wupa.
\q1 
\v 42 A ciɓa n utsura u ni
\q2 a ayin a na u shiba̱i le
\q2 ekiye a irala i le ba,
\q1 
\v 43 ana u yaꞋin urotu wi ili i mereve a iɗika i Masar,
\q2 ili i mereve i na vi yaꞋin a uɓon u Zowan.
\q1 
\v 44 U bonokoi nɗolu n le mo okpoi mpasa,
\q2 a fuɗa o soꞋo mini ma nyeneke n le ba.
\q1 
\v 45 U suꞋuki le n ka̱kuma̱ ka ayun ka takacikai le,
\q2 opoɗo tamkpamu a̱ la̱nga̱sa̱i iɗika i le.
\q1 
\v 46 U zuwai akyun takumai ucanuku wa ashina e le,
\q2 nta̱ɗa̱ma̱ci tamkpamu n la̱nga̱sa̱i ashina e le.
\q1 
\v 47 U la̱nga̱sa̱i ashina a itacishi e le m mini ma atali,
\q2 nɗanga mu mbiri n egele.
\q1 
\v 48 Wu unai anaka e le n mini ma atali,
\q2 ɗa kpamu wu unai ushiga wu nkyon le,
\q2 nu nraɗika n le n akpanga.
\q1 
\v 49 U tsuwa̱nka̱i le n wupa u ni,
\q2 asuvu a usuɗukpi,
\q2 n una̱mgbuka̱tsuma̱
\q2 u zuwai le atakaci,
\q2 u suꞋuki le n alingata a munuka.
\q1 
\v 50 U tsuwa̱nka̱i le n wupa u gbani-gbani u ni,
\q2 wu ere le a̱ ubuta̱ wu ukpa̱ ba,
\q2 ama ɗa wu unai le m ma̱dukpa̱.
\q1 
\v 51 Wu unai muku mu ugiti n ali a masar,
\q2 muku mu ugiti,
\q2 mu utsura u le a Ham.
\q1 
\v 52 Ɗa wu uta̱i n uma a̱ ni tsu ushiga,
\q2 u tonoi n ele tsu nkyon e meremune.
\q1 
\v 53 U tonoi n ele m ma̱ta̱na̱,
\q2 adama a na ka̱ta̱ a pana wovon ba,
\q2 ama mala ma lyaꞋa ta̱ irala i le.
\q1 
\v 54 U tuka̱i le e kureꞋe ki iɗika i ciɗa,
\q2 u tuka̱i le a kusan ku na kukiye
\q2 ku utsura ku ni ku lyaꞋi n kuvon.
\q1 
\v 55 U lokoi uduniyan u na wi e kelime ke le,
\q2 ɗa u pecekei aza a Isaraila iɗika ya,
\q2 yo okpoi ili yi uka̱ni i le,
\q2 u zuwai uma a Isaraila
\q2 a̱ da̱sa̱ngi punu a iꞋuwa i uma ya.
\q1 
\v 56 Ama ɗa o kondoi Ka̱shile,
\q2 a yaꞋankai MalaꞋimili ugbamiwasuvu,
\q2 a zuwaka n kadanshi ka̱ ni ba,
\q1 
\v 57 a yaꞋan ili i na i gaꞋin ba,
\q2 ci ikaya i le,
\q1 i n kamayun ba,
\q2 tsu kokondori ka kayaꞋa ka na a taɗuki,
\q1 
\v 58 A zuwai ni u yaꞋin wupa,
\q2 adama a nva̱li ma̱ a̱ma̱li e le,
\q1 ɗa a zuwai ni cisheꞋe
\q2 adama a̱ma̱li e le.
\q1 
\v 59 Ana Ka̱shile ka panakai le,
\q2 ɗa u yaꞋin wupa n ele ka̱u,
\q2 u iwain aza a Isaraila ra̱ka̱-ra̱ka̱.
\q1 
\v 60 U ka̱sukpa̱i Ma̱va̱li mo oɓolo a Shilo,
\q2 a̱ ubuta̱ u na wi a̱ ida̱shi e mere ma uma.
\q1 
\v 61 U ka̱sukpa̱i akpati vu uzuwakpani vu utsura u ni va,
\q2 a kubana ugbashi,
\q1 u ka̱sukpa̱i tsugbayin ci ni
\q2 a kubana wa aza a na a iwain ni.
\q1 
\v 62 U yaꞋan ta̱ wupa n ili yi uka̱ni a̱ ni
\q2 ɗa u nekei le e ekiye a irala i le
\q2 yi unai le n kotokobi.
\q1 
\v 63 Akina o songi muku mo olobo n le,
\q2 nkere tankpamu n nambai ali o ku olo,
\q1 
\v 64 Anan ganu e le a banai ukpa̱ u kotokobi,
\q2 agapa a̱ma̱ci e le tana a̱ shika̱ ba.
\q1 
\v 65 Ɗa Vuzavaguɗu u ɗa̱nga̱i,
\q2 a danshi wishi ta̱ alavu,
\q2 tsu vuza na u jimgbai
\q2 n kagimi ku soꞋi u ma̱ra̱.
\q1 
\v 66 U lapai irala i ni,
\q2 ɗa okpoi n wono ko wannai.
\q1 
\v 67 Vuzavaguɗu u iwain kefeku ka̱ Isufu,
\q2 u zagba kefeku ka̱ Ifirayimu ba.
\q1 
\v 68 Ama ɗa kucikpa u zagbai kefeku ka̱ Yahuda,
\q2 kusan ku Sihiyona ku na u cigai ka̱u.
\q1 
\v 69 Ta ɗe u maꞋi A̱Ꞌisa̱ a gbayin a̱ ni,
\q2 tsu gaɗi ko wannai,
\q1 u maꞋi ku ɗa n utsura
\q2 tsu na u shikpa̱i aduniyan ko wannai.
\q1 
\v 70 U zagbai kagbashi ka̱ ni Dawuda,
\q2 u ɗikai ni a̱ ubuta̱ u kaguɓa ko nkyon,
\q1 
\v 71 u ta̱wa̱i n a̱yi a̱ ubuta̱ u kaguɓa ko nkyon,
\q2 ɗa u zuwai ni maguɓi ma uma a̱ ni a Yakubu,
\q2 ɗaɗa Isaraila ili yi uka̱ni i ni
\q1 
\v 72 Dawuda tana u guɓai le
\q2 n ka̱ɗu ke te,
\q2 n kuyeve kpamu.
\c 79
\s1 Avasa m ma̱shi adama a Urushelima
\d Vishipa vu Asafa.
\p 
\v 1 Ka̱shile, uduniyan u tuka̱ ta̱,
\q2 uma a̱ nu n kuvon,
\q2 a natukpai A̱Ꞌisa̱ a gbayin a ciɗa a̱ nu,
\q2 o bonokoi Urushelima agali.
\q1 
\v 2 A̱ ka̱sukpa̱i even a ikyamba ya agbashi a̱ nu,
\q2 o okpo ilikulyaꞋa yi nnu,
\q1 inyama i uma a ciɗa a̱ nu,
\q2 okpoi ilikulyaꞋa yi nnama n kakamba.
\q1 
\v 3 A̱ tsuwa̱in mpasa n uma a̱ nu tsu mini,
\q2 a̱ ubuta̱ ra̱ka̱ a Urushelima,
\q2 ko vuza u buwa a na wa̱ ciɗa̱ngu
\q2 even a ikyamba a ba.
\q1 
\v 4 Tsu okpoi ili i ma̱ka̱n,
\q2 wa aza a na i a ida̱shi ɗeɗevu n a̱tsu,
\q1 tsu okpoi ili yi izoshi n ulami,
\q2 wa aza a na i uka̱ra̱Ꞌi n a̱tsu.
\b
\q1 
\v 5 Vuzavaguɗu ali n wannai ɗai,
\q2 vu kulyaꞋa ta̱ kelime n wupa ko wannai ɗa?
\q1 Ali n wannai ɗai,
\q2 wupa u nu u kuka̱na̱ ku kula̱ tsa akina?
\q1 
\v 6 Vu tsuwa̱n wupa u nu,
\q2 a uduniyan u na u kpa̱ɗa̱i ku cikpa wu,
\q1 N tsugono dem,
\q2 tsu na tsu kpa̱ɗa̱i kuɗeke kula ku nu.
\q1 
\v 7 Adama a na a lyaꞋa ta̱ Yakubu,
\q2 a̱ la̱nga̱sa̱i iɗika i ni.
\b
\q1 
\v 8 Ka̱ta̱ vu takacika tsu,
\q2 adama unushi wi ikaya i tsu ba,
\q1 ama vu pana asuvayali a̱ tsu,
\q2 adama a na tsu takpa ta̱ asuvu a̱ tsu.
\q1 
\v 9 Vu ɓa̱nka̱ tsu, Ka̱shile kishi ka̱ tsu,
\q2 adama a tsugbayin tsu kula ku nu,
\q1 isa tsu ka̱ta̱ vu cinukpaka tsu unushi u tsu,
\q2 adama a kula ku nu.
\q1 
\v 10 Adama a̱ yiɗa̱i ɗa uduniyan u ku dana,
\q2 <<Te ɗai Ka̱shile ke le?>>
\q1 YaꞋan tsu ene tsu na va kutakacika uduniyan,
\q2 adama a na vu tsupa
\q2 mpasa ma agbashi a̱ nu n na a̱ tsuwa̱in.
\b
\q1 
\v 11 Zuwa atsuvu vu pana,
\q2 yura̱ ya aza a na i ushiyi,
\q1 n kukiye ku utsura ku nu,
\q2 vu wawa aza a na a kiɗakai afada a̱ ukpa̱.
\q1 
\v 12 Vuzavaguɗu tsupa,
\q2 uduniyan u nanlo ali kucindere,
\q2 adama a kadanshi ka ishikushi
\q2 ka na a yaꞋankai nu.
\q1 
\v 13 A̱tsu na ci uma a̱ nu,
\q2 nkyon mu ushiga u nu,
\q2 ci ta̱ a kucikpa wu ko wannai.
\q1 Tsukaya a kubana a tsukaya,
\q2 ci ta̱ a kucikpa wu.
\c 80
\s1 Avasa adama kusabaꞋasaka Isaraila
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n ka̱la̱ka̱tsu ka Uzuwakpani u apulufa. Vishipa vu Asafa.
\q1 
\v 1 Zuwaka tsu atsuvu,
\q2 avu maguɓi mi Isaraila,
\q2 avu vu na vu tonoi n kumaci
\q2 ku Isufu tsu ushiga.
\q1 Avu na vi a̱ ida̱shi a kakuba
\q2 ko tsugono ka̱ nu,
\q2 a gaɗi vu Corobi vu akana,
\q1 
\v 2 e kelime ka Ifirayimu,
\q2 m Bayami m Manasa,
\q1 yotsongu utsura u nu
\q2 ka̱ ta̱ vu ta̱wa̱ vu wawa tsu.
\q1 
\v 3 Ka̱shile, bonoko tsu,
\q2 vu pana asuvayali a̱ tsu,
\q2 ka̱ta̱ vu wawa tsu.
\q1 
\v 4 Vuzavaguɗu Ka̱shile MalaꞋimili,
\q2 Ali n wannai ɗai va̱ ku ka̱na̱ wupa
\q2 n avasa a uma a̱ nu?
\q1 
\v 5 N kujilya ku ɗa vu lyaꞋatangi tsu,
\q2 n kujilya ku ɗa vu nekei tsu moko ma̱ mini tsu soꞋi.
\q1 
\v 6 Vu bonokoi tsu ili i vishili
\q2 wa aza a na ci ida̱shi ɗeɗevu,
\q2 irala i tsu kpamu o ku zoꞋoso tsu.
\q1 
\v 7 Ka̱shile MalaꞋimili, bonoko tsu,
\q2 vu pana asuvayali a̱ tsu,
\q2 ka̱ta̱ vu wawa tsu.
\q1 
\v 8 Vu utuka̱i uma a̱ nu tsu maɗanga mi itacishi a Masar,
\q2 vu lokoi uduniyan
\q2 u na wi ida̱shi a KanaꞋana,
\q2 ɗa vu shikpa̱i le.
\q1 
\v 9 Ɗa vu lapulakai le ubuta̱ adama a na o gbonguro
\q2 aralu a̱ ni a uwai a iɗika ka̱u,
\q2 a tatsai a palai ubuta̱ dem a iɗika ya.
\q1 
\v 10 A palai aginda n ululu e le,
\q2 a palai nɗanga m gbagbain n Sida n acaka e le.
\q1 
\v 11 Acaka a̱ ni a lazai,
\q2 a kubana a mala me mere,
\q2 ali a kubana a Mala ma Yufiretu.
\q1 
\v 12 Yiɗa̱i i zuwai ɗa vu ɓosoi
\q2 nshilya n na mi uka̱ra̱Ꞌi
\q2 n maɗanga mi itacishi ma?
\q2 Adama a na irala i ni i na yi a kulaza lo dem
\q2 a uwa o boko umaci u ni.
\q1 
\v 13 Njuma mi ta̱ a kudasa le,
\q2 nnama n kakamba n takuma le.
\q1 
\v 14 Ka̱shile MalaꞋimili, bono wa̱ tsu,
\q2 la̱na̱ku ɗe gaɗi vu ene,
\q1 ta̱wa̱ vu wawa kashina ki itacishi ka̱ nu.
\q2 
\v 15 Ta̱wa̱ vu wawa maɗanga mi itacishi ma,
\q2 ma na avu n ka̱ci ka̱ nu vu shikpa̱i,
\q2 ma na vu ɗa̱ngusa̱i
\q2 adama a̱ ka̱ci ka̱ nu.
\q1 
\v 16 Irala i tsu i kapai le i songi le n akina,
\q2 vu yaꞋin wupa n ele
\q2 vu unai le ra̱ka̱.
\q1 
\v 17 YaꞋan kukiye ku singai ku nu
\q2 ku yongo n uma a̱ nu a na vu zagbai,
\q2 maku ma vuma ma na vu kumgbasai
\q2 adama a̱ ka̱ci ka̱ nu.
\q1 
\v 18 Ci a kukpatala tsu ka̱sukpa̱ wu ba,
\q2 neke tsu wuma u savu,
\q2 adama a na tsu ɗeke a kula ku nu.
\q1 
\v 19 Ka̱shile MalaꞋimili, bonoko tsu,
\q2 vu pana asuvayali a̱ tsu,
\q2 ka̱ta̱ vu wawa tsu.
\c 81
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n ka̱la̱ka̱tsu ka, <<Gititi.>> Vishipa vu Asafa.
\s1 Ishipa i ka̱ɗiva̱ ka̱ a̱pa̱m
\q1 
\v 1 Cananai ishipa i ma̱za̱nga̱ u Ka̱shile katsura ka̱ tsu,
\q2 orukpoi ka̱u u Ka̱shile ka Yakubu.
\q1 
\v 2 Gita̱i ishipa n i kucuwai medelemishipa,
\q2 waꞋi umolu, waꞋi umolu u gbayin,\f + \fr 81:2 \fq umolu u gbayin \ft Umolu u aꞋin kupa.\f*
\q2 n ka̱la̱ka̱tsu ka uyoꞋo.
\q1 
\v 3 I lika̱ kavana ka̱ ka̱giri o wotoi u savu,
\q2 i lika̱ kavana ka a makyan ma na wotoi u pecei,
\q2 i yaꞋan ka̱ɗiva̱ ka.
\q1 
\v 4 Na lo ili i kutono i ɗa wa aza a Isaraila,
\q2 wila̱ u ɗa u na wu uta̱i a̱ Ka̱shile ka Yakubu.
\q1 
\v 5 U neke ta̱ wila̱ u nanlo a̱ ubuta̱ uma a Isaraila,
\q2 a makyan ma na wu uta̱i u shilika̱i n uma a Masar.
\q2 M panai ka̱la̱ka̱tsu ka na n saꞋwai kupana ba, a kudansa,
\q1 
\v 6 <<N cipa̱ka̱ ɗa̱ ta̱ ucanuku wa̱ a̱miki u na wi avangatsu a̱ ɗa̱,
\q2 mbana ma atakaci n na mi ekiye a̱ ɗa̱ n yaꞋan ta̱ wishi.
\q1 
\v 7 A makyan ma na yi o kusoꞋo atakaci,
\q2 i ɗeke mu ta̱, ɗa tana n wawai ɗa̱,
\q2 ɗa mu ushuki mpa punu eleshu,
\q2 n kondoi ɗa̱ a̱ mini ma Mariba.\qs Kuvuka\qs*
\q1 
\v 8 Panai, a̱ɗa̱ uma a̱ va̱ aza a Isaraila,
\q2 n ciga ta̱ i panaka mu.
\q1 
\v 9 Ka̱ta̱ i cikpa a̱ma̱li ba,
\q2 ka̱ta̱ kpamu i kuɗa̱ngu a omoci a̱ma̱li ba.
\q1 
\v 10 Mpa ɗa Vuzavaguɗu Ka̱shile ka̱ ɗa̱,
\q2 vuza na wu utuka̱i ɗa̱ a iɗika i Masar,
\q2 apukai una̱ u ɗa̱, mi ta̱ a ku lyatangu ɗa̱.
\b
\q1 
\v 11 <<Ama uma a̱ va̱ a panaka mu ba,
\q2 Isaraila u iwain kutono mu.
\q1 
\v 12 Adama a nannai,
\q2 n ka̱sukpa̱ le ta̱ a lyaꞋa kelime n ugbamukaci u le,
\q2 a yaꞋan ili i na i a kufuɗa kuyaꞋan.
\q1 
\v 13 Uma a̱ va̱ i baci a kupanaka mu,
\q2 ishi baci aza a Isaraila o kutono uye u va̱,
\q1 
\v 14 mi ishi ta̱ o kuloko irala i le gogoꞋo lo
\q2 n lyaꞋa aza a na a iwai le ra̱ka̱.
\q1 
\v 15 Aza a na a iwai Vuzavaguɗu,
\q2 i ta̱ a̱ ku kuɗa̱ngu e kelime ka̱ ni adama o wovon,
\q2 atakaci e le ko wannai ɗa.
\q1 
\v 16 Ama mi ta̱ a ku lyaꞋatangu ɗa̱ n alkama i singai,
\q2 ka̱ta̱ n zuwa ɗa̱ i cuwa̱ n ishigi i na a jaꞋwain a katali.>>
\c 82
\d Vishipa vu Asafa.
\s1 Isa aza a unambi n aza a babu utsura
\q1 
\v 1 Ka̱shile ka ɗika ta̱ tsugbayin ci ni
\q2 o koɓolo ka gbayin ka gaɗi.
\q1 Ka̱shile ka tsu kiɗa ta̱ afada
\q2 a̱ ka̱tsuma̱ ka̱ a̱ma̱li.
\q1 
\v 2 <<Ali n wannai ɗai i ku ka̱na̱ kuyaꞋan afada a na i mejege ba,
\q2 i ka̱na̱ kuɓa̱nka̱ aza a gbani-gbani? \qs Kuvuka\qs*
\q1 
\v 3 I ɓa̱nka̱ aza a unambi nu mkpaꞋan,
\q2 i yaꞋanka aza a unambi
\q2 n aza a na o doroi kasingai.
\q1 
\v 4 Wawai aza a na i n utsura ba n aza a unambi,
\q2 wawai le e ekiye aza a gbani-gbani.>>
\q1 
\v 5 I n cicoꞋo ba, ko e yeve ili,
\q2 i ta̱ a nwalu a̱ ka̱yimbi,
\q2 a̱miꞋi a ngon ma aduniyan m gba̱ɗa̱i.
\q1 
\v 6 N danai, <<A̱ɗa̱ a̱ma̱li a ɗa,
\q2 ra̱ka̱ vu ɗa̱ muku m MalaꞋimili n ɗa,
\q1 
\v 7 Ama yi ta̱ a̱ ku kuwa̱ tsu vuma,
\q2 i yikpa̱ tsu ngono ra̱ka̱.>>
\q1 
\v 8 Ka̱shile, ta̱wa̱ vu yaꞋanka aduniyan afada,
\q2 adama a na uduniyan ra̱ka̱ ili yi uka̱ni i nu i ɗa.
\c 83
\d Vishipa vu Asafa.
\s1 Avasa adama a na una irala i Isaraila
\q1 
\v 1 Ka̱shile, ka̱ta̱ vu paɗa bini, vu shamgba gbaɓa ba,
\q2 Ka̱shile ka̱ta̱ vu kpa̱ɗa̱ kukeɓece ukuna ba.
\q1 
\v 2 Inda, tsu na irala i nu yi a̱ra̱ɗi,
\q2 la̱na̱, tsu na i a ugbamukaci.
\q1 
\v 3 A nsata adama a uma a̱ nu,
\q2 a gbaɓai aci e le a yaꞋan tsurala n uma a na vi a kinda.
\q1 
\v 4 Aza a ugbamukaci a kudansa,
\q2 <<Ta̱wa̱i tsu una aza a Isaraila,
\q2 adama a na a cinukpa n ele ko wannai.>>
\q1 
\v 5 N ka̱ɗu kete kaꞋa e sheshei,
\q2 a gbaɓai kaci a kuyaꞋan tsurala n avu.
\q1 
\v 6 Ele ɗa aza a Edom n aza a IshimaꞋilu,
\q2 n aza a Mowabu, n aza a Haga,
\q1 
\v 7 n aza a Gebalu n aza a Amona
\q2 n aza a Ameleki n aza a Filisitiya n aza a Taya,
\q1 
\v 8 Asiriya feu o ɓolongi kaci n ele,
\q2 o doki kumaci ku Lotu utsura. \qs Kuvuka\qs*
\q1 
\v 9 YaꞋanka le tsu na vu yaꞋankai aza a Midiya,
\q2 yaꞋanka le tsu na vu yaꞋankai Sisera,
\q2 n Jabinu e kuyene ku Kishon,
\q1 
\v 10 a̱ kuwa̱i a Eni-doru,
\q2 even a ikyamba e le a shamai a iɗika.
\q1 
\v 11 YaꞋanka aza e kelime e le
\q2 tsu na vu yaꞋankai Orebu n Zeyibu,
\q2 vu lokoi aza o tsugono e le
\q2 tsu na vu lokoi Zeba n Zalumuna,
\q1 
\v 12 a danai, <<Ci ta̱ a ku isa iɗika i na yi i Ka̱shile
\q2 yi okpo i tsu.>>
\q1 
\v 13 Ka̱shile ka̱ va̱, loko le tsu wunla̱i u kabatalikpau,
\q2 vu loko le tsu na wunla̱i u tsu pura̱ngu kopo.
\q1 
\v 14 Tsu na akina a ci lyaꞋa kutsun,
\q2 tsu na kpamu melentsu ma akina me ci leɓece nsasan,
\q1 
\v 15 Vu loko le n wunla̱i wu utsura u nu,
\q2 vu rikpa̱sa̱ le n kabatalikpau ka utsura.
\q1 
\v 16 Vuzavaguɗu zuwa le okpo n wono,
\q2 adama a na a̱ la̱nsa̱ kula ku ni.
\q1 
\v 17 YaꞋan okpo n wono ko wannai,
\q2 yaꞋan a bana ukpa̱ u wono,
\q1 
\v 18 Adama a na e yeve a na avu ɗa koci, Vuzavaguɗu,
\q2 avu ɗa koci MalaꞋimili aduniyan ra̱ka̱.
\c 84
\s1 Uzuwi u ka̱ɗu u Ka̱shile
\d Kadanshi a kubana u vuza vu kelime vi ishipa: A yaꞋan vu ɗa n ka̱la̱ka̱tsu ka <<Gititi.>>Vishipa vu muku n Kora.
\q1 
\v 1 Yiɗa̱i a kugisangu ku ugaꞋin wa̱ A̱Ꞌisa̱ a gbayin a̱ nu,
\q2 Ka̱shile MalaꞋimili?
\q1 
\v 2 Wuma u va̱ wi ta̱ a mali
\q2 ma ulanga wa̱ A̱Ꞌisa̱ a gbayin a Vuzavaguɗu.
\q1 Ka̱ɗu ka̱ va̱ n wuma u va̱ ra̱ka̱ a kucanana ishipa
\q2 u Ka̱shile ka wuma.
\q1 
\v 3 Ali ojironjiron feu a̱ ciya̱ ta̱ ɗe kpaꞋa,
\q2 mbeɗukule n yaꞋan ta̱ ɗe cikinda,
\q1 ɗevu n katalikalyuka a tsu guɓa muku n le,
\q2 Vuzavaguɗu MalaꞋimili, mogono ma̱ va̱ Ka̱shile ka̱ va̱.
\q1 
\v 4 Aza a una̱singai a ɗa aza a na i a ida̱shi a kpaꞋa ku nu,
\q2 makyan dem i ta̱ a kucanana ishipa i kucikpa wu. \qs Kuvuka\qs*
\q1 
\v 5 Aza a̱ ma̱za̱nga̱ a ɗa aza a na a̱ ciya̱i utsura wa̱ nu,
\q2 aza a na i a mali a bana a kusan ku Sihiyona.
\q1 
\v 6 Aza a̱ ma̱za̱nga̱ a ɗa a na o tonoi n ka̱ra̱Ꞌa̱ ke ɗekpu,
\q2 ɗa ko bonoi tsu a̱shi a̱ mini,
\q2 tsu na mini ma̱ ugiti ma̱ Ka̱shile ma tsu shatangu ayivan dem.
\q1 
\v 7 A̱ tsu ka̱na̱ ta̱ kutsurukpa a̱ ka̱tsuma̱ ka nwalu n le,
\q2 i ta̱ tana e kene Ka̱shile ka̱ a̱ma̱li a Sihiyona.
\q1 
\v 8 Pana avasa a̱ va̱, Vuzavaguɗu Ka̱shile MalaꞋimili,
\q2 panaka mu, Ka̱shile ka Yakubu. \qs Kuvuka\qs*
\q1 
\v 9 La̱na̱ Ka̱shile, avu ɗa ubuta̱ u kusheɗeku u tsu,
\q2 sa̱Ꞌa̱ mazagbi ma̱ nu.
\q1 
\v 10 Kanna kete ka na a kuyaꞋan A̱Ꞌisa̱ a gbayin a̱ nu
\q2 u laꞋa ta̱ ayin ka̱kpa̱n a na a kuyaꞋan a̱ ubuta̱ u yoku kau.
\q1 n laꞋa ta̱ n kuciga m shamgba utsutsu u kpaꞋa ku Ka̱shile ka̱ va̱,
\q2 a na ma̱ kuda̱sa̱ngu a iꞋuwa i uma a gbani-gbani.
\q1 
\v 11 Vuzavaguɗu Ka̱shile,
\q2 a̱yi ɗa kutashi ku tsu m ma̱ra̱ga̱ ma̱ tsu,
\q2 u tsu zuwaka tsu ta̱ una̱singai
\q2 n kasingai n tsugbayin,
\q1 u sa̱nka̱ aza a na i a kuyaꞋan ili i mejege
\q2 ili singai ba.
\q1 
\v 12 Aza a una̱singai a ɗa aza a na e nekei a̱ɗu ele wa̱ nu,
\q2 Ka̱shile MalaꞋimili.
\c 85
\s1 Ma̱shi ma̱ kula̱nsa̱ kasingai adama a Isaraila
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu muku n Kora.
\q1 
\v 1 Vuzavaguɗu, vu yaꞋanka ta̱ iɗika i nu kasingai,
\q2 vu bonoko ta̱ Yakubu n una̱singai u ni.
\q1 
\v 2 Vu cinukpaka ta̱ uma a̱ nu unushi u le,
\q2 vu cinukpakai le unushi u le. \qs Kuvuka\qs*
\q1 
\v 3 Vu ka̱sukpa̱i kuyaꞋan wupa n ele,
\q2 ɗa vu takpai wupa wu usuɗukpi u nu we le.
\q1 
\v 4 Bonoko tsu kpamu, Ka̱shile kishi ka̱ tsu,
\q2 vu ka̱sukpa̱ kupana wupa u tsu.
\q1 
\v 5 Vi ta̱ a kuyaꞋan wupa n a̱tsu ko wannai ɗa?
\q2 Vi a ku saꞋawa kuta̱na̱ ba?
\q1 
\v 6 Vi o kudoku tsu utsura,
\q2 vu ɗa̱ngusa̱ tsu kpamu ba?
\q2 Adama a na ci cikpa wu ba?
\q1 
\v 7 Vuzavaguɗu vu yotsongu tsu
\q2 ucigi u na u tsu sabaꞋa ba,
\q2 vu ɓa̱nka̱ tsu n wishi u nu.
\q1 
\v 8 Mi ta̱ a kuzuwa atsuvu wu ili i na,
\q2 Vuzavaguɗu Ka̱shile ki a kudansa,
\q2 a̱tsu na ci uma a̱ ni,
\q2 u yaꞋanka tsu ta̱ uzuwakpani u ma̱ta̱na̱,
\q2 tsu bono baci a ukuna u tsulau u tsu ba.
\q1 
\v 9 Mayun wi ta̱ ufoɓushi adama a na wu isa aza a na i e kuneke yi tsugbayin,
\q2 adama a na tsugbayin ci ni tsu yongo punu a iɗika ya.
\q1 
\v 10 Ucigi u na u tsu sabaꞋa ba n usuɓi i ta̱ o kugasa a̱ ubuta̱ u te,
\q2 ma̱riki m ma̱ta̱na̱ i ta̱ kpamu o ku oɓongbonoi
\q1 
\v 11 Ma̱riki ma vuma mi ta̱ a̱ ku uta̱ aduniyan a kubana gaɗi,
\q2 usuɓi u Ka̱shile wi ta̱ a ku indana ɗe gaɗi.
\q1 
\v 12 Vuzavaguɗu wi ta̱ a ku zuwaka tsu una̱singai,
\q2 iɗika i tsu yi ta̱ a kumatsa ili i kashina n a̱bunda̱i.
\q1 
\v 13 Usuɓi wi ta̱ a kulyaꞋa kelime ka̱ ni,
\q2 u foɓusoko yi uye.
\c 86
\s1 Avasa a̱ kula̱nsa̱ uɓa̱nki
\d Avasa a Dawuda
\q1 
\v 1 Vuzavaguɗu zuwaka mu atsuvu, vu ushuku mu,
\q2 adama a na mpa vuza vu unambi ɗa n vuza yali.
\q1 
\v 2 Ere wuma u va̱ a̱ ubuta̱ ukpa̱,
\q2 adama a na mpa vuza vu usuɓi ɗa,
\q2 wawa kagbashi ka̱ nu,
\q2 adama a na avu ɗa Ka̱shile ka̱ va̱.
\q1 
\v 3 Pana asuvayali a̱ va̱, Vuzavaguɗu,
\q2 mi ta̱ avasa wa̱ nu kanna dem.
\q1 
\v 4 Vuzavaguɗu, zuwa kagbashi ka̱ nu
\q2 ka yaꞋan ma̱za̱nga̱,
\q2 adama a na n neke ta̱ wuma u va̱ wa̱ nu.
\q1 
\v 5 Vuzavaguɗu, avu vuza vu kasingai ɗa
\q2 n kacinukpi ka unushi,
\q2 vi ta̱ n ka̱bunda̱i ka ucigi u na u tsu sabaꞋa ba
\q2 wa aza na i e meɗevile wa̱ nu ra̱ka̱.
\q1 
\v 6 Zuwa atsuvu wa avasa a̱ va̱, Vuzavaguɗu,
\q2 pana ma̱shi ma̱ va̱ ma̱ kula̱nsa̱ uɓa̱nki.
\q1 
\v 7 Mi ta̱ e ɗeke wu a kanna ka atakaci,
\q2 adama a na vi ta̱ a̱ ku ushuku avasa a̱ va̱.
\q1 
\v 8 Vuzavaguɗu, a̱ ka̱tsuma̱ ka̱ a̱ma̱li
\q2 ko vuza te wi lo tsu nu ba,
\q2 ko vuza te, wi a kufuɗa kuyaꞋan ili i na vi a kuyaꞋan ba.
\q1 
\v 9 Uduniyan u na vu yaꞋin ra̱ka̱,
\q2 i ta̱ a̱ kuta̱wa̱ a̱ kuɗa̱ngu e kelime ka̱ nu, Vuzavaguɗu,
\q2 i ta̱ e kuneke kula ku nu tsugbayin.
\q1 
\v 10 Adama a na avu vuza gbayin ɗa,
\q2 vu na vu ci yaꞋan ili i mereve,
\q2 avu endeꞋin avu ɗa Ka̱shile,
\q1 
\v 11 Vuzavaguɗu, piꞋisaka mu ili i na vu cigai n yaꞋan,
\q2 mpa tana mi ta̱ o kutono wu mayun,
\q2 zuwa mu n ga̱nda̱ka̱ wu n ka̱ɗu kete.
\q1 
\v 12 Vuzavaguɗu Ka̱shile ka̱ va̱,
\q2 mi ta̱ a kucikpa wu n ka̱ɗu kete,
\q2 mi ta̱ a kusala tsugbayin tsu nu ko wannai.
\q1 
\v 13 Ucigi u gbayin u nu u na tsu sabaꞋa,
\q2 a kubana wa̱ va̱ wi kugisangu ba,
\q2 adama a na vu isa mu a kasaun uga̱vi.
\q1 
\v 14 Aza a ugbamukaci a̱ tuka̱ mu ta̱ n vishili, Ka̱shile,
\q2 koɓolo ka uma a gbani-gbani a̱ kula̱nsa̱ wuma u va̱,
\q2 uma a na e ci neke wu tsugbayin ba.
\q1 
\v 15 Ama avu Vuzavaguɗu, avu Ka̱shile ka asuvayali kaꞋa n kasingai,
\q2 vuza na u ci yaꞋan wupa gogo ba,
\q2 vuza wu ucigi wa̱ a̱bunda̱i m ma̱riki,
\q1 
\v 16 La̱na̱ mu, vu pana asuvayali a̱ va̱,
\q2 vu neke kagbashi ka̱ nu utsura
\q2 vu wawa maku ma kagbashi ka vuka ka̱ nu.
\q1 
\v 17 Vuzavaguɗu, yotsongu mu urotu u kasingai ka̱ nu,
\q2 aza a na iwain mu i ta̱ e kene, ka̱ta̱ a pana wono,
\q2 ɗa baci enei vu nekei mu kadanshi
\q2 vu ɓa̱nka̱i mu kpamu.
\c 87
\d Vishipa vu muku n Kora.
\q1 
\v 1 Vuzavaguɗu u vara ta̱ kumiꞋi ku kumaꞋa ku ni,
\q2 a gaɗi vu aginda a ciɗa,
\q2 
\v 2 Vuzavaguɗu u laꞋa ta̱ n kuciga utsutsu u Sihiyona
\q2 n ubuta̱ wi ida̱shi i Yakubu ra̱ka̱.
\q1 
\v 3 I ta̱ a kadanshi ka tsugbayin adama a̱ nu,
\q2 avu likuci i Ka̱shile. \qs Kuvuka\qs*
\q1 
\v 4 Mi ta̱ a kuzuwa Masar m Babila,
\q2 a̱ ka̱tsuma̱ ka aza a na e yevei mu,
\q2 Filisitiya n Taya n Habasha
\q2 <<Ele feu ta ɗe a matsai le,>>
\q1 
\v 5 A Sihiyona tankpamu i ta̱ a kudana,
\q2 <<Ele na n ele nan ɗe a matsa le ta̱ punu.>>
\q2 MalaꞋimili wi ta̱ a kuzuwa i ɗa.
\q1 
\v 6 Vuzavaguɗu wi ta̱ a kuɗana a katagarda ka ula a uma a̱ ni dem,
\q2 <<A̱yi na a matsai ta̱ a Sihiyona.>>\qs Kuvuka\qs*
\q1 
\v 7 A makyan ma na i a kuyaꞋan tsuwaꞋi i ta̱ a kucanana ishipa, ka̱ta̱ a dana,
\q2 <<Una̱singai u va̱ dem wi ta̱ Sihiyona.>>
\c 88
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu muku n Kora. A yaꞋan vu ɗa n ka̱la̱ka̱tsu ka Leyonotu.VicuꞋu vu tsuwaꞋi tsu Heman vuza vu aza a Ezirahitu
\q1 
\v 1 Vuzavaguɗu Ka̱shile, vuza na u wawai mu,
\q2 kanna n kayin mpa a̱ ma̱shi wa̱ nu,
\q1 
\v 2 YaꞋan avasa a̱ va̱ a̱ ta̱wa̱ wa̱ nu,
\q2 zuwa atsuvu vu pana ma̱shi ma̱ va̱.
\q1 
\v 3 Wuma u va̱ wi ta̱ tukpa n atakaci,
\q2 ali mi ɗevu n ukpa̱.
\q1 
\v 4 E kece mu ta̱ a̱ ka̱tsuma̱ ka aza a na a̱ gida̱la̱i
\q2 e kpenle ku ukpa̱
\q2 mo okpoi tsu vuza na wi n utsura ba,
\q1 
\v 5 A variki mu a̱ ubuta̱ wa̱ a̱kpisa̱,
\q2 tsa aza a na unai,
\q2 punu a ivaꞋin asaun e le,
\q1 aza a na vu cinukpai n e le,
\q2 aza a na a buwai n u uɓa̱nki u nu ba.
\q1 
\v 6 Vu taɗuku mu ta̱ a kasaun ku uga̱vi,
\q2 m kpenle ku uga̱vi ku ka̱yimbi.
\q1 
\v 7 Vi ta̱ a wupa nu mpa ka̱u,
\q2 vu vita̱la̱sa̱i mu n aɓau a mala. \qs Kuvuka\qs*
\q1 
\v 8 Vu zuwai a̱ja̱Ꞌa̱ a̱ va̱ a variki mu,
\q2 vu zuwai e pecei mu kau,
\q1 mo okpoi a ukanji babu tsu na n kulaꞋaka.
\q2 
\v 9 A̱shi a̱ va̱ a̱ ga̱la̱i adama a una̱mgbuka̱tsuma̱.
\q1 Vuzavaguɗu kanna dem mi ta̱ e kuɗekushe wu,
\q2 n tsu ɗa̱ngusa̱ ta̱ ekiye a̱ va̱ wa̱ nu avasa.
\q1 
\v 10 Vu tsu yaꞋanka ta̱ a̱kpisa̱ ili i mereve?
\q2 A̱kpisa̱ a̱ tsu ɗa̱nga̱ ta̱ a cikpa wu? \qs Kuvuka\qs*
\q1 
\v 11 A ci yaꞋan ta̱ kadanshi ka
\q2 ucigi u nu u na u tsu sabaꞋa ba a kasaun?
\q2 Ko ma̱riki ma̱ nu a̱ ubuta̱ wa aza a na a unai.
\q1 
\v 12 I ta̱ e kene ili i mereve i nu a̱ ka̱yimbi?
\q2 Ko ukuna wu usuɓi u nu a̱ ubuta̱ wa̱ a̱kpisa̱.
\q1 
\v 13 Ama Vuzavaguɗu mi ta̱ e meɗevile a̱ kula̱nsa̱ uɓa̱nki,
\q2 n usana n ci yaꞋan ta̱ avasa a kubana wa̱ nu.
\q1 
\v 14 Vuzavaguɗu, yiɗa̱i i zuwai ɗa vu variki mu?
\q2 Yiɗa̱i i zuwai ɗa vu sokongu ki mu a̱shi a̱ nu?
\q1 
\v 15 Ili i na i ɗikai mpa kenu ɗa mi atakaci,
\q2 ali a kubana ɗevu n ukpa̱,
\q2 ɗa n togbolyoi adama atakaci a̱ nu.
\q1 
\v 16 Wupa u nu u lyaꞋa mu ta̱ tsu na mini ma tsu aya,
\q2 uɓarangi u nu wu una mu ta̱.
\q1 
\v 17 Kanna ka̱ɓula̱ a̱ ka̱ra̱Ꞌi mu tsu mini,
\q2 a kanza mu ta̱ a̱ ubuta̱ dem.
\q1 
\v 18 Vu zuwai a̱ja̱Ꞌa̱ va̱ n aza a na a cigai mu a iwain mu,
\q2 ka̱yimbi kaꞋa koci ko okpoi ka̱ja̱Ꞌa̱ ka̱ va̱.
\c 89
\s1 Uzuwakpani u Ka̱shile n Dawuda
\d VicuꞋu vu tsuwaꞋi tsu Itan vuza va aza a Ezirahitu
\q1 
\v 1 Mi ta̱ a kucanana ishipa
\q2 adama a ucigi u Vuzavaguɗu
\q2 u na u tsu sabaꞋa ba ko wannai.
\q1 Mi ta̱ a kusala ukuna u ma̱riki ma̱ nu,
\q2 tsukaya a kubana a tsukaya
\q1 
\v 2 Mi ta̱ a kudana,
\q2 <<Ucigi u nu u na u tsu sabaꞋa ba wi ta̱ o kuyongo ko wannai,
\q2 ma̱riki ma̱ nu mi ta̱ o kuyongo tsu gaɗi a̱da̱nga̱shile.>>
\q1 
\v 3 Vu danai, <<N yaꞋan ta̱ uzuwakpani m mazagbi ma̱ va̱,
\q2 n yaꞋanka ta̱ kagbashi ka̱ va̱ Dawuda uzuwakpani n danai,
\q1 
\v 4 <A ntsukaya u nu n ɗa a̱ kuciya̱ mogono ko wannai,
\q2 i ta̱ a̱ kuda̱sa̱ngu a kakuba ko tsugono ka̱ nu tsukaya n tsukaya.> >> \qs Kuvuka\qs*
\q1 
\v 5 Vuzavaguɗu, ili wuma i gaɗi
\q2 yi ta̱ a kucikpa ili i mereve i na vu yaꞋin,
\q1 koɓolo ka uma a ciɗa feu,
\q2 a kucikpa ma̱riki ma̱ nu.
\q1 
\v 6 Adama a na ɗe e eleshu yayi a kugisanku n Vuzavagɗu,
\q2 yayi wi tsu Vuzavaguɗu a̱ ka̱tsuma̱ ki ili wuma i gaɗi?
\q1 
\v 7 I ta̱ e kuneke wu tsugbayin a̱ ka̱tsuma̱ ki ili i wuma i ciɗa,
\q2 aza a na i uka̱ra̱Ꞌi n avu i ta̱ o wovon u nu ka̱u.
\q1 
\v 8 Vuzavaguɗu Ka̱shile, MalaꞋimili,
\q2 babu vuza vu utsura tsu nu,
\q2 avu vuza vu ma̱riki ɗa a ili dem.
\q1 
\v 9 Avu ɗa vu tsu lyaꞋa tsugono tsu mala ma ujari,
\q2 vu tsu vaꞋanku ta̱ aɓau.
\q1 
\v 10 Vu yokumoi ka̱ma̱li ka ugbamukaci ka nanlo vu unai ni,
\q2 n utsura u kukiye ku nu ɗa vu wacuwai irala i nu.
\q1 
\v 11 Gaɗi a̱da̱nga̱shile a̱ nu a ɗa, aduniyan feu a̱ nu a ɗa,
\q2 avu ɗa vu yaꞋin aduniyan n ili i na yi punu dem.
\q1 
\v 12 Avu ɗa vu yaꞋin uɓongaɗi n uɓonɗakai,
\q2 kusan ku Taboru n Hamonu i ta̱ a kuyaꞋanka wu ishipa adama a̱ ma̱za̱nga̱.
\q1 
\v 13 Kukiye ku nu ki ta̱ n tsugbayin,
\q2 kukiye ku usingai ku nu kpamu ki ta̱ n utsura.
\q1 
\v 14 Usuɓi n kamayun kaꞋa kumiꞋi ku kakuba ko tsugono ka̱ nu,
\q2 ucigi u nu u na u tsu sabaꞋa ba m ma̱riki i ta̱ e kelime ka̱ nu.
\q1 
\v 15 Vuzavaguɗu, aza a una̱singai a ɗa aza a na i a kucikpa wu n ishipa i ma̱za̱nga̱,
\q2 aza a na i a nwalu a kutashi ku nu.
\q1 
\v 16 I ta̱ a̱ ma̱za̱nga̱ a kanna dem adama a̱ nu,
\q2 i a̱ kuciya̱ ucikpi adama a usuɓi u nu.
\q1 
\v 17 Adama a na avu ɗa tsugbayin ci le n utsura u le,
\q2 n kasingai ka̱ nu kaꞋa ci ciya̱i ucikpi.
\q1 
\v 18 Adama a na mayun Vuzavaguɗu ɗa ma̱ra̱ga̱ ma̱ tsu,
\q2 mogono ma̱ tsu a̱yi ɗa vuza ciɗa vi Isaraila,
\q1 
\v 19 Vu saꞋwa ta̱ kuyaꞋan kadanshi tsa alatani
\q2 u uma a̱ nu a usuɓi m makyan ɗe,
\q2 vu danai,<<N neke ta̱ kovonshi utsura
\q2 vuza na n ɗa̱ngusa̱i a̱ ka̱tsuma̱ ka uma.
\q1 
\v 20 N ciya̱ ta̱ Dawuda kagbashi ka̱ va̱,
\q2 me erengi ta̱ m maniꞋin ma ciɗa,
\q1 
\v 21 Utsura u va̱ wi ta̱ o kuyongo n a̱yi,
\q2 kukiye ku va̱ ki ta̱ a ku zuwa yi u tsurukpa.
\q1 
\v 22 Vurala vu ni vi a kusaꞋwa kulyaꞋa yi ba,
\q2 uma a gbani-gbani i o kuloko yi ba.
\q1 
\v 23 A̱ a̱shi a̱ ni mi ta̱ o ku yokumo irala i ni,
\q2 mu una aza a na a iwain ni.
\q1 
\v 24 Ukuna u ma̱riki u va̱
\q2 n ucigi u va̱ u na u tsu sabaꞋa ba wi ta̱ o kuyongo n a̱yi,
\q2 mi ta̱ a ku zuwa yi u ciya̱ ulyaꞋi.
\q1 
\v 25 Mi ta̱ a kuzuwa tsugono ci ni ci lyaꞋa kelime,
\q2 ili i na i ɗikai a mala,
\q2 ali a kubana e kuyene ku Ifiritis.
\q1 
\v 26 Dawuda wi ta̱ a kudana mu,<Avu esheku a̱ va̱ a ɗa n Ka̱shile ka̱ va̱
\q2 avu ɗa vi e ku ere mu avu ɗa ubuta̱ u kusheɗeku u va̱ n kishi ka̱ va̱.>
\q1 
\v 27 Mi ta̱ o kubonoko yi maku mu ugiti ma̱ va̱,
\q2 vuza na u laꞋi ngono ma aduniyan m gbayin.
\q1 
\v 28 Ucigi u va̱ u na u tsu sabaꞋa ba wi o kuyongo n a̱yi ko wannai,
\q2 uzuwakpani u na n yaꞋin n a̱yi wi ta̱ a kushamgba ko wannai.
\q1 
\v 29 A ntsukaya n ni ɗa a̱ kuciya̱ mogono makyan dem,
\q2 tsugono ci ni ci ta̱ a kushamgba tsa eleshu a gaɗi.
\q1 
\v 30 Ama ɗa baci muku n ni n kpa̱ɗa̱i kutono wila̱ u va̱,
\q2 kpamu o tono ili i na n dansai ba,
\q1 
\v 31 Ɗa baci a̱ ka̱sukpa̱i wila̱ u kadanshi,
\q2 a̱ kpa̱ɗa̱i kutono uneki u kadanshi ka̱ va̱,
\q1 
\v 32 mi ta̱ a kutakacika le adama a unushi u le,
\q2 n faba le adama a kawuya ke le.
\q1 
\v 33 Ama mi a̱ kukpa̱ɗa̱ ku ciga Dawuda ba,
\q2 mi tana a̱ kukpa̱ɗa̱ kushatangu uzuwakpani u na n yaꞋanka ni ba.
\q1 
\v 34 Mi o ku koɗo uzuwakpani u na n yaꞋanka ni ba,
\q2 mi tana a̱ ku sabaꞋa ko ili i te a kadanshi ku una̱ ka̱ va̱ ba.
\q1 
\v 35 N kula ku ciɗa ku va̱ ɗa n yaꞋin a kucina kute koci,
\q2 mi a kuyaꞋanka Dawuda aꞋuwa ba.
\q1 
\v 36 Ntsukaya n ni mi ta̱ o kuyongo ko wannai,
\q2 mi ta̱ a̱ kula̱na̱ tsugono ci ni kanna ki baci de n kutashi.
\q1 
\v 37 Ki ta̱ a kushamgba n utsura tsu wotoi,
\q2 tsu magan mu usuɓi ma na mi gaɗi.>>\qs Kuvuka\qs*
\q1 
\v 38 Ama gogo na vu yaꞋan ta̱ wupa m mazagbi ma̱ nu,
\q2 vu iwain ni ɗa vu variki ni.
\q1 
\v 39 Vu koɗoi uzuwakpani u na vu yaꞋin n kagbashi ka̱ nu,
\q2 vu variki oroliko a̱ ni a̱ ka̱kiza̱.
\q1 
\v 40 Vu ɓosoi asaka a̱ likuci i ni,
\q2 vu bonokoi ubuta̱ u kusheɗeku u ni agali.
\q1 
\v 41 Aza a na i a nwalu a uye i ta̱ o kuboko ucanuku u ni,
\q2 aza a na i a̱ ida̱shi ɗeɗevu n a̱yi o ku zoꞋoso yi.
\q1 
\v 42 Vu zuwai irala i ni i lyaꞋi kelime,
\q2 vu zuwai ra̱ka̱ vu le a yaꞋin ma̱za̱nga̱.
\q1 
\v 43 Vu zuwai ucanuku u kuvon u ni
\q2 wo okpoi ili i gbani,
\q2 vu ka̱sukpa̱i a lyaꞋi ni n kuvon.
\q1 
\v 44 Vu isai ni kalangu ko tsugono ci ni,
\q2 vu lapai kakuba ko tsugono ci ni a iɗika.
\q1 
\v 45 Vu zuwai ni u kutsai babu ayin a̱ ni a yawa,
\q2 vu zuwai wono u kimba̱i ni.\qs Kuvuka\qs*
\q1 
\v 46 Vuzavaguɗu, ali n wannai ɗai va ku sokongu ka̱ci ka̱ nu?
\q2 Ko wannai ɗa?
\q2 Ali n wannai ɗa̱i ka̱ɗu ka̱ nu ka̱ kuka̱na̱ ku kula̱ tsa akina?
\q1 
\v 47 Vuzavaguɗu, ciɓa a na ayin a vuma kenu ɗa a ɗa i,
\q2 ciɓa tsu na vu yaꞋin vuma dem vuza vu ukpa̱ ɗa,
\q1 
\v 48 Yayi u kuyongo n wuma ko wannai, u ku kuwa̱ ba?
\q2 Nini ɗai vuma u kusa̱nka̱ ka̱ci ka̱ ni ku uwa a kasaun? \qs Kuvuka\qs*
\q1 
\v 49 Vuzavaguɗu te ɗai ucigi u nu u tsu sabaꞋa ba u cau?
\q2 Te ɗai uzuwakpani u nu u na vu yaꞋankai Dawuda?
\q1 
\v 50 Vuzavaguɗu, ka̱ta̱ vu cinukpa tsu na a shikusai mu ba, mpa kagbashi ka̱ nu,
\q2 n tsu na n ka̱na̱i ka̱ɗu n kawuya ka na uma i a kuyaꞋanka mu,
\q1 
\v 51 Vuzavaguɗu, ka̱ta̱ vu cinukpa tsu na irala i nu yi o ku zoꞋoso mogono ma na vu erengi ba,
\q2 a̱ ka̱na̱i ku shika yi a̱ ubuta̱ u na u banai dem.
\q1 
\v 52 Tsu cikpai Vuzavaguɗu ko wannai,
\q2 Tananai! Tananai.
\c 90
\ms1 Katagarda ka̱ na̱shi
\mr (Ishp 90--106)
\d Avasa a Musa, vuma vu Ka̱shile.
\q1 
\v 1 Vuzavaguɗu, makyan dem avu ɗa ubuta̱ wi ida̱shi i tsu.
\q2 Ali tsukaya n tsukaya.
\s1 Ka̱shile vi ta̱ lo ko wannai
\q1 
\v 2 Kafu vu yaꞋan nsasan,
\q2 kafu a iɗika
\q2 kafu kpamu vu yaꞋan aduniyan,
\q2 avu Ka̱shile kaꞋa ko wannai.
\q1 Vi n ugiti ba tana vi n ukocishi ba.
\b
\q1 
\v 3 Vu tsu bonoko ta̱ uma tsu na ishi kubuta̱,
\q2 vu dana, <<O bono kubuta̱ a̱ ubuta̱ u na uta̱i.>>
\q1 
\v 4 A̱ya̱ ka̱kpa̱n wa̱ nu i ta̱ tsu kanna ke te,
\q2 i ta̱ tsu kanna ke te ka na ka lazai,
\q2 tsu makyan ma kayin ma na ma lazai.
\q1 
\v 5 Vu tsu pura̱ngu ta̱ uma tsu alavu a̱ ukpa̱
\q2 i ta̱ tsu mita̱ ma na ma̱ tsu uta̱ n usana,
\q1 
\v 6 o gbonguro ali a yaꞋan a̱pa̱lu,
\q2 ka̱ta̱ n kulivi a lumba e ɗekpe.
\b
\q1 
\v 7 Tsu kuwa̱ ta̱ adama a wupa u nu,
\q2 tsu dagaza ta̱ adama asuvu a usuɗukpi a̱ nu.
\q1 
\v 8 Vu gere ta̱ unushi u tsu e kelime ka̱ nu,
\q2 unushi u tsu wu usokongi kpamu,
\q2 vu zuwai u ɗa a̱ ubuta̱ u na ve kene le.
\q1 
\v 9 Wupa u nu u jebe ta̱ ayin a wuma a̱ tsu,
\q2 wuma u tsu u kotsoi tsa ayinviki.
\q1 
\v 10 A̱ya̱ a wuma a̱ tsu ra̱ka̱ a ɗaɗa amangatatsunkupa
\q2 ci baci m ma̱ta̱na̱ a̱ya̱ amanga̱na̱shi,
\q2 n nannai dem ili i na a̱ya̱ a nanlo
\q2 a tsu tuka̱ tsu ɗaɗa
\q2 atakaci n una̱mgbuka̱tsuma̱,
\q1 gogoꞋo lo a laza,
\q2 a̱tsu tamkpamu tsu puwa̱nka̱.
\q1 
\v 11 Yayi u yevei utsura u wupa u nu?
\q2 Yayi u yevei wovon u na wupa u nu u kutuka̱?
\q1 
\v 12 PiꞋisaka tsu ci yeve a na wuma u tsu u makyan me kenu maꞋa,
\q2 adama a na tsu okpo aza a ugboji.
\b
\q1 
\v 13 Vuzavaguɗu, bono,
\q2 ali n wannai ɗai tsa̱ kuka̱na̱ kuvana wu?
\q2 Pana asuvayali agbashi a̱ nu.
\q1 
\v 14 Usana dem yotsongu tsu,
\q2 ucigi u nu u na u tsu sabaꞋa ba,
\q2 adama a na tsu canana ishipa i ma̱za̱nga̱
\q2 a ayin a wuma a̱ u tsu ra̱ka̱.
\q1 
\v 15 Zuwa tsu ci yaꞋan ma̱za̱nga̱,
\q2 tsu ka̱bunda̱i ka ayin a na ci atakaci,
\q2 tsu ka̱bunda̱i ka̱ a̱ya̱ a na tsu takacikai.
\q1 
\v 16 YaꞋan a̱tsu agbashi a̱ nu,
\q2 ci ene ulinga u gbayin u nu,
\q2 yaꞋan ntsukaya n tsu me ene,
\q2 utsura u tsugbayin tsu nu.
\b
\q1 
\v 17 Vuzavaguɗu Ka̱shile ka̱ tsu,
\q2 yaꞋan una̱singai u nu u yongo n a̱tsu,
\q2 vu zuwa tsu ci lyaꞋa kelime a ili i na ci a kuyaꞋan dem,
\q2 vu neke tsu ulyaꞋi a ili i na ci a kuyaꞋan dem.
\c 91
\s1 Ida̱shi a̱ kulu ku vuza vu utsura dem,
\q1 
\v 1 Vuza na baci wi a̱ ida̱shi a̱
\q2 a̱ ubuta̱ u MalaꞋimili dem,
\q2 wi ta̱ a kuvuka a̱ kulu ku vuza vu utsura dem,
\q1 
\v 2 wi ta̱ a kufuɗa kudana Vuzavaguɗu,
\q2 <<Avu ɗa ubuta̱ u kusheɗeku u va̱,
\q2 m mashilya ma utsura ma̱ va̱,
\q1 avu ɗa vuza na vi a ku inda mu,
\q2 avu ɗa Ka̱shile ka̱ va̱,
\q2 wa̱ nu u ɗa n zuwai ka̱ɗu ka̱ va̱.>>
\b
\q1 
\v 3 Mayun wi ta̱ a̱ ku utuka̱ wu a maza ma uma a gbani-gbani,
\q2 kpamu wu utuka̱ wu atakaci a na a̱ kutuka̱ n ukpa̱.
\q1 
\v 4 Wi ta̱ a kupala wu tsu na motoku,
\q2 ma tsu pala muku n ni n evelyu,
\q2 vi ta̱ a̱ kuda̱sa̱ngu m ma̱ta̱na̱ a ɗaka vi le.
\q1 Ma̱riki ma̱ ni mi ta̱ ke ere wu,
\q2 ka̱ta̱ u shamkpa wu.
\q1 
\v 5 Vi a kupana wovon wi ili i wovon i na i kuta̱wa̱ n kayin ba,
\q2 ko vishili vu na a kuyaꞋan n avu n kanna,
\q1 
\v 6 ko ma̱dukpa̱ ma na ma̱ kuta̱wa̱ n kayin,
\q2 ko uma a gbani-gbani a na a ci yaꞋan munuka n kanna a kaci.
\q1 
\v 7 Uma ka̱kpa̱n i ta̱ a̱ kuyikpa̱ ɗevu n avu,
\q2 a̱kpa̱n kupa i ta̱ a̱ kuyikpa̱ e kukiye ku usingai ku nu,
\q2 ama avu ko ili yi a̱ kuciya̱ wu ba.
\q1 
\v 8 Vi ta̱ a ku inda le n a̱shi a̱ nu,
\q2 vu ene tsu na a kutakacika aza asuvawuya.
\b
\q1 
\v 9 A na wo okpoi avu vu danai,
\q2 Vuzavaguɗu ɗa ubuta̱ u kusheɗeku u va̱,
\q2 MalaꞋimili kpamu ubuta̱ wi ida̱shi i va̱.
\q1 
\v 10 Babu ma̱dukpa̱ ma na ma̱ kuciya̱ wu,
\q2 ko kpamu ili i gbani-gbani i na i kuyaꞋan ɗevu n kpaꞋa ku nu.
\q1 
\v 11 Vuzavaguɗu wi ta̱ a kuzuwa alingata a̱ ni inda wu,
\q2 kpamu i ta̱ e kere wu a̱ ubuta̱ u na vu banai dem,
\q1 
\v 12 i ta̱ e kukeɓe wu e ekiye e le,
\q2 adama a na ka̱ ta̱ vu ta̱ɗa̱tsa̱ a katali ba.
\q1 
\v 13 Vi ta̱ a kudasa ikawu m megu,
\q2 vi ta̱ a kudasa ikawu yi utsura n oko o tsukono.
\b
\q1 
\v 14 adama a na u dana ta̱,
\q2 <<Mi ta̱ a ki isa aza a na a cigai mu,
\q2 mi ta̱ a ku inda aza a na e yeve mu.
\q1 
\v 15 Makyan ma na baci u ɗekei mu,
\q2 mi ta̱ a̱ ku ushuku ku yi,
\q2 mi ta̱ o kuyongo n a̱yi makyan ma na wi o kusoꞋo atakaci,
\q2 mi ta̱ a ku isa yi, ka̱ta̱ n neke yi tsugbayin.
\q1 
\v 16 Mi ta̱ a kuzuwa wuma u ni u geshe,
\q2 mayun tana mi ta̱ a ku wawa yi.>>
\c 92
\s1 Ishipa i kucikpa
\d Vishipa. Adama a kanna ka Ashibi
\q1 
\v 1 Ili singai i ɗa a cikpa Vuzavaguɗu,
\q2 a canana ishipa a kula ku Ka̱shile MalaꞋimili.
\q1 
\v 2 Ili i singai i ɗa a sala ucigi u nu u na u tsu sabaꞋa ba n usana,
\q2 ma̱riki ma̱ nu n kayin
\q1 
\v 3 n ili yi iwashi yi umolu,
\q2 n ka̱la̱ka̱tsu ku umolu ku ugaꞋin.
\b
\q1 
\v 4 Vuzavaguɗu,
\q2 ulinga u gbayin u nu
\q2 u tsu zuwa mu ta̱ ma̱za̱nga̱ ka̱u,
\q1 adama ili i na vu yaꞋin,
\q2 mi ta̱ ishipa i ma̱za̱nga̱.
\q1 
\v 5 Vuzavaguɗu, n yiɗa̱i a kugisanku ulinga u gbayin u nu,
\q2 kusheshe ku nu ki ta̱ n atakaci e kuyeve.
\q1 
\v 6 Ili i yoku i ɗa na i na kalau ki e kuyeve ba,
\q2 kpamu ka̱ta̱m ki a kufuɗa ku zuwaka ba,
\q1 
\v 7 a na wo okpoi aza asuvawuya i ta̱ o kugbonguro tsu mita̱,
\q2 aza a na i a kuyaꞋan ka gbani-gbani a̱ kuciya̱ uciyi,
\q1 n nannai dem i ta̱ a ku una le ra̱ka̱-ra̱ka̱.
\b
\q2 
\v 8 Adama a na avu, Vuzavaguɗu ɗa
\q1 MalaꞋimili ko wannai.
\q1 
\v 9 Mayun, Vuzavaguɗu,
\q2 irala i nu yi ta̱ a̱ ku kuwa̱,
\q2 i ta̱ a ku kuwacuwa aza a kuyaꞋan ka gbani-gbani.
\b
\q1 
\v 10 Vu zuwai mu n tsurukpai tsu kanama,
\q2 vu zuwakai mu una̱singai m ma̱za̱nga̱.
\q1 
\v 11 A̱shi a̱ va̱ ene ta̱ tsu na irala i va̱ i yikpa̱i,
\q2 m pana ta̱ ma̱shi ma uma a gbani-gbani.
\b
\q1 
\v 12 Aza a usuɓi i ta̱ o kutopo tsu nshuwa,
\q2 o kugbonguro tsu nɗanga n sida a Lebano,
\q1 
\v 13 n na a̱ shikpa̱i a kpaꞋa ku Vuzavaguɗu,
\q2 i ta̱ a kulyaꞋa kelime a kpaꞋa ku Ka̱shile ka̱ tsu.
\q1 
\v 14 Aza a na i a kumatsa n tsukutsa ci le,
\q2 makyan dem i ta̱ o kuyongo n kuta̱nu n tsuloboi.
\q1 
\v 15 A kusala Vuzavaguɗu wi ta̱ n usuɓi,
\q2 a̱yi na wi e kere mu
\q1 wi n unushi ba.
\c 93
\s1 Ka̱shile mogono maꞋa
\q1 
\v 1 Vuzavaguɗu wi ta̱ o tsugono,
\q2 wi ta̱ n tsugbayin
\q2 Vuzavaguɗu wi ta̱ n tsugbayin kpamu wi ta̱ n utsura
\q1 Vu zuwa ta̱ aduniya a̱ ubuta̱ u na i,
\q2 i tana a̱ kugba̱ɗa̱ ba.
\q1 
\v 2 Vuzavaguɗu, kakuba ko tsugono ka̱ nu
\q2 ka yaꞋan ta̱ ushikpi mayin ali n ugiti ɗe,
\q2 vi ta̱ lo ali n ugiti.
\b
\q1 
\v 3 Vuzavaguɗu, aɓau a̱ ɗa̱nga̱ ta̱,
\q2 aɓau a̱ ɗa̱ngusa̱ ta̱ a̱la̱ka̱tsu e le
\q2 i ta̱ a̱ kuvuzukpa sa n yura̱.
\q1 
\v 4 Vuzavaguɗu wi ta̱ o tsugono gaɗi,
\q2 tsugono ci ni ci ta̱ n tsugbayin,
\q2 tsu laꞋa ta̱ yura̱ ya aɓau a mala,
\q2 tsu laꞋi utsura wo oroꞋo a̱ mini.
\b
\q1 
\v 5 Vuzavaguɗu, wila̱ u kadanshi u nu u shamgba ta̱ n utsura,
\q2 kpaꞋa ku nu ki ta̱ ciɗa,
\q2 ko wannai.
\c 94
\s1 Ka̱shile ki a kuvaruku uma a̱ ni ba
\q1 
\v 1 Vuzavaguɗu, avu Ka̱shile ka kutsupa ili i na a yaꞋin,
\q2 Ka̱shile avu na vu tsu tsupa ili i na a yaꞋin,
\q2 utuka̱ wupa u nu,
\q1 
\v 2 kayaꞋinkafada ka aduniyan,
\q2 ɗa̱nga̱ vu tsupa aza a̱ra̱ɗi,
\q2 ili i na yu untsai le.
\q1 
\v 3 Ali n wannai ɗai aza a gbani-gbani
\q2 a kulyaꞋa kelime n kuyaꞋan ma̱za̱nga̱?
\q2 Ali n wannai ɗai, Vuzavaguɗu?
\q1 
\v 4 Ali n wannai ɗai a̱ kuka̱na̱ ku dansa kavama,
\q2 ali n wannai ɗai aza asuvawuya a kulyaꞋa kelime n a̱ra̱ɗi?
\q1 
\v 5 Vuzavaguɗu, i ta̱ o ku yokumo uma a̱ nu,
\q2 o kudoro uma a̱ nu ili yi uka̱ni i nu.
\q1 
\v 6 A ku una agapa a̱ma̱ci, n omoci,
\q2 nu mkpaꞋan kpamu,
\q1 
\v 7 a kudana, <<Vuzavaguɗu wi e kene tsu ba
\q2 Ka̱shile ka Yakubu ka zuwaka n ili i na yi lo a̱ kugita̱ ba.>>
\b
\q1 
\v 8 Niniɗai yi okpoi a̱ta̱m,
\q2 alau wannai ɗai i ku gbojo?
\q1 
\v 9 Ka̱shile ka na ka yaꞋin atsuvu, a̱yi wi a kupana ba?
\q2 Ka̱shile ka na ka yaꞋin a̱shi a̱yi wi e kene ba?
\q1 
\v 10 A̱yi ɗa wi o kutono n uduniyan u na u buwai,
\q2 wi a kutakacika le ba?
\q2 A̱yi na wi a kupiꞋisaka uma,
\q2 wi n kuyeve ba?
\q1 
\v 11 Vuzavaguɗu u yeve ta̱ kusheshe ku vuma,
\q2 u yeve ta̱ kusheshe ku ni gbani ɗa.
\b
\q1 
\v 12 Vuzavaguɗu, vuza vu ma̱za̱nga̱ ɗa vuza na vu gbarai,
\q2 vuza na vi a kupiꞋisaka wila̱ u nu,
\q1 
\v 13 Adama a na u yongo asuvu a̱ ida̱shi a ayin atakaci,
\q2 ali a̱ ga̱va̱ka̱i aza asuvawuya asaun.
\q1 
\v 14 Adama a na Vuzavaguɗu wi a ku iwan uma a̱ ni ba,
\q2 wi tana a̱ ku ka̱sukpa̱ uma a̱ ni,
\q2 ili yi uka̱ni i ni ba,
\q1 
\v 15 KuyaꞋan ka afada ki ta̱ o kubono a̱ ubuta̱ wa aza a usuɓi,
\q2 aza e mejege i ta̱ a̱ kushuku n a ɗa.
\b
\q1 
\v 16 Yayi u kushamkpa ka mu u yaꞋan tsurala n aza a gbani-gbani?
\q2 Yayi u kuɓa̱nka̱ mu adama a na n takacika aza a gbani-gbani?
\q1 
\v 17 Ishi baci Vuzavaguɗu u ɓa̱nka̱ mu ba,
\q2 a na gogo na n yawa ta̱ ɗe a̱ ubuta̱ wa̱ a̱kpisa̱.
\q1 
\v 18 N danai, <<Mi ta̱ ukuna u kuyikpa̱,>> ama Vuzavaguɗu, ucigi u nu u na u tsu sabaꞋa ba u keɗe mu ta̱.
\q1 
\v 19 Ana atakaci a yaꞋin mu a̱bunda̱i,
\q2 ɗa vu kparasai mu, vu zuwai mu n yaꞋin ma̱za̱nga̱.
\q1 
\v 20 Wi ta̱ a kuyaꞋan vu ɓolongu tsugono n aza a gbani-gbani?
\q2 Ko n aza a na a tsu zuwa wila̱ u kavama?
\q1 
\v 21 O tsu foɓusoko ta̱ uma a usuɓi ka gbani-gbani,
\q2 a tsu kiɗaka ta̱ vuza vu babu unushi afada a̱ ukpa̱.
\q1 
\v 22 Ama Vuzavaguɗu u tsu ere mu ta̱,
\q2 Ka̱shile ka̱ va̱ a̱yi ɗa ubuta̱ u kusheɗeku u va̱.
\q1 
\v 23 A̱yi ɗa u kutakacika le adama a kawuya ke le,
\q2 wu una le adama a unushi u le,
\q2 Vuzavaguɗu Ka̱shile ka̱ tsu ki ta̱ a ku una le.
\c 95
\s1 Ishipa i kucikpa
\q1 
\v 1 Ta̱wa̱i ci yaꞋan ishipa i ma̱za̱nga̱ u Vuzavaguɗu,
\q2 ci cananai ishipa i ma̱za̱nga̱ u katali ka wishi ka̱ tsu.
\q1 
\v 2 YaꞋan tsu ta̱wa̱ e kelime ka̱ ni n kucikpa,
\q2 ci cananai ishipa i ma̱za̱nga̱ n kucikpa.
\q1 
\v 3 Adama a na Vuzavaguɗu Ka̱shile ka gbayin kaꞋa,
\q2 mogono ma gbayin maꞋa wa̱ a̱ma̱li ra̱ka̱.
\q1 
\v 4 Wi ta̱ o tsugono tsa aduniyan ra̱ka̱,
\q2 a ɗaka va aɓatsu atali a kubana,
\q2 a nsasan mu ugaɗi.
\q1 
\v 5 Mala ma̱ ni maꞋa, adama a na a̱yi ɗa u yaꞋin maꞋa,
\q2 n ekiye a̱ ni a ɗa u yaꞋin iɗika i ɗekpu.
\b
\q1 
\v 6 Ta̱wa̱i tsu kuɗa̱ngi ci yaꞋankai ni a̱ga̱nda̱,
\q2 yaꞋan tsu kuɗa̱ngu e kelime,
\q2 ka Vuzavaguɗu, vuza na u yaꞋin tsu.
\q1 
\v 7 Adama a na a̱yi ɗa Ka̱shile ka̱ tsu,
\q2 a̱tsu ɗa uma a na wi a kuguɓa,
\q2 a̱tsu ɗa ushiga wu nkyon u na wi a̱ kula̱na̱.
\q2 I pana baci ka̱la̱ka̱tsu ka̱ ni anana,
\q1 
\v 8 ka̱ta̱ i yaꞋan ugbami u kaci tsu na ikaya i ɗa̱ i yaꞋin a Mariba ba,
\q2 tsu na a yaꞋin e meremune,
\q2 ma Masaha a kanna ka nanlo ba,
\q1 
\v 9 taɗe o tonoi mu kune-kune
\q2 ɗa o kondoi mu,
\q2 ko a na wo okpoi ene ta̱ ili i na n yaꞋin adama e le.
\q1 
\v 10 Ali a̱ya̱ amangere mpa a wupa n tsukaya tsu nanlo,
\q2 n danai <<A̱ɗu a uma a nanlo i wa̱ a̱ va̱ ba,
\q2 kpamu e yeve uye u va̱ ba.>>
\q1 
\v 11 Adama a nannai n kucina ta̱ a̱ ka̱tsuma̱ ka wupa u va̱,\x - \xo 95:11 \xt Mkc 14:20-23; Wil 1:34-36; A Ib 4:3\x*
\q2 n danai, <<I a ku uwa a̱ ubuta̱ u kuvuka u va̱ ba.>>
\c 96
\s1 YaꞋin ishipa i savu u Vuzavaguɗu
\r (1 Ar 16:23-33)
\q1 
\v 1 Cananai ishipa i savu u Vuzavaguɗu,
\q2 cananai ishipa u Vuzavaguɗu aduniyan ra̱ka̱.
\q1 
\v 2 Cananai ishipa u Vuzavaguɗu, cikpai kula ku ni,
\q2 i sala ukuna u wishi u ni kanna lakam.
\q1 
\v 3 Salai tsugbayin ci ni a̱ ka̱tsuma̱ ku uduniyan,
\q2 n ulinga wi ili i mereve i na u yaꞋin a̱ ubuta̱ u uma ra̱ka̱.
\q1 
\v 4 Adama a na Vuzavaguɗu vuza tsugbayin ɗa,
\q2 mayun ɗa a cikpa yi,
\q2 mayun ɗa kpamu a laꞋa n kupana
\q2 wovon u ni n a̱ma̱li ra̱ka̱.
\q1 
\v 5 Adama a na a̱ma̱li aduniyan ra̱ka̱ ili i gbani ɗa,
\q2 ama Vuzavaguɗu a̱yi ɗa u yaꞋin gaɗi.
\q1 
\v 6 Ucikpi n tsugbayin ci ta̱ uka̱ra̱Ꞌi n a̱yi,
\q2 utsura n ugaꞋin u shana ta̱ ubuta̱ wu ida̱shi i ciɗa i ni.
\b
\q1 
\v 7 Nekei Vuzavaguɗu tsugbayin, a̱ɗa̱ uma aduniyan ra̱ka̱,
\q2 cikpai Vuzavaguɗu adama a tsugbayin n utsura u ni.
\q1 
\v 8 Nekei kula ku Vuzavaguɗu tsugbayin,
\q2 tuka̱i n kuneꞋe,
\q2 i uwa punu a ulanga u kpaꞋa ku ni,
\q1 
\v 9 i kuɗa̱ngu e kelime ka Vuzavaguɗu n ugaꞋin u ciɗa u ni,
\q2 i jeꞋeke ikyamba e kelime ka̱ ni a̱ɗa̱ aduniyan ra̱ka̱.
\q1 
\v 10 Dansai a̱ ka̱tsuma̱ ku uduniyan, <<Vuzavaguɗu wi ta̱ o tsugono,
\q2 aduniyan a shamgba ta̱ mayin,
\q2 i a̱ ku gba̱ɗa̱ ba,
\q2 wi ta̱ a kuyaꞋanka uma afada derere.>>
\b
\q1 
\v 11 YaꞋan gaɗi u yaꞋan ma̱za̱nga̱,
\q2 ka̱ta̱ iɗika i yaꞋan ma̱za̱nga̱ feu,
\q2 yaꞋan mala ma yaꞋan yura̱
\q2 n ili i na yi punu ra̱ka̱.
\q2 
\v 12 YaꞋan a̱pula̱ka̱ a yaꞋan ma̱za̱nga̱ n ili i na yi punu ra̱ka̱,
\q1 yaꞋan nɗanga n kutsun ra̱ka̱ n yaꞋan ishipa i ma̱za̱nga̱,
\q2 
\v 13 e kelime ka Vuzavaguɗu,
\q2 adama a na wi ta̱ a̱ kuta̱wa̱,
\q2 wi ta̱ a̱ kuta̱wa̱ u yaꞋanka aduniyan afada,
\q1 wi ta̱ a kuyaꞋanka aduniyan afada a usuɓi,
\q2 n kuyaꞋan ka afada e mejege u uma ra̱ka̱.
\c 97
\s1 Ka̱shile kaꞋa vuza tsugono ra̱ka̱
\q1 
\v 1 Vuzavaguɗu mogono maꞋa,
\q2 yaꞋan iɗika i yaꞋan ma̱za̱nga̱,
\q2 yaꞋan uma a na i a iga̱Ꞌin i mala a yaꞋan ma̱za̱nga̱,
\q1 
\v 2 Eleshu n ka̱yimbi a̱ ka̱ra̱Ꞌi ni,
\q2 n usuɓi n kamayun kaꞋa kumiꞋi ku kakuba ko tsugono ci ni.
\q1 
\v 3 Akina a kuwala e kelime ka̱ ni,
\q2 o kusongu irala i ni i na yi uka̱ra̱Ꞌi n a̱yi.
\q1 
\v 4 Ulaɗi u ni wa akana ta̱ aduniyan,
\q2 aduniyan tana enei ɗa e jeꞋekei ikyamba.
\q1 
\v 5 Nsasan n derikpei e kelime ka Vuzavaguɗu
\q2 tsa abashi ishigi,
\q2 e kelime ka Vuzavaguɗu ka aduniyan ra̱ka̱.
\b
\q1 
\v 6 Gaɗi wi ta̱ a kusala usuɓi u ni,
\q2 uma ra̱ka̱ i ta̱ e kene tsugbayin ci ni.
\q1 
\v 7 Aza a na i o kutono a̱ma̱li ra̱ka̱
\q2 i ta̱ a kuyaꞋan wono,
\q2 aza a na i a̱ra̱ɗi n a̱ma̱li e le feu.
\q1 Ga̱nda̱ka̱i Vuzavaguɗu a̱ɗa̱ a̱ma̱li ra̱ka̱!
\b
\q1 
\v 8 Uma a Sihiyona a panai,
\q2 ɗa a yaꞋin ma̱za̱nga̱,
\q2 aza a̱ likuci i wawaꞋa i Yahuda a yaꞋin ma̱za̱nga̱,
\q2 adama afada a̱ nu Vuzavaguɗu.
\q1 
\v 9 Vuzavaguɗu MalaꞋimili,
\q2 avu ɗa vi a kulyaꞋa tsugono tsa aduniyan ra̱ka̱,
\q2 vu laꞋa ta̱ a̱ma̱li ra̱ka̱ tsugbayin.
\b
\q1 
\v 10 YaꞋan aza a na a cigai Vuzavaguɗu a iwain ka gbani-gbani,
\q2 adama a na u tsu ere ta̱ wuma u uma a̱ ni,
\q2 kpamu u tsu uta̱ka̱ le ta̱ ekiye a uma a gbani-gbani.
\q1 
\v 11 Ulaɗi wa akana ta̱ aza a usuɓi,
\q2 m ma̱za̱nga̱ wa aza e mejege.
\q1 
\v 12 Ra̱ka̱ vu ɗa̱ aza a usuɓi i yaꞋan ma̱za̱nga̱ u Vuzavaguɗu,
\q2 i cikpa kula ku ciɗa ku ni kpamu.
\c 98
\s1 Ucikpi adama usuɓi u Vuzavaguɗu
\q1 
\v 1 Cananai ishipa i savu u Vuzavaguɗu,
\q2 adama ili i mereve i na u yaꞋin.
\q1 Utsura u kukiye ku singai ku ni,
\q2 n utsura u kukiye ku ciɗa ku ni,
\q2 ku ciya̱ka̱i ni ulyaꞋi.
\q1 
\v 2 Vuzavaguɗu u yotsongu ta̱ utsura u wishi u ni,
\q2 ɗa u yotsongi usuɓi u ni a uduniyan.
\q1 
\v 3 U ciɓa ta̱ n ucigi u ni u na u tsu sabaꞋa ba n usuɓi u ni,
\q2 a kpaꞋa ki Isaraila.
\q1 Aduniyan ra̱ka̱ ene ta̱
\q2 ulyaꞋi u Ka̱shile ka̱ tsu.
\q1 
\v 4 YaꞋin ishipa i ma̱za̱nga̱ u Vuzavaguɗu, aduniyan ra̱ka̱,
\q2 cananai ishipa i ma̱za̱nga̱ i ɗa̱ngusa̱ a̱la̱ka̱tsu
\q1 
\v 5 Cikpai Vuzavaguɗu n umolu,
\q2 n umolu n a̱la̱ka̱tsu a ugaꞋin.
\q1 
\v 6 I lika̱ ishari n avana,
\q2 i sala adama a̱ ma̱za̱nga̱ u Vuzavaguɗu mogono.
\q1 
\v 7 YaꞋan mala ma yaꞋan yura̱,
\q2 n ili i na yi punu dem,
\q2 aduniyan n aza a na i punu ida̱shi.
\q1 
\v 8 YaꞋan mala ma ɓasa ekiye adama a̱ ma̱za̱nga̱,
\q2 aginda kpamu ra̱ka̱ a̱ ɗa̱ngusa̱ a̱la̱ka̱tsu a̱ ma̱za̱nga̱,
\q1 
\v 9 e kelime ka Vuzavaguɗu,
\q2 adama a na wi ta̱ a̱ kuta̱wa̱,
\q2 u yaꞋanka aduniyan afada.
\q1 Wi ta̱ a kuyaꞋanka aduniyan afada a usuɓi,
\q2 n kuyaꞋan ka afada e mejege u uma ra̱ka̱.
\c 99
\s1 Vuzavaguɗu Ka̱shile ka̱ tsu wi ta̱ ciɗa
\q1 
\v 1 Vuzavaguɗu mogono maꞋa,
\q2 yaꞋan uma e jeꞋeke ikyamba,
\q1 u da̱sa̱ngu ta̱ a kakuba ko tsugono ci ni a Icorobi,
\q2 yaꞋan aduniyan a̱ gba̱ɗa̱.
\q1 
\v 2 Vuzavaguɗu vuzagbayin ɗa a Sihiyona,
\q2 a̱yi ɗa wi o tsugono tsu uma ra̱ka̱.
\q1 
\v 3 YaꞋan a cikpa kula ku gbayin ku nu,
\q2 n ku utsura ku ni, a̱yi ɗa ciɗa.
\q1 
\v 4 Mogono a utsura u nu vi ta̱ a kuciga afada a na i derere,
\q2 vu zuwai ukuna u mejege,
\q1 n usuɓi n kamayun,
\q2 a kumaci ku Yakubu.
\q1 
\v 5 Cikpai Vuzavaguɗu Ka̱shile ka̱ tsu,
\q2 kuɗa̱ngi e kelime ka̱ ni i cikpa yi,
\q2 a̱yi ɗa ciɗa.
\q1 
\v 6 Musa n Haruna i ta̱ a̱ ka̱tsuma̱ ka anan ganu a̱ ni,
\q2 Samaila kpamu feu wi ta̱ a̱ ka̱tsuma̱ ka aza a na e ci ɗeke kula ku ni.
\q2 a yaꞋin meɗevile u Vuzavaguɗu,
\q2 ɗa tana wu ushuki le.
\q1 
\v 7 U yaꞋin kadanshi n ele e keleshu,
\q2 ɗa o tonoi kadanshi ka̱ ni n kadanshi ka na u shamkpai.
\q1 
\v 8 Vuzavaguɗu Ka̱shile ka̱ tsu,
\q2 vu ushuku le ta̱,
\q2 vu yotsongi le avu Ka̱shile ka kucinukpa unushi kaꞋa,
\q2 ko a na wo okpoi vu takacika le ta̱.
\q1 
\v 9 Cikpai Vuzavaguɗu Ka̱shile ka̱ tsu,
\q2 i ga̱nda̱ka̱ yi a aginda a ciɗa a̱ ni,
\q2 adama a na Vuzavaguɗu Ka̱shile ka̱ tsu vuza ciɗa ɗa.
\c 100
\d Vishipa vu kucikpa.
\q1 
\v 1 YaꞋin ishipa i ma̱za̱nga̱ u Vuzavaguɗu,
\q2 a̱ɗa̱ aduniyan ra̱ka̱
\q1 
\v 2 YaꞋankai Vuzavaguɗu a̱ga̱nda̱ m ma̱za̱nga̱.
\q2 Ta̱wa̱i e kelime ka̱ ni n ishipa i ma̱za̱nga̱.
\q1 
\v 3 I yeve a na Vuzavaguɗu a̱yi ɗa Ka̱shile,
\q2 a̱yi ɗa u yaꞋin tsu, a̱tsu aza a̱ ni a ɗa,
\q2 a̱tsu uma a̱ ni a ɗa n ushiga u ni.
\q1 
\v 4 Uwai utsutsu wa̱ A̱Ꞌisa̱ a gbayin a̱ ni n kucikpa.
\q2 ulanga u kpaꞋa ku ni n kucikpa
\q2 I cikpa yi ka̱ta̱ i neke kula ku ni tsugbayin.
\q1 
\v 5 Adama a na Vuzavaguɗu vuza kasingai ɗa.
\q2 Ucigi u ni u na u tsu sabaꞋa ba
\q2 wi ta̱ lo ko wannai,
\q2 ma̱riki ma̱ ni kpamu tsukaya n tsukaya.
\c 101
\d Vishipa vu Dawuda.
\s1 Uzuwakpani u Mogono
\q1 
\v 1 Vuzavaguɗu, mi ta̱ a kucanana vishipa
\q2 adama a ucigi u na u na u tsu sabaꞋa ba
\q1 n kamayun ka̱ nu,
\q2 n canana ka wu vishipa vu kucikpa.
\q1 
\v 2 Mi ta̱ a kuzuwaka mayin,
\q2 n yongo ko unushi.
\q2 wannai ɗai va̱ kuta̱wa̱ wa̱ a̱ va̱?
\b
\q1 Mi ta̱ o kuyongo a kpaꞋa ku va̱,
\q2 n ka̱ɗu ka ciɗa.
\q1 
\v 3 Mi a kuzuwa a̱shi a̱ va̱
\q2 a ukuna wi ili i wasasa ba.
\q1 N iwan ta̱ ulinga u uma a kavama,
\q2 i a kugbaga mu ba.
\q1 
\v 4 Mi ta̱ a kuyaꞋan daꞋangi n aza a̱ɗu a gbani-gbani,
\q2 babu i na i kugbaɓa mu n ka gbani-gbani.
\q1 
\v 5 Mi ta̱ a ku una,
\q2 vuza na u tsu la̱nga̱sa̱
\q2 kula ku vuza na i a ida̱shi ɗeɗevu n ka̱bini.
\q1 Vuza vu ugbamukaci n kugoyi,
\q2 mi a kugbama asuvu n a̱yi ba.
\q1 
\v 6 A̱shi a̱ va̱ i ta̱ a kinda aza a̱ ma̱riki a iɗika ya,
\q2 adama a na a̱ da̱sa̱ngu koɓolo nu mpa.
\q1 Vuza na u tsu yongo n kamayun a̱ ka̱ɗu ka̱ ni,
\q2 a̱yi ɗa u kuyaꞋanka mu a̱ga̱nda̱.
\q1 
\v 7 Vuza vu ma̱ya̱nsa̱ka̱,
\q2 wi a̱ kuda̱sa̱ngu a kpaꞋa ku va̱ ba.
\q1 Vuza vu na u tsu dansa aꞋuwa,
\q2 wi a kushamgba e kelime ka̱ va̱ ba.
\q1 
\v 8 Usana lakam,
\q2 mi ta̱ a ku una uma a gbani-gbani a̱ likuci ya,
\q1 adama a na n loko aza a gbani-gbani ra̱ka̱,
\q2 punu a̱ likuci i Vuzavaguɗu.
\c 102
\s1 Ma̱shi ma̱ kushika̱ unushi ma vuza na wi atakaci.
\d Kavasa ka vuza va a atakaci a makyan ma na u nambai utsura a̱ ma̱shi e kelime ka Vuzavaguɗu.
\q1 
\v 1 Vuzavaguɗu pana avasa a̱ va̱,
\q2 yaꞋan ma̱shi ma̱ kula̱nsa̱ uɓa̱nki ma̱ va̱,
\q2 ma̱ ta̱wa̱ wa̱ a̱ nu.
\q1 
\v 2 Ka̱ta̱ vu sokongu ku mu a̱shi a̱ nu
\q2 a makyan ma na mi atakaci ba.
\q1 Zuwaka mu atsuvu,
\q2 a makyan ma na baci n yaꞋin meɗevile,
\q2 ushuku mu gogoꞋo.
\q1 
\v 3 Adama a na ayin a̱ va̱ i ta̱ a̱ kupuwa̱nka̱
\q2 tsu ka̱nga̱,
\q1 etele a̱ va̱ a kutakuma n usuɗukpi
\q2 tsa a akina.
\q1 
\v 4 Ka̱ɗu ka̱ va̱ ka̱ ka̱na̱ ta̱ mɓa̱la̱,
\q2 ɗa ko okpoi an mita̱ mu uɗekpu,
\q2 ko mali mi ilikulya n tsu pana ba.
\q1 
\v 5 Adama a inka ya a̱bunda̱i i va̱,
\q2 n yambai ali etele a̱ va̱ uta̱i e keteshe.
\q1 
\v 6 Ɗa mo okpoi an ma̱kpa̱tuwa̱n ma kakamba,
\q2 an ma̱kpa̱tuwa̱n a kagali.
\q1 
\v 7 M asai a̱shi wuma,
\q2 mo okpoi an kojuronjuron endeꞋin a gaɗi vu kukpa̱Ꞌa̱.
\q1 
\v 8 Irala i va̱ i ka̱na̱i kushika mu ali kanna ka̱ɓula̱,
\q2 a kuyaꞋanka mu ma̱ka̱n,
\q2 o bonokoi kula ku va̱ ili yi uyaꞋanki wu una̱.
\q1 
\v 9 Adama a na n lyaꞋa ta̱ kokomo an tsuwa,
\q2 ka̱ta̱ n satara ili i kusoꞋo i va̱ n kujilya
\q1 
\v 10 ɗa vu ɗa̱ngusa̱i mu gaɗi vu ɓasangi mu a iɗika,
\q2 adama a wupa nu n asuvu a usuɗukpi u ka̱ɗu u nu.
\q1 
\v 11 Ayin a̱ va̱ i ta̱ an kulu ku kulivi,
\q2 n ɗekpei an mita̱.
\q1 
\v 12 Ama avu, Vuzavaguɗu,
\q2 vi ta̱ a kakuba ko tsugono ko wannai,
\q1 i ta̱ a kuciɓa n kula ku nu
\q2 a tsukaya a kubana tsukaya.
\q1 
\v 13 Vi ta̱ a̱ kuɗa̱nga̱
\q2 ka̱ta̱ vu sa̱Ꞌa̱ a Sihiyona,
\q1 adama a na makyan maꞋa, ma na va kuɓa̱nka̱ yi,
\q2 makyan ma na o foɓoi ma yawa ta̱.
\q1 
\v 14 Agbashi a̱ nu i ta̱ a kuciga yi,
\q2 ko a na wo okpoi una yi ta̱.
\q1 I ta̱ a̱ kusa̱Ꞌa̱ yi
\q2 ko a na wo okpoi agali.
\q1 
\v 15 Uduniyan wi ta̱ a kupana wovon u kula ku Vuzavaguɗu,
\q1 ngono ma aduniyan ra̱ka̱,
\q2 mi ta̱ a kupana wovon u tsugbayin tsu nu.
\q1 
\v 16 Adama a na Vuzavaguɗu,
\q2 wi ta̱ a kumaꞋasaka Sihiyona,
\q1 ka̱ta̱ wu uta̱ a̱ ka̱tsuma̱ ka tsugbayin ci ni.
\q1 
\v 17 Wi ta̱ a kupana avasa aza a na i n utsura ba,
\q2 kpamu u tsu goyo avasa e le ba.
\b
\q1 
\v 18 Ka̱sukpa̱ a ɗana ili i nampa adama a tsukaya tsu na tsa kuta̱wa̱,
\q2 adama uduniyan u na ka̱ta̱ a matsai ba u cikpa Vuzavaguɗu,
\q1 
\v 19 a dana, Vuzavaguɗu u tsu inda ta̱ aduniyan ɗe gaɗi a̱ ubuta̱ u ciɗa u ni,
\q2 ɗe gaɗi ɗa Vuzavaguɗu u tsu inda aduniyan,
\q1 
\v 20 adama a na u pana yura̱ ya aza a na i a tsugbashi,
\q2 ka̱ta̱ kpamu u shikpa aza a na a kiɗikai afada a̱ ukpa̱.
\q1 
\v 21 I ta̱ a kudansa ukuna u kula ku Vuzavaguɗu a Sihiyona
\q2 ka̱ta̱ a cikpa yi a Urushelima,
\q1 
\v 22 ana uma nu ngono o ɓolongi a̱ ubuta̱ u te,
\q2 adama a cikpa Vuzavaguɗu.
\q1 
\v 23 U jebe mu ta̱ utsura kafu tsukutsa tsu va̱,
\q2 ɗa u gbatyai ka̱bunda̱i ka ayin a wuma u va̱.
\q1 
\v 24 Ɗa n danai, <<Ka̱shile ka̱ va̱,
\q2 ka̱ta̱ vu ɗika mu e mere ma ayin a wuma a̱ va̱ ba,
\q1 avu na a̱ya̱ nu
\q2 tsukaya n tsukaya ɗa.
\q1 
\v 25 A ayin ɗe, an vu yaꞋin aduniyan,
\q2 ɗa gaɗi kpamu wo okpoi ulinga wa ekiye a̱ nu.
\q1 
\v 26 I ta̱ a kukuwa̱, ama vi ta̱ a kulyaꞋa kelime,
\q2 ra̱ka̱ vu le i ta̱ o ku oꞋoi an motogu,
\q1 ka̱ta̱ a sabaꞋasa le tsa a kashi,
\q2 ka̱ta̱ a̱ puwa̱nka̱.
\q1 
\v 27 Ama avu vi ta̱ lo tsu na vi,
\q2 kpamu a̱ya̱ nu i nu uteku ba.
\q1 
\v 28 Muku ma agbashi a̱ nu mi ta̱ o kuyongo m ma̱ta̱na̱,
\q2 kumaci ku le ki ta̱ a kutsurukpa.>>
\c 103
\s1 Vishipa vu ucikpi adama kasingai ka̱ Ka̱shile
\d Vishipa vu Dawuda
\q1 
\v 1 Cikpa Vuzavaguɗu, ka̱ɗu ka̱ va̱.
\q2 Ili ra̱ka̱ i na yi a̱ ka̱tsuma̱ ka̱ va̱,
\q2 cikpai kula ku ciɗa ku ni.
\q1 
\v 2 Cikpa Vuzavaguɗu, ka̱ɗu ka̱ va̱,
\q2 ka̱ta̱ vu cinukpa n kasingai ka̱ ni ba.
\q1 
\v 3 A̱yi ɗa vuza na u kucinukpa nu unushi u nu dem,
\q2 a̱yi ɗa vuza na u kupotsotongu m mɓa̱la̱ n nu dem.
\q1 
\v 4 A̱yi ɗa vuza na wa̱ kushiba̱ wuma u nu e kpenle ku ukpa̱,
\q2 ka̱ta̱ u kala wu nu ucigi
\q2 u na u tsu sabaꞋa n asuvayali a̱ ni.
\q1 
\v 5 A̱yi ɗa vuza na wa ku cuwa̱ta̱ngu wu
\q2 n ili i singai,
\q1 adama a na a sabaꞋa tsuloboi tsu nu
\q2 tsu kajimba.
\q1 
\v 6 Vuzavaguɗu u ci yaꞋan ta̱ kasingai,
\q2 ka̱ta̱ u ɓa̱nka̱ aza a na o doroi.
\q1 
\v 7 U yotsongu ta̱ Musa uye u ni dem,
\q2 ulinga u ni kpamu wa aza a Isaraila.
\q1 
\v 8 Vuzavaguɗu vuza va asuvayali a ɗa
\q2 vuza kasingai ɗa,
\q2 u tsu yaꞋan wupa gogoꞋo ba,
\q2 wi ta̱ tukpa n ucigi u na u tsu sabaꞋa ba.
\q1 
\v 9 U tsu ɓarangu ayin tutu ba,
\q2 kpamu u tsu zuwa wupa u ni u yongo ali ayin ko wannai ba.
\q1 
\v 10 U tsu takacika tsu
\q2 tsu unushi u tsu ba,
\q1 kpamu u ci yaꞋan katsupu derere vu unushi tsu ba.
\q1 
\v 11 Tsu na gaɗi wi daꞋangi n iɗika,
\q1 ta ka̱bunda̱i ku ucigi u ni u na u tsu sabaꞋa wi nannai
\q2 wa aza a na i a kupana wovon u ni.
\q1 
\v 12 Uteku tsu na kasana
\q2 ki daꞋangi n ka̱livi,
\q2 ta u takpai unushi u tsu nannai wa̱ a̱ tsu.
\q2 
\v 13 Uteku u na kesheku
\q2 ka tsu pana asuvayali a̱ muku ni,
\q1 ta feu Vuzavaguɗu u tsu pana asuvayali
\q2 a uma a na a tsu pana wovon u ni nannai.
\q1 
\v 14 Adama a na a̱yi u yeve ta̱ tsu na a yaꞋin tsu,
\q2 ɗa kpamu wi a kuciɓaka tsu an a̱tsu kubuta̱ ku ɗa.
\q1 
\v 15 Vuma dem,
\q2 wuma u ni wi ta̱ tsu mita̱,
\q2 u tsu gbonguro ta̱ u yentukpe an a̱pa̱lu a kakamba,
\q1 
\v 16 ka̱ta̱ a̱ sa̱ruwa̱ ɗa baci wunla̱i u fabai le,
\q2 ka̱ta̱ a cinukpa n ubuta̱ u na ishi.
\q1 
\v 17 Ama ucigi u Vuzavaguɗu u na u tsu sabaꞋa ba
\q2 wi n ugiti ba wi n ukocishi ba
\q2 wa aza a na i a kupana wovon u ni,
\q1 usuɓi u ni wi ta̱ o kuyongo
\q2 a tsukaya n tsukaya,
\q1 
\v 18 koɓolo n aza a na i o kutono kadanshi ka̱ ni,
\q2 n aza a na a tsu ciɓa kutono wila̱ u ni.
\q1 
\v 19 Vuzavaguɗu u shikpa̱ ta̱
\q2 kakuba ko tsugono ci ni gaɗi,
\q1 tsugono ci ni kpamu
\q2 a gaɗi vi ili dem.
\q1 
\v 20 Cikpai Vuzavaguɗu, a̱ɗa̱ alingata a̱ ni,
\q2 a̱ɗa̱ aza a utsura, a na yu ushuki n kadanshi ka̱ ni.
\q1 
\v 21 Cikpai Vuzavaguɗu
\q2 a̱ɗa̱ ili i wuma i gaɗi ra̱ka̱,
\q2 a̱ɗa̱ na yi a̱ kuga̱nda̱ka̱ yi,
\q2 ɗa yi o kutono kadanshi ka̱ ni.
\q1 
\v 22 Cikpai Vuzavaguɗu
\q2 a̱ɗa̱ ili i wuma
\q1 a̱ ubuta̱ u tsugono ci ni dem.
\q2 Cikpa Vuzavaguɗu, avu ka̱ɗu ka̱ va̱.
\c 104
\s1 Vishipa vu ucikpi u Ka̱shile MalaꞋimili
\q1 
\v 1 Cikpa Vuzavagɗu ka̱ɗu ka̱ va̱.
\q2 Avu Vuzavaguɗu Ka̱shile ka̱ va̱,
\q2 avu vuzagbayin ɗa ka̱u,
\q1 vu kala ta̱ ka̱ci ka̱ nu n
\q2 ugaꞋin n tsugbayin.
\q1 
\v 2 Vu pala ta̱ ka̱ci ka̱ nu n kutashi tsu motogu,
\q2 ɗa vu kpa̱Ꞌi gaɗi tsu ma̱va̱li.
\q1 
\v 3 Vu maꞋin ubuta̱ wi ida̱shi i nu
\q2 a gaɗi vu mini ma gaɗi,
\q1 ɗa vu bonokoi eleshu ekeke odoku a̱ nu,
\q2 ɗa vu walai a gaɗi ve evelyu a̱ wunla̱i.
\q1 
\v 4 Vu bonokoi wunla̱i maku mu usuki ma̱ nu,
\q2 melentsu ma akina kpamu vuza va̱ a̱ga̱nda̱ a̱ nu.
\q1 
\v 5 Vu shikpa̱i aduniyan a̱ kumiꞋi ku ni,
\q2 kpamu i kumuɗa̱ ba ko wannai.
\q1 
\v 6 Ɗa vu zuwai mala ma palai aduniyan tsa aminya,
\q2 mini kpamu ma palai nsasan.
\q1 
\v 7 Ama a na vu ɓarangi mini ɗa ma sumai,
\q2 a na ma panai ulapi u kakpanga ka̱ nu ɗa ma sumai,
\q1 
\v 8 ɗa me yenei a gaɗi vu nsasan,
\q2 ma̱ gida̱la̱i a kubana a̱ a̱ra̱Ꞌa̱,
\q2 a̱ ubuta̱ u na vu zuwakai le.
\q1 
\v 9 Vu zuwakai le kureꞋe ku na a kupasa ba,
\q2 adama a na ka̱ta̱ o doku a pala iɗika kpamu ba.
\q1 
\v 10 Vu zuwai mini me yenei a̱ nka̱riki,
\q2 ɗa me yenei e mere ma nsansa,
\q1 
\v 11 e kuneke nnama n kakamba ra̱ka̱ mini,
\q2 a̱ ubuta̱ u na mkparagi n tsu soꞋo mini ma takpaka le kakuli.
\q1 
\v 12 A̱ ka̱kina̱ ka̱ mini ka, ta ɗe nnu n kakamba n tsu da̱sa̱ngu.
\q2 e mere ma a nsaɓu a nɗanga a taɗe a ci yaꞋan ishipa i le.
\q1 
\v 13 Ɗe gaɗi a̱ ubuta̱ wi ida̱shi u nu,
\q2 ɗa vu tsu neke nsasan mini,
\q2 ka̱ta̱ iɗika i shana n kasingai ku ulinga u nu.
\q1 
\v 14 Vu zuwai mita̱ mo gbonguro adama a ilikuzuwa,
\q2 ica̱Ꞌa̱shi kpamu adama a na vuma,
\q2 u ciya̱ ilikulya a iɗika,
\q1 
\v 15 ma̱kya̱n kpamu adama a na
\q2 u zuwa ka̱ɗu ka vuma ma̱za̱nga̱,
\q2 m maniꞋin adama a na a̱shi a̱ ni a gaꞋan,
\q2 n ilikulya adama a na vuma u ciya̱ utsura wi ikyamba.
\q1 
\v 16 Nɗanga n na Vuzavaguɗu
\q2 u ca̱Ꞌi n ciya̱ ta̱ mini mayin,
\q2 tsu nɗanga n sida n Lebano,
\q1 
\v 17 a gaɗi vu le, taɗe nnunu n ci yaꞋan cikinda ci le,
\q2 ta ɗe feu mapapadan u ci yaꞋan ta̱ kpaꞋa ku ni.
\q1 
\v 18 Nsasan m gbagbaꞋin mi igeve n ɗa,
\q2 aɓatsu kpamu ubuta̱ u kusheɗeku n rema n ɗa.
\q1 
\v 19 Vu yaꞋin wotoi adama a na vu yotsongu ayin,
\q2 kanna kpamu ke yeve ta̱ makyan ma na ki a̱ kuyikpa̱.
\q1 
\v 20 Vu yaꞋin kayin n ka̱yimbi,
\q2 a makyan ma nanlo maꞋa
\q2 nnama n kakamba ra̱ka̱ n tsu uta̱.
\q1 
\v 21 Ikawu i tsu ura̱ ta̱ a makyan ma na i a kutambu,
\q2 a̱ kula̱nsa̱ i na a kulyaꞋa u Ka̱shile,
\q1 
\v 22 kanna ku uta̱ baci,
\q2 ka̱ta̱ o bono a vaku a enle e le,
\q1 
\v 23 vuma tankpamu wu uta̱ ulinga,
\q2 ali a kubana kulivi.
\q1 
\v 24 Vuzavaguɗu la̱na̱
\q2 ka̱bunda̱i ku ulinga u nu,
\q1 a̱ ka̱tsuma̱ ka kuyeve
\q2 ɗa vu yaꞋin ili i nampa ra̱ka̱,
\q2 aduniyan a shana ta̱ tukpa ni i na vu yaꞋin.
\q1 
\v 25 Mala mi ta̱ n wanshi nu mgbayin,
\q2 tukpa n imacishi i na i laꞋi ku kece,
\q2 ili i wuma, i gbagbaꞋin ni i kenkeꞋen dem.
\q1 
\v 26 Antsu a̱ mini i ta̱ lo,
\q2 a kubana n o bonoi,
\q2 oroꞋo a na vi yaꞋin,
\q1 adama a na o yongo a̱ mini.
\q1 
\v 27 Ra̱ka̱ vu le avu ɗa i a kinda
\q2 adama a na vu neke le ilikulya
\q2 a makyan ma na a cikalai.
\q1 
\v 28 Vi neke le baci i na a cikalai
\q2 ka̱ta̱ o ɓolongu i ɗa,
\q2 vu neke le baci ili i na yi e kukiye ku nu,
\q1 ka̱ta̱ a lyaꞋa a̱ cuwa̱ mayin.
\q1 
\v 29 Ɗa baci vu sokongi a̱shi a̱ nu,
\q2 ka̱ta̱ a pana wovon,
\q2 vu ɗika baci ayinviki e le ka̱ta̱ a̱ kuwa̱.
\q2 o bono a̱ kubuta̱ ubuta̱ u na uta̱i.
\q1 
\v 30 Ɗa baci vu suꞋuki n ayinviki a̱ nu,
\q2 ka̱ta̱ a matsa le,
\q2 kpamu vu tsu sabaꞋa ta̱ a̱shi aduniyan.
\q1 
\v 31 YaꞋan tsugbayin tsu Vuzavaguɗu,
\q2 ci yongo ko wannai.
\q2 yaꞋan Vuzavaguɗu u yaꞋan ma̱za̱nga̱ n ulinga u ni.
\q1 
\v 32 A̱yi na wi inda baci aduniyan,
\q2 ka̱ta̱ a̱ gba̱ɗa̱,
\q1 ɗa baci u saꞋwai nsasan m gbagbaꞋin,
\q2 ka̱ta̱ n ɗa mu utuka̱ n ka̱nga̱.
\q1 
\v 33 Mi ta̱ a kuyaꞋan vishipa u Vuzavaguɗu
\q2 a wuma u va̱ dem,
\q1 mi ta̱ a kuyaꞋan vishipa vu kucikpa u Ka̱shile ka̱ va̱
\q2 a ayin a wuma u va̱ dem.
\q1 
\v 34 YaꞋan kusheshe ku va̱ ku zuwa yi ma̱za̱nga̱,
\q2 ka̱ta̱ mpa tamkpamu
\q2 n yaꞋan ma̱za̱nga̱ u Vuzavaguɗu.
\q1 
\v 35 Ama yaꞋan aza a unushi a̱ puwa̱nka̱ punu a aduniyan
\q2 ka̱ta̱ odoku ene aza a gbani-gbani ba.
\q1 Cikpa Vuzavaguɗu, avu ka̱ɗu ka̱ va̱,
\q2 Cikpa Vuzavaguɗu.
\c 105
\s1 Ka̱shile n uma a̱ ni
\r (1 Ar 16:8-22)
\q1 
\v 1 Cikpai Vuzavaguɗu,
\q2 ɗekei kula ku ni,
\q2 salai ukuna wu ulinga u ni,
\q2 a kumaci ku uduniyan dem.
\q1 
\v 2 YaꞋankai ni ishipa,
\q2 yaꞋankai ni ishipa yu ucikpi.
\q2 dansai ukuna wu ulinga
\q2 u mereve u na u yaꞋin ra̱ka̱.
\q1 
\v 3 YaꞋin ma̱za̱nga̱ adama a
\q2 kula ku ciɗa ku ni,
\q2 yaꞋan a̱ɗu a aza a na a̱ la̱nsa̱i,
\q2 Vuzavaguɗu a yaꞋan ma̱za̱nga̱.
\q1 
\v 4 Zuwai a̱ɗu a̱ ɗa̱ u Vuzavaguɗu,
\q2 n utsura u ni,
\q2 la̱nsa̱i a̱shi a̱ ni a makyan dem.
\q1 
\v 5 Ciɓai n ulinga u mereve u ni,
\q2 nu urotu u mereve u ni,
\q2 n afada a na u kiɗai,
\q2 ɗa u dansai n una̱ u ni,
\q1 
\v 6 a̱ɗa̱ ntsukaya n kagbashi ka̱ ni Ibirahi,
\q2 a̱ɗa̱ muku n Yakubu nzagbi n ni.
\q1 
\v 7 A̱yi ɗa Vuzavaguɗu Ka̱shile ka̱ tsu,
\q2 afada a̱ ni i ta̱ a ubuta̱ dem aduniyan.
\q1 
\v 8 U tsu ciɓa ta̱ n uzuwakpani
\q2 u ni u ko wannai,
\q2 kadanshi ka na vu nekei,
\q2 a kubana tsukaya a̱kpa̱n,
\q1 
\v 9 uzuwakpani u na u yaꞋin n Ibirahi,
\q2 akucina a̱ ni a na u yaꞋan n Ishaku,\x - \xo 105:9 \xt Ugi 12:7; 17:8\x*
\q1 
\v 10 u na u dansai u Yakubu mayun ɗa,
\q2 uzuwakpani wa aza a Isaraila ko wannai,
\q1 
\v 11 u danai,<<Wa̱ a̱ nu ɗa n ku neke
\q2 iɗika ya aza a KanaꞋana,
\q2 yo okpo ubuta̱ wu uka̱ni u ɗa̱.>>
\q1 
\v 12 A ayin a na biꞋi i kenu,
\q2 kenu gbani, kpamu omoci a ɗa
\q2 a iɗika ya,
\q1 
\v 13 a̱ ka̱ka̱ra̱sa̱ a iɗika-iɗika,
\q2 o tsugono tsu nampa a kubana tsu nanɗe,
\q1 
\v 14 u ka̱sukpa̱ aza o yoku o doro le ba,
\q2 kpamu ɗa u ɓarangi ngono adama e le,
\q1 
\v 15 a kudana <<Ka̱ta̱ i saꞋwa nzagbi n va̱ ba,
\q2 ka̱ta̱ kpamu i uka eneki a̱va̱ muna ba.>>
\q1 
\v 16 U tuka̱i n kambulu a iɗika ya,
\q2 ɗa u la̱nga̱sa̱i ubuta̱ u kuciya̱ ilikulyaꞋa dem,
\q1 
\v 17 ɗa u suki vuza e kelime ke le,
\q2 Isufu vu na e dengei tsu kagbashi.
\q1 
\v 18 A̱yi na a shiyai ene a̱ ni n ikani,
\q2 kuɗeku ku ni kpamu m kogboro ka̱ viyum,
\q1 
\v 19 ali makyan ma na kene ku na
\q2 a yaꞋin a kaci ka̱ ni ku shanai,
\q2 ali kadanshi ka Vuzavaguɗu
\q2 ko yotsongi ili i na u dansai va mayun ɗa.
\q1 
\v 20 Mogono ma̱ suki a̱ ka̱sukpa̱ yi,
\q2 vuza vu tsugono tsu aduniyan wu uta̱ka̱ ni.
\q1 
\v 21 Ɗa u zuwai ni wo okpo
\q2 Vuzagbayin vu kpaꞋa ku ni,
\q2 u bonokoi ni vuza kula̱na̱
\q2 ucanuku u kpaꞋa ku ni dem,
\q1 
\v 22 adama a na u ɓarangu
\q2 aza o tsugono a̱ likuci,
\q2 tsu na u cikalai,
\q1 ka̱ta̱ kpamu u piꞋisaka
\q2 nkoshi m gba̱ra̱-gba̱ra̱ kuyeve.
\q1 
\v 23 Ɗa Isaraila u uwai a Masar,
\q2 Yakubu tamkpamu
\q2 u da̱sa̱ngi limoci a iɗika i Ham.
\q1 
\v 24 Vuzavaguɗu u zuwai,
\q2 uma a̱ ni a matsasakai n ka̱bunda̱i,
\q2 u zuwai a laꞋa irala i le utsura.
\q1 
\v 25 Ɗa Vuzavaguɗu u sabaꞋi a̱ɗu a irala i le,
\q1 a iwan uma a̱ ni,
\q2 e sheshei ka gbani-gbani adama e le.
\q1 
\v 26 U suki kagbashi ka̱ ni Musa,
\q2 n Haruna aza na u zagbai.
\q1 
\v 27 A yaꞋansai ukuna u gbagbaꞋin e kelime ke le,
\q2 a yaꞋin ili i mereve a iɗika i Ham.
\q1 
\v 28 U suki n ka̱yimbi,
\q2 ɗa tana a yaꞋin ka̱yimbi a iɗika ya,
\q1 adama a na aza a Masar,
\q2 a yaꞋan ta̱ ugbamiwasuvu
\q2 n kadanshi ka̱ ni.
\q1 
\v 29 U bonokoi mini me le mpasa,
\q2 u zuwai adan e le a̱ kuwa̱i.
\q1 
\v 30 Iɗika i le i shanai n opoɗo,
\q2 ali a uwai anunu a ku asa o ngono n le.
\q1 
\v 31 U yaꞋin kadanshi
\q2 ɗa ka̱kuma̱ ka ayun ka̱ ta̱wa̱i,
\q2 ɗa nkulaꞋin n shanai a iɗika ya.
\q1 
\v 32 U yoꞋokoi le mini ma atali,
\q2 a na wo yoꞋokoi le m mini ma gaɗi,
\q2 n ulaɗi u na wu akanai iɗika i le ra̱ka̱,
\q1 
\v 33 ɗa ma lapai ashina a itacishi,
\q2 nu nɗanga n zaitu n le,
\q2 ɗa o koɗosoi nɗanga mi iɗika n le,
\q1 
\v 34 U yaꞋin kadanshi ɗa ka̱kuma̱ ka akyun ku uta̱i,
\q2 nta̱ɗa̱ma̱ci a na a laꞋi kukece.
\q1 
\v 35 A takumai ica̱Ꞌa̱shi yi iɗika i le ra̱ka̱,
\q2 a takumai ili ya ashina e le dem.
\q1 
\v 36 Ɗa u lapai muku mu ugiti mi iɗika n le ra̱ka̱,
\q2 muku mu ugiti mu utsura u le,
\q1 
\v 37 Wu uta̱ka̱i n aza a Isaraila
\q2 tukpa n azanariya n azurufa,
\q1 ko vuza te a kumaci ku le u ta̱ɗa̱tsa̱ ba.
\q1 
\v 38 Aza a Masar a yaꞋin,
\q2 ma̱za̱nga̱ n wu uta̱i u le,
\q2 adama a na i ta̱ a kupana wovon
\q2 wa aza a Isaraila ka̱u.
\q1 
\v 39 U zuwai keleshu n kanna,
\q2 adama a na u neke le kulu,
\q1 akina kpamu n kayin
\q2 adama a na u neke le kutashi.
\q1 
\v 40 O folonoi ɗa u nekei le nroni,
\q2 ɗa kpamu u nekei le ilikulyaꞋa i gaɗi,
\q2 a lyaꞋi a̱ cuwa̱i.
\q1 
\v 41 U ka̱ga̱lukpa̱i katali
\q2 ɗa mini mu uta̱i,
\q2 ɗa me yenei a kakamba tsu kuyene.
\q1 
\v 42 Adama a na u ciɓa ta̱,
\q2 n uzuwakpani u ciɗa u ni,
\q2 u na u yaꞋankai kagbashi ka̱ ni Ibirahi,
\q1 
\v 43 Wu utuka̱i uma a̱ ni m ma̱za̱nga̱,
\q2 nzagbi n ni kpamu n ishipa i ma̱za̱nga̱.
\q1 
\v 44 Ɗa u nekei le iɗika ya aza a KanaꞋana,
\q2 ɗa u ka̱sukpa̱i le a lyaꞋa ili yu uka̱ni i le,
\q1 
\v 45 adama a na o tono wila̱ u ni,
\q2 ka̱ta̱ kpamu o tono,
\q2 kuyotsongusu ku ni.
\q1 Cikpai Vuzavaguɗu.
\c 106
\q1 
\v 1 Cikpai Vuzavaguɗu.
\q1 Cikpai Vuzavaguɗu adama a na a̱yi vuza kasingai ɗa,
\q2 ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.
\q1 
\v 2 Yayi u kusala ili i gbagbain
\q2 i na Vuzavaguɗu u yaꞋin,
\q2 ko u dansa ucikpi u ni?
\q1 
\v 3 Aza a̱ ma̱za̱nga̱ a ɗa,
\q2 ele na a̱ ka̱na̱i ukuna wu usuɓi,
\q2 ele na a ci yaꞋan i na yi derere makyan dem.
\q1 
\v 4 Ciɓa nu mpa, Vuzavaguɗu,
\q2 ayin a na baci vu yaꞋankai uma a̱ nu kasingai,
\q1 ɓa̱nka̱ mu Vuzavaguɗu,
\q2 a ayin a na baci vu wawai le,
\q1 
\v 5 ciya̱ m pana uyoꞋo wu ulyaꞋi u kelime
\q2 wa aza a na vu zagbai,
\q2 ciya̱ n yaꞋan feu ma̱za̱nga̱ n uma a̱ nu,
\q2 ka̱ta̱ n uwa a̱ ka̱tsuma̱ ka
\q2 ili yi uka̱ni i nu n kucikpa.
\q1 
\v 6 Tsu nusa ta̱,
\q2 tsu na ikaya i tsu i yaꞋin,
\q1 ci yaꞋan derere ba,
\q2 ci yaꞋin ka gbani-gbani.
\q1 
\v 7 Ayin a na ikaya i tsu yi ishi a Masar,
\q2 a zuwaka n ukuna wu ili i mereve i nu ba,
\q2 a ciɓa n ucigi u nu u na u tsu sabaꞋa ba.
\q1 ɗa a yaꞋin ugbamiwasuvu
\q2 a Mala ma Shili.
\q1 
\v 8 N nannai dem,
\q2 ɗa u wawai le adama a kula ku ni.
\q1 Ciya̱ u yotsongu utsura u ni,
\q2 u gbayin u ɗa.
\q1 
\v 9 U ɓarangi Mala ma Shili,
\q2 ɗa me ɗekpei.
\q1 U tonoi n ele punu
\q2 adanshi iɗika i ɗekpu i ɗa.
\q1 
\v 10 U wawai le
\q2 e ekiye a irala.
\q1 U shiba̱i le,
\q2 e ekiye aza a na a iwain le.
\q1 
\v 11 Ɗa mini ma lyaꞋi irala i le.
\q2 ko vuza te a̱ ka̱tsuma̱ ke le u laꞋa ba.
\q1 
\v 12 Ɗa e nekei a̱ɗu n uzuwakpani u ni,
\q2 ɗa a cikpai ni.
\b
\q1 
\v 13 Ama gogoꞋo lo ɗa a cinukpai
\q2 n ili i na u yaꞋankai le,
\q2 a vana odoki a̱ ni ba.
\q1 
\v 14 A̱shi a wuya a̱ ka̱na̱i le e meremune,
\q2 ɗa o kondoi Ka̱shile a kakamba ka ɗe.
\q1 
\v 15 Ɗa u nekei le ili i na o folonoi,
\q2 ama ɗa u suꞋuki le nu mɓa̱la̱ m gbani-gbani.
\b
\q1 
\v 16 A yaꞋin tsurala m Musa a̱ ka̱tsura̱ ka ɗe
\q2 koɓolo n Haruna, a̱yi na Vuzavaguɗu we erengi.
\q1 
\v 17 Iɗika i ɓa̱yuwa̱i ɗa i soɗongi Datan.
\q2 ɗa i ciɗa̱ngi uma a Abiram.
\q1 
\v 18 Akina a lyaꞋi aza a na i o kutono le.
\q2 ɗa melentsu ma akina me leɓecei aza a gbani-gbani.
\b
\q1 
\v 19 A yimai medendem
\q2 ma azanariya a Horebu,
\q2 ɗa a cikpai ka̱ma̱li ka na a̱ luwa̱i va.
\q1 
\v 20 O bonoi a ɗikai tsugbayin tsu Ka̱shile
\q2 e nekei ka̱ma̱li ko iyoci i kobomburon,
\q2 ka na ka tsu takuma ijanu.
\q1 
\v 21 A cinukpai n Ka̱shile ka na ka wawai le,
\q2 a̱yi vu na u yaꞋin ili i gbagbaꞋin a Masar,
\q1 
\v 22 ili i mereve i na u yaꞋin a iɗika i Ham
\q2 n ili i gbagbaꞋin kpamu i na u yaꞋin
\q2 a Mala ma Shili.
\q1 
\v 23 Adama a nannai ɗa u danai
\q2 wi ta̱ a ku una le,
\q2 ama Musa mazagbi ma̱ ni,
\q1 u uwai e mere me le n Ka̱shile,
\q2 adama a na u sa̱nka̱ wupa u ni ku una le.
\b
\q1 
\v 24 Ɗa uma o goyoi iɗika i singai ya.
\q2 e neke a̱ɗu n uzuwakpani u ni ba.
\q1 
\v 25 O yongoi o mololo,
\q2 punu a̱ a̱pa̱m e le.
\q1 Ɗa a̱ kpa̱ɗa̱i kutono,
\q2 kadanshi ka Vuzavaguɗu.
\q1 
\v 26 Ɗa u kucinakai le,
\q2 u ɗengusa̱i ekiye gaɗi u danai.
\q1 Wi ta̱ a kuzuwa le a̱ kuwa̱ e meremune,
\q1 
\v 27 ka̱ta̱ u zuwa ntsukaya n le
\q2 n wacuwa a uduniyan kakau,
\q2 a̱ kuwa̱ a iɗika yi uduma.
\b
\q1 
\v 28 A gbaɓai kaci n ka̱ma̱li ka BaꞋalu vu Piyo,
\q2 ɗa a lyaꞋi alyuka a na a yaꞋankai
\q2 ka̱ma̱li ka na ki n wuma ba,
\q1 
\v 29 a zuwai Vuzavaguɗu wupa
\q2 adama a ili i gbani-gbani i na a yaꞋin,
\q2 ɗa ta na ma̱dukpa̱ ma uwai le.
\q1 
\v 30 Ama Finihasu u ɗa̱nga̱i,
\q2 ɗa u kiɗai kadanshi,
\q2 ɗa ma̱dukpa̱ ma zuwakai uteku.
\q1 
\v 31 Adama a ili yi usuɓi i na u yaꞋin,
\q2 ɗa yo okpoi ili i kuciɓasa,
\q2 ali a kubana a tsukaya n tsukaya.
\b
\q1 
\v 32 Ɗevu n kuɗolu ku Meriba
\q2 a zuwai Vuzavaguɗu wupa,
\q2 ɗa kadama ka cinai Musa adama e le,
\q1 
\v 33 adama a na a yaꞋanka ta̱
\q2 Ayinviki a̱ Ka̱shile ugbamiwasuvu,
\q1 ali a zuwai Musa wupa
\q2 ɗa u dansai wa̱u.
\b
\q1 
\v 34 Una uma a ba,
\q2 tsu na Vuzavaguɗu u danai le ba,
\q1 
\v 35 ama o bonoi a gbaɓai n uduniyan wa,
\q2 o tonoi kuyongo ku le.
\q1 
\v 36 A cikpai a̱ma̱li uduniyan a,
\q2 a na okpoi le maza.
\q1 
\v 37 A lyukai olobo n ni nkere n le
\q2 a̱ ubuta̱ u wunla̱i u gbani-gbani.
\q1 
\v 38 A̱ tsuwa̱in mpasa
\q2 ma aza a na i n unushi ba,
\q2 mpasa m muku le olobo ni nkere,
\q1 aza a na a lyukai wa̱ a̱ma̱li a KanaꞋana,
\q2 ɗa iɗika i na̱mgba̱i
\q2 adama a mpasa n le.
\q1 
\v 39 A natukpai ka̱ci ke le
\q2 adama a ili i na a yaꞋin,
\q2 o tonoi a̱ma̱li o yoku.
\b
\q1 
\v 40 Adama a nannai,
\q2 ɗa Vuzavaguɗu u yaꞋin wupa n uma a̱ ni,
\q2 ali u ka̱na̱i ku ene unata wi ili yi uka̱ni i ni.
\q1 
\v 41 U nekei le e ekiye uduniyan u yoku,
\q2 ɗa irala i le i lyaꞋakai le tsugono.
\q1 
\v 42 Irala i le i takacikai le,
\q2 a gutsakai le, a yaꞋanka le ulinga.
\q1 
\v 43 U tsu wawa le ta̱ ayin dem,
\q2 ama ɗa a̱ ka̱na̱i kuyaꞋanka yi
\q2 ugbamiwasuvu,
\q2 ali unushi u le u tuka̱i le n kugoyi.
\b
\q1 
\v 44 Ama ɗa u zuwakai n atakaci e le,
\q2 ana u panai ma̱shi me le,
\q1 
\v 45 ɗa u ciɓai n uzuwakpani u ni n ele,
\q2 ɗa u panai asuvayali e le,
\q2 adama ucigi u ni u na u tsu sabaꞋa ba.
\q1 
\v 46 U zuwai aza a na a ɗikai le,
\q2 tsa agbashi a̱ sa̱Ꞌi le.
\b
\q1 
\v 47 Vuzavaguɗu Ka̱shile ka̱ tsu, Wawa tsu,
\q2 ka̱ta̱ vu ɓolongu tsu a̱ ubuta̱ wu uduniyan,
\q1 adama a na tsu cikpa kula ku ciɗa ku nu
\q2 ci neke wu tsugbayin a̱ ubuta̱ u kucikpa wu.
\b
\q1 
\v 48 Una̱singai a kubana u Vuzavaguɗu,
\q2 Ka̱shile ki Isaraila,
\q2 a tsukaya a kubana tsukaya,
\q1 YaꞋan uma a aduniyan dem a̱ ushuku a dana, <<Ta nannai>>
\q1 Cikpai Vuzavaguɗu.
\c 107
\d KATAGARDA KA TAWUN
\r (Ishp 107--150)
\s1 Ishipa i kucikpa u Ka̱shila̱
\s1 Ishipa i kucikpa adama a kasingai
\q1 
\v 1 Cikpai Vuzavaguɗu,
\q2 adama a na a̱yi vuza kasingai ɗa,
\q1 ucigi u ni u na u tsu sabaꞋa ba
\q2 ko wannai ɗa.
\q1 
\v 2 YaꞋan aza a na Vuzavaguɗu u shiba̱i
\q2 a dansa ukuna u nampa,
\q1 aza a na u shiba̱i e ekiye a irala,
\q1 
\v 3 n aza a na u ɓolongi a iɗika kakau,
\q2 a kasana n ka̱livi,
\q2 a uɓon u gaɗi n uɓon u ɗakai.
\b
\q1 
\v 4 Aza a Israila a̱ ka̱ra̱sa̱ ta̱ e meremune,
\q2 a̱ ciya̱ uye a kubana a̱ likuci i na a̱ kuda̱sa̱ngu ba.
\q1 
\v 5 Kambulu ka̱ ka̱na̱i le n kakuli,
\q2 ɗa a takpai asuvu.
\q1 
\v 6 Ɗa a bankai m ma̱shi me le u Vuzavaguɗu,
\q2 a̱ ka̱tsuma̱ ka atakaci e le,
\q2 ɗa tana u wawai le, a kadama ke le.
\q1 
\v 7 U tonoi n ele n uye u na wu untsukai,
\q2 a kubana a̱ likuci i na a̱ kuda̱sa̱ngu.
\q1 
\v 8 YaꞋan a cikpa Vuzavaguɗu
\q2 a dama a ucigi u ni u na u tsu sabaꞋa ba,
\q1 n adama a ulinga wi ili i mereve i ni
\q2 a̱ ubuta̱ u uma,
\q1 
\v 9 adama a na u tsu neke ta̱
\q2 aza a kakuli mini,
\q2 u tsu cuwa̱ta̱ngu ta̱
\q2 aza a kambulu n ilikulya i singai.
\b
\q1 
\v 10 Aza a Israila a̱ da̱sa̱ngi a̱ ka̱yimbi,
\q2 n ka̱yimbi ka kpaɓam,
\q2 aza a ugbashi atakaci n ikani,
\q1 
\v 11 adama a na a yaꞋanka ta̱
\q2 kadanshi ka̱ Ka̱shile ugbamiwasuvu
\q2 o ogoyoi odoki a MalaꞋimili.
\q1 
\v 12 Ɗa u zuwai le ulinga wa atakaci ka̱u,
\q2 a̱ ka̱na̱i kuta̱ɗa̱tsa̱sa̱,
\q2 kpamu ko ka̱ɓa̱nki.
\q1 
\v 13 Ɗa a bankai m ma̱shi me le u Vuzavaguɗu,
\q2 a̱ ka̱tsuma̱ ka atakaci e le,
\q2 ɗa tana u wawai le, a kadama ke le.
\q1 
\v 14 Wu uta̱ka̱i le a̱ ka̱tsuma̱ ka̱ ka̱yimbi,
\q2 n ka̱yimbi ka kpaɓam,
\q2 ɗa u taɓai ikani i le.
\b
\q1 
\v 15 YaꞋan a cikpa Vuzavaguɗu
\q2 adama a ucigi u ni u na u tsu sabaꞋa ba,
\q1 n adama a ulinga wi ili i mereve i ni,
\q2 a̱ ubuta̱ u uma.
\q1 
\v 16 Adama a na u fa̱da̱ ta̱,
\q2 ukungulu wi iyum i shili
\q2 ɗa u kiɗai agbaguratsu a̱ iyum.
\q1 
\v 17 Aza a Isaraila okpoi alau
\q2 a uye u gbani-gbani u le,
\q2 a takacikai adama unushi u le.
\q1 
\v 18 Ili i kulyaꞋa dem
\q2 i luwa le ba,
\q1 ali ɗa a yawai ɗevu n kukuwa̱.
\q1 
\v 19 Ɗa a bankai m ma̱shi me le u Vuzavaguɗu,
\q2 a̱ ka̱tsuma̱ ka atakaci e le,
\q2 ɗa tana u wawai le, a kadama ke le.
\q1 
\v 20 U nekei kadanshi, ɗa ko potsokpoi le,
\q2 u wawai le a̱ ubuta̱ wa a asaun.
\b
\q1 
\v 21 YaꞋan a cikpa Vuzavaguɗu
\q2 adama a ucigi u ni u na u tsu sabaꞋa ba,
\q1 n adama a ulinga wi ili i mereve i ni
\q2 a̱ ubuta̱ u uma.
\q1 
\v 22 YaꞋan a̱ tuka̱ n kuneꞋe ku ucikpi,
\q2 ka̱ta̱ kpamu a sala ulinga u ni
\q2 a̱ ka̱tsuma̱ ki ishipa i ma̱za̱nga̱.
\b
\q1 
\v 23 Aza o yoku a wala ta̱ a mala n antsu,
\q2 ele aza a tsulaga a ɗa a̱ mini ma gbagbaꞋin.
\q1 
\v 24 Ene ta̱ ulinga u Vuzavaguɗu,
\q2 n ulinga u mereve u ni a mala ma uga̱vi.
\q1 
\v 25 Ana u nekei kadanshi
\q2 ɗa wunla̱i wu utsura u ɗa̱nga̱i
\q2 ali u zuwai aɓau a̱ mini,
\q1 
\v 26 a̱ ɗa̱nga̱i a kubana gaɗi,
\q2 ɗa o bonoi punu a̱ mini ma̱ uga̱vi,
\q1 a̱ ka̱tsuma̱ ka atakaci e le
\q2 ɗa antiki a antsu a,
\q2 a panai wovon.
\q1 
\v 27 A̱ ka̱na̱i katangalasa n a̱ ta̱ɗa̱tsa̱i,
\q2 adanshi ma̱ra̱ ma maka le ta̱.
\q1 kuyeve ku le ra̱ka̱,
\q2 ko okpoi ukuna u gbani.
\q1 
\v 28 Ɗa a bankai m ma̱shi me le u Vuzavaguɗu,
\q2 a̱ ka̱tsuma̱ ka atakaci e le,
\q2 ɗa tana wu uta̱ka̱i le, a kadama ke le.
\q1 
\v 29 U vaꞋankai n wunla̱i wu utsura wa,
\q2 ɗa aɓau a̱ mini a kpamu a shamgbai bini.
\q1 
\v 30 Ɗa a yaꞋin ma̱za̱nga̱ a na ubuta̱ u shira̱i,
\q2 ɗa u tonoi n ele a kubana
\q2 a̱ ubuta̱ u na antsu a ci shamgba.
\b
\q1 
\v 31 YaꞋan a cikpa Vuzavaguɗu
\q2 adama a ucigi u ni u na u tsu sabaꞋa ba,
\q1 n adama a ulinga wi ili i mereve i ni
\q2 a̱ ubuta̱ u uma.
\q1 
\v 32 YaꞋan e neke yi tsugbayin o koɓolo ka uma,
\q2 ka̱ta̱ kpamu a cikpa yi
\q2 a̱ ka̱tsuma̱ ko koɓolo
\q2 ko nkoshi m gba̱ra̱-gba̱ra̱.
\b
\q1 
\v 33 U bonokoi nyeneke kakamba,
\q2 a̱shi a̱ mini tankpamu kayala ke ɗekpu,
\q1 
\v 34 iɗika i singai yo okpoi yi mkpaɗi
\q2 adama a ka gbani-gbani ka uma a iɗika ya.
\q1 
\v 35 U bonokoi kakamba ko okpoi nyeneke m mini,
\q2 iɗika i ɗekpu kpamu a̱shi a̱ mini.
\q1 
\v 36 Ta ɗe u bankai aza a kambulu o yongo,
\q2 ɗa a maꞋin likuci i na a̱ ku da̱sa̱ngu ɗe.
\q1 
\v 37 A yaꞋin vica̱Ꞌa̱ ashina, ɗa a̱ shikpa̱i nɗanga mi itacishi,
\q2 ɗa a̱ ciya̱i ili n a̱bunda̱i.
\q1 
\v 38 U zuwakai le una̱singai,
\q2 ɗa ka̱bunda̱i ke le ko doki.
\q2 u ka̱sukpa̱ ushiga wi ili kuzuwa i le i jebe ba.
\q1 
\v 39 Ana ka̱bunda̱i ke le ke jebei,
\q2 ɗa okpoi ili i kugoyi.
\q1 A̱ ubuta̱ u modoruko,
\q2 ma̱dukpa̱ n una̱mgbuka̱tsuma̱,
\q1 
\v 40 a̱yi na u tsu goyo aza a gbagbain,
\q2 u zuwai le a̱ ka̱na̱i ka̱ ka̱ra̱sa̱
\q2 a kakamba ka na ki n uye ba.
\q1 
\v 41 Ama wu uta̱ka̱ ta̱ n aza a yali
\q2 a̱ ka̱tsuma̱ ka a atakaci e le,
\q2 kpamu u zuwai muku n le n yimkpai
\q2 tsu ushiga wi ilikuzuwa.
\b
\q1 
\v 42 Aza a̱ ka̱ɗu ka mayun,
\q2 enei ɗa a yaꞋin ma̱za̱nga̱,
\q2 ama aza a gbani-gbani ra̱ka̱
\q2 i ta̱ a ku paɗa bini.
\q1 
\v 43 Vuza na baci wi n ugboji dem,
\q2 u pana ukuna u nampa,
\q2 ka̱ta̱ kpamu u coꞋoko
\q2 n ucigi u gbayin u Vuzavaguɗu.
\c 108
\s1 Ma̱shi ma̱ kula̱nsa̱ ulyaꞋi adama i irala
\d Vishipa vu Dawuda.
\q1 
\v 1 Ka̱shile n foɓuso ta̱ ka̱ɗu ka̱ va̱ mayin,
\q2 n canana ishipa,
\q2 ka̱ta̱ n cikpa wu n utsura u va̱ dem.
\q1 
\v 2 Jimgbai umolu u va̱ n ugogi
\q2 tsu jimgbasa kanna.
\q1 
\v 3 Vuzavaguɗu mi ta̱ kucikpa wu
\q2 a̱ ka̱tsuma̱ ka uma,
\q2 mi ta̱ a ku canana ishipa
\q2 a̱ ka̱tsuma̱ ku uduniyan.
\q1 
\v 4 Ucigi u nu u na u tsu sabaꞋa ba u yawa ta̱ gaɗi a̱da̱nga̱shile,
\q2 ma̱riki ma̱ nu kpamu u yawa ta̱ a gaɗi ve eleshu.
\q1 
\v 5 Ka̱shile, yaꞋan ene ucikpi u nu a gaɗi ve eleshu,
\q2 yaꞋan tsugbayin tsu nu
\q2 ci yongo aduniyan dem.
\q1 
\v 6 Wawa tsu vu ɓa̱nka̱ tsu,
\q2 n kukiye ku usingai ku nu,
\q2 adama a na ncigi n nu n ciya̱ uɓa̱nki.
\q1 
\v 7 Ka̱shile ka yaꞋan ta̱ kadanshi
\q2 a̱ ubuta̱ u ciɗa u ni, u danai.
\q2 <<N ulyaꞋi mi ta̱ e kupece Shekem,
\q2 ka̱ta̱ n gisanku ka̱ra̱Ꞌa̱ ka Sukotu.
\q1 
\v 8 Giliyadu vu va̱ vu ɗa,
\q2 Manasa feu vu va̱ vu ɗa.
\q2 Ifirayimu ɗa ma̱kuꞋun ma̱ viyum ma̱ va̱.
\q2 Yahuda kalangu ko tsugono ka̱ va̱.
\q1 
\v 9 Mi ta̱ o kubonoko Mowabu
\q2 tsu kasasu ka̱ kuza̱Ꞌa̱ ka̱ va̱,
\q2 Edom wi ta̱ o ko okpo a ɗaka vu ene a̱ va̱,
\q2 Ka̱ta̱ n yaꞋan yoroli yi ulyaꞋi wa aza a Filisitiya.>>
\q1 
\v 10 Yayi u kubanka mu a̱ likuci yi u ukanji?
\q2 Yayi u kutono nu mpa a kubana a iɗika i Edom?
\b
\q1 
\v 11 Ka̱shile, avu ɗa vu variki tsu,
\q2 Vu kpa̱ɗa̱i kudoku kuwala n osoji a̱ tsu ba?
\q1 
\v 12 Ɓa̱nka̱ tsu, tsu shilika̱ ni irala i tsu,
\q2 adama a na uɓa̱nki u vuma gbani ɗa.
\q1 
\v 13 N uɓa̱nki u Ka̱shile ci ta̱ a̱ kuciya̱ ulyaꞋi,
\q2 wi ta̱ a kulyaꞋa irala i tsu.
\c 109
\s1 Ufolu u vuza na wi a̱ ka̱tsuma̱ ka atakaci
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda.
\q1 
\v 1 Ka̱shile ka̱ va̱ ka na mi a kucikpa.
\q2 Ka̱ta̱ vu paɗa bini ba,
\q1 
\v 2 adama a na uma a gbani-gbani
\q2 n aza ma̱ya̱nsa̱ka̱,
\q2 a̱ ɓa̱yuwa̱ ta̱ una̱ u le adama a̱ va̱,
\q2 a kudansa ka aꞋuwa adama a̱ va̱.
\q1 
\v 3 A kanza mu ta̱ n kadanshi ka tsurala,
\q2 a kuzama mu vishili ko unushi.
\q1 
\v 4 Kucikpa i o kubonoko mu n ka gbani-gbani,
\q2 ama mpa vuza va avasa ɗa.
\q1 
\v 5 A tsupai mu n ka gbani-gbani,
\q2 a na a kutsupa mu n kasingai,
\q2 n cigai le, ama ɗa a iwain mu.
\b
\q1 
\v 6 Ɗa a danai,<<Zuwa vuma vu gbani-gbani
\q2 wo okpo yi vuza vu kanananai,
\q2 yaꞋan vuza na u shamkpa ni
\q2 u neke yi unushi.
\q1 
\v 7 Makyan ma na i a kuyaꞋanka yi afada,
\q2 yaꞋan a̱ ka̱na̱ yi n unushi,
\q2 yaꞋan avasa a̱ ni okpo unushi.
\q1 
\v 8 YaꞋan ayin a̱ ni okpo kenu,
\q2 yaꞋan vuza yoku u ɗika tsugbayin ci ni.
\q1 
\v 9 YaꞋan muku n ni mo okpo mkpaꞋan,
\q2 vuka vi ni kpamu vo okpo kagapa.
\q1 
\v 10 YaꞋan muku n ni
\q2 n ka̱na̱ kuka̱ra̱Ꞌa̱sa̱ a ufolu,
\q2 ka̱ta̱ kpamu o loko le a gali a ana i a̱ ida̱shi.
\q1 
\v 11 YaꞋan vuza na wi o kutono yi kutan
\q2 wi isa i li i na wi n ɗa ra̱ka̱,
\q1 omoci kpamu a̱ pura̱ ili i na u takacikai u ciya̱i.
\q1 
\v 12 Ka̱ta̱ vuza u yaꞋanka yi kasingai ba,
\q2 ko u sa̱Ꞌa̱ a mkpaꞋan n ni ba.
\q1 
\v 13 YaꞋan ntsukaya n ni ra̱ka̱ n kuwa̱,
\q2 ura ula e le a tsukaya tsu na tsa̱ kuta̱wa̱.
\q1 
\v 14 YaꞋan Vuzavaguɗu u ciɓa n unushi wi ikaya i ni,
\q2 ka̱ta̱ a cinukpa n unushi wa̱ a̱na̱ku a̱ ni ba.
\q1 
\v 15 YaꞋan Vuzavaguɗu u ciɓa n unushi u le ayin tutu,
\q2 adama a na a cinukpa n ula ele ra̱ka̱ aduniyan,
\q1 
\v 16 Adama a na u saꞋawa kusheshe kuyaꞋan ka singai ba,
\q2 ama u tsu takacika ta̱ aza a unambi n aza a yali
\q2 n aza a na a takpai a̱ɗu e le ali a̱ kuwa̱i.
\q1 
\v 17 U tsu ciga ta̱ kuyaꞋanka vuza una̱,
\q2 yaꞋan u ɗa u bono wa̱ ni,
\q2 u tsu ciga kuzuwaka vuza una̱singai ba,
\q2 yaꞋan vuza u zuwaka yi una̱singai ba.
\q1 
\v 18 U bonokoi una̱wuya tsu motogu ma ku uka,
\q2 yaꞋan una̱wuya u tono yi tsu mini mo kusoꞋo,
\q2 u uwa etele a̱ ni tsu maniꞋin ma̱ kusukuya̱.
\q1 
\v 19 YaꞋan wo okpo tsu kalaba
\q2 ka na a lapangi a kavangatsu ka̱ ni.
\q2 tsu kaɗambura ka na a shiyaka ni ko wannai.>>
\q1 
\v 20 YaꞋan Vuzavaguɗu,
\q2 u tsupa aza a na i a kushika mu,
\q2 aza na i a kadanshi ka gbani-gbani
\q2 adama a wuma u va̱.
\q1 
\v 21 Ama a vu Vuzavaguɗu,
\q2 vuzagbayin ɓa̱nka̱ mu,
\q2 adama a na e neke kula ku nu tsugbayin.
\q1 Adama a kasingai ku ucigi u nu u na u tsu sabaꞋa ba,
\q2 wawa mu.
\q1 
\v 22 Adama a na mpa vuza vu unambi ɗa,
\q2 vuza yali kpamu,
\q2 m pana ta̱ mɓa̱la̱ ka̱u a̱ ka̱ɗu ka̱ va̱.
\q1 
\v 23 M puwa̱nka̱i tsu kulu ku kulivi,
\q2 i a̱ ku ka̱pa̱tsa̱ mu tsu akyun a na uta̱ni u ka̱na̱i.
\q1 
\v 24 A̱ka̱nga̱tsu a̱ va̱ a̱ kuwa̱ ta̱
\q2 adama a kakuli n kambulu,
\q2 n yamba ta̱ ra̱ka̱.
\q1 
\v 25 Mo okpoi ili yi izoshi wa aza ishikushi,
\q2 a̱ tsu fila̱ ta̱ aci e le e enei mu baci.
\b
\q1 
\v 26 Ɓa̱nka̱ mu, Vuzavaguɗu Ka̱shile ka̱ va̱.
\q2 wawa mu,
\q2 adama a ucigi u nu u na u tsu sabaꞋa ba.
\q1 
\v 27 Vuzavaguɗu! YaꞋan irala i va̱ e yeve
\q2 a na kukiye ku nu ku ɗa, ku yaꞋin nannai.
\q1 
\v 28 I ta̱ a kuyaꞋanka mu una̱wuya,
\q2 ama a vu vi ta̱ a kuzuwaka mu una̱singai,
\q2 i ta̱ a̱ kuta̱wa̱ n vishili, ka̱ta̱ okpo n wono
\q2 ka̱ta̱ mpa kagbashi ka̱ nu, n yaꞋan ma̱za̱nga̱.
\q1 
\v 29 YaꞋan wono u pala irala i va̱,
\q2 a pala le n akashi o wono.
\q1 
\v 30 N una̱ u va̱ u ɗa mi a kucikpa Vuzavaguɗu,
\q1 mi ta̱ a kucikpa yi o koɓolo ka uma a̱bunda̱i,
\q1 
\v 31 Adama a na u tsu shamkpa ta̱
\q2 vuza yali u wawa yi
\q2 e ekiye aza na i a kukiɗaka yi afada a ukpa̱.
\c 110
\s1 Vuzavaguɗu m mazagbi ma̱ ni
\d Vishipa vu Dawuda.
\q1 
\v 1 Vuzavaguɗu u danai Vuzagbayin vu va̱,
\q2 <<Da̱sa̱ngu e kukiye ku usingai ku va̱
\q2 ali a makyan ma na n zuwai irala i nu
\q2 yo okpoi a ɗaka vu ene a̱ nu.>>
\b
\q1 
\v 2 Ili i na i ɗikai a Sihiyona
\q2 Vuzavaguɗu wi ta̱ o kudoku wanshi tsugono tsu nu,
\q2 vi lyaꞋa tsugono wa irala i nu.
\q1 
\v 3 Ka̱bunda̱i ko osoji ki ta̱ a kuciga kuyaꞋan kuvon,
\q2 a kanna ko kuvon ka̱ nu.
\q1 A uki nu ntogu n ciɗa n tsugbayin,
\q2 tsu na ciza tsu usana tsu uta̱
\q2 nannai ɗa a̱ɗa̱nga̱ni a̱ kuta̱wa̱ wu.
\q1 
\v 4 Vuzavaguɗu u kucinai
\q2 wi a̱ kusabaꞋa kusheshe ku ni kpamu ba,
\q1 <<A vu ganu ɗa vu ayin ko wannai,
\q2 tsu Melikizedeku.>>
\b
\q1 
\v 5 Vuzavaguɗu wi ta̱ e kukiye ku usingai ku nu,
\q2 wi ta̱ a ku una ngono
\q2 a kanna ka wupa u ni.
\q1 
\v 6 Wi ta̱ a kukiɗaka uduniyan afada,
\q2 u shatangu le n even a ikyamba,
\q2 wi ta̱ o ku ɓososo aza o tsugono aduniyan.
\q1 
\v 7 Wi ta̱ o ku soꞋo mini mo kuɗolu
\q2 ma na mi ɗevu n uye,
\q2 adama a nannai wi ta̱ a̱ kuɗengusa̱
\q2 ka̱ci ka̱ ni a̱ ka̱tsuma̱ ku ulyaꞋi.
\c 111
\s1 Ulinga u Ka̱shile ili gbayin i ɗa
\q1 
\v 1 Cikpai Vuzavaguɗu
\q2 mi ta̱ a kucikpa Vuzavaguɗu
\q2 n ka̱ɗu ka̱ va̱ dem,
\q2 a̱ ka̱tsuma̱ ko koɓolo ka uma a usuɓi.
\q1 
\v 2 Ulinga u Vuzavaguɗu ili gbayin i ɗa,
\q2 aza a na a ci yaꞋan ma̱za̱nga̱ n u ɗa,
\q2 i ta̱ a kuciɓasa n u ɗa.
\q1 
\v 3 Ulinga u ni wi ta̱ n tsugbayin n utsura,
\q2 kpamu usuɓi u ni wi ta̱ o kuyongo ko wannai.
\q1 
\v 4 U zuwai a ciɓa n ulinga u mereve u ni,
\q2 Vuzavaguɗu wi ta̱ n kasingai n asuvayali.
\q1 
\v 5 U tsu neke ta̱ aza a na i a kupana wovon u ni ilikulyaꞋa,
\q2 u tsu ciɓa ta̱ n uzuwakpani u ni ko wannai.
\q1 
\v 6 U yotsongu ta̱ uma a̱ ni utsura wu ulinga u ni,
\q2 u nekei le iɗika yu uduniyan u yoku,
\q2 yo okpo ili yi uka̱ni i le.
\q1 
\v 7 Ulinga wa ekiye a̱ ni,
\q2 wu usuɓi u ɗa n kamayun,
\q2 ili i kutono i ni kpamu i ku ushuku i ɗa ra̱ka̱,
\q1 
\v 8 u shikpa̱ kaꞋa ko wannai,
\q2 a yaꞋan kaꞋa, a̱ ka̱tsuma̱ ku usuɓi n kamayun.
\q1 
\v 9 U tuka̱i n ushibi u uma a̱ ni,
\q2 u zuwai uzuwakpani u ni ko wannai,
\q2 kula ku ni ku Ciɗa ku ɗa n ili i wovon.
\q1 
\v 10 Wovon u Vuzavaguɗu u ɗa ugiti wu ugboji,
\q2 aza a na o tsu tono wila̱ u ni dem,
\q2 a̱ tsu ciya̱ ta̱ kuyeve ku singai.
\q2 YaꞋan a cikpa yi ko wannai.
\c 112
\s1 Ma̱za̱nga̱ ma vuza vu Usuɓi
\q1 
\v 1 Cikpai Vuzavaguɗu, vuza vu ma̱za̱nga̱ ɗa,
\q2 a̱yi na u tsu pana wovon u Vuzavaguɗu,
\q2 a̱yi na u tsu pana uyoꞋo
\q2 u kutono kadanshi ka̱ ni.
\q1 
\v 2 Muku n vuza vu usuɓi
\q2 mi ta̱ a̱ kuciya̱ tsugbayin a i iɗika ya
\q2 ntsukaya
\q2 mi ta̱ a̱ kuciya̱ una̱singai.
\q1 
\v 3 Uciyi n udukuyan u kuyongo ta̱ a kpaꞋa ku ni,
\q2 ka̱ta̱ ukuna wu usuɓi u ni u yongo ko wannai.
\b
\q1 
\v 4 A̱yi kutashi ku ɗa a ku akana,
\q2 u vuza na wi o kutono mejege,
\q2 u vuza kasingai n asuvayali
\q2 n vuza vu usuɓi.
\q1 
\v 5 Kasingai ki ta̱ o kuyongo n vuza na
\q2 u ci yaꞋan kuneꞋe n kuneke okopu n ka̱ɗu ba̱ri,
\q2 a̱yi na u ci yaꞋan ukuna u mayun.
\q1 
\v 6 Mayun wi ku gba̱ɗa̱sa̱ ba,
\q2 a ku ciɓa ta̱ n vuza vu usuɓi ko wannai.
\q1 
\v 7 U tsu pana wovon wa arabali a gbani-gbani ba,
\q2 ka̱ɗu ka̱ ni ka shamgba ta̱ mayin
\q2 a̱ ubuta̱ u kutono Vuzavaguɗu.
\q1 
\v 8 Ka̱ɗu ka̱ ni ki ta̱ a̱ ida̱shi cika, ko wovon
\q2 a ukocishi wi ta̱ a kulyaꞋa irala i ni.
\q1 
\v 9 U tsu neke ta̱ aza a yali kuneꞋe ba̱ri,
\q2 usuɓi u ni wi ta̱ o kuyongo ko wannai,
\q2 utsura u ni wi ta̱ kuciya̱ ucikpi n tsugbayin.
\q1 
\v 10 Vuza gbani-gbani wi ta̱ e kene
\q2 ka̱ta̱ u ka̱na̱ wupa
\q2 n u lumai una̱ ali u na̱mgba̱.
\q1 ka̱ta̱ kusheshe ku vuza gbani-gbani
\q2 ko okpo ukuna u gbani.
\c 113
\s1 Ishipa i kucikpa kasingai ka Vuzavaguɗu
\q1 
\v 1 Cikpai Vuzavaguɗu.
\q1 Cikpai ni, a̱ɗa̱ agbashi a̱ ni,
\q2 Cikpai kula ku Vuzavaguɗu.
\q1 
\v 2 YaꞋan kula ku Vuzavaguɗu ku ciya̱ ucikpi,
\q2 gogo na n kowanai.
\q1 
\v 3 I na i ɗikai a̱ wuti u kanna
\q2 a kubana ubuta̱ u na ka̱ ci yikpa̱,
\q2 u yotso ta̱ a cikpa kula ku Vuzavaguɗu.
\q1 
\v 4 Tsugbayin tsu Vuzavaguɗu
\q2 tsu laꞋa ta̱ uduniyan ra̱ka̱,
\q2 tsugbayin ci ni kpamu ci ta̱ a gaɗi va̱ a̱da̱nga̱shile.
\q1 
\v 5 Yayi wi lo tsu Vuzavaguɗu Ka̱shile ka̱ tsu,
\q2 a̱yi na wi a̱ ida̱shi a kakuba ko tsugono ci ni gaɗi?
\q1 
\v 6 Yayi wi lo ci nu,
\q2 a̱yi na u tsu za̱lika̱ ka̱ta̱ u la̱na̱
\q2 gaɗi n aduniyan?
\q1 
\v 7 U tsu ɗa̱ngusa̱ ta̱ aza a unambi
\q2 a̱ ka̱tsuma̱ ka unambi u le,
\q2 ka̱ta̱ u zuwa aza a na i a iɗika a̱ ɗa̱nga̱.
\q1 
\v 8 U zuwa le a lyaꞋa koɓolo m muku mu ngono,
\q2 m muku mu ngono n uma e le
\q1 
\v 9 U tsu zuwa ta̱ madari ma da̱sa̱ngu a kpaꞋa ku ni,
\q2 m ma̱za̱nga̱ tsu vuka vu na vi m muku.
\q1 Cikpai Vuzavaguɗu.
\c 114
\s1 Vishipa vu ka̱ɗiva̱ ka kupasamgbanai
\q1 
\v 1 Ana aza a Isaraila a̱ ka̱sukpa̱i iɗika i Masar,
\q2 kpaꞋa ku Yakubu ku ka̱sukpa̱i iɗika yo omoci,
\q1 
\v 2 Yahuda wo okpo ta̱
\q2 ubuta̱ wi ida̱shi i ciɗa u Ka̱shile,
\q2 Isaraila kpamu ubuta̱ u tsugono ci ni.
\b
\q1 
\v 3 Mala mashili me enei ɗa ma sumai,
\q2 ɗa kuyene ku Urudu ku bonoi n ka̱ca̱pa̱.
\q1 
\v 4 Nsansa a̱ ka̱na̱i ci ɗikpangi tsa̱ a̱giri,
\q2 aginda tankpamu tsu nkyon.
\q1 
\v 5 Yiɗa̱i i zuwai ɗa vu sumai
\q2 avu mala mashili?
\q1 Avu kuyene ku Urudu,
\q2 a na vu bonoi n ka̱ca̱pa̱?
\q1 
\v 6 A̱ɗa̱ nsansa a̱ɗa̱ na i ɗikpangi tsa̱ a̱giri,
\q2 aginda tankpamu tsu nkyon?
\q1 
\v 7 JeꞋekei ikyamba a̱ɗa̱ aduniyan,
\q2 e kelime ka Vuzavaguɗu,
\q2 e kelime ka̱ Ka̱shile ka Yakubu,
\q1 
\v 8 a̱yi na u bonokoi kakpanlai kadaɓa ka̱ mini,
\q2 kpamu katali a̱shi a mini.
\c 115
\s1 Ishipa u Ka̱shile ka mayun
\q1 
\v 1 Vuzavaguɗu, wa̱ a̱ tsu u ɗa ba,
\q2 wa̱ a̱ tsu u ɗa ba,
\q2 ama a kula ku nu ku ɗa e ku neke tsugbayin,
\q2 adama a ucigi u nu u na u tsu sabaꞋa ba n usuɓi u nu.
\q1 
\v 2 Yiɗa̱i i zuwai ɗa uduniyan wi a kudansa,
\q2 <<Te ɗai Ka̱shile ka̱ ɗa̱ ki?>>
\q1 
\v 3 Ka̱shile ka̱ tsu ki ta̱ ɗe gaɗi,
\q2 A kuyaꞋan ili i na u cikalai.
\q1 
\v 4 A yaꞋan ta̱ a̱ma̱li e le n azurufa n azanariya,
\q2 ulinga we ekiye u uma u ɗa.
\q1 
\v 5 I ta̱ nu una̱, ama a tsu dansa ba,
\q2 i ta̱ n a̱shi, ama e ci ene ba.
\q1 
\v 6 I ta̱ n atsuvu, ama tsu pana ba,
\q2 i ta̱ n yunu, ama a tsu tsumgba ili ba.
\q1 
\v 7 I ta̱ n ekiye, ama a̱ tsu ka̱na̱ ili ba,
\q1 i ta̱ n ene, ama a tsu wala ba.
\q2 ogboroli e le a tsu uta̱ka̱ a̱la̱ka̱tsu ba.
\q1 
\v 8 Aza a na a yaꞋin le va i ta̱ o ko okpo ci le,
\q2 ta feu wi o ko okpo nannai
\q2 wa aza na i o kutono le.
\q1 
\v 9 A̱ɗa̱ kpaꞋa ki Isaraila, zuwai a̱ɗu u Vuzavaguɗu.
\q2 a̱yi ɗa ka̱ɓa̱nki ka̱ ɗa̱ m ma̱ra̱ga̱ ma̱ ɗa̱.
\q1 
\v 10 A̱ɗa̱ kpaꞋa ku Haruna, zuwai a̱ɗu u Vuzavaguɗu.
\q2 a̱yi ɗa ka̱ɓa̱nki ka̱ ɗa̱ m ma̱ra̱ga̱ ma̱ ɗa̱.
\q1 
\v 11 zuwai a̱ɗu u Vuzavaguɗu,
\q2 a̱ɗa̱ vu na yi o kutono yi ra̱ka̱,
\q2 a̱yi ɗa ka̱ɓa̱nki ka̱ ɗa̱ m ma̱ra̱ga̱ ma̱ ɗa̱.
\q1 
\v 12 Vuzavaguɗu u tsu ciɓa ta̱ n a̱tsu,
\q2 wi ta̱ a kuzuwaka tsu una̱singai.
\q2 Wi ta̱ a kuzuwaka kpaꞋa ki Isaraila una̱singai
\q2 wi ta̱ a kuzuwaka kpaꞋa ku Haruna, una̱singai
\q1 
\v 13 wi ta̱ a ku zuwaka yaba dem
\q2 vu na u tonoi Vuzavaguɗu una̱singai
\q2 aza a wawaꞋa n aza gbagbaꞋin dem.
\q1 
\v 14 YaꞋan Vuzavaguɗu u doku ɗa̱ ka̱bunda̱i,
\q2 a̱ɗa̱ n muku n ɗa̱.
\q1 
\v 15 YaꞋan Vuzavaguɗu vu na u yaꞋin gaɗi n iɗika
\q2 u zuwa ka ɗa̱ una̱singai,
\q1 
\v 16 Gaɗi vu a̱da̱nga̱shile,
\q2 vu Vuzavaguɗu ɗa,
\q2 ama ɗa u nekei vuma aduniya.
\q1 
\v 17 A̱kpisa̱ a ci cikpa Vuzavaguɗu ba,
\q2 aza a na a̱ gida̱la̱i a kubana a kasaun.
\q1 
\v 18 Ama a̱tsu ɗa tsa kucikpa Vuzavaguɗu,
\q2 gogo na a kubana ko wannai.
\q1 Cikpai Vuzavaguɗu.
\c 116
\s1 Avasa a ucikpi
\q1 
\v 1 N ciga ta̱ Vuzavaguɗu,
\q2 adama a na u pana ta̱ ka̱la̱ka̱tsu ka̱ va̱,
\q2 u pana ta̱ ma̱shi ma asuvayali ma̱ va̱.
\q1 
\v 2 Mi ta̱ e kuɗeke yi
\q2 a ayin a wuma u va̱ dem,
\q2 adama a na u tsu zuwaka mu ta̱ atsuvu,
\q1 
\v 3 Maza ma̱ ukpa̱ ma̱ ka̱na̱ mu ta̱,
\q2 wovon u kasaun u kimba̱ mu ta̱.
\q2 kadama n una̱mgbuka̱tsuma̱ u ciya̱ mu ta̱.
\q1 
\v 4 Ɗa n ɗekei kula ku Vuzavaguɗu, n danai,
\q2 <<Vuzavaguɗu, n folono wu ta̱, wawa mu.>>
\q1 
\v 5 Vuzavaguɗu vuza kasingai ɗa,
\q2 n vuza vu usuɓi
\q2 Ka̱shile ka̱ tsu vuza va asuvayali ɗa.
\q1 
\v 6 Vuzavaguɗu u tsu ere ta̱
\q2 aza a na o goyoi ka̱ci ke le.
\q1 A makyan ma na mi a̱ kula̱nsa̱ uɓa̱nki,
\q2 u wawai mu.
\q1 
\v 7 Ka̱ɗu ka̱ va̱ vaꞋanku,
\q2 Vuzavaguɗu vuza kasingai ɗa wa̱ nu.
\q1 
\v 8 Adama a na Vuzavaguɗu, vu wawa ta̱,
\q2 wuma u va̱ a̱ ukpa̱,
\q2 a̱shi a̱ va̱ a̱ ubuta̱ u ku uta̱ka̱ kujilya
\q2 ene a̱ va̱ adama a̱ kuta̱ɗa̱tsa̱.
\q1 
\v 9 Adama a na n fuɗa n wala
\q2 e kelime ka Vuzavaguɗu,
\q2 a iɗika ya aza a wuma.
\q1 
\v 10 Ko a na n danai, <<A takacika mu ta̱ ka̱u.>>
\q2 n neke ta̱ ka̱ɗu,
\q1 
\v 11 A̱ ka̱tsuma̱ ka̱ uripuli u va̱, n danai,
\q2 <<Uma ra̱ka̱ a yaꞋin a uwa ɗa.>>
\q1 
\v 12 Ya̱ɗa̱i n kuneke u Vuzavaguɗu,
\q2 adama a kasingai ka̱ ni wa̱ va̱ ra̱ka̱?
\q1 
\v 13 Mi ta̱ a̱ kuɗa̱ngusa̱ kuneꞋe ku ma̱kya̱n
\q2 tsu ucikpi adama a wishi
\q2 ka̱ta̱ n ɗeke kula ku Vuzavaguɗu.
\q1 
\v 14 Mi ta̱ e kuneke Vuzavaguɗu,
\q2 ili i na n kucinai kuneke,
\q2 e kelime ka uma a̱ ni dem.
\q1 
\v 15 Vuzavaguɗu u ɗika ta̱ wuma wa aza a usuɓi
\q2 n ugaꞋin ka̱u.
\q1 
\v 16 Vuzavaguɗu, mayun mpa kagbashi ka̱ nu kaꞋa,
\q2 mpa kagbashi ka̱ nu kaꞋa,
\q2 maku ma kagbashi ka̱ nu vuka
\q2 vu shikpa mu ta̱ a ikani.
\q1 
\v 17 Mi ta̱ e kuneke alyuka a ucikpi,
\q2 ka̱ta̱ n ɗeke kula ku Vuzavaguɗu.
\q1 
\v 18 Mi ta̱ e kuneke Vuzavaguɗu,
\q2 ili i na n kucinai kuneke,
\q2 e kelime ka uma a̱ ni dem,
\q1 
\v 19 a ulanga u kpaꞋa ku Vuzavaguɗu,
\q2 a̱ ka̱tsuma̱ ka Urushelima.
\q1 Cikpai Vuzavaguɗu.
\c 117
\s1 Vishipa vu ucikpi u Vuzavaguɗu
\q1 
\v 1 Cikpai Vuzavaguɗu, uduniyan ra̱ka̱,
\q2 nekei ni tsugbayin, a̱ɗa̱ uma dem.
\q1 
\v 2 Adama a ucigi u ni u na u tsu sabaꞋa ba
\q2 a kubana wa̱ tsu wi ta̱ n tsugbayin,
\q2 kamayun ka Vuzavaguɗu ko wannai ɗa.
\q1 Cikpai Vuzavaguɗu.
\c 118
\s1 Avasa a ucikpi adama a ulyaꞋi
\q1 
\v 1 Cikpai Vuzavaguɗu
\q2 adama a na a̱yi vuza singai ɗa,
\q2 ucigi u ni u na u tsu sabaꞋa ba ko wannai ɗa.
\q1 
\v 2 YaꞋan aza a Isaraila a dana,
\q2 <<Ucigi u ni u na u tsu sabaꞋa ba ko wannai ɗa.>>
\q1 
\v 3 YaꞋan aza a kpaꞋa ku Haruna a dana,
\q2 <<Ucigi u ni u na u tsu sabaꞋa ba ko wannai ɗa.>>
\q1 
\v 4 YaꞋan aza a na i a kupana wovon u Vuzavaguɗu a dana,
\q2 <<Ucigi u ni u na u tsu sabaꞋa ba ko wannai ɗa.>>
\q1 
\v 5 A̱ ka̱tsuma̱ ka kadama ka̱ va̱,
\q2 n ɗekei vuzavaguɗu,
\q2 ɗa wu ushuki, u ka̱sukpa̱i mu ba̱ri.
\q1 
\v 6 Vuzavaguɗu wi ta̱ koɓolo nu mpa,
\q2 mi a kupana wovon ba.
\q2 yiɗa̱i vuma u kufuɗa kuyaꞋanka mu?
\q1 
\v 7 Vuzavaguɗu wi ta̱ koɓolo nu mpa,
\q2 a̱yi ɗa ka̱ɓa̱nki ka̱ va̱,
\q2 mi ta̱ e kene tsu na a kulyaꞋa irala i va̱.
\q1 
\v 8 U laꞋa ta̱ n kugaꞋan vu sheɗeku u Vuzavaguɗu,
\q2 a na va ku lemece ke vuma ma̱tsa̱n.
\q1 
\v 9 U laꞋa ta̱ n kugaꞋan vu sheɗeku u Vuzavaguɗu,
\q2 a na va ku lemece ke muku mu ngono ma̱tsa̱n.
\q1 
\v 10 Uduniyan ra̱ka̱ u kanza mu ta̱,
\q2 ama a̱ ka̱tsuma̱ ka kula ku Vuzavaguɗu
\q2 ɗa mu unai le.
\q1 
\v 11 A kanzai mu a̱ ubuta̱ dem,
\q2 ama a̱ ka̱tsuma̱ ka kula ku Vuzavaguɗu
\q2 ɗa mu unai le.
\q1 
\v 12 A̱ kpa̱nta̱i mu ci ishigi,
\q2 ama ɗa a̱ kuwa̱i gogoꞋo lo tsu na awana a̱ tsu kula̱ akina,
\q2 ama a ka̱tsuma̱ ka kula ku Vuzavaguɗu
\q2 ɗa mu unai le ra̱ka̱.
\q1 
\v 13 A yaꞋin tsu na a ku una mu,
\q2 ama ɗa Vuzavaguɗu u ɓa̱nka̱i mu.
\q1 
\v 14 Vuzavaguɗu ɗa katsura ka̱ va̱ n vishipa vu va̱,
\q2 wo okpo ta̱ kishi ka̱ va̱.
\q1 
\v 15 Ishipa i ma̱za̱nga̱ n ulyaꞋi,
\q2 yi uta̱i a̱tsura̱ aza a usuɓi.
\q1 <<Kukiye ku usingai ku Vuzavaguɗu,
\q2 kuyaꞋan ta̱ ili i gbagbaꞋin.
\q1 
\v 16 Kukiye ku usingai ku Vuzavaguɗu ku ɗa
\q2 ku nekei tsu ulyaꞋi,
\q2 kukiye ku usingai ku Vuzavaguɗu
\q2 ku yaꞋin ili i gbagbaꞋin.>>
\q1 
\v 17 Mpa mi a̱ kukuwa̱ ba,
\q2 ama mi ta̱ o kuyongo n wuma,
\q2 ka̱ta̱ n neke arabali a ulinga u na Vuzavaguɗu u yaꞋin.
\q1 
\v 18 Vuzavaguɗu u gbara mu ta̱ ka̱u,
\q2 ama wu una mu ba.
\q1 
\v 19 Ɓa̱yuwa̱ ka̱ mu utsutsu wa aza a usuɓi,
\q2 mi ta̱ a ku uwa punu n cikpa Vuzavaguɗu.
\q1 
\v 20 Na lo ɗa utsutsu u Vuzavaguɗu,
\q2 u na uma a usuɓi a ku uwa.
\q1 
\v 21 N cikpa wu ta̱ adama a na vu ushuku mu ta̱,
\q2 vu okpoi kishi ka̱ va̱.
\q1 
\v 22 Katali ka na a maꞋi a iwain
\q2 ko okpo ta̱ kenene ke mere.
\q1 
\v 23 Na lo ulinga u Vuzavaguɗu ɗa,
\q2 ili i mereve i ɗa kpamu a̱ a̱shi a̱ tsu.
\q1 
\v 24 Na ɗa kanna ka na Vuzavaguɗu u yaꞋin,
\q2 yaꞋan tsu pana uyoꞋo ci yaꞋin ma̱za̱nga̱ n ka a.
\q1 
\v 25 Vuzavaguɗu wawa tsu,
\q2 Vuzavaguɗu neke tsu u lyaꞋi.
\q1 
\v 26 Vuza vu una̱singai ɗa,
\q2 a̱yi na wi a̱ kuta̱wa̱ a̱ ka̱tsuma̱ ka kula ku Vuzavaguɗu.
\q2 ɗe a kpaꞋa ku Vuzavaguɗu
\q2 tsu zuwaka wu una̱singai.
\q1 
\v 27 Vuzavaguɗu a̱yi ɗa Ka̱shile,
\q2 ɗa u zuwai kutashi ku akana tsu.
\q1 Gita̱i ka̱ɗiva̱, i dara n a̱vuku a nshuwa ekiye a̱ ɗa̱,
\q2 a kubana a katalikalyuka.
\q1 
\v 28 Avu ɗa Ka̱shile ka̱ va̱,
\q2 mi ta̱ a kucikpa wu,
\q2 avu ɗa Ka̱shile ka̱ va̱,
\q2 mi ta̱ e kuneke wu tsugbayin.
\q1 
\v 29 Cikpai Vuzavaguɗu
\q2 adama a na a̱yi vuza singai ɗa,
\q1 ucigi u ni u na u tsu sabaꞋa ba ko wannai ɗa.
\c 119
\s1 Una̱singai wa aza o kutono wila̱
\b
\q1 
\v 1 Aza a̱ ma̱za̱nga̱ a ɗa
\q2 aza a na i n unushi ba,
\q2 aza a na i o kutono wila̱ u Vuzavaguɗu.
\q1 
\v 2 Aza a̱ ma̱za̱nga̱ a ɗa
\q2 aza a na a cinukpai
\q2 n kadanshi ka̱ ni ba,
\q1 aza a na i a̱ kula̱nsa̱ yi
\q2 n a̱ɗu ele ra̱ka̱,
\q1 
\v 3 ele na i a kuyaꞋan
\q2 ka gbani-gbani ba,
\q2 ama i ta̱ an nwalu a uye u ni.
\q1 
\v 4 Vu zuwa ta̱ ili i kutono i nu
\q2 adama a na o tono i ɗa mayin.
\q1 
\v 5 Ishi baci ka̱ɗu ka̱ va̱ ki a sabaꞋa ba,
\q2 a̱ ubuta̱ u kutono ili i na u dansai,
\q1 
\v 6 mi shi o ko okpo n wono ba
\q2 ɗa baci m bonokoi ka̱ɗu
\q2 a̱ ubuta̱ u kutono ili i na u dansai.
\q1 
\v 7 Mi ta̱ a kucikpa wu n ka̱ɗu ka mayun,
\q2 A makyan ma na n piꞋisai
\q2 afada a̱ usuɓi u nu.
\q1 
\v 8 Mi ta̱ o kutono ili i na u dansai,
\q2 ka̱ta̱ vu varuku mu ra̱ka̱-ra̱ka̱ ba.
\s1 Kutono wila̱ u Vuzavaguɗu
\b
\q1 
\v 9 Nini ɗai ka̱ɗa̱nga̱ni ko kuyongo ciɗa?
\q2 A̱ ubuta̱ u kutono kadanshi ka̱ nu.
\q1 
\v 10 N ka̱ɗu ka̱ va̱ ra̱ka̱, n la̱nsa̱i nu,
\q2 ka̱ta̱ vu ka̱sukpa̱ mu
\q2 n katsukpa kadanshi ka̱ nu ba.
\q1 
\v 11 N sokongu ta̱ kadanshi ka̱ nu a̱ ka̱ɗu ka̱ va̱,
\q2 adama a na ka̱ta̱
\q2 n yaꞋanka wu unushi ba.
\q1 
\v 12 Vuza vu una̱singai ɗa vi, avu Vuzavaguɗu,
\q2 piꞋisaka mu ili i na vu dansai.
\q1 
\v 13 N una̱ u va̱ u ɗa n kecei
\q2 afada a na vu nekei tsu ra̱ka̱.
\q1 
\v 14 Mi ta̱ a̱ ma̱za̱nga̱ mo
\q2 kutono kadanshi ka̱ nu,
\q2 tsu na vuma u ci yaꞋan ma̱za̱nga̱
\q2 ma̱ kuciya̱ udukuyan wa̱ a̱bunda̱i.
\q1 
\v 15 Mi ta̱ a̱ kuka̱na̱ kusheshe,
\q2 a̱ ukuna wi ili i kutono i nu,
\q2 ka̱ta̱ n zuwaka n uye u nu.
\q1 
\v 16 Mi ta̱ a̱ ma̱za̱nga̱
\q2 n ili i na vu dansai,
\q2 mi a kucinukpa n kadanshi ka̱ nu ba.
\b
\s1 Ma̱za̱nga̱ a̱ wila̱ u Vuzavaguɗu
\q1 
\v 17 YaꞋanka kagbashi ka̱ nu kasingai,
\q2 adama a na u ciya̱ wuma,
\q2 u kutono kadanshi ka̱ nu.
\q1 
\v 18 Ɓa̱yuwa̱ a̱shi a̱ va̱,
\q2 adama a na me ene,
\q2 ili i mereve i gbagbaꞋin
\q2 a̱ ka̱tsuma̱ ka̱ wila̱ u nu.
\q1 
\v 19 Mpa komoci kaꞋa aduniyan,
\q2 ka̱ta̱ vu sokongu ku mu
\q2 kadanshi ka̱ nu ba.
\q1 
\v 20 Ili i na n laꞋi n kuciga ka̱u a makyan dem
\q2 ɗaɗa n tono afada a̱ nu.
\q1 
\v 21 Vu tsu ɓarangu ta̱ aza a ugbamukaci,
\q2 ele na a katsukpai kadanshi nu.
\q1 
\v 22 Uta̱ka̱ mu o kugoyi ku le n a̱ra̱ɗi ele,
\q2 adama a na n tono ta̱ ili i na vu dansai.
\q1 
\v 23 Ko a na wo okpoi
\q2 aza o tsugono a gbaɓa ta̱ kaci,
\q2 a̱ kula̱nga̱sa̱ mu kula,
\q2 kagbashi ka̱ nu ki ta̱
\q2 e kusheshe ili i na vu dansai.
\q1 
\v 24 Mayun, n tsu pana ta̱
\q2 uyoꞋo u kadanshi ka̱ nu,
\q2 ke ci neke mu ta̱ odoki.
\b
\s1 Uzuwi u ka̱ɗu o kutono wila̱ u Vuzavaguɗu
\q1 
\v 25 Mi ta̱ ivaꞋin ma̱kpa̱ɓa̱ a̱ kubuta̱,
\q2 wawa wuma u va̱
\q2 tsu kadanshi ka̱ nu.
\q1 
\v 26 Ana n tonokoi nu ukuna u va̱
\q2 ɗa vu ushuki mu,
\q2 piꞋisaka mu ili i na vu dansai.
\q1 
\v 27 Ɓa̱nka̱ mu n yeve ili i kutono i nu,
\q2 ka̱ta̱ n yongo a kuciɓasa
\q2 n ulinga wi ili mereve i nu.
\q1 
\v 28 Ka̱ɗu ka̱ va̱ ka̱ kula̱ ta̱
\q2 adama a una̱mgbuka̱tsuma̱,
\q2 zuwa mu n tsurukpa
\q2 tsu kadanshi ka̱ nu.
\q1 
\v 29 Ere mu a uye wa aꞋuwa,
\q2 yaꞋan n ciya̱ kasingai a̱ wila̱ u nu.
\q1 
\v 30 N zagba ta̱ uye u ma̱riki,
\q2 n zuwa ta̱ ka̱ɗu ka̱ va̱
\q2 a̱ ubuta̱ wa afada a̱ nu.
\q1 
\v 31 Vuzavaguɗu, n ka̱na̱ ta̱
\q2 kadanshi nu gbagu,
\q2 ka̱ta̱ vu ka̱sukpa̱ mu
\q2 n yaꞋan wono ba.
\q1 
\v 32 N ilaɗi i ɗa, mi o kutono
\q2 kadanshi ka̱ nu,
\q2 adama a na vu zuwa ta̱
\q2 ka̱ɗu ka̱ va̱ ko yongo ba̱ri.
\b
\s1 Avasa adama e kuyeve ku wila̱ u Vuzavaguɗu
\q1 
\v 33 Vuzavaguɗu, piꞋisaka mu
\q2 ili i na vu dansai,
\q2 ka̱ta̱ n tono i ɗa ko wannai.
\q1 
\v 34 Neke mu kuyeve,
\q2 adama a na n tono wila̱ u nu,
\q1 ka̱ta̱ ta na n tono u ɗa
\q2 n ka̱ɗu ka̱ va̱ dem.
\q1 
\v 35 Tono nu mpa n tsu uye u kadanshi ka̱ nu,
\q2 adama a na ta ɗe
\q2 mi a̱ kuciya̱ ma̱za̱nga̱.
\q1 
\v 36 Zuwa ka̱ɗu ka̱ va̱,
\q2 a̱ ubuta̱ u kutono kadanshi ka̱ nu,
\q2 ba a̱ ubuta̱ u kula̱nsa̱
\q2 ku udukuyan ba.
\q1 
\v 37 Takpa a̱shi a̱ va̱
\q2 a̱ ubuta̱ wu ili i kavama,
\q2 ere wuma u va̱ tsu kadanshi ka̱ nu.
\q1 
\v 38 Shatangu kadanshi ka̱ nu,
\q2 u kagbashi ka̱ nu,
\q2 u na vu yaꞋankai
\q2 aza a na e nekei nu tsugbayin.
\q1 
\v 39 Takpa ka mu wono u na
\q2 mi a kupana wovon,
\q2 adama a na afada a̱ nu ili i singai i ɗa.
\q1 
\v 40 Mpa ɗa na a mali mi ili i kutono i nu,
\q2 ere mu a̱ ka̱tsuma̱ ku usuɓi u nu.
\b
\s1 Kuneke katsura a̱ wila̱ u Vuzavaguɗu
\q1 
\v 41 Vuzavaguɗu, yaꞋan
\q2 ucigi u nu u na u tsu sabaꞋa ba
\q2 u ta̱wa̱ wa̱ va̱,
\q2 wishi u nu kpamu u ta̱wa̱ tsu uzuwakpani u nu,
\q1 
\v 42 ka̱ta̱ n ciya̱ ili i na n ku ushuku
\q2 vuza na wi a kushika mu,
\q2 adama a na n zuwaka ta̱
\q2 kadanshi ka̱ nu katsura.
\q1 
\v 43 Ka̱ta̱ vu takpa kadanshi
\q2 ka̱ ma̱riki a̱ una̱ u va̱ ba,
\q2 adama a na a afada a̱ nu u ɗa n keɗei a̱pa̱Ꞌa̱.
\q1 
\v 44 Mi ta̱ o kutono wila̱ u nu
\q2 a makyan dem, ko wannai,
\q1 
\v 45 ka̱ta̱ n yaꞋan nwalu n va̱ ba̱ri,
\q2 adama a na mi ta̱
\q2 a̱ kula̱nsa̱ ili i kutono i nu.
\q1 
\v 46 Mi ta̱ a kudansa ukuna
\q2 u kadanshi u nu e kelime ko ngono,
\q2 mi ta na a kupana wono ba.
\q1 
\v 47 Adama a na n tsu pana ta̱
\q2 uyoꞋo u kadanshi ka̱ nu,
\q2 adama a na n ciga ta̱ u ɗa.
\q1 
\v 48 Mi ta̱ e kuneke kadanshi ka̱ nu tsugbayin,
\q2 adama a na n ciga ta̱ kaꞋa,
\q2 kpamu ka̱ta̱ n ka̱ na̱ kusheshe a ili i na vu dansai.
\b
\s1 Kuzuwa ka̱ɗu a̱ wila̱ u Vuzavaguɗu
\q1 
\v 49 Ciɓa n kadanshi ka na
\q2 vu yaꞋankai kagbashi ka̱ nu,
\q2 adama a na vu zuwa mu ta̱ n keɗei a̱pa̱Ꞌa̱.
\q1 
\v 50 Ma̱za̱nga̱ ma̱ va̱ a̱ ka̱tsuma̱ ka atakaci
\q2 ɗaɗa uzuwakpani u nu
\q2 u tsu ere ta̱ wuma u va̱.
\q1 
\v 51 Aza a ugbamukaci a yaꞋanka mu ta̱ ulami,
\q2 ama n vadalukpuka wila̱ u nu kucina̱ ba.
\q1 
\v 52 N ciɓai n afada a Vuzavaguɗu,
\q2 ɗa n ciya̱i uneki u kadanshi.
\q1 
\v 53 Wupa u tsu ka̱na̱ mu ta̱ ka̱u
\q2 adama a uma a gbani-gbani,
\q2 aza a na a̱ ka̱sukpa̱i wila̱ u nu.
\q1 
\v 54 Ili i kutono i nu
\q2 yo okpo mu ta̱ ishipa,
\q2 a kpaꞋa ku na mi o limoci.
\q1 
\v 55 Vuzavaguɗu, n ciɓa ta̱ n kula ku nu n kayin,
\q2 mi ta̱ ta na o kutono wila̱ u nu.
\q1 
\v 56 Nava ɗaɗa n kiwanai kuyaꞋansa,
\q2 adama a na n zuwaka ta̱ n ili i kutono i nu.
\b
\s1 Uneki u kaci a̱ wila̱ u Vuzavaguɗu
\q1 
\v 57 Vuzavaguɗu ɗa upecu u va̱,
\q2 n yaꞋan ta̱ uzuwakpani
\q2 n tono kadanshi ka̱ nu
\q1 
\v 58 N la̱nsa̱ wu ta̱ n ka̱ɗu ka̱ va̱ dem,
\q2 yaꞋan n ciya̱ mapasa ma singai
\q2 tsu na vu yaꞋin kadanshi.
\q1 
\v 59 N coꞋoko ta̱ n uye u va̱,
\q2 ɗa n kpatalai n tonoi kadanshi ka̱ nu.
\q1 
\v 60 Ɗa n dakakai n la̱nga̱sa̱ makyan ba,
\q2 n tonoi kadanshi ka̱ nu.
\q1 
\v 61 Uma a gbani-gbani
\q2 a shiya mu ta̱ n awin,
\q2 ama n cinukpa n wila̱ u nu ba.
\q1 
\v 62 Kayin ke pece baci n tsu ɗa̱nga̱ ta̱ n cikpa wu,
\q2 adama afada a usuɓi a̱ nu.
\q1 
\v 63 Mpa ka̱ja̱Ꞌa̱ kaꞋa u yaba dem
\q2 na wi a kupana wovon u nu,
\q2 n aza na a zuwakai n ili i kutono i nu.
\q1 
\v 64 Vuzavaguɗu, ucigi u nu
\q2 u na u tsu sabaꞋa ba
\q2 u shana ta̱ aduniyan ra̱ka̱,
\q2 piꞋisaka mu ili i na vu dansai.
\b
\s1 UgaꞋin u wila̱ u Vuzavaguɗu
\q1 
\v 65 Vuzavaguɗu, vu yaꞋanka ta̱ kagbashi ka̱ nu kasingai,
\q2 tsu na vu yaꞋin kadanshi.
\q1 
\v 66 PiꞋisaka mu n yeve afada asingai,
\q2 adama a na n neke ta̱ katsura
\q2 a kadanshi ka̱ nu.
\q1 
\v 67 Kafu vu takacika mu, n nusa ta̱ ɗe,
\q2 ama gogo na n tono ta̱ kadanshi ka̱ nu.
\q1 
\v 68 Avu vuza singai ɗa,
\q2 kpamu vi yaꞋan ta̱ kasingai,
\q2 piꞋisaka mu ili i na vu dansai.
\q1 
\v 69 Aza a ugbamukaci i ta̱
\q2 a kudansa aꞋuwa adama a̱ va̱,
\q1 n zuwaka ta̱ n ili i kutono
\q2 i nu n ka̱ɗu ka̱ va̱ ra̱ka̱.
\q1 
\v 70 A̱ɗu ele a kpanduku ta̱,
\q2 ama mpa mi ta̱
\q2 a̱ ma̱za̱nga̱ n wila̱ u nu.
\q1 
\v 71 UgaꞋan ta̱ a na n takacikai,
\q2 adama a na m piꞋisa ili i na vu dansai.
\q1 
\v 72 Wila̱ wu una̱ u nu u laꞋaka mu ta̱,
\q2 n a̱kpa̱n a azanariya n azurufa.
\b
\s1 Ma̱riki ma̱ wila̱ u Vuzavaguɗu
\q1 
\v 73 Ekiye a̱ nu a ɗa a yaꞋin mu
\q2 o foɓusoi mu,
\q2 neke mu kuyeve, adama a na
\q2 m piꞋisa kadanshi ka̱ nu.
\q1 
\v 74 Aza a na i a kupana wovon u nu
\q2 yaꞋan ene mu ka̱ta̱ a yaꞋan ma̱za̱nga̱,
\q2 adama a na n keɗe ta̱
\q2 a̱pa̱Ꞌa̱ a kadanshi ka̱ nu.
\q1 
\v 75 Vuzavaguɗu, n yeve ta̱
\q2 wila̱ u nu derere ɗa,
\q2 kpamu a̱ ka̱tsuma̱ ka̱ ma̱riki ka̱ nu
\q2 ɗa vu yaꞋankai mu afada a usuɓi.
\q1 
\v 76 YaꞋan ucigi u nu
\q2 u na u tsu sabaꞋa ba,
\q1 u neke mu utsura u ka̱ɗu,
\q2 tsu na vu danai kagbashi ka̱ nu,
\q1 
\v 77 YaꞋan vu sa̱Ꞌa̱ mu, adama a na n yongo n wuma,
\q2 adama a na mi ta̱ a̱ ma̱za̱nga̱ n wila̱ u nu.
\q1 
\v 78 YaꞋan aza a ugbamukaci a yaꞋan wono,
\q2 adama a ka gbani-gbani ka na
\q2 a yaꞋankai mu ko unushi,
\q1 ama mi ta̱ e kusheshe a ukuna
\q2 wi ili i na vu dansai.
\q1 
\v 79 YaꞋan aza a na i
\q2 a kupana wovon u nu,
\q2 o bono wa̱ va̱,
\q2 ele na e yevei kadanshi ka̱ nu.
\q1 
\v 80 YaꞋan ka̱ɗu ka̱ va̱ ko yongo ko unushi
\q2 a ukuna wi ili i na vu dansai,
\q2 adama a na ka̱ta̱ mo okpo n wono ba.
\b
\s1 Avasa a̱ kula̱nsa̱ wishi
\q1 
\v 81 Vuzavaguɗu, wuma u va̱ wi ta̱ a mali ka̱u
\q2 a̱ kula̱nsa̱ wishi u nu,
\q2 n keɗe ta̱ a̱pa̱Ꞌa̱ a kadanshi ka̱ nu.
\q1 
\v 82 A̱shi a̱ va̱ a̱ ga̱la̱ ta̱
\q2 a kuvana uzuwakpani u nu,
\q2 ɗa n danai,
\q2 <<Wannai ɗai va kuneke mu kadanshi?>>
\q1 
\v 83 Adama a na mo okpo ta̱
\q2 tsu kedele ku ukpan ka na a saki a̱ ka̱nga̱,
\q2 dem n nannai n cinukpa
\q2 n ili i na vu dansai ba.
\q1 
\v 84 Ali n wannai ɗai kagbashi ka̱ nu
\q2 ka kulyaꞋa kelime n kugbama asuvu?
\q2 Wannai ɗai va kuyaꞋanka aza a na
\q2 i a kutakacika mu afada?
\q1 
\v 85 Aza a ugbamukaci a̱ ga̱va̱ ka̱ mu ta̱ kpenle
\q2 adama a na n yikpa̱ punu,
\q2 o tono wila̱ u nu ba.
\q1 
\v 86 Kadanshi ka̱ nu ra̱ka̱
\q2 ili i kuzuwaka katsura kaꞋa,
\q2 ɓa̱nka̱ mu, irala i va̱ i takacika mu ta̱ ko unushi,
\q1 
\v 87 Kenu ɗa ubuwai o kotso nu mpa aduniyan,
\q2 ama mpa n ka̱sukpa̱ ili i kutono i nu ba.
\q1 
\v 88 Adama a ucigi u nu u
\q2 na u tsu sabaꞋa ba,
\q2 wawa wuma u va̱,
\q2 ka̱ta̱ n tono kadanshi ka̱ una̱ u nu.
\b
\s1 Uneki u ka̱ɗu a̱ wila̱ u Vuzavaguɗu
\q1 
\v 89 Vuzavaguɗu, kadanshi ka̱ nu
\q2 ki ta̱ lo ko wannai,
\q2 ka shamgba ta̱ n utsura gaɗi.
\q1 
\v 90 Ma̱riki ma̱ nu a tsukaya a kubana tsukaya ra̱ka̱,
\q2 vu shikpa̱i aduniyan
\q2 ɗa tana a ɗa ashamgbai mayin.
\q1 
\v 91 Ili ra̱ka̱ yi ta̱ lo ali n gogo na
\q2 adama afada a̱ nu,
\q2 adama a na ili ra̱ka̱
\q2 agbashi a̱ nu a ɗa.
\q1 
\v 92 Ishi ba ci n ciya̱ ma̱za̱nga̱
\q2 a̱ wila̱ u nu ba,
\q2 mi ishi ta̱ a̱ ku kuwa̱
\q2 a̱ ka̱tsuma̱ ka atakaci a̱ va̱.
\q1 
\v 93 Mi a ku cinukpa n ili i kutono i nu ba,
\q2 adama a i ɗa, ɗa vu erei wuma u va̱.
\q1 
\v 94 Wawa mu, adama a na mpa wa̱ nu u ɗa mi,
\q2 n la̱nsa̱ ta̱ ili i kutono i nu.
\q1 
\v 95 Uma a gbani-gbani
\q2 i ta̱ a kuvana una mu,
\q2 ama n ciɓa ta̱ n kadanshi ka̱ nu.
\q1 
\v 96 N zuwaka ta̱ a na ko ili,
\q2 yi lo o kuyongo ko wannai ba,
\q2 ama kadanshi ka̱ nu ki n uteku ba.
\b
\s1 Ucigi u wila̱ u Vuzavaguɗu
\q1 
\v 97 Tsu na n cigai wila̱ u nu,
\q2 n tsu ka̱na̱ ta̱ kusheshe
\q2 ku u ɗa kanna dem.
\q1 
\v 98 Kadanshi ka̱ nu ka zuwa mu ta̱
\q2 n ciya̱i ugboji n laꞋi irala i va̱,
\q1 adama a na makyan dem
\q2 kaꞋa ki ta̱ nu mpa.
\q1 
\v 99 N ciya̱ ta̱ kuyeve n laꞋi nlum n va̱ ra̱ka̱,
\q2 adama a na mi ta̱ e kusheshe
\q2 a ukuna u kadanshi ka̱ nu.
\q1 
\v 100 N laꞋa ta̱ nkoshi m gba̱ra̱-gba̱ra̱ kuyeve,
\q2 adama a na n zuwaka ta̱
\q2 n ili i kutono i nu.
\q1 
\v 101 N tsu suma ta̱ kuyongo ku gbani-gbani,
\q2 adama a na n tono kadanshi ka̱ nu.
\q1 
\v 102 N vadalukpa ka afada a̱ nu kucina̱ ba,
\q2 adama a na avu ɗa vu piꞋisakai mu.
\q1 
\v 103 UyoꞋo u kadanshi ka̱ nu a̱ una̱ u va̱,
\q2 u laꞋa ta̱ ishigi uyoꞋo.
\q1 
\v 104 A̱ ubuta̱ wi ili i kutono i nu ɗa n ciya̱i kuyeve,
\q2 adama a nannai n iwan ta̱
\q2 uye wa aꞋuwa ra̱ka̱.
\b
\s1 Wila̱ u Vuzavaguɗu kutashi ku ɗa
\q1 
\v 105 Kadanshi ka̱ nu ki ta̱
\q2 tsu ma̱kuni e ene a̱ va̱,
\q2 kutashi kpamu a uye u va̱.
\q1 
\v 106 N kucina ta̱ kpamu ka shamgba ta̱
\q2 a na ma kuzuwaka
\q2 n afada a̱ usuɓi u nu.
\q1 
\v 107 Vuzavaguɗu n takacika ta̱ ka̱u,
\q2 bonoko wuma u va̱ tsu kadanshi ka̱ nu.
\q1 
\v 108 Vuzavaguɗu isa ili i na n kucinakai nu
\q2 piꞋisaka mu afada a̱ nu.
\q1 
\v 109 A makyan dem wuma u va̱
\q2 wi ta̱ a̱ ka̱tsuma̱ ka̱ ma̱da̱ka̱,
\q2 ama n cinukpa wila̱ u nu ba.
\q1 
\v 110 Uma a gbani-gbani
\q2 a zuwaka mu ta̱ maza,
\q2 ama n katsukpa a ili i kutono i nu ba.
\q1 
\v 111 Ili i na vu dansai
\q2 ili yu uka̱ni i va̱ i ɗa ko wannai,
\q2 ka ɗaɗa ma̱za̱nga̱ ma̱ ka̱ɗu ka̱ va̱.
\q1 
\v 112 N coꞋoko ta̱
\q2 n ili i na vu dansai ko wannai.
\b
\s1 Wila̱ u Vuzavaguɗu Ma̱ta̱na̱ maꞋa
\q1 
\v 113 N iwan ta̱ uma a̱ una̱ ure,
\q2 ama n ciga ta̱ wila̱ u nu.
\q1 
\v 114 Avu ɗa ubuta̱ u kusheɗeku u va̱
\q2 m ma̱ra̱ga̱ ma̱ va̱,
\q2 n keɗe ta̱ a̱pa̱Ꞌa̱ a kadanshi ka̱ nu.
\q1 
\v 115 YaꞋin daꞋangi nu mpa
\q2 a̱ɗa̱ uma a gbani-gbani,
\q2 adama a na n tono
\q2 kadanshi ka̱ Ka̱shile ka̱ va̱.
\q1 
\v 116 Neke mu wuma tsu na
\q2 vu yaꞋin kadanshi,
\q2 adama a na n ciya̱ wuma,
\q2 ka̱ta̱ vu ka̱sukpa̱ mu n yaꞋan wono
\q2 a̱ a̱pa̱Ꞌa̱ a na n keɗei ba.
\q1 
\v 117 Ka̱na̱ mu, adama a na n ciya̱ wishi.
\q2 N tono ili i na vu dansai ko wannai.
\q1 
\v 118 Vu iwan ta̱ aza a na a katsukpai
\q2 ili i na vu dansai,
\q2 adama a na ma̱ya̱nsa̱ka̱ me le gbani ɗa.
\q1 
\v 119 Vu tsu vakangu ta̱
\q2 uma a gbani-gbani
\q2 aduniyan ra̱ka̱ tsa̱ a̱shinda̱,
\q1 ɗaɗa i zuwai ɗa n cigai
\q2 kadanshi ka̱ nu.
\q1 
\v 120 Ikyamba i va̱ i jeꞋe ta̱
\q2 adama o wovon u nu,
\q2 kpamu mi ta̱ a kupana
\q2 wovon wa afada a̱ nu.
\b
\s1 Kutono ku wila̱ u Vuzavaguɗu
\q1 
\v 121 N yaꞋan ta̱ ili yu usuɓi m mejege,
\q2 ka̱ta̱ vu ka̱sukpa̱ mu
\q2 ekiye a irala i va̱ ba.
\q1 
\v 122 Ka̱sukpa̱ kagbashi ka̱ nu
\q2 ko yongo m ma̱ta̱na̱,
\q1 ka̱ta̱ vu ka̱sukpa̱ aza
\q2 a ugbamukaci o doro mu ba.
\q1 
\v 123 A̱shi a̱ va̱ a̱ ga̱la̱ ta̱
\q2 a kuvana wishi u nu,
\q2 n kadanshi ku usuɓi ka̱ nu.
\q1 
\v 124 yaꞋanka kagbashi ka̱ nu
\q2 tsu ucigi u nu u na u tsu sabaꞋa ba,
\q2 vu piꞋisaka mu ili i na vu dansai.
\q1 
\v 125 Mpa kagbashi ka̱ nu kaꞋa,
\q2 neke mu cicoꞋo,
\q2 adama a na n yeve kadanshi ka̱ nu.
\q1 
\v 126 Vuzavaguɗu makyan ma yaꞋan ta̱
\q2 a na va kuyaꞋan ili,
\q2 adama a na uma o koɗo ta̱ wila̱ u nu.
\q1 
\v 127 Adama a na n cigai ta̱
\q2 kadanshi ka̱ nu ali u laꞋi azanariya,
\q2 u laꞋi azanariya koci.
\q1 
\v 128 Adama a na kpamu mi ta̱
\q2 a kuzuwaka n ili i kutono i nu mayin,
\q2 n iwan ta̱ ukuna wa aꞋuwa ra̱ka̱.
\b
\s1 Mali mo kutono wila̱ u Vuzavaguɗu
\q1 
\v 129 Kadanshi ka̱ nu ili i mereve i ɗa,
\q2 ɗaɗa i zuwai ɗa n zuwai
\q2 kadanshi ka̱ nu a̱ ka̱ɗu ka̱ va̱.
\q1 
\v 130 Ku utuka̱ kadanshi ka̱ nu
\q2 e keteshe ku tsu neke ta̱ kutashi,
\q2 ku tsu neke ta̱ kuyeve u vuza na wi n kuyeve ba.
\q1 
\v 131 M apukai una̱ u va̱ ka̱u,
\q2 n ka̱na̱i ayinviki gaɗi-gaɗi,
\q2 adama a ucigi u kadanshi ka̱ nu.
\q1 
\v 132 Kpatala wa̱ va̱
\q2 vu yaꞋanka mu kasingai,
\q2 tsu na wu untsukai vu yaꞋanka
\q2 aza a na a cigai kula ku nu.
\q1 
\v 133 Tono nu nwalu n va̱ tsu na vi yaꞋin kadanshi,
\q2 ka̱ta̱ vu ka̱sukpa̱ ka gbani-gbani ka̱ ciya̱ mu ba.
\q1 
\v 134 Shiba̱ mu ekiye aza o modoruko,
\q2 ka̱ta̱ n zuwaka n ili i kutono i nu.
\q1 
\v 135 YaꞋan kutashi ku nu ku akana
\q2 a̱shi a kagbashi ka̱ nu,
\q2 ka̱ta̱ vu piꞋisaka mu ili i na vu dansai.
\q1 
\v 136 Kujilya a̱ kutsuwa̱n
\q2 a̱ a̱shi a̱ va̱ tsu mini,
\q2 adama a na uma o tono wila̱ u nu ba.
\b
\s1 Ma̱riki ma̱ wila̱ u Vuzavaguɗu
\q1 
\v 137 Vuzavaguɗu, avu vuza vu usuɓi ɗa,
\q2 afada a̱ nu kpamu i ta̱ mejege.
\q1 
\v 138 Kadanshi ka na vu nekei ra̱ka̱, ku usuɓi kaꞋa,
\q2 kpamu ili i kuzuwaka katsura kaꞋa.
\q1 
\v 139 Mali ma̱ va̱ wa̱ nu
\q2 ma takacika mu ta̱,
\q2 adama a na irala i va̱
\q2 i iwan ta̱ kadanshi ka̱ nu.
\q1 
\v 140 O kondo ta̱ kadanshi ka̱ nu mayin,
\q2 kpamu mpa kagbashi ka̱ nu n ciga ta̱ kaꞋa.
\q1 
\v 141 Mpa ili i yoku i ɗa ba, ili i kugoyi,
\q2 ama n cinukpa n ili i kutono i nu ba.
\q1 
\v 142 Usuɓi u nu, usuɓi u ɗa ko wannai,
\q2 wila̱ u nu mayun ɗa ayin dem.
\q1 
\v 143 Mi ta̱ n atakaci
\q2 n una̱mgbuka̱tsuma̱,
\q2 ama kadanshi ka̱ nu ke
\q2 ci neke mu ta̱ ma̱za̱nga̱ a̱ ka̱ɗu.
\q1 
\v 144 Kadanshi ka̱ nu ki ta̱ mejege ko wannai,
\q2 ke ci neke mu ta̱ kuyeve
\q2 adama a na n ciya̱ wuma.
\b
\s1 Avasa a̱ kula̱nsa̱ wishi
\q1 
\v 145 Vuzavaguɗu, ushuku mu
\q2 n ka̱ɗu ka̱ va̱ kaꞋa ra̱ka̱ mi a̱ ma̱shi,
\q2 mi ta̱ o kutono ili i na vu dansai.
\q1 
\v 146 Mi ta̱ e meɗevile wa̱ nu, wawa mu!
\q2 Ka̱ta̱ n tono kadanshi ka̱ nu.
\q1 
\v 147 Kafu kayin ka asa n shika̱ ta̱ a̱ kula̱nsa̱ uɓa̱nki
\q2 n keɗe ta̱ a̱pa̱Ꞌa̱ a kadanshi ka̱ nu.
\q1 
\v 148 Kayin ra̱ka̱ n lata ba,
\q2 e kusheshe a ukuna wu
\q2 uzuwakpani u Vuzavaguɗu.
\q1 
\v 149 Pana ka̱la̱ka̱tsu ka̱ va̱
\q2 adama a ucigi u nu
\q2 u na u tsu sabaꞋa ba,
\q2 ere wuma u va̱ tsu afada a̱ nu.
\q1 
\v 150 Aza a gbani-gbani a na
\q2 a takacikai mu,
\q2 a yawa ta̱ ɗevu,
\q2 uma a na i daꞋangi n wila̱ u nu.
\q1 
\v 151 Ama avu Vuzavaguɗu, vi ta̱ ɗevu,
\q2 kadanshi ka̱ nu kpamu mayun ɗa.
\q1 
\v 152 Ali n cau ɗa n yevei a kadanshi ka̱ nu,
\q2 vu zuwa ta̱ kaꞋa ko wannai.
\b
\s1 Ufolu adama a̱ uɓa̱nki
\q1 
\v 153 Indana atakaci a̱ va̱ ka̱ta̱ vu isa mu,
\q2 adama a na n cinukpa n wila̱ u nu ba.
\q1 
\v 154 Shamkpa mu ka̱ta̱ vu shiba̱ mu,
\q2 ere mu tsu na vu dansai.
\q1 
\v 155 Wishi wi ta̱ daꞋin n aza agbani-gbani,
\q2 adama a na a̱ la̱nsa̱ e yeve ili i na vu dansai ba.
\q1 
\v 156 Vuzavaguɗu, asuvayali a̱ nu a gbayin a ɗa,
\q2 ere wuma u va̱ tsu afada a̱ nu.
\q1 
\v 157 Irala i na yi a kutakacika mu, i ta̱ n a̱bunda̱i,
\q2 ama n katsukpa kadanshi ka̱ nu ba.
\q1 
\v 158 Mi indai aza a kavama
\q2 ɗa m panai unata u le,
\q2 adama a na o tono
\q2 kadanshi ka̱ nu ba.
\q1 
\v 159 Vuzavaguɗu la̱na̱ tsu na
\q2 n cigai ili i kutono i nu,
\q2 ere wuma u va̱ tsu
\q2 ucigi u nu u na u tsu sabaꞋa ba.
\q1 
\v 160 Kadanshi ka̱ nu ra̱ka̱ mayun ɗa,
\q2 afada a usuɓi a̱ nu ko wannai ɗa.
\b
\s1 Kubonoko ku ka̱ɗu a̱ wila̱ u Vuzavaguɗu
\q1 
\v 161 Aza o tsugono a kutakacika mu ko unushi,
\q2 ama ka̱ɗu ka̱ va̱ ki ta̱
\q2 o wovon u kadanshi ka̱ nu.
\q1 
\v 162 Mi ta̱ a̱ ma̱za̱nga̱ n a̱bunda̱i
\q2 n kadanshi ka̱ nu,
\q2 tsu vuza na u ciya̱i ucanuku
\q2 u gbani n a̱bunda̱i.
\q1 
\v 163 N kovo ta̱ aza aꞋuwa,
\q2 kpamu n tsu pana ta̱ unata u le,
\q2 ama n ciga ta̱ wila̱ u nu.
\q1 
\v 164 A kanna lakam n ci cikpa wu ta̱ kucindere,
\q2 adama afada a usuɓi u nu.
\q1 
\v 165 Aza a na a cigai wila̱ u nu
\q2 a̱ ciya̱ ta̱ ida̱shi i ma̱ta̱na̱ ka̱u,
\q2 kpamu ko ili yi lo a kuzuwa le a̱ ta̱ɗa̱tsa̱ ba.
\q1 
\v 166 vuzavaguɗu, mi ta̱ a kuvana wishi u nu,
\q2 mi ta̱ o kutono kadanshi ka̱ nu.
\q1 
\v 167 N tono ta̱ kadanshi ka̱ nu,
\q2 n ciga ta̱ kaꞋa n ka̱ɗu ke te.
\q1 
\v 168 N zuwaka ta̱
\q2 n ili i kutono i nu
\q2 n kadanshi ka̱ nu,
\q2 adama a na vu yeve ta̱
\q2 ili i na mi a kuyaꞋan ra̱ka̱.
\b
\s1 Avasa a̱ kula̱nsa̱ uɓa̱nki
\q1 
\v 169 Vuzavaguɗu, yaꞋan ma̱shi ma̱ va̱
\q2 ma yawa wa̱ nu
\q2 neke mu kuyeve tsu na vu dansai
\q1 
\v 170 YaꞋan ufolu u va̱ u ta̱wa̱ wa̱ nu,
\q2 isa mu tsu na vu yaꞋin kadanshi.
\q1 
\v 171 YaꞋan nla̱ba̱ ma̱ una̱ u va̱ u cikpa wu,
\q2 adama a na vu piꞋisaka mu ili i na vu dansai.
\q1 
\v 172 YaꞋan kelentsu ka̱ va̱ ka canana kadanshi ka̱ nu,
\q2 adama a na kadanshi ka̱ nu ra̱ka̱ ku usuɓi kaꞋa.
\q1 
\v 173 YaꞋan kukiye ku nu kuyongo
\q2 ufoɓushi kuɓa̱nka̱ mu,
\q2 adama a na n zagba ta̱ ili i kutono i nu.
\q1 
\v 174 Vuzavaguɗu, mi ta̱ a mali ma wishi u nu,
\q2 n ci ciya̱ ta̱ ma̱za̱nga̱ n wila̱ u nu.
\q1 
\v 175 Ka̱sukpa̱ mu n wuma,
\q2 adama a na n cikpa wu,
\q2 kpamu yaꞋan afada a̱ nu a̱ ɓa̱nka̱ mu.
\q1 
\v 176 M puwa̱nka̱ ta̱ tsu mokyon
\q2 ma na ma̱ puwa̱nka̱i.
\q1 La̱nsa̱ kagbashi ka̱ nu
\q2 adama a na n cinukpa n kadanshi ka̱ nu ba.
\c 120
\s1 Ma̱shi ma̱ kula̱nsa̱ uɓa̱nki
\d Vishipa vu kugaɗukpa a kubana a̱ ubuta̱ wa̱ a̱ga̱nda̱.
\q1 
\v 1 N ɗekushe ta̱ Vuzavaguɗu,
\q2 ana mi a̱ ka̱tsuma̱ ka atakaci,
\q2 ɗa tana wu ushuki mu.
\q1 
\v 2 Vuzavaguɗu, wawa wuma u va̱,
\q2 we elentsu aza a uwa
\q2 n wa aza o modoruko.
\q1 
\v 3 Yiɗa̱i u kuyaꞋanka ɗa̱,
\q2 afada e ne a ɗai u kuyaꞋanka ɗa̱
\q2 a̱ɗa̱ aza o modoruko?
\q1 
\v 4 Wi ta̱ a kutakacika ɗa̱
\q2 n ayaꞋa a lyalyaꞋan o osoji
\q2 koɓolo n a̱ga̱ruwa̱shi akina.
\q1 
\v 5 Ili ya atakaci i ɗa wa̱ a̱ va̱,
\q2 a na mi a̱ ida̱shi a̱ likuci i Mesheku
\q2 punu a̱pa̱m e Kedaru.
\q1 
\v 6 N geshe ta̱ ida̱shi,
\q2 a̱ ka̱tsuma̱ ka aza a na a cigai ida̱shi i ma̱ta̱na̱ ba.
\q1 
\v 7 Mpa vuza vu kuciga ida̱shi i ma̱ta̱na̱ i ɗa,
\q2 ama n dansa baci,
\q2 ka̱ta̱ a yaꞋan ukuna u kuɗa̱ngusa̱ vishili.
\c 121
\s1 Vuzavaguɗu ɗa ka̱ɓa̱nki ka̱ va̱
\d Vishipa vu kugaɗukpa a kubana a̱ ubuta̱ wa̱ a̱ga̱nda̱.
\q1 
\v 1 N ɗengusa̱i a̱shi a̱ va̱ a uɓon wa aginda me ene,
\q2 teɗai uɓa̱nki u va̱ wi a̱ ku uta̱?
\q1 
\v 2 Uɓa̱nki u va̱ wi ta̱ a̱ ku uta̱
\q2 a̱ ubuta̱ u Vuzavaguɗu,
\q2 a̱yi na u yaꞋin gaɗi n iɗika.
\q1 
\v 3 Wi a̱ ku ka̱sukpa̱ wu vu yikpa̱ ba,
\q2 maguɓi ma nu mi a ku gbaɗika ba.
\q1 
\v 4 Maguɓi ma aza a Israila
\q2 ma tsu gbaɗika ko u lata ba.
\q1 
\v 5 Vuzavaguɗu ɗa ke eri ka̱ nu,
\q2 Vuzavaguɗu kulu ku ɗa wa̱ nu.
\q1 
\v 6 Vi o kusoꞋo kanna ba,
\q2 ko kutashi ku wotoi n kayin ba.
\q1 
\v 7 Vuzavaguɗu wi ta̱ e ku ere wu
\q2 a ka gbani-gbani dem,
\q2 wi ta̱ a̱ ku la̱na̱ wuma u nu.
\q1 
\v 8 Vuzavaguɗu wi ta̱ e ku ere
\q2 ku uwa ku nu n ku uta̱ ku nu,
\q2 gogo na a kubana ko wannai.
\c 122
\s1 Vishipa adama a Urushelima
\d Ishipa i kugaɗukpa a kubana a̱ ubuta̱ wa̱ a̱ga̱nda̱. Vishipa vu Dawuda.
\q1 
\v 1 N yaꞋan ta̱ ma̱za̱nga̱ ana a danai mu,
\q2 <<YaꞋan tsu bana A̱Ꞌisa̱ a gbayin a Vuzavaguɗu.>>
\q1 
\v 2 A̱tsu ɗa na ci yawai,
\q2 ci ta̱ kashani a̱ utsutsu u Urishelima.
\b
\q1 
\v 3 A maꞋa ta̱ Urishelima tsu likuci i na
\q2 yi ugbaɓi a̱ ubuta̱ u te,
\q1 
\v 4 ubuta̱ u na kumaci kakau ku tsu bana,
\q2 kumaci ki Isaraila,
\q2 adama a na a cikpa Vuzavaguɗu,
\q2 tsu na e nekei aza a Isaraila kadanshi.
\q1 
\v 5 Adama a na ta ɗe akuba afada i,
\q2 akuba o tsugono tsu kpaꞋa ku Dawuda.
\b
\q1 
\v 6 YaꞋankai Urushelima avasa a̱ ma̱ta̱na̱,
\q2 <<YaꞋan aza na a cigai nu
\q2 a̱ ciya̱ ulyaꞋi u kelime.
\q1 
\v 7 YaꞋan ma̱ta̱na̱ mo yongo a Urushelima,
\q2 ida̱shi i ma̱ta̱na̱ kpamu
\q2 e efeku o tsugono a̱ nu.>>
\q1 
\v 8 Adama a̱ja̱Ꞌa̱ a̱ va̱ n aza a̱ va̱,
\q2 n danai Urishelima, <<Ma̱ta̱na̱ mo yongo n avu.>>
\q1 
\v 9 Adama a kpaꞋa ku Vuzavaguɗu Ka̱shile ka̱ tsu,
\q2 mi ta̱ avasa vu lyaꞋa kelime.
\c 123
\s1 Ma̱shi ma asuvayali
\d Vishipa vu kugaɗukpa a kubana a̱ ubuta̱ wa̱ a̱ga̱nda̱.
\q1 
\v 1 Vuzavaguɗu, wa̱ nu ɗa n zuwai a̱shi,
\q2 gaɗi a̱ ubuta̱ u na vi o tsugono.
\q1 
\v 2 Tsu na a̱shi a agbashi i
\q2 a ku inda vuza kpaꞋa vu le
\q2 tsu na a̱shi kagbashi ka vuka ki
\q2 a ku inda vuzagbayin vu ni,
\q1 ta a̱shi a̱ tsu i nannai u Vuzavaguɗu Ka̱shile ka̱ tsu,
\q2 ali a makyan ma na u panai asuvayali a̱ tsu.
\q1 
\v 3 Pana asuvayali a̱ tsu Vuzavaguɗu,
\q2 pana asuvayali,
\q2 adama a na kugoyi ka, ku yawa tsu ta̱.
\q1 
\v 4 Aza a uciyi e geshe ta̱ o kugoyo tsu,
\q2 aza a gbani-gbani n ugbamukaci
\q2 o goyo tsu ta̱.
\c 124
\s1 Ka̱shile kaꞋa kawawi ka uma a̱ ni
\d Vishipa vu kugaɗukpa a kubana a̱ ubuta̱ wa̱ a̱ga̱nda̱. Vishipa vu Dawuda.
\q1 
\v 1 Ishi baci Vuzavaguɗu wi koɓolo n a̱tsu ba,
\q2 yiɗa̱i yi ishi a̱ kuciya̱ tsu?
\q2 YaꞋan Isaraila a dana.
\q1 
\v 2 Ishi baci Vuzavaguɗu wi koɓolo n a̱tsu ba,
\q2 ana uma a̱ tuka̱i tsu n vishili,
\q1 
\v 3 ishi o kusoɗongu tsu n wuma
\q2 a makyan ma nanlo,
\q2 adama asuvusuɗukpi a na i a kuyaꞋan n a̱tsu.
\q1 
\v 4 Ishi a̱ kupura̱ngu tsu n wupa tsu mini ma na ma ayai,
\q2 mini ma, mi ishi a kulyaꞋa tsu,
\q1 
\v 5 mini mi ilaɗi mi ishi a kulyaꞋa tsu ra̱ka̱.
\q1 
\v 6 Ucikpi u Vuzavaguɗu,
\q2 ana u ka̱sukpa̱i irala i tsu i lyaꞋi tsu ba.
\q1 
\v 7 Tsu laꞋakai tsu manunu a maza ma vuza kutambu,
\q2 maza ma, ma kasai ɗa tsu laꞋakai.
\q1 
\v 8 Uɓa̱nki u tsu wi ta̱ a̱ ku uta̱ u Vuzavaguɗu,
\q2 a̱yi na u yaꞋin gaɗi n iɗika.
\c 125
\s1 Ka̱shile ki ta̱ e ku ere uma a̱ ni
\d Vishipa vu kugaɗukpa a kubana a̱ ubuta̱ wa̱ a̱ga̱nda̱.
\q1 
\v 1 Aza a na a zuwai katsura ke le u Vuzavaguɗu,
\q2 i ta̱ tsu kusan ku gbayin ku Sihiyona,
\q2 ku na ku tsu kugba̱ɗa̱ ba,
\q2 ki ta̱ lo ko wannai.
\q1 
\v 2 Tsu na nsansa m gbagbaꞋin
\q2 mi uka̱ra̱Ꞌi n Urushelima,
\q2 ta feu Vuzavaguɗu
\q2 u kanzai uma a̱ ni nannai,
\q2 gogo na a kubana ko wannai.
\q1 
\v 3 Aza a gbani-gbani i a kulyaꞋa tsugono
\q2 a iɗika i uma a̱ Ka̱shile ba,
\q2 ɗa baci a lyaꞋi tsugono,
\q2 yoku ba uma a̱ Ka̱shile a feu i ta̱ a ku nusa.
\q1 
\v 4 Vuzavaguɗu, yaꞋanka aza a usuɓi kasingai,
\q2 ele na i o kutono wila̱ u nu.
\q1 
\v 5 Ama aza a na a vadalukpai
\q2 o tonoi uye u gbani-gbani,
\q2 yaꞋan Vuzavaguɗu wu utuka̱ le
\q2 koɓolo n aza a gbani-gbani.
\b
\q1 YaꞋan ma̱ta̱na̱ mo yongo n aza a Isaraila.
\c 126
\s1 Vishipa va aza a na a̱ uta̱i a̱ ubuta̱ u tsugbashi
\d Vishipa vu kugaɗukpa a kubana a̱ ubuta̱ wa̱ a̱ga̱nda̱.
\q1 
\v 1 Ana Vuzavaguɗu u bonokoi tsu
\q2 n una̱singai u tsu,
\q2 a̱tsu na ci o kubono a Sihiyona,
\q2 ɗa wo okpoi tsu tsa alatani.
\q1 
\v 2 Ɗa tsu ɓosoi izoshi,
\q2 ci yaꞋin ishipa i ma̱za̱nga̱.
\q1 Ɗa uduniyan u yoku u danai,
\q2 <<Vuzavaguɗu u yaꞋanka le ta̱ ili i gbayin.>>
\q1 
\v 3 E mayun ɗa, Vuzavaguɗu u yaꞋanka tsu ta̱ ili i gbagbaꞋin,
\q2 ɗa tana ci shanai m ma̱za̱nga̱.
\q1 
\v 4 Avu Vuzavaguɗu,
\q2 bonoko tsu n tsugbayin tsu tsu
\q2 tsu na o ci yoꞋo mini ma utsura
\q2 a iɗika i na yi ishi i ɗekpei.
\q1 
\v 5 Aza a na i a̱ vica̱Ꞌa̱ m ma̱shi,
\q2 i ta̱ a kuyaꞋan vikyaꞋa m ma̱za̱nga̱.
\q1 
\v 6 A̱yi na wu uta̱i m ma̱shi
\q2 ucaniki n icuꞋu i vica̱Ꞌa̱,
\q2 wi ta̱ o kubono n vishipa vu ma̱za̱nga̱.
\q2 ucaniki nu nta̱ka̱ mi ili i kashina.
\c 127
\s1 Ucikpi u kasingai ka̱ Ka̱shile
\d Vishipa vu kugaɗukpa a kubana a̱ ubuta̱ wa̱ a̱ga̱nda̱.Vishipa vu Sulemanu.
\q1 
\v 1 Vuzavaguɗu ɗa baci u maꞋin kpaꞋa ba,
\q2 ulinga wa aza a kumaꞋa gbani ɗa.
\q1 Vuzavaguɗu ɗa baci we erei likuci ba,
\q2 gbani ɗa a zuwa aza a kindi.
\q1 
\v 2 Gbani ɗa i ci ɗa̱nga̱ n usana ka̱li-ka̱li
\q2 yi kpamu o kubono a kpaꞋa ga̱ba̱ ba,
\q2 yi atakaci adama a ilikulyaꞋa.
\q1 Adama a na u tsu zuwa ta̱
\q2 aza na u cigai a uvuka mayin.
\q1 
\v 3 Mayun, muku mo olobo kuneꞋe ku ɗa,
\q2 a̱ ubuta̱ u Vuzavaguɗu,
\q2 muku katsupu kaꞋa wa̱ ni.
\q1 
\v 4 Tsa ayaꞋa ekiye o kosoji,
\q2 nannai ɗa muku mo olobo n na
\q2 a matsakai vuza a ayin a utsura u ni.
\q1 
\v 5 Vuza vu ma̱za̱nga̱ ɗa,
\q2 a̱yi na majiki ma̱ ni
\q2 ma shanai tukpa n ele.
\q1 Wi a kuyaꞋan wono ba,
\q2 a makyan ma na wi a̱ vishili n irala i ni,
\q2 n ubuta̱ u koɓolo, a̱ utsutsu u likuci.
\c 128
\s1 Una̱singai wa aza a ukuna u mayun
\d Vishipa vu kugaɗukpa a kubana a̱ ubuta̱ wa̱ a̱ga̱nda̱.
\q1 
\v 1 Aza a̱ ma̱za̱nga̱ a ɗa ra̱ka̱
\q2 aza a na i a kupana wovon u Vuzavaguɗu,
\q2 aza a na i a nwalu a uye u ni.
\q1 
\v 2 Vi ta̱ a kulyaꞋa mele ma ulinga ma̱ nu,
\q2 m ma̱za̱nga̱ n kasingai
\q2 i ta̱ o ko okpo wa̱ nu.
\q1 
\v 3 Vuka vu nu vi ta̱ o ko okpo
\q2 tsu maɗanga mi itacishi ma limata a kpaꞋa ku nu,
\q2 muku n nu kpamu tsu n nɗanga n zaitu
\q2 uka̱ra̱Ꞌi n kirukpa ku nu.
\q1 
\v 4 Nannai ɗa a kuzuwaka vuma una̱singai,
\q2 vuza na u tsu pana wovon u Vuzavaguɗu.
\q1 
\v 5 YaꞋan Vuzavaguɗu u zuwaka wu
\q2 una̱singai a Sihiyona,
\q2 a ayin a wuma u nu dem
\q2 yaꞋan vu ene ulyaꞋi u kelime u Urushelima.
\q1 
\v 6 YaꞋan vi yongo n wuma,
\q2 vu ene ntsukaya n nu.
\q2 Ma̱ta̱na̱ mo yongo koɓolo n aza a Isaraila.
\c 129
\s1 Avasa a kuyaꞌan tsurala ya aza a Isaraila
\d Vishipa vu kugaɗukpa a kubana a̱ ubuta̱ wa̱ a̱ga̱nda̱.
\q1 
\v 1 A̱ɗa̱ aza a Isaraila,
\q2 yaꞋin n i dansai ukuna u nampa.
\q1 <<Ali biꞋi mpa kenu,
\q2 ɗa i a kutakacika mu ka̱u.>>
\q1 
\v 2 <<Ali biꞋi mpa kenu, ɗa i a kutakacika mu ka̱u,
\q2 ama a̱ ciya̱ ulyaꞋi wa̱ a̱ va̱ ba.
\q1 
\v 3 Ɗa a yaꞋankai mu muna
\q2 a ɓatsai mu a̱ kucina̱ ka̱u
\q2 o bonokoi ku ɗa
\q2 tsu kashina ka na a nimai.>>
\q1 
\v 4 Ama Vuzavaguɗu vuza kasingai ɗa,
\q2 u wawai mu a̱ ubuta̱ u tsugbashi.
\q1 
\v 5 YaꞋan aza a na a iwain Sihiyona ra̱ka̱,
\q2 yaꞋan o bono n wono.
\q1 
\v 6 YaꞋan okpo an mita̱
\q2 ma na mu uta̱i a gaɗi vu kukpa̱Ꞌa̱,
\q2 ma ci ɗekpe ta̱ kafu mo gbonguro,
\q1 
\v 7 ma na ma ci shana ureci
\q2 u kukiye ku vuza vu vikya ba,
\q2 ko ekiye aza o kuɓolongu nta̱ka̱ ba.
\q1 
\v 8 Ka̱ta̱ aza a nwalu a dana ba.
\q1 <<YaꞋan una̱singai u Vuzavaguɗu
\q2 u yongo a kaci ka̱ ɗa̱.
\q1 ci ta̱ a ku zuwaka ɗa̱ una̱singai
\q2 a̱ ka̱tsuma̱ ka kula ku Vuzavaguɗu.>>
\c 130
\s1 Ma̱shi ma vuza na u shika̱i unushi u ni
\d Vishipa vu kugaɗukpa a kubana a̱ ubuta̱ wa̱ a̱ga̱nda̱.
\q1 
\v 1 Avu Vuzavaguɗu, n ɗeke wu ta̱
\q2 a̱ ka̱tsuma̱ ka atakaci a̱bunda̱i a̱ va̱,
\q1 
\v 2 Avu Vuzavaguɗu, pana ma̱shi ma̱ va̱,
\q2 zuwa atsuvu, vu pana ka̱la̱ka̱tsu ka̱ va̱,
\q2 ka̱ kula̱nsa̱ uɓa̱nki.
\q1 
\v 3 Avu Vuzavaguɗu,
\q2 vi baci e kukece unushi u tsu,
\q2 yayi wa ku shamgba?
\q1 
\v 4 Ama vu tsu cinukpaka ta̱ uma unushi,
\q2 adama a na a pana wovon u nu.
\q1 
\v 5 N zuwa ta̱ ka̱ɗu ka̱ va̱ u Vuzavaguɗu,
\q2 wuma uva̱ wa̱ ni ɗa u ɗa wi,
\q2 kpamu a kadanshi ka̱ ni ka n zuwai ka̱ɗu ka̱ va̱.
\q1 
\v 6 Wuma u va̱ wi ta̱ a mali ma Vuzavaguɗu
\q2 ali u laꞋa tsu na aza a kindi
\q2 a ci yaꞋan mali ma na ene usana.
\q1 mayun, u laꞋa ta̱ tsu na aza a kindi
\q2 a ci yaꞋan mali ma na ene usana.
\q1 
\v 7 Avu Isaraila, zuwa katsura u Vuzavaguɗu,
\q2 adama a na a̱ ubuta̱ u Vuzavaguɗu
\q2 ucigi wi ta̱ lo,
\q2 a̱ ubuta̱ u ni kpamu wishi wi ta̱ lo.
\q1 
\v 8 A̱yi tana wi ta̱ a ku wawa aza a Isaraila
\q2 a̱ ka̱tsuma̱ ku unushi u le dem.
\c 131
\s1 Vishipa vu ku zuwa katsura u Ka̱shile
\d Vishipa vu kugaɗukpa a kubana a̱ ubuta̱ wa̱ a̱ga̱nda̱. Vishipa vu Dawuda.
\q1 
\v 1 Vuzavaguɗu,
\q1 mpa vuza vu a̱ra̱ɗi ɗa ba,
\q2 mi tana feu n ugbamukaci ba,
\q1 ili i bura mu n ukuna u gbagbaꞋin ba,
\q2 ko kpamu i na i laꞋi utsura u va̱ ba.
\q1 
\v 2 Ama mpa, n ka̱na̱ ta̱ ka̱ɗu ka̱ va̱,
\q2 n vaꞋanka ta̱ n kaꞋa,
\q2 an maku me kenu ma na a kasai mani,
\q1 an maku me kenu ekiye a̱na̱ku a̱ ni,
\q2 ta ka̱ɗu ka̱ va̱ ki ida̱shi nannai.
\q1 
\v 3 Avu Isaraila, zuwa ka̱ɗu ka̱ nu u Vuzavaguɗu,
\q2 gogo na a kubana ko wannai.
\c 132
\s1 Vishipa adama a̱ likuci i Dawuda
\d Vishipa vu kugaɗukpa a kubana a̱ ubuta̱ wa̱ a̱ga̱nda̱.
\q1 
\v 1 Vuzavaguɗu,
\q2 ciɓa n Dawuda,
\q2 n tsu na u lulukpa̱i a̱ ka̱tsuma̱ ka atakaci a̱ ni.
\q1 
\v 2 Ciɓa n tsu na u kucinakai Vuzavaguɗu,
\q2 n akucina a̱ ni u MalaꞋimili ma Yakubu, u danai,
\q1 
\v 3 <<Mpa mi a kubana a kpaꞋa ba,
\q2 ko n vaku a kajiba ka̱ va̱ ba,
\q1 
\v 4 mi a̱ ku ka̱sukpa̱ a̱shi a̱ va̱ a̱ yimba̱tsa̱ka̱ ba,
\q2 mi e kuneke a̱ga̱la̱ a̱shi a̱ va̱ wuvuki ba,
\q1 
\v 5 ali n la̱nsa̱ka̱ Vuzavaguɗu ubuta̱,
\q2 ubuta̱ wi ida̱shi adama a MalaꞋimili ma Yakubu.>>
\q1 
\v 6 Ɗanna tsu panai arabali, a danai,
\q2 akpati vu uzuwakpani vi ta̱ a Efarata,
\q2 ɗa ci cinai vu ɗa a̱pula̱ka̱ a Kiriyatu-jerimu.
\q1 
\v 7 Ɗa tsu danai,
\q2 <<YaꞋan tsu bana a̱ ubuta̱ wi ida̱shi i Vuzavaguɗu,
\q2 yaꞋan tsu kuɗa̱ngu e kelime ka̱ ni.>>
\q1 
\v 8 Vuzavaguɗu,
\q2 ɗa̱nga̱ vu bana ubuta̱ u kuvuka u nu,
\q2 avu n akpati vu uzuwakpani a utsura a̱ nu.
\q1 
\v 9 YaꞋan anan ganu a̱ nu
\q2 a yaꞋan ukuna wu usuɓi,
\q1 YaꞋan ncigi n nu
\q2 n ɗa̱ngusa̱ a̱la̱ka̱tsu
\q2 a canana ishipa i ma̱za̱nga̱.
\q1 
\v 10 Adama a kagbashi ka̱ nu Dawuda,
\q2 ka̱ ta̱ vu kpatala a̱shi a̱ nu
\q2 u vuza na vu erengi ba.
\q1 
\v 11 Vuzavaguɗu u yaꞋanka ta̱ Dawuda
\q2 uzuwakpani u ma̱riki,
\q2 uzuwakpani u na u kukotso ba, u danai,
\q1 <<Vuza te a̱ ka̱tsuma̱ ka̱ muku mo olobo n nu,
\q2 ɗa n kuzuwa a kakuba ko tsugono tsu nu.
\q1 
\v 12 Ɗa baci muku mo olobo n nu
\q2 n tonoi uzuwakpani u va̱,
\q2 n kadanshi ka̱ va̱ ka na m piꞋisakai le,
\q1 muku mo olobo ma feu
\q2 i ta̱ a kuda̱sa̱ngu
\q2 a kakuba ko tsugono tsu nu ko wannai.>>
\q1 
\v 13 Adama a na Vuzavaguɗu
\q2 u zagba ta̱ Sihiyona,
\q2 u yaꞋin mali ma na wo okpo yi
\q2 ubuta̱ wi ida̱shi i ni.
\q1 
\v 14 U danai,
\q2 <<Na va kpaꞋa ku kuvuka ku va̱ ku ɗa ko wannai,
\q2 ta punu ma ku da̱sa̱ngu
\q2 adama a na mi ta̱ a mali ma ku ɗa.
\q1 
\v 15 Mi ta̱ a kuzuwaka Sihiyona una̱singai n ili ba̱ri
\q2 aza a unambi i ta̱ a̱ kucuwa̱ n ilikulyaꞋa.
\q1 
\v 16 Mi ta̱ a kuzuwa anan Ganu a̱ ni a dana,
\q2 mi ta̱ a ku wawa uma
\q2 uma a̱ va̱ kpamu i ta̱ a kucanana ishipa,
\q2 a̱ ɗa̱ngusa̱ a̱la̱ka̱tsu e le adama a̱ ma̱za̱nga̱.
\q1 
\v 17 Ta punu n kuzuwa vuza te
\q2 a̱ ka̱tsuma̱ ka ntsukaya n Dawuda
\q2 wo okpo mogono ma gbayin,
\q1 ta punu kpamu n kuzuwa tsugono tsu mazagbi
\q2 ci lyaꞋa kelime ko wannai.
\q1 
\v 18 Mi ta̱ a kuzuwa irala i ni yi okpo n wono,
\q2 ama tsugono ci ni ci ta̱
\q2 a kulyaꞋa kelime ci shamgba mayin.>>
\c 133
\d Ishipa i kugaɗukpa a kubana a̱ ubuta̱ wa̱ a̱ga̱nda̱. Vishipa vu Dawuda.
\q1 
\v 1 Mayun, ili i singai i ɗa m ma̱za̱nga̱ kpamu
\q2 uma a̱ da̱sa̱ngu koɓolo an vuza te.
\q1 
\v 2 Wi ta̱ an maniꞋin me kerengu ma singai,
\q2 ma na mi e kuyene a̱ kucipa̱
\q1 a gaɗi vu kaci ka Haruna
\q2 a̱ kuta̱wa̱ a̱ ntsa̱ka̱ n ni,
\q2 ali a kubana e kuɗeku ku motogu ma̱ ni.
\q1 
\v 3 Wi ta̱ an ciza tsu Hamon
\q2 tsu na ci e kuyene a̱ kucipa̱
\q2 a gaɗi vu kusan ku Sihiyona,
\q1 adama a na ta ɗe Vuzavaguɗu u yaꞋin
\q2 uzuwakpani wu una̱singai u ni,
\q2 wuma u ko wannai.
\c 134
\d Ishipa i kugaɗukpa a kubana a̱ ubuta̱ wa̱ a̱ga̱nda̱.
\q1 
\v 1 Cikpai Vuzavaguɗu,
\q2 a̱ɗa̱ agbashi Vuzavaguɗu ra̱ka̱,
\q2 a̱ɗa̱ na yi a kuyaꞋanka yi a̱ga̱nda̱
\q2 a kpaꞋa ku Vuzavaguɗu n kayin.
\q1 
\v 2 Ɗa̱ngusa̱i ekiye a̱ ɗa̱
\q2 a kubana a̱ ubuta̱ u ciɗa,
\q2 i cikpa Vuzavaguɗu.
\q1 
\v 3 YaꞋan Vuzavaguɗu
\q2 a̱yi na u yaꞋin gaɗi n iɗika
\q2 u zuwaka ɗa̱ una̱singai a Sihiyona.
\c 135
\q1 
\v 1 Cikpai Vuzavaguɗu,
\q2 cikpai kula ku Vuzavaguɗu,
\q2 cikpai ni, a̱ɗa̱ agbashi a Vuzavaguɗu,
\q1 
\v 2 a̱ɗa̱ na yi a̱ga̱nda̱ a kpaꞋa ku Vuzavaguɗu,
\q2 a ulanga u kpaꞋa ku Ka̱shile ka̱ tsu.
\q1 
\v 3 Cikpai Vuzavaguɗu,
\q2 adama a na Vuzavaguɗu
\q2 vuza kasingai ɗa.
\q1 Cananai vishipa adama a kula ku ni,
\q2 adama a na nannai va u gaꞋan ta̱.
\q1 
\v 4 Vuzavaguɗu u zagba ka ta̱ ka̱ci ka̱ ni Yakubu,
\q2 Isaraila tana wo okpo ta̱ upecu u singai u ni.
\q1 
\v 5 Adama a na n yeve ta̱
\q2 Vuzavaguɗu vuza gbayin ɗa,
\q2 Vuzavaguɗu vu tsu u laꞋa ta̱ a̱ma̱li dem.
\q1 
\v 6 Ili i na Vuzavaguɗu u cikalai dem
\q2 i ɗaɗa u ci yaꞋan,
\q2 ko ɗe gaɗi ko a iɗika,
\q2 punu a mala ko a ɗaka vu uga̱vi u mini dem.
\q1 
\v 7 A̱yi ɗa u tsu ɗa̱ngusa̱ eleshu a uteku wa aduniyan,
\q2 u tsu suku ta̱ kutashi m mini,
\q2 ka̱ta̱ wu utuka̱ n wunla̱i a̱ a̱nu a kuzuwa a̱ ni.
\q1 
\v 8 A̱yi ɗa wu unai muku mu ugiti mi iɗika i Masar,\x - \xo 135:8 \xt Kut 12:29-30\x*
\q2 muku mu ugiti n uma m mu nnama
\q1 
\v 9 U suki iyoci n ili i mereve
\q2 a̱ ka̱tsuma̱ ka̱ ɗa̱ a Masar
\q2 u FiriꞋauna n agbashi a̱ ni ra̱ka̱.
\q1 
\v 10 Wu unai uduniyan wa̱ a̱bunda̱i,
\q2 ɗa wu unai ngono m gbagbaꞋin.
\q1 
\v 11 Sihon mogono ma aza a Amoriya,
\q2 n Ogu, mogono ma Bashan
\q2 n tsugono tsu KanaꞋana ra̱ka̱,
\q1 
\v 12 ɗa u nekei iɗika i le tsu ili yu uka̱ni,
\q2 ili yu uka̱ni wa aza a Isaraila.
\q1 
\v 13 Vuzavaguɗu, kula ku nu ko wannai ɗa,
\q2 kula ku nu ili kuciɓa i ɗa
\q2 tsukaya a kubana a tsukaya.
\q1 
\v 14 Adama a na Vuzavaguɗu,
\q2 wi ta̱ o kuyotsongu uma a̱ ni
\q2 a na i n unushi ba,
\q2 ka̱ta̱ u sa̱Ꞌa̱ agbashi a̱ ni.
\q1 
\v 15 A̱ma̱li a uduniyan wa,
\q2 azurufa a ɗa n azanariya,
\q2 a na uma a yaꞋin n ekiye e le.\x - \xo 135:15 \xt Ishp 115:4-8; Ken 9:20\x*
\q1 
\v 16 I ta̱ n una̱, ama a tsu dansa ba,
\q2 i ta̱ n a̱shi, ama e ci ene ba.
\q1 
\v 17 I ta̱ n atsuvu, ama a tsu pana ba,
\q2 a ci yinvuka ba.
\q1 
\v 18 Aza a na a yaꞋin le i ta̱ o ko okpo ci le
\q2 aza a na e nekei katsura ke le we le,
\q2 i ta̱ o ko okpo ci le,
\q1 
\v 19 Cikpai Vuzavaguɗu kpaꞋa ki Isaraila,
\q2 cikpai Vuzavaguɗu kpaꞋa ku Haruna.
\q1 
\v 20 Cikpai Vuzavaguɗu kpaꞋa ku Levi,
\q2 a̱ɗa̱ na yi a kupana wovon u Vuzavaguɗu,
\q2 cikpai Vuzavaguɗu.
\q1 
\v 21 Una̱singai u ɗa u Vuzavaguɗu a Sihiyona
\q2 a̱yi na wi ida̱shi a Urishelima.
\q1 Cikpa Vuzavaguɗu.
\c 136
\s1 Ishipa i kucikpa Ka̱shile MalaꞋimili
\q1 
\v 1 Cikpai Vuzavaguɗu.
\q2 adama a na a̱yi vuza kasingai ɗa,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 2 Cikpai Ka̱shile
\q2 a̱yi na u laꞋi a̱ma̱li dem.
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 3 Cikpai Vuzavaguɗu,
\q2 a̱yi na u laꞋi a̱ma̱li dem,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 4 a̱yi ɗa koci u ci yaꞋan
\q2 ili i mereve i gbagbaꞋin,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 5 a̱yi na n kuyeve ku ni ɗa u yaꞋin gaɗi,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 6 a̱yi na u zuwai aduniyan
\q2 a gaɗi vu mini mu uga̱vi,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 7 a̱yi na u yaꞋin kutashi ku gbagbaꞋin,\x - \xo 136:7 \xt Ugi 1:16\x*
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 8 kanna adama a na ka lyaꞋa
\q2 tsugono tsu kanna,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 9 wotoi n azangata adama a na
\q2 a lyaꞋa tsugono tsu kayin,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 10 a̱yi ɗa wu unai muku mu ugiti ma aza a Masar,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 11 wu utuka̱i aza a Isaraila a̱ ka̱tsuma̱ ke le
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 12 n kukiye ku utsura n ili i mereve,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 13 a̱yi na u pecei mala ma shili ugboku ure,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 14 u tonoi n aza a Isaraila a walai e mere ma̱ ni,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 15 ama ɗa u niꞋwa̱ta̱ngi FiriꞋauna
\q2 n osoji a̱ ni a mala ma shili,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 16 a̱yi na u tonoi n uma a̱ ni e meremune,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 17 a̱yi na u lapai ngono m gbagbaꞋin,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 18 ɗa wu unai ngono m gbagbaꞋin,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 19 Sihon, mogono ma aza a Amoriya,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 20 n Ogu, mogono ma Bashan,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 21 U nekei iɗika i le ci iliyuka̱ni,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 22 iliyuka̱ni u kagbashi ka̱ ni Isaraila,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 23 a̱yi na u cinukpai n a̱tsu ba
\q2 a makyan ma na a lyaꞋi tsu.
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 24 Wi isai tsu e ekiye a Irala i tsu,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 25 a̱yi na u ci neke ili i wuma ra̱ka̱ ilikulyaꞋa,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\q1 
\v 26 Cikpai Ka̱shile ka gaɗi,
\qr \tl Ucigi u ni u na u tsu sabaꞋa ba wi ta̱ lo ko wannai.\tl*
\c 137
\s1 Ma̱shi ma aza a Isaraila a iɗika i tsugbashi
\q1 
\v 1 A̱kina̱ e nyeneke m Babila,
\q2 ta ɗe tsu da̱sa̱ngi ci shika̱i,
\q2 a na ci ciɓai n Sihiyona.
\q1 
\v 2 A gaɗi vu a nsaɓu a nɗanga,
\q2 ta ɗe tsu saɓangi omolu u tsu,
\q1 
\v 3 adama a na ta ɗe aza a na a̱ ka̱na̱i tsu,
\q2 a zuwai tsu ishipa,
\q2 a danai ci yaꞋan ka le ishipa.
\q1 Aza a na a tsu takacika tsu a danai,
\q2 ci yaꞋanka le ishipa i ma̱za̱nga̱,
\q2 a danai,<<YaꞋankai tsu vishipa
\q2 vi te a̱ ka̱tsa̱ma̱ ki ishipa i Sihiyona.>>
\q1 
\v 4 Nini ɗai tsa kucanana vishipa vu Vuzavaguɗu
\q2 a iɗika yo omoci?
\q1 
\v 5 N cinukpa baci n avu Urushelima,
\q2 yaꞋan kukiye ku usingai ku va̱
\q2 ku cinukpa n kufuɗa ku ni.
\q1 
\v 6 YaꞋan kelentsu ka̱ va̱ ka paɗa
\q2 a kalakpani ku una̱ u va̱,
\q2 ɗa baci n ciɓai n avu ba,
\q1 n ciga baci Urushelima
\q2 u laꞋi ili i na ya kuzuwa mu ma̱za̱nga̱ ba.
\q1 
\v 7 Vuzavaguɗu, ciɓa n unushi
\q2 wa aza a Edom
\q2 a kanna ka na Urishelima u yikpa̱i.
\q1 Orukpoi a danai,
\q2 <<A̱ fa̱da̱i, a̱ fa̱da̱i,
\q2 ali a kubana a̱ kumiꞋi ku ni.>>
\q1 
\v 8 Avu Babila,
\q2 iɗika i munuka.
\q2 Vuza vu una̱singai ɗa
\q2 vuza na u kuyaꞋanka wu,
\q2 tsu na vu yaꞋankai tsu.
\q1 
\v 9 Vuza vu una̱singai ɗa
\q2 a̱yi na wu isai nreɓu n nu
\q2 u ɓasangi le atali.
\c 138
\d Vishipa vu Dawuda.
\q1 
\v 1 Vuzavaguɗu, mi ta̱ a kucikpa wu,
\q2 n ka̱ɗu ka̱ va̱ dem,
\q2 mi ta̱ a kucanana vishipa
\q2 n cikpa wu e kelime ka̱ a̱ma̱li.
\q1 
\v 2 Mi ta̱ a̱ kuɗa̱ngu a ku inda A̱Ꞌisa̱ a gbayin a̱ nu,
\q1 n cikpa kula ku nu
\q2 adama ucigi u nu
\q2 u na u tsu sabaꞋa ba m ma̱riki ma̱ nu,
\q1 adama a na vu neke ta̱
\q2 kula ku nu n kadanshi ka̱ nu
\q2 tsugbayin a laꞋi ili dem.
\q1 
\v 3 Kanna ka na n ɗekei nu,
\q2 vu ushuku mu ta̱,
\q2 vu nekei mu utsura u ka̱ɗu n utsura.
\q1 
\v 4 Vuzavaguɗu, yaꞋan ngono ma aduniyan ra̱ka̱ n cikpa wu,
\q2 a makyan ma na a panai kadanshi ka̱ nu.
\q1 
\v 5 YaꞋan a canana ishipa
\q2 adama a uye u Vuzavaguɗu,
\q2 adama a na tsugbayin tsu Vuzavaguɗu
\q2 tsu gbangam tsu ɗa.
\q1 
\v 6 Ko a na wo okpoi Vuzavaguɗu wi ta̱ ɗe gaɗi,
\q2 u tsu zuwaka ta̱ aza a na o goyoi ka̱ci ke le,
\q2 ama u tsu yeve ta̱
\q2 aza a ugbamukaci e le daꞋin.
\q1 
\v 7 Ko ɗa baci mi a̱ ka̱tsuma̱ ka atakaci,
\q2 vi ta̱ e ku ere wuma u va̱.
\q1 vi shilika̱ n irala i va̱ i na yi a wupa nu mpa
\q2 vi tana a ku wawa mu n utsura u nu.
\q1 
\v 8 Vuzavaguɗu wi ta̱ a kushatangu kusheshe ku ni wa̱ a̱ va̱.
\q2 Vuzavaguɗu,
\q1 ucigi u nu u na u tsu sabaꞋa ba
\q2 wi ta̱ lo ko wannai.
\q2 Ka̱ta̱ vu ka̱sukpa̱ ulinga we ekiye a̱ nu ba.
\c 139
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda.
\q1 
\v 1 Vuzavaguɗu vu la̱na̱ mu ta̱,
\q2 kpamu vu yeve ta̱ ko mpa ɗa ya.
\q1 
\v 2 Vu yeve ta̱ makyan ma na n da̱sa̱ngi
\q2 m makyan ma na n ɗa̱nga̱i
\q2 vu tsu yeve ta̱ kusheshe ku va̱ avu daꞋin.
\q1 
\v 3 Vu tsu zuwaka ta̱ n nwalu n va̱ n ivaꞋin i va̱,
\q2 vu yeve ta̱ ili i na n ci yaꞋansa.
\q1 
\v 4 Vuzavaguɗu, kafu kadanshi ka̱ uta̱ una̱ u va̱,
\q2 vu yeve ta̱ ɗe kaꞋa dem.
\q1 
\v 5 Vu ka̱ra̱Ꞌa̱ mu ta̱ a̱ ubuta̱ dem,
\q2 vu zuwai kukiye ku una̱singai ku nu a kaci ka̱ va̱.
\q1 
\v 6 IcuꞋu i kuyeve ku nanlo adama a̱ va̱
\q2 ku laꞋa ta̱ utsura u kadanshi,
\q2 ku laꞋa ta̱ utsura u kuyeve ku va̱.
\q1 
\v 7 Teɗai n kubana n katsukpa ayinviki a̱ nu?
\q2 Teɗai n kusuma a kubana e kelime ka̱ nu?
\q1 
\v 8 N kumba baci gaɗi ta ɗe vi,
\q2 n vaku baci a̱ ubuta̱ wa̱ ukpisa̱ vi ta̱ ɗe.
\q1 
\v 9 N imkpa baci gaɗi tsu manunu
\q2 n lazai a uɓon u kasana,
\q2 ko m banai n telei a uɓon u ka̱livi,
\q1 
\v 10 ko ɗe va kukiye ku nu ki ta̱ o kutono nu mpa,
\q2 kukiye ku usingai ku nu ki ta̱ e kureme mu mayin.
\q1 
\v 11 Ishi baci mi a kufuɗa kudana ka̱yimbi ka pala mu,
\q2 ka̱ta̱ kutashi uka̱ra̱Ꞌi nu mpa ko okpo kayin,
\q1 
\v 12 ko ka̱yimbi feu ki o ko okpo ka̱yimbi wa̱ nu ba,
\q2 kayin ki ta̱ an kutashi ku kanna,
\q2 adama a na ka̱yimbi n kutashi ili i te i ɗa wa̱ nu.
\q1 
\v 13 Avu ɗa vu yaꞋin ili i ka̱tsuma̱ i va̱,
\q2 avu ɗa vu yaꞋin mu a̱ ka̱tsuma̱ ka̱ a̱na̱ku a̱ va̱.
\q1 
\v 14 N cikpa wu ta̱,
\q2 adama a tsu na vu yaꞋin mu,
\q2 ili wovon i ɗa n ili mereve.
\q1 Ulinga u nu ili i mereve i ɗa,
\q2 n yeve ta̱ n ka nanlo mayin.
\q1 
\v 15 Etele a ikyamba a̱ va̱,
\q2 i usokongi wa̱ a̱ nu ba,
\q1 ana a yaꞋin mu usokongi,
\q2 ana a yaꞋin mu a̱ ka̱yimbi.
\q1 
\v 16 Vu ene mu ta̱ kafu a matsa mu
\q2 ayin a na a zuwakai mu n kuyaꞋan,
\q1 i ta̱ uɗani a katagarda ka̱ nu,
\q2 kafu a̱ gita̱ kuyaꞋan vuza te a̱ ka̱tsuma̱ ke le.
\q1 
\v 17 Ka̱shile yiɗa̱i a kugisanku
\q2 n kusheshe ku singai ku nu wa̱ va̱.
\q2 n yiɗa̱i a kugisanku ka̱bunda̱i ke le.
\q1 
\v 18 Mi baci e kukece le,
\q2 i ta̱ a ku laꞋa kayala a̱bunda̱i.
\q2 ko ɗa baci n jimgbai,
\q2 mi ta̱ koɓolo n avu.
\q1 
\v 19 Ka̱shile, ishi baci va̱ a̱ ku ushuku vu una
\q2 aza a gbani-gbani ra̱ka̱,
\q2 ka̱sukpa̱i mu,
\q2 a̱ɗa̱ aza a munuka,
\q1 
\v 20 aza a na i a kadanshi ka gbani-gbani adama a̱ nu,
\q2 irala i nu i na yi a kadanshi ka gbani-gbani.
\q1 
\v 21 Vuzavaguɗu, n iwan aza a na a iwain nu ba,
\q2 mi kpamu e ke ne unata wa aza a na i a kuyaꞋanka wu ugbamukaci ba.
\q1 
\v 22 N iwan le ta̱ n ka̱ɗu ka̱ va̱ ra̱ka̱-ra̱ka̱.
\q2 irala i va̱ i ɗa n iɗika le.
\q1 
\v 23 Vuzavaguɗu, la̱na̱ mu vi ta̱ e kuyeve ka̱ɗu ka̱ va̱,
\q2 kondo mu vi ta̱ e kuyeve kusheshe ku va̱.
\q1 
\v 24 La̱na̱ ko mi ta̱ n unushi a wuma u va̱
\q2 ubuta̱ wi ta̱ lo una n nusakai nu,
\q2 ka̱ta̱ vu tono nu mpa a uye u ko wannai.
\c 140
\s1 Avasa a̱ kula̱nsa̱ wishi wa aza a gbani-gbani
\d Kadanshi a kubana u vuza vu kelime vi ishipa: Vishipa vu Dawuda.
\q1 
\v 1 Vuzavaguɗu,
\q2 uta̱ka̱ mu e ekiye a aza a gbani-gbani,
\q2 ere mu e ekiye a aza a na
\q2 a̱ ci ɗa̱ngusa̱ vishili,
\q1 
\v 2 aza a na a̱ɗu ele i tukpa n kusheshe ku gbani-gbani,
\q2 makyan dem a̱ kuɗa̱ngusa̱ vishili.
\q1 
\v 3 Elentsu ele an oko o tsukono,
\q1 kadanshi ka na ka tsu uta̱ una̱ u le
\q2 ki ta̱ an tsukono tsu kagbaji. \qs Kuvuka\qs*
\q1 
\v 4 Vuzavaguɗu uta̱ka̱ mu e ekiye aza a gbani-gbani,
\q2 ere mu e ekiye a aza a na a̱ ci ɗa̱ngusa̱ vishili,
\q2 aza a na o foɓusoi a varuku mu.
\q1 
\v 5 Aza a̱ra̱ɗi azuki mu ayakuru
\q2 a zuwakai mu maza a uye u le,
\q2 adama a na a̱ ka̱na̱ mu. \qs Kuvuka\qs*
\q1 
\v 6 Ɗa n danai, Vuzavaguɗu,
\q2 <<Avu ɗa Ka̱shile ka̱ va̱.>>
\q2 Pana ma̱shi ma̱ va̱, ma̱ kula̱nsa̱ uɓa̱nki,
\q2 Vuzavaguɗu.
\q1 
\v 7 Vuzavaguɗu Ka̱shile
\q2 kishi ka̱ va̱ ku utsura,
\q2 a̱yi na wu erei mu m ma̱ra̱ga̱ a kanna ko kuvon.
\q1 
\v 8 Vuzavaguɗu,
\q2 ka̱ta̱ vu neke aza a gbani-gbani
\q2 ili i na a cigai ba,
\q1 ka̱ta̱ vu ka̱sukpa̱ a̱ ciya̱ ulyaꞋi e kusheshe ku le ba,
\q2 ta lo a kuyaꞋan a̱ra̱ɗi. \qs Kuvuka\qs*
\q1 
\v 9 Ka̱ta̱ vu ka̱sukpa̱ irala i va̱ i ciya̱ ulyaꞋi ba,
\q2 yaꞋan ka gbani-gbani ka na
\q2 i a kuyaꞋanka mu ko bono a kaci ke le.
\q1 
\v 10 YaꞋan a̱ga̱ruwa̱shi akina
\q2 a̱ tsuwa̱nka̱ le aci,
\q1 yaꞋan a taɗuku le akina
\q2 punu e kpenle ku uga̱vi,
\q2 ka̱ta̱ o doku ku uta̱ ba.
\q1 
\v 11 Ka̱ta̱ aza a̱ kula̱nga̱su a̱ ciya̱
\q2 katsura a iɗika ya ba,
\q1 yaꞋan wunla̱i u gbani-gbani
\q2 u tamba aza a na a̱ ci ɗa̱ngusa̱ vishili.
\q1 
\v 12 N yeve ta̱ Vuzavaguɗu
\q2 wi ta̱ a̱ kuɓa̱nka̱ aza a unambi,
\q2 ka̱ta̱ kpamu u yaꞋanka aza a yali kasingai.
\q1 
\v 13 Mayun aza a̱ ma̱riki
\q2 i ta̱ a kucikpa kula ku nu,
\q2 ka̱ta̱ aza a ukuna u mayun a̱ɗu e le,
\q2 a̱ da̱sa̱ngu e kelime ka̱ nu.
\c 141
\d Vishipa vu Dawuda.
\q1 
\v 1 Vuzavaguɗu, n ɗeke wu ta̱,
\q2 ta̱wa̱ gogoꞋo vu ɓa̱nka̱ mu,
\q2 pana ka̱la̱ka̱tsu ka̱ va̱
\q2 a makyan ma na baci n yaꞋin meɗevile.
\q1 
\v 2 YaꞋan avasa a̱ va̱ okpo
\q2 ci ili i ma̱gula̱ni wa̱ nu,
\q2 uɗa̱ngushi we ekiye u va̱ tsa alyuka a̱ kulivi.
\q1 
\v 3 Vuzavaguɗu, zuwa mu n ka̱na̱ una̱ u va̱,
\q2 vu la̱na̱ nla̱ba̱ mu una̱ n va̱.
\q1 
\v 4 Ka̱ta̱ vu ka̱sukpa̱ ka̱ɗu ka̱ va̱ ka yaꞋan mali,
\q2 ma ka gbani-gbani ba,
\q2 ko n gbaɓa kaci a ka gbani-gbani ke le ba
\q1 vu zuwa mu n yongo n ele a̱ ka̱ɗiva̱ ke le ba.
\q1 
\v 5 YaꞋan vuza vu usuɓi u ɓarangu mu,
\q2 u dansuka mu n kasingai,
\q2 wi ta̱ o ku okpo mu a danshi a putala ta̱ maniꞋin a kaci ka̱ va̱,
\q2 adama a na makyan dem mi ta̱ avasa
\q2 adama a ka gbani-gbani.
\q1 
\v 6 A ayin a na baci a ɓasangi
\q2 azafada e le a katali,
\q2 uma a gbani-gbani i ta̱ e kuyeve
\q2 a na kadanshi ka̱ va̱ mayun ɗa.
\q1 
\v 7 Tsu katali ka na vuma u ɓosoi,
\q2 ɗa u wacuwai kaꞋa a iɗika,
\q2 ta a̱ kutsuwa̱n etele e le,
\q2 nannai a̱ una̱ u kasaun.
\q1 
\v 8 Ama n zuwa ta̱ a̱shi a̱ va̱ wa̱ nu,
\q2 Vuzavaguɗu MalaꞋimili,
\q2 wa̱ nu ɗa n la̱nsa̱i ubuta̱ u kusheɗeku,
\q2 ka̱ta̱ vu ka̱sukpa̱ mu n takacika ba.
\q1 
\v 9 Ere mu a maza ma na a zuwakai mu,
\q2 a maza ma na aza a gbani-gbani azuki.
\q1 
\v 10 Zuwa uma a gbani-gbani a̱ yikpa̱ a maza me le,
\q2 ama yaꞋan mpa n wala m ma̱ta̱na̱.
\c 142
\d VicuꞋu vu tsuwaꞋi tsu Dawuda. Avasa a Dawuda a makyan ma na wi a kaɓatsu.
\q1 
\v 1 Vuzavaguɗu, wa̱ nu ɗa n shika̱i ka̱u,
\q2 n ɗa̱ngusa̱i ka̱la̱ka̱tsu ka̱ va̱
\q2 u Vuzavaguɗu u pana asuvayali a̱ va̱.
\q1 
\v 2 M banka ta̱ m mavura ma̱ va̱ wa̱ ni ra̱ka̱,
\q2 n danai ni atakaci a̱ va̱.
\q1 
\v 3 Ana utsura u va̱ u kotsoi,
\q2 avu ɗa vu yevei uye u va̱.
\q1 A uye u na mi a nwalu,
\q2 irala i va̱ i zuwakai mu maza usokongi.
\q1 
\v 4 La̱na̱ku usingai u va̱ ka̱ta̱ vu ene,
\q2 ko vuza u zuwaka nu mpa ba.
\q2 mi n ubuta̱ u kusheɗeku ba,
\q2 ko vuza u la̱na̱ mu ba.
\q1 
\v 5 Vuzavaguɗu, n shika̱ ta̱ wa̱ nu,
\q2 n danai, <<Avu ɗa ubuta̱ u kusheɗeku u va̱,
\q2 upecu u va̱ a iɗika ya aza a wuma.>>
\q1 
\v 6 Pana ma̱shi ma̱ va̱,
\q2 adama a na mi ta̱ a kutakpa asuvu.
\q1 Isa mu ekiye aza a na i a kutakacika mu,
\q2 adama a na a laꞋa mu ta̱ utsura.
\q1 
\v 7 Uta̱ka̱ mu a̱ kunu ku ugbashi,
\q2 adama a na n cikpa kula ku nu.
\q1 Aza a usuɓi i ta̱ a̱ kuka̱ra̱Ꞌa̱ mu
\q2 adama a na vi ta̱ a kuyaꞋanka mu kasingai ka̱u.
\c 143
\d Vishipa vu Dawuda.
\q1 
\v 1 Vuzavaguɗu, pana avasa a̱ va̱,
\q2 pana ma̱shi ma asuvayali a̱ va̱,
\q2 avu vuza vu usuɓi ɗa n vuza vu ma̱riki,
\q2 adama a nannai ushuku mu.
\q1 
\v 2 Ka̱ta̱ vu yaꞋanka kagbashi ka̱ nu afada ba,
\q2 adama a na ko vuza
\q2 wi lo babu u nushi wa̱ nu ba.
\q1 
\v 3 Vurala vu va̱
\q2 vu guva mu ta̱,
\q2 u ɓasangi mu a iɗika,
\q1 u zuwai mu ida̱shi a̱ ka̱yimbi,
\q2 tsa aza a na a̱ kuwa̱i ɗe m megeshe.
\q1 
\v 4 Adama a nannai mi ta̱
\q2 a ukuna u kutakpa ka̱ɗu,
\q2 mi ta̱ a una̱mgbuka̱tsuma̱ ka̱u.
\q1 
\v 5 N ciɓa ta̱ n ayin a cau,
\q2 n ka̱na̱i kusheshe a ili i na vu yaꞋin ra̱ka̱,
\q2 n ciɓa ta̱ n ulinga we ekiye u nu ra̱ka̱.
\q1 
\v 6 N ɗa̱ngusa̱ ta̱ ekiye a̱ va̱
\q2 wa̱ nu a kavasa,
\q2 mi ta̱ a kakuli ka̱ nu ci iɗika i na i cigai mini. \qs Kuvuka\qs*
\q1 
\v 7 Vuzavaguɗu, ushuku mu gogoꞋo,
\q2 mi ta̱ ɗevu n kutakpa asuvu,
\q2 ka̱ta̱ vu sokongu mu a̱shi a̱ nu ba,
\q2 ka̱ ta̱ mo okpo a na aza na a̱ kuwa̱i ɗe ba.
\q1 
\v 8 Zuwa mu n ciɓa n
\q2 ucigi u nu u na u tsu sabaꞋa ba
\q2 adama a na n zuwa ta̱ katsura wa̱ nu.
\q1 Yotsongu mu uye u na n kutono
\q2 n neke ta̱ wuma u va̱ wa̱ nu.
\q1 
\v 9 Vuzavaguɗu, isa mu ekiye a irala i va̱,
\q2 n ta̱wa̱ ta̱ wa̱ nu kula̱nsa̱ ubuta̱ sheɗeku.
\q1 
\v 10 PiꞋisaka mu n tono kusheshe ku nu,
\q2 yaꞋan ayinviki a singai a̱ nu
\q2 o tono nu mpa,
\q2 a uye u na wi n a̱ga̱vushi ba.
\q1 
\v 11 Vuzavaguɗu, adama a kula ku nu
\q2 ere wuma u va̱,
\q1 a ukuna wu usuɓi nu
\q2 utuka̱ wuma u va̱ atakaci.
\q1 
\v 12 Adama a ucigi u nu
\q2 u na u tsu sabaꞋa ba
\q2 una irala i va̱ ra̱ka̱,
\q2 adama a na mpa kagbashi ka̱ nu ka a.
\c 144
\d Vishipa vu Dawuda.
\q1 
\v 1 Ucikpi u Vuzavaguɗu a̱yi na wi
\q2 katali ke kusheɗeku ka̱ va̱
\q2 u piꞋisaka mu ta̱ vishili
\q2 ɗa u foɓusoi mu adama o kuvon,
\q1 
\v 2 a̱yi ɗa Ka̱shile macigi ma̱ va̱ n ke ere ka̱ va̱
\q2 mashilya ma̱ va̱ n kawawi ka̱ va̱,
\q2 ma̱ra̱ga̱ ma̱ va̱ ma na
\q2 mi a̱ kula̱nsa̱ ubuta̱ u kusheɗeku wa̱ ni,
\q2 a̱yi ɗa u zuwai uduniyan o tsugono tsu va̱.
\q1 
\v 3 Vuzavaguɗu, yayi vuma
\q2 ali ɗa vi a̱ kula̱na̱ yi?
\q2 Maku ma vuma, ali ɗa vi e kusheshe adama a̱ ni?
\q1 
\v 4 Vuma wi ta̱ tsu ayinviki
\q2 ayin a̱ ni a kulaza tsu kulu.
\q1 
\v 5 Vuzavaguɗu ɓa̱yuwa̱ gaɗi ka̱ta̱ vu cipa̱,
\q2 saꞋawa nsansa i ta̱ a kuyaꞋan ka̱nga̱.
\q1 
\v 6 Zuwa kutashi ku ulaɗi u nu
\q2 ku wacuwa irala i nu,
\q2 taku ayaꞋa a̱ nu vu zuwa le a wacuwa n ilaɗi.
\q1 
\v 7 Ba̱rukpa̱ kukiye ku nu ɗe gaɗi,
\q2 vu uta̱ka̱ mu a̱ mini u uga̱vi,
\q2 vu isa mu e ekiye omoci.
\q1 
\v 8 Aza a na una̱ u le
\q2 u tsu dansa ukuna u mayun ba,
\q2 a ci yaꞋan ta̱ akucina aꞋuwa.
\v 9 Ka̱shile ka̱ va̱ mi ta̱
\q2 a kucanana vishipa vu savu wa̱ nu,
\q2 n umolu u aꞋin kupa,
\q2 mi ta̱ a kucanana ka wu ishipa i kucikpa,
\q1 
\v 10 avu na vu ci neke ngono ulyaꞋi,
\q2 vuza na u wawai kagbashi ka̱ ni Dawuda.
\q2 o kotokobi ka munuka.
\q1 
\v 11 Uta̱ka̱ mu, vi isa mu
\q2 e ekiye o omoci,
\q2 ele na a ci yaꞋan kucina aꞋuwa.
\q1 
\v 12 Zuwa muku mo olobo n tsu
\q2 okpo tsu nɗanga n na
\q2 mi o kugbonguro gogoꞋo lo,
\q1 muku mu nkere n tsu mo okpo
\q2 tsa ashamkpatsu a na a yaꞋin
\q2 adama e kefeku ko mogono,
\q1 
\v 13 Zuwa mpon n tsu n shana,
\q2 n ili ya ashina ra̱ka̱.
\q1 Zuwa nkyon n tsu n yimkpa,
\q2 ushiga a̱ a̱kpa̱n-a̱kpa̱n a shana,
\q2 a̱ ubuta̱ u kaguɓa u tsu.
\q1 
\v 14 Zuwa anaka a̱ tsu a matsa n a̱bunda̱i,
\q2 ka̱ta̱ a̱tsuma̱ a̱ tsuwa̱n le ko a̱ puwa̱nka̱ ba,
\q2 ka̱ta̱ a pana ma̱shi ma̱
\q2 una̱mgbuka̱tsuma̱ wa̱ tsu ba.
\q1 
\v 15 Aza a una̱singai a ɗa
\q2 ele na a̱ ciya̱i ka nampa ka
\q2 aza a una̱singai a ɗa uma a na Ka̱shile ke le kaꞋa Vuzavaguɗu.
\c 145
\d Vishipa vu kucikpa vu Dawuda.
\q1 
\v 1 Ka̱shile ka̱ va̱ mogono mi ta̱ a kucikpa tsugbayin tsu nu,
\q2 mi ta̱ a kucikpa kula ku nu ko wannai.
\q1 
\v 2 Kanna lakam mi ta̱ a kucikpa wu,
\q2 ka̱ta̱ n cikpa kula ku nu ko wannai.
\q1 
\v 3 Vuzavaguɗu vuzagbayin ɗa,
\q2 mayun ɗa u yotsoi a cikpa yi,
\q2 tsugbayin ci ni tsu laꞋa ta̱ utsura u kuyeve.
\q1 
\v 4 Tsukaya a kubana a tsukaya
\q2 i ta̱ a kucikpa ili i na vi yaꞋin,
\q2 ka̱ta̱ a dansa ili i gbagbaꞋin i na vi yaꞋin.
\q1 
\v 5 Uma i ta̱ a kudansa ukuna
\q2 wu ucikpi u tsugbayin tsu nu,
\q2 mpa kpamu mi ta̱ e kusheshe a ukuna
\q2 wi ili i mereve i na vi yaꞋin.
\q1 
\v 6 I ta̱ a kudansa ukuna wu ulinga u gbagbaꞋin u nu,
\q2 mi ta̱ kpamu e kuneke arabali a tsugbayin tsu nu.
\q1 
\v 7 I ta̱ a kudansa ukuna u tsugbayin
\q2 n kasingai ka̱ nu ra̱ka̱,
\q2 ka̱ta̱ a canana ishipa a ukuna wu usuɓi u nu.
\q1 
\v 8 Vuzavaguɗu vuza kasingai ɗa,
\q2 vuza va asuvayali,
\q2 u ci yaꞋan wupa gogoꞋo ba,
\q2 n ucigi u na u tsu sabaꞋa ba.
\q1 
\v 9 Vuzavaguɗu vuza kasingai ɗa a uma ra̱ka̱,
\q2 u tsu sa̱Ꞌa̱ ta̱ ili i na u yaꞋin ra̱ka̱.
\q1 
\v 10 Vuzavaguɗu, ili i na vu yaꞋin ra̱ka̱
\q2 yi ta̱ a kucikpa wu,
\q2 uma a̱ nu kpamu ra̱ka̱ i ta̱ a kucikpa wu.
\q1 
\v 11 I ta̱ a kusala tsugbayin tsu tsugono tsu nu.
\q2 ka̱ta̱ a dansa ukuna wu utsura u nu,
\q1 
\v 12 adama a na muku n vuma ra̱ka̱
\q2 e yeve ulinga ugbayin u nu,
\q2 n ucikpi u tsugbayin u tsugono tsu nu.
\q1 
\v 13 Tsugono tsu nu tsu ko wannai tsu ɗa,
\q2 avu mogono maꞋa tsukaya a kubana a tsukaya.
\q1 
\v 14 Vuzavaguɗu, u tsu keɗe ta̱ aza a na i a̱ kuyikpa̱,
\q2 u tsu ɗa̱ngusa̱ ta̱ aza a na a̱ yikpa̱i.
\q1 
\v 15 A̱shi a uma ra̱ka̱ i ta̱ wa̱ nu,
\q2 vu ci neke le ta̱ ilikulyaꞋa
\q2 a makyan ma na ma untsai.
\q1 
\v 16 Vu tsu neke le ta̱ ili n a̱bunda̱i,
\q2 ili i na a cigai dem.
\q1 
\v 17 Vuzavaguɗu vuza vu usuɓi ɗa
\q2 a̱ uye u ni ra̱ka̱,
\q2 vuza vu ma̱riki kpamu a̱ ka̱tsuma̱ ka ulinga u ni ra̱ka̱.
\q1 
\v 18 Vuzavaguɗu wi ta̱ ɗevu n aza a na e ɗekei ni,
\q2 aza a na e ɗekei ni n ka̱ɗu n ke te.
\q1 
\v 19 U tsu neke ta̱ aza a na
\q2 i a kupana wovon u ni ili i na a cigai ra̱ka̱,
\q2 u tsu pana ta̱ ma̱shi me le, ka̱ta̱ u wawa le.
\q1 
\v 20 Vuzavaguɗu u tsu ere ta̱ aza a na a cigai ni ra̱ka̱,
\q2 ama u tsu una ta̱ aza a gbani-gbani ra̱ka̱.
\q1 
\v 21 Vuzavaguɗu, ayin tutu mi ta̱ a kucikpa wu
\q2 yaꞋan uma ra̱ka̱ a cikpa kula ku ciɗa ku ni ko wannai.
\c 146
\q1 
\v 1 Cikpa Vuzavaguɗu,
\q2 cikpa Vuzavaguɗu, wuma u va̱.
\q1 
\v 2 Mi ta̱ a ku cikpa Vuzavaguɗu ayin a wuma u va̱ ra̱ka̱,
\q2 Mi ta̱ a kucanana vishipa
\q2 vu kucikpa Ka̱shile ka̱ va̱ ali mi baci n wuma.
\q1 
\v 3 Ka̱ta̱ vu zuwa katsura,
\q2 wa aza o tsugono ba,
\q2 ko u vuma vuza,
\q2 wi a kufuɗa ku wawa wu ba.
\q1 
\v 4 Ayin ana baci a̱ kuwa̱i
\q2 ka̱ta̱ o bono a iɗika,
\q2 kusheshe ku le ko okpo ta̱
\q2 ili i gbani a kanna ka nanlo.
\q1 
\v 5 Vuza vu una̱singai ɗa vuza na
\q2 Ka̱shile ka Yakubu kaꞋa ka̱ɓa̱nki ka̱ ni,
\q2 vuza na u keɗei a̱pa̱Ꞌa̱
\q2 u Vuzavaguɗu Ka̱shile ka̱ ni.
\q1 
\v 6 Vuza na u yaꞋin gaɗi n aduniyan,
\q2 n kuyene n ili i na yi punu dem,
\q2 a̱yi na u tsu ka̱na̱ ma̱riki ma̱ ni ko wannai.
\q1 
\v 7 U tsu kiɗa ta̱ afada e mejege wa aza a na o doroi,
\q2 u ci neke ta̱ ilikulyaꞋa wa aza a kambulu,
\q2 Vuzavaguɗu u tsu uta̱ka̱ ta̱ aza a ugbashi.
\q1 
\v 8 Vuzavaguɗu u tsu zuwa ta̱ a̱yimba̱ ene,
\q2 Vuzavaguɗu u tsu ɗa̱ngusa̱ ta̱ aza a na o doroi,
\q2 Vuzavaguɗu wi ta̱ a kuciga aza a usuɓi.
\q1 
\v 9 Vuzavaguɗu u tsu ere ta̱ omoci
\q2 u tsu la̱na̱ ta̱ mkpaꞋan n agapa a̱ma̱ci,
\q2 ama u tsu la̱nga̱sa̱ ta̱
\q2 ukuna wa aza a gbani-gbani.
\q1 
\v 10 Vuzavaguɗu wi ta̱ a kulyaꞋa tsugono ko wannai,
\q2 Avu Sihiyona, Ka̱shile ka̱ nu ki ta̱ a kulyaꞋa tsugono
\q2 tsukaya a kubana a tsukaya.
\q1 Cikpai Vuzavaguɗu.
\c 147
\q1 
\v 1 Cikpai Vuzavaguɗu,
\q2 adama a na u gaꞋan ta̱ a canana,
\q2 vishipa vu ucikpi u Ka̱shile ka̱ tsu,
\q2 ili i uyoꞋo i ɗa kpamu derere ɗa a cikpa yi.
\q1 
\v 2 Vuzavaguɗu ɗa u maꞋi Urushelima,
\q2 ɗa u ɓolongi aza a Isaraila a na
\q2 ishi a tsugbashi a iɗika i yoku,
\q1 
\v 3 U tsu neke ta̱ kadanshi wa aza a na a takpai a̱ɗu,
\q2 tsa aza na i n untsu ka̱ta̱ a shiya le.
\q1 
\v 4 U tsu kece ta̱ ka̱bunda̱i ka azangata,
\q2 u tsu ɗeke le ta̱ n ula ra̱ka̱.
\q1 
\v 5 Vuzavaguɗu vu tsu vuza gbayin ɗa,
\q2 vuza vu utsura ɗa,
\q2 kuyeve ku ni ki kugisanku ba.
\q1 
\v 6 U tsu ɗa̱ngusa̱ ta̱ aza a na o doroi,
\q2 ama u tsu cipa̱ka̱ ta̱ aza a gbani-gbani a iɗika.
\q1 
\v 7 Cananai vishipa vu kuneke ucikpi u Vuzavaguɗu,
\q2 cikpai Ka̱shile ka̱ tsu n umolu.
\q1 
\v 8 U pala ta̱ gaɗi n eleshu,
\q2 u yoꞋokoi iɗika mini,
\q2 ɗa kpamu u zuwai mita̱,
\q2 mo gbonguroi a kaginda.
\q1 
\v 9 U tsu neke ta̱ nnama ijanu i le,
\q2 m muku ma agawun a makyan ma na a̱ shika̱i.
\q1 
\v 10 U tsu zuwa katsura wo odoku a utsura ba,
\q2 ko u yaꞋan ma̱za̱nga̱ n utsura u vuma.
\q1 
\v 11 Vuzavaguɗu u tsu pana ta̱ u yoꞋo
\q2 wa aza na i a kupana wovon u ni,
\q2 aza a na e keɗei a̱pa̱Ꞌa̱ e le,
\q2 a ucigi u ni u na u tsu sabaꞋa ba.
\q1 
\v 12 Cikpa Vuzavaguɗu, avu Urishelima,
\q2 cikpa Ka̱shile ka̱ nu, avu Sihiyona.
\q1 
\v 13 A̱yi ɗa wi a ku inda utsutsu u nu mayin,
\q2 u tsu zuwaka ta̱ uma a na i punu una̱singai.
\q1 
\v 14 U tsu zuwa ta̱ kureꞋe ki iɗika i nu,
\q2 kuyongo m ma̱ta̱na̱,
\q2 u tsu lyaꞋatangu wu ta̱ n alkama vu singai.
\q1 
\v 15 U tsu suku ta̱ n kadanshi ka̱ ni aduniyan,
\q2 gogoꞋo lo ɗa kadanshi ka̱ ni ka tsu
\q2 bana a̱ ubuta̱ u na a̱ suki kaꞋa.
\q1 
\v 16 U tsu suku ta̱ egele a pala iɗika tsu tsugbere tsu a̱ri,
\q2 u tsu vishangu ta̱ a ɗa an kokomo.
\q1 
\v 17 U tsu suku ta̱ m mini ma atali,
\q2 tsu atali a wawaꞋa,
\q2 yayi u kufuɗa kugbama asuvu n uta̱ni u ni.
\q1 
\v 18 Utsu neke ta̱ kpamu kadanshi,
\q2 ka̱ta̱ atali a, a̱ niꞋwa̱n
\q2 utsu suku ta̱ n wunla̱i, ka̱ta̱ mini me yene.
\q1 
\v 19 U tsu suku ta̱ n kadanshi ka̱ ni u Yakubu,
\q2 u tsu yotsongu ta̱ ili i kutono i ni
\q2 n afada a̱ ni wa aza a Isaraila.
\q1 
\v 20 U yaꞋanka uduniyan u yoku ili i nanlo ba,
\q2 adama a na e yeve wila̱ u ni ba.
\q1 Cikpai Vuzavaguɗu.
\c 148
\s1 YaꞋan ili i na Ka̱shile ka yaꞋin i cikpa yi
\q1 
\v 1 Cikpai Vuzavaguɗu!
\q2 Cikpai Vuzavaguɗu na ɗe gaɗi,
\q2 cikpai ni a̱ɗa̱ na yi ɗe a̱da̱nga̱shile.
\q1 
\v 2 Cikpai ni a̱ɗa̱ alingata a̱ ni,
\q2 cikpai ni ili i wuma i gaɗi.
\q1 
\v 3 Cikpai ni, kanna n wotoi,
\q2 cikpai ni a̱ɗa̱ azangata a kutashi ra̱ka̱.
\q1 
\v 4 Cikpai ni, a̱ɗa̱ gaɗi a̱da̱nga̱shile,
\q2 Cikpai ni, a̱ɗa̱ mini ma gaɗi a̱da̱nga̱shile.
\q1 
\v 5 YaꞋan a cikpa kula ku Vuzavaguɗu,
\q2 tsu na u dansai, ta ka yaꞋin nannai.
\q1 
\v 6 N kadanshi ka̱ ni ɗa a zuwai le,
\q2 a̱ ubuta̱ u le ko wannai,
\q2 u nekei le kadanshi ka na,
\q2 ka̱ kupuwa̱nka̱ ba.
\q1 
\v 7 Cikpai Vuzavaguɗu a aduniyan,
\q2 a̱ɗa̱ oroꞋo a mala n ili i na yi,
\q2 a mala mu uga̱vi,
\q1 
\v 8 ulaɗi, m mini ma atali,
\q2 egele n eleshu, n wunla̱i wu utsura,
\q2 u na wi o kutono kadanshi ka̱ ni,
\q1 
\v 9 nsasan n aginda,
\q2 nɗanga mu umaci nu nɗanga n sida ra̱ka̱,
\q1 
\v 10 nnama n kakamba nu m kpaꞋa,
\q2 ili i wuma i na yi o kurono a̱tsuma̱ nu nnunu,
\q1 
\v 11 ngono ma aduniyan n uduniyan ra̱ka̱,
\q2 a̱ɗa̱ nkoshi m gba̱ra̱-gba̱ra̱,
\q2 n aza afada aduniyan ra̱ka̱,
\q1 
\v 12 muku mo olobo nu nkere n a̱ma̱ci,
\q2 nkoshi m muku.
\q1 
\v 13 YaꞋan ra̱ka̱ vule a cikpa kula ku Vuzavaguɗu,
\q2 adama a na kula ku ni ku ɗa koci ku ciya̱i ucikpi.
\q2 tsugbayin ci ni tsu laꞋa ta̱ tsa aduniyan n tsu gaɗi.
\q1 
\v 14 U zuwai mogono ma utsura adama a uma a̱ ni,
\q2 adama a na uma a na i a kuciga yi ra̱ka̱ a cikpa yi,
\q2 uma Isaraila, aza a na i ɗevu n a̱yi.
\q1 Cikpai Vuzavaguɗu.
\c 149
\q1 
\v 1 Cikpai Vuzavaguɗu, cananai vishipa vu savu u Vuzavaguɗu,
\q2 cikpai ni o koɓolo ka uma a̱ ma̱riki.
\q1 
\v 2 YaꞋan aza Isaraila a yaꞋan ma̱za̱nga̱,
\q2 n vuza na u yaꞋin le,
\q2 yaꞋan aza a Sihiyona a yaꞋan
\q2 ma̱za̱nga̱ m mogono me le.
\q1 
\v 3 YaꞋan a cikpa kula ku ni n kujeꞋe,
\q2 a waꞋa umolu m medelemishipa,
\q1 
\v 4 Vuzavaguɗu wi ta̱ a kupana uyoꞋo u uma a̱ ni,
\q2 u ci neke ta̱ aza a na o goyoi ka̱ci ke le,
\q2 tsugbayin n ulyaꞋi.
\q1 
\v 5 YaꞋan uma a̱ ma̱riki,
\q2 a yaꞋan ma̱za̱nga̱ adama a tsugbayin
\q2 tsu na u nekei le,
\q2 a canana vishipa vu ma̱zanga̱ a iꞋuwa i le.
\q1 
\v 6 YaꞋan ucikpi u Ka̱shile u yongo a̱ una̱ u le,
\q2 n kotokobi ka una̱ ure ekiye e le,
\q1 
\v 7 adama a na a tsupa ili i na,
\q2 uduniyan u yaꞋankai le,
\q2 ka̱ta̱ kpamu a takacika uma,
\q1 
\v 8 ka̱ta̱ a shiya ngono n ikani,
\q2 aza a gbagbaꞋin e le n ikani yi iyum,
\q1 
\v 9 adama a na a yaꞋan afada tsu na wi uɗani.
\q2 Na ɗa tsugbayin tsu uma a̱ ma̱riki a̱ ni.
\q1 Cikpai Vuzavaguɗu.
\c 150
\q1 
\v 1 Cikpai Vuzavaguɗu!
\q2 Cikpai Ka̱shile a̱ ubuta̱ u ciɗa u ni,
\q2 cikpai utsura u ni ɗe gaɗi, a̱ ubuta̱ wi ida̱shi i ni.
\q1 
\v 2 Cikpai ni adama
\q2 a ili i gbagbaꞋin i na u yaꞋin,
\q2 cikpai ni adama a tsugbayin tsa̱ a̱bunda̱i ci ni.
\q1 
\v 3 Cikpai ni n ciliki ci ishari,
\q2 cikpai ni n ugogi n umolu.
\q1 
\v 4 Cikpai ni n agundari n kujeꞋe,
\q2 cikpai ni n aꞋin a umolu n igbala.
\q1 
\v 5 Cikpai ni n ka̱la̱ka̱tsu ka̱ ma̱ka̱nla̱,
\q2 cikpai ni nu nka̱nla̱ m mashi ka̱u.
\q1 
\v 6 YaꞋan ili ya ayinviki ra̱ka̱ i cikpa Vuzavaguɗu.
\q1 Cikpai Vuzavaguɗu.
