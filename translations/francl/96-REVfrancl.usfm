\v 1 \w Après|strong="G3326"\w* \w cela|strong="G2532"\w*, \w j|strong="G1473"\w*’\w entendis|strong="G2532"\w* \w dans|strong="G1722"\w* \w le|strong="G2532"\w* \w ciel|strong="G3772"\w* \w comme|strong="G5613"\w* \w une|strong="G2532"\w* \w grande|strong="G3173"\w* \w voix|strong="G5456"\w* \w d|strong="G1722"\w*’\w une|strong="G2532"\w* \w foule|strong="G3793"\w* immense \w qui|strong="G3588"\w* \w disait|strong="G3004"\w* : « Alléluia ! \w Le|strong="G2532"\w* \w salut|strong="G4991"\w*, \w la|strong="G2532"\w* \w gloire|strong="G1391"\w* \w et|strong="G2532"\w* \w la|strong="G2532"\w* \w puissance|strong="G1411"\w* \w appartiennent|strong="G3588"\w* \w à|strong="G1722"\w* \w notre|strong="G2532"\w* \w Dieu|strong="G2316"\w*,  
