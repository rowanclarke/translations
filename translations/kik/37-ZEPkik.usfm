\id ZEP - Biblica® Open Kikuyu Holy Word of God 
\h Zefania 
\toc1 Zefania 
\toc2 Zefania 
\toc3 Zef 
\mt1 ZEFANIA 
\c 1  
\p  
\v 1 Atĩrĩrĩ, ĩno nĩyo ndũmĩrĩri ya Jehova ĩrĩa yakinyĩrĩire Zefania mũrũ wa Kushi, mũrũ wa Gedalia, mũrũ wa Amaria, mũrũ wa Hezekia, rĩrĩa Mũthamaki Josia mũrũ wa Amoni aathamakaga Juda. 
\s1 Juda Gũtuĩrwo Ciira 
\q1  
\v 2 Atĩrĩrĩ, Jehova ekuuga ũũ: 
\q2 “Nĩnganiina indo ciothe ithire biũ, 
\q2 ithire kũndũ guothe gũkũ thĩ. 
\q1  
\v 3 Nĩnganiina andũ o na nyamũ; 
\q2 njooke niine nyoni cia rĩera-inĩ, 
\q2 na thamaki cia iria-inĩ. 
\q1 Andũ arĩa aaganu magaatigĩrio o hĩba cia mahuti, 
\q2 hĩndĩ ĩrĩa ngaaniina andũ mathire kũndũ guothe gũkũ thĩ,” 
\q4 ũguo nĩguo Jehova ekuuga. 
\b  
\q1  
\v 4 “Nĩngatambũrũkia guoko gwakwa njũkĩrĩre Juda, 
\q2 na njũkĩrĩre andũ othe arĩa matũũraga Jerusalemu. 
\q1 Nĩnganiina mĩhianano ya Baali ĩrĩa ĩtigarĩte gũkũ, 
\q2 na niine marĩĩtwa ma andũ arĩa matooĩ Ngai, 
\q2 na athĩnjĩri-ngai cia mĩhianano, 
\q1  
\v 5 o acio mainamagĩrĩra, 
\q2 makahooya mbũtũ cia igũrũ marĩ nyũmba igũrũ, 
\q1 o na makainamĩrĩra, makehĩta na rĩĩtwa rĩa Jehova, 
\q2 na magacooka makehĩta na rĩĩtwa rĩa Milikomu, 
\q1  
\v 6 o acio matigaga kũrũmĩrĩra Jehova magacooka na thuutha, 
\q2 na maticaragia Jehova, o na kana makamũrongooria. 
\q1  
\v 7 Atĩrĩrĩ, kirai ki mũrĩ mbere ya Mwathani Jehova, 
\q2 nĩgũkorwo mũthenya wa Jehova ũrĩ hakuhĩ. 
\q1 Jehova nĩahaarĩirie igongona; 
\q2 ningĩ nĩamũrĩte andũ arĩa etĩte. 
\q1  
\v 8 Mũthenya ũcio wa igongona rĩa Jehova-rĩ, 
\q2 nĩngaherithia anene, o na herithie ariũ a mũthamaki, 
\q2 hamwe na arĩa othe magaakorwo mehumbĩte nguo cia bũrũri ũngĩ. 
\q1  
\v 9 Mũthenya ũcio-rĩ, nĩngaherithia ataagarari othe a hingĩro, 
\q2 o acio maiyũragia hekarũ ya ngai ciao na haaro na maheeni.” 
\b  
\q1  
\v 10 Jehova ekuuga atĩrĩ, “Mũthenya ũcio 
\q2 nĩgũkaiguuo mũkayo uumĩte Kĩhingo-inĩ gĩa Thamaki, 
\q2 o na kũgirĩka kuumĩte Itũũra Rĩerũ, 
\q2 naguo mũrurumo mũnene wa mũmomoko uume tũrĩma-inĩ. 
\q1  
\v 11 Girĩkai, inyuĩ mũtũũraga rũgongo rwa ndũnyũ; 
\q2 mũgirĩke tondũ onjorithia anyu othe nĩmekũniinwo, 
\q2 na arĩa othe monjorithanagia na betha manangwo. 
\q1  
\v 12 Hĩndĩ ĩyo nĩngoya matawa njethe andũ Jerusalemu, 
\q2 na herithie arĩa meiganĩtie, 
\q2 arĩa mahaana ndibei ĩtiganĩirio na kĩnyita kĩayo, 
\q1 arĩa meciiragia atĩrĩ, 
\q2 ‘Jehova ndarĩ ũndũ angĩĩka, mwega kana mũũru.’ 
\q1  
\v 13 Ũtonga wao nĩũgatahwo, 
\q2 na nyũmba ciao imomorwo. 
\q1 Nĩmagaka nyũmba, 
\q2 no matigacitũũra; 
\q1 nĩmakahaanda mĩgũnda ya mĩthabibũ, 
\q2 no matikanyua ndibei yayo. 
\s1 Mũthenya ũrĩa Mũnene wa Jehova 
\q1  
\v 14 “Mũthenya ũrĩa mũnene wa Jehova ũrĩ hakuhĩ, 
\q2 ũrĩ hakuhĩ na nĩũrooka narua. 
\q1 Ta thikĩrĩriai! Kĩrĩro kĩa mũthenya ũcio wa Jehova gĩgaakorwo kĩrĩ kĩnene, 
\q2 nacio njamba cia ita nĩikaarĩra mũno irĩ kũu. 
\q1  
\v 15 Mũthenya ũcio-rĩ, ũgaakorwo ũrĩ wa mangʼũrĩ, 
\q2 mũthenya wa mĩnyamaro na ruo rũnene, 
\q1 mũthenya wa mathĩĩna na mwanangĩko, 
\q2 mũthenya wa nduma na mairia, 
\q2 mũthenya wa matu na nduma ndumanu, 
\q1  
\v 16 mũthenya wa kũhuhwo karumbeta na mbugĩrĩrio ya mbaara 
\q2 ya gũũkĩrĩra matũũra marĩa mairigĩirwo na hinya, 
\q2 na gũũkĩrĩra mĩthiringo ĩrĩa mĩraihu na igũrũ. 
\q1  
\v 17 Nĩngarehere andũ mĩnyamaro, 
\q2 nao magaathiiaga ta andũ atumumu, 
\q2 nĩ ũndũ nĩmehĩirie Jehova. 
\q1 Thakame yao nĩĩgaitwo ta rũkũngũ, 
\q2 nacio nyama cia nda ciao iteo ta irĩ rũrua. 
\q1  
\v 18 Betha kana thahabu ciao 
\q2 itikahota kũmahonokia, 
\q2 mũthenya ũcio wa mangʼũrĩ ma Jehova. 
\q1 Thĩ yothe ĩkaaniinwo 
\q2 na mwaki wa ũiru wake, 
\q1 nĩgũkorwo arĩa othe matũũraga gũkũ thĩ 
\q2 nĩakamaniina o rĩmwe.” 
\b  
\c 2  
\q1  
\v 1 Mwĩcookanĩrĩriei hamwe, mwĩcookanĩrĩriei hamwe 
\q2 inyuĩ rũrĩrĩ rũrũ rũtarĩ thoni. 
\q1  
\v 2 Mwĩcookanĩrĩriei mbere ya ihinda rĩrĩa rĩtuĩtwo gũkinya, 
\q2 mũthenya ũcio ũmũkorerere ta ũrĩa mũũngũ ũmbũragwo nĩ rũhuho, 
\q1 mbere ya marakara mahiũ ma Jehova mamũkore, 
\q2 mbere ya mũthenya ũcio wa mangʼũrĩ ma Jehova kũmũkora. 
\q1  
\v 3 Cariai Jehova, inyuĩ andũ othe arĩa enyiihia a bũrũri, 
\q2 inyuĩ arĩa mwĩkaga ũrĩa aathanĩte. 
\q1 Mwĩcarĩriei ũthingu, mwĩcarĩriei kwĩnyiihia; 
\q2 no gũkorwo nĩmũkagitĩrwo 
\q2 mũthenya ũcio wa marakara ma Jehova. 
\s1 Ũrathi wa Gũũkĩrĩra Filistia 
\q1  
\v 4 Itũũra rĩa Gaza nĩrĩgatiganĩrio, 
\q2 narĩo itũũra rĩa Ashikeloni rĩanangwo. 
\q1 Andũ a Ashidodi makaarutũrũrwo mũthenya barigici, 
\q2 narĩo itũũra rĩa Ekironi rĩthario ta mũtĩ ũkũmunywo. 
\q1  
\v 5 Inyuĩ arĩa mũtũũraga ndwere-inĩ cia iria, 
\q2 o inyuĩ Akerethi, kaĩ mũrĩ na haaro-ĩ! 
\q1 Ndũmĩrĩri ya Jehova nĩ ĩgũũkĩrĩire, 
\q2 wee Kaanani, bũrũri wa Afilisti. 
\b  
\q1 “Nĩngakũniina, 
\q2 na gũtirĩ mũndũ o na ũmwe ũgaatigara.” 
\b  
\q1  
\v 6 Bũrũri ũcio ũrĩ ndwere-inĩ cia iria, o kũu Akerethi matũũraga, 
\q2 gũgaatuĩka kũndũ gwa gwakwo ithũnũ cia arĩithi, na ciugũ cia ngʼondu. 
\q1  
\v 7 Bũrũri ũcio ũgaatuĩka wa matigari ma nyũmba ya Juda; 
\q2 kũu nĩkuo makoona ũrĩithio. 
\q1 Hwaĩ-inĩ magaakomaga nyũmba cia Ashikeloni. 
\q2 Nake Jehova Ngai wao nĩakamamenyerera, na atũme magaacĩre rĩngĩ. 
\s1 Ũrathi wa Gũũkĩrĩra Moabi na Amoni 
\q1  
\v 8 “Nĩnjiguĩte irumi cia Moabi 
\q2 na inyũrũri cia Aamoni, 
\q1 acio maarumire andũ akwa 
\q2 na makĩĩhĩta gũũkĩrĩra bũrũri wao.” 
\q1  
\v 9 Jehova Mwene-Hinya-Wothe, Ngai wa Isiraeli, ekuuga atĩrĩ, 
\q2 “Ti-itherũ o ta ũrĩa niĩ ndũũraga muoyo-rĩ, 
\q1 Moabi gũgaatuĩka o ta Sodomu, 
\q2 naguo bũrũri wa Aamoni ũtuĩke ta Gomora, 
\q1 kũndũ kwa riya, na marima ma cumbĩ, 
\q2 kũndũ gũtakũraga kĩndũ kuuma tene. 
\q1 Matigari ma andũ akwa nĩmakaamataha; 
\q2 nao andũ a rũrĩrĩ rwakwa arĩa makaahonoka nĩmakagaya bũrũri wao.” 
\b  
\q1  
\v 10 Maũndũ macio nĩmakamakora nĩ ũndũ wa mwĩtĩĩo wao, 
\q2 na nĩ ũndũ wa kũruma na kũnyũrũria andũ a Jehova Mwene-Hinya-Wothe. 
\q1  
\v 11 Jehova nĩagetigĩrwo nĩo 
\q2 rĩrĩa akaananga ngai ciothe cia bũrũri ũcio. 
\q1 Ndũrĩrĩ iria irĩ hũgũrũrũ-inĩ ciothe cia iria nĩikamũhooya, 
\q2 o rũrĩrĩ rũrĩ bũrũri waruo kĩũmbe. 
\s1 Ũrathi wa Gũũkĩrĩra Kushi 
\q1  
\v 12 “O na inyuĩ, andũ a Kushi, 
\q2 nĩmũkooragwo na rũhiũ rwakwa rwa njora.” 
\s1 Ũrathi wa Gũũkĩrĩra Ashuri 
\q1  
\v 13 Nĩagatambũrũkia guoko gwake okĩrĩre andũ a gathigathini 
\q2 na aniine Ashuri, 
\q1 atige Nineve gũkirĩte ihooru, 
\q2 na kũũmagarĩte o ta werũ. 
\q1  
\v 14 Ndũũru cia mbũri na ngʼombe igaakoma kuo, 
\q2 hamwe na ciũmbe cia mĩthemba yothe. 
\q1 Ndundu cia werũ na ndundu iria ngʼambi 
\q2 nĩikomba itugĩ-inĩ ciakuo. 
\q1 Kayũ ka mĩgambo yacio gakaiguuagwo ndirica-inĩ, 
\q2 hĩba cia mahiga igaakorwo mĩrango-inĩ, 
\q2 nayo mĩgamba ya mĩtarakwa ĩtigwo ũtheri. 
\q1  
\v 15 Rĩĩrĩ nĩrĩo itũũra rĩrĩa rĩratũire na gĩkeno, 
\q2 o na rĩtarĩ na ũgwati. 
\q1 Rĩrĩa rĩeĩĩraga atĩrĩ, 
\q2 “Niĩ no niĩ, na gũtirĩ ũngĩ tiga niĩ.” 
\q1 Kaĩ nĩrĩkĩanangĩtwo, 
\q2 rĩgatuĩka o kĩmamo kĩa nyamũ cia gĩthaka-ĩ! 
\q1 Arĩa othe mahĩtũkagĩra harĩ rĩo 
\q2 no kũrĩnyũrũria na kũrĩorota. 
\c 3  
\s1 Mehia ma Jerusalemu 
\q1  
\v 1 Kaĩ itũũra rĩĩrĩ inene rĩa andũ aremi, na rĩgwatĩtio thaahu, 
\q2 o na rĩiyũrĩte maũndũ ma kũhinyanĩrĩria rĩrĩ na haaro-ĩ! 
\q1  
\v 2 Rĩtirĩ mũndũ rĩathĩkagĩra, rĩtiĩtĩkagĩra gũtaarwo. 
\q2 Rĩtiĩhokaga Jehova, na rĩtikuhagĩrĩria Ngai warĩo. 
\q1  
\v 3 Anene aarĩo mahaana ta mĩrũũthi ĩkũrarama, 
\q2 aathani aarĩo mahaana ta njũũi iria icangacangaga hwaĩ-inĩ, 
\q2 gũtirĩ kĩndũ matigagia gĩkinyie rũciinĩ. 
\q1  
\v 4 Anabii aarĩo nĩ etĩĩi; 
\q2 nĩ andũ a ungumania. 
\q1 Athĩnjĩri-Ngai aarĩo mathaahĩtie handũ-harĩa-haamũre, 
\q2 na magathũkia watho. 
\q1  
\v 5 Jehova ũrĩa ũrĩ thĩinĩ warĩo nĩ mũthingu; 
\q2 we ndeekaga ũũru. 
\q1 Rũciinĩ o rũciinĩ nĩatuanagĩra ciira na kĩhooto, 
\q2 mũthenya o mũthenya ndagaga gwĩka ũguo, 
\q2 no arĩa matarĩ athingu matirĩ thoni. 
\b  
\q1  
\v 6 “Nĩniinĩte ndũrĩrĩ; 
\q2 ciĩgitĩro ciao cia hinya nĩ momore. 
\q1 Nacio barabara ciao ndũmĩte itiganĩrio, 
\q2 gũtirĩ mũndũ ũracigerera. 
\q1 Matũũra mao manene nĩmanange; 
\q2 gũtirĩ mũndũ o na ũmwe ũtigarĩte, gũtirĩ o na ũmwe. 
\q1  
\v 7 Ndeerire itũũra rĩu inene atĩrĩ, 
\q2 ‘Ti-itherũ nĩũkanjĩtigĩra, 
\q2 na wĩtĩkĩre gũtaarwo!’ 
\q1 Hĩndĩ ĩyo itũũro ciake itikaniinwo, 
\q2 o na kana maherithia makwa mamũkore.” 
\q1 No o meeriragĩria o gwĩka ũũru 
\q2 maũndũ-inĩ mao mothe. 
\q1  
\v 8 Nĩ ũndũ ũcio Jehova ekuuga atĩrĩ, 
\q2 “Ikarai mũnjetereire, 
\q1 mweterere mũthenya ũrĩa ngaarũgama ndute ũira. 
\q2 Nĩnduĩte atĩ nĩngacookanĩrĩria ndũrĩrĩ hamwe, 
\q1 na nyũnganie mothamaki, 
\q2 nĩguo ndĩmaitĩrĩrie mangʼũrĩ makwa, 
\q1 nĩmo marakara makwa mahiũ. 
\q2 Thĩ yothe nĩĩkaniinwo 
\q2 nĩ mwaki wa marakara ma ũiru wakwa. 
\b  
\q1  
\v 9 “Hĩndĩ ĩyo nĩngatheria mĩromo ya ndũrĩrĩ, 
\q2 nĩguo othe makayagĩre rĩĩtwa rĩa Jehova, 
\q2 na mamũtungatagĩre marĩ na ũrũmwe. 
\q1  
\v 10 Andũ akwa arĩa mahurunjũkĩire 
\q2 mũrĩmo ũrĩa ũngĩ wa njũũĩ cia Kushi, 
\q2 o acio maahooyaga, 
\q2 nĩmakandehera maruta. 
\q1  
\v 11 Mũthenya ũcio wee ndũgaconorithio 
\q2 nĩ ũndũ wa maũndũ mothe marĩa mooru wananjĩka, 
\q1 tondũ nĩngeheria arĩa othe makenagĩra mwĩtĩĩo wao, 
\q2 ndĩmarute kuuma itũũra-inĩ rĩĩrĩ inene. 
\q1 Ndũgacooka gwĩtũũgĩria 
\q2 ũrĩ kĩrĩma-inĩ gĩakwa gĩtheru. 
\q1  
\v 12 No rĩrĩ, nĩngatigia gatagatĩ-inĩ kanyu 
\q2 andũ arĩa ahooreri na enyiihia, 
\q2 arĩa mehokete rĩĩtwa rĩa Jehova. 
\q1  
\v 13 Matigari ma Isiraeli matigekaga ũũru; 
\q2 matikaheenanagia, 
\q2 kana ũhinga woneke tũnua-inĩ twao. 
\q1 Makaarĩĩaga na magakoma, 
\q2 na gũtirĩ mũndũ ũkaamamakia.” 
\b  
\q1  
\v 14 Atĩrĩrĩ, wee Mwarĩ wa Zayuni, ina rwĩmbo; 
\q2 o nawe, Isiraeli anĩrĩra! 
\q1 Nawe Mwarĩ wa Jerusalemu 
\q2 kena na ũcanjamũke na ngoro yaku yothe! 
\q1  
\v 15 Jehova nĩeheretie ihũũra rĩaku, 
\q2 nacio thũ ciaku nĩacingatĩte. 
\q1 Jehova mũthamaki wa Isiraeli arĩ hamwe nawe; 
\q2 ndũgacooka gwĩtigĩra mwanangĩko rĩngĩ. 
\q1  
\v 16 Mũthenya ũcio nĩmakeera Jerusalemu atĩrĩ, 
\q2 “Wee Zayuni, ndũgacooke gwĩtigĩra 
\q2 na ndũkaregerie moko maku. 
\q1  
\v 17 Jehova Ngai waku arĩ hamwe nawe, 
\q2 o we ũrĩa ũrĩ hinya wa kũhonokania. 
\q1 Nĩarĩgũkenagĩra mũno, 
\q2 na nĩarĩkũhooragĩria na wendo wake, 
\q2 agũkũngũĩre akĩinaga nyĩmbo.” 
\b  
\q1  
\v 18 “Kĩeha gĩa ciathĩ iria njathane nĩngamwehereria; 
\q2 icio ikoretwo irĩ mũrigo na cia thoni harĩ inyuĩ. 
\q1  
\v 19 Hĩndĩ ĩyo nĩngaherithia 
\q2 arĩa othe maamũhinyagĩrĩria; 
\q1 nĩngahonokia arĩa ithua, 
\q2 na njookererie arĩa mahurunjĩtwo. 
\q1 Nĩngatũma magĩe igweta na ndĩmagoocithie 
\q2 mabũrũri-inĩ mothe kũrĩa manaconorithio. 
\q1  
\v 20 Ihinda rĩu nĩngamũcookanĩrĩria; 
\q2 hĩndĩ ĩyo nĩngamũcookia mũciĩ. 
\q1 Nĩngatũma mũgĩe igweta na ndĩmũgoocithie 
\q2 gatagatĩ-inĩ ka ndũrĩrĩ ciothe cia thĩ, 
\q1 hĩndĩ ĩrĩa ngaatũma mũgaacĩre rĩngĩ, 
\q2 o mũkĩĩonagĩra na maitho manyu,” 
\q4 ũguo nĩguo Jehova ekuuga.