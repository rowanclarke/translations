\id 1CO  
\ide UTF8
\h I. Korinthalani 
\toc1 Pauluni Dakani jaura I. Korinthalani 
\toc2 I. Korinthalani 
\toc3 1 Kor 
\mt1 Pauluni Dakani jaura I. Korinthalani.  
\c 1  
\p
\v 1 Paulus, Jesuni Christuni Apostel, ninaia Nulia karkana wonti Godaia jertapaterinali, ja Sosthenes ngatata,   
\p
\v 2 Godaia mili wolarani, tana Korinthangu ngamala wapaia, tana kulikiri pantjinala Christungu Jesungu, matja karkanala kana kulikiri, tanangunto pratjanani jela, tanali ngaianani Kaparaia Jesuni Christuni tala karkai piri pratjanani, Nauja ngaianani ja tananani nganai:   
\p
\v 3 Manju ja murla jurangunto nganaiatimai Goda ngaianani Ngaperandru ja Kapara Jesu Christungundru.   
\lit (Dakani jaura G. D. 18 Trinitatis.)  
\p
\v 4 Ngato Goda ngakani milingeru jurakokai jurangundru Godaia manjulandru, ninaia Nulia jurangu jinkinala Christungu Jesungu.   
\p
\v 5 Jura pratjanani poto pirna pantjinala nunkangu, ngujangujara pratjanali ja ngujamana pratjanali;   
\p
\v 6 Worderu Christuni tinkari ngankanali matja ngurunguru pantjina,   
\p
\v 7 Jeruja jura wata manjulaia poto kulnuni ngadani terkai, windri jura ngaiananaia Kaparaia Jesuni Christuni wondraterinaia kalkateriai,   
\p
\v 8 Nulupini bakana jurana ngurunguru ngankala nganai ditjini ngadalajelu, jeruja jura kalala panini nganala nganai ngaiananaia Kaparaia Jesuni Christuni ditjini.   
\p
\v 9 Goda talku nganai, Nulia jurana matja karkana nunkanaia Ngatamuraia jela ngamanaia, Nauja Jesus Christus Kapara ngaianani nganai.  
\b  
\p
\v 10 Ngato jurana kurukurubai, ngatata worajai, ngaiananaia Kaparaia Jesuni Christuni talandru, jura jaura kulnukulnuni jatananto, ja wata jurangu puntibani nganananto, a‐ai, jura kulnukulnuni nganananto ngundranani ja ngujamanani.   
\p
\v 11 Ngangau Chloeni nguralali ngakangu kaukaubana warai jurangundru, ngatata worajai, jurangu terti kaldri ngankijiribamalina parai.   
\p
\v 12 Ngato jenia ngundrai, pilkipilki jura jatai: Kulnujeli: Ngani Pauluni; kulnujeli: Ngani Apolloni; kulnujeli: Ngani Kephasani; kulnujeli: Ngani Christuni mili nganai.   
\p
\v 13 Christus pilki ja pilki nganai? Tanali Paulus jurangundru kunarkuni katibana wonti? Jura kara Pauluni talani multibanila manina wonti?   
\p
\v 14 Ngato Goda jurakokai, ngangau ngato wata kulno multibana wonti, windri Krispus ja Gajus;   
\p
\v 15 Ngangau wata kulno jatananto, ngato ngakani talani multibana wonti.   
\p
\v 16 Ngato bakana Stephanani pungala multibana wonti; morla ngani wata milkila, ngato kulno morla kara multibana wonti.   
\p
\v 17 Ngangau Christulu ngana wata jinpana wonti multibala, a‐ai, ngantjani jaura kaukaubala; wata jaura kirieli, ngangau Christuni kunarku wata walto pantjinanto.   
\p
\v 18 Ngangau kunarkuja jaura patipatila nganai tanangu, tana tintaterila nganai; ngaianingu, tana tepi pantjila nganai, Godaia ngurula.   
\p
\v 19 Ngangau dakanala parai: „Ngato kana kiria kirila teribala nganai, ja ngujamanietjaia tjuru ngato worarala nganai.“   
\p
\v 20 Wodajeri kana kiri? Wodajeri jaura jinkinietja? Wodajeri nunkanipini miljaraia kana kiri nganai? Wata Godali nunkanipini mitaia kiri patipatila karitjimalkana warai?   
\p
\v 21 Ngangau mitalali nunkani kirieli Goda nunkani kirilani wata ngujamana warai, jeruja Godali ngantjana wonti ngujangujara patipatieli tanana kulkala, tanali morlalu ngundrai.   
\p
\v 22 Ngangau Juda kanali malka ngatjiai ja bakana Grieka kanali kiri wontiai;   
\p
\v 23 Jeruja ngaiani Christus kaukaubai, ninaia tanali kunarkuni katibana wonti, Juda kanani kintjakintjarinaia ja Grieka kanani patipatia.   
\p
\v 24 Tanangu, tanana Nulia matja karkana, Juda kanani ja Grieka kanani, ngaiani Christus Godaia ngurula ja Godaia kirila kaukaubai.   
\p
\v 25 Ngangau Godaia patipatila morla kiri nganai kanani; ja Godaia waltowaltula morla ngurunguru nganai kanani.   
\p
\v 26 Najanau, jurani karkani, ngatata worajai, wata kana kiri marapu palkujeli, wata kana ngurunguru marapu, wata kana pirna marapu Nulia matja karkana;   
\p
\v 27 A‐ai, patipati mitandru Godali kalkalkana warai, Nulia kana kiri nintali ngankananto; ja waltowalto mitandru Godali kalkalkana warai, Nulia kana ngurunguru nintali ngankananto;   
\p
\v 28 Ja wakawaka mitandru ja ngirkibani Godali kalkalkana warai, ja mina panila nganai, ngangau Nulia panini ngankananto mina kantji nganai;   
\p
\v 29 Ngangau wata palku kulno Godani jurakokaterinanto.   
\p
\v 30 Nunkangundru bakana jura Christungu Jesungu nganai, ninaia Godali ngaianingu ngankana wonti kirilaia ja talkulaia, kulikirilaia ja kulkanilaia.   
\p
\v 31 Ngangau, worderu dakanala parai: „Worana jurakokateriai, Kaparani jurakokaterinanto.“   
\c 2  
\p
\v 1 Bakana ngani, ngani jurangu wokarana wonti, ngatata worajai, wata wokarana wonti jaura mirieli kara kiri mirieli kara jurangu Godaia ngantjani jaura kaukaubala.   
\p
\v 2 Ngangau ngato wata ngundrana wonti jurangu terti milkila nganala, windri Jesus Christus kunarkula.   
\p
\v 3 Ja ngani jurangu ngamana wonti waltowaltuni ja japani ja ngarranani.   
\p
\v 4 Ja jaura ngakani ja ngujangujara ngakani wata kirilaia jaura kiri nganana wonti, a‐ai, Jaolaia ja ngurulaia wondraterina.   
\p
\v 5 Ngangau jurani morlalu ngundrana wata kanaia kirilani parananto, a‐ai, Godaia ngurulani.   
\p
\v 6 Kirila ngaiani kaukaubai kana kirini, wata nunkanipini mitaia kirila, bakana wata nunkanipini mitaia kaparaia, tana mudala nganai,   
\p
\v 7 A‐ai, ngaiani Godaia kirila jaura kurukuruni kaukaubai, naupini ngopera ngalpuru nganana wonti, ninapini Godali mitani ngopera kurana wonti pirnalaia ngaiananaia.   
\p
\v 8 Ninaia wata nunkanipini mitaia kapara kulnujeli ngujamana wonti; ngangau tanali ninaia ngujamanani, tanali pirnalaia Kapara wata kunarkuni katibanani.   
\p
\v 9 Worderu dakanala parai: „Mina milkieli wata najina warai, ja talpali wata ngarana warai, ja wata kana ngarani wirina warai, minanina Godali tanangu ngankingana wonti, tanali ninaia ngantjai.“   
\p
\v 10 Ngaianingu Godali jenia tinkari ngankana warai Jaolali nunkanali; ngangau Jaolali pratjana winpai, bakana Godaia mikari.   
\p
\v 11 Warle kanali ngujamai mina kanaia nganai, windri kanaia jaolali nauja nunkangu nganai? Jeruja bakana wata kulnujeli ngujamai mina Godaia nganai, windri Godaia Jaolali.   
\p
\v 12 Ngaiani wata mitaia jaola maninala, a‐ai, Jaola Godandru; ngangau ngaiani ngujamananto, mina Godali ngaianingu bakujeli jinkina warai.   
\p
\v 13 Jenia ngaiani kaukaubai, wata kanaia kirilaia jaura kirieli, a‐ai, jenia jaurali, tananaia Jaolali kiri ngankai, ja Jaolaia poto Jaolaia potujeli mildiri ngankai.   
\p
\v 14 Kana tjurujeli jenia wata patai mina Godaia Jaolaia nganai, ngangau jenia nunkangu patipati nganai, ja nauja ngandandariai jenia ngujamala, ngangau Jaolali jenia ngundrananto.   
\p
\v 15 Jaolaia kanali pratjana ngundrai, ja nina muntali wata kulnujeli ngundrai.   
\p
\v 16 Ja warle Kaparaia ngundrana ngujamana warai, nunkangu ngujangujara jinkila? Ngaiani Christuni ngundrana ngamalkai.   
\c 3  
\p
\v 1 Ja ngani, ngatata worajai, ngandandarina wonti jurangu kaukaubala Jaolaia kanali jeribaka, a‐ai, palkuja kanali jeribaka, kupa wakali jeribaka Christungu.   
\p
\v 2 Ngama ngato jurangu jinkina wonti tapananto ja wata buka; ngangau jura wata ngurunguru nganana wonti, ja kararielu jura wata ngurunguru nganai.   
\p
\v 3 Bakana karari jura palkuja kana nganai; ngangau kuterina ja jatamalina ja puntibijiribamalina jurangu ngananani, jura wata palkuja kana nganai? Ja wata jura mitaia kanani jeribaka wirariai?   
\p
\v 4 Ngangau kulno jatanani: Ngani Pauluni; kulnujeli: Ngani Apolloni mili nganai; jura wata palkuja kana nganai?   
\p
\v 5 Worana Paulus ja worana Apollo nganai? Mili pudlaia nganai, pudlangundru jura morlalu ngundrana wonti, worderu Kaparali pudlangu pilki ja pilki jinkina wonti.   
\p
\v 6 Ngato kurana wonti, Apolloli turibana wonti, ja Godali punkibana jinkina wonti.   
\p
\v 7 Ja jeruja kuranietja pani nganai, ja bakana turibanietja pani nganai, a‐ai, windri Goda, Nulia punkibani jinkina wonti.   
\p
\v 8 Kuranietja ja turibanietja kulno nganai, pudlali kalala pudlani manila nganai pudlanina ngankanandru.   
\p
\v 9 Ngangau Godaia jelalingankanietja ngaiani nganai, ja Godaia mita, ja Godaia wotini jura nganai.   
\p
\v 10 Godaia manjulandru, ninaia ngato maninala, ngato wotinietja kiri jeribaka marda kapara kurana wonti. Kulno ngurujeli nunkangu morla wotiai; pratjanali najinanto, worderu tanali nunkangu wotiai.   
\p
\v 11 Kulno nguru ngandandariai marda kapara pilki kurala nnnkangu, nauja matja parai, Naupini Jesus Christus nganai.   
\p
\v 12 Kulnujeli nunkangupini marda kaparani wotinani marda maralje, marda bulu, marda ngumu pilki, pita, kanta, ngurdi;   
\p
\v 13 Jeruja pratjanaia ngankana tinkari pantjila nganai, ngangau ditjieli nina wondrala nganai, ngangau nau turujeli tinkari pantjila nganai; ja worderu kulnuja ngankana wodajeni nganai, turujeli nina wontjala nganai.   
\p
\v 14 Kulnuja ngankana paranani, nina nulu morla wotina warai, jeruja nulu kalala manila nganai.   
\p
\v 15 Kulnuja ngankana jerkinani, jeruja nulu nina tintala nganai; nau munta tepi pantjila nganai turuni palkingana jeribaka.   
\p
\v 16 Jura wata milkila, jura Godaia punga nganai, ja Godaia Jaola jurangu ngamai?   
\p
\v 17 Kulnujeli Godaia punga madlentji ngankanani, ninapini Godali madlentji ngankala nganai; ngangau Godaia punga kulikiri nganai, naupini jura nganai.   
\p
\v 18 Wata kulno jedibateriatimai. Kulnujeli ngundranani kiri nganala jurangu nunkangupini miljarani, nau patipati pantjiatimai, ngangau nau kiri pantjinanto.   
\p
\v 19 Ngangau nunkangupini mitaia kirila patipati nganai Godani. Ngangau dakanala parai: „Nulia kana kirieli tanani kirilani patai.“   
\p
\v 20 Ja nakaldra: „Kaparali kana kiria ngundrana ngujamai, nau baku nganai.“   
\p
\v 21 Ja jeruja wata kulno kanandru jurakokateriatimai; ngaugau pratjana jurani nganai;   
\p
\v 22 Paulus kara Apollo kara Kephas kara, tepi kara nari kara, mina kantji parai kara, mina wokarala nganai kara; pratjana jurani nganai.   
\p
\v 23 Jura Christuja nganai, ja Christus Godaia.   
\c 4  
\lit (Dakani jaura G. D. 3. Advent.)  
\p
\v 1 Jeruja jura ngaianina Christuni mili ngundrananto, ja Godaia kurukurulaia ngamalkijiribanietja.   
\p
\v 2 Mina jura morla ngamalkijiribanietjani wontiai? Kulno talku mankamankananto.   
\p
\v 3 Ngakangu jenia baku ngangai, jura kara kanaia ditji kara ngana wontjananto, ngangau ngani munta wata wontjateriai.   
\p
\v 4 Ngani munta panila milkila, windri nunkangu ngani wata talku ngankateriai; Nulia ngana wontjai, Nauja Kapara nganai.   
\p
\v 5 Jeruja wata ditjini ngopera kalala kuranau Kapara wokaranantulu, Nulia praitjani kurala nganai ngalpuruja kurukurula, ja tinkari ngankala nganai ngara woraia ngundrana; ja ngadani pratjanani jurakokana pantjila nganai Godandru.   
\p
\v 6 Jenia, ngatata worajai, ngani ngakangundru ja Apollongundru jatana warai jurangundru, ngangau jura ngalingundru kiririnanto, wata nunkangu morla pirna ngundraterinanto mina dakanala parai, ngangau jura wata kulnuni wombatjerananto kulnuni.   
\p
\v 7 Warle jidna pirna ngankana warai? Mina jundru ngamalkai, ninaia jundru wata maninala? Jundru ninaia morlalu matja maninani, minandru jidni jurakokateriai, jundru ninaia wata maninani?   
\p
\v 8 Jura matja jerto nganai; jura kana poto pirnanto pantjina warai, ngalingu panini jura kapara pantjina warai. Ngumu nganananto jura kapara nganai, ngangau bakana ngali jurangu jela kapara nganananto.   
\p
\v 9 Ngato ngundrai, Godali ngaianina Apostel worana ngadanietja terkibana warai, narini matja jinkina jeribaka; ngangau ngaiani wondrani malka pantjina warai mitalani ja angelani ja kanani.   
\p
\v 10 Ngaiani patipati nganai Christungundru, jura kiri nganai Christungu; ngaiani waltowalto, jura ngurunguru; jura pirna, ngaiani pirnala pani.   
\p
\v 11 Karari ditjielu ngaiani mauali ja tertieli ngamai ja balu nganai, ja tanali ngaianina maramokujeli nandrai, ja piri pani ngaiani ngamalkai,   
\p
\v 12 Ja jiglerali ngaianini marali ngankai. Tanali ngaianingu kaldri jatanani, jeruja ngaiani ngurungutanani; tana ngaianingu tirikaripaterinani, jeruja ngaiani tanana patai;   
\p
\v 13 Tanali ngaianina ngirkibanani, jeruja ngaiani jaura murlali jinkiai; mitalaia tarpani mita ngaiani pantjina warai, kana pratjanaia worani kararielu.   
\p
\v 14 Wata jurana nintali ngankala ngato jenia dakai, a‐ai, ngato jurana ngakani kupa ngantjalu jeribaka kurukurubai.   
\p
\v 15 Jura 10,000 wapalkanietja Christuni ngamalkanani, jeruja jura wata ngaperi marapu ngamalkai; ngangau Christungu Jesungu ngantjani jaurali ngato jurana kantji patana warai.   
\p
\v 16 Jeruja ngato jurana kurukurubai, ngakangu karipaterianimai.   
\p
\v 17 Jendrania ngato Timotheus jurangu jinpana warai, nau ngakani kupa ngantjalu ja talku nganai Kaparani, nulu jurana mangatandra wilpa ngankala nganai ngakani palto Christungu, worderu ngato paruparu mili wolara pratjanani ngujangujara jinkiai.   
\p
\v 18 Palpa jurangundru wombatjarai, ngangau tanali ngundrai, ngani wata wokarala nganai.   
\p
\v 19 Wolja ngani jurangu wokarala nganai, Kapara jertapaterinani, ja ngato ngujamala nganai wata wombatjaranietjaia jaura, a‐ai, ngurula.   
\p
\v 20 Ngangau wata jaurani Godaia milila parai, a‐ai, ngurulani.   
\p
\v 21 Mina jura ngantjai? Ngani pitali jurangu wokarananto kara, ngantjanali ja Jaola manjujeli kara?   
\c 5  
\p
\v 1 Jaura parai, jurangu jela palakantji nganai, ja jenipara palakantji, ninaia bakana kana kojeli wata ngujamai, kulnujeli ngaperaia nunkanaia noa ngamalkai.   
\p
\v 2 Ja jura wombatjarai, ja wata ngaurongauro pantjina warai, nina jurangundru dangananto, nulu jenia ngankana warai.   
\p
\v 3 Ngani palkujeli wata jerra nganai, windri jaolali kantji jerra nganai, ja ngani kantji naka jeribaka kurana warai, nina, nulu jenipara ngankana warai:   
\p
\v 4 Ngaiananaia Kaparaia Jesuni Christuni talani, jura matja jurborinani ja bakana ngani jaola ngaiananaia Kaparaia Jesuni Christuni ngurulali,   
\p
\v 5 Jenipara kana Satanangu jinkila palkuja teribanaia, ngangau jaola tepi pantjinanto Kaparaia Jesuni ditjini.   
\lit (Dakani jaura Jesu tepi terkakani ditjini ngoperalani.)  
\p
\v 6 Jurani pirnala wata ngumu nganai. Wata jura milkila, pulkurutjeribani buka ngalje buka tjanka pratjana pulkurutjeribai?   
\p
\v 7 Jeruja pulkurutjeribani buka womala tarpanau, jura buka tjanka marra pantjinanto, worderu jura pulkurutjeribani buka pani nganai. Ngangau Passa kuparu ngaianini Christus, ngaianingundru matja nandrana.   
\p
\v 8 Jeruja ngaiani ditji pirnani ngamananto wata pulkurutjeribani buka womalani, bakana wata madlentjaia ja tjikatjikaia pulkurutjeribani bukani, a‐ai, talkulaia ja morlalulaia pulkurutjeribani buka panini.  
\b  
\p
\v 9 Ngato jurangu dakani jaurali dakanala, jura wata palakantjini jela ngamananto.   
\p
\v 10 Jenia ngato wata ngundrai nunkanipini mitaia palakantjindru, ja ngukingukibaterinietjandru, ja watawatali maninietjandru, ja Goda muramura wodatarana ngamanietjandru; jeruja jura mitandru dunkananto.   
\p
\v 11 Jeruja ngato jurangu dakanala, jura wata jela ngamananto kulnuni, nulu tala „ngatata“ ngamalkai, ja palakantji kara, ngukingukibaterinietja kara, Goda muramura wodatarana ngamanietja kara, ngirkibanietja kara, tapanietja kara, watawatali maninietja kara nganai; jendrangupara jela jura bakana wata tajinanto.   
\p
\v 12 Jenia ngakangu parai, tanangu palarani kalala kurala? Jura wata tanangu, jurangu terti, kalala kuranani?   
\p
\v 13 Tanangu palarani Godali kalala jinkila nganai. Nina madlentji ngankanietja jurangundru danganau!   
\c 6  
\p
\v 1 Minandru kulnujeli jurangundru, nulu tirijakalkijiribamalina ngamalkanani, tjakakijiribamaliai kana talku panini ja wata kana kulikirini?   
\p
\v 2 Jura wata milkila, kana kulikirieli mitani kalala kurala nganai? Ja jura mitani kalala kuranani, minandru jura ngandandariai poto wakawakani kalala kurala?   
\p
\v 3 Jura wata milkila, ngaiani angelani kalala kurala nganai? Worderu morla mitaia potuni?   
\p
\v 4 Jura mitaia potundru tjakakijiribamalinani, jura tanana, tanali mili wolarali wakawaka ngundrai, kurai.   
\p
\v 5 Jurana nintali ngankala ngani jenia jatai. Jurangundru wata kana kiri kulno nganai, nau ngurunguru nganai ngatatani kalala kurala?   
\p
\v 6 A‐ai, ngatatajeli ngatatani tjakakijiribamaliai, ja jenia kana morlalu ngundrani panini!   
\p
\v 7 Jenia matja madlentji nganai jurangundru, jura tjakakijiribamalinani. Minandru jura wata tjikatjika patai? Minandru jura wata manju nganai, tanali jurangu watawatali maninani?   
\p
\v 8 A‐ai, jura wata talku ngankai ja watawatali maniai, ja jenia ngatatani?   
\p
\v 9 Jura wata milkila, kana wata talkujeli Godaia milila wata maratunka manila nganai? Wata tjautjau ngundranau: Wata palakantji, wata Goda muramura wodatarana ngamanietja, wata pinta wokaribanietja, wata kana muramura, wata kankuni murumuru ngankanietja.   
\p
\v 10 Wata kurikantji, wata ngukingukibaterinietja, wata tapanietja, wata ngirkibanietja, wata watawatali maninietja Godaia milila maratunka manila nganai.   
\p
\v 11 Ja jenipara palpa jurangundru nganana warai. Karari Nulia jurana kulirkana warai, ja kulikiri ngankana warai, ja talku ngankana warai Kaparaia Jesuni talani, ja ngaiananaia Godaia Jaolani.   
\p
\v 12 Pratjana ngakangu parai, windri wata pratjana ngumu nganai; pratjana ngakangu parai, ja wata kulnujeli ngana kalalu ngankananto.   
\p
\v 13 Buka mandraia, ja mandra bukaia; Godali ninapara ja jenipara worala nganai. Palku wata palakantjia, a‐ai, Kaparaia; ja Kapara palkuja.   
\p
\v 14 Godali wata windri Kapara jiritjibana wonti, a‐ai, Nulia bakana ngaianina jiritjibala nganai nunkani ngurulali.   
\p
\v 15 Jura wata milkila, jurani palku Christuni buru nganai? Ngato Christuni buru maninanto ja palakantjia buru ngankananto? A‐ai.   
\p
\v 16 Jura wata milkila kara, worona piranguruni ngamai, nau nankangu jela palku kulno nganai? Ngangau pudla, worderu Nauja jatai, palku kulno nganala nganai.   
\p
\v 17 Worana Kaparani ngamai, nau nunkangu jela Jaola kulno nganai.   
\p
\v 18 Palakantjindru japa mindrianau! Madlentji pratjana, kana kulnujeli ngankanani kara, palkuni palarani nganai; palakantjieli nunkani palkuni madlentji ngankateriai.   
\p
\v 19 Jura wata milkila kara, jurani palku Jaola kulikiria punga jurangu nganai, ninaia jura Godandru maninala, ja ngani wata munta ngani nganai?   
\p
\v 20 Ngangau Nulia jurana kalalaia mamana wonti. Jeruja Goda jurakokanau jurani palkuni ja jurani jaolani, ngangau pudlaia Godaia pilki nganai.   
\c 7  
\p
\v 1 Nunkangundru, mina jura ngakangu dakanala, ngani jatai: Ngumu nganai kanani, nulu widla wata karanani;   
\p
\v 2 Windri palakantjindru materali widla nunkani ngamalkaiatimai, ja widlali materi nankani ngamalkaiatimai.   
\p
\v 3 Materali widlani jinkinanto, mina nulu nankangu wilpanto nganai; jeruja bakana widlali materani.   
\p
\v 4 Widlali nankani palkuni wata ngurula ngamalkai, a‐ai, materali; jeruja bakana materali nunkani palkuni wata ngurula ngamalkai, a‐ai, widlali.   
\p
\v 5 Wata kulno ngadatikibau kulnuni, windri judla kulnukulnuni ngananani miljaru kulnuwirdi, jura ngara ngamani ngamalkananto milja ngamanaia ja ngatjinaia; ja nakaldra jelarialumai, Satanali judlana wontjaiati judlani waltowaltundru.   
\p
\v 6 Jenia ngani jatai manuni kurana jeribaka, ja wata jirijiribana jeribaka.   
\p
\v 7 Ngato ngantjai, kana pratjana ngakangu jeribaka nganananto; windri pratjana pilkipilkieli Godandru nunkani manjulaia poto pilki ngamalkai, kulnujeli jeruja, kulnujeli jeruja.   
\p
\v 8 Ngani mantakani ja mangawaruni jatai: Tanangu ngumu nganai, tana ngakangu jeribaka ngamanani.   
\p
\v 9 Tana ngandandarinani ngamalkaterila, tanali noa patananto; ngangau morla ngumu nganai, tanali noa patanani, baka pirna ketjaketjanani.   
\p
\v 10 Tanangu pintani ngato jirijiribai, wata ngato, a‐ai, Kaparali, widla materandru wata puntibateriatimai;   
\p
\v 11 Nani kantji puntibaterinani, nandru noa pani ngamananto kara, materani murlali pantjinanto kara; ja materali widla wata worarananto.   
\p
\v 12 Tanangu nguruni ngani jatai, wata Kapara: Ngatata kulnujeli noa ngamalkanani, nandru wata morlalu ngundranani, ja nandru kulnukulnuni ngananani nunkangu jela ngamala, nulu nana wata worarananto.   
\p
\v 13 Bakana widlali noa ngamalkanani, nulu wata morlalu ngundranani, ja nulupini kulnukulnuni ngananani nankangu jela ngamala, nandru nina wata worarananto.   
\p
\v 14 Ngangau materi, nulu wata morlalu ngundranani, kulikiri nganai widlani; ja widla, wata morlalu ngundranani, kulikiri nganai materani; jenia wata ngananani, kupa jurani murumuru ngananani, karari tana kulikiri nganai.   
\p
\v 15 Nulu wata morlalu ngundranani, nau puntinanto; ngatata kara, kaku kara, tanangupini potuni wata dupudupu nganai. Murlani Godali ngaianina karkana warai;   
\p
\v 16 Ngangau jundru milkila, widlajai, jundru materi kulkala nganai kara? Jidni milkila, materiai, jundru widla kulkala nganai kara?   
\p
\v 17 Windri worderu Kaparali kulnuni jinkina warai, worderu Godali kulno karkana warai, jeruja nau wirarinanto. Ja jeruja ngato mili wolara pratjanani jirijiribai.   
\p
\v 18 Nulia kulno karuwalila karkana warai, nulu wata karuwalila panini jeri ngankaterinanto; Nulia kulno karuwalila panini karkana warai, nulu wata karuwalila pantjinanto.   
\p
\v 19 Karuwalila panila nganai, ja karuwalila panini panila nganai, windri Godaia jirijiribani jaura ngamalkala.   
\p
\v 20 Pratjana nunkangupini karkanilani ngamaiatinimai, nunkanali Nulia tanana matja karkana.   
\p
\v 21 Jidni kanaia mili matja karkana, wata manujeli ngundrau, jidni ngurunguru nganai kurakaterila, kurakateriau!   
\p
\v 22 Ngangau worana Kaparani kanaia mili matja karkana, nau Kaparaia kurakanila nganai; jeruja bakana, worana kurakanila matja karkana, nau Christuja mili nganai.   
\p
\v 23 Kalala pirnali Nulia jurana burungankana wonti; wata kanaia mili pantjianau!   
\p
\v 24 Ngatata worajai, pratjana nunkangu ngamananto Godani, worderu Nulia nina karkana warai.   
\p
\v 25 Mankarandru ngato wata Kaparaia jirijiribani jaura ngamalkai: ngato ngundrana ngankani kaukaubai, ngangau ngato Kaparandru kalumiltjamiltjarina manina wonti morlalu ngundrani nganala.   
\p
\v 26 Jeruja ngato ngundrai, jenia ngumu nganai karari ketjaketjanandru, jenia kana kulnuni ngumu nganai jeruja nganala.   
\p
\v 27 Jidni widlani workamantraterina warai, wata wontiau nana worarala; jundru widla pani ngananani, wata widla wontiau.   
\p
\v 28 Jundru kantji noa patana warai, jundru wata madlentji ngankana warai; ja mankarali noa patana warai, nandru bakana wata madlentji ngankana warai. Ketjaketjana palkujeli tanali ngamalkala nganai; ngato jurana kulkananto.   
\p
\v 29 Jenia ngani jatai, ngatata worajai, miljaru wordu nganai; ngangau bakana tanana, tanali noa ngamalkai, nganananto noa pani jeribaka; ja tana jindrala wapaia, jindrana pani jeribaka nganananto;   
\p
\v 30 Ja tana mankila wapaia, mankina pani jeribaka nganananto; ja tanali burungankala wapaia, poto pani jeribaka nganananto.   
\p
\v 31 Ja tanali ninapini mita ngamalkala wapaia, wata ngamalkana jeribaka nganananto; ngangau nunkanipini mitaia mudla mudai.   
\p
\v 32 Ngato ngantjai, jura manujeli ngundrani pani nganananto. Mantaka materali manujeli ngundrai mina Kaparaia nganai, worderu nau Godaia ngantjani nganananto.   
\p
\v 33 Warle noa patana warai, mitaia manujeli ngundrai, worderu nau widlaia ngantjani nganananto.   
\p
\v 34 Pilkipilki nganai widlani ja mankarani. Mantaka widlali manujeli ngundrai mina Kaparaia nganai, nani kulikiri nganananto palkujeli ja jaolali; nandru matja noa patana, nana manujeli ngundrai mina mitaia nganai, worderu nani materaia ngantjani nganananto.   
\p
\v 35 Jenia ngani jatai jurani ngumuja; ngato jurangu wata minti worananto, a‐ai, ngangau jenia ngumu nganai, jura milingeru ja wonki Kaparani nganananto.   
\p
\v 36 Kulnujeli ngundranani, nunkani mankarani nintali nganai, ngangau nunkani mankaraia ditji mudaiati, ja jenia jeruja pantjinanto, nulu ngankaiatimai mina nau jertapateriai, nulu wata madlentji ngankai; nana noa patananto.   
\p
\v 37 Warle ngarali ngurunguru ngundranani, ja nunkangu wata nankanankana parai, ja ngurula ngamalkai nunkani jertapaterinani, ja nunkani ngarani jenia ngundrana warai, nunkani mankara ngamalkijiribala, nulu ngumu ngankai.   
\p
\v 38 Jeruja nulu ngumu ngankai, nulu noa patai; ja nulupini, nulu wata noa patai, nulu morla ngumu ngankai.   
\p
\v 39 Widla workamandrana nganai jirijiribani jaurandru, jeruntjaia ditji noa nankani tepi nganai; nankani noa matja palinani, nani kurakani nganai noa kulno patala worana nandru ngantjai, windri Kaparani.   
\p
\v 40 Nani morla murlali nganai, nani jeruja ngamanani, worderu ngato ngundrai. Ngato ngundrai, ngato bakana Godaia Jaola ngamalkai.   
\c 8  
\p
\v 1 Muramuraia poto ngumundru ngaiani milkila, ngaiani pratjanali ngujamani ngamalkai. Ngujamanali wombatjarai, ja ngantjanali wotiai.   
\p
\v 2 Kulnujeli ngundraterinani nau milkila ngananani, jeruja nulu panila ngujamana warai worderu nina ngujamananto.   
\p
\v 3 Kulnujeli Goda ngantjanani, nina Nulia ngujamala wapaia.   
\p
\v 4 Muramura poto ngumuja tajinandru ngaiani milkila, muramura pani mitani nganai, ja wata Goda pilki nganai, windri Kulno.   
\p
\v 5 Ja tanali kantji muramura worana dikanani, pariwilpani kara mitani kara, worderu Goda muramura marapu ja Kapara marapu nganai;   
\p
\v 6 Ngaianingu windri Goda kulno nganai, Ngaperi, nunkangundru warupoto nganai, ja ngaiani nunkangu; ja windri Kapara kulno, Jesus Christus, nunkangundru warupoto nganai, ja ngaiani nunkangundru.   
\p
\v 7 Wata pratjanali ngujamani ngamalkai. Palpa ngara ngaialandru japali, tanali nina muramuraia poto ngumu jeribaka tajiai, ja ngangau tanani ngara ngaiala waltowalto nganai, jeruja nau murumuru pantjiai.   
\p
\v 8 Tajinali ngaianina Godani wata talku ngankai; ngangau ngaiani tajinani, ngaiani wata morla talku nganala nganai; ja ngaiani wata tajinani, ngaiani wata morla waka nganala nganai.   
\p
\v 9 Ngamalkaterianau, jurani ngurula waltowaltuni dakaterina pantjiati.   
\p
\v 10 Kulnujeli jidna, jundru ngujamana ngamalkanani, najinani muramuraia pungani kurlini ngamanani; nau wata nunkani ngara ngaiala waltowalto ngurunguru ngankaterila nganai muramuraia poto ngumu tajila?   
\p
\v 11 Ja jinkani ngujamanandru ngatata waltowalto tintaterila nganai, nunkangundru Christus palina wonti?   
\p
\v 12 Jeruja jura ngatata worangu madlentji ngankanani, ja tanani ngara ngaiala waltowalto nandranani, jura Christungu madlentji ngankai.   
\p
\v 13 Jendrangundruja, ngangau tajinali ngatatani ngakanani dakaterina jinkinani, jeruja ngato morlalu wata nganti tajila nganai ngurali, ngangau ngato wata ngatatani ngakanani dakaterina kurananto.   
\c 9  
\p
\v 1 Ngani wata Apostel nganai? Ngani wata kurakanila nganai? Ngani wata Jesus Kapara ngaianani najina wonti? Jura wata ngankani ngakani nganai Kaparani?   
\p
\v 2 Ngani wata kana pilkia Apostel ngananani, ngani jenipara morlalu jurangu nganai, ngangau ngakani Apostel ngamalkijiribani malka morlalu jura nganai Kaparani;   
\p
\v 3 Jurajuralkaterini ngakani tanangu, tanali ngana wontjai, naupini nganai.   
\p
\v 4 Ngaiani wata ngurula ngamalkai tajila ja tapala?   
\p
\v 5 Ngaiani wata ngurula ngamalkai kaku noa wiralkala, Apostel worali ja Kaparaia ngatatajeli ja Kephajeli jeribaka?   
\p
\v 6 Windri ngato ja Barnabali kara wata ngurula ngamalkai panila ngankala?   
\p
\v 7 Worana tirimalinaia wapai, ja kalala pani maniai? Warle waina maru kurai, ja wata nunkani tandrandru tajiai? Warle ngami kulno ngamalkai, ja wata ngamandru tajiai?   
\p
\v 8 Ngani jenia kana jeribaka jatai; wata jirijiribani jaura jenia bakana jatai?   
\p
\v 9 Ngangau Mosini jirijiribani jaurani dakanala parai: „Jundru ngantini nulu tandra nankanankai, wata mana billieli ngandrawalkananto!“ Godali nganti manujeli ngundrai kara?   
\p
\v 10 Nauja jenia wata kantji ngaianingundru jatai? Kau, ngaianingundru jenia dakanala parai, ngangau mita bakunietjali mita bakujai kalkanaia, ja tandra nankanankanietjali nankai kalkanaia, bakana manila.   
\p
\v 11 Ngaiani jurangu Jaolaia poto jaupana warai, jenia pirna nganai, ngaiani jurani mitaia poto kampanani?   
\p
\v 12 Kana pilkieli ngurula ngamalkanani jurangu, minandru morla wata ngaiani? Ngaiani ninapini ngurula wata manina warai, a‐ai, ngaiani pratjana mandrai, ngaiani wata dakaterini jinkinanto Christuni ngantjani jaurani.   
\p
\v 13 Jura wata milkila, tanali poto ngumu ngankingai, poto ngumundru tajiai? Ja tanali Altara ngamalkai, Altarandru maniai?   
\p
\v 14 Jeruja bakana Kaparali kurana wonti, tanali ngantjani jaura kaukaubai, tana ngantjani jaurandru bakana tepirinanto.   
\p
\v 15 Ngato panila tanangundru manina warai. Jenia ngato wata dakana warai, ngakangu bakana jeruja pantjinanto. Ngakangu morla ngumu nganananto palila, kulnujeli pirnala kaliati.   
\p
\v 16 Ngato ngantjani jaura kaukaubanani, jenia wata pirnala nganai ngakangu, ngangau ngato jenia kantji ngankananto. Jakajai ngakangu, ngato ngantjani jaura wata kaukaubanani.   
\p
\v 17 Ngangau ngato jenia bakujeli ngankanani, ngato kalala manila nganai; ngato jenia buljubuljujeli ngankanani, jeruja ngakangu Godaia poto ngamalkijiribani jinkinala.   
\p
\v 18 Mina kalala ngakani nganai? Ngato ngantjani jaura kaukaubanani, ngato ninaia ngantjani jaura bakujeli kaukaubananto, ja ngakani ngurula ngantjani jaurandru wata maninanto.   
\p
\v 19 Ngani wata kulnuja mili nganai, ngani munta pratjanani mili jinkiterinala, ngato tanangundru marapu mamananto.   
\p
\v 20 Ja ngani Juda kanani Juda kana jeribaka pantjina warai, Juda kana mamala; tanangu, tana jirijiribani jaurani ngamai, jirijiribani jaurani ngamanani jeribaka, tanana, tana jirijiribani jaurani ngamai, mamala;   
\p
\v 21 Tanangu, tana jirijiribani jaura panina, jirijiribani jaura panini jeribaka, ngani munta wata Godaia jirijiribani jaura panini ngamai, a‐ai, ngani jirijiribani jaurani ngamai Christungu, tanana, tana jirijiribani jaura panini, mamala.   
\p
\v 22 Ngani waltowaltuetjani waltowaltuetja jeribaka pantjina warai, tanana, tana waltowalto, mamala; ngani kana pratjanani pratjana pantjina warai, paruparu palpa kulkala.   
\p
\v 23 Jenia pratjana ngato ngankai ngantjani jaurandru, ngato nunkanina maninanto.   
\lit (Dakani jaura Septuagesimä ditjini.)  
\p
\v 24 Wata jura milkila, tana milkimalini mitani mindriai, pratjana mindriai, ja windri kulnujeli kalala patai? Jeruja jura mindrianau nina patala.   
\p
\v 25 Pratjaterina, tana mindriai, pratjanani ngamalkateriai; tanapara pirapira manila nau mudai, ja ngaiani pirapira nau wata mudai.   
\p
\v 26 Ngani mindriai, ja wata bakuja; ngato nandrai, ja wata kulnuni jeribaka nulu warumai.   
\p
\v 27 A‐ai, ngani palku nankateriai, ja nina mila ngankateriai, ngangau ngato nguruni matja kaukaubani pirna nganana, munta tintateriati.   
\c 10  
\p
\v 1 Ngangau jura milkila nganananto, ngatata worajai, ngaperi wora ngaianani pratjana talara palkuja ngalpani nganana wonti, ja pratjana panto pirnani palkingana wonti;   
\p
\v 2 Ja pratjana tanali multibanila manina wonti Mosingu talara palkujeli ja panto pirnali.   
\p
\v 3 Ja pratjanali tanali Jaolaia buka kulno tajina wonti.   
\p
\v 4 Ja pratjanali tanali Jaolaia tapani kulno tapana wonti, ngangau tanali tapana wonti Jaolaia taldrandru, naupini tanangu karipaterina wonti, nauja taldra Christus nganana wonti.   
\p
\v 5 Ja tanana marapu Godali wata ngantjana wonti; ngangau Nulia tanana worana ngutana wonti pitarani.  
\b  
\lit (Dakani jaura G. D. 9 Trinitatis.)  
\p
\v 6 Jenia ngaianangu mudlamalkaia pantjina wonti, ngangau ngaiana wata poto madlentjani milkirinanto, worderu tanali milkirina wonti.   
\p
\v 7 Bakana wata muramuraia mili pantjianau, worderu tanangundru palpa; worderu dakanala parai: „Kana wolara ngamana ngarina wonti tajila ja tapala, ja terkala tarana wonti dultrila.“   
\p
\v 8 Bakana ngaiana wata palakantji ngamananto worderu tanangundru palpa palakantji ngamana wonti, ja ditji kulnuni palina wonti 23,000.   
\p
\v 9 Ngaiana bakana Christus wata wontjananto, worderu tanali palpali ninaia wontjana wonti, ja tjutjujeli tanana nandrana wonti.   
\p
\v 10 Bakana wata kuterianau, worderu tana palpa kuterina wonti, ja naria angelali tanana nandrana wonti.   
\p
\v 11 Jenipara pratjana tanangu mudlamalkali pantjina wonti; ja ngaianangu naupini dakanala ngaianana kapakuribala, ngaiana ditjini ngadalani karakara.   
\p
\v 12 Ngangau worana munta ngundrateriai terkala, nau ngamalkaterinanto puriati.   
\p
\v 13 Wontjana pilkieli jurana wata patana warai, windri kanaia wontjana; Goda talku nganai, Nulia wata manuni kurala nganai, jurana wontjananto morla pirna jurani ngurulani, a‐ai, Nulia wontjanandru jurana tjirimalkala nganai, jeruja jura ngurunguru nganala nganai nina waltala.  
\b  
\p
\v 14 Jendrangundruja, ngantjani ngakani, muramura wodatarana ngamanandru japa mindrianau!   
\p
\v 15 Ngani kana kirini jeribaka jatai; jura muntali wontjanau, mina ngato kurai.   
\p
\v 16 Ngurungutani koko, ninaia ngaiani ngurungutai, nauja wata Christuni kumarani jela nganai? Nauja buka, ninaia ngaiani wokaribai, nauja wata Christuni palku jela nganai?   
\p
\v 17 Ngangau windri buka kulno nganai, ja palku kulno ngaiana marapujeli, ngangau ngaiana pratjana buka kulnundru maniai.   
\p
\v 18 Najianau Israel palkundru! Wata tana, tanali poto ngumu tajiai, Altarani jela nganai?   
\p
\v 19 Mina ngani jatai? Muramura minakulno nganai kara, muramuraia poto ngumu minakulno nganai kara?   
\p
\v 20 A‐ai, Mina kana kojeli poto ngumu jinkiai, jenia tanali kutjini jinkiai, ja wata Godani; ngato wata ngantjai, jura kutjia kamaneli pantjinanto.   
\p
\v 21 Jura ngandandariai Kaparaia koko tapala ja kutjia koko; jura ngandandariai Kaparaia kurlini ngamala ja kutjia kurlini.   
\p
\v 22 Ngaiana Kaparani delkinanto kara? Ngaiana morla ngurunguru nganai nunkangu?   
\p
\v 23 Pratjana ngakangu manuni kurala wapaia, windri wata pratjana ngumu nganai; pratjana ngakangu manuni kurala wapaia, ja wata pratjanali wotiai.   
\p
\v 24 Wata kulnujeli wontiau nunkanina, a‐ai, mina kulnuja nganai.   
\p
\v 25 Pratjana, mina tanali ngantiburungankani pirini kalalaia jinkiai, tajianau, ja morla wata jakalkanau ngara ngaialandru.   
\p
\v 26 Ngangau mita Kaparaia nganai, ja nunkani poto pratjana.   
\p
\v 27 Kana kulno morlalu ngundrani panieli jurana karkanani, ja jura jertapaterinani wapala, pratjana tajianau mina tanali jurangu kurai, ja morla wata jakalkanau ngara ngaialandru.   
\p
\v 28 Kulno jurangu jatanani: Naupini muramura poto ngumuja nganti nganai, jenia wata tajianau nunkangundru, nulu jenia kaukaubana warai ngara ngaialandru; ngangau mita Kaparaia nganai, ja nunkani poto pratjana.   
\p
\v 29 Ngara ngaialandru ngani jatai, wata jinkanani, a‐ai, nguruja; minandru kulnuja ngara ngaialali ngakani kurakanani kalala ngundrananto?   
\p
\v 30 Ngato jurakokanali tajinani, minandru tanali ngana ngirkibai, nunkangundru minani ngato jurakokai?   
\p
\v 31 Jura tajinani kara tapanani kara minakulno ngankanani kara, pratjana ngankanau Godaia pirnalaia.   
\p
\v 32 Juda kanani ja Grieka kanani ja Godaia mili wolarani wata dakaterini pantjianau!   
\p
\v 33 Worderu bakana ngani warupotuni kana pratjanani murlali nganai, ja wata wontiai mina ngakangu, a‐ai, mina warupotuni ngumu nganai, tana tepi pantjinanto.   
\c 11  
\p
\v 1 Ngakangu karipaterianau, worderu ngani Christungu.   
\p
\v 2 Ngato jurana jurakokai, ngatata worajai, ngangau jura pratjanani ngana milingeru ngundrai, ja jirijiribani jaura ngamalkai, worderu ngato tanana jurangu jinkina wonti.   
\p
\v 3 Ngani jertapateriai jura milkila nganananto, materaia mangatandra Christus nganai; widlaia mangatandra materi nganai; Christuni mangatandra Goda nganai.   
\p
\v 4 Materali ngatjinani kara talpadakanani kara, ja kakabilli mangatandrani ngamalkanani, nulu mangatandra nunkani nintali ngankai.   
\p
\v 5 Widlali ngatjinani kara talpadakanani kara mangatandra wata walpaterini, nandru mangatandra nankani nintali ngankai; ngangau jenia para wokaribani jeribaka nganai.   
\p
\v 6 Widlali mangatandra wata walpaterinani, nandru ba kana para wokaribananto; widlani ninta ngananani para wokaribala kara balurila kara, jeruja nani walpaterinanto.   
\p
\v 7 Materi mangatandra wata walpaterinanto, ngangau nau Godaia mudla ja pirnala nganai; ja widla materaia pirnala nganai.   
\p
\v 8 Ngangau materi wata widlandru, a‐ai, widla materandru nganai.   
\p
\v 9 Ngangau Nulia materi wata widlandru pantjimana wonti, a‐ai, widla materandru.   
\p
\v 10 Jendrangundruja widlali ngurula mangatandrani ngamalkananto angelandru.   
\p
\v 11 Windri materi widla panini, ja widla materi panini, wata Kaparani nganai.   
\p
\v 12 Ngangau worderu widla materandru, jeruja bakana materi widlandru, ja pratjana Godandru.   
\p
\v 13 Muntali ngundranau jenia talku nganai kara, widla wata walpaterini Godani ngatjinanto?   
\p
\v 14 Mangatandra muntali jurangu wata wondrai, materali para wirdi ngamalkanani, jenia nunkangu ninta nganai?   
\p
\v 15 Widlali para wirdi ngamalkanani, jenia nankangu pirnala nganai? Ngangau para nankangu walpaterini matja jinkina.   
\p
\v 16 Kulnujeli jurangundru ngantjanani jatamalila, ngaiani wata jenia ngankai, bakana wata Godaia mili wolara.   
\p
\v 17 Ngato jenia jirijiribanani, ngato jenia wata jurakokai, jura wata jurboriai ngumuja, a‐ai, madlentjaia.   
\p
\v 18 Ngopera, jura jurborinani mili wolarani, ngato ngarai, tidatida nganai jurangu terti, ja palpa ngato morlalu ngundrai.   
\p
\v 19 Ngangau mudlawariwari jurangu terti nganananto, ngangau wonkietja tinkari pantjinanto jurangundru.   
\p
\v 20 Jura jurborinaia jurborinani, jura ngandandariai Kaparaia buka tajila.   
\p
\v 21 Ngangau kulno ja kulnujeli buka nunkani bukani ngopera tajiai, jeruja kulno mauali nganai ja kulno kaljura.   
\p
\v 22 Jura wata punga ngamalkai tajila ja tapala kara? Jura Godaia mili wolara waka ngundrai, ja tanana nintali ngankai, tanali panila ngamalkai kara? Mina ngani jurangu jatananto? Ngato jurana jurakokananto? Jendrangundruja ngato jurana wata jurakokai.   
\lit (Dakani jaura kuljakulja Thursdayni.)  
\p
\v 23 Ngato jenia Kaparandru manina wonti, mina ngato jurangu bakana jinkina wonti: Kapara Jesujeli nunkangupini tinkani, nulu ninaia matja wondawondana, Nulia buka patana wonti;   
\p
\v 24 Ja Nulia jurakokana wonti, ja ninaia wokaribana wonti ja jatana wonti: „Patanimai ja tajianimai; Naupini ngani palku nganai, Nauja jurangu nganai, jenia ngankanau ngakangu ngundrala.“   
\p
\v 25 Jeruja bakana koko, tajinani ngadani, ja jatana wonti: „Naupini koko Testamenta marra nganai, ngakangu kumarani; jenia ngankanau jeruntjaia pota jura tapai, ngakangu ngundrala.“   
\p
\v 26 Ngangau jeruntjaia poto jura ninapini buka tajiai, ja ninapini koko tapai, jura Kaparaia nari kaukaubai, Nauja wokarala tikanantulu.   
\p
\v 27 Jeruja: Warle wata talku ninapini buka tajiai kara, Kaparaia koko tapai kara, nulu Kaparaia palkundru ja kumarandru kalala manila nganai.   
\p
\v 28 Kulno munta winpateriatimai, ja jeruja nulu bukandru tajiatimai ja kokundru tapaiatimai.   
\p
\v 29 Ngangau warle wata talku tajiai ja tapai, nulu muntali kalala tajiai ja tapai, ngangau nulu Kaparaia palku wata pilki ngundrai.   
\p
\v 30 Jendrangundruja jurangu jela waltowalto ja muntja marapu nganai, ja marapu matja palina.   
\p
\v 31 Ngaiani munta kalala ngundraterinani, ngaiani wata kalala maninani.   
\p
\v 32 Ngaiani kalala maninani, Kaparali ngaianina nandrai, ngaiani wata mitalali jela kalala maninanto.  
\b  
\p
\v 33 Ngangau, ngakani ngatata worajai, jura jurborinani bukaia, kalkamalianimai.   
\p
\v 34 Kulno maua ngananani, nulu pungani tajiatimai, jura wata kalalaia jurborinanto. Mina morla, jenia ngato kurala nganai ngani wokaranani.   
\c 12  
\lit (Dakani jaura G. D. 10 Trinitatis.)  
\p
\v 1 Jaolaia potundru ngani wata jertapateriai, ngatata worajai, jura ko nganananto.   
\p
\v 2 Jura milkila, jura kana ko matja nganana, jura muramura ngapuni wapana wonti, worderu tanali jurana wapalkana wonti.   
\p
\v 3 Jendrangundruja ngato jurangu tinkari ngankai: Wata kulno, nulu Godaia Jaolali kaukaubai, Jesus dikidikibala nganai, ja kulno ngandandariai jatala: „Jesus Kapara nganai,“ windri Jaolali kulikirieli.   
\p
\v 4 Manjulaia potuja mangini marapu nganai, ja Jaola kulno;   
\p
\v 5 Ja ngankijiribanaia mangini marapu nganai, ja Kapara kulno:   
\p
\v 6 Ja ngurulaia mangini marapu nganai, ja Goda kulno, Nulia warupoto ngankai warupotuni.   
\p
\v 7 Pratjanani Nulia Jaolaia tinkari ngankani jinkiai mili marapu ngumuja.   
\p
\v 8 Kulnuni Nulia jinkiai Jaolali jaura kiri jatala; kulnuni Nulia jinkiai Nulupini Jaoiali ngujamani jaura jatala;   
\p
\v 9 Kulnuni morlalu ngundrani, nunkangupini Jaolali; kulnuni manjulaia poto tepi ngankanaia, nunkangupini Jaolali;   
\p
\v 10 Kulnuni pirnala ngankala, kulnuni talpadakala; kulnuni Jaola ngujangujamala; kulnuni tali nguja marapu; kulnuni tali mildiri ngankala.   
\p
\v 11 Jenipara pratjana Nulupini Jaolali kulnujeli ngankai, ja Nulia warupotuni pilki jinkiai, worderu Nauja jertapateriai.   
\p
\v 12 Ngangau worderu palku kulno nganai, ja nulia buru marapu ngamalkai, ja palku buru pratjana windri palku kulno nganai, jeruja bakana Christus.   
\p
\v 13 Ngangau ngaiani Jaola kulnujeli palku kulnuja multibanila manina wonti; ngaiani Juda kana kara Griekala kara, mili kara kurakanila kara, ja Nulia ngaianina pratjana Jaola kulnujeli kaljura ngankana wonti.   
\p
\v 14 Ngangau bakana palku wata buru kulno nganai, a‐ai, marapu.   
\p
\v 15 Tidna jatanani: Ngangau ngani wata mara nganai, jendrangundruja ngani wata palkuja nganai; nauja jendrangundruja wata palkuja nganai?   
\p
\v 16 Ja talpa jatanani: Ngani wata milki nganai, jendrangundruja ngani wata palkuja nganai; nauja jendrangundruja wata palkuja nganai?   
\p
\v 17 Palku windri milki ngananani, woderi ngarani parai? Nauja windri ngarani ngananani, woderi panimani parai?   
\p
\v 18 Jeruja Godali buru pratjanani pilki ja pilki kurana wonti, worderu Nulia ngantjana wonti.   
\p
\v 19 Tanaia pratjana windri buru kulno ngananani, woderi palku?   
\p
\v 20 Jeruja bura marapu nganai, ja windri palku kulno.   
\p
\v 21 Milki ngandandariai marani jatala: Ngato jidna wata ngundrai; ja nakaldra mangatandra tidnani: Ngato judlana wata ngundrai.   
\p
\v 22 A‐ai, tanaia palku buru, tananaia ngaiani ngundrai waltowalto, tanaia ngaianingu pirna nganai.   
\p
\v 23 Ja tanangu buruni, tananaia ngaiani wata pirna ngundrai, tanangu ngaiani morla pirnala jinkiai; ja tananaia ninta pani, ngaiani ninta pirna ngankai;   
\p
\v 24 Ja tananaia ninta pirna nganai, tanalia jenia wata ngamalkananto. Godali palku ngokana wonti, ja buru wangiwangini morla pirnala jinkina wonti.   
\p
\v 25 Ngangau wata puntibijiribamalina nganananto palkuni, a‐ai, buru pratjana manjujeli ngundrijiribamalinanto.   
\p
\v 26 Ja buru kulno ketjaketjanani, buru pratjana jela ketjaketjai; ja buru kulno pirna pantjinani, buru pratjana jela mankiai.   
\p
\v 27 Jura Christuni palku, ja pratjana pilki ja pilki buru nganai.   
\p
\v 28 Ja Godali palpa mili wolarani kurana wonti: Ngoperala Apostel, mandrula Propheta, parkula ngujangujara jinkinietja; ngadani pirnala ngankanietja, ngadani manjulaia poto tepia, marangokanietja, jirijiribanietja, tali nguja pilki ja pilki.   
\p
\v 29 Pratjana Apostel nganai? Pratjana Propheta nganai? Pratjana ngujangujara jinkinietja nganai? Pratjana pirnala ngankanietja nganai?   
\p
\v 30 Pratjana ngurula ngamalkai pirnala ngankala? Pratjanali tepi ngankani poto ngamalkai? Pratjana tali pilki ja pilkini jatai? Pratjanali mildiri ngankai?   
\p
\v 31 Jigleri ngananau poto ngumu pirna manila. Ja ngato jurangu palto ngumu pirna wondrala nganai.   
\c 13  
\lit (Dakani jaura G. D. Quinquagesimä.)  
\p
\v 1 Ngato kanaia ja angelaia talieli kaukaubanani, ja wata ngantjani ngamalkanani, jeruja ngani windri marda talingana nganai ja lingalinga ngaiala.   
\p
\v 2 Ja ngato talpadakani ngamalkanani, ja kurukurula warupoto ngujamanani, ja ngujamana warupoto ngamalkanani; ja morlalu ngundrani warupoto ngamalkanani, jeruja ngani ngurunguru ngananani mardawonpa tirimalkala, ja wata ngantjani ngamalkanani, jeruja ngani baku nganai.   
\p
\v 3 Ja ngato poto ngakani pratjana piltjaru ngankanani wangiwangini, ja palku jinkiterinani turuni jerkila, ja wata ngantjani ngamalkanani, jeruja jendralia ngana wata marangokai.   
\p
\v 4 Ngantjani manju nganai, ja ngumu nganai; ngantjani wata kaldririai, ngantjani wata pirna ngundrateriai, ja wata wombatjarai.   
\p
\v 5 Ngantjani wata pankipankiai, nauja wata muntapata nganai, ja tana ngandandariai ninaia kaldri ngankala, ja nulia wata kalalaia ngundrai.   
\p
\v 6 Nauja wata mankiai talkula panini, a‐ai, nauja mankiai morlalulali.   
\p
\v 7 Nulia pratjana mandrai, nulia pratjana morlalu ngundrai, nulia pratjanani kalkai, ja pratjanani manju nganai.   
\p
\v 8 Ngantjani wata mudai; talpadakani mudala nganai, tali pilkipilki jatana mudala nganai, ja ngujamani mudala nganai.   
\p
\v 9 Ngangau ngujamani ngaianini windri buru wuldru nganai, ja talpadakani ngaianini buru wuldru nganai.   
\p
\v 10 Manamirila matja wokaranani, buru wuldru mudala nganai.   
\p
\v 11 Ngani kupa ngananani, ngani jatana wonti kupa jeribaka ja ngundrana wonti kupali jeribaka, ja kaukaubana wonti kupali jeribaka; matja ngani materi, ngato kupalaia mangini worarana wonti.   
\p
\v 12 Karari ngaiani milkitjerieli jaura waluni najiai, ngadani mudlandru mudlani. Karari ngato ngujamai buru wuldrujeli, ngadani ngato nina kantji ngujamala nganai, worderu Nulia ngana ngujamai.   
\p
\v 13 Karari wonki nganai morlalu ngundrani, kalkani, ngantjani, tanapini parkulu; ja ngantjani morla pirna nganai pudlangu.  
\b  
\c 14  
\p
\v 1 Ngantjanani karipaterianau; jiglerali ngankanau Jaolaia poto manila, ja morla pirna, jura talpadakananto.   
\p
\v 2 Ngangau warle tali pilkieli jatai, nau wata kanani, a‐ai, Godani jatai; wata kulnujeli jenia ngujamai, Jaolali nau kurukurula jatai.   
\p
\v 3 Warle talpadakai, nau kanani jatai wotinaia, kurukurubanaia ja ngankalkanaia.   
\p
\v 4 Warle tali pilkieli jatai, nau munta wotiteriai; warle talpadakai, mili wolara wotiai.   
\p
\v 5 Ngato ngantjai, jura pratjana talieli jatananto, ja morla, jura talpadakananto; ngangau talpadakanietja morla pirna nganai tali pilki jatanietjani, windri nulu jenia bakana mildiri ngankananto mili wolara wotila.   
\p
\v 6 Karari, ngatata worajai, ngani jurangu wokaranani tali pilki jatanietja, mina ngani jurangu ngumu nganai, ngato jurangu wata kaukaubanani tinkari ngankanali kara, ngujamanali kara, talpadakani jaurali kara, ngujangujarali kara?   
\p
\v 7 Wima poto tepi pani, wima koko kara, wima kata kara, taltjinganani ja ngaru wata pilki pilki ngankanani, worderu kanali ngujamananto mina tanali wima kokujeli pulkai kara, wima katali nandrai kara?   
\p
\v 8 Ja wima koko ngaru walu jinkinani, worana ngankingaterinanto tirimalinaia?   
\p
\v 9 Jeruja bakana, jura tali pilkieli jaura karpakarpa jinkinani, worderu tanali jurani jaura ngujamananto? Jura jenipara nganala nganai, tanali ngaranani kaukaubai.   
\p
\v 10 Tali nguja pilki pilki marapu mitani nganai, ja wata kulno tanangundru jaura pani wondrai.   
\p
\v 11 Ngato talia ngundrana wata ngujamanani, ngani kaukaubanietjani tula nganai, ja kaukaubanietja ngakangu tula.   
\p
\v 12 Jeruja bakana jura, ngangau jura jigleri nganai jaolaia potuja, jigleri ngananau mili wolaraia wotinaia, jura pirna pantjinanto.   
\p
\v 13 Jendrania tali pilki kaukaubanietja ngatjinanto, nulu jenia bakana mildiri ngankananto.   
\p
\v 14 Ngani tali pilkieli ngatjinani, ngani jaolali ngatjiai, ja tjuru ngakani tandra pani nganai.   
\p
\v 15 Mina karari? Ngani ngatjila nganai jaolali, ngani bakana ngatjila nganai tjurujeli; ngato wonkala nganai jaolali, ngato bakana wonkala nganai tjurujeli.   
\p
\v 16 Jundru Jaolali jurokokanani, worderu kana mangupunkujeli Amen jatananto jinkani jurakokanani, ngangau nau ko nganai mina jidni jatai.   
\p
\v 17 Jundru ngumu jurakokai, windri jundru nguruni wata wotiai.   
\p
\v 18 Ngato Goda jurakokala wapaia, ngangau ngato tali pilkieli morla kaukaubai jurangu pratjanani.   
\p
\v 19 Mili wolarani ngato morla ngantjai jaura mara wora tjurujeli ngakanali kaukaubala, ngangau ngato bakana nguruni ngujangujara jinkinanto, jaura 10,000 talieli.   
\p
\v 20 Ngatata worajai, wata kupa waka pantjianau tjurujeli, a‐ai, madlentjali kupa pantjianau; tjurujeli manamiri pantjianau.   
\p
\v 21 Jirijiribani jaurani dakanala parai: „Tali pilkieli ja manamimi pilkieli ngato tanangupini kana wolarani kaukaubala nganai, ja bakana wata jeruja tanali ngana ngarala nganai, Kapara jatai.“   
\p
\v 22 Jeruja tali pilki malka nganai, wata tanangu, tanali morlalu ngundrai, a‐ai, tanangu, morlalu ngundrani panini; talpadakani wata tanangu, tana morlalu ngundrani panini, a‐ai, tanangu, tanali morlalu ngundrai.   
\p
\v 23 Mili wolara jurborinani, ja pratjanali talieli kaukaubanani, ja kana patipati kara kana morlalu ngundrani panini kara wirinani, tana wata jatala nganai jura jirijiri?   
\p
\v 24 Pratjanali talpadakanani, ja kana morlalu ngundrani panini kara kana patipati kulno kara wirinani, pratjanali nina karkarkala nganai, ja pratjana nulu ngundrala nganai.   
\p
\v 25 Ja nunkani ngaraia kurukurula tinkari pantjila nganai; ja jeruja nau mudlani woraterila nganai ja Godani ngatjila nganai, ja kaukaubala nganai, kantji Goda jurangunto nganai.   
\p
\v 26 Mina karari nganai, ngatata worajai? Jura jurborinani, kulnujeli Psalma kulno ngamalkai, nulu ngujangujara kulno ngamalkai, tinkari ngankani kulno kara, nulu jaura tali pilkieli ngamalkai, nulu mildiri ngankani kulno ngamalkai. Jenia pratjana wotinaia pantjiatimai!   
\p
\v 27 Kulnujeli tali pilkieli kaukaubanani mandrujeli kara parkulali kara jelali kaukaubananto, wata morla, ja kulnulu kulnulali, ja kulnujeli jenia mildiri ngankananto.   
\p
\v 28 Mildiri ngankanietja wata naka ngananani, nau ngapu nganananto mili wolarani. Nulu muntali ja Godani kaukaubananto.   
\p
\v 29 Propheta mandrujeli kara parkulali kara kaukaubananto, tanali palpali jenia wontjananto.   
\p
\v 30 Kulnuni, nau naka ngamanani, jaura tinkari pantjinani, ngoperala ngapurinanto.   
\p
\v 31 Jura kulnulu kulnulali talpadakananto, ngangau pratjana kiririnanto, ja pratjanali kurukurubani maninanto.   
\p
\v 32 Prophetaia jaolali Prophetani wodatarana ngamai;   
\p
\v 33 Ngangau Goda wata tjautjauja, a‐ai, murlaia Goda nganai.   
\p
\v 34 Worderu mili wolara kulikirini pratjanani, jeruja bakana widla jurani mili wolarani ngapu nganananto; ngangau tanangu wata manuni kurala wapaia jatananto, a‐ai, tana wodatarana ngamananto, worderu bakana jirijiribani jaura jatai.   
\p
\v 35 Tanali ngantjanani kiririla, tanali pungani noa tanani jakalkananto; ngangau widlani wata ngumu parai, mili wolarani kaukaubala.   
\p
\v 36 Jurangundru kara Godaia jaura dunkana wonti? Nauja kara windri jurangu wokarana wonti?   
\p
\v 37 Kulnujeli ngundranani nau Propheta nganai kara kana jaolanto kara, nulu ngujamaiatimai, mina ngato jurangu dakala wapaia, ngangau jenia Kaparaia jirijiribani jaura nganai.   
\p
\v 38 Kulnu jenia wata ngujamanani, nulu wata ngujamaiatimai.   
\p
\v 39 Jeruja, ngatata worajai, jigleri ngankanau talpadakala, ja tali pilkieli kaukaubala wata ngandrawalkanau.   
\p
\v 40 Pratjana ngumu ja talku pantjiatimai.   
\c 15  
\lit (Dakani jaura G. D. 11 Trinitatis.)  
\p
\v 1 Ngato jurangu tinkari ngankai, ngatata worajai, ngantjani jaura, ninaia ngato jurangu kaukaubana wonti, ninaia jura bakana patana wonti, ninapini jura bakana ngamalkala wapaia,   
\p
\v 2 Nunkangundru jura bakana tepi pantjila nganai, jura wonki ngamalkanani, mina jaurali ngato jurangu ninaia kaukaubana wonti, jura wata bakujeli morlalu ngundrani pantjina wonti.   
\p
\v 3 Ngangau ngato jurangu ngopera jinkina wonti, mina ngato bakana manina wonti, Christus palina wonti madlentji ngaianandru, worderu jaura worali kaukaubai;   
\p
\v 4 Ja tanali ninaia todina wonti, ja Nauja jiritjina tarana wonti ditjini parkulani, worderu jaura worali kaukaubai.   
\p
\v 5 Ja Nauja wondraterina wonti Kephangu, ngadani marapratjana ja mandruni   
\p
\v 6 Ngadani Nauja wondraterina wonti moria 500 ngatatani pota kulno, tanangundru marapu tepi ngamala wapaia, ja palpa matja turarai.   
\p
\v 7 Ngadani Nauja wondraterina wonti Jakobungu, ngadani Apostel worangu.   
\p
\v 8 Mili warupotuni ngadani Nauja bakana ngakangu wondraterina wonti tidari jeri, nau ditji talkuja woljaia dankanala.   
\p
\v 9 Apostel worangu ngani wata talku nganai Apostel tala ngamalkala, ngangau ngani Godaia mili wolarani tirikaripaterina wonti.   
\p
\v 10 Windri Godaia manjulandru ngani nganai mina ngani nganai, ja manjula nunkani ngakangu wata baku nganana wonti, a ai, ngato morla ngankana wonti tanangu pratjanani, ja wata ngato, a‐ai, Godaia manjula ngakangunto.   
\p
\v 11 Ngato kara, tanali kara: Jeruja ngaiani jaura jinkiai, ja jeruja jura morlalu ngundranala.   
\p
\v 12 Ngujangujara Christungundru paranani, Nauja narindru jiritjina wonti, worderu kana palpa jurangu terti jatai, narila wata jiritjiai?   
\p
\v 13 Narila wata jiritjinani, jeruja bakana Christus wata jiritjina wonti.   
\p
\v 14 Christus wata narindru jiritjina wontinani, jeruja bakana ngujangujara ngaianini kala ngananani, ja bakana jurani morlalu ngundrani kala nganai.   
\p
\v 15 Ngaiani bakana jeruja jedi tinkari ngankanietja nganai Godaia, ngangau ngaiani tinkari ngankana warai Godani, Nulia Christus jiritjibana wonti, ninaia Nulia wata jiritjibana wonti, narila wata jiritjinani.   
\p
\v 16 Narila wata jiritjinani, jeruja bakana Christus wata jiritjina wonti.   
\p
\v 17 Christus wata jiritjina wontinani, jurani morlalu ngundrani baku ngananani, ja kararielu jura madlentjani juranani ngamanani;   
\p
\v 18 Jeruja bakana tana, Christungu matja parala wapaia, tintaterina warai.   
\p
\v 19 Ngaiani windri jenipara ngananani, tana nunkangupini tepini Christungu kalkanani, ngaiani morla wangiwangi ngananani kanani worupotuni.   
\p
\v 20 Karari Christus matja narindru jiritjina wonti, ja ngoperala pantjina wonti tanangu, tana mukaturarala wapaia.   
\p
\v 21 Jeruja kana kulnundru nari, bakana kana kulnundru narindru jiritjini nganai.   
\p
\v 22 Ngangau worderu Adamangu pratjana paliai, jeruja bakana Christungu pratjana tepi pantjila nganai.   
\p
\v 23 Pratjana tanani wittani; Ngoperala Christus, ngadani tana, tana Christungu jela nganai, Nauja tikanani;   
\p
\v 24 Ngadani mudani, Nulia milila Goda Ngaperani matja jinkina, ja Nulia kapara pratjana ja ngurula pratjana ja pirnala pratjana matja teribana.   
\p
\v 25 Ngangau Nauja Kapara nganananto, Nulia talpala pratjana nunkangu tidnani kuranantulu.   
\p
\v 26 Pratjanani ngadani Nulia mudani talpala, ninaia nari, teribala nganai.   
\p
\v 27 Ngangau warupoto Nulia nunkangu tidnani kurana wonti. Nauja jatanani: Warupoto nunkangu matja kurana, jeruja kantji kalitakali Naujata, nunkangu Nulia warupoto kurana wonti.   
\p
\v 28 Nunkangu warupoto matja kurana, ngadani bakana Nauja Ngatamura kuraterila nganai nunkangu, Nulia nunkangu warupoto matja kurana, ngangau Goda warupoto nganananto warupotuni.   
\p
\v 29 Mina tanali ngankala nganai, tanali multibanila maniai kana narini? Kana nari wata jiritjinani, minandru tanali multibanila maniai kana narini?   
\p
\v 30 Minandru ngaiani ditji pratjanani ketjaketjanani terkai?   
\p
\v 31 Ditji pratjanani ngani palila wapaia jurakokaterina jurangundru, ninaia ngato ngamalkai Kapara ngaiananani Jesungu Christungu.   
\p
\v 32 Ngani kana jeribaka Ephesungu nganti tirini tirimalina wonti, mina ngato ngamalkai nunkangundru? Narila wata jiritjinani, ngaiani tajinanto ja tapananto, ngangau tankubana ngaiani matja nari.   
\p
\v 33 Ngamalkaterianau karkarkanandru: „Ngankamalina madlentji ngamana ngumu tjautjau ngankai.“   
\p
\v 34 Tepirianau, ja wata madlentji ngankanau; ngangau palpali Goda wata ngujamai, jurangu nintaia ngani jenia jatai.   
\p
\v 35 Kulno jatala nganai: Worderu narila jiritjila nganai? Ja mina palkujeli tana dunkala nganai?   
\p
\v 36 Jidni patipatiai! Mina jundru jaupai wata tepi pantjiai, a‐ai, jenia ngopera palinanto.   
\p
\v 37 Ja minanina jundru jaupai, jenia wata naupini palku nganai, nau pantjinanto, a‐ai, windri tandra balu, buka tandra kara tandra nguja pilki kara.   
\p
\v 38 Godali nunkangu palku jinkiai, worderu Nauja jertapaterina wonti, ja tandra nguja pilki ja pilkini palku pilki ja pilki.   
\p
\v 39 Wata nganti pratjana jeribaka nganai, a‐ai, kanaia nganti pilki, ngantia nganti pilki, paia nganti pilki, paru nganti pilki.   
\p
\v 40 Ja pariwilpaia palku ja mitaia palku parai; tananina pariwilpaia pirnala nguja pilki nganai, ja tananina mitaia pilki nganai.   
\p
\v 41 Ditji pirnaia mintjini pilki nganai, ja piraia mintjini pilki nganai, ja ditji wakaia mintjini pilki nganai; ja ditji waka kulno morla pirna mintjiai kulnuni.   
\p
\v 42 Jeruja bakana narila jiritjini nganai. Tanali nina jaupai puapuarinani, ja Nulia nina jiritjibala nganai wata puapuarinani.   
\p
\v 43 Tanali nina jaupai pirnala panini, ja Nulia nina jiritjibala nganai pirnalani. Tanali nina jaupai waltowaltuni, ja Nulia nina jiritjibala nganai ngurunguruni.   
\p
\v 44 Tanali jaupai mungara palku; ja Nulia jiritjibala nganai jaola palku. Mungaraia palku ngananani, jeruja bakana jaolaia palku ngananani.   
\p
\v 45 Jeruja bakana dakanala parai: „Kana ngoperala, Adam, pantjina wonti mungara tepia; Adam ngadala tepi ngankani jaolaia.“   
\p
\v 46 Jaolaia palku wata ngopera nganana wonti, a‐ai, mungaraia, ngadani jaolaia.   
\p
\v 47 Kana ngoperala mitandru nganai, mita kana; kana mandrula pariwilpandru nganai.   
\p
\v 48 Worderu mitala nganai, jeruja bakana mitala wolara nganai; ja worderu pariwilpala nganai, jeruja bakana pariwilpala wolara nganai.   
\p
\v 49 Ja worderu ngaiani mitalaia mudla mandrana warai, jeruja ngaiani bakana pariwilpalaia mudla mandrala nganai.   
\p
\v 50 Jenia ngani jatai, ngatata worajai, palku ja kumari ngandandariai Godaia milila maratunka manila; bakana puapuarinali puapuarini panini wata maratunka manila nganai.   
\p
\v 51 Mai! Ngani jaura kurukuru jurangu jatai: Wata ngaiani pratjana palila nganai, a‐ai, Nulia ngaianina pratjana karitjimalkala nganai.   
\p
\v 52 Nurujeli, milkiwirpini kulnuni, wima koko ngadalani. Ngangau wima koko ngaru maritjila nganai, ja Nulia narila jiritjibala nganai puapuarini panini, ja Nulia ngaianina karitjimalkala nganai.   
\p
\v 53 Ngangau naupini puapuarini widmaterila nganai puapuarini panila, ja naupini narila widmaterila nganai nari panila.   
\p
\v 54 Naupini puapuarini widmaterina warai puapuarini panila, ja naupini narila widmaterina warai nari panila, ngadani jaura morlalu pantjila nganai, mina dakanala parai:   
\p
\v 55 „Nari julkana warai kalalu ngankanaia. Nariai, woderi dilka jinkani? Turujai, woderi kalalu ngankana jinkani?“   
\p
\v 56 Naria dilka madlentji nganai, madlentjaia ngurula jirijiribani jaura nganai.   
\p
\v 57 Godani jurakokana nganaiatimai, ngangau Nulia ngaianingu kalalu ngankana jinkiai ngaianani Kapara Jesu Christungundru.   
\p
\v 58 Jendrangundruja, ngatata ngantjalu ngakani, ngurunguru, taturu, ja poto pirna pantjianau Kaparaia ngankanani milingeru, ngangau jura milkila, ngankani jurani wata baku nganai Kaparani.   
\c 16  
\p
\v 1 Kampanandru kulikirilaia, worderu ngato mili wolarani Galatiani kuranala, jeruja bakana jura ngankanau.   
\p
\v 2 Godaia ditji pratjanani jurangundru pilki ja pilki kuraiatinimai ja kampaiatinimai, mina tanali ngundrai, ngangau kampala wata woninanto ngani matja wokaranani.   
\p
\v 3 Ngani matja wokarana, ngato tanana, jura talku ngundrai, dakani jaurali jinpala nganai, tanali kalumiltjamiltjarini jurani Jerusalemia padakananto.   
\p
\v 4 Jenia pirna ngananani, ngani bakana palkananto, tana ngakangu jela palkananto.   
\p
\v 5 Ngani jurangu wokarala nganai, ngani Macedoniani matja palkingana warai; ngangau Macedoniani ngani palkingala nganai.   
\p
\v 6 Jurangu jela ngani ngamala nganai, bakana kilpawirdi ngamala nganai kara, jura ngakangu jela palkananto, wodajeri ngani palkanani.   
\p
\v 7 Ngato wata ngantjai karari jurana najila, ngani wiringanani; ngato kalkai jurangu jela miljaru palpa ngamala, Kaparali jenia manuni kuranani.   
\p
\v 8 Ngani Ephesungu ngamala nganai Jaolaia ditjielu.   
\p
\v 9 Ngangau mana pirna ngakangu piririna warai ngankana marapuja, ja talpala marapu nganai.   
\p
\v 10 Timotheus wokaranani, najianau, nau japanguru jurangu jela nganananto; ngangau Kaparaia ngankana nulu ngankai, ngakangu jeribaka.   
\p
\v 11 Wata kulnujeli nina waka ngundraiatimai! Murlali nina jinpanau, nau ngakangu wokarananto; ngangau ngatatani jela ngato nunkangu kalkai.   
\p
\v 12 Apollo ngatatandru, ninaia ngato kurukurubana warai, nauja ngatatani jela jurangu wokarananto, ja nauja karari wata jertapateriai wokarala; nauja wokarala nganai miljaru ngumuni.   
\p
\v 13 Tepi ngamanau, taturu ngamanau, morlalu ngundrani materi ngananau, ngurunguru ngananau!   
\p
\v 14 Jurani poto pratjana ngantjanani pantjiatinimai.   
\p
\v 15 Ngato jurana kurukurubai, ngatata worajai, jura Stephanani pungala ngujamai, tana ngoperala nganai Achajani, tana munta ngankaterinala kulikirila ngamalkijiribanaia;   
\p
\v 16 Bakana jura jenipara kanani wodatarana ngamananto, ja pratjanani, tanali jela ngankai ja jiglerali ngankai.   
\p
\v 17 Ngani mankila wapaia Stephanani ja Fortunatuni ja Achaikuni wokaranandru, ngangau tana jurangu panini ngakangu jela ngamana warai.   
\p
\v 18 Tanali jaola ngakani ja jurani murlali ngankana warai; jenipara kana ngujamanimai.   
\p
\v 19 Asialali mili wolara pilki pilkieli jurangu mandurini jaura jinkiai. Jurangu mandurini jaura jinkiai Kaparani Aquilali ja Priscillali, ja mili wolarali pudlani pungani.   
\p
\v 20 Jurangu mandurini jaura jinkiai ngatata pratjanali. Mandurini jaura jinkimalianimai manatapani kulikirieli.   
\p
\v 21 Ngato Paululu jurangu mandurini jaura jinkiai marali ngakanali.   
\p
\v 22 Kulnujeli Kapara Jesus Christus wata ngantjanani, nau nganaiatimai Anathema. Maran Atha.   
\p
\v 23 Kapara Jesuni Christuni manju jurangunto nganaiatimai.   
\p
\v 24 Ngantjani ngakani jurangu pratjanani nganai Christungu Jesungu.   