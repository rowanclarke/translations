\id ISA - Biblica® Open Shona Contemporary Bible 2017 
\h Isaya 
\toc1 Isaya 
\toc2 Isaya 
\toc3 Isa 
\mt1 ISAYA 
\c 1  
\p  
\v 1 Chiratidzo chaIsaya mwanakomana waAmozi, chaakaona pamusoro peJudha neJerusarema pamazuva aUzia naJotamu, naAhazi naHezekia, madzimambo eJudha. 
\s1 Rudzi Runomukira 
\q1  
\v 2 Inzwai imi matenga! Teerera iwe nyika! 
\q2 Nokuti Jehovha akataura achiti, 
\q1 “Ndakarera vana ndikavakudza, 
\q2 asi ivo vakandimukira. 
\q1  
\v 3 Nzombe inoziva vatenzi vayo, 
\q2 nembongoro inoziva chidyiro chomwene wayo, 
\q1 asi Israeri haizivi, 
\q2 vanhu vangu havanzwisisi.” 
\q1  
\v 4 Haiwa, rudzi runotadza, 
\q2 vanhu vakaremerwa nezvakaipa, 
\q1 vana vavaiti vezvakaipa, 
\q2 vana vanoita zvakaora! 
\q1 Vakasiya Jehovha; 
\q2 vakashora Mutsvene waIsraeri 
\q2 vakamufuratira. 
\b  
\q1  
\v 5 Mucharambireiko muchingorohwa? 
\q2 Munorambireiko muchimukira Jehovha? 
\q1 Musoro wenyu wose wakuvadzwa, 
\q2 mwoyo wenyu wose warwadziwa. 
\q1  
\v 6 Kubvira pasi porutsoka rwako kusvikira panhongonya yomusoro 
\q2 wako hapana pakukutu, 
\q1 anongova maronda nokurwadziwa 
\q2 namavanga akazaruka, 
\q1 asina kusukwa kana kusungwa 
\q2 kana kuzorwa mafuta. 
\b  
\q1  
\v 7 Nyika yenyu yaparadzwa, 
\q2 Maguta enyu apiswa nomoto; 
\q1 minda yenyu iri kutorwa navatorwa 
\q2 pamberi penyu chaipo, 
\q2 nyika yaparadzwa sapanoparadza vatorwa. 
\q1  
\v 8 Mwanasikana weZioni asiyiwa sedumba 
\q2 mumunda wemizambiringa, 
\q1 seimba mumunda wamanwiwa, 
\q2 seguta rakakombwa. 
\q1  
\v 9 Dai Jehovha Wamasimba Ose 
\q2 asina kutisiyira vakapunyuka, 
\q1 tingadai takafanana neSodhomu, 
\q2 tingadai takaita seGomora. 
\b  
\q1  
\v 10 Inzwai shoko raJehovha, 
\q2 imi vabati veSodhomu; 
\q1 teererai kumurayiro waMwari wedu, 
\q2 imi vanhu veGomora! 
\q1  
\v 11 “Zvibayiro zvenyu zvizhinji, 
\q2 zvinyiko kwandiri?” ndizvo zvinotaura Jehovha. 
\q1 “Zvibayiro zvinopiswa zvawandisa, 
\q2 zvamakondobwe namafuta ezvipfuwo zvakakodzwa; 
\q1 Handifadzwi neropa renzombe, 
\q2 ramakwayana nerembudzi. 
\q1  
\v 12 Pamunouya kuzozviratidza pamberi pangu, 
\q2 ndianiko akambokukumbirai izvi kwamuri, 
\q2 naikoku kutsika-tsika pavazhe dzangu? 
\q1  
\v 13 Regai kuuya nezvipiriso zvisina maturo! 
\q2 Zvinonhuhwira zvenyu zvinondinyangadza. 
\q1 Nguva dzoKugara kwoMwedzi, maSabata nenguva dzekokorodzano, 
\q2 handigoni kufarira ungano dzenyu dzakaipa. 
\q1  
\v 14 Mitambo yenyu yoKugara kwoMwedzi nemitambo yenyu yakatsaurwa inovengwa 
\q2 nomweya wangu. 
\q1 Zvava mutoro kwandiri; 
\q2 ndaneta nokuzvitakura. 
\q1  
\v 15 Pamunotambanudza maoko enyu muchinyengetera, 
\q2 ini ndichakuvanzirai chiso changu; 
\q1 kunyange mukawanza munyengetero, 
\q2 handisi kuzokunzwai. 
\q1 Maoko enyu azere neropa; 
\q2  
\v 16 shambai muzvinatse. 
\q1 Bvisai mabasa enyu akaipa 
\q2 pamberi pangu! 
\q1 Regai kuita zvakaipa, 
\q2  
\v 17 dzidzai kuita zvakarurama. 
\q1 Tsvakai kururamisira, 
\q2 kurudzirai vakamanikidzwa. 
\q1 Dzivirirai nherera, 
\q2 mukumbirire chirikadzi. 
\b  
\q1  
\v 18 “Chiuyai zvino titaurirane,” 
\q2 ndizvo zvinotaura Jehovha. 
\q1 “Kunyange zvivi zvenyu zviri 
\q2 zvitsvuku zvichachena sechando; 
\q1 kunyange zviri zvishava somuti mushava, 
\q2 zvichaita samakushe amakwai. 
\q1  
\v 19 Kana muchida uye muchiteerera 
\q2 muchadya zvakanakisa zvenyika; 
\q1  
\v 20 asi kana muchiramba uye muchindimukira, 
\q2 muchaparadzwa nomunondo.” 
\q4 Nokuti muromo waJehovha wazvitaura. 
\b  
\q1  
\v 21 Tarirai guta rakatendeka 
\q2 rava chifeve sei! 
\q1 Iro rakanga rizere nokururamisira; 
\q2 kururama kwaigara mariri, 
\q2 asi zvino mogara mhondi! 
\q1  
\v 22 Sirivha yako yava nengura, 
\q2 waini yako yakavhenganiswa nemvura. 
\q1  
\v 23 Machinda ako vapanduki, 
\q2 ishamwari dzembavha; 
\q1 vose vanoda fufuro, 
\q2 uye vanomhanyira zvipo. 
\q1 Havana hanya nokudzivirira nherera; 
\q2 mhaka yechirikadzi haiuyiswi pamberi pavo. 
\q1  
\v 24 Naizvozvo Ishe, Jehovha 
\q2 Wamasimba Ose, Anesimba waIsraeri, anotaura achiti, 
\q1 “Haiwa, ndichadurura hasha dzangu pamusoro pavadzivisi vangu, 
\q2 nokuzvitsivira vavengi vangu. 
\q1  
\v 25 Ndichatambanudzira ruoko rwangu kwauri; 
\q2 ndichapedza chose ngura yako 
\q2 ndigobvisa kusachena kwako kwose. 
\q1  
\v 26 Ndichadzosera vatongi vako sapamazuva akare, 
\q2 namakurukota ako sapamazuva okutanga. 
\q1 Shure kwaizvozvo uchanzi 
\q2 Guta Rokururama, 
\q2 Guta Rakatendeka.” 
\b  
\q1  
\v 27 Zioni richadzikinurwa nokururamiswa, 
\q2 navanotendeuka varo, nokururama. 
\q1  
\v 28 Asi vapanduki navatadzi vachaparadzwa vose, 
\q2 uye vose vanosiya Jehovha vachaparara. 
\b  
\q1  
\v 29 “Nokuti muchanyadziswa nokuda kwemiti yomuouki yamunoeresa, 
\q2 yamunofadzwa nayo; 
\q1 muchanyadziswa nokuda kwamapindu 
\q2 amakasarudza. 
\q1  
\v 30 Muchafanana nomuouki wasvava mashizha, 
\q2 sebindu risina mvura. 
\q1  
\v 31 Murume ane simba achava serwodzi 
\q2 nebasa rake sesasaradzi; 
\q1 zvose zvichatsva pamwe chete, 
\q2 pasina achadzima moto.” 
\c 2  
\s1 Gomo raJehovha 
\p  
\v 1 Izvi ndizvo zvakaonekwa naIsaya mwanakomana waAmozi, pamusoro peJudha neJerusarema: 
\p  
\v 2 Mumazuva okupedzisira, 
\q1 gomo retemberi yaJehovha richasimbiswa, 
\q2 richava guru pakati pamakomo; 
\q1 richakwiridzirwa pamusoro pezvikomo, 
\q2 uye ndudzi dzose dzichamhanyira kwariri. 
\p  
\v 3 Ndudzi zhinji dzichauya dzichiti, 
\q1 “Uyai ngatiendei kugomo raJehovha, 
\q2 kuimba yaMwari waJakobho 
\q1 Iye achatidzidzisa nzira dzake, 
\q2 kuitira kuti tigofamba mumakwara ake.” 
\q1 Nokuti murayiro uchabva paZioni, 
\q2 shoko raJehovha richabva kuJerusarema. 
\q1  
\v 4 Achatonga pakati pendudzi 
\q2 uye achapedza gakava pakati pamarudzi mazhinji. 
\q1 Vachapfura minondo yavo vagoiita miromo yamagejo, 
\q2 namapfumo avo vagoaita mapanga okuchekerera miti nawo. 
\q1 Rudzi rumwe harungazosimudziri munondo kuno rumwe rudzi, 
\q2 kana kuzodzidzirazve kurwa. 
\p  
\v 5 Uyai, imi imba yaJakobho, 
\q2 ngatifambei muchiedza chaJehovha. 
\s1 Zuva raJehovha 
\q1  
\v 6 Nokuti makasiya vanhu venyu, 
\q2 ivo imba yaJakobho. 
\q1 Vakazara nezvinamato zvokuMabvazuva; 
\q2 vanoita zvokuvuka kufanana navaFiristia, 
\q2 vachibatana maoko nevedzimwe ndudzi. 
\q1  
\v 7 Nyika yavo izere nesirivha negoridhe; 
\q2 pfuma yavo haiperi. 
\q1 Nyika yavo izere namabhiza; 
\q2 ngoro dzavo hadziperi. 
\q1  
\v 8 Nyika yavo izere nezvifananidzo; 
\q2 vanopfugamira mabasa amaoko avo, 
\q2 kuzvinhu zvakaitwa neminwe yavo. 
\q1  
\v 9 Naizvozvo munhu achaderedzwa 
\q2 uye marudzi avanhu achaninipiswa, 
\q2 musavakanganwira. 
\b  
\q1  
\v 10 Pinda mumapako, 
\q2 uvande muguruva, 
\q1 ubve mukutyisa kwaJehovha 
\q2 nokubwinya kwoumambo hwake! 
\q1  
\v 11 Meso omunhu anozvikudza achaninipiswa, 
\q2 uye kuzvikudza kwavanhu kuchaderedzwa; 
\q1 asi Jehovha oga ndiye achakudzwa pazuva iro. 
\b  
\q1  
\v 12 Nokuti Jehovha Wamasimba Ose 
\q2 ane zuva raakachengetera avo vose 
\q2 vanozvikudza navanodada, 
\q2 navose vanokudzwa (uye vachaninipiswa), 
\q1  
\v 13 nemisidhari yose yeRebhanoni, yakareba neyakakwirira, 
\q2 nemiouki yose yeBhashani, 
\q1  
\v 14 namakomo ose akakwirira, 
\q2 nezvikomo zvose zvakakwirira, 
\q1  
\v 15 neshongwe dzose dzakakwirira, 
\q2 namasvingo ose akasimba, 
\q1  
\v 16 nezvikepe zvose zveTashishi, 
\q2 nemidziyo yose yakanaka. 
\q1  
\v 17 Kuzvikudza kwomunhu kuchaderedzwa, 
\q2 uye kuzvikudza kwavanhu kuchaninipiswa; 
\q1 Jehovha oga ndiye achakudzwa pazuva iro, 
\q2  
\v 18 uye zvifananidzo zvichapera zvachose. 
\b  
\q1  
\v 19 Vanhu vachatizira kumapako amatombo, 
\q2 nokumwena yapasi 
\q1 nokuda kwaJehovha anotyisa, 
\q2 uye nokubwinya kwoumambo hwake, 
\q2 paanosimuka achizungunutsa nyika. 
\q1  
\v 20 Pazuva iro vanhu vacharasira 
\q2 kumakonzo nokuzviremwaremwa, 
\q1 zvifananidzo zvavo zvesirivha nezvifananidzo zvegoridhe, 
\q2 zvavakaita kuti vazvinamate. 
\q1  
\v 21 Vachatizira kumapako amatombo 
\q2 nokumikaha yakarembera, 
\q1 nokuda kwokutya Jehovha, 
\q2 uye nokubwinya kwoumambo hwake, 
\q2 paanosimuka kuti azungunutse nyika. 
\b  
\q1  
\v 22 Regai kuvimba nomunhu, 
\q2 anongova nokufema mumhino dzake. 
\q1 Anobatsireiko? 
\c 3  
\s1 Kutongwa kweJerusarema neJudha 
\q1  
\v 1 Tarirai zvino, Ishe Jehovha 
\q2 Wamasimba Ose 
\q1 ava kuda kutora zvose rutsigiro nomudonzvo, 
\q2 kubva kuJerusarema neJudha; 
\q1 rutsigiro rwose rwezvokudya norutsigiro rwose rwemvura, 
\q2  
\v 2 mhare nomurwi, 
\q1 mutongi nomuprofita, 
\q2 muvuki nomukuru, 
\q1  
\v 3 mukuru wamakumi mashanu nomunhu anokudzwa, 
\q2 gurukota nomurume weumhizha, nomuvuki anoziva. 
\q1  
\v 4 Ndichaita kuti majaya ave vabati vavo; 
\q2 vana vadiki ndivo vachavatonga. 
\q1  
\v 5 Vanhu vachadzvinyirirana, 
\q2 munhu nomunhu, muvakidzani nomuvakidzani. 
\q1 Vadiki vachamukira vakuru, 
\q2 nounozvidza achamukira anokudzwa. 
\b  
\q1  
\v 6 Murume achabata mumwe wavanunʼuna vake 
\q2 paimba yababa vake achiti, 
\q1 “Ndiwe une nguo, chiva mutungamiri wedu; 
\q2 iva mutariri wedutu roungwandangwanda uhu!” 
\q1  
\v 7 Asi pazuva iro achadanidzira achiti, 
\q2 “Handigoni kugadzirisa zvinhu. 
\q1 Handina chokudya kana chokufuka mumba mangu; 
\q2 musandiita mutungamiri wavanhu.” 
\b  
\q1  
\v 8 Jerusarema rozungunuka, 
\q2 Judha riri kuwa; 
\q1 mashoko avo nezviito zvavo zvinopesana naJehovha, 
\q2 vachizvidza kuvapo kwake kunobwinya. 
\q1  
\v 9 Zvinoonekwa pazviso zvavo zvinovapupurira; 
\q2 vanoburitsa chivi chavo pachena seSodhomu; 
\q2 havambochivanzi. 
\q1 Vane nhamo! 
\q2 Vanouyisa njodzi pamusoro pavo. 
\b  
\q1  
\v 10 Udzai vakarurama kuti zvichavanakira, 
\q2 nokuti vachanakirwa nezvibereko zvamabasa avo. 
\q1  
\v 11 Vane nhamo vakaipa! Njodzi yava kuda kuvawira! 
\q2 Vacharipirwa zvakabatwa namaoko avo. 
\b  
\q1  
\v 12 Vadiki vanomanikidza vanhu vangu, 
\q2 vakadzi vanovatonga. 
\q1 Haiwa, vanhu vangu, vatungamiri venyu vanokutsausai; 
\q2 vanokubvisai munzira. 
\b  
\q1  
\v 13 Jehovha anotora nzvimbo yake muimba yokutonga; 
\q2 anosimuka kuti atonge vanhu. 
\q1  
\v 14 Jehovha anopinda mukutonga vakuru 
\q2 navatungamiri vavanhu vake achiti, 
\q1 “Ndimi makaparadza munda wangu womuzambiringa; 
\q2 zvakapambwa zvinobva kuvarombo zviri mudzimba dzenyu. 
\q1  
\v 15 Munoreveiko zvamunopwanya vanhu vangu, 
\q2 uye muchikuya zviso zvavarombo?” 
\q4 ndizvo zvinotaura Ishe Jehovha Wamasimba Ose. 
\b  
\q1  
\v 16 Jehovha anoti, 
\q2 “Vakadzi veZioni vanozvikudza, 
\q1 vanofamba vakamisa mitsipa yavo. 
\q2 Vachichonya nameso avo, 
\q1 uye vanofamba vachinzenzeta, 
\q2 vaine zvishongo zvinorira muzviziso zvamakumbo avo. 
\q1  
\v 17 Naizvozvo Jehovha achauyisa maronda pamisoro yavakadzi veZioni; 
\q2 Jehovha achaitisa misoro yavo mhanza.” 
\p  
\v 18 Pazuva iro Jehovha achabvisa pazviziso zvamakumbo avo: mabhenguro, nezvishongo zvomusoro, neungetani hwomutsipa hunonʼaima,  
\v 19 nemhete dzenzeve, nezvingetani zvomumaoko, namavhoiri  
\v 20 nezvishongo zvebvudzi, nezvingetani zvomuzviziso zvamakumbo, nemasikavha, namabhodhoro amafuta anonhuhwira, namazango,  
\v 21 nemhete, noukomba hwemhino,  
\v 22 nenguo dzakanaka dzomutambo, nezvijasi, namakepesi namajasi nezvikwama,  
\v 23 nezvionioni, nenguo dzomucheka wakaisvonaka, nezvishongo namashaweri. 
\q1  
\v 24 Pachinzvimbo chezvinonhuhwira, pachava nokunhuhwa; 
\q2 pachinzvimbo chesikavha, pachava netambo; 
\q1 pachinzvimbo chebvudzi rakashongedzwa zvakanaka, 
\q2 pachava nemhanza; pachinzvimbo chembatya dzakaisvonaka, pachava nechipfeko chesaga; 
\q2 pachinzvimbo chorunako, pachava nokupiswa. 
\q1  
\v 25 Varume venyu vachafa nomunondo, 
\q2 varwi venyu vachafa muhondo. 
\q1  
\v 26 Masuo eZioni achachema uye achaungudza; 
\q2 nokutambura kwaro, richagara pasi. 
\c 4  
\q1  
\v 1 Pazuva iro vakadzi 
\q2 vanomwe vachabata murume mumwe vagoti, 
\q1 “Tichadya zvokudya zvedu 
\q2 uye tichazvitsvakira zvokufuka. 
\q1 Tinongoda kudanwa nezita rako bedzi. 
\q2 Bvisa kunyadziswa kwedu!” 
\s1 Davi raJehovha 
\p  
\v 2 Pazuva iro, davi raJehovha richava rakanaka uye richabwinya, uye zvibereko zvenyika zvichava chidadiso nokukudzwa kwavakapunyuka muIsraeri.  
\v 3 Vaya vakasara muZioni, navakasara muJerusarema, vachanzi vatsvene, navose vakanyorwa pakati pavapenyu muJerusarema.  
\v 4 Jehovha achashambidza tsvina yevakadzi veZioni; achanatsa makwapa eropa kubva muJerusarema nomweya wokutonga uye nomweya womoto.  
\v 5 Ipapo Jehovha achasika pamusoro pegomo rose reZioni napamusoro pavose vanoungana ikoko gore routsi masikati nezhenje romoto unopfuta usiku; pamusoro pokubwinya kwose pachava nechidzitiro.  
\v 6 Chichava chifukidzo nomumvuri kubva pakupisa kwezuva, noutiziro, nenzvimbo yokuvanda kubva padutu nemvura inonaya. 
\c 5  
\s1 Rwiyo rwoMunda weMizambiringa 
\q1  
\v 1 Ndichaimbira mudiwa wangu 
\q2 rwiyo pamusoro pomunda wake wemizambiringa: 
\q1 Mudiwa wangu akanga ane munda wake wemizambiringa, 
\q2 pachikomo chakaorera. 
\q1  
\v 2 Akautimbira akabvisa mabwe 
\q2 akasimamo mazambiringa akaisvonaka. 
\q1 Akavaka shongwe mukati mawo 
\q2 uye akauchererawo chisviniro chewaini. 
\q1 Ipapo akatarisa kuti awane zvibereko zvamazambiringa akanaka, 
\q2 asi iwo wakangobereka muchero wakaipa chete. 
\q1  
\v 3 “Zvino imi vagari vomuJerusarema nemi varume veJudha, 
\q2 chitongai pakati pangu nomunda wemizambiringa wangu. 
\q1  
\v 4 Chiiko chimwezve chaifanira kuitirwa munda wangu 
\q2 wemizambiringa chandisina kuuitira? 
\q1 Pandakatsvaka mazambiringa akanaka, 
\q2 wakagoberekerei akaipa oga? 
\q1  
\v 5 Zvino ndichakuudzai 
\q2 zvandichaitira munda wangu wemizambiringa: 
\q1 Ndichabvisa ruzhowa rwawo, 
\q2 ugoparadzwa; 
\q1 ndichaputsa rusvingo rwawo, 
\q2 ugochatsikwa-tsikwa. 
\q1  
\v 6 Ndichauita nzvimbo yamarara, 
\q2 hauzochekererwi kana kusakurirwa, 
\q2 uye minzwa norukato zvichakuramo. 
\q1 Ndicharayira makore kuti 
\q2 arege kunayisa mvura pamusoro pawo.” 
\b  
\q1  
\v 7 Munda womuzambiringa waJehovha Wamasimba Ose 
\q2 ndiwo imba yaIsraeri, 
\q1 uye varume veJudha 
\q2 ndivo bindu rake rinomufadza. 
\q1 Zvino akatarisira kururamisira asi akaona kuteuka kweropa; 
\q2 akatsvaka kururuma, asi akanzwa kuchema kwokutambudzika. 
\s1 Nhamo noKutongwa 
\q1  
\v 8 Mune nhamo imi munowedzera dzimba nedzimba 
\q2 uye munobatanidza munda nomunda, 
\q1 kusvikira pasisina nzvimbo yasara, 
\q2 mugogara moga munyika. 
\p  
\v 9 Jehovha Wamasimba Ose akataura ndichinzwa akati, 
\q1 “Zvirokwazvo dzimba zhinji dzichava matongo, 
\q2 dzimba huru dzakanaka dzichashaya vanogaramo. 
\q1  
\v 10 Maeka gumi omunda wemizambiringa achabereka bhati rimwe chete\f + \fr 5:10 \ft marita angaita 22\f* rewaini, 
\q2 uye homeri\f + \fr 5:10 \ft marita angaita 220\f* rembeu richabereka efa\f + \fr 5:10 \ft marita angaita 22\f* imwe chete rezviyo.” 
\b  
\q1  
\v 11 Vane nhamo avo vanomuka mangwanani 
\q2 kuti vatsvake doro rinodhaka, 
\q1 vanogara kusvikira usiku, 
\q2 kusvikira vapengeswa newaini. 
\q1  
\v 12 Vanenge vane rudimbwa, 
\q2 nemitengeranwa pamabiko avo, 
\q1 namatambureni, nenyere newaini, 
\q2 asi havana hanya namabasa aJehovha, havana rukudzo nebasa ramaoko ake. 
\q1  
\v 13 Naizvozvo vanhu vangu vachapinda muutapwa, 
\q2 nokuda kwokushayiwa zivo; 
\q1 vanokudzwa vavo vachafa nenzara, 
\q2 uye vazhinji vavo vachafa nenyota. 
\q1  
\v 14 Naizvozvo gehena rakawedzera kukara kwaro, 
\q2 uye rakazarura muromo waro zvinodarika mwero; 
\q1 mariri muchaburukira vanokudzwa vavo nevoruzhinji, 
\q2 navose vanokakavara vavo navanofara vavo. 
\q1  
\v 15 Naizvozvo munhuwo zvake achadzikiswa, 
\q2 marudzi avanhu achaninipiswa, 
\q2 nameso avanozvikudza achaninipiswa. 
\q1  
\v 16 Asi Jehovha Wamasimba Ose achakudzwa, nokuda kwokururamisira kwake, uye Mwari, 
\q2 mutsvene achazviratidza pachake kuti mutsvene, mukururama kwake. 
\q1  
\v 17 Ipapo makwai achafura saari mumafuro awo; 
\q2 makwayana achadya pakati pamatongo avapfumi. 
\b  
\q1  
\v 18 Vane nhamo avo vanokweva chivi nerwodzi rwokunyengera, 
\q2 uye zvakaipa sezvinenge mabote engoro, 
\q1  
\v 19 uye nevanoti, “Mwari ngaakurumidze, 
\q2 ngaachimbidzike nebasa 
\q2 rake kuti tirione. 
\q1 Ngarisvike, 
\q2 urongwa hwoMutsvene waIsraeri ngahuuye, 
\q2 kuti tihuzive.” 
\b  
\q1  
\v 20 Vane nhamo avo vanoti zvakaipa 
\q2 ndizvo zvakanaka, 
\q1 uye zvakanaka ndizvo zvakaipa, 
\q2 vanoisa rima panzvimbo yechiedza nechiedza panzvimbo yerima, 
\q1 vanoisa zvinovava panzvimbo yezvinotapira, 
\q2 nezvinotapira panzvimbo yezvinovava. 
\b  
\q1  
\v 21 Vane nhamo avo vanoti vakachenjera pameso avo, 
\q2 uye vakangwara pakuona kwavo. 
\b  
\q1  
\v 22 Vane nhamo avo vanova mhare pakunwa waini, 
\q2 uye shasha pakuvhenganisa zvokunwa zvinodhaka, 
\q1  
\v 23 vanopembedza ane mhosva nokuda kwefufuro, 
\q2 asi vanoramba kururamisira vasina mhosva. 
\q1  
\v 24 Naizvozvo, samarimi omoto anonanzva mashanga, 
\q2 uye souswa hwakaoma hunomedzwa nemirazvo yemoto, 
\q1 naizvozvo midzi yavo ichaora 
\q2 uye maruva avo achapeperetswa seguruva; 
\q1 nokuti vakaramba murayiro waJehovha Wamasimba Ose, 
\q2 uye vakazvidza shoko roMutsvene waIsraeri. 
\q1  
\v 25 Naizvozvo kutsamwa kwaJehovha kwopfuta pamusoro pavanhu vake; 
\q2 ruoko rwake rwasimudzwa uye anovarovera pasi. 
\q1 Makomo anozungunuka, 
\q2 uye mitumbi yavakafa yaita samarara mumigwagwa. 
\b  
\q1 Kunyange zvakadaro nokuda kwezvose izvi, 
\q2 kutsamwa kwake hakuna kudzorwa, ruoko rwake rwaramba rwakasimudzwa. 
\b  
\q1  
\v 26 Anosimudzira ndudzi dziri kure mureza, 
\q2 anoridzira muridzo kuna avo vari kumigumo yenyika. 
\q1 Havo vouya, nokukurumidza 
\q2 uye nokuchimbidzika! 
\q1  
\v 27 Hapana kana mumwe wavo anoneta kana kugumburwa, 
\q2 hapana kana mumwe wavo achakotsira kana kuvata; 
\q1 hapana kana bhanhire richasunungurwa pachiuno, 
\q2 hapana kana rukanda rweshangu ruchadambuka. 
\q1  
\v 28 Miseve yavo inopinza, 
\q2 uta hwavo hwose hwakakungwa; 
\q1 mahwanda amabhiza avo anenge omusarasara, 
\q2 mavhiri engoro dzavo akaita sechamupupuri. 
\q1  
\v 29 Kuomba kwavo kwakaita sokweshumba, 
\q2 vanoomba kufanana neshumba diki; 
\q1 vanodzvova pavanobata mhuka yavo 
\q2 vagoitakura pasina kana angairwira. 
\q1  
\v 30 Pazuva iro vachaomba pamusoro payo, 
\q2 sokutinhira kwegungwa. 
\q1 Uye kana mumwe akatarisa panyika, 
\q2 achaona rima nokutambudzika; 
\q2 kunyange chiedza chichasvibiswa namakore. 
\c 6  
\s1 Kutumwa kwaIsaya 
\p  
\v 1 Mugore rakafa Mambo Uziya, ndakaona Ishe agere pachigaro choushe, chirefu chakakwirira uye mupendero wenguo dzake wakazadza temberi.  
\v 2 Kumusoro kwake kwaiva neserafimi, imwe neimwe yaiva namapapiro matanhatu: namapapiro maviri, dzakafukidza uso hwadzo, namaviri dzakafukidza makumbo adzo, uye namaviri dzakanga dzichibhururuka.  
\v 3 Zvino imwe yaidanidzira kune imwe ichiti: 
\q1 “Mutsvene, mutsvene, mutsvene, iye Jehovha Wamasimba Ose; 
\q2 nyika yose izere nokubwinya kwake.” 
\m  
\v 4 Nokutinhira kwamanzwi adzo, nheyo dzezvikumbaridzo dzakazungunuka uye temberi yakazadzwa noutsi. 
\p  
\v 5 Ipapo ndakachema ndichiti, “Ndine nhamo! Ndaparara! Nokuti ndiri munhu ane miromo ine tsvina uye ndigere pakati pavanhu vane miromo ine tsvina uye meso angu aona Mambo, Jehovha Wamasimba Ose.” 
\p  
\v 6 Ipapo imwe yesarafimi yakabhururukira kwandiri ine zimbe romoto muruoko rwayo, rayakanga yatora nembato kubva paaritari.  
\v 7 Yakagunzva muromo wangu naro ikati, “Tarira, zimbe iri ragunzva miromo yako; mhosva yako yabviswa uye chivi chako chadzikinurwa.” 
\p  
\v 8 Ipapo ndakanzwa inzwi raJehovha richiti, “Ndiani wandichatuma? Uye ndiani achatiendera?” 
\p Ini ndakati, “Ndiri pano! Nditumei!” 
\p  
\v 9 Iye akati, “Enda undoudza vanhu ava uti, 
\q1 “ ‘Munogara muchinzwa, asi hamumbonzwisisi; 
\q2 munogara muchiona, asi hamuonesesi.’ 
\q1  
\v 10 Ita kuti mwoyo yavanhu ava isindimare; 
\q2 ita kuti nzeve dzavo dzisanzwisise 
\q2 uye vatsinzine meso avo. 
\q1 Nokuti vangaona nameso avo, 
\q2 nokunzwa nenzeve dzavo, 
\q2 vakanzwisisa nemwoyo yavo, 
\q1 vakadzoka vakaporeswa.” 
\p  
\v 11 Ipapo ndakati, “Haiwa, Ishe, kusvikira riniko?” 
\p Iye akapindura achiti, 
\q1 “Kusvikira maguta ava matongo 
\q2 uye pasisina anogaramo, 
\q1 kusvikira dzimba dzasiyiwa dzisina vanhu, 
\q2 neminda yaparadzwa zvachose, 
\q1  
\v 12 kusvikira Jehovha adzingira vanhu kure, 
\q2 uye nyika yasiyiwa zvachose. 
\q1  
\v 13 Uye kunyange kukasara chegumi munyika, 
\q2 naichowo chichaparadzwa. 
\q1 Asi somuterabhiniti nomuouki 
\q2 zvichasara zvava zvigutsa pazvinotemwa, 
\q2 saizvozvo rudzi rutsvene ruchavawo sechigutsa munyika.” 
\c 7  
\s1 Chiratidzo chaImanueri 
\p  
\v 1 Zvino Ahazi mwanakomana waJotamu, mwanakomana waUzia, paakanga ari mambo weJudha, Mambo Rezini weAramu naPeka mwanakomana waRamaria mambo weIsraeri vakauya kuzorwa neJerusarema, asi havana kugona kurikunda. 
\p  
\v 2 Zvino imba yaDhavhidhi yakaudzwa kuti, “Aramu yabatana neEfuremu;” saka mwoyo waAhazi nemwoyo yavanhu vake yakazungunuswa, sokuzungunuswa kunoitwa miti yesango nemhepo. 
\p  
\v 3 Ipapo Jehovha akati kuna Isaya, “Buda, iwe nomwanakomana wako Sheari-Jashubhi, unosangana naAhazi kumucheto womugero weDziva Rokumusoro, mumugwagwa unoenda kuMunda woMusuki.  
\v 4 Uti kwaari, ‘Chenjera, dzikama hako, uye usatya. Usaora mwoyo nokuda kwamatsiga maviri ehuni, nokuda kwokutsamwa kunotyisa kwaRezini naAramu uye nekwomwanakomana waRemaria.  
\v 5 Aramu naEfuremu nomwanakomana waRemaria vakarangana kukuparadza vachiti,  
\v 6 “Handei tindorwa neJudha; ngatiribvarurei tigorigovana pakati pedu, tigogadza Tabheeri kuti ave mambo pamusoro paro.”  
\v 7 Asi zvanzi naIshe Jehovha: 
\q1 “ ‘Izvi hazvingamiri, hazvingaitiki, 
\q2 nokuti musoro weAramu iDhamasiko, 
\q1  
\v 8 uye musoro weDhamasiko 
\q2 iRezini bedzi. 
\q1 Makore makumi matanhatu namashanu asati apera, 
\q2 vaEfuremu vachaputswa-putswa zvokusazova rudzizve. 
\q1  
\v 9 Musoro weEfuremu iSamaria, 
\q2 uye musoro weSamaria mwanakomana waRamaria bedzi. 
\q1 Kana usingamiri zvakasimba mukutenda kwako, 
\q2 hauchazomiri zvachose.’ ” 
\p  
\v 10 Jehovha akataurazve kuna Ahazi akati,  
\v 11 “Kumbira chiratidzo kuna Jehovha Mwari wako, kunyange pakadzikadzika kana pamusoro-soro.” 
\p  
\v 12 Asi Ahazi akati, “Handizokumbiri; handingaedzi Jehovha.” 
\p  
\v 13 Ipapo Isaya akati, “Inzwai zvino, imi imba yaDhavhidhi! Hazvina kuringana here kuedza mwoyo murefu wavanhu? Ko, imi muchaedzawo mwoyo murefu waMwari wangu here?  
\v 14 Naizvozvo Jehovha pachake achakupai chiratidzo: Mhandara ichava nemimba uye ichabereka mwanakomana igomutumidza kuti Imanueri.  
\v 15 Iye achadya ruomba nouchi paachaziva zvakakwana kuti arambe zvakaipa achisarudza zvakarurama.  
\v 16 Asi mwana asati anyatsoziva kuramba zvakaipa nokusarudza zvakanaka, nyika yamadzimambo maviri aunotya ichava dongo.  
\v 17 Jehovha achauyisa pamusoro pako napamusoro pavanhu vako napamusoro peimba yababa vako nguva isina kumbovapo kubva nguva iya yaakazvipatsanura kubva kuna Judha, achauyisa mambo weAsiria.” 
\p  
\v 18 Pazuva iroro Jehovha acharidzira muridzo kunhunzi dzichibva kuhova dziri kure dzeIjipiti nokunyuchi dzichibva kunyika yeAsiria.  
\v 19 Dzichauya dzose dzigogara mumawere emipata nomumikaha yamatombo, nomumakwenzi ose eminzwa uye napamadziva ose.  
\v 20 Pazuva iro Jehovha achashandisa chisvo chakakumbirwa kubva mhiri kwoRwizi, kuna mambo weAsiria, kuti aveure misoro yenyu nemvere dzomumakumbo enyu, uye kuti abvisewo ndebvu dzenyu.  
\v 21 Pazuva iro, murume achapfuwa mhou duku imwe chete nembudzi mbiri.  
\v 22 Uye nokuda kwokuwanda kwomukaka wadzinopa, achadya ruomba. Vose vachasara munyika vachadya ruomba nouchi.  
\v 23 Pazuva iro munzvimbo imwe neimwe maimbova nemizambiringa inokwana chiuru yaitengwa namashekeri anokwana chiuru\f + \fr 7:23 \ft makirogiramu angaita 11.5 \f* esirivha, pachazova norukato neminzwa chete.  
\v 24 Varume vachaendako neuta nemiseve, nokuti nyika ichange yafukidzwa norukato neminzwa.  
\v 25 Kana zviri zvikomo zvose zvaichimbosakurirwa nebadza, hakuna achada kuendako nokuda kwokutya rukato neminzwa; dzichava nzvimbo dzokusundira mombe nokunomhanyirwa namakwai. 
\c 8  
\s1 Asiria, Shamhu yaJehovha 
\p  
\v 1 Jehovha akati kwandiri, “Tora bhuku guru unyore pamusoro paro nechinyoreso: pamusoro paMaheri-Sharari-Hashi-Bhazi.  
\v 2 Ndichadana Uriya muprista naZekaria mwanakomana waJebherekia sezvapupu zvakatendeka kwandiri.” 
\p  
\v 3 Ipapo ndakaenda kumuprofitakadzi, akatora pamuviri akabereka mwanakomana. Zvino Jehovha akati kwandiri, “Mutumidze kuti Maheri-Sharari-Hashi-Bhazi;  
\v 4 nokuti mwana asati aziva kuti, ‘Baba vangu’ kana kuti, ‘Mai vangu,’ pfuma yeDhamasiko nezvakapambwa zveSamaria zvichatakurwa namambo weAsiria.” 
\p  
\v 5 Jehovha akataurazve kwandiri akati, 
\q1  
\v 6 “Nokuti vanhu ava vakaramba 
\q2 mvura inoyerera zvinyoronyoro yeShiroa, 
\q1 uye vanofarira Rezini 
\q2 nomwanakomana waRemaria, 
\q1  
\v 7 naizvozvo Jehovha ava kuda kuuyisa pamusoro pavo 
\q2 mafashamu makuru oRwizi, 
\q2 mambo weAsiria nokukudzwa kwake kwose. 
\q1 Ruchapfachukira hova dzarwo dzose, 
\q2 uye rugopfachukira kumahombekombe arwo ose, 
\q1  
\v 8 ruchakukura kusvikira kuJudha, 
\q2 ruchipafuma nomukati mayo, rugopfuura nomairi ruchisvika muhuro. 
\q1 Kutandavara kwamapapiro arwo kuchafukidza upamhi hwenyika yako, 
\q2 iwe Imanueri!” 
\b  
\q1  
\v 9 Ridzai mhere yehondo, imi ndudzi, mugoputswa-putswa! 
\q2 Teererai, imi nyika dzose dziri kure. 
\q1 Gadzirirai kurwa, 
\q2 mugoputswa-putswa! 
\q1  
\v 10 Gadzirirai urongwa hwenyu, asi huchakona; 
\q2 Taurai zvourongwa hwenyu, asi hauzomiri, 
\q1 nokuti Mwari anesu. 
\s1 Ityai Mwari 
\p  
\v 11 Jehovha akataura kwandiri ruoko rwake rune simba rwuri pamusoro pangu, achindiyambira kuti ndirege kutevera nzira yavanhu ava, akati: 
\q1  
\v 12 “Musati irangano zvinhu zvose 
\q2 zvinonzi navanhu ava irangano; 
\q1 musatya zvavanotya, 
\q2 musazvivhunduka. 
\q1  
\v 13 Jehovha Wamasimba Ose ndiye wamunofanira kuita mutsvene, 
\q2 ndiye wamunofanira kuvhunduka, 
\q1  
\v 14 ndiye achava nzvimbo tsvene; 
\q2 asi padzimba dzose dzaIsraeri 
\q1 achava dombo rinoita kuti vanhu vagumburwe; 
\q2 nedombo rinoita kuti vapunzike. 
\q1 Uye kuvanhu veJerusarema 
\q2 iye achava musungo norugombe. 
\q1  
\v 15 Vazhinji vavo vachagumburwa; 
\q2 vachawa vagovhunika, 
\q2 vachateyiwa vagobatwa.” 
\b  
\q1  
\v 16 Sungai chipupuriro 
\q2 mugosimbisa murayiro pakati pavadzidzi vangu. 
\q1  
\v 17 Ndichamirira Jehovha, 
\q2 iye ari kuvanzira imba yaJakobho chiso chake. 
\q1 Ndichaisa ruvimbo rwangu maari. 
\p  
\v 18 Ndiri pano, navana vandakapiwa naJehovha. Tiri zviratidzo nemifananidzo muIsraeri inobva kuna Jehovha Wamasimba Ose paGomo reZioni. 
\p  
\v 19 Kana vanhu vachiti kwamuri bvunzai masvikiro navavuki, vanozevezera nokunguruma, ko, vanhu havangabvunzi kuna Mwari wavo here? Munobvunzirei vakafa pamusoro pavapenyu?  
\v 20 Endai kumurayiro nokuzvipupuriro! Kana vasingatauri maererano neshoko iri havana chiedza chamambakwedza.  
\v 21 Vatambudzika, vava vane nzara vachafamba-famba nenyika; pavachatambudzika vachava neshungu, uye vachatarira kudenga, vagotuka mambo wavo naMwari wavo.  
\v 22 Ipapo vachatarira pasi vagoona nhamo chete nerima nokusafara kunotyisa, uye vachakandirwa kurima guru. 
\c 9  
\s1 Isu tazvarirwa Mwana 
\p  
\v 1 Kunyange zvakadaro, hakuchazovazve nerima kuna avo vakanga vari munhamo. Pamazuva akare akaninipisa nyika yeZebhuruni nenyika yeNafutari, asi panguva inouya achakudza Garirea reveDzimwe Ndudzi, nenzira yokugungwa mhiri kwaJorodhani. 
\q1  
\v 2 Vanhu vaifamba murima 
\q2 vakaona chiedza chikuru; 
\q1 avo vaigara munyika yomumvuri worufu, 
\q2 chiedza chakavavhenekera. 
\q1  
\v 3 Makakurisa rudzi mukawedzera mufaro wavo; 
\q2 vanofara pamberi penyu 
\q1 savanhu vanofara 
\q2 panguva yokukohwa, 
\q1 sokufara kwavarume, 
\q2 kana vachigoverana zvakapambwa. 
\q1  
\v 4 Nokuti sapamazuva okukundwa kwavaMidhia, 
\q2 vamakaparadzira 
\q1 joko raivaremera, 
\q2 nedanda raichinjika mafudzi avo, 
\q2 iyo tsvimbo yavamanikidzi vavo. 
\q1  
\v 5 Shangu imwe neimwe yomurwi yakashandiswa muhondo, 
\q2 nenguo imwe neimwe yakaumburudzwa muropa, 
\q1 zvichapiswa, 
\q2 zvichava huni dzomoto. 
\q1  
\v 6 Nokuti takazvarirwa mwana, 
\q2 takapiwa mwanakomana, 
\q2 uye umambo huchava pamapfudzi ake. 
\q1 Uye achanzi Gota Rinoshamisa, 
\q2 Mwari Ane Simba, 
\q2 Baba Vokusingaperi, Muchinda woRugare. 
\q1  
\v 7 Kukura kwoumambo hwake nekworugare rwake 
\q2 hazvizovi namagumo. 
\q1 Achatonga pachigaro choushe chaDhavhidhi 
\q2 napamusoro poumambo hwake, 
\q1 achihusimbisa nokuhutsigira, 
\q2 nokururamisira uye nokururama, 
\q2 kubva panguva iyoyo kusvikira nokusingaperi. 
\q1 Kushingaira kwaJehovha Wamasimba Ose 
\q2 kuchazviita. 
\s1 Kutsamwa kwaJehovha pamusoro peIsraeri 
\q1  
\v 8 Jehovha akatuma shoko pamusoro paJakobho; 
\q2 richawira pamusoro paIsraeri. 
\q1  
\v 9 Vanhu vose vachariziva, 
\q2 Efuremu navagari vomuSamaria, 
\q1 ivo vanoti nokuzvikudza kwavo 
\q2 uye namanyawi emwoyo, 
\q1  
\v 10 “Zvidhinha zvakoromokera pasi, 
\q2 asi tichavakazve namatombo; 
\q1 mionde yatemerwa pasi, 
\q2 asi tichaitsiva nemisidhari.” 
\q1  
\v 11 Asi Jehovha akamutsira Rezini vadzivisi 
\q2 akakurudzira vavengi vavo. 
\q1  
\v 12 VaAramu vachibva nokumabvazuva navaFiristia vachibva 
\q2 nokumavirira vakapedza vaIsraeri nomuromo wakashama. 
\b  
\q1 Kunyange zvakadaro, kutsamwa kwake hakuna kudzorwa, 
\q2 asi ruoko rwake ruchatongotambanudzwa. 
\b  
\q1  
\v 13 Asi vanhu havana kutendeukira kuna iye akavarova, 
\q2 kana kutsvaka Jehovha Wamasimba Ose. 
\q1  
\v 14 Naizvozvo Jehovha achadimura vaIsraeri vose musoro nomuswe, 
\q2 zvose davi romuchindwe norutsanga pazuva rimwe; 
\q1  
\v 15 vakuru navarume vanokudzwa ndivo musoro, 
\q2 vaprofita vanodzidzisa nhema ndivo muswe. 
\q1  
\v 16 Vanotungamirira vanhu ava vanovatsausa, 
\q2 navose vanotungamirirwa vanotsauswa. 
\q1  
\v 17 Naizvozvo Jehovha haachazofariri majaya, 
\q2 kana kuva netsitsi nenherera nechirikadzi, 
\q1 nokuti mumwe nomumwe wavo haana umwari uye akaipa, 
\q2 muromo mumwe nomumwe unotaura zvoupenzi. 
\b  
\q1 Kunyange zvakadaro, kutsamwa kwake hakuna kudzorwa, 
\q2 ruoko rwake ruchakangosimudzwa. 
\b  
\q1  
\v 18 Zvirokwazvo zvakaipa zvinopfuta somoto; 
\q2 unopisa rukato neminzwa, 
\q1 unopisa matenhere edondo zvokuti unokwira 
\q2 kudenga mushongwe youtsi. 
\q1  
\v 19 Kubudikidza nokutsamwa kwaJehovha Wamasimba Ose 
\q2 nyika ichapiswa kwazvo 
\q1 uye vanhu vachava huni dzomoto; 
\q2 hapana achaponesa hama yake. 
\q1  
\v 20 Kurudyi vachadya 
\q2 asi vacharamba vane nzara; 
\q1 kuruboshwe, 
\q2 vachadya asi havangaguti. 
\q1 Mumwe nomumwe achadya nyama yomwana wake. 
\q2  
\v 21 Manase achadya Efuremu uye Efuremu achadya Manase; 
\q2 pamwe chete vachamukira Judha. 
\b  
\q1 Kunyange zvakadaro, kutsamwa kwake hakuna kudzorwa, 
\q2 ruoko rwake ruchakangosimudzwa. 
\c 10  
\q1  
\v 1 Vane nhamo vanodzika mitemo isina kururama, 
\q2 neavo vanopa mitemo inodzvinyirira, 
\q1  
\v 2 kuti vadzivise varombo kodzero dzavo 
\q2 uye vadzivise kururamisirwa kwavakadzvinyirirwa vavanhu vangu, 
\q1 vachipamba chirikadzi 
\q2 uye vachibira nherera. 
\q1  
\v 3 Muchaita sei pazuva rokutongwa, 
\q2 njodzi painouya ichibva kure? 
\q1 Muchatizira kuna aniko kuti mubatsirwe? 
\q2 Upfumi hwenyu muchahusiyepiko? 
\q1  
\v 4 Hapana chichasara asi kungokotama pakati penhapwa, 
\q2 kana kuwira pakati pavakaurayiwa. 
\q1 Kunyange zvakadaro, kutsamwa kwake hakuna kudzorwa, 
\q2 ruoko rwake ruchakangosimudzwa. 
\s1 Kutonga kwaMwari pamusoro peAsiria 
\q1  
\v 5 “Une nhamo iwe Asiria, shamhu yokutsamwa kwangu, 
\q2 iye akabata tsvimbo yehasha dzangu mumaoko ake! 
\q1  
\v 6 Ndiri kumutuma kurudzi rusina Mwari, 
\q2 ndinomutuma kuvanhu vanonditsamwisa, 
\q1 kundokomba nokutora nokubvuta zvakapambwa, 
\q2 nokuvatsikirira pasi sedope riri mumigwagwa. 
\q1  
\v 7 Asi izvi handizvo zvaanoda, 
\q2 izvi handizvo zvaanga achifunga; 
\q1 vavariro yake ndeyokuparadza, 
\q2 kupedza chose marudzi mazhinji. 
\q1  
\v 8 Anoti, ‘Ko, machinda angu haazi madzimambo ose here? 
\q2  
\v 9 Karino harina kuita sezvakaita Karikemishi here? 
\q1 Ko, Hamati harina kufanana neAripadhi, 
\q2 uye Samaria harina kufanana neDhamasiko here? 
\q1  
\v 10 Ruoko rwangu sezvarwakatora umambo hwezvifananidzo, 
\q2 umambo hune zvifananidzo zvakakunda zveJerusarema neSamaria, 
\q1  
\v 11 ko, handichaitiri Jerusarema nezvifananidzo zvaro 
\q2 sezvandakaitira Samaria nezvifananidzo zvayo here?’ ” 
\p  
\v 12 Kana Ishe achinge apedza basa rake rose pamusoro peGomo reZioni neJerusarema, achazoti, “Ndicharanga mambo weAsiria nokuda kwokuzvikudza kwomwoyo wake namanyawi emeso ake.  
\v 13 Nokuti iye anoti, 
\q1 “ ‘Nesimba ramaoko angu ndakaita izvi, 
\q2 uye nouchenjeri hwangu, nokuti ndinonzwisisa. 
\q1 Ndakabvisa miganhu yendudzi, 
\q2 ndikapamba pfuma yavo; 
\q2 semhare ndakakunda madzimambo avo. 
\q1  
\v 14 Sezvinoita munhu anosvasvavira mudendere, 
\q2 saizvozvo ruoko rwangu rwakananavira pfuma yamarudzi; 
\q1 savarume vanounganidza mazai akasiyiwa, 
\q2 saizvozvo ndakaunganidza nyika dzose; 
\q1 hakuna yakapfakanyisa bapiro, 
\q2 kana kushamisa muromo wayo kuti irire.’ ” 
\b  
\q1  
\v 15 Ko, demo ringazvirumbidza kupfuura iye anoritemesa here? 
\q2 Kana jeko ringazvirumbidza pamusoro pounorishandisa here? 
\q1 Zvinozoita sokunge tsvimbo inosimudza uyo anoitakura, 
\q2 kana mudonzvo kusimudza uyo asati ari huni! 
\q1  
\v 16 Naizvozvo, Ishe Jehovha Wamasimba Ose, 
\q2 achatumira denda rinoonza pamusoro pavarwi vakafuta; 
\q1 pasi pokubwinya kwake moto uchatungidzwa 
\q2 kufanana nemirazvo inopfuta. 
\q1  
\v 17 Chiedza chaIsraeri chichava moto, 
\q2 noMutsvene wavo murazvo womoto; 
\q1 muzuva rimwe chete uchapfuta 
\q2 ugopedza minzwa yake norukato rwake. 
\q1  
\v 18 Kubwinya kwamasango ake neminda yake 
\q2 yakaorera kuchaparadzwa chose, 
\q2 kufanana nomurwere anoramba achipera. 
\q1  
\v 19 Uye miti yakasara yamasango ake ichava mishoma kwazvo, 
\q2 zvokuti mwana angagona kuinyora pasi. 
\s1 Vakasara veIsraeri 
\q1  
\v 20 Pazuva iro vakasara veIsraeri, 
\q2 vakapunyuka veimba yaJakobho, 
\q1 havachazovimbi naye iye akavarova, 
\q2 asi zvirokwazvo vachavimba naJehovha, Mutsvene waIsraeri. 
\q1  
\v 21 Vakasara vachadzokera, vakasara vaJakobho, 
\q2 vachadzokera kuna Mwari Ane Simba. 
\q1  
\v 22 Kunyange vanhu vako, iwe Israeri, vakaita sejecha regungwa, 
\q2 vachasara chete ndivo vachadzokera. 
\q1 Kuparadzwa kwakatotemwa, 
\q2 kuzere nokururama. 
\q1  
\v 23 Ishe, Jehovha Wamasimba Ose 
\q2 achapedzisa kuparadzwa kwakatemerwa nyika yose. 
\p  
\v 24 Naizvozvo zvanzi naIshe, Jehovha Wamasimba Ose: 
\q1 “Haiwa, vanhu vangu vanogara muZioni, 
\q2 musatya vaAsiria, 
\q1 vanokurovai nomudonzvo nokukusimudzirai tsvimbo, 
\q2 sezvakaitwa neIjipiti. 
\q1  
\v 25 Nokuti nenguva duku duku kutsamwa kwangu pamusoro penyu kuchapera, 
\q2 uye hasha dzangu dzichanangana nokuparadzwa kwavo.” 
\b  
\q1  
\v 26 Jehovha Wamasimba Ose achavarova netyava, 
\q2 samarovero aakaita vaMidhia padombo reOrebhi, 
\q1 uye achasimudza tsvimbo yake pamusoro pemvura zhinji, 
\q2 sezvaakaita muIjipiti. 
\q1  
\v 27 Pazuva iro mitoro yavo ichabviswa pamapfudzi enyu, 
\q2 nejoko ravo pamitsipa yenyu; 
\q1 joko richavhuniwa, 
\q2 nokuti manyanya kufuta. 
\b  
\q1  
\v 28 Vanopinda muAyati; 
\q2 vopfuura nomuMigironi; 
\q2 vochengeta nhumbi paMikimashi. 
\q1  
\v 29 Vanopfuura napamupata, vagoti, 
\q2 “Tichadzika matende paGebha usiku.” 
\q1 Rama rinobvunda; 
\q2 Gibhea raSauro rinotiza. 
\q1  
\v 30 Ridza mhere, iwe mukunda weGarimi! 
\q2 Teerera, iwe Raisha! 
\q2 Newe Anatoti unonzwisa urombo! 
\q1  
\v 31 Madhimena riri kutiza; 
\q2 vanhu veGebhimi vanovanda. 
\q1  
\v 32 Zuva ranhasi vachamira paNobhi; 
\q2 vachakunga chibhakera chavo 
\q1 pagomo remwanasikana weZioni, 
\q2 pachikomo cheJerusarema. 
\b  
\q1  
\v 33 Tarirai, Ishe, Jehovha Wamasimba Ose, 
\q2 achatema matavi nesimba guru. 
\q1 Miti mirefu refu ichawiswa, 
\q2 uye yakareba ichadzikiswa. 
\q1  
\v 34 Achatema matenhere esango nedemo; 
\q2 Rebhanoni ichawa pamberi paIye Ane Simba. 
\c 11  
\s1 Davi raJese 
\q1  
\v 1 Bukira richabva kudzinde raJese; 
\q2 Davi rinobva pamidzi yake richabereka muchero. 
\q1  
\v 2 Mweya waJehovha uchagara pamusoro pake, 
\q2 mweya wouchenjeri newokunzwisisa, mweya wokurayira nowesimba, 
\q2 mweya wokuziva newokutya Jehovha, 
\q1  
\v 3 uye achafarira kutya Jehovha. 
\q1 Haazotongi nezvaanoona nameso ake, 
\q2 kana kutonga nezvaanonzwa nenzeve dzake, 
\q1  
\v 4 asi nokururama achatongera varombo, 
\q2 nokururamisira achatongera vanyoro vapanyika. 
\q1 Acharova nyika neshamhu yomuromo wake; 
\q2 nokufema kwemiromo yake achauraya vakaipa. 
\q1  
\v 5 Kururuma ndiro richava bhanhire rake 
\q2 uye kutendeka bhanhire romuchiuno chake. 
\b  
\q1  
\v 6 Bere richagara negwayana, 
\q2 ingwe ichavata pasi nembudzi, 
\q1 mhuru neshumba nezvakakodzwa zvichafura pamwe chete; 
\q2 uye mwana mudiki achazvitungamirira. 
\q1  
\v 7 Mhou ichafura nebere, 
\q2 vana vazvo vachavata pasi pamwe chete, 
\q2 uye shumba ichadya uswa senzombe. 
\q1  
\v 8 Mwana mucheche achatambira pedyo nomwena wemhakure, 
\q2 uye mwana mudiki achaisa ruoko rwake mumwena wenyoka. 
\q1  
\v 9 Hazvingazokuvadzi kana kuparadza 
\q2 pagomo rangu rose dzvene, 
\q1 nokuti nyika ichazara nokuziva Jehovha 
\q2 semvura zhinji inofukidza gungwa. 
\p  
\v 10 Pazuva iro Mudzi waJese uchamira somureza wamarudzi; ndudzi dzichamhanyira kwaari, uye nzvimbo yake yokuzorora ichabwinya.  
\v 11 Pazuva iro Jehovha achatambanudza ruoko rwake kechipiri kuti adzorezve vakasara ivo vanhu vake vakasiyiwa kubva kuAsiria, kubva zasi kweIjipiti, nokubva kumusoro kweIjipiti nokubva kuEtiopia, nokubva kuEramu, nokubva kuBhabhironi, nokuHamati uye nokubva kuzviwi zvegungwa. 
\q1  
\v 12 Achasimudzira marudzi mureza 
\q2 uye achaunganidza vakadzingwa vaIsraeri; 
\q1 achaunganidza vakaparadzirwa vavanhu veJudha, 
\q2 kubva kumativi mana enyika. 
\q1  
\v 13 Godo raEfuremu richapera 
\q2 uye vavengi vavaJudha vachagurwa; 
\q1 Efuremu haachazovi negodo naJudha, 
\q2 naJudha haangaitire Efuremu hasha. 
\q1  
\v 14 Asi vachawira pamusoro pamateru eFiristia kumavirazuva; 
\q2 pamwe chete vachapamba vanhu vokumabvazuva. 
\q1 Vachatora Edomu neMoabhu, 
\q2 uye vaAmoni vachava varanda vavo. 
\q1  
\v 15 Jehovha achaomesa chose 
\q2 chikamu chegungwa reIjipiti; 
\q1 nemhepo inopisa achatsvaira noruoko rwake 
\q2 pamusoro peRwizi rweYufuratesi. 
\q1 Acharukamura-kamura agoruita hova nomwe, 
\q2 kuitira kuti vanhu vagone kuyambuka vachienda mhiri vakapfeka shangu. 
\q1  
\v 16 Pachava nomugwagwa mukuru wavanhu vake vakasara, 
\q2 vakasiyiwa kubva kuAsiria, 
\q1 sezvazvakanga zviri kuvaIsraeri 
\q2 pavakabva kuIjipiti. 
\c 12  
\s1 Nziyo dzoKurumbidza 
\p  
\v 1 Pazuva iro muchati, 
\q1 “Ndichakurumbidzai, imi Jehovha, 
\q2 kunyange makanga makanditsamwira, 
\q1 kutsamwa kwenyu kwakadzorwa 
\q2 uye makandinyaradza. 
\q1  
\v 2 Zvirokwazvo Mwari ndiye ruponeso rwangu; 
\q2 ndichavimba naye uye handingatyi. 
\q1 Jehovha, Jehovha ndiye simba rangu nerwiyo rwangu; 
\q2 ava ruponeso rwangu.” 
\q1  
\v 3 Nomufaro muchachera mvura 
\q2 kubva mumatsime oruponeso. 
\p  
\v 4 Pazuva iro muchati, 
\q1 “Vongai Jehovha, danai kuzita rake; 
\q2 zivisai zvaakaita pakati pendudzi, 
\q2 uye muparidze kuti zita rake risimudzirwe. 
\q1  
\v 5 Imbirai Jehovha, nokuti akaita zvinhu zvinoshamisa; 
\q2 izvi ngazvizivikanwe pasi pose. 
\q1  
\v 6 Pururudzai uye muimbe nomufaro, imi vanhu veZioni, 
\q2 nokuti Mutsvene waIsraeri mukuru pakati penyu.” 
\c 13  
\s1 Chiprofita pamusoro peBhabhironi 
\p  
\v 1 Shoko rakaonekwa naIsaya mwanakomana waAmozi pamusoro peBhabhironi: 
\q1  
\v 2 Simudzai mireza pamusoro pechikomo chisina miti, 
\q2 danidzirai kwavari; 
\q1 muninire kwavari 
\q2 kuti vapinde pamasuo amakurukota. 
\q1  
\v 3 Ndakarayira vatsvene vangu; 
\q2 ndakadana varwi vangu kuti vazadzise kutsamwa kwangu, 
\q2 avo vanofadzwa nokukunda kwangu. 
\b  
\q1  
\v 4 Inzwai, kutinhira pamusoro pamakomo, 
\q2 kwakafanana nokwavanhu vazhinji zhinji! 
\q1 Inzwai, mheremhere pakati poumambo, 
\q2 sendudzi dziri kuungana pamwe chete! 
\q1 Jehovha Wamasimba Ose ari kugadzirira 
\q2 mauto kundorwa. 
\q1  
\v 5 Vanobva kunyika dziri kure, 
\q2 kubva kumagumo amatenga, 
\q1 Jehovha nezvombo zvokutsamwa kwake, 
\q2 kuti aparadze nyika yose. 
\b  
\q1  
\v 6 Ungudzai, nokuti zuva raJehovha rava pedyo; 
\q2 richauya nokuparadza kunobva kuna Wamasimba Ose. 
\q1  
\v 7 Naizvozvo maoko ose achashaya simba, 
\q2 mwoyo mumwe nomumwe wavanhu uchanyungudika. 
\q1  
\v 8 Kutya kuchavabata, 
\q2 kurwadziwa nokugomera zvichavabata, 
\q2 vachamonyoroka somukadzi ari kusununguka. 
\q1 Vachatarisana vachishamisika mumwe nomumwe wavo, 
\q2 zviso zvavo zvichipfuta. 
\b  
\q1  
\v 9 Tarirai, zuva raJehovha riri kuuya, 
\q2 zuva rakaipisisa, rine hasha nokutsamwa kunotyisa, 
\q1 kuti nyika ive dongo 
\q2 uye nokuzoparadza vatadzi vari mukati mayo. 
\q1  
\v 10 Nyeredzi dzokudenga namapoka adzo 
\q2 hadzizoratidzi chiedza chadzo. 
\q1 Zuva rinobuda richasvibiswa 
\q2 uye mwedzi hauzopi chiedza chawo. 
\q1  
\v 11 Ndicharanga nyika nokuda kwokuipa kwayo, 
\q2 navakaipa nokuda kwezvivi zvavo. 
\q1 Ndichagumisa vanozvikudza pakudada kwavo, 
\q2 uye ndichaderedza kuzvikudza kwavasina tsitsi. 
\q1  
\v 12 Ndichaita kuti munhu ashayikwe kudarika goridhe, 
\q2 ashayikwe kudarika kushayikwa kwegoridhe reOfiri. 
\q1  
\v 13 Naizvozvo ndichabvundisa matenga; 
\q2 uye nyika ichazungunuka kubva panzvimbo yayo, 
\q1 nehasha dzaJehovha Wamasimba Ose, 
\q2 pazuva rokutsamwa kwake kunopisa. 
\b  
\q1  
\v 14 Semhara inovhimwa, 
\q2 samakwai asina mufudzi, 
\q1 mumwe nomumwe achadzokera kuvanhu vokwake, 
\q2 mumwe nomumwe achatizira kunyika yake. 
\q1  
\v 15 Mumwe nomumwe achabatwa achabayiwa, 
\q2 vose vanobatwa vachaurayiwa nomunondo. 
\q1  
\v 16 Vacheche vavo vacharoverwa pasi vagobvamburwa-bvamburwa vachizviona; 
\q2 dzimba dzavo dzichapambwa uye vakadzi vavo vachachinyiwa. 
\b  
\q1  
\v 17 Tarirai, ndichavamutsira vaMedhia 
\q2 vasina hanya nesirivha, 
\q2 uye vasingafariri goridhe. 
\q1  
\v 18 Uta hwavo huchabaya majaya; 
\q2 havazovi nengoni navacheche 
\q2 kana kutarira vana netsitsi. 
\q1  
\v 19 Zvino Bhabhironi rembiri paumambo, 
\q2 kubwinya kwokuzvikudza kwavaBhabhironi, 
\q1 richaparadzwa naMwari 
\q2 kufanana neSodhomu neGomora. 
\q1  
\v 20 Haringatongogarwizve navanhu 
\q2 uye hakuna vachazogaramo kusvikira kuzvizvarwa zvose; 
\q1 hapana muArabhu achadzika tende rake ikoko, 
\q2 hakuna mufudzi achazorodza makwai ake ikoko. 
\q1  
\v 21 Asi zvisikwa zvomugwenga ndizvo zvichagara ikoko, 
\q2 makava achazadza dzimba dzavo; 
\q1 mazizi achagara ikoko, 
\q2 uye imomo ngururu dzichakwakuka-kwakuka. 
\q1  
\v 22 Mapere achachema ari munhare dzavo, 
\q2 makava mudzimba dzavo dzinoyevedza dzamadzimambo. 
\q1 Nguva yake yaswedera, 
\q2 uye mazuva aro haazowedzerwi. 
\c 14  
\q1  
\v 1 Jehovha achanzwira Jakobho tsitsi; 
\q2 achasarudza Israeri zvakare 
\q2 uye achavagarisa munyika yavo. 
\q1 Vatorwa vachabatana navo 
\q2 vachanamatirana neimba yaJakobho. 
\q1  
\v 2 Ndudzi dzichavatora 
\q2 dzigovadzosera kunzvimbo yavo chaiyo. 
\q1 Uye imba yaIsraeri ichatora ndudzi 
\q2 kuti vave varandarume navarandakadzi munyika yaJehovha. 
\q1 Vachaita nhapwa vaya vaimbova vatapi vavo, 
\q2 uye vachabata ushe pamusoro pavaya vaimbova vamanikidzi vavo. 
\p  
\v 3 Pazuva ramuchapiwa rusununguko naJehovha kubva pakutambudzika, nokusagadzikana, nokubatwa noutsinye,  
\v 4 uchasveeredza mambo weBhabhironi uchiti: 
\q1 Haiwa, mumanikidzi apera sei! 
\q2 Haiwa, hasha dzake dzapera sei! 
\q1  
\v 5 Jehovha akavhuna tsvimbo yavakaipa 
\q2 netsvimbo yamadzimambo, 
\q1  
\v 6 yaakarova nayo marudzi 
\q2 mukutsamwa nokurova kusingaperi, 
\q1 uye akakunda ndudzi 
\q2 nehasha nokurwisa kusingaperi. 
\q1  
\v 7 Nyika dzose dzazorora uye dzava norugare; 
\q2 votanga kufara nokuimba. 
\q1  
\v 8 Kunyange nemiti yemisipuresi nemisidhari yokuRebhanoni 
\q2 inofara pamusoro pako ichiti, 
\q1 “Zvino zvawaparadzwa, 
\q2 hakuna varume vanotsvaka huni vachauya kuzotitema.” 
\b  
\q1  
\v 9 Pasi, iro sheori razungunuka 
\q2 kuti rinangane newe pakuuya kwako; 
\q1 riri kumutsa mweya yavakaenda kuti izokukwazisai, 
\q2 vose vakaenda vari vatungamiri munyika; 
\q1 rinoita kuti vasimuke pazvigaro zvavo zvoushe, 
\q2 vose vakanga vari madzimambo endudzi. 
\q1  
\v 10 Vose vachapindura, 
\q2 vachati kwauri, 
\q1 “Newewo hauchisina simba, sesu; 
\q2 wangofanana nesu.” 
\q1  
\v 11 Kuzvikudza kwako kwose kwaderedzwa kusvika muguva, 
\q2 pamwe chete nokurira kworudimbwa rwako; 
\q1 honye dzawarirwa pasi pako 
\q2 uye makonye anokufukidza. 
\b  
\q1  
\v 12 Haiwa, wawa seiko, uchibva kudenga, 
\q2 iwe nyamasase yamangwanani, mwanakomana wamambakwedza! 
\q1 Wakakandwa panyika, 
\q2 iyewe wakambowisira ndudzi pasi! 
\q1  
\v 13 Wakati mumwoyo mako, 
\q2 “Ndichakwira kudenga; 
\q1 ndichasimudzira chigaro changu choushe 
\q2 pamusoro penyeredzi dzaMwari; 
\q1 ndichagara pachigaro changu choushe pagomo reungano, 
\q2 pamusoro pegomo dzvene. 
\q1  
\v 14 Ndichakwira pamusoro-soro pamakore; 
\q2 ndichazviita seWokumusoro-soro.” 
\q1  
\v 15 Asi waderedzwa kusvika kuguva, 
\q2 kwakadzika dzika kwegomba. 
\b  
\q1  
\v 16 Vose vanokuona vanokunanʼanidza, 
\q2 vachafungisisa zvamagumo ako vachiti, 
\q1 “Ndiye here murume 
\q2 uya akazungunutsa nyika, akadederesa ushe, 
\q1  
\v 17 murume akaita kuti nyika ive gwenga, 
\q2 akaparadza maguta ayo, 
\q2 akasatendera vasungwa vake kudzokera kumusha?” 
\b  
\q1  
\v 18 Madzimambo ose endudzi ave mukukudzwa, 
\q2 mumwe nomumwe muguva rake. 
\q1  
\v 19 Asi iwe warasirwa kunze kweguva rako, 
\q2 kufanana nedavi rakaraswa; 
\q1 wakafukidzwa navakaurayiwa, 
\q2 naavo vakabayiwa nomunondo, 
\q2 avo vakadzika kumatombo egomba. 
\q1 Kufanana nechitunha chinotsikwa-tsikwa netsoka, 
\q2  
\v 20 hauzobatani navo pakuvigwa kwako, 
\q1 nokuti wakaparadza nyika yako 
\q2 ukauraya vanhu vako. 
\b  
\q1 Vana vowakaipa 
\q2 havazotaurwi nezvavozve. 
\q1  
\v 21 Gadzirirai nzvimbo yokuurayira vanakomana vake 
\q2 nokuda kwezvivi zvamadzitateguru avo; 
\q1 havazosimuki kuti vagare nhaka yenyika 
\q2 vagozadza nyika namaguta avo 
\b  
\q1  
\v 22 “Ndichavamukira ini,” 
\q2 ndizvo zvinotaura Jehovha Wamasimba Ose. 
\q1 “Ndichabvisa zita rake navakasara vake kubva kuBhabhironi, 
\q2 vana vake navana vavana vake,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 23 “Ndichaishandura kuti ive nzvimbo yamazizi 
\q2 nenyika yamachawi; 
\q1 ndicharitsvaira nomutsvairo wokuparadza,” 
\q2 ndizvo zvinotaura Jehovha Wamasimba Ose. 
\s1 Chiprofita pamusoro peAsiria 
\p  
\v 24 Jehovha Wamasimba Ose akapika achiti: 
\q1 “Zvirokwazo sezvandakafunga ndizvo zvichaitika, 
\q2 uye sezvandakarangarira ndizvo zvichaitika. 
\q1  
\v 25 Ndichapwanya muAsiria munyika yangu; 
\q2 ndichamutsikirira pasi pamusoro pegomo rangu. 
\q1 Joko rake richabviswa kubva pavanhu vangu, 
\q2 nomutoro wake wokubva pamabvudzi avo.” 
\b  
\q1  
\v 26 Iyi ndiyo pfungwa yakarongerwa nyika yose; 
\q2 urwu ndirwo ruoko rwakatambanudzirwa pamusoro pamarudzi ose. 
\q1  
\v 27 Nokuti Jehovha Wamasimba Ose akazvironga zvino ndianiko angamukonesa? 
\q2 Ruoko rwake rwakatambanudzwa ndianiko angarudzora? 
\s1 Chiprofita pamusoro peFiristia 
\p  
\v 28 Shoko iri rakauya mugore rakafa Mambo Ahazi richiti: 
\q1  
\v 29 Musafara imi mose vaFiristia, 
\q2 muchiti shamhu yakakurovai imi, yavhunika; 
\q1 nokuti kubva pamudzi wenyoka iyo pachabuda mvumbi, 
\q2 chibereko chayo chichava nyoka ino uturu hunobaya. 
\q1  
\v 30 Murombo wavarombo achawana mafuro, 
\q2 uye vanoshayiwa vacharara pasi murugare. 
\q1 Asi ndichaparadza mudzi wako nenzara; 
\q2 ichauraya vakasara vako. 
\b  
\q1  
\v 31 Ungudza iwe suo! Chema, iwe guta! 
\q2 Nyungudukai, imi vaFiristia mose! 
\q1 Gore routsi riri kuuya richibva kumusoro, 
\q2 uye hapana achatiza pasimba raro. 
\q1  
\v 32 Ko, imhinduroi ichapiwa 
\q2 kunhume dzorudzi urwo? 
\q1 “Jehovha akasimbisa Zioni, 
\q2 uye mariri vanhu vake vanotambudzika vachawana pokuvanda.” 
\c 15  
\s1 Chiprofita pamusoro peMoabhu 
\p  
\v 1 Chirevo chaJehovha maererano neMoabhu: 
\q1 Ari romuMoabhu rava dongo, 
\q2 rakaparadzwa usiku! 
\q1 Kiri romuMoabhu rava dongo, 
\q2 rakaparadzwa usiku! 
\q1  
\v 2 Dhibhoni rakwira kutemberi yaro, 
\q2 kunzvimbo dzaro dzakakwirira kundochema; 
\q2 Moabhu ari kuungudza pamusoro peNebho napamusoro peMedhebha. 
\q1 Misoro yose yaveurwa 
\q2 ndebvu dzose dzabviswa. 
\q1  
\v 3 Munzira dzomuguta vakapfeka masaga: 
\q2 pamusoro pamatenga edzimba 
\q1 uye nomumatare, vanoungudza vose, 
\q2 vakazvambarara vachichema. 
\q1  
\v 4 Heshibhoni neErieri dzinodanidzira, 
\q2 manzwi avo anonzwika kusvikira kuJahazi. 
\q1 Naizvozvo varwi veMoabhu vanodanidzira, 
\q2 uye mwoyo yavo yaziya. 
\b  
\q1  
\v 5 Mwoyo wangu unodanidzira pamusoro peMoabhu; 
\q2 vatizi varo vanotiza kusvikira kuZoari, 
\q2 kusvikira kuEgirati-Sherishiya. 
\q1 Vanokwidza nenzira yokuRuhiti, 
\q2 vanofamba vachichema, 
\q1 munzira yokuHoronaimi 
\q2 vanochema kuparadzwa kwavo. 
\q1  
\v 6 Mvura yokuNimirimi yakapwa 
\q2 uye uswa hwaoma; 
\q1 bumhudza rapera 
\q2 uye hapachina chakasvibirira chakasara. 
\q1  
\v 7 Saka pfuma yavakawana neyavakaunganidza 
\q2 vanoiyambutsira mhiri kworukova rwemikonachando. 
\q1  
\v 8 Kudanidzira kwavo kwaita maungira kuchitevedza muganhu weMoabhu; 
\q2 kuungudza kwavo kunosvikira kuEgiraimi, 
\q2 kuchema kwavo kunosvikira kuBheeri Erimi. 
\q1  
\v 9 Mvura yapaDhimoni yakazara neropa, 
\q2 asi ndichauyisazve zvakawanda pamusoro peDhimoni, 
\q1 shumba pamusoro pavatizi veMoabhu 
\q2 uye napamusoro pavaya vakasara munyika. 
\c 16  
\q1  
\v 1 Tumirai mutero 
\q2 wamakwayana kumutongi wenyika, 
\q1 kubva kuSera, zvichiyambukira kurenje, 
\q2 kugomo roMwanasikana weZioni. 
\q1  
\v 2 Kufanana neshiri dzadzungaira 
\q2 dzichisundidzirwa kubva mudendere, 
\q1 ndizvo zvakaita vakadzi veMoabhu 
\q2 pamazambuko eAmoni. 
\q1  
\v 3 “Tipeiwo zano, 
\q2 ruramisirai. 
\q1 Ita mumvuri wako kuti ufanane nousiku, 
\q2 pamasikati makuru. 
\q1 Viga vatizi, 
\q2 usapandukira vapoteri. 
\q1  
\v 4 Rega vatizi veMoabhu vagare newe, 
\q2 iva utiziro hwavo kubva kumuparadzi.” 
\b  
\q1 Mutambudzi achasvika kumagumo, 
\q2 uye kuparadza kuchapera; 
\q2 mudenhi achatsakatika panyika. 
\q1  
\v 5 Murudo, chigaro choushe chichasimbiswa; 
\q2 mukutendeka, munhu achagarapo, mumwe anobva kuimba yaDhavhidhi, 
\q1 uyo anoti achitonga anotsvaka kururamisira, 
\q2 uye achikurumidza kuita zvakarurama. 
\b  
\q1  
\v 6 Takanzwa nezvokuzvikudza kwaMoabhu, 
\q2 namanyawi ake makuru uye kuzvida kwake, 
\q1 kuzvikudza kwake nokuvirima kwake, 
\q2 asi kuzvirumbidza kwake hakuna maturo. 
\q1  
\v 7 Naizvozvo vaMoabhu voungudza, 
\q2 vanoungudzira Moabhu pamwe chete. 
\q1 Chemai musuwe 
\q2 nokuda kwavarume veKiri Hareseti. 
\q1  
\v 8 Minda yeHeshibhoni yaoma 
\q2 uye mazambiringa eSibhima aomawo. 
\q1 Vatongi vendudzi vatsika-tsika 
\q2 mizambiringa yakaisvonaka, 
\q1 iyo yaimbosvika kuJazeri 
\q2 uye yaitandira yakananga kurenje. 
\q1 Mabukira ayo 
\q2 aitandira kusvika kugungwa. 
\q1  
\v 9 Saka ndinochema, sokuchema kweJazeri, 
\q2 nokuda kwemizambiringa yeSibhima. 
\q1 Haiwa Heshibhoni, haiwa Ereare, 
\q2 ndichakudiridza nemisodzi! 
\q1 Ruzha rwomufaro pamusoro pemizambiringa 
\q2 yakaibva napamusoro pezvamakakohwa rwanyaradzwa. 
\q1  
\v 10 Mufaro nokufarisisa zvabviswa paminda yemizambiringa; 
\q2 hapana anoimba kana kuita ruzha muminda yemizambiringa; 
\q1 hapana anosvina waini pazvisviniro, 
\q2 nokuti ndagumisa ruzha rwacho. 
\q1  
\v 11 Mwoyo wangu unorira nokuda kwaMoabhu, kufanana nokurira kwembira, 
\q2 mukati kati mangu munorira nokuda kweKiri Hareseti. 
\q1  
\v 12 Zvino kana Moabhu achizviratidza panzvimbo dzake dzakakwirira, 
\q2 anenge achingozvinetsa pachake; 
\q1 paanoenda kuimba yake kunonyengetera, 
\q2 zvinenge zvisina chazvinobatsira, 
\p  
\v 13 Iri ndiro shoko rakataurwa kare naJehovha pamusoro peMoabhu.  
\v 14 Asi zvino Jehovha anoti, “Makore matatu asati apfuura, sokuverengwa kwaangaitwa nomuranda akazvisunga kubatira mubayiro, kukudzwa kweMoabhu navanhu vake vose vakawanda kuchazvidzwa, uye vakapunyuka vake vachava vashoma kwazvo uye vasina simba.” 
\c 17  
\s1 Chirevo pamusoro peDhamasiko 
\p  
\v 1 Chirevo pamusoro peDhamasiko: 
\q1 “Tarirai, Dhamasiko harichazovazve guta, 
\q2 asi richava murwi wamatongo. 
\q1  
\v 2 Maguta eAroeri achasiyiwa uye achava mafuro ezvipfuyo, 
\q2 izvo zvichavata pasi, 
\q2 pasina anozvivhundutsa. 
\q1  
\v 3 Maguta akakomberedzwa namasvingo achanyangarika achibva pana Efuremu, 
\q2 uye simba roushe kubva paDhamasiko; 
\q1 vakasara veAramu 
\q2 vachava sembiri yavaIsraeri,” 
\q4 ndizvo zvinotaura Jehovha Wamasimba Ose. 
\q1  
\v 4 “Pazuva iro kukudzwa kwaJakobho kuchapera; 
\q2 mafuta omuviri wake achapera. 
\q1  
\v 5 Zvichafanana nomukohwi anokohwa madzinde akamira, 
\q2 uyo anokohwa zviyo noruoko rwake, 
\q1 sezvinoita murume anononga hura 
\q2 dzezviyo muMupata weRefaimi. 
\q1  
\v 6 Kunyange zvakadaro dzimwe tsanga dzichasara, 
\q2 sezvinoita muorivhi kana wazunzwa, 
\q1 uchisiya maorivhi maviri kana matatu pamatavi okumusoro-soro, 
\q2 mana kana mashanu pamatavi makuru anobereka,” 
\q4 ndizvo zvinotaura Jehovha Mwari waIsraeri. 
\q1  
\v 7 Pazuva iro vanhu vachatarira kuMusiki wavo, 
\q2 vagodzorera meso avo kuMutsvene waIsraeri. 
\q1  
\v 8 Havachazotarisi kuaritari, 
\q2 iro basa ramaoko avo, 
\q1 uye havachazovi nehanya nematanda aAshera nearitari 
\q2 dzezvinonhuhwira dzakaitwa neminwe yavo. 
\p  
\v 9 Pazuva iro maguta avo akasimba avakasiya nokuda kwavaIsraeri, achafanana nenzvimbo dzakaregerwa kuti dzive matenhere nezvinomera pasi pavo. Uye ose achava matongo. 
\q1  
\v 10 Nokuti wakanganwa Mwari Muponesi wako, 
\q2 hauna kurangarira Dombo, iyo nhare yako. 
\q1 Naizvozvo, kunyange ukazvisimira miti yakanakisisa, 
\q2 uye ukadyara mizambiringa inobva kune dzimwe nyika, 
\q1  
\v 11 kunyange pazuva raunoisima, ugoita kuti ikure, 
\q2 ugoita kuti ive namaruva, 
\q1 asi mukohwo uchava sapasina 
\q2 pazuva rehosha nokurwadziwa kusingarapiki. 
\b  
\q1  
\v 12 Haiwa, kutinhira kwendudzi zhinji, 
\q2 dzinotinhira sokutinhira kwegungwa! 
\q1 Haiwa, kuomba kwamarudzi 
\q2 anoomba kufanana nokutinhira kwemvura zhinji! 
\q1  
\v 13 Kunyange vanhu vakaomba sokutinhira kwamafungu emvura, 
\q2 paanovatuka vachatizira kure, 
\q1 vachidzingirirwa nemhepo sehundi pamusoro pezvikomo, 
\q2 kufanana nouswa hunozungunuswa pamberi pedutu guru. 
\q1  
\v 14 Munguva yamadekwana, 
\q2 pachava nokutyisa! Kusati kwaedza, havachipo! 
\q1 Uyu ndiwo mugove wavaya vanotibira, 
\q2 nomubayiro wavanotipamba. 
\c 18  
\s1 Chiprofita pamusoro peEtiopia 
\q1  
\v 1 Ine nhamo nyika yokutinhira 
\q2 kwamapapiro inotevedza nzizi dzeEtiopia, 
\q1  
\v 2 inotuma nhume nenzira yomugungwa, 
\q2 muzvikepe zvenhokwe pamusoro pemvura. 
\q1 Endai, imi nhume dzinokurumidza, 
\q1 kuvanhu vakareba uye vane ganda rinotsvedzerera, 
\q2 kuvanhu vanotyiwa kure napedyo, 
\q1 rudzi rune hasha nomutauro usinganzwisisiki, 
\q2 rune nyika yakakamurwa nenzizi. 
\b  
\q1  
\v 3 Imi mose muri pasi pose, 
\q2 imi munogara panyika, 
\q1 kana mureza wasimudzwa pamusoro pamakomo, 
\q2 muchauona, 
\q1 uye kana hwamanda yarira, 
\q2 muchainzwa. 
\q1  
\v 4 Zvanzi naJehovha kwandiri: 
\q2 “Ndicharamba ndinyerere uye ndichatarira ndiri paugaro hwangu, 
\q1 samanyirinyiri omushana unopisa, 
\q2 segore redova mukupisa kwokukohwa.” 
\q1  
\v 5 Nokuti, kukohwa kusati kwasvika, 
\q2 kana kutungira kwamaruva kwaguma, uye ruva rova muzambiringa woibva, 
\q2 achagura mabukira namapanga okurangura, 
\q2 achatemera pasi uye agorasira kure matavi akatandavara. 
\q1  
\v 6 Zvose zvichasiyirwa magora omugomo nokuzvikara zvesango; 
\q2 shiri dzichazvidya chirimo chose, 
\q1 uye zvikara zvesango 
\q2 zvichazvidya muchando chose. 
\p  
\v 7 Panguva iyoyo, zvipo zvichavigirwa Jehovha Wamasimba Ose, 
\q1 zvichibva kuvanhu vakareba vane ganda rinotsvedzerera, 
\q2 kubva kuvanhu vanotyiwa kwose kwose, 
\q1 rudzi rune hasha nomutauro usinganzwisisiki, 
\q2 rudzi rune nyika yakakamurwa nenzizi, 
\m zvipo zvichauyiswa kuZioni, nzvimbo yeZita raJehovha Wamasimba Ose. 
\c 19  
\s1 Chiprofita pamusoro peIjipiti 
\p  
\v 1 Chirevo pamusoro peIjipiti: 
\q1 Tarirai, Jehovha akatasva gore rinomhanya, 
\q2 uye ari kuuya kuIjipiti. 
\q1 Zvifananidzo zveIjipiti zviri kudedera pamberi pake, 
\q2 uye mwoyo yavaIjipita yonyungudika mukati mavo. 
\b  
\q1  
\v 2 “Ndichakuchidzira kumukirana pakati pavaIjipita, 
\q2 mununʼuna acharwa nomukoma, 
\q2 muvakidzani acharwa nowaakavakidzana naye, 
\q2 guta richarwisana nerimwe guta, 
\q2 umambo hucharwisana nohumwe umambo. 
\q1  
\v 3 VaIjipita vachaora mwoyo, 
\q2 uye ndichaita kuti zvavanoronga zvive pasina; 
\q1 vachabvunza zvifananidzo nemweya yavakafa, 
\q2 nokumasvikiro navavuki. 
\q1  
\v 4 Ndichaisa vaIjipita mumaoko amambo ano utsinye 
\q2 uye mambo anotyisa achatonga pamusoro pavo,” 
\q1 ndizvo zvinotaura Ishe, 
\q2 Jehovha Wamasimba Ose. 
\b  
\q1  
\v 5 Mvura yomurwizi ichapwa, 
\q2 uye mahombekombe erwizi achapwa agova akaoma. 
\q1  
\v 6 Migero ichanhuhwa; 
\q2 hova dzeIjipiti dzichaderera uye dzichapwa. 
\q1 Tsanga nenhokwe zvichauna, 
\q2  
\v 7 uyewo zvinomera zvichitevedza Nairi, 
\q2 pamuromo werwizi. 
\q1 Minda yose yakadyarwa mujinga meNairi ichaoma, 
\q2 mbesa dzichapeperetswa nemhepo, hazvingazovapozve. 
\q1  
\v 8 Vabati vehove vachagomera uye vagorira, 
\q2 vose vanokanda zviredzo muna Nairi; 
\q1 vaya vanokanda mimbure pamusoro pemvura vacharukutika. 
\p  
\v 9 Vanobata neshinda yakanaka vachapera simba, 
\q2 varuki vemicheka yakanaka vachashaya tariro. 
\q1  
\v 10 Vanobata nemicheka vachaora mwoyo, 
\q2 uye vose vanobatira mubayiro vacharwadziwa mwoyo. 
\b  
\q1  
\v 11 Machinda eZoani haasi chinhu asi mapenzi; 
\q2 makurukota aFaro akachenjera anopa zano risina mano. 
\q1 Mungareva sei kuna Faro, kuti, 
\q2 “Ndini mumwe wavakachenjera, 
\q2 mudzidzi wamadzimambo akare?” 
\b  
\q1  
\v 12 Zvino vakachenjera venyu varipiko? 
\q2 Ngavakuratidzei uye vakuzivisei 
\q1 zvakafungwa naJehovha Wamasimba Ose 
\q2 pamusoro peIjipiti. 
\q1  
\v 13 Machinda eZoani ava mapenzi, 
\q2 vatungamiri veMemufisi vanyengerwa; 
\q1 mabwe ekona amarudzi 
\q2 avo atsausa Ijipiti. 
\q1  
\v 14 Jehovha akadururira mavari mweya wedzungu; 
\q2 vanoita kuti Ijipiti idzedzereke mune zvose zvainoita, 
\q1 sezvinoita chidhakwa 
\q2 chinodzedzereka mumarutsi acho. 
\q1  
\v 15 Hapana chingaitwa neIjipiti, musoro kana muswe, 
\q2 davi romuchindwe kana rushanga. 
\p  
\v 16 Pazuva iro, vaIjipita vachafanana navakadzi. Vachadedera nokutya panosimudzwa ruoko rwaJehovha Wamasimba Ose pamusoro pavo.  
\v 17 Uye nyika yeJudha ichava chinhu chinotyisa kuvaIjipita; mumwe nomumwe achanzwa nezvaJudha achatya, nokuda kwezvinofungwa naJehovha Wamasimba Ose pamusoro pavo. 
\p  
\v 18 Pazuva iro, maguta mashanu omuIjipiti achataura mutauro weKenani uye vachapikira vachazvipira kuna Jehovha Wamasimba Ose. Rimwe racho richanzi Guta roKuparadza. 
\p  
\v 19 Pazuva iro, pachava nearitari kuna Jehovha mukati chaimo meIjipiti, nembiru kuna Jehovha pamuganhu wayo.  
\v 20 Ichava chiratidzo nechapupu kuna Jehovha Wamasimba Ose munyika yeIjipiti. Pavanodanidzira kuna Jehovha nokuda kwavamanikidzi vavo, achavatumira muponesi nomurwiri, ipapo achavanunura.  
\v 21 Saka Jehovha achazviratidza kuvaIjipita, uye pazuva iro vachaziva Jehovha. Vachanamata nezvibayiro uye nezvipiriso zvezviyo; vachaita mhiko kuna Jehovha uye vagodzichengeta.  
\v 22 Jehovha acharova Ijipiti nehosha; acharova agovarapazve. Vachatendeukira kuna Jehovha, uye achapindura mikumbiro yavo nokuvarapa. 
\p  
\v 23 Pazuva iro, pachava nenzira huru ichabva kuIjipiti ichienda kuAsiria. VaAsiria vachaenda kuIjipiti uye vaIjipita vachaendawo kuAsiria. VaIjipita navaAsiria vachanamata pamwe chete.  
\v 24 Pazuva iro Israeri ichava yechitatu, ichitevera Ijipiti neAsiria, ichava ropafadzo panyika.  
\v 25 Jehovha Wamasimba Ose achavaropafadza achiti, “Ngavaropafadzwe vaIjipita vanhu vangu, navaAsiria, basa ramaoko angu, navaIsraeri, nhaka yangu.” 
\c 20  
\s1 Chiprofita pamusoro peIjipiti neEtiopia 
\p  
\v 1 Mugore rokusvika kwomutungamiri mukuru, kuAshidhodhi, atumwa naSarigoni mambo weAsiria, akairwisa uye akaitapa,  
\v 2 panguva iyoyo Jehovha akataura kubudikidza naIsaya mwanakomana waAmozi. Akati kwaari, “Bvisa nguo yesaga pamuviri wako neshangu mumakumbo mako.” Iye akaita saizvozvo, akafamba asina nguo uye asina shangu. 
\p  
\v 3 Ipapo Jehovha akati, “Sezvakaita Isaya muranda wangu akafamba asina nguo, uye asina shangu kwamakore matatu, sechiratidzo nechishamiso pamusoro peIjipiti neEtiopia,  
\v 4 saizvozvo mambo weAsiria achaenda navatapwa veIjipiti, navakadzingwa veEtiopia, vadiki navakuru, uye magaro ari panze, kuti chive chinyadziso kuIjipiti.  
\v 5 Avo vaivimba neEtiopia uye vaizvikudza neIjipiti vachatya uye vachanyadziswa.  
\v 6 Pazuva iro, vanhu vaigara pamhenderekedzo ino vachati, ‘Tarirai zvaitika kuna vaya vataivimba navo, vaya vataitizira kwavari kuti vatibatsire uye vatinunure kubva kuna mambo weAsiria! Zvino isu tichapunyuka sei?’ ” 
\c 21  
\s1 Chiprofita pamusoro peBhabhironi 
\p  
\v 1 Chirevo pamusoro peRenje riri pedyo neGungwa: 
\q1 Kufanana nechamupupuri chinovhuvhuta nomunyika yezasi, 
\q2 mupambi anouya achibva kurenje, 
\q2 kubva kunyika inotyisa. 
\b  
\q1  
\v 2 Ndaratidzwa chiratidzo chinorwadza. 
\q2 Mupanduki anopanduka, muparadzi anotora zvokupamba 
\q1 Eramu, rwisa! Medhia, vandira! 
\q2 Ndichagumisa kugomera kwose kwaakaita kuti kuvepo. 
\b  
\q1  
\v 3 Naizvozvo muviri wangu wakazara nokurwadziwa; 
\q2 marwadzo akandibata, kufanana nomukadzi ari kusununguka; 
\q1 ndiri kudzedzereka nezvandinonzwa, 
\q2 ndakanganisika nezvandinoona. 
\q1  
\v 4 Mwoyo wangu woziya, 
\q2 kutya kwondidederesa; 
\q1 rubvunzavaeni rwandaishuva 
\q2 rwava chinyangadzo kwandiri. 
\b  
\q1  
\v 5 Vanogadzira matafura, 
\q2 vanowaridza micheka pasi, 
\q2 vanodya, vanonwa! 
\q1 Simukai, imi machinda, 
\q2 zodzai nhoo! 
\p  
\v 6 Zvanzi naIshe kwandiri: 
\q1 “Endai, mundogadza nharirire 
\q2 uye muite kuti azivise zvaanoona. 
\q1  
\v 7 Kana achiona ngoro namapoka amabhiza, 
\q2 navatasvi vari pamusoro pembongoro 
\q1 kana vatasvi vari pamusoro pengamera, 
\q2 ngaave akachenjera, akachenjera zvizere.” 
\p  
\v 8 Ipapo nharirire yakadanidzira ichiti, 
\q1 “Zuva nezuva, tenzi wangu, ndinomira pamusoro peshongwe yomurindi; 
\q2 usiku hwoga hwoga ndinogara panzvimbo yangu. 
\q1  
\v 9 Tarirai, hoyo murume ari kuuya ari mungoro 
\q2 neboka ramabhiza. 
\q1 Uye anopa mhinduro achiti, 
\q2 ‘Bhabhironi rawa, rawa! 
\q1 Zvifananidzo zvose zvavamwari 
\q2 varo zvaputsirwa pasi!’ ” 
\b  
\q1  
\v 10 Haiwa, vanhu vangu vapwanyirwa paburiro, 
\q2 ndinokuudzai zvandanzwa kubva kuna 
\q1 Jehovha Wamasimba Ose, 
\q2 kubva kuna Mwari waIsraeri. 
\s1 Chiprofita pamusoro peEdhomu 
\p  
\v 11 Chirevo pamusoro peDhuma: 
\q1 Mumwe anodana kwandiri ari kuSeiri, achiti, 
\q2 “Nharirire iwe, inguvaiko ino yousiku? 
\q2 Nharirire iwe, inguvaiko ino yousiku?” 
\q1  
\v 12 Nharirire inopindura ichiti, 
\q2 “Mambakwedza achauya, asi nousikuwo. 
\q1 Zvino kana uchida kubvunza, bvunza; 
\q2 uye ugodzokazve.” 
\s1 Chiprofita pamusoro peArabhia 
\p  
\v 13 Chirevo pamusoro peArabhia: 
\q1 Imi ngoro dzavaDhedhani, 
\q2 munodzika misasa mumatenhere eArabhia, 
\q2  
\v 14 vigirai vane nyota mvura; 
\q1 imi munogara muTema, 
\q2 uyai nezvokudya zvavanotiza. 
\q1  
\v 15 Vari kutiza munondo, 
\q2 kubva kumunondo wavhomorwa, 
\q1 nokuuta hwawemburwa, 
\q2 uye nokupisa kwehondo. 
\p  
\v 16 Zvanzi naJehovha kwandiri: “Pachinguva chegore rimwe chete, sokuverenga kungaita mushandi akabatwa nechibvumirano, kuzvikudza kwose kweKedhari kuchapera.  
\v 17 Varume vouta vachapunyuka, ivo mhare dzeKedhari vachava vashoma.” Jehovha, Mwari weIsraeri ataura. 
\c 22  
\s1 Chiprofita pamusoro peJerusarema 
\p  
\v 1 Chirevo pamusoro poMupata weChiratidzo: 
\q1 Chii chinokutambudzai zvino, 
\q2 zvokuti mose makwira pamusoro pamatenga edzimba? 
\q1  
\v 2 Haiwa guta rizere nemheremhere, 
\q2 haiwa guta renyonganyonga nokupembera? 
\q1 Vakaurayiwa venyu havana kubayiwa nomunondo, 
\q2 kana kufira muhondo. 
\q1  
\v 3 Vatungamiri vako vose vatiza pamwe chete; 
\q2 vabatwa pasina kushandiswa uta. 
\q1 Mose imi makabatwa mukaitwa vasungwa pamwe chete, 
\q2 kunyange makanga matiza muvengi achiri kure. 
\q1  
\v 4 Naizvozvo ndakati, “Endai kure neni; 
\q2 regai ndicheme kwazvo. 
\q1 Musaedza kundinyaradza 
\q2 pamusoro pokuparadzwa kwavanhu vangu.” 
\b  
\q1  
\v 5 Ishe, Jehovha Wamasimba Ose, 
\q2 ane zuva renyonganyonga nerokutsikira 
\q2 pasi nokutyisa muMupata woKuratidza, 
\q1 zuva rokukoromorera masvingo 
\q2 pasi nerokudanidzira kumakomo. 
\q1  
\v 6 Eramu anotora goba, 
\q2 pamwe chete navatasvi vamabhiza nengoro; 
\q2 Kiri anofudugura nhoo. 
\q1  
\v 7 Mipata yako yakaisvonaka yakazara nengoro, 
\q2 uye vatasvi vamabhiza vakaiswa pamasuo eguta; 
\q1  
\v 8 kudzivirirwa kweJudha kwakabviswa. 
\b  
\q1 Uye pazuva iro makatarira, 
\q2 kuzvombo muMuzinda weSango; 
\q1  
\v 9 makaona kuti Guta raDhavhidhi 
\q2 raiva napakakoromoka pakawanda 
\q1 munzvimbo dzokudzivirira; 
\q2 makazvichengetera mvura muDziva reZasi. 
\q1  
\v 10 Makaverenga dzimba muJerusarema, 
\q2 mukaondomora dzimba kuti musimbise rusvingo. 
\q1  
\v 11 Makavaka gungwa pakati pamasvingo maviri, 
\q2 kuti muchingidzire mvura yomudziva rakare, 
\q1 asi hamuna kutarira kuna Iye akariita, 
\q2 kana kuva nehanya naIye akazvironga kare. 
\b  
\q1  
\v 12 Ishe, Jehovha Wamasimba Ose, 
\q2 akakudaidzai pazuva iro 
\q1 kuti mucheme uye muungudze, 
\q2 kuti mudzure bvudzi renyu uye mufuge masaga. 
\q1  
\v 13 Asi tarirai, kune mufaro nokupembera, 
\q2 kubayiwa kwemombe nokuurayiwa kwamakwai, 
\q2 kudyiwa kwenyama nokunwiwa kwewaini! 
\q1 Munoti, “Ngatidyei uye tinwe, 
\q2 nokuti mangwana tichafa!” 
\p  
\v 14 Jehovha Wamasimba Ose akazivisa izvi munzeve dzangu achiti, “Kusvikira pazuva rokufa kwako, chivi ichi hachizokanganwirwi,” ndizvo zvinotaura Ishe, Jehovha Wamasimba Ose. 
\p  
\v 15 Zvanzi naIshe, Jehovha Wamasimba Ose: 
\q1 “Enda, undoti kumutariri uyu, 
\q2 kuna Shebhina, mutariri womuzinda, uti kwaari: 
\q1  
\v 16 Uri kuitei pano uye ndiani akakupa mvumo 
\q2 yokuti uzvicherere rinda pano, 
\q1 uchizvivezera rinda rako pakakwirira 
\q2 nokuzvivezera nzvimbo yako yokuzorora mudombo? 
\b  
\q1  
\v 17 “Hokoyo, Jehovha ava kuda kukuti dzvi, 
\q2 agokurasira kure, iwe murume wesimba. 
\q1  
\v 18 Achakupomba-pomba sebhora 
\q2 agokukanda munyika yakakura. 
\q1 Ndimo mauchafira, 
\q2 uye ngoro dzako dzine mbiri dzichasara imomo, 
\q2 iwe wokunyadzisa imba yatenzi wako! 
\q1  
\v 19 Ndichakudzinga pabasa rako, 
\q2 uye uchatandaniswa panzvimbo yako. 
\p  
\v 20 “Pazuva iro ndichadana muranda wangu, Eriakimi mwanakomana waHirikia.  
\v 21 Ndichamupfekedza nguo yako ndigomusimbisa nebhanhire rako uye ndigoisa masimba ako pamusoro pake. Achava baba kuna vagere muJerusarema nokuimba yaJudha.  
\v 22 Ndichaisa papfudzi rake kiyi yeimba yaDhavhidhi; chaanenge azarura hapana angapfiga, uye chaanenge apfiga hapana angazarura.  
\v 23 Ndichamuroverera sembambo panzvimbo yakasimba; achava chigaro chinokudzwa paimba yababa vake.  
\v 24 Mbiri yeimba yababa vake ichaturikwa paari; matavi namabukira, nemidziyo midiki yose, kubva pamikombe kusvikira pamakate ose. 
\p  
\v 25 “Pazuva iro,” ndizvo zvinotaura Jehovha Wamasimba Ose, “mbambo yakarovererwa panzvimbo yakasimba ichabva; ichatemwa igowisirwa pasi, uye mutoro wakarembera pauri uchatemerwa pasi.” Jehovha ataura izvozvo. 
\c 23  
\s1 Chiprofita pamusoro peTire 
\p  
\v 1 Chirevo pamusoro peTire: 
\q1 Ungudzai imi zvikepe zveTashishi! 
\q2 Nokuti Tire raparadzwa 
\q2 uye rasiyiwa risina imba kana pangamira zvikepe. 
\q1 Shoko rakasvika kwavari richibva 
\q2 kunyika yeSaipurasi. 
\b  
\q1  
\v 2 Nyararai, imi vanhu vagere pachiwi 
\q2 nemi vatengesi veSidhoni, 
\q2 imi makapfumiswa navashambadzi vomunyanza. 
\q1  
\v 3 Pamusoro pemvura 
\q2 zhinji zviyo zveShihori zvakayambutswa; 
\q1 mukoho weNairi ndiwo waiva pfuma yeTire, 
\q2 uye ikazova nzvimbo yokutengesera yamarudzi. 
\b  
\q1  
\v 4 Nyara, iwe Sidhoni, uye newe nhare yegungwa, 
\q2 nokuti gungwa rataura richiti, 
\q1 “Handina kumborwadziwa kana kubereka; 
\q2 handina kumborera vanakomana kana kukurisa vanasikana.” 
\q1  
\v 5 Panosvika shoko kuIjipiti, 
\q2 vacharwadziwa pamusoro peshoko rinobva kuTire. 
\b  
\q1  
\v 6 Yambukirai kuTashishi; 
\q2 ungudzai, imi vanhu vagere pachiwi. 
\q1  
\v 7 Ko, iri ndiro guta renyu ramafaro here, 
\q2 guta rakare kare, 
\q1 rakaendeswa kure kure netsoka dzaro 
\q2 kundogara kunyika iri kure? 
\q1  
\v 8 Ndianiko akarongera Tire izvozvi, 
\q2 iro raipa korona, 
\q1 vatengesi varo vari machinda, 
\q2 vashambadziri varo vane mukurumbira munyika? 
\q1  
\v 9 Jehovha Wamasimba Ose akaronga izvozvo, 
\q2 kuti adzikise kuzvikudza kwekukudzwa kwose, 
\q2 uye kuti aninipise vose vane mukurumbira panyika. 
\b  
\q1  
\v 10 Rima nyika yako sezvinoitwa mujinga meNairi, 
\q2 iwe mwanasikana weTashishi, 
\q2 nokuti hauchina panomira zvikepe. 
\q1  
\v 11 Jehovha akatambanudza ruoko rwake pamusoro pegungwa, 
\q2 uye akaita kuti ushe hwaro hudedere. 
\q1 Akarayira pamusoro peKenani, 
\q2 kuti nhare dzayo dziparadzwe. 
\q1  
\v 12 Akati, “Mafaro ako haachazovapozve, 
\q2 iwe mhandara yeSidhoni, yaparadzwa! 
\b  
\q1 “Simuka uyambukire kuSaipurasi; 
\q2 Kunyange naikoko haundowani zororo.” 
\q1  
\v 13 Tarira nyika yavaBhabhironi, 
\q2 rudzi urwo haruchaverengwi zvino! 
\q1 VaAsiria vakaiita 
\q2 nzvimbo yemhuka dzerenje; 
\q1 vakamisa shongwe dzavo dzokurwa, 
\q2 vakakoromora nhare dzaro dzikava pasina, 
\q2 uye vakarishandura rikava dongo. 
\b  
\q1  
\v 14 Ungudzai, imi zvikepe zveTashishi; 
\q2 nhare yenyu yaparadzwa! 
\p  
\v 15 Panguva iyoyo Tire ichakanganwikwa kwamakore makumi manomwe, zvakaenzana namakore oupenyu hwamambo. Asi shure kwamakore makumi manomwe aya, Tire richaitirwa sezvinoimbwa rwiyo rwechifeve runoti: 
\q1  
\v 16 “Tora rudimbwa, ufambe nomuguta, 
\q2 iwe chifeve chakakanganikwa; 
\q1 ridza rudimbwa zvakanaka, imba nziyo zhinji, 
\q2 kuitira kuti ugorangarirwa.” 
\p  
\v 17 Panopera makore makumi manomwe, Jehovha achashanyira Tire. Richadzokerazve kubasa raro sechifeve rigofeva noushe hwose huri pamusoro penyika.  
\v 18 Asi zvarakashambadzira uye nomubayiro waro zvichatsaurirwa Jehovha; hazvingachengetwi kana kuvigwa. Zvarakashambadzira zvichaendeswa kuna avo vanogara pamberi paJehovha, kuti vave nezvokudya zvakawanda nenhumbi dzakanaka. 
\c 24  
\s1 Kuparadzwa kweNyika naJehovha 
\q1  
\v 1 Tarirai, Jehovha ari kuzoparadza nyika 
\q2 achiiparadza zvachose; 
\q1 achanyangadza kutarisika kwayo 
\q2 uye achaparadzira vanogaramo, 
\q1  
\v 2 zvichangofanana, 
\q2 zvinoitirwa muprista nezvinoitirwa vanhu, 
\q2 zvinoitirwa vatenzi nezvinoitirwa muranda, 
\q2 zvinoitirwa vahosi nezvinoitirwa mushandiri, 
\q2 zvinoitirwa mutengesi nezvinoitirwa mutengi, 
\q2 zvinoitirwa anokwereta nezvinoitirwa akweretwa, 
\q2 zvinoitirwa anoripa mhindu nezvinoitirwa anoreva mhindu. 
\q1  
\v 3 Nyika ichaparadzwa zvachose 
\q2 uye ichatorerwa zvayo zvose. 
\q4 Jehovha ataura shoko irori. 
\q1  
\v 4 Nyika inooma uye inosvava, 
\q2 pasi pose panorwadziwa uye panounyana, 
\q2 vanokudzwa venyika vanopera simba uye vanorwadziwa. 
\q1  
\v 5 Nyika inosvibiswa navanhu vayo; 
\q2 havana kuteerera mirayiro, 
\q1 vakapandukira mitemo 
\q2 uye vakaputsa sungano isingaperi. 
\q1  
\v 6 Naizvozvo chituko chinoparadza nyika, 
\q2 vanhu vayo vanofanira kuzvitakurira mhosva dzavo. 
\q1 Naizvozvo vagari vomunyika vapiswa, 
\q2 uye vashoma ndivo vasara. 
\q1  
\v 7 Waini itsva inopera uye muzambiringa unosvava; 
\q2 vose vanoda mafaro vanogomera. 
\q1  
\v 8 Kufadza kwamakandira kwanyaradzwa, 
\q2 kupembera kwavapururudzi kwapera, 
\q2 rudimbwa rwomufaro rwanyaradzwa. 
\q1  
\v 9 Havangazonwi waini vachiimba rwiyo; 
\q2 doro rava kuvava kuvanwi varo. 
\q1  
\v 10 Guta rakoromorwa rava dongo; 
\q2 mukova wokupinda mudzimba dzose wapfigwa. 
\q1  
\v 11 Vochemera waini mumigwagwa; 
\q2 mufaro wose washanduka wava kusuwa, 
\q2 mupururu wabviswa panyika. 
\q1  
\v 12 Guta rasara rava dongo, 
\q2 masuo aro aputswa-putswa. 
\q1  
\v 13 Ndizvo zvazvichaita munyika 
\q2 napakati pendudzi, 
\q1 zvichafanana nokuzunzwa kwomuorivhi, 
\q2 kana sezvinosara pakunongwa shure kwegohwo ramazambiringa. 
\b  
\q1  
\v 14 Vanosimudza manzwi avo, vanopururudza nomufaro; 
\q2 kubva kumavirira vanoparidza zvoukuru hwaJehovha. 
\q1  
\v 15 Naizvozvo kumabvazuva, mbiri kuna Jehovha; 
\q2 kudzai zita raJehovha Mwari waIsraeri 
\q2 pazviwi zvegungwa. 
\q1  
\v 16 Kubva kumigumo yenyika tinonzwa kuimba kunoti: 
\q2 “Ngaakudzwe iye Akarurama.” 
\b  
\q1 Asi ini ndakati, “Ndiri kupera muviri, ndiri kupera muviri! 
\q2 Ndine nhamo! 
\q1 Vanyengeri vakaita zvinhu nokunyengera! 
\q2 Vanyengeri vakaita zvinhu nokunyengera kukuru!” 
\q1  
\v 17 Kutya negomba zvakakumirirai, 
\q2 imi vanhu vapanyika. 
\q1  
\v 18 Ani naani anotiza kutinhira kunotyisa, 
\q2 achawira mugomba; 
\q1 ani naani anokwira achibuda mugomba 
\q2 achabatwa mumusungo. 
\b  
\q1 Nokuti mawindo okudenga azaruka, 
\q2 uye nheyo dzapanyika dzozungunuka. 
\q1  
\v 19 Nyika yaputswa-putswa, 
\q2 nyika yakamurwa napakati, 
\q2 nyika yozungunuswa chose. 
\q1  
\v 20 Nyika yodzedzereka sechidhakwa, 
\q2 inozengaira semba iri mumhepo; 
\q1 kudarika nokumukira kwayo kwairemera kwazvo, 
\q2 zvokuti inowa, ikasazomukazve. 
\b  
\q1  
\v 21 Pazuva iro Jehovha acharanga masimba 
\q2 omuchadenga kumusoro, 
\q2 uye namadzimambo ari pamusoro penyika pasi. 
\q1  
\v 22 Vachaunganidzwa pamwe chete 
\q2 kufanana navasungwa vakasungwa mugomba; 
\q1 vachapfigirwa mutorongo 
\q2 vagozorangwa kwamazuva mazhinji. 
\q1  
\v 23 Mwedzi uchanyadziswa, zuva richanyara; 
\q2 nokuti Jehovha Wamasimba Ose achatonga 
\q1 pamusoro peGomo reZioni nomuJerusarema, 
\q2 napamberi pavakuru varo, nokubwinya kukuru. 
\c 25  
\s1 Rumbidzo kuna Jehovha 
\q1  
\v 1 Haiwa, Jehovha ndimi Mwari wangu; 
\q2 ndichakukudzai uye ndicharumbidza zita renyu, 
\q1 nokuti nokutendeka kukuru 
\q2 makaita zvinhu zvinoshamisa, 
\q2 zvinhu zvamakaronga kare kare. 
\q1  
\v 2 Makaita kuti guta rive dutu ramarara, 
\q2 guta rakakomberedzwa rikava dongo, 
\q1 nhare yavatorwa haichazova gutazve; 
\q2 haichazovakwazve. 
\q1  
\v 3 Naizvozvo vanhu vane simba vachakukudzai; 
\q2 maguta endudzi dzine utsinye achakuremekedzai. 
\q1  
\v 4 Manga muri utiziro hwavarombo, 
\q2 utiziro hwaanoshayiwa mukutambudzika kwake, 
\q1 uye dumba panguva yemvura zhinji 
\q2 nomumvuri pakupisa kwezuva. 
\q1 Nokuti kufema kwavano utsinye 
\q2 kwakafanana nemvura zhinji inorovera parusvingo, 
\q2  
\v 5 uye kwakafanana nokupisa kwerenje. 
\q1 Munonyaradza bope ravatorwa; 
\q2 sokupisa kunotonhodzwa nomumvuri wegore, 
\q2 naizvozvo rwiyo rwavane utsinye rwanyaradzwa. 
\q1  
\v 6 Pamusoro pegomo iri, Jehovha Wamasimba Ose achagadzirira 
\q2 vanhu vose mutambo wezvakakora, 
\q1 namabiko ewaini yakare, 
\q2 nyama yakanakisa uye newaini yakaisvonaka. 
\q1  
\v 7 Pamusoro pegomo iri, 
\q2 achaparadza chifukidziro chinoputira marudzi ose, 
\q1 mucheka unofukidza ndudzi dzose; 
\q2  
\v 8 iye achamedza rufu nokusingaperi. 
\q1 Wamasimba Ose achapisika misodzi 
\q2 kubva pazviso zvose; 
\q1 achabvisa kunyadziswa kwavanhu vake 
\q2 panyika yose. 
\q4 Jehovha ataura. 
\p  
\v 9 Pazuva iro vachati, 
\q1 “Zvirokwazvo uyu ndiye Mwari wedu; 
\q2 takavimba naye, iye akatiponesa. 
\q1 Uyu ndiye Jehovha, takavimba naye; 
\q2 ngatifarei tifarisise muruponeso rwake.” 
\b  
\q1  
\v 10 Ruoko rwaJehovha ruchagara pagomo iri, 
\q2 asi Moabhu achatsikwa-tsikwa pasi pake, 
\q2 samashanga anotsikwa-tsikwa mumupfudze. 
\q1  
\v 11 Vachatambanudza maoko avo mariri, 
\q2 somushambiri anotambanudza maoko ake kuti ashambire. 
\q1 Mwari achaderedza kuzvikudza kwavo, 
\q2 kunyange vachigona kuita zvakanaka namaoko avo, 
\q1  
\v 12 Achakoromora nhare yako yamasvingo 
\q2 akakwirira agoaputsira pasi; 
\q1 achaakoromorera pasi, 
\q2 muguruva chaimo. 
\c 26  
\s1 Rwiyo rwoKurumbidza 
\p  
\v 1 Pazuva iro rwiyo urwu ruchaimbwa munyika yaJudha: 
\q1 Tine guta rakasimba; 
\q2 Mwari anoita kuti ruponeso 
\q2 ruve masvingo nenhare dzaro. 
\q1  
\v 2 Zarurai masuo kuti rudzi 
\q2 rwakarurama rupinde, 
\q2 rudzi runochengeta kutenda. 
\q1  
\v 3 Muchachengeta murugare 
\q2 rwakakwana munhu ane mufungo wakasimba, 
\q2 nokuti anovimba nemi. 
\q1  
\v 4 Vimba naJehovha nokusingaperi, 
\q2 nokuti Jehovha, iye Jehovha ndiye Dombo rokusingaperi. 
\q1  
\v 5 Anoderedza avo vagere pakakwirira, 
\q2 anodzikisa pasi guta rapamusoro; 
\q1 anorideredza kusvikira pavhu 
\q2 uye anorikanda muguruva. 
\q1  
\v 6 Tsoka dzicharitsikirira pasi, 
\q2 tsoka dzavakamanikidzwa, 
\q2 idzo tsoka dzavarombo. 
\b  
\q1  
\v 7 Nzira yavakarurama yakati chechetere; 
\q2 imi Akarurama, munoita kuti nzira yavakarurama iti chechetere. 
\q1  
\v 8 Hongu, Jehovha tichifamba munzira yomurayiro wenyu, 
\q2 tinokumirirai; 
\q1 zita renyu nemukurumbira 
\q2 wenyu ndizvo chishuwo chemwoyo yedu. 
\q1  
\v 9 Mwoyo wangu unokushuvai pausiku; 
\q2 mangwanani, mweya wangu unokupangai. 
\q1 Kutonga kwenyu pakunouya panyika, 
\q2 vanhu vanogara panyika vanodzidza zvokururama. 
\q1  
\v 10 Kunyange nyasha dzichiratidzwa kuna vakaipa, ivo havadzidzi kururama; 
\q2 kunyange munyika yokururama, 
\q1 vanongoramba vachiita zvakaipa, 
\q2 uye havana hanya noukuru hwaJehovha. 
\q1  
\v 11 Haiwa Jehovha, ruoko rwenyu rwakasimudzirwa kumusoro, 
\q2 asi havaruoni. 
\q1 Ngavaone kushingaira kwenyu pamusoro pavanhu venyu vagonyadziswa; 
\q2 moto wakachengeterwa vavengi venyu ngauvaparadze. 
\b  
\q1  
\v 12 Jehovha, imi munotigadzirira rugare; 
\q2 zvose zvatakakwanisa ndimi makatiitira. 
\q1  
\v 13 Haiwa Jehovha Mwari wedu, mamwe madzishe kunze kwenyu akatitonga, 
\q2 asi zita renyu ndiro ratinokudza chete. 
\q1  
\v 14 Ivo vakafa zvino, havachararamizve; 
\q2 mweya yavakafa haimuki. 
\q1 Makavaranga mukavaparadza; 
\q2 makabvisa chirangaridzo chavo. 
\q1  
\v 15 Makakurisa rudzi, imi Jehovha; 
\q2 makakurisa rudzi. 
\q1 Makazviwanira mukurumbira; 
\q2 mukakurisa miganhu yose yenyika. 
\b  
\q1  
\v 16 Jehovha, vakauya kwamuri mumatambudziko avo; 
\q2 pamakavarova, 
\q2 havana kugona kuzevezera munyengetero. 
\q1  
\v 17 Sezvinoita mukadzi ane mimba oda kusununguka, 
\q2 anomonyoroka mukurwadziwa kwake, agochema kwazvo, 
\q2 ndizvo zvatakanga takaita pamberi penyu, imi Jehovha. 
\q1  
\v 18 Takanga tine mimba, tichimonyoroka mukurwadziwa, 
\q2 asi takabereka mhepo. 
\q1 Hatina kuvigira nyika ruponeso; 
\q2 hatina chatakaberekera vanhu venyika. 
\b  
\q1  
\v 19 Asi vakafa venyu vachararama; 
\q2 miviri yavo ichamuka. 
\q1 Imi mugere muguruva, 
\q2 mukai mupembere. 
\q1 Dova renyu rakaita sedova ramangwanani; 
\q2 nyika ichabudisa vakafa vayo. 
\b  
\q1  
\v 20 Chiendai, vanhu vangu, 
\q2 pindai mumakamuri enyu, 
\q1 mugopfiga mikova shure kwenyu; 
\q2 muvande kwechinguva kusvikira kutsamwa kwake kwapfuura. 
\q1  
\v 21 Tarirai, Jehovha ari kubuda muugaro hwake, 
\q2 kuti arange vanhu venyika nokuda kwezvivi zvavo. 
\q1 Nyika ichafukura ropa rakateurwa pamusoro payo; 
\q2 haichazovanzizve vakaurayiwa vayo. 
\c 27  
\s1 Kusunungurwa kwaIsraeri 
\p  
\v 1 Pazuva iro, 
\q1 Jehovha acharanga nomunondo wake, 
\q2 iwo munondo wake mukuru une simba uye unotyisa, 
\q1 Revhiatani nyoka inokurumidza, 
\q2 Revhiatani nyoka inogonyana; 
\q1 achauraya chikara chomugungwa. 
\p  
\v 2 Pazuva iro, 
\q1 “Imbai nezvomuzambiringa unobereka: 
\q2  
\v 3 Ini Jehovha ndini ndinouchengeta; 
\q2 ndinoramba ndichiudiridzira. 
\q1 Ndinourinda masikati nousiku 
\q2 kuitira kuti parege kuva neanoukanganisa. 
\q2  
\v 4 Handina kutsamwa. 
\q1 Dai paingova nerukato neminzwa zvinorwa neni! 
\q2 Ndaienda kundorwa nazvo; 
\q2 ndaizvipisa zvose nomoto. 
\q1  
\v 5 Kana kuti ngazviuye zvizovanda kwandiri; 
\q2 ngazviyanane neni, hongu, ngazviyanane neni.” 
\b  
\q1  
\v 6 Mumazuva anouya, Jakobho achadzika midzi, 
\q2 Israeri achabukira uye achatunga maruva, 
\q2 agozadza nyika yose nomuchero, 
\b  
\q1  
\v 7 Ko, Jehovha akamurova here 
\q2 sezvaanorova avo vakamurova? 
\q1 Akaurayiwa here 
\q2 sokuurayiwa kwakaitwa avo vakamuuraya? 
\q1  
\v 8 Muhondo makarwa naye mukamudzinga, 
\q2 nokurwisa kwake kunotyisa akamudzinga, 
\q2 sezvinoitika pazuva rinovhuvhuta mhepo yokumabvazuva. 
\q1  
\v 9 Zvino nenzira iyi, mhosva yaJakobho ichadzikinurwa, 
\q2 uye izvi zvichava chibereko chakazara chokubviswa kwechivi chake: 
\q1 Paanoita kuti aritari dzose dzifanane namabwe omunyaka akaputswa-putswa, 
\q2 hapana matanda aAshera kana aritari dzezvinonhuhwira zvichasiyiwa zvakamira. 
\q1  
\v 10 Guta rakakomberedzwa norusvingo rasiyiwa rava dongo, 
\q2 hwava ugaro hwakasiyiwa, 
\q1 kufanana nerenje; 
\q2 mhuru dzofura ikoko, uye ikoko ndiko kwadzinovata; 
\q2 dzinosiya matavi asisina chinhu. 
\q1  
\v 11 Panooma matavi acho, anovhuniwa, 
\q2 uye vakadzi vanouya vovesa moto nawo. 
\q1 Nokuti vanhu ava havana njere; 
\q2 nokudaro Muiti wavo haachina tsitsi pamusoro pavo, 
\q2 uye Musiki wavo haangavaitiri nyasha. 
\p  
\v 12 Pazuva iro Jehovha achapura kubva panoyerera Yufuratesi kusvikira paRukova rweIjipiti, uye imi vaIsraeri, muchaunganidzwa muchiita mumwe mumwe.  
\v 13 Uye pazuva iro hwamanda huru icharira. Vakanga vofira muAsiria uye navaya vakanga vatizira kuIjipiti vachauya kuzonamata Jehovha pamusoro pegomo dzvene riri muJerusarema. 
\c 28  
\s1 Nhamo kuna Efuremu 
\q1  
\v 1 Ine nhamo korona yokuzvikudza, yezvidhakwa zveEfuremu, 
\q2 neruva rosvava pakubwinya kworunako rwaro, 
\q1 riri pamusoro pemipata yakaorera 
\q2 yaavo vakurirwa newaini! 
\q1  
\v 2 Tarira, Ishe ano mumwe ane simba uye anokurira. 
\q2 Sechimvuramabwe uye nedutu rinoparadza, 
\q1 sedutu remvura zhinji uye samafashamu emvura inonaya, 
\q2 achaiwisira pasi nesimba guru. 
\q1  
\v 3 Iya korona, yokuzvikudza yezvidhakwa zveEfuremu, 
\q2 ichatsikwa-tsikwa pasi petsoka. 
\q1  
\v 4 Ruva riya rosvava pakubwinya kworunako rwaro, 
\q2 riri pamusoro pomupata wakaorera, richafanana neonde raibva gohwo risati rasvika, 
\q2 munhu achingoriona, anoritanha noruoko rwake, 
\q2 obva aridya pakarepo. 
\q1  
\v 5 Pazuva iro Jehovha Wamasimba Ose achava korona inobwinya, 
\q2 chishongo chakanaka chavanhu vake vakasara. 
\q1  
\v 6 Achava mweya wokururamisira 
\q2 kuna iye anogara pakutonga, 
\q1 chitubu chesimba kuna avo 
\q2 vanodzosera shure vanorwa pasuo. 
\b  
\q1  
\v 7 Ivavawo vanodzedzereka newaini 
\q2 uye vanozengaira nedoro: 
\q1 Vaprista navaprofita vanodzedzereka nedoro, 
\q2 uye vanonyonganiswa newaini; 
\q1 vanozengaira nedoro, 
\q2 vanodzedzereka pavanoona zviratidzo, 
\q2 vanogumburwa pakutonga. 
\q1  
\v 8 Tafura dzose dzazara marutsi 
\q2 uye hapachina nzvimbo isina tsvina. 
\b  
\q1  
\v 9 “Ndianiko waachadzidzisa ruzivo? 
\q2 Ndianiko waanotsanangurira shoko? 
\q1 Kuvana vakarumurwa pamukaka, 
\q2 kuna avo vachangobva pazamu here? 
\q1  
\v 10 Nokuti zvinoti: 
\q2 Chirevo pamusoro pechirevo, chirevo pamusoro pechirevo, 
\q2 mutsara pamusoro pomutsara, mutsara pamusoro pomutsara, 
\q2 apa zvishoma, apo zvishoma.” 
\b  
\q1  
\v 11 Zvirokwazvo, Mwari achataura kurudzi urwu nemitauro yavatorwa, 
\q2 nendimi dzokumwe, 
\q1  
\v 12 kwavari akati, “Iyi ndiyo nzvimbo yokuzorora, 
\q2 vakaneta ngavazorore,” 
\q1 uye, “Iyi ndiyo nzvimbo yorunyararo,” 
\q2 asi havana kumboteerera. 
\q1  
\v 13 Saka zvino, shoko raJehovha kwavari richava: 
\q2 Chirevo pamusoro pechirevo, chirevo pamusoro pechirevo, 
\q2 mutsara pamusoro pomutsara, mutsara pamusoro pomutsara, 
\q2 apa zvishoma, apo zvishoma, 
\q1 kuitira kuti vaende vagondowa, vavhunike, 
\q2 vabatwe nomusungo vagotapwa. 
\b  
\q1  
\v 14 Naizvozvo inzwai shoko raJehovha, imi vaseki, 
\q2 imi vanotonga rudzi urwu muJerusarema. 
\q1  
\v 15 Munozvirumbidza muchiti, “Takaita sungano norufu, 
\q2 takatenderana neguva. 
\q1 Shamhu inokukura painouya, 
\q2 haizotibati, 
\q1 nokuti nhema takadziita utiziro hwedu, 
\q2 uye kunyengera takakuita nzvimbo yedu yokuvanda.” 
\p  
\v 16 Saka zvanzi naJehovha Wamasimba Ose: 
\q1 “Tarirai ndinoisa ibwe muZioni, 
\q2 ibwe rakaedzwa, 
\q1 ibwe rinokosha rapakona kuti rive nheyo yakasimba; 
\q2 anovimba naro haangavhunduki. 
\q1  
\v 17 Ndichaita kuti kururamisira kuve rwodzi rwokururamisira, 
\q2 uye kururama ndichakuita chokururamisa nacho; 
\q1 chimvuramabwe chichakukura utiziro hwenyu, idzo nhema, 
\q2 uye mvura ichafukidza nzvimbo yenyu yokuvanda. 
\q1  
\v 18 Sungano yenyu norufu ichadzimwa; 
\q2 chitenderano chenyu neguva hachingamiri. 
\q1 Shamhu inokukura painouya, 
\q2 muchakundwa nayo. 
\q1  
\v 19 Nguva nenguva painouya ichakutakurai ichikuendesai kure; 
\q2 mangwanani achitevera mamwe mangwanani, panguva dzamasikati nenguva dzousiku, 
\q2 ichakukura.” 
\b  
\q1 Kunzwisisa shoko iri 
\q2 kuchauyisa kutya. 
\q1  
\v 20 Nokuti mubhedha uchava mupfupi pakutandavara, 
\q2 uye jira richava diki zvokuti munhu haangagoni kufukidzwa naro. 
\q1  
\v 21 Nokuti Jehovha achasimuka sezvaakaita paGomo rePerazimi, 
\q2 achatsamwa sezvaakaita muMupata weGibheoni, 
\q1 kuti aite basa rake, iro basa risinganzwisisiki, 
\q2 uye azadzise basa rake, basa risinganzwisisiki. 
\q1  
\v 22 Zvino chiregai kudada kwenyu, 
\q2 nokuti ngetani dzenyu dzichanyanya kukuremerai; 
\q1 Ishe, iye Jehovha Wamasimba Ose, 
\q2 andiudza pamusoro pokuparadzwa kwakatemwa pamusoro penyika yose. 
\b  
\q1  
\v 23 Teererai uye munzwe inzwi rangu; 
\q2 rerekai nzeve dzenyu munzwe zvandinoreva. 
\q1  
\v 24 Murimi paanorimira kuti agodyara, anoramba achingorima here? 
\q2 Ko, anoramba achingorima kana kuhara here? 
\q1  
\v 25 Paanoenzanisa munda wake kuti uti chechetere, 
\q2 haangadyari karawe uye agokusha kumini here? 
\q1 Haangadyari gorosi munzvimbo yaro, 
\q2 nebhari mumunda wayo, 
\q2 nesipereti mumunda wayo here? 
\q1  
\v 26 Nokuti Mwari wake anomurayiridza 
\q2 uye achamudzidzisa nzira yakanaka. 
\b  
\q1  
\v 27 Karawe haipurwi nechireyi, 
\q2 uye vhiri rengoro harikunguruswi pamusoro pekumini; 
\q1 karawe inopurwa nemhuro 
\q2 uye kumini inopurwa norumuti. 
\q1  
\v 28 Zviyo zvinofanira kukuyiwa kuti zviitiswe chingwa; 
\q2 saka munhu haafaniri kuramba achingopura nokusingaperi. 
\q1 Kunyange achifambisa mavhiri engoro yake 
\q2 yokupura pamusoro pazvo, mabhiza ake haazvikuyi. 
\q1  
\v 29 Izvi zvose zvinobvawo kuna Jehovha Wamasimba Ose, 
\q2 anoshamisa mukurayira uye mukuru kwazvo muuchenjeri. 
\c 29  
\s1 Nhamo kuGuta raDhavhidhi 
\q1  
\v 1 Une nhamo iwe Arieri, Arieri, 
\q2 guta raigara Dhavhidhi! 
\q1 Wedzera gore pagore; 
\q2 uye regai nguva dzemitambo yenyu dzirambe dziripo. 
\q1  
\v 2 Kunyange zvakadaro, ndichakomba Arieri; 
\q2 pachava nokuungudza uye nokuchema, 
\q2 richafanana nechoto chearitari kwandiri. 
\q1  
\v 3 Ndichakukomba kumativi ose; 
\q2 ndichakukomberedza neshongwe 
\q2 uye ndichavaka nhare dzokurwa newe. 
\q1  
\v 4 Uchadzikisirwa pasi, uchataura uri pasi; 
\q2 kutaura kwako kuchabva muguruva. 
\q1 Inzwi rako richava seresvikiro rinobva pasi muvhu; 
\q2 kutaura kwako kuchaita zevezeve kuchibva muguruva. 
\q1  
\v 5 Asi vavengi vako vazhinji vachava seguruva rakatsetseka, 
\q2 vane utsinye vachafanana nehundi inopepereswa. 
\q1 Pakarepo, nokukurumidza 
\q2  
\v 6 Jehovha Wamasimba Ose achauya 
\q1 nokutinhira nokudengenyeka kwenyika, uye nemheremhere huru, 
\q2 nechamupupuri, nedutu guru uye nomurazvo womoto unoparadza zvose. 
\q1  
\v 7 Ipapo mhomho dzendudzi dzose dzakawanda dzinorwa neArieri, 
\q2 dzinorirwisa iro nenhare dzaro uye dzinorikomba, 
\q1 zvichaita sokurota, 
\q2 nechiratidzo chinoonekwa usiku, 
\q1  
\v 8 sezvinoitwa nomunhu ane nzara anorota achidya, 
\q2 asi apepuka, anowana nzara yake ichiripo; 
\q1 sezvinoita munhu ane nyota anorota achinwa mvura, 
\q2 asi omuka achiziya, nyota yake isina kupera. 
\q1 Naizvozvo ndizvo zvichaitawo marudzi ose akawanda 
\q2 anorwa neGomo reZioni. 
\b  
\q1  
\v 9 Katyamarai uye mushamiswe, 
\q2 zvipofumadzei muve vasingaoni; 
\q1 dhakwai asi kwete newaini; 
\q2 dzedzerekai asi kwete nedoro. 
\q1  
\v 10 Jehovha akauyisa pamusoro penyu hope huru; 
\q2 Akafukidza meso enyu, vaprofita; 
\q2 akafukidza misoro yenyu, vaoni. 
\p  
\v 11 Nokuti kwamuri, chiratidzo ichi hachizi chinhu asi mashoko akanamirwa murugwaro. Uye kana mukapa rugwaro kuno mumwe munhu anogona kuverenga, mukati kwaari, “Ndapota, verenga izvi,” achapindura achiti, “Handikwanisi, nokuti rwakanamirwa.”  
\v 12 Kana kuti mukapa rugwaro kuno mumwe asingagoni kuverenga, mukati kwaari, “Ndapota, verenga izvi,” achapindura achiti, “Handigoni kuverenga.” 
\p  
\v 13 Ishe anoti: 
\q1 “Vanhu ava vanoswedera kwandiri nemiromo yavo, 
\q2 uye vanondikudza nemiromo yavo, 
\q2 asi mwoyo yavo iri kure neni. 
\q1 Kundinamata kwavo 
\q2 kwangova kwemitemo inodzidziswa navanhu chete. 
\q1  
\v 14 Naizvozvo ndichashamisa vanhu ava zvakare 
\q2 nechishamiso pamusoro pechishamiso; 
\q1 uchenjeri hwavakachenjera huchaparadzwa, 
\q2 zivo yavane zivo ichapera.” 
\q1  
\v 15 Vane nhamo avo vanosvika kwakadzika dzika 
\q2 kuti vavanzire Jehovha mano avo, 
\q1 vanoita mabasa avo murima vachifunga mumwoyo yavo kuti, 
\q2 “Ndiani anotiona? Ndiani achaziva?” 
\q1  
\v 16 Munoshandura mamiriro ezvinhu, 
\q2 sezvinonzi muumbi wehari anonzi ndiye ivhu! 
\q1 Ko, chakaumbwa chingati kuna iye akachiumba, 
\q2 “Iye haana kundiita?” 
\q1 Ko, hari ingati kumuumbi, 
\q2 “Iye haana chaanoziva?” 
\b  
\q1  
\v 17 Ko, Rebhanoni haingashandurwi ikava munda wakaorera muchinguva chidiki, 
\q2 uye munda wakaorera ugoita kunge dondo? 
\q1  
\v 18 Pazuva iro vanamati vachanzwa shoko rorugwaro, 
\q2 uye meso amapofu achaona 
\q2 ari pakasviba naparima. 
\q1  
\v 19 Zvakare vanozvininipisa vachafara muna Jehovha; 
\q2 vanoshayiwa vachafara muMutsvene waIsraeri. 
\q1  
\v 20 Vane utsinye vachaparadzwa, 
\q2 vaseki vachanyangarika, 
\q2 uye vose vane ziso rinofarira zvakaipa vachaurayiwa, 
\q1  
\v 21 avo vanopomera munhu mhosva neshoko chete, 
\q2 vanoisira musungo kuna anoruramisira mudare, 
\q2 uye nouchapupu hwenhema, vanokonesa kururamisirwa kwavasina mhosva. 
\p  
\v 22 Naizvozvo izvi ndizvo zvinotaura Jehovha, akadzikinura Abhurahama, achiti kuimba yaJakobho: 
\q1 “Jakobho haachazonyadziswizve; 
\q2 zviso zvavo hazvichazocheneruki. 
\q1  
\v 23 Pavachaona vana vavo pakati pavo, 
\q2 iro basa ramaoko angu, 
\q1 vachachengeta zita rangu muutsvene; 
\q2 vachaziva utsvene hwoMutsvene waJakobho, 
\q2 uye vachamira vachitya Mwari waIsraeri. 
\q1  
\v 24 Vakarasika pamweya vachawana njere; 
\q2 vanonyunyuta vachagamuchira kurayirwa.” 
\c 30  
\s1 Rune Nhamo Rudzi Rwakasindimara 
\q1  
\v 1 “Vane nhamo vana vakasindimara,” 
\q2 ndizvo zvinotaura Jehovha, 
\q1 “kuna avo vanoita urongwa husati huri hwangu, 
\q2 vanoita sungano, asi vasingaiti noMweya wangu, 
\q2 vachiunganidza chivi pamusoro pechivi; 
\q1  
\v 2 vanoenda kuIjipiti 
\q2 vasina kundibvunza; 
\q1 vanotsvaka rubatsiro rworudziviriro rwaFaro, 
\q2 vanotsvaka utiziro kumumvuri weIjipiti. 
\q1  
\v 3 Asi kudzivirira kwaFaro kuchava kunyadziswa kwenyu, 
\q2 mumvuri weIjipiti uchakuvigirai kunyadziswa, 
\q1  
\v 4 kunyange vaine machinda muZoani 
\q2 uye nhume dzavo dzasvika muHanesi, 
\q1  
\v 5 mumwe nomumwe wavo achanyadziswa 
\q2 nokuda kwavanhu vasina betsero kwavari, 
\q1 vasingavavigiri rubatsiro kana ruyamuro, 
\q2 asi kunyadziswa chete nokuzvidzwa.” 
\p  
\v 6 Chirevo pamusoro pemhuka dzeNegevhi: 
\q1 nomunyika yenhamo namatambudziko, 
\q2 yeshumba neshumbakadzi, 
\q2 yemvumbi nenyoka dzine hasha uye dzinobhururuka, 
\q1 nhume dzinotakura pfuma yadzo pamusoro pembongoro, 
\q2 noupfumi hwadzo pamusoro penyundwa dzengamera, 
\q1 dzichihuendesa kurudzi rusingabatsiri, 
\q2  
\v 7 kuIjipiti kuno rubatsiro rusina maturo chose. 
\q1 Naizvozvo ndinomutumidza zita rokuti 
\q2 Rahabhi Asina Chaanoita. 
\b  
\q1  
\v 8 Chienda iye zvino, unovanyorera pahwendefa izvozvo, 
\q2 uzvinyore murugwaro, 
\q1 kuti pamazuva anouya 
\q2 chigova chapupu nokusingaperi. 
\q1  
\v 9 Ava ndivo vanhu vakapanduka, vana vokunyengera, 
\q2 vana vasingadi kunzwa kurayira kwaJehovha. 
\q1  
\v 10 Vanoti kuvaoni, 
\q2 “Regai kuonazve zviratidzo!” 
\q1 nokuvaprofita, 
\q2 “Regai kutipazve zviratidzo zvezvakanaka! 
\q1 Tiudzei zvinhu zvinofadza, 
\q2 muprofite zvinonyengera. 
\q1  
\v 11 Siyai nzira iyi, 
\q2 ibvai mugwara iri, 
\q1 murege kuita kuti timisidzane 
\q2 noMutsvene waIsraeri!” 
\p  
\v 12 Naizvozvo zvanzi naMutsvene waIsraeri: 
\q1 “Nokuti makaramba shoko rangu iri, 
\q2 mukasendamira pakumanikidza 
\q2 uye mukavimba nokunyengera, 
\q1  
\v 13 chivi ichi chichava kwamuri 
\q2 sorusvingo, rwakatsemuka nokufutunuka, 
\q2 runoondomoka pakarepo uye nokukurumidza. 
\q1  
\v 14 Ruchaputsika kuita zvimedu zvimedu sehari, 
\q2 yakaputswa noutsinye 
\q2 zvokuti pakati pezvimedu zvayo hapana kuwanikwa chaenga chakasara, 
\q2 chokugoka mazimbe omoto pachoto 
\q2 kana chokuchera nacho mvura kubva muchitubu.” 
\p  
\v 15 Zvanzi naIshe Jehovha, Mutsvene waIsraeri: 
\q1 “Mukutendeuka nezororo ndimo mune ruponeso rwenyu, 
\q2 murunyararo nomukuvimba ndimo mune simba renyu, 
\q2 asi imi makaramba chimwe chazvo. 
\q1  
\v 16 Imi makati, ‘Kwete, tichatiza takatasva mabhiza.’ 
\q2 Naizvozvo muchatiza! 
\q1 Imi makati, ‘Tichatasva mabhiza anomhanya kwazvo.’ 
\q2 Naizvozvo vadzinganisi venyu vachamhanya kwazvo! 
\q1  
\v 17 Chiuru chimwe chete chichatiza 
\q2 nokuvhundutsa kwomumwe chete; 
\q1 imi mose muchatiza 
\q2 kuvhundutsa kwavashanu, 
\q1 kusvikira masara 
\q2 maita sedanda romureza riri pamusoro pegomo, 
\q2 kuita somureza pamusoro pechikomo.” 
\b  
\q1  
\v 18 Asi Jehovha anoshuva kukuitirai nyasha; 
\q2 anosimuka kuti akuratidzei tsitsi. 
\q1 Nokuti Jehovha ndiMwari wokururamisira. 
\q2 Vakaropafadzwa vose vanomurindira! 
\p  
\v 19 Haiwa imi vanhu veZioni, vanogara muJerusarema, hamuchazochemizve. Achava nenyasha sei pamunochemera rubatsiro! Achingozvinzwa, achakupindurai.  
\v 20 Kunyange Ishe achikupai chingwa chenhamo nemvura yokutambudzika, vadzidzi venyu havachazovanzwizve; muchavaona nameso enyu pachenyu.  
\v 21 Kunyange mukatendeukira kurudyi kana kuruboshwe, nzeve dzenyu dzichanzwa inzwi mumashure menyu, richiti, “Iyi ndiyo nzira, fambai mairi.”  
\v 22 Ipapo muchasvibisa zvifananidzo zvenyu zvakafukidzwa nesirivha nezviumbwa zvenyu zvakafukidzwa negoridhe; muchazvirasira kure somucheka wakasvibiswa neropa romukadzi ari kumwedzi kwake muchiti kwazviri, “Ibvai pano!” 
\p  
\v 23 Achakutumiraiwo mvura yokumeresa mbeu dzamunodyara muvhu, uye zvokudya zvichabva munyika zvichange zvakanyatsosvika uye zvakawanda kwazvo. Pazuva iro, nzombe dzenyu dzichafura mumafuro akafaranuka.  
\v 24 Nzombe nembongoro dzinorima munda zvichadya mashanga noupfu, zvakaparadzirwa neforogo nefoshoro.  
\v 25 Pazuva rokuuraya kukuru, panowira shongwe pasi, hova dzemvura dzichayerera pamusoro pamakomo ose akakwirira napamusoro pezvikomo zvakareba.  
\v 26 Mwedzi uchapenya sezuva, uye zuva richapenya kakapetwa kanomwe, kufanana nechiedza chamazuva manomwe azere, Jehovha paanosunga mavanga avanhu vake agorapa maronda aakavakuvadza nawo. 
\q1  
\v 27 Tarirai, Zita raJehovha rasvika richibva kure, 
\q2 rine hasha dzinopfuta moto namakore outsi hwakasviba kuti ndo-o; 
\q1 miromo yake yakazara nokutsamwa, 
\q2 uye rurimi rwake moto unoparadza. 
\q1  
\v 28 Kufema kwake kunofanana nokuyerera kwemvura ine simba zhinji, 
\q2 inokwira ichisvika mumutsipa. 
\q1 Anozungura ndudzi murusero rwokuparadza; 
\q2 anoisa mushaya dzavanhu 
\q2 matomu anovatsausa. 
\q1  
\v 29 Uye muchaimba 
\q2 sapausiku hwamunopemberera mutambo mutsvene; 
\q1 mwoyo yenyu ichafara 
\q2 sezvinoita vanhu vanokwira kugomo raJehovha, 
\q2 nokuDombo raIsraeri, vachiridza nyere. 
\q1  
\v 30 Jehovha achaita kuti vanhu vanzwe inzwi rake roumambo, 
\q2 uye achaita kuti vaone ruoko rwake ruchiburuka pasi, 
\q1 nehasha zhinji nomoto wokuparadza, 
\q2 nokuputika kwamakore, kunaya kwemvura zhinji nechimvuramabwe. 
\q1  
\v 31 Inzwi raJehovha richaparadza vaAsiria; 
\q2 achavarova netsvimbo yake. 
\q1  
\v 32 Shamhu yoga yoga yavacharohwa nayo naJehovha 
\q2 netsvimbo yake yokuranga, 
\q1 ichaenderana nerwiyo rwamakandira norudimbwa, 
\q2 paacharwa navo muhondo noruoko rwake. 
\q1  
\v 33 Tofeti yakanguri yagadzirira; 
\q2 yakagadzirirwa kare kugamuchira mambo. 
\q1 Gomba rayo romoto rakadzikiswa rikapamhamiswa, 
\q2 uye pane moto wakawanda nehuni zhinji; 
\q1 kufema kwaJehovha, 
\q2 sorukova runopfuta nesafuri, 
\q2 kuchazvitungidza. 
\c 31  
\s1 Vane Nhamo Vanovimba neIjipiti 
\q1  
\v 1 Vane nhamo avo vanoburukira kuIjipiti kundotsvaka rubatsiro, 
\q2 vanovimba namabhiza, 
\q1 vanovimba nokuwanda kwengoro dzavo 
\q2 uye nesimba guru ravatasvi vavo vamabhiza, 
\q1 asi vasingatariri kuMutsvene waIsraeri, 
\q2 kana kutsvaka rubatsiro runobva kuna Jehovha. 
\q1  
\v 2 Kunyange zvakadaro naiyewo akachenjera uye anogona kuuyisa njodzi; 
\q1 haangadzosi mashoko ake. 
\q1 Iye achamukira imba yavakaipa, 
\q2 naavo vanobatsira vanoita zvakaipa. 
\q1  
\v 3 Asi vaIjipita vanhu uye havasi Mwari, 
\q2 mabhiza avo inyama uye haasi mweya. 
\q1 Zvino panotambanudza Jehovha ruoko rwake, 
\q2 uyo anobatsira achagumburwa, 
\q2 uyo achabatsirwa achawa; 
\q2 vose vachaparara pamwe chete. 
\p  
\v 4 Zvanzi naJehovha kwandiri: 
\q1 “Sezvinoita shumba inoomba, 
\q2 seshumba huru pamusoro pechayabata, 
\q1 kunyange mhomho yose yavafudzi 
\q2 ikakokerwa pamwe chete kuzorwa neshumba iyi, 
\q1 iyo haingavhundutswi noruzha rwavo, 
\q2 kana kukanganiswa nemhere yavo, 
\q1 saizvozvo Jehovha Wamasimba Ose achaburukira pamusoro peGomo reZioni 
\q2 napazvikomo zvaro kuzorwa hondo. 
\q1  
\v 5 Seshiri dzinobhururuka napamusoro, 
\q2 Jehovha Wamasimba Ose achadzivirira Jerusarema; 
\q1 acharidzivirira, acharirwira, 
\q2 achadarika pamusoro paro uye acharisunungura.” 
\p  
\v 6 Dzokerai kuna iye wamakamukira zvikuru, imi vaIsraeri.  
\v 7 Nokuti pazuva iro mumwe nomumwe wenyu acharamba zvifananidzo zvesirivha negoridhe zvakaitwa namaoko enyu akaipa. 
\q1  
\v 8 “Asiria ichawisirwa pasi nomunondo usati uri womunhu; 
\q2 munondo, kwete wavanhu, uchavapedza. 
\q1 Vachatiza pamberi pomunondo 
\q2 uye majaya avo achaiswa kuchibharo. 
\q1  
\v 9 Nhare dzavo dzakasimba dzichawa nokuda kwokutya; 
\q2 vatungamiri vavo vachavhundutswa pavachaona mureza wehondo,” 
\q1 ndizvo zvinotaura Jehovha, 
\q2 ane moto wake paZioni 
\q2 choto chake chiri muJerusarema. 
\c 32  
\s1 Umambo hwoKururama 
\q1  
\v 1 Tarirai mambo achatonga nokururama, 
\q2 uye vatongi vachatonga nokururamisira. 
\q1  
\v 2 Munhu mumwe nomumwe achafanana nenzvimbo yokuvanda kubva kumhepo, 
\q2 noutiziro kubva pakunaya kwemvura zhinji, 
\q1 sehova dzemvura mugwenga nomumvuri 
\q2 webwe guru munyika yafa nenyota. 
\q1  
\v 3 Ipapo meso avose vanoona haachazotsinzini, 
\q2 uye nzeve dzavanonzwa dzichateerera. 
\q1  
\v 4 Ndangariro dzavanokurumidzira zvinhu dzichaziva uye dzichanzwisisa, 
\q2 uye vanokakama vachataura zvakanaka uye zvinonzwika. 
\q1  
\v 5 Benzi harichazonzi munhu anokudzwa, 
\q2 munhu asina maturo haazoremekedzwi. 
\q1  
\v 6 Nokuti benzi rinotaura zvoupenzi, 
\q2 ndangariro dzaro dzinofunga zvakaipa: 
\q1 Zvaanoita hazvina umwari 
\q2 uye anoparadzira zvinhu zvakarasika zvisiri zvaJehovha; 
\q1 anosiya vane nzara vasina chinhu 
\q2 uye anonyima mvura vane nyota. 
\q1  
\v 7 Nzira dzousina maturo dzakaipa, 
\q2 anoita rangano dzakaipa 
\q1 kuti aparadze varombo nenhema, 
\q2 kunyange chichemo chaanoshayiwa chakanaka hacho. 
\q1  
\v 8 Asi munhu anokudzwa anoita urongwa hwakanaka, 
\q2 uye namabasa anokudzwa. 
\s1 Vakadzi veJerusarema 
\q1  
\v 9 Imi vakadzi musina hanya, 
\q2 simukai muteerere kwandiri; 
\q1 imi vanasikana munoti makachengetedzeka, 
\q2 inzwai zvandinoreva! 
\q1  
\v 10 Gore risati rapera 
\q2 muchabvunda iyemi munoti makachengetedzeka; 
\q1 nokuti kuchekwa kwamazambiringa kuchakundikana, 
\q2 uye kutanhwa kwemichero hakuchasviki. 
\q1  
\v 11 Dederai, imi vakadzi musina hanya; 
\q2 dederai imi vanasikana munoti makachengetedzeka! 
\q1 Bvisai nguo dzenyu, 
\q2 monerai masaga muzviuno zvenyu. 
\q1  
\v 12 Muzvirove zvipfuva nokuda kweminda yakanaka, 
\q2 nokuda kwezvibereko zvemizambiringa, 
\q1  
\v 13 uye nokuda kwenyika yavanhu vangu, 
\q2 nyika yamera minzwa norukato, 
\q1 hongu, mucheme nokuda kwedzimba dzose dzamafaro, 
\q2 uye nokuda kweguta rinopururudza iri. 
\q1  
\v 14 Nhare dzichasiyiwa, 
\q2 guta roruzha richasara risina munhu; 
\q1 nhare neshongwe zvichava dongo nokusingaperi, 
\q2 mufaro wembongoro, namafuro ezvipfuwo, 
\q1  
\v 15 kusvikira Mweya wadururirwa pamusoro pedu uchibva kumusoro, 
\q2 uye gwenga rava nyika yakaorera, 
\q2 nemunda wakaorera wava sesango. 
\q1  
\v 16 Kururamisira kuchagara kugwenga 
\q2 uye kururama kuchagara kumunda wakaorera. 
\q1  
\v 17 Chibereko chokururama chichava rugare; 
\q2 uye chibereko chokururama chichava runyararo nokuvimba nokusingaperi. 
\q1  
\v 18 Vanhu vangu vachagara munzvimbo dzorugare, 
\q2 mumisha yakachengetedzeka, 
\q2 munzvimbo dzokuzorora dzakadzikama. 
\q1  
\v 19 Kunyange chimvuramabwe chikafukidza sango, 
\q2 neguta rikaparadzwa zvachose, 
\q1  
\v 20 ucharopafadzwa zvakadiniko, 
\q2 uchidyara mbeu dzako pedyo nehova dzose, 
\q2 uye uchirega mombe nembongoro dzako zvichifura zvakasununguka! 
\c 33  
\s1 Kutambudzika noKubatsirwa 
\q1  
\v 1 Une nhamo iwe, muparadzi, 
\q2 iyewe usati wamboparadzwa! 
\q1 Une nhamo iwe, mupanduki, 
\q2 iyewe usati wambopandukirwa! 
\q1 Paunorega kuparadza, 
\q2 iwe uchaparadzwa; 
\q1 paunorega kupandukira, 
\q2 iwe uchapandukirwa. 
\q1  
\v 2 Haiwa Jehovha, tinzwirei tsitsi; 
\q2 tinokupangai imi. 
\q1 Ivai simba redu mangwanani oga oga, 
\q2 noruponeso rwedu panguva yokutambudzika. 
\q1  
\v 3 Pakutinhira kwenzwi renyu, ndudzi dzinotiza; 
\q2 pamunosimuka, marudzi anopararira. 
\q1  
\v 4 Haiwa imi ndudzi, zvakapambwa zvenyu zvachekwa kunge zvachekwa nemhashu diki; 
\q2 vanhu vanomhanyira kwazviri segwatakwata remhashu. 
\b  
\q1  
\v 5 Jehovha asimudzirwa, iye anogara kumusoro; 
\q2 achazadza Zioni nokururamisira nokururama. 
\q1  
\v 6 Achava nheyo yechokwadi yenguva yenyu, 
\q2 nedura repfuma yoruponeso, uchenjeri nezivo; 
\q2 kiyi yepfuma iyi ndiko kutya Jehovha. 
\b  
\q1  
\v 7 Tarirai, mhare dzavo dzinodanidzira munzira dzomumisha; 
\q2 nhume dzorugare dzinochema zvikuru. 
\q1  
\v 8 Migwagwa mikuru yasiyiwa, 
\q2 vafambi havachisimo mumigwagwa. 
\q1 Sungano yaputswa, 
\q2 zvapupu zvayo zvazvidzwa, 
\q2 hapachina anoremekedzwa. 
\q1  
\v 9 Nyika inochema uye yoparara, 
\q2 Rebhanoni yanyadziswa uye yasvava; 
\q1 Sharoni yafanana neArabha, 
\q2 uye Bhashani neKarimeri dzakurumuka mashizha adzo. 
\b  
\q1  
\v 10 “Zvino ini ndichasimuka,” ndizvo zvinotaura Jehovha. 
\q2 “Zvino ini ndichakudzwa; 
\q2 zvino ini ndichasimudzirwa pamusoro. 
\q1  
\v 11 Munoita mimba yehundi, 
\q2 munobereka mashanga; 
\q2 kufema kwenyu ndiwo moto unokuparadzai. 
\q1  
\v 12 Marudzi achapiswa kunge suko; 
\q2 vacharirima kunge huni dzeminzwa dzakatemwa.” 
\b  
\q1  
\v 13 Imi vari kure, inzwai zvandakaita; 
\q2 imi vari pedyo, bvumai kuti ndine simba! 
\q1  
\v 14 Vatadzi vari muZioni vavhundutswa; 
\q2 vasina Mwari vodedera: 
\q1 “Ndianiko pakati pedu 
\q2 angagare nomoto unopisa nokusingaperi?” 
\q1  
\v 15 Iye anofamba nokururama 
\q2 uye anotaura zvakanaka, 
\q1 anoramba pfuma inobva pakumanikidza 
\q2 uye anodzivisa ruoko rwake kugamuchira fufuro, 
\q1 anodzivisa nzeve dzake kunzwa rangano dzokuuraya, 
\q2 uye anotsinzina meso ake kuti arege kuona zvakaipa, 
\q1  
\v 16 uyu ndiye munhu achagara pakakwirira, 
\q2 nhare dzegomo dzichava utiziro hwake. 
\q1 Zvokudya zvake achazvipiwa, 
\q2 uye haangashayiwi mvura. 
\b  
\q1  
\v 17 Meso ako achaona mambo pakunaka kwake; 
\q2 uye achatarira nyika yakakura kwazvo. 
\q1  
\v 18 Mundangariro dzako ucharangarira zvaimbokutyisa ugoti: 
\q2 “Aripiko muchinda mukuru uya? 
\q2 Aripiko uya aimbotora mutero? 
\q2 Aripiko muchinda aiva mutariri weshongwe?” 
\q1  
\v 19 Vanhu vaya vokuzvikudza hauchazovaonazve, 
\q2 ivo vanhu vomutauro wakavanzika, 
\q2 vorurimi rwavo, rusinganzwiki. 
\b  
\q1  
\v 20 Tarirai Zioni, iro guta remitambo yedu; 
\q2 meso enyu achaona Jerusarema, 
\q2 ugaro hworunyararo, tende risingazozungunuswi; 
\q1 mbambo dzaro hadzingadzurwi, 
\q2 kana mabote aro kudamburwa. 
\q1  
\v 21 Asi Jehovha achava Wamasimba Ose kwatiri. 
\q2 Richafanana nenzvimbo yenzizi dzakapamhamha uye nehova. 
\q1 Magwa anokwasviwa haangasvikiko, 
\q2 uye zvikepe zvikuru hazvingapfuuri. 
\q1  
\v 22 Nokuti Jehovha ndiye mutongi wedu, 
\q2 Jehovha ndiye anotipa murayiro, 
\q1 Jehovha ndiye mambo wedu; 
\q2 ndiye achatiponesa. 
\b  
\q1  
\v 23 Mabote ako ava dembutembu: 
\q2 Haagoni kusimbisa mbambo yechikepe, 
\q2 sairi harina kutambanudzwa. 
\q1 Ipapo zvakapambwa zvakawanda zvichagoverwa, 
\q2 uye kunyange chirema chichawanawo zvakapambwa. 
\q1  
\v 24 Hapana agere muZioni achati, “Ndinorwara,” 
\q2 uye zvivi zvavanogaramo zvicharegererwa. 
\c 34  
\s1 Kutongwa kweNdudzi 
\q1  
\v 1 Swederai pedyo, imi ndudzi dzavanhu, munzwe. 
\q2 Teererai, imi vanhu! 
\q1 Nyika ngainzwe, nezvose zviri mairi, 
\q2 pasi pose, nezvose zvinobudamo! 
\q1  
\v 2 Jehovha akatsamwira ndudzi dzose; 
\q2 hasha dzake dziri pamusoro pehondo dzavo dzose. 
\q1 Achavaparadza chose, 
\q2 achaita kuti vaurayiwe. 
\q1  
\v 3 Vakaurayiwa vavo vacharasirwa kunze, 
\q2 mitumbi yavo ichanhuhwa; 
\q2 makomo achanyorova neropa ravo. 
\q1  
\v 4 Nyeredzi dzokudenga dzose dzichanyungudika, 
\q2 uye denga richapetwa sorugwaro; 
\q1 marudzi ose enyeredzi achawa 
\q2 samashizha akaoma abva pamuzambiringa, 
\q2 samaonde akasvava abva pamuonde. 
\q1  
\v 5 Munondo wangu wakanwa ukaguta kumatenga; 
\q2 tarirai, unoburukira kuzotonga Edhomu, 
\q2 vanhu vandakaparadza chose. 
\q1  
\v 6 Munondo waJehovha wakanyura muropa, 
\q2 wakafukidzwa namafuta, 
\q1 iro ropa ramakwayana nerembudzi, 
\q2 namafuta anobva paitsvo dzamakondobwe. 
\q1 Nokuti Jehovha ane chibayiro muBozira 
\q2 uye nokuuraya kukuru muEdhomu. 
\q1  
\v 7 Nyati dzichawa pamwe navo 
\q2 nehono dzemhuru nehando huru. 
\q1 Nyika yavo ichanyorova neropa, 
\q2 uye guruva richazara mafuta. 
\b  
\q1  
\v 8 Nokuti Jehovha ane zuva rokutsiva 
\q2 negore rokuripira kuti atsigire zvinodiwa neZioni. 
\q1  
\v 9 Hova dzeEdhomu dzichashanduka kuva namo, 
\q2 guruva rayo richapisa sesafuri; 
\q2 nyika yayo ichava namo inopfuta! 
\q1  
\v 10 Haingadzimwi usiku namasikati; 
\q2 utsi hwayo huchakwira nokusingaperi. 
\q1 Richava dongo kubva kune chimwe chizvarwa kusvikira kune chimwe chizvarwa; 
\q2 hapana munhu achazopfuura napozve. 
\q1  
\v 11 Asi zvichava zvezizi romugwenga nehukurwizi; 
\q2 zizi guru negunguo zvichaita matenderemo. 
\q1 Mwari achatambanudzira Edhomu 
\q2 rwodzi rwokuyera, 
\q2 rwenyonganiso nerwokuparadza. 
\q1  
\v 12 Makurukota ake haazovi nechinhu ikoko chingazonzi umambo, 
\q2 machinda ake ose achapera. 
\q1  
\v 13 Minzwa ichatandira nhare dzayo, 
\q2 utumbambeva norukato munzvimbo dzayo dzakakomberedzwa. 
\q1 Ichava ugaro hwamakava, 
\q2 nomusha wamazizi. 
\q1  
\v 14 Zvikara zvomugwenga zvichasangana namapere, 
\q2 uye ngururu dzichadaidzirana; 
\q1 zvikara zvousiku zvichazororapo, 
\q2 uye zvichazviwanira nzvimbo yokuzorora. 
\q1  
\v 15 Zizi richaita dendere rigokandira mazaipo, 
\q2 richaachochonyerapo, rigochengeta mazana aro pasi pomumvuri wamapapiro aro; 
\q1 makondo achaunganapo, 
\q2 rimwe nerimwe neshamwari yaro. 
\p  
\v 16 Tarirai murugwaro rwaJehovha mugorava: 
\q1 Hapana chimwe chezvinhu izvi chichashayikwa, 
\q2 kana chichashaya shamwari. 
\q1 Nokuti muromo wake ndiwo warayira izvozvo, 
\q2 uye Mweya wake uchavaunganidza pamwe chete. 
\q1  
\v 17 Anozvigovera migove yazvo; 
\q2 ruoko rwake runozvigovera nechiyero. 
\q1 Zvichava zvazvo nokusingaperi 
\q2 uye zvichagaramo kubva kune chimwe chizvarwa kusvikira kune chimwe chizvarwa. 
\c 35  
\s1 Mufaro waVakadzikinurwa 
\q1  
\v 1 Gwenga nenyika yakaoma zvichafara; 
\q2 sango richafara kwazvo uye richatumbuka; 
\q1 seruva,  
\v 2 richatumbuka; 
\q2 richafara zvikuru uye richapembera nomufaro. 
\q1 Mbiri yeRebhanoni ichapiwa kwariri, 
\q2 kunaka kweKarimeri neSharoni; 
\q1 vachaona kubwinya kwaJehovha, 
\q2 nokunaka kwaMwari wedu. 
\q1  
\v 3 Simbisai maoko asina simba, 
\q2 tsigirai mabvi anodedera; 
\q1  
\v 4 muti kuna avo vane mwoyo inotya, 
\q2 “Simbai, musatya; 
\q1 Mwari wenyu achauya, 
\q2 achauya nokutsiva, 
\q1 nokuripira kutsvene 
\q2 achauya kuzokuponesai.” 
\b  
\q1  
\v 5 Ipapo meso amapofu achasvinudzwa 
\q2 uye nzeve dzematsi dzichazarurwa. 
\q1  
\v 6 Ipapo akaremara achakwakuka senondo, 
\q2 uye rurimi rwechimumu ruchaimba nomufaro. 
\q1 Mvura ichatubuka murenje, 
\q2 uye nehova dzemvura mugwenga. 
\q1  
\v 7 Jecha rinopisa richashanduka rikava dziva, 
\q2 ivhu rine nyota richava zvitubu zvemvura. 
\q1 Maigara makava noumo maaimbovata, 
\q2 muchamera uswa, netsanga nenhokwe. 
\b  
\q1  
\v 8 Ipapo pachava nomugwagwa; 
\q2 uchanzi Nzira yoUtsvene. 
\q1 Vane tsvina havangazofambi mairi; 
\q2 ichava yaivavo vanofamba muNzira iyoyo; 
\q2 vakaipa namapenzi havangazofambi mairi. 
\q1  
\v 9 Hapangavi neshumba ipapo, 
\q2 kana chikara chipi zvacho chichawanikwapo. 
\q1 Asi vakadzikinurwa voga ndivo vachafambamo, 
\q2  
\v 10 uye vakasunungurwa vaJehovha vachadzoka. 
\q1 Vachapinda muZioni vachiimba; 
\q2 mufaro usingaperi uchava pamusoro pavo. 
\q1 Vachawana mufaro nokufarisisa, 
\q2 kusuwa nokuneta zvichatiza. 
\c 36  
\s1 Senakeribhi anovhundutsira Jerusarema 
\p  
\v 1 Mugore regumi namana rokutonga kwaMambo Hezekia, Senakeribhi mambo weAsiria akarwisa maguta ose akakomberedzwa aJudha akaapamba.  
\v 2 Ipapo mambo weAsiria akatuma mukuru wehondo yake nehondo huru achibva kuRakishi kuna Mambo Hezekia muJerusarema. Mukuru wehondo akati amira pamugero weDziva roKumusoro, pamugwagwa unoenda kuMunda woMusuki,  
\v 3 ipapo Eriakimu mwanakomana waHirikia, mufambisi webasa mumuzinda wamambo, naShebhina munyori, naJoa mwanakomana waAsafi munyori wenhoroondo, akabuda kundosangana naye. 
\p  
\v 4 Mukuru wehondo akati kwavari, “Udzai Hezekia kuti: 
\pm “ ‘Zvanzi namambo mukuru, iye mambo weAsiria: Uri kuvimba nei chaizvo?  
\v 5 Iwe unoti une urongwa nesimba rokurwa, asi uri kutaura mashoko asina maturo. Ko, unovimba naaniko, zvawandimukira?  
\v 6 Tarira zvino, unovimba neIjipiti, ruya rushanga rwomudonzvo rwakavhunika, runobaya ruoko rwomunhu nokumupa vanga kana azendamira parwuri! Ndizvo zvakaita Faro mambo weIjipiti kuna vose vanovimba naye.  
\v 7 Asi kana ukati kwandiri, “Isu tinovimba naJehovha Mwari wedu,” haasi iye here ane nzvimbo dzakakwirira nearitari dzakabviswa naHezekia, iye akati kuJudha neJerusarema, “Munofanira kunamata pamberi pearitari iyi”? 
\pm  
\v 8 “ ‘Zvino chiuya, ita sungano natenzi wangu, mambo weAsiria: Ndichakupa mabhiza anokwana zviuru zviviri, kana ukagona kuisa vatasvi pamusoro pawo!  
\v 9 Ungagona seiko kukunda mubati mumwe wavabati vadiki vatenzi vangu, kunyange uchivimba nengoro dzeIjipiti navatasvi vadzo vamabhiza?  
\v 10 Pamusoro pezvo, ndauya kuzorwa nenyika ino nokuiparadza ndisina Jehovha here? Jehovha pachake andiudza kuti ndiuye munyika ino ndizoiparadza.’ ” 
\p  
\v 11 Ipapo Eriakimu, naShebhina, naJoa vakati kumukuru wehondo, “Tapota hedu, taurai kuvaranda venyu norurimi rwechiAramu, sezvo tichirunzwa. Musataura nesu nechiHebheru vanhu vari parusvingo vachinzwa.” 
\p  
\v 12 Asi mukuru wehondo akapindura akati, “Ko, ndakatumwa natenzi wangu kuna tenzi wenyu nemi chete ndisingatauriwo kuvarume vagere parusvingo, ivo vanofanira kudya tsvina yavo nokunwa mvura yavo kufanana nemi here?” 
\p  
\v 13 Ipapo mukuru wehondo akasimuka akadanidzira nechiHebheru achiti, “Inzwai mashoko amambo mukuru, mambo weAsiria!  
\v 14 Zvanzi namambo: Musarega Hezekia achikunyengerai. Iye haangagoni kukurwirai!  
\v 15 Musarega Hezekia achikunyengetedzai kuti muvimbe naJehovha achiti, ‘Jehovha achakurwirai zvirokwazvo; guta rino harizoiswa muruoko rwamambo weAsiria.’ 
\p  
\v 16 “Musateerera Hezekia. Zvanzi namambo weAsiria: Itai rugare neni mugouya kwandiri. Ipapo mumwe nomumwe wenyu achadya zvinobva pamuzambiringa wake napamuonde wake uye achanwa mvura inobva muchitubu chake,  
\v 17 kusvikira ndauya ndizokutorai, ndigokuendesai kunyika yakaita seyenyu, nyika ine zviyo newaini itsva, nyika ine chingwa neminda yemizambiringa. 
\p  
\v 18 “Musarega Hezekia achikutsausai achiti, ‘Jehovha achatirwira.’ Ndimwari weipi nyika zvayo akamborwira nyika yake muruoko rwamambo weAsiria?  
\v 19 Vamwari veHamati neAripadhi varipi? Vamwari veSefarivhaimi varipi? Vakarwira Samaria muruoko rwangu here?  
\v 20 Ndavapi pakati pavamwari vendudzi dzose vakambogona kuponesa nyika dzavo kubva kwandiri? Ko, Jehovha achagona seiko kurwira Jerusarema muruoko rwangu?” 
\p  
\v 21 Asi vanhu vakaramba vanyerere, vakasapindura chinhu, nokuti mambo akanga arayira achiti, “Musamupindura.” 
\p  
\v 22 Ipapo Eriakimu mwanakomana waHirikia mutariri womuzinda wamambo, naShebhina munyori, naJoa mwanakomana waAsafi munyori wenhoroondo vakaenda kuna Hezekia, nenguo dzavo dzakabvaruka, vakamuudza zvakanga zvataurwa nomukuru wehondo. 
\c 37  
\s1 Kusunungurwa kweJerusarema kunoprofitwa 
\p  
\v 1 Mambo Hezekia akati anzwa izvi, akabvarura nguo dzake akafuka masaga akapinda mutemberi yaJehovha.  
\v 2 Akatuma Eriakimu mutariri womuzinda wamambo, naShebhina munyori, navakuru vavaprista, vose vakapfeka masaga, kumuprofita Isaya mwanakomana waAmozi.  
\v 3 Vakati kwaari, “Zvanzi naHezekia: Nhasi izuva renhamo nokutukwa uye kunyadziswa, sezvinoitika kana vana vakasvika pakuzvarwa asi simba rokusununguka pasina.  
\v 4 Zvimwe Jehovha Mwari wenyu achanzwa mashoko omukuru wehondo, akatumwa naishe wake, mambo weAsiria, kuzomhura Mwari mupenyu, uye kuti azomutuka pamusoro pamashoko aakanzwa iye Jehovha Mwari wenyu. Naizvozvo nyengetererai vakasara vari vapenyu.” 
\p  
\v 5 Vabati vaHezekia vakati vasvika kuna Isaya,  
\v 6 Isaya akati kwavari, “Udzai ishe wenyu kuti, ‘Zvanzi naJehovha: Usatya hako zvawakanzwa, mashoko andakamhurwa nawo navaranda vamambo weAsiria.  
\v 7 Teererai! Ndichaisa mweya maari wokuti akangonzwa rimwe guhu, achadzokera kunyika yake, uye ikoko, ndichaita kuti aurayiwe nomunondo.’ ” 
\p  
\v 8 Mukuru wehondo akati anzwa kuti mambo weAsiria akanga abva kuBhakishi, akadzoka akawana mambo achirwa neRibhina. 
\p  
\v 9 Zvino Senakeribhi akagamuchira mashoko okuti Tirihaka, muEtiopia mambo weIjipiti, akanga achiuya kuzorwa naye. Akati anzwa izvozvo, akatuma nhume kuna mambo Hezekia neshoko iri rokuti:  
\v 10 “Udzai Hezekia mambo weJudha muti: Mwari waunovimba naye ngaarege kukunyengera achiti, ‘Jerusarema harizoiswa muruoko rwamambo weAsiria.’  
\v 11 Zvirokwazvo wakanzwa zvakaitwa namadzimambo eAsiria kunyika dzose vachidziparadza chose. Zvino iwe ucharwirwa here?  
\v 12 Ko, vamwari vamamwe marudzi akaparadzwa namadzibaba angu vakavarwira here, vamwari veGezani, neHarani neRezefi navanhu vokuEdheni vakanga vari kuTeri Asari?  
\v 13 Mambo weHamati aripiko, namambo weArifadhi namambo weguta reSefarivhaimi, kana Hena kana Ivha?” 
\s1 Munyengetero waHezekia 
\p  
\v 14 Hezekia akagamuchira tsamba kubva mumaoko enhume, akaiverenga. Ipapo akakwidza kutemberi yaJehovha akaitambanudza pamberi paJehovha.  
\v 15 Uye Hezekia akanyengetera kuna Jehovha achiti,  
\v 16 “Haiwa Jehovha Wamasimba Ose, Mwari waIsraeri, mugere pakati pamakerubhimi, imi moga ndimi Mwari aripo pamusoro poumambo hwose hwenyika. Makasika denga nepasi.  
\v 17 Rerekai nzeve yenyu, Jehovha, munzwe; zarurai meso enyu, Jehovha muone; teererai mashoko ose aSenakeribhi aakatuma kuzozvidza nawo Mwari mupenyu. 
\p  
\v 18 “Ichokwadi, Jehovha, kuti madzimambo eAsiria akaparadza chose ndudzi idzi dzose nenyika dzadzo.  
\v 19 Vakakanda vamwari vavo mumoto vakavaparadza, nokuti vakanga vasiri vamwari asi matanda chete namatombo akaitwa namaoko avanhu.  
\v 20 Zvino, Jehovha Mwari wedu, tidzikinurei kubva muruoko rwake, kuitira kuti madzimambo ose enyika azive kuti imi moga, Jehovha, ndimi Mwari.” 
\s1 Kuwa kwaSenakeribhi 
\p  
\v 21 Ipapo Isaya mwanakomana waAmozi akatumira shoko kuna Hezekia achiti, “Zvanzi naJehovha, Mwari waIsraeri: Nokuda kwokuti wanyengetera kwandiri pamusoro paSenakeribhi mambo weAsiria,  
\v 22 heri shoko rakataurwa naJehovha pamusoro pake: 
\q1 “Mhandara Mwanasikana weZioni 
\q2 anokuzvidza uye anokuseka. 
\q1 Mwanasikana weJerusarema 
\q2 anokudzungudzira musoro wake paunenge uchitiza. 
\q1  
\v 23 Ndianiko wawatuka uye ukamhura? 
\q2 Ndianiko wawasimudzira inzwi rako, 
\q1 uye ukasimudzira meso ako uchizvikudza? 
\q2 Ndiye Mutsvene waIsraeri! 
\q1  
\v 24 Navaranda vako watutira 
\q2 kutuka pamusoro paIshe. 
\q1 Uye wakati, 
\q2 ‘Nengoro dzangu zhinji 
\q1 ndakakwira makomo marefu, 
\q2 kumusoro-soro kweRebhanoni. 
\q1 Ndakatema misidhari yayo mirefu refu, 
\q2 nemisipuresi yayo yakanakisisa. 
\q1 Ndakasvika kumusoro-soro kwayo, 
\q2 nokumasango ayo akanakisisa. 
\q1  
\v 25 Ndakachera matsime munyika yavamwe, 
\q2 ndikanwa mvura imomo. 
\q1 Netsoka dzangu 
\q2 ndakapwisa hova dzose dzeIjipiti.’ 
\b  
\q1  
\v 26 “Hauna kunzwa here? 
\q2 Izvi ndakazviita kare. 
\q1 Ndakazvironga pamazuva akare; 
\q2 zvino ndaita kuti zviitike, 
\q1 nokuti wakaparadza maguta akakomberedzwa 
\q2 akava mirwi yamatombo. 
\q1  
\v 27 Vanhu vawo, vapererwa nesimba, 
\q2 vavhundutswa uye vanyadziswa. 
\q1 Vafanana nembeu mumunda, 
\q2 namabukira manyoro, 
\q1 sebundo ramera padenga remba, 
\q2 ratsva risati rakura. 
\b  
\q1  
\v 28 “Asi ndinoziva paunogara 
\q2 uye nguva yaunouya neyaunoenda 
\q2 uye kuti unondiitira hasha zvakadii. 
\q1  
\v 29 Nokuda kwehasha dzako kwandiri 
\q2 uye nokuda kwokuti kusateerera kwako kwasvika munzeve dzangu, 
\q1 ndichaisa chiredzo changu mumhuno dzako 
\q2 namatomu angu mumuromo mako, 
\q1 uye ndichaita kuti udzokere 
\q2 nenzira yawakauya nayo. 
\p  
\v 30 “Ichi ndicho chichava chiratidzo kuvarwi, iwe Hezekia: 
\q1 “Gore rino muchadya zvinomera zvoga, 
\q2 uye mugore rinotevera muchadya mabukira azvo. 
\q1 Asi mugore rechitatu mudyare mugokohwa, 
\q2 mudyare minda yemizambiringa mugodya michero yayo. 
\q1  
\v 31 Zvakare, vakasara veimba yaJudha vachava nemidzi pasi 
\q2 uye vachabereka michero kumusoro. 
\q1  
\v 32 Nokuti muJerusarema muchabuda vachasara, 
\q2 uye muZioni muchabuda boka ravachapunyuka. 
\q1 Kushingaira kwaJehovha 
\q2 kuchazviita. 
\p  
\v 33 “Naizvozvo zvanzi naJehovha pamusoro pamambo weAsiria, 
\q1 “Haazopindi muguta iri 
\q2 kana kupfura museve pano. 
\q1 Haazosviki mberi kwaro nenhoo 
\q2 kana kuvaka gomo revhu pariri. 
\q1  
\v 34 Achadzokera nenzira yaakauya nayo; 
\q2 haazopindi muguta rino,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 35 “Ndichadzivirira guta rino uye ndichariponesa, 
\q2 nokuda kwangu uye nokuda kwaDhavhidhi muranda wangu!” 
\p  
\v 36 Ipapo mutumwa waJehovha akabuda akauraya varume zviuru zana namakumi masere nezvishanu pamusasa wavaAsiria. Vanhu vakati vachimuka mangwanani, onei mitumbi yavakafa!  
\v 37 Naizvozvo Senakeribhi mambo weAsiria akaputsa musasa. Akadzokera kuNinevhe akandogara ikoko. 
\p  
\v 38 Mumwe musi achinamata ari mutemberi yamwari wake Nisiroki, Adhiramereki naSharezeri, vanakomana vake vakamuuraya nomunondo, ndokutizira kunyika yeArarati. Mwanakomana waEsarihadhoni akamutevera paushe. 
\c 38  
\s1 Kurwara kwaHezekia 
\p  
\v 1 Mumazuva iwayo Hezekia akarwara kusvikira oda kufa. Muprofita Isaya mwanakomana waAmozi akaenda kwaari akati, “Zvanzi naJehovha: Gadzirisa zveimba yako, nokuti uri kuzofa; hausi kuzopona.” 
\p  
\v 2 Hezekia akatendeukira kumadziro akanyengetera kuna Jehovha achiti,  
\v 3 “Rangarirai henyu, Jehovha, kuti ndakafamba sei nokutendeka pamberi penyu nomwoyo wose nechokwadi uye ndikaita zvakanaka pamberi penyu.” Hezekia akachema kwazvo. 
\p  
\v 4 Ipapo shoko raJehovha rakauya kuna Isaya richiti,  
\v 5 “Enda undoti kuna Hezekia, ‘Zvanzi naJehovha, Mwari wababa vako Dhavhidhi: Ndanzwa munyengetero wako uye ndaona misodzi yako; ndichawedzera makore gumi namashanu paupenyu hwako.  
\v 6 Uye ndichakurwira iwe neguta rino kubva muruoko rwamambo weAsiria. Ndicharwira guta rino. 
\p  
\v 7 “ ‘Ichi ndicho chiratidzo chaJehovha kwauri kuti Jehovha achaita zvose zvaakavimbisa:  
\v 8 Ndichaita kuti mumvuri waitwa pazuva udzokere shure nhambwe gumi pamutaro wawanga wafamba pamanera aAhazi.’ ” Saizvozvo zuva rakadzokera shure nhambwe gumi dzarakanga radzika. 
\p  
\v 9 Chinyorwa chaHezekia mambo weJudha mushure mokurwara nokupora kwake: 
\q1  
\v 10 Ndakati, “Mazuva oupenyu hwangu 
\q2 achangotanga ndingafanira kupinda mumasuo orufu here? 
\q2 Ndigotorerwa makore angu asara here?” 
\q1  
\v 11 Ndakati, “Handichazoonizve Jehovha, 
\q2 iye Jehovha, munyika yavapenyu; 
\q1 handichazotarisizve kuvanhu 
\q2 kana kuva naavo vagere munyika ino zvino. 
\q1  
\v 12 Setende romufudzi, imba yangu 
\q2 yakoromorwa uye yatorwa. 
\q1 Somuruki ndapeta upenyu hwangu, 
\q2 uye iye andigura kubva pachirukiso; 
\q2 masikati namadekwana makaita kuti ndigume. 
\q1  
\v 13 Ndakamirira nomwoyo murefu kusvikira mambakwedza, 
\q2 asi iye akavhuna mapfupa angu ose kufanana nezvinoitwa neshumba; 
\q2 masikati namadekwana makaita kuti ndigume. 
\q1  
\v 14 Ndakarira senyenganyenga kana kondo. 
\q2 Ndakachema sokuchema kunoita njiva. 
\q1 Meso angu akaneta nokutarisa kudenga. 
\q2 Haiwa Jehovha, ndine nhamo, uyai mundinunure!” 
\b  
\q1  
\v 15 Asi ndingati kudiniko? 
\q2 Iye ataura neni, uye iye ndiye aita izvi. 
\q1 Ndichafamba nokuzvininipisa pamakore angu ose, 
\q2 nokuda kwokurwadziwa kwomwoyo wangu. 
\q1  
\v 16 Ishe, vanhu vanorarama nezvinhu zvakadai; 
\q2 uye mweya wangu unowana upenyu mazviriwo. 
\q1 Makandiporesa 
\q2 mukandiraramisa. 
\q1  
\v 17 Zvirokwazvo kutambudzika kwangu kukuru 
\q2 kwakandivigira rugare. 
\q1 Murudo rwenyu makandirwira 
\q2 pagomba rokuparadzwa; 
\q1 makaisa zvivi zvangu zvose 
\q2 shure kwenyu, 
\q1  
\v 18 Nokuti guva haringagoni kukurumbidzai, 
\q2 rufu harugoni kukurumbidzai nenziyo; 
\q1 vanodzika kugomba 
\q2 havangagoni kutarisira kutendeka kwenyu. 
\q1  
\v 19 Vapenyu, ivo vapenyu, 
\q2 ndivo vanokurumbidzai, 
\q1 sezvandiri kuita iye nhasi; 
\q2 madzibaba anoudza vana vavo nezvokutendeka kwenyu. 
\b  
\q1  
\v 20 Jehovha achandiponesa, 
\q2 uye tichaimba nemitengeranwa, 
\q1 mazuva ose oupenyu hwedu 
\q2 mutemberi yaJehovha. 
\p  
\v 21 Zvino Isaya akanga ati, “Gadzirai bundu ramaonde mugoriisa pamota, uye achapora.” 
\p  
\v 22 Hezekia akanga abvunza achiti, “Chiratidzo chichava chei chokuti ndiende kutemberi yaJehovha?” 
\c 39  
\s1 Nhume dzakabva kuBhabhironi 
\p  
\v 1 Panguva iyoyo Merodhaki-Bharadhani mwanakomana waBharadhani mambo weBhabhironi, akatumira matsamba nechipo kuna Hezekia, nokuti akanga anzwa nezvokurwara nokupora kwake.  
\v 2 Hezekia akagamuchira nhume nomufaro akavaratidza zvakanga zviri mumatura ake: sirivha, goridhe, zvinonhuhwira namafuta anokosha nenhumbi dzake dzose dzokurwa uye nezvose zvaiwanikwa papfuma yake. Hapana chinhu mumuzinda wake kana muumambo hwake chavasina kuratidzwa naHezekia. 
\p  
\v 3 Ipapo muprofita Isaya akaenda kuna Mambo Hezekia akabvunza achiti, “Varume avo vakati kudini, uye vakabvepi?” 
\p Hezekia akapindura achiti, “Vakabva kunyika iri kure. Vakauya kwandiri vachibva kuBhabhironi.” 
\p  
\v 4 Muprofita akamubvunza achiti, “Vakaoneiko mumuzinda menyu?” 
\p Hezekia akati, “Vakaona zvose zviri mumuzinda mangu. Pakati pepfuma yangu hapana chandisina kuvaratidza.” 
\p  
\v 5 Ipapo Isaya akati kuna Hezekia, “Inzwa shoko raJehovha Wamasimba Ose:  
\v 6 Zvirokwazvo nguva ichauya iyo zvose zviri mumba mako, nezvose zvakaunganidzwa namadzibaba ako kusvikira nhasi, zvichatakurwa zvichiendeswa kuBhabhironi. Hapana chichasara, ndizvo zvinotaura Jehovha.  
\v 7 Uye vamwe vavana vako, venyama neropa rako chairo vauchabereka, vachatorwa uye vachava varanda mumuzinda wamambo weBhabhironi.” 
\p  
\v 8 Hezekia akapindura achiti, “Shoko raJehovha rawataura rakanaka.” Nokuti akafunga kuti, “Pachava norugare nokudzivirirwa pamazuva oupenyu hwangu.” 
\c 40  
\s1 Kunyaradzwa kwaVanhu vaMwari 
\q1  
\v 1 Nyaradzai, nyaradzai vanhu vangu, 
\q2 ndizvo zvinotaura Mwari wenyu. 
\q1  
\v 2 Taurai nounyoro kuJerusarema, 
\q2 mudanidzire kwariri 
\q1 kuti kubata kwaro kukuru kwapera, 
\q2 uye kuti chivi charo charipirwa, 
\q1 kuti ragamuchira kubva muruoko rwaJehovha 
\q2 zvakapetwa kaviri pamusoro pezvivi zvaro. 
\q1  
\v 3 Inzwi rounodanidzira achiti, 
\q1 “Gadzirai nzira yaJehovha 
\q2 mugwenga, 
\q1 ruramisai mugwagwa 
\q2 waMwari wedu murenje. 
\q1  
\v 4 Mipata yose ichasimudzirwa, 
\q2 makomo ose nezvikomo zvichaenzaniswa; 
\q2 nzvimbo dzisakaenzana dzichava bani. 
\q1  
\v 5 Uye kubwinya kwaJehovha kucharatidzwa, 
\q2 uye marudzi ose avanhu achazviona. 
\q4 Nokuti muromo waJehovha wazvitaura.” 
\b  
\q1  
\v 6 Inzwi rinoti, “Danidzirai.” 
\q2 Ini ndokuti, “Ndodanidzireiko?” 
\b  
\q1 “Vanhu vose vakaita souswa, 
\q2 uye kubwinya kwavo kwose kwakaita samaruva omunda. 
\q1  
\v 7 Uswa hunooma uye maruva anowa, 
\q2 nokuti mweya waJehovha unofuridzira pamusoro pazvo. 
\q2 Zvirokwazvo vanhu uswa. 
\q1  
\v 8 Uswa hunooma uye maruva anowa, 
\q2 asi shoko raMwari wedu rinogara nokusingaperi.” 
\b  
\q1  
\v 9 Imi munoparidzira Zioni zvinhu zvakanaka, 
\q2 kwirai pagomo refu. 
\q1 Imi munoparidzira Jerusarema mashoko akanaka, 
\q2 danidzirai nesimba, musatya; 
\q2 muti kumaguta eJudha, “Hoyu Mwari wenyu!” 
\q1  
\v 10 Tarirai, Ishe Jehovha ari kuuya nesimba, 
\q2 uye ruoko rwake runomubatira ushe. 
\q1 Tarirai, mubayiro wake anawo, 
\q2 uye zvaanoripira nazvo anazvo. 
\q1  
\v 11 Anofudza makwai ake somufudzi: 
\q2 Anounganidza makwayana mumaoko ake 
\q1 agoatakurira pedyo nomwoyo wake; 
\q2 zvinyoronyoro anotungamirira nhunzvi dzinonwisa. 
\b  
\q1  
\v 12 Ndianiko akayera mvura zhinji muchanza chake, 
\q2 kana kuyera denga noupamhi hwechanza chake? 
\q1 Ndianiko akaisa guruva rose rapasi mudengu, 
\q2 kana kuyera kurema kwamakomo nechiyero, 
\q2 nezvikomo pachiyero? 
\q1  
\v 13 Ndiani akanzwisisa murangariro waJehovha, 
\q2 kana kumudzidzisa somudzidzisi wake? 
\q1  
\v 14 Ndiani akabvunzwa naJehovha kuti amujekesere, 
\q2 uye ndiani akamudzidzisa nzira yakanaka? 
\q1 Ndianiko akamudzidzisa ruzivo 
\q2 kana kumuratidza nzira yokunzwisisa? 
\b  
\q1  
\v 15 Zvirokwazvo ndudzi dzavanhu dzakaita sedonhwe remvura riri muchirongo; 
\q2 vanongova seguruva riri pamusoro pechiyero; 
\q2 anoyera zviwi kunge guruva rakatsetseka. 
\q1  
\v 16 Rebhanoni harina huni dzinoringana kuvesa moto wearitari, 
\q2 uye zvipfuwo zvaro hazvikwani kuita chipiriso chinopiswa. 
\q1  
\v 17 Ndudzi dzose dzakaita sepasina chinhu pamberi pake; 
\q2 iye anodziona sedzisina maturo, 
\q2 kunge dzisipo. 
\b  
\q1  
\v 18 Zvino, mungafananidza Mwari naaniko? 
\q2 Ndoupi mufananidzo wamungamuenzanisa nawo? 
\q1  
\v 19 Kana chiri chifananidzo, muumbi anochiumba, 
\q2 mupfuri wegoridhe ochinamira negoridhe, 
\q2 uye anochiitira uketani hwesirivha. 
\q1  
\v 20 Murombo anoshayiwa chipo 
\q2 anosarudza danda risingaori. 
\q1 Anotsvaka mhizha kuti 
\q2 imuvezere chifananidzo chisingazozungunuki. 
\b  
\q1  
\v 21 Hamuzivi here? 
\q2 Hamuna kunzwa here? 
\q1 Hamuna kumbozviudzwa kubva pakutanga here? 
\q2 Hamuna kunzwisisa kubva pakuvamba kwenyika here? 
\q1  
\v 22 Anogara samambo pamusoro pedenderedzwa renyika, 
\q2 uye vanhu vayo vakaita semhashu. 
\q1 Anotambanudza matenga setende, 
\q2 agoawaridzira setende kuti agaremo. 
\q1  
\v 23 Anoita kuti machinda ave pasina, 
\q2 uye anoderedza vatongi venyika ino kuti vave pasina. 
\q1  
\v 24 Vachangosimwa, vachangodyarwa, 
\q2 vachangodzika midzi muvhu, 
\q2 iye anofuridza pamusoro pavo vachibva vaoma, uye chamupupuri chinovakukura sehundi. 
\b  
\q1  
\v 25 “Mungandienzanisa naaniko? 
\q2 Kana kuti ndiani akaenzana neni?” ndizvo zvinotaura Iye Mutsvene. 
\q1  
\v 26 Simudzai meso enyu mutarire kumatenga. 
\q2 Ndianiko akasika zvose izvi? 
\q1 Iye anobudisa nyeredzi imwe imwe, 
\q2 achidzidana imwe neimwe nezita rayo. 
\q1 Nokuda kwesimba rake guru uye noukuru hwesimba rake, 
\q2 hapana kana imwe zvayo inoshayikwa. 
\b  
\q1  
\v 27 Unoreveiko, iwe Jakobho, 
\q2 unogununʼuna chii, iwe Israeri uchiti, 
\q1 “Nzira yangu haizivikanwi naJehovha; 
\q2 Mwari wangu haana hanya nezvandinorwira?” 
\q1  
\v 28 Hauzivi here? 
\q2 Hauna kunzwa here? 
\q1 Jehovha ndiye Mwari nokusingaperi, 
\q2 Musiki wamagumo enyika. 
\q1 Haaneti kana kuziya, 
\q2 uye hakuna angayera kunzwisisa kwake. 
\q1  
\v 29 Anopa simba kuna vakarukutika, 
\q2 uye anowedzera simba kuna vasina simba. 
\q1  
\v 30 Kunyange majaya anoneta uye anorukutika, 
\q2 uye majaya anogumburwa agowa; 
\q1  
\v 31 asi avo vane tariro muna Jehovha 
\q2 vachavandudza simba ravo. 
\q1 Vachabhururuka namapapiro samakondo; 
\q2 vachamhanya vasinganeti; 
\q2 vachafamba vasingaziyi. 
\c 41  
\s1 Mubatsiri waIsraeri 
\p  
\v 1 “Nyararai pamberi pangu, imi zviwi! 
\q2 Ndudzi ngadzivandudze simba radzo! 
\q1 Ngadziswedere mberi dzitaure; 
\q2 ngatisanganei pamwe chete panzvimbo inotongerwa mhaka. 
\b  
\q1  
\v 2 “Ndianiko akamutsa mumwe kubva kumabvazuva, 
\q2 akamudana nokururama kuushumiri hwake? 
\q1 Anopa ndudzi kwaari, 
\q2 uye anoisa madzimambo pasi pake. 
\q1 Anovashandura vagova guruva nomunondo wake, 
\q2 vagova hundi inopepereswa nemhepo nouta hwake. 
\q1  
\v 3 Anovadzinganisa agopfuurira mberi asina vanga, 
\q2 nenzira yaasina kumbotsika netsoka dzake kare. 
\q1  
\v 4 Ndiani akabata basa iri akaripedza, 
\q2 akadana zvizvarwa kubva pakutanga? 
\q1 Ini, Jehovha, iye wokutanga wavo 
\q2 newokupedzisira, ndini iye.” 
\b  
\q1  
\v 5 Zviwi zvakazviona zvikatya; 
\q2 magumo enyika anodedera. 
\q1 Vanoswedera uye vagouya mberi; 
\q2  
\v 6 mumwe nomumwe anobatsira wokwake, 
\q2 achiti kuhama yake, “Simba!” 
\q1  
\v 7 Mhizha inokurudzira mupfuri wegoridhe, 
\q2 uye iye anotsetsenura nenyundo 
\q2 anokurudzira uyo anorova panhera. 
\q1 Anoti kune chakanamwa nomoto, “Ichi chakanaka.” 
\q2 Anoroverera chifananidzo pasi nechipikiri kuti chisazungunuka. 
\b  
\q1  
\v 8 “Asi iwe, Israeri, muranda wangu, 
\q2 Jakobho, wandakasarudza, 
\q2 imi vana vaAbhurahama, shamwari yangu, 
\q1  
\v 9 ndakakutora kubva kumagumo enyika, 
\q2 ndikakudana kubva kumakona ayo ari kure. 
\q1 Ndakati kwauri, ‘Uri muranda wangu,’ 
\q2 ndakakusarudza uye handina kukuramba. 
\q1  
\v 10 Naizvozvo usatya, nokuti ndinewe; 
\q2 usavhunduka, nokuti ndini Mwari wako. 
\q1 Ndichakusimbisa uye ndichakubatsira; 
\q2 ndichakutsigira noruoko rwangu rworudyi rwokururama. 
\b  
\q1  
\v 11 “Vose vanokutsamwira 
\q2 zvirokwazvo vachanyadziswa uye vachanyara; 
\q1 vose vanokakavadzana newe 
\q2 vachava sechinhu chisipo uye vachaparara. 
\q1  
\v 12 Kunyange ukatsvaka vavengi vako, 
\q2 hauzovawani. 
\q1 Avo vanorwa newe 
\q2 vachava sechinhu chisipo chose. 
\q1  
\v 13 Nokuti ndini Jehovha, Mwari wako, 
\q2 anobata ruoko rwako rworudyi 
\q1 achiti kwauri, Usatya; 
\q2 ndichakubatsira. 
\q1  
\v 14 Usatya Jakobho iwe honye, 
\q2 iwe mudiki Israeri, 
\q1 nokuti ini iyeni ndichakubatsira,” ndizvo zvinotaura Jehovha, 
\q2 Mudzikinuri wako, Mutsvene waIsraeri. 
\q1  
\v 15 “Tarira, ndichakuita mupuro, mutsva unopinza, 
\q2 una meno mazhinji. 
\q1 Uchapura makomo ugoapwanya, 
\q2 uye uchaderedza zvikomo zvikava hundi. 
\q1  
\v 16 Uchaapepeta, achatorwa nemhepo, 
\q2 uye chamupupuri chichaaparadzira. 
\q1 Asi iwe uchafara muna Jehovha, 
\q2 uye uchazvirumbidza muMutsvene waIsraeri. 
\b  
\q1  
\v 17 “Varombo navanoshaya vanotsvaka mvura 
\q2 asi hakuna; 
\q2 ndimi dzavo dzaoma nenyota. 
\q1 Asi ini Jehovha ndichavapindura; 
\q2 ini, Mwari waIsraeri, handizovasiya. 
\q1  
\v 18 Ndichaita kuti nzizi dziyerere pamitunhu isina miti, 
\q2 namatsime pakati pemipata. 
\q1 Ndichashandura gwenga rikava madziva emvura, 
\q2 nenyika yakaoma ikava matsime. 
\q1  
\v 19 Ndichaisa mugwenga musidhari nomuakasiya, 
\q2 mumite nomuorivhi. 
\q1 Ndichaisa mipaini musango, 
\q2 misipuresi nemifiri pamwe chete, 
\q1  
\v 20 kuitira kuti vanhu vaone uye vagoziva, 
\q2 varangarire vagonzwisisa, 
\q1 kuti ruoko rwaJehovha rwakaita izvozvi, 
\q2 kuti Mutsvene waIsraeri ndiye akazvisika. 
\b  
\q1  
\v 21 “Sumai mhaka yenyu,” ndizvo zvinotaura Jehovha. 
\q2 “Uyai namashoko enyu akasimba,” ndizvo zvinotaura Mambo waJakobho. 
\q1  
\v 22 “Uyai nezvifananidzo zvenyu zvitiudze 
\q2 zvichaitika. 
\q1 Tiudzei zvinhu zvakare kuti zvaiva zvipi, 
\q2 kuti zvimwe tizviongorore 
\q2 tigoziva magumo azvo. 
\q1 Kana kuti tizivisei, zvinhu zvichaitika, 
\q2  
\v 23 tiudzei kuti ramangwana rinei, 
\q2 kuti tizive kana imi muri vanamwari. 
\q1 Itai chimwe chinhu, chingava chakanaka kana chakaipa, 
\q2 kuitira kuti tigoshamiswa tigozadzwa nokutya. 
\q1  
\v 24 Asi imi hamusi chinhu, 
\q2 uye mabasa enyu haana maturo chose; 
\q2 anokusarudzai anonyangadza. 
\b  
\q1  
\v 25 “Ndamutsa mumwe anobva kumusoro, zvino ari kuuya, 
\q2 mumwe anobva kumabvazuva anodana kuzita rangu. 
\q1 Iye anotsika pamusoro pavabati kunge anotsika dope, 
\q2 kuita sokunge muumbi wehari anokanya ivhu. 
\q1  
\v 26 Ndianiko akazvireva kubva pakutanga, kuti zvimwe, 
\q2 tingaziva, kana kuti zvichigere kuitika, kuti zvimwe tigoti, ‘Akanga anatsa?’ 
\q1 Hapana akataura izvozvi, 
\q2 hapana akataura kuti zvichauya, 
\q2 hapana akanzwa kana shoko kubva kwamuri. 
\q1  
\v 27 Ndini akava wokutanga kuudza Zioni kuti, ‘Tarira, ava vari pano!’ 
\q2 Ndakapa kuJerusarema nhume yamashoko akanaka. 
\q1  
\v 28 Ndinotarisa asi hapana munhu, 
\q2 hapana pakati pavo anopa zano, 
\q2 hapana anondipindura pandinovabvunza. 
\q1  
\v 29 Tarirai, vose inhema dzoga! 
\q2 Mabasa avo haana maturo; 
\q2 zvifananidzo zvavo imhepo nenyonganiso. 
\c 42  
\s1 Muranda waJehovha 
\q1  
\v 1 “Tarirai muranda wangu, wandinotsigira, 
\q2 musanangurwa wangu wandinofarira; 
\q1 Ndichaisa Mweya wangu pamusoro pake, 
\q2 uye achavigira ndudzi kururamisirwa. 
\q1  
\v 2 Haazodanidziri kana kuridza mhere, 
\q2 kana kusimudza inzwi munzira dzomuguta. 
\q1  
\v 3 Rutsanga rwakapwanyika haangaruvhuni, 
\q2 uye nomwenje unopfungaira haazoudzimi. 
\q1 Mukutendeka, achavigira vanhu kururamisira; 
\q2  
\v 4 haangakoniwi uye haangaperi simba 
\q1 kusvikira asimbisa kururamisirwa panyika. 
\q2 Zviwi zvichaisa tariro yazvo mumurayiro wake.” 
\b  
\q1  
\v 5 Zvanzi naMwari Jehovha, 
\q1 iye akasika matenga akaatatamura, 
\q2 akatambanudza nyika nezvose zvinobuda mairi, 
\q1 anopa kufema kuvanhu vayo, 
\q2 noupenyu kuna avo vanofamba pamusoro payo: 
\q1  
\v 6 “Ini, Jehovha, ndakakudana mukururama; 
\q2 ndichabata ruoko rwako. 
\q1 Ndichakuchengeta ndigokuita 
\q2 kuti uve sungano yavanhu 
\q2 nechiedza kune veDzimwe Ndudzi, 
\q1  
\v 7 kuti usvinudze meso asingaoni, 
\q2 usunungure vakasungwa mutorongo 
\q2 uye usunungure vari mugomba, avo vagere murima. 
\b  
\q1  
\v 8 “Ndini Jehovha; ndiro zita rangu! 
\q2 Handizopi kukudzwa kwangu kuno mumwe, 
\q2 kana kurumbidzwa kwangu kuzvifananidzo. 
\q1  
\v 9 Tarira, zvinhu zvakare zvaitika, 
\q1 uye ndiri kutaura zvinhu zvitsva; 
\q2 izvo zvisati zvavapo 
\q2 ndinozvizivisa kwamuri.” 
\s1 Rwiyo rwoKurumbidza Jehovha 
\q1  
\v 10 Imbirai Jehovha rwiyo rutsva, 
\q2 murumbidzei kubva kumagumo enyika, 
\q1 imi munoburukira kugungwa, nezvose zviri mariri, 
\q2 imi zviwi, navose vanogaramo. 
\q1  
\v 11 Gwenga namaguta aro ngazvidanidzire; 
\q2 nzvimbo dzinogara Kedhari ngadzifare. 
\q1 Vanhu veSera ngavaimbe nomufaro; 
\q2 ngavapururudze pamusoro pemakomo. 
\q1  
\v 12 Ngavape rukudzo kuna Jehovha 
\q2 uye vaparidze rumbidzo yake kuzviwi. 
\q1  
\v 13 Jehovha achabuda somunhu ane simba, 
\q2 semhare, achamutsa kushingaira kwake; 
\q1 nokudanidzira, achamutsa kurwa 
\q2 uye achakunda vavengi vake. 
\b  
\q1  
\v 14 “Nokuti ndanga ndakanyarara kwenguva refu, 
\q2 ndanga ndinyerere uye ndichizvidzora. 
\q1 Asi zvino kufanana nomukadzi ari kusununguka, 
\q2 ndiri kudanidzira, ndiri kufemedzeka nokutakwaira. 
\q1  
\v 15 Ndichaparadza makomo nezvikomo, 
\q2 uye ndichaomesa zvose zvawo zvinomera; 
\q1 ndichashandura nzizi dzikava zviwi, 
\q2 uye madziva ndichaaomesa. 
\q1  
\v 16 Ndichatungamirira mapofu nenzira dzavasingazivi, 
\q2 nomumakwara avasina kuziva, 
\q1 ndichavatungamirira; ndichashandura rima rikava chiedza pamberi pavo 
\q2 uye ndichaita kuti nzvimbo dzakaipa dziti chechetere. 
\q1 Izvi ndizvo zvinhu zvandichaita; 
\q2 handizovasiya. 
\q1  
\v 17 Asi ivo vanovimba nezvifananidzo, 
\q2 vanoti kune zvakaumbwa, ‘Ndimi vamwari vedu,’ 
\q2 vachadzoserwa shure mukunyadziswa kukuru. 
\s1 Israeri iBofu neMatsi 
\q1  
\v 18 “Inzwai, imi matsi; 
\q2 tarirai, imi mapofu, muone! 
\q1  
\v 19 Ndianiko bofu, asi muranda wangu, 
\q2 uye matsi kufanana nenhume yandinotuma? 
\q1 Ndianiko bofu rakafanana naiye akazvipira kwandiri, 
\q2 kana bofu rakafanana nomuranda waJehovha? 
\q1  
\v 20 Wakaona zvinhu zvizhinji, asi hauna kuva nehanya; 
\q2 nzeve dzako dzakazaruka, asi hauna chaunonzwa.” 
\q1  
\v 21 Zvakafadza Jehovha 
\q2 nokuda kwokururama kwake, 
\q2 kuti akudze murayiro wake uye aubwinyise. 
\q1  
\v 22 Asi ava ndivo vanhu vakapambwa uye vakabirwa, 
\q2 vose vakasungwa mumakomba 
\q2 kana kuti vakavanzwa mumatorongo. 
\q1 Vakava vabatwa, 
\q2 pasina anovarwira; 
\q1 vakaitwa chinhu chakapambwa, 
\q2 pasina anoti, “Vadzoserei kwavakabva.” 
\b  
\q1  
\v 23 Ndiani pakati penyu achateerera izvi, 
\q2 kana kurerekera nzeve dzake zvikuru panguva inouya? 
\q1  
\v 24 Ndiani akarega Jakobho achipambwa, 
\q2 akaendesa Israeri kuvapambi? 
\q1 Akanga asiri Jehovha here, 
\q2 iye watakatadzira? 
\q1 Nokuti havana kuda kutevera nzira dzake; 
\q2 havana kuteerera murayiro wake. 
\q1  
\v 25 Naizvozvo akadururira hasha dzake dzinopisa pamusoro pavo, 
\q2 iro bongozozo rehondo. 
\q1 Rakavaputira muvira romoto, asi havana kunzwisisa; 
\q2 rakavapisa, asi mwoyo yavo yakashaya hanya nazvo. 
\c 43  
\s1 Muponesi waIsraeri Mumwe Oga 
\q1  
\v 1 Asi zvino, zvanzi naJehovha, 
\q2 iye akasika iwe Jakobho, 
\q2 iye akakuumba iwe Israeri: 
\q1 “Usatya, nokuti ndakakudzikinura; 
\q2 ndakakudana nezita rako; uri wangu. 
\q1  
\v 2 Paunopfuura nomumvura zhinji 
\q2 ini ndichava newe; 
\q1 uye paunopinda nomunzizi, hadzizokukukuri. 
\q2 Paunofamba nomumoto, haungazotsvi; 
\q2 murazvo haungazokupisi. 
\q1  
\v 3 Nokuti ndini Jehovha, Mwari wako, 
\q2 Mutsvene waIsraeri, Muponesi wako; 
\q1 ndinopa Ijipiti kuti ive rusununguko rwako, 
\q2 Etiopia neShebha pachinzvimbo chako. 
\q1  
\v 4 Sezvo uchikosha uye uchikudzwa pamberi pangu, 
\q2 uye nokuti ndinokuda, 
\q1 ndichaisa vanhu panzvimbo yako, 
\q2 namarudzi avanhu pachinzvimbo choupenyu hwako. 
\q1  
\v 5 Usatya, nokuti ndinewe; 
\q2 ndichauyisa vana vako kubva kumabvazuva, 
\q2 ndichakuunganidzai kubva kumavirira. 
\q1  
\v 6 Ndichati kurutivi rwokumusoro, ‘Varegedze!’ 
\q2 uye kurutivi rwezasi, ‘Usavadzivisa.’ 
\q1 Uyisai vanakomana vangu kubva kure, 
\q2 uye navanasikana vangu vabva kumigumo yenyika, 
\q1  
\v 7 vose vanodanwa nezita rangu, 
\q2 vandakasikira kukudzwa kwangu 
\q2 vandakaumba uye ndikaita.” 
\q1  
\v 8 Uyai neavo vane meso asi vari mapofu, 
\q2 vane nzeve asi vari matsi. 
\q1  
\v 9 Ndudzi dzose ngadziungane pamwe chete, 
\q2 uye marudzi ngaaungane. 
\q1 Ndianiko pakati pavo akati izvi zvichaitika, 
\q2 akatiparidzira zvinhu zvakare? 
\q1 Ngavauye nezvapupu zvavo kuti zvionekwe kuti havana mhosva, 
\q2 kuitira kuti vamwe vanzwe vagoti, “Ichokwadi.” 
\q1  
\v 10 “Imi muri zvapupu zvangu,” ndizvo zvinotaura Jehovha, 
\q2 “uye nomuranda wangu wandakasarudza, 
\q1 kuti mugoziva uye mugonditenda 
\q2 uye mugonzwisisa kuti ndini iye. 
\q1 Hakuna kumbova nomumwe mwari akaumbwa ndisati ndavapo, 
\q2 uye hakuchazova nomumwe shure kwangu. 
\q1  
\v 11 Ini, iyeni, ndini Jehovha, 
\q2 uye kunze kwangu hakuna muponesi. 
\q1  
\v 12 Ini ndakaratidza ndikaponesa, ndikaparidza, 
\q2 ini, kwete vamwe vamwari vedzimwe ndudzi vari pakati penyu. 
\q1 Imi muri zvapupu zvangu,” ndizvo zvinotaura Jehovha, kuti, “ndini Mwari. 
\q2  
\v 13 Hongu, kubva pamazuva akare ndini iye. 
\q1 Hakuna angarwira munhu muruoko rwangu. 
\q2 Pandinoita chinhu, ndianiko angachikonesa?” 
\s1 Ngoni dzaMwari noKusatendeka kwaIsraeri 
\q1  
\v 14 Zvanzi naJehovha, 
\q2 Mudzikunuri wenyu, Mutsvene waIsraeri: 
\q1 “Ndichatuma vanhu kuBhabhironi nokuda kwenyu, 
\q2 uye ndichaburitsa vaBhabhironi vose vachitiza, 
\q2 muzvikepe zvavaidada nazvo. 
\q1  
\v 15 Ndini Jehovha, Mutsvene Wenyu, 
\q2 Musiki waIsraeri, Mambo wenyu.” 
\b  
\q1  
\v 16 Zvanzi naJehovha, 
\q2 iye akaita nzira pakati pegungwa, 
\q2 nenzira mukati memvura zhinji, 
\q1  
\v 17 iye akabudisa ngoro namabhiza, 
\q2 hondo pamwe chete nezvinosimbisa, 
\q1 vakavata ipapo, havana kuzombomukazve, 
\q2 vadzimwa, vadzimwa somwenje: 
\q1  
\v 18 “Chikanganwai zvinhu zvakare; 
\q2 musaramba muri pane zvakapfuura. 
\q1  
\v 19 Tarirai, ndava kuita chinhu chitsva! 
\q2 Zvino chava kumera; hamuchioni here? 
\q1 Ndiri kuita nzira mugwenga 
\q2 nehova musango. 
\q1  
\v 20 Zvikara zvesango zvinondikudza, 
\q2 makava namazizi, 
\q1 nokuti ndinozvipa mvura mugwenga 
\q2 nehova musango, 
\q1 kuti ndipe vanhu vangu chokunwa, vasanangurwa vangu, 
\q2  
\v 21 vanhu vandakazviumbira, 
\q2 kuti vaparidze kurumbidzwa kwangu. 
\b  
\q1  
\v 22 “Kunyange zvakadaro hauna kudana kwandiri, iwe Jakobho; 
\q2 hauna kuzvinetesa nokuda kwangu, iwe Israeri. 
\q1  
\v 23 Hauna kundivigira makwai ezvipiriso zvinopiswa, 
\q2 kana kundikudza nezvibayiro zvako. 
\q1 Handina kukuremedza nezvipiriso zvezviyo, 
\q2 kana kukunetesa nokuda zvinonhuhwira. 
\q1  
\v 24 Hauna kundivigira kana zvinotapira, 
\q2 kana kundigutsa namafuta ezvibayiro zvako. 
\q1 Asi wakandiremedza nezvivi zvako 
\q2 uye ukandinetesa nokudarika kwako. 
\b  
\q1  
\v 25 “Ini, iyeni, ndini ndinodzima kudarika kwako, 
\q2 nokuda kwangu, 
\q2 handizorangaririzve zvakaipa zvako. 
\q1  
\v 26 Ndiyeuchidze zvakapfuura, 
\q2 ngatitaurirane nyaya iyi pamwe chete; 
\q2 zvipupurire kuti hauna mhosva. 
\q1  
\v 27 Tateguru wako akatadza; 
\q2 vamiririri vako vakandimukira. 
\q1  
\v 28 Naizvozvo ndichanyadzisa vanokudzwa vomutemberi yako, 
\q2 uye ndichaita kuti Jakobho aparadzwe 
\q2 uye Israeri asekwe. 
\c 44  
\s1 Israeri Musanangurwa 
\q1  
\v 1 “Asi zvino chinzwa, iwe Jakobho, muranda wangu, 
\q2 Israeri, wandakasarudza. 
\q1  
\v 2 Zvanzi naJehovha, iye akakuita, 
\q2 akauumba mudumbu 
\q2 uye iye achakubatsira: 
\q1 Usatya, iwe Jakobho, muranda wangu, 
\q2 Jeshuruni, wandakasarudza. 
\q1  
\v 3 Nokuti ndichadurura mvura panyika ine nyota, 
\q2 nehova pamusoro pevhu rakaoma; 
\q1 ndichadurura Mweya wangu pamusoro porudzi rwako, 
\q2 nemikomborero yangu pamusoro pavana vako. 
\q1  
\v 4 Vachamera souswa mudekete, 
\q2 semiti yemikonachando pahova dzinoyerera. 
\q1  
\v 5 Mumwe achati, ‘Ndiri waJehovha’; 
\q2 mumwe achazvitumidza nezita raJakobho; 
\q1 zvakadaro, mumwe achanyora muruoko rwake achiti, ‘Ndiri waJehovha,’ 
\q2 uye achatora zita rokuti Israeri. 
\s1 Jehovha, Kwete Zvifananidzo 
\q1  
\v 6 “Zvanzi naJehovha, 
\q2 Mambo waIsraeri noMudzikinuri, Jehovha Wamasimba Ose: 
\q1 Ndini wokutanga uye ndini wokupedzisira; 
\q2 kunze kwangu hakuna Mwari. 
\q1  
\v 7 Ndianiko zvino akafanana neni? Ngaazvitaure. 
\q2 Ngaadanidzire, azviise mberi kwangu 
\q1 izvo zvakaitika kubva pandakasimbisa vanhu vangu vekare, 
\q2 uye kuti chiiko chichaitika hongu, 
\q2 ngaataure zvichaitika. 
\q1  
\v 8 Musadedera, musatya. 
\q2 Handina kuparidza izvi here uye ndikazvitaura kare kare? 
\q1 Imi muri zvapupu zvangu. 
\q2 Kune mumwe Mwari kunze kwangu here? Kwete, hakuna rimwe Dombo; hakuna rimwe randinoziva.” 
\b  
\q1  
\v 9 Vose vanoita zvifananidzo havana maturo, 
\q2 uye zvinhu zvavanofarira hazvibatsiri. 
\q1 Vose vangada kuvapupurira mapofu; 
\q2 havazivi, ndiko kuchava kunyadziswa kwavo. 
\q1  
\v 10 Ndiani anoveza mwari 
\q2 uye anoumba chifananidzo, chisingamubatsiri chinhu? 
\q1  
\v 11 Iye navamwe vake vachanyadziswa; 
\q2 mhizha hadzizi chinhu asi vanhu zvavo. 
\q1 Ngavaungane vose pamwe chete uye vamire vasingazungunuswi; vachaderedzwa, 
\q2 uye vachatya vachanyadziswa. 
\b  
\q1  
\v 12 Mupfuri anotora chokupfurisa 
\q2 agochishandisa mumazimbe; 
\q1 anoita chifananidzo nenyundo, 
\q2 agochiumba nesimba roruoko rwake. 
\q1 Anonzwa nzara agorasikirwa nesimba rake. 
\q2 Mukusanwa kwake mvura anobva aziya. 
\q1  
\v 13 Muvezi anoyera nerwodzi 
\q2 ozoita mutsetse nechokunyoresa; 
\q1 anounatsa nembezo, 
\q2 uye anoutara nezvienzaniso. 
\q1 Anouumba mumufananidzo womunhu, 
\q2 womunhu nokunaka kwake kwose, 
\q2 kuti ugare mumba. 
\q1  
\v 14 Akatema misidhari, 
\q2 kana zvimwe akatora musipuresi kana muouki. 
\q1 Akaurega uchikura pakati pemiti yesango, 
\q2 kana kuti akasima mupaini, mvura ikaita kuti ukure. 
\q1  
\v 15 Ndidzo huni dzomunhu dzokuvesa moto; 
\q2 dzimwe dzacho anodzitora agozvidziyisa nadzo, 
\q2 anovesa moto agobika chingwa nadzo. 
\q1 Asizve anoveza chimwari agochinamata; 
\q2 anoita chifananidzo agochipfugamira. 
\q1  
\v 16 Hafu yehuni anopisa mumoto, 
\q2 nadzo anobika zvokudya zvake, 
\q2 anogocha nyama yake agoidya achiguta. 
\q1 Anozvidziyisazve, agoti, 
\q2 “Haiwa! Ndadziyirwa; moto ndiri kuuona.” 
\q1  
\v 17 Nezvasara anoita nazvo chimwari, 
\q2 icho chifananidzo chake; anochipfugamira agochinamata. 
\q1 Anonyengetera kwachiri achiti, 
\q2 “Ndiponesei; ndimi mwari wangu.” 
\q1  
\v 18 Havana chavanoziva, havanzwisisi chinhu, meso avo akanamwa kuitira kuti varege kuona, 
\q2 uye ndangariro dzavo dzakafukidzirwa kuitira kuti varege kunzwisisa. 
\q2 Hapana anombomira kuti afunge, 
\q1  
\v 19 Hapana ane ruzivo 
\q2 kana kunzwisisa kuti ati, 
\q1 “Hafu yacho ndaishandisa pakuvesa moto; 
\q2 ini iyeni ndabikira chingwa pamazimbe acho, 
\q2 ndagocha nyama ndikadya. 
\q1 Ndichaita zvinonyangadza pane zvasara here? 
\q2 Ndichapfugamira kudanda rehuni here?” 
\q1  
\v 20 Anodya madota, mwoyo wakanyengerwa unomutsausa; 
\q2 haagoni kuzviponesa kana kuti ati, 
\q2 “Ko, chinhu ichi chiri muruoko rwangu rworudyi hachisi chenhema here?” 
\b  
\q1  
\v 21 “Rangarira zvinhu izvi, iwe Jakobho, 
\q2 nokuti uri muranda wangu, iwe Israeri. 
\q1 Ndakakuita, uri muranda wangu; 
\q2 haiwa Israeri, handichakukanganwizve. 
\q1  
\v 22 Ndakadzima kudarika kwako segore, 
\q2 nezvivi zvako semhute yamangwanani. 
\q1 Dzokera kwandiri, 
\q2 nokuti ndakakudzikinura.” 
\b  
\q1  
\v 23 Imbai nomufaro imi matenga, nokuti Jehovha akaita izvozvi; 
\q2 danidzira nesimba, iwe nyika iri pasi. 
\q1 Imbai nziyo, imi makomo, 
\q2 nemi masango nemiti yose, 
\q1 nokuti Jehovha adzikinura Jakobho, 
\q2 akaratidza kubwinya muIsraeri. 
\s1 Jerusarema Richagarwazve 
\q1  
\v 24 “Zvanzi naJehovha, 
\q2 mudzikinuri wako, iye akakuumba uri mudumbu: 
\b  
\q1 “Ndini Jehovha, 
\q1 akaita zvinhu zvose, 
\q1 iye oga akatatamura matenga, 
\q1 akatambanudza nyika oga, 
\b  
\q1  
\v 25 “iye anokonesa zviratidzo zvavaprofita venhema, 
\q2 anoita kuti vavuki vave mapenzi, 
\q1 iye anoparadza kudzidza kwevane njere, 
\q2 uye anokushandura kuti kuve upenzi, 
\q1  
\v 26 anozadzisa mashoko omuranda wake, 
\q2 uye anozadzisa zvakaprofitwa nenhume dzake, 
\b  
\q1 “anoti kuJerusarema, ‘Richagarwa,’ 
\q2 nokumaguta eJudha, ‘Achavakwa,’ 
\q2 nokumatongo awo, ‘Ndichaavandudza,’ 
\q1  
\v 27 iye anoti kumvura yakadzika, ‘Oma, 
\q2 uye ndichaomesa hova dzako,’ 
\q1  
\v 28 iye anoti pamusoro paSirasi, 
\q2 ‘Ndiye mufudzi wangu uye achaita zvose zvandinoda; 
\q2 iye achati pamusoro peJerusarema, “Ngarivakwezve,” 
\q2 uye pamusoro petemberi achati, “Nheyo dzayo ngadziteyiwe.” ’ 
\b  
\c 45  
\q1  
\v 1 “Zvanzi naJehovha kumuzodziwa wake, 
\q2 kuna Sirasi, ane ruoko rworudyi rwandakabata 
\q1 kuti akunde ndudzi pamberi pake, 
\q2 uye kuti atorere madzimambo zvombo zvavo, 
\q1 kuti ndizarure mikova pamberi pake, 
\q2 masuo agorega kupfigwa: 
\q1  
\v 2 Ndichaenda mberi kwako 
\q2 uye ndichaenzanisa makomo; 
\q1 ndichaputsa masuo endarira 
\q2 uye ndichacheka ndigopinda napamazariro esimbi. 
\q1  
\v 3 Ndichakupa pfuma yerima, 
\q2 upfumi hwakavigwa panzvimbo dzakavanda, 
\q1 kuti uzive kuti ndini Jehovha, Mwari waIsraeri, 
\q2 anokudana nezita rako. 
\q1  
\v 4 Nokuda kwaJakobho muranda wangu, 
\q2 nokwaIsraeri musanangurwa wangu, 
\q1 ndinokudana nezita rako, 
\q2 uye ndinoisa pamusoro pako zita rokukudzwa, 
\q2 kunyange iwe usingandizivi. 
\q1  
\v 5 Ndini Jehovha, uye hakuna mumwe; 
\q2 kunze kwangu ini hakuna Mwari. 
\q1 Ndichakusimbisa, 
\q2 kunyange usina kundiziva, 
\q1  
\v 6 kuti kubva kumabudazuva 
\q2 kusvikira kwarinovirira, 
\q1 vanhu vazive kuti hakuna mumwe kunze kwangu. 
\q2 Ndini Jehovha uye hakuna mumwe. 
\q1  
\v 7 Ndinoumba chiedza uye ndinosika rima, 
\q2 ndinoita rugare uye ndinosika njodzi; 
\q2 ini Jehovha, ndini ndinoita zvinhu izvi zvose. 
\b  
\q1  
\v 8 “Imi matenga kumusoro, nayisai kururama; 
\q2 makore ngaakudonhedze pasi. 
\q1 Nyika ngaizaruke kwazvo, 
\q2 ruponeso ngarutubuke, 
\q1 kururama ngakukure pamwe chete narwo; 
\q2 ini Jehovha, ndini ndakazvisika. 
\b  
\q1  
\v 9 “Ane nhamo uyo anokakavadzana noMuiti wake, 
\q2 iye anongova chaenga pakati pezvaenga pamusoro pevhu. 
\q1 Ko, ivhu ringati kumuumbi, 
\q2 ‘Uri kugadzirei?’ 
\q1 Ko, basa rako rinoti here, 
\q2 ‘Uyu haana maoko?’ 
\q1  
\v 10 Ane nhamo uyo anoti kuna baba vake, 
\q2 ‘Chiiko chamakabereka?’ 
\q1 kana kuna mai vake, 
\q2 ‘Chiiko chamakazvara?’ 
\b  
\q1  
\v 11 “Zvanzi naJehovha, 
\q2 iye Mutsvene waIsraeri, noMuiti wake: 
\q1 Pamusoro pezvinhu zvichauya, 
\q2 unondibvunza here pamusoro pavana vangu, 
\q2 kana kundirayira pamusoro pebasa ramaoko angu? 
\q1  
\v 12 Ndini ndakaita nyika 
\q2 uye ndikasika vanhu vendudzi dzose pamusoro payo. 
\q1 Maoko angu pachangu akatatamura matenga; 
\q2 ndakarayira hondo dzawo dzose dzenyeredzi. 
\q1  
\v 13 Ndichamutsa Sirasi mukururama kwangu: 
\q2 ndichaita kuti nzira dzake dzose dzirurame. 
\q1 Achavakazve guta rangu, 
\q2 uye achasunungura vatapwa vangu, 
\q1 asi pasina muripo kana mubayiro, 
\q2 ndizvo zvinotaura Jehovha Wamasimba Ose.” 
\p  
\v 14 Zvanzi naJehovha: 
\q1 “Zvibereko zveIjipiti nezvinoshambadzirwa zveEtiopia, 
\q2 navaSabhea varefu, 
\q1 vachauya kwauri 
\q2 uye vachava vako; 
\q1 vachatevera mushure mako, 
\q2 vachiuya kwauri vakasungwa nengetani. 
\q1 Vachapfugama pamberi pako 
\q2 uye vachakunyengetedza, vachiti, 
\q1 ‘Zvirokwazvo Mwari anewe, 
\q2 uye hakunazve mumwe; hakuna mumwe mwari.’ ” 
\b  
\q1  
\v 15 Zvechokwadi muri Mwari anozvivanza, 
\q2 imi Mwari noMuponesi waIsraeri. 
\q1  
\v 16 Vose vanoita zvifananidzo vachava nenyadzi uye vachanyadziswa, 
\q2 vachasvika pakunyadziswa pamwe chete. 
\q1  
\v 17 Asi Israeri achaponeswa naJehovha 
\q2 noruponeso rusingaperi; 
\q1 hamuchazombonyadziswi kana kuva nenyadzi, 
\q2 kusvikira kumakore asingaperi. 
\b  
\q1  
\v 18 Nokuti zvanzi naJehovha, 
\q1 iye akasika matenga, 
\q2 ndiye Mwari; 
\q1 iye akaumba uye akaita nyika, 
\q2 ndiye akaisimbisa; 
\q1 haana kuisikira kuti igare isina chinhu, 
\q2 asi akaiumba kuti igarwe, 
\q1 anoti: 
\q1 “Ndini Jehovha, 
\q2 uye hakuna mumwe. 
\q1  
\v 19 Handina kutaura ndiri pakavanda, 
\q2 ndichibva kumwe kunyika yerima; 
\q1 handina kuti kuvana vaJakobho, 
\q2 ‘Nditsvakei pasina.’ 
\q1 Ini, Jehovha ndinotaura chokwadi; 
\q2 ndinoparidza zvakarurama. 
\b  
\q1  
\v 20 “Unganai pamwe chete muuye; 
\q2 unganai, imi vatizi vanobva kune dzimwe ndudzi. 
\q1 Vose vanotakura mifananidzo yamatanda havazivi, 
\q2 vanonyengetera kuna vamwari vasingagoni kuponesa. 
\q1  
\v 21 Paridzai zvichauya, muzvibudise pachena: 
\q2 ngavarangane pamwe chete. 
\q1 Ndianiko akazvitaura kare, 
\q2 ndiani akazvireva kubva kare nakare? 
\q1 Handizini Jehovha here? 
\q2 Uye kunze kwangu ini hakuna Mwari, 
\q1 Mwari akarurama noMuponesi; 
\q2 hakuna mumwe asi ini. 
\b  
\q1  
\v 22 “Dzokerai kwandiri mugoponeswa, 
\q2 imi mose migumo yenyika; 
\q2 nokuti ndini Mwari, uye hakuna mumwe. 
\q1  
\v 23 Ndakapika neni pachangu, 
\q2 muromo wangu wakataura 
\q2 nokururama kwose shoko risingazoshandurwi: 
\q1 Mabvi ose achapfugama pamberi pangu; 
\q2 ndimi dzose dzichapika neni. 
\q1  
\v 24 Vachati pamusoro pangu, 
\q2 ‘Muna Jehovha chete ndimo muno kururama nesimba.’ ” 
\q1 Vose vakamutsamwira 
\q2 vachauya kwaari uye vachanyadziswa. 
\q1  
\v 25 Asi rudzi rwose rwaIsraeri 
\q2 ruchawanikwa rwakarurama muna Jehovha uye ruchafara. 
\c 46  
\s1 Vamwari veBhabhironi 
\q1  
\v 1 Bheri rinokotamira pasi, Nebho rinokotama; 
\q2 zvifananidzo zvavo zvinotakurwa nezvipfuwo zvinotakura mutoro. 
\q1 Zvifananidzo zvacho zvinotakurwa zvinorema, 
\q2 mutoro pazvipfuwo zvakaneta. 
\q1  
\v 2 Zvinokotama uye zvinokotamira pasi pamwe chete; 
\q2 zvisingagoni kurwira mutoro, 
\q2 izvo pachazvo zvinoenda kuutapwa. 
\q1  
\v 3 “Ndinzwei, imi imba yaJakobho, 
\q2 imi mose vakasara veimba yaIsraeri, 
\q1 imi vandakasimudzira kubvira muchiri mudumbu, 
\q2 uye ndikakutakurai kubvira pakuzvarwa kwenyu. 
\q1  
\v 4 Kunyange kusvikira pakuchembera kwenyu, 
\q2 bvudzi rachena, ndini iye, ndini ndichakururamisai. 
\q1 Ndakakuitai uye ndichakutakurai; 
\q2 ndichakuraramisai uye ndichakununurai. 
\b  
\q1  
\v 5 “Mungandienzanisa naaniko kana kunditi ndakaita saani? 
\q2 Mungandifananidza naaniko wandingaenzaniswa naye? 
\q1  
\v 6 Vamwe vanodurura goridhe kubva muhomwe dzavo, 
\q2 uye vanoyera sirivha pazviyero; 
\q1 vanotsvaka mupfuri kuti avaitire chimwari, 
\q2 vagopfugama kuti vachinamate. 
\q1  
\v 7 Vanochisimudzira pamapfudzi avo vagochitakura; 
\q2 vanochigadzika panzvimbo yacho, 
\q2 uye hecho chomira, hachigoni kufamba kuti chibvepo. 
\q1 Kunyange mumwe akadanidzira kwachiri, hachipinduri; 
\q2 hachigoni kumuponesa kubva pamatambudziko ake. 
\b  
\q1  
\v 8 “Rangarirai chinhu ichi, muchiise mupfungwa dzenyu, 
\q2 muise pamwoyo yenyu, imi vapanduki. 
\q1  
\v 9 Rangarirai zvinhu zvakare, zviya zvekare kare; 
\q2 ndini Mwari, uye hakuna mumwe; 
\q2 ndini Mwari, hakuna akafanana neni. 
\q1  
\v 10 Ndinozivisa magumo kubva pakutanga, 
\q2 kubva panguva yekare kare, izvo zvichiri kuuya. 
\q1 Ndinoti: Zvandakaronga zvichaitika, 
\q2 uye ndichaita zvose zvandinoda. 
\q1  
\v 11 Kubva kumabvazuva ndinodana gondo; 
\q2 kubva kunyika iri kure kure ndinodana munhu achazadzisa kuda kwangu. 
\q1 Zvandakareva ndichaita kuti zviitike; 
\q2 zvandakaronga, ndichazviita. 
\q1  
\v 12 Nditeererei, imi vane mwoyo yakasindimara, 
\q2 iyemi muri kure nokururama. 
\q1  
\v 13 Ndiri kuswededza pedyo kururama kwangu, 
\q2 hakusi kure; 
\q2 uye ruponeso rwangu haruzononotswi. 
\q1 Ndichapa ruponeso kuZioni, 
\q2 nokubwinya kwangu kuna Israeri. 
\c 47  
\s1 Kuwa kweBhabhironi 
\q1  
\v 1 “Buruka, ugare muguruva, 
\q2 iwe Mhandara yeBhabhironi; 
\q1 gara pasi usina chigaro choushe, 
\q2 iwe Mhandara yavaBhabhironi. 
\q1 Hauchazonzi uri munyoro 
\q2 kana munhu akapfava. 
\q1  
\v 2 Tora makuyo ukuye upfu; 
\q2 bvisa vhoiri rako. 
\q1 Fukura nguo dzako, 
\q2 makumbo ako aonekwe, uyambuke hova. 
\q1  
\v 3 Kushama kwako kuchava pachena, 
\q2 uye kunyadzwa kwako kuchaonekwa. 
\q1 Ndichatsiva; 
\q2 handizosiyi munhu.” 
\b  
\q1  
\v 4 Mudzikinuri wedu, Jehovha Wamasimba Ose ndiro zita rake; 
\q2 ndiye Mutsvene waIsraeri. 
\b  
\q1  
\v 5 Gara unyerere, enda murima, 
\q2 Mhandara yavaBhabhironi; 
\q1 hauchazonzi mambokadzi wenyika 
\q2 dzakasiyana-siyana. 
\q1  
\v 6 Ndakatsamwira vanhu vangu 
\q2 ndikasvibisa nhaka yangu; 
\q1 ndakavapa muruoko rwako, 
\q2 iwe ukasavanzwira ngoni. 
\q1 Kunyange vakakwegura 
\q2 wakavatakudza joko rinorema kwazvo. 
\q1  
\v 7 Wakati, “Ndicharamba 
\q2 ndiri mambokadzi nokusingaperi!” 
\q1 Asi hauna kufunga zvinhu izvi, 
\q2 kana kucherechedza zvaizogona kuitika. 
\b  
\q1  
\v 8 Naizvozvo zvino, chinzwa, 
\q2 iwe chisikwa chisingagutsikani, 
\q1 ugere zvakachengetedzeka, uchiti, 
\q2 mumwoyo mako, “Ndini, hakuna mumwe kunze kwangu. 
\q1 Handizovi chirikadzi, 
\q2 uye handizotambudziki nokurasikirwa navana.” 
\q1  
\v 9 Zviviri izvozvi zvichakuwira nechinguva chidiki diki, 
\q2 pazuva rimwe chete zvinoti: 
\q2 kufirwa navana nouchirikadzi. 
\q1 Zvichauya pamusoro pako nechiyero chizere, 
\q2 kunyange uine unʼanga hwako huzhinji, 
\q2 nouroyi hwako hwakawanda. 
\q1  
\v 10 Wakavimba nezvakaipa zvako uye wakati, 
\q2 “Hapana anondiona.” 
\q1 Uchenjeri hwako nezivo yako 
\q2 zvinokutsausa paunoti, mumwoyo mako, 
\q2 “Ndini, uye hakuna mumwe kunze kwangu.” 
\q1  
\v 11 Dambudziko richakuwira, 
\q2 uye haugoni kuzoziva kuti ungaritanda sei. 
\q1 Njodzi ichakuwira yausingagoni 
\q2 kubvisa nomuripo; 
\q1 pakarepo kuparadza kwausingagoni kuziva, 
\q2 kuchawira pamusoro pako. 
\b  
\q1  
\v 12 “Zvino, enderera hako mberi nouroyi hwako, 
\q2 uye nounʼanga hwako huzhinji, 
\q2 hwawakashandira kubva paudiki hwako. 
\q1 Zvichida uchabudirira, 
\q2 zvichida uchavhundutsira vamwe. 
\q1  
\v 13 Mazano ose awakagamuchira, akakunetesa chete! 
\q2 Vanhu vako vanocherechedza nyeredzi ngavauye mberi, 
\q1 avo vanotarira nyeredzi vachifembera mwedzi nomwedzi, 
\q2 ngavakuponese pane zviri kuuya pamusoro pako. 
\q1  
\v 14 Zvirokwazvo vakafanana namashanga; 
\q2 moto uchaapisa akapera. 
\q1 Havangatongogoni kuzvirwira, 
\q2 pasimba romurazvo womoto. 
\q1 Asi hapana mazimbe okuti munhu adziyirwe; 
\q2 hapana moto wokudziya ipapo. 
\q1  
\v 15 Izvozvi ndizvo chete zvavangakuitira, 
\q2 ava vawakashanda navo, 
\q2 uye ukafamba navo kubva paudiki hwako. 
\q1 Mumwe nomumwe wavo anoenderera mberi nokukanganisa kwake; 
\q2 hapana kana mumwe angakuponesa. 
\c 48  
\s1 Israeri ino mwoyo mukukutu 
\q1  
\v 1 “Inzwai izvi, imi imba yaJakobho, 
\q2 makatumidzwa zita raIsraeri, 
\q2 uye muchibva kurudzi rwaJudha, 
\q1 imi munoita mhiko muzita raJehovha, 
\q2 uye munodana kuna Mwari waIsraeri, 
\q2 asi musingaiti muzvokwadi kana mukururama, 
\q1  
\v 2 imi munozviti vagari vomuguta dzvene, 
\q2 muchivimba naMwari weIsraeri; 
\q2 Jehovha Wamasimba Ose ndiro zita rake: 
\q1  
\v 3 Ndakazivisa zvinhu zvakare, kare kare, 
\q2 muromo wangu wakazvireva uye ndakaita kuti zvizivikanwe; 
\q2 ipapo nokukurumidza ndakazviita, uye zvikaitika. 
\q1  
\v 4 Nokuti ndaiziva kuti mwoyo wako wakanga wakasindimara sei; 
\q2 nokuti mutsipa wako wakanga uri runda rwesimbi, 
\q2 huma yako yakanga iri ndarira. 
\q1  
\v 5 Naizvozvo ndakakuudza zvinhu izvi kare kare; 
\q2 zvisati zvaitika ndakazvizivisa kwauri, 
\q1 kuitira kuti urege kuzoti, 
\q2 ‘Zvifananidzo zvangu, 
\q2 ndizvo zvakazviita; mufananidzo wangu wedanda namwari wangu wesimbi ndizvo zvakarayira izvozvo.’ 
\q1  
\v 6 Wakazvinzwa zvinhu izvi; zvitarire zvose. 
\q2 Haungazvibvumi here? 
\b  
\q1 “Kubva zvino ndichakuzivisa zvinhu zvitsva, 
\q2 zvakavanzika zvausingazivi. 
\q1  
\v 7 Zvava kusikwa zvino, uye hakusi kare; 
\q2 hauna kumbozvinzwa zuva ranhasi risati rasvika. 
\q1 Saka haugoni kuti, 
\q2 ‘Hongu, ndaizviziva.’ 
\q1  
\v 8 Hauna kumbonzwa kana kunzwisisa; 
\q2 kubva kare nzeve yako yakanga isina kudziurwa. 
\q1 Ndinoziva kwazvo kuti uri munyengeri akadii; 
\q2 wakanzi mhandu kubva pakuzvarwa kwako. 
\q1  
\v 9 Nokuda kwezita rangu ndinononoka kutsamwa; 
\q2 nokuda kwokurumbidzwa kwangu ndinozvidzora pamusoro pako, 
\q2 kuti ndisakuparadza. 
\q1  
\v 10 Tarira, ndakakunatsa, kunyange zvisina kuita sesirivha; 
\q2 ndakakuedza muchoto chokutambudzika. 
\q1  
\v 11 Nokuda kwangu, nokuda kwangu, ndinoita izvi. 
\q2 Ko, ndingaregererei zita rangu richimhurwa? 
\q2 Handingapi kukudzwa kwangu kuno mumwe. 
\s1 Israeri inosunungurwa 
\q1  
\v 12 “Nditeerere, iwe Jakobho, 
\q2 Israeri, wandakadaidza; 
\q1 ndini iye: 
\q2 ndini wokutanga uye ndini wokupedzisira. 
\q1  
\v 13 Ruoko rwangu ndirwo rwakateya nheyo dzenyika, 
\q2 uye ruoko rwangu rworudyi rwakatambanudza matenga; 
\q1 pandinozvidana, 
\q2 zvose zvinomira pamwe chete. 
\b  
\q1  
\v 14 “Unganai pamwe chete, imi mose muteerere; 
\q2 Ndechipiko chimwe chezvifananidzo chakakuudzai kuti zvinhu izvi zvichaitika? 
\q1 Iye anodikanwa naJehovha 
\q2 achaita zvakarongwa naJehovha pamusoro peBhabhironi; 
\q2 ruoko rwake rucharwisa vaBhabhironi. 
\q1  
\v 15 Ini, iyeni ndataura; 
\q2 hongu, ndamudana. 
\q1 Ndichauya naye, 
\q2 uye achabudirira pane zvaanotumwa. 
\p  
\v 16 “Swederai kwandiri muteerere izvi: 
\q1 “Kubvira pachiziviso chokutanga handina kumbotaura muchivande; 
\q2 panguva yazvinoitika, ndinenge ndiripo.” 
\b  
\q1 Uye zvino Ishe Jehovha andituma 
\q2 noMweya wake. 
\b  
\q1  
\v 17 Zvanzi naJehovha 
\q2 Mudzikinuri wako, Mutsvene waIsraeri: 
\q1 “Ndini Jehovha Mwari wako, 
\q2 anokudzidzisa zvinokubatsira, 
\q2 anokutungamirira munzira yaunofanira kufamba nayo. 
\q1  
\v 18 Dai chete wakanga wateerera mirayiro yangu, 
\q2 rugare rwako rungadai rwakaita sorwizi, 
\q2 kururama kwako samafungu egungwa. 
\q1  
\v 19 Zvizvarwa zvako zvingadai zvakaita sejecha, 
\q2 navana vako vakaita setsanga dzejecha dzisingaverengeki; 
\q1 zita ravo haraimboparara 
\q2 kana kuparadzwa pamberi pangu.” 
\b  
\q1  
\v 20 Mudai muBhabhironi, 
\q2 tizai vaBhabhironi! 
\q1 Zivisai izvi nomufaro mukuru, 
\q2 uye muzviparidze. 
\q1 Zvitumirei kumagumo enyika; 
\q2 muti, “Jehovha adzikinura muranda wake Jakobho.” 
\q1  
\v 21 Havana kunzwa nyota paakavatungamirira mugwenga; 
\q2 akaita kuti mvura iyerere ichibva mudombo, achiitira ivo; 
\q1 akatsemura dombo 
\q2 mvura ikatubuka. 
\b  
\q1  
\v 22 “Vakaipa havana rugare,” ndizvo zvinotaura Jehovha. 
\c 49  
\s1 Muranda waJehovha 
\q1  
\v 1 Ndinzwei, imi zviwi; 
\q2 inzwai izvi, imi ndudzi dziri kure; 
\q1 Jehovha akandidana ndisati ndaberekwa; 
\q2 kubva pakuzvarwa kwangu akataura zita rangu. 
\q1  
\v 2 Akaita muromo wangu somunondo unopinza, 
\q2 akandiviga mumumvuri wechanza chake; 
\q1 akandiita museve unopenya, 
\q2 akandiviga mugomba rake. 
\q1  
\v 3 Akati kwandiri, “Ndiwe muranda wangu, 
\q2 Israeri, wandicharatidza kubwinya kwangu maari.” 
\q1  
\v 4 Asi ndakati, “Ndakashandira pasina, 
\q2 ndapedza simba rangu pane zvisina maturo uye pasina. 
\q1 Nyamba zvakandifanira ini zviri muruoko rwaJehovha, 
\q2 uye mubayiro wangu uri kuna Mwari.” 
\q1  
\v 5 Zvino Jehovha anoti, 
\q2 iye akandiumba ndiri muchizvaro kuti ndive muranda wake, 
\q1 kuti ndidzorere Jakobho kwaari 
\q2 uye kuti Israeri vaunganidzwezve kwaari, 
\q1 nokuti ndinokudzwa pamberi paJehovha, 
\q2 uye Mwari wangu ndiye anga ari simba rangu, 
\q1  
\v 6 iye anoti: 
\q1 “Chinhu chiduku kwazvo kuti iwe uve muranda wangu, 
\q2 anomutsazve marudzi aJakobho 
\q2 uye achadzosa avo vaIsraeri vandakachengeta. 
\q1 Uyezve ndichakuita chiedza chevedzimwe ndudzi, 
\q2 kuti uuyise ruponeso rwangu kumigumo yenyika.” 
\b  
\q1  
\v 7 Zvanzi naJehovha, 
\q2 Mudzikinuri noMutsvene waIsraeri, 
\q1 kuna iye akanga azvidzwa uye akasemwa norudzi, 
\q2 kumuranda wavatongi: 
\q1 “Madzimambo achakuona agosimuka, 
\q2 machinda achaona agokotamira pasi, 
\q1 nokuda kwaJehovha akatendeka, 
\q2 Mutsvene waIsraeri, akakusarudza.” 
\s1 Israeri Inomutsiridzwa 
\p  
\v 8 Zvanzi naJehovha: 
\q1 “Munguva yangu yakafanira, ndichakupindura, 
\q2 uye pazuva roruponeso ndichakubatsira; 
\q1 ndichakuchengeta uye ndichakuita 
\q2 kuti uve sungano yavanhu, 
\q1 kuti uvandudze nyika 
\q2 uye uvagarise patsva nhaka yakaparara, 
\q1  
\v 9 kuti uti kunhapwa, ‘Budai,’ 
\q2 nokuna avo vari murima, ‘Uyai muchiedza!’ 
\b  
\q1 “Vachadya zvokudya parutivi rwenzira, 
\q2 uye vachawana mafuro pazvikomo zvose zvisina zvibereko. 
\q1  
\v 10 Havangavi nenzara kana nyota, 
\q2 havangabayiwi nokupisa kwegwenga, kana nokupisa kwezuva. 
\q1 Iye anovanzwira tsitsi achavatungamirira, 
\q2 uye achavafambisa napazvitubu zvemvura. 
\q1  
\v 11 Ndichashandura makomo angu ose kuti ave migwagwa, 
\q2 uye migwagwa yangu mikuru ichasimudzirwa. 
\q1  
\v 12 Tarirai vachauya vachibva kure: 
\q2 vamwe vachibva nechokumusoro, vamwe nechokumavirazuva, 
\q2 vamwe nokurutivi rweAsiwani.” 
\b  
\q1  
\v 13 Imbai, imi matenga, 
\q2 pembera iwe nyika; 
\q2 imbai rwiyo imi makomo! 
\q1 Nokuti Jehovha anonyaradza vanhu vake, 
\q2 uye achava netsitsi navanhu vake vanotambudzika. 
\b  
\q1  
\v 14 Asi Zioni rakati, “Jehovha akandisiya, 
\q2 Jehovha akandikanganwa.” 
\b  
\q1  
\v 15 “Ko, mai vangakanganwa mucheche anonwa ari pachipfuva chavo, 
\q2 uye vangasanzwira tsitsi mwana wavakazvara here? 
\q1 Kunyange hazvo ivo vakakanganwa, 
\q2 ini handizokukanganwi! 
\q1  
\v 16 Tarira, ndakakunyora pazvanza zvamaoko angu; 
\q2 madziro ako anogara ari mberi kwangu. 
\q1  
\v 17 Vanakomana vako vanokurumidza kudzoka shure, 
\q2 uye vose vaikuparadza vachabva kwauri. 
\q1  
\v 18 Simudza meso ako utarise kwose kwose; 
\q2 vanakomana vako vose vanoungana vachiuya kwauri. 
\q1 Zvirokwazvo noupenyu hwangu,” 
\q2 ndizvo zvinotaura Jehovha, “uchavafuka vose sezvishongo: 
\q2 uchavapfeka, somwenga. 
\b  
\q1  
\v 19 “Kunyange wakaparadzwa ukaitwa dongo, 
\q2 uye nyika yako yakasiyiwa yava dongo, 
\q1 zvino vanhu vako havachakwani mauri, 
\q2 uye vose vaikumedza vachava kure. 
\q1  
\v 20 Vana vakaberekwa panguva yokufirwa kwako 
\q2 vachatizve munzeve dzako, 
\q1 ‘Nzvimbo iyi yava diki kwatiri: 
\q2 tipeiwo nzvimbo yakatambanuka yatingagara.’ 
\q1  
\v 21 Ipapo uchati mumwoyo mako, 
\q2 ‘Ndianiko akandiberekera ava? 
\q1 Ndakanga ndafirwa uye ndisina mwana; 
\q2 ndakanga ndadzingwa uye ndarambwa. 
\q2 Ndianiko akarera ava? 
\q1 Ndakasiyiwa ndiri ndoga, 
\q2 asi ava, vabvepiko?’ ” 
\p  
\v 22 Zvanzi naIshe Jehovha, 
\q1 “Tarira ndichasimudza ruoko rwangu kune veDzimwe Ndudzi, 
\q2 ndichasimudzira mureza wangu kumarudzi; 
\q1 vachauya navanakomana vako vari mumaoko avo, 
\q2 uye vachatakura vanasikana vako pamapfudzi avo. 
\q1  
\v 23 Madzimambo achava madzibaba anokurerai, 
\q2 uye vanamambokadzi vavo vachava vanamai vanokurerai. 
\q1 Vachakupfugamirai uso hwavo hwakatsikitsira pasi, 
\q2 vachananzva guruva patsoka dzenyu. 
\q1 Ipapo muchaziva kuti ndini Jehovha; 
\q2 vanovimba neni havachazonyadziswi.” 
\b  
\q1  
\v 24 Ko, mhare ingapambwa here, 
\q2 kana vatapwa vanganunurwa kubva kune anotyisa here? 
\p  
\v 25 Asi zvanzi naJehovha, 
\q1 “Hongu vatapwa vachatorwa kubva kumhare, 
\q2 uye zvakapambwa kubva kune anotyisa; 
\q1 ndicharwa nevanorwa newe, 
\q2 uye vana vako ndichavaponesa. 
\q1  
\v 26 Ndichaita kuti vamanikidzi vako vadye nyama yavo; 
\q2 vachadhakwa neropa ravo, sevadhakwa newaini. 
\q1 Ipapo vanhu vose vachaziva kuti ini Jehovha, 
\q2 ndini Muponesi wako, 
\q2 Mudzikinuri wako, Wamasimba Ose waJakobho.” 
\c 50  
\s1 Chivi chaIsraeri noKuteerera kwoMuranda 
\p  
\v 1 Zvanzi naJehovha: 
\q1 “Ko, rugwaro rwokurambwa 
\q2 kwamai venyu rwuripiko rwandakavadzinga narwo? 
\q1 Uye ndevapiko vandakakwereta 
\q2 ndikazokutengesai kwavari? 
\q1 Makatengeswa nokuda kwezvivi zvenyu; 
\q2 mai venyu vakadzingwa nokuda kwokudarika kwenyu. 
\q1  
\v 2 Sei ndakashaya munhu, pandakauya? 
\q2 Sei pasina akapindura pandakadana? 
\q1 Ko, ruoko rwangu rwakanga rwakapfupika here kuti ndikudzikinurei? 
\q2 Handina simba rokukununurai here? 
\q1 Nokungorayira chete ndinopwisa gungwa; 
\q2 ndinoshandura nzizi dzikava gwenga; 
\q1 hove dzadzo dzinoora nokushayiwa mvura, 
\q2 uye dzinofa nenyota. 
\q1  
\v 3 Ndinoshongedza denga nerima 
\q2 uye ndinoita masaga chifukidzo charo.” 
\b  
\q1  
\v 4 Ishe Jehovha akandipa rurimi rwakadzidziswa, 
\q2 kuziva shoko rinosimbisa vakarukutika. 
\q1 Anondimutsa mangwanani namangwanani, 
\q2 anomutsa nzeve yangu kuti iteerere somunhu anodzidziswa. 
\q1  
\v 5 Ishe Jehovha akazarura nzeve dzangu, 
\q2 uye handina kumumukira; 
\q2 handina kudzokera shure. 
\q1  
\v 6 Ndakapa musana wangu kuna avo vaindirova, 
\q2 namatama angu kuna avo vakadzura ndebvu dzangu; 
\q1 Handina kuvanza chiso changu 
\q2 pakusekwa nokupfirwa mate. 
\q1  
\v 7 Nokuti Ishe Jehovha anondibatsira, 
\q2 handizonyadziswi. 
\q1 Naizvozvo ndakaita kuti chiso changu chive sebwe romusarasara, 
\q2 uye ndinoziva kuti handizonyadziswi. 
\q1  
\v 8 Iye anondiruramisira ari pedyo. 
\q2 Ndianiko zvino achandipa mhosva? 
\q2 Ngatitarisanei! 
\q1 Ndianiko mupomeri wangu? 
\q2 Ngaanangane neni! 
\q1  
\v 9 Ndiye Ishe Jehovha anondibatsira. 
\q2 Ndianiko achandipa mhosva? 
\q1 Vose vachasakara senguo; 
\q2 vachadyiwa nezvipfuno. 
\b  
\q1  
\v 10 Ndiani pakati penyu anotya Jehovha, 
\q2 uye anoteerera shoko romuranda wake? 
\q1 Ngaafambe murima, 
\q2 iye asina chiedza, 
\q1 ngaavimbe nezita raJehovha 
\q2 uye avimbe naMwari wake. 
\q1  
\v 11 Asi zvino, imi mose munotungidza moto 
\q2 muchava nemwenje inopfuta, 
\q1 endai, mufambe muchiedza chomoto 
\q2 wenyu nechemwenje yamakabatidza. 
\q1 Izvi ndizvo zvamuchagamuchira kubva paruoko rwangu: 
\q2 Muchavata pasi mukurwadziwa. 
\c 51  
\s1 Ruponeso Rwokusingaperi rweZioni 
\q1  
\v 1 Nditeererei, imi munotevera kururama 
\q2 uye munotsvaka Jehovha: 
\q1 Tarirai kudombo ramakabviswa pariri 
\q2 naparuware pamakacherwa; 
\q1  
\v 2 tarirai kuna Abhurahama, baba venyu, 
\q2 nokuna Sara, akakuberekai. 
\q1 Pandakamudana akanga achingova mumwe chete, 
\q2 ndikamuropafadza ndikamuita vazhinji. 
\q1  
\v 3 Zvirokwazvo Jehovha achanyaradza Zioni, 
\q2 uye achatarira netsitsi pamusoro pamatongo aro ose; 
\q1 achaita magwenga aro kuti afanane neEdheni, 
\q2 marenje aro achafanana nebindu raJehovha. 
\q1 Kupembera nomufaro zvichawanikwa mariri, 
\q2 kuvonga nenzwi rokuimba. 
\b  
\q1  
\v 4 “Nditeererei, imi vanhu vangu; 
\q2 ndinzwei imi rudzi rwangu: 
\q1 Ndichakupai murayiro; 
\q2 kururamisira kwangu kuchava chiedza kundudzi. 
\q1  
\v 5 Kururama kwangu kwoswedera pedyo nokukurumidza, 
\q2 ruponeso rwangu rwuri munzira, 
\q2 uye ruoko rwangu ruchauyisa kururamisira kundudzi. 
\q1 Zviwi zvichatarira kwandiri 
\q2 uye zvichamirira ruoko rwangu netariro. 
\q1  
\v 6 Simudzirai meso enyu kumatenga, 
\q2 tarirai pasi panyika; 
\q1 matenga achanyangarika soutsi, 
\q2 nyika ichasakara senguo, 
\q2 uye vanogaramo vachafa senhunzi. 
\q1 Asi ruponeso rwangu ruchagara nokusingaperi, 
\q2 kururama kwangu hakuzombogumi. 
\b  
\q1  
\v 7 “Ndinzwei, imi munoziva zvakarurama, 
\q2 imi vanhu vane murayiro wangu mumwoyo yenyu: 
\q1 Musatya kuzvidza kwavanhu, 
\q2 uye musavhundutswa nokutuka kwavo. 
\q1  
\v 8 Nokuti chipfuno chichavadya senguo; 
\q2 honye ichavadya sewuru. 
\q1 Asi kururama kwangu kuchagara nokusingaperi, 
\q2 ruponeso rwangu kuzvizvarwa zvose.” 
\b  
\q1  
\v 9 Muka, muka! Zvishongedze nesimba, 
\q2 iwe ruoko rwaJehovha; 
\q1 muka, sepamazuva akare, 
\q2 sepazvizvarwa zvakare. 
\q1 Ko, hausiwe wakagura-gura Rahabhi, 
\q2 ukabaya chikara chiya here? 
\q1  
\v 10 Hausiwe wakaomesa gungwa here, 
\q2 iyo mvura yokwakadzika zvikuru, 
\q1 ukaita mugwagwa makadzika megungwa 
\q2 kuitira kuti vakadzikinurwa vayambuke? 
\q1  
\v 11 Vakasunungurwa vaJehovha vachadzoka. 
\q2 Vachapinda muZioni vachiimba; 
\q2 mufaro usingaperi uchava korona pamisoro yavo. 
\q1 Mufaro nokupembera zvichafashukira, 
\q2 uye kusuwa nokukahadzika zvichatiza. 
\b  
\q1  
\v 12 “Ini, iyeni, ndini iye anokunyaradzai. 
\q2 Ndiwe aniko unotya vanhu vanofa, 
\q2 vanakomana vavanhu, ivo uswa zvahwo, 
\q1  
\v 13 kuti ukanganwe Jehovha Muiti wako, 
\q2 akatatamura matenga, 
\q2 akateya nheyo dzenyika, 
\q1 kuti ugare uchitya mazuva ose 
\q2 nokuda kwehasha dzomumanikidzi, 
\q2 uyo akarerekera kukuparadza? 
\q1 Ko, hasha dzomumanikidzi dziripi? 
\q2  
\v 14 Vasungwa vakatapwa vachakurumidza kusunungurwa; 
\q1 havazofiri mumakomba avo, 
\q2 kana kuzoshayiwa chingwa. 
\q1  
\v 15 Nokuti ndini Jehovha Mwari wako, 
\q2 anomutsa gungwa kuti mafungu aro atinhire, 
\q2 Jehovha Wamasimba Ose ndiro zita rake. 
\q1  
\v 16 Ndakaisa mashoko angu mumuromo mako, 
\q2 ndikakufukidza nomumvuri woruoko rwangu, 
\q1 iyeni ndakagadzika matenga panzvimbo yawo, 
\q2 iyeni ndakateya nheyo dzenyika, 
\q2 uye ndinoti kuZioni, ‘Muri vanhu vangu.’ ” 
\s1 Mukombe weHasha dzaJehovha 
\q1  
\v 17 Muka, muka! Simuka, 
\q2 iwe Jerusarema, 
\q1 iwe wakanwa kubva muruoko rwaJehovha, 
\q2 mukombe wehasha dzake, 
\q1 iwe wakasveta kusvikira wapera kuti tsvai, 
\q2 iwo mukombe unoita kuti vanhu vadzedzereke. 
\q1  
\v 18 Pavanakomana vose 
\q2 vaakabereka pakanga pasina anomutungamirira; 
\q1 pavanakomana vose vaakarera 
\q2 pakanga pasina aimusesedza noruoko rwake. 
\q1  
\v 19 Njodzi mbiri idzi dzauya pamusoro pako, 
\q2 ndianiko angakunyaradza? Dzinoti: 
\q1 kuva dongo nokuparadzwa, nzara nomunondo; 
\q2 ndianiko anogona kukunyaradza? 
\q1  
\v 20 Vanakomana vako vaziya; 
\q2 vanovata panotangira migwagwa, 
\q2 kufanana nemhara yabatwa mumumbure. 
\q1 Vakazadzwa nehasha dzaJehovha 
\q2 nokutuka kwaMwari wako. 
\b  
\q1  
\v 21 Naizvozvo inzwa izvi, 
\q2 iwe munhu wokutambudzika, wakadhakiswa asi kwete newaini. 
\q1  
\v 22 Zvanzi naIshe Jehovha Mwari wako, 
\q2 anodzivirira vanhu vake, 
\q1 “Tarira, ndabvisa muruoko rwako mukombe wakakuita kuti udzedzereke; 
\q2 kubva pamukombe uyo, 
\q1 iwo mukombe wehasha dzangu, 
\q2 hauchazounwizve. 
\q1  
\v 23 Ndichauisa mumaoko avatambudzi vako, 
\q2 ivo vanoti kwauri, 
\q2 ‘Zvambarara pasi kuti tifambe napamusoro pako.’ 
\q1 Iwe wakaita kuti musana wako uve sapasi, 
\q2 kufanana nomugwagwa unofambwa nawo.” 
\c 52  
\q1  
\v 1 Muka, muka iwe Zioni, 
\q2 zvifukidze nesimba. 
\q1 Fuka nguo dzako dzakanakisa, 
\q2 iwe Jerusarema, guta dzvene. 
\q1 Vasina kudzingiswa navakasvibiswa 
\q2 havachapindizve mauri. 
\q1  
\v 2 Zunza guruva rako: simuka, 
\q2 ugare paushe, iwe Jerusarema. 
\q1 Zvisunungure pangetani dziri pamutsipa wako, 
\q2 iwe nhapwa, Mwanasikana weZioni. 
\p  
\v 3 Nokuti zvanzi naJehovha, 
\q1 “Wakatengeswa pasina mutengo, 
\q2 uye uchadzikinurwa pasina mari.” 
\p  
\v 4 Nokuti zvanzi naIshe Jehovha, 
\q1 “Pakutanga vanhu vangu vakaenda kuIjipiti kundogarako; 
\q2 iye zvino Asiria inovamanikidza. 
\p  
\v 5 “Uye zvino ndinei pano?” ndizvo zvinotaura Jehovha. 
\q1 “Nokuti vanhu vangu vakabviswa pasina, 
\q2 uye avo vanovatonga vanovaseka,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1 “Uye zuva rose 
\q2 zita rangu rinogara richimhurwa. 
\q1  
\v 6 Naizvozvo vanhu vangu vachaziva zita rangu; 
\q2 naizvozvo pazuva iro vachaziva 
\q1 kuti ndini ndakazvitaura. 
\q2 Hongu, ndini iye.” 
\b  
\q1  
\v 7 Dzakanaka sei pamusoro pamakomo 
\q2 tsoka dzavanouya namashoko akanaka, 
\q1 vanoparidza rugare, 
\q2 vanouya namashoko akanaka, 
\q2 vanoparidza ruponeso, 
\q1 vanoti kuZioni, 
\q2 “Mwari wako anotonga!” 
\q1  
\v 8 Chinzwa! Nharirire dzako dzinodanidzira namanzwi adzo; 
\q2 vanopembera nomufaro pamwe chete. 
\q1 Panodzokera Jehovha kuZioni, 
\q2 vachazviona nameso avo pachavo. 
\q1  
\v 9 Pururudzai muimbe nziyo dzomufaro pamwe chete, 
\q2 imi matongo eJerusarema, 
\q1 nokuti Jehovha anyaradza vanhu vake, 
\q2 akadzikinura Jerusarema. 
\q1  
\v 10 Jehovha acharatidza ruoko rwake rutsvene 
\q2 pamberi pendudzi dzose, 
\q1 uye magumo ose enyika achaona 
\q2 ruponeso rwaMwari wedu. 
\b  
\q1  
\v 11 Ibvai, ibvai, budai ikoko! 
\q2 Musabata chinhu chine tsvina! 
\q1 Budaimo mugova vakachena, 
\q2 imi munotakura midziyo yaJehovha. 
\q1  
\v 12 Asi hamungazobudi nokukurumidza 
\q2 kana kuenda muchitiza; 
\q1 nokuti Jehovha achakutungamirirai, 
\q2 Mwari waIsraeri achakurindai mushure. 
\s1 Kutambudzika noKukudzwa kwoMuranda 
\q1  
\v 13 Tarirai muranda wangu achaita nouchenjeri; 
\q2 achasimudzirwa uye achakwidzwa pamusoro, uye achakudzwa kwazvo. 
\q1  
\v 14 Sezvo vazhinji vakashamiswa naye, 
\q2 chiso chake chakanga chakakuvadzwa zvikuru, kupfuura chomunhu upi zvake, 
\q2 uye chimiro chake chakanga chakanganiswa, kupfuura kuratidzika kwomunhu, 
\q1  
\v 15 saka iye achasasa ndudzi zhinji, 
\q2 uye madzimambo achafumbira miromo nokuda kwake. 
\q1 Nokuti zvavakanga vasina kuudzwa, vachazviona, 
\q2 uye zvavasina kumbonzwa, vachazvinzwisisa. 
\c 53  
\q1  
\v 1 Ndianiko akatenda zvatakaparidza, 
\q2 uye ruoko rwaJehovha rwakaratidzwa kuna aniko? 
\q1  
\v 2 Akamera pamberi pake sebukira nyoro, 
\q2 uye somudzi pavhu rakaoma. 
\q1 Akanga asina runako kana chimiro choumambo kuti atikwezve kwaari, 
\q2 hapana chatingada pakuratidzika kwake. 
\q1  
\v 3 Akazvidzwa uye akarambwa navanhu, murume wokusuwa, 
\q2 uye anoziva kutambudzika. 
\q1 Somunhu anovanzirwa chiso navanhu, akazvidzwa, 
\q2 uye isu hatina kumukudza. 
\q1  
\v 4 Zvirokwazvo akatakura matenda edu, 
\q2 uye akatakura kurwadziswa kwedu; 
\q1 asi isu takafunga kuti akarohwa naMwari, 
\q2 akarohwa naye uye akarwadziswa. 
\q1  
\v 5 Asi akabayiwa nokuda kwokudarika kwedu, 
\q2 akakuvadzwa nokuda kwezvakaipa zvedu; 
\q1 kurohwa kwakativigira rugare kwaiva pamusoro pake, 
\q2 uye namavanga ake takaporeswa. 
\q1  
\v 6 Isu tose takanga takarasika samakwai, 
\q2 mumwe nomumwe nenzira yake, 
\q1 asi Jehovha akaisa pamusoro pake 
\q2 kuipa kwedu tose. 
\b  
\q1  
\v 7 Akamanikidzwa uye akarwadziswa, 
\q2 asi haana kushamisa muromo wake; 
\q1 akatungamirirwa segwayana riri kundobayiwa, 
\q2 uye sokunyarara kwegwai pamberi pomuveuri waro, 
\q2 saizvozvo haana kushamisa muromo wake. 
\q1  
\v 8 Akabviswa achimanikidzwa uye akatongwa. 
\q2 Uye ndianiko angataura rudzi rwake? 
\q1 Nokuti akagurwa kubva panyika yavapenyu, 
\q2 nokuda kwokudarika kwavanhu vangu, akarohwa. 
\q1  
\v 9 Akapiwa guva rake pakati pavatadzi, 
\q2 uye akava navapfumi pakufa kwake, 
\q1 kunyange akanga asina kuita zvechisimba, 
\q2 uye kunyengera kusina kuwanikwa mumuromo make. 
\b  
\q1  
\v 10 Asi kwakanga kuri kuda kwaJehovha kuti amukuvadze uye aite kuti atambudzike, 
\q2 uye kunyange zvazvo Jehovha akaita kuti upenyu hwake huve chipiriso chezvivi, 
\q1 achaona zvibereko zvake uye achawedzera mazuva ake, 
\q2 uye kuda kwaJehovha kuchabudirira muruoko rwake. 
\q1  
\v 11 Shure kwokutambudzika kwomweya wake, 
\q2 achaona chiedza choupenyu uye achagutsikana; 
\q1 nokuziva kwake, muranda wangu akarurama acharuramisira vazhinji, 
\q2 uye achatakura kuipa kwavo. 
\q1  
\v 12 Naizvozvo ndichamupa mugove pakati pavakuru vakuru, 
\q2 uye achagoverana zvakapambwa navane simba, 
\q1 nokuti akadurura upenyu hwake kusvika parufu, 
\q2 akaverengwa pamwe chete navadariki. 
\q1 Nokuti akatakura chivi chavazhinji, 
\q2 akanyengeterera vadariki. 
\c 54  
\s1 Kubwinya kuchaita Zioni 
\q1  
\v 1 “Imba, iwe mukadzi asina mwana, 
\q2 iwe usina kumbobereka mwana 
\q1 pururudza uimbe rwiyo, pembera nomufaro, 
\q2 iwe usina kumborwadziwa; 
\q1 nokuti vana vomukadzi akasiyiwa ari oga vazhinji kupfuura 
\q2 veane murume,” 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1  
\v 2 Wedzera nzvimbo yetende rako, 
\q2 tambanudza micheka yetende rako ifare, 
\q2 usarega kuita izvozvo; 
\q1 rebesa tambo dzako, 
\q2 simbisa mbambo dzako. 
\q1  
\v 3 Nokuti uchapararira kurudyi nokuruboshwe; 
\q2 vana vako vachatorera dzimwe ndudzi 
\q2 uye vachagara mumatongo amaguta avo. 
\p  
\v 4 “Usatya hako: haunganyadziswi. 
\q2 Usatya kunyadziswa; haunganinipiswi. 
\q1 Uchakanganwa nyadzi dzapaudiki hwako, 
\q2 uye hauzorangaririzve kunyadzisa kwouchirikadzi hwako. 
\q1  
\v 5 Nokuti Muiti wako ndiye murume wako, 
\q2 Jehovha Wamasimba Ose ndiro zita rake, 
\q1 Mutsvene waIsraeri ndiye Mudzikinuri wako; 
\q2 anonzi Mwari wenyika yose. 
\q1  
\v 6 Jehovha achakudanazve 
\q2 sokunge wanga uri mukadzi akasiyiwa, uye anotambudzika pamweya, 
\q1 mukadzi akawanikwa achiri mudiki, 
\q2 pedzezvo ndokurambwa,” ndizvo zvinotaura Mwari wako. 
\q1  
\v 7 “Kwechinguvana ndakakusiya, 
\q2 asi netsitsi huru ndikakudzosazve. 
\q1  
\v 8 Ndichisundwa nehasha 
\q2 ndakavanza chiso changu kwauri kwechinguva, 
\q1 asi nounyoro husingaperi 
\q2 ndichava netsitsi, pamusoro pako,” 
\q2 ndizvo zvinotaura Jehovha Mudzikinuri wako. 
\b  
\q1  
\v 9 “Kwandiri izvi zvakafanana namazuva aNoa, 
\q2 pandakapika kuti mvura zhinji yaNoa haizofukidzizve nyika. 
\q1 Naizvozvo zvino ndapika kuti ndirege kukutsamwira, 
\q2 kana kukutukazve. 
\q1  
\v 10 Kunyange makomo akazungunuswa, 
\q2 uye zvikomo zvikabviswa, 
\q1 rudo rwangu rusingaperi harungazungunuswi, 
\q2 uye sungano yangu yorugare haingabviswi,” 
\q2 ndizvo zvinotaura Jehovha anokunzwira tsitsi. 
\b  
\q1  
\v 11 “Haiwa, iwe guta rokutambudzika wakarohwa nedutu ukasanyaradzwa, 
\q2 ndichakuvaka namabwe ana mavara, 
\q2 nheyo dzako namabwe esafire. 
\q1  
\v 12 Ndichakuitira zviruvi zvamabwe matsvuku, 
\q2 masuo amabwe anovaima, 
\q2 uye masvingo ako ose amabwe anokosha. 
\q1  
\v 13 Vanakomana venyu vose vachadzidziswa naJehovha, 
\q2 uye rugare rwavana venyu ruchava rukuru. 
\q1  
\v 14 Muchasimbiswa mukururama: 
\q1 Kumanikidzwa kuchava kure nemi: 
\q2 hapana chamuchazotya. 
\q1 Kutya kuchava kure nemi; 
\q2 hakuchazosviki pedyo nemi. 
\q1  
\v 15 Kana mumwe akakurwisa, handisini ndinenge ndazviita; 
\q2 ani naani anokurwisa achazvipira kwauri. 
\b  
\q1  
\v 16 “Tarira, ndini ndakasika mupfuri wesimbi 
\q2 anopfutidza mazimbe moto ugonganduma, 
\q2 uye anopfura munondo wakakodzera pabasa rawo. 
\q1 Uye ndini ndakasika muparadzi kuti aparadze; 
\q2  
\v 17 hapana munondo ucharwisana newe ukakunda, 
\q2 uye uchakonesa rurimi rumwe norumwe runokupomera mhosva. 
\q1 Iyi ndiyo nhaka yavaranda vaJehovha, 
\q2 uye uku ndiko kururamisirwa kwavo kunobva kwandiri,” 
\q4 ndizvo zvinotaura Jehovha. 
\c 55  
\s1 Kukokwa kwaVane Nyota 
\q1  
\v 1 “Uyai imi mose mune nyota, 
\q2 uyai kumvura zhinji; 
\q1 nemi musina mari, uyai, 
\q2 mutenge uye mudye! 
\q1 Uyai mutenge waini nomukaka 
\q2 pasina mari uye pasina mutengo. 
\q1  
\v 2 Ko, munopedzerei mari pazvinhu zvisati zviri zvokudya, 
\q2 nesimba renyu pazvinhu zvisingagutsi? 
\q1 Teererai, nditeererei mugodya zvakanaka, 
\q2 uye mweya yenyu ichafarira zvakakora zvezvakanaka. 
\q1  
\v 3 Rerekai nzeve yenyu muuye kwandiri; 
\q2 ndinzwei kuti mweya yenyu irarame. 
\q1 Ndichaita sungano isingaperi nemi, 
\q2 iko kutendeka kworudo rwangu rwakavimbiswa kuna Dhavhidhi. 
\q1  
\v 4 Tarirai, ndakamuita chapupu kumarudzi, 
\q2 mutungamiri nomukuru wamarudzi. 
\q1  
\v 5 Zvirokwazvo uchakoka ndudzi dzausina kumboziva, 
\q2 uye ndudzi dzisingakuzive dzichamhanyira kwauri, 
\q1 nokuda kwaJehovha Mwari wako, 
\q2 Mutsvene waIsraeri, 
\q2 nokuti iye akakufukidza nokubwinya.” 
\q1  
\v 6 Tsvakai Jehovha achawanikwa: 
\q2 danai kwaari achiri pedyo. 
\q1  
\v 7 Akashata ngaasiye nzira yake, 
\q2 nomunhu akaipa mirangariro yake. 
\q1 Ngaadzokere kuna Jehovha, uye iye achamunzwira ngoni, 
\q2 nokuna Mwari wedu, nokuti achakanganwirwa zvikuru. 
\b  
\q1  
\v 8 “Nokuti ndangariro dzangu hadzizi ndangariro dzenyu, 
\q2 uye nzira dzenyu hadzizi nzira dzangu,” 
\q4 ndizvo zvinotaura Jehovha. 
\q1  
\v 9 “Sokukwirira kwakaita matenga kupfuura nyika, 
\q2 saizvozvo nzira dzangu dzakakwirira kupinda dzenyu, 
\q2 nendangariro dzangu kupfuura ndangariro dzenyu. 
\q1  
\v 10 Sezvinoita mvura nechando 
\q2 zvinoburuka kubva kudenga, 
\q1 zvisingadzokeriko 
\q2 zvisina kudiridza nyika 
\q1 nokuita kuti ibukire uye ibereke zvakawanda, 
\q2 kuitira kuti iberekere mudyari wembeu, uye ipe chingwa kune anodya, 
\q1  
\v 11 saizvozvo neshoko rangu rinobuda mumuromo mangu: 
\q2 Haringadzokeri kwandiri risina chinhu, 
\q1 asi richaita zvinondifadza, 
\q2 uye richaita zvandakarituma. 
\q1  
\v 12 Muchabuda nomufaro, 
\q2 uye muchafambiswa murugare; 
\q1 makomo nezvikomo zvichapururudza 
\q2 uye zvichaimba rwiyo pamberi penyu, 
\q1 uye miti yose yeminda 
\q2 ichauchira maoko ayo. 
\q1  
\v 13 Pachinzvimbo chomunzwa pachamera muti womupaini, 
\q2 pachinzvimbo chorukato pachamera mumite. 
\q1 Izvi zvichava mukurumbira waJehovha, 
\q2 nechiratidzo chokusingaperi, 
\q2 chisingazoparadzwi.” 
\c 56  
\s1 Ruponeso rwaVamwe 
\p  
\v 1 Zvanzi naJehovha: 
\q1 “Chengetedzai kururamisira 
\q2 mugoita zvakanaka, 
\q1 nokuti ruponeso rwangu rwava pedyo, 
\q2 uye kururama kwangu kuchakurumidza kuratidzwa. 
\q1  
\v 2 Akaropafadzwa munhu anoita izvi, 
\q2 munhu anozvibatisisa, 
\q1 anochengeta Sabata asingarisvibisi, 
\q2 uye anodzivisa ruoko rwake kuita chinhu chakaipa.” 
\b  
\q1  
\v 3 Mutorwa akanamatira kuna Jehovha ngaarege kuti, 
\q2 “Zvirokwazvo Jehovha achandiparadzanisa navanhu vake.” 
\q1 Uye nomuyunaki ngaarege kugununʼuna achiti, 
\q2 “Ndinongova zvangu muti wakaoma.” 
\p  
\v 4 Nokuti zvanzi naJehovha: 
\q1 “Kuvayunaki vanochengeta maSabata angu, 
\q2 vanosarudza zvinondifadza, 
\q2 uye vanobatirira pasungano yangu, 
\q1  
\v 5 kwavari ndichapa, mukati metemberi yangu namasvingo ayo, 
\q2 chirangaridzo nezita riri nani kupfuura vanakomana navanasikana; 
\q2 ndichavapa zita risingaperi, risingazoparadzwi. 
\q1  
\v 6 Uye vatorwa vakazvipira kuna Jehovha 
\q2 kuti vamushumire, 
\q1 kuti vade zita raJehovha, 
\q2 uye vamunamate, 
\q1 vose vanochengeta Sabata 
\q2 vasingarisvibisi vachibatisisa sungano yangu, 
\q1  
\v 7 ivava ndichavauyisa kugomo rangu dzvene 
\q2 ndigovapa mufaro muimba yangu yokunyengetera. 
\q1 Zvipiriso zvavo zvinopiswa 
\q2 nezvibayiro zvichagamuchirwa paaritari yangu; 
\q1 nokuti imba yangu ichanzi 
\q2 imba yokunyengetera yendudzi dzose.” 
\q1  
\v 8 Ishe Jehovha anoti, 
\q2 iye anounganidza vakatapwa vaIsraeri, 
\q1 “Ndichaunganidzazve vamwe kwavari, 
\q2 tisingaverengeri avo vakaunganidzwa kare.” 
\s1 Mwari anopa mhosva kuna Vakaipa 
\q1  
\v 9 Uyai, imi mose zvikara zvesango, 
\q2 uyai mudye, imi mose zvikara zvesango! 
\q1  
\v 10 Nharirire dzeIsraeri mapofu, 
\q2 vose vanoshayiwa zivo; 
\q1 vose imbwa dzisingahukuri, 
\q2 hadzigoni kuhukura; 
\q1 dzinovata pose pose dzichingorota, 
\q2 dzinofarira kuvata. 
\q1  
\v 11 Imbwa dzinokara zvikuru; 
\q2 dzisingamboguti. 
\q1 Vafudzi vanoshayiwa kunzwisisa: 
\q2 vose vanotsaukira kunzira yavo pachavo, 
\q2 mumwe nomumwe anotsvaka zvinomupfumisa. 
\q1  
\v 12 Mumwe nomumwe anodanidzira achiti, “Uyai, regai nditore waini! 
\q2 Regai tinwe tigute nedoro! 
\q1 Uye mangwana achafanana nanhasi, 
\q2 kana kutopfuura.” 
\c 57  
\q1  
\v 1 Vakarurama vanoparara, 
\q2 uye hakuna anofunga izvi mumwoyo make; 
\q1 vanhu vanoda Mwari vanobviswa, 
\q2 uye hakuna anonzwisisa 
\q1 kuti vakarurama vanobviswa 
\q2 kuti vanunurwe kubva pane zvakaipa. 
\q1  
\v 2 Vose vanofamba mukururama 
\q2 vanopinda murugare, 
\q2 vanowana zororo pavanovata murufu. 
\q1  
\v 3 “Asi imi, uyai pano, imi vanakomana vomuroyi, 
\q2 imi chibereko chemhombwe nezvifeve! 
\q1  
\v 4 Muri kuseka aniko? 
\q2 Ndiani wamunohomera 
\q2 uye wamunobudisira rurimi rwenyu? 
\q1 Ko, hamusi chibereko chemhandu here, 
\q2 nechizvarwa chavanoreva nhema? 
\q1  
\v 5 Munotsva noruchiva pakati pemiti 
\q2 yemuouki napasi pomuti mumwe nomumwe wakapfumvutira; 
\q1 munobayira vana venyu mumipata 
\q2 napasi pamapazi akarembera. 
\q1  
\v 6 Zvifananidzo zviri pakati pamatombo anotsvedzerera emipata ndiwo mugove wenyu; 
\q2 izvozvo, ndiwo mugove wenyu. 
\q1 Hongu, wakadururira chipiriso chokunwa kwazviri, 
\q2 uye ukapa chipiriso chezviyo. 
\q2 Ko, ini muchagona kundiripira zvinhu izvi here? 
\q1  
\v 7 Wakawaridza nhoo pakakwirira napachikomo chirefu; 
\q2 ikoko wakakwira kundobayira zvibayiro. 
\q1  
\v 8 Seri kwamakonhi ako nezvivivo zvako 
\q2 wakaisa chirangaridzo chavamwari vako. 
\q1 Uchindisiya ini, wakafukura mubhedha wako, 
\q2 wakakwira pauri ukaushamisa kwazvo; 
\q1 wakaita sungano naavo vane mibhedha yaunoda, 
\q2 uye wakatarisa kusasimira kwavo. 
\q1  
\v 9 Wakaenda kuna Moreki namafuta 
\q2 omuorivhi ukawedzera zvinonhuhwira zvako. 
\q1 Wakatumira nhume dzako kure; 
\q2 wakaburukira kuguva chaiko! 
\q1  
\v 10 Wakaneteswa nenzira dzako dzose, 
\q2 asi hauna kumboti, ‘Hazvina maturo.’ 
\q1 Wakawana kuvandudzwa kwesimba rako, 
\q2 nokudaro hauna kuziya. 
\b  
\q1  
\v 11 “Ndianiko wawakatya uye ukavhunduka 
\q2 zvokuti wakazoreva nhema kwandiri, 
\q1 uye hauna kumbondirangarira 
\q2 kana kumbozvifunga izvi mumwoyo mako? 
\q1 Hakuzi kuti ndakaramba ndakanyarara 
\q2 iwe ukasanditya here? 
\q1  
\v 12 Ndichaisa pachena kururama kwako namabasa ako, 
\q2 uye hazvizombokubatsiri. 
\q1  
\v 13 Paunochemera rubatsiro, 
\q2 zvifananidzo zvawakaunganidza ngazvikubatsire! 
\q1 Mhepo ichazvikukura zvose, 
\q2 mweya wokungofema zvawo uchazvifuridzira kure. 
\q1 Asi munhu anondiita utiziro hwake 
\q2 achagara nhaka yenyika, 
\q2 uye gomo rangu dzvene richava rake.” 
\s1 Kunyaradzwa kwaVane Mwoyo Yakapwanyika 
\p  
\v 14 Uye zvichazonzi: 
\q1 “Vakai, vakai, gadzirai mugwagwa! 
\q2 Bvisai zvipinganidzo munzira yavanhu vangu.” 
\q1  
\v 15 Nokuti zvanzi naIye akakwirira ari kumusoro, 
\q2 iye anorarama nokusingaperi, ane zita dzvene: 
\q1 “Ndinogara pakakwirira panzvimbo tsvene, 
\q2 asi naiyewo ane mweya wakapwanyika uye anozvininipisa, 
\q1 kuti ndimutsiridze mweya yavanozvininipisa 
\q2 uye ndimutsiridze mwoyo yavakapwanyika. 
\q1  
\v 16 Handichapi mhosva nokusingaperi, 
\q2 kana kugara ndakatsamwa, 
\q1 nokuti ipapo mweya yavanhu ingaziya pamberi pangu, 
\q2 kufema kwomunhu wandakasika. 
\q1  
\v 17 Ndakatsamwiswa nechivi chake chokukara; 
\q2 ndakamuranga, ndikavanza chiso changu mukutsamwa kwangu, 
\q2 asi akaramba ari munzira dzaaida. 
\q1  
\v 18 Ndakaona nzira dzake, 
\q2 asi ndichamuporesa; ndichamutungamirira uye ndichamunyaradza, 
\q2  
\v 19 ndichisika rumbidzo pamiromo yavanochema muIsraeri. 
\q1 Rugare, rugare kuna vari kure navari pedyo,” 
\q2 ndizvo zvinotaura Jehovha. “Uye ndichavaporesa.” 
\q1  
\v 20 Asi vakaipa vakafanana negungwa rinozungunuka, 
\q2 risingagoni kuzorora, 
\q2 rina mafungu anorasa marara namatope. 
\q1  
\v 21 Mwari wangu anoti, “Vakaipa havana rugare.” 
\c 58  
\s1 Kutsanya kwechokwadi 
\q1  
\v 1 “Danidzira nesimba, usanyarara. 
\q2 Simudza inzwi rako sehwamanda. 
\q1 Paridzira vanhu vangu kupanduka kwavo, 
\q2 neimba yaJakobho zvivi zvavo. 
\q1  
\v 2 Nokuti zuva nezuva vanonditsvaka; 
\q2 vanoita savane chido chokuziva nzira dzangu, 
\q1 kunge vanga vari rudzi runoita zvakanaka 
\q2 uye rusina kusiya mirayiro yaMwari wavo. 
\q1 Vanondikumbira kutonga kwakarurama 
\q2 sokunge vanofarira kuti Mwari auye pedyo navo. 
\q1  
\v 3 Vanoti, ‘Takatsanyireiko, 
\q2 uye imi mukasazviona? 
\q1 Takazvininipisireiko, 
\q2 imi mukasazviona?’ 
\b  
\q1 “Asi pazuva rokutsanya kwenyu munoita zvamunoda 
\q2 muchimanikidza vashandi venyu. 
\q1  
\v 4 Kutsanya kwenyu kunogumisira mukukakavadzana nemhirizhonga, 
\q2 uye kurovana netsiva dzakaipisisa. 
\q1 Hamungatsanyi sezvamunoita mazuva ano, 
\q2 mugotarisira kuti inzwi renyu richanzwika kumusoro. 
\q1  
\v 5 Ko, ndiko here kutsanya kwandakasarudza, 
\q2 zuva rimwe chete rokuti munhu azvininipise? 
\q1 Ndezvokukotamisa musoro chete sorushanga here, 
\q2 nokungovata pamusoro penguo dzamasaga namadota? 
\q1 Ndiko kwamunoti kutsanya here, 
\q2 pazuva rinodikanwa naJehovha? 
\b  
\q1  
\v 6 “Uku handiko kutsanya kwandakasarudza here: 
\q1 Kusunungura ngetani dzokusaruramisira 
\q2 nokusunungura zvitirobho zvejoko, 
\q1 kusunungura vakamanikidzwa 
\q2 nokuvhuna joko rimwe nerimwe? 
\q1  
\v 7 Hakuzi kugoverana zvokudya zvako nevane nzara, 
\q2 nokupa varombo vanodzungaira pokugara here, 
\q1 paunoona vakashama, kuvapfekedza, 
\q2 uye kusafuratira venyama neropa rako? 
\q1  
\v 8 Ipapo chiedza chako chichabuda samambakwedza, 
\q2 uye kuporeswa kwako kucharatidzwa nokukurumidza; 
\q1 ipapo kururama kwako kuchakutungamirira, 
\q2 uye kubwinya kwaJehovha kuchakurinda mumashure. 
\q1  
\v 9 Ipapo uchadana, Jehovha achakupindura; 
\q2 uchadanidzira uchida rubatsiro, uye iye achati: Ndiri pano. 
\b  
\q1 “Kana ukabvisa joko roudzvinyiriri, 
\q2 kutendeka nomunwe nokutaura kwakaipa, 
\q1  
\v 10 uye ukapa zvokudya zvako kune vane nzara 
\q2 uye ukagutsa vakamanikidzwa pakushaya kwavo, 
\q1 ipapo chiedza chako chichabuda murima, 
\q2 uye usiku hwako huchashanduka hukafanana namasikati. 
\q1  
\v 11 Jehovha achakutungamirira nguva dzose; 
\q2 achakugutsa pakushaya kwako munyika yakapiswa nezuva 
\q2 uye achasimbisa mapfupa ako. 
\q1 Uchafanana nebindu rinodiridzwa nemvura yetsime, 
\q2 sechitubu chine mvura isingapwi. 
\q1  
\v 12 Vanhu vako vachavakazve matongo akare 
\q2 vachasimudza nheyo dzakare; 
\q1 iwe uchanzi Mugadziri waMasvingo Akakoromoka, 
\q2 Muvandudzi weMigwagwa ine Dzimba. 
\b  
\q1  
\v 13 “Kana ukachengeta tsoka dzako kuti dzisaputsa Sabata, 
\q2 uye kuti dzisaita zvinokufadza iwe pazuva rangu dzvene, 
\q1 kana ukati Sabata izuva rinofadza, 
\q2 uye ukati zuva dzvene raJehovha izuva rinokudzwa, 
\q1 uye kana ukarikudza nokusafamba munzira yako, 
\q2 uye usingaiti zvinokufadza kana kutaura mashoko asina maturo, 
\q1  
\v 14 ipapo uchawana mufaro wako muna Jehovha, 
\q2 uye ndichakuita kuti ukwire pakakwirira penyika, 
\q2 uye ndichakugutsa nenhaka yababa vako Jakobho.” 
\q4 Muromo waJehovha wazvitaura. 
\c 59  
\s1 Chivi, Kureurura, neDzikinuro 
\q1  
\v 1 Zvirokwazvo ruoko rwaJehovha haruna kupfupika kuti rukonewe kuponesa, 
\q2 uye nzeve yake haina kudzivira kuti irege kunzwa. 
\q1  
\v 2 Asi zvakaipa zvenyu zvakakuparadzanisai 
\q2 naMwari wenyu; 
\q1 zvivi zvenyu zvakavanza chiso chake 
\q2 kwamuri kuti arege kunzwa. 
\q1  
\v 3 Nokuti maoko enyu akasvibiswa neropa, 
\q2 minwe yenyu nezvakaipa. 
\q1 Miromo yenyu yakareva nhema, 
\q2 rurimi rwenyu runonguruma zvinhu zvakaipa. 
\q1  
\v 4 Hapana anochemera kururamisira; 
\q2 hapana anokwidza mhaka yake nokutendeka. 
\q1 Vanongovimba negakava risina maturo uye nokureva nhema; 
\q2 vanoita mimba yezvakashata uye vanobereka zvakaipa. 
\q1  
\v 5 Vanochochonya mazai emvumbi, 
\q2 uye vanoruka dandira redandemutande. 
\q1 Ani naani anodya mazai avo achafa, 
\q2 uye rimwe rikaputsika, panochochonywa nyoka. 
\q1  
\v 6 Matandira avo haabatsiri pakupfeka; 
\q2 havagoni kuzvifukidza nezvavanogadzira. 
\q1 Mabasa avo mabasa akaipa, 
\q2 uye kuita nechisimba kuri mumaoko avo. 
\q1  
\v 7 Tsoka dzavo dzinomhanyira kundopinda muchivi; 
\q2 vanokurumidza kuteura ropa risina mhosva. 
\q1 Mirangariro yavo mirangariro yakaipa; 
\q2 kuputsa nokuparadza zviri munzira dzavo. 
\q1  
\v 8 Nzira yorugare havaizivi; 
\q2 hapana kururamisira pamakwara avo. 
\q1 Vakashandura nzira dzavo dzikava dzakaminama; 
\q2 hakuna anofamba madziri achaziva rugare. 
\q1  
\v 9 Naizvozvo kururamisira kuri kure nesu, 
\q2 uye kururama hakusviki kwatiri. 
\q1 Tinotsvaka chiedza, asi zvose irima; 
\q2 tinotsvaka kujeka, asi tiri kufamba mumumvuri werima. 
\q1  
\v 10 Sebofu tinotsvanzvadzira tichitevedza madziro, 
\q2 tichitsvaka nzira yedu savanhu vasina meso. 
\q1 Panguva yamasikati tinogumburwa kunge nguva yorubvunzavaeni; 
\q2 pakati pavane simba, tangoita savakafa. 
\q1  
\v 11 Tose tiri kuomba samapere; 
\q2 tinorira nokurira kukuru senjiva. 
\q1 Tinotsvaka kururamisira, asi hatikuwani; 
\q2 tinotsvaka kurwirwa, asi kuri kure kure. 
\b  
\q1  
\v 12 Nokuti kutadza kwedu kwawanda pamberi penyu, 
\q2 uye zvivi zvedu zvinotipupurira zvakaipa. 
\q1 Kudarika kwedu kunogara nesu, 
\q2 uye tinobvuma kutadza kwedu: 
\q1  
\v 13 kumukira nokunyengera Jehovha, 
\q2 kufuratira Mwari wedu, 
\q1 kukuchidzira udzvinyiriri nokupanduka, 
\q2 nokutaura mashoko enhema anobva mumwoyo yedu. 
\q1  
\v 14 Naizvozvo kururamisirwa kwadzorerwa shure, 
\q2 uye kururama kwamira kure; 
\q1 chokwadi chakagumburwa munzira dzomumusha, 
\q2 kutendeka hakuchagoni kupinda. 
\q1  
\v 15 Zvokwadi haichawanikwi 
\q2 uye vanovenga zvakaipa ndivo vopambwa. 
\b  
\q1 Jehovha akatarisa akasafara 
\q2 kuti pakanga pasisina kururamisira. 
\q1  
\v 16 Akaona kuti pakanga pasina munhu, 
\q2 akashamiswa kuti pakanga pasina munhu aipindira; 
\q1 naizvozvo ruoko rwake rwakamuvigira ruponeso, 
\q2 uye kururama kwake kwakamuraramisa. 
\q1  
\v 17 Akashonga kururama sechidzitiro chechipfuva, 
\q2 nenguwani yoruponeso mumusoro make; 
\q1 akashonga nguo dzokutsiva akazviputira 
\q2 mukushingaira kwake seanozviputira nejasi. 
\q1  
\v 18 Sezvavakaita, saizvozvo acharipira 
\q2 hasha 
\q1 kuvavengi vake 
\q2 nokutsiva kuvadzivisi vake; 
\q2 acharipira zvakafanira kuzviwi. 
\q1  
\v 19 Kubva kumavirira, vanhu vachatya Jehovha, 
\q2 uye kubva pakubuda kwezuva, vachakudza kubwinya kwake. 
\q1 Nokuti achauya sokudira kworwizi 
\q2 runosundwa nokufema kwaJehovha. 
\b  
\q1  
\v 20 “Mudzikinuri achauya kuZioni, 
\q2 kuna avo vari muna Jakobho vanotendeuka pazvivi zvavo,” 
\q4 ndizvo zvinotaura Jehovha. 
\p  
\v 21 “Kana ndirini, iyi ndiyo sungano yangu navo,” ndizvo zvinotaura Jehovha. “Mweya wangu uri pamusoro pako, namashoko angu andakaisa mumuromo mako hazvichabvi pamuromo wako, kana pamiromo yavana venyu, kana pamiromo yezvizvarwa zvavo kubva zvino nokusingaperi,” ndizvo zvinotaura Jehovha. 
\c 60  
\s1 Kubwinya kweZioni 
\q1  
\v 1 “Simuka, upenye nokuti chiedza chako chasvika, 
\q2 uye kubwinya kwaJehovha kwabuda pamusoro pako. 
\q1  
\v 2 Tarira, rima rakafukidza nyika 
\q2 uye rima guru riri pamusoro pavanhu, 
\q1 asi Jehovha anobuda pamusoro pako 
\q2 uye kubwinya kwake kunoratidzwa pamusoro pako. 
\q1  
\v 3 Ndudzi dzichauya kuchiedza chako, 
\q2 uye madzimambo kukubwinya kwamambakwedza ako. 
\b  
\q1  
\v 4 “Simudza meso ako utarise zvakakukomberedza: 
\q2 vose vanoungana uye vanouya kwauri, 
\q1 vanakomana vako vanobva kure, 
\q2 uye vanasikana vako vanotakurwa pamaoko. 
\q1  
\v 5 Ipapo uchatarisa ugopenya, 
\q2 mwoyo wako uchakwata uye uchazara nomufaro; 
\q1 upfumi huri pamusoro pamakungwa huchauyiswa kwauri, 
\q2 pfuma yendudzi ichauya kwauri. 
\q1  
\v 6 Mapoka engamera achazadza nyika yako, 
\q2 mhuru dzengamera dzeMidhiani neEfa. 
\q1 Uye vose vanobva kuShebha vachauya, 
\q2 vakatakura goridhe nezvinonhuhwira 
\q2 vachiparidza kurumbidzwa kwaJehovha. 
\q1  
\v 7 Mapoka eKedhari achaunganidzirwa 
\q2 kwauri makondobwe eNebhayoti achakushumira: 
\q1 achagamuchirwa sezvipo paaritari yangu, 
\q2 uye ndichashongedza temberi yangu yokukudzwa. 
\b  
\q1  
\v 8 “Ndivanaani ava vanobhururuka samakore, 
\q2 senjiva dzinoenda kumatendere adzo? 
\q1  
\v 9 Zvirokwazvo zviwi zvinotarira kwandiri; 
\q2 zvikepe zveTashishi zvinotungamira 
\q1 zvichiuya navanakomana venyu vari kubva kure, 
\q2 nesirivha yavo negoridhe, 
\q1 kuzokudza Jehovha Mwari wako, 
\q2 iye Mutsvene waIsraeri, 
\q2 nokuti akakushongedza nokubwinya. 
\b  
\q1  
\v 10 “Vatorwa vachavakazve masvingo ako, 
\q2 uye madzimambo avo achakushandira. 
\q1 Kunyange ndakakurova mukutsamwa kwangu, 
\q2 munyasha dzangu ndichakunzwira tsitsi. 
\q1  
\v 11 Masuo ako achagara akashama 
\q2 haachazombozarirwi, masikati kana usiku 
\q1 kuitira kuti vanhu vakuvigire upfumi hwendudzi, 
\q2 madzimambo adzo achafambiswa ari mumudungwe akundwa. 
\q1  
\v 12 Nokuti rudzi kana ushe husingakushumiri huchaparadzwa; 
\q2 huchaparadzwa zvachose. 
\b  
\q1  
\v 13 “Kubwinya kweRebhanoni kuchauya kwauri, 
\q2 mipaini nemifiri nemisipuresi pamwe chete, 
\q1 kuzoshongedza nzvimbo yetemberi yangu tsvene; 
\q2 uye ndichabwinyisa nzvimbo yetsoka dzangu. 
\q1  
\v 14 Vanakomana vavamanikidzi venyu 
\q2 vachauya vachikotama pamberi penyu; 
\q1 vose vanokuzvidzai vachapfugama patsoka dzenyu uye vachakutumidzai kuti Guta raJehovha, 
\q2 Zioni roMutsvene waIsraeri. 
\b  
\q1  
\v 15 “Kunyange wanga wasiyiwa uye uchivengwa, 
\q2 pasina munhu anopfuura nemauri, 
\q1 ndichakuita kuti ukudzwe nokusingaperi 
\q2 uye uve mufaro wezvizvarwa zvinotevera. 
\q1  
\v 16 Uchanwa mukaka wendudzi 
\q2 uye ucharerwa pamazamu oumambo. 
\q1 Ipapo uchaziva kuti ini, iyeni Jehovha, ndini Muponesi wako, 
\q2 Mudzikinuri wako, Wamasimba Ose waJakobho. 
\q1  
\v 17 Ndichakuvigira goridhe pachinzvimbo chendarira, 
\q2 nesirivha pachinzvimbo chesimbi. 
\q1 Ndichakuvigira ndarira pachinzvimbo chamatanda, 
\q2 nesimbi pachinzvimbo chamabwe. 
\q1 Ndichaita rugare mubati wako 
\q2 nekururama mutongi wako. 
\q1  
\v 18 Kuita nechisimba hakuchazonzwikwa munyika yako, 
\q2 kana dongo kana kuparadzwa mukati memiganhu yako, 
\q1 asi uchatumidza masvingo ako zita 
\q2 rokuti Ruponeso nemasuo ako kuti Rumbidzo. 
\q1  
\v 19 Zuva harichazovi chiedza chako masikati, 
\q2 uye kupenya kwomwedzi hakungavi pamusoro pako, 
\q1 nokuti Jehovha ndiye achava chiedza chako chisingaperi, 
\q2 uye Mwari wako achava kubwinya kwako. 
\q1  
\v 20 Zuva rako harichazovirizve, 
\q2 uye mwedzi wako hauchazoperizve; 
\q1 Jehovha achava chiedza chako chisingaperi, 
\q2 uye mazuva okuchema kwako achaguma. 
\q1  
\v 21 Ipapo vanhu vako vose vachava vakarurama, 
\q2 uye vachatora nyika kuti ive yavo nokusingaperi. 
\q1 Ndivo mabukira andakadyara, 
\q2 basa ramaoko angu, 
\q2 kuti ndiratidze kubwinya kwangu. 
\q1  
\v 22 Mudikisa wako achava chiuru, 
\q2 mudiki achava rudzi rune simba. 
\q1 Ndini Jehovha, 
\q2 munguva yacho ndichazviita nokukurumidza.” 
\c 61  
\s1 Gore reNyasha dzaJehovha 
\q1  
\v 1 Mweya waIshe Jehovha uri pamusoro pangu, 
\q2 nokuti Jehovha akandizodza 
\q2 kuti ndiparidze vhangeri kuvarombo. 
\q1 Akandituma kuti ndirape vane mwoyo yakaputsika, 
\q2 kuti ndiparidze kusunungurwa kwavakatapwa, 
\q2 nokubudiswa kwavasungwa kuti vabve murima, 
\q1  
\v 2 kuti ndiparidze gore rengoni dzaJehovha 
\q2 uye nezuva rokutsiva kwaMwari wedu, 
\q1 kuti ndinyaradze vose vanochema, 
\q2  
\v 3 uye ndiriritire avo vanochema muZioni, 
\q1 kuti ndiise pamusoro pavo korona yorunako 
\q2 pachinzvimbo chamadota, 
\q1 mafuta omufaro 
\q2 pachinzvimbo chokuchema, 
\q1 uye nenguo yokurumbidza 
\q2 pachinzvimbo chomweya wakarukutika. 
\q1 Vachanzi miouki yokururama, 
\q2 yakasimwa naJehovha 
\q2 kuti aratidze kubwinya kwake. 
\q1  
\v 4 Vachavakazve matongo akare 
\q2 uye vachamutsazve nzvimbo dzakaparadzwa kare; 
\q2 vachavandudza matongo amaguta 
\q2 akaparadzwa kwezvizvarwa nezvizvarwa zvakapfuura. 
\q1  
\v 5 Vatorwa vachafudza mapoka amakwai enyu; 
\q2 vatorwa vachashanda muminda yenyu nomuminda yenyu yemizambiringa. 
\q1  
\v 6 Ipapo imi muchanzi vaprista vaJehovha, 
\q2 muchanzi vashumiri vaMwari. 
\q1 Muchadya pfuma yendudzi, 
\q2 uye muchazvirumbidza nepfuma yavo. 
\b  
\q1  
\v 7 Pachinzvimbo chokunyadziswa kwavo 
\q2 vanhu vangu vachagamuchira migove miviri, 
\q1 uye pachinzvimbo chokunyadziswa vachafara munhaka yavo; 
\q2 nokudaro vachagara nhaka yemigove miviri munyika yavo, 
\q2 uye mufaro usingaperi uchava wavo. 
\b  
\q1  
\v 8 “Nokuti ini, Jehovha, ndinoda kururamisira; 
\q2 ndinovenga kupamba nezvakaipa. 
\q1 Mukutendeka kwangu, ndichavapa mubayiro 
\q2 uye ndichaita sungano isingaperi navo. 
\q1  
\v 9 Zvizvarwa zvavo zvichazivikanwa pakati pendudzi 
\q2 uye navana vavo pakati pamarudzi. 
\q1 Vose vanovaona vachaziva 
\q2 kuti vanhu vakaropafadzwa naJehovha.” 
\b  
\q1  
\v 10 Ndinofara zvikuru muna Jehovha; 
\q2 mweya wangu unofara muna Mwari. 
\q1 Nokuti akandifukidza nenguo dzoruponeso, 
\q2 uye akandishongedza nenguo yokururama, 
\q1 sechikomba chinoshongedza musoro wacho somuprista, 
\q2 uye somwenga anozvishongedza nezvishongo zvamatombo anokosha. 
\q1  
\v 11 Nokuti ivhu sezvarinomeresa mbeu, 
\q2 nebindu richiita kuti mbeu dzikure, 
\q1 saizvozvo Ishe Jehovha achaita kuti kururama nerumbidzo 
\q2 zvimere pamberi pendudzi dzose. 
\c 62  
\s1 Zita idzva reZioni 
\q1  
\v 1 Nokuda kweZioni handinganyarari, 
\q2 nokuda kweJerusarema handingarambi ndinyerere, 
\q1 kusvikira kururama kwake kwapenya samambakwedza, 
\q2 noruponeso rwake somwenje unopfuta. 
\q1  
\v 2 Ndudzi dzichaona kururama kwako, 
\q2 uye madzimambo ose achaona kubwinya kwako; 
\q1 iwe uchadaidzwa nezita idzva 
\q2 richataurwa nomuromo waJehovha. 
\q1  
\v 3 Uchava korona yokubwinya muruoko rwaJehovha, 
\q2 ukomba hwoumambo muruoko rwaMwari wako. 
\q1  
\v 4 Havachazokutizve Musiyiwa, 
\q2 kana kutumidza nyika yako kuti Dongo. 
\q1 Asi uchatumidzwa kuti Hefizibha 
\q2 uye nyika yako ichanzi Bhiyura; 
\q1 nokuti Jehovha achakufarira, 
\q2 uye nyika yako icharoorwa. 
\q1  
\v 5 Sejaya zvarinowana mhandara, 
\q2 saizvozvo vanakomana vako vachakuwana; 
\q1 sechikomba chinofarira mwenga, 
\q2 saizvozvo Mwari wako achafara pamusoro pako. 
\q1  
\v 6 Ndakagadza nharirire pamasvingo ako, iwe Jerusarema; 
\q2 havangambonyarari masikati kana usiku. 
\q1 Imi munodana kuna Jehovha, 
\q2 musazorora, 
\q1  
\v 7 uye musamupa zororo kusvikira asimbisa Jerusarema, 
\q2 uye ariita rumbidzo yenyika. 
\b  
\q1  
\v 8 Jehovha akapika noruoko rwake rworudyi, 
\q2 noruoko rwake rune simba achiti, 
\q2 “Handichazopizve zviyo zvenyu sezvokudya kuvavengi venyu, 
\q1 uye vatorwa havachazonwizve waini itsva 
\q2 yamakatamburira; 
\q1  
\v 9 asi ivo vanokohwa ndivo vachadya 
\q2 uye vacharumbidza Jehovha, 
\q1 uyewo vaya vanounganidza mazimbiringa ndivo vachainwa 
\q2 mumavazhe eimba yangu tsvene.” 
\b  
\q1  
\v 10 Pfuurai, pfuurai napamasuo! 
\q2 Gadzirirai vanhu nzira. 
\q1 Vakai, vakai mugwagwa mukuru! 
\q2 Bvisai mabwe. 
\q1 Simudzirai ndudzi mureza. 
\b  
\q1  
\v 11 Jehovha akaparidzira kumagumo enyika achiti, “Uti kuMwanasikana weZioni, ‘Tarira, Muponesi wako ouya! Tarira, mubayiro wake anawo, uye kuripira kwake kunomutevera.’ ” 
\q1  
\v 12 Vachanzi Vanhu Vatsvene, Vakadzikinurwa vaJehovha; uye iwe uchanzi Mutsvakwa, iro Guta Risina Kuzova Dongo. 
\c 63  
\s1 Zuva raMwari roKutsiva noKudzikinura 
\q1  
\v 1 Ndianiko uyu anobva kuEdhomu, 
\q2 anobva kuBhozira, ane nguo dzakatsvuka seropa? 
\q1 Ndianiko uyu, akafuka zvinobwinya, 
\q2 anofamba muukuru hwesimba rake? 
\q1 “Ndini ndinotaura nokururama, 
\q2 ndine simba rokuponesa.” 
\b  
\q1  
\v 2 Seiko nguo dzenyu dzakatsvuka 
\q2 sedzomunhu anotsika chisviniro chewaini? 
\b  
\q1  
\v 3 “Ndakatsika chisviniro chewaini ndoga; 
\q2 kubva kundudzi dzose hapana akanga aneni. 
\q1 Ndakavatsika-tsika mukutsamwa kwangu 
\q2 uye ndakavapwanyira pasi muhasha dzangu; 
\q1 ropa ravo rikatsatikira panguo dzangu, 
\q2 ndikasvibisa nguo dzangu dzose. 
\q1  
\v 4 Nokuti zuva rokutsiva rakanga riri mumwoyo mangu, 
\q2 uye gore rokudzikinura kwangu rasvika. 
\q1  
\v 5 Ndakatarisa, asi pakanga pasina angabatsira, 
\q2 ndakashamiswa nokuti hapana akatsigira; 
\q1 naizvozvo ruoko rwangu rwakandivigira ruponeso, 
\q2 uye hasha dzangu dzakanditsigira. 
\q1  
\v 6 Ndakatsika-tsika ndudzi mukutsamwa kwangu; 
\q2 muhasha dzangu ndakaita kuti vadhakwe 
\q2 uye ndakadurura ropa ravo pasi.” 
\s1 Kurumbidza noKunyengetera 
\q1  
\v 7 Ndichataura nezvounyoro hwaJehovha, 
\q2 iwo mabasa aanofanira kukudzwa nawo, 
\q2 nokuda kwezvose zvatakaitirwa naJehovha, 
\q1 hongu, izvo zvinhu zvizhinji zvaakaitira 
\q2 imba yaIsraeri, 
\q2 nokuda kwetsitsi dzake uye nengoni dzake zhinji. 
\q1  
\v 8 Akati, “Zvirokwazvo ndivo vanhu vangu, 
\q2 ivo vanakomana vasingazovi venhema kwandiri,” 
\q2 naizvozvo akava Muponesi wavo. 
\q1  
\v 9 Mumatambudziko avo ose naiyewo akatambudzika, 
\q2 uye mutumwa wokuvapo kwake akavaponesa. 
\q1 Murudo rwake nengoni akavadzikinura; 
\q2 akavasimudza uye akavatakura 
\q2 mumazuva ose akare. 
\q1  
\v 10 Asi vakamumukira 
\q2 vakachemedza Mweya wake Mutsvene. 
\q1 Saka akashanduka akava muvengi wavo, 
\q2 uye iye amene akarwa navo. 
\b  
\q1  
\v 11 Ipapo vanhu vake vakarangarira mazuva akare, 
\q2 mazuva aMozisi navanhu vake, vakati, 
\q1 aripiko akavayambutsa gungwa, 
\q2 nomufudzi wamakwai ake? 
\q1 Aripiko akaisa 
\q2 Mweya wake Mutsvene pakati pavo, 
\q1  
\v 12 iye akavatumira ruoko rwake rwokukudzwa nesimba 
\q2 kuti ruve paruoko rworudyi rwaMozisi, 
\q1 iye akaparadzanisa mvura pamberi pavo, 
\q2 kuti azviwanire mukurumbira usingaperi, 
\q1  
\v 13 iye akavatungamirira nomakadzika? 
\q2 Sebhiza murenje, havana kugumburwa; 
\q1  
\v 14 semombe dzinoburukira kubani, 
\q2 vakapiwa zororo noMweya waJehovha. 
\q1 Ndiwo matungamiriro amakaita vanhu venyu 
\q2 kuti muzviitire zita rine mukurumbira. 
\b  
\q1  
\v 15 Tarirai pasi muri kudenga uye muone, 
\q2 kubva pachigaro chenyu chakakwirira chitsvene uye chinobwinya. 
\q1 Kushingaira kwenyu nesimba renyu zviripiko? 
\q2 Unyoro hwenyu netsitsi dzenyu zvakabviswa kwatiri. 
\q1  
\v 16 Asi muri Baba vedu, 
\q2 kunyange Abhurahama asingatizivi 
\q2 kana naIsraeri asingatiziviwo; 
\q1 imi, Jehovha, ndimi Baba vedu, 
\q2 Mudzikinuri wedu kubva kare ndiro zita renyu. 
\q1  
\v 17 Haiwa Jehovha, munotiregereiko tichidzungaira, kubva panzira dzenyu 
\q2 muchiomesa mwoyo yedu kuti tirege kukutyai? 
\q1 Dzokai nokuda kwavaranda venyu, 
\q2 iwo marudzi enhaka yenyu. 
\q1  
\v 18 Kwenguva duku vanhu venyu vakatora nzvimbo yenyu tsvene, 
\q2 asi zvino vavengi vedu vakatsika-tsika nzvimbo yenyu tsvene. 
\q1  
\v 19 Isu tiri venyu kubva kare; 
\q2 asi ivo hamuna kumbovatonga, 
\q2 havana kumbodaidzwa nezita renyu. 
\c 64  
\q1  
\v 1 Haiwa, dai maibvarura matenga mukaburuka pasi, 
\q2 kuti makomo adedere pamberi penyu! 
\q1  
\v 2 Sezvinoita moto paunopisa tsotso 
\q2 uchiita kuti mvura ivire, 
\q1 burukai muzoita kuti zita renyu rizivikanwe kuvavengi venyu, 
\q2 uye muite kuti ndudzi dzidedere pamberi penyu! 
\q1  
\v 3 Nokuti pamakaita zvinhu zvinotyisa zvatakanga tisina kutarisira, 
\q2 makaburuka pasi, makomo akabvunda pamberi penyu. 
\q1  
\v 4 Kubva panguva dzekare hakuna munhu akanzwa, 
\q2 hakuna nzeve yakanzwisisa, 
\q1 hakuna ziso rakaona mumwe Mwari kunze kwenyu, 
\q2 anobatsira avo vanomumirira. 
\q1  
\v 5 Munouya kuzobatsira avo vanofarira kuita zvakarurama, 
\q2 vanorangarira nzira dzenyu. 
\q1 Asi patakaramba tichivatadzira, 
\q2 imi makatsamwa. 
\q2 Zvino tingaponeswa seiko? 
\q1  
\v 6 Isu tose tafanana nousina kuchena, 
\q2 uye mabasa edu ose okururama afanana namamvemve enguo dzine tsvina; 
\q1 isu tose tinooma seshizha, 
\q2 semhepo zvivi zvedu zvinotitsvairira kure. 
\q1  
\v 7 Hakuna anodana kuzita renyu 
\q2 kana anoshingairira kuti akubatei; 
\q1 nokuti makativanzira chiso chenyu mukaita 
\q2 kuti tiperezeke nokuda kwezvivi zvedu. 
\q1  
\v 8 Haiwa, Jehovha, kunyange zvakadaro muri Baba vedu. 
\q2 Isu tiri ivhu, imi muri muumbi; 
\q2 isu tose tiri basa ramaoko enyu. 
\q1  
\v 9 Regai kutsamwa zvikuru imi Jehovha; 
\q2 regai kurangarira zvivi zvedu nokusingaperi. 
\q1 Haiwa Jehovha, ringirai kwatiri, tinokumbira, 
\q2 nokuti tose tiri vanhu venyu. 
\q1  
\v 10 Maguta enyu matsvene ava renje; 
\q2 kunyange Zioni irenje, Jerusarema rava dongo. 
\q1  
\v 11 Temberi yedu tsvene inobwinya, umo madzibaba edu akakurumbidzai, 
\q2 yakapiswa nomoto, 
\q2 uye nzvimbo dzose dzataikoshesa dzaparara. 
\q1  
\v 12 Haiwa Jehovha, mushure maizvozvi mungazvidzorawo here? 
\q2 Mucharamba munyerere, uye mugotiranga zvinopfuura mwero here? 
\c 65  
\s1 Kutongwa noRuponeso 
\q1  
\v 1 “Ndakazviratidza kuna avo vasina kundibvunza; 
\q2 ndakawanikwa neavo vasina kunditsvaka. 
\q1 Kurudzi rwakanga rusina kudana kuzita rangu 
\q2 ndakati, ‘Ndiri pano, ndiri pano.’ 
\q1  
\v 2 Zuva rose ndakatambanudzira maoko angu 
\q2 kurudzi rwakasindimara, 
\q1 vanofamba munzira dzisina kunaka 
\q2 vachitevera zvavanofunga, 
\q1  
\v 3 vanhu vanogara vachindigumbura 
\q2 ipo pamberi pangu chaipo, 
\q1 vachibayira zvibayiro pamapindu 
\q2 uye vachipisira zvinonhuhwira paaritari dzezvitinha; 
\q1  
\v 4 vanogara pakati pamarinda 
\q2 uye vanopedza usiku hwavo vachinyengetera vari munzira yakavanda: 
\q1 vanodya nyama yenguruve, 
\q2 uye hari dzavo dzine furo renyama yakasvibiswa; 
\q1  
\v 5 vanoti, ‘Gara kure; usaswedera pedyo neni, 
\q2 nokuti ndiri mutsvene kupfuura iwe.’ 
\q1 Vanhu vakadaro utsi mumhuno dzangu, 
\q2 moto unoramba uchipfuta zuva rose. 
\b  
\q1  
\v 6 “Tarirai, zvakanyorwa pamberi pangu zvinoti: 
\q2 Handinganyarari asi ndicharipira zvakazara; 
\q2 ndichazviripa pamakumbo avo, 
\q1  
\v 7 zvakaipa zvenyu nezvamadzibaba enyu,” 
\q2 ndizvo zvinotaura Jehovha. 
\q1 “Nokuti vakapisira zvibayiro pamusoro pezvikomo, 
\q2 ndichayera pamakumbo avo 
\q2 muripo wakazara wamabasa avo akare.” 
\p  
\v 8 Zvanzi naJehovha: 
\q1 “Sezvazvakangoita kana musvi uchiri kuwanikwa musumbu ramazambiringa 
\q2 uye vanhu vachiti, ‘Musauparadza, muchine zvakanaka mauri,’ 
\q1 saizvozvo ndizvo zvandichaitira varanda vangu; 
\q2 handingavaparadzi vose. 
\q1  
\v 9 Ndichabudisa marudzi kuna Jakobho, 
\q2 uye nokubva kuna Judha avo vachatora makomo angu; 
\q1 vasanangurwa vangu vachagara nhaka, 
\q2 uye varanda vangu vachagara ikoko. 
\q1  
\v 10 Sharoni richava mafuro amakwai, 
\q2 uye Mupata weAkori uchava uvato hwemombe 
\q2 dzavanhu vangu vanonditsvaka. 
\b  
\q1  
\v 11 “Asi kana murimi munosiya Jehovha 
\q2 uye munokanganwa gomo rangu dzvene, 
\q1 munowaridzira Rombo Rakanaka tafura, 
\q2 uye munozadza zvirongo newaini yakavhenganisirwa Magumo, 
\q1  
\v 12 ndichakuendesai kumunondo, 
\q2 uye mose muchakotamira pasi kuti mubayiwe, 
\q1 nokuti ndakadana asi hamuna kudavira, 
\q2 ndakataura asi hamuna kuteerera. 
\q1 Makaita zvakaipa pamberi pangu 
\q2 mukasarudza zvisingandifadzi.” 
\b  
\q1  
\v 13 Naizvozvo zvanzi naIshe Jehovha: 
\q1 “Varanda vangu vachadya, 
\q2 asi imi muchanzwa nzara; 
\q1 varanda vangu vachanwa, 
\q2 asi imi muchava nenyota; 
\q1 varanda vangu vachafara, 
\q2 asi imi muchanyadziswa. 
\q1  
\v 14 Varanda vangu vachaimba zvichibva mumufaro wemwoyo yavo, 
\q2 asi imi muchachema nokurwadziwa nemwoyo 
\q2 uye muchaungudza mukupwanyika kwomweya. 
\q1  
\v 15 Muchasiyira zita renyu 
\q2 kuvasanangurwa vangu sechituko; 
\q1 Ishe Jehovha achakuurayai, 
\q2 asi achapa varanda vake rimwe zita. 
\q1  
\v 16 Ani naani achati nyika iropafadzwe 
\q2 achazviita naMwari wechokwadi; 
\q1 ani naani achaita mhiko munyika 
\q2 achapika naMwari wechokwadi. 
\q1 Nokuti matambudziko akare achakanganwikwa, 
\q2 uye achavanzirwa meso angu. 
\s1 Matenga Matsva neNyika Itsva 
\q1  
\v 17 “Tarirai, ndichasika 
\q2 matenga matsva nenyika itsva. 
\q1 Zvinhu zvakare hazvichazorangarirwi, 
\q2 kana kuuya mundangariro. 
\q1  
\v 18 Asi farai mupembere nokusingaperi 
\q2 mune zvandichasika, 
\q1 nokuti ndichasika Jerusarema kuti rifadze 
\q2 uye kuti vanhu varo vave mufaro. 
\q1  
\v 19 Ndichapembera pamusoro peJerusarema, 
\q2 uye ndichafarira vanhu vangu; 
\q1 maungira okuchema kana kurira 
\q2 haachazonzwikwazve imomo. 
\b  
\q1  
\v 20 “Mariri hamungazovazve 
\q2 nomucheche achararama mazuva mashoma shoma, 
\q2 kana mutana asingasvitsi makore ake okurarama; 
\q1 uyo anofa ane zana ramakore 
\q2 achangotorwa somujaya; 
\q1 uyo anotadza kusvika pazana ramakore 
\q2 achatorwa sowakatukwa. 
\q1  
\v 21 Vachavaka dzimba vagogara madziri; 
\q2 vachadyara mazambiringa vagodya michero yawo. 
\q1  
\v 22 Havachazovakazve dzimba dzinozogarwa navamwe, 
\q2 kana kudyara vamwe vachizodya. 
\q1 Nokuti sezvakaita mazuva omuti, 
\q2 ndizvo zvichaita mazuva avanhu vangu; 
\q1 vasanangurwa vangu vachafara kwenguva refu 
\q2 mumabasa amaoko avo. 
\q1  
\v 23 Havachazoshandira pasina 
\q2 kana kubereka vana vanoparadzwa; 
\q1 nokuti vachava vanhu vakaropafadzwa naJehovha, 
\q2 ivo nezvizvarwa zvavo. 
\q1  
\v 24 Vasati vadana ndichavapindura; 
\q2 vachiri kutaura ndichavanzwa. 
\q1  
\v 25 Bumhi negwayana zvichafura pamwe chete, 
\q2 uye shumba ichadya uswa senzombe, 
\q2 asi guruva richava chokudya chenyoka. 
\q1 Hazvichazokuvadza kana kuparadza 
\q2 pamusoro pegomo rangu dzvene rose,” 
\q4 ndizvo zvinotaura Jehovha. 
\c 66  
\s1 Kutonga neTariro 
\p  
\v 1 Zvanzi naJehovha: 
\q1 “Denga ndicho chigaro changu, 
\q2 uye nyika chitsiko chetsoka dzangu. 
\q1 Ko, iripi imba yamungandivakira? 
\q2 Nzvimbo yangu yokuzorora ichava kupiko? 
\q1  
\v 2 Haruzi ruoko rwangu rwakaita izvozvi zvose here, 
\q2 nokudaro zvikavapo?” 
\q4 ndizvo zvinotaura Jehovha. 
\b  
\q1 “Munhu akadai ndiye wandichakudza: 
\q2 iye anozvininipisa uye ane mweya wakapwanyika, 
\q2 uye anodedera paanonzwa shoko rangu. 
\q1  
\v 3 Asi ani naani anobayira hando 
\q2 akafanana nouyo anouraya munhu, 
\q1 uye anobayira gwayana, 
\q2 anofanana nouyo anovhuna mutsipa wembwa; 
\q1 ani naani anoita chipiriso chezviyo 
\q2 anofanana nomunhu anopa ropa renguruve, 
\q1 uye ani naani anopisira zvinonhuhwira zvokurangaridza, 
\q2 anofanana nounonamata chifananidzo. 
\q1 Vakasarudza nzira dzavo, 
\q2 uye mweya yavo inofarira zvinonyangadza zvavo; 
\q1  
\v 4 naizvozvo neniwo ndichavasarudzira kuranga kuchavaomera, 
\q2 uye ndichauyisa pamusoro pavo izvo zvavanotya. 
\q1 Nokuti pandakadana, hapana akapindura, 
\q2 pandakataura, hapana akateerera. 
\q1 Vakaita zvakaipa pamberi pangu 
\q2 vakasarudza zvisingandifadzi.” 
\b  
\q1  
\v 5 Inzwai shoko raJehovha, 
\q2 imi munodedera pamunonzwa shoko rake: 
\q1 “Hama dzenyu dzinokuvengai, 
\q2 uye dzinokutsaurai nokuda kwezita rangu, dzakati, 
\q1 ‘Jehovha ngaaratidze kukudzwa kwake, 
\q2 kuti tione mufaro wenyu!’ 
\q2 Asi ivo vachanyadziswa. 
\q1  
\v 6 Inzwai maungira ebope anobva muguta, 
\q2 inzwai mheremhere inobva mutemberi! 
\q1 Ndiwo maungira aJehovha 
\q2 achiripira vavengi vake zvose zvakavakodzera. 
\b  
\q1  
\v 7 “Asati arwadziwa nemimba, 
\q2 anosununguka; 
\q1 kurwadza kusati kwauya pamusoro pake, 
\q2 anosununguka mwanakomana. 
\q1  
\v 8 Ndiani akambonzwa chinhu chakadai? 
\q2 Ndiani akamboona zvinhu zvakadai? 
\q1 Ko, nyika ingazvarwa pazuva rimwe here 
\q2 kana rudzi rungazvarwa pakarepo here? 
\q1 Kunyange zvakadaro, Zioni rakangoti kurwadziwa, 
\q2 pakarepo ndokubereka vana varo. 
\q1  
\v 9 Ndingasvitsa panguva yokubereka 
\q2 ndikasaberekesa here?” ndizvo zvinotaura Jehovha. 
\q1 “Ko, ndinozarira chizvaro 
\q2 pandinoberekesa here?” ndizvo zvinotaura Mwari wenyu. 
\q1  
\v 10 “Pemberai pamwe chete neJerusarema uye mufarisise nokuda kwaro, 
\q2 imi mose munorida; 
\q1 farisisai pamwe chete naro, 
\q2 imi mose munochema pamusoro paro. 
\q1  
\v 11 Nokuti muchanwa mukaguta 
\q2 pamazamu ake anonyaradza; 
\q1 muchanwa zvikuru kwazvo 
\q2 uye muchafadzwa nezvakawanda zvake zvinopfachukira.” 
\p  
\v 12 Nokuti zvanzi naJehovha: 
\q1 “Ndichawedzera rugare kwaari sorwizi, 
\q2 uye upfumi hwendudzi sokudira kworukova; 
\q1 muchayamwa uye muchatakurwa paruoko rwake, 
\q2 uye muchavaraidzwa pamabvi ake. 
\q1  
\v 13 Samai vanonyaradza mwana wavo, 
\q2 saizvozvo ndichakunyaradzai; 
\q2 uye muchanyaradzwa pamusoro peJerusarema.” 
\b  
\q1  
\v 14 Pamuchaona izvozvo, mwoyo wenyu uchafara, 
\q2 uye muchaita bumhudza sebundo; 
\q1 ruoko rwaJehovha rucharatidzwa kuvaranda vake, 
\q2 asi hasha dzake dzicharatidzwa kuvavengi vake. 
\q1  
\v 15 Tarirai, Jehovha ari kuuya nomoto, 
\q2 uye ngoro dzake dzakaita sechamupupuri; 
\q1 achaburutsa kutsamwa kwake nehasha huru, 
\q2 uye kutuka kwake nomurazvo womoto. 
\q1  
\v 16 Nokuti nomoto uye nomunondo wake 
\q2 Jehovha achatonga vanhu vose, 
\q2 uye vazhinji vachava vaya vanourayiwa naJehovha. 
\p  
\v 17 “Vaya vanozvinatsa nokuzvichenesa kuti vaende mumapindu, vachitevera munhu ari pakati paavo vanodya nyama yenguruve nembeva uye nezvimwe zvinhu zvinonyangadza, magumo avo achava mamwe chete,” ndizvo zvinotaura Jehovha. 
\p  
\v 18 “Nokuti ini nokuda kwamabasa avo nepfungwa dzavo, ndiri kuuya kuzounganidza marudzi ose nendimi dzose; vachauya uye vachaona kubwinya kwangu. 
\p  
\v 19 “Ndichaisa chiratidzo pakati pavo, uye ndichatumira vamwe vavakapunyuka kundudzi, kuTashishi, nokuvaRibhiya navaRidhia (vane mbiri yokuwembura uta), nokuTubhari nokuGirisi, nokuzviwi zviri kure zvisina kumbonzwa nezvembiri yangu kana kuona kubwinya kwangu. Vachaparidza kubwinya kwangu pakati pendudzi.  
\v 20 Uye vachauyisa hama dzenyu dzose, kubva kundudzi dzose, kugomo rangu dzvene muJerusarema, sechipo kuna Jehovha, pamusoro pamabhiza, nomungoro uye mungoro dzina matenga, napamanyurusi uye napangamera,” ndizvo zvinotaura Jehovha. “Vachazviuyisa, savaIsraeri vanouyisa zvipiriso zvavo zvezviyo, kutemberi yaJehovha mumidziyo yakacheneswa.  
\v 21 Ipapo ndichasarudza vamwe vavo kuti vave vaprista navaRevhi,” ndizvo zvinotaura Jehovha. 
\p  
\v 22 “Nokuti sezvakaita matenga matsva nenyika itsva zvandinoita zvichazogara pamberi pangu,” ndizvo zvinotaura Jehovha, “saizvozvo zita renyu nezvizvarwa zvenyu zvichagara.  
\v 23 Kubva paKugara kwoMwedzi kusvikira kuno mumwe, uye kubva paSabata rimwe kusvikira kune rimwe, marudzi ose achauya kuzokotama pamberi pangu,” ndizvo zvinotaura Jehovha.  
\v 24 “Vachabudapo vachindotarira zvitunha zvaavo vaindimukira; honye yavo haizofi, moto wavo haungadzimwi, uye vachasemesa vanhu vose.”