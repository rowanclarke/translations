\v 11 “\w Manghai|strong="H4428"\w* kah \w sal|strong="H5650"\w* rhoek \w boeih|strong="H3605"\w* \w neh|strong="H9999"\w* \w pilnam|strong="H5971"\w* khaw, \w manghai|strong="H4428"\w* kah \w paeng|strong="H4082"\w* long khaw, \w huta|strong="H0802"\w* \w neh|strong="H9999"\w* \w tongpa|strong="H0376"\w* \w boeih|strong="H3605"\w* khaw, \w a|strong="H9909"\w* \w olkhan|strong="H1881"\w* \w pakhat|strong="H0259"\w* nen khaw a \w khue|strong="H7121"\w* \w pawt|strong="H3808"\w* ah \w vongup|strong="H2691"\w* \w khui|strong="H6442"\w* \w la|strong="H0413"\w* \w manghai|strong="H4428"\w* \w taengla|strong="H0413"\w* aka \w mop|strong="H0935"\w* tah a \w duek|strong="H4191"\w* \w ham|strong="H9997"\w* coeng ni, \w manghai|strong="H4428"\w* loh \w a|strong="H9909"\w* \w taengah|strong="H9997"\w* \w sui|strong="H2091"\w* \w mancai|strong="H8275"\w* a \w doe|strong="H3447"\w* \w bueng|strong="H0905"\w* ni \w dawk|strong="H9997"\w* a \w hing|strong="H2421"\w* \w khaw|strong="H9999"\w* na \w ming|strong="H3045"\w* uh. \w Tedae|strong="H9999"\w* \w kamah|strong="H0589"\w* he \w manghai|strong="H4428"\w* \w taengla|strong="H0413"\w* \w kun|strong="H0935"\w* \w ham|strong="H9997"\w* akhaw \w khohnin|strong="H3117"\w* \w sawmthum|strong="H7970"\w* khuiah n'\w khue|strong="H7121"\w* \w moenih|strong="H3808"\w*,” tila a \w uen|strong="H6680"\w*.  
