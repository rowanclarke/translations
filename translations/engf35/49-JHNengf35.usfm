\v 30 \w So|strong="G3767"\w* \w they|strong="G2532"\w* \w tried|strong="G2212"\w* \w to|strong="G2532"\w* \w arrest|strong="G4084"\w* \w Him|strong="G3588"\w*, \w yet|strong="G2532"\w* \w no|strong="G3762"\w* \w one|strong="G3762"\w* \w laid|strong="G1911"\w* \w a|strong="G2532"\w* \w hand|strong="G5495"\w* \w on|strong="G1909"\w* \w Him|strong="G3588"\w* \w because|strong="G3754"\w* \w His|strong="G1909"\w* \w hour|strong="G5610"\w* \w had|strong="G2532"\w* \w not|strong="G3762"\w* \w yet|strong="G2532"\w* \w come|strong="G2064"\w*.
