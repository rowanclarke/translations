\v 26 \w Manghai|strong="G0935"\w* \w loh|strong="G3588"\w* \w ngang|strong="G4036"\w* a \w yaak|strong="G1096"\w* dae a \w olhlo|strong="G3727"\w* \w neh|strong="G2532"\w* aka \w ngol|strong="G0345"\w* \w rhoek|strong="G3588"\w* \w kongah|strong="G1223"\w* te \w aal|strong="G0114"\w* hamla \w ngaih|strong="G2309"\w* \w pawh|strong="G3756"\w*.  
\v 27 \w Tedae|strong="G2532"\w* \w manghai|strong="G0935"\w* \w loh|strong="G3588"\w* \w rhalkap|strong="G4688"\w* \w koe|strong="G2117"\w* a \w tueih|strong="G0649"\w* tih \w a|strong="G0846"\w* \w lu|strong="G2776"\w* \w te|strong="G3588"\w* hang \w khuen|strong="G5342"\w* ham \w ol|strong="G2004"\w* a paek. Te \w dongah|strong="G2532"\w* \w cet|strong="G0565"\w* tih \w Johan|strong="G0846"\w* te \w thongim|strong="G5438"\w* \w khuiah|strong="G1722"\w* a \w rhaih|strong="G0607"\w*.  
