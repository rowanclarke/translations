\v 13 \w Mael|strong="H7725"\w* mai dae, \w mael|strong="H7725"\w* mai dae, \w Sulamit|strong="H7759"\w* \w aw\w* \w mael|strong="H7725"\w* mai dae, \w mael|strong="H7725"\w* mai dae, \w namah|strong="H9903"\w* \w te|strong="H9996"\w* ni kan \w dan|strong="H2372"\w* eh.
\sp Tongpang
\p \w Balae|strong="H4100"\w* \w tih\w* \w Sulamit|strong="H7759"\w* \w tah|strong="H9996"\w* \w rhaehhmuen|strong="H4264"\w* \w lamcawn|strong="H4246"\w* \w la|strong="H9995"\w* n'\w dan|strong="H2372"\w* eh?
\c 7
\q1 
\v 1 Na kho te hlangcong canu kah
\q2 khokhom neh sawtthen tangkik.
\q1 Na phai dongkah phaibong khaw
\q2 kutthai kut kah bibi neh himbai bangla om.
\q1 
\v 2 Na yenrhui te kueluek baeldung bangla
\q2 homtui long khaw vaitah pawh.
\q2 Na bungko te khaw tuilipai loh cang hlom neh a ven.
\q1 
\v 3 Na rhangsuk rhoi tah
\q2 sakhi rhuinu caphae ca rhoi van pawn ni.
\q1 
\v 4 Na rhawn tah rhaltoeng vueino van pawn ni.
\q2 Na mik tah Bathrabbim vongka kah
\q2 Heshbon tuibuem van pawn ni.
\q2 Na hnarhong tah Damasku rhaldan aka tawt
\q2 Lebanon rhaltoengim van pawn ni.
\q1 
\v 5 Na sokah na lu tah Karmel tlang van pawn ni.
\q2 Na lu samloeng tah manghai sammuei,
\q2 daidi samdueng van pawn ni.
\q1 
\v 6 Lungnah, omthenbawnnah neh
\q2 sawtthen tangkik tih hmae tangkik.
\q1 
\v 7 Na sang loh rhophoe a puet tih
\q2 na rhangsuk loh thaihsu coeng he.
\q1 
\v 8 “Rhophoe dongah ka yoeng saeh lamtah
\q2 a koi te ka hlan eh,’ ka ti.
\q2 Na rhangsuk tah misur thaihsu bangla om laeh saeh.
\q2 Na hnarhong hmueih tah thaihthawn van pawn ni.
\q1 
\v 9 Na ka tah misurtui then van pawn ni.
\sp Oila
\q2 Kamah hlo taengah caeh vaengah no neh
\q2 lai khaw vanat la khuep uh.
\q1 
\v 10 Kamah he kamah hlo kah coeng tih
\q2 a lungdueknah tah kamah ham saeh.
\s1 Tongpang te Lungnah a Paek
\q1 
\v 11 Kamah hlo aw halo lamtah pong la cet lah sih,
\q2 vangca ah khaw rhaeh mai sih.
\q1 
\v 12 Thoo sih, misurdum te so sih.
\q2 Misur khaw a cuen khaming,
\q2 thaihmoe loh culh tih tale khaw khooi coeng.
\q2 Teah te kamah hlo te nang taengah kam pae eh.
\q1 
\v 13 Hloih he a bo rhim.
\q2 Tedae mah kah thohka ah
\q2 cangtham he a rhuem a thai la cungkuem tih
\q2 ka hlo nang ham ka khoem.
\c 8
\s1 Thintlo A Rhing
\p 
