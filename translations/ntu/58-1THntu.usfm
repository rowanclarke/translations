\id 1TH stc-531TH-Nat.sfm, 1 Thessalonians, Natqgu (Santa Cruz) STC, Daniel Boerger, 11/07/2007
\ide UTF-8
\h 1 Tesalonika
\toc3 1 Tesalonika
\toc1 Nzryr-krbz Pol Kx Ayrnrngr Mz Lr Tesalonika
\toc2 1 Tesalonika
\mt1 Nzryr-krbz Pol Kx Ayrnrngr Mz Lr Tesalonika
\imt1 Natq Ngr Nzaplxtqngr Mz Nzryr-krbz Pol Kx Ayrnrngr Mz Lr Tesalonika
\ip Letz lc yrbz aposol Pol mz dzbe lrmakxtr kcng taon kxetu Tesalonika mz provins kc Masedonia. Mzbq ka Masedonia nzrpipebz kandre kc Gris. Oklatile nidr mz nzvzpx-krde krali x yapwxtipxbzle Nrpakxmrlz badr. KxtrngiulrJiu kxnzkqlung x kzdung lr Jiu nzlxngitilr Jiszs mzli lc. \x + \xo 1:0 \xt Aposol 17:1-15\x* A' kzdung lr Jiu kxtrnzrlxngitiung nzngyati drtwrdr nide x nzbatrpzlr kzdq nzotablrngr kxetu. Delc kxnzrlxngiting tzatwzlrpx-ngrdr Pol badr Timoti x Saelas mz taon kc Berea. Zbz Pol atwzlr-mopwzle Timoti x Saelas mz nzalvztr-krdr lr Tesalonika. Mz nibr kzdung mzli, Pol yrle letz lc mz nzayzlu-krbzle kzdung da kx rlwa-ngrbz Timoti bade.
\ip Yrle letz lc mz mzlir yiz 50—51 AD mz nibr nzrmcngr mz Jiszs, mzli kc tqmnc-ngrde Korint. Mwx krlc buk ayrnrngr kx nzyr mz Nzryrngrkxtr Kc Ate.
\iot Mrkcng Mz Letz Lc
\io1 Pol abrtzlvzle nqmq kr lr Tesalonika. \ior [dckrlzde 1]\ior*
\io1 Pol ayzlubzle natq kxnzpibqti-ngrdr nqmq krde. \ior [2:1-16]\ior*
\io1 Nike troklati-mou-ngrdeu nidr x nike tqatwzlr-ngrbzle Timoti badr. \ior [2:17—3:13]\ior*
\io1 Kxnamu nzmnc-zpwx-krdr badr Gct x kztedrng. \ior [4:1-12]\ior*
\io1 Pol ayzlubzle natqdr mz kxnzrlxngiting kcng tzbzpeng x mzli kc nayzlu-mou-ngrm Jiszs. \ior [4:13—5:11]\ior*
\io1 Alvztr-kzle nidr kxnamu nzmnc-zpwx-lxblr-krdr. \ior [5:12-28]\ior*
\c 1
\p 
\v 1 Ninge Pol, nigr ncdr Saelas x Timoti. Ryrbzkr bamu, nimu leplz neng Gct Trte x Kxetu rgu Jiszs Kxnzmcpx, kcng tzmncng taon Tesalonika.
\p Krka'-ngrgr kx Gct naokatrle nimu mz zmrlz ngrde kxmyalz x namnc-zpwxamu.
\s1 Nqmq Kr Lr Tesalonika
\p 
\v 2-3 Mzli kx krka'-ngrbzkr mz Trtegu Gct, awi-zvz-ngrbzkr bade nimu amrlx. Murde aelwapx-ngrnamu nzrlxngiti-krmu mz nzwztr-krbzmu bade. X aelwapx-ngrnamu nivz lrmu mz nzokatr-krmu leplz. X aelwapx-kz-ngrnamu nzobqtipx-krmu nzyzlu-krm Kxetu rgu Jiszs Kxnzmcpx. Mz nztu-amqngi-zvz-krmu mz mzli r nzatrkatingr.
\p 
\v 4 Gct mrlztile nimu. X krlzkr kx mcpxle nimu mz nzngini-krmu leplz nedeng.
\v 5 Murde mzli kc lemgr bamu Nrpa ngr Jiszs Kxnzmcpx, trpi-txpwzkru mz natq. A' aelwapx-kz-ngrgr mz zmatq, mz nzokatrkr Mqngrkxtr, x mz nzrlxngiti-angidrngr. X krlz-kzamu kx aelwapx-ngrgr Nrpakxmrlz lc mz nzmnc-krgr, mzli kc tqmnc-ngrbzkr bamu. Da kcng amrlx tqalebzkr bamu, ngi dalr nzokatrngr nimu.
\v 6 X nigr badr Kxetu kx ngibz lrpzki bamu kx navz-nqblqamu. Kxmule-esz' sc tzatrkatimu, a' sc tqlxngitiamu Nrpakxmrlz mz nzabrtzngr kx vzpxm mz Mqngrkxtr.
\v 7 Mz nzmu-krde lcde, nanginibzmu lrpzki mz leplz neng Kraes mz provins kcng Masedonia x Akaia.
\v 8 Murde nzaetunepx-krmu Nrpa ngr Kxetu Jiszs Kxnzmcpx trngi-txpwzu Masedonia x Akaia, a' nrpa ngr nzrlxngiti-krmu nzkrlzpe mrlcng kqlu. Dekc, trpnzngr da kx napitr-mopwzkr mz nzrlxngiti-krmu.
\v 9 Lr mztea lcng tzyapwxtipelr nzmrlzkr nqmq krmu mz nzabrtzlvz-krmu nigr. Se tzyapwxtine nzesakikr nzangio-krmu mqngr drka' kxnzlz, kx trpnzngr nzlu-krdr. X tekqtrpeamu nqmq krmu mz nzwztr-nrbalq-krbzmu mz Yawe Gct angidr kc tqlu alo.
\v 10 X aenzliamu nzvzo-krm Mrlxde Heven, kc tqatulzmle mz nzbz-krde. Krlc Jiszs kc tqarlapxbzle nigu mz zngya ngr drtwr Gct kc navzm mzli kc napipxngr neke tubq x neke vz-rbr.
\c 2
\s1 Nzwzkr Pol Tesalonika
\p 
\v 1 Mzlegrng x inwegrng, krlzpeamu kx nzvz-krbzkr bamu ngi da kx nrade ycbz.
\v 2 Mzli kc trvzka-ngrpgr bamu, drtqgr etqtx x nzamyatibz mztea Filipae. Nzmusr-krdr lc nigr krlzamu. Kxmule-esz' nzxplrmimlr bagr nzrpwa'-krdr nzwz-krgr, a' Gct rgr abrmle nelzgr mz nzpipx-krbzkr Nrpakxmrlz bamu.
\v 3 Dekc, tqkrlz-ngrnamu kx nzrpipx-krgr Nrpakxmrlz trvzpxpuu mz drtwr ngr nzpokiangr, drtwr kxtrka, x mz drtwr ngr nzesabrtingr.
\v 4 A' pipxkr murde Gct kc tqabzpx-kaile nigr x aprc-atemle nzwzngr lc bagr. Trsutiu drtwrgr leplz nzabrtzlvz-krdr nigr, a' sutitx drtwrgr Gct kc tqobqplxle nabzgr nzabrtzlvz-krde nigr.
\v 5 X krlz-zpwxamu kx trtamitikru nimu mz nzycmne-krgr x tresabrtikru nimu mz nztwz-krgr trau scmu. Krlz Gct kx da lc da zpwx.
\v 6 X trsutiu drtwrgr kx naglqlzamu nigr o naglqlz kzdung kz leplz nigr. Kxmule-esz' nigr aposol neng Kraes, x takitrde nzokatr-krmu nigr x nzamatq-krmu nigr, a' trwaipwzkru lc bamu.
\v 7 A' mzli kc tqmnc-ngrgu, mnc-nrwxbzkr apubzkr bamu lxe doa, kc tqaclvele itoto nede.
\v 8 Abrtzlvz-ngrgr nzrpipx-ngrbz bamu Nrpa ngr Gct murde aodukr nimu. X abrtz-kzkr nzka-lzbq-krbzkr bamu murde pqtr zlwz mz drtwrgr nimu.
\v 9 Mzlegrng x inwegrng, krlzx kx sc tqdcpxbe mz drtwrmu kxmu nzwz-kato-krgr. Mzli lc tqyapwxtipx-ngrbzkr Nrpakxmrlz bamu, wzkr mz nrlckxbq x ngrlx mz nzatatr-krmgr trau, murde ma tqaetunepxkr nzwz-krmu.
\p 
\v 10 Mzli kc tqmnc-ngrgu, krlz-zpwxamu kx nzmnc-krgr tr x tubq, x trpnzngr da kx trkatr elr. X krlz Gct kx krlc da angidr.
\v 11 Krlz-kzamu kx apusr-ngrgr nimu doa negrng.
\v 12 Axplrkr nimu, apqtrpzkr drtwrmu, x pibzkr bamu kx nzmnc-krmu natubq, murde natakitrde Gct kc tqkqlele nimu mz nzmnclz-krbzmu bade x mz nzprtr-krmu mz nzmyalz-krde.
\p 
\v 13 X awi-zvzbzkr mz Gct. Murde mzli kc lemgr bamu Nrpa ngr Kraes, xlramu x lxngitiamu. X lxngiti-kzamu kx nrpa lc tqngi natq Gct angidr, trngiu natq ncblo. X me tutr-ngrde lape! X natq Gct lc tqatutrle nzwz-krde mz nabzmu, nimu kcng tzbrtipe drtwrmu Jiszs.
\v 14 Mzlegrng x inwegrng, prtramu mz nzatrkatingr kcpwz tzprtrng lr Jiu kcng tzlxngitilr Mevalu Jiszs, tzmncng mz Judiz Provins. Murde lr mrnyzdr nzatrkatilr nidr, da kc tzwaisr-ngrdr lr mrnyzmu nzatrkati-krdr nimu.
\v 15 Lr Jiu lcng, melrmqdrng nznibq-kailr profet. X mz nibrdr, trtedrng nznibq-kzlr Kxetu rgu Jiszs Kxnzmcpx. X mzli ka, sc tzmaszlrpe-kz-ngrdr nigr. Gct trabrtzlvzleu lr Jiu lcng, murde nzpxtxpx-ngrdr leplz amrlx,
\v 16 mz nzrpwa'-krmlr bagr nzle-krbzkr nrpa ngr nzarlapxngr mz kxtrngiulrJiu. Mz nzmu-krde lcde, tzrtxlvzlz-zvzpelr alwx ngrdr. A' mzli ka zngya ngr drtwr Gct ycpe pipz nzkrlz-krbzle nidr.
\s1 Suti Drtwr Pol Naoklati-mouleng
\p 
\v 17 Mzlegrng x inwegrng, mzli kc tqmnctitxtrpemgr mzli mrbcnepwz mz nrkrdrtq, sutitx zlwz drtwrgr nzoklati-kr-mopwzkr nimu, a' sc tqrblxm bagr. Kxmule-esz', a' krlzku kx mz drtwrgr nigu kc tqmncku.
\v 18 Sutitx zlwz drtwrgr nzyzlu-krbzkr bamu. X ninge, Pol, abz-ngrnele nzwrde kqlupe, a' Setzn tqrpwa'-ngrde nzvz-krbzkr.
\v 19 Suti drtwrgr nzoklati-mou-krmgr nimu murde obqtipxkr nzmc-krgr nztu-amqngi-krmu mz nzrlxngitingr. Mz nzmu-krde lcde, sa nanginimu kx nabatrpzle nzaelalz-krm drtwrgr! X sa na-apuamu da kxmrlz kx natwzkr mz nzwz-krgr. X sa naglqpx-lzbq-ngrgr nimu mzli kc natu-lxblr-ngrbzku mz mz Jiszs Kxnzmcpx mzli kc nayzlu-mou-ngrmle!
\p 
\v 20 Da zpwxtx! Nimu kx nabatrpzle nzelalz-krm drtwrgr x nimu kx nzglqlzngr nigr.
\c 3
\p 
\v 1 Mzli kc tqrblxtxpe nzaenzli-krgr x tqxngitr-zlwzkr nzmnc-rlru-krmamu bagr, sc tqaotipe drtwrgr kx nigr badr Saelas namnc-txpwzkr taon kc etu Atens,
\v 2-3 x na-atwzlr-ngrbzkr Timoti bamu. Nide mzlegr kx wzkr badr mz nzwztr-krbzkr Gct. Okatrle nigr mz nzyapwxtipx-krbzle Nrpa ngr Kraes. X atwzlr-ngrbzkr nide murde na-axplrle nimu x na-apqtrpzle nabzmu. Murde ma nzrlxngiti-krmu tqrnrc mz nzkxpungr kcng tqprtzmqng bamu mzli ka. Murde krlzpeamu kx da kxmule lcng naprtzmqng bagu.
\v 4 Murde pi-pnzbzkr ena bamu mzli kc tqmnc-ngrgu, kx leplz sa na-atrkatilr nimu kalr. X mzli ka da kc tqpi-ngrbzkrle sc tqtutrpe.
\v 5 Mz nzmu-krde lcde, mzli ka rblxtxpe nzaenzli-krgr, delc tqatwzlrpe-kai-ngrbo Timoti bamu, murde nakrlzx kxmupe nzrlxngiti-krmu. X mwxlrlvzx nimu murde ma tqataole nimu Setzn, x nzwz-krgr sc tqngipe brmrda.
\p 
\v 6 A' mzli ka Timoti yzlupe-mop bagr x lemle bagr nrpa ngr nzrlxngiti-krmu x nivz lrmu. Pimle bagr kx dcpx zvz mz drtwrmu nigr x sutitx zlwz drtwrmu nzmc-krmu nigr, da kc tqwai-kzkr nzsutikr drtwrgr nzmc-krgr nimu.
\v 7 Mz nzmu-krde lcde, kxmule-esz' nzatrkatilr nigr mz da kxkqlu, a' apqtrle drtwrgr nzxlr-krgr nrpa ngr nzrlxngiti-krmu.
\v 8 X mnc-zpwxpekr mz nzxlr-krgr nzlolvz-amqngi-krmu Kxetu rgu.
\v 9 X rblxm bagr nzpipx-krgr natq ngr nzawi-krbzkr mz Gct mz nzetukr nzabrtzlvz-krgr nimu.
\v 10 X nzkrka'-krgr pq zvz, ngrlx x nrlckxbq. Krka'-ngrgr kx namc-moukr nimu x na-alvztr-ngrbzkr bamu da amrlx kcng tqmrbrpxm mz nzrkrlz-krmu nzrlxngiti-krgu.
\p 
\v 11 Krka'ngr mz nzrpi-krgr kx,
\p “Gct Trtegr x Kxetu rgr Jiszs, rlxtibzkr bamu naoliqtipxbzmu lrpzki kc nakrlz-ngrbzkr lr Tesalonika.
\v 12 X krka'-kz-ngrgr kx na-aetunepxbzmu nivz lrdr mz nzmrlzti-lzbq-krdr x nzmrlzti-krdr leplz amrlx, x namrlztilr leplz da kc tqwai nzmrlzti-krgr nidr.
\v 13 Trte, axplr nabzdr, murde natrng x natubqng mz nzobq-krm, myapxbz mzli kc Kxetu rgr Jiszs nayzlu-ngrmlr badr leplz kxnztr nedeng. Eu. Angida!”
\c 4
\s1 Nzmncngr Kx Abrtzlvz Gct
\p 
\v 1 Mzlegrng x inwegrng, alvztrpekr nimu mz nzmncngr kxtubq, murde na-aelalz-ngrm drtwr Gct, x sc tqvz-nqblqpeamu. X mzli ka rngidrtx-zlwz-ngrbzkr bamu mz zmatq ngr Kxetu rgu Jiszs, kx nzmnc-krmu lc tqtubq navz zvz x naetunepx.
\v 2 Krlzpeamu nike pibzkr bamu, mz zmatq ngr Kxetu rgu Jiszs.
\v 3 Me pnz drtwr Gct nide sele: Nzmnc-krmu natramu, x nayrlqpx-lzbqamu mz alwx ngr nzrmwimi-krmu doa kxtrngiu krnalzmu.
\v 4 Suti drtwrde kx doa kxesz' mz nimu nakrlzle nzaclve-krde nrkrdrtqde mz nzmncngr kxtr x kxtubq.
\v 5 Leplz kcng trnzkrlzlru Gct nzrlrpx-ngrdr nrkrdrtqdr nzmailz-krdr nidr mz alwx ngr nzrmwimingr doa kxtrngiu krnalzdr. A' bzkq apuamu nidr.
\v 6 X bzkq angqngutiamu kztemu mz da lc. Murde Gct sa na-ayrplapx-zlwzle leplz kx nzrtrngztibzlr da lcng. Dekc tqpi-ngrbzkrle ena bamu mz natq kxlqlwx.
\v 7 Gct kqlele nigu murde nzmnc-krgu natr. X trsutiu drtwrde nzrtrngzti-krbzku alwx ngr nzrmwimingr kxtrngiu krnalzgu.
\v 8 Mz nzmu-krde lcde, mrlx kx pxtxpx-ngrde nzalvztrngr lc, pxtxpx-kz-ngrde Gct, kc tqrkam bagu Mqngrkxtr.
\p 
\v 9 Tryrpwzkru kxnamu nzmrlzti-krmu kztemung mz Kraes, murde opx angidr kx Gct alvztrpe-ngrde nimu da lc.
\v 10 Murde mrlztiamu leplz neng Kraes mz mztea amrlx mrkc Masedonia Provins. A' mzli ka, rngidrtr-ngrbzkr bamu kx nzmrlzti-krmu nidr naetunepx zvz.
\v 11 Rtrngztibzmu da kc tqbatrpzle nzmnc-krmu mz nrwx. Bzkq pnz drtwrmu dztu leplz, a' dztumu. X aleamu nzwz-krmu esz'-krmu. Pi-pnzbzkr bamu ena nzale-krmu da lcng.
\v 12 Murde mz nzmnc-krmu lc tqmrlz, leplz kcng trnzlxngitilru Kraes na-amatqlr nimu x ma tqmnc-xgleamu doa kc-kzng.
\s1 Nzyzlu-krm Kxetu Rgu
\p 
\v 13 Suti drtwrgr nakrlzamu nike naprtzbz mz leplz neng Kraes kcng tzbzpeng. Murde trsutiu drtwrgr nzmnc-krmu mz drtwr kxvz mz nzapu-krmu leplz kx trpnzngr da kx nzobqtipxlr.
\v 14 Lxngitiku kx Jiszs bz x tulz mou. Mz nzmu-krde lcde, Gct sa na-atulz-kzple krkcng tzbzpeng tzlxngitilr Jiszs, murde navzmimle nidr, mzli kc nayzlu-ngrmle.
\p 
\v 15 Nzalvztrkr Kxetu nide sele. Nigu kcng tzlubeng mzli kc nayzlu-ngrm Kxetu rgu, trnartwayzpwzkuu mz krkcng tzbzpeng, mz nzvzdz-ngrbz mz nzrmctingr nide.
\v 16 Murde mzli kc Kxetu rgu navzom Heven, lr nrlc sa naxlrlr dq nzkabongr, natq narenjrl, x trpu r nzkqkr Gct. X leplz neng Kraes kx nzbzpeng natulz-kaipqng.
\v 17 X mz nibrde, nigu kcng tzlubeng x kxnzlu-moung sa navzdz-lxblrku mz nabz dcbz, mz nzyrlwrpx-lxblr-krgu badr Kxetu mrlc mzlilxlr. X sa namnc-lxblr-aloku badr Kxetu! \x + \xo 4:17 \xt Luk 17:34-36\x* \fig Leplz neng Kraes kx nzbzpeng natulz-kaipqng x kxnzrlxngiting kcng tzlubeng kc ate.|alt="114 one taken while other stays" src="114-GNp38.tif" size="SPAN" loc="1TH 4:17" copy="LLL Language Recording" ref="4:17"\fig*
\v 18 Mz nzmu-krde lcde, apqtr-etramu nabzmu mz nzpipx-krmu natq lcng.
\c 5
\s1 Naoliqti-zvzku Nzyzlu-krm Kxetu
\p 
\v 1 Mzlegrng, mzli ka trnayrpwzkru bamu mz mzli kc na-adcpx-lzbq-ngrm Kxetu rgu o zbq kc nayzlu-ngrmle.
\v 2 Murde krlzpeamu kx mzli lc nakctipx, na-apule ncblo kc tqpna da mz nrlckxbq.
\v 3 Leplz kx trnzrlxngitiung narpilr kx, “Nigr ka tqmnc-zpwxpekr ye mz nrwx.” A' mzli lcde, nzayrplapxngr nidr sa na-ani txpwz, na-apule nimz ngr zvetqkr nibr olvz kx narmika. X sa narblxbz mz leplz lcng nzrlapx-krdr mz nzlva-krdr.
\v 4 A' trnakctipxwamuu nzvz-krm Mzli lc Tqmatq, mz nzapu-krde nzvz-krm ncblo kc tqpna da. Murde trvz-nqblqpewamuu nqmq ngr alwx.
\v 5 A' nimu doa neng Kraes kcng tqvz-nqblqamu nzalvztrngr angidrng x aleamu da kxtubq. A' tralepekuu da kx amyale drtq kcng tqyc-kapq.
\v 6 Bzkq apuku kxtrnzrlxngitiung. Murde alwx ngrdrng nzakamrbr-ngrdr da mz nabzdr x nzapulr leplz kx nzmwing, murde trnzkrlzlru drtwr ngr da kx prtilzmqng mzli ka mz nrlc. Mz nzmu-krde lcde, na-aclvetio-lzbqku x nalolvzo-lzbqku.
\v 7 Murde nrlckxbq mzli r alwx, mzli r nzmwingr, x mzli r nzrmnqngr.
\v 8 Mz nzvz-nqblq-krgu nzalvztrngr angidr, na-aclvetio-lzbqku. Na-apuku ncblo ngr vea mz nzvec-krgu badr Setzn. Nzrlxngiti-krgu x nivz lrgu na-ayrbqpxle nabzgu na-apule temz ngr lomrgu kc tqyrputrngr nipna. X nzarlapxkr Kraes nigu na-ayrbqpxle drtwrgu na-apule da kxmqngi kx nalalvzle nar ncblo ngr vea, murde mz drtwrgu kxbr, obqtipxku da amrlx kx vzpxm mz nzarlapx-krde nigu. \fig Da kxmqngi kx nalalvzle nar ncblo ngr vea.|alt="115 soldier in helmet" src="115-CN02024b.tif" size="COL" loc="1TH 5:8" copy="David C. Cook" ref="5:8"\fig*
\v 9 X nadcpx mz drtwrgu kx Gct mcpxle nigu x arlapxpele nigu mz nzbzkr Kxetu rgu Jiszs Kxnzmcpx. A' trmcpxleu nigu mz nzayrplapx-alo-krde nigu.
\v 10 Kxmule-esz' bzpeku o lubeku mzli kc nayzlu-ngrm Jiszs, a' bz-ngrde murde nalu-zvzku badr.
\v 11 Mz nzmu-krde lcde, apqtramu drtwrmu x axplr-lzbqamu da kc tqwaiamu mzli ka.
\s1 Natq Ngr Nzarlr-lzbqngr
\p 
\v 12 Mzli ka, mzlegrng x inwegrng, na-amatqamu krkcng tzwz-katong mz mzlirmu, mz nzaclve-krdr nimu mz zmatq ngr Kxetu x mz nzalvztr-krdr nimu.
\v 13 Mz nivz angidr, aelwa-ngrbzmu badr kx amatqamu nidr mz nzwzngr kcng tzalebzlr bamu. X mnc-zpwx-lxblramu.
\p 
\v 14 Mzlegrng x inwegrng, lalztqmamu bagr. Axplrbzmu natqmu mz krkcng drtqdr tqsa. Apqtrpzmu drtwr krkcng tzmwxlrng. Okatramu krkcng nabzdr tqbao mz nzlxngiti-krdr. X mnc-zpwxamu badr leplz amrlx.
\v 15 Aclvetio-lzbqamu x bzkq ayzlubzmu da kxtrka mz da kxtrka. A' na-alebzmu da kxmrlz mz kztemung x leplz amrlx.
\p 
\v 16 Naelalz-zvz-ngrm drtwrmu!
\v 17 Nakrka'-zvzamu!
\v 18 Kxmule-esz' nike prtz, a' na-awi-zvz-ngrbzmu mz Gct da lc. Murde suti drtwrde kx doa amrlx kcng tzlxngitilr Jiszs na-awi-zvzbzng bade.
\p 
\v 19 Bzkq rpwa'-ngrnamu nzwzkr Mqngrkxtr.
\v 20 Bzkq apusr-ngrnamu natq x nrpa kc tqaelwapx-ngrbz Mqngrkxtr mz leplz brmrda.
\v 21 A' mzli kc tqrpingr kzdq ncblo kx natqde aelwa-ngrbz Mqngrkxtr, naobqtitr-kaiamu da amrlx. X yrlq-zvzamu natq kxmrlz.
\v 22 A' yrlqpx-lzbqamu mz natq kxtrka amrlx.
\p 
\v 23 Nzkrka'-krgr nimu nide sele:
\p “Gct, nim kc tqrkam bagr nzmnc-zpwxngr. Krka'-ngrgr kx na-atrq nidr mz da amrlx. Murde nztubq-krdr mz mqngrdr, nabzdr, x nrkrdrtqdr navz nakrlzbzle nzyzlu-krm Kxetu rgr Jiszs Kxnzmcpx.
\v 24 Nim kc tqkqlepele nidr. X lxngitikr kx sa na-atutrq natqmqng amrlx. Eu. Angida!”
\p 
\v 25 Mzlegrng x inwegrng, nakrka'-kz-ngrnamu nigr.
\v 26 Pibz “Nimu la,” mz inwegung x mzlegung amrlx mrla, mz nzmale-lxblr-krmu mqmu mz nivz.
\v 27 Rngidrtx-zlwz-ngrbo bamu mz zmatq ngr Kxetu, kx natqgr lcng narlwxbz mz leplz neng Kraes amrlx.
\p 
\v 28 Krka'-ngrgr kx Kxetu rgu Jiszs Kxnzmcpx naokatrle nimu mz zmrlz ngrde kxmyalz.
\cls Delape. Ninge \sig Pol\sig*,
\cls nigr ncdr \sig Saelas\sig* x \sig Timoti.\sig* 
