\v 19 \w No|strong="H3808"\w* \w hubo|strong="H1961"\w* \w guerra|strong="H4421"\w* \w hasta|strong="H5704"\w* el \w año|strong="H8141"\w* 35 del \w reinado|strong="H4438"\w* \w de|strong="H5704"\w* Asa.   
\c 16  
\s1 Lucha de Asa contra Israel  
\p
\v 1 \w El|strong="H5921"\w* \w año|strong="H8141"\w* 36 \w del|strong="H5921"\w* \w reinado|strong="H4428"\w* \w de|strong="H5921"\w* Asa, \w Baasa|strong="H1201"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w subió|strong="H5927"\w* \w contra|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* fortificó \w a|strong="H3068"\w* \w Ramá|strong="H7414"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* nadie tuviera acceso \w a|strong="H3068"\w* Asa, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.   
\p
\v 2 Entonces Asa \w sacó|strong="H3318"\w* la \w plata|strong="H3701"\w* y \w el|strong="H3427"\w* \w oro|strong="H2091"\w* de \w los|strong="H3427"\w* tesoros de la \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd* y del palacio \w real|strong="H4428"\w*, \w los|strong="H3427"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w Ben-adad|strong="H1130"\w*, \w rey|strong="H4428"\w* de Siria, quien \w estaba|strong="H3427"\w* \w en|strong="H3318"\w* \w Damasco|strong="H1834"\w*, y le dijo:  
\v 3 Haya \w alianza|strong="H1285"\w* \w entre|strong="H5921"\w* tú \w y|strong="H5921"\w* \w yo|strong="H2009"\w*, \w como|strong="H5921"\w* \w la|strong="H5921"\w* \w hubo|strong="H2009"\w* \w entre|strong="H5921"\w* \w mi|strong="H5921"\w* padre \w y|strong="H5921"\w* tu padre. \w Ciertamente|strong="H2009"\w* \w te|strong="H5921"\w* \w envío|strong="H7971"\w* \w plata|strong="H3701"\w* \w y|strong="H5921"\w* \w oro|strong="H2091"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* fin \w de|strong="H5921"\w* \w que|strong="H5921"\w* rompas tu \w alianza|strong="H1285"\w* \w con|strong="H5921"\w* \w Baasa|strong="H1201"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* aparte \w de|strong="H5921"\w* \w mí|strong="H5921"\w*.   
\p
\v 4 \w Ben-adad|strong="H1130"\w* \w atendió|strong="H8085"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* Asa y \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w jefes|strong="H8269"\w* \w de|strong="H8269"\w* sus \w ejércitos|strong="H2428"\w* \w contra|strong="H3478"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H8269"\w* \w Israel|strong="H3478"\w*. Atacaron \w a|strong="H3068"\w* Ijón, \w a|strong="H3068"\w* \w Dan|strong="H1835"\w*, \w a|strong="H3068"\w* Abel-maim y \w a|strong="H3068"\w* \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H8269"\w* almacenamiento \w de|strong="H8269"\w* Neftalí.  
\v 5 \w Aconteció|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* \w Baasa|strong="H1201"\w* \w oyó|strong="H8085"\w* esto, \w dejó|strong="H2308"\w* de fortificar \w a|strong="H3068"\w* \w Ramá|strong="H7414"\w* y abandonó su \w obra|strong="H4399"\w*.  
\v 6 Entonces \w el|strong="H3605"\w* \w rey|strong="H4428"\w* Asa \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w* y se \w llevó|strong="H3947"\w* las piedras y \w la|strong="H3605"\w* \w madera|strong="H6086"\w* de \w Ramá|strong="H7414"\w*, con las cuales \w Baasa|strong="H1201"\w* \w la|strong="H3605"\w* fortificaba. Con ellas \w reedificó|strong="H1129"\w* Geba y \w Mizpa|strong="H4709"\w*.   
\p
\v 7 \w En|strong="H5921"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w el|strong="H1931"\w* \w vidente|strong="H7200"\w* \w Hanani|strong="H2607"\w* \w fue|strong="H1931"\w* \w a|strong="H3068"\w* Asa, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w y|strong="H5921"\w* \w le|strong="H1931"\w* dijo: \w Por|strong="H5921"\w* \w cuanto|strong="H3651"\w* \w te|strong="H5921"\w* apoyaste \w en|strong="H5921"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* apoyaste \w en|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* tu \nd ʼElohim\nd*, \w el|strong="H1931"\w* \w ejército|strong="H2426"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria \w escapó|strong="H4422"\w* \w de|strong="H5921"\w* tu \w mano|strong="H3027"\w*.  
\v 8 ¿\w Los|strong="H5921"\w* etíopes \w y|strong="H5921"\w* \w los|strong="H5921"\w* libios \w no|strong="H3808"\w* \w eran|strong="H1961"\w* un \w ejército|strong="H2428"\w* \w numerosísimo|strong="H7230"\w*, \w con|strong="H5921"\w* carruajes \w y|strong="H5921"\w* \w muchos|strong="H7235"\w* \w jinetes|strong="H6571"\w*? \w Sin|strong="H3808"\w* embargo, \w porque|strong="H5921"\w* \w te|strong="H5921"\w* apoyaste \w en|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w Él|strong="H5921"\w* \w los|strong="H5921"\w* \w entregó|strong="H5414"\w* \w en|strong="H5921"\w* tu \w mano|strong="H3027"\w*.  
\v 9 \w Porque|strong="H3588"\w* \w los|strong="H5921"\w* \w ojos|strong="H5869"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* contemplan \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra, \w para|strong="H5921"\w* ayudar \w a|strong="H3068"\w* \w aquellos|strong="H3605"\w* cuyo \w corazón|strong="H3824"\w* \w es|strong="H3588"\w* \w íntegro|strong="H8003"\w* ante \w Él|strong="H5921"\w*. ¡\w Locamente|strong="H5528"\w* actuaste \w en|strong="H5921"\w* \w esto|strong="H2063"\w*, \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w ahora|strong="H6258"\w* \w en|strong="H5921"\w* adelante \w habrá|strong="H3426"\w* \w guerras|strong="H4421"\w* \w contra|strong="H5921"\w* \w ti|strong="H5973"\w*!   
\p
\v 10 \w Entonces|strong="H3588"\w* Asa \w se|strong="H1931"\w* enojó \w contra|strong="H5921"\w* \w el|strong="H1931"\w* \w vidente|strong="H7200"\w* \w y|strong="H3588"\w* \w lo|strong="H1931"\w* echó \w en|strong="H5921"\w* \w la|strong="H1931"\w* cárcel, \w pues|strong="H3588"\w* \w se|strong="H1931"\w* enfureció muchísimo \w contra|strong="H5921"\w* \w él|strong="H1931"\w* \w por|strong="H5921"\w* \w esto|strong="H2063"\w*. \w Y|strong="H3068"\w* \w al|strong="H5921"\w* \w mismo|strong="H1931"\w* \w tiempo|strong="H6256"\w*, Asa oprimió \w a|strong="H3068"\w* algunos \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w*.   
\p
\v 11 \w Los|strong="H5921"\w* \w hechos|strong="H1697"\w* \w de|strong="H5921"\w* Asa, \w primeros|strong="H7223"\w* \w y|strong="H5921"\w* últimos, \w ciertamente|strong="H2009"\w* \w están|strong="H2009"\w* \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.   
\s1 Muerte del rey Asa  
\p
\v 12 \w El|strong="H3588"\w* \w año|strong="H8141"\w* 39 \w de|strong="H3588"\w* \w su|strong="H3588"\w* \w reinado|strong="H4438"\w*, Asa cayó \w enfermo|strong="H2456"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w pies|strong="H7272"\w*. \w Su|strong="H3588"\w* \w enfermedad|strong="H2483"\w* \w era|strong="H8141"\w* grave, \w pero|strong="H3588"\w* \w aun|strong="H1571"\w* \w en|strong="H5704"\w* \w su|strong="H3588"\w* \w enfermedad|strong="H2483"\w* \w no|strong="H3808"\w* \w buscó|strong="H1875"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w sino|strong="H3588"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w médicos|strong="H7495"\w*.   
\p
\v 13 Asa descansó \w con|strong="H5973"\w* sus antepasados. \w Murió|strong="H4191"\w* \w el|strong="H5973"\w* \w año|strong="H8141"\w* 41 \w de|strong="H5973"\w* su \w reinado|strong="H4427"\w*.  
\v 14 \w Lo|strong="H5704"\w* \w sepultaron|strong="H6912"\w* \w en|strong="H5704"\w* su \w sepulcro|strong="H6913"\w* \w que|strong="H5704"\w* excavó \w en|strong="H5704"\w* la \w Ciudad|strong="H5892"\w* \w de|strong="H5704"\w* \w David|strong="H1732"\w*. \w Lo|strong="H5704"\w* \w pusieron|strong="H8313"\w* \w en|strong="H5704"\w* un ataúd, el cual \w llenaron|strong="H4390"\w* \w de|strong="H5704"\w* toda clase \w de|strong="H5704"\w* \w especias|strong="H1314"\w* aromáticas \w y|strong="H5704"\w* perfumes preparados \w por|strong="H5704"\w* expertos perfumistas, \w y|strong="H5704"\w* encendieron una \w gran|strong="H1419"\w* hoguera \w en|strong="H5704"\w* su honor.   
\c 17  
\s1 Reinado de Josafat en Judá  
\p
\v 1 Su \w hijo|strong="H1121"\w* Josafat \w reinó|strong="H4427"\w* \w en|strong="H5921"\w* su \w lugar|strong="H8478"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* fortaleció \w contra|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 2 Destacó tropas en \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w* \w de|strong="H5414"\w* \w Judá|strong="H3063"\w* y colocó guarniciones en \w la|strong="H3605"\w* tierra \w de|strong="H5414"\w* \w Judá|strong="H3063"\w* y en las \w ciudades|strong="H5892"\w* \w de|strong="H5414"\w* Efraín \w que|strong="H3605"\w* su padre Asa capturó.   
\p
\v 3 \nd \+w Yavé|strong="H3068"\+w*\nd* \w estuvo|strong="H1961"\w* \w con|strong="H5973"\w* Josafat, \w porque|strong="H3588"\w* \w anduvo|strong="H1980"\w* \w en|strong="H5973"\w* \w los|strong="H5973"\w* procedimientos \w de|strong="H3588"\w* \w su|strong="H3588"\w* antepasado \w David|strong="H1732"\w*. \w No|strong="H3808"\w* acudió \w a|strong="H3068"\w* \w los|strong="H5973"\w* baales,  
\v 4 \w sino|strong="H3588"\w* acudió al \nd ʼElohim\nd* \w de|strong="H3588"\w* \w su|strong="H3588"\w* padre. \w Anduvo|strong="H1980"\w* \w en|strong="H3588"\w* sus \w Mandamientos|strong="H4687"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* según las \w obras|strong="H4639"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*.  
\v 5 \nd \+w Yavé|strong="H3068"\+w*\nd* confirmó \w el|strong="H3605"\w* \w reino|strong="H4467"\w* en su \w mano|strong="H3027"\w*. \w Todo|strong="H3605"\w* \w Judá|strong="H3063"\w* \w dio|strong="H5414"\w* \w presentes|strong="H4503"\w* \w a|strong="H3068"\w* Josafat, \w y|strong="H3519"\w* \w tuvo|strong="H1961"\w* riqueza \w y|strong="H3519"\w* honores en \w abundancia|strong="H7230"\w*.  
\v 6 Su \w corazón|strong="H3820"\w* se animó \w en|strong="H5493"\w* los \w caminos|strong="H1870"\w* \w de|strong="H5750"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, y \w quitó|strong="H5493"\w* \w de|strong="H5750"\w* \w Judá|strong="H3063"\w* los lugares \w altos|strong="H1116"\w* y las Aseras.   
\p
\v 7 En el tercer \w año|strong="H8141"\w* \w de|strong="H8269"\w* su \w reinado|strong="H4427"\w*, \add el rey Josafat\add* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* sus magistrados \w Ben-hail|strong="H1134"\w*, \w Abdías|strong="H5662"\w*, \w Zacarías|strong="H2148"\w*, Natanael y Micaías, \w a|strong="H3068"\w* enseñar en las \w ciudades|strong="H5892"\w* \w de|strong="H8269"\w* \w Judá|strong="H3063"\w*.  
\v 8 Envió \w con|strong="H5973"\w* ellos \w a|strong="H3068"\w* \w los|strong="H5973"\w* \w levitas|strong="H3881"\w* \w Semaías|strong="H8098"\w*, Netanías, \w Zebadías|strong="H2069"\w*, \w Asael|strong="H6214"\w*, Semiramot, Jonatán, Adonías, \w Tobías|strong="H2900"\w*, Tobadonías y \w a|strong="H3068"\w* \w los|strong="H5973"\w* \w sacerdotes|strong="H3548"\w* Elisama y \w Joram|strong="H3088"\w*.  
\v 9 \w Ellos|strong="H3605"\w* enseñaron \w en|strong="H5973"\w* \w Judá|strong="H3063"\w* y llevaban \w consigo|strong="H5973"\w* \w el|strong="H5973"\w* Rollo \w de|strong="H5973"\w* \w la|strong="H3605"\w* \w Ley|strong="H8451"\w* \w de|strong="H5973"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. Recorrieron \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5973"\w* \w Judá|strong="H3063"\w* y enseñaban al \w pueblo|strong="H5971"\w*.   
\p
\v 10 \w El|strong="H5921"\w* pavor \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* cayó \w sobre|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* tierras \w que|strong="H3808"\w* \w estaban|strong="H1961"\w* \w alrededor|strong="H5439"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w y|strong="H5921"\w* \w no|strong="H3808"\w* hicieron \w guerra|strong="H3898"\w* \w contra|strong="H5921"\w* Josafat.  
\v 11 Algunos \w de|strong="H4480"\w* los \w filisteos|strong="H6430"\w* llevaban \w a|strong="H3068"\w* Josafat \w presentes|strong="H4503"\w* \w y|strong="H1571"\w* \w plata|strong="H3701"\w* \w como|strong="H1571"\w* \w tributo|strong="H4503"\w*. \w También|strong="H1571"\w* los árabes le llevaron rebaños: 7.700 carneros \w y|strong="H1571"\w* 7.700 machos cabríos.   
\p
\v 12 Josafat \w llegó|strong="H5704"\w* \w a|strong="H3068"\w* ser \w muy|strong="H4605"\w* grande. \w Edificó|strong="H1129"\w* \w en|strong="H5704"\w* \w Judá|strong="H3063"\w* \w fortalezas|strong="H1003"\w* \w y|strong="H5704"\w* \w ciudades|strong="H5892"\w* \w de|strong="H5704"\w* almacenamiento.  
\v 13 Además \w tuvo|strong="H1961"\w* \w muchas|strong="H7227"\w* provisiones en las \w ciudades|strong="H5892"\w* de \w Judá|strong="H3063"\w*, y \w hombres|strong="H1368"\w* de \w guerra|strong="H4421"\w* muy \w valientes|strong="H1368"\w* en Jerusalén.   
\p
\v 14 Éste era \w el|strong="H5973"\w* número \w de|strong="H5973"\w* ellos, según sus \w casas|strong="H1004"\w* paternas: \w de|strong="H5973"\w* \w los|strong="H5973"\w* comandantes \w de|strong="H5973"\w* millares \w de|strong="H5973"\w* \w Judá|strong="H3063"\w*, \w el|strong="H5973"\w* \w jefe|strong="H8269"\w* era \w Adnas|strong="H5734"\w*, \w con|strong="H5973"\w* 300.000 guerreros \w valientes|strong="H1368"\w*;  
\v 15 \w le|strong="H5921"\w* seguía \w el|strong="H5921"\w* \w jefe|strong="H8269"\w* \w Johanán|strong="H3076"\w*, \w con|strong="H5973"\w* 280.000;  
\v 16 luego \w Amasías|strong="H6007"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Zicri, quien \w se|strong="H5921"\w* ofreció \w voluntariamente|strong="H5068"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w con|strong="H5973"\w* 200.000 \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*;  
\v 17 \w de|strong="H4480"\w* \w Benjamín|strong="H1144"\w*, Eliada, \w hombre|strong="H1368"\w* muy \w valiente|strong="H1368"\w*, y \w con|strong="H5973"\w* \w él|strong="H5973"\w* 200.000 \w que|strong="H4480"\w* llevaban \w arco|strong="H7198"\w* y \w escudo|strong="H4043"\w*;  
\v 18 \w y|strong="H5921"\w* \w a|strong="H3068"\w* continuación, \w Jozabad|strong="H3075"\w*, \w con|strong="H5973"\w* 180.000 hombres equipados \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w guerra|strong="H6635"\w*.   
\p
\v 19 \w Éstos|strong="H3605"\w* eran \w los|strong="H3605"\w* \w que|strong="H3605"\w* servían \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, aparte \w de|strong="H5414"\w* \w los|strong="H3605"\w* \w que|strong="H3605"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* destacó en las \w ciudades|strong="H5892"\w* fortificadas \w por|strong="H5414"\w* \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w*.   
\c 18  
\s1 Batalla de Acab y Josafat contra Ramot de Galaad  
\p
\v 1 Josafat \w tenía|strong="H1961"\w* \w riquezas|strong="H6239"\w* \w y|strong="H3519"\w* honores en \w abundancia|strong="H7230"\w*, \w y|strong="H3519"\w* emparentó con Acab.  
\v 2 Después \w de|strong="H5973"\w* unos \w años|strong="H8141"\w* bajó \w a|strong="H3068"\w* \w Samaria|strong="H8111"\w* \w para|strong="H5973"\w* visitar \w a|strong="H3068"\w* Acab. \w Y|strong="H3068"\w* Acab ordenó degollar numerosas \w ovejas|strong="H6629"\w* \w y|strong="H1241"\w* \w bueyes|strong="H1241"\w* \w para|strong="H5973"\w* \w él|strong="H5973"\w* \w y|strong="H1241"\w* \w el|strong="H5973"\w* ejército \w que|strong="H5971"\w* estaba \w con|strong="H5973"\w* \w él|strong="H5973"\w*. Lo incitó \w a|strong="H3068"\w* \w ir|strong="H3381"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w* \w contra|strong="H5973"\w* Ramot \w de|strong="H5973"\w* \w Galaad|strong="H1568"\w*.  
\v 3 Acab, \w rey|strong="H4428"\w* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w*, preguntó \w a|strong="H3068"\w* Josafat, \w rey|strong="H4428"\w* \w de|strong="H5973"\w* \w Judá|strong="H3063"\w*: ¿\w Irás|strong="H3212"\w* \w conmigo|strong="H5973"\w* \w contra|strong="H5973"\w* Ramot \w de|strong="H5973"\w* \w Galaad|strong="H1568"\w*?  
\p \w Y|strong="H3068"\w* \w él|strong="H5973"\w* respondió: Yo soy \w como|strong="H3644"\w* tú, y mi ejército \w como|strong="H3644"\w* \w el|strong="H5973"\w* \w tuyo|strong="H5971"\w*. \w Iremos|strong="H3212"\w* \w contigo|strong="H5973"\w* \w a|strong="H3068"\w* la \w guerra|strong="H4421"\w*.  
\v 4 Además Josafat dijo \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Israel|strong="H3478"\w*: Te \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* consultes \w ahora|strong="H4994"\w* la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 5 Entonces \w el|strong="H5030"\w* \w rey|strong="H4428"\w* \w de|strong="H5414"\w* \w Israel|strong="H3478"\w* convocó \w a|strong="H3068"\w* unos 400 hombres \w que|strong="H3027"\w* eran \w profetas|strong="H5030"\w* y les preguntó: ¿\w Iremos|strong="H3212"\w* \w a|strong="H3068"\w* la \w guerra|strong="H4421"\w* \w contra|strong="H3478"\w* Ramot \w de|strong="H5414"\w* \w Galaad|strong="H1568"\w* \w o|strong="H3068"\w* desistiré?  
\p \w Y|strong="H3068"\w* \w ellos|strong="H3027"\w* respondieron: \w Sube|strong="H5927"\w*, \w porque|strong="H4428"\w* \tl ʼelohim\tl* la \w entregará|strong="H5414"\w* \w en|strong="H3212"\w* \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w*.   
\p
\v 6 Pero Josafat preguntó: ¿\w Hay|strong="H5750"\w* \w aún|strong="H5750"\w* \w aquí|strong="H6311"\w* \w algún|strong="H5750"\w* \w profeta|strong="H5030"\w* \w de|strong="H5750"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, para que \w consultemos|strong="H1875"\w* \w por|strong="H5750"\w* medio \w de|strong="H5750"\w* \w él|strong="H5030"\w*?   
\p
\v 7 \w El|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* respondió \w a|strong="H3068"\w* Josafat: \w Aún|strong="H5750"\w* queda un \w hombre|strong="H1121"\w* \w por|strong="H5921"\w* medio \w de|strong="H5921"\w* \w quien|strong="H3605"\w* podemos consultar \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w pero|strong="H3588"\w* \w yo|strong="H3588"\w* \w lo|strong="H1931"\w* \w aborrezco|strong="H8130"\w*, \w porque|strong="H3588"\w* \w nunca|strong="H3588"\w* \w me|strong="H5921"\w* \w profetiza|strong="H5012"\w* \w para|strong="H5921"\w* \w bien|strong="H2896"\w*, \w sino|strong="H3588"\w* \w siempre|strong="H3605"\w* \w para|strong="H5921"\w* \w mal|strong="H7451"\w*. \w Es|strong="H1931"\w* Micaías, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Imla.  
\p \w Y|strong="H3068"\w* dijo Josafat: \w No|strong="H3588"\w* hable \w así|strong="H3651"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w*.   
\p
\v 8 Entonces \w el|strong="H1121"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* un funcionario y le dijo: ¡Trae \w pronto|strong="H4116"\w* \w a|strong="H3068"\w* Micaías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Imla!   
\p
\v 9 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* Josafat, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w vestidos|strong="H3847"\w* \w con|strong="H5921"\w* ropas \w reales|strong="H4428"\w*, \w estaban|strong="H3427"\w* \w sentados|strong="H3427"\w* \w cada|strong="H3605"\w* uno \w en|strong="H5921"\w* su \w trono|strong="H3678"\w* \w en|strong="H5921"\w* una plaza ubicada \w a|strong="H3068"\w* \w la|strong="H5921"\w* entrada \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w* \w de|strong="H5921"\w* \w Samaria|strong="H8111"\w*. \w Todos|strong="H3605"\w* \w los|strong="H3427"\w* \w profetas|strong="H5030"\w* \w profetizaban|strong="H5012"\w* \w ante|strong="H6440"\w* \w ellos|strong="H5921"\w*.  
\v 10 Sedequías, \w hijo|strong="H1121"\w* \w de|strong="H5704"\w* Quenaana, \w hizo|strong="H6213"\w* unos \w cuernos|strong="H7161"\w* \w de|strong="H5704"\w* \w hierro|strong="H1270"\w* \w y|strong="H5704"\w* decía: \nd \+w Yavé|strong="H3068"\+w*\nd* dice: \wj \+w Con|strong="H5704"\+w* éstos \+w acornearás|strong="H5055"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H1121"\+w* sirios \+w hasta|strong="H5704"\+w* \+w que|strong="H5704"\+w* sean consumidos.\wj*   
\p
\v 11 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* \w profetas|strong="H5030"\w* \w profetizaban|strong="H5012"\w* \w así|strong="H3651"\w*: ¡\w Sube|strong="H5927"\w* \w a|strong="H3068"\w* Ramot \w de|strong="H5414"\w* \w Galaad|strong="H1568"\w* y triunfa, \w pues|strong="H3651"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w la|strong="H3605"\w* \w entregó|strong="H5414"\w* en \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w*!   
\s1 Profecía de Micaías sobre la muerte de Acab  
\p
\v 12 \w El|strong="H5030"\w* \w mensajero|strong="H4397"\w* \w que|strong="H4994"\w* \w fue|strong="H1961"\w* \w a|strong="H3068"\w* \w llamar|strong="H7121"\w* \w a|strong="H3068"\w* Micaías le \w habló|strong="H1696"\w*: \w Mira|strong="H2009"\w*, \w las|strong="H1992"\w* \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* \w los|strong="H1992"\w* \w profetas|strong="H5030"\w* declaran \w a|strong="H3068"\w* una voz \w cosas|strong="H1697"\w* \w buenas|strong="H2896"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*. \w Sea|strong="H1961"\w* tu \w palabra|strong="H1697"\w* \w como|strong="H1961"\w* la \w de|strong="H1697"\w* \w cada|strong="H1697"\w* uno \w de|strong="H1697"\w* \w ellos|strong="H1992"\w*, y predice \w cosa|strong="H1697"\w* \w buena|strong="H2896"\w*.   
\p
\v 13 \w Pero|strong="H3588"\w* Micaías replicó: \w Vive|strong="H2416"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H3588"\w* lo \w que|strong="H3588"\w* mi \nd ʼElohim\nd* indique, eso \w hablaré|strong="H1696"\w*.   
\p
\v 14 Cuando \w llegó|strong="H3212"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, éste le preguntó: Micaías, ¿\w iremos|strong="H3212"\w* \w a|strong="H3068"\w* la \w guerra|strong="H4421"\w* contra Ramot \w de|strong="H5414"\w* \w Galaad|strong="H1568"\w*, \w o|strong="H3068"\w* desistiré?  
\p \w Y|strong="H3068"\w* le respondió: Suban y prosperen, \w porque|strong="H4428"\w* \w ellos|strong="H3027"\w* serán entregados \w en|strong="H3212"\w* \w mano|strong="H3027"\w* \w de|strong="H5414"\w* ustedes.   
\p
\v 15 Pero el \w rey|strong="H4428"\w* le preguntó: ¿\w Cuántas|strong="H4100"\w* \w veces|strong="H6471"\w* te haré jurar \w que|strong="H4100"\w* \w no|strong="H3808"\w* me \w digas|strong="H1696"\w* \w sino|strong="H7535"\w* la verdad \w en|strong="H5704"\w* \w Nombre|strong="H8034"\w* \w de|strong="H5704"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*?   
\p
\v 16 \w Entonces|strong="H7725"\w* \w respondió|strong="H7725"\w*: \w Vi|strong="H7200"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w esparcido|strong="H6327"\w* \w por|strong="H5921"\w* \w las|strong="H5921"\w* montañas \w como|strong="H5921"\w* \w ovejas|strong="H6629"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* tienen \w pastor|strong="H7462"\w*. \w Y|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* dijo: \wj \+w Éstos|strong="H3605"\+w* \+w no|strong="H3808"\+w* tienen \+tl ʼadón\+tl*. Regrese \+w cada|strong="H3605"\+w* uno \+w a|strong="H3068"\+w* su \+w casa|strong="H1004"\+w* \+w en|strong="H5921"\+w* \+w paz|strong="H7965"\+w*.\wj*   
\p
\v 17 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* dijo \w a|strong="H3068"\w* Josafat: ¿\w No|strong="H3808"\w* \w te|strong="H5921"\w* dije \w que|strong="H3588"\w* éste \w nunca|strong="H3808"\w* \w profetiza|strong="H5012"\w* \w lo|strong="H3808"\w* \w bueno|strong="H2896"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*, \w sino|strong="H3588"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w*?   
\p
\v 18 Pero Micaías dijo: \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w oigan|strong="H8085"\w* \w la|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*: \wj \+w Vi|strong="H7200"\+w* \+w a|strong="H3068"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w sentado|strong="H3427"\+w* \+w en|strong="H5921"\+w* su \+w trono|strong="H3678"\+w*. \+w Toda|strong="H3605"\+w* \+w la|strong="H5921"\+w* hueste \+w de|strong="H5921"\+w* \+w los|strong="H3427"\+w* \+w cielos|strong="H8064"\+w* \+w estaba|strong="H5975"\+w* \+w a|strong="H3068"\+w* su \+w derecha|strong="H3225"\+w* \+w y|strong="H5921"\+w* \+w a|strong="H3068"\+w* su \+w izquierda|strong="H8040"\+w*.\wj*   
\p
\v 19 \nd \+w Yavé|strong="H3068"\+w*\nd* dijo: \wj ¿\+w Quién|strong="H4310"\+w* \+w inducirá|strong="H6601"\+w* \+w a|strong="H3068"\+w* Acab, \+w rey|strong="H4428"\+w* de \+w Israel|strong="H3478"\+w*, para \+w que|strong="H4310"\+w* \+w suba|strong="H5927"\+w* y \+w caiga|strong="H5307"\+w* en Ramot de \+w Galaad|strong="H1568"\+w*?\wj*  
\p \w Y|strong="H3068"\w* uno decía de una manera y \w otro|strong="H2088"\w* de otra.   
\p
\v 20 \w Salió|strong="H3318"\w* un \w espíritu|strong="H7307"\w* \w que|strong="H4100"\w* \w se|strong="H4100"\w* colocó \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* y dijo: Yo \w lo|strong="H4100"\w* induciré.  
\p \w Y|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* le preguntó: \wj ¿\+w De|strong="H6440"\+w* \+w cuál|strong="H4100"\+w* modo?\wj*   
\p
\v 21 Le respondió: \w Saldré|strong="H3318"\w* \w y|strong="H1571"\w* \w seré|strong="H1961"\w* \w espíritu|strong="H7307"\w* de \w mentira|strong="H8267"\w* \w en|strong="H3318"\w* \w la|strong="H1571"\w* \w boca|strong="H6310"\w* de \w todos|strong="H3605"\w* sus \w profetas|strong="H5030"\w*.  
\p \w Y|strong="H3068"\w* \w Él|strong="H3605"\w* dijo: \wj \+w Lo|strong="H6213"\+w* inducirás \+w y|strong="H1571"\+w* \+w ciertamente|strong="H1571"\+w* prevalecerás. ¡Vé \+w y|strong="H1571"\+w* \+w hazlo|strong="H6213"\+w*!\wj*   
\p
\v 22 \w Ahora|strong="H6258"\w*, \w mira|strong="H2009"\w*, \nd \+w Yavé|strong="H3068"\+w*\nd* \w puso|strong="H5414"\w* un \w espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w mentira|strong="H8267"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* estos \w profetas|strong="H5030"\w* tuyos, \w porque|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* decretó \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*.   
\p
\v 23 Entonces Sedequías, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Quenaana, \w se|strong="H5921"\w* \w acercó|strong="H5066"\w*, golpeó \w a|strong="H3068"\w* Micaías \w en|strong="H5921"\w* \w la|strong="H5921"\w* mejilla \w y|strong="H5921"\w* \w dijo|strong="H1696"\w*: ¿\w Por|strong="H5921"\w* cuál \w camino|strong="H1870"\w* \w pasó|strong="H5674"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w para|strong="H5921"\w* \w hablarte|strong="H1696"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w*?   
\p
\v 24 Micaías respondió: \w Ciertamente|strong="H2005"\w*, ¿no \w lo|strong="H1931"\w* \w verás|strong="H7200"\w* en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* vayas \w a|strong="H3068"\w* esconderte de aposento en aposento?   
\p
\v 25 \w Entonces|strong="H7725"\w* \w el|strong="H1121"\w* \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* dijo: \w Tomen|strong="H3947"\w* \w a|strong="H3068"\w* Micaías y llévenlo \w a|strong="H3068"\w* Amón, \w gobernador|strong="H8269"\w* \w de|strong="H1121"\w* la \w ciudad|strong="H5892"\w*, y \w a|strong="H3068"\w* \w Joás|strong="H3101"\w*, \w hijo|strong="H1121"\w* del \w rey|strong="H4428"\w*,  
\v 26 \w y|strong="H5704"\w* díganles: El \w rey|strong="H4428"\w* dijo: Metan \w a|strong="H3068"\w* \w éste|strong="H2088"\w* \w en|strong="H5704"\w* la cárcel \w y|strong="H5704"\w* denle \w pan|strong="H3899"\w* \w y|strong="H5704"\w* \w agua|strong="H4325"\w* \w de|strong="H5704"\w* aflicción \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* yo \w vuelva|strong="H7725"\w* \w en|strong="H5704"\w* \w paz|strong="H7965"\w*.   
\p
\v 27 \w Entonces|strong="H7725"\w* Micaías \w dijo|strong="H1696"\w*: ¡\w Si|strong="H3808"\w* \w vuelves|strong="H7725"\w* en \w paz|strong="H7965"\w*, \nd \+w Yavé|strong="H3068"\+w*\nd* \w no|strong="H3808"\w* \w habló|strong="H1696"\w* por medio \w de|strong="H5971"\w* mí! \w Y|strong="H3068"\w* agregó: ¡Escúchenlo, \w pueblos|strong="H5971"\w* \w todos|strong="H3605"\w*!   
\p
\v 28 Así que el \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w* \w subió|strong="H5927"\w* con Josafat, \w rey|strong="H4428"\w* de \w Judá|strong="H3063"\w*, \w contra|strong="H3478"\w* Ramot de \w Galaad|strong="H1568"\w*.  
\v 29 El \w rey|strong="H4428"\w* \w de|strong="H3847"\w* \w Israel|strong="H3478"\w* dijo \w a|strong="H3068"\w* Josafat: Me disfrazaré y entraré en la \w batalla|strong="H4421"\w*, pero tú cúbrete con tus ropas \w reales|strong="H4428"\w*. \w Y|strong="H3068"\w* el \w rey|strong="H4428"\w* \w de|strong="H3847"\w* \w Israel|strong="H3478"\w* se disfrazó, y entraron en la \w batalla|strong="H4421"\w*.   
\p
\v 30 \w Pero|strong="H3588"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Siria \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w jefes|strong="H8269"\w* \w de|strong="H3588"\w* sus carruajes: \w No|strong="H3808"\w* luchen \w contra|strong="H3478"\w* \w pequeño|strong="H6996"\w* \w ni|strong="H3808"\w* \w grande|strong="H1419"\w*, \w sino|strong="H3588"\w* solo \w contra|strong="H3478"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*.   
\p
\v 31 \w Cuando|strong="H1961"\w* \w los|strong="H1992"\w* \w jefes|strong="H8269"\w* \w de|strong="H4480"\w* \w los|strong="H1992"\w* carruajes \w vieron|strong="H7200"\w* \w a|strong="H3068"\w* Josafat, dijeron: ¡\w Ése|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*! \w Así|strong="H1992"\w* \w que|strong="H4480"\w* \w lo|strong="H1931"\w* rodearon \w para|strong="H5921"\w* luchar, pero Josafat \w clamó|strong="H2199"\w*, \w y|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w lo|strong="H1931"\w* \w ayudó|strong="H5826"\w*. \nd ʼElohim\nd* \w los|strong="H1992"\w* \w apartó|strong="H5437"\w* \w de|strong="H4480"\w* \w él|strong="H1931"\w*.   
\p
\v 32 \w Pues|strong="H3588"\w* \w sucedió|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w los|strong="H1961"\w* \w jefes|strong="H8269"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* carruajes \w vieron|strong="H7200"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w era|strong="H1961"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w se|strong="H1961"\w* apartaron \w de|strong="H3588"\w* perseguirlo.   
\s1 Una flecha al que pueda interesar  
\p
\v 33 Un hombre disparó \w con|strong="H4480"\w* \w el|strong="H3588"\w* \w arco|strong="H7198"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* ventura, \w e|strong="H3068"\w* \w hirió|strong="H5221"\w* \w al|strong="H4480"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w entre|strong="H3588"\w* las junturas \w de|strong="H4480"\w* \w la|strong="H3588"\w* armadura. \w Y|strong="H3068"\w* \add el rey\add* dijo \w al|strong="H4480"\w* \w que|strong="H3588"\w* manejaba \w los|strong="H3588"\w* caballos \w del|strong="H4480"\w* carruaje: \w Vuelve|strong="H2015"\w* tu \w mano|strong="H3027"\w* \w y|strong="H3588"\w* \w sácame|strong="H3318"\w* \w del|strong="H4480"\w* \w campo|strong="H4264"\w* \w porque|strong="H3588"\w* estoy herido.   
\p
\v 34 Pero \w la|strong="H1931"\w* \w batalla|strong="H4421"\w* arreció \w aquel|strong="H1931"\w* \w día|strong="H3117"\w*. \w Por|strong="H5704"\w* tanto \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* \w fue|strong="H1961"\w* sostenido \w en|strong="H5704"\w* \w su|strong="H1931"\w* carroza frente \w a|strong="H3068"\w* \w los|strong="H1931"\w* sirios \w hasta|strong="H5704"\w* llegar \w la|strong="H1931"\w* noche, pero \w murió|strong="H4191"\w* \w al|strong="H5704"\w* ocultarse \w el|strong="H1931"\w* \w sol|strong="H8121"\w*.   
\c 19  
\s1 Amonestación a Josafat  
\p
\v 1 Josafat, \w rey|strong="H4428"\w* de \w Judá|strong="H3063"\w*, regresó en \w paz|strong="H7965"\w* \w a|strong="H3068"\w* su \w casa|strong="H1004"\w* en Jerusalén.   
\p
\v 2 Pero \w el|strong="H5921"\w* \w vidente|strong="H2374"\w* \w Jehú|strong="H3058"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Hanani|strong="H2607"\w*, \w salió|strong="H3318"\w* \w a|strong="H3068"\w* encontrarlo \w y|strong="H5921"\w* dijo \w al|strong="H5921"\w* \w rey|strong="H4428"\w* Josafat: ¿Das \w ayuda|strong="H5826"\w* \w al|strong="H5921"\w* perverso \w y|strong="H5921"\w* amas \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w que|strong="H5921"\w* \w aborrecen|strong="H8130"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*? \w Por|strong="H5921"\w* \w esto|strong="H2063"\w* \w la|strong="H5921"\w* \w ira|strong="H7110"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w está|strong="H2063"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*.  
\v 3 Sin embargo, \w se|strong="H4480"\w* \w hallaron|strong="H4672"\w* \w cosas|strong="H1697"\w* \w buenas|strong="H2896"\w* \w en|strong="H4480"\w* \w ti|strong="H5973"\w*, \w pues|strong="H3588"\w* eliminaste las Aseras \w de|strong="H4480"\w* \w la|strong="H3588"\w* tierra \w y|strong="H3588"\w* dispusiste tu \w corazón|strong="H3824"\w* \w a|strong="H3068"\w* buscar \w a|strong="H3068"\w* \nd ʼElohim\nd*.   
\p
\v 4 Josafat \w se|strong="H5971"\w* \w quedó|strong="H3427"\w* \w en|strong="H5704"\w* Jerusalén, \w aunque|strong="H5704"\w* \w salía|strong="H3318"\w* \w a|strong="H3068"\w* visitar \w al|strong="H5704"\w* \w pueblo|strong="H5971"\w* \w desde|strong="H5704"\w* Beerseba \w hasta|strong="H5704"\w* la región montañosa \w de|strong="H5704"\w* Efraín, \w para|strong="H5704"\w* hacerlos \w volver|strong="H7725"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w de|strong="H5704"\w* sus antepasados.   
\p
\v 5 Estableció \w jueces|strong="H8199"\w* \w en|strong="H5975"\w* \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w* del territorio de \w Judá|strong="H3063"\w*.  
\v 6 Advirtió \w a|strong="H3068"\w* \w los|strong="H5973"\w* \w jueces|strong="H8199"\w*: Consideren \w lo|strong="H1697"\w* \w que|strong="H3588"\w* \w hacen|strong="H6213"\w*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w juzgan|strong="H8199"\w* \w con|strong="H5973"\w* autoridad \w de|strong="H3588"\w* hombre, \w sino|strong="H3588"\w* \w con|strong="H5973"\w* \w la|strong="H3588"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w Quien|strong="H4100"\w* estará \w con|strong="H5973"\w* ustedes \w cuando|strong="H3588"\w* pronuncien \w sentencia|strong="H4941"\w*.  
\v 7 \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, \w el|strong="H5921"\w* \w terror|strong="H6343"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w sea|strong="H1961"\w* \w sobre|strong="H5921"\w* ustedes. Procedan \w con|strong="H5973"\w* cuidado, \w porque|strong="H3588"\w* \w con|strong="H5973"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd* \w no|strong="H6213"\w* \w hay|strong="H1961"\w* injusticia, \w ni|strong="H5973"\w* acepción \w de|strong="H5921"\w* personas, \w ni|strong="H5973"\w* admisión \w de|strong="H5921"\w* \w soborno|strong="H7810"\w*.   
\p
\v 8 Josafat \w también|strong="H1571"\w* designó \w en|strong="H4480"\w* Jerusalén \w a|strong="H3068"\w* algunos \w levitas|strong="H3881"\w* \w y|strong="H1571"\w* \w sacerdotes|strong="H3548"\w*, \w así|strong="H1571"\w* \w como|strong="H1571"\w* \w de|strong="H4480"\w* los \w jefes|strong="H7218"\w* \w de|strong="H4480"\w* las casas paternas \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w para|strong="H4480"\w* administrar \w la|strong="H1571"\w* \w justicia|strong="H4941"\w* \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w y|strong="H1571"\w* juzgar litigios \w entre|strong="H4480"\w* los habitantes \w de|strong="H4480"\w* Jerusalén.   
\p
\v 9 \w Les|strong="H5921"\w* \w ordenó|strong="H6680"\w*: Procedan \w asimismo|strong="H3541"\w* \w con|strong="H5921"\w* \w temor|strong="H3374"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, fidelidad \w y|strong="H5921"\w* \w corazón|strong="H3824"\w* \w íntegro|strong="H8003"\w*.  
\v 10 \w Cuando|strong="H1961"\w* lleven ante ustedes \w cualquier|strong="H3605"\w* \w pleito|strong="H7379"\w* \w entre|strong="H5921"\w* sus hermanos \w que|strong="H3808"\w* viven \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w*, \w en|strong="H5921"\w* litigios \w por|strong="H5921"\w* derramamiento \w de|strong="H5921"\w* \w sangre|strong="H1818"\w*, \w o|strong="H3068"\w* \w en|strong="H5921"\w* consultas \w sobre|strong="H5921"\w* \w Ley|strong="H8451"\w*, Precepto, \w Estatutos|strong="H2706"\w* \w y|strong="H5921"\w* Decretos, ustedes \w los|strong="H3427"\w* amonestarán \w para|strong="H5921"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* pequen \w contra|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w y|strong="H5921"\w* \w así|strong="H3541"\w* \w no|strong="H3808"\w* llegue \w la|strong="H5921"\w* \w ira|strong="H7110"\w* \w sobre|strong="H5921"\w* ustedes \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* sus hermanos. \w Si|strong="H3808"\w* actúan \w de|strong="H5921"\w* \w esta|strong="H1961"\w* manera \w no|strong="H3808"\w* \w tendrán|strong="H1961"\w* culpa.   
\p
\v 11 \w Ciertamente|strong="H2009"\w*, \w el|strong="H5921"\w* \w sumo|strong="H7218"\w* \w sacerdote|strong="H3548"\w* Amarías \w los|strong="H1121"\w* presidirá \w en|strong="H5921"\w* \w cualquier|strong="H3605"\w* \w asunto|strong="H1697"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \w Zebadías|strong="H2069"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Ismael|strong="H3458"\w*, \w jefe|strong="H7218"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \add los atenderá\add* \w en|strong="H5921"\w* \w cualquier|strong="H3605"\w* \w asunto|strong="H1697"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*, \w y|strong="H5921"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* \w serán|strong="H1961"\w* \w oficiales|strong="H7860"\w* \w en|strong="H5921"\w* \w presencia|strong="H6440"\w* \w de|strong="H5921"\w* ustedes. \w Esfuércense|strong="H2388"\w* \w y|strong="H5921"\w* actúen, \w y|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w esté|strong="H1961"\w* \w con|strong="H5973"\w* \w el|strong="H5921"\w* justo.   
\c 20  
\s1 Victoria contra Moab y Amón  
\p
\v 1 \w Aconteció|strong="H1961"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* esto \w que|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Moab|strong="H4124"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* Amón, \w y|strong="H5921"\w* algunos \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w de|strong="H5921"\w* Seír, salieron \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w guerra|strong="H4421"\w* \w contra|strong="H5921"\w* Josafat.   
\p
\v 2 Entonces algunos fueron \w a|strong="H3068"\w* informar \w a|strong="H3068"\w* Josafat: Una \w gran|strong="H7227"\w* \w multitud|strong="H1995"\w* viene \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w de|strong="H5921"\w* Siria, \w del|strong="H5921"\w* otro \w lado|strong="H5676"\w* \w del|strong="H5921"\w* \w mar|strong="H3220"\w*. \w Ciertamente|strong="H2009"\w* \w están|strong="H2009"\w* \w en|strong="H5921"\w* Hazezon-tamar, \w que|strong="H1931"\w* \w es|strong="H1931"\w* En-gadí.   
\p
\v 3 Josafat \w tuvo|strong="H3372"\w* \w temor|strong="H3372"\w*, humilló su semblante \w para|strong="H5921"\w* buscar \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w y|strong="H5921"\w* \w proclamó|strong="H7121"\w* un \w ayuno|strong="H6685"\w* \w en|strong="H5921"\w* \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w*.  
\v 4 \w Los|strong="H3605"\w* de \w Judá|strong="H3063"\w* se reunieron para pedir socorro \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. Acudieron de \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* de \w Judá|strong="H3063"\w* para pedir ayuda \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 5 Entonces Josafat se colocó \w en|strong="H5975"\w* \w pie|strong="H5975"\w* \w ante|strong="H6440"\w* la \w congregación|strong="H6951"\w* \w de|strong="H6440"\w* \w Judá|strong="H3063"\w* y \w de|strong="H6440"\w* Jerusalén, \w delante|strong="H6440"\w* del \w patio|strong="H2691"\w* \w nuevo|strong="H2319"\w* \w en|strong="H5975"\w* la \w Casa|strong="H1004"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*,  
\v 6 y dijo: Oh \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w de|strong="H5973"\w* nuestros antepasados, ¿\w no|strong="H3808"\w* \w eres|strong="H1931"\w* Tú \w el|strong="H1931"\w* \nd ʼElohim\nd* \w del|strong="H5973"\w* \w cielo|strong="H8064"\w*, \w Quien|strong="H3605"\w* gobierna \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reinos|strong="H4467"\w* \w de|strong="H5973"\w* las \w naciones|strong="H1471"\w*? ¿\w No|strong="H3808"\w* hay \w en|strong="H5973"\w* tu \w mano|strong="H3027"\w* tal \w fuerza|strong="H3581"\w* y \w poder|strong="H3027"\w* \w que|strong="H1931"\w* \w nadie|strong="H3808"\w* puede resistir?  
\v 7 ¿\w No|strong="H3808"\w* \w echaste|strong="H3423"\w* Tú, oh \nd ʼElohim\nd* nuestro, \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H6440"\w* \w esta|strong="H2063"\w* tierra \w delante|strong="H6440"\w* \w de|strong="H6440"\w* tu \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, y \w la|strong="H2063"\w* \w diste|strong="H5414"\w* \w para|strong="H5414"\w* \w siempre|strong="H5769"\w* \w a|strong="H3068"\w* \w la|strong="H2063"\w* \w descendencia|strong="H2233"\w* \w de|strong="H6440"\w* tu amigo Abraham?  
\v 8 Vivieron en ella, \w edificaron|strong="H1129"\w* un \w Santuario|strong="H4720"\w* \w a|strong="H3068"\w* tu \w Nombre|strong="H8034"\w* y dijeron:  
\v 9 \w Si|strong="H3588"\w* \w nos|strong="H5921"\w* llega \w el|strong="H5921"\w* \w mal|strong="H7451"\w*, \w ya|strong="H2088"\w* sea \w con|strong="H5921"\w* \w espada|strong="H2719"\w*, \w con|strong="H5921"\w* \w pestilencia|strong="H1698"\w* \w o|strong="H3068"\w* hambruna, \w nos|strong="H5921"\w* congregaremos \w ante|strong="H6440"\w* \w esta|strong="H2088"\w* \w Casa|strong="H1004"\w* \w y|strong="H3588"\w* \w ante|strong="H6440"\w* \w Ti|strong="H5921"\w*, \w porque|strong="H3588"\w* tu \w Nombre|strong="H8034"\w* \w está|strong="H2088"\w* \w en|strong="H5921"\w* \w esta|strong="H2088"\w* \w Casa|strong="H1004"\w*. \w Clamaremos|strong="H2199"\w* \w a|strong="H3068"\w* \w Ti|strong="H5921"\w* \w en|strong="H5921"\w* nuestra \w aflicción|strong="H6869"\w*, \w y|strong="H3588"\w* Tú \w nos|strong="H5921"\w* escucharás \w y|strong="H3588"\w* \w nos|strong="H5921"\w* \w salvarás|strong="H3467"\w*.  
\v 10 \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, \w aquí|strong="H2009"\w* \w están|strong="H2009"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón, \w de|strong="H5921"\w* \w Moab|strong="H4124"\w* \w y|strong="H3588"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* región montañosa \w de|strong="H5921"\w* \w Seír|strong="H8165"\w*, \w a|strong="H3068"\w* quienes \w no|strong="H3808"\w* permitiste \w que|strong="H3588"\w* \w Israel|strong="H3478"\w* invadiera \w cuando|strong="H3588"\w* venía \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*. \w Por|strong="H5921"\w* eso \w se|strong="H5921"\w* desviaron \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w los|strong="H1121"\w* \w destruyeron|strong="H8045"\w*.  
\v 11 \w Mira|strong="H2009"\w*, \w ellos|strong="H1992"\w* \w nos|strong="H5921"\w* recompensan \w al|strong="H5921"\w* venir \w a|strong="H3068"\w* echarnos \w de|strong="H5921"\w* tu herencia, \w la|strong="H5921"\w* cual \w nos|strong="H5921"\w* diste \w en|strong="H5921"\w* \w posesión|strong="H3425"\w*.  
\v 12 ¡\w Oh|strong="H4100"\w* \nd ʼElohim\nd* nuestro! ¿\w Tú|strong="H8199"\w* \w no|strong="H3808"\w* \w los|strong="H5921"\w* castigarás? \w Porque|strong="H3588"\w* \w no|strong="H3808"\w* hay \w fuerza|strong="H3581"\w* \w en|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w contra|strong="H5921"\w* \w esta|strong="H2088"\w* \w gran|strong="H7227"\w* \w multitud|strong="H1995"\w* \w que|strong="H3588"\w* viene \w contra|strong="H5921"\w* \w nosotros|strong="H5921"\w*, \w ni|strong="H3808"\w* \w sabemos|strong="H3045"\w* \w qué|strong="H3588"\w* \w hacer|strong="H6213"\w*. \w Por|strong="H5921"\w* eso volvemos nuestros \w ojos|strong="H5869"\w* \w a|strong="H3068"\w* \w Ti|strong="H5921"\w*.   
\p
\v 13 \w Todo|strong="H3605"\w* \w Judá|strong="H3063"\w* \w permaneció|strong="H5975"\w* \w en|strong="H5975"\w* \w pie|strong="H5975"\w* \w ante|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w con|strong="H1571"\w* sus pequeños, mujeres \w e|strong="H3068"\w* \w hijos|strong="H1121"\w*.   
\p
