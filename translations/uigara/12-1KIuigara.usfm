\id 1KI
\h پادىشاھلار «1» 
\toc1 پادىشاھلار «1» 
\toc2 پادىشاھلار «1» 
\toc3 1پاد. 
\mt1 پادىشاھلار «1»  
\c 1
\s1 داۋۇت پادىشاھ ئوغلى سۇلايماننى ئۆز ئورنىغا تەختكە ئولتۇرغۇزىدۇ  
\m
\v 1 داۋۇت پادىشاھ خېلى ياشىنىپ قالغانىدى؛ ئۇنى يوتقان-ئەدىيال بىلەن ياپسىمۇ، ئۇ ئىسسىمايتتى.   
\m
\v 2 خىزمەتكارلىرى ئۇنىڭغا: ــ غوجام پادىشاھ ئۆزلىرى ئۈچۈن، ئالدىلىرىدا تۇرىدىغان بىر پاك قىز تاپقۇزايلى؛ ئۇ پادىشاھتىن خەۋەر ئېلىپ، سىلىنىڭ قۇچاقلىرىدا ياتسۇن؛ شۇنىڭ بىلەن غوجام پادىشاھ ئىسسىيلا ــ دېدى.   
\m
\v 3 ئۇلار پۈتكۈل ئىسرائىل زېمىنىنى كېزىپ گۈزەل بىر قىزنى ئىزدەپ يۈرۈپ، ئاخىرى شۇناملىق ئابىشاگنى تېپىپ پادىشاھنىڭ ئالدىغا ئېلىپ كەلدى. \f ◼ \fr 1:3 \ft \+bd «شۇناملىق ئابىشاگ»\+bd* ــ ياكى «شۇنەملىك ئابىشاگ».\f*  
\v 4 قىز ئىنتايىن گۈزەل ئىدى؛ ئۇ پادىشاھتىن خەۋەر ئېلىپ ئۇنىڭ خىزمىتىدە بولاتتى، ئەمما پادىشاھ ئۇنىڭغا يېقىنچىلىق قىلمايتتى. \f ◼ \fr 1:4 \ft \+bd «پادىشاھ ئۇنىڭغا يېقىنچىلىق قىلمايتتى»\+bd* ــ ئىبرانىي تىلىدا «پادىشاھ ئۇنى تونۇمايتتى» دېگەن ئىبارە بىلەن ئىپادىلىنىدۇ.\f*   
\m
\v 5 ئەمما ھاگگىتنىڭ ئوغلى ئادونىيا مەرتىۋىسىنى كۆتۈرمەكچى بولۇپ: «مەن پادىشاھ بولىمەن» دېدى. ئۇ ئۆزىگە جەڭ ھارۋىلىرى بىلەن ئاتلىقلارنى ۋە ئالدىدا يۈرىدىغان ئەللىك ئەسكەرنى تەييار قىلدى \f ◼ \fr 1:5 \ft \+bd «ھاگگىتنىڭ ئوغلى ئادونىيا»\+bd* ــ ئادونىيا داۋۇتنىڭ ئوغۇللىرىدىن بىرى. ھاگگىت داۋۇتنىڭ ئاياللىرىدىن بىرى ئىدى («2سام.» 4:3) \+bd «ئۆز ئالدىدا يۈرىدىغان... ئەسكەرلەر»\+bd* ــ دېمەك، ئۇلار ئۆزلىرىنىڭ خۇسۇسىي مۇھاپىزەتچىلىرى ئىدى.\f*  \x ◘ \xo 1:5 \xt 2سام. 15‏:1\x*  
\v 6 (ئۇنىڭ ئاتىسى ھېچقاچان: «نېمىشقا بۇنداق قىلىسەن؟» دەپ، ئۇنىڭغا تەنبىھ-تەربىيە بېرىپمۇ باقمىغانىدى ھەم ئۇ ناھايىتى كېلىشكەن يىگىت بولۇپ، ئانىسى ئۇنى ئابشالومدىن كېيىن تۇغقانىدى). \f ◼ \fr 1:6 \ft \+bd «ئۇنىڭ ئاتىسى ... ئۇنىڭغا \+bdit ، يەنى ئادونىياغا\+bdit* تەنبىھ-تەربىيە بېرىپمۇ باقمىغانىدى ھەم ئۇ ... كېلىشكەن يىگىت بولۇپ، ئانىسى ئۇنى ئابشالومدىن كېيىن تۇغقانىدى»\+bd* ــ ئابشالوم داۋۇتنىڭ يەنە بىر ئايالى مائاكاھدىن تۇغۇلغان ئوغلى ئىدى. ئادونىيا داۋۇتنىڭ تۆتىنچى ئوغلى بولۇپ، شۇ چاغدا بەلكىم داۋۇتنىڭ ئوغۇللىرى ئارىسىدا «چوڭى» ھېسابلىناتتى. (15:2نى كۆرۈڭ). ئادونىيا بەلكىم ئاتىسى تەرىپىدىن ئەركە چوڭ قىلىنغانلىقى ھەم ئۆزىنىڭ كېلىشكەنلىكىدىن شۇنداق مەغرۇرلىنىپ كەتكەن ئوخشايدۇ.\f*  \x ◘ \xo 1:6 \xt 1تار. 3‏:2\x*  
\v 7 ئۇ زەرۇئىيانىڭ ئوغلى يوئاب ۋە كاھىن ئابىياتار بىلەن مەسلىھەت قىلىشىپ تۇردى. ئۇلار بولسا ئادونىياغا ئەگىشىپ ئۇنىڭغا ياردەم بېرەتتى. \x ◘ \xo 1:7 \xt 1پاد. 2‏:22، 28\x*  
\v 8 لېكىن كاھىن زادوك ۋە يەھويادانىڭ ئوغلى بىنايا، ناتان پەيغەمبەر، شىمەي، رەي ۋە داۋۇتنىڭ ئۆز پالۋانلىرى ئادونىياغا ئەگەشمىدى.   
\m
\v 9 ئادونىيا قوي، كالا ۋە بوردىغان تورپاقلارنى ئەن-روگەلنىڭ يېنىدىكى زوھەلەت دېگەن تاشتا سويدۇرۇپ، ھەممە ئاكا-ئۇكىلىرىنى، يەنى پادىشاھنىڭ ئوغۇللىرى بىلەن پادىشاھنىڭ خىزمىتىدە بولغان ھەممە يەھۇدالارنى چاقىردى. \f ◼ \fr 1:9 \ft \+bd «ئەن-روگەل»\+bd* ــ بۇنىڭ مەنىسى بەلكىم «روگەلنىڭ بۇلىقى» ياكى «پاك قىزنىڭ بۇلىقى».\f*  \x ◘ \xo 1:9 \xt يە. 15‏:7؛ 18‏:16\x*  
\v 10 لېكىن ناتان پەيغەمبەر، بىنايا، پالۋانلار ۋە ئۆز ئىنىسى سۇلايماننى ئۇ چاقىرمىدى.   
\m
\v 11 ناتان بولسا سۇلايماننىڭ ئانىسى بات-شېباغا: ــ «ئاڭلىمىدىڭمۇ؟ ھاگگىتنىڭ ئوغلى ئادونىيا پادىشاھ بولدى، لېكىن غوجىمىز داۋۇت ئۇنىڭدىن خەۋەرسىز.  
\v 12 ئەمدى مانا، ئۆز جېنىڭ ۋە ئوغلۇڭ سۇلايماننىڭ جېنىنى قۇتقۇزۇشقا مېنىڭ ساڭا بىر مەسلىھەت بېرىشىمكە ئىجازەت بەرگەيسەن.  
\v 13 داۋۇت پادىشاھنىڭ ئالدىغا بېرىپ ئۇنىڭغا: ــ غوجام پادىشاھ ئۆزلىرى قەسەم قىلىپ ئۆز كەمىنىلىرىگە ۋەدە قىلىپ: «سېنىڭ ئوغلۇڭ سۇلايمان مەندىن كېيىن پادىشاھ بولۇپ تەختىمدە ئولتۇرىدۇ» دېگەن ئەمەسمىدىلە؟ شۇنداق تۇرۇقلۇق نېمىشقا ئادونىيا پادىشاھ بولىدۇ؟ ــ دېگىن.  
\v 14 مانا، پادىشاھ بىلەن سۆزلىشىپ تۇرغىنىڭدا، مەنمۇ سېنىڭ كەينىڭدىن كىرىپ سۆزۈڭنى ئىسپاتلايمەن، ــ دېدى.   
\m
\v 15 بات-شېبا ئىچكىرى ئۆيگە پادىشاھنىڭ قېشىغا كىردى (پادىشاھ تولىمۇ قېرىپ كەتكەنىدى، شۇناملىق ئابىشاگ پادىشاھنىڭ خىزمىتىدە بولۇۋاتاتتى).  
\v 16 بات-شېبا پادىشاھقا ئېڭىشىپ تەزىم قىلدى. پادىشاھ: ــ نېمە تەلىپىڭ بار؟ ــ دەپ سورىدى.   
\m
\v 17 ئۇ ئۇنىڭغا: ــ ئى غوجام، سىلى پەرۋەردىگار خۇدالىرى بىلەن ئۆز دېدەكلىرىگە: «سېنىڭ ئوغلۇڭ سۇلايمان مەندىن كېيىن پادىشاھ بولۇپ تەختىمدە ئولتۇرىدۇ» دەپ قەسەم قىلغانىدىلا.  
\v 18 ئەمدى مانا، ئادونىيا پادىشاھ بولدى! لېكىن ئى غوجام پادىشاھ، سىلىنىڭ ئۇنىڭدىن خەۋەرلىرى يوق.  
\v 19 ئۇ كۆپ كالىلارنى، بورداق تورپاقلار بىلەن قويلارنى سويدۇرۇپ، پادىشاھنىڭ ھەممە ئوغۇللىرىنى، ئابىياتار كاھىننى ۋە قوشۇننىڭ سەردارى يوئابنى چاقىردى. لېكىن قۇللىرى سۇلايماننى ئۇ چاقىرمىدى.  
\v 20 ئەمدى، ئى غوجام پادىشاھ، پۈتكۈل ئىسرائىلنىڭ كۆزلىرى سىلىگە تىكىلمەكتە، ئۇلار غوجام پادىشاھنىڭ ئۆزلىرىدىن كېيىن تەختلىرىدە كىمنىڭ ئولتۇرىدىغانلىقى توغرىسىدا ئۇلارغا خەۋەر بېرىشلىرىنى كۈتۈشۈۋاتىدۇ؛  
\v 21 بىر قارارغا كەلمىسىلە، غوجام پادىشاھ ئۆز ئاتا-بوۋىلىرى بىلەن بىللە ئۇخلاشقا كەتكەندىن كېيىن، مەن بىلەن ئوغلۇم سۇلايمان گۇناھكار سانىلىپ قالارمىزمىكىن، ــ دېدى.   
\m
\v 22 مانا، ئۇ تېخى پادىشاھ بىلەن سۆزلىشىپ تۇرغىنىدا ناتان پەيغەمبەرمۇ كىرىپ كەلدى.  
\v 23 ئۇلار پادىشاھقا: ــ ناتان پەيغەمبەر كەلدى، دەپ خەۋەر بەردى. ئۇ پادىشاھنىڭ ئالدىغا كىرىپلا، يۈزىنى يەرگە يېقىپ تۇرۇپ پادىشاھقا تەزىم قىلدى.   
\m
\v 24 ناتان: ــ ئى غوجام پادىشاھ، سىلى ئادونىيا مەندىن كېيىن پادىشاھ بولۇپ مېنىڭ تەختىمدە ئولتۇرىدۇ، دەپ ئېيتقانىدىلىمۇ؟  
\v 25 چۈنكى ئۇ بۈگۈن چۈشۈپ، كۆپ بۇقا، بوردىغان تورپاقلار بىلەن قويلارنى سويدۇرۇپ، پادىشاھنىڭ ھەممە ئوغۇللىرىنى، قوشۇننىڭ سەردارلىرىنى، ئابىياتار كاھىننى چاقىردى؛ ۋە مانا، ئۇلار ئۇنىڭ ئالدىدا يەپ-ئىچىپ: «ياشىسۇن پادىشاھ ئادونىيا!» ــ دەپ توۋلاشماقتا.  
\v 26 لېكىن قۇللىرى بولغان مېنى، زادوك كاھىننى، يەھويادانىڭ ئوغلى بىنايانى ۋە قۇللىرى بولغان سۇلايماننى ئۇ چاقىرمىدى.  
\v 27 غوجام پادىشاھ كىمنىڭ ئۆزلىرىدىن كېيىن غوجام پادىشاھنىڭ تەختىدە ئولتۇرىدىغانلىقىنى ئۆز قۇللىرىغا ئۇقتۇرماي ئۇ ئىشنى بۇيرۇدىلىمۇ؟ ــ دېدى.   
\m
\v 28 داۋۇت پادىشاھ: ــ بات-شېبانى ئالدىمغا قىچقىرىڭلار، دېدى. ئۇ پادىشاھنىڭ ئالدىغا كىرىپ، ئۇنىڭ ئالدىدا تۇردى.  
\v 29 پادىشاھ بولسا: ــ جېنىمنى ھەممە قىيىنچىلىقتىن قۇتقۇزغان پەرۋەردىگارنىڭ ھاياتى بىلەن قەسەم قىلىمەنكى،  
\v 30 مەن ئەسلىدە ئىسرائىلنىڭ خۇداسى پەرۋەردىگار بىلەن ساڭا قەسەم قىلىپ: «سېنىڭ ئوغلۇڭ سۇلايمان مەندىن كېيىن پادىشاھ بولۇپ ئورنۇمدا مېنىڭ تەختىمدە ئولتۇرىدۇ» دەپ ئېيتقىنىمدەك، بۈگۈنكى كۈندە مەن بۇ ئىشنى چوقۇم ۋۇجۇدقا چىقىرىمەن، ــ دېدى.   
\m
\v 31 ۋە بات-شېبا يۈزىنى يەرگە يېقىپ تۇرۇپ پادىشاھقا تەزىم قىلىپ: ــ غوجام داۋۇت پادىشاھ ئەبەدىي ياشىسۇن! ــ دېدى.   
\m
\v 32 داۋۇت پادىشاھ: ــ زادوك كاھىننى، ناتان پەيغەمبەرنى، يەھويادانىڭ ئوغلى بىنايانى ئالدىمغا چاقىرىڭلار، دېدى. ئۇلار پادىشاھنىڭ ئالدىغا كەلدى.   
\m
\v 33 پادىشاھ ئۇلارغا: ــ غوجاڭلارنىڭ خىزمەتكارلىرىنى ئۆزۈڭلارغا قوشۇپ، سۇلايماننى ئۆز قېچىرىمغا مىندۈرۈپ، گىھونغا ئېلىپ بېرىڭلار؛  
\v 34 ئۇ يەردە زادوك كاھىن بىلەن ناتان پەيغەمبەر ئۇنى ئىسرائىلنىڭ ئۈستىگە پادىشاھ بولۇشقا مەسىھ قىلسۇن. ئاندىن كاناي چېلىپ: ــ سۇلايمان پادىشاھ ياشىسۇن! دەپ توۋلاڭلار. \f ◼ \fr 1:34 \ft \+bd «زادوك كاھىن بىلەن ناتان پەيغەمبەر ئۇنى ئىسرائىلنىڭ ئۈستىگە پادىشاھ بولۇشقا مەسىھ قىلسۇن»\+bd* ــ «مەسىھ قىلىش»: ــ خۇدانىڭ يوليورۇقى بىلەن ئىسرائىلغا يېڭى بىر پادىشاھ بېكىتىش ئۈچۈن ئۇنىڭ بېشىغا كاھىن ياكى پەيغەمبەر تەرىپىدىن زەيتۇن مېيى سۈرۈلۈشى كېرەك ئىدى. مۇشۇ مۇراسىم «مەسىھ قىلىش» ياكى «مەسىھلەش» دېيىلگەن. شۇ مۇراسىمدىن كېيىن مۇشۇ پادىشاھ «خۇدانىڭ مەسىھ قىلغىنى» دەپ ئاتىلىپ، ھۆكۈم سۈرۈشكە خۇدانىڭ ھوقۇقىغا ئىگە، دەپ قارىلاتتى. كاھىنلار ۋە بەزى ۋاقىتلاردا پەيغەمبەرنىمۇ ئۆز ۋەزىپىسىگە بېكىتىش ئۈچۈن «مەسىھ قىلىنىش» مۇراسىمى ئۆتكۈزۈلەتتى.\f*   
\m
\v 35 ئاندىن ئۇ تەختىمدە ئولتۇرۇشقا بۇ يەرگە كەلگەندە، ئۇنىڭغا ئەگىشىپ مېڭىڭلار؛ ئۇ مېنىڭ ئورنۇمدا پادىشاھ بولىدۇ؛ چۈنكى مەن ئۇنى ئىسرائىل بىلەن يەھۇدانىڭ ئۈستىگە پادىشاھ بولۇشقا تەيىنلىدىم، ــ دېدى.   
\m
\v 36 يەھويادانىڭ ئوغلى بىنايا پادىشاھقا جاۋاب بېرىپ: ــ ئامىن! غوجام پادىشاھنىڭ خۇداسى پەرۋەردىگارمۇ شۇنداق بۇيرۇسۇن!  
\v 37 پەرۋەردىگار غوجام پادىشاھ بىلەن بىللە بولغاندەك، سۇلايمان بىلەن بىللە بولۇپ، ئۇنىڭ تەختىنى غوجام داۋۇت پادىشاھنىڭكىدىن تېخىمۇ ئۇلۇغ قىلغاي! ــ دېدى.   
\m
\v 38 زادوك كاھىن، ناتان پەيغەمبەر، يەھويادانىڭ ئوغلى بىنايا ۋە كەرەتىيلەر بىلەن پەلەتىيلەر چۈشۈپ، سۇلايماننى داۋۇت پادىشاھنىڭ قېچىرىغا مىندۈرۈپ، گىھونغا ئېلىپ باردى. \f ◼ \fr 1:38 \ft \+bd «كەرەتىيلەر بىلەن پەلەتىيلەر»\+bd* ــ بۇلار بولسا داۋۇتنىڭ خۇسۇسىي مۇھاپىزەتچىلىرىدىن ئىدى («2سام.» 18:8نى كۆرۈڭ). كەرەتىيلەر ئەسلىدە كرېت ئارىلىدىن كەلگەن بولۇشى مۇمكىن ئىدى.\f*  
\v 39 زادوك كاھىن ئىبادەت چېدىرىدىن ماي بىلەن تولغان بىر مۈڭگۈزنى ئېلىپ، سۇلايماننى مەسىھ قىلدى. ئاندىن ئۇلار كاناي چالدى. خەلقنىڭ ھەممىسى: ــ سۇلايمان پادىشاھ ياشىسۇن! ــ دەپ توۋلاشتى. \x ◘ \xo 1:39 \xt 1سام. 20‏:24\x*   
\m
\v 40 خەلقنىڭ ھەممىسى ئۇنىڭ كەينىدىن ئەگىشىپ، سۇناي چېلىپ زور شادلىق بىلەن يەر يېرىلغۇدەك تەنتەنە قىلىشتى. \f ◼ \fr 1:40 \ft \+bd «خەلقنىڭ ھەممىسى ... سۇناي چېلىپ زور شادلىق بىلەن يەر يېرىلغۇدەك تەنتەنە قىلىشتى»\+bd* ــ ئىبرانىي تىلىدا: «خەلقنىڭ ھەممىسى ... سۇناي چېلىپ زور شادلىق بىلەن تەنتەنە قىلىشىپ يەرنى يېرىۋەتتى». مۇمكىنچىلىكى باركى، يەر دەرۋەقە ئاۋازلار بىلەن يېرىلىپ كەتكەنىدى. مەسىھنىڭ كېلىشىدىمۇ چوڭ يەر تەۋرەش بولىدۇ («زەك.» 5:14، «ۋەھ.» 12:6، 18:16).\f*  
\v 41 ئەمدى ئادونىيا ۋە ئۇنىڭ بىلەن جەم بولغان مېھمانلار غىزالىنىپ چىققاندا، شۇنى ئاڭلىدى. يوئاب كاناي ئاۋازىنى ئاڭلىغاندا: ــ نېمىشقا شەھەردە شۇنچە قىيقاس-سۈرەن سېلىنىدۇ؟ ــ دەپ سورىدى.  
\v 42 ئۇ تېخى سۆزىنى تۈگەتمەيلا، مانا ئابىياتار كاھىننىڭ ئوغلى يوناتان كەلدى. ئادونىيا ئۇنىڭغا: ــ كىرگىن، قەيسەر ئادەمسەن، چوقۇم بىزگە خۇش خەۋەر ئېلىپ كەلدىڭ، ــ دېدى.   
\m
\v 43 يوناتان ئادونىياغا جاۋاب بېرىپ: ــ ئۇنداق ئەمەس! غوجىمىز داۋۇت پادىشاھ سۇلايماننى پادىشاھ قىلدى!  
\v 44 ۋە پادىشاھ ئۆزى ئۇنىڭغا زادوك كاھىننى، ناتان پەيغەمبەرنى، يەھويادانىڭ ئوغلى بىنايانى ۋە كەرەتىيلەر بىلەن پەلەتىيلەرنى ھەمراھ قىلىپ ئەۋىتىپ، ئۇنى پادىشاھنىڭ قېچىرىغا مىندۈردى؛  
\v 45 ئاندىن زادوك كاھىن بىلەن ناتان پەيغەمبەر ئۇنى پادىشاھ بولۇشقا گىھوندا مەسىھ قىلدى. ئۇلار ئۇ يەردىن چىقىپ شادلىق قىلىپ، پۈتكۈل شەھەرنى قىيقاس-سۈرەن بىلەن لەرزىگە سالدى. سىز ئاڭلاۋاتقان سادا دەل شۇدۇر.  
\v 46 ئۇنىڭ ئۈستىگە سۇلايمان ھازىر پادىشاھلىق تەختىدە ئولتۇرۇۋاتىدۇ.  
\v 47 يەنە كېلىپ پادىشاھنىڭ خىزمەتكارلىرى كېلىپ غوجىمىز داۋۇت پادىشاھقا: «خۇدالىرى سۇلايماننىڭ نامىنى سىلىنىڭكىدىن ئەۋزەل قىلىپ، تەختىنى سىلىنىڭكىدىن ئۇلۇغ قىلغاي!» دەپ بەخت تىلەپ مۇبارەكلەشكە كېلىشتى. پادىشاھ ئۆزى ياتقان ئورۇندا سەجدە قىلدى  
\v 48 ۋە پادىشاھ: ــ «بۈگۈن مېنىڭ تەختىمگە ئولتۇرغۇچى بىرسىنى تەيىنلىگەن، ئۆز كۆزلىرىمگە شۇنى كۆرگۈزگەن ئىسرائىلنىڭ خۇداسى پەرۋەردىگار مۇبارەكلەنسۇن!» ــ دېدى ــ دېدى.   
\m
\v 49 شۇنى ئاڭلاپ ئادونىيانىڭ بارلىق مېھمانلىرى ھودۇقۇپ، ئورنىدىن قوپۇپ ھەربىرى ئۆز يولىغا كەتتى.  
\v 50 ئادونىيا بولسا سۇلايماندىن قورقۇپ، ئورنىدىن قوپۇپ، \add ئىبادەت چېدىرىغا\add* بېرىپ قۇربانگاھنىڭ مۈڭگۈزلىرىنى تۇتتى. \f ◼ \fr 1:50 \ft \+bd «ئادونىيا ... سۇلايماندىن قورقۇپ، ... ئىبادەت چېدىرىغا بېرىپ قۇربانگاھنىڭ مۈڭگۈزلىرىنى تۇتتى»\+bd* ــ شۇ چاغلاردا «قۇربانگاھنىڭ مۈڭگۈزلىرىنى تۇتۇش» پادىشاھتىن ھىمايە تىلەشنى بىلدۈرۈشنىڭ ئىپادىسى ئىدى.\f*   
\m
\v 51 سۇلايمانغا شۇنداق خەۋەر بېرىلىپ: ــ «ئادونىيا سۇلايمان پادىشاھتىن قورقىدۇ؛ چۈنكى مانا، ئۇ قۇربانگاھنىڭ مۈڭگۈزلىرىنى تۇتۇپ تۇرۇپ: ــ «سۇلايمان پادىشاھ بۈگۈن ماڭا شۇنى قەسەم قىلسۇنكى، ئۇ ئۆز قۇلىنى قىلىچ بىلەن ئۆلتۈرمەسلىككە ۋەدە قىلغاي» دېدى»، ــ دېيىلدى.   
\m
\v 52 سۇلايمان: ــ ئۇ دۇرۇس ئادەم بولسا بېشىدىن بىر تال چاچ يەرگە چۈشمەيدۇ. لېكىن ئۇنىڭدا رەزىللىك تېپىلسا، ئۆلىدۇ، دېدى.   
\m
\v 53 سۇلايمان پادىشاھ ئادەم ئەۋىتىپ ئۇنى قۇربانگاھدىن ئېلىپ كەلدى. ئۇ كېلىپ سۇلايمان پادىشاھنىڭ ئالدىدا ئېڭىشىپ تەزىم قىلدى. سۇلايمان ئۇنىڭغا: ــ ئۆز ئۆيۈڭگە كەتكىن، ــ دېدى.   
\b  
\b  
\m  
\c 2
\s1 داۋۇت سۇلايمانغا ئاخىرقى نەسىھەتنى قىلىدۇ  
\m
\v 1 داۋۇتنىڭ ئۆلىدىغان ۋاقتى يېقىنلاشقاندا، ئوغلى سۇلايمانغا تاپىلاپ مۇنداق دېدى: ــ   
\m
\v 2 «ئەمدى يەر يۈزىدىكىلەرنىڭ ھەممىسى بارىدىغان يول بىلەن كېتىمەن. يۈرەكلىك بولۇپ، ئەركەكتەك بولغىن!  
\v 3 سەن بارلىق قىلىۋاتقان ئىشلىرىڭدا ھەمدە بارلىق نىيەت قىلغان ئىشلىرىڭدا راۋاج تېپىشىڭ ئۈچۈن مۇساغا چۈشۈرۈلگەن قانۇندا پۈتۈلگەندەك، پەرۋەردىگار خۇدايىڭنىڭ يوللىرىدا مېڭىپ، ئۇنىڭ بەلگىلىمىلىرى، ئۇنىڭ ئەمرلىرى، ئۇنىڭ ھۆكۈملىرى ۋە ئاگاھ-گۇۋاھلىقلىرىدا چىڭ تۇرۇپ، ئۇنىڭ تاپشۇرۇقىنى چىڭ تۇتقىن. \f ◼ \fr 2:3 \ft \+bd «بارلىق نىيەت قىلغان ئىشلىرىڭدا...»\+bd* ــ ئىبرانىي تىلىدا: «سەن قەيەرگە بۇرۇلساڭ،...» دېگەن سۆزلەر بىلەن ئىپادىلىنىدۇ.\f*  \x ◘ \xo 2:3 \xt قان. 17‏:18؛ 29‏:9؛ يە. 1‏:7\x*  
\v 4 شۇنداق قىلغاندا پەرۋەردىگار ماڭا: «ئەگەر ئەۋلادلىرىڭ ئۆز يولىغا كۆڭۈل بۆلۈپ، مېنىڭ ئالدىمدا پۈتۈن قەلبى ۋە پۈتۈن جېنى بىلەن ھەقىقەتتە ماڭسا، ساڭا ئەۋلادىڭدىن ئىسرائىلنىڭ تەختىدە ئولتۇرۇشقا بىر زات كەم بولمايدۇ» دەپ ئېيتقان سۆزىگە ئەمەل قىلىدۇ. \x ◘ \xo 2:4 \xt 2سام. 7‏:12؛ زەب. 132‏:12\x*   
\m
\v 5 ئەمما زەرۇئىيانىڭ ئوغلى يوئابنىڭ ماڭا قىلغىنىنى، يەنى ئۇنىڭ ئۆزى قانداق قىلىپ ئىسرائىلنىڭ قوشۇنىدىكى ئىككى سەردارنى، يەنى نېرىيانىڭ ئوغلى ئابنەر بىلەن يەتەرنىڭ ئوغلى ئاماسانى ئۇرۇپ ئۆلتۈرۈپ، تىنچ مەزگىلدە جەڭدە تۆكۈلگەندەك قان تۆكۈپ، بېلىگە باغلىغان كەمەرگە ۋە پۇتىغا كىيگەن كەشىگە جەڭدە تۆكۈلگەندەك قان چېچىپ، داغ قىلغانلىقىنى بىلىسەن. \x ◘ \xo 2:5 \xt 2سام. 3‏:27؛ 20‏:10\x*  
\v 6 سەن ئۇنى دانالىقىڭغا مۇۋاپىق بىر تەرەپ قىلىپ، ئۇنىڭ ئاق بېشىنىڭ گۆرگە سالامەت چۈشۈشىگە يول قويمىغايسەن. \f ◼ \fr 2:6 \ft \+bd «ئۇنىڭ ئاق بېشىنىڭ گۆرگە سالامەت چۈشۈشىگە يول قويمىغايسەن»\+bd* ــ مۇشۇ يەردە «گۆر» «تەھتىسارا» دېگەننى بىلدۈرىدۇ.\f*   
\m
\v 7 لېكىن گىلېئادلىق بارزىللاينىڭ ئوغۇللىرىغا مېھرىبانلىق كۆرسىتىپ، داستىخىنىڭدىن نان يېگۈزگىن؛ چۈنكى مەن ئاكاڭ ئابشالومدىن قاچقىنىمدا، ئۇلار يېنىمغا كېلىپ ماڭا شۇنداق قىلغان. \x ◘ \xo 2:7 \xt 2سام. 17‏:27؛ 19‏:31\x*   
\m
\v 8 ۋە مانا باھۇرىمدىن كەلگەن بىنيامىن قەبىلىسىدىن گېرانىڭ ئوغلى شىمەي يېنىڭدا تۇرىدۇ. ئۇ مەن ماھانائىمغا بارىدىغاندا، ئەشەددىي لەنەت بىلەن مېنى قارغىدى. كېيىن ئۇ ئىئوردان دەرياسىغا بېرىپ مېنىڭ ئالدىمغا كەلگەندە، مەن پەرۋەردىگارنىڭ \add نامى\add* بىلەن ئۇنىڭغا: «سېنى قىلىچ بىلەن ئۆلتۈرمەيمەن» دەپ قەسەم قىلدىم. \x ◘ \xo 2:8 \xt 2سام. 16‏:5؛ 19‏:19\x*  
\v 9 ئەمما ھازىر ئۇنى گۇناھسىز دەپ سانىمىغىن. ئۆزۈڭ دانا كىشى بولغاندىن كېيىن ئۇنىڭغا قانداق قىلىشنى بىلىسەن؛ ھەرھالدا ئۇنىڭ ئاق بېشىنى قانىتىپ گۆرگە چۈشۈرگىن». \f ◼ \fr 2:9 \ft \+bd «...ھەرھالدا ئۇنىڭ ئاق بېشىنى قانىتىپ گۆرگە چۈشۈرگىن»\+bd* ــ مۇشۇ يەردە «گۆر» «تەھتىسارا» دېگەننى بىلدۈرىدۇ. \+bd «زەرۇئىيانىڭ ئوغلى يوئاب... بىنيامىن قەبىلىسىدىن گېرانىڭ ئوغلى شىمەي»\+bd* ــ بۇ ئىككى ئادەمنىڭ سۇلايمانغا دۈشمەن بولىدىغانلىقىغا داۋۇت پادىشاھنىڭ كۆزى يەتتى. ئەسلىدە ئۇ ئۇلارنى جازالاشقا توغرا كېلەتتى؛ بىراق ئۆزى ئېغىر گۇناھ سادىر قىلغانلىقى تۈپەيلىدىن («2سام.» 11-باب) خىجالەتتە قېلىپ، قولى بۇ ئىشلارغا ھېچ بارمايتتى.\f*   
\m
\v 10 داۋۇت ئۆز ئاتا-بوۋلىرى بىلەن بىر يەردە ئۇخلىدى. ئۇ «داۋۇتنىڭ شەھىرى» \add دېگەن جايدا\add* دەپنە قىلىندى. \f ◼ \fr 2:10 \ft \+bd «داۋۇت ئۆز ئاتا-بوۋىلىرى بىلەن بىر يەردە ئۇخلىدى»\+bd* ــ مۇشۇنداق ئىبارىلەر ئۈستىدە «يارىتىلىش»تىكى «قوشۇمچە سۆز»ىمىزدە توختىلىمىز. \+bd ««داۋۇتنىڭ شەھىرى» دېگەن جاي»\+bd* ــ «داۋۇتنىڭ شەھىرى»: ــ زىئوننى، يەنى يېرۇسالېمدىكى ئېگىز دۆڭگە جايلاشقان، داۋۇت قۇرغان قەلئەنى كۆرسىتىدۇ.\f*  \x ◘ \xo 2:10 \xt روس. 2‏:29؛ 13‏:36\x*  
\v 11 داۋۇتنىڭ ئىسرائىلغا سەلتەنەت قىلغان ۋاقتى قىرىق يىل ئىدى؛ ئۇ ھېبروندا يەتتە يىل سەلتەنەت قىلىپ، يېرۇسالېمدا ئوتتۇز ئۈچ يىل سەلتەنەت قىلدى. \x ◘ \xo 2:11 \xt 1تار. 29‏:27\x*   
\b  
\m  
\s1 سۇلايماننىڭ ئورنى مۇستەھكەملىنىدۇ  
\m
\v 12 سۇلايمان ئاتىسى داۋۇتنىڭ تەختىدە ئولتۇردى؛ ئۇنىڭ سەلتەنىتى خېلى مۇستەھكەملەندى. \x ◘ \xo 2:12 \xt 1تار. 29‏:23؛ 2تار. 1‏:1\x*  
\v 13 ئەمما ھاگگىتنىڭ ئوغلى ئادونىيا سۇلايماننىڭ ئانىسى بات-شېبانىڭ قېشىغا باردى. ئۇ ئۇنىڭدىن: ــ تىنچلىق مەقسىتىدە كەلدىڭمۇ؟ ــ دەپ سورىدى. ئۇ: ــ شۇنداق، تىنچلىق مەقسىتىدە، دېدى.   
\m
\v 14 ئۇ يەنە: ــ ساڭا بىر سۆزۈم بار ئىدى، دېدى. ئۇ: ــ سۆزۈڭنى ئېيتقىن، دېدى.   
\m
\v 15 ئۇ: ــ بىلىسەنكى، پادىشاھلىق ئەسلىدە مېنىڭكى ئىدى، ۋە پۈتۈن ئىسرائىل مېنى پادىشاھ بولىدۇ دەپ، ماڭا قارايتتى. لېكىن پادىشاھلىق مەندىن كېتىپ، ئىنىمنىڭ ئىلكىگە ئۆتتى؛ چۈنكى پەرۋەردىگارنىڭ ئىرادىسى بىلەن ئۇ ئۇنىڭكى بولدى. \x ◘ \xo 2:15 \xt 1تار. 22‏:9؛ 28‏:5\x*  
\v 16 ئەمدى ساڭا بىر ئىلتىماسىم بار. مېنى ياندۇرمىغىن، دېدى. ئۇ: ــ ئېيتقىن، دېدى.   
\m
\v 17 ئۇ: ــ سەندىن ئۆتۈنىمەن، سۇلايمان پادىشاھقا مەن ئۈچۈن ئېيتقىنكى ــ چۈنكى ئۇ ساڭا ياق دېمەيدۇ! ــ ئۇ شۇناملىق ئابىشاگنى ماڭا خوتۇنلۇققا بەرسۇن، دېدى.   
\m
\v 18 بات-شېبا: ــ ماقۇل؛ سەن ئۈچۈن پادىشاھقا سۆز قىلاي، دېدى.   
\m
\v 19 بات-شېبا ئادونىيا ئۈچۈن سۆز قىلغىلى سۇلايمان پادىشاھنىڭ ئالدىغا باردى. پادىشاھ قوپۇپ ئالدىغا بېرىپ، ئانىسىغا تەزىم قىلدى. ئاندىن تەختىگە بېرىپ ئولتۇرۇپ پادىشاھنىڭ ئانىسىغا بىر تەختنى كەلتۈردى. شۇنىڭ بىلەن ئۇ ئۇنىڭ ئوڭ يېنىدا ئولتۇرۇپ، ئۇنىڭغا: ــ  
\v 20 ساڭا كىچىككىنە بىر ئىلتىماسىم بار. مېنى ياندۇرمىغىن، دېدى. پادىشاھ ئۇنىڭغا: ــ ئى ئانا، سوراۋەرگىن، مەن سېنى ياندۇرمايمەن، دېدى.   
\m
\v 21 ئۇ: ــ ئاكاڭ ئادونىياغا شۇناملىق ئابىشاگنى خوتۇنلۇققا بەرگۈزگىن، دېدى.   
\m
\v 22 سۇلايمان پادىشاھ جاۋاب بېرىپ ئانىسىغا: ــ نېمىشقا ئادونىيا ئۈچۈن شۇناملىق ئابىشاگنى سورايسەن؟ ئۇ ئاكام بولغانىكەن، ئۇنىڭ ئۈچۈن، ئابىياتار كاھىن ئۈچۈن ۋە زەرۇئىيانىڭ ئوغلى يوئاب ئۈچۈن پادىشاھلىقنىمۇ سورىمامسەن! ــ دېدى. \f ◼ \fr 2:22 \ft \+bd «نېمىشقا ئادونىيا ئۈچۈن شۇناملىق ئابىشاگنى سورايسەن؟ ئۇ ئاكام بولغانىكەن، ئۇنىڭ ئۈچۈن، ... پادىشاھلىقنىمۇ سورىمامسەن!»\+bd* ــ مۇمكىنچىلىكى باركى، ئادونىيا ئاتىسىنىڭ كېنىزىكىنى ئەمرىگە ئالسا، خەلق ئۇنى ئاتىسىغا باراۋەر ئىكەن، شۇڭا پادىشاھ بولۇشقا لايىق دەپ قارايتتى. سۇلايماننىڭ كۆزلىرى بۇ ئىشقا يەتتى.\f*   
\m
\v 23 سۇلايمان پادىشاھ پەرۋەردىگار بىلەن قەسەم قىلىپ مۇنداق دېدى: ــ ئادونىيا شۇ سۆزنى قىلغىنى ئۈچۈن ئۆلمىسە، خۇدا مېنى ئۇرسۇن ياكى ئۇنىڭدىن ئارتۇق جازالىسۇن!  
\v 24 مېنىڭ ئورنۇمنى مۇستەھكەم قىلغان، ئاتامنىڭ تەختىدە ئولتۇرغۇزغان، ئۆز ۋەدىسى بويىچە ماڭا بىر ئۆينى قۇرغان پەرۋەردىگارنىڭ ھاياتى بىلەن قەسەم قىلىمەنكى، ئادونىيا بۈگۈن ئۆلۈمگە مەھكۈم قىلىنىدۇ، دېدى. \f ◼ \fr 2:24 \ft \+bd «\+bdit پەرۋەردىگار\+bdit*... ئۆز ۋەدىسى بويىچە ماڭا بىر ئۆينى قۇرغان...»\+bd* ــ «ئۆي» مۇشۇ يەردە سۇلايماندىن بولىدىغان شاھانە سۇلالىنى كۆرسىتىدۇ.\f*  \x ◘ \xo 2:24 \xt 2سام. 7‏:12، 13\x*   
\m
\v 25 شۇنىڭ بىلەن سۇلايمان پادىشاھ يەھويادانىڭ ئوغلى بىنايانى بۇ ئىشقا ئەۋەتتى؛ ئۇ ئۇنى چېپىپ ئۆلتۈردى.   
\m
\v 26 پادىشاھ ئابىياتار كاھىنغا: ــ ماڭ، ئاناتوتتىكى ئۆز ئېتىزلىقىڭغا بارغىن. سەن ئۆلۈمگە لايىقسەن، لېكىن سەن رەب پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى ئاتام داۋۇتنىڭ ئالدىدا كۆتۈرگەنلىكىڭ تۈپەيلىدىن، ۋە ئاتامنىڭ تارتقان ھەممە ئازاب-ئوقۇبەتلىرىدە ئۇنىڭغا ھەمدەرد بولغىنىڭ ئۈچۈن، مەن ھازىر سېنى ئۆلۈمگە مەھكۇم قىلمايمەن، دېدى. \x ◘ \xo 2:26 \xt 1سام. 22‏:20-23؛ 2سام. 15‏:24\x*   
\m
\v 27 ئاندىن سۇلايمان ئابىياتارنى پەرۋەردىگارغا كاھىن بولۇشتىن جۇدا قىلىپ ھەيدىدى. شۇنىڭ بىلەن پەرۋەردىگارنىڭ ئەلىنىڭ جەمەتى توغرۇلۇق شىلوھدا ئېيتقان سۆزى ئەمەلگە ئاشۇرۇلدى. \f ◼ \fr 2:27 \ft \+bd «پەرۋەردىگارنىڭ ئەلىنىڭ جەمەتى توغرۇلۇق شىلوھدا ئېيتقان سۆزى ئەمەلگە ئاشۇرۇلدى»\+bd* ــ بۇ سۆز «1سام.» 27:2-36دە ۋە 11:3-14دە خاتىرىلەنگەن.\f*  \x ◘ \xo 2:27 \xt 1سام. 2‏:31-36\x*   
\m
\v 28 بۇنىڭ خەۋىرى يوئابقا يەتكەندە (چۈنكى يوئاب ئابشالومغا ئەگەشمىگەن بولسىمۇ، ئادونىياغا ئەگەشكەنىدى) يوئاب پەرۋەردىگارنىڭ چېدىرىغا قېچىپ قۇربانگاھنىڭ مۈڭگۈزلىرىنى تۇتتى. \x ◘ \xo 2:28 \xt 1پاد. 1‏:50\x*  
\v 29 سۇلايمان پادىشاھقا: «مانا، يوئاب پەرۋەردىگارنىڭ چېدىرىغا قېچىپ بېرىپ، قۇربانگاھنىڭ يېنىدا تۇرىدۇ» دېگەن خەۋەر يەتكۈزۈلدى. سۇلايمان يەھويادانىڭ ئوغلى بىنايانى شۇ يەرگە ئەۋەتىپ: ــ ماڭ، ئۇنى ئۆلتۈرۈۋەتكىن، دېدى.   
\m
\v 30 بىنايا پەرۋەردىگارنىڭ چېدىرىغا بېرىپ ئۇنىڭغا: ــ «پادىشاھ سېنى بۇياققا چىقسۇن!» دېدى، دېدى. ئۇ: ــ ياق، مۇشۇ يەردە ئۆلىمەن، دېدى. بىنايا پادىشاھنىڭ يېنىغا قايتىپ ئۇنىڭغا خەۋەر بېرىپ: ــ يوئاب مۇنداق-مۇنداق دېدى، ماڭا شۇنداق جاۋاب بەردى، دېدى.   
\m
\v 31 پادىشاھ ئۇنىڭغا: ــ ئۇ ئۆزى دېگەندەك قىلىپ، ئۇنى چېپىپ ئۆلتۈرگىن ۋە ئۇنى دەپنە قىلغىن. شۇنىڭ بىلەن يوئاب تۆككەن ناھەق قان مەندىن ۋە ئاتامنىڭ جەمەتىدىن كۆتۈرۈلۈپ كەتكەي.  
\v 32 شۇنداق قىلىپ ئاتام داۋۇت بىخەۋەر ئەھۋالدا ئۇ ئۆزىدىن ئادىل ۋە ئېسىل ئىككى ئادەمنى، يەنى ئىسرائىلنىڭ قوشۇنىنىڭ سەردارى نەرنىڭ ئوغلى ئابنەر بىلەن يەھۇدانىڭ قوشۇنىنىڭ سەردارى يەتەرنىڭ ئوغلى ئاماسانى قىلىچلىغىنى ئۈچۈن، پەرۋەردىگار ئۇ تۆككەن قاننى ئۆز بېشىغا ياندۇرىدۇ.  
\v 33 ئۇلارنىڭ قېنى يوئابنىڭ بېشى ۋە نەسلىنىڭ بېشىغا مەڭگۈ يانغاي؛ لېكىن داۋۇت، ئۇنىڭ نەسلى، جەمەتى ۋە تەختىگە ئەبەدىلئەبەدگىچە پەرۋەردىگاردىن تىنچ-خاتىرجەملىك بولغاي، دېدى.   
\m
\v 34 يەھويادانىڭ ئوغلى بىنايا چىقىپ ئۇنى چېپىپ، ئۆلۈمگە مەھكۇم قىلدى. ئاندىن ئۇ چۆلدىكى ئۆز ئۆيىدە دەپنە قىلىندى.   
\m
\v 35 پادىشاھ يەھويادانىڭ ئوغلى بىنايانى ئۇنىڭ ئورنىغا قوشۇننىڭ سەردارى قىلدى؛ پادىشاھ ئابىياتارنىڭ ئورنىغا زادوكنى كاھىن قىلىپ تەيىنلىدى. \x ◘ \xo 2:35 \xt 1سام. 2‏:35\x*   
\m
\v 36 ئاندىن كېيىن پادىشاھ شىمەينى چاقىرىپ ئۇنىڭغا: ــ يېرۇسالېمدا ئۆزۈڭگە بىر ئۆي سېلىپ ئۇ يەردە ئولتۇرغىن. باشقا ھېچ يەرگە چىقما.  
\v 37 ئەگەر سەن چىقىپ كىدرون جىلغىسىدىن ئۆتسەڭ، شۇنى ئېنىق بىلىپ قويكى، شۇ كۈندە سەن شەكسىز ئۆلىسەن. سېنىڭ قېنىڭ ئۆز بېشىڭغا چۈشىدۇ، دېدى.   
\m
\v 38 شىمەي پادىشاھقا: ــ غوجامنىڭ سۆزى بەرھەقتۇر. غوجام پادىشاھ ئېيتقاندەك قۇللىرى شۇنداق قىلىدۇ، دېدى. شۇنىڭ بىلەن شىمەي ئۇزۇن ۋاقىتقىچە يېرۇسالېمدا تۇردى.   
\m
\v 39 ئۈچ يىلدىن كېيىن شۇنداق بولدىكى، شىمەينىڭ قۇللىرىدىن ئىككىسى قېچىپ مائاكاھنىڭ ئوغلى، گاتنىڭ پادىشاھى ئاقىشنىڭ قېشىغا باردى. شىمەيگە: ــ مانا قۇللىرىڭ گات شەھىرىدە تۇرىدۇ، دېگەن خەۋەر يەتكۈزۈلدى.  
\v 40 شىمەي ئېشىكىنى توقۇپ قۇللىرىنى ئىزدىگىلى گاتقا، ئاقىشنىڭ يېنىغا باردى. ئاندىن ئۇ يېنىپ ئۆز قۇللىرىنى گاتتىن ئېلىپ كەلدى.   
\m
\v 41 سۇلايمانغا: ــ شىمەي يېرۇسالېمدىن گاتقا بېرىپ كەلدى، دەپ خەۋەر يەتكۈزۈلدى.  
\v 42 پادىشاھ شىمەينى چاقىرتىپ ئۇنىڭغا: ــ مەن سېنى پەرۋەردىگار بىلەن قەسەم قىلدۇرۇپ: ــ شۇنى ئېنىق بىلىپ قويكى، سەن قايسى كۈنى چىقىپ بىرەر يەرگە بارغان بولساڭ، سەن شۇ كۈنىدە شەكسىز ئۆلىسەن، دەپ ئاگاھلاندۇرۇپ ئېيتمىغانمىدىم؟ ئۆزۈڭمۇ، مەن ئاڭلىغان سۆز بەرھەق، دېگەنىدىڭغۇ؟  
\v 43 شۇنداق بولغانىكەن، نېمىشقا ئۆزۈڭ پەرۋەردىگار ئالدىدا قىلغان قەسىمىڭنى بۇزۇپ، مەن ساڭا بۇيرۇغان بۇيرۇقۇمنىمۇ تۇتمىدىڭ؟ ــ دېدى.   
\m
\v 44 پادىشاھ شىمەيگە يەنە: سەن ئاتام داۋۇتقا قىلغان ھەممە رەزىللىكنى ئوبدان بىلىسەن، ئۇ كۆڭلۈڭگە ئاياندۇر. مانا پەرۋەردىگار رەزىللىكىڭنى ئۆز بېشىڭغا ياندۇرىدۇ. \x ◘ \xo 2:44 \xt 2سام. 16‏:5، 6، 7\x*  
\v 45 لېكىن سۇلايمان پادىشاھ بولسا بەرىكەتلىنىپ، داۋۇتنىڭ تەختى پەرۋەردىگارنىڭ ئالدىدا ئەبەدىلئەبەد مۇستەھكەم قىلىنىدۇ، دېدى.   
\m
\v 46 ئاندىن پادىشاھنىڭ بۇيرۇقى بىلەن يەھويادانىڭ ئوغلى بىنايا چىقىپ ئۇنى چېپىپ ئۆلتۈردى. پادىشاھلىق بولسا سۇلايماننىڭ قولىدا مۇستەھكەم قىلىندى. \x ◘ \xo 2:46 \xt 2تار. 1‏:1\x*   
\b  
\b  
\m  
\c 3
\s1 پەرۋەردىگار سۇلايمانغا دانالىق بېرىدۇ  
\r 2تار. 1‏:1-12  
\m
\v 1 سۇلايمان مىسىرنىڭ پادىشاھى پىرەۋن بىلەن ئىتتىپاق تۈزۈپ پىرەۋننىڭ قىزىنى خوتۇنلۇققا ئالدى. ئۆز ئوردىسى، پەرۋەردىگارنىڭ ئۆيى ۋە يېرۇسالېمنىڭ چۆرىسىدىكى سېپىلنى ياساپ پۈتكۈزگۈچىلىك ئۇ ئۇنى «داۋۇتنىڭ شەھىرى»گە ئاپىرىپ تۇرغۇزدى. \x ◘ \xo 3:1 \xt 1پاد. 7‏:8\x*   
\m
\v 2 شۇ ۋاقىتلاردا پەرۋەردىگارنىڭ نامى ئۈچۈن بىر ئىبادەتخانا ياسالمىغىنى ئۈچۈن خەلق «يۇقىرى جايلار»دا قۇربانلىقلىرىنى قىلاتتى. \f ◼ \fr 3:2 \ft \+bd «خەلق «يۇقىرى جايلار»دا قۇربانلىقلىرىنى قىلاتتى»\+bd* ــ «يۇقىرى جايلار»: ــ تەۋراتتىكى «قان.» 5:12-14دە ۋە باشقا مۇناسىۋەتلىك يەرلەردە، خۇدا ئىسرائىللارغا: ــ بىرسى ماڭا ئاتاپ قۇربانلىق قىلسا، پەقەت «ئۆزۈم تاللىغان جاي»دا قۇربانلىق قىلسۇن، دەپ تاپىلايدۇ. ئىسرائىلنىڭ تارىخىدا خۇدا مۇشۇنداق قۇربانلىق قىلىدىغان بىرنەچچە جاينى بېكىتكەنىدى (بىر ۋاقىتتا پەقەت بىرلا جاينى بېكىتەتتى). بىراق ئىسرائىللار بەلكىم ئۆز قولايلىقىنى كۆزلەپ (ۋە بەلكىم بۇتپەرەسلەرنىڭ ئىش-ھەرىكەتلىرىنى دوراپ) خۇدانىڭ ئەمرىنى نەزىرىدىن ساقىت قىلىپ تاغ چوققىلىرى قاتارلىق يۇقىرى جايلاردا خۇداغا ئىبادەت قىلىپ قۇربانلىق قىلاتتى. بۇنىڭ شۇنداق بىر خەتىرى بار ئىدىكى، ئۇلار ئەتراپىدىكى بۇتپەرەسلەرنىڭ تەسىرىنى قوبۇل قىلىپ، شۇ يەردە ھەرخىل بۇتلارغىمۇ چوقۇنۇپ، ھەتتا بۇتپەرەسلەرگە ئەگىشىپ «ئىنسان قۇربانلىق»لارنىمۇ قىلىشى مۇمكىن ۋە دەرۋەقە كۆپ ۋاقىتلاردا شۇنداق قىلاتتى (مەسىلەن، «ئەز.» 21:16، 26:20نى كۆرۈڭ).\f*  \x ◘ \xo 3:2 \xt قان. 12‏:5\x*   
\m
\v 3 سۇلايمان پەرۋەردىگارنى سۆيۈپ، ئاتىسى داۋۇتنىڭ بەلگىلىگەنلىرىدە ماڭاتتى. پەقەت «يۇقىرى جايلار»دا قۇربانلىق قىلىپ خۇشبۇي ياقاتتى. \f ◼ \fr 3:3 \ft \+bd «سۇلايمان پەرۋەردىگارنى سۆيۈپ، ئاتىسى داۋۇتنىڭ بەلگىلىگەنلىرىدە ماڭاتتى؛ پەقەت «يۇقىرى جايلار»دا ... خۇشبۇي ياقاتتى»\+bd* ــ «داۋۇتنىڭ بەلگىلىگەنلىرى»: ــ شۈبھىسىزكى، مۇسا پەيغەمبەرگە چۈشۈرۈلگەن بارلىق بەلگىلىمىلەرنى ئۆز ئىچىگە ئالغان. ئۇلارنىڭ ئىچىدە، قۇربانلىق قىلىش «يۇقىرى جايلار»دا ئەمەس، بەلكى پەرۋەردىگار بېكىتكەن جايدىلا بولۇشى كېرەك، دەپ بېكىتىلگەن («قان.» 10:12-14).\f*   
\m
\v 4 پادىشاھ قۇربانلىق قىلغىلى گىبېئونغا باردى؛ چۈنكى ئۇ يەر «ئۇلۇغ يۇقىرى جاي» ئىدى. سۇلايمان ئۇ يەردىكى قۇربانگاھتا بىر مىڭ كۆيدۈرمە قۇربانلىق سۇندى. \x ◘ \xo 3:4 \xt 2تار. 1‏:3\x*  
\v 5 پەرۋەردىگار گىبېئوندا سۇلايمانغا كېچىسى چۈشىدە كۆرۈندى. خۇدا ئۇنىڭغا: ــ مېنىڭ ساڭا نېمە بېرىشىمنى لايىق تاپساڭ، شۇنى تىلىگىن، دېدى. \x ◘ \xo 3:5 \xt 1پاد. 9‏:2\x*   
\m
\v 6 سۇلايمان جاۋابەن مۇنداق دېدى: ــ قۇلۇڭ ئاتام داۋۇت سېنىڭ ئالدىڭدا ھەقىقەت، ھەققانىيلىق ۋە كۆڭلىنىڭ سەمىمىيلىكى بىلەن ماڭغانلىقى بىلەن سەن ئۇنىڭغا زور مېھرىبانلىقنى كۆرسەتكەنىدىڭ؛ ۋە سەن شۇ زور مېھرىبانلىقنى داۋام قىلىپ، بۈگۈنكى كۈندىكىدەك ئۆز تەختىدە ئولتۇرغىلى ئۇنىڭغا بىر ئوغۇل بەردىڭ.  
\v 7 ئەمدى ئى پەرۋەردىگار خۇدايىم، قۇلۇڭنى ئاتام داۋۇتنىڭ ئورنىدا پادىشاھ قىلدىڭ. ئەمما مەن پەقەت بىر گۆدەك بالا خالاس، چىقىش-كىرىشنىمۇ بىلمەيمەن. \x ◘ \xo 3:7 \xt 2تار. 2‏:7\x*  
\v 8 ئۆز قۇلۇڭ سەن تاللىغان خەلقىڭ، كۆپلۈكىدىن ساناپ بولمايدىغان ھېسابسىز ئۇلۇغ بىر خەلق ئارىسىدا تۇرىدۇ. \x ◘ \xo 3:8 \xt 2تار. 1‏:9\x*  
\v 9 شۇڭا ئۆز قۇلۇڭغا خەلقىڭنىڭ ئۈستىگە ھۆكۈم قىلىشقا ياخشى-ياماننى پەرق ئېتىدىغان ئويغاق بىر قەلبنى بەرگەيسەن؛ بولمىسا، كىم بۇ ئۇلۇغ خەلقىڭ ئۈستىگە ھۆكۈم قىلالىسۇن؟ ــ دېدى. \f ◼ \fr 3:9 \ft \+bd «ياخشى-ياماننى پەرق ئېتىدىغان ئويغاق بىر قەلب»\+bd* ــ ئىبررانىي تىلىدا «ئاڭلاشقا ئويغاق بىر قەلب».\f*   
\m
\v 10 سۇلايماننىڭ شۇنى تىلىگىنى رەبنى خۇش قىلدى.   
\m
\v 11 خۇدا ئۇنىڭغا: ــ سەن شۇنى تىلىگىنىڭ ئۈچۈن ــ يا ئۆزۈڭ ئۈچۈن ئۇزۇن ئۆمۈر تىلىمەي، يا ئۆزۈڭ ئۈچۈن دۆلەت-بايلىق تىلىمەي، يا دۈشمەنلىرىڭنىڭ جانلىرىنى تىلىمەي، بەلكى توغرا ھۆكۈم قىلغىلى ئويغاق بولۇشقا ئۆزۈڭ ئۈچۈن ئەقىل-پاراسەتنى تىلىگىنىڭ ئۈچۈن، \x ◘ \xo 3:11 \xt 2تار. 1‏:11\x*  
\v 12 مانا، سۆزۈڭ بويىچە شۇنداق قىلدىم. مانا ساڭا شۇنداق دانا ۋە يورۇتۇلغان قەلبنى بەردىمكى، سەندىن ئىلگىرى ساڭا ئوخشايدىغىنى بولمىغان، سەندىن كېيىنمۇ ساڭا ئوخشايدىغىنى بولمايدۇ. \x ◘ \xo 3:12 \xt توپ. 1‏:16\x*  
\v 13 مەن سەن تىلىمىگەن نەرسىنىمۇ، يەنى دۆلەت-بايلىق ۋە شان-شۆھرەتنى ساڭا بەردىم. شۇنىڭ بىلەن بارلىق كۈنلىرىڭدە پادىشاھلارنىڭ ئارىسىدا ساڭا ئوخشاش بولىدىغىنى چىقمايدۇ. \x ◘ \xo 3:13 \xt مات. 6‏:33؛ ئ‍ەف. 3‏:20\x*  
\v 14 ئەگەر ئاتاڭ داۋۇت ماڭغاندەك مېنىڭ يوللىرىمدا مېڭىپ، بەلگىلىمىلىرىم ۋە ئەمرلىرىمنى تۇتساڭ كۈنلىرىڭنى ئۇزارتىمەن، دېدى.   
\m
\v 15 سۇلايمان ئويغانغاندا، مانا بۇ بىر چۈش ئىدى. ئۇ يېرۇسالېمغا كېلىپ پەرۋەردىگارنىڭ ئەھدە ساندۇقىنىڭ ئالدىغا كېلىپ، ئۆرە تۇرۇپ كۆيدۈرمە قۇربانلىقلارنى قىلىپ، ئىناقلىق قۇربانلىقلىرىنى ئۆتكۈزۈپ، ھەممە خىزمەتكارلىرىغا زىياپەت قىلىپ بەردى.   
\b  
\m  
\s1 سۇلايماننىڭ دانالىقى ئايان بولىدۇ  
\m
\v 16 شۇنىڭدىن كېيىن ئىككى پاھىشە ئايال پادىشاھنىڭ قېشىغا كېلىپ ئۇنىڭ ئالدىدا تۇردى.   
\m
\v 17 بىرىنچى ئايال: ــ ئى غوجام! مەن ۋە بۇ خوتۇن بىر ئۆيدە ئولتۇرىمىز؛ ئۇ مەن بىلەن ئۆيدە تۇرغىنىدا بىر بالىنى تۇغدۇم.  
\v 18 مەن بالىنى تۇغۇپ ئۈچ كۈندىن كېيىن ئۇ خوتۇنمۇ بىر بالا تۇغدى. بىز ئىككىيلەن ئۇ يەردە ئولتۇردۇق؛ ئۆيدە بىزدىن باشقا ھېچ يات ئادەم يوق ئىدى، يالغۇز بىز ئىككىيلەن ئۆيدە ئىدۇق.  
\v 19 شۇ كېچىدە بۇ خوتۇننىڭ بالىسى ئۆلدى؛ چۈنكى ئۇ بالىسىنى بېسىپ ئۆلتۈرۈپ قويغانىدى.  
\v 20 ئۇ يېرىم كېچىدە قوپۇپ دېدەكلىرى ئۇخلاپ قالغاندا، يېنىمدىن ئوغلۇمنى ئېلىپ ئۆز قۇچىقىغا سېلىپ، ئۆزىنىڭ ئۆلگەن ئوغلىنى مېنىڭ قۇچىقىمغا سېلىپ قويۇپتۇ.  
\v 21 ئەتىسى قوپۇپ بالامنى ئېمىتەي دېسەم مانا ئۆلۈك تۇرىدۇ. لېكىن ئەتىگەندە قارىسام، ئۇ مەن تۇغقان بالا ئەمەس ئىدى، دېدى.   
\m
\v 22 ئىككىنچى ئايال: ــ ياق، ئۇنداق ئەمەس. تىرىك قالغىنى مېنىڭ ئوغلۇم، ئۆلگىنى سېنىڭ ئوغلۇڭ، دېدى. لېكىن بىرىنچى ئايال: ــ ياق، ئۆلگىنى سېنىڭ ئوغلۇڭ، تىرىك قالغىنى مېنىڭ ئوغلۇم، دېدى. ئۇلار شۇ ھالەتتە پادىشاھنىڭ ئالدىدا تالىشىپ تۇراتتى.   
\m
\v 23 پادىشاھ: ــ بىرى: «تىرىك قالغىنى مېنىڭ ئوغلۇم، ئۆلگىنى سېنىڭ ئوغلۇڭ» دەيدۇ. ئەمما يەنە بىرى: «ياق، ئۆلگىنى سېنىڭ ئوغلۇڭ، تىرىك قالغىنى مېنىڭ ئوغلۇم» دەيدۇ، دېدى.   
\m
\v 24 پادىشاھ: ماڭا بىر قىلىچ ئېلىپ كېلىڭلار، دېدى. ئۇلار قىلىچنى پادىشاھقا ئېلىپ كەلگەندە  
\v 25 پادىشاھ: تىرىك بالىنى ئوتتۇرىدىن كېسىپ ئىككى پارچە قىلىپ يېرىمىنى بىرىگە، يەنە بىر يېرىمنى ئىككىنچىسىگە بېرىڭلار، دېدى.   
\m
\v 26 ئۇ ۋاقىتتا تىرىك بالىنىڭ ئانىسى ئۆز بالىسىغا ئىچىنى ئاغرىتىپ پادىشاھقا: ــ ئاھ غوجام! تىرىك بالىنى ئۇنىڭغا بەرسىلە، ھەرگىز ئۇنى ئۆلتۈرمىگەيلە! ــ دەپ يالۋۇردى. لېكىن ئىككىنچىسى: ــ ئۇنى نە مېنىڭكى نە سېنىڭكى قىلماي، ئوتتۇرىدىن كېسىڭلار، دېدى.   
\m
\v 27 پادىشاھ جاۋابەن: ــ تىرىك بالىنى ئۇنىڭغا بېرىڭلار، ئۇنى ھېچ ئۆلتۈرمەڭلار؛ چۈنكى بۇ بالىنىڭ ئانىسى شۇدۇر، دېدى.   
\m
\v 28 پۈتكۈل ئىسرائىل پادىشاھنىڭ قىلغان ھۆكۈمى توغرىسىدا ئاڭلىدى ۋە ئۇلار پادىشاھتىن قورقتى، چۈنكى ئۇلار خۇدانىڭ ئادىل ھۆكۈملەرنى چىقىرىش دانالىقىنىڭ ئۇنىڭدا بارلىقىنى كۆردى.   
\b  
\b  
\m  
\c 4
\s1 سۇلايماننىڭ ئەمەلدارلىرى ۋە خىزمەتكارلىرى  
\m
\v 1 سۇلايمان پادىشاھ پۈتكۈل ئىسرائىلغا پادىشاھ بولدى.   
\m
\v 2 ئۇنىڭ چوڭ ئەمەلدارلىرى مۇنۇلار: ــ زادوكنىڭ ئوغلى ئازارىيا كاھىن ئىدى؛  
\v 3 شىشانىڭ ئوغۇللىرى ئېلىخورەف ۋە ئاخىياھ كاتىپلار ئىدى؛ ئاھىلۇدنىڭ ئوغلى يەھوشافات تەزكىرىچى ئىدى؛  
\v 4 يەھويادانىڭ ئوغلى بىنايا قوشۇننىڭ باش سەردارى ئىدى. زادوك بىلەن ئابىياتار كاھىنلار ئىدى؛  
\v 5 ناتاننىڭ ئوغلى ئازارىيا نازارەت بېگى، ناتاننىڭ يەنە بىر ئوغلى زابۇد ھەم كاھىن ۋە پادىشاھنىڭ مەسلىھەتچىسى ئىدى.  
\v 6 ئاخىشار ئوردىنىڭ غوجىدارى، ئابدانىڭ ئوغلى ئادونىرام باج-ئالۋان بېگى ئىدى. \x ◘ \xo 4:6 \xt 1پاد. 12‏:18\x*   
\m
\v 7 پۈتكۈل ئىسرائىل زېمىنىدا سۇلايمان پادىشاھنىڭ ئۆزى ئۈچۈن ۋە ئوردىدىكىلىرى ئۈچۈن يېمەك-ئىچمەك تەمىنلەيدىغان، ئون ئىككى نازارەتچى تەيىنلەنگەنىدى؛ ئۇلارنىڭ ھەربىرى يىلدا بىر ئايدىن يېمەك-ئىچمەك تەمىنلەشكە مەسئۇل ئىدى.  
\v 8 ئۇلارنىڭ ئىسمى تۆۋەندە خاتىرىلەنگەن: ئەفرائىم تاغلىق رايونىغا بەن-خۇر؛  
\v 9 ماكاز، شائالبىم، بەيت-شەمەش ۋە ئېلون-بەيت-ھانانغا بەن-دەكەر؛  
\v 10 ئارۇبوتقا بەن-خەسەد؛ ئۇ يەنە سوكوھ ۋە خەفەر دېگەن بارلىق يۇرتقىمۇ مەسئۇل ئىدى؛ \f ◼ \fr 4:10 \ft \+bd «سوكوھ»\+bd* ــ ياكى «سوكو».\f*  
\v 11 يەنە نافات-دورغا بەن-ئابىناداب (ئۇ سۇلايماننىڭ قىزى تافاتنى خوتۇنلۇققا ئالغان)؛  
\v 12 تائاناق، مەگىددو ۋە يىزرەئەلنىڭ تۆۋەنكى تەرىپىدىكى زارەتاننىڭ يېنىدا بولغان پۈتكۈل بەيت-شانغا، شۇنداقلا بەيت-شاندىن تارتىپ ئابەل-مەھولاھغىچە، جوكنېئامدىن ئۆتكۈچە بولغان زېمىنلارغا ئاھىلۇدنىڭ ئوغلى بائانا؛  
\v 13 راموت-گىلېئادقا بەن-گەبەر؛ ئۇ يەنە گىلېئاد يۇرتىغا جايلاشقان، ماناسسەھنىڭ ئوغلى يائىرغا تەۋە بولغان كەنتلەر ۋە ھەم باشاندىكى يۇرت ئارگوب، جۈملىدىن ئۇ يەردىكى سېپىلى، مىس بالداقلىق قوۋۇقلىرى بولغان ئاتمىش چوڭ شەھەرگىمۇ مەسئۇل ئىدى.   
\m
\v 14 ماھانائىمغا ئىددونىڭ ئوغلى ئاھىناداب؛  
\v 15 نافتالىغا ئاخىمائاز (ئۇ سۇلايماننىڭ قىزى باسىماتنى خوتۇنلۇققا ئالغانىدى).  
\v 16 ئاشىر ۋە ئالوتقا ھۇشاينىڭ ئوغلى بائاناھ؛  
\v 17 ئىسساكارغا پارۇئاھنىڭ ئوغلى يەھوشافات؛  
\v 18 بىنيامىن زېمىنىغا ئېلانىڭ ئوغلى شىمەي؛  
\v 19 گىلېئاد زېمىنىغا (ئەسلىدە ئامورىيلارنىڭ پادىشاھى سىھون ۋە باشاننىڭ پادىشاھى ئوگنىڭ زېمىنى ئىدى) ئۇرىنىڭ ئوغلى گەبەر. ئۇ شۇ يۇرتقا بىردىنبىر نازارەتچى ئىدى. \f ◼ \fr 4:19 \ft \+bd «ئۇ شۇ يۇرتقا بىردىنبىر نازارەتچى ئىدى»\+bd* ــ ياكى «ۋە پۈتكۈل زېمىن ئۈستىدە يەنە بىر نازارەتچى بار ئىدى». بەزى ئالىملار شۇ «يەنە بىر» نازارەتچىنى كەبسە يىللادىكى «-13ئاي»نىڭ ھاجىتىگە مەسئۇل، دەپ قارايدۇ.\f*   
\b  
\m  
\s1 سۇلايماننىڭ دۆلىتى ۋە شۆھرىتى  
\m
\v 20 يەھۇدا بىلەن ئىسرائىلنىڭ ئادەملىرى دېڭىز ساھىلىدىكى قۇمدەك نۇرغۇن ئىدى. ئۇلار يەپ-ئىچىپ، خۇشاللىق قىلاتتى.  
\v 21 ۋە سۇلايمان بولسا \add ئەفرات\add* دەرياسىدىن تارتىپ فىلىستىيلەرنىڭ زېمىنىغا ۋە مىسىرنىڭ چېگرالىرىغىچە بولغان ھەممە پادىشاھلىقلارنىڭ ئۈستىدە سەلتەنەت قىلاتتى. ئۇلار ئولپان كەلتۈرۈپ سۇلايماننىڭ پۈتۈن ئۆمرىدە ئۇنىڭ خىزمىتىدە بولاتتى.  
\v 22 سۇلايماننىڭ ئوردىسىغا كېتىدىغان كۈنلۈك تەمىنات ئۈچۈن ئوتتۇز كور تاسقىغان ئاق ئۇن، ئاتمىش كور قارا ئۇن، \f ◼ \fr 4:22 \ft \+bd «ئوتتۇز كور»\+bd* ــ بىر كور 220 لىتر، 30 كور 6600 لىتر.\f*  
\v 23 ئون بوردىغان ئۇي، يايلاقتىن كەلتۈرۈلگەن يىگىرمە ئۇي، يۈز قوي كېتەتتى؛ بۇنىڭدىن باشقا بۇغىلار، جەرەنلەر، كېيىكلەر ۋە بوردىغان توخۇلار لازىم ئىدى.  
\v 24 چۈنكى ئۇ تىفساھدىن تارتىپ گازاغىچە، \add ئەفرات\add* دەرياسىنىڭ بۇ تەرىپىدىكى ھەممە يۇرتلارنىڭ ئۈستىدە، يەنى \add ئەفرات\add* دەرياسىنىڭ بۇ تەرىپىدىكى بارلىق پادىشاھلارنىڭ ئۈستىگە ھۆكۈم سۈرەتتى؛ ئۇنىڭ تۆت ئەتراپى تىنچ ئىدى.  
\v 25 سۇلايماننىڭ پۈتكۈل كۈنلىرىدە داندىن تارتىپ بەئەر-شېباغىچە يەھۇدا بىلەن ئىسرائىل ئادەملىرىنىڭ ھەربىرى ئۆز ئۈزۈم تېلى ۋە ئۆز ئەنجۈر دەرىخىنىڭ تېگىدە ئامان-ئېسەن ئولتۇراتتى. \x ◘ \xo 4:25 \xt لاۋ. 26‏:5\x*   
\m
\v 26 سۇلايماننىڭ جەڭ ھارۋىلىرىنىڭ ئاتلىرى ئۈچۈن تۆت مىڭ ئاتخانىسى، ئون ئىككى مىڭ چەۋەندىزى بار ئىدى. \f ◼ \fr 4:26 \ft \+bd «تۆت مىڭ ئاتخانىسى»\+bd* ــ كۆپ كونا كۆچۈرمىلەردە «قىرىق مىڭ ئاتخانىسى» دېيىلىدۇ. لېكىن بىز بۇ ساننى كۆچۈرگۈچىلەرنىڭ خاتالىقى دەپ قارايمىز. «2تار.» 25:9دە ۋە بۇ تېكىستنىڭ بەزى گرېك تەرجىمىلىرىدە «تۆت مىڭ» دېيىلىدۇ. \+bd «ئون ئىككى مىڭ چەۋەندىزى»\+bd* ــ ياكى «ئون ئىككى مىڭ ئېتى».\f*  \x ◘ \xo 4:26 \xt 1پاد. 10‏:26؛ 2تار. 1‏:14؛ 9‏:25\x*   
\m
\v 27 مەزكۇر نازارەتچىلەرنىڭ ھەربىرى ئۆزىگە بېكىتىلگەن ئايدا سۇلايمان پادىشاھقا ۋە ئۇنىڭ داستىخىنىغا كەلگەنلەرنىڭ ھەممىسىنىڭ يېمەك-ئىچمەكلىرىنى كېمەيتمەي تەمىنلەيتتى.  
\v 28 خەلق بولسا ھەربىرى ئۆزىگە بېكىتىلگەن نورما بويىچە ئات-قېچىرلار ئۈچۈن ئارپا بىلەن سامانلارنى \add نازارەتچىلەر بار\add* يەرگە ئېلىپ كېلەتتى.   
\m
\v 29 خۇدا سۇلايمانغا دېڭىز ساھىلىدىكى قۇمدەك دانالىق، ئىنتايىن مول پەم-پاراسەت ئاتا قىلىپ، ئۇنىڭ قەلبىنى كەڭ قىلىپ زور يورۇتتى. \f ◼ \fr 4:29 \ft \+bd «ئۇنىڭ قەلبىنى كەڭ قىلىپ زور يورۇتتى»\+bd* ــ ياكى «ئۇنىڭ كۆكسى-قارنىنى بەك كەڭ قىلدى».\f*  
\v 30 شۇنىڭ بىلەن سۇلايماننىڭ دانالىقى بارلىق شەرقتىكىلەرنىڭ دانالىقىدىن ۋە مىسىردىكى بارلىق دانالىقتىن ئاشتى.  
\v 31 چۈنكى ئۇ بارلىق ئادەملەردىن، جۈملىدىن ئەزراھلىق ئېتان بىلەن ماخولنىڭ ئوغۇللىرى ھېمان، كالكول ۋە داردا دېگەنلەردىن دانا ئىدى؛ ۋە ئۇنىڭ شۆھرىتى ئەتراپىدىكى ھەممە ئەللەر ئارىسىدا يېيىلدى.  
\v 32 ئۇ ئېيتقان پەند-نەسىھەت ئۈچ مىڭ ئىدى؛ ئۇنىڭ شېئىر-كۈيلىرى بىر مىڭ بەش ئىدى.  
\v 33 ئۇ لىۋاندىكى كېدىر دەرىخىدىن تارتىپ تامدا ئۆسىدىغان لېپەكگۈلگىچە دەرەخ-گىياھلارنىڭ ھەممىسىنى بايان قىلىپ خاتىرىلىگەنىدى؛ ئۇ يەنە مال ۋە ھايۋانلار، قۇشلار، ھاشارەت-ئۆمىلىگۈچىلەر ۋە بېلىقلار توغرىسىدا بايان قىلىپ خاتىرىلىگەنىدى.  
\v 34 سۇلايماننىڭ دانالىقىنى ئاڭلىغىلى كىشىلەر بارلىق ئەللەردىن كېلەتتى، شۇنداقلا ئۇنىڭ دانالىقى توغرۇلۇق خەۋەر تاپقان يەر يۈزىدىكى ھەممە پادىشاھلاردىن كىشىلەر كەلمەكتە ئىدى.   
\b  
\b  
\m  
\c 5
\s1 ئىبادەتخانىنى قۇرۇشقا ماتېرىياللارنى توپلاش  
\r 2تار. 2‏:1-17  
\m
\v 1 تۇرنىڭ پادىشاھى ھىرام سۇلايماننى ئاتىسىنىڭ ئورنىغا پادىشاھ بولۇشقا مەسىھ قىلىنغان دەپ ئاڭلاپ، ئۆز خىزمەتكارلىرىنى ئۇنىڭ قېشىغا ئەۋەتتى؛ چۈنكى ھىرام داۋۇتنى ئىزچىل سۆيگۈچى ئىدى. \x ◘ \xo 5:1 \xt 2سام. 5‏:11؛ 1تار. 14‏:1\x*  
\v 2 سۇلايمان ھىرامغا ئادەم ئەۋىتىپ مۇنداق ئۇچۇرنى يەتكۈزدى: ــ   
\m
\v 3 «ئۆزۈڭ بىلىسەنكى، ئاتام داۋۇتنىڭ دۈشمەنلىرىنى پەرۋەردىگار ئۇنىڭ پۇتى ئاستىغا قويغۇچە، ئۇ ئەتراپىدا ھەر تەرەپتە جەڭ قىلغانلىقى تۈپەيلىدىن پەرۋەردىگار خۇداسنىڭ نامىغا بىر ئىبادەتخانا ياسىيالمىدى. \x ◘ \xo 5:3 \xt 1تار. 28‏:3\x*  
\v 4 ئەمدى ھازىر پەرۋەردىگار خۇدايىم ماڭا ھەممە تەرەپتىن ئارام بەردى؛ ھېچبىر دۈشمىنىم يوق، ھېچبىر بالا-قازا يوق.  
\v 5 مانا، پەرۋەردىگارنىڭ ئاتام داۋۇتقا: «مەن سېنىڭ ئورنۇڭغا ئۆز تەختىڭگە ئولتۇرغۇزغان ئوغلۇڭ بولسا، ئۇ مېنىڭ نامىمغا بىر ئىبادەتخانا ياسايدۇ» دەپ ئېيتقىنىدەك، مەن پەرۋەردىگار خۇدايىمنىڭ نامىغا بىر ئىبادەتخانا ياساي دەپ نىيەت قىلدىم؛ \x ◘ \xo 5:5 \xt 2سام. 7‏:13؛ 1تار. 22‏:10؛ 2تار. 1‏:18\x*  
\v 6 ئەمدى مەن ئۈچۈن \add ئادەملىرىڭگە\add* لىۋاندىن كېدىر دەرەخلىرىنى كېسىڭلار، دەپ يارلىق چۈشۈرگىن؛ مېنىڭ خىزمەتكارلىرىم سېنىڭ خىزمەتكارلىرىڭغا ھەمدەمدە بولىدۇ. سېنىڭ بېكىتكىنىڭ بويىچە خىزمەتكارلىرىڭغا بېرىلىدىغان ئىش ھەققىنى ساڭا تۆلەيمەن؛ چۈنكى ئۆزۈڭگە ئايانكى، دەرەخ كېسىشتە ئارىمىزدا ھېچكىم زىدوندىكىلەردەك ئۇستا ئەمەس».   
\m
\v 7 ھىرام سۇلايماننىڭ سۆزىنى ئاڭلىغاندا ئىنتايىن خۇشال بولۇپ: ــ بۈگۈن بۇ ئۇلۇغ خەلق ئۈستىگە ھۆكۈم سۈرۈشكە داۋۇتقا شۇنداق دانا بىر ئوغۇل بەرگەن پەرۋەردىگارغا تەشەككۈر ئېيتىلسۇن! ــ دېدى.  
\v 8 ھىرام سۇلايمانغا ئادەم ئەۋىتىپ: ــ سەن ماڭا قويغان تەلەپلىرىڭنى ئاڭلاپ قوبۇل قىلدىم. مەن سېنىڭ كېدىر ياغىچى ۋە ئارچا ياغىچى توغرۇلۇق ئارزۇ قىلغانلىرىڭنىڭ ھەممىسىنى ئادا قىلىمەن؛  
\v 9 مېنىڭ خىزمەتكارلىرىم شۇلارنى لىۋاندىن دېڭىزغا ئاپىرىدۇ؛ مەن ئۇلارنى سال قىلىپ باغلاپ، دېڭىز بىلەن سەن ماڭا بېكىتكەن يەرگە يەتكۈزىمەن، ئاندىن شۇ يەردە ئۇلارنى يەشكۈزىمەن. شۇنىڭ بىلەن سەن ئۇلارنى تاپشۇرۇۋېلىپ، ئېلىپ كېتىسەن. بۇنىڭ ھېسابىغا سەن تەلەپلىرىم بويىچە ئوردىدىكىلىرىم ئۈچۈن يېمەك-ئىچمەك تەمىنلىگەيسەن، ــ دېدى.   
\m
\v 10 شۇنداق قىلىپ، ھىرام سۇلايمانغا بارلىق تەلىپى بويىچە كېدىر ياغاچلىرى ۋە ئارچا ياغاچلىرىنى بەردى.  
\v 11 سۇلايمان ھىرامغا ئوردىدىكىلىرىنىڭ يېمەك-ئىچمىكىگە يىگىرمە مىڭ كور بۇغداي ۋە يىگىرمە بات ساپ زەيتۇن مېيىنى ئەۋەتىپ بەردى. ھەر يىلى سۇلايمان ھىرامغا شۇنداق بېرەتتى. \f ◼ \fr 5:11 \ft \+bd «يىگىرمە بات»\+bd* ــ بىر «بات» تەخمىنەن 27 لىتر، 20 بات 540 لىتر.\f*  
\v 12 پەرۋەردىگار سۇلايمانغا ۋەدە قىلغاندەك ئۇنىڭغا دانالىق بەرگەنىدى. ھىرام بىلەن سۇلايماننىڭ ئارىسىدا ئىناقلىق بولۇپ، ئىككىسى ئەھدە تۈزۈشتى. \x ◘ \xo 5:12 \xt 1پاد. 3‏:12\x*   
\m
\v 13 سۇلايمان پادىشاھ پۈتۈن ئىسرائىلدىن ھاشارغا ئىشلەمچىلەرنى بېكىتتى، ئۇلارنىڭ سانى ئوتتۇز مىڭ ئىدى.  
\v 14 ئۇ بۇلارنى نۆۋەت بىلەن ھەر ئايدا ئون مىڭدىن لىۋانغا ئەۋەتەتتى؛ شۇنداق قىلىپ، ئۇلار بىر ئاي لىۋاندا تۇرسا، ئىككى ئاي ئۆيىدە تۇردى. ئادونىرام ھاشارچىلانىڭ ئۈستىدە تۇراتتى.  
\v 15 سۇلايماننىڭ يەتمىش مىڭ ھاممىلى، تاغلاردا ئىشلەيدىغان سەكسەن مىڭ تاشچىسى بار ئىدى.  
\v 16 ئۇنىڭدىن باشقا سۇلايماننىڭ مەنسەپدارلىرىدىن ئىش ئۈستىگە قويۇلغان ئۈچ مىڭ ئۈچ يۈز ئىش بېشى بار ئىدى؛ ئۇلار ئىشلەمچىلەرنى باشقۇراتتى.   
\m
\v 17 پادىشاھ يارلىق چۈشۈرۈشى بىلەن ئۇلار ئىبادەتخانىنىڭ ئۇلىنى سېلىشقا يونۇلغان، چوڭ ۋە قىممەتلىك تاشلارنى كېسىپ كەلتۈردى.  
\v 18 ۋە سۇلايماننىڭ تامچىلىرى بىلەن ھىرامنىڭ تامچىلىرى ۋە گەباللىقلار قوشۇلۇپ تاشلارنى ئويۇپ، ئۆينى ياساش ئۈچۈن ياغاچ ھەم تاشلارنى تەييارلاپ قويدى. \f ◼ \fr 5:18 \ft \+bd «گەباللىقلار»\+bd* ــ ياكى «بىبلوسلۇقلار»، ياكى «گىرۋەكلەرنى كەسكۈچىلەر».\f*   
\b  
\b  
\m  
\c 6
\s1 مۇقەددەس ئىبادەتخانىنىڭ قۇرۇلۇشى  
\r 2تار. 3‏:1-14  
\m
\v 1 ئىسرائىللار مىسىردىن چىققاندىن كېيىنكى تۆت يۈز سەكسىنىنچى يىلى، سۇلايماننىڭ ئىسرائىلنىڭ ئۈستىدىكى سەلتەنىتىنىڭ تۆتىنچى يىلىنىڭ ئىككىنچى ئېيىدا، يەنى زىف ئېيىدا ئۇ پەرۋەردىگارنىڭ ئۆيىنى ياساشقا باشلىدى. \x ◘ \xo 6:1 \xt 2تار. 3‏:2؛ روس. 7‏:47\x*  \fig سۇلايمان پادىشاھ قۇرغان ئىبادەتخانا|src="solomontempleinsideview-uara-01.jpg" size="span" ref="1 «پاد.» 6" \fig*   
\m
\v 2 سۇلايمان پادىشاھ پەرۋەردىگارغا ياسىغان ئىبادەتخانىنىڭ ئۇزۇنلۇقى ئاتمىش گەز، كەڭلىكى يىگىرمە گەز ۋە ئېگىزلىكى ئوتتۇز گەز ئىدى. \f ◼ \fr 6:2 \ft \+bd «ئىبادەتخانىنىڭ ئۇزۇنلۇقى...»\+bd* ــ ئىبرانىي تىلىدا «ئۆينىڭ ئۇزۇنلۇقى...». \+bd «پەرۋەردىگارغا ياسىغان ئىبادەتخانىنىڭ ئۇزۇنلۇقى ئاتمىش گەز...»\+bd* ــ مۇقەددەس كىتابتا ئىشلىتىلگەن «گەز»نى بەلكىم بىر «جەينەك» دېيىشكە توغرا كېلىدۇ ــ يەنى ئادەمنىڭ جەينىكىدىن بارماقلىرىنىڭ ئۇچىغىچە بولغان ئارىلىق (تەخمىنەن 45 سانتىمېتر) ئىدى.\f*  
\v 3 ئىبادەتخانىدىكى «مۇقەددەس جاي»نىڭ ئالدىدىكى ئايۋاننىڭ ئۇزۇنلۇقى ئىبادەتخانىنىڭ كەڭلىكى بىلەن باراۋەر بولۇپ، يىگىرمە گەز ئىدى. ئىبادەتخانىنىڭ ئالدىدىكى ئايۋاننىڭ كەڭلىكى ئون گەز ئىدى. \x ◘ \xo 6:3 \xt يـۇھ. 10‏:23؛ روس. 3‏:11؛ 5‏:12\x*   
\m
\v 4 ئۇ ئىبادەتخانىغا روجەكلىك دېرىزە-پەنجىرىلەرنى ئورناتتى. \f ◼ \fr 6:4 \ft \+bd «ئۇ ئىبادەتخانىغا روجەكلىك دېرىزە-پەنجىرىلەرنى ئورناتتى»\+bd* ــ باشقا بىرنەچچە خىل تەرجىمىلەر ئۇچرىشى مۇمكىن بولغىنى بىلەن ھەرھالدا بۇ سۆزلەر دېرىزىلەرنى كۆرسىتىدۇ.\f*  
\v 5 ئىبادەتخانا تېمىغا، يەنى مۇقەددەس جاي ۋە «كالامخانا»نىڭ تېمىغا يانداش \add ئۈچ قەۋەتلىك\add* بىر ئىمارەتنى سالدى ۋە ئۇنىڭ ئىچىگە ھۇجرىلارنى ياسىدى. \f ◼ \fr 6:5 \ft \+bd «ئىبادەتخانا تېمىغا، يەنى مۇقەددەس جاي ۋە «كالامخانا»نىڭ تېمىغا...»\+bd* ــ مۇشۇ يەردە «كالامخانا» «ئەڭ مۇقەددەس جاي»نىڭ باشقا بىر ئىسمىدۇر. 16:6نى ۋە ئىزاھاتىنى كۆرۈڭ. «كالامخانا» دېيىلىشىنىڭ سەۋەبى، «ئەڭ مۇقەددەس جاي» ئىچىدە «ئەھدە ساندۇقى» بار ئىدى، «ئەھدە ساندۇقى» ئىچىدە خۇدانىڭ ئىسرائىل بىلەن تۈزگەن ئەھدىنامىسى ساقلاقلىق ئىدى.\f*   
\m
\v 6 \add تاشقىرىقى ئىمارەتنىڭ\add* تۆۋەنكى قەۋىتىنىڭ كەڭلىكى بەش گەز، ئوتتۇرا قەۋىتىنىڭ كەڭلىكى ئالتە گەز، ئۈچىنچى قەۋىتىنىڭ كەڭلىكى يەتتە گەز ئىدى. چۈنكى ئىبادەتخانىنىڭ تاشقى تېمىدا لىملارنى ئورناتقان تۆشۈكلەر بولماسلىقى ئۈچۈن ئۇ تامغا تەكچە چىقىرىلغانىدى. \f ◼ \fr 6:6 \ft \+bd «...ئىبادەتخانىنىڭ تاشقى تېمىدا لىملارنى ئورناتقان تۆشۈكلەر بولماسلىقى ئۈچۈن ئۇ تامغا تەكچە چىقىرىلغانىدى»\+bd* ــ لىمنىڭ يەنە بىر ئۇچى «تاشقى ئىمارەت»نىڭ تاشقى تېمىغا بېكىتىلىشى ئۈچۈن شۇ تەرەپتە تۆشۈك تېشىلگەن بولسا كېرەك. «ئىبادەتخانا سخېمىسى»نى كۆرۈڭ.\f*   
\m
\v 7 ئىبادەتخانا پۈتۈنلەي تەييار قىلىپ ئېلىپ كېلىنگەن تاشلاردىن بىنا قىلىنغانىدى. شۇنداق قىلغاندا، ئۇنى ياسىغان ۋاقىتتا نە بولقا نە پالتا نە باشقا تۆمۈر ئەسۋابلارنىڭ ئاۋازى ئۇ يەردە ھېچ ئاڭلانمايتتى.   
\m
\v 8 تۆۋەنكى قەۋەتنىڭ ھۇجرىلىرىنىڭ كىرىش ئىشىكى ئىبادەتخانىنىڭ ئوڭ تەرىپىدە ئىدى؛ بىر ئايلانما پەلەمپەي ئوتتۇرا قەۋەتكە ئاندىن ئوتتۇرا قەۋەتتىن ئۈچىنچى قەۋەتكە چىقاتتى. \f ◼ \fr 6:8 \ft \+bd «تۆۋەنكى قەۋەتنىڭ ھۇجرىلىرىنىڭ كىرىش ئىشىكى ئىبادەتخانىنىڭ ئوڭ تەرىپىدە ئىدى»\+bd* ــ بىز مۇشۇ يەردە («تۆۋەنكى قەۋەت» دېگەن سۆزلەر بىلەن) كونا گرېك تىلىدىكى تەرجىمىگە ئەگەشتۇق. «ئىبادەتخانىنىڭ ئوڭ تەرىپى» ئىبادەتخانىنىڭ جەنۇبىي تەرىپىدۇر.\f*   
\m
\v 9 شۇنداق قىلىپ \add سۇلايمان\add* ئىبادەتخانىنى ياساپ پۈتتۈردى. ئىبادەتخانىنىڭ ئۈستىگە خار-لىملارنى بېكىتىپ، ئۇنى كېدىر تاختايلار بىلەن قاپلىدى.  
\v 10 ئۇ ئىبادەتخانىغا يانداش ئىمارەتنىڭ قەۋەتلىرىنىڭ ئېگىزلىكىنى بەش گەزدىن قىلدى. شۇ ئىمارەتنىڭ قەۋەتلىرى ئىبادەتخانىغا كېدىر لىملىرى ئارقىلىق تۇتۇشۇقلۇق ئىدى.   
\b  
\m
\v 11 پەرۋەردىگارنىڭ سۆزى سۇلايمانغا كېلىپ مۇنداق دېگەندە: ــ   
\m
\v 12 «سەن ماڭا ياساۋاتقان بۇ ئىبادەتخانىغا كەلسەك، ئەگەر سەن بەلگىلىمىلىرىمدە مېڭىپ، ھۆكۈملىرىمگە رىئايە قىلىپ، بارلىق ئەمرلىرىمنى تۇتۇپ ئۇلاردا ماڭساڭ، مەن ئاتاڭ داۋۇتقا سەن توغرۇلۇق ئېيتقان سۆزۈمگە ئەمەل قىلىمەن؛ \x ◘ \xo 6:12 \xt 2سام. 7‏:13؛ 1پاد. 2‏:4؛ 9‏:4؛ 1تار. 22‏:10، 19\x*  
\v 13 مەن ئىسرائىللارنىڭ ئارىسىدا ماكان قىلىپ ئۆز خەلقىم ئىسرائىلنى ئەسلا تاشلىمايمەن».   
\m
\v 14 سۇلايمان ئىبادەتخانىنى ياساپ پۈتتۈردى.  
\v 15 ئىبادەتخانىنىڭ تاملىرىنىڭ ئىچ تەرىپىنى ئۇ كېدىر تاختايلىرى بىلەن ياساپ، ئىبادەتخانىنىڭ تېگىدىن تارتىپ تورۇسنىڭ لىملىرىغىچە ياغاچ بىلەن قاپلىدى؛ ۋە ئارچا تاختايلىرى بىلەن ئىبادەتخانىغا پول ياتقۇزدى.   
\m
\v 16 ئۇ ئىبادەتخانىنىڭ ئارقا تېمىدىن يىگىرمە گەز ئۆلچەپ ئارا تام ياساپ، ئىچكىرىكى خانىنى ھاسىل قىلدى؛ ئۇ تېگىدىن تارتىپ تورۇس لىملىرىغىچە كېدىر تاختايلىرى بىلەن قاپلىدى. بۇ ئەڭ ئىچكىرىكى خانا بولۇپ، يەنى «كالامخانا»، «ئەڭ مۇقەددەس جاي» ئىدى. \f ◼ \fr 6:16 \ft \+bd «بۇ ئەڭ ئىچكىرىكى خانا بولۇپ، يەنى «كالامخانا»، «ئەڭ مۇقەددەس جاي» ئىدى»\+bd* ــ «ئەڭ مۇقەددەس جاي»نىڭ «كالامخانا» دەپ ئاتىلىشىنىڭ سەۋەبى، ئۇنىڭدا خۇدا مۇسا پەيغەمبەرگە تاپشۇرغان «ئەھدە تاش تاختىلىرى» (خۇدانىڭ كالامى) «ئەھدە ساندۇقى» ئىچىدە تۇراتتى؛ ۋە ئۇنىڭ ئۈستىگە بەلكىم بەزى ۋاقتىدا، باش كاھىن شۇ «ئەڭ مۇقەددەس جاي»غا كىرگەندە، خۇدانىڭ بېشارەتلىرى ئۇلارغا كېلىشى مۇمكىن ئىدى.\f*   
\m
\v 17 ئۇنىڭ ئالدىدىكى ئۆي، يەنى مۇقەددەس خانىنىڭ ئۇزۇنلۇقى قىرىق گەز ئىدى.  
\v 18 ئىبادەتخانىنىڭ ئىچكى تاملىرىغا قاپاق ۋە چېچەكنىڭ نۇسخىلىرى نەقىش قىلىنغانىدى. ئىبادەتخانا پۈتۈنلەي كېدىر تاختايلار بىلەن قاپلانغانىدى. ھېچ تاش كۆرۈنمەيتتى.   
\m
\v 19 پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى ئۇ يەردە قويۇش ئۈچۈن، ئۇ ئىبادەتخانىنىڭ ئىچكىرىدىكى كالامخانىنى ياسىدى.  
\v 20 كالامخانىنىڭ ئۇزۇنلۇقى يىگىرمە گەز، توغرىسى يىگىرمە گەز، ئېگىزلىكى يىگىرمە گەز ئىدى؛ ئۇ ئۇنى ساپ ئالتۇندىن قاپلىدى، شۇنداقلا ئۇنىڭ ئالدىدىكى كېدىر ياغاچلىق قۇربانگاھنىمۇ شۇنداق قاپلىدى. \f ◼ \fr 6:20 \ft \+bd «ئۇ ... ئۇنىڭ ئالدىدىكى كېدىر ياغاچلىق قۇربانگاھنىمۇ شۇنداق قاپلىدى»\+bd* ــ بۇ ئىچىدىكى قۇربانگاھقا قۇربانلىقلار سۇنۇلمايتتى؛ ئۇ «خۇشبۇيدان» ياكى «خۇشبۇيگاھ» ئىدى.\f*  
\v 21 سۇلايمان ئىبادەتخانىنىڭ ئىچىنى ساپ ئالتۇن بىلەن قاپلىدى؛ ئۇ ئىچكى كالامخانىنىڭ ئالدىنى ئالتۇن زەنجىرلەر بىلەن توسىدى؛ كالامخانىنى ئالتۇن بىلەن قاپلىدى.  
\v 22 شۇ تەرىقىدە ئۇ پۈتكۈل ئىبادەتخانىنى، يەنى پۈتكۈل ئىبادەتخانىنىڭ ئىچىنى ئالتۇن بىلەن تولۇق قاپلىغانىدى. كالامخانىغا تەئەللۇق بولغان قۇربانگاھنىمۇ پۈتۈنلەي ئالتۇن بىلەن قاپلىغانىدى. \f ◼ \fr 6:22 \ft \+bd «كالامخانىغا تەئەللۇق بولغان قۇربانگاھ»\+bd* ــ بۇ «قۇربانگاھ»، يەنى «خۇشبۇيدان» ئادەتتە كالامخانىنىڭ سەل ئالدىدا، «مۇقەددەس جاي»نىڭ ئىچىدە ئىدى.\f*   
\m
\v 23 كالامخانىغا ئۇ زەيتۇن ياغىچىدىن ئىككى كېرۇبنىڭ شەكلىنى ياسىدى. ھەربىرىنىڭ ئېگىزلىكى ئون گەز ئىدى. \f ◼ \fr 6:23 \ft \+bd «كېرۇبلار»\+bd* ــ كېرۇبلار بولسا خۇدانىڭ ھۆكۈم-جازالىرىنى يەتكۈزىدىغان، ئىنتايىن كۈچلۈك پەرىشتىلەردۇر. مەسىلەن، «يار.» 24:3 ۋە «ئەز.» 10-بابنى كۆرۈڭ.\f*  \x ◘ \xo 6:23 \xt مىس. 25‏:18\x*  
\v 24 بىر كېرۇبنىڭ بىر قانىتىنىڭ ئۇزۇنلۇقى بەش گەز ۋە يەنە بىر قانىتىنىڭ ئۇزۇنلۇقى ھەم بەش گەز بولۇپ، بىر قانىتىنىڭ ئۇچىدىن يەنە بىر قانىتىنىڭ ئۇچىغىچە ئون گەز ئىدى.  
\v 25 ئىككىنچى كېرۇبنىڭ ئىككى قانىتى قوشۇلۇپ ئون گەز ئىدى. ئىككى كېرۇبنىڭ چوڭ-كىچىكلىكى ۋە شەكلى ئوخشاش ئىدى.  
\v 26 بىر كېرۇبنىڭ ئېگىزلىكى ئون گەز بولۇپ، ئىككىنچى كېرۇبنىڭكىمۇ ھەم شۇنداق ئىدى.  
\v 27 ئۇ كېرۇبلارنى ئىچكىرىكى خانىدا قويدى. كېرۇبلارنىڭ قاناتلىرى يېيىلىپ تۇراتتى. بىرسىنىڭ بىر قانىتى بىر تامغا تېگىپ، ئىككىنچىسىنىڭ قانىتى ئۇدۇلىدىكى تامغا تېگىپ تۇراتتى؛ ئىككىسىنىڭ ئىچىدىكى قاناتلىرى خانىنىڭ ئوتتۇرىسىدا بىر-بىرىگە تېگىشىپ تۇراتتى. \x ◘ \xo 6:27 \xt مىس. 25‏:20\x*  
\v 28 ئۇ كېرۇبلارنى ئالتۇن بىلەن قاپلىدى.   
\m
\v 29 ئۇ ئىبادەتخانىنىڭ تاملىرىنىڭ پۈتكۈل ئىچ چۆرىسىنى، يەنى ئىچكىرىكى خانىنىڭ ۋە ھەم تاشقىرىقى خانىنىڭ چۆرىسىنى كېرۇب بىلەن خورما دەرەخلىرىنىڭ شەكىللىرى ۋە چېچەك نۇسخىلىرى بىلەن نەقىش قىلدى.  
\v 30 ئىبادەتخانىنىڭ پولىنى، يەنى ئىچكىرىكى خانىنىڭ ھەم تاشقىرىقى خانىنىڭكىنى ئالتۇن بىلەن قاپلىدى.   
\m
\v 31 كالامخانىنىڭ كىرىش ئېغىزىغا ئۇ زەيتۇن ياغىچىدىن ئېتىلگەن قوش ئىشىكلەرنى ياسىدى. ئىشىكلەرنىڭ كېشەكلىرى ۋە بېشى ئۆينىڭ توغرىسىنىڭ بەشتىن بىر قىسمى ئىدى. \f ◼ \fr 6:31 \ft \+bd «ئىشىكلەرنىڭ كېشەكلىرى ۋە بېشى ئۆينىڭ توغرىسىنىڭ بەشتىن بىر قىسمى ئىدى»\+bd* ــ باشقا تەرجىمىسى: «ئىشىكلەرنىڭ كېشەكلىرى بەش چاسىلىق ئىدى». ئىبرانىي تىلىنى چۈشىنىش تەس.\f*  
\v 32 بۇ قوش ئىشىكلەر زەيتۇن ياغىچىدىن ئېتىلگەنىدى؛ ئۇ ئىشىكلەرنىڭ ئۈستىگە كېرۇبلار، خورما دەرەخلىرى ۋە چېچەك نۇسخىلىرى نەقىش قىلىنىپ زىننەتلەنگەنىدى؛ ئۇ ئىشىكلەرنى، جۈملىدىن كېرۇب بىلەن خورما دەرەخلىرىنىڭ نەقىشلىرىنى ئالتۇن بىلەن قاپلىدى.   
\m
\v 33 ئىبادەتخانىنىڭ تاشقى خانىسىنىڭ ئىشىكىنىڭ كېشەكلىرىنى زەيتۇن ياغىچىدىن ياسىدى؛ ئۇلار ئۆينىڭ توغرىسىنىڭ تۆتتىن بىر قىسمى ئىدى؛ \f ◼ \fr 6:33 \ft \+bd « \+bdit كېشەكلەر\+bdit* ئۆينىڭ توغرىسىنىڭ تۆتتىن بىر قىسمى ئىدى»\+bd* ــ باشقا تەرجىمىسى: «ئۇلار (كېشەكلەر) تۆت چاسىلىق ئىدى». ئىبرانىي تېكىستنى چۈشىنىش تەس.\f*  
\v 34 قوش قاناتلىق ئىشىك بولسا ئارچا ياغىچىدىن ياسالدى. بىر قانىتى يېيىلىپ قاتلىناتتى، ئىككىنچى قانىتىمۇ يېيىلىپ قاتلىناتتى.  
\v 35 ئۇ ئۇلارنىڭ ئۈستىگە كېرۇبلار، خورما دەرەخلىرى ۋە چېچەك نۇسخىلىرىنى نەقىش قىلدى؛ ئاندىن ئۇلارنىڭ ئۈستىگە، جۈملىدىن نەقىشلەر ئۈستىگە ئالتۇن قاپلىدى.   
\m
\v 36 ئىچكىرىكى ھويلىنىڭ تېمىنى بولسا ئۇ ئۈچ قەۋەت يونۇلغان تاش بىلەن بىر قەۋەت كېدىر ياغىچىدىن ياسىدى.   
\m
\v 37 \add سۇلايماننىڭ سەلتەنىتىنىڭ\add* تۆتىنچى يىلىنىڭ زىف ئېيىدا پەرۋەردىگارنىڭ ئىبادەتخانىسىنىڭ ئۇلى سېلىندى. \f ◼ \fr 6:37 \ft \+bd «تۆتىنچى يىلىنىڭ زىف ئېيىدا...»\+bd* ــ «زىف» ئېيى ئىككىنچى ئاي. بۇ بەلكىم مىلادىيەدىن ئىلگىرىكى 966-يىلى، ئاپرېل ياكى ماي ئايلىرى بولۇشى مۇمكىن ئىدى.\f*  
\v 38 ۋە ئون بىرىنچى يىلىنىڭ بۇل ئېيىدا، يەنى سەككىزىنچى ئايدا ئىبادەتخانىنىڭ ھېچيېرى قالدۇرۇلماي، لايىھە بويىچە پۈتۈنلەي تامام بولدى. شۇنداق قىلىپ ئۇنىڭ ئۆينى ياسىشىغا يەتتە يىل كەتتى. \f ◼ \fr 6:38 \ft \+bd «لايىھە بويىچە پۈتۈنلەي تامام بولدى»\+bd* ــ مۇشۇ يەردە «لايىھە» بەلكىم داۋۇت مۇقەددەس روھنىڭ كۆرسەتمىسى ئارقىلىق ئالدىن كۆرسەتكەن سخېمىسىنى كۆرسىتىدۇ «1تار.» 19:28).\f*   
\b  
\b  
\m  
\c 7
\s1 ئوردىنىڭ قۇرۇلۇشى  
\m
\v 1 سۇلايمان ئۆز ئوردىسىنى بولسا، ئون ئۈچ يىلدا ياساپ پۈتتۈردى. \f ◼ \fr 7:1 \ft \+bd «سۇلايمان ئۆز ئوردىسىنى بولسا، ئون ئۈچ يىلدا ياساپ پۈتتۈردى»\+bd* ــ سۇلايمان ئىبادەتخانىنى قۇرۇشقا 7 يىل، ئۆز ئوردىسىنى قۇرۇشقا 13 يىل ۋاقىت سەرپ قىلدى. پۈتكۈل مۇقەددەس كىتابتا «7» دېگەن رەقەم بەزىدە خۇدا ۋە ئۇنىڭ مۇكەممەللىكىگە باغلىق، «13» بولسا گۇناھ ۋە ئاسىيلىق بىلەن باغلىق بولىدۇ. بىزدە ھېچ گۇمان يوقكى، سۇلايماننىڭ ئۆز ئوردىسىغا 13 يىل سەرپ قىلىشى ئۇنىڭ ئاللىقاچان تەكەببۇر بولۇپ كەتكەنلىكىنى پۇرىتىپ بېرىدۇ. ھېچ بولمىغاندا، ئۇ كۆپرەك ۋاقتىنى ئۆز ئۆيى ئۈستىگە سەرپ قىلغان.\f*  \x ◘ \xo 7:1 \xt 1پاد. 9‏:10\x*   
\m
\v 2 ئۇ ياسىغان بۇ «لىۋان ئورمىنى سارىيى»نىڭ ئۇزۇنلۇقىنى يۈز گەز، كەڭلىكىنى ئەللىك گەز ۋە ئېگىزلىكىنى ئوتتۇز گەز قىلدى. كېدىر ياغىچى تۈۋرۈكىدىن تۆت قاتار ۋە تۈۋرۈكلەرنىڭ ئۈستىگە كېدىر لىملىرى قويۇلغانىدى. \f ◼ \fr 7:2 \ft \+bd «لىۋان ئورمىنى سارىيى»\+bd* ــ سۇلايماننىڭ ئوردىسىنىڭ «لىۋان ئورمىنى سارىيى» دەپ ئاتىلىشىنىڭ سەۋەبى ئۇنىڭ قۇرۇلۇشىدا لىۋاندىن كەلتۈرۈلگەن چىرايلىق كېدىر ياغاچلىرىنى كۆپ ئىشلەتكەنلىكتىن بولغانىدى. ئوردا ئىچىدە «كېدىر ياغىچى تۈۋرۈكىدىن تۆت قاتار» بولغىنى ئۈچۈن «ئورماندەك» كۆرۈنگەن بولسا كېرەك.\f*  
\v 3 تۈۋرۈكلەرنىڭ ئۈستىدىكى لىم كۆتۈرۈپ تۇرغان ئۆگزىسىمۇ كېدىر ياغىچىدىن ئىدى. لىملار جەمئىي قىرىق بەش بولۇپ ھەر قاتاردا ئون بەشتىن ئىدى.  
\v 4 ئۇنىڭ ئۈچ قەۋەت دېرىزىسى بار ئىدى، ئۈچ قەۋەتتىكى دېرىزىلەر بىر-بىرىگە ئۇدۇلمۇئۇدۇل ئىدى. \f ◼ \fr 7:4 \ft \+bd «ئۈچ قەۋەتتىكى دېرىزىلەر بىر-بىرىگە ئۇدۇلمۇئۇدۇل ئىدى»\+bd* ــ بۇ ئايەتتىكى بەزى ئىبرانىي سۆزلەر ئىنتايىن ئاز ئۇچرايدىغان بولغاچقا، مەنىسىنى پەقەت پەرەز قىلغىلى بولىدۇ. باشقا بىر تەرجىمىسى بەلكىم: «ئۈچ قەۋەتتىكى ھەربىر دېرىزە كۆزنەكلىك ئىدى».\f*   
\m
\v 5 بارلىق ئىشىكلەر ۋە كېشەكلەر تۆت چاسىلىق قىلىنغاندى؛ ئىشىكلەر ئۈچ كۆزنەكلىك بولۇپ، ئىشىكلەر بىر-بىرىگە ئۇدۇلمۇئۇدۇل ئىدى. \f ◼ \fr 7:5 \ft \+bd «ئىشىكلەر ئۈچ كۆزنەكلىك بولۇپ، ئىشىكلەر بىر-بىرىگە ئۇدۇلمۇئۇدۇل ئىدى»\+bd* ــ كۆپ باشقا خىل تەرجىمىلىرى ئۇچرىشىمۇ مۇمكىن.\f*   
\m
\v 6 ئۇ ئۇزۇنلۇقىنى ئەللىك گەز، توغرىسىنى ئوتتۇز گەز قىلىپ، تۈۋرۈكلۈك بىر دەھلىز ياسىدى؛ ئۇنىڭ ئالدىدا يەنە بىر دەھلىز بار ئىدى، ۋە ئۇنىڭ ئالدىدا يەنە تۈۋرۈكلۈك ئايۋان بار ئىدى. \f ◼ \fr 7:6 \ft \+bd «ئۇنىڭ ئالدىدا يەنە بىر دەھلىز بار ئىدى، ۋە ئۇنىڭ ئالدىدا يەنە تۈۋرۈكلۈك ئايۋان بار ئىدى»\+bd* ــ بۇ ئايەتنىڭ ئىككىنچى قىسمىدىكى ئىبرانىيچە ئىبارىلەر ئىنتايىن ئاز ئۇچرايدىغان بولغاچقا، مەنىسىنى پەقەت پەرەز قىلغىلى بولىدۇ. «...ئۇنىڭ ئالدىدا يەنە تۈۋرۈكلۈك ئايۋان بار ئىدى» دېگەننىڭ باشقا بىرخىل تەرجىمىسى «...ئۇنىڭ ئالدىدا يەنە تۈۋرۈكلەر ۋە پەلەمپەي بار ئىدى».\f*   
\m
\v 7 ئاندىن كېيىن ئۇ سوراق سورايدىغان تەختى ئۈچۈن «سوراق دەھلىزى» دەپ ئاتالغان يەنە بىر دەھلىزنى ياسىدى. ئۇ دەھلىزنىڭ تېگىدىن تارتىپ تورۇسنىڭ لىملىرىغىچە كېدىر ياغىچى بىلەن قاپلانغانىدى.   
\m
\v 8 \add سۇلايمان\add* ئۆزى ئولتۇرىدىغان ساراي، يەنى دەھلىزنىڭ ئارقا ھويلىسىغا جايلاشاقان ساراينىڭ لايىھىسى «\add سوراق\add* ئۆيى»نىڭكىگە ئوخشاش ئىدى. سۇلايمان ئۆز ئەمرىگە ئالغان پىرەۋننىڭ قىزى ئۈچۈن شۇ دەھلىزگە ئوخشاش بىر ساراينى ياساتتى. \f ◼ \fr 7:8 \ft \+bd «...يەنى دەھلىزنىڭ ئارقا ھويلىسىغا جايلاشاقان ساراينىڭ...»\+bd* ــ باشقا بىرخىل تەرجىمىسى «...يەنى شۇ ئۆيدىن ئايرىم بولغان، بىر ھويلىلىق، دەھلىز ئىچىگە جايلاشقان ئۆينىڭ...».\f*  \x ◘ \xo 7:8 \xt 1پاد. 3‏:1\x*  \fig خەرىتە - سۇلاتمان پادىشاھ قۇرغان «لېۋان ئورمىنى ئوردىسى»، چوڭ ئوردىسى ۋە ئىبادەتخانا|src="houseforestsolomonspalacaandtemple-uara-01.jpg" size="span" ref="1 «پاد.» 7" \fig*   
\m
\v 9 بۇ ئىمارەتلەرنىڭ ھەممىسى ئىچكىرىكى تاملىرىدىن تارتىپ چوڭ ھويلىنىڭ تاملىرىغىچە، ئۇلىدىن تارتىپ ئۆگزىنىڭ پەۋازىغىچە قىممەت تاشلاردىن، يەنى ئۆلچەم بويىچە ئويۇلۇپ ئاندىن ئىچ-تېشى ھەرە بىلەن كېسىلگەن تاشلاردىن ياسالغانىدى.  
\v 10 ئۇللىرى بولسا چوڭ ۋە قىممەت تاشلاردىن، ئۇزۇنلۇقى ئون گەز ۋە سەككىز گەز بولغان تاشلاردىن قىلىنغانىدى.  
\v 11 ئۇللارنىڭ ئۈستىگە يەنە بېكىتىلگەن ئۆلچەم بويىچە ئويۇلغان قىممەت ئېسىل تاشلار ۋە كېدىر لىملىرى قويۇلغانىدى.  
\v 12 چوڭ ھويلىنىڭ چۆرىسىدىكى تام ئۈچ قەۋەت ئويۇلغان تاش ۋە بىر قەۋەت يونۇلغان كېدىر لىملىرىدىن ياسالغانىدى. پەرۋەردىگارنىڭ ئىبادەتخانىسىنىڭ ئىچكىرىكى ھويلىسىنىڭ تېمى ۋە يەنە ئوردىدىكى دەھلىزىنىڭ تېمىمۇ شۇنداق ياسالغانىدى. \f ◼ \fr 7:12 \ft \+bd «ئوردىدىكى دەھلىزىنىڭ تېمى...»\+bd* ــ ياكى «ئىبادەتخانىدىكى ئايۋىنىنىڭ تېمى...»\f*   
\b  
\m  
\s1 ئۇستا مىسكەر ھىرامنىڭ ئىبادەتخانىدىكى ئىشلىرى  
\r 2تار. 3‏:15-17؛ 2تار. 4؛ 2تار. 1:5  
\m
\v 13 سۇلايمان پادىشاھ ئادەم ئەۋەتىپ ھىرامنى تۇردىن كەلتۈردى. \x ◘ \xo 7:13 \xt 2تار. 2‏:12\x*  
\v 14 ئۇ كىشى نافتالى قەبىلىسىدىن بولغان بىر تۇل خوتۇننىڭ ئوغلى بولۇپ، ئاتىسى تۇرلۇق بىر مىسكەر ئىدى. ھىرام مىسكەرچىلىكتە تۈرلۈك ئىشلارنى قىلىشقا تولىمۇ ئۇستا، پەم-پاراسەتلىك ۋە بىلىملىك ئىدى. ئۇ سۇلايمان پادىشاھنىڭ قېشىغا كېلىپ، ئۇنىڭ ھەممە ئىشىنى قىلدى. \x ◘ \xo 7:14 \xt مىس. 31‏:3\x*  
\v 15 ئۇ ئۆزى ئىككى تۈۋرۈكنى مىستىن ياسىدى. ھەربىر تۈۋرۈكنىڭ ئېگىزلىكى ئون سەككىز گەز بولۇپ، ئايلانمىسى ئون ئىككى گەز ئىدى. \x ◘ \xo 7:15 \xt 2پاد. 25‏:16، 17؛ يەر. 52‏:21\x*   
\m
\v 16 بۇ تۈۋرۈكلەرنىڭ ئۈستىگە قويۇش ئۈچۈن مىستىن ئىككى تاجنى قۇيۇپ ياساپ، ئۇنىڭ ئۈستىگە قويدى. بىر تاجنىڭ ئېگىزلىكى بەش گەز، ئىككىنچى تاجنىڭ ئېگىزلىكىمۇ بەش گەز ئىدى.  
\v 17 تۈۋرۈكلەرنىڭ تۆپىسىدىكى تاجلار تورلارغا ئوخشاش زىننەتلىنىپ، زەنجىرلەر ۋە تورلانغان ھالقىلار بىلەن توقۇقلۇق ئىدى. بىر تاجنىڭ شۇنداق يەتتە قاتار تور ھالقىلىرى بار ئىدى، ئىككىنچى تاجنىڭمۇ ھەم شۇنداق يەتتە قۇر تور ھالقىلىرى بار ئىدى.  
\v 18 ئۇ يەنە ئانارلارنى، يەنى تۈۋرۈكلەرنىڭ ئۈستىدىكى ھەربىر تاجنى يېپىپ تۇرىدىغان تور ھالقىلارنىڭ ئۈستىگە ئىككى قاتار ئانارنى ياسىدى. ئۇ بىرىنچى ۋە ئىككىنچى تاجغىمۇ ئوخشاشلا شۇنداق قىلدى.  
\v 19 ئايۋاندىكى تۈۋرۈكلەرنىڭ ئۈستىدىكى تاجلىرى نىلۇپەر شەكىللىك بولۇپ، ئېگىزلىكى تۆت گەزدىن ئىدى.  
\v 20 ئىككى تۈۋرۈكنىڭ تاجلىرىدىكى تور ھالقىلىرىغا يېقىن تومپىيىپ چىققان جاينىڭ ئۈستىدە قەۋەتمۇ-قەۋەت چۆرىدىگەن ئىككى يۈز ئانار نۇسخىسى بار ئىدى. ئىككىنچى تاجنىڭ چۆرىسىمۇ ئوخشاش ئىدى.   
\m
\v 21 ئۇ تۈۋرۈكلەرنى ئىبادەتخانىنىڭ ئالدىدىكى ئايۋانغا تىكلىدى. ئوڭ تەرىپىگە بىرنى تىكلەپ نامىنى «ياقىن»، سول تەرىپىگە بىرنى تىكلەپ، نامىنى «بوئاز» ئاتىدى. \f ◼ \fr 7:21 \ft \+bd «ئوڭ تەرىپىگە بىرنى تىكلەپ نامىنى «ياقىن»، سول تەرىپىگە بىرنى تىكلەپ، نامىنى «بوئاز» ئاتىدى»\+bd* ــ «ياقىن» دېگەننىڭ مەنىسى بەلكىم «ئۇ مۇستەھكەملەيدۇ»، «بوئاز»نىڭ مەنىسى بەلكىم «ئۇنىڭدا كۈچ بار». ئوڭدىن سولغا ئوقۇغاندا «ئۇ (پەرۋەردىگار) كۈچ بىلەن ئۇنى (بۇ ئۆينى) مۇستەھكەملەيدۇ».\f*  
\v 22 تۈۋرۈكلەرنىڭ ئۈستى نىلۇپەر شەكلىدە ياسالغانىدى. بۇنىڭ بىلەن تۈۋرۈكلەرنىڭ ئىشلىرى پۈتكەنىدى.   
\m
\v 23 ئۇ مىستىن «دېڭىز» دەپ ئاتالغان يوغان داس ياسىدى. ئۇنىڭ شەكلى دۈگىلەك بولۇپ، ئۇ گىرۋىكىدىن بۇ گىرۋىكىگىچە ئون گەز كېلەتتى؛ ئېگىزلىكى بەش گەز، ئايلانمىسى ئوتتۇز گەز ئىدى. \x ◘ \xo 7:23 \xt 2تار. 4‏:2؛ يەر. 52‏:20\x*  
\v 24 داسنىڭ گىرۋىكى ئاستى چۆرىدەپ قاپاق نۇسخىلىرى بىلەن زىننەتلەنگەنىدى. بۇلار داسنىڭ چۆرىسىنىڭ ھەربىر گېزىگە ئوندىن، ئىككى قاتار قويۇلغان ئىدى. ئۇلار داس بىلەن بىر ۋاقىتتا قۇيۇپ چىقىرىلغانىدى. \x ◘ \xo 7:24 \xt 2تار. 4‏:3\x*  
\v 25 داس ئون ئىككى بۇقا شەكلى ئۈستىدە تۇرغۇزۇلغانىدى. بۇلارنىڭ ئۈچى شىمال تەرەپكە، ئۈچى غەرب تەرەپكە، ئۈچى جەنۇب تەرەپكە، ئۈچى شەرق تەرەپكە يۈزلەنگەنىدى. «دېڭىز» بۇلارنىڭ ئۈستىدە ئىدى؛ ئۇلارنىڭ ئارقىسى ئىچ تەرىپىدە ئىدى.  
\v 26 داسنىڭ قېلىنلىقى ئالىقاننىڭ كەڭلىكىدەك بولۇپ، ئۇنىڭ گىرۋىكى پىيالىنىڭ گىرۋىكىدەك، شەكلى ئېچىلغان نىلۇپەردەك ئىدى. ئۇنىڭغا ئىككى مىڭ بات سۇ سىغاتتى. \f ◼ \fr 7:26 \ft \+bd «ئىككى مىڭ بات»\+bd* ــ بىر بات 22 لىتر بولۇشى مۇمكىن ئىدى؛ ئۇنداقتا 2000 بات 44000 لىتر ئىدى. «دېڭىز»نىڭ شەكلى «داڭقان شەكلى»دىكى داس بولسا كېرەك.\f*   
\m
\v 27 ئۇنىڭدىن باشقا ئۇ مىستىن ئون تەگلىكنى ياسىدى. ھەربىر تەگلىكنىڭ ئۇزۇنلۇقى تۆت گەز، كەڭلىكى تۆت گەز بولۇپ، ئېگىزلىكى ئۈچ گەز ئىدى.  
\v 28 بۇ تەگلىكلەر شۇنداق ياسالغانىدىكى، ئۇلارنىڭ \add رەسىملىك\add* تاختىلىرى بار ئىدى؛ تاختىلىرى رامكىلار ئىچىگە ئورنىتىلغانىدى.  
\v 29 رامكىلارنىڭ ئوتتۇرىسىدىكى رەسىم تاختايلىرىدا ۋە رامكىلارنىڭ ئۆزىدىمۇ شىرلار، بۇقىلار ۋە كېرۇبلارنىڭ سۈرەتلىك زىننەتلىرى بار ئىدى؛ شىرلار ۋە بۇقىلارنىڭ ئاستى ۋە ئۈستى زەنجىرسىمان گۈل چەمبىرەك شەكلىدە زىننەتلەنگەنىدى. \f ◼ \fr 7:29 \ft \+bd «گۈل چەمبىرەك شەكلىدە زىننەتلەنگەنىدى»\+bd* ــ ئىبرانىي تىلىدىكى نۇسخىسىدا قانداق مەنىدە ئىشلىتىلگىنى بىزگە تېخى ئېنىق ئەمەس.\f*  
\v 30 ھەربىر تەگلىكنىڭ مىس ئوقلىرى بىلەن تۆت چاقى بار ئىدى؛ تەگلىكنىڭ داسنى كۆتۈرۈپ تۇرىدىغان تۆت بۇرجىكىدە جازىسى بار ئىدى؛ داس ئاستىدىكى پۇتلىرىنىڭ ھەر تەرىپىدە تورلانغان قۇيما گۈل شاخلىرى ئورنىتىلغانىدى.  
\v 31 ھەر تەگلىكنىڭ ئىچىدە چوڭقۇرلۇقى بىر گەز كېلىدىغان «كىچىك تەگلىك» بولۇپ، ئاغزى دۈگىلەك ئىدى؛ كىچىك تەگلىكنىڭ ئۇزۇنلۇقى بىر يېرىم گەز ئىدى؛ ئاغزىنىڭ ئەتراپىدا نەقىشلەر بار ئىدى؛ ئۇلارنىڭ رامكىلىرى دۈگىلەك ئەمەس، بەلكى تۆت چاسىلىق ئىدى. \f ◼ \fr 7:31 \ft \+bd «ھەر تەگلىكنىڭ ئىچىدە چوڭقۇرلۇقى بىر گەز كېلىدىغان «كىچىك تەگلىك» بولۇپ، ... ئۇلارنىڭ رامكىلىرى دۈگىلەك ئەمەس، بەلكى تۆت چاسىلىق ئىدى»\+bd* ــ پۈتكۈل ئايەتنىڭ مەنىسىنى ئالىملار تېخى تولۇق ئېنىقلىغان ئەمەس. بىزنىڭ «پەرەزىي سخېما»مىزنى كۆرۈڭ.\f*   
\m
\v 32 تۆت چاقى رەسىملىك تاختايلىرى ئاستىدا بولۇپ، ئۇلارنىڭ ئوقلىرى تەگلىككە بېكىتىلگەنىدى. ھەربىر چاقنىڭ ئېگىزلىكى بىر يېرىم گەز ئىدى.  
\v 33 چاقلارنىڭ قۇرۇلمىسى جەڭ ھارۋىلىرىنىڭ چاقلىرىدەك ئىدى. ئۇلارنىڭ قازانلىرى، قاسقانلىرى، چېتىقلىرى ۋە ئوقلىرىنىڭ ھەممىسى مىستىن قۇيۇلغانىدى.  
\v 34 ھەربىر تەگلىكنىڭ تۆت بۇرجىكىدە بىردىن تۆت تۇتقۇچى بار ئىدى؛ ئۇلار تەگلىكتىن چىقىپ تۇراتتى ۋە ئۇلار تەگلىك بىلەن تەڭ قۇيۇلغان. \f ◼ \fr 7:34 \ft \+bd «ھەربىر تەگلىكنىڭ تۆت بۇرجىكىدە بىردىن تۆت تۇتقۇچى بار ئىدى»\+bd* ــ مۇشۇ يەردە ئىبرانىي تىلىدا «بۇرجەك» («مۈرىلىرى») دېگەن بۇ سۆزنىڭ مۇشۇ يەردە قانداق مەنىدە ئىشلىتىلگىنى تېخى ئېنىق ئەمەس. «تۇتقۇچى» دېگەن مەنىسى ئېھتىماللىققا ئەڭ يېقىن.\f*  
\v 35 ھەربىر تەگلىكنىڭ تۆپىسىدە ئېگىزلىكى يېرىم گەز كېلىدىغان بىر يۇمىلاق جازا بار ئىدى. ھەربىر تەگلىكنىڭ تۆپىسىدە تىرەك ۋە رەسىملىك تاختايلار بار ئىدى. ئۇلار تەگلىك بىلەن تەڭ قۇيۇلغان.  
\v 36 ئۇ مۇشۇ تىرەك ۋە رەسىم تاختايلىرىدىكى بوش ئورۇنلارغا كېرۇب، شىر ۋە خورما دەرەخلىرىنىڭ نۇسخىلىرىنى ۋە چۆرىسىگە تورلانغان گۈل شاخلىرىنى نەقىش قىلدى.  
\v 37 شۇ تەرىقىدە ئۇ مۇشۇ ئون تەگلىكنى ياساپ بولدى. ھەممىسى بىر نۇسخىدا قۇيۇلۇپ، ئوخشاش چوڭلۇقتا ۋە شەكىلدە ئىدى.   
\m
\v 38 ئۇ مىستىن ئون داس ياسىغان بولۇپ، ھەربىر داسقا قىرىق بات سۇ سىغاتتى؛ ھەربىر داسنىڭ توغرىسى تۆت گەز ئىدى. ئون تەگلىكنىڭ ھەربىرىنىڭ تۆپىسىدە بىردىن داس بار ئىدى. \x ◘ \xo 7:38 \xt 2تار. 4‏:6\x*  
\v 39 ئۇ بەش داسنى ئىبادەتخانىنىڭ ئوڭ يېنىدا ۋە بەشنى ئىبادەتخانىنىڭ سول يېنىدا قويدى؛ مىس دېڭىزنى ئىبادەتخانىنىڭ ئوڭ تەرىپىگە، يەنى شەرقىي جەنۇب تەرىپىگە قويدى.   
\m
\v 40 ھىرام شۇلارغا تەئەللۇق داس، كۈرەك ۋە قاچا-قۇچىلارنىمۇ ياساپ تەييار قىلدى. شۇنداق قىلىپ ھىرام سۇلايمان پادىشاھ ئۈچۈن پەرۋەردىگارنىڭ ئۆيىنىڭ بارلىق قۇرۇلۇش خىزمىتىنى پۈتكۈزدى: ــ   
\m
\v 41 ئىككى تۈۋرۈك، ئىككى تۈۋرۈكنىڭ ئۈستىدىكى ئاپقۇرسىمان ئىككى باش ۋە بۇ ئىككى باشنى يېپىپ تۇرىدىغان ئىككى تورنى ياسىتىپ پۈتتۈردى،  
\v 42 شۇ ئىككى تور ئۈستىگە قايچىلاشتۇرۇلغان تۆت يۈز ئانارنى ياساتتى. بىر توردا ئىككى قاتار ئانار بولۇپ، تۈۋرۈك ئۈستىدىكى؛ ئاپقۇرسىمان ئىككى باشنى يېپىپ تۇراتتى.  
\v 43 ئۇ ئون داس تەگلىكى ۋە داس تەگلىكىگە قويۇلىدىغان ئون «يۇيۇش دېسى»نى،  
\v 44 «مىس دېڭىز» ۋە ئۇنىڭ ئاستىدىكى ئون ئىككى مىس بۇقىنى ياساتقۇزدى،  
\v 45 قازانلارنى، كۈرەكلەرنى ۋە قاچا-قۇچىلارنىمۇ تەييار قىلدى. ھىرام پەرۋەردىگارنىڭ ئۆيى ئۈچۈن سۇلايمان پادىشاھنىڭ ئەمرى بىلەن ياسىغان بۇ ھەممە نەرسىلەر پارقىرايدىغان مىستىن ئىدى.   
\m
\v 46 پادىشاھ ئۇلارنى ئىئوردان تۈزلەڭلىكىدە، سۇككوت بىلەن زارەتاننىڭ ئوتتۇرىسىدا، \add شۇ يەردىكى\add* سېغىزلايدا قېلىپ ياساپ، قۇيدۇرۇپ چىقتى.   
\m
\v 47 بۇ نەرسىلەر شۇنچە كۆپ بولغاچقا، سۇلايمان ئۇلارنىڭ ئېغىرلىقىنى ئۆلچىمىدى. شۇنىڭ بىلەن مىسنىڭ ئېغىرلىقى مەلۇم بولمىدى.   
\m
\v 48 سۇلايمان يەنە پەرۋەردىگارنىڭ ئۆيى ئىچىدىكى بارلىق ئەسۋابلارنى ياساتتى: ــ يەنى ئالتۇن خۇشبۇيگاھنى، «تەقدىم نان» قويۇلىدىغان ئالتۇن شىرەنى، \f ◼ \fr 7:48 \ft \+bd «تەقدىم نانلار»\+bd* ــ باشقا خىل تەرجىمىلىرى: «ھۇزۇرىي نان»لار، «خۇدانىڭ ھۇزۇرىدىكى نان»لار) ياكى «تىزىلغان نان». ئۇلار ۋە ئالتۇن شىرە توغرۇلۇق «مىس.» 23:25-30 ۋە «لاۋ.» 5:24-9نى كۆرۈڭ.\f*  \x ◘ \xo 7:48 \xt مىس. 25‏:23؛ 30‏:1\x*  
\v 49 كالامخانا ئالدىدا تۇرىدىغان ساپ ئالتۇن چىراغدانلارنى (بەشنى ئوڭ يېنىدا، بەشنى سول يېنىدا) ياساتتى؛ ۋە شۇلارنىڭ گۈلسىمان زىننەتلىرىنى، چىراغلىرىنى، چىراغ قىسقۇچلىرىنى ئالتۇندىن ياساتتى؛  
\v 50 داس-پىيالىلىرىنى، پىچاقلىرىنى، قاچىلىرىنى، تەخسىلىرىنى ۋە كۈلدانلارنىڭ ھەممىسىنى ساپ ئالتۇندىن ياساتتى؛ ئۇ ئىچكىرىكى خانىنىڭ، يەنى ئەڭ مۇقەددەس جاينىڭ قاتلىنىدىغان، قوش قاناتلىق ئىشىكلەرنىڭ گىرەلىرىنى ۋە ئۆيدىكى مۇقەددەس جاينىڭ \add ئىشىكلىرىنىڭ\add* گىرەلىرىنى ئالتۇندىن ياساتتى.   
\m
\v 51 سۇلايمان پادىشاھ پەرۋەردىگارنىڭ ئۆيى ئۈچۈن قىلدۇرىدىغان ھەممە قۇرۇلۇشلار تامام بولغاندا، ئۇ ئاتىسى داۋۇت \add خۇداغا\add* ئاتىغان نەرسىلەرنى (يەنى كۈمۈش، ئالتۇن ۋە تۈرلۈك باشقا بۇيۇملارنى) ئەكەلتۈرۈپ پەرۋەردىگارنىڭ ئۆيىنىڭ خەزىنىلىرىگە قويدۇردى. \x ◘ \xo 7:51 \xt 2سام. 8‏:7، 11؛ 2تار. 5‏:1\x*   
\b  
\b  
\m  
\c 8
\s1 سۇلايمان ئەھدە ساندۇقىنى ئىبادەتخانىغا ئەكىلىپ قويىدۇ  
\r 2تار. 5‏:2-14؛ 2تار. 6؛ 2تار. 7‏:1-10  
\m
\v 1 شۇ چاغدا سۇلايمان پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى «داۋۇت شەھىرى»دىن، يەنى زىئوندىن يۆتكەپ كېلىش ئۈچۈن ئىسرائىل ئاقساقاللىرىنى، قەبىلە بەگلىرىنى ۋە ئىسرائىل جەمەتلىرىنىڭ بەگلىرىنى يېرۇسالېمغا ئۆز يېنىغا يىغىلىشقا چاقىردى. \f ◼ \fr 8:1 \ft \+bd ««داۋۇت شەھىرى»...، يەنى زىئون...»\+bd* ــ «زىئون» يېرۇسالېمنىڭ ئىچىدىكى ئېگىزلىك بولۇپ، شۇ يەرگە دائىم قورغان سېلىنىپ تۇراتتى. كېيىن ئىبادەتخانىمۇ زىئوندا قۇرۇلغان.\f*  \x ◘ \xo 8:1 \xt 2سام. 5‏:9؛ 6‏:12، 17؛ 2تار. 5‏:2\x*   
\m
\v 2 بۇنىڭ ئۈچۈن ئىسرائىلنىڭ ھەممە ئادەملىرى ئېتانىم ئېيىدا، يەنى يەتتىنچى ئايدىكى بېكىتىلگەن ھېيتتا سۇلايمان پادىشاھنىڭ قېشىغا يىغىلدى. \f ◼ \fr 8:2 \ft \+bd «يەتتىنچى ئايدىكى بېكىتىلگەن ھېيت»\+bd* ــ يەنى «كەپىلەر ھېيتى» ياكى «مېۋە ھوسۇل ھېيتى». بۇ ھېيت 7-ئاينىڭ 15-22 كۈنلىرىدە ئۆتكۈزۈلىدۇ («لاۋ.» 34:23-43). ئىسرائىلنىڭ ئەرلىرى ئۇنىڭغا يېرۇسالېمدا قاتنىشىشى لازىم ئىدى.\f*  
\v 3 ئىسرائىلنىڭ ھەممە ئاقساقاللىرى يېتىپ كەلگەندە لاۋىيلار ئەھدە ساندۇقىنى كۆتۈرۈپ \add ماڭدى\add*.  
\v 4 ئۇلار پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى، جامائەت چېدىرى بىلەن ئۇنىڭ ئىچىدىكى بارلىق مۇقەددەس بۇيۇملارنى كۆتۈرۈپ ئېلىپ چىقتى. كاھىنلار بىلەن لاۋىيلار مۇشۇلارنى ئېلىپ چىقتى. \f ◼ \fr 8:4 \ft \+bd «جامائەت چېدىرى»\+bd* ــ يەنى «جامائەت يىغىلىدىغان چېدىر» ياكى «ئىبادەت چېدىرى».\f*   
\m
\v 5 سۇلايمان پادىشاھ ۋە ئۇنىڭ ئالدىغا يىغىلغان بارلىق ئىسرائىل جامائىتى ئەھدە ساندۇقىنىڭ ئالدىدا مېڭىپ، كۆپلىكىدىن سانىنى ئېلىپ بولمايدىغان سان-ساناقسىز قوي بىلەن كالىلارنى قۇربانلىق قىلىشاتتى.  
\v 6 كاھىنلار پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى ئۆز جايىغا، ئىبادەتخانىنىڭ ئىچكى «كالامخانا»سىغا، يەنى ئەڭ مۇقەددەس جايغا ئېلىپ كىرىپ، كېرۇبلارنىڭ قاناتلىرىنىڭ ئاستىغا قويدى. \f ◼ \fr 8:6 \ft \+bd «كالامخانا»\+bd* ــ 16:6 ۋە ئىزاھاتىنى كۆرۈڭ.\f*   
\m
\v 7 چۈنكى كېرۇبلارنىڭ يېيىلىپ تۇرغان قانىتى ئەھدە ساندۇقىنىڭ ئورنى ئۈستىدە بولغاچقا، ئەھدە ساندۇقى بىلەن ئۇنى كۆتۈرۈپ تۇرىدىغان بالداقلارنى يېپىپ تۇراتتى.  
\v 8 بۇ بالداقلار ناھايىتى ئۇزۇن بولغاچقا، كالامخانىنىڭ ئالدىدىكى مۇقەددەس جايدا تۇرۇپ، ئەھدە ساندۇقىنىڭ يېنىدىكى ئىككى بالداقنىڭ ئۇچلىرىنى كۆرگىلى بولاتتى، بىراق ئۆينىڭ سىرتىدا ئۇلارنى كۆرگىلى بولمايتتى؛ بۇ بالداقلار تاكى بۈگۈنگە قەدەر شۇ يەردە تۇرماقتا. \f ◼ \fr 8:8 \ft \+bd «بۇ بالداقلار تاكى بۈگۈنگە قەدەر شۇ يەردە تۇرماقتا»\+bd* ــ «بۈگۈنگە قەدەر...» دېگەن سۆزلەر ئىبادەتخانا تېخى ئۆز جايىدا تۇرغان ۋاقتىدا خاتىرىلەنگەن، ئەلۋەتتە، ۋە شۇڭلاشقا شۇنى ئىسپاتلايدۇكى، «پادىشاھلار»نىڭ كۆپ قىسىملىرى يەھۇدادىكىلەرنىڭ سۈرگۈن بولۇشىدىن ئىلگىرى يېزىلغان. «2پاد.» 24-25 بابلىرىنى بەلكىم كېيىنكى بىر پۈتۈكچى قوشۇپ يازغان بولۇشى مۇمكىن.\f*  
\v 9 ئەھدە ساندۇقىنىڭ ئىچىدە مۇسا پەيغەمبەر ھورەب تېغىدا تۇرغاندا ئىچىگە سالغان ئىككى تاش تاختايدىن باشقا ھېچنەرسە يوق ئىدى (ئىسرائىللار مىسىر زېمىنىدىن چىققاندىن كېيىن پەرۋەردىگار ئۇلار بىلەن ھورەبدە ئەھدە تۈزگەنىدى). \f ◼ \fr 8:9 \ft \+bd «ھورەب تېغى»\+bd* ــ سىناي تېغىنىڭ باشقا بىر ئىسمىدۇر.\f*  \x ◘ \xo 8:9 \xt مىس. 34‏:27\x*   
\m
\v 10 ۋە شۇنداق بولدىكى، كاھىنلار مۇقەددەس جايدىن چىقىشىغىلا، بىر بۇلۇت پەرۋەردىگارنىڭ ئىبادەتخانىسىنى قاپلىۋالدى.  
\v 11 كاھىنلار بۇلۇت تۈپەيلىدىن ئۆز ۋەزىپىلىرىنى ئۆتەشكە ئۆرە تۇرالمايتتى؛ چۈنكى پەرۋەردىگارنىڭ جۇلاسى پەرۋەردىگارنىڭ ئۆيىنى تولدۇرغانىدى. \x ◘ \xo 8:11 \xt مىس. 40‏:34، 35؛ 2تار. 7‏:2\x*   
\m
\v 12 بۇ پەيتتە سۇلايمان: ــ پەرۋەردىگار تۇم قاراڭغۇلۇق ئىچىدە تۇرىمەن، دەپ ئېيتقانىدى؛ \x ◘ \xo 8:12 \xt مىس. 20‏:21؛ لاۋ. 16‏:2؛ قان. 4‏:11؛ 5‏:22؛ 2تار. 6‏:1\x*   
\m
\v 13 لېكىن، \add ئى پەرۋەردىگار\add*، مەن دەرۋەقە سېنىڭ ئۈچۈن بىر ھەيۋەتلىك ماكان بولسۇن دەپ، سەن مەڭگۈ تۇرىدىغان بىر ئۆينى ياسىدىم، دېدى. \f ◼ \fr 8:13 \ft \+bd «سېنىڭ ئۈچۈن بىر ھەيۋەتلىك ماكان»\+bd* ــ يەنە بىرخىل تەرجىمىسى «سېنىڭ ئۈچۈن بۇر تۇرالغۇ ماكان». \+bd «ھەيۋەتلىك ماكان»\+bd* ــ يەنە بىرخىل تەرجىمىسى «تۇرالغۇ ماكان».\f*  \x ◘ \xo 8:13 \xt 1پاد. 39:8، 49؛ مىس. 17:15؛ يۇ. 2:14\x*  
\v 14 ئاندىن پادىشاھ بۇرۇلۇپ بارلىق ئىسرائىل جامائىتىگە بەخت تىلىدى؛ ئىسرائىلنىڭ بارلىق جامائىتى ئۇنىڭ ئالدىدا تۇراتتى.  
\v 15 ئۇ مۇنداق دېدى: ــ «ئىسرائىلنىڭ خۇداسى پەرۋەردىگارغا تەشەككۈر-مەدھىيە بولغاي! ئۇ ئۆز ئاغزى بىلەن ئاتام داۋۇتقا ۋەدە قىلغانىدى ۋە ئۆز قولى بىلەن ئۇنى ئەمەلگە ئاشۇردى. ئۇ داۋۇتقا يەنە: ــ   
\m
\v 16 «مەن ئۆز خەلقىم ئىسرائىلنى مىسىر زېمىنىدىن ئېلىپ چىققان كۈندىن بۇيان نامىم ئۈچۈن بۇ يەردە بىر ئۆي سالاي دەپ ئىسرائىلنىڭ ھەرقايسى قەبىلىلىرىنىڭ شەھەرلىرىدىن ھېچقايسىسىنى تاللىمىدىم؛ بىراق خەلقىم بولغان ئىسرائىلغا ھۆكۈمرانلىق قىلسۇن دەپ داۋۇتنى تاللىدىم» دېگەنىدى. \x ◘ \xo 8:16 \xt 2سام. 7‏:6؛ 2تار. 6‏:5\x*  
\v 17 ئەمدى ئاتام داۋۇتنىڭ ئىسرائىلنىڭ خۇداسى پەرۋەردىگارنىڭ نامىغا ئاتاپ بىر ئۆي سېلىش ئارزۇ-نىيىتى بار ئىدى. \x ◘ \xo 8:17 \xt  2سام. 7‏:2؛ 1تار. 17‏:1؛ 2تار. 6‏:7\x*  
\v 18 بىراق پەرۋەردىگار ئاتام داۋۇتقا: «كۆڭلۈڭدە مېنىڭ نامىمغا بىر ئۆي ياساشقا قىلغان نىيىتىڭ ياخشىدۇر؛  
\v 19 ئەمما شۇ ئۆينى سەن ياسىمايسەن، بەلكى سېنىڭ پۇشتۇڭدىن بولىدىغان ئوغلۇڭ، ئۇ مېنىڭ نامىمغا ئاتاپ شۇ ئۆينى سالىدۇ»، دېگەنىدى.   
\m
\v 20 مانا ئەمدى پەرۋەردىگار ئۆز سۆزىگە ئەمەل قىلدى. مەن پەرۋەردىگار ۋەدە قىلغىنىدەك، ئاتامنىڭ ئورنىنى بېسىپ، ئىسرائىلنىڭ تەختىگە ئولتۇردۇم؛ ئىسرائىلنىڭ خۇداسى پەرۋەردىگارنىڭ نامىغا ئاتاپ بۇ ئۆينى سالدىم.  
\v 21 ئۆيدە ئەھدە ساندۇقى ئۈچۈن بىر جاينى راسلىدىم؛ ئەھدە ساندۇقى ئىچىدە پەرۋەردىگارنىڭ ئاتا-بوۋىلىرىمىزنى مىسىر زېمىنىدىن ئېلىپ چىققاندا، ئۇلار بىلەن تۈزگەن ئەھدە \add تاختىلىرى\add* باردۇر».   
\b  
\m  
\s1 سۇلايمان ئىسرائىل ئۈچۈن دۇئا قىلىدۇ  
\m
\v 22 ئاندىن سۇلايمان ئىسرائىلنىڭ بارلىق جامائىتىگە يۈزلىنىپ، پەرۋەردىگارنىڭ قۇربانگاھىنىڭ ئالدىدا تۇرۇپ، قوللىرىنى ئاسمانغا قارىتىپ كۆتۈرۈپ \x ◘ \xo 8:22 \xt 2تار. 6‏:12\x*  
\v 23 مۇنداق دۇئا قىلدى: ــ «ئى ئىسرائىلنىڭ خۇداسى پەرۋەردىگار! نە يۇقىرىقى ئاسماندا نە تۆۋەنكى يەردە سەندەك خۇدا يوقتۇر؛ ئالدىڭدا پۈتۈن قەلبى بىلەن ماڭىدىغان قۇللىرىڭ ئۈچۈن ئەھدەڭدە تۇرۇپ ئۆزگەرمەس مۇھەببىتىڭنى كۆرسەتكۈچىسەن.  
\v 24 چۈنكى سەن ئۆز قۇلۇڭ ئاتام داۋۇتقا بەرگەن ۋەدىدە تۇردۇڭ؛ سەن ئۆز ئاغزىڭ بىلەن ئېيتقان سۆزۈڭگە مانا بۈگۈنكىدەك ئۆز قولۇڭ بىلەن ئەمەل قىلدىڭ.  
\v 25 ئەمدى ھازىر، ئى ئىسرائىلنىڭ خۇداسى پەرۋەردىگار، ئۆز قۇلۇڭ ئاتام داۋۇتقا: ــ «ئەگەر سېنىڭ ئەۋلادلىرىڭ ئۆز يوللىرىغا سەگەك بولۇپ سەن مېنىڭ ئالدىمدا ماڭغاندەك ماڭىدىغان بولسا، ساڭا ئەۋلادىڭدىن ئىسرائىلنىڭ تەختىدە ئولتۇرىدىغان بىر زات كەم بولمايدۇ» دەپ بەرگەن ۋەدەڭدە تۇرغايسەن. \x ◘ \xo 8:25 \xt 2سام. 7‏:12، 16؛ 1پاد. 2‏:4؛ زەب. 132‏:12\x*  
\v 26 ئەمدى ھازىر، ئى ئىسرائىلنىڭ خۇداسى، سەن قۇلۇڭ داۋۇتقا ئېيتقان سۆزلىرىڭ ئەمەلگە ئاشۇرۇلغاي، دەپ ئۆتۈنىمەن!   
\m
\v 27 لېكىن خۇدا ئۆزى راستلا يەر يۈزىدە ماكان قىلامدۇ؟ مانا، ئاسمانلار بىلەن ئاسمانلارنىڭ ئاسمىنى سېنى سىغدۇرالمىغان يەردە، مەن ياسىغان بۇ ئۆي قانداقمۇ سېنىڭ ماكانىڭ بولالىسۇن؟! \x ◘ \xo 8:27 \xt 2تار. 2‏:5؛ يەش. 66‏:1؛ يەر. 23‏:24؛ روس. 7‏:49\x*  
\v 28 لېكىن ئى پەرۋەردىگار خۇدايىم، قۇلۇڭنىڭ دۇئاسى بىلەن ئىلتىجاسىغا قۇلاق سېلىپ، قۇلۇڭنىڭ بۈگۈن ساڭا كۆتۈرگەن نىداسى ۋە تىلىكىنى ئاڭلىغايسەن؛  
\v 29 شۇنىڭ بىلەن ئۆز كۆزلىرىڭنى كېچە-كۈندۈز بۇ ئۆيگە، يەنى سەن: «مېنىڭ نامىم ئۇ يەردە ئايان بولسۇن» دەپ ئېيتقان جايغا كېچە-كۈندۈز تىككەيسەن؛ ئۆز قۇلۇڭنىڭ ئۇ جايغا قاراپ قىلغان دۇئاسىغا قۇلاق سالغايسەن. \f ◼ \fr 8:29 \ft \+bd «ئۇ جايغا قاراپ قىلغان دۇئاسىغا...»\+bd* ــ ياكى بولمىسا: «ئۇ جاي توغرىسىدىكى دۇئاسى...».\f*  \x ◘ \xo 8:29 \xt قان. 12‏:11\x*  
\v 30 قۇلۇڭ ۋە خەلقىڭ ئىسرائىل بۇ جايغا قاراپ دۇئا قىلغان چاغدا، ئۇلارنىڭ ئىلتىجاسىغا قۇلاق سېلىپ، ئۆز ماكانىڭ قىلغان ئاسمانلاردىن تۇرۇپ ئاڭلىغايسەن، ئاڭلىغىنىڭدا ئۇلارنى كەچۈرگەيسەن.   
\m
\v 31 ئەگەر بىرسى ئۆز قوشنىسىغا گۇناھ قىلسا ۋە شۇنداقلا ئىشنىڭ راست-يالغانلىقىنى بېكىتىش ئۈچۈن قەسەم ئىچكۈزۈلسە، بۇ قەسەم بۇ ئۆيدىكى قۇربانگاھىڭنىڭ ئالدىغا كەلسە، \f ◼ \fr 8:31 \ft \+bd «ئەگەر بىرسى ئۆز قوشنىسىغا ... ئىشنىڭ راست-يالغانلىقىنى بېكىتىش ئۈچۈن قەسەم ئىچكۈزۈلسە، بۇ قەسەم بۇ ئۆيدىكى قۇربانگاھىڭنىڭ ئالدىغا كەلسە...»\+bd* ــ بۇنداق قەسەم توغرۇلۇق «چۆل.» 11:5-31نى كۆرۈڭ. «قەسەم بۇ ئۆيدىكى قۇربانگاھنىڭ ئالدىغا كەلسە...» مۇمكىنچىلىكى باركى، ئىسرائىلدا مۇشۇنداق قەسەملەرنى ئىچىش ئۈچۈن قۇربانگاھنىڭ ئالدىغا كېلىش كېرەك ئەمەس ئىدى، پەقەت: «خۇدانىڭ قۇربانگاھى ئالدىدا قەسەم قىلىمەنكى...» دېگەندەك سۆزلەر ئېيتىلغان بولسا «قۇربانگاھ ئۆز ئالدىدا تۇرغاندەك» ھېسابلىناتتى.\f*  
\v 32 سەن قەسەمنى ئاسماندا تۇرۇپ ئاڭلاپ، ئامال قىلىپ ئۆز بەندىلىرىڭ ئوتتۇرىسىدا ھۆكۈم چىقارغايسەن؛ گۇناھى بار ئادەمنى گۇناھقا تارتىپ، ئۆز يولىنى ئۆز بېشىغا ياندۇرۇپ، گۇناھسىز ئادەمنى ئاقلاپ، ئۆز ئادىللىقىغا قاراپ ئۇنىڭغا ھەققىنى بەرگەيسەن.   
\m
\v 33 ئۆز خەلقىڭ ئىسرائىل سېنىڭ ئالدىڭدا گۇناھ قىلغىنى ئۈچۈن دۈشمەندىن يېڭىلسە، ساڭا قايتىپ بۇ ئۆيدە تۇرۇپ، نامىڭنى ئېتىراپ قىلىپ، ساڭا دۇئا بىلەن ئىلتىجا قىلسا،  
\v 34 سەن ئاسماندا ئاڭلاپ، ئۆز خەلقىڭ ئىسرائىلنىڭ گۇناھىنى كەچۈرۈپ، ئۇلارنى سەن ئاتا-بوۋىلىرىغا تەقدىم قىلغان زېمىنغا قايتۇرۇپ كەلگەيسەن.   
\m
\v 35 ئۇلار ساڭا گۇناھ قىلغىنى ئۈچۈن ئاسمان ئېتىلىپ يامغۇر ياغمايدىغان قىلىۋېتىلگەن بولسا، لېكىن ئۇلار بۇ جايغا قاراپ ساڭا دۇئا قىلىپ نامىڭنى ئېتىراپ قىلىپ، سېنىڭ ئۇلارنى قىيىنچىلىققا سالغىنىڭ تۈپەيلىدىن ئۆز گۇناھىدىن يېنىپ توۋا قىلسا،  
\v 36 سەن ئاسماندا تۇرۇپ قۇلاق سېلىپ، قۇللىرىڭنىڭ ۋە خەلقىڭ ئىسرائىلنىڭ گۇناھىنى كەچۈرگەيسەن؛ چۈنكى سەن ئۇلارغا مېڭىش كېرەك بولغان ياخشى يولنى ئۆگىتىسەن ۋە ئۆز خەلقىڭگە مىراس قىلىپ بەرگەن زېمىننىڭ ئۈستىگە يامغۇر ياغدۇرىسەن!   
\m
\v 37 ئەگەر زېمىندا ئاچارچىلىق يا ۋابا بولسا، يا زىرائەتلەر دان ئالمىسا يا ھال چۈشسە يا ئۇنى چېكەتكىلەر ياكى چېكەتكە لىچىنكىلىرى بېسىۋالسا، يا دۈشمەنلەر ئۇلارنىڭ زېمىندىكى شەھەرلىرىنىڭ قوۋۇقلىرىغا ھۇجۇم قىلىپ قورشىۋالسا، يا ھەرقانداق ئاپەت يا كېسەللىك بولسا،  
\v 38 سېنىڭ خەلقىڭ بولغان ئىسرائىلدىكى ھەرقانداق كىشى ئۆز كۆڭلىدىكى ۋابانى بىلىپ، ئۇلاردىن ھەرقايسى كىشى قوللىرىنى بۇ ئۆيگە سۇنۇپ، ھەرقانداق دۇئا ياكى ئىلتىجا قىلغان بولسا،  
\v 39 ئەمدى سەن تۇرۇۋاتقان ماكانىڭ ئاسماندا تۇرۇپ ئاڭلاپ، كەچۈرۈم قىلغايسەن؛ سەن ھەربىر ئادەمنىڭ قەلبىنى بىلگەچكە، ئامال قىلىپ ئۆزىنىڭ يوللىرىنى ئۆزىگە ياندۇرغايسەن (چۈنكى سەنلا، يالغۇز سەنلا ھەممە ئىنسان بالىلىرىنىڭ قەلبلىرىنى بىلگۈچىدۇرسەن)؛  
\v 40 شۇنداق قىلىپ، ئۇلار سەن ئاتا-بوۋىلىرىمىزغا تەقدىم قىلغان زېمىندا ئولتۇرۇپ ئۆمرىنىڭ ھەممە كۈنلىرىدە سەندىن قورقىدىغان بولىدۇ.   
\m
\v 41 ئۆز خەلقىڭ ئىسرائىلدىن بولمىغان، سېنىڭ ئۇلۇغ نامىڭ تۈپەيلىدىن يىراق-يىراقلاردىن كەلگەن مۇساپىر بولسا  
\v 42 (چۈنكى ئۇلار سېنىڭ ئۇلۇغ نامىڭ، قۇدرەتلىك قولۇڭ ۋە سوزغان بىلىكىڭ توغرىسىدا ئاڭلىيلايدۇ)، ــ ئۇنداق بىرسى كېلىپ بۇ ئۆي تەرەپكە قاراپ دۇئا قىلسا،  
\v 43 سەن تۇرۇۋاتقان ماكانىڭ بولغان ئاسمانلاردا ئۇنىڭغا قۇلاق سېلىپ، ئۇ مۇساپىر ساڭا نىدا قىلىپ تىلىگىنىنىڭ ھەممىسىگە مۇۋاپىق قىلغايسەن؛ شۇنىڭ بىلەن يەر يۈزىدىكى بارلىق ئەللەر نامىڭنى تونۇپ يېتىپ، ئۆز خەلقىڭ ئىسرائىلدەك سەندىن قورقىدىغان بولۇپ، مەن ياسىغان بۇ ئۆينىڭ سېنىڭ نامىڭ بىلەن ئاتالغىنىنى بىلىدۇ. \f ◼ \fr 8:43 \ft \+bd «بۇ ئۆي سېنىڭ نامىڭ بىلەن ئاتىلىدۇ»\+bd* ــ بۇ ئىبارە خۇدانىڭ ئىبادەتخانىسى توغرۇلۇق «بۇ ئۆي مېنىڭكىدۇر» ۋە «بۇ ئۆيدە مېنىڭ كىم ئىكەنلىكىم ئايان قىلىنىدۇ» دېگەندەك ئىككى مەقسىتىنى كۆرسىتىدۇ.\f*   
\m
\v 44 ئەگەر سېنىڭ خەلقىڭ سېنىڭ تاپشۇرۇقۇڭ بىلەن دۈشمىنى بىلەن جەڭ قىلىشقا چىققاندا، سەن تاللىغان بۇ شەھەرگە، شۇنداقلا مەن نامىڭغا ئاتاپ ياسىغان بۇ ئۆي تەرەپكە قاراپ سەن پەرۋەردىگارغا دۇئا قىلسا،  
\v 45 سەن ئاسمانلاردا تۇرۇپ ئۇلارنىڭ دۇئاسى بىلەن ئىلتىجاسىغا قۇلاق سېلىپ، ئۇلارنى نۇسرەتكە ئېرىشتۈرگەيسەن.   
\m
\v 46 ئەگەر ئۇلار ساڭا گۇناھ سادىر قىلغان بولسا (چۈنكى گۇناھ قىلمايدىغان ھېچكىشى يوقتۇر) سەن ئۇلارغا غەزەپلىنىپ، ئۇلارنى دۈشمەنلىرىنىڭ قولىغا تاپشۇرغان بولساڭ، بۇلار ئۇلارنى يىراق-يېقىنغا، ئۆزلىرىنىڭ زېمىنىغا سۈرگۈن قىلىپ ئېلىپ بارغان بولسا، \x ◘ \xo 8:46 \xt 2تار. 6‏:36؛ پەند. 20‏:9؛ توپ. 7‏:20؛ 1يۇھ. 1‏:8، 10\x*  
\v 47 لېكىن ئۇلار سۈرگۈن قىلىنغان يۇرتتا ئەس-ھوشىنى تېپىپ توۋا قىلىپ، ئۆزى سۈرگۈن بولغان يۇرتتا ساڭا: ــ بىز گۇناھ قىلىپ، قەبىھلىككە بېرىلىپ سەندىن يۈز ئۆرۈپ كەتتۇق، دەپ يېلىنسا،  
\v 48 ــ ئەگەر ئۇلارنى سۈرگۈن قىلغان دۈشمەنلىرىنىڭ زېمىنىدا پۈتۈن قەلبى ۋە پۈتۈن جېنىدىن سېنىڭ تەرىپىڭگە يېنىپ، سەن ئۇلارنىڭ ئاتا-بوۋىلىرىغا تەقدىم قىلغان زېمىنغا، سەن تاللىغان شەھەر تەرەپكە ۋە مەن نامىڭغا ئاتاپ ياسىغان بۇ ئۆي تەرەپكە يۈزىنى قىلىپ، ساڭا قاراپ دۇئا قىلسا،  
\v 49 سەن تۇرۇۋاتقان ماكانىڭ بولغان ئاسمانلاردا تۇرۇپ ئۇلارنىڭ دۇئاسى ۋە ئىلتىجاسىنى ئاڭلاپ ئۇلار ئۈچۈن ھۆكۈم چىقىرىپ،  
\v 50 ئۆز خەلقىڭنىڭ ساڭا سادىر قىلغان گۇناھىنى، ساڭا ئۆتكۈزگەن ھەممە ئىتائەتسىزلىكلىرىنى كەچۈرۈم قىلغايسەن ۋە ئۇلارنى سۈرگۈن قىلغانلارنىڭ ئالدىدا ئۇلارغا رەھىم تاپقۇزغايسەنكى، شۇلار ئۇلارغا رەھىم قىلسۇن  
\v 51 (چۈنكى ئۇلار ئۆزۈڭ مىسىردىن، يەنى تۆمۈر تاۋلاش پېچىدىن چىقارغان ئۆز خەلقىڭ ۋە ئۆز مىراسىڭدۇر)؛  
\v 52 سېنىڭ كۆزلىرىڭ ئۆز قۇلۇڭنىڭ ئىلتىجاسىغا ۋە ئۆز خەلقىڭنىڭ ئىلتىجاسىغا ئوچۇق بولغاي، ئۇلار ھەر ئىشتا ساڭا نىدا قىلىپ تىلىگىنىدە ئۇلارغا قۇلاق سالغايسەن؛  
\v 53 چۈنكى سەن ئاتا-بوۋىلىرىمىزنى مىسىردىن چىقارغىنىڭدا ئۆز قۇلۇڭ مۇسا ئارقىلىق ئېيتقىنىڭدەك، سەن خەلقىڭنى ئۆزۈڭگە خاس مىراسىڭ بولسۇن دەپ، يەر يۈزىدىكى ھەممە ئەللەر ئارىسىدىن ئۇلارنى ئايرىم ئېلىپ تاللىدىڭ، ئى رەب پەرۋەردىگار!». \x ◘ \xo 8:53 \xt مىس. 19‏:5؛ قان. 4‏:20؛ 7‏:6؛ 9‏:26، 29؛ 14‏:2\x*   
\m
\v 54 سۇلايمان پەرۋەردىگارغا شۇ بارلىق دۇئا ۋە ئىلتىجالىرىنى قىلىپ بولغاندا، قوللىرىنى ئاسمانغا قاراپ كۆتۈرۈپ پەرۋەردىگارنىڭ قۇربانگاھىنىڭ ئالدىدا تىزلىنىپ تۇرغان يەردىن قوپۇپ،  
\v 55 ئۆرە تۇرۇپ ئىسرائىلنىڭ بارلىق جامائىتىگە يۇقىرى ئاۋازدا بەخت تىلەپ مۇنداق دېدى: ــ  
\v 56 «ئۇنىڭ بارلىق ۋەدە قىلغىنى بويىچە ئۆز خەلقى ئىسرائىلغا ئارام بەرگەن پەرۋەردىگار مۇبارەكتۇر! ئۇ ئۆز قۇلى مۇسانىڭ ۋاسىتىسى بىلەن قىلغان ھەممە مېھرىبانە ۋەدىلەرنىڭ ھېچبىرى يەردە قالمىدى! \x ◘ \xo 8:56 \xt يە. 21‏:45\x*   
\m
\v 57 پەرۋەردىگار خۇدايىمىز ئاتا-بوۋىلىرىمىز بىلەن بولغاندەك بىز بىلەن بىللە بولغاي؛ ئۇ نە بىزدىن ۋاز كەچمىسۇن نە بىزنى تاشلىمىسۇن؛  
\v 58 بۇنىڭ بىلەن ئۇ قەلبىمىزنى ئۇنىڭ يوللىرىدا مېڭىشقا، ئۆزى ئاتا-بوۋىلىرىمىزغا بۇيرۇغان ئەمرلەر، بەلگىلىمىلەر ۋە ھۆكۈملەرنى تۇتۇشقا ئۆزىگە مايىل قىلغاي؛  
\v 59 مېنىڭ پەرۋەردىگارنىڭ ئالدىدا ئىلتىجا قىلغان بۇ سۆزلىرىم كېچە-كۈندۈز پەرۋەردىگار خۇدايىمىزنىڭ يېنىدا تۇرسۇن؛ شۇنىڭ بىلەن ئۆز قۇلۇڭ ئۈچۈن توغرا ھۆكۈم قىلىپ، خەلقىڭ ئىسرائىل ئۈچۈن توغرا ھۆكۈم قىلىپ، ھەر كۈندىكى دەردىگە يەتكەيسەن؛  
\v 60 شۇنىڭ بىلەن يەر يۈزىدىكى ھەممە ئەللەر پەرۋەردىگار ئۆزى خۇدادۇر، ئۇنىڭدىن باشقىسى ھېچقايسىسى يوقتۇر دەپ بىلگەي، \x ◘ \xo 8:60 \xt قان. 4‏:35، 39\x*  
\v 61 شۇنداقلا بۈگۈن قىلغىنىڭلارغا ئوخشاش ئۇنىڭ بەلگىلىمىلىرىدە مېڭىشقا ۋە ئەمرلىرىنى تۇتۇشقا قەلبىڭلار پەرۋەردىگار خۇدايىمىزغا مۇكەممەل بولغاي!».   
\b  
\m  
\s1 سۇلايمان ئىبادەتخانىنى خۇداغا ئاتايدۇ  
\m
\v 62 ۋە پادىشاھ پۈتۈن ئىسرائىل بىلەن بىللە پەرۋەردىگارنىڭ ئالدىدا قۇربانلىقلارنى قىلدى.  
\v 63 سۇلايمان پەرۋەردىگارغا ئىناقلىق قۇربانلىقى سۈپىتىدە يىگىرمە ئىككى مىڭ كالا ۋە بىر يۈز يىگىرمە مىڭ قوي قۇربانلىق قىلدى. پادىشاھ بىلەن بارلىق ئىسرائىللار شۇنداق قىلىپ پەرۋەردىگارنىڭ ئۆيىنى ئۇنىڭغا بېغىشلىدى. \x ◘ \xo 8:63 \xt 2تار. 7‏:5-10\x*  
\v 64 شۇ كۈنى پادىشاھ پەرۋەردىگارنىڭ ئۆيىنىڭ ئالدىدىكى ھويلىسىنىڭ ئوتتۇرىسىنى ئايرىپ مۇقەددەس قىلىپ، ئۇ يەردە كۆيدۈرمە قۇربانلىقلار، ئاشلىق ھەدىيەلىرى ۋە ئىناقلىق قۇربانلىقلىرىنىڭ ياغلىرىنى سۇندى؛ چۈنكى پەرۋەردىگارنىڭ ئالدىدا تۇرغان مىس قۇربانگاھ كۆيدۈرمە قۇربانلىقلار، ئاشلىق ھەدىيەلىرى ۋە ئىناقلىق قۇربانلىقلىرىنىڭ ياغلىرىنى قوبۇل قىلىشقا كىچىك كەلدى. \x ◘ \xo 8:64 \xt 2تار. 7‏:7\x*  
\v 65 شۇنىڭ بىلەن ئۇ ۋاقىتتا سۇلايمان ۋە ئۇنىڭ بىلەن بولغان پۈتۈن ئىسرائىل، يەنى خامات رايونىغا كىرىش ئېغىزىدىن تارتىپ مىسىر ئېقىنىغىچە ھەممە يەرلەردىن كەلگەن زور بىر جامائەت پەرۋەردىگار خۇدايىمىزنىڭ ئالدىدا يەتتە كۈن ۋە يەنە يەتتە كۈن، جەمئىي ئون تۆت كۈنگىچىلىك ھېيت ئۆتكۈزدى. \f ◼ \fr 8:65 \ft \+bd «خامات رايونىغا كىرىش ئېغىزىدىن تارتىپ...»\+bd* ــ ياكى «لىبو-خاماتتىن تارتىپ». \+bd «...جامائەت پەرۋەردىگار خۇدايىمىزنىڭ ئالدىدا يەتتە كۈن ۋە يەنە يەتتە كۈن، جەمئىي ئون تۆت كۈنگىچىلىك ھېيت ئۆتكۈزدى»\+bd* ــ «كەپىلەر ھېيتى»نىڭ بېكىتىلگەن ۋاقتى يەتتە كۈن ئىدى. ئىسرائىللار مۇشۇ ۋاقىتقا يەنە يەتتە كۈن قوشتى.\f*  
\v 66 سەككىزىنچى كۈنىدە ئۇ خەلقنى قايتۇردى؛ ئۇلار پادىشاھنىڭ بەختىنى تىلىدى؛ ئاندىن ئۇلار پەرۋەردىگارنىڭ ئۆز قۇلى داۋۇتقا ۋە خەلقى ئىسرائىلغا قىلغان ياخشىلىقلىرى ئۈچۈن قەلبىدە شاد-خۇرام بولۇپ ئۆز ئۆي-چېدىرلىرىگە قايتىپ كەتتى. \f ◼ \fr 8:66 \ft \+bd «سەككىزىنچى كۈنىدە»\+bd* ــ دېمەك، ئىككىنچى «يەتتە كۈن»دىن كېيىنكى كۈندە.\f*   
\b  
\b  
\m  
\c 9
\s1 پەرۋەردىگار سۇلايمانغا ۋەدە ھەم ئاگاھ بېرىدۇ  
\r 2تار. 7‏:11-22  
\m
\v 1 سۇلايمان پەرۋەردىگارنىڭ ئۆيى، پادىشاھ ئوردىسى ۋە شۇنداقلا قۇرۇشنى ئارزۇ قىلغان باشقا قۇرۇلۇشلارنى كۆڭلىدىكىدەك پۈتكۈزۈپ بولغاندا، \x ◘ \xo 9:1 \xt 2تار. 7‏:11\x*  
\v 2 پەرۋەردىگار سۇلايمانغا گىبېئوندا كۆرۈنگەندەك ئەمدى ئىككىنچى قېتىم ئۇنىڭغا كۆرۈندى. \x ◘ \xo 9:2 \xt 1پاد. 3‏:5\x*   
\m
\v 3 پەرۋەردىگار ئۇنىڭغا مۇنداق دېدى: ــ «سەن مېنىڭ ئالدىمدا قىلغان دۇئا ۋە ئىلتىجايىڭنى ئاڭلىدىم؛ مېنىڭ نامىم ئۇنىڭدا ئەبەدگىچە ئايان قىلىنىشى ئۈچۈن، سەن ياسىغان بۇ ئۆينى ئۆزۈمگە مۇقەددەس قىلدىم. مېنىڭ كۆزلىرىم ۋە كۆڭلۈم شۇ يەردە ھەمىشە بولىدۇ. \x ◘ \xo 9:3 \xt قان. 12‏:11؛ 1پاد. 8‏:29\x*  
\v 4 سەن بولساڭ، ئاتاڭ داۋۇتنىڭ ئالدىمدا ماڭغىنىدەك، سەنمۇ ساڭا بۇيرۇغىنىمنىڭ ھەممىسىگە مۇۋاپىق ئەمەل قىلىش ئۈچۈن، بەلگىلىمىلىرىم ۋە ھۆكۈملىرىمنى تۇتۇپ، پاك كۆڭۈل ۋە دۇرۇسلۇق بىلەن ئالدىمدا ماڭساڭ،  
\v 5 مەن ئەمدى ئاتاڭ داۋۇتقا: «ئىسرائىلنىڭ تەختىدە ساڭا ئەۋلادىڭدىن ئولتۇرۇشقا بىر زات كەم بولمايدۇ» دەپ ۋەدە قىلغىنىمدەك، مەن پادىشاھلىق تەختىڭنى ئىسرائىلنىڭ ئۈستىدە ئەبەدگىچە مەھكەم قىلىمەن. \x ◘ \xo 9:5 \xt 2سام. 7‏:12، 16؛ 1پاد. 6‏:12؛ 2‏:4؛ 1تار. 22‏:10؛ زەب. 89‏:28-29؛ 132‏:12\x*  
\v 6 لېكىن ئۆزۈڭ يا ئوغۇللىرىڭ ماڭا ئەگىشىشتىن ۋاز كېچىپ مەن ئالدىڭلاردا قويغان ئەمرلىرىم بىلەن بەلگىلىمىلىرىمنى تۇتماي، بەلكى باشقا ئىلاھلارنىڭ قۇللۇقىغا كىرىپ ئۇلارغا سەجدە قىلساڭلار، \x ◘ \xo 9:6 \xt 2سام. 7‏:14؛ زەب. 89‏:30-32\x*  
\v 7 شۇ چاغدا مەن ئىسرائىلنى ئۇلارغا تەقدىم قىلغان زېمىنىدىن ئۈزۈپ چىقىرىمەن؛ ۋە ئۆز نامىمنى كۆرسىتىشكە ئۆزۈمگە مۇقەددەس قىلغان بۇ ئۆينى نەزىرىمدىن تاشلايمەن ۋە ئىسرائىل ھەممە خەلقلەر ئارىسىدا سۆز-چۆچەك ۋە تاپا-تەنىنىڭ ئوبيېكتى بولىدۇ؛ \x ◘ \xo 9:7 \xt قان. 28‏:37؛ يەر. 7‏:15\x*  
\v 8 بۇ ئۆي گەرچە ھازىر كۆركەم كۆرۈنسىمۇ، شۇ زاماندا ئۇنىڭدىن ئۆتكەنلەرنىڭ ھەممىسى زور ھەيران قېلىشىپ ئۈشقىرتىپ: «پەرۋەردىگار بۇ زېمىنغا ۋە بۇ ئۆيگە نېمىشقا شۇنداق قىلدى؟» دەپ سورايدۇ. \f ◼ \fr 9:8 \ft \+bd «بۇ ئۆي گەرچە ھازىر كۆركەم كۆرۈنسىمۇ،...»\+bd* ــ باشقا بىرخىل تەرجىمىسى (بەزى كونا تېكىستلەرگە ئەگىشىپ): «بۇ ئۆي بىر خارابە بولىدۇ،...»\f*  \x ◘ \xo 9:8 \xt قان. 29‏:23؛ 2تار. 7‏:21؛ يەر. 22‏:8\x*   
\m
\v 9 كىشىلەر: ــ چۈنكى \add زېمىندىكى خەلقلەر\add* ئۆز ئاتا-بوۋىلىرىنى مىسىر زېمىنىدىن چىقارغان پەرۋەردىگار خۇداسىنى تاشلاپ، ئۆزلىرىنى باشقا ئىلاھلارغا باغلاپ، ئۇلارغا سەجدە قىلىپ قۇللۇقىدا بولغانلىقى ئۈچۈن، پەرۋەردىگار بۇ پۈتكۈل كۈلپەتنى ئۇلارنىڭ بېشىغا چۈشۈرۈپتۇ، دەپ جاۋاب بېرىدۇ.   
\b  
\m  
\s1 تاشقى ئىشلار ۋە باشقا قۇرۇلۇشلار  
\r 2تار. 8‏:1-18  
\m
\v 10 شۇنداق بولدىكى، يىگىرمە يىل ئۆتۈپ، سۇلايمان ئۇ ئىككى ئۆينى، يەنى پەرۋەردىگارنىڭ ئۆيى بىلەن پادىشاھ ئۆيىنى ياساپ بولغاندىن كېيىن، \x ◘ \xo 9:10 \xt 2تار. 8‏:1\x*  
\v 11 تۇرنىڭ پادىشاھى ھىرام سۇلايمانغا بارلىق تەلەپلىرى بويىچە كېدىر دەرەخلىرى، ئارچا دەرەخلىرى ۋە ئالتۇن تەمىنلىگىنى ئۈچۈن سۇلايمان پادىشاھ ئۇنىڭغا گالىلىيە ئۆلكىسىدىن يىگىرمە شەھەرنى بەردى.  
\v 12 ھىرام سۇلايمان ئۇنىڭغا بەرگەن شەھەرلەرنى كۆرۈشكە تۇردىن چىقىپ كەلدى؛ لېكىن ئۇلار ئۇنىڭغا ھېچ ياقمىدى.  
\v 13 ئۇ: ــ ھەي بۇرادىرىم، سەن مۇشۇ ماڭا بەرگىنىڭ زادى قانداق شەھەرلەر؟! ــ دېدى. ئۇ ئۇلارنى «كابۇلنىڭ يۇرتى» دەپ ئاتىدى، ۋە ئۇلار بۈگۈنكى كۈنگىچە شۇنداق ئاتىلىدۇ. \f ◼ \fr 9:13 \ft \+bd «كابۇلنىڭ يۇرتى»\+bd* ــ «كابۇل» دېگەننىڭ مەنىسى بەلكىم «چەكلىك» بولۇشى مۇمكىن. ئىبرانىي تىلىدا سۆزنىڭ ئاھاڭى «ئەرزىمەس»كە يېقىن كېلىدۇ.\f*  
\v 14 ھىرام بولسا پادىشاھقا بىر يۈز يىگىرمە تالانت ئالتۇن ئەۋەتكەنىدى. \f ◼ \fr 9:14 \ft \+bd «بىر يۈز يىگىرمە تالانت ئالتۇن»\+bd* ــ بىر تالانت (ئالتۇن) بەلكىم 27 كىلوگرام ئىدى. 120 تالانت 3240 كىلوگرام؛ ھازىرقى پۇلدا بولسا (2008-يىلى) 100 مىليون دوللار بولىدۇ.\f*   
\b  
\m
\v 15 سۇلايمان پادىشاھ پەرۋەردىگارنىڭ ئۆيىنى، ئۆز ئۆيىنى، مىللونى، يېرۇسالېمنىڭ سېپىلىنى، ھازورنى، مەگىددونى ۋە گەزەر شەھەرلىرىنى ياساش ئۈچۈن ھاشارغا تۇتقان ئىشلىگۈچىلەرنىڭ ئىشلىرى مۇنداق: ــ \f ◼ \fr 9:15 \ft \+bd «مىللو»\+bd* ــ بەلكىم يېرۇسالېمدىكى ئېگىزلىككە جايلاشقان بىر قەلئە ياكى ئىستىھكام ئىدى.\f*  
\v 16 (مىسىرنىڭ پادىشاھى پىرەۋن چىقىپ گەزەرگە ھۇجۇم قىلىپ ئېلىپ، ئۇنى ئوتتا كۆيدۈرۈپ، شەھەردە تۇرۇۋاتقان قانائانىيلارنى قىرىپ، شەھەرنى توي سوۋغىسى سۈپىتىدە سۇلايماننىڭ خوتۇنى بولغان ئۆز قىزىغا بەرگەنىدى)  
\v 17 سۇلايمان گەزەر بىلەن تۆۋەنكى بەيت-ھوروننى بىنا قىلدى؛  
\v 18 ئۇ بائالات بىلەن ئۆز زېمىنىدىكى چۆلگە جايلاشقان تادمورنىمۇ يېڭىدىن ياسىدى، \x ◘ \xo 9:18 \xt 2تار. 8‏:6\x*  
\v 19 شۇنداقلا ئۆزىگە خاس ھەممە ئامبار شەھەرلىرىنى، «جەڭ ھارۋىسى شەھەرلىرى»نى، «ئاتلىقلار شەھەرلىرى»نى ۋە يېرۇسالېمدا، لىۋاندا ۋە ئۆزى سورايدىغان بارلىق زېمىندا خالىغىنىنى بىنا قىلدى.   
\m
\v 20 ئىسرائىللاردىن بولمىغان ئامورىيلار، ھىتتىيلار، پەرىززىيلەر، ھىۋىيلار ۋە يەبۇسىيلاردىن \add ئىسرائىل\add* زېمىنىدا قېلىپ قالغانلارنىڭ ھەممىسىنى بولسا،  
\v 21 سۇلايمان بۇلارنى، يەنى ئىسرائىللار پۈتۈنلەي يوقىتالمىغان ئەللەرنىڭ قالدۇق ئەۋلادلىرىنى قۇللۇق ھاشارغا تۇتتى. ئۇلار بۈگۈنكى كۈنگىچە شۇنداق بولۇپ كەلدى. \f ◼ \fr 9:21 \ft \+bd ئىسرائىللار پۈتۈنلەي يوقىتالمىغان ئەللەرنىڭ قالدۇق ئەۋلادلىرى...»\+bd* ــ بۇ ئىشلارنىڭ تارىخى «يەشۇئا پەيغەمبەر» دېگەن قىسمىدا پۈتۈلگەن. تەۋراتتىكى «يەشۇئا»نى كۆرۈڭ. مۇشۇ ھاشارچىلار 5:13-16دە خاتىرىلەنگەنلەردىن باشقا ھاشارچىلار بولسا كېرەك ئىدى. \+bd «ئۇلار (قانائانىيلار قاتارلىقلار) بۈگۈنكى كۈنگىچە شۇنداق بولۇپ كەلدى»\+bd* ــ بۇ سۆز ئىسرائىللار تېخى ئۆز ۋەتىنىدە تۇرغان ۋاقتىدا خاتىرىلەنگەن، ئەلۋەتتە.\f*   
\m
\v 22 لېكىن سۇلايمان ئىسرائىللاردىن ھېچكىمنى قۇل قىلماي، بەلكى ئۇلارنى لەشكەر، خىزمەتكار، ھۆكۈمدار-ئەمەلدار، ھارۋا بىلەن ئاتلىقلارنىڭ سەردارلىرى قىلدى. \x ◘ \xo 9:22 \xt لاۋ. 25‏:39\x*  
\v 23 بۇلاردىن سۇلايماننىڭ ئىشلىرىنى باشقۇرىدىغان، يەنى ئىشلىگۈچىلەرنىڭ ئۈستىگە قويۇلغان چوڭ نازارەتچىلەر بەش يۈز ئەللىك ئىدى.   
\m
\v 24 پىرەۋننىڭ قىزى داۋۇتنىڭ شەھىرىدىن كۆچۈپ سۇلايمان ئۇنىڭ ئۈچۈن ياسىغان ئۆيدە ئولتۇرغىنىدا، ئۇ مىللو قەلئەسىنى ياسىدى. \x ◘ \xo 9:24 \xt 2تار. 8‏:11\x*  
\v 25 سۇلايمان پەرۋەردىگارغا ياسىغان قۇربانگاھتا يىلدا ئۈچ قېتىم كۆيدۈرمە قۇربانلىقلار بىلەن ئىناقلىق قۇربانلىقلىرىنى سۇناتتى ۋە پەرۋەردىگارنىڭ ئالدىدىكى \add خۇشبۇيگاھتا\add* خۇشبۇي ياقاتتى. شۇ تەرىقىدە ئۇ ئىبادەتخانىنىڭ ئىشلىرىنى پۈتكۈزدى. \f ◼ \fr 9:25 \ft \+bd «شۇ تەرىقىدە ئۇ ئىبادەتخانىنىڭ ئىشلىرىنى پۈتكۈزدى»\+bd* ــ بۇ جۈملىنىڭ مەنىسى بەلكىم سۇلايمان ھېيتلەرنى مۇشۇ ئىبادەتخانىدا ئۆتكۆزۈشلىرى بىلەن ھەربىر باشقا «ئىبادەت جايلىرى»، بولۇپمۇ «يۇقىرى جايلار»نىڭ ئىناۋەتسىزلىكىنى كۆرسەتتى. دېمەك، شۇ چاغدىن باشلاپ پەرۋەردىگار قۇربانلىقلارنى قوبۇل قىلغان جاي پەقەت يېرۇسالېمدىكى ئىبادەتخانىلا ئىدى.\f*   
\m
\v 26 سۇلايمان پادىشاھ ئېزىئون-گەبەردە بىر تۈركۈم كېمىلەرنى ياسىدى. ئۇ يەر بولسا ئېدوم زېمىنىدا، قىزىل دېڭىز بويىدىكى ئېلوتنىڭ يېنىدا ئىدى. \f ◼ \fr 9:26 \ft \+bd «قىزىل دېڭىز بويىدىكى ئېلوت»\+bd* ــ ياكى «قىزىل دېڭىز بويىدىكى ئېلات» (ھازىرقى نامى «ئېلات»).\f*  
\v 27 ھىرام ئۆز خىزمەتكارلىرى، يەنى دېڭىزچىلىقنى ئوبدان بىلىدىغان نەچچە كېمىچىلەرنى سۇلايماننىڭ خىزمەتكارلىرىغا قوشۇلۇپ كېمىلەردە ئىشلەشكە ئەۋەتتى.  
\v 28 ئۇلار ئوفىرغا بېرىپ، ئۇ يەردىن تۆت يۈز يىگىرمە تالانت ئالتۇننى ئېلىپ كېلىپ، سۇلايمان پادىشاھقا ئاپاردى. \f ◼ \fr 9:28 \ft \+bd «تۆت يۈز يىگىرمە تالانت ئالتۇن»\+bd* ــ بىر تالانت (ئالتۇن) بەلكىم 27 كىلوگرام ئىدى. ئۇنداقتا 420 تالانت 11340 كىلوگرام.\f*   
\b  
\b  
\m  
\c 10
\s1 شېبانىڭ ئايال پادىشاھى سۇلايماننى ئىزدەپ كېلىدۇ  
\r 2تار. 9‏:1-12  
\m
\v 1 شېبانىڭ ئايال پادىشاھى بولسا سۇلايماننىڭ پەرۋەردىگارنىڭ نامى بىلەن باغلىنىشلىق بولغان داڭق-شۆھرىتىنى ئاڭلاپ، ئۇنى قىيىن چىگىش-سوئاللار بىلەن سىنىغىلى كەلدى.  
\v 2 ئۇ خۇشبۇي بۇيۇملار، ئىنتايىن تولا ئالتۇن ۋە ياقۇت-گۆھەرلەر ئارتىلغان تۆگىلەرنى ئېلىپ، چوڭ دەبدەبە بىلەن يېرۇسالېمغا كەلدى. سۇلايماننىڭ قېشىغا كەلگەندە ئۆز كۆڭلىگە پۈككەن ھەممە ئىش توغرۇلۇق ئۇنىڭ بىلەن سۆزلەشتى. \x ◘ \xo 10:2 \xt 2تار. 9‏:1؛ مات. 12‏:42؛ لۇقا 11‏:31\x*  
\v 3 سۇلايمان ئۇنىڭ ھەممە سورىغانلىرىغا جاۋاب بەردى. ھېچنېمە پادىشاھقا قاراڭغۇ ئەمەس ئىدى، بەلكى ھەممىسىدە ئۇنىڭغا جاۋاب بەردى.   
\m
\v 4 شېبانىڭ ئايال پادىشاھى سۇلايماننىڭ دانالىقىغا، ياسىغان ئوردا-سارايغا،  
\v 5 داستىخاندىكى تائاملارغا، ئەمەلدارلارنىڭ قاتار-قاتار ئولتۇرۇشلىرىغا، خىزمەتكارلىرىنىڭ قاتار-قاتار تۇرۇشلىرىغا، ئۇلارنىڭ كىيگەن كىيىملىرىگە، ئۇنىڭ ساقىيلىرىغا ۋە ئۇنىڭ پەرۋەردىگارنىڭ ئۆيىدە ئاتاپ سۇنغان كۆيدۈرمە قۇربانلىقلىرىغا قاراپ، ئۈنى ئىچىگە چۈشۈپ كەتتى. \f ◼ \fr 10:5 \ft \+bd «(...ئۇنىڭ \+bdit ، يەنى شېبانىڭ ئايال پادىشاھنىڭ\+bdit*... ئۈنى ئىچىگە چۈشۈپ كەتتى»\+bd* ــ ئىبرانىي تىلىدا «ئۇنىڭدا روھ قالمىدى». دېمەك، ئىنتايىن ھەيران قالدى.\f*   
\b  
\m
\v 6 ئۇ پادىشاھقا: ــ مەن ئۆز يۇرتۇمدا سىلىنىڭ ئىشلىرى ۋە دانالىقلىرى توغرىسىدا ئاڭلىغان خەۋەر راست ئىكەن؛  
\v 7 ئەمما مەن كېلىپ ئۆز كۆزلىرىم بىلەن كۆرمىگۈچە بۇ سۆزلەرگە ئىشەنمىگەنىدىم؛ ۋە مانا، مەن يېرىمىنىمۇ ئاڭلىمىغان ئىكەنمەن؛ سىلىنىڭ دانالىقلىرى بىلەن بەرىكەت-باياشاتلىقلىرى مەن ئاڭلىغان خەۋەردىن زىيادە ئىكەن.  
\v 8 سىلىنىڭ ئادەملىرى نېمىدېگەن بەختلىك-ھە! ھەمىشە سىلىنىڭ ئالدىلىرىدا تۇرۇپ دانالىقلىرىنى ئاڭلايدىغان بۇ خىزمەتكارلار نەقەدەر بەختلىكتۇر!  
\v 9 سىلىدىن سۆيۈنگەن، سىلىنى ئىسرائىلنىڭ تەختىگە ئولتۇرغۇزغان پەرۋەردىگار خۇدالىرى مۇبارەكتۇر! پەرۋەردىگار ئىسرائىلغا مەڭگۈلۈك باغلىغان مۇھەببىتى ئۈچۈن، ئۇ سىلىنى توغرا ھۆكۈم ۋە ئادالەت سۈرگىلى پادىشاھ قىلدى، دېدى.   
\m
\v 10 ئۇ پادىشاھقا بىر يۈز يىگىرمە تالانت ئالتۇن، ئىنتايىن كۆپ خۇشبۇي بۇيۇملار ۋە ياقۇت-گۆھەرلەرنى سوۋغا قىلدى. شېبانىڭ ئايال پادىشاھى سۇلايمان پادىشاھقا سۇنغان شۇنچە زور مىقداردىكى خۇشبۇي بۇيۇملار ئۇنىڭدىن كېيىن ھېچ كۆرۈنگەن ئەمەس  
\v 11 (ھىرامنىڭ ئوفىردىن ئالتۇن ئەپكېلىدىغان كېمىلىرىمۇ ئوفىردىن يەنە ئىنتايىن زور مىقداردىكى سەندەل ياغىچى ۋە ياقۇت-گۆھەرلەرنى ئېلىپ كەلدى.  
\v 12 پادىشاھ سەندەل ياغىچىدىن پەرۋەردىگارنىڭ ئۆيى ئۈچۈن ۋە پادىشاھنىڭ ئوردىسى ئۈچۈن پەلەمپەي-سالاسۇنلار ياساتتى ھەم نەغمە-ناۋاچىلار ئۈچۈن چىلتارلار ۋە سازلارنى شۇنىڭدىن ياساتتى. شۇ ۋاقىتتىن كېيىن شۇنداق زور مىقداردىكى ئېسىل سەندەل ياغىچى بۇ ۋاقىتقىچە ھېچ كەلتۈرۈلمىدى يا كۆرۈلۈپ باقمىدى). \x ◘ \xo 10:12 \xt 2تار. 9‏:11\x*  
\v 13 سۇلايمان پادىشاھ شېبانىڭ ئايال پادىشاھىغا ئۆز شاھانە ساخاۋىتىدىن بەرگەندىن باشقا، ئايال پادىشاھنىڭ كۆڭلى تارتقان ھەممىنى ــ نېمە سورىسا، شۇنى بەردى؛ ئاندىن ئۇ خىزمەتكارلىرى بىلەن يولغا چىقىپ ئۆز يۇرتىغا قايتىپ كەتتى.   
\b  
\m  
\s1 سۇلايماننىڭ بايلىقلىرى  
\r 2تار.9‏:13-28  
\m
\v 14 سۇلايمانغا ھەر يىلى كەلتۈرۈلگەن ئالتۇننىڭ ئۆزى ئالتە يۈز ئاتمىش ئالتە تالانت ئىدى. \f ◼ \fr 10:14 \ft \+bd «666 تالانت»\+bd* ــ 22 توننا.\f*  
\v 15 بۇ كىرىمدىن باشقا، تىجارەتچىلەردىن، ئوقەتچىلەرنىڭ سودىسىدىن، بارلىق ئەرەبىيە پادىشاھلىرىدىن ۋە ئۆز زېمىنىدىكى ئەمەلدارلاردىن ھەم ئالتۇن كەلتۈرۈلدى.   
\m
\v 16 سۇلايمان پادىشاھ ئىككى يۈز چوڭ سىپارنى سوقتۇردى ۋە ھەر سىپارغا ئالتە يۈز شەكەل ئالتۇن كەتتى؛ \f ◼ \fr 10:16 \ft \+bd «600 شەكەل»\+bd* ــ 600 شەكەل بەلكىم 7 كىلوگرامغا يېقىن.\f*  \x ◘ \xo 10:16 \xt 1پاد. 14‏:26\x*  
\v 17 شۇنداقلا ئۈچ يۈز قالقاننى ياپىلاقلانغان ئالتۇندىن ياسىدى؛ ھەربىر قالقاننى ياساشقا ئۈچ مىنا ئالتۇن ئىشلىتىلدى؛ پادىشاھ ئۇلارنى «لىۋان ئورمىنى سارىيى»غا ئېسىپ قويدى. \f ◼ \fr 10:17 \ft \+bd «ئۈچ مىنا ئالتۇن»\+bd* ــ «مىنا» ئېغىرلىق بىرلىكى ئىدى، ھازىرقى بىرلىكلەردە قانچە ئىكەنلىكى ئېنىق ئەمەس.\f*  \x ◘ \xo 10:17 \xt 1پاد. 7‏:2\x*   
\m
\v 18 پادىشاھ پىل چىشلىرىدىن چوڭ بىر تەختنى ياساپ، ئۇنى تاۋلانغان ئالتۇن بىلەن قاپلاتتى. \x ◘ \xo 10:18 \xt 2تار. 9‏:17\x*  
\v 19 تەختنىڭ ئالتە قەۋەتلىك پەلەمپىيى بار ئىدى. تەختنىڭ باش يۆلەنچۈكى يۇمىلاق بولۇپ، ئورۇندۇقنىڭ ئىككى يېنىدا تايانغۇچىسى بار ئىدى، ھەربىر تايانغۇچنىڭ يېنىدا بىردىن ئۆرە تۇرغان شىرنىڭ ھەيكىلى بار ئىدى.  
\v 20 ئالتە قەۋەتلىك پەلەمپەينىڭ ئۈستىدە، ئوڭ ۋە سول تەرىپىدە ئۆرە تۇرغان ئون ئىككى شىرنىڭ ھەيكىلى بولۇپ، ھەربىر باسقۇچنىڭ ئوڭ-سول تەرىپىدە بىردىن بار ئىدى؛ باشقا ھېچقانداق ئەلدە ئۇنىڭغا ئوخشاش ياسالغىنى يوق ئىدى.   
\m
\v 21 سۇلايمان پادىشاھنىڭ بارلىق جام-پىيالىلىرى ئالتۇندىن ياسالغان؛ «لىۋان ئورمىنى سارىيى»دىكى بارلىق قاچا-قۇچىلار تاۋلانغان ئالتۇندىن ياسالغان؛ ئۇلارنىڭ ھېچقايسىسى كۈمۈشتىن ياسالمىغان؛ سۇلايماننىڭ كۈنلىرىدە كۈمۈش ھېچنېمىگە ئەرزىمەيتتى.  
\v 22 چۈنكى پادىشاھقا قاراشلىق دېڭىزدا يۈرىدىغان، ھىرامنىڭ كېمىلىرىگە قوشۇلۇپ «تارشىش كېمە» ئەترىتىمۇ بار ئىدى؛ «تارشىش كېمە ئەترىتى» ئۈچ يىلدا بىر قېتىم كېلىپ ئالتۇن-كۈمۈش، پىل چىشلىرى، مايمۇنلار ۋە توزلارنى ئەكېلەتتى. \f ◼ \fr 10:22 \ft \+bd «تارشىش كېمە»\+bd* ــ بەلكىم تارشىش دېگەن پورتقا بېرىپ كېلىش سەپىرىگە چىداملىق بولغان كېمىنى كۆرسىتەتتى. «تارشىش» دېگەن ئىسىم ئىسپانىيە، شىمالىي ئافرىقا ياكى برىتانىيەنى ياكى ئۈچىنىڭ ھەممىسىنى كۆرسىتىدۇ. بەزى ئلىملار سومالىيەنىڭ (شەرقىي ئافرىقانىڭ) دېڭىز بويىدا تۆتىنچى بىر تارشىشمۇ بولغان، دەپ قارايدۇ.\f*   
\m
\v 23 سۇلايمان پادىشاھ يەر يۈزىدىكى بارلىق پادىشاھلاردىن بايلىقتا ۋە دانالىقتا ئۈستۈن ئىدى. \x ◘ \xo 10:23 \xt 1پاد. 3‏:12، 13\x*  
\v 24 خۇدا سۇلايماننىڭ كۆڭلىگە سالغان دانالىقنى ئاڭلاش ئۈچۈن يەر يۈزىدىكىلەر ھەممىسى ئۇنىڭ بىلەن دىدارلىشىش ئارزۇسى بىلەن كېلەتتى.  
\v 25 كەلگەنلەرنىڭ ھەممىسى ئۆز سوۋغىتىنى ئېلىپ كېلەتتى؛ يەنى كۈمۈش قاچا-قۇچىلار، ئالتۇن قاچا-قۇچىلار، كىيىم-كېچەكلەر، دۇبۇلغا-ساۋۇتلار، تېتىتقۇلار، ئاتلار ۋە قېچىرلارنى ئېلىپ كېلەتتى. ئۇلار ھەر يىلى بەلگىلىك مىقداردا شۇنداق قىلاتتى. \f ◼ \fr 10:25 \ft \+bd «تېتىتقۇلار»\+bd* ــ ياكى «خۇشبۇي بۇيۇملار». \+bd «ئۇلار ھەر يىلى بەلگىلىك مىقداردا شۇنداق قىلاتتى»\+bd* ــ ياكى «يىلمۇيىل ئۇلار شۇنداق قىلاتتى».\f*   
\m
\v 26 ۋە سۇلايمان جەڭ ھارۋىلىرى ۋە ئاتلىق ئەسكەرلەرنى يىغدى؛ ئۇنىڭ بىر مىڭ تۆت يۈز جەڭ ھارۋىسى، ئون ئىككى مىڭ ئاتلىق ئەسكىرى بار ئىدى؛ ئۇ ئۇلارنى «جەڭ ھارۋىسى شەھەرلىرى»گە ۋە ئۆزى تۇرۇۋاتقان يېرۇسالېمغا ئورۇنلاشتۇردى. \x ◘ \xo 10:26 \xt 1پاد. 5‏:20؛ 2تار. 1‏:14؛ 9‏:25\x*   
\m
\v 27 پادىشاھ يېرۇسالېمدا كۈمۈشنى تاشتەك كۆپ، كېدىر دەرەخلىرىنى شەرقىي تۈزلەڭلىكتىكى ئۈجمە دەرەخلىرىگە ئوخشاش نۇرغۇن قىلدى. \f ◼ \fr 10:27 \ft \+bd «كېدىر دەرەخلىرىنى...»\+bd* ــ ياكى «كېدىر ياغىچىنى...». لېكىن بىزنىڭچە سۇلايمان كېدىر ياغىچىنى ئىشلىتىپلا قالماي، شۇ چىرايلىق دەرەخلەردىن يېرۇسالېم ئەتراپىغا كۆپ تىكتۈردى («توپ.» 5:2نى كۆرۈڭ). \+bd «شەرقىي تۈزلەڭلىكتىكى...»\+bd* ــ ئىبرانىي تىلىدا «شەفەلاھدىكى...». «شەفەلاھ» بۇ يەرنىڭ (تۈزلەڭلىكنىڭ) ئىسمى.\f*  \x ◘ \xo 10:27 \xt 2تار. 1‏:15؛ 9‏:27\x*   
\m
\v 28 سۇلايمان ئالغان ئاتلار مىسىردىن ۋە كۇۋەدىن ئىدى؛ پادىشاھنىڭ تىجارەتچىلىرى ئۇلارنى كۇۋەدىن بېكىتىلگەن باھادا ئالاتتى. \f ◼ \fr 10:28 \ft \+bd «پادىشاھنىڭ تىجارەتچىلىرى ئۇلارنى كۇۋەدىن بېكىتىلگەن باھادا ئالاتتى»\+bd* ــ بۇ جۈملىنىڭ باشقا بىرخىل تەرجىمىسى: «پادىشاھنىڭ تىجارەتچىلىرى ئۇلارنى كارۋانغا قوشۇپ ئالاتتى». «كۇۋە» بولسا ھازىرقى تۈركىيەنىڭ جەنۇبىي تەرىپىدە.\f*  \x ◘ \xo 10:28 \xt 2تار. 1‏:16؛ 9‏:28\x*  
\v 29 مىسىردىن ئېلىپ كەلگەن بىر جەڭ ھارۋىسىنىڭ باھاسى ئالتە يۈز كۈمۈش تەڭگە، ھەر ئات بولسا يۈز ئەللىك تەڭگە ئىدى؛ ۋە ئۇلار يەنە ھىتتىيلارنىڭ پادىشاھلىرى ھەم سۇرىيە پادىشاھلىرى ئۈچۈنمۇ ئوخشاش باھادا ئېلىپ چىقتى. \f ◼ \fr 10:29 \ft \+bd «بىر جەڭ ھارۋىسىنىڭ باھاسى ئالتە يۈز كۈمۈش تەڭگە...»\+bd* ــ مۇشۇ ئايەتتىكى «تەڭگە»نىڭ قىممىتى ھازىرغىچە ئېنىق ئەمەس. ئەگەر «شەكەل» بولسا 11.4 گرامنى كۆرسىتىدۇ.\f*  \x ◘ \xo 10:29 \xt 2تار. 1‏:17\x*   
\b  
\b  
\m  
\c 11
\s1 سۇلايمان كۆپ ئاياللارنى ئېلىپ، ئۇلارنىڭ ئېزىتقۇلۇقى بىلەن بۇتپەرەسلىككە تېيىلىپ كېتىدۇ  
\m
\v 1 لېكىن سۇلايمان پادىشاھنىڭ كۆڭلى پىرەۋننىڭ قىزىدىن باشقا كۆپ چەتئەللىك ئاياللارغا، جۈملىدىن موئابىي، ئاممونىي، ئېدومىي، زىدونىي، ھىتتىي ئاياللىرىغا چۈشكەنىدى. \f ◼ \fr 11:1 \ft \+bd «لېكىن سۇلايمان پادىشاھنىڭ كۆڭلى پىرەۋننىڭ قىزىدىن باشقا كۆپ چەتئەللىك ئاياللارغا، جۈملىدىن موئابىي، ئاممونىي، ئېدومىي، زىدونىي، ھىتتىي ئاياللىرىغا چۈشكەنىدى»\+bd* ــ بۇ بابتا خاتىرىلەنگەن ھەممە ئىشلار «قانۇن شەرھى»دىكى ئەمرلەرگە خىلاپ. «قان.» 16:17-20نى كۆرۈڭ.\f*  \x ◘ \xo 11:1 \xt قان. 17‏:17\x*  
\v 2 پەرۋەردىگار ئەسلىدە مۇشۇ ئەللەر توغرۇلۇق ئىسرائىللارغا: «ئۇلارنىڭ قىزلىرىنى ئىزدەپ بارماڭلار، ۋە ئۇلارنى سىلەرنىڭكىلەرگە كىرگۈزمەڭلار؛ چۈنكى ئۇلار كۆڭۈللىرىڭلارنى چوقۇم ئۆز مەبۇدلىرىغا ئازدۇرىدۇ» دەپ ئاگاھلاندۇرغان. بىراق سۇلايماننىڭ كۆڭلى دەل شۇلارغا باغلاندى. \x ◘ \xo 11:2 \xt مىس. 34‏:16؛ قان. 7‏:3\x*  
\v 3 ئۇنىڭ يەتتە يۈز ئايالى، يەنى خانىشى ۋە ئۈچ يۈز كېنىزىكى بار ئىدى؛ ئاياللىرى ئۇنىڭ كۆڭلىنى ئازدۇرۇپ بۇرىۋەتكەنىدى.   
\m
\v 4 شۇنداق بولدىكى، سۇلايمان ياشانغاندا، ئۇنىڭ ئاياللىرى ئۇنىڭ كۆڭلىنى باشقا ئىلاھلارغا ئازدۇرۇپ بۇرۇۋەتتى؛ شۇنىڭ ئۈچۈن ئۇنىڭ كۆڭلى ئاتىسى داۋۇتنىڭكىدەك پەرۋەردىگار خۇداسىغا مۇتلەق سادىق بولمىدى.   
\m
\v 5 شۇڭا سۇلايمان زىدونىيلارنىڭ مەبۇدى ئاشتاروتنى، ئاممونىيلارنىڭ يىرگىنچلىك مەبۇدى مىلكومنى ئىزدىدى؛ \x ◘ \xo 11:5 \xt ھاك. 2‏:13؛ 2پاد. 23‏:13\x*  
\v 6 شۇنىڭ بىلەن سۇلايمان پەرۋەردىگارنىڭ نەزىرىدە رەزىللىك قىلدى؛ ئۇ ئاتىسى داۋۇت پەرۋەردىگارغا ئەگەشكەندەك ئىزچىللىق بىلەن ئەگەشمىدى.   
\m
\v 7 ئاندىن سۇلايمان يېرۇسالېم ئالدىدىكى ئېدىرلىقتا موئابىيلارنىڭ يىرگىنچلىك مەبۇدى كېموش ھەم ئاممونىيلارنىڭ يىرگىنچلىك مەبۇدى مىلكوم ئۈچۈن بىر «يۇقىرى جاي»نى ياسىدى؛ \f ◼ \fr 11:7 \ft \+bd «يىرگىنچلىك مەبۇد مىلكوم»\+bd* ــ «مىلكوم» ئىبرانىي تىلىدا مۇشۇ يەردە «مولەق» دەپ ئىپادىلىنىدۇ.\f*  \x ◘ \xo 11:7 \xt 2پاد. 23‏:13\x*  
\v 8 شۇنىڭدەك ئۆزىنىڭ مەبۇدلىرىغا خۇشبۇي ياقىدىغان ۋە قۇربانلىق قىلىدىغان ھەربىر يات ئەللىك ئايالى ئۈچۈنمۇ ئۇ شۇنداق قىلدى؛  
\v 9‏-10 شۇڭا پەرۋەردىگار سۇلايماندىن رەنجىدى؛ گەرچە ئۇ ئۇنىڭغا ئىككى قېتىم كۆرۈنگەن بولسىمۇ، شۇنداقلا ئۇنىڭغا دەل مۇشۇ ئىش توغرۇلۇق، يەنى باشقا ئىلاھلارنى ئىزدىمەسلىكىنى تاپىلىغان بولسىمۇ، ئۇنىڭ كۆڭلى ئىسرائىلنىڭ خۇداسى پەرۋەردىگاردىن ئاينىپ كەتتى؛ ئۇ پەرۋەردىگارنىڭ تاپىلىغىنىغا ئەمەل قىلمىدى. \x ◘ \xo 11:9‏-10 \xt 1پاد. 3‏:5؛ 9‏:2؛ 1پاد. 6‏:12\x*  
\v 11 شۇنىڭ ئۈچۈن پەرۋەردىگار سۇلايمانغا مۇنداق دېدى: ــ «سەن شۇنداق قىلىۋېرىپ، مېنىڭ ساڭا بۇيرۇغان ئەھدەم بىلەن بەلگىلىرىمنى تۇتمىغىنىڭ ئۈچۈن، مەن جەزمەن پادىشاھلىقنى سەندىن يىرتىۋېتىپ خىزمەتكارىڭغا بېرىمەن. \f ◼ \fr 11:11 \ft \+bd «مەن جەزمەن پادىشاھلىقنى سەندىن يىرتىۋېتىپ خىزمەتكارىڭغا بېرىمەن»\+bd* ــ «يىرتىۋېتىپ ... بېرىمەن» ــ دېمەك، پەرۋەردىگار پادىشاھلىقىنى سۇلايماندىن زوراۋانلىق بىلەن تارتىۋېلىپ ئۇنىڭ قول ئاستىدىكى بىرسىگە بەرمەكچى. 28-33-ئايەتنى كۆرۈڭ.\f*  \x ◘ \xo 11:11 \xt 1پاد. 12‏:15\x*  
\v 12 لېكىن ئاتاڭ داۋۇتنىڭ ۋەجىدىن سېنىڭ ئۆز كۈنلىرىڭدە مەن شۇنداق قىلمايمەن، بەلكى ئوغلۇڭنىڭ قولىدىن ئۇنى يىرتىۋېتىمەن.  
\v 13 لېكىن پۈتۈن پادىشاھلىقنى ئۇنىڭدىن يىرتىۋەتمەيمەن، بەلكى قۇلۇم داۋۇتنىڭ ۋەجىدىن ۋە ئۆزۈم تاللىغان يېرۇسالېم ئۈچۈن ئوغلۇڭغا بىر قەبىلىنى قالدۇرۇپ قويىمەن».   
\m
\v 14 ئەمما پەرۋەردىگار سۇلايمانغا بىر دۈشمەن، يەنى ئېدوملۇق ھادادنى قوزغىدى، ئۇ كىشى ئېدومنىڭ پادىشاھىنىڭ نەسلىدىن ئىدى.  
\v 15‏-16 ئەسلىدە داۋۇت ئېدوم بىلەن \add جەڭ قىلغان\add* ۋاقىتتا، قوشۇننىڭ سەردارى يوئاب ئېدومنىڭ ھەممە ئەرلىرىنى يوقاتقانىدى (چۈنكى ئېدومدىكى ھەممە ئەرلەرنى يوقاتقۇچە، يوئاب بىلەن بارلىق ئىسرائىللار ئۇ يەردە ئالتە ئاي تۇرغانىدى)؛ ئۇ ئۆلتۈرۈلگەنلەرنى كۆمگىلى چىققاندا \f ◼ \fr 11:15‏-16 \ft \+bd « \+bdit داۋۇت\+bdit* ئۆلتۈرۈلگەنلەرنى كۆمگىلى چىققاندا...»\+bd* ــ ئۆز ئادەملىرىنى كۆمۈش ئۈچۈن، دېمەك. بۇ سۆزگە قارىغاندا يوئابنىڭ ئېدوملارنى شۇنداق ئۆلتۈرۈشى قىساس مەقسىتىدە ئىدى.\f*  \x ◘ \xo 11:15‏-16 \xt 2سام. 8‏:14؛ 1تار. 18‏:12، 13\x*  
\v 17 ھاداد ئاتىسىنىڭ بىرنەچچە ئېدومىي خىزمەتچىلىرى بىلەن مىسىرغا قېچىپ كەتكەنىدى. ھاداد ئۇ چاغدا كىچىك بالا ئىدى.  
\v 18 ئۇلار مىدىيان زېمىنىدىن چىقىپ پارانغا كەلدى. ئۇلار پاراندىن بىرنەچچە ئادەمنى ئېلىپ ئۆزلىرىگە قوشۇپ مىسىرغا، يەنى مىسىرنىڭ پادىشاھى پىرەۋننىڭ قېشىغا كەلدى. پىرەۋن ئۇنىڭغا بىر ئۆي تەقسىم قىلىپ، ئوزۇق-تۈلۈكمۇ تەمىنلىدى ھەمدە بىر پارچە يەرنىمۇ ئۇنىڭغا تەقدىم قىلدى.  
\v 19 ھاداد پىرەۋننىڭ نەزىرىدە كۆپ ئىلتىپات تاپقان بولۇپ، ئۇ ئۆز خوتۇنىنىڭ سىڭلىسىنى، يەنى تاھپەنەس خانىشنىڭ سىڭلىسىنى ئۇنىڭغا خوتۇن قىلىپ بەردى.  
\v 20 تاھپەنەسنىڭ سىڭلىسى ئۇنىڭغا بىر ئوغۇل، گېنۇباتنى تۇغۇپ بەردى. تاھپەنەس پىرەۋننىڭ ئوردىسىدا ئۇنى ئۆزى چوڭ قىلدى. ئاندىن گېنۇبات پىرەۋننىڭ ئائىلىسى، يەنى پىرەۋننىڭ ئوغۇللىرى ئارىسىدا تۇردى. \f ◼ \fr 11:20 \ft \+bd «تاھپەنەس پىرەۋننىڭ ئوردىسىدا ئۇنى ئۆزى چوڭ قىلدى»\+bd* ــ ياكى «تاھپەنەس پىرەۋننىڭ ئوردىسىدا ئۇنى ئۆزى ئەمچەكتىن ئايرىدى».\f*   
\m
\v 21 ھاداد مىسىردا: «داۋۇت ئاتا-بوۋىلىرىنىڭ ئارىسىدا ئۇخلاپ قالدى» ۋە «قوشۇننىڭ سەردارى يوئابمۇ ئۆلدى» دەپ ئاڭلىغاندا پىرەۋنگە: ــ مېنىڭ ئۆز يۇرتۇمغا بېرىشىمغا ئىجازەت قىلغايلا، دېدى.   
\m
\v 22 پىرەۋن ئۇنىڭغا: ــ سېنىڭ ئۆز يۇرتۇمغا باراي دېگىنىڭ نېمە دېگىنىڭ، مېنىڭ قېشىمدا ساڭا نېمە كەملىك قىلىدۇ؟ ــ دېدى. ئۇ جاۋابەن: ــ ھېچ نەرسە كەم ئەمەس، ئەمما نېمىلا بولمىسۇن مېنى كەتكىلى قويغايلا، دېدى.   
\m
\v 23 خۇدا سۇلايمانغا يەنە بىر دۈشمىنىنى قوزغىدى؛ ئۇ بولسا غوجىسى، يەنى زوباھنىڭ پادىشاھى ھادادئېزەرنىڭ يېنىدىن قېچىپ كەتكەن ئېلىئادانىڭ ئوغلى رەزون ئىدى. \x ◘ \xo 11:23 \xt 2سام. 8‏:3؛ 10‏:18\x*  
\v 24 داۋۇت \add زوباھلىقلارنى\add* قەتل قىلغاندا رەزون ئۇلاردىن بىر توپ ئادەمنى ئۆزىگە توپلاپ ئۇلارنىڭ سەردارى بولدى. ئاندىن كېيىن بۇلار دەمەشققە بېرىپ ئۇ يەردە تۇرۇپ، دەمەشق ئۈستىدىن ھۆكۈم سۈردى. \f ◼ \fr 11:24 \ft \+bd «داۋۇت زوباھلىقلارنى قەتل قىلغاندا رەزون ئۇلاردىن بىر توپ ئادەمنى ئۆزىگە توپلاپ ئۇلارنىڭ سەردارى بولدى. ئاندىن كېيىن بۇلار دەمەشققە بېرىپ...»\+bd* ــ باشقا بىرخىل تەرجىمىسى: «رەزون بىر توپ ئادەمنى ئۆزىگە قوشۇپ ئۇلارنىڭ سەردارى بولدى. داۋۇت ئۇلارنى ئۆلتۈرمەكچە بولغاندا، ئۇلار دەمەشققە بېرىپ...».\f*  \x ◘ \xo 11:24 \xt 2سام. 8‏:3\x*  
\v 25 شۇنىڭ بىلەن ھاداد ئىسرائىلغا ئاۋارىچىلىك تۇغدۇرغاندىن باشقا، رەزون سۇلايماننىڭ بارلىق كۈنلىرىدە ئىسرائىلنىڭ دۈشمىنى ئىدى؛ ئۇ ئىسرائىلنى ئۆچ كۆرەتتى، ئۆزى سۇرىيە ئۈستىدە پادىشاھ ئىدى.   
\m
\v 26 سۇلايماننىڭ يەروبوئام دېگەن بىر خىزمەتكارى بار ئىدى. ئۇ زەرەداھدىن كەلگەن ئەفرائىمىي نىباتنىڭ ئوغلى بولۇپ، ئانىسى زەرۇئاھ ئىسىملىك بىر تۇل ئايال ئىدى. يەروبوئاممۇ پادىشاھقا قارشى چىقتى. \f ◼ \fr 11:26 \ft \+bd «ئەفرائىمىي نىبات»\+bd* ــ مۇشۇ ئايەتتە «ئەفرائىمىي» ئىبرانىي تىلىدا «ئەفراتلىق» دېگەن سۆز بىلەن ئىپادىلىنىدۇ.\f*  \x ◘ \xo 11:26 \xt 2تار. 13‏:6\x*  
\v 27 ئۇنىڭ پادىشاھقا قارشى چىقىشتىكى سەۋەبى مۇنداق ئىدى: سۇلايمان مىللو قەلئەسىنى ياسىغاندا، ئاتىسى داۋۇتنىڭ شەھىرىدىكى سېپىلنىڭ بىر بۆسۈكىنى ياساۋاتاتتى؛  
\v 28 يەروبوئام قاۋۇل قەيسەر يىگىت ئىدى؛ سۇلايمان يىگىتنىڭ ئىشچان ۋە چاققان ئىكەنلىكىنى كۆرۈپ، ئۇنى يۈسۈپنىڭ جەمەتىگە بۇيرۇلغان ئىشنىڭ ئۈستىگە قويدى.  
\v 29 شۇ كۈنلەردە يەروبوئام يېرۇسالېمدىن چىقىۋاتقاندا، ئۇنى ئىزدەۋاتقان شىلوھلۇق ئاخىياھ پەيغەمبەر ئۇنى يولدا ئۇچراتتى. ئاخىياھ يىپيېڭى بىر توننى كىيىۋالغانىدى. ئىككىسى دالادا يالغۇز قالغاندا  
\v 30 ئاخىياھ ئۈستىدىكى توننى قولىغا ئېلىپ، ئۇنى يىرتىپ ئون ئىككى پارچە قىلىپ  
\v 31 يەروبوئامغا مۇنداق دېدى: ــ «ئۆزۈڭگە ئون پارچىنى ئالغىن؛ چۈنكى ئىسرائىلنىڭ خۇداسى پەرۋەردىگار مۇنداق دەيدۇ: ــ «مانا، پادىشاھلىقنى سۇلايماننىڭ قولىدىن يىرتىۋېتىپ ئون قەبىلىنى ساڭا بېرىمەن. \x ◘ \xo 11:31 \xt 1سام. 15‏:28\x*  
\v 32 بىراق قۇلۇم داۋۇتنىڭ ۋەجىدىن ۋە يېرۇسالېم، يەنى ئىسرائىلنىڭ ھەممە قەبىلىلىرىدىن تاللىغان شەھەر ئۈچۈن بىر قەبىلە ئۇنىڭغا قالىدۇ.  
\v 33 ــ چۈنكى ئۇلار مېنى تاشلاپ زىدونىيلارنىڭ ئايال مەبۇدى ئاشتاروتقا، موئابىيلارنىڭ مەبۇدى كېموشقا ۋە ئاممونىيلارنىڭ مەبۇدى مىلكومغا سەجدە قىلىپ، ئۇنىڭ ئاتىسى داۋۇتنىڭ قىلىنغىنىدەك قىلماي، مېنىڭ بەلگىلىمىلىرىم بىلەن ھۆكۈملىرىمگە ئەمەل قىلماي، نەزىرىمدە دۇرۇس بولغاننى قىلمىدى، مېنىڭ يوللىرىمدا ماڭمىدى؛  
\v 34 لېكىن پۈتكۈل پادىشاھلىقنى ئۇنىڭ قولىدىن تارتىۋالمايمەن؛ چۈنكى مەن تاللىغان، ئۆز ئەمرلىرىم ۋە بەلگىلىمىلىرىمنى تۇتقان قۇلۇم داۋۇتنى دەپ، ئۇنىڭ ئۆمرىنىڭ بارلىق كۈنلىرىدە ئۇنى ھۆكۈم سۈرگۈچى قىلىپ قالدۇرىمەن.  
\v 35 ئەمما پادىشاھلىقنى ئۇنىڭ ئوغلىنىڭ قولىدىن تارتىپ ئېلىپ، ساڭا بېرىمەن، يەنى ئون قەبىلىنى بېرىمەن.   
\m
\v 36 لېكىن مېنىڭ نامىمنىڭ شۇ يەردە بولۇشىغا ئۆزۈم تاللىغان شەھەر يېرۇسالېمدا، مېنىڭ ئالدىمدا قۇلۇم داۋۇت ئۈچۈن ھەمىشە يورۇق بىر چىراغ بولسۇن دەپ، ئۇنىڭ ئوغلىغا بىر قەبىلىنى بېرەي. \f ◼ \fr 11:36 \ft \+bd «مېنىڭ ئالدىمدا قۇلۇم داۋۇت ئۈچۈن يورۇق بىر چىراغ بولسۇن»\+bd* ــ بۇ كۆچمە مەنىلىك سۆز بولۇپ، داۋۇتنىڭ خاندانىنى كۆرسىتىدۇ؛ خانداننىڭ مەۋجۇت بولغانلىقى (1) داۋۇتنىڭ خۇداغا سادىق بولغانلىقىغا گۇۋاھلىق بېرىدىغان «چىراغ» بولىدۇ؛ (2) خۇدانىڭ داۋۇتقا، سەن ئارقىلىق پۈتكۈل دۇنيانى سورايدىغان مەسىھ تۇغۇلىدۇ، دەپ بەرگەن ۋەدىسىدە تۇرىدىغانلىقىغا گۇۋاھلىق بېرىدىغان «چىراغ» بولىدۇ.\f*  \x ◘ \xo 11:36 \xt 1پاد. 15‏:4؛ زەب. 132‏:17-18؛ پەند. 9:13\x*  
\v 37 مەن سېنى تاللاپ، سېنى بارلىق خالىغان يەرلەر ئۈستىگە ھۆكۈم سۈرگۈزىمەن، سەن ئىسرائىلغا پادىشاھ بولىسەن.  
\v 38 ۋە شۇنداق بولىدۇكى، ئەگەر سەن ھەممە بۇيرۇغانلىرىمنى ئاڭلاپ، مېنىڭ يوللىرىمدا مېڭىپ، نەزىرىمدە دۇرۇس بولغاننى قىلىپ، قۇلۇم داۋۇت قىلغاندەك مېنىڭ بەلگىلىرىم بىلەن ئەمرلىرىمنى تۇتساڭ، ئەمدى مەن سەن بىلەن بىللە بولىمەن ۋە داۋۇتقا بىر جەمەت تىكلىگىنىمدەك، ساڭىمۇ مۇستەھكەم بىر جەمەت تىكلەيمەن ۋە ئىسرائىلنى ساڭا تەقدىم قىلىمەن. \f ◼ \fr 11:38 \ft \+bd «داۋۇتقا بىر جەمەت تىكلىگىنىمدەك...»\+bd* ــ ئىبرانىي تىلىدا «داۋۇتقا بىر ئۆي تىكلىگىنىمدەك...».\f*  
\v 39 داۋۇتنىڭ نەسلىنى شۇ ئىشلار تۈپەيلىدىن خارلاپ پەس قىلىمەن، لېكىن مەڭگۈلۈك ئەمەس»».   
\b  
\m
\v 40 شۇنىڭ ئۈچۈن سۇلايمان يەروبوئامنى ئۆلتۈرۈشكە پۇرسەت ئىزدەيتتى. لېكىن يەروبوئام قېچىپ مىسىرنىڭ پادىشاھى شىشاكنىڭ قېشىغا باردى؛ سۇلايمان ئۆلگۈچە ئۇ مىسىردا تۇردى.   
\m
\v 41 سۇلايماننىڭ باشقا ئىشلىرى، ئۇنىڭ ھەممە قىلغان ئەمەللىرى ۋە ئۇنىڭ دانالىقى بولسا «سۇلايماننىڭ ئەمەللىرى» دېگەن كىتابقا پۈتۈلگەن ئەمەسمىدى؟ \f ◼ \fr 11:41 \ft \+bd ««سۇلايماننىڭ ئەمەللىرى» دېگەن كىتاب»\+bd* ــ بۇ كىتابتىن ھازىر خەۋىرىمىز يوق.\f*  \x ◘ \xo 11:41 \xt 2تار. 9‏:29-31\x*  
\v 42 سۇلايماننىڭ يېرۇسالېمدا ئىسرائىلنىڭ ئۈستىگە ھۆكۈم سۈرگەن ۋاقتى قىرىق يىل بولدى. \x ◘ \xo 11:42 \xt 2تار. 9‏:30\x*  
\v 43 سۇلايمان ئاتا-بوۋىلىرىنىڭ ئارىسىدا ئۇخلىدى ۋە ئاتىسى داۋۇتنىڭ شەھىرىدە دەپنە قىلىندى. ئاندىن ئوغلى رەھوبوئام ئورنىدا پادىشاھ بولدى.   
\b  
\b  
\m  
\c 12
\s1 رەھوبوئام پادىشاھلىقىدىن مەھرۇم بولىدۇ  
\r 2تار. 10‏:1-19؛ 11‏:1-4  
\m
\v 1 رەھوبوئام شەقەمگە باردى؛ چۈنكى پۈتكۈل ئىسرائىل ئۇنى پادىشاھ تىكلىگىلى شەقەمگە كەلگەنىدى. \x ◘ \xo 12:1 \xt 2تار. 10‏:1\x*  
\v 2 نىباتنىڭ ئوغلى يەروبوئام شۇ ئىشنى ئاڭلىغاندا، شۇنداق بولدىكى، ئۇ تېخى مىسىردا ئىدى (چۈنكى يەروبوئام سۇلايمان پادىشاھتىن قېچىپ مىسىردا تۇرۇۋاتاتتى). \x ◘ \xo 12:2 \xt 1پاد. 11‏:40\x*  
\v 3 ئەمدى ئۇلار ئادەم ئەۋەتىپ ئۇنى چاقىرتىپ كەلدى. شۇنىڭ بىلەن يەروبوئام ۋە پۈتكۈل ئىسرائىل جامائىتى كېلىپ رەھوبوئامغا سۆز قىلىپ:  
\v 4 ــ سىلىنىڭ ئاتىلىرى بوينىمىزغا سالغان بويۇنتۇرۇقىنى ئېغىر قىلدى. سىلى ئەمدى ئاتىلىرىنىڭ بىزگە قويغان قاتتىق تەلەپلىرى بىلەن ئېغىر بويۇنتۇرۇقىنى يېنىكلىتىپ بەرسىلە، سىلىنىڭ خىزمەتلىرىدە بولىمىز، دېيىشتى. \x ◘ \xo 12:4 \xt 2تار. 10‏:4\x*   
\m
\v 5 ئۇ ئۇلارغا: ــ ھازىرچە قايتىپ ئۈچ كۈندىن كېيىن ئاندىن قېشىمغا يەنە كېلىڭلار، دېدى. شۇنىڭ بىلەن خەلق تارىلىپ كەتتى.   
\m
\v 6 رەھوبوئام پادىشاھ ئۆز ئاتىسى سۇلايمان ھايات ۋاقتىدا ئۇنىڭ خىزمىتىدە تۇرغان مويسىپىتلاردىن مەسلىھەت سوراپ: ــ بۇ خەلققە بېرىدىغان جاۋابىم توغرىسىدا نېمە مەسلىھەت كۆرسىتىسىلەر؟ ــ دېدى.   
\m
\v 7 ئۇلار ئۇنىڭغا: ــ ئەگەر سىلى رازىلىق بىلەن بۈگۈن بۇ خەلقنىڭ خىزمىتىدە بولىمەن دېسىلە (ۋە دەرۋەقە ئۇلارنىڭ خىزمىتىدە بولسىلا)، ئۇلارغا ياخشى سۆزلەر بىلەن جاۋاب قىلسىلا، ئۇلار سىلىنىڭ بارلىق كۈنلىرىدە خىزمەتلىرىدە بولىدۇ، دېدى.   
\m
\v 8 لېكىن ئۇ مويسىپىتلارنىڭ كۆرسەتكەن مەسلىھەتىنى قايرىپ قويۇپ، ئۆزى بىلەن چوڭ بولغان، ئالدىدا خىزمىتىدە بولۇۋاتقان ياشلاردىن مەسلىھەت سوراپ  
\v 9 ئۇلارغا: ــ ماڭا «سىلىنىڭ ئاتىلىرى بىزگە سالغان بويۇنتۇرۇقنى يېنىكلەتكەيلا» دەپ تىلىگەن بۇ خەلققە جاۋاب بېرىشىمىز توغرۇلۇق قانداق مەسلىھەت بېرىسىلەر؟ ــ دېدى.   
\m
\v 10 ئۇنىڭ بىلەن چوڭ بولغان بۇ ياشلار ئۇنىڭغا: ــ «سىلىنىڭ ئاتىلىرى بويۇنتۇرۇقىمىزنى ئېغىر قىلدى، ئەمدى سىلى ئۇنى بىزگە يېنىك قىلغايلا» دەپ ئېيتقان بۇ خەلققە سۆز قىلىپ: ــ «مېنىڭ چىمچىلاق بارمىقىم ئاتامنىڭ بېلىدىن تومراقتۇر.  
\v 11 ئاتام سىلەرگە ئېغىر بويۇنتۇرۇقنى سالغان، لېكىن مەن بويۇنتۇرۇقۇڭلارنى تېخىمۇ ئېغىر قىلىمەن. ئاتام سىلەرگە قامچىلار بىلەن تەنبىھ-تەربىيە بەرگەن بولسا، مەن سىلەرگە «چايانلىق قامچىلار» بىلەن تەنبىھ بېرىمەن»، دېگەيلا، ــ دېدى. \f ◼ \fr 12:11 \ft \+bd «چايانلىق قامچىلار»\+bd* ــ ياكى بولمىسا «چايانلار» دېگەننىڭ نېمە ئىكەنلىكى ھازىر مەلۇم ئەمەس، ھېچ بولمىغاندا پادىشاھنىڭ ئىنتايىن قاتتىق مۇئامىلىسىنى كۆرسىتىدۇ.\f*   
\m
\v 12 رەھوبوئام پادىشاھ ئۇلارغا: «ئۈچ كۈندىن كېيىن ئاندىن قېشىمغا يەنە كېلىڭلار» دېگىنىدەك، يەروبوئام ۋە بارلىق خەلق ئۈچىنچى كۈنى ئۇنىڭ قېشىغا كەلدى.   
\m
\v 13 پادىشاھ مويسىپىتلارنىڭ ئۇنىڭغا بەرگەن مەسلىھەتىنى تاشلاپ، خەلققە قاتتىقلىق بىلەن جاۋاب بەردى.  
\v 14 ئۇ ياشلارنىڭ مەسلىھەتى بويىچە ئۇلارغا: ــ ئاتام سىلەرگە ئېغىر بويۇنتۇرۇقنى سالغان، لېكىن مەن بويۇنتۇرۇقۇڭلارنى تېخىمۇ ئېغىر قىلىمەن. ئاتام سىلەرگە قامچىلار بىلەن تەنبىھ-تەربىيە بەرگەن بولسا مەن سىلەرگە «چايانلىق قامچىلار» بىلەن تەنبىھ-تەربىيە بېرىمەن، دېدى.   
\m
\v 15 شۇنىڭ بىلەن پادىشاھ خەلقنىڭ سۆزىنى ئاڭلىمىدى. بۇ ئىش پەرۋەردىگار تەرىپىدىن بولغان؛ چۈنكى بۇنىڭ بىلەن پەرۋەردىگارنىڭ شىلوھلۇق ئاخىياھنىڭ ۋاسىتىسىدە نىباتنىڭ ئوغلى يەروبوئامغا ئېيتقان سۆزى ئەمەلگە ئاشۇرۇلىدىغان بولدى. \x ◘ \xo 12:15 \xt 1پاد. 11‏:11، 31\x*   
\m
\v 16 پۈتكۈل ئىسرائىل پادىشاھنىڭ ئۇلارنىڭ سۆزىگە قۇلاق سالمىغىنىنى كۆرگەندە خەلق پادىشاھقا جاۋاب بېرىپ: ــ داۋۇتتىن بىزگە نېمە نېسىۋە بار؟ يەسسەنىڭ ئوغلىدا بىزنىڭ ھېچ مىراسىمىز يوقتۇر! ئۆز ئۆي-چېدىرلىرىڭلارغا قايتىڭلار، ئى ئىسرائىل! ئى داۋۇت، سەن ئۆز جەمەتىڭگىلا ئىگە بول، ــ دېدى. شۇنىڭ بىلەن ئىسرائىللار ئۆز ئۆي-چېدىرلىرىغا قايتىپ كېتىشتى. \f ◼ \fr 12:16 \ft \+bd «...ئىسرائىللار ئۆز ئۆي-چېدىرلىرىغا قايتىپ كېتىشتى»\+bd* ــ ئىبرانىي تىلىدا «ئىسرائىللار ئۆز چېدىرلىرىغا قايتىپ كېتىشتى».\f*  \x ◘ \xo 12:16 \xt 2سام. 20‏:1\x*   
\m
\v 17 ئەمما يەھۇدا شەھەرلىرىدە ئولتۇرغان ئىسرائىللارغا بولسا، يەروبوئام ئۇلارنىڭ ئۈستىگە ھۆكۈم سۈردى. \f ◼ \fr 12:17 \ft \+bd «يەھۇدا شەھەرلىرىدە ئولتۇرغان ئىسرائىللار»\+bd* ــ بۇلارنىڭ كۆپىنچىسى يەھۇدا ۋە بىنيامىن قەبىلىلىرىدىن بولغان.\f*  
\v 18 رەھوبوئام پادىشاھ باج-ئالۋان بېگى ئادورامنى ئىسرائىللارغا ئەۋەتتى، لېكىن پۈتكۈل ئىسرائىل ئۇنى چالما-كېسەك قىلىپ ئۆلتۈردى. ئۇ چاغدا رەھوبوئام پادىشاھ ئالدىراپ، ئۆزىنىڭ جەڭ ھارۋىسىغا چىقىپ، يېرۇسالېمغا تىكىۋەتتى. \x ◘ \xo 12:18 \xt 1پاد. 4‏:6؛ 5‏:14\x*   
\m
\v 19 شۇ تەرىقىدە ئىسرائىل داۋۇتنىڭ جەمەتىدىن يۈز ئۆرۈپ، بۈگۈنگە قەدەر ئۇنىڭغا قارشى چىقىپ كەلدى. \f ◼ \fr 12:19 \ft \+bd «شۇ تەرىقىدە ئىسرائىل داۋۇتنىڭ جەمەتىدىن يۈز ئۆرۈپ، ... ئۇنىڭغا قارشى چىقىپ كەلدى»\+bd* ــ بۇ تارىختا مۇشۇ يەردىن باشلاپ «ئىسرائىل» دېگەن سۆز ئادەتتە «شىمالىي پادىشاھلىق»، يەنى «ئون قەبىلە»نى كۆرسىتىدۇ.\f*  \x ◘ \xo 12:19 \xt 2پاد. 17‏:21\x*  
\v 20 ئىسرائىلنىڭ ھەممىسى يەروبوئامنىڭ يېنىپ كەلگەنلىكىنى ئاڭلىغاندا، ئادەم ئەۋەتىپ ئۇنى خەلقنىڭ جامائىتىگە چاقىردى. ئۇلار ئۇنى پۈتكۈل ئىسرائىلنىڭ ئۈستىگە رەسمىي پادىشاھ قىلدى. يەھۇدا قەبىلىسىدىن باشقا ھېچكىم داۋۇتنىڭ جەمەتىگە ئەگەشمىدى.   
\m
\v 21 رەھوبوئام يېرۇسالېمغا قايتىپ كېلىپ، ئىسرائىلنىڭ جەمەتى بىلەن جەڭ قىلىپ، پادىشاھلىقنى سۇلايماننىڭ ئوغلى بولغان ئۆزىگە قايتۇرۇپ ئەكىلىش ئۈچۈن يەھۇدانىڭ پۈتكۈل جەمەتىدىن ۋە بىنيامىن قەبىلىسىدىن بىر يۈز سەكسەن مىڭ خىللانغان جەڭگىۋار ئەسكەرنى توپلىدى. \x ◘ \xo 12:21 \xt 2تار. 11‏:1\x*   
\m
\v 22 لېكىن خۇدانىڭ سۆزى خۇدانىڭ ئادىمى شېماياغا كېلىپ مۇنداق دېگەندە: ــ \x ◘ \xo 12:22 \xt 2تار. 11‏:2\x*   
\m
\v 23 «يەھۇدانىڭ پادىشاھى، سۇلايماننىڭ ئوغلى رەھوبوئامغا، پۈتۈن يەھۇدا بىلەن بىنيامىننىڭ جەمەتىگە ۋە خەلقنىڭ قالغانلىرىغا سۆز قىلىپ: ــ  
\v 24 «پەرۋەردىگار مۇنداق دەيدۇ: ــ ھۇجۇمغا چىقماڭلار، قېرىنداشلىرىڭلار ئىسرائىللار بىلەن جەڭ قىلماڭلار؛ ھەربىرىڭلار ئۆز ئۆيۈڭلارغا قايتىپ كېتىڭلار؛ چۈنكى بۇ ئىش مەندىندۇر»، دېگىن».  
\m ئۇلار پەرۋەردىگارنىڭ سۆزىگە قۇلاق سالدى. پەرۋەردىگارنىڭ سۆزى بويىچە ئۇلار ئۆيلىرىگە قايتىپ كەتتى. \fig ئىسرائىل» ۋە «يەھۇدا» دېگەن ئىككى پادىشاھلىق (بىر-بىرىدىن بۆلۈنگەن)|src="dividedkingdom-uara-01.jpg" size="span" ref="«1 پاد.» 12»" \fig*   
\b  
\m  
\s1 يەروبوئام ئالتۇن موزايلارنى ياسايدۇ  
\m
\v 25 يەروبوئام بولسا ئەفرائىم تاغلىقىدىكى شەقەم شەھىرىنى ياساپ شۇ يەردە تۇردى؛ كېيىن ئۇ يەردىن چىقىپ پەنۇئەلنى ياسىدى. \x ◘ \xo 12:25 \xt مىس. 32‏:30\x*  
\v 26 رەھوبوئام كۆڭلىدە ئۆز-ئۆزىگە: ــ ئەمدى پادىشاھلىق داۋۇتنىڭ جەمەتىگە يېنىشى مۇمكىن.  
\v 27 ئەگەر بۇ خەلق پەرۋەردىگارنىڭ ئۆيىدە قۇربانلىق قىلىشقا يېرۇسالېمغا چىقسا، بۇ خەلقنىڭ قەلبى ئۆز غوجىسى، يەنى يەھۇدا پادىشاھى رەھوبوئامغا يەنە مايىل بولىدۇ، ئاندىن ئۇلار مېنى ئۆلتۈرۈپ يەنە يەھۇدا پادىشاھى رەھوبوئامنىڭ تەرىپىگە يانارمىكىن، دېدى.  
\v 28 پادىشاھ مەسلىھەت سوراپ، ئالتۇندىن ئىككى موزاي ھەيكىلىنى ياسىتىپ خەلققە: ــ يېرۇسالېمغا چىقىش سىلەرگە ئېغىر كېلىدۇ. ئى ئىسرائىل، مانا سىلەرنى مىسىر زېمىنىدىن چىقارغان ئىلاھلار! ــ دېدى. \x ◘ \xo 12:28 \xt مىس. 32‏:8؛ 2پاد. 17‏:16\x*   
\m
\v 29 بىرىنى ئۇ بەيت-ئەلدە، يەنە بىرىنى داندا تۇرغۇزۇپ قويدى.  
\v 30 بۇ ئىش گۇناھقا سەۋەب بولدى، چۈنكى خەلق موزايلىرىنىڭ بىرىنىڭ ئالدىدا باش ئۇرغىلى ھەتتا دانغىچە باراتتى.   
\m
\v 31 ئۇ ھەم «ئېگىز جايلار»دا \add ئىبادەت\add* ئۆيلىرىنى ياسىدى ۋە ھەم لاۋىيدىن بولمىغان ئادەملەرنى كاھىن قىلىپ تەيىنلەپ قويدى. \f ◼ \fr 12:31 \ft \+bd «ئۇ ھەم ... ئىبادەت ئۆيلىرىنى ياسىدى»\+bd* ــ ياكى «ئۇ ھەم ئىبادەت ئۆيىنى ياسىدى». ئەمما 32-ئايەتنى كۆرۈڭ.\f*  \x ◘ \xo 12:31 \xt چۆل. 3‏:10؛ 1پاد. 13‏:33؛ 2پاد. 17‏:32؛ 2تار. 11‏:15\x*   
\m
\v 32 يەروبوئام يەنە سەككىزىنچى ئاينىڭ ئون بەشىنچى كۈنىنى خۇددى يەھۇدانىڭ زېمىنىدىكى ھېيتكە ئوخشاش بىر ھېيت قىلىپ بېكىتتى. ئۇ ئۆزى قۇربانگاھ ئۈستىگە قۇربانلىق قىلغىلى چىقتى. شۇنداق قىلىپ ئۇ بەيت-ئەلدە ئۆزى ئەتكۈزگەن موزاي مەبۇدلىرىگە قۇربانلىق ئۆتكۈزدى. ئۇ يەنە بەيت-ئەلدە سالدۇرغان شۇ «ئېگىز جايلار» ئۈچۈن كاھىنلارنى تەيىنلىدى. \f ◼ \fr 12:32 \ft \+bd «يەھۇدانىڭ زېمىنىدىكى ھېيت»\+bd* ــ مۇشۇ يەردە «ھېيت» يەتتىنچى ئاينىڭ ئون بەشىنچى كۈنىدە ئۆتكۈزۈلگەن «ئورما ھېيتى» ياكى «كەپىلەر ھېيتى» ئىدى.\f*  
\v 33 ئۇ بەيت-ئەلدە ياسىغان قۇربانگاھ ئۈستىگە سەككىزىنچى ئاينىڭ ئون بەشىنچى كۈنى (بۇ ئاي-كۈننى ئۇ ئۆز مەيلىچە تاللىغانىدى) قۇربانلىقلارنى سۇنۇشقا چىقتى؛ شۇ تەرىقىدە ئۇ ئىسرائىللارغا بىر ھېيت ياراتتى؛ ئۇ ئۆزى قۇربانگاھ ئۈستىگە قۇربانلىقلارنى سۇندى ۋە خۇشبۇي ياقتى. \f ◼ \fr 12:33 \ft \+bd «\+bdit يەروبوئام\+bdit* ئۆزى قۇربانگاھ ئۈستىگە قۇربانلىقلارنى سۇندى ۋە خۇشبۇي ياقتى»\+bd* ــ مۇشۇنداق ئىشلارنى پەقەت لاۋىي قەبىلىسى، ھارۇننىڭ جەمەتىدىن بولغانلار، يەنى ھەقىقىي كاھىنلار قىلىشقا بولاتتى، ئەلۋەتتە.\f*   
\b  
\b  
\m  
\c 13
\s1 نامسىز بىر پەيغەمبەر بەيت-ئەل توغرۇلۇق بېشارەت بېرىدۇ  
\m
\v 1 ۋە مانا، پەرۋەردىگارنىڭ بۇيرۇقى بىلەن خۇدانىڭ بىر ئادىمى يەھۇدادىن چىقىپ بەيت-ئەلگە كەلدى؛ شۇ پەيتتە يەروبوئام خۇشبۇي يېقىشقا قۇربانگاھنىڭ يېنىدا تۇراتتى؛  
\v 2 شۇ ئادەم قۇربانگاھغا قاراپ پەرۋەردىگارنىڭ ئەمرى بىلەن چاقىرىپ: ــ ئى قۇربانگاھ، ئى قۇربانگاھ! پەرۋەردىگار مۇنداق دەيدۇ: ــ مانا داۋۇتنىڭ جەمەتىدە يوسىيا ئىسىملىك بىر ئوغۇل تۇغۇلىدۇ. ئۇ بولسا سېنىڭ ئۈستۈڭدە خۇشبۇي ياققان «يۇقىرى جايلار»دىكى كاھىنلارنى سويۇپ قۇربانلىق قىلىدۇ؛ شۇنداقلا سېنىڭ ئۈستۈڭدە ئادەم سۆڭەكلىرى كۆيدۈرۈلىدۇ! ــ دېدى. \f ◼ \fr 13:2 \ft \+bd «سېنىڭ ئۈستۈڭدە ئادەم سۆڭەكلىرى كۆيدۈرۈلىدۇ»\+bd* ــ مۇشۇ ھەرىكەت بۇ قۇربانگاھنى «ناپاك» ياكى «ھارام» قىلىۋەتكەن بولاتتى.\f*  \x ◘ \xo 13:2 \xt 2پاد. 23‏:15-20\x*   
\m
\v 3 ئۇ كۈنى ئۇ بىر بېشارەتلىك ئالامەتنى جاكارلاپ: پەرۋەردىگارنىڭ مۇشۇ سۆزىنى ئىسپاتلايدىغان ئالامەت شۇ بولىدۇكى: ــ مانا، قۇربانگاھ يېرىلىپ، ئۈستىدىكى كۈللەر تۆكۈلۈپ كېتىدۇ، ــ دېدى.   
\m
\v 4 ۋە شۇنداق بولدىكى، يەروبوئام پادىشاھ خۇدانىڭ ئادىمىنىڭ بەيت-ئەلدىكى قۇربانگاھقا قاراپ جاكارلىغان سۆزىنى ئاڭلىغاندا، ئۇ قۇربانگاھتا تۇرۇپ قولىنى سوزۇپ: ــ ئۇنى تۇتۇڭلار، دېدى. لېكىن ئۇنىڭغا قارىتىپ سوزغان قولى شۇنىڭ بىلەن شۇ پېتى قۇرۇپ كەتتى، ئۇنى ئۆزىگە يەنە يىغالمىدى.  
\v 5 ئاندىن خۇدانىڭ ئادىمى پەرۋەردىگارنىڭ سۆزى بىلەن ئېيتقان مۆجىزىلىك ئالامەت يۈز بېرىپ، قۇربانگاھ ھەم يېرىلىپ ئۈستىدىكى كۈللەر تۆكۈلۈپ كەتتى.  
\v 6 پادىشاھ خۇدانىڭ ئادىمىدىن: ــ پەرۋەردىگار خۇدايىڭدىن مېنىڭ ھەققىمدە ئۆتۈنگەيسەنكى، قولۇمنى ئەسلىگە كەلتۈرگەي، دەپ يالۋۇردى. خۇدانىڭ ئادىمى پەرۋەردىگارنىڭ ئىلتىپاتىنى ئۆتۈنگىنىدە، پادىشاھنىڭ قولى يەنە ئۆزىگە يىغىلىپ ئەسلىگە كەلتۈرۈلدى. \x ◘ \xo 13:6 \xt مىس. 8‏:4؛ 9‏:28؛ 10‏:17؛ چۆل. 21‏:7؛ روس. 8‏:24\x*   
\m
\v 7 پادىشاھ خۇدانىڭ ئادىمىگە: ــ مېنىڭ بىلەن ئۆيۈمگە بېرىپ ئۆزۈڭنى قۇتلاندۇرغىن، مەن ساڭا ئىنئام بېرەي، دېدى.   
\m
\v 8 لېكىن خۇدانىڭ ئادىمى پادىشاھقا جاۋاب بېرىپ: ــ سەن ماڭا ئورداڭنىڭ يېرىمىنى بەرسەڭمۇ، سېنىڭ بىلەن بارمايمەن ياكى بۇ يەردە نان يەپ سۇ ئىچمەيمەن. \x ◘ \xo 13:8 \xt چۆل. 22‏:18\x*  
\v 9 چۈنكى پەرۋەردىگار ئۆز سۆزىنى يەتكۈزۈپ ماڭا بۇيرۇپ: «سەن نە نان يېمە نە سۇ ئىچمە، بارغان يولۇڭ بىلەن قايتىپ كەلمە» دېگەن، دېدى. \f ◼ \fr 13:9 \ft \+bd «چۈنكى پەرۋەردىگار ئۆز سۆزىنى يەتكۈزۈپ ماڭا بۇيرۇپ ... »\+bd* ــ ئىبرانىي تىلىدا: «چۈنكى پەرۋەردىگارنىڭ سۆزى بىلەن ماڭا مۇنداق بۇيرۇلدى».\f*   
\m
\v 10 شۇنىڭ بىلەن ئۇ بەيت-ئەلگە كەلگەن يول بىلەن ئەمەس، بەلكى باشقا بىر يول بىلەن قايتىپ كەتتى.   
\m
\v 11 لېكىن بەيت-ئەلدە ياشانغان بىر پەيغەمبەر تۇراتتى. ئۇنىڭ ئوغۇللىرى كېلىپ خۇدانىڭ ئادىمىنىڭ ئۇ كۈنى بەيت-ئەلدە قىلغان بارلىق ئەمەللىرىنى ئۇنىڭغا دەپ بەردى، شۇنداقلا ئۇنىڭ پادىشاھقا قىلغان سۆزلىرىنىمۇ ئاتىسىغا ئېيتىپ بەردى.   
\m
\v 12 ئاتىسى ئۇلاردىن، ئۇ قايسى يول بىلەن كەتتى، دەپ سورىدى؛ چۈنكى ئوغۇللىرى يەھۇدادىن كەلگەن خۇدانىڭ ئادىمىنىڭ قايسى يول بىلەن كەتكىنىنى كۆرگەنىدى. \f ◼ \fr 13:12 \ft \+bd «...چۈنكى ئوغۇللىرى ... قايسى يول بىلەن كەتكىنىنى كۆرگەنىدى»\+bd* ــ ياكى، «ئاندىن ئوغۇللىرى ... قايسى يول بىلەن كەتكىنىنى ئۇنىڭغا كۆرسەتتى».\f*   
\m
\v 13 ئۇ ئوغۇللىرىغا: ــ ماڭا ئېشەكنى توقۇپ بېرىڭلار، دەپ تاپىلىدى. ئۇلار ئۇنىڭغا ئېشەكنى توقۇپ بەرگەندە ئۇ ئۇنىڭغا مىنىپ  
\v 14 خۇدانىڭ ئادىمىنىڭ كەينىدىن قوغلاپ كەتتى. ئۇ ئۇنى بىر دۇب دەرىخىنىڭ ئاستىدا ئولتۇرغان يېرىدىن تېپىپ ئۇنىڭدىن: ــ يەھۇدادىن كەلگەن خۇدانىڭ ئادىمى سەنمۇ؟ ــ دەپ سورىدى. ئۇ: ــ مەن شۇ، دەپ جاۋاب بەردى.   
\m
\v 15 ئۇ ئۇنىڭغا: ــ مېنىڭ بىلەن ئۆيۈمگە بېرىپ نان يېگىن، دېدى. \f ◼ \fr 13:15 \ft \+bd «ئۆيۈمگە بېرىپ نان يېگىن»\+bd* ــ «نان يېگىن» ئۇيغۇرلارنىڭ «چاي ئىچىڭ» دېگىنىدەك، «تاماق يېگىن» دېگەن مەنىدە.\f*   
\m
\v 16 ئۇ جاۋابەن: ــ مەن نە سېنىڭ بىلەن قايتالمايمەن، نە سېنىڭكىگە كىرەلمەيمەن؛ مەن نە بۇ يەردە سېنىڭ بىلەن نان يەپ سۇ ئىچەلمەيمەن؛  
\v 17 چۈنكى پەرۋەردىگار ئۆز سۆزى بىلەن ماڭا تاپىلاپ: «ئۇ يەردە نان يېمە، سۇ ئىچمىگىن؛ بارغان يولۇڭ بىلەن قايتىپ كەلمىگىن» دېگەن، دېدى. \f ◼ \fr 13:17 \ft \+bd « چۈنكى پەرۋەردىگار ئۆز سۆزى بىلەن ماڭا تاپىلاپ: «...» دېگەن، دېدى»\+bd* ــ ئىبرانىي تىلىدا « چۈنكى پەرۋەردىگارنىڭ سۆزى بىلەن ماڭا تاپىلاپ: «...» دېيىلگەن، دېدى»\f*   
\m
\v 18 \add قېرى پەيغەمبەر\add* ئۇنىڭغا: ــ مەن ھەم سەندەك بىر پەيغەمبەردۇرمەن؛ ۋە بىر پەرىشتە پەرۋەردىگارنىڭ سۆزىنى ماڭا يەتكۈزۈپ: ــ «ئۇنىڭغا نان يېگۈرۈپ، سۇ ئىچكۈزگىلى ئۆزۈڭ بىلەن ئۆيۈڭگە ياندۇرۇپ كەل» دېدى، دەپ ئېيتتى. لېكىن ئۇ شۇنى دەپ ئۇنىڭغا يالغان ئېيتىۋاتاتتى. \f ◼ \fr 13:18 \ft \+bd «بىر پەرىشتە پەرۋەردىگارنىڭ سۆزىنى ماڭا يەتكۈزۈپ: ــ «...» دېدى،...»\+bd* ــ ئىبرانىي تىلىدا « بىر پەرىشتە پەرۋەردىگارنىڭ سۆزى بىلەن ماڭا تاپىلاپ: ــ «...» دېدى،...»\f*  \x ◘ \xo 13:18 \xt گال. 1‏:8\x*   
\m
\v 19 شۇنىڭ بىلەن \add خۇدانىڭ ئادىمى\add* ئۇنىڭ بىلەن يېنىپ ئۆيدە نان يەپ سۇ ئىچتى.  
\v 20 لېكىن ئۇلار داستىخاندا ئولتۇرغىنىدا، پەرۋەردىگارنىڭ سۆزى ئۇنى ياندۇرۇپ ئەكەلگەن قېرى پەيغەمبەرگە كەلدى.  
\v 21 ئۇ يەھۇدادىن كەلگەن خۇدانىڭ ئادىمىنى چاقىرىپ: ــ پەرۋەردىگار مۇنداق دەيدۇ: ــ «سەن پەرۋەردىگارنىڭ سۆزىگە ئىتائەتسىزلىك قىلىپ، پەرۋەردىگار خۇدايىڭنىڭ بۇيرۇغان ئەمرىنى تۇتماي،  
\v 22 بەلكى يېنىپ، ئۇ ساڭا: ــ نان يېمە، سۇ ئىچمە، دەپ مەنئى قىلغان يەردە نان يەپ سۇ ئىچكىنىڭ تۈپەيلىدىن، جەسىتىڭ ئاتا-بوۋىلىرىڭنىڭ قەبرىسىدە كۆمۈلمەيدۇ»، دەپ توۋلىدى.   
\m
\v 23 ۋە شۇنداق بولدىكى، خۇدانىڭ ئادىمى نان يەپ سۇ ئىچىپ بولغاندا، ئۇنىڭغا، يەنى ئۆزى ياندۇرۇپ ئەكەلگەن پەيغەمبەرگە ئېشەكنى توقۇپ بەردى.  
\v 24 ئۇ يولغا چىقتى. كېتىۋاتقىنىدا، يولدا ئۇنىڭغا بىر شىر ئۇچراپ، ئۇنى ئۆلتۈرۈۋەتتى. شۇنىڭ بىلەن ئۇنىڭ جەسىتى يولدا تاشلىنىپ قالدى، ئېشىكى بولسا ئۇنىڭ يېنىدا تۇراتتى؛ شىرمۇ جەسەتنىڭ يېنىدا تۇراتتى. \x ◘ \xo 13:24 \xt 1پاد. 20‏:36\x*   
\m
\v 25 مانا بىرنەچچە ئادەم ئۆتۈپ كېتىۋېتىپ، يولدا تاشلىنىپ قالغان جەسەت بىلەن جەسەتنىڭ يېنىدا تۇرغان شىرنى كۆردى؛ ئۇلار قېرى پەيغەمبەر تۇرغان شەھەرگە كېلىپ ئۇ يەردە شۇ خەۋەرنى يەتكۈزدى.  
\v 26 ئۇنى يولدىن ياندۇرغان پەيغەمبەر بۇنى ئاڭلاپ: ــ ئۇ دەل پەرۋەردىگارنىڭ سۆزىگە ئىتائەتسىزلىك قىلغان خۇدانىڭ ئادىمىدۇر. شۇڭا پەرۋەردىگار ئۇنى شىرغا تاپشۇردى؛ پەرۋەردىگار ئۇنىڭغا قىلغان سۆزى بويىچە شىر ئۇنى تىتما-تىتما قىلىپ ئۆلتۈردى، دېدى.   
\m
\v 27 ئۇ ئوغۇللىرىغا: ــ ماڭا ئېشەكنى توقۇپ بېرىڭلار، دېدى؛ ئۇلار ئۇنى توقۇپ بەردى.   
\m
\v 28 ئۇ يولدا تاشلاقلىق جەسەت بىلەن جەسەتنىڭ يېنىدا تۇرغان ئېشەك ۋە شىرنى تاپتى. شىر بولسا نە جەسەتنى يېمىگەنىدى نە ئېشەكنىمۇ تالىمىغانىدى.  
\v 29 پەيغەمبەر خۇدانىڭ ئادىمىنىڭ جەسىتىنى ئېلىپ ئېشەككە ئارتىپ ياندى. قېرى پەيغەمبەر ئۇنىڭ ئۈچۈن ماتەم تۇتۇپ ئۇنى دەپنە قىلغىلى شەھەرگە كىردى.  
\v 30 ئۇ جەسەتنى ئۆز قەبرىستانلىقىدا قويدى. ئۇلار ئۇنىڭ ئۈچۈن ماتەم تۇتۇپ: ــ ئاھ بۇرادىرىم! ــ دەپ پەرياد كۆتۈردى.   
\m
\v 31 ئۇنى دەپنە قىلغاندىن كېيىن ئۇ ئۆز ئوغۇللىرىغا: ــ مەن ئۆلگەندە مېنى خۇدانىڭ ئادىمى دەپنە قىلىنغان گۆرگە دەپنە قىلىڭلار؛ مېنىڭ سۆڭەكلىرىمنى ئۇنىڭ سۆڭەكلىرىنىڭ يېنىدا قويۇڭلار؛  
\v 32 چۈنكى ئۇ پەرۋەردىگارنىڭ بۇيرۇقى بىلەن بەيت-ئەلدىكى قۇربانگاھقا قارىغان ۋە سامارىيەدىكى شەھەرلەرنىڭ «يۇقىرى جاي»لىرىدىكى \add ئىبادەت\add* ئۆيلىرىگە قارىغان، ئۇنىڭ جار قىلغان سۆزى ئەمەلگە ئاشۇرۇلماي قالمايدۇ، ــ دېدى. \f ◼ \fr 13:32 \ft \+bd «چۈنكى \+bdit پەيغەمبەر\+bdit* پەرۋەردىگارنىڭ بۇيرۇقى بىلەن ... جار قىلغان سۆزى ئەمەلگە ئاشۇرۇلماي قالمايدۇ، ــ دېدى»\+bd* ــ بۇ سىرلىق ۋەقە ئۈستىدە «قوشۇمچە سۆز»ىمىزدە توختىلىمىز.\f*  \x ◘ \xo 13:32 \xt 2پاد. 23‏:16\x*   
\m
\v 33 لېكىن يەروبوئام بۇ ۋەقەدىن كېيىنمۇ ئۆز رەزىل يولىدىن يانماي، بەلكى «يۇقىرى جايلار»غا ھەرخىل خەلقتىن كاھىنلارنى تەيىنلىدى؛ كىم خالىسا، ئۇ شۇنى «مۇقەددەس قىلىپ» \add كاھىنلىق مەنسىپىگە\add* بېغىشلايتتى؛ شۇنىڭ بىلەن ئۇلار «يۇقىرى جايلار»دا \add قۇربانلىق قىلىشقا\add* كاھىن بولاتتى. \f ◼ \fr 13:33 \ft \+bd «...ئۇ شۇنى «مۇقەددەس قىلىپ» كاھىنلىق مەنسىپىگە بېغىشلايتتى»\+bd* ــ مۇشۇ يەردە «مۇقەددەس قىلىپ» (كاھىنلىق مەنسىپىگە بېغىشلاش») ئىنتايىن كىنايىلىك گەپ. خۇداغا كاھىن بولۇش ئۈچۈن «مۇقەددەس قىلىپ خۇداغا ئاتىلىشى» كېرەك ئىدى. لېكىن مۇشۇ يەردە مۇشۇ «كاھىنلار» بۇتلارغا ئاتىلىدۇ.\f*  \x ◘ \xo 13:33 \xt 1پاد. 12‏:31، 32\x*  
\v 34 شۇ ئىش تۈپەيلىدىن يەروبوئام جەمەتىنىڭ ھېسابىغا گۇناھ بولۇپ، ئۇلارنىڭ يەر يۈزىدىن ئۈزۈپ ئېلىنىپ ھالاك بولۇشىغا سەۋەب بولدى.   
\b  
\b  
\m  
\c 14
\s1 خۇدا يەنە يەروبوئامنى ئاگاھلاندۇرىدۇ  
\m
\v 1 ئۇ ۋاقىتتا يەروبوئامنىڭ ئوغلى ئابىياھ كېسەل بولۇپ قالدى.  
\v 2 يەروبوئام ئايالىغا: ــ ئورنۇڭدىن قوپۇپ، ھېچكىم سېنىڭ يەروبوئامنىڭ ئايالى ئىكەنلىكىڭنى تونۇمىغۇدەك قىلىپ ئۆز قىياپىتىڭنى ئۆزگەرتىپ، شىلوھقا بارغىن. مانا ماڭا: «بۇ خەلقنىڭ ئۈستىدە پادىشاھ بولىسەن» دەپ ئېيتقان ئاخىياھ پەيغەمبەر ئۇ يەردە ئولتۇرىدۇ. \x ◘ \xo 14:2 \xt 1پاد. 11‏:31\x*  
\v 3 قولۇڭغا ئون نان، بىرنەچچە پوشكال، بىر قۇتا ھەسەلنى ئېلىپ ئۇنىڭ قېشىغا بارغىن. ئۇ يىگىتىمىزنىڭ نېمە بولىدىغانلىقىنى ساڭا دەپ بېرىدۇ، دېدى.   
\m
\v 4 يەروبوئامنىڭ ئايالى شۇنداق قىلىپ، شىلوھقا بېرىپ ئاخىياھنىڭ ئۆيىگە كەلدى. ئاخىياھنىڭ كۆزلىرى قېرىلىقتىن كور بولۇپ كۆرەلمەيتتى.  
\v 5 لېكىن پەرۋەردىگار ئاخىياھقا: ــ مانا، يەروبوئامنىڭ ئايالى ئۆز ئوغلى توغرىسىدا سەندىن سورىغىلى كېلىدۇ، چۈنكى ئۇ كېسەلدۇر. ئۇنىڭغا مۇنداق-مۇنداق دېگىن؛ چۈنكى ئۇ كەلگەندە باشقا قىياپەتكە كىرىۋالغان بولىدۇ، دەپ ئېيتقانىدى.   
\m
\v 6 ئۇ ئىشىكتىن كىرگەندە ئاخىياھ ئاياغ تىۋىشىنى ئاڭلاپ مۇنداق دېدى: ــ «ھەي، يەروبوئامنىڭ ئايالى، كىرگىن؛ نېمىشقا باشقا قىياپەتكە كىرىۋالدىڭ؟ ساڭا بىر شۇم خەۋەرنى بېرىش ماڭا بۇيرۇلدى. \f ◼ \fr 14:6 \ft \+bd «ساڭا بىر شۇم خەۋەرنى بېرىش ماڭا بۇيرۇلدى»\+bd* ــ «ماڭا بۇيرۇلدى» دېگەنلىك ئىبرانىي تىلىدا: «مەن ئەۋەتىلدىم» دېگەن بىلەن ئىپادىلىنىدۇ.\f*  
\v 7 بېرىپ يەروبوئامغا مۇنداق دېگىن: ــ «ئىسرائىلنىڭ خۇداسى پەرۋەردىگار مۇنداق دەيدۇ: ــ «مەن سېنى خەلقنىڭ ئارىسىدىن ئېلىپ كۆتۈرۈپ، ئۆز خەلقىم ئىسرائىلغا ھۆكۈمران قىلىپ \x ◘ \xo 14:7 \xt 1پاد. 12‏:15\x*  
\v 8 پادىشاھلىقنى داۋۇتنىڭ جەمەتىدىن يىرتىۋېتىپ، ساڭا بەردىم؛ لېكىن سەن مېنىڭ ئەمرلىرىمنى تۇتۇپ، نەزىرىمدە پەقەت دۇرۇس بولغاننىلا قىلىشتا پۈتۈن قەلبىدىن ماڭا ئەگەشكەن قۇلۇم داۋۇتقا ئوخشاش بولمىدىڭ،  
\v 9 بەلكى ئۆزۈڭدىن ئىلگىرى كەلگەنلەرنىڭ ھەممىسىدىن ئارتۇق رەزىللىك قىلىپ، مېنىڭ غەزىپىمنى قوزغاپ، مېنى ئارقاڭغا تاشلاپ، بېرىپ ئۆزۈڭگە غەيرىي ئىلاھلارنى، قۇيما مەبۇدلارنى ياساتتىڭ.  
\v 10 شۇنىڭ ئۈچۈن مەن يەروبوئامنىڭ جەمەتىگە بالا چۈشۈرۈپ، يەروبوئامنىڭ ئىسرائىلدىكى خاندانىدىن ھەممە ئەركەكنى، ھەتتا ئاجىز ياكى مېيىپ بولسىمۇ ھەممىسىنى ئۈزۈپ تاشلايمەن، ئادەملەر پوق-تېزەكلەرنى سۈپۈرگەندەك يەروبوئامنىڭ جەمەتىدىن قالغىنىنى يوق بولغۇچە سۈپۈرىمەن. \f ◼ \fr 14:10 \ft \+bd «ھەممە ئەركەك»\+bd* ــ ئىبرانىي تىلىدا: «تامغا قاراپ سىيىدىغان ھەربىرى» دېگەنلىك بىلەن ئىپادىلىنىدۇ. \+bd «...ھەتتا ئاجىز ياكى مېيىپ بولسىمۇ ھەممىسىنى ئۈزۈپ تاشلايمەن»\+bd* ــ باشقا بىرخىل تەرجىمىسى: «... ياكى كىچىك ياكى چوڭ بولسا، ھەممىسىنى تاشلايمەن». \+bd «ئادەملەر پوق-تېزەكلەرنى سۈپۈرگەندەك ... يوق بولغۇچە سۈپۈرىمەن»\+bd* ــ ياكى «ئادەملەر تېزەك كۆيدۈرگەندەك ... يوق بولغۇچە كۆيدۈرۈۋېتىمەن».\f*  \x ◘ \xo 14:10 \xt 1سام. 25‏:22، 34؛ 1پاد. 15‏:29؛ 16‏:11؛ 21‏:21؛ 2پاد. 9‏:8\x*   
\m
\v 11 يەروبوئامدىن بولغانلاردىن شەھەردە ئۆلگىنىنى ئىتلار يەيدۇ؛ سەھرادا ئۆلگىنىنى ئاسماندىكى قۇشلار يەيدۇ. چۈنكى پەرۋەردىگار شۇنداق سۆز قىلغاندۇر.  
\v 12 ئەمدى سەن بولساڭ، قوپۇپ ئۆز ئۆيۈڭگە بارغىن؛ ئايىغىڭ شەھەرگە كىرگەن ھامان، بالا ئۆلىدۇ.  
\v 13 پۈتۈن ئىسرائىل ئۇنىڭ ئۈچۈن ماتەم تۇتۇپ ئۇنى دەپنە قىلىدۇ. چۈنكى يەروبوئامنىڭ جەمەتىدىن قەبرىگە قويۇلىدىغان يالغۇز شۇلا بولىدۇ؛ چۈنكى يەروبوئامنىڭ جەمەتىنىڭ ئارىسىدا ئىسرائىلنىڭ خۇداسى پەرۋەردىگارنىڭ ئالدىدا پەقەت شۇنىڭدا پەزىلەت تېپىلدى.   
\m
\v 14 ئەمدى پەرۋەردىگار ئۆزىگە يەروبوئامنىڭ جەمەتىنى ئۈزۈپ تاشلايدىغان، ئىسرائىلنىڭ ئۈستىگە ھۆكۈم سۈرىدىغان بىر پادىشاھنى تىكلەيدۇ. دەرھەقىقەت، ئۇ پات ئارىدا بولىدۇ! \x ◘ \xo 14:14 \xt 1پاد. 15‏:28، 29\x*  
\v 15 پەرۋەردىگار ئىسرائىلنى ئۇرۇپ، خۇددى سۇدا لىڭشىپ قالغان قۇمۇشتەك قىلىپ قويىدۇ، ئاتا-بوۋىلىرىغا تەقدىم قىلغان بۇ ياخشى زېمىندىن قومۇرۇپ، ئۇلارنى \add ئەفرات\add* دەرياسىنىڭ ئۇ تەرىپىگە تارقىتىدۇ؛ چۈنكى ئۇلار ئۆزىگە «ئاشەراھ بۇتلار»نى ياساپ پەرۋەردىگارنىڭ غەزىپىنى قوزىغىدى. \f ◼ \fr 14:15 \ft \+bd «ئاشەراھ بۇتلار»\+bd* ــ بەلكىم بۇتپەرەسلىككە بېغىشلانغان دەرەخلىكلەردۇر. دەرەخلەر بەلكىم ئايال بۇت شەكلىدە ئويۇلغان ياكى نەقىشلەنگەن بولۇشى مۇمكىن ئىدى.\f*  \x ◘ \xo 14:15 \xt 2پاد. 17‏:18\x*  
\v 16 يەروبوئامنىڭ سادىر قىلغان گۇناھلىرى تۈپەيلىدىن، ئۇنىڭ ئىسرائىلنى گۇناھ قىلدۇرغىنى تۈپەيلىدىن، خۇدا ئىسرائىلنى تاشلاپ بېرىدۇ!»».   
\m
\v 17 شۇنىڭ بىلەن يەروبوئامنىڭ ئايالى قوپۇپ، يولغا چىقىپ تىرزاھقا قايتىپ كەلدى. ئۇ ئۆيىنىڭ بوسۇغىسىدىن ئاتلىشىغا بالا ئۆلدى.  
\v 18 ئۇلار ئۇنى دەپنە قىلدى. پەرۋەردىگارنىڭ ئۆز قۇلى ئاخىياھ پەيغەمبەر ئارقىلىق ئېيتقان سۆزىدەك، پۈتۈن ئىسرائىل ئۇنىڭ ئۈچۈن ماتەم تۇتتى.   
\m
\v 19 ئەمدى يەروبوئامنىڭ باشقا ئىشلىرى، يەنى جەڭلىرى ۋە قانداق سەلتەنەت قىلغانلىرى توغرىسىدا مانا، «ئىسرائىل پادىشاھلىرىنىڭ تارىخ-تەزكىرىلىرى» دېگەن كىتابتا پۈتۈلگەندۇر. \f ◼ \fr 14:19 \ft \+bd «ئىسرائىل پادىشاھلىرىنىڭ تارىخ-تەزكىرىلىرى»\+bd* ــ بۇ كىتاب تەۋراتتىكى «تارىخ-تەزكىرە» دېگەن كىتاب ئەمەس، بىراق شۈبھىسىزكى، تەۋراتتىكى «تارىخ-تەزكىرە»نىڭ مۇئەللىپلىرى ئۇنىڭدىن كۆپ ئۇچۇرلارنى ئالغانىدى.\f*  
\v 20 يەروبوئامنىڭ سەلتەنەت قىلغان ۋاقتى يىگىرمە ئىككى يىل بولۇپ، ئۇ ئۆز ئاتا-بوۋىلىرىنىڭ ئارىسىدا ئۇخلىدى. ئوغلى ناداب ئۇنىڭ ئورنىدا ھۆكۈم سۈردى.   
\b  
\m  
\s1 رەھوبوئامنىڭ سەلتەنىتى  
\r 2تار. 12‏:1-16  
\m
\v 21 ۋە سۇلايماننىڭ ئوغلى رەھوبوئام بولسا يەھۇدانىڭ ئۈستىگە ھۆكۈم سۈردى. رەھوبوئام پادىشاھ بولغاندا قىرىق بىر ياشقا كىرگەنىدى؛ ئۇ پەرۋەردىگارنىڭ ئۆز نامىنى ئايان قىلىش ئۈچۈن، ئىسرائىلنىڭ ھەممە قەبىلىلىرى ئارىسىدىن تاللىغان يېرۇسالېم شەھىرىدە ئون يەتتە يىل ھۆكۈم سۈردى؛ ئۇنىڭ ئانىسىنىڭ ئىسمى نائاماھ بولۇپ، ئاممونىي ئىدى. \x ◘ \xo 14:21 \xt 2تار. 12‏:13\x*  
\v 22 يەھۇدالار بولسا پەرۋەردىگارنىڭ نەزىرىدە يامانلىق قىلدى؛ ئۇلار ئۆز ئاتا-بوۋىلىرى سادىر قىلغانلىرىدىن زىيادە گۇناھلارنى قىلىپ، ئۇنىڭ ھەسەتلىك غەزىپىنى قوزغىغانىدى.  
\v 23 چۈنكى ئۇلار «يۇقىرى جايلار»نى، «بۇت تۈۋرۈك»لەرنى ۋە ھەم ھەربىر ئېگىز دۆڭلار ئۈستىدە، ھەربىر كۆك دەرەخلەرنىڭ ئاستىدا «ئاشەراھ» بۇتلارنى ياسىدى.  
\v 24 ۋە زېمىندا كەسپىي بەچچىۋازلارمۇ بار ئىدى. ئۇلار پەرۋەردىگار ئەسلىدە ئىسرائىللارنىڭ ئالدىدىن ھەيدەپ چىقارغان ئەللەرنىڭ بارلىق يىرگىنچلىك ھارام ئىشلىرىنى قىلاتتى. \f ◼ \fr 14:24 \ft \+bd «كەسپىي بەچچىۋازلار»\+bd* ــ بۇ كىشىلەر بۇتپەرەسلىككە ياكى بۇتخانىلارغا مۇناسىۋەتلىك بولۇپ، پۇل ئۈچۈن بەچچىۋازلىق قىلاتتى.\f*   
\m
\v 25 رەھوبوئام پادىشاھنىڭ سەلتەنىتىنىڭ بەشىنچى يىلىدا شۇنداق بولدىكى، مىسىرنىڭ پادىشاھى شىشاك يېرۇسالېمغا ھۇجۇم قىلدى. \x ◘ \xo 14:25 \xt 2تار. 12‏:2\x*  
\v 26 ئۇ پەرۋەردىگارنىڭ ئۆيىدىكى گۆھەر-بايلىقلارنى ھەم پادىشاھنىڭ ئوردىسىدىكى گۆھەر-بايلىقلارنى ئېلىپ كەتتى؛ ئۇ ھەممىسىنى، جۈملىدىن سۇلايمان ياساتقان ئالتۇن سىپارلارنىمۇ ئېلىپ كەتتى. \x ◘ \xo 14:26 \xt 1پاد. 10‏:16، 17؛ 2تار. 9‏:15\x*  
\v 27 ئۇلارنىڭ ئورنىدا رەھوبوئام پادىشاھ مىستىن بىرمۇنچە سىپار-قالقانلار ياسىتىپ، ئۇلارنى پادىشاھ ئوردىسىنىڭ كىرىش يولىنى ساقلايدىغان پاسىبان بەگلىرىنىڭ قولىغا تاپشۇردى.  
\v 28 شۇنداق قىلىپ، پادىشاھ ھەر قېتىم پەرۋەردىگارنىڭ ئۆيىگە كىرىدىغان چاغدا، پاسىبانلار ئۇ سىپار-قالقانلارنى كۆتۈرۈپ چىقاتتى، ئاندىن ئۇلارنى يەنە پاسىبانخانىغا ئەكىرىپ قويۇشاتتى.  
\v 29 ئەمما رەھوبوئامنىڭ باشقا ئىشلىرى ۋە قىلغىنىنىڭ ھەممىسى «يەھۇدا پادىشاھلىرىنىڭ تارىخ-تەزكىرىلىرى» دېگەن كىتابتا پۈتۈلگەن ئەمەسمىدى؟ \f ◼ \fr 14:29 \ft \+bd «يەھۇدا پادىشاھلىرىنىڭ تارىخ-تەزكىرىلىرى»\+bd* ــ بۇ كىتاب تەۋراتتىكى «تارىخ-تەزكىرە» دېگەن كىتاب ئەمەس، بىراق شۈبھىسىزكى، تەۋراتتىكى «تارىخ-تەزكىرە»نىڭ مۇئەللىپلىرى ئۇنىڭدىن كۆپ ئۇچۇرلار ئالغانىدى.\f*   
\m
\v 30 رەھوبوئام بىلەن يەروبوئام بارلىق كۈنلىرىدە بىر-بىرى بىلەن جەڭ قىلىشىپ تۇرغانىدى.  
\v 31 رەھوبوئام ئۆز ئاتا-بوۋىلىرىنىڭ ئارىسىدا ئۇخلىدى ۋە «داۋۇتنىڭ شەھىرى»دە دەپنە قىلىندى. ئۇنىڭ ئانىسىنىڭ ئىسمى نائاماھ بولۇپ، بىر ئاممونىي ئىدى. رەھوبوئامنىڭ ئوغلى ئابىيام ئاتىسىنىڭ ئورنىدا پادىشاھ بولدى. \f ◼ \fr 14:31 \ft \+bd «رەھوبوئامنىڭ ئوغلى ئابىيام»\+bd* ــ مۇشۇ يەردە ۋە 1:15-8دە ئىبرانىي تىلىدا «ئابىياھ»نىڭ ئىملاسى «ئابىيام» بولىدۇ.\f*   
\b  
\b  
\m  
\c 15
\s1 ئابىياھ يەھۇداغا ھۆكۈم سۈرىدۇ  
\r 2تار. 13‏:1-23  
\m
\v 1 نىباتنىڭ ئوغلى يەروبوئام پادىشاھنىڭ سەلتەنىتىنىڭ ئون سەككىزىنچى يىلىدا ئابىيام يەھۇدانىڭ ئۈستىگە پادىشاھ بولۇپ \f ◼ \fr 15:1 \ft \+bd «ئابىيام»\+bd* ــ باشقا خىل شەكلى «ئابىياھ».\f*  \x ◘ \xo 15:1 \xt 2تار. 13‏:1\x*  
\v 2 يېرۇسالېمدا ئۈچ يىل سەلتەنەت قىلدى. ئۇنىڭ ئانىسىنىڭ ئىسمى مائاكاھ بولۇپ، ئابىشالومنىڭ قىزى ئىدى. \f ◼ \fr 15:2 \ft \+bd «ئابىشالومنىڭ قىزى»\+bd* ــ ياكى «ئابشالومنىڭ قىزى». بۇ «ئابىشالوم» داۋۇتنىڭ ئوغلى ئابشالوم بولۇشى مۇمكىن.\f*  \x ◘ \xo 15:2 \xt 2تار. 13‏:2\x*  
\v 3 ئابىيامنىڭ قەلبى بوۋىسى داۋۇتنىڭ كۆڭلىدەك خۇداسى پەرۋەردىگارغا پۈتۈنلەي بېغىشلانغان ئەمەس ئىدى، بەلكى ئاتىسى رەھوبوئامنىڭ ئۇنىڭدىن ئىلگىرى قىلغان بارلىق گۇناھلىرىدا ماڭاتتى.  
\v 4 شۇنداقتىمۇ داۋۇتنىڭ سەۋەبىدىن خۇداسى پەرۋەردىگار يېرۇسالېمدا ئۇنىڭغا \add يورۇق\add* بىر چىراغنى قالدۇرۇش ئۈچۈن، داۋۇتنىڭ ئەۋلادىنى ئۇنىڭدىن كېيىنمۇ تىكلەپ تۇرغۇزدى ۋە يېرۇسالېمنى قوغدىدى. \f ◼ \fr 15:4 \ft \+bd «داۋۇتنىڭ ئەۋلادى»\+bd* ــ ئىبرانىي تىلىدا «داۋۇتنىڭ ئوغلى». \+bd «شۇنداقتىمۇ داۋۇتنىڭ سەۋەبىدىن خۇداسى پەرۋەردىگار يېرۇسالېمدا ئۇنىڭغا يورۇق بىر چىراغنى قالدۇرۇش ئۈچۈن، داۋۇتنىڭ ئەۋلادىنى ... تۇرغۇزدى ۋە يېرۇسالېمنى قوغدىدى»\+bd* ــ خۇدانىڭ داۋۇتقا بىر «چىراغ» قالدۇرغانلىقى، بەلكىم ئۇنىڭ كېيىنكى كۆپ دەۋرلەرگە: «داۋۇت مېنىڭ سادىق قۇلۇم ئىدى» دەپ ئىسپاتلاش ئۈچۈن دائىم ئۇنىڭ خاندانىدىكىلەردىن بىرىنى يېرۇسالېمدىكى تەختىدە ئولتۇرغۇزۇپ كېلىۋاتقانلىقىنى كۆرسىتىدۇ. شۇنىڭدەك، خۇدا بۇ ئىش ئارقىلىق (داۋۇتنىڭ ئەۋلادلىرىنىڭ ئۇزۇنغىچە تەختتە ئولتۇرۇشى)، ئەسلىدە داۋۇتقا: كەلگۈسى بىر زاماندا سېنىڭ ئەۋلادىڭ (مەسىھ) دۇنياغا كېلىپ، دۇنيانى خۇدانىڭ پادىشاھلىقى قىلىدۇ» دېگەن ۋەدەمنى چوقۇم ئەمەلگە ئاشۇرىمەن، دەپمۇ كۆرسىتىدۇ.\f*  \x ◘ \xo 15:4 \xt 1پاد. 11‏:36\x*  
\v 5 چۈنكى داۋۇت پەرۋەردىگارنىڭ نەزىرىدە دۇرۇس بولغاننى قىلىپ، ھىتتىي ئۇرىياغا قىلغانلىرىدىن باشقا ئۆمرىنىڭ ھەممە كۈنلىرىدە پەرۋەردىگار ئۇنىڭغا ئەمر قىلغانلىرىدىن چىقمىدى. \x ◘ \xo 15:5 \xt 2سام. 11‏:4، 15؛ 12‏:9\x*   
\m
\v 6 ئەمدى \add ئابىيامنىڭ\add* پۈتۈن ئۆمرىدە رەھوبوئام بىلەن يەروبوئام بىر-بىرى بىلەن جەڭ قىلىشىپ تۇردى. \f ◼ \fr 15:6 \ft \+bd «ئابىيامنىڭ پۈتۈن ئۆمرىدە رەھوبوئام بىلەن يەروبوئام بىر-بىرى بىلەن جەڭ قىلىشىپ تۇردى»\+bd* ــ شۈبھىسىزكى، مۇشۇ ئايەتتە «رەھوبوئام» بولسا رەھوبوئام جەمەتىنى ۋە «يەروبوئام» بولسا يەروبوئام جەمەتىنى كۆرسىتىدۇ.\f*   
\m
\v 7 ئابىيامنىڭ باشقا ئىشلىرى ۋە قىلغانلىرىنىڭ ھەممىسى «يەھۇدا پادىشاھلىرىنىڭ تارىخ-تەزكىرىلىرى» دېگەن كىتابتا پۈتۈلگەن ئەمەسمىدى؟ ئابىيام بىلەن يەروبوئام بىر-بىرى بىلەن جەڭ قىلىشىپ تۇراتتى.   
\m
\v 8 ئابىيام ئۆز ئاتا-بوۋىلىرىنىڭ ئارىسىدا ئۇخلىدى؛ ئۇلار ئۇنى «داۋۇتنىڭ شەھىرى»دە دەپنە قىلدى. ئاندىن ئوغلى ئاسا ئورنىدا پادىشاھ بولدى. \x ◘ \xo 15:8 \xt 2تار. 13‏:23\x*   
\b  
\m  
\s1 ئاسا يەھۇداغا ھۆكۈم سۈرىدۇ  
\r 2تار. 14‏:1-2؛ 15‏:16؛ 16‏: 6، 14-11  
\m
\v 9 ئىسرائىلنىڭ پادىشاھى يەروبوئام سەلتەنىتىنىڭ يىگىرمىنچى يىلىدا ئاسا يەھۇدانىڭ ئۈستىگە پادىشاھ بولۇپ  
\v 10 يېرۇسالېمدا قىرىق بىر يىل سەلتەنەت قىلدى. ئۇنىڭ چوڭ ئانىسىنىڭ ئىسمى مائاقاھ بولۇپ، ئابىشالومنىڭ قىزى ئىدى. \f ◼ \fr 15:10 \ft \+bd «ئۇنىڭ چوڭ ئانىسىنىڭ ئىسمى مائاقاھ بولۇپ...»\+bd* ــ بۇ ئىبارىدە ئىبرانىي تىلىدا «چوڭ ئانىسى» دېگەن «ئۇنىڭ ئانىسى» بىلەن ئىپادىلىنىدۇ. ئىبرانىي تىلىدا گاھى ۋاقىتلاردا «ئاتا» ياكى «ئانا» ئادەمنىڭ ئەجدادىنى كۆرسىتىدۇ. مەسىلەن، 11-ئايەتنى كۆرۈڭ.\f*  
\v 11 ئاسا ئاتىسى داۋۇت قىلغاندەك پەرۋەردىگارنىڭ نەزىرىدە دۇرۇس بولغاننى قىلدى.  
\v 12 ئۇ كەسپىي بەچچىۋازلارنى زېمىندىن ھەيدەپ، ئاتا-بوۋىلىرى ياساتقان ھەممە يىرگىنچلىك مەبۇدلارنى يوقىتىۋەتتى. \f ◼ \fr 15:12 \ft \+bd «كەسپىي بەچچىۋازلار»\+bd* ــ بۇ كىشىلەر بۇتپەرەسلىككە ياكى بۇتخانىلارغا مۇناسىۋەتلىك ئىدى.\f*  \x ◘ \xo 15:12 \xt 1پاد. 22‏:47\x*  
\v 13 ئۇ يەنە چوڭ ئانىسى مائاقاھنى يىرگىنچلىك بىر «ئاشەراھ» تۈۋرۈكنى ياسىغىنى ئۈچۈن خانىشلىق مەرتىۋىسىدىن چۈشۈرۈۋەتتى. ئاسا بۇ يىرگىنچلىك بۇتنى كېسىپ كىدرون جىلغىسىدا كۆيدۈرۈۋەتتى. \f ◼ \fr 15:13 \ft \+bd «ئۇ يەنە چوڭ ئانىسى مائاقاھنى ... خانىشلىق مەرتىۋىسىدىن چۈشۈرۈۋەتتى»\+bd* ــ «خانىشلىق مەرتىۋىسى»: بۇ سۆزگە قارىغاندا ئۇنىڭ چوڭ ئانىسى مائاقاھ پادىشاھلىقتا ئىككىنچى ئورۇندا تۇراتتى.\f*  \x ◘ \xo 15:13 \xt 2تار. 15‏:16\x*  
\v 14 «يۇقىرى جايلار» يوقىتىلمىسىمۇ، ئاسانىڭ قەلبى ئۆمرىنىڭ بارلىق كۈنلىرىدە پەرۋەردىگارغا پۈتۈنلەي بېغىشلانغانىدى.  
\v 15 ھەم ئاتىسى ھەم ئۇ ئۆزى \add پەرۋەردىگارغا\add* ئاتاپ ياسىغان نەرسىلەرنى، جۈملىدىن كۈمۈش بىلەن ئالتۇننى ۋە تۈرلۈك قاچا-قۇچىلارنى پەرۋەردىگارنىڭ ئۆيىگە كەلتۈردى. \x ◘ \xo 15:15 \xt لاۋ. 5‏:15\x*   
\m
\v 16 ئەمدى ئاسا ۋە ئىسرائىلنىڭ پادىشاھى بائاشا بارلىق كۈنلىرىدە بىر-بىرى بىلەن جەڭ قىلىشىپ تۇردى.  
\v 17 ئىسرائىلنىڭ پادىشاھى بائاشا يەھۇداغا قارشى ھۇجۇم قىلدى؛ ھېچكىم يەھۇدانىڭ پادىشاھى ئاسا بىلەن باردى-كەلدى قىلمىسۇن دەپ، راماھ شەھىرىنى مەھكەم قىلىپ ياسىدى. \x ◘ \xo 15:17 \xt 2تار. 16‏:1\x*  
\v 18 ئۇ ۋاقىتتا ئاسا پەرۋەردىگارنىڭ ئۆيىدىكى خەزىنىلەردە قالغان بارلىق ئالتۇن-كۈمۈش ۋە پادىشاھنىڭ ئوردىسىدىكى خەزىنىلەردە قالغان ئالتۇن-كۈمۈشنى ئېلىپ خىزمەتكارلىرىنىڭ قولىغا تاپشۇردى؛ ئاندىن ئاسا پادىشاھ ئۇلارنى دەمەشقتە تۇرۇشلۇق سۇرىيە پادىشاھى ھېزىئوننىڭ نەۋرىسى، تابرىمموننىڭ ئوغلى بەن-ھادادقا ئەۋەتتى ۋە شۇلار بىلەن بۇ خەۋەرنى يەتكۈزۈپ: ــ \x ◘ \xo 15:18 \xt 1پاد. 20‏:1؛ 2تار. 16‏:2-14\x*   
\m
\v 19 «مېنىڭ ئاتام بىلەن سىلىنىڭ ئاتىلىرىنىڭ ئارىسىدا بولغاندەك مەن بىلەن سىلىنىڭ ئارىلىرىدا بىر ئەھدە بولسۇن. مانا، سىلىگە كۈمۈش بىلەن ئالتۇندىن ھەدىيە ئەۋەتتىم؛ ئەمدى ئىسرائىلنىڭ پادىشاھى بائاشا بىلەن بولغان ئەھدىلىرىدىن قوللىرىنى ئۈزسىلە؛ شۇنىڭ بىلەن ئۇ مېنى قامال قىلىشتىن قول ئۈزسۇن» ــ دېدى.   
\m
\v 20 بەن-ھاداد ئاسا پادىشاھنىڭ سۆزىگە كىرىپ، ئۆز قوشۇنىنىڭ سەردارلىرىنى ئىسرائىلنىڭ شەھەرلىرىگە ھۇجۇم قىلىشقا ئەۋەتىپ، ئىجون، دان، بەيت-مائاقاھدىكى ئابەل، پۈتكۈل كىننەرەت يۇرتى بىلەن نافتالىنىڭ پۈتكۈل زېمىنىنى بېقىندۇردى.  
\v 21 بائاشا بۇ خەۋەرنى ئاڭلاپ، راماھ ئىستىھكامىنى ياساشتىن قولىنى يىغىپ، تىرزاھقا بېرىپ تۇردى.   
\m
\v 22 ئاسا پادىشاھ بولسا پۈتكۈل يەھۇدانىڭ ئادەملىرىنى ھېچبىرىنى قويماي چاقىرىپ يىغدى؛ ئۇلار بائاشا راماھ شەھىرىنى ياساشقا ئىشلەتكەن تاشلار بىلەن ياغاچلارنى راماھتىن توشۇپ ئېلىپ كەتتى. ئاسا پادىشاھ مۇشۇلارنى ئىشلىتىپ بىنيامىن زېمىنىدىكى گېبانى ۋە مىزپاھنى مەھكەم قىلىپ ياسىدى.   
\m
\v 23 ئەمدى ئاسانىڭ باشقا ئىشلىرى، ئۇنىڭ زور قۇدرىتى، ئۇنىڭ قىلغىنىنىڭ ھەممىسى، شۇنداقلا ياسىغان شەھەرلەر توغرىسىدا «يەھۇدا پادىشاھلىرىنىڭ تارىخ-تەزكىرىلىرى» دېگەن كىتابتا پۈتۈلگەن ئەمەسمىدى؟ لېكىن قېرىغاندا، ئۇنىڭ پۇتىدا بىر كېسەل پەيدا بولدى.  
\v 24 ئاسا ئۆز ئاتا-بوۋىلىرى ئارىسىدا ئۇخلىدى ۋە داۋۇتنىڭ شەھىرىدە دەپنە قىلىندى. ئاندىن ئۇنىڭ ئوغلى يەھوشافات ئورنىدا پادىشاھ بولدى. \x ◘ \xo 15:24 \xt 2تار. 16‏:13؛ 17‏:1\x*   
\b  
\m  
\s1 ناداب ئىسرائىل ئۈستىگە ھۆكۈم سۈرىدۇ  
\m
\v 25 يەھۇدانىڭ پادىشاھى ئاسانىڭ سەلتەنىتىنىڭ ئىككىنچى يىلىدا يەروبوئامنىڭ ئوغلى ناداب ئىسرائىل ئۈستىگە ھۆكۈم سۈرۈشكە باشلىدى؛ ئۇ ئىسرائىلغا ئىككى يىل پادىشاھ بولدى.  
\v 26 ئۇ پەرۋەردىگارنىڭ نەزىرىدە رەزىل بولغاننى قىلىپ ئاتىسىنىڭ يولىدا مېڭىپ، ئاتىسىنىڭ ئىسرائىلنى گۇناھقا پۇتلاشتۇرغان گۇناھلىرىدا ماڭدى.   
\m
\v 27 لېكىن ئىسساكار جەمەتىدىن بولغان ئاخىياھنىڭ ئوغلى بائاشا ئۇنىڭغا قەست قىلىپ، ئۇنى فىلىستىيلەرنىڭ تەۋەسىدىكى گىببېتوندا ئۆلتۈردى. شۇ چاغدا ناداب پۈتۈن ئىسرائىللار بىلەن بىرلىكتە گىببېتونغا قورشاپ ھۇجۇم قىلىۋاتاتتى.   
\m
\v 28 يەھۇدا پادىشاھى ئاسانىڭ سەلتەنىتىنىڭ ئۈچىنچى يىلىدا بائاشا نادابنى ئۆلتۈرۈپ، ئۆزى ئۇنىڭ ئورنىدا پادىشاھ بولدى.  
\v 29 ۋە شۇنداق بولدىكى، ئۇ پادىشاھ بولغاندا يەروبوئامنىڭ پۈتكۈل جەمەتىنى چېپىپ ئۆلتۈردى؛ پەرۋەردىگارنىڭ قۇلى شىلوھلۇق ئاخىياھنىڭ ۋاسىتىسى بىلەن ئېيتقان سۆزى ئەمەلگە ئاشۇرۇلۇپ، ئۇ يەروبوئامنىڭ جەمەتىدىن نەپىسى بارلارنى بىرىنىمۇ قويماي پۈتۈنلەي يوقاتتى. \x ◘ \xo 15:29 \xt 1پاد. 14‏:10، 14\x*  
\v 30 بۇ ئىش يەروبوئامنىڭ سادىر قىلغان گۇناھلىرى ھەم ئۇنىڭ ئىسرائىلنى گۇناھقا پۇتلاشتۇرغان گۇناھلىرى تۈپەيلىدىن بولدى؛ ئۇ شۇلار بىلەن ئىسرائىلنىڭ خۇداسى پەرۋەردىگارنىڭ غەزىپىنى قاتتىق قوزغىغانىدى.  
\v 31 نادابنىڭ باشقا ئىشلىرى بىلەن قىلغانلىرىنىڭ ھەممىسى «ئىسرائىل پادىشاھلىرىنىڭ تارىخ-تەزكىرىلىرى» دېگەن كىتابتا پۈتۈلگەن ئەمەسمىدى؟   
\m
\v 32 ئاسا ۋە ئىسرائىلنىڭ پادىشاھى بائاشا بارلىق كۈنلىرىدە بىر-بىرى بىلەن جەڭ قىلىشىپ تۇردى.   
\b  
\m  
\s1 بائاشا ئىسرائىل ئۈستىگە ھۆكۈم سۈرىدۇ  
\m
\v 33 يەھۇدانىڭ پادىشاھى ئاسانىڭ سەلتەنىتىنىڭ ئۈچىنچى يىلىدا ئاخىياھنىڭ ئوغلى بائاشا پۈتۈن ئىسرائىل ئۈستىگە تىرزاھتا ھۆكۈم سۈرۈشكە باشلىدى؛ ئۇ يىگىرمە تۆت يىل سەلتەنەت قىلدى.  
\v 34 ئۇ پەرۋەردىگارنىڭ نەزىرىدە رەزىل بولغاننى قىلدى؛ ئۇ يەروبوئامنىڭ يولىدا يۈرۈپ، ئىسرائىلنى گۇناھقا پاتقۇزغان گۇناھىدا ماڭدى.   
\b  
\b  
\m  
\c 16
\m
\v 1 پەرۋەردىگارنىڭ سۆزى ھانانىنىڭ ئوغلى يەھۇغا كېلىپ بائاشانى ئەيىبلەپ مۇنداق دېگەندە: ــ  
\v 2 «مانا، مەن سېنى توپا-چاڭ ئىچىدىن چىقىرىپ، خەلقىم ئىسرائىلغا ھۆكۈمران قىلىپ قويدۇم. لېكىن سەن يەروبوئامنىڭ يولىدا يۈرۈپ خەلقىم ئىسرائىلنى گۇناھقا پۇتلاشتۇردۇڭ، ئۇلار گۇناھلىرى بىلەن غەزىپىمنى قوزغىدى. \x ◘ \xo 16:2 \xt 1پاد. 14‏:7\x*  
\v 3 مانا، مەن بائاشانى ئۆز جەمەتى بىلەن سۈپۈرۈپ يوقىتىپ، جەمەتىڭنى نىباتنىڭ ئوغلى يەروبوئامنىڭ جەمەتىگە ئوخشاش قىلىمەن. \x ◘ \xo 16:3 \xt 1پاد. 15‏:29\x*  
\v 4 بائاشادىن بولغانلاردىن شەھەردە ئۆلگىنىنى ئىتلار يەيدۇ؛ سەھرادا ئۆلگىنىنى ئاسماندىكى قۇشلار يەيدۇ». \x ◘ \xo 16:4 \xt 1پاد. 14‏:11؛ 15‏:29؛ 16‏:12\x*   
\m
\v 5 بائاشانىڭ باشقا ئىشلىرى ۋە ئۇنىڭ قىلغانلىرى بىلەن قۇدرىتى توغرىسىدا «ئىسرائىل پادىشاھلىرىنىڭ تارىخ-تەزكىرىلىرى» دېگەن كىتابتا پۈتۈلگەن ئەمەسمىدى؟  
\v 6 بائاشا ئۆز ئاتا-بوۋىلىرى ئارىسىدا ئۇخلىدى ۋە تىرزاھتا دەپنە قىلىندى؛ ئاندىن ئۇنىڭ ئوغلى ئېلاھ ئورنىدا پادىشاھ بولدى.   
\m
\v 7 بائاشانىڭ پەرۋەردىگارنىڭ نەزىرىدە قىلغان بارلىق رەزىللىكى تۈپەيلىدىن، پەرۋەردىگارنىڭ بائاشانىڭ بېشىغا ۋە ئۇنىڭ جەمەتىنىڭ بېشىغا چۈشۈرگىنى توغرۇلۇق سۆزى ھانانىنىڭ ئوغلى يەھۇ پەيغەمبەر ئارقىلىق بېرىلگەنىدى. چۈنكى ئۇ يەروبوئامنىڭ جەمەتى قىلغىنىغا ئوخشاش قىلىپ ئۆز قوللىرىنىڭ ئىشلىرى (جۈملىدىن يەروبوئامنىڭ جەمەتىنى چېپىپ ئۆلتۈرگەنلىكى) بىلەن پەرۋەردىگارنىڭ غەزىپىنى قوزغىدى.   
\b  
\m  
\s1 ئېلاھ ئىسرائىل ئۈستىگە ھۆكۈم سۈرىدۇ  
\m
\v 8 يەھۇدا پادىشاھى ئاسانىڭ سەلتەنىتىنىڭ يىگىرمە ئالتىنچى يىلىدا، بائاشانىڭ ئوغلى ئېلاھ تىرزاھتا ئىسرائىلغا پادىشاھ بولۇپ، ئىككى يىل سەلتەنەت قىلدى.  
\v 9 لېكىن ئۇنىڭ جەڭ ھارۋىلىرىنىڭ يېرىمىغا سەردار بولغان خىزمەتكارى زىمرى ئۇنىڭغا قەست قىلدى؛ \add ئېلاھ\add* تىرزاھتا تىرزاھتىكى ئوردىسىدىكى غوجىدار ئارزانىڭ ئۆيىدە شاراب ئىچىپ مەست بولغاندا  
\v 10 زىمرى كىرىپ ئۇنى چېپىپ ئۆلتۈردى. بۇ ۋاقىت يەھۇدانىڭ پادىشاھى ئاسانىڭ سەلتەنىتىنىڭ يىگىرمە يەتتىنچى يىلى ئىدى. زىمرى ئېلاھنىڭ ئورنىدا پادىشاھ بولدى. \x ◘ \xo 16:10 \xt 2پاد. 9‏:31\x*   
\m
\v 11 ئۇ پادىشاھ بولۇپ ئۆز تەختىدە ئولتۇرۇشى بىلەنلا ئۇ بائاشانىڭ بارلىق جەمەتىنى چېپىپ ئۆلتۈردى؛ ئۇ ئۇنىڭ ئۇرۇق-تۇغقانلىرى ۋە دوستلىرىدىن بىر ئەركەكنىمۇ تىرىك قالدۇرمىدى. \f ◼ \fr 16:11 \ft \+bd «ئۇنىڭ ئۇرۇق-تۇغقانلىرى ۋە دوستلىرىدىن بىر ئەركەكنىمۇ تىرىك قالدۇرمىدى»\+bd* ــ بۇنىڭدا «(ھەربىر) ئەركەك» ئىبرانىي تىلىدا: «تامغا قاراپ سىيىدىغان ھەربىرى» دېگەنلىك بىلەن ئىپادىلىنىدۇ.\f*  
\v 12 شۇنداق قىلىپ زىمرى پەرۋەردىگارنىڭ يەھۇ پەيغەمبەر ئارقىلىق بائاشانى ئەيىبلىگەن سۆزىنى ئەمەلگە ئاشۇرۇپ، بائاشانىڭ پۈتكۈل جەمەتىنى يوقاتتى.  
\v 13 بۇ ئىش بائاشانىڭ بارلىق گۇناھلىرى بىلەن ئۇنىڭ ئوغلى ئېلاھنىڭ گۇناھلىرى، جۈملىدىن ئۇلارنىڭ ئىسرائىلنى گۇناھقا پۇتلاشتۇرغان گۇناھلىرى، ئەرزىمەس بۇتلىرى بىلەن ئىسرائىلنىڭ خۇداسى پەرۋەردىگارنىڭ غەزىپىنى قوزغاپ، شۇنداق بولدى. \f ◼ \fr 16:13 \ft \+bd «ئەرزىمەس بۇتلىرى بىلەن...»\+bd* ــ ئىبرانىي تىلىدا «يوق بولغان نەرسىلىرى بىلەن...»\f*   
\m
\v 14 ئېلاھنىڭ باشقا ئىشلىرى ۋە قىلغانلىرىنىڭ ھەممىسى «ئىسرائىل پادىشاھلىرىنىڭ تارىخ-تەزكىرىلىرى» دېگەن كىتابتا پۈتۈلگەن ئەمەسمىدى؟   
\b  
\m  
\s1 زىمرى ئىسرائىل ئۈستىگە ھۆكۈم سۈرىدۇ  
\m
\v 15 يەھۇدانىڭ پادىشاھى ئاسانىڭ سەلتەنىتىنىڭ يىگىرمە يەتتىنچى يىلىدا زىمرى تىرزاھتا يەتتە كۈن سەلتەنەت قىلدى. خەلق فىلىستىيلەرگە تەۋە بولغان گىببېتوننى قورشىۋېلىپ بارگاھ تىككەنىدى.  
\v 16 بارگاھتا تۇرغان خالايىق: ــ «زىمرى قەست قىلىپ پادىشاھنى ئۆلتۈردى» دەپ ئاڭلىدى. شۇنىڭ بىلەن پۈتكۈل ئىسرائىل شۇ كۈنى بارگاھتا قوشۇننىڭ سەردارى ئومرىنى ئىسرائىلغا پادىشاھ قىلدى.  
\v 17 ئاندىن ئومرى ئىسرائىلنىڭ ھەممىسىنى يېتەكلەپ، گىببېتوندىن چىقىپ، تىرزاھنى قورشىدى.  
\v 18 ۋە شۇنداق بولدىكى، زىمرى شەھەرنىڭ ئېلىنغانلىقىنى كۆرۈپ، پادىشاھ ئوردىسىدىكى قورغانغا كىرىپ، ئوردىغا ئوت قويۇۋەتتى، ئۆزى كۆيۈپ ئۆلدى.  
\v 19 بۇ ئىش ئۆزىنىڭ گۇناھلىرى ئۈچۈن، يەنى پەرۋەردىگارنىڭ نەزىرىدە رەزىللىك قىلىپ، يەروبوئامنىڭ يولىدا يۈرۈپ، ئىسرائىلنى گۇناھقا پۇتلاشتۇرغان گۇناھتا ماڭغىنى ئۈچۈن شۇنداق بولدى.  
\v 20 زىمرىنىڭ باشقا ئىشلىرى ۋە قەست قىلغىنى توغرىسىدا «ئىسرائىل پادىشاھلىرىنىڭ تارىخ-تەزكىرىلىرى» دېگەن كىتابتا پۈتۈلگەن ئەمەسمىدى؟   
\m
\v 21 ئەمما ئىسرائىل خەلقى ئىككىگە بۆلۈنۈپ، ئۇلارنىڭ يېرىمى گىناتنىڭ ئوغلى تىبنىنى پادىشاھ قىلىشقا ئۇنىڭغا ئەگەشتى؛ باشقا يېرىمى بولسا ئومرىگە ئەگەشتى.  
\v 22 ئەمدى ئومرىگە ئەگەشكەن خەلق گىناتنىڭ ئوغلى تىبنىگە ئەگەشكەن خەلقتىن كۈچلۈك چىقتى. تىبنى ئۆلدى؛ ئومرى پادىشاھ بولدى.   
\m
\v 23 يەھۇدانىڭ پادىشاھى ئاسانىڭ ئوتتۇز بىرىنچى يىلىدا ئومرى ئىسرائىلغا پادىشاھ بولۇپ ئون ئىككى يىل سەلتەنەت قىلدى. ئۇ تىرزاھتا ئالتە يىل سەلتەنەت قىلدى.  
\v 24 ئۇ شەمەردىن سامارىيە ئېگىزلىكىنى ئىككى تالانت كۈمۈشكە سېتىۋېلىپ، شۇ ئېگىزلىك ئۈستىگە قۇرۇلۇشلارنى سېلىپ بىر شەھەر بىنا قىلىپ، ئۇنى ئېگىزلىكنىڭ ئەسلىي ئىگىسى شەمەرنىڭ نامى بىلەن «سامارىيە» دەپ ئاتىدى.  
\v 25 ئومرى پەرۋەردىگارنىڭ نەزىرىدە رەزىل بولغاننى قىلدى، ئۆزىدىن ئىلگىرىكى پادىشاھلارنىڭ ھەممىسىدىن بەتتەر بولۇپ يامانلىق قىلدى.  
\v 26 ئۇ نىباتنىڭ ئوغلى يەروبوئامنىڭ ھەممە يوللىرىدا، شۇنداقلا جۈملىدىن ئۇنىڭ ئىسرائىلنى گۇناھقا پۇتلاشتۇرغان گۇناھى ئىچىدە ماڭدى؛ ئۇلار ئەرزىمەس بۇتلىرى بىلەن ئىسرائىلنىڭ خۇداسى پەرۋەردىگارنىڭ غەزىپىنى قوزغىدى.   
\m
\v 27 ئومرىنىڭ باشقا ئىشلىرى، ئۇنىڭ قىلغانلىرىنىڭ ھەممىسى، كۆرسەتكەن قۇدرىتى توغرىسىدا «ئىسرائىل پادىشاھلىرىنىڭ تارىخ-تەزكىرىلىرى» دېگەن كىتابتا پۈتۈلگەن ئەمەسمىدى؟   
\m
\v 28 ئومرى ئاتا-بوۋىلىرى ئارىسىدا ئۇخلىدى ۋە سامارىيەدە دەپنە قىلىندى. ئاندىن ئۇنىڭ ئوغلى ئاھاب ئورنىدا پادىشاھ بولدى.   
\b  
\m  
\s1 ئاھاب خەلقنى بۇتپەرەسلىككە تېخىمۇ ئازدۇرىدۇ  
\m
\v 29 يەھۇدا پادىشاھى ئاسانىڭ سەلتەنىتىنىڭ ئوتتۇز سەككىزىنچى يىلىدا ئومرىنىڭ ئوغلى ئاھاب ئىسرائىلغا پادىشاھ بولدى. ئومرىنىڭ ئوغلى ئاھاب سامارىيەدە يىگىرمە ئىككى يىل ئىسرائىلنىڭ ئۈستىدە سەلتەنەت قىلدى.  
\v 30 ئەمما ئومرىنىڭ ئوغلى ئاھاب پەرۋەردىگارنىڭ نەزىرىدە ئۆزىدىن ئىلگىرىكىلەرنىڭ ھەممىسىدىن ئاشۇرۇپ يامانلىق قىلدى.  
\v 31 ۋە شۇنداق بولدىكى، ئۇ نىباتنىڭ ئوغلى يەروبوئامنىڭ گۇناھلىرىدا يۈرۈش ئانچە ئېغىر گۇناھ ئەمەستەك، ئۇ زىدونىيلارنىڭ پادىشاھى ئەتبائالنىڭ قىزى يىزەبەلنى خوتۇنلۇققا ئالدى ۋە شۇنىڭ بىلەن ئۇ بائال دېگەن بۇتنىڭ قۇللۇقىدا بولۇپ، ئۇنىڭغا سەجدە قىلدى.  
\v 32 ئۇ سامارىيەدە ياسىغان بائالنىڭ بۇتخانىسى ئىچىگە بائالغا بىر قۇربانگاھ ياسىدى.   
\m
\v 33 ئاھاب ھەم بىر «ئاشەراھ بۇت»نىمۇ ياساتتى؛ ئاھاب شۇنداق قىلىپ ئۇنىڭدىن بۇرۇن ئۆتكەن ئىسرائىلنىڭ ھەممە پادىشاھلىرىنىڭ ئىسرائىلنىڭ خۇداسى پەرۋەردىگارنىڭ غەزىپىنى قوزغىغان ئىشلىرىدىن ئاشۇرۇپ يامانلىق قىلدى.  
\v 34 ئۇنىڭ كۈنلىرىدە بەيت-ئەللىك خىئەل يېرىخو شەھىرىنى ياسىدى؛ لېكىن ئۇ ئۇنىڭ ئۇلىنى سالغاندا تۇنجى ئوغلى ئابىرام ئۆلدى؛ ۋە دەرۋازىلىرىنى سالغاندا ئۇنىڭ كەنجى ئوغلى سەگۇب ئۆلدى؛ شۇنىڭ بىلەن پەرۋەردىگارنىڭ نۇننىڭ ئوغلى يەشۇئا ئارقىلىق \add يېرىخو توغرۇلۇق\add* ئېيتقان سۆزى ئەمەلگە ئاشۇرۇلدى. \f ◼ \fr 16:34 \ft \+bd «ئۇ ئۇنىڭ ئۇلىنى سالغاندا تۇنجى ئوغلى ئابىرام ئۆلدى؛ ۋە دەرۋازىلىرىنى سالغاندا ئۇنىڭ كەنجى ئوغلى سەگۇب ئۆلدى. شۇنىڭ بىلەن پەرۋەردىگارنىڭ ... يەشۇئا ئارقىلىق ئېيتقان سۆزى ئەمەلگە ئاشۇرۇلدى»\+bd* ــ يەشۇئا پەيغەمبەرنىڭ يېرىخو شەھىرىگە قارىتا لەنىتى توغرۇلۇق «يەشۇئا» 26:6نى كۆرۈڭ.\f*  \x ◘ \xo 16:34 \xt يە. 6‏:26\x*   
\b  
\b  
\m  
\c 17
\s1 ئىلىياس پەيغەمبەر مەيدانغا چىقىدۇ  
\m
\v 1 ئەمدى گىلېئادتا تۇرۇۋاتقانلاردىن بولغان تىشبىلىق ئىلىياس ئاھابقا: ــ مەن خىزمىتىدە تۇرۇۋاتقان ئىسرائىلنىڭ خۇداسى پەرۋەردىگارنىڭ ھاياتى بىلەن قەسەم قىلىمەنكى، مېنىڭ سۆزۈمسىز بۇ يىللاردا نە شەبنەم نە يامغۇر چۈشمەيدۇ، دېدى. \f ◼ \fr 17:1 \ft \+bd «گىلېئادتا تۇرۇۋاتقانلاردىن بولغان تىشبىلىق ئىلىياس...»\+bd* ــ «ئىلىياس» ئىبرانىي تىلىدىكى «ئېلىياھ» دېگەننىڭ ئەرەبچە تەلەپپۇزىدۇر. «ئېلىياھ»نىڭ مەنىسى «پەرۋەردىگار (ياھ) مېنىڭ خۇدايىم». «ئىلىياس» ئوقۇرمەنلەرگە تونۇش بولغاچقا، پەيغەمبەرنىڭ نامىنىڭ ئەرەبچە تەلەپپۇزىنى ئىشلەتتۇق. \+bd «مەن خىزمىتىدە تۇرۇۋاتقان ئىسرائىلنىڭ خۇداسى پەرۋەردىگار»\+bd* ــ ئىبرانىي تىلىدا «مەن ئۇنىڭ (خۇدانىڭ) ئالدىدا تۇرۇۋاتقان، ئىسرائىلنىڭ خۇداسى پەرۋەردىگار» دېگەن سۆز بىلەن ئىپادىلىنىدۇ. ئىلىياس ئۆزىنى پادىشاھنىڭ ئوردىسىدا دائىم غوجىسىنىڭ ئالدىدا تۇرۇۋاتقان خىزمەتكارغا ئوخشىتىدۇ.\f*  \x ◘ \xo 17:1 \xt ياق. 5‏:17\x*   
\m
\v 2 ئاندىن پەرۋەردىگارنىڭ سۆزى ئۇنىڭغا كېلىپ مۇنداق دېگەندە: ــ   
\m
\v 3 «بۇ يەردىن كېتىپ، مەشرىق تەرەپكە بېرىپ، ئىئوردان دەرياسىنىڭ ئۇ تەرىپىدىكى قېرىت ئېقىنىنىڭ بويىدا ئۆزۈڭنى يوشۇرغىن؛  
\v 4 ۋە شۇنداق بولىدۇكى، سەن ئېقىننىڭ سۈيىدىن ئىچىسەن؛ مانا، ساڭا ئۇ يەردە ئوزۇق يەتكۈزۈپ بېرىشكە قاغا-قۇزغۇنلارنى بۇيرۇدۇم».   
\m
\v 5 شۇنىڭ بىلەن ئۇ پەرۋەردىگار بۇيرۇغاندەك قىلىپ، ئىئوردان دەرياسىنىڭ ئۇ تەرىپىدىكى قېرىت ئېقىنىغا بېرىپ، ئۇ يەردە تۇردى.  
\v 6 قاغا-قۇزغۇنلار ئەتىگەندە نان بىلەن گۆش، ھەر كەچتە يەنە نان بىلەن گۆش يەتكۈزۈپ بېرەتتى. ئۇ ئۆزى ئېقىننىڭ سۈيىدىن ئىچەتتى.  
\v 7 لېكىن زېمىندا يامغۇر ياغمىغىنى ئۈچۈن بىرمەزگىلدىن كېيىن ئېقىن سۇ قۇرۇپ كەتتى.  
\v 8 ئۇ ۋاقىتتا پەرۋەردىگارنىڭ سۆزى ئۇنىڭغا كېلىپ مۇنداق دېگەندە: ــ  
\v 9 «ئورنۇڭدىن تۇرۇپ زىدوندىكى زارەفاتقا بېرىپ، ئۇ يەردە تۇرغىن؛ مانا، مەن ئۇ يەردىكى بىر تۇل خوتۇننى سېنى بېقىشقا بۇيرۇدۇم». \x ◘ \xo 17:9 \xt لۇقا 4‏:25، 26\x*   
\m
\v 10 ئۇ ئورنىدىن تۇرۇپ زارەفاتقا بېرىپ، شەھەرنىڭ دەرۋازىسىغا كەلگەندە، مانا ئۇ يەردە بىر تۇل خوتۇن ئوتۇن تېرىپ تۇراتتى. ئۇ تۇل خوتۇننى چاقىرىپ: ــ ئۆتۈنىمەن، قاچىدا ماڭا ئىچكىلى ئازراق سۇ ئېلىپ كەلگەيسەن، دېدى.   
\m
\v 11 ئۇ سۇ ئالغىلى ماڭغاندا، ئۇ يەنە: ــ ئۆتۈنىمەن، ماڭا قولۇڭدا بىر چىشلەم نانمۇ ئالغاچ كەلگەيسەن، دېدى.   
\m
\v 12 ئەمما ئۇ: ــ پەرۋەردىگار خۇدايىڭنىڭ ھاياتى بىلەن، ساڭا قەسەم قىلىمەنكى، مەندە ھېچ نان يوق، پەقەت ئىدىشتا بىر چاڭگال ئۇن، كوزىدا ئازغىنە ماي بار، مانا ئىككى تال ئوتۇن تېرىۋاتىمەن؛ ئاندىن بېرىپ ئۆزۈم بىلەن ئوغلۇمغا نان ئېتىپ، ئۇنى يەپ ئۆلىمىز، دېدى.   
\m
\v 13 ئىلىياس ئۇنىڭغا: ــ قورقمىغىن؛ بېرىپ ئېيتقىنىڭدەك قىلغىن؛ لېكىن ئاۋۋال بىر كىچىك توقاچ ئېتىپ، ماڭا ئېلىپ كەلگىن؛ ئاندىن ئۆزۈڭ بىلەن ئوغلۇڭغا نان ئەتكىن.  
\v 14 چۈنكى ئىسرائىلنىڭ خۇداسى پەرۋەردىگار مۇنداق دەيدۇ: ــ «پەرۋەردىگار يەر يۈزىگە يامغۇر ياغدۇرىدىغان كۈنگىچىلىك ئىدىشتىكى ئۇن تۈگىمەيدۇ ۋە كوزىدىكى ماي كېمەيمەيدۇ»، دېدى.   
\m
\v 15 شۇنىڭ بىلەن ئۇ بېرىپ، ئىلىياسنىڭ ئېيتقىنىدەك قىلدى ۋە ئۇ، ئىلىياس ۋە ئايالنىڭ ئۆيىدىكىلەر خېلى كۈنلەرگىچە يېدى.  
\v 16 پەرۋەردىگارنىڭ ئىلىياس ئارقىلىق ئېيتقان سۆزى بويىچە، ئىدىشتىكى ئۇن تۈگىمىدى ۋە كوزىدىكى مايمۇ كېمەيمىدى.  
\v 17 شۇ ئىشلاردىن كېيىن شۇنداق بولدىكى، ئۆينىڭ ئىگىسى بولغان بۇ ئايالنىڭ ئوغلى كېسەل بولدى. ئۇنىڭ كېسىلى شۇنداق ئېغىرلىشىپ كەتتىكى، ئۇنىڭدا نەپەس قالمىدى.   
\m
\v 18 ئايال ئىلىياسقا: ــ ئى خۇدانىڭ ئادىمى، مېنىڭ سەن بىلەن نېمە ئالاقەم بار ئىدى؟ سەن گۇناھىمنى يادقا كەلتۈرۈپ، ئوغلۇمنىڭ جېنىغا زامىن بولۇشقا كەلدىڭمۇ؟ ــ دېدى.   
\m
\v 19 ئۇ ئۇنىڭغا: ــ ئوغلۇڭنى قولۇمغا بەرگىن، دەپ ئۇنى ئۇنىڭ قۇچىقىدىن ئېلىپ ئۆزى ئولتۇرغان بالىخانىغا ئېلىپ چىقىپ ئۆز ئورنىغا قويۇپ،  
\v 20 پەرۋەردىگارغا پەرياد قىلىپ: ــ ئى خۇدايىم پەرۋەردىگار، مەن مېھمان بولغان بۇ تۇل خوتۇننىڭ ئوغلىنى ئۆلتۈرۈش بىلەن ئۇنىڭ بېشىغىمۇ بالا چۈشۈردۇڭمۇ؟ ــ دەپ نىدا قىلدى.   
\m
\v 21 ئۇ بالىنىڭ ئۈستىگە ئۈچ قېتىم ئۆزىنى چاپلاپ، پەرۋەردىگارغا پەرياد قىلىپ: ــ ئى پەرۋەردىگار خۇدايىم، بۇ بالىنىڭ جېنى ئۆزىگە يەنە يېنىپ كىرسۇن! ــ دەپ نىدا قىلدى. \f ◼ \fr 17:21 \ft \+bd «بۇ بالىنىڭ جېنى ئۆزىگە يەنە يېنىپ كىرسۇن!»\+bd* ــ «بالىنىڭ جېنى»: ئىبرانىي تىلىدا «جان» ۋە «نەپەس» بىر سۆزدۇر.\f*   
\m
\v 22 پەرۋەردىگار ئىلىياسنىڭ پەريادىنى ئاڭلىدى؛ بالىنىڭ جېنى ئۇنىڭغا يېنىپ كىرىشى بىلەن ئۇ تىرىلدى.  
\v 23 ئىلىياس بالىنى بالىخانىدىن ئېلىپ چۈشۈپ، ئۆيگە كىرىپ، ئانىسىغا تاپشۇرۇپ بەردى. ئىلىياس: ــ مانا ئوغلۇڭ تىرىكتۇر، دېدى.   
\m
\v 24 ئايال ئىلىياسقا: ــ مەن شۇ ئىش ئارقىلىق ئەمدى سېنىڭ خۇدانىڭ ئادىمى ئىكەنلىكىڭنى، ئاغزىڭدىن چىققان پەرۋەردىگارنىڭ سۆزى ھەقىقەت ئىكەنلىكىنى بىلدىم، دېدى.   
\b  
\b  
\m  
\c 18
\s1 ئىلىياس پەيغەمبەر ئىسرائىلنى توۋا قىلىشقا چاقىرىدۇ  
\m
\v 1 ئۇزۇن ۋاقىت ئۆتۈپ، پەرۋەردىگارنىڭ سۆزى \add قۇرغاقچىلىقنىڭ\add* ئۈچىنچى يىلىدا ئىلىياسقا كېلىپ مۇنداق دېگەندە: ــ «سەن بېرىپ ئۆزۈڭنى ئاھابنىڭ ئالدىدا ئايان قىلغىن، ۋە مەن يەر يۈزىگە يامغۇر ياغدۇرىمەن».   
\m
\v 2 شۇنىڭ بىلەن ئىلىياس ئۆزىنى ئاھابنىڭ ئالدىدا ئايان قىلغىلى چىقىپ كەتتى. ئاچارچىلىق بولسا سامارىيەدە قاتتىق ئىدى.  
\v 3 ئاھاب ئوردىسىدىكى غوجىدار ئوبادىيانى چاقىردى (ئوبادىيا تولىمۇ تەقۋادار كىشى بولۇپ پەرۋەردىگاردىن ئىنتايىن قورقاتتى.  
\v 4 يىزەبەل پەرۋەردىگارنىڭ پەيغەمبەرلىرىنى ئۆلتۈرۈپ يوقىتىۋاتقاندا ئوبادىيا يۈز پەيغەمبەرنى ئېلىپ ئەللىكتىن-ئەللىكتىن ئايرىم-ئايرىم ئىككى غارغا يوشۇرۇپ، ئۇلارنى نان ۋە سۇ بىلەن باققانىدى).  
\v 5 ئاھاب ئوبادىياغا: ــ زېمىننى كېزىپ ھەممە بۇلاق ۋە ھەممە جىلغىلارغا بېرىپ باققىن؛ ئۇ يەرلەردە ئات-قېچىرلارنى تىرىك ساقلىغۇدەك ئوت-چۆپ تېپىلارمىكىن؟ شۇنداق بولسا بىزنىڭ ئۇلاغلىرىمىزنىڭ بىر قىسمىنى سويماي تۇرالارمىز، دېدى.   
\m
\v 6 ئۇلار ھەربىرى جايلارغا بۆلۈنۈپ ماڭدى؛ ئاھاب ئۆز ئالدىغا ماڭدى، ئوبادىيامۇ ئۆز ئالدىغا ماڭدى.  
\v 7 ئوبادىيا ئۆز يولىدا كېتىپ بارغاندا، مانا، ئۇنىڭغا ئىلىياس ئۇچرىدى. ئۇ ئۇنى تونۇپ يەرگە يىقىلىپ دۈم يېتىپ: بۇ راست سەن، غوجام ئىلىياسمۇ؟ ــ دەپ سورىدى.   
\m
\v 8 ئۇ ئۇنىڭغا: ــ بۇ مەن. بېرىپ ئۆز غوجاڭغا: ــ ئىلىياس قايتىپ كەلدى! دەپ ئېيتقىن، دېدى.   
\m
\v 9 ئۇ ئىلىياسقا مۇنداق دېدى: ــ «سەن قانداقسىگە كەمىنەڭنى ئۆلتۈرگىلى ئاھابنىڭ قولىغا تاپشۇرماقچى بولىسەن، مەن زادى نېمە گۇناھ قىلدىم؟  
\v 10 ئۆز خۇدايىڭ پەرۋەردىگارنىڭ ھاياتى بىلەن قەسەم قىلىمەنكى، غوجام ئادەم ئەۋەتىپ سېنى ئىزدىمىگەن ھېچ ئەل ۋە مەملىكەت قالمىدى. شۇ ئەل، مەملىكەتلەر: «ئۇ بۇ يەردە يوق» دېسە، پادىشاھ ئۇلارغا سېنى تاپالمىغانغا قەسەم ئىچكۈزدى.  
\v 11 لېكىن سەن ماڭا ھازىر: ــ «بېرىپ غوجاڭغا: ــ ئىلىياس قايتىپ كەلدى! دېگىن» ــ دەيسەن!  
\v 12 مەن قېشىڭدىن كەتكەندىن كېيىن، پەرۋەردىگارنىڭ روھى سېنى مەن بىلمىگەن يەرگە ئېلىپ بارىدۇ؛ شۇنداقتا مەن ئاھابقا خەۋەر يەتكۈزۈپ، لېكىن ئۇ سېنى تاپالمىسا، مېنى ئۆلتۈرىدۇ. ئەمەلىيەتتە، كەمىنەڭ ياشلىقىمدىن تارتىپ پەرۋەردىگاردىن قورقۇپ كەلگەنمەن.  
\v 13 يىزەبەل پەرۋەردىگارنىڭ پەيغەمبەرلىرىنى ئۆلتۈرگەندە مېنىڭ قانداق قىلغىنىم، يەنى مەن پەرۋەردىگارنىڭ پەيغەمبەرلىرىدىن يۈزنى ئەللىكتىن-ئەللىكتىن ئايرىم-ئايرىم ئىككى غارغا يوشۇرۇپ، ئۇلارنى نان ۋە سۇ بىلەن تەمىنلەپ باققانلىقىم سەن غوجامغا مەلۇم قىلىنغان ئەمەسمۇ؟  
\v 14 ئەمدى سەن ھازىر ماڭا: ــ «بېرىپ غوجاڭغا: ــ مانا ئىلىياس كەلدى دېگىن»، ــ دېدىڭ. شۇنداق قىلسام ئۇ مېنى ئۆلتۈرىدۇ!».   
\m
\v 15 لېكىن ئىلىياس: ــ مەن خىزمىتىدە تۇرۇۋاتقان ساماۋى قوشۇنلارنىڭ سەردارى بولغان پەرۋەردىگارنىڭ ھاياتى بىلەن قەسەم قىلىمەنكى، مەن جەزمەن بۈگۈن ئۇنىڭ ئالدىدا ئايان بولىمەن، دېدى. \f ◼ \fr 18:15 \ft \+bd «مەن خىزمىتىدە تۇرۇۋاتقان ئىسرائىلنىڭ خۇداسى پەرۋەردىگار»\+bd* ــ ئىبرانىي تىلىدا «مەن ئۇنىڭ (خۇدانىڭ) ئالدىدا تۇرۇۋاتقان، ئىسرائىلنىڭ خۇداسى پەرۋەردىگار» دېگەن سۆز بىلەن ئىپادىلىنىدۇ. ئىلىياس ئۆزىنى پادىشاھنىڭ ئوردىسىدا دائىم غوجىسىنىڭ ئالدىدا تۇرۇۋاتقان خىزمەتكارغا ئوخشىتىدۇ.\f*   
\m
\v 16 شۇنىڭ بىلەن ئوبادىيا ئاھابنىڭ قېشىغا بېرىپ ئۇنىڭغا خەۋەر بەردى. ئاھاب ئىلىياس بىلەن كۆرۈشكىلى باردى.  
\v 17 ئاھاب ئىلىياسنى كۆرگەندە ئۇنىڭغا: ــ بۇ سەنمۇ، ئى ئىسرائىلغا بالا كەلتۈرگۈچى؟! ــ دېدى. \x ◘ \xo 18:17 \xt ئام. 7‏:10\x*   
\m
\v 18 ئۇ جاۋاب بېرىپ: ــ ئىسرائىلغا بالا كەلتۈرگۈچى مەن ئەمەس، بەلكى سەن بىلەن ئاتاڭنىڭ جەمەتىدىكىلەر! چۈنكى سىلەر پەرۋەردىگارنىڭ ئەمرلىرىنى تاشلاپ بائال دېگەن بۇتلارغا تايىنىپ ئەگەشكەنسىلەر.  
\v 19 ئەمدى ئادەم ئەۋەتىپ كارمەل تېغىدا پۈتكۈل ئىسرائىلنى يېنىمغا جەم قىل، شۇنداقلا يىزەبەلنىڭ داستىخىنىدىن غىزالىنىدىغان بائالنىڭ تۆت يۈز ئەللىك پەيغەمبىرى بىلەن ئاشەراھنىڭ تۆت يۈز پەيغەمبىرىنى يىغدۇر، ــ دېدى.   
\m
\v 20 شۇنىڭ بىلەن ئاھاب ئىسرائىللارنىڭ ھەممىسىگە ئادەملەرنى ئەۋەتىپ، پەيغەمبەرلەرنى كارمەل تېغىغا يىغدۇردى.   
\m
\v 21 ئىلىياس بارلىق خەلققە يېقىن كېلىپ: ــ قاچانغىچە ئىككى پىكىر ئارىسىدا ئارىسالدى تۇرىسىلەر؟ ئەگەر پەرۋەردىگار خۇدا بولسا، ئۇنىڭغا ئەگىشىڭلار؛ بائال خۇدا بولسا، ئۇنىڭغا ئەگىشىڭلار، دېدى. ئەمما خەلق ئۇنىڭغا جاۋاب بەرمەي، ئۈن-تىن چىقارمىدى. \x ◘ \xo 18:21 \xt يە. 24‏:15\x*   
\m
\v 22 ئىلىياس خەلققە: ــ پەرۋەردىگارنىڭ پەيغەمبەرلىرىدىن پەقەت مەن يالغۇز قالدىم. ئەمما بائالنىڭ پەيغەمبەرلىرى تۆت يۈز ئەللىك كىشىدۇر.  
\v 23 ئەمدى بىزگە ئىككى بۇقا بېرىلسۇن. ئۇلار ئۆزلىرىگە بىر بۇقىنى تاللاپ، سويۇپ پارچىلاپ ئوتۇننىڭ ئۈستىگە قويسۇن، ئەمما ئوت ياقمىسۇن. مەنمۇ باشقا بىر بۇقىنى تەييار قىلىپ ئوت ياقماي ئوتۇننىڭ ئۈستىگە قوياي.  
\v 24 سىلەر بولساڭلار، ئۆز ئىلاھلىرىڭلارنىڭ نامىنى چاقىرىپ نىدا قىلىڭلار. مەن بولسام، پەرۋەردىگارنىڭ نامىنى چاقىرىپ نىدا قىلىمەن. قايسى خۇدا ئوت بىلەن جاۋاب بەرسە، شۇ خۇدا بولسۇن، دېدى. ھەممە خەلق: ــ بۇ ئوبدان گەپ، دەپ جاۋاب بەردى.   
\m
\v 25 ئىلىياس بائالنىڭ پەيغەمبەرلىرىگە: سىلەر كۆپ بولغاچ ئاۋۋال ئۆزۈڭلار ئۈچۈن بىر بۇقىنى تاللاپ تەييار قىلىڭلار؛ ئاندىن ھېچ ئوت ياقماي ئۆز ئىلاھىڭلارنىڭ نامىنى قىچقىرىپ نىدا قىلىڭلار، دېدى.   
\m
\v 26 ئۇلار ئۇنىڭ دېگىنى بويىچە ئۆزلىرىگە بېرىلگەن بۇقىنى ئېلىپ ئۇنى تەييار قىلدى. ئەتىگەندىن چۈشكىچە ئۇلار بائالنىڭ نامىنى قىچقىرىپ: ــ ئى بائال، بىزگە جاۋاب بەرگىن! دەپ نىدا قىلدى. لېكىن ھېچ ئاۋاز ياكى ھېچ جاۋاب بولمىدى. ئۇلار راسلانغان قۇربانگاھ چۆرىسىدە توختىماي سەكرەيتتى.  
\v 27 چۈش كىرگەندە ئىلىياس ئۇلارنى زاڭلىق قىلىپ: ــ ئۈنلۈكرەك قىچقىرىڭلار؛ چۈنكى ئۇ بىر ئىلاھ ئەمەسمۇ؟ بەلكىم ئۇ چوڭقۇر خىيالغا چۆمۈپ كەتكەندۇ، ياكى ئىش بىلەن چىقىپ كەتكەندۇ، ياكى بىر سەپەرگە چىقىپ كەتكەندۇ؟ ياكى بولمىسا ئۇ ئۇخلاۋاتقان بولۇشى مۇمكىن، ئۇنى ئويغىتىشىڭلار كېرەك؟! ــ دېدى.   
\m
\v 28 ئۇلار تېخىمۇ ئۈنلۈك چاقىرىپ ئۆز قائىدىسى بويىچە قانغا مىلىنىپ كەتكۈچە ئۆزلىرىنى قىلىچ ۋە نەيزە بىلەن تىلاتتى.  
\v 29 چۈشتىن كېيىن ئۇلار «بېشارەت بېرىۋاتقان» ھالەتكە چۈشۈپ كەچلىك قۇربانلىق ۋاقتىغىچە شۇ ھالەتتە تۇردى. لېكىن ھېچ ئاۋاز ئاڭلانمىدى، ياكى جاۋاب بەرگۈچى ياكى ئىجابەت قىلغۇچى مەلۇم بولمىدى. \f ◼ \fr 18:29 \ft \+bd «چۈشتىن كېيىن ئۇلار «بېشارەت بېرىۋاتقان» ھالەتكە چۈشۈپ كەچلىك قۇربانلىق ۋاقتىغىچە شۇ ھالەتتە تۇردى»\+bd* ــ «بېشارەت بېرىۋاتقان» ئىبرانىي تىلىدا «پەيغەمبەرچىلىق قىلىۋاتقان» دېگەن ئىبارە بىلەن ئىپادىلىنىدۇ. «كەچلىك قۇربانلىق» چۈشتىن كېيىن سائەت ئۈچلەردە بولاتتى.\f*   
\m
\v 30 ئىلىياس ھەممە خەلققە: ــ يېنىمغا يېقىن كېلىڭلار، دېدى. ھەممە خەلق ئۇنىڭغا يېقىن كەلگەندىن كېيىن ئۇ پەرۋەردىگارنىڭ شۇ يەردىكى يىقىتىلغان قۇربانگاھىنى قايتىدىن قۇرۇپ چىقتى.  
\v 31 ئىلىياس ئون ئىككى تاشنى ئالدى. بۇ تاشلارنىڭ سانى پەرۋەردىگارنىڭ «نامىڭ ئىسرائىل بولسۇن» دېگەن سۆزىنى تاپشۇرۇۋالغان ياقۇپنىڭ ئوغۇللىرىدىن چىققان قەبىلىلەرنىڭ سانى بىلەن ئوخشاش ئىدى. \x ◘ \xo 18:31 \xt يار. 32‏:27؛ يە. 4‏:5، 20؛ 2پاد. 17‏:34\x*  
\v 32 شۇ تاشلاردىن ئۇ پەرۋەردىگارنىڭ نامى بىلەن بىر قۇربانگاھنى ياسىدى. ئۇ قۇربانگاھنىڭ چۆرىسىدە ئىككى سېئاھ دان پاتقۇدەك ئازگال كولىدى. \f ◼ \fr 18:32 \ft \+bd «ئىككى سېئاھ»\+bd* ــ بىر سېئاھ بەلكىم 13.5 لىتر ئىدى، 2 سېئاھ 27 لىتر.\f*  
\v 33 ئاندىن ئۇ ئوتۇننى راستلاپ، بۇقىنى پارچىلاپ ئوتۇننىڭ تۆپىسىگە قويدى.   
\m
\v 34 ئۇ: ــ تۆت ئىدىشنى سۇغا توشقۇزۇپ ئۇنى كۆيدۈرمە قۇربانلىق ۋە ئوتۇننىڭ ئۈستىگە تۆكۈڭلار، ــ دېدى. ئاندىن: «يەنە بىر قېتىم قىلىڭلار» ــ دېۋىدى، ئۇلار شۇنداق قىلدى. ئۇ يەنە: ــ ئۈچىنچى مەرتىۋە شۇنداق قىلىڭلار، دېدى. ئۇلار ئۈچىنچى مەرتىۋە شۇنداق قىلغاندا  
\v 35 سۇ قۇربانگاھنىڭ چۆرىسىدىن ئېقىپ چۈشۈپ، كولانغان ئازگالنىمۇ سۇ بىلەن تولدۇردى.   
\m
\v 36 كەچلىك قۇربانلىقنىڭ ۋاقتى كەلگەندە ئىلىياس پەيغەمبەر قۇربانلىققا يېقىن كېلىپ مۇنداق دۇئا قىلدى: ــ ئەي پەرۋەردىگار، ئىبراھىم بىلەن ئىسھاق ۋە ئىسرائىلنىڭ خۇداسى، ئۆزۈڭنىڭ ئىسرائىلدا خۇدا بولغىنىڭنى ئاشكارا قىلغايسەن، شۇنداقلا مېنىڭ سېنىڭ قۇلۇڭ بولۇپ بۇلارنىڭ ھەممىسىنى بۇيرۇقۇڭ بىلەن قىلغانلىقىمنى بۈگۈن بىلدۈرگەيسەن. \x ◘ \xo 18:36 \xt مىس. 3‏:6؛ مات. 22‏:32؛ مار. 12‏:26؛ لۇقا 20‏:37؛ روس. 7‏:32\x*  
\v 37 ماڭا ئىجابەت قىلغايسەن، ئەي پەرۋەردىگار، ئىجابەت قىلغايسەن؛ شۇنىڭ بىلەن بۇ خەلققە سەن پەرۋەردىگارنىڭ خۇدا ئىكەنلىكىڭنى ھەمدە ئۇلارنىڭ قەلبلىرىنى توغرا يولغا ياندۇرغۇچى ئۆزۈڭ ئىكەنلىكىڭنى بىلدۈرگەيسەن، دېدى.   
\m
\v 38 شۇنىڭ بىلەن پەرۋەردىگارنىڭ ئوتى چۈشۈپ كۆيدۈرمە قۇربانلىقنى، ئوتۇننى، تاشلارنى ۋە توپىنى كۆيدۈرۈپ ئازگالدىكى سۇنىمۇ يوقىتىۋەتتى.   
\m
\v 39 خەلقلەرنىڭ ھەممىسى بۇنى كۆرۈپلا، ئۇلار دۈم يىقىلىپ: ــ پەرۋەردىگار، ئۇ خۇدادۇر، پەرۋەردىگار، ئۇ خۇدادۇر، دېيىشتى.   
\m
\v 40 ئىلىياس خەلققە بۇيرۇپ: ــ بائالنىڭ پەيغەمبەرلىرىنى تۇتۇڭلار، ھېچقايسىنى قويۇپ بەرمەڭلار، ــ دېدى. ئۇلار ئۇلارنى تۇتقاندا ئىلىياس ئۇلارنى كىشۇن جىلغىسىغا ئېلىپ بېرىپ، ئۇ يەردە قەتل قىلدۇردى.   
\m
\v 41 ئىلىياس ئاھابقا بولسا: ــ چىقىپ يەپ-ئىچكىن. چۈنكى قاتتىق يامغۇرنىڭ شالدىرلىغان ئاۋازى ئاڭلانماقتا، ــ دېدى.   
\m
\v 42 ئاھاب قوپۇپ يەپ-ئىچىش ئۈچۈن چىقتى. ئەمما ئىلىياس كارمەلنىڭ چوققىسىغا چىقىپ يەرگە ئېڭىشىپ، بېشىنى تىزىنىڭ ئوتتۇرىسىغا قويۇپ تىزلىنىپ  
\v 43 خىزمەتكارىغا: ــ چىقىپ دېڭىز تەرەپكە قارىغىن، دېدى. ئۇ چىقىپ سەپسېلىپ قاراپ: ــ ھېچنەرسە كۆرۈنمەيدۇ، دېدى. ئۇ جەمئىي يەتتە قېتىم: ــ بېرىپ قاراپ باققىن، دەپ بۇيرۇدى.   
\m
\v 44 يەتتىنچى قېتىم كەلگەندە ئۇ: ــ مانا، دېڭىزدىن چىقىۋاتقان، ئادەم ئالىقىنىدەك كىچىك بىر بۇلۇتنى كۆردۇم ــ دېدى. ئىلىياس ئۇنىڭغا: ــ چىقىپ ئاھابقا: ــ «ھارۋىنى قېتىپ تۆۋەنگە چۈشكىن، بولمىسا يامغۇر سېنى توسۇۋالىدۇ»، دەپ ئېيتقىن، ــ دېدى.   
\m
\v 45 ئاڭغۇچە ئاسمان بۇلۇت بىلەن تۇتۇلۇپ، بوران چىقىپ قاتتىق بىر يامغۇر ياغدى. ئاھاب ھارۋىغا چىقىپ يىزرەئەلگە كەتتى.  
\v 46 پەرۋەردىگارنىڭ قولى ئىلىياسنىڭ ۋۇجۇدىدا تۇرغاچ، ئۇ بېلىنى باغلاپ ئاھابنىڭ ئالدىدا يىزرەئەلنىڭ كىرىش ئېغىزىغىچە يۈگۈرۈپ ماڭدى.   
\b  
\b  
\m  
\c 19
\s1 ئىلىياس پەيغەمبەر يىزەبەلدىن قاچىدۇ  
\m
\v 1 لېكىن ئاھاب ئىلىياسنىڭ ھەممە قىلغىنىنى، جۈملىدىن ھەممە پەيغەمبەرلەرنى قىلىچلاپ ئۆلتۈرگىنىنى يىزەبەلگە ئېيتىپ بەردى.   
\m
\v 2 يىزەبەل بولسا ئىلىياسقا بىر خەۋەرچى ئەۋەتىپ: ــ ئەگەر ئەتە مۇشۇ ۋاقىتقىچە سەن شۇلارنىڭ جانلىرىغا قىلغىنىڭدەك مەن سېنىڭ جېنىڭنى ئوخشاش قىلمىسام، ئىلاھلار ماڭىمۇ شۇنداق قىلسۇن ھەمدە ئۇنىڭدىنمۇ زىيادە قىلسۇن! ــ دەپ ئېيتقۇزدى.   
\m
\v 3 ئۇ بۇنى بىلگەندە، ئۆز جېنىنى قۇتقۇزماق ئۈچۈن قېچىپ يەھۇدا تەۋەسىدىكى بەئەر-شېباغا باردى. ئۇ ئۇ يەردە ئۆز خىزمەتكارىنى قالدۇرۇپ قويۇپ،  
\v 4 ئۆزى چۆلنىڭ ئىچىگە قاراپ بىر كۈن يول ماڭدى. ئۇ ئۇ يەردىكى بىر شىۋاقنىڭ قېشىغا كېلىپ ئۇنىڭ ئاستىدا ئولتۇرۇپ، ئۆزىنىڭ ئۆلۈمىگە تىلەك تىلەپ: ــ ئى پەرۋەردىگار ئەمدى بولدى، جېنىمنى ئالغىن؛ نېمىلا دېگەنبىلەن مەن ئاتا-بوۋىلىرىمدىن ئارتۇق ئەمەسمەن، ــ دېدى.   
\m
\v 5 ئۇ شۇ شىۋاق ئاستىدا يېتىپ ئۇخلاپ قالدى. مانا بىر پەرىشتە ئۇنى نوقۇپ ئۇنىڭغا: ــ قوپۇپ، نان يېگىن، دېدى.   
\m
\v 6 ئۇ قارىسا بېشىدا قىزىق چوغلاردا پىشىۋاتقان بىر پوشكال ۋە بىر كوزا سۇ تۇراتتى. ئۇ يەپ-ئىچىپ يەنە ئۇخلىغىلى ياتتى.  
\v 7 ئاندىن پەرۋەردىگارنىڭ پەرىشتىسى يەنە كېلىپ ئىككىنچى قېتىم ئۇنى نوقۇپ ئۇنىڭغا: ــ قوپۇپ نان يېگىن. بولمىسا يولۇڭنىڭ ئېغىرىنى كۆتۈرەلمەيسەن، دېدى.   
\m
\v 8 ئۇ قوپۇپ يەپ-ئىچتى. شۇ تائامدىن ئالغان قۇۋۋەت بىلەن ئۇ قىرىق كېچە-كۈندۈز مېڭىپ خۇدانىڭ تېغى ھورەبگە يېتىپ باردى. \f ◼ \fr 19:8 \ft \+bd «خۇدانىڭ تېغى ھورەب»\+bd* ــ «ھورەب تېغى» دەل پاران چۆل-باياۋانىغا جايلاشقان، مۇسا پەيغەمبەر تۇرۇپ ئىسرائىل ئۈچۈن «تەۋرات قانۇنى»نى قوبۇل قىلغان «سىناي تېغى»دۇر.\f*  \x ◘ \xo 19:8 \xt مىس. 34‏:28؛ مات. 4‏:2\x*  
\v 9 ئۇ ئۇ يەردىكى غارغا كىرىپ قوندى. ۋە مانا، پەرۋەردىگارنىڭ سۆزى ئۇنىڭغا كېلىپ مۇنداق دېگەندە: ــ ئى ئىلىياس، بۇ يەردە نېمە قىلىۋاتىسەن؟ \f ◼ \fr 19:9 \ft \+bd «ئۇ ئۇ يەردىكى غارغا كىرىپ قوندى»\+bd* ــ ئىبرانىي تىلىدا «ئۇ \+bd ئاشۇ\+bd* غارغا كىرىپ قوندى» دېيىلىدۇ. «ئاشۇ غار» دېگەن سۆزگە قارىغاندا ئويلايمىزكى، بۇ غار تونۇش بىر جاي بولسا كېرەك. يەھۇدىي ئۆلىمىلار بۇ غارنى خۇدا مۇسا پەيغەمبەرنى يوشۇرۇپ قويغان جاي ئىدى دەپ قارايتتى، بىز بۇ پىكىرگە قايىلمىز («مىس.» 21:33-22نى كۆرۈڭ).\f*   
\m
\v 10 ئۇ جاۋاب بېرىپ: ــ ساماۋى قوشۇنلارنىڭ سەردارى بولغان خۇدا پەرۋەردىگار ئۈچۈن زور ئوتلۇق مۇھەببەت بىلەن ھەسەت قىلدىم. چۈنكى ئىسرائىللار سېنىڭ ئەھدەڭنى تاشلاپ قۇربانگاھلىرىڭنى يىقىتىپ، سېنىڭ پەيغەمبەرلىرىڭنى قىلىچ بىلەن ئۆلتۈردى. مەن، يالغۇز مەنلا قالدىم ۋە ئۇلار مېنىڭ جېنىمنى ئالغىلى قەستلەۋاتىدۇ، دېدى. \f ◼ \fr 19:10 \ft \+bd «پەرۋەردىگار ئۈچۈن زور ئوتلۇق مۇھەببەت بىلەن ھەسەت قىلدىم»\+bd* ــ دېمىسەكمۇ، ئىلىياسنىڭ: «ئوتلۇق مۇھەببەت بىلەن ھەسەت قىلدىم» دېگىنى ئۆزىنىڭ ئىسرائىلنىڭ خۇداغا ئەمەس، بەلكى تۈرلۈك يىرگىنچلىك بۇتلارغا ئىبادەت قىلغانلىقىغا قاراپ «ئىبادەت پەقەت خۇداغىلا مەنسۇپ بولۇش كېرەك» دەپ بۇتلارغا ياكى بۇتلارنىڭ كەينىدە تۇرۇۋاتقان جىن-شەيتانلارغا ۋە ئۇلارنىڭ ۋەكىلى بولغان ساختا پەيغەمبەرلەرگە بولغان ھەسىتىنى كۆرسىتىدۇ.\f*  \x ◘ \xo 19:10 \xt رىم. 11‏:3\x*   
\m
\v 11 ئۇ ئۇنىڭغا: ــ چىقىپ، پەرۋەردىگارنىڭ ئالدىدا تاغدا تۇرغىن، دېدى. مانا، پەرۋەردىگار ئۆتۈپ كېتىۋاتاتتى؛ \add ئۇنىڭ ئالدىدا\add* زور كۈچلۈك بىر شامال چىقىپ، تاغلارنى سۇندۇرۇپ، قورام تاشلارنى پارچىلاپ چېقىۋەتتى. لېكىن پەرۋەردىگار شامالدا ئەمەس ئىدى. شامالدىن كېيىن بىر يەر تەۋرەش بولدى. لېكىن پەرۋەردىگار يەر تەۋرەشتە ئەمەس ئىدى.  
\v 12 يەر تەۋرەشتىن كېيىن بىر لاۋۇلدىغان ئوت كۆتۈرۈلدى. لېكىن پەرۋەردىگار ئوتتا ئەمەس ئىدى. ئوتتىن كېيىن بوشقىنا، مۇلايىم بىر ئاۋاز ئاڭلاندى. \f ◼ \fr 19:12 \ft \+bd «بوشقىنا، مۇلايىم بىر ئاۋاز ئاڭلاندى»\+bd* ــ ياكى «يېنىك، بوش بىر تىنىش ئاۋاز ئاڭلاندى».\f*   
\m
\v 13 ۋە شۇنداق بولدىكى، ئىلىياس شۇنى ئاڭلاپ، يۈزىنى يېپىنچىسى بىلەن ئوراپ غارنىڭ ئاغزىغا بېرىپ تۇردى. مانا، بىر ئاۋاز چىقىپ ئۇنىڭغا: ــ ئى ئىلىياس، سەن بۇ يەردە نېمە قىلىۋاتىسەن؟ ــ دېدى.   
\m
\v 14 ئۇ جاۋاب بېرىپ: ــ ساماۋى قوشۇنلارنىڭ سەردارى بولغان خۇدا پەرۋەردىگار ئۈچۈن زور ئوتلۇق مۇھەببەت بىلەن ھەسەت قىلدىم. چۈنكى ئىسرائىللار سېنىڭ ئەھدەڭنى تاشلاپ قۇربانگاھلىرىڭنى يىقىتىپ، سېنىڭ پەيغەمبەرلىرىڭنى قىلىچ بىلەن ئۆلتۈردى. مەن يالغۇز مەنلا قالدىم ۋە ئۇلار مېنىڭ جېنىمنى ئالغىلى قەستلەۋاتىدۇ، دېدى.   
\m
\v 15 پەرۋەردىگار ئۇنىڭغا مۇنداق دېدى: ــ «بارغىن، كەلگەن يولۇڭ بىلەن قايتىپ، ئاندىن دەمەشقنىڭ چۆلىگە بارغىن. ئۇ يەرگە بارغاندا ھازائەلنى سۇرىيە ئۈستىگە پادىشاھ بولۇشقا مەسىھ قىلغىن. \f ◼ \fr 19:15 \ft \+bd «ھازائەلنى سۇرىيە ئۈستىگە پادىشاھ بولۇشقا مەسىھ قىلغىن»\+bd* ــ «مەسىھ قىلىش» توغرىسىدا 34:1دىكى ئىزاھاتنى كۆرۈڭ.\f*  
\v 16 ئاندىن نىمشىنىڭ ئوغلى يەھۇنى ئىسرائىلنىڭ ئۈستىگە پادىشاھ بولۇشقا مەسىھ قىلغىن؛ ئۆز ئورنۇڭغا پەيغەمبەر بولۇشقا ئابەل-مەھولاھلىق شافاتنىڭ ئوغلى ئېلىشانىمۇ مەسىھ قىلغىن.  
\v 17 ۋە شۇنداق بولىدۇكى، ھازائەلنىڭ قىلىچىدىن قېچىپ قۇتۇلغان ھەربىرىنى يەھۇ ئۆلتۈرىدۇ؛ يەھۇنىڭ قىلىچىدىن قېچىپ قۇتۇلغان ھەربىرىنى ئېلىشا ئۆلتۈرىدۇ. \x ◘ \xo 19:17 \xt 2پاد. 9‏:14-37\x*  
\v 18 لېكىن ئىسرائىلدا يەتتە مىڭ كىشىنى، يەنى بائالنىڭ ئالدىدا تىزلىرىنى پۈكمىگەن ۋە ئۇنىڭغا ئاغزىنى سۆيگۈزمىگەن ھەربىرىنى ئۆزۈمگە ساقلاپ قالدۇردۇم». \f ◼ \fr 19:18 \ft \+bd «ئۇنىڭغا ئاغزىنى سۆيگۈزمىگەن ھەربىرىنى ئۆزۈمگە ساقلاپ قالدۇردۇم»\+bd* ــ خۇدانىڭ ئىلىياس پەيغەمبەرگە ئېيتقان سۆزلىرىنىڭ ئەھمىيىتى، شۇنداقلا ئىلىياسنىڭ ھورەب تېغىغا سەپىرىنىڭ مەقسىتى توغرۇلۇق «قوشۇمچە سۆز»ىمىزنى كۆرۈڭ.\f*  \x ◘ \xo 19:18 \xt رىم. 11‏:4\x*   
\m
\v 19 ئۇ ئۇ يەردىن چىقىپ، شافاتنىڭ ئوغلى ئېلىشانى تاپتى. ئۇ چاغدا ئۇ يەر ھەيدەۋاتاتتى؛ ئۇنىڭ ئالدىدا ئون ئىككى جۈپ ئۇي بار ئىدى، ئۇ ئون ئىككىنچىسى بىلەن قوش ھەيدەۋاتاتتى. ئىلىياس كېلىپ ئۇنىڭ ئۈستىگە ئۆز يېپىنچىسىنى تاشلاپ ئارتىپ قويدى. \f ◼ \fr 19:19 \ft \+bd « \+bdit ئىلىياس\+bdit*... شافاتنىڭ ئوغلى ئېلىشانى تاپتى... ئۇنىڭ ئۈستىگە ئۆز يېپىنچىسىنى تاشلاپ ئارتىپ قويدى»\+bd* ــ ئىلىياس مۇشۇ ھەرىكىتى بىلەن «سەن ئېلىشاغا پەيغەمبەرلىك خىزمىتىم تاپشۇرۇلدى» دېگەندەك ئىدى.\f*  
\v 20 ئۇ ئۇيلارنى تاشلاپ ئىلىياسنىڭ كەينىدىن يۈگۈرۈپ كېلىپ: ــ مېنى بېرىپ ئاتام بىلەن ئانامنى سۆيگىلى قويغىن، ئاندىن مەن كېلىپ ساڭا ئەگىشەي، ــ دېدى. ئۇ ئۇنىڭغا: ــ قايتقىن؛ مەن ساڭا نېمە قىلدىم؟ ــ دېدى. \f ◼ \fr 19:20 \ft \+bd «قايتقىن؛ مەن ساڭا نېمە قىلدىم؟»\+bd* ــ ئىلىياسنىڭ بۇ دېگىنى بەلكىم ئېلىشاغا: «پەيغەمبەرلىك يولى تەس، سېنىڭدە خۇدانىڭ چاقىرىقى بولمىسا ماڭا ھەرگىز ئەگەشمە!» دېگەندەك بىر ئاگاھ بولۇشى مۇمكىن. «پادىشاھلار (2)» 2-بابتا ئىلىياس ئېلىشاغا يەنە بۇنىڭغا ئوخشاپ كېتىدىغان سۆزنى قىلىدۇ.\f*   
\m
\v 21 ئۇ ئۇنىڭدىن ئايرىلىپ، ئۆزى ئىشلەتكەن بىر جۈپ ئۇينى سويۇپ، ئۇلارنىڭ جابدۇقىنى ئوتۇن قىلىپ، گۆشىنى پىشۇرۇپ خەلققە بېرىۋىدى، ئۇلار يېدى. ئاندىن ئۇ ئورنىدىن قوپۇپ ئىلىياسنىڭ كەينىدىن ئەگىشىپ، ئۇنىڭ خىزمىتىدە بولدى.   
\b  
\b  
\m  
\c 20
\s1 خۇدا ئىسرائىلنى سۇرىيەدىن قۇتقۇزىدۇ  
\m
\v 1 سۇرىيەنىڭ پادىشاھى بەن-ھاداد پۈتكۈل قوشۇنىنى جەم قىلدى؛ ئۇ ئوتتۇز ئىككى پادىشاھنى ئات ۋە جەڭ ھارۋىلىرى بىلەن ئېلىپ چىقىپ، سامارىيەگە قورشاپ ھۇجۇم قىلدى.  
\v 2 ئۇ ئەلچىلەرنى شەھەرگە كىرگۈزۈپ ئىسرائىلنىڭ پادىشاھى ئاھابنىڭ قېشىغا ئەۋەتىپ ئۇنىڭغا: ــ  
\v 3 «بەن-ھاداد مۇنداق دەيدۇ: ــ سېنىڭ كۈمۈش بىلەن ئالتۇنۇڭ، سېنىڭ ئەڭ چىرايلىق خوتۇنلىرىڭ بىلەن بالىلىرىڭمۇ مېنىڭكىدۇر» دەپ يەتكۈزدى.   
\m
\v 4 ئىسرائىلنىڭ پادىشاھى ئۇنىڭغا: ــ ئى غوجام پادىشاھ، سىلى ئېيتقانلىرىدەك مەن ئۆزۈم ۋە بارلىقىم سىلىنىڭكىدۇر، دەپ جاۋاب بەردى.   
\m
\v 5 ئەلچىلەر يەنە كېلىپ: ــ «بەن-ھاداد سۆز قىلىپ مۇنداق دەيدۇ: ــ ساڭا دەرۋەقە: ــ سېنىڭ كۈمۈش بىلەن ئالتۇنۇڭنى، سېنىڭ خوتۇنلىرىڭ بىلەن بالىلىرىڭنى ماڭا تاپشۇرۇپ بېرىسەن، دېگەن خەۋەرنى ئەۋەتتىم.  
\v 6 لېكىن ئەتە مۇشۇ ۋاقىتلاردا خىزمەتكارلىرىمنى يېنىڭغا ئەۋەتىمەن؛ ئۇلار ئورداڭ بىلەن خىزمەتكارلىرىڭنىڭ ئۆيلىرىنى ئاختۇرۇپ، سېنىڭ كۆزلىرىڭدە نېمە ئەزىز بولسا، ئۇلار شۇنى قولىغا ئېلىپ كېلىدۇ» ــ دېدى.   
\m
\v 7 ئۇ ۋاقىتتا ئىسرائىلنىڭ پادىشاھى زېمىندىكى ھەممە ئاقساقاللارنى چاقىرىپ ئۇلارغا: ــ بۇ كىشىنىڭ قانداق ئاۋارىچىلىك چىقارماقچى بولغانلىقىنى بىلىپ قېلىڭلار. ئۇ ماڭا خەۋەر ئەۋەتىپ مەندىن خوتۇنلىرىم بىلەن بالىلىرىم، كۈمۈش بىلەن ئالتۇنلىرىمنى تەلەپ قىلغىنىدا مەن ئۇنىڭغا ياق دېمىدىم، دېدى.   
\m
\v 8 بارلىق ئاقساقاللار بىلەن خەلقنىڭ ھەممىسى ئۇنىڭغا: ــ قۇلاق سالمىغىن، ئۇنىڭغا ماقۇل دېمىگىن، دېدى.   
\m
\v 9 بۇنىڭ بىلەن ئۇ بەن-ھادادنىڭ ئەلچىلىرىگە: ــ غوجام پادىشاھقا، سىلى ئادەم ئەۋەتىپ، ئۆز كەمىنىلىرىدىن دەسلەپتە سورىغاننىڭ ھەممىسىنى ئادا قىلىمەن؛ لېكىن كېيىنكىسىگە ماقۇل دېيەلمەيمەن، دەپ بېرىڭلار، ــ دېدى. ئەلچىلەر يېنىپ بېرىپ شۇ سۆزنى يەتكۈزدى.   
\m
\v 10 بەن-ھاداد ئۇنىڭغا يەنە خەۋەر ئەۋەتىپ: ــ «پۈتكۈل سامارىيە شەھىرىدە ماڭا ئەگەشكەنلەرنىڭ قوللىرىغا ئوچۇملىغۇدەك توپا قېلىپ قالسا، ئىلاھلار ماڭىمۇ شۇنداق قىلسۇن ۋە ئۇنىڭدىن ئاشۇرۇپ قىلسۇن!» ــ دېدى.   
\m
\v 11 لېكىن ئىسرائىلنىڭ پادىشاھى جاۋاب بېرىپ: ــ «ساۋۇت-قوراللار بىلەن جابدۇنغۇچى ساۋۇت-قوراللاردىن يېشىنگۈچىدەك ماختىنىپ كەتمىسۇن!» دەپ ئېيتىڭلار، ــ دېدى. \f ◼ \fr 20:11 \ft \+bd «ساۋۇت-قوراللار بىلەن جابدۇنغۇچى ساۋۇت-قوراللاردىن يېشىنگۈچىدىن ماختىنىپ كەتمىسۇن!»\+bd* ــ دېگەن ماقال-تەمسىلنىڭ مەنىسى بەلكىم «جەڭ ئالدىدا تۇرۇپ ئۆزۈڭنى غەلىبىچى سانىما» ــ «چۈچۈرىنى خام سانىما» دېگەندەك.\f*   
\m
\v 12 بەن-ھاداد بۇ سۆزنى ئاڭلىغاندا ھەرقايسى پادىشاھلار بىلەن چېدىرلىرىدا شاراب ئىچىشىۋاتاتتى. ئۇ خىزمەتكارلىرىغا: ــ سەپكە تىزىلىڭلار، دېدى. شۇنى دېۋىدى، ئۇلار شەھەرگە ھۇجۇم قىلىشقا تىزىلىشتى.   
\b  
\m  
\s1 پەرۋەردىگار ئىسرائىلنى قۇتقۇزىدۇ  
\m
\v 13 ئۇ ۋاقىتتا بىر پەيغەمبەر ئىسرائىلنىڭ پادىشاھى ئاھابنىڭ قېشىغا كېلىپ: ــ پەرۋەردىگار مۇنداق دەيدۇ: ــ «بۇ زور بىر توپ ئادەمنى كۆردۈڭمۇ؟ مانا، مەن بۇ كۈنى ئۇلارنى سېنىڭ قولۇڭغا تاپشۇرىمەن؛ شۇنىڭ بىلەن سەن مېنىڭ پەرۋەردىگار ئىكەنلىكىمنى بىلىسەن»، دېدى.   
\m
\v 14 ئاھاب: ــ كىمنىڭ ۋاسىتىسى بىلەن بولىدۇ؟ دەپ سورىدى. ئۇ: ــ پەرۋەردىگار مۇنداق دەيدۇ: «ۋالىيلارنىڭ غۇلاملىرى بىلەن بولىدۇ»، دېدى. ئۇ يەنە: ــ كىم ھۇجۇمنى باشلايدۇ؟ ــ دەپ سورىدى. ئۇ: ــ سەن ئۆزۈڭ، دېدى.   
\m
\v 15 ئۇ ۋاقىتتا ۋالىيلارنىڭ غۇلاملىرىنى سانىۋىدى، ئۇلارنىڭ سانى ئىككى يۈز ئوتتۇز ئىككى نەپەر چىقتى. ئاندىن كېيىن ئۇ ھەممە خەلقنى، يەنى بارلىق ئىسرائىللارنى سانىۋىدى، ئۇلارنىڭ سانى يەتتە مىڭ نەپەر چىقتى.  
\v 16 ئىسرائىللار شەھەردىن چۈش ۋاقتىدا چىقتى. بەن-ھاداد بىلەن شۇ پادىشاھلار، يەنى ياردەمگە كەلگەن ئوتتۇز ئىككى پادىشاھ بولسا چېدىرلىرىدا شاراب ئىچىپ مەست بولۇشقانىدى.  
\v 17 ۋالىيلارنىڭ غۇلاملىرى يۈرۈشتە ئاۋۋال ماڭدى. بەن-ھاداد ئادەم ئەۋەتىۋىدى، ئۇلار ئۇنىڭغا خەۋەر بېرىپ: ــ «سامارىيەدىن ئادەملەر كېلىۋاتىدۇ» ــ دېدى.   
\m
\v 18 ئۇ: ــ ئەگەر سۈلھى تۈزۈشكە چىققان بولسا ئۇلارنى تىرىك تۇتۇڭلار، ئەگەر سوقۇشقىلى چىققان بولسىمۇ ئۇلارنى تىرىك تۇتۇڭلار، دېدى.   
\m
\v 19 ئەمدى ۋالىيلارنىڭ بۇ غۇلاملىرى ۋە ئۇلارنىڭ كەينىدىكى قوشۇن شەھەردىن چىقىپ،  
\v 20 ھەربىرى ئۆزىگە ئۇچرىغان ئادەمنى چېپىپ ئۆلتۈردى. سۇرىيلەر قاچتى؛ ئىسرائىل ئۇلارنى قوغلىدى. سۇرىيەنىڭ پادىشاھى بەن-ھاداد بولسا ئاتقا مىنىپ ئاتلىقلار بىلەن قېچىپ قۇتۇلدى.  
\v 21 ئىسرائىلنىڭ پادىشاھى چىقىپ ھەم ئاتلىقلارنى ھەم جەڭ ھارۋىلىرىنى بىتچىت قىلىپ سۇرىيلەرنى قاتتىق قىر-چاپ قىلدى.   
\m
\v 22 پەيغەمبەر يەنە ئىسرائىلنىڭ پادىشاھىنىڭ قېشىغا كېلىپ ئۇنىڭغا: ــ ئۆزۈڭنى مۇستەھكەملەپ، ئۆزۈڭنى ئوبدان دەڭسەپ، نېمە قىلىشىڭ كېرەكلىكىنى ئويلاپ باققىن. چۈنكى كېلەر يىلى ئەتىيازدا سۇرىيەنىڭ پادىشاھى سەن بىلەن جەڭ قىلغىلى يەنە چىقىدۇ، دېدى.   
\m
\v 23 سۇرىيەنىڭ پادىشاھىنىڭ خىزمەتكارلىرى ئۇنىڭغا مۇنداق دېدى: ــ «ئۇلارنىڭ ئىلاھى تاغ ئىلاھى بولغاچقا، ئۇلار بىزگە كۈچلۈك كەلدى. لېكىن بىز تۈزلەڭلىكتە ئۇلار بىلەن سوقۇشساق، جەزمەن ئۇلارغا كۈچلۈك كېلىمىز.  
\v 24 ئەمدى شۇنداق قىلغايلىكى، پادىشاھلارنىڭ ھەربىرىنى ئۆز مەنسىپىدىن چۈشۈرۈپ، ئۇلارنىڭ ئورنىدا ۋالىيلارنى تىكلىگەيلا.  
\v 25 ئاندىن سىلى مەھرۇم بولغان قوشۇنلىرىغا باراۋەر بولغان يەنە بىر قوشۇننى، يەنى ئاتنىڭ ئورنىغا ئات، ھارۋىنىڭ ئورنىغا ھارۋا تەييار قىلدۇرۇپ ئۆزلىرىگە يىغقايلا؛ بىز تۈزلەڭلىكتە ئۇلار بىلەن سوقۇشايلى؛ شۇنىڭ بىلەن ئۇلارغا كۈچلۈك كەلمەمدۇق؟». ئۇ ئۇلارنىڭ سۆزىگە قۇلاق سېلىپ شۇنداق قىلدى.   
\m
\v 26 كېيىنكى يىلى ئەتىيازدا بەن-ھاداد سۇرىيلەرنى ئېدىتلاپ تولۇق يىغىپ، ئىسرائىل بىلەن جەڭ قىلغىلى ئافەك شەھىرىگە چىقتى.  
\v 27 ئىسرائىللارمۇ ئۆزلىرىنى ئېدىتلاپ، ئوزۇق-تۈلۈك تەييارلاپ، ئۇلار بىلەن جەڭ قىلىشقا چىقتى. ئىسرائىللار ئۇلارنىڭ ئۇدۇلىدا بارگاھ تىكلىۋىدى، سۇرىيلەرنىڭ ئالدىدا خۇددى ئىككى توپ كىچىك ئوغلاق پادىسىدەك كۆرۈندى. لېكىن سۇرىيلەر پۈتكۈل زېمىننى قاپلىغانىدى.   
\m
\v 28 ئەمما خۇدانىڭ ئادىمى ئىسرائىلنىڭ پادىشاھىنىڭ قېشىغا كېلىپ ئۇنىڭغا: ــ پەرۋەردىگار مۇنداق دەيدۇ: ــ «سۇرىيلەر: پەرۋەردىگار تاغ ئىلاھىدۇر، جىلغىلارنىڭ ئىلاھى ئەمەس، دەپ ئېيتقىنى ئۈچۈن، مەن بۇ زور بىر توپ ئادەمنىڭ ھەممىسىنى سېنىڭ قولۇڭغا تاپشۇرىمەن؛ شۇنىڭ بىلەن سىلەر مېنىڭ پەرۋەردىگار ئىكەنلىكىمنى بىلىپ يېتىسىلەر»، دېدى.   
\m
\v 29 ئىككى تەرەپ يەتتە كۈن بىر-بىرىنىڭ ئۇدۇلىدا بارگاھلىرىدا تۇردى. يەتتىنچى كۈنى سوقۇش باشلاندى. ئىسرائىللار بىر كۈندە سۇرىيلەردىن يۈز مىڭ پىيادە ئەسكەرنى ئۆلتۈردى.  
\v 30 قالغانلار ئافەك شەھىرىگە قېچىپ كىرىۋالدى؛ لېكىن سېپىلى ئۆرۈلۈپ ئۇلاردىن يىگىرمە يەتتە مىڭ ئادەمنىڭ ئۈستىگە چۈشۈپ بېسىپ ئۆلتۈردى. بەن-ھاداد ئۆزى بەدەر قېچىپ شەھەرگە كىرىپ ئىچكىرىدىكى بىر ئۆيگە مۆكۈۋالدى.   
\m
\v 31 خىزمەتكارلىرى ئۇنىڭغا: ــ مانا بىز ئىسرائىلنىڭ پادىشاھلىرىنى رەھىملىك پادىشاھلار دەپ ئاڭلىدۇق؛ شۇنىڭ ئۈچۈن بەللىرىمىزگە بۆز باغلاپ باشلىرىمىزغا كۇلا يۆگەپ ئىسرائىلنىڭ پادىشاھىغا تەسلىمگە چىقايلى. ئۇ سىلىنىڭ جانلىرىنى ئايارمىكىن؟ ــ دېدى.  
\v 32 شۇنىڭ بىلەن ئۇلار بەللىرىگە بۆز باغلاپ باشلىرىغا كۇلا يۆگەپ ئىسرائىلنىڭ پادىشاھىنىڭ قېشىغا بېرىپ ئۇنىڭغا: ــ كەمىنىلىرى بەن-ھاداد: «جېنىمنى ئايىغايلا»، دەپ ئىلتىجا قىلدى، دېدى. ئۇ بولسا: ــ ئۇ تېخى ھاياتمۇ؟ ئۇ مېنىڭ بۇرادىرىم، دېدى.   
\m
\v 33 بۇ ئادەملەر بۇ سۆزنى ياخشىلىقنىڭ ئالامىتى، دەپ ئويلاپ، دەرھاللا ئۇنىڭ بۇ سۆزىنى چىڭ تۇتۇۋېلىپ: ــ بەن-ھاداد سىلىنىڭ بۇرادەرلىرىدۇر! ــ دېدى. ئۇ: ــ ئۇنى ئېلىپ كېلىڭلار، دەپ بۇيرۇدى. شۇنىڭ بىلەن بەن-ھاداد ئۇنىڭ قېشىغا چىقتى؛ شۇنىڭ بىلەن ئۇ ئۇنى قولىدىن تارتىپ جەڭ ھارۋىسىغا چىقاردى.   
\m
\v 34 بەن-ھاداد ئۇنىڭغا: ــ مېنىڭ ئاتام سىلىنىڭ ئاتىلىرىدىن ئالغان شەھەرلەرنى سىلىگە قايتۇرۇپ بېرەي. ئاتام سامارىيەدە رەستە-بازارلىرىنى تىكلىگەندەك سىلى ئۆزلىرى ئۈچۈن دەمەشقتە رەستە-بازارلارنى تىكلەيلا، ــ دېدى. ئاھاب: ــ بۇ شەرت بىلەن سېنى قويۇپ بېرەي، دېدى. شۇنىڭ بىلەن ئىككىسى ئەھدە قىلىشتى ۋە ئۇ ئۇنى قويۇپ بەردى.   
\m
\v 35 پەيغەمبەرلەرنىڭ شاگىرتلىرىنىڭ بىرى پەرۋەردىگارنىڭ بۇيرۇقى بىلەن يەنە بىرىگە: ــ سەندىن ئۆتۈنىمەن، مېنى ئۇرغىن، دېدى. لېكىن ئۇ ئادەم ئۇنى ئۇرغىلى ئۇنىمىدى. \f ◼ \fr 20:35 \ft \+bd «پەيغەمبەرلەرنىڭ شاگىرتلىرى»\+bd* ــ بۇ ئىبارە سۆز ئىبرانىي تىلىدا «پەيغەمبەرلەرنىڭ ئوغۇللىرى» دېگەنلىك بىلەن ئىپادىلىنىدۇ.\f*  
\v 36 شۇنىڭ بىلەن ئۇ ئۇنىڭغا: ــ سەن پەرۋەردىگارنىڭ سۆزىنى ئاڭلىمىغىنىڭ ئۈچۈن مانا بۇ يەردىن كەتكىنىڭدە بىر شىر سېنى بوغۇپ ئۆلتۈرىدۇ، ــ دېدى. ئۇ ئۇنىڭ يېنىدىن چىققاندا، ئۇنىڭغا بىر شىر ئۇچراپ ئۇنى ئۆلتۈردى.   
\m
\v 37 ئاندىن كېيىن ئۇ يەنە بىر ئادەمنى تېپىپ ئۇنىڭغا: ــ سەندىن ئۆتۈنىمەن، مېنى ئۇرغىن، دېدى. ئۇ ئادەم ئۇنى قاتتىق ئۇرۇپ زەخىملەندۈردى.  
\v 38 ئاندىن پەيغەمبەر بېرىپ ئۆز قىياپىتىنى ئۆزگەرتىپ، كۆزلىرىنى تېڭىق بىلەن تېڭىپ يول بويىدا پادىشاھنى كۈتۈپ تۇردى.   
\m
\v 39 پادىشاھ شۇ يەردىن ئۆتكەندە ئۇ پادىشاھنى چاقىرىپ: ــ كەمىنىلىرى كەسكىن جەڭ مەيدانىغا چىققانىدىم، ۋە مانا، بىر ئادەم ماڭا بۇرۇلۇپ، بىر كىشىنى تاپشۇرۇپ: «بۇ كىشىگە چىڭ قارىغىن، ھەرقانداق سەۋەبتىن ئۇ يوقاپ كەتسە، سەن ئۆز جېنىڭنى ئۇنىڭ جېنىنىڭ ئورنىغا تۆلەيسەن؛ بولمىسا بىر تالانت كۈمۈش تۆلەيسەن»، دېدى.  
\v 40 لېكىن مەن كەمىنىلىرى ئۇ-بۇ ئىش بىلەن بەند بولۇپ كېتىپ، ئۇنى يوقىتىپ قويدۇم، دېدى. ئىسرائىلنىڭ پادىشاھى ئۇنىڭغا: ــ ئۆزۈڭ بېكىتكىنىڭدەك ساڭا ھۆكۈم قىلىنىدۇ! ــ دېدى.   
\m
\v 41 ئۇ دەرھال كۆزلىرىدىن تېڭىقنى ئېلىۋەتتى؛ ئىسرائىلنىڭ پادىشاھى ئۇنى تونۇپ ئۇنىڭ پەيغەمبەرلەردىن بىرى ئىكەنلىكىنى كۆردى.  
\v 42 پەيغەمبەر ئۇنىڭغا: ــ پەرۋەردىگار مۇنداق دەيدۇ: ــ «مەن ھالاكەتكە بېكىتكەن ئادەمنى قولۇڭدىن قۇتۇلغىلى قويغىنىڭ ئۈچۈن سېنىڭ جېنىڭ ئۇنىڭ جېنىنىڭ ئورنىدا ئېلىنىدۇ؛ سېنىڭ خەلقىڭ ئۇنىڭ خەلقىنىڭ ئورنىدا ئېلىنىدۇ»، دېدى. \x ◘ \xo 20:42 \xt 1پاد. 22‏:37، 38\x*   
\m
\v 43 شۇنىڭ بىلەن ئىسرائىلنىڭ پادىشاھى خاپا بولۇپ، غەشلىككە چۆمگەن ھالدا سامارىيەگە قايتىپ ئوردىسىغا كىردى.   
\b  
\b  
\m  
\c 21
\s1 ئاھاب قاتىللىق قىلىپ نابوتنى ئۆلتۈرىدۇ  
\m
\v 1 بۇ ئىشلاردىن كېيىن شۇنداق بولدىكى، يىزرەئەللىك نابوتنىڭ يىزرەئەلدە، سامارىيەنىڭ پادىشاھى ئاھابنىڭ ئوردىسىنىڭ يېنىدا بىر ئۈزۈمزارلىقى بار ئىدى.  
\v 2 ئاھاب نابوتقا سۆز قىلىپ: ــ ئۆز ئۈزۈمزارلىقىڭنى ماڭا بەرگىن، مېنىڭ ئۆيۈمگە يېقىن بولغاچ، ئۇنى بىر سەي-كۆكتاتلىق باغ قىلاي. ئۇنىڭ ئورنىدا ساڭا ئوبدانراق بىر ئۈزۈمزارلىق بېرەي ياكى لايىق كۆرسەڭ باھاسىنى نەق بېرىمەن، دېدى.   
\m
\v 3 ئەمما نابوت ئاھابقا: ــ پەرۋەردىگار مېنى ئاتا-بوۋىلىرىمنىڭ مىراسىنى ساڭا سېتىشنى مەندىن نېرى قىلسۇن، دېدى.   
\m
\v 4 ئاھاب يىزرەئەللىك نابوتنىڭ: «ئاتا-بوۋىلىرىمنىڭ مىراسىنى ساڭا بەرمەيمەن» دەپ ئېيتقان سۆزىدىن خاپا بولۇپ غەشلىككە چۆمگەن ھالدا ئوردىسىغا قايتتى؛ ئۇ كارىۋاتتا يېتىپ يۈزىنى \add تام\add* تەرەپكە ئۆرۈپ نانمۇ يېمىدى.  
\v 5 خوتۇنى يىزەبەل ئۇنىڭ قېشىغا كېلىپ: روھىي كەيپىياتىڭ نېمىشقا شۇنچە تۆۋەن، نېمىشقا نان يېمەيسەن؟ ــ دېدى.   
\m
\v 6 ئۇ ئۇنىڭغا: ــ مەن يىزرەئەللىك نابوتقا سۆز قىلىپ: «ئۈزۈمزارلىقىڭنى ماڭا پۇلغا بەرسەڭ، ياكى لايىق كۆرسەڭ ئۇنىڭ ئورنىغا باشقا ئۈزۈمزارلىق بېرەي» دېدىم. لېكىن ئۇ: «ساڭا ئۈزۈمزارلىقىمنى بەرمەيمەن» دېدى، ــ دېدى.   
\m
\v 7 خوتۇنى يىزەبەل ئۇنىڭغا: ــ سەن ھازىر ئىسرائىلنىڭ ئۈستىگە سەلتەنەت قىلغۇچى ئەمەسمۇ؟ قوپۇپ نان يەپ، كۆڭلۈڭنى خۇش قىلغىن؛ مەن ساڭا يىزرەئەللىك نابوتنىڭ ئۈزۈمزارلىقىنى ئېرىشتۈرىمەن، دېدى.   
\m
\v 8 ئاندىن ئۇ ئاھابنىڭ نامىدا بىر خەت يېزىپ، ئۈستىگە ئۇنىڭ مۆھۈرىنى بېسىپ، خەتنى نابوتنىڭ شەھىرىدە ئۇنىڭ بىلەن تۇرۇۋاتقان ئاقساقاللار ۋە مۆتىۋەرلەرگە ئەۋەتتى.  
\v 9 خەتتە ئۇ مۇنداق يازغانىدى: ــ «روزا تۇتۇش كېرەك دەپ بۇيرۇپ، خەلقنىڭ ئارىسىدا نابوتنى تۆردە ئولتۇرغۇزغىن؛  
\v 10 ئىككى ئادەمنى، يەنى بېلىيالنىڭ بالىسىنى ئۇنىڭ ئۇدۇلىدا ئولتۇرغۇزۇپ، ئۇلارنى نابوتنىڭ ئۈستىدىن ئەرز قىلغۇزۇپ: «سەن خۇداغا ۋە پادىشاھقا لەنەت ئوقۇدۇڭ» دەپ گۇۋاھلىق بەرگۈزۈڭلار. ئاندىن ئۇنى ئېلىپ چىقىپ چالما-كېسەك قىلىپ ئۆلتۈرۈڭلار». \f ◼ \fr 21:10 \ft \+bd «بېلىيالنىڭ بالىسى»\+bd* ــ ئىبرانىي تىلىدا «بېلىئال» ئىبلىسنىڭ (يەنى شەيتاننىڭ) يەنە بىر ئىسمى. دېمەك، بۇ سۆز تولىمۇ ئىپلاس ئادەمنى كۆرسىتىدۇ.\f*   
\m
\v 11 شەھەرنىڭ ئادەملىرى، يەنى ئۇنىڭ شەھىرىدە تۇرۇۋاتقان ئاقساقالار بىلەن مۆتىۋەرلەر يىزەبەلنىڭ ئۇلارغا ئەۋەتكەن خېتىدە پۈتۈلگەندەك قىلدى؛  
\v 12 ئۇلار روزىنى بۇيرۇپ، خەلقنىڭ ئارىسىدا نابوتنى تۆردە ئولتۇرغۇزدى.  
\v 13 ئاندىن ئۇ ئىككى ئادەم، يەنى بېلىيالنىڭ بالىلىرى خەلقنىڭ ئالدىدا نابوت ئۈستىدىن ئەرز قىلىپ: «نابوت خۇداغا ۋە پادىشاھقا دەشنەم قىلدى» دەپ گۇۋاھلىق بەردى. شۇنىڭ بىلەن ئۇلار نابوتنى شەھەرنىڭ تاشقىرىغا سۆرەپ ئېلىپ چىقىپ، تاشلار بىلەن چالما-كېسەك قىلىپ ئۆلتۈردى.  
\v 14 ئاندىن ئۇلار يىزەبەلگە ئادەم ئەۋەتىپ: «نابوت چالما-كېسەك قىلىپ ئۆلتۈرۈلدى» دەپ خەۋەر بەردى.   
\m
\v 15 يىزەبەل نابوتنىڭ چالما-كېسەك قىلىنىپ ئۆلتۈرۈلگەنلىكىنى ئاڭلىغاندا ئاھابقا: قوپۇپ، يىزرەئەللىك نابوتنىڭ ساڭا پۇلغا بەرگىلى ئۇنىمىغان ئۈزۈمزارلىقىنى تاپشۇرۇپ ئالغىن؛ چۈنكى نابوت ھايات ئەمەس، بەلكى ئۆلدى، دېدى.   
\m
\v 16 شۇنداق بولدىكى، ئاھاب نابوتنىڭ ئۆلگەنلىكىنى ئاڭلاپ، يىزرەئەللىك نابوتنىڭ ئۈزۈمزارلىقىنى ئىگىلەش ئۈچۈن شۇ يەرگە باردى.  
\v 17 لېكىن پەرۋەردىگارنىڭ سۆزى تىشبىلىق ئىلىياسقا كېلىپ مۇنداق دېگەندە: ــ  
\v 18 قوپۇپ بېرىپ، سامارىيەدە ئولتۇرۇشلۇق ئىسرائىل پادىشاھى ئاھاب بىلەن ئۇچراشقىن؛ مانا ئۇ نابوتنىڭ ئۈزۈمزارلىقىدا تۇرىدۇ؛ چۈنكى ئۇنى ئىگىلىۋېلىش ئۈچۈن ئۇ يەرگە باردى.  
\v 19 ئۇنىڭغا: ــ «ئادەم ئۆلتۈردۈڭمۇ، يېرىنى ئىگىلىۋالدىڭمۇ؟» ــ دېگىن. ئاندىن ئۇنىڭغا يەنە سۆز قىلىپ: ــ پەرۋەردىگار مۇنداق دەيدۇ: ــ «نابوتنىڭ قېنىنى ئىتلار يالىغان جايدا سېنىڭ قېنىڭنىمۇ ئىتلار يالايدۇ» ــ دېگىن».   
\m
\v 20 ئاھاب ئىلىياسقا: ــ ئى دۈشمىنىم، مېنى تاپتىڭمۇ؟ ــ دېدى. ئۇ جاۋابەن مۇنداق دېدى: ــ راست، مەن سېنى تاپتىم؛ چۈنكى سەن پەرۋەردىگارنىڭ نەزىرىدە رەزىللىك قىلىش ئۈچۈن ئۆزۈڭنى سېتىۋەتتىڭ.  
\v 21 پەرۋەردىگار: «مانا، مەن ئۈستۈڭگە بالا چۈشۈرۈپ نەسلىڭنى يوقىتىپ، سەن ئاھابنىڭ ئىسرائىلدا قالغان جەمەتىدىكى ھەممە ئەركەكنى، ھەتتا ئاجىز ياكى مېيىپ بولسۇن، ھەممىسىنى ئۈزۈپ يوقىتىمەن؛ \f ◼ \fr 21:21 \ft \+bd «مەن ... نەسلىڭنى يوقىتىپ،...»\+bd* ــ ياكى «مەن نەسلىڭنى...كۆيدۈرۈۋېتىپ،...». \+bd «ئاھابنىڭ ئىسرائىلدا قالغان جەمەتىدىكى ھەممە ئەركەك»\+bd* ــ ئىبرانىي تىلىدا: «ئاھابنىڭ ئىسرائىلدا قالغان جەمەتىدە، تامغا قاراپ سىيىدىغان ھەربىرى» دېگەنلىك بىلەن ئىپادىلىنىدۇ. \+bd «ھەتتا ئاجىز ياكى مېيىپ بولسۇن، ھەممىسىنى...»\+bd* ــ بۇنىڭ باشقا بىرخىل تەرجىمىسى: «ياكى قۇل ياكى ھۆر بولسۇن، ھەممىسىنى...».\f*  \x ◘ \xo 21:21 \xt 2پاد. 9‏:7، 8، 9\x*  
\v 22 ۋە سەن مېنىڭ غەزىپىمنى قوزغاپ ئىسرائىلنى گۇناھقا ئازدۇرغىنىڭ ئۈچۈن سېنىڭ جەمەتىڭنى نىباتنىڭ ئوغلى يەروبوئامنىڭ جەمەتى ۋە ئاخىياھنىڭ ئوغلى بائاشانىڭ جەمەتىگە ئوخشاش قىلىمەن» ــ دەيدۇ، ــ دېدى. \x ◘ \xo 21:22 \xt 1پاد. 15‏:29؛ 16‏:3، 11\x*   
\m
\v 23 ــ يىزەبەل توغرىسىدىمۇ پەرۋەردىگار سۆز قىلىپ: «يىزرەئەلنىڭ سېپىلىنىڭ تېشىدا ئىتلار يىزەبەلنى يەيدۇ. \x ◘ \xo 21:23 \xt 2پاد. 9‏:35-37\x*  
\v 24 ئاھابنىڭ جەمەتىدىكىلەردىن شەھەردە ئۆلگەنلەرنى ئىتلار يەيدۇ؛ سەھرادا ئۆلگەنلەرنى بولسا ئاسماندىكى قۇشلار يەيدۇ» دېدى  
\v 25 (بەرھەق، خوتۇنى يىزەبەلنىڭ قۇترىتىشلىرى بىلەن پەرۋەردىگارنىڭ نەزىرىدە رەزىللىك قىلغىلى ئۆزىنى ساتقان ئاھابدەك ھېچكىم يوق ئىدى. \x ◘ \xo 21:25 \xt 1پاد. 16‏:33\x*  
\v 26 ئۇ پەرۋەردىگار ئىسرائىللارنىڭ ئالدىدىن ھەيدەپ قوغلىۋەتكەن ئامورىيلارنىڭ قىلغىنىدەك قىلىپ، يىرگىنچلىك بۇتلارغا تايىنىپ ئەگىشىپ، لەنەتلىك ئىشلارنى قىلاتتى).   
\m
\v 27 لېكىن ئاھاب بۇ سۆزلەرنى ئاڭلىغاندا ئۆز كىيىملىرىنى يىرتىپ بەدىنىگە بۆز يۆگەپ، روزا تۇتتى. ئۇ بۆز رەختتە ياتاتتى، جىمجىت ماڭاتتى.   
\m
\v 28 ئۇ ۋاقىتتا پەرۋەردىگارنىڭ سۆزى تىشبىلىق ئىلىياسقا كېلىپ مۇنداق دېگەندە: ــ   
\m
\v 29 «ئاھابنىڭ مېنىڭ ئالدىمدا ئۆزىنى قانداق تۆۋەن تۇتۇۋاتقانلىقىنى كۆردۈڭمۇ؟ ئۇ ئۆزىنى مېنىڭ ئالدىمدا تۆۋەن تۇتۇۋاتقانلىقى تۈپەيلىدىن، بۇ بالانى ئۇنىڭ كۈنلىرىدە كەلتۈرمەيمەن، بەلكى ئۇنىڭ ئوغلىنىڭ كۈنلىرىدە ئۇنىڭ جەمەتىگە كەلتۈرىمەن».   
\b  
\b  
\m  
\c 22
\s1 ئاھاب جەڭدە ئۆلىدۇ  
\r 2تار. 18‏:2-34  
\m
\v 1 ئۈچ يىلغىچە سۇرىيە بىلەن ئىسرائىلنىڭ ئوتتۇرىسىدا جەڭ بولمىغاچقا، ئۇلار تىنچلىقتا ئۆتتى.  
\v 2 ئۈچىنچى يىلدا بولسا يەھۇدانىڭ پادىشاھى يەھوشافات ئىسرائىلنىڭ پادىشاھىنى يوقلاپ باردى.  
\v 3 ئىسرائىلنىڭ پادىشاھى ئۆز خىزمەتكارلىرىغا: ــ گىلېئادتىكى راموت بىزنىڭكى ئىكەنلىكىنى بىلىسىلەرغۇ؟ شۇنداق ئىكەن، نېمىشقا بىز جىم ئولتۇرۇپ، تېخىچە سۇرىيەنىڭ پادىشاھىنىڭ قولىدىن ئۇنى ئالمايمىز؟ ــ دېدى.   
\m
\v 4 ئۇ يەھوشافاتتىن: ــ جەڭ قىلغىلى مېنىڭ بىلەن گىلېئادتىكى راموتقا بېرىشقا ماقۇل بولامدىلا؟ ــ دەپ سورىدى. يەھوشافات ئىسرائىلنىڭ پادىشاھىغا جاۋاب بېرىپ: ــ بىز سىلىنىڭ-مېنىڭ دەپ ئايرىمايمىز؛ مېنىڭ خەلقىم ئۆزلىرىنىڭ خەلقىدۇر، مېنىڭ ئاتلىرىم سىلىنىڭ ئاتلىرىدۇر، دېدى. \f ◼ \fr 22:4 \ft \+bd «بىز سىلىنىڭ-مېنىڭ دەپ ئايرىمايمىز»\+bd* ــ ئىبرانىي تىلىدا «مەن ئۆزۈم ساڭا ئوخشاش بولىمەن» دېگەن سۆز بىلەن ئىپادىلىنىدۇ.\f*   
\m
\v 5 لېكىن يەھوشافات ئىسرائىلنىڭ پادىشاھىغا: ــ ئۆتۈنىمەنكى، بۈگۈن ئاۋۋال پەرۋەردىگارنىڭ سۆزىنى سوراپ كۆرگەيلا، دېدى.   
\m
\v 6 شۇنىڭ بىلەن ئىسرائىلنىڭ پادىشاھى پەيغەمبەرلەرنى، يەنى تۆت يۈزچە ئادەمنى يىغدۇرۇپ ئۇلاردىن: ــ سوقۇشقىلى گىلېئادتىكى راموتقا چىقسام بولامدۇ، يوق؟ ــ دەپ سورىۋىدى، ئۇلار: ــ چىققىن، رەب ئۇنى پادىشاھنىڭ قولىغا بېرىدۇ، دېيىشتى.   
\m
\v 7 لېكىن يەھوشافات بولسا: ــ بۇلاردىن باشقا، يول سورىغۇدەك پەرۋەردىگارنىڭ بىرەر پەيغەمبىرى يوقمۇ؟ ــ دەپ سورىدى. \f ◼ \fr 22:7 \ft \+bd «بۇلاردىن باشقا، يول سورىغۇدەك پەرۋەردىگارنىڭ بىرەر پەيغەمبىرى يوقمۇ؟»\+bd* ــ يەھوشافات (5-ئايەتتە): «بۈگۈن ئاۋۋال پەرۋەردىگارنىڭ سۆزىنى سوراپ كۆرگەيلا» دەيدۇ . لېكىن «پەيغەمبەرلەر» «پەرۋەردىگار» (ئىبرانىي تىلىدا «يەھۋە، يەھوۋاھ») دېگەن نامنى (ئاۋۋال) ئىشلەتمەي، بەلكى «خۇدا» (ئىبرانىي تىلىدا «ئەلوھىم») ياكى «رەب» («ئادوناي») دەپ ئىشلىتىدۇ. شۇڭا يەھوشافات «پەيغەمبەرلەر»نىڭ بېشارەتلىرىدىن قاتتىق گۇمان قىلغان بولسا كېرەك. 7-ئايەت ۋە كېيىنكى ئايەتلەرنىمۇ كۆرۈڭ.\f*   
\m
\v 8 ئىسرائىلنىڭ پادىشاھى يەھوشافاتقا جاۋاب بېرىپ: ــ پەرۋەردىگاردىن يول سورايدىغان يەنە بىر ئادەم بار؛ لېكىن ئۇ مېنىڭ توغرامدا قۇتلۇقنى ئەمەس، بەلكى بالايىئاپەتنى كۆرسىتىپ بېشارەت بەرگەچكە، مەن ئۇنى ئۆچ كۆرىمەن. ئۇ بولسا ئىملاھنىڭ ئوغلى مىكايادۇر، دېدى. يەھوشافات: ــ ئى ئالىيلىرى، سىلى ئۇنداق دېمىگەيلا، دېدى.   
\m
\v 9 ئاندىن ئىسرائىلنىڭ پادىشاھى بىر چاكىرىنى چاقىرىپ ئۇنىڭغا: ــ چاققان بېرىپ، ئىملاھنىڭ ئوغلى مىكايانى چاقىرتىپ كەل، دەپ بۇيرۇدى.   
\m
\v 10 ئەمدى ئىسرائىلنىڭ پادىشاھى بىلەن يەھۇدانىڭ پادىشاھى يەھوشافات شاھانە كىيىملىرىنى كىيىشىپ، سامارىيەنىڭ دەرۋازىسىنىڭ ئالدىدىكى خاماندا ھەربىرى ئۆز تەختىدە ئولتۇرۇشتى. ئۇلارنىڭ ئالدىدا پەيغەمبەرلەرنىڭ ھەممىسى بېشارەت بەرمەكتە ئىدى. \x ◘ \xo 22:10 \xt 2تار. 18‏:9\x*  
\v 11 كەنئاناھنىڭ ئوغلى زەدەكىيا بولسا ئۆزى تۆمۈردىن مۈڭگۈزلەرنى ياساپ چىقىپ: ــ پەرۋەردىگار مۇنداق دەيدۇ: ــ «مۇشۇ مۈڭگۈزلەر بىلەن سۇرىيلەرنى يوقاتقۇچە ئۈسۈپ ئۇرسىلا»، دېدى.  
\v 12 ھەممە پەيغەمبەرلەر شۇنىڭغا ئوخشاش بېشارەت بېرىپ: «گىلېئادتىكى راموتقا چىقىپ سۆزسىز مۇۋەپپەقىيەت قازىنىلا؛ چۈنكى پەرۋەردىگار ئۇنى پادىشاھنىڭ قولىغا تاپشۇرىدىكەن»، دېيىشتى.   
\m
\v 13 مىكايانى قىچقىرغىلى بارغان خەۋەرچى ئۇنىڭغا: ــ مانا، ھەممە پەيغەمبەرلەر بىردەك پادىشاھقا ياخشى خەۋەر بەرمەكتە؛ ئەمدى ئۆتۈنىمەن، سېنىڭ سۆزۈڭمۇ ئۇلارنىڭ سۆزى بىلەن بىردەك بولۇپ، ياخشى بىر خەۋەرنى بەرگىن، دېدى.   
\m
\v 14 ئەمما مىكايا: ــ پەرۋەردىگارنىڭ ھاياتى بىلەن قەسەم قىلىمەنكى، پەرۋەردىگار ماڭا نېمە ئېيتسا، مەن شۇنى ئېيتىمەن، دېدى.   
\m
\v 15 ئۇ پادىشاھنىڭ ئالدىغا كەلگەندە پادىشاھ ئۇنىڭدىن: ئى مىكايا، جەڭ قىلغىلى گىلېئادتىكى راموتقا چىقساق بولامدۇ، يوق؟ ــ دەپ سورىۋىدى، ئۇ ئۇنىڭغا جاۋاب بېرىپ: ــ چىقىپ مۇۋەپپەقىيەت قازىنىسەن؛ چۈنكى پەرۋەردىگار شەھەرنى پادىشاھنىڭ قولىغا بېرىدۇ، دېدى. \f ◼ \fr 22:15 \ft \+bd «پەرۋەردىگار شەھەرنى پادىشاھنىڭ قولىغا بېرىدۇ»\+bd* ــ شۈبھىسىزكى، مىكايا بۇ سۆزنى كىنايىلىك تەلەپپۇز بىلەن ئېيتىدۇ. چۈنكى پادىشاھ دەرھال ئۇنىڭدىن گۇمانلىنىپ قالىدۇ (16-ئايەتنى كۆرۈڭ).\f*   
\m
\v 16 لېكىن پادىشاھ ئۇنىڭغا: ــ مەن ساڭا قانچە قېتىم پەرۋەردىگارنىڭ نامىدا راست گەپتىن باشقىسىنى ماڭا ئېيتماسلىققا قەسەم ئىچكۈزۈشۈم كېرەك؟! ــ دېدى.   
\m
\v 17 مىكايا: ــ مەن پۈتكۈل ئىسرائىلنىڭ تاغلاردا پادىچىسىز قويلاردەك تارىلىپ كەتكەنلىكىنى كۆردۈم. پەرۋەردىگار: «بۇلارنىڭ ئىگىسى يوق؛ بۇلارنىڭ ھەربىرى تىنچ-ئامان ئۆز ئۆيىگە قايتسۇن»، دېدى، ــ دېدى.   
\m
\v 18 ئىسرائىلنىڭ پادىشاھى يەھوشافاتقا: ــ مانا، مەن سىلىگە «ئۇ مېنىڭ توغرامدا قۇتلۇقنى ئەمەس، بەلكى ھامان بالايىئاپەتنى كۆرسىتىپ بېشارەت بېرىدۇ»، دېمىگەنمىدىم؟ ــ دېدى.   
\m
\v 19 مىكايا يەنە: ــ شۇڭا پەرۋەردىگارنىڭ سۆزىنى ئاڭلىغىن؛ مەن پەرۋەردىگارنىڭ ئۆز تەختىدە ئولتۇرغانلىقىنى، ئاسماننىڭ پۈتكۈل قوشۇنلىرى ئۇنىڭ يېنىدا، ئوڭ ۋە سول تەرىپىدە تۇرغانلىقىنى كۆردۈم. \x ◘ \xo 22:19 \xt 2تار. 18‏:18؛ ئايۇپ 1‏:6-12؛ 2‏:1\x*  
\v 20 پەرۋەردىگار: «كىم ئاھابنى گىلېئادتىكى راموتقا چىقىپ، شۇ يەردە ھالاك بولۇشقا ئالدايدۇ؟» ــ دېدى. بىرسى ئۇنداق، بىرسى مۇنداق دېيىشتى؛  
\v 21 شۇ ۋاقىتتا بىر روھ چىقىپ پەرۋەردىگارنىڭ ئالدىدا تۇرۇپ: «مەن بېرىپ ئالداي»، دېدى. پەرۋەردىگار ئۇنىڭدىن: «قانداق ئۇسۇل بىلەن ئالدايسەن؟» ــ دەپ سورىۋىدى،  
\v 22 ئۇ: ــ «مەن چىقىپ ئۇنىڭ ھەممە پەيغەمبەرلىرىنىڭ ئاغزىدا يالغانچى بىر روھ بولىمەن»، دېدى. پەرۋەردىگار: ــ «ئۇنى ئالداپ ئىلكىڭگە ئالالايسەن؛ بېرىپ شۇنداق قىل» ــ دېدى. \f ◼ \fr 22:22 \ft \+bd «ئۇ \+bdit روھ\+bdit*: - «مەن چىقىپ ئۇنىڭ ھەممە پەيغەمبەرلىرىنىڭ ئاغزىدا يالغانچى بىر روھ بولىمەن»، دېدى. پەرۋەردىگار: ــ «ئۇنى ئالداپ ئىلكىڭگە ئالالايسەن؛ بېرىپ شۇنداق قىل» ــ دېدى»\+bd* ــ بۇ ئايەتلەردىن بۇ روھنىڭ بىر يالغان سۆزلەيدىغان جىن ئىكەنلىكى كۆرۈنىدۇ. خۇدانىڭ ئۆز روھى ياكى پەرىشتىلىرى ھېچقاچان يالغان سۆز قىلالمايدۇ. دېمەك، خۇدا جىن-شەيتانلارغا ئاھاب پادىشاھنى ئالداشقا يول قويىدۇ.\f*  
\v 23 مانا ئەمدى پەرۋەردىگار سېنىڭ بۇ ھەممە پەيغەمبەرلىرىڭنىڭ ئاغزىغا يالغانچى بىر روھنى سالدى؛ پەرۋەردىگار سېنىڭ توغراڭدا بالايىئاپەت كۆرسىتىپ سۆزلىدى» ــ دېدى.   
\m
\v 24 شۇنى ئاڭلاپ كەنئاناھنىڭ ئوغلى زەدەكىيا كېلىپ مىكايانىڭ كاچىتىغا بىرنى سېلىپ: ــ پەرۋەردىگارنىڭ روھى قايسى يول بىلەن مەندىن ئۆتۈپ، ساڭا سۆز قىلىشقا باردى؟! ــ دېدى.   
\m
\v 25 مىكايا جاۋاب بېرىپ: ــ ئۆزۈڭنى يوشۇرۇش ئۈچۈن ئىچكىرىدىكى ئۆيگە يۈگۈرگەن كۈنىدە شۇنى كۆرىسەن، دېدى. \f ◼ \fr 22:25 \ft \+bd «ئۆزۈڭنى يوشۇرۇش ئۈچۈن ئىچكىرىدىكى ئۆيگە يۈگۈرگەن كۈنى...»\+bd* ــ ياكى «ئۆزۈڭنى يوشۇرۇش ئۈچۈن ئۆيدىن ئۆيگە يۈگۈرگەن كۈنى...».\f*   
\m
\v 26 ئىسرائىلنىڭ پادىشاھى ئەمدى: ــ مىكايانى ئېلىپ قايتۇرۇپ بېرىپ، شەھەر ھاكىمى ئامون بىلەن پادىشاھنىڭ ئوغلى يوئاشقا تاپشۇرۇپ،  
\v 27 ئۇلارغا تاپىلاپ: «پادىشاھ مۇنداق دەيدۇ: ــ ئۇنى زىندانغا سولاپ مەن تىنچ-ئامان يېنىپ كەلگۈچىلىك قىيناپ نان بىلەن سۇنى ئاز-ئاز بېرىپ تۇرۇڭلار» ــ دېگىن، دەپ بۇيرۇدى.   
\m
\v 28 مىكايا: ــ ئەگەر سەن ھەقىقەتەن تىنچ-ئامان يېنىپ كەلسەڭ، پەرۋەردىگار مېنىڭ ۋاسىتەم بىلەن سۆز قىلمىغان بولىدۇ، دېدى. ئاندىن ئۇ يەنە: ــ ئەي جامائەت، ھەربىرىڭلار ئاڭلاڭلار، دېدى. \x ◘ \xo 22:28 \xt مىك. 1‏:2\x*   
\b  
\m
\v 29 ئىسرائىلنىڭ پادىشاھى بىلەن يەھۇدانىڭ پادىشاھى يەھوشافات گىلېئادتىكى راموتقا چىقتى.  
\v 30 ئىسرائىلنىڭ پادىشاھى يەھوشافاتقا: ــ مەن باشقا قىياپەتكە كىرىپ جەڭگە چىقاي؛ سىلى بولسىلا ئۆز كىيىملىرىنى كىيىپ چىققايلا، دېدى. ئىسرائىلنىڭ پادىشاھى باشقا قىياپەت بىلەن جەڭگە چىقتى.   
\m
\v 31 سۇرىيەنىڭ پادىشاھى جەڭ ھارۋىلىرى ئۈستىدىكى ئوتتۇز ئىككى سەردارغا: ــ چوڭلىرى ياكى كىچىكلىرى بىلەن ئەمەس، پەقەت ئىسرائىلنىڭ پادىشاھى بىلەن سوقۇشۇڭلار، دەپ بۇيرۇدى.   
\m
\v 32 ۋە شۇنداق بولدىكى، جەڭ ھارۋىلىرىنىڭ سەردارلىرى يەھوشافاتنى كۆرگەندە: ــ ئۇنى چوقۇم ئىسرائىلنىڭ پادىشاھى دەپ، ئۇنىڭغا ھۇجۇم قىلغىلى بۇرۇلدى. لېكىن يەھوشافات پەرياد كۆتۈردى.  
\v 33 جەڭ ھارۋىلىرىنىڭ سەردارلىرى ئۇنىڭ ئىسرائىلنىڭ پادىشاھى ئەمەسلىكىنى كۆرگەندە ئۇنى قوغلىماي، بۇرۇلۇپ كېتىپ قېلىشتى.  
\v 34 ئەمما بىرەيلەن قارىسىغىلا بىر ئوقيا ئېتىۋىدى، ئوق ئىسرائىلنىڭ پادىشاھىنىڭ ساۋۇتىنىڭ مۈرىسىدىن تۆۋەنكى ئۇلىقىدىن ئۆتۈپ تەگدى. ئۇ ھارۋىكېشىگە: ھارۋىنى ياندۇرۇپ مېنى سەپتىن چىقارغىن؛ چۈنكى مەن يارىدار بولدۇم، دېدى.  
\v 35 ئۇ كۈنى جەڭ بارغانسېرى قاتتىق بولدى. پادىشاھ بولسا سۇرىيلەرنىڭ ئۇدۇلىدا ئۆز جەڭ ھارۋىسىغا يۆلىنىپ ئۆرە تۇردى. زەخمىدىن قېنى ھارۋىنىڭ تېگىگىچە ئېقىپ، كەچ كىرگەندە ئۇ ئۆلدى.   
\m
\v 36 كۈن پاتاردا قوشۇن ئارىسىدا بىر قاتتىق سادا ئاڭلىنىپ: ــ ھەر ئادەم ئۆز شەھىرىگە يانسۇن! ھەربىرى ئۆز يۇرتىغا يېنىپ كەتسۇن! ــ دېيىلدى.   
\m
\v 37 پادىشاھ ئۆلدى، كىشىلەر ئۇنى سامارىيەگە ئېلىپ كەلدى؛ ئۇلار پادىشاھنى سامارىيەدە دەپنە قىلدى.  
\v 38 بىرسى پادىشاھنىڭ ھارۋىسىنى سامارىيەنىڭ كۆلىدە \add يۇغاندا\add* (بۇ كۆل پاھىشە ئاياللار يۇيۇنىدىغان جاي ئىدى)، پەرۋەردىگارنىڭ ئېيتقان سۆزى ئەمەلگە ئاشۇرۇلۇپ، ئىتلار ئۇنىڭ قېنىنى يالىدى.   
\m
\v 39 ئاھابنىڭ باشقا ئىشلىرى، قىلغانلىرىنىڭ ھەممىسى، جۈملىدىن ئۇنىڭ ياسىغان «پىل چىش سارىيى» ۋە بىنا قىلغان ھەممە شەھەرلەر توغرۇلۇق «ئىسرائىل پادىشاھلىرىنىڭ تارىخ-تەزكىرىلىرى» دېگەن كىتابتا پۈتۈلگەن ئەمەسمىدى؟   
\m
\v 40 ئاھاب ئاتا-بوۋىلىرى ئارىسىدا ئۇخلىدى. ئاندىن ئۇنىڭ ئوغلى ئاھازىيا ئورنىدا پادىشاھ بولدى.   
\b  
\m  
\s1 يەھوشافات يەھۇدا ئۈستىگە ھۆكۈم سۈرىدۇ  
\r 2تار. 20‏:30-37؛ 21‏:1  
\m
\v 41 ئاسانىڭ ئوغلى يەھوشافات ئىسرائىلنىڭ پادىشاھى ئاھابنىڭ سەلتەنىتىنىڭ تۆتىنچى يىلىدا يەھۇداغا پادىشاھ بولدى. \x ◘ \xo 22:41 \xt 2تار. 20‏:31\x*  
\v 42 يەھوشافات پادىشاھ بولغاندا ئوتتۇز بەش ياشتا ئىدى، ئۇ يېرۇسالېمدا يىگىرمە بەش يىل سەلتەنەت قىلدى. ئۇنىڭ ئانىسىنىڭ ئىسمى ئازۇباھ بولۇپ، ئۇ شىلھىنىڭ قىزى ئىدى.  
\v 43‏-44 ئۇ ھەر ئىشتا ئاتىسى ئاسانىڭ بارلىق يوللىرىدا يۈرۈپ، ئۇلاردىن چىقماي پەرۋەردىگارنىڭ نەزىرىدە دۇرۇس بولغاننى قىلاتتى. پەقەت «يۇقىرى جايلار»لا يوقىتىلمىغانىدى؛ خالايىق يەنىلا «يۇقىرى جايلار»دا قۇربانلىق قىلىپ خۇشبۇي ياقاتتى.   
\m
\v 45 ۋە يەھوشافات بىلەن ئىسرائىلنىڭ پادىشاھى ئوتتۇرىسىدا تىنچلىق بولدى.   
\m
\v 46 يەھوشافاتنىڭ باشقا ئىشلىرى، ئۇنىڭ كۆرسەتكەن قۇدرىتى، قانداق جەڭ قىلغانلىرى توغرىسىدا «يەھۇدا پادىشاھلىرىنىڭ تارىخ-تەزكىرىلىرى» دېگەن كىتابتا پۈتۈلگەن ئەمەسمىدى؟   
\m
\v 47 ئۇ ئاتىسى ئاسانىڭ كۈنلىرىدە زېمىندىن قوغلىۋېتىلمىگەن كەسپىي بەچچىۋازلارنى زېمىنىدىن ھەيدەپ چىقاردى. \f ◼ \fr 22:47 \ft \+bd «كەسپىي بەچچىۋازلار»\+bd* ــ بۇ كىشىلەر بۇتپەرەسلىككە ياكى بۇتخانىلارغا مۇناسىۋەتلىك ئىدى.\f*   
\m
\v 48 ئۇ ۋاقىتتا ئېدومنىڭ پادىشاھى يوق ئىدى، بەلكى بىر ۋالىي ھۆكۈم سۈرەتتى.   
\m
\v 49 يەھوشافات ئوفىردىن ئالتۇن ئېلىپ كېلىش ئۈچۈن بىر «تارشىش كېمە» ئەترىتىنى قۇردى. لېكىن كېمىلەر ھېچيەرگە بارالمىدى؛ چۈنكى ئۇلار ئەزىئون-گەبەردە ئۇرۇلۇپ ۋەيران بولغانىدى. \f ◼ \fr 22:49 \ft \+bd «يەھوشافات ... بىر «تارشىش كېمە» ئەترىتىنى قۇردى»\+bd* ــ «تارشىش كېمە» بەلكىم تارشىش دېگەن پورتقا بېرىپ كېلىشتىكى ئۇزۇن سەپەرگە چىداملىق بولغان كېمىنى كۆرسىتەتتى. «تارشىش» دېگەن ئىسىم ئىسپانىيە، شىمالىي ئافرىقا ياكى برىتانىيەنى ياكى ئۈچىنىڭ ھەممىسىنى كۆرسىتىدۇ.\f*   
\m
\v 50 ئۇ ۋاقىتتا ئاھابنىڭ ئوغلى ئاھازىيا يەھوشافاتقا: ــ مېنىڭ خىزمەتكارلىرىم سېنىڭ خىزمەتكارلىرىڭ بىلەن كېمىلەردە بارسۇن، دېدى. لېكىن يەھوشافات ئۇنىمىدى.   
\m
\v 51 يەھوشافات ئۆز ئاتا-بوۋىلىرى ئارىسىدا ئۇخلىدى ۋە «داۋۇتنىڭ شەھىرى»دە ئاتا-بوۋىلىرىنىڭ قەبرىسىدە دەپنە قىلىندى. ئاندىن ئوغلى يەھورام ئورنىدا پادىشاھ بولدى.   
\b  
\m  
\s1 ئاھازىيا ئىسرائىل ئۈستىگە ھۆكۈم سۈرىدۇ  
\m
\v 52 ئاھابنىڭ ئوغلى ئاھازىيا يەھۇدانىڭ پادىشاھى يەھوشافاتنىڭ سەلتەنىتىنىڭ ئون يەتتىنچى يىلىدا سامارىيەدە ئىسرائىلنىڭ ئۈستىدە پادىشاھ بولۇپ ئىككى يىل سەلتەنەت قىلدى.  
\v 53 ئۇ پەرۋەردىگارنىڭ نەزىرىدە رەزىل بولغاننى قىلىپ ئاتىسىنىڭ يولىدا ۋە ئانىسىنىڭ يولىدا يۈرۈپ، شۇنداقلا ئىسرائىلنى گۇناھقا پۇتلاشتۇرغان نىباتنىڭ ئوغلى يەروبوئامنىڭ يولىدا ماڭدى؛  
\v 54 ئۇ ئاتىسى قىلغاننىڭ ھەممىسىنى قىلىپ، بائالنىڭ قۇللۇقىدا بولۇپ، ئۇنىڭغا سەجدە قىلىپ، ئىسرائىلنىڭ خۇداسى پەرۋەردىگارنىڭ غەزىپىنى قوزغىدى.   