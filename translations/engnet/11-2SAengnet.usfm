\v 4  \w So|strong="H3947"\w* \w Hanun|strong="H2586"\w* \w seized|strong="H3947"\w* \w David|strong="H1732"\w*’s \w servants|strong="H5650"\w* \w and|strong="H7971"\w* \w shaved|strong="H1548"\w* \w off|strong="H3772"\w* \w half|strong="H2677"\w* \w of|strong="H5650"\w* \w each|strong="H3947"\w* one’s \w beard|strong="H2206"\w*. \w He|strong="H5704"\w* \w cut|strong="H3772"\w* \w the|strong="H3947"\w* lower \w part|strong="H2677"\w* \w of|strong="H5650"\w* \w their|strong="H3947"\w* robes \w off|strong="H3772"\w* \w so|strong="H3947"\w* \w that|strong="H1732"\w* \w their|strong="H3947"\w* \w buttocks|strong="H8357"\w* \w were|strong="H5650"\w* exposed, \w and|strong="H7971"\w* \w then|strong="H3947"\w* \w sent|strong="H7971"\w* \w them|strong="H7971"\w* \w away|strong="H7971"\w*.  
\v 5  \w Messengers|strong="H5046"\w* \w told|strong="H5046"\w* \w David|strong="H1732"\w* \w what|strong="H1732"\w* \w had|strong="H1961"\w* \w happened|strong="H1961"\w*, \w so|strong="H7971"\w* \w he|strong="H3588"\w* summoned \w them|strong="H7725"\w*, \w for|strong="H3588"\w* \w the|strong="H3588"\w* men \w were|strong="H1961"\w* thoroughly \w humiliated|strong="H3637"\w*. \w The|strong="H3588"\w* \w king|strong="H4428"\w* said, “\w Stay|strong="H3427"\w* \w in|strong="H3427"\w* \w Jericho|strong="H3405"\w* \w until|strong="H5704"\w* \w your|strong="H7725"\w* \w beards|strong="H2206"\w* \w have|strong="H1961"\w* \w grown|strong="H6779"\w* \w again|strong="H7725"\w*; \w then|strong="H1961"\w* \w you|strong="H3588"\w* \w may|strong="H1961"\w* \w come|strong="H1961"\w* \w back|strong="H7725"\w*.”   
\p
\v 6  \w When|strong="H3588"\w* \w the|strong="H7200"\w* \w Ammonites|strong="H1121"\w* \w realized|strong="H7200"\w* \w that|strong="H3588"\w* \w David|strong="H1732"\w* \w was|strong="H1732"\w* disgusted \w with|strong="H1732"\w* \w them|strong="H7971"\w*, \w they|strong="H3588"\w* \w sent|strong="H7971"\w* \w and|strong="H1121"\w* \w hired|strong="H7936"\w* 20,000 \w foot|strong="H7273"\w* \w soldiers|strong="H7273"\w* \w from|strong="H1121"\w* Aram Beth Rehob \w and|strong="H1121"\w* Aram \w Zobah|strong="H6678"\w*, \w in|strong="H4428"\w* addition \w to|strong="H7971"\w* 1,000 \w men|strong="H1121"\w* \w from|strong="H1121"\w* \w the|strong="H7200"\w* \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w Maacah|strong="H4601"\w* \w and|strong="H1121"\w* 12,000 \w men|strong="H1121"\w* \w from|strong="H1121"\w* \w Ish-tob|strong="H2897"\w*.   
\p
