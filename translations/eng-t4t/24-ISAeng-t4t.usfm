\q2 \w the|strong="H7725"\w* people who \w remain|strong="H1961"\w* \add in this land will be a group that will become large again\add* \w and|strong="H7725"\w* \w be|strong="H1961"\w* ◄\w set|strong="H7725"\w* \w apart|strong="H6944"\w* \w for|strong="H1961"\w*/\w dedicated|strong="H6944"\w* \w to|strong="H7725"\w*► \w me|strong="H7725"\w*.”   
\c 7  
\s1 A message of encouragement for King Ahaz  
\p
\v 1 Ahaz \w was|strong="H1961"\w* \w the|strong="H5921"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jotham|strong="H3147"\w* \w and|strong="H1121"\w* \w grandson|strong="H1121"\w* \w of|strong="H1121"\w* \w Uzziah|strong="H5818"\w*. \w During|strong="H3117"\w* \w the|strong="H5921"\w* \w time|strong="H3117"\w* \w that|strong="H3117"\w* Ahaz \w was|strong="H1961"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w*, \w King|strong="H4428"\w* \w Rezin|strong="H7526"\w* \w of|strong="H1121"\w* Syria \w and|strong="H1121"\w* \w King|strong="H4428"\w* \w Pekah|strong="H6492"\w* \w of|strong="H1121"\w* \w Israel|strong="H3478"\w* \w marched|strong="H5927"\w* \add with their armies\add* \w to|strong="H3478"\w* \w attack|strong="H5927"\w* \w Jerusalem|strong="H3389"\w*. \w But|strong="H3808"\w* \w they|strong="H3117"\w* \w could|strong="H3201"\w* \w not|strong="H3808"\w* \w conquer|strong="H3898"\w* \w it|strong="H5921"\w*.   
\p
\v 2  \add But before they attacked\add*, everyone \w in|strong="H5921"\w* \w the|strong="H6440"\w* \w palace|strong="H1004"\w* \w heard|strong="H5046"\w* \w a|strong="H3068"\w* \w report|strong="H5046"\w* \w that|strong="H5971"\w* \w the|strong="H6440"\w* armies \w of|strong="H1004"\w* Syria \w and|strong="H1004"\w* \w Israel|strong="H5971"\w* \w were|strong="H5971"\w* \add now\add* ◄allies/joined \add to attack Jerusalem►\add*. \w So|strong="H5921"\w* Ahaz \w and|strong="H1004"\w* \w the|strong="H6440"\w* \w people|strong="H5971"\w* \w over|strong="H5921"\w* \w whom|strong="H6440"\w* \w he|strong="H1004"\w* ruled \w were|strong="H5971"\w* extremely afraid; \w they|strong="H5921"\w* \w were|strong="H5971"\w* shaking \w from|strong="H6440"\w* \w fear|strong="H6440"\w* \w like|strong="H1004"\w* \w trees|strong="H6086"\w* \w shake|strong="H5128"\w* \w in|strong="H5921"\w* \w a|strong="H3068"\w* windstorm.   
\p
\v 3 \w Then|strong="H3318"\w* \w Yahweh|strong="H3068"\w* \w said|strong="H3318"\w* \w to|strong="H3318"\w* \w me|strong="H4994"\w*, “\w Take|strong="H3318"\w* \w your|strong="H3068"\w* \w son|strong="H1121"\w* \w Shear-Jashub|strong="H7610"\w*, \w and|strong="H1121"\w* \w go|strong="H3318"\w* \w to|strong="H3318"\w* talk \w with|strong="H3068"\w* \add King\add* Ahaz. \w He|strong="H3068"\w* \w is|strong="H3068"\w* \w at|strong="H3068"\w* \w the|strong="H3068"\w* \w end|strong="H7097"\w* \w of|strong="H1121"\w* \w the|strong="H3068"\w* ◄aqueduct/water \w channel|strong="H8585"\w*► \w that|strong="H3068"\w* \w brings|strong="H3318"\w* water \w into|strong="H3318"\w* \w the|strong="H3068"\w* \w upper|strong="H5945"\w* reservoir, near \w the|strong="H3068"\w* road \w to|strong="H3318"\w* \w the|strong="H3068"\w* place where women \w wash|strong="H3526"\w* clothes.  
\v 4 Tell Ahaz \w to|strong="H8104"\w* stop worrying [DOU]. Tell \w him|strong="H3372"\w* \w that|strong="H1121"\w* \w he|strong="H8147"\w* does \w not|strong="H3372"\w* need \w to|strong="H8104"\w* \w be|strong="H1121"\w* \w afraid|strong="H3372"\w* \w of|strong="H1121"\w* \w those|strong="H1121"\w* \w two|strong="H8147"\w* kings, \w Rezin|strong="H7526"\w* \w and|strong="H1121"\w* Pekah. \w They|strong="H3824"\w* \w are|strong="H1121"\w* very angry \add with Judah\add*, but \w they|strong="H3824"\w* \w are|strong="H1121"\w* \add unable to harm his country any more than\add* completely burned-out coals \add can harm him\add*.  
\v 5 \w Yes|strong="H3588"\w*, \w they|strong="H3588"\w* \w are|strong="H1121"\w* \w planning|strong="H3289"\w* \w to|strong="H5921"\w* attack \w this|strong="H3588"\w* land \w and|strong="H1121"\w* saying,  
\v 6 ‘We \w will|strong="H4428"\w* \w attack|strong="H5927"\w* \w Judah|strong="H3063"\w* \w and|strong="H1121"\w* conquer \w it|strong="H8432"\w*. \w Then|strong="H4428"\w* \w we|strong="H3068"\w* \w will|strong="H4428"\w* \w appoint|strong="H4427"\w* \w Tabeel|strong="H2870"\w*’s \w son|strong="H1121"\w* \w to|strong="H5927"\w* \w be|strong="H1121"\w* \w the|strong="H8432"\w* \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w*.’  
\v 7 \w But|strong="H3808"\w* \w this|strong="H3541"\w* \w is|strong="H1961"\w* \w what|strong="H3541"\w* \w Yahweh|strong="H3068"\w*, \w the|strong="H3069"\w* \w Lord|strong="H3069"\w*, \w says|strong="H3541"\w*:  
\q1 ‘\w It|strong="H1961"\w* \w will|strong="H1961"\w* \w not|strong="H3808"\w* \w happen|strong="H1961"\w*;  
\q2 \w they|strong="H3808"\w* \w will|strong="H1961"\w* \w not|strong="H3808"\w* \add conquer Jerusalem\add*!   
\q1
\v 8 \w The|strong="H3588"\w* capital \w of|strong="H8141"\w* Syria \w is|strong="H7218"\w* \w Damascus|strong="H1834"\w*,  
\q2 \w but|strong="H3588"\w* \w Damascus|strong="H1834"\w* \w is|strong="H7218"\w* ruled \add only\add* \w by|strong="H8141"\w* \w its|strong="H3588"\w* \add unimportant/insignificant\add* king king \w Rezin|strong="H7526"\w*.  
\q1 \w And|strong="H5971"\w* \w as|strong="H3588"\w* \w for|strong="H3588"\w* \w Israel|strong="H5971"\w*, \w within|strong="H1157"\w* 65 \w years|strong="H8141"\w* \w it|strong="H3588"\w* \w will|strong="H5971"\w* \w be|strong="H8141"\w* conquered \w and|strong="H5971"\w* completely destroyed.   
\q1
\v 9 Israel’s capital \w is|strong="H7218"\w* \w Samaria|strong="H8111"\w*, \w and|strong="H1121"\w* \w Samaria|strong="H8111"\w* \w is|strong="H7218"\w* ruled \w only|strong="H3588"\w* \w by|strong="H3808"\w* \w its|strong="H3588"\w* \add insignificant/unimportant\add* king king Pekah.  
\q2 \add So you do not need to be afraid of those two countries\add*!  
\q1 \add But you must trust me, because\add* \w if|strong="H3588"\w* \w you|strong="H3588"\w* do \w not|strong="H3808"\w* trust \w me|strong="H3808"\w* fully,  
\q2 \w you|strong="H3588"\w* \w will|strong="H1121"\w* \w be|strong="H3808"\w* defeated.’ ”   
\s1 A promise of a son named Immanuel  
\p
\v 10  \add Later\add*, \w Yahweh|strong="H3068"\w* \w gave|strong="H1696"\w* \add me another message to tell to\add* King Ahaz.  
\v 11  \add He said to tell him\add*, “\w Request|strong="H7592"\w* \w me|strong="H5973"\w*, \w Yahweh|strong="H3068"\w* \w your|strong="H3068"\w* \w God|strong="H3068"\w*, \w to|strong="H3068"\w* \w do|strong="H3068"\w* something \w that|strong="H3068"\w* \w will|strong="H3068"\w* enable \w you|strong="H5973"\w* \w to|strong="H3068"\w* \w be|strong="H3068"\w* sure \add that I will help/protect you\add*. What \w you|strong="H5973"\w* \w request|strong="H7592"\w* can \w be|strong="H3068"\w* \add from a place that is\add* \w as|strong="H3068"\w* \w high|strong="H4605"\w* \w as|strong="H3068"\w* \w the|strong="H3068"\w* sky \w or|strong="H3068"\w* \w as|strong="H3068"\w* low \w as|strong="H3068"\w* \w the|strong="H3068"\w* place where \w the|strong="H3068"\w* dead people \w are|strong="H3068"\w*.”   
\p
\v 12 \w But|strong="H3808"\w* \add when I told that to the king, he refused\add*. \w He|strong="H3068"\w* said, “\add No\add*, \w I|strong="H3808"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w request|strong="H7592"\w* \w Yahweh|strong="H3068"\w* \w to|strong="H3068"\w* \w do|strong="H3068"\w* something \w to|strong="H3068"\w* \w prove|strong="H5254"\w* \add that he will help/protect us\add*!”   
\p
\v 13 \w Then|strong="H1571"\w* \w I|strong="H3588"\w* \w said|strong="H8085"\w* \add to him\add*, “\w You|strong="H3588"\w* \w people|strong="H8085"\w* \w who|strong="H3588"\w* \w are|strong="H1004"\w* descendants \w of|strong="H1004"\w* King \w David|strong="H1732"\w*, \w listen|strong="H8085"\w*! \w You|strong="H3588"\w* \w are|strong="H1004"\w* causing \w me|strong="H4994"\w* \w to|strong="H8085"\w* \w be|strong="H1571"\w* \w tired|strong="H3811"\w* \w of|strong="H1004"\w* \w being|strong="H1004"\w* patient. \w Are|strong="H1004"\w* \w you|strong="H3588"\w* \w also|strong="H1571"\w* going \w to|strong="H8085"\w* cause \w my|strong="H8085"\w* God \w to|strong="H8085"\w* stop \w being|strong="H1004"\w* patient \w with|strong="H1004"\w* \w you|strong="H3588"\w* [RHQ]?  
\v 14 \w Yahweh|strong="H3068"\w* \w himself|strong="H1931"\w* \w will|strong="H1121"\w* do something \w for|strong="H7121"\w* \w you|strong="H5414"\w* \add to prove that he will help/protect you\add*. \w Listen|strong="H2009"\w* \w to|strong="H5414"\w* \w this|strong="H3651"\w*: \w A|strong="H3068"\w* \w young|strong="H1121"\w* \w woman|strong="H2030"\w* \w will|strong="H1121"\w* \w become|strong="H3205"\w* \w pregnant|strong="H2030"\w* \w and|strong="H1121"\w* \w give|strong="H5414"\w* \w birth|strong="H3205"\w* \w to|strong="H5414"\w* \w a|strong="H3068"\w* \w son|strong="H1121"\w*. \w She|strong="H1931"\w* \w will|strong="H1121"\w* \w name|strong="H8034"\w* \w him|strong="H5414"\w* \w Immanuel|strong="H6005"\w*, \add which means ‘God is with us’\add*.  
\v 15 \w And|strong="H3045"\w* \w by|strong="H7451"\w* \w the|strong="H3045"\w* time \w that|strong="H3045"\w* child \w is|strong="H2896"\w* \w old|strong="H2896"\w* enough \w to|strong="H3045"\w* eat \w curds|strong="H2529"\w*/yogurt \w and|strong="H3045"\w* \w honey|strong="H1706"\w*, \w he|strong="H3045"\w* \w will|strong="H7451"\w* \w be|strong="H7451"\w* able \w to|strong="H3045"\w* \w reject|strong="H3988"\w* \w what|strong="H2896"\w* \w is|strong="H2896"\w* \w evil|strong="H7451"\w* \w and|strong="H3045"\w* choose \w what|strong="H2896"\w* \w is|strong="H2896"\w* \w good|strong="H2896"\w*.  
\v 16 \w And|strong="H4428"\w* \w before|strong="H6440"\w* \w that|strong="H3588"\w* \w child|strong="H5288"\w* \w is|strong="H2896"\w* \w old|strong="H2896"\w* enough \w to|strong="H6440"\w* do \w that|strong="H3588"\w*, \w the|strong="H6440"\w* lands \w of|strong="H4428"\w* \w the|strong="H6440"\w* \w two|strong="H8147"\w* \w kings|strong="H4428"\w* \w that|strong="H3588"\w* \w you|strong="H3588"\w*(sg) \w are|strong="H4428"\w* \w very|strong="H3045"\w* ◄afraid \w of|strong="H4428"\w*/worried \w about|strong="H3045"\w*► \w will|strong="H4428"\w* \w be|strong="H4428"\w* \w deserted|strong="H5800"\w*.  
\v 17  \add But then\add* \w Yahweh|strong="H3068"\w* \w will|strong="H3068"\w* \w cause|strong="H5971"\w* \w you|strong="H5921"\w* \w and|strong="H3063"\w* \w your|strong="H3068"\w* \w family|strong="H1004"\w* \w and|strong="H3063"\w* \w your|strong="H3068"\w* \w entire|strong="H3117"\w* \w nation|strong="H5971"\w* \w to|strong="H3068"\w* experience \add terrible disasters\add*. \w Those|strong="H5921"\w* disasters \w will|strong="H3068"\w* \w be|strong="H3808"\w* worse \w than|strong="H3808"\w* \w any|strong="H3808"\w* disasters \w that|strong="H5971"\w* \w have|strong="H3068"\w* occurred \w since|strong="H3117"\w* \w the|strong="H5921"\w* country \w of|strong="H4428"\w* \w Israel|strong="H5971"\w* \w separated|strong="H5493"\w* \w from|strong="H5493"\w* \w Judah|strong="H3063"\w*. \w Yahweh|strong="H3068"\w* \w will|strong="H3068"\w* \w cause|strong="H5971"\w* \add the army of\add* \w the|strong="H5921"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* Assyria \w to|strong="H3068"\w* attack \w you|strong="H5921"\w*!”   
\p
\v 18 \w At|strong="H3068"\w* \w that|strong="H3117"\w* \w time|strong="H3117"\w*, \add it will be as though\add* \w Yahweh|strong="H3068"\w* \w will|strong="H3068"\w* \w whistle|strong="H8319"\w* \w to|strong="H3068"\w* summon \w the|strong="H3068"\w* army \w from|strong="H3117"\w* \w the|strong="H3068"\w* south \w of|strong="H3068"\w* \w Egypt|strong="H4714"\w* \w as|strong="H3117"\w* well \w as|strong="H3117"\w* \w the|strong="H3068"\w* army \w of|strong="H3068"\w* Assyria. \w They|strong="H3117"\w* \w will|strong="H3068"\w* \add come and surround your country like\add* [MET] \w flies|strong="H2070"\w* \w and|strong="H3068"\w* \w bees|strong="H1682"\w*.  
\v 19 \w They|strong="H3605"\w* \w will|strong="H5158"\w* \w all|strong="H3605"\w* come \w and|strong="H3605"\w* \w settle|strong="H5117"\w*/live \add everywhere\add*—\w in|strong="H5117"\w* \w the|strong="H3605"\w* narrow \w valleys|strong="H5158"\w* \w and|strong="H3605"\w* caves \w in|strong="H5117"\w* \w the|strong="H3605"\w* \w rock|strong="H5553"\w* \w cliffs|strong="H5553"\w*, \w on|strong="H5117"\w* land where \w there|strong="H3605"\w* are thornbushes \w as|strong="H3605"\w* well \w as|strong="H3605"\w* \w on|strong="H5117"\w* \w the|strong="H3605"\w* fertile land.  
\v 20 \w At|strong="H3117"\w* \w that|strong="H3117"\w* \w time|strong="H3117"\w* \w Yahweh|strong="H3068"\w* \w will|strong="H4428"\w* hire \w the|strong="H3117"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* Assyria \w to|strong="H3117"\w* come \add with his army\add* \w from|strong="H3117"\w* \w east|strong="H5676"\w* \w of|strong="H4428"\w* \w the|strong="H3117"\w* \add Euphrates\add* \w River|strong="H5104"\w*. \add They will get rid of everything in your land—the crops and the people. They will destroy everything thoroughly\add*; \w it|strong="H1931"\w* \w will|strong="H4428"\w* \w be|strong="H1571"\w* \w like|strong="H7272"\w* [MET] \w a|strong="H3068"\w* barber shaving \w not|strong="H1571"\w* \w only|strong="H1571"\w* \w a|strong="H3068"\w* \w man|strong="H7218"\w*’s \w hair|strong="H8181"\w* \w but|strong="H1571"\w* \w his|strong="H3117"\w* \w beard|strong="H2206"\w* \w and|strong="H4428"\w* \w the|strong="H3117"\w* \w hair|strong="H8181"\w* \w on|strong="H3117"\w* \w his|strong="H3117"\w* \w legs|strong="H7272"\w*.  
