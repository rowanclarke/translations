\p
\v 22 \add Los \add*\w judíos|strong="G2453"\w* piden \w señales|strong="G4592"\w* \w y|strong="G2532"\w* \add los \add*\w griegos|strong="G1672"\w* \w buscan|strong="G2212"\w* \w sabiduría|strong="G4678"\w*,  
