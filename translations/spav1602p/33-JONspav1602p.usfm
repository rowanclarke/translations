\v 3 \w Y|strong="H3068"\w* \w levantóse|strong="H6965"\w* \w Jonás|strong="H3124"\w*, y \w fue|strong="H1961"\w* \w a|strong="H3068"\w* \w Nínive|strong="H5210"\w*, conforme \w a|strong="H3068"\w* la \w palabra|strong="H1697"\w* del \w SEÑOR|strong="H3068"\w*. \w Y|strong="H3068"\w* \w era|strong="H1961"\w* \w Nínive|strong="H5210"\w* \w ciudad|strong="H5892"\w* \w sobremanera|strong="H1419"\w* \w grande|strong="H1419"\w*, \w de|strong="H1697"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w* \w de|strong="H1697"\w* \w camino|strong="H4109"\w*.   
