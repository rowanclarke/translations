\v 13 \w On|strong="G1537"\w* \w the|strong="G1537"\w* \w other|strong="G1161"\w* \w hand|strong="G1188"\w*, \w to|strong="G4314"\w* \w which|strong="G3588"\w* \w of|strong="G1537"\w* \w the|strong="G1537"\w* angels \w did|strong="G5101"\w* \w He|strong="G1161"\w* \w ever|strong="G4218"\w* \w say|strong="G3004"\w*,
