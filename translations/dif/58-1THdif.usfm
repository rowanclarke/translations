\id 1TH
\ide UTF-8
\h I. Thessalonichalani
\toc1 Pauluni Dakani jaura I. Thessalonichalani
\toc2 I. Thessalonichalani
\toc3 1 Thess
\mt1 Pauluni Dakani jaura I. Thessalonichalani.
\c 1
\p 
\v 1 Paululu ja Silvanulu ja Timotheulu, Thessalonicha mili wolarani Goda Ngaperani ja Kapara Jesungu Christungu. Manjula jurangu nganaiatimai ja murla Goda ngaianani Ngaperandru ja Kapara Jesu Christungundru.
\p 
\v 2 Ngaiani Goda jurakokai milingeru jurangu pratjanandru, ja jurana ngundrai ngaianini ngatjinani,
\p 
\v 3 Ja ngaiani milingeru ngundrai jurani morlalu ngundranaia ngankana, ja jurani ngantjinaia jigleri ngankana, ja jurani kalkanaia ngurunguru terkana, ngaianani Kaparani Jesungu Christungu, Goda ja Ngaperi ngaiananani.
\p 
\v 4 Ngangau ngaiani milkila, ngatata ngantjalu Godandru, jurani kalkalkani,
\p 
\v 5 Ngangau ngantjani jaura ngaianini jurangu wokarana wonti, wata windri jaurali, a‐ai, bakana ngurulali ja Jaola kulikirieli morlalu ngundrana pirnali; ngangau jura milkila, mina kana ngaiani jurangu wondraterina wonti jurangundru.
\p 
\v 6 Ja jura ngaianini ja Kaparaia karipaterini pantjina wonti, ngangau jura jaura patana wonti ketjaketjana marapuni Jaola kulikiria mankinali,
\p 
\v 7 Jeruja jura wondrani malka pantjina warai tanangu pratjanani, tanali Macedoniani ja Achajani morlalu ngundrai.
\p 
\v 8 Ngangau jurangundru Kaparaia jaura pinti marurina warai, wata windri Macedoniani ja Achajani, a‐ai, bakana piri pratjanani jurani morlalu ngundrani Godani wokarana warai, jeruja ngaiani panila ngamalkai, jendrangundruja minakulno jatala.
\p 
\v 9 Ngangau tanali muntali kaukaubai jurangundru, worderu ngaiani jurangu wirina wonti, ja worderu jura karitjina wonti muramurandru Godaia, Goda tepini ja morlaluni wodatarana ngamala,
\p 
\v 10 Ja kalkala Ngatamurani nunkanani pariwilpandru, ninaia Nulia jiritjibana wonti narindru, Jesus, Nulia ngaianana kulkana wonti tirindru, nauja wokarala nganai.
\c 2
\p 
\v 1 Ngangau jura munta milkila, ngatata worajai, ngaianini wirini jurangu wata baku nganana wonti,
\p 
\v 2 A‐ai, ngaiani ngopera, worderu jura milkila, Philippungu ketjaketjala wiri, ja tanali ngaianina jupala wiri, ngaiani murlali nganana wonti Godani ngaiananani, jurangu Godaia ngantjani jaura kaukaubala tirimalini pirnani.
\p 
\v 3 Ngangau ngaianini jaura wata jirijirindru, bakana wata murumurundru, bakana wata jedibanandru wokarai,
\p 
\v 4 A‐ai, worderu Godali ngaianina talku ngundrana wonti ngantjani jaura kaukaubala, ninaia Nulia ngaianingu matja jinkina, jeruja ngaiani kaukaubai, wata kana murlali ngankala jeribaka, a‐ai, Goda, Nulia ngara ngaianina wontjai.
\p 
\v 5 Ngangau ngaiani wata jaura jeljujeljujeli wokarana wonti, worderu jura milkila, ja wata ngukingukipaterina ngundranali, Goda tinkari ngankanietja nganai;
\p 
\v 6 Ngaiani bakana wata pirnala wontiai kanandru, wata jurangundru, ja bakana wata ngurundru; kau, ngaiani ngurunguru nganana wonti Christuni Apostel jeribaka wondralkaterila.
\p 
\v 7 A‐ai, ngaiani malti wondraterina wonti jurangu terti, worderu ngamajinkinietjali kupa nankani ngamalkai,
\p 
\v 8 Jeruja ngaiani jurangu wolkareli ngantjana wonti ja jertapaterina wonti, wata windri Godaia ngantjani jaura jurangu kaukaubala, a‐ai, bakana tepi ngaianini jinkiterila, ngangau ngaiani jurana ngantjana wonti.
\p 
\v 9 Jura ngundrai, ngatata worajai, ngankani ja jigleri ngaianini: Tinkani ja ditjini ngaiani ngankana wonti, wata kulno jurangundru jupala, ngaiani Godaia ngantjani jaura jurangu matja kaukaubana.
\p 
\v 10 Jura ja Goda tinkari ngankani nganai, worderu kulikiri ja talku ja madlentji pani ngaiani jurangu, jura morlalu ngundrai, pantjina wonti,
\p 
\v 11 Ngangau ngaiani, worderu jura milkila, kulnulu kulnulu jurangundru murlali ngankana wonti ja kurukurubana wonti, worderu Ngaperali nunkani kupa,
\p 
\v 12 Ja jurangu morlalu kurana wonti, jura nunkangupini Godani talku wirarinanto, Nulia jurana karkanala mililaia nunkanaia ja pirnalaia nunkanaia.
\p 
\v 13 Jendrangundruja bakana ngaiani milingeru Goda jurakokai, ngangau jura Godaia ngantjani jaura ngaianingundru patana wonti, wata kana jaura jeribaka, a‐ai, mina nauja morlalu nganai, Godaia jaura jeribaka, nulia bakana jurangu ngankai, jura morlalu ngundrai.
\p 
\v 14 Jeruja bakana jura, ngatata worajai, Godaia mili wolarani, tana Christungu Jesungu Judaiani karipaterini pantjina warai, ngangau bakana jura ketjaketjana warai jurani nguralandru, worderu tanali Juda kanandru;
\p 
\v 15 Tanali Kapara Jesus nari ngankana wonti, worderu tanani Propheta bakana, ja ngaianingu tiri karipaterina wonti, tanana Godali wata ngantjai, ja kana pratjanani talpala tana nganai,
\p 
\v 16 Tanali ngaianina daudauai kana koni kaukaubananto tana tepi pantjinanto, ja tanali tanani madlentji manamiri ngankananto; tiri tanangu matja wokarana warai.
\p 
\v 17 Ngaiani, ngatata worajai, miljaru wordu warawararina warai ngamuru jeribaka, windri mudlali, wata ngarali, a‐ai, ngaiani wolkareli pirna nganana warai jurani mudla najila.
\p 
\v 18 Jendrangundruja ngaiani ngantjana warai jurangu wokarala, ngani Paulus pota kulno ja pota kulno nakaldra, ja Satanali ngaianina ngandrawalkana warai.
\p 
\v 19 Worana kalkani ja mankini ja pirnalaia pirapira ngaianini nganai, ngaianani Kaparani Jesungu nunkani tikanani, jura wata jenia ngananani?
\p 
\v 20 Kau, jura pirnala ja mankini ngaianini nganai.
\c 3
\p 
\v 1 Jendrangundruja ngaiani ngandandarina paraia jeruja ngamala, ja ngaiani ngundrana paraia Athenangu ngadaia ngamantila,
\p 
\v 2 Ja ngali jinpana paraia Timotheus, ngatata ngaianini ja Godaia mili ja jelangankanietja ngaianini Christuni ngantjani jaurani, jurana ngurunguru ngankala ja kurukurubala jurani morlalu ngundranandru,
\p 
\v 3 Wata kulno walto pantjinanto tanangupini ketjaketjanani; ngangau jura munta milkila, Nulia ngaianina jendrania kurana wonti.
\p 
\v 4 Ngaiani jurangu jenia ngopera jatana wonti, ngaiani jurangunto nganana, ngaiani ketjaketjananto, worderu bakana pantjina warai, ja jura milkila.
\p 
\v 5 Jendrangundruja bakana ngani ngandandarina paraia jeruja ngamala, ja ngato jinpana paraia ngujamala jurani morlalu ngundrana, wontjanietjali jurana wontjana warai kara, ja ngankani ngaianini jeruja bakurinani.
\p 
\v 6 Karari, Timotheus jurangundru ngalingu matja tikana, ja ngalingu jaura murlali matja kaukaubana jurani morlalu ngundranandru ja jurani ngantjanandru, worderu jura ngalina milingeru ngumu ngundrai, ja wolkareli nganai ngalina najila, worderu bakana ngali jurana.
\p 
\v 7 Jeruja ngali ngankalkani manina warai, ngatata worajai, jurangundru, ngalini ketjaketjanani ja jeninani, jurani morlalu ngundranandru;
\p 
\v 8 Ngali nakaldra tepiriai, jura ngurunguru terkanani Kaparani.
\p 
\v 9 Minali ngaiani Godani jurakokananto jurangundru, nunkangupini mankini pratjanandru, ninaia ngaiani ngamalkai jurangundru Godani ngaiananani,
\p 
\v 10 Tinkani ja ditjini ngaiani wolkareli ngatjiai, ngaiani jurani mudla najinanto, ja jurani morlalu ngundranaia jurra manamiri ngankananto.
\p 
\v 11 Nulia muntali, Godali ja Ngaperali ngaiananali, ja Kaperali ngaiananali Jesus Christus, palto ngaianini jurangu ngankijiribingaiatimai,
\p 
\v 12 Kaparali jurana pirna ja manamiri ngankaiatimai ngantjanani kulno kulnuni ja warupotuni, worderu ngaiani bakana jurangu;
\p 
\v 13 Jurani ngara ngurunguru ngankala, madlentji pani nganananto kulikirini Goda ngaianani Ngaperandru, Kapara Jesus Christus ngaianani tikanani kulikirini nunkanani pratjanani jela.
\c 4
\lit (Dakani jaura Reminiscere ditjiui.)
\p 
\v 1 Morla, ngatata worajai, ngaiani jurangu ngatjiai ja jurana kurukurubai Kaparani Jesungu, jura ngaianingundru matja manina, worderu jura wirarinanto ja Goda ngantjananto, jura milingeru morla ja morla pirnarinanto;
\p 
\v 2 Ngangau jura milkila, mina jirijiribani jaura ngaiani jurangu jinkinala Kaparani Jesungu.
\p 
\v 3 Ngangau jenia Godaia jertapaterini nganai: Jurani kulikirila. Jura ngamalkaterinanto palakantjindru,
\p 
\v 4 Pratjana jurangundru milkila nganananto, tanani koko ngamalkaterila kulikiri ja pirna,
\p 
\v 5 Wata milkirinaia jertapaterinali kanani koni jeribaka, tana ko nganai Godandru;
\p 
\v 6 Wata kulno nejini nunkanani jinkimalinani ngirkingirkinanto ja jedibananto, ngangau Kapara kalala jinkinietja nganai warupotundru, worderu ngaiani jurangu ngopera kaukaubana wonti ja morlalu kurana wonti.
\p 
\v 7 Ngangau Godali wata ngaianana karkana wonti murumuruja, a‐ai, kulikiria.
\b
\p 
\v 8 Jendrangundruja, warle waka ngundrai, nulu wata kana waka ngundrai, a‐ai, Goda, Nulia Jaola kulikiri nunkani jurangu jinkina wonti.
\p 
\v 9 Ngatata ngantjanandru baku nganai jurangu dakala, ngangau jura munta Godandru kiri nganai, jura ngantjamalinanto.
\p 
\v 10 Jenia jura bakana ngankai ngatata pratjanani, tana Macedoniani paruparu ngamai. Ngaiani jurana kurukurubai, ngatata worajai, jura morla ja morla pirnarinanto,
\p 
\v 11 Ja jenia pirna ngundranau, jura ngapu nganananto, ja pilki ja pilki nunkanina ngankananto, ja muntali marali juranali ngankananto, worderu ngaiani jurangu jirijiribana wonti;
\p 
\v 12 Jura talku wirarinanto tanangu, tana palarani, jura wata kulno karkananto.
\lit (Dakani jaura G. D. 25 Trinitatis.)
\p 
\v 13 Ngaiani wata ngantjai, ngatata worajai, jura ko nganananto tanangundru, tana turarai, ngangau jura wata ngaurongauro nganananto nguruni jeribaka, tana kalkani panini.
\p 
\v 14 Ngangau ngaiana morlalu ngundranani Jesus palina wonti ja tepi terkakana wonti, jeruja Godali bakana tanana, tana Jesungunto turarana wonti, nunkangu jela wapalkala nganai.
\p 
\v 15 Ngangau jenia ngaiani jurangu jatai Kaparaia jaurali: Ngaiana, matja tepi ja pinpani ngamai Kaparaia tikanaia, tanangu, tana turarai, wata wiringala nganai.
\p 
\v 16 Ngangau Nulia muntali, Kaparali, julja wolaraia maritjinali ja angelaia kaparaia ngaialali ja Godaia wima kokojeli ngarila nganai pariwilpandru, ja narila Christuni ngopera jiritjila nganai;
\p 
\v 17 Ngadani ngaiana, tana tepi ja pinpani ngamai, tanangu jela tertapala nganai talara palkuni, Kaparani mandurila ngaranani, ja kararindru ngaiana Kaparani jela ngamala nganai ngurali.
\p 
\v 18 Nulupini jaurali ngankalkijiribamalianimai.
\b
\c 5
\lit (Dakani jaura G. D. 27 Trinitatis.)
\p 
\v 1 Ditjindru ja miljarandru, ngatata worajai, baku nganai jurangu dakala;
\p 
\v 2 Ngangau jura munta talku milkila, Kaparaia ditji wokarai, worderu kurikantji tinkani.
\p 
\v 3 Tana jatanani: Murla nganai ja japa pani, ngadani nurujeli tanangu tintani wokarai, worderu dankani ketjaketjana mandrantjani, ja tana bulu japa mindrila nganai.
\p 
\v 4 Jura, ngatata worajai, wata ngalpurani ngamanau, nulupini ditjieli kurikantjieli jeribaka jurana pataiati.
\p 
\v 5 Jura pratjana praitjaia kupa ja ditjia kupa nganai; ja ngaiana wata tinkandru ja ngalpurandru nganai.
\p 
\v 6 Jeruja ngaiana wata mukaturarananto nguruni jeribaka, a‐ai, ngaiana tepi ja milja ngamananto.
\p 
\v 7 Ngangau tana, tana mukaturarai, tinkani mukaturarai, ja tana, tana tapana parawarai, tana tinkani tapana parawarai;
\p 
\v 8 Ngaiana, ngaiana ditjindru nganai, milja ngamananto, morlalu ngundranaia ja ngantjanaia marda katieli matja widmaterina, ja kalkanaia kabuluru kulkanaia.
\p 
\v 9 Ngangau Godali ngaianana wata kurana wonti tiria, a‐ai, tepi pirna manila Kapara ngaianani Jesungu Christungundru,
\p 
\v 10 Nauja ngaianangu palina wonti, ngangau ngaiana, tepi ngamanani kara mukaturaranani kara, nunkangunto tepi ngamananto.
\p 
\v 11 Jendrangundruja kurukurubijiribamalianimai ja wotijirimalianimai, worderu jura bakana ngankai.
\b
\p 
\v 12 Ngaiani jurangu ngatjiai, ngatata worajai, jura tanana ngujamananto, tanali jurangu ngankai, ja jurani kapara nganai Kaparani, ja jurana kurukurubai,
\p 
\v 13 Ja jura tanana pirna ngundrananto ngantjanani, tanani ngankanandru. Murlali ngananau tanangunto.
\p 
\v 14 Ngaiani jurana kurukurubai, ngatata worajai: Tjikatjikaetja daudauanau; kana burkaburka pirna ngankalkanau; kana waltowalto patanau; manju ngananau pratjanani.
\p 
\v 15 Ngamalkaterianau, wata kulnujeli madlentjandru kalala madlentji jinkinanto, a‐ai, milingeru ngumu pratjanaia mindrianau, ja ngankijiribamalianimai.
\p 
\v 16 Milingeru mankianau;
\p 
\v 17 Milingeru ngatjianau;
\p 
\v 18 Warupotuni jurakokanau; ngangau jenia Godaia jertapaterina nganai Christungu Jesungu jurangu.
\p 
\v 19 Jaola wata palimanau;
\p 
\v 20 Talpadakani jaura wata waka ngundranau;
\p 
\v 21 Pratjana wontjanau; mina ngumu, jenia patanau;
\p 
\v 22 Wata baka pilki jinkianau;
\p 
\v 23 Murlaia Goda muntali jurana warupotuni kulikiri ngankau, ja jurani jaola ja mungara ja palku madlentji pani ngananau Kaparaia ngaiananaia Jesuni Christuni tikanaia.
\p 
\v 24 Wonki Nauja nganai, Nulia jurana karkai, Nulia jenia bakana ngankala nganai.
\p 
\v 25 Ngatata worajai, ngaianingundru ngatjianau!
\p 
\v 26 Mandurini jaura jinkianau ngatata pratjanani manatapana kulikirieli!
\p 
\v 27 Ngato jurangu Kaparani jaura morlalu kurai, jura ninapini dakani jaura ngatata pratjanani warapananto.
\p 
\v 28 Ngaiananaia Kaparaia Jesuni Christuni manjula jurangunto nganaiatimai! 
