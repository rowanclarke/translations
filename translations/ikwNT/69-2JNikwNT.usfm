\id 2JN - Ikwerre
\h 2 Jọni
\toc1 Ọkwukwo izi ke Ẹbo Jọni gbarụ
\toc2 2 Jọni
\toc3 2 Jọn
\mt2 Ọkwukwo izi
\mt2 ke Ẹbo
\mt1 Jọni
\mt2 gbarụ
\imt1 Nhne gbasịri ọkwukwo izi ka
\im Nga Jọni gbarụ \bk Ọkwukwo izi Jọni ke ẹbo,\bk* ọ ghọlam nye okno badnụ. O gweznenu a “Nyerinya ọma nụ rụmu a,” ke bụ ọgbako Chiokike. Ọkwukwo izi matị ka nookwu ọka gbasịri ọwhnun'anya n'ẹhni ibne be, nọodo be aka nụ nsnị gbasịri ele neezni nhne aghalaghala.
\iot Nhne zị n'ọkwukwo izi ka
\io1 Ọpanizo \ior (1-3) \ior*
\io1 Ezi ọka nụ Ọwhnun'anya \ior (4-11) \ior*
\io1 Okwukwo \ior (12-13) \ior*
\c 1
\s1 Obekwu ikwu nụ okpukpe
\p 
\v 1 Mawa, Jọni, nye okno badnụ, naagbaznenu nwerinya Chiokike họhiaru nụ rụmu a ọkwukwo, ele me whnụrnu n'anya n'ezi, ọ bụ́o me nụ nsnụnu m, kọvu kpakara ele magwụ ezi ọka.
\v 2 Kwnornu nụ ezi ọka ke zị nụ rime aị, ke jaazịgidne aị tim tọm.
\p 
\v 3 Oru nụ obirizi nụ udno ke hi n'aka Chiokike Nda nụ Jizọsi Karaịsi Nnwọ Nda aị va, jaadazịnu aị nụ ezi ọka nụ ọwhnun'anya.
\s1 Ezi ọka nụ ọwhnun'anya
\p 
\v 4 O neenye m ovu ọso n'ọnu kpa me nọowhnu rụmu ị neezne izne n'ezi ọka lele kpa Nda aị nyernu aị n'iwu.
\v 5 Kịtna, nwerinya ọma, m zá m naagbanụ ị iwu ikne, kọvu ọ bụ kọriri ke a ji hite nụ mbọm. M naarịasno ma a whnụrita ẹhni aị n'anya.
\v 6 Ka bụ ọwhnun'anya wam, a zne izne noobno nsnị nụ nhne Chiokike nyernu n'iwu. Lele kpa anụ nụrnu n'ọpanizo, iwu a bụ ma anụ zne izne n'ọwhnun'anya.
\p 
\v 7 Agịda ele nooduwhu ele badnụ, ele zá neekweru nụ Jizọsi Karaịsi varụ n'anọ-ẹhni, bnarnụ nụ rime ọwa. Nye nụ kpam bụ nye nooduwhu nụ nye neemegidne Karaịsi.
\v 8 Anụ ledu anya, ọ zị anụ tuwhu nhne anụ dọgburu ẹhni anụ n'ẹrnu, kọvu ma anụ nwehịa ọgwo ẹrnu zuru ozu.
\v 9 Nye ọbula ke neezne nụ ruwhnu gharụ nhne Karaịsi znirni máa Chiokike. Kọvu nye ọbula ke zị neeme iznizni a magwụ Nda nụ Nnwọ a.
\v 10 Nye ọbula ke vakwnusiri anụ ke gwéyala iznizni ka, anụ kwúbnana ọro anụ, mọbu kanụ a, “Ị valẹ.”
\v 11 Nye ọbula ke kannụ a, “Ị valẹ” jeekehịa igwe n'ẹrnu ọjo a.
\p 
\v 12 M nwernu m agịda nhne me jaagbanụ anụ, kọvu m jéeme kpam n'ọkwukwo nụ nki. Tnụnuma, m neele anya nụ m jaava me nụ anụ kwu ọka ruwhnu nụ ruwhnu, kpam, ovu ọso n'ọnu aị joozu ozu.
\p 
\v 13 Rụmu nwene i rinya kam Chiokike họhiaru neebekwu i.
