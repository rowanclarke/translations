\v 22 \w So|strong="G1161"\w* \w I|strong="G1161"\w* \w remained|strong="G1510"\w* unknown \w by|strong="G1722"\w* \w face|strong="G4383"\w* \w to|strong="G1722"\w* \w the|strong="G1722"\w* congregations \w of|strong="G1577"\w* \w Judea|strong="G2449"\w* (\w those|strong="G3588"\w* \w in|strong="G1722"\w* \w Christ|strong="G5547"\w*)\f + \fr 1:22 \ft Every town with a synagogue would have a local congregation, but usually not “in Christ”.\f*
