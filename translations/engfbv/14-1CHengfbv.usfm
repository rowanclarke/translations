\p 
\v 13 \w Canaan|strong="H3667"\w* \w was|strong="H1060"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H3205"\w* \w his|strong="H3205"\w* \w firstborn|strong="H1060"\w* \w son|strong="H3205"\w*, \w Sidon|strong="H6721"\w*, \w and|strong="H6721"\w* \w of|strong="H3205"\w* \w the|strong="H3205"\w* Hittites,
