\v 30 \w Après|strong="H1121"\w* \w lui|strong="H1121"\w*, \w Hanania|strong="H2608"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* Shélémia, \w et|strong="H1121"\w* \w Hanun|strong="H2586"\w*, \w le|strong="H1121"\w* \w sixième|strong="H8345"\w* \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Tsalaph|strong="H6764"\w*, \w réparèrent|strong="H2388"\w* \w une|strong="H1121"\w* \w autre|strong="H8145"\w* \w portion|strong="H4060"\w*. \w Après|strong="H1121"\w* \w lui|strong="H1121"\w*, Meshullam, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Bérékia|strong="H1296"\w*, \w fit|strong="H1121"\w* \w les|strong="H1121"\w* \w réparations|strong="H2388"\w* \w vis-à-vis|strong="H1121"\w* \w de|strong="H1121"\w* \w sa|strong="H1121"\w* \w chambre|strong="H5393"\w*.  
\v 31 \w Après|strong="H1004"\w* \w lui|strong="H1004"\w*, \w Malkija|strong="H4441"\w*, l'\w un|strong="H1121"\w* \w des|strong="H1121"\w* \w orfèvres|strong="H6885"\w*, \w fit|strong="H1004"\w* \w les|strong="H1121"\w* \w réparations|strong="H2388"\w* jusqu'\w à|strong="H1121"\w* \w la|strong="H1121"\w* \w maison|strong="H1004"\w* \w des|strong="H1121"\w* serviteurs \w du|strong="H1121"\w* \w temple|strong="H1004"\w* \w et|strong="H1121"\w* \w des|strong="H1121"\w* \w marchands|strong="H7402"\w*, \w vis-à-vis|strong="H1121"\w* \w de|strong="H1121"\w* \w la|strong="H1121"\w* \w porte|strong="H8179"\w* \w de|strong="H1121"\w* \w Miphkad|strong="H4663"\w*, \w et|strong="H1121"\w* jusqu'\w à|strong="H1121"\w* \w la|strong="H1121"\w* \w chambre|strong="H5944"\w* \w haute|strong="H5944"\w* \w du|strong="H1121"\w* \w coin|strong="H6438"\w*.  
\v 32 \w Entre|strong="H2388"\w* \w la|strong="H2388"\w* \w chambre|strong="H5944"\w* \w haute|strong="H5944"\w* \w du|strong="H8179"\w* \w coin|strong="H6438"\w* \w et|strong="H8179"\w* \w la|strong="H2388"\w* \w porte|strong="H8179"\w* \w des|strong="H8179"\w* \w brebis|strong="H6629"\w*, \w les|strong="H2388"\w* \w orfèvres|strong="H6884"\w* \w et|strong="H8179"\w* \w les|strong="H2388"\w* \w marchands|strong="H7402"\w* firent \w les|strong="H2388"\w* \w réparations|strong="H2388"\w*.   
\c 4  
\p
\v 1 Or, \w lorsque|strong="H3588"\w* \w Sanballat|strong="H5571"\w* \w apprit|strong="H8085"\w* \w que|strong="H3588"\w* \w nous|strong="H3588"\w* rebâtissions \w la|strong="H8085"\w* \w muraille|strong="H2346"\w*, \w il|strong="H3389"\w* \w fut|strong="H1961"\w* \w en|strong="H5927"\w* \w colère|strong="H2734"\w* \w et|strong="H5927"\w* \w très|strong="H3966"\w* indigné, \w et|strong="H5927"\w* \w il|strong="H3389"\w* \w se|strong="H3588"\w* moqua \w des|strong="H5927"\w* Juifs.  
\v 2 \w Il|strong="H3389"\w* parla \w devant|strong="H3389"\w* \w ses|strong="H6213"\w* \w frères|strong="H6213"\w* \w et|strong="H6213"\w* l'armée \w de|strong="H6213"\w* Samarie, \w et|strong="H6213"\w* \w dit|strong="H3389"\w* : « \w Que|strong="H6213"\w* \w font|strong="H6213"\w* \w ces|strong="H6213"\w* \w Juifs|strong="H6213"\w* faibles ? Vont-ils \w se|strong="H3162"\w* fortifier ? Vont-ils \w offrir|strong="H6213"\w* \w des|strong="H6213"\w* \w sacrifices|strong="H6213"\w* ? Vont-ils achever \w en|strong="H6213"\w* \w un|strong="H6213"\w* \w jour|strong="H6213"\w* ? Vont-ils redonner \w vie|strong="H6213"\w* \w à|strong="H6213"\w* \w des|strong="H6213"\w* \w pierres|strong="H6213"\w* ensevelies \w sous|strong="H6213"\w* \w des|strong="H6213"\w* tas \w de|strong="H6213"\w* \w poussière|strong="H6213"\w*, \w alors|strong="H6213"\w* qu'\w elles|strong="H6213"\w* \w sont|strong="H3162"\w* brûlées ? »   
\p
\v 3 Or Tobija \w l|strong="H6440"\w*'Ammonite \w était|strong="H6440"\w* \w à|strong="H6440"\w* \w côté|strong="H6440"\w* \w de|strong="H6440"\w* \w lui|strong="H6440"\w*, \w et|strong="H6440"\w* \w il|strong="H5921"\w* \w dit|strong="H6440"\w* : « Qu'\w ils|strong="H6440"\w* bâtissent seulement ! Si \w un|strong="H6440"\w* renard \w y|strong="H6440"\w* montait, \w il|strong="H5921"\w* ferait s'écrouler \w leur|strong="H6440"\w* \w muraille|strong="H6440"\w* \w de|strong="H6440"\w* \w pierre|strong="H6440"\w*. »   
\p
\v 4 « Écoute, ô \w notre|strong="H3808"\w* \w Dieu|strong="H3808"\w*, car \w nous|strong="H1129"\w* \w sommes|strong="H3808"\w* méprisés. \w Fais|strong="H3808"\w* retomber \w leurs|strong="H7235"\w* \w insultes|strong="H7235"\w* \w sur|strong="H2346"\w* \w leur|strong="H3063"\w* \w propre|strong="H1129"\w* tête, \w et|strong="H3063"\w* \w livre-les|strong="H3063"\w* \w au|strong="H3063"\w* \w pillage|strong="H3063"\w* \w dans|strong="H3808"\w* \w une|strong="H1129"\w* \w terre|strong="H6083"\w* \w de|strong="H7235"\w* captivité.  
\v 5 \w Ne|strong="H3808"\w* couvre \w pas|strong="H3808"\w* \w leur|strong="H7200"\w* iniquité, \w et|strong="H7200"\w* \w que|strong="H7200"\w* \w leur|strong="H7200"\w* \w péché|strong="H7200"\w* \w ne|strong="H3808"\w* \w soit|strong="H3808"\w* \w pas|strong="H3808"\w* \w effacé|strong="H3808"\w* \w de|strong="H7200"\w* \w devant|strong="H7200"\w* \w toi|strong="H3808"\w*, car \w ils|strong="H3045"\w* \w ont|strong="H3045"\w* offensé \w les|strong="H7200"\w* bâtisseurs. »   
\p
\v 6 \w Nous|strong="H6471"\w* \w rebâtîmes|strong="H6471"\w* \w donc|strong="H3427"\w* \w la|strong="H5921"\w* muraille, \w et|strong="H7725"\w* \w toute|strong="H3605"\w* \w la|strong="H5921"\w* muraille \w fut|strong="H1961"\w* raccordée jusqu'\w à|strong="H3427"\w* \w la|strong="H5921"\w* \w moitié|strong="H7725"\w* \w de|strong="H3427"\w* \w sa|strong="H7725"\w* hauteur, car \w le|strong="H7725"\w* peuple \w avait|strong="H1961"\w* \w à|strong="H3427"\w* \w cœur|strong="H3427"\w* \w de|strong="H3427"\w* travailler.   
\p
\v 7 Mais lorsque Sanballat, Tobija, \w les|strong="H5975"\w* Arabes, \w les|strong="H5975"\w* \w Ammonites|strong="H5975"\w* \w et|strong="H5971"\w* \w les|strong="H5975"\w* Asdodiens apprirent \w que|strong="H4725"\w* \w la|strong="H5975"\w* \w réparation|strong="H5975"\w* \w des|strong="H4940"\w* \w murailles|strong="H2346"\w* \w de|strong="H5971"\w* Jérusalem \w avançait|strong="H2346"\w*, \w et|strong="H5971"\w* \w que|strong="H4725"\w* \w les|strong="H5975"\w* brèches commençaient \w à|strong="H5975"\w* \w être|strong="H5971"\w* fermées, \w ils|strong="H5971"\w* \w furent|strong="H5971"\w* très irrités ;  
\v 8 \w ils|strong="H1121"\w* conspirèrent \w tous|strong="H5971"\w* \w ensemble|strong="H5971"\w* \w pour|strong="H6440"\w* \w venir|strong="H6440"\w* \w attaquer|strong="H3898"\w* \w Jérusalem|strong="H1121"\w* \w et|strong="H1121"\w* \w pour|strong="H6440"\w* \w y|strong="H5971"\w* \w causer|strong="H1004"\w* \w du|strong="H1121"\w* désordre.  
\v 9 \w Mais|strong="H3588"\w* \w nous|strong="H3588"\w* priâmes \w notre|strong="H3588"\w* \w Dieu|strong="H3588"\w*, \w et|strong="H7725"\w* \w nous|strong="H3588"\w* établîmes \w une|strong="H8085"\w* \w garde|strong="H3045"\w* \w contre|strong="H8085"\w* \w eux|strong="H3588"\w* \w jour|strong="H3045"\w* \w et|strong="H7725"\w* \w nuit|strong="H7725"\w* \w pour|strong="H3588"\w* \w nous|strong="H3588"\w* \w en|strong="H7725"\w* défendre.   
\p
\v 10 \w Juda|strong="H3063"\w* disait : « \w La|strong="H6213"\w* \w force|strong="H2388"\w* \w des|strong="H6213"\w* porteurs \w de|strong="H1004"\w* fardeaux faiblit, \w et|strong="H3117"\w* \w il|strong="H3117"\w* \w y|strong="H1004"\w* \w a|strong="H3068"\w* beaucoup \w de|strong="H1004"\w* \w décombres|strong="H6213"\w*, \w de|strong="H1004"\w* \w sorte|strong="H6213"\w* \w que|strong="H3117"\w* \w nous|strong="H6213"\w* \w ne|strong="H5288"\w* pouvons \w pas|strong="H6213"\w* \w bâtir|strong="H3117"\w* \w la|strong="H6213"\w* \w muraille|strong="H2388"\w*. »  
\v 11 \w Nos|strong="H6213"\w* adversaires disaient : « \w Ils|strong="H6213"\w* \w ne|strong="H3027"\w* \w sauront|strong="H3027"\w* \w et|strong="H3027"\w* \w ne|strong="H3027"\w* verront \w rien|strong="H3027"\w*, jusqu'\w à|strong="H6213"\w* \w ce|strong="H6213"\w* \w que|strong="H3027"\w* \w nous|strong="H6213"\w* \w arrivions|strong="H3027"\w* \w au|strong="H6213"\w* \w milieu|strong="H6213"\w* d'\w eux|strong="H3027"\w* ; \w nous|strong="H6213"\w* \w les|strong="H6213"\w* tuerons \w et|strong="H3027"\w* \w nous|strong="H6213"\w* \w ferons|strong="H6213"\w* cesser l'\w ouvrage|strong="H4399"\w*. »   
\p
\v 12 \w Les|strong="H1129"\w* \w Juifs|strong="H1129"\w* \w qui|strong="H1129"\w* \w habitaient|strong="H1129"\w* \w près|strong="H5921"\w* \w de|strong="H5921"\w* \w nos|strong="H5921"\w* ennemis vinrent \w nous|strong="H1129"\w* avertir dix fois, disant : « \w De|strong="H5921"\w* \w tous|strong="H5921"\w* \w les|strong="H1129"\w* \w lieux|strong="H1129"\w* où \w vous|strong="H5921"\w* \w vous|strong="H5921"\w* tournerez, \w ils|strong="H2719"\w* viendront \w contre|strong="H5921"\w* \w nous|strong="H1129"\w*. »   
\p
\v 13 C'\w est|strong="H5971"\w* pourquoi \w je|strong="H3499"\w* plaçai \w des|strong="H5921"\w* gardes \w dans|strong="H5921"\w* \w les|strong="H7235"\w* parties \w les|strong="H7235"\w* \w plus|strong="H7235"\w* basses \w de|strong="H5971"\w* \w l|strong="H5971"\w*'espace \w derrière|strong="H5971"\w* \w la|strong="H5921"\w* \w muraille|strong="H2346"\w*, \w dans|strong="H5921"\w* \w les|strong="H7235"\w* lieux dégagés. \w J|strong="H3068"\w*'\w y|strong="H5971"\w* plaçai \w le|strong="H5971"\w* \w peuple|strong="H5971"\w* \w par|strong="H5921"\w* \w familles|strong="H5971"\w*, \w avec|strong="H5971"\w* \w leurs|strong="H7235"\w* épées, \w leurs|strong="H7235"\w* \w lances|strong="H7235"\w* \w et|strong="H5921"\w* \w leurs|strong="H7235"\w* arcs.  
\v 14 \w Je|strong="H3068"\w* regardai, \w je|strong="H6963"\w* me levai, \w et|strong="H8085"\w* \w je|strong="H6963"\w* \w dis|strong="H6963"\w* \w aux|strong="H8085"\w* nobles, \w aux|strong="H8085"\w* magistrats \w et|strong="H8085"\w* \w au|strong="H8085"\w* \w reste|strong="H8085"\w* \w du|strong="H6963"\w* peuple : « \w Ne|strong="H4725"\w* \w les|strong="H8085"\w* \w craignez|strong="H8085"\w* \w pas|strong="H8085"\w* ! Souvenez-vous \w du|strong="H6963"\w* \w Seigneur|strong="H8085"\w*, \w qui|strong="H6963"\w* \w est|strong="H4725"\w* grand \w et|strong="H8085"\w* redoutable, \w et|strong="H8085"\w* \w combattez|strong="H3898"\w* \w pour|strong="H8085"\w* \w vos|strong="H8085"\w* \w frères|strong="H8085"\w*, \w vos|strong="H8085"\w* \w fils|strong="H8085"\w*, \w vos|strong="H8085"\w* filles, \w vos|strong="H8085"\w* \w femmes|strong="H8085"\w* \w et|strong="H8085"\w* \w vos|strong="H8085"\w* maisons ! »   
\p
\v 15 Lorsque \w nos|strong="H6213"\w* \w ennemis|strong="H6213"\w* apprirent \w que|strong="H5704"\w* \w nous|strong="H6213"\w* \w étions|strong="H6213"\w* avertis, \w et|strong="H3318"\w* \w que|strong="H5704"\w* \w Dieu|strong="H6213"\w* \w avait|strong="H6213"\w* anéanti \w leur|strong="H5927"\w* projet, \w nous|strong="H6213"\w* \w retournâmes|strong="H6213"\w* \w tous|strong="H6213"\w* \w à|strong="H6213"\w* \w la|strong="H6213"\w* \w muraille|strong="H2388"\w*, \w chacun|strong="H3318"\w* \w à|strong="H6213"\w* \w son|strong="H6213"\w* \w ouvrage|strong="H4399"\w*.  
\v 16 \w À|strong="H3117"\w* \w partir|strong="H3117"\w* \w de|strong="H3117"\w* \w ce|strong="H1931"\w* \w jour|strong="H3117"\w*, \w la|strong="H3117"\w* \w moitié|strong="H3117"\w* \w de|strong="H3117"\w* \w mes|strong="H3117"\w* \w serviteurs|strong="H5288"\w* \w travaillaient|strong="H4399"\w*, \w et|strong="H3117"\w* \w l|strong="H5971"\w*'\w autre|strong="H6256"\w* \w moitié|strong="H3117"\w* \w tenait|strong="H5288"\w* \w les|strong="H3117"\w* lances, \w les|strong="H3117"\w* boucliers, \w les|strong="H3117"\w* arcs \w et|strong="H3117"\w* \w les|strong="H3117"\w* cuirasses ; \w et|strong="H3117"\w* \w les|strong="H3117"\w* \w chefs|strong="H3117"\w* \w se|strong="H5971"\w* tenaient \w derrière|strong="H5971"\w* \w toute|strong="H3117"\w* \w la|strong="H3117"\w* \w maison|strong="H3117"\w* \w de|strong="H3117"\w* Juda.  
\v 17 \w Ceux|strong="H5288"\w* \w qui|strong="H4325"\w* \w bâtissaient|strong="H5288"\w* \w la|strong="H6584"\w* muraille, \w et|strong="H5288"\w* \w ceux|strong="H5288"\w* \w qui|strong="H4325"\w* portaient ou chargeaient \w les|strong="H4325"\w* fardeaux, travaillaient d'une main \w et|strong="H5288"\w* tenaient leur \w arme|strong="H7973"\w* \w de|strong="H4325"\w* l'autre.  
\v 18 Parmi les bâtisseurs, chacun avait son épée ceinte sur le côté pour bâtir. Celui qui sonnait de la trompette se tenait près de moi.  
\v 19 \w Je|strong="H3068"\w* dis aux nobles, aux magistrats et au reste du peuple : « \w L|strong="H3068"\w*'œuvre est grande et étendue, et nous sommes dispersés sur la muraille, éloignés les uns des autres.  
\v 20 Au lieu où vous entendrez le son de la trompette, rassemblez-vous là vers nous. Notre Dieu combattra pour nous. »   
\p
\v 21 C'est ainsi que nous faisions l'ouvrage. La moitié d'entre eux tenaient les lances depuis le lever de l'aurore jusqu'à l'apparition des étoiles.  
\v 22 À la même époque, je dis aussi au peuple : « Que chacun passe la nuit avec son serviteur dans Jérusalem, afin qu'ils nous servent de garde pendant la nuit, et qu'ils travaillent pendant le jour. »  
\v 23 Ainsi ni moi, ni mes frères, ni mes serviteurs, ni les hommes de la garde qui me suivaient, nous ne quittions nos vêtements. Chacun gardait son arme, même lorsqu'il allait chercher de l'eau.   
\c 5  
\p
\v 1 \w Alors|strong="H1961"\w* s'éleva \w un|strong="H5971"\w* \w grand|strong="H1419"\w* \w cri|strong="H6818"\w* \w du|strong="H5971"\w* \w peuple|strong="H5971"\w* \w et|strong="H1419"\w* \w de|strong="H5971"\w* \w leurs|strong="H1961"\w* femmes \w contre|strong="H5971"\w* \w leurs|strong="H1961"\w* \w frères|strong="H5971"\w* \w les|strong="H5971"\w* \w Juifs|strong="H3064"\w*.  
\v 2 Car \w il|strong="H1121"\w* \w y|strong="H1323"\w* \w en|strong="H3947"\w* \w avait|strong="H1121"\w* \w qui|strong="H1121"\w* disaient : « \w Nous|strong="H1121"\w*, \w nos|strong="H1121"\w* \w fils|strong="H1121"\w* \w et|strong="H1121"\w* \w nos|strong="H1121"\w* \w filles|strong="H1323"\w*, \w nous|strong="H1121"\w* sommes \w nombreux|strong="H7227"\w*. Procurez-nous \w du|strong="H1121"\w* \w blé|strong="H1715"\w*, afin \w que|strong="H1121"\w* \w nous|strong="H1121"\w* mangions \w et|strong="H1121"\w* \w que|strong="H1121"\w* \w nous|strong="H1121"\w* \w vivions|strong="H2421"\w*. »  
\v 3 \w D|strong="H3068"\w*'\w autres|strong="H3426"\w* disaient : « \w Nous|strong="H3947"\w* \w engageons|strong="H6148"\w* \w nos|strong="H6148"\w* \w champs|strong="H7704"\w*, \w nos|strong="H6148"\w* \w vignes|strong="H3754"\w* \w et|strong="H1004"\w* \w nos|strong="H6148"\w* \w maisons|strong="H1004"\w*, \w pour|strong="H3947"\w* \w avoir|strong="H3947"\w* \w du|strong="H1004"\w* \w blé|strong="H1715"\w* \w pendant|strong="H1004"\w* \w la|strong="H3947"\w* \w famine|strong="H7458"\w*. »  
\v 4 \w D|strong="H3068"\w*'\w autres|strong="H3426"\w* \w encore|strong="H3426"\w* disaient : « \w Nous|strong="H4428"\w* \w avons|strong="H3426"\w* \w emprunté|strong="H3867"\w* \w de|strong="H4428"\w* l'\w argent|strong="H3701"\w* \w pour|strong="H4428"\w* \w le|strong="H4428"\w* \w tribut|strong="H4060"\w* \w du|strong="H4428"\w* \w roi|strong="H4428"\w* \w en|strong="H4428"\w* donnant \w nos|strong="H4428"\w* \w champs|strong="H7704"\w* \w et|strong="H4428"\w* \w nos|strong="H4428"\w* \w vignes|strong="H3754"\w* \w en|strong="H4428"\w* garantie.  
