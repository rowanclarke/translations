\v 3 Atarot, \w Dibón|strong="H1769"\w*, \w Jazer|strong="H3270"\w*, Nimra, \w Hesbón|strong="H2809"\w*, Eleale, Sebam, \w Nebo|strong="H5015"\w* y Beón.  
\v 4 \w La|strong="H1931"\w* tierra \w que|strong="H1931"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* conquistó \w en|strong="H5221"\w* \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* \w la|strong="H1931"\w* congregación \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w es|strong="H1931"\w* tierra para \w ganado|strong="H4735"\w*, y tus esclavos tienen \w ganado|strong="H4735"\w*.  
\v 5 \w Por|strong="H5414"\w* tanto, dijeron, si \w hallamos|strong="H4672"\w* \w gracia|strong="H2580"\w* \w delante|strong="H5869"\w* \w de|strong="H5414"\w* ti, rogamos que \w esta|strong="H2063"\w* tierra sea \w dada|strong="H5414"\w* \w a|strong="H3068"\w* tus esclavos como posesión. No nos hagas cruzar \w el|strong="H5674"\w* \w Jordán|strong="H3383"\w*.   
\p
\v 6 \w Moisés|strong="H4872"\w* respondió \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gad|strong="H1410"\w* y \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w*: ¿Irán sus hermanos \w a|strong="H3068"\w* la \w guerra|strong="H4421"\w*, y ustedes se \w quedarán|strong="H3427"\w* \w aquí|strong="H6311"\w*?  
\v 7 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* desaniman \w el|strong="H1121"\w* \w corazón|strong="H3820"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w para|strong="H5414"\w* \w que|strong="H4100"\w* \w no|strong="H4100"\w* pasen \w a|strong="H3068"\w* la tierra \w que|strong="H4100"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* les \w dio|strong="H5414"\w*?  
\v 8 \w Así|strong="H3541"\w* \w hicieron|strong="H6213"\w* sus antepasados cuando los \w envié|strong="H7971"\w* desde Cades Barnea \w a|strong="H3068"\w* explorar la tierra.  
\v 9 \w Subieron|strong="H5927"\w* \w hasta|strong="H5704"\w* \w el|strong="H1121"\w* valle \w de|strong="H5704"\w* Escol, \w y|strong="H5704"\w* \w al|strong="H5704"\w* \w ver|strong="H7200"\w* la tierra, desanimaron \w el|strong="H1121"\w* \w corazón|strong="H3820"\w* \w de|strong="H5704"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* \w para|strong="H5704"\w* \w que|strong="H5704"\w* \w no|strong="H1115"\w* entraran \w a|strong="H3068"\w* la tierra \w que|strong="H5704"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* les \w dio|strong="H5414"\w*.   
\p
\v 10 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w se|strong="H1931"\w* encendió \w la|strong="H1931"\w* ira de \nd \+w Yavé|strong="H3068"\+w*\nd* y \w juró|strong="H7650"\w*:  
\v 11 \wj \+w Los|strong="H1121"\+w* \+w varones|strong="H3588"\+w* \+w de|strong="H3588"\+w* 20 \+w años|strong="H8141"\+w* \+w para|strong="H3588"\+w* \+w arriba|strong="H4605"\+w* \+w que|strong="H3588"\+w* \+w subieron|strong="H5927"\+w* \+w de|strong="H3588"\+w* \+w Egipto|strong="H4714"\+w*, \+w no|strong="H3808"\+w* \+w verán|strong="H7200"\+w* \+w la|strong="H3588"\+w* tierra \+w por|strong="H3588"\+w* \+w la|strong="H3588"\+w* \+w cual|strong="H3588"\+w* \+w juré|strong="H7650"\+w* \+w a|strong="H3068"\+w* Abraham, \+w Isaac|strong="H3327"\+w* \+w y|strong="H3588"\+w* \+w Jacob|strong="H3290"\+w*, \+w por|strong="H3588"\+w* \+w cuanto|strong="H3588"\+w* \+w no|strong="H3808"\+w* \+w fueron|strong="H5927"\+w* íntegros \+w para|strong="H3588"\+w* seguirme,\wj*  
\v 12 \wj \+w excepto|strong="H1115"\+w* \+w Caleb|strong="H3612"\+w*, \+w hijo|strong="H1121"\+w* \+w de|strong="H3588"\+w* Jefone, \+w cenezeo|strong="H7074"\+w*, \+w y|strong="H3588"\+w* \+w Josué|strong="H3091"\+w*, \+w hijo|strong="H1121"\+w* \+w de|strong="H3588"\+w* \+w Nun|strong="H5126"\+w*, quienes \+w con|strong="H3588"\+w* integridad siguieron \+w a|strong="H3068"\+w* \+nd \+w Yavé|strong="H3068"\+w*.\+nd* \wj*  
\v 13 Entonces se encendió \w la|strong="H3605"\w* ira \w de|strong="H5704"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w contra|strong="H3478"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5704"\w* \w los|strong="H3605"\w* \w hizo|strong="H6213"\w* andar \w errantes|strong="H5128"\w* 40 \w años|strong="H8141"\w* \w por|strong="H5704"\w* \w el|strong="H3605"\w* \w desierto|strong="H4057"\w*, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* se extinguió \w toda|strong="H3605"\w* aquella \w generación|strong="H1755"\w* \w que|strong="H5704"\w* obró \w mal|strong="H7451"\w* ante \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 14 \w Y|strong="H3068"\w* miren, ustedes surgen \w en|strong="H5921"\w* \w lugar|strong="H8478"\w* \w de|strong="H5921"\w* sus padres, una \w prole|strong="H8635"\w* \w de|strong="H5921"\w* hombres \w pecadores|strong="H2400"\w*, \w para|strong="H5921"\w* aumentar \w aún|strong="H5750"\w* \w más|strong="H5750"\w* \w el|strong="H5921"\w* ardor \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ira|strong="H2740"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w contra|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 15 \w Si|strong="H3588"\w* \w se|strong="H5971"\w* \w vuelven|strong="H7725"\w* \w de|strong="H3588"\w* seguirlo \w a|strong="H3068"\w* \w Él|strong="H3588"\w*, \w otra|strong="H5750"\w* vez \w volverá|strong="H7725"\w* \w a|strong="H3068"\w* dejarlos \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w desierto|strong="H4057"\w* \w y|strong="H3588"\w* destruirán \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*.  
\v 16 Entonces ellos se le acercaron y dijeron: Construiremos \w aquí|strong="H6311"\w* corrales para nuestro \w ganado|strong="H4735"\w* y \w ciudades|strong="H5892"\w* para nuestros pequeños.  
\v 17 Pero nosotros nos armaremos \w e|strong="H3068"\w* iremos \w con|strong="H5704"\w* diligencia \w al|strong="H5704"\w* frente \w de|strong="H6440"\w* \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \w los|strong="H3427"\w* hayamos introducido \w a|strong="H3068"\w* su \w lugar|strong="H4725"\w*. \w En|strong="H5704"\w* tanto nuestros pequeños vivirán \w en|strong="H5704"\w* \w ciudades|strong="H5892"\w* fortificadas \w por|strong="H6440"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H6440"\w* la tierra.  
\v 18 \w No|strong="H3808"\w* \w volveremos|strong="H7725"\w* \w a|strong="H3068"\w* nuestras \w casas|strong="H1004"\w* \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* \w posean|strong="H5157"\w*, cada uno, su \w heredad|strong="H5159"\w*.  
\v 19 \w No|strong="H3808"\w* tomaremos \w heredad|strong="H5159"\w* \w con|strong="H3588"\w* ellos al otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w* \w ni|strong="H3808"\w* \w más|strong="H3588"\w* \w allá|strong="H1973"\w*, \w porque|strong="H3588"\w* tendremos ya nuestra \w heredad|strong="H5159"\w* \w en|strong="H3588"\w* esta parte del \w Jordán|strong="H3383"\w*, al \w oriente|strong="H4217"\w*.   
\p
\v 20 Entonces \w Moisés|strong="H4872"\w* les respondió: \w Si|strong="H6440"\w* ustedes \w hacen|strong="H6213"\w* \w esto|strong="H2088"\w*, \w si|strong="H6440"\w* se arman \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* para ir \w a|strong="H3068"\w* la \w guerra|strong="H4421"\w*,  
\v 21 \w y|strong="H5704"\w* \w todos|strong="H3605"\w* ustedes \w armados|strong="H2502"\w* cruzan \w el|strong="H3605"\w* \w Jordán|strong="H3383"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* \w Él|strong="H3605"\w* expulse \w a|strong="H3068"\w* sus enemigos \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w Él|strong="H3605"\w*,  
\v 22 \w y|strong="H5355"\w* \w la|strong="H2063"\w* tierra \w quede|strong="H1961"\w* sometida \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w luego|strong="H7725"\w* \w se|strong="H1961"\w* \w volverán|strong="H7725"\w*. Quedarán \w libres|strong="H5355"\w* \w de|strong="H6440"\w* culpa \w ante|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w y|strong="H5355"\w* \w ante|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5355"\w* \w esta|strong="H2063"\w* tierra \w será|strong="H1961"\w* \w de|strong="H6440"\w* ustedes \w como|strong="H1961"\w* su heredad \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 23 Pero \w si|strong="H3808"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w hacen|strong="H6213"\w* \w así|strong="H3651"\w*, \w ciertamente|strong="H2009"\w* habrán \w pecado|strong="H2403"\w* contra \nd \+w Yavé|strong="H3068"\+w*\nd*, y \w sepan|strong="H3045"\w* \w que|strong="H3808"\w* su \w pecado|strong="H2403"\w* los \w alcanzará|strong="H4672"\w*.  
\v 24 Construyan, pues, \w ciudades|strong="H5892"\w* para sus pequeños, corrales para sus rebaños y \w hagan|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H6310"\w* declaró su \w boca|strong="H6310"\w*.   
\p
\v 25 Entonces \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gad|strong="H1410"\w* y \w los|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w* hablaron \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: Tus esclavos \w haremos|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H1121"\w* \w mandaste|strong="H6680"\w* \w tú|strong="H6213"\w*, nuestro \tl ʼadón\tl*.  
\v 26 Nuestros pequeños, nuestras esposas, nuestro \w ganado|strong="H4735"\w* y \w todos|strong="H3605"\w* nuestros animales quedarán \w aquí|strong="H8033"\w* en las \w ciudades|strong="H5892"\w* de \w Galaad|strong="H1568"\w*.  
\v 27 Pero tus esclavos, \w armados|strong="H2502"\w* \w todos|strong="H3605"\w* para \w la|strong="H3605"\w* \w batalla|strong="H4421"\w*, \w pasaremos|strong="H5674"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w guerra|strong="H4421"\w*, \w de|strong="H6440"\w* \w la|strong="H3605"\w* manera como \w dices|strong="H1696"\w* tú, nuestro \tl ʼadón\tl*.   
\p
\v 28 Entonces \w Moisés|strong="H4872"\w* \w los|strong="H1121"\w* encomendó al \w sacerdote|strong="H3548"\w* Eleazar, \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nun|strong="H5126"\w*, y \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H1121"\w* familia \w de|strong="H1121"\w* las \w tribus|strong="H4294"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*.  
\v 29 \w Moisés|strong="H4872"\w* les dijo: \w Si|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Gad|strong="H1410"\w* y \w los|strong="H1121"\w* \w de|strong="H6440"\w* \w Rubén|strong="H7205"\w* cruzan con ustedes \w el|strong="H3605"\w* \w Jordán|strong="H3383"\w*, \w armados|strong="H2502"\w* \w todos|strong="H3605"\w* \w para|strong="H5414"\w* \w la|strong="H3605"\w* \w guerra|strong="H4421"\w*, \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, y \w la|strong="H3605"\w* tierra es sometida \w a|strong="H3068"\w* ustedes, les \w darán|strong="H5414"\w* \w la|strong="H3605"\w* tierra \w de|strong="H6440"\w* \w Galaad|strong="H1568"\w* como posesión,  
\v 30 pero \w si|strong="H3808"\w* \w no|strong="H3808"\w* \w pasan|strong="H5674"\w* \w armados|strong="H2502"\w* con ustedes, entonces tendrán heredad \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de ustedes \w en|strong="H8432"\w* la tierra de \w Canaán|strong="H3667"\w*.   
\p
\v 31 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gad|strong="H1410"\w* y \w los|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w* \w respondieron|strong="H6030"\w*: \w Haremos|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* tus esclavos.  
\v 32 \w Nosotros|strong="H5168"\w* \w pasaremos|strong="H5674"\w* \w armados|strong="H2502"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w a|strong="H3068"\w* la tierra \w de|strong="H6440"\w* \w Canaán|strong="H3667"\w*, pero la propiedad \w de|strong="H6440"\w* nuestra \w heredad|strong="H5159"\w* estará \w a|strong="H3068"\w* este \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*.  
\v 33 \w Moisés|strong="H4872"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gad|strong="H1410"\w* y \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w* y \w a|strong="H3068"\w* la media \w tribu|strong="H7626"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w José|strong="H3130"\w*: \w el|strong="H1121"\w* \w reino|strong="H4467"\w* \w de|strong="H1121"\w* \w Sehón|strong="H5511"\w*, \w rey|strong="H4428"\w* amorreo, y \w el|strong="H1121"\w* \w reino|strong="H4467"\w* \w de|strong="H1121"\w* \w Og|strong="H5747"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Basán|strong="H1316"\w*, la tierra con sus \w ciudades|strong="H5892"\w*, con sus territorios, y las \w ciudades|strong="H5892"\w* \w de|strong="H1121"\w* la tierra circundante.   
\p
\v 34 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gad|strong="H1410"\w* construyeron \w Dibón|strong="H1769"\w*, Atarot, \w Aroer|strong="H6177"\w*,  
\v 35 Atarot-sofán, \w Jazer|strong="H3270"\w* y Jogbeha,  
\v 36 Bet-nimra y Bet-arán, \w ciudades|strong="H5892"\w* fortificadas, y también corrales para el \w rebaño|strong="H6629"\w*.  
\v 37 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Rubén|strong="H7205"\w* construyeron \w Hesbón|strong="H2809"\w*, Eleale, Quiriataim,  
\v 38 \w Nebo|strong="H5015"\w* y Baal-meón (cambiadas de \w nombre|strong="H8034"\w*), y Sibma. \w Y|strong="H3068"\w* \w llamaron|strong="H7121"\w* por sus \w nombres|strong="H8034"\w* las \w ciudades|strong="H5892"\w* que reedificaron.   
\p
\v 39 También \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Maquir, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, \w fueron|strong="H3212"\w* \w a|strong="H3068"\w* \w Galaad|strong="H1568"\w*, la capturaron y desposeyeron \w a|strong="H3068"\w* \w los|strong="H1121"\w* amorreos \w que|strong="H1121"\w* estaban \w en|strong="H3212"\w* ella.  
\v 40 \w Moisés|strong="H4872"\w* \w dio|strong="H5414"\w* \w Galaad|strong="H1568"\w* \w a|strong="H3068"\w* Maquir, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*, y vivió en ella.  
\v 41 También \w Jaír|strong="H2971"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w* \w fue|strong="H1980"\w* y se apoderó \w de|strong="H1121"\w* sus aldeas, y les puso \w el|strong="H1121"\w* \w nombre|strong="H7121"\w* Javot-Jaír.  
\v 42 También \w Noba|strong="H5025"\w* \w fue|strong="H1980"\w* y capturó Quenat y sus \w aldeas|strong="H1323"\w*, y conforme \w a|strong="H3068"\w* su \w nombre|strong="H8034"\w* la \w llamó|strong="H7121"\w* \w Noba|strong="H5025"\w*.   
\c 33  
\s1 Desde Egipto al Jordán  
\p
\v 1 Estas son las jornadas \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* cuando \w salieron|strong="H3318"\w* \w de|strong="H1121"\w* la tierra \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w* \w en|strong="H3318"\w* escuadrones, bajo \w el|strong="H1121"\w* mando \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w* y Aarón.  
\v 2 \w Por|strong="H5921"\w* \w mandato|strong="H6310"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w Moisés|strong="H4872"\w* \w escribió|strong="H3789"\w* \w los|strong="H5921"\w* puntos \w de|strong="H5921"\w* \w salida|strong="H4161"\w* \w según|strong="H5921"\w* sus jornadas. Estas \w son|strong="H6310"\w* sus jornadas \w conforme|strong="H6310"\w* \w a|strong="H3068"\w* sus puntos \w de|strong="H5921"\w* partida:   
\p
\v 3 \w Salieron|strong="H3318"\w* \w de|strong="H2568"\w* Rameses \w el|strong="H3605"\w* \w día|strong="H3117"\w* 15 del \w mes|strong="H2320"\w* \w primero|strong="H7223"\w*, \w la|strong="H3605"\w* mañana \w siguiente|strong="H4283"\w* \w de|strong="H2568"\w* \w la|strong="H3605"\w* \w Pascua|strong="H6453"\w*. \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H2568"\w* \w Israel|strong="H3478"\w* \w salieron|strong="H3318"\w* con \w mano|strong="H3027"\w* \w poderosa|strong="H7311"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* vista \w de|strong="H2568"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w egipcios|strong="H4713"\w*,  
\v 4 \w mientras|strong="H3605"\w* \w éstos|strong="H3605"\w* enterraban \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus \w primogénitos|strong="H1060"\w*, \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w que|strong="H3605"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w hirió|strong="H5221"\w* de muerte. También \nd \+w Yavé|strong="H3068"\+w*\nd* \w ejecutó|strong="H6213"\w* actos justicieros contra sus \tl ʼelohim\tl*.   
\p
\v 5 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w salieron|strong="H5265"\w* \w de|strong="H1121"\w* Rameses y acamparon en Sucot.   
\p
