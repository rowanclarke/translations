\q2 \w including|strong="H3605"\w* \w the|strong="H3605"\w* leaders \w of|strong="H3027"\w* Israel.  
\q1 \w They|strong="H3588"\w* \w and|strong="H3027"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w other|strong="H3605"\w* \w people|strong="H3820"\w*, \w my|strong="H3605"\w* \w people|strong="H3820"\w*,  
\q2 \w will|strong="H1961"\w* \w be|strong="H1961"\w* killed \w by|strong="H3027"\w* swords,  
