\v 15 \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, Quien mora \w en|strong="H5921"\w* \w medio|strong="H7130"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*, \w es|strong="H3588"\w* \w celoso|strong="H7067"\w*, \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H3588"\w* \w el|strong="H5921"\w* furor \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w se|strong="H5921"\w* encienda \w contra|strong="H5921"\w* \w ti|strong="H5921"\w* \w y|strong="H3588"\w* \w te|strong="H5921"\w* destruya \w de|strong="H5921"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* superficie \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra.
\p 
\v 16 \w No|strong="H3808"\w* tentarán \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*, como \w lo|strong="H3808"\w* \w tentaron|strong="H5254"\w* en Masa.
\p 
\v 17 \w Guarden|strong="H8104"\w* diligentemente los \w Mandamientos|strong="H4687"\w* de \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*, sus Testimonios y sus \w Estatutos|strong="H2706"\w* que \w les|strong="H6680"\w* \w ordenó|strong="H6680"\w*.
\p 
\v 18 \w Harás|strong="H6213"\w* \w lo|strong="H6213"\w* \w recto|strong="H3477"\w* y \w lo|strong="H6213"\w* \w bueno|strong="H2896"\w* ante \nd \w Yavé|strong="H3068"\w*\nd* \w para|strong="H4616"\w* \w que|strong="H4616"\w* \w te|strong="H5869"\w* vaya \w bien|strong="H2896"\w*, y entres y poseas la \w buena|strong="H2896"\w* tierra \w que|strong="H4616"\w* \nd \w Yavé|strong="H3068"\w*\nd* prometió con juramento \w a|strong="H3068"\w* tus antepasados,
\v 19 para \w que|strong="H3605"\w* \w Él|strong="H3605"\w* eche \w a|strong="H3068"\w* \w todos|strong="H3605"\w* tus enemigos \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti, como \nd \w Yavé|strong="H3068"\w*\nd* prometió.
\p 
\v 20 \w Cuando|strong="H3588"\w* tu \w hijo|strong="H1121"\w* \w te|strong="H3588"\w* \w pregunte|strong="H7592"\w* \w mañana|strong="H4279"\w*: ¿\w Qué|strong="H3588"\w* significan \w los|strong="H1121"\w* Testimonios, \w los|strong="H1121"\w* \w Estatutos|strong="H2706"\w* \w y|strong="H3588"\w* las \w Ordenanzas|strong="H2706"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* nuestro \nd ʼElohim\nd* \w les|strong="H6680"\w* \w ordenó|strong="H6680"\w*?
\v 21 Entonces dirás \w a|strong="H3068"\w* tu \w hijo|strong="H1121"\w*: Nosotros éramos esclavos \w de|strong="H1121"\w* \w Faraón|strong="H6547"\w* \w en|strong="H3318"\w* \w Egipto|strong="H4714"\w*, pero \nd \w Yavé|strong="H3068"\w*\nd* nos \w sacó|strong="H3318"\w* \w de|strong="H1121"\w* \w Egipto|strong="H4714"\w* con \w mano|strong="H3027"\w* \w fuerte|strong="H2389"\w*.
\v 22 Ante nuestros propios \w ojos|strong="H5869"\w*, \nd \w Yavé|strong="H3068"\w*\nd* \w hizo|strong="H5414"\w* señales y \w grandes|strong="H1419"\w* \w prodigios|strong="H4159"\w* en \w Egipto|strong="H4714"\w* contra \w Faraón|strong="H6547"\w* y contra \w toda|strong="H3605"\w* su \w casa|strong="H1004"\w*,
\v 23 y nos \w sacó|strong="H3318"\w* \w de|strong="H5414"\w* \w allá|strong="H8033"\w* \w para|strong="H4616"\w* traernos y darnos la tierra \w que|strong="H4616"\w* prometió con juramento \w a|strong="H3068"\w* nuestros antepasados.
\p 
\v 24 \nd \w Yavé|strong="H3068"\w*\nd* nos \w ordenó|strong="H6680"\w* practicar \w todos|strong="H3605"\w* \w estos|strong="H2088"\w* \w Estatutos|strong="H2706"\w* y temer \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* nuestro \nd ʼElohim\nd* para \w que|strong="H3117"\w* \w siempre|strong="H3605"\w* nos vaya \w bien|strong="H2896"\w* y para \w que|strong="H3117"\w* nos conserve \w la|strong="H3605"\w* \w vida|strong="H3117"\w*, como sucede \w hoy|strong="H3117"\w*.
\v 25 \w Será|strong="H1961"\w* \w justicia|strong="H6666"\w* \w para|strong="H3588"\w* \w nosotros|strong="H3605"\w* \w si|strong="H3588"\w* tenemos \w el|strong="H3588"\w* cuidado \w de|strong="H3588"\w* cumplir \w todo|strong="H3605"\w* \w este|strong="H2063"\w* \w Mandamiento|strong="H4687"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* nuestro \nd ʼElohim\nd*, \w tal|strong="H2063"\w* \w como|strong="H3588"\w* \w Él|strong="H3588"\w* nos \w ordenó|strong="H6680"\w*.
\c 7
\s1 Exterminio de los cananeos
\p 
\v 1 \w Cuando|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H4480"\w* introduzca \w en|strong="H4480"\w* \w la|strong="H3588"\w* tierra \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w cual|strong="H3588"\w* entrarás \w para|strong="H3588"\w* poseerla, \w y|strong="H3588"\w* expulse \w de|strong="H4480"\w* \w delante|strong="H6440"\w* \w de|strong="H4480"\w* \w ti|strong="H4480"\w* \w a|strong="H3068"\w* \w muchas|strong="H7227"\w* \w naciones|strong="H1471"\w*: \w al|strong="H4480"\w* heteo, \w al|strong="H4480"\w* gergeseo, \w al|strong="H4480"\w* amorreo, \w al|strong="H4480"\w* \w cananeo|strong="H3669"\w*, \w al|strong="H4480"\w* ferezeo, \w al|strong="H4480"\w* \w heveo|strong="H2340"\w* \w y|strong="H3588"\w* \w al|strong="H4480"\w* \w jebuseo|strong="H2983"\w*, \w siete|strong="H7651"\w* \w naciones|strong="H1471"\w* \w mayores|strong="H7227"\w* \w y|strong="H3588"\w* \w más|strong="H3588"\w* \w fuertes|strong="H6099"\w* \w que|strong="H3588"\w* tú,
\v 2 y \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* las \w entregue|strong="H5414"\w* \w ante|strong="H6440"\w* ti y las derrotes, las destruirás \w por|strong="H6440"\w* completo. \w No|strong="H3808"\w* \w harás|strong="H3772"\w* \w pacto|strong="H1285"\w* con ellas, \w ni|strong="H3808"\w* les \w tendrás|strong="H5414"\w* \w compasión|strong="H2603"\w*.
\v 3 \w No|strong="H3808"\w* \w emparentarás|strong="H2859"\w* con ellas. \w No|strong="H3808"\w* \w darás|strong="H5414"\w* tus \w hijas|strong="H1323"\w* \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w ni|strong="H3808"\w* \w tomarás|strong="H3947"\w* sus \w hijas|strong="H1323"\w* \w para|strong="H5414"\w* tus \w hijos|strong="H1121"\w*,
\v 4 \w porque|strong="H3588"\w* apartarán \w a|strong="H3068"\w* tu \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* seguirme \w para|strong="H3588"\w* \w servir|strong="H5647"\w* \w a|strong="H3068"\w* otros \tl ʼelohim\tl*. \w La|strong="H3588"\w* ira \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* se encenderá contra ustedes \w y|strong="H3588"\w* \w los|strong="H1121"\w* \w destruirá|strong="H8045"\w* \w pronto|strong="H4118"\w*.
\v 5 \w Esto|strong="H3541"\w* \w es|strong="H3588"\w* \w lo|strong="H6213"\w* \w que|strong="H3588"\w* \w harán|strong="H6213"\w* \w con|strong="H3588"\w* \w ellos|strong="H1992"\w*: demolerán \w sus|strong="H1992"\w* \w altares|strong="H4196"\w*, \w destruirán|strong="H5422"\w* \w sus|strong="H1992"\w* estelas, talarán \w sus|strong="H1992"\w* Aseras\f + \fr 7:5 \ft Asera: diosa cananea de la fertilidad considerada madre de los \tl ʼelohim\tl*.\f* \w y|strong="H3588"\w* \w quemarán|strong="H8313"\w* \w sus|strong="H1992"\w* imágenes \w en|strong="H3588"\w* \w el|strong="H3588"\w* fuego.
\v 6 \w Porque|strong="H3588"\w* tú \w eres|strong="H1961"\w* un \w pueblo|strong="H5971"\w* consagrado \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*. \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H5921"\w* escogió \w a|strong="H3068"\w* \w ti|strong="H5921"\w* \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* superficie \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w seas|strong="H1961"\w* un \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w su|strong="H3588"\w* propia posesión.
\p 
\v 7 \nd \w Yavé|strong="H3068"\w*\nd* \w no|strong="H3808"\w* \w se|strong="H3808"\w* agradó \w de|strong="H3588"\w* ustedes \w ni|strong="H3808"\w* \w los|strong="H3605"\w* escogió \w porque|strong="H3588"\w* \w eran|strong="H3808"\w* \w más|strong="H3588"\w* numerosos \w que|strong="H3588"\w* \w cualquiera|strong="H3605"\w* \w de|strong="H3588"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w*, \w porque|strong="H3588"\w* ustedes \w eran|strong="H3808"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w más|strong="H3588"\w* pequeño,
\v 8 \w sino|strong="H3588"\w* \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w los|strong="H3588"\w* ama, \w y|strong="H3588"\w* quiso cumplir \w el|strong="H3588"\w* \w juramento|strong="H7621"\w* \w que|strong="H3588"\w* hizo \w a|strong="H3068"\w* sus antepasados. \nd \w Yavé|strong="H3068"\w* l\nd*os \w sacó|strong="H3318"\w* \w con|strong="H3588"\w* \w mano|strong="H3027"\w* \w fuerte|strong="H2389"\w* \w y|strong="H3588"\w* \w los|strong="H3588"\w* \w redimió|strong="H6299"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* esclavitud, del dominio \w de|strong="H3588"\w* \w Faraón|strong="H6547"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*.
\p 
\v 9 \w Reconoce|strong="H3045"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w es|strong="H1931"\w* fiel, \w que|strong="H3588"\w* \w guarda|strong="H8104"\w* \w el|strong="H1931"\w* \w Pacto|strong="H1285"\w* \w y|strong="H3588"\w* \w la|strong="H1931"\w* \w misericordia|strong="H2617"\w* \w hasta|strong="H1931"\w* 1.000 \w generaciones|strong="H1755"\w* \w de|strong="H3588"\w* \w los|strong="H1931"\w* \w que|strong="H3588"\w* \w lo|strong="H1931"\w* aman \w y|strong="H3588"\w* \w guardan|strong="H8104"\w* \w sus|strong="H1931"\w* \w Mandamientos|strong="H4687"\w*,
\v 10 pero retribuye en sus caras \w a|strong="H3068"\w* los \w que|strong="H3808"\w* \w lo|strong="H3808"\w* \w aborrecen|strong="H8130"\w* hasta destruirlos. \w No|strong="H3808"\w* demorará. Al \w que|strong="H3808"\w* \w lo|strong="H3808"\w* \w aborrece|strong="H8130"\w* le \w dará|strong="H7999"\w* el pago en su misma \w cara|strong="H6440"\w*.
\p 
\v 11 Por tanto, \w guarda|strong="H8104"\w* \w el|strong="H6213"\w* \w Mandamiento|strong="H4687"\w*, los \w Estatutos|strong="H2706"\w* y las \w Ordenanzas|strong="H2706"\w* \w que|strong="H3117"\w* \w hoy|strong="H3117"\w* te \w ordeno|strong="H6680"\w* para \w que|strong="H3117"\w* los practiques.
\p 
\v 12 Entonces \w sucederá|strong="H1961"\w* \w que|strong="H1961"\w* \w por|strong="H6118"\w* cuanto \w tú|strong="H6213"\w* escuchas estos Decretos, \w los|strong="H1961"\w* \w guardas|strong="H8104"\w* y \w los|strong="H1961"\w* practicas, también \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd* \w guardará|strong="H8104"\w* contigo \w el|strong="H6213"\w* \w Pacto|strong="H1285"\w* y \w la|strong="H8104"\w* \w misericordia|strong="H2617"\w* \w que|strong="H1961"\w* \w juró|strong="H7650"\w* \w a|strong="H3068"\w* tus antepasados.
\v 13 \w Te|strong="H5921"\w* amará, \w te|strong="H5921"\w* \w bendecirá|strong="H1288"\w* \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w multiplicará|strong="H7235"\w*. \w Bendecirá|strong="H1288"\w* también \w el|strong="H5921"\w* \w fruto|strong="H6529"\w* \w de|strong="H5921"\w* tu vientre, \w el|strong="H5921"\w* \w fruto|strong="H6529"\w* \w de|strong="H5921"\w* tu tierra, tu \w grano|strong="H1715"\w*, tu \w mosto|strong="H8492"\w*, tu \w aceite|strong="H3323"\w*, \w las|strong="H5921"\w* crías \w de|strong="H5921"\w* tus manadas \w de|strong="H5921"\w* \w ganado|strong="H6629"\w* vacuno \w y|strong="H5921"\w* \w el|strong="H5921"\w* incremento \w de|strong="H5921"\w* tu \w rebaño|strong="H6629"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w que|strong="H5921"\w* \w Él|strong="H5921"\w* \w juró|strong="H7650"\w* \w a|strong="H3068"\w* tus antepasados \w que|strong="H5921"\w* \w te|strong="H5921"\w* \w daría|strong="H5414"\w*.
\v 14 \w Serás|strong="H1961"\w* bendecido \w más|strong="H3808"\w* \w que|strong="H3808"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w*. \w No|strong="H3808"\w* \w habrá|strong="H1961"\w* hombre \w ni|strong="H3808"\w* mujer estéril \w entre|strong="H3808"\w* ustedes, \w ni|strong="H3808"\w* en tu ganado.
\p 
\v 15 \nd \w Yavé|strong="H3068"\w*\nd* \w quitará|strong="H5493"\w* \w de|strong="H4480"\w* \w ti|strong="H4480"\w* \w toda|strong="H3605"\w* \w enfermedad|strong="H2483"\w* y \w todas|strong="H3605"\w* las \w malas|strong="H7451"\w* \w plagas|strong="H4064"\w* \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w* \w que|strong="H4480"\w* tú \w conoces|strong="H3045"\w*, pero las cargará \w sobre|strong="H4480"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H4480"\w* \w te|strong="H4480"\w* \w aborrecen|strong="H8130"\w*.
\v 16 Destruye \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H5869"\w* \w entregue|strong="H5414"\w*. \w No|strong="H3808"\w* \w tengas|strong="H5414"\w* compasión \w de|strong="H5921"\w* \w ellos|strong="H1931"\w* \w ni|strong="H3808"\w* rindas culto \w a|strong="H3068"\w* \w sus|strong="H1931"\w* \tl ʼelohim\tl*, \w porque|strong="H3588"\w* \w eso|strong="H1931"\w* \w será|strong="H1931"\w* una trampa \w para|strong="H5921"\w* \w ti|strong="H5921"\w*.
\p 
\v 17 \w Si|strong="H3588"\w* dices \w en|strong="H4480"\w* tu \w corazón|strong="H3824"\w*: Estas \w naciones|strong="H1471"\w* \w son|strong="H3588"\w* \w más|strong="H3588"\w* \w grandes|strong="H7227"\w* \w que|strong="H3588"\w* \w yo|strong="H4480"\w*, ¿\w cómo|strong="H3588"\w* \w puedo|strong="H3201"\w* desposeerlas?
\v 18 \w No|strong="H3808"\w* \w les|strong="H1992"\w* \w temas|strong="H3372"\w*. Recuerda \w bien|strong="H2142"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd* \w hizo|strong="H6213"\w* con \w Faraón|strong="H6547"\w* y con \w todo|strong="H3605"\w* \w Egipto|strong="H4714"\w*.
\v 19 Las \w pruebas|strong="H4531"\w* tremendas \w que|strong="H5971"\w* \w vieron|strong="H7200"\w* tus \w ojos|strong="H5869"\w*, las señales y \w los|strong="H3605"\w* portentos, \w la|strong="H3605"\w* \w mano|strong="H3027"\w* \w fuerte|strong="H2389"\w* y \w el|strong="H3605"\w* \w brazo|strong="H2220"\w* \w extendido|strong="H5186"\w* con \w el|strong="H3605"\w* cual \w te|strong="H5869"\w* \w sacó|strong="H3318"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd*. \w Así|strong="H3651"\w* \w hará|strong="H6213"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w* \w de|strong="H6440"\w* cuya \w presencia|strong="H6440"\w* tengas temor.
\p 
\v 20 \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w enviará|strong="H7971"\w* avispas \w contra|strong="H6440"\w* \w ellos|strong="H1571"\w*, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* perezcan los \w que|strong="H5704"\w* queden escondidos \w de|strong="H6440"\w* ti.
\v 21 \w No|strong="H3808"\w* \w desmayes|strong="H6206"\w* \w ante|strong="H6440"\w* ellos, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* está \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* ti, \nd ʼElohim\nd* \w grande|strong="H1419"\w* \w y|strong="H3588"\w* \w terrible|strong="H3372"\w*.
\p 
\v 22 \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* expulsará \w a|strong="H3068"\w* esos \w pueblos|strong="H1471"\w* \w de|strong="H5921"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w poco|strong="H4592"\w* \w a|strong="H3068"\w* \w poco|strong="H4592"\w*. \w No|strong="H3808"\w* \w podrás|strong="H3201"\w* exterminarlos \w de|strong="H5921"\w* inmediato, \w no|strong="H3808"\w* \w sea|strong="H6435"\w* \w que|strong="H3808"\w* \w las|strong="H5921"\w* fieras \w del|strong="H5921"\w* \w campo|strong="H7704"\w* sean \w demasiado|strong="H7235"\w* numerosas \w para|strong="H5921"\w* \w ti|strong="H5921"\w*.
\v 23 \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* los \w entregará|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti, \w e|strong="H3068"\w* infligirá derrota sobre ellos \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* sean \w destruidos|strong="H8045"\w*.
\v 24 Él \w entregará|strong="H5414"\w* sus \w reyes|strong="H4428"\w* \w en|strong="H5704"\w* tu \w mano|strong="H3027"\w*, \w y|strong="H5704"\w* destruirás sus \w nombres|strong="H8034"\w* \w de|strong="H8478"\w* \w debajo|strong="H8478"\w* del \w cielo|strong="H8064"\w*. \w Nadie|strong="H3808"\w* te \w podrá|strong="H3808"\w* hacer frente \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* los destruyas.
\p 
\v 25 \w Quemarás|strong="H8313"\w* \w con|strong="H5921"\w* fuego \w las|strong="H5921"\w* \w esculturas|strong="H6456"\w* \w de|strong="H5921"\w* \w sus|strong="H1931"\w* \tl ʼelohim\tl*. \w No|strong="H3808"\w* \w codiciarás|strong="H2530"\w* \w la|strong="H1931"\w* \w plata|strong="H3701"\w* \w ni|strong="H3808"\w* \w el|strong="H1931"\w* \w oro|strong="H2091"\w* \w que|strong="H3588"\w* \w las|strong="H5921"\w* recubre, \w ni|strong="H3808"\w* \w te|strong="H5921"\w* \w lo|strong="H1931"\w* apropiarás, \w no|strong="H3808"\w* \w sea|strong="H6435"\w* \w que|strong="H3588"\w* \w tropieces|strong="H3369"\w* \w en|strong="H5921"\w* \w ello|strong="H1931"\w*, \w porque|strong="H3588"\w* \w es|strong="H1931"\w* repugnancia \w para|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*.
\v 26 \w No|strong="H3808"\w* introduzcas \w en|strong="H3588"\w* tu \w casa|strong="H1004"\w* alguna cosa repugnante \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w seas|strong="H1961"\w* maldición. \w La|strong="H1931"\w* aborrecerás \w y|strong="H3588"\w* \w la|strong="H1931"\w* repugnarás completamente, \w porque|strong="H3588"\w* \w es|strong="H1931"\w* maldición.
\c 8
\s1 Las bendiciones divinas
\p 
\v 1 Cuidarán de practicar \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w Mandamientos|strong="H4687"\w* \w que|strong="H3117"\w* \w yo|strong="H6680"\w* \w les|strong="H6680"\w* \w ordeno|strong="H6680"\w* \w hoy|strong="H3117"\w* \w para|strong="H4616"\w* \w que|strong="H3117"\w* vivan, se multipliquen y entren \w a|strong="H3068"\w* poseer \w la|strong="H8104"\w* tierra \w que|strong="H3117"\w* \nd \w Yavé|strong="H3068"\w*\nd* prometió con juramento \w a|strong="H3068"\w* sus antepasados.
\p 
\v 2 \w Acuérdate|strong="H2142"\w* de \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w* \w en|strong="H3212"\w* \w el|strong="H3605"\w* \w desierto|strong="H4057"\w* \w por|strong="H1870"\w* donde te condujo \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w estos|strong="H2088"\w* 40 \w años|strong="H8141"\w* \w para|strong="H4616"\w* afligirte, probarte y \w saber|strong="H3045"\w* \w lo|strong="H2088"\w* \w que|strong="H3808"\w* había \w en|strong="H3212"\w* tu \w corazón|strong="H3824"\w*, \w si|strong="H3808"\w* guardarías \w o|strong="H3068"\w* \w no|strong="H3808"\w* sus \w Mandamientos|strong="H4687"\w*.
\p 
\v 3 \w Él|strong="H5921"\w* \w te|strong="H5921"\w* \w humilló|strong="H6031"\w* \w y|strong="H3588"\w* \w te|strong="H5921"\w* dejó padecer \w hambre|strong="H7456"\w*, \w pero|strong="H3588"\w* \w te|strong="H5921"\w* sustentó \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w maná|strong="H4478"\w*, \w comida|strong="H3899"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w conocías|strong="H3045"\w*, \w ni|strong="H3808"\w* tus antepasados \w conocieron|strong="H3045"\w* \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* hacerte entender \w que|strong="H3588"\w* \w no|strong="H3808"\w* solo \w de|strong="H5921"\w* \w pan|strong="H3899"\w* \w vive|strong="H2421"\w* \w el|strong="H5921"\w* hombre, \w sino|strong="H3588"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* \w sale|strong="H4161"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 4 Tu \w ropa|strong="H8071"\w* \w nunca|strong="H3808"\w* \w se|strong="H3808"\w* envejeció \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*, \w ni|strong="H3808"\w* tu \w pie|strong="H7272"\w* \w se|strong="H3808"\w* hinchó \w en|strong="H5921"\w* \w estos|strong="H2088"\w* 40 \w años|strong="H8141"\w*.
\v 5 \w Reconoce|strong="H3045"\w*, \w pues|strong="H3588"\w*, \w en|strong="H5973"\w* tu \w corazón|strong="H3824"\w*, \w que|strong="H3588"\w* \w como|strong="H3588"\w* un \w hombre|strong="H1121"\w* \w corrige|strong="H3256"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w*, \w así|strong="H3588"\w* \w te|strong="H5973"\w* \w corrige|strong="H3256"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*.
\p 
\v 6 \w Por|strong="H1870"\w* tanto, \w guardarás|strong="H8104"\w* los \w Mandamientos|strong="H4687"\w* \w de|strong="H3372"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, \w andarás|strong="H3212"\w* \w en|strong="H3212"\w* sus \w caminos|strong="H1870"\w* y \w temerás|strong="H3372"\w* \w a|strong="H3068"\w* Él.
\v 7 \w Porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H5869"\w* introduce \w a|strong="H3068"\w* una tierra \w buena|strong="H2896"\w*, tierra \w de|strong="H3588"\w* \w arroyos|strong="H5158"\w* \w de|strong="H3588"\w* \w agua|strong="H4325"\w*, \w de|strong="H3588"\w* \w fuentes|strong="H5869"\w* \w y|strong="H3588"\w* manantiales \w que|strong="H3588"\w* brotan \w en|strong="H3588"\w* \w los|strong="H3588"\w* valles \w y|strong="H3588"\w* \w en|strong="H3588"\w* las montañas,
\v 8 tierra de \w trigo|strong="H2406"\w*, \w cebada|strong="H8184"\w*, \w vides|strong="H1612"\w*, \w higueras|strong="H8384"\w* y granados, tierra de \w aceite|strong="H8081"\w* de \w olivas|strong="H2132"\w* y \w miel|strong="H1706"\w*,
\v 9 tierra en \w la|strong="H3605"\w* cual comerás \w el|strong="H3605"\w* \w pan|strong="H3899"\w* \w sin|strong="H3808"\w* escasez y \w nada|strong="H3808"\w* te faltará en \w ella|strong="H3605"\w*, tierra cuyas piedras \w son|strong="H3808"\w* \w hierro|strong="H1270"\w*, y de sus montañas extraerás \w el|strong="H3605"\w* cobre.
\p 
\v 10 Comerás \w y|strong="H5921"\w* \w te|strong="H5921"\w* saciarás. \w Bendecirás|strong="H1288"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w buena|strong="H2896"\w* tierra \w que|strong="H5921"\w* \w te|strong="H5921"\w* \w dio|strong="H5414"\w*.
\v 11 Cuídate \w de|strong="H7911"\w* \w no|strong="H6435"\w* olvidar \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* al \w no|strong="H6435"\w* \w guardar|strong="H8104"\w* sus \w Mandamientos|strong="H4687"\w*, \w Ordenanzas|strong="H4941"\w* y \w Estatutos|strong="H2708"\w* \w que|strong="H6435"\w* \w yo|strong="H6680"\w* te \w ordeno|strong="H6680"\w* \w hoy|strong="H3117"\w*,
\v 12 \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H6435"\w* cuando comas y te sacies, \w edifiques|strong="H1129"\w* \w hermosas|strong="H2896"\w* \w casas|strong="H1004"\w* y las ocupes,
\v 13 tus manadas de \w ganado|strong="H6629"\w* \w vacuno|strong="H1241"\w* \w y|strong="H1241"\w* tus rebaños incrementen, \w la|strong="H3605"\w* \w plata|strong="H3701"\w* \w y|strong="H1241"\w* \w el|strong="H3605"\w* \w oro|strong="H2091"\w* se te multipliquen \w y|strong="H1241"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* tengas aumente,
\v 14 tu \w corazón|strong="H3824"\w* se enaltezca y te \w olvides|strong="H7911"\w* \w de|strong="H7911"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*.
\p Él te \w sacó|strong="H3318"\w* \w de|strong="H7911"\w* la tierra \w de|strong="H7911"\w* \w Egipto|strong="H4714"\w*, \w de|strong="H7911"\w* la \w casa|strong="H1004"\w* \w de|strong="H7911"\w* esclavitud,
\v 15 te condujo por un \w desierto|strong="H4057"\w* vasto y \w terrible|strong="H3372"\w* con \w serpientes|strong="H5175"\w* \w ardientes|strong="H8314"\w* y escorpiones, y \w en|strong="H3318"\w* una tierra sedienta, carente \w de|strong="H3372"\w* \w agua|strong="H4325"\w*. Él te \w sacó|strong="H3318"\w* \w agua|strong="H4325"\w* del duro \w pedernal|strong="H6697"\w*,
\v 16 te sustentó con \w maná|strong="H4478"\w* en el \w desierto|strong="H4057"\w*, comida \w que|strong="H3808"\w* tus antepasados \w no|strong="H3808"\w* \w conocieron|strong="H3045"\w*, \w para|strong="H4616"\w* afligirte, probarte y al final hacerte \w bien|strong="H3190"\w*.
\p 
\v 17 \w No|strong="H6213"\w* sea \w que|strong="H2088"\w* digas en \w tu|strong="H6213"\w* \w corazón|strong="H3824"\w*: Mi \w poder|strong="H3581"\w* y la \w fuerza|strong="H3581"\w* de mi \w mano|strong="H3027"\w* me \w trajeron|strong="H6213"\w* \w esta|strong="H2088"\w* riqueza.
\v 18 \w Más|strong="H3588"\w* \w bien|strong="H3588"\w* \w te|strong="H3588"\w* acordarás \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd*, \w pues|strong="H3588"\w* \w Él|strong="H1931"\w* \w es|strong="H1931"\w* \w Quien|strong="H6213"\w* \w te|strong="H3588"\w* \w da|strong="H5414"\w* \w fuerza|strong="H3581"\w* \w para|strong="H4616"\w* producir riqueza, \w a|strong="H3068"\w* fin \w de|strong="H3588"\w* confirmar \w el|strong="H1931"\w* \w Pacto|strong="H1285"\w* \w que|strong="H3588"\w* \w juró|strong="H7650"\w* \w a|strong="H3068"\w* tus antepasados, \w como|strong="H3588"\w* \w se|strong="H1931"\w* ve \w hoy|strong="H3117"\w*.
\p 
\v 19 \w Pero|strong="H3588"\w* \w sucederá|strong="H1961"\w* \w que|strong="H3588"\w* \w si|strong="H3588"\w* \w te|strong="H3588"\w* olvidas \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, sigues \w a|strong="H3068"\w* otros \tl ʼelohim\tl*, les sirves \w y|strong="H3588"\w* \w te|strong="H3588"\w* postras ante ellos, afirmo \w hoy|strong="H3117"\w* \w contra|strong="H1961"\w* ustedes \w que|strong="H3588"\w* \w ciertamente|strong="H3588"\w* perecerán.
\v 20 \w Como|strong="H3651"\w* las \w naciones|strong="H1471"\w* \w que|strong="H3808"\w* \nd \w Yavé|strong="H3068"\w*\nd* destruye \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ustedes, \w así|strong="H3651"\w* perecerán, \w porque|strong="H3808"\w* \w no|strong="H3808"\w* \w obedecieron|strong="H8085"\w* la \w voz|strong="H6963"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*.
\c 9
\s1 Rebeldía de Israel
\p 
\v 1 ¡\w Escucha|strong="H8085"\w*, \w Israel|strong="H3478"\w*! \w Hoy|strong="H3117"\w* cruzas \w el|strong="H5674"\w* \w Jordán|strong="H3383"\w* \w para|strong="H4480"\w* entrar \w a|strong="H3068"\w* desposeer \w naciones|strong="H1471"\w* \w más|strong="H4480"\w* \w grandes|strong="H1419"\w* y \w fuertes|strong="H1219"\w* \w que|strong="H4480"\w* tú, \w ciudades|strong="H5892"\w* \w grandes|strong="H1419"\w* y amuralladas \w hasta|strong="H3117"\w* \w el|strong="H5674"\w* \w cielo|strong="H8064"\w*,
\v 2 \w a|strong="H3068"\w* un \w pueblo|strong="H5971"\w* \w grande|strong="H1419"\w* y \w alto|strong="H7311"\w*, \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* anaceos, \w de|strong="H6440"\w* \w quienes|strong="H4310"\w* \w sabes|strong="H3045"\w* y \w oíste|strong="H8085"\w* \w decir|strong="H8085"\w*: ¿\w Quién|strong="H4310"\w* \w se|strong="H3045"\w* enfrentará \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* Anac?
\v 3 \w Por|strong="H3588"\w* tanto, \w entiende|strong="H3045"\w* \w hoy|strong="H3117"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w que|strong="H3588"\w* \w pasa|strong="H5674"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti \w como|strong="H3588"\w* Fuego Consumidor. \w Él|strong="H1931"\w* \w los|strong="H1931"\w* \w destruirá|strong="H8045"\w* \w y|strong="H3588"\w* \w los|strong="H1931"\w* someterá \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti \w para|strong="H3588"\w* \w que|strong="H3588"\w* tú \w los|strong="H1931"\w* eches \w y|strong="H3588"\w* \w los|strong="H1931"\w* extermines rápidamente, \w como|strong="H3588"\w* \w dijo|strong="H1696"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 4 Cuando \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* los eche \w de|strong="H6440"\w* tu \w presencia|strong="H6440"\w*, \w no|strong="H6440"\w* pienses en tu \w corazón|strong="H3824"\w*: \w Por|strong="H6440"\w* mi \w justicia|strong="H6666"\w* me trajo \nd \w Yavé|strong="H3068"\w*\nd* \w a|strong="H3068"\w* \w esta|strong="H2063"\w* tierra, pues \w por|strong="H6440"\w* \w la|strong="H2063"\w* perversidad \w de|strong="H6440"\w* \w estas|strong="H2063"\w* \w naciones|strong="H1471"\w* \nd \w Yavé|strong="H3068"\w*\nd* las echa \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti.
\v 5 \w No|strong="H3808"\w* \w por|strong="H3588"\w* tu \w justicia|strong="H6666"\w* \w ni|strong="H3808"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* rectitud \w de|strong="H3588"\w* tu \w corazón|strong="H3824"\w* entras \w a|strong="H3068"\w* poseer \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* ellos, \w sino|strong="H3588"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* perversidad \w de|strong="H3588"\w* estas \w naciones|strong="H1471"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* las echa \w de|strong="H3588"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti, \w y|strong="H3588"\w* \w para|strong="H4616"\w* confirmar \w la|strong="H3588"\w* \w Palabra|strong="H1697"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w juró|strong="H7650"\w* \w a|strong="H3068"\w* tus antepasados: \w a|strong="H3068"\w* Abraham, \w Isaac|strong="H3327"\w* \w y|strong="H3588"\w* \w Jacob|strong="H3290"\w*.
\p 
\v 6 \w Entiende|strong="H3045"\w*, \w pues|strong="H3588"\w*, \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w por|strong="H3588"\w* tu \w justicia|strong="H6666"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w te|strong="H3588"\w* \w da|strong="H5414"\w* \w esta|strong="H2063"\w* \w buena|strong="H2896"\w* tierra \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* heredes, \w pues|strong="H3588"\w* eres un \w pueblo|strong="H5971"\w* \w indómito|strong="H3808"\w*.
\p 
\v 7 Recuerda. \w No|strong="H1961"\w* \w olvides|strong="H7911"\w* \w que|strong="H4480"\w* provocaste \w a|strong="H3068"\w* \w ira|strong="H3318"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w en|strong="H4480"\w* \w el|strong="H5973"\w* \w desierto|strong="H4057"\w*. \w Desde|strong="H4480"\w* \w el|strong="H5973"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w saliste|strong="H3318"\w* \w de|strong="H4480"\w* la tierra \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w* \w hasta|strong="H5704"\w* \w cuando|strong="H3117"\w* entraste \w en|strong="H4480"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*, \w fueron|strong="H1961"\w* \w rebeldes|strong="H4784"\w* \w contra|strong="H5973"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 8 En \w Horeb|strong="H2722"\w* provocaron \w a|strong="H3068"\w* ira \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* de manera que se airó contra ustedes para \w destruirlos|strong="H8045"\w*.
\p 
\v 9 \w Cuando|strong="H3117"\w* subí \w a|strong="H3068"\w* la Montaña \w a|strong="H3068"\w* \w recibir|strong="H3947"\w* las \w tablas|strong="H3871"\w* \w de|strong="H5973"\w* piedra, las \w tablas|strong="H3871"\w* \w del|strong="H5973"\w* \w Pacto|strong="H1285"\w* \w que|strong="H3808"\w* \nd \w Yavé|strong="H3068"\w*\nd* estableció \w con|strong="H5973"\w* ustedes, \w permanecí|strong="H3427"\w* \w en|strong="H5973"\w* la Montaña 40 \w días|strong="H3117"\w* y 40 \w noches|strong="H3915"\w* \w sin|strong="H3808"\w* comer \w pan|strong="H3899"\w* \w ni|strong="H3808"\w* \w beber|strong="H8354"\w* \w agua|strong="H4325"\w*.
\v 10 \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H5921"\w* \w dio|strong="H5414"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w tablas|strong="H3871"\w* \w de|strong="H5921"\w* piedra \w escritas|strong="H3789"\w* \w con|strong="H5973"\w* \w el|strong="H5921"\w* dedo \w de|strong="H5921"\w* \nd ʼElohim\nd*, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ellas|strong="H5921"\w* estaban \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w Palabras|strong="H1697"\w* \w que|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w les|strong="H5921"\w* \w dio|strong="H5414"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* Montaña, \w desde|strong="H5921"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w del|strong="H5921"\w* fuego, \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* asamblea.
\p 
\v 11 Al final \w de|strong="H5414"\w* \w los|strong="H1961"\w* 40 \w días|strong="H3117"\w* y 40 \w noches|strong="H3915"\w* \nd \w Yavé|strong="H3068"\w*\nd* me \w dio|strong="H5414"\w* las \w dos|strong="H8147"\w* \w tablas|strong="H3871"\w* \w de|strong="H5414"\w* piedra, las \w tablas|strong="H3871"\w* del \w Pacto|strong="H1285"\w*.
