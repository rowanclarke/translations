\id AMO - Tarok
\h Nlir aAmos
\toc3 aAm
\toc2 aAmos
\toc1 Nlir aAmos
\mt2 Nlir
\mt1 AAmot
\mt2 Unəm uga nlà ìchu Inan
\c 1
\s1 Alár AAmot
\p 
\v 1 Nnap nlà va ta̱ uAmot uzəngtəng ka̱ ashe onəm oga nkpak iya̱m nkang kà̱ ìtong aTeka̱wa ka̱m ka̱ atak Inan ka̱ ashe alár, ìzun pa̱ ìparəm kang mbin wong yənggət, ka̱ ashe nra va̱ ta te, uUza̱ya uwa uponzhi uga aYahudi, uYerobwam uya aYowash nnyi te ka̱ yà uponzhi uga aIsa̱rila.
\v 2 Uza̱ là pa̱,
\q1 <<UYawe ɗum wa ìlir ka̱ ashe aSiyona,
\q2 ichəchu wa ìgbarman ka̱ aUrushelima ,
\q1 á nak te atak nkpak iya̱m nkang wom, onəm oga nkpak iya̱m nkang yə́ng,
\q2 Ipəpà ka̱ apal Aɓam aKarmel lwai.>>
\s1 Nnyám ntàn Inan ka̱ apal onəm // va ra kà̱ ngba̱k oIsa̱rila
\s2 ASiriya
\p 
\v 3 UYawe là pa̱,
\q1 <<Onəm oga aDimaska nəm nnap mɓá̱ngɓa̱ng chit dədan,
\q2 Mi yà ka̱ ǹre oza̱ pa ka̱t, nkpak pa̱ ń nyám ntàn óza̱,
\q1 Ka̱kul oza̱ nə́m onəm mi ka̱ aGileyat
\q2 ká̱ nkumbək wa nva mí pək ikur á.
\q1 
\v 4 Ka̱kul nva̱ ta te, mi re ǹre ká̱ apər kà̱ nzhi iponzhi aHazayel,
\q2 a va i zhì akamsəlang aBenhadad.
\q1 
\v 5 Mi chwan anung asa̱l ìtong aDimaska,
\q2 mi dərkən onənəm kà̱ mba̱nda̱m aAva̱n.
\q1 Mi zhì uponzhi uga aBet-Eden,
\q2 onəm oga aAram te mí ga izwal ká̱ oza̱ ka̱ aKir,>>
\q1 uYawe à là. \fig Chwan anung asa̱l|alt="Break the gate" src="cho01239c.TIF" size="chol" ref="1.5"\fig*
\s2 OFilisti
\p 
\v 6 UYawe là pa̱,
\q1 <<Onəm oga aGaza nəm nnap mɓá̱ngɓa̱ng chit dədan,
\q2 nkpak pa̱ ń nyám ntàn óza̱.
\q1 Ka̱kul oza̱ wur nkpaktak onəm ga ká̱ kà̱ mbin nkak.
\q2 Oza̱ yáp ká̱ oza̱ wa ozwal oga aEdom.
\q1 
\v 7 Ka̱kul nva̱ ta te, mi re ǹre ká̱ apər ka̱ apal anyán va̱ gang aGaza,
\q2 i pwák akamsəlang va̱ ta.
\q1 
\v 8 Mi dərkən onəm oga aAshdod,
\q2 ká̱ uponzhi uga aAshəkelon.
\q1 Te mi nak awo ka̱ aEkron kpa,
\q2 aɓo oFilisti va̱ re te mi zhì,>>
\q1 uPonzhinan uYawe à là.
\s2 ATaya
\p 
\v 9 UYawe là pa̱,
\q1 <<Onəm oga aTaya nəm nnap mɓá̱ngɓa̱ng chit dədan,
\q2 nkpak pa̱ ń nyám ntàn óza̱.
\q1 Ka̱kul oza̱ ɓəkchi nsar nnap-nlà igənang oza̱,
\q2 oza̱ yáp ká̱ nkpaktak ìtong oga aEdom.
\q1 
\v 10 Ka̱kul nva̱ ta te, mi re ǹre ká̱ apər i ri anyán aTaya,
\q2 i zhì akamsəlankamsəlang.>>
\s2 AEdom
\p 
\v 11 UYawe là pa̱,
\q1 <<Onəm oga aEdom nəm nnap mɓá̱ngɓa̱ng chit dədan,
\q2 nkpak pa̱ ń nyám ntàn óza̱.
\q1 Ka̱kul uza̱ wà ogənnang wò ká̱ ndokchi,
\q2 uza̱ nyám nrwa ìgwak óza̱ ka̱t,
\q1 uza̱ re nlak ìgwak ká̱ oza̱ ka̱t,
\q2 kang uza̱ kpán mmən ìkum ká̱ oza̱ mbyet mbyet.
\q1 
\v 12 Ka̱kul nva̱ ta te, mi re ǹre ká̱ apər ka̱ aTeman,
\q2 i zhì akamsəlang aBozrah.>>
\s2 AAmmon
\p 
\v 13 UYawe là pa̱,
\q1 <<Onəm oga aAmmon nəm nnap mɓá̱ngɓa̱ng chit dədan,
\q2 nkpak pa̱ ń nyám ntàn óza̱.
\q1 Ka̱kul oza̱ cha afu ochar oga anyám ka̱ aGileyat
\q2 ká̱ ndokchi pa̱ na ó bol mbin oza̱.
\q1 
\v 14 Ka̱kul nva̱ ta te, mi re ǹre ká̱ apər i ri anyán aRabba,
\q2 i zhì akamsəlankamsəlang.
\q1 Mí bà achu kà̱ ìlum ìkum va̱ ta,
\q2 i kandar wa ǹyə̀r nvàngváng nkánkám.
\q1 
\v 15 UPonzhi oza̱ i ga izwal,
\q2 ká̱ oponzhi oga avəvəng nzəng ká̱ na.>>
\q1 UYawe à là.
\c 2
\s2 aMowap
\p 
\v 1 UYawe là pa̱,
\q1 <<aMowap nəm nnap mɓá̱ngɓa̱ng chit dədan,
\q2 nkpak pa̱ ń nyám ntàn á na.
\q1 Ka̱kul uza̱ shì akúp áponzhi uga aEdom nyáng nchwang
\q1 
\v 2 Mi re apər ka̱ aMowap,
\q2 i pwák akamsəlang aKeriyot.
\q1 Onəm oga aMowap i kú ka̱ ashe nzwar nnap nnəm,
\q2 kà̱ ìlum va̱ onəm oga nlung ìkum i bà ká̱ mɓúr agbəshi.
\q1 
\v 3 Mi dərkən uponzhi oza̱,
\q2 kang mi gbá̱ng nkpaktak ovan oponzhi nzəng ká̱ na.>>
\q1 UYawe à là.
\s2 AYahudi
\p 
\v 4 Iya̱m va ta̱ uYawe là,
\q1 <<Onəm oga aYahudi nəm nnap mɓá̱ngɓa̱ng chit dədan.
\q2 Ka̱kul oza̱ yang nnap mpakpak mi, oza̱ kpak nnap nla mi ka̱t,
\q1 oza̱ wop ichər va okəka oza̱ ká̱ wop,
\q2 kang à nak oza̱ re asa̱l aga nnandər.
\q1 
\v 5 Mi re ǹre ká̱ apər áYahudi,
\q2 na á pwák oga akamsəlang aUrushelima pa̱ chatchat.>>
\s2 AKwali Inan ka̱ apal OIsa̱rila
\p 
\v 6 UYawe là pa̱,
\q1 <<Onəm oga aIsa̱rila nəm nnap mɓá̱ngɓa̱ng chit dədan,
\q2 mi re oza̱ pa ka̱t, nkpak pa̱ ń nyám ntàn óza̱.
\q1 Ka̱kul oza̱ yáp mbwai ká̱ onəm onəna̱n.
\q2 Onəm oga nkun nnyi te, oza̱ yáp ká̱ oza̱ á kúr mbwai akwàp ka̱t.
\q1 
\v 7 Oza̱ tòng ishi onəm oga nkun
\q2 wa mɓwang mbin
\q2 Oza̱ bwam nnandər onəm va mmá kà̱r.
\q1 UYen ká̱ upo wò i ga atak nra kà̱ uyen ɓyen uzəngtəng,
\q2 wa nnà ta oza̱ vyap aɗin mi ayə́ryər.
\q1 
\v 8 Ka̱ atak awop oza̱ te oza̱ i ra ka̱ apal ìlukwan
\q2 va oza̱ ka̱m ndatdat ka̱ anung akat va̱ oza̱ ná.
\q1 Ka̱ ashe nzhi inan oza̱ te,
\q2 oza̱ wa ndəng ìba̱ngba̱ng ǹsámsàm va mmá mwa nkpán ká̱.
\q1 
\v 9 Ká̱ nnà te, n zhì oAmori ka̱ mpyal oza̱,
\q2 káp ka̱ nva̱ pa̱ oza̱ rup wa ichir,
\q2 kang oza̱ kam wa akún asida,
\q1 n zhì awar oza̱ ka̱ apal
\q2 ká̱ alə̀ng oza̱ ka̱ akum le.
\q1 
\v 10 Mmami na kpa n fa ká̱ wo ka̱ ashe mbin aMasar,
\q2 kang n lə́p mpyal a wo ka̱ ashe ǹzam izun ìsəm pa̱ ineɗing
\q2 na o wur iya̱m akúp ká̱ mbin aAmori.
\q1 
\v 11 N yak ovan wo oro tong onəm oga nlà ìchu Inan,
\q2 oro te oNaziri.
\q1 Mwote pa ka̱t ɗak ɓo oga aIsa̱rila?>>
\q1 UYawe à ɓəp.
\q1 
\v 12 <<Te o nak oNaziri wa ncè kang
\q2 o dáng onəm oga nlà ìchu Inan kà̱ nləlà.
\q1 
\v 13 Dər, ǹyangmata̱ mi ga nkà̱r wo
\q2 wa nva̱ mí byachi akeke ipəri ká̱ nsar ikur.
\q1 
\v 14 Onəm oga nchəng ashar ka̱ ashe wo i zhì.
\q2 Onəm okankam ka̱ ashe wo i tong nku.
\q2 Onəm oga nlung ìkum i nyi nka̱mshi ishi oza̱ ka̱t.
\q1 
\v 15 Ovan oga ijang i yà ká̱ ntong ka̱t.
\q2 Onəm oga nchəng ashar ka̱ ashe oza̱ i yà ká̱ mbar ka̱t,
\q2 kang onəm oga ipəri ìkum i ka̱mshi ishi oza̱ ka̱t kpa.
\q1 
\v 16 Kà̱ ìlum va̱ ta onəm oga nkam ìgwak
\q2 i chəng ká̱ ìjili ìbwat ka̱kul irirì oza̱,>>
\q1 uYawe à là.
\c 3
\s1 INok ánəm uga nlà icù Inan
\p 
\v 1 O gwong achwang kà̱ nnap-nlà va̱ ta̱ uYawe là ka̱ apal wo, ónəm oga aIsa̱rila ká̱ nkpaktak akum va̱ n fa ká̱ oza̱ ka̱ aMasar.
\q1 
\v 2 <<Ka̱ ashe akum va̱ ka̱ apambin pa̱ kpaktak te,
\q2 n yak mmawó na byet n nak ishi ká̱ wo.
\q1 Ka̱kul nva̱ ta te, nkpak pa̱ ń nyám ntàn a wo,
\q2 ka̱kul nnap mɓá̱ngɓa̱ng wo.>>
\q1 
\v 3 I məma pa̱ onəm pa̱ oparəm i ga achen nzəng
\q2 kang anung oza̱ i gwàr kà̱ ka̱t ɗò?
\q1 
\v 4 Ìlir i ɗuɗum ka̱ ashe ikún
\q2 u wa ya ìzhe chit ka̱t ɗò?
\q1 Ìyen nza̱m ìlir i gbək izər gbək ka̱ ashe agba̱k
\q2 ì yà kpán iya̱m iro chit ka̱t ɗò?
\q1 
\v 5 Ajə̀p i kpán ìnyil kpán
\q2 ka̱ atak va̱ mmá lwak kà̱ ka̱t ɗò?
\q1 Ajə̀p i tətat ya nna kpán
\q2 iya̱m iro chit ka̱t ɗò?
\q1 
\v 6 A yà pa̱ mma ɓur agbəshi ìkum ka̱ ashe mbin te
\q2 ayər i nəm onəm ka̱t ɗò?
\q1 Nɗaktak i fəfa kà̱ mbin
\q2 nva uYawe à nəm ka̱t ɗò?
\q1 
\v 7 Nnandər, uPonzhinan uYawe i ya ká̱ nnəm iya̱m iro
\q2 nzəng ká̱ nnyám iya̱m va̱ ta
\q2 ozwal wò onəm oga nlà ìchu Inan ka̱t ɗò ka̱t.
\q1 
\v 8 Ìlir ɗum te uda
\q2 i nəm ayər ka̱t yà?
\q1 UPonzhinan uYawe là nnàp chit,
\q2 te uda i yang ka̱ nlà ichəchu va̱ ta yà?
\q1 
\v 9 Là nnap ká̱ oga akamsəlang aga aAshdod
\q2 ká̱ oga akamsəlang kà̱ mbin aMasar pa̱,
\q1 <<O ɓut ishi wo ka̱ aɓam aSamariya
\q2 na o dər nzwar va̱ ka̱ ashishe
\q2 ká̱ nkà̱r nnandər va̱ ka̱ ashe onənəm>>
\q1 
\v 10 <<Onəm mi nyi nnəm iya̱m inəna̱n ka̱t,>> uYawe à là.
\q2 <<Oza̱ va ɓut iya̱m ka̱ akamsəlang oza̱ ka̱ atak nvyat onəm ká̱ nnəm ayi.>>
\p 
\v 11 Ka̱kul nva̱ ta te, uPonzhinan uYawe là pa̱,
\q1 <<Ukpa ìkum i gáng mbin,
\q2 i kap wo ká̱ ìkam wo
\q2 kang i lyangshin akamsəlang wo.>>
\p 
\v 12 UYawe là pa̱,
\q1 <<Wa nva unəm uga nkpak iya̱m nkang i vyat ka̱ anung ìlir
\q2 ashar pa̱ aparəm ka̱t te achwang pa̱ azəng,
\q1 te wa nnà ta mí ka̱mshi oIsa̱rila,
\q2 va̱ təm ka̱ ashe aSamariya
\q2 ka̱ aranchwang ìgban ká̱ ìtok.>>
\p 
\v 13 <<O gwong achwang na o là nnàp ákum áYakup,>>
\q2 uPonzhinan uYawe, Inan iga nggatək à là.
\q1 
\v 14 <<ÌLum va̱ mi nyám ntàn óIsa̱rila ka̱kul nnap mɓá̱ngɓa̱ng oza̱ te,
\q2 mi shin atak nshì iya̱m awop aga aBetel.
\q1 Mi ɓun oga nggùnggúng atak
\q2 awop i tàk kà̱ mbin.
\q1 
\v 15 Mi shin nzhi oza̱
\q2 ká̱ aghal oza̱,
\q1 nzhi oza̱ va̱ mmá zà̱m ká̱ oga inyin nlàlap,
\q2 nza̱ nzhi nchumchum nggo mí shin.>>
\q1 UYawe à là.
\c 4
\s1 OIsa̱rila le atak Inan ka̱t
\q1 
\v 1 O gwong achwang na o fe nva̱ ta̱ óchar oga Samariya.
\q2 Mmawo va wa ina imwalmwal iga aBashan va ka̱ aɓam aSamariya.
\q1 Ó nyán ká̱ onəm oga nlàng kang o kà̱r onəm oga nkun,
\q2 o là ónəm oga nzhi wo pa̱ <<Ɓa ká̱ iya̱m iwàwà á yi.>>
\q1 
\v 2 UPonzhinan uYawe sóng anung chit ká̱ ishi wò, uza̱ là pa̱,
\q2 <<Nra nna kà̱ mɓa ka̱ apal wo
\q1 nva mí wur wo ká̱ aKugaya,
\q2 wa ìgwali va mmá kpán ká̱ aKugaya.
\q1 
\v 3 Mí wur wo mi fa ká̱
\q2 ka̱ atak va akamsəlang kàkchi kà̱,
\q2 mí swang wo te, udanggo i ru asa̱l mbin aHamon.>>
\q1 UYawe à là.
\q1 
\v 4 <<O ga aBetel kang ô fa iya̱mkak ,
\q2 o ga aGilgal na o ga mpyal ká̱ nnəm inga.
\q1 O ná iya̱m ipápà wo nza̱ ipin nggo,
\q2 ká̱ iya̱m pa̱ izəng ka̱ ashe agba̱pchi nza̱ nra pa̱ nshatɗing nggo.
\q1 
\v 5 O ná nzənkəng ngga anyer ka̱kul nná aɗəngchi
\q2 ká̱ iya̱m inana wo iga nɗom ìgwak.
\q1 O ghok ka̱kul apir iya̱m
\q2 va ta̱ o fe nchang nnənəm, óIsa̱rila.>>
\qr UPonzhinan uYawe à là.
\q1 
\v 6 <<M ɓa ká̱ ayang kà̱ ìtong wo,
\q2 o lang iya̱m-nrì kà̱ oga mbin wo,
\q2 káp ká̱ nnà te, o ga̱ɓa̱n o ɓa atak mi ka̱t.>>
\q1 UYawe à là.
\q1 
\v 7 Kà̱ɗi te, n dàng wo ká̱ ìva̱r
\q2 ya nna ɓur apye pa̱ shatɗing kang mí ɓən iya̱m.
\q1 N nak mmá pəng ìva̱r kà̱ mbin nro,
\q2 kà̱ mbin nro nnyi te n dàng ìva̱r.
\q1 Ìram iro ká̱ azham
\q2 ìram iro te azham ya kà̱ ka̱t, a wom.
\q1 
\v 8 Iìtong pa̱ iparəm ka̱t te pa̱ ishatɗing i pin kà̱ nram ndəng ngwa,
\q2 kà̱ mbín va kà̱ ngba̱k oza̱,
\q1 ka̱ ta te oza̱ ya ndəng kúr oza̱ ka̱t.
\q2 Káp ká̱ nnà te, o le atak mi ka̱t,
\q1 uYawe à là.
\q1 
\v 9 <<N lə̀p iya̱m nsuk wo ká̱ arwa ká̱ atak sur,
\q2 Mbankum ri oga ìram ìkáka wo ká̱ iga iɓá̱ngɓa̱ng,
\q1 ká̱ iga ikún mpyet wo ká̱ iga ikún ìpipyan,
\q2 káp ká̱ nnà te, o le atak mi ka̱t,>>
\q1 uYawe à là.
\q1 
\v 10 <<N re ǹre a wo ká̱ nɗaktak
\q2 wa nva̱ ka̱ n nəm ká̱ aMasar,
\q1 n gbá̱ng ovan nza̱m wo ká̱ ndokchi, nzəng ká̱ ipəri wo va mmá vyat.
\q2 N nak nnəng oga akúm va̱ ta táng a wo ka̱ alúr.
\q1 Káp ká̱ nnà te, o le atak mi ka̱t,>>
\q2 uYawe à là.
\q1 
\v 11 <<N zhì mbín wo
\q2 wa nva̱ Inan ka̱ zhì aSodom ká̱ aGomora,
\q1 o tong wa akún va mmá tur ka̱ anung apər á.
\q2 Káp ká̱ nnà te, o le atak mi ka̱t,>>
\q1 uYawe à là.
\q1 
\v 12 <<Ka̱kul nva̱ ta te, iya̱m va ta̱ mi ga nnənəm a wo, óIsa̱rila.
\q2 Ka̱kul mi ga nnəm iya̱m ata̱ a wo te,
\q2 o gbar izər o gwan Inan wo, óIsa̱rila.>>
\q1 
\v 13 Dər, uza̱ uwa ta̱,
\q2 uwa nəm aɓam kang à fa ká̱ ayə́r,
\q2 uwa kà̱ nnyám iya̱m va̱ uza̱ rəng ka̱ ashe ìgwak wò ûnəmləbər,
\q1 uwa fa ká̱ atak atántàn aga anung ipin ka̱ ashe ìzwam,
\q2 uza̱ nak oga aɓam aruprup ka̱ avəng ashar wò.
\q2 Aɗiɗin pa̱ uYawe, Inan iga nggatək.
\c 5
\s1 ÌPyang ìga aɗor
\p 
\v 1 O gwong achwang ónəm oga aIsa̱rila, kà̱ ìpyang ìga aɗor va̱ mmami kà̱ nshìshi ka̱ apal ishi wo á.
\q1 
\v 2 Uza̱ ru chit, i yà ká̱ ngwong lap ka̱t,
\q2 uyen ɓyen ugəkgək uIsa̱rila ru chit.
\q1 Mmá yang ká̱ na kà̱ mbibin,
\q2 unəm uro yà pa̱ á gha̱p na a wong ka̱t.
\p 
\v 3 UPonzhinan uYawe là onəm oga aIsa̱rila pa̱,
\q1 <<Ììtong va̱ i re ǹre ká̱ onəm ìkalong pa̱ ìzəng fa agbai te,
\q2 onəm ìgba̱l pa̱ ìzəng i ga i le,
\q1 ìro va̱ nnyi i re ǹre ká̱ onəm ìgba̱l pa̱ ìzəng fa agbai te,
\q2 pa̱ ogba̱pchi i ga i le.>>
\s1 O ɓa atak Inan na o lár
\p 
\v 4 Iya̱m va ta̱ uYawe là ónəm oga aIsa̱rila,
\q1 <<O ram mi na o lár,
\q2 
\v 5 kang o ram aBetel ka̱t,
\q1 kang o ga aGilgal,
\q2 ka̱t te o pa̱l aBəyersheba ka̱t.
\q1 Ka̱kul mi ga ngwur onəm oga aGilgal i ga izwal
\q2 kang aBetel nnyi te i təm atak alakchi.>>
\q1 
\v 6 O ram uYawe na o lár,
\q2 ka̱t te uza̱ i fa wa apər
\q1 kà̱ nzhi aYusufu, i ri,
\q2 unəm uga njəjip ka̱ aBetel yà ka̱t.
\q1 
\v 7 Mmawo va o ga̱ɓa̱n akwali a nandər wal ìɗángɗáng
\q2 kang o kà̱r nnandər kà̱ mbin á yà iya̱m ilakchi ka̱ atak wo.
\q1 
\v 8 Uza̱ uwa fa ká̱ izhan ivanɓyen ká̱ nɗukkəri,
\q2 uza̱ uwa ga̱ɓa̱n atak akpá̱rkpà̱r ɓa anung ipin
\q2 alum nyáng ìzwam,
\q1 uza̱ wór ndəng ìwá
\q2 tar ka̱ apambin,
\q2 aɗiɗin pa̱ uYawe.
\q1 
\v 9 Wa aməlam, uza̱ i zhì onəm okankam,
\q2 kang i shin oga akamsəlang.
\q1 
\v 10 Oza̱ yang unəm unandər kà̱ nkəlang,
\q2 kang unəm va̱ i là nnandər te, oza̱ jan na.
\q1 
\v 11 Ka̱kul o tòng onəm oga nkun,
\q2 kang o nak amwa ìpirkur oza̱ ká̱ ìfan,
\q1 nzhi wo ngga ipáng nnəna̱n va̱ o me te,
\q2 ó yà ka̱ nra ka̱ ashishe ka̱t.
\q1 O yà ka̱ ngwa ndəng ìba̱ngba̱ng
\q2 iga ashe ìram wo inəna̱n ka̱t.
\q1 
\v 12 N nyi mmak nnap mɓá̱ngɓa̱ng wo nyi,
\q2 ká̱ iya̱m inga iga nnəm ayər va̱ mmawó kà̱ nnənəm.
\q1 Mmawo kà̱ nyán ká̱ onəm onəna̱n kang o ka̱m iya̱m ka̱kul nkà̱r nnandər,
\q2 te o nak pa̱ mmá náp akwali aga nnandər onəm oga nkun kà̱ nkəlang ka̱t.
\q1 
\v 13 Ka̱kul nva̱ ta te, unəm va̱ tətàn te uza̱ á ma̱r pa̱ kwak,
\q2 ka̱kul nra va̱ ta̱ nra mɓá̱ngɓa̱ng.
\q1 
\v 14 Ram inəna̱n iɓá̱ngɓa̱ng ka̱t,
\q2 ka̱kul na o lár,
\q1 nna chit te uYawe, Inan uga nggatək i yà nzəng ká̱ wo
\q2 dakdak wa nva̱ o là.
\q1 
\v 15 O yang inga,
\q2 o ma̱n inəna̱n.
\q1 O náp akwali aga nnandər kà̱ nkəlang wo,
\q2 mwote uYawe, Inan iga nggatək i nyám nnap nnəna̱n á ɓo akum aYusufu.
\p 
\v 16 Ka̱kul uPonzhinan uYawe, Inan iga nggatək là pa̱,
\q1 <<Mí ga ǹyə́ng ayə́ng ká̱ aɗor ka̱ agəntəng,
\q2 mí nə́m ìwar ka̱ apal asa̱l.
\q1 Mí wór onəm ka̱ ashe ìram
\q2 ka̱ onəm oga nnyi nshì ìpyang pa̱ oza̱ á ɓa á yə́ng ikú.
\q1 
\v 17 Mí yə́ng ikú nza̱ atak nggo ka̱ ashe iram wo,
\q2 ka̱kul mi watar ka̱ ashe wo,\f + \fr 5.17 \ft Ngwatar ka̱ ashe wo kà̱ nnyám akwali áYawe wa nva ka̱ ashe \xt Nfa 12.12\xt*\ft .\f*>>
\q1 uYawe à là.
\s1 ÌLum àYawe
\q1 
\v 18 Álak ká̱ wo chit,
\q2 mmawó va̱ ká̱ ìgwak kà̱ ìlum àYawe á.
\q1 Iza̱ ìlum àYawe i nəm a wo yà?
\q2 Ìlum va̱ ta ìlum ìkpá̱rkpà̱r, ìghanghan ka̱t.
\q1 
\v 19 I yà wa ánəm va chər ìlir
\q2 te á ga pa ìwu kà̱ ìdəshìli.
\q1 Ka̱t te wa ánəm va chər ɓa
\q2 da̱r awo ka̱ izər nzhi
\q2 te ìpwang kà̱p na.
\q1 
\v 20 Nnandər ìlum àYawe ìkpá̱rkpà̱r ìghanghan ka̱t,
\q2 ìlum va̱ ta pa̱ zhiwuli pa̱ haa ka̱t.
\q1 
\v 21 <<N yang, n ɗom awop wo aga nnəm nchang izər ka̱t,
\q2 mɓut awop wo nəng ká̱ mi paɗi.
\q1 
\v 22 A yà pa̱ o ná iya̱m inana iga nshì pa̱ ɗwot ká̱ iya̱m inana iga ìpirkur te,
\q2 mi yà ká̱ nkəka̱m ka̱t.
\q1 Mi yà ká̱ nnak ishi ká̱ iya̱m nkang wo imwalmwal
\q2 ka̱kul iya̱m inana iga ntəm ikángkáng ka̱t.
\q1 
\v 23 Ga ká̱ ngghám achu ɓu ka̱ cho,
\q2 iya̱m inə́mnə́m ɓu a chàng sang nggo te,
\q2 n ɗom nfife ka̱t.
\q1 
\v 24 Ka̱ aɗor nva̱ ta te, re akwali aga nnandər á nang wa ndəng awang,
\q2 kang inəna̱n wa awangsang va i fu ka̱t á.
\q1 
\v 25 O ɓa ká̱ nləfər iya̱m ipápà iga iya̱m nkang, ká̱ iya̱m inana iga ìram wo ɓa á mi,
\q2 nva̱ mmawó ka̱ ashe anyin ìzun ìsəm pa̱ ineɗing ɗò, óIsa̱rila?
\q1 
\v 26 Iya̱m va̱ o nəm te, o wur ìchər wo
\q2 va mí wór pa̱ aSakut ûponzhi wo,
\q1 ká̱ aKaiwan inan wo iga izhan,
\q2 iva o nəm ká̱ awo wo á.
\q1 
\v 27 Ka̱kul nva̱ ta te, mi ga ká̱ wo ka̱ ashe mbin nro kà̱ mpyal aDimaska.>>
\q2 UYawe, aɗiɗin pa̱ Inan iga nggatək, à là.
\c 6
\s1 ONəm va re izər chit pa̱ yàk ká̱ aSiyona
\q1 
\v 1 Álak ká̱ wo chit, mmawó va̱ o təm pa̱ shat ka̱ aSiyona á.
\q2 Ká̱ mmawó va̱ o rəng pa̱ o təm chit ká̱ ikángkáng ka̱ aɓam aSamariya.
\q1 Mmawo onəm oga ala̱ka̱n va mmá nyi wo nyi kà̱ mbin nchumchum,
\q2 ka̱ atak áda oIsa̱rila ga yà?
\q1 
\v 2 O ga aKalne na o dər,
\q2 o ga aHamat,
\q1 o watar o ga aGat ajo oFilisti,
\q2 o dər mbin oza̱ rup kam ji aIsa̱rila ji ɗò?
\q1 
\v 3 Mmawo kà̱ nnyám pa̱ ìlum ìɓá̱ngɓa̱ng va̱ ta ì ya nggbəgbà̱ng ka̱ cho,
\q2 kang iya̱m va̱ mmawó kà̱ nnənəm te kà̱ ndap ìtok iponzhi iga idumdùm va̱ ta dat ká̱ wo.
\q1 
\v 4 Mmawo va kà̱ nra ka̱ apal
\q2 alyer aga inyin nlàlap,
\q1 kang o dal izər ka̱ apal ìtok ngbat wo,
\q2 o ri izhé itam iyákyàk ka̱ ashe iya̱m nkang,
\q2 ká̱ ina imwalmwal ka̱ ashe nggatək ina.
\q1 
\v 5 O mar oga nnap-nshì va̱ yà ká̱ ìpir ka̱t ká̱ aɓwa,
\q2 kang o mar aghan oga iya̱m ǹza̱m wa nva̱ uDawuda nəm.\fig Iya̱m ǹza̱m|alt="musichal instruments" src="WA04017b.tif" size="chol" ref="6.5"\fig*
\q1 
\v 6 O wá ndəng ìba̱ngba̱ng ǹsámsàm ká̱ ìnang ìkpáng.
\q2 O ɓəl mmì nnəna̱n.
\q2 Kang o yə́ng ká̱ nvyap ovan aYusufu ka̱t.
\q1 
\v 7 Ka̱kul nva̱ ta te, mmawó na oga nggəshi va̱ o ga izwal.
\q2 Ndal izər wo ká̱ nri izhé wo i ga nkùr.
\p 
\v 8 UPonzhinan uYawe sóng anung ka̱ ishi wò, uYawe, Inan iga nggatək là pa̱,
\q1 <<N jan ǹrup ishi áYakup, n yang akamsəlankamsəlang.
\q2 Mi ga nná mbin oza̱ ká̱ iya̱m va̱ ka̱ ashishe.>>
\m 
\v 9 A yà pa̱ onəm pa̱ ogba̱pchi à re ka̱ ashe nzhi pa̱ nzəng te oza̱ i kú.
\v 10 Kà̱ nva̱ngva̱ onal onəm va̱ kú ɓa táng ashe nzhi pa̱ na o fa ká̱ akúm o shì, te uro i wór awór pa̱, <<Unəm uro uwa yà ka̱ ashe nzhi va̱ ta̱ ɗak ɓo?>> Te mí ma̱n pa̱ <<Pa ka̱t.>> Te uza̱ i là pa̱, <<Gbat, kang mmá wór aɗin áYawe.>>
\q1 
\v 11 Ka̱kul uYawe à là,
\q2 nzhi nchumchum mí chwan pa̱ rukutrukut,
\q2 nzhi mɓwakan mí shin.
\q1 
\v 12 Mí kwak ipəri kwak ka̱ apal ipáng ɗò?
\q2 Mí shàng ipáng shàng ká̱ ina ɗò?
\q1 Káp ká̱ nnà te o nak nnandər sat akàl,
\q2 kang nnap nnəm nnəna̱n sat ìɗángɗáng. \fig Ngshàng ìram ina|alt="Cow plowing" src="cho01456b.TIF" size="chol" ref="6.12"\fig*
\q1 
\v 13 Mmawo va̱ o lan ká̱ igwan wo ka̱ apal aLodeba o là pa̱,
\q2 <<Ká̱ nkàm yi kang í ri aKarnayim ka̱t ɗò?>>
\q1 
\v 14 <<Ónəm oga aIsa̱rila, mmami kà̱ ngga mɓa ká̱ onəm ìkum wo,
\q2 va i ga nnyán ká̱ wo i ɓàn ka̱ aHamat
\q1 ka̱ asa̱l mpal i ga i chu aba̱nda̱m Ìwá Mman.>>
\q2 UYawe, Inan iga nggatək à là.
\c 7
\s1 Oga iwon ka̱ ashe alár pa̱ shatɗing
\p 
\v 1 Alár va ta̱ uPonzhinan uYawe nyám á mi. N ya uza̱ kà̱ nfa ká̱ mbankum ka̱ ashe mbin, kà̱ nva̱ngva̱ mmá kpam nrì aponzhi chit, kang oza̱ ɓàn ntə́p kà̱ɗi .
\v 2 Kà̱ nva̱ngva̱ mbankum gba̱l ká̱ nri iya̱m va tə́p kà̱ mbin te, n là pa̱, <<Áponzhi Inan, uYawe, kusuk yar mpat ûYakup, uza̱ i nəm sang kang i sat yà? Uza̱ makmak ka̱t.>>
\p 
\v 3 UYawe re iya̱m va̱ uza̱ yar pa̱ ô nəm.
\p UYawe là pa̱, <<I nəm ka̱t.>>
\s1 ALár apər
\p 
\v 4 UPonzhinan uYawe nyám alár á mi. N ya uPonzhinan uYawe kà̱ mpə̀ng apər. Apər va̱ ta shì ìnang ìwá ga akpán ká̱ nri apambin kpa.
\v 5 Te n là pa̱, <<ÁPonzhinan, uYawe, wa ma̱n te wa re nnap va̱ ta, uYakup i nəm sang kang i sat yà? Uza̱ makmak ka̱t.>>
\p 
\v 6 Te uYawe re iya̱m va̱ uza̱ yar pa̱ ô nəm, <<Iva̱ ta̱ i nəm ka̱t na kpa>> uPonzhinan , uYawe à là.
\s1 ALár iya̱m iga mmàl iya̱m
\p 
\v 7 Uza̱ nyám alár á mi. N ya uPonzhinan sat ka̱ izər akamsəlang va mmá me ká̱ iya̱m iga mmàl nsat nzwàng nzhi. Uza̱ kpán iya̱m iga mmàl nzhi ka̱ awo.
\v 8 UYawe ɓəp mi pa̱, <<ÁAmot, iza̱ u ya yà?>>
\p Te n là pa̱ <<Iya̱m iga mmàl nsat nzwàng nzhi.>>
\p Te uPonzhinan là pa̱,
\q1 <<Mmami kà̱ nnak iya̱m iga màl nsat nzwàng nzhi,
\q2 ka̱ ishimshe onəm mi oIsa̱rila.
\q2 Mi watar ka̱ ashe oza̱.
\q1 
\v 9 Atak awop akum ìjili àIshaku ká̱ aɓam i shin,
\q2 kang atak awop ayə́ryər oga aIsa̱rila i ra agúng,
\q2 mi ru akum ìjili àYerobwam ká̱ ndokchi.>>
\s1 UAmot ká̱ uAmaziya
\p 
\v 10 Te uAmaziya unəm uga mpyal awop ka̱ aBetel re ǹre ûYerobwam uponzhi uga aIsa̱rila pa̱, <<UAmot uwa suk iya̱m ro ka̱ ashe onəm oga aIsa̱rila. Mbin ka̱m nnap va̱ ta̱ ka̱t.
\v 11 UAmot là pa̱,
\q1 <<Mí ga ngba̱l uYerobwam ka̱ atak ìkum,
\q2 te mí wur oga aIsa̱rila i re mbin oza̱ i ga izwal. I mai ka̱t oza̱ i ga izwal.>>
\p 
\v 12 Te uAmaziya là ûAmot pa̱, <<Re atak va̱ ta̱ ánəm uga iva̱k, le ga mbin oga aYahudi, là ìchu Inan ɓu va̱ ka̱ ta kang ɓu ri ká̱.
\v 13 Kang wa ɗak yi ka̱ ta̱ ka̱ aBetel ká̱ nlà ìchu Inan ɓu va̱ ta ka̱t. Atak a va̱ ta̱ atak awop áponzhi, kang nnà atak awop achumchum.>>
\p 
\v 14 Te uAmot ná ama̱n ûAmaziya pa̱, <<Mmami unəm uga nlà ìchu Inan ka̱t, kang mmami uya ànəm uga nlà ìchu Inan ka̱t kpa. Mmami unəm uga nkpak iya̱m nkang ká̱ nnak ishi ká̱ oga ipipyan.
\v 15 Te uYawe kap mi ká̱ nkpak iya̱m nkang,>> uYawe là á mi pa̱, <<Ga là ìchu Inan ónəm mi oIsa̱rila.>>
\v 16 Ǹyangmata̱ te, gwong achwang kà̱ nnap-nlà àYawe. U là pa̱,
\q1 <<Kang ń là ìchu Inan ka̱ apal ishi oIsa̱rila ka̱t,
\q2 kang ń là nnap-nlà ka̱ apal ishi nzhi àIshaku ka̱t.>>
\p 
\v 17 Ka̱kul nva̱ ta te, uYawe là pa̱,
\q1 <<UChar ɓu i nyáng uga nnəm mmai ka̱ ashe ìtong.
\q2 Ovan ɓu onunggwan ká̱ ovan ochar mí gbá̱ng ká̱ ndokchi.
\q1 Mí màl mbin ɓu ká̱ asang aga mmàl atak mí kap,
\q2 mmaɓu ká̱ ishi ɓu te ɓu kú ka̱ ashe mbin nvyapvyap.
\q1 Mí wur oga aIsa̱rila i re mbin oza̱ i ga izwal
\q2 i mai ka̱t oza̱ i ga izwal.>>
\c 8
\s1 Nkatəp awar ìpipyan
\p 
\v 1 UPonzhinan uYawe nyám alár á mi. N ya awar ìpipyan ìyályál ka̱ ashe nkatəp.
\v 2 UYawe ɓəp pa̱, <<Iza̱ u ya yà áAmot?>>
\p Te n ma̱n pa̱, <<Nkatəp yə́l ká̱ awar ìpipyan ìyályál.>>
\p Te uYawe là á mi pa̱,
\q1 <<Onəm mi oIsa̱rila yál chit,
\q2 mi watar ka̱ ashe oza̱.>>
\q1 
\v 3 <<Oga nnap-nshì va̱ mí shì kà̱ nzhi iponzhi te, i wal ìpyang ikú ká̱ nda va̱ ta,>>
\q2 uPonzhinan uYawe à là.
\q1 Akúm ka̱ atak pa̱ kpaa,
\q1 mí swang ǹdúndùn.
\q1 
\v 4 O fe, mmawó va̱ o tòng onəm oga nlang
\q2 kang o nak onəm oga nkun pa̱ iya̱m ro ka̱ ashe mbin ka̱t.
\p 
\v 5 O là pa̱,
\q1 <<Azəmwo nra ngga Nfa Apye apipye i watar
\q2 na í ya asa̱l ǹyáp ká̱ ìpirkur yi,
\q1 kang azəmwo Ìlum iga Njul i kùr
\q2 na í yáp ká̱ iya̱m mma yi yà?
\q2 Í tək ikpáng iga mma iya̱m kang í ran asikel,
\q1 í ma iya̱m ónəm ká̱ ka̱ apal mbwai mmakmak.
\q1 
\v 6 Í yáp ká̱ ikur va mmá lyang ká̱ adùng.
\q2 Í yáp unəm uga nkun ká̱ aazurfa.
\q2 Í yáp unəm uga nlàng ka̱ anung mbwai akwàp.>>
\p 
\v 7 UYawe, Inan ovan oga aIsa̱rila sóng anung chit ka̱ apal ǹrup ká̱ ishi áYakup pa̱, <<Mi yà ká̱ nka̱ng ká̱ inga va̱ oza̱ nəm ka̱t.
\q1 
\v 8 Ka̱kul nva̱ ta te mbin i tán,
\q2 kang nkpaktak onəm oga ashishe i təm ká̱ aɗor ka̱t ɗò?
\q1 Mbin i wong wa ndəng awang aNilu,
\q2 i wong kang i fər wa aNilu aga aMasar.>>
\p 
\v 9 UPonzhinan uYawe là pa̱, kà̱ ilum va̱ ta te,
\q1 <<Mi nak alum ka̱ apal ndəng i tar,
\q2 kang mbin i kpà̱r ká̱ alum.
\q1 
\v 10 Mi ga̱ɓa̱n nchang izər wo i yà ntəm aɗor,
\q2 kang nkpaktak nnap-nshì wo i nyáng ìpyang iga aɗor.
\q1 Mi nak o mwak ìlukwan iga ǹyə́ng ikú,
\q2 kang o kà̱p ishi.
\q1 Mi nak o yə́ng wa ánəm va uyiyen pa̱ uzəng kang à kú.
\q2 Ìlum va̱ ta nkukur i ɗul byet.>>
\q1 
\v 11 <<Fye, nra nna kà̱ mɓa.>> UPonzhinan uYawe là pa̱,
\q2 <<Mi ga re ǹre ká̱ ayáng kà̱ mbin.
\q1 Ayáng i ji oza̱ aga iya̱m-nrì ka̱t,
\q2 ndəng i gba̱l oza̱ ngga ndəng ngwà ka̱t kpa.
\q1 Ayáng ká̱ ndəng ngbà̱l
\q2 ka̱kul nɗom nfe nnap nla mi, uYawe.
\q1 
\v 12 Oza̱ i pin kà̱ ìwá ìva̱ ta̱ i ga ìva̱ cho,
\q2 oza̱ i ga mpal i ga asa̱l awu alum.
\q1 Ka̱kul oza̱ i ram pa̱ na o fe nnap-nlà àYawe,
\q2 kang oza̱ i ya ka̱t.
\p 
\v 13 <<Ka̱ ashe nra va̱ ta ovan ochar ogəkgək oɓyenɓyen ká̱ ovan nza̱m okankam i tàk ká̱ ndəng ngbà̱l.>>
\q1 
\v 14 Oza̱ va̱ i sóng anung ká̱ mpat oga aSamariya,
\q2 oza̱ i là pa̱, <<Nnandər, wa nva inan ɓu ì ya yà, áDan>>
\q2 ka̱t te <<Á yà wa nji ɓu lap ka̱t á ìchər oga aBəyersheba>>
\q1 oza̱ i tàk, i yà ká̱
\q2 ngwong lap ka̱t mbyet mbyet.
\c 9
\s1 NTàn nro yà nva unəm i // nəm ká̱ akwali Inan ka̱t
\p 
\v 1 N ya uPonzhinan sat ka̱ atak nshì iya̱m awop. Uza̱ là pa̱,
\q1 <<Lə̀p nggwan nzhi awop pa̱ gənggəng na mbang nzhi á yənggət.
\q2 Chwan oza̱ á tàk ka̱ apal ishi nkpaktak onəm.
\q1 Aɓo onəm te, mi gbá̱ng ká̱ ndokchi.
\q2 UNəm pa̱ uzəng i pətər ka̱t,
\q2 uro ya i lár ka̱t.
\q1 
\v 2 A yà pa̱ oza̱ atáng aShəwol te,
\q2 awo mi i fa ká̱ oza̱ ka̱ ta.
\q1 A yà pa̱ oza̱ a kyen ka̱ ashe apaɓur te,
\q2 mi fəng ká̱ oza̱ ka̱ ta.
\q1 
\v 3 A yà pa̱ oza̱ a bwam kà̱ ìtə́ngtə́ng aɓam aKarmel te,
\q2 mi ram oza̱ mi fəng ká̱ ka̱ ta.
\q1 A yà pa̱ oza̱ a bwam ka̱ avəng ìwá te,
\q2 mi nak awù aga ashe ndəng i kyen oza̱.
\q1 
\v 4 A yà pa̱ okpa ìkum oza̱ a wur izwal ká̱ oza̱ te,
\q2 mi nak mí gbá̱ng oza̱ ká̱ ndokchi.
\q1 Mi pá ìwu óza̱,
\q2 ka̱kul inga, inəna̱n ka̱t.>>
\q2 
\v 5 UPonzhinan uYawe uga nggatək
\q2 dok apambin te apambin sərak,
\q2 nkpaktak onəm oga ashishe təm ká̱ aɗor.
\q1 Nkpaktak mbin i wong kang i fər,
\q2 wa ìgum ndəng awang aNilu aga aMasar.
\q1 
\v 6 Uza̱ va me nzhi iponzhi wò ka̱ ashe apaɓur,
\q2 kang uza̱ bang akukum ka̱ apambin.
\q1 Uza̱ wór ndəng ìwá
\q2 tar ka̱ apambin.
\q2 Aɗiɗin pa̱ uYawe.
\q1 
\v 7 UYawe ɓəp pa̱, <<Ónəm oIsa̱rila, o rəng pa̱ o ji
\q2 onəm oKush ji ka̱ atak mi ɗò?
\q1 Mmami na n fa ká̱ oga aIsa̱rila kà̱ mbin aMasar,
\q2 ká̱ oFilisti ka̱ aKafto.
\q2 Kang onəm oga aAram te, ka̱ aKir ka̱t ɗò?>>
\q1 
\v 8 <<Dər, uPonzhinan uYawe
\q2 kà̱ ndər iponzhi iɓá̱ngɓa̱ng oga aIsa̱rila va̱ ta̱,
\q1 mi zhì na i le
\q2 ka̱ apambin.
\q1 Káp ká̱ nnà te, mi nzhì nkpaktak
\q2 nzhi àYakup ka̱t,>> uYawe à là.
\q1 
\v 9 <<Mi nak mí yənggət oga aIsa̱rila
\q2 ka̱ ashe nkpaktak oga mbin,
\q1 wa nva mí yeka̱n ikur ká̱ ìkpáng ìga atum,
\q2 apir pa̱ zəng i yà ká̱ nlar ka̱t>>
\q1 
\v 10 Onəm oga nnap mɓá̱ngɓa̱ng pa̱ kpaktak te mí zhì oza̱ ká̱ ndokchi.
\q2 Onəm va kà̱ nlà pa̱, <<Iya̱m ro i yà ká̱ ǹya yi ka̱t.>>
\s1 Ngwong ká̱ oga aIsa̱rila
\q1 
\v 11 <<Kà̱ ìlum va̱ ta te,
\q2 mi me nzhi aDawuda kà̱ɗi .
\q1 Mi ɗa̱mshi oga mɓol akamsəlang,
\q2 mi wong ká̱ oga agúng va̱ shin
\q2 kang mi me oza̱ wa nva ka̱ yà,
\q1 
\v 12 ka̱kul na oza̱ à ka̱m aɓo oga aEdom va̱ re,
\q2 ka̱ nkpaktak oga mbin va̱ ka̱ yà mí wór oza̱ pa̱ ojem á.>>
\q2 UYawe va i ga nnənəm à là.
\p 
\v 13 <<Fye, nra na kà̱ mɓa.>> UYawe là pa̱,
\q1 <<Iya̱m i yál nna mmá gba̱l nshàng ìram chit ka̱t,
\q2 kang nkáng ndəng ìba̱ngba̱ng ǹsámsàm nna i ga mpyal mɓəɓal.
\q1 Aɓam i na ndeng ìba̱ngba̱ng ichángchàng
\q2 va i ɓəl ka̱ apal oga aɗuktum.
\q1 
\v 14 Mi le ká̱ onəm mi oIsa̱rila ka̱ atak izwal,
\q2 oza̱ i me oga ìtong oza̱ va̱ ra agúng i təm kà̱.
\q1 Oza̱ i ɓál ìba̱ngba̱ng oza̱ i wá ndədəng,
\q2 oza̱ i wap ìram ìkáká, i ri iyəya̱m.
\q1 
\v 15 Mi ɓál oza̱ ka̱ ashe mbin oza̱,
\q2 mí yà ká̱ ntur oza̱ lap kà̱ mbin va̱ nná óza̱ ka̱t.>>
\q2 UYawe, Inan wo à là.
