\s1 Prisionero en Cesarea  
\p
\v 22 \w Cuando|strong="G3752"\w* \w Félix|strong="G5344"\w* \w conoció|strong="G1492"\w* \w con|strong="G2596"\w* mayor exactitud \w estas|strong="G3588"\w* cosas referentes \w al|strong="G3588"\w* \w Camino|strong="G3598"\w*, \w los|strong="G3588"\w* aplazó. Les \w dijo|strong="G3004"\w*: \w Cuando|strong="G3752"\w* \w el|strong="G3588"\w* comandante \w Lisias|strong="G3079"\w* baje, determinaré \w lo|strong="G3588"\w* referente \w a|strong="G2596"\w* ustedes.  
\v 23 \w Ordenó|strong="G1299"\w* \w al|strong="G3588"\w* \w centurión|strong="G1543"\w* custodiarlo, \w que|strong="G3588"\w* \w tuviera|strong="G2192"\w* servicio \w y|strong="G2532"\w* \w que|strong="G3588"\w* \w no|strong="G3367"\w* impidiera \w que|strong="G3588"\w* \w alguno|strong="G3367"\w* \w de|strong="G3588"\w* \w los|strong="G3588"\w* \w suyos|strong="G2398"\w* \w lo|strong="G3588"\w* atendiera.   
\p
\v 24 \w Después|strong="G3326"\w* \w de|strong="G4012"\w* \w algunos|strong="G5100"\w* \w días|strong="G2250"\w*, cuando \w Félix|strong="G5344"\w* \w se|strong="G2532"\w* presentó \w con|strong="G3326"\w* \w su|strong="G3588"\w* \w esposa|strong="G1135"\w* \w Drusila|strong="G1409"\w*, \w quien|strong="G3588"\w* \w era|strong="G1519"\w* \w judía|strong="G2453"\w*, \w llamó|strong="G3343"\w* \w a|strong="G1519"\w* \w Pablo|strong="G3972"\w* \w y|strong="G2532"\w* \w lo|strong="G3588"\w* oyó \w con|strong="G3326"\w* \w respecto|strong="G1519"\w* \w a|strong="G1519"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w en|strong="G1519"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w*.  
\v 25 \w Pero|strong="G1161"\w* cuando \w él|strong="G3588"\w* \w se|strong="G1096"\w* pronunció \w sobre|strong="G4012"\w* \w justicia|strong="G1343"\w*, dominio propio \w y|strong="G2532"\w* \w el|strong="G3588"\w* \w juicio|strong="G2917"\w* \w que|strong="G3588"\w* viene, \w Félix|strong="G5344"\w* \w se|strong="G1096"\w* sintió atemorizado \w y|strong="G2532"\w* replicó: ¡\w Vete|strong="G4198"\w* \w por|strong="G4012"\w* \w ahora|strong="G3568"\w*! Cuando \w haya|strong="G1096"\w* \w un|strong="G3588"\w* \w tiempo|strong="G2540"\w* favorable, \w te|strong="G4771"\w* \w llamaré|strong="G3333"\w*.  
