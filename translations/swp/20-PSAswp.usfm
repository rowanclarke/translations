\id PSA
\ide UTF-8
\h SALAMO
\toc1 SALAMO HEADI BUKANA
\toc2 Salamo
\toc3 Sal.
\mt1 SALAMO HEADI BUKANA
\c 1
\s1 Laulau dudurai tauna eo laulau baaea tauna
\q1 
\v 1 Tau wa ie kode
\q2 ia laulau gewagewa tataodi edi ribahesanapu nige i laulauedi,
\q1 baaea tataodi edi dobila eai nige i totoro,
\q2 eo Eaubada tau‐alaliuliuwaena edi oigogo eai nige i patulau;
\q1 
\v 2 na GUIAU ena laugagaeo i kodei mo,
\q2 eo i hasihasiri asubena to maiona.
\q1 
\v 3 Ia doha oeagi esau
\q2 saga gegesina eai se umai,
\q2 ena huia ua eai aiaina abo ie tore,
\q2 eo luguna taba nige se wowoea.
\q1 Ginauri gamagaridi i ginauridi abo se lau lolo.
\b
\q1 
\v 4 Laulau gewagewa tataodi isi nige meta doha,
\q2 isi doha sitona wenudi mana i eoho’eohoedi.
\q1 
\v 5 Arinai ede laulau gewagewa tataodi hedudurai asubenana eai taba nige se toro,
\q2 eo baaea tataodi taulaulau dudurai edi oigogo eai taba nige se toro.
\q1 
\v 6 Paana GUIAU laulau dudurai tataodi i abi komakomanidi,
\q2 na laulau gewagewa tataodi abo se tauyamui.
\c 2
\s1 GUIAU ena heyausi tauna ena huia tanuaga
\q1 
\v 1 Paana saha eanua gamagaridi taumiaidi se oioiriba,
\q2 eo tatao se saha se nuanuatu gaibu mo?
\q1 
\v 2 Tanoubu wasawasadi se totoro‐lelei,
\q2 tanutanuaga hinage se oiribagogoesega
\q2 GUIAU bena se laugudugudui eo ena heyausi tauna, si ene,
\q1 
\v 3 “Edi auau ta oimotudi,
\q2 eo edi maina poasi ta gabahesuaradi!”
\b
\q1 
\v 4 Ia galewa eai ie mia abo i maruhi;
\q2 GUIAU ia abo i alaliuliuwaedi.
\q1 
\v 5 Abotai ma ouyalayalana abo i ribalau aridi eai,
\q2 ena ouyalayala eai abo i hematausi aririedi, abo i ene,
\q1 
\v 6 “Eau egu wasawasa ea hetoroyao wa
\q2 egu oea tabuna Siona tupina arinai.”
\b
\q1 
\v 7 GUIAU ena laugagaeo ribana abo ea heribamiu:
\q2 I ribalaoma i ene, “Oa natugu ede,
\q2 wauta ea hemala oa tamam.
\q1 
\v 8 U aibodalaoma, abo eanua gamagaridi taumiaidi ea lediwa em gogo,
\q2 eo tanoubu maudoudoina abo oa enam.
\q1 
\v 9 Oa abo u hetamogorugorudi poasi tu’ena arinai,
\q2 abo u oigorugoru hegahegagiridi doha gulewa.”
\q1 
\v 10 Omi wasawasa e, bena au sibasiba;
\q2 omi tanoubu tanutanuagamiu bena se ribahesanapumiu.
\q1 
\v 11 Ma matausimiu GUIAU au heayaiyei,
\q2 ma tabutabubumiu
\v 12 aena au alagoiedi,
\q2 ata i ouyalayala, eo dobila eai au mate,
\q1 paana ena ouyalayala i heura ariariri.
\b
\q1 Tatao gamagaridi ena se dagolau ia arinai abo nuadi se kode.
\c 8
\s1 Eaubada Namanamarina eo Tau heasisina
\q1 
\v 1 GUIAU, tanuagamai e,
\q2 tanoubu maudoina eai oa esam i sae ariariri!
\b
\q1 Galewa ewana eai oa namanamarim se wanai
\q1 
\v 2 kaimou gagiridi, taumadomado awadi eai,
\q2 iala numana adiadidirina u hetoro em waiunu debadi eai,
\q2 waiunu eo tauabigum em abahemonoudi.
\q1 
\v 3 Ena ea itasae em galewa eai, oa nimagigim paisoadi,
\q2 nawarai eo ipora hinage oa tautoredi;
\q1 
\v 4 tau ede saha bena oa u nuanuatui,
\q2 eo tau natuna eai bena oa u abiloloei?
\b
\q1 
\v 5 Taiede oa u ginauri Eaubada ia begana mo i hemuri,
\q2 eo namanamari eai eo heasisina eai ia u hekorona.
\q1 
\v 6 Oa nimam eai ginauri gamagaridi u ginauridi wa u mosedio ia
\q2 tanuagadi eai ie lau;
\q1 ginauri gamagaridi ia aena ubudi eai ue toredi,
\q1 
\v 7 mamoe eo bulumakau gamagamagaridi,
\q2 eo nuura suisuidi hinage,
\q1 
\v 8 ewa manudi eo gabogabo eamadi,
\q2 eo ginauri gamagaridi gabogabo dobiladi eai se laulau.
\b
\q1 
\v 9 GUIAU, tanuagamai e,
\q2 tanoubu maudoina eai oa esam i sae ariariri!
\c 13
\s1 Amamna boeana eai bena se saguhai uurana
\q1 
\v 1 GUIAU e, abo i lau e aitea huia? Abo u nuahuiegu i lau e ana huia ana tasi?
\q2 I lau e aitea huia matam abo u buburi taba nige ea itam?
\q1 
\v 2 I lau e aitea huia abo nuagu eai amamna lailai,
\q2 eo asubena to maiona abo nuadubu nuagu eai?
\q2 I lau e aitea huia agu waiunu abo i saepoigu?
\b
\q1 
\v 3 U italaoma eo u heuioegu, GUIAU e, egu Eaubada;
\q2 matagu u hemaradi ata mate mamohoi enona ea enoei;
\q2 
\v 4 ata agu waiunu i ene, “Ea saepoiyao”;
\q1 ata agu waiunu se kode paana egu tabutabubu debana eai.
\q1 
\v 5 Na oa em gadosisi miatahitahina ea sunumaei,
\q2 nuagu abo i kodelamposi em abihemauri debana eai.
\q1 
\v 6 GUIAU arinai abo ea wana,
\q2 paana ia i ainauia aririegu.
\c 14
\s1 Tatao edi eauyaule eo edi baaea
\q1 
\v 1 Taueauyaure ia i ribariba nuana eai i ene,
\q2 “Eaubada nige’e.”
\q1 Isi tatao bi’ibi’idi, edi laulau se manamanabara ariri,
\q2 nige esau ena laulau i dudurai.
\b
\q1 
\v 2 GUIAU ia galewa eai i itadobi
\q2 tatao nanatudiyao aridi eai,
\q1 bena i itadi eai to eai se mia dudurai,
\q2 eai to eai Eaubada se eo’oi.
\b
\q1 
\v 3 Isi gamagaridi se gegege, isi gamagaridi edi miamia doha ie boha,
\q2 nige esau i mia dudurai,
\q2 nige’e, nige ariariri.
\b
\q1 
\v 4 Edi sonoga nige’e, tatao baabaaeadi ta,
\q2 agu bogaoyao se aidi doha falawa se aiaini,
\q2 eo nige se eogalau GUIAU arinai?
\b
\q1 
\v 5 Matausi lailai didiga abo se hearo
\q2 paana Eaubada ia laulau dudurai tataodi edi tupo eai.
\q1 
\v 6 Gogo gesagesa tauna ena nuatu isi bena se gudugudui,
\q2 na ena abadago ede GUIAU.
\b
\q1 
\v 7 Taba Isaraela ena abihemauri Siona eai i pesama!
\q2 Huiana wa GUIAU ena tataoyao edi gogo i hemaisauioidi
\q2 Iakobo abo i kodelamposi, Isaraela abo nuana i lolo.
\c 15
\s1 Eaubada ena oea tupina tabuna taumiaina
\q1 
\v 1 GUIAU e, eai gonoana i bawa oa em numalulu arinai?
\q2 Eai abo i mia em oea tupi tabuna eai?
\b
\q1 
\v 2 Tau wa nige abahegiruna,
\q2 eo laulau dudurai i laulauedi,
\q2 ia hinage nuana eai riba mamohoi mo i ribaribaei;
\q1 
\v 3 ia wa memenana eai nige monumonunu,
\q2 ena dodogayao nige i heamamna,
\q2 eo helena‐taumia‐tauna nige i ribasagasagariei;
\q1 
\v 4 laulau gewagewa tauna i isuewaei,
\q2 na GUIAU taumatausi tataodi ia abo i hedebasaedi;
\q2 ena riba aigora i hemamohoiei piripiri boeana eai;
\q1 
\v 5 ia moni ena i mosehagahagaidi, taba nige hagahagana bena i abiuioi,
\q2 hinage taba nige moni se mosei bena laulau dudurai tauna i hegirugaibui.
\b
\q1 Ia wa ena laulau doha ina, ia taba nige se hemoiu, nige ariariri.
\c 16
\s1 Gogo lolo dumadumana
\q1 
\v 1 Eaubada e, bena oa u hemaurigu, paana ea dagolaowa oa arim eai.
\q1 
\v 2 Ea ribalau GUIAU arinai ea ene, “Oa egu Guiau ede;
\q2 egu lolo ede oabom mo arim eai.”
\b
\q1 
\v 3 Oa em hetabu tataodi isi heasisi tataodi ede,
\q2 egu nualolo maudoina isi wa aridi eai.
\q1 
\v 4 Tatao wa isi eaubada esau se hineri isibom edi nuadubu se helai;
\q2 edi aitalasam osiosina taba nige ea hegoigabaedi,
\q2 esadi taba nige ea abidi sopagu eai.
\b
\q1 
\v 5 GUIAU ia egu hinehineri tupona ede, eo egu abanom,
\q2 egu mauri ede oabom nimam eai.
\q1 
\v 6 Dobila lolodi aridi eai u woeawoeaigu,
\q2 mamohoi em ainauia enagu i sae ariri.
\b
\q1 
\v 7 GUIAU ea ribatausaei ia tauribahesanapugu;
\q2 maiona huiana eai hinage nuagu eai i heaheatagu.
\q1 
\v 8 Huia gamagari GUIAU ea itadidini matagu eai,
\q2 paana ia nima‐tutugu eai abo taba nige ea moiu.
\q1 
\v 9 Arinai nuagu i lolo ariri, eo earuagu i kodelamposi,
\q2 taugu hinage i ota komakomani.
\q1 
\v 10 Paana oa taba nige u moselaegu Hade eai,
\q2 eo taba nige u eari em hetabu tauna Duha lailai i ita.
\b
\q1 
\v 11 Mauri dobilana oa u heiheitagu;
\q2 oa matam eai kode saesaena mo,
\q2 nimatutum eai amna lolo mo, i lau e ana huia ana tasi.
\c 19
\s1 Eaubada ana paipaisoa eo ena laugagaeo
\q1 
\v 1 Eaubada ena namanamari galewa i ribahemasaraha,
\q2 eo teha ewa eai nimana paisoana i wasawasaei.
\q1 
\v 2 Asubena to asubena ena riba se hetamarilaei,
\q2 eo maiona to maiona ena sonoga se ribahelai.
\q1 
\v 3 Isi nige arinadi dagugudi, eo nige edi riba,
\q2 memenadi nige dagugudi;
\q1 
\v 4 ia mo arinadi ie lau tanoubu maudoina boeana eai,
\q2 edi riba hinage se lau tanoubu sigana eai.
\q2 Duaduaridi eai mahana ena numalulu i hetoro,
\q1 
\v 5 ia doha tautawasora harihariu wa ena numa i torohaigabaei,
\q2 doha tau adiadidirina ma kodena ena dobila i laulauwatai.
\q1 
\v 6 Ena abadalasae ede galewa tupo esau eai,
\q2 i hetahetaiiri i lau e ie lage galewa sigana eai;
\q2 gigiborina arinai hinage taba nige ginauri saha i tauyamui.
\b
\q1 
\v 7 GUIAU ena laugagaeo i lolo dumaduma,
\q2 tau earuana i hemauriuioi;
\q1 GUIAU ena abahemasaraha ribadi mamohoidi ede,
\q2 tau nuasupusupuna i hesonoga.
\q1 
\v 8 GUIAU ena lauheata ribadi se dudurai,
\q2 tatao nuadi se hekodedi;
\q1 GUIAU ena lauhesom ie a’a esegai,
\q2 tatao matadi se hemaradi.
\q1 
\v 9 GUIAU matausina ie a’a,
\q2 i mia i lau e huia nige nosina;
\q1 GUIAU ena hesanapu ribadi mamohoidi ede,
\q2 eo se dudurai ariri.
\q1 
\v 10 Ta henua aririedi abotai \tl gold\tl*,
\q2 \tl gold\tl* gamagaridi lolololodi wa;
\q1 edi amna amoamo ena amna i hemuri,
\q2 amoamo wa noina eai i namnamtutu.
\b
\q1 
\v 11 Ribadi wa aridi eai em heaheari tauna se ribahesanapuei;
\q2 sogohidi eai ainauiana abo i lai ariri.
\q1 
\v 12 Aitea tau iabom ena baaea italobaina abina ie ata?
\q2 Egu laulau baaeadi eamuyamuidi aridi eai bena oa u hea’agu.
\q1 
\v 13 Oa em heaheari tauna ta bena nuasaesae baaeadi aridi eai u nuahi;
\q2 tabu se tanuagaigu!
\q1 Abotai abo ea toro dudurai,
\q2 eo awayagara lailaina arinai taba nige edi abahegirugu.
\b
\q1 
\v 14 Taba awagu ribadi eo nuagu nuanuatuna
\q2 oa matam eai bena se dudurai,
\q1 GUIAU e, egu we’utau, eo tau unehemaurigu.
\c 22
\s1 Amamna douna, eo hedebasae wanana
\q1 
\v 1 Egu Eaubada e, egu Eaubada e, ue saha u nuagabaegu ta?
\q2 Paana saha oa eda lohaloha eai, na nige u saguigu, egu dou nige u ataiei?
\q1 
\v 2 Eaubada e, asubena huiadi eai ea dousaewa, na nige u heuio,
\q2 maiona huiadi eai hinage, na nige aiawasi ea lobai.
\b
\q1 
\v 3 Iamo oa tabuna ede,
\q2 oa se hebawam Isaraela edi aihelahui potadi eai.
\q1 
\v 4 Tamamaiyao oa se sunumaem,
\q2 se sunumaem arinai oa u lebohaidi.
\q1 
\v 5 Se doulaowa, eo se mauri;
\q2 oa se sunusunumaem, eo nige u laudobiedi.
\b
\q1 
\v 6 Na eau motamota mo na nige tau;
\q2 tatao se subugu, dodoga se isuewaegu,
\q1 
\v 7 Isi gamagaridi se itagu eo se alaliuliuwaegu,
\q2 adi ao se hebaaeadi arigu eai, eo urudi se heodedi:
\q1 
\v 8 “Ena sunuma ie tore GUIAU arinai; besi ia i lebohai!
\q2 Hage ia i saguhai, paana ena nualolo ia arinai!”
\b
\q1 
\v 9 Omihede oa ede sinagu bogana eai u abihaigu;
\q2 sinagu susuna eai oa u itawataigu.
\q1 
\v 10 Egu huia labasi eai i laoma e wauta oa u itawataigu,
\q2 sinagu bogana eai i laoma e huia ta oa egu Eaubada ede.
\q1 
\v 11 Tabu oa eda lohaloha eai,
\q2 paana huia baaea i hanahanauma,
\q2 eo nige doga esau bena i saguigu.
\b
\q1 
\v 12 Bulumakau tamoadi gamagaridi se torohetai’irigu;
\q2 Basana edi bulumakau adiadidiridi se torohetai’irigu;
\q1 
\v 13 awadi se dabari helaidi matagu eai
\q2 doha liona guriguriamdi, eo se doulailai.
\q1 
\v 14 Amnagu ede doha goila se hegoigabaei,
\q2 eo siadagu popodi se tarumo.
\q1 Nuagu doha \tl wax\tl*
\q2 nuapougu eai ie welo;
\q1 
\v 15 adidirigu ie ohi, doha gulewa se oigoru,
\q2 memenagu ie patu gaeagaeagu eai;
\q2 mate mua’a mua’ana eai u he’enogu.
\b
\q1 
\v 16 Mamohoi kedewa se torohetai’ irigu,
\q2 tatao manamanabaradi se torohetai’ irigu;
\q2 nimagu eo aegu se aigoridi—
\q1 
\v 17 siadagu gamagaridi se hasiridi—
\q2 tatao wa se aiai’ewaigu eo nuadi se lolo;
\q1 
\v 18 agu lulu se soiedi,
\q2 eo agu lulu gamagaridi hinage se hekelerodi.
\b
\q1 
\v 19 Na oa, GUIAU e, tabu u mia eda lohaloha eai,
\q2 oa agu sagu ede, u heurama u saguigu!
\q1 
\v 20 Earuagu bena u saguhai elepa eai,
\q2 kedewa edi gigibori eai hinage u abihemaurigu!
\q1 
\v 21 Liona awana eai u hemaurigu,
\q2 bulumakau manamanabaradi donadi eai earuagu nuanuadubuna bena u saguhai!
\b
\q1 
\v 22 Oa esam abo ea wasawasaei egu tataoyao aridi eai,
\q2 tatao peledi boeadi eai abo ea aihelahuim:
\q1 
\v 23 Omi, eai to eai GUIAU au matausiei, ia au aihelahui!
\q2 Omi, Iakobo nanatunayao ia au ribapasipasiei,
\q2 ia matausina nuamiu eai, omi Isaraela nanatunayao!
\q1 
\v 24 Paana ia tau ai’iwala ana iwala nige i isuewaei
\q2 eo nige i hewaiunuei;
\q1 matana nige i toreamui arinai,
\q2 na ena dou mo i ataiei.
\b
\q1 
\v 25 Moutuana matadi eai abo ea hedebasaem;
\q2 egu riba aigora abo ea heduduraidi isi taumatausiem matadi eai.
\q1 
\v 26 Tau gogogesagesa abo se aiai, eo abo bogadi se sese.
\q2 Eai to eai ia se eo’oeo’oi abo GUIAU se hedebasaei!
\q2 Bena se amna lolo i lau e nige nosina!
\b
\q1 
\v 27 Tanoubu tupo gamagamagari abo se henuaisini eo abo se sinibui GUIAU arinai;
\q2 eanua gamagaridi taumiaidi abo se tabaohu ia arinai.
\q1 
\v 28 Paana GUIAU ia wasawasa ede,
\q2 eanua gamagaridi taumiaidi ia tanuagadi eai ie lau.
\b
\q1 
\v 29 Mamohoi ariri ia matana eai tanoubu taunuasaesae gamagaridi abo se tabaohui;
\q2 isi gamagaridi se hemala tanouio ia arinai abo se tabaohu,
\q2 isi hinage nige abina se ata se hemauriuioidi.
\q1 
\v 30 Isimurita ia abo se heayaiyei;
\q2 Guiau wasana tatao adi isimurita abo se heribadi,
\q1 
\v 31 ena mauri abo se wasaduaiei isi sora nige se labasidi aridi eai,
\q2 ia ana paisoa ede meta.
\c 23
\s1 GUIAU ia taumiataunigu
\q1 
\v 1 GUIAU ia taumiataunigu doha mamoe tauitawataina;
\q2 eau taba nige saha ea deha.
\q1 
\v 2 Abaaibai lolodi eai i heotagu.
\q2 Goila ipudi daumoridi gegesidi eai i woeaigu;
\q1 
\v 3 earuagu i hemauriuioi.
\q1 Laulau dudurai dobiladi eai i woeawoeaigu,
\q2 iabom esana debana eai.
\b
\q1 
\v 4 Ena mate gonuna masimasigirina eai ea lulau,
\q2 taba nige baaea aisana ea matausiei;
\q1 paana ede oa maidagu;
\q2 em pidipidiri, eo em tu’e
\q2 se henuabigagu.
\b
\q1 
\v 5 Hatahata enagu ue wese
\q2 agu waiunuyao matadi eai;
\q1 urugu u heyausi,
\q2 egu bia i monau boriboriri.
\q1 
\v 6 Mamohoi, abilolo eo nuatoatoa abo se hemuriwataigu
\q2 egu mauri asubenadi gamagaridi eai;
\q1 eo GUIAU ena numa eai eau abo ea miahai
\q2 i lau e huia nige nosina.
\c 24
\s1 Namanamari wasawasana
\q1 
\v 1 Tanoubu ma ginaurina gamagarina GUIAU enana ede,
\q2 tanoubu eo isi taumiaina gamagaridi hinage.
\q1 
\v 2 Paana ia iabom gabogabo potana eai i hetoro,
\q2 eo goila ubu eai potadi eai i tore komakomani.
\b
\q1 
\v 3 Eai gonoana abo i dalasae GUIAU ena oea tupina eai?
\q2 Eo eai ena eanua tabuna eai abo i toro?
\q1 
\v 4 Ia wa ena nimana se a’a, eo nuana i a’a mamohoi hinage,
\q2 ia wa nuana taba nige i sae ginauri borabora arinai,
\q2 eo nige i aigora borabora.
\q1 
\v 5 Ia GUIAU ena ainauia lolona abo i abi,
\q2 eo nige abahegiruna ena mauri Eaubadana matana eai.
\q1 
\v 6 Ia tau eo’oina isina adi ao ede ina,
\q2 Iakobo ena Eaubada matana taueo’oina wa.
\b
\q1 
\v 7 Urumiu au lauisinidi, omi gana dobilamiu e!
\q2 Omi se lauisinimiu, gudu lailaimiu beabeamiu e!
\q2 Namanamari Wasawasana bena i lusorama!
\q1 
\v 8 Wau namanamari Wasawasana wa eai?
\q2 GUIAU ede, ma adidirina, ma gigiborina,
\q2 GUIAU ia iala eai i gigibori wa!
\q1 
\v 9 Urumiu au lauisinidi, omi gana dobilamiu e!
\q2 Omi se lauisinimiu, gudu lailaimiu beabeamiu e!
\q2 Namanamari Wasawasana bena i lusorama!
\q1 
\v 10 Namanamari Wasawasana wa ia ede eai?
\q2 Tauiala tataodi moutuadi GUIAUNA,
\q2 ia ede namanamari Wasawasana!
\c 25
\s1 Woeawoea, ribagigiri, eo laubili uurana
\q1 
\v 1 GUIAU e, earuagu ea lauisini oa arim eai.
\q1 
\v 2 Egu Eaubada e, egu sunuma ea tore’esegai oa arim eai,
\q2 tabu se hetaumaeamaeagu
\q2 agu waiunuyao tabu se saepoigu.
\q1 
\v 3 Hedeomi, eai to eai se bagibagilaoa oa arim eai taba nige se taumaeamaea,
\q2 na isi mo dodoga manamanabaradi i lolo isi se hetaumaeamaeadi.
\b
\q1 
\v 4 GUIAU e, em laulau bena u heitagu;
\q2 em dobila bena u heatagu.
\q1 
\v 5 Em riba mamohoina bena arinai u woeaigu, eo u heatagu,
\q2 paana oa egu mauri Eaubadana ede.
\q2 Asubena lohaloha eai oa ea bagibagiem.
\b
\q1 
\v 6 GUIAU e, em nuatoatoa tabu u nuahuiei, eo em gadosisi miatahitahina,
\q2 mumuga eai ie mia i lau e nige nosina.
\q1 
\v 7 Hewarigu laulaudi baabaaeadi tabu u henuaisinidi, e egu awayagara;
\q2 oa em gadosisi miatahitahina mo arinai abo u nuatuigu,
\q2 em abilolo debana eai, GUIAU e!
\q1 
\v 8 GUIAU i lolo eo i dudurai;
\q2 arinai tatao baabaaeadi dobila i heitadi.
\q1 
\v 9 Tau nuatudobidobiuioina dobila duduraina arinai i woeai,
\q2 eo tau nuatudobidobiuioina ia ena eda i heata.
\q1 
\v 10 GUIAU ena abiabi gamagaridi aridi eai gadosisi miatahitahina eo riba hemamohoiena i hemasarahadi,
\q2 isi, eai to eai ena ribahesunuma eo ena riba tabudi se sogohididinidi.
\b
\q1 
\v 11 Oa esam debana eai, GUIAU e,
\q2 egu baaea giruna bena u ribagigiri, paana ie lai.
\q1 
\v 12 Aitea tau ia GUIAU i matausiei?
\q2 ia abo i heata aisega dobila bena i hineri.
\q1 
\v 13 Ia abo i mia komakomani, taba nige saha i deha,
\q2 eo nanatunayao edi tano abo se abi isi enadi.
\q1 
\v 14 GUIAU ena awa’eha i mosei isi ia se matausiei aridi eai
\q2 ena ribahesunuma hinage i hemasaraha aridi eai.
\q1 
\v 15 Matagu huia gamagari ea tusaei GUIAU arinai,
\q2 aegu sai’i eai abo i abihaidi.
\b
\q1 
\v 16 U sinibuima, eo u nuatoatoaegu,
\q2 paana ede eaubom, nige agu sagu, eo ea amnabaaea.
\q1 
\v 17 Nuagu ena amamna bena u laehesuara
\q2 eo egu nuadubu eai bena u abiisinigu.
\q1 
\v 18 Egu nuadubu eo agu iwala bena u nuatui,
\q2 eo egu baaea gamagamagaridi bena u ribagigiridi.
\b
\q1 
\v 19 Agu waiunu gamagamagaridi bena u nuatuidi,
\q2 edi hewaiunu hinage arigu eai i karapi ariri.
\q1 
\v 20 Nuagu u itawatai, eo u saguhaigu;
\q2 tabu se hetaumaeamaeagu, paana egu abadago ede oa.
\q1 
\v 21 Egu miamia a’a eo egu laulau dudurai bena se ganaganaigu,
\q2 paana ea bagibagilaoa oa arim eai.
\q1 
\v 22 GUIAU e, Isaraela ena lauita gamagaridi aridi eai
\q2 oa bena u unehai.
\c 27
\s1 GUIAU ia egu mara eo abihemaurigu
\q1 
\v 1 GUIAU ia egu mara eo egu abamauri ede;
\q2 eai abo ea matausiei?
\q1 GUIAU ia egu mauri ena iala bonana ede;
\q1 eai matausina abo ea matausi?
\b
\q1 
\v 2 Ena tatao manamanabaradi se ialaigu
\q2 eo se aipate bena se unuigu,
\q1 agu waiunu eo isi tau hebaaeagu,
\q2 abo se alabesibesi eo abo se beu.
\b
\q1 
\v 3 Taba iala tataodi gamagaridi se hetaiirigu,
\q2 taba nige aruagu i loi;
\q1 taba hinage se ialaigu,
\q2 nuagu taba nige se hemoiu.
\b
\q1 
\v 4 Ginauri esega dumaduma GUIAU arinai ea aibodai,
\q2 abo hinage ea eo’owatai:
\q2 ia ede bena GUIAU ena numa eai ea miamia
\q2 egu mauri asubenadi gamagaridi eai,
\q1 GUIAU ana ao lolo dumadumana bena eai itaitai,
\q2 eo bena ena dubu alona eai ea aiaibodalau.
\b
\q1 
\v 5 Paana ede huia baaea eai
\q2 ena abaailogulogu eai abo i toreamuigu;
\q1 ena apa birigomna eai abo i buburigu,
\q2 ia abo i abiisinigu we’utau saesaena potana eai i toregu.
\b
\q1 
\v 6 Abotai eau urugu abo se lauisini agu waiunuyao
\q2 se toro hetaiirigu ea saetawatawaidi,
\q1 arinai ena numa lulu eai aitalasam abo ea gabudi ma wowogu;
\q2 abo ea wana, eo GUIAU abo ea aihelahui!
\b
\q1 
\v 7 GUIAU e, ena ea eoga lailai bena u ataatai!
\q2 Em abilolo bena u hemasara arigu eai, eo u heuioegu!
\q1 
\v 8 U ribaeyao u ene, “Matagu u eo’oi.”
\q2 Nuagu i heuioem, i ene,
\q1 “GUIAU e, matam abo ea eo’oi.”
\q2 
\v 9 Tabu matam u woeoi arigu eai.
\b
\q1 Em heaheari tauna tabu u aiduiei ma ouyalayalam,
\q2 tau saguigu ede oa.
\q1 Tabu u gabahesuaragu, tabu u nuagabaegu,
\q2 abihemaurigu Eaubadana e!
\q1 
\v 10 Taba tamagu eo sinagu se otaotaegu wa,
\q2 GUIAU abo i abi’isinigu.
\b
\q1 
\v 11 Oa em dobila u heatagu, GUIAU e,
\q2 abalau masamasarahana eai u woeaigu
\q2 agu waiunuyao debadi eai.
\b
\q1 
\v 12 Tabu u buigabaegu agu waiunu edi henuhenua aridi eai,
\q2 paana tauribaribataubiga tataodi se toro bena se hebaaeagu,
\q2 isi hinage heamamna laulaudi eahuadi eai.
\b
\q1 
\v 13 Ea awamamohoiei GUIAU ena abilolo abo ea ita
\q2 tatao maumauridi edi eanua eai.
\q1 
\v 14 GUIAU u laubagibagiei; u adidiri, eo u nuakipikipi,
\q2 hedeomi, GUIAU u laubagibagiei.
\c 31
\s1 Sunuma ribahemasarahana
\q1 
\v 1 GUIAU e, egu abahomo ede oa,
\q2 taba nige se hetaumaeamaeagu, nige ariariri;
\q2 em laulau dudurai debana eai bena u lebohaigu!
\q1 
\v 2 U ataatailaoma arigu eai,
\q2 u heurama u saguhaigu!
\q1 Oa bena egu ababawayamui we’una,
\q2 egu abamia adiadidirina abo arinai ea mauri!
\q1 
\v 3 Mamohoi oa egu we’utau eo egu abamia adidirina;
\q2 esam debana eai bena u woeaigu eo u eda bagunaegu.
\q1 
\v 4 Siposipo se abinonoha eamuyamui enagu, bena arinai u eairihaigu,
\q2 paana egu abahomo ede oa.
\q1 
\v 5 Earuagu ta ea leawa oa nimam eai,
\q2 GUIAU e, Eaubada mamohoina, oa u unehaiguo.
\b
\q1 
\v 6 Aidimodi oitau borabora se nuanuatuidi oa u hewaiunuedi;
\q2 na eau GUIAU mo ea sunumaei.
\q1 
\v 7 Abo ea kode ariri eo nuagu i lolo oa em gadosisi miatahitahina debana eai,
\q2 paana egu amamna u itayao,
\q2 egu lauita oa u nuatuidio,
\q1 
\v 8 na nige u moselaegu waiunu nimana eai,
\q2 aegu mo u hetorodi eanua magamagagana eai.
\b
\q1 
\v 9 GUIAU e, bena u nuatoatoaegu, paana ea ai’iwala;
\q2 matagu i beruberuo nuadubu debana eai,
\q2 nuagu eo taugu hinage.
\q1 
\v 10 Paana nuadubu egu mauri i abiheohi,
\q2 eo egu borimai gamagaridi eai hinage ea aiai’iwala.
\q1 Egu adidiri ie ohi nuadubu debana eai,
\q2 siadagu hinage se meimei.
\b
\q1 
\v 11 Ea hemala agu waiunuyao edi abaalaliuliuwa,
\q2 helegu‐tau‐mia‐tataodi edi abamatamatausi,
\q1 egu dodogayao edi abatabutabubu;
\q2 aidobudi dobila eai se itagu abo se dagogabaegu.
\q1 
\v 12 Se nuahuiegu doha tau matematena,
\q2 agu ao doha gulewa tamotamogoruna.
\q1 
\v 13 Agueamoisa, monumonunu gamagaridi ea ataiedi—
\q2 tupo gamagari eai matausi lailai!—
\q1 Se oioiribagogo bena se hebaaeagu,
\q2 se nuatueamuyamui bena se unuigu.
\q1 
\v 14 Na, GUIAU e, egu sunuma ede oa arim eai,
\q2 ea ene, “Oa egu Eaubada ede.”
\q1 
\v 15 Egu mauri asubenadi gamagaridi ede oa nimam eai;
\q2 agu waiunuyao, eo tauheamamnagu nimadi eai bena oa u saguhaigu!
\q1 
\v 16 Bena am ao u hesina em heaheari tauna potana eai;
\q2 em gadosisi miatahitahina arinai bena u abihemaurigu!
\q1 
\v 17 Tabu se hetaumaemaeagu GUIAU e, paana ea eogasaewa arim eai.
\q2 Isi mo tatao manamanabaradi bena se hetaumaeamaeadi,
\q2 bena se hetagugudi, eo se laedi Hade eai.
\q1 
\v 18 Sopa boraboradi bena se unauna,
\q2 aidobu tatao laulaududurai se ribahebaaeadi,
\q2 nuasaesae eo isuewa debana eai.
\b
\q1 
\v 19 Em abilolo i lai ariariri
\q2 u nonohai isi taumatausiem enadi,
\q1 eo isi eai to eai se ailogulogu oa arim eai
\q2 tatao matadi eai!
\q1 
\v 20 Oa nuanuam eai u hebawayamuidi
\q2 tatao edi nuatu hebahebaaea aridi eai;
\q1 logulogum eai u ganaganaidi
\q2 arina baaea aridi eai.
\b
\q1 
\v 21 GUIAU abo se ribahelolo,
\q2 paana ena gadosisi otaotahaina i hemasaraha enagu
\q2 huiana ne lauita lailai ea hearo gonogonoana doha eanua se ialai.
\q1 
\v 22 Ma nuaberuberugu ea ene,
\q2 “Oa matam eai se henauhesuaragu!”
\q1 Na oa egu awanori u ataiei
\q2 huiana ne ea eogalaowa bena u saguigu.
\b
\q1 
\v 23 GUIAU au gadosisiei, omi tau miatahitahina!
\q1 GUIAU tausunumaena i ganahetai’iridi
\q2 na taunuasaesae ena maisa i heporohe aririei.
\q1 
\v 24 Au adidiri, eo hinage au nuakipikipi,
\q2 Omi gamagarimiu, GUIAU taulaubagibagiena!
\c 32
\s1 Ribagigiri helolona
\q1 
\v 1 Tau wa ena awayagara se ribagigiri,
\q2 ena baaea se bubulitawai, ia ie kode!
\q1 
\v 2 Tau wa nige ana giru GUIAU matana eai,
\q2 earuana eai nige abiborabora, ia ie kode hinage!
\b
\q1 
\v 3 Huiana ne egu baaea nige ea hemasaraha, taugu se porohe ariri,
\q2 asubena maudoina ea lepalepa.
\q1 
\v 4 Asubena to maiona nimam potagu eai i porohe ariri,
\q2 egu adidiri ie ohi, doha siwaro lailai eai gigibori huiana eai.
\b
\q1 
\v 5 Oa arim eai egu beaea ea hemasaraha,
\q2 eo egu ponori nige ea toreamui;
\q1 ea ene, “Egu awayagara wa abo ea ribahemasaraha GUIAU arinai,”
\q2 abotai egu baaea giruna u ribagigiri.
\b
\q1 
\v 6 Arinai isi nuadi se ota esegai taba gamagaridi se uura arim eai;
\q2 huia baaea eai, abaita ena huia didi eai,
\q2 isi taba nige se hearo.
\q1 
\v 7 Oa egu ababawayamui ede,
\q2 piripiri aridi eai u ganahetaiirigu,
\q2 aridi eai u lebohaigu.
\b
\q1 
\v 8 Abo ea heatam, em dobila abo ea heitam arinai bena u lau;
\q2 abo ea lauhasahasaim, matagu ede oa potam eai.
\q1 
\v 9 Oa tabu em abi doha hosi e doha \tl mule\tl*, isi nige edi sibasiba;
\q2 arinai se paidi, eo awadi eai abawoeawoeaidi se heapudidinidi
\q2 bena abo se awa’abiem.
\b
\q1 
\v 10 Tau laulau gewagewa ena nua’amamna se gamagari ariri,
\q2 na gadosisi miatahitahina GUIAU tausunumaena abo i hetaiiri.
\q1 
\v 11 Au kode GUIAU arinai, eo nuamiu se lolo, omi dudurai tataomiu e,
\q2 au eoga lailai, omi nuamiu se dudurai e!
\c 33
\s1 Tanoubu tauhetubuna eo tauitawataina se hedebasaei
\q1 
\v 1 Au kode ariri GUIAU arinai, omi taulaulau dudurai!
\q2 Tau dudurai i lolo i aiaihelahui.
\q1 
\v 2 Huelele arinai GUIAU au aihelahui,
\q2 huelele mainadi saudoudoi aridi eai enana au oioini!
\q1 
\v 3 Wana harihariuna enana au wanai,
\q2 au oi‐huelele komakomani ma arina lailaimiu!
\b
\q1 
\v 4 Paana GUIAU ena riba i dudurai;
\q2 eo ana paisoa maudoina ie abi ma nuapai’ipai’ina.
\q1 
\v 5 I’ila lolo eo laulau dudurai i gadosisiedi;
\q2 GUIAU ena gadosisi miatahitahina tanoubu i hemonau.
\b
\q1 
\v 6 GUIAU ena riba arinai galewa tehana se hetubu,
\q2 eo ena ginauri gamagaridi ia awana eahuana arinai.
\q1 
\v 7 Gabogabo goilana i pei’esegai tupo esega eai,
\q2 gabogabo ena aba ota eai ie tore.
\b
\q1 
\v 8 Tanoubu maudoina bena GUIAU se matausiei,
\q2 tanoubu taumiaina ia bena se tabutabubuei!
\q1 
\v 9 Paana ia ie riba, to ia ede:
\q2 i lauhesom, abo i taumasaraha.
\b
\q1 
\v 10 GUIAU eanua gamagaridi taumaiaidi edi sonoga i itasubudi;
\q2 tatao bodadi edi nuanuatu i guduguduidi.
\q1 
\v 11 GUIAU ena ribahesanapu i otaesegai i lau e nige nosina,
\q2 ia ena nuatu se miatahitahi isi gamagaridi aridi eai.
\q1 
\v 12 Eanua taumiaidi wa se kode ariri taba edi Eaubada ede GUIAU,
\q2 tatao wa isi i hileidio iabom enanayao.
\q1 
\v 13 GUIAU galewa eai i itadobima,
\q2 tanoubu tataodi gamagaridi i itadi.
\q1 
\v 14 Ena ababawa telona potana eai i italau tanoubu taumiaina
\q2 gamagaridi aridi eai,
\q1 
\v 15 ia wa gamagaridi nuadi ia i hetubudi,
\q2 eo edi laulau gamagaridi i itasipoidi.
\q1 
\v 16 Wasawasa esau ena tauiala gamagaridi taba nige se hemauri;
\q2 tauiala nuakipikipina iabom ena adidiri lailaina eai taba nige i mauri.
\q1 
\v 17 Iala hosina taba nige i saepoi,
\q2 eo ena adidiri lailaina eai taba nige i hemauri.
\b
\q1 
\v 18 Mamohoi GUIAU matana ie lau eai tau matausiena arinai,
\q2 eo eai to eai ia ena gadosisi otaotahaina se sunumaei,
\q1 
\v 19 bena earuadi mate eai abo i saguhaidi,
\q2 eo guriam huiana eai abo i abihemauridi.
\b
\q1 
\v 20 Earuada GUIAU se laubagibagiei,
\q2 ia ada sagu eo eda opea ede.
\q1 
\v 21 Mamohoi, nuada se kode ia arinai,
\q2 paana ia esana tabuna ta sunusunumaei.
\q1 
\v 22 GUIAU e, em gadosisi miatahitahina bena i ota ai potamai eai,
\q2 paana ai ema sunuma ede oa arim eai.
\c 34
\s1 Iwala lebohaina hedebasaena
\q1 
\v 1 Huia gamagari GUIAU ea ribatausaei;
\q2 aihelahuina awagu eai taba nige i lautom.
\q1 
\v 2 Nuagu ena abaribapasipasi ede GUIAU;
\q2 taunuatudobidobiuio abo se ataiei, eo se kode.
\q1 
\v 3 Omi maeguyao GUIAU ta ribahelai,
\q2 eo esana ta hedebasae gogo!
\b
\q1 
\v 4 Eau GUIAU ea eo’oi to i ataiegu,
\q2 egu matausi gamagaridi boeadi eai i earihaigu.
\q1 
\v 5 Au italau ia arinai abo au nuawoiwoina;
\q2 abo ami ao taba nige se taumaeamaea.
\q1 
\v 6 Gogogesagesa tauna ta ie eoga, to GUIAU ia i ataiei,
\q2 eo ena amamna gamagaridi aridi eai i hemauri.
\q1 
\v 7 GUIAU ena aneru ia tau matausina tataodi i miahetaiiridi
\q2 eo baaea eai i saguhaidi.
\q1 
\v 8 Omi hage au ai’ita, abo au italobai GUIAU i lolo ede!
\q2 Tausunusunumaena abo nuana i kode!
\q1 
\v 9 GUIAU au heasisiei, omi hetabu tataomiu e,
\q2 paana ia tauheasisiena taba nige ena deha.
\q1 
\v 10 Liona nanatudiyao se dabu to se guriam,
\q2 na isi GUIAU tau eo’oina tataodi taba nige ginauri esa lolona se abisapuri.
\b
\q1 
\v 11 Merumeru tatao e, au laoma au ataatai arigu eai,
\q2 GUIAU heasisina eau abo ea heatamiu.
\q1 
\v 12 Aitea tau mauri i henua
\q2 eo i henua ena mauri asubenadi bena se gamagari, bena lolo amnana i ataiei?
\q1 
\v 13 Oa memenam u abididini tabu u riba baaea,
\q2 sopam hinage borabora ribadi tabu se ribaedi.
\q1 
\v 14 Laulau gewagewa u tausuaraei, laulau lolo mo u laulauei;
\q2 loni u eo’oi, eo u miawatai.
\b
\q1 
\v 15 GUIAU matana se italau laulau dudurai tataodi aridi eai,
\q2 eo beana se tasoe edi eoga aridi eai.
\q1 
\v 16 GUIAU ana ao i laeudoiei laulau gewagewa tataodi aridi eai,
\q2 abahenuaisinidi tanoubu eai i tomgabaedio.
\q1 
\v 17 Laulau dudurai tataodi ena se eoga GUIAU i ataiedi,
\q2 edi piripiri gamagaridi eai ia i saguhaidi.
\q1 
\v 18 Ena tatao se nuaberuberu GUIAU i hanahanauidi,
\q2 isi nuadi se tamogorugoru ia i hemauridi.
\b
\q1 
\v 19 Laulau dudurai tauna piripiri gamagaridi i hearodi,
\q2 na gamagaridi boeadi eai GUIAU i saguhai.
\q1 
\v 20 Ia siadana gamagaridi GUIAU i itawataidi;
\q2 taba nige esau i tagodu.
\q1 
\v 21 Laulau gewagewa tauna baaea eai abo se unuheboso,
\q2 eo isi laulau dudurai tataodi tauhewaiunuedi abo se ribahematedi.
\q1 
\v 22 GUIAU ena heaheari tataodi abo i unehaidi,
\q2 isi wa taubawayamui ia arinai, taba nige esau se ribahemate.
\c 37
\s1 Laulau baaea tataodi taba nige se miatahitahi
\q1 
\v 1 Tabu nuam eai u hemodeuioim laulau baaea tataodi debadi eai,
\q2 laulau ponori tataodi hinage tabu u aiaromagigiriedi!
\q1 
\v 2 Paana nige baeaona abo se wowoea doha lagau,
\q2 eo se kokoeagi doha ginauri iniinidi.
\b
\q1 
\v 3 GUIAU mo au sunumaei, laulau lolodi mo au laulauedi,
\q2 arinai emi oea eai abo au mia, ma nuatarumiu.
\q1 
\v 4 U hekodeuioim GUIAU arinai,
\q2 eo oa nuam ena henuhenua ia abo i leawa.
\b
\q1 
\v 5 Em dobila GUIAU nimana eai u tore;
\q2 ia u sunumaei, abo hinage i paisoa.
\q1 
\v 6 Em laulau dudurai abo i hemasaraha doha mara,
\q2 eo am ao duduraina doha asuasubenalai.
\b
\q1 
\v 7 U heaiyawasiuioim GUIAU matana eai, eo u bagibagi ma nuapai’ipai’im;
\q2 tabu nuam i mode paana esau ena dobila i lau lolo,
\q2 ia laulau baaea wa i hetuhetubudi.
\b
\q1 
\v 8 Ouyalaya u helautom, eo nuaheura i otawa!
\q2 Tabu hinage u nuamodemode, ata u hebaaea’uioim.
\q1 
\v 9 Mata paana laulau baaea tataodi abo se tomgabaedi;
\q2 na isi GUIAU ena nuatu se bagiwatai tanoubu abo se abi isi enadi.
\b
\q1 
\v 10 Huia ku’uku’u mo eo laulau gewagewa tauna abo i tauyamui,
\q2 taba ena eanua eai se eo’oeo’oi, ia nei eai nige’e.
\q1 
\v 11 Na manabiga tataodi tanoubu abo se abi isi enadi,
\q2 ainauia lailai hinage abo se hearo eo arinai abo se kode.
\b
\q1 
\v 12 Tau laulau gewagewa i nuatu nonohai bena tau laulau dudurai i heamamna,
\q2 eo hinage ia arinai moana i taburueahisi;
\q1 
\v 13 na Guiau tau baaea i marumaruhiei,
\q2 paana ie ita ena huia i laolaoma.
\b
\q1 
\v 14 Tau laulau gewagewa elepa i niusihai, pidu hinage ie tu,
\q2 bena gogogesagesa tauna i laudobei
\q2 eo laulau dudurai tataodi bena i unuidi;
\q1 
\v 15 edi elepa abo i soralau isi isibom nuadi eai,
\q2 edi pidu abo se hetagodudi.
\b
\q1 
\v 16 Tau dudurai ena gogo begana mo, i lolo ariri
\q2 abotai laulau gewagewa tataodi edi gogo lailai didigadi.
\q1 
\v 17 Paana tau gewagewa nimana abo se godudi,
\q2 na GUIAU taududurai abo i abiisini.
\b
\q1 
\v 18 Tatao nige abahegirudi GUIAU edi huia abina i atao,
\q2 edi gogo hinage abo se ota i lau e nige nosina.
\q1 
\v 19 Huia piripiri eai taba nige se hetaumaeamaeadi,
\q2 guriam asubenana eai hinage adi aiai abo i lai ariri.
\b
\q1 
\v 20 Na tatao baabaaeadi abo se tomgabaedi
\q2 GUIAU ana waiunuyao isi doha oea liasina,
\q2 se tauyamui— doha asuasu se tautauyamui ariri.
\b
\q1 
\v 21 Tau laulau gewagewa ginauri i sagesagenai, na taba nige i hemaisauioi,
\q2 na tau laulau dudurai ena abi se lolo, to i aiainauia;
\q1 
\v 22 isi GUIAU i nualoloedi abo oea se abi enadi,
\q2 na isi i ribahematedi abo se tomgabaedi.
\b
\q1 
\v 23 Tau lolo ena abalau GUIAU i nuatu nonohai,
\q2 eo tau wa i nualolo arinai, abo i hetoro komakomani;
\q1 
\v 24 taba ie beu, taba nige i lau ariri,
\q2 paana GUIAU i abilau nimana eai.
\b
\q1 
\v 25 Egu huia hewari eai i laoma e egu huia tautaubada,
\q2 sora nige taududurai ea ita se nuagabaei,
\q2 e nanatunayao falawa se aiaiboda.
\q1 
\v 26 Ia huia gamagari i aiainauiasom, eo ia arinai se sagesagena.
\q2 eo nanatunayao hinage tatao se henualoloedi.
\q1 
\v 27 Baaea u torohaigabaei, lolo mo u abiwatai,
\q2 arinai abo u miatahitahi i lau e nige nosina.
\q1 
\v 28 Paana GUIAU abi dudurai mo i gadosisisiei;
\q2 ena tau miatahitahi tataodi taba nige i nuagabaedi.
\b
\q1 Tau dudurai abo se ganaganai i lau e nige nosina,
\q2 na tau gewagewa nanatunayao abo se tomgabaedi.
\q1 
\v 29 Tau dudurai abo oea i abi enana,
\q2 eo abo arinai i mia i lau e nige nosina.
\b
\q1 
\v 30 Tau dudurai awana eai riba sonoga i hepesadi,
\q2 memenana abi dudurai i ribaribaedi.
\q1 
\v 31 Ena GUIAU ena laugagaeo ia nuana eai;
\q2 ena abalau eai taba nige i utusagigi.
\b
\q1 
\v 32 Tau gewagewa tau dudurai i itasipoi,
\q2 eo i aipate bena i unui.
\q1 
\v 33 GUIAU taba nige i abigabaei ia nimana gigiborina eai,
\q2 eo abahedudurai eai taba nige se hegiru.
\b
\q1 
\v 34 GUIAU u bagibagiei, eo ena dobila u abididini,
\q2 ia hinage abo i abiisinim, eanua abo oa enam;
\q2 tau laulau gewagewa tauna abo u ita se tomgabaei.
\b
\q1 
\v 35 Tau laulau gewagewa ea ita i gigibori ariri,
\q2 i sae ariri doha Lebanona maruwaina esau.
\q1 
\v 36 Huia esau ea baeawa ea lau, na hedeomi, ia nei eai nige’e,
\q2 ea eo’oi komakomani, na taba nige ea lobai.
\b
\q1 
\v 37 Tau nige abahegiruna u italau arinai, eo tau dudurai u ita,
\q2 manabiga tauna abo ana isimurita.
\q1 
\v 38 Na tau awayagara abo se unuidi,
\q2 adi isi murita abo se tomgabaedi.
\b
\q1 
\v 39 Tatao duduraidi edi mauri abo se abi GUIAU arinai,
\q2 huia baea eai edi abahomo ede ia arinai.
\q1 
\v 40 GUIAU i saguidi eo i lebohaidi,
\q2 laulau gewagewa tataodi nimadi eai i lebohaidi eo i hemauridi,
\q2 paana edi abaailogulogu ede ia arinai.
\c 42
\s1 GUIAU gadomaguna
\q1 
\v 1 Doha suisui nuura
\q2 goila dididi i gadohiedi,
\q2 eau hinage, Eaubada e,
\q3 earuagu i gadohiem.
\q1 
\v 2 Earuagu i gadomagu Eaubada arinai,
\q2 Eaubada maumaurina arinai.
\q1 Aitea huia abo ea laoma
\q2 Eaubada ana ao abo ea ita?
\q1 
\v 3 Agu aiai esega ede matasulugu
\q2 asubena to maiona,
\q2 eo tatao huia gamagari se hesiolaoma, “Em Eaubada ia haedi‐eai?”
\b
\q1 
\v 4 Ina ginauri ta ea henuaisini
\q2 huiana wa nuagu ea soeauri;
\q1 tatao bodadi maeguyao
\q2 ea woeaidi, se hemuriwataigu Eaubada ena numa eai,
\q1 aie wowo ma kodemai, eo aie wana ma lautoimai,
\q2 moutuana lailai ai mataasi gogo.
\q1 
\v 5 Earuagu e, paana saha u nuadobidobi,
\q2 eo paana saha nuaboeagu eai u heunaboisaha?
\q1 Eaubada u sunumaei; paana ia abo ea hedebasaeuioi,
\q2 ia agu sagu ede
\v 6 eo egu Eaubada.
\b
\q1 Earuagu i porohe ariri nuaboeagu eai
\q2 arinai abo oa ea nuanuatuim,
\q1 Ioridana eo Heremona eanuadi eai,
\q2 Misara oea tupina eai hinage.
\q1 
\v 7 Gabotum i eogalau gabotum esau arinai,
\q2 em goila edi abadidi lailaidi dagugudi eai;
\q1 em bagodu eo em butubutu gamagaridi
\q2 se heputuhaigu.
\q1 
\v 8 Asubena huiana eai GUIAU ena gadosisi miatahitahina i leama;
\q2 eo maiona eai enana ea wawana,
\q2 ea lauuura egu mauri Eaubadana arinai.
\b
\q1 
\v 9 Ea ribalau Eaubada arinai ia egu we’utau,
\q2 “Paana saha u nuahuiegu ta?
\q1 Paana saha ea nuanuadubu,
\q2 waiunu ena hebahebaaea debana eai?”
\q1 
\v 10 Agu waiunuyao edi hesom
\q2 i hemala doha bonu lailai taugu eai,
\q1 huia gamagamagari se ribalaoma si ene,
\q2 “Em Eaubada haedi?”
\b
\q1 
\v 11 Earuagu e, paana saha u nuadobidobi,
\q2 eo paana saha nuaboeagu eai u heunaboisaha?
\q1 Eaubada u sunumaei; paana ia abo ea hedebasaeuioi,
\q2 ia agu sagu ede, eo egu Eaubada.
\c 43
\s1 Hedudurai eo Saguhai Urana
\q1 
\v 1 Egu laulau dudurai u hemasaraha, Eaubada e, eo enagu u toro
\q1 ganamuri tataodi matadi eai;
\q1 ao borabora eo laulau gewagewa tataodi nimadi eai
\q2 u lebohaigu!
\q1 
\v 2 Paana oa Eaubada egu aba ailogulogu ede;
\q2 paana saha u gabahesuaragu?
\q1 Paana saha ea nuadubu
\q2 waiunu ena hebahebaaea debana eai?
\b
\q1 
\v 3 Em mara eo em riba mamohoina bena u hetamaridima bena abo se woeaigu,
\q2 abo se woeaigu em oea tupi tabuna eo em abamia arinai!
\q1 
\v 4 Murina eai abo ea lau Eaubada ena aitalasam hatahatana arinai,
\q2 Eaubada egu abanuawoiwoina;
\q1 eo abo ea aihelahuim huelele arinai,
\q2 Eaubada e, egu Eaubada.
\q1 
\v 5 Earuagu e, paana saha u nuadobidobi
\q2 paana saha nuaboeagu eai u heunaboisaha?
\q1 Eaubada u sunumaei, paana ia abo ea hedebasaeuioi,
\q2 ia agu sagu ede eo egu Eaubada.
\c 46
\s1 Eaubada ia eda abahomo eo eda adidiri ede
\q1 
\v 1 Eaubada ia eda aba homo eo eda adidiri ede,
\q2 tausaguheulaida baaea huiadi eai.
\q1 
\v 2 Arinai taba nige ta matausi taba tanoubu ana ao ie bui,
\q2 taba oea tupidi gabogabo nuanuana eai se tabutabubu,
\q1 
\v 3 taba butubutu dagugudi se lai ma puropurodi,
\q2 eo taba oea tupidi se tabutabubu dagugu lailaina wa debana eai.
\b
\q1 
\v 4 Goila esau i dididi abo Eaubada ena eanua i hekode,
\q2 Saesae Aririna ena aba mia tabuna meta.
\q1 
\v 5 Eaubada ia duaduarina eai, ia taba nige se hemoiu,
\q2 Eaubada ia abo i saguheulai.
\q1 
\v 6 Etene se sagasagari, eanua udoi udoi se eoeo;
\q2 arinana ie tore, na tanoubu ie welo.
\q1 
\v 7 Tauiala moutuana GUIAUNA ia maeda,
\q2 Iakobo ena Eaubada ita eda aba homo!
\b
\q1 
\v 8 Au laoma GUIAU ena paipaisoa au itadi,
\q2 iabom i ginauridi tanoubu eai:
\q1 
\v 9 Iala i helautomdi i lau e tanoubu sigana;
\q2 welolo gigidi i hetagodudi, eo alahia i godudi,
\q2 kariota oeagi eai i gabudi!
\q1 
\v 10 “Au monou, eo abina au ata eau mo Eaubada,
\q2 Eau mo se lauisinigu eanua tataodi boeadi eai,
\q2 Eau mo se lauisinigu tanoubu eai!”
\q1 
\v 11 Tauiala moutuana GUIAUNA ia maeda,
\q2 Iakobo ena Eaubada ita eda abahomo ede!
\c 50
\s1 Eaubada ia Tauhedudurai i lolo
\q1 
\v 1 Eaubada GUIAU, Gigiborina,
\q2 i ribariba, eo tanoubu i eogalau arinai,
\q2 mahana ena huia dalasae, i lau e ena huia dui.
\q1 
\v 2 Siona, ana ao lolo dumadumana eai,
\q2 Eaubada ena mara i hesinalaei.
\b
\q1 
\v 3 Eda Eaubada i laolaoma, taba nige i monou,
\q2 ia matana eai doha oeagi i alabalebalelem,
\q2 mana lailai didigana ia i lauhetaiiri.
\q1 
\v 4 I eogasae galewa ewana eai
\q2 eo tanoubu eai hinage, bena ena tataoyao abo i heduduraidi.
\q1 
\v 5 “Tausunusunumaegu au heoigogoidima,
\q2 isi aitalasam arinai edi aigora arigu eai se ginauri wa!”
\q1 
\v 6 Galewa ia ena laulau dudurai se hemasaraha
\q2 paana Eaubada iabom tauheduhedudurai ede!
\q1 
\v 7 “Egu tataoyao e, au ataatai abo ea ribariba,
\q2 Isaraela e, emi baaea abo ea ribahemasaraha!
\q2 Eau Eaubada ede, emi Eaubada.
\q1 
\v 8 Emi aitalasam debadi eai taba nige ea hegirumiu;
\q2 emi aitalasam gabugabudi matagu eai huia gamagamagari.
\q1 
\v 9 Bulumakau tamoana emi numa eai taba nige ea nuatui,
\q2 goti tamoana emi gana eai hinage nige’e.
\q1 
\v 10 Paana nuura suisuidi gamagaridi eau enaguyao ede,
\q2 bulumakau hinage oea tupidi tausani potadi eai.
\q1 
\v 11 Galewa manudi gamagaridi hinage abidi ea ata’o,
\q2 eo ginauri maumauridi gamagamagaridi oea eai isi eau enaguyao ede.
\b
\q1 
\v 12 “Ena ea guriam, taba nige ea heribamiu;
\q2 paana tanoubu maena ginauri gamagaridi eau enaguyao ede.
\q1 
\v 13 Bulumakau bulumana eau ea aiaini, e nige’e?
\q2 Goti osinana hinage ea nomnomi, e nige’e?
\q1 
\v 14 Lautoi aitalasamna au heaitalasam Eaubada arinai,
\q2 eo emi aigora au hemamohoiedi Saesae‐Aririna arinai;
\q1 
\v 15 huia baaea eai abo au eogalaoma
\q2 eau hinage abo ea lebohaimiu, eo omi abo au hedebasaegu.”
\b
\q1 
\v 16 Na laulau gewagewa tataodi aridi eai Eaubada i ribalau, i ene:
\q2 “Ami paisoa saha na egu lauhesom au hasihasiridi,
\q2 eo egu ribahesunuma au abi sopamiu eai?
\q1 
\v 17 Paana heduhedudurai au hewaiunuei,
\q2 eo egu riba au gabaedi dagelamiu eai.
\q1 
\v 18 Taba tauaiyahari au ita, au awaehalau arinai,
\q2 tauganaganawari hinage maemiuyao au heboriesegaimiu.
\b
\q1 
\v 19 “Awam u moselaei riba gewagewa arinai,
\q2 memenam eai hinage u riba borabora.
\q1 
\v 20 Ue bawa na em tau u ribahebaaea,
\q2 sinam tahunuana natuna tau u ribahebaaea.
\q1 
\v 21 Ina laulau ta u laulauedi, na eau ea monou;
\q2 u ene bena eau gonogonoana doha oa.
\q1 Abotai ea ribasuuim, eo giru wa ea tore oa matam eai.
\b
\q1 
\v 22 “Ina ta au nuanuatui, omi aidobu Eaubada au nuahuiei,
\q2 ata ea purisimiu, na nige esau bena i toro i saguhaimiu!
\q1 
\v 23 Eai to eai lautoi i leama, ia ena heasisi enagu i hemasaraha;
\q2 eai to eai ena dobila i hedudurai
\q2 ia arinai Eaubada ena abihemauri abo ea hemasaraha.”
\c 51
\s1 Hea’a Uurana
\q1 
\v 1 Eaubada e, u nuatoatoaegu em gadosisi miatahitahina debana eai,
\q2 em nuatoatoa lailai didigana debana eai egu awayagara bena u saugabaedi.
\q1 
\v 2 Girugu bena u deurigabaei
\q2 eo egu baaea arinai oa bena u hea’agu!
\b
\q1 
\v 3 Paana egu awayagara abidi ea ata’o,
\q2 eo egu baaea hinage huia gamagari eau matagu eai i totoro.
\q1 
\v 4 Oa, oabom, ea hebaaeam,
\q2 saha i baaea oa matam eai, meta ea ginauriyao,
\q1 arinai em riba se dudurai ariri,
\q2 eo em hesanapu ribana nige abahegiruna.
\q1 
\v 5 Mamohoi baaea boeana eai se labasigu,
\q2 eo baaea eai hinage sinagu i abigu.
\b
\q1 
\v 6 Hedeomi, oa u henua bena ao mamohoi eau nuagu eai;
\q2 arinai nuagu eamuyamuina eai bena sonoga oa u heatagu.
\q1 
\v 7 \tl Hyssop\tl* arinai u hea’agu, eau hinage abo arinai ea a’a;
\q2 oa u deurigu, abo ea posiposi ariri abotai \tl snow\tl*.
\q1 
\v 8 Kode eo nualolo arinai oa u hemonaugu;
\q2 siada wa oa u hetagodudi abo se kodelamposi.
\q1 
\v 9 Egu baaea bena u hetauyamuidi oa matam eai,
\q2 agu giru gamagarina bena u saugabaei.
\b
\q1 
\v 10 Eaubada e, nua a’a oa u hetubu eau nuagu eai,
\q2 earua harihariuna eo duduraina u tore nuaboeagu eai.
\q1 
\v 11 Oa matam eai tabu u gabahesuaragu
\q2 eo em Earua Tabuna tabu u abihai arigu eai.
\q1 
\v 12 Em abihemauri kodena bena oa u leamauioi,
\q2 eo earua awaabina bena i bouisinigu.
\b
\q1 
\v 13 Abotai tauawayagara em laulau abo ea heatadi,
\q2 eo tatao baabaaeadi abo se sinibui oa arim eai.
\q1 
\v 14 Eaubada e, osina giruna arinai bena oa u saguhaigu,
\q2 oa Eaubada egu mauri paana,
\q2 eo memenagu oa em abihemauri abo i wana helai.
\b
\q1 
\v 15 Guiau e, sopagu oa u dabaridi,
\q2 eo awagu aihelahuim abo i hemasaraha.
\q1 
\v 16 Paana aitalasam taba nige oa i hekodem;
\q2 ena aitalasam gabugabuna ea leawa, taba nige nuam i lolo.
\q1 
\v 17 Aitalasam esega wa Eaubada i henua aririei iaede nua tamotamogoruna,
\q2 nua tamotamogoruna, dobidobina, Eaubada e, taba nige u isuewaei.
\b
\q1 
\v 18 Em nualolo debana eai Siona bena oa u helolo;
\q2 Ierusalema ganana abo u hetorouioidi,
\q1 
\v 19 abotai aitalasam duduraidi debadi eai abo u nuawoiwoina,
\q2 aitalasam gabugabudi eo aitalasam gabugabudi maudoidi;
\q1 bulumakau abo se heaitalasamdi em aitalasam hatahatana eai.
\c 57
\s1 Hesaguhai tau hebaaea nimadi eai uurana
\q1 
\v 1 Eaubada e, u nuatoatoaegu, u nuatoatoaegu ta,
\q2 paana oa arim eai earuagu abo i ailogulogu;
\q2 mabem logulogudi eai abo ea ailogulogu,
\q2 i lau e sabom i lau’o.
\q1 
\v 2 Ea eogalau Eaubada Saesae Aririna arinai,
\q2 Eaubada arinai ia wa ena nuatu enagu i hemamohoiei.
\q1 
\v 3 Galewa eai abasaguigu ia abo i hetamariama eo abo i hemaurigu,
\q2 aidobu bena se ututawaigu abo i hetaumaeamaeadi.
\q1 Eaubada ena gadosisi miatahitahina, eo ena riba hemamohoiena abo i hetamarilaei!
\b
\q1 
\v 4 Liona boeadi eai ea laulauota,
\q2 isi se lelehi ariri bena tatao se aidi,
\q1 moadi ede alahia eo pidu,
\q2 memenadi alahia matamatadi ede.
\b
\q1 
\v 5 Eaubada e, oa abo u sae ariariri galewa ewana eai!
\q2 Em namanamari tanoubu bena i hemonau!
\b
\q1 
\v 6 Hiana se gala nonohai aegu adi,
\q2 ea nuaporohe ariri.
\q1 Duha se sara eau egu dobila eai
\q2 na isi, isibom se beudobi alona eai.
\b
\q1 
\v 7 Eaubada e, nuagu i otaesegai,
\q2 nuagu i ota esegai.
\q1 Abo ea wana eo salamo aridi eai abo ea hedebasaei!
\q2 
\v 8 Earuagu, u enotoro!
\q1 Baubau eo huelele, au enotoro!
\q2 Mara i uiari abo ea hanoi!
\q1 
\v 9 Guiau e, abo ea lautoiem, etene boeadi eai:
\q2 aihelahuim abo ea wanaidi hari eanua tataodi boeadi eai.
\q1 
\v 10 Paana em gadosisi miatahitahina ie sae doha galewa,
\q2 am ao otaotahaina ie sae doha eada.
\q1 
\v 11 Eaubada e, oa abo u sae ariariri galewa ewana eai!
\q2 Em namanamari tanoubu bena i hemonau!
\c 62
\s1 Eda abahomo esega mo ede Eaubada
\q1 
\v 1 Eaubada iabom earuagu i laubagibagiei ma monomonougu;
\q2 ia arinai egu mauri i laolaoma.
\q1 
\v 2 Ia iabom egu we’utau eo egu abamauri ede,
\q2 egu numa adiadidirina; taba nige se hemoiugu, nige ariariri.
\b
\q1 
\v 3 I lau e aitea huia abo tau au aipatei au oiheguri,
\q2 omi gamagarimiu e,
\q1 bena ia doha bilibili eoueouna, e gana beruberuna?
\q1 
\v 4 Edi nuatu esega mo ede bena ena abatoro eai se oiheguri.
\q2 Ao borabora se henua aririei.
\q1 Awadi eai se ribalolo,
\q2 na nuaboeadi eai se riba‐hemate.
\b
\q1 
\v 5 Eaubada iabom earuagu i laubagibagiei ma monomonougu;
\q2 egu sunuma ede ia arinai.
\q1 
\v 6 Ia iabom egu we’utau eo egu abamauri ede,
\q2 egu numa adiadidirina; taba nige nuagu se heberuberu.
\q1 
\v 7 Egu abamauri eo egu abadudurai ede Eaubada iabom arinai,
\q2 ia egu we’utau adiadidirina eo egu abahomo ede.
\b
\q1 
\v 8 Egu dodogayao e, huia gamagamagari ia bena au sunumaei,
\q2 nuamiu au hegoigabaedi ia matana eai.
\q2 Eaubada ia eda aba ailogulogu ede.
\b
\q1 
\v 9 Tatao dobidobidi isi doha eahua mo,
\q2 tatao saesaedi isi doha ginauri borabora;
\q1 taba se nonoidi se mamara,
\q2 mamohoi se mamara ariri abotai eahua.
\q1 
\v 10 Tabu baaea maisana u nuatui,
\q2 eo tabu em sunuma u torelaei aiyahari arinai;
\q2 taba em gogo i helai, tabu nuam i lauei.
\q1 
\v 11 Ma’esega Eaubada ie riba,
\q2 malabui ina ta ea ataiei:
\q1 iaede ina, gigibori Eaubada iabom enana,
\q2 
\v 12 gadosisi miatahitahina ede oabom arim eai, Guiau e,
\q1 eo tau ena paipaisoa arinai
\q2 abo oa u hemaisa.
\c 63
\s1 Ena tau earuana i gadomagu Eaubada abo i hegadobiga
\q1 
\v 1 Eaubada e, oa egu Eaubada ede, eau ea eo’o’eo’oim,
\q2 earuagu i gadomaguem;
\q2 taugu maudoina i gadohiem,
\q2 gonogonoana doha oea esau nige goilana, i pitari ariri eo i amnabaaea.
\q1 
\v 2 Doha em abamia tabuna eai ea itamo,
\q2 em gigibori eo em namanamari ea itadio.
\q1 
\v 3 Paana oa em gadosisi miatahitahina i sae ariri abotai mauri,
\q2 eau sopagu eai abo ea hedebasaem.
\q1 
\v 4 Egu mauri asubenana lohana eai abo ea ribatausaei,
\q2 eau nimagu abo ea lauisinidi, eo oa esam eai abo ea aiaiboda.
\b
\q1 
\v 5 Earuagu i mata’asi, gonogonoana doha siada aroarodi eo momona ea aiaini,
\q2 eo awagu i hedebasaem ma kodegu, sopagu eai,
\q1 
\v 6 huiana eai wa egu abaeno eai ea nuanuatuim,
\q2 maiona silasilawana eai ea nuanuatuim,
\q1 
\v 7 paana oa agu sagu ede,
\q2 eo oa mabem loguloguna eai abo ea wana ma nuawoiwoinagu.
\q1 
\v 8 Earuagu i patudidini arim eai,
\q2 oa nima tutum i abiisinigu.
\b
\q1 
\v 9 Na aidobu se aipate egu mauri se hebaaea
\q2 abo se dobi tano boeana eai;
\q1 
\v 10 abo se moselaedi elepa gigiborina eai,
\q2 abo se hemala suisui nuura adi aiai.
\q1 
\v 11 na wasawasa abo Eaubada arinai i nuawoiwoina,
\q2 isi gamagaridi ia debana eai se riba aigora, abo se kode lamposi;
\q2 na tatao borabora awadi abo se gududi.
\c 65
\s1 Eaubada se hedebasaei oea masurina lolona debana eai
\q1 
\v 1 Eaubada e, i lolo oa se hedebasaem Siona eai,
\q2 oa arim eai hinage abo riba aigora se hemamohoiedi,
\q2 
\v 2 Oa uura tau ataiena!
\q1 Oa arim eai tatao gamagaridi abo se laoma,
\q2 
\v 3 baaea giruna debana eai.
\q1 Ena ema awayagara se saetawatawaimai,
\q2 oa u ribagigiridi.
\q1 
\v 4 Aisega tau oa u abihineri, u woeaieama
\q2 em numa tabuna gegesina eai, ia i kode ariri!
\q1 Em abamia ena lolo i hegonoahimai,
\q2 oa em dubu tabuna!
\b
\q1 
\v 5 Laulau matamatausidi aridi eai oa u lebohaimai
\q2 ema abamauri Eaubadana e,
\q1 tanoubu sigasigadi gamagaridi edi abasunuma ede oa arim eai,
\q2 gabogabo sigasigadi hinage.
\q1 
\v 6 Oa em adidiri eai oea tupidi u hetubudi,
\q2 oa gigibori ue lui;
\q1 
\v 7 gabogabo ena dagugu u hemonou,
\q2 butubutu dagudaguguna;
\q2 tatao hinage edi hetalagegagega;
\q1 
\v 8 arinai isi tanoubu sigasigadi eai se mia
\q2 em heiheinoi ta se matausiedi;
\q1 mahana ena aba dalasae eanuadi eo mahana ena aba dui eanuadi
\q2 se wowo ma kodedi.
\b
\q1 
\v 9 Tanoubu u nuatui eo nabu u hetaru,
\q2 eo u hemasuri aririei;
\q1 Eaubada ena saga goila eai i monau,
\q2 edi tuma u mosedi,
\q1 paana oa u abinonohayao wa:
\q1 
\v 10 Oea se giari nonohaidi adi goila u mosedi,
\q2 padipadi u hesabusabu,
\q1 nabu arinai tano u hebiga,
\q2 eo ginauri ini’inidi u helolodi.
\q1 
\v 11 Borimai huiana eai oea u hemasuri lolo aririei,
\q2 em abalau gamagaridi eai masuri i lai ariri.
\q1 
\v 12 Barabara eai hinage nabu ie taru,
\q2 oea tupidi se kode lamposi.
\b
\q1 
\v 13 Oea abaaibai hinage mamoe eawoidi se hemonau,
\q2 gonu hinage tuma arinai se hepasauioidi,
\q2 se wowo eo se wanagogo kode debana eai!
\c 67
\s1 Eanua udoi udoi taumiaidi se lauhesomdi bena Eaubada se hedebasaei
\q1 
\v 1 Eaubada taba i ainauiaida eo i heloloda
\q2 eo matana marana i hesina potada eai —
\q1 
\v 2 oa em dobila tanoubu eai ta bena se ata,
\q2 eo em abihemauri gigiborina eanua gamagaridi taumiaidi boeadi eai.
\q1 
\v 3 Eaubada e, tanoubu tataodi taba oa se hedebasaem,
\q2 tanoubu tataodi gamagaridi taba se hedebasaem!
\b
\q1 
\v 4 Eanua udoi udoi taumiaidi taba se kode, se wana ma kodedi,
\q2 paana tanoubu tataodi duduraina eai oa u heduduraidi,
\q2 tanoubu eanuadi udoi udoi taumiaidi oa abo u woeaidi.
\b
\q1 
\v 5 Eaubada e, tanoubu tataodi taba oa se hedebasaem,
\q2 tanoubu tataodi gamagaridi taba se hedebasaem!
\b
\q1 
\v 6 Tano aiaina i tubuo;
\q2 Eaubada, ita eda Eaubada, i helolodao.
\q1 
\v 7 Eaubada i helolodao;
\q2 tanoubu sigana gamagamagaridi ia abo se heasisiei!
\c 71
\s1 Tautaubada ena Uura
\q1 
\v 1 GUIAU e, abo ea ailogulogu oa arim eai;
\q2 taba nige se hetaumaeamaeagu, nige ariariri!
\q1 
\v 2 Em laulau dudurai debana eai bena u saguhaigu eo u hemaurigu;
\q2 beam eai u ataiegu, eo u hemaurigu!
\q1 
\v 3 Oa bena egu we’utau aba ailoguloguna,
\q2 egu numa adiadidirina, egu aba mauri,
\q2 paana oa egu we’utau ede, eo egu aba mia adiadidirina.
\b
\q1 
\v 4 Egu Eaubada e, u lebohaigu tau baaea nimana eai,
\q2 tau laulau gewagewa, eo tau manamanabara nimadi eai.
\q1 
\v 5 Paana ede oa, Guiau e, oa egu sunuma ede,
\q2 egu aba awamamohoi, ma hewarigu i laoma e wauta.
\q1 
\v 6 Ea duihasari oa arim eai egu huia labasi eai i laoma e ina wauta,
\q2 sinagu bogana eai oa u abihaigu.
\q1 Egu hedebasae ede oa enam huia gamagamagari.
\b
\q1 
\v 7 Ea hemala tatao edi aba no’o;
\q2 na oa egu aba homo adiadidirina ede.
\q1 
\v 8 Aihelahuim awagu i hemonau huia gamagari,
\q2 eo em namanamari hinage asubena lohaloha.
\q1 
\v 9 Egu huia tautaubada eai tabu u abigabaegu,
\q2 ena egu adidiri i dobidobi tabu u nuagabaegu.
\q1 
\v 10 Paana agu waiunu se ribaribaegu,
\q2 isi se itasipoigu, se oiribagogo,
\q1 
\v 11 si ene, “Eaubada tau ta i lausuaraei,
\q2 ta henauwatai ta toai,
\q2 paana nige doga esau bena i saguhai.”
\b
\q1 
\v 12 Eaubada e, tabu u lausuara aririegu;
\q2 egu Eaubada e, u heurama u saguigu!
\q1 
\v 13 Isi tau hegirugu bena se hetaumaeamaeadi eo se hetauyamuidi;
\q2 isuewa eo taumaeamaea bena i buburidi,
\q2 isi se aipate se hebaaeagu wa.
\q1 
\v 14 Na eau egu sunuma abo i otahai huia gamagamagari,
\q2 oa hinage abo ea hedebasae aririem.
\q1 
\v 15 Awagu eai em abidudurai abo ea ribaribaei,
\q2 em abihemauri laulaudi asubena gamagamagari,
\q2 paana se gamagari ariri, nige gonoana ea hasiridi.
\b
\q1 
\v 16 Guiau EAUBADA ena paipaisoa gigigigiboridi abo ea wasawasaedi;
\q2 oa oabom em laulau dudurai abo ea hedebasaei.
\b
\q1 
\v 17 Eaubada e, egu hewari huiana eai oa u heaheatagu,
\q2 i laoma e wauta em laulau gigigigiboridi ea wasaduaiedi.
\q1 
\v 18 Arinai egu huia tautaubada eo egu huia uruhou eai,
\q2 Eaubada e, tabu u abigabaegu,
\q1 i lau e em adidiri ea wasaduaiei
\q2 isimurita gamagari aridi eai.
\q1 Em gigibori
\v 19 eo em laulau dudurai, Eaubada e,
\q2 se sae e galewa ewana eai.
\q1 Oa em paipaisoa se lai ariri,
\q2 Eaubada e, eai doha oa?
\q1 
\v 20 Egu lauita lailaidi u hegamagari aririedi,
\q2 na oa abo u hemauriuioigu;
\q1 tano boeana eai
\q2 abo u abiisiniuioigu.
\q1 
\v 21 Heasisi enagu abo u helaiama,
\q2 eo nuagu abo u hebigauioi.
\b
\q1 
\v 22 Baubau arinai abo ea hedebasaem
\q2 em laulau lolodi debadi eai, egu Eaubada e;
\q1 baubau eai abo ea aihelahuim ma wanagu,
\q2 Isaraela edi Tabuna e.
\q1 
\v 23 Ma kodegu abo sopagu se wowo,
\q2 oa aihelahuim abo ea wanaidi;
\q2 earuagu hinage, ia ede oa u unehai wa.
\q1 
\v 24 Em haisagusagu duduraina memenagu abo i ribaribaei
\q2 asubena lohaloha,
\q1 paana ede isi se eo’oigu bena se heamamnagu wa,
\q2 isi se hetaumaeamaeadi eo se isugaraedi.
\c 73
\s1 Tatao baabaaeadi adi sigasiga
\q1 
\v 1 Mamohoi Eaubada ena abi se lolo tatao laulau dudurai aridi eai,
\q2 tau nua’aa’aa aridi eai hinage.
\q1 
\v 2 Na eau mo begana abo aegu se alabesibesi,
\q2 aegu hanahanau abo se utusagigi.
\q1 
\v 3 Paana ede tau nuasaesae ea aiaromagigiriedi,
\q2 huiana wa tau laulau gewagewa ena gogo ea i’ita.
\b
\q1 
\v 4 Paana isi nige begana amamna se hearo;
\q2 se amna lolo mo eo se tubu lolo.
\q1 
\v 5 Isi nige se ai’iwala doha tatao headi;
\q2 pidipidiri nige se hearo doha tatao headi.
\q1 
\v 6 Arinai nuasaesae i hemala adi gadogado;
\q2 manamanabara i buburidi doha lulu.
\q1 
\v 7 Se tubu lolo ariri arinai matadi se pou,
\q2 nuatu eauyaule nuadi se hemonau boriboriridi.
\q1 
\v 8 Se riba alaliuliuwa, eo se ribakarapi;
\q2 tatao se riba hematausidi ma nuasaesaedi.
\q1 
\v 9 Awadi eai galewa se hewaiunuei,
\q2 eo se ribahetausaeuioidi tanoubu boeana eai.
\b
\q1 
\v 10 Arinai tatao se sinibui eo se ribatausaedi;
\q2 edi ponori hinage nige se italobaidi.
\q1 
\v 11 Eo si ene, “Mamohoi, Eaubada i nuatui?
\q2 Saesae Aririna abina ie ata, e nige’e?”
\q1 
\v 12 Mamohoi, tatao baabaaeadi ede ina;
\q2 huia gamagari taba nige saha se deha, edi gogo mo se helahelai.
\q1 
\v 13 Nuagu ea hea’a gaibui,
\q2 eo nimagu ea deuridi gaibui laulau dudurai boeana eai:
\q1 
\v 14 Paana asubena lohaloha eai pidipidiri mo ea hearodi,
\q2 eo maratomtom gamagari maisa mo ea abidi.
\b
\q1 
\v 15 Taba ea ene, “Doha ina abo ea riba”,
\q2 am isimurita abo ea woeaponoridi.
\q1 
\v 16 Na ena ea aipate ina ginauri ta ea nuatulobai,
\q2 i heamnabaaea aririegu,
\q1 
\v 17 i lau e ea awasaei Eaubada ena aba mia tabuna eai;
\q2 abotai adi sigana ea italobai.
\q1 
\v 18 Mamohoi tupo sagisagigi eai oa u hetorodi;
\q2 abo u heguridi mate arinai.
\q1 
\v 19 Maesega se hebaaea heohidi,
\q2 matausi lailai arinai se ueagabaedi!
\q1 
\v 20 Guiau e, isi doha enosuai mo, ena u enotoro,
\q2 enosuai wa u isuewaei, ana ao doha tautau gaibu mo.
\b
\q1 
\v 21 Huiana eai wa ea nuakarapi,
\q2 eo nuagu i amamna,
\q1 
\v 22 ea eauyaule eo ea supusupu,
\q2 agu ao doha suisui manamanabarana oa matam eai.
\q1 
\v 23 Taiede huia gamagari eau gegesim eai;
\q2 nimatutugu u abididini.
\q1 
\v 24 Em nuatu sibasibana arinai u woeaigu,
\q2 eo maraitom asubena abo u heawasaegu em namanamari eai.
\q1 
\v 25 Eai abo enagu galewa eai na oabom mo?
\q2 Tanoubu eai hinage nige saha ea henua na oabom mo.
\q1 
\v 26 Bulumagu eo nuagu se beruberu,
\q2 na Eaubada nuagu ena aba adidiri eo egu gogo ede i lau e nige nosina.
\b
\q1 
\v 27 Hedeomi, tatao ena se miasuaraem abo se mate,
\q2 tatao wa se boraboraim abo se mate.
\q1 
\v 28 Na eau ea amna lolo ena ea hanahanau Eaubada gegesina eai;
\q2 Guiau EAUBADA ea abiyao egu aba ailogulogu,
\q2 abo em paipaisoa gamagaridi ea wasaduaiedi.
\c 80
\s1 Isaraela basileiana hetorouioina uurana
\q1 
\v 1 Isaraela taumiataunina e, u ataatai,
\q2 oa Iosepa u woeai doha mamoe eawoina!
\q1 Oa ue bawa serubim potadi eai, maram u hesinalaei
\q2 
\v 2 Eparanaime, Beniamina eo Manase eai!
\q1 Em gigibori u healabalebalelem
\q2 eo u laoma u hemaurimai!
\b
\q1 
\v 3 Eaubada e, u hetorouioimai;
\q2 matam u hesina potamai eai arinai abo ai mauri!
\b
\q1 
\v 4 Tauiala moutuana edi GUIAU Eaubadana e,
\q2 i lau e aitea huia abo u ouyalayala em tataoyao edi uura aridi eai?
\q1 
\v 5 Matasulu mo u mosei adi aiai,
\q2 matasulu hinage u henom aririedi.
\q1 
\v 6 U hetoromai helemai taumia edi aba alaliuliuwa;
\q2 ema waiunu hinage isibom se marumaruhiemai.
\b
\q1 
\v 7 Tauiala moutuana Eaubadana e, u hetorouioimai;
\q2 matam u hesina potamai eai arinai abo ai mauri!
\q1 
\v 8 Aigupito eai vine esau oa u abiyama;
\q2 eanua tataodi u aihenauidi, eo vine wa u umai.
\q1 
\v 9 Tano enana u hea’a,
\q2 lamna ie dobi, eo eanua maudoina i hemonau.
\q1 
\v 10 Loguloguna oea tupidi i heoputawaidi,
\q2 eo maruwai lailaidi lagadi aridi eai hinage;
\q1 
\v 11 lagadi i loloidi gabogabo eai,
\q2 ini’inidi hinage se tulaedi Saga eai.
\q1 
\v 12 Paana saha ganana u oiheguri,
\q2 to taubaeawa gamagaridi uauana se losi?
\q1 
\v 13 Sarai nuura i hebaaea
\q2 eo oea suisuidi gamagaridi arinai se aibai.
\b
\q1 
\v 14 Tauiala moutuana Eaubadana e, u sinibuiuioma!
\q2 Galewa eai u itadobima, eo u ita;
\q1 vine ta oa u itawatai,
\q2 
\v 15 lie wa oa nimatutum eai u umai wa.
\q1 
\v 16 Se gabuyao oeagi alaalasina arinai, se oiheguriyao;
\q2 i lolo am ao u hebaaea aridi eai, abo arinai se mate!
\q1 
\v 17 Na bena oa nimam u torelaei nimatutum tauna wa potana eai;
\q2 tau natuna oa u headidiri bena oabom enam!
\q1 
\v 18 Abotai taba nige ai sinibui ai lausuaraem;
\q2 Mauri u leama, abo oa esam eai ai aiaiboda!
\b
\q1 
\v 19 Bena u hetorouioimai, tauiala moutuana edi GUIAU Eaubadana e!
\q2 matam u hesina potamai eai arinai abo ai mauri!
\c 84
\s1 Eaubada ena numa gadohina
\q1 
\v 1 Oa em abamia, i lolo ariariri
\q2 tauiala moutuana GUIAUNA e!
\q1 
\v 2 Hedeomi, earuagu i gadohi ariri eo i amna baaea
\q2 GUIAU ena abamia bena i lage arinai;
\q1 nuagu eo bulumagu se wana ma kodedi
\q2 Eaubada maumaurina arinai.
\q1 
\v 3 Manu gagiridi edi abamia se lobaidi,
\q2 manu hinage se abinoi,
\q1 bena nanatudiyao edi abaota,
\q2 oa em aitalasam hatahatana, tauiala moutuana GUIAUNA e,
\q2 egu Wasawasa eo egu Eaubada.
\q1 
\v 4 Aidimo em numa eai se mia wa nuadi se kode,
\q2 huia gamagari em aihelahui se wanaidi!
\b
\q1 
\v 5 Tatao wa edi adidiri se abi oa arim eai abo se kode ariri,
\q2 isi nuadi eai Siona ena dobila saesaedi!
\q1 
\v 6 Baka gonuna se luhudadai
\q2 bena abo bunubunuasi dimona se saradi;
\q1 nabu ena huia sora, na ie taru abo ipu i hemonaudi.
\q1 
\v 7 Se adidiri, i lau e se adidiri ariri;
\q2 hari eaubada edi Eaubada abo i taumasaraha Siona eai.
\b
\q1 
\v 8 Tauiala moutuana edi GUIAU Eaubadana e, egu uura u ataiei,
\q2 beam bena i tasoe, Iakobo ena Eaubada e!
\q1 
\v 9 Eaubada e, ema guiau wasawasa bena u italau arinai;
\q2 bena u italau em heyausi tauna ana ao arinai!
\b
\q1 
\v 10 Taba asubena esega mo em dubu eai ea mia,
\q2 meta i loro ariri, abotai asubena tausani hari tupo eai.
\b
\q1 Ea henua ariri bena eau dobila tauitawataina mo egu Eaubada ena numa eai,
\q2 abotai tau laulau gewagewa ena numalulu eai ea miamia.
\q1 
\v 11 Paana GUIAU Eaubada ia mahana eo opea ede,
\q2 nualolo eo heasisi i mosei.
\q1 Nige ginauri lolona esau GUIAU abo i nuahi,
\q2 isi se mia dudurai aridi eai.
\q1 
\v 12 Tauiala moutuana GUIAUNA e,
\q2 aitea tau i sunusunumaem ia tau kode mamohoina ede!
\c 85
\s1 Eaubada Isaraela nuatoatoaena uurana
\q1 
\v 1 GUIAU, oa em eanua u abiloloei,
\q2 Iakobo ena gogo u moseuioi arinai.
\q1 
\v 2 Em tataoyao adi giru u ribagigiridio;
\q2 edi manamanabara gamagaridi u bubulitawaidio.
\b
\q1 
\v 3 Em ouyalayala u helautom;
\q2 em nuayalayala gigigigiborina u torehesuara.
\b
\q1 
\v 4 Ema mauri Eaubadana e, bena u helolouioimai,
\q2 em nuabaaea arimai eai hinage bena u torehesuara!
\q1 
\v 5 Abo u ouyalayalaemai i lau e nige nosina?
\q2 Em ouyalayala abo u tubei i lau e isi gamagari aridi eai?
\q1 
\v 6 Taba nige u hemauriuioimai,
\q2 bena em tataoyao se kode arim eai?
\q1 
\v 7 Em gadosisi miamiahaina bena u hemasaraha arimai eai,
\q2 oe em mauri hinage bena abo u leama.
\b
\q1 
\v 8 Hage ea ata’atai Eaubada GUIAU ena riba arinai,
\q2 paana abo i ribabigabiga ena tataoyao aridi eai,
\q2 ena tau miatahitahi tataodi aridi eai, isi wa se nuabui ia arinai.
\q1 
\v 9 Mamohoi ena abihemauri isi tau matausiena gamagaridi gegesidi eai,
\q2 bena namanamari abo i otahai ita eda eanua eai.
\b
\q1 
\v 10 Gadosisi miatahitahina eo ao mamohoina se haihailobai,
\q2 laulau dudurai eo loni se haitalagadoi.
\q1 
\v 11 Ao mamohoi tano eai abo i inisae,
\q2 laulau dudurai galewa eai abo i itadobi.
\q1 
\v 12 Mamohoi saha eo saha i lolo GUIAU abo i leama,
\q2 abotai eda tano aiaina abo i helai.
\q1 
\v 13 Laulau dudurai ia abo se edabagunaei,
\q2 eo ena dobila abo se sepa nonohai.
\c 90
\s1 Eaubada ena mia i lau e huia nige nosina, na tau ena huia ku’uku’una
\q1 
\v 1 Guiau e, ema aba miatahitahi ede oabom mo,
\q2 isidi gamagamagari eai.
\q1 
\v 2 Oea tupidi sora nige se tubu,
\q2 tano eo tanoubu sora nige u hetubudi meta huiana ne i laoma e wauta,
\q2 eo i lau e nige nosina oabom Eaubada.
\b
\q1 
\v 3 Oa tatao u hebuidi se hemala tanouio;
\q2 u ene, “Tatao nanatudiyao gamagarimiu e, au uio!”
\q1 
\v 4 Paana borimai tausani oa matam eai i lao’o doha lahi,
\q2 hinage doha maiona esega silawana.
\b
\q1 
\v 5 Tatao u ueahaidi; isi doha enosuai mo,
\q2 doha lei maratomtom eai i ini harihariu:
\q1 
\v 6 maratomtom eai ie ini eo ie tubu,
\q2 maimailahi eai i wowoea eo ie mate.
\b
\q1 
\v 7 Paana em ouyalayala eai ai tauyamui;
\q2 em nuabaaea i wuitawaimai.
\q1 
\v 8 Ema laulau gewagewadi wa oa matam eai u hemasarahadi,
\q2 ema lausapuri eamuyamuidi oa matam marana eai u hemasarahadio.
\q1 
\v 9 Paana em nuabaaea eai ema asubena gamagaridi se laoma se lau,
\q2 ema mauri borimaidi se lao’o doha eahua mo.
\q1 
\v 10 Ema mauri borimaidi ai hasiridi tatao haiona se mate saudoudoi,
\q2 e ibai adidirimai eai taba tatao hasi se mate ai lobaidi,
\q1 na ma amna baaeamai eo ma ai’iwalamai mo,
\q2 nige baeaona se ohi na ai loi ai lau hari teha eai.
\b
\q1 
\v 11 Em ouyalayala gigiborina eai abina ie ata,
\q2 eo em ouyalayala eai i matausiei?
\q1 
\v 12 Arinai ema asubena hasirina u heatamai
\q2 abo nuasonoga ai lobai.
\q1 
\v 13 GUIAU e, u uioma! Tabu u boneawa!
\q2 Em heaheari tataodi u nuatoataedi!
\q1 
\v 14 Maratomtom huiadi eai nuamai u hebigadi em gadosisi miatahitahina arinai,
\q2 abo ema asubena gamagaridi eai ai nualolo eo ai kode.
\q1 
\v 15 Asubena gamagamagari u heamnabaaeamai wa,
\q2 eo borimai gamagamagari hinage amamna aie ita wa
\q2 gonogonoana abo hinage u hekodemai.
\q1 
\v 16 Bena am paisoa i masaraha em heaheari tataodi aridi eai;
\q2 em gigibori namanamarina nanatumyao aridi eai.
\q1 
\v 17 GUIAU ema Eaubada bena em nualolo i ota ai potamai eai,
\q2 ema nimapaisoa hinage bena u helolodi,
\q2 hedeomi, ema nimapaisoa oa bena u helolodi.
\c 91
\s1 Miatahitahi Saesae Aririna loguloguna eai
\q1 
\v 1 Aitea tau ia Saesae‐Aririna loguloguna eai i miahai,
\q2 ia Gigibori‐Aririna loguloguna eai i miatahitahi,
\q1 
\v 2 ia abo i ribalau GUIAU arinai i ene, “Egu aba dago lolona
\q2 eo egu aba mia adiadidirina,
\q2 egu Eaubada, egu sunuma ea tore esegai arim eai.”
\q1 
\v 3 Paana ia manu siposipona arinai abo i saguhaim,
\q2 asiebo baaea eai hinage;
\q1 
\v 4 goina eai abo i buburim,
\q2 eo mabena ubuna eai em aba ailogulogu abo u lobai;
\q2 ena riba hemamohoiena opea gagirina eo opea lailaina ede.
\q1 
\v 5 Maiona hematausina ginaurina taba nige u matausiei,
\q2 asubena eai pidu se tu hinage taba nige’e,
\q1 
\v 6 baaea lailai masigiri eai ie sae ie dobi taba nige u matausiei,
\q2 asubenalai eai sabom i hebaaea hinage taba nige’e.
\b
\q1 
\v 7 Tausani gegesim eai abo se guri,
\q2 tausani saudoudoi nimatutum eai hinage,
\q2 na taba nige iwala wa i laoa oa gegesim eai.
\q1 
\v 8 Matam eai mo abo u aiaiewa
\q2 laulau gewagewa tataodi edi maisa abo u ita.
\q1 
\v 9 Paana GUIAU ue abi em aba dago lolona,
\q2 Saesae Aririna ia em abahomo
\q1 
\v 10 taba nige baaea esau i abi’itam,
\q2 nige iwala saha i laoma oa em numalulu gegesina eai.
\b
\q1 
\v 11 Paana ia ena aneru abo i hetorodi se itawataim,
\q2 em dobila gamagaridi eai abo se ganaganaim.
\q1 
\v 12 Isi nimadi eai abo se abi’isinim,
\q2 ata aem u hetupanei we’u eai.
\q1 
\v 13 Liona eo mota abo u ututawaidi,
\q2 ae aroarom eai liona natuna eo mota abo u ututawaidi.
\b
\q1 
\v 14 Paana ia gadosisi debana eai i patulaoma, eau abo ea lebohai;
\q2 abo ea ganaganai, paana esagu abina ie ata.
\b
\q1 
\v 15 Ena i eogalaoma, abo ea heuio;
\q2 huia baaea boeana eai eau abo gegesina eai,
\q2 eau abo ea lebohai, eo abo ea heasisiei.
\q1 
\v 16 Ena mauri abo ea heloha, eo abo ea henuabiga,
\q2 egu abihemauri hinage eau abo ea heita.
\c 93
\s1 Wasawasa GUIAUNA
\q1 
\v 1 GUIAU ia wasawasa ede; ia ana tepo wasawasana eai se helui;
\q2 GUIAU se helui, adidirina ie lio.
\q1 Mamohoi tanoubu i totoro adidiri; taba nige se hemoimoiu.
\q1 
\v 2 Em terona mumuga eai se hetoro;
\q2 oa mumuga ariri eai u mia nige nosina.
\b
\q1 
\v 3 GUIAU e, dibori utu’utu se dagudagugu,
\q2 dibori utu’utu arinadi se lauisinidi,
\q2 dibori utu’utu balamumudi se helaidi.
\q1 
\v 4 GUIAU ini puripurina eai i gigibori ariri, ena gigibori
\q2 dibori utu’utudi gamagaridi dagugudi i saetawatawaidi,
\q2 gabogabo bagodudi edi gigibori i saetawatawaidi!
\q1 
\v 5 Ena lauhesom ribadi isi ede mamohoi ariri;
\q2 hetabuena i patulau em numa tabuna arinai,
\q2 GUIAU e, i lau e nige nosina.
\c 95
\s1 Aihelahui eo Hedebasae Wanana
\q1 
\v 1 Ehei, au laoma ta wana GUIAU arinai,
\q2 ta wowo ma kodeda eda mauri we’utauna arinai!
\q1 
\v 2 Ta laoma ia matana eai ma lautoida,
\q2 ta wowo ma kodeda ia arinai, ta wana ia ta aihelahui!
\q1 
\v 3 Paana ede GUIAU ia Eaubada lailaina,
\q2 ia wasawasa lailai didigana, eaubada gamagaridi i saetawatawaidi.
\q1 
\v 4 Tanoubu ubu aririna ia nimana eai,
\q2 oea tupidi saesaedi hinage ia enanayao ede;
\q1 
\v 5 Gabogabo ede ia enana, paana ia i hetubu,
\q2 ia nimana eai tano pitapitarina i ginauri.
\b
\q1 
\v 6 Ehei, au laoma ta aihelahui eo ta tabaohui,
\q2 ta turibono GUIAU matana eai, ia Tauhetubuda ede!
\q1 
\v 7 Paana ia eda Eaubada,
\q2 ita ena ganaalo tataoda
\q2 eo ia nimana mamoedi.
\b
\q1 I lolo wauta arinana au ataiei!
\q1 
\v 8 Tabu nuamiu au heoiuradi doha Meriba eai,
\q2 doha asubena wa Masa eai, barabara eai,
\q1 
\v 9 huiana wa tamamiuyao se lauitagu,
\b
\q2 eo se nohoigu, na agu paisoa se itayao.
\q1 
\v 10 Borimai tatao labui se mate isi ne ea hewaiunuedi,
\q2 eo ea ene, “Tatao ta nuadi eai se ponori ariri,
\q2 eo egu laulau nige se nuatuidi.”
\q1 
\v 11 Arinai ma ouyalayalagu ea riba aigora,
\q2 bena taba nige se awasaei eau egu abaaiyawasi eai.
\c 96
\s1 Aihelahui Wanana
\q1 
\v 1 Omi wana harihariuna au wanai GUIAU arinai!
\q2 Tanoubu maudoina e, GUIAU arinai au wana!
\q1 
\v 2 Au wana GUIAU arinai, ia esana au ribatausaei;
\q2 ena abihemauri au hemasaraha, asubena to asubena.
\q1 
\v 3 Tanoubu tataodi gamagaridi matadi eai ena namanamari au ribahemasaraha,
\q2 ena heiheinoi gigiboridi tatao gamagaridi matadi eai!
\q1 
\v 4 Paana GUIAU i lai ariri, ia aihelahuina hinage i lai ariri;
\q2 eaubada udoi udoi i saetawatawaidi.
\q1 
\v 5 Paana basileia udoi udoi edi eaubada ede oitau;
\q2 na GUIAU ia galewa tauginaurina.
\q1 
\v 6 Heasisi eo wasawasana ia matana eai,
\q2 adidirina eo ao lolona ia ena abamia tabuna eai.
\b
\q1 
\v 7 GUIAU enana au mosei, omi boga udoi udoi tataomiu e,
\q2 GUIAU arinai namanamarina eo adidirina au mosei!
\q1 
\v 8 Namanamarina GUIAU esana enana au mosei;
\q2 ainauia au leama au awasaema ena dubu alona eai.
\q1 
\v 9 GUIAU au tabaohui, lulu tabudi au luidi,
\q2 ia matana eai au tabutabubu, tanoubu tataomiu gamagarimiu e!
\b
\q1 
\v 10 Eanua gamagaridi taumiaidi au heribadi au ene, “GUIAU ia wasawasa ede!
\q2 Mamohoi tanoubu se hetoro, taba nige i moimoiu;
\q2 tanoubu tataodi ia i heduduraidi ma duduraina.”
\q1 
\v 11 Galewa taba i kode, tanoubu taba i wowo,
\q2 gabogabo taba i dagugu, eo taumiaina,
\q1 
\v 12 oea taba i kode, eo taumiaina hinage;
\q2 abotai nuura oeagidi abo se wana ma kodedi,
\q1 
\v 13 GUIAU matana eai, paana ia ede i laoma,
\q2 paana ia ede i laoma tanoubu
\q2 i hedudurai ma laulau duduraina,
\q2 eo tatao wa ma ao mamohoina.
\c 100
\s1 Tabu lautoi ta nuahuiei
\q1 
\v 1 Tanoubu tataomiu gamagarimiu e, kode daguguna au ginauri GUIAU arinai!
\q1 
\v 2 GUIAU au heayaiyei ma kodekodemiu,
\q2 au laoma ia matana eai ma wanamiu!
\b
\q1 
\v 3 Omi abo au nuatui, GUIAU ia Eaubada.
\q2 Ia i ginaurida, ita ia enana;
\q2 ita ia ena tataoyao, eo ita ia ena heaheai mamoena.
\q1 
\v 4 Au lulau ena dobila eai ma lautoimiu,
\q2 au lulau ena dubu alona eai ma hedebasaemiu!
\q2 Ia au lautoiei, ia esana au ribatausaei!
\b
\q1 
\v 5 Paana GUIAU i lolo,
\q2 ena gadosisi miatahitahina i ota esegai i lau e nige nosina,
\q2 eo ena riba hemamohoiena i lau e hari isi to hari isi.
\c 103
\s1 Hedebasae GUIAU arinai ena ainauia debadi eai
\q1 
\v 1 Earuagu e, GUIAU u ribatausaei;
\q2 nuagu maudoina e, ia esana tabuna u ribatausaei.
\q1 
\v 2 Earuagu e, GUIAU u ribatausaei,
\q2 eo ena ainauia gamagaridi tabu u nuahuiedi:
\q1 
\v 3 ia em laulau gewagewadi gamagaridi ie ribagigiridi,
\q2 ia em iwala gamagaridi i helolodi,
\q1 
\v 4 em mauri ia mate Duhana eai i unehai,
\q2 ia urum i heou gadosisi miatahitahina eo nuatoatoa arinai,
\q1 
\v 5 ia ginauri lolodi eai awam i hemonau i lau e em mauri sigana eai,
\q2 arinai taum ena adidiri i heharihariu doha magesubu.
\b
\q1 
\v 6 GUIAU abiabi dudurai i hemasaraha,
\q2 isi gamagaridi se heamamnadi aridi eai.
\q1 
\v 7 Ia ena dobila Mose i heata,
\q2 ena paipaisoa hinage Isaraela tataodi gamagaridi i heatadi.
\q1 
\v 8 GUIAU ena nuatoatoa eo ena aiainauia ie lai,
\q2 ena ouyalayala nige i abiheulai, ena gadosisi miatahitahina i helai mo ie lau.
\q1 
\v 9 Ia taba nige huia gamagari i dilaida,
\q2 ena ouyalayala taba nige i ota huia gamagari.
\q1 
\v 10 Eda baaea maisadi nige i ledima,
\q2 eo eda laulau gewagewadi hinage nige maisadi i ledima.
\q1 
\v 11 Paana ede doha galewa tanoubu i saetawatawa aririei,
\q2 doha ede meta ena gadosisi miatahitahina laina, ia tauheasisiena enadi.
\q1 
\v 12 Lohana doha mahana ena abadalasae ie lau mahana ena abadui,
\q2 lohana doha meta eda awayagara arida eai i abihesuaradi.
\q1 
\v 13 Doha hinage tamana nanatunayao i nuatoatoaedi,
\q2 GUIAU tauheasisiena tataodi nei doha abo i nuatoatoaedi.
\q1 
\v 14 Paana edohana ena ginaginaurida ia abina i atao,
\q2 i nuatuiyao ita doha tano muamuana.
\b
\q1 
\v 15 Na tau ia ena mauri asubenadi doha lei,
\q2 e doha oea liasidi i maumauriei:
\q1 
\v 16 paana mana ie toa ede i eohoei i lao’o,
\q2 ena abaota wa nige i itauioi.
\q1 
\v 17 Na GUIAU ena godosisi miatahitahina mumuga ariri eai i laoma, otaotana i lau e nige nosina,
\q2 ia tauheasisiena enadi,
\q2 eo ena laulau dudurai isimuri to isimuri tataodi enadi,
\q1 
\v 18 isi ena laugagaeo taunanabuena enadi,
\q2 eo ena lauheata ribadi taunuanuatuidi, eo taupaisoaidi enadi.
\b
\q1 
\v 19 GUIAU ena terona galewa eai i abinonohai,
\q2 eo tanoubu maudoina boeana eai ia wasawasa ede.
\q1 
\v 20 GUIAU au ribatausaei, omi ena aneru e,
\q2 omi emi adidiri i lai ariri, ia ena lauhesom au nanabuedi,
\q2 ena riba daguguna hinage au ataataiei!
\q1 
\v 21 Ena tauiala tataomiu gamagarimiu e, galewa tehana eai, GUIAU au ribatausaei,
\q2 ena heaheari tataomiu ena gadosisi au lauwatai, ia au ribatausaei!
\q1 
\v 22 GUIAU ena nima paisoa gamagarimiu e, omi ia au ribatausaei,
\q2 eanua gamagaridi ia i tanuagaidi.
\q2 Earuagu e, GUIAU u ribatausaei!
\c 104
\s1 GUIAU arinai nimana ginaurina ena itawata
\q1 
\v 1 Earuagu e, GUIAU u ribatausaei!
\q2 GUIAU e, egu Eaubada, oa u lai ariri!
\q2 Heasisi eo wasawasana arinai se heluim,
\q1 
\v 2 oa mara eai u bubuliuioim, doha lulu,
\q2 galewa ue wese doha numalulu,
\q1 
\v 3 oa em abamia ena tuaga u toredi goila potadi eai,
\q2 ealoi u abidi em abageru,
\q2 mana mabena potadi eai ue gerusae,
\q1 
\v 4 oa mana u abidi em tauwasa,
\q2 oeagi ala’alana eo balebalelemna em heaheari ede.
\b
\q1 
\v 5 Tanoubu u hetoro ena du potadi eai,
\q2 bena tabu se hemoiu i lau e nige nosina.
\q1 
\v 6 Gabogabo arinai u buburi doha ena lulu;
\q2 oea tupidi se salili goila gabotumna eai.
\q1 
\v 7 Em riba su’u arinai goila se dago;
\q2 em parere daguguna eai se loi.
\q1 
\v 8 Oea tupidi eai se dididioidi se didi dobi gonu eai
\q2 i lau e se lage teha eai wa oa u abinonohai enadi.
\q1 
\v 9 Adi sigasiga ue tore, taba nige se hemuri,
\q2 bena tabu huia esau tanoubu se hesalili.
\b
\q1 
\v 10 Gonu eai goila bunubunuwasina u hesito seama,
\q2 se didilau oea duaduaridi eai,
\q1 
\v 11 se hemala nu’ura suisuidi gamagaridi edi aba nom,
\q2 asini manamanabaradi gadodi se hebigadi.
\q1 
\v 12 Gegesidi eai maragaibu manudi edi abamia se abidi,
\q2 oeagi lagadi boeadi eai se wana.
\q1 
\v 13 Em abamia ewa ariri eai oea tupidi adi goila u mosei,
\q2 tanoubu ie sese am paisoa uauana arinai.
\b
\q1 
\v 14 Lei u he’ini suisui adi,
\q2 oea uauadi hinage bena tau i umaidi,
\q1 bena tano eai aiai i abi,
\q2 
\v 15 waina hinage abo tau nuana i hekode,
\q1 eausi abo arinai ana ao i masaraha,
\q2 falawa hinage abo tau nuana i headidiri.
\q1 
\v 16 GUIAU ena oeagi goila se henomaririedi,
\q2 Lebanona ena tamonau ia i umaidi wa.
\q1 
\v 17 Lagadi eai manu se abinoi;
\q2 oeagi lailaidi eai hinage manu siari lohalohana ena noi i ginauri.
\q1 
\v 18 Oea tupidi saesaedi goti manamanabaradi edi abalau,
\q2 we’u lailaidi sibini edi aba bawayamui ede.
\q1 
\v 19 Nawarai oa u ginauri abo borimai sorasoradi edi heiheinoi;
\q2 mahana iabom ena huia dui abina ie ata.
\q1 
\v 20 Masigiri u leama to i maiona,
\q2 nu’ura suisuina gamagarina se dalapesama.
\q1 
\v 21 Liona nanatudiyao se dou adi aiai sabidi
\q2 adi aiai wa bena se eo’o Eaubada nimana eai.
\q1 
\v 22 Mahana ena huia dalasae abo se uio,
\q2 se ota edi duha eai.
\q1 
\v 23 Tau ie pesa ie lau ena aba paisoa eai,
\q2 i paipaisoa i lau e i maimailahi.
\b
\q1 
\v 24 GUIAU e, nimam ginauridi ta’i se gamagari!
\q2 Sonogam eai ginauri gamagaridi oa u hetubudi;
\q2 tanoubu i monau nimam ginauridi aridi eai.
\q1 
\v 25 Gabogabo kalau nei eai, ie lai eo i magaga,
\q2 ginauri gamagaridi se hemonau,
\q2 ginauri maumauridi, gagiridi eo lailaidi.
\q1 
\v 26 Waga hinage se adau se lau,
\q2 ulaulasi hinage u ginarui abo nei eai i aiaihea.
\b
\q1 
\v 27 Teina ginauri gamagaridi ta se italaowa arim eai,
\q2 huia mamohoina eai aiai adi abo u mosedi.
\q1 
\v 28 Ena u mosei aridi eai, se abi se ai;
\q2 ena nimam u soe bogadi se sese ginauri lolodi aridi eai.
\q1 
\v 29 Ena am ao u toreamui se heunaboisaha;
\q2 ena eahuadi u abihaidi se mate,
\q2 eo se uio tano muamuana arinai.
\q1 
\v 30 Taba Earuam u hetamarilaei, se maumauri;
\q2 tano ana ao u heharihariu.
\b
\q1 
\v 31 GUIAU namanamarina bena i mia i lau e nige nosina!
\q2 GUIAU bena i kode ariri ena nima paisoa aridi eai,
\q1 
\v 32 ia i italau tanoubu potana eai to tanoubu i tabutabubu,
\q2 oea tupidi i abi’itadi to se asuasu!
\q1 
\v 33 Egu mauri asubenana maudoina eai, GUIAU abo arinai ea wana,
\q2 ma maumaurigu Eaubada abo ea hedebasaei wana arinai.
\q1 
\v 34 Egu nuanuatu eai bena ia nuana ea helolo,
\q2 paana ea nuawoiwoina GUIAU arinai.
\b
\q1 
\v 35 Taba tatao baaeadi se helautomdi tanoubu eai ta,
\q2 taba tatao manamanabaradi se mateohi!
\q1 Earuagu e, GUIAU u ribatausaei!
\q2 GUIAU u aihelahui!
\c 107
\s1 GUIAU iwala eai i saguhaida
\q1 
\v 1 GUIAU ta lautoiei, paana ia i lolo;
\q2 eo ena gadosisi miatahitahina i laulau i lau e nige nosina!
\q1 
\v 2 Isi GUIAU i unehaidi wa bena se ribahemasaraha,
\q2 isi wa iwala eai i unehaidi,
\q1 
\v 3 eo eanua udoi udoi eai i woeagogoidi,
\q2 tupo mahana ena aba dalasae eai eo tupo mahana ena aba dui eai,
\q2 tupo bauri eo tupo eawana eai.
\b
\q1 
\v 4 Headi barabara eai se sae se dobi,
\q2 nige eanua se lobai bena arinai se mia;
\q1 
\v 5 se guriam eo se gadomagu,
\q2 se nua beruberu ariri.
\q1 
\v 6 Abo se doulau GUIAU arinai edi piripiri eai,
\q2 eo i saguhaidi edi amamna eai;
\q1 
\v 7 dobila duduraina eai i woeaidi,
\q2 i lau e eanua se lagelobai abo arinai se mia.
\q1 
\v 8 I lolo GUIAU se lautoiei ena gadosisi miatahitahina debana eai,
\q2 ena abiabi lolo dumadumadi tatao nanatudiyao aridi eai!
\q1 
\v 9 Paana taugadomagu gadona i hebiga,
\q2 eo tauguriam bogana i hesese ginauri lolodi aridi eai.
\b
\q1 
\v 10 Tatao headi masigiri eo nuadubu boeana eai se babawa,
\q2 tau‐tutugudu amamna eo auau poasi eai,
\q1 
\v 11 paana Eaubada ena riba se oipiriedi,
\q2 eo Saesae Aririna ena riba hesanapu se isuewaei.
\q1 
\v 12 Se nuadobidobi paisoa oiurana debana eai;
\q2 se guridobi na nige tausaguidi.
\q1 
\v 13 Abo se doulau GUIAU arinai edi piripiri eai,
\q2 eo i hemauridi edi amamna eai;
\q1 
\v 14 masigiri eai eo nuadubu eai ia i woeahaidi,
\q2 eo edi auau ia i tomutusidi.
\q1 
\v 15 I lolo GUIAU se lautoiei ena gadosisi miatahitahina debana eai,
\q2 ena abiabi lolo dumadumadi tatao nanatudiyao aridi eai!
\q1 
\v 16 Paana dobila gududi \tl bronze\tl* i eatugorugorudi,
\q2 gana poasi i tomutusilabuiedi.
\b
\q1 
\v 17 Headi se asiebo, matapaana edi laulau awayagara,
\q2 eo edi manamanabara debadi eai amamna se hearodi;
\q1 
\v 18 aiai udoi udoi se nua’itaitaedi,
\q2 eo mate dobilana guduna se hanahanaui.
\q1 
\v 19 Abo se doulau GUIAU arinai edi piripiri eai,
\q2 eo i hemauridi edi amamna eai;
\q1 
\v 20 ena riba i hetamarilaei to i helolodi,
\q2 mate eai i abihemauridi.
\q1 
\v 21 I lolo GUIAU se lautoiei ena gadosisi miatahitahina debana eai,
\q2 ena abiabi lolo dumadumadi tatao nanatudiyao aridi eai!
\q1 
\v 22 Abo hinage lautoi aitalasamdi se moselaedi,
\q2 eo ena laulau se wasawasaedi ma wana kodedi!
\b
\q1 
\v 23 Tatao headi waga eai se adau se lau gabogabo eai,
\q2 adi paisoa se laelaei gabogabo lailai eai;
\q1 
\v 24 GUIAU ena laulau se itadi,
\q2 ena abiabi lolo dumadumadi gabotum eai.
\q1 
\v 25 Paana ia ena riba eai na mana baaea ie toa,
\q2 gabogabo butubutuna i helaidi.
\q1 
\v 26 Se sae e galewa, abotai se dobiuio gabotum,
\q2 piripiri ta debana eai edi nuaadidiri ie welo;
\q1 
\v 27 se mataodeode, eo se utu’utu sagisagigi doha doga i nomeauyaure,
\q2 eo nuadi se tupa.
\q1 
\v 28 Abo se doulau GUIAU arinai edi piripiri eai,
\q2 eo i hemauridi edi amamna eai.
\q1 
\v 29 Abo mana baaea i hemotu
\q2 eo gabogabo butubutudi se daumori.
\q1 
\v 30 Abotai se kode ariri paana i daumori,
\q2 to ia i woealaedi edi abalo se henua wa arinai.
\q1 
\v 31 I lolo GUIAU se lautoiei ena gadosisi miatahitahina debana eai,
\q2 ena abiabi lolo dumadumadi tatao nanatudiyao aridi eai!
\q1 
\v 32 I lolo abo tatao edi oigogo eai ia se wasawasaei,
\q2 babada edi oigogo eai hinage bena se hedebasaei.
\b
\q1 
\v 33 Sagasaga i abiitadi se guma doha barabara,
\q2 goila bunubunuwasina i hemala tano pitapitarina,
\q1 
\v 34 oea masurina i abiita abo i hemala ariarita barabarana,
\q2 taumiaina edi baaea debadi eai.
\q1 
\v 35 Barabara i hebui i hemala goila ipuna,
\q2 tano pitapitarina i hemala goila ena ababunubunuwasi.
\q1 
\v 36 Nei eai tauguriam i hemiadi,
\q2 edi eanua se hetoro abo arinai se mia;
\q1 
\v 37 edi oea se umaidi, vine hinage se umaidi,
\q2 abotai se masuri lolo.
\q1 
\v 38 Ia ena aiainauia debana eai se helaiuioi;
\q2 edi suisui hinage taba nige gamagarina i gagiri.
\q1 
\v 39 Ena Eaubada ena tataoyao se saetawatawaidi, eo nuadi se beruberu,
\q2 hewaiunu, iwala e nuadubu debadi eai,
\q1 
\v 40 ena isuewa abo i hegoilaei wasawasa potadi eai
\q2 eo i hetamaridi se laulau gaibu barabara nige dobiladi aridi eai;
\q1 
\v 41 na gogogesagesa tauna i lauisini lauita boeana eai,
\q2 eo nanatunayao i hegamagaridi doha mamoe eawoina.
\q1 
\v 42 Taududurai ie ita to nuana i lolo;
\q2 na laulau gewagewa tataodi nige ariarinadi.
\q1 
\v 43 Eai to eai i sonoga i lolo ginauridi ta i nuatudidinidi;
\q2 i lolo GUIAU ena gadosisi miatahitahina bena se nuanuatui.
\c 110
\s1 GUIAU awa‐tanuagana i mosei Wasawasa arinai
\q1 
\v 1 GUIAU i ribalau egu guiau arinai i ene,
\q2 “Nimatutugu eai u bawa,
\q1 i lau e am waiunuyao abo ea abidi se hemala aem ana bou.”
\b
\q1 
\v 2 Em gigibori tuena Siona eai GUIAU i hetamarilaei.
\q2 Am waiunuyao boeadi eai oa abo tanuaga!
\q1 
\v 3 Em tataoyao abo se moselaeiuiodi ma kodedi
\q2 asubenana eai wa arinai em tauiala u woeaidi
\q2 oea tupidi tabudi potadi eai.
\q1 Maratomtom begana eai
\q2 em isihariu doha wabumari abo se laoa arim eai.
\q1 
\v 4 GUIAU i riba aigora,
\q2 eo taba nige nuana i bui,
\q1 “Oa kohena ede, i lau e nige nosina,
\q2 Melekisadeka dobilana u miawatai.”
\b
\q1 
\v 5 Guiau ia nimatutum eai;
\q2 wasawasa abo i hetatagorigoridi ena ouyalayala asubenana eai.
\q1 
\v 6 Eanua taumiaidi abo i heduduraidi,
\q2 tatao sinaredi eanuadi abo se hemonaudi;
\q1 babada abo i eatugorigoridi
\q2 tanoubu maudoina potana eai.
\q1 
\v 7 Saga gagirina dobila gegesina eai abo arinai i ainom;
\q2 abotai uruna abo i lauisini.
\c 115
\s1 Eaubada eo oitau
\q1 
\v 1 Nige ai enamai, GUIAU e, nige ai enamai,
\q2 na oa esam namanamarina enana abo se moselaei,
\q1 em gadosisi miatahitahina debana eai,
\q2 eo em riba hemamohoiena debana eai hinage!
\q1 
\v 2 Paana saha abo etene si ene,
\q2 “Edi Eaubada ede haedi?”
\b
\q1 
\v 3 Ema Eaubada ia galewa eai;
\q2 saha eo saha i henua meta mo i ginauridi.
\q1 
\v 4 Isi edi oitau \tl silver\tl* eo \tl gold\tl* aridi eai se ginauridi,
\q2 tau nimana ginaurina.
\q1 
\v 5 Isi awadi, na nige se ribariba;
\q2 isi matadi, na nige se itaita.
\q1 
\v 6 Isi beadi, na nige saha se ataiei;
\q2 isi isudi, na nige se panei.
\q1 
\v 7 Isi nimadi, na nige se abi’ita;
\q2 aedi hinage na nige se laulau;
\q2 eo gadoliedi eai nige begana dagugudi.
\q1 
\v 8 Tatao tauginauridi wa gonogonoana doha isi
\q2 gamagaridi hinage eai to eai edi sunuma se torelaei aridi eai,
\b
\q1 
\v 9 Isaraela e, GUIAU au sunumaei!
\q2 Ia isi adi sagu eo edi opea ede.
\q1 
\v 10 Arona numana e, emi sunuma au tore esegai GUIAU arinai!
\q2 Ia isi adi sagu eo edi opea ede.
\q1 
\v 11 Omi eai to eai GUIAU au matausiei, GUIAU au sunumaei!
\q2 Ia isi adi sagu eo edi opea ede.
\q1 
\v 12 GUIAU ia i nuanuatuidaoieda; ia abo i heloloda;
\q2 Isaraela numana abo i helolo;
\q2 Arona numana abo i helolo.
\q1 
\v 13 Isi GUIAU se matausiei abo i helolodi,
\q2 dodoga gagiridi, eo dodoga lailaidi.
\q1 
\v 14 GUIAU emi gogo taba i helai,
\q2 eo nanatumiuyao enadi hinage!
\q1 
\v 15 Taba GUIAU i helolomiu,
\q2 ia galewa eo tanoubu tau ginauridi!
\b
\q1 
\v 16 Galewa isi ede GUIAU ena galewa,
\q2 na tanoubu mo i moseyao tatao nanatudiyao aridi eai.
\q1 
\v 17 Tau matematena ia taba nige GUIAU i hedebasaei,
\q2 gonogonoana hinage isi gamagaridi wa se dobi monomonou eai:
\q1 
\v 18 Na ita GUIAU abo ta ribatausaei
\q2 ina wauta eo i lau e nige nosina.
\q1 GUIAU au hedebasaei!
\c 116
\s1 Lautoi lailai mate eai abihemaurina
\q1 
\v 1 GUIAU ea gadosisiei paana eau arinagu
\q2 eo egu aiaiboda ia i ataiedio.
\q1 
\v 2 Ia i nonoha arinagu i ataiei,
\q2 arinai egu mauri huiana maudoina eai abo ea eogalau arinai.
\q1 
\v 3 Mate ena sai’i se wese hetaiirigu,
\q2 Hade amamnadi se abigu;
\q2 nuadubu eo amamna lailai ea hearodi.
\q1 
\v 4 Abotai ea eogalau GUIAU esana ea atai:
\q2 “GUIAU e, ea dousaewa, oa bena u abihemaurigu!”
\b
\q1 
\v 5 Ia abilolo eo laulau dudurai GUIAUNA ede;
\q2 eda Eaubada ia nuatoatoa Eaubadana ede.
\q1 
\v 6 Tau dobidobina GUIAU i ganaganai;
\q2 huiana wa nuagu i dobidobi ia i lebohaigu.
\q1 
\v 7 Nuagu e, u uio em abaaiyawasi eai;
\q2 paana GUIAU i ainauia aririem.
\q1 
\v 8 Mate eai u saguhaigu,
\q2 matasulugu matagu eai u sauhai,
\q2 aegu u headidiridi bena tabu ea alabesibesi.
\q1 
\v 9 GUIAU matana eai abo ea laulau
\q2 tatao maumauridi oeana eai.
\q1 
\v 10 Huiana wa ea ribaei ea ene,
\q2 “Egu lauita i lai ariri”; na egu sunuma mo nige ea abigabaei.
\q1 
\v 11 Egu heunaboisaha eai ea ene,
\q2 “Tatao gamagaridi se sunuma gaibu.”
\b
\q1 
\v 12 Saha abo ea moselaei GUIAU arinai
\q2 ena abilolo gamagarina arigu eai maisana?
\q1 
\v 13 Mauri biana abo ea abiisini
\q2 eo ea eogalau GUIAU arinai esana ea atai,
\q1 
\v 14 egu aigora abo ea hemamohoiedi GUIAU arinai,
\q2 ena tataoyao gamagaridi matadi eai.
\q1 
\v 15 Ena taumiutahitahi tataodi edi mate i sae ariri
\q2 GUIAU matana eai.
\q1 
\v 16 GUIAU e, eau em heaheari tauna esau,
\q2 eau em heaheari tauna, em heaheari sinena natuna,
\q2 egu auau u eairihaidio.
\q1 
\v 17 Lautoi aitalasamna abo ea moseleawa arim eai,
\q2 eo abo ea eogalau GUIAU arinai esana ea atai.
\q1 
\v 18 Egu riba aigora abo ea hemamohoiedi GUIAU arinai,
\q2 ena tataoyao gamagaridi matadi eai,
\q1 
\v 19 GUIAU ena numa bau’ubau’una eai,
\q2 boeam eai, Ierusalema e.
\q1 GUIAU ta hedebasaei!
\c 119
\s1 Eaubada ena laugagaeo lolo ariaririna
\q1 
\v 57 GUIAU ia egu gogo ede;
\q2 ea ribahesunuma oa em riba abo ea sogohididinidi.
\q1 
\v 58 Ma nua’esegagu em nualolo ea aiboda gadogadorai;
\q2 em riba hesunuma debana eai bena u nuatoatoaegu.
\q1 
\v 59 Ena em abiabi ea nuanuatuidi,
\q2 aegu ea toreuoidi em riba tabudi aridi eai;
\q1 
\v 60 Ea lelehi, taba nige ea bebeda
\q2 em lauhesom bena ea nanabuedi.
\q1 
\v 61 Laulau gewagewa tauna siposipo mainana arinai bena i sipoigu,
\q2 na em laugagaeo taba nige ea nuahuiei.
\q1 
\v 62 Bulinuana eai ea toro ea lautoiem,
\q2 em hesanapu ribadi duduraidi debadi eai.
\q1 
\v 63 Tatao gamagaridi taumatausiem eau boeadi eai,
\q2 isi gamagaridi em lauheata ribadi se nanabuedi.
\q1 
\v 64 GUIAU e, em gadosisi miatahitahina ta tanoubu i hemonauyao;
\q2 em laugagaeo bena u heatagu!
\s1 GUIAU ena laugagaeo abiwataina
\q1 
\v 65 Em abi se lolo em heaheari tauna arinai,
\q2 GUIAU e, oa em riba debana eai.
\q1 
\v 66 Sibasiba lolona eo sonoga oa bena u heatagu,
\q2 paana em lauhesom ea awamamohoiedi.
\q1 
\v 67 Huiana eai wa sora nige amamna ea hearo, ea lausuaraem;
\q2 na ina huia ta em riba ea sogohididinidi.
\q1 
\v 68 Oa u lolo, em abiabi hinage se lolo;
\q2 em laugagaeo bena u heatagu.
\q1 
\v 69 Etene tataodi riba borabora arinai se hebaaeagu,
\q2 na eau ma nuagu i ohihai em lauheata ribadi ea abididinidi.
\q1 
\v 70 Isi nuadi se potopoto doha momona,
\q2 na eau em laugagaeo mo ea henua aririei.
\q1 
\v 71 Mamohoi i lolo ariri lauita ea hearodi;
\q2 debana eai em laugagaeo ea italobaidi.
\q1 
\v 72 Oa awam laugagaeona ie sae ariri arigu eai,
\q2 abotai \tl gold\tl* eo \tl silver\tl* gamagamagaridi.
\s1 GUIAU ena laugagaeo sunusunumaena
\q1 
\v 89 Em riba, GUIAU e, i otaesegai
\q2 galewa eai, i lau e nige nosina.
\q1 
\v 90 Em riba u hemamohoiedi i lau e isi gamagaridi aridi eai;
\q2 tanoubu u hetoro‐tahitahi, eo i otaesegai.
\q1 
\v 91 Oa em riba debana eai wauta se totoro;
\q2 paana ginauri gamagaridi oa em heaheari ede.
\q1 
\v 92 Ena oa em laugagaeo nige i hekodegu,
\q2 lauita boeana eai abo ea mate aririo.
\q1 
\v 93 Oa em lauheata ribadi taba nige ea nuahuiedi,
\q2 paana isi debadi eai u abihemaurigu.
\q1 
\v 94 Eau oa enam, bena u abihemaurigu;
\q2 paana oa em lauheata ribadi ea eo’eo’oidi.
\q1 
\v 95 Laulau gewagewa tataodi se bagibagi bena se unuigu,
\q2 na oa em riba tabudi mo ea nuanuatuidi.
\q1 
\v 96 Laulau lolo dumadumadi adi sigasiga ea itadio,
\q2 na oa em lauhesom mo i magaga ariariri.
\s1 GUIAU ena laugagaeo gadosisina
\q1 
\v 97 Em laugagaeo ea gadosisi aririei!
\q2 Asubena maudoina eai i hemala egu abanuanuatu.
\q1 
\v 98 Em lauhesom i hesonoga aririegu, agu waiunuyao nige doha,
\q2 paana huia gamagari matagu eai i totoro.
\q1 
\v 99 Ea sibasiba ariri abotai egu taulauheata,
\q2 paana em riba tabudi egu aba nuanuatu ede.
\q1 
\v 100 Ea sibasiba ariri abotai tautaubada,
\q2 paana em lauheata ribadi ea nanabuedi.
\q1 
\v 101 Aegu ea abididinidi tabu dobila gegewarina ea lauwatai,
\q2 em riba mo bena ea awaabiei.
\q1 
\v 102 Em ribahesanapu taba nige ea torehesuaradi,
\q2 paana oa u heataguo.
\q1 
\v 103 Em riba se amna ariri awagu eai,
\q2 se amna ariri awagu eai abotai amoamo!
\q1 
\v 104 Em lauheata ribadi aridi eai sibasiba ea lobai,
\q2 to arinai dobila boraboradi gamagaridi ea hewaiunuedi.
\s1 GUIAU ena laugagaeo marana
\q1 
\v 105 Oa em riba ede eau aegu ena lamepa,
\q2 eo egu dobila ena mara.
\q1 
\v 106 Eau ea aigorao, abo hinage ea hemamohoiei,
\q2 em hesanapu ribadi duduraidi wa abo ea abiwataidi.
\q1 
\v 107 Egu amamna se gamagari ariri;
\q2 GUIAU e, oa u hemaurigu, gonogonoana doha ue ribaei wa!
\q1 
\v 108 GUIAU e, egu hedebasae aitalasamna awagu eai bena u abidi
\q2 eo em hesanapu ribadi wa bena oa u heatagu.
\q1 
\v 109 Egu mauri eau nimagu eai huia gamagamagari,
\q2 na oa em laugagaeo nige esau ea nuahuiei.
\q1 
\v 110 Laulau gewagewa tataodi sai’i se tore bena se sai’igu,
\q2 na oa em lauheata ribadi taba nige ea lausuaraedi.
\q1 
\v 111 Oa em riba tabudi ea abidi doha egu gogo i lau e nige nosina;
\q2 mamohoi eau nuagu ena abakode meta.
\q1 
\v 112 Eau nuagu ea toreyao em lauhesom ribadi ea lauwataidi
\q2 huia gamagari, i lau e sigana eai.
\s1 GUIAU ena laugagaeo awaabina
\q1 
\v 129 Oa em riba tabudi wa se sae ariri;
\q2 arinai earuagu i sogohididinidi.
\q1 
\v 130 Ena em riba se hemasaraha abo i hemaramai;
\q2 tau supusupu i hesibasiba.
\q1 
\v 131 Ma awadabarigu eawasigu ie ku’u,
\q2 paana em lauhesom ribadi ea gadohiedi.
\q1 
\v 132 U sinibuima eo u nuatoatoaegu,
\q2 paana oa kamanim isi esam tau gadosisiena aridi eai.
\q1 
\v 133 Aegu u headidiridi em ribahesunuma debana eai,
\q2 abo taba nige laulau gewagewa esau i saetawatawaigu.
\q1 
\v 134 Tau ena hewahewaiunu arinai bena u unehaigu,
\q2 abo em lauheata ribadi ea abiwataidi.
\q1 
\v 135 Am ao bena u hesina em heaheari potana eai,
\q2 eo em laugagaeo u heatagu.
\q1 
\v 136 Eau matasulugu se dididi,
\q2 mata paana tatao oa em laugagaeo nige se awaabiei.
\s1 GUIAU ena laugagaeo abiabi duduraina
\q1 
\v 137 GUIAU e, oa u dudurai,
\q2 em hesanapu ribadi hinage se dudurai.
\q1 
\v 138 Em riba tabudi u hetorodi laulau dudurai debadi eai.
\q2 eo em riba hinage u hemamohoiedi.
\q1 
\v 139 Egu nuaialayala i gabugu,
\q2 paana agu waiunuyao em riba se nuahuiedi.
\q1 
\v 140 Oa em ribahesunuma wa se lauitayao,
\q2 eo em heaheari tauna i gadosisiei.
\q1 
\v 141 Eau ea dobi ariri, to se isuewaegu,
\q2 na oa em lauheata ribadi taba nige ea nuahuiedi.
\q1 
\v 142 Oa em laulau dudurai se dudurai i lau e nige nosina,
\q2 eo oa em laugagaeo mamohoina ede.
\q1 
\v 143 Piripiri eo amamna se abigu,
\q2 na oa em lauhesom ribadi egu nuawoiwoina ede.
\q1 
\v 144 Oa em riba tabudi se dudurai i lau e nige nosina;
\q2 sonoga bena oa u leama abo ea mauri.
\s1 Abihemauri Aibodana
\q1 
\v 153 Egu amamna bena u italau arinai eo bena u lebohaigu,
\q2 paana oa em laugagaeo taba nige ea nuahuiei.
\q1 
\v 154 Enagu u toro, u ribasaguigu, eo u unehaigu,
\q2 mauri u leama em ribahesunuma debana eai.
\q1 
\v 155 Laulau gewagewa tataodi taba nige se mauri,
\q2 paana oa em laugagaeo nige se eo’o eo’oidi.
\q1 
\v 156 GUIAU e, oa em nuatoatoa i lai ariri;
\q2 em laulau dudurai debana eai bena mauri u leama.
\q1 
\v 157 Tauheamamnagu eo tauhewaiunuegu se gamagari,
\q2 na oa em riba tabudi taba nige ea lausuaraedi.
\q1 
\v 158 Isi nige se awamamohoiem ea italau aridi eai ma nua’itaitagu;
\q2 paana oa em lauhesom nige se awamamohoiedi.
\q1 
\v 159 Abo u nuatui komakomani em lauheata ribadi ea gadosisiedi!
\q2 Egu mauri bena u ganaganai em gadosisi miatahitahina debana eai.
\q1 
\v 160 Em riba maudoina mamohoina ede;
\q2 eo em hesanapu ribadi duduraidi gamagaridi abo se otahai i lau e nige nosina.
\s1 Saguhai Aibodana
\q1 
\v 169 GUIAU e, egu dou bena i saewa arim eai;
\q2 sonoga u leama gonogonoana doha u ribaei wa!
\q1 
\v 170 Egu awanori bena i saewa oa matam eai;
\q2 u saguhaigu gonogonoana doha u ribaei wa!
\q1 
\v 171 Eau sopagu eai ea hedebasaem
\q2 paana oa em lauhesom ribadi u heatagu.
\q1 
\v 172 Eau memenagu eai em riba abo ea wanai,
\q2 paana oa em lauhesom ribadi gamagaridi se dudurai.
\q1 
\v 173 Oa nimam taba i nonoha i saguigu,
\q2 paana oa em lauheata ribadi wa ea abi hineridio.
\q1 
\v 174 GUIAU e, oa em abihemauri ea gadohi aririei,
\q2 eo em laugagaeo egu aba kode ede.
\q1 
\v 175 Eau earuagu bena i mauri, abo ea hedebasaem,
\q2 eo em hesanapu ribadi bena se saguigu.
\q1 
\v 176 Eau ea laupono doha mamoe ie gege wa;
\q2 em heaheari tauna taba u eo’oi,
\q2 paana em lauhesom ribadi nige esau ea nuahuiei.
\c 120
\s1 Tatao edi laulau borabora eai bena se saguhaidi uurana
\q1 
\v 1 Egu nuadobidobi boeana eai ea eogalau GUIAU arinai,
\q2 bena i heuioegu:
\q1 
\v 2 “Sopa borabora aridi eai eo memena borabora aridi eai,
\q2 GUIAU e, bena oa u saguhaigu.”
\b
\q1 
\v 3 Oa memena borabora e,
\q2 saha abo se moseleawa arim eai,
\q2 eo saha abo se ginauri enam?
\q1 
\v 4 Tauiala ena pidu matamatana,
\q2 ma oeagi alaalasina!
\b
\q1 
\v 5 Ahani eau, paana Meseka eai ea miamia,
\q2 Kedara ena numa lulu hinage boeadi eai ea miamia!
\q1 
\v 6 Ea abimatemate paana ea mia ariri
\q2 isi boeadi eai labini se hewaiunuei.
\q1 
\v 7 Eau labini mo ea henua;
\q2 na ena ea ribariba,
\q2 isi iala mo se henua.
\c 121
\s1 GUIAU ia Tauitawataim
\q1 
\v 1 Eau matugu abo ea tusaei oea tupidi eai.
\q2 Aba saguigu haedi eai abo i laoma?
\q1 
\v 2 Aba saguigu GUIAU arinai i laoma,
\q2 ia ede galewa eo tanoubu tauginauridi.
\b
\q1 
\v 3 Ia abo aem i itawatai, taba nige i moiu,
\q2 ia tauitawataim wa, taba nige i eno.
\q1 
\v 4 U ita, Isaraela tauitawataina
\q2 ia matana taba nige se enoeno, eo taba nige i enomate.
\b
\q1 
\v 5 GUIAU ia tauitawataim ede;
\q2 GUIAU ia ede em abaailogulogu
\q2 oa nimatutum eai.
\q1 
\v 6 Mahana gigiborina taba nige i talaim asubena eai,
\q2 eo nawarai hinage maiona eai taba nige’e.
\b
\q1 
\v 7 GUIAU abo i itawataim piripiri gamagaridi boeadi eai;
\q2 em mauri abo i itawatai.
\q1 
\v 8 Em pesa eo em awaseuio GUIAU abo i itawataidi,
\q2 ina huia ta ie lau e nige nosina.
\c 122
\s1 Ierusalema ena labini uurana
\q1 
\v 1 Ea kode ariri huiana eai wa se heribagu, si ene,
\q2 “Ta awasaei GUIAU ena numa eai!”
\q1 
\v 2 Aemai wa se totoro
\q2 oa em dobila abalusoradi eai, Ierusalema e!
\b
\q1 
\v 3 Ierusalema se hetoro doha eanua wasawasana
\q2 numana se adidiri eo se toro patupatu,
\q1 
\v 4 boga gamagaridi se saesaewa,
\q2 isi ede GUIAU ana bogaoyao,
\q2 doha Isaraela se lauhesom wa, lautoi se mosei GUIAU esana eai.
\q1 
\v 5 Nei eai aba hedudurai aba bawadi saesaedi se toredi,
\q2 aba bawadi saesaedi wa Davida numana enana.
\q1 
\v 6 Ierusalema enana au aiboda bena loni abina i ata!
\q2 “Isi taugadosisiem bena se laulolo!
\q1 
\v 7 Em gana alodi eai bena loni nei eai,
\q2 em numa lailaidi alodi eai bena nuataru!”
\q1 
\v 8 Egu tataoyao eo egu dodogayao debadi eai
\q2 abo ea ribaei, ea ene, “Loni enamiu!”
\q1 
\v 9 GUIAU ema Eaubada ena numa debana eai,
\q2 oa em lolo abo ea eo’o eo’oi.
\c 124
\s1 Waiunu nimadi eai saguhaina uurana
\q1 
\v 1 Taba GUIAU ia nige eda tupo eai,
\q2 ―Isaraela abo si ene―
\q1 
\v 2 taba GUIAU ia nige eda tupo eai
\q2 huiana eai wa tatao abo se toro se ialaida,
\q1 
\v 3 abotai taba ma maumaurida se domda,
\q2 huiana eai wa se ouyalayala aririeda;
\q1 
\v 4 huiana eai ne abaita taba i earuhaida,
\q2 goila lailai abo i earuhaida;
\q1 
\v 5 goila ena didi adidiri
\q2 abo i earutawaida.
\q1 
\v 6 GUIAU bena ta ribatausaei,
\q2 paana nige i moselaeda
\q2 doha moadi edi aba aipurisi!
\q1 
\v 7 Ta dago doha manu
\q2 sa’i tauginaurina ena sa’i arinai;
\q1 sa’i i tagoduo,
\q2 to ta dago’o!
\b
\q1 
\v 8 Aba saguida ede GUIAU esana eai,
\q2 ia galewa eo tanoubu tauginauridi.
\c 126
\s1 Hetorouio lautoina
\q1 
\v 1 Huiana eai wa GUIAU Siona ena lolo i heharihariu,
\q2 ita ada ao doha tau enosuai.
\q1 
\v 2 Abo maruhi awada i hemonaudi,
\q2 eo memenada eai ta wowo ma kodeda.
\q1 Abo eanua headi taumiaidi si ene,
\q2 “GUIAU ginauri lailaidi enadi i ginauridi.”
\q1 
\v 3 GUIAU ginauri lailaidi enada i ginauridi;
\q2 arinai ta kode ariri.
\b
\q1 
\v 4 Ema dobila bena u heharihariudi, GUIAU e,
\q2 doha goila se dididi Negeb barabarana eai!
\q1 
\v 5 Tatao wa tuma se lauhesuru ma matasurudi
\q2 abotai abo se tanogogo eo se wowo ma kodedi!
\q1 
\v 6 Ia ma douna i torohai,
\q2 tuma i bahei bena i hesuru,
\q1 abo i uioma ena numa eai ie wowo ma kodena,
\q2 nimana eai sitona augogodi i baheidima.
\c 127
\s1 Ginauri lolodi gamagaridi GUIAU arinai se laoma
\q1 
\v 1 Ena GUIAU numa wa nige i hetoro,
\q2 isi tauhetorona se paisoa asaeai.
\q1 Ena GUIAU ia eanua wasawasa nige i silawai,
\q2 tau aisilawa i silawa asa.
\q1 
\v 2 Nige aniona ena u enotoro heura,
\q2 eo u eno boneawa,
\q1 paisoa porohena aiaina mo ue ai;
\q2 isi i gadosisiedi taba nige saha se deha.
\b
\q1 
\v 3 U ita, merumeru tatao GUIAU ena ainauia ede,
\q2 boga uauana ia ena ainauia.
\q1 
\v 4 Doha pidu tauiala nimana eai
\q2 hewari huiana nanatunayao doha ede.
\q1 
\v 5 Tau wa ie kode
\q2 taba ena aba aiusa i monau!
\q1 Taba nige se hetaumaeamaea
\q2 huiana eai wa ma ana waiunuyao aba hedudurai eai se hailobai.
\c 130
\s1 GUIAU ena abihemauri sunumana
\q1 
\v 1 GUIAU e, eau duha alona eai ea doulaowa arim eai!
\b
\q1 
\v 2 Guiau e, arinagu u ataiei!
\q2 Beam bena i tasoe egu aiboda
\q2 daguguna arinai!
\b
\q1 
\v 3 GUIAU e, ena oa laulau gewagewadi u nuatudidinidi,
\q2 Guiau e, eai gonoana abo i toro?
\q1 
\v 4 Na baaea ribagigirina ede oa arim eai i laoma,
\q2 arinai oa mo matausim abo se matausi.
\b
\q1 
\v 5 Eau GUIAU ea bagibagiei, earuagu hinage ia i bagibagiei,
\q2 eo ia ena riba arinai ea sunusunuma;
\q1 
\v 6 Eau earuagu Guiau i bagibagiei
\q2 doha isi tausilasilawa maratomtom taubagibagiena, eau mo ea hemuridi,
\q2 doha isi tausilasilawa maratomtom taubagibagiena eau mo ea hemuridi.
\b
\q1 
\v 7 Isaraela e, u sunumalau GUIAU arinai!
\q2 Paana GUIAU arinai ede gadosisi miatahitahina,
\q2 eo ena abihemauri i lai ariariri.
\q1 
\v 8 Ia hinage abo Isaraela i unehemauri ena laulau gewagewadi
\q2 gamagaridi aridi eai.
\c 132
\s1 Abamia tabuna se helolo uurana
\q1 
\v 1 GUIAU e, bena Davida u nuatui ma nualolom,
\q2 lauita oioiuradi gamagaridi i hearodi;
\q1 
\v 2 ie riba aigora GUIAU arinai
\q2 eo i ribahesunuma Iakobo ena Eaubada Gigiborina arinai,
\q1 
\v 3 “Taba nige ea awasae egu numa eai
\q2 eo taba nige ea lau egu abaeno eai;
\q1 
\v 4 taba nige matagu ea hegibudi,
\q2 eo taba nige matagu se enoeno.
\q1 
\v 5 na GUIAU ena numa abahetorona ea eooi i lau e ea lobai.
\q2 Iakobo ena Eaubada Gigiborina ena abamia.”
\b
\q1 
\v 6 Ai ataiei Eparata eai,
\q2 ai lobai Ia’ara ena oea eai.
\q1 
\v 7 “I lolo ta lau ena aba mia eai;
\q2 aena ana bou arinai ta tabaohu!”
\b
\q1 
\v 8 U toro, GUIAU e, u lau em aba aiyawasi dimona eai,
\q2 oa, eo em gigibori akena maem.
\q1 
\v 9 Em kohena bena laulau dudurai se luidi,
\q2 eo tatao tabudi abo se wowo ma kodedi,
\q1 
\v 10 Em heaheari tauna Davida debana eai
\q2 oa em heyausi tauna tabu u otaotaei.
\q1 
\v 11 GUIAU aigora mamohoina i aigoraei Davida arinai
\q2 eo ena riba wa i ota esegai:
\q1 “Oa natum tau esau, oa taum eai i laoma,
\q2 abo ea hebawa em terona potana eai.
\q1 
\v 12 Taba nanatumyao tatao egu ribahesunuma se sogohididini
\q2 eo egu riba tabudi ea heatadi wa hinage,
\q1 isi nanatudiyao oa em terona potana eai abo se bawa
\q2 i lau e huia nige nosina.”
\q1 
\v 13 Paana ede GUIAU Siona i abihineri,
\q2 i gadohiei abo ena aba miahai:
\q1 
\v 14 “Inata ede egu aba aiyawasi i lau e huia nige nosina;
\q2 inai abo ea miatahitahi, paana ea gadohiei.
\q1 
\v 15 Ana aiai abo ea helai aririei;
\q2 ena gogogesagesa tataodi aiai eai abo ea hebogasesedi.
\q1 
\v 16 Ena kohena mauri arinai abo ea heluidi,
\q2 ena taumiatahitahi tataodi abo se wowo makodedi.
\q1 
\v 17 Nei eai abo dona esau ea he’ini Davida enana;
\q2 lamepa ea abinonohai egu heyausi tauna enana.
\q1 
\v 18 Ana waiunuyao mo abo ea heluidi taumaeamaea arinai,
\q2 na ia iabom uruna eai ena korona namanamarina abo i sina.”
\c 137
\s1 Taumiasuara Babilonia eai edi eanua tahunuana sabina se dou
\q1 
\v 1 Babilonia goilana gegesidi eai,
\q2 ai bawa na ai doudou,
\q3 huiana eai wa Siona ai nuanuatui.
\q1 
\v 2 Oeagi lagadi eai
\q2 ema huelele ai heabasidi.
\q1 
\v 3 Nei eai isi tauitawataimai
\q2 se riba bena enadi ai wana,
\q1 eo isi tauheamamnamai se riba bena ai kode, si ene,
\q2 “Siona wanana enamai au wana!”
\b
\q1 
\v 4 Edohana abo GUIAU ena wana
\q2 hari eanua eai ai wanai?
\q1 
\v 5 Ierusalema e, ena ea nuahuiem,
\q2 i lolo nimatutugu taba i wowoea!
\q1 
\v 6 I lolo memenagu i patu esegai awagu potana eai,
\q2 ena taba nige ea nuanuatuim
\q1 ena taba nige Ierusalema ea tore bagunai
\q2 egu kode saesae aririna nuagu eai!
\b
\q1 
\v 7 GUIAU e, Edoma tataodi edi laulau bena u nuanuatui
\q2 nei asubena na eai ne Ierusalema se saetawatawai,
\q1 si ene, “Ta hebaaea auri, ta hebaaea auri!
\q2 I dobi e paa eai!”
\q1 
\v 8 Babilonia natuna sine e, oa ede tauhebahebaaea!
\q2 Ia tauhemaisam wa abo nuana i kode
\q2 gonogonoana doha oa u ginauri arimai eai wa!
\q1 
\v 9 Ia wa eai nanatumyao i abidi abo i kode hinage
\q2 i hetamogorugorudi malamalatete potana eai.
\c 139
\s1 Eaubada ia tupo gamagamagari eai, eo sonoga maudoina ia enana
\q1 
\v 1 GUIAU e, eau nuagu u eo’oiyao, eo abigu u ata’o!
\b
\q1 
\v 2 Egu bawa eo egu toro abidi u ata’o;
\q2 oa eda lohaloha eai egu nuanuatu u italobaidio.
\q1 
\v 3 Egu dobila u itahetaiiri, eo egu otadobi hinage,
\q2 egu laulau gamagaridi abidi ue ata.
\q1 
\v 4 Sora nige riba esau memenagu eai,
\q2 na oa, GUIAU e, abina u ata heohiyao.
\q1 
\v 5 Oa u bagubagunaegu, eo u murimuritaegu,
\q2 eo oa nimam u toresaei eau potagu eai.
\q1 
\v 6 Sonoga meta doha no’ona nige gonoagu;
\q2 i sae ariri, eau taba nige ea lage arinai.
\b
\q1 
\v 7 Oa Earuam ea dagogabaei abo ea lau haedi?
\q2 E oa matam abo edohana egu dagodagogabaena?
\q1 
\v 8 Eau taba ea sae galewa eai, oa nei eai!
\q2 Taba Hade eai egu eba ea wese na oa hinage nei eai!
\q1 
\v 9 Taba maratomtom mabena ea abi
\q2 abo ea loi ea lau gabogabo sigana eai ea mia,
\q1 
\v 10 nei eai hinage oa nimam abo i woeaigu,
\q2 eo nimatutum abo i abididinigu.
\q1 
\v 11 Ena ea ene, “Masigiri taba i bubulitawaigu,
\q2 eo mara arigu eai i hemala maiona,”
\q1 
\v 12 taiede masigiri oa arim eai nige i masigiri,
\q2 maiona ie mara doha asubena;
\q2 paana masigiri gonogonoana doha mara oa matam eai.
\b
\q1 
\v 13 Taugu boeana oa u ginauri,
\q2 sinagu bogana eai eaugu gamagaridi oa u hepatuesegaidi.
\q1 
\v 14 Ea hedebasaem, paana oa u nuamatamatausi eo oa no’ono’om.
\q2 Nimam ginauridi hinage no’ono’odi.
\q2 Oa abigu u ata ariri!
\q1 
\v 15 Taugu nige i otayamui oa arim eai,
\q2 huiana wa eamuyamui eai se ginaurigu,
\q2 tano boeana eai se ginauri komakomanigu.
\q1 
\v 16 Bulumagu sora nige se ginauri, oa matam se itaguo;
\q2 oa em buka eai egu asubena gamagaridi se uri nonohaidio,
\q2 huiana eai wa sora nige se labasigu.
\q1 
\v 17 Oa em nuatu se sae ariariri, GUIAU e!
\q2 Se gamagari ariariri hinage!
\q1 
\v 18 Ena ea hasiridi gamagarina gelegele i dioi.
\q2 Ena ea enotoro oa hinage gegesigu eai.
\q1 
\v 19 Eaubada e, taba laulau gewagewa tataodi u unuidi mo,
\q2 taba taunimaosina tataodi hinage se torohaigabaegu,
\q1 
\v 20 tatao wa ma nuatu baabaaeadi se awayagalaem,
\q2 baaea debana eai se oioipiriem!
\q1 
\v 21 GUIAU e, isi oa se hewaiunuem eau hinage ea hewaiunuedi e nige’e?
\q2 Isi hinage oa se ialaim, eau hinage ea isugaraedi e nige’e?
\q1 
\v 22 Hewaiunu mamohoina arinai ea hewaiunuedi;
\q2 ea itadi isi hinage eau agu waiunuyao.
\q1 
\v 23 Eaubada e, bena u itaheohigu, nuagu hinage abina u ata.
\q2 U lauitagu eo egu nuanuatu bena abidi u ata.
\q1 
\v 24 U ita taba laulau baaea aisana eau arigu eai,
\q2 eo dobila miatahitahina bena arinai u woeawoeaigu!
\c 145
\q1 
\v 1 Egu Eaubada e, eo egu Wasawasa, oa abo ea hatoem,
\q2 oa esam abo ea ribatausaei i lau e huia nige nosina.
\q1 
\v 2 Asubena gamagari eau abo ea ribatausaem,
\q2 oa esam ea aihelahui i lau e nige nosina.
\q1 
\v 3 GUIAU ia i sae ariri, ia hedebasaena ie lai,
\q2 eo saesaena nige tau esau gonoana i eo’oi.
\b
\q1 
\v 4 Isi esau isi esau aridi eai am paisoa abo se hedebasaei,
\q2 em gigibori laulaudi se ribahemasarahadi.
\q1 
\v 5 Em wasawasa ana ao lolona eo em gigibori namanamarina,
\q2 eau nuagu eai abo ea nuanuatuidi.
\q1 
\v 6 Oa em laulau matamatausidi ma gigiboridi, tatao abo se ribahemasarahadi,
\q2 eo em abiabi saesaedi abo ea guguiaei.
\q1 
\v 7 Oa em abilolo saesaena wasana abo se ribaribaei,
\q2 em laulau duduraidi abo se wanawanaidi.
\b
\q1 
\v 8 GUIAU ena ainauia i lai ariri eo ena nuatoatoa hinage,
\q2 ena ouyalayala nige i heula, ena gadosisi miatahitahina hinage i lai ariri.
\q1 
\v 9 GUIAU ena abi se lolo tatao gamagaridi aridi eai,
\q2 eo ginauri gamagaridi ia i hetubudi meta i nuatoatoaedi.
\b
\q1 
\v 10 GUIAU e, nimam ginauridi gamagaridi wa abo se lautoiem,
\q2 em taumiatahitahi tataodi gamagaridi abo se ribatausaem!
\q1 
\v 11 Em basileia namanamarina abo se ribaei,
\q2 eo em gigibori hinage,
\q1 
\v 12 tatao nanatudiyao em gigibori laulaudi abo se heatadi,
\q2 eo em basileia ena namanamari hinage.
\q1 
\v 13 Oa em basileia miatahitahi basileiana,
\q2 em tanutanuagaimai i laulau hari isi to hari isi.
\b
\q1 GUIAU ena riba gamagaridi i hemamohoiedi,
\q2 eo ena nuatoatoa i laulau ena abiabi gamagaridi aridi eai.
\q1 
\v 14 Taubeu gamagaridi GUIAU i abi’isinidi,
\q2 eo tatao dageladi se eou i abihetorodi.
\q1 
\v 15 Mata gamagaridi se italaowa oa arim eai,
\q2 eo oa adi aiai taumosedi huiana mamohoina eai.
\q1 
\v 16 Oa nimam ue ala,
\q2 ginauri gamagaridi edi henuhenua u mosedi.
\q1 
\v 17 GUIAU ena laulau gamagaridi se dudurai,
\q2 eo ena abi gamagaridi ma nuatoatoana.
\q1 
\v 18 GUIAU tatao gamagaridi taueogalau i hanahanau‐aririedi,
\q2 isi wa mamohoina eai taueogalau.
\q1 
\v 19 Ia tauheasisiena tataodi gamagaridi i itawataidi,
\q2 edi dou hinage i ataiei, eo i hemauridi.
\q1 
\v 20 GUIAU taugadosisiena tataodi gamagaridi i itawataidi;
\q2 na laulau gewagewa tataodi abo i unuheohidi.
\q1 
\v 21 Awagu eai GUIAU hedebasaena abo ea ribaei,
\q2 buluma eai tatao gamagaridi ia esana tabuna taba se ribatausaei,
\q2 i lau e huia nige nosina.
\c 146
\s1 GUIAU se hedebasaei ena laulau duduraidi debadi eai
\q1 
\v 1 GUIAU au hedebasaei!
\q2 Earuagu e, GUIAU u hedebasaei!
\q1 
\v 2 Eau GUIAU abo ea hedebasaei i lau e egu mauri sigana;
\q2 sora ma maumaurigu GUIAU hedebasaena abo ea wanai.
\b
\q1 
\v 3 Wasawasa tabu au sunumaedi,
\q2 tanoubu tauna hinage tabu au sunumaei, ia arinai nige aba haisagusagu.
\q1 
\v 4 Ia eawasina ie ohi abo i uio i hemala tanouio;
\q2 meta asubenana ne ena nuatu se lautom.
\b
\q1 
\v 5 Tau ne ie kode, ia wa tausaguina ede Iakobo ena Eaubada,
\q2 ena sunuma ie tore GUIAU ena Eaubada arinai,
\q1 
\v 6 ia galewa eo tanoubu tauginauridi
\q2 gabogabo hinage, ma ginauri gamagamagarina;
\q2 ena riba i otaesegai i lau e nige nosina;
\q1 
\v 7 abidudurai i hemasaraha isi se heamamnadi aridi eai;
\q2 eo tau guriguriam ia aiai adi i mosedi.
\q1 Tatao auaudi GUIAU i eairihaidi se lau;
\q1 
\v 8 GUIAU matagibugibu tataodi matadi i helaladi.
\q2 Tatao nuadi se porohe nuadi i hemamaradi;
\q1 GUIAU laulau‐dudurai tataodi i gadosisiedi.
\q2 
\v 9 Taulaolaoma tataodi GUIAU i itawataidi;
\q1 wabuwabu eo dabudabure i abididinidi;
\q2 na laulau gewagewa tauna ena dobila i hetatagorigori.
\b
\q1 
\v 10 GUIAU ena wasawasa huiana i laulau e nige nosina,
\q2 Siona e, em Eaubada ta, i lau e hari isi to hari isi.
\q1 GUIAU au hedebasaei!
\c 148
\s1 Ginauri gamagamagaridi bena GUIAU se hedebasaei
\q1 
\v 1 GUIAU au hedebasaei!
\q2 Galewa eai GUIAU au hedebasaei:
\q1 ewa inipuripuri eai au hedebasaei!
\q1 
\v 2 Aneru gamagarimiu ia au hedebasaei,
\q2 ana tauiala tataomiu gamagarimiu, galewa tehana eai, ia au hedebasaei!
\b
\q1 
\v 3 Mahana eo nawarai e, ia au hedebasaei,
\q2 ipora namanamarimiu e, ia au hedebasaei!
\q1 
\v 4 Galewa ewapuripurina eai, ia au hedebasaei,
\q2 eo goila hinage galewa ewana eai!
\q1 
\v 5 GUIAU esana taba isi se hedebasaei,
\q2 paana ia ie riba arinai ede isi wa se tubu.
\q1 
\v 6 Ia i hetorodi i lau e, nige nosina,
\q2 adi sigasiga laugagaeona ie tore, taba nige se dioi.
\b
\q1 
\v 7 Tanoubu eai GUIAU au hedebasaei:
\q2 omi gabogabo taumia nabunabutuadi, eo gabotum gamagarina hinage,
\q1 
\v 8 oeagi alaalasi, nabu tupitupina, \tl snow\tl* eo madagau,
\q2 mana lailai woworina ia ena riba se hemamohoiei!
\b
\q1 
\v 9 Oea tupidi lailaidi eo gagiridi,
\q2 oeagi uauadi, maruai oeagidi gamagaridi,
\q1 
\v 10 nuura saraidi eo bulumakau gamagaridi,
\q2 ginauri se daladalausi eo manu loiloiusidi!
\b
\q1 
\v 11 Tanoubu wasawasadi eo tatao gamagaridi,
\q2 eanua guiaudi eo tanoubu tauheduhedudurai gamagaridi!
\q1 
\v 12 Hewari eo hasara gamagaridi maediyao,
\q2 tautaubada eo merumeru!
\b
\q1 
\v 13 Isi GUIAU esana bena se hedebasaei,
\q2 paana iabom esana i sae ariri;
\q2 ia ana tepo lolona tanoubu eo galewa i saetawatawaidi.
\q1 
\v 14 Ia ena boda tataodi edi dona i lauisini,
\q2 ena taumiatahitahi tataodi gamagaridi edi aba‐hedebasaena,
\q2 Isaraela bodana isi ede ia gegesina eai wa.
\q1 GUIAU au hedebasaei!
\c 150
\s1 GUIAU se hedebasaei
\q1 
\v 1 GUIAU au hedebasaei!
\q2 Eaubada ena abamia tabuna eai bena ia au hedebasaei,
\q1 ena galewa tehana gigiborina eai ia au hedebasaei!
\q1 
\v 2 Ena laulau gigiboridi debadi eai ia au hedebasaei,
\q2 ena gigibori saesae‐aririna debana eai ia au hedebasaei!
\b
\q1 
\v 3 Bogigi dagudaguguna eai ia au hedebasaei,
\q2 huelele eo baubau aridi eai ia au hedebasaei!
\q1 
\v 4 Boiatu eo saga aridi eai ia au hedebasaei,
\q2 huelele au iuhi eo baubau au oioini aridi eai ia au hedebasaei!
\q1 
\v 5 Pate aridi eai ia au hedebasaei,
\q2 pate au oihelaidi abo arinai ia au hedebasaei!
\q1 
\v 6 Ginauri gamagaridi se eahueahua bena ia se hedebasaei!
\q1 GUIAU au hedebasaei! 
