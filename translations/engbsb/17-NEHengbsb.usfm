\v 19 \w Moreover|strong="H1571"\w*, \w these|strong="H6440"\w* nobles \w kept|strong="H1961"\w* reporting \w to|strong="H3318"\w* \w me|strong="H6440"\w* \w Tobiah|strong="H2900"\w*’s \w good|strong="H2896"\w* \w deeds|strong="H1697"\w*, \w and|strong="H7971"\w* \w they|strong="H1697"\w* relayed \w my|strong="H7971"\w* \w words|strong="H1697"\w* \w to|strong="H3318"\w* \w him|strong="H6440"\w*. \w And|strong="H7971"\w* \w Tobiah|strong="H2900"\w* \w sent|strong="H7971"\w* letters \w to|strong="H3318"\w* intimidate \w me|strong="H6440"\w*.   
\c 7  
\s1 Securing the City  
