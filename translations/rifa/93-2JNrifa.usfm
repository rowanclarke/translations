\id 2JN
\h 2 يُوحَانَّا 
\toc1 2 يُوحَانَّا 
\toc2 2 يُوحَانَّا 
\toc3 2 يُوح. 
\mt1 2 يُوحَانَّا  
\c 1
\m
\v 1 \bd أَمْغَارْ، إِ ثْمطُّوثْ إِتّْوَافَارْزنْ ذ ثَارْوَا نّسْ\bd*، إِنِّي تّخْسغْ ذِي ثِيذتّْ، وَارْ إِدْجِي نشّْ وَاهَا، مَاشَا عَاوذْ قَاعْ إِنِّي إِسّْننْ ثِيذتّْ،  
\v 2 ذِي طّْوعْ ن ثِيذتّْ إِ ذَايْنغْ إِزدّْغنْ ؤُشَا أَذْ كِيذْنغْ ثِيڒِي إِ ڒبْذَا:  
\v 3 أَرْضَا ذ أَرّحْمثْ ذ ڒهْنَا أَذْ كِيذْنغْ إِڒِينْ زِي أَربِّي، بَابَاثْنغْ، ؤُ زِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، مِّيسْ ن بَابَاسْ، ذِي ثِيذتّْ ؤُ ذِي ثَايْرِي. \f ◼ \fr 1:‏3 \ft \+bd ’كِيذْنغْ‘\+bd* - مَارَّا إِرِيسْفُوسنْ (ڒْْمَاخْطُوطَاثْ) غَارْسنْثْ ’أَكِيذْنغْ‘، مْغِيرْ ذِي ثكْسْثُوسْ رسبْثُوسْ نتَّافْ ’أَكِيذْومْ‘.\f*   
\b  
\m
\v 4 أَقَا فَارْحغْ أَطَّاسْ ؤُمِي ؤُفِيغْ جَارْ ثَارْوَا نّمْ شَا إِنِّي إِڭُّورنْ ذِي ثِيذتّْ، أَمْ مَامّشْ ثَاوْصيّثْ نِّي نكْسِي زِي بَابَاثْنغْ.  
\v 5 ؤُشَا ڒخُّو تّتَّارغْ أَمْ، \add أَ\add* ثَامطُّوثْ، وَارْ إِدْجِي أَخْمِي ذ أَمْ ؤُرِيغْ ثَاوْصيّثْ ن جْذِيذْ، مَاشَا ثنِّي أَقَا-ت غَارْنيْ زڭْ ؤُمزْوَارُو: أجّْ أَنغْ أَذْ نخْسْ أَيَاوْيَا. \x ◘ \xo 1:‏5 \xt يُوح. 13‏:‏34؛ 15‏:‏12؛ Efez؛ 5‏:‏2؛ 1 تس. 4‏:‏9؛ 1 بُط. 4‏:‏8؛ 1 يُوح. 2‏:‏7؛ 3‏:‏23؛ 4‏:‏21. \x*  
\v 6 ثَا ذ ثَايْرِي، أَقَا أَذْ نُويُورْ عْلَاحْسَابْ ثِيوصَّا نّسْ. ثَا ذ ثَاوْصيّثْ أَمْ مَامّشْ إِ ثسْڒِيمْ زڭْ ؤُمزْوَارُو، أَقَا إِتّْخصَّا أَذْ ثُويُورمْ ذَايسْ. \x ◘ \xo 1:‏6 \xt يُوح. 15‏:‏10. \x*   
\b  
\m
\v 7 مِينْزِي أَطَّاسْ ن إِخدَّاعنْ ؤُذْفنْ غَارْ دُّونشْثْ، إِنِّي وَارْ إِشهّْذنْ شَا إِ ثْوَاسِيثْ ن يَاسُوع لْمَاسِيحْ ذِي دَّاثْ. ذ وَا ذ أَخدَّاعْ ذ أَمْضِيدّْ ن لْمَاسِيحْ. \x ◘ \xo 1:‏7 \xt مت. 24‏:‏5، 24؛ 2 بُط. 2‏:‏1؛ 1 يُوح. 4‏:‏1. \x*  
\v 8 حْضَامْ إِخفْ نْومْ، حِيمَا وَارْ ثْخسَّارمْ شَا مِينْ خفْ ثْخذْممْ كنِّيوْ، مَاشَا أَذْ ثَاوْيمْ ڒْمُونثْ ثْمُونْ.  
\v 9 مَارَّا ونِّي إِ غَا إِخْضَانْ ؤُشَا وَارْ إِقِّيمْ شَا ذِي ثْغُورِي ن لْمَاسِيحْ، وَارْ غَارسْ بُو أَربِّي ذڭْ يِيخفْ نّسْ. ونِّي إِ غَا إِقِّيمنْ ذِي ثْغُورِي نّسْ، أَقَا غَارسْ بَابَاسْ ذ مِّيسْ  
\v 10 مَاڒَا يُوسَا-د غَارْومْ شَا ن إِجّنْ ؤُشَا وَارْ د-يِيوِي شَا ثَاغُورِي-يَا، خنِّي وَارْ ث قبّْڒمْ ذِي ثَادَّارْثْ \add نْومْ\add*، وَارْ زَّايسْ أَرحّْبمْ. \x ◘ \xo 1:‏10 \xt رُوم. 16‏:‏17؛ 2 تِيم. 3‏:‏5؛ ثِيث. 3‏:‏10. \x*  
\v 11 مِينْزِي ونِّي خَاسْ إِ غَا يَارحّْبنْ، غَارسْ أَمُونِي أَكْ-ذ ڒخْذَايمْ نّسْ ثِيعفَّانِينْ.   
\b  
\m
\v 12 أَقَا غَارِي أَطَّاسْ إِ ذ أَومْ غَا أَرِيغْ، مَاشَا ثُوغَا وَارْ خْسغْ أَذْ ث أَرِيغْ ذِي ثوْرِيقْثْ س سّْمخْ، مَاشَا سِّيثِيمغْ أَذْ غَارْومْ د-أَسغْ، حِيمَا أَذْ كِيومْ سِّيوْڒغْ زڭْ ؤُقمُّومْ غَارْ ؤُقمُّومْ، حِيمَا ڒفْرَاحثْ نّغْ أَذْ ثِيڒِي ثكْمڒْ.   
\m
\v 13 ثَارْوَا ن ؤُتْشْمَامْ إِتّْوَافَارْزنْ، تّْسدْجَامنْ خَامْ س ڒهْنَا. أَمِينْ.   