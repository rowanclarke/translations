\p
\v 1 \w The|strong="H6213"\w* \w Lord|strong="H3068"\w* \w came|strong="H3068"\w* \w to|strong="H1696"\w* \w help|strong="H6213"\w* \w Sarah|strong="H8283"\w* \w as|strong="H6213"\w* \w he|strong="H6213"\w*'d \w said|strong="H1696"\w* \w he|strong="H6213"\w* \w would|strong="H3068"\w*. \w The|strong="H6213"\w* \w Lord|strong="H3068"\w* \w did|strong="H6213"\w* \w for|strong="H6213"\w* \w Sarah|strong="H8283"\w* \w what|strong="H6213"\w* \w he|strong="H6213"\w*'d \w promised|strong="H1696"\w*.  
