\id JUD
\h AR HUDA
\toc1 AR HUDA Ar he̱ꞌmi bi ꞌyotꞌa ar Huda
\toc2 AR HUDA
\toc3 Jud.
\mt1 AR HUDA
\mt2 Ar he̱ꞌmi bi ꞌyotꞌa ar Huda
\c 1
\s1 Ar nze̱ngwa
\p 
\v 1 Nuga dar Huda, ár ꞌbe̱gogi ar tsi Hmu Hesukristo ne ár jödö ar Hakobo. Di pe̱ñꞌahu̱ nunar he̱ꞌminu̱ nuꞌahu̱ xi zoñꞌahu̱ da tꞌaxkꞌahu̱ Jö ar Dada, ne xi hwixꞌahu̱ har tsi Hmu Hesukristo.
\p 
\v 2 Dá hñuxa ár nhwëki, ár hogamꞌu̱i ne ar mhöte ꞌraꞌahu̱ Jö.
\s1 Ya kate utate ne yá tsꞌontꞌuti
\r (2 Pedro 2:1‑17)
\p 
\v 3 Tsi kuhu̱, xa di ne ga pe̱ñꞌahu̱ nꞌar he̱ꞌmi habu̱ ga xiꞌahu̱ nunar ñꞌemu̱i di pe̱ꞌsu̱. Ha di handi mꞌe̱tꞌo, mahyoni ga xiꞌahu̱ xa gi umba ri mu̱ihu̱ gi ñöñhu̱ nunar ñꞌemu̱i nꞌagitho bi tꞌakagihu̱.
\p 
\v 4 Ngetho xi yu̱tꞌa ñꞌöntho ꞌra ya tsꞌojöꞌi ju̱mpa ár nhwëki Jö da ꞌyo̱tꞌa nöꞌö te gatho neꞌu̱. Nuyu̱ yanu̱ mamꞌe̱tꞌo xi tꞌe̱ntꞌi da mꞌe̱di, ne ko̱nga Jö togo ar ndö xo̱ge, ne ko̱nga ma tsi Hmuhu̱ Hesukristo.
\p 
\v 5 Di ne ga beñꞌahu̱ nöꞌö mamꞌe̱tꞌo xka pöhu̱: Núꞌmu̱ ar tsi Dada ba ju̱ka ya me Israel mi njapi nda mpe̱ ntsꞌe̱di núnu̱ Ehipto, mꞌe̱fa bi hyo gatho nuꞌu̱ togo himbi ñꞌemu̱ibi.
\p 
\v 6 Ha nuya e̱nxe̱ himbi su yá nsu xki tꞌumbabi, bi zopꞌu̱ yá ngu habu̱ mi ꞌbu̱ꞌu̱, nupya Jö xi gotꞌa har ꞌbe̱xui, ne xi nthötꞌi to̱ꞌmtho da zo̱nga ar pa da thöꞌspa majöni.
\p 
\v 7 Ngu ar Sodoma, ar Gomora ne nu maꞌra ya hnini mi ja ha yá nthetꞌiyu̱, nuꞌu̱ nꞌehe mi hye̱pꞌu̱ Jö, ho̱nse̱ mi ne nda ꞌyo̱tꞌa gatho nöꞌö mi ne yá ndoꞌyo, ne ya ndo̱ mi ꞌbe̱ngwi yá mindo̱wi. Ngu nꞌar ntꞌudi bi tꞌe̱ntꞌa har tsibi hiñhamꞌu̱ da götsꞌi. Njanu̱ utkagihu̱ tengu ár mfe̱i Jö.
\p 
\v 8 Nuya tsꞌojöꞌiyu̱ ngu ꞌwithötho, ngu nu maꞌra xta möñhu̱ hingi tsupa Jö, tsanga gatho nuꞌu̱ ja yá tsꞌe̱di, ne hyaxꞌmu̱ tsꞌoka yá ndoꞌyo.
\p 
\v 9 Nunar ndö e̱nxe̱ Mige, núꞌmu̱ mi nwengwi ar tsꞌondöhi togo nda gohwi ár ndoꞌyo ar Moise, himbi ꞌya̱pa nꞌar ntꞌa̱di. Ho̱nse̱ bi ꞌñembabi: Ar tsi Dada da zu̱ꞌaꞌi.
\p 
\v 10 Ha nuya tsꞌojöꞌiyu̱ tsanga gatho nöꞌö hingi pödi. Ha nöꞌö pödi, ngu ya me̱ti hiñꞌotho yá mfeni, o̱tꞌa gatho nöꞌö neꞌu̱. Njapꞌu̱ japa da tsꞌoka yá te.
\p 
\v 11 Hwëkateꞌu̱, ngetho xi de̱mbatho ár ꞌbe̱fi ar Kain, ne bi ñꞌe̱ntꞌatho da dö ar bojö ngu ar Balam. Nuyu̱ ma da nhwata ngu ar Kore, ngetho xa ya me̱ꞌsku.
\p 
\v 12 Nuya jöꞌiyu̱ nꞌar mꞌe̱tsa̱ gi nthöskwihu̱ núꞌmu̱ gi ñungwihu̱ mahye̱gi ya hmöka ku. Hiñꞌotho yá tsa̱yu̱, honse̱ yá ñho. Ñhe̱hwi ya ꞌbikui tuxta ar ndöhi, ngu ya ꞌba̱iza núꞌmu̱ ndöbëhë hinti unga te da tsꞌi, yoꞌgi xi du ne yoꞌgi xi nkꞌu̱tsꞌi xi tꞌe̱mpꞌu̱.
\p 
\v 13 Nuyu̱, njangu nuya dehe mpu̱ntsꞌi ne tuxa ár fu̱gi bi e̱nga har ñönthe, njapꞌu̱ nheki yá tsꞌoki ꞌbe̱ yá tsa̱, ngu ya tso̱ nixtꞌi xi tꞌe̱ntꞌi da mꞌe̱ har ꞌbe̱xui.
\p 
\v 14 Ar Enok ár yoto mꞌu̱i yá ma̱ngaꞌbe̱to ar Adan, bi ꞌñeñꞌö mamꞌe̱tꞌo: Hyanthu̱ ba ehnu̱ ar tsi Hmu ñꞌowi nuꞌu̱ ra nze̱ye̱ ya nthebe ya nthebe nuꞌu̱ yá me̱tiꞌö.
\p 
\v 15 Ne da hñöꞌspa majöni gatho ya jöꞌi, ne da hñuꞌmba yá hmi ya tsꞌojöꞌi da uta gatho nuya tsꞌoki xi ꞌyo̱tꞌe, ne gatho nöꞌö xi tso̱tꞌwa ár mu̱i Jö mi ho̱xa ya tsꞌomhö.
\p 
\v 16 Nuya jöꞌiyu̱ gatho tsa̱mañꞌu̱ ne gatho ñömañꞌu̱, ne da ꞌyo̱tꞌa gatho nöꞌö neꞌu̱, xa ñꞌexase̱ ne ka ya jöꞌi da zipyá bojö.
\s1 Ar tsꞌu̱i ne ar humamu̱i
\p 
\v 17 Ha nuꞌahu̱ ma tsi kuhu̱, beñhu̱ xiñho nuya mhö bi mönga mahamꞌu̱ yá mpo̱te ma tsi Hmuhu̱ Hesukristo.
\p 
\v 18 Nuya mhö bi xiꞌahu̱: Nu ha ya ngöxapa ma da nja ya hya̱te jöꞌi, ma da mꞌu̱ꞌu̱ ngu xipabi yá tsꞌomfeni.
\p 
\v 19 Gehyu̱ heka ya ku, te̱mnda yá ꞌbe̱fi ar ximha̱i, ngetho hinxi me̱ꞌspa ár Hñö Jö.
\p 
\v 20 Hö, tsi kuhu̱, umba ri mu̱ihu̱ da te ri ñꞌemu̱ihu̱, ne zohu̱ ar tsi Dada, di tsixꞌahu̱ ár Hñö Jö.
\p 
\v 21 Yo ma gi hye̱hu̱ nunar mhöte xi ꞌrakagihu̱ Jö, ne hyaxꞌmu̱ gi to̱ꞌmhu̱ ár nhwëki ma tsi Hmuhu̱ Hesukristo da ꞌraꞌahu̱ ar te hiñhamꞌu̱ da götsꞌi.
\p 
\v 22 Nuꞌmu̱ gi hyanthu̱ ꞌra ya ku hingi ñꞌemu̱i xiñho, fa̱xu̱ da te yá jamfi.
\p 
\v 23 Maꞌra fa̱xu̱ da mpo̱ho̱, ne njapꞌu̱ gi tsiñhu̱ hinda ma har tsibi. Maꞌra hwëju̱, ho̱nse̱ ntsuñhu̱ yo ma gi te̱mfu̱ yá tsꞌoki. U̱tsahu̱ ar tsꞌoki ne yá dutu xi tsꞌonga nuya ꞌyo̱tꞌatsꞌokiyu̱.
\s1 Ya ngöxa mhö tꞌeꞌspa ár nsu Jö
\p 
\v 24 Jö togo pe̱ꞌsa ar tsꞌe̱di da sugagihu̱, ne hinda hye̱gagihu̱ ga ꞌwehu̱, xa di johyanu̱ da zixkagihu̱ xintꞌaxigihu̱ hár nsunda.
\p 
\v 25 Gehnu̱ pe̱ꞌsa ar mfödi, ne ho̱nse̱nu̱ Jö ne ma Po̱ho̱tehu̱. Dá nhutꞌwabiꞌö ár nsunda. Dá nhumansubi ár tsꞌu̱tꞌwi ne ár tsꞌe̱di, ne da tꞌeꞌspa ár nsupya, ne hiñhamꞌu̱ da götsꞌi. Dá njapꞌu̱.
