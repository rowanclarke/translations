\v 14 \w I|strong="H3808"\w*, \w Yahweh|strong="H3068"\w*, \w have|strong="H3068"\w* \w said|strong="H1696"\w* \add that I will surely punish you\add*. \add And it is time\add* \w for|strong="H6213"\w* \w me|strong="H6213"\w* \w to|strong="H1696"\w* \w do|strong="H6213"\w* \w that|strong="H3068"\w*. \w I|strong="H3808"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w change|strong="H5162"\w* \w my|strong="H3068"\w* \w mind|strong="H5162"\w*; \w I|strong="H3808"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w refrain|strong="H3808"\w* \w from|strong="H3068"\w* punishing \w you|strong="H6213"\w*, \w and|strong="H3068"\w* \w I|strong="H3808"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w pity|strong="H2347"\w* \w you|strong="H6213"\w*. \w I|strong="H3808"\w* \w will|strong="H3068"\w* \w judge|strong="H8199"\w* \w you|strong="H6213"\w* \add and punish you\add* \w as|strong="H6213"\w* \w you|strong="H6213"\w* deserve \w to|strong="H1696"\w* \w be|strong="H3808"\w* punished \w for|strong="H6213"\w* \w your|strong="H3068"\w* sinful \w behavior|strong="H1870"\w*. \add That will surely happen because\add* \w I|strong="H3808"\w*, \w Yahweh|strong="H3068"\w* \w the|strong="H5002"\w* \w Lord|strong="H3068"\w*, \w have|strong="H3068"\w* \w said|strong="H1696"\w* \w it|strong="H6213"\w*.” ’ ”   
