\id XXA - Matupi Chin Standard Bible
\h MATU CHRISTIAN WORSHIP HYMNAL
\toc1 Matu Christian Worship Hymnal
\toc2 Matu Laa Bu
\toc3 Mtb
\c 1
\s1 Sosang Koek ah Pathen
\s2 To God be The Glory
\sp Doh is Ab
\q1 
\v 1 Sosangkoek ah Pathen thangthen la om saeh.
\q1 Diklai a thintloh na tih capa te m'paek.
\q1 Tholh khodakngai hamla a hingnah a paek,
\q1 Hlang boeih ham hingnah thohka te a ong coeng
\q2 \qt Boeipa te koeh uh lah \qt*
\q2 \qt diklai hman hlang boeih loh\qt*
\q2 \qt Boeipa te koeh uh lah \qt*
\q2 \qt lai hlang boeih omngaih uh\qt*
\q2 \qt Capa Jesuh tang nah Pathen taengla mael \qt*
\q2 \qt Soeprhaep saikung Pathen te thangthen uh lah \qt*
\q1 
\v 2 Khangnah soep sak hamla a thisen neh n'lai
\q1 a ka tangnah boeih taengah Pathen olkam
\q1 Hlang tholh koek la om dae a ka tangnah rhoek tah
\q1 Jesuh kah tholh khodawkngainah te a dang.
\q1 
\v 3 A sai hluen kawng boeih te mamih tukkil tih,
\q1 Capa Jesuh ah omngaihnah soep taaep.
\q1 Tedae Jesuh muei hmuh u koep vaengah tah
\q1 kopoekrhai omngaihnah te hmuh uh pawn ni.
\c 2
\s1 Kai Aka Dawn Lungnah Boei
\s2 The King of Love My Shepherd Is
\sp Doh is G
\q1 
\v 1 Kai aka dawnkung lungnah boei,
\q1 A then na loh bawt pawh.
\q1 Ka taeng a om a tah ka vawt pawh,
\q1 A mah dung yan kai ham ni.
\q1 
\v 2 Hing nah tuisip a long na ah,
\q1 Ka mueihla te a mawt,
\q1 Rhamtlim sai noe na ah n'caeh puei tih
\q1 Vaan dong buh te khaw mpaek bal.
\q1 
\v 3 Hlang tholh la ka pam ka dah dae,
\q1 A lung hla na loh n'tlap koep.
\q1 A laeng pang neh n'kop tih kai yalh sak,
\q1 Omngaihnah im khui la n'khuen.
\q1 
\v 4 Dueknah long hoi ah ka rhih pawh,
\q1 Ka taeng ah a mah om.
\q1 A cong hol loh ka ngaih ham mong sak.
\q1 A thing lam loh long'e puei n'tueng.
\q1 
\v 5 Ka hmai ah ca boei nan phaih tih,
\q1 yoethen ngaimong nah m'paek
\q1 Me tluk lam lae kai ka omngaihnah ,
\q1 Na boeng dong lam ka long te
\c 3
\s1 Vaan Ram Manghai Boei
\s2 O Worship the King
\sp Doh is G
\q1 
\v 1 Vaan ram manghai boei hinyahnah pae uh,
\q1 A boeilen nah tah laa then neh koeh uh.
\q1 Mamih kah Pathen neh aka hlipdah kung,
\q1 Dungyan a ka om manghai boei neh Pathen
\q1 
\v 2 A thaom nah neh lungvatnah thui uh,
\q1 A himbai bok loh hno then boeih a dah.
\q1 A thinsa khomai rhaek la tla tih ha lo,
\q1 Diklai hlangtholh rhoek boeih ol a caek pawn ni.
\q1 
\v 3 Nan dawn dah nah he ol neh thui lek pawh,
\q1 Yilhding lah na cu khomik la na sae.
\q1 Tlang som long langdai due tui sih la na long,
\q1 Rhotui then neh dam tui dingsuek la na long.
\q1 
\v 4 Ca moe yongdik bang diklai hlang boeih loh,
\q1 Nang bueng kan uep nah nan thai na tlaih pawh.
\q1 Lungvat sitloh nah a bawt due la phat cak,
\q1 Sai kung neh khangkung paya then la na om.
\c 4
\s1 Soeprhaep Saiikung Manghai
\s2 Praise and Magnify Our King
\r Tgt 34. 3
\sp Doh is C
\q1 
\v 1 Soeprhaep sai kung manghai boeipa la om.
\q1 Tho lam laa sa, Tho lam laa sa
\q1 A kho kung ah kuep doe ah bawk boeih uh.
\q1 manghaiboei thangthen uh lah
\q1 \qt So ben kah ming thang nah, \qt*
\q1 \qt A lung nah phong boeih uh.\qt*
\q1 \qt Boeilen koek boeipa a sang la koeh uh\qt*
\q1 \qt Kopoek rhai boeilen nah, \qt*
\q1 \qt Na ol then neh koeh uh\qt*
\q1 \qt Manghaiboei te koeh uh lah.\qt*
\q1 
\v 2 A ol khueh neh soeprhaep boeih a coeng sak
\q1 Tho lam laa sa, Tho lam laa sa
\q1 Soeprhaep boeih ah a na khueh kung boeipa
\q1 manghaiboei thangthen u lah.
\q1 
\v 3 Boeilen boeipa taeng tha hlue la ha lo
\q1 Tho lam laa sa, Tho lam laa sa
\q1 Hlang phun soep rhaep omngaih doe ha lo uh
\q1 manghaiboei thangthen uh lah.
\q1 
\v 4 Boeilen boeipa a ming cim te koeh uh
\q1 Tho lam laa sa, Tho lam laa sa
\q1 Vaanhlang he hlang hing boeipa kopoek rhai
\q1 manghaiboei thangthen uh lah.
\c 5
\s1 Kaimih Boeih Kah Pathen
\r Now Thanks We All Our God
\sp Doh is F
\q1 
\v 1 Kai mih boeih kah Pathen, thin ko boeih neh kan koeh.
\q1 Ko poek rhai hno na saii loh, diklai loh omngaih coeng.
\q1 A nu pum lam kah tong tih, ka hmai long ah yoe then soep
\q1 Tihnin due ah lung nah, toek lek toek na nan tueng.
\q1 
\v 2 Soeprhaep cungkuem Pathen, ka hing khui ha yoei lah
\q1 Om ngaih ngai mong na boeih neh, kai mih hloep hloei bal lah.
\q1 Na lung vat nah neh khoem bael, ngai hmang na ah long n'tueng.
\q1 Diklai neh vaan rhainah, lam kah n'loeih sak uh lah.
\q1 
\v 3 Om ngaih koeh na boeih he, Pa taeng ah boeih pae uh
\q1 Vaan dongah tloengkhoelh Capa, neh a ka om hmaih boeih.
\q1 Lai neh vaan dong loh a bawk, dungyan Pa Pathen te
\q1 Tahae lam ka loh bawt, pat mueh la cak ngai saeh.
\c 6
\s1 Aw ol neh ka thui thai lek pawh
\s2 Oh Could I Speak
\sp Doh is Eb
\q1 
\v 1 Aw ol neh ka thui thai lek pawh.
\q1 Khangkung boei kah boeilennah te
\q1 ka phong thai van a ya.
\q1 Ol khueh neh vaan dong ka ben tih,
\q1 Gabriel kah laa sak ol ka rhoi ni ni.
\q1 A boeilen nah ka thui
\q1 A boeilen nah ka thui.
\q1 
\v 2 Thi sen tholh phu ah a hawk te,
\q1 Kai n'tlan dongah thangthennah laa
\q1 then koek mai ka sa ni.
\q1 A boeilennah neh a dueng na ah
\q1 Ka soep ve tih bai bok ka bai ni
\q1 Ka mueihla omngaih ni
\q1 Ka Muei hla omngaih ni.
\q1 
\v 3 A moei a boe te ka koeh ni
\q1 Lungnah neh thoeih cam tih a boei,
\q1 ngol hmuen ah aka ngol,
\q1 phungding laa then neh
\q1 ka Ka soep ve tih koeh vetih
\q1 Kho kum kho hal ka thangpomnah he,
\q1 Hlang boei ka ming sak ni,
\q1 Hlang boeih ka ming sak ni.
\q1 
\v 4 A lumim la n'loh na hnin te,
\q1 Me tluk lam lae omthen omyal
\q1 ngaimong a soep pawn eh,
\q1 Tlankung boei neh huiko manu ca,
\q1 hum soep la dungyan khon'sak uh ni,
\q1 Ta hlang la om uh ni,
\q1 Ta hlang la om uh ni.
\c 7
\s1 Tangnah hna neh ka yak vaengah
\s2 How Sweet the Name
\sp Doh is Bb
\q1 
\v 1 Tangnah hna neh ka yak vaengah
\q1 Jesuh ming then tangkik.
\q1 Kothae a hloep boengha a hoeih sak,
\q1 long puei tueng kung ni.
\q1 
\v 2 Mueihla tloh kaem nah a hoeih sak,
\q1 Ngaihmang ngai ham mong sak.
\q1 Bungpong hamla hingnah
\q1 manna neh ngaiuepnah then ni.
\q1 
\v 3 Ming then lung nu ah im ka sak,
\q1 Patling neh ka ying nah,
\q1 Ka la kueng tlaih pawh,
\q1 a lung vat nah a baetawt dong ah.
\q1 
\v 4 Jesuh kai dawn kung paya then,
\q1 Khosoih tong hma boei koek,
\q1 Boeipa, ka long puei,
\q1 ka hing soep nah, kan koeh na doe lah.
\c 8
\s1 Pathen lungvat tuibap bangla
\s2 Come Thou Font
\sp Doh is Eb
\q1 
\v 1 Pathen lungvat tuibap bangla,
\q1 nan thintlohnah laa ka sak.
\q1 Nan lung nah tuiva bangla long,
\q1 thangthennah laa ka sa ni.
\q1 Na mah koeh nah laa then koek
\q1 vaan hlang bangla sak sak lah.
\q1 Nan lung vat nah tlang bang la sang,
\q1 ke tlang dong ah m'pha sak lah.
\q1 
\v 2 Eben nezar tlang dong ah ke
\q1 nan sitlohnah muei ka hm uh.
\q1 Sading la im ka pha nah ham,
\q1 na then nah bueng ka uep nah.
\q1 long hmang la sut ka om vaeng,
\q1 Boei Jesuh loh kai he n'tlap.
\q1 Duem nah lam kah kai tlan ham la,
\q1 A thisen tlo na hawk coeng.
\q1 
\v 3 Nan lungvatnah lai ka ba tih,
\q1 hnin takuem ah ka dawn yai.
\q1 Boeipa nang kah na thennah te,
\q1 ka ko dang khui ah hong sak,
\q1 Thintlo Pathen poek kolla
\q1 Hlangpam padah la ka om
\q1 Na kongaih bangla hno nah lah,
\q1 Na vaan im due la mawt lah.
\c 9
\s1 Pathen kah hlang thoo uh
\s2 Oh Rise Man of God
\sp Doh is Bb
\q1 
\v 1 Pathen kah hlang thoo uh
\q1 A bi te bi uh lah.
\q1 Boeipa te lungbuei mueihla
\q1 tha om na boeih hing nah pae uh.
\q1 
\v 2 Pathen kah hlang thoo uh,
\q1 A ram long tah dangka,
\q1 Tholh yin kah manuca te
\q1 omngaihnah khosae la khuen lah.
\q1 
\v 3 Pathen kah hlang tho uh,
\q1 Khrih hlang boel loh nang rhing,
\q1 A tha hoeng la a om
\q1 sut vaengah tho lam nag bi bi.
\q1 
\v 4 Khrih thing lam te kawt uh,
\q1 A kho laeh ke thuih uh,
\q1 Hlang hing ca pa ma nu ca ni,
\q1 Pa then kah hlang tho uh.
\c 10
\s1 Tlankung Koehnah Laa Ka sa ni
\s2 My Redeemer
\sp Doh is Ab
\q1 
\v 1 Tlankung koehnah laa ka sa ni.
\q1 Kopoekrhai a lungvatnah.
\q1 Thinglam dong kah pa tang nah loh,
\q1 kosi khui lam kah loeih sak.
\q1 \qt Boeipa thanngthen nah laa sa uh.\qt*
\q1 \qt thangthen nah laa te ka sai ni \qt*
\q1 \qt A thi sen nen te n'tlan coeng \qt*
\q1 \qt Thing lam tai nah te a ueh tih, \qt*
\q1 \qt Ka tholhnah boeih a sah coeng. \qt*
\q1 
\v 2 Kopoekrhai cil ol ka thui ni,
\q1 Ka hma na lamkah n'tlan nah.
\q1 A lung vat nah a ka len koek
\q1 a yoe la te a tlan coeng.
\q1 
\v 3 Ka lungnah tlankung ka koeh ni,
\q1 A thaomnah ka thui ni.
\q1 Hell ram dueknah tholhnah boeih boeih
\q1 tanah tah kai he ‘mpaek coeng.
\q1 
\v 4 Tlankung koehnah laa ka sa ni,
\q1 A van dong ka lungnah te.
\q1 Dueknah lamkah hingnah la mawt
\q1 Pathen capa neh om sak.
\q1 Boeipa thangthen nah laa saa uh.
\c 11
\s1 A cim A cim A cim
\s2 Holy Holy Holy
\sp Doh is Eb
\q1 
\v 1 A cim A cim A cim a so sang koek Pathen
\q1 min cang lam kah koeh nah laa na taeng ham pha saeh
\q1 A cim A cim A cim lung vat kung tha om
\q1 Pum khat Pathen Pa Capa Cim Muei hla.
\q1 
\v 2 A cim A cim A cim hlang cim rhoek loh nang m'bawk
\q1 a sui lumuek tui tun li taeng due a khueh uh,
\q1 Che rubim neh Serphim na hmai ah kuep uh,
\q1 Dungyan Pathen nang yoeyah la koeh uh.
\q1 
\v 3 A cim A cim A cim yin nah loh hlip ca khaw,
\q1 hlang tholh rhoek loh na boei mang hmu uh pawt cakhaw,
\q1 Na mah bueng ni A Cim hlang cim tloe om pawh,
\q1 tha om nah lung nah cim na soep Pathen then.
\q1 
\v 4 A cim A cim A cim a so sang koek Pathen
\q1 Na mah ming te lai neh van hlang boeih loh koeh uh.
\q1 A cim A cim A cim hlang rhen kung Pathen
\q1 thum soep Pathen Pa Capa CimMuei hla.
\c 12
\s1 Ka Mueihla Hnatun Lah
\s2 Hark Hark My Soul
\sp Doh is D
\q1 
\v 1 Ka mueihla hnatun lah vaan dong hlang laa sak
\q1 Diklai mol voel tuitunli due la thang.
\q1 Didip tang kik oltak yoethen a thuivaeng,
\q1 Hing nah thai dong ah tholhnah om voel pawh.
\q2 \qt Vaan hlang laa sak uep om nah a tueng sak uh.\qt*
\q2 \qt Vaan ol soep neh mamih taeng han sak uh.\qt*
\q2 \qt Hlaem ben rhahnah min cang omngaihnah then koek \qt*
\q2 \qt Kho yin nah te lung nah loh a vang sak.\qt*
\q1 
\v 2 A hla hlang kah hlaemben darkhing ol bang la,
\q1 Jesuh ol thang tuitun mol tlang due thang.
\q1 Toeklek toekna tholh hnorhih loh a nan hlang
\q1 Tu dawn boeipa na mah taeng ah ka bal.
\q1 
\v 3 Hmai ben la cawh ta hae laa ol yak vaengah,
\q1 Kho daeng pa tang khang hlang boeih ha lo uh.
\q1 Kho yin nah khui ah Jesuh a mah loh ng'khue
\q1 Im then la mawt kung omngaih ol thangthen.
\q1 
\v 4 Kothaenah tue ta hae ah sen mai cakhaw,
\q1 Khoyin khum tih omngaihnah kho sae ni,
\q1 Patang rhoek nah long puei a bawt vaengah
\q1 Mueihla ngaimongnah sui khopuei mpha pawn ni.
\c 13
\s1 Hlang Cim Rhoek Dan Lah
\s2 Crown Him
\sp Doh is F
\q1 
\v 1 Hlang cim rhoek dan lah om then nah,
\q1 Kothae patang khang hlang ke.
\q1 A rhal rhoek boeih ke a na tih
\q1 Hlang boeih boeih loh bawk uh saeh.
\q1 \qt Boeilen lumuek muek sak uh lah\qt*
\q1 \qt Khang kung boeipa manghai boei, \qt*
\q1 \qt Boeilen lumuek muek sak uh lah \qt*
\q1 \qt khang kung manghai boeipa te. \qt*
\q1 
\v 2 Khang kung boei ke muek sak uh lah,
\q1 Rhal tuk nah boeih a ta coeng.
\q1 Boeilen ngol hmuen dong ah ngol sak
\q1 vaan hlang rhoek loh a om puei
\q1 
\v 3 Tholh ca rhoek loh hling a muei sak,
\q1 Khang kung boei a thae kha nah.
\q1 Hlang cim neh vaan hlang loh
\q1 a vael a ming boeilen a koeh uh.
\q1 
\v 4 A ming koeh nah laa ol ya lah
\q1 phung ding ol rhoi neh a koeh.
\q1 Boei Jesuh ke a pom sang uh
\q1 omngaih puei ham om tang kik.
\c 14
\s1 Sui Rhuisam Khrih Manghai
\s2 Crown Him King
\sp Doh is G
\q1 
\v 1 Sui rhuisam Khrih manghai boei khuem sak,
\q1 Kumhal bawt mueh la thangthen uh sih.
\q1 A ming rhuep om a hinyah nah kap,
\q1 kum hal bawt pat mueh la.
\q1 \qt Muek sak uh sih muek sak uh sih \qt*
\q1 \qt boeilen nah seng pahrang lumuek te, \qt*
\q1 \qt Muek sak uh boeih lah sih, \qt*
\q1 \qt thangthen nah bawt kol la. \qt*
\q1 
\v 2 Thangthen thangthen vanhlangping rhoek loh,
\q1 A ngolkhoel hmai ah tingtoeng tum doe,
\q1 Namtom hlang rhoek boeih loh thangthen uh.
\q1 Sui lumuek muek sak uh.
\q1 
\v 3 A mah tah tholh na boeih ta kung ni,
\q1 A Mueihla loh m'mih lungbuei uk saeh,
\q1 A ming neh mah mih loh ta nah n'khueh
\q1 Sui lu muek muek sak uh.
\c 15
\s1 Tloeng Khoelh Boeipa Te Koeh
\s2 Praise to The Lord
\sp Doh is G
\q1 
\v 1 Tloeng khoelh boeipa te koeh uh
\q1 saii kung manghai boeipa te
\q1 Aw ka mueihla thangthen sak
\q1 khang kung neh sa ding nah ni.
\q1 A ka ya boeih, a bawk im ben la cet uh
\q1 thik at la thangthen sak uh sih.
\q1 
\v 2 Thang then sak uh rhoep saep
\q1 hno boeih uk kung he thangthen uh.
\q1 A phae hlip ah ngaimong la nying sak
\q1 kung boeipa la om.
\q1 Na ngoe ngaih boeih, tui neh buh an boeih boeih te,
\q1 pa loh m'paek na ming moe nih a?
\q1 
\v 3 Thang then sak uh bi bi
\q1 thaihtak sak kung neh hlip dah kung
\q1 A then na loh hnin ta kuem ah
\q1 nang mih te n'dawn dah coeng.
\q1 A then na boeih, te phong yoeyah u bal lah
\q1 Pa then neh paya na he then
\c 16
\s1 Boeipa Yoethen Bih Ham
\s2 We Gather Together
\sp Doh is D
\q1 
\v 1 Boeipa yoethen bih hamla kai mih ka tun uh,
\q1 Amah kongaih yakming sak hamla n'thui tuen,
\q1 Hlang thae rhoek kah hnaemtaek hlang tahae atah loeih coeng,
\q1 A ming thangthen uh a hlang te a hnilh tlaih moenih.
\q1 
\v 2 Mamih taengah Pathen om tih long puei n'hoihaeng,
\q1 A poeng nah ram he a dawndah tih a taem,
\q1 dong ah tholh rhal tuk cuek lamkah tahae tah n'na coeng,
\q1 Kai mih taengkah boeipa thangpom nah tah nang ka ni.
\q1 Caem rhal kung ah kai mih om puei kung kan thangpom,
\q1 Kaimih rhunkung la om phueih hamla kan coep,
\q1 Na hlang ping rhoek puen rhih lamkaloh loeih sak bal lah,
\q1 Nang thangthen yoeyah saeh kaimih he n'loeih sak Boeipa.
\c 17
\s1 Aw A Lungnah Thui Thai Koinih
\s2 My Savior's Love
\sp Doh is A
\q1 
\v 1 Aw a lungnah thui thai koinih,
\q1 Nazaret Jesuh cing te,
\q1 Te tih tluk la thintloh na te,
\q1 Kai hlang tholh ka dawk tangtae,
\q1 \qt Aw a lungnah kopoek la rhai \qt*
\q1 \qt ti te kai ka laa lah sue\qt*
\q1 \qt Aw a lungnah kopoek la rhai \qt*
\q1 \qt ka khang kung loh thin tloh nah.\qt*
\q1 
\v 2 Kai hamla dum khui ah thang thui,
\q1 Nang ming ham khaw thang thui van,
\q1 A mah hamla a ko thae pawh,
\q1 kai hamla a thi sen cip,
\q1 
\v 3 Ka tholh nah tueilaeh a caeh puei,
\q1 A mah ham lat a ben tih,
\q1 A phueih Kalvari ah a hal,
\q1 a khoeng tih a caeh tak coeng.
\q1 
\v 4 A boeilen neh thoeih cam uh tih,
\q1 A hlang then muei hmuh vaengah ,
\q1 Kai ham a lung nah tlo koek te,
\q1 Ka dung yan laa la om ni.
\c 18
\s1 Min cang kho sae vaengah
\s2 When Morning Gilds The Skies
\sp Doh is C
\q1 
\v 1 Min cang kho sae vaengah,
\q1 ka lung buei hing hang tih,
\q1 Jesuh Khrih koeh lah saeh.
\q1 Bi tat neh thang thui nah,
\q1 Jesuh taengah ka caih,
\q1 Jesuh Khrih koeh lah saeh.
\q1 
\v 2 Bawk im darkhing ol ding,
\q1 dup puei tlang hlaep la hum,
\q1 Jesuh Khrih koeh lah saeh,
\q1 Omngaih nah laa ol te
\q1 hna tun uh boeih van lah,
\q1 Jesuh Khrih koeh lah saeh.
\q1 
\v 3 Khohmuep kho ha thai tih,
\q1 ka lung buei long he khaw
\q1 Jesuh Khrih koeh lah saeh,
\q1 Muei rhih tam yin lam kah
\q1 omngaih olthang ka yaak
\q1 Jesuh Khrih koeh lah saeh.
\q1 
\v 4 Nam tom hlang rhoek boeih aw
\q1 he rhoek kah na hmuh he
\q1 Jesuh Khrih koeh lah saeh,
\q1 Dik lai hlang rhoek boeih aw
\q1 omngaihnah laa sa uh
\q1 Jesuh Khrih koeh lah saeh.
\c 19
\s1 A Ming Then Koek Boei Jesuh
\s2 He Is Precious
\sp Doh is A
\q1 
\v 1 A ming then koek boei Jesuh tah
\q1 ka lung nah ngai a ming.
\q1 Hlang tloe rhoek loh a yak na ham
\q1 Cet tih thui ham ka ngaih.
\q1 Cet tih thui ham ka ngaih,
\q1 hlang tloe rhoek loh a yaak nah ham
\q1 cet tih thui ham ka ngaih.
\q1 
\v 2 Ka mueihla hingnah la na om
\q1 dungyan due kan uep nah.
\q1 Aw hlang tloe a om mai a khaw
\q1 kai loh ka ngaih tlaih pawh,
\q1 Kai loh ka ngaih tlaih pawh,
\q1 aw hlang tloe a om mai a khaw
\q1 kai loh ka ngaih tlaih pawh.
\q1 
\v 3 Kongaih na boeih na mah taeng ah
\q1 kai long tah ka dang coeng
\q1 Aw hlang tloe a om mai a khaw
\q1 Kai loh ka ngaih tlaih pawh.
\q1 Kai loh ka ngaih tlaih pawh,
\q1 aw hlang tloe a om mai a khaw
\q1 kai loh ka ngaih tlaih pawh.
\q1 
\v 4 Na ol thangthen te ka koeh ni.
\q1 Kai loh ka duek hlan hil
\q1 Na taeng ah kan pha van vaengah
\q1 Laa ka sak yoe yah ni.
\q1 Laa ka sak yoe yah ni,
\q1 Na taeng ah ka pha van vaengah
\q1 Laa ka sak yoe yah ni.
\c 20
\s1 Then Tangkik Pathen Taeng
\s2 How Sweet The Hour
\sp Doh is F
\q1 
\v 1 Then tang kik Pathen taeng
\q1 thangthuinah neh bawknah tue ah.
\q1 Tang nah cim neh thangthuinah boeih
\q1 he hmuen cim la ham pha.
\q1 Olkhueh phu tlo cang ding yilka
\q1 neh kai n'toei te ka ming
\q1 Lai ah phih uh cakhaw vaan
\q1 im then ah humtun pawn ni.
\q2 \qt Vaan im then ah hum-tun nah\qt*
\q2 \qt a tue then koep om pawn ni \qt*
\q2 \qt Je-suh thi-sen rhang neh \qt*
\q2 \qt vaan im then ah tun nah om ni\qt*
\q1 
\v 2 Then tang kik pum khat sa khat ca
\q1 neh lung vat nah cim he
\q1 Pathen ca pa Jesuh pum dongah
\q1 pum khat la n'cui uh.
\q1 Phih-nah tue loh m'pha
\q1 yue bal mai ca khaw
\q1 ol-cim m'paek coeng
\q1 A yoe then paek ngai-uep
\q1 vaan im then ah kun-tun pawn ni.
\q1 
\v 3 Thahnoeng patang khang la om
\q1 mai cakhaw tuikaeng then ah,
\q1 Thin tlo bae rhoep boeih
\q1 a soep nah vaan ah kuntun pawn ni.
\q1 Hli-puei boeih neh tui let
\q1 tui phu poeng nah a tue yoei coeng
\q1 Om ngaih laa sak pawn ni
\q1 vaan im then ah kun-tun pawn ni.
\c 21
\s1 A Lungnah Rhui Pin Tih
\s2 Blest Be The Tie That Binds
\sp Doh is F
\q1 
\v 1 A lungnah rhui pin tih,
\q1 Khrih lungnah thikat la,
\q1 Koatca la humtun boeih uh
\q1 so ben lung buei la om.
\q1 
\v 2 A pa ngol khoel hmai ah,
\q1 Thikat la n'thang thui uh,
\q1 Kothae na neh ngaiuep na boeih
\q1 omngaihnah khaw thikat.
\q1 
\v 3 Kothae lung nat ming hmaih,
\q1 Hno rhih khaw m'phueih uh hmaih,
\q1 Khat neh khat kah ol ngai nah neh,
\q1 lungvat nah phitui bo.
\q1 
\v 4 Phih uh koep vaengah tah,
\q1 Thinko dang tlo tangkik,
\q1 Tedae mamih lungbuei thikat,
\q1 tun koep ham ngai uep uh.
\c 22
\s1 Boeipa Na Yoethen Han Caeh Tak
\s2 Lord, Dismiss Us With Thy Blessing
\sp Doh is Ab
\q1 
\v 1 Boeipa na yoethen han caeh tak,
\q1 Kai mih lungbuei omngaih sak.
\q1 Na lung nah ka pang uh lah eh.
\q1 Lung vat nah neh ta nah m'pae.
\q1 kai mih n'caih sak.
\q1 Kai mih n'caih sak
\q1 rham haeng ah ka caeh li ah.
\q1 
\v 2 Omngaih nah ol thangthen dong ah,
\q1 Uemnah neh na ming kan pomsang.
\q1 Na khangnah ol a thaih tak te
\q1 Kaimih lungbuei ah bae saeh.
\q1 Uep om hlang boeih
\q1 uep om hlang boeih
\q1 na oltak te ming sak lah.
\q1 
\v 3 Na lungnah neh kaimih boeih he
\q1 lai lam kah nan phuengvaengah ,
\q1 Dueknah rhihnah loh khu boelsaeh,
\q1 Na khuenah ol neh n'yak sak,
\q1 dungyan uk saeh dungyan uk saeh
\q1 Bawt mueh la na mah neh uk.
\c 23
\s1 Boeipa Na Ming Cim Te Koep
\s2 God Will Take Care Of You
\sp Doh is Db
\q1 
\v 1 Boeipa na ming cim te koep kan phoe uh,
\q1 Ka pai uh tih phih laa hmaih ka sak tih,
\q1 Bawt nah ham ka pai uh tih kan koeh uh.
\q1 Ngaimong nah kaimih lungbuei ah m'pae lah.
\q1 
\v 2 Im caehlong ah rhalthal nah m'pae uh lah,
\q1 Nang neh hmaih om vaengah khohnin bawt saeh.
\q1 He imkhui ah nang ming ka khue rhoek tah
\q1 Tholh hmuika neh yahnah lam kah loeih sak.
\q1 
\v 3 Kholaeh due la rhalthal nah m'pae uh lah,
\q1 Yinnah khaw vangnah la han coeng sak lah,
\q1 Rhih om puen cak a khaw n'loeih sak uh lah,
\q1 Nang a tah khoyin kho thaih vai uh rhoi.
\q1 
\v 4 Lai hing khui ah rhal thal nah m'pae uh lah,
\q1 Ngaihmang khobing he nang loh han dip sak,
\q1 Na ol long tah ngaihmang a dip sak thai,
\q1 Dungyanngaimongnah la kai mih n'khue lah.
\c 24
\s1 Boeilen Jehovah Kai Mawt Lah
\s2 Guide Me, O Thou Great Jehovah
\sp Doh is D
\q1 
\v 1 Boeilen Jeho vah kai mawt lah,
\q1 rham haeng ah ka caeh vaengah.
\q1 Kai tha hnoeng hlang na tha om
\q1 na boeilen kut neh kai m'mawt lah.
\q1 Vaan dong kah vai dam te a hah la n'cah lah.
\q1 Vaan dong kah vai dam te a hah la n'cah lah.
\q1 
\v 2 Tuibap tui cil ta hae phuet sak
\q1 ka hoeih nah tui han long sak.
\q1 Hmaivang then neh khomai then loh
\q1 ka yin caeh long m'mawt lah saeh.
\q1 Mawt kung nang ka patling neh thaomnah ni.
\q1 Mawt kung nang ka patling neh thaomnah ni.
\q1 Jordan tuiphu ka kat vaengah,
\q1 Lakueng rhih na boeih hma sak.
\q1 Tuilet lak ah dawn dah lamtah
\q1 Sa ding la Kanan m'pha sak.
\q1 Na taengah Koeh nah laa yoeyah ka sa ni.
\q1 Na taeng ah koehnah laa yoeyah ka sa ni.
\c 25
\s1 A Pum Boeih La Tun Uh Hlan due
\s2 God Be With You
\sp Doh is Db
\q1 
\v 1 A pum boeih la tun uh hlan due ah
\q1 Nang mih taeng ah Pathen om saeh.
\q1 A mueihla neh longpuei mawt saeh
\q1 A im khui due sa ding la mawt saeh.
\q2 \qt Ma mih ng'hum uh hlan due \qt*
\q2 \qt Jesuh taeng ah ng'hum uh due. \qt*
\q2 \qt Mamih ng'hum uh hlan due \qt*
\q2 \qt Mamih taengah Pathen om van saeh.\qt*
\q1 
\v 2 A pum boeih la tun uh hlan due ah
\q1 Nang mih taeng ah Pathen om saeh,
\q1 A phae hlip ah kuep kol sak saeh,
\q1 Hnin takuem bung khut nah buh m'pae saeh,
\q1 
\v 3 A pum boeih la tun uh hlan due ah
\q1 Nang mih taeng ah Pathen om saeh,
\q1 Khodaeng patang na ming vaengah
\q1 A rhang dong ah a kut neh m'pom saeh.
\q1 
\v 4 A pum boeih la tun uh hlan due ah
\q1 Nang mih taeng ah Pathen om saeh.
\q1 Lungnah hni bok n'hlaek sak uh saeh,
\q1 mih taengah Pathen om puei yoeyah saeh.
\q2 \qt Ma mih ng'hum uh hlan due \qt*
\q2 \qt Jesuh taeng ah ng'hum uh due. \qt*
\q2 \qt Mamih ng'hum uh hlan due \qt*
\q2 \qt Mamih taengah Pathen om van saeh.\qt*
\c 26
\s1 Aw Ka Boeipa Namah Loh Ompuei Lah
\s2 A Bide With Me
\sp Doh is Ab
\q1 
\v 1 Aw ka Boeipa na mah loh ng'om puei lah
\q1 Khoyin tom coeng na mah loh ng'om puei lah.
\q1 A ka bom kung ngai mong sak kung om pawh.
\q1 Kho daeng ca dah bom kung a Pa lo lah.
\q1 
\v 2 Ka hing nah kolkalh ca ah bawt koinih,
\q1 Diklai omthenbawnnah khaw paltham ni,
\q1 Mikhmuh lai koeva he kolkalh mai ni.
\q1 A ka cak boeipa ka taeng ah om lah.
\q1 
\v 3 Khohnin rhamhnin na muei then hmuh ka ngaih.
\q1 Namah mueh atah rhal ka na thai pawh.
\q1 Na mah bang la hlang tloe bom kung om pawh.
\q1 Lung vat kung Pathen ka taeng ah om lah.
\q1 
\v 4 Thinglam dong nan lung nah n'yak ming sak lah.
\q1 Ka hing nah loh bawt tih ka duek hlan ah,
\q1 Vaandong kho ah kho thai, lai ah kho yin.
\q1 Boeipa Pathen ka taengah ha om lah.
\c 27
\s1 Boei Then Koek Kai M'Mawt Lah
\s2 Take My Hand Precious Lord
\sp Doh is Ab
\q1 
\v 1 Boei then koek kai mawt lah.
\q1 Ka longpuei kho bing coeng,
\q1 Ka hingnah long he tah bawt tom coeng.
\q1 Ka thangthui ol han ya
\q1 ka bung tom vaengah m'bom
\q1 aw boeipa na im then la mawt lah.
\q2 \qt Ka kut ah kai mawt lah\qt*
\q2 \qt aw boeipa kai n'thoh lah \qt*
\q2 \qt Patang ka khang tih ka tha bong sut \qt*
\q2 \qt Hlipuei loh mvael ca khaw \qt*
\q2 \qt khosae na la mawt lah \qt*
\q2 \qt aw boeipa na im then la mawt lah. \qt*
\q1 
\v 2 Rhih om ah ka caeh vaeng
\q1 Ka taeng ah ha om lah
\q1 Kho sae long khaw khum tih kho yin coeng,
\q1 Tui va kaeng ah ka pai
\q1 Boeipa nang loh mawt lah
\q1 aw boeipa na im then la mawt lah.
\q1 
\v 3 Khokhawn loh ha khup tih
\q1 kho loh ha yin vaengah
\q1 tha om nah kai pae lah ka boeipa
\q1 Hlipuei loh m'vael ca khaw
\q1 kho sae na ben la mawt
\q1 aw boeipa na im then la mawt lah
\q2 \qt Ka kut ah kai mawt lah\qt*
\q2 \qt aw boeipa kai n'thoh lah \qt*
\q2 \qt Patang ka khang tih ka tha bong sut \qt*
\q2 \qt Hlipuei loh mvael ca khaw \qt*
\q2 \qt khosae na la mawt lah \qt*
\q2 \qt aw boeipa na im then la mawt lah. \qt*
\c 28
\s1 Khotlak Benla Kho Tla Coeng
\s2 Day Is Dying In The West
\sp Doh is Ab
\q1 
\v 1 Kho tlak ben la kho tla coeng,
\q1 Vaan neh diklai sap duem coeng.
\q1 Bawk nah tue rhing nah ham la
\q1 vaan dong tom ah vaan hmai im boeih a tok uh.
\q2 \qt A cim A cim A cim Boeipa Pathen\qt*
\q2 \qt vaan neh lai ah na bae tawt, \qt*
\q2 \qt so sang koek Pa then vaan neh lai loh n'koeh uh. \qt*
\q1 
\v 2 Hing nah boeipa na im loh
\q1 lung lai boeih a hlip a dah.
\q1 Nang kan tlap uh vaengah he
\q1 khoyin puet na rhang dong ah kuep sak uh lah.
\q1 
\v 3 Kho loh a yin khup vaengah ,
\q1 lung nah thinko loh a cun.
\q1 Boei mang nah ai si loh na
\q1 mael hmai a yol nah hmuen la ka lung buei om.
\q1 
\v 4 Mamih boeih mik hmuh lam kah,
\q1 Kho yin a khum phoei a tah,
\q1 Vaan puencawn Boeipa te tah
\q1 mamih ham dung yan kho sae then la om ni.
\c 29
\s1 Rhing Mai Dae
\s2 Only Waiting!
\sp Doh is G
\q1 
\v 1 Rhing mai dae kho yin loh hoi uh
\q1 tih kho mik loh a sae due la,
\q1 Rhing mai dae hlaem ben kho khaw khawn
\q1 mol dong tlang ah voeh voeh khup,
\q1 Kho thun kho voei hlaem hmah khawn phai
\q1 kho yin loh a thing khup due,
\q1 Haeng vai puk thung vaan dong ai si
\q1 loh a vang due la rhing dae.
\q1 
\v 2 Rhing mai dae cang at rhoek cang pa
\q1 pawn tih im la a mael uh due,
\q1 Khohal hung kang khum yip tih cui
\q1 li yilh ding loh ha lo coeng.
\q1 A loe la cangat rhoek thin ko
\q1 cangvuei long tah boeih hmin coeng,
\q1 Hing na rhaipai loh tlumtloi tih
\q1 kai khaw caeh ka ngaih van coeng.
\q1 
\v 3 Rhing mai dae vaan hlang rhoek loh vaan
\q1 sui thoh ka a ong uh due la,
\q1 Kho daeng rham thai lung ma ka lam
\q1 dae te thohka ka lam tawn.
\q1 A hla hlang kah tuen pa ol neh
\q1 kho laeh ol te ka yak coeng,
\q1 A mih kah khuenah ol bueng te
\q1 rhing oel tih ka lam tawn coeng.
\q1 
\v 4 Ka om nah ham im then ngai mik
\q1 neh hmuh noek pawt te ka lamtawn
\q1 Hingnah thing kung ulh ulh pailum
\q1 te hmuen tak dik dik saitlim,
\q1 Ka khangkung loh n'loh tih tlan nah
\q1 ha soep na te ka lamtawn.
\q1 Tholhnah boeih boeih hma pawn vetih
\q1 patang nah om voel mah pawh.
\c 30
\s1 Kopoekrhai La Cuekhalhnah Ka Tong
\s2 Farther Along
\sp Doh is F
\q1 
\v 1 Ko poek rhai la cuekhalhnah ka tong khing,
\q1 Ba kong mai ah he rhainah ka tong,
\q1 Tholhdalhnah khuiah om uh boeih van dae,
\q1 Mamih bangla cuekhalhnah tong pawh.
\q2 \qt A voel a tah a cim phan la ming ni,\qt*
\q2 \qt A thui ngaih nah khaw m'ming boeih pawn ni, \qt*
\q2 \qt Ko thae nah ah ah ngai mong la om uh ngawn, \qt*
\q2 \qt a voel ah a cim la ming bit ni.\qt*
\q1 
\v 2 Bae rhoep hlang boeih neh dueknah loh m'paek sak,
\q1 Ngai hlih mik phi doe cet dam khum dam
\q1 Koe va khuehtawn te hlang tloe a om vaeng
\q1 Bang kong mai a khodaeng hlang la ng'om.
\q1 
\v 3 Duek due uepom la om hamla nang n'cael,
\q1 Tholh tat pa tang nah hnin sen mah pawh,
\q1 Khodaeng lungma ming nah hnin bawt pawn ni,
\q1 vaan sui thoka then a kun vaengah.
\q1 
\v 4 Boeilen nah neh Jesuh ha lo vaengah,
\q1 Vaan dong kah a rhum te hmuh uh ni,
\q1 Im then sai hluen dongah te tun uh ni,
\q1 A voel a tah a cim la ming ni.
\q2 \qt A voel a tah a cim phan la ming ni,\qt*
\q2 \qt A thui ngaih nah, khaw m'ming boeih pawn ni, \qt*
\q2 \qt Ko thae nah ah ah ngai mong la om uh ngawn, \qt*
\q2 \qt a voel ah a cim la ming bit ni.\qt*
\c 31
\s1 Boeipa Hlaemben Ka Ih
\s2 Saviour, Breath An Evening Blessing
\sp Doh is Bb
\q1 
\v 1 Boeipa hlaem ben ka ih hlan ah,
\q1 Na yoe then nah te kai m'pae lah,
\q1 Tholh neh vawt nah boeih ka phong he
\q1 Namah loh na hoeih sak thai.
\q1 
\v 2 Pocinah loh taengvai ham vael,
\q1 Thaal loh ka taeng lah ha lo he,
\q1 Vaan hlang loh n'hoeptlang tih n'loeih sak,
\q1 Namah daengah ka loeih uh.
\q1 
\v 3 Yin nah loh hmuep hlang mai ca khaw,
\q1 Kho yin loh nang hlipdah moe nih,
\q1 Namah ah la kueng nah om pawh,
\q1 Na hlang rhoek tah na dawndah.
\q1 
\v 4 Tu hlaem ah dueknah ha pai tih,
\q1 Hlan mol la ka khum mai cakhaw,
\q1 Thang vuen na vaan ram dong ah tah,
\q1 Ka mueihla hing ngai bit ni.
\c 32
\s1 Ka Mueihla Khosae Then Boeipa
\s2 Sun At My Soul
\sp Doh is F
\q1 
\v 1 Ka mueihla kho sae then boeipa,
\q1 Na taengah tah kho hmuep om pawh,
\q1 Boeipa na muei ka hmuh na ham
\q1 la na Mueihla te thoh sak lah
\q1 
\v 2 Ka thahnoeng vaengah dam tui loh,
\q1 Ka mik dong ah duem duem ha tlan,
\q1 Boeipa kah a rhang dongah tah
\q1 Ka om loh dik dik tui tang kik.
\q1 
\v 3 Kho laeh due kaimih taeng om lah,
\q1 Nang mueh atah hing ko hut pawh,
\q1 Khoyin ah kaimih taeng om lah
\q1 Na om pawt atah ka deuk ni.
\q1 
\v 4 Na ca rhoek kho daeng a ming tih,
\q1 Na mah taeng ah hnintakuem pang,
\q1 Boeipa tahae na bi ka tong
\q1 A nih he tholh ah bung sak boeh.
\q1 
\v 5 Ka thahnoeng vaengah ha yoei lah,
\q1 He diklai ka longpuei bawt due
\q1 Vaan dong ram kah lungnah tuitun
\q1 li ka om uh due ng'om puei lah.
\c 33
\s1 Khosae Loh Voehvoeh Yaai
\s2 Softly Now The Light Of Day
\sp Doh is F
\q1 
\v 1 Khosae loh voehvoeh yaai thuk,
\q1 Kho khawn long tah voehvoeh khup.
\q1 Bi bi lamkah ka duem tih
\q1 na mah neh voemtoei ka ngaih.
\q1 
\v 2 Namah kah mik hmuh ah he
\q1 bang khaw n'hlipdah thai moenih,
\q1 Hman tang neh a huep kah tholh
\q1 na boeih kho dawk han ngai dae.
\q1 
\v 3 Diklai ka hingnah kho hnin he
\q1 khum phat ve bal ca khaw,
\q1 Kho thae a om na mueh hmuen
\q1 na om na ah kai om sak.
\q1 
\v 4 Nang tah tholh na khueh pawt dae
\q1 hlang kah a vawtthoek na ming,
\q1 Na boei ngolkhoel lam ka loh,
\q1 sit loh na mik neh nan sawt.
\c 34
\s1 Hnatun Khuenah Ol
\s2 Jesus Leads His Army
\sp Doh is C
\q1 
\v 1 Hna tun la khue nah ol u nim ka cet eh,
\q1 Ka tueih na ta kuem ah aal mueh la caeh ham
\q1 Ai tlang hlaek kung om a caem rhal tlung na ah,
\q1 U lae ka cet eh Pathen neh duengnah ham
\q2 \qt A cim mang taeng nah neh a hla a yoei kah, \qt*
\q2 \qt Tuen ol hna tun lam tah, caem thoh la cet uh.\qt*
\q1 
\v 2 Pa then tha om uep nah neh rhal na ta ni,
\q1 Sa tan rhal loh thoo li rhal kap pho lip buen,
\q1 A cim neh a ka dueng te pai puei uh sih,
\q1 Pa then ah tlung mu tih, rhal te tuuk uh sih.
\q1 
\v 3 Jesuh loh ai tlang hmui ah rhal kap a mawt,
\q1 rhal a ta phoei ah dueng nah lai ah a bae sak
\q1 Hna tun caem thoh tuen ol laa sak doe khong uh,
\q1 Mawt kung manghai boei tah thangthen la om saeh,
\c 35
\s1 Boeipa Thangthen Sak Uh
\s2 Bless The Lord, O My Soul
\sp Doh is Bb
\q1 
\v 1 Boeipa thangthen sak uh, Boeimang koek Pathen
\q1 Ma mih khang hamla longpuei then a ong coeng,
\q1 Khangnah a ka then koek te mamih m'paek coeng,
\q1 Hmaivang neh khomai lakli ah ma mih mawt.
\q2 \qt Vaan hlang boeih aw koeh uh, pung ding olthang neh\qt*
\q2 \qt A boeimang nah muei loh, hlang lungbuei a tue \qt*
\q2 \qt A hlang khueh boeih so ah A yoeyah cak saeh, \qt*
\q2 \qt A sai hluen hno boeih loh a sai hluen hno boeih loh \qt*
\q2 \qt boeipa a koeh aw ka mueihla koeh van lah. \qt*
\q1 
\v 2 Boeipa thangthen sak uh, Mueihla loeih sak kung
\q1 tholh cim na ham hing nah tuiva a long sak,
\q1 A rhen lung nah mamih a yoe la m'paek coeng,
\q1 Thang thui ol hna tun kung boeipa thangthen uh.
\q1 
\v 3 Boeipa thangthen sak uh, Ngaihmang la om vaeng,
\q1 a mah rhen na rhui neh van dong la mawt tih,
\q1 Tangnah ngaiuepnah neh a ka ta rhoek boeih,
\q1 lungnah ram ah a soep la tun uh pawn ni.
\c 36
\s1 Aka Hing Boeih Kah Boeipa Nang
\s2 Lord Of All Being
\sp Doh is Ab
\q1 
\v 1 A ka hing boeih kah boeipa nang,
\q1 Khomik hla ah boeilen nah tueng,
\q1 Vaan dong khocil ke ka sawt vaengah
\q1 nang n'lungvat nah uh tangtang.
\q1 
\v 2 Kai mih ham kho sae la na om,
\q1 Ka caeh na long puei na tueng sak.
\q1 Khoyin vaengah ngaiuep nah aisi
\q1 la na om long puei nan tueng.
\q1 
\v 3 Nan mangthung tak vaengah khoyin,
\q1 Khothaih then he na rhennah ni,
\q1 Na lungvat nah khosaeng then long tah
\q1 tholh khomai a cing sak boeih.
\q1 
\v 4 A hmui hman boeih kah hingnah boei,
\q1 na oltak te vang lung nah bae,
\q1 Na vang nah ngolkhoel hmai ah
\q1 kaimih kah hmaivang kan bih moenih.
\q1 
\v 5 Na ol tak neh kai mih n'loeih sak,
\q1 Ka lung buei nang ham ka ung sak,
\q1 Vaan dong hmaivang then a vang nah
\q1 hmueih tuk cim ham pha hang due la.
\c 37
\s1 Omngaih La Kan Thangthen Sak
\s2 Joyful, Joyful We Adore Thee
\sp Doh is G
\q1 
\v 1 Omngaih la kan thangthen sak uh,
\q1 then rhuep Pathen lungnah boei.
\q1 Rhaipai kho ben a mael bang la,
\q1 Ka thinko ham mael sak lah.
\q1 Tholh kothae muei he han hai sak,
\q1 uepvawt nah yin khaw ham vaai.
\q1 A ka cak omngaihnah a ka
\q1 pae kung khosae te m'pae lah.
\q1 
\v 2 Na sai boeih loh nang n'thangthen sak,
\q1 Lai neh van ah na aa tueng,
\q1 Aisi, vaan hlang loh laa a sak,
\q1 Na hlangthen nah bawt tlaih pawh,
\q1 Duppuei tuiko molmae boeih neh
\q1 molsom boeih ah tuiding long,
\q1 Sucawk vacek ol boeih long khaw
\q1 na mah taeng ah omngaih puei.
\q1 
\v 3 Nang khodawk ngai kung hlang rhen kung,
\q1 Yoethen nah cungkuem na khueh,
\q1 Hing nah omngaihnah tui ha phuet,
\q1 Na lungnah tui bang la dung,
\q1 Nang a pa neh Khrih la na om,
\q1 hui at la kho ka sak uh,
\q1 Hlang tloe ka lungnah van ham
\q1 ncang sak Pathen kah lungnah te.
\q1 
\v 4 Diklai hlang omngaih laa sa uh,
\q1 Aisi Thuipa loh a sak,
\q1 A pa kah lungnah loh he n'uk,
\q1 Boeina lungnah loh m'pin uh,
\q1 Laa sak doe a hmai la n'cet uh,
\q1 rhainah ah ta kung la om,
\q1 Omngaih phung ding loh tanah laa
\q1 neh khomik ben la m'mawt uh.
\c 38
\s1 Belshazar Neh A Boei Thawngkhat
\s2 The Hand Writing On The Wall
\sp Doh is F
\q1 
\v 1 Belshazar neh a boei thawng khat rhoek kah buhvael kung ah,
\q1 sui boengloeng neh yu a ok u oltak loh a thui bang la,
\q1 Te kah hlaem vaengah a boei im khui ah ka tueng te tah,
\q1 Im dong ah noek nah kut a tueng pa uh tih lakueng uh.
\q2 \qt Pathen kut imbang dong ah tueng\qt*
\q2 \qt Pathen kut imbang dong ah tueng, \qt*
\q2 \qt na vawt pueng na soep van \qt*
\q2 \qt ti lam nim ca te a daek van co, \qt*
\q2 \qt Im bang dong ah ca a daek vaengah.\qt*
\q1 
\v 2 So uh lah thin om sal Daniel hlang ping hmaiah pai tih,
\q1 mang pa hlang tholh rhoek boeih te rhih khueh kolla a phoe pa boeih,
\q1 Kut daekca a hmuh vaengah soeprhaep boeih a po ci nah,
\q1 Mang hai kah ram yawk coeng ti la im bang dong ah a daek.
\q1 
\v 3 So lah tangnah neh thinomnah loh a dueng a sai sak,
\q1 Cim mueihla long ni Da niel te tah tha om nah boeih a paek,
\q1 Ju dia ram kah a im a khaw sal lah a om hmuen ah,
\q1 Im bang dong kah ca daek yakming na Pa then loh a paek.
\q1 
\v 4 Mamih kah khoboe khaw imbang dong ka bang la om van,
\q1 Hlangtholh nang na lungbuei te Jesuh taengla mael sak van laeh,
\q1 Hlang boeih taeng ah te kah kho hnin tah ha yoei li coeng he,
\q1 Na tholh pangbueng dong a daek vaengah ola cawh pawn ni.
\c 39
\s1 Ka Pathen Tah Vong Cak La Om
\s2 A Mighty Fortress Is Our God
\sp Doh is C
\q1 
\v 1 Ka Pathen tah vong cak la om,
\q1 a vong tung loh bung thai tlaih mah pawh.
\q1 Tholh tuiphu ha tho ca khaw
\q1 a mah tah mamih kah bom kung la om
\q1 Rhal lak li ah khaw a ol khueh bang lah n'tlap,
\q1 A sai thai na boeih neh a tha om na tah len,
\q1 Diklai tlung na loh noeng thai pawh.
\q1 
\v 2 Ma mih tha om uep na koi nih,
\q1 ma mih tha yung he tah bawt pat thai,
\q1 Hlang tloe loh pai puei pawt khaw
\q1 Pathen a mah te mah tuek u lah sih.
\q1 U lae n'ti la eh, A nih tah Jesuh Khrih
\q1 A ming ah boeipa ni Kho kum khohal due la,
\q1 Caem rhal boeih te khaw a ta coeng,
\q1 
\v 3 Lai he tholhnah bae tawt cakhaw,
\q1 mamih he n'ta thai tang a ya te?
\q1 Pa then loh ma mih n'hno nah vetih
\q1 ta hamla a om coeng dongah,
\q1 ka rhih tlaih voel pawh,
\q1 pil nam loh n'caeh tak tih,
\q1 Ka hing nah khum ca khaw,
\q1 ka pum ngawn mai ca khaw,
\q1 Pa then ol tak loh om puei coeng.
\c 40
\s1 Yan Vaeng Israel Hlangping
\s2 He Rolls The Sea Away
\sp Doh is F
\q1 
\v 1 Yan vaeng Isarael hlang ping
\q1 tholh loh a pin vaengah ,
\q1 Pathen thaomnah a tueng sak
\q1 tuitunli a kueng pah.
\q2 \qt Tui tunli a kueng coeng,\qt*
\q2 \qt tuitun li a kueng coeng \qt*
\q2 \qt Jesu ka taeng ah om tih \qt*
\q2 \qt Ka rhih na om voel pawh \qt*
\q2 \qt Tuitunli a kueng coeng.\qt*
\q1 
\v 2 Cuek halh nah tholh tuiphu loh
\q1 ka mueihla li bal ca khaw,
\q1 Boeipa kah khodawkngainah neh
\q1 tui tun li a kueng coeng.
\q1 
\v 3 Long puei rhih om na hmuen ah Boei
\q1 pa Jesuh long n'om puei,
\q1 Lung vat nah thinko neh ha yoei,
\q1 tuitun li a kueng coeng.
\q1 
\v 4 Boeipa Jesuh ka duek na neh
\q1 ka hing a bawt tue ah,
\q1 Na ram then lam kai m'mawt lam tah,
\q1 tuitunli boeih kueng lah
\c 41
\s1 Boeipa Pathen Na Saihluen Hnopai
\s2 How Great Thou Art
\sp Doh is C
\q1 
\v 1 Boeipa Pathen na saihluen hno pai boeih he,
\q1 Ka poek vaengah Ka lo loh pha thai pawh.
\q1 vaan dong aisi khomai khohum rhotui loh,
\q1 na sai kutngo na khueh tawn a tueng sak.
\q2 \qt Aw ka hing nah khangkung boei thangthensak, \qt*
\q2 \qt Metihtluk la na boeilen nah.\qt*
\q2 \qt Aw ka hing nah khangkung boei thangthensak, \qt*
\q2 \qt Metihtluk la na boeilen nah)\qt*
\q1 
\v 2 Molsang dong ah ka pong pa caeh om vaengah ,
\q1 thingsoi bahoe vahlo ol ding ka yaak,
\q1 Tlang som lam loh khohmuen mol ka dan vaengah ,
\q1 soko tuiva yilh ding ol te ka yak.
\q1 
\v 3 A pa Pathen Capa te kae na kolla,
\q1 hlang thloh tlan ham lam te han tueih thuk coeng.
\q1 Thing lam dong ah, ka tholh na boeih na phueih tih,
\q1 tholh khui lam kah ka loeih na ham na duek.
\q1 
\v 4 Boeilen tangkik la Khrih koep ha lo vaengah ,
\q1 Khang kung taengah omngaihnah soep pawn ni.
\q1 Hinyah na neh a hmai ah ka kuep ve tih,
\q1 Pathen Boeilen nah te ka koeh pawn ni.
\c 42
\s1 Na Uepomnah Len Tangkik
\s2 Great Is Thy Faithfulness
\sp Doh is Eb
\q1 
\v 1 Na uepom nah len tang kik a pa Pathen
\q1 Na taeng ah khoyin nah loh omtlaih pawh,
\q1 Nan rhen lung nah he khaw tho laeng uh tlaih pawh.
\q1 Na mah tah dung yan due la phueih na cak.
\q2 \qt Uepom nah len tang kik Uepom nah len tang kik,\qt*
\q2 \qt Vuen bal hlaem bal na rhen lung na ka hmuh \qt*
\q2 \qt Ka ngoengaih boeih na mah kut neh nan paek tih, \qt*
\q2 \qt uepom la na om nah tah len tang kik. \qt*
\q1 
\v 2 Khocui khohal sikca cangah tue boeih neh,
\q1 Khomik hla neh vandong aisi boeih loh
\q1 Na saihluen boeih loh na boeilen a pai puei,
\q1 Na lungvat rhennah boeih thintlohnah te.
\q1 
\v 3 Tholh khodawk na ngai tih ngaimongnah nan paek,
\q1 Na hmai ah long puei then te nan tueng tih,
\q1 Ti hnin khosae then thangvuen ham ngaiuep nah,
\q1 Kataeng ah yoethen na cung kuem nan paek.
\c 43
\s1 Tloengkhoelh Pathen Halo
\s2 Come, Thou Almighty King
\sp Doh is G
\q1 
\v 1 Tloeng khoelh Pathen ha lo,
\q1 thangthen nah laa n'sak sak.
\q1 Na mah ming te ka thang pom thai na ham
\q1 kai mih he bom u lah
\q1 Kai mih taeng ah uk kung la om yoeyah.
\q1 
\v 2 Oltak Pathen ha lo
\q1 na cunghang a haat neh.
\q1 Thang thui ol he hnatun lam yoethen m'pae
\q1 ta nah te han soep sak,
\q1 Kai mih taeng ah rhum lah A cim mueihla.
\q1 
\v 3 Ngaimong sak kung rhum lah,
\q1 na olhuep pai puei lah,
\q1 A tue then khui boeilen Pathen nang
\q1 loh kai mih lung buei uk lah,
\q1 Kai mih taeng Cimmueihla tha om nah m'pae.
\q1 
\v 4 Pa Capa CimMueihla,
\q1 thumsoep Pathen pa khat,
\q1 Namah taengah thangthennah boeilen nah
\q1 thenrhuep nah hinyah nah,
\q1 dungyan bawt thai mueh la om yoeyah saeh.
\c 44
\s1 Vangnah Kodo Yin Khui Lamloh
\s2 Lead, Kindly Light
\sp Doh is G
\q1 
\v 1 Vangnah kodo yinkhui lam kah n'hoihaeng.
\q1 Kai he mawt lah, ka longpuei loh hmuep tih
\q1 ka im loh hla Kai he m'mawt lah
\q1 Ka kho hoihaeng A hla hlang ham moe nih
\q1 kan at ham ni ka kan a tah rhoeh mai.
\q1 
\v 2 Longpuei m'hmuh sak ti la kan cael vai pawh
\q1 Kai he m'mawt lah, Ka longpuei ka mah bueng
\q1 tuek ka ngaih dae Na mah loh m'mawt
\q1 Om then ka ngaih Tholh nah loh kai he m'pin
\q1 Ka oek hlawn loh khu lae he mai boeh
\q1 
\v 3 Na thaom loh tahae due la kai m'mawt
\q1 Nan mawt bal ni, Tang kham singling longken
\q1 tamyen boeih ah Yin nah loh khum
\q1 Mincang kho sae then
\q1 ah vaan hlangcim mael hmai ka hm uh.
\q1 long puei sut ka hmang vaengah.
\c 45
\s1 Kan Yingnah Lungnu Jesuh
\s2 A shelter in the storm
\sp Doh is F
\q1 
\v 1 Ka ying nah lung nu Jesuh ni
\q1 hlipuei a thoh vaengah ying nah.
\q1 Rhai nah soeprhaep khui ah n'loeih sak.
\q1 hlipuei a thoh vaengah ying nah.
\q2 \qt Aw tha hnoeng rhoek hamla Jesuh lungnu ni.\qt*
\q2 \qt Tha hnoeng rhoek ham, tha hnoeng rhoek ham, \qt*
\q2 \qt aw tha hnoeng rhoek hamla Jesuh lungnu ni \qt*
\q2 \qt hlipuei a thoh vaengah ying nah.\qt*
\q1 
\v 2 Khothun hlipkhup hlaem ah vongtung
\q1 hlipuei a thoh vaengah ying nah.
\q1 Caem rhal lak ah ka ngaimong nah,
\q1 hlipuei a thoh vaengah ying nah.
\q1 
\v 3 Hli puei rhonu tlanthim lak ah,
\q1 ka ying na tah Jesuh nang ni.
\q1 Ka taeng ah dungyan la om lah.
\q1 hlipuei a thoh vaengah ying nah.
\q1 
\v 4 Aw lungnu puei duem nah then koek,
\q1 Hlipuei a thoh vaengah ying nah.
\q1 Ka taeng ah dung yan la lah,
\q1 hlipuei a thoh vaengah ying nah.
\c 46
\s1 Boeipa Loh Mawt Tih Ka Omngaih
\s2 He Leadeth Me
\sp Doh is D
\q1 
\v 1 Boeipa loh m'mawt tih ka omngaih.
\q1 Vaan ram ngai mong nah ol ka yaak.
\q1 ka bi ka tat na kung boeih ah
\q1 amah kut cim nen te m'mawt coeng.
\q2 \qt A mah loh m'mawt a mah loh mawt,\qt*
\q2 \qt ka hing khui a yoe yah la m'mawt \qt*
\q2 \qt a mah kah mawtnah ta kuem ah, \qt*
\q2 \qt uepom la a hnuk bang ka ngaih.\qt*
\q1 
\v 2 Khodaeng lungma khoyin cakhaw
\q1 Patang nah hmuen ah ha om lah
\q1 Kohoenah neh kobawtna ah.
\q1 Boeipa nang loh mawt yoeyah lah.
\q1 
\v 3 Diklai tholh neh patang hlang boeih
\q1 thinko ngaimong nah te dang ham
\q1 melam khaw nan mawt na kung ah.
\q1 uep om ca la vai ham ka ngaih.
\q1 
\v 4 Diklai bibi ka coeng vetih,
\q1 na lennah neh ka ta vaengah.
\q1 Eden tuiphu ha tho ca khaw,
\q1 Jor dan tuiva te ng'kat puei coeng.
\c 47
\s1 Khangkung Jesuh Kaimih M'mawt
\s2 Jesus Saviour Pilot Me
\sp Doh is B
\q1 
\v 1 Khangkung Jesuh kai mih mawt
\q1 ka hingnah ah tuiphu tho.
\q1 Tuilet loh n'khuu uh coeng he,
\q1 lung nu lung rhang kung la m'mawt
\q1 Long dueng na mah loh hmuh sak
\q1 khang kung Jesuh kai m'mawt lah
\q1 
\v 2 Oingaih poeh li camoe bang,
\q1 tuitun li khaw na sim thai,
\q1 Tuilet loh na ol a ngai,
\q1 duem lah na ti na tih duem
\q1 Tuituen li khaw toel tham kung
\q1 khang kung Jesuh kai m'mawt lah.
\q1 
\v 3 Tui kaeng lang dai ka yoei vaeng,
\q1 Rhih om tui len tuen ka yak
\q1 Na rhang dong ah nan pom tih
\q1 ngai mong la ka duem na tih
\q1 Ka ca aw rhih boeh kan mawt
\q1 bit ni ti ol yaak ka ngaih.
\c 48
\s1 A Cak Lungnu Namah Khui ah
\s2 Hide Thou Me
\sp Doh is Ab
\q1 
\v 1 A cak lungnu na mah khui ah kai n'thuh lah,
\q1 Khodaeng patang ngaihmang vaengah Kai n'thuh lah,
\q1 Hlanghing loh a sai mueh hmuen ni
\q1 ka lungbuei long tah a ngaidam,
\q1 
\v 2 Kai n'thuh Aw a cak lungnu khui ah n'ying sak.
\q1 Omthen bawn tholhnah lamkaloh kai n'thuh lah,
\q1 Ka mueihla he na mah khuiah han n'thuh lah,
\q1 Dik lai loh a thaom hang tih ka lungbuei dalh a payawk coeg,
\q1 Kai n'thuh Aw a cak lungnu khui ah n'ying sak.
\q1 
\v 3 Yin thuem ih sap om dam vaengah kai n'thuh lah,
\q1 Min cang kho sae ka pha duela Kai n'thuh lah,
\q1 Jor dan tui phu ha yoei vaengah,
\q1 na rhang dongah n'kun sak lamtah,
\q1 Kai n'thuh Aw a cak lungnu khui ah n'ying sak.
\c 49
\s1 A Lak ah Kho Khup Loh
\s2 Hide Thou Me
\sp Doh is Ab
\q1 
\v 1 A lak ah kho khup loh yin tih
\q1 ka long puei ba hoeng ah ha rhai.
\q1 A lak ah kothaenah loh n'thing tih,
\q1 Ka mueihla cuekhalhnah a tong.
\q2 \qt Aw lungnu taengla luei sak lah,\qt*
\q2 \qt Te lungnu tah kai lak ah sang ngai. \qt*
\q2 \qt Aw te lung nu taengla luei sak \qt*
\q2 \qt Te lungnu tah kai lak ah sang ngai. \qt*
\q1 
\v 2 A lak ah kho hnin khaw ha puh,
\q1 A lak ah kho kan loh rhih sut.
\q1 Tedae ka hing loh pa tang vaengah,
\q1 Lungnu hlip nah then tang kik hlang.
\q1 
\v 3 Om ngaih neh ko thae na hmuen ah,
\q1 Lung nu khui amahkuep u sih,
\q1 Tang kham sing ling caeh thuk caeh hang ah,
\q1 yin nah khui ah ceah vaengah khaw.
\c 50
\s1 Khosuen Lamkah Bomkung
\s2 O God Our Help In Ages Past
\sp Doh is C
\q1 
\v 1 Khosuen lamkah bom kung
\q1 Pathen hmai long ngaiuep nah,
\q1 Hli puei vaengah ka ying nah
\q1 neh yoeyah hamla im then.
\q1 
\v 2 Na ngolnah hlip ah hlang
\q1 cim rhoek loh cuemhuet la ying uh.
\q1 Na kut bueng long ni kaimih
\q1 hlipdah thai tih a soep thai.
\q1 
\v 3 Molmae tlang sang tom boeih
\q1 boeih neh lunglai a sai hlan ah,
\q1 Nang bueng dungyan due la
\q1 amah la phueih ah na om coeng.
\q1 
\v 4 Kum sen hlang boeipa nang
\q1 taengah khoyinnah om tlaih pawh,
\q1 Khoyin tue loh bawt tih
\q1 khothaih then tah ha sae bal coeng.
\c 51
\s1 Aw Lakueng Hlang
\s2 A Bide To Deliver
\sp Doh is Bb
\q1 
\v 1 Aw lakueng hlang nangmih loh rhih boeh,
\q1 Na boeipa Pathen taengah hangdang lah,
\q1 A mah loh na kopang nah ol
\q1 han hlat vetih m'bom ngaicai bitni.
\q2 \qt A mah loh nang mih te mawt thai ngai ni.\qt*
\q2 \qt A ban tang kut neh nang mih hlip dah ni, \qt*
\q2 \qt A mah loh nang mih te mawt thai \qt*
\q2 \qt la a om dong ah rhih tlaih boeh.\qt*
\q1 
\v 2 Aw lakueng hlang rhal a thoh a khaw,
\q1 Thincak nah na pho na lip mah buen lah,
\q1 Boeipa thaomnah na uep na
\q1 atah rhal te na na thai pawn ni.
\q1 
\v 3 Aw lakueng hlang long puei rhih om dae,
\q1 rhih om khui lamkah amah loh n'loeih sak,
\q1 Na ngoe ngaih nah takuem boeih ah
\q1 amah tah mamih taengah ha om.
\c 52
\s1 Mebang Rhih Omnah Ah Khaw
\s2 God will Take Care of You
\sp Doh is B
\q1 
\v 1 Mebang rhih om nah ah khaw rhih boeh
\q1 Pathen loh nang ngaithuen.
\q1 A lung nah phehlip hmui ah kun lah
\q1 Pa then loh nang ngaithuen.
\q2 \qt Pathen loh nang ngai thuen,\qt*
\q2 \qt na hing khui neh na long puei ah, \qt*
\q2 \qt A mah loh nang ngai thuen, \qt*
\q2 \qt A mah loh nang ngai thuen.\qt*
\q1 
\v 2 Ngaihmang na khohnin tue vaengah khaw,
\q1 Pathen loh nang ngaithuen
\q1 Longpuei rhih om nah hmuen boeih a khaw,
\q1 Pa then loh nang ngaithuen.
\q1 
\v 3 Ngoe ngaih na boeih a mah loh a poek,
\q1 Pa then loh nang ngaithuen.
\q1 Na bih boeih te vai at khaw hloh pawh,
\q1 Pathen loh nang ngaithuen.
\q1 
\v 4 Noemcaina akhaw mawnnah khueh boeh,
\q1 Pathen loh nang ngaithuen.
\q1 A rhang dong amah hangdang van lah,
\q1 Pathen loh nang ngaithuen.
\c 53
\s1 Rhih Boeh Nang Taengah Ka Om
\s2 Never Alone
\sp Doh is B
\q1 
\v 1 Rhih boeh nang taeng ka om, na mah bueng moe nih.
\q1 Khosaeng bang la ha sae, tih long puei han tue.
\q1 Kho mong khomai lak ah, vangnah neh han tue,
\q1 Na mah bueng kan caeh tak, mah pawh boeipa loh a ti.
\q2 \qt Ka mah bueng moe nih \qt*
\q2 \qt ka mah bueng moe nih,\qt*
\q2 \qt kan caeh tak voel mah pawh a ti, \qt*
\q2 \qt N'caeh tak tlaih mah pawh a ti \qt*
\q2 \qt n'caeh tak tlaih mah pawh a ti.\qt*
\q1 
\v 2 Rhai ai boeih khaw tlumtloi, diklai pai then boeih.
\q1 Kho khawn long khaw khup tih, van ben kho hmuep dae
\q1 Jesuh tah a hlang rhoek, ham pai lum li pueng
\q1 Vaan kho sae then Jesuh, loh n'caeh tak tlaih voel mah pawh.
\q1 
\v 3 Hmuh thai mueh rhainah loh, ha yoei mai ca khaw,
\q1 Khang kung loh ha yoei tih, rhih boeh ne a ti.
\q1 Khohal langloep bang la, ka tha hlue mai tih
\q1 Nang caeh tak moe nih ti, omngaihnah laa ka sak uh.
\c 54
\s1 He Lai A Pa Khohmuen
\s2 This Is My Father's World
\sp Doh is Eb
\q1 
\v 1 He lai a pa khohmuen, ka hna neh ka kaeng vaeng
\q1 soeprhaep boeih laa sak tuen ol cai, a phungding ol ka yaak
\q1 He lai a pa kah ni, thing hlip khup ah ka duem
\q1 Lung nu sokko tuiva boeih loh, na boeilen a tueng sak.
\q1 
\v 2 He lai a pa khohmuen, suva kah loei ol neh,
\q1 Mincang khosae Lily pai then, a boeilen na a koeh.
\q1 He lai a pa kah ni, Soeprhaep ah vang nah tueng,
\q1 Sul hing sai tlim ka hmuh vaengah, a ol thui te ka yak.
\q1 
\v 3 He lai a pa khohmuen, Kahnilh tlaih voel boel eh,
\q1 A thae na loh tha om ca khaw, Pa then loh a uk pueng.
\q1 He lai a pa kah ni, Rhal thal na loh om hlan,
\q1 Mah boeipa Jesuh loh a taa, Vaan neh lai a rhoep sak
\c 55
\s1 Khangkung Boei Namah Hmuen Cim ah
\s2 Hide Me, O My Saviour
\sp Doh is Ab
\q1 
\v 1 Khang kung boei namah hmuen cim ah
\q1 kai he n'ying sak lah.
\q1 Na boeilen na ah n'duem sak lam
\q1 na mik hmai m'hmuh sak lah.
\q2 \qt Kai n'thuh kai n'thuh \qt*
\q2 \qt aw khang kung boeipa kai n'thuh, \qt*
\q2 \qt Aw khang kung kai nthuh \qt*
\q2 \qt kai he cuemhuet la n'khueh.\qt*
\q1 
\v 2 Hli puei loh ha tho mai coeng tih,
\q1 ka ngaihmang vaengah ,
\q1 Vahu bang la ding ham ka ngaih,
\q1 na mah taeng ah lo ham.
\q1 
\v 3 Ka lungbuei a rhek vaengah he,
\q1 namah loh kai n'th uh.
\q1 Thael naem phi tui sul puem vaengah
\q1 lol mang cil han thui lah.
\c 56
\s1 Khangkung Ka Taengah Ha Om
\s2 The Hollow Of God's Hand
\sp Doh is C
\q1 
\v 1 Khang kung ka taeng ah ha om tih kai m'mawt.
\q1 rhai nah me bang khaw lo saeh ka loeih ni.
\q1 Cuek nah ha lo vaengah kai n'thuh vetih,
\q1 a kut neh kai te n'loeih sak.
\q2 \qt A mah kah kut cim nen te\qt*
\q2 \qt a mah kah kut cim nen te \qt*
\q2 \qt Me bang hmuen a khaw kai ka loeih pawn ni, \qt*
\q2 \qt A kut cim nen te loeih sak\qt*
\q1 
\v 2 A lungvat nah kut neh kai he m'pom tih.
\q1 Ka taeng ah ngai mong ol ding te han thui.
\q1 Ta hae ka loeih he Pathen a mah loh,
\q1 a kut neh kai te n'loeih sak.
\q1 
\v 3 Caeh tak mueh la ka mueihla a dawndah,
\q1 A lung nah dilai loh pat sak thai pawh.
\q1 Ta hae lam kah di lai a bawt due la
\q1 a kut neh kai te n'loeih sak.
\c 57
\s1 Rhih Om Hlipuei Loh
\s2 I'll Stand By Until The Morning
\sp Doh is Eb
\q1 
\v 1 Rhih om hli puei loh vael khoep tih
\q1 Ngai hmang la ka buek,
\q1 Muei rhih tam yin tui li dung ah
\q1 Long puei ka hmang sut.
\q2 \qt Omngaih khangkung ke so\qt*
\q2 \qt Omngaih lah a ol te hnatun uh. \qt*
\q2 \qt Kho thaih due kan om puei ni \qt*
\q2 \qt Nang khangham la ka lo la kueng boeh \qt*
\q2 \qt Min cang due la kan om puei ni\qt*
\q2 \qt Nang khang ham ka lo lakueng boeh\qt*
\q1 
\v 2 Ngaihmang khobing la ka om tih
\q1 Ka ko loh bawt sut
\q1 Khang kung boeipa a mah nen tah
\q1 omngaihnah ha soep.
\q1 
\v 3 Hlipuei tlan thim tui phu lak ah
\q1 Ka muelh thuk vaengah
\q1 Ka mueihla duek tom ca ca khaw
\q1 Khang kung Khrih ha lo.
\q1 
\v 4 Duek tom mueihla koep han hlawt tih
\q1 Lungnah la ha lo
\q1 Tui sang pho dong ka ngol ve tih
\q1 A im la m'mawt ni.
\c 58
\s1 Hingnah Hlipuei Loh Ha Thoo
\s2 He Will Hide Me
\sp Doh is G
\q1 
\v 1 Hing nah hli puei loh ha thoo tih,
\q1 cuek nah loh thing khoep vaengah ,
\q1 Kai loh ka tlap khing ka hlipyingnah hmuen
\q1 Pa then hlip khui ah ka hm uh.
\q2 \qt A mah loh n'thuh ni, \qt*
\q2 \qt amah loh n'thuh ni. \qt*
\q2 \qt rhal loh kai te n'na thai na pawt hamla \qt*
\q2 \qt A mah loh n'thuh ni, \qt*
\q2 \qt amah loh n'thuh ni. \qt*
\q2 \qt rhal loh n'na thai pawt ham kai n'thuh ni.\qt*
\q1 
\v 2 Ngai hmang hmuen la n'thak mai a khaw,
\q1 im then te ka rhing oel nah,
\q1 Soeprhaep ah thinsa na mueh la lung nah,
\q1 ka taeng ah han thoeng puei coeng.
\q1 
\v 3 Rhal ka taeng ah khoep vael mai tih,
\q1 Satan vuelvaek la vaengah ,
\q1 A tloh yak koi te Khohni a mah loh,
\q1 dung ya la a omngaih sak.
\q1 
\v 4 Te dong thing lam tung ka koh,
\q1 Rhih om kho hli vael vaengah ,
\q1 Jesuh loh ka mueihla he a dawn dah.
\q1 Pa kah a ca tah duek pawh.
\c 59
\s1 Khoengim Loh Cak Tangkik
\s2 How Firm A Foundation
\sp Doh is A
\q1 
\v 1 Khoeng im loh cak tang kik
\q1 Boeipa hlang cim rhoek
\q1 A cim dong ah na tang na te na khueh uh.
\q1 Amah loh nangmih taengah a thui te tah
\q1 Nangmih na yingnah hamla Jesu ha lo.
\q1 Nangmih na yingnah hamla Jesuh halo.
\q1 
\v 2 Rhih boeh na taeng ka om,
\q1 Aw la kueng boeh na Pathen la ka om.
\q1 Kai loh nang kan bom ni.
\q1 Na tha kan om sak vetih kan pai puei ni.
\q1 Kan lungvatnah kut neh nang kan thoh pawn ni.
\q1 Kan lungvatnah kut neh nang kan thoh pawn ni.
\q1 
\v 3 Tui li dung na hmuen ah,
\q1 Caeh rhoi hmaih hamla na mah ni kan khue.
\q1 Tui dung loh et pawt ham.
\q1 Na mah loh nan om puei a tah rhai nah neh
\q1 Omngaih nah yoethen nah a sang koek la om.
\q1 Kothae nah long he kai ham cim na la coeng.
\q1 
\v 4 Pa tang nah hmai lak ak ka cet li vaengah
\q1 Nan lung vat nah te tah kai hamla ha soep
\q1 Hmai ung te khaw kai ham ka hlang then na neh.
\q1 Ka ti ka hnai tlum hmawn ve ti sui bang la
\q1 A phu om a hlang a then na hamla coeng.
\c 60
\s1 Lai Hman Ah Rhih Omnah
\s2 To Live With God
\sp Doh is Bb
\q1 
\v 1 Lai hman ah rhih om nah yet mai cakhaw,
\q1 bangdong a nim ka rhih eh.
\q1 Hmuh mueh Pa then neh ka caeh hmaih a tah
\q1 Me la khaw ka cet mong ni ta.
\q2 \qt Tedong ah ka puei rhoek \qt*
\q2 \qt Pathen taengah na thin cak saeh. \qt*
\q2 \qt Me vaengah ko bawt kolla \qt*
\q2 \qt Pathen taeng m'pha uh a tah, \qt*
\q2 \qt omngaihnah me tluk lam lae hmuh na eh.\qt*
\q1 
\v 2 Khodaeng ming nah soep rhaep ha pai cakhaw
\q1 bangdong a nim ka rhih eh,
\q1 Pa then te ka mah taeng a om a tah,
\q1 Me la khaw ka cet mong ni ta.
\q1 
\v 3 Duek nah longhoi dung ah ka cet cakhaw
\q1 bangdong a nim ka rhih eh,
\q1 Ka kut a cak la tlal han tuk a tah,
\q1 Me la khaw ka cet mong ni ta
\q1 
\v 4 Ka pilnam boeih rhal la ha tho cakhaw,
\q1 bangdong a nim ka rhih eh,
\q1 Kho neh len nah ka so a om a tah,
\q1 Me la khaw ka cet mong ni ta
\c 61
\s1 Tuiding Cim A Longnah Langdai
\s2 Where The Saviour Leads
\sp Doh is Eb
\q1 
\v 1 Tui ding cim a long nah langdai hmuen a khaw,
\q1 Khangkung Jesuh mawt na kung ah ka cet ni.
\q1 Tui phu lak a khaw a kut neh m'mawt a tah,
\q1 Olthangthen thui ham omngaih la ka cet ni.
\q2 \qt Khang boei mawt na kung ah, \qt*
\q2 \qt omngaih la ka cet ni. \qt*
\q2 \qt Khang kung boei loh mawt nah \qt*
\q2 \qt kung ah uem neh ka cet ni.\qt*
\q1 
\v 2 Moldong tlang sang khosik rhado lak a khaw,
\q1 A hui taeng lam kah ka hma tu te tlap ham,
\q1 Hlipuei rhonu tlanbuk tlan thim lak a khaw,
\q1 Khang kung boei loh mawt na kung a ka cet ni.
\q1 
\v 3 Khang kung boei loh mawt nah kung ah ka cet ni,
\q1 Pa tang rhainah soep rhaep loh pinyen cakhaw,
\q1 Loeih nah long puei he amah loh boeih a ming.
\q1 Vaan dong im then la caeh nah long puei a ming.
\c 62
\s1 Kopoekrhai Khangkhung Boei
\s2 He Hideth My Soul
\sp Doh is D
\q1 
\v 1 Kopoek rhai khangkung boei tah Jesuh boeipa.
\q1 Kai ham kopoekrhai khangkung boei.
\q1 Lungnu khui ah ka mueihla te a thuh tih.
\q1 omngaihnah tuiva te ka hm uh.
\q2 \qt Lung nu khuiah ka mueihla te a thuh coeng. \qt*
\q2 \qt rhamrhae khui ah hlipkhup then ni. \qt*
\q2 \qt A lung na khuiah ka mueihla te a thuh tih \qt*
\q2 \qt a kut neh khoep a hlip dah \qt*
\q2 \qt A kut neh kai khaw n'dah van coeng.\qt*
\q1 
\v 2 Kopoek rhai khang kung boei tah Jesuh boeipa.
\q1 Ka hnorhih boeih te a han loh.
\q1 Amah loh n'tuk dong ah ka thuen tlaih mah pawh.
\q1 Hnin takuem ka tha han om sak.
\q1 
\v 3 Yoethen toeklektoekna te kai m'paek bal tih,
\q1 Hnothen cungkuem ham baetawt sak.
\q1 Amah loh n'coi na hnin laa la ka sak tih,
\q1 Kai boeipa ka Kho hni ka poek.
\q1 
\v 4 Amah kah bai bok bai tih ka thoh vaengah,
\q1 Vaan dong ah ka hmu uh rhoi ni.
\q1 Hlang toek lek toek na neh vaan dong sosang ah,
\q1 lung nah soep te ka koeh pawn ni.
\c 63
\s1 A Phae Hlip Hmui Ah
\s2 Under His Wings
\sp Doh is Db
\q1 
\v 1 A phae hlip hmui ah a mong la kai ka om.
\q1 Muei rhih tamyin cuekhalhnah lak a khaw.
\q1 A mah loh kai n'khoem bael ni ti la ka ming.
\q1 Kai n'tlan tih a ca la kai ka om coeng.
\q2 \qt A phae hlip ah A phae hlip ah \qt*
\q2 \qt Lung vat nah a ka pae kung. \qt*
\q2 \qt A phae hlip ah ka mueihla duem ni. \qt*
\q2 \qt Dung yan ngai mong la om ni. \qt*
\q1 
\v 2 Ko thae vaengah a phae hlip dong ah ka ying.
\q1 Ka lung buei long ngaimong na bueng a ngai.
\q1 Dilai ah ka hoeih na tui si om tlaih pawh.
\q1 A mah dong bueng a ni sayalh a om.
\q1 
\v 3 A phae hlip ah omngaihnah a sang koek om
\q1 Ka hingnah pa tang vaengah ka yingnah.
\q1 Te hlip khup ah tholh cuek halh nah om tlaih pawh.
\q1 Jesuh pum ah dung yan ka duem pawn ni.
\c 64
\s1 Somko Pako Tah
\s2 The Ninety And Nine
\sp Doh is Ab
\q1 
\v 1 Somkopako tah vong up khuiah a mong
\q1 ca la kol uh van coeng dae ta,
\q1 Pa khat tah vong ka lam kah a hla na hmuen
\q1 mol voel tlang hlaep ah vik hma ta coeng.
\q1 Tudawn kodo kut khui lam ka loh,
\q1 A hla hlang khohong rhaita khui la vik hma coeng.
\q1 Kho hong rhai ta la vik ah ta coeng.
\q1 
\v 2 Boeipa ta hae som ko pa ko a om he
\q1 nang hamla ta hae rhoeh hlan a?
\q1 He khaw kai kah tu ni tu ni a hla la
\q1 a ka cet tudawn kung loh a thui.
\q1 Long puei loh rhai tih tih kael ca khaw,
\q1 Tu hma tlap hamla kho hong khui la ka cet ni.
\q1 Tu hma tlap ham kho hong la ka cet ni.
\q1 
\v 3 Na tlan tang tae rhoek loh a ka hma tuca
\q1 rhoek te tui dung neh yin lak ah,
\q1 Patang palai doe ah a tlap tih a hmuh
\q1 te khaw a ming uh tlaih voel moe nih.
\q1 Rhamrhae rhae khui ah tloh tat pa tang neh,
\q1 a ka bom kung a om voel mueh la duek tom coeng.
\q1 A ka bom om mueh la duek tom coeng.
\q1 
\v 4 Boeipa long puei ta kuem ah na thisen a
\q1 cip te a ming u moe nih a?
\q1 Na taeng lam ka loh a ka hma rhoek na hmuh
\q1 hlan due la na cip sak thisen te,
\q1 A mih rhoek boeih coi tun na ham la,
\q1 Na kut te thicung ne a khing u tang mai aw,
\q1 Na kut te thicung neh a khing uh.
\c 65
\s1 Kolkahlh N'caeh Phoeiah
\s2 A Few More Marchings Weary
\sp Doh is A
\q1 
\v 1 Kolkalh n'caeh phoeiah vaan dong im ah n'tun uh ni.
\q1 Patangnah muei mpoeng phoei ah vaan ah n'tun uh ni.
\q1 Thinglam te n'koh phoeiah suilumuek muek ham Jesuh neh n'om ni.
\q1 Kolkalh n'caeh phoeiah vaandong im ah n'tun uh ni.
\q2 \qt Rhalvangan m'pha vaengah , Dungyan la tun u ni.\qt*
\q2 \qt Kol kalh ca n'caeh phoei ah vaan ah n'tun ni.\qt*
\q1 
\v 2 Kolkalh n'rhah phoeiah vaan dong im ah tun uh ni.
\q1 Kolkalh ca n'rhing uh phoei ah van ah n'tun uh ni.
\q1 Tholhyoeknah n'ta phoeiah cang pa pawn ham vaan ah ke n'tun uh ni.
\q1 Kolkalh n'caeh phoeiah vaandong im ah n'tun uh ni.
\q1 
\v 3 Kol kalh phih uh phoei ah vaan dong ah n'tun uh ni.
\q1 Lung nah ol n'thui uh phoei ah vaan ah n'tun uh ni.
\q1 Long puei a bawt vaengah vaan Ka nan ram then te m'pha uh pawn ni.
\q1 Kol kalh n'caeh phoei ah vaan dong im ah n'tun uh ni.
\c 66
\s1 Aw Hmuen Sang kah Ka Loeihnah
\s2 Hiding In Thee
\sp Doh is F
\q1 
\v 1 Aw hmuen sang kah ka loeih nah lung nu dong ah
\q1 Ka mueihla long tah ding hamla a ngaih coeng.
\q1 Kai hlang tholh padalh koek mai he rhen lam tah
\q1 A cak lung nu then dong ah kai he n'thuh lah.
\q2 \qt Namah ah n'thuh namah ah n'thuh \qt*
\q2 \qt A cak lungnu then namah dongah kai n'th uh.\qt*
\q1 
\v 2 Kho sae lak kah kho daeng ming nah boeih boeih neh,
\q1 Cuekhalh nah loh ka soah bi a bi tih,
\q1 Ka hingnah tholhtui phu a thoh bal vaengah,
\q1 A cak lungnu then dongah kai he n'thuh lah.
\q1 
\v 3 Ngai hmangnah neh caemrhal a thoh bal vaengah ,
\q1 Ka ying na hmuen ah ka thuh tih ka hil hoem,
\q1 Noemcai nah tuiphu loh a thoh vaengah khaw,
\q1 Ka mueihla tah lungnu then dongah a th uh.
\c 67
\s1 Caemrhal Rhih Om A Yoei
\s2 As Thy Days Thy Strength
\sp Doh is Db
\q1 
\v 1 Caem rhal rhih om a yoei vaengah,
\q1 Ka hna neh a olthang ka yaak.
\q1 Na ngaih bangla ka tha om sak
\q1 Khang kung Jesuh loh han thui coeng.
\q2 \qt A ol tah lung nu puei vong ni \qt*
\q2 \qt Ke ol dong ah kai tah ka ying. \qt*
\q2 \qt Na mah hing lung a vang bang la \qt*
\q2 \qt Na noe vaengah tha kan tom ni.\qt*
\q1 
\v 2 He bang ol khueh ka yak vaengah,
\q1 Ka ko khui ah ngaimong na bae,
\q1 Na hing khui puet tha dueng thai neh
\q1 kan om sak ni a ti dong ah.
\q1 
\v 3 Ka duek na tue a yoei vaengah,
\q1 Na ol kam te ka uep na tih,
\q1 Uep nah bangla ka hing khui ah
\q1 tangnah thadueng te han tom lah.
\c 68
\s1 Hnatun a Lungnah Tlo Koek
\s2 Behold What Love
\sp Doh is Db
\q1 
\v 1 Hna tun a lungnah tlo koek te
\q1 Kai hlang tholh taeng ha tueng.
\q1 Hlang tholh kai he a mah kah ca la khue
\q1 la kai ka om tang tang coeng.
\q2 \qt Hnatun ko poekrhai lungnah, \qt*
\q2 \qt Pathen loh ma mih so ah \qt*
\q2 \qt me tluk la lung nah a khueh, \qt*
\q2 \qt Pathen ca n'ti na u coeng \qt*
\q2 \qt Tlang tae hlang la om coeng dong ah.\qt*
\q1 
\v 2 A thisen a hawk tih tahae
\q1 amah neh n'hla uh pawh.
\q1 A khueh duen ca la n'doe tih
\q1 Pathen amah rhang suk dongah m'pom.
\q1 
\v 3 Aka lo ham koi boeilennah
\q1 te tahae ah tueng hlan.
\q1 Lungnah boeipa m'hmuh uh vaengah
\q1 A mueimae boeih m'pang u pawn ni.
\q1 
\v 4 Te ngaiuepnah neh ka dan vaeng
\q1 ah hing cim na ka ngaih
\q1 A muei hmuh ham koi khangkung
\q1 Jesuh a mueimae neh loh uh ham
\c 69
\s1 Tholhnah Tuidung ah Ka Buek
\s2 Love Lifted Me
\sp Doh is B
\q1 
\v 1 Tholh nah tui dung ah ka buek,
\q1 tui kaeng lam kah ka hla
\q1 Tui let tui dung tang kik khui,
\q1 thoh thai mueh la ka tla,
\q1 Te dae tui tun li boeipa ,
\q1 ka pang nah ol han yak,
\q1 Tui li khui lam kah kai n'doek tih kai ka loeih.
\q2 \qt Lung vatnah loh kai m'pa cuet hang\qt*
\q2 \qt bomkung om pawt vaengah \qt*
\q2 \qt kai he m'pa cuet \qt*
\q2 \qt Lung vatnah loh kai m'pa cuet hang \qt*
\q2 \qt bom kung om pawt vaengah \qt*
\q2 \qt kai he m'pa cuet \qt*
\q1 
\v 2 Thinko boeih amah ka paek,
\q1 soeprhaep boeih khaw ka paek,
\q1 Amah kah a kho kung ah,
\q1 om ngaihnah laa ka sak,
\q1 Lung nah ka len a ka dueng,
\q1 Koeh nah laa te ka sak.
\q1 A taengah uepom la a bi ka bi ni.
\q1 
\v 3 Rhihom hmuen kah ka mueihla
\q1 a so ben ke dan lah
\q1 A soep lah Jesuh loh n'tlan,
\q1 lungnah neh m'pa cuet hang,
\q1 Tui tuen li boeipa la om,
\q1 Tuipuei loh ol a ngai,
\q1 Amah bueng ni khang kung
\q1 tihnin nang n'khang thai.
\c 70
\s1 Long Ka Taeng Phael Pawt Ham
\s2 Lead Me, Saviour
\sp Doh is Db
\q1 
\v 1 Long ka taengphael na pawt ham,
\q1 Kodo na neh longpuei m'mawt.
\q1 Na taeng a tah ka sa sueng,
\q1 Na lung na dong ah ka om.
\q2 \qt Kai m'mawt kai m'mawt \qt*
\q2 \qt long ka phael na pawt hamla \qt*
\q2 \qt Ko do na neh kai m'mawt lah \qt*
\q2 \qt Kai m'mawt ka long puei ah m'mawt.\qt*
\q1 
\v 2 Ka hingnah tuiphu thoh vaeng,
\q1 Mueihla ham nang kan ying nah.
\q1 Rhen nah ah ka hang dang tih
\q1 Yin akhaw ka ngai ha mong.
\q1 
\v 3 A bawt due m'mawt khangkung boei.
\q1 Ka hingnah long he khum tih,
\q1 Mik phi a tui a rhaem nah,
\q1 Te ram om then ka pha due.
\c 71
\s1 Pathen Loh Hlang Hing
\s2 Wondrous Love
\sp Doh is Eb
\q1 
\v 1 Pathen loh hlang hing tholh ah ka
\q1 po tang tae a lung nah.
\q1 Khangnah a pom sang koek a paek
\q1 tih hlang hing boeih a khang.
\q2 \qt Aw ko poek rhai a lungvatnah! \qt*
\q2 \qt Pathen loh lungnah he, \qt*
\q2 \qt Vaan lam khang kung ha rhum tih \qt*
\q2 \qt Kal va ri tlang ah a duek ke.\qt*
\q1 
\v 2 Tang nah rhang neh Pathen ca pa
\q1 te kai hamla om coeng.
\q1 A thii a hawk a duek rhang neh
\q1 kai tlan tae la ka om.
\q1 
\v 3 Lung nah neh boeilen nah m'pang te
\q1 hlang cim rhoek a ming sak.
\q1 Khrih a mah long ni tholh lam kah
\q1 duem nah te m'paek thai eh.
\q1 
\v 4 A ka tang nah loh omngaih lah,
\q1 nang mih paek la om coeng.
\q1 Dik lai ah tang nah na khueh bang
\q1 la vaan ram na pang ni.
\c 72
\s1 Thinglam Dong Khangkung Boei Duek
\s2 Love Held Him On The Cross
\sp Doh is Ab
\q1 
\v 1 Thinglam dong khangkung boei duek
\q1 cim nah tuisih a phuet sak.
\q1 Ka tholhnah boeih boeih te a cim sak.
\q1 Lungnah sang koek a khueh tih,
\q1 Vaan kah ngol hmuen a caeh tak.
\q1 Kai loh a ming ka koeh thai lek pawh.
\q2 \qt Khing nah thicung loh tu pawh, \qt*
\q2 \qt Tedae kai n'lung na dong ah, \qt*
\q2 \qt Ka boeipa te thing lam dong a bang \qt*
\q2 \qt Kai hamla duek nah a tong \qt*
\q2 \qt kai tah ka sa te sueng tih \qt*
\q2 \qt Jesuh bueng loh tholh phu a sah thai.\qt*
\q1 
\v 2 Kobawtnah neh ka om vaeng,
\q1 Ka tholh nah phueih ham ha lo,
\q1 Kai yueng a ka duek hlang tloe om pawh.
\q1 Kai hingnah boeih te ka paek,
\q1 Thangpom na laa ka sa ni,
\q1 Ko poek rhai lungvatnah neh n'tlan coeng.
\q1 
\v 3 Lungbuei tholhnah a cim sak,
\q1 Mueihla Cim neh kai om puei,
\q1 Hnin takuem ah ka hnorhih ham phueih.
\q1 Ka pamdah na kung lam kah,
\q1 Ka im then ben la ka bal,
\q1 Te hmuen ah boeipa te ka hmuh ni.
\c 73
\s1 Kunnah Thenkoek Omngaihnah
\s2 Resting In The Everlasting Arms
\sp Doh is A
\q1 
\v 1 Kuntunnah then koek omngaihnah kai ham,
\q1 dungyan a rhang dongah kai ka om,
\q1 Yoethennah cungkuem Pa then ngaimongnah
\q1 dung yan a rhang dongah ka om coeng.
\q2 \qt Ka duem ka duem \qt*
\q2 \qt lakueng rhih om lam loh hoep tlang coeng. \qt*
\q2 \qt Ka duem ka duem \qt*
\q2 \qt dungyan a rhang dongah ka om coeng. \qt*
\q1 
\v 2 Ka yin caeh long ah voelphoeng la ka om,
\q1 dungyan a rhang dongah kai ka om,
\q1 Hin takuem dong ah ka long puei ha khui
\q1 dungyan a rhang dongah ka om coeng.
\q1 
\v 3 Bang nim ka mawn nah bang nim ka rhih eh,
\q1 dungyan a rhang dongah kai ka om,
\q1 Khangkung taeng ka caeh vaeng ngaimong na soep
\q1 dungyan a rhang dongah ka om coeng.
\c 74
\s1 Diklai Omthen Bawnnah Lakah
\s2 I Know I Love Thee Better Lord
\sp Doh is C
\q1 
\v 1 Diklai omthen bawnnah lak ah,
\q1 Boeipa nang kan lungnah.
\q1 Balong khaw a phae tloel mongnah
\q1 nang loh nan paek dong ah.
\q2 \qt A vang a thal khaw ka thui hlan, \qt*
\q2 \qt a yoe la lungnah he, \qt*
\q2 \qt A vang a thal khaw ka thui hlan \qt*
\q2 \qt a thii sen neh silh he.\qt*
\q1 
\v 2 Diklai paya hmuen then lakah
\q1 Boeipa ni yoei ka ngaih.
\q1 A tloe lung na laa boeih lak ah
\q1 na mah tah na di dip.
\q1 
\v 3 Ka lungbuei na omngaih sak tih
\q1 omngaih ha loh ha soep
\q1 Lungnah he nan hnaih pawt dongah
\q1 ka ko ka ngai hlih pawh.
\q1 
\v 4 Aw khang kung boei na then tang kik,
\q1 Na taeng ah om then mai
\q1 Na mah neh n'caeh rhoih hmaih a tah
\q1 ka hing he omngaih soep.
\c 75
\s1 Aw Ka Hingnah Pathen Koeh Lah
\s2 Amazing Grace
\sp Doh is G
\q1 
\v 1 Aw ka hing nah Pathen koeh lah,
\q1 ka mueihla omngaih lah,
\q1 Nan dawn nan dah,
\q1 nan poeh nan pom,
\q1 Mik dael kho nan hmuh sak.
\q1 
\v 2 Paeng tom hlang boeih omngaih uh saeh,
\q1 Lungnah tui cil pawk long,
\q1 taeng om taeng ca na khueh tawn sak,
\q1 Pathen na len tangkik.
\q1 
\v 3 Khodaeng buhpong hlang na cah tih,
\q1 Hoemdam hlang tah na hlak.
\q1 Saltam na khaw lat na pom sang
\q1 ko poek rhai lungnah neh.
\q1 
\v 4 Halelui jah Haleluijah
\q1 Haleluijah Amen
\q1 Hale lui jah Hale luijah
\q1 Haleluijah Amen.
\c 76
\s1 Aw Bethlehem Nang Vangca Kho
\s2 O Little Town Of Bethlehem
\sp Doh is G
\q1 
\v 1 Aw Bethlehem nang vangca kho,
\q1 sipdip la na om sut.
\q1 Na ih loh a tui li vaengah na soah aisi cet.
\q1 Long puei a hmuep vaeng ah
\q1 dungyan vangnah tah ha sae.
\q1 Ngai uep nah rhing oel khing coeng
\q1 te kho yin ah ha thoeng coeng.
\q1 
\v 2 Khrih tah Mari loh a cun tih,
\q1 Boeih boeih lak ah tang lue,
\q1 Diklai hlang a ih li vaengah
\q1 vancaeltueih loh a tawt.
\q1 Aw aisi thuipa nang
\q1 Cet lamtah a thang na thui.
\q1 Manghai khohni koe u lam
\q1 tah lai ah rhoep na om saeh.
\q1 
\v 3 Sipdip ca la sipdip ca la,
\q1 kut doe then te m'paek coeng.
\q1 Manghai mah kho hni a mah loh
\q1 lai hlang ngai mong nah m'paek.
\q1 Diklai hlang tholh rhoek loh ha lo
\q1 na thang ya pawt dae,
\q1 Lunghoih ko do hlang rhoek dong a
\q1 tah Khrih amah kun coeng.
\q1 
\v 4 Bethlehem kah a cim camoe,
\q1 Kai mih taeng ah ha rhum,
\q1 Kaimih tholh han cim caih sak lam
\q1 ti hnin ah ha thang lah,
\q1 Omngaih na Khrimas thang te
\q1 kai mih loh ka yaak uh,
\q1 Ka boeipa Emanuel
\q1 kaimih taengah ha om lah.
\c 77
\s1 Hlaenben Khawn Phai
\s2 The Angels’ Song
\sp Doh is G
\q1 
\v 1 Hlaem ben khawn phai kho yin li ah,
\q1 Boeilen omngaih laa ol ta rha thoeng.
\q1 Then tang kik mai te laa ol te
\q1 vaan hlang rhoek loh a sak uh laa te.
\q2 \qt Boeilen boeilen so sang koek ah \qt*
\q2 \qt Hlang boeih so ah rhoep na om pawn saeh, \qt*
\q2 \qt A yoe ya la khaw thang pawn saeh, \qt*
\q2 \qt He diklai loh omngaih pawn saeh.\qt*
\q1 
\v 2 Tudawn rhoek loh a hmuh uh ti,
\q1 Vaan hlang loh a thui te a yaak uh.
\q1 Te phung ding te a yaak vaengah
\q1 a hlang tueih loh bawk hamla kuep uh.
\q1 
\v 3 Pathen hlangtuek khangkung Khrih tah,
\q1 mamih lai ba sah hamla ha rhum,
\q1 Pa then tuca loh mamih kah
\q1 tholhnah boeih boeih te tah a phueih coeng.
\c 78
\s1 Uepom Hlang Boeih Ha Lo
\s2 O Come, All Ye Faithful
\sp Doh is G
\q1 
\v 1 Uep om hlang boeih ha lo,
\q1 omngaih thahlue ca neh,
\q1 Bethlehem kho la tahae ha lo uh.
\q1 So uh boeih lah sih
\q1 vaan Boeipa thang coeng.
\q2 \qt A mah te tah koeh uh sih, \qt*
\q2 \qt A mah te tah koeh uh sih \qt*
\q2 \qt A mah te tah koeh uh sih \qt*
\q2 \qt Khrih boeipa te.\qt*
\q1 
\v 2 Vaan olsoep neh laa sa,
\q1 Jesuh thang pom nah laa,
\q1 Vaan dong kah hlang cim
\q1 boeih long khaw sa uh,
\q1 Boeilen Pathen tah
\q1 a ming thang pom uh,
\q1 
\v 3 Boeipa kan thangthen uh,
\q1 Ta hae ah ka thang te,
\q1 Aw Jesuh boeilen nah boeih kan paek uh,
\q1 Pathen ol tak te pum sa la ha tueng.
\c 79
\s1 Diklai Omngaih Boeipa Ha Rhum
\s2 Joy To The World The Lord Is Come
\sp Doh is Eb
\q1 
\v 1 Dik lai omngaih Boeipa ha rhum,
\q1 manghai te doe uh lah.
\q1 Na thin na ko rhoekbah uh lam
\q1 vaan neh lai laa sa uh,
\q1 vaan neh lai laa saa uh.
\q1 vaan neh vaan neh lai laa sa uh.
\q1 
\v 2 Diklai omngaih Khang kung loh n'uk,
\q1 Hlang boeih boeih laa sa uh.
\q1 Lai neh tui puei mol tlang boeih loh
\q1 omngaih laa koep sa bal
\q1 Omngaih laa koep sa bal
\q1 omngaih omngaih laa sa bal dae.
\q1 
\v 3 Khodaeng patang boeih hma pawn ni,
\q1 Hlingthun omvoel ma pawh,
\q1 Diklai hman kah paeng pum boei he,
\q1 Yoethen paek ham ha rhum,
\q1 Yoethen paek ham ha rhum
\q1 Yoethen Yoethenpaek ham ha rhum.
\q1 
\v 4 Duengnah phung then lungvatnah loh,
\q1 Namtom hlang boeih a uk,
\q1 A duengnah neh a lung vat nah,
\q1 Hlang tom boeih a ming sak,
\q1 Hlang tom boeih a ming sak
\q1 hlang tom hlang tom boeih a ming sak.
\c 80
\s1 Aw Halo Lah Nang Immanuel
\s2 O Come Emmanuel
\sp Doh is G
\q1 
\v 1 Aw halo lah nang Imanuel,
\q1 Isarel thong tla rhoek loeih nah
\q1 He ah ko thae om uh li he
\q1 Pathen ca pa ha thoeng hlan due.
\q1 Omngaih omngaih
\q1 Ima nu el ha lo coeng Aw Isarel.
\q1 
\v 2 Aw ha lo lah nang khothaih then te,
\q1 Ka mueihla loh nang lam li he,
\q1 mueirhih tamyin khui lam ka loh
\q1 ka mueihla he loeih laeh ka ngaih.
\q1 Omngaih omngaih
\q1 Ima nu el ha lo coeng Aw Isarel.
\q1 
\v 3 Aw ha lo lah nang soben cueih nah,
\q1 A hla a yoei soep rhaep na khueh,
\q1 Kaimih ham cueihnah long nan tueng,
\q1 Na long puei ah nan caeh sak uh.
\q1 Omngaih omngaih
\q1 Ima nu el ha lo coeng Aw Isarel.
\q1 
\v 4 Aw ha lo lah nang namtom loh n'ngai,
\q1 hlang boeih ko at la na hui sak,
\q1 Nang loh ko thae nah na hma sak,
\q1 Nang ni ngai mongnah manghai boei.
\q1 Omngaih omngaih
\q1 Ima nu el ha lo coeng Aw Isarel.
\c 81
\s1 Kopoek Rhai Lungnah
\s2 Wondeful Grace of Jesus
\sp Doh is C
\q1 
\v 1 Kopoek rhai Jesuh lungnah,
\q1 Ka tholh nah lakah len.
\q1 Ol Ka neh me tlam ka thui eh,
\q1 me tlam lae ka koeh eh,
\q1 Ka hno rhih boeih a loh tih,
\q1 ka mueihla a loeih sak.
\q1 Kopoekrhai lungnah neh
\q1 Jesuh loh kai n'om puei.
\q2 \qt Ko poek rhai Jesuh kah lungvatnah tah \qt*
\q2 \qt Tui tun li ah dung ngai tih ka ngai. \qt*
\q2 \qt mol tlang lak ah sang ngai \qt*
\q2 \qt sih tui bang la ha phuet. \qt*
\q2 \qt Soeprhaep ah lung nah kai hamla rhoeh, \qt*
\q2 \qt kai boe thae lah ah khaw ka coeng tih, \qt*
\q2 \qt ka yah na la ah khaw sang ngai bal \qt*
\q2 \qt Aw Je Jesuh ming tlo koek te \qt*
\q2 \qt thang pom nah om yoe yah saeh.\qt*
\q1 
\v 2 Kopoek rhai Jesuh lungnah,
\q1 sungdaeh na boeih a ming,
\q1 Rhen la kai tah ka om coeng,
\q1 khang na soep ne m'paek coeng.
\q1 Tamdaeng pin na rhui a thuek
\q1 yalponah te m'paek coeng,
\q1 Kopoekrhai lungnah neh
\q1 Jesuh loh kai n'om puei.
\q1 
\v 3 Ko poek rhai lung nah neh
\q1 Jesuh loh kai n'om puei.
\q1 Ko poek rhai Jesuh lungnah,
\q1 tuei laeh kap a cim sak,
\q1 Te thaom nah loh n'thai sak,
\q1 Pathen ca la n'coeng sak.
\q1 Kopoekrhai lungnah neh
\q1 Jesuh loh kai n'om puei.
\c 82
\s1 No El Lamhma
\s2 The First Noel, The Angels Did Say
\sp Doh is D
\q1 
\v 1 Noel lamhma vaan hlang loh a thui,
\q1 Khodaeng ca tu dawn rhoek taeng ah.
\q1 Tu a dawn nah kho hong khui ah,
\q1 Sik ca kho yin kho yin long hmuep.
\q2 \qt No el No el No el No el \qt*
\q2 \qt I sarel manghai boei thang coeng.\qt*
\q1 
\v 2 Vaan a dan vaengah aisi a hmuh,
\q1 Mik voelh hla hlang kho long lam loh,
\q1 diklai pum he a tue khung daeng,
\q1 kho yin khothaih bawt mueh la vang.
\q1 
\v 3 Te ai si neh thikat hmaih ca la,
\q1 kho hla hlang cuei pa thum halo.
\q1 manghai boeih tlap hamla cai uh,
\q1 Ai si caeh nah te a vai uh.
\q1 
\v 4 Ai si loh khotlak ben la thoeih tih,
\q1 Bet hle hem kho so a te duem,
\q1 te hmuen ah pa hoi tung tai duem,
\q1 Boei Jesuh a omna tueng ah.
\c 83
\s1 Yin Thuem Khoyin Khocil Vaengah
\s2 It Come Upon The Midnight Clear
\sp Doh is Bb
\q1 
\v 1 Yin thuem kho yin khocil vaeng ah,
\q1 a boeilennah ha thoeng.
\q1 Vaan hlang loh lai la ha yoei tih
\q1 a sui tingtoenga tum.
\q1 Lai ah rhoep nah om ah rhoep saeh
\q1 vaan ah manghai boei boeilen saeh.
\q1 Dik lai long tah long duem la om,
\q1 te laa sak a yak ah.
\q1 
\v 2 Hno rhih loh a nan hlang boeih neh,
\q1 birhih hlang rhoek tho lah,
\q1 longpueng lampae,
\q1 caeh thuk caeh hang
\q1 pa tang hlang boeih long khaw,
\q1 Dan uh van lah omngaihnah
\q1 a tue a ka khuen kung ke,
\q1 A taeng ah hno rhih hal lam tah,
\q1 laa ol ke hna tun lah.
\q1 
\v 3 Tonghma rhoek loh a lamtawn uh,
\q1 omngaih hnin ha pai coeng,
\q1 Kho kum kho hal a thui uh sut
\q1 te tahae ah ha thoeng.
\q1 Lai neh vaan loh rhoep nah boei te
\q1 a boei na vaeng atah
\q1 Lai neh van loh vaan lai nang
\q1 hlang laa sak tahae ah sa van lah.
\c 84
\s1 Hnatun Vaan Hlang Laa Sak Ol
\s2 Hark, The Herald Angels Sing
\sp Doh is G
\q1 
\v 1 Hna tun vaan hlang laa sak ol
\q1 Boei thai thang boeilen koek ni.
\q1 Lai dong ah rhoep na om saeh,
\q1 Pathen kah moeithennah ni.
\q1 Paeng tom boeih loh omngaih uh,
\q1 Vaan ah ta nah laa sa uh,
\q1 Vaan dong hlang rhoek loh a thui
\q1 Khrih Bethlehem ah thang coeng.
\q1 Hnatun vaan hlang laa sak ol
\q1 Boei thai thang boeilen koek ni.
\q1 
\v 2 Khrih vaan hlang loh a bawk te
\q1 Aw dung yan boeipa la om.
\q1 A tue loh a pha vaeng ah,
\q1 hu la cim khui lam kah thang
\q1 Pa then hlang hing la ha coeng
\q1 Pathen muei te ha tueng coeng
\q1 Ko hoe ol hlang taeng a thui
\q1 Jesuh tah Imanuel
\q1 Hnatun vaan hlang laa sak ol
\q1 Boei thai thang boeilen koek ni.
\q1 
\v 3 Rhoepnah boei ke thangpom uh
\q1 Duengnah kho la ka sae ke
\q1 khosae then hingnah han khuen,
\q1 sadingnah neh thohkoep Boei,
\q1 a kodonah thangpom uh
\q1 cun thai hlang tah duek mah pawh
\q1 Diklai hlang boeih thoh koep nah
\q1 Hnatun vaan hlang laa sak ol
\q1 Boei thai thang boeilen koek ni.
\c 85
\s1 Na Boei Ngolhmuen Neh
\s2 Thou Didst Leave Thy Throne
\sp Doh is F
\q1 
\v 1 Na boei ngolhmuen neh
\q1 na boei lumuek na caeh tak,
\q1 diklai dong hlang boeih ham na lo.
\q1 Na thang na hamla te
\q1 Bethlehem kho khui ah
\q1 Na thangnah hmuen kang na om pawh.
\q2 \qt Kai kah ko khui ah ha om lah \qt*
\q2 \qt Nang hamla om nah hmuen then om \qt*
\q2 \qt Kai kah ko khui ah ha om van lah \qt*
\q2 \qt Nang hamla om nah hmuen then om.\qt*
\q1 
\v 2 Vaan dong hlang rhoek boeih loh
\q1 omngaih laa a sak uh,
\q1 Bethlehem Jesuh a thang vaeng,
\q1 Jesuh loh khodaeng hna
\q1 rhah bang lam ni a thang,
\q1 ko do nah thin ko neh ha lo.
\q1 
\v 3 Metang neh vaca loh
\q1 om nah bu boeih a khueh,
\q1 dup puei thing ko thing baek dong ah,
\q1 Te ca khaw diklai hman
\q1 ah Jesuh a om vaeng
\q1 Ih nah hmuen kang na khaw om pawh.
\q1 
\v 4 Aw Boeipa hingnah ol
\q1 thangthen neh na rhum vaeng,
\q1 lai hlang tholh khang ham na lo ni,
\q1 Na vaan im la kai te
\q1 koep nan caeh puei ve tih,
\q1 kai hamla hmuen then om pawn ni.
\c 86
\s1 Aw Kopoekrhai Tonghma
\s2 Oh, Wonderous Name!
\sp Doh is C
\q1 
\v 1 Aw kopoekrhai ming tong hma rhoek
\q1 loh yan ah a yaak coeng.
\q1 Ha lo nah te a hmuh oep soeh,
\q1 rhoep nah boei capa te.
\q2 \qt Kopoek rhai thuituen kung boei neh, \qt*
\q2 \qt Boeilen koek boeipa ni. \qt*
\q2 \qt Dungyan rhoep nah boei neh \qt*
\q2 \qt Pathen ca pa manghai boei ni.\qt*
\q1 
\v 2 Aw ming then koek he vaan dong hlang,
\q1 cim rhoek loh a koeh te
\q1 Ming tloe boeih lak ah tanglue koek,
\q1 mamih hamla ying nah.
\q1 
\v 3 Aw ming tang lue koek tha om nah,
\q1 soep rhaep aka pae kung
\q1 A mah rhang neh tholh rhal n'ta tih,
\q1 vaan dong la n'kun uh coeng.
\c 87
\s1 Khrih Hlang Then Omngaih Uh
\s2 Good Christian Men Rejoice
\sp Doh is F
\q1 
\v 1 Khrih hlang then omngaih uh,
\q1 Lungbuei thinko tak neh.
\q1 Kai mih thui he hnatun uh,
\q1 Ti hnin Jesuh thang nah olthang he.
\q1 Vaito loh a hmai ah kuep,
\q1 Kong duk dong ah a om vaeng ah,
\q1 Khrih tihnin ah thang
\q1 Khrih tihnin ah thang.
\q1 
\v 2 Khrih hlang then omngaih uh,
\q1 Lung buei thin ko tak neh.
\q1 Om ngaih ol thang n'yak uh coeng,
\q1 Khri Jesuh ha thang coeng dong a ni.
\q1 A nih loh van thoh a ong,
\q1 hlang hing yoe then na a paek coeng.
\q1 Khrih a thang dong ah,
\q1 Khrih a thang dong ah.
\q1 
\v 3 Khrih hlang then omngaih uh,
\q1 Lungbuei thinko tak neh.
\q1 Duek nah hlan khaw rhih voel boeh,
\q1 Na ngai mong sak Jesuh ha thang coeng.
\q1 A om nah im then pang ham
\q1 nang neh hlang tom boeih a khue coeng.
\q1 Khang kung Khrih thang coeng
\q1 Khang kung khrih thang coeng.
\c 88
\s1 Boei Jesuh Kaimih Taengah
\s2 Away In The Manger
\sp Doh is F
\q1 
\v 1 Boei Jesuh kai mih taeng ah ha om lah
\q1 Lungnah neh kaimih taeng ah ha yoei lamtah
\q1 Na ca rhoek boeih dawndah lam yoethen pae
\q1 Vaan dong im ka pha u due namah loh mawt lah
\q1 
\v 2 Kongduk taeng kah caeh long tah ih hmuen om pawh
\q1 camoe Jesuh a lung a tloeng tih tih ip
\q1 Vaan ai si boeih loh a yalh nah hmuen a dan.
\q1 Yong dik boei Jesuh sul rham dongah ip sut
\q1 
\v 3 Vaito loh ca moe te haeng mai bal cakhaw
\q1 a nih long tah tet ca khaw a rhah kolla
\q1 Dan ngaih tangkik hlang mai mah oi ngaih camoe
\q1 Mincang khothaih loh a pha due la ka om
\c 89
\s1 Sipdip Hlaem A Cim Hlaem
\s2 Silent Night, Holy Night
\sp Doh is Bb
\q1 
\v 1 Sipdip hlaem a cim hlaem
\q1 soep rhaep boeih loh boeih cil
\q1 camoe nuca taeng a vael
\q1 ca moe cim te a dah khoep
\q1 vaan ngai mongnah neh ip
\q1 vaan ngaimongnah neh ip.
\q1 
\v 2 Sipdip hlaem a cim hlaem
\q1 tudawn rhoek hing hang sak
\q1 Vaan dong boeilen vangnah neh,
\q1 vaan hlang ping laa sak ol loh,
\q1 Khrih khang kung boei thang coeng
\q1 Khrih khang kung boei thang coeng.
\q1 
\v 3 Sipdip hlaem a cim hlaem
\q1 Mang hai Pathen ca pa
\q1 A maelhmai kho la ha sae,
\q1 Lungvatnah kho ha thai coeng
\q1 Jesuh a thang vaeng ah,
\q1 Jesuh a thang vaengah.
\c 90
\s1 Tudawn Rhoek Loh Tu A Tawt
\s2 While the Shephards Watched
\sp Doh is G
\q1 
\v 1 Tudawn rhoek loh tu a tawt tih
\q1 a ngol tun uh vaengah,
\q1 Vaancaeltueih loh ha rhum thuk tih,
\q1 Vangnah neh han tue thuk.
\q1 
\v 2 Rhih uh boeh diklai hlang rhoek aw,
\q1 omngaihnah ol thangthen,
\q1 Khang kung boeipa Khrih Pathen te,
\q1 Ca moe ca la thang coeng.
\q1 
\v 3 Da vid kho ah ti hnin ah thang,
\q1 Da vid ca dil lak ah,
\q1 Khrih boeipa ka khangkung te ah,
\q1 miknawt la ha om coeng.
\q1 
\v 4 Vaandong camoe te na hmuh ni,
\q1 hlang hing pum la ha tueng,
\q1 Himbai neh moelh a yol uh tih,
\q1 kong duk dong ah a soei.
\q1 
\v 5 Vaancaeltueih loh a thui phoei ah,
\q1 vaan dong hlangping ha tueng
\q1 a vang a then koek mai nen te,
\q1 Pathen ming a koeh uh.
\q1 
\v 6 Vaan dong ah ka om Pathen tah,
\q1 a thangthen ta aep saeh,
\q1 diklai ah ngai mong nah om saeh,
\q1 A rhen nah tueng pawn saeh.
\c 91
\s1 Vaan Dong Sang Kah Vaan Hlang
\s2 Angels We Have, Heard On High
\sp Doh is F
\q1 
\v 1 Vaan dong sang kah vaan hlang loh
\q1 lai dong ah laa han sak uh.
\q1 Tlang hlaep yilh loh a hoih vaeng
\q1 laa sak ol loh rhoi ta aep.
\q2 \qt A sosang koek Pa then \qt*
\q2 \qt thangthen la om saeh, \qt*
\q2 \qt lai hlang boeih so ah rhoep nah \qt*
\q2 \qt a yoe yah la om saeh \qt*
\q2 \qt A sosang koek Pa then \qt*
\q2 \qt thangthen la om saeh, \qt*
\q2 \qt lai hlang boeih so ah rhoep nah, \qt*
\q2 \qt a yoe yah la om saeh.\qt*
\q2 \qt (Glo ria inexcelsis Deo \qt*
\q2 \qt Gloria inexcelsis Deo)\qt*
\q1 
\v 2 Bethlehem la ha lo lah,
\q1 camoe sen te so uh lah,
\q1 Kho cungkueng doe ah bawk uh,
\q1 Boeipa Khrih thangthen sak uh.
\q1 
\v 3 Vaan hlang rhoek loh a koeh te,
\q1 Kongduk dong ah na hmuh ni,
\q1 Meri neh Joseph long khaw,
\q1 BoeiKhrih thangthen rhip uh sih.
\q1 
\v 4 Tu dawn rhoek omngaih uet ah,
\q1 laa then ol neh a koeh uh,
\q1 Cet uh sih lam koeh van sih,
\q1 boei thai ke uem uh van sih.
\c 92
\s1 Voei Khat Ah David Kho
\s2 Once In Royal David's City
\sp Doh is G
\q1 
\v 1 Voei khat ah David khokhui ah
\q1 Vaito im pakhat te om
\q1 Vaito kongduk te Camoe ham
\q1 thingkong la a phaih pa uh.
\q1 Cangkhuen manu Meri loh
\q1 camoesen Jesuh a uem.
\q1 
\v 2 Dik lai la vaan lam kah ha rhum,
\q1 soep rhaep boeih kah Pa then te,
\q1 Vai to im a im na tih
\q1 kong duk te ni a thing kong nah
\q1 Kho daeng pa tang hlang taeng ah
\q1 hingcimnah neh kho a sak.
\q1 
\v 3 A ca moe vaeng lam ka long ni,
\q1 A manu poeh pom kung te,
\q1 A lung na tih a hinyah nah,
\q1 Kodonah neh boe a ngai.
\q1 Mamih Khrih hlang rhoek boeih loh
\q1 a mah bang la om uh sih.
\q1 
\v 4 Hnuk khueng koek ah a mah m'hmuh ni,
\q1 A mah loh lung nah dong ah,
\q1 Kodo boengai hlang camoe te,
\q1 mamih kah boei la om ni
\q1 A om nah vaan omthen ah
\q1 A ca boeih te a mawt ni.
\q1 
\v 5 Vaito im ah om voel kolla,
\q1 boeilen vaan dong kho then kah,
\q1 Pa then ban tang ben ah te ngol,
\q1 Boeilen hlang la m'hmuh uh ni
\q1 amih tah aisi bang la a taeng vai ah vang uh ni.
\c 93
\s1 Kholo Manghai Pathum Rhoek Loh
\s2 We Three Kings Of Orient Are
\sp Doh is G
\q1 
\v 1 Kho lo manghai pa rhum rhoek loh
\q1 a hla lam kah kut doe kan khuen,
\q1 Noi neh tlang tui va ka lan uh,
\q1 Aisi hnuk kan vai uh.
\q1 Aw kopoekrhai ai si,
\q2 \qt A vangnah long tah then tangkik mai, \qt*
\q2 \qt Kho tlak ben due phueih m'mawt lah \qt*
\q2 \qt a taeng ka pha due la.\qt*
\q1 
\v 2 Boei thai ha thang Bethle hem ah,
\q1 A suilu muek ham kan khuen uh,
\q1 Dungyan ka sengpahrang boei nang,
\q1 Kai mih so ah om lah.
\q1 
\v 3 Botui koek paek hamla kan khuen,
\q1 Pathen taengah tho thueng na ham,
\q1 Thang thui nah koeh na kan bawk uh,
\q1 So sang koek Pa then te.
\q1 
\v 4 Mura te paek hamla kan khuen,
\q1 He botui kha tangkik he tah,
\q1 Kopoekrhai kothae neh dueknah,
\q1 hlan khui noek na ham ni.
\c 94
\s1 Boeilen Ram Kah Vaan Caeltueih
\s2 Angels From The Realms Of Glory
\sp Doh is C
\q1 
\v 1 Boeilen ram kah vaan caeltueih rhoek
\q1 lai hman lah phae na phuel uh,
\q1 Lunglai suen nah cil na thui uh,
\q1 Tahae mesiah thang coeng.
\q2 \qt Ha lo lam bawk ha lo lam bawk \qt*
\q2 \qt Khrih te bawk boei thai ha thang. \qt*
\q1 
\v 2 Noi tlang rham tlim sai noe na ah,
\q1 yin thuem ah tu ka tawt rhoek,
\q1 Hlang hing taeng ah Pathen ha om,
\q1 khosae then tah ha thoeng coeng.
\q1 
\v 3 Hlang cueih rhoek na poek nah hnawt laeh,
\q1 Mik tueng nah thai ha lo coeng
\q1 Namtu hlang kah ngai uep nah tlap,
\q1 A mah kai ai si na hm uh.
\q1 
\v 4 Hmueihtuk kung kah hlang cim rhoek boeih,
\q1 kum sen hlang na rhing oel te,
\q1 Boeipa tah ha pai pakcak coeng,
\q1 A bawkim khuiah ha tueng.
\c 95
\s1 Jesuh Kawng Ka Ming Ta Aep
\s2 More About Jesus
\sp Doh is Ab
\q1 
\v 1 Jesuh kawng ka ming ta aep ni,
\q1 A lungvatnah kawng ka thui ni,
\q1 Khangnah a soep la mingnah ham,
\q1 lungnah neh kai ham ka duek te.
\q2 \qt Jesuh kawng te ka ming, \qt*
\q2 \qt Jesuh ka ming ta aep \qt*
\q2 \qt Khangnah ol thangthen te ming tih, \qt*
\q2 \qt lung nah neh kai ham a duek nah. \qt*
\q1 
\v 2 Jesuh kawng ka ming ta aep ni,
\q1 A cim na te ming taaep ham,
\q1 Pathen mueihla tuklip kung loh,
\q1 Khrih kah a duek kawng te han thui
\q1 
\v 3 Jesuh kawng a ol neh ka ming,
\q1 Ka boeipa nen te hmaih ka om.
\q1 A ol ding te ka yak poepa
\q1 A ol thui te kai ka uep nah.
\q1 
\v 4 A rhaenghmuen long tah sang taaep,
\q1 A peng ram long khaw ka ta aep.
\q1 Rhoep manghai boeipa ka lo te,
\q1 A boei. len nah ka ming ta aep.
\c 96
\s1 Boeipa Dongah Omngaihnah Ham
\s2 Pardon, Peace, And Power
\sp Doh is Bb
\q1 
\v 1 Boeipa dong ah omngaihnah ham
\q1 Boeirhaeng te khaw poek boeh.
\q1 Amah dong ah tang nah ha tueng
\q1 toek lek toek na mueh la
\q2 \qt Tholh hlah nah, neh ngaimongnah \qt*
\q2 \qt A cim vaan dong, kho thai ah om \qt*
\q2 \qt Boei Jesuh loh, ma mih ham duek \qt*
\q2 \qt Omngaih neh thangthennah laa sa uh sih. \qt*
\q1 
\v 2 A rhennah loh tholhnah cung kuem,
\q1 A rhen tih a hlah coeng,
\q1 Jesuh thi suh thisen tholh hlah nah loh,
\q1 ngaimong nah te m'paek uh.
\q1 
\v 3 A lung vat na loh tholh a ta,
\q1 Hing soep na te m'paek coeng,
\q1 Cim Muei hla n'lung buei khui ah om,
\q1 tholh khui lam kah n'loeih sak.
\q1 
\v 4 Pa then taeng hlang mueihla mawt ham,
\q1 A mah Muei hla te m'paek.
\q1 A kutdoe then koek Khrih boeipa ,
\q1 ma mih lung buei ah om.
\c 97
\s1 Boei Jesuh Ka Soepnah Ham
\s2 Whiter Than Snow
\sp Doh is Ab
\q1 
\v 1 Boei Jesuh ka soep nah ham nang kan ngaidam,
\q1 Ka ko khui ah nang om yoeyah ham kan ngaih,
\q1 Muei he boeih ham phae cu cai boeih ham voei lah
\q1 vuel song lak ah bok na ham kai n'cim sak lah.
\q2 \qt Vuel song lak ah ka cim na hamla \qt*
\q2 \qt Nan silh a tah vuel song la ah ka cim ni.\qt*
\q1 
\v 2 Boei Jesuh ka cim nah pawt boeih han cim sak
\q1 Na thi cim neh atiahnai boeih han sil,
\q1 Te kah cim nah then neh kai soep rhaep khum coeng
\q1 vuel song lak ah bok na ham kai n'cim sak lah.
\q1 
\v 3 Boei Jesuh vaan lam ka loh kai he n'so thuk,
\q1 Ka hmueih hlut a soep na ham kai he m'bom lah,
\q1 Ka pum neh ka coeng na boeih he ka voeih coeng,
\q1 vuel song lak ah bok na ham kai n'cim sak lah
\q1 
\v 4 Boei Jesuh lung hoeih la kan rhing he na ming,
\q1 Ha loh lam tah lung buei a thai han sai lah,
\q1 Tangnah neh cim nah thi sen te ka hmuh coeng
\q1 vuel song lak ah bok na ham kai cim sak lah.
\c 98
\s1 Kopoek Rhai Cil Laa Ka sa ni
\s2 I Will Sing The Wondrous Story
\sp Doh is Eb
\q1 
\v 1 Kopoek rhai cil laa ka sa ni,
\q1 kai ham khangkung duek nah cil,
\q1 A im then koek a caeh tak tih,
\q1 Kalvari thing lam dong duek.
\q2 \qt Kopoek rhai cil laa ka sa ni, \qt*
\q2 \qt Krih kai ham a duek nah laa, \qt*
\q2 \qt Hlang cim rhoek neh hmaih ka sa ni, \qt*
\q2 \qt vaan kho cil ah ka om te. \qt*
\q1 
\v 2 Ka hmata dae Jesuh loh n'rhuh,
\q1 tuu long hmang hlang kai he n'tlap,
\q1 A lung vat nah kut neh m'pom tih,
\q1 A long puei then ben la m'mawt.
\q1 
\v 3 Ka boeng ha Jesuh loh a toi,
\q1 ka tha hnoeng li ah kai n'thoh.
\q1 Ka mik hmuh kho loh yin khup tih,
\q1 Rhih om khui lam kah n'loeih sak.
\q1 
\v 4 Yin loh ka so ah n'thing khoep tih,
\q1 Kothae long puei ka pan vaeng,
\q1 Ka boeipa amah loh n'om puei,
\q1 Amah kut neh kai he m'mawt.
\c 99
\s1 Vaan ah Boei a Tloe Ka Khueh Pawh
\s2 Christ For Me
\sp Doh is D (moderato)
\q1 
\v 1 Vaan ah boei a tloe ka khueh pawh
\q1 nang mueh tah, Nang mueh tah,
\q1 Khrih khui kah ka sak ham laa tah
\q1 Khrih kai ham, Khrih kai ham.
\q1 Kai yueng la patang a khang tih,
\q1 a thisen neh kai khang la om coeng.
\q1 Pa then neh moei then nah han sai,
\q1 Khrih kai ham, Khrih kai ham.
\q1 
\v 2 Diklai khueh tawn khaw ka nai pawh,
\q1 Khrih kai ham, Khrih kai ham,
\q1 Diklai omthen khaw ka ngai pawh,
\q1 Khrih kai ham, Khrih kai ham.
\q1 Dik lai om ngaihnah rhai pai tah
\q1 rhaem ve tih kolkalh ah tlumtloi ni.
\q1 Om ngaih nah ka khueh coeng he tah,
\q1 Khrih kai ham, Khrih kai ham.
\q1 
\v 3 Khodaeng patang ka khang ca khaw,
\q1 Khrih kai ham, Khrih kai ham
\q1 Ka mawn tlaih pawh a mah loh m'ming,
\q1 Khrih kai ham, Khrih kai ham.
\q1 Ka lo tawn loh n'tang pawt mai tih,
\q1 ka thing kung loh thaisu pawt ca khaw,
\q1 Ka boei va loh mitmoeng ca khaw,
\q1 Khrih kai ham. Khrih kai ham.
\q1 
\v 4 Rham rhae a ka om mai ca khaw,
\q1 Khrih kai ham, Khrih kai ham
\q1 Tholh loh m'vael khoep bal mai ca khaw,
\q1 Khrih kai ham, Khrih kai ham.
\q1 Diklai loh caem la ha thoe tih,
\q1 rhal loh m'vael ka hing nah vael ca khaw,
\q1 Boeipa tha om neh ka ta ni,
\q1 Khrih kai ham, Khrih kai ham.
\q1 
\v 5 Ka hingnah loh a bawt a khaw,
\q1 Khrih kai ham, Khrih kai ham
\q1 A rhang dong ah ka sa sueng coeng,
\q1 Khrih kai ham, Khrih kai ham.
\q1 Tloh tat neh khodaeng ka ming tih,
\q1 ka thayung thamal a bawt vaeng ah,
\q1 Duek nah ah omngaih laa ka sak,
\q1 Khrih kai ham, Khrih kai ham.
\c 100
\s1 Jesuh Tah Kai Ham Soeprhaep
\s2 Jesus Is All The World To Me
\sp Doh is Ab
\q1 
\v 1 Jesuh tah kai ham ka soep rhaep,
\q1 Ka hing nah omngaihnah ,
\q1 Hnin takuem ah ka thaomnah,
\q1 te mueh a tah ka bung.
\q1 Ko thae vaengah a taeng ka puen,
\q1 hloep kung a tloe u khaw ompawh.
\q1 Ko thae vaeng ah omngaih sak kung paya then.
\q1 
\v 2 Jesuh tah kai ham ka soep rhaep,
\q1 Pa tang vaeng ah paya,
\q1 Yoethen bih ham a taeng ka cet,
\q1 vuen hlaem ah yoe then m'paek
\q1 Rho tui then neh kho sae then m'paek,
\q1 cang ah tue neh cang vuei khaw m'paek
\q1 rhotui kho sae a ka pae kung paya then.
\q1 
\v 3 Jesuh tah kai ham ka soep rhaep,
\q1 Pathen a tloe om pawh,
\q1 Amah pa ya then la om tih,
\q1 ka hnawt thai mah pawh.
\q1 A hnuk ka bang tue pai ka ti,
\q1 vuen hlaem ah kai he n'dawn yoeyah.
\q1 Vuen hlaem a hnuk bang ham koi ka paya then.
\q1 
\v 4 Jesuh tah kai ham ka soep rhaep,
\q1 paya tloe ka ngoe pawh,
\q1 Amah bueng ni ka uep na kung,
\q1 ka hing nah a bawt due
\q1 He bang pa ya then neh ka hing
\q1 hing then nah loh bawt thai tlaih pawh.
\q1 Dung yan hingnah neh om ngaihnah paya then.
\c 101
\s1 Jesuh Na Kawng Ka Thui
\s2 Jesus The Very Thought Of Thee
\sp Doh is A
\q1 
\v 1 Jesuh na kawng ka thui vaengah
\q1 ka lungbuei ah didip,
\q1 Na mik hmaithen ka hmuh vaengah,
\q1 ngaimong nah ta aep soep
\q1 
\v 2 Olkhueh nen khaw kan koeh lek pawh,
\q1 poeknah loh pha lek pawh,
\q1 Namah ming bueng ni then tangkik,
\q1 hlang tom boeih kah khangkung.
\q1 
\v 3 Ngaihmang hlang boeih ham ngaiuepnah,
\q1 kodo hlang omngaihnah ,
\q1 Hlang tholh boeih khaw nang loh na rhen,
\q1 Nang ming he then tangkik.
\q1 
\v 4 Mamih loh hmuh omngaihnah he,
\q1 ol ka neh phong lek pawh,
\q1 Jesuh lung na ka tlo koek he,
\q1 u longkhaw ming lek pawh.
\q1 
\v 5 Jesuh nang bueng ka omngaihnah ,
\q1 Kut doe khaw nan khueh sut,
\q1 Jesuh nang bueng ka boeilennah,
\q1 dungyandue la na om.
\c 102
\s1 Tudawn Loh A Yai La
\s2 Seeking To Save
\sp Doh is Ab
\q1 
\v 1 Tudawn loh a yai lah mol tom boeih a lan,
\q1 A hma tu mawt koep tih khue koep ham la.
\q2 \qt Khang hamla tlap khang hamla tlap \qt*
\q2 \qt Jesuh loh a ka hma te koep a tlap \qt*
\q2 \qt A ka hma te Jesuh loh \qt*
\q2 \qt khang hamla tlap khang hamla tlap. \qt*
\q1 
\v 2 A ka hma tang tae te thin sen la a tlap,
\q1 A kawn then a khueh te a tlap koep bal,
\q1 
\v 3 Capa te lung nah neh, a pa loh a tlap,
\q1 A duek tang tae hing koep ha phoe koep coeng,
\c 103
\s1 Ka Yan Cil Rhuem Ka Yaak Coeng
\s2 Victory In Jesus
\sp Doh is Ab
\q1 
\v 1 Ka yan cil rhuem ka yaak coeng
\q1 khang kung boeilen la ha lo nah.
\q1 Kal va ri ah a hing nah a voeih,
\q1 Hlang tholh khang hamla te,
\q1 A ko pang ol te ka yak,
\q1 Thi sen cim neh n'tlan nah ol ding
\q1 Te tah tholh nah ka yut tih
\q1 ta nah te tah ka hmuh coeng.
\q2 \qt Aw Jesuh rhang neh ta nah, \qt*
\q2 \qt dung yan khang kung boeipa , \qt*
\q2 \qt Kai n'tlap tih n'khuen phoei ah \qt*
\q2 \qt a thisen neh tlan coeng, \qt*
\q2 \qt A mah loh n'lung nah ka ming tih \qt*
\q2 \qt a mah ka lung na van, \qt*
\q2 \qt Tanah hmuen la kai n'caeh puei \qt*
\q2 \qt cim nah thi sen dong ah \qt*
\q1 
\v 2 Hoeih na ni ti la ka ming cim
\q1 caih sak kung la a om nah,
\q1 Kho khaem boeih long khaw
\q1 cet thai coeng tih,
\q1 Mik dael loh kho a hmuh,
\q1 Jesuh ha lo lam n'hoeih sak,
\q1 ti la thin ko boeih neh ka pang,
\q1 Jesuh kai ham ha lo tih
\q1 ta na te tah kai m'paek coeng.
\q1 
\v 3 Kai ham om nah a sai coeng
\q1 boeilennah im then koek mai te
\q1 Sui long puei dong ah cet u coeng tih,
\q1 lung vang om na hmuen ah,
\q1 Vaan dong hlang laa sak ol neh,
\q1 kai n'tlan na yan cil rhuem te tah,
\q1 te khohnin ah ka sak van ni
\q1 ta na laa then koek te.
\c 104
\s1 Boeipa Bi Tha Hlue Sak
\s2 Revive Thy Work, O Lord
\sp Doh is G
\q1 
\v 1 Boeipa bi tha n'hlue sak,
\q1 na hlang cim ha tueng saeh,
\q1 Hlang boeih taeng tha om nah ol thui,
\q1 na hlang rhoek loh ya saeh.
\q2 \qt Boeipa bi tha n'hlue sak, \qt*
\q2 \qt Na hmai ka kun vaengah \qt*
\q2 \qt Thin tloh Jesuh kaimih taengah \qt*
\q2 \qt yoe then na te m'pae lah n'hlue sak \qt*
\q1 
\v 2 Boeipa bi tha n'hlue sak,
\q1 na ming thang pom uh saeh,
\q1 Hlang boeih thin ko khui ah lung nah,
\q1 hmai bang la alh sak lah,
\q1 
\v 3 Boeipa bi tha n'hlue sak,
\q1 Na ol yoethen soep sak,
\q1 Namah ol cim dung koek te tah,
\q1 tangna neh yakming sak
\q1 
\v 4 Kai mih lungbuei khui ah,
\q1 tangnah te hing sak lah,
\q1 Jesuh Khrih nang khang kung bueng ni,
\q1 hoeihnah tui la na om.
\c 105
\s1 Omngaihnah Olthangthen Laa Sa Uh
\s2 Salvation
\sp Doh is C
\q1 
\v 1 Omngaih nah olthangthen laa sa uh,
\q1 khangnah tah soep coeng.
\q1 Jubili khohnin then dik lai
\q1 Pum tom ah hoe uh lah.
\q2 \qt Khangnah tah khang na tah \qt*
\q2 \qt Pa lung nah ha pai coeng. \qt*
\q2 \qt Khangnah tah khang nah tah \qt*
\q2 \qt Khrih rhang neh ha pai coeng. \qt*
\q1 
\v 2 Ko thae hlang rhoek omngaih boeih uh lah,
\q1 khang kung boei so ah
\q1 Thongtla boeih om ngaih
\q1 laa sa uh lah boeipa loh n'loeih sak.
\q1 
\v 3 Coinah tue kah laa sa uh bal lah,
\q1 Jesuh a duek nah
\q1 Dik lai hman ah rhoepnah
\q1 om pawn saeh, Pathen te koeh uh.
\c 106
\s1 Boei Jesuh Ming Te Lo Uh
\s2 Take The Name of Jesus With You
\sp Doh is Ab
\q1 
\v 1 Boei Jesuh ming te lo uh lah,
\q1 Kothae ngaihmang hlang rhoek aw,
\q1 omngaih ngaimongnah te m'paek ni,
\q1 Na caeh na kung ah khuen uh,
\q2 \qt Aw lung nah ming tlo koek \qt*
\q2 \qt diklai neh vaan omngaihnah \qt*
\q2 \qt Aw lung nah ming tlo koek \qt*
\q2 \qt diklai neh vaan omngaihnah . \qt*
\q1 
\v 2 Lakueng rhih om nah boeih noeng ham,
\q1 Jesuh ming khue yoeyah uh,
\q1 cuekhalh nah loh vael khoep vaengah,
\q1 A ming cim neh thangthui uh,
\q1 
\v 3 Jesuh ming dong ah kuep boeih uh,
\q1 vaan dong ah n'tun uh vaeng ah,
\q1 Boeilen sui lu muek te muek sak,
\q1 Yincaeh na loh bawt pawn ni.
\c 107
\s1 Hlang Tholh Boeih Boeih
\s2 Thou Hast Said Exalted Jesus
\sp Doh is F
\q1 
\v 1 Hlang tholh boeih boeih ka taeng lo uh,
\q1 Tlohtat patang khang hlang boeih.
\q1 Jesuh loh ng'khang ham oepsoeh om,
\q1 Lung vat rhen tha om nah soep
\q1 A mah long tah a sai thai boeih,
\q1 A moei hoeih nah uepvawt boeh.
\q1 
\v 2 Nang vawt thoek hlang rhoek ha lo uh,
\q1 Boeilennah cungkuem a khueh,
\q1 Tholhyut lamtah tangnah van laeh,
\q1 A rhennah soep na dang ni,
\q1 A phu kollaA phu kol la,
\q1 Jesuh taengah laiuh lah.
\q1 
\v 3 Uepvawt nah loh vuelvaek boel saeh,
\q1 Namah poeknah uep na boeh,
\q1 Amah na cueih na boeih a ngoe,
\q1 A ko ngaih na ming a tah,
\q1 A mah loh m'paek A mah loh m'paek,
\q1 Muei hla hamla kho sae then.
\q1 
\v 4 Hnorhih pa tang hlang ha lo uh,
\q1 A ka bung tangtae ha lo,
\q1 Patang lamkah na hoeih khang due,
\q1 Nang loh na lo thai tlaih pawh,
\q1 Hlang dueng hlang rhoek ham lam moenih,
\q1 Hlang tholh rhoek Jesuh loh n'khue.
\c 108
\s1 Jesuh Loh Tholh Hlahnah a saii
\s2 What A Wonderful Saviour
\sp Doh is D
\q1 
\v 1 Jesuh loh tholh hlah nah a sai
\q1 kopoekrhai khangkung boeipa.
\q1 mamih tah tlan tae hlang la n'om
\q1 Ko poek rhai khang kung boeipa
\q2 \qt Ko poek rhai khangkung \qt*
\q2 \qt ka Boeipa Jesuh Boei Jesuh \qt*
\q2 \qt Kopoekrhai khang kung boei\qt*
\q2 \qt tah ka Boei Jesuh ni \qt*
\q1 
\v 2 A thiisen neh n'silh tih ka koeh,
\q1 kopoekrhai khangkung boeipa
\q1 Pathen neh rhoep nah koep han sai
\q1 Ko poek rhai khang kung boeipa
\q1 
\v 3 Ka lungbuei tholh boeih a cim sak
\q1 kopoekrhai khangkung boeipa
\q1 Ta hae ah boei na neh a uk
\q1 Ko poek rhai khang kung boeipa
\q1 
\v 4 Ta na hamla tha om nah m'paek
\q1 kopoekrhai khangkung boeipa
\q1 A tue boeih ah ta na ha soep
\q1 Ko poek rhai khang kung boeipa
\c 109
\s1 Kopoekrhai Yancil Hnatun Uh Lah
\s2 What Did He Do
\sp Doh is D
\q1 
\v 1 Kopoek rhai yancil hna tun uh lah,
\q1 Hma ta uh li vaeng ah he
\q1 Boeilen nah ram lam ka loh ha rhum,
\q1 toeklekna khangnah phu tlo
\q2 \qt Duek khui lam kah u long nim n'khang \qt*
\q2 \qt Bang lae han sai me lam a om \qt*
\q2 \qt dung yan vaan dong ram then ah \qt*
\q1 
\v 2 Dik lai neh vaan hlang rhoek boeih lakah,
\q1 A ka len koek manghai boei
\q1 Thing lam dong ah a tai uh te tah,
\q1 Pathen capa khang kung ni.
\q1 
\v 3 Ta hae amah hmai ah kuep doe ah,
\q1 Khangkung hamla hoep uh lah
\q1 A ko ngaih te khaw na ming uh ni,
\q1 tahae nang te khang pawn ni.
\c 110
\s1 Akah Len Koek Siboei Ha Yoei
\s2 The Great Physician
\sp Doh is D
\q1 
\v 1 A ka len koek Si boei ha yoei,
\q1 Rhennah khueh kung Jesuh ni.
\q1 Kothae taeng omngaih ol a thui,
\q1 Jesuh ol hnatun uh lah.
\q2 \qt Vaan hlang boeih loh a koeh uh, \qt*
\q2 \qt A ming boeilen na a thui, \qt*
\q2 \qt Koehnah laa then a sak uh, \qt*
\q2 \qt Jesuh then koek Jes uh.\qt*
\q1 
\v 2 Na tholhnah boeih kho dawk a ngai,
\q1 Jesuh ol hna tun uh lah,
\q1 Na vaan long puei ngai mong la cet,
\q1 sui lu muek te muek sak uh.
\q1 
\v 3 A ka duek tuca thangthen sak,
\q1 Jesuh ta hae ka tangnah.
\q1 Khang kung a ming then ka lung nah,
\q1 Jesuh a ming ka lungnah.
\q1 
\v 4 A vaan hmuen then m'paek uh vaeng ah,
\q1 Jesuh neh n'tho koep hmaih ni.
\q1 A taeng ah laa then n'sak uh ni,
\q1 Jesuh ming thangthen nah laa.
\c 111
\s1 Aka Hma A Tlap
\s2 Seeking The Lost
\sp Doh is Ab
\q1 
\v 1 A ka hma a tlap ol ding neh a khue,
\q1 Mol tung tuk li ah pam dah rhoek,
\q1 Ka taengla ha lo a ol ding neh n'khue,
\q1 Boeipa loh ti hnin ah ol a thui.
\q2 \qt kho hla la cet mol som tlang som ah \qt*
\q2 \qt a ka poeng doe koep han lo puei han \qt*
\q2 \qt Tlan kung boei kah vong up kui a ke, \qt*
\q2 \qt Hlang thol yueng la Jesuh duek \qt*
\q2 \qt hlang tholh yueng Jesuh duek\qt*
\q1 
\v 2 A ka hma tlap lam Jesuh ke tueng lah,
\q1 Mueihla tha hnoeng neh ko bawt rhoek,
\q1 Khangnah long puei la amih te ham mawt,
\q1 dungyan hingnah long puei ke tueng lah.
\q1 
\v 3 Rhennah ol thangthen thui ham cet uh sih,
\q1 Hnin ta kuem Khrih hnukbang uh sih.
\q1 Tha thae hlang hloep lam a ka bung rhoek thoh,
\q1 A ka hma Jesuh kah longpuei tueng.
\c 112
\s1 Jesuh Ka Khangkung Bethlehem Kho
\s2 Seeking For Me
\sp Doh is G
\q1 
\v 1 Jesuh ka khangkung Bethlehem kho kah,
\q1 Ko thae yahrhaila kong duk dong ah thang;
\q1 Aw a ming kopoekrhaina long te tah,
\q1 kai tlap hamla halo.
\q1 Kai tlap hamla ha rhum.
\q1 Kai tlap hamla ha rhum
\q1 A ming tang lue koek a ka then koek te
\q1 kai tlap hamla ha rhum.
\q1 
\v 2 Jesuh ka khang kung thing lam dong a tai,
\q1 Ka lai ba boeih han sah tih n'loeih sak coeng,
\q1 A duek nah kopoek rhaina long te tah,
\q1 kai hamla a duek mai
\q1 kai hamla a ueh mai
\q1 Kai hamla a duek mai
\q1 A dueknah ko poekrhai na long te tah
\q1 kai hamla a duek mai.
\q1 
\v 3 Jesuh ka khang kung a mah rhawp pawn ni,
\q1 Ka pamdah na kung ah kai he koep n'tlap,
\q1 Kum sen hlang ko donah ka mueihla te,
\q1 a khue tih a om puei
\q1 a khue tih a om puei
\q1 a khue tih a om puei
\q1 Kum sen hlang ko do na neh ka mueihla
\q1 a khue tih a om puei
\q1 
\v 4 Jesuh tah diklai la koep ha rhum ni,
\q1 Amah ol khueh tah ha soep yoeyah ni,
\q1 Vaan lam kah ha rhum vaengah ka hmuh ni,
\q1 Kai hamla ha rhum ni
\q1 Kai hamla ha rhum ni,
\q1 kai hamla ha rhum ni
\q1 Vaan lam kah ha rhum vaengah ka hmuh ni
\q1 kai hamla ha rhum ni
\c 113
\s1 A tlannah te thui ham ka ngaih
\s2 Redeemed
\sp Doh is Ab
\q1 
\v 1 A tlannah te thui ham ka ngaih,
\q1 Tu ca thi sen neh tlannah kawng te,
\q1 Rhen nah neh tlan la ka om coeng
\q1 tih dung yan a ca la ka om coeng.
\q2 \qt N'tlan coeng n'tlang coeng\qt*
\q2 \qt tu ca thisen neh n'tlan uh coeng\qt*
\q2 \qt n'tlang coeng n'tlan coeng\qt*
\q2 \qt dungyan a ca la ka om coeng.\qt*
\q1 
\v 2 Tlan la ka om tih ka om ngaih,
\q1 Ka olka neh ka koeh thai lek pawh,
\q1 A hmai ah dung yan bawt mueh la
\q1 ka om pawn ni ti te ka ming coeng
\q1 
\v 3 Vuen hlaem khothun kho tlak a khaw
\q1 ka lung na ka tlang kung boei pa te,
\q1 Phah mueh la laa te ka sa ni,
\q1 a lung na te ka laa la om ni.
\q1 
\v 4 A muei then ka hmuh ni ka ming
\q1 ka boei pa ka ol paek tah ka ngaih,
\q1 Ka khokan a hoihaeng kung te,
\q1 Yin thuem koehnah laa then n'sak sak coeng.
\c 114
\s1 Lai Omthennah Ka Ko ah
\s2 I Love Him
\sp Doh is Eb
\q1 
\v 1 Lai om thennah ka ko ah om voel pawh
\q1 Jesuh thii loh la kueng nah a hma sak.
\q1 Thinglamtai loh ka lungbuei a mong sak,
\q1 Boei Jesuh thii loh vuel song bangla m'bok sak coeng.
\q2 \qt Amah ka lung na tang kik \qt*
\q2 \qt N'lung na lam hma tih, \qt*
\q2 \qt Kal va ri thinglam dong ah \qt*
\q2 \qt kai he tah n'tlan coeng \qt*
\q1 
\v 2 Tholh ko yin ram khui ah ka pam ka dah,
\q1 Thinko ngaihnah sal tam na la ka om.
\q1 Pathen neh hum hamla ka rhih tangkik,
\q1 Te dae Boei Jesuh thi sen loh kai tah n'tlan coeng.
\q1 
\v 3 Tholh loh kai n'pin bal ca khaw ka loeih coeng.
\q1 Ka mik dael lam kah kho koep ka hmuh coeng
\q1 Ka duek cakhaw Khrih dongah ka om coeng
\q1 Namtom hlang taengah thui hamla ngaimongnah m'paek.
\c 115
\s1 Jesuh Kah Cil Te Han Thui Lah
\s2 Tell Me The Story Of Jesus
\sp Doh is Eb
\q1 
\v 1 Jesuh kah cil te han thui lah, Yaak ham ka ngaih.
\q1 Amah te he ah a om atah, bih ka ngaih
\q1 Longtaeng lamkah loh tuitunli due
\q1 Jesuh ka cil boeihboeih te han thui.
\q1 
\v 2 A kho taengah ca moe ca pai, cil te han thui.
\q1 A yoe then nah kai m'paek na boeih te, ka poek ni.
\q1 Na lung vat nah neh sit loh nah ol
\q1 Jesuh kah mikhmai then kawng boeih te.
\q1 
\v 3 Camoe rhoek boeih loh na hnuk ah ka bang uh ni.
\q1 A sang samtoe ka hlaek doeah kut ka thueng ni
\q1 Hosanna boei Jesuh ka ti ni
\q1 Ho sa na Boei Jesuh ka ti ni ka ti ni.
\c 116
\s1 Boei Jesuh Ming Then Tanngkik
\s2 The Name Of Jesus
\sp Doh is C
\q1 
\v 1 Boei Jesuh ming then tang kik,
\q1 A ming thui koep ham ka ngaih.
\q1 Boei Jesuh ming boeilen na loh,
\q1 Ka ko a omngaih sak tang kik mai.
\q2 \qt Boei Jesuh ming then tangkik \qt*
\q2 \qt A ming thui koep ham ka ngaih. \qt*
\q2 \qt Boei Jesuh ming boeilennah loh, \qt*
\q2 \qt ka ko a omngaih sak. rhoe pai. \qt*
\q1 
\v 2 Boei Jesuh ming ka ngaih tang kik,
\q1 Ka kothae nah n'ueh puei,
\q1 ka omdam na boeih a hma sak tih,
\q1 Jesuh ming then ka ngaih tang tang
\q1 
\v 3 A ming then ming koep koep ka ngaih,
\q1 Ka lungbuei omngaih sak kung ni.
\q1 Mikphibonah a rhaem sak tih,
\q1 Jesuh ming koeh ham tueng pai.
\c 117
\s1 Rhennah Olthangthen Loh
\s2 The Gospel Of Thy Grace
\sp Doh is G
\q1 
\v 1 Rhennah olthangthen loh,
\q1 ka thin ko tholh a na,
\q1 Lai a lungna dongah,
\q1 Khuehduen Capa a paek.
\q2 \qt A u khaw aka tangnah tah, \qt*
\q2 \qt dungyan hingnah te a dang ni \qt*
\q2 \qt dungyan hingnah te a dang ni. \qt*
\q1 
\v 2 Rhohum rhul tai sawt neh,
\q1 hoeihnah a hmuh bangla,
\q1 Boei Jesuh ke dan uh,
\q1 dung yan hingnah hamla,
\q1 
\v 3 Tholh phu tah dueknah ni,
\q1 olrhi te na yaak coeng,
\q1 Na tang nah pawt koinih,
\q1 na po tangtang ni ta,
\q1 
\v 4 Lai hlang tholh kungsut ham
\q1 Jesuh ha lo moenih,
\q1 hlangtholh tlan hamla ni
\q1 a hingnah lu a voeih.
\q1 
\v 5 Uepvawtnah boeih voei lam
\q1 tangnah thinko te pae,
\q1 Olthangthen koek hmuh he
\q1 camoe bang la ngai tang.
\c 118
\s1 A Ya Ka Khangkung Thisen Long
\s2 Alas! And Did My Saviour Bleed
\sp Doh is Ab
\q1 
\v 1 A ya ka khang kung thi sen long,
\q1 Ka manghai boeipa duek
\q1 Koihvaih mueh kai hlangtholh koek ham
\q1 a lu ke a voeih mai ca
\q1 
\v 2 Kai kah kho sak ka tholh dongah,
\q1 thing lam dongah Patang
\q1 Titlukla kai lungvatnah he
\q1 ol neh ka thui thai lek pawh.
\q1 
\v 3 Dik lai hlang boeih tholh nah dong ah,
\q1 Jesuh long a duek puei,
\q1 A thinglam muei ka hmuh vaengah,
\q1 Ka mael hmai te ka buem sut.
\q1 
\v 4 A mikphi bo ka sah thai pawh,
\q1 a lungnah lai ba ke,
\q1 Ka pumrho he khum mai cakhaw,
\q1 a lungnah bawt thai tlaih pawh.
\c 119
\s1 Khangkung Boei A Lu Soah
\s2 Majestic Sweetness
\sp Doh is Ab
\q1 
\v 1 Khangkung boei a lu soah
\q1 a boei a mang nah te om,
\q1 A boeilen nah kho la ha sae,
\q1 A mah kah rhen nah thoeng
\q1 A ka ah rhennah thoeng.
\q1 
\v 2 A boeilennah te thuidoeknah
\q1 ham diklai ah om pawh.
\q1 Vaan om then na long pataeng khaw,
\q1 a van uh thai moenih
\q1 a van uh thai moenih.
\q1 
\v 3 Ka kothae na neh ka patangnah
\q1 boeih a hoeih na ham,
\q1 Kai hamla a ti dong mai ah,
\q1 yah rhai thinglam a koh
\q1 Yahrhai thinglam a koh.
\q1 
\v 4 Ka hingnah boeih neh ka hingnah
\q1 hil boeih paek ham ka ngaih,
\q1 Hlan khui lamkah n'khang coeng phoeiah,
\q1 Tanah te m'paek dong ah,
\q1 Tanah te m'paek dong ah
\q1 
\v 5 Pathen boeilennah a song
\q1 a sang kai loh ka hmuh tih
\q1 Ngai hmang ka ting rhi mai ca khaw,
\q1 Boeipa nang kan tangnah
\q1 Boeipa nang kan tang nah.
\c 120
\s1 Jesuh Thinglam Taeng Ka Yoei
\s2 Near The Cross
\sp Doh is F
\q1 
\v 1 Jesuh thing lam lam taeng ka yoei.
\q1 Tuiphuet then om nah ah
\q1 hlang boeih ham cimnah hamla
\q1 Kalvari tlang ah long
\q2 \qt Thinglam dong thinglam dong \qt*
\q2 \qt dungyan ka thangpomnah, \qt*
\q2 \qt Tui va rhal ah ka mueihla \qt*
\q2 \qt ngaimong la a duemnah \qt*
\q1 
\v 2 Thinglam kung ka pai hnin ah,
\q1 Lung vat rhennah ka hmuh,
\q1 Ai si thui pa vangnah loh,
\q1 Ka taeng a tue khungdaeng.
\q1 
\v 3 Pa then capa thinglam loh,
\q1 Ka hmai ah ha tueng saeh,
\q1 Hnin ta kuem ka caeh na ah,
\q1 Namah loh hlipdah lah.
\q1 
\v 4 Thinglam kung ah ka rhing oel
\q1 Ngai uepnah tangnah neh,
\q1 Tuiva rhal kah kho puei then,
\q1 Kai loh ka pha due la.
\c 121
\s1 Jesuh Thinglam Hmuiah
\s2 Beneath The Cross Of Jesus
\sp Doh is Eb
\q1 
\v 1 Jesuh thinglam hmuiah om ham ka ngaih
\q1 Lakueng ram ah ka om vaengah
\q1 lungnu hlip la ha om.
\q1 Rham rhae ah ka om vaeng ah,
\q1 hlip khup then la ha om bal.
\q1 Kho ling kho lai neh hno rhih
\q1 pa tang khaw om tlaih voel pawh.
\q1 
\v 2 Jesuh thinglam dongah ka hmuh te tah
\q1 Kai yueng pa tang a khang tih
\q1 a duek hlang te ni ka hmuh
\q1 Ka ngai a hmang tih
\q1 ka mikphi ha bo he ko poek rhai
\q1 Kai koihvaih mueh n'lung na he
\q1 ka kopoek la rhai tangkik.
\q1 
\v 3 Na thinglam hmui te
\q1 ka yingnah hmuen saeh
\q1 Vangnah a tloe boeih lakah
\q1 a vangnah he ka ngaih bet,
\q1 Hoeikhang sung daeh poek muehla
\q1 soeprhaep boeih khum mai ca khaw
\q1 Tholh he ya rhaipoh nah
\q1 thinglam ni ka boeilennah coeng
\c 122
\s1 Aw Yinnah Loh Ka Thinko
\s2 All the Way to Calvary
\sp Doh is A
\q1 
\v 1 Aw yinnah loh ka thinko he khoep a khuk,
\q1 ka patangnah khang kung loh a ming,
\q1 Yoethen nah m'paek vaeng ah ka lung buei kho sae.
\q1 khoyin khum tih ka hing nah ha soep.
\q2 \qt Kalva ri ben lam te kai yueng la cet phai, \qt*
\q2 \qt Kai yueng la cet kai yueng la cet \qt*
\q2 \qt Kai hamla tloh nat na a ueh \qt*
\q2 \qt kai yueng la Kal vari ben la cet. \qt*
\q1 
\v 2 Hlang tholh kai a hmai ah la kueng doe ka kuep,
\q1 Lung nah kho dawk ngainah ka ming pawh.
\q1 A olding ka thoeng loh khodawk han ngai coeng
\q1 tih laiba boeih khaw han sah bal coeng.
\q1 
\v 3 Khangkung lungnah tah ka kopoekrhai tangkik,
\q1 Ngol hmuen Kalvari la a caeh tak.
\q1 Tamdaengtamkha thaekhanah kai ham a ueh.
\q1 Yoeyah la a ming thangthen sak uh.
\c 123
\s1 Hingsuep Tlang Sang Te Om
\s2 There Is A Green Hill For Away
\sp Doh is E
\q1 
\v 1 Hing suep tlang sang te tah om
\q1 Kho puei kah a voel ah ke,
\q1 Kang kung Jesuh a ngawn nah
\q1 Kal va ri tlang dong ah ke.
\q2 \qt Lungnah kap amah lung na uh sih, \qt*
\q2 \qt a mah lungna sih. \qt*
\q2 \qt N'tlannah thi sen uepnah \qt*
\q2 \qt si lam a bi ke bi uh sih. \qt*
\q1 
\v 2 Pa tang a khang nah boeih boeih
\q1 te ol ka neh thui thai pawh,
\q1 Ma mih ham kho daeng a ming
\q1 te n'tang na u hamla om
\q1 
\v 3 Ma mih tholh ko dawk ngai ham
\q1 duek tih mamih n'hoei khang uh.
\q1 A bawt ah vaandong m'pha
\q1 na ham a thi cim neh n'tlan uh.
\q1 
\v 4 Tholh phu sah na ham la
\q1 hno tloe aka then he om pawh.
\q1 Amah bueng long ni vaan
\q1 thohka kunnah ham a ong thai.
\c 124
\s1 Imma Nu El Vae Khui Lamkah
\s2 There Is A Fountain
\sp Doh is C
\q1 
\v 1 I manu el vae khui lamkah
\q1 Thisen neh tui ha thoeng.
\q1 Te thisen ah ka buek hlang tah,
\q1 A tholhnah boeih cim coeng.
\q1 A tholhnah boeih cim coeng
\q1 A tholhnah boeih cim coeng
\q1 Te thisen ah a ka buek tah,
\q1 A tholh nah boeih cim coeng.
\q1 
\v 2 Thinglam kah a tai hlangtholh loh,
\q1 Te hingnah te a dang
\q1 A nih bangla n'tholh mai ca khaw,
\q1 Hlangtholh rhen ham a ngaih.
\q1 Hlangtholh rhen ham a ngaih
\q1 Hlang tholhrhen ham a ngaih.
\q1 Anih bangla tholh mai ca khaw
\q1 hlangtholh rhen ham a ngaih.
\q1 
\v 3 Tang nah neh te tui ka dan vaeng,
\q1 A lungnah loh kai n'tlan
\q1 Te thi sen tui koehnah laa te,
\q1 Ka duek due ka sa ni.
\q1 Ka duek due ka sa ni,
\q1 Ka duek due ka sa ni.
\q1 Te thisen tui koeh na laa te,
\q1 Ka duek due ka sa ni.
\q1 
\v 4 A thi long muei ka hmuh vaengah,
\q1 Tangnah thinko loh cak
\q1 Hingnah tui yoeyah ka long te,
\q1 Hlangtholh a cim na ni
\q1 Hlang tholh a cim na ni,
\q1 Hlangtholh a cim na ni,
\q1 Hingnah tui yoeyah ka long te,
\q1 Hlangtholh a cim na ni.
\c 125
\s1 Kopoekrhai Thinglam Ka Dan Vaeng
\s2 When I Survey The Wondrous Cross
\sp Doh is F (Eb.)
\q1 
\v 1 Kopoek rhai thing lam ka dan vaeng,
\q1 Boeilen capa dueknah ka hmuh,
\q1 Boe thae halangnah boeih te khaw,
\q1 Ta hae bangla ka poek voel pawh
\q1 
\v 2 Khrih Pathen a duek phoeiah tah,
\q1 Ka ka hoem damnah tloe ompawh,
\q1 soeprhaep ko ngaih ka khuehtawn boeih,
\q1 A dueknah dongah paek ka ngaih
\q1 
\v 3 A kut a kho a lu dan lah,
\q1 Ko thae la kueng na hmai ha long
\q1 Tap khoeh tap loeng la hum uh rhoi,
\q1 Hling lu muek neh a koih moenih.
\q1 
\v 4 Ka khuehtawn boeih ka pae cakhaw,
\q1 A rhennah neh tingtawk uh pawh,
\q1 A lungnah neh a rhennah ah,
\q1 Pum neh mueihla paek ham ka ngaih.
\c 126
\s1 Ka Hingnah Boeipa Thangthen
\s2 Lead Me, To Calvary
\sp Doh is Eb
\q1 
\v 1 Ka hingnah Boeipa kan thangthen,
\q1 Boeilennah nang ham saeh.
\q1 Na hling lu muek ka hnilh tholh ve
\q1 Kal va ri la m'mawt lah
\q2 \qt Ke sa ma ni poekkoepnah la, \qt*
\q2 \qt na thin phatnah poekkoepnah la \qt*
\q2 \qt Na ko ngaih ka poek koep na ham \qt*
\q2 \qt Kal va ri la m'mawt lah \qt*
\q1 
\v 2 Na yalhnah phuel khui te n'tueng lah,
\q1 Ko thae omdam na hmuen.
\q1 Vaan hlang loh baibok a bai tih,
\q1 na hlan hmuen te a tawt.
\q1 
\v 3 Khoyin khui kah Meri bang la,
\q1 Kut doe neh hmaih ka lo
\q1 A hong la hlan hmuen om m'hmuh sak,
\q1 Kalvari la mawt lah.
\q1 
\v 4 Thinglam hnin takuem koh ka ngaih,
\q1 thahluenah lungbuei neh,
\q1 Na boengloeng khaw kai bet n'ok sak,
\q1 kaiham na uehnah te.
\c 127
\s1 Diklai Tholhnah Boeih Cim Sak Kung
\s2 The Blood Of The Lamb
\sp Doh is D
\q1 
\v 1 Dik lai tholhnah boeih cim sak kung,
\q1 A thi cim koek tah tang lue saeh,
\q1 Pa-then ca pa tah boeilen saeh,
\q1 A uehnah loh mamih n'hoeih sak.
\q1 Tu hui lamkah loh ka pam tih
\q1 khodaeng pa tang ka ming vaengah khaw
\q1 Tu ca thi sen neh kai n'silh tih,
\q1 vuelsong lakah ka bok ngai coeng.
\q2 \qt Vuel song lak ah ka bok ngai ni \qt*
\q2 \qt Tu ca thisen ah kai sil lah \qt*
\q2 \qt vuel song lak ah ka bok ngai ni. \qt*
\q1 
\v 2 Pathen ca pa hling a muek tih,
\q1 Amah thing lam te a koh bal
\q1 Kho daeng pa tang a uehnah ke,
\q1 A yoe yap la a uem moe nih,
\q1 Ka tholh boeih a caih na ham la
\q1 tui va then la kai he n'caeh sak lah.
\q1 A thii long neh kai sil lah saw,
\q1 vuelsong lakah ka bok na ham
\q1 
\v 3 Na taeng lamkah ka pamdah tih,
\q1 Ka lungbuei khaw taengphael boeih coeng,
\q1 Ka tholh amhmol bangla thim tih,
\q1 Tui long khaw cim sak thai voel pawh
\q1 Jesuh nang kah tuibap then ah,
\q1 caeh ham lam ni tahae ah ka ngaih
\q1 Na tui cim neh kai n'sil lah saw,
\q1 veulsong lakah ka bok ngai ni.
\c 128
\s1 Hlang Tholh Rhoek Loh
\s2 It Is Finished!
\sp Doh is B
\q1 
\v 1 Hlang tholh rhoek loh ming uh pawh
\q1 rhennah ol thangthen te,
\q1 Jesuh loh yan ah ni
\q1 a sai boeih coeng dae ta,
\q2 \qt Te tah soep coeng boeih soep coeng, \qt*
\q2 \qt A yit ca koek due \qt*
\q2 \qt Hlang tholh rhoek loeihnah ham \qt*
\q2 \qt Jesuh kah a sai soep coeng. \qt*
\q1 Vaan ngol khoel dong lam kah
\q1 Jesuh rhum tih lai ah duek,
\q1 Soeprhaepboeih tah a coeng
\q1 coeng a pa ol hnatun,
\q1 Bi bi pa tang hnorhih hlang,
\q1 bang a lae na lakueng,
\q1 yan vaengah la nang ham la
\q1 a sai boeih coeng ta.
\q1 Jesu kah a sai dongah
\q1 tangnah neh yoei uh lah,
\q1 Dueknah hno saiinah loh
\q1 dueknah la a bawt sak.
\c 129
\s1 Kalvri Tlang Thing Lam Dongah
\s2 Calvary
\sp Doh is D
\q1 
\v 1 Kal va ri tlang thinglam dongah
\q1 Khangkung boeipa Ke ah a ngawn.
\q1 Kai ham lam ni a thi a long
\q1 Ke tlang dongah tholhnah ka loeih.
\q2 \qt Aw kal va ri pa tang nah tlang \qt*
\q2 \qt ke ah kai ham thi sen ha long \qt*
\q2 \qt Aw Kal va ri pa tang na tlang \qt*
\q2 \qt Khang kung duek na tlang la om \qt*
\q1 
\v 2 Lungnu puei can khomik loh hmuep
\q1 rhunkung boei lu a khun tih duek.
\q1 Bawkim himbai boeih ah pawn tih
\q1 hingnah long then tueng kung la om.
\q1 
\v 3 Aw Boei Jesuh he tluk lam a?
\q1 kai yueng ueh ham thinglam na koh.
\q1 Kalvari ah hingnah khum due,
\q1 kai hma na hing lu na voei mai
\c 130
\s1 Thinglam ah A Tai Hlang
\s2 There Is Life For Look
\sp Doh is G
\q1 
\v 1 Thinglam ah a tai hlang
\q1 ka so ham hingnah om,
\q1 Tahae rhoe ah hing nah te om coeng.
\q1 Aw hlang tholh loh solah,
\q1 nangmih ham hingnah om,
\q1 Thinglam dong a tai ke dan uh lah.
\q2 \qt Dan uh hingnah om \qt*
\q2 \qt thinglam ah a tai hlang \qt*
\q2 \qt ka so ham hingnah om \qt*
\q2 \qt ta hae rhoeah hingnah te om coeng \qt*
\q1 
\v 2 Badongah a tholh pawt
\q1 mai ah a tai uh mai,
\q1 Jesuh a tholhnah om pawt mai ah
\q1 Badongah a vae kah,
\q1 thisen cim a long sak
\q1 Na tholh laiba boeih a sah pawn a?
\q1 
\v 3 Tholhyut mik phi dawk neh
\q1 tholhnah a cim moenih,
\q1 A hawk thi sen bueng loh a cim sak,
\q1 A taeng ah na tholhnah,
\q1 a taeng a phong uh lah,
\q1 na tholh hnorhih yanghoep boeih pawnni.
\q1 
\v 4 Pathen olpaek soah
\q1 uepvawtnah khueh uh boeh,
\q1 Tue then om mahpawh tangnah van laeh
\q1 Dik lai tue loh bawt tih amah a tueng vaengah,
\q1 a bi bi na long khaw bawt pawn ni.
\c 131
\s1 Lungnah Then Koek Lungnah Cim
\s2 Love Divines All Love Excelling
\sp Doh is B
\q1 
\v 1 Lungnah then koek lungnah cim koek
\q1 vaan om ngaihnah lai la rhum.
\q1 Lunghoihnah neh kaimih taeng om,
\q1 uepomrhennah neh muek lah.
\q1 Jesuh nang hlang rhen kung koek ni,
\q1 lungnah cim boei koek lak om.
\q1 Khangnah neh kai mih taeng pong pa,
\q1 kai mih lung buei a kun lah.
\q1 
\v 2 Ngai hmang hlang rhoek thinko khui ah,
\q1 Na cim Muei hla han tueih lah,
\q1 Kai mih loh na rho panng ka ngaih,
\q1 Na ol kam nah hmuh sak lah.
\q1 Tha om boeipa ha lo lamtah,
\q1 na lungvatnah m'pang sak lah
\q1 A loe la koep ha mael lam tah,
\q1 a yoe ya la om puei lah.
\q1 
\v 3 Na sai hluen tahae ah na coeng,
\q1 cawtbah muehla cimcaih sak,
\q1 Khangnah soep koek kaika mih m'hmuh sak,
\q1 Dung yan na im ah om sak.
\q1 Kaimih yoethennah mpae lamtah,
\q1 vaan hlang bang la kan bawk eh.
\q1 Na taeng bawt mueh la ka thang thui,
\q1 lung na soep ah ka pomsang
\c 132
\s1 Jesuh Loh Thintlohnah Dongah
\s2 More Than Tongue Can Tell
\sp Doh is G
\q1 
\v 1 Jesuh loh thintlohna dongah,
\q1 Thing lam tai dong pa tang a khang,
\q1 Ka mueihla tlan la om na tah
\q1 Ol neh ka thui lek pawh.
\q2 \qt Boei Jesuh loh thintlohnah tah \qt*
\q2 \qt ka ol ka neh ka thui lek pawh. \qt*
\q2 \qt a lungnah neh rhennah yet ngai \qt*
\q2 \qt ol neh ka thui lek pawh. \qt*
\q1 
\v 2 Ka ko thae na boeih phueih ham la,
\q1 Hling lu muek te a muek sak uh,
\q1 Te dongah dung yan ka hing coeng
\q1 Ol neh ka thui lek pawh.
\q1 
\v 3 Ka ngai mong na ham Pathen loh,
\q1 A ca pa boei Jesuh te m'paek,
\q1 A thi sen neh tlannah te tah
\q1 Ol neh ka thui lek pawh.
\q1 
\v 4 Amah loh n'dawn tih ka om ngaih.
\q1 Rhihnah ah ka ngai a mong sak,
\q1 Ngai uep nah then koek m'paek te tah,
\q1 Ol neh ka thui lek pawh.
\c 133
\s1 Jesuh Thinglam ah Ka Pomsang
\s2 In The Cross Of Christ Of I Glory
\sp Doh is C
\q1 
\v 1 Jesuh thinglam ah ka pomsang,
\q1 rhai nah khui ah rhaltoengim,
\q1 A cim yan cil vangnah then tah,
\q1 Jesuh thing lam tai ke ni.
\q1 
\v 2 Ko thae la kueng loh m'pha vaengah,
\q1 Ngai uep na bawt rhih om dae,
\q1 Thinglam loh n'hnawt tlaih pawt dongah,
\q1 Om ngaih ngaimong koep ha phoe.
\q1 
\v 3 Om ngaihnah kho a sae vaengah,
\q1 lung nah neh long puei ha vang.
\q1 Thing lam dong kah mueisam then loh,
\q1 kho hnin a then ta aep sak.
\q1 
\v 4 Om ngaih kohoe neh tlohtat boeih,
\q1 Thinglamtung loh a cim sak.
\q1 Rhal thalnah loh ming thai lek pawh,
\q1 Om ngaihnah kumhalahsoep.
\c 134
\s1 Rhamsa Thii Nen Moenih
\s2 Not All The Blood Of Beasts
\sp Doh is C
\q1 
\v 1 Rhamsa thi nen moenih,
\q1 mueituk a bal moenih.
\q1 Cim nah neh ngaimong sak kung ompawh.
\q1 Tholh sil kung ompawh.
\q1 
\v 2 Pathen tuca Khrih thii,
\q1 tholh cim sak kung la om.
\q1 A thisen neh hmueih a phum coeng te
\q1 sa thii lak ah tlo.
\q1 
\v 3 A mah te ka tangnah
\q1 kai ham lu a voeih tih,
\q1 Ka tholh boeih te ka yut pawn vetih
\q1 tholh ka phong pawn ni.
\q1 
\v 4 Thinglamtai na dong ah
\q1 patang a khang tih duek,
\q1 Ka poek vaeng ah ka thin ko ah thip,
\q1 a lung nah ka poek.
\c 135
\s1 Dan Lah Tuiva A Dung A Ka
\s2 The Cleansing Fountain
\sp Doh is Ab
\q1 
\v 1 Dan lah tuiva a dung a ka
\q1 a hmai la yut yut long,
\q1 Khang kung vae khui a ka long te,
\q1 vuel song bang la bok nah
\q1 vuel song bang la bok nah.
\q2 \qt Ti hnin a ka long tuiva la lo uh, \qt*
\q2 \qt A ka lo boeih tah a tholh na \qt*
\q2 \qt boeih a cim caih sak pawn ni. \qt*
\q1 
\v 2 Kalvari thinglam dong ah
\q1 Jesuh loh kothae a ming
\q1 Kopoek rhai te tui va cim tah,
\q1 vuel song bang la bok nah,
\q1 vuel song bang la bok nah.
\q1 
\v 3 A pum boeih la tangnah uh sih
\q1 hoeihnah tuicim ha long,
\q1 Thisen phu tlo koek ka long ke,
\q1 vuel song bang la bok nah,
\q1 vuel song bang la bok nah,
\q1 
\v 4 Hnukkhueng koek ol thangthen long tah,
\q1 mamih boeih n'khue pawn ni,
\q1 A thisen tlo ko a ka tangnah,
\q1 vaan dong kho a pang ni,
\q1 Vaan dong kho a pang ni
\c 136
\s1 Boei Jesuh Thii Cim Koek Te
\s2 The Precious Blood
\sp Doh is Eb
\q1 
\v 1 Boei Jesuh thii cim koek te tah,
\q1 kai hamla a phu tlo,
\q1 Rhihnah neh tholhdalhnah khuiah,
\q1 ka mueihla tah loeih coeng.
\q2 \qt A kan khang kung pum khui lam kah, \qt*
\q2 \qt ko poek rhai thii ha long, \qt*
\q2 \qt vaan dong duela ka laa then tah, \qt*
\q2 \qt aw thi sen thi sen tlo. \qt*
\q1 
\v 2 Nangmih tholhnah boeih boeih te tah,
\q1 kho dawk kan ngai a ti,
\q1 Nangmih ham ni ka ca a duek,
\q1 Pathen ol loh a thui.
\q1 
\v 3 Ka tholhnah ka hnilhdam long he,
\q1 kai n'na tlaih voel mahpawh,
\q1 Thisen cim koek a long phoei ah,
\q1 ka tholhnah boei cim coeng.
\q1 
\v 4 Ka pum sa thahnoeng sut long he,
\q1 tlohtat ming mai cakhaw,
\q1 Ke thii khuiah ka buek atah,
\q1 ngaimong la ka duek ni.
\c 137
\s1 Tholh Hnorhih Khui Lamkah
\s2 There Is Power In The Blood
\sp Doh is Bb
\q1 
\v 1 Tholh hnorhih khui lamkah loeih na ngaih a?
\q1 A thii sen dongah, saithainah om.
\q1 Na mah poek ah tholhnah na na aya?
\q1 Ko poekrhai saithainah te om.
\q2 \qt Kopoek la rhai sai thainah te om, \qt*
\q2 \qt tu ca thii sen dong ah, \qt*
\q2 \qt Ko poekla rhai saithainah te om, \qt*
\q2 \qt tu ca thii sen cim dongah ke. \qt*
\q1 
\v 2 Oekhlawnnah khui lam kah na loeih a ya?
\q1 A thii sen dongah, sai thai nah om,
\q1 Kal va ri thii sen dong na hlu a ya?
\q1 Kopoek rhai saithainah te om
\q1 
\v 3 Vuelsong lak ah bok hamla na ngaih a?
\q1 A thii sen dongah, saithainah om,
\q1 Thii a ka long loh tholh a cim sak coeng,
\q1 Kopoekrhaisaithainah te om.
\q1 
\v 4 Boeipa Jesuh kah bi na bi a ya?
\q1 A thii sen dong ah, sai thainah om,
\q1 Hnin takuem thangthen laa na sa a ya?
\q1 Kopoekrhai sai thainah te om
\c 138
\s1 A Hla Hlang Tlang Dongah
\s2 The Old Rugged Cross
\sp Doh is Bb
\q1 
\v 1 A hla hlang tlang dong ah
\q1 thing lam tai tung te pai,
\q1 Khodaeng pa tang noek na ni.
\q1 Tedae kai hlang tholh ham
\q1 Ka boeipa a dueknah,
\q1 Thing lamtung te ka tuk mangkhak.
\q2 \qt Thinglamtai te tah ka uepnah koek \qt*
\q2 \qt ka hingnah khohni a bawt vaengah \qt*
\q2 \qt Thiglamtai te ka uepnah vetih \qt*
\q2 \qt sui lumuek then koek te ka lai ni \qt*
\q1 
\v 2 Thinglamtai tung longtah
\q1 diklai thaekha a ueh,
\q1 Tetah kai ham kopoekrhai.
\q1 Pathen kah tuca vaan
\q1 boeilen a caeh tak tih,
\q1 Kal va ri ah dueknah a ueh.
\q1 
\v 3 Thinglamtai kah a thii
\q1 cim a hluk na soah,
\q1 Ko poekrhai muei then ka hm uh.
\q1 Thinglam dongah Jesuh
\q1 kho daeng mingnah neh duek
\q1 Kai kah tholh boeih cim sak hamla.
\q1 
\v 4 Ke kah thinglamtai ke
\q1 dungyan la ka tangnah.
\q1 Kothae yahrhaipoh a phueih.
\q1 Vaan dongah im la
\q1 kai khue duela ka bang ni,
\q1 A boeilennah ah ka ngol ni.
\c 139
\s1 Solah Tholhnah Ka Caeh Puei
\s2 The Cleansing Blood
\sp Doh is Bb
\q1 
\v 1 So lah tholhnah ka caeh puei kung tuca,
\q1 Dueknah Kal va ri tlang dongah.
\q1 Thinglamtai thing tung, dongah a tai uh.
\q1 Kai hamla a thi tah ha long coeng.
\q2 \qt Aw ka khangkung boei vae khui kah \qt*
\q2 \qt thi sen neh tui tah ha thoeng coeng \qt*
\q2 \qt Ka ko khuiah om yoeyah saeh, \qt*
\q2 \qt hlang tholh cim nah tuiva. \qt*
\q1 
\v 2 A lung vatnah tui cim tah ha long coeng
\q1 ka khangkung dueknah hmuen lamkah
\q1 Te kah tui dongah yoe yah hlu uh lah,
\q1 Muei hla khangkung boeipa taengah te.
\q1 
\v 3 A thii long nah tui aka hlu boeih tah
\q1 a tholh vuel song bang la bok ni.
\q1 Na tholhna boeih boeih te han khuen lamtah,
\q1 Khangkung boei loh ha lo uh a ti.
\q1 
\v 4 Ka khangkung Boeipa Jesuh Khrih te tah,
\q1 Tholh ah ka pam tak voel mahpawh.
\q1 Na Cim Muei hla neh a yoeyah la m'mawt,
\q1 Na om ngaihnah muei te hmuh sak lah.
\c 140
\s1 Pathen Capa Caem Hmai La cet
\s2 The Son Of God Goes Forth To War
\sp Doh is Bb
\q1 
\v 1 Pathen ca pa caem hmai la cet,
\q1 Boei lu muek loh hamla,
\q1 Thi ah a nuem hnitai sawt tih,
\q1 u loh a vai thai eh.
\q1 U long a boengloeng a ok eh,
\q1 pa tang a noeng thai eh,
\q1 Thinsen lathing lam kawt hlang ni,
\q1 a hnukbang hlang la om.
\q1 
\v 2 Jesuh hamla lu voei kung loh,
\q1 dueknah rhal vangan ah,
\q1 Boeipa mik hmai then a hmuh tih,
\q1 khangnah hamla a bih.
\q1 Jesuh bangla kho dawkngai tih,
\q1 kho daeng pa tang a ming,
\q1 A ka ngawn rhoek hamla thang thui,
\q1 u long a vai thai eh.
\q1 
\v 3 A Cim Muei hla loh a tuek hlang,
\q1 Hlang si taeng  boeilen tueng,
\q1 Hlangcim hlai nit loh a ngaiuep,
\q1 rhihnah khueh uh tlaih pawh.
\q1 Rhan a hlaek tih sathueng no te
\q1 a mih loh a hnaep uh,
\q1 A mih ka kholaeh te thuih tih,
\q1 U nim ka cet thai eh.
\q1 
\v 4 Hlangcong caempuei, pa tong cadong,
\q1 boeinu neh nuham boeih,
\q1 Khangkung boei taengah vael uh tih,
\q1 him bai then a bai uh,
\q1 kho daeng pa tang rhainah lak kah,
\q1 vaan dong la luei uh hang,
\q1 Pa then na lungvatnah m'pae uh,
\q1 na hnuk bang thai na ham.
\c 141
\s1 Bowipa Kah Olthang Ka Khueh
\s2 Look And Live
\sp Doh is G
\q1 
\v 1 Boeipa kah olthang ka khueh Ha le luijah,
\q1 Te lungnah ol thangthen te tah,
\q1 A olka neh han thui coeng, Ha le lui jah
\q1 Te olthang te tangnah na hing ni.
\q2 \qt So lam tangnah ma nuca \qt*
\q2 \qt Jesuh tangnah na hing ni. \qt*
\q2 \qt Amah kah ol ka tang nah, \qt*
\q2 \qt Ha le luijah Na tangnah a tah \qt*
\q2 \qt dungyan hing ni. \qt*
\q1 
\v 2 Lungvatnah soep te ka ming Haleluijah,
\q1 Pueivan aw nang ham hingnah tah,
\q1 Vaan lamkah m'paek la om ta, Ha le lui jah
\q1 Jesuh ol ka hing te ka ming coeng.
\q1 
\v 3 Hingnah ta paek la om coeng Ha le lui jah,
\q1 Amah te na tangna atah,
\q1 Dungyan hingnah na khueh ni, Ha le lui jah
\q1 Amah bueng long ni nang te n'khang thai.
\c 142
\s1 Aka Hing Boeipa Ka Bawk
\s2 He Lives
\sp Doh is B
\q1 
\v 1 A ka hing boeipa ka bawk,
\q1 tihnin diklai ah hing.
\q1 Amah hing tite ka ming,
\q1 thui thet uh mai cakhaw.
\q1 A lungvatnah kut ka hmuh,
\q1 A ol ding te ka yaak.
\q1 Kai loh ka ngoengaih vaengah
\q1 Ka taeng ah ha om.
\q2 \qt Amah tah hing Tihnin Khrih Jessuh hing \qt*
\q2 \qt Ka hingnah long puei caek ah \qt*
\q2 \qt ka cet hmaih ol ka thui hmaih \qt*
\q2 \qt A mah tah hing khangnah paek ham \qt*
\q2 \qt ka ning nah te nan dawt koi nih \qt*
\q2 \qt ka lung buei khui ah hing. \qt*
\q1 
\v 2 Ka om nah ka taengvai ah
\q1 a lungvatnah ka hmuh,
\q1 Ka lung buei lakueng ca khaw,
\q1 ka ngai hmang tlaih mah pawh.
\q1 Hlipuei a thoh li vaeng ah
\q1 a mah loh kai n'caeh puei
\q1 A mah pumphoe na hnin te
\q1 Khaw ha thoeng pawn ni
\q1 
\v 3 Aw Khrih ca omngaih uh lah,
\q1 a sang ngai la koek uh,
\q1 Ha le lui jah Jesuh tah
\q1 ka boeipa manghai boei
\q1 A mah a tlap hlang boeih ham,
\q1 ngai uep na then la om.
\q1 A mah bang la hlang tloe
\q1 tah a ka then om pawh.
\c 143
\s1 Thohkoepnah Khohnin Te Then
\s2 The Day Of Resurrection
\sp Doh is D
\q1 
\v 1 Thohkoepnah khohnin te then,
\q1 Diklai loh paeng ah thui,
\q1 Sung lat omngaih khohnin ni,
\q1 Pathen kah khohnin then
\q1 Dueknah lamkaloh hingnah,
\q1 Diklai lamkah vaan ah
\q1 Mamih kah Khrih loh tanah
\q1 laa then neh han khuen coeng.
\q1 
\v 2 Ma mih thin ko cim sak sih,
\q1 phung dueng then hmuh na ham,
\q1 A thoh koep nah kho saeng he,
\q1 dung yan vang na then ni.
\q1 A luei nah ol te yaak ham
\q1 A then la hnatun uh
\q1 A tanah te hlang boeih boeih loh
\q1 thangpomuh van saeh.
\q1 
\v 3 Vaan ah omngaihnah bae saeh,
\q1 Diklai loh laa sa saeh.
\q1 Diklai so boeih a he khaw,
\q1 Tanah laa neh bae saeh.
\q1 Hmuh neh hmuh mueh boeih long khaw,
\q1 omngaihnah khueh uh saeh.
\q1 Khrih boeipa tho coeng tih
\q1 omngaihnah bawt tlaih mahpawh.
\c 144
\s1 Tihnin ah Jesuh Thoo Coeng
\s2 Christ The Lord Risen Today
\sp Doh is D
\q1 
\v 1 Tihnin ah Jesuh thoo coeng, Haleluiah
\q1 Omngaihnah hnin omngaih uh, Haleluiah
\q1 Hlang boeih neh vanhlang loh saa, Haleluiah.
\q1 Ma mihtholhnah han cim sak, Haleluiah.
\q1 
\v 2 Vaan dong kho kah manghaiboei, Haleluiah
\q1 Aw dueknah sue melam nim, Haleluiah
\q1 Dueknah loh noeng thai voelpawh, Haleluiah.
\q1 Vaan dong thohka a ong coeng, Haleluiah.
\q1 
\v 3 Mamih manghai boei thoo coeng, Haleluiah
\q1 Thangthennah laa sa uh sih, Haleluiah.
\q1 A duek na neh mamih n'tlan, Haleluiah
\q1 Tanahpaek hamla ha lo, Haleluiah.
\q1 
\v 4 Tloeng khoelh Pathen koeh uh sih, Haleluiah
\q1 Dung yan lung nah thangthen uh, Haleluiah
\q1 Vaan hlang ping long khaw koeh uh, Haleluiah
\q1 Pa Capa A Cim Muei hla, Haleluiah
\c 145
\s1 Phuel Khuiah Ni A Om
\s2 Christ Arose!
\sp Doh is C
\q1 
\v 1 Phuel khui ah ni a om, Jesuh ka boeipa
\q1 Na thohkoephnin na rhing Jesuh boeipa
\q2 \qt Phuel khui lam kah Jesuh thoo\qt*
\q2 \qt Boeilennah neh rhal boeih a ta coeng\qt*
\q2 \qt Saelkhui dueknah na kung boeipa tah tho coeng\qt*
\q2 \qt Hlangcim rhoek neh dung yan om hamla ha thoo,\qt*
\q2 \qt tho koep coeng tho koep coeng\qt*
\q2 \qt ha leluijah tho koep coeng \qt*
\q1 
\v 2 A hoei la phuel a tawt, Jesuh ka boeipa
\q1 Phuel khaw a muek uh tloel Jesuh boeipa.
\q1 
\v 3 Duek nah loh na thaipawh, Jesuh ka boeipa
\q1 Dueknah vong a phae coeng Jesuh boeipa
\c 146
\s1 Ka Tlan Kung Boei Hing Koep Ti Ka Ming
\s2 I Know That My Redeemer Liveth
\sp Doh is D
\q1 
\v 1 Ka tlan kung boei hing koep ti ka ming
\q1 he lai hman ah ha rhum koep ni
\q1 dungyan hingnah paek ti la ka ming
\q1 a lungvatnah a kut ah om.
\q2 \qt Boei Jesuh thoo koep coeng ti la ka ming\qt*
\q2 \qt Diklai hman ah ha lo koep ni,\qt*
\q2 \qt Hingnah boei la om,\qt*
\q2 \qt Ka ming rhennah neh \qt*
\q2 \qt Saithai nah te a kut ah om.\qt*
\q1 
\v 2 A olkhueh hlo tlaih pawh ti ka ming
\q1 a ol thui tah pal tham thai pawh,
\q1 Duek nah loh ka pum ta mai ca khaw
\q1 a voel ah a muei ka hmuh ni,
\q1 
\v 3 Ka om na im a tlaih te ka ming
\q1 a om na ah ka om van ni,
\q1 Ka kopoek la rhai tang kik hlang
\q1 kai n'ngaih thuen na neh dawn dah na he
\c 147
\s1 Dueknah Ta Kung Boei
\s2 Thine Is The Glory
\sp Doh is E
\q1 
\v 1 Dueknah ta kung boei ta kung tho koep coeng.
\q1 Boeilen nah nang ka ni dueknah na ta tih.
\q1 Vaan hlang bok rhoek loh hlan lung te a thoeih uh.
\q1 Na rhok yol nah hni te a then la a khoem
\q2 \qt Duek nah ta kung boei a ka tho koep boei\qt*
\q2 \qt Boeilen nah nang ka ni duek nah na ta tih\qt*
\q1 
\v 2 So lah thoo koep coeng Jesuh tah boeipa
\q1 Lung nah neh a pom uh rhih nah om voel pawh.
\q1 A hlang tuek rhoek loh ta nah laa te sa uh.
\q1 Boeipa hing koep coeng tih ta nah laa sa saeh
\q1 
\v 3 Dungyan hingnah boei kan tangnah uh coeng
\q1 Nang mueh atah hingnah a hoei mai pawn ni.
\q1 Ta kung tha om la kaimih he n'om sak uh.
\q1 Sa ding ca la m'mawt uh na im pha puei uh.
\c 148
\s1 Paya Then Jesuh Ka Khueh
\s2 The Lily of the Valley
\sp Doh is F
\q1 
\v 1 Pa ya then Jesuh ka khueh
\q1 ka soep rhaep boeih la om,
\q1 Ka mueihla ham a then nah ka thui lek pawh,
\q1 Van li kah Li ly pai then a mah dong ah ka hmuh,
\q1 A mah ah ka cim na neh ka hoeih na om
\q1 Ko thae vaeng ah ngai mong nah
\q1 ngai hmang vaeng ah kuepkol nah
\q1 Lung vat na neh a ka dawn dah kung,
\q2 \qt Van li pai then tlumtloih tloel te ai si thui pa la om\qt*
\q2 \qt Ka mueihla ham a thennah ka thui lek pawh. \qt*
\q2 \qt Kothae vaengah ngaimongnah ngaihmang vaengah \qt*
\q2 \qt kuep kol nah lungvatnah neh a ka dawndah kung \qt*
\q2 \qt Vaan li pai then tlumtloih tloel te ai si thuipa la om \qt*
\q2 \qt Ka mueihla ham a thennah ka thui lek pawh. \qt*
\q1 
\v 2 Ka ko thae a khuen boeih tih,
\q1 thahlue na te m'paek coeng,
\q1 cuek halhna ka tong vaeng
\q1 ah ka loeih na kung
\q1 Soeprhaep boeih te ka paek coeng
\q1 ngai hmang na boeih te khaw,
\q1 A mah loh kai n'khue tih a taeng ah n'om sak.
\q1 Dik lai loh n'hnawt mai ca khaw
\q1 cuek halh na ha lo cakhaw
\q1 Jesuh rhang neh ka maengtaeng ka pha.
\q1 
\v 3 A mah loh n'caeh tak tlaih pawh,
\q1 n'hnawt khaw n'hnawt tlaih bal pawh
\q1 Tangnah rhang neh ka om hmaih a ngaih
\q1 ka sai Kai ham vong tung la om tih
\q1 rhih nah ka khueh tlaih pawh.
\q1 Mana neh ka buhpong han dip sak coeng tih,
\q1 A boeilen neh m'muek dah
\q1 vaeng ah a mik hmai ka hmuh ni
\q1 Omngaih na tuivaeng kaeng ka pha ni.
\c 149
\s1 Boei Jesuh Ming Thang
\s2 All Hail the Power of Jesus’ Name
\sp Doh is F
\q1 
\v 1 Boei Jesuh ming thangthen sak uh.
\q1 Vaan hlang long khaw koeh saeh.
\q1 vaanhlang long khaw koeh saeh.
\q1 Boeilen hinyahnah te pae uh.
\q1 Boei lu Boei lu te muek sak uh lah
\q1 Boei boeih lak ah boei koek.
\q1 
\v 2 A tuek hlang rhoek Isa rel rhoek
\q1 Tholh khui lam kah n'tlan coeng
\q1 Tholh khui lam kah n'tlan coeng.
\q1 A lung vat nah neh tlang kung boei
\q1 Boei lu Boei lu te muek sak uh lah
\q1 Boei boeih lak ah boei koek.
\q1 
\v 3 Hlang com hlang ci hlang phung boeih loh,
\q1 Vaan hmui kah boeih long khaw
\q1 Vaan hmui kah boeih long khaw.
\q1 A boei a len nah tueng sak uh.
\q1 Boei lu Boei lu te muek sak uh lah
\q1 Boei boeih lak ah boei koek.
\q1 
\v 4 A boei ngolkhoel cim koek hmai ah
\q1 kho cung kueng boeih uh sih
\q1 kho cungkueng boeih uh sih
\q1 Dungyan laa then koek te sa sih
\q1 Boei lu Boei lu te muek sak uh lah
\q1 Boei boeih lak ah boei koek.
\c 150
\s1 Yincaehnah Ram Diklai Ah He
\s2 Memories Of Galilee
\sp Doh is Bb
\q1 
\v 1 Yincaehnah ram diklai ah he
\q1 dungyan khopuei ka pha vaengah
\q1 hnuk la mael tih ha bal laeh saw
\q1 tila diklai loh kai he khue khing
\q2 \qt (Tloih mueh pai then) Khrih te ka hlaek coeng \qt*
\q2 \qt lungvatnah neh kai he n'hloem bael \qt*
\q2 \qt ka om ngai hlang laa ka sa ni \qt*
\q2 \qt a hnuk la ka bal voel mah pawh. \qt*
\q1 
\v 2 Lai khosak nah ka dan vaengah
\q1 lai omthennah loh n'yoek khing tih
\q1 ti dae lung vat kung Khrih he tah
\q1 dungyan tloih mueh pai ka hlaek coeng.
\q1 
\v 3 Ka tholhnah boeih boeih te a silh
\q1 him bai thai te kai m'bai sak tih
\q1 rhih rhoe rhoe boeh ti ol ka yaak,
\q1 A hnuk la ka koep voel tlaih mah pawh.
\q1 
\v 4 Tholh mikphi tui loh rhaem hal tih
\q1 Jerusalem thai te ka dan
\q1 Ka omngaihnah Khrih hnuk bang doe
\q1 a mong ca la ka cet van pawn ni.
\c 151
\s1 Hnatun Lah Dungyan Laa
\s2 The Lord Is King
\sp Doh is G
\q1 
\v 1 Hnatun lah dungyan laa then,
\q1 vaan lamkah ha thoeng
\q1 Sosang koek ah Pathen boeilen nah ngai saeh.
\q1 Hlang cim rhoek neh vaanhlang loh
\q1 laa then sak neh a koeh boeih uh
\q1 Phungding tum neh Boeipa tah manghai boeini.
\q1 
\v 2 Hnatun lah taa nah laa ol,
\q1 diklai boeih a khuu,
\q1 Tui tun tui phu thoh bangla omngaih ol loh
\q1 Ha le luiah boeipa tah
\q1 ram tom boeih ah thangthen sak uh.
\q1 Ol khueh boeih neh Boeipa tah manghai boei ni.
\q1 
\v 3 Nangmih vaan hlangping rhoek aw,
\q1 thumsoep khat koeh uh,
\q1 Pa Pathen te koeh Capa neh Cim Muei hla
\q1 Kho suen ah na om bang la
\q1 dung yan la nang tah na cak tih
\q1 Tlan tae ca loh Boeipa tah manghai boei ni.
\c 152
\s1 Aw Vaan Hlang Thawngsang Laa
\s2 Oh, For A Thousand Tongues To Sing
\sp Doh is G
\q1 
\v 1 Aw vaan hlang thawngsang laa a sak.
\q1 Khangkung boei thangthen nah
\q1 khangkung boei thangthen nah.
\q1 Jeho Pathen Boeipa khangkung
\q1 A lungnah koeh uh sih.
\q1 A lungnah koeh uh sih,
\q1 A lung nah koeh uh sih.
\q1 
\v 2 Aw mamih mawt kung manghai boei
\q1 Tha om na te m'pae lah,
\q1 Saithai nah te m'pae lah,
\q1 Diklai dong hlang tom boeih taeng ah
\q1 Na olthangthen pung saeh
\q1 Na olthangthen pung saeh,
\q1 Na olthangthen pung saeh.
\q1 
\v 3 Boeipa Jesuh na ming cim nah,
\q1 Kothaenah dip sak kung
\q1 Ko thaenah dip sak kung,
\q1 Hlang tholh ham khaw phung dueng ol ni.
\q1 Ngai mong sak kung la om
\q1 Ngai mong sak kung la om
\q1 Ngai mong sak kung la om.
\q1 
\v 4 Tholh thaomnah aka noeng kung,
\q1 Hlang tholh boeih na khang tih,
\q1 Hlang tholh boeih na khang tih,
\q1 Thi sen tlo loh tholh a cim sak.
\q1 Kaimih boeih ham loeih nah
\q1 Kai mih boeih ham loeihnah
\q1 Kai mih boeih ham loeih nah.
\c 153
\s1 Sak Ham Ka Ngaih Laa Then
\s2 Since I Have Been Redeemed
\sp Doh is G
\q1 
\v 1 Sak ham ka ngaih laa then ka khueh,
\q1 A mah loh n'tlan dong ah,
\q1 Khang kung tlan kung ka manghai boei,
\q1 A mah loh n'tlan dong ah.
\q2 \qt Amah loh n'tlan dong ah\qt*
\q2 \qt A mah loh n'tlan dong ah,\qt*
\q2 \qt A ming then neh ka omngaih\qt*
\q2 \qt Amah loh n'tlan dong ah\qt*
\q2 \qt Khang boei ming rhang neh ming then ka dang\qt*
\q1 
\v 2 Ngai khuek nah pae kung Pathen om,
\q1 Amah loh n'tlan dong ah,
\q1 A mah kah bi ka kut doe then,
\q1 Amah loh n'tlan dong ah.
\q1 
\v 3 A cim la ming kung laipai om,
\q1 Amah loh n'tlan dong ah,
\q1 Uepvawtnah neh rhihnah boeih hma,
\q1 Amah loh n'tlan dong ah.
\q1 
\v 4 Kai ham sai tangtae im then om,
\q1 Amah loh n'tlan dong ah,
\q1 Dung yan ka omnah ham im then,
\q1 Amah loh n'tlan dong ah.
\c 154
\s1 Jesuh Thinko Tang Neh
\s2 Jesus Loved Of Heard
\sp Doh is C
\q1 
\v 1 Jesuh thinko tang neh kan ngaih.
\q1 Na thintlohnah kai hamla ni,
\q1 Na kongaihnah te han soep sak.
\q1 Nang kan lungna taaep hamla.
\q2 \qt Poek nah lung then neh han soep sak\qt*
\q2 \qt Khocil sui kho puei te hmuh sak\qt*
\q2 \qt Ka ko khui he kho han thaih sak\qt*
\q2 \qt na omnah tah kai ham vaan ni. \qt*
\q1 
\v 2 Diklai omngaih bawn nah he khaw,
\q1 Na kongaih hlipdah kung mai ni,
\q1 Thahlue la vaan ben ke ka dan,
\q1 Namah muei te ka hmuh ngai ni.
\q1 
\v 3 Omngaih na tloe yet mai cakhaw,
\q1 Rhaipai then hlang yet mai ca khaw,
\q1 Ka mueihla omngaihnah ham tah
\q1 na rhen nah bang lam tah om pawh.
\q1 
\v 4 Namah mueh tah khocil then neh,
\q1 Khosae then kai hamla om pawh.
\q1 Nang loh lai ngai hmang na dip sak
\q1 Vaan om ngaihnah neh na bae sak.
\c 155
\s1 Laitha Phu Tlo Koek
\s2 The Pearl Of Greatest Price
\sp Doh is G
\q1 
\v 1 Lai tha phu tlo koek te ka hmuh,
\q1 omngaih laa ka sa ni,
\q1 Jesuh Khrih tah kai ka pawn ni
\q1 omngaih laa ka sa ni.
\q2 \qt Laitha phu tlo koek ka hmuh coeng,\qt*
\q2 \qt omngaih laa ka sa ni.\qt*
\q2 \qt Jesuh khrih tah kai ka pawn ni\qt*
\q2 \qt omngaih laa ka sa ni.\qt*
\q1 
\v 2 Kho soih puei koek te tah Khrih ni,
\q1 vangnah tong hma la om
\q1 Ka vaan boei koek khosoih puei tah
\q1 a ngol khoel dongah ngol.
\q1 
\v 3 Boei boeih lakah Boei koek la om,
\q1 manghai boei la om bal
\q1 Kho mik capa duengnah boeipa
\q1 a phae dong hoeihnah om
\q1 
\v 4 Jesuh khrih tah ka soeprhaep ni,
\q1 ngaimongnah neh lungnah,
\q1 Ka hingnah ah ka tla cakhaw
\q1 amah loh koep m'pom sang
\c 156
\s1 Sui Neh Tangka Nen Moenih
\s2 Nor Silver Nor Gold
\sp Doh is D
\q1 
\v 1 Sui neh tangka nen moenih kai tholh tlansum tah,
\q1 Lai koeva loh ka mueihla tah khang thai pawh.
\q1 Thing lam dongkah thii bueng ka yung caknah lungnu,
\q1 Khang boei dueknah dongah ta hae ka mong coeng.
\q2 \qt Kai tlan nah tah tangka nen moe nih,\qt*
\q2 \qt Kai lai nah tah sui moe nih,\qt*
\q2 \qt Thinglam dong kah Jesuh thii bueng ni\qt*
\q2 \qt Thui lek pawh lung nah phu tlo. \qt*
\q1 
\v 2 Sui neh tangka nen moenih kai tholh tlansum tah,
\q1 Ka lungbuei tholh na tah taaep ha rhih coeng,
\q1 Thinglam dong kah thii bueng ka yung caknah lung nu,
\q1 Khang boei dueknah long bueng ni tholh phu a sah.
\q1 
\v 3 Sui neh tangka nen moenih kai tholh tlansum tah,
\q1 Ol rhi ol vai nah long khaw kai n'khang thai pawh,
\q1 Thinglam dong kah thii bueng ka yung cak nah lungnu,
\q1 Khang boei dueknah loh ka rhihyawp nah a voeih.
\q1 
\v 4 Sui neh tangka nen moenih kai tholh tlansum tah,
\q1 Te bang neh vaandong caeh thai na la om pawh,
\q1 Thinglam dong kah thii bueng ka yung cak nah lungnu,
\q1 Khang boei dueknah rhangneh tholh hlah nah ka hm uh.
\c 157
\s1 Sui Lumuek Muep Muek Sak
\s2 Crown Him With Many Crowns
\sp Doh is E
\q1 
\v 1 Suilumuek muep muek sak vaan ngolhmuen kah tu ca.
\q1 Vaan hlangping laa sak ol neh a koeh te hna tun uh lah.
\q1 Ka mueihla tho lam koeh nang ham aka duek te,
\q1 Nang kah dungyan manghai boei te thang pomnah laa sa lah.
\q1 
\v 2 Sui lumuek muep muek sak lung nah na boeipa te,
\q1 A kut a kho a vae thun hma boeilennah la om coeng.
\q1 Me bang van hlang long khaw amah a sawt ha pawh.
\q1 Ma mih n'khang na te tah ko poek lam ni a rhai ta aep.
\q1 
\v 3 Sui lu mek muep muek sak, Hing nah boei duek a ta,
\q1 Ta nah neh thohkoep tih khangkung boei la a ka lo te,
\q1 Duek nah lam loh a thoh te ma mih loh n'koeh uh,
\q1 Duek nah loh dungyan hingnah a ka khuen kung te n'koeh uh.
\q1 
\v 4 Sui lu muek muep muek sak kum tue ukkung boeipa.
\q1 Vaan neh lai a sak kung soep rhaep boeih kah boeipa Pathen
\q1 Kai mih ham ka duek khang kung boei kan thangthen uh.
\q1 Nang kan thangthennah tah dung yan duela bawt thai mah pawh.
\c 158
\s1 Ka Ko Khuiah Laa Then
\sp Doh is Ab
\q1 
\v 1 Ka ko khuiah laa then tang kik tah,
\q1 Jesuh loh dik dik a sak.
\q1 Rhih boeh nang mih taeng ah kai ka om,
\q1 ngai mong la om uh a ti.
\q2 \qt Jesuh Jesuh Jesuh \qt*
\q2 \qt na ming then ka ming\qt*
\q2 \qt ka kongaih a soep sak \qt*
\q2 \qt caeh doe ah laa n'sak sak bal.\qt*
\q1 
\v 2 Ka hingnah he tholh loh a po sak,
\q1 ka lungbuei ah li lol sut.
\q1 Bawt pat rhui Jesuh loh a toom tih,
\q1 ka lung buei ah rhoinaeng koep.
\q1 
\v 3 A rhennah dongah ka boei coeng tih,
\q1 a phae hlip ka ka ku van.
\q1 A mik hmai hlampan ka dan vetih,
\q1 omngaihnah laa ka sak ni.
\q1 
\v 4 A lakah tuidung na ah m'mawt tih,
\q1 patang na a khaw n'caeh puei.
\q1 A lak ah rhainah a khaw n'caeh puei,
\q1 dae a kho lah te ka hm uh.
\q1 
\v 5 A di hlan ah koep ha lo pawn ni.
\q1 Vaan kho cil voel lam kah loh.
\q1 Kai khaw ming pawt ram la ka cet ni
\q1 Vaan ah ka om hmaih pawn ni.
\c 159
\s1 Boeipa Tah Kai aka Dawnkung
\sp Doh is Bb
\q1 
\v 1 Boeipa tah kai a dawn dah kung,
\q1 Ka vawt ka thoek mahpawh
\q1 Rhamtlim saihing nah hmuen then neh,
\q1 tuikaeng then la kai m'mawt
\q1 Rhamtlim sai hingnah hmuen then neh
\q1 tuikaeng then la kai m'mawt.
\q1 
\v 2 Amah loh ka mueihla a thoh,
\q1 tih koep ah a caeh sak.
\q1 A long puei then na a te m'mawt
\q1 , A ming cim thangthen ham.
\q1 A long puei then nah ah te mawt
\q1 coeng a ming thangthen ham.
\q1 
\v 3 Kai hamla ka rhal rhoek hmai ah,
\q1 Buh te hmaih nan vael sak.
\q1 Ka lu ah si tui neh nan suep,
\q1 ka boeng loeng bae coih pawk.
\q1 Ka lu ah si tui neh nan suep,
\q1 ka boeng loeng bae coih pawk. pawk.
\q1 
\v 4 Ka hing khui na rhen na loh soep,
\q1 Ka taengla nawt nawt long.
\q1 A pa im ah ka om pawn ni,
\q1 Ka om na ham im ah.
\q1 A pa im ah ka om pawn ni,
\q1 Ka om na ham im ah.
\q1 
\v 5 Dueknah long hoi ah cet ca khaw,
\q1 rhihnah ka khueh tlaih pawh.
\q1 Na cong hol nen te nan mawt tih,
\q1 Na caitueng neh nan hloep.
\q1 Na conghol nen te nan mawt tih,
\q1 Na cai tueng neh nan hloep.
\c 160
\s1 Then Koek Jesuh
\s2 Fairest Lord Jesus
\sp Doh is F
\q1 
\v 1 Then koek Boei Jesuh,
\q1 Soeprhaep boeih uk kung.
\q1 Pathen neh hlanghing capa,
\q1 Nang ah ka om ngaih.
\q1 Nang kah hinyah nah,
\q1 Nang ka boeilennah lumuek ni.
\q1 
\v 2 Thing sai boeih sai hnim,
\q1 Dup puei loh sawt then.
\q1 Kho niing rhaipai lum vaengah,
\q1 Jesuh tah then ngai.
\q1 Jesuh cim caih ngai,
\q1 Kothae hlang rhoek ko a hoe sak
\q1 
\v 3 Khosae long khaw then,
\q1 Hlavang khaw then bal,
\q1 Aisi thoeng lek vang dae,
\q1 Jesuh tah then ngai.
\q1 Vaan cael tueih lak ah,
\q1 Jesuh kah a vangnah then ngai.
\q1 
\v 4 Sawt ngaih ka khangkung,
\q1 Namtu kah boeipa,
\q1 Pathen neh hlang hing capa
\q1 Hinyah nah loh kap.
\q1 Koeh uh lam pomsang,
\q1 Dung yan duela namah kah ni.
\c 161
\s1 Koeh Uh Koeh Uh
\s2 Praise Him! Praise Him!
\sp Doh is Eb
\q1 
\v 1 Koeh uh koeh uh
\q1 Lungnah boei tlankung Boeipa Jesuh,
\q1 Dik lai loh a boeilennah thui uh.
\q1 Koeh uh koeh uh,
\q1 tloeng khoelh koek ah a ming cim te,
\q1 Saithainah neh hinyahnah te pae uh.
\q1 Tudawn bangla Jesuh loh a ca a dawn,
\q1 Hnin takuem a kut neh a mawt yoeyah.
\q1 Koeh uh koeh uh a boei a len na te thui uh,
\q1 Koeh kuh koeh uh omngaihnah laa saa uh.
\q1 
\v 2 Koeh uh koeh uh
\q1 Lungnah boei tlan kung Boeipa Jesuh,
\q1 Mamih kah tholh phu la ha duek coeng.
\q1 Koeh uh koeh uh
\q1 a ngawn u tangtae Jesuh ke,
\q1 Mamih kothaenah boeih aka phuei kung
\q1 Jesuh ke koeh na la then te sa u lah,
\q1 A lung na loh tlo tang kik dung tangkik.
\q1 Koeh uh koeh uh a boei a len na te thui uh,
\q1 Koeh kuh koeh uh omngaihnah laa saa uh.
\q1 
\v 3 Koeh uh koeh uh
\q1 vaan kah tang lue koek Boeipa Jesuh,
\q1 Hosanna ti la pang boeih uh lah,
\q1 Jesuh khang kung dungyan boei la a ka om te,
\q1 Khosoihpuei sui lumuek te muek sak uh,
\q1 Khrih ha lo coeng Diklai he boeih a na coeng,
\q1 boeilen na boeih tah amah ka pawn ni.
\q1 Koeh uh koeh uh a boei a len na te thui uh,
\q1 Koeh kuh koeh uh omngaihnah laa saa uh.
\c 162
\s1 Jesuh Loh Kutdoe Paek Ham
\s2 When Jesus Find Us Watching
\sp Doh is Bb
\q1 
\v 1 Jesuh loh kutdoe paek ham a rhum vaengah,
\q1 Kho yin kho thaih ti muehla.
\q1 Uep omnah neh ma mih long n'rhing coi a?
\q1 Hmai im oep soeh la n'tok a?
\q2 \qt Mamih boeih loh oep soeh ng'om uh van nim,\qt*
\q2 \qt mueihla om na ham im then,\qt*
\q2 \qt Mamih rhing nah Jesuh loh a ming nim,\qt*
\q2 \qt Rhing dae Jesuh a rhum tue rhing dae.\qt*
\q1 
\v 2 Min cang kho po thui pa a vang vaengah,
\q1 Pa khat phoei khat n'khue pawn ni.
\q1 Ma mih taengkah n'doe hno m'paek koep a tah,
\q1 Amah loh a uem a ya?
\q1 
\v 3 N'caeh tak bangla ol tak la ng'om uh a?
\q1 Mamih loh than'huel vaeng ah.
\q1 Ma mih lung buei cawt a kap pawt atah,
\q1 A boeilennah te m'pang ni.
\q1 
\v 4 Boeipa hmuh ham aka rhing rhoek long tah,
\q1 A boeilennah a pang ni,
\q1 Khoyin neh hlaem mincang vaeng mai akhaw,
\q1 N'rhing uh he a hmuh van nim?
\c 163
\s1 Khothaih Ham Thuipa Ha Thoeng
\s2 Christ Returneth
\sp Doh is D
\q1 
\v 1 Khothaih ham thuipa loh ha thoeng hang vaeng atah,
\q1 Khosae loh khoyin boeih boeih te a phae vetih,
\q1 Tang ca rhoek coi ham a boeilennah neh
\q1 Boeipa Jesuh tah ha rhum pawn ni.
\q2 \qt Aw Boei Jesuh kan lam tawn uh,\qt*
\q2 \qt Khrih tah ha lo koep coeng \qt*
\q2 \qt Hal le lui ah, Hal lei lui ah, Hal le lui ah,\qt*
\q2 \qt A men hal le lui ah A men.\qt*
\q1 
\v 2 Khothun lung ah khaw, kho tlak tue vaeng mai a a khaw,
\q1 Kho yin bang li ih sap tue vaeng mai bal akhaw,
\q1 Yinnah vang sak ham a boeilennah neh
\q1 Boeipa Jesuh tah ha rhum pawn ni.
\q1 
\v 3 Vaan lamkah ha rhum thuk vaengah vaan hlang ping neh,
\q1 Boeilen hlang la hlangcim rhoek khaw ha rhum van ni,
\q1 Rhennah mik hmai then a boeilennah neh
\q1 Boeipa Jesuh tah ha rhum pawn ni.
\q1 
\v 4 Om ngaih ngai mongnah duek mueh la pha ham ka ngaih,
\q1 Ko thae pa tang tloh tat rhungrhah om voel pawt hmuen,
\q1 Kho mai soah kai pomsang hang pawn ni,
\q1 Boeipa Jesuh tah ha rhum pawn ni.
\c 164
\s1 Boei Jesuh A Rhum Koep vaengah
\s2 When The Roll Is Called Up Yonder
\sp Doh is Ab
\q1 
\v 1 Boeipa olueng a tum vaeng ah
\q1 a tue long khaw bawt pawn ni.
\q1 Dung yan vangnah mincang kho bang sae pawn ni,
\q1 Khang la a ka om rhoek boeih neh
\q1 vaan dong kho ah n'tun pawn ni.
\q1 Ming a khue vaeng ah kai khaw ka om van ni.
\q2 \qt Vaan dong ah ming a khue vaeng ah,\qt*
\q2 \qt vaan dong ah ming a khue vaeng ah,\qt*
\q2 \qt Vaandong ah ming a khue vaeng ah, \qt*
\q2 \qt ming a khue vaeng ah ka khaw ka om van ni. \qt*
\q1 
\v 2 A ka then koek min cang hi ah
\q1 hlang duek rhoek boeih tho pawn ni.
\q1 Boei Jesuh thoh koepnah lennah a pang ni,
\q1 Vaan dong kho amah omnah ah
\q1 tlan ca rhoek loh tun pawn ni.
\q1 Ming a khue vaeng ah kai khaw ka om van ni.
\q1 
\v 3 Min cang lam kah kho tlak duela
\q1 Boeipa hamla bi bi sih,
\q1 A rhen lungnah ko poekrhai te thui lah sih,
\q1 Hingnah bawt tih he lai hman ah
\q1 bi bi loh a bawt vaengah,
\q1 Ming a khue vaeng ah kai khaw ka om van ni.
\c 165
\s1 Boeipa Tah Koep Ha Hlo Ngai Ni
\s2 The Lord Is Coming
\sp Doh is G
\q1 
\v 1 Boeipa tah koep ha lo ngai ni,
\q1 Ngaithuen oepsoeh uh sih.
\q1 A vaan ngolhmuen lamka loh halo,
\q1 Ngaithuen oep soeh sih.
\q1 A mah tah mamih dueng nah boei,
\q1 A hlang yoethen paek ham ha lo,
\q1 Boei ngolkhoel dong ah ngol van ham la
\q1 ngai thuen oep soeh sih.
\q2 \qt Ha lo vaeng ka hamla na oepsoeh a?\qt*
\q2 \qt Ha lo vaeng ka ham na oep soep pawn a?\qt*
\q2 \qt Khoyin kho thaih me vaeng khaw\qt*
\q2 \qt hmai im vang neh ngai thuen sih,\qt*
\q2 \qt ha lo vaeng ka ham ngai thuen oepsoeh sih. \qt*
\q1 
\v 2 Boeipa tah koep ha lo ngai ni,
\q1 Ngaithuem oepsoeh uh sih,
\q1 Paeng tom ham mik nawt na neh ha lo,
\q1 Ngaithuem oepsoeh sih.
\q1 Hal le luijah vaan ah a sak,
\q1 Jesuh loh tlan nah han khuen coeng,
\q1 Boeipa doe hamla hmai im tok laeh,
\q1 ngaithuen oep soeh sih.
\q1 
\v 3 Boeipa tah koep ha lo ngai ni,
\q1 Ngai thuen oep soeh uh sih,
\q1 Olueng ol nen te n'yaak uh pawn ni,
\q1 Ngaithuen oepsoeh sih.
\q1 Olcaek hamla ha lo ve tih,
\q1 Paeng tom hlang  tom tingtung pawn ni,
\q1 A ngolkhoel hmai ah pai van ham la
\q1 ngaithuen oep soeh sih.
\c 166
\s1 Yulokung Ha Lo Vaeng Ham
\s2 When The Bridegroom Comes
\sp Doh is E
\q1 
\v 1 Yu lo kung ha lo vaeng ham
\q1 hmai im na tlaih pawn a?
\q1 Kho yin ah yu lo kung ha lo vaeng ka
\q1 hamla na hmai im te, na vang pawn a?
\q2 \qt Yulokung ha lo vaeng ka ham hmai na tok a?\qt*
\q2 \qt Aw oepsoeh la, rhuengphong uh laeh,\qt*
\q2 \qt yu loh poei ka ham rhuengphong uh laeh.\qt*
\q1 
\v 2 Yulo kung ha lo vaeng ah a ol te n'yaak a yaa?
\q1 Kho yin kah yulokung halo vaeng ah
\q1 omngaih cangtloeng la laa n'sak thai a yaa?
\q1 
\v 3 Yulo kung ha lo vaeng ka ham rhuengphong oepsoeh uh.
\q1 Khoyin ah yulokung halo vaeng ah
\q1 paek na om tholh pawt ham n'ngai thuen uh nim?
\c 167
\s1 Jesuh Lai ah Koep Ha Rhum
\s2 What If It Were Today?
\sp Doh is D
\q1 
\v 1 Jesuh lai ah koep ha rhum thuk ni,
\q1 Ti hnin rhum koi ni ta?
\q1 Saithainah lungnah neh uk ham
\q1 Tihnin ha rhum koi nih,
\q1 A tuek hu la tlan tae boeih neh
\q1 a silh hlang loh ham halo ni.
\q1 Dik lai paeng pum boeih ah te om,
\q1 tihnin ah rhum koinih.
\q2 \qt Thang then thangthen \qt*
\q2 \qt ka lung buei omngaih cuen.\qt*
\q2 \qt Thang then thangthen\qt*
\q2 \qt Lumuek te muek vaeng ah,\qt*
\q2 \qt Thang then thangthen\qt*
\q2 \qt A long puei rhoek bah uh,\qt*
\q2 \qt Thang then Thang then\qt*
\q2 \qt Jesuh ha rhum ngai ni.\qt*
\q1 
\v 2 Satan kah uknah khum yue pawn ni,
\q1 Tihnin ah khum koi nih,
\q1 Ko thae rhung rhah om tlaih mahpawh,
\q1 Tihnin ah mai koinih.
\q1 Khrih ah ka duek loh thoo koep ni,
\q1 Khrih doe ham vaan ah te n'rhing ni,
\q1 Mae vaeng ah boeilen ka hmuh eh,
\q1 tihnin ah rhum koinih.
\q1 
\v 3 A mik hmuh ah hlang dueng la ka om,
\q1 Tihnin ah rhum koinih.
\q1 Rhih mueh la omngaih neh rhing sih,
\q1 Tihnin ha lo a tah,
\q1 Ha lo na ham miknawt muep om,
\q1 Mincang khosae ha sae phuk coeng.
\q1 Rhing dae khoyin tue loh yoei coeng,
\q1 tihnin ah rhum koinih
\c 168
\s1 Hingnah Tui A Longnah Kungah
\s2 Where the Living Wather is Flow
\sp Doh is G
\q1 
\v 1 Hing nah tui a long nah kung ah,
\q1 Boei Jesuh pai dan uh lah,
\q1 Buh pong tui halh rhoek cet uh sih,
\q1 ram then khui ah cet uh sih,
\q2 \qt Long puei tueng kung te vai uh sih,\qt*
\q2 \qt Long puei tueng kung te vai uh sih,\qt*
\q2 \qt Long puei tueng kung te vai uh sih,\qt*
\q2 \qt a me lam khaw vai uh sih,\qt*
\q1 
\v 2 Hing nah thoh ka kun hlang rhoek ni,
\q1 Pathen mah loh a khang eh,
\q1 A mah lu a voeih nah rhang neh,
\q1 dung yan hing nah te m'paek ni.
\q1 
\v 3 Hing nah tu thoh ka ah kun uh,
\q1 A hlang boel tu ping la om,
\q1 A mah Pathen loh a ming bang,
\q1 mamih khaw Jesuh loh m'ming.
\q1 Long puei tueng kung te vai uh sih.
\c 169
\s1 Pathen Poengnah Vaan Dong Kho Then
\s2 The Coming of The Kingdom
\sp Doh is Bb
\q1 
\v 1 Pathen poeng nah vaan dong kho then
\q1 ka mueihla loh a lamtawn,
\q1 Te atah hlang cim rhoek kumhal omthen uh.
\q1 Pathen poengnah vaan dong kho thai omthen khohnin loh yoei ca,
\q1 Pathen om nah vaan dong kho tah yoei ca coeng.
\q1 Pathen om nah vaan dong kho tah yoei ca coeng,
\q2 \qt Pathen om nah vaan dong kho tah yoei ca coeng,\qt*
\q2 \qt Aw ka hing nah rhuengphong lah,\qt*
\q2 \qt vaan dong olueng ol thang neh n'doe uh coeng\qt*
\q2 \qt manghai Pathen ha tueng coeng.\qt*
\q1 
\v 2 Pathen om nah van dong kho then
\q1 ngaiuepnah thinko lung neh,
\q1 Khangkung boeipa ha lo nah bueng a lamtawn,
\q1 Haleluiah a thi neh lainah tah ngaimong yoethen ni,
\q1 Pathen om nah vaan dong kho tah yoei ca coeng,
\q1 
\v 3 Pathen poengnah ha pai vaeng ah
\q1 Boeilen Pathen te tueng ni,
\q1 Yulo kung Boeipa amah tueng lamhma ni,
\q1 Amah loh diklai tholhnah sung rhai kut lamkah loh n'tlan coeng,
\q1 Pathen om nah vaan dong kho tah yoei ca coeng,
\q1 
\v 4 Kum sen hlang rhingda tloel ah
\q1 diklai hlang loh boeih pa tang coeng,
\q1 Lamtawn tloel ah hlang boeih boeih a ko bawt coeng.
\q1 Pathen poengnah thui u si lam tah thahlue sak u la sih.
\q1 Pathen om nah vaan dong kho tah yoei ca coeng,
\c 170
\s1 Jesuh Halo Li
\s2 Jesus Is Coming
\sp Doh is Bb
\q1 
\v 1 Jesuh ha lo li, omngaih laa sa uh,
\q1 A thii neh a tlan te hlang rhoek ham la,
\q1 a then rhuep neh taem rhai ham ha lo li.
\q2 \qt Jesuh tah koep ha rhum ni.\qt*
\q2 \qt Jesuh tah ha lo li Koe ha lo ni,\qt*
\q2 \qt Jesuh tah koep ha lo li,\qt*
\q2 \qt Mol thumtukli, thuitung loh pang uh boeih,\qt*
\q2 \qt Jesuh tah koep ha rhum li.\qt*
\q1 
\v 2 Jesuh ha lo li, hlang duek koep thoo ni,
\q1 Thin tlo hlang rhoek neh tunnah koep om ni,
\q1 Vaan ah a mah taengla n'cet uh hang ni.
\q1 
\v 3 Jesuh ha lo li, hlang cim a coi ni,
\q1 Diklai caemrhal boeih a dim sak pawn ni.
\q1 Kothae la kueng tholh na boeih hma pawn ni.
\q1 
\v 4 Jesuh ha lo li, a ol khueh tah thuem,
\q1 A tuek hlang khui ah uep om hlang yol ca.
\q1 A mah lo nah a ka rhing rhoek coi ham,
\c 171
\s1 Boeipa Te Rhing Uh
\s2 Wait On The Lord
\sp Doh is Eb
\q1 
\v 1 Boeipa te rhing uh,
\q1 ol a khueh vanbangla,
\q1 Boeipa te rhing uh vaan lamkah ha rhum ni,
\q1 Boeipa te rhing uh, tangna neh rhing uh,
\q1 Na thinko tak nen te rhing uh.
\q2 \qt Boeilennah Boeilan nah\qt*
\q2 \qt Tholh ta kung rhal tananeh \qt*
\q2 \qt lungbuei cim caih nah,\qt*
\q2 \qt Boeilennah Boeilennah\qt*
\q2 \qt Pentikos hnin kah boeilennah. \qt*
\q1 
\v 2 Boeipa te rhing uh,
\q1 soep rhaep boeih Jesuh pae,
\q1 Boeipa te rhing uh tholhnah han hlah boeih coeng,
\q1 Boeipa te rhing uh, vaan ah hum ham la,
\q1 Na thinko tak nen te rhing uh.
\q1 
\v 3 Boeipa te rhing uh,
\q1 hmuen sang ben la yoeng ham,
\q1 Boeipa te rhing uh ngaiuepnah then koek neh,
\q1 Boeipa te rhing uh, Vaan hmai vang hmu due,
\q1 Na thinko tak nen te rhing uh.
\c 172
\s1 Pathen Mueihla Ka Khuiah Rhum Lah
\s2 Spirit Of God, Descend Upon My Heart
\sp Doh is C
\q1 
\v 1 Pathen mueihla, ka ko khui ah rhum lah,
\q1 Ka thinko lai lam kah van la luei puei.
\q1 Tha hnoeng vaeng namah bangla tha om sak.
\q1 Lungnah la na om bangla n'lungvat sak.
\q1 
\v 2 Mang ka man pawh, tung hma khaw ka dawt pawh,
\q1 Kut sai taeng a khaw ka kuep bal pawt tih,
\q1 Vaanhlang taengah khaw ka puen bal pawt dae
\q1 Ka lung buei kho yin boeih na hmata sak.
\q1 
\v 3 Nang tah ka Pathen ka manghai boei ni,
\q1 Ka mueihla ka soep rhaep he nang ka ni,
\q1 Na thinglam neh ka lung buei na hmuh sak.
\q1 Namah te n'tlap lam tah m'hmuh sak van lah.
\q1 
\v 4 Kho yin ah rhawp na om te n'cang puei lah,
\q1 Ka mueihla loh hno rhih a na ham khaw,
\q1 Uep vawt na neh ol tha na caekboe ham,
\q1 Thang thuinah neh thin sennah n'cang sak lah.
\q1 
\v 5 Vaan hlang bang la ka lungnah ham n'cang puei,
\q1 A cim sitloh na neh m'bae tawt sak lah.
\q1 Vaan A cim Muei hla neh baptisma m'pae.
\q1 Ka lungbuei he lungnah mueituk pawn saeh.
\c 173
\s1 A Cim Mueihla Vangnah Cim
\s2 Holy Ghost, With Light Divine
\sp Doh is Bb
\q1 
\v 1 A cim Mueihla vangnah cim,
\q1 Ka thinko khui han tue lah.
\q1 Yinnah muei hlip cing sak lam,
\q1 kho thaih then la han coeng sak.
\q1 
\v 2 A cim Mueihla tha dueng cim,
\q1 Ka thinko tholh han cim sak.
\q1 Kum sen hlangka tholhnah he,
\q1 Ka lungbuei nang loh han uk.
\q1 
\v 3 A cim Mueihla omngaihnah
\q1 Ka kothae ko han hoe sak.
\q1 Kosi boeihhan cim sak lam,
\q1 katloh boeihhan hoeih sak lah.
\q1 
\v 4 A cim Mueihla a cim koek,
\q1 Ka thinko ah ha omlah.
\q1 Kutsai rhaenghmuen ka voeih boeih.
\q1 Boeilen koekla ha ngol lah.
\c 174
\s1 Hlanghing Omnah Kungah
\s2 The Comforter Has Come
\sp Doh is C
\q1 
\v 1 Hlang hing omnah kung ah,
\q1 he ol thangthen pung saeh,
\q1 Kothae kosi lungnan
\q1 pin yen hlang boeih taeng ah,
\q1 Khrih ca hlangboel boeih loh,
\q1 omngaih ol thang thui uh,
\q1 Ngaimong sak kung ha lo.
\q2 \qt Ngaimong sak kung ha lo,\qt*
\q2 \qt Ngaimong sak kung ha lo,\qt*
\q2 \qt Vaan kah A cim Mueihla,\qt*
\q2 \qt Pa kah ol khueh bang la,\qt*
\q2 \qt Hlang hing omnah boeih ah,\qt*
\q2 \qt He ol boeih ah thang saeh,\qt*
\q2 \qt ngai mong sak kung ha lo.\qt*
\q1 
\v 2 Khoyin na m'poeng coeng tih,
\q1 Khothaih then he m'pha coeng,
\q1 Lakueng rhih omnah ah,
\q1 Ngaimongnah pae kung ni,
\q1 Om then na hnin mpha coeng,
\q1 kothae tue loh khum coeng.
\q1 Ngaimong sak kung ha lo
\q1 
\v 3 Boei koek ke dan uh lah,
\q1 Hoeihnah a phae hlip neh,
\q1 Tholh kah pin yen hlang boeih,
\q1 loeihnah pae kung la om,
\q1 Vaan hlang ping loh a sak,
\q1 ta nah laa then ol tah,
\q1 Ngaimong sak kung ha lo
\q1 
\v 4 A lungnah ka sang koek,
\q1 olka loh thui thai pawh,
\q1 Na rhen lungvatnah he,
\q1 ka thui ka phong lek pawh,
\q1 Yin khuiah om tangtae,
\q1 kho sae then la mawt ham
\q1 Ngaimong sak kung ha lo
\c 175
\s1 A Cim Mueihla Hoihaeng Kung
\s2 Holy Spirit Faithful Guide
\sp Doh is G
\q1 
\v 1 A CimMuei hla, hoihaeng kung,
\q1 Kaimih taengah om yoeyah.
\q1 Hnin takuem na kutneh m'mawt,
\q1 Vaan long puei ka caeh vaengah,
\q1 Ol ding ca neh n'toi vaengah,
\q1 Pa tang rhoek loh a ngaimong,
\q1 Ka caeh nah long hoihaeng kung
\q1 vaan im then la n'caeh puei ni.
\q1 
\v 2 Paya then la om yoeyah
\q1 Khang kung boei la nang na om.
\q1 Rhihom lakueng om kolla,
\q1 Rhai nah khui ah kai mawt lah,
\q1 Tuilet hlipuei a thoh vaeng,
\q1 Ngaihmang nah om mai ca khaw.
\q1 Ka caeh nah long hoihaeng kung
\q1 vaan im then la n'caeh puei ni.
\q1 
\v 3 Bi patang a bawt vaeng ah,
\q1 Pathen khue nah ol hnatun.
\q1 Thangthuinah neh rhing yoeyah,
\q1 Vaan ah mamih boeih ng'om coeng,
\q1 Dueknah tuiva n'kat vaeng ah,
\q1 Jesuh thisen bueng uep nah,
\q1 Ka caeh nah long hoihaeng kung
\q1 vaan im then la n'caeh puei ni.
\c 176
\s1 Pathen Hil Han Sang Lah
\s2 Breathe On Me, Breath Of God
\sp Doh is F
\q1 
\v 1 Pathen hil han sang lah,
\q1 hing thai neh m'baetawt sak.
\q1 Na ko ngaih na bangla
\q1 bi ka bi thainah ham.
\q1 
\v 2 Pathen hil han sang lah,
\q1 ka ko a cim hla due.
\q1 Nang neh kodok hmaih tih,
\q1 uehnah neh bi bi ham.
\q1 
\v 3 Pathen hil han sang lah,
\q1 Na hlang la ka om due,
\q1 Lai pumsa tholaeng due,
\q1 hmai neh kai n'cim sak lah.
\q1 
\v 4 Pathen hil han sang lah,
\q1 ka duek na tlaih pawt ham,
\q1 Na mah neh hing thennah dongah,
\q1 dung yan hing ham.
\c 177
\s1 Cim Mueihla Vahu Bang Rhum
\s2 Come, Holy Spirit, Heavenly Dove
\sp Doh is G
\q1 
\v 1 Cim Muei hla vahu bang rhum lah,
\q1 Na boei na lennah neh,
\q1 Lungnah hmai thoi bangla vang sak,
\q1 Ka ko dingrhael ah he.
\q1 
\v 2 Thathae dawk la laa ka sak tih,
\q1 tangnah loh a duek sut,
\q1 Ka ka loh ho san na ti pawh,
\q1 Lungnah loh vik hmata.
\q1 
\v 3 Boeipa he tlam he kum hal ah,
\q1 ka hing thai van a yaa?
\q1 Nang kan lungnah long tah bawt boeng,
\q1 Nang kah lungnah tah len.
\q1 
\v 4 Muei hla Cim vahu bang rhum lah,
\q1 Na boei na lennah neh,
\q1 Kan lungnah hmaialh sak ham la,
\q1 Lungnah hmai han tok lah.
\c 178
\cp 178A
\s1 Paya Then Koek Ka Hmuh
\s2 I Have Found A Friend Indeed
\sp Doh is G
\q1 
\v 1 Paya then koek ka hmuh coeng
\q1 ka ngoe na boeih soep sak kung,
\q1 Tanglue koek khangkung boeipa,
\q1 Tangnah mik neh ka hmuh coeng,
\q1 Amah tah khangkung boei ni,
\q1 Ka caeh nah boeih ah n'om puei.
\q2 \qt Ha le lui jah khangkung boei neh ka cet hmaih ni,\qt*
\q2 \qt Khangkung boeipa, so sang boeipa.\qt*
\q2 \qt A lung vatnah sit lohnah neh ka cet hmaih ni,\qt*
\q2 \qt Kamah bueng ka pamdah voel mahpawh. \qt*
\q1 
\v 2 Ka tholh nah a cim sak tih,
\q1 hlang dueng la kai n'poeh sak coeng,
\q1 Tang lue koek khang kung boeipa ,
\q1 Ka mueihla a sueng sak tih,
\q1 Rhoepnah ol thangthen han thui,
\q1 Ka long puei ah kai n'om puei.
\q1 
\v 3 Tholh thinrhih neh ka om vaeng,
\q1 Maelhmai hlampan neh n'om puei,
\q1 Tanglue koek khangkung boeipa
\q1 Amah bang la hlip ying nah,
\q1 Duemnah hmuen then ka hmuh pawh,
\q1 Amah bueng khangkung la om. A
\cp 178B
\s1 Yan Vaengkah Khokhaem Pa Loh
\q1 
\v 1 Yan vaeng kah khokhaem pa loh,
\q1 Bawk im kah thoh ka kaeng ah,
\q1 Peter neh Johan taeng ah hno a bih,
\q1 Peter loh hno tloe paek ham,
\q1 He tah a om moe nih a ti,
\q1 A khueh duen Naza reth Jesuh a paek,
\q2 \qt Nazareth Jesuh mueh tah,\qt*
\q2 \qt nang hamla ka khueh he om moenih, \qt*
\q2 \qt Ka taeng ah hno tloe om mai ca khaw, \qt*
\q2 \qt Nazareth Jesuh bueng ni ka khueh duen he.\qt*
\q1 \va 2\va* Na khueh tawn te boeih yoi lah,
\q1 Hna rhah kho daeng boeih pae lah,
\q1 Te phoei ah ka hnuk ha bang lah a ti,
\q1 Khrih muei mae hlip dah kung neh,
\q1 Dik lai koe va phaeng lak ah he,
\q1 Ka hoe mueh Jesuh khueh duen la om saeh,
\q1 \va 3\va* Khrih kah a hnuk bang rhoek loh,
\q1 A ram kah bi bi vaeng ah,
\q1 Kang halh kung hno tloe he khueh uh boel sih,
\q1 Nang hut la kai ka om coeng,
\q1 a ka tih kung Pathen bueng he,
\q1 Hing khui ah khueh duen hno then la om saeh,
\c 179
\s1 Aw Manghai Boei Phueih Mawt
\s2 Lead On O King Eternal
\sp Doh is D
\q1 
\v 1 Aw manghai boei phueih m'mawt lah,
\q1 hmai la khong tue ham pha.
\q1 Tanah hmuen due la m'mawt lah,
\q1 Na dap kai mih im saeh.
\q1 Ka rhuengphong khui a te tah,
\q1 rhennah neh tha n'om sak
\q1 Dung yan manghai boei ta hae,
\q1 caemthoh laa ka sak uh.
\q1 
\v 2 Aw manghai boei phueih m'mawt lah,
\q1 tholh caem bawt ka tloek due,
\q1 Na cimcaih nah han thui lah,
\q1 Amen rhoepnah tila,
\q1 Cucai tubael nen moenih,
\q1 toem ca mong laeng nen moenih,
\q1 Na rhen lung nah nen ni,
\q1 Pa then ram a pai eh.
\q1 
\v 3 Aw manghai boei phueih m'mawt lah,
\q1 rhih mueh la baang ka ngaih.
\q1 Na maelhmai ka hmuh na ah,
\q1 Omngaihnah kho ha thai.
\q1 Na thinglam a so ah cet,
\q1 Kaimih kah long puei han tue.
\q1 Tanah lumuek ka rhing,
\q1 Thaom Pathen m'mawt lah.
\c 180
\s1 Khrihca Rhalkap Rhoek Aw
\s2 Onward Christian Soldiers
\s3 Doh is F
\q1 
\v 1 Khrih ca rhal kap rhoek aw hmai ben la cet uh,
\q1 ma mih hmai ah ka cet Jesuh ke dan uh.
\q1 Khrih boeipa loh ma mih ham hmai ben ah cet
\q1 A thinglam ke danlah hmai ben la cet uh.
\q2 \qt Khrihca rhalkap rhoek aw hmai be la cet uh\qt*
\q2 \qt hmai ben ah a ka cet Jesuh ke so uh.\qt*
\q1 
\v 2 Jesuh ming a yaak vaeng sungrhai boeih nong coeng
\q1 Jesuh ming neh ta uh Khrihca rhoek boeih aw
\q1 Thang then ol a yak vaeng sungrhai ram loh yawk
\q1 Ma nu ca laa sa uh na ol khueh boeih neh.
\q1 
\v 3 Rhal kap bangla cet uh Khrih hlangboel boeih loh,
\q1 hlang cim rhoek a caeh nah konghu vai uh sih
\q1 paekboenah om voel pawh pum khat ca boeih ni
\q1 Tang nah neh ngai uep nah khaw thik at la om.
\c 181
\s1 Khrih Kah Hlangboel Hamla
\s2 For Christ And The Church
\sp Doh is F
\q1 
\v 1 Khrih kah hlangboel hamla m'pai,
\q1 Kut at thin at cala,
\q1 Amah koeh ol n'thui tih,
\q1 Kut neh kho daeng m'bom uh.
\q1 Khrih kah hlangboel hamla,
\q1 aka hma kho neh n'tlap.
\q2 \qt Khrih a hlang boel hamla m'pai uh.\qt*
\q2 \qt kut at thinat ca la.\qt*
\q2 \qt Ma mih kah hingnah boeih m'paek uh.\qt*
\q2 \qt Khrih a hlang boel ham la.\qt*
\q1 
\v 2 Khrih kah hlangboel ham n'thang thui,
\q1 Hin ta kuem a bi bi,
\q1 Thahlue neh n'thinom tih,
\q1 A bi bitha n'huel uh.
\q1 Khrih a hlang boel ham la,
\q1 a paipi m'pai puei uh.
\q1 
\v 3 Khrih kah hlangboel ham laa n'sak.
\q1 Om ngaih ho san na n'ti.
\q1 Sayalhnah m'paek lam loh,
\q1 ta na ham ol a khueh.
\q1 Khrih a hlang boel ham ti,
\q1 ma mih kah maeng taeng nah.
\c 182
\s1 Caih Lah Caih Lah
\s2 The Church's Rallying Song
\sp Doh is C
\q1 
\v 1 Caih lah caih lah, Boeipa loh ta hae ma mih n'khue.
\q1 Tho lah tho lah A ol dong hangdang uh.
\q1 Cet lah cet lah, Ju bi lee ol thangthen thui uh,
\q1 Khangkung boeipa kah ol cim te khuen uh boeih lah.
\q2 \qt Tho uh laa ke sa uh, Tho uh,\qt*
\q2 \qt Ai si thui pa ma mih so ah vang.\qt*
\q2 \qt Tho uh, Khang kung boei \qt*
\q2 \qt thin om koek loh ma mih hmai ah m'mawt uh coeng.\qt*
\q2 \qt Thang then thangthen \qt*
\q2 \qt hlang ping loh dung yan la pang,\qt*
\q2 \qt Hosanna ti la caeh doe ah phueih a thui uh.\qt*
\q2 \qt He uepom rhalkap boeih loh, \qt*
\q2 \qt Jesuh bueng he ni m'ming uh.\qt*
\q2 \qt Haleluijah ti la caeh doe ah n'sak uh. \qt*
\q1 
\v 2 Vangnah a ngoe, ram thai ben kah pang ol hnatun,
\q1 Ha pai ha pai Tuitun poeng voel lamkah,
\q1 Phong uh phong uh, kho hla ram la a ol thui uh,
\q1 Imkhui ah aka om sut khaw han hnilh uh boeh.
\q1 
\v 3 Pathen hlangboel, rhen nah kut te yueng uh boeih lah,
\q1 Mol hlaep tam yin ah aka hma tlap ham,
\q1 Na kut phuel lam lungnah neh amih han hlawt lah,
\q1 Khang kung boei kah tu ping khui la han lo puei lah.
\q1 
\v 4 Dan lah dan lah, a ol khueh loh ha yoei ca coeng,
\q1 Thangpom thangpom Mamih khangkung boeimang,
\q1 A phae neh a ku tih omngaih ngai mongnah soep,
\q1 Ha le lui jah boeilenkoek tila pang uh sih.
\c 183
\s1 Na Poengnah Ka Ngai Uh
\s2 I Love Thy Kingdom, Lord
\sp Doh is G
\q1 
\v 1 Na poengnah ka ngaih uh,
\q1 na om nah im then te,
\q1 Tlangkung loh a khang na hlangboel,
\q1 amah thi neh a tlan.
\q1 
\v 2 Na hlang boel ka lungnah,
\q1 Na hmai ah ka pai uh,
\q1 Dan ngaih nan pu hlu uh boeih he,
\q1 na kut ah ka om uh.
\q1 
\v 3 Anih ham mik phi bo,
\q1 Anih ham ka thangthui,
\q1 Anih hamla ka hlan tui bo,
\q1 Dik lai a bawt duela.
\q1 
\v 4 Na oltak te cak tih
\q1 Dik lai omthennah neh,
\q1 vaan boeilennah boeih boeih te khaw,
\q1 Zi on na pang sak coeng.
\c 184
\s1 Hnin At Ah Pathen Koehnah
\s2 One Day
\sp Doh is G
\q1 
\v 1 Hnin at ah Pathen koehnah vaan ah bae tih,
\q1 Tholh nah he kho a yin khup hnin vaeng ah,
\q1 Jesuh tah hula cuem lamkahloh ha thaang.
\q1 Awt ham koi la hlang lakah kho a sak.
\q2 \qt A hing neh n'lung nah,\qt*
\q2 \qt a duek nah neh n'khang,\qt*
\q2 \qt a vueinah neh ka tholhnah boeih a phueih.\qt*
\q2 \qt Thoh koep na neh n'cim sak,\qt*
\q2 \qt dungyan la ka loeih,\qt*
\q2 \qt hninat ah boeilennah neh ha lo ni.\qt*
\q1 
\v 2 Hnin at ah Jesuh Kalvari la a mawt,
\q1 Thinglam dong ah anih te a tai uh.
\q1 Ko daeng pa tang tam daeng tam khaa te a yook.
\q1 Ma mih kah tholhnah boeih boeih a phueih coeng.
\q1 
\v 3 Hnin at ah dum khui ah sut a caeh tak uh,
\q1 Patangnah lamkah loh anih loeih coeng.
\q1 Vaan caeltueih loh ha rhum thuk tih phuel a tawt.
\q1 Ko bawt rhoek te ngaiuepnah paek koep ham.
\q1 
\v 4 Hnin at ah phuel loh Boeipa te a thuh tloel,
\q1 Lungto khaw phuel thohka lamkah a thoih.
\q1 Dueklakli lamkah loh tanah neh tho coeng.
\q1 Vaan dong la luei hang dungyan ka boeipa.
\c 185
\s1 Pathen Kah Kopoekrhai
\s2 The Lord Is Coming
\sp Doh is Eb
\q1 
\v 1 Pathen kah kopoekrhai lunngnah,
\q1 kai ming sak ka ming pawh.
\q1 Hlang koih pawh kai he a hlang la,
\q1 Khrih loh n'tlan ka ming pawh.
\q2 \qt Te ah ca khaw ka tangnah ka ming, \qt*
\q2 \qt amah loh kai hloeihhlamnah boeih te khaw, \qt*
\q2 \qt Ke kho hnin due la n'khoem bael thai, \qt*
\q2 \qt te dong ah kai ka yak pawh.\qt*
\q1 
\v 2 Khang hamla kai ka khui a he,
\q1 tangnah m'paek ka ming pawh.
\q1 Ka ko khuiah amah ol loh,
\q1 ngaimongnah m'paek te khaw.
\q1 
\v 3 Cim Muei hla loh thin ko tholhnah,
\q1 n'yakmingsak ka ming pawh.
\q1 A ol loh Jesuh kawng a thui,
\q1 tangnah thin ko m'paek khaw.
\q1 
\v 4 Boeipa me vaeng nim halo vae,
\q1 kho thun a nim, m'ming pawh.
\q1 Dik lai a nim n'om hmaih van ve,
\q1 vaan lam nim n'luei puei ve.
\c 186
\s1 Paham Nuham Tangnah
\s2 Faith Of Our Fathers’ Living Still
\sp Doh is Ab
\q1 
\v 1 Paham nuham tangnah phueih hing,
\q1 Rhihom caemrhal ngai yaak na pawh.
\q1 He ol then koek ka yaak vaengah,
\q1 Ka lungbuei om ngaihnah neh bae.
\q2 \qt Pa ham nu ham tangnah cim tah,\qt*
\q2 \qt Duek hlan due la khueh uh boeih sih. sih.\qt*
\q1 
\v 2 Paham nuham tangnah len koek
\q1 Namtom hlang boeih a na uh boeih.
\q1 Pathen taeng kah oltak rhangneh,
\q1 Hlang hing boeih loh loeih uh pawn ni.
\q1 
\v 3 Paham nuham tangnah bangla,
\q1 Baerhoep neh rhal ka lungnah ni,
\q1 Lungnah ol he ka thui van ni,
\q1 Ol ding neh khoboe rham lang neh.
\c 187
\s1 Namah Boeilennah A Thui Uh
\s2 Glorious Things Of Thee Are Spoken
\sp Doh is F
\q1 
\v 1 Namah boeilennah a thui uh
\q1 Pa then kah Zi on kho puei.
\q1 Ol khueh aka cak Pathen loh
\q1 amah omnah a saii coeng.
\q1 Dungyan lung nu dong a sak te,
\q1 u long nim a thoeih sak eh?
\q1 Khangnah vong loh n'thung khoep phoei ah,
\q1 Na rhal rhoek ka rhih mahpawh.
\q1 
\v 2 Dan lah dungyan lungnah lamkah
\q1 hingnah tuiva ha long coeng.
\q1 Na ca boeih na tul na cah coeng,
\q1 Vawtvainah a om mueh la,
\q1 Te tui va a long li vaengah,
\q1 U nim tui aka hal eh?
\q1 Boeipa kah a lungvatnah he,
\q1 Dungyan bawt tlaih voel mahpawh.
\q1 
\v 3 A om nah a taengvai boeih ah,
\q1 Hmaivang neh khomai ha thoeng.
\q1 Boeilennah loh a thing a dah,
\q1 Boei ha yoei nah a tueng sak.
\q1 Hnin takuem hingnah buh pae kung
\q1 ko pang ol boeih ka yaa kung
\q1 So ben na ngolkhoel hmai ah te,
\q1 Hosanna ti la boeih pang uh.
\c 188
\s1 Kai Ka Omngaih Tangkik
\s2 How Pleased And Blest Was I
\sp Doh is F
\q1 
\v 1 Kai ka omngaih tang kik,
\q1 Hlang tuen ol ka yaak ah,
\q1 Ha lo Pathen tlap uh lah sih.
\q1 Thahlue tha hmae neh
\q1 Boeipa tlang cim dong la cet uh sih,
\q1 Pathen te koeh bawk sih.
\q1 
\v 2 Zi on hmuen then lamkah
\q1 a lungvatnah a koeh,
\q1 Thaomnah vong loh a thung te,
\q1 Nang dongah ka pil nam loh
\q1 thangthuinah neh tho a thueng.
\q1 Ol thang a yak vaengah.
\q1 
\v 3 David capa te om,
\q1 A ngol hmuen a cak sak.
\q1 Lungvatnah neh ol a caek coeng.
\q1 Hlang cim ngaia mong sak tih
\q1 hlang tholh a ko a thae sak.
\q1 lunghoih a omngaih sak.
\q1 
\v 4 Ngai mongnah ah ka pai,
\q1 Omngaih la kan lamtawn,
\q1 Hlang boeih he yoethen ham pae lah.
\q1 Nang kah ngaimongnah neh
\q1 na kongaihna aka tlap te,
\q1 yoethennah ham pae lah.
\c 189
\s1 Khotlak Vannaem Lamkah
\s2 Loyalty to Christ
\sp Doh is F
\q1 
\v 1 Kho tlak vannaem lamkah, noeknah aka thoeng tah,
\q1 Uepomnah ni, uep omnah, Khrih ham uepomnah.
\q1 Phung ding ol neh mol dong ah uepom laa a sak,
\q1 Oe uepomnah Oe uepomnah Khrih ham uepomnah.
\q2 \qt Tanah ben la cet, tanah ben la cet\qt*
\q2 \qt Ma mih kah rhal boei loh m'mawt.\qt*
\q2 \qt A ol paek ngai uh sih lamram ke lo uh sih,\qt*
\q2 \qt Uep om ca la uep om ca la , Khrih ah uep om la.\qt*
\q1 
\v 2 Thin om rhoek hna tun uh, lai a ka hil ol te,
\q1 Uepomnah neh, uepomnah, Khrih ham uepomnah,
\q1 Tho lam a bi te bi, ol thangthen te phong uh,
\q1 Oe uepomnah, Oe uepomnah Khrih hamuepomnah.
\q1 
\v 3 Uepom hlang ha lo uh, tholh te n'ta uh boeih coeng.
\q1 Uepomnah neh uepomnah, Khrih ham uepomnah,
\q1 Satan kah hni tai te, olueng ol neh khoe uh,
\q1 Oe uepomnah, Oe uepomnah Khrih ham uepomnah.
\q1 
\v 4 Tihnin rhoengthai rhoek loh, Khrih kho kung ah kuep uh,
\q1 Uepomnah neh uepomnah, Khrih ham uepomnah,
\q1 Ol thangthen pang puei uh, Diklai paeng tom ram ah,
\q1 Oe uepomnah Oe uepomnah, Khrih ham uepomnah.
\c 190
\s1 Khrih ah Kholo Khotlak
\s2 In Christ There Is Not East Or West
\sp Doh is Eb
\q1 
\v 1 Khrih ah kholo khotlak ompawh,
\q1 a noi a tlang ompawh.
\q1 Tedae lung nah tang lue loh
\q1 diklai pum a thing boeih.
\q1 
\v 2 Amah dongah hlang phung boeih loh,
\q1 ko at ca la tun uh.
\q1 A bi bi tah hlang phung
\q1 cingcui nah sui rhui la om.
\q1 
\v 3 Kut at la tangnah saicin uh,
\q1 phung paekboe om kolla.
\q1 Pa ko ngaih a ka sai te tah
\q1 kai ham phung tak ni.
\q1 
\v 4 Khrih ah khocuk khotlak hum cui,
\q1 Noi tlang loh tingtun uh.
\q1 Khrih thinko a khueh hlang te tah
\q1 pum khat la ng'om uh.
\c 191
\s1 Hlangboel kah Khoengim
\s2 The Church's One Foundation
\sp Doh is Eb
\q1 
\v 1 Hlang boel kah khoengim khat tah,
\q1 Boeipa Jesuh Khrih ni A nih tah a ol neh,
\q1 tuii neh a thai la a sai.
\q1 Hulacuem la om sak ham
\q1 vaan dong lam kah han tlap.
\q1 A mah thii neh a lai tih,
\q1 manih hamla ha duek.
\q1 
\v 2 Namtom hlang lak kah a tuek,
\q1 Lai ah pum khat la om.
\q1 Khangnah khoengim te tah,
\q1 tangnah cun nah pa khat ni.
\q1 Ming cim khat bueng a koeh uh,
\q1 buh cim khat a vael uh.
\q1 Ngaiuepnah khat lungvatnah,
\q1 a len koek neh a cah.
\q1 
\v 3 Patang neh puen pa vaeng ah,
\q1 caem rhal lak li a khaw,
\q1 Anih long tah dungyan,
\q1 ngaimongnah te a lamtawn.
\q1 Boeilennah a hmuh duela
\q1 a mik khap tlaih voel pawh.
\q1 Tanah a om vaeng ah tah,
\q1 a hlang boel duem pawn ni.
\q1 
\v 4 Diklai hman ah anih tah,
\q1 thum suem Pathen khat neh,
\q1 Thikat la buh a vael.
\q1 Hlang cim yoe then hlang bangla,
\q1 Boeipa na rhennah te
\q1 kaimih khaw m'pae uh van lah.
\q1 Nang neh thikat la om ham
\q1 lunghoih kodo nah m'pae.
\c 192
\s1 Boeipa kah Boeilennah ah
\s2 Be Ye Strong In The Lord
\sp Doh is G
\q1 
\v 1 Boeipa kah boeilennah ah thaomnah boeih neh,
\q1 a ol dongah a cak la pai uh sih.
\q1 Caem neh rhal lak ah khaw
\q1 amah loh m'mawt bitni,
\q1 Boeipa ming neh tanah la cet uh sih.
\q2 \qt A cak la pai uh sih,\qt*
\q2 \qt Boeipa ol paek bang rhal boeih ta uh.\qt*
\q2 \qt Boeipa ming thang pom nah ham\qt*
\q2 \qt a ol paek neh ta uh sih,\qt*
\q2 \qt Boeipa dong a cak la pai uh sih.\qt*
\q1 
\v 2 Boeipa kah boeilennah dongah na tha om sak,
\q1 Me vaengah khaw a hnuk la nong uh boeh.
\q1 Ol tak hamla n'tuk tih a mah loh n'om puei ni,
\q1 A thaomnah dong a hmai la cawh uh.
\q1 
\v 3 Boeipa kah boeilennah dongah na tha om sak,
\q1 A ol khuehnah long tah paa tlaih mah pawh,
\q1 Oltak ham n'tuk atah, amah loh m'mawt ngai ni,
\q1 Amah pangtung la na yawk tlaih mahpawh.
\c 193
\s1 Baibal Cim Pathen Cabu
\s2 Holy Bible, Book Divine
\sp Doh is A
\q1 
\v 1 Baibal Cim Pathen ca bu,
\q1 Nang kai kah kawn then koek ni.
\q1 Kai ka poe nah han thui tih,
\q1 Ka coengnah khaw n'cang sak bal.
\q1 
\v 2 Ka pam dah vaeng toeltham kung,
\q1 Khangkung lungnah ming sak kung.
\q1 Kai dawn kung neh hoi haeng kung,
\q1 Toel tham kung neh uem o kung.
\q1 
\v 3 Rham rhae ah ka pa tang tih,
\q1 ngai hmang vaeng ah hloep hloei kung.
\q1 A ka hing tangnah nan tueng,
\q1 duek he hlangloh a ta nah.
\q1 
\v 4 Kai ham omngaihnah han khuen,
\q1 boekoek tah duek ni a ti.
\q1 Aw nang Khohni cabu cim,
\q1 kai ka kawn then koek la om.
\c 194
\s1 Baibal Neh Yoei Lah
\s2 Cling To The Bible
\sp Doh is Bb
\q1 
\v 1 Baibal neh yoei lah rhih nah boeih hma ta ni,
\q1 A cim cangpueinah te han hlong uh boeh.
\q1 Ih duek sut mueihla hinghang na ham lam ni.
\q1 Duek lam kah hinghang nah ham ol a khueh.
\q2 \qt Baibal neh yoei lah, Baibal neh yoei lah,\qt*
\q2 \qt long puei tueng kung hmai im then Baibal.\qt*
\q1 
\v 2 Baibal neh yoei lah lung then lakah then ngai,
\q1 Hlang tholh ham dungyan hingnah ka pae kung.
\q1 A phu a tloh hlang hing loh thui thai lek pawh.
\q1 A yoe then na tlap la aw ka mueihla.
\q1 
\v 3 Kho ka hmang vaengah ka kho ham hmaithoi ni,
\q1 Hlangnoe rhoek a paloe pawt ham a hoii.
\q1 Ko bawt rhoek hamla ngai uepnah then koek ni.
\q1 Patong ham cong hol cabu then koek ni.
\c 195
\s1 Lai Ka Hingnah Longpuei
\s2 Cling To The Bible, My Boy
\sp Doh is F
\q1 
\v 1 Lai ka hingnah long puei yin ka caeh li vaengah,
\q1 Sai sak ham ka ngaih tangkik hno pa khat te om,
\q1 Aw hnatun lah he ol ka ka thui vaengah,
\q1 Bai bal ol te poek khuep van lah.
\q2 \qt Bai bal ol te poek khuep van lah,\qt*
\q2 \qt Bai bal ol te poek khuep van lah,\qt*
\q2 \qt Duek neh hing ah Baibal ol te poek khuep van lah\qt*
\q2 \qt Baibal ol te poek khuep van lah.\qt*
\q1 
\v 2 Ko thae ngaihmang neh mikphitui bo mai cakhaw,
\q1 Kumhal Satan rhal te na tuuk bal mai cakhaw,
\q1 Khrih rhangneh rhih kolla na rhal te tuk lam,
\q1 Baibal ol te poek khuep van lah.
\q1 
\v 3 Pathen na tangta a tah na tha te om ni,
\q1 Thinglam te na hmai taang atah na hma mahpawh,
\q1 Yin caeh long ah thangthennah laa sa lamtah,
\q1 Baibal ol te poek khuep van lah.
\q1 
\v 4 Bai bal he tah ngaiuepnah a kung puei la om,
\q1 Kho yin lak ah mawt kung aisi hmai vang la om,
\q1 A mawt na kung ah hmata na om pawt tih,
\q1 Bai bal ol te poek khuep van lah.
\c 196
\s1 Ka Taengah Ol Neh Han Thui
\s2 Wonderful Words Of Life
\sp Doh is G
\q1 
\v 1 Ka taeng ah ol neh han thui lah
\q1 ko poek rhai hing nah ol
\q1 Na mah muei then te hmuh ka ngaih
\q1 ko poek rhai hing nah ol.
\q1 Hing nah ol then koek te
\q1 tang nah neh tukkil lah.
\q1 A then ngai ol kopoekrhai ol,
\q1 kopoekrhai hingnah ol.
\q1 A then ngai ol kopoekrhai ol,
\q1 kopoekrhai hingnah ol.
\q1 
\v 2 Khrih loh hlang ham yoe then a paek,
\q1 ko poek rhai hingnah ol
\q1 A lung vatnah khue ol hnatun,
\q1 ko poek rhai hingnah ol.
\q1 Kopoek rhai yancil ol,
\q1 Na boei na len hmuh sak.
\q1 A then ngai ol kopoekrhai ol,
\q1 kopoekrhai hingnah ol.
\q1 A then ngai ol kopoekrhai ol,
\q1 kopoekrhai hingnah ol.
\q1 
\v 3 Ding suek ca gospel olthangthen,
\q1 kopoekrhai hingnah ol
\q1 Hlang boeih tholh rhennah neh rhoep nah,
\q1 ko poek rhai hingnah ol.
\q1 Jesuh bueng he khang kung
\q1 neh tholh cim sak kung ni.
\q1 A then ngai ol kopoekrhai ol,
\q1 kopoekrhai hingnah ol.
\q1 A then ngai ol kopoekrhai ol,
\q1 kopoekrhai hingnah ol.
\c 197
\s1 Diklai Ham Baibal Cim A Ong
\s2 An Open Bible For The World
\sp Doh is Bb
\q1 
\v 1 Diklai ham Bai bal cim a ong.
\q1 Mamih kah rhungsut la om saeh.
\q1 Yilh ding a caeh na ta kuem ah,
\q1 yoe then nah cung kuem te khuen saeh.
\q2 \qt Pathen ol cim vangnah han tueih.\qt*
\q2 \qt paeng tom neh tui tun li due\qt*
\q2 \qt Kho khoyin khui ah ka om rhoek \qt*
\q2 \qt Pathen om nah vaan dong la na mawt. \qt*
\q1 
\v 2 A pha na boeih ah a vangnah,
\q1 Khosae bangla a sae sak coeng.
\q1 Tholhnah boeih boeih a na coeng tih,
\q1 muei rhih tamyin a haai sak coeng.
\q1 
\v 3 Pathen maelhmai a tueng sak tih,
\q1 Khodawk ngai neh lungvat nah bae.
\q1 Adam ca dil ka hma taeng ah,
\q1 so ben olding neh a thui pah.
\q1 
\v 4 Lakueng vaeng ah ngai a mong sak.
\q1 Aka rhap khaw a hloep a hloei.
\q1 Ko bawt rhoek tha a hlue sak tih,
\q1 Kum te ngaiuepnah a soep sak.
\c 198
\s1 Khohnin rhih Khui Sading La
\s2 Safely Through Another Week
\sp Doh is G
\q1 
\v 1 Khohnin rhih khui sa ding la,
\q1 Pathen nang loh nan mawt tih,
\q1 Ti hnin na bawk im cim ah,
\q1 Ngai mong yoe then kan bih uh,
\q1 Khohnin rhih nah hnin then koek
\q1 dungyan duem nah ham noeknah
\q1 kho hnin rhih na hnin then koek
\q1 dung yan duemnahham noek nah.
\q1 
\v 2 Rhennah bih ham ka thangthui,
\q1 Khangkung boei na ming cim neh,
\q1 Na boeilennah te m'hmuh sak,
\q1 Na maelhmai then te hmuh sak.
\q1 Lai ko ngaih lamkah n'loeih sak,
\q1 namah taengah duemka ngaih.
\q1 Lai ko ngaih lamkah n'loeih sak,
\q1 namah taengah duemka ngaih.
\q1 
\v 3 Na ming koeh ham ka lo uh,
\q1 Namah neh yoei ka ngaih uh.
\q1 Na im la ka lo uh vaeng,
\q1 na boeilennah m'hmu sak uh.
\q1 Kaimih khaw m'vael sak van lah,
\q1 na dungyan buh loei kung ah.
\q1 Kaimih khaw m'vael sak van lah,
\q1 na dungyan buh loei kung ah.
\q1 
\v 4 Na ol thangthen ol long tah,
\q1 Tholh a ta hlang cim hloep saeh.
\q1 Na rhen lungnah thaih su saeh,
\q1 ko pang hlang hoeih khang nah pae
\q1 He khohnin cim sak van saeh,
\q1 vaan dong la n'luei uh hlan due,
\q1 He khohnin cim sak van saeh,
\q1 vaan dong la n'luei uh hlan due.
\c 199
\s1 Aw Duemnah Neh Omngaih Hnin
\s2 Lead On O King Eternal
\sp Doh is F
\q1 
\v 1 Aw duemnah neh omngaih hnin,
\q1 Kohoe neh vangnah hnin,
\q1 Kothae neh ngaihmang vaengah,
\q1 sawt ngaih na omthen mai.
\q1 A toem a sang hlang boeih loh,
\q1 bawt mueh la nang n'koeh uh.
\q1 Sa a cim a cim a cim ti la Pathen koeh sih.
\q1 
\v 2 Namah ni saikung lamhma
\q1 cunkung neh vangnah,
\q1 Nang ni kai hamla khangnah,
\q1 Diklai ah Khrih thoo tih.
\q1 Nang ah kaimih ham tanah,
\q1 Mueihla van kah nan tueih.
\q1 Te om then na kho hnin ah,
\q1 vangnah pathum nan paek.
\q1 
\v 3 Namtu buh a pong vaengah,
\q1 vaan manna nan hlak pah.
\q1 A cim thothuengnah hmuen ah,
\q1 Olueng ol neh a khue.
\q1 Ol thangthen a van nah tah,
\q1 kho saeng bang la a tue.
\q1 Hing nah tui a longnah ah,
\q1 mueihla tui halh rhaem sak.
\q1 
\v 4 Lungvatnah a thai n'dang uh,
\q1 Ma mih duemnah hnin ah.
\q1 Muei hla ka yoethennah ham,
\q1 duemnah hmuen te m'pha uh.
\q1 Pa Capa neh Cim mueihla
\q1 thangthen sak uh lah sih.
\q1 Thum soep pakhat nang bueng te,
\q1 na hlangboel loh n'koeh saeh.
\c 200
\s1 Duem Hnin Boeipa
\s2 Lord Of Sabbath
\sp Doh is Bb
\q1 
\v 1 Duemhnin boeipa,
\q1 ti hnin na mah im khui ah ka kun uh.
\q1 Ka ol kan neh laa ka sak he khaw
\q1 uem om hmueih la ha luei hang saeh.
\q1 
\v 2 Dik lai hman kah,
\q1 duem hnin bangla a tloe vaan ah om pueng,
\q1 Te a tah pa tang palai lungnat
\q1 mikphibo nah omvoelpawh.
\q1 
\v 3 Tawnba ngaihlih om voelpawh,
\q1 tholh neh hel hmuen om voelpawh.
\q1 Rhungrhah rhah khaw omngaihnah laa la om tih,
\q1 nguekcoi na khaw dim coeng.
\q1 
\v 4 Puen pa tuen ol om voel pawh,
\q1 dueknah khaw rhihnah om pawh.
\q1 Ihsap sap yinmang lakuengnah n'caeh tak ni,
\q1 Pathen ah n'duem pawn ni ni.
\c 201
\s1 Aw Ka Mueihla Na Khangkung Loh
\s2 I Will
\sp Doh is A
\q1 
\v 1 Aw ka mueihla
\q1 na khang kung loh tahae,
\q1 a yoe la ol a thui.
\q1 Ta hae boeipa kah lungnah ol ka thui,
\q1 namah ni kan doe coeng.
\q2 \qt Kan tang nah kan tang \qt*
\q2 \qt nah nang loh nan bom atah, \qt*
\q2 \qt nang kan tang nah \qt*
\q2 \qt Na thii phu tlo \qt*
\q2 \qt neh nan lai na cim sak, \qt*
\q2 \qt Na mah ni kan tang nah.\qt*
\q1 
\v 2 Na lung vat nah,
\q1 na rhennah ka doe coeng.
\q1 Ka ko ah lungnah bae.
\q1 Aw Khrih nang dong ah
\q1 ni tangnah ka khueh,
\q1 nang bueng ni kan uep nah.
\q1 
\v 3 Ka vawtthoeknah
\q1 na ming aw ka boeipa .
\q1 ka pam ka dah nah khaw,
\q1 Nang taeng ah ni thaomnah ka tlap he,
\q1 Boeipa nang loh m'pae lah.
\q1 
\v 4 Aw Boeipa na
\q1 taeng aka lo boeih loh,
\q1 bomnah ham bih vaengah,
\q1 Kan bom ni na ti nah ol te ka yaak.
\q1 Te bueng te ni ka poek.
\c 202
\s1 Aw Omngaihnah Hnin Te
\s2 O Happy Day
\sp Doh is G
\q1 
\v 1 Aw om ngaihnah hnin te ka khueh,
\q1 khangkung Pathen namah taeng ah.
\q1 Ta hae ah kai loh kohoe la
\q1 hlang tom boeih taengah thui ka ngaih.
\q2 \qt Omngaih hnin omngaih hnin\qt*
\q2 \qt Jesuh ka tholh a silh nah hnin,\qt*
\q2 \qt Thang thui nah a mah loh tukkil\qt*
\q2 \qt Khohnin rham hnin ah omngaih sak \qt*
\q2 \qt omngaih hnin omngaih hnin\qt*
\q2 \qt Jesuh ka tholh a silhnah hnin.\qt*
\q1 
\v 2 Ti hnin ah tah bi tung bawt coeng,
\q1 Boeipa kai ham a hlang kai ni.
\q1 Amah mawtnah kung ah ka bang,
\q1 A khuenah ben la ka mael coeng.
\q1 
\v 3 Ka ngai dip coeng ka ko khui ah,
\q1 kobawtnah ah ngai mongnah soep.
\q1 Me vaeng khaw caeh tak ka ngaih pawh,
\q1 Boeipa nen tah soeprhaep boeih then.
\q1 
\v 4 Ka ol khueh Pathen loh a yaak,
\q1 Hnin ta kuem he ol a cak sak.
\q1 Ka hing nah kho hnin loh bawt tih,
\q1 ka duek due la ka omngaih ni.
\c 203
\s1 Hnin Takuem Ka Lungbuei
\s2 Once For All
\sp Doh is Bb
\q1 
\v 1 Hnin takuem ka lungbuei khui ah Jesuh didip ta aep.
\q1 A mikhmai tah mincang khosae then lakah khaw then ngai.
\q1 A mah tah taaep taaep then ngai hnin takuem mai ah.
\q2 \qt Te vaeng ah he lak ah \qt*
\q2 \qt ta aep ta aep then ngai bal pueng\qt*
\q2 \qt A vang a thal ca khaw m'ming pawh.\qt*
\q2 \qt Rhal vang kho puei ke, \qt*
\q2 \qt A mah te hae ka lak ah \qt*
\q2 \qt a then la m'hmuh ta aep ni. \qt*
\q1 
\v 2 Hmuen hla lamkah long khaw a boeilennah neh n'kue yoe yah.
\q1 Dan ngaih thak va, thui pa ai si lak ah sawt ngaih loh rhoep.
\q1 Ka kongaih a soep sak lol mang ni ka taeng van ngawn coeng.
\q1 
\v 3 Om dam yut hno bung ko phoeh na vaengah tuk cawt nan n'duel.
\q1 Lung ma ka lam tih ngai a hmang vaengah rhang dongah m'pom.
\q1 Ka tholhnah boeih phuei kung Jesuh ke ta aep ka lungnah.
\c 204
\s1 Ka Khangkung Ka Hmuh Pawt Cakhaw
\s2 I Know His Voice
\sp Doh is Ab
\q1 
\v 1 Ka khangkung ka hmuh pawt cakhaw,
\q1 hnin ta kuem kai taeng ol han thui.
\q1 Amah te ni ka tuek coeng tih,
\q1 Boeipa ka koeh a ol ka yaak.
\q2 \qt A ol ka yaak ka khangkung ol.\qt*
\q2 \qt Ka ko khui ah omngaihnah m'paek.\qt*
\q2 \qt A ol then te kai taeng han thui \qt*
\q2 \qt boeipa koeh lah a ol ka yaak. \qt*
\q1 
\v 2 A muei te ka hmu pawt cakhaw,
\q1 hlipuei lakah a ol ka yaak,
\q1 A mah loh tui phu a duem sak,
\q1 kho sae then te a tueng sak coeng.
\q1 
\v 3 Ol tak ol dueng kai ham han thui,
\q1 omngaih ngai mongnah ol then te,
\q1 Lungnah rhoepnah ol han thui tih,
\q1 vaan im then kawng khaw han thui bal.
\c 205
\s1 Hingnah Buh Kai Pae Lah
\s2 Breat Thou The Bread Of Life
\sp Doh is Eb
\q1 
\v 1 Hing nah buh kai m'pae lah lung nah boeipa ,
\q1 Tui tun kaeng kah buh na paek uh bangla,
\q1 Hmuen cim ben a voel ah nang bueng kan tlap,
\q1 Ka mueihla loh nang n'ngaih aw hingnah ol.
\q1 
\v 2 Namah loh yoe then m'pae lah ka boeipa ,
\q1 Kalali ah yoe then na paek bangla,
\q1 Kuel rhui loh boeih pat saeh,
\q1 hloong tung bung saeh,
\q1 Ngai mongnah soep rhaep te ka hmuh pawn ni.
\q1 
\v 3 Nang bueng ni hingnah buh aw ka boeipa,
\q1 Na olcim oltak loh kai te n'khang coeng.
\q1 Soben kah hingnah buh, te kai m'pae lah,
\q1 Nang kan lung na ham lungnah n'cang puei lah.
\q1 
\v 4 Ka taeng ah Cim Mueihla m'pae lah boeipa,
\q1 Ka hmuh naham ka mik han tueng sak saeh.
\q1 Na oltak olhuep te, kai n'tueng lah saeh,
\q1 Na cabu dong ah nang kan hmuh boeipa.
\c 206
\s1 Ka Tholh Bang Nim A Cim
\s2 Nothing But The Blood Of Jesus
\sp Doh is G
\q1 
\v 1 Ka tholh bang nen nim a cim
\q1 Jeuh thii bueng ni a ka cim
\q1 Bang nen nim ka cimcaih ve,
\q1 Jesuh thii bueng ni a ka cim
\q2 \qt Aw thiisen cim koek loh\qt*
\q2 \qt vuelsong bang la m'bok sak.\qt*
\q2 \qt Thiisen tloe ka ming pawh\qt*
\q2 \qt Jesuh thii bueng ni a ka cim.\qt*
\q1 
\v 2 Ka kah tholh rhen nah ham la,
\q1 Jesuh thii bueng ni a ka cim
\q1 Kai loh ka cim nah ham la,
\q1 Jesuh thii bueng ni a ka then.
\q1 
\v 3 Ka tholh yueng ah ueh ham la,
\q1 Jesuh thii bueng ni aka then,
\q1 Ka yueng moei then nah sai ham,
\q1 Jesuh thii bueng ni a ka then.
\q1 
\v 4 Ka ngaiuep ko mong na ham
\q1 Jesuh thii bueng ni a ka then,
\q1 Kai loh ka dueng na hamla,
\q1 Jesuh thii bueng ni a ka then.
\c 207
\s1 Ka Hingnah Nang Kan Paek
\s2 I Gave My Life For Thee
\sp Doh is C
\q1 
\v 1 Ka hingnah nang kan paek
\q1 nang hamla thii ka long sak.
\q1 Nang kan tlannah hamla
\q1 dueknah lamkah koep ka tho.
\q1 Nang ham lam ni hing lu ka voeih,
\q1 Kai ham bang nim na voeih.
\q1 
\v 2 Kum sen hlang nang ham la
\q1 kai loh kho daeng nah ka ming,
\q1 Nang loh dungyan duela
\q1 omngaihnah ka dang na ham.
\q1 Nang hamla kum sen hlang ka hmoel,
\q1 Hnin at talh nan hmoel a?
\q1 
\v 3 A pa kah im then neh,
\q1 A boeilennah ngolkhoel ke,
\q1 Nang ham kan caeh tak tih,
\q1 kho daeng pa tangnah ka khang,
\q1 Te rhoek boeih nang ham kan caeh tak,
\q1 Bang nim nan caeh tak van?
\q1 
\v 4 Nang ham kho daeng ka ming,
\q1 ol neh ka thui thai lek pawh.
\q1 Ko pangnah neh rhahnah,
\q1 dueknah hell lam kah kan hlawt.
\q1 Nang ham kho daeng pa tang ka khang,
\q1 Kai ham bang nim nan phueih?
\c 208
\s1 Boeipa Nang Kan Bawk Uh
\s2 In Rememberance Of Me
\sp Doh is D
\q1 
\v 1 Boeipa nang kan bawk uh,
\q1 lung vatnah ko poek rhai,
\q1 te lungvatnah loh ti hnin due n'khoem.
\q1 Na thennah ka koeh uh,
\q1 Na mah kah hmai ah.
\q1 Kai mih lungbuei boeih
\q1 ka kuep vaeng lungnah ha cak.
\q2 \qt Na mah kah phung dueng \qt*
\q2 \qt bang la tihnin kho a he,\qt*
\q2 \qt na buh te tun ah ka vael uh coeng,\qt*
\q2 \qt kai ming rhoek taeng ah,\qt*
\q2 \qt na thui ka poek uh tah \qt*
\q2 \qt “Kai poek koep na la” na ti te.\qt*
\q1 
\v 2 Nan paek hingnah vaidam,
\q1 cak ham ka koih moenih,
\q1 A bo a rhae te coi ham lam khaw.
\q1 Nang na thennah rhang neh,
\q1 na buh ka vael uh.
\q1 Kai mih hamla rhennah
\q1 kho te khaw nan poek coeng.
\q1 
\v 3 Tha dueng thai huel uh sih,
\q1 hing nah thai khueh uh sih,
\q1 Tangnah mik neh dan uh si lamtah,
\q1 Koep ha rhum thuk duela,
\q1 tueng sak uh lah sih,
\q1 Boeilennah neh duemnah
\q1 hmuen m'pha due tueng sak sih.
\c 209
\s1 Lungnah Boei Kopoekrhai Lungvatnah
\s2 Grace Greater Then Our Sin
\sp Doh is G
\q1 
\v 1 Lungnah boei kopoekrhai lung vatnah,
\q1 tholh dalh sainah boeih lak ah len ngai.
\q1 Kal va ri tlang ah ke ha thoeng tih
\q1 ke hmuen ah tuca thi te ha long.
\q2 \qt Pathen lungnah, \qt*
\q2 \qt Tholhnah boeih rhen na neh cim sak nah. \qt*
\q2 \qt Pa then lungvatnah, \qt*
\q2 \qt Lung vat nah tholhnah lak ah len ngai.\qt*
\q1 
\v 2 Tholh neh ko bawt nah tui phu tho tih,
\q1 ka mueihla loh hma ta tom cakhaw,
\q1 A lung vatnah len toengtoengbal tih,
\q1 a thing lam dongah ka thuh ka ying.
\q1 
\v 3 Tholh boeng ha ngo he n'thuh thai pawt he,
\q1 a balongnim a cim sak thai eh,
\q1 So lah ke hmuen ah tui cim ha long,
\q1 ti hnin vuelsong lakah boknah ham.
\q1 
\v 4 Ka bawt mueh ko poek rhai lungvatnah,
\q1 Aka tangnah a yoe la a paek.
\q1 Nang mih amah aka rhing oel rhoek,
\q1 Ta hae a lung vatnah lo uh lah.
\c 210
\s1 Jesuh Kho Kungah
\s2 Sitting at the Feet of Jesus
\sp Doh is F
\q1 
\v 1 Jesuh kho kung ah kai ka ngol,
\q1 a ol ding te ka yaak coeng.
\q1 Lung vat sit lohnah ol ding ni,
\q1 hnin ta kuem ah ka ngai hlang.
\q1 Boei Jesuh kho kung ah ka ngol,
\q1 hnuk sul kong hu te ka poek.
\q1 A lungvatnah loh tlo tang kik
\q1 Ka lungbuei khuiah rhaehrhong.
\q1 
\v 2 Boei Jesuh kho kung ah ka ngol,
\q1 om thennah hmuen tloe om pawh.
\q1 Ka hno rhih boeihboeih ka haal nah,
\q1 Ka duemdong nah hmuen la om.
\q1 Jesuh ka kho kung ah ka duem,
\q1 Ka kuek ka ngoenah boeih neh,
\q1 Ka bih ka hoenah boeih te m'paek.
\q1 M'paek mueh he om tlaih moenih.
\q1 
\v 3 Khang kung boei na ol thangthen neh,
\q1 tahae ah kai m'bom ngai lah.
\q1 Nang ngai nah mik te n'khueh sak lam,
\q1 na maelhmai then kai m'hmuh sak.
\q1 Na cimcaihnah ka khueh na ham,
\q1 na lungbuei te kai m'pae lah.
\q1 Na mah bangla ka then na ham,
\q1 na lung buei te kai m'pae lah.
\c 211
\s1 Hlipuei Hliphoei Khui Neh
\s2 From Every Stormy Wind
\sp Doh is C
\q1 
\v 1 Hli puei khohli hliphoe khui neh,
\q1 Ko thae tui phu khui lamkah loh,
\q1 Dingsuek la duemnan then te om,
\q1 Lungvatnah ngol khoel hmui ah te.
\q1 
\v 2 Jesuh kah muei hlip hmui atah,
\q1 omngaihnah situi neh n'suep uh.
\q1 Diklai hmuen boeih lakah then ngai,
\q1 Jesuh kah rhennah ngolkhoel ah.
\q1 
\v 3 Muei hla thik at la pongpanah,
\q1 Baerhoep neh tunnah hmuen atah,
\q1 Palang kol la tangnah thikat
\q1 , Lung vatnah ngolkhoel taengvai ah.
\q1 
\v 4 A tha bangla ti ah n'lam ni,
\q1 Tholh ko thae nah om tlaih voelpawh.
\q1 Mamih mueihla hum tun pawn ni,
\q1 Lungvat ngolkhoel n'khuk uh vaengah.
\c 212
\s1 A Lungnah Cangti Then
\s2 Bringing in the Sheaves
\sp Doh is C
\q1 
\v 1 A lungnah cangti then, min cang hi ah tuh lah,
\q1 Kho thun ah m'bi bang la hlaem ben a khaw bi,
\q1 A hmin tue n'rhing bang la, ah na tue te lam tawn,
\q1 omngaih la m'voei pawn ni, cang pa pawn doe ah,
\q1 Cang pa pawn doe ah cang pa pawn doe ah,
\q1 omngaih la m'voei pawn ni cang pa pawn doe ah,
\q1 Cang pa pawn doe ah cang pa pawn doe ah,
\q1 omngaih la m'voei pawn ni cang pa pawn doe ah
\q1 
\v 2 Khosae a khaw tuh lah, a khup a khaw tuh lah,
\q1 Khosik khaw ueh lam tah muei yal khaw rhih boeh,
\q1 Coi tue a pha vaeng ah, bi bi te khaw bawt ni.
\q1 omngaih la m'voei pawn ni, cang pa pawn doe ah,
\q1 Cang pa pawn doe ah cang pa pawn doe ah,
\q1 omngaih la m'voei pawn ni cang pa pawn doe ah,
\q1 Cang pa pawn doe ah cang pa pawn doe ah,
\q1 omngaih la m'voei pawn ni cang pa pawn doe ah
\q1 
\v 3 Rhah doe ah cet lam tah Boeipa hamla tuh lah,
\q1 Pa taang na neh koo pang na loh m'pha ca khaw,
\q1 Ko thae a bawt vaeng ah, Boeipa mah loh n'doe ni,
\q1 omngaih la m'voei pawn ni, cang pa pawn doe ah,
\q1 Cang pa pawn doe ah cang pa pawn doe ah,
\q1 omngaih la m'voei pawn ni cang pa pawn doe ah,
\q1 Cang pa pawn doe ah cang pa pawn doe ah,
\q1 omngaih la m'voei pawn ni cang pa pawn doe ah
\c 213
\s1 Hnatun Tudawnkung Ol
\s2 Bring Them In
\sp Doh is Ab
\q1 
\v 1 Hnatun tudawnkung ol ka yaak.
\q1 rham rhae neh kho yin na khui ah.
\q1 Tuping lak lamkah a ka poeng
\q1 tu hma te a khue khing la om.
\q1 
\v 2 U long lae tu dawn a bom eh,
\q1 tuhma te tlap uh puei van lah.
\q1 Kho sik khui lamkah pakhat talh,
\q1 u longlae han lo puei lah eh.
\q1 
\v 3 Rham rhae ah pang ol te ya lah,
\q1 Tlang som mol voel boeih boeih a khaw,
\q1 Boeipa loh a thui he ya lah,
\q1 Cet ka tu te ha tlap uh lah.
\q2 \qt Han lo puei han lo puei\qt*
\q2 \qt tholhnah hmuen lam kah han lo puei.\qt*
\q2 \qt Han lo puei han lo puei\qt*
\q2 \qt Jesuh taeng ah te han lo puei.\qt*
\c 214
\s1 Duemnah Ram Then Ka Hmuh
\s2 We'll Work Till Jesus Come
\sp Doh is F
\q1 
\v 1 Duemnah ram then ka hmuh sut ke
\q1 me vaeng nim ka pha ve.
\q1 Me vaeng nim rhalpho ka dul ve,
\q1 Rhal thal la ka om ve.
\q2 \qt Jesuh ha rhum due la bi uh,\qt*
\q2 \qt ha lo duela a bawt vaeng ah\qt*
\q2 \qt lum ah om u pawn ni. ng'om ni. \qt*
\q1 
\v 2 Lai ah omngaih ngaimong ko hoe
\q1 nah long he soep thai pawh.
\q1 Lai he pa tang rhungrhahnah ni
\q1 He lai ka im moenih.
\q1 
\v 3 Jesuh taeng duem hamla ka cet,
\q1 ka ngai koep ham mong sak
\q1 A rhang dongah ka hangdang tih,
\q1 a im then la n'caeh puei.
\q1 
\v 4 Khang kung ka taeng a om vaeng ah,
\q1 kho kan ka taeng phael pawh.
\q1 Tuiphu lakah ka thin om coeng,
\q1 im then ka pha pawn ni.
\c 215
\s1 Hnatun Boeipa Loh
\s2 The Master's Call
\sp Doh is Ab
\q1 
\v 1 Hna tun boeipa loh ta hae n'khue li,
\q1 a lo cang ah ham la,
\q1 Lo hmuen cangvuei loh aengnoi boeih coeng,
\q1 Cangat kung hlang om pawh.
\q2 \qt Cet uh a lung na a rhen na neh,\qt*
\q2 \qt Boeipa ming neh cet uh\qt*
\q2 \qt Khangnah a yoe paek omngaihnah he\qt*
\q2 \qt paeng tom ah thui uh lah.\qt*
\q1 
\v 2 Cet lam yin khui kah hlang hma te tlap
\q1 lam tah koep hlawt uh lah.
\q1 Amih rhoek boeih te han bom lamtah
\q1 kuelrhui boeih bawt pa uh.
\q1 
\v 3 Khodaeng lungma te omngai puei
\q1 lungnah buh loei te tael pah
\q1 Dungyan hingnah buh te vael ham la
\q1 amih te han khue lah.
\q1 
\v 4 Ta hae a tue a om vaeng ah cet,
\q1 a tue a bawt hlan ah,
\q1 A tue bawt na loh m'phae vaeng ah tah
\q1 bi u thai voel mahpawh.
\c 216
\s1 Tholhnah Lo Lakli Kah Cangvuei
\s2 Where Are The Reapers?
\sp Doh is G
\q1 
\v 1 Tholhnah lo lakli kah cangvuei then mai,
\q1 Aka coi kung te melam nim a om.
\q1 Ol tak vin hat neh bibi sai uh sih.
\q1 Thai dii khuila n'hlak duela duem boel sih.
\q2 \qt Cang at la u nim a ka lo eh? \qt*
\q2 \qt Thaidi khui kah omngaih cang koei nah hmuen ah, \qt*
\q2 \qt U long m'bom uh eh cang vuei coi ham, \qt*
\q2 \qt Tholh nah lo hmuen kah cang vuei coi ham.\qt*
\q1 
\v 2 Longtaeng longvai ah khaw boeih tlap uh sih,
\q1 Lota loh a thing dae cangvuei om pueng.
\q1 Long puei caeh tung akhaw boeih tlap uh sih,
\q1 Thai dii khuila boeih ah khuen uh lah sih.
\q1 
\v 3 Hmuenlung cangkung long tah aengnoi boeih coeng,
\q1 Dik lai loh cangah tue te a lamtawn.
\q1 Bi bi loh pung tih cangat hlang loh yol.
\q1 A ko ngai long tah hmata boeih pawn ni.
\q1 
\v 4 Hlang ca pa rhoek na vin han khuen uh lah,
\q1 A sui cangtham thai di khuila khuen uh,
\q1 Boeipa ha lo duela a then la bi.
\q1 Cang ah bawt ah omngaih uh hmaih pawn ni.
\c 217
\s1 Lo Khuiah Cang Ah Ham
\s2 Labour On
\sp Doh is Bb
\q1 
\v 1 Lo khui ah cang ah ham a om vaengah,
\q1 Aka at hamla cang at hlang yol ca,
\q1 Bi bi kung rhoek loh boeipa khue ol ya,
\q1 Tihnin ah amah loh n'khue coeng.
\q2 \qt Tha huel uh tha huel uh \qt*
\q2 \qt omngaih thahlue la ngai uep,\qt*
\q2 \qt Boeipa loh thaomnah kan paek ni a ti,\qt*
\q2 \qt Kho a tlak duela bi sai uh. \qt*
\q1 
\v 2 Khai thai di khuiah cang bae sak uh lah,
\q1 omngaih tha lue tha hmae cala bi uh.
\q1 Kho yin khotlak due boeipa bi bi uh,
\q1 Ol tak tang neh bi yoeyah uh.
\q1 
\v 3 Long puei caek cakhaw omngaihnah loh yet,
\q1 Bi bi pa tang tih kho ling tlo cakhaw
\q1 A tuek hlang boeih neh boeipa omngaih ni,
\q1 khoyin na te a bawt vaengah.
\q1 
\v 4 Vaan dong thaidi khuiah omngaihnah soep,
\q1 bi bi tlo tih pa tang hlang loh a pang,
\q1 Boeipa lungnah ol loh a pai vaengah,
\q1 dungyan hingnah te m'pang pawn ni.
\c 218
\s1 Vaan Dong Khopuei Omthen Kho Ke
\s2 Will There Be Any Stars?
\sp Doh is A
\q1 
\v 1 Vaan dong kho puei omthen then kho ke ka poek tihnin,
\q1 Khotlak vaeng ah ka caeh nah kho ke,
\q1 Ka khang kung kah ko poek rhai a lungnah dong ah
\q1 Boeilen lu muek ai si om coi nim.
\q2 \qt Boeilen lu muek ai si om coi nim\qt*
\q2 \qt Diklai dong ka hing nah kho hnin a khum vaeng ah,\qt*
\q2 \qt Dungyan ka duem na im then ka pha puk vaeng ah\qt*
\q2 \qt thangthen nah kai hamla om coi nim.\qt*
\q1 
\v 2 Boeipa taeng thang thui tih ngai uepnah he bih uh,
\q1 Muei hla tu kung hamla ka om ni,
\q1 Thang then boeilen ai si ka khueh puk vaengah tah
\q1 koehnah ol tui li ol la hum ni.
\q1 
\v 3 Boeipa muei ka hmuh vaeng ah ka om ngaihnah te,
\q1 A kho kung ah lungbok ka khueh ni,
\q1 A then sui kho puei ah omngaih laa ka sa ni
\q1 Boeilen lu muek kai ham om na ah.
\c 219
\s1 Balae Na Rhing Manuca
\s2 Why Do You Wait, Dear Brother?
\sp Doh is A
\q1 
\v 1 Balae na rhing manu ca?
\q1 Ba lae na poek yulh ka puei aw?
\q1 ma mih khangkung boeipa long n'rhing ta.
\q1 Omnah hmuen te paek ham a ngaih.
\q2 \qt Bakong Bakong ah\qt*
\q2 \qt a taeng na lo pawh\qt*
\q2 \qt Bakong bakong\qt*
\q2 \qt ah a taeng na lo pawh.\qt*
\q1 
\v 2 Balae na uelh ka paya
\q1 Hmai long ham Ba lae na ngai uep?
\q1 Jesuh mueh tah khangkung tloe om pawh
\q1 A mah mueh tah longpuei om pawh.
\q1 
\v 3 Nang na ngaihlih moenih a?
\q1 Na khui ah Cim Mueihla tat te
\q1 Khangnah he bakong ah na doe pawh
\q1 Na tholh hnorhih aka voei ke
\q1 
\v 4 Balae na rhing manuca?
\q1 Cang ah tue long tah khum boeih coeng.
\q1 Na khang kung loh yoe then paek ham n'rhing
\q1 Na uelh a tah na duek pawn ni.
\c 220
\s1 Thohkah Khoekkung U Lae?
\s2 Knocking, Knocking, Who is There?
\sp Doh is Eb
\q1 
\v 1 Thohka khoek kung ke ulae
\q1 rhing lah ko poek rhaila om.
\q1 He kah yin cet tah boeipa ni.
\q1 Anih tah ka hmuh noek pawh
\q1 Muei hla omngaih sak kung la om,
\q1 Thoh na ong mahpawt aya?
\q1 
\v 2 Thoh a khoek tih he ah pai
\q1 Nang te khing n'rhing poek uh lah
\q1 Tedae thoh ong ham bahoeng rhai.
\q1 Rhui sun kha ban hoeng la om.
\q1 Hlingpup loh a thing muelh dongah
\q1 Thoh ong hamla ba hoeng rhai?
\q1 
\v 3 Tahae due la a khoek pueng
\q1 A cim a caih la n'rhing pueng
\q1 Cai ngo kut neh a khoek li pueng.
\q1 Hling lumuek te a muek dae
\q1 A mik hmai tah hlampan bal pueng
\q1 Khangkung boei loh nang rhing pueng.
\c 221
\s1 Tihnin Khangkung Loh n'Khue
\s2 Today The Saviour Calls
\sp Doh is F
\q1 
\v 1 Tihnin khangkung loh n'khue
\q1 long hmang rhoek aw
\q1 Na mueihla te hma ve
\q1 tholh sai voelboeh.
\q1 
\v 2 Tihnin khangkung loh n'khue
\q1 hna tun uh lah,
\q1 A pangbueng cim taengkah
\q1 Jesuh bawk sih.
\q1 
\v 3 Ti hnin khangkung loh n'khue
\q1 ying na tlap lah,
\q1 Olcaek nah kho lo hli
\q1 dueknah yoei coeng.
\q1 
\v 4 Ti hnin Mueihla loh n'khue
\q1 a taeng kun lah,
\q1 Kothae nah boeih voei lah,
\q1 rhennah tue ni.
\c 222
\s1 Ha Bal Koep Loeih Saw Nang Hlang Hma Pata
\s2 Tenderly Pleading
\sp Doh is G
\q1 
\v 1 Ha bal koep loeih saw nang hlang hma pata,
\q1 tu dawn then ka khue ol hnatun van lah.
\q1 Khang hamla nang n'tlan cim sak hamla n'rhing,
\q1 hampan yue laeh saw uelh tlaih voel mueh la.
\q2 \qt A lung nah kodo olding loh nang n'khue\qt*
\q2 \qt Boeipa Jesuh ol ding hnatun lah,\qt*
\q2 \qt A taeng yue pan hamla nang te n'coep.\qt*
\q1 
\v 2 Kum sen hlang khui nang na hma bal cakhaw,
\q1 Boeipa loh nang rhing ba dong ah na hma,
\q1 A thii neh tlan tangtae lam ni na om,
\q1 A rhen lungnah tah ol neh n'thui lek pawh.
\q1 
\v 3 A lung vat nah ol uen te hnatun lah,
\q1 Boeipa nang tholh ham duek thinglam dong ah,
\q1 Tholh rhen nah soeprhaep dungyan hingnah te,
\q1 Moeithen nah a sai tih mamih te m'paek.
\q1 
\v 4 Longpuei dueng neh oltak te ham vai lah,
\q1 Jesuh tu thohka khui ah ha kun lah,
\q1 Tudawn then hlang kodo olding neh n'khue,
\q1 Ka kun van lah dungyan hingna ham la.
\c 223
\s1 Ol Boeih Lakah Ol Tui Koek
\s2 Come!
\sp Doh is D
\q1 
\v 1 Ol boeih lak ah ol tui koek,
\q1 A olkhueh long tah cak
\q1 A olkhueh boeih khaw soep tih,
\q1 dangcingdangvoei la om.
\q1 Lungnat neh kohoe a khaw,
\q1 uepvawt muei rhih a khaw,
\q1 Jesuh khue ol ka yaak tih,
\q1 Thinglam kung lam te ka cet.
\q2 \qt Halo ka taeng ah, Ha lo ka taeng ah,\qt*
\q2 \qt Thin rhih patang rhoek ka taeng ah ha lo uh\qt*
\q2 \qt Ha lo ka taeng ah ha lo Ha lo ka taeng ah, \qt*
\q2 \qt Thin rhih patang rhoek ka taeng ah halo uh.\qt*
\q1 
\v 2 Hlang boeih bang a lae na poeng,
\q1 Ke paya taeng lam kah,
\q1 Voeh voeh voeh voeh yoei lam tah,
\q1 a taeng ah phueih om lah.
\q1 Aw kai mang daeng mang tok he,
\q1 hlangtholhpadalh koek he
\q1 Ka pam ka dah khing coeng dae,
\q1 koep ah ka bal koep bal coeng.
\q1 
\v 3 A tue long ha yoei ca coeng,
\q1 Tlek ha lo mai thai coeng,
\q1 Olding neh n'voem n'toei uh te,
\q1 a taengla yoei mai lah,
\q1 Tui rhal moldong tlang hlaep boeih,
\q1 a yoei a hla ka boeih,
\q1 Na kut ah kan mawt uh ni,
\q1 olding neh ha lo a ti.
\c 224
\s1 Khangkung Taengah Uelh Mueh La Halo
\s2 Come To The Saviour
\sp Doh is Bb
\q1 
\v 1 Khang kung taengah uelh muehla ha lo
\q1 Bai bal ca loh long puei te hmuh sak,
\q1 Ti hnin ma mih taengah Jesuh om,
\q1 Ol ding neh ha lo ti.
\q2 \qt Tholhnah thinko boeih a cim vaengah,\qt*
\q2 \qt ma mih boeih omngaih la n'tun uh ni.\qt*
\q2 \qt Khangkung taeng ah boeih n'tun uh pawn ni,\qt*
\q2 \qt dung yan im then khui ah.\qt*
\q1 
\v 2 Jesuh loh ca moe ha lo a ngaih,
\q1 Tihnin ah hlang boeih omngaih uh saeh.
\q1 Boeipa Jesuh amah tu uh sih.
\q1 Uelh boeh ha lo u laeh.
\q1 
\v 3 Tihnin mamih taeng ah Jesuh om.
\q1 A then la Pathen ol hnatun uh.
\q1 A kodo ol ding khuenah ol loh,
\q1 ka ca ha lo a ti.
\c 225
\s1 Pathen Loh N'Khue
\s2 God Is Calling Yet
\sp Doh is Bb
\q1 
\v 1 Pathen loh n'khue na ya hlan a?
\q1 lai om then na a ka tuk khak,
\q1 Hing he me vaeng nim ka poeng van ve,
\q1 Ka ih ko long khaw tui van ve nim.
\q2 \qt N'khue coeng hna tun mai lah,\qt*
\q2 \qt N'khue coeng aw hna tun lah,\qt*
\q2 \qt Pa then loh n'khue hna tun van lah,\qt*
\q2 \qt n'khue li n'khue li,\qt*
\q2 \qt N'khue li hnatun van lah,\qt*
\q2 \qt N'khue li hnatun van lah,\qt*
\q2 \qt Pathen loh n'khue li coeng \qt*
\q2 \qt hnatun van mai lah.\qt*
\q1 
\v 2 Pathen khuenah hnatun muehla,
\q1 kai loh ka mang thong tak aya?
\q1 N'lungvatnah ka sah thai van aya?
\q1 Amah loh n'khue pueng ka uelh aya?
\q1 
\v 3 Pathen khuenah ka ming mueh la,
\q1 Ka lung buei thohka khaih a ya?
\q1 Amah loh tho ka a khoek li pueng,
\q1 A Mueihla ko ka thae sak a ya?
\q1 
\v 4 Pathen khuenah ka aal mah pawh
\q1 Kho hnong ka buh sak voel mahpawh.
\q1 A mah bueng te kai loh ka rhingoel.
\q1 Ka hinghang due amah loh kai n'khue.
\c 226
\s1 Jesuh Loh a Khoek
\s2 Open Wide the Door
\sp Doh is Db
\q1 
\v 1 Jesuh loh a khoek tih n'khue,
\q1 pa tang hlang ha lo uh lah,
\q1 Amah bueng khang kung la om,
\q1 thoh ka ong pa lah.
\q2 \qt Thoh ka ong lah.\qt*
\q2 \qt Aw thoh ka ong lah,\qt*
\q2 \qt A mah bung long n'khang thai eh.\qt*
\q2 \qt Aw thoh ong lah. \qt*
\q1 
\v 2 Jesuh loh a khoek tih n'khue,
\q1 A hingnah te nang m'pek tih,
\q1 Amah loh saelkhui a noeng,
\q1 thoh ka ong pa lah.
\q1 
\v 3 Jesuh loh a khoek li pueng,
\q1 Na lungbuei a taengla hong.
\q1 Om ngaihnah ham bae sak ni,
\q1 thoh ka ong pa lah.
\c 227
\s1 Im La Nang Na Lo Aya?
\s2 Are You Coming Home Tonight
\sp Doh is Ab
\q1 
\v 1 Im la nang na lo a ya? tholh longhmang khui lamka loh.
\q1 Tholh him bai neh kho khaem la kueng lama na om eh?
\q1 Na him bai cim na Jesuh thi na tlam mahpawt a ya?
\q1 Ol kam na uepnah moenih a? im la nang na lo a ya?
\q2 \qt Tu hlaem im la na lo ham?\qt*
\q2 \qt Tu hlaem im la na lo ham?\qt*
\q2 \qt Jesuh taeng ah im la nang \qt*
\q2 \qt J tu hlaem im la na lo ham a?\qt*
\q2 \qt Tu hlaem im la na lo ham, \qt*
\q2 \qt Tu hlaem im la na lo ham\qt*
\q2 \qt Vaan dong a pa lung nah boeipa \qt*
\q2 \qt J im la nang na lo ham a?\qt*
\q1 
\v 2 Im la nang na lo a ya? So Boeipa long nang n'rhing ke,
\q1 Ha lo laeh uelh tlaih voelboeh kho ba hoeng sa coeng ke.
\q1 Na lo tih amah kah n'khang ham te na ngaih moenih a?
\q1 Amah loh nang n'khue li vaengah, im la nang na lo a ya?
\q1 
\v 3 Im la nang na lo a ya? Tholh hno a ka rhih rhoek nang.
\q1 Kawt poeng ah pai sut muehla ha lo lamtah kun laeh.
\q1 A ol kam te thaana boeh amah te duem uepnah lah.
\q1 Jesu loh ha lo a ti te im la nang na lo a ya?
\c 228
\s1 Khangkung Boei Ol Ka Yaak
\s2 I Hear The Saviour Say
\sp Doh is Eb
\q1 
\v 1 Khangkung boei ol ka yaak,
\q1 na tha khueh loh yol sut,
\q1 Thahnoeng ca loh kan bih,
\q1 ka soep rhaep he han so.
\q2 \qt Jesuh loh lai ba ka khueh boeih han sah,\qt*
\q2 \qt Ka tholh thimduk mai te vuelsong bang la a bok sak.\qt*
\q1 
\v 2 Ka thennah khaw ompawh,
\q1 na lung vat na pang ham,
\q1 Kalvari thii cim neh,
\q1 cim caih la silh ka ngaih.
\q1 
\v 3 A mah rhang nen bueng ni
\q1 na hmai ah ka soep thai,
\q1 Jesuh kai ham a duek te
\q1 Ka neh koep koep ka thui.
\c 229
\s1 Tuca Im Khuiah Omnah Ham Hmuen Om
\s2 Yet There Is Room
\sp Doh is F
\q1 
\v 1 Tuca im khui ah omnah ham hmuen om pueng.
\q1 A boei alen neh hlang boeihboeih a khue.
\q1 Hmuen om hmuen om tahae ah kun van laeh.
\q1 
\v 2 Kho thaih loh khum tih khomik loh tla thuk coeng
\q1 Kho loh ha khup coeng hmai tok lam cet lah,
\q1 Hmuen om hmuen om tahae ah kun van laeh.
\q1 
\v 3 Yuloh nah im khui ah bul hamla bae coeng,
\q1 Kun uh kun uh lah a hlang rhoek boeih loh,
\q1 Hmuen om hmuen om tahae ah kun van laeh.
\q1 
\v 4 Bae sak bae sak Jubilee im khui ah ke,
\q1 A loe la lo lah nang ham hmuen om pueng.
\q1 Hmuen om hmuen om tahae ah kun van laeh.
\q1 
\v 5 A hmuen om pueng thoh ka khaw a ong li pueng.
\q1 Lungnah thoh a ong a tue khaw om pueng.
\q1 Hmuen om hmuen om tahae ah kun van laeh.
\c 230
\s1 Nang Tholh aka Phuei Jesuh Ham
\s2 Have You Any Room For Jesus?
\sp Doh is Bb
\q1 
\v 1 Nang tholh a ka phuei Jesuh ham,
\q1 A hmuen na khueh pa van a?
\q1 Anih loh kun ham han bih te,
\q1 na kun sak mah pawt a ya?
\q2 \qt Mang hai Jesuh ham hmuen khueh pah.\qt*
\q2 \qt a ol te hnatun uh lah,\qt*
\q2 \qt Lung buei thoh ka a len la \qt*
\q2 \qt ong lam tah amah te kun saeh.\qt*
\q1 
\v 3 Khuehtawn om then ham hmuen om dae,
\q1 Khrih tah thing ah a tai uh,
\q1 A kun nah hmuen om van aya?
\q1 nangmih lungbuei khui ah ke.
\q1 
\v 4 Jesuh ham hmuen om van a ya?
\q1 a rhennah loh nang te n'khue
\q1 Ti hnin ah khueh van mai lah saw,
\q1 Thang vuen te a poeioep ni.
\q1 
\v 5 Jesuh hmuen ta hae khueh pa laeh,
\q1 lung vat nah tue khum pawn ni.
\q1 Khang kung boei loh n'khue vaeng ah he,
\q1 uelh muehla ha lo van lah.
\c 231
\s1 Jesuh Loh Olding Neh n'Khue
\s2 Come, Sinner, Come
\sp Doh is F
\q1 
\v 1 Jesuh loh ol ding neh n'khue, nang ha lo laeh.
\q1 Nang ham ka thang thui uh vaeng nang ha lo laeh.
\q1 Ti hnin he ni khuenah tue, nang ha lo laeh.
\q1 Tihnin he ni na ming tue, nang ha lo laeh.
\q1 
\v 2 Nang na hno ba hoeng rhih a? nang ha lo laeh.
\q1 Jesuh loh ham phueih bit ni, nang ha lo laeh.
\q1 Jesuh loh nang m'poek mah pawh, nang ha lo laeh.
\q1 Jesuh tahae nang n'doe ni, nang ha lo laeh.
\q1 
\v 3 Aw a ol ding te ya lah. nang ha lo laeh.
\q1 Yoe thennah te doe van lah, nang ha lo laeh.
\q1 Jesuh loh ol ding neh n'khue nang ha lo laeh.
\q1 Nang ham ka thangthui vaeng ah, nang ha lo laeh.
\c 232
\s1 Aw Khangkung Boei Loh
\s2 Verily, Verily
\sp Doh is G
\q1 
\v 1 Aw khang kung boei loh kai ham a duek mai,
\q1 Tholhdalhnah khui lamkah loh kai n'loeih sak.
\q1 Te Pathen ca pa aka tangna tah
\q1 dung yan hingnah a khueh.
\q2 \qt Ol tak la, ol tak la nang taeng ah kan thui.\qt*
\q2 \qt Oltak la oltak la nang taeng ah kan thui. \qt*
\q2 \qt Pathen capa aka tangnah long tah \qt*
\q2 \qt dung yan hing nah a khueh.\qt*
\q1 
\v 2 Ka tholhnah boeih a pum dong ah a phueih,
\q1 Ka lai ba boeih khaw amah loh han sah.
\q1 Amah a ka tangna tah
\q1 dungyan hingnah a khueh coeng a ti.
\q1 
\v 3 Khodaeng ming vaengah amah ka uepnah,
\q1 Ka vawtvai vaengah a ol ka tangnah,
\q1 Om ngaihnah olthang Pathen ca rhoek tah
\q1 dung yan hingnah a khueh.
\q1 
\v 4 Ka koih vaih pawt dae uep vawtnah om pawh.
\q1 Amah ha lo vaengah kai n'haek mah pawh.
\q1 Amah a ka tangna loh a phong tah
\q1 dung yan hingnah a khueh.
\c 233
\s1 Thohka Kaeng Ka Pai Ke
\s2 Behold Me Standing At The Door
\sp Doh is Ab
\q1 
\v 1 Thohka kaeng ka pai ke so lah,
\q1 a khue nah ol ke hna tun lah.
\q1 Ol ding ca la hlang tholh ko ah
\q1 ka kun mai eh, kun nah kan bih.
\q2 \qt Na ko thoh kaeng ka pai so lah\qt*
\q2 \qt kan bih nah ol he han tun lah\qt*
\q2 \qt tholh patang rhoek na ko ong lah,\qt*
\q2 \qt kun nah kan bih na ko khui ah.\qt*
\q1 
\v 3 Nang hamla hling lumuek a muek,
\q1 kum sen hlang khui nang kan lamtawn,
\q1 Tholh patang neh hno rhih hlang boeih,
\q1 ka kun mai eh, kun nah kan bih.
\q1 
\v 4 A yoeyap la kan khue moe nih,
\q1 Ka kothae na he ham poek lah,
\q1 Nang kah tholh tlan ham ni ka duek,
\q1 ka kun mai eh, kun nah kan bih.
\q1 
\v 5 Nang ham vaan omngaihnah kan khuen,
\q1 Rhoepnah lungnah ngaimongnah neh,
\q1 Tholh ah hnaemtaek patang hlang rhoek
\q1 ka kun mai eh, kun nah kan bih.
\c 234
\s1 Diklai Pum He Tholhnah Dongah
\s2 The Light Of The World Is Jesus
\sp Doh is Ab
\q1 
\v 1 Diklai pum he tholh nah dong ah buek coeng dae,
\q1 Diklai vang nah tah Jesuh ni.
\q1 A boeilennah kho thun khosae bangla vang.
\q1 Dik lai vang nah tah Jesuh ni.
\q2 \qt Nang mih boeih loh vangnah la ha lo,\qt*
\q2 \qt Kho sae then ka soah ha sae coeng.\qt*
\q2 \qt Kai mik dael tahae kho koep ka hmuh, \qt*
\q2 \qt Diklai vangnah tah Jesuh ni.\qt*
\q1 
\v 2 Jesuh ah om a tah kho yin nah om pawh,
\q1 Diklai vang na tah Jesuh ni.
\q1 M'mih loh long tueng kung vangnah hnuk ah m'bang uh.
\q1 Diklai vang nah tah Jesuh ni.
\q1 
\v 3 Tholh ah om tih mik a ka dael rhoek ham la,
\q1 Dik lai vang nah tah Jesuh ni
\q1 Cet lam tah kho sae then ah sil uh van lah,
\q1 Dik lai vang nah tah Jesuh ni.
\q1 
\v 4 Vaan ah tah khosae hlavang ngoe tlaih voel pawh.
\q1 Te kah vang nah tah Jesuh ni.
\q1 Tuca noe tah sui khopuei kah hmaivang ni.
\q1 Diklai vang nah tah Jesuh ni.
\c 235
\s1 A Ong Tangtae Thohka Khuiah
\s2 The Gate A Jar For Me
\sp Doh is C
\q1 
\v 1 A ong tang tae tho ka khui ah,
\q1 Thing lam tung long tah ha vang,
\q1 Khang kung lungnah kho saeng bang la
\q1 ma mih taengah ha tueng coeng
\q2 \qt A rhen lungnah tah dung tang kik,\qt*
\q2 \qt ke thohka then kai ham a ong,\qt*
\q2 \qt kai ham kai ham kai hamla a ong coeng.\qt*
\q1 
\v 2 Khangnah aka tlap rhoek boeih ham,
\q1 A yoe la te thoh a ong,
\q1 Khodaeng kuirhang hlang yit hlang len,
\q1 Nam tom hlang boeih ham a ong.
\q1 
\v 3 Lakueng ngaihmang khodaeng rhoek ham
\q1 Rhennah thoh ka a ong pah,
\q1 Thinglam tung aka kawt rhoek ham,
\q1 dungyan lungnah tah om coeng.
\q1 Tahae thinglamtung kawt cakhaw
\q1 duek nah tuirhal ah hal ni,
\q1 Hing nah suilumuek muek vetih,
\q1 Lung nah yet taaep pawn ni.
\c 236
\s1 A Dingsuek La Boei Jesuh Loh n'Khue
\s2 Softly and Tenderly Jesus Is Calling
\sp Doh is Ab
\q1 
\v 1 A ding suek la Boei Jesuh loh n'khue uh li.
\q1 Nang neh kai he tah n'khue li.
\q1 Lungnah neh thinsennah,
\q1 n'lam tawn tih n'rhing uh.
\q1 Nang neh kai te n'lam tawn li.
\q2 \qt Im la ha lo nang patang hlang rhoek ha lo\qt*
\q2 \qt Oltak tang ol ding neh Jesuh loh n'khue li\qt*
\q2 \qt Aw hlang tholh im la ha lo.\qt*
\q1 
\v 2 Jesuh loh n'toem vaengah
\q1 bang a lae n'uelh eh.
\q1 Nang neh kai he tah n'toem li
\q1 Bang a lae a rhennah n'tha na tih n'rhing pawh.
\q1 Nang neh kai ham a rhennah.
\q1 
\v 3 Ko poekrhai lungvatnah ol a khueh sut coeng,
\q1 Nang neh kai ham ol a khueh.
\q1 N'tholh u dae amah loh n'rhen,
\q1 khaw dawk a ngai.
\q1 Nang neh kai kho dawk han ngai.
\c 237
\s1 Jesuh Loh Im La Olding Neh nKhue
\s2 Jesus Is Calling
\sp Doh is C
\q1 
\v 1 Jesuh loh im la olding neh n'khue li,
\q1 tihnin ah n'khue, Tihnin ah n'khue,
\q1 Bang a lae lung nah kho saeh na ngaih pawh.
\q1 A hla la patoeng na caeh.
\q2 \qt Ti hnin ah n'khue Ti hnin ah nkhue\qt*
\q2 \qt Jesuh loh n'khue li\qt*
\q2 \qt olding la tihin ah n'khue li.\qt*
\q1 
\v 2 Pa tang hlang duem sak ham Jesuh loh n'khue
\q1 tihnin ah n'khue Tihnin ah n'khue
\q1 A taengah na hno rhih boeih te khuen lah,
\q1 Nang te m'mangthung tak mah pawh.
\q1 
\v 3 Jesuh loh n'rhing aw tahae ha lo laeh,
\q1 tihnin ah n'rhing Tihnin ah n'rhing
\q1 A kho kung ah na tholh boeih te haal lah,
\q1 Uelh voel mueh la ha lo laeh.
\q1 
\v 4 Jesuh loh n'toem aw a ol te ya lah,
\q1 tihnin ah yaa. Tihnin ah yaa.
\q1 A ol a ka tang na tah omngaih ni.
\q1 A loe la tho lam cet laeh.
\c 238
\s1 Aka Ya Boei Loh Angaih La Pang
\s2 Whosever Will
\sp Doh is D
\q1 
\v 1 A ka ya boeih loh a ngaih la pang uh lah,
\q1 Ol thangthen diklai paeng tom ah thui uh lah,
\q1 Ol thangthen te hlang tom taeng ah thui uh lah
\q1 Ko a ka huem boeih lo uh.
\q2 \qt Ko a ka huem boeih Ko a ka huem boeih\qt*
\q2 \qt Noi tlang paeng tom boeih ah olthangthen thui uh\qt*
\q2 \qt A pa loh hlang hma tangtae khaw boeih a khue \qt*
\q2 \qt a ka huem boeih ha lo uh.\qt*
\q1 
\v 2 A ka lo ham koi uelh mueh la ha lo uh,
\q1 Ta hae thoh ka a ong li vaeng ah kun uh,
\q1 Jesuh tah ol tak neh hing nah long puei ni
\q1 Ko a ka huem boeih lo uh.
\q1 
\v 3 A ka ngaih ham te tah a ol khueh te cak.
\q1 A ka ngai ham te tah dung yan la cak ni.
\q1 A ka ngaih ham te dung yan hing nah om coeng.
\q1 Ko a ka huem boeih lo uh.
\c 239
\s1 Khrih Loh Hlangtholh Boeih A Doe
\s2 Christ Receiveth Sinful Men
\sp Doh is D
\q1 
\v 1 Khrih loh hlang tholh boeih a doe,
\q1 rhen nah ol hlang boeih ham ni.
\q1 Vaan longpuei a ka phael tih,
\q1 hlang tholh boeih tholh yut uh laeh.
\q2 \qt Laasa uh koep sa uh bal,\qt*
\q2 \qt Khrih loh hlang tholh te a doe. \qt*
\q2 \qt He ol thang a caih la thui qt* \qt*
\q2 \qt Khrih loh hlang tholh rhoek a doe. \qt*
\q1 
\v 2 Ha lo lah duem nah m'paek ni,
\q1 A ol cim bueng mah uep nah,
\q1 Hlang tholh koek khaw a loh tih,
\q1 A rhen coeng Boei Jesuh loh.
\q1 
\v 3 Ka lungbuei tholh cimcaih sak,
\q1 A cim la na hmai m'pai sak,
\q1 A ti hnai cim sak lam tah,
\q1 Ngaikhuek na te han soep sak.
\q1 
\v 4 Khrih loh hlang tholh boeih a doe,
\q1 Kai hlang tholh koek mai pataeng,
\q1 Ka tholh boeih boeih han loh tih,
\q1 Vaan dong la kai n'caeh puei ni.
\c 240
\s1 Thohka Kaengah Kamyin Pai
\s2 Let The Saviour In
\sp Doh is Db
\q1 
\v 1 Thohka kaeng ah kamyin pai Kun van saeh,
\q1 Khing khing ah ha lo coeng tih Kun van saeh.
\q1 A mael hlan ah kun sak lah.
\q1 Kun van saeh a cim boeipa,
\q1 Pathen capa kun sak lah Kun sak lah.
\q1 
\v 2 Na thinko ta hae ong lam Kun sak lah,
\q1 Na uelh a tah bal pawn ni.
\q1 Kun sak lah, Nang kah na paya then ni.
\q1 Na mueihla han hlip ve tih,
\q1 A bawt due la nang n'khoem ni Kun sak lah.
\q1 
\v 3 A lungnah ol hna tun lah, Kun sak lah,
\q1 Ti hnin ah tuek nah khueh lam Kun sak lah
\q1 Thoh kaeng ah a mah pai li,
\q1 Om ngaihnah soep sak ham la,
\q1 A ming te thang pom lam tah kun sak lah.
\q1 
\v 4 Ta hae vaan kamyin khue lam Kun sak lah,
\q1 Vaan buhloei te han tael ni Kun sak lah,
\q1 Kho dawk ngai ol han thui ni,
\q1 Lai tui phu a thoh vaengah,
\q1 A im lah n'caeh puei pawn ni Kun sak lah.
\c 241
\s1 Im La Mael
\s2 The Prodigal Child
\sp Doh is Eb
\q1 
\v 1 Im la ha mael
\q1 Na lung buei thahnoeng coeng.
\q1 Long puei loh mueng coeng tih
\q1 Na ngai loh hmang sut coeng.
\q2 \qt Im la ha mael\qt*
\q2 \qt Buh an khaw om muep coeng, \qt*
\q2 \qt Om ngaih la nang n'doe pa ya.\qt*
\q1 
\v 2 Im la ha mael
\q1 Nang tah kan rhingoel coeng.
\q1 Hlaem hmah khawn phai a khaw,
\q1 Thohka ah ka pai pueng
\q1 
\v 3 Im la ha mael
\q1 Kothae khui lam ka loh,
\q1 Yahrhaidaeng tholhnah neh,
\q1 cuekhalh khui lamkah loh
\c 242
\s1 Tholhnah Longpuei Ka Vai Rhoek
\s2 Only Trust Him
\sp Doh is G
\q1 
\v 1 Tholh ah pa tang aka khang boeih,
\q1 A rhen nah ol neh n'khue
\q1 A mah loh ngai mong duem
\q1 na te m'paek ni a ol dong ah.
\q2 \qt Amah bueng mah uep nah uh\qt*
\q2 \qt lah ta hae ah uepnah, \qt*
\q2 \qt Nang te n'khang ni \qt*
\q2 \qt nang te khang ni \qt*
\q2 \qt ta hae ah n'khang ni.\qt*
\q1 
\v 2 Boeipa Jesuh loh thing lam dong,
\q1 Pha cip pha baem a ueh,
\q1 Ma mih ham thii sen a hawk
\q1 coeng vuel song bang bok nah ham.
\q1 
\v 3 Jesuh long puei ol tak bueng loh,
\q1 Duem nah la nang m'mawt thai,
\q1 A mah te tang nah uelh tlai mueh
\q1 la nang yoe then hlang ni.
\q1 
\v 4 Ha lo ram cim dong ah kun sih,
\q1 Boeilen na la cet sih,
\q1 Te ram then ah om uh van sih
\q1 lamtah, omngaih uh sih.
\c 243
\s1 Boeipa Taeng Lamkah Ka Hma
\s2 Lord I'm Coming Home
\sp Doh is Ab
\q1 
\v 1 Boeipa taeng lam kah ka hma dae,
\q1 tahae koep ka bal,
\q1 Tholh long puei yulh ka vai tih,
\q1 Boeipa koep ka bal.
\q2 \qt Koep ka bal koep ka bal\qt*
\q2 \qt hma tlaih voel pawt ham\qt*
\q2 \qt Lungnah ban te na phuel coeng\qt*
\q2 \qt Boeipa koep ka bal.\qt*
\q1 
\v 2 A tue then kum boeih ka poeih tih,
\q1 tahae koep ka bal,
\q1 Tholhyutnah mikphi bo doe,
\q1 Boeipa koep ka bal.
\q1 
\v 3 Tholh ah pam he ka thahnoeng tih,
\q1 tahae koep ka bal,
\q1 Nan lungnahol ka tangnah,
\q1 Boeipa koep ka bal.
\q1 
\v 4 Ka ko loh tlo, ka thin loh phat,
\q1 tahae koep ka bal,
\q1 Thaom na ngaiuep nah m'pae,
\q1 Boeipa koep ka bal.
\c 244
\s1 Hlangtholh Te A Rhennah Neh
\s2 Lay It Down
\sp Doh is G
\q1 
\v 1 Hlang tholh te a rhennah neh a khue,
\q1 Jesuh kho kung ah.
\q1 Halo na tholh te boeih yut uh laeh
\q1 Jesuh kho kung ah.
\q2 \qt Tholh hal laeh aw hal laeh\qt*
\q2 \qt Na hno rhih na phueih boeih hal laeh\qt*
\q2 \qt Aw hal laeh hal uh laeh\qt*
\q2 \qt Jesuh kho kung ah.\qt*
\q1 
\v 2 Ha lo tang nah neh duemnah tlap lah,
\q1 Jesuh kho kung ah,
\q1 Na lungbuei hno rhih patang hal lah,
\q1 Jesuh kho kung ah.
\q1 
\v 3 Na tangnah loh nang teng n'soep sak ni,
\q1 Jesuh kho kung ah,
\q1 Lakueng ngaihmang na boeih te hal lah,
\q1 Jesuh kho kung ah.
\q1 
\v 4 Ha lo uah lah nangmih ham hmuen om,
\q1 Jesuh kho kung ah.
\q1 Tholh hno na rhih na boeih te hal lah,
\q1 Jesuh kho kung ah.
\c 245
\s1 Khangkung Taeng Halo Lamtah
\s2 There Is Pardon For You
\sp Doh is Ab (Slowly)
\q1 
\v 1 Khangkung taeng ha lo lamtah a ming tangnah,
\q1 thinko thai neh a taeng ah bih,
\q1 Then sak ham nang n'rhingnah te mang thong tak boeh
\q1 nang ham kho dawkngaihnah te om.
\q2 \qt Nang ham tholh hlah na te om\qt*
\q2 \qt nang ham tholh hlah na te om\qt*
\q2 \qt Khrih loh nang ham a duek dong ah\qt*
\q2 \qt tholh hlah na soep tah nang hamla om.\qt*
\q1 
\v 2 Tholhnah long puei dueknah a ka pan puei te,
\q1 me yet nim na ngai laem pueng ve,
\q1 Lungnah olding te na hna khong thil boel saw
\q1 nang khodawkngainah pae kung te.
\q1 
\v 3 Rhih om nah boeih te thinglam taengla rhael lah,
\q1 Te ah ni nang ham khangnah om
\q1 Na tangnah neh a di hlan ah
\q1 rhennah mueihla loh na thangthuinah m'paek ni.
\c 246
\s1 Aw Bangnim Ka Saii Lah Ve
\s2 What Shall I Do To Be Save?
\sp Doh is F
\q1 
\v 1 Aw bang nim kai ka saii lah ve,
\q1 khothae patang mueihla khang na ham,
\q1 tuiphu kho hli rhal la ha tho tih
\q1 kothae loh ka mueihla tui li bang la a khuu.
\q1 ba ka saii eh, ba ka ti eh,
\q1 Aw ba lae kai ka ti van eh.
\q1 
\v 2 Khang la om ham ba ka ti eh,
\q1 Rhoengthai ka om then na boeih boeih neh,
\q1 puei van thui ngaih long khaw,
\q1 muei thuh hlipying tak coeng,
\q1 Dueknah hlan kaeng ah a ka rhap tih,
\q1 mik phi tui pha, ba ka ti eh,
\q1 Aw ba lae kai ka ti van eh.
\q1 
\v 3 Khang la ka om ba ka ti eh,
\q1 tloh ka kaem tih ka tha la hnoeng sut,
\q1 Diklai khohnin long he muei bang la ha cing tih,
\q1 dungyan muei ha tueng van poek a ya?
\q1 ba ka sai eh, ba ka ti eh,
\q1 Aw ba lae kai ka ti van eh.
\q1 
\v 4 Aw Boeipa kai he n'rhen mai lah,
\q1 Ha lo lam tah ngai mong ol han thui,
\q1 Kho daeng lung ma lung nat ka yak nah han hoeih sak,
\q1 Te tlam te kai ka sai van pawn ni,
\q1 Te tlam te kai ka sai pawn ni,
\q1 Jesuh te kai ka pan pawn ni.
\c 247
\s1 Jesuh Taengah Cet Lam Na Tloh
\s2 Go and Tell Jesus
\sp Doh is Ab
\q1 
\v 1 Jesuh taengah cet lam na tloh thui lah,
\q1 A hoei khang sak vetih nang n'hoeih sak ni.
\q1 Amah bueng dan lah khodawkngai kung ni,
\q1 Amah ke tang nah nang tah na hing ni.
\q2 \qt Jesuh taeng ah thui lah khodawk a ngai ni\qt*
\q2 \qt Jesuh tang ah thui la a mah ben la hing \qt*
\q2 \qt Jesuh taeng ah thui Jesuh taeng ah thui\qt*
\q2 \qt a mah bueng long ni kho dawk a ngai thai eh\qt*
\q1 
\v 2 Jesuh taengah cet lam tah thui van lah,
\q1 Tholh loh tlang bang la sang tih yin ca khaw,
\q1 A thisen a hawk tih a hing nah m'paek
\q1 Te lungvat na loh ngai a mong sak ni.
\q1 Jesuh taengah cet lam na rhih te thui,
\q1 Uep vawt nah, phi tui khaw boeih a huih ni,
\q1 A kut dong ah m'pom ve tih n'koep sak ni,
\q1 Nang ham dungyan omngaihnah te m'paek ni.
\c 248
\s1 Omdam Yutho Ngaihmang Li
\s2 I Am Coming
\sp Doh is F
\q1 
\v 1 Omdam yutho ngaihmang li vaengah,
\q1 Boeipa na khue ol ka hnatun.
\q1 Nang kan tangnah Khrih ka doe coeng,
\q1 Ta hae na taengla koep ka bal.
\q2 \qt Ka lo li coeng, ka lo li coeng,\qt*
\q2 \qt Khang kung boei then na taeng lo li coeng \qt*
\q2 \qt Ka lo li coeng ka lo li coeng \qt*
\q2 \qt na taeng ah duem ham ka lo li coeng.\qt*
\q1 
\v 2 Jesuh nang ni lunghoih ko do,
\q1 Jesuh nang taengla koep ka mael.
\q1 Kai n'khoem yoe yah n'caeh tak tlaih boeh,
\q1 Na yoethennah khui lamkah loh.
\q1 
\v 3 Na taengah ka kuep ka ying tih,
\q1 ka mueihla duemnah ham ka tlap
\q1 Mincang khothaih khosae then ah,
\q1 om ngaihnah cungkuem ka dang koep.
\q1 
\v 4 Kai khoem bael lah n'cim caih sak lah,
\q1 hli puei muei rhih lakli a he,
\q1 Ko thae nah he omngaih sak lah,
\q1 khoyin he kho han thaih sak lah ing tih.
\c 249
\s1 Boei Khat Jesuh Taengla Hlaem ah
\s2 Ye Must Be Born Again
\sp Doh is Eb
\q1 
\v 1 Boei khat Jesuh taengla hlaem ah ha lo,
\q1 Khangnah neh vang nah long puei a mah dawt ham la,
\q1 Boeipa loh a caih la a thui pa te tah,
\q1 cun koep hamla na ngoe.
\q2 \qt Nang cun koep hamla na ngoe\qt*
\q2 \qt nang cun koep hamla na ngoe, \qt*
\q2 \qt Na taeng ah ol tak tang la kan thui coeng he, \qt*
\q2 \qt cun koep hamla na ngoe\qt*
\q1 
\v 2 Nang hlang hing ca rhoek hna tun uh boeih lah,
\q1 Jesuh loh ol yoei ca la a thui sut ol te,
\q1 he ol thang he a yoe la om sut boel saeh,
\q1 cun koep hamla na ngoe
\q1 
\v 3 Boeilen yoe then khui la aka kun rhoek,
\q1 tlannah laa then koek te sa uh boeih van lah sih,
\q1 Dung yan hingnah na khueh nahamlam te tah,
\q1 cun koep hamla na ngoe
\q1 
\v 4 Vaan dong kah thin tlo hlang a muei ka hue,
\q1 A sui vong ka then ah kai n'rhing tih lam tawn te,
\q1 te vaengah a thui ham ko olka te tah,
\q1 cun koep hamla na ngoe
\c 250
\s1 Lai Hman ah Rhihnah Yet Mai Cakhaw
\s2 Weary Of Earth
\sp Doh is F
\q1 
\v 1 Lai hman rhihnah neh tholh hno rhih phueih he,
\q1 Vaan ka dan vaengah kun hamla ka ngaih,
\q1 Te dae vaan im ah tholhnah om voelpawh,
\q1 Ha lo lah tila a khue ol ka yaak.
\q2 \qt Duengnah boeipa thangthuinah rhoirhi kung,\qt*
\q2 \qt Na omngaihnah he kai ham kut doe then, \qt*
\q2 \qt Hling lu muek na muek kai ham sui lumuek, \qt*
\q2 \qt Na ueh nah tah kai ham hing nah la om. \qt*
\q1 
\v 2 Vaan dong kho thai neh a cim kho puei ke,
\q1 kai bang hlang tholh loh ka pha van poek ya?
\q1 Ka boei ngol khoel bok hmaiah phoe ham la,
\q1 A boeilen kut a yueng tih kai he mawt ng'khue
\q1 
\v 3 Vaan dong long puei omngaih la ka caeh vaeng,
\q1 Kho hnin rhamhnin ah cuek halh nah loh n'kae,
\q1 Te vaengah lungnah ol thangthen ka yaak,
\q1 Tholh na yut atah boeih na loeih ni ti.
\q1 
\v 4 Ta hae ah Jesuh kah khue ol ka yaak,
\q1 Ca vaih nah kut loh ka taengla ha yoei,
\q1 Kai tholh cim naham a thi a long sak,
\q1 A ngol khoel hmaiah hlang dueng la kai n'khueh.
\c 251
\s1 Tholh Cimnah Ham Jesuh
\s2 Have You Been To Jesus?
\sp Doh is Ab
\q1 
\v 1 Tholh cim na ham
\q1 Jesuh taeng na cet pawn a?
\q1 Tu ca thii ah na sil uh pawn a?
\q1 Tahae a lungvatnah na uep na pawn a?
\q1 Tu ca thi ah na sil uh pawn a?
\q2 \qt Tuca thiisen dong ah\qt*
\q2 \qt nang loh tholh cim ham na silh pawn a? \qt*
\q2 \qt Na himbai tuei laeh vuel song bang la bok a\qt*
\q2 \qt Tuca thisen dong na silh pawn a?\qt*
\q1 
\v 2 Kho hnin rhamhnin
\q1 khang kung taeng na cet pawn a?
\q1 Tu ca thi ah na sil uh pawn a?
\q1 Thing lam dong a dueknah dong na duem pawn a?
\q1 Tu ca thi ah na sil uh pawn a?
\q1 
\v 3 Yulo kung ha lo vaeng baibok na bai a?
\q1 Tu ca thi ah na sil u pawn a?
\q1 Na mueihla vaan caeh ham na oepsoeh pawn a?
\q1 Tu ca thi ah na sil uh pawn a?
\q1 
\v 4 Tholh neh na nok nah him bai te voei mai laeh,
\q1 Tu ca thi ah na sil uh pawn a?
\q1 Muei hla cim nah hamla tui cim ha phuet coeng,
\q1 Tu ca thi ah na sil uh pawn a?
\c 252
\s1 Ngaih Om Boei Ka Rhahnah Ol
\s2 Save Me At The Cross
\sp Doh is A
\q1 
\v 1 Ngaih om boei ka rhah nah ol
\q1 na hnatun na hnatun
\q1 tholh khui ah ka buek coeng dae
\q1 Aw thing lam neh n'khang lah
\q1 Ka tholh dae kai ham na duek
\q1 Nang na duek nang na duek
\q1 rhen na neh hoep tlang lam tah,
\q1 Na thing lam neh n'khang lah.
\q2 \qt Aw Boeipa kai n'doe lah,\qt*
\q2 \qt ka pam dah voel mah pawh\qt*
\q2 \qt Na rhang ah m'poem lah \qt*
\q2 \qt na thing lam ah kai n'khang lah\qt*
\q1 
\v 2 Ka hma ta dae ka bi ni
\q1 thang thui neh ka bih ni.
\q1 Na hing nah dung yan long ah
\q1 Na thing lam ah m'mawt lah
\q1 Na thui na rhen na te tah a yoe ni a yoe ni
\q1 Na rhen na te ka taeng ah,
\q1 Na thing lam ah m'mawt lah.
\q1 
\v 3 Na thii neh n'cim caih sak lah
\q1 na hawk sut thi sen cim
\q1 Thi sen long neh kai n'sil lah
\q1 Aw thing lam ah m'mawt lah
\q1 Tangnah neh bueng dang thai tih
\q1 lung nah nan paek te tah
\q1 Tangnah neh na taeng ka lo
\q1 Aw thing lam ah n'khang lah.
\c 253
\s1 Long Hmaang Tu La Ka Om
\s2 I Was A Wondering Sheep
\sp Doh is F
\q1 
\v 1 Long hmaang tu la ka om,
\q1 tuhui te ka lungnah pawh.
\q1 Tudawnkung ol khaw ka lungnah pawh,
\q1 ngairhungngairha mai ah
\q1 ca moe bangla ka pam dah
\q1 ka im khaw ka lungnah pawh
\q1 a pa ka ol thui khaw ka ngaih pawh,
\q1 pamdahnah bueng ka ming.
\q1 
\v 2 Tu dawn loh tu a tlap
\q1 pa loh a ca te a tlap
\q1 Mol tom tuk li tang laeh a hil tih,
\q1 kho tom rha li a tluek,
\q1 Buhmueh rha thih neh kai he
\q1 kho yin rham maeng due la n'tlap.
\q1 Amih loh a lungnah kut neh n'tuuk
\q1 kai hlang hma he koep n'khang.
\q1 
\v 3 Jesuh kai dawn kung tih
\q1 ka mueihla he a lungnah,
\q1 A thi sen neh kai he n'silh phoeiah,
\q1 kai he hlang soep la n'khueh,
\q1 Aka hma te a tlap tih a ka poeng tu koep a hm uh.
\q1 Tu ping taengla kai n'caeh puei phai tih,
\q1 A then la n'khoem n'bael bal.
\q1 
\v 4 Hlang poeng pa doe la he
\q1 kuemsuem na khaw ka khueh pawh,
\q1 Tedae tahae khang boei ol ka yaak,
\q1 tu hui rhoek ka lungnah,
\q1 Ca hma la kai ka om tih
\q1 a thae na te ka tuek dae
\q1 Tahae khang boei ol te ka yaak coeng,
\q1 A im ka lungnah coeng.
\c 254
\s1 Dan Lah Kalvary Thinglam
\s2 Look, And Thou Shall Live
\sp Doh is Bb
\q1 
\v 1 Dan lah Kalvari thinglam dong ah,
\q1 Khangkung boei nang neh kai ham patang,
\q1 A lung nah ol loh nang te n'khue li,
\q1 Dan lah na hing ni.
\q2 \qt Dan lah na hing ni dan lah na hin ni \qt*
\q2 \qt thing lam dong nang hamla ka duek ke \qt*
\q2 \qt dan lah na hing ni\qt*
\q1 
\v 2 Tholh hno rhih boeih khang la om pawn a?
\q1 Dungyan hing nah nang na khueh pawn a?
\q1 Jesuh bueng long ni tlan na he m'paek,
\q1 Dan lah na hing ni.
\q1 
\v 3 Duek lam kah thokoep khang kung dan lah,
\q1 A loe la a taeng ah hmuen om pueng,
\q1 A vang na loh yin nah a cing sak,
\q1 Dan lah na hing ni.
\q1 
\v 4 Jesuh vaan dong ah laipai la om,
\q1 Hlangtholh ka a ngoe na boeih a ming,
\q1 Khokan na boeih te a mah loh m'mawt,
\q1 Dan lah na hing ni
\c 255
\s1 Kothae Khoyin Pinyen Khui Lamkah
\s2 Jesus I Come
\sp Doh is A
\q1 
\v 1 Kothae khoyin pinyen khui lam kah,
\q1 Jesuh ka lo, Jesuh ka lo.
\q1 Sayalhnah neh omngaih khosae ah,
\q1 Jesuh na taeng ka lo.
\q1 Tlohtat lamkah na sading na ah,
\q1 khodaeng lam kah na boei na khui ah
\q1 Ka tholh lamkah namah kah taeng ah
\q1 Jesuh na taeng ka lo.
\q1 
\v 2 Ka hma ka ta yapoh khui lam kah,
\q1 Jesuh ka lo, Jesuh ka lo.
\q1 Na thing lam kah boeilen na khui ah,
\q1 Jesuh na taeng ka lo.
\q1 Ka kothae nah khui lam kah hoeih si,
\q1 hli puei lam kah ngai dip na khui la,
\q1 Ngai hmang lam kah ko hoe na khui ah,
\q1 Jesuh na taeng ka lo.
\q1 
\v 3 Omlawt caha oek hlawn khui lam kah,
\q1 Jesuh ka lo, Jesuh ka lo
\q1 Na kongaih na khui ah om hamla,
\q1 Jesuh na taeng ka lo.
\q1 Ka ngaih khui lamkah na lungnah ah,
\q1 poci lam kah ngai uep na khui ah,
\q1 Vahu bangla pomsang hang ka ngaih,
\q1 Jesuh na taeng ka lo.
\q1 
\v 4 Dueknah hlan mol rhih om khui lam kah,
\q1 Jesuh ka lo, Jesuh ka lo.
\q1 Na im then a vang om then na ah,
\q1 Jesuh na taeng ka lo.
\q1 Thui thai lek mueh rhawkrhal khui lamkah,
\q1 mongnah vong up na tuping khui ah,
\q1 Na mikhmai then khosae hmuh ham la
\q1 Jesuh na taeng ka lo.
\c 256
\s1 Ka Hing Khui Ka Tholdalhnah
\s2 The Mistakes Of My Life
\sp Doh is G
\q1 
\v 1 Ka hing khui ka tholh dalh nah yet coeng.
\q1 Ka lung buei tholh nah yet coeng,
\q1 Ka rhap tih ka mik khaw tueng pawh.
\q1 Te dae thoh ka ka khoek ni.
\q2 \qt Kai hlang thloh ka vawt thoek ka ming\qt*
\q2 \qt Ka ko taoetaoe koep hing, \qt*
\q2 \qt Tedae lungvat kung boeipa n'khue vaeng atah\qt*
\q2 \qt a thoh ka ah ka kun ni. \qt*
\q1 
\v 2 Amah aka hnawt sut hlang kai he
\q1 a ka thangthui khoe koek kai,
\q1 Tedae n'khue bang la koep ka lo
\q1 A mah loh n'haek tlaih mahpawh.
\q1 
\v 3 Na rhen nah loh tholhdalhnah a dah,
\q1 ka tholh nah boeih a silh ni
\q1 Tholh ah a ka bung ka kho he
\q1 A thoh ka la cet pawn ni.
\q1 
\v 4 Ka hing khui tholh nah loh yet tangkik,
\q1 Tholh ah ka mueihla loh tlo.
\q1 Ka mik phi loh kho khoep a dah,
\q1 Te dae boeipa loh n'kun sak.
\c 257
\s1 Nan Doenah Ol Ka Yaak
\s1 Ka Tholhnah Han Sil Lah
\s2 I Hear Thy Welcome Voice
\sp Doh is Eb
\q1 
\v 1 Nan doenah ol ka yaak
\q1 Boeipa kah khuenah ol,
\q1 Na thi sen cim phu ka tlo koek,
\q1 Kal va ri ah long coeng.
\q2 \qt Boeipa na taeng ah\qt*
\q2 \qt na taeng ah ka lo\qt*
\q2 \qt Ka tholh nah han cim sak lah, \qt*
\q2 \qt Kalvari na thi neh.\qt*
\q1 
\v 2 Ka thahnoeng sut ca khaw,
\q1 ka tha koep nan hlue sak,
\q1 Pa then aw ka tholh tuei laeh he,
\q1 cim ca la nan silh coeng.
\q1 
\v 3 Jesuh nang loh nan khue,
\q1 Ka tangnah soep sak ham,
\q1 Ngai uep nah tangnah soep sak ham,
\q1 vaan dong lamkah nan paek.
\q1 
\v 4 Jesuh na mah bueng loh,
\q1 ka bi tat nan cak sak,
\q1 Yoe then nah cungkuem nan paek tih,
\q1 tholh tha om nah na ta.
\c 258
\s1 Lungnah neh Nang Te n’Khue
\s2 Still Out Of Christ
\sp Doh is G
\q1 
\v 1 Lung nah neh nang te n'khue
\q1 Khrih mueh la na om,
\q1 Tang na kolla badong lae na oltha
\q1 Me bang diklai omthen lae bawn na ngaih pueng
\q1 Hna voei lah thai latnah na ueh thai ham
\q2 \qt Jesuh taeng pan laeh\qt*
\q2 \qt Kho daeng patang hlang rhoek\qt*
\q2 \qt A tue om vaeng ah ha cet uh, \qt*
\q2 \qt Jesuh loh nang n'rhing\qt*
\q2 \qt Nang te tahae n'tlap li, \qt*
\q2 \qt Hnatun tihnin ah nang n'khue coeng.\qt*
\q1 
\v 2 A tue then om vaengah
\q1 Khrih mueh la na om,
\q1 Khoyin koi nih metlamna om naeh,
\q1 Tui bap phu tlo ta hae ah ha phuet koep coeng
\q1 nang ham tui ding cim ha long li bal pueng
\q1 
\v 3 A rhennah tah om pueng
\q1 Khrih mueh la na om,
\q1 Na om kung lam kah loh bal ngaih atah,
\q1 Nang khang hamla thohka kung ah n'rhing li pueng
\q1 Tholh hlah ham kun sak a ngaih tih n'rhing pueng
\q1 
\v 4 Lungnah neh om a khueh
\q1 Khrih mueh la na om,
\q1 A ngaih nah pang hamla na poek van a?
\q1 Ta hae ai si mawt na kung ah kun van laeh.
\q1 A loe la kun yut lam tah kun van laeh
\c 259
\s1 Rhah Loh Kai Khang Thai Pawh
\s2 Weeping Will Not Save Me
\sp Doh is Eb
\q1 
\v 1 Rhah loh kai khang thai pawh,
\q1 ka mik phi sul puem ca khaw,
\q1 Ka rhihyawp dip sak thai pawh,
\q1 kum sen ka tholh sil thai pawh,
\q1 Rhahloh kai n'khang mahpawh.
\q2 \qt Jesuh rhap tih kai ham duek,\qt*
\q2 \qt Jesuh loh thing dong a yook, \qt*
\q2 \qt Jesuh loh kai he n'loeih sak. \qt*
\q2 \qt A mah long ni n'khang thai.\qt*
\q1 
\v 2 Bisai loh n'khang mah pawh,
\q1 tui si then ka tuem ca khaw,
\q1 Ko poek cim ka poek cakhaw,
\q1 ka mueihla thai sak thai pawh,
\q1 Bisai lon n'khang mahpawh.
\q1 
\v 3 Rhing nah loh n'khang mah pawh,
\q1 tholhnah dong bueng a ka buek,
\q1 A rhen khuenah ol ka yak,
\q1 ka mong koinih ka duek ni,
\q1 Rhingnah loh n'khang mahpawh,
\q1 
\v 4 Khrih tangnah loh n'khang ni,
\q1 Na ca te ka uepnah eh,
\q1 A bi dong ka hangdang eh,
\q1 A mah kut neh n'caeh sak lah,
\q1 Khrih tangnah loh n'khang thai.
\c 260
\s1 Thinglam Tai Kungah Ka lo
\s2 I Am Coming To The Cross
\sp Doh is G
\q1 
\v 1 Thing lam tai kung ah ka lo,
\q1 ka mikdael kai ka kho daeng,
\q1 Thung na ham bang ka khueh pawh,
\q1 Khangnah then koek ka hmuh he.
\q2 \qt Boeipa nang ni kan uep nah\qt*
\q2 \qt Kalvari tuca then koek\qt*
\q2 \qt Na thinglam hmui ah ka kun\qt*
\q2 \qt Jesuh tahae ah khang lah.\qt*
\q1 
\v 2 Namah ni khing kan ngaidam
\q1 tholh khui ah ka om cakhaw
\q1 Na tholhnah boeih kan silh coeng
\q1 Jesuh ol ding loh a ti.
\q1 
\v 3 Soeprhaep boeih he nang kan paek
\q1 ka khueh tawn ka pa ya boeih
\q1 Ka mueihla neh ka pum boeih
\q1 A yoeyah namah kah ni.
\q1 
\v 4 Boeipa ol kam ka tang nah
\q1 Na thii long nah ol cim ke
\q1 Ka ko khui ah ka khueh coeng
\q1 Namah neh hmaih duek ka ngaih
\c 261
\s1 Ka Om Bangla Thennah
\s2 Just I Am
\sp Doh is Db
\q1 
\v 1 Ka om bangla thennah om pawh,
\q1 Tedae kai ham thi na long sak,
\q1 Na taengla kai ka lo koep coeng
\q1 Pathen tuca na taeng ka lo.
\q1 
\v 2 Ka om bang la ka koih vaih pawh,
\q1 Ka mueihla cim sak nah om pawh,
\q1 A mah thi bueng long ni n'cim sak
\q1 Pathen tuca na taeng ka lo.
\q1 
\v 3 Ka om bang la ka ngaimong pawh,
\q1 Ngaihmang patang na la lat om,
\q1 Rhahnah neh rhainah lakli ah
\q1 Pathen tuca na taeng ka lo.
\q1 
\v 4 Ka om bang la nang loh n'khang lah,
\q1 Ka tholhnah boeih han cim caih sak,
\q1 Na ol khueh bang lam ka tangnah.
\q1 Pathen tuca na taeng ka lo.
\q1 
\v 5 Ka om bang la ka koih vaih pawh,
\q1 Lung buei khui tloh boeih na hoeih sak,
\q1 Na mah bueng ni sai kung boeipa
\q1 Pathen tu ca na taeng ka lo.
\c 262
\s1 Ka Rhah Ol Hnatun
\s2 Come Great Deliverer, Come!
\sp Doh is C
\q1 
\v 1 Ka rhah ol hnatun lamtah kai rhen lah,
\q1 Khang kung boei ha rhum lah.
\q1 Nang kan lam tawm ah kho ka cung kueng he,
\q1 khang kung boei ha rhum lah.
\q2 \qt Mol voel tlang hlaep la ka long puei ka hmang,\qt*
\q2 \qt Im lam kah a hla la ka pam. \qt*
\q2 \qt Aw tahae n'lo na tu ping taengla m'mawt, \qt*
\q2 \qt khangkung boei ha rhum lah.\qt*
\q1 
\v 2 Khohmuen neh hlipying na ham ka khueh pawh,
\q1 Khangkung boei ha rhum lah.
\q1 Hing na neh vang nah pae kung tah nang ni,
\q1 khangkung boei ha rhum lah.
\q1 
\v 3 Longpuei ah ka bueng kholaeh loh thui pawh,
\q1 Khangkung boei ha rhum lah
\q1 Na mikhmai hlampan hmuh hamla ka ngaih,
\q1 khangkung boei ha rhum lah.
\q1 
\v 4 Lungbuei aka rhen he na sawt sit pawh,
\q1 Khang kung boei ha rhum lah
\q1 Thang thui ol neh ka rhah ol han ya lah,
\q1 khangkung boei ha rhum lah.
\c 263
\s1 Olrhi Lam Loeihnah Omngaihnah Paihmuen
\s2 Once for All
\sp Doh is Eb
\q1 
\v 1 Olrhi lam loeihnah omngaihnah paihmuen,
\q1 Jesuh thi sen ah tlannah te om coeng,
\q1 Olrhi ah ko si bungnah lamkah,
\q1 Lung vatnah loh ma'mih boeih n'tlan coeng.
\q2 \qt Hlang boeih hamla om,\qt*
\q2 \qt hlang tholh rhoek doe uh, \qt*
\q2 \qt Aw ma nu ca rhoek tangna uh van lah, \qt*
\q2 \qt Thinglam kung pan lam hnorhih hal lah\qt*
\q2 \qt Khrih loh vaiat la n'tlan uh coeng.\qt*
\q1 
\v 2 Ta hae n'loeih u coeng tholh pael nah om pawh,
\q1 Jesuh loh khang nah soep na te m'paek coeng,
\q1 Ka taeng ha lo ti khue ol ding yaa
\q1 Amah loh mamih boeih n'tlan coeng .
\q1 
\v 3 Pathen capa na boeilennah neh n'khue
\q1 A rhennah loh tholhnah lam ka loh n'khang
\q1 Dueknah caeh tak tih hingnah la n'khue
\q1 Khangnah uem om koek hlang boeih ham.
\c 264
\s1 Kumhal ah Poeihcaih La Kho ka sak
\s2 At Calvary
\sp Doh is C
\q1 
\v 1 Kum hal ah poeih caih la kho ka sak,
\q1 Boeipa a dueknah toek sap mueh la,
\q1 Kai tholh ham a duek te ka ming pawh Kalvari ah.
\q2 \qt A rhen lungvat na loh n'sa yalh sak.\qt*
\q2 \qt tholh rhen nah ka so la muep ha soep, \qt*
\q2 \qt Ka mueihla hnorhih tah yalpo coeng Kalvari ah\qt*
\q1 
\v 2 Pa then olka tholh nah m'ming sak tih,
\q1 A olka aek na te ka la kueng,
\q1 Ka tholh ka yak ming duela ka cet Kalvari la.
\q1 
\v 3 Ta hae ah soep rhaep Jesuh ka paek,
\q1 Ka Boeipa so ah ka om ngaih,
\q1 Ka mueihla omngaih laa a sak tah, Kal va ri kah.
\q1 
\v 4 Lungnah loh khangnah te a sai tih,
\q1 Lung vat nah loh hlang hing te a khue
\q1 Pathen loh tuk kainah hlai a sui Kal va ri ah.
\c 265
\s1 A Cak Lungnu Kai Ham Can
\s2 Rock Of Ages
\sp Doh is Bb
\q1 
\v 1 A cak lung nu kai ham can
\q1 namah khui ah ying ka ngaih,
\q1 Cai thun ngo na vae khui ah
\q1 aka long thi sen tui loh,
\q1 Kai kah tholhnah boeih han silh
\q1 kai cim nah he tlam pai a.
\q1 
\v 2 Ka kut bi ka sai na loh
\q1 Pathen kongaih soep thai pawh.
\q1 Dung yan tangnah thin ko neh,
\q1 Ka mik phi a bonah loh.
\q1 Kai kah tholh cim sak thai pawh.
\q1 Namah long ni na khang thai.
\q1 
\v 3 Ka kut neh bang kan khuen pawh
\q1 thinglam tung koh doe ka lo.
\q1 himbai tling la na taeng ah
\q1 ka lo he nang loh na ming,
\q1 Kai hlang tholh tuei laehkap he
\q1 Na thi cim neh kai n'sil lah.
\q1 
\v 4 Ka hil nah mal loh pat tih
\q1 Ka mik lung ka khah vaeng ah.
\q1 Vaan la ka pom sang vetih
\q1 olcaek hmuen ah nang kan hmuh,
\q1 A cak lung nu kai ham can
\q1 na mah khui ah kai ying sak.
\c 266
\s1 Na Hingnah Amah Taengah
\s2 Will Your Anchor Hold?
\sp Doh is F
\q1 
\v 1 Na hingnah amah taeng na pae a yaa?
\q1 Rhainah kho mai bangha lo vaeng ah,
\q1 Tui phu ha tho tih hli a tlohvaeng ah,
\q1 Na hingnah na ngai mong van a ya?
\q2 \qt Ka mueihla hamla kuep nah ka khueh,\qt*
\q2 \qt Tui phu tui let lak ah ka loeih ni, \qt*
\q2 \qt Ka kuep nah lung nu tah thoihtat pawh, \qt*
\q2 \qt Boeipa lung na loh sa ding la n'dawn ni.\qt*
\q1 
\v 2 Caem rhal lak a khaw ka ngai loh mong ni,
\q1 Boeipa loh ka kut cak la han tuk,
\q1 A om nah hmuen te tah kai ham lam ni,
\q1 Tuiphu lak ah ka sa sueng van ni.
\q1 
\v 3 Tui li neh kho daeng na ha pai cakhaw,
\q1 Boeipa dong ah a mong la ka om,
\q1 Hli puei loh ha tho bal mai a ca khaw,
\q1 Boeipa hnuk ah a mong la ka cet.
\q1 
\v 4 Dueknah tui phu neh ngai hmangnah lakah,
\q1 Boeipa lungnah loh n'om puei yoe yah,
\q1 Tui phu tui let long khaw n'na thai mahpawh,
\q1 Boeipa lungnah loh dung yan la n'dawn.
\q1 
\v 5 Muei rhih khui ah mik dael la ka cet dae,
\q1 a vang hmuen then sui kho puei la m'mawt,
\q1 Vaan duemnah hmuen ah dungyan ka pong pa,
\q1 Rhainah ngai hmang nah om tlaih mah pawh.
\c 267
\s1 Rhal Lon n’Na Pawn Ni
\s2 Let The Sunshine In
\sp Doh is Ab
\q1 
\v 1 Rhal loh n'na pawn ni ti la na la kueng a?
\q1 Yinnah loh nang khoep ah kho han yin sak a?
\q2 \qt Yin nah bangbuet te \qt*
\q2 \qt boeih ah cim sak lam tah,\qt*
\q2 \qt thohka a len la ong lah, \qt*
\q2 \qt Khosae te sae van lah saeh\qt*
\q2 \qt Khosae then sae van lah saeh. \qt*
\q2 \qt Yin nah bang buet cim sak lam thohka ong lah, \qt*
\q2 \qt Khosae then te sae lah saeh.\qt*
\q1 
\v 2 Na kongaih loh nang te paltham sak tom a?
\q1 Na thang thuinah so ben lamkah han lan a?
\q1 
\v 3 So ben long puei ah caeh ham na thahlue nim,
\q1 Kho sae lung ah he yinnah a om moenih,
\c 268
\s1 So benkah Ram Ke Ka Yoei
\s2 Higher Ground
\sp Doh is Ab
\q1 
\v 1 So ben kah ram ke ka yoei hang
\q1 kho hnin rham hnin, hmuen sang ka pha,
\q1 Thang thui doe hmai ben la ka cet,
\q1 Boeipa hmuen sang ah kai m'pai sak.
\q2 \qt Boeipa n'thoh lah ka pai lah ni, \qt*
\q2 \qt tangnah neh vaan dong ram then ah, \qt*
\q2 \qt ka pha noek mueh ke ram ah ke\qt*
\q2 \qt Boeipa hmuen sang ah kai m'pai sak.\qt*
\q1 
\v 2 Rhih om na neh ngai hmangnah hmuen
\q1 ka lung buei loh om ka ngaih pawh,
\q1 Hlang tloe rhoek omngaih mai cakhaw,
\q1 Kai tah hmuen sang ke ni ka ngai.
\q1 
\v 3 Satan tholhnah ka tong cakhaw,
\q1 so ben ram ni om ham ka ngaih,
\q1 Hlang cim rhoek kah laa sak ol te,
\q1 tangnah hna vue neh kai ka yaak.
\q1 A sang nah ram ke ka pan tih,
\q1 Boeilen om thennah pang ka ngaih,
\q1 Vaan ka pha due thang thui doe ah,
\q1 hmuen sang ah kai m'mawt lah ka ti.
\c 269
\s1 Pathen Nang Kan Koeh
\s2 Revive Us Again
\sp Doh is G
\q1 
\v 1 Pathen nang kan koeh
\q1 ca pa neh nan lungnah,
\q1 Na capa kaimih hamla a duek dongah,
\q2 \qt Ha le lui jah na boeilen koek,\qt*
\q2 \qt Hal le lui jah amen. \qt*
\q2 \qt Ha le lui jah na boeilen koek\qt*
\q2 \qt Kaimih koep n'huek lah.\qt*
\q1 
\v 2 Pathen nang kan koeh
\q1 vang nah mueihla nan paek,
\q1 Khangkung loh yin
\q1 a cing sak te kai m'ming sak.
\q1 
\v 3 Soeprhaep loh koeh saeh,
\q1 a ngawn tu ca te tah,
\q1 Ma mih tholh boeih
\q1 a phueih tih a cim sak coeng.
\q1 
\v 4 Kai mih koep n'huek lah,
\q1 lung buei lungnah bae sak,
\q1 Te lung buei ah so ben
\q1 hmai boeih vang sak saeh.
\c 270
\s1 Aw Lungvat Kung Pathen Loh
\sp Doh is C
\q1 
\v 1 Aw lungvat kung Pathen loh,
\q1 ka thin ko khui a he,
\q1 Muei hla m'paek omngaihnah he,
\q1 Diklai cueihnah loh pha thai pawh,
\q2 \qt Hlang cueih hlang hing coengnah neh,\qt*
\q2 \qt a poeknah loh, pha thai lek pawh, \qt*
\q2 \qt Ka khangkung boeipa kah olhuep he\qt*
\q1 
\v 2 Aw dung tangkik sang tangkik,
\q1 diklai cueihnah lakah,
\q1 Pathen lungvatnah ol he,
\q1 Vaan neh diklai tom ah boeih bae.
\q1 
\v 3 Aw kai hlang tholh hma tangtae,
\q1 A lungvatnah dongah,
\q1 Muei hla m'paek ka hingnah he,
\q1 Aw ka hingnah boeipa koeh lah.
\c 271
\s1 Ka Kut Hong Nen Nim Ka Luei Ve?
\s2 Must I Go And Empty Handed?
\sp Doh is D
\q1 
\v 1 Ka kut hong nen nim ka luei ve,
\q1 khang boei Jesuh hmuh ham la,
\q1 Hnin at khaw a bi ka bi pawh,
\q1 Kai loh bang khaw ka pae pawh.
\q2 \qt Ka kut hong nen a ka luei eh,\qt*
\q2 \qt tlam a khang boei ka hmuh eh, \qt*
\q2 \qt Hlang khat khaw ka khuen mueh mai la, \qt*
\q2 \qt kut tling lam a ka luei eh.\qt*
\q1 
\v 2 Ka duek ham khaw ka lakueng pawh,
\q1 Jesuh loh kai n'khang dong ah,
\q1 Kut tling mai la ka caeh dong ah,
\q1 Mikphi buem tui bangla buem.
\q1 
\v 3 Ka kum tholh ah aka khum te,
\q1 kai loh koep ka khue thai pawh,
\q1 Khangkung boeiboeih ka paek sui tih,
\q1 omngaih la ka kun van sue.
\q1 
\v 4 Hlang cim rhoek boeih ip boeh tho laeh,
\q1 a tue om vaeng bi bi uh,
\q1 Dueknah yin loh kae hlan vaengah,
\q1 Muei hla ham bi bi van laeh.
\c 272
\s1 Ka Pumsa Neh Ka Hingnah He
\s2 Enthroned Is Jesus Now
\sp Doh is Eb
\q1 
\v 1 Ka pum sa neh ka hingnah he
\q1 Boei Jesuh taengah ka paek coeng
\q1 Rhainah me bang khaw ka rhih pawh,
\q1 Ka khuehtawn boeih neh pum ka paek.
\q1 
\v 2 Boei Jesuh loh tholh a tlan coeng,
\q1 Sal khui lamkah kai n'loeih sak coeng,
\q1 Te tla saithaikung u ka om,
\q1 Tholh sal khui lamkah n'loeih sak ke.
\q1 
\v 3 Boei Jesuh bueng he hingnah kung,
\q1 Dung yan apa rhoepnah boei ni,
\q1 Amah taengah hingnah te om,
\q1 Tholh ah aka bung koep rhoek ham.
\q1 
\v 4 Diklai ah hlang hing om coinim,
\q1 Hlangcim tholhaka khueh pawt hlang
\q1 Hlang hing ca pa Boei Jesuh bueng,
\q1 Tholh neh a ti hnai khaw khueh pawh.
\q1 
\v 5 Diklai boei rhaeng om thennah he,
\q1 Hmatanah neh thailatnah ni,
\q1 Te dae van dong boeilennah tah,
\q1 Dung yan duela pal tlaih mah pawh.
\c 273
\s1 Aka Hma Hlang Coi Lah
\s2 Rescue The Perishing
\sp Doh is Bb
\q1 
\v 1 Aka hma hlang coi lah,
\q1 duek dalh hlang bom lah,
\q1 Rhennah neh tholh hlan tui lamkah doek lah,
\q1 Boe thae hlang khaw hip lah,
\q1 aka bung thoh lah,
\q1 Jesuh kah khangnah thai kawng thui pa uh.
\q2 \qt A ka poci rhoek coi \qt*
\q2 \qt duek dalh hlang hip lah, \qt*
\q2 \qt Jesuh lungvat na neh khang nah paek ham.\qt*
\q1 
\v 2 Tholh a ka yut ca pa
\q1 te a rhing li pueng,
\q1 A ol bang lam khaw toek sap u pawt dae,
\q1 Ol tak la han coep uh,
\q1 Lung hoih la han coep,
\q1 A ka tang nah kho dawk a ngai pa ni.
\q1 
\v 3 Hlang thin ko khui ah ke
\q1 tholhnah loh a ven,
\q1 Dueknah neh po cinah loh a pin coeng,
\q1 Te dae lung vatnah neh,
\q1 a taengla cet lah,
\q1 Aka duek tang tae te koep ah hing ni.
\q1 
\v 4 Aka hma rhoek hul lah
\q1 bi ham koi rhoe ni,
\q1 Boeipa loh thaomnah te m'paek ngai ni,
\q1 Long hmang hlang boeih ke
\q1 rhennah neh ham mawt lah,
\q1 Amih ham Jesuh dueknah cil thui uh.
\c 274
\s1 Bi Uh Lah
\s2 To The Work
\sp Doh is F
\q1 
\v 1 Bi uh lah bi uh lah,
\q1 Pathen sal la n'om uh,
\q1 Boeipa kah cong hol neh
\q1 mawt nah long puei vai uh,
\q1 Tha n'hnoeng atah amah
\q1 loh tha hluenah m'paek ni,
\q1 Bi bi te tha om cueihnah neh bi uh lah sih.
\q2 \qt Bi uh la bi uh lah\qt*
\q2 \qt Bi uh la bi uh lah\qt*
\q2 \qt ngaiuep lam tangnah neh\qt*
\q2 \qt Boeipa ha lo hlan due bi lah\qt*
\q1 
\v 2 Bi uh lah bi uh lah,
\q1 bung pong hlang buh pae uh,
\q1 kho daeng hlang hingnah tui sih kaeng la mawt uh lah,
\q1 Thing lam tung kah hmai ah,
\q1 ma mih boeilennah tah,
\q1 A yoe paek rho ni ti la tamhoe uh pawn ni,
\q1 
\v 3 Bi uh lah bi uh lah,
\q1 hlang boeih loh bi ham om,
\q1 Tholh taemrhainah neh pinyennah boeih pat pawn ni,
\q1 Jehova Pathen kah ming thangthennah te tah,
\q1 A yoe paek rho ni ti la laa n'sak uh pawn ni.
\q1 
\v 4 Bi uh lah bi uh lah,
\q1 Boeipa tha omnah neh,
\q1 sui lu muek neh him bai bok tah mamih ham ni,
\q1 Uepom hlang rhoek om nah
\q1 hmuen te m'pha uh vaengah,
\q1 A yoe paek rho ni ti la laa n'sak uh pawn ni.
\c 275
\s1 Manghai Pa Rhalkap Taengah
\s2 The Banner Of The Cross
\sp Doh is Bb
\q1 
\v 1 Mang hai pa rhal kap taeng ah hni tai a hmuh,
\q1 A ming tang lue tueng sak ham,
\q1 Tihnin tlan nah laa n'sak vaeng ah
\q1 hni tai te lik soi la thueng uh hang lah,
\q2 \qt Hmai ben ah cawh uh lah\qt*
\q2 \qt Jesuh kah bi bi u sih\qt*
\q2 \qt Manghai kah lu muek muek sak uh \qt*
\q2 \qt Thing lam hni tai hlaek uh lah\qt*
\q1 
\v 2 Tuili lungpok bang la rhal loh len ca khaw,
\q1 Hnitai na hmai ah hlaek uh,
\q1 BoeiJesuh rhal kai boeih hmai la cawh uh
\q1 dilai loh m'pal tham sak boel saeh.
\q1 
\v 3 Dik lai kho tom boeih neh tui tun li boeih ah,
\q1 omngaihnah ol thang sak uh,
\q1 Hni tai thim kah thi te m'poek u koep vaeng ah,
\q1 Boeipa tah kai kah n'ti ni.
\q1 
\v 4 A boeilen thangthen tue long tah ha yoei coeng,
\q1 hnin at pa toeng hnin at yoei,
\q1 Boeipa manghai kah hmai ah rhal khaw dip ni,
\q1 Thing lam tung loh a ta ni.
\c 276
\s1 Jesuh Khuenah Ol Hnatun Lah
\s2 Here Am I, Send Me
\sp Doh is F
\q1 
\v 1 Jesuh khue nah ol hna tun lah,
\q1 U long ti hnin a bi eh,
\q1 Lo hmuen loh ah ham rhoeh hlai coeng,
\q1 u long cangvuei a coi eh,
\q1 Boeipa loh a ngai la n'khue uh,
\q1 Kutdoe then koek mai te m'paek,
\q1 Omngaih la u long a lan eh,
\q1 He ah ka om kai n'tueih lah
\q1 he ah ka om kai n'tueih lah lah.
\q1 
\v 2 Tuili puei na kat thai pawt tih,
\q1 mol voel na lan pawt cakhaw,
\q1 na taeng kah hlang tholh rhoek te mah,
\q1 han bom lamtah han coep dae,
\q1 Tangka na paek thai pawt atah,
\q1 Nuhmai bang lam mah ham pae,
\q1 Hlang mikhmuh ah a sit om dae,
\q1 Jesuh loh phu a tloh sak,
\q1 Jesuh loh phu a tloh sak.
\q1 
\v 3 Vaan hlang bang la thui thai pawt tih,
\q1 Pawl bangla na phong pawt dae,
\q1 Jesuh lungnah ol te thui pah,
\q1 Hlang boeih ham a dueknah te,
\q1 Hlang tholh rhoek na thoh tloel atah,
\q1 Ol caek rhih om kawng thui pah,
\q1 Ca moe Boeih Jesuh taeng lo ham,
\q1 Khang kung boeih loh a lam tawm,
\q1 Khang kung boei loh a lamtawn.
\q1 
\v 4 Nangmih taeng kah pa tong boeih ke,
\q1 cang puei tuk kil ham hnilh boeh,
\q1 Khrih loh a tu han dawn a ti,
\q1 Rham tlim la ham mawt a ti,
\q1 Ca moe talh khaw a om atah,
\q1 na kho daeng kut neh ham mawt,
\q1 Sui lu muek then koek na hmuh ni,
\q1 Ram then khui na pha vaeng ah,
\q1 Ram then khui na pha vaeng ah.
\c 277
\s1 Jesuh Lungnah Hlang Boeih Omngaih la
\s2 We're Marching To Zion
\sp Doh is G
\q1 
\v 1 Jesuh lungnah hlang boeih omngaih la ha lo
\q1 uh omngaih laa ko at la sa sih,
\q1 omngaih laa ko at la sa sih,
\q1 Pathen kah hmuen cim ah
\q1 Pathen kah hmuen cim ah,
\q2 \qt Zi on tlang ah luei sih\qt*
\q2 \qt Kho om then kho om then\qt*
\q2 \qt Zion tlang dong la luei uh hang\qt*
\q2 \qt Pathen hni kho puei dong la cet u sih\qt*
\q1 
\v 2 Pathen ming mueh rhoek loh laa sak ham al ca khaw,
\q1 Vaan boeipa ca rhoek long he tah,
\q1 vaan boeipa ca rhoek long he tah,
\q1 Om ngaih laa sa uh sih
\q1 omngaih la sa uh sih.
\q1 
\v 3 Zi on tlang kho omthen omngaihnah la cet sih,
\q1 Vaan dong kho then pha hlan vaeng ah,
\q1 vaan dong kho then pha hlan vaeng ah,
\q1 Sui long puei vai uh sih sui long puei vai uh sih.
\q1 
\v 4 Te dong kohoe laa sa sih mikphi bo boel saeh,
\q1 Imanuel kho long cet uh,
\q1 Imanuel kho long cet uh,
\q1 vaan dong kho then pha ni,
\q1 vaan dong kho then pha ni.
\c 278
\s1 Thinglam Rhalkap La Ka Om
\s2 Am I A Soldier Of The Cross
\sp Doh is D
\q1 
\v 1 Thing lam rhal kap la ka om tih,
\q1 tu ca hnuk ah ka bang,
\q1 A bi bi hamla ka rhih pawh,
\q1 A ming then ka thui ni.
\q2 \qt A ming tanglue koek la om\qt*
\q2 \qt Kai yueng la aka duek ni. \qt*
\q2 \qt Thing lam tai ka kawt mai cakhaw, \qt*
\q2 \qt Sui lu muek ka muek ni. \qt*
\q1 
\v 2 Hlang tloe kut doe dang sak ham la,
\q1 duek due ka bi thai ham?
\q1 Vaan ah ka pha sak van a ya?
\q1 Dueknah tui len cakhaw.
\q1 
\v 3 Rhaltuk hamla caemrhal om a?
\q1 Tuipuei rhih om khui ah.
\q1 Lai hman thin om hlang om coi a?
\q1 Pathen taeng pha ham la.
\q1 
\v 4 Rhalta hamla ka tuk vaengah,
\q1 Boeipa thin om sak lah,
\q1 Kho daeng lung ma ka lam vaengah,
\q1 na ol then neh bom lah.
\c 279
\s1 He Diklai ah Jesuh Bueng Loh
\s2 Must Jesus Bear The Cross Alone
\sp Doh is A
\q1 
\v 1 He diklai ah Jesuh bueng loh,
\q1 thing lam tai a koh eh,
\q1 Hlang boeih long khaw koh ham om tih,
\q1 Kai long khaw koh ham om.
\q1 
\v 2 Ke a cim thing lam ka kawt ni,
\q1 duek loh kai n'hlah duela,
\q1 Vaan im then ah sui lu muek then
\q1 Kai loh ka muek ham om.
\q1 
\v 3 A khing Jesuh kah kho kung ah,
\q1 a vang lung nu so ah,
\q1 Ka sui lu muek ka tloeng ve tih,
\q1 A ming ka thangthen ni.
\q1 
\v 4 Ke thing lam tah aka then koek,
\q1 a cim thoh koepnah hnin,
\q1 Vaan dong lamkah vaan hlang rhum lah
\q1 ka mueihla he mawt lah.
\c 280
\s1 Pathen Manghai Te Uepnah
\s2 Onward Go
\sp Doh is D
\q1 
\v 1 Pathen manghai te uep nah,
\q1 hmai la cet hmai la cet,
\q1 A ol khueh nah hna tun lah, hmai la cet.
\q1 A ming cim te voei mai boeh
\q1 rhai daeng la a om akhaw.
\q1 A thang a then pung sak lam hmai la cet.
\q1 
\v 2 A bi bi ham nang n'khue a?
\q1 hmai la cet hmai la cet,
\q1 A yin hlan ah a bi bi hmai la cet.
\q1 Tangnah lungnah neh bi bi
\q1 A kut dong ah hang dang lah.
\q1 A cak la phueih pai lamtah, hmai la cet.
\q1 
\v 3 Sui cang vuei te tah m'paek coeng,
\q1 hmai la cet hmai la cet,
\q1 Na tuh bangla na ah ni, hmai la cet.
\q1 Boeipa loh thohka a saii
\q1 Nang te lam tawm rhing oel khing,
\q1 Na thangthuinah ol a yak hmai la cet.
\q1 
\v 4 Kolh kalh ah ha bawt pawn ni,
\q1 hmai la cet hmai la cet,
\q1 A cim la a bi bi lah, hmai la cet.
\q1 Khrih na kho hmuen,
\q1 kho sak nah na long puei ah hingnah buh,
\q1 Kho hnin om then m'pha sak ni, hmai la cet.
\c 281
\s1 Boeipa Khue Ol Hnatun
\s2 Our Best
\q1 
\v 1 Boeipa khue ol hna tun a then koek pae,
\q1 a yit a len cakhaw a nuemnai ni,
\q1 Saithai khui a then sai dangham moe nih,
\q1 Hlang kah koeh ham moe nih Boeipa ham ni.
\q2 \qt Jesuh ham n'sai boeih he yoe then ni,\qt*
\q2 \qt Te dae hlang boeih he boeipa ham ni, \qt*
\q2 \qt N'thoem n'thai yol mai cakhaw yit bal cakhaw\qt*
\q2 \qt amah ham tah a then koek he sai sih.\qt*
\q1 
\v 2 Hlang kah kolonah neh uemnah moenih,
\q1 Pathen mik hmai hlam pan na ham koini,
\q1 A tueng a then sai he yoe thae moe nih,
\q1 poek saii boeih he a then koek la om saeh.
\c 282
\s1 Khrihca Ngaithuen
\s2 Christ Walk Carefully
\sp Doh is G
\q1 
\v 1 Khrihca ngai thuen rhihomnah loh ha yoei,
\q1 Na yin caeh nah la kueng neh rhihnahom.
\q1 Cuek halhnah thang dong ah man na koi om,
\q1 nangmih tholh dong ah mawt hamla n'tlap coeng.
\q1 Khrih ca ngai thuen la cet, Khrih ca ngai thuen la cet,
\q1 Khrih ca ngaithuen la cet, nuen loh ha yoei yoei.
\q1 
\v 2 Khrihca omngaih la cet hli puei tho tih,
\q1 Vaan khoyin loh thing khoep mai bal ca khaw,
\q1 cueknah kho mai tah ha cing bat pawn ni,
\q1 Khang kung neh dung yan na duem hmaih pawn ni.
\q1 Khrih ca omngaih la cet, Khrih ca omngaih la cet,
\q1 Khrih ca omngaih la cet, hli tlo cakhaw,
\q1 
\v 3 Khrih ca thang thui neh cet na bung tholh ve,
\q1 Khang kung boei khue lam tah nang loh cet lah,
\q1 patang na lak li ah na sa sueng ni,
\q1 Caem rhal a khaw omngaih la thang thui lah
\q1 Khrih ca thang thui neh cet, Khri ca thang thui neh cet
\q1 Khrih ca thang thui neh cet, rhih na hma ni.
\q1 
\v 4 Khrih ca ngai uep na neh kothae khaw ueh,
\q1 Vaandong na pha vaeng ah hno yanghoep ni,
\q1 Olcaeng kung loh nang taeng a thui ham tah,
\q1 omngaihnah khui ah kun van a ti ni.
\q1 Khrih ca rhoek ngaiuep uh, Khrih ca rhoek ngaiuep uh,
\q1 Khrih ca rhoek ngaiuep uh, kothae akhaw
\c 283
\s1 Khangkung Boei Neh Tuikol Van Naem Ah
\s2 Follow On
\sp Doh is Ab
\q1 
\v 1 Khang kung boei neh tui kol van naem ah ka cet ni,
\q1 Rhaipai lum tih tui ding cil loh a phuet na ah,
\q1 Me lam khaw amah kah mawt na ah ka bang ni,
\q1 Sui lu muek ka hmuh due a hnuk ka bang ni.
\q2 \qt Bang lah bang lah Jesuh hnuk ka bang ni,\qt*
\q2 \qt Me lam khaw khotom rham tom ah ka bang ni, \qt*
\q2 \qt melam khaw khotom rham tom ah ka bang ni.\qt*
\q1 
\v 2 Khangkung boei neh tui kol van naem ah ka cet ni,
\q1 Kho hli kho nal long hnal tui pha tui phu a khaw,
\q1 Amah kut neh kai m'mawt dong ah ka lakueng pawh,
\q1 Boeipa neh ka om atah ka ngai mong ni.
\q1 
\v 3 Tlang sang thael pang long hoi dongah ka cet ca khaw,
\q1 Khang kung boei loh ka mueihla te a khoem yoe yah.
\q1 A cong hol neh long puei ah sa ding la m'mawt ni,
\q1 Pa then kah tlang dong ah boeih tun na hmuen ah.
\c 284
\s1 Hmuhnah Ham La Mik Han Tueng Sak
\s2 Open My Eyes That I May See
\sp Doh is Ab
\q1 
\v 1 Hmuhnah hamla mik han tueng sak,
\q1 Na oltak te tah kai ham ni,
\q1 Kopoekrhai ca bi te kai m'pom sak.
\q1 Pinnah hlam tih kai n'loeih sak ni.
\q1 Ngai mong ca la nang te kan rhing,
\q1 Na ko ngaih ming ham ka ngaithuen,
\q1 Hmuh na hamla mik han tueng sak
\q1 Aw Cim Mueihla.
\q1 
\v 2 Yaak nah hamla hna han khui sak,
\q1 Na ol thuem te ka ming na ham,
\q1 Ka hna ah he ol a kun phoeiah,
\q1 Ol thuem mueh te boeih hma pawn ni,
\q1 Ngaimong ca la nang te kan rhing
\q1 Na ko ngaih ming ham ka ngaithuen,
\q1 Yak na ham ka hna han khui sak
\q1 Aw CimMueihla
\q1 
\v 3 Ka thui nah ham ka ka han ong,
\q1 Kho tom ah na ol ka phong eh,
\q1 Rhueng phong na ham ka lunglungbuei han ong,
\q1 Na lungnah te pang van hmaih ham,
\q1 Ngaimong ca la nang te kan rhing
\q1 Na ko ngaih ming ham ka ngaithuen,
\q1 Ka thin ko lung buei han ong lah
\q1 Aw Cim Mueihla
\c 285
\s1 A Hla A Yoei Lo Hmuen Boeih Kah
\s2 A Call for Reapers
\sp Doh is Ab
\q1 
\v 1 A hla a yoei lo hmuen boeih kah
\q1 cang vuei loh aengnoi boeih coeng.
\q1 Cing toe tui kong kol ben ah khaw
\q1 a pum la boeih rhohmin coeng.
\q2 \qt Aw Boeipa nang taeng kan bih\qt*
\q2 \qt cangat rhoek te han tueih lah saw, \qt*
\q2 \qt A tue a dawi hlan vaeng ah\qt*
\q2 \qt a loe ngai la han tueih lah saw.\qt*
\q1 
\v 2 Ming cang ah khaw kho thun ah khaw,
\q1 kho a tlak tom vaeng ah khaw,
\q1 Boeipa kho tom rham tom boeih ah
\q1 cangat kung han tueih lah saw,
\q1 
\v 3 Aw boeipa nang loh n'coi puei lah,
\q1 Sui cang vuei pok hnaih om ke,
\q1 Na hingnah kho hnin bawt vaengah
\q1 Om ngaih la na duem pawn ni.
\c 286
\s1 Bi Lah Khoyin Tom Ca Coeng
\s2 Work, for the Night is Coming
\sp Doh is F
\q1 
\v 1 Bi lah kho yin tom ca coeng, min cang due phat bi lah,
\q1 Do tui lak akhaw bi lah, kho nal lak akhaw,
\q1 Kho sae akhaw bi lamtah kho ling akhaw bi lah,
\q1 Bi lah kho yin tom coeng tih bi bi khaw bawt coeng
\q1 
\v 2 Bi lah kho yin tom ca coeng, Kho thun akhaw bi lah,
\q1 Kho sae then ah thahuel lah duem tue m'pha tom coeng.
\q1 Mik pa lap khaw dal rha boeh, khat khat tah tung pawn sih,
\q1 Bi lah kho yin tom coeng tih bi om voel mahpawh.
\q1 
\v 3 Bi lah kho yin tom ca coeng, Kho mik loh tla thuk coeng
\q1 Kho sae then a om vaengah bi bi te bi laeh
\q1 Kho a khup due la bi lah, kho sae tueng voel mah pawh
\q1 Bi lah kho loh hmuep pawn ni bi a bawt vaeng ah.
\c 287
\s1 Longhoi Khokhup Neh Khoyin Khui Lamkah
\s2 I Will Not Forget Thee
\sp Doh is Ab
\q1 
\v 1 Lung hoi khokhup neh kho yin khui lamkah loh,
\q1 Tholh dung khui lamkah loh ka mueihla mael laeh,
\q1 Dung yan nah vangnah long puei la ka bal tih,
\q1 Kan hnilh mah pawh Boeipa Jesuh loh a ti.
\q2 \qt Na hing khui boeih ah kan hnilh mahpawh\qt*
\q2 \qt Na kut ah kan mawt coeng, \qt*
\q2 \qt Ka olpaek uepvawt boeh. \qt*
\q2 \qt Na hing khui ah ka hnilh mahpawh\qt*
\q2 \qt Na khangkung boeipa Jesuh loh a thui coeng. \qt*
\q1 
\v 2 Diklai he muei rhih tam yin loh thing cakhaw,
\q1 A lungnah neh a rhennah ming mueh mai la
\q1 Ta hae Kal va ri lungnah te ka ming coeng.
\q1 Amah mueh tah loeihnah a om tlaih moenih.
\q1 
\v 3 Ngai uepnah neh Bawi pa na taengla ka lo,
\q1 Thang thennah laa sak doe na taengla kam pan,
\q1 Na ca la omngaih ah lai hui ka caeh tak,
\q1 Na sai vaan im ah Boeipa kai he m'mawt lah.
\c 288
\s1 Kan Uh Kan Uh
\s2 Forward
\sp Doh is A
\q1 
\v 1 Kan uh kan uh Khrih ah hing thai ka khueh rhoek aw,
\q1 tui thim tlang puei kho cuk khotlak a sai hno taeng ah,
\q1 He ram olthangthen he thui soep la a om hlan a tah
\q1 toeng muehla bi yoeyah sih Boeipa ol paek bangla.
\q1 
\v 2 Duek ham mai la a mawt uh te boeih tlan uh laeh,
\q1 hnatun uh lah ka ming moenih na ti koinih ta,
\q1 Thinko khing kung hmaiah soep rhaep boeih phoe la a om vaeng,
\q1 hlang boeih loh a bi a sai bang la a thung pawn ni.
\q2 \qt Kan uh kan uh kan uh lah\qt*
\q2 \qt tui thim tlang puei kho cuk kho tlak a sai hluen taeng ah, \qt*
\q2 \qt he ram ol thangthen he thui soep la a om boeih due la\qt*
\q2 \qt olpuei koek la khueh uh sih olthangthen phong ham he.\qt*
\q1 
\v 3 Hlang tholh rhoek loh a tholhnah boeih a caeh tak tih,
\q1 a hing lu a hlawt na ham na thui pawt koinih ta,
\q1 Tholh dongah a pum boeih la hma ta uh mai koinih ta,
\q1 A thii sen phu te nang taengah koep han suk pawn ni.
\q1 
\v 4 Ti hnin he ol thangthen uem om pai nah kho hnin,
\q1 ma mih loh ng'om sut tih kho thaih n'rhing uh koinih ta,
\q1 Pa tangnah n'tong hlan ah ol thangthen he thui uh pawn sih,
\q1 A yoe la m'hmuh hno then a yoe la koep paek ham om.
\c 289
\s1 Cuekhalhnah ah Om Boeh
\s2 Yield Not To Temptation
\sp Doh is Bb
\q1 
\v 1 Cuek halhnah ah om boeh tholhnah la om thai,
\q1 Vai na noeng atah a tloe khaw yoei koek coeng.
\q1 Thahuel uh lam tuk uh, Tholhnah han ta uh.
\q2 \qt Jesuh dan uh lah a mah loh m'mawt bit ni.\qt*
\q2 \qt Khang kung taeng ah bom nah bih, \qt*
\q2 \qt Ngai mong thaom nah m'paek ni\qt*
\q2 \qt A mah loh nang bom a ngaih, \qt*
\q2 \qt amah loh nang m'mawt ni.\qt*
\q1 
\v 2 Tholhnah hnuk la rhoe uh, ol thae khaw rhael uh,
\q1 Pa then ming hinyah na lakuengnah hma ni,
\q1 A ol poek hueltue uh, Hlang rhen kho poek uh,
\q1 
\v 3 Rhal a ka noeng hlang tah lu muek a dang ni,
\q1 Tangnah neh n'noeng ni, yawk nah om tang mahpawh,
\q1 Khang kung boeipa long tah, tha om na m'paek uh.
\c 290
\s1 Caeh Thae Khaw Toek Lek Pawh
\s2 If Jesus Goes With Me
\sp Doh is C
\q1 
\v 1 Caehthae khaw toeklek pawh la kueng rhihomnah ah khaw,
\q1 Khosaenah ah ngai mong la ka om na akhaw saeh,
\q1 Kho yinnah neh kho a tuengnah akhaw ti saeh,
\q1 Jesuh a om atah boeih ah ka cet ni.
\q2 \qt Me lam khaw Jesuh neh hmaih ka cet mong ni\qt*
\q2 \qt A mah a om a tah me lam khaw vaan dong kho pawn ni. \qt*
\q2 \qt Thing lam koh te kai ka yoethen na la om coeng\qt*
\q2 \qt Jesuh kah mawt na kung boeih ah ka bang ni.\qt*
\q1 
\v 2 Omngaih hingnah ol thang thui kung la ka om atah,
\q1 Hlang tloe long khaw kho daeng pa tang a ueh thai van ni,
\q1 Amah ka tangna te a caih la ka thui ni,
\q1 Kai taeng a om atah ka om rhoi hmaih ni.
\q1 
\v 3 Boeipa kah ol caeng te tah kai ka oltha mahpawh,
\q1 A ol bangla khosak he ni ka vawtnah la om,
\q1 Melamkhaw a hnuk bang lam ni kai ka om coeng,
\q1 Khangkung nen tah om mong ko ka yael van coeng.
\c 291
\s1 Pueivan Rhoek Vaan Kee Dan Uh Lah
\s2 Hold The Fort
\sp Doh is D
\q1 
\v 1 Puei van rhoek vaan ke dan uh lah
\q1 mik noeknah ha tueng,
\q1 Bomkung rhal kap ta ha tueng coeng,
\q1 tanah loh yoei coeng.
\q2 \qt Rhalkap tho uh ka lo pawn ni\qt*
\q2 \qt Jesuh tuenpa coeng\qt*
\q2 \qt Na rhennah rhang neh ka ol loh\qt*
\q2 \qt van hampha hang coeng\qt*
\q1 
\v 2 So uh rhal muep ha tlung pawn ni
\q1 Sa tan kah a mawt,
\q1 Thaom hlang rhoek tlim uh vetih
\q1 thin om nah dalh boeih.
\q1 
\v 3 Boeilennah aitlang ke dan uh
\q1 olueng ol te ngai,
\q1 Mawt kung ming ah n'ta uh bit ni,
\q1 rhal boeih boeih so ah.
\q1 
\v 4 Caemrhal tlungnah sen mai ca khaw
\q1 bom kung ha yoei coeng,
\q1 Hmai la cawh rhal boei ham pha coeng,
\q1 puei van omngaih lah
\c 292
\s1 Kho Loh Thai Tih Ka Hing
\s2 I'll Fly Away
\sp Doh is Bb
\q1 
\v 1 Kho loh thai tih ka hing a bawt vaeng
\q1 ka cet pawn ni.
\q1 Pathen taeng kah ka im then ben la
\q1 Ka cet pawn ni.
\q2 \qt Ka cet pawn ni boeilen nah\qt*
\q2 \qt Ka cet pawn ni \qt*
\q2 \qt Vuen vai ah ha le lui jah ka sak ni\qt*
\q2 \qt ka cet pawn ni.\qt*
\q1 
\v 3 Yin nah muei hlip hing nah a khum vaeng
\q1 ka cet pawn ni
\q1 Dong lamkah va a loeih van bang la
\q1 Ka cet pawn ni.
\q1 
\v 4 Ngaihmang khohnin loh a khum vaeng ah
\q1 ka cet pawn ni
\q1 Omngaih bawt mueh ram omthen khui ah
\q1 Ka cet pawn ni.
\c 293
\s1 Jesuh Ham Tahae Thoo Uh
\s2 Stand Up, Stand Up, For Jesus
\sp Doh is Bb
\q1 
\v 1 Jesuh ham ta hae tho uh,
\q1 Thing lam rhal kap rhoek aw,
\q1 Ta nah aitlang te hlaek uh,
\q1 rhal loh n'ta uh mah pawh.
\q1 Tha om la na ta uh due rhal kap te ham mawt ni
\q1 Rhal boeih boeih a ta vaengah
\q1 Khrih boei koek la om ni.
\q1 
\v 2 Jesuh ham tahae tho uh,
\q1 Ol ueng ol hnatun uh,
\q1 Tihnin khohnin tue then ah,
\q1 rhal tlung na la cet uh.
\q1 Amah te bawk uh lam tah
\q1 caemrhal boei te tuk uh,
\q1 Nangmih tah thinom hlang ni,
\q1 rhal tlung cakhaw thoo uh.
\q1 
\v 3 Jesuh ham tahae thoo uh,
\q1 Amah thaa bueng uep nah,
\q1 Pum sa thaa na uep na tah,
\q1 na yawk ni tila poek
\q1 Olthangthen pa tling dan uh
\q1 thang thui neh ngai thuen uh,
\q1 Rhihom na ah mamih n'khueh
\q1 Te hmuen ah thaa na boeh.
\q1 
\v 4 Jesuh ham tahae thoo uh,
\q1 Rhal tuk na sen mah pawh,
\q1 Tihnin rhal tlung tuen ol n'yaak
\q1 thangvuen ta na laa n'sak.
\q1 Rhal a ka ta rhoek boeih tah
\q1 hing lumuek a muek ni,
\q1 Boeilen nah a pang hmaih ni,
\q1 dungyan a poeng hmaih ni.
\c 294
\s1 Boeipa Halo Nah Boeilennah Te
\s2 Our God Is Marching On
\sp Doh is C
\q1 
\v 1 Boeipa ha lo nah boeilennah
\q1 te kamik loh a hmuh coeng.
\q1 Thin sanah mi sur thaih a tung nah
\q1 hmuen te a net boeih coeng,
\q1 Rhih ham ka om kho pha thung lang
\q1 a ka haat te a tueng sak,
\q1 Pathen tah ha lo li,
\q2 \qt Omngaih uh lah haleluijah,\qt*
\q2 \qt omngaih uh lah halelui jah,\qt*
\q2 \qt Pathen tah ha lo li.\qt*
\q1 
\v 2 Rhaeh nah hmuen taeng vai kah hmaivang
\q1 ah amah te ka hmuh coeng,
\q1 Ke lakliah amah bawknah
\q1 muei tuk te tah a suen uh,
\q1 Amah ol caek ngol khoel hmai ah
\q1 hlang kah thin ko te a vam,
\q1 Pathen tah ha lo li,
\q1 Ol ueng te a tum coeng dongah
\q1 koep mael uh ti tlaih mah pawh,
\q1 Amah kah ol caek nah hmai ah
\q1 hlang kah thinko te a vam,
\q1 Ka mueihla amah taeng mael lah,
\q1 ka lung buei nang omngaih lah,
\q1 Pathen tah halo li.
\q1 Tuili paithen bang la rham hla
\q1 hlang ah Jesuh tah ha thang,
\q1 A mah boeilen na rhang neh nang
\q1 neh kai muei khaw a then sak,
\q1 Khangnah hamla a duek bang la,
\q1 hlang loeih sak ham duek van sih,
\q1 Pathen tah halo li
\c 295
\s1 Caem Ol Loh Halo Rhal Ha Yoei
\s2 Sound The Battle Cry
\sp Doh is Bb
\q1 
\v 1 Caem ol loh ha lo rhal ha yoei so lah,
\q1 Boeipa ham hni a sang la hlaek,
\q1 na li va buen lah, a cak la pai uh,
\q1 Na hnorhih te a ol cim ah hal.
\q2 \qt Thoo uh Khrih ca noek nah aitlang hlaek lah,\qt*
\q2 \qt rhuengphong oepsoeh lam tamhoe uh lah, \qt*
\q2 \qt Hmai la cawh lam hosana ti la pang uh, \qt*
\q2 \qt Khrihca kah rhalboei Jesuh ni.\qt*
\q1 
\v 2 Rhal te hum na uh ham hmai la cawh lah,
\q1 Ma mih loh n'na ni ti m'ming uh,
\q1 Vangnah te buen lah,
\q1 Dueng nah dong ka ham,
\q1 tuk uh a tah n'yawk uh tlaih mahpawh.
\q1 
\v 3 Soeprhaep ah Pathen kah khue ol han yaa,
\q1 Lung nah neh khat rhip m'bom uh lah,
\q1 Rhal tuk na boeih tih, ka ta uh vaengah,
\q1 Na hmai ah sui lumuek muek na ham.
\c 296
\s1 Jesuh Uepnah He Didip Hlang
\s2 Tis’ So Sweet To Frust In Jesus
\sp Doh is Ab
\q1 
\v 1 Jesuh uep nah he didip hlang,
\q1 a olding uep nah ham then,
\q1 A olkhueh dong duem hamla then
\q1 a ol thui ming hamla then,
\q2 \qt Jesuh Jesuh nang kan uep nah,\qt*
\q2 \qt a mah bueng koep koep ka poek,\qt*
\q2 \qt Jesuh Jesuh thin tlo Jesuh\qt*
\q2 \qt na lungvatnah ka uepnah.\qt*
\q1 
\v 2 Jesuh nang bueng ni kan uep nah,
\q1 thiisen neh cim sak na khaw,
\q1 Ka tangnah loh a pat vaengah,
\q1 hoeihnah tui ding a long sak.
\q1 
\v 3 Jesuh uep na hamla ka cang,
\q1 khang kung boei neh paya then,
\q1 Tahae Jesuh taeng lam ka loh,
\q1 omngaih ngai mong na ka khueh.
\q1 
\v 4 Ka uep nah tih ka ko la hoe,
\q1 Khang kung neh paya thintlo,
\q1 Amah long n'om puei ti ka ming,
\q1 a bawt due kai m'mawt pawn ni.
\c 297
\s1 Boeipa Ben U Ka Om
\s2 Who Is On The Lord's Side
\sp Doh is C
\q1 
\v 1 Boeipa ben u ka om u long lae a bawk
\q1 Bom kung la u ka om, hlang tloe mawt ham la,
\q1 Ulae a ka caeh tak, rhal te tuk ham la
\q1 Boeipa ben u ka om u nim ka cet eh,
\q1 Na mah kah khue na neh, na lung vat nah loh,
\q1 boeipa ben mamih ng'om nang hut la ka om.
\q1 
\v 2 Boeilennah ham moenih, thang pomham moenih,
\q1 ma mih Pathen rhal kap sam toe n'hlaek u he,
\q1 Lung na ol ni n'thui uh, ning ham ka duek kawng,
\q1 Jesuh loh n'tuek coeng a taengah om lah sih,
\q1 Na lungnah cim koek neh, na lung vat nah loh,
\q1 boeipa ben mamih ng'om nang hut la ka om.
\q1 
\v 3 Jesuh nang loh nan lai, sui ngun nen moenih,
\q1 Na rhui sam la om ham thii sen neh nan lai,
\q1 Na taeng aka lo tah yoe then nah na paek.
\q1 Na ko ngaih la nan khueh tih nan loeih sak uh.
\q1 Namah kah tlannah neh, na lung vat nah loh,
\q1 boeipa ben mamih ng'om nang hut la ka om.
\q1 
\v 4 Puen pa loh ha tho tih, rhal ha tlung ca khaw,
\q1 Pathen rhal kap long tah yawk tlaih tang mahpawh,
\q1 A taeng a vai boeih ah ta na loh a vael
\q1 A ol tak he tah ta nah la phueih om coeng.
\q1 Om ngaih na long khaw soep. na lung vat nah loh,
\q1 boeipa ben mamih ng'om nang hut la ka om.
\c 298
\s1 Jesuh Kah Thinglam Ka Koh
\s2 Jesus I My Cross Have Taken
\sp Doh is Ab
\q1 
\v 1 Jesuh kah thinglam ka koh coeng,
\q1 soep rhaep hnawt tih nang kan vai,
\q1 khodaeng lungma ka lam cakhaw,
\q1 nang hamla kai ka om van pawn ni.
\q1 ka poeknah boeih loh poci tih,
\q1 ka ngaiuepnah loh bawt coeng,
\q1 Te cakhaw kuirhang la na om dong ah
\q1 Pathen te kai ham om coeng.
\q1 
\v 2 Dik lai loh n'hnawt tih n'caeh tak dae,
\q1 khang kung boei khaw a caeh tak,
\q1 Hlang hing n'thai lat na mai ca khaw,
\q1 Nang tah hlang hing poek bang lam moenih,
\q1 Maelhmai hlam pan kai nan hmuh sak,
\q1 Thaom nah lung na bae tawt,
\q1 Rhal neh ka hui loh n'hnawt ca khaw,
\q1 na mikhmai then te kai he hmuh sak.
\q1 
\v 3 Hlang loh ngai ham hmang sak cakhaw,
\q1 Na rhang lam loh nan haek pawh,
\q1 Pa tang na loh n'nan mai cakhaw,
\q1 Duem nah then koek van im la nan mawt,
\q1 Na lungvat nah nan khueh vaeng ah
\q1 Tlohnah kopang na om pawh.
\q1 Na mah neh hmaih om pawt a tah,
\q1 omngaihnah long he soep thai tlaih pawh.
\q1 
\v 4 Lungvatnah lam kah boeilennah,
\q1 Tangnah neh ka tuuk khak tih,
\q1 thangthui na neh ka pomsang hang,
\q1 Na hmai kah dungyan duem na hmuen ah,
\q1 na mah loh nan hoihaeng hang ni,
\q1 Na bi bi bawt yue ve tih
\q1 Yincaehnah kho hnin khum pawn ni,
\q1 ngai na te omngaihnah thaih tueng ni.
\c 299
\s1 Ka Hingnah Na Kut ah Om
\s2 My Times Are In Thy Hand
\sp Doh is Bb
\q1 
\v 1 Ka hingnah na kut ah om,
\q1 sak hamla ka ngaih,
\q1 Ka hingnah ka paya soeprhaep
\q1 na taengla ka caeh tak.
\q1 
\v 2 Ka hingnah na kut ah om,
\q1 me vaeng mai a khaw,
\q1 yinnah neh patangnah vaeng ah
\q1 na mah ni na then koek.
\q1 
\v 3 Ka hingnah na kut ah om,
\q1 balae ka mawn nah.
\q1 A pa loh a ca he mikphi
\q1 bo sak tang tlaih mah pawh.
\q1 
\v 4 Ka hingnah na kut ah om,
\q1 na mah kan uep nah,
\q1 Ka duek phoei ah na ban tang
\q1 kut ah dungyan ka om ni.
\c 300
\s1 Namah Ni Kan Lungnah
\s2 More Love To Thee
\sp Doh is Ab
\q1 
\v 1 Namah ni kan lungnah aw Boei Jesuh,
\q1 Na taengah ka thang thui ol han ya lah,
\q1 Thin tak neh ka thang thui, na mah ni kan lungnah
\q1 Khrih ka boeipa nang kan lungnah.
\q1 
\v 2 Omthen ka bawn vaengah ka ngai mong pawh,
\q1 Ta hae ah nang kan hmuh yoe then pae kung
\q1 Ka thang thuinah ol he, han ya lah boei Jesuh
\q1 Khrih ka boeipa nang kan lungnah.
\q1 
\v 3 Pa tang ka khang cakhaw ka ngai hmang pawh,
\q1 Namah ko ngaih bangla kai hno nah lah,
\q1 Kho daeng pa tang nah ah ngai mong yoe then soep sak
\q1 Khrih ka boeipa nang kan lungnah.
\q1 
\v 4 Ka hil a bawt vaengah nang koeh ka ngaih,
\q1 Ka ol hnuk khueng he tah omngaih cil ni
\q1 Bawt mueh la ka thangthui Boeipa nang kan lungnah
\q1 Khrih ka boeipa nang kan lungnah.
\c 301
\s1 A Tue Then La Hnonah
\s2 Take Time To Be Holy
\sp Doh is F
\q1 
\v 1 A tue then la hno nah, Pathen mah voek lah,
\q1 A mah ah duemnah tlap a ol te ca lah,
\q1 Pathen capa hinyah tha vawt hlang te bom,
\q1 A yoe then tlap hamla tet ca khaw hnilh boeh.
\q1 
\v 2 A tue then la hno nah, Dik lai po ci coeng,
\q1 Jesuh neh om khing hmaih, Jesuh mah te tlap,
\q1 Amah bangla khosa amah kho boe neh,
\q1 Teta na pa ya loh Khrih muei a hmuh ni.
\q1 
\v 3 A tue then la hno nah, Amah loh m'mawt saeh,
\q1 Amah te yong tak boeh, me bang vaeng ah khaw,
\q1 omngaih kothae vaengah khaw a hnukbang lah,
\q1 Jesuh bueng mah te tlap a ol te uep nah.
\q1 
\v 4 A tue then la hno nah, Na hil te uep sak,
\q1 Na poeknah neh cueihnah, amah rhang mai saeh,
\q1 Acim Mueihla mah loh tui kaeng la m'mawt saeh,
\q1 So ben kah bibi na bi na thai ham la.
\c 302
\s1 Thangthuinah He Ka Mueihla Ngaih
\s2 Prayer Is The Soul's Sincere Desire
\sp Doh is D
\q1 
\v 1 Thang thui he ka mueihla ngaih nah,
\q1 Ka phoe neh phoe pawt khaw
\q1 ka lungbuei khui ah hmai la alh.
\q1 ka rhang dong ah ha tuen.
\q1 
\v 2 Thang thui he Khrihca hil nah ni,
\q1 Krihca hing nah yilh ni
\q1 Dueknah hmuen ah khoemdawn kung tih,
\q1 vaan la luei puei kung ni.
\q1 
\v 3 Thang thui he a mah bueng moe nih,
\q1 CimMueihla neh vaan kah
\q1 Dungyan Jesuh hlang tholh ham la
\q1 thangthui kung taeng ah m'bih.
\q1 
\v 4 Aw Pathen nang taeng ka lo uh,
\q1 Nang kah hingnah oltak
\q1 Na long pueina cong hol nen te
\q1 Thang thuinah he n'cang sak.
\c 303
\s1 Pathen Nang Taeng Ka Yoei
\s2 Nearer My God To Thee
\sp Doh is G
\q1 
\v 1 Pa then nang taeng ka yoei na taeng ka yoei,
\q1 Rhih om tangkik dueknah ka tong cakhaw,
\q1 Ka sak ham ko laa tah Ka Kho hni taeng ka yoei,
\q1 Ka Kho hni taeng ka yoei na taeng ka yoei.
\q1 
\v 2 Long hmang hlang bang lamni kho loh tla coeng,
\q1 Yinnah loh thing khup tih long dong ka duem,
\q1 Yin ka muei mang ah khaw, Namah neh yoei ka ngaih,
\q1 Ka Pathen taeng ka yoei na taeng ka yoei.
\q1 
\v 3 Ka long puei tueng sak lah van la luei nah,
\q1 Na lung vat rhennah te kai taeng nan tueih,
\q1 van hlang ka taeng a om, Ka Pa then taeng ka yoei,
\q1 Ka Pathen taeng ka yoei na taeng ka yoei.
\q1 
\v 4 Ka ko khui ah ha thoeng namah koeh nah,
\q1 Rhainah lung to ke Be thel la ha coeng,
\q1 Rhainah ka tong cakhaw, Ka Pa then taeng ka yoei,
\q1 Ka Pathen taeng ka yoei na taeng ka yoei.
\c 304
\s1 Khangkung Kodo Kai Caeh Tak Boeh
\s2 Pass Me Not
\sp Doh is Ab
\q1 
\v 1 Khang kung ko do kai n'caeh tak boeh,
\q1 Ka pang ol han yaa.
\q1 Hlang tloe khaw na khue van vaengah,
\q1 Kai he n'rhael mai boeh.
\q2 \qt Khang boei Jesuh ka pang ol han ya. \qt*
\q2 \qt Hlang tloe khaw na khue van vaeng ah \qt*
\q2 \qt Kai he n'caeh tak boeh.\qt*
\q1 
\v 2 Na rhen nah ngol khoel taengla m'mawt,
\q1 Ngai mongnah te m'pae
\q1 Tholhyutnah neh kan bih vaengah,
\q1 kai he n'rhael mai boeh.
\q1 
\v 3 Na thennah bueng te ka uepnah,
\q1 Na muei hmuh ka ngaih,
\q1 Ka mueihla tlohnah han hoeih sak,
\q1 Na rhennah neh n'khang.
\q1 
\v 4 Nang ni ka ngai mongnah tui cil,
\q1 hingsoepnah la om.
\q1 Nang mueh atah diklai ah he,
\q1 Ka uepnah ompawh.
\c 305
\s1 Boeipa Na Yoethen Ol Ka Yaak
\s2 Even Me
\sp Doh is G
\q1 
\v 1 Boeipa na yoethen ol ka yaak,
\q1 kai soah nan lun thil te,
\q1 Rham rhae ram na sai hing sak te,
\q1 kai van khaw han tlan sak lah,
\q1 Kai van khaw kai van khaw,
\q1 ka soah han tlan sak lah.
\q1 
\v 2 Pathen a pa kai n'caeh tak boeh,
\q1 ka lungbuei tholh mai cakhaw,
\q1 Kai he n'caeh tak boel mai lamtah,
\q1 kai soah he n'rhen mai lah,
\q1 Kai van khaw kai van khaw,
\q1 kai so ah he n'rhen mai lah.
\q1 
\v 3 Khangkung kodo kai caeh tak boeh,
\q1 lungnah neh yoei ham ka ngaih,
\q1 Na ko lonah te ka ngaidam,
\q1 Na ngaih bangla n'khue mai lah,
\q1 Kai van khaw kai van khaw,
\q1 na ngaih bang la n'khueh mai lah.
\q1 
\v 4 Aw Muei hla Cim kai n'caeh tak boeh,
\q1 mik dael khaw kho han hmuh sak,
\q1 Khrih yueng laipai la om ham la,
\q1 Na ol te han thui van lah,
\q1 Kai van khaw kai van khaw,
\q1 na ol te han thui van lah.
\c 306
\s1 Jesuh Loh Mamih n’rhingah Dum
\s2 The Beautiful Garden Of Prayer
\sp Doh is D
\q1 
\v 1 Jesuh loh ma mih n'rhing nah dum te om,
\q1 Aka then tang kik mai dum te om.
\q1 Boeipa a om dongah soep rhaep boeih vang.
\q1 Om then koek thang thui nah dum la om.
\q2 \qt Aw omthen hlang thangthuinah dum\qt*
\q2 \qt thangthuinah dum, \qt*
\q2 \qt Aw omthen tangkik thangthui na dum\qt*
\q2 \qt khangkung loh n'rhing uh pueng, \qt*
\q2 \qt thohka te a ong coeng \qt*
\q2 \qt ke kah om then thang thui na dum ah. \qt*
\q2 \qt then hlang thang thui nah dum dum la om.\qt*
\q1 
\v 2 Jesuh loh mamih n'rhing nah dum te om,
\q1 Tholh thinrhih neh kun na dum la om.
\q1 Boeipa hmui ka lam kah hloep ol ka yaak.
\q1 Aka then thangthui nah dum khui ah.
\q1 
\v 3 Jesuh loh mamih n'rhing nah dum te om,
\q1 Amah neh hum uh ham nang khaw n'khue
\q1 A hmai ah kuep lam ngai mongnah pang lah,
\q1 Omthenhlang thangthuinah dum khui ah.
\c 307
\s1 Mamih Tholh Ah Patangkhang Kung
\s2 What A Friend We Have In Jesus
\sp Doh is F
\q1 
\v 1 Ma mih tholh ah pa tang khang kung
\q1 pa ya then tah Jesuh ni
\q1 Amah taengah kongaih nah boeih
\q1 bih mueh la om uh dong ah
\q1 Ngaimong nah loh a bawt vaeng ah
\q1 kothae nah boeih te a ming
\q1 kothae nah boeih a ka phuei kung
\q1 Pa then taeng ah thangthui uh.
\q1 
\v 2 Tholh ah cuek halh nah na n'tong a?
\q1 A soep rhaep na ngai hmang a?
\q1 Thinko te mah bawt sak boel sih,
\q1 Pathen taeng ah thangthui uh,
\q1 Tholh patang nah a ka ueh kung
\q1 Paya then a tloe om pawh,
\q1 Vawtvai nah Jesuh loh a ming,
\q1 Boeipa taeng ah thangthui uh.
\q1 
\v 3 Na hno rhih tih na tha hnoeng a?
\q1 Na kothae na ko bawt a?
\q1 Mamih uep nah a kung la om,
\q1 Boeipa taeng ah thangthui uh,
\q1 Paya loh caeh tak u vaeng ah,
\q1 Boeipa taeng ah thangthui uh,
\q1 A kut neh n'loh ve tih m'pom ni,
\q1 Ngai mong la na om pawn ni.
\c 308
\s1 Pathen Pangtung A Ca Bangla
\s2 Remember Me
\sp Doh is F
\q1 
\v 1 Pathen pangtung a ca bang la,
\q1 A mik neh longpuei n'tueng te pangtung.
\q1 Hing khui yoethen na ham pangtung,
\q1 he rhoek boeih m'paek ngai ni.
\q2 \qt Han thui bang amah pangtung.\qt*
\q2 \qt Hintakuem a mah te dan lah, \qt*
\q2 \qt Pathen mah pangtung, \qt*
\q2 \qt Pathen mah pangtung, \qt*
\q2 \qt nang a ka khoom kung la khueh.\qt*
\q1 
\v 2 Pathen pangtung ngai hmang na ah,
\q1 A mah pangtung rhen na neh puei uh.
\q1 Hlipuei lakli ah uepnah lah
\q1 Hlipying nah te m'paek ni.
\q1 
\v 3 Pathen pangtung. ngaihmang vaeng ah,
\q1 A mah uep nah thinphat dip na ham.
\q1 Na hno a rhih vaeng ah pangtung
\q1 Thaom nah a khue te.
\q1 
\v 4 Pathen pangtung longhla vaeng ah,
\q1 A rhennah kutdoe then na dang ni.
\q1 Tahae khue ol yaak due pangtung
\q1 Vaan ah tong uh rhoi ham.
\c 309
\s1 Yoeyah Namah Kan Ngoe
\sp Doh is F
\q1 
\v 1 Yoeyah namah kan ngoe, Boethen Boeipa,
\q1 Namah ol ding bangla mongnah om pawh
\q2 \qt Kan ngoe boeipa nang kan ngoe\qt*
\q2 \qt a yoe yah nang kan ngoe\qt*
\q2 \qt Tahae yoethen na m'pae lah na taeng ka lo. \qt*
\q1 
\v 2 Yoeyah namah kan ngoe, ha yoei lah saw,
\q1 Cuekhalh ka tong vaengah Ka na thai pawh.
\q1 
\v 3 Yoeyah namah kan ngoe, a soeprhaep ah,
\q1 Nang na om pawt atah, hing phu ompawh.
\q1 
\v 4 Yoeyah namah kan ngoe, na kongaih te,
\q1 Hnin takuem ah saii ham, koi n'thuituen lah.
\q1 
\v 5 Yoeyah namah kan ngoe, Aka cim koek,
\q1 Na hlang la kai n'coeng sak. Kho capa nang.
\c 310
\s1 Yoeyah Nang Kai Ham
\s2 Close To Thee
\sp Doh is G
\q1 
\v 1 Yoeyah nang kai ham khohmuen then,
\q1 huitai then lakah tlo ngai,
\q1 Vaan dong longpuei ka caeh li ah,
\q1 Boeipa namah loh m'mawt lah.
\q1 Na taengah na taengah
\q1 na taengah na taengah,
\q1 Vaan dong long puei ka caeh li ah
\q1 Boeipa na mah loh m'mawt lah.
\q1 
\v 2 Lai boeirhaeng neh omthennah boeih,
\q1 Ming thennah khaw kan bih pawh,
\q1 Patangnah ah kohoenah ham,
\q1 namah neh caeh hmaih ka ngaih.
\q1 Na taengah na taengah
\q1 na taengah na taengah
\q1 Patang nah ah kohoe nah ham
\q1 namah neh caeh hmaih ka ngaih.
\q1 
\v 3 Khoyinnah ah nang loh m'mawt lah,
\q1 Tuili puei khaw n'kat puei lah,
\q1 Yoeyah hingnah thohka due la,
\q1 Boeipa na mah loh m'mawt lah.
\q1 Na taengah na taengah
\q1 na taengah na taengah
\q1 Yoeyah hingnah thoh ka due la,
\q1 boeipa namah loh m'mawt lah.
\c 311
\s1 Aw Ka Pathen Ka Im Lamkah
\s2 Thy Will Be Done
\sp Doh is Ab
\q1 
\v 1 Aw ka Pathen ka im lamkah,
\q1 khohla la long puei ka hmang vaeng,
\q1 ka lungbuei ah he ol n'caeng sak
\q1 Na ko ngaih saeh
\q2 \qt Na mah kongaih nah ha soep saeh,\qt*
\q2 \qt ka lung buei ah cang puei\qt*
\q2 \qt namah kongaih soep saeh. \qt*
\q1 
\v 2 Pa ya om kolla ka om dam,
\q1 hlaemhmah khoyin ko thae vaengah,
\q1 ka lungbuei ah ka thui ham tah
\q1 Na ko ngaih saeh
\q1 
\v 3 Ka thin loh yaai sut mai cakhaw,
\q1 Mueihla Cim ol ding te ka yaak,
\q1 ka Pathen bueng ni ka duemnah
\q1 Na ko ngaih saeh
\q1 
\v 4 Vuen hlaem ka tha han hlue sak lah,
\q1 Namah taeng ah kai n'om sak lah,
\q1 Te lungbuei loh a thui ham tah,
\q1 Na ko ngaih saeh
\c 312
\s1 Ka Hingnah Im then Boeipa
\s2 Every Day And Hour
\sp Doh is Ab
\q1 
\v 2 Ka hingnah im then boeipa
\q1 na mah taengla voeh voeh ah ka yoei,
\q1 A phu tlo na thii neh n'sil,
\q1 na mah taeng ah yoe yah la n'yoei sak.
\q2 \qt Vuen hlaem ah hnin takuem\qt*
\q2 \qt na thi phu tlo m'ming sak lah,\qt*
\q2 \qt na boethen lungnah rhui neh\qt*
\q2 \qt Na mah neh yoei hamla m'pin lah saw. \qt*
\q1 
\v 3 Tho vael nah diklai a he,
\q1 na mah loh a yai la kai m'mawt lah,
\q1 Namah te kan uepnah tih,
\q1 ka longpuei te ka hmang voel mah pawh.
\q1 
\v 4 Ka hingnah a bawt duela,
\q1 nang ta aep kan lungnah ham ka ngaih,
\q1 lungnah dong ka buek vaengah
\q1 kho sae then te ka hmuh so ben ah.
\c 313
\s1 Ka Khangkung Boei Tah Kai Hamla
\s2 I Am Praying For You
\sp Doh is Bb
\q1 
\v 1 Ka khang kung boei tah kai hamla thangthui tih,
\q1 lai hman kah pa ya lak ah kai n'lung nah ngai.
\q1 Lunghoeih na boeih neh a dawn kung khang kung boei te,
\q1 Aw nang ham ni khang kung boeipa te om van.
\q2 \qt Nang ham ka thang thui\qt*
\q2 \qt ka thang thui ka thang thui \qt*
\q2 \qt nang hamla ka thang thui \qt*
\q2 \qt nang hamla ka thang thui. \qt*
\q1 
\v 2 Dungyan ngaiuepnah pae kung a ka then koek pa
\q1 Pathen ka khueh. A di hlan kah tue ah
\q1 Amah neh hum ham kai te van la n'khue vaengah
\q1 Aw nang neh khaw hmai ah caeh rhoi ham om coeng.
\q1 
\v 3 Ka khueh himbai bok a ka then tang kik loh
\q1 boeilen omthen nah van dong ah kai te n'rhing
\q1 Te ka pang vaengah tah soep rhaep a ka vaeng te,
\q1 Paya nang loh na dang hmuh hamla ka ngaih.
\q1 
\v 4 A mah loh hmuh vaeng ah hlang taeng ah thui lah,
\q1 Ka khang kung te nang khang kung boei la om van
\q1 Thang thui nah mah khueh pah a mah loh a mawt ni,
\q1 Na thang thui te na bing bangla han rhoi ni.
\c 314
\s1 Thangthuinah Tue Omngaihnah Ni
\s2 Sweet Hour Of Prayer
\sp Doh is D(Slowly)
\q1 
\v 1 Thangthuinah tue omngaihnah ni,
\q1 ngaithuennah ram lamkah kai n'khue
\q1 Vaandong a pa ngol nah hmai ah,
\q1 ka ngoe ngaih na te ka bih tih
\q1 kothae ngaihmang muei ha yal vaeng
\q1 ka mueihla loh a ngai mong nah.
\q1 cuek halh dong rhui lam loh n'loeih sak
\q1 thang thui nah tue then om dong ah.
\q1 
\v 2 Thang thui nah tue omngaihnah ni,
\q1 na phae loh kai vaan la m'pom sang
\q1 Oltak neh uep om la ka om,
\q1 yoethen khueh kung boeipa taeng ah,
\q1 A hmai tlap ham a ol tang nah,
\q1 a rhen lung nah uep nah hma thui,
\q1 Ka ko ngaihmang nah boei te tah
\q1 a mah taeng ah ka hal pawn ni.
\q1 
\v 3 Thangthuinah tue om ngaihnah ni,
\q1 Na ngaimongnah te kai m'hmuh sak,
\q1 Mol dong tlang som ka ka im ke,
\q1 ka dan phai tih koep ka pha due,
\q1 He ka pumsa himbai he tah,
\q1 He diklai ah ka dul ve tih,
\q1 Pathen taeng ah ka caeh vaeng ah
\q1 thang thui na tue khaw bawt pawn ni.
\c 315
\s1 Thangthui Tue Yoethennah Ni
\s2 Tis’ The Blessed Hour Of Prayer
\sp Doh is Eb
\q1 
\v 1 Thang thui tue yoe thennah ni,
\q1 thin ko ka paek vaengah,
\q1 Jesuh khangkung paya then taengah n'tun vaengah,
\q1 Tangnah neh m'paan uh atah,
\q1 a hoep tlang nah pang ham,
\q1 la kueng ngai hmang dip nah ni,
\q1 Te tue di dip tangkik.
\q2 \qt Thangthui yoethennah, \qt*
\q2 \qt Thangthui yoe thennah, \qt*
\q2 \qt Ngai hmang nah dip sak kung ni \qt*
\q2 \qt te tue di dip tang kik.\qt*
\q1 
\v 2 Thang thui tue yoe thennah ni,
\q1 khangkung neh n'yoei vaengah,
\q1 A hlang rhoek loh rhen nah ol a yaak uh vaengah.
\q1 Mamih la kueng nah boeih te,
\q1 a taengah tloeng uh tih,
\q1 la kueng ngai hmang dip nah ni,
\q1 Te tue di dip tangkik.
\q1 
\v 3 Thang thui tue yoe thennah ni,
\q1 cuekhalhnah tue vaengah,
\q1 Khangkung kah lungnah loh lakuengnah a hma sak
\q1 Amah kah thintlohnah loh,
\q1 ngaihmangnah a khoe boeih
\q1 la kueng ngai hmang dip nah ni,
\q1 Te tue di dip tangkik.
\q1 
\v 4 Thang thui tue yoe thennah ni,
\q1 Tangnah a cak atah,
\q1 Yoethen m'bih te a tak la m'hmuh u van pawn ni.
\q1 Oltak la m'hmae uh vaengah
\q1 hnorhih boeih n'hal uh ni
\q1 la kueng ngai hmang dip nah ni,
\q1 Te tue di dip tangkik.
\c 316
\s1 Lungbuei Lakueng Rhoek Boeih
\s2 Wait And Murmur Not
\sp Doh is C
\q1 
\v 1 Lungbuei la kueng hlang rhoek boeih aw,
\q1 pa tang nah mueh im vaan ah om,
\q1 Ke im ah tho vael nah om pawh,
\q1 duem na te khaw a bawt mah pawh.
\q2 \qt Rhing dae lunguen mueh la rhing mai dae,\qt*
\q2 \qt rhing dae lung uen mueh la rhing mai dae \qt*
\q2 \qt rhing dae rhing dae\qt*
\q2 \qt lung uen mueh la rhing mai dae.\qt*
\q1 
\v 2 Diklai ah hno thinrhih cakhaw,
\q1 Nang loh vaan ram ni na tuek coeng,
\q1 Ke kah im then ke dan van lah,
\q1 rhing dae lunguen kolla rhing dae.
\q1 
\v 3 Na long puei ah hling om cakhaw,
\q1 Boeipa kah hling lu muek poek lah,
\q1 Amah kah thinphat te ming lah,
\q1 nang cimnah aka pha sak te.
\q1 
\v 4 Na tha tlo tih na tawn cakhaw,
\q1 Thang thui na te mah khueh van lah,
\q1 A tue then ha sae nang hamla kodo neh
\q1 rhing dae lung uen boeh.
\c 317
\s1 Aw Boeipa Hnatun Lah
\s2 O My Saviour, Hear Me
\sp Doh is F
\q1 
\v 1 Aw boeipa hnatun lah na taengla n'yoei sak.
\q1 Ka lai ba nan sah tih kai hamla na duek.
\q1 Lung hoih la ka tangnah vaeng ah,
\q1 na ming neh tholh hlah nah ka hm uh.
\q1 Nang ni ka sueng nah na taengla lo ka ngaih.
\q1 
\v 2 Aw boeipa yoethen m'pae ka thangthui vaeng ah,
\q1 Na rhennah neh m'bom lah ka rhih nah hma sak.
\q1 Boeipa na ol khueh ka tang nah,
\q1 na ol cim te khaw ka uep nah.
\q1 Ka mueihla tlan kung nang, yoe then nah m'pae lah.
\q1 
\v 3 Aw boeipa kai n'lung nah na ngaih bang la n'khueh.
\q1 Ka mah bueng ka om ham sut n'caeh tak mai boeh.
\q1 Na vang na cim neh longpuei n'tueng,
\q1 na boeilen loh kai m'vael lah saeh.
\q1 Ka ying nah lung nu nang,
\q1 namah ham m'hmoel lah.
\q1 Aw khang kung kai n'dawn dah n'khoem bael yoe yah lah.
\q1 N'lung na lam yoethen m'pae
\q1 Na ming koeh na ham.
\q1 Kohoe nah neh ka tho la eh,
\q1 na boeilen nah van ah thui ham,
\q1 Te ah nang khang kung neh, dungyan ka om ham.
\c 318
\s1 A Capa Boei Jesuh Aka Tangnah Rhoek
\s2 Hallelujah! Tis Done
\sp Doh is G
\q1 
\v 1 A ca pa boei Jesuh aka tangnah rhoek ham,
\q1 Pa then kah khangnah soep he ol a khueh pacoeng.
\q1 
\v 2 Long puei te rhai tih rhih hamla om bal ca khaw,
\q1 Jesuh amah loh kai te m'mawt tang tang pawn ni.
\q2 \qt (Ha le lui jah boeih coeng.\qt*
\q2 \qt A capa ka tangnah , \qt*
\q2 \qt A tai uh hlang thisen neh \qt*
\q2 \qt kai te tah n'khang coeng)\qt* \sup 2\sup*
\q1 
\v 3 Lungnah thin tlo koei na rhoek neh van la n'cet uh,
\q1 Boeilennah neh om uh tih he laa a sak uh.
\q1 
\v 4 Camoe rhoek mang kah a hmai a pai te ka hmuh,
\q1 Mik hmai hlam pan la khangnah laa te a sak uh.
\q1 
\v 5 Te hmuen ah manghai mah neh tung hma rhoek ka hmuh,
\q1 Sui long puei long ah nawt nawt ah a khong uh te.
\q1 
\v 6 Te kah laa a sak uh te nang neh kai ham khaw,
\q1 mamih kah thangthennah tah dungyan due ham.
\c 319
\s1 Kuirhang Im Then Thohkah Kaengah
\s2 Carried By The Angels
\sp Doh is Ab
\q1 
\v 1 Kuirhang imthen thohka kaeng ah te ngol tih,
\q1 Pathen kah a ca loh duek tom coeng.
\q1 Diklai boei rhaeng khueh tawn khaw om van pawt dae
\q1 vaan dongah tah omngaihnah a dang.
\q2 \qt Duem nah ram then la vaan hlang loh a caeh puei.\qt*
\q2 \qt Phungding laa then ol neh khawk ah bae, \qt*
\q2 \qt Vaan buhloei kung ah khang kung boeih loh a doe, \qt*
\q2 \qt a lung nah hlang neh vaan ah tun uh.\qt*
\q1 
\v 2 Tahae ning kah hing he me tlam a bawt eh,
\q1 tih ol dawt nah n'taeng ah ha lo khing.
\q1 He long puei kah hno rhih phueihnah boeih boeih neh
\q1 kothae mikphi bo na boeih boeih he.
\q1 
\v 3 Jesuh hnuk bang rhoek loh sungdaeh mai cakhaw
\q1 A kum ngai tah vaan dong ah om coeng.
\q1 Toek lek toek na om ngaihnah vaan m'hmuh vetih
\q1 vuen hlaem thovael nah loh om pawn ni.
\q1 
\v 4 Pathen bi bi dongah hmai ben la cawh lah
\q1 Na tue thoem thai nah te hno na lah
\q1 Na bi nah yiit cakhaw kutdoe long tah yet.
\q1 Thing lam te suilukhuem la coeng ni.
\c 320
\s1 Ka Ngaiuepnah A Kung Te Cak
\s2 The Solid Rock
\r Tng 125:1
\sp Doh is G
\q1 
\v 1 Ka ngaiuepnah a kung te cak,
\q1 Jesuh thiisen cim dong ka sak.
\q1 A tloe uep pang nah then om pawh,
\q1 Jesuh ming dong boeih ka hangdang.
\q2 \qt Khrih lung nu puei dong ah ka om,\qt*
\q2 \qt a tloe pai hmuen then om tlaih pawh, \qt*
\q2 \qt A tloe pai hmuen then om tlaih pawh.\qt*
\q1 
\v 2 Lung nah mael hmai yin loh a hlip,
\q1 a lung vatnah dong ah ka duem,
\q1 Hli puei tui let tho mai ca khaw,
\q1 Ka uep nah a yung long tah cak.
\q1 
\v 3 A olkhueh neh a thi sen loh,
\q1 tuilen khui lam kah kai loeih sak,
\q1 Cuekhalhnah loh m'vael khoep cakhaw,
\q1 Amah ni ka uepnah kung puei.
\q1 
\v 4 Olueng ol te a tum vaeng ah,
\q1 a hmai ben ah ka pai pawn ni,
\q1 Duengnah neh a thoeihcam vaengah,
\q1 tholhkung sutnah om voel mahpawh.
\c 321
\s1 Boeipa Jesuh Olkhueh Dongah Ka Pai
\s2 Standing On The Promise
\sp Doh is Bb
\q1 
\v 1 Boeipa Jesuh olkhueh dong ah kai ka pai
\q1 Amah te ta a yoe yah ka thangthen sak.
\q1 So sang koek ah thangthennah om saeh ka ti,
\q1 Pa then kah olkhueh dong ah ka pai.
\q2 \qt Ka pai ka pai Ka khang kung \qt*
\q2 \qt Pathen kah olkhueh dong ah ka pai, \qt*
\q2 \qt Ka pai ka pai khang kung \qt*
\q2 \qt boei kah olkhueh dong ah ka pai. \qt*
\q1 
\v 2 Aka dalh pawh olkhueh dong ah kai ka pai,
\q1 Rhih om la kueng hli puei loh n'yawn mai ca khaw,
\q1 A yoe yah Pathen ming neh ka na buet ni
\q1 Pathen kah ol khueh dong ah ka pai.
\q1 
\v 3 Amah ol khueh dong ah ka pai te ka ming,
\q1 A thiisen dong ah cim caih nah ham boeih soep.
\q1 Khrih kah a paek sayalh nah dong ah ka pai,
\q1 Pathen kah ol khueh dong ah ka pai.
\c 322
\s1 Aw Ka Jesuh Ka Mueihla Loh
\s2 None But Christ Can Satisfy
\sp Doh is F
\q1 
\v 1 Aw ka Jesuh ka Mueihla loh
\q1 namah dong bueng ah ni.
\q1 Omngaih ngaimong ka tlap khing te
\q1 tahae daeng ah ka hm uh.
\q2 \qt Khrih ming mueh a tah ngai khuek nah\qt*
\q2 \qt ming then a tloe om pawh. \qt*
\q2 \qt Lung nah, hing nah, dung yan om ngaih\qt*
\q2 \qt Jesuh dong ah ka hm uh.\qt*
\q1 
\v 2 Omthen bawnnah buen te ka dan
\q1 namah te poek mueh la
\q1 Ka khang kung boei ka rhael vaeng ah
\q1 a lung nah rhui neh khih.
\q1 
\v 3 Tui phuet te ka hmuh ka ti dae
\q1 aw Boeipa vik kak boeih
\q1 Tui puei then tui ka ok van dae
\q1 kai loh ka tahah sut.
\q1 
\v 4 Omngaihnah loh bawt tih
\q1 ka rhap namah te poek kol la,
\q1 Lungvatnah neh mik na tueng sak
\q1 na lungnah muei ka hm uh.
\c 323
\s1 Uepvawtnah Boeih Jesuh Ka Paek
\s2 Fully Trusting
\sp Doh is F
\q1 
\v 1 Uepvawtnah boeih Jesuh ka paek,
\q1 a ol khueh phu tlo ka khueh,
\q1 Kai ka ngaihmang tlaih voel mahpawh,
\q1 A mah ol ka uep nah coeng.
\q2 \qt A soep ca la ka uepnah coeng\qt*
\q2 \qt a ol khueh te ka uep nah\qt*
\q2 \qt A soep ca la ka uep nah coeng\qt*
\q2 \qt a ol khueh te ka uep nah.\qt*
\q1 
\v 2 Ka tholh boeih Jesuh pum ka hal,
\q1 a thisen neh kai n'silh coeng,
\q1 Cimcaih cala kai n'khueh vetih,
\q1 A im la kai n'caeh puei ni.
\q1 
\v 3 Ka rhihyawpnah Jesuh ka paek,
\q1 ka lakuengnah loh boeih dip,
\q1 Ka longpuei kho yin khoep ca khaw,
\q1 A vangnah te hlip thai pawh.
\q1 
\v 4 Ka omngaihnah Jesuh ka paek,
\q1 amah bueng ni ka ngaih koek
\q1 He diklai pum amah koe ni,
\q1 Ka ngoe ngaihnah boeih a khueh.
\q1 
\v 5 Ka soeprhaep boeih Jesuh ka paek,
\q1 Ka pum neh ka mueihla boeih,
\q1 Khuehtawn boeih neh ka ngai uepnah,
\q1 Jesuh taengah ka thung boeih.
\c 324
\s1 Uepnah Uepna
\s2 Trust Him
\sp Doh is F
\q1 
\v 1 Uepnah uepnah Khrihca
\q1 rhoek rhaltuknah sen cakhaw
\q1 nangmih loh na na duel
\q1 la Pathen loh m'bom bit ni.
\q2 \qt Uep nah uep nah\qt*
\q2 \qt rhihnah kho yin ca khaw, \qt*
\q2 \qt Uep nah uep nah\qt*
\q2 \qt thuipa ha thoeng tom coeng.\qt*
\q1 
\v 2 Uepnah lah rhal lakli
\q1 cuekhalhnah loh yet cakhaw,
\q1 Rhih om hing nah khui lam
\q1 kah Pathen loh m'bom ngai ni.
\q1 
\v 3 Boeipa tah tlankung thai
\q1 neh uepom pa ya then ni,
\q1 Uepnah uepnah Khrih ca
\q1 rhoek a bawt duela uepnah.
\c 325
\s1 Vaan Dong Im Thinglam Neh
\s2 The Way Of Cross Leads Home
\sp Doh is Ab
\q1 
\v 1 Vaan dong im thinglam neh caeh hamla a ngoe.
\q1 Longpuei a tloe om tlaih pawh.
\q1 A vang thohka then ka pha thai mah pawh,
\q1 thinglam longpuei ka hmang a tah.
\q2 \qt Vaan long puei thinglam tai ni,\qt*
\q2 \qt vaan long puei thing lam tai ni. \qt*
\q2 \qt Ka caeh li vaeng ah caeh ko dik dik tui, \qt*
\q2 \qt vaan long puei tah thing lam ni.\qt*
\q1 
\v 2 Thisen a cip nah longpuei vai ham a ngoe.
\q1 Khangkung kung a caeh nah longpuei.
\q1 A so ben kah kho la ka luei vaeng ah,
\q1 Pathen taengah ka mueihla om.
\q1 
\v 3 He diklai longpuei he ka phih ka rha coeng,
\q1 koep ka cet tlaih voel mahpawh.
\q1 Ka im ka tlap vaeng Boeipa loh n'khue tih,
\q1 Vaan thoh ka a ong tih kai n'rhing.
\c 326
\s1 Khangkung Khrih Taeng
\s2 Face To Face
\sp Doh is Bb
\q1 
\v 1 Khang kung Khrih taeng
\q1 hlam pan ca la ka mael poek van ve nim.
\q1 A mah khue nah la ka mael hang,
\q1 Kai ham ka duek Khrih taeng ah.
\q2 \qt A hmai ah amah te ka dan,\qt*
\q2 \qt vaan ai si kah a voel ah, \qt*
\q2 \qt A boei a mang boeih te khaw \qt*
\q2 \qt ka hmuh pawn ni vuenvai ahtah.\qt*
\q1 
\v 2 Hmai thi khaw kak boeih ah kak tih,
\q1 yinnah loh a hlip dae,
\q1 A boeilenmik hmai m'hmuh vaengah,
\q1 kho hnin then ha pai pawn ni.
\q1 
\v 3 Ko thae ngaihmang a boeih vaengah,
\q1 omngaihnah soep pawn ni,
\q1 Yinnah loh a boeih vaengah tah
\q1 long thae caeh kael bawt pawn ni.
\q1 
\v 4 Hmuh tunnah a tue om then koek,
\q1 thikatla mingnah tue,
\q1 Tlan kung boei neh hum tun tue,
\q1 Lung vat kung Jesuh neh humnah.
\c 327
\s1 Boei Jesuh Nang Ni Kan Uepnah
\s2 I Am Trusting Thee, Lord Jesus
\sp Doh is Bb
\q1 
\v 1 Boei Jesuh nang ni kan uep nah,
\q1 nang bueng kan uep nah.
\q1 A yoe paek khang nah a ka len koek ham khaw.
\q2 \qt Nang kan uep nah,\qt*
\q2 \qt nang ni kan uep nah. \qt*
\q2 \qt nang bueng ni kan uep nah. \qt*
\q2 \qt nang bueng kan uep nah. \qt*
\q1 
\v 2 Tholh rhen kung nang ni kan uep nah,
\q1 na kho kung ka kuep
\q1 Na lungvat nah neh na rhen nah tlo koek te,
\q1 
\v 3 Tholh cim nah ham nang kan uep nah,
\q1 Na thisen long ni kai he
\q1 cim caih sak thai la a om thai eh.
\q1 
\v 4 Nang kah na tha om ka uep nah,
\q1 Nang na yawk tlaih pawh,
\q1 Ka taeng ah nan thui ham na ol ham phong lah.
\q1 
\v 5 Boei Jesuh nang ni kan uep nah.
\q1 Nan tlim sak mah pawh,
\q1 Soeprhaep boeih ah nang te dung yan kan uep nah.
\c 328
\s1 Ka Longpuei ah Khangkung Loh Mawt
\s2 All The Way My Saviour Leads Me
\sp Doh is Ab
\q1 
\v 1 Ka long puei ah khangkung loh m'mawt,
\q1 ba ol nim ka ngoe pueng eh
\q1 A rhen lungnah neh kai mawt kung
\q1 uepvawt nah ka khueh a ya?
\q1 vaan dong kho hoe ngaimongnah te
\q1 tangnah neh tahae ka hmuh,
\q1 ka soah rhainah boeih boeih he,
\q1 Jesuh loh then la ham poek
\q1 ka so ah rhai nah boeih boeih he
\q1 Jesuh loh then la ham poek.
\q1 
\v 2 Ka long puei ah khang kung loh m'mawt,
\q1 rhainah ah om ngaihnah m'paek
\q1 Kho daeng ka ming vaengah kai rhen
\q1 hing nah vai dam te kai m'paek
\q1 ka caeh li ka tha loh hoeng tih
\q1 ka mueihla tui hal cakhaw,
\q1 ka hmai kah lung nu khui lamkah,
\q1 om ngaihnah tui long ka hmuh
\q1 ka hmai kah lungnu khui lam kah
\q1 omngaihnah tui long ka hm uh.
\q1 
\v 3 Ka long puei ah khang kung loh m'mawt,
\q1 Aw a lungna neh bae tawt,
\q1 Kai ham duemnah then koek a khueh
\q1 vaan dong kah a pa im ah,
\q1 Ka mueihla a thoeih a cam tih,
\q1 vaan la ka pom sang hnin ah,
\q1 dungyan due ka sak ham laa tah,
\q1 Long puei ah Jesuh loh m'mawt
\q1 dung yan duek ka sak ham laa tah
\q1 longpuei kihg Jesuh loh m'mawt.
\c 329
\s1 Yoethen Rhotui Te tah Tlan Ni
\s2 There Shall Be Showers Of Blessing
\sp Doh is Bb
\q1 
\v 1 Yoethen rhotui te tah tlan ni,
\q1 he tah lung nah olkhueh ni,
\q1 Kho tue then khaw ha lo bal
\q1 ni vaan khang kung loh han tueih te.
\q2 \qt Yoethen nah rhotui yoethen rhotui ka ngaih uh.\qt*
\q2 \qt Lungvat nah kho loh tlan li coeng, \qt*
\q2 \qt Rhotui tlan thim ka phoe uh.\qt*
\q1 
\v 2 Yoethen rhotui te tah tlan ni,
\q1 cangti bael lung koep thoo ni,
\q1 Tlang som neh tuiko boeih boeih ah
\q1 rhotui tuen ol te ha lo.
\q1 
\v 3 Yoethen rhotui te tah tlan ni,
\q1 Kai mih taeng han tueih Boeipa
\q1 Kai mih taeng thokoep nah m'pae lah
\q1 na ol cim ha lo lah saeh.
\q1 
\v 4 Yoethen rhotui te tah tlan ni,
\q1 Te kho hnin tah ham pha coeng
\q1 Pathen taeng ah tholh m'phong uh tih
\q1 Jeuh boeipa te m'phoe uh.
\c 330
\s1 Boeipa Boeirhaeng Khuehtawn
\s2 Is My Name Written There?
\sp Doh is C
\q1 
\v 1 Boeipa boei rhaeng khueh tawn neh sui ngun khaw kan bih pawh,
\q1 vaan ram ke hmuen ni poek ka ngaih, na vong khui ah ka kun,
\q1 na vaan cabu cim dongah kai ming a daek coi a?
\q1 Khang kung Jesuh han thui lah ka ming a daek coi a?
\q1 Te kah cahmai bok neh van dong ca bu dong ah
\q1 kai kah ming a daek coi a? ka ming a daek coi a?
\q1 
\v 2 Boeipa ka tholh ba hoeng yet, tui kaeng lai vin bangla,
\q1 Tedae na thi sen cim te kaihamla bahoeng rhoeh.
\q1 Na ca khueh bu cim ah kai ham ol na khueh sut te tah,
\q1 na tholh thim duk mai cakhaw vuel song bang la bok ni,
\q1 Te kah cahmai bok neh van dong cabu dong ah
\q1 kai kah ming a daek coi a? ka ming a daek coi a?
\q1 
\v 3 Aw te kho puei then a vang tah vangnah neh lum im soep,
\q1 boeilen nah a sui bai bok neh a thoeih cam u te,
\q1 tholh hno thae khaw om voel pawh, rhihnah khaw om voel pawh,
\q1 Vaan cael tueih loh a dawn tih, Oe ka ming a daek coeng,
\q1 Te kah cahmai bok neh van dong ca bu dong ah
\q1 kai kah ming a daek van coeng, ka ming a daek van coeng.
\c 331
\s1 Me Hmuen Khaw Jesuh Neh
\s2 Anywhere With Jesus
\sp Doh is D
\q1 
\v 1 Me hmuen khaw Jesuh neh a mong la ka cet.
\q1 He diklai khui ah khaw amah loh n'hoi haeng,
\q1 Amah mueh tah ka omngaihnah loh tlum tloi.
\q1 Jesuh omnah hmueh a tah rhihnah ompawh.
\q2 \qt Me lam khaw me lam khaw\qt*
\q2 \qt rhih nah ka khueh pawh. \qt*
\q2 \qt Me lam khaw Jesuh neh a mong la ka cet.\qt*
\q1 
\v 2 Me hmuen khaw Jesuh om tih ka omdam pawh.
\q1 Ka pa ya loh n'caeh tak ca khaw amah om.
\q1 Caehthae paiphum ah a kut neh kai te m'mawt.
\q1 Jesuh omnah hmuen atah lumim la coeng.
\q1 
\v 3 Mol voel neh tui tun ah Jesuh neh ka om.
\q1 Yinnah khui ah khang nah te boeih a thui li.
\q1 A tueih na ah caeh ham oep soeh la ka om.
\q1 Amah kah a tueng na hmuen ah kai n'om puei.
\c 332
\s1 Tuiva Then Bang Ka Longpuei
\s2 It Is Well With My Soul
\sp Doh is Db
\q1 
\v 1 Tuiva then bang ka longpuei rhalthalnah om.
\q1 Kothae tuiphu a thoh vaengah,
\q1 Mebang tholhnah khaw ka soah lo mai saeh
\q1 nang loh nan cangpuei tah kai ham then.
\q2 \qt Te tah then mueihla ham\qt*
\q2 \qt Te tah then te tah then ka mueihla ham. \qt*
\q1 
\v 2 Satan cueknah dongah ka pa tang cakhaw,
\q1 Kai ham ngaiuepnah then koek tah,
\q1 Kai kah ngai daengnah boeih te tah
\q1 Khrih mah loh a ming tih kai ham thi sen a hawk.
\q1 
\v 3 Ka poek tih tholh nah neh boeilennah boeih he,
\q1 a ngen mai moeni a pum lah,
\q1 Thinglam ah a khing tih tholh ka phuei voel pawh.
\q1 boeipa koeh boeipa koeh ka hing nah.
\q1 
\v 4 Kai ham tah Khrih ni, Khrih te ni ka hingnah,
\q1 Dueknah tuiphu loh n'dah ca khaw,
\q1 tloh ka ya mahpawh,
\q1 duek he hingnah la om nang he
\q1 ka mueihla ham rhalthalnah.
\q1 
\v 5 Boeipa na lo na bueng ni ka lamtawn uh,
\q1 Phuel mol ka mang taeng u moenih,
\q1 Vaan hlang kah tanah, boeipa nang ol te ni
\q1 ngaiuepnah neh mueihla ham duemnah.
\c 333
\s1 Jerusamlem Sui Khopuei
\s2 Jerusalem In Golden
\sp Doh is D
\q1 
\v 1 Jerusalem sui kho tah khoi tui suk tui neh bae.
\q1 Na kho loei poeh ka thin dang tah a moe tih a thoel
\q1 Na khui kah om ngaihnah a om te ka ming lek pawh.
\q1 Na boeilen khosaeng te bang neh khaw ka nuet thai pawh.
\q1 
\v 2 Zion im ah pai uh tih omngaih laa a sak uh.
\q1 Vaanhlang loh bok phaeh uh tih, mar ta rhoek khaw boeih pai
\q1 David kah rhaeng hmuen om tih pa tangnah khaw bawt coeng
\q1 Tanah laa a sak uh tih om ngaihnah a bul uh.
\q1 
\v 3 Aka mawt kung neh hmaih ah rhal te khaw a na uh.
\q1 dungyan due dung yan duela bai bok te a bai uh.
\q1 Te ram a ko thae ngai hmang nah khaw om tlaih voel pawh.
\q1 dung yan omngaihnah te dung yan duela a bul uh.
\q1 Te kho puei ta then tangkik Pathen loh a tuek ram
\q1 Aw te kho puei then te ka bung ko long ta a moe.
\q1 Te duemnah ram ah Jesuh loh lung vatnah han khuen.
\q1 Pa Pa then Cim mueihla neh hmaih aka om hlang te.
\c 334
\s1 Mamih he Ip Phat Mahpawh
\s2 We Shall Sleep, But Not For Ever
\sp Doh is C
\q1 
\v 1 Ma mih he n'ip phat uh mah pawh, Om ngaih nah kho loh thai ni.
\q1 Thoh koep na hnin a tah ma mih phih rha nah om voel mah pawh.
\q1 A ka dung koek tui tun li lam ka neh rham rhae kol bawn lam kah.
\q1 kol bawn neh mol dong tlang som kah, toek lek na hlang tho pawn ni.
\q2 \qt Dungyan due n'ip uh phat mah pawh,\qt*
\q2 \qt omngaihnah kho ha thai ni. \qt*
\q2 \qt Thohkoep min cang hum tun vaeng ah\qt*
\q2 \qt phih na tue om voel mah pawh. \qt*
\q1 
\v 2 Rhai pai lum then m'hmu uh vaeng ah, te lung na tlo koek m'ming uh,
\q1 Rhang kung lam ka loh m'paek vaeng ah, ko dang long tah tha na sut,
\q1 Hlaem hmah khawn phai loh voeh voeh khum, phuel mol long tah voeh voeh ha yoei,
\q1 Ngai uep na long khaw bawt sut tih, rhai pai long khaw tlim tloi vik.
\q1 
\v 3 Ma mih he n'ip phat uh mah pawh, lai ih ci rhong phuel khui ah,
\q1 Hing na pae kung boeipa thangthen, boeipa te thangthen sak uh,
\q1 A mah kah dung yan vangnah khui ah dueknah he om voel mah pawh,
\q1 A mah tue then a pha vaengah im then la n'khue u pawn ni.
\c 335
\s1 Boeipa Neh A Ol Kah
\s2 Trust And Obey
\sp Doh is F
\q1 
\v 1 Boeipa neh a ol kah
\q1 vangnah khui n'caeh vaeng ah,
\q1 Caeh long ah a boeilen nah ha tueng,
\q1 A ko ngaih sai vaeng ah ma mih taeng ah ha om,
\q1 a ka uep nah neh ol ngai taengah.
\q2 \qt A mah uep nah a tloe uep nah om pawh\qt*
\q2 \qt Jesuh ah omngaihnah ham\qt*
\q2 \qt a mah bueng uep pang nah.\qt*
\q1 
\v 2 Kho yin loh hlip thai pawh,
\q1 kho mai loh dah thai pawh,
\q1 Hmai hoelphoeng neh boeih a na coeng tih,
\q1 rhih neh la kueng ompawh.
\q1 mik phi bo nah om pawh,
\q1 Uepnah a ol n'ngaih u vaeng atah.
\q1 
\v 3 Hno rhih khaw ka m'phuei pawh,
\q1 Lung nat khaw m'ming u pawh,
\q1 Pa tangnah loh boeinah te lat m'paek,
\q1 sung daeh ko pang moe nih,
\q1 thing lam khaw n'kawt voel pawh,
\q1 a ka uepnah neh ol ngai taeng ah.
\q1 
\v 4 Kun tun loh dikdik tui,
\q1 a kho kung ah n'om vaeng,
\q1 A taeng ah n'caeh uh bal vaengah tah,
\q1 A thui tuen ol m'vai uh,
\q1 Me la n'tuei mai cakhaw
\q1 a ka uep na ham rhih na om pawh.
\c 336
\s1 Khangkung Kah Olthangthen Te
\s2 Come, Believing
\sp Doh is G
\q1 
\v 1 Khang kung kah ol thangthen te vai
\q1 at khaw na yaan van bal coeng.
\q1 Khuenah ol na hna tun a ya?
\q1 Boeipa te na tlap koep a?
\q2 \qt Ha lo lam tah uep nah van lah\qt*
\q2 \qt Ha lo lam tah Jesuh dan, \qt*
\q2 \qt Ha lo lam tah uep nah van lah\qt*
\q2 \qt Jesuh dan lam tah hing lah.\qt*
\q1 
\v 2 Khohal tue te na hlong boeih tih,
\q1 cang ah tue tah bal coeng dae.
\q1 Lobah sikca a pha coeng dae,
\q1 Tholh dong ah kho na sak pueng.
\q1 
\v 3 Kho na poek te khang mai sak lah,
\q1 Ngai hlih na khaw khueh voel boeh,
\q1 Cim Muei hla a colh tat vaeng ah,
\q1 Khang kung boei taeng ah kun laeh.
\q1 
\v 4 Na kongaih te Pathen pae lah,
\q1 Khrih thisen te uep na lah,
\q1 Vaan dong kah Jesuh ke dan lah,
\q1 A ol thovael uh tlaih pawh.
\c 337
\s1 Cet Lamtah Lai Kothae Boeih
\s2 Bury Thy Sorrow
\sp Doh is Bb
\q1 
\v 1 Cet lamtah lai ko thae boeih boeih he voei lah.
\q1 Cet lamtah voei mai lah a then ca la th uh.
\q1 Kho hlaem tue vaengah a then ca la poek lah.
\q1 Jesuh taeng na puen atah then ngai bitni.
\q1 
\v 2 Cet lam Jesuh taeng thui na ko thae a ming,
\q1 Cet lam Jesuh taeng thui a hoei khang sak ni.
\q1 Amah kah long puei then kho sae ah cet lah
\q1 Na hnorhih boeih boeih te a yanghoep sak ni.
\q1 
\v 3 Lung buei la kuengnah neh thin rhih mai ca khaw,
\q1 Yinnah loh a hmai ah ha lo bal ca khaw
\q1 Kothae te voei lamtah hlang yoe then pae lah
\q1 Amih taengah vangnah Jesu kawng thui pah.
\c 338
\s1 Jesuh Uepnah Hnin Takuem
\s2 Trusting Jesus
\sp Doh is Ab
\q1 
\v 1 Jesuh uepnah hnin takuem,
\q1 Hli puei long puei rhaina ah.
\q1 Tangnah a yit vaengah khaw,
\q1 Soeprhaep ah Jesuh uepnah.
\q1 
\v 2 Cim Muei hla ha vang bal coeng,
\q1 kai kho daeng lung buei khui ah.
\q1 M'mawt vaeng ah ka bung thai pawh,
\q1 Soeprhaep ah Jesuh uepnah.
\q1 
\v 3 Long then ah te laa sa lah
\q1 caeh thae na ah thang thui lah.
\q1 Nuenom na ah amah khue,
\q1 Soeprhaep ah Jesuh uep nah.
\q1 
\v 4 He hingnah loh a bawt due,
\q1 he diklai tue loh bawt tih
\q1 A khuenah ol ka yaak due,
\q1 Soeprhaep ah Jesuh uepnah.
\q1 
\v 5 Hnin takuem ah uep nah lah,
\q1 uepnah neh kho hnin thok sak.
\q1 Metla na bung mai akhaw,
\q1 Soeprhaep ah Jesuh uepnah.
\c 339
\s1 Yaak Ham Ka Ngaih Ming Then
\s2 O How I Love Jesus
\sp Doh is Ab
\q1 
\v 1 Yaak ham ka ngaih ming then koek om,
\q1 koeh ham tueng rhoe pai ni
\q1 Ka hna ah phung ding laa ka yaak,
\q1 lai ah ming then koek ni.
\q2 \qt Aw Jesuh ka lung nah hlang,\qt*
\q2 \qt Aw Jesuh ka lung nah. \qt*
\q2 \qt Jesu ka lung nah, \qt*
\q2 \qt kai n'lung na lamhma tih.\qt*
\q1 
\v 2 Khangkung kah lungnah kawng han thui,
\q1 kai loeih sak hamla duek,
\q1 Thii sen tlo koek kawng te han thui,
\q1 hlang tholh a duengnah te.
\q1 Thinphat cal la a ka lungnah
\q1 kung kah kawng te a thui,
\q1 Kai kah ko thae hno rhih boeih neh,
\q1 pa tang ka phuei kung te.
\c 340
\s1 Ngaikhueknah Then Koek Jesuh Kai Kah
\s2 Blessed Assurance
\sp Doh is D
\q1 
\v 1 Ngaikhueknah then koek Jesuh kai kah,
\q1 Pathen boeilennah kai loh ka ten coeng,
\q1 Khangnah rho m'pang uh, Pathen loh n'lai,
\q1 Muei hla neh n'cun tih, thi sen neh n'silh.
\q2 \qt He tah ka yan cil neh ka laa ni.\qt*
\q2 \qt kho yin khothaih boeipa ming koeh he. \qt*
\q2 \qt Hetah ka yan cil neh ka laa ni. \qt*
\q2 \qt khoyin khothaih boeipa ming koeh he.\qt*
\q1 
\v 2 Pum paeknah dongah om ngaihnah soep,
\q1 Hlangcim coi nah ka mik hlam ah ha tueng,
\q1 Vaan dong lamkah vaan hlang neh ha rhum
\q1 A lungnah neh rhennah ol thangthen.
\q1 
\v 3 Pumpaeknah soep he duemnah then ni,
\q1 Khang kung boei taeng ah kai ka omngaih hlang.
\q1 Vaan ke ka dan tih ka lam tawn kung,
\q1 A thennah neh a lungnah te m'paek.
\c 341
\s1 Vangnah Tlangsom Ah Tun Uh
\s2 Faith is the Victory
\sp Doh is F
\q1 
\v 1 Vangnah tlang som ah tun uh lah, Nangmih Khrih rhal kap rhoek
\q1 Kho laeh tih kho a khup hlan ah rhal ke han tuk uh laeh,
\q1 Thaomnah boeih huel sih lamtah caemrhal ke thup pawn sih.
\q1 Tang nah he ta nah ti m'ming uh, diklai ta nah la om.
\q1 Tang nah he ta nah ni
\q1 Tloengkhoel koek la tanah ni he diklai tanah ni.
\q1 
\v 2 Lungnah he mamih kah aitlang, Pathen ol thung lang ni.
\q1 Tanah conghol neh hlangcim rhoek kah long puei te n'thuep uh.
\q1 Tang nah loh a hliphoe bang la hmuen mol boeih te a cim sak.
\q1 Tang nah loh duek nah a ta tih, vang nah patling la om.
\q1 Tang nah he ta nah ni
\q1 Tloengkhoel koek la tanah ni he diklai tanah ni.
\q1 
\v 3 Caem rhal a ka ta rhoek te tah, bai bok a bai sak ni.
\q1 Vaan kah vaan dong caeltueih hmai ah ming a phoei uh ve tih
\q1 Vang nah tlang lam kah ha khong tih, lung buei ah lung nah thoeng,
\q1 Jesuh ming neh ta nah hmuen ah, yin nah boeih khum pawn ni.
\q1 Tang nah he ta nah ni
\q1 Tloengkhoel koek la tanah ni he diklai tanah ni.
\c 342
\s1 Halo Ngaihmang Rhoek Aw
\s2 Come, Ye Disconsolate
\sp Doh is D
\q1 
\v 1 Ha lo ngaihmang rhoek aw, na vawt thoek a khaw
\q1 Rhennah ngol khoel hmaiah kho cung kueng sih.
\q1 Na thin phatnah han khuen, na thin sa khaw thui,
\q1 vaan loh a boeih sak thai mueh he om pawh.
\q1 
\v 2 Ngai hmang ham omngaihnah , long hmang hlahmae nah,
\q1 Ta hah ham ngaiuepnah, bawt pawt tih cim.
\q1 Ngai mong sak kung long tah Ol ding a thui ah,
\q1 vaan loh a hoeih sak thai mueh he om pawh.
\q1 
\v 3 So lah hingnah vaidam, hingnah tuitah phuet
\q1 Pa then hmuen cim lamkah, ha long thuk coeng.
\q1 Lung nah buhloei han lo Aka ya rhoek boeih vaan loh
\q1 a hloep thai mueh ko thae om pawh.
\c 343
\s1 Kothaenah Ram Diklai Ah He
\s2 Jesus All of Me
\sp Doh is E
\q1 
\v 1 Ko thae na ram diklai ah he,
\q1 pa tang pa lai ka ko ka pang,
\q1 omngaih ngai mongnah te,
\q1 tlap ti ka om he diklai ah,
\q1 bom kung a tloe u khaw om pawh.
\q1 Jesuh ka soep rhep ni.
\q2 \qt Boei Jesuh ka soep rhaep\qt*
\q2 \qt Jesuh soeprhaep la om, \qt*
\q2 \qt Jesuh soep rhaep la om.\qt*
\q1 
\v 2 Rhih om nah loh khoep ah m'vael tih,
\q1 tloh tat na loh n'caeng mai ca khaw,
\q1 Jesuh loh kai n'om puei.
\q1 A sak then muei kho lakah sae,
\q1 hnin takuem amah loh m'mawt tih,
\q1 Jesuh ka soep rhep ni.
\q1 
\v 3 Muihla loh a yuu la m'bae uh,
\q1 aka ngaih rhoek boeih ha lo uh,
\q1 Khangnah na ngaih atah,
\q1 Boei Jesuh taeng ham pae uh lah,
\q1 Na tholh te boeih a cim sak ni,
\q1 Jesuh ka soep rhep ni.
\c 344
\s1 Ka Ram Loh Boeipa Nang Ngoe
\sp Doh is G
\q1 
\v 1 Ka ram loh boeipa nang ‘ngoe
\q1 ka hingnah loh nang te ngoe,
\q1 Ka ram hoeihnah ol cim he mueihla neh phong lah
\q1 Ol tloh ol ding neh kan thui
\q1 hlang boeih loh yak ming thai pawh
\q1 ka ram loh boeipa a ngoe he bueng ni ka poek.
\q2 \qt Cim mueihla neh thoh sak lah boeilen koek boeipa\qt*
\q2 \qt na hlang rhoek na tlannah ol tahae ming uh saeh. \qt*
\q2 \qt Ka ram hamla thang thui tih ka mik phi a bonah he\qt*
\q2 \qt ka ram han hnilh rhoe rhoe boeh Boeipa nang kan ngoe. \qt*
\q1 
\v 2 Tui va khaw boeih ka kat coeng
\q1 tlang sang khaw boeih ka lan coeng
\q1 na hlang tueih hnuksul ka vai Nang kah cil kan thui
\q1 A yaak dae a ih tak coeng
\q1 ming doeah a duek puei coeng
\q1 ka ram loh boeipa a ngoe he bueng ni ka poek.
\q1 
\v 3 Bawt mueh la na ol phong tih
\q1 buhpong tuihalh mai cakhaw
\q1 ka caeh ko loh dikdik tui Boeipa nang nen tah
\q1 A tloe lungnah om bal nim
\q1 na hlang rhoek loh ming uh pawh
\q1 ka ram loh boeipa a ngoe he bueng ni ka poek.
\c 345
\s1 Van Dong Darkhing Tum Lah
\s2 Ring The Bells Of Heaven
\sp Doh is Bb(Joyfully)
\q1 
\v 1 Vaan dong darkhing tum lah, ti hnin omngaihnah.
\q1 hlang pakhat tholh lam kah ha bal coeng.
\q1 So lah a na pa loh long pueng ah a doe,
\q1 capa aka hma tang tae coeng te.
\q2 \qt Tloengkhoelh tloeng khoelh, vaan hlang laa a sak.\qt*
\q2 \qt Tloeng khoelh tloeng khoelh tingtoeng ol then neh\qt*
\q2 \qt Vaan hlang ping loh tui hum ol bang la cai tih \qt*
\q2 \qt loeih na laa then te a sak uh boeih. \qt*
\q1 
\v 2 Vaan dong darkhing tum lah, ti hnin om ngaihnah.
\q1 Pam dah rhoek boeih khaw a moei then coeng.
\q1 Hlang tholh rhoek boeih a tlan tholh na khui lam kah,
\q1 a ca la koep a cun na ham la.
\q1 
\v 3 Vaandong darkhing tum lah, vaan buhloei kung ah,
\q1 Vaan hlang rhoek loh tanah laa a sak.
\q1 Omngaih olthang thui uh kho hla rham hla lah,
\q1 Muei hla thai loh cun thai na a khueh.
\c 346
\s1 Ka Hingnah Kopoekrhai La Tho Uh
\s2 Since Jesus Come Into My Heart
\sp Doh is A
\q1 
\v 1 Ka hingnah ko poekrhai la tho uh,
\q1 Ka ko khui Jesuh a kun vaeng lamkahloh,
\q1 Ka tlap khing lungbuei vangnah te tah ka hmuh coeng
\q1 Jesuh a kun vaeng lamkaloh
\q2 \qt Jesuh ka ko khui ah a kun,\qt*
\q2 \qt Jesuh a kun vaeng lamkaloh, \qt*
\q2 \qt Ka lung buei ah omngaihnah loh tah\qt*
\q2 \qt tui tun li ol bang la kolkalh ah ha bae.\qt*
\q1 
\v 2 Ka pamnah kung lam kah ka bal coeng,
\q1 Ka ko khui Jesuh a kun vaeng lam ka loh,
\q1 Ka tholh nah aka yet koek mai te boeih a silh,
\q1 Jesuh a kun vaeng lamka loh
\q1 Te kho puei la ka cet ni ka ming,
\q1 Ka ko khui Jesuh a kun vaeng lam ka loh,
\q1 Om ngaih neh tha hlue la a hmai ben la ka cet,
\q1 Jesuh a kun vaeng lamka loh.
\c 347
\s1 Jesuh Mueihla Lungnah Kung
\s2 Jesus Lover Of My soul
\sp Doh is F
\q1 
\v 1 Jesuh mueihla lungnah kung,
\q1 Na rhang dong ah n'cuk sak lah
\q1 Tuiphu loh ha len bal tih,
\q1 Cuek halh nah loh a yet vaengah.
\q1 Khang kung boei kai he n'thuh lah,
\q1 Hli puei loh a khum due la,
\q1 Vaan long puei n'hoihaeng lam tah
\q1 Ka mueihla he han doe lah.
\q1 
\v 2 Yinnah a tloe ka khueh pawh,
\q1 Ka ngai daeng tih ka lo coeng,
\q1 Kai bueng he tah n'caeh tak boeh.
\q1 M'bom lamtah kai n'hloep koep bal dae,
\q1 Na mah bueng ni kan uepnah,
\q1 Na bom nah ni ka ngaih koek,
\q1 Hlip dah kung then om mueh la,
\q1 Na phae hlip ah n'ying sak lah.
\q1 
\v 3 Na taengah lung vatnah soep,
\q1 Ka tholh boeih he na rhen coeng,
\q1 Hoeihnah tui na long sak tih
\q1 Kai he nan cim nan caih sak.
\q1 Hing nah tuiphuet tah nang ni,
\q1 A yoe la yuetyuet na long,
\q1 Ka lung buei ah dung yan la
\q1 tui sih loh ha phuet van coeng.
\c 348
\s1 Ka Boeipa Te Ka Yah Puei Pawh
\s2 At The Cross
\sp Doh is E.
\q1 
\v 1 Ka Boeipa te ka yah puei pawh,
\q1 a mah bi ka huul ni,
\q1 A ol cim neh a thing lam te
\q1 a then la ka khoem ni.
\q2 \qt Thinglam ah thinglam ah\qt*
\q2 \qt vangnah ka hmuh lamhma, \qt*
\q2 \qt Ka lungbuei hnorhihnah boeih hma coeng\qt*
\q2 \qt Tangnah neh kai loh kho ka hmuh thai tih, \qt*
\q2 \qt Ta hae hlaem mincang ah ka omngaih.\qt*
\q1 
\v 2 Jesuh Pathen a ming ka ming
\q1 a mah ming ka uepnah,
\q1 Ka mueihla yah sak mah pawh,
\q1 ngaiuepnah bawt mah pawh.
\q1 
\v 3 A ngol hmuen loh a cak bangla
\q1 a then la a kuem coeng,
\q1 Cuek halh nah tue ha lo vaengah
\q1 a kut dongah ka paek.
\q1 
\v 4 Hlang tholh tang kik la ka om dae
\q1 ka tholhnah boeih ham vuei,
\q1 Jerusalem thai dong ah te
\q1 ka mueihla ham hmuen om.
\c 349
\s1 Boei Jesuh Loh Ngaithuen Van Nim?
\s2 Dose Jesus Care?
\sp Doh is Db
\q1 
\v 1 Boei Jesuh loh kai ngai thuen van nim,
\q1 ka ngai a hmang vaengah
\q1 Ka hno rhih tih long puei a bing vaengah
\q1 Jesuh loh kai ngai thuen coi nim
\q2 \qt Boei Jesuh loh ngaithuen ka ming\qt*
\q2 \qt ka ko thae nah he a ming\qt*
\q2 \qt Kholaeh loh hla tih khoyin a sen vaeng ah\qt*
\q2 \qt Boei Jesuh loh ngaithuen\qt*
\q1 
\v 2 Boei Jesuh loh kai ngaithuen van nim,
\q1 Long puei a bing vaeng ah
\q1 hlaem hmah kho khawn loh a khup thuk vaengah
\q1 Jesuh loh kai ngaithuen coi nim.
\q1 
\v 3 Boei Jesuh loh kai ngai thuen van nim,
\q1 tholhyoeknah ueh tloel vaeng
\q1 Kho yin kho thai ah ko thae mik phi doe ah
\q1 ka om he ngaithuen coi nim
\q1 
\v 4 Thin tlo koek neh m'apek uh vaengah he,
\q1 Jesuh kai n'ngaithuen nim?
\q1 Ko thae thin phat la ka om li vaengah
\q1 Jesuh loh kai m'hmuh van coi nim
\c 350
\s1 Rhaipai Dong Buem A Tlak Vaengah
\s2 In The Garden
\sp Doh is Ab
\q1 
\v 1 Rhaipai dong buem a tlak vaengah
\q1 ka mah bueng he dum khui la ka lo.
\q1 Ka hna khui ah Kho hni ca pa ha yoei,
\q1 ol te ka hna ah ha kun.
\q2 \qt Amah loh n'caeh puei tih ol te han thui,\qt*
\q2 \qt Kai hlang la nang na om a ti. \qt*
\q2 \qt A u long khaw a ming mueh \qt*
\q2 \qt omngaihnah thikat la hmai ka bul uh.\qt*
\q1 
\v 2 Amah kah ol thui ol hum loh,
\q1 ding suek la su cawk va cek sap duem,
\q1 A laa then ka lungbuei ah m'paek te tah,
\q1 hlet hle ha cai li bal coeng.
\q1 
\v 3 Amah neh dum ah om ka ngaih,
\q1 yinnah loh ka taeng ham vael cakhaw,
\q1 A olkhueh neh long kan caeh puei
\q1 tila a ol neh kai te n'khue li.
\c 351
\s1 Olkhueh Phu Tlo Pathen Loh
\s2 I Will Guide Thee
\sp Doh is G
\q1 
\v 1 Olkhueh phu tlo Pathen loh
\q1 yin cet taengah te a paek coeng,
\q1 Dik lai neh van long puei ah te
\q1 ‘Ka mik neh kan hoi haeng ni.'
\q2 \qt Kanhoi haeng ni, kan hoihaeng ni\qt*
\q2 \qt Ka mik neh ka hoi haeng ni, \qt*
\q2 \qt Dik lai neh vaan dong long puei ah\qt*
\q2 \qt Ka mik neh kan hoihaeng ni.\qt*
\q1 
\v 2 Cuekhalh loh nang n'ta tom coeng tih
\q1 Na uepnah hlang hma ca khaw
\q1 He ol khueh na khui ah om sak,
\q1 ‘Ka mik neh kan hoi haeng ni'b
\q1 
\v 3 Ngaiuep nah ol huep te po tih
\q1 Kum loh a thok bal vaengah
\q1 Om ngaih sak kung ol khueh he tah,
\q1 Ka mik neh kan hoi haeng ni.'
\q1 
\v 4 Mueirhihtamyin te ha pai tih,
\q1 duek nah tue ha lo vaengah,
\q1 N'yaak ham mawt kung khue ol te tah
\q1 ‘Ka mik neh kan hoi haeng ni.'
\c 352
\s1 Boeipa Thinko Boeih Neh Ka Koeh Ni
\s2 He Has Taken My Sins Away
\sp Doh is Bb
\q1 
\v 1 Boeipa thinko neh boeih ka koeh ni,
\q1 Amah ah ka omngaih ni.
\q1 Ko poekrhai la kai he n'lungvatnah,
\q1 He bueng ni ka laa then.
\q2 \qt Ka tholhnah boeih te a caeh puei coeng \qt*
\q2 \qt A ming cim thangthen\qt*
\q2 \qt a ming cim thangthen\qt*
\q2 \qt Ka tholhnah boeih te a caeh puei coeng \qt*
\q2 \qt Ha le luijah thangthen uh.\qt*
\q1 
\v 2 Duemnah neh ngai mongnah hmuh hamla,
\q1 tholh hno rhih phueih doe ka lo.
\q1 Ka thang thuinah han yak tih n'loeih sak,
\q1 He bueng ni ka laa then.
\q1 
\v 3 Ka khah uh due amah ka koeh ni,
\q1 Dueknah ta kung boeipa te.
\q1 A yoeyah la ka thangthennah laa
\q1 He bueng ni ka laa then.
\c 353
\s1 A Pa Loh Imhmuen Lohmuen Muep A Khueh
\s2 The Child of a King!
\sp Doh is F
\q1 
\v 1 A pa loh imhmuen lohmuen muep a khueh,
\q1 Dik lai khuehtawn boeih khaw a kut ah om,
\q1 Sui ngun neh lung then lung sen boeih boeih khaw,
\q1 Kawnthen neh a boei rhaeng toeklekna pawh.
\q2 \qt Mang hai kah a ca ni oi ngaih poeh pom ni,\qt*
\q2 \qt Khang kung Jesuh neh manghai kah ca la ka om.\qt*
\q1 
\v 2 A pa kah khueh duen ca pa khang kung boei,
\q1 Lai ah ca dah a na ming mai cakhaw,
\q1 Ta hae van ah dung yan uk kung la om,
\q1 A voel ah vaan im then m'paek van pawn ni.
\q1 
\v 3 Kai van khaw lai ah yin la ka om van,
\q1 Tholh bueng he ka ko lo a tuek la om,
\q1 Te dae ta hae a ca la n'khueh coeng tih,
\q1 Sui lumuek pang kung la ka om van coeng.
\q1 
\v 4 Ka yin im lai he ka ngaih tlaih voel pawh,
\q1 lum im then kai hamla a om dongah
\q1 He kah ka im ka caeh tak mai akhaw,
\q1 Mang hai ca la ka om te uem la ka sak.
\c 354
\s1 Lai Hman Hing Khui Cueknah Loh
\s2 Count Your Blessings
\sp Doh is Eb
\q1 
\v 1 Lai hman hing khui cuek nah loh a thoh vaeng ah,
\q1 Rhihyawp na loh ngaiuep nah a bawt vaeng ah,
\q1 Na yoethen pa khat phoei pa khat ah soep lah.
\q1 Boeipa loh a yet ngai m'paek te na ming ni.
\q2 \qt Yoe then pa khat pa khat ah soep lah\qt*
\q2 \qt Pathen kah a paek boeih tila poek. \qt*
\q2 \qt Yoethen soep lah Pa khat phoei pa khat\qt*
\q2 \qt Boeipa loh a yet ngai m'paek te na ming ni. \qt*
\q1 
\v 2 A kum ngaihnah dong hnorhih la na phueih a?
\q1 Thinglam koh ham khuenah ol na hnorhih a?
\q1 Yoe thennah te soep lam na ngaihmang sak boeh
\q1 Uepvawtnah om voelmuehla na ngaimong ni.
\q1 
\v 3 Hlang tloe rhoek kah a khueh a tawn na nai vaeng
\q1 Khrih kah a paek khueh tawn boei rhaeng mah poek lah,
\q1 Yoethennah boeih he koe va neh n'lai thai pawh
\q1 Vaan dong ah na hmuh ham koi te ham poek lah.
\q1 
\v 4 Khodaeng patang soep rhaep he na tong vaeng ah,
\q1 Ko bawt kolla Boeipa mah te uep nah lah,
\q1 Yoethennah boeih soep lah van hlang ha lo li
\q1 Na hing khui ah ngai mong nah te na hmuh ni.
\c 355
\s1 Boeipa Ka Uepnah Hlang Tah
\s2 Who Trust in The Lord
\sp Doh is A
\q1 
\v 1 Boeipa ka uepnah hlang tah
\q1 Zion tlang bang la om ni
\q1 Rhihnah khueh pawh.
\q1 Thuennah khaw khueh pawh.
\q1 Moltlang loh Jerusalem kho a thung khoep bang la
\q1 Boeipa loh a hlang rhoek tah a thung khoep.
\q2 \qt Jesuh tah ka loeih nah Jesuh tah ka ying nah.\qt*
\q2 \qt Jesuh tah kai hamla hingnah la om. \qt*
\q2 \qt Ka hingnah tah Boeipa Jesuh a mah he pawn ni. \qt*
\q2 \qt Ka omngaih haleluijah Amen.\qt*
\q1 
\v 2 Boeipa ka uepnah hlang tah
\q1 Tui va kaeng thing kung bangla.
\q1 Amah tue ah a thaih thaih bang la
\q1 A rham long khaw yai tlaih pawh,
\q1 a thaih khaw hul tlaih pawh.
\q1 A sai na boeih ah yoe thennah a dang.
\q1 
\v 3 Kai ka om ngaihnah koek tah.
\q1 Boeipa Jesuh amah ni.
\q1 Amah mueh tah omngaihnah soep pawh.
\q1 Jesuh khrih ka khueh dong ah
\q1 dilai rho ka ngoe pawh.
\q1 Ka yoe then, ka yoe then Jesuh ka khueh
\c 356
\s1 Toeklekna Tingtoeng Ol Then Neh
\s2 Hark! Ten Thousand Harps and Voices!
\sp Doh is G
\q1 
\v 1 Toek lek na ting toeng ol then neh
\q1 vaan dong ah laa then ol n'yaak.
\q1 Jesuh amah loh a poeng coeng,
\q1 lungnah Pathen la om tih.
\q2 \qt A boei ngol khoel ke dan lah,\qt*
\q2 \qt Jesuh loh di lai a poeng \qt*
\q2 \qt Ha le lui jah ha le luijah\qt*
\q2 \qt Jesuh loh diklai a poeng. \qt*
\q1 
\v 2 Boeilen koek manghai pa nang loh
\q1 dung yan duela a poeng coeng,
\q1 Na hlang na khueh rhoek boeih te tah
\q1 u ca long khaw paek thai pawh.
\q1 
\v 3 Ka khang kung boeilen koek mai la
\q1 na lonah hnin ka lamtawn,
\q1 Namah tuen ol ha lo vaengah
\q1 vaan neh lai he khum pawn ni.
\c 357
\s1 Khodaeng Patang Rhoek Boeih
\s2 Living Where The Healing Waters Flow
\sp Doh is A
\q1 
\v 1 Khodaeng patang rhoek boeih
\q1 Jesuh taengla ha lo
\q1 Hingnah tui cim a long na ah,
\q1 Amah tah hoeihnah neh thaomnah la om bal
\q1 Hingnah tui cim a long na ah.
\q2 \qt Tui hing cim a long nah kung ah\qt*
\q2 \qt Hing nah thing kung a om na ah,\qt*
\q2 \qt Haleilui jah khosae khui ah ka om ni. \qt*
\q2 \qt Boei Jesuh om na ah \qt*
\q2 \qt Tuihing cim a long na kung ah \qt*
\q1 
\v 2 Ka mueihla he na lai
\q1 coeng tih amah hut coeng,
\q1 Hingnah tui cim a long na ah,
\q1 Ka tholh nah boeih hlah ham la
\q1 Khrih lai dong ha rhum.
\q1 Hingnah tui cim a long na ah.
\q1 
\v 3 Tlantae ca rhoek ha lo
\q1 khangkung boeih thangthen uh,
\q1 Hing nah tui cim a long na ah,
\q1 Tu canoe hmaiah kuep lam tahthangthen sak uh.
\q1 Hing nah tui cim a long na ah.
\q1 
\v 4 A mah hmai ah kuep uh
\q1 amah te thangthen uh.
\q1 Hing nah tui cim a long na ah,
\q1 Lungnah loh a noeng tih
\q1 A lungvatnah loh cak
\q1 Hing nah tui cim a long na ah.
\c 358
\s1 Ka Ko Khuiah Omngaih Vangnah Om
\s2 Sunshine In The Soul
\sp Doh is Ab
\q1 
\v 1 Ti hnin ka ko ah kho sae then om,
\q1 A then tang kik la sae,
\q1 Dik lai kho sae lakah then ngai,
\q1 Jesuh kah vangnah ni.
\q2 \qt Aw khosae then vang na then koek\qt*
\q2 \qt Omngaih la a tue a bawt vaeng ah\qt*
\q2 \qt Jesuh hmai pan a tueng vaeng ah, \qt*
\q2 \qt ka ko khui ah kho ha sae.\qt*
\q1 
\v 2 Ka ko khui ah uemnah laa ha cuen,
\q1 Ka boeipa thangthennah,
\q1 Ka ol loh thui thai pawt cakhaw,
\q1 Boei Jesuh loh a ming,
\q1 
\v 3 Tihnin ka ko ah dawn thai ha cawt,
\q1 Boeipa loh ha yoei tih,
\q1 Vahu bangla rhuep rhuep ha loei,
\q1 Lungvatnah rhai ha phuelh.
\q1 
\v 4 Ti hnin ka ko ah om ngaihnah cuen,
\q1 Ngai uep koehnah lungnah,
\q1 Ta hae yoe then nah boeih te m'paek
\q1 vaan om ngaihnah boeih te.
\c 359
\s1 Boeipa Lungvatnah Dongah Thangpom Uh
\s2 If God Be For Us
\sp Doh is G
\q1 
\v 1 Boeipa lungvatnah dongah thangpom uh lah,
\q1 Amah loh tholhrhal boeih han na,
\q1 Thi sen neh n'tlan tih Jesuh ka soep rhaep la om tih
\q1 ka la kueng tlaih voel pawh.
\q2 \qt Pathen loh om puei\qt*
\q2 \qt Pathen loh om puei\qt*
\q2 \qt Pathen loh om puei\qt*
\q2 \qt U ca long nim n'tuk uh thai van eh\qt*
\q2 \qt U ca long khaw n'na uh thai mawh pawh.\qt*
\q1 
\v 2 Boeipa ah thaphoh u hang lamtah om ngaih,
\q1 Hnin ta kuem uepom la om uh,
\q1 Tholh lakli ah a thuem te pai puei boeih uh
\q1 Amah tah ma mih thaomnah.
\q1 
\v 3 Amah ol khueh ta nah dongah uep na lah,
\q1 Khrih tah soep rhaep ah boei la om,
\q1 Dik lai he khum a cakhaw a ol ah cak,
\q1 He ni koep koep a daek uh eh.
\q1 
\v 4 Boeipa neh pha uh la nang tah na sueng ni,
\q1 Tahae dung yan hingnah a tong,
\q1 Hlang tholh koek khaw a kut neh a loh coeng tih
\q1 U ca long khaw rhawt thai mah pawh.
\c 360
\s1 Thinko Aka Dueng Hlang Rhoek
\s2 Rejoice In The Lord
\sp Doh is Bb
\q1 
\v 1 Thinko aka dueng hlang rhoek aw,
\q1 Boeipa taeng ah omngaih uh lah.
\q1 Amah kah hlang tuek rhoek boeih aw,
\q1 Kothae ngaihmang nah boeih voei uh.
\q2 \qt Omngaih uh lah\qt*
\q2 \qt Boeipa taeng ah omngaih uh lah. \qt*
\q2 \qt Omngaih uh lah \qt*
\q2 \qt Boeipa taengah omngaih uh lah. \qt*
\q1 
\v 2 Boeipa la om tih koeh uh lah,
\q1 Vaan neh dilai a kung mah ni
\q1 a kut khui kah hlang la n'om uh
\q1 A ka tlung ngai boei koek la om.
\q1 
\v 3 Duengnah ham rhal n'tuk li vaeng ah
\q1 Rhal loh dalh ah n'ta uh ca khaw,
\q1 Pa then rhalkap loh n'thuh tak dae,
\q1 Rhal boeih boeih lak ah khaw tlung ngai
\q1 
\v 4 Khothun lung ah kho yin ca khaw,
\q1 Vaan ke yin loh hlip dah cakhaw,
\q1 Na mueihla ham rhih na om pawh
\q1 Rhai nah a bawt due la tangnah
\c 361
\s1 Nan Khueh Na Ol Ka Yaak Aw
\s2 Draw Me Nearer
\sp Doh is Ab
\q1 
\v 1 Nan khuenah ol ka yaak aw ka boeipa
\q1 nan lung vatnah ol han thui
\q1 Tangnah neh na rhang dongah om ka ngaih
\q1 namah taengah kai yoei sak
\q2 \qt Kai yoei sak lah thin tlo ka boeipa \qt*
\q2 \qt na duek nah thing lam kung ah\qt*
\q2 \qt kai yoei sak lah sak lah thin thin tlo ka boeipa \qt*
\q2 \qt na thing lam kung ben ah ke.\qt*
\q1 
\v 2 Boeipa na bi bi hamla kai n'hoep lah
\q1 na thin tloh nah ko lung neh
\q1 A cak ngai uepnah ka mueihla hmuh sak
\q1 na kongaih bangla om sak.
\q1 
\v 3 Namah kho kung ah ka thang thui vaengah
\q1 omngaih kohoe neh ka hmuh
\q1 Paya bae rhoep la na taeng om ka ngaih
\q1 nan toidal na te ka ngaih.
\q1 
\v 4 Nan lungnah dung koek kai loh ka ming pawh
\q1 dueknah tuiva ka kat due
\q1 Om ngaihnah koek te kai ka hmuh pawn ni
\q1 na taeng ah ka duem vaeng ah.
\c 362
\s1 Khangkung Nan Lungnah He
\s2 Saviour, Thy Dying Love
\sp Doh is G
\q1 
\v 1 Khangkung nan lungnah he, Kai ham na duek
\q1 Thuh phah koi om tlaih pawh
\q1 na taeng lamkah Lungnah neh ka kun ni
\q1 Ol khueh he ka cak sak
\q1 Ka kutdoe kan khuen he na mah ham saeh.
\q1 
\v 2 Rhennah ngol khoel hmai ah rhennah ham bih,
\q1 Ka tangnah loh vawtdae Jesuh ka dan,
\q1 Thing lam tung n'koh puei lah,
\q1 Na lung nah ol phong ham
\q1 Laa sak neh thangthui he na mah ham saeh.
\q1 
\v 3 Namah bang la kai khaw thincaknah m'pae
\q1 Kho hnin pa toeng a he thincaknah m'pae
\q1 Lungnah bi m'bi sak lam rhennah kai n'khueh sak lah,
\q1 Hlang tloe ka coep cael he na mah ham saeh.
\q1 
\v 4 Ka khueh ka tawn boeih he nang kutdoe ni,
\q1 Kothae omngaih akhaw Namah hut ni
\q1 Na muei ka hmuh vaengah ka mueihla a ko hoe
\q1 Dung yan ka omngaih he na mah ham saeh.
\c 363
\s1 Sui Khohmuen Kah Laa Ol
\s2 Gather The Reapers Home
\sp Doh is Bb
\q1 
\v 1 Sui khohmuen kah laa ol na yaak pawn a?
\q1 Omngaih laa thai na yaak a?
\q1 Mamih boeih thahlue la kut thueng uh sih,
\q1 A tue loh sen voel mah pawh.
\q2 \qt Cang at kung boeipa tah ha lo pawn ni,\qt*
\q2 \qt A mik hmai then a ol te n'yaak ni\qt*
\q2 \qt Cang at kung boei te tah ha lo pawn ve tih\qt*
\q2 \qt Cang at rhoek te a coi ni.\qt*
\q1 
\v 2 Sui khohmuen te tah a mih loh han dan,
\q1 Thintlo hlang a mih rhoek loh,
\q1 A bi bi te rhip a bi uh boeih tih,
\q1 A thing lam te a koh uh.
\q1 
\v 3 Sui khohmuen kah laa ol a ka thoeng loh,
\q1 Ti hnin tha koep han hlue sak,
\q1 Diksueh phungding ol neh kaimih n'toi lah,
\q1 Bi bi ka bi uh vaeng ah.
\q1 
\v 4 A sui hmuenlung laa ol a ka thoeng loh,
\q1 Lolmang ko koep ham phuelh sak,
\q1 Tang nah hing neh ka ming tang tae pawn ni,
\q1 He ka laa then la om saeh.
\c 364
\s1 Jesuh Ham Hing He Khosak Then
\s2 Living For Jesus
\sp Doh is F
\q1 
\v 1 Jesuh ham hing he khosak then la om,
\q1 A sai boeih dong ah a kohoe sak ham.
\q1 Lunghoih la amah ka hinyah he tah
\q1 Kai ham yoethen ha lo nah long puei ni.
\q2 \qt Aw Jesuh khang kung boeipa ,\qt*
\q2 \qt Ka pum he nang kan paek, \qt*
\q2 \qt Kai yueng la na duek coeng tih, \qt*
\q2 \qt Na pum na paek dong ah\qt*
\q2 \qt Boei a tloe ka ka khueh pawh, \qt*
\q2 \qt Ka lung buei ah ha om \qt*
\q2 \qt Nang ham hing ham ka hingnah he \qt*
\q2 \qt nang Khrih ni kan paek coeng.\qt*
\q1 
\v 2 Jesuh ham ka hing kai yueng la duek tih,
\q1 Tholh yahpohnah thing lam dongah ham phueih,
\q1 Te lungnah ol loh kai he n'khue dong ah
\q1 Ka soep he a mah ka paek tih ka hing.
\q1 
\v 3 Jesuh ham ka hing me la ka om ah,
\q1 Aming cim hamla ka bi tueng ka bi,
\q1 Sung daeh maih neh pa tang mai khaw ka ueh,
\q1 Khodaeng ming na neh thinglam ka koh puei.
\q1 
\v 4 Jesuh ham ka hing diklai tue toi ah,
\q1 A mik hmai hlam pan te ka kawn then ni,
\q1 A tlan hlang a ka hma he ka tlap tih,
\q1 A taengla ka pumphoe puei he pawn ni.
\c 365
\s1 Jesuh Taengah Soeprhaep Ka Paek
\s2 All To Jesus I Surrender
\sp Doh is D
\q1 
\v 1 Jesuh taeng ah soep rhaep ka paek,
\q1 moeihoeih ca la boeih ka paek.
\q1 Ka uepnah bangla ka lung nah,
\q1 hnintakuem a taeng ka cet.
\q2 \qt Soeprhaep boeih ka paek\qt*
\q2 \qt Soeprhaep boeih ka paek\qt*
\q2 \qt Soeprhaep boeih he Jesuh taeng ah\qt*
\q2 \qt kai loh ka paek coeng \qt*
\q1 
\v 2 Jesuh taeng ah soep rhaep ka paek
\q1 A kho kung ah kai ka kuep,
\q1 Lai omthen bawnnah boeih ka toeng,
\q1 Tahae Jesu kai n'lo lah.
\q1 
\v 3 Jesuh taeng ah soeprhaep ka paek
\q1 Khang kung hut la boeih ka om,
\q1 Cim Mueihla loh n'yakming sak saeh,
\q1 Nang hut la ka om nah te.
\q1 
\v 4 Jesuh taeng ah soeprhaep ka paek
\q1 Ka pum hing nah boeih nang kah,
\q1 Lungvatnah neh kai m'baetawt sak,
\q1 Na yoethen nah han soep sak.
\c 366
\s1 Tangnah Neh Nang Kan Dan
\s2 My Faith Looks Up To Thee
\sp Doh is Eb
\q1 
\v 1 Tang nah neh nang kan dan,
\q1 Kalvari tuca noe.
\q1 Khangkung Pathen Ka thangthui ol han ya,
\q1 Ka tholh boeih caeh puei lah,
\q1 Ka pum boeih he nang hut la om lah saeh.
\q1 
\v 2 Na rhen nah han kun sak
\q1 ka lung buei tha hlue sak
\q1 Poek na then pae Kai ham nang na duek tih,
\q1 Nang kan lung na he caih,
\q1 Tho laeng nah voel mueh la hmai bang la alh.
\q1 
\v 3 Ka hing nah loh kho yin
\q1 ko pang na loh vael dae
\q1 Hoi haeng kung nang Khoyin kho na thaih sak,
\q1 Mik phi khaw na huih tih,
\q1 Na taeng lam ka loh ka n'taengphael sak boeh.
\q1 
\v 4 Lai hing he a bawt vaeng ah,
\q1 Duek nah tuili loh n'thing koep vaeng ah
\q1 Khangkung boeipa nang loh
\q1 Lakueng nah boeih ham voei,
\q1 So ben kah a sueng na hmuen la n'om sak.
\c 367
\s1 Mueihla ah Hnin Takuem Cangti Tuh
\s2 Sowing To The Spirit
\sp Doh is Ab
\q1 
\v 1 Muei hla ah hnin takuem cangti tuh uh lah,
\q1 Lungnah cangti diklai peng pum ah tuh lah,
\q1 Muei hla ah tuh lamtah Boeipa te uepnah,
\q1 Ma mih bi bi bangla Yoe thennah n'dang ni.
\q2 \qt Cang ti te tuh uh lah \qt*
\q2 \qt Khokhawn loh a khup hlan due, \qt*
\q2 \qt Lakuengnah khueh muehla a bawt due bi lah \qt*
\q1 
\v 3 Muei hla ah thang thui neh cangti tuh uh lah,
\q1 Cangti tuh long he tah poe ngai ngai bit ni.
\q1 Tangnah neh tuh uh lah rho tui tlan ngai ni.
\q1 Sui cang vuei then te khaw ma mih loh m'hmuh ni.
\q1 
\v 4 Muei hla ah cangti tuh tangna yit cakhaw,
\q1 Tha hnoeng mik phi bo dae cang ti te tuh uh,
\q1 Bi bi a bawt vaengah dung yan om ngaihnah
\q1 cangah tue then te khaw ma mih loh m'pha ni.
\c 368
\s1 Na Ko Khuiah Boeipa Loh Yoethennah
\s2 Bring Your Vessels, Not A Few
\sp Doh is E.
\q1 
\v 1 Na ko khui ah Boeipa loh yoe
\q1 thennah muep m'paek na ham la,
\q1 Ti hnin ah nang na poek a?
\q1 Yan hlang cim rhoek caeh bang la
\q1 Na pa kah olkhueh ngaitang lah
\q1 Tahae na lo mahpawtnim.
\q2 \qt Na ko khui ah bae coih pawk la han suep ni.\qt*
\q2 \qt Boeipa thui bang la amhoeng mah \qt*
\q2 \qt muep han khuen uh van mai lah, \qt*
\q2 \qt Na khui ah mueihla tha om nah han suep ni. \qt*
\q2 \qt Cim Mueihla kah a tha om nah. \qt*
\q1 
\v 2 Jesuh thi loh a cim sak tae
\q1 na am hoeng te han khuen lah,
\q1 Hlang tloe khaw ha lo van saeh.
\q1 Pa then ngol khoel hmai ah,
\q1 Na pum ne rhing lamtah tawt mai dae,
\q1 Cim Muei hla ham suep duela,
\q1 
\v 3 A rhennah he si tui bangla
\q1 a bawt a pat thai moenih,
\q1 A lungnah khaw bawt tlaih pawh.
\q1 A ol khueh van bangla Cim
\q1 Muei hla tha omnah boeih te tah,
\q1 Am hoeng boeih dongah bae ni.
\c 369
\s1 Khangkung Kah Khue Ol Ka Yaak
\s2 Where He Leads
\sp Doh is F
\q1 
\v 1 Khang kung kah khue ol ka yaak thai,
\q1 Khang kung kah khue ol ka yaak thai
\q1 Khang kung kah khue ol ka yaak thai,
\q1 Na thing lam koh doeah ha bang lah.
\q1 
\v 2 A mah neh olcaeknah ka cet,
\q1 Amahneh olcaek nah ka cet
\q1 Amahneh olcaek nah ka cet
\q1 Melamkhaw amah neh hmaih ka cet.
\q1 
\v 3 Lungvatnah neh boeilen m'paek ni,
\q1 lungvatnah neh boeilen m'paek ni
\q1 Lungvatnah neh boeilen m'paek ni
\q1 Long pueng khing hmaih ka cet rhoi ngai ni.
\c 370
\s1 Boeipa Nang Ne Hmai Ah Cet Sih
\s2 O Master Let Me Walk With Thee
\sp Doh is Eb
\q1 
\v 1 Boeipa nang neh hmai ah cet sih,
\q1 Lunghoih nah neh bi bi sainah ah,
\q1 Na olhuep han thui hnom'phueih puei
\q1 Ueh thai na ham tha om nah m'pae.
\q1 
\v 2 Thin thah rhoek ko a tho na ham,
\q1 lungnah ol ding nen te m'bom n'cen lah,
\q1 Long hmang rhoek na la khueh thai ham,
\q1 Na mah ol ding ol tuk kil lah.
\q1 
\v 3 Na thin sen nah te n'awt sak lah,
\q1 Na taeng ah ka he n'om sak van lah,
\q1 Tang nah neh tha om na m'pae lah,
\q1 A thae boei te ka noeng na ham.
\q1 
\v 4 Ngai uep nah khosaeng then long tah,
\q1 Kho hmai kah khosak long a khui sak.
\q1 Nang long ni rhalthal nah na paek
\q1 Boei nang neh hmaih kho sa lah sih.
\c 371
\s1 Hingnah Lungnah Namah Kan Paek
\s2 My Life, My Love, I Give To Thee
\sp Doh is F
\q1 
\v 1 Hingnah lungnah namah kan paek,
\q1 Pathen capa kai ham na duek,
\q1 Uepom la om yoe yah ka ngaih
\q1 Ka khangkung ka Pathen.
\q2 \qt Kai yueng na duek tih kai ka hing,\qt*
\q2 \qt Ka hingnah dong omngaihnah bae, \qt*
\q2 \qt Kai yueng na duek tih kai ka hing\qt*
\q2 \qt Ka khangkung ka Pathen kan nawn.\qt*
\q1 
\v 2 Kai nan doe he ka tang na coeng,
\q1 Nang na duek tih kai ka hing coeng,
\q1 Ta hae lamkah kan tang nah coeng.
\q1 Ka khangkung ka Pa then.
\q1 
\v 3 Kal va ri tlang ah nang na duek,
\q1 Kai ka mueihla loeih sak ham la,
\q1 Ka hingnah he nang taeng kan nawn,
\q1 Ka khangkung ka Pa then.
\c 372
\s1 Kai Kah Hingnah He Lo Lamtah
\s2 Take My Life, And Let It Be
\sp Doh is G
\q1 
\v 1 Kai kah hingnah lo lamtah
\q1 Han cim caih sak ka Boeipa.
\q1 Ka khohnin boeih nang loh lo
\q1 Na mah koeh na la om saeh
\q1 Na mah koeh na la om saeh.
\q1 
\v 2 Kai kah kho he lo lamtah
\q1 Namah hamla bibi saeh.
\q1 Ka ol neh laa ka sa eh
\q1 Ka manghai boei koehnah laa
\q1 Ka manghai boei koeh nah laa.
\q1 
\v 3 Ka hmui ka he lo lamtah
\q1 Na ol thangthen thui na saeh,
\q1 sui ngun neh khuehtawn boeih he
\q1 Nang thangpomnah ham hno nah
\q1 Nang thangpomnah ham hno nah.
\q1 
\v 4 Kai kah lungnah boeih he khaw
\q1 Namah kho kung ah kan khuen,
\q1 Ka pum he nang loh hno nah
\q1 Nang kah hut la om pawn saeh
\q1 Nang kah hut la om pawn saeh.
\c 373
\s1 Jesuh Na Ngaih Bangla
\s2 My Jesus, As Thou Wilt
\sp Doh is Eb
\q1 
\v 1 Jesuh na ngaih bang la Na ko ngaih kai kongaih saeh.
\q1 Na lungnah kut dongah Ka pumrho hingnah boeih kan tloeng,
\q1 Ko thae a omngaih ah Na ko ngaih bang la n'khueh lah.
\q1 Boeipa kai m'bom lah ka ti, ka kah bih
\q1 Ka boei ko ngaih sai hamla m'bom lah.
\q1 
\v 2 Jesuh na ngaih bang la Mik phi tui a bo akhaw,
\q1 Ngai uepnah ai si te mevaeng akhaw han thih sak boeh,
\q1 Dik lai ah kothaenah Nang loh na ming van bang la
\q1 Nang neh kothae hmaih na he, ka koboei ko ngaih sai ham.
\q1 
\v 3 Jesuh na ngaih bang. la Soeprhaep boeih kai hamla then,
\q1 Hmai long kah tho vaelnah boeih a khaw nangni kan uepnah,
\q1 Vaan im long puei dueng ah Ngaimong ngaitoe la ka cet
\q1 Duekneh hingnah hmuen akhaw, ka boei kongaih sai ham.
\c 374
\s1 Aw Jesuh Ol Ka Khueh
\s2 O Jesus, I Have Promised
\sp Doh is G
\q1 
\v 1 Aw Jesuh ol ka khueh A bawt due nang bawk hamla,
\q1 Kai n'om puei yoe yah lah, Ka boeipa neh ka pa ya.
\q1 Caem rhal khaw ka rhih pawh Kai taeng nang na om atah,
\q1 Long puei ka hmang tlaih pawh, na mah loh nan mawt atah.
\q1 
\v 2 Ka taeng na om m'ming sak Diklai ah ka om vaengah,
\q1 Hmuh nah mik loh hmang tih, Cuekhalh ol ka te ka yaak.
\q1 Caemrhal loh ka taengah Ham vael khoep bal vaeng atah,
\q1 Jesuh nang ha yoei lah, Kai hlip kung tah nang pawn ni.
\q1 
\v 3 Aw Jesuh ol nan khueh Na hnuk bang hlang rhoek boeih neh
\q1 Ka tueih yoeih hlang rhoek ham, Aw Jesuh ol ka khueh coeng.
\q1 A bawt due nang bawk ham Na lungvatnah te m'pae lah,
\q1 Na hnuk ka bang na ham, Ka boeipa neh ka pa ya.
\c 375
\s1 Ka Boei Jesuh Nang Taeng Kan Bih
\s2 Take Me As I Am
\sp Doh is E. (Moderate)
\q1 
\v 1 Ka Boei Jesuh na taeng kan bih,
\q1 Nan bom pawt tah ka duek pawn ni,
\q1 A yoe paek khang nah te han khuen,
\q1 Ka om bang la n'lo lah.
\q1 Ka om bang la n'lo lah,
\q1 Ka om bang la n'doe lah
\q1 Kai ham Khrih a duek bueng ka thui,
\q1 ka om bang la n'lo lah.
\q1 
\v 2 Ngai daeng maila ka tholh tangkik,
\q1 Kai hamla na thii sen na hawk,
\q1 Na ngaih bangla kai he n'coeng sak,
\q1 Ka om bang la n'lo lah.
\q1 Ka om bang la n'lo lah,
\q1 Ka om bang la n'doe lah
\q1 Kai ham Khrih a duek bueng ka thui,
\q1 ka om bang la n'lo lah.
\q1 
\v 3 A then la ka rhueng ka phong pawh,
\q1 na ol khueh te ka phae coeng tih,
\q1 Na ming cim hamla kai n'khang lah,
\q1 Ka om bang la n'lo lah.
\q1 Ka om bang la n'lo lah,
\q1 Ka om bang la n'doe lah
\q1 Kai ham Khrih a duek bueng ka thui,
\q1 ka om bang la n'lo lah.
\q1 
\v 4 Khang boei kho kung ka kun n'so lah,
\q1 Na ming bangla kai he n'hno nah,
\q1 Bi bi hma toeng te khah ham la,
\q1 Ka om bang la n'lo lah.
\q1 Ka om bang la n'lo lah,
\q1 Ka om bang la n'doe lah
\q1 Kai ham Khrih a duek bueng ka thui,
\q1 ka om bang la n'lo lah.
\c 376
\s1 Boeipa Bangla Khosak Ham
\s2 More Like The Master
\sp Doh is Db
\q1 
\v 1 Boeipa bang la khosak ham ka om ni
\q1 Ko donah neh lung hoihnah a khueh te,
\q1 Bi bi nah dueng nah neh thin omna ha yet
\q1 Tha rhangnah neh cim nah a yet khue ka ngaih.
\q2 \qt Ka lungbuei he han lo lamtah\qt*
\q2 \qt namah ham bueng ni hing ka ngaih\qt*
\q2 \qt Ka lungbuei he nang bueng ham ni \qt*
\q2 \qt Tahae ka tholh cim caih sak ham ka ngaih.\qt*
\q1 
\v 2 Boeipa bangla vuen hlaem ah ka thangthui
\q1 Thing lam koh na thaomnah he ka ngoe,
\q1 A poengnah ram pai sak ham a yet ka ngaih.
\q1 Hlang hma khol cui ham na khoboe awt ka ngaih.
\q1 
\v 3 Boeipa bangla hing ti rhoeng ham ka ngaih
\q1 A lungnah he hlang tloe tueng ham ka ngaih,
\q1 Amah bangla ka pum he voeih ka ngaih
\q1 vaan Boeipa bangla kho sak na thai ham ka ngaih.
\c 377
\s1 Namah Kongaih La Om Sak
\s2 Have Thine Own Way Lord
\sp Doh is Eb
\q1 
\v 1 Na mah ko ngaih la n'om sak boeipa,
\q1 Nang tah am saii kung kai amlai ni
\q1 Na ko ngaih bangla n'hluem n'bael lamtah,
\q1 Ta hae ah kai ka kun tih kan rhing.
\q1 
\v 2 Na mah ko ngaih la n'om sak boeipa
\q1 Ti hnin ah kai he n'noem cai mai lah,
\q1 Vuel song lakah a bok ngai la n'sil
\q1 Na hmai ah kodo la ka kuep coeng.
\q1 
\v 3 Na mah ko ngaih la n'om sak boeipa
\q1 Lakueng vaengah bom na ham kan bih,
\q1 Thaomnah boeih te namah ka ni,
\q1 Khangkung Pathen kai he n'hoeih sak lah.
\q1 
\v 4 Na mah kongaih la n'om sak boeipa
\q1 Ka hingnah boeih na mah loh tu lah,
\q1 A Cim Mueihla neh ka m'baetawt sak
\q1 Khrih bueng he kai ko khui ah hing saeh.
\c 378
\s1 Boei Jesuh Kah Cil Han Thui Lah
\s2 Tell Me The Stories Of Jesus
\sp Doh is C
\q1 
\v 1 Boei Jesuh kah cil han thui lah,
\q1 Ka ko khui ah rhaeh rhong saeh,
\q1 A phu tlo koek cil han thui lah,
\q1 ka yaak vaeng di dip tang kik,
\q1 Vaan hlang loh laa then a sak te,
\q1 Amah thangnah uem nah laa
\q1 A so sang Pathen Boeilen saeh
\q1 Diklai ah rhal thalnah om saeh.
\q2 \qt Boei Jesuh kah kawng han thui lah,\qt*
\q2 \qt Ka ko khui ah rhaeh rhong saeh,\qt*
\q2 \qt A phu tlo koek cil han thui lah,\qt*
\q2 \qt ka yaak vaeng didip tang kik\qt*
\q1 
\v 2 Rham rhae ah buh a yaehna neh,
\q1 Thohkoepnah khohnin thui lah,
\q1 Ma mih tholh yueng a cuek halh dae
\q1 a bawt ah a noeng na te,
\q1 Kum sen hlang bi a bi na neh,
\q1 Kothae a ming na cil te
\q1 A tam daeng tam kha a ueh tih
\q1 Khodaeng a ming na khawng boeih te,
\q1 
\v 3 Thing lam dong ah a khingnah neh,
\q1 Patang a khang na kawng te,
\q1 A vuei nah hlan kawng te han thui
\q1 A thohkoep na a kawng te.
\q1 A lungnah tah tlo tangkik tih,
\q1 a soep te ka hmuh cim coeng.
\q1 Ka ko dang ah ka thoel lah eh,
\q1 Kai lungnah neh kai tlannah te.
\c 379
\s1 A u Vaa Lamkah Ka Rhum
\s2 Jesus Christ Our Saviour
\sp Doh is G
\q1 
\v 1 Au vaan lamkah ka rhum
\q1 Jesuh ma mih khang kung
\q1 Ca moe bangla a cun a?
\q1 Jesuh ma mih khang kung,
\q2 \qt Om ngaihnah neh thangthen uh,\qt*
\q2 \qt khangnah te tah m'paek uh coeng, \qt*
\q2 \qt Amah bangla u om pawh \qt*
\q2 \qt Jesuh mamih khangkung\qt*
\q1 
\v 2 A u thing dong a tai uh
\q1 Jesuh ma mih khang kung
\q1 Nang neh kai ham a yok a?
\q1 Jesuh mamih khangkung
\q1 
\v 3 A u khodawk a ka ngai
\q1 Jesuh ma mih khang kung
\q1 U long hing nah ol a thui?
\q1 Jesuh mamih khangkung.
\q1 
\v 4 A u dungyan lai tloek kung
\q1 Jesuh mamih khang kung
\q1 Ukah ol nim n'ngai uh eh?
\q1 Jesuh ma mih khangkung.
\c 380
\s1 Jesuh Loh Mamih Vangnah
\s2 Jesus Bids Us Shine
\sp Doh is G
\q1 
\v 1 Jesuh loh mamih vangnah neh m'vang sak,
\q1 Khoyin khui kah hmai thoi a vang van bangla.
\q1 He diklai kho yin na ram khui ah he
\q1 Mamih om na kung boeih ah vang uh sih.
\q1 
\v 2 Jesuh ma mih ham lam hmacuek la vang,
\q1 Mamih kah hmaisuep he amah loh a ming,
\q1 Mamih vang ham vaan lamkah han sawt thuk
\q1 Mamih om na kung boeih ah vang uh sih.
\q1 
\v 3 Jesuh loh taengvai hamla m'vang sak uh.
\q1 Yinnah soep rhaep taeng vai boeih ah khoep m'vael uh.
\q1 Tholh ko thae vawtthoeknah a om dongah
\q1 Mamih om na kung boeih ah vang uh sih.
\c 381
\s1 Jesuh Loh Lungnah Ka Ming
\s2 Jesus Loves Me
\sp Doh is Eb
\q1 
\v 1 Jesuh loh n'lung nah ka ming
\q1 Bai bal loh a thui dongah,
\q1 Ca moe khaw amah kah ni,
\q1 A tha yol dae tha a paek.
\q2 \qt Jesuh long n'lung nah\qt*
\q2 \qt Jesuh loh n'lung nah \qt*
\q2 \qt Jesuh loh n'lung nah\qt*
\q2 \qt Bai bal ah boeih a thui.\qt*
\q1 
\v 2 Jesuh loh n'lung nah ka ming
\q1 Vaan dong thoh ka han ong coeng
\q1 Ka tholh boeih a silh vetih,
\q1 Ca moe boeih te a kun sak.
\q1 
\v 3 Jesuh loh n'lung nah ka ming
\q1 Ka pum boeih he amah kah
\q1 Kai ham thinglam ah duek coeng,
\q1 dung yan la ka hingnah ham.
\c 382
\s1 Halo Vaengah
\s2 Jewels
\sp Doh is E.
\q1 
\v 1 Ha lo vaengah ha lo vaengah
\q1 lungthen boeih a coi ni,
\q1 Lung then a phu ka tlo koek te,
\q1 A lungnah rhoek te.
\q2 \qt Min cang thui pa bangla sae,\qt*
\q2 \qt A lu muek loh phaa tih, \qt*
\q2 \qt A hlang then na ah\qt*
\q2 \qt lung then te a khuem uh boeih.\qt*
\q1 
\v 2 A coi ngai ni a coi ngai ni
\q1 A poengnah kah lung then
\q1 aka cim aka pha lung then,
\q1 A lungnah rhoek te.
\q1 
\v 3 Ca moe rhoek loh ca moe rhoek loh
\q1 tlankung boei a lungnah,
\q1 Lung then a phu aka then koek,
\q1 A lungnah rhoek te.
\c 383
\s1 Vaan Dong Kho A Pa Taeng Ka Omngaih
\s2 Jesus Loves Even Me
\sp Doh is G
\q1 
\v 1 Vaan dong kho a pa taeng ka omngaih hlang,
\q1 A Baibal dong ah lungnah ol a thui,
\q1 Baibal cim ah ko poek rhai ka hmuh tah,
\q1 Jesuh loh n'lung nah aka then koek ni.
\q1 
\v 2 Amah ka hnilh tih ka pamdah cakhaw,
\q1 Ka pamdah kung ah amah loh n'lungnah,
\q1 Amah loh n'lungnah te ka poek vaeng ah,
\q1 Amah taengah bal ham kut neh n'ya vaih.
\q2 \qt Boei Jesuh loh thintlohnah dongah\qt*
\q2 \qt ka omngaih hlang ka omngaih hlang \qt*
\q2 \qt Boei Jesuh loh thintlohnah dongah \qt*
\q2 \qt ka omngaih tangkik hlang\qt*
\q1 
\v 3 A boei a len neh a boei na bueng he,
\q1 Kai loh ka koeh na ham laa then la om,
\q1 Dungyan due kai loh ka sak ham laa tah,
\q1 Jesuh loh thin tlohnah tang kik mah aw.
\q1 
\v 4 Jesuh loh n'lung na ti ka lungnah van,
\q1 Lungnah loh ka mueihla te a tlan coeng,
\q1 Lungnah loh thinglam ah lu a voeih sak,
\q1 Jesuh loh thin tlohnah tangkik mah aw.
\q1 
\v 5 Me tlam na thui thai ti la n'dawt koinih,
\q1 A Cim Muei hla loh ka khui ah m'ming puei.
\q1 Amah neh ka mueihla rhoep uh rhoi tih
\q1 Thin tlohnah kawng ka ming te a cak sak.
\c 384
\s1 Camoe Rhoek Longkhaw
\s2 Children May Be Heralds
\sp Doh is D
\q1 
\v 1 Camoe ca rhoek long khaw tlan nah olthang a pang puei ni,
\q1 Mamih tlan kung neh thinglam kawng te a thui uh ni,
\q1 Mingpawt kho li thui tung bungtlang kah nu ca koina te,
\q1 Lolmang phoelphoeng sak ham Baibal ca te a pat uh.
\q2 \qt Ca moe rhoek long khaw a thui ni,\qt*
\q2 \qt Khang kung boei ka lung nah omngiah olthang te, \qt*
\q2 \qt Camoe rhoek long khaw a thui ni, \qt*
\q2 \qt Vaan dong im then la caeh long te a tueng thai.\qt*
\q1 
\v 2 Ca moe rhoek loh Boeipa ka mision bi te a bi uh,
\q1 Kothae ngaihmang khomong kho mai ah omngaih uh thai,
\q1 Kopang rhah na neh pa tang lakli ah om mai ca khaw,
\q1 Rhennah he mol dong khosae bang la a khuen uh thai.
\q1 
\v 4 Ca moe rhoek loh khang kung ol khueh te a ngai tang na uh,
\q1 Lam hma la Khohni lungvat rhen nah a pang uh thai,
\q1 Boeipa loh a mih so ah a then la a dawn a dah,
\q1 Vaan caeltueih loh pa mikhmai a hmuh te a thui uh.
\c 385
\s1 Hingnah Tue Then He Toi
\s2 Life At Best Is Very Brief
\sp Doh is Eb
\q1 
\v 1 Hingnah tue then he toi ca
\q1 thing hnah rhohu loh rhul tih,
\q1 cangvuei bang la cuhu boeih rhueng phong laeh,
\q1 Hing khui khohnin voeh voeh khum,
\q1 dueknah tue loh ha yoei coeng
\q1 Tlohtat long khaw cing pawn ni rhueng phong laeh.
\q2 \qt Rhueng phong laeh rhueng phong laeh\qt*
\q2 \qt Jesuh loh a ol neh nang n'khue rhueng phong laeh, \qt*
\q2 \qt Tholh dong yulh na om a tah thoh ka khoep han khaih ve tih\qt*
\q2 \qt Kothae boep la na om ni rhueng phong laeh. \qt*
\q1 Danngaih pai then loh tlumtloi,
\q1 Rhoeng li sakthen long khaw khum,
\q1 Kum sen na hing tang mah pawh, rhueng phong laeh.
\q1 Pathen Mueihla loh n'khue he nang hlang tholh pamdah voel boeh
\q1 Yoethae loh kae hlan vaeng ah rhueng phong laeh.
\q1 A tue long tah voeh voeh khum,
\q1 Duek phoei laitloek nah loh yoei,
\q1 Jesuh taeng ah om ham la, rhueng phong laeh,
\q1 Nang hamla kai ka thang thui duek nah tui na kat vaeng ah,
\q1 Hell ram na pha na pawt ham rhueng phong laeh.
\c 386
\s1 Aw Omngaih Hnin Omngaih La
\s2 Oh Happy Oh
\sp Doh is Ab
\q1 
\v 1 Aw omngaih hnin omngaih la kuntun nah,
\q1 Om ngaih ca la hum tun soep la om nah,
\q1 (vaeng ah) ke kah kho cil voel ah a voel vai ah om hmaih ni.
\q1 Hlang cim boeih loh tun soep na om ve tih
\q1 boeipa mah loh hmai ah caeh puei pawn ni
\q1 (vaan ah) nang neh kai lam tawn coeng.
\q1 
\v 2 Ma mih loeih nah kho hnin pha vaengah tah,
\q1 hlang cim rhoek neh ma mih rhoek boeih laa n'sak pawn ni,
\q1 he di lai im lam ka loh mueihla n'ho uh pawn ni.
\q1 Te kho hnin tah voeh voeh ah ha yoei coeng
\q1 vaan dong Pathen loh voeh voeh pha tom coeng
\q1 (vaan ah) vaan hlang laa a sak uh.
\q2 \qt Vaan ah vaan ah rhai khaw tlum tloi tlaih pawh,\qt*
\q2 \qt dung yan hing nah vaan ah\qt*
\q2 \qt vaan hlang rhoek loh kai rhing oel. \qt*
\q2 \qt Vaan hlang rhoek loh sui tingtoeng a tum tih\qt*
\q2 \qt hlang cim rhoek loh laa then koek a sak uh\qt*
\q2 \qt vaan ah dung yan la omngaih uh. \qt*
\c 387
\s1 Khrihca Thoo Uh
\s2 Go And Work
\sp Doh is C
\q1 
\v 1 Khrihca tho uh ip voel boeh
\q1 kothae na hloep mah pawt nim,
\q1 A ol te mpaek li vaeng ah
\q1 Mamih ngol sut mai a ya.
\q2 \qt Cet lam bi bi bi tong laeh\qt*
\q2 \qt cet lam tlap a ka hma rhoek \qt*
\q2 \qt Tholh yin rhihom khui lam kah\qt*
\q2 \qt Buhloei lung la ham mawt lah.\qt*
\q1 
\v 2 Khang kung te n'lung na tang a?
\q1 A ol khueh n'tang na uh a?
\q1 Soeprhaep ah na moei hoeih a?
\q1 A ol na ngai mah pawt a?
\q1 
\v 3 Tang nah te lai la m'ba a?
\q1 N'thui tuen bang la kho n'sak a?
\q1 A mah bueng hamla n'om a?
\q1 Bi bi neh tang nah tueng a?
\q1 
\v 4 Thing lam tung kawt uh ca khaw
\q1 Suilumuek ngaiuep a tah,
\q1 Cet sih thayung te huel sih,
\q1 A tue toi kho hnin loh yol.
\c 388
\s1 Me Bang Tuiphu Thoo Saeh
\s2 Keep Step With The Master
\sp Doh is Db
\q1 
\v 1 Me bang tuiphu thoo saeh Boeipa neh hmaih cet.
\q1 Longpuei khoyin ca khaw, hoihaeng kung taeng cet,
\q1 Rhal loh nang te n'yoek tih rhih om nuen yoei dae,
\q1 Jesuh neh hmaih cet lah rhih na om mah pawh.
\q2 \qt Thinom la hmai ben ah cet uh\qt*
\q2 \qt Thadueng thai koep ah cuen sak \qt*
\q2 \qt Hnin takuem ah khangkung neh cet\qt*
\q2 \qt A bawt due a mah loh mawt ngai ni. \qt*
\q1 
\v 2 Mela na caeh a khaw Boeipa neh hmaih cet,
\q1 Khoyin kho khup a khaw, longpuei te n'tueng ni,
\q1 Amah ka vang nah loh long puei hmuh sak ni,
\q1 Rhamrhae ram boeih long khaw koep ah pailum ni.
\q1 
\v 3 Longpueng ah duem mueh la Boeipa neh hmaih cet,
\q1 A mah ol thui boeih te, a loe la hna tun,
\q1 Amah neh a tha om na dong ah om lah,
\q1 Jesuh neh hmaih na caeh a tah boeih ah then.
\c 389
\s1 Hlangnoe La na Om
\s2 Now In The Day Of Youth
\sp Doh is Eb
\q1 
\v 1 Hlang noe la ka om vaeng ka tha a rhang vaeng ah,
\q1 Nang ka hing nah ka boeipa te thin ko kan paek uh,
\q1 Ka kut doe han uem lah, Na ko ngaih la hno nah,
\q1 A pa ko ngaih soep sak hamla Ka hing khui ah m'bom lah
\q1 
\v 2 Mela ka om a khaw Na kongaih te sai tih,
\q1 Na hmai ah ka om vanbangla thin ko he n'khueh sai
\q1 Hno len khaw tuek mueh la, hno yit khaw hnawt mueh la,
\q1 Bi bi boei he na mah kut ah m'hmu sak m'ming sak van lah.
\q1 
\v 3 Oltak la thin ko cim Ka ngaih na ham m'bom lah,
\q1 Set ca mai khaw tui phih rhaboe ka om u pawt tih,
\q1 Tong a neh bi rhih la Ka om na pawt ham m'bom
\q1 A hno te ka ka ngai tih a cim pawt te hnawt na ham
\q1 
\v 4 Boei Jesuh CimMueihla Ka lungbuei ham vang sak,
\q1 A cim lung nah hing nah long puei Ka vai nah thai ham
\q1 Hmailong ben kun hamla Na mah loh m'poek van lah,
\q1 A pa ram khui dungyan hing nah Ka pha uh hlan due la.
\c 390
\s1 Yancil Rhuem Te Han Thui Lah
\s2 Tell Me The Old, Old Story
\sp Doh is C
\q1 
\v 1 Yancil rhuem te han thui lah so ben kah ming mueh te,
\q1 Jesuh boeilen na neh a mah kah a lung vatnah.
\q1 Ol yoei ca neh koep han thui lah camoe casen bangla.
\q1 Thahnoeng neh hlang tholh a ka bom kung tloe ka khueh pawh.
\q2 \qt Yan cil rhuem te han thui lah,\qt*
\q2 \qt Yan cil rhuem te han thui lah\qt*
\q2 \qt Jesuh kah a lungvat na yan cil rhuem han thui lah\qt*
\q1 
\v 2 A yai la cil han thui kai loh ka ming na ham la
\q1 Te cil tah tlan na neh tholh a hoei na cil la om.
\q1 Koep koep ah han thui bal dae lah Ka hnil na pawt ham la.
\q1 Mincang dotui long he Khothun ah a hma bang la
\q1 Yancil rhuem te han thui lah rhih nah ka tong vaeng ah
\q1 Diklai toelen na khum vaeng ah te ol a phu tlo
\q1 Dik lai omthen ka lungbuei ah a cuen hang vaengah te
\q1 Jesuh loh hlang soep la n'khueh na cil te han thui lah.
\c 391
\s1 Lumim Ka Khueh Vaan Dong Sang Kah
\s2 Way Beyond the Blue
\q1 
\v 1 Lumim ka khueh vaan dong sang kah kho cil voelah
\q1 Lum im then ka khueh vaan dong sang kah kho cil voel ah,
\q1 Lum im ka khueh van dong sang kah khocil voel ah
\q1 Kho cil voel a ke.
\q2 \qt Cet u sih khocil voel la cet sih \qt*
\q2 \qt cet uh sih kho cil voel la cet sih \qt*
\q2 \qt cet uh sih kho cil voel la ce sih vaan im la cet sih.\qt*
\q1 
\v 2 Khang kung Boeipa Jesuh ka khueh nang khaw khueh van
\q1 Kang kung boeipa Jesuh ka khueh nang khaw khueh van,
\q1 Khang kung boeipa Jesuh ka khueh nang khaw khueh van
\q1 Nang te khaw n'khue van.
\c 392
\s1 Na Noeng Aya Boeipa Loh Ti
\s2 Are Ye Able Said The Master
\sp Doh is Ab
\q1 
\v 1 Na noeng a ya Boeipa loh ti
\q1 Kai neh hmaih ah tai ham la,
\q1 Oe hmantang ah koep ka thui tih,
\q1 Duek due nang hnuk ka bang ni.
\q2 \qt Boeipa ka noeng ni ka hmueihla nang kah,\qt*
\q2 \qt Na mah bang la kai mih koep n'sai lah. \qt*
\q2 \qt Kaimih so ah na mah loh n'hoihaeng lah, \qt*
\q2 \qt Pathen nang taeng ah uep om la om na ham. \qt*
\q1 
\v 2 Na ko na hlawt thai pueng aya?
\q1 A huep la koep ha lo nah,
\q1 Nang kho dawk ngai la omnah te,
\q1 Vaan ah nang ham hmuen om a?
\q1 
\v 3 Na boeipa la na khueh pueng a?
\q1 Olding la na taeng ah n'toi
\q1 Muei hla loh thinomnah a thui
\q1 na ko te cak tak a ya?
\c 393
\s1 Tuiva Rhal Ben Ka Dan Vaengah
\s2 Swing Low, Sweet Chariot
\sp Doh is Ab
\q2 \qt Tuiva rhal ben ka dan vaeng ah ka hmuh tah\qt*
\q2 \qt Vaan im la luei puei ham ha lo\qt*
\q2 \qt Vaan hlang ping rhoek neh hmai kai phoei ah ha lo uh, \qt*
\q2 \qt Vaan im la luei puei ham ha lo. \qt*
\q1 
\v 1 Vai a tah ka rhum vai a tah ka luei hang
\q1 Vaan im la luei puei ham ha lo
\q1 Ka mueihla loh vaan im bueng ke ni a lam tawn
\q1 Vaan im la luei puei ham ha lo.
\q1 
\v 2 Cet lamhma pueivan taeng ah kai van te khaw,
\q1 Vaan im la luei puei ham ha lo
\q1 Ka puei rhoek aw thui hamla ka ngaih vaan te tah
\q1 Vaan im la luei puei ham ha lo.
\q1 
\v 3 Sui kho puei om then te
\q1 Hlang com hlang ci rhoek boeih ham la,
\q1 Khang kung Jesuh rhang neh
\q1 nang neh kai ham thoh han ong coeng
\c 394
\s1 Khrih Neh Hlangboel Ham Tila
\s2 For Christ And The Church
\sp Doh is D
\q1 
\v 1 Khrih neh hlang boel ham ti la pang boeih uh,
\q1 Ma mih manghai boei ming hin yahnah pae u sih,
\q1 Hlangnoe tha neh bi bi hamla cai uh sih,
\q1 Oltak neh ram ham uepom la pai u sih.
\q2 \qt Khrih mamih tlan kung \qt*
\q2 \qt boei neh ma mih ham ka duek ke,\qt*
\q2 \qt Thisen neh hlangboel he na lai, \qt*
\q2 \qt Boeipa kai mih cim sak.\qt*
\q1 
\v 2 Khrih neh hlang boel ham oltak la thang thui,
\q1 Thing lam koh doe hnin ta kuem a hnuk bang uh sih,
\q1 Cim Muei hla tha om na dong hangdang uh sih,
\q1 Hingnah tue then khui amah bi bi uh sih
\q1 
\v 3 Khrih neh hlang boel ham moei hoeih la pae sih,
\q1 A tue tang cueih thai nah sui ngun boeih hmoel uh sih,
\q1 N'sai thai khui tah amah hamla sai uh sih,
\q1 Lungnah thin ko he tah khum yip thai mah pawh.
\c 395
\s1 Khangkung Tudawn Bangla Mawt
\s2 Saviour Like A Shepherd Lead Us
\sp Doh is Eb
\q1 
\v 1 Khang kung tu dawn bangla m'mawt uh,
\q1 Nan dawndahnah muep ka ngoe,
\q1 Rham tlim then ah n'luem sak uh lah,
\q1 Kaimih ham im then na khueh,
\q1 Thin tlo Jesuh thin tlo Jesuh
\q1 Nan lai tih nang kah hlang ni,
\q1 Thintlo Jesuh thintlo Jesuh
\q1 nan lai tih nang kah hlang ni.
\q1 
\v 2 Na hlang la ka om nang hui then,
\q1 Long puei tueng kung la ha om,
\q1 Na tu ping te na khoem na bael
\q1 Long hmang hlang te koep na tlap,
\q1 Thin tlo Jesuh thin tlo Jesuh
\q1 Na ca rhoek thang thui na rhoi,
\q1 Thin tlo Jesuh thin tlo Jesuh
\q1 na ca rhoek thang thui na rhoi.
\q1 
\v 3 Mincang ah na mik then ka tlap
\q1 Na kongaih te sai ka ngaih
\q1 Nang bueng ni ka boei ngaih om tih
\q1 lungnah rhaipai nan phuelh sak,
\q1 Thin tlo Jesuh thin tlo Jesuh
\q1 Ta hae due ah nan lung nah,
\q1 Thin tlo Jesuh thin tlo Jesuh
\q1 ta hae due la nan lungnah.
\q1 
\v 4 Kaimih he doe ham ol na khueh
\q1 Hlang tholh la ka om uh dae
\q1 Nang loh kai mih he nan hlawt tih
\q1 lungvatnah neh nan silh coeng
\q1 Thin tlo Jesuh thin tlo Jesuh
\q1 Na taengla mael yue ka ngaih,
\q1 Thin tlo Jesuh thin tlo Jesuh
\q1 na taengla mael yue ka ngaih.
\c 396
\s1 Ka Poek Hnin Ka Pha Vaeng
\s2 If I Could Hear My Mother's Prayer
\sp Doh is Bb
\q1 
\v 1 Ka poek hnin ka pha vaeng omthen tangkik hlang mai,
\q1 vuen hlaem ah kai loh koep ah ka poek tih,
\q1 A nu thangthui ol loh ka yaak vaeng ka ko hoe,
\q1 A nu thangthui ol ka yaak koep lah sue.
\q2 \qt A nu thangthui koep ka ya thai koi nih\qt*
\q2 \qt A nu yilhka cang ding ol bueng he lol mang ka taeng nah, \qt*
\q2 \qt Kai ham di dip tang kik hlang\qt*
\q2 \qt A nu thang thui ol ka yaak koep kah sue.\qt*
\q1 
\v 2 Kai ham thang thui yoe yah Jesuh bueng a uep nah,
\q1 Olthangthen longpuei a vai na thai ham,
\q1 Thinphoei a nu muei ke van im duek tlap ka ngaih,
\q1 Jesu kongaih tang nah tih kho ka sak.
\q1 
\v 3 Lumim khui om vaeng kah mik hmai hlampan na loh,
\q1 Omngaih ngaimong ngaiuep na la ha coeng,
\q1 Dung yan boeipa a koeh a thangthen nah ol te,
\q1 van hlang loh yaak ngaih yaak hlue la om bal.
\q1 
\v 4 Lai hman bi bi a coeng, hingnah long khaw khum coeng,
\q1 Vaandong lumim then khui dong ah duem coeng,
\q1 Mincang kho a thai vaeng omngaih la kai n'doe ni,
\q1 dung yan lung vat nah lumim then khui ah.
\c 397
\s1 He Diklai Muei Thennah Ham
\s2 For The Beauty Of The Earth
\sp Doh is Ab
\q1 
\v 1 He diklai muei thennah ham
\q1 Vaan kah boeilen tueng na ham
\q1 Lungnah loh thang paek lamkah
\q1 mamih taeng vai ah a vael,
\q1 Soeprhaep boeipa nang taeng ah,
\q1 he kah laa neh kan thangthen.
\q1 
\v 2 A tue he ko poek rhai om,
\q1 Kho yin kho thaih hlaem min cang,
\q1 Mol neh tlang kah rhai pai neh
\q1 Khosae hla vaan ai si loh.
\q1 Soeprhaep boeipa nang taeng ah,
\q1 he kah laa neh kan thangthen.
\q1 
\v 3 Lungnah dong omngaihnah ham,
\q1 Ngan nu ngan pa koeina boeih,
\q1 Vaan neh lai pa yalai koi,
\q1 tolrhum pil nam rhoek boeih ham,
\q1 Soeprhaep boeipa nang taeng ah,
\q1 he kah laa neh kan thangthen.
\q1 
\v 4 Hlang boel neh hlang boeih hamla,
\q1 Na kut vaan la thueng uh lah,
\q1 Hlang ham te pae uh van lah,
\q1 lungnah te hmueih la nawn uh.
\q1 Soeprhaep boeipa nang taeng ah,
\q1 he kah laa neh kan thangthen.
\c 398
\s1 Boei Jesuh Taeng Ka Patang Ka Thui Ni
\s2 I Must Tell Jesus
\sp Doh is Eb
\q1 
\v 1 Boei Jesuh taeng ka patang ka thui ni,
\q1 Kamah bueng loh hno rhih ka phueih tloel,
\q1 Ka ngai a hmang vaengah mah loh m'bom ni,
\q1 A mah loh n'lung nah kai he n'ngai thuen.
\q2 \qt Jesuh taeng ka thui Jesuh taeng ka thui\qt*
\q2 \qt Ka mah bueng hnorhi he ka na pawh, \qt*
\q2 \qt Jesuh taeng ka thui Jesuh taeng ka thui\qt*
\q2 \qt a mah bueng ni a ka bom thai kung.\qt*
\q1 
\v 2 BoeiJesuh taeng ngaihmang nah ka thui ni,
\q1 A mah tah hlang yawn poek kung la om.
\q1 Bomnah ka bih vaeng ah kai m'bom pawn ni,
\q1 ngaihmang khaw a yoei la bawt pawn ni.
\q1 
\v 3 Cuekhalhnah neh yoek na ka tong vaeng ah,
\q1 Hno rhih a ka talong thai kung ni.
\q1 Boeipa Jesuh taeng ah ka thui pawn ni,
\q1 Kothae na boeih te ka hal pawn ni.
\q1 
\v 4 Diklai thae na loh yoek mai bal coeng tih,
\q1 tholh loh ka lungbuei piyen ca khaw,
\q1 Jesuh taeng ah bom na ka bih pawn ni,
\q1 Dik lai boeih he ka noeng van pawn ni.
\c 399
\s1 Boeipa Jesuh A Lungvatnah
\s2 Jesus, Lord of Grace
\sp Doh is Eb
\q1 
\v 1 Boeipa Jesuh a lung vat nah,
\q1 hlanghma tang tae mai te n'khue tih,
\q1 Kai ham thisen tlo te a long sak,
\q1 Hlang hma tang tae koep ah tlan ham la.
\q2 \qt Aw dung tang kik tih sang tang kik\qt*
\q2 \qt Hlang tholh lak li ah a tai te\qt*
\q2 \qt bang kong mai a nim van boei capa\qt*
\q2 \qt Ka hlang tholh hamla a duek nah ke.\qt*
\q1 
\v 2 Tholh ca rhoek boeih te khang ham la,
\q1 vaan boeilen koek capa long ke,
\q1 Lai kongduk neh thinglam dong a ke,
\q1 Aw dung tang kik sang tang kik mah aw.
\q1 
\v 3 Namtom hlang rhoek boeih ha lo uh,
\q1 omngaih ngaimong na phu tlo te,
\q1 boeipa Jesuh long ah m'paek uh coeng,
\q1 A ram omthen dong la n'caeh puei ni.
\c 400
\s1 Imkhui Lungnah Om Vaengah
\s2 Love In The Family
\sp Doh is Ab
\q1 
\v 1 Im khui lungnah om vaengah
\q1 taeng vai neh boeih rhoep,
\q1 Im khui lungnah om vaengah ko hoe ol ding n'yaak.
\q1 Om ngaih ngai mongnah bae tih,
\q1 Mik hmai hlam pan bueng te m'hmuh
\q1 Ding suek ca la a tue boeih lungnah im khui ah.
\q1 Lung nah then lungnah cim
\q1 Ding suek ca la a tue boeih lungnah im khui ah.
\q1 
\v 2 Im khui lungnah om vaengah
\q1 hlam khui khaw om then,
\q1 Toh thi nah uetnah ompawh lungnah imkhui ah,
\q1 A caeh long pai then la om,
\q1 Diklai pum hmuen then la om,
\q1 Hing soep nah te a dang uh, lung nah im khui ah.
\q1 Lung nah then lungnah cim
\q1 Ding suek ca la a tue boeih lungnah im khui ah.
\q1 
\v 3 Im khui lungnah om vaengah
\q1 soeprhaep boeih rhoep thai,
\q1 Cak ok long khaw boeih ah tui lungnah imkhui ah
\q1 Im ben neh rhoep na la om
\q1 Berhoep neh lung na la coeng
\q1 Yin lai boeih loh omngaih tih ming then na neh bae
\q1 Lung nah then lungnah cim
\q1 Ding suek ca la a tue boeih lungnah im khui ah.
\q1 
\v 4 Im khui lungnah om vaengah
\q1 van omngaihnah tueng
\q1 Dik lai lung vatnah bae tawt lungnah imkhui ah.
\q1 Sok ca tui loh laa a sak vaan ah omngaihnah kho sae
\q1 So ben kohoe na loh bae lung nah imkhui ah.
\q1 Lung nah then lungnah cim
\q1 Ding suek ca la a tue boeih lungnah im khui ah.
\c 401
\s1 Khrih Kah Lungnah Loh Ngah Ngah
\sp Doh is G
\q1 
\v 1 Khrih kah lungnah loh ngahngah tueih la ka om,
\q1 Kai hlangtholh hamla he a duek dongah,
\q1 Kamah ham hing kolla amah ham hing ham,
\q1 Ka pae uh coeng aka hma rhoek tlap ham,
\q2 \qt Ka boeipa loh khue nah ol te tah ka yak coeng\qt*
\q2 \qt a bi bi tom hlaep phueih hamla, \qt*
\q2 \qt Boei Krih yueng la lai pai la n'om uh coeng, \qt*
\q2 \qt duekduela uep om neh bi phueih ham la.\qt*
\q1 
\v 2 Aw boeipa diklai boeih boeih he dan sak lah,
\q1 Muei hla hma yin khui ah aka om rhoek
\q1 Khangnah ol thangthen a teng ah thui ham la,
\q1 Na Cim Muei hla neh kai he n'thoeih cam lah.
\q1 
\v 3 Na ram hamla bi hamla nan khue dong ah,
\q1 n'thoeih cam lah na ol neh lung vatnah neh,
\q1 Thin omnah ko donah neh thin tloh nah te,
\q1 Namah ah ka om boeih boei khueh sak lah.
\q1 
\v 4 Ka boeipa uehnah te ueh puei phueih hamla,
\q1 Ka pum sa neh mueihla ka khueh boeih neh,
\q1 Om ngaih la a muei ka hmuh na thai ham la,
\q1 Ka pae u coeng ka hma rhoek tlap hamla.
\c 402
\s1 Patang Rhainah Soeprhaep
\sp Doh is A
\q1 
\v 1 Pa tang rhainah soep rhaep neh
\q1 he diklai hman hlang boeih,
\q1 tholh hnorhih boeih a phueih uh,
\q1 Rhungrhah mikphi yin khui ah bom kung a om mueh la
\q1 hlan mol boeih khum uh
\q2 \qt Tholh ah Pa tang khang hlang boeih\qt*
\q2 \qt Boei Jesuh loh n'khue li \qt*
\q2 \qt ta hae ka taengla ha lo duem nah hmuh ham, \qt*
\q2 \qt Khrih kah hno tah yanghoep tih, \qt*
\q2 \qt a phueih ham khaw then hlang, \qt*
\q2 \qt kodo thindo na a mah taeng ah cang yoeyah uh sih.\qt*
\q1 
\v 2 Cang khuen nu pa loh tal tih he diklai hing khui ah,
\q1 cadah la ka om ca khaw,
\q1 Khrih kah lung vatnah long tah amah
\q1 taengla hlang boeih ta hae a khue li
\q1 
\v 3 He diklai kah mik hmuh ah
\q1 hlang tholh la ka om dae,
\q1 Khrih amah loh kai n'lung nah,
\q1 tholhyutnah neh ta hae ah
\q1 a taengla ka mael tih a ca la kai n'khueh
\c 403
\s1 Jesuh Loh Kho Tom Boeih
\s2 Jesus Shall Reign
\sp Doh is E
\q1 
\v 1 Jesuh loh kho tom boeih a uk,
\q1 Kho sae loh a caeh na boeih ah,
\q1 Tuipuei tui rhal khat ben ram duela,
\q1 Hlasae hla yaem ti om tlaih pawh.
\q1 
\v 2 Olcom olcae nam tom hlang loh
\q1 A taengah phung ding laa neh om,
\q1 Ca moe rhoek long khaw a pang puei uh,
\q1 A ming neh yoe then a dang te.
\q1 
\v 3 A taengah thangthui nah bawt pawh,
\q1 Sui lu muek te rhip a muek sak,
\q1 A ming then a bo a tui sak bal,
\q1 Min cang kho sae hmueih hlut na loh.
\q1 
\v 4 Dik lai pum loh tho uh vetih,
\q1 manghaiboei ming a thang pom ni,
\q1 Laa then sak neh vaan hlang ham rhum ni,
\q1 Dik lai loh A men a ti ni.
\c 404
\s1 Thin Tlo Jesuh Ka Khueh
\s2 I’d Rather Have Jesus
\sp Doh is Db
\q1 
\v 1 Jesuh khueh ka ngai bet lai sui ngun lakah,
\q1 A khueh a tawn boeih te ol neh ka thui lek pawh,
\q1 Jesuh kan thintlohnah Lai im lo lakah,
\q1 A kut kah boeng ha neh kai te mawt pawn ni.
\q2 \qt Soeprhaep ah a mah hut la khueh ka ngaih,\qt*
\q2 \qt Tholh khui lam ka loh loeih nah \qt*
\q2 \qt Jesuh kan thin tloh nah hno tloe lak ah, \qt*
\q2 \qt Lai omthen boeih lak ah.\qt*
\q1 
\v 2 Hlang kah uem o lakah Jesuh kan lungnah,
\q1 Uep om sit loh nah neh, thin tlohnah ham ka ngaih,
\q1 Thin tlo Jesuh ka khueh lai ming then lak ah,
\q1 Ka thin tloh na koek tah namah ming cim ni.
\q1 
\v 3 Lili pai then lakah Jesuh na then ngai,
\q1 Khoi litui lak a khaw, nang tah na di dip ngai,
\q1 Mueihla buh pong tuihalh na boeih a dip sak,
\q1 Thintlo Jesuh ka khueh a mah loh kai m'mawt.
\c 405
\s1 Hmuenlung Cangkhaeh Long Tah
\s2 Harvest Fields Are Waiting
\sp Doh is Ab
\q1 
\v 1 Hmuenlung cangkhaeh long tah ah ham rhohmin coeng,
\q1 Khang kung Jesuh loh nang te n'coep kho laeh ve,
\q1 coep nah ol aal mueh la cangat rhoek nen te
\q1 thahlue thahmae la rhip ah bi u pawn sih.
\q2 \qt Cang ah hamla n'rhing nang na cet van a ya?\qt*
\q2 \qt kho a laeh hlan ah tho si lamtah bi sih. sih. \qt*
\q1 
\v 2 Hmuenlung cangkhaeh loh n'rhing kho a laeh hlan ah,
\q1 Hlipuei lak ah phung laa then neh bi uh sih,
\q1 Kho nu tham kol hi cil cing toe kol bawn khaw
\q1 dikhaeh cil thui mueh la uepom neh bi sih.
\q1 
\v 3 Hmuenlung cangkhaeh loh n'rhing u a ka cet eh
\q1 taeng laeh hil sih lam hmuen lung cangpa pawn sih.
\q1 patang a di hlanah bawt ngai khoek vetih
\q1 Khang kung Jesuh loh mamih he n'doe pawn ni.
\c 406
\s1 Omngaih Olthang Then Yaak Coeng
\s2 Jesus Saves
\sp Doh is G
\q1 
\v 1 Om ngaih ol thangthen te n'yaak,
\q1 Jesuh loh a khang coeng,
\q1 OL thang loh khawk ah thang coeng,
\q1 Jesuh loh a khang coeng.
\q1 Paeng pum ah olthang thui uh,
\q1 tlang tom neh tuipuei rhal due,
\q1 Boeipa ol paek bangla cawh
\q1 Jesuh loh a khang coeng.
\q1 
\v 2 Tui puei li yawn ah pang puei
\q1 Jesuh loh a khang coeng,
\q1 A yoei a hla hlang taeng thui
\q1 Jesuh loh a khang coeng,
\q1 Tui tun neh tlang sang ah sa,
\q1 Kat ben duela thang sak uh,
\q1 Diklai loh omngaih u saeh
\q1 Jesuh loh a khang coeng.
\q1 
\v 3 Rhaltuknah khui ah pang uh
\q1 Jesuh loh a khang coeng
\q1 A dueknah loh hingnah m'paek
\q1 Jesuh loh a khang coeng,
\q1 Hlem ben duela pang puei uh,
\q1 Lungbuei loh a huem vaengah,
\q1 Hlan khui ah tanah laa sa
\q1 Jesuh loh a khang coeng.
\q1 
\v 4 Thaomnah neh pang uh lah,
\q1 Jesuh loh a khang coeng
\q1 Nam tom loh omngaih u saeh
\q1 Je uh loh a khang coeng,
\q1 A yoe la n'khang he pang puei
\q1 mol dong neh tui ko boeih ah,
\q1 He ma mih kah ta na laa
\q1 Jesuh loh a khang coeng.
\c 407
\s1 A Pa Kah Rhennah Hmai Vang
\s2 Brightly Beams Father's Mercy
\sp Doh is Bb
\q1 
\v 1 A pa kah rhen nah hmai ha vang,
\q1 hmai vang nah im sang lamkah,
\q1 Te dae tui tun kaeng boeih ah te,
\q1 ma mih lon dan ham a khueh.
\q2 \qt Tui tun kaeng kah hmai vang sak lah,\qt*
\q2 \qt tui let tui phu khaw poeng saeh. \qt*
\q2 \qt Tui phu lak li hlang te om ni, \qt*
\q2 \qt nang loh na hlawt thai ngai ni.\qt*
\q1 
\v 2 Tholh kho yin loh ha yoel coeng tih,
\q1 thin sanah tui phu ol hum,
\q1 Mikkhah kolla khing ah ka dan,
\q1 Tui tun tui kaeng tom ah te.
\q1 
\v 3 Na hmai thoi te bet vang sak lah,
\q1 Tuiphu ah a ka om ham
\q1 Tui kaeng te pha hamla a ngaih,
\q1 Yin khui ah hma ta tholh ve.
\c 408
\s1 Vangnah A Loe La Han Tueih
\s2 Send The Gospel Light
\sp Doh is G
\q1 
\v 1 Vang nah a loe la han tueih lah,
\q1 khohla ram hlang rhoek taeng ah,
\q1 Tlan kung boeipa Jesuh ming neh,
\q1 khangnah ol thangthen phong uh.
\q2 \qt Vangnah te a loe la tueih lah,\qt*
\q2 \qt tui varhal ram hla ah khaw, \qt*
\q2 \qt Lungnah lungvatnah ko poek rhai, \qt*
\q2 \qt amih long khaw ming van saeh. \qt*
\q1 
\v 2 Vang nah a loe la han tueih lah,
\q1 yin khui mueihla hma taengah,
\q1 A tue kho hnin a bawt hlan ah,
\q1 thin tawn la phong uh pawn saeh.
\q1 
\v 3 Vang nah ol khueh te han tueih lah,
\q1 A ol cim loh a thui tah,
\q1 Cet lam ol thangthen te thui uh,
\q1 A bawt due kan om puei ni.
\c 409
\s1 Jesuh Kawng Diklai Pum Ah Thui
\s2 Tell The Whole Wide World
\sp Doh is Db
\q1 
\v 1 Jesuh kawng diklai pum ah thui,
\q1 ol thang te kho ta kuem thui.
\q1 Hlangtholh khang kung kawng te thui uh,
\q1 Kho loh voehvoeh thaii van saeh.
\q2 \qt Diklai paeng tom ah thui lah,\qt*
\q2 \qt Kho takuem ah thui uh lah, \qt*
\q2 \qt Diklai pum ah Jesuh kawng thui, \qt*
\q2 \qt A ming he dungyan koeh lah.\qt*
\q1 
\v 2 Olthangthen thui kung te tueih uh,
\q1 vangnah then te khuen lah saeh.
\q1 Kho yin ram ah ka om rhoek neh
\q1 hlip loh a dah rhoek taengah.
\q1 
\v 3 Om ngaih ol thang koep ka tueih ni
\q1 tlang hlaep neh tui puei ben ah,
\q1 Jesuh kah olthang neh a tha
\q1 omnah te peng pum ah thui.
\q1 
\v 4 Ram tloe hlang loh ham bih vaengah
\q1 moei hoeih la bom kung tueih uh,
\q1 Tol rhum kah pilnam khaw hnilh boeh,
\q1 cang khuen tui kong kho rha he.
\c 410
\s1 Omngaih Olthang Yaa Lah
\s2 Whosoever Calleth
\sp Doh is F
\q1 
\v 1 Om ngaih ol thang yaa lah kho hla rham hla duela thang,
\q1 Khangnah ol thangthen te Khrih a duek rhangneh ha pai.
\q1 Pa then ol tah cak tih, a ol khueh te ka phong ni.
\q1 Tangnah neh ka dan tih Boeipa ming te phoei uh lah.
\q2 \qt U khaw a ka khue tah u khaw ka khue tah\qt*
\q2 \qt U khaw a ka khue hlang te tah khang la om ni. \qt*
\q2 \qt U khaw a ka khue tah u khaw a ka khue tah\qt*
\q2 \qt U khaw a ka khue hlang te tah khang la om ni.\qt*
\q1 
\v 2 Yin khui ka om hlang rhoek tholh longpuei a ka vai rhoek,
\q1 Rhen nah hmaivang dan uh, Pa then tuca ke so uh,
\q1 Na thinko lungbuei neh, a olkhueh te tang nah lah
\q1 A ming a ka khue tah u cakhaw po ci mah pawh.
\q1 
\v 3 Khodaeng patang khang tih ko thae ngaihmang hlang rhoek boeih
\q1 Boeipa loh nang te n'rhingnah hno rhih boeih han khuen lah,
\q1 Kut doe then paek a ngaih, hlang tom boeih ham kut doe then,
\q1 A ming aka khue tih a ka tangnah boeih taengah.
\q2 \qt U khaw a ka khue tah u khaw ka khue tah\qt*
\q2 \qt U khaw a ka khue hlang te tah khang la om ni. \qt*
\q2 \qt U khaw a ka khue tah u khaw a ka khue tah\qt*
\q2 \qt U khaw a ka khue hlang te tah khang la om ni.\qt*
\c 411
\s1 Tholh Yin Khuikah Lakueng Pang Ol
\s2 Send The Light
\sp Doh is Ab
\q1 
\v 1 Tholh yin khui kah lakueng pang ol te ka yaak,
\q1 vangnah te han tueih lah,
\q1 Khangnah a ngoe tih hlah ham a ngoe hlang om,
\q1 vangnah te han tueih lah.
\q2 \qt (Ol thangthen vangnah te han hlah lah,\qt*
\q2 \qt paeng tom boeih vang ta aep saeh) \qt*\sup 2\sup*
\q1 
\v 2 Ram thai ben lamkah khuenah ol te ka yaak,
\q1 vang nah te han tueih lah,
\q1 Tholh pa tang khui lam kah a loeih na ham la,
\q1 vang nah te han tueih lah.
\q1 
\v 3 Kol ram pum ah Jesuh lung vat pha pawn saeh,
\q1 vang nah te han tueih lah,
\q1 Noi tlang neh cing doem ah thin tlo kung Jesuh,
\q1 vangnah te han tueih lah.
\q1 
\v 4 Lungnah neh bi bi vaeng la kuengnah khueh boeh,
\q1 vangnah te han tueih lah,
\q1 Vaan sui lu muek dong ka ham lungthen coi sih,
\q1 vangnah te han tueih lah.
\c 412
\s1 Namtom Taengah Thui Ham Yan Cil
\s2 We've A Story To Tell The Nations
\sp Doh is F
\q1 
\v 1 Nam tom taeng ah thui ham yan cil ka khueh,
\q1 thinko then aka pae kung ham,
\q1 Ol tak neh rhen nah yan cil ol,
\q1 Rhalthalnah neh vang nah cil,
\q1 Rhalthalnah neh vang nah cil.
\q2 \qt Khoyin te khothaih la coeng ni,\qt*
\q2 \qt mincang khosae khothun la coeng ni, \qt*
\q2 \qt Khrih kah a ram dilai ah pai ni, \qt*
\q2 \qt Lung nah vang nah ram then te.\qt*
\q1 
\v 2 Nam tom taeng ah sak ham laa then ka khueh,
\q1 Boeipa ming a koeh na thai ham,
\q1 Te laa loh thae nah a ta ni,
\q1 caineh thunglang a koi ni,
\q1 Cai neh thunglang a koi ni.
\q1 
\v 3 Namtom taeng ah thui ham ol thang ka khueh,
\q1 vaan uk kung boeipa kah ol thang,
\q1 Mamih tlang kung capa han tueih,
\q1 Pa then kah lung vatnah ni,
\q1 Pa then kah lung vatnah ni.
\q1 
\v 4 Nam tom ah tueng sak ham khang kung ka khueh,
\q1 Ko thae long puei a ka vai te,
\q1 A mah lam kah diklai pum loh,
\q1 ol tak ming na ham ha lo,
\q1 ol tak ming na ham ha lo.
\c 413
\s1 Aw Nang Zion
\s2 O Zion, Haste
\sp Doh is Bb
\q1 
\v 1 Aw nang Zi on na bi bi loh ha soep coeng,
\q1 Dik lai ah vangnah Kho hni kawng thui lah,
\q1 Ram pum boeih a ka sai kung loh pa khat khaw,
\q1 kho yin khui ah tholh po ci sak a ngaih moe nih.
\q2 \qt Ol thang te thui uh rhoep nah ol thang\qt*
\q2 \qt Khrih kah olthang tlannah ol thang te thui uh.\qt*
\q1 
\v 2 Hlang com hlang cae ol com ol cae taengah thui,
\q1 Pa then lung vatnah halonah kawng te
\q1 A sai hluen rhoek ka khang nah kawng te thui uh,
\q1 Hlang hing lu hlawt nah ham a duek nah kawng te khaw,
\q1 
\v 3 Ol thangthen ham na ca rhoek te pae van lah,
\q1 Na khueh tawn khaw a mih boeih ham hno nah,
\q1 Thang thuinah a so ah khueh pa lamtah,
\q1 Pa then om then ha pai pawn ni na thintawn sak.
\q2 \qt Ol thang te thui uh rhoep nah ol thang\qt*
\q2 \qt Khrih kah olthang tlannah ol thang te thui uh.\qt*
\c 414
\s1 Olthangthen Darkhing
\s2 The Gospel Bell
\sp Doh is F
\q1 
\v 1 Olthangthen darkhing loh cai,
\q1 peng tom boeih tuitun boeih ah,
\q1 Omngaih ol thang khang nah yoe paek,
\q1 nang neh kai hamla m'paek tah,
\q1 Pathen loh diklai he ca pa khueh duen m'paek na he.
\q1 U khaw a ka tangnah hlang tah,
\q1 dung yan hingnah a khueh ni.
\q2 \qt Ol thang dar ha cai coeng,\qt*
\q2 \qt paeng tom tui tunli due la, \qt*
\q2 \qt Olthang dar ha cai coeng \qt*
\q2 \qt nang neh kai ham olthang han khuen. \qt*
\q2 \qt A hla hlang la boeih ah hum, \qt*
\q2 \qt Tholh rhen na soep te han khuen coeng.\qt*
\q1 
\v 2 Olthangthen darkhing loh n'khue,
\q1 hlang boeih ham buhloei a tael,
\q1 A coep nah he thaa na uh boeh,
\q1 a khue na he khaw aal boeh,
\q1 Kai tah hingnah buh ni,
\q1 buh pong hlang rhoek caa uh lah,
\q1 Na tholh nah thim duk ca ca khaw
\q1 vuel song bang la bok pawn ni.
\q1 
\v 3 Ol thang dar khing loh n'thui tuen,
\q1 hnintakuem vuen hlaem ha cai,
\q1 Pocinah loh a mih a rhing
\q1 a ka uelh khak rhoek boeih te,
\q1 Hing nah a loeih nah ham,
\q1 hmuen naem ah sut om mai boeh,
\q1 Hnukthung mang thong tak uh boeh
\q1 patang lam kah loeih na ham la.
\q1 
\v 4 Olthangthen dar omngaihnah ,
\q1 A hla hlang la boeih ah hum,
\q1 Tholh rhen nah soep te han khuen coeng,
\q1 Khangkung boei a duek rhang neh,
\q1 Omngaih olthangthen koek,
\q1 hlang boeih taengah a khuen coeng,
\q1 Nangmih ham khang kung tah thang coeng
\q1 Khrih khangkung manghai boei te.
\c 415
\s1 Cil Thui Hamla Ka Lungnah
\s2 I Love To Tell The Story
\sp Doh is Ab
\q1 
\v 1 Cil thui hamla te ka lung nah, so ben ol huep cil,
\q1 Jesuh kah toe len na neh Jesuh kah lung nah cil.
\q1 Cil thui hamla ka lung nah te cil te thuem ti ka ming,
\q1 A tloe lak ah te long ni, ngai khuek nah a soep sak.
\q2 \qt Cil thui hamla ka lung nah, Ka boei ka len nah la om,\qt*
\q2 \qt Cil rhuem Jesuh cil neh lung nah thui he ka boeilen nah.\qt*
\q1 
\v 2 Cil thui hma la te ka lung nah, Kopoek rhai la om
\q1 Mamih loh m'mang tuk u thil sui khopuei la ah then,
\q1 Cil thui hamla ka lung nah kai ham lam tah bahoeng then.
\q1 Te bueng ka poek nah te ni na taeng ah koep kan thui.
\q1 
\v 3 Cil thui hamla te ka lung nah, koep koep thui ham then,
\q1 A then nah thui thai lek pawh, A kai khaw didip.
\q1 Cil thui hamla ka lung nah hlang loh a yak noek mueh cil.
\q1 Pathen ol dong lam ka loh khang nah then ka lo te.
\q1 
\v 4 Cil thui hamla te ka lung nah, a then a ming tih,
\q1 Buhpong tui halh rhoek boeih loh, ham buh pong a dip nah,
\q1 A toe len botui n'yak vaeng laa thai ka sak ham te tah
\q1 Ci rhuem ka thui ham te ni ka ngai dam kol la om.
\c 416
\s1 Cangti Then Tuh Uh
\s2 Sowing The Precious Seed
\sp Doh is Bb
\q1 
\v 1 Cangti then te tuh uh, min cang kho po ai khong lamkah,
\q1 Cangti then te tuh uh kho thun due lam khaw,
\q1 Cangti then te tuh uh hlangnoe na tha a om vaengah,
\q1 cang ti then tuh uh lah ko do thin sen neh.
\q2 \qt Cang ti then tuh u lah \qt*
\q2 \qt lung nah neh a yoei a hla a kael a cong ah. \qt*
\q2 \qt hing nah vaidam paek hamla ol thangthen thui pa uh lah. \qt*
\q2 \qt Cang ti then tuh uh lah Boeipa hmuen lung ah.\qt*
\q1 
\v 2 Cangti then te tuh uh, min canghi ah thoo uh lamtah
\q1 Cangti then te tuh uh hlaem kholaeh duela,
\q1 Cangti then te tuh uh uepvawtnah thin ko khueh mueh la,
\q1 Boeipa taeng ah hal uh amah taeng boeih pae.
\q1 
\v 3 Cangti then te tuh uh, omngaih tha hlue tha ko ca la,
\q1 Cangti then te tuh uh sui cangvuei then te,
\q1 Cangti then te tuh uh ban vaeh hlaengtang uh boeih lamtah,
\q1 Boeipa taeng thang thui uh rho tui tlan nah ham
\c 417
\s1 Ram Hlahlang Ah
\s2 Go Ye Into All The World
\sp Doh is A
\q1 
\v 1 Ram hla hlang ah tholh yin ah hlang muep om pueng,
\q1 A thong a sang mueihla loh hma pawn ni.
\q1 U ka cet eh khangnah ol thangthen thui ham,
\q1 Jesuh loh a phu a sah ke poek lah.
\q2 \qt Sai thainah boeih boeih te m'paek coeng.\qt*
\q2 \qt Saithainah boeih te boeih m'paek coeng. \qt*
\q2 \qt Dik lai pum ah cet uh lam ol thangthen thui, \qt*
\q2 \qt nangmih taeng ka om yoeyah ni ti.\qt*
\q1 
\v 2 Paeng tom boeih ah thoh a ong tih a coep li,
\q1 Khrih rhalkap rhoek tho uh lah kun boeih uh,
\q1 Khrih ca tho uh thikat la tha huel uh lah,
\q1 Tholh pin nah hlam hamla olthang theu thui.
\q1 
\v 3 Bang ah na duek Pa then ol loh nang n'khue li,
\q1 Bang ah na duek A ming cim te uep nah,
\q1 ma mih hingnah ham Jesuh a duek ming uh,
\q1 Khangnah neh hingnah ol thang pang puei uh.
\q1 
\v 4 Pathen kah hnin long tah voeh voeh ha yoei coeng,
\q1 Ta nah uem na neh Pathen te koeh uh.
\q1 Tlan tae la aka om rhoek loh uemnah neh,
\q1 Haleluijah Boeipa tila pang uh.
\c 418
\s1 Aka Then Koek Tlang Dong Lamkah
\s2 When The Mist Have Rolled Way
\sp Doh is D (moderate)
\q1 
\v 1 Aka then koek tlang dong lam kah muei loh baat ah hai vetih,
\q1 Tui va dongah omngaihnah kho loh ha sae koep vaeng atah,
\q1 A pa kah ol khueh tam pa cung te koep ah m'poek uh pawn ni,
\q1 Khat neh khat a caih ca la boeih ah m'ming uh thae bal pawn ni.
\q2 \qt Khat neh khat boei m'ming uh ni,\qt*
\q2 \qt Omdam nah om voel mah pawh, \qt*
\q2 \qt min cang kho ha thai tih omngaih \qt*
\q2 \qt khohnin the a sae vaeng ah, \qt*
\q2 \qt A caih la boeih m'ming uh thae ni, \qt*
\q2 \qt Muei loh boeih a haai vaeng ah. \qt*
\q1 
\v 2 Mamih hmai kah caehlong te tah rhai tih lung buei khaw hno rhih,
\q1 Yinnah khui ah pa tang pa lai neh lo hmuen loh hla cakhaw,
\q1 Pa tang hlang rhoek na yoe then uh Boeipa loh koep n'thung bit ni,
\q1 Min cang tun nah a tue vaengah tah muei loh hai bal pawn ni.
\q1 
\v 3 Om ngaih cang tloeng la a ngol khoel ah ma mih n'un uh vaeng ah,
\q1 Thin tlo rhoek neh mik hmai hum tun la khat neh khat mingpha ni,
\q1 Ma mih khang nah laa n'sak na ol long te khaw bawt pat mah pawh,
\q1 Yinnah loh boeih khum coeng tih muei long khaw a haai vaeng atah.
\c 419
\s1 Tuiva Kaengah Ka Pai Tih
\s2 Beyond The Smiling And The Weeping
\sp Doh is Ab
\q1 
\v 1 Tui va kaeng ah ka pai tih khat ben rhal ka ka dan vaengah,
\q1 Tui va rhal ah timbaw khat khat a duem muei te ka hmuh
\q1 Amah te doe hamla van ping a yet loh a vael tih duem uh
\q1 phih nah loh om tlaih voelpawh vaandong om then tueng sak
\q2 \qt Im then ben ka cet Zion tim baw dawng ka ngol,\qt*
\q2 \qt Tui val rhal khat ben vang khui ah a vang pa khat ka hmuh\qt*
\q2 \qt tim baw teng ka pha tih pa ya neh ka hmuh uh vaeng ah\qt*
\q2 \qt vaan hlang rhoek loh kai te n'doe pawn ni.\qt*
\q1 
\v 2 A nu loh yilhding a poeng tih rhalvang mol khum ca khaw,
\q1 Te hmuen long kai n'doe ni khang kung boei na khueh n'ti nah,
\q1 Tahae tah ka cueih la om kai khaw te hmuen ni te ka dang coeng
\q1 A nu loh rhingda tih lamtawn tuival rhal lamkah.
\c 420
\s1 Ka Hing Khui Tui La Ka Hal
\s2 The Happy Growing Day
\sp Doh is G
\q1 
\v 1 Ka hingnah khui ah tui la ka hal ca,
\q1 thinko rhaem sak kung boei a tloe om
\q1 pawh tuiding ok sak hamla nang loh nan khue yoeyah,
\q1 Na lung vat nah len koek neh kai nan khue
\q1 rhamsa bang hnuk hmai lah nan hloem yoeyah tih,
\q1 mikphi na huih doe la nan tlap khuep oeh,
\q2 \qt Nang nen ah thik at la pongpa yoeyah van ham la,\qt*
\q2 \qt dung yan neh dung yan due la om hmaih ka rhing da\qt*
\q2 \qt omngaihnah mik phi tui rhotui kho bang \qt*
\q2 \qt nal ve tih ko thae nah mik phi loh rhaem ni \qt*
\q2 \qt na rhing da aw te ram then ah om ham.\qt*
\q1 
\v 2 Kai he tueilaeh kap tang kik bal cakhaw,
\q1 nan lungnah rhui nan pat sak van muehla,
\q1 Hnaih ham koi ka taeng ah ba om mai pawt cakhaw,
\q1 Ka tholh phu dueknah laibai te na sah,
\q1 dueknah dong rhui te nan haih but coeng dongah,
\q1 Ka ying ka rhaelnah ka boeipa Pa then.
\q1 
\v 3 Rhohum thihcung neh diklai hno pai tah,
\q1 Bumbo neh aek lo a cak ti hmawn ni,
\q1 A tue a bawt a tah hmai kui la tlum boeih ni,
\q1 Rhap voel boeh rhap voel boeh aw ka ca aw,
\q1 Ngaimongnah Jesuh te mah khueh phawt van lah,
\q1 Kum thawng sang na mueihla omngaihnah am.
\c 421
\s1 Vaan Im Sang Khui Ah
\s2 They Sing A New Song
\sp Doh is C
\q1 
\v 1 Vaan im sang khui ah tlan tae ca laa a sak,
\q1 manghai boei hmai ah sui lumuek a tloeng uh,
\q1 Dik lai tholh ko thae boei te a hnilh uh coeng,
\q1 hlangcim rhoek loh thangthennah laa thai a sak.
\q2 \qt Tu ca ming koeh uh Kalvari tlang dong ka duek te,\qt*
\q2 \qt Tu ca ming koeh uh, dueknah a ta tih tho koep coeng \qt*
\q1 
\v 2 Ko poek rhai lung vat nah te tah ha soep coeng.
\q1 Sui boeng loeng neh bo tui long tah ha bae coeng,
\q1 Hlang tholh yuengla khang kung boei a duek dongah,
\q1 Pa then taengah kho soih puei la n'om uh coeng.
\q1 
\v 3 Tihnin a thi neh a ka sil uh pawt tah,
\q1 A hmui ka loh thangthen laa sai thai mah pawh,
\q1 Aw khangkung kai mih tholh nah boeih han sil lah,
\q1 Tlan ca rhoek neh laa then ka sa uh la eh,
\c 422
\s1 Manghai Boei Hmai Pai Uh
\s2 We Shall Stand Before The King
\sp Doh is Ab
\q1 
\v 1 Mang hai boei hmai m'pai uh ni,
\q1 Vaan hlang rhoek neh laa n'sak ni,
\q1 vuen vai ah vuen vai ah,
\q1 Tui kaeng om then la cet sih
\q1 amah te koeh yoeyah sih
\q1 vuen vai ah vuen vai ah,
\q2 \qt Mang hai boei hmai m'pai uh ni,\qt*
\q2 \qt Vaan hlang rhoek neh laa n'sak ni\qt*
\q2 \qt thangthen sak uh manghai boei\qt*
\q2 \qt Ha le lui jah ha le lui jah \qt*
\q2 \qt manghai boei hmai m'pai uh ni.\qt*
\q1 
\v 2 Vaan dong dar khing tum uh lah,
\q1 manghai boei hmai m'pai uh ni,
\q1 vuen vai ah vuen vai ah,
\q1 Ma mih ko thae bawt pawn ni,
\q1 a ming n'thang pom uh pawn ni,
\q1 vuen vai ah vuen vai ah
\q1 
\v 3 Ka mueihla nang hinghang laeh,
\q1 manghai boei hmai m'pai uh ni,
\q1 vuen vai ah vuen vai ah,
\q1 Na likmal Pathen pae lah,
\q1 amah muei loh soepnah ham,
\q1 vuen vai ah vuen vai ah.
\c 423
\s1 Ka Thoo Vetih A Pa Taengah
\s2 I Will Go To My Father
\sp Doh is G
\q1 
\v 1 Ka thoo ve tih a pa taengah ka cet bal ni,
\q1 Ka hmai ah muei bang loh ha yal
\q1 Thin tlo kung a tloe ka khueh pawh diklai ah he
\q1 a pa mueh tah ka rhal boeih ni.
\q2 \qt Tholh neh ka hma ta cakhaw a then na loh bawt pawh,\qt*
\q2 \qt Yut doe koep ka tlap a tah a ko koep ka tong ni. \qt*
\q1 
\v 2 A pa im ah tah koe va soep rhaep om dae ni,
\q1 Ko thae ca rhoek te a hloep nah,
\q1 Kai tloe tah buh pong pa tang neh ka duek tom coeng
\q1 ba dongah khodaeng la ka om.
\q1 
\v 3 Aw a taeng ah ka om vaengah om then hlang mai
\q1 Diklai om then ka tlap boeih khaw
\q1 Ka poek vaeng ah a pa im khui ka ngai tangkik
\q1 tholhnah phong dawk ham ni ka om
\q1 
\v 4 Kai hlang tholh kothae sak kung neh yahpoh sak kung
\q1 Kai ham hmuen nan paek mak a tah,
\q1 He dilai rhaipai ka rhal he ka ngaih mah pawh
\q1 a pai lum na loh tloih tom coeng.
\c 424
\s1 So Ben Ram Kah Im Ke Poek Lah
\s2 The Home Over There
\sp Doh is A
\q1 
\v 1 So ben ram kah im ke poek lah,
\q1 Vangnah tui va kaeng kah ka om ke,
\q1 Te kah hlang cim rhoek neh hlang boeih loh,
\q1 him bai bok neh boeih ah thoeih cam uh.
\q2 \qt Te hmuen ah te hmuen ah,\qt*
\q2 \qt so ben kah im ke poek uh lah. \qt*
\q2 \qt te hmuen ah te hmuen ah\qt*
\q2 \qt so ben im poek lah\qt*
\q2 \qt so ben im ke poek lah.\qt*
\q1 v2 Te kah pa ya rhoek te poek lah,
\q1 Ma mih lakah a lam hma rhoek te,
\q1 Vaan ah laa then ol loh han hoih te,
\q1 Pathen lum im ah im a khueh uh.
\q1 
\v 3 Teah ka khangkung ta hae om,
\q1 Ka koei ka na ka hui ko boeih khaw,
\q1 Ko thae ngai hmang lamkah loeih uh coeng,
\q1 Khang kung omnah hmuen ah caeh ka ngaih.
\q1 
\v 4 A di hlan ah ka pha van ni,
\q1 Ka yin caeh long puei a bawt vaengah,
\q1 Thin tlo rhoek loh om uh tih n'rhing oel.
\q1 A di hlan ah ka pha van pawn ni.
\c 425
\s1 Khohla Omthen Ram Ah
\s2 I Long To Be There
\sp Doh is Eb
\q1 
\v 1 Kho hla om then ram ah om ka ngaih,
\q1 a om then nah uh loh thui lek pawh,
\q1 Kho lak ah a ka sae ngai ram ah
\q1 Jesuh neh dung yan om hmaih ka ngaih.
\q2 \qt Ke ram ah ke ram ah\qt*
\q2 \qt Boei Jesuh neh yoeyah om ka ngaih\qt*
\q2 \qt Ke ram ah ke ram ah \qt*
\q2 \qt Boei Jesuh neh yoeyah om ka ngaih. \qt*
\q1 
\v 2 Bai bal khui kah ol ka yaak vaeng ah,
\q1 Ka hing ngai mong yoe then na la om,
\q1 Thahnoeng buhpawng tui halh na boeih te
\q1 Ke ram ka pha vaengah bawt pawn ni.
\q1 
\v 3 Kho paeh ham yoe kho li om then ah,
\q1 Dueknah ngai hmang nah om voel tlaih pawh,
\q1 Rhahnah neh mik phi bo nah om pawh,
\q1 Dueknah om voel tlaih pawh ke ram ah.
\q1 
\v 4 Ke ram om then ah om na thai ham,
\q1 Hlang tholh rhoek khaw Pathen loh a cael,
\q1 Olkhueh bangla a ka tang nah tah,
\q1 Ke ram ah dung yan la om pawn ni.
\c 426
\s1 MinCang Khothaih Mamih Tun
\s2 Gathered Home
\sp Doh is Bb
\q1 
\v 1 Min cang kho thaih ma mih ntun uh vaeng ah,
\q1 Ke tui va kaengah vang hmuen then ah?
\q1 n'lung na tih a ka rhing hlang rhoek nen te,
\q1 im ah me tlam lae tun uh eh?
\q2 \qt Im then ha tun boeih uh,\qt*
\q2 \qt Tui kaeng then a vang nah hmuen then ah,\qt*
\q2 \qt Im then la tun boeih uh \qt*
\q2 \qt thintlo neh dungyan om hmaih hamla \qt*
\q1 
\v 2 Mincang khothaih mamih n'tun uh vaeng ah,
\q1 kothae he boei hma van poek ve nim,
\q1 Tlan na laa te n'sak uh van poek ve nim,
\q1 im ah me tlam lae tun uh eh?
\q1 
\v 3 Mincang khothaih ma mih n'tun uh vaeng ah,
\q1 Tlankung boei a muei m'hmuh uh ve nim?
\q1 Thin tlo koei na neh m'ming uh thae ve nim,
\q1 im ah me tlam lae tun uh eh?
\c 427
\s1 Khoyin Om Voel Mahpawh
\s2 There'll Be No Dark Valley
\sp Doh is F
\q1 
\v 1 Kho yin om voel mahpawh ha rhum vaeng ah,
\q1 Khoyin om voel mah pawh ha rhum vaeng ah,
\q1 khoyin om voel mah pawh ha rhum vaeng ah,
\q1 A lung nah hlang rhoek coi ham.
\q2 \qt A lungnah hlang rhoek coi ham\qt*
\q2 \qt a lung nah hlang rhoek coi ham\qt*
\q2 \qt Khoyin om voel mah pawh ha rhum vaengah\qt*
\q2 \qt a lungnah hlang rhoek coi ham.\qt*
\q1 
\v 2 Ko thae om voel mah pawh ha rhum vaeng ah,
\q1 Ko thae om voel mah pawh ha rhum vaeng ah,
\q1 A boeilen ha sae ni ha rhum vaeng ah,
\q2 \qt A lungnah hlang rhoek coi ham\qt*
\q2 \qt a lung nah hlang rhoek coi ham\qt*
\q2 \qt Khoyin om voel mah pawh ha rhum vaengah\qt*
\q2 \qt a lungnah hlang rhoek coi ham.\qt*
\q1 
\v 3 Rhahnah om voel mah pawh ha rhum vaeng ah,
\q1 rhahnah om voel mah pawh ha rhum vaeng ah,
\q1 cangvuei a coi pawn ni ha rhum vaeng ah
\q2 \qt A lungnah hlang rhoek coi ham\qt*
\q2 \qt a lung nah hlang rhoek coi ham\qt*
\q2 \qt Khoyin om voel mah pawh ha rhum vaengah\qt*
\q2 \qt a lungnah hlang rhoek coi ham.\qt*
\q1 
\v 4 Uemnah laa n'sak pawn ni ha rhum vaeng ah,
\q1 Uemnah laa n'sak pawn ni ha rhum vaeng ah,
\q1 omngaih la n'tun pawn ni ha rhum vaeng ah
\q2 \qt A lungnah hlang rhoek coi ham\qt*
\q2 \qt a lung nah hlang rhoek coi ham\qt*
\q2 \qt Khoyin om voel mah pawh ha rhum vaengah\qt*
\q2 \qt a lungnah hlang rhoek coi ham.\qt*
\c 428
\s1 Kho Lakah Ka Sae Ngai Khohmuen Om
\s2 Sweet By And By
\sp Doh is G
\q1 
\v 1 Kho lak ah ka sae ngai kho hmuen om,
\q1 tangnah neh vuen vai ah m'hmuh uh ni,
\q1 Long puei ah a pa loh ma mih n'rhing
\q1 ma mih omnah hmuen rhueng phong ham la.
\q2 \qt Vuen vai ah kho then ah\qt*
\q2 \qt Tuiva kaeng ah mamih n'hmu uh ni, \qt*
\q2 \qt vuen vai ah kho then ah\qt*
\q2 \qt tuiva kaeng ah ma mih n'hum uh ni.\qt*
\q1 
\v 2 Ke tui va langdai ah laa n'sak ni,
\q1 Ma mih ham tekah laa then koek te,
\q1 Muei hla ko thae nah om voel mah pawh,
\q1 Tloh tat tawn ba khaw om tlaih mah pawh.
\q1 
\v 3 Vaan dong kho kah lungnah pa Pa then
\q1 Om ngaihnah thin ko na mah kan paek,
\q1 A lung nah kut doe then m'paek long he,
\q1 Ka kum kho hnin yoe then nah ham paek.
\c 429
\s1 Bi Tloh Neh Patangnah Loh
\s2 Glory For Me
\sp Doh is Ab
\q1 
\v 1 Bi tloh neh pa tang nah loh bawt coeng tih,
\q1 tui kaeng ah a mong la ka duem vaeng ah,
\q1 Ka lungnah ka boeipa ka bawk na te
\q1 dung yan ka thang pom nah la om pawn ni.
\q2 \qt Aw kai hamla thang pom nah ni thangpom nah ni\qt*
\q2 \qt A lung vatnah rhangneh a mik hmai then ka dan na te\qt*
\q2 \qt kai ham thang pomnah thang pom nah la om. \qt*
\q1 
\v 2 Lung vat bawt pat mueh kut doe ka dang tih,
\q1 Vaan im ah kai ka om van vaengah tah,
\q1 Te hmuen ah a mikhmai then ka hmuh te
\q1 dungyan ka thang pom nah la om pawn ni.
\q1 
\v 3 Hnuk vaeng kah paya thintlo rhoek nen te
\q1 Tui bang la li lup ka ka long hmaih tih
\q1 Khang kung kah omngaih muei then ka hmuh te
\q1 dungyan ka thang pom nah la om pawn ni.
\c 430
\s1 Longhla Hlang Kah Patangnah
\s2 Dwelling Beaulah Land
\sp Doh is Ab
\q1 
\v 1 Long hla hlang kah patangnah ol te ka hna ah ka yak
\q1 Dik lai tholh loh hlang boeih a tul a noi ti ka ming,
\q1 La kueng rhih om ngai hmang na neh diklai koeva long he,
\q1 Beu lah ram lam ka loh kai n'khoe thai pawh.
\q2 \qt Muei loh cing kho a cil nah tlang som van li ah ka om\qt*
\q2 \qt Tui ding cim tui phuet tui te ka ok,\qt*
\q2 \qt phakpuei buh a rha te ka hah tih lum nai ka cet poel tih\qt*
\q2 \qt lum poe loh yawt yawt ha thoeng pawn ni te Beu lah ram ah.\qt*
\q1 
\v 2 Dik lai hman ah uep vawt nah hli puei long tah ha tho li,
\q1 Hlang hing loh a cak la pai tih rhal te tuk ham om.
\q1 Te dae Kho hni ol dong ah ka pai la a om dong ah
\q1 Beulah ram te ka phat thai van pawn ni.
\q1 
\v 3 Hli puei loh ha hli mai ca khaw ka let thai voel mah pawh,
\q1 Pathen kut dongah ta hae ngai mong la ka om coeng,
\q1 He hmuen a tah khaw phueih ah sae tih mawn na om tlaih pawh
\q1 Beu lah ram tah a mong la phueih ka om.
\q1 
\v 4 Pathen bi bi te ka dan vaeng ah kai muelh ka poek uh,
\q1 A cang ding ol ka yaak vaengah ka long puei koep khui,
\q1 Kai tlannah ham Muei hla loh kho ham poek ka ming vaeng ah
\q1 Beu lah ram ah tha hlue la ka om ni.
\c 431
\s1 He Lai Ka Im Moenih
\s2 This World is Not My Home
\sp Doh is Bb
\q1 
\v 1 He lai ka im moe nih ka caeh tak ham koi ni,
\q1 lai ah yin la ka om ka im vaan ah ka khueh,
\q1 Vaan hlang loh vaan thohka a ong tih kai te n'khue
\q1 He diklai dong ah he om ka ngaih soe tlaih pawh.
\q2 \qt Boeipa nang bang la paya then om pawh,\qt*
\q2 \qt Vaan ka im pawt koi nih, boeipa bang ka ti eh, \qt*
\q2 \qt vaan hlang loh vaanthohka a ong tih kai te n'khue \qt*
\q2 \qt he diklai dongah he om ka ngaih soe tlaih pawh. \qt*
\q1 
\v 2 Amih rhoek loh kai he n'lam tawn uh te ka ming,
\q1 Jesuh neh thik at la ka om hmaih coeng dongah,
\q1 Kai hlang tholh kho daeng koek he, amah loh n'lung nah
\q1 He diklai dong a he om ka ngaih soe tlaih pawh.
\q1 
\v 3 Thin tlo a nu pa khaw boeilen nah ram ah om,
\q1 A kut ka tuk hlan due ka ngai uep nah bawt pawh,
\q1 Nu pa loh vaan thoh ka a ong tih kai n'lam tawn.
\q1 He diklai dong a he om ka ngaih soe tlaih pawh.
\q1 
\v 4 Te kah ram then dong ah dung yan ma mih n'om ni,
\q1 Hlang cim neh thik at la ta nah laa n'sak uh ni,
\q1 Amih kah laa ding ol te ka yaak koep vaeng ah.
\q1 He diklai dong ah he om ka ngaih soe tlaih pawh.
\c 432
\s1 Jesuh Thii Ah Bai Bok Bai Tih
\s2 Beyond The Swelling Flood
\sp Doh is G
\q1 
\v 1 Jesuh thi ah bai bok bai tih,
\q1 Tui va rhal ah tun nah om ni,
\q1 Tloh tat pa tang lam kah n'loeih ni,
\q1 phih rha nah om voel tlaih mah pawh.
\q1 Dueknah tui va rhal ah.
\q2 \qt Duek nah tuiva rhal ah duek nah tuiva rhal ah\qt*
\q2 \qt Duek nah tui va rhal ah phihrha na om mah pawh, \qt*
\q2 \qt phih rha nah om mah pawh phih rha na om mah pawh\qt*
\q2 \qt phih rha na om mah pawh duek nah tuiva rhal ah. \qt*
\q1 
\v 2 Tlohtat nah khaw ka rhih voel pawh,
\q1 tangnah neh ka vaan im ka hmuh,
\q1 Vaan caeltueih rhoek laa sak ol tah,
\q1 Pa then loh mik phi tui a huih,
\q1 Dueknah tuiva rhal ah.
\q1 
\v 3 Thin tlo pa ya ka hmuh vaengah,
\q1 me bang laa then nim ka yaak ve,
\q1 Coi nah tue loh a pha vaengah,
\q1 ka mueihla khaw hing hang pawn ni,
\q1 Dueknah tuiva rhal ah.
\q1 
\v 4 Ka khang kung ka kho han hoi haeng,
\q1 ka om ngaihnah a soep na ham,
\q1 A bawt due na ming koehnah loh
\q1 ka mik phi tui boeih a rhaem sak
\q1 Duek nah tui va rhal ah.
\c 433
\s1 Jordan Tuiva Kaengah Ka Pai
\s2 On Jordan's Stormy Banks
\sp Doh is G
\q1 
\v 1 Jordan tui va kaeng ah ka pai,
\q1 omdam mik neh ka dan,
\q1 Ka nan ram om then tueng ka hmuh
\q1 Ka pang hamla ram ni.
\q2 \qt Ke om then ram ah mamih n'duem pawn ni,\qt*
\q2 \qt Dung yan hing suep tuikaeng m'pha vaeng ah\qt*
\q2 \qt vuen vai ah Moses neh \qt*
\q2 \qt Tu ca noe n'thangthen uh ve tih, \qt*
\q2 \qt Jesuh neh n'om pawn ni.\qt*
\q1 
\v 2 Ke kah hmuen ka vannaep ah ke,
\q1 dungyan khohnin then sae,
\q1 Pathen ca pa long a poeng tih,
\q1 kho yin long he hma coeng.
\q1 
\v 3 Ke omngaihnah ram ka pha vaeng,
\q1 dungyan ka yoethen ni,
\q1 A pa mikhmai then ka hmuh vaeng
\q1 a rhang dong ka duem ni.
\q1 
\v 4 Coi nah tue pha vaeng ah omngaih,
\q1 diklai loh khum pawn ni.
\q1 Jor dan tuiphu loh m'vael ca khaw,
\q1 a mong la ka kat ni.
\c 434
\s1 Mamih Hmaikah Kutdoe Loh
\s2 Triumph By And By
\sp Doh is G
\q1 
\v 1 Ma mih hmai kah kutdoe loh ham boeipa loh n'khue uh,
\q1 Boeipa loh a mik neh n'dawn a so lam kah.
\q1 A lung nah ol neh n'khue li,
\q1 Tholh loh hmuep ti thim duk vaeng ah,
\q1 So ben kah a om Boei Jesuh loh n'khue li.
\q2 \qt Vuen vai ah a mah n'tong ni, \qt*
\q2 \qt vuen vai ah a mah n'tong ni,\qt*
\q2 \qt Vuen vai ah Jesuh boeilen na m'pang pawn ni. \qt*
\q2 \qt Vuen vai ah a mah n'tong ni, \qt*
\q2 \qt Vuen vai ah a mah n'tong ni, \qt*
\q2 \qt Vuen vai ah Jesuh boeilen nah m'pang pawn ni. \qt*
\q1 
\v 2 Amah kah mawtnah rhamtlim sai noe ah cet uh sih,
\q1 So ben lamkah ka khue kung kho taeng om lah,
\q1 Ngai uep nah cak sak uh sih,
\q1 tangnah dong ah paek rha boel sih
\q1 Tangnah khaw taaep a cak sak bal pawn ni.
\q1 
\v 3 Yinnah loh a ta thai mueh im tah vaan ah om tih
\q1 Lung vat kung Jesuh khaw vaan dong kho ah om.
\q1 A mah bi te bi uh sih, A ming te thangthen sak uh sih,
\q1 A ol khue bang la mevaeng ah dalh mah pawh.
\c 435
\s1 Jesuh Lungnah Kopoek Rhai
\s2 When We All Get To Heaven
\sp Doh is C
\q1 
\v 1 Jesuh lung nah kopoekrhai he
\q1 omngaih neh koeh uh lah sih.
\q1 Hmai vang om then vaan dong kho ke,
\q1 ma mih omnah ham a saii.
\q2 \qt Vaandong lah m'voei uh vaeng ah,\qt*
\q2 \qt me tluk la omthen omyal na n'khueh eh, \qt*
\q2 \qt Jesuh te hmuh vaeng ah\qt*
\q2 \qt tanah laa a ngaih la n'sak ni.\qt*
\q1 
\v 2 Vaan dong long puei caeh li vaengah
\q1 muei loh khop ha yaal ca khaw,
\q1 Te dae yin caeh a bawt vaeng ah,
\q1 a hmuep long khaw hma pawn ni.
\q1 
\v 3 Vuen hlaem amah kah bi bi he
\q1 uepom ca la bi uh sih,
\q1 Kho daeng pa tang na boeih boeih he,
\q1 Boeilennah la om pawn ni.
\q1 
\v 4 Hmai ben kah kut doe then pan tih,
\q1 Thennah a yet hmuh uh pawn ni,
\q1 Lai tha thoh ka a ong vetih,
\q1 Sui long puei ah m'pong pa ni.
\c 436
\s1 Vaan dongah Caehnah Longpuei Tah
\s2 The Happy Home
\sp Doh is G
\q1 
\v 1 Vaan dong ah caehnah ham long puei tah,
\q1 Jesuh loh long puei a saelh boeih coeng,
\q1 Rhal boeih boeih te tah a noeng coeng tih,
\q1 He ben ha boeih ha lo mia ma na.
\q2 \qt Ram then ah om hamla om hamla om ham la\qt*
\q2 \qt he ben la lo boeih uh miamana, \qt*
\q2 \qt he ben la lo boeih uh mia mana.\qt*
\q1 
\v 2 A rhennah long puei ta hae tlap lah,
\q1 Vuen vai tah khoyin loh n'kae pawn ni.
\q1 Tang ca rhoek long tah vaan a pha ni,
\q1 Na tangnah tah nang ham vaan ram om.
\q1 
\v 3 Boei Jesuh loh a rhennah neh n'khue,
\q1 A ka tangnah pawt rhoek tangnah laeh,
\q1 A boei a len nah te m'pang uh ni,
\q1 Pa then lungnah khui ah kun uh sih.
\c 437
\s1 Ram Hla Kah Olthangthen
\s2 Where We'll Never Grow Old
\sp Doh is Ab
\q1 
\v 1 Ram hla kah ol thangthen
\q1 koek te tah ka yaak coeng,
\q1 Muei hla ham om nah im then om coeng,
\q1 Jesuh loh im han sak
\q1 dueknah om tlaih voel pawh,
\q1 Te ram ah m'pa tong uh tlaih mah pawh.
\q2 \qt Patong om pawh, tloh tat om pawh\qt*
\q2 \qt Te kah ram a tah patong om pawh, \qt*
\q2 \qt Patong om pawh, tloh tat om pawh\qt*
\q2 \qt Te kah ram a tah patong om pawh, \qt*
\q1 
\v 2 Te kah im then khui ah
\q1 ko pangnah om voel pawh,
\q1 Vuen vai ah ma mih loh m'pha van ni.
\q1 Om ngaih la manghai boei
\q1 koeh nah laa n'sak pawn ni,
\q1 Te ram a dueknah om tlaih mah pawh.
\q1 
\v 3 Bi bi a bawt vaeng ah
\q1 hingnah lu muek n'dang ni,
\q1 Ngai hmang pa tang na boeih khum pawn ni.
\q1 Ko thaenah bawt ve tih,
\q1 rhung rhan om voel mah pawh,
\q1 Cet tangtae rhoek neh n'tun uh pawn ni.
\c 438
\s1 Kho Aka Sae Ram Pakhat Om
\s2 The Bright For Evermore
\sp Doh is Bb
\q1 
\v 1 Kho la aka sae ram pa khat te om,
\q1 vaan dong lakah sae ngai,
\q1 Kho yin khawn phai hlaem hmah om tlaih pawh,
\q1 Khang kung vang nah la om coeng.
\q2 \qt Thing lam tai te n'koh a tah,\qt*
\q2 \qt suilumuek te m'muek ni. \qt*
\q2 \qt Vaandong kho m'pha vaengah tah\qt*
\q2 \qt dungyan m'vang uh van pawn ni.\qt*
\q1 
\v 2 Vaan ram ah rhal thal ommong nah te om,
\q1 dueknah tui va rhal ah.
\q1 Te hmuen ah hli puei long khaw duem tih,
\q1 Te hmuen ah kawn tung uh sih.
\q1 
\v 3 Te ah im then om lum im then koek ni,
\q1 te kah vaan im then ke.
\q1 m'hmuh voel mueh thin tlo koeina rhoek loh
\q1 te hmuen ah mamih n'doe ni.
\q1 
\v 4 He pa tang rhihom na he a loe la,
\q1 poeng hamla ka rhing da.
\q1 Vaan hlang ping neh om hmaih ka ngaih coeng,
\q1 te ah dueknah om voel pawh.
\c 439
\s1 Ka Lungnah Ip Lam A Then La Duem Laeh
\s2 The Christian's “Good Night”
\sp Doh is Ab
\q1 
\v 1 Ka lungnah ip lam a then la duem laeh.
\q1 Na khangkung rhang dongah na lu tloeng lah.
\q1 Kai mih lakah Jesuh loh n'lungnah ngai.
\q1 mang tong mangtong mangtong.
\q1 
\v 2 Ca moe bangla a then ca la ip ne
\q1 Ko thaenah loh nang n'haeng tlaih voel mahpawh,
\q1 Duemnah soep dingsuek hmuen te na pha coeng.
\q1 mangtong mangtong mangtong.
\q1 
\v 3 Dik lai yinna long a hma hlan duela
\q1 A tue bawt na cang vuei a coi hlan due,
\q1 Kho ling tloh nah loh a bawt hlan duela
\q1 mang tong mangtong mangtong.
\q1 
\v 4 Pathen lungnah loh n'then sak hlan duela,
\q1 Pathen muei loh kho la ha sae ve tih,
\q1 Nang hamla sui lumuek te han khuen ni
\q1 mang tong mangtong mangtong.
\q1 
\v 5 A ngol khoel hmaiah kun tun uh due la,
\q1 Amah kah m'paek him bai te m'bai uh ni.
\q1 A mah loh m'ming bangla m'ming uh hlan due
\q1 mang tong mangtong mangtong.
\c 440
\s1 Dueknah Tuiva Rhalvang ah Khopuei Then
\s2 The City Of Gold
\sp Doh is Ab
\q1 
\v 1 Dueknah tui va rhal vang kah kho puei dan uh lah,
\q1 a om then na n'thui lek thai mahpawh.
\q1 Khomik loh tla tlaih pawh thing hnah khaw yaai tlaih pawh,
\q1 te kah sui kho puei om then dong ah.
\q2 \qt Kho a tlak na noek pawh, thing hnah loh yaai tlaih pawh.\qt*
\q2 \qt Uep om hlang rhoek long tah boeipa muei a hmuh ni,\qt*
\q2 \qt te kah sui kho puei om then dong ah. \qt*
\q1 
\v 2 Te a tah lung vat kung tlankung m'boeipa te om,
\q1 uepom hlang rhoek tah a coi pawn ni,
\q1 Hlang dueng rhoek tah ai si bang la yoe yah vaang ni,
\q1 te kah sui kho puei om then dong ah.
\q1 
\v 3 Thinglam tah kho kung ah hlang mueihla ka mawt rhoek,
\q1 Tu ping khui la tu ca ka mawt rhoek,
\q1 Sui lu muek a ka then sak kung la om pawn ni,
\q1 te kah sui kho puei om then dong ah.
\c 441
\s1 Vaan Dong Omthen Lungnah Ram
\s2 Will The Circle Be Unbroken?
\sp Doh is Ab
\q1 
\v 1 Vaan dong om then lung nah ram ke,
\q1 hlang cim rhoek kah a im ni.
\q1 A mih taengah om van ham la
\q1 diklai hno boeih te voei lah,
\q1 Dik lai tue he a bawt vaengah a voel ah a im ah,
\q1 Hlang cim rhoeng pong pa na ram ah
\q1 vuen vai ah n'om van ni.
\q1 
\v 2 Dung yan im then boeilenhmuen kah,
\q1 om rhoek tah hlang cim rhoek ni.
\q1 Te im then ah om van ham la
\q1 paeng tom hlang tom te a coi.
\q1 Dik lai tue he a bawt vaengah a voel ah a im ah,
\q1 Hlang cim rhoeng pong pa na ram ah
\q1 vuen vai ah n'om van ni.
\q1 
\v 3 Khangkung manghai dueknah hmuen neh
\q1 a lung vatnah boeih thui uh
\q1 A tue a hmoel a soep vaeng ah
\q1 A lungvat nah te tang nah.
\q1 Dik lai tue he a bawt vaengah a voel ah a im ah,
\q1 Hlang cim rhoeng pong pa na ram ah
\q1 vuen vai ah n'om van ni.
\q1 
\v 4 Pakhat phoei khat a caeh atah,
\q1 Im khui kho loh soep tlaih pawh,
\q1 Te bal ca khaw thin tlo rhoek neh
\q1 hum tun soepnah om ve nim.
\q1 Dik lai tue he a bawt vaengah a voel ah a im ah,
\q1 Hlang cim rhoeng pong pa na ram ah
\q1 vuen vai ah n'om van ni.
\c 442
\s1 Vaan Dong Kho Ka Ngaiuep
\s2 There Is No Sorrow There
\sp Doh is A
\q1 
\v 1 Vaan dong kho ka ngaiuep
\q1 Jehovah Pathen kho,
\q1 A sui mik hmai then hmuh vaengah
\q1 om ngaihnah soep pawn ni.
\q2 \qt Ko thae nah om tlaih pawh,\qt*
\q2 \qt kothae nah om tlaih pawh, \qt*
\q2 \qt Lung nah soep boeih vaandong sui ram\qt*
\q2 \qt kothae nah om tlaih pawh.\qt*
\q1 
\v 2 Vaan dong kho ka ngai uep
\q1 A kan khangkung omnah,
\q1 A lungnah neh thangthen nah laa
\q1 yoe yah la n'sak uh ni.
\q1 
\v 3 Vaan dong dong kho ka ngai uep
\q1 Vaan hlang cim rhoek boeih loh,
\q1 Him bai bok bai tih boeih om uh,
\q1 ma mih khaw n'om van ni.
\q1 
\v 4 Vaan dong kho ka ngai uep
\q1 Cet tangtae rhoek boeih neh,
\q1 Humtun vaengah m'paek voel mahpawh,
\q1 yoe yah la n'omngaih ni.
\c 443
\s1 Khomik A Saenah Voel Ben Ah
\s2 A Home On High
\sp Doh is Ab
\q1 
\v 1 Kho mik a sae nah voel ben ah,
\q1 vaan kho mai kah voel ah,
\q1 Kho yin ai si kah voel ben ah,
\q1 vaan ah im ka khueh coeng.
\q2 \qt Ke lum im tah kut neh sak pawh,\qt*
\q2 \qt kai ham a rhoek bah coeng\qt*
\q2 \qt Vaan hlang rhoek loh Pa then a koeh , \qt*
\q2 \qt Kai ka om na ham im. \qt*
\q1 
\v 2 Kho daeng pa tang kah voel ben ah,
\q1 ngai hmang nah voel ben ah,
\q1 A tue tho vael omnah pawt ah,
\q1 kai ah im oep soeh om.
\q1 
\v 3 Dueknah hli puei kah voel ben ah,
\q1 kho yin na voel ben ah,
\q1 Ka mueihla omngaihnah neh bae,
\q1 vang nah lum im om coeng.
\q1 
\v 4 Tholh rhih tloh pa tang na boeih te
\q1 ta hae ka caeh tak coeng.
\q1 Dung yan om van hamla ka ngaih
\q1 Khang kung Khrih om nah ah.
\c 444
\s1 Diklai Khohnin Loh Khum Pawn Ni
\s2 Saved By Grace
\sp Doh is F
\q1 
\v 1 Dik lai kho hnin loh khum pawn ni
\q1 ta hae kah coeng na khaw hma ni,
\q1 manghai kah lum im khui ah te
\q1 omngaih la ka hing hang vaeng ah.
\q2 \qt Boeipa neh rhep ka hmu rhoi ni,\qt*
\q2 \qt Lungvat nah cil te ka thui ni, \qt*
\q2 \qt Boeipa neh rhep ka hmu rhoi ni, \qt*
\q2 \qt lungvat nah cil te ka thui ni. \qt*
\q1 
\v 2 Dik lai yin im he tah tim ni,
\q1 me tlam ka om eh ka ming pawh,
\q1 Ka Soeprhaep ah Soeprhaep mah loh
\q1 vaan lum im han khueh coeng ka ming.
\q1 
\v 3 Kho sae then loh khum yip bal tih
\q1 Boeipa neh ka hum uh vaeng ah,
\q1 Boeipa thui a ka yun bang la
\q1 duem nah khui ah ka kun van ni.
\c 445
\s1 Kil Pali Khopuei Te Om
\s2 No Night There
\sp Doh is Eb
\q1 
\v 1 Kil pali khopuei te om,
\q1 Te ah khoyin om pawh.
\q1 Mevaeng ah khaw khum mah pawh,
\q1 Te ah khoyin ompawh.
\q2 \qt Pa then loh mikphi a huih,\qt*
\q2 \qt Duek om pawh, rhih nah om pawh, \qt*
\q2 \qt Kum hla tae nah khaw om pawh, \qt*
\q2 \qt te ah kho yin om pawh. \qt*
\q1 
\v 2 Kil pali kho puei te om,
\q1 Thoh ka te laitha ni.
\q1 Longpuei khaw likmal la om,
\q1 Te ah khoyin om pawh.
\q1 
\v 3 Kil pali khopuei te om,
\q1 Thohka khai uh tlaih pawh,
\q1 Hing na tuiva te long tih,
\q1 Te ah khoyin om pawh.
\q1 
\v 4 Kil pali kho puei te om,
\q1 Khosae hla vang ngoe pawh,
\q1 Tucanoe te vang coeng tih,
\q1 Te ah khoyin om pawh.
\c 446
\s1 Caeh doe ah Omngaihnah Laa Then
\s2 In A Little While We're Going Home
\sp Doh is F
\q1 
\v 1 Caeh doe ah om ngaihnah laa then sa uh lah sih,
\q1 im la kolh kalh ni n'caeh uh pawn eh;
\q1 Kho yin loh khum ni dung yan kho ha sae pawn ni,
\q1 im la kolh kalh ni n'caeh uh pawn eh.
\q2 \qt A di hlan vaeng ah, a di hlan vaeng ah\qt*
\q2 \qt ma mih tui phu n'kat u ni. \qt*
\q2 \qt n'kun tun uh pawn ni, \qt*
\q2 \qt Hli puei te n'poen uh pawn ve tih, \qt*
\q2 \qt im la kolhkalh ni n'caeh pawn eh.\qt*
\q1 
\v 2 Kut neh n'sai ham tueng bi bi te n'sai uh lah sih,
\q1 im la kolh kalh ni n'caeh u pawn eh;
\q1 Pathen lung vatnah hnin ta kuem tha han om sak,
\q1 im la kolh kalh ni n'caeh uh pawn eh.
\q1 
\v 3 La kueng doe n'cet dae caeh ko loh dik dik ah tui,
\q1 im la kolh kalh ni n'caeh uh pawn eh,
\q1 Ka ko dang long tah omngaih ko la yael tang kik,
\q1 im la kolh kalh ni n'caeh uh pawn eh.
\q1 
\v 4 Te hmuen ah duem na om ti ngaimong nah om bal
\q1 im la kolh kalh ni n'caeh uh pawn eh,
\q1 Te kho puei then ah mik phibonah om voel pawh,
\q1 im la kolh kalh ni n'caeh uh pawn eh.
\c 447
\s1 Hlangcim Caeh nah Longpuei Rhuem Ka Vai
\s2 Safe In The Glory Land
\sp Doh is G
\q1 
\v 1 Hlang cim caeh nah long puei rhuem ka vai tih,
\q1 Boeipa loh a hmai ah phat m'mawt;
\q1 Vaan ram im pan ham caeh ka tong vaengah,
\q1 Kho thaih ai si ka so ah vang.
\q2 \qt Vaan imthen pan ham cet uh li,\qt*
\q2 \qt Hing nah omngaihnah pang van ham la, \qt*
\q2 \qt pha uh vaeng ah omngaih tangkik ni, \qt*
\q2 \qt vaan imthen ah om ni.\qt*
\q1 
\v 2 Uep omnah neh kong hu then ka vai vaeng,
\q1 lung vat nah neh rhoepnah long tah,
\q1 Boeipa muei ka hmuh vaeng ka omngaih ni,
\q1 Amah neh ka kun tun pawn ni.
\q1 
\v 3 Hnuk sul ka poek vaengah rih ham om tih,
\q1 dueknah tui puei ka kat ca khaw,
\q1 Boeipa loh rhal vang ben la n'kat puei ni,
\q1 Amah te ka thangthen sak ni.
\c 448
\s1 Khoyin Khohmuep ah M’pongpa
\s2 When The Beautiful Gates Infold
\sp Doh is G
\q1 
\v 1 Kho yin kho hmuep a m'pong pa tlaih voel mahpawh,
\q1 Thoh ka then a ong vaeng atah.
\q1 Pa then kah a aa kho puei ah n'cet uh ni.
\q1 Thohka then a ong vaeng ahtah.
\q2 \qt Lai tha thoh te a ong vaeng ah te tah,\qt*
\q2 \qt Lai tha thoka then a ong vaeng ah te tah, \qt*
\q2 \qt Boeipa muei m'hmuh uh ve tih omngaih uh ni. \qt*
\q2 \qt Thoh ka then a ong vaeng atah.\qt*
\q1 
\v 2 Thin tlo hlang loh tui kaeng ah kai te n'rhing li,
\q1 Thoh ka then a ong vaeng atah,
\q1 A im la kai n'doe tih tholh lam ka ka loeih,
\q1 Thohka then a ong vaeng atah.
\q1 
\v 3 Tloh tat ko thae pa tang nah om tlaih mahpawh,
\q1 Thoh ka then a ong vaeng atah,
\q1 Puei van boeih neh omngaih la kun tun hmai ni,
\q1 Thohka then a ong vaeng atah.
\q1 
\v 4 Boeilennah mueihlip long mah mih soh ah yaal,
\q1 Thohka then a ong vaeng atah,
\q1 Te rhal vang ben ah omngaih laa n'sak uh ni,
\q1 Thohka then a ong vaeng atah.
\q1 
\v 5 Thoh ka then te a ong vaeng ah tah,
\q1 Thohka then a ong vaeng ah tah,
\q1 Boeipa muei m'hmuh uh ve tih omngaih uh ni,
\q1 Thoh ka then a ong vaeng atah.
\c 450
\s1 Khohnin Omthen Loh Ha Pai He
\s2 Haleluijah We Shall Rise
\sp Doh is Bb
\q1 
\v 1 Khohnin omthen loh ha pai he
\q1 hlang tom boeih loh omngaih uh,
\q1 Lung va nah Thang then uh.
\q1 Lungvatnah thohka thai ta hae
\q1 mamih hamla a ong coeng,
\q1 Boeipa ming Thang then uh
\q2 \qt \nd (Thangthen uh)\nd* \qt*
\q2 \qt \nd (Thangthen uh)\nd* \qt*
\q2 \qt Haleluijah \nd (Thangthen uh)\nd* \qt*
\q2 \qt Amen thangthen uh. \qt*
\q2 \qt Nam tom boeih ham yoethen thoh ka \qt*
\q2 \qt he tah a thai la a ong coeng\qt*
\q2 \qt Boeipa ming Thangthen uh\qt*
\q1 
\v 2 Tholh tam na khui kah na ca rhoek ham
\q1 loeih nah he na saii coeng,
\q1 Boeipa ming Thang then uh.
\q1 A vong thoh ka khui ka kun tah
\q1 po ci hma ta voel mah pawh,
\q1 Boeipa ming Thang then uh,
\q1 
\v 3 Kun a ka ngaih boeih loh kun uh
\q1 a tue a ong vaeng ah he,
\q1 Boeipa ming Thang then uh.
\q1 A ong tang tae thohka then he
\q1 u long khaw khai voel mah pawh,
\q1 Boeipa ming Thang then uh.
\c 451
\s1 Tingtoeng Pom Doe Hlang Ping
\s2 The New Song
\sp Doh is Bb
\q1 
\v 1 Ting toeng pom doe hlang ping rhoek loh pai uh tih,
\q1 Jesuh hmai ah hekah laa thai he a sak uh.
\q2 \qt Ma mih nlung na tih tholh a ka sil kung taengah\qt*
\q2 \qt Boeilennah a taeng ah dung yan om saeh A men.\qt*
\q1 
\v 2 A hmai ah tuei laehkap hlang tholh rhoek te khaw,
\q1 Bai bok a bai sak tih laa thai hmaih a sak uh.
\q1 
\v 3 A mah tah kho soi neh seng pa hrang la om,
\q1 A mah loh n'lai coeng tih laa thai he n'sak sak uh.
\q1 
\v 4 Ma mih hlang tholh ngai daeng ngai kha vaeng mai ah,
\q1 A mah loh n'lung nah tih ma mih tholh han cim sak.
\c 452
\s1 Sayuk Loh Tuisih Te a ngai Bangla
\s2 As the Deer
\sp Doh is Ab
\q1 
\v 1 Sa yuk loh tui sih te a ngai bangla
\q1 ka mueihla loh nang te n'ngai,
\q1 Nang bueng kan thin tlohnah,
\q1 namah bueng ni bawk ham ka ngaih.
\q2 \qt Nang bueng ni kai ka tha om nah\qt*
\q2 \qt mueihla ham khaw patling la na om. \qt*
\q2 \qt Nang bueng ni kan lung nah, \qt*
\q2 \qt na mah bueng te ni bawk hamla ka ngaih.\qt*
\q1 
\v 2 Na mah ni pa ya then
\q1 ma nu ca neh ka manghai boei la na om
\q1 A tloe boeih boeih lak ah,
\q1 na mah bueng ni kan lung nah ngai.
\q1 
\v 3 Na mah ni sui ngun lak a khaw
\q1 tanglue koek la kan lung na koek ngai,
\q1 Nang long bueng ni omngaih,
\q1 na a ka pae kung la na om.
\c 453
\s1 Khrihca Hlang Cim Rhoek
\s2 Jubilee
\sp Doh is Bb
\q1 
\v 1 Khrihca hlang cim rhoek Boeipa Jesuh loh khue uh.
\q1 Vaan dong Jubilee poei bul nah loh yoei coeng
\q1 Vaan hlang cim rhoek loh om ngaihnah laa then sak neh
\q1 Vaan dong Ju bi lee poei bul nah loh lamtawn uh.
\q2 \qt Vaan dong Ju bi lee kho hnin loh yoei coeng\qt*
\q2 \qt si kim uh boeih sih a mah loh khue vaeng ah\qt*
\q2 \qt Diklai tholh nah ah a ngai ka mong hlang boei tah\qt*
\q2 \qt hing nah Ju bilee poei ah bul thai voel mah pawh\qt*
\q1 
\v 2 Je ru sa lem thai Boeipa Jesuh kah kutngo
\q1 hingnah tui va kaengah thing soep pailum nah
\q1 Amah thangthennah laa sak ol loh ha hum thuk
\q1 Tlankung so sang koek tila laa sak ol loh rhoi.
\q1 
\v 3 Boeipa Jesuh ham thin ko a ka phat rhoek neh
\q1 Dik lai dong kah patang rhai nah neh dueknah
\q1 A cing doem noei tlang a sip hnawt hlang com hlang cim
\q1 Boei Jesuh Khrih amah hmai ah tun u boeih sih.
\c 454
\s1 Hingnah Pathen Kum a Hoi Uh
\s2 God Of Our Life, Through All Circling Years
\sp Doh is G
\q1 
\v 1 Hing nah Pathen kum a hoi uh khui ah nang kan uepnah.
\q1 Hnuk sul a khaw ngai uepnah rhihnah ah na kut ka hmuh,
\q1 Min cang ta kuem kah kho sae then koep koep ha sae bal tih
\q1 Na lung vatnah bawt pawh.
\q1 
\v 2 Boeipa Pathen na kut ah a tue om, kai taeng om lah,
\q1 Ol khueh ram tangnah neh mawt uh lamtah n'hoihaeng uh lah.
\q1 Na yoe thennah loh kho yin te kho koep a sae sak tih
\q1 tangnah ming loh ha tueng.
\q1 
\v 3 Kho hmai kum ka ka caeh ham ka ming pawh nang hnuk kan vai,
\q1 ka tha a rhang uh vaeng ka mah mih bueng n'caeh tak sut boeh,
\q1 Nang te vuen hlaem ah kaimih boeih hamla buh an la om
\q1 ta kum khui ka dong ah.
\c 455
\s1 Khangkung Boei Kah Lungnah Cil
\s2 Sweeter As The Days Go By
\sp Doh is D
\q1 
\v 1 Khang kung boei kah lungnah cil
\q1 rhuem te tah hnin at pa toeng hnin at di dip,
\q1 Ngai khuek nah ko hoenah vaan im loh
\q1 hnin at pa toeng hnin at ah didip.
\q2 \qt Hnintakuem omngaih la n'koeh ni,\qt*
\q2 \qt omngaih laa sak doe vaan la n'ding ni. \qt*
\q2 \qt So ben kah lung nah laa long tah\qt*
\q2 \qt Hnin takuem ah di dip hlang mai. \qt*
\q1 
\v 2 Hingnah hmai vang kho saeng then long
\q1 te tah hnin at pa toeng ah koep koep sae,
\q1 Ol khueh aisi loh kho yin khui ah
\q1 hnin at patoeng hnin at ah ha vang.
\q1 
\v 3 Ngai uepnah lungvawt loh hli lakli
\q1 ah hnin at pa toeng yung a cak sak,
\q1 Dik lai hing ngai hmang nah lak li ah
\q1 hnin at pa toeng ka dawn a sai sak.
\c 456
\s1 Kum Thai Tue Thai Ha Thoeng
\s2 Another Year Is Dawning
\sp Doh is Eb
\q1 
\v 1 Kum thai tue thai ha thoeng coeng, Pathen ko ngaih bangla,
\q1 Amah neh hmaih bi bi ham kum a tloe pa toeng om,
\q1 Thang thennah kum la om tih, rhoengcawt nah kum la om.
\q1 Kai taeng om yoeya ve tih, Kum a thai a thoeng sak.
\q1 
\v 2 Lung vat nah neh a ka soep kum thai tah ha thoeng coeng,
\q1 Om ngaih nah kum thai long te Boeipa hmai a tueng sak,
\q1 Lung vat rhang suk dongah te, ka kuep ka kol pawn ni,
\q1 Om ngaih ngai mongnah dongah, Uep om nah kum ha thoeng.
\q1 
\v 3 Na lung vatnah cil thui ham kum thai tah ha thoeng coeng,
\q1 Cim nah bi bi awt hamla Kum thai pa toeng ha thoeng,
\q1 Kum thai tue thai ha thoeng coeng, Pa then ko ngaih bangla,
\q1 Lai lamkah loh vaan duela, nang hamla kum thai om.
\c 457
\s1 Omdam Kopoek Ko La Hoe
\s2 While The Days Are Coming By
\sp Doh is A
\q1 
\v 1 Omdam kopoek loh ko la hoe,
\q1 khohnin tue a caeh vaeng ah,
\q1 Hlang mueihla long tah poci boeih
\q1 khohnin tue a caeh vaeng ah.
\q1 mamih yin caeh li vaeng ah
\q1 omngaihnah thai cuen koi nih,
\q1 then na te sai u boeih sih,
\q1 khohnin tue a caeh vaeng ah.
\q2 \qt Kho hnin tue loh cet li \qt*
\q2 \qt Khohnin tue loh cet li \qt*
\q2 \qt hno then te mah sai uh sih\qt*
\q2 \qt khohnin tue a caeh vaeng ah. \qt*
\q1 
\v 2 Tohhaem nah thi na tue khueh boeh
\q1 khohnin tue a caeh vaeng ah,
\q1 Ming cang khosae bang la hmai khueh
\q1 khohnin tue a caeh vaeng ah,
\q1 diklai ah hmuh na loh yet
\q1 mik hmuh ah kothae na tueng,
\q1 A ka bung koeina te thoh,
\q1 khohnin tue a caeh vaeng ah
\q1 
\v 3 Lung nah rhui loh mamih boeih m'pin
\q1 khohnin tue a caeh vaeng ah,
\q1 Pakhat phoei ah pakhat n'caeh tak
\q1 khohnin tue a caeh vaeng ah,
\q1 Khosae neh a huep kah n'tuh
\q1 cang ti long tah poe ngai ni,
\q1 lung buei mah omngaih uh sih,
\q1 khohnin tue a caeh vaeng ah.
\c 458
\s1 Omngaih Hlang Rhoek Halo Uh
\s2 Come, Ye Thankful People Come
\sp Doh is G
\q1 
\v 1 Om ngaih hlang rhoek ha lo uh, cang koei laa te sa uh lah.
\q1 Thai di khui ah boeih khueh uh, hli puei loh ha lo hlan ah.
\q1 Kho khan kung sai kung Pa then ngoe ngaih na ka soep sak kung.
\q1 Pa then im la ha lo uh, cang koei laa te sa uh sih sih.
\q1 
\v 2 Pathen he hmuen kung la om, a vuei thaih dong a ko hoe,
\q1 Cang ti bael lung hmaih a tue, omngaih ko thae khaw poe hmaih,
\q1 mikhing hang tih lai moe coeng, cang kung long tah boeih ha thoeng,
\q1 Pa then thang bong na mah loh, hi cil cang mah m'boeng sak lah.
\q1 
\v 3 Pathen ha lo koep ve tih, cang vuei te boeih a coi ni,
\q1 Te hnin ah lo hmuen boeih kah cang hi te boeih a voeih ni,
\q1 Hmai dong a ka phum hamla van cael tueih te a tueih coeng,
\q1 cang tak te thai di khui ah, a then la a khoem pawn ni.
\q1 
\v 4 Boeipa a loe ha lo laeh, lo noi cang vuei coi ham la,
\q1 Tholhnah neh ko thae khui kah na hlang rhoek te ha coi lah,
\q1 Namah hmai ah om hamla amih boeih te cim caih sak,
\q1 Vaan cael tueih neh hmai ha lo na cang vuei te coi hamla.
\c 459
\s1 Huhbung Neh Tawnhnu Pamsae
\s2 We Plow The Fields And Scatter
\sp Doh is Bb
\q1 
\v 1 Huh bung neh tawn hnu pam sae n'tawn tih cang ti n'tuh dae,
\q1 Pathen kah sai thai nah loh rho tui then a tlan sak,
\q1 Sik ca tue ah vuel tla tih, kho hal ah kho loh awlh.
\q1 Yil ding kho sae then neh kho tlan tui khaw a tlan sak.
\q2 \qt Taeng vai kah kutdoe then he vaan lam kah nan paek,\qt*
\q2 \qt Kan uem tang mah aw ka boeipa nang ni kan uem. \qt*
\q1 
\v 2 Amah bueng ni a hla a yoei kah hno boeih sai kung,
\q1 Rhai pai neh a thoeih cam ai si mik te a vang sak.
\q1 A ol te tah hli puei neh, tui phu loh a ngai pah.
\q1 Vaa pa taeng a cah te a ca ma mih he n'cah ni.
\q1 
\v 3 A pa nang kan uem uh soep rhaep hno then na sai tih,
\q1 Rhuk tuh tue neh cang ah tue, ka hingnah sa ding sak nah,
\q1 Nan lungnah kan thung uh he nang loh han doe mai dae,
\q1 Uem o lung hoih nah neh ka ko dang loh nang ni m'moe.
\c 460
\s1 Khangkung Boei Kah Lungnah Ka Ming
\s2 A Song Of Salvation
\sp Doh is G
\q2 
\v 1 Khang kung boei kah lung nah ka ming
\q1 A lung nah kho bae rham bae pawn ni,
\q1 Vaan dong lam kah lai dong ha rhum
\q1 kai lungnah tih sitlohnah dong ah, dong ah
\q1 kai n'lung nah tih n'sit lohnah dong ah,
\q2 \qt oe oe oe kai ham kai ham\qt*
\q2 \qt oe oe oe kai ham\qt*
\q2 \qt M'boeipa loh ha rhum tih lung nah tlo koek neh\qt*
\q2 \qt nang neh kai tlan ham thinglam dong duek.\qt*
\q1 
\v 2 A uehnah neh thii a long nah,
\q1 Thing lam dong ko thae pa tangnah te,
\q1 Me ah khaw a thui u pawn ni,
\q1 Kai hamla ko thae pa tangnah te, nah te,
\q1 kai hamla ko thae pa tangnah te,
\q1 
\v 3 Vaan dong kho cil te ka thui coeng,
\q1 Jesuh kah ca rhoek loh a pang ni,
\q1 Te vaan dong kah kah hmuen a ke
\q1 Kai ham hmuen a sai oep soeh pawn nim, pawn nim,
\q1 kai ham hmuen a sai oep soeh pawn nim.
\c 461
\s1 A Cim Pathen Mah Loh Khangnah He
\s2 By Grace Are Ye Saved
\sp Doh is D
\q1 
\v 1 A cim Pathen mah loh khang nah he a saii coeng,
\q1 A lung vatnah ah tuek la om,
\q1 hlang tholh te khang la om.
\q2 \qt Lungvat nah tang nah dong ah khang nah om,\qt*
\q2 \qt tang nah dong rhang ah khang nah om na mah poek a moe nih, \qt*
\q2 \qt na mah kah bi na rhang nen moe nih\qt*
\q2 \qt na bi sai na nen moe nih, u ca khaw koe voei boeh\qt*
\q2 \qt Pathen kah kut doe ni, Pathen kah kut doe ni, \qt*
\q2 \qt Pa then kah kut doe ni, Pathen kah kut doe ni \qt*
\q2 \qt Pathen kut doe \qt*
\q1 
\v 2 A ca pa Jesuh ah he lung vatnah ha tueng,
\q1 Thinglam ah yah rhai a poh dae
\q1 Pathen lungvatnah tueng
\q1 
\v 3 Khrih dong ah aka tueng Pathen a ka tangnah,
\q1 Lung vatnah khangnah a khueh coeng,
\q1 Pathen ca la om coeng.
\c 462
\s1 Kanan Ram Lungloeinah Kap
\s2 Canaan, Beautiful Land
\sp Doh is G (Moderate)
\q1 
\v 1 Ka nan ram lung loei nah kap ke,
\q1 Boei Jesuh thing lam neh ka tuuk coeng.
\q1 Te thing lam loh hmai ben ah m'mawt,
\q1 Ka caeh long yin te a vang sak.
\q2 \qt Jordan tui kothae na ram he \qt*
\q2 \qt Tholh olrhi a om na ram ni, \qt*
\q2 \qt Te dae ka boeipa thing lam ah, \qt*
\q2 \qt Ol rhi boeih boeih te ka khueh coeng.\qt*
\q1 
\v 2 Po ci rhai nah soep rhaep boeih neh,
\q1 sawt sit nah hnaep na boeih boeih te khaw,
\q1 Te so kah te rhoek boeih boeih te,
\q1 Boei Jesuh loh boeih a loh coeng.
\q1 
\v 3 Khrih kah hno sai thai na long tah,
\q1 tloh nat nah soep rhaep boeih a hoeih sak,
\q1 Ka vawtthoek na boeih a loh tih,
\q1 A tha om na neh kai te m'mawt.
\q1 
\v 4 Kanan ram then neh ngaih om ke,
\q1 tang nah neh Khrih ah ka dang coeng tih,
\q1 Yoethen nah te khaw m'paek coeng tih,
\q1 hno sai thai na te khaw m'paek coeng.
\c 463
\s1 Thinglam Dongah Thisen Tlo Om
\s2 Precious Blood on The Cross
\sp Doh is Eb
\q1 
\v 1 Thinglam dong ah thisen tlo om,
\q1 Thinglam cim te ka hmuh,
\q1 Thisen tah Jesuh loh m'ming sak
\q1 Kai hamla ka long te.
\q2 \qt Aw thisen a ka tlo koek\qt*
\q2 \qt Jesuh loh a ueh nah, \qt*
\q2 \qt Thinglam dong ah thisen tlo long\qt*
\q2 \qt tangnah neh ka hmuh coeng.\qt*
\q1 
\v 2 Thing lam ka rhih tang kik mai te,
\q1 Jesuh kai ham a koh,
\q1 Ko thae tangkik a ueh na te,
\q1 Kal va ri ah a hal.
\q1 
\v 3 Yang hoep coi nim thinglam tlo te,
\q1 Ke thinglam ka dan dae,
\q1 Ka koh thai tang van venim aw,
\q1 Ka bi ni lumuek ham,
\q1 
\v 4 Boeilumuek a kathen koek te,
\q1 Ta kung boei lumuek ni,
\q1 Vanah Jesuh ka hmuh vaeng ah,
\q1 Kai khaw ka muek van ni.
\q1 
\v 5 Ka mik phi tui bo voel mah pawh,
\q1 Lung nah bawt na mueh ah,
\q1 Dik lai dong lam kah m'mawt lam tah,
\q1 omngaih hmuen m'pha sak lah.
\c 464
\s1 Ka Khangkung Loh Kai Yueng La
\s2 Nailed To The Cross
\sp Doh is F
\q1 
\v 1 Ka khang kung loh kai yueng la duek nah a tuek coeng,
\q1 hing pa pawh kai hlang tholh khang ham la,
\q1 Ba dong ah hnaelcoena neh yah poh na a ueh
\q1 Ka tholh toek lek na khaw dawk a ngai.
\q2 \qt Ka tholh nah thinglam dong boeipa loh a phueih coeng,\qt*
\q2 \qt Tholh na me yet khaw khawdawk a ngai, \qt*
\q2 \qt Kothae thui lek thai pawh a ueh Kalvari ah\qt*
\q2 \qt ka tholh na phu laiba a sah boeih coeng.\qt*
\q1 
\v 2 Boeipa loh lung nah tah aw ka thui lek thai pawh,
\q1 Tholh a ka mu mai a silh boeih coeng,
\q1 A mah loh koep ntlan tih ka tholh tak voel mah pawh,
\q1 Thing lam loh diklai neh n'lang sak coeng.
\q1 
\v 3 Thinglam kung ah ka tholh na boeih boeih ka hal coeng,
\q1 Me tla tholh hno rhih ka phueih khak eh?
\q1 Jesuh loh thinglam dong ah te a tai coeng tih,
\q1 Vaan hing cim neh ka pongpa pawn ni.
\q1 
\v 4 Ka khang kung te tholh ah ka pam tak voel mah pawh,
\q1 Hin takuem a bi ka bi pawn ni,
\q1 A ming cim thangthen na ham koeh nah laa ka sak,
\q1 Ka thin tloh na tang kik khang kung boei.
\c 465
\s1 A Cim Kuttukanah Hinyah Kap
\s2 Heaven of Rest
\sp Doh is Ab
\q1 
\v 1 A cim kuttuk nah hinyah kap la n'sai uh,
\q1 Boeipa loh a thui sut coeng ni,
\q1 Diklai a suen vaeng ah boeipa loh a tong,
\q1 Yu neh va pum khat la coeng ham.
\q2 \qt Lung vat kung boeipa, He a cim kuttuknah,\qt*
\q2 \qt Yoe thennah neh han cak sak, \qt*
\q2 \qt Lungnah a yung pa a cak nah ham\qt*
\q2 \qt Cim Mueihla neh a long puei te ham mawt lah.\qt*
\q1 
\v 2 Kang halh kung ompawh a cim he kut tuk nah,
\q1 Khrih ca mamih hingnah rhoe ni,
\q1 Boeipa lung na khui ah kuttuk nah cak saeh,
\q1 Khrih ca imkhui then la coeng saeh.
\q1 
\v 3 Pathen samtom he hlang hing loh paek boel saeh,
\q1 Kang halh kung hno boei te hma saeh,
\q1 Paekboe nah sawtsit na thin ko om boel saeh,
\q1 Yoethen om nah soep saeh tila.
\c 466
\s1 Aw Ka Boeipa He Hmuen Cim Ah
\s2 Wedding Band
\sp Doh is A
\q1 
\v 1 Aw ka boeipa he hmuen cim ah,
\q1 Kuttuk olcaeng cak sak ham ka lo uh,
\q1 Nang loh han doe samtom na he,
\q1 Hing khui puet a cak na ham ol ka caeng.
\q2 \qt Na lung nah rhui neh m'pin uh lam tah,\qt*
\q2 \qt U long khaw paek boe thai uh boel saeh, \qt*
\q2 \qt Na vaan yoethen na te ham pae, \qt*
\q2 \qt Lung nah im khui kho la han coeng sak lah. \qt*
\q1 
\v 2 He diklai ah ka tong ham koi,
\q1 soep rhaep boeih ah lungnah long he cak saeh.
\q1 Lung hoeih ko poe nah pung tai saeh,
\q1 A lungnah thai mueh khaw lungnah thai saeh.
\q1 
\v 3 Aw ka boeipa namah hmai ah,
\q1 Kut tutnah hinyah kap la ka sai uh.
\q1 Han doe lamtah han cim caih sak
\q1 Dik lai suen cuek lamkah na hmoel bangla.
\c 467
\s1 Tahae Jesuh Cilka He Thintlo Paya
\s2 O God, Most Gracious
\sp Doh is D
\q1 
\v 1 Ta hae Jesuh cil ka he thin tlo pa ya then ni,
\q1 Ha lo omngaih la Nang ham a sai hno thui lah sih.
\q2 \qt Jesuh cil ka long ni ka long puei a he n'talong\qt*
\q2 \qt Thang thui thothueng vaeng ah diksueh ol ding te han thui.\qt*
\q1 
\v 2 Ta hae Jesuh cil ka loh na tholh kho dawk han ngai,
\q1 A lung vatnah loh Na vaan dong im la n'luei puei ni.
\q1 
\v 3 Ta hae Jesuh cil ka ol neh thui thai lek pawt dae,
\q1 Ka khangkung boeipa Te ni ka thin tloh cil ka thui.
\q1 
\v 4 Ta hae Jesuh cil ka he pal tham thai tlaih mahpawh,
\q1 Ka thaa na ca khaw ko thae na lam ni a thoeng eh.
\q1 
\v 5 Ta hae Jesuh cil ka longtah tangnah ha yol tih,
\q1 Ka thaa hnoeng vaengah thaa han koep han thoh tih n'duem sak.
\c 468
\s1 Pathen Loh Yan Lamkah Yulohnah A saii
\s2 Wedding Song
\sp Doh is Bb
\q1 
\v 1 Pa then loh yan lamkah yu lohnah a saii,
\q1 Aka cim im khui kho la om ham.
\q1 Hinyah nah neh uep om la kho sak na ham,
\q1 A cim hingnah a khueh na thai ham.
\q2 \qt Tha hlue thahmae la omngaih puei sih,\qt*
\q2 \qt Paya then kah yuloh na poei he, \qt*
\q2 \qt Ta hae ah n'uem puei he vaan dong la pha saeh, \qt*
\q2 \qt Dik lai ah hing nah a bawt due la. \qt*
\q1 
\v 2 Jesuh loh a hlang boel rhoek a lungnah tih,
\q1 Anih ham hinglu a paek bangla,
\q1 He yuloh vasak kung rhukom la om saeh,
\q1 A cim tukkilnah te vai rhoi saeh.
\q1 
\v 3 Boeipa amih rhoi he na kut ah kan tloeng,
\q1 A soah yoe then na te cak sak,
\q1 Ko thae omngaih a khaw bong yong uh rhoi saeh,
\q1 A tha om te nang ham hnonah saeh.
\c 469
\s1 Ti Hnin Hang Cadong Hula
\sp Doh is
\q1 
\v 1 Ti hnin hang cadong hu la,
\q1 Ram hamla bang nim na sai uh Kho yinnah ram,
\q1 m'hmuh vaengah na ko a thae u moenih a?
\q1 thangthui hamla a kuek.
\q2 \qt Then hlang van dae ta mi mi ram kah muei mae he,\qt*
\q2 \qt Bang ah tahae due Jesuh muei a kap pawh \qt*
\q2 \qt Unim uep nah ma mih ram ham \qt*
\q2 \qt Jesuh loh nang cing cing n'ngoe coeng. \qt*
\q1 
\v 2 Nang na om van pawt koi nih,
\q1 Yin ta aep ni ma mih kong ah, Ma ya ma na,
\q1 Rhih om hlang mai ta he vaeng hingnah tue he,
\q1 oltak Mueihla n'ngoe coeng.
\q1 
\v 3 Ram thai vang sak kung hamla
\q1 Nang neh kai kah hut lam ni om, na ming pawn a?
\q1 Vangvan pawn saeh ma mih ram he Jesuh loh,
\q1 Bi then koek te m'paek coeng.
\c 470
\s1 Kan Rhing Yoeyah Ka Boei Koek
\s2 The Beauty of Heaven
\sp Doh is Bb
\q1 
\v 1 Kan rhing yoe yah ka boei koek, Dik lai rhainah yin khui ah,
\q1 Na sai tae Sa lem kho puei aw ka ngai tang kik coeng,
\q1 Dik lai rhih om na neh yin khui ka pong pa ca khaw,
\q1 Lungnah neh aka tlap kung ka ngai nah bawt thai pawh.
\q2 \qt Vaan omthen Eden thai then tah,\qt*
\q2 \qt ko thae om tlaih na pawt hmuen te\qt*
\q2 \qt Aw mevaengnim ka pha van ve, \qt*
\q2 \qt Na dungyan boei nah ram vangnah ram then te.\qt*
\q1 
\v 2 Ha yoei lah ka khang kung boei, Rhal ha yet diklai ah he,
\q1 Thi sen neh na tlan ca rhoek ko thae doela rhap boeih.
\q1 Lai hman na lo vaengah na la kueng nah Kal va ri
\q1 Na rhal rhoek ha tho bal coeng na ram ka tuk rhoek ke.
\q1 
\v 3 Aw me lam nim khang kung boei Zi on tlang rhalmongnah te,
\q1 Tholh a cimnah lungnah tui kai ham na long sak te,
\q1 Tholh a mang nah vong puei dung yan vaan dong kho neh tui,
\q1 Khang ca rhoek tah na taeng ah, omngaih la pong pa uh.
\q1 
\v 4 Dik lai paeng he hma pawn ni A di hlanah hma pawn ni,
\q1 Khang kung boei loh pang vetih diklai n'caeh tak pawn ni,
\q1 Khrih loh a lungnah hlang tah boeilennah a pang ni,
\q1 Lungnah longtah tho li coeng omngaih ha le lui jah.
\c 471
\s1 Ka Lungnu Puei Aw Ka Khangkung Boei
\s2 Thou Art My Rock
\sp Doh is G
\q1 
\v 1 Ka lung nu puei ni aw ka khang kung boei,
\q1 Nang kan hlip ying nah ka ying lah eh,
\q1 Nang ka lung nu puei ka kuep kolnah ni,
\q1 Na mah dong a tah ka om loh mong.
\q2 \qt Ka lung nu ni ka khang kung boeipa nang\qt*
\q2 \qt Nang ka paya neh hoi haeng kung ni, \qt*
\q2 \qt Nang ngaiuep nah neh ka khang kung boei ni \qt*
\q2 \qt na ka uep na neh na kol na ni. \qt*
\q1 
\v 2 Tholh nah neh rhainah loh ha yoei vaengah
\q1 Nang ni ka ka lung nu la na om,
\q1 Ko thae vaeng ah khaw lung nu la na o,
\q1 Nang na om tih ka la kueng mah pawh
\q1 
\v 3 Cuek halh loh tul noi vaeng ah lung nu ni,
\q1 Na mah tah kai ham paya then ni,
\q1 Ka mueihla he khaw na mah ni ka paek
\q1 uep om la om ham kai om sak lah.
\c 472
\s1 A Cim Mueihla Vahu Kodo
\s2 Holy Spirit, Gently Dove
\sp Doh is
\q1 
\v 1 A Cim Muei hla va hu ko do,
\q1 ha lo koep lah kan ngai hlang
\q1 Caih sak koep lah saw hlang ping tha hnoeng rhoek
\q1 Mol voel khum boeh ha mael koep dae.
\q2 \qt Aw kan ngai tangkik mueihla kodo\qt*
\q2 \qt nang mueh a tah hlang boeih longpuei a hmang, \qt*
\q2 \qt Mawt koep lah saw aw Thui pa aisi\qt*
\q2 \qt Zion omngaih longpuei cim ah.\qt*
\q1 
\v 2 Hna tun boeipa na tlan rhoek loh
\q1 Dung yan long puei boeih a hmang,
\q1 Lai tu dawn rhoek long he mawt thai tlaih pawh,
\q1 Me tla ka ti la eh boeipa
\q1 
\v 3 A Cim Muei hla na om a tah,
\q1 Dik lai ko thae boeih na hloep,
\q1 Tholh hli puei neh rhainah rhal len cakhaw,
\q1 Na ming koeh neh ka rhaeng la eh.
\q1 
\v 4 Jesuh ko do ha rhum laeh saw
\q1 Ko thae hlang la na ueh nah,
\q1 Ming sak koep bal lah na hling lu muek te,
\q1 Na la kueng nah kopoekrhai neh.
\c 473
\s1 Hosannah Ti Yoeyah Uh
\s2 Shout Hosanna
\sp Doh is G
\q1 
\v 1 Hosanna ti yoeyah uh, hale lui jah Amen
\q1 BoeiJesuh Khrih tah thang coeng Bethle hem kho ah,
\q1 A ol ka thoeng lung nah ol Paeng tom hlang a hoeih sak,
\q1 omngaih la pang uh sih, hosanna ti la,
\q2 \qt Aw Bet hle hem tlang dong ah \qt*
\q2 \qt dung yan kho tah ha thai coeng boeih boeih thui u lah. \qt*
\q2 \qt U long khaw te hing nah kho thaih a ka tangnah tah, \qt*
\q2 \qt kothae rhah patang nah khang tlaih voel mah pawh. \qt*
\q1 
\v 2 Kopoek rhai boeilen tang kik Rhoep nah ka boeipa te,
\q1 A lung nah tui a long sak di lai paeng pum ah.
\q1 Tholh kho yin khui lam ka loh mamih loeih na ham ni
\q1 Lung na ram kah boei ni boeipa Jesuh ke.
\q1 
\v 3 A pa olkhueh na ha thoeng mamih ham sa ding nah,
\q1 A lung nah tui loh coih pawk Kavari tlang ah
\q1 Kopoek rhai nah thui lek pawh lai hman hlang boeih long khaw
\q1 A lung nah ram then la te m'mawt u pawn ni.
\c 474
\s1 Yinthuem Kothae Zion Vong Voel Benah
\s2 Beyond the Gloomy
\sp Doh is D
\q1 
\v 1 Yinthuem kothae Zion vong voel ben ah,
\q1 Ka boeipa loh thisen a long sak,
\q1 Te tlamaih la kothae mueiyal khui ah
\q1 Ka boeipa lakueng la a ko sak.
\q2 \qt Aw nang mih Je ru sa lem rhoek aw,\qt*
\q2 \qt A rhen nah na dang te ming uh lah, \qt*
\q2 \qt Tlohnat soep rhaep boeih han hoeih sak uh te\qt*
\q2 \qt A ko thae nah hilh uh boel mai saw.\qt*
\q1 
\v 2 Jerusalem kah voel hmuen ben ah ke,
\q1 Tonghma a duek noek moe nih a ti,
\q1 Tedae dan ka Kalvari tlang ben ke
\q1 Hlangping lak li ka boeipa ka hm uh.
\q1 
\v 3 Dan lah ke Kalvari a pha pawn ni,
\q1 Aw metlam nim ka ti na lah ve,
\q1 Aw ka boeipa na mael tlaih mah pawt nim
\q1 Na hmuen ham tah Kalvari tlang ni.
\q1 
\v 4 Kan hnilh tlaih mahpawh ne ka boei Jesuh,
\q1 Kalvari ka mang thong tak mah pawh,
\q1 Kai hamla na ueh nah ka lung buei ah,
\q1 Ka duek due ka poek yoe yah ngai ni.
\c 475
\s1 He Diklai Paeng Tom Ah
\s2 Joy Jesus is born
\sp Doh is G
\q1 
\v 1 He diklai paeng tom ah boei muep ha thang coeng dae,
\q1 Te ca khaw Khrih bang la boei he tah thang vai pawh,
\q1 Vaan boei ca pa thang coeng boei lu muek muek sak ham,
\q1 Vaan hlang boeih boeih long khaw omngaih puei uh van lah.
\q2 \qt omngaih sih uem uh sih van boei ca pa thang coeng,\qt*
\q2 \qt A cun nah uem na laa he lai ah khawk thang saeh\qt*
\q2 \qt Vaan boei capa ha thang boei lu muek muek sak ham, \qt*
\q2 \qt van hlang rhoek boei long khaw omngaih puei uh van sih.\qt*
\q1 
\v 2 Vaan hlang toeklek na loh thangthen nah laa a sak,
\q1 A ol then thang khawk ol tu dawn rhoek loh a yaak,
\q1 Boei Khrih a thangnah te cim ca la a thui pah,
\q1 A tu rhoek a caeh tak tih Boei Khrih a bawk uh.
\q1 
\v 3 Kholo hlang cueih rhoek loh bo tui pom doe ha lo,
\q1 Vaan sang ai si vangnah loh hmai ben la a mawt,
\q1 A ma nu Me ri loh a pom yong dik a hmuh,
\q1 A kutdoe bom a ong tih boei Khrih a bawk uh.
\q1 
\v 4 Jesuh ti hnin kaimih lung buei vai to im ah,
\q1 A thai la ha thang lah dung yang ka boei la om,
\q1 Kai mih kut he Me ri kut la coeng sak van lah,
\q1 Dungyan om ngai ne la ka tha hlu uh pawn ni.
\c 476
\s1 Kai Hlang Tholh Ham Khangkung Boei Loh
\s2 Remember Me
\sp Doh is F
\q1 
\v 1 Kai hlang tholh ham khangkung boei loh thi sen te a long sak,
\q1 Kai bang hlang tholh rhoek boeih hamla a lu te a voeih coeng.
\q2 \qt Ka khang kung boei na mah loh m'bom,\qt*
\q2 \qt uep om la bang ka ngaih, \qt*
\q2 \qt Vaan ngolhmuen ah na om vaeng ah \qt*
\q2 \qt boeipa kai he m'poek van.\qt*
\q1 
\v 2 Kai kah tholh sai na dong mai ah thing lam dong ah ko pang,
\q1 A lungvatnah khomap tangkik ko poek loh pha thai pawh.
\q1 
\v 3 Kho mik long khaw khup ah yin tih boeilen nah khoep a dah,
\q1 Sai kung tha om hlang tholh ham thing lam ah a duek vaeng ah.
\q1 
\v 4 Kai van ka lu ka kun van ni, thinglam a tueng vaengah,
\q1 Om ngaih uet ah ka baeng a he mikphi tui ka oi khuep,
\q1 
\v 5 A pa tang nah ka thung thai pawh, lung nah lai la ka ba,
\q1 Aw ka boeipa ka pum he namah taengah kan paek coeng.
\c 477
\s1 Honthen Hmuh Uh Bang He U Long Khaw
\s2 Ramoth
\sp Doh is D
\q1 
\v 1 Hno then hmuh uh bang he
\q1 u long khaw hmu thai pawh.
\q1 Pa ram kah hno then ni,
\q1 Dik lai long khaw hmu pawh.
\q1 U ca long khaw paekboe thai pawh,
\q1 Pa kah thin tlohnah khui lamkah.
\q1 
\v 2 A sang nah toeklek pawh,
\q1 a lungnah thui lek pawh,
\q1 A lungnah then koek mhmuh
\q1 A phu toek lek na pawh,
\q1 Nang mih se raph hlang cim rhoek aw,
\q1 A boeilennah thui mah pawt nim.
\q1 
\v 3 Dik lai loh khum tom coeng,
\q1 A ko ngaihnah boeih neh,
\q1 A saithainah boeih neh,
\q1 A boeia mang boeih khaw,
\q1 Dik lai rhaipai long ta rhaem thai
\q1 Ka boeipa bueng ni then ka ti.
\q1 
\v 4 Dik lai khueh tawn boeih neh
\q1 a boei a len boeih khaw,
\q1 A muei then na boeih neh,
\q1 Mik hmuh thai boei lak ah,
\q1 Ka boeipa ni a ka then koek
\q1 Hling lu muek te muek sak cakhaw.
\c 478
\s1 Ol Then Ka Thui Lek Thai Mueh Tah
\s2 Sing the Love of Jesuh
\sp Doh is A
\q1 
\v 1 Ol then ka thui lek thai mueh tah,
\q1 Kal va ri tlang ol thang ni,
\q1 Me tlam nim Pathen ca pa khueh duen
\q1 Kai hlang tholh hamla ha duek.
\q1 Kal va ri tlang Kal va ri tlang,
\q1 ka poek nah loh pha thai pawh.
\q1 Kalva ri tlang kalvari tlang
\q1 Ka poek nah loh pha thai pawh.
\q1 
\v 2 Nang mih vaandong hlang cim rhoek neh,
\q1 Seraphim boeilen rhoek aw,
\q1 Vuen hlaem boeipa bi bi rhoek neh,
\q1 A kongaih a ka sai rhoek.
\q1 Kalvari tlang Kalva ri tlang
\q1 ol thang na thui mah nim
\q1 Kalva ri tlang kal va ri tlang
\q1 Olthang nan thui mah pawt nim.
\q1 
\v 3 Aw ka mueihla te tlang a te,
\q1 Khoyin kho thaih pong pa lah,
\q1 Ka boeipa thing lam dong ka te,
\q1 A hing la na hmuh ngai ni.
\q1 Kalvari tlang Kalvari tlang
\q1 olthangthen te han thui lah,
\q1 Kal va ri tlang kalva ri tlang
\q1 olthangthen te han thui lah.
\q1 
\v 4 Cing neh doem khocuk kho tlak boeih,
\q1 A kho kung ah ha kuep saeh,
\q1 Kui rhang boei rhaeng a yit a len,
\q1 A ming koeh nah laa sa saeh.
\q1 Kal va ri ah Kal va ri ah
\q1 ma mih hamla ha duek tih
\q1 Kalvari ah kalva ri ah
\q1 ma mih ham a duek dong ah.
\c 479
\s1 Dan Lah Muei Tim ah Ha Rhum
\s2 Lo He Come
\sp Doh is Bb
\q1 
\v 1 Dan lah muei lak ah ha rhum thuk li,
\q1 hlang tholh ham a duek phoei ah,
\q1 Hlang cim toeklekna loh ham bong uh,
\q1 A taeng ah boeilennah neh,
\q1 HalleluiJah Haleluijah
\q1 Hal leluijah ol caek hamla ha rhum coeng.
\q1 
\v 2 Hlang tom boeih loh a hmuh uh ngai ni,
\q1 Boeilen him bai a bai te,
\q1 Bang pawt mai ah a ka yoi kung neh,
\q1 Thing ah a ka tai rhoek loh.
\q1 Kothae hlang la Ko thae hlang la
\q1 Kothae hlang la Boei khrih na a hmuh u ni
\q1 
\v 3 Thang pa olthang yaak tue vaengah tah,
\q1 vaan neh lai boeih hma pawn ni,
\q1 Amah aka khueh hlang rhoek boeih loh,
\q1 Khuenah ol te a yaak ni, Ol caeknah ah,
\q1 Ol caek na ah, A loela halo a ti na uh pawn ni.
\q1 
\v 3 Khangnah ngai uep uh tang kik hlang te,
\q1 So lah ta hae ah tueng coeng,
\q1 Hlang cim rhoek hlang kah a hnawt rhoek te,
\q1 Pa then ah a doe uh ni,
\q1 Ha le lui jah Ha le lui jah,
\q1 Ha le lui jah dan lah ta hae ah ha tueng.
\c 480
\s1 Jesuh Loh Lai a Tloek
\s2 Jesus Enthrone Now
\sp Don is Eb
\q1 
\v 1 Jesuh loh laiatloek
\q1 vaan dong ngol hmuen a ke,
\q1 A lu ah boei lu muek neh
\q1 Hlang cim rhoek loh a bawk uh.
\q2 \qt Boeilen neh khangca rhoek\qt*
\q2 \qt a taengah kun tun uh, \qt*
\q2 \qt A voel a tah mamih n'tun van ni. \qt*
\q2 \qt A voel ah A voel ah\qt*
\q2 \qt A voel ah ma mih khaw n'tun van ni. \qt*
\q1 
\v 2 Khosae then ah pai uh,
\q1 toek lek pawh hlang cim rhoek
\q1 Boeilen conghol rhip a pom tih
\q1 thangthen laa a sak uh.
\q1 
\v 3 Tu ca ming a koeh uh,
\q1 diklai ham ka duek ke
\q1 Thii sen phu tlo te a hawk tih
\q1 lumuek rhip a muei uh.
\q1 
\v 4 Cim Mueihla rhen nah neh,
\q1 omngaihnah te nan paek,
\q1 Hlang cim rhoek neh hmai om ham la
\q1 Vaan dong la a caeh puei.
\c 481
\s1 A Cim Mueihla Han Tueih Lah Saw
\s2 Sent Thy Holy Spirit
\sp Doh is F
\q1 
\v 1 A CimMuei hla han tueih lah saw,
\q1 Boeipa Jesuh ming neh,
\q1 Kaimih lung buei ah ha om lah,
\q1 A lennah hmai bang la.
\q1 
\v 2 Pentikos hnin kah ha lo vaeng
\q1 ma nu ca boeih a bom,
\q1 Ti tah tholh thun bang la a ming,
\q1 Hlang boeih a ko puk uh.
\q1 
\v 3 Te tlam te bi thai nah van ham
\q1 Mueihla te kan bih uh,
\q1 Hmaih n'om puei lamtah n'cang puei saeh,
\q1 Vaan dong ka pha duela.
\q1 
\v 4 Hno pai tloe cungkuem hmu cakhaw,
\q1 He ni ka tuek rhoe coeng,
\q1 Tholh ming na ham bom thai kung tah,
\q1 Muei hla bueng ni ka then.
\c 482
\s1 He Khodaeng Ingnah Tlang Voel ah
\s2 O'er The Gloomy Hill
\sp Doh is Eb
\q1 
\v 1 He khodaeng ming nah tlang voel ah
\q1 ka mueihla cet lam duem lah.
\q1 Pathen olkhueh na te tueng coeng
\q1 a rhen na kho hnin om then.
\q2 \qt Vaan Jubilee Vaan Jubilee\qt*
\q2 \qt Kho hnin om then ha thai coeng\qt*
\q2 \qt Khohnin om then ha thai coeng, \qt*
\q2 \qt Vaan Jubi li van Ju bi li\qt*
\q2 \qt Khohnin omthen ha pai coeng. \qt*
\q1 
\v 2 Nam com nam ci hlang tom boeih neh
\q1 a yit a len hlang boeih loh,
\q1 Kalvari kah Pathen thangpomnah
\q1 tahae ah boeih hmu saeh.
\q1 
\v 3 Khoyin khui kah hlang boeih so ah
\q1 gospel hmai vang boeih tueng saeh,
\q1 Khothoeng lam kha kho tlak due la
\q1 kho yin ram loh kho thai saeh.
\q1 
\v 4 Kho hnin omthen ha pai pawn saeh
\q1 khoyin loh kho thai pawn saeh.
\q1 A yoeyah gospel olthang loh
\q1 a bawt due na ming koeh saeh.
\c 483
\s1 Pathen Rhang Dong Cim Koek ah Tah
\sp Doh is Bb
\q1 
\v 1 Pa then rhang cim koek dong a tah,
\q1 duek nah ca rhoek duem uh ni.
\q1 Kho bae rham bae a ti uh ni,
\q1 Hell hmai khui lam kah loeih nah.
\q1 Pa then koeh nah Pa then koeh nah,
\q1 Vaan ah tah bawt tkaih mahpawh.
\q1 vaan a tah bawt tlaih mah pawh
\q1 vaan a tah bawt tlaih mah pawh.
\q1 
\v 2 Tholh lak li kah a tlan dongah,
\q1 Khangkung boeipa Jesuh loh.
\q1 Dung yan hmuen then a pha vaeng ah,
\q1 Laa sak neh a koeh uh ni.
\q1 Tingtoeng tum rhoek Tingtoeng tum rhoek,
\q1 Vaan ah tah bawt tlaih mahpawh.
\q1 Vaan a tah bawt tlaih mah pawh
\q1 vaan a tah bawt tlaih mah pawh.
\q1 
\v 3 Hlang hing lungbuei ah kun noek pawh.
\q1 Mik hmuh pawh hna yaak noek pawh,
\q1 Boeipa loh a lung nah rhoek ham
\q1 A hmoel te a pang u ni.
\q1 Hingnah omthen Hingnah omthen,
\q1 Kumhal om then ta aep ni.
\q1 kum hal omthen ta aep ni
\q1 kum hal om then a aep ni.
\q1 
\v 4 Pa then hmai ah bai bok bai tih,
\q1 vuen hlaem ah tun u pawn ni,
\q1 Buhpong tui halh ming voel mueh lah
\q1 Om thennah boeih neh soep ni.
\q1 khodaeng pa tang Kho daeng pa tang
\q1 Dung yan ming tlaih voel mahpawh.
\q1 dungyan ming tlaih voel mahpawh
\q1 dungyan ming tlaih voel mahpawh.
\q1 
\v 5 Je ru sa lem thai om then ah,
\q1 duek neh tloh lungnat la kueng,
\q1 Ngai hmang kho daeng ming tlaih mueh loh
\q1 Dan ngaih ngak uh tlaih mah pawh.
\q1 Boeipa lungnah Boeipa lungnah
\q1 Toeng mueh la a koeh uh ni.
\q1 toeng mueh la a koeh uh ni
\q1 toeng mueh la a koeh uh ni.
\c 484
\s1 Kho Lakah Khaw Nang Na Sae Ngai
\s2 Fairer than the Morning
\q1 
\v 1 Kho lak ah khaw nang na sae ngai,
\q1 Aw ka khang kung boeipa ni
\q1 Na mah kah thin tloh nah dong ah
\q1 Ka mueihla omngaih tang kik.
\q2 \qt Kho lak ah khaw nang na sae ngai,\qt*
\q2 \qt Na sae ngai khaw lak ah na sae ngai. \qt*
\q2 \qt na vaan ram om then hlang a tah\qt*
\q2 \qt kho yin na te om tlaih pawh. \qt*
\q1 
\v 2 Na omngaihnah neh nan thoeih cam,
\q1 Na boei na len na boeih neh,
\q1 Na uk na ram boeih boeih he khaw
\q1 dung yan due la nang ka ni.
\q1 
\v 3 Na rhen nah a ka len koek te,
\q1 Nan sitloh na lawng baetawt,
\q1 Na ram lung nah a ka kap te
\q1 Kai ham oepsoeh la na sai.
\q1 
\v 4 Mincang kho long tah ha sae tih,
\q1 Ka hingnah a bawt vaeng ah,
\q1 Vaan hlang toek lek toek na mueh neh
\q1 dungyan laa ka sak pawn ni.
\c 485
\s1 Boei Jesuh Thaom Dong Hangdang Uh
\sp Doh is G
\q1 
\v 1 Boei Jesuh thaom dong hangdang uh,
\q1 A mah loh m'bom ni m'bom yoe yah ni,
\q1 A lungnah bawt pawh na tangna tah,
\q1 Om ngaih laa n'sak sak ni.
\q2 \qt A tha om neh a lung nah uep nah\qt*
\q2 \qt a tha om neh a lung nah uep nah\qt*
\q2 \qt A tha om neh a lung nah uep nah\qt*
\q2 \qt Tlang kung boei ke na hmuh ni. \qt*
\q1 
\v 2 Boei Jesuh tha om dong hang dang uh,
\q1 Long puei a vang sak a vang sak ni,
\q1 A mawtnah ah omngaih la cet lah,
\q1 A ol ding te ngai lah.
\q1 
\v 3 Boei Jesuh tha om dong hang dang uh,
\q1 Na ngai hmang nah pae a mah te pae,
\q1 Na hno phueih loh thin rhih mai ca khaw
\q1 Boeipa taeng ah thang thui.
\q1 
\v 4 Boei Jesuh tha om dong hang dang uh,
\q1 Na soep rhaep boeih pae soep rhaep boeih pae,
\q1 Lungnah neh lung vatnah loh bae tawt,
\q1 Amah loh n'hno mah pawh.
\c 486
\s1 Omngaih La Thangthen Sak Uh Sih
\sp Doh is G
\q1 
\v 1 Om ngaih la thangthen uh lah sih
\q1 rhoepnah boeipa ka thang he,
\q1 A boei ngol khoel neh a hlang cim
\q1 boei lu muek te han dul tih,
\q1 ma mih tholh ah a ka pam rhoek
\q1 ham khang nah long puei a ong
\q1 koeh uh lah hlang com hlang ci loh,
\q1 boeipa te tah koeh uh lah.
\q2 \qt A koeh nah duem tlaih mah pawh,\qt*
\q2 \qt Diklai bawt tue a pha due, \qt*
\q2 \qt Hnin bal kum bal a thangthen nah\qt*
\q2 \qt pung ta aep ni dung yan la, \qt*
\q2 \qt Dik lai neh vaan a bawt a khaw \qt*
\q2 \qt vaan hlang rhoek neh n'koeh pawn ni. \qt*
