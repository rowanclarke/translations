\v 4  \w So|strong="H1961"\w* \w he|strong="H3117"\w* \w had|strong="H1961"\w* \w them|strong="H6440"\w* \w stay|strong="H3427"\w* \w with|strong="H5973"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* \w Moab|strong="H4124"\w*; \w they|strong="H3117"\w* \w stayed|strong="H3427"\w* \w with|strong="H5973"\w* \w him|strong="H6440"\w* \w the|strong="H3605"\w* \w whole|strong="H3605"\w* \w time|strong="H3117"\w* \w that|strong="H3605"\w* \w David|strong="H1732"\w* \w was|strong="H1961"\w* \w in|strong="H3427"\w* \w the|strong="H3605"\w* \w stronghold|strong="H4686"\w*.  
