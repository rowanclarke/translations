\id NAM Biblica® Open Lingala Contemporary Bible 2020
\h Naumi
\toc1 Naumi
\toc2 Naumi
\toc3 Na
\mt1 Naumi
\c 1
\s1 Kanda mpe bolamu ya Yawe
\p 
\v 1 Lisakoli na tina na engumba Ninive.
\p Buku ya emoniseli ya Naumi, moto ya engumba Elikoshi.
\q1 
\v 2 Yawe azali Nzambe oyo atonda na zuwa,
\q2 oyo azongisaka mabe na mabe.
\q1 Yawe azongisaka mabe na mabe
\q2 mpe atombokaka makasi.
\q1 Yawe azongisaka mabe na mabe
\q2 epai ya banguna na Ye,
\q2 akangelaka bayini na Ye kanda makasi.
\q1 
\v 3 Yawe asilikaka noki te,
\q2 mpe nguya na Ye ezali monene.
\q1 Yawe atikaka te moto oyo asali mabe
\q2 lokola nde asali na ye mabe te,
\q1 kasi apesaka etumbu na moto oyo asali mabe.
\q2 Yawe apasolaka nzela na Ye kati na ekumbaki\f + \fr 1.3 \ft Ekumbaki ezali mopepe ya makasi oyo ekumbaka biloko nyonso tango elekaka.\f*,
\q2 kati na mopepe makasi.
\q1 
\v 4 Agangelaka ebale monene
\q2 mpe akawusaka yango,
\q1 akawusaka bibale nyonso.
\q2 Etuka ya Bashani mpe ya Karimeli
\q1 esili nyonso kokawuka,
\q2 mpe matiti nyonso ya Libani esili kokawuka.
\q1 
\v 5 Bangomba milayi eninganaka liboso na Ye,
\q2 mpe bangomba mikuse epanzanaka.
\q1 Mabele, mokili mpe bavandi na yango
\q2 balengaka liboso na Ye.
\q1 
\v 6 Nani akoki solo kotelema liboso na Ye soki asiliki ?
\q2 Nani akoki solo kobika soki kanda na Ye epeli ?
\q1 Mpo ete kanda na Ye epanzanaka lokola moto,
\q2 bongo mabanga ebukanaka liboso na Ye.
\b
\q1 
\v 7 Yawe azali malamu,
\q2 azali ebombamelo ya solo na tango ya pasi
\q2 mpe abatelaka bato nyonso oyo batiaka elikya na Ye.
\q1 
\v 8 Akobebisa engumba na Ye nyonso na mpela
\q2 mpe akobengana banguna na Ye kino kati na molili.
\b
\q1 
\v 9 Likita ya ndenge nini bakoki kosalela Yawe ?
\q1 Azali Ye oyo asilisaka makambo nyonso ;
\q2 pasi ekoya lisusu te.
\q1 
\v 10 Bakokoma lokola bato oyo bazali kati na banzube,
\q2 lokola bato oyo balangwe masanga ya vino ;
\q2 bakozikisama nye lokola matiti ya kokawuka.
\q1 
\v 11 Ezali kati na yo Ninive nde moto
\q2 oyo azali na mabongisi mabe
\q1 mpo na kotelemela Yawe
\q2 mpe azali na batoli ya mabe abimi.
\q1 
\v 12 Tala liloba oyo Yawe alobi :
\q2 « Ata banguna na bino bazali ebele mpe makasi,
\q1 bakosila kokufa mpe kolimwa.
\q2 Oh mokili ya Yuda, soki nasambwisaki yo,
\q2 nakosala yango lisusu te.
\q1 
\v 13 Nakobuka ekangiseli na bango,
\q2 oyo ezali na kingo na yo
\q2 mpe nakolongola yo na minyololo. »
\b
\q1 
\v 14 Kasi Yawe azwi mokano oyo mpo na yo :
\q2 « Okotikala kozwa lisusu bakitani te
\q1 oyo bakobatela kombo na yo na bokonzi.
\q2 Nakolongola kati na tempelo na yo
\q1 banzambe na yo ya bikeko mpe bikeko nyonso
\q2 oyo basala na bibende balekisa na moto.
\q1 Nazali kobongisela yo kunda,
\q2 pamba te ozali na yo pamba. »
\b
\c 2
\q1 
\v 1 Botala kuna na bangomba
\q2 makolo ya momemi sango malamu :
\q1 amemi sango ya kimia !
\q2 Oh mokili ya Yuda, sepela na bafeti na yo
\q1 mpe kokisa ndayi na yo ;
\q2 pamba te wuta sik’oyo,
\q1 moto mabe moko te akokota lisusu epai na yo ;
\q2 pamba te bango nyonso bakobebisama nye.
\q1 
\v 2 Tala, mobebisi azali koya kosala yo mabe !
\q2 Batela malamu bandako na yo batonga makasi,
\q1 kengela nzela na yo,
\q2 bongama mpo na bitumba
\q2 mpe sangisa bato na yo.
\q1 
\v 3 Yawe akozongisa lisusu nkembo
\q2 ya Jakobi mpe ya Isalaele,
\q1 atako babebisaki mpe bapanzaki mokili na bango,
\q2 mpe atako babebisaki bilanga na bango ya vino.
\b
\q1 
\v 4 Banguba mpe bilamba ya basoda na bango
\q2 ezali ya langi ya motane ;
\q1 bibende ya bashar na bango ezali kongenga
\q2 na mokolo oyo babongisi mpo na bitumba,
\q2 mpe makonga basala na nzete ekomi kotambola bipai na bipai.
\q1 
\v 5 Bashar ezali kokota na elulu na nzela,
\q2 ezali kokende mpe kozonga
\q1 na bisika oyo bato ebele bakutanaka ;
\q2 ezali komonana lokola koni
\q1 oyo ezali kopela moto,
\q2 ezali kotambola na bangambo nyonso
\q2 lokola mikalikali.
\b
\q1 
\v 6 Abengi basoda na ye nyonso ya mpiko.
\q2 nzokande, na nzela na bango, bazali kotepatepa,
\q2 bazali kokende na lombangu pene ya mir.
\q1 
\v 7 Bikuke ya ebale efungwami\f + \fr 2.7 \ft Bikuke ya ebale efungwami elingi koloba ete engumba ekobebisama na mpela.\f*,
\q2 mpe ndako na ye ya bokonzi ebukani.
\q1 
\v 8 Ekatami ete engumba wana ekokende na bowumbu
\q2 mpe bakomema yango mosika penza ;
\q1 basali na yango ya basi bakolela lokola bibenga
\q2 mpe bakomibeta batolo likolo ya pasi.
\q1 
\v 9 Na kala, engumba Ninive ezalaki
\q2 lokola liziba ya mayi.
\q1 Kasi tala yango lelo oyo :
\q2 etoboki mpe ekomi kobimisa mayi !
\q1 Bazali kobelela : « Botelema ! Botelema ! »
\q2 Kasi ata moto moko te azongi lisusu kuna.
\q1 
\v 10 Bobotola wolo mpe palata na yango na makasi,
\q2 pamba te bomengo na yango ezali penza mingi koleka
\q2 mpe etonda na biloko ya motuya.
\b
\q1 
\v 11 Bakoteli yango, bapanzi yango,
\q2 babotoli na makasi biloko na yango ya talo !
\q1 Mitema ebukani, mabolongo ekomi kolenga,
\q2 mpe banzoto etondi na somo.
\q1 
\v 12 Wapi sik’oyo libulu epai wapi bankosi
\q2 ezalaki kobokola bana na yango ?
\q1 Wapi sik’oyo libulu epai wapi nkosi ya mwasi
\q2 elongo na bana na yango
\q2 ezalaki kotambola na somo ata moke te ?
\q1 
\v 13 Nkosi ebomi banyama ebele
\q2 mpo ete epesa yango lokola bilei
\q1 epai ya bana na yango,
\q2 ekangi nyama ya kolia mpo na mwasi na yango,
\q1 bongo etondisi libulu na yango na banyama
\q2 oyo ebomi mpe na misuni.
\b
\q1 
\v 14 « Nakotombokela yo, »
\q2 elobi Yawe, Mokonzi ya mampinga ;
\q1 « nakozikisa bashar na yo na moto,
\q2 mpe mopanga ekoboma bana ya nkosi na yo.
\q1 Nakobotola yo misuni nyonso awa na se ;
\q2 boye mongongo ya batindami na yo
\q2 ekotikala koyokana lisusu te. »
\c 3
\s1 Engumba ya babomi ebebisami
\q1 
\v 1 Mawa na engumba oyo mosala na yango
\q2 kosopa makila ya bato,
\q1 engumba oyo etonda
\q2 na makambo ya lokuta mpe na moyibi,
\q2 engumba oyo ezangaka te koboma bato !
\q1 
\v 2 Tango nyonso, kaka makelele ya bafimbu,
\q2 makelele ya bapine :
\q1 bampunda ezali kopumbwa,
\q2 mpe bashar ezali koningana.
\q1 
\v 3 Basoda oyo batambolaka likolo ya bampunda
\q2 bazali kotambola-tambola,
\q1 mipanga ezali kongenga,
\q2 makonga ezali koleka-leka lokola mikalikali !
\q1 Bato bazali kozoka, kokufa ebele penza !
\q2 Bongo bibembe elali-lali bisika nyonso,
\q1 mpe makolo ya bato ekomi kotuta bibembe
\q2 tango bazali kotambola.
\b
\q1 
\v 4 Makambo oyo nyonso esalemi
\q2 likolo ya makambo ya nkele ya engumba
\q1 oyo etonda na kindumba,
\q2 engumba ya kitoko makasi
\q1 kasi etonda na misala ya soloka,
\q2 engumba oyo epengwisaka bikolo
\q1 na nzela ya kindumba na yango
\q2 mpe epengwisaka bato
\q2 na nzela ya misala na yango ya soloka.
\b
\q1 
\v 5 « Natombokeli yo, »
\q2 elobi Yawe, Mokonzi ya mampinga ;
\q1 « nakotombola yo elamba kino na elongi,
\q2 nakolakisa bolumbu na yo
\q1 na miso ya bikolo mosusu
\q2 mpe nakoyokisa yo soni
\q2 na miso ya bamboka nyonso.
\q1 
\v 6 Nakobwakela yo bosoto,
\q2 nakosambwisa yo
\q2 mpe nakokomisa yo eloko ya maseki.
\q1 
\v 7 Bato nyonso oyo bakomona yo
\q2 bakokima mpe bakoganga :
\q1 ‹ Engumba Ninive ebebisami boye !
\q2 Nani akoyokela yango mawa ? › »
\b
\q1 
\v 8 Boni, okanisi ete ozali kitoko
\q2 koleka engumba Tebesi
\q1 oyo ezalaka pembeni ya ebale Nili
\q2 mpe ezingelama na mayi,
\q1 bongo ebale ebatelaka yango
\q2 mpe mayi ezalaka lokola mir
\q2 oyo ebombaka yango ?
\q1 
\v 9 Makasi na yango ezalaki kowuta
\q2 na Kushi mpe na Ejipito ;
\q2 bato ya Puti mpe ya Libi bazalaki kosunga yango.
\q1 
\v 10 Nzokande, yango mpe ekweyaki,
\q2 mpe bamemaki bato na yango na bowumbu.
\q1 Bakataki-kataki na biteni
\q2 bana na bango na babalabala nyonso,
\q1 babetaki zeke mpo na kopona
\q2 bato na yango ya lokumu
\q1 mpo ete bamema bango na bowumbu,
\q2 mpe bakangaki bakambi na yango minyololo.
\q1 
\v 11 Yo mpe okokoma lokola moto
\q2 oyo alangwe masanga,
\q1 yo mpe okoluka ekimelo
\q2 mpo na kokima banguna na yo.
\b
\q1 
\v 12 Bandako na yo nyonso, oyo batonga makasi
\q2 ezali lokola banzete ya figi etonda
\q1 na bambuma ya liboso ekomela ;
\q2 soki kaka bameki koningisa yango,
\q2 bambuma ekweyaka kino na monoko ya moto ya lokoso.
\q1 
\v 13 Tala malamu mampinga na yo,
\q2 balemba lokola basi ;
\q1 bikuke ya mokili na yo ezali polele
\q2 liboso ya banguna na yo,
\q2 pamba te moto ezikisi bikangelo na yango.
\q1 
\v 14 Bino bato ya engumba oyo,
\q2 bomitokela libela mayi
\q1 mpo ete bakozingela bino ;
\q2 bolendisa libela bamir
\q1 oyo ebatelaka engumba na bino ;
\q2 bokamata mabele oyo batongelaka bandako,
\q1 bosangisa yango mpo ete ekoma potopoto,
\q2 bongo bobeta babiliki mpe botumba yango.
\q1 
\v 15 Kuna nde moto ekoya kozikisa yo,
\q2 mopanga ekoya koboma yo
\q1 mpe kosilisa yo lokola mabanki.
\q2 Tika ete bato na yo bakoma ebele lokola mabanki,
\q2 bakoma lisusu ebele makasi lokola mankoko.
\q1 
\v 16 Okomisi motango ya bato na yo ya mombongo
\q2 ebele koleka ata minzoto ya likolo,
\q1 kasi babebisi mokili nyonso
\q2 mpe bapumbwe na bango
\q2 ndenge kaka mankoko esalaka.
\q1 
\v 17 Bakengeli na yo bazali lokola mankoko,
\q2 bakonzi ya basoda na yo bazali
\q1 lokola maboke ya mabanki
\q2 oyo eyaka kovanda na bamir ya lopango
\q1 na tango ya malili ;
\q2 kasi soki kaka moyi ebimi, yango nyonso epanzani,
\q2 mpe moto moko te ayebaka esika yango ekendaka.
\b
\q1 
\v 18 Oh mokonzi ya Asiri,
\q2 bakambi na yo bazali kolala pongi,
\q1 basoda na yo ya mpiko balali pongi ya makasi,
\q2 mampinga na yo bapalangani na bangomba
\q2 mpe moto akosangisa bango azali komonana te.
\q1 
\v 19 Ezali ata na kisi moko te
\q2 oyo ekoki kobikisa pota na yo ;
\q1 pota na yo ezali monene makasi !
\q2 Moto nyonso oyo akoyoka sango
\q1 ya makambo oyo ekomeli yo
\q2 akobeta maboko mpo na kokweyisama na yo.
\q2 Pamba te nani oyo ozangaki kosala mabe ?
