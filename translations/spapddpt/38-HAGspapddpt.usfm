\v 3 Entonces \w vino|strong="H1961"\w* la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd* \w por|strong="H1697"\w* \w medio|strong="H3027"\w* del \w profeta|strong="H5030"\w* Hageo:  
\v 4 \wj ô¢\+w Es|strong="H2088"\+w* \+w tiempo|strong="H6256"\+w* para \+w que|strong="H2088"\+w* ustedes mismos vivan en \+w casas|strong="H1004"\+w* arregladas con paneles \+w de|strong="H6256"\+w* madera, mientras \+w esta|strong="H2088"\+w* \+w Casa|strong="H1004"\+w* \+w estûÀ|strong="H2088"\+w* desolada?\wj*   
\p
\v 5 \w Pues|strong="H6258"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes dice: \wj Consideren bien sus procedimientos: \wj*  
\v 6 \wj Siembran \+w mucho|strong="H7235"\+w* y recogen \+w poco|strong="H4592"\+w*. Comen y no se sacian. \+w Beben|strong="H8354"\+w*, y no quedan satisfechos. Se cubren, pero no se calientan, y el que gana salario, lo echa en bolsa rota.\wj*   
\p
\v 7 \nd \+w Yavûˋ|strong="H3068"\+w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes dice: \wj Mediten \+w sobre|strong="H5921"\+w* sus procedimientos.\wj*  
\v 8 \wj Suban \+w a|strong="H3068"\+w* la montaûÝa, bajen \+w madera|strong="H6086"\+w* y reedifiquen la \+w Casa|strong="H1004"\+w*. \+w Y|strong="H3068"\+w* Yo me complacerûˋ en ella y serûˋ glorificado,\wj* dice \nd \+w Yavûˋ|strong="H3068"\+w*\nd*.  
\v 9 \wj Buscan \+w mucho|strong="H7235"\+w* y hallan \+w poco|strong="H4592"\+w*. Encierran en \+w la|strong="H1931"\+w* \+w casa|strong="H1004"\+w*, pero \+w Yo|strong="H2009"\+w* \+w lo|strong="H1931"\+w* lanzo al viento. ô¢\+w Por|strong="H3282"\+w* \+w quûˋ|strong="H4100"\+w*?\wj* \nd \+w Yavûˋ|strong="H3068"\+w*\nd* de las huestes \w dice|strong="H5002"\w*: \wj \+w Porque|strong="H3282"\+w* \+w mi|strong="H2009"\+w* \+w Casa|strong="H1004"\+w* \+w estûÀ|strong="H1931"\+w* desolada y cada uno de ustedes \+w corre|strong="H7323"\+w* \+w a|strong="H3068"\+w* \+w su|strong="H1931"\+w* propia \+w casa|strong="H1004"\+w*.\wj*  
\v 10 \wj \+w Por|strong="H5921"\+w* \+w eso|strong="H3651"\+w*, \+w por|strong="H5921"\+w* causa \+w de|strong="H5921"\+w* ustedes, \+w el|strong="H5921"\+w* \+w cielo|strong="H8064"\+w* retiene \+w la|strong="H5921"\+w* lluvia, \+w y|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra su cosecha.\wj*  
\v 11 \wj \+w Llamûˋ|strong="H7121"\+w* una sequûÙa \+w sobre|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra, \+w las|strong="H5921"\+w* montaûÝas, \+w el|strong="H5921"\+w* \+w trigo|strong="H1715"\+w*, \+w el|strong="H5921"\+w* \+w mosto|strong="H8492"\+w*, \+w el|strong="H5921"\+w* \+w aceite|strong="H3323"\+w*, \+w todo|strong="H3605"\+w* \+w lo|strong="H5921"\+w* \+w que|strong="H5921"\+w* \+w produce|strong="H3318"\+w* \+w la|strong="H5921"\+w* tierra, \+w el|strong="H5921"\+w* hombre, \+w el|strong="H5921"\+w* ganado \+w y|strong="H5921"\+w* \+w todo|strong="H3605"\+w* \+w trabajo|strong="H3018"\+w* \+w de|strong="H5921"\+w* tus \+w manos|strong="H3709"\+w*.\wj*   
\p
\v 12 \w Zorobabel|strong="H2216"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Salatiel, \w Josuûˋ|strong="H3091"\w*, \w hijo|strong="H1121"\w* \w del|strong="H5921"\w* \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w* Josadac, \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w resto|strong="H7611"\w* \w del|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w obedecieron|strong="H8085"\w* \w la|strong="H5921"\w* \w voz|strong="H6963"\w* \w de|strong="H5921"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd* su \nd ò¥Elohim\nd* \w por|strong="H5921"\w* medio \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w del|strong="H5921"\w* \w profeta|strong="H5030"\w* Hageo, \w tal|strong="H1697"\w* \w como|strong="H5921"\w* \nd \+w Yavûˋ|strong="H3068"\+w*, ò¥Elohim\nd* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w les|strong="H5921"\w* \w mandû°|strong="H7971"\w*. \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* mostrû° reverencia \w a|strong="H3068"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd*.   
\p
\v 13 Entonces Hageo, \w enviado|strong="H4397"\w* \w de|strong="H5971"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd*, hablû° por mandato \w de|strong="H5971"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd* al \w pueblo|strong="H5971"\w*: \wj Yo estoy con ustedes, \wj*\w dice|strong="H5002"\w* \nd \+w Yavûˋ|strong="H3068"\+w*\nd*.   
