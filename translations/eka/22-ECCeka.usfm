\id ECC - Ekajuk Unicode New Testament
\h Eltibi
\toc3 Elti
\toc2 Eltibi
\toc1 Nwer nyi Eltibi
\mt1 Eltibi
\c 1
\s1 Nsol kpee ejumjum lohngem
\q1 
\v 1 Alum nya a, nya ntiingi etib, mmon a Devid no jolo ntul go Jeruselem, bungu no re:
\q1 
\v 2 <<Nsol kpee ejumjum lohngem!>>Ntiingitib wo bungu.
\q2 <<Jol egburu ejum lohngem ejumjum!>>
\q3 <<Nsol kpkee Ejumjum lohngem ejumjum lohngem.>>
\q1 
\v 3 Nsehng anyii ane kpo li go eboa ntum kpee,
\q2 nyi bo kp'limi go njini nyia?
\q1 
\v 4 Aying kpo ba, fere sehng asongo,
\q2 wo ndi tiki li go njinanjini.
\q1 
\v 5 Njul kpo lohng fere lahm,
\q2 fere foomo feere go edi ji á kpo lohng.
\q1 
\v 6 Nfeb kpo lim feere go ejang eboblum, fere sennge feere go ejang ebobkal;
\q2 kpo sennge ano ano, tiki jo feere toono elsehnge ene.
\q1 
\v 7 Ngba kpee kpo fab song yel go agburu aya,
\q2 wo agburu aya nehme tiki rur.
\q3 Go edi ji ngba kpo lohng ba, go wo kpo kpe feere tahm.
\q1 
\v 8 Nsol kpee ebkpen nne,
\q2 sehnge ana nne bahke ma bung.
\q3 Amahr kp'sebe re nyehn wo nsol elyehne lim, jol atung kp'sebe re wuk wo nsol elwuku lim.
\q1 
\v 9 Jio ji ma tohko jol, bahke kpe jol, ji bo ma tohko lim, bo bahke kpe lim;
\q2 ejumjum limm ji li ejum nfenfe go njini.
\q1 
\v 10 Ejum ajehng ajehng jia go ji nne bahke ma bung re,<<Nyehnene! A ejum nfenfe ji a?>>
\q2 Ebtohko jol a, mahne mahne; tohko jol a ngare enyahre kehm rehnge.
\q1 
\v 11 Nnene kpehme kpe buumu aying nya mahne mahne,
\q2 jol aying nya kp'bake ane nehm buumu, ane ba bahke jolo toono ngare nyio, nehm kpe jo buumu aying nyao.
\s1 Ngbere ejumjum lohngem
\q1 
\v 12 Me ntiingi etib, n kuumu etul go Jerusalem jo fili Isreel.
\q1 
\v 13 N yehke ntir enyame kak re me n kpili nsol, fere ko ngbere feede nsol kpee nyi ane kpo lim go njini.
\q2 A wo li egburu elsol ni Esowo ma rod si nnee!
\q1 
\v 14 Me n seenge nsol kpee nyi ane kpo lim go njini;
\q2 nsol nyio kpee ejumjum lohngem, nne kp'kame na toono elfeb.
\q1 
\v 15 Ejum ji ma galle, nne nehm ma tanne;
\q2 ji ki li a nehm ma fange kak nti.
\q1 
\v 16 M bungu tong elname re, <<Me m bel ngbere sehnge nne awohng awohng no ma tohko kuumu etul go Jerusalem me n kehm ba kuumu; ngbere a elkahne ma-m nahre gbalee.>>
\q1 
\v 17 Owo n kehm yehke ntir enyame kak re me n kpili bada ngbere, a esahl go elgboolo, wo n tob kpili re, jia fvfo, nne kp'beke na kam elfeb.
\q1 
\v 18 Tibre nne no kpi egburu ngebere kpo jol ndon ndon sehng;
\q2 ana elkahne kp'gbale, ano wo egbiingeltim tob li.
\c 2
\s1 Elfo alehke ejumjum lohngem
\q1 
\v 1 N kehm bungu tong elname re, <<Wuk-mo! M bahke koko elfo wuung-a eji n l'seb kahn ji kp'nobo.>> Wo jia fvfo n nyehne re ejumjum lohngem.
\q1 
\v 2 N kehm bungu re, <<Asol awolo esahl bi. Anv elfo alehke kpo ka nne jen?>>
\q1 
\v 3 N gare re me n ko amahm ka elname eyebatahng, fere jo lim agbolo nsol, wo ntir atahng enyame jo tiki soong-m a ngbere. N jo sebe re me n kahn ji nobo ka ane re bo jo lim go njini nyia abon afung ba nkpin ebo.
\q1 
\v 4 N kake esehk jo lim agburu ntum: N sii ntahk ka elname fere bahm ebgbe agrab
\q1 
\v 5 N bahme adi ebgbe, fere lim adi ekv areke nya m bahme nkohn a nti kpee nyi kpo kab akab.
\q1 
\v 6 N ramme abing nya alahb akuuru, nya bo jo ko alahb toomo abohko nti.
\q1 
\v 7 N gunu aju nya nlum a nya nkal, fere bel aju nyako nya bo jele bo go egame etahk. N tob bele nlong efong a nlong ebul a ejoro sehnge nne awohng awohng no gbo mbang kuumu etul go Jerusalem ka me.
\q1 
\v 8 N kpu asilva a agul luk ka elname, go atingi nsol nya atul a nya arohko ajahbe. M bele ayimase ba nlum a ba nkal, a aneb elkang gbalee, nsol nyo nyi kpo ka aneblum eyebatahng.
\q1 
\v 9 N sahb gb'gbal sehnge nne awohng awohng no tohko jol ntul go Jeusalem ka me, n kehm kuumu etul. Go nsol nyia kpee, ngbere enyame sa a name.
\q1 
\v 10 N tenem elname ejum ajehng ajehng ji koro amahr enyame;
\q2 N tenem eltim ename elfo anehng anehng.
\q3 Eltim ename jo geere kak ntum abo enyame kpee, jia ji jolo eltuuru eltum ename go agb'gbiingi enyame kpee.
\q1 
\v 11 Wo ga n l'fere seenge nsol kpee nyi abo enyame ma lim,
\q2 a nsol nyi m ma gbiingi elname bel,
\q3 ejum ajehng ajehng ejumjum lohngem, nne kp'beke kam elfeb; nsehng anyehng anyehng nne belem go elwo ni njul.
\s1 Ngbere a elgboolo ejumjum lohngem
\q1 
\v 12 Owo n kehm sennge fere yehke eltim ename kunu re me n gbo ntir bada ngbere, fvfo esahl a elgboolo.
\q2 Anv ejum ajii ji ntul no bahke ba kuumu etul toono atul bahko bahke ma kpe lim, sehnge ji bo ma toko lim?
\q1 
\v 13 N nyehne re ngbere nobo sehnge elgboolo, ana ellennge kp'nobo sehnge ejannge.
\q1 
\v 14 Aneb ngbere kpo bel amahr go ebo esi, wo egboolo nne kpo jen go ejannge;
\q2 wo n sebe kahn re elkohn ejum ajehng ji kpo gbo tub bo ane abal abal.
\q1 
\v 15 Owo n kehm bungu tong elname re, <<Ji kpo gbo tub egboolo nne bahke tob gbo tub-m fvfo.
\q2 Anv nsehng anyii N kpi no go egama ngbere?>>
\q3 N kehm tongo elname re <<Jia fvfo ejumjum lohngem.>>
\q1 
\v 16 Tibre nne a ngbere tob li ana egboolo nne, bo ane abal abal bo nehm ga buumu bo; afung ebsi r'rehng nya ane bahke yini bo.
\q2 Fvfo nnea ngbere bahke tob kpo ana egboolo nne.
\s1 Elgbiingi ejumjum lohngem
\q1 
\v 17 Ano wo elkpin tehn-m no, tibre eltum ni ane kpo lim go njini, jo ka-m eyameltim sehng. Nsehng nyi ngbere kpee ejumjum lohngem, nne kpe kame na toono elfeb.
\q1 
\v 18 N kpi etehn ka nsol kpee nyi m ma lim bum go njini a elgbiingi enahme go elwo ni njul, tibre m bahke tahme sa nne no bahk-m toono.
\q1 
\v 19 Anv nne awoo kp'kahne jo re á bahke jolo nnea ngbere afii egboolo nne? Tvtv o, ye wo nsehng nyi ntum enyame bahk-e woomo go elwo, nyi N nyennge ko elkahne ename kak eko lim go elwo ni njul. Jia fvfo ejumjum lohngem.
\q1 
\v 20 Ano wo, eko kehm-m eltane bada ntum kpee nyi m ma nyehn erem lim go njini.
\q1 
\v 21 Tibre nne li ma ko ngbere a elkahne go ebnere lim eltum, fvfo á ba fere yake nsol kpee nyi á kpi no bum nne nondiki, no kii nyehn erem lim eltum nio. Jia fvfo ejumjum lohngem, li egburu ebibisi.
\q1 
\v 22 Nsehng anyii ane kpo bel go ntum ebo nyi bo kpo nyehn erem lim fere jo biingi elbo go njini nyia?
\q1 
\v 23 Afung elkpin ebo kpee, bo kpo lim eltum ndon ndon a abiingi eltim; jol ngare atv, eltim ebo kpehme re ekv. Jia fvfo, ejumjum lohngem.
\q1 
\v 24 Ejumjum limm ji nne bahke ma lim sehnge re á jo li nsol, fere jo w'wo, fere bel elwohngo go eltum erem ebe. Jia fvfo, me N nyehn re Esowo bi kpo ka nne,
\q1 
\v 25 tibre tohko jol Esowo, nne awoo bahke ma li fere bel elyebe?
\q1 
\v 26 Esowo kpo ka nne no kp'nobo go ege esamahr ngbere a elkahne go eyebatahng, wo nne abiafem á kpo ka-e eltum ni li re á jo kpu afang bum, nya á bahke faake ka nne no kp'nobo go esamahr bi Esowo. Jia fvfo ejumjum lohngem, nne kp kahme na toono elfeb.
\c 3
\s1 Ejum ajehng ajehng kpi ngare ny'nye
\q1 
\v 1 Ejum ajehng ajehng kpi ngare ny'nye,
\q2 fvfo ejum ajehng ajehng ji kp'limi go njini kpi ngare;
\q1 
\v 2 kpi ngare nyi bo kpo jel nne, fvfo tob kpi ngare nyi nne kpo kpo,
\q2 ngare nyi nsol abahme, a ngare nyi elfohko nsol,
\q1 
\v 3 ngare nyi elwulu a ngare nyi enobayam,
\q2 ngare nyi etahk afake a ngare nyi elsehke,
\q1 
\v 4 ngare nyi eling alingi a ngare nyi asol awolo,
\q2 ngare nyi eljolo ndon ndon a ngare nyi ase abahne,
\q1 
\v 5 ngare nyi atal afare faade a ngare nyi elkpuku atal luk edi ajehng,
\q2 ngare nyi a bahke bingi nne a ngare nyi a bahke yaame go elbingi nio,
\q1 
\v 6 ngare nyi ejum asebe a ngare nyi ekpu ayini,
\q2 ngare nyi elbumu ejum a ngare nyi elroko ejum jio go,
\q1 
\v 7 ngare nyi nne bahke yare mbomo a ngare nyi á bahke jahme baade,
\q2 ngare nyi li re nne belle a ngare nyi li re nne bung,
\q1 
\v 8 ngare nyi li re nne jo kor-a a ngare nyi li re nne jo tehn-a,
\q2 ngare nyi ebta a ngare nyi elkoono.
\q1 
\v 9 Nsehng anyii abalimentum kpo bel go ebo eltum ni bo kpo nyehn erem jo lim?
\q1 
\v 10 Me n nyehn elsol ni Esowo ma si nne.
\q1 
\v 11 Esowo eblim ejum ajehng ajehng re nob go ege a ngare. Yebkak elkahne ni elkpin ni njinanjini go eltim ni nne, tvtv o, nnene nehm ma lohko kahn ji Esowo kp'limi kpee go mbomo rehng go ekahlsi.
\q1 
\v 12 Nkp'kahne re ejumjum go limmm ji nobo ka ane, sehnge re bo jo bel eyebatahng fere lim nnoobo ngare nyi bo li go elkpin.
\q1 
\v 13 Re nne jo li fere w'wo fere bel elwohngo go ntum ebo nyi bo kp'nyennge lim, tib jia ayare nya Esowo nya.
\q1 
\v 14 N kp'kahne re ejum ajehng ajehng ji Esowo limi no bahke jolo go njinanjini, jol nne nehm ma budu ejumjum o, afii yehke na. Esowo kpo lim ano eji ane l'jo fahl-e.
\q1 
\v 15 Ejum ajehng ajeng ji li no, ebtohko jol, ji bahke jolo ebtohko jol,
\q2 fvfo Esowo bahke limi ji ma tohko lim kpe lim.
\q1 
\v 16 N kpe nyehn ejum ajehng jehko go njini nyia ji li re:
\q2 Go edi elam alame, ab'bi li o, go edi ji fuumu re ane jo lim nsol songo songo, ab'bi li o.
\q1 
\v 17 N kehm bungu tong elname re, <<Esowo bahke lame etinginne a ebinne, bo ane abal abal,
\q2 tibre ngare bahke jolo ka eltum anehng anehng, ngare nyi bo bahke lame ejum ajehng ajehng ji nne limi no.>>
\q1 
\v 18 N tob bungu tong elname re, <<Ana ane, Esowo kpo wuungu bo, eji bo l'kahn re bo li ana enyam.>>
\q1 
\v 19 Etingitingi, ji li ka nne, tob li ano ka enyam; j'nehm ji kpi bo sik: Ji li re, ana nnyam bahke kpoko, ano wo nne kpo tob kpo. Bo kpee kpi elv elv anehng ni elkpin, nne kpimm na nsehng sehnge nnyam. Go ejum ajehng ajehng, ejumjum lohngem.
\q1 
\v 20 Bo kpee kpo feere tahm edi j'nehm; bo ko ebtohko lim nne a nnyam, ano wo bo bahke feere go ebtohko.
\q1 
\v 21 Nne awoo kp'kahne jo re etohko ji nne kpo mehl tahm go ero, fvfo jo re ji nnyam kpo badde yel go ndi?
\q1 
\v 22 Ano wo n nyehne no re ejumjum go limm ji kp'nobo ka nne, sehnge re a jo geere kak eltum ene tibre jio ji li etuureltum j'je. Tibre, anv, nne awoo bahke feere abo ba tib bo ji bahke jolo ngare nyi bo ma kpo fi?
\c 4
\s1 Eblum alimi, eltum alimi a ekubin
\q1 
\v 1 Owo n kehm kpe seenge fere nyehn eblum kpee ni ane kp'limi atem go njini:
\q2 N nyehne abonngo nya ane ba bo kp'limi bo eblum, jol nkakeltim bo kpimm;
\q3 ane ba kp'limi bo nlum kpi eko, wo bo nkakeltim bo kpimm.
\q1 
\v 2 N kehm bungu gbul gbul gbuul re, ane ba ma kpo fi, bo kpi eyebatahng sehnge aneb mbir mbir,
\q2 bo ji kpeka li go elkpin.
\q1 
\v 3 Nne no bo kal-e j'jel ye wo ga nob a ne sehnge bo njahm ebal ebal,
\q2 ye ji kala nyehn ab'bi nya ane kp'limi go njini.
\q1 
\v 4 N t'tob nyehne re enok kpee, a eko kpee ji nne kpo kak go eltum ni alimi no, kpo lohng go eteele ala ji nne kpi no bada ntem. Jia fvfo ejumjum lohngem, li ana nne kp'beke kam elfeb.
\q1 
\v 5 Agboolo ane kpo wal abo ebo, ko elrannge ba ka elbo.
\q1 
\v 6 Ga nob re nne bel ndabbo ejum alehke anyehng a enange eltim, sehnge re á bel ndabbo nsol alehke ebal go elnyennge lim eltum,
\q2 elnyennge lim eltum li ana nne kp'kame toono elfeb.
\q1 
\v 7 Owo n kehm kpe nyehn ejum jehko ji ki lohng ejumjum go njini nyia.
\q1 
\v 8 Nne awohng jolo go no lene ntahng ntahng, jol mmon a belem afii mmonannyehn.
\q2 Tvtv o, á joom lahng eltum alimi, jol afang enye we-e joom gbal.
\q3 Owo á kehm bahbe elne re, <<Anv, nne awoo me n kp'nyehne erem jo lim eltum nia ka-e,>> <<Fvfo jenji wahnge n kil elbele ngare lim elgeere?>>
\q4 Jia fvfo tob li ejum mbol mbol, a erem bi kpo kpo ko et'tane ba!
\q1 
\v 9 Ane abal ba ga nob sehnge nne awohng,
\q2 tibre, tibre nsehng eltum ebo bahke gbale.
\q1 
\v 10 Nne awohng ebo l'foro gbo, noko bahk-e mehle yiimi.
\q2 Wo eyuu a nne no bahke gboko fvfo k'bel nne no bahk-e mehle yiimi.
\q1 
\v 11 Budu o, ane abal l'noongo edi ajehng, bo bahke bele elfuubu bo.
\q2 Wo nne no li antahng bahke limi rejen kehm bele elfuubu ngubjing?
\q1 
\v 12 Jol nne awohng nne noko bahk-e ma ko elfono, ane abal bahke ma yiimi ka elbo.
\q2 Nlehke mi bo fere nja era bahke riidi eltohngo kim.
\s1 Eko edi afili ejumjum lohngem
\q1 
\v 13 Nkubin a njangkun nyi kpi ngbere nyi ga nob sehnge ek'kulu egboolo ntul, no kil jo wuk erehke.
\q1 
\v 14 Li ma jol re njangkun nyio lohngo ngbekobo ba kuumu etul, afii bo jele go ekpak go ejahbe ji á kp'fili.
\q1 
\v 15 N nyehne re ane kpee ba jolo go elkpin go njini jo toono njangkun nyio nyi ba kuumu etul toon-e.
\q1 
\v 16 Ane ba á jo fili bo, jol go nfange bo jolem.
\q2 Wo ane ba bo jele bo ngare nyi á ma kuumu etul sehng, eltim yebem bo bada a ne. Jia ejumjum lohngem, nne kp'kame na toono elfeb.
\c 5
\s1 Lim ana a ko nwongo ka Jehova
\q1 
\v 1 Jo baabe akpade eljen enya a l'je go Etahk Esowo. Jo je re wo song wuungu atung, sehnge re wo song lim njom nyi agboolo ane, bo ji kil jo kahn re boblim ebi.
\q1 
\v 2 Ka jo warre go nnyo, jol ejum ki-a jo foomo go eltim re wo bung ejum ajehng ajehng go esamahr bi Esowo.
\q2 Esowo li go elbung, wo li ga ndi, owo wahnge nobo re wo k'ga jo bung.
\q1 
\v 3 Nne kpo leeme nlem tib go nsol gbalee nyi wob-e go eltim,
\q2 fvfo egboolo nne kpo bung alum gbalee.
\q1 
\v 4 A l'ko nwongo a Esowo, ka laange ellimi ejum jio.
\q2 Esowo eltim we-e kpehme yebe bada agboolo ane; lim ji a ko nwongo.
\q1 
\v 5 Ga fuumu re nne k'ko nwongo sehnge re á ko, k'lim ji á nyame no.
\q1 
\v 6 Ka taame nnyo ema gbul-a kak go abiafem. Fvfo ka yiimi nfaabe a ntiigetib no Etahk Esowo re, <<Nwongo nyi n ko no, n soodo na.>> Jenji wahnge a bahke limi re eltim rak Esowo bade ajum ji a bungu no, fere rannge eltum abo enya?
\q1 
\v 7 Alem gbalee a eb'bungu gb'gbal kehme lohng ejumjum.
\q2 Fvfo jo fahl Esowo.
\s1 Afang ejumjum lohngem
\q1 
\v 8 A l'nyehn go esi jahbe re bo kp'limi nkpak eblum, fere jo lam elam eje go ebi mbang, taar-e eno eje, nsol ana nyio ki-a jo kpo esi, tibre ntubesi abalimentum awohng awohg kpo bel nne no kpe fil-e. Wo atubesi bao abal abal kpi nne no kp'ware sehnge bo ane abal abal.
\q1 
\v 9 Nsehng nyi ndi li ka ane kpee; yefono ntul kpo tob li nsehng go ebgbe bi bo bahme.
\q1 
\v 10 Nne awohng awohng no akpohko kpo kor-e, akpohko we-e nehm tiki gbal;
\q2 nne awohng awohng no nsol afang kpo kor-e, nsehng afang we-e nehm tiki gbal.
\q3 Jia fvfo ejumjum lohngem.
\q1 
\v 11 Ana nsol kp'ruru,
\q2 ano wo ane ba kpo li kpo tob rur.
\q3 Anv nsehng anyii li no a nne no kpi no, sehnge re kpo kor bo re bo jo ko amahr jo nyehn?
\q1 
\v 12 Ellu ni nne no ma lim nltum kpo yebe sehng, jol afii bo li nsol ntiil afii bo li gbalee,
\q2 wo efangene, nsol afang ebo nehm taame re bo lal.
\q1 
\v 13 Me n nyehn egburu ebi ejum go njini nyia,
\q2 ji li re, nne l'behr afang enye es'kohro bahke koko ebi ba ka-e,
\q1 
\v 14 afii afang nyao fere tane tib go ebibesi,
\q2 wahnge á l'jel mmon, ejumjum nehm kpe jol ji elkv alehke.
\q1 
\v 15 Nne awohng awohng kpo lohng ebun ebun go ala nnyehn ba, ana nne awohng awohng ba no, ano wo á bahke feere.
\q2 Ejumjum á nehm bel go ntum enye kpee nyi á jo nyennge lim, ji á bahke fili go ege ebo asongo.
\q1 
\v 16 Jia fvfo egburu ebi ejum ji:
\q2 Tibre ana nne awohng awohng ba no, ano wo á bahke feere,
\q3 fvfo nsehng anyii bo kpi no, eji bo kp'nyennge lim eltum ka elfeb?
\q1 
\v 17 Go afung enye kpee, á kpo li nsol go ejannge,
\q2 a elmarre ekubin a erakatahng.
\q1 
\v 18 Ejum ji a ji m ma nyehn re kp'nobo: Ji li re, ga fuumu re nne jo li fere jo w'wo, jo bel elwohngo go ntum abo enye nyi á kp'limi go njini nyia go abon afung elkpin ba Esowo me-e ka,
\q3 tibre jia ji li ji Esowo me-e ka.
\q1 
\v 19 Budu o, Esowo l'ka nne agburu afang á fere bel nsol,
\q2 fere ka-e eko re á jo li nsehng go nsol nyio, fere ko re ano wo elkpin li no, jo bel eyebatahng go eltum ene, jia ayare nya Esowo nya.
\q1 
\v 20 Nne noo nehm jo tir gbalee bade afung nya elkpin ene, tibre Esowo me-e bum re á jo li elfo.\f + \fr 5:20 \f*
\c 6
\s1 Ka yehke ntir kunu go afang
\q1 
\v 1 Me n nyehn ebi ejum jehko go njini, li egburu elsol ka ane.
\q1 
\v 2 Esowo kpo ka ane bandiki agburu afang, a nsol afang go ekpunu, wahnge bo limm elehng ejum ejehng ajehng ji eltim ebo sebe no, wo Esowo kpehme ka bo eko re bo li nsehng nyi nsol nyio, fvfo ajenne nya bahke lehke nsehng nyio. Jia ejumjum lohngem, egburu eyameltim ji.
\q1 
\v 3 Nne li ma bel abon atahl alon, fere kang nya tvv, wo jol afii elkpin ene labe renan, á tohko ma li nsehng nyi afang enye, fvfo bo tohko ma lim elkv ene ana fuumu no, me n kp'bungu re, mmon no bo ejel ekpakv wo ga nob sehnge nne noo.
\q1 
\v 4 Tibre á kpo ba ana ejum ji kii lohng ejumjum, fvfo mbing enye ebtob sa go ejannge.
\q1 
\v 5 Jol mmon no ki nyehn ebare elbung, afii kahn ejumjum, ye wo ga kpi erekekv sehnge efange nne.
\q1 
\v 6 Jol afii nne noo kange nnya atahltahl nkpel elon, wo á maam li nsehng nyi afang nya á bele no. Anv edi j'nehm sang bo kpee fi noa?
\q1 
\v 7 Nne awohng awohng kpo nyennge lim eltum re a bel ejum alehke,
\q2 wo ga ekpidla nehm tiki wohngo.
\q1 
\v 8 Nsehng anyii nnea ngbere kpi no sehnge egboolo nne?
\q2 Nsheng anyii akpak bahke bele go elkahne mbang ana nyi bo bahke jo fili elbo go ellong ane?
\q1 
\v 9 Ellehke ji nne kp'nyehne go ege amahr ji ga nob, sehnge re nne jo tiiri bade ejum ji á kala nyehn go ege amarhr.
\q2 Jia fvfo ejumjum lohngem, nne kp'kame na toono elfeb.
\q1 
\v 10 Ejum ajehng ajehng ji li no bob tohko gungu mbing, fvfo ji nne li no, bob tohko kahn bade;
\q2 nnene nehm ma yiimi abohng a nne no kp'tahne sehng-e.
\q1 
\v 11 Ana alum kp'ruru, ano wo kil jo kpe lohng ejum jum,
\q2 fvfo nsehng anyii jio bahke ma ka nne awohng awohng?
\q1 
\v 12 Tib anv, nne awoo kp'kahne ji kp'nobo ka nne go elkpin, go abon afung ba ki lohng ejumjum nya á li elkpin ni bahke sehnge ana etohko? Nne awoo bahk-e tongo ji bahke jolo go njini, go ngare nyi á ma kpo?
\c 7
\s1 Ngbere
\q1 
\v 1 Nnooba mbing kp'nobo sehnge atingi akehng es'sv eleenge,
\q2 fvfo efung bi nne kpo no kp'nobo senge efung bi bo jel-e no.
\q1 
\v 2 Ga nob re nne je go etahk ji ane nong elkv, senge re á je go etahk elkak,
\q2 tibre elkv ni li ejum ji li ka nne awohng awohng;
\q3 nobo re ane ba elkpin ko jia kak go eltim.
\q1 
\v 3 Ndon nyi ga nob sehnge asol,
\q2 tibre esahmahr ndon ndon kp'nobo ka eltim.
\q1 
\v 4 Eltim ni nnea ngbere li go etahk elkv,
\q2 wo eltim ni agboolo ane li go etahk elfo alehke.
\q1 
\v 5 Ga nob re nne wuk erehke ji nne a ngbere
\q2 sehnge re nne jo wuungu atung go ese ji agboolo ane.
\q1 
\v 6 Ana ajoong kp'tahke go agun nya etu kun no, ano wo asol nya egbooko nne li no.
\q2 Jia fvfo ejumjum lohngem.
\q1 
\v 7 Eloono nne kpo lim nnea ngbere fere jol egboolo nne,
\q2 fvfo ngu kpo rannge eltim nne.
\q1 
\v 8 Nkahlsi ejum kp'nobo sehnge mbomannahm,
\q2 fvfo elkpuumu kp'nobo sehnge agaabe.
\q1 
\v 9 Ka jo ware rak eltim sohk sohk go ega atahng,
\q2 tibre erakatahg wob go ntim nyi agboolo ane.
\q1 
\v 10 Ka jo bung re, <<Jenji wahnge afung nya mahne mahne, nobo sehnge afung nya lela?>>
\q2 Tibre fuuemem re nne jo bahb abahbe ana nyao.
\q1 
\v 11 Ngbere li nnoobo ejum ana elehkelkv,
\q2 kpi nsehng ka ane ba li go elkpin.
\q1 
\v 12 Ngbere li ejum ji kpo bulu nne
\q2 ana akpohko li ejum ji kpo bulu nne,
\q3 wo nsehng nyi elkahne li re, ngbere kpo kuuru ane ba kpi-e no.
\q1 
\v 13 Tir bada ji Esowo ma lim,
\q2 nne awoo bahke ma tanne ji á ma lim galle galle galle?
\q1 
\v 14 L'nob a na, jo bel eyebatahng; wo l'sab a na, jo buumu jia, re, Esowo eblim ejum jia ana a limi jehko.
\q2 Fvfo, nnene nehm ma kahn ejumjum bade ana bahke jolo a ne behnjehle.
\q1 
\v 15 Go elkpin ename nia ni kii lohng ejumjum, me n nyehn nsol ebal nyia:
\q2 Me n nyehn etinginne kp'kpoko tan go etingi eljini ene, ebi nne fere bel nlaabe elkpin go ege ebi eljini.
\q1 
\v 16 Ka jo tir bade elna re wo wo ga kpi etingi eljini,
\q2 jol ka tir re wo wo ga kpi ngbere, jenji wahnge a bahke rannge elna?
\q1 
\v 17 Ka jo gbal go ab'bi alimi,
\q2 fvfo ka jol egboolo nne, jenji wahnge a bahke kpoko ngare enya kehm rehnge.
\q1 
\v 18 Ga nob re wo gbo ejahm go ejum ajehng go nsol nyia,
\q2 fvfo jol ka yake jehko.
\q3 Nne awohng awohng no kpo fahl Esowo nehm gbo yel nsol nyia.
\q1 
\v 19 Ngbere kpo lim nnea ngbere awohng tahne
\q2 sehnge afiladi awubu ba li go nfam.
\q1 
\v 20 Lohko li ano re, nnene lim go njini no li etinginne;
\q2 nnene lim no kpo lim nsol go nseenga nseenge k'tiki lim abiafem
\q1 
\v 21 Ka jo kunu atung go ellum anehng anehng ni ane kp'bungu;
\q2 tohko jol ano, a bahke wuku nlokeltum ewa kp-a suku,
\q1 
\v 22 tibre a kp'kahne go ega eltim
\q2 re, akpel tvv wofonantahng kpo t'tob su ane bako.
\q1 
\v 23 Nsol nyia kpee n ko ngbere wuungu, n kehm bung re,
\q2 <<Me n ntoobo egame eltim re me n bel ngbere,>> wo ga ejum jia ebgbal sehng-m.
\q1 
\v 24 Ejum ajehng ajehng ji li no, li go fee, fere r'rahbe,
\q2 nne awoo bahke ma seb kahn?
\q1 
\v 25 Owo n kehm fere yehhke ntir enyame kunu re me n bel ekahnafem,
\q2 re me n feede, fere seb ngbere yehke, kahn ana nsol lohngo lohng,
\q3 fere lenng-m bade ademme nya li go ebiljini a esahl bi li go elgboolo.
\q1 
\v 26 Me n nyehn re ejum jia kp'yame sehnge elkv,
\q2 nenkal no li ana ekpoko, ye ji eltim ene li ekpoko, fvfo abo enye li agbekobo.
\q3 Nenlum no kpo lim ji kpo kor Esowo bahke foro go ege abo, wo nne abiafem wo bahke gboko ege ekpoko.
\q1 
\v 27 Nt'tibi kp'bungu re, <<Nyehn gae!>>
\q2 <<Ejum ji a ji m ma seb kahn, me n ko ejum ajehng budu a jehko, eji n l'kahn ana nsol lohngo lohng.>>
\q1 
\v 28 Ana n jo seb asongo, jol eji n kala ny'nyehn,
\q2 wo nyehne nnelum na awohng no li songo songo go ellong ane atahl alon nkpel ewubu (1000), wo nenkal na awohng n nyehnem go ellong ane baa kpee.
\q1 
\v 29 Ejum ajehn ji m ma nyehn ji a, ji li re, Esowo limi ane ba li elkpin songo songo,
\q2 wo bobtahm kp'sebe afehme abang gbalee.
\c 8
\q1 
\v 1 Nne awoo li ana nnea ngbere?
\q2 Nne awoo bahke ma lennge nsol ka ane?
\q3 Ngbere nyi nne kpi no kpo lim re esamahr ebe jo bang, fere yaange elbohngo esahmahr ebe bi kp'nyehnge.
\s1 Jo kpunu ntul
\q1 
\v 2 N kp'bungu tong-a re wo jo kpunu nkahn nyi ntul, tibre a ko nwongo go essamahr bi Esowo
\q1 
\v 3 Ka foomo tahm lohng go esamahr ntul. Ka yel ellong ane ba kpo toobo bade ab'bi, tibre ntul bahke ma lim ejum ajehng ajehng ji kor-e no.
\q1 
\v 4 Eji li re ellum ni ntul kpi egbuuru eko, nne awoo bahke ma bung a ne re, <<Ejum aji a kp'limi?>>
\q1 
\v 5 Nne awohng awohng no kpunu nkahn enye, ebi ejum nehm gbo tub-e,
\q2 fvfo nne no kpi ngbere go eltim bahke kahne ngare nyi fuumu re á lim nsol nyia, a mbang ana nyi á bahke koko lim.
\q1 
\v 6 Tibre ngare nyia, nyi fuumu no re nne lim ejum ajehng ajehng,
\q2 a mbang ana nyi á bahke limi, jol eji li li re nne li ekubin ekubin.
\q1 
\v 7 Eji li re nnene nehme kahn ji behna,
\q2 nne awoo bahke ma tong ntem ejum ji bahke jolo?
\q1 
\v 8 Ana nnene kii kpi nsahm nyi á bahke ma kpan elfeb,
\q2 ano wo nnene kii kpi nsahm bada ngare elkv enye.
\q3 Ana bo kil jo yehke nne go nsoja ngare ebta, ano wo ab'bi l'k'ma yake ane abo bo ji kp'limi.
\q1 
\v 9 N nyehne nsol nyia kpee, eji n yehke ntir enyame kak go nsol kpee nyi bo kp'limi go njini nyi ane bandiki kpi eko fvfo ane bako kpi erem nyehn go ebo elwo.
\q1 
\v 10 Ano wo fvfo n nyehne ana bo limi elkv abi ane, kpa bo kak, bo jio ji jo kono elbake go edi li saang fere feere, fvfo ane jo tehke bo go nfam nyi bo jo lim nsol nyia. Jia fvfo ejumjum lohngem.
\q1 
\v 11 Erem akake bi bo kimi elam bada nne no limi eb'bi l'jo laange, ntim ane kpo kehme elsebe abang nya bo bahke koko jo lim ab'bi.
\q1 
\v 12 Jol afii ebi nne ji limi abi nsol nkpel atahl alon kange aya tvv, n kp'kahne re bahke nobo a ane ba kpo fahl Esowo, ba kpo kpun-e go ege esamahr.
\q1 
\v 13 Wo eji abi ane kil jo fahl Esowo, nehm nob a bo, jol afung ebo nehm lahb ana etohko elgung.
\q1 
\v 14 Ejum ajehng jehko jia ji kpeka li ji ki lohng ejumjum go njini. Etinginne no bele ji kehn fuumu a ebi nne, a ebi nne ji bele ji kehn fuumu a etinginne. Jia fvfo, lohngem ejumjum.
\q1 
\v 15 Owo wahnge egame, fuumu re nne jo li elkpin go njini nyia, tibre ejumjum limm ji nobo no ka nne sehnge re, á jo li, jo w'wo, fere bel eyebatahng go elkpin. Owo eyebatahng bahke toono bo go ntum erem ebo go afung kpee nya elkpin ebo nya Esowo ma ka bo go njini nyia.
\q1 
\v 16 Eji n neyhke ntir enyame kunu re me n kahn bada ngbere fere kunu amahr nyehn ntum nyi ane kpo lim go njini, nyi wahnge bo kil jo lal atv a njul,
\q1 
\v 17 owo n kehm nyehne nsol kpee nyi Esowo ma lim. Nnene nehm ma kahn ana ji kp'j'jol go njini nyia. Jol ana bo kp'n'nok kpee re bo feede kahn, nnene we-e nehm ma tiki lennge ana lohngo lohng. Jolafii aneb ngbere kp'woro nnyo re bo kp'kahne, nehm ma tiki lennge bo.
\c 9
\s1 Ji li ka ane kpee
\q1 
\v 1 Ano wo n jo tir bade nsol nyia kpee fere kohlo asi re, etinginne a nnea ngbere a nsol nyi bo kp'limi wob go abo nya Esowo, wo nnene nehme kahn joare elkoro ni nong kpi bo sik afii etehn nne.
\q1 
\v 2 Ejum ajehng j'nehm ji kpo gbo tub bo ane kpee, atingane a abiane, anobonbo a asabsab, ane ba li saang a ba ki li saang, ane ba kpo lim ajom ka Esowo a ba kil jo lim ajom ka Esowo.
\q2 Ana li a nnooba nne ano wo tob li a nne abiafem;
\q3 ana li a ane ba kpo ko nwongo, ano wo tob li a ane ba kpo fahl nwongo akoko.
\q1 
\v 3 A wo li ebi ejum ji li go ejum ajehng ajehng ji kp'jolo go njini, ji li re, ejum ajehng j'nehm ji kpo gbo tub ane kpee. Budu o, ab'bi ebrur go nitim ane, esahl tob wob bo go ntim ana bo li go elkpin, tete bo kpo song jol a akvne.
\q1 
\v 4 Nne awohng awohng no li elkpin kpi ekunukpu, jol mbv nyi li elkpin kp'gake nob sehnge egabi ji ma kpo.
\q1 
\v 5 Tibre ane ba li go elkpin kp'kahne re bo bahke kpoko,
\q2 wo akvne ejumjum bo nehme kahn,
\q3 eltuuru bo kpeem kpi, jol abing ebo ane ebyini
\q1 
\v 6 Elkoro ebo, a etehnne ebo,
\q2 go eteele ala ebo ebtan fi ekidi eblab;
\q3 bo nehm ma kpe lim ejum ajehng ajehng bade nsol nyi kp'jolo go njini
\q1 
\v 7 Song, wo song li nsol alehke enya a eyebatahng, wo amahm ema a eyebeltim tibre Esowo ebtaame tv ejum ji a kp'limi.
\q1 
\v 8 Jo liibi a babare nsol ngare kpekpe, fvfo wo fere jo kak elna akehng go esi ngare kpekpe.
\q1 
\v 9 Jo li elkpin a nkal ewa no kpo kor-a, go afung kpe kpe nya elkpin ena ni ki lohng ejumjum, ni Esowo m-a ka go njini, afung enya kpee nyao nya ki lohng ejumejum. Tibre ejum ji a, ji li ka go elkpin, fvfo go eltum ni a kp'nyennge jo lim go njini.
\q1 
\v 10 Ejum ajehng ajehng ji a kake abo enya re wo lim, lim a eko eko eja kpee, tib go ejahbe akvne ji a fi no, eltum alimi go limm, jol ntoobo, jol elkahne afii ngbere limm.
\q1 
\v 11 Me n tob nyehn ejum jehko go njini nyia:
\q2 Nne no kpo ware abahl abeke sang kpo be ga ane bako,
\q3 jol nne eko sang kpo ko esehnge ebta,
\q4 jol nne a ngbere sang kpo bel nsol alehke,
\q1 afii agburu afang jol ka ebangbanag nne,
\q2 afii nnoobo jol ka nne elkahne;
\q3 Kpo jol go enobesi, nne l'jol go edi ji fuumu no go ngare nyi fuumu no.
\q1 
\v 12 Fvfo, nnene nehme kahn ana ngare ny'nye bahke bake:
\q2 Ana bo kpo ko arim eblum bob nsahre,
\q3 afii ana nruk kpo gbo ekpoko,
\q4 ano wo ebi ngare kpo bob ane ana ekpoko, kpo gbede na bo.
\s1 Ngbere nyi ga nob sehnge elgboolo
\q1 
\v 13 Fvfo n kehm kpe tob nyehn ntugare nyehko nyi li bada ngbere go njini nyia, nyi liim na egbuuru nkpoko esi ejum.
\q1 
\v 14 Mojahbe awohng jolo go, a abon amohk ane ba lene o. Owo ntul no kpi eko kehm ba yiimi ebta a bo, sennge bo kak, fere si nkpak ngbe sennge ekahme nfam kak.
\q1 
\v 15 Nnenlum awohng lene o no jolo nkpak, wo á bele ngbere, fvfo a ko ngbere enye tahre nfam nyio. Jol nnene buumem nkpak a nne noo.
\q1 
\v 16 Ano wo m bungu no re, <<Ngbere nyi ga nob sehnge atahne.>> Wo bo rodo ngbere nyi nkpak nyio daange, jol alum enye bo nehme kpe wuk.
\q1 
\v 17 Anaange alum nya nnea ngbere nya ga fuumun re nne wuk,
\q2 sehnge elrabe ni mfiladi no agboolo ane.
\q1 
\v 18 Ngbere nyi ga nob sehnge nsol ebta,
\q2 wo nne abiafem awohng kpo rannge anoobo nsol gbalee.
\c 10
\q1 
\v 1 Ana akpakv aj'jahnge kpo lim re akehng es'sv eleenge jo v esabsab es'sv,
\q2 ano wo li bada nne elkahne a ekpunu bo l'lim elgboolo ntiil.
\q1 
\v 2 Eltim ni nnea ngbere kpo jol feere go ejang etingi mbang,
\q2 wo ni egboolo nne kpo jol feere go ejang ab'bi.
\q1 
\v 3 Jol eji agboolo ane kp'jene asongo go mbang,
\q2 ntir nyi nno bo kpimm,
\q3 bo kpo tib nne awohng awohng eldaabe ebo.
\q1 
\v 4 Nfiladi l'rak eltim bade a na,
\q2 ka tahm edi eltum eja sa;
\q3 nnaangeljini bahke limi bo tahm ka nne go nsoodo.
\q1 
\v 5 Ebi eju jia a, ji m ma nyehn go njini nyia,
\q2 elkohn nsoodo nyi nfiladi kpo lim:
\q1 
\v 6 Agboolo ane bo kpo rod bo kunu go awahrewahre adi gbalee,
\q2 wo ga afangane, kpo kuumu arederede adi.
\q1 
\v 7 Me n nyehn aju kun go ajahm ebvankang,
\q2 wo atubesi ane fere jo jen go akpade ana aju.
\q1 
\v 8 Nne awohng awohng no kpa elbing, li ma gbo yel o;
\q2 nne awohng awohng no wa ekahme re a yel, nnyo li-e ma tohko.
\q1 
\v 9 Nne awohng awohng no kpo kpa atahl yehke, atal nyao bahk-e ma lim ejum;
\q2 nne awohng awohng no kpo yange nti, á li go efin efin, li-e ma lim ejum.
\q1 
\v 10 Elfuk l'kohd,
\q2 fvfo bo tohko k'bange, nne bahke kake eko gbalee lim eltum,
\q3 wo nne no elfuk m-e nahre bahke limi nobnob.
\q1 
\v 11 Nnyo l'gbo mbang tohko nne, nnea ntanne kehm-e koko elfono,
\q2 eblohng re nnea ntaane noo bo we-e nehm kpe kpi.
\q1 
\v 12 Alum nya lohng go nnyo mi nnea ngbere li anoobo alum,
\q2 wo agboolo ane kpo wul elbo go eboa nnyo.
\q1 
\v 13 Go mboma mbomo alum e bo li agboolo alum;
\q2 ekahlsi alum ebo li abi alum nya esahl,
\q1 
\v 14 fvfo agboolo ane kpo bung alum gbalee.
\q2 Nnene nehme kahn ji kp'bake,
\q3 fvfo nne awoo bahke ma tong ntem ji bahke jolo b'njehle ngare nyi bo ki kpe li?
\q1 
\v 15 Eltum ni agboolo ane kpo nyennge jo lim, kpo lahng na bo,
\q2 bo kpehme kahn mbang rehng to nfam.
\q1 
\v 16 Eyuu a ejahbe ji ntula bo jolo nlokeltum,
\q2 bo ji atubesi ane ebo kpo lim nkak efungfu.
\q1 
\v 17 Elfuulu li ka ejahbe ji ntula bo lohng go ebangenahb ji agburu ane,
\q2 ye ji atubesi ane ebe kpo lim nkak go ngare nyi fuumu no,
\q3 eji bo l'bel eko, bo kpehme lim re bo jo wo fere jo b'buumu.
\q1 
\v 18 Ewon kpo lim elbulutahk jak;
\q2 tib eji abo li nehme nehme, etahk kpo l'lahl.
\q1 
\v 19 Elkak bo kpo lim re ane jo wol asol,
\q2 amahm kpo lim elkpin jol yebe yebe,
\q3 fvfo akpohko nya li nfaange nyi ejum ajehng ajehng.\fe + \fr 10:19 \fe*
\q1 
\v 20 Ka nyok ntul, jol go ega eltim,
\q2 afii su efangenne go ega ekp'kpa elkang,
\q3 tibre ebruk bi kp'foongo go elbung bahke ma rod alum enya, fvfo ebruk bi kpo foongo bahke ma tooro ji a bungu no.
\c 11
\s1 Rod akpohko enya kak, wo jen ajoobo are
\q1 
\v 1 Ro abred enya kak go alahb;
\q2 l'kang afung gbalee, a bahke ma bel nsehng.
\q1 
\v 2 Kak akpohko enya go are na asehma, jol kak rehng anehkeni;
\q2 a nehme kahn ebi erem bi bahke gboko tub ejahbe.
\q1 
\v 3 Akparesemsem l'jol alahb alahb,
\q2 kpo na elahb wohngo go ndi.
\q3 Jol afii eti gbo feere go ejang aboblum afii ejang ebobkal, edi j'nehm ji gbo no, o wo kpo noongo
\q1 
\v 4 Mbahmgbe awohng awohng no kp'kahn ejang ji elfeb kpo lohng ba kp'kahn ngare nyi á l'k'bahme nosl enye;
\q2 mbahmgbe awohng awohng no kp'kahne bade akparesemsem kpo kahn ngare nyi ki fuumu re á fv nsol enye.
\q1 
\v 5 Ana a kil elkahne mbang nyi nfeb kpo sehng,
\q2 afii ana nne kpo jini go ala nnyehn,
\q3 ano wo a l'k'ma kahn eltum ni Esowo, ye ji li Nlima nsol kpee.
\q1 
\v 6 Bahm nsol ndi enya go ngare efungfu,
\q2 fvfo ngare elgung, non abo enya k're ekv,
\q3 tib a nehme kahn nsol nyi bahke nobo, ma nyao nya njii, afii nyako nya,
\q4 afii fundiki abbal abbal bahke nobo.
\s1 Buumu Nne no lim-a no eji a kpeka njangkun
\q1 
\v 7 Ellennge kp'yebe,
\q2 nne kpo bel eyebe eltim re amahr enye nyehn njul.
\q1 
\v 8 Jol afii ne kahnge aya tvv,
\q2 nong bo bel elgeere aya nyao kpee.
\q3 Wo nong bo buumu afung nya ejannge, tibre afung nyao bahke bahke jolo gbalee.
\q4 Ejum ajehng ajehng ji kp'bake ejumjum lohngem.
\q1 
\v 9 Wahn ji li ajangkun, jo belen eyebatahng eji ń li ajangkun,
\q2 fvfo nong ntim enyahne jo ka-n eyebatahng go afung nya n li ajangkun.
\q3 Jo toonen abang nya nltim enyahne
\q4 a ejum ajehng ajehn ji amahr enyahne nyehne no.
\q1 Wo kahnen re go nsol nyia kpee,
\q2 Esowo bahk-n lungu elam.
\q1 
\v 10 Ano wo wahnge fuumu no re wo yehke egbiingi eltim go ega eltim,
\q2 fere rod atongtong nya ngubjing enya ro go,
\q3 tibre eljolo ejangkun a eljolo eko eko, ejumjum lohngem.
\c 12
\q1 
\v 1 Buumu nl'limi ewa
\q2 go ngare nyi a kpeka li njangkun,
\q3 afung nya atongtong kehm bake,
\q4 aya kehm kabbe, nya a bahke bung re, << N kpimm ekor go ejum ajehng ajehng.>>
\q1 
\v 2 Ngare nyio njul a ellennge,
\q2 a ebareka go alonlo bahke daade, siingi ejannge,
\q3 fvfo akparesemsem kehm feere elahb l'na mal;
\q1 
\v 3 ngare nyi ane ba kpo baabe etahk bahke jo kahm,
\q2 tib go elfahle, atahntahn aneblum fere jo jen gong gong;
\q3 ngare nyi abagoko nsol l'k'kpe jol tibre bo li abon mohk ane abik abik,
\q4 fvfo ngare nyi amahr bahke bamme ane ba kpo fahng go mombua nkpe ekahme.
\q1 
\v 4 Ngare nyi bo ma bame abutahk nya afakabang,
\q2 fvfo ewahl nsol agoko fere rahke;
\q3 ngare nyi ane bahke nyahme tib eji nruk kp'siiki, wo ase ebo kpee bahke rahke na;
\q1 
\v 5 ngare nyi ane bahke jo fahl ejum ji kp'wahre,
\q2 a efin bi li go afakabang,
\q3 eji elrahn almon ma nyono,
\q4 fvfo ekpaange kp'feebe asongo,
\q1 ejumjum nehm kpe jo tab nne nkpa.
\q2 Owo ane kpo tahm asongo go ekehnge ebo ji li njinanjini,
\q3 abanoongo elkv fere jo jen yannge go afakabang.
\q1 
\v 6 Buumu nl'limi ewa, nlehke asilva kehm kimi
\q2 fvfo ekpingi agul kehm gboko wa;
\q3 etulahb kehm gboko wa go ebgba,
\q4 fvfo egare kehm kimi go elbing elahb,
\q1 
\v 7 fvfo ebtohko kehm feere go ndi nyi lohng no,
\q2 etohko feere goji Esowo bi kaa no.
\q1 
\v 8 <<Ejumjum lohngem! ejumjum lohngem!>> nt'tibi wo bungu.
\q2 <<Jol ejumjum ajehng ajehng! Ejumjum lohngem ejumjum.>>
\s1 Es'kohro elbungu
\q1 
\v 9 Nt'tibi jolem na jol nnea ngbere, wo á tob tibi ane elkahne. Á jo tiri bade agaane, jo feede, fere toobo. agaane gbalee bum go ntooranti.
\q1 
\v 10 Nt'tibi kpo feede eji á l'seb kahn ellum ni fuumu no, fvfo jore ji á nyono no, li songo songo a etingitingi.
\q1 
\v 11 Alum nya nnea ngbere li ana ebti mbaabebul, alum ebo li ana aba nya bo ma sahb k'kum kak ejum, mbaabebul awohng wo bungu alum nya.
\q1 
\v 12 Mmon ewame, nong me n rehk-a, re wo k'yehke ntir enya kak go alum anyehng anyehng sehnge nyaa.
\q2 Ane nehm ma tiki nyon awer mal, fvfo nne l'ga kpili sehng, á bahke lahnge na.
\q1 
\v 13 Anv wobwuk nsol kpee;
\q2 a wo li es'kohro elbungu nia, nyi li re:
\q3 Jo fahl Esowo wo jo bum nkahn enye,
\q4 tibre a wo li eltum ni ane kpee.
\q1 
\v 14 Tibre Esowo bahke lame nne bade ejum ajehng ajehng ji á limi no,
\q2 a ejum mbehr mbehr ajehng ajehng,
\q3 jol afii nobo na afii sabe na.
