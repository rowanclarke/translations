\ms1 Jesus declares His death, and ministers on that basis
\s1 Peter is inspired
\p 
\v 27 \w Then|strong="G2532"\w* \w Jesus|strong="G2424"\w* \w and|strong="G2532"\w* \w His|strong="G1519"\w* \w disciples|strong="G3101"\w* \w set|strong="G2532"\w* \w out|strong="G1831"\w* \w for|strong="G1519"\w* \w the|strong="G1722"\w* \w towns|strong="G2968"\w* \w of|strong="G2532"\w* \w Caesarea|strong="G2542"\w* \w Philippi|strong="G5376"\w*; \w and|strong="G2532"\w* \w on|strong="G1722"\w* \w the|strong="G1722"\w* \w way|strong="G3598"\w* \w He|strong="G2532"\w* \w questioned|strong="G1905"\w* \w His|strong="G1519"\w* \w disciples|strong="G3101"\w*, \w saying|strong="G3004"\w* \w to|strong="G1519"\w* \w them|strong="G3588"\w*, “\w Who|strong="G5101"\w* \w are|strong="G1510"\w* \w people|strong="G1510"\w* \w saying|strong="G3004"\w* \w that|strong="G3588"\w* \w I|strong="G1473"\w* \w am|strong="G1510"\w*?”
