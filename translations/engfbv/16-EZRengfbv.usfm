\v 1 \w In|strong="H8141"\w* \w order|strong="H1697"\w* \w to|strong="H3068"\w* \w fulfill|strong="H3615"\w* \w the|strong="H3605"\w* \w Lord|strong="H3068"\w*'s prophecy given \w through|strong="H5674"\w* \w Jeremiah|strong="H3414"\w*, \w the|strong="H3605"\w* \w Lord|strong="H3068"\w* encouraged \w Cyrus|strong="H3566"\w*, \w king|strong="H4428"\w* \w of|strong="H4428"\w* \w Persia|strong="H6539"\w*, \w to|strong="H3068"\w* issue \w a|strong="H3068"\w* \w proclamation|strong="H6963"\w* \w throughout|strong="H3605"\w* \w his|strong="H3605"\w* \w kingdom|strong="H4438"\w* \w and|strong="H3068"\w* \w also|strong="H1571"\w* \w to|strong="H3068"\w* \w put|strong="H3068"\w* \w it|strong="H3615"\w* \w in|strong="H8141"\w* \w writing|strong="H4385"\w*, \w saying|strong="H1697"\w*,
\v 2 “\w This|strong="H1931"\w* \w is|strong="H3068"\w* \w what|strong="H3541"\w* \w Cyrus|strong="H3566"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* \w Persia|strong="H6539"\w* \w says|strong="H3541"\w*: ‘\w The|strong="H3605"\w* \w Lord|strong="H3068"\w*, \w the|strong="H3605"\w* \w God|strong="H3068"\w* \w of|strong="H4428"\w* \w heaven|strong="H8064"\w*, \w who|strong="H3605"\w* \w has|strong="H3068"\w* \w given|strong="H5414"\w* \w to|strong="H3068"\w* \w me|strong="H5414"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w kingdoms|strong="H4467"\w* \w of|strong="H4428"\w* \w the|strong="H3605"\w* \w earth|strong="H8064"\w*, \w has|strong="H3068"\w* \w given|strong="H5414"\w* \w me|strong="H5414"\w* \w the|strong="H3605"\w* \w responsibility|strong="H5921"\w* \w to|strong="H3068"\w* \w build|strong="H1129"\w* \w a|strong="H3068"\w* \w Temple|strong="H1004"\w* \w for|strong="H5921"\w* \w him|strong="H5414"\w* \w at|strong="H5921"\w* \w Jerusalem|strong="H3389"\w* \w in|strong="H5921"\w* \w Judah|strong="H3063"\w*.
\v 3 \w Anyone|strong="H3605"\w* \w among|strong="H5973"\w* \w you|strong="H3605"\w* \w who|strong="H4310"\w* \w belongs|strong="H1961"\w* \w to|strong="H3478"\w* \w his|strong="H3605"\w* \w people|strong="H5971"\w* \w can|strong="H4310"\w* \w go|strong="H5927"\w* \w to|strong="H3478"\w* \w Jerusalem|strong="H3389"\w* \w in|strong="H3478"\w* \w Judah|strong="H3063"\w* \w to|strong="H3478"\w* \w rebuild|strong="H1129"\w* \w this|strong="H1931"\w* \w Temple|strong="H1004"\w* \w of|strong="H1004"\w* \w the|strong="H3605"\w* \w Lord|strong="H3068"\w*, \w the|strong="H3605"\w* \w God|strong="H3068"\w* \w of|strong="H1004"\w* \w Israel|strong="H3478"\w*, \w who|strong="H4310"\w* \w lives|strong="H1961"\w* \w in|strong="H3478"\w* \w Jerusalem|strong="H3389"\w*. \w May|strong="H1961"\w* \w your|strong="H3068"\w* \w God|strong="H3068"\w* \w be|strong="H1961"\w* \w with|strong="H5973"\w* \w you|strong="H3605"\w*.
\v 4 \w Wherever|strong="H3605"\w* \w survivors|strong="H7604"\w* \w are|strong="H1004"\w* currently \w living|strong="H1481"\w*, \w let|strong="H7604"\w* \w them|strong="H5375"\w* \w be|strong="H3389"\w* \w helped|strong="H5375"\w* \w by|strong="H2091"\w* \w the|strong="H3605"\w* \w people|strong="H1931"\w* \w of|strong="H1004"\w* \w that|strong="H3605"\w* region \w with|strong="H5973"\w* \w silver|strong="H3701"\w*, \w gold|strong="H2091"\w*, \w goods|strong="H7399"\w*, \w and|strong="H3701"\w* livestock, \w together|strong="H5973"\w* \w with|strong="H5973"\w* \w a|strong="H3068"\w* \w voluntary|strong="H5071"\w* donation \w for|strong="H1004"\w* God's \w Temple|strong="H1004"\w* \w in|strong="H1004"\w* \w Jerusalem|strong="H3389"\w*.’”\f + \fr 1:4 \ft This proclamation of Cyrus is also found at the end of 2 Chronicles.\f*
\p 
\v 5 \w Then|strong="H6965"\w* \w God|strong="H3068"\w* encouraged \w the|strong="H3605"\w* \w family|strong="H1004"\w* \w leaders|strong="H7218"\w* \w of|strong="H1004"\w* \w Judah|strong="H3063"\w* \w and|strong="H3063"\w* \w Benjamin|strong="H1144"\w*, \w as|strong="H3068"\w* well \w as|strong="H3068"\w* \w the|strong="H3605"\w* \w priests|strong="H3548"\w* \w and|strong="H3063"\w* \w Levites|strong="H3881"\w* \w to|strong="H3068"\w* \w go|strong="H5927"\w* \w and|strong="H3063"\w* \w rebuild|strong="H1129"\w* \w the|strong="H3605"\w* \w Lord|strong="H3068"\w*'s \w Temple|strong="H1004"\w* \w in|strong="H3068"\w* \w Jerusalem|strong="H3389"\w*.
\v 6 \w All|strong="H3605"\w* \w their|strong="H3605"\w* neighbors \w supported|strong="H2388"\w* \w them|strong="H5921"\w* \w with|strong="H5921"\w* gifts \w of|strong="H3027"\w* \w silver|strong="H3701"\w* \w and|strong="H3701"\w* \w gold|strong="H2091"\w*, \w with|strong="H5921"\w* \w goods|strong="H7399"\w* \w and|strong="H3701"\w* livestock, \w and|strong="H3701"\w* \w with|strong="H5921"\w* \w other|strong="H3605"\w* \w valuable|strong="H4030"\w* \w items|strong="H3627"\w*, \w in|strong="H5921"\w* \w addition|strong="H5921"\w* \w to|strong="H5921"\w* \w all|strong="H3605"\w* \w their|strong="H3605"\w* voluntary donations.
\p 
\v 7 \w King|strong="H4428"\w* \w Cyrus|strong="H3566"\w* \w also|strong="H3068"\w* retrieved \w the|strong="H5414"\w* \w items|strong="H3627"\w* belonging \w to|strong="H3318"\w* \w the|strong="H5414"\w* \w Lord|strong="H3068"\w*'s \w Temple|strong="H1004"\w* \w that|strong="H3068"\w* \w Nebuchadnezzar|strong="H5019"\w* \w had|strong="H3068"\w* \w taken|strong="H3318"\w* \w from|strong="H3318"\w* \w Jerusalem|strong="H3389"\w* \w and|strong="H3068"\w* \w placed|strong="H5414"\w* \w in|strong="H3068"\w* \w the|strong="H5414"\w* \w temple|strong="H1004"\w* \w of|strong="H4428"\w* \w his|strong="H5414"\w* \w god|strong="H3068"\w*.
\v 8 \w Cyrus|strong="H3566"\w* \w had|strong="H4428"\w* \w Mithredath|strong="H4990"\w* \w the|strong="H5921"\w* \w treasurer|strong="H1489"\w* retrieve \w them|strong="H5921"\w*, \w who|strong="H3063"\w* \w counted|strong="H5608"\w* \w them|strong="H5921"\w* \w and|strong="H3063"\w* \w gave|strong="H3318"\w* \w them|strong="H5921"\w* \w to|strong="H3318"\w* \w Sheshbazzar|strong="H8339"\w*,\f + \fr 1:8 \ft “Sheshbazzar”: some have identified Sheshbazzar (Babylonian name) with Zerubbabel (Hebrew name).\f* \w the|strong="H5921"\w* \w leader|strong="H5387"\w* \w of|strong="H4428"\w* \w Judah|strong="H3063"\w*.
\p 
\v 9 This \w was|strong="H3701"\w* \w the|strong="H4557"\w* \w list|strong="H4557"\w*: 30 \w gold|strong="H2091"\w* basins, 1,000 \w silver|strong="H3701"\w* basins, 29 \w silver|strong="H3701"\w* silverware,
\v 10 30 \w gold|strong="H2091"\w* \w bowls|strong="H3713"\w*, 410 matching \w silver|strong="H3701"\w* \w bowls|strong="H3713"\w*, \w and|strong="H3967"\w* 1,000 \w other|strong="H4932"\w* \w items|strong="H3627"\w*.
\v 11 \w In|strong="H3701"\w* \w total|strong="H3605"\w* \w there|strong="H5927"\w* \w were|strong="H3627"\w* 5,400 \w gold|strong="H2091"\w* \w and|strong="H3967"\w* \w silver|strong="H3701"\w* \w items|strong="H3627"\w*. \w When|strong="H5927"\w* \w the|strong="H3605"\w* \w exiles|strong="H1473"\w* \w left|strong="H5927"\w* Babylon \w to|strong="H5927"\w* \w go|strong="H5927"\w* \w to|strong="H5927"\w* \w Jerusalem|strong="H3389"\w* \w Sheshbazzar|strong="H8339"\w* \w took|strong="H5927"\w* \w all|strong="H3605"\w* \w these|strong="H3605"\w* \w along|strong="H5973"\w* \w with|strong="H5973"\w* \w them|strong="H5927"\w*.
\b
\c 2
\p 
