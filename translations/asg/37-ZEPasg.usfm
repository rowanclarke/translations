\id ZEP - Cishingini Agwara Kambari [asg]
\toc3 Zaf
\toc2 Zafaniya
\toc1 Katagarda ka Zafaniya
\mt2 Katagarda ka
\mt1 Zafaniya
\imt1 Kuɓa̱yuwa̱
\ip Keneki Zafaniya u dana ta̱ uma kadanshi ka̱ Ka̱shile a ayin a ukocishi a tsumani ci cindere kafu a matsa Yesu (KY). U yotso ta̱ u yaꞋan ta̱ kene ku nampa a̱ya̱ kupa kafu mogono Josaya u lapula ukuna u kutoni a̱ ka̱ya̱ ka amangatawa̱nta̱li n kamanga n kete (621) kafu a matsa Yesu (KY).
\ip Katagarda ka ki ta̱ uɗiki n kadanshi ka ukuna u kene ku na uma a kiwanai n uɗa. Kanna ka afada n kanna ka wuya ki ta̱ lo a̱ kuta̱wa̱ ka na Vuzavaguɗu u kutakacika Yahuda adama a na wi ta̱ a kucikpa a̱ma̱li. Vuzavaguɗu wi ta̱ feu a kutakacika iɗika i uma i na i buwai.
\ip Ko a na wo okpoi a takacika ta̱ ɗe Urushelima, a kubana kelime i ta̱ o kubonoko likuci ya tsu na yi ishi cau. Uma i ta̱ a̱ kuda̱sa̱ngu punu, i ta̱ o ko okpo aza a usuɓi n ma̱riki. Vuzavaguɗu n ka̱ci ka̱ ni wi ta̱ a kupana uyoꞋo u yaꞋan ma̱za̱nga̱ adama a uma a̱ ni a na a buwai, a na u yaꞋansakai nwalu n le.
\iot Ili i na yi punu udari
\io1 Kanna ka na Vuzavaguɗu u kutakacika aza a Yahuda ki ta̱ lo a̱ kuta̱wa̱ 1:1-18
\io1 Uɗeki adama a̱ kushika̱ ku unushi 2:1-3
\io1 Atakaci adama a iɗika i uma a na e yevei Ka̱shile ba 2:4-15
\io1 Atakaci a Urushelima n wishi u ni 3:1-13
\io1 Vishipa vu ma̱za̱nga̱ 3:14-20
\c 1
\s1 Kanna ka afada a Vuzavaguɗu wa aza a Yahuda
\p 
\v 1 Vuzavaguɗu u yaꞋin kadanshi n Zafaniya kolobo ka̱ Kushi, matsukaya ma Gedaliya, vuza na esheku a̱ ni Amariya, maku ma Hezekaya, a ayin a na Josaya kolobo ka Amon wi o tsugono tsu Yahuda.
\v 2 Vuzavaguɗu u danai,
\q2 <<Mi ta̱ a ku una ili ra̱ka̱,
\q2 a aduniyan.>>
\q1 
\v 3 <<Mi ta̱ a ku una uma nu nnama dem,
\q2 Mi ta̱ a̱ ku una nnu n gaɗi,
\q2 n adan a mala,
\q1 mi ta̱ kpamu a̱ ku una aza a gbani-gbani n a̱ma̱li e le,
\q2 ka̱ta̱ m pura̱ngu vuma vu lima̱ aduniyan.>>
\q1 
\v 4 <<Mi ta̱ a̱ kuba̱rukpa̱ kukiye ku va̱ n yaꞋan tsurala n Yahuda,
\q2 n aza a na i a̱ ida̱shi a Urushelima dem.
\q1 A̱ ubuta̱ u nanlo ɗa mi a ku una aza a na a buwai a kucikpa ka̱ma̱li ka Balu,
\q2 n ula a anan ganu va̱ a̱ma̱li a nanlo.
\q1 
\v 5 Mi ta̱ a ku una aza a na a tsu kumba gaɗi vu kukpa̱,
\q2 a cikpa kanna n wotoi n azangata.
\q1 Mi ta̱ a ku una aza a na a̱ tsu kuɗa̱ngu a kucina n Vuzavaguɗu,
\q2 i kpamu a kucina n ka̱ma̱li ka Moleka.
\q1 
\v 6 Mi ta̱ a ku una aza a na o bonoi n ka̱ca̱pa̱,
\q2 a̱ ka̱sukpa̱i kutono Vuzavaguɗu,
\q2 n aza a na a̱ kpa̱ɗa̱i kula̱nsa̱ ili u Vuzavaguɗu,
\q2 kpamu a̱ la̱nsa̱ kusheshe ku ni ba.>>
\q1 
\v 7 Paɗa bini e kelime ka Vuzavaguɗu Ka̱shile,
\q2 adama a na kanna ka Vuzavaguɗu ka yawa ta̱ ɗevu,
\q1 Vuzavaguɗu wi ta̱ kufoɓuso kanna ka afada,
\q2 kpamu u zagba ta̱ aza a na a kuyaꞋan a ɗa,
\q1 
\v 8 A kanna ka nanlo, mpa Vuzavaguɗu,
\q2 <<Mi ta̱ a kutakacika aza e kelime n aza o tsugono,
\q2 n aza a na i o kutono kuyongo ki iɗika yi uduma.
\q1 
\v 9 A kanna ka nanlo mi ta̱ a kutakacika,
\q2 aza a na a banai a̱ ubuta̱ u ka̱ɗiva̱ ka̱ a̱ma̱li,\f + \fr 1:9 \ft Na va kuyongo ku ɗa ka aza o kutoni ka̱ a̱ma̱li a Filisitiya. La̱na̱ 1 Sam 5:5\f*
\q1 n ele na a shatangi iꞋuwa yi nva̱li ma̱ a̱ma̱li n le,
\q2 n ukuna u modoruko n kalyaꞋa.
\q1 
\v 10 Vuzavaguɗu u danai, <<A kanna ka nanlo,
\q2 i ta̱ a kupana ma̱shi na ɗe a̱ Utsutsu u Kadan,
\q2 a pana yoroli ɗe a kakambu ke ire,
\q2 n izumgbi yi ili o kuɓososo a gaɗi vu nsasan.
\q1 
\v 11 Shika̱i, a̱ɗa̱ na yi ida̱shi a uɓon u kuden ku Morota,
\q2 adama a na i ta̱ a ku una aza a tsulaga ra̱ka̱,
\q2 n edengi azanariya n azurufa ra̱ka̱ i ta̱ a ku una le.
\q1 
\v 12 A ayin a nanlo mi ta̱ a̱ kula̱nsa̱ Urushelima nu nkuni,
\q2 mi ta̱ a kutakacika aza a na a tsu zuwaka nu ukuna ba,
\q2 aza a na a tsu dana a̱ɗu e le,
\q1 <Vuzavaguɗu wi a kuyaꞋanka tsu kasingai ba,
\q2 ko u yaꞋanka tsu i gbani-gbani ba.>
\q1 
\v 13 I ta̱ a̱ kupura̱ uciyi u le,
\q2 ka̱ta̱ o ɓoso iꞋuwa i le,
\q1 ko a na wo okpoi a maꞋa ta̱ iꞋuwa,
\q2 ama a̱ kuda̱sa̱ngu punu ba,
\q1 i ta̱ a kucimba ashina a itacishi,
\q2 ama o kusoꞋo ma̱kya̱n ma ba.>>
\s1 Kanna ka gbayin ka Vuzavaguɗu
\q1 
\v 14 Kanna ka gbayin ka Vuzavaguɗu ka yawa ta̱ ɗevu,
\q2 ka yawa ta̱ ɗevu ɗa kpamu ki a̱ kuta̱wa̱ gogoꞋo.
\q1 Izumgbi i kanna ka Vuzavaguɗu yi ta̱ n okono,
\q2 a kanna ka nanlo keyevi ko kuvon ki ta̱ a̱ kushika̱ ka̱u.
\q1 
\v 15 Kanna ka nanlo ki ta̱ o ko okpo kanna ka wupa,
\q2 kanna ku una̱mgbuka̱tsuma̱ n atakaci,
\q1 kanna ka̱ munuka n kula̱nga̱su,
\q2 kanna ka̱ ka̱yimbi ka kpaɓam,
\q2 kanna ke eleshu n ka̱yimbi ka gbayin,
\q1 
\v 16 kanna ka̱ ku uvula̱ avana n isali i kuvon,
\q2 adama a̱ likuci yi ukanji n nshilya mu ugaɗi.
\q1 
\v 17 Mi ta̱ a̱ ku tuka̱ n atakaci a̱ ubuta̱ u uma,
\q2 ali a wala tsa̱ a̱yimba̱,
\q2 adama a na a nusaka ta̱ Vuzavaguɗu,
\q1 i ta̱ a̱ kutsuwa̱n mpasa tsu mini,
\q2 inyama yi ikyamba i le an tsuta̱.
\q1 
\v 18 A kanna ka wupa ka Vuzavaguɗu,
\q2 azanariya ko azurufa e le,
\q2 a kufuɗa ku isa le ba.
\q1 A̱ ka̱tsuma̱ ka̱ usuɗukpi u cisheꞋe u ni,
\q2 aduniyan dem i ta̱ a kuyaꞋan wu uni,
\q1 wi ta̱ a̱ kutuka̱ n uteku wa aduniyan gogoꞋo lo.
\c 2
\s1 Afada adama irala i Yahuda
\p 
\v 1 Ɓolongi, ɓolongi a̱ ubuta̱ ute,
\q2 a̱ɗa̱ uduniyan u na wi n wono ba,
\q1 
\v 2 kafu makyan ma na a zuwai ma yawa,
\q2 kafu o loko ɗa̱ tsu kopo,
\q1 kafu wupa u Vuzavaguɗu u ta̱wa̱ ɗa̱,
\q2 kafu kanna ka wupa ka Vuzavaguɗu ka̱ ta̱wa̱ ɗa̱.
\q1 
\v 3 La̱nsa̱i Vuzavaguɗu,
\q2 a̱ɗa̱ aza a na i goyoi ka̱ci ka̱ ɗa̱ aduniyan.
\q1 a̱ɗa̱ na yi o kutono wila̱ u ni,
\q2 la̱nsa̱i kasingai n kugoyo ka̱ci ka̱ ɗa̱,
\q2 u gaꞋan ba o sokongu ɗa̱ a kanna ka wupa Vuzavaguɗu.
\q1 
\v 4 Likuci i Gaza yi ta̱ o kokpo ko vuza,
\q2 Ashikelon wo okpo agali.
\q1 I ta̱ o kuloko aza a Ashidodu n kanna a kaci,
\q2 ka̱ta̱ a̱ mutsukpa̱ iɗika i Ekoron.
\q1 
\v 5 Ili ya atakaci i ɗa wa aza a na i o kuyongo a̱ ka̱kina̱ ka mala,
\q2 a̱ɗa̱ uma e Keritiya.
\q1 Kadanshi ka Vuzavaguɗu ki ta̱ a tsurala n avu,
\q2 avu KanaꞋana, iɗika ya aza a̱ Filisitiya.
\q1 I ta̱ a ku una wu,
\q2 ko vuza u kubuwa n wuma ba.
\q1 
\v 6 Ka̱kina̱ ka mala, ki ta̱ o kokpo ubuta̱ u kaguɓa,
\q2 wi ta̱ o ku okpo ubuta̱ wu nguɓi n ushiga wu nkyon.
\q1 
\v 7 Ka̱kina̱ ka mala ka ki ta̱ o kokpo ubuta̱ wu uka̱ni,
\q2 wa aza a kagimi ka kpaꞋa ku Yahuda,
\q2 ubuta̱ u na a kuyaꞋan kaguɓa.
\q1 N kulivi a vaku lo,
\q2 a iꞋuwa ya aza a Ashikelon.
\q1 Vuzavaguɗu Ka̱shile ke le wi ta̱ a̱ kula̱na̱ le,
\q2 wi ta̱ kpamu o kubonoko le n uciyi u le.
\s1 Afada adama a Mowabu n Amona
\p 
\v 8 <<M pana ta̱ ulami u na aza a Mowabu a yaꞋin, n ishikushi i na aza a Amona a yaꞋin,
\q1 tsu na a yaꞋankai uma a̱ va̱ ulami,
\q2 ɗa a yaꞋin a̱ra̱ɗi a danai i ta̱ a kulyaꞋa iɗika i uma a̱ va̱
\q1 
\v 9 <<Adama a nannai,
\q2 mpa Vuzavaguɗu MalaꞋimili, Ka̱shile ki Isaraila,
\q2 n danai, n kucina ta̱ n wuma u va̱,
\q1 mayun Mowabu wi ta̱ o kokpo tsu Sodom,
\q2 Amona tamkpamu tsu Gomora,
\q1 iɗika ya yi ta̱ o kokpo ubuta̱ wa awana,
\q2 n enle a mkpaɗi a na a buwa n ugaꞋin ba ko wannai.
\q1 Uma a̱ va̱ a na a buwai i ta̱ a̱ ku pura̱ ucanuku u le,
\q2 a lyaꞋa uka̱ni u le.>>
\q1 
\v 10 Na ɗa katsupu ka na a̱ kuciya̱ adama a̱ a̱ra̱ɗi e le,
\q2 adama a ishikushi n ulami u na a yaꞋankai uma a Vuzavaguɗu MalaꞋimili,
\q1 
\v 11 Vuzavaguɗu wi ta̱ o ku okpo ili i wovon we ele,
\q2 wi ta̱ a ku una a̱ma̱li aduniyan ra̱ka̱,
\q1 yaba dem aduniyan wi ta̱ a̱ ku kuɗa̱ngu wa̱ a̱ ni,
\q2 a ubuta̱ u na wi n iɗika yi uduniya u na u buwai.
\s1 Afada adama a iɗika i Kushi
\q1 
\v 12 A̱ɗa̱ aza a̱ Kushi
\q2 i ta̱ a ku una ɗa̱ n kotokobi.
\s1 Afada adama a Asiriya
\q1 
\v 13 Vuzavaguɗu wi ta̱ a̱ kuba̱rukpa̱ kukiye ku ni u shilika̱ n uɓon u gaɗi,
\q2 wi ta̱ a ku una Asiriya,
\q1 wi ta̱ o kubonoko Niniva agali,
\q2 uɗekpu tsu kakamba.\x - \xo 2:13 \xt Ish 10:5-34; 14:24-27; Nah 1:1--3:19\x*
\q1 
\v 14 Ushiga wi ili i kuzuwa wi ta̱ a kuvaku e mere,
\q2 nu nnama n kakamba dem.
\q1 Asakali n ma̱kpa̱tuwa̱n,
\q2 i ta̱ o kuyongo a̱ kumiꞋi ku ni.
\q1 Ma̱shi ma̱kpa̱tuwa̱n a̱ kuta̱ n katusu,
\q2 ma agawun tamkpamu a̱ utsutsu,
\q2 i ta̱ a kupalukpa kukpa̱Ꞌa̱,
\q2 a̱ ka̱sukpa̱ ogboli a nɗanga n sida e keteshe.
\q1 
\v 15 Na ɗa likuci yi shi n tsugbayin,
\q2 i na yi shi n ma̱ta̱na̱.
\q1 I na i tsu danaka ka̱ci ka̱ ni,
\q2 <<Vuza vu yoku wi lo ba mpa ɗa koci.>>
\q1 la̱na̱ tsu na wo okpoi agali,
\q2 ubuta̱ wi ivaꞋin yi nnama n kakamba.
\q1 Vuza na baci u walai lo dem,
\q2 wi ta̱ a kuyaꞋan ka̱curu, ka̱ta̱ u gba̱ɗa̱ kaci.
\c 3
\s1 Unushi u Urushelima n ushibi u ni
\q1 
\v 1 Ili ya atakaci a kubana a̱ likuci yi ugbamiwasuvu,
\q2 likuci yi nshinda̱ n modoruko!
\q1 
\v 2 U tsu panaka vuza ba,
\q2 u tsu ushuku a lapulaka yi ba.
\q1 U zuwa ka̱ɗu u Vuzavaguɗu ba,
\q2 u gbaga Ka̱shile ka̱ ni ba.
\q1 
\v 3 Aza e kelime a̱ ni ikawu i yura̱ i ɗa,
\q2 ayaꞋinfada a̱ ni nkunzukunzu n ɗa n na n tsu uta̱ n kulivi,
\q2 ele na a tsu buka ili yi asa ba.
\q1 
\v 4 Eneki a̱ ni uma a kavama a ɗa,
\q2 aza a kalyaꞋa a ɗa.
\q1 Anan ganu a̱ ni a natukpai,
\q2 ili i na yi ciɗa.
\q1 Ɗa kpamu a̱ kpa̱ɗa̱i kutono wila̱ u Ka̱shile.
\q1 
\v 5 Vuzavaguɗu na wi punu a̱ likuci ya,
\q2 wi ta̱ n usuɓi,
\q2 u tsu nusa ba.
\q1 Usana lakam u tsu yaꞋan ta̱ kasingai,
\q2 babu usana u na u tsu kpa̱ɗa̱ kuyaꞋan kasingai,
\q2 ama uma a gbani-gbani i n wono ba.
\q1 
\v 6 Vuzavaguɗu u danai, <<N takpa ta̱ kumaci ka aduniyan,
\q2 ubuta̱ wu utsura u le u na̱mgba̱ ta̱.
\q1 Ɗa kpamu n la̱nga̱sa̱i uye u le,
\q2 ko vuza u tsu tono punu ba.
\q1 O bonokoi likuci i le agali,
\q2 ali ko vuza a buwaka punu ba,
\q2 ko vuza u buwa punu ba.
\q1 
\v 7 N danai, <Mayun uma a̱ va̱ a pana wovon u va̱,
\q2 ushuku n kulapulu.>
\q1 I o kudoku kutakpa asuvu e le,
\q2 a kakuna ka na m ɓarangi le ba.
\q1 Ama ɗa o doku yaꞋin mali,
\q2 a natukpa ka̱ci ke le.
\q1 
\v 8 Vuzavaguɗu u danai,
\q2 << Vanai, kanna ka na n kuɗa̱nga̱ n yaꞋan kadanshi adama a̱ɗa̱,
\q1 adama a na n sheshe ta̱ n ɓolongu uma aduniyan,
\q2 n tsugono kakau,
\q1 adama a na n tsuwa̱nka̱ le wupa u va̱,
\q2 n asuvu a usuɗukpi a̱ va̱ dem.
\q1 adama asuvu a usuɗukpi e cisheꞋe tsu va̱,
\q2 i ta̱ o kusongu aduniyan ra̱ka̱.
\q1 
\v 9 <<Ka̱ta̱ m bonoko elentsu a uma a̱ va̱ ciɗa,
\q2 adama a na ra̱ka̱ vi le e ɗeke kula ku Vuzavaguɗu,
\q2 ka̱ta̱ a cikpa yi n ka̱ɗu ke te.
\q1 
\v 10 Ili i na i ɗikai a nɗolu n Kushi,
\q2 aza a na a ci cikpa mu,
\q2 uma a̱ va̱ a na i uwaciwi,
\q2 i ta̱ a̱ kutuka̱ mu n kuneꞋe.
\q1 
\v 11 <<A kanna ka nanlo i e kuneke wu wono ba,
\q2 adama a ugbamiwasuvu u na vu yaꞋankai mu ba,
\q1 adama a na mi ta̱ a ku utuka̱ aza ugbamiwasuvu,
\q2 n aza a̱ra̱ɗi e mere ma̱ ɗa̱.
\q1 Yi o kudoku ya yaꞋan ugbamukaci,
\q2 a kusan ku ciɗa ku va̱ ba.
\q1 
\v 12 Ama mi ta̱ a̱ kuka̱sukpa̱ aza a̱ ma̱riki,
\q2 n aza a na o goyoi ka̱ci ke le,
\q2 aza a na e nekei a̱ɗu e le u Vuzavaguɗu.
\q1 
\v 13 Aza a Isaraila a na a buwai,
\q2 i o kudoku a yaꞋan unushi ba,
\q2 i kpamu a kudansa aꞋuwa ba,
\q2 adama a na kelentsu ka aꞋuwa ki o kuyongo a una̱ u le ba.
\q1 I ta̱ a kuyaꞋan kalina a vaku,
\q2 ko vuza u kurikpa̱sa̱ le ba.>>
\q1 
\v 14 YaꞋan ishipa, avu Sihiyona,
\q2 ɗa̱ngusa̱ ka̱la̱ka̱tsu ka̱u avu Isaraila.
\q1 YaꞋan ma̱za̱nga̱ n izoshi,
\q2 avu Urushelima.
\q1 
\v 15 Vuzavaguɗu u takpaka wu ta̱ atakaci a̱ nu,
\q2 ɗa kpamu u lokoi irala i nu.
\q1 Vuzavaguɗu, mogono mi Isaraila, mi ta̱ e mere ma̱ nu,
\q2 vi a kupana wovon ba.
\q1 
\v 16 A kanna ka nanlo i ta̱ a kudana Urushelima,
\q2 <<Ka̱ta̱ vu pana wovon ba, avu Sihiyona,
\q2 ka̱ta̱ vu ka̱sukpa̱ ekiye a̱ nu a̱ kuwa̱ ba.
\q1 
\v 17 Vuzavaguɗu Ka̱shile ka̱ nu ki ta̱ e mere ma̱ nu,
\q2 kovonshi kaꞋa ka na ka̱ tsu ciya̱ ulyaꞋi.
\q1 Wi ta̱ a kuyaꞋan ma̱za̱nga̱ n avu,
\q2 wi ta̱ a ku sabaꞋasaka wu n ucigi u ni,
\q2 wi ta̱ a kuyaꞋan ma̱za̱nga̱ n avu a̱ ubuta̱ u kuyaꞋan ki ishipa.
\q1 
\v 18 Tsu na a ci yaꞋan a kanna ka̱ ka̱ɗiva̱,
\q2 mi ta̱ a kutakpaka ɗa̱ ka gbani-gbani,
\q2 i o kudoku e neke ɗa̱ wono ba.
\q1 
\v 19 A ayin a nanlo, mi ta̱ a kutakacika,
\q2 aza a na i a kutakacika wu ra̱ka̱,
\q1 mi ta̱ a ku wawa ma̱kutsuma̱,
\q2 mi ta̱ kpamu o kuɓolongu aza a na ishi a wacuwai.
\q1 Mi ta̱ o kubonoko wono ucikpi,
\q2 i ta̱ a kulyaꞋa kula aduniyan.
\q1 
\v 20 A ayin a nanlo mi ta̱ o kubonoko ɗa̱ a kpaꞋa,
\q2 n ɓolongu ɗa̱ a̱ ubuta̱ ute,
\q2 ka̱ta̱ n zuwa ɗa̱ i yaꞋan kula.
\q1 i ciya̱ ucikpi a ubuta̱ u uma aduniyan dem,
\q2 a ayin a na baci m bonokoi ɗa̱ n una̱singai u ɗa̱.>>
\q1 Mpa Vuzavaguɗu n dansai.
