\v 6 \wj \w En|strong="H5921"\w* \w cuanto|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w extranjeros|strong="H1121"\w* \w que|strong="H5921"\w* \w se|strong="H1961"\w* adhieren \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w para|strong="H5921"\w* servirle, \w que|strong="H5921"\w* aman \w el|strong="H5921"\w* \w Nombre|strong="H8034"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w para|strong="H5921"\w* ser sus esclavos, \w guardan|strong="H8104"\w* \w el|strong="H5921"\w* \w sábado|strong="H7676"\w* sin profanarlo \w y|strong="H5921"\w* \w se|strong="H1961"\w* aferran \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w Pacto|strong="H1285"\w*,\wj*
\v 7 \wj ordenaré \w que|strong="H3588"\w* sean conducidos \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w Santa|strong="H6944"\w* Montaña \w y|strong="H3588"\w* \w se|strong="H5921"\w* alegren \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Oración|strong="H8605"\w*. Sus \w holocaustos|strong="H5930"\w* \w y|strong="H3588"\w* sus \w sacrificios|strong="H2077"\w* serán aceptos \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w altar|strong="H4196"\w*, \w porque|strong="H3588"\w* \w mi|strong="H5921"\w* \w Casa|strong="H1004"\w* será llamada \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Oración|strong="H8605"\w* \w para|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w*.\wj*
\v 8 Palabra \w de|strong="H5921"\w* \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd*, Quien reúne \w a|strong="H3068"\w* \w los|strong="H5921"\w* dispersos \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: \wj \w Aún|strong="H5750"\w* reuniré \w con|strong="H5921"\w* \w él|strong="H5921"\w* \w a|strong="H3068"\w* sus ya reunidos.\wj*
\p 
\v 9 Vengan \w a|strong="H3068"\w* devorar, ustedes \w todas|strong="H3605"\w* \w bestias|strong="H2416"\w* del \w campo|strong="H7704"\w* y del \w bosque|strong="H3293"\w*.
\v 10 Sus centinelas están \w ciegos|strong="H5787"\w*, \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* ignorantes. \w Todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w son|strong="H3808"\w* \w perros|strong="H3611"\w* mudos, incapaces de ladrar, \w soñolientos|strong="H1957"\w* \w echados|strong="H7901"\w*, amantes del sueño.
\v 11 \w Son|strong="H3808"\w* \w perros|strong="H3611"\w* insaciables. \w Son|strong="H3808"\w* \w los|strong="H1992"\w* \w pastores|strong="H7462"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w saben|strong="H3045"\w* distinguir. \w Todos|strong="H3605"\w* \w ellos|strong="H1992"\w* siguen \w sus|strong="H1992"\w* propios \w caminos|strong="H1870"\w*, \w cada|strong="H3605"\w* uno tras \w su|strong="H1992"\w* propio \w provecho|strong="H1215"\w*.
\v 12 Vengan, dicen, bebamos \w vino|strong="H3196"\w*. \w Embriaguémonos|strong="H5433"\w* con licor, y el \w día|strong="H3117"\w* de \w mañana|strong="H4279"\w* \w será|strong="H1961"\w* \w como|strong="H1961"\w* \w hoy|strong="H3117"\w*, \w o|strong="H3068"\w* aún \w más|strong="H3499"\w* abundante.
\c 57
\s1 La idolatría de Israel
\p 
\v 1 \w El|strong="H5921"\w* \w justo|strong="H6662"\w* perece \w y|strong="H3588"\w* \w no|strong="H3588"\w* hay quien piense \w en|strong="H5921"\w* ello. Mueren \w los|strong="H5921"\w* piadosos. \w No|strong="H3588"\w* hay quien entienda \w que|strong="H3588"\w* \w el|strong="H5921"\w* \w justo|strong="H6662"\w* \w es|strong="H3588"\w* quitado \w ante|strong="H6440"\w* \w la|strong="H5921"\w* aflicción.
\v 2 \w Él|strong="H5921"\w* entra \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w paz|strong="H7965"\w*. \w Los|strong="H5921"\w* \w que|strong="H5921"\w* \w anduvieron|strong="H1980"\w* \w en|strong="H5921"\w* su \w camino|strong="H1980"\w* \w de|strong="H5921"\w* rectitud \w descansan|strong="H5117"\w* \w en|strong="H5921"\w* sus lechos.
\v 3 Pero acérquense ustedes, \w oh|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* la hechicera, \w generación|strong="H2233"\w* \w de|strong="H1121"\w* un adúltero y \w de|strong="H1121"\w* una prostituta.
\v 4 ¿\w De|strong="H5921"\w* \w quién|strong="H4310"\w* \w se|strong="H5921"\w* burlan? ¿\w Contra|strong="H5921"\w* \w quién|strong="H4310"\w* abren \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w y|strong="H5921"\w* sueltan \w la|strong="H5921"\w* \w lengua|strong="H3956"\w*? ¿\w No|strong="H3808"\w* \w son|strong="H6310"\w* ustedes \w hijos|strong="H3206"\w* \w rebeldes|strong="H6588"\w*, \w generación|strong="H2233"\w* \w mentirosa|strong="H8267"\w*,
\v 5 \w que|strong="H3605"\w* arden \w de|strong="H8478"\w* lujuria \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* \w todo|strong="H3605"\w* \w árbol|strong="H6086"\w* \w frondoso|strong="H7488"\w*, y \w degüellan|strong="H7819"\w* \w a|strong="H3068"\w* sus \w hijos|strong="H3206"\w* \w en|strong="H8478"\w* \w los|strong="H3605"\w* valles y \w en|strong="H8478"\w* las hendiduras \w de|strong="H8478"\w* las peñas?
\p 
\v 6 \wj Tu \w parte|strong="H2506"\w* \w está|strong="H1992"\w* \w en|strong="H5921"\w* \w las|strong="H1992"\w* piedras lisas \w del|strong="H5921"\w* valle. \w Ellas|strong="H1992"\w* son tu porción, \w porque|strong="H5921"\w* \w a|strong="H3068"\w* \w ellas|strong="H1992"\w* \w derramaste|strong="H8210"\w* \w libación|strong="H5262"\w* \w y|strong="H1571"\w* \w ofreciste|strong="H5927"\w* sacrificios. ¿\w Me|strong="H5921"\w* aplacaré ante \w estas|strong="H1992"\w* \w cosas|strong="H1992"\w*?\wj*
\v 7 \wj \w Pusiste|strong="H7760"\w* tu \w cama|strong="H4904"\w* \w sobre|strong="H5921"\w* una montaña \w alta|strong="H1364"\w* \w y|strong="H1571"\w* encumbrada. \w Allí|strong="H8033"\w* \w también|strong="H1571"\w* \w subiste|strong="H5927"\w* \w a|strong="H3068"\w* ofrecer \w sacrificio|strong="H2077"\w*.\wj*
\v 8 \wj Detrás \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w puerta|strong="H1817"\w* \w y|strong="H3588"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* batiente \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w puerta|strong="H1817"\w* \w pusiste|strong="H7760"\w* tu señal. \w Te|strong="H3588"\w* desnudaste alejado \w de|strong="H3588"\w* Mí. \w Subiste|strong="H5927"\w* \w y|strong="H3588"\w* extendiste tu \w cama|strong="H4904"\w*, hiciste un acuerdo \w con|strong="H3588"\w* \w ellos|strong="H1992"\w*. Amaste \w su|strong="H1992"\w* \w cama|strong="H4904"\w* donde viste \w su|strong="H1992"\w* desnudez.\wj*
\v 9 \wj Fuiste \w al|strong="H5704"\w* \w rey|strong="H4428"\w* \w con|strong="H5704"\w* \w ungüento|strong="H8081"\w* \w y|strong="H5704"\w* aumentaste tus perfumes. \w Enviaste|strong="H7971"\w* \w a|strong="H3068"\w* tus \w mensajeros|strong="H6735"\w* \w lejos|strong="H7350"\w* \w y|strong="H5704"\w* los bajaste \w al|strong="H5704"\w* \tl Seol\tl*.\wj*
\v 10 \wj \w Te|strong="H5921"\w* cansaste \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w largo|strong="H7230"\w* \w camino|strong="H1870"\w*, pero \w no|strong="H3808"\w* dijiste: \w No|strong="H3808"\w* hay esperanza. \w Hallaste|strong="H4672"\w* fuerza renovada. \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w no|strong="H3808"\w* \w te|strong="H5921"\w* desanimaste.\wj*
\p 
\v 11 \wj ¿\w De|strong="H5921"\w* \w quién|strong="H4310"\w* tuviste \w temor|strong="H3372"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* negaras tu fe, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* acordaras \w de|strong="H5921"\w* \w Mí|strong="H5921"\w*, \w ni|strong="H3808"\w* \w te|strong="H5921"\w* vino \w al|strong="H5921"\w* \w pensamiento|strong="H3820"\w*? ¿\w La|strong="H5921"\w* razón \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w cual|strong="H4310"\w* \w no|strong="H3808"\w* \w me|strong="H5921"\w* temes \w no|strong="H3808"\w* \w fue|strong="H3808"\w* \w por|strong="H5921"\w* \w mi|strong="H5921"\w* silencio durante un largo tiempo?\wj*
\v 12 \wj Yo \w denuncio|strong="H5046"\w* tu \w justicia|strong="H6666"\w* y tus \w obras|strong="H4639"\w*, \w porque|strong="H3808"\w* ellas \w no|strong="H3808"\w* te servirán de \w provecho|strong="H3276"\w*\wj*
\v 13 \wj cuando clames \w que|strong="H3605"\w* te libren tus ídolos. Pero \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w ellos|strong="H3605"\w* \w los|strong="H3605"\w* \w llevará|strong="H5375"\w* \w el|strong="H3605"\w* \w viento|strong="H7307"\w*. Un \w soplo|strong="H7307"\w* \w los|strong="H3605"\w* arrebatará. Sin embargo, \w el|strong="H3605"\w* \w que|strong="H3605"\w* confía en \w Mí|strong="H5375"\w*, \w heredará|strong="H5157"\w* \w la|strong="H3605"\w* tierra, y \w poseerá|strong="H3423"\w* \w mi|strong="H5375"\w* \w Santa|strong="H6944"\w* Montaña.\wj*
\p 
\v 14 \wj \w Se|strong="H5971"\w* dirá: Allanen, allanen la calzada. Preparen el \w camino|strong="H1870"\w*. Quiten los \w tropiezos|strong="H4383"\w* del \w camino|strong="H1870"\w* \w de|strong="H5971"\w* mi \w pueblo|strong="H5971"\w*.\wj*
\v 15 \wj \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w Alto|strong="H7311"\w* \w y|strong="H3588"\w* \w Excelso|strong="H4791"\w*, Morador \w Eterno|strong="H5703"\w*, \w su|strong="H3588"\w* \w Nombre|strong="H8034"\w* \w es|strong="H3588"\w* \w El|strong="H3588"\w* \w Santo|strong="H6918"\w*, dice: \w Yo|strong="H3588"\w* moro \w en|strong="H3588"\w* las \w alturas|strong="H4791"\w* \w y|strong="H3588"\w* \w en|strong="H3588"\w* santidad, \w Pero|strong="H3588"\w* estoy \w con|strong="H3588"\w* \w los|strong="H3588"\w* \w de|strong="H3588"\w* \w espíritu|strong="H7307"\w* \w que|strong="H3588"\w* siente pesar \w porque|strong="H3588"\w* \w me|strong="H3588"\w* ofendió \w y|strong="H3588"\w* \w está|strong="H7931"\w* humillado. Estoy \w para|strong="H3588"\w* reanimar \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w de|strong="H3588"\w* \w espíritu|strong="H7307"\w* \w humilde|strong="H8217"\w* \w y|strong="H3588"\w* vivificar \w el|strong="H3588"\w* \w corazón|strong="H3820"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* quebrantados.\wj*
\v 16 \wj \w No|strong="H3808"\w* contenderé \w para|strong="H3588"\w* \w siempre|strong="H5769"\w*, \w ni|strong="H3808"\w* estaré airado \w para|strong="H3588"\w* \w siempre|strong="H5769"\w*, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* aliento \w y|strong="H3588"\w* las almas \w que|strong="H3588"\w* creé decaerían \w delante|strong="H6440"\w* \w de|strong="H3588"\w* Mí.\wj*
\v 17 \wj Estuve airado y lo \w herí|strong="H5221"\w* \w a|strong="H3068"\w* causa de la \w iniquidad|strong="H5771"\w* de su codicia. Me oculté y estuve airado, y él continuó apartado \w por|strong="H1870"\w* el \w camino|strong="H1870"\w* de su \w corazón|strong="H3820"\w*.\wj*
\v 18 \wj \w Vi|strong="H7200"\w* sus \w caminos|strong="H1870"\w*, pero lo \w sanaré|strong="H7495"\w*. Lo guiaré y le daré consuelo, \w a|strong="H3068"\w* él y \w a|strong="H3068"\w* los que se conduelen de él.\wj*
\v 19 \wj Crearé la alabanza de los \w labios|strong="H8193"\w*: ¡\w Paz|strong="H7965"\w*, \w paz|strong="H7965"\w*, para el que está \w lejos|strong="H7350"\w* y para el que está \w cerca|strong="H7138"\w*!\wj* dice \nd \w Yavé|strong="H3068"\w*\nd*. \wj \w Y|strong="H3068"\w* \w lo|strong="H7350"\w* \w sanaré|strong="H7495"\w*.\wj*
\v 20 \wj \w Los|strong="H3588"\w* perversos \w son|strong="H3588"\w* \w como|strong="H3588"\w* \w el|strong="H3588"\w* \w mar|strong="H3220"\w* tempestuoso \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w puede|strong="H3201"\w* aquietarse. Sus \w aguas|strong="H4325"\w* remueven \w la|strong="H3588"\w* basura \w y|strong="H3588"\w* \w el|strong="H3588"\w* lodo.\wj*
\v 21 \wj \w No|strong="H7563"\w* hay \w paz|strong="H7965"\w* para los perversos,\wj* dice mi \nd ʼElohim\nd*.
\c 58
\s1 El verdadero ayuno
\p 
\v 1 \wj ¡Proclama \w a|strong="H3068"\w* \w voz|strong="H6963"\w* en cuello, no te detengas! ¡\w Alza|strong="H7311"\w* tu \w voz|strong="H6963"\w* como una \w trompeta|strong="H7782"\w*! Denuncia su \w rebelión|strong="H6588"\w* \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w*, sus \w pecados|strong="H2403"\w* \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H5971"\w* \w Jacob|strong="H3290"\w*,\wj*
\v 2 \wj quienes me \w buscan|strong="H1875"\w* \w cada|strong="H3117"\w* \w día|strong="H3117"\w* y quieren saber mis \w caminos|strong="H1870"\w*, como \add si fuera\add* un pueblo \w que|strong="H3808"\w* practicó \w justicia|strong="H6664"\w* y \w que|strong="H3808"\w* \w no|strong="H3808"\w* abandonó la \w Ordenanza|strong="H4941"\w* de su \nd ʼElohim\nd*. Me piden decisiones \w justas|strong="H6664"\w*. \w Se|strong="H3808"\w* complacen en la cercanía de \nd ʼElohim\nd*. \wj*
\v 3 \wj Dicen: ¿Para \w qué|strong="H4100"\w* \w ayunamos|strong="H6684"\w*, \w si|strong="H2005"\w* \w no|strong="H3808"\w* haces caso? ¿\w Humillamos|strong="H6031"\w* nuestras \w almas|strong="H5315"\w*, \w si|strong="H2005"\w* \w no|strong="H3808"\w* \w te|strong="H5315"\w* das \w por|strong="H4100"\w* \w entendido|strong="H3045"\w*? \wj*
\p \wj \w Ciertamente|strong="H2005"\w* en \w el|strong="H3605"\w* \w día|strong="H3117"\w* de \w ayuno|strong="H6685"\w* buscan su propio \w deseo|strong="H2656"\w* y oprimen \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus trabajadores.\wj*
\v 4 \wj \w Ciertamente|strong="H2005"\w*, ayunan para contiendas y debates, para herir con el puño \w inicuamente|strong="H7562"\w*. \w No|strong="H3808"\w* ayunen como \w hoy|strong="H3117"\w*, \w si|strong="H2005"\w* quieren \w que|strong="H3808"\w* su \w voz|strong="H6963"\w* sea escuchada \w en|strong="H5221"\w* \w lo|strong="H3808"\w* \w alto|strong="H4791"\w*.\wj*
\v 5 \wj ¿\w Es|strong="H1961"\w* \w éste|strong="H2088"\w* el \w ayuno|strong="H6685"\w* \w que|strong="H3117"\w* \w Yo|strong="H5315"\w* escogí, \w que|strong="H3117"\w* el hombre \w aflija|strong="H6031"\w* su \w alma|strong="H5315"\w* de \w día|strong="H3117"\w*, \w que|strong="H3117"\w* incline la \w cabeza|strong="H7218"\w* \w como|strong="H1961"\w* un junco y \w se|strong="H1961"\w* acueste \w sobre|strong="H1961"\w* tela áspera y ceniza? ¿\w Llamarán|strong="H7121"\w* \w a|strong="H3068"\w* eso \w ayuno|strong="H6685"\w*, \w es|strong="H1961"\w* \w decir|strong="H7121"\w*, \w día|strong="H3117"\w* \w agradable|strong="H7522"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*?\wj*
\p 
\v 6 \wj ¿\w El|strong="H3605"\w* \w ayuno|strong="H6685"\w* \w que|strong="H3808"\w* Yo escogí \w no|strong="H3808"\w* \w es|strong="H2088"\w* \w más|strong="H3808"\w* bien \w desatar|strong="H6605"\w* las ligaduras de maldad, \w soltar|strong="H7971"\w* las cargas de opresión, dejar \w ir|strong="H7971"\w* \w libres|strong="H2670"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* quebrantados y \w que|strong="H3808"\w* rompan \w todo|strong="H3605"\w* \w yugo|strong="H4133"\w*?\wj*
\v 7 \wj ¿\w No|strong="H3808"\w* \w es|strong="H3588"\w* \w que|strong="H3588"\w* compartas tu \w pan|strong="H3899"\w* \w con|strong="H3588"\w* \w el|strong="H3588"\w* hambriento \w y|strong="H3588"\w* albergues \w en|strong="H3588"\w* \w casa|strong="H1004"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* pobres \w errantes|strong="H4788"\w*, \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w veas|strong="H7200"\w* al \w desnudo|strong="H6174"\w*, \w lo|strong="H3808"\w* \w cubras|strong="H3680"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H3588"\w* \w escondas|strong="H5956"\w* \w de|strong="H3588"\w* tu hermano?\wj*
\v 8 \wj Entonces tu luz \w nacerá|strong="H1234"\w* como el alba \w y|strong="H3519"\w* tu recuperación \w brotará|strong="H6779"\w* \w pronto|strong="H4120"\w*. Tu \w justicia|strong="H6664"\w* \w irá|strong="H1980"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti \w y|strong="H3519"\w* la \w gloria|strong="H3519"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* será tu retaguardia.\wj*
\p 
\v 9 \w Entonces|strong="H5493"\w* \w invocarás|strong="H7121"\w*, y \nd \w Yavé|strong="H3068"\w*\nd* te escuchará. \w Clamarás|strong="H7768"\w*, y Él dirá: \wj ¡\w Aquí|strong="H2005"\w* estoy!\wj*
\p \w Si|strong="H2005"\w* quitas de \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de ti el \w yugo|strong="H4133"\w*, el dedo amenazador y el \w hablar|strong="H1696"\w* perversidad,
\v 10 \w si|strong="H5315"\w* tu \w alma|strong="H5315"\w* provee para el hambriento y sacias al \w alma|strong="H5315"\w* \w afligida|strong="H6031"\w*, tu luz irradiará en \w la|strong="H7646"\w* tenebrosidad y tu \w oscuridad|strong="H2822"\w* será como el mediodía.
\v 11 \nd \w Yavé|strong="H3068"\w*\nd* \w te|strong="H5315"\w* pastoreará \w siempre|strong="H8548"\w*. Tu \w alma|strong="H5315"\w* \w se|strong="H1961"\w* saciará en las sequías y dará vigor \w a|strong="H3068"\w* tus \w huesos|strong="H6106"\w*. \w Serás|strong="H1961"\w* un \w huerto|strong="H1588"\w* bien regado, \w como|strong="H1961"\w* manantial \w de|strong="H4325"\w* \w agua|strong="H4325"\w* \w que|strong="H3808"\w* \w nunca|strong="H3808"\w* falta.
\v 12 \w Los|strong="H3427"\w* \w tuyos|strong="H4480"\w* reedificarán las ruinas \w antiguas|strong="H5769"\w*. Levantarán \w los|strong="H3427"\w* cimientos \w de|strong="H4480"\w* muchas \w generaciones|strong="H1755"\w* \w que|strong="H4480"\w* \w estaban|strong="H3427"\w* destruidos y serás \w llamado|strong="H7121"\w* \w reparador|strong="H1443"\w* \w de|strong="H4480"\w* brechas, \w restaurador|strong="H7725"\w* \w de|strong="H4480"\w* calzadas \w para|strong="H4480"\w* descansar.
\s1 La delicia del Sábado
\p 
\v 13 Si detienes \w tu|strong="H6213"\w* \w pie|strong="H7272"\w* en \w el|strong="H6213"\w* \w sábado|strong="H7676"\w* para \w no|strong="H6213"\w* \w hacer|strong="H6213"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* te plazca en mi \w día|strong="H3117"\w* \w santo|strong="H6918"\w*, si llamas al \w sábado|strong="H7676"\w* \w tu|strong="H6213"\w* delicia, \w Santo|strong="H6918"\w*, \w glorioso|strong="H3513"\w* \w de|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd*, y \w lo|strong="H1697"\w* honras, sin seguir en tus propios \w caminos|strong="H1870"\w*, ni buscar \w tu|strong="H6213"\w* placer, ni \w hablar|strong="H1696"\w* tus propias \w palabras|strong="H1697"\w*,
\v 14 \w entonces|strong="H3588"\w* \w te|strong="H5921"\w* deleitarás \w en|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \wj \w Te|strong="H5921"\w* subiré \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* alturas \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w y|strong="H3588"\w* \w te|strong="H5921"\w* alimentaré \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w herencia|strong="H5159"\w* \w de|strong="H5921"\w* tu padre \w Jacob|strong="H3290"\w*. \wj* \w Porque|strong="H3588"\w* \w habló|strong="H1696"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\c 59
\s1 Acusación contra Israel y promesa de restauración
\p 
\v 1 En verdad la \w mano|strong="H3027"\w* de \nd \w Yavé|strong="H3068"\w*\nd* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w acortó|strong="H7114"\w* para \w salvar|strong="H3467"\w*, \w ni|strong="H3808"\w* su \w oído|strong="H8085"\w* \w se|strong="H3808"\w* endureció para \w no|strong="H3808"\w* \w escuchar|strong="H8085"\w*.
\v 2 \w Pero|strong="H3588"\w* las \w iniquidades|strong="H5771"\w* \w de|strong="H4480"\w* ustedes \w los|strong="H1961"\w* separaron \w de|strong="H4480"\w* \w su|strong="H3588"\w* \nd ʼElohim\nd* \w y|strong="H3588"\w* sus \w pecados|strong="H2403"\w* ocultaron \w su|strong="H3588"\w* \w rostro|strong="H6440"\w* \w de|strong="H4480"\w* ustedes \w para|strong="H3588"\w* \w no|strong="H3588"\w* \w escuchar|strong="H8085"\w*.
\v 3 \w Porque|strong="H3588"\w* sus \w manos|strong="H3709"\w* están contaminadas \w de|strong="H3588"\w* \w sangre|strong="H1818"\w*, \w y|strong="H3588"\w* sus dedos, \w con|strong="H3588"\w* \w iniquidad|strong="H5766"\w*. Sus \w labios|strong="H8193"\w* \w dicen|strong="H1696"\w* \w mentira|strong="H8267"\w*, \w su|strong="H3588"\w* \w lengua|strong="H3956"\w* murmura perversidad.
\v 4 \w No|strong="H5921"\w* hay quien \w clame|strong="H7121"\w* \w por|strong="H5921"\w* \w justicia|strong="H6664"\w*. \w No|strong="H5921"\w* hay quien discuta \w con|strong="H5921"\w* fidelidad. \w Se|strong="H5921"\w* apoyan \w en|strong="H5921"\w* \w palabras|strong="H1696"\w* \w vanas|strong="H7723"\w* \w y|strong="H5921"\w* \w dicen|strong="H1696"\w* falsedad. \w Conciben|strong="H2029"\w* \w perversidad|strong="H5999"\w* \w y|strong="H5921"\w* dan \w a|strong="H3068"\w* luz iniquidad.
\v 5 Incuban huevos de víboras y tejen tela de araña. El que come de sus huevos muere y del que es aplastado sale una víbora.
\v 6 Sus telarañas \w no|strong="H3808"\w* sirven \w para|strong="H1961"\w* ropa. \w Son|strong="H1961"\w* tejidos \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w cubren|strong="H3680"\w*. Sus \w obras|strong="H4639"\w* \w son|strong="H1961"\w* de \w iniquidad|strong="H2555"\w* y un \w hecho|strong="H1961"\w* de \w violencia|strong="H2555"\w* \w está|strong="H1961"\w* en sus \w manos|strong="H3709"\w*.
\v 7 Sus \w pies|strong="H7272"\w* \w corren|strong="H7323"\w* hacia el \w mal|strong="H7451"\w*. Se apresuran \w a|strong="H3068"\w* derramar \w sangre|strong="H1818"\w* \w inocente|strong="H5355"\w*. Sus \w pensamientos|strong="H4284"\w* son \w de|strong="H1818"\w* iniquidad. Desolación \w y|strong="H5355"\w* \w destrucción|strong="H7701"\w* hay \w en|strong="H5355"\w* sus \w caminos|strong="H4546"\w*.
\v 8 \w No|strong="H3808"\w* \w conocen|strong="H3045"\w* \w camino|strong="H1870"\w* de \w paz|strong="H7965"\w*, \w ni|strong="H3808"\w* hay \w justicia|strong="H4941"\w* en \w sus|strong="H1992"\w* senderos. \w Sus|strong="H1992"\w* \w caminos|strong="H1870"\w* \w son|strong="H3808"\w* \w torcidos|strong="H3808"\w*. \w Cualquiera|strong="H3605"\w* \w que|strong="H3808"\w* ande \w por|strong="H1870"\w* \w ellos|strong="H1992"\w* \w no|strong="H3808"\w* tendrá \w paz|strong="H7965"\w*.
\p 
\v 9 \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w se|strong="H5921"\w* \w aleja|strong="H7368"\w* \w de|strong="H4480"\w* \w nosotros|strong="H5921"\w* \w la|strong="H5921"\w* \w justicia|strong="H6666"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* rectitud \w no|strong="H3808"\w* \w nos|strong="H5921"\w* alcanza. \w Esperamos|strong="H6960"\w* luz, pero hay tenebrosidad. \add Esperamos\add* claridad, \add pero\add* andamos \w en|strong="H5921"\w* \w oscuridad|strong="H2822"\w*.
\v 10 Como \w ciegos|strong="H5787"\w* \w palpamos|strong="H1659"\w* la \w pared|strong="H7023"\w*. Andamos \w a|strong="H3068"\w* tientas como si no tuviéramos \w ojos|strong="H5869"\w*. \w Tropezamos|strong="H3782"\w* tanto al mediodía como cuando llega la noche. Estamos como \w muertos|strong="H4191"\w* entre los vigorosos.
\v 11 \w Todos|strong="H3605"\w* \w nosotros|strong="H3605"\w* gruñimos \w como|strong="H1993"\w* \w osos|strong="H1677"\w*, y gemimos \w con|strong="H4480"\w* lástima \w como|strong="H1993"\w* palomas. \w Esperamos|strong="H6960"\w* \w justicia|strong="H4941"\w* y no \w la|strong="H3605"\w* hay, salvación, y está \w lejos|strong="H7368"\w* \w de|strong="H4480"\w* \w nosotros|strong="H3605"\w*.
\p 
\v 12 \w Porque|strong="H3588"\w* nuestras transgresiones \w se|strong="H3045"\w* \w multiplicaron|strong="H7235"\w* \w delante|strong="H5048"\w* \w de|strong="H3588"\w* Ti. Nuestros \w pecados|strong="H2403"\w* \w testifican|strong="H6030"\w* \w contra|strong="H5048"\w* nosotros, \w porque|strong="H3588"\w* nuestras transgresiones permanecen \w con|strong="H3588"\w* nosotros. \w Reconocemos|strong="H3045"\w* nuestras \w iniquidades|strong="H5771"\w*.
\v 13 Transgredimos y negamos \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*. Volvimos atrás y dejamos \w de|strong="H1697"\w* seguir \w a|strong="H3068"\w* nuestro \nd ʼElohim\nd*. \w Hablamos|strong="H1696"\w* \w de|strong="H1697"\w* opresión y \w rebelión|strong="H5627"\w*. \w Concebimos|strong="H2029"\w* y expresamos \w de|strong="H1697"\w* \w corazón|strong="H3820"\w* \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* \w mentira|strong="H8267"\w*.
\v 14 \w La|strong="H3588"\w* \w justicia|strong="H6666"\w* \w es|strong="H3588"\w* rechazada \w y|strong="H3588"\w* \w la|strong="H3588"\w* equidad \w está|strong="H5975"\w* \w lejos|strong="H7350"\w*. \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* verdad \w tropezó|strong="H3782"\w* \w en|strong="H3588"\w* \w la|strong="H3588"\w* calle \w y|strong="H3588"\w* \w la|strong="H3588"\w* rectitud \w no|strong="H3808"\w* \w puede|strong="H3201"\w* entrar.
\v 15 \w La|strong="H3588"\w* verdad \w está|strong="H1961"\w* ausente. \w El|strong="H3588"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* \w aparta|strong="H5493"\w* del \w mal|strong="H7451"\w* \w se|strong="H1961"\w* convierte \w en|strong="H3588"\w* un despojo.
\p Ahora \nd \w Yavé|strong="H3068"\w*\nd* \w vio|strong="H7200"\w* esto. \w Es|strong="H1961"\w* desagradable \w a|strong="H3068"\w* \w Él|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w haya|strong="H1961"\w* \w justicia|strong="H4941"\w*.
\v 16 \w Vio|strong="H7200"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w había|strong="H3588"\w* alguno \w y|strong="H3588"\w* \w se|strong="H1931"\w* asombró \w de|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* haya \w quien|strong="H1931"\w* \w se|strong="H1931"\w* interponga. \w Lo|strong="H1931"\w* \w salvó|strong="H3467"\w* \w su|strong="H1931"\w* \w brazo|strong="H2220"\w* \w y|strong="H3588"\w* \w lo|strong="H1931"\w* afirmó \w su|strong="H1931"\w* \w misma|strong="H1931"\w* \w justicia|strong="H6666"\w*.
\v 17 Se cubrió con la coraza \w de|strong="H3847"\w* \w justicia|strong="H6666"\w* y con casco \w de|strong="H3847"\w* salvación sobre su \w cabeza|strong="H7218"\w*. Se envolvió en ropas \w de|strong="H3847"\w* \w venganza|strong="H5359"\w* y se cubrió \w de|strong="H3847"\w* \w celo|strong="H7068"\w* como con un \w manto|strong="H4598"\w*.
\v 18 \w Él|strong="H5921"\w* retribuirá \w ira|strong="H2534"\w* \w para|strong="H5921"\w* sus \w enemigos|strong="H6862"\w* \w según|strong="H5921"\w* sus obras, recompensa \w para|strong="H5921"\w* sus \w adversarios|strong="H6862"\w*. Retribuirá \w por|strong="H5921"\w* completo \w a|strong="H3068"\w* \w las|strong="H5921"\w* tierras \w de|strong="H5921"\w* \w las|strong="H5921"\w* costas.
\v 19 Desde \w el|strong="H3588"\w* \w occidente|strong="H4628"\w* \w temerán|strong="H3372"\w* al \w Nombre|strong="H8034"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w gloria|strong="H3519"\w* desde \w donde|strong="H8034"\w* \w nace|strong="H4217"\w* \w el|strong="H3588"\w* \w sol|strong="H8121"\w*, \w porque|strong="H3588"\w* vendrá \w como|strong="H3588"\w* \w río|strong="H5104"\w* encajonado impulsado \w por|strong="H3588"\w* \w el|strong="H3588"\w* \w soplo|strong="H7307"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 20 \wj Vendrá el \w Redentor|strong="H1350"\w* \w a|strong="H3068"\w* \w Sion|strong="H6726"\w*, \w a|strong="H3068"\w* los que regresaron de la iniquidad de \w Jacob|strong="H3290"\w*,\wj* \w dice|strong="H5002"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 21 \wj \w Este|strong="H2063"\w* \w será|strong="H3808"\w* \w mi|strong="H5921"\w* \w Pacto|strong="H1285"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w*,\wj* \w dice|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd*: \wj \w Mi|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w que|strong="H3808"\w* derramé \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*. Mis \w Palabras|strong="H1697"\w* \w que|strong="H3808"\w* \w puse|strong="H7760"\w* \w en|strong="H5921"\w* tu \w boca|strong="H6310"\w* \w no|strong="H3808"\w* \w se|strong="H5921"\w* apartarán \w jamás|strong="H5769"\w* \w de|strong="H5921"\w* tu \w boca|strong="H6310"\w*, \w ni|strong="H3808"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* tus descendientes, \w ni|strong="H3808"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* descendientes \w de|strong="H5921"\w* \w ellos|strong="H5921"\w* \w desde|strong="H5704"\w* \w ahora|strong="H6258"\w* \w y|strong="H5921"\w* \w para|strong="H5704"\w* \w siempre|strong="H5769"\w*,\wj* \w dice|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\c 60
\s1 El resplandor de Sion
\p 
\v 1 ¡\w Levántate|strong="H6965"\w*, resplandece, \w porque|strong="H3588"\w* llegó tu Luz! ¡\w La|strong="H5921"\w* \w gloria|strong="H3519"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w resplandeció|strong="H2224"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*!
\v 2 \w En|strong="H5921"\w* verdad, \w la|strong="H5921"\w* tenebrosidad \w cubrirá|strong="H3680"\w* \w la|strong="H5921"\w* tierra, densa \w oscuridad|strong="H2822"\w*, \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w pueblos|strong="H3816"\w*. \w Pero|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* resplandecerá \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H3588"\w* \w aparecerá|strong="H7200"\w* \w su|strong="H3588"\w* \w gloria|strong="H3519"\w* \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*.
\v 3 Los gentiles \w acudirán|strong="H1980"\w* \w a|strong="H3068"\w* tu luz, los \w reyes|strong="H4428"\w*, \w al|strong="H4428"\w* \w resplandor|strong="H5051"\w* de tu amanecer.
\p 
\v 4 \w Levanta|strong="H5375"\w* tus \w ojos|strong="H5869"\w* \w alrededor|strong="H5439"\w* \w y|strong="H5921"\w* \w mira|strong="H7200"\w*. \w Todos|strong="H3605"\w* \w ellos|strong="H5921"\w* \w se|strong="H5921"\w* reunieron \w y|strong="H5921"\w* vinieron \w a|strong="H3068"\w* \w ti|strong="H5921"\w*. Tus \w hijos|strong="H1121"\w* vendrán \w de|strong="H5921"\w* \w lejos|strong="H7350"\w* \w y|strong="H5921"\w* tus \w hijas|strong="H1323"\w* serán traídas \w en|strong="H5921"\w* brazos.
\v 5 \w Entonces|strong="H3588"\w* \w verás|strong="H7200"\w* \w y|strong="H3588"\w* resplandecerás. Tu \w corazón|strong="H3824"\w* \w se|strong="H5921"\w* maravillará \w y|strong="H3588"\w* \w se|strong="H5921"\w* regocijará \w porque|strong="H3588"\w* \w vuelve|strong="H2015"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w* \w la|strong="H5921"\w* abundancia \w del|strong="H5921"\w* \w mar|strong="H3220"\w*. \w La|strong="H5921"\w* riqueza \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* viene \w a|strong="H3068"\w* \w ti|strong="H5921"\w*.
\v 6 Una \w multitud|strong="H8229"\w* de \w camellos|strong="H1581"\w* te \w cubrirá|strong="H3680"\w*, \w dromedarios|strong="H1070"\w* de \w Madián|strong="H4080"\w* y de Efa. Vendrán \w todos|strong="H3605"\w* \w los|strong="H3605"\w* de Sabá. \w Traerán|strong="H5375"\w* \w oro|strong="H2091"\w* \w e|strong="H3068"\w* \w incienso|strong="H3828"\w*, y proclamarán las \w alabanzas|strong="H8416"\w* de \nd \w Yavé|strong="H3068"\w*\nd*.
\v 7 Serán reunidos \w para|strong="H5921"\w* \w ti|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* rebaños \w de|strong="H5921"\w* \w Cedar|strong="H6938"\w*, \w los|strong="H5921"\w* carneros \w de|strong="H5921"\w* Nebaiot \w te|strong="H5921"\w* \w servirán|strong="H8334"\w*. \w Subirán|strong="H5927"\w* \w como|strong="H5921"\w* ofrenda \w agradable|strong="H7522"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w altar|strong="H4196"\w*, \w y|strong="H5921"\w* glorificaré \w el|strong="H5921"\w* esplendor \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w Casa|strong="H1004"\w*.
\p 
\v 8 ¿\w Quiénes|strong="H4310"\w* son éstos \w que|strong="H4310"\w* vuelan \w como|strong="H5645"\w* \w nubes|strong="H5645"\w*, y \w como|strong="H5645"\w* palomas \w a|strong="H3068"\w* su palomar?
\v 9 \wj \w Ciertamente|strong="H3588"\w*, las costas esperarán \w en|strong="H3588"\w* Mí. Las naves \w de|strong="H3588"\w* \w Tarsis|strong="H8659"\w* vendrán \w a|strong="H3068"\w* \w la|strong="H3588"\w* cabeza. Traerán \w a|strong="H3068"\w* tus \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w lejos|strong="H7350"\w* \w con|strong="H3588"\w* \w su|strong="H3588"\w* \w plata|strong="H3701"\w* \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w oro|strong="H2091"\w* \w por|strong="H3588"\w* causa del \w Nombre|strong="H8034"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* \w y|strong="H3588"\w* del \w Santo|strong="H6918"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, Quien \w te|strong="H3588"\w* llenó \w de|strong="H3588"\w* esplendor.\wj*
\p 
\v 10 \wj \w Extranjeros|strong="H1121"\w* reedificarán tus \w muros|strong="H2346"\w*, \w y|strong="H3588"\w* sus \w reyes|strong="H4428"\w* \w te|strong="H3588"\w* \w servirán|strong="H8334"\w*. \w Aunque|strong="H3588"\w* \w te|strong="H3588"\w* castigué \w en|strong="H3588"\w* mi furor, \w en|strong="H3588"\w* mi buena \w voluntad|strong="H7522"\w* tendré \w misericordia|strong="H7355"\w* \w de|strong="H3588"\w* ti.\wj*
\v 11 \wj Tus \w puertas|strong="H8179"\w* estarán \w continuamente|strong="H8548"\w* \w abiertas|strong="H6605"\w*. \w No|strong="H3808"\w* serán cerradas de \w día|strong="H3119"\w* \w ni|strong="H3808"\w* de \w noche|strong="H3915"\w*, para \w que|strong="H3808"\w* las \w riquezas|strong="H2428"\w* de las \w naciones|strong="H1471"\w* sean traídas \w a|strong="H3068"\w* ti, y sus \w reyes|strong="H4428"\w* \w conducidos|strong="H5090"\w* \w a|strong="H3068"\w* ti.\wj*
\v 12 \wj \w Porque|strong="H3588"\w* \w la|strong="H3588"\w* \w nación|strong="H1471"\w* \w o|strong="H3068"\w* \w el|strong="H3588"\w* \w reino|strong="H4467"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w te|strong="H3588"\w* \w sirva|strong="H5647"\w* \w perecerá|strong="H3808"\w*. Esa \w nación|strong="H1471"\w* \w será|strong="H3808"\w* completamente destruida.\wj*
\p 
\v 13 \wj Vendrá \w a|strong="H3068"\w* ti el esplendor del \w Líbano|strong="H3844"\w* con el ciprés, el abeto \w y|strong="H3519"\w* el pino, para hermosear el \w lugar|strong="H4725"\w* de mi \w Santuario|strong="H4720"\w*. Yo haré esplendoroso el estrado de mis \w pies|strong="H7272"\w*.\wj*
\v 14 \wj \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w que|strong="H5921"\w* \w te|strong="H5921"\w* \w afligieron|strong="H6031"\w* vendrán encorvados \w a|strong="H3068"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w los|strong="H1121"\w* \w que|strong="H5921"\w* \w te|strong="H5921"\w* escarnecieron \w se|strong="H5921"\w* postrarán \w a|strong="H3068"\w* \w las|strong="H5921"\w* plantas \w de|strong="H5921"\w* tus \w pies|strong="H7272"\w*. \w Te|strong="H5921"\w* \w llamarán|strong="H7121"\w* \w Ciudad|strong="H5892"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w Sion|strong="H6726"\w* \w del|strong="H5921"\w* \w Santo|strong="H6918"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.\wj*
\p 
\v 15 \wj Aunque \w fuiste|strong="H1961"\w* \w abandonada|strong="H5800"\w* y \w aborrecida|strong="H8130"\w*, sin \w que|strong="H1961"\w* nadie transitara \w por|strong="H8478"\w* ti, Yo te convierto \w en|strong="H8478"\w* esplendor \w perpetuo|strong="H5769"\w*, \w el|strong="H5674"\w* \w gozo|strong="H4885"\w* \w de|strong="H8478"\w* \w todas|strong="H1755"\w* las \w generaciones|strong="H1755"\w*.\wj*
\v 16 \wj \w Mamarás|strong="H3243"\w* \w la|strong="H3588"\w* \w leche|strong="H2461"\w* \w de|strong="H3588"\w* las \w naciones|strong="H1471"\w* \w y|strong="H3588"\w* \w el|strong="H3588"\w* pecho \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w reyes|strong="H4428"\w*. Entenderás \w que|strong="H3588"\w* \w Yo|strong="H3588"\w*, \nd \w Yavé|strong="H3068"\w*\nd*, soy tu \w Salvador|strong="H3467"\w*, tu \w Redentor|strong="H1350"\w*, \w el|strong="H3588"\w* Fuerte \w de|strong="H3588"\w* \w Jacob|strong="H3290"\w*.\wj*
\v 17 \wj \w En|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* bronce, te traeré \w oro|strong="H2091"\w*. \w En|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* \w hierro|strong="H1270"\w*, te traeré \w plata|strong="H3701"\w*. \w En|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* \w madera|strong="H6086"\w*, bronce. \w En|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* piedras, \w hierro|strong="H1270"\w*. Te daré la \w paz|strong="H7965"\w* \w como|strong="H8478"\w* administrador, y la \w justicia|strong="H6666"\w* \w como|strong="H8478"\w* supervisor.\wj*
\v 18 \wj \w No|strong="H3808"\w* \w se|strong="H3808"\w* \w oirá|strong="H8085"\w* \w más|strong="H5750"\w* \w en|strong="H5750"\w* tu tierra: ¡\w Violencia|strong="H2555"\w*! \w Ni|strong="H3808"\w* \w dentro|strong="H5750"\w* \w de|strong="H5750"\w* tus fronteras: ¡Ruina! ¡\w Destrucción|strong="H7701"\w*! Tus \w muros|strong="H2346"\w* \w se|strong="H3808"\w* \w llamarán|strong="H7121"\w* Salvación, y tus \w puertas|strong="H8179"\w* \w Alabanza|strong="H8416"\w*.\wj*
\p 
\v 19 \wj El \w sol|strong="H8121"\w* \w nunca|strong="H3808"\w* \w jamás|strong="H5769"\w* te \w servirá|strong="H1961"\w* \w como|strong="H1961"\w* luz \w de|strong="H5750"\w* \w día|strong="H3119"\w*, \w ni|strong="H3808"\w* el \w resplandor|strong="H5051"\w* \w de|strong="H5750"\w* la \w luna|strong="H3394"\w* te alumbrará. \nd \w Yavé|strong="H3068"\w*\nd* \w será|strong="H1961"\w* tu Luz \w perpetua|strong="H5769"\w*. El \nd ʼElohim\nd* tuyo \w será|strong="H1961"\w* tu Esplendor.\wj*
\v 20 \wj Tu \w sol|strong="H8121"\w* \w no|strong="H3808"\w* \w se|strong="H1961"\w* ocultará \w jamás|strong="H5769"\w*, \w ni|strong="H3808"\w* menguará tu luna, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w será|strong="H1961"\w* tu Luz \w perpetua|strong="H5769"\w*. \w Los|strong="H1961"\w* \w días|strong="H3117"\w* \w de|strong="H3588"\w* tu luto terminarán.\wj*
\v 21 \wj Tu \w pueblo|strong="H5971"\w*, \w todos|strong="H3605"\w* \w ellos|strong="H3027"\w* \w justos|strong="H6662"\w*, \w heredarán|strong="H3423"\w* \w para|strong="H5971"\w* \w siempre|strong="H5769"\w* \w la|strong="H3605"\w* tierra, retoños \w de|strong="H5971"\w* mi \w plantío|strong="H4302"\w*, \w obra|strong="H4639"\w* \w de|strong="H5971"\w* mis \w manos|strong="H3027"\w*, \w para|strong="H5971"\w* \w que|strong="H5971"\w* Yo sea glorificado.\wj*
\v 22 \wj El \w más|strong="H1471"\w* \w pequeño|strong="H6996"\w* equivaldrá \w a|strong="H3068"\w* 1.000, y el \w menor|strong="H6996"\w* \w a|strong="H3068"\w* una \w nación|strong="H1471"\w* poderosa. Yo, \nd \w Yavé|strong="H3068"\w*\nd*, apresuraré esto en su \w tiempo|strong="H6256"\w*.\wj*
\c 61
\s1 Las buenas noticias
\p 
\v 1 \w El|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* \w está|strong="H5921"\w* \w sobre|strong="H5921"\w* \w Mí|strong="H5921"\w*, \w porque|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H5921"\w* \w ungió|strong="H4886"\w*. \w Me|strong="H5921"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* predicar buenas noticias \w a|strong="H3068"\w* \w los|strong="H5921"\w* afligidos, \w a|strong="H3068"\w* vendar \w los|strong="H5921"\w* corazones quebrantados, \w a|strong="H3068"\w* proclamar \w libertad|strong="H1865"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* cautivos \w y|strong="H5921"\w* \w libertad|strong="H1865"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* presos,
\v 2 \w a|strong="H3068"\w* promulgar \w el|strong="H3605"\w* \w año|strong="H8141"\w* de \w la|strong="H3605"\w* buena \w voluntad|strong="H7522"\w* de \nd \w Yavé|strong="H3068"\w*\nd* y \w el|strong="H3605"\w* \w día|strong="H3117"\w* de \w venganza|strong="H5359"\w* de nuestro \nd ʼElohim\nd* y \w a|strong="H3068"\w* consolar \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3117"\w* lloran.
\v 3 \add Me envió\add* \w a|strong="H3068"\w* ordenar que \w a|strong="H3068"\w* los enlutados \w de|strong="H8478"\w* \w Sion|strong="H6726"\w* se les \w dé|strong="H8478"\w* diadema \w de|strong="H8478"\w* hermosura \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* ceniza, \w aceite|strong="H8081"\w* \w de|strong="H8478"\w* \w gozo|strong="H8342"\w* \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* lamento, y el \w manto|strong="H4594"\w* \w de|strong="H8478"\w* \w alabanza|strong="H8416"\w* \w en|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* desaliento \w para|strong="H5414"\w* que sean \w llamados|strong="H7121"\w* árboles \w de|strong="H8478"\w* \w justicia|strong="H6664"\w*, plantados \w por|strong="H8478"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w para|strong="H5414"\w* \w gloria|strong="H6287"\w* suya.
\p 
\v 4 Reconstruirán las ruinas \w antiguas|strong="H5769"\w*. Levantarán los viejos escombros. Restaurarán las \w ciudades|strong="H5892"\w* \w destruidas|strong="H2723"\w*, los escombros de muchas \w generaciones|strong="H1755"\w*.
\v 5 Se presentarán \w extranjeros|strong="H1121"\w* y pastorearán sus rebaños. Sus labradores y viñadores serán forasteros.
\p 
\v 6 Pero ustedes serán \w llamados|strong="H7121"\w* \w sacerdotes|strong="H3548"\w* de \nd \w Yavé|strong="H3068"\w*\nd*. Dirán de ustedes: \w Ministros|strong="H8334"\w* de nuestro \nd ʼElohim\nd*. Comerán la riqueza de las \w naciones|strong="H1471"\w* \w y|strong="H3519"\w* se ufanarán en las \w riquezas|strong="H2428"\w* de ellas.
\v 7 \w En|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* su \w vergüenza|strong="H3639"\w* \w tendrán|strong="H1961"\w* doble honra y \w en|strong="H8478"\w* vez \w de|strong="H8478"\w* su humillación gritarán \w de|strong="H8478"\w* júbilo \w por|strong="H8478"\w* su herencia. \w Por|strong="H8478"\w* \w tanto|strong="H3651"\w*, \w poseerán|strong="H3423"\w* el doble \w en|strong="H8478"\w* su tierra y \w tendrán|strong="H1961"\w* \w gozo|strong="H8057"\w* \w eterno|strong="H5769"\w*.
\p 
\v 8 \wj \w Porque|strong="H3588"\w* \w Yo|strong="H3588"\w*, \nd \w Yavé|strong="H3068"\w*\nd*, amo \w la|strong="H3588"\w* \w justicia|strong="H4941"\w*. \w Aborrezco|strong="H8130"\w* \w la|strong="H3588"\w* rapiña \w para|strong="H3588"\w* \w el|strong="H3588"\w* \w holocausto|strong="H5930"\w*. \w Pero|strong="H3588"\w* \w a|strong="H3068"\w* ellos les \w daré|strong="H5414"\w* fielmente \w su|strong="H3588"\w* \w recompensa|strong="H6468"\w* \w y|strong="H3588"\w* \w haré|strong="H5414"\w* \w con|strong="H3588"\w* ellos un \w Pacto|strong="H1285"\w* \w perpetuo|strong="H5769"\w*.\wj*
\v 9 \w Su|strong="H1992"\w* \w descendencia|strong="H2233"\w* será conocida \w entre|strong="H8432"\w* \w las|strong="H1992"\w* \w naciones|strong="H1471"\w* \w y|strong="H3588"\w* \w sus|strong="H1992"\w* retoños \w entre|strong="H8432"\w* \w los|strong="H1992"\w* \w pueblos|strong="H5971"\w*. \w Todos|strong="H3605"\w* \w los|strong="H1992"\w* \w que|strong="H3588"\w* \w los|strong="H1992"\w* \w vean|strong="H7200"\w* reconocerán \w que|strong="H3588"\w* \w ellos|strong="H1992"\w* \w son|strong="H3588"\w* \w el|strong="H3588"\w* \w linaje|strong="H2233"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w bendijo|strong="H1288"\w*.
\p 
\v 10 \w Me|strong="H3588"\w* regocijaré \w en|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w en|strong="H3588"\w* gran manera. \w Mi|strong="H5315"\w* \w alma|strong="H5315"\w* se alegrará \w en|strong="H3588"\w* \w mi|strong="H5315"\w* \nd ʼElohim\nd*, \w porque|strong="H3588"\w* \w me|strong="H3588"\w* cubrió \w con|strong="H3588"\w* ropas \w de|strong="H3588"\w* salvación. \w Me|strong="H3588"\w* envolvió \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w manto|strong="H4598"\w* \w de|strong="H3588"\w* \w justicia|strong="H6666"\w*. \w Como|strong="H3588"\w* \w a|strong="H3068"\w* un novio \w me|strong="H3588"\w* atavió \w con|strong="H3588"\w* una diadema, \w como|strong="H3588"\w* una novia se adorna \w con|strong="H3588"\w* sus joyas.
\v 11 \w La|strong="H3588"\w* tierra \w produce|strong="H3318"\w* \w su|strong="H3588"\w* retoño \w y|strong="H3588"\w* \w el|strong="H3588"\w* huerto permite \w que|strong="H3588"\w* brote \w la|strong="H3588"\w* semilla. \w Así|strong="H3651"\w* \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd* \w producirá|strong="H6779"\w* \w justicia|strong="H6666"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w alabanza|strong="H8416"\w* \w delante|strong="H5048"\w* \w de|strong="H3588"\w* \w todas|strong="H3605"\w* las \w naciones|strong="H1471"\w*.
\c 62
\s1 Restauración de Israel
\p 
\v 1 \wj \w Por|strong="H4616"\w* amor \w a|strong="H3068"\w* \w Sion|strong="H6726"\w* \w no|strong="H3808"\w* guardaré silencio. \w Por|strong="H4616"\w* amor \w a|strong="H3068"\w* Jerusalén \w no|strong="H3808"\w* descansaré \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* rompa \w la|strong="H1197"\w* aurora \w de|strong="H5704"\w* su \w justicia|strong="H6664"\w* \w y|strong="H5704"\w* arda \w la|strong="H1197"\w* antorcha \w de|strong="H5704"\w* su salvación.\wj*
\v 2 Entonces las \w naciones|strong="H1471"\w* \w verán|strong="H7200"\w* tu \w justicia|strong="H6664"\w*, \w y|strong="H3519"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w reyes|strong="H4428"\w*, tu esplendor. Te será dado un \w nombre|strong="H8034"\w* \w nuevo|strong="H2319"\w* \w que|strong="H6310"\w* pronunciará \w la|strong="H3605"\w* \w boca|strong="H6310"\w* de \nd \w Yavé|strong="H3068"\w*\nd*.
\v 3 \w Serás|strong="H1961"\w* \w corona|strong="H5850"\w* de esplendor en la \w mano|strong="H3027"\w* de \nd \w Yavé|strong="H3068"\w*\nd* y diadema \w real|strong="H4410"\w* en la palma \add de la mano\add* de tu \nd ʼElohim\nd*.
\v 4 \w Nunca|strong="H3808"\w* \w más|strong="H5750"\w* serás llamada \w la|strong="H3588"\w* \w Desamparada|strong="H5800"\w*, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* dirá \w más|strong="H5750"\w* \w de|strong="H3588"\w* tu tierra, \w Desolada|strong="H8077"\w*. \w Sino|strong="H3588"\w* serás llamada mi Deleite, \w y|strong="H3588"\w* tu tierra, Desposada, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w se|strong="H3808"\w* deleita \w en|strong="H3588"\w* ti, \w y|strong="H3588"\w* tu tierra \w será|strong="H3808"\w* desposada.
\v 5 \w Pues|strong="H3588"\w* \w como|strong="H3588"\w* \w el|strong="H5921"\w* joven \w se|strong="H5921"\w* desposa \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w virgen|strong="H1330"\w*, \w así|strong="H3588"\w* \w se|strong="H5921"\w* desposarán tus \w hijos|strong="H1121"\w* \w contigo|strong="H5921"\w*. \w Como|strong="H3588"\w* \w el|strong="H5921"\w* novio \w se|strong="H5921"\w* regocija \w por|strong="H5921"\w* \w la|strong="H5921"\w* novia, \w así|strong="H3588"\w* tu \nd ʼElohim\nd* \w se|strong="H5921"\w* regocijará \w por|strong="H5921"\w* \w ti|strong="H5921"\w*.
\p 
\v 6 ¡Oh Jerusalén, \w sobre|strong="H5921"\w* tus \w muros|strong="H2346"\w* puse \w centinelas|strong="H8104"\w*! \w Nunca|strong="H3808"\w* \w callarán|strong="H2814"\w* \w en|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w día|strong="H3117"\w* \w ni|strong="H3808"\w* \w en|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w noche|strong="H3915"\w*. Ustedes \w los|strong="H5921"\w* \w que|strong="H3808"\w* \w se|strong="H5921"\w* acuerdan \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w no|strong="H3808"\w* \w se|strong="H5921"\w* den reposo.
\v 7 No le \w den|strong="H7760"\w* reposo \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* Él restablezca \w a|strong="H3068"\w* Jerusalén, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* convierta \w a|strong="H3068"\w* Jerusalén \w en|strong="H5704"\w* la \w alabanza|strong="H8416"\w* \w de|strong="H5704"\w* la tierra.
\p 
\v 8 \nd \w Yavé|strong="H3068"\w*\nd* \w juró|strong="H7650"\w* con la mano \w derecha|strong="H3225"\w* \w y|strong="H5797"\w* su \w brazo|strong="H2220"\w* poderoso: \wj \w Ya|strong="H3068"\w* no \w entregaré|strong="H5414"\w* tu \w trigo|strong="H1715"\w* \w como|strong="H5750"\w* \w comida|strong="H3978"\w* \w a|strong="H3068"\w* tus enemigos, ni \w los|strong="H1121"\w* \w extranjeros|strong="H1121"\w* se \w beberán|strong="H8354"\w* \w más|strong="H5750"\w* \w el|strong="H1121"\w* \w vino|strong="H8492"\w* \w por|strong="H5750"\w* \w el|strong="H1121"\w* cual tú trabajaste.\wj*
\v 9 \wj \w Los|strong="H3588"\w* \w que|strong="H3588"\w* \w lo|strong="H6908"\w* cosechan \w lo|strong="H6908"\w* comerán, \w y|strong="H3588"\w* \w alabarán|strong="H1984"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w Los|strong="H3588"\w* \w que|strong="H3588"\w* \w lo|strong="H6908"\w* recolectan \w lo|strong="H6908"\w* \w beberán|strong="H8354"\w* \w en|strong="H3588"\w* \w los|strong="H3588"\w* \w patios|strong="H2691"\w* \w de|strong="H3588"\w* mi \w Santuario|strong="H6944"\w*.\wj*
\p 
\v 10 Pasen, pasen \w por|strong="H5921"\w* \w las|strong="H5921"\w* \w puertas|strong="H8179"\w*. Despejen \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w para|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w*. Allanen, allanen \w la|strong="H5921"\w* \w calzada|strong="H4546"\w*, \w y|strong="H5921"\w* quiten \w las|strong="H5921"\w* piedras. ¡Alcen \w pendón|strong="H5251"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w*!
\v 11 \w Ciertamente|strong="H2009"\w* \nd \w Yavé|strong="H3068"\w*\nd* envía un pregón hasta el confín \w de|strong="H6440"\w* la tierra. \wj Digan \w a|strong="H3068"\w* la \w hija|strong="H1323"\w* \w de|strong="H6440"\w* \w Sion|strong="H6726"\w*: ¡\w Mira|strong="H2009"\w*, tu \w Salvador|strong="H3468"\w* viene! ¡\w Mira|strong="H2009"\w*, su \w recompensa|strong="H6468"\w* viene con Él y su \w obra|strong="H6468"\w* lo precede!\wj*
\v 12 Entonces \w los|strong="H1992"\w* \w llamarán|strong="H7121"\w* \w Pueblo|strong="H5971"\w* \w Santo|strong="H6944"\w*, \w Redimidos|strong="H1350"\w* \w de|strong="H5971"\w* \nd \w Yavé|strong="H3068"\w*\nd*, y \w a|strong="H3068"\w* ti te \w llamarán|strong="H7121"\w* \w Ciudad|strong="H5892"\w* Deseada, \w Ciudad|strong="H5892"\w* \w no|strong="H3808"\w* \w Desamparada|strong="H5800"\w*.
\c 63
\s1 El día de la venganza
\p 
\v 1 ¿\w Quién|strong="H4310"\w* \w es|strong="H2088"\w* \w éste|strong="H2088"\w* \w que|strong="H4310"\w* viene de Edom, de \w Bosra|strong="H1224"\w*, con ropas enrojecidas, \w éste|strong="H2088"\w* de ropa hermosa \w que|strong="H4310"\w* marcha en la grandeza de su \w poder|strong="H3581"\w*? \wj Yo, \w el|strong="H4310"\w* \w que|strong="H4310"\w* \w hablo|strong="H1696"\w* con \w justicia|strong="H6666"\w*, \w grande|strong="H7227"\w* para \w salvar|strong="H3467"\w*. \wj*
\v 2 ¿\w Por|strong="H4069"\w* \w qué|strong="H1869"\w* tu manto está rojo y tu ropa \w como|strong="H4069"\w* la del \w que|strong="H1869"\w* \w pisó|strong="H1869"\w* en el lagar?
\p 
\v 3 \wj Yo solo pisé \w el|strong="H5921"\w* lagar, \w y|strong="H5921"\w* \w ninguno|strong="H3605"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w* estuvo conmigo. \w Los|strong="H5921"\w* aplasté \w con|strong="H5921"\w* \w mi|strong="H5921"\w* \w ira|strong="H2534"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* pisoteé \w con|strong="H5921"\w* \w mi|strong="H5921"\w* \w furor|strong="H2534"\w*. Su sangre \w salpicó|strong="H5137"\w* mis mantos \w y|strong="H5921"\w* manché \w todas|strong="H3605"\w* mis ropas.\wj*
\v 4 \wj \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w venganza|strong="H5359"\w* está \w en|strong="H3588"\w* mi \w corazón|strong="H3820"\w*, \w y|strong="H3588"\w* vino \w el|strong="H3588"\w* \w año|strong="H8141"\w* \w de|strong="H3588"\w* mis \w redimidos|strong="H1350"\w*. \wj*
\v 5 \wj Miré, y no había \w quien|strong="H1931"\w* ayudara. Me asombré de \w que|strong="H1931"\w* no había \w quien|strong="H1931"\w* ayudara. Entonces me \w salvó|strong="H3467"\w* mi propio \w brazo|strong="H2220"\w* y me \w sostuvo|strong="H5564"\w* mi \w ira|strong="H2534"\w*.\wj*
\v 6 \wj Pisoteé \w pueblos|strong="H5971"\w* con mi \w ira|strong="H2534"\w*. Los embriagué con mi \w furor|strong="H2534"\w* y derramé su sangre en la tierra. \wj*
\s1 Bondad de Yavé
\p 
\v 7 Recordaré \w las|strong="H5921"\w* \w misericordias|strong="H7356"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w las|strong="H5921"\w* \w alabanzas|strong="H8416"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w según|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* hizo \w por|strong="H5921"\w* \w nosotros|strong="H3605"\w*, \w y|strong="H5921"\w* su \w gran|strong="H7227"\w* \w bondad|strong="H2898"\w* \w hacia|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w que|strong="H5921"\w* \w Él|strong="H5921"\w* \w les|strong="H5921"\w* concedió \w según|strong="H5921"\w* su compasión \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w abundancia|strong="H7230"\w* \w de|strong="H5921"\w* sus \w misericordias|strong="H7356"\w*.
\v 8 \w Pues|strong="H1961"\w* dijo: \wj Ciertamente \w ellos|strong="H1992"\w* \w son|strong="H1961"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w*, \w hijos|strong="H1121"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w mienten|strong="H8266"\w*. \wj*\w Él|strong="H1121"\w* \w fue|strong="H1961"\w* \w el|strong="H1121"\w* \w Salvador|strong="H3467"\w* \w de|strong="H1121"\w* \w ellos|strong="H1992"\w*.
\v 9 \w Él|strong="H1931"\w* \w fue|strong="H1931"\w* angustiado en \w toda|strong="H3605"\w* \w angustia|strong="H6869"\w* \w de|strong="H6440"\w* \w ellos|strong="H1931"\w*. \w El|strong="H1931"\w* \w Ángel|strong="H4397"\w* \w de|strong="H6440"\w* \w su|strong="H1931"\w* \w Presencia|strong="H6440"\w* \w los|strong="H3605"\w* \w salvó|strong="H3467"\w*. \w Por|strong="H6440"\w* \w su|strong="H1931"\w* amor y \w su|strong="H1931"\w* \w clemencia|strong="H2551"\w* \w los|strong="H3605"\w* \w redimió|strong="H1350"\w*, y \w los|strong="H3605"\w* cargó \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w de|strong="H6440"\w* \w la|strong="H1931"\w* antigüedad.
\p 
\v 10 Pero \w ellos|strong="H1992"\w* \w se|strong="H1931"\w* rebelaron y entristecieron \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w Espíritu|strong="H7307"\w* \w Santo|strong="H6944"\w*, por \w lo|strong="H1931"\w* \w cual|strong="H1931"\w* \w se|strong="H1931"\w* \w volvió|strong="H2015"\w* \w su|strong="H1931"\w* enemigo. \w Él|strong="H1931"\w* \w mismo|strong="H1931"\w* combatió contra \w ellos|strong="H1992"\w*.
\p 
\v 11 \w Entonces|strong="H3117"\w* recordó los \w días|strong="H3117"\w* \w antiguos|strong="H5769"\w* \w de|strong="H5971"\w* su esclavo \w Moisés|strong="H4872"\w* y \w de|strong="H5971"\w* su \w pueblo|strong="H5971"\w*, \add y dijo\add*: \wj ¿Dónde está el \w que|strong="H5971"\w* los \w sacó|strong="H5927"\w* del \w mar|strong="H3220"\w* con el \w pastor|strong="H7462"\w* \w de|strong="H5971"\w* su \w rebaño|strong="H6629"\w*? ¿Dónde está el \w que|strong="H5971"\w* \w puso|strong="H7760"\w* su \w Espíritu|strong="H7307"\w* \w Santo|strong="H6944"\w* en él,\wj*
\v 12 \wj \w el|strong="H6213"\w* \w que|strong="H4325"\w* envió su \w glorioso|strong="H8597"\w* \w brazo|strong="H2220"\w* para \w que|strong="H4325"\w* estuviera \w a|strong="H3068"\w* la mano \w derecha|strong="H3225"\w* \w de|strong="H6440"\w* \w Moisés|strong="H4872"\w* y \w lo|strong="H6213"\w* \w guió|strong="H3212"\w* con su \w brazo|strong="H2220"\w* \w glorioso|strong="H8597"\w*, \w el|strong="H6213"\w* \w que|strong="H4325"\w* dividió \w el|strong="H6213"\w* mar \w ante|strong="H6440"\w* ellos y se ganó renombre \w eterno|strong="H5769"\w*,\wj*
\v 13 \wj el \w que|strong="H3808"\w* los condujo por el fondo del mar, como \w se|strong="H3808"\w* conduce el \w caballo|strong="H5483"\w* por el \w desierto|strong="H4057"\w* \w sin|strong="H3808"\w* tropezar?\wj*
\p 
\v 14 \w El|strong="H6213"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5971"\w* \nd \w Yavé|strong="H3068"\w*\nd* les dio \w reposo|strong="H5117"\w* \w así|strong="H3651"\w* \w como|strong="H3651"\w* al ganado \w que|strong="H5971"\w* \w baja|strong="H3381"\w* al valle. \w Así|strong="H3651"\w* condujiste \w a|strong="H3068"\w* \w tu|strong="H6213"\w* \w pueblo|strong="H5971"\w* \w para|strong="H5971"\w* darte un \w Nombre|strong="H8034"\w* \w glorioso|strong="H8597"\w*.
\s1 Reclamo del profeta Isaías
\p 
\v 15 \w Mira|strong="H7200"\w* desde el \w cielo|strong="H8064"\w* y contempla desde tu \w santa|strong="H6944"\w* y gloriosa morada. ¿Dónde están tu \w celo|strong="H7068"\w* y tus obras poderosas? ¿Se estrecharon la conmoción de tu corazón y tu compasión hacia mí?
\v 16 \w Pero|strong="H3588"\w* Tú eres nuestro Padre. \w Aunque|strong="H3588"\w* Abraham nos ignora \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* nos \w reconoce|strong="H5234"\w*, Tú, oh \nd \w Yavé|strong="H3068"\w*\nd*, eres nuestro Padre. \w Redentor|strong="H1350"\w* nuestro, desde \w la|strong="H3588"\w* \w eternidad|strong="H5769"\w* \w es|strong="H3588"\w* tu \w Nombre|strong="H8034"\w*.
\p 
\v 17 ¿\w Por|strong="H1870"\w* \w qué|strong="H4100"\w*, \w oh|strong="H4100"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w nos|strong="H4100"\w* dejas desviar de tus \w caminos|strong="H1870"\w* y endureces nuestro \w corazón|strong="H3820"\w* \w a|strong="H3068"\w* tu \w temor|strong="H3374"\w*? Regresa \w por|strong="H1870"\w* amor \w a|strong="H3068"\w* tus esclavos, las \w tribus|strong="H7626"\w* de tu \w heredad|strong="H5159"\w*.
\v 18 Por poco \w tiempo|strong="H4705"\w* tu \w pueblo|strong="H5971"\w* \w santo|strong="H6944"\w* \w poseyó|strong="H3423"\w* tu \w Santuario|strong="H4720"\w*. Nuestros \w enemigos|strong="H6862"\w* lo pisotearon.
\v 19 \w Somos|strong="H1961"\w* \w como|strong="H1961"\w* aquellos \w sobre|strong="H5921"\w* quienes Tú \w nunca|strong="H3808"\w* señoreaste, \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* cuales \w nunca|strong="H3808"\w* \w fue|strong="H1961"\w* \w invocado|strong="H7121"\w* tu \w Nombre|strong="H8034"\w*.
\c 64
\p 
\v 1 ¡Oh, \w si|strong="H6440"\w* rasgaras los cielos y descendieras, y \w se|strong="H3045"\w* estremecieran las montañas \w ante|strong="H6440"\w* tu \w Presencia|strong="H6440"\w*!
\v 2 Como fuego abrasador \w de|strong="H6440"\w* fundiciones \w que|strong="H3808"\w* hierve \w el|strong="H6213"\w* agua, para \w que|strong="H3808"\w* des \w a|strong="H3068"\w* conocer \w tu|strong="H6213"\w* Nombre \w a|strong="H3068"\w* tus enemigos y tiemblen las naciones \w ante|strong="H6440"\w* \w tu|strong="H6213"\w* \w Presencia|strong="H6440"\w*.
\v 3 Cuando \w hiciste|strong="H6213"\w* cosas asombrosas \w que|strong="H3808"\w* \w no|strong="H3808"\w* esperábamos, las montañas temblaron ante \w tu|strong="H6213"\w* Presencia.
\v 4 \w Jamás|strong="H5769"\w* oído oyó ni ojo vio \w a|strong="H3068"\w* un \tl ʼelohim\tl* fuera de Ti, que actúa \w a|strong="H3068"\w* favor del que espera en \w Él|strong="H6213"\w*.
\v 5 Sales \w a|strong="H3068"\w* encontrarte con \w aquel|strong="H3605"\w* \w que|strong="H1961"\w* con gozo practica \w la|strong="H3605"\w* \w justicia|strong="H6666"\w*, del \w que|strong="H1961"\w* \w tiene|strong="H1961"\w* presentes tus caminos.
\p Ciertamente, Tú te airaste \w cuando|strong="H1961"\w* pecamos. En \w los|strong="H3605"\w* \w pecados|strong="H5771"\w* estuvimos largo tiempo. ¿\w Y|strong="H3068"\w* \w seremos|strong="H1961"\w* salvados?
\v 6 Todos nosotros somos \w como|strong="H3588"\w* suciedad, todas nuestras obras \w de|strong="H4480"\w* justicia \w como|strong="H3588"\w* trapo \w de|strong="H4480"\w* menstruo. Todos nosotros \w nos|strong="H4480"\w* marchitamos \w como|strong="H3588"\w* hojas, \w y|strong="H3588"\w* nuestras \w iniquidades|strong="H5771"\w* \w nos|strong="H4480"\w* arrastran \w como|strong="H3588"\w* \w el|strong="H3588"\w* viento.
\v 7 No hay \w quien|strong="H3605"\w* invoque tu Nombre, \w que|strong="H6258"\w* despierte \w para|strong="H6258"\w* apoyarse en Ti, porque ocultaste tu rostro de \w nosotros|strong="H3605"\w*, y nos entregaste al \w poder|strong="H3027"\w* de nuestras iniquidades.
\p 
\v 8 \w Ahora|strong="H4994"\w* \w pues|strong="H4994"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd*, Tú eres nuestro Padre. \w Nosotros|strong="H3605"\w* somos \w la|strong="H3605"\w* arcilla \w y|strong="H5704"\w* Tú nuestro Alfarero. \w Todos|strong="H3605"\w* \w nosotros|strong="H3605"\w* somos \w la|strong="H3605"\w* obra \w de|strong="H5704"\w* tu mano.
\v 9 \w No|strong="H1961"\w* te aíres en exceso, oh \nd \w Yavé|strong="H3068"\w*\nd*. \w No|strong="H1961"\w* te acuerdes \w para|strong="H1961"\w* siempre de la iniquidad. Mira, te ruego, todos nosotros \w somos|strong="H1961"\w* pueblo tuyo.
\v 10 Tus \w santas|strong="H6944"\w* ciudades \w se|strong="H1961"\w* volvieron un desierto. Sion \w es|strong="H1961"\w* un desierto, Jerusalén una desolación.
\v 11 \w La|strong="H5921"\w* Casa \w de|strong="H5921"\w* nuestro Santuario \w y|strong="H5921"\w* \w de|strong="H5921"\w* nuestro esplendor, \w en|strong="H5921"\w* \w la|strong="H5921"\w* cual \w te|strong="H5921"\w* alabaron nuestros antepasados, fue consumida \w por|strong="H5921"\w* \w el|strong="H5921"\w* fuego. Todas nuestras cosas preciosas fueron destruidas.
\v 12 ¡Oh \nd \w Yavé|strong="H3068"\w*\nd*! ¿Te retraes ante todas estas cosas? ¿Te callas, y nos afliges sin medida?
\c 65
\s1 Un pueblo rebelde
\p 
\v 1 \wj Me dejé \w hallar|strong="H4672"\w* por los \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w preguntaban|strong="H7592"\w* por \w Mí|strong="H1245"\w*. Me dejé buscar por los \w que|strong="H3808"\w* \w no|strong="H3808"\w* me \w invocaban|strong="H7121"\w*. Dije \w a|strong="H3068"\w* \w gente|strong="H1471"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w invocaba|strong="H7121"\w* \w mi|strong="H1245"\w* \w Nombre|strong="H8034"\w*: ¡\w Aquí|strong="H2005"\w* estoy! ¡\w Aquí|strong="H2005"\w* estoy!\wj*
\v 2 \wj \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w día|strong="H3117"\w* \w extendí|strong="H6566"\w* mis \w manos|strong="H3027"\w* \w hacia|strong="H1870"\w* un \w pueblo|strong="H5971"\w* \w rebelde|strong="H5637"\w*, \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w anda|strong="H1980"\w* \w por|strong="H1870"\w* \w buen|strong="H2896"\w* \w camino|strong="H1870"\w*. \w Anda|strong="H1980"\w* tras sus propios \w pensamientos|strong="H4284"\w*.\wj*
\v 3 \wj \w Pueblo|strong="H5971"\w* \w que|strong="H5921"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* propio \w rostro|strong="H6440"\w* \w me|strong="H5921"\w* provoca \w a|strong="H3068"\w* ira \w continuamente|strong="H8548"\w*, \w que|strong="H5921"\w* \w sacrifica|strong="H2076"\w* \w en|strong="H5921"\w* \w huertos|strong="H1593"\w* \w y|strong="H5921"\w* quema incienso \w sobre|strong="H5921"\w* \w ladrillos|strong="H3843"\w*,\wj*
\v 4 \wj que se sientan en \w los|strong="H3427"\w* \w sepulcros|strong="H6913"\w* y pasan la noche en las bóvedas, que comen \w carne|strong="H1320"\w* de cerdo y hay caldo de cosas repugnantes en sus ollas.\wj*
\v 5 \wj \w Ellos|strong="H3605"\w* dicen: Quédate \w en|strong="H3588"\w* tu lugar. \w No|strong="H3588"\w* \w te|strong="H3588"\w* acerques, \w porque|strong="H3588"\w* estoy \w más|strong="H3588"\w* consagrado \w que|strong="H3588"\w* tú. \w Éstos|strong="H3605"\w* \w son|strong="H3588"\w* \w como|strong="H3588"\w* \w el|strong="H3588"\w* \w humo|strong="H6227"\w* \w de|strong="H3588"\w* mi furor, \w como|strong="H3588"\w* fuego \w que|strong="H3588"\w* arde \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w*.\wj*
\p 
\v 6 \wj \w En|strong="H5921"\w* verdad \w está|strong="H5921"\w* \w escrito|strong="H3789"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w Mí|strong="H5921"\w*. \w No|strong="H3808"\w* \w callaré|strong="H2814"\w* \w hasta|strong="H5921"\w* dar retribución. \w No|strong="H3808"\w* descansaré \w hasta|strong="H5921"\w* \w retribuir|strong="H7999"\w* \w su|strong="H3588"\w* obra \w del|strong="H5921"\w* pasado \w en|strong="H5921"\w* \w su|strong="H3588"\w* propio \w regazo|strong="H2436"\w*,\wj*
\v 7 \wj \w por|strong="H5921"\w* sus \w iniquidades|strong="H5771"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w de|strong="H5921"\w* sus antepasados \w juntamente|strong="H3162"\w*, \wj*dice \nd \w Yavé|strong="H3068"\w*\nd*. \wj \w Porque|strong="H5921"\w* quemaron incienso \w en|strong="H5921"\w* \w los|strong="H5921"\w* lugares altos \w y|strong="H5921"\w* blasfemaron \w en|strong="H5921"\w* \w las|strong="H5921"\w* colinas. \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, mediré su \w obra|strong="H6468"\w* \w antigua|strong="H7223"\w* \w en|strong="H5921"\w* su \w regazo|strong="H2436"\w*.\wj*
\p 
\v 8 \nd \w Yavé|strong="H3068"\w*\nd* dice: \wj \w Como|strong="H3588"\w* \w alguno|strong="H3605"\w* \w que|strong="H3588"\w* \w halla|strong="H4672"\w* jugo \w en|strong="H3588"\w* un racimo \w y|strong="H3588"\w* dice: ¡\w No|strong="H6213"\w* dejes \w que|strong="H3588"\w* \w se|strong="H3651"\w* pierda, \w porque|strong="H3588"\w* \w es|strong="H3588"\w* \w una|strong="H4672"\w* \w bendición|strong="H1293"\w*! \w Así|strong="H3541"\w* \w Yo|strong="H3588"\w* \w haré|strong="H6213"\w* \w a|strong="H3068"\w* causa \w de|strong="H3588"\w* mis esclavos. \w No|strong="H6213"\w* \w lo|strong="H6213"\w* \w destruiré|strong="H7843"\w* \w todo|strong="H3605"\w*.\wj*
\v 9 \wj Sacaré \w linaje|strong="H2233"\w* de \w Jacob|strong="H3290"\w* y de \w Judá|strong="H3063"\w*, al \w heredero|strong="H3423"\w* de mis montañas. Entonces mis escogidos \w poseerán|strong="H3423"\w* la tierra, y mis esclavos vivirán \w allí|strong="H8033"\w*.\wj*
\v 10 \wj \w Sarón|strong="H8289"\w* \w será|strong="H1961"\w* un pastizal \w de|strong="H5971"\w* \w ovejas|strong="H6629"\w*, \w y|strong="H1241"\w* el \w valle|strong="H6010"\w* \w de|strong="H5971"\w* Acor lugar \w de|strong="H5971"\w* descanso \w para|strong="H1961"\w* manadas \w de|strong="H5971"\w* \w ganado|strong="H6629"\w* \w vacuno|strong="H1241"\w* \w y|strong="H1241"\w* beneficio \w de|strong="H5971"\w* \w mi|strong="H1961"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* me \w busca|strong="H1875"\w*.\wj*
\p 
\v 11 \wj Pero ustedes, los que \w abandonan|strong="H5800"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* y se olvidan \w de|strong="H7911"\w* mi \w Santa|strong="H6944"\w* Montaña, los que preparan una \w mesa|strong="H7979"\w* para el \tl ʼelohim\tl* Fortuna y hacen \w libaciones|strong="H4469"\w* al \tl ʼelohim\tl* Destino,\wj*
\v 12 \wj \w Todos|strong="H3605"\w* ustedes \w se|strong="H3808"\w* encorvarán \w para|strong="H3282"\w* \w la|strong="H3605"\w* \w matanza|strong="H2874"\w*. \w Yo|strong="H6213"\w* también \w los|strong="H3605"\w* destino \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w espada|strong="H2719"\w*. \w Porque|strong="H3282"\w* \w llamé|strong="H7121"\w* y \w no|strong="H3808"\w* \w respondieron|strong="H6030"\w*. \w Hablé|strong="H1696"\w* y \w no|strong="H3808"\w* \w escucharon|strong="H8085"\w*. \w Hicieron|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w* ante mis \w ojos|strong="H5869"\w*, escogieron \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* me deleita.\wj*
