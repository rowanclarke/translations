\p 
\v 1 \w J|strong="H3068"\w*'ai \w dit|strong="H1732"\w*: \w Je|strong="H3068"\w* prendrai garde \w à|strong="H1732"\w* mes voies, afin \w de|strong="H4210"\w* \w ne|strong="H1732"\w* pas pécher par \w ma|strong="H4210"\w* langue; je mettrai \w un|strong="H1732"\w* frein \w à|strong="H1732"\w* \w ma|strong="H4210"\w* bouche, tant que \w le|strong="H1732"\w* méchant \w sera|strong="H1732"\w* devant moi.
\v 2 \w Je|strong="H3068"\w* \w suis|strong="H6310"\w* resté muet, \w dans|strong="H5704"\w* \w le|strong="H8104"\w* silence; \w je|strong="H5704"\w* \w me|strong="H6310"\w* \w suis|strong="H6310"\w* abstenu \w de|strong="H1870"\w* parler, \w même|strong="H1870"\w* \w pour|strong="H5704"\w* \w le|strong="H8104"\w* bien; \w et|strong="H8104"\w* \w ma|strong="H8104"\w* douleur \w s|strong="H1870"\w*'\w est|strong="H1870"\w* augmentée.
\v 3 Mon cœur s'\w est|strong="H2896"\w* échauffé au-dedans \w de|strong="H2896"\w* \w moi|strong="H2896"\w*; \w ma|strong="H2896"\w* méditation s'\w est|strong="H2896"\w* embrasée \w comme|strong="H2896"\w* \w un|strong="H2896"\w* feu; \w ma|strong="H2896"\w* langue \w a|strong="H3068"\w* parlé:
\v 4 Éternel, fais-moi \w connaître|strong="H1696"\w* \w ma|strong="H7130"\w* fin \w et|strong="H1696"\w* quelle \w est|strong="H3820"\w* \w la|strong="H1696"\w* mesure \w de|strong="H3820"\w* \w mes|strong="H1696"\w* jours; \w que|strong="H1696"\w* \w je|strong="H1696"\w* sache combien courte \w est|strong="H3820"\w* \w ma|strong="H7130"\w* durée.
\v 5 \w Voilà|strong="H3068"\w*, \w tu|strong="H3117"\w* \w as|strong="H3045"\w* réduit \w mes|strong="H3117"\w* \w jours|strong="H3117"\w* \w à|strong="H3068"\w* \w la|strong="H3068"\w* \w mesure|strong="H4060"\w* \w de|strong="H3117"\w* \w quatre|strong="H3117"\w* doigts, \w et|strong="H3068"\w* \w ma|strong="H3117"\w* \w durée|strong="H3117"\w* \w est|strong="H3068"\w* devant \w toi|strong="H3068"\w* \w comme|strong="H3068"\w* \w un|strong="H3068"\w* \w rien|strong="H4100"\w*; oui, \w tout|strong="H3045"\w* \w homme|strong="H1931"\w* debout \w sur|strong="H3068"\w* \w la|strong="H3068"\w* \w terre|strong="H3068"\w* n'\w est|strong="H3068"\w* \w que|strong="H3117"\w* vanité! Sélah (pause).
\v 6 Oui, l'\w homme|strong="H3605"\w* \w se|strong="H3117"\w* promène \w comme|strong="H5414"\w* \w une|strong="H5414"\w* ombre; oui, c'\w est|strong="H3117"\w* \w en|strong="H5414"\w* \w vain|strong="H1892"\w* qu'\w on|strong="H3117"\w* s'agite; \w on|strong="H3117"\w* amasse \w des|strong="H5414"\w* \w biens|strong="H5414"\w*, \w et|strong="H3117"\w* \w on|strong="H3117"\w* \w ne|strong="H5414"\w* sait \w qui|strong="H3117"\w* \w les|strong="H5414"\w* recueillera.
\v 7 \w Et|strong="H3045"\w* maintenant, qu'ai-je attendu, \w Seigneur|strong="H3045"\w*? \w Mon|strong="H3045"\w* espoir \w est|strong="H4310"\w* \w en|strong="H1980"\w* \w toi|strong="H3808"\w*.
\v 8 Délivre-moi de toutes mes transgressions, \w et|strong="H6258"\w* \w ne|strong="H1931"\w* m'expose \w pas|strong="H1931"\w* \w à|strong="H6960"\w* l'opprobre de l'insensé!
\v 9 \w Je|strong="H3068"\w* \w me|strong="H2781"\w* suis \w tu|strong="H7760"\w*, je n'ouvre \w pas|strong="H7760"\w* \w la|strong="H7760"\w* bouche, parce \w que|strong="H7760"\w* c'\w est|strong="H6588"\w* \w toi|strong="H7760"\w* \w qui|strong="H3605"\w* l'as \w fait|strong="H7760"\w*.
\v 10 Détourne \w de|strong="H6213"\w* \w moi|strong="H6213"\w* \w tes|strong="H6213"\w* châtiments! \w Je|strong="H3068"\w* \w me|strong="H3588"\w* consume \w sous|strong="H6213"\w* \w les|strong="H6213"\w* coups \w de|strong="H6213"\w* \w ta|strong="H6213"\w* \w main|strong="H6213"\w*.
\v 11 \w Lorsque|strong="H3027"\w* \w tu|strong="H3027"\w* châties l'\w homme|strong="H3027"\w* \w en|strong="H5921"\w* \w le|strong="H3027"\w* reprenant \w pour|strong="H3027"\w* \w son|strong="H3027"\w* péché, \w tu|strong="H3027"\w* \w consumes|strong="H3615"\w* comme \w la|strong="H5921"\w* teigne \w ce|strong="H3027"\w* qu'\w il|strong="H3027"\w* \w a|strong="H3068"\w* \w de|strong="H3027"\w* \w plus|strong="H5921"\w* précieux. Oui, \w tout|strong="H5921"\w* \w homme|strong="H3027"\w* n'\w est|strong="H3027"\w* \w que|strong="H3027"\w* vanité! (Sélah.)
\v 12 Éternel, écoute \w ma|strong="H5921"\w* requête; prête l'oreille \w à|strong="H6211"\w* \w mon|strong="H3605"\w* cri, \w ne|strong="H2530"\w* sois pas sourd \w à|strong="H6211"\w* \w mes|strong="H5921"\w* larmes! Car \w je|strong="H5921"\w* suis \w un|strong="H5921"\w* étranger chez \w toi|strong="H5921"\w*, \w un|strong="H5921"\w* voyageur \w comme|strong="H3605"\w* \w tous|strong="H3605"\w* \w mes|strong="H5921"\w* pères.
\v 13 Détourne \w de|strong="H3068"\w* \w moi|strong="H3068"\w* \w ton|strong="H3068"\w* regard, \w et|strong="H3068"\w* \w que|strong="H3588"\w* \w je|strong="H3588"\w* reprenne \w mes|strong="H8085"\w* forces, avant \w que|strong="H3588"\w* \w je|strong="H3588"\w* m'\w en|strong="H3068"\w* aille \w et|strong="H3068"\w* \w que|strong="H3588"\w* \w je|strong="H3588"\w* \w ne|strong="H3068"\w* \w sois|strong="H3068"\w* \w plus|strong="H5973"\w*.
\c 40
\p 
\v 1 \w J|strong="H3068"\w*'ai patiemment attendu \w l|strong="H1732"\w*'Éternel; \w il|strong="H1732"\w* s'est incliné vers moi, \w il|strong="H1732"\w* \w a|strong="H3068"\w* entendu mes cris.
\v 2 \w Il|strong="H3068"\w* m'\w a|strong="H3068"\w* \w fait|strong="H3068"\w* remonter \w de|strong="H3068"\w* \w la|strong="H3068"\w* fosse \w de|strong="H3068"\w* destruction, \w du|strong="H3068"\w* bourbier fangeux; \w il|strong="H3068"\w* \w a|strong="H3068"\w* posé \w mes|strong="H8085"\w* pieds \w sur|strong="H3068"\w* \w le|strong="H3068"\w* roc, \w il|strong="H3068"\w* \w a|strong="H3068"\w* affermi \w mes|strong="H8085"\w* \w pas|strong="H8085"\w*.
\v 3 \w Et|strong="H6965"\w* \w il|strong="H5921"\w* \w a|strong="H3068"\w* \w mis|strong="H6965"\w* \w dans|strong="H5921"\w* \w ma|strong="H5921"\w* bouche \w un|strong="H5927"\w* nouveau chant \w de|strong="H5921"\w* louange \w à|strong="H5927"\w* \w notre|strong="H5921"\w* \w Dieu|strong="H5927"\w*. \w Plusieurs|strong="H5921"\w* \w le|strong="H5927"\w* verront, \w et|strong="H6965"\w* \w auront|strong="H5927"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* crainte, \w et|strong="H6965"\w* \w se|strong="H7272"\w* confieront \w en|strong="H5927"\w* l'Éternel.
