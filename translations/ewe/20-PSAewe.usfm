\id PSA - Biblica® Open Ewe Contemporary Scriptures 2020 
\h Psalmowo 
\toc1 Psalmowo 
\toc2 Psalmowo 
\toc3 Psa 
\mt1 Psalmowo 
\c 1  
\ms1 Agbalẽ gbãtɔ 
\mr Psalmowo 1–41 
\cl Psalmo 1 
\q1  
\v 1 Woayra ame si 
\q2 mezɔna ɖe ame vɔ̃ɖiwo ƒe aɖaŋuɖoɖo nu 
\q1 alo nɔa tsitre ɖe nu vɔ̃ wɔlawo ƒe mɔ dzi loo 
\q2 alo nɔa anyi ɖe fewuɖulawo dome o, 
\q1  
\v 2 ke boŋ ekpɔa dzidzɔ le Yehowa ƒe se la ŋu, 
\q2 eye wòdea ŋugble le eŋu zã kple keli. 
\q1  
\v 3 Eya amea ɖi ati si wodo ɖe tɔʋuwo to, 
\q2 esi tsea ku le etseɣi, 
\q1 melũa xe o, eye 
\q2 nu sia nu si wòwɔna la, edzea edzi nyuie. 
\b  
\q1  
\v 4 Mele alea na ame vɔ̃ɖi ya o! 
\q2 Wole abe blitsro si ya ƒona dzonae la ene. 
\q1  
\v 5 Eya ta ame vɔ̃ɖi manɔ te le ʋɔnudrɔ̃gbe, 
\q2 alo nu vɔ̃ wɔlawo nanɔ ame dzɔdzɔewo ƒe ha me o. 
\b  
\q1  
\v 6 Elabena Yehowa kpɔa ame dzɔdzɔewo ƒe mɔ ta, 
\q2 ke ame vɔ̃ɖiwo ƒe mɔ atsrɔ̃ gbidii. 
\c 2  
\cl Psalmo 2 
\q1  
\v 1 Nu ka ta dukɔwo le nugbe ɖom, 
\q2 eye amewo le nu dzodzrowo ɖom? 
\q1  
\v 2 Anyigbadzifiawo ɖo afɔ anyi sesĩe, 
\q2 eye dumegãwo ƒo ta kpli ɖe aɖaŋu me ɖe 
\q2 Yehowa kple eƒe amesiamina la ŋu. 
\q1  
\v 3 Wole gbɔgblɔm be, 
\q2 “Mina míado le Yehowa kple eƒe amesiamina la te, 
\q2 eye míana ablɔɖe mía ɖokuiwo.” 
\b  
\q1  
\v 4 Ame si woɖo zi dzi le dziƒo la ko nu, 
\q2 eye Yehowa ɖe alɔme le wo ŋu. 
\q1  
\v 5 Tete wòka mo na wo le eƒe dɔmedzoe me, 
\q2 eye wòdo ŋɔdzi na wo le eƒe dziku helĩhelĩ me hegblɔ be, 
\q1  
\v 6 “Meɖo nye ŋutɔ nye fia ɖe Zion, 
\q2 nye to kɔkɔe la dzi.” 
\p  
\v 7 Maɖe gbeƒã Yehowa ƒe sedede la; 
\q1 Yehowa gblɔ nam be, 
\q2 “Wòe nye vinye ŋutsu, 
\q2 egbea mezu fofowò. 
\q1  
\v 8 Biam, ne matsɔ dukɔwo awɔ wò domenyinui 
\q2 kple anyigba ƒe seƒewo ke awɔ tɔwòe. 
\q1  
\v 9 Àtsɔ gafiatikplɔ aɖu wo dzii, eye àxlã wo ɖi, 
\q2 woakaka abe ale si ze gbãnae ene.” 
\b  
\q1  
\v 10 Eya ta mi fiawo, midze nunya, 
\q2 eye mi anyigbadzidumegãwo, miɖo to nuxlɔ̃ame. 
\q1  
\v 11 Mitsɔ ɖokuibɔbɔ kple bubu subɔ Yehowa le dzidzɔ gã me 
\q2 kple dzodzo nyanyanya. 
\q1  
\v 12 Mitsɔ ɖokuibɔbɔ do ɖe fia la ŋkume, ne menye nenema o la, 
\q2 ado dziku, eye wòatsrɔ̃ mi kpata, 
\q1 elabena eƒe dɔmedzoe ate ŋu afla ɣe sia ɣi. 
\q2 Woayra ame siwo katã tsɔe wɔ sitsoƒee. 
\c 3  
\cl Psalmo 3 
\d David ƒe ha, esi wòsi le via Absalom nu. 
\q1  
\v 1 O, Yehowa, aleke nye futɔwo sɔ gbɔ ale! 
\q2 Aleke ame geɖewo tso ɖe ŋunye ale! 
\q1  
\v 2 Ame geɖewo le gbɔgblɔm tso ŋutinye be, 
\q2 “Mawu maɖee akpɔ o.” \qs Sela\qs* 
\b  
\q1  
\v 3 O, Yehowa, ke wò la, ènye akpoxɔnu ƒo xlãm; 
\q2 ètsɔ ŋutikɔkɔe kɔ ɖe dzinye, eye nèkɔ nye ta dzi. 
\q1  
\v 4 Yehowae medo ɣli na sesĩe, 
\q2 eye wòtɔ nam tso eƒe to kɔkɔe la dzi. \qs Sela\qs* 
\b  
\q1  
\v 5 Memlɔ anyi hedɔ alɔ̃; 
\q2 meganyɔ, elabena Yehowae kpɔ tanye. 
\q1  
\v 6 Nyemavɔ̃ na ame akpe nane siwo ho, 
\q2 ɖe to ɖem godoo la o. 
\b  
\q1  
\v 7 Tso, O, Yehowa! Ɖem, O, nye Mawu! 
\q2 Ƒo tome na nye futɔwo katã; 
\q2 eye nàŋe aɖu na ame vɔ̃ɖiwo. 
\b  
\q1  
\v 8 Yehowa gbɔe ɖeɖe tsona. 
\q2 Na be wò yayra nanɔ wò amewo dzi. \qs Sela.\qs* 
\c 4  
\cl Psalmo 4 
\d David ƒe ha na hɛnɔ la. Woadzii ɖe kasaŋku ŋu. 
\q1  
\v 1 Nye Mawu dzɔdzɔetɔ, 
\q2 tɔ nam ne meyɔ wò. 
\q1 Na gbɔdzɔem le nye xaxa me; 
\q2 kpɔ nye nublanui, eye nàse nye gbedodoɖa. 
\b  
\q1  
\v 2 O! Amegbetɔviwo, va se ɖe ɣe ka ɣie 
\q2 miaɖi gbɔ̃ nye ŋutikɔkɔe? 
\q1 Va se ɣe ka ɣie mialɔ̃ beble, 
\q2 ahadze aʋatsomawuwo yome? \qs Sela\qs* 
\q1  
\v 3 Minyae be Yehowa tia mawuvɔ̃lawo na eɖokui, 
\q2 eya ta Yehowa asee, ne meyɔe. 
\b  
\q1  
\v 4 Migawɔ nu vɔ̃ ne dzi ku mi o; 
\q2 ne miele miaƒe abawo dzi la, 
\q2 midzro miaƒe dziwo me, eye mizi ɖoɖoe. \qs Sela\qs* 
\q1  
\v 5 Misa vɔ siwo le dzɔdzɔe, 
\q2 eye miɖo dzi ɖe Yehowa ŋu. 
\b  
\q1  
\v 6 Ame geɖewo le biabiam be, “Ame kae afia nu nyui aɖe mí?” 
\q2 Na wò mo ƒe kekeli naklẽ ɖe mía dzi, O! Yehowa. 
\q1  
\v 7 Ètsɔ dzidzɔ gã aɖe yɔ nye dzi me wu ame siwo bli 
\q2 kple wain yeye do agbogbo na. 
\b  
\q1  
\v 8 Mamlɔ anyi, adɔ alɔ̃ le ŋutifafa me, 
\q2 elabena wò, Yehowa, koe na mele dedie. 
\c 5  
\cl Psalmo 5 
\d David ƒe ha na hɛnɔ la. Woadzii kple kpẽ. 
\q1  
\v 1 O! Yehowa, ɖo to nye nyawo, 
\q2 eye nàse nye hũɖeɖe. 
\q1  
\v 2 Fianye kple Mawunye, 
\q2 ɖo to nye ɣlidodo, 
\q2 elabena wòe mele gbe dom ɖa na. 
\b  
\q1  
\v 3 O! Yehowa, le ŋdi me la, àse nye gbe; 
\q2 le ŋdi me la, matsɔ nye biabiawo aɖo ŋkuwò me, 
\q2 eye manɔ lalam kple mɔkpɔkpɔ. 
\q1  
\v 4 Menye Mawu si kpɔa dzidzɔ le vɔ̃ ŋutie nènye o; 
\q2 wò la, ame vɔ̃ɖiwo mate ŋu anɔ gbɔwò o. 
\q1  
\v 5 Ɖokuiŋudzelawo mate ŋu atsi tsitre ɖe ŋkuwò me o; 
\q2 elabena èlé fu nu vlo wɔlawo katã. 
\q1  
\v 6 Ètsrɔ̃ aʋatsokalawo; 
\q2 Yehowa tsri hlɔ̃dolawo kple ameblelawo. 
\q1  
\v 7 Ke nye ya, mava wò aƒe me to wò nublanuikpɔkpɔ gã la me. 
\q2 Matsɔ bubu ade ta agu ɖe wò gbedoxɔ kɔkɔe la ŋgɔ. 
\b  
\q1  
\v 8 Kplɔm, O! Yehowa, 
\q2 le wò dzɔdzɔenyenye nu le nye futɔwo ta, 
\q2 eye wɔ wò mɔwo dzɔdzɔe le ŋkunye me. 
\q1  
\v 9 Womate ŋu axɔ nya siwo doa go tso 
\q2 woƒe nu me la ɖeka pɛ hã dzi ase o, 
\q2 woƒe dzi yɔ fũu kple gbegblẽ. 
\q1 Woƒe ve me le abe yɔdo si le ʋuʋu ɖi la ene, 
\q2 eye wotsɔa woƒe aɖe gblɔa alakpanyawoe. 
\q1  
\v 10 O! Mawu, bu fɔ wo! 
\q2 Na be woƒe ayemɔwo naƒu wo anyi. 
\q1 Ɖe wo ɖa le woƒe nu vɔ̃ gbogboawo ta, 
\q2 elabena wodze aglã ɖe ŋuwò. 
\q1  
\v 11 Ke na ame siwo si wò tso la nakpɔ dzidzɔ, 
\q2 eye na be woadzi ha kple dzidzɔ tegbee. 
\q1 Keke wò ametakpɔkpɔ ɖe wo dzi, 
\q2 ale be ame siwo lɔ̃ wò ŋkɔ la natso aseye le mewò. 
\b  
\q1  
\v 12 O! Yehowa, èyraa ame dzɔdzɔewo vavã, 
\q2 eye nètsɔa wò amenuveve ƒoa xlã wo abe akpoxɔnu ene. 
\c 6  
\cl Psalmo 6 
\d David ƒe ha na hɛnɔ la. Woadzii ɖe kasaŋku kple \tl seminit\tl* ŋu. 
\q1  
\v 1 O! Yehowa, mègaka mo nam le wò dziku me 
\q2 alo ahe to nam le wò dɔmedzoe helĩhelĩ me o. 
\q1  
\v 2 Yehowa, kpɔ nublanui nam, elabena nu te ŋunye. 
\q2 O! Yehowa, yɔ dɔm, elabena nye ƒuwo le veve sem. 
\q1  
\v 3 Nye luʋɔ le nuxaxa me. 
\q2 Va se ɖe ɣe ka ɣi, O! Yehowa, 
\q2 va se ɖe ɣe ka ɣi? 
\b  
\q1  
\v 4 O! Yehowa, trɔ ɖe ŋunye, eye nàɖem; 
\q2 ɖem, le wò lɔlɔ̃ si meʋãna o la ta. 
\q1  
\v 5 Ame aɖeke meɖoa ŋku dziwò ne eku o. 
\q2 Ame kae kafua wò tso eƒe yɔdo me? 
\b  
\q1  
\v 6 Mevɔ le eme keŋkeŋ le ŋeŋe ta; 
\q2 metsɔ aɖatsi ƒo nye aba, elabena mefa avi zã blibo la, 
\q2 eye nye aɖatsi wɔe be nye dɔƒe ƒo tsi belebele. 
\q1  
\v 7 Nuxaxa na ɖeɖi te nye ŋkuwo ŋu; 
\q2 womegale nu kpɔm tututu o, le nye futɔwo ta. 
\b  
\q1  
\v 8 Mite ɖa le gbɔnye, mi nu vlo wɔlawo, 
\q2 elabena Yehowa se nye avifafa. 
\q1  
\v 9 Yehowa se ɣli si medo be wòakpɔ nye nublanui; 
\q2 Yehowa xɔ nye gbedodoɖa alɔ eve. 
\q1  
\v 10 Nye futɔwo katã ŋu akpe mi, eye miaƒe mo atsi dãa; 
\q2 woagbugbɔ ɖe megbe enumake kple ŋukpe. 
\c 7  
\cl Psalmo 7 
\d David ƒe konyifaha si wòdzi na Yehowa le Benyamintɔ, Kus ƒe nyawo ta. 
\q1  
\v 1 O! Yehowa, nye Mawu, wòe mesi tso, 
\q2 xɔ nam, eye nàɖem tso ame siwo katã le yonyeme tim la ƒe asi me. 
\q1  
\v 2 Ne menye nenema o la, 
\q2 woavuvum abe ale si dzata vuvua nui ene, 
\q1 eye woavuvum ʋayaʋaya, 
\q2 xɔnametɔ aɖeke mava ɖem o. 
\b  
\q1  
\v 3 O! Yehowa, nye Mawu, 
\q2 ne mewɔ nu sia, eye vɔ̃ lé ɖe nye asiwo ŋu, 
\q1  
\v 4 ne mewɔ nu vɔɖi ɖe ame si li kplim le ŋutifafa me ŋuti 
\q2 alo meda adzo nye futɔ naneke mawɔmawɔtɔe la, 
\q1  
\v 5 ekema na nye futɔ nati yonyeme, eye eƒe asi nasu dzinye; 
\q2 na be wòafanyam ɖe anyigba, 
\q2 eye wòana matsi ke me adɔ. \qs Sela\qs* 
\b  
\q1  
\v 6 O! Yehowa, tso, le wò dziku me; 
\q2 tso ɖe nye futɔwo ƒe nyanyra ŋuti. 
\q2 Nyɔ, nye Mawu, ne nàɖo ʋɔnu dzɔdzɔe dɔdrɔ̃ anyi. 
\q1  
\v 7 Na be amehawo naƒo ƒu ɖe ŋuwò. 
\q2 Ɖu fia ɖe wo dzi tso dziƒo; 
\q1  
\v 8 na be Yehowa nadrɔ̃ ʋɔnu dukɔ la. 
\q2 O! Yehowa, tso afia nam le nye dzɔdzɔenyenye ta, 
\q2 O! Dziƒoʋĩtɔ, tso afia nam le nye nuteƒewɔwɔ ta. 
\q1  
\v 9 O! Mawu dzɔdzɔetɔ, 
\q2 ame si dzroa susuwo kple dziwo me, 
\q1 na ame vɔ̃ɖiwo ƒe nu vɔ̃ɖi wɔwɔ nu natso, 
\q2 eye nàna dedinɔnɔ ame dzɔdzɔewo. 
\b  
\q1  
\v 10 Nye akpoxɔnue nye Mawu Dziƒoʋĩtɔ la, 
\q2 ame si ɖea ame si dza le eƒe dzi me. 
\q1  
\v 11 Mawue nye ʋɔnudrɔ̃la dzɔdzɔe, 
\q2 Mawu si ɖea eƒe dɔmedzoe fiana gbe sia gbe. 
\q1  
\v 12 Nu metia kɔ nɛ o, anyre eƒe yi, 
\q2 eye wòavu eƒe dati me. 
\q1  
\v 13 Edzra eƒe lãnuwo ɖo da ɖi, 
\q2 eye eƒe aŋutrɔ bibiawo la etrɔ asi le wo ŋu wosɔ gbe. 
\b  
\q1  
\v 14 Ame si fɔ nu vɔ̃ɖi ƒe fu, 
\q2 eye dzɔgbevɔ̃e zu fu wòfɔ la, 
\q2 adzi beble ƒe vi. 
\q1  
\v 15 Ame si ɖe ʋe, heku eme wògoglo nyuie la age dze ʋe si 
\q2 eya ŋutɔ ɖe la me. 
\q1  
\v 16 Dzɔgbevɔ̃e si wòhe vɛ la atrɔ abali ɖe eya ŋutɔ ŋuti, 
\q2 eye eƒe ŋutasesẽ atrɔ ava eya ŋutɔ ƒe ta dzi. 
\b  
\q1  
\v 17 Mada akpe na Yehowa le eƒe dzɔdzɔenyenye ta, 
\q2 eye madzi kafukafuha na Yehowa Dziƒoʋĩtɔ la ƒe ŋkɔ. 
\c 8  
\cl Psalmo 8 
\d David ƒe ha na hɛnɔ la. Woadzii ɖe \tl gitit\tl* ƒe gbeɖiɖi nu. 
\q1  
\v 1 O Yehowa, míaƒe Aƒetɔ, 
\q2 aleke wò ŋkɔ ƒe gãnyenye yɔ anyigba katã dzi ale! 
\b  
\q1 Èɖo wò ŋutikɔkɔe anyi 
\q2 ɖe dziƒowo tame. 
\q1  
\v 2 Èɖo kafukafu anyi ɖe ɖeviwo 
\q2 kple vi nonowo ƒe nu me le wò futɔwo ta be 
\q2 nàmia nu na futɔ kple hlɔ̃biala la. 
\q1  
\v 3 Ne mekpɔ wò dziƒowo, 
\q2 siwo nye wò asinudɔwɔwɔwo, 
\q1 ne mekpɔ ɣleti kple ɣletiviwo, 
\q2 nu siwo nètsɔ ɖo wo nɔƒee la, 
\q1  
\v 4 Nu kae nye amegbetɔ be wò ŋkuwo le eŋuti 
\q2 kple amegbetɔvi be nèléa be nɛ? 
\b  
\q1  
\v 5 Èwɔe wòsɔ kple Mawu kloe, 
\q2 eye nètsɔ ŋutikɔkɔe kple bubu ɖɔ nɛ. 
\q1  
\v 6 Èwɔe be wòanye agbo ɖe wò asinudɔwɔwɔ dzi; 
\q2 eye nètsɔ nu sia nu de eƒe afɔ te. 
\q1  
\v 7 Alẽhawo, nyihawo, 
\q2 gbemelãwo, 
\q1  
\v 8 dziƒoxeviwo, ƒumelãwo 
\q2 kple nu siwo katã ƒua tsi 
\q2 le atsiaƒu me la le eƒe kpɔkplɔ te. 
\b  
\q1  
\v 9 O Yehowa, míaƒe Aƒetɔ, 
\q2 aleke wò ŋkɔ ƒe gãnyenye yɔ anyigba katã dzi ale! 
\c 9  
\cl Psalmo 9 
\d David ƒe ha na hɛnɔ la. Woadzii ɖe “ŋutsuvi la ƒe ku” ƒe gbeɖiɖi nu. 
\q1  
\v 1 Makafu wò, O! Yehowa, 
\q2 kple nye dzi blibo, 
\q2 maɖe wò nukunuwɔwɔwo katã afia. 
\q1  
\v 2 Dzi adzɔm, eye matso aseye le mewò; 
\q2 O Dziƒoʋĩtɔ, madzi kafukafuhawo na wò ŋkɔ. 
\b  
\q1  
\v 3 Nye futɔwo trɔ megbe; 
\q2 wokli nu, eye wo katã wotsrɔ̃ le ŋkuwò me. 
\q1  
\v 4 Elabena wòe xɔ nye nya, 
\q2 eye nèɖe nye dzɔdzɔenyenye ɖe go. 
\q2 Ènɔ wò fiazikpui dzi, eye nèdrɔ̃ ʋɔnu dzɔdzɔe. 
\q1  
\v 5 Èka mo na dukɔwo, eye nètsrɔ̃ ame vɔ̃ɖiwo hetutu 
\q2 woƒe ŋkɔwo ɖa tso mavɔ me yi ɖe mavɔ me. 
\q1  
\v 6 Tsɔtsrɔ̃ mavɔ va futɔ la dzi, 
\q2 elabena èho woƒe duwo, 
\q2 eye womagaɖo ŋku wo dzi gɔ̃ hã akpɔ gbeɖe o. 
\b  
\q1  
\v 7 Yehowa aɖu fia tegbetegbe; 
\q2 eɖo eƒe fiazikpui anyi hena ʋɔnudɔdrɔ̃. 
\q1  
\v 8 Adrɔ̃ ʋɔnu xexea me le dzɔdzɔenyenye me; 
\q2 akplɔ dukɔwo katã le nuteƒewɔwɔ me. 
\q1  
\v 9 Yehowa nye sitsoƒe na ame siwo wote ɖe anyi 
\q2 kple mɔ sesẽ le xaxaɣiwo. 
\q1  
\v 10 Ame siwo nya wò ŋkɔ la aɖo dzi ɖe ŋuwò, 
\q2 elabena wò Yehowa, 
\q2 megble ame siwo dia wò la ɖi kpɔ o. 
\b  
\q1  
\v 11 Midzi kafukafuhawo na Yehowa, 
\q2 ame si nɔ fiazikpui dzi gli le Zion, 
\q2 miɖe gbeƒã nu siwo wòwɔ la le dukɔwo dome. 
\q1  
\v 12 Elabena eya, ame si biaa hlɔ̃ hlɔ̃dolawo la, 
\q2 ɖoa ŋku edzi, medoa toku hiãtɔwo ƒe ɣlidodo o. 
\b  
\q1  
\v 13 O Yehowa, kpɔ ale si nye futɔwo le yonyeme tim ɖa! 
\q2 Kpɔ nye nublanui, eye nàkɔm tso ku ƒe agbowo me, 
\q1  
\v 14 be maɖe wò kafukafu afia le Zion Vinyɔnu ƒe agbowo me, 
\q2 eye le afi ma matso aseye le ɖeɖe si nènam la ta. 
\b  
\q1  
\v 15 Dukɔwo ge dze do si woawo ŋutɔ woɖe la me; 
\q2 woƒe afɔwo ɖo ɖɔ si woawo ŋutɔ woɖo ɖi le bebeme la me. 
\q1  
\v 16 Yehowa ɖe eɖokui fia to eƒe ʋɔnu dzɔdzɔe dɔdrɔ̃ me; 
\q2 ame vɔ̃ɖiwo ƒe asinudɔwɔwɔwo atsɔ wo ade mɔ me. 
\q2 Ŋugbledede. \qs Sela\qs* 
\q1  
\v 17 Ame vɔ̃ɖiwo gbugbɔ yi yɔ me, 
\q2 nenema kee nye dukɔ siwo ŋlɔ Mawu be. 
\q1  
\v 18 Ke womaŋlɔ hiãtɔ be ɖikaa 
\q2 alo ame si le fu kpem la, mɔkpɔkpɔ nabu ɖee o. 
\b  
\q1  
\v 19 Tso, O Yehowa! Mègana amegbetɔ naɖu dzi o, 
\q2 na woadrɔ̃ ʋɔnu dukɔwo le ŋkuwò me. 
\q1  
\v 20 O! Yehowa, ƒo wo ƒu anyi kple ŋɔdzi; 
\q2 na dukɔwo nanya be amegbetɔwo yewonye. \qs Sela.\qs* 
\c 10  
\cl Psalmo 10 
\q1  
\v 1 O! Yehowa, nu ka ta nèle adzɔge ʋĩi ɖo? 
\q2 Nu ka ta nèɣla ɖokuiwò le xaxaɣiwo ɖo? 
\b  
\q1  
\v 2 Ame vɔ̃ɖi dadala he hiãtɔ ƒu anyi, 
\q2 ke wògena ɖe mɔ si wòtre da ɖi la me. 
\q1  
\v 3 Nu siwo eƒe dzi dina la, egblɔnɛ adegbeƒotɔe; 
\q2 eyraa ŋuklẽlawo, eye wòɖea alɔme le Yehowa ŋu. 
\q1  
\v 4 Ame vɔ̃ɖi la media eƒe mɔ o, 
\q2 le dada viviwo ta, 
\q1 le eƒe ŋugblededewo katã me la, 
\q2 meɖoa ŋku Mawu dzi o. 
\q1  
\v 5 Eƒe mɔwo dzea edzi nɛ nyuie ɣe sia ɣi, 
\q2 edoa eɖokui ɖe dzi, 
\q1 wò sewo didi tso egbɔ; 
\q2 eye wòɖoa hehe ɖe eƒe futɔwo ta. 
\q1  
\v 6 Egblɔna na eɖokui be, “Naneke maʋuʋum o, 
\q2 makpɔ dzidzɔ ɣe sia ɣi, eye nyemage ɖe dzɔgbevɔ̃e me akpɔ o.” 
\b  
\q1  
\v 7 Fiƒode, alakpa kple ŋɔdzidodo yɔ eƒe nu me fũu, 
\q2 eye gbegblẽ kple nu vɔ̃ɖi le eƒe aɖe te. 
\q1  
\v 8 Edea xa ɖe kɔƒewo xa; 
\q2 ewu ame maɖifɔwo le xame, 
\q2 eye wòtsa ŋu na ame si wòalé le bebeme. 
\q1  
\v 9 Edea xa ɖe ɣaɣlɛƒe abe dzatae be ɖe ave xa ene; 
\q2 ale be wòalé amemanɔsitɔ; 
\q2 eléa amemanɔsitɔ, eye wòhea wo ɖe eƒe ɖɔ me dzonae. 
\q1  
\v 10 Etoa ƒu ɖe lãme na ame siwo wòlé, 
\q2 woƒe mo tsyɔa zi, eye womuna dzea anyi le eƒe ŋusẽ te. 
\q1  
\v 11 Egblɔna na eɖokui be, 
\q2 “Mawu ŋlɔ be; etsɔ nu tsyɔ eƒe mo, eye mele nu kpɔm o.” 
\b  
\q1  
\v 12 Tso, Yehowa! O! Mawu, kɔ wò abɔ dzi. 
\q2 Mègaŋlɔ hiãtɔ be o. 
\q1  
\v 13 Nu ka ta ame vɔ̃ɖi la le alɔme ɖem le Mawu ŋuti ɖo? 
\q2 Nu ka ta wògblɔna na eɖokui be, 
\q2 “Mayɔm be mana akɔnta o” ɖo? 
\q1  
\v 14 Ke wò, O! Mawu, koe kpɔa dzɔgbevɔ̃e kple vevesese; 
\q2 èbua eŋuti, eye asiwò me wole. 
\q1 Ame si le fukpekpe me la, 
\q2 tsɔa eɖokui dea asi na wò; 
\q2 elabena wòe nye xɔnametɔ na tsyɔ̃eviwo. 
\q1  
\v 15 Ŋe abɔ na ame vɔ̃ɖi kple nu tovo wɔla; 
\q2 yɔe ne wòana akɔnta tso nu vɔ̃ɖi siwo wòwɔ 
\q2 ame aɖeke mekpɔe o la ŋuti. 
\b  
\q1  
\v 16 Yehowae nye fia tso mavɔ me yi mavɔ me; 
\q2 dukɔwo atsrɔ̃ ɖa le eƒe anyigba dzi. 
\q1  
\v 17 O! Yehowa, èse hiãtɔwo ƒe didi; 
\q2 ède dzi ƒo na wo, eye nèɖo to woƒe ɣlidodo. 
\q1  
\v 18 Èʋli tsyɔ̃eviwo kple ame siwo wote ɖe anyi la ta, 
\q2 ale be amegbetɔ si nye anyi la magado ŋɔdzi na amewo azɔ o. 
\c 11  
\cl Psalmo 11 
\d David ƒe ha na hɛnɔ la. 
\q1  
\v 1 Yehowae mesi tso. 
\q2 Aleke miele gbɔgblɔm nam be, 
\q2 “Dzo abe xevi ene nàyi ɖe wò to dzi? 
\q1  
\v 2 Elabena kpɔ ɖa, ame vɔ̃ɖiwo he woƒe da me; 
\q2 wotsɔ woƒe aŋutrɔwo ɖo datikawo ŋuti be 
\q2 woada ame siwo dza le woƒe dzi me la le blukɔ me. 
\q1  
\v 3 Esi wole gɔmeɖokpeawo gbãm la, 
\q2 nu ka dzɔdzɔetɔ la awɔ?” 
\b  
\q1  
\v 4 Yehowa le eƒe gbedoxɔ kɔkɔe la me; 
\q2 Yehowa le eƒe fiazikpui dzi le dziƒo. 
\q1 Elé ŋku ɖe amegbetɔviwo ŋu, 
\q2 eye wòdo wo kpɔ. 
\q1  
\v 5 Yehowa doa ame dzɔdzɔe kpɔna, 
\q2 ke eƒe luʋɔ tsri ame vɔ̃ɖiwo 
\q2 kple ame siwo lɔ̃a ŋutasesẽ. 
\q1  
\v 6 Ana dzoka xɔxɔ kple aŋɔ dzodzoe nadza ɖe 
\q2 ame vɔ̃ɖiwo dzi, eye ya xɔdzo anye wo tɔ gome. 
\b  
\q1  
\v 7 Elabena Yehowae nye dzɔdzɔetɔ, elɔ̃a nuteƒewɔwɔ; 
\q2 ame siwo dza le woƒe dzi me la akpɔ eƒe ŋkume. 
\c 12  
\cl Psalmo 12 
\d David ƒe ha na hɛnɔ la. Woadzii ɖe \tl seminit\tl* ŋu. 
\q1  
\v 1 Xɔ nam, Yehowa elabena, mawuvɔ̃lawo megali o, 
\q2 eye nuteƒewɔlawo bu le amegbetɔwo dome. 
\q1  
\v 2 Ame sia ame kaa aʋatso na ehavi, 
\q2 eye wovivia nu me, 
\q2 elabena woƒe nuyiwo blea ame. 
\b  
\q1  
\v 3 Yehowa nelã beblenuyiwo katã 
\q2 kple aɖe siwo doa wo ɖokui ɖe dzi 
\q1  
\v 4 hegblɔna be, “Míaɖu dzi kple míaƒe aɖewo, 
\q2 míaƒe nuyiwo nye mía tɔ, 
\q2 ame kae aɖu amegã ɖe mía dzi?” 
\b  
\q1  
\v 5 Yehowa be, “Esi wotea ame gblɔewo ɖe to, 
\q2 eye hiãtɔwo ŋena ta la, matso azɔ. 
\q2 Maɖe wo tso ame siwo le vlo dom wo la ƒe asi me.” 
\q1  
\v 6 Kpɔtsɔtsɔ mele Yehowa ƒe nyawo ŋuti o, 
\q2 wole abe klosalo si wololo le anyikpo me, 
\q2 eye wòdza zi gbɔ zi adre la ene. 
\b  
\q1  
\v 7 Ame vɔ̃ɖiwo zɔna le ablɔɖe me, 
\q2 eye wodea bubu yakanuwɔwɔwo ŋu le amegbetɔwo dome. 
\q1  
\v 8 O! Yehowa, àna míanɔ dedie, 
\q2 eye àdzɔ mía ŋu tso ame siawo tɔgbi ƒe asi me tegbetegbe. 
\c 13  
\cl Psalmo 13 
\d David ƒe ha na hɛnɔ la. 
\q1  
\v 1 O! Yehowa, va se ɖe ɣe ka ɣi? 
\q2 Ɖe nàŋlɔm be ɖikaɖika? 
\q2 Va se ɖe ɣe ka ɣi nàɣla wò ŋkume ɖem? 
\q1  
\v 2 Va se ɖe ɣe ka ɣi mawɔ avu kple nye tamesusu, 
\q2 eye gbe sia gbe nuxaxa nayɔ nye dzi me? 
\q2 Va se ɖe ɣe ka ɣi nye futɔwo aɖu dzinye? 
\b  
\q1  
\v 3 Kpɔm ɖa, eye nàɖo nya ŋu nam, 
\q2 O! Yehowa, nye Mawu. 
\q1 Na kekeli naklẽ ɖe nye ŋkuwo dzi, 
\q2 ne menye nenema o la, 
\q2 madɔ alɔ̃ ayi ku me. 
\q1  
\v 4 Ekema nye futɔwo agblɔ be, 
\q2 “Meɖu edzi,” eye nye ketɔwo akpɔ dzidzɔ ne medze anyi. 
\b  
\q1  
\v 5 Ke nye ya meɖo dzi ɖe wò lɔlɔ̃ si meʋãna o la ŋu, 
\q2 nye dzi le aseye tsom le wò xɔname ŋuti. 
\q1  
\v 6 Madzi ha na Yehowa, 
\q2 elabena ewɔ nyui nam. 
\c 14  
\cl Psalmo 14 
\d David ƒe ha na hɛnɔ la. 
\q1  
\v 1 Bometsila gblɔna le eƒe dzi me be, 
\q2 “Mawu aɖeke meli o.” 
\q1 Wonye ame tovowo, eye woƒe nuwɔnawo nye ŋunyɔnu; 
\q2 ame ɖeka hɔ̃ɔ hã mele wo dome si wɔa nu nyui o. 
\b  
\q1  
\v 2 Yehowa bi kɔ kpɔ amegbetɔviwo ɖa tso dziƒo, 
\q2 be wòakpɔe ɖa be nugɔmesela aɖe le wo dome, 
\q2 eye wòdia Mawu vevie mahã? 
\q1  
\v 3 Wo katã wodze ɖe aga, 
\q2 wo katã tim wogblẽ; 
\q1 ame aɖeke meli si wɔa nu nyui o, 
\q2 ɖeka pɛ gɔ̃ hã meli o. 
\b  
\q1  
\v 4 Ɖe nu tovo wɔlawo, 
\q2 ame siwo ɖua nye amewo abe abolo ene, 
\q2 eye womeyɔa Yehowa o la manya esia oa? 
\q1  
\v 5 Ŋɔdzi lé wo ale gbegbe, 
\q2 elabena Mawu le ame dzɔdzɔewo ƒe hame. 
\q1  
\v 6 Mi nu tovo wɔlawo, 
\q2 miegblẽ ame dahewo ƒe ɖoɖowo me, 
\q2 gake Yehowae nye woƒe sitsoƒe. 
\b  
\q1  
\v 7 O! Xɔname ado tso Zion na Israel. 
\q2 Ne Yehowa gaɖo eƒe amewo ƒe nunyonamewo te la, 
\q2 na Yakob natso aseye, eye Israel nakpɔ dzidzɔ! 
\c 15  
\cl Psalmo 15 
\d David ƒe ha. 
\q1  
\v 1 Yehowa, ame kae dze anɔ wò kɔkɔeƒe la? 
\q2 Ame kae anɔ wò togbɛ kɔkɔe la dzi? 
\b  
\q1  
\v 2 Ame si fɔɖiɖi mele eƒe zɔzɔme ŋu o, 
\q2 eye wòwɔa nu dzɔdzɔe lae. 
\q2 Ame si toa nyateƒe tso eƒe dzi me ke 
\q1  
\v 3 eye ameŋugbegblẽ mele aɖe dzi nɛ o, 
\q2 ame si mewɔa vɔ̃ ɖe ehavi ŋu o, 
\q2 eye meƒoa ɖi nɔvia amegbetɔ o, 
\q1  
\v 4 ame si ame baɖa ƒe nu menyoa eŋu o, 
\q2 ke boŋ edea bubu ame siwo vɔ̃a Yehowa la ŋuti, 
\q1 ame si kaa atam si hea vevesese vanɛ, 
\q2 gake megbea edziwɔwɔ o, 
\q1  
\v 5 ame si medoa ga xɔa deme ɖe edzi o, 
\q2 eye mexɔa zãnu ɖe ame maɖifɔ ŋuti o. 
\b  
\q1 Ame si wɔa nu siawo la, 
\q2 naneke maʋãe akpɔ gbeɖegbeɖe o. 
\c 16  
\cl Psalmo 16 
\d David ƒe ha si wɔa dɔ ɖe ame dzi. 
\q1  
\v 1 O! Mawu, na manɔ dedie, 
\q2 elabena wò mee mebe ɖo. 
\b  
\q1  
\v 2 Megblɔ na Yehowa be, 
\q2 “Wòe nye nye Aƒetɔ; 
\q2 nu nyui aɖeke mele asinye kpe ɖe ŋuwò o.” 
\q1  
\v 3 Ame kɔkɔe siwo le anyigba dzi la woe nye bubume 
\q2 siwo ƒe nu nyoa ŋunye vevie. 
\q1  
\v 4 Ame siwo ati mawu tutɔwo yome la, adzi woƒe vevesesewo ɖe edzi. 
\q2 Nyemasa woƒe ʋuvɔsawo na mawu mawo, 
\q2 alo ayɔ woƒe ŋkɔwo o. 
\b  
\q1  
\v 5 Yehowa, èɖo tɔnye gome 
\q2 kple nye kplu da ɖi nam; 
\q2 èna nye gomekpɔkpɔ le dedie nam. 
\q1  
\v 6 Liƒo ƒe dzidzeka la dze teƒe nyuiwo nam; 
\q2 le nyateƒe me la, domenyinu si do dzidzɔ nam la su asinye. 
\q1  
\v 7 Makafu Yehowa, ame si ɖoa aɖaŋu nam; 
\q2 le zã me ke hã, nye dzi xlɔ̃a num. 
\q1  
\v 8 Metsɔ Yehowa ɖo ŋkunye me ɖaa, 
\q2 elabena ele nye nuɖusime, eya ta nyemavɔ̃ o. 
\b  
\q1  
\v 9 Esia ta nye dzi le dzidzɔ kpɔm, 
\q2 nye aɖe tso aseye, eye nye ŋutilã hã agbɔ ɖe eme le dedinɔnɔ me, 
\q1  
\v 10 elabena màgblẽm ɖi na yɔdo alo ana wò, 
\q2 Kɔkɔetɔ la, nàkpɔ gbegblẽ o. 
\q1  
\v 11 Èna menya agbemɔ la; 
\q2 àtsɔ dzidzɔkpɔkpɔ ayɔ menye le ŋkuwò me, 
\q1 eye matsɔ vivisese si mevɔna o la 
\q2 anɔ wò nuɖusime tegbee. 
\c 17  
\cl Psalmo 17 
\d David ƒe gbedodoɖa. 
\q1  
\v 1 See, O! Yehowa, ɖo to nye ɣlidodo 
\q2 kple nye dzɔdzɔenyenye ƒe kukuɖeɖe. 
\q1 Ƒu to anyi ɖe nye gbedodoɖa 
\q2 si metso alakpanuyiwo me o. 
\q1  
\v 2 Afiatsotso nam netso gbɔwò, 
\q2 eye na wò ŋkuwo nakpɔ nu si le dzɔdzɔe. 
\b  
\q1  
\v 3 Togbɔ be èdzro nye dzi me 
\q2 eye nèlé ŋku ɖe ŋunye tsitotsito le zã me; 
\q1 ne èdom kpɔ hã la, 
\q2 màkpɔ naneke le menye o. 
\q2 Meɖoe kplikpaa be nye nu mawɔ nu vɔ̃ o. 
\q1  
\v 4 Le amegbetɔwo ƒe nuwɔnawo me la, 
\q2 metsɔ wò numenya kpɔ ɖokuinye dzii be, 
\q2 nyemage ɖe ame vɔ̃ɖiwo ƒe mɔwo dzi o. 
\q1  
\v 5 Nye afɔɖeɖewo li ɖe wò toƒewo, 
\q2 eye nye afɔ meɖiɖi o. 
\b  
\q1  
\v 6 Mele yɔwòm, O! Mawu, elabena àtɔ nam; 
\q2 ƒu to anyi ɖe ŋunye, eye nàse nye gbedodoɖa. 
\q1  
\v 7 Ɖe wò lɔlɔ̃ gã la ƒe nukunu fia, 
\q2 wò ame si tsɔa wò nuɖusi ɖea ame siwo si wò tso, 
\q2 tso woƒe futɔwo ƒe asi me. 
\q1  
\v 8 Kpɔ tanye abe wò ŋku ƒe gadaglamakui ene, 
\q2 eye nàɣlam ɖe wò aʋala ƒe vɔvɔli te, 
\q1  
\v 9 ɖem tso ame vɔ̃ɖi siwo le funyafunya wɔmem 
\q2 kple futɔ siwo ɖe to ɖem la ƒe asi me. 
\b  
\q1  
\v 10 Wotu woƒe ŋutasẽdziwo, 
\q2 eye wotsɔa woƒe nuwo gblɔa dadanyawoe. 
\q1  
\v 11 Wodo afɔ nam, eye azɔ la, woɖe to ɖem, 
\q2 woƒe ŋkuwo le te ne woaxlãm ɖe anyigba. 
\q1  
\v 12 Wole abe dzata dɔwui si le nu dim be yealé, 
\q2 hele adeklo dzi le avekɔe me ene. 
\b  
\q1  
\v 13 O! Yehowa, tso, kpe akɔ kpli wo, 
\q2 he wo ƒu anyi, eye tsɔ wò yi nàɖem le ame vɔ̃ɖiwo ƒe asi me. 
\q1  
\v 14 O! Yehowa, tsɔ wò asi ɖem le ame siawo tɔgbi 
\q2 kple xexemetɔ siawo ƒe asi me, 
\q2 ame siwo ƒe fetu le agbe sia me. 
\q1 Ètsia ame siwo nèlɔ̃ vevie la ƒe dɔwuame nu; 
\q2 wo viŋutsuwo kpɔ nu nyui geɖe, 
\q2 eye wodzraa kesinɔnuwo ɖo ɖi na wo viwo. 
\b  
\q1  
\v 15 Ke nye la, makpɔ wò ŋkume le dzɔdzɔenyenye me, 
\q2 eye ne menyɔ hekpɔ wò nɔnɔme ko la, maɖi ƒo. 
\c 18  
\cl Psalmo 18 
\d David, Yehowa ƒe dɔla, ƒe ha na hɛnɔ la. David dzi ha sia na Yehowa le esime wòɖee tso Saul kple eƒe futɔ bubuawo ƒe asi me. David gblɔ be: 
\q1  
\v 1 O! Yehowa, nye ŋusẽ, melɔ̃ wò. 
\b  
\q1  
\v 2 Yehowa nye nye agakpe, nye mɔ kple nye xɔnametɔ. 
\q2 Nye Mawu nye nye agakpe, eyae mesi tso. 
\q1 Eyae nye nye akpoxɔnu kple ɖeɖe 
\q2 ƒe ŋusẽ kple nye mɔ sesẽ. 
\b  
\q1  
\v 3 Meyɔ Yehowa, ame si dze na kafukafu, 
\q2 eɖem tso nye futɔwo katã ƒe asi me. 
\q1  
\v 4 Ku ƒe kawo blam, 
\q2 eye nu siwo gblẽa ame la ƒo ɖe dzinye abe tɔʋu ene. 
\q1  
\v 5 Tsiẽƒe ƒe kawo 
\q2 blam, eye ku ƒe mɔtetrewo ɖi kpem. 
\b  
\q1  
\v 6 Meyɔ Yehowa le nye xaxa me; 
\q2 medo ɣli na nye Mawu be wòaɖem. 
\q1 Ese nye gbe tso eƒe gbedoxɔ me ke, 
\q2 eye nye ɣlidodo ɖo egbɔ, ge ɖe eƒe to me. 
\q1  
\v 7 Tete anyigba dzo nyanyanya, eye wòʋuʋu; 
\q2 towo ƒe agunuwo ke hã ʋuʋu heyeheye, 
\q2 eye wodzo kpekpekpe, elabena dzi kui. 
\q1  
\v 8 Dzudzɔ do tso eƒe ŋɔtime; 
\q2 dzo ƒe aɖewo do tso eƒe nu me 
\q2 eye dzoka xɔxɔwo kplɔe ɖo. 
\q1  
\v 9 Ema dziŋgɔli ɖe eve, 
\q2 wòto eme ɖi va anyi, 
\q2 eye lilikpo do blukɔ le eƒe afɔ te. 
\q1  
\v 10 Ede kerubiwo dzi, eye wòdzo dzo. 
\q2 Eɖo asagba ɖe ya ƒe aʋalawo dzi. 
\q1  
\v 11 Viviti nye avɔ si wòtsyɔ, eye lilikpo yibɔ 
\q2 si dzaa tsi lae nye agbadɔ si ƒo xlãe. 
\q1  
\v 12 Lilikpo, kpetsi kple dzikedzo do tso 
\q2 eƒe mo ƒe keklẽ la me. 
\q1  
\v 13 Yehowa ɖe gbe tso dziƒo, 
\q2 eye Dziƒoʋĩtɔ la na wose eƒe gbe. 
\q1  
\v 14 Eda eƒe aŋutrɔ, eye wòkaka eƒe futɔwo, 
\q2 eɖo dzikedzo ɖa, eye wòtɔtɔ wo. 
\q1  
\v 15 Atsiaƒu ƒe balimewo dze gaglã, 
\q2 eye anyigba ƒe gɔmeɖoɖo tsi ƒuƒlu. 
\q1 Le Yehowa ƒe nyaheɖeameŋu 
\q2 kple gbɔgbɔ si do tso eƒe ŋɔtime ta. 
\b  
\q1  
\v 16 Edo asi ɖa tso dziƒo lém, 
\q2 Heɖem tso tɔ goglowo me. 
\q1  
\v 17 Eɖem tso nye futɔ ŋusẽtɔwo ƒe asi me, 
\q2 tso nye ketɔwo ƒe asi me, 
\q2 ame siwo sesẽ wum akpa la ƒe asi me. 
\q1  
\v 18 Woƒo ɖe dzinye le nye dzɔgbevɔ̃egbe, 
\q2 gake Yehowa nye nye kpeɖeŋutɔ. 
\q1  
\v 19 Eɖem tsɔ da ɖe teƒe gbadzaa; 
\q2 eɖem, elabena nye nu nyo eŋu. 
\b  
\q1  
\v 20 Yehowa nɔ kplim le nye dzɔdzɔenyenye nu, 
\q2 eye wòwɔ nyui nam le esi nye asi me dza la ta. 
\q1  
\v 21 Elabena melé Yehowa ƒe mɔwo me ɖe asi; 
\q2 nyemewɔ vɔ̃ hetrɔ le nye Mawu yome o. 
\q1  
\v 22 Eƒe sewo katã le ŋkunye me; 
\q2 eye nyemetrɔ le eƒe ɖoɖowo yome o. 
\q1  
\v 23 Nyemeɖi fɔ le eŋkume o, 
\q2 eye mete ɖokuinye ɖa tso nu vɔ̃ gbɔ. 
\q1  
\v 24 Yehowa wɔ nyui nam le nye dzɔdzɔenyenye 
\q2 kple esi nye asi me dza le eŋkume la ta. 
\b  
\q1  
\v 25 Èwɔa nuteƒe na nuteƒewɔla, 
\q2 eye nèfiaa ɖokuiwò fɔmaɖilae na ame si ŋu fɔɖiɖi mele o. 
\q1  
\v 26 Ame si dza le eƒe dzi me la, èɖea ɖokuiwò fianɛ be èdza, 
\q2 eye nèfiaa ɖokuiwò ayetɔe ɖe ayetɔ la ŋu. 
\q1  
\v 27 Èɖea ame siwo bɔbɔa wo ɖokui, 
\q2 ke ame siwo si dadaŋku le la, èɖiɖia wo ɖe anyi. 
\q1  
\v 28 Wò, O! Yehowae na nye akaɖi le bibim, 
\q2 eye nye Mawu trɔ nye viviti wòzu kekeli. 
\q1  
\v 29 Mate ŋu alũ ɖe aʋakɔ dzi to wò kpekpeɖeŋu me, 
\q2 eye le nye Mawu ta mate ŋu ati kpo aflɔ gli. 
\q1  
\v 30 Mawu ya ƒe mɔwo de blibo, 
\q2 Yehowa ƒe nya nye nyateƒe sɔŋ. 
\q2 Enye akpoxɔnu na ame siwo tsɔe wɔ sitsoƒee. 
\q1  
\v 31 Elabena ame kae ganye Mawu kpe ɖe Yehowa ŋu? 
\q2 Ame kae ganye Agakpe, 
\q2 ɖe menye míaƒe Mawu la koe oa? 
\q1  
\v 32 Mawue nye nye mɔ sesẽ, 
\q2 Eyae na nye mɔ zu gbadzaa. 
\q1  
\v 33 Ewɔ nye afɔwo abe zi tɔwo ene, 
\q2 eye wòna metea ŋu tsia tsitre ɖe teƒe kɔkɔwo. 
\q1  
\v 34 Efia aʋawɔwɔ nye asiwo, 
\q2 eye nye asiwo ate ŋu abɔ dati si wowɔ kple akɔbli. 
\q1  
\v 35 Ètsɔ wò dziɖuɖu ƒe akpoxɔnu la nam, 
\q2 eye wò nuɖusi lém ɖe te. 
\q2 Èbɔbɔ ɖokuiwò be nàdo kɔkɔm. 
\q1  
\v 36 Èkeke mɔ le tenye, 
\q2 be nye klowo magli le tenye o. 
\b  
\q1  
\v 37 Meti nye futɔwo yome, eye metu wo. 
\q2 Nyemetrɔ le wo yome o, 
\q2 va se ɖe esime wotsrɔ̃. 
\q1  
\v 38 Metsrɔ̃ wo be womagate ŋu afɔ gbeɖe o, 
\q2 ale wodze anyi ɖe nye afɔ nu. 
\q1  
\v 39 Wòe na ŋusẽm hena aʋa la wɔwɔ, 
\q2 Èna mebɔbɔ ame siwo katã 
\q2 tso ɖe ŋunye la ɖe anyi. 
\q1  
\v 40 Èna nye futɔwo trɔ megbe dem helé du tsɔ, 
\q2 eye metsrɔ̃ nye futɔwo. 
\q1  
\v 41 Wodo ɣli be Yehowa naxɔ na yewo, 
\q2 gake ame aɖeke mexɔ na wo o, 
\q2 elabena Yehowa metɔ na wo o. 
\q1  
\v 42 Metu wo memie abe ʋuʋudedi si ya lɔ ɖe nu la ene, 
\q2 eye metrɔ wo ɖe mɔtata dzi abe anyi ene. 
\q1  
\v 43 Èɖem tso ame siwo va dze dzinye la ƒe asi me, 
\q2 ètsɔm ɖo dukɔwo nu, 
\q2 eye ame siwo nyemenya o la dzie meɖu fia ɖo. 
\q1  
\v 44 Ne wose ŋkɔnye ko la, 
\q2 woɖoa tom, eye du bubu me tɔwo gɔ̃ hã 
\q2 dzona nyanyanya le nye ŋkume. 
\q1  
\v 45 Dzi ɖena le wo katã ƒo, eye wotsɔa dzodzo nyanyanya hedoa goe 
\q2 le woƒe mɔ sesẽwo me. 
\b  
\q1  
\v 46 Yehowa li tegbee! 
\q2 Woakafu nye Agakpe la! 
\q2 Woado Mawu, nye Xɔla la, ɖe dzi bobobo! 
\q1  
\v 47 Eyae nye Mawu si biaa hlɔ̃ nam, 
\q2 eye wòbɔbɔa dukɔwo ɖe nye afɔ te, 
\q1  
\v 48 ame si ɖeam tso nye futɔwo ƒe asi me. 
\q2 Èkɔm ɖe dzi gbɔ nye futɔwo ta, 
\q2 eye nèɖem tso ŋutasẽlawo ƒe asi me. 
\q1  
\v 49 O! Yehowa, makafu wò le dukɔwo dome 
\q2 le esia ta, eye madzi kafukafuha na wò ŋkɔ. 
\b  
\q1  
\v 50 Ena dziɖuɖu gãwo eƒe fia la; 
\q2 eɖe amenuveve si nu meyi o la fia David, 
\q2 eƒe amesiamina la kple eƒe dzidzimeviwo tegbee. 
\c 19  
\cl Psalmo 19 
\d David ƒe ha na hɛnɔ la. 
\q1  
\v 1 Dziƒo ɖe Mawu ƒe ŋutikɔkɔe ɖe go, 
\q2 eye dziŋgɔli le gbeƒã ɖem eƒe asinudɔwo. 
\q1  
\v 2 Tso ŋkeke yi ŋkeke, wole Mawu ƒe ŋutikɔkɔe kafum, 
\q2 eye tso zã yi zã, 
\q2 wole eƒe gãnyenye ɖem fia. 
\q1  
\v 3 Nuƒoƒo alo gbegbɔgblɔ aɖeke meli 
\q2 si me womese woƒe gbe le o. 
\q1  
\v 4 Woƒe gbe ɖina le anyigba dzi afi sia afi, 
\q2 eye woƒe nyawo dea xexea me ƒe mlɔenu ke gɔ̃ hã. 
\q1 Etu agbadɔ ɖe dziƒowo na ɣe, 
\q1  
\v 5 eye wòle abe ŋugbetɔsrɔ̃e le go dom tso eƒe agbadɔ me ene. 
\q2 Ele abe duƒula si le dzidzɔ kpɔm be wòalé eƒe mɔ atsɔ ene. 
\q1  
\v 6 Ɣe dzena tso dziƒo ƒe go ɖeka dzi, 
\q2 eye wòzɔna yia go kemɛ dzi, 
\q2 naneke meɣla ɖe eƒe dzoxɔxɔ o. 
\b  
\q1  
\v 7 Yehowa ƒe se la de blibo, 
\q2 enaa agbegbɔgbɔ luʋɔ! 
\q1 Yehowa ƒe ɖoɖowo le eteƒe, 
\q2 eye wonana bometsilawo dzea nunya. 
\q1  
\v 8 Yehowa ƒe mɔwo dzɔ, 
\q2 wonana dzi kpɔa dzidzɔ. 
\q1 Yehowa ƒe sewo me kɔ, 
\q2 wonana ame dzea nunya. 
\q1  
\v 9 Yehowa ƒe sewo me kɔ; 
\q2 wonɔa anyi ɖaa. 
\q1 Yehowa ƒe sewo li ke sesĩe, 
\q2 eye ɖikeke aɖeke mele woƒe dzɔdzɔenyenye ŋu o. 
\b  
\q1  
\v 10 Woxɔ asi wu sika kple sika nyuitɔ; 
\q2 wovivina wu anyitsi 
\q2 kple anyitsi si woɖe le anyito me. 
\q1  
\v 11 Wò sewo wotsɔ xlɔ̃ nu wò dɔlae, 
\q2 elabena viɖe gã geɖe le wo dzi wɔwɔ me. 
\q1  
\v 12 Ame kae ate ŋu ade dzesi nu gbegblẽ si wòwɔ? 
\q2 Tsɔ nye vodada siwo metsɔ ɣla la kem. 
\q1  
\v 13 Ɖe wò dɔla tso lɔlɔ̃nuwɔwɔ ƒe nu vɔ̃wo hã me; 
\q2 womaɖu dzinye akpɔ o. 
\q1 Ekema mazu fɔɖiɖi manɔŋutɔ, 
\q2 eye ŋutinye akɔ tso vodada gã me. 
\b  
\q1  
\v 14 Na be nye numenyawo 
\q2 kple nye dzi ƒe ŋugbledede nadze ŋuwò, 
\q2 O! Yehowa, nye Agakpe kple nye Xɔnametɔ. 
\c 20  
\cl Psalmo 20 
\d David ƒe ha na hɛnɔ la. 
\q1  
\v 1 Yehowa netɔ na wò ne èɖo xaxa me; 
\q2 Yakob ƒe Mawu la ƒe ŋkɔ nanye ŋuwòdzɔla. 
\q1  
\v 2 Neɖo kpekpeɖeŋu ɖe wò tso kɔkɔeƒe la, 
\q2 eye wòaɖo xɔname ɖe wò tso Zion. 
\q1  
\v 3 Neɖo ŋku wò vɔsawo katã dzi, 
\q2 eye wòaxɔ wò numevɔsawo. \qs Sela\qs* 
\q1  
\v 4 Nena nu si wò dzi di la wò, 
\q2 eye wòana wò ɖoɖowo katã nadze edzi na wò. 
\q1  
\v 5 Míado dzidzɔɣli ne èɖu dzi, eye míakɔ míaƒe aflagawo dzi 
\q2 le míaƒe Mawu la ƒe ŋkɔ me. 
\b  
\q1 Yehowa awɔ nu siwo katã nèbiae la na wò. 
\b  
\q1  
\v 6 Azɔ menya be Yehowa ɖe eƒe amesiamina, 
\q2 etɔ nɛ tso eƒe nɔƒe kɔkɔe la 
\q2 kple eƒe nuɖusi ƒe ŋusẽ, si wòtsɔna ɖea amee. 
\q1  
\v 7 Ame aɖewo ɖoa ŋu ɖe tasiaɖamwo ŋu, 
\q2 eye ame aɖewo ɖoa dzi ɖe sɔwo ŋu, 
\q1 ke míawo ya míeɖo dzi ɖe Yehowa, 
\q2 míaƒe Mawu la ƒe ŋkɔ ŋu. 
\q1  
\v 8 Ame mawo la, wodzea klo, eye wodzea anyi, 
\q2 ke míawo ya, míenɔa tsitre, eye míedzɔna kã. 
\q1  
\v 9 O! Yehowa, xɔ na fia la! 
\q2 Tɔ na mí ne míeyɔ wò! 
\c 21  
\cl Psalmo 21 
\d David ƒe ha na hɛnɔ la. 
\q1  
\v 1 O! Yehowa, fia la le dzidzɔ kpɔm le wò ŋusẽ me. 
\q2 Ale gbegbe wòle aseye tsom le dziɖuɖu gã siwo nènae la ta! 
\b  
\q1  
\v 2 Ètsɔ nu si eƒe dzi di la nɛ, eye nèwɔ nu 
\q2 siwo wòtsɔ eƒe nu bia la dzi nɛ. \qs Sela\qs* 
\q1  
\v 3 Ètsɔ yayra xɔasi geɖewo do dza nɛ, 
\q2 eye nètsɔ fiakuku si wowɔ kple sika nyuitɔ la ɖɔ nɛ. 
\q1  
\v 4 Ebia agbe wò, eye nènae hedidi 
\q2 eƒe ŋkekewo tso mavɔ me yi mavɔ me. 
\q1  
\v 5 Eƒe ŋkɔxɔxɔ de du to dziɖuɖu siwo nènae la me. 
\q2 Ètsɔ atsyɔ̃ kple bubu kɔ ɖe eya amea dzi. 
\q1  
\v 6 Vavã ènae yayra si nu meyina o, 
\q2 eye nèna dzidzɔkpɔkpɔ kple aseyetsotsoe le ŋkuwò me. 
\q1  
\v 7 Elabena fia la ɖo dzi ɖe Yehowa ŋu, 
\q2 eye le Dziƒoʋĩtɔ la ƒe lɔlɔ̃ si meʋãna o ta la, 
\q2 mavɔ̃ akpɔ gbeɖe o. 
\b  
\q1  
\v 8 Wò asi alé wò futɔwo katã, 
\q2 eye wò nuɖusi atu wò ketɔwo. 
\q1  
\v 9 Ne wò vavaɣi ɖo la, 
\q2 àwɔ wo abe kpodzo bibi ene. 
\q1 Yehowa ami wo le eƒe dɔmedzoe me, 
\q2 eye eƒe dzo afia wo katã. 
\q1  
\v 10 Àtsrɔ̃ woƒe dzidzimeviwo ɖa le anyigba dzi, 
\q2 eye àtsrɔ̃ woƒe nunɔamesiwo ɖa le amegbetɔwo dome. 
\q1  
\v 11 Togbɔ be wole vɔ̃ ɖom ɖe ŋuwò, 
\q2 eye wowɔ ɖoɖowo be woasẽ ŋuta le ŋuwò hã la, 
\q2 madze edzi na wo o, 
\q1  
\v 12 elabena ne èdidi wò aŋutrɔ ɖe wo dzi la, 
\q2 woatrɔ ʋu me ade wò adzo. 
\b  
\q1  
\v 13 Ède ŋgɔ, O! Yehowa, le wò ŋusẽ me; 
\q2 eya ta míadzi ha, eye míakafu wò ŋusẽ. 
\c 22  
\cl Psalmo 22 
\d David ƒe ha na hɛnɔ la, ne woadzi ɖe “Zinɔ le ŋdi kanyaa” ƒe gbeɖiɖi nu. 
\q1  
\v 1 Nye Mawu, nye Mawu, nu ka ŋuti nègblẽm ɖi? 
\q2 Nu ka ta nèle adzɔge ʋĩi na xɔxɔ nam, 
\q2 eye nète ɖa xaa tso nye hũɖeɖe gbɔ? 
\q1  
\v 2 O! Nye Mawu, medo ɣli na wò le ŋkeke 
\q2 kple zã me; megale edzi ko, 
\q2 gake mètɔ nam o. 
\b  
\q1  
\v 3 Ke wò la, èle kɔkɔe, eye Israel ƒe kafukafuhawo zu 
\q2 fiazikpui nènɔ anyi ɖe edzi gli. 
\q1  
\v 4 Mewòe mía fofowo tsɔ woƒe xɔse dee, 
\q2 woka ɖe dziwò, eye nèɖe wo. 
\q1  
\v 5 Wodo ɣli na wò, eye nèɖe wo, 
\q2 dziwòe woka ɖo, eye ŋu mekpe wo o. 
\b  
\q1  
\v 6 Ke nye la, ŋɔ menye, menye amegbetɔ o, 
\q2 elabena amewo ɖu fewu le ŋunye, eye wodo vlom. 
\q1  
\v 7 Ame siwo katã kpɔm la ɖe alɔme le ŋunye; 
\q2 woflɔa dzu ɖe dzinye, eye woʋuʋua ta ɖe ŋunye gblɔna be: 
\q1  
\v 8 “Eka ɖe Yehowa dzi, 
\q2 Yehowa neɖee míakpɔ. 
\q2 Yehowa neɖee, elabena eƒe nu nyo eŋu.” 
\b  
\q1  
\v 9 Ke wòe hem tso vidzidɔ me, 
\q2 eye le danye ƒe no nu ke, èna meka ɖe dziwò. 
\q1  
\v 10 Wòe nye nye Mawu tso danye ƒe dɔ me 
\q2 ke, eye tso ɖevime wotsɔm de asi na wò. 
\b  
\q1  
\v 11 Mèganɔ adzɔge tso gbɔnye o, 
\q2 elabena xaxa tum, 
\q2 eye ame aɖeke meli axɔ nam o. 
\b  
\q1  
\v 12 Nyitsu geɖewo ɖe to ɖem; 
\q2 Basan nyitsu sesẽwo ƒo xlãm. 
\q1  
\v 13 Woke woƒe nuwo ɖe ŋunye baa 
\q2 abe dzata si le gbe tem hele nu si wòlé la vuvum ene. 
\q1  
\v 14 Woƒom ɖe anyi abe tsi ene, 
\q2 eye nye ƒuwo katã gli le woƒe kpeƒewo. 
\q2 Nye dzi lolõ ɖe dɔ me nam gbanaa hesi to menye. 
\q1  
\v 15 Ŋusẽ vɔ le ŋunye abe ze gbagbã ene, 
\q2 eye nye aɖe lé ɖe nye nu me, 
\q2 elabena ètsɔm mlɔ ku ƒe ʋuʋudedi me. 
\b  
\q1  
\v 16 Avuwo ƒo xlãm, 
\q2 ame vɔ̃ɖiwo ƒe ha ɖe to ɖem, 
\q2 eye wotsɔ nu ŋɔ nye asiwo kple afɔwo. 
\q1  
\v 17 Mate ŋu axlẽ nye ƒuwo, 
\q2 amewo fɔ ŋku ɖe dzinye, 
\q2 eye wokpɔ dzidzɔ le nye anyidzedze ŋuti. 
\q1  
\v 18 Woma nye awuwo na wo nɔewo, 
\q2 eye woda akɔ ɖe nye awu ʋlaya dzi. 
\b  
\q1  
\v 19 Ke wò, O! Yehowa, mèganɔ adzɔge o; 
\q2 O! Nye ŋusẽ, va kaba nàɖem. 
\q1  
\v 20 Ɖe nye agbe tso yi ƒe asi me, 
\q2 eye ɖe nye agbe xɔasi la tso avuwo ƒe ŋusẽ me. 
\q1  
\v 21 Ɖem le dzatawo ƒe nu me, 
\q2 eye nàɖem le towo ƒe dzowo nu. 
\b  
\q1  
\v 22 Maɖe gbeƒã wò ŋkɔ na nɔvinyewo, 
\q2 eye le amehawo dome, makafu wò. 
\q1  
\v 23 Mi ame siwo vɔ̃a Yehowa, mikafui! 
\q2 Mi, Yakob ƒe dzidzimeviwo, mide bubu eŋuti! 
\q2 Misroe ɖa, mi Israel ƒe dzidzimeviwo! 
\q1  
\v 24 Elabena menyɔ ŋu alo do vlo 
\q2 ame siwo le fu kpem la ƒe hiãtuame o; 
\q1 meɣla eƒe mo ɖee o, 
\q2 ke boŋ eɖo to eƒe ɣlidodo na kpekpeɖeŋu. 
\b  
\q1  
\v 25 Gbɔwòe nye kafukafuha si medzina 
\q2 le ameha gãwo dome la ƒe tanya tsona. 
\q1 Maxe nye adzɔgbeɖefewo 
\q2 le ame siwo vɔ̃a wò la ŋkume. 
\q1  
\v 26 Hiãtɔwo aɖu nu aɖi ƒo; 
\q2 ame siwo dia Yehowa la akafui. 
\q2 Miaƒe dziwo nenɔ agbe tegbee! 
\b  
\q1  
\v 27 Anyigba ƒe mlɔenu katã hã aɖo ŋku edzi, 
\q2 atrɔ ɖe Yehowa ŋu, 
\q1 eye anyigbadzidukɔwo ƒe ƒomeawo katã 
\q2 ava de ta agu ɖe eŋkume. 
\q1  
\v 28 Elabena fiaɖuɖu la nye Yehowa tɔ, 
\q2 eye wòɖu fia ɖe dukɔwo dzi. 
\q1  
\v 29 Kesinɔtɔ siwo katã le anyigba dzi la 
\q2 aɖu nu, eye woasubɔe; 
\q1 ame siwo katã mate ŋu anɔ agbe o, 
\q2 eye woyi ɖe ke ƒe tume la adze klo ɖe eŋkume. 
\q1  
\v 30 Dzidzimewo asubɔe, eye dzidzime siwo ava dzɔ la, 
\q2 woagblɔ nya na wo tso Aƒetɔ la ŋuti. 
\q1  
\v 31 Woaɖe gbeƒã eƒe dzɔdzɔenyenye na 
\q2 ame siwo meva dzɔ haɖe o, 
\q2 elabena eyae wɔe. 
\c 23  
\cl Psalmo 23 
\d David ƒe ha. 
\q1  
\v 1 Yehowae nye kplɔnyela, 
\q2 eya ta naneke mahiãm o. 
\q1  
\v 2 Lãnyiƒe damawo dzi wòna metsyɔ akɔ ɖo, 
\q2 eye wòkplɔm yi tɔʋu fafɛwo gbɔe, 
\q1  
\v 3 hena nye luʋɔ gbɔ agbe. 
\q2 Ekplɔm to dzɔdzɔenyenye ƒe 
\q2 mɔwo dzi le eƒe ŋkɔ la ta. 
\q1  
\v 4 Ne mezɔ to ku ƒe balime si do viviti tsiɖitsiɖi hã la, 
\q2 nyemavɔ̃ dzɔgbevɔ̃e aɖeke o, 
\q1 elabena wòe le gbɔnye, eye wò lãkplɔti 
\q2 kple atikplɔ faa akɔ nam. 
\b  
\q1  
\v 5 Èɖo kplɔ̃ ɖe akɔnyeme le nye ketɔwo ƒe ŋkume. 
\q2 Èsi ami ɖe ta nam, nye kplu yɔ gbagba. 
\q1  
\v 6 Vavãe, dzɔgbenyui kple amenuveve adze yonyeme 
\q2 le nye agbemeŋkekewo katã me, 
\q2 eye manɔ Yehowa ƒe aƒe me ɖaa. 
\c 24  
\cl Psalmo 24 
\d David ƒe ha. 
\q1  
\v 1 Anyigba kple nu siwo katã yɔ edzi, 
\q2 xexea me kple emenɔlawo katã nye Yehowa tɔ. 
\q1  
\v 2 Elabena eɖoe anyi ɖe atsiaƒu dzi, 
\q2 eye wòɖo egɔme anyi ɖe tɔsisiwo dzi gli. 
\b  
\q1  
\v 3 Ame kae alia Yehowa ƒe togbɛ? 
\q2 Ame kae atsi tsitre ɖe eƒe kɔkɔeƒe la? 
\q1  
\v 4 Ame si ƒe asi me dza, eye eƒe dzi me le dzadzɛe, 
\q2 ame si metsɔ eƒe luʋɔ na legba o, 
\q2 eye mekaa aʋatso heta nu dzodzro o. 
\b  
\q1  
\v 5 Eya axɔ yayra tso Yehowa gbɔ, eye Mawu, 
\q2 eƒe Ɖela la, atso afia nɛ. 
\q1  
\v 6 O! Yakob ƒe Mawu, 
\q2 aleae dzidzime si dia wò, 
\q2 eye wòdia ŋkuwòme la le. \qs Sela\qs* 
\b  
\q1  
\v 7 O! Mi agbowo, miʋu; 
\q2 mi blemaʋɔtruwo, miʋu, 
\q2 ne Ŋutikɔkɔefia la nage ɖe eme. 
\q1  
\v 8 Ame kae nye Ŋutikɔkɔefia la? 
\q2 Yehowa ŋusẽtɔ kple kalẽtɔ lae, 
\q2 Yehowa si wɔa kalẽ le aʋagbedzi lae. 
\q1  
\v 9 O! Mi agbowo, miʋu; 
\q2 mi blemaʋɔtruwo, miʋu, 
\q2 ne Ŋutikɔkɔefia la nage ɖe eme. 
\q1  
\v 10 Ame kae nye Ŋutikɔkɔefia sia? 
\q2 Yehowa Ŋusẽkatãtɔ lae nye Ŋutikɔkɔefia la. \qs Sela.\qs* 
\c 25  
\cl Psalmo 25 
\d David ƒe ha. 
\q1  
\v 1 O! Yehowa, 
\q2 wòe mekɔ nye luʋɔ ɖe dzi na. 
\b  
\q1  
\v 2 O! Nye Mawu, ŋuwòe meɖo dzi ɖo. 
\q2 Mègana ŋu nakpem, 
\q2 alo nàɖe mɔ nye futɔwo naɖu dzinye o. 
\q1  
\v 3 Ame si tsɔ eƒe mɔkpɔkpɔ da ɖe dziwò la, 
\q2 ŋu makpee akpɔ gbeɖe o; 
\q2 gake ŋu akpe ame siwo nye vivimenuwɔlawo. 
\b  
\q1  
\v 4 O! Yehowa, fia wò mɔwo 
\q2 kple wò toƒewom, 
\q1  
\v 5 kplɔm le wò nyateƒe la me, eye nàfia num, 
\q2 elabena wòe nye nye Mawu kple nye Ɖela, 
\q2 eye nye mɔkpɔkpɔ le mewò ŋkeke blibo la katã. 
\q1  
\v 6 O! Yehowa, ɖo ŋku wò lɔlɔ̃ 
\q2 kple wò nublanuikpɔkpɔ sɔgbɔ la dzi, 
\q2 elabena woli tso blema ke. 
\q1  
\v 7 O! Yehowa, mègaɖo ŋku nye ɖekakpuimenu vɔ̃wo 
\q2 kple nye aglãdzemɔwo dzi o; 
\q1 ke boŋ ɖo ŋku dzinye le wò lɔlɔ̃ la ta, 
\q2 elabena nyuiwɔwɔ le mewò. 
\b  
\q1  
\v 8 Yehowa nyo, eye wòwɔa nu dzɔdzɔe, 
\q2 eya ta efiaa eƒe mɔ nu vɔ̃ wɔlawo. 
\q1  
\v 9 Ekplɔa ɖokuibɔbɔlawo to nu dzɔdzɔe wɔwɔ me, 
\q2 eye wòfiaa eƒe mɔ wo. 
\q1  
\v 10 Yehowa ƒe mɔwo katã nye lɔlɔ̃ kple nuteƒewɔwɔ na 
\q2 ame siwo léa eƒe nubablamenyawo ɖe asi. 
\q1  
\v 11 O! Yehowa, togbɔ be nye dzidada sɔ gbɔ ale gbegbe hã la, 
\q2 tsɔ wo kem le wò ŋkɔ la ta. 
\b  
\q1  
\v 12 Ekema ame kawoe nye ŋutsu ma siwo vɔ̃a Yehowa? 
\q2 Afia nu wo le mɔ si woato la dzi. 
\q1  
\v 13 Woakpɔ dzidzedze le woƒe agbemeŋkekewo me, 
\q2 eye woƒe dzidzimeviwo anyi anyigba la ƒe dome. 
\q1  
\v 14 Yehowa gblɔa nya ɣaɣlawo na ame siwo vɔ̃nɛ, 
\q2 eye wòɖea eƒe nubabla fiaa wo. 
\q1  
\v 15 Nye ŋkuwo le Yehowa ŋu ɖaa, 
\q2 elabena eya koe aɖe nye afɔ le mɔ me. 
\b  
\q1  
\v 16 Trɔ ɖe ŋunye ne nàve nunye, 
\q2 elabena metsi akogo, eye hiã tum. 
\q1  
\v 17 Nye dzi ƒe nuxaxawo do gã ɖe edzi, 
\q2 na vovom tso nye vevesesewo me. 
\q1  
\v 18 Nye kɔ nàkpɔ nye nuxaxa kple nye vevesese ɖa, 
\q2 eye nàɖe nye nu vɔ̃wo katã ɖa. 
\q1  
\v 19 Kpɔ ale si nye futɔwo dzi ɖe edzii ɖa, 
\q2 eye nàkpɔ ale si wolé fum ɖikaɖikae ɖa! 
\b  
\q1  
\v 20 Kpɔ nye agbe ta, eye nàɖem; 
\q2 megana ŋu nakpem o, elabena mewòe mebe ɖo. 
\q1  
\v 21 Nuteƒewɔwɔ kple dzɔdzɔenyenye nedzɔ ŋunye, 
\q2 elabena nye mɔkpɔkpɔ le mewò. 
\b  
\q1  
\v 22 O! Mawu, 
\q2 ɖe Israel tso woƒe xaxawo katã me. 
\c 26  
\cl Psalmo 26 
\d David ƒa ha. 
\q1  
\v 1 O! Yehowa, tso afia nam, 
\q2 elabena menɔ agbe si ŋu fɔɖiɖi mele o. 
\q1 Meɖo dzi ɖe Yehowa ŋu, 
\q2 nyemeʋã kpɔ gbeɖe o. 
\q1  
\v 2 O! Yehowa, lolom, dom kpɔ; 
\q2 eye nàdzro nye dzi kple tamesusu hã me, 
\q1  
\v 3 elabena wò lɔlɔ̃ le ŋkunye me ɖaa, 
\q2 eye mezɔna le wò nyateƒe la me ɣe sia ɣi. 
\b  
\q1  
\v 4 Nyemanɔ anyi ɖe ameblelawo dome, 
\q2 alo ade ha kple alakpanuwɔlawo o. 
\q1  
\v 5 Metsri ame tovowo ƒe habɔbɔ, 
\q2 eye megbe be nyemanɔ ame vɔ̃ɖiwo dome o. 
\q1  
\v 6 Meklɔ nye asiwo le fɔmaɖimaɖi me, 
\q2 eye meƒo xlã wò vɔsamlekpui, O! Yehowa, 
\q1  
\v 7 hele wò kafukafuha dzim 
\q2 kple ɣli le nukudɔ siwo katã nèwɔ la xlẽm fia. 
\b  
\q1  
\v 8 O! Yehowa, melɔ̃ aƒe si me nèle, 
\q2 afi si wò ŋutikɔkɔe le. 
\q1  
\v 9 Mègatsɔ nye luʋɔ kpe ɖe nu vɔ̃ wɔlawo ŋuti 
\q2 kple nye agbe kpe ɖe hlɔ̃dolawo ŋuti, 
\q1  
\v 10 ame siwo ƒe asi me ɖoɖo vɔ̃ɖiwo le, 
\q2 eye woƒe nuɖusime yɔ fũu kple zãnuxɔxɔ o. 
\q1  
\v 11 Ke nye la, menɔ agbe si ŋu fɔɖiɖi mele o, 
\q2 eya ta ɖem, eye nàkpɔ nublanui nam. 
\b  
\q1  
\v 12 Nye afɔ le sɔsɔeƒe. 
\q2 Makafu Yehowa le takpekpe gã la me. 
\c 27  
\cl Psalmo 27 
\d David ƒe ha. 
\q1  
\v 1 Yehowae nye nye kekeli kple nye ɖeɖe. 
\q2 Ame ka mavɔ̃? 
\q1 Yehowae nye mɔ sesẽ na nye agbe, 
\q2 ame ka adzi ŋɔ nam? 
\b  
\q1  
\v 2 Ne ame vɔ̃ɖiwo lũ ɖe dzinye be woavuvum, 
\q2 ne nye futɔwo kple nye ketɔwo lũ ɖe dzinye la, 
\q2 woakli nu adze anyi. 
\q1  
\v 3 Togbɔ be aʋakɔ gã aɖe ɖe to ɖem hã la, 
\q2 nye dzi mavɔ̃ o, 
\q1 togbɔ be wodze aʋa ɖe ŋunye hã la, 
\q2 azɔ koŋ dzi aɖo ƒonye. 
\b  
\q1  
\v 4 Nu ɖeka mebia Yehowa, 
\q2 esiae nye be manɔ Yehowa ƒe aƒe me 
\q1 le nye agbemeŋkekewo katã me, 
\q2 ne malé ŋku ɖe Yehowa ƒe nyonyo ŋu, 
\q2 eye madii le eƒe gbedoxɔ me. 
\q1  
\v 5 Elabena le xaxaɣiwo la, 
\q2 atsyɔ nu dzinye le eƒe nɔƒe la me; 
\q1 aɣlam ɖe eƒe agbadɔ ƒe bebeƒe, 
\q2 eye wòakɔm aɖo agakpe kɔkɔ aɖe dzi. 
\b  
\q1  
\v 6 Ekema nye ta akɔ dzi agbɔ nye futɔ 
\q2 siwo ƒo xlãm godoo la ta; 
\q1 matsɔ dzidzɔɣli asa vɔ nɛ le eƒe agbadɔ kɔkɔe la me. 
\q2 Madzi ha, eye maƒo saŋku na Yehowa. 
\b  
\q1  
\v 7 O! Yehowa, se nye gbe, ne meyɔ wò; 
\q2 kpɔ nublanui nam, eye nàtɔ nam. 
\q1  
\v 8 Nye dzi le gbɔgblɔm le ŋuwò be, 
\q2 “Di eƒe ŋkume!” 
\q2 Yehowa, wò ŋkumee madi. 
\q1  
\v 9 Mègaɣla wò ŋkume ɖem o, 
\q2 mègatrɔ wò dɔla ɖo ɖa le dɔmedzoe me o, 
\q2 elabena wòe nye nye xɔnametɔ. 
\q1 O! Mawu, nye Ɖela, 
\q2 mègagbe nu le gbɔnye alo agblem ɖi o. 
\q1  
\v 10 Togbɔ be tɔnye kple nɔnye gblem ɖi hã la, 
\q2 Yehowa axɔm. 
\q1  
\v 11 O! Yehowa, fia wò mɔwom; 
\q2 kplɔm to mɔ dzɔdzɔe dzi, 
\q2 le ame siwo tem ɖe to la ta. 
\q1  
\v 12 Mègatsɔm de asi na nye futɔwo ƒe didi o, 
\q2 elabena alakpaɖasefowo tso ɖe ŋutinye kpe ɖe 
\q2 ame siwo lɔ ŋutasesẽ ƒe gbɔgbɔtsixɛ ɖe ƒo la ŋuti. 
\b  
\q1  
\v 13 Esia nye nu si dzi meka ɖo la be: 
\q2 Makpɔ Yehowa ƒe nu nyuiwo 
\q2 le agbagbeawo ƒe anyigba dzi. 
\q1  
\v 14 Kpɔ mɔ na Yehowa; 
\q2 sẽ ŋu, eye nàlé dzi ɖe ƒo. 
\q2 Kpɔ mɔ na Yehowa. 
\c 28  
\cl Psalmo 28 
\d David ƒe ha. 
\q1  
\v 1 O! Yehowa, nye Agakpe, 
\q2 wò yɔm mele, mègado tokum o. 
\q1 Elabena ne èzi ɖoɖoe la, 
\q2 manɔ abe ame siwo yi aʋlime la ene. 
\q1  
\v 2 Esi mekɔ nye asiwo dzi ɖo ɖe wò Kɔkɔeƒewo ƒe Kɔkɔƒe la gbɔ la, 
\q2 se nye ɣlidodo na nublanuikpɔkpɔ, 
\q2 ne meyɔ wò be nàxɔ nam. 
\b  
\q1  
\v 3 Mègakplɔm kpe ɖe ame vɔ̃ɖiwo ŋu o, 
\q2 ame siwo ƒoa nu kple aƒelikawo fafɛ, 
\q2 gake vɔ̃ɖivɔ̃ɖi le woƒe dzi me. 
\q1  
\v 4 Ɖo eteƒe na wo le woƒe nuwɔnawo 
\q2 kple woƒe dɔwɔwɔ vɔ̃wo ta. 
\q1 Xe fe na wo ɖe nu si woƒe asiwo wɔ la nu, 
\q2 eye nàgbugbɔ tohehe si wodze na la ahe va wo dzii. 
\b  
\q1  
\v 5 Esi womede bubu Yehowa ƒe nuwɔnawo 
\q2 kple eƒe asinudɔwo ŋuti o ta la, 
\q1 àgbã wo aƒu anyi, 
\q2 eye màgbugbɔ wo atu akpɔ gbeɖe o. 
\b  
\q1  
\v 6 Woakafu Yehowa, elabena ese ɣli si dom mele 
\q2 le nublanuikpɔkpɔ biam. 
\q1  
\v 7 Yehowae nye nye ŋusẽ kple akpoxɔnu; 
\q2 nye dzi ka ɖe eya amea dzi, eye wòɖem. 
\q1 Nye dzi ti kpo le dzidzɔkpɔkpɔ ta, 
\q2 eye mada akpe nɛ to hadzidzi me. 
\b  
\q1  
\v 8 Yehowae nye eƒe dukɔ ƒe ŋusẽ; 
\q2 ɖeɖe ƒe mɔ sesẽ wònye na eƒe amesiamina. 
\q1  
\v 9 Ɖe wò dukɔ, eye nàyra wò domenyinu; 
\q2 nànye woƒe kplɔla, eye nàkɔ wo ɖe akɔnu tegbetegbe. 
\c 29  
\cl Psalmo 29 
\d David ƒe ha. 
\q1  
\v 1 Mitsɔ bubu na Yehowa, O! Mi ŋusẽtɔwo, 
\q2 mitsɔ ŋutikɔkɔe kple ŋusẽ na Yehowa. 
\q1  
\v 2 Mitsɔ ŋutikɔkɔe si dze Yehowa ƒe ŋkɔ nɛ; 
\q2 misubɔ Yehowa le eƒe kɔkɔenyenye ƒe atsyɔ̃ me. 
\b  
\q1  
\v 3 Yehowa ƒe gbe ɖi le tsiwo dzi; 
\q2 Ŋutikɔkɔe ƒe Mawu la ɖe gbe, 
\q2 eye Yehowa ɖe gbe le tsi gãwo dzi. 
\q1  
\v 4 Ŋusẽ le Yehowa ƒe gbe ŋu, 
\q2 eye ŋutikɔkɔe nye Yehowa ƒe gbe. 
\q1  
\v 5 Yehowa ƒe gbe ŋe Lebanon ƒe sedatiwo. 
\q1  
\v 6 Ena Lebanon ti kpo abe nyivi ene, 
\q2 eye Sirion hã abe tovi ene. 
\q1  
\v 7 Yehowa ƒe gbe ke dzo mia abe dzikedzo ene. 
\q1  
\v 8 Yehowa ƒe gbe ʋuʋu dzogbenyigba, 
\q2 eye Yehowa ʋuʋu Kades Dzogbenyigba. 
\q1  
\v 9 Yehowa na gboti sesẽwo ʋuʋu heyeheye, 
\q2 eye wòna avewo lũ xɛ. 
\q1 Le eƒe gbedoxɔ me la, ame sia ame do ɣli be, 
\q2 “Ŋutikɔkɔe!” 
\b  
\q1  
\v 10 Yehowa nɔ eƒe fiazikpui dzi gli le tsiɖɔɖɔ dzi. 
\q2 Woɖo Yehowa fia tso mavɔ me yi mavɔ me. 
\q1  
\v 11 Yehowa naa ŋusẽ eƒe dukɔ; 
\q2 eye wòyraa eƒe amewo kple ŋutifafa. 
\c 30  
\cl Psalmo 30 
\d David ƒe ha na gbedoxɔ la ŋutikɔkɔ. 
\q1  
\v 1 O! Yehowa, mado wò ɖe dzi, 
\q2 elabena wòe hem do goe tso ʋe globo me, 
\q2 eye mèna mezu nu ɖikokoe na nye futɔwo o. 
\q1  
\v 2 O! Yehowa, nye Mawu, 
\q2 mebia kpekpeɖeŋu tso gbɔwò, eye nèyɔ dɔm. 
\q1  
\v 3 O! Yehowa, wòe ɖem tso tsiẽƒe, 
\q2 eye mèna meyi aʋlime o. 
\b  
\q1  
\v 4 Midzi ha na Yehowa, 
\q2 mi eƒe ame kɔkɔewo, 
\q2 eye mikafu eƒe ŋkɔ kɔkɔe la. 
\q1  
\v 5 Elabena medoa dɔmedzoe eteƒe didina o, 
\q2 ke eƒe amenuveve ya nɔa anyi agbenɔɣi katã. 
\q1 Avifafa anɔ anyi le zã me, 
\q2 gake aseyetsotso ava le ŋdi me. 
\b  
\q1  
\v 6 Esi mekpɔ be meli ke la, megblɔ be, 
\q2 “Nye la, nyemaʋuʋu kpɔ gbeɖe o.” 
\q1  
\v 7 O! Yehowa, esi nève nunye la, 
\q2 èna nye to li ke zã, 
\q1 gake esi nèɣla wò ŋkume ɖem la, 
\q2 nye mo tsi dãa. 
\b  
\q1  
\v 8 Yehowa, wòe meyɔ, 
\q2 Yehowae medo ɣli na be wòakpɔ nublanui nam. 
\q1  
\v 9 “Viɖe kae le eme ne donyeme 
\q2 gblẽ alo ne meyi ɖe aʋlime? 
\q1 Ɖe ʋuʋudedi akafu wòa? 
\q2 Ɖe wòaɖe gbeƒã wò nuteƒewɔwɔa? 
\q1  
\v 10 See, O! Yehowa, eye nàkpɔ nye nublanui; 
\q2 O! Yehowa, kpe ɖe ŋunye.” 
\b  
\q1  
\v 11 Èna nye avifafa zu ɣeɖuɖu; 
\q2 èɖe akpanya le ŋutinye hetsɔ dzidzɔkpɔkpɔ do nam, 
\q1  
\v 12 ale be nye dzi nadzi ha na wò, eye mazi ɖoɖoe o. 
\q2 O! Yehowa, nye Mawu, 
\q2 mada akpe na wò tegbetegbe. 
\c 31  
\cl Psalmo 31 
\d David ƒe ha na hɛnɔ la. 
\q1  
\v 1 O! Yehowa, mewòe mebe ɖo; 
\q2 mègana ŋu nakpem akpɔ gbeɖe o; 
\q2 ɖem le wò dzɔdzɔenyenye la ta. 
\q1  
\v 2 Ƒu to anyi ɖe ŋunye, va kaba nàɖem, 
\q2 nànye nye xɔxɔ ƒe agakpe 
\q2 kple mɔ sesẽ ne nàɖem. 
\q1  
\v 3 Le wò ŋkɔ la ta, kplɔm, eye nàfia mɔm, 
\q2 elabena wòe nye nye agakpe kple mɔ sesẽ. 
\q1  
\v 4 Ɖem le mɔ si woɖo ɖi nam la me, 
\q2 elabena wòe nye nye mɔ sesẽ. 
\q1  
\v 5 Asiwò me metsɔ nye gbɔgbɔ de, eya ta Yehowa, 
\q2 nyateƒe ƒe Mawu, va nàɖem. 
\b  
\q1  
\v 6 Metsri ame siwo ku ɖe legba maɖinuwo ŋu; 
\q2 ke nye la meku ɖe Yehowa ŋu. 
\q1  
\v 7 Makpɔ dzidzɔ, eye matso aseye le wò lɔlɔ̃ la me, 
\q2 elabena èkpɔ nye hiã henya nye luʋɔ ƒe nuxaxa. 
\q1  
\v 8 Mètsɔm de asi na nye futɔ o, 
\q2 ke boŋ èɖo nye afɔ gbadzaƒe. 
\b  
\q1  
\v 9 O! Yehowa, kpɔ nublanui nam, 
\q2 elabena nye dzi ʋu dzo, 
\q1 nuxaxa na nye ŋkuwo dzi wɔ dɔ̃ɔ, 
\q2 eye konyifafa na nye luʋɔ kple ŋutilã gbɔdzɔ. 
\q1  
\v 10 Vevesese sɔŋ yɔ nye agbe me, 
\q2 eye ŋeŋe xɔ nye agbenɔƒewo me. 
\q1 Ŋusẽ vɔ le ŋunye le nye fukpekpewo ta, 
\q2 eye nye ƒuwo hã nyunyɔ ɖe lãme nam. 
\q1  
\v 11 Le nye futɔwo ƒe nuwɔnawo ta mezu alɔmeɖenu na nye 
\q2 aƒelikawo vevie ŋutɔ. 
\q1 Mezu ŋɔdzinu na xɔ̃nyewo, 
\q2 eye ame siwo do gom le mɔtata dzi la sina le nunye. 
\q1  
\v 12 Woŋlɔm be abe ɖe meku xoxo ene, 
\q2 ale mezu ze gbagbã. 
\q1  
\v 13 Mese ame geɖewo ƒe ameŋugblẽnyawo; 
\q2 ŋɔdzi ɖe to ɖem, wode adaŋu tso ŋunye, 
\q2 eye woɖo nugbe be yewoaɖe nye agbe ɖa. 
\b  
\q1  
\v 14 Ke wò, Yehowa, dzie meka ɖo; 
\q2 megblɔ be, “Wòe nye nye Mawu.” 
\q1  
\v 15 Nye ɣeyiɣiwo le asiwò me; 
\q2 ɖem tso nye futɔwo kple ame siwo 
\q2 le yonyeme tim la ƒe asi me. 
\q1  
\v 16 Na wò mo naklẽ ɖe wò dɔla dzi, 
\q2 ɖem le wò lɔlɔ̃ si meʋãna o la ta. 
\q1  
\v 17 O! Yehowa, mègana ŋu nakpem o, 
\q2 elabena wòe medo ɣli na; 
\q1 ke na ŋu nakpe ame vɔ̃ɖiwo, 
\q2 eye ɖoɖoe nazi le wo nu le yɔme. 
\q1  
\v 18 De ga nu na woƒe alakpanuyiwo, 
\q2 elabena wotsɔa dada 
\q2 kple ɖekematsɔleme gblɔa nya vlo ɖe ame dzɔdzɔe ŋu. 
\b  
\q1  
\v 19 Wò nu nyui siwo nèdzra ɖo ɖi na 
\q2 ame siwo vɔ̃a wò la lolo ŋutɔ. 
\q1 Nu nyui siwo nèkɔ ɖe ame siwo 
\q2 si wò tso dzi le amewo ƒe ŋkume la lolo. 
\q1  
\v 20 Èɣla wo ɖe ɣaɣlaƒe si le gbɔwò, 
\q2 tso amewo ƒe ayemenuwo gbɔ. 
\q1 Èɣla wo ɖe nɔwòƒe be 
\q2 woanɔ dedie tso aɖeɖiƒoame gbɔ. 
\b  
\q1  
\v 21 Woakafu Yehowa, 
\q2 elabena eɖe eƒe nukulɔlɔ̃ la fiam 
\q2 le esime mele du si ŋu woƒu kpo ɖo la me. 
\q1  
\v 22 Megblɔ le nye dzikatsoƒo me be: 
\q2 “Woɖem ɖa le wò ŋkume azɔ!” 
\q1 Ke hã la, èse nye nublanuiɣlidodo 
\q2 esi meyɔ wò be nàxɔ nam. 
\b  
\q1  
\v 23 Milɔ̃ Yehowa, mi eƒe ame kɔkɔewo! 
\q2 Yehowa kpɔa nuteƒewɔlawo ta, 
\q1 ke eɖoa eteƒe na dadalawo wòsɔa gbɔ dea 
\q2 woƒe nuwɔnawo nu. 
\q1  
\v 24 Misẽ ŋu, eye milé dzi ɖe ƒo, mi ame siwo katã tsɔ 
\q2 miaƒe mɔkpɔkpɔ de Yehowa me. 
\c 32  
\cl Psalmo 32 
\d David ƒe nufiameha. 
\q1  
\v 1 Woayra ame si wotsɔ eƒe dzidadawo kee, 
\q2 eye wotsyɔ nu eƒe nu vɔ̃wo dzi. 
\q1  
\v 2 Woayra ŋutsu si Aƒetɔ la meɖe vodada na o, 
\q2 eye alakpa mele eƒe gbɔgbɔ me o. 
\b  
\q1  
\v 3 Esi mezi ɖoɖoe la, 
\q2 nye ŋeŋe atraɖii ŋkeke blibo la katã na nye ƒuwo nyunyɔ. 
\q1  
\v 4 Elabena wò asi sẽ ɖe dzinye zã 
\q2 kple keli katã, eye ŋusẽ vɔ le ŋunye 
\q2 abe dzomeŋɔli ƒe dzoxɔxɔ mee mele ene. \qs Sela\qs* 
\b  
\q1  
\v 5 Tete meɖe nye nu vɔ̃wo fia wò, 
\q2 eye nyemetsyɔ nu nye dzidadawo dzi o. 
\q1 Megblɔ be, “Maʋu nye dzidadawo me na Yehowa”, 
\q2 eye nètsɔ nye nu vɔ̃wo ƒe yomedzenuwo kem. \qs Sela\qs* 
\b  
\q1  
\v 6 Mawumemewo katã nedo gbe ɖa na wò zi ale si nèli kpli wo, 
\q2 elabena enye nyateƒe be ne tɔsisi gãwo ɖɔ la, womade wo gbɔ o. 
\q1  
\v 7 Wòe nye nye bebeƒe, 
\q2 àɖem tso xaxa me, eye àtsɔ ɖeɖe 
\q2 ƒe aseyetsohawo aƒo xlãm. \qs Sela\qs* 
\b  
\q1  
\v 8 Mafia nu wò, eye mafia mɔ si nàto la wò. 
\q2 Maxlɔ̃ nu wò, eye makpɔ tawò. 
\q1  
\v 9 Mèganɔ abe sɔ alo tedzisɔ 
\q2 siwo nunya mele tagbɔ na o la ene o, 
\q1 elabena ele be woade ka 
\q2 kple numega nu me na wo hafi amla wo, 
\q1 ne menye nenema o la, 
\q2 womate ŋu ate ɖe ŋuwò o. 
\q1  
\v 10 Ame vɔ̃ɖiwo kpea fu geɖe, 
\q2 ke Yehowa ƒe lɔlɔ̃ si meʋãna o la ƒoa xlã 
\q2 ame siwo ɖoa dzi ɖe eŋu la. 
\b  
\q1  
\v 11 Mikpɔ dzidzɔ, eye mitso aseye ɖe Yehowa ŋu, 
\q2 mi ame dzɔdzɔewo; 
\q2 midzi ha, mi ame siwo katã ƒe dzi le dzɔdzɔe! 
\c 33  
\cl Psalmo 33 
\q1  
\v 1 Midzi ha kple dzidzɔ na Yehowa, 
\q2 mi ame dzɔdzɔewo; 
\q1 edze mi ame siwo ƒe dzi to 
\q2 mɔ ɖeka la be woakafui. 
\q1  
\v 2 Mikafu Yehowa kple kasaŋkuwo, 
\q2 eye miƒo ha nɛ le ka ewo ƒe kasaŋku dzi. 
\q1  
\v 3 Midzi ha yeye nɛ; 
\q2 miƒo ha nɛ kple ŋusẽ, eye míado dzidzɔɣli. 
\b  
\q1  
\v 4 Elabena Yehowa ƒe nya nye nyateƒe, eye wòto mɔ ɖeka; 
\q2 etoa nyateƒe le nu siwo katã wòwɔna la me. 
\q1  
\v 5 Yehowa lɔ̃a dzɔdzɔenyenye kple nuteƒewɔwɔ; 
\q2 anyigba yɔ fũu kple eƒe lɔlɔ̃ si meʋãna o. 
\b  
\q1  
\v 6 Yehowa ƒe nya wotsɔ wɔ dziƒowoe, 
\q2 eye eƒe numegbɔgbɔ wotsɔ wɔ wo ŋuti nuwoe. 
\q1  
\v 7 Eƒo atsiaƒumetsiwo nu ƒu ɖe kpluwo me, 
\q2 eye wòdzra tɔ goglowo ɖo ɖe nudzraɖoƒewo. 
\q1  
\v 8 Anyigba katã nevɔ̃ Yehowa, 
\q2 eye xexemetɔwo katã nede bubu eŋu. 
\q1  
\v 9 Elabena eƒo nu, eye wòva dzɔ; 
\q2 eɖe gbe, eye wòli ke goŋgoŋgoŋ. 
\b  
\q1  
\v 10 Yehowa gblẽ dukɔwo ƒe adaŋudedewo me, 
\q2 eye wòtɔtɔ anyigbadzitɔwo ƒe ɖoɖowo. 
\q1  
\v 11 Ke Yehowa ya ƒe ɖoɖowo nɔa anyi maʋamaʋãe ɖikaa, 
\q2 eye eƒe dzimesusuwo li tso dzidzime yi dzidzime. 
\b  
\q1  
\v 12 Woayra dukɔ si ƒe Mawue nye Yehowa, 
\q2 ame siwo wòtia be woanyi yeƒe dome. 
\q1  
\v 13 Yehowa bi kɔ tso dziƒo ke, 
\q2 eye wòkpɔ amegbetɔviwo katã. 
\q1  
\v 14 Ele eƒe nɔƒe ke hekpɔ 
\q2 ame siwo katã le anyigba dzi, 
\q1  
\v 15 eya ame si wɔ ame sia ame ƒe dzi, 
\q2 eye wòléa ŋku ɖe nu sia nu si wowɔna la ŋu. 
\b  
\q1  
\v 16 Aʋakɔ gbogbo si le fia aɖe si la mate ŋu aɖee o, 
\q2 eye ŋusẽ triakɔ hã meɖea kalẽtɔ o. 
\q1  
\v 17 Ne eɖo ɖeɖe dzi la, 
\q2 sɔ maɖe ame si tsɔ eƒe mɔkpɔkpɔ da ɖe edzi o, 
\q1 togbɔ be ŋusẽ triakɔ le esi hã la, 
\q2 mate ŋu aɖee o. 
\q1  
\v 18 Ke Yehowa ƒe ŋku le ame siwo vɔ̃nɛ la ŋu, 
\q2 ame siwo tsɔa woƒe mɔkpɔkpɔ dana ɖe 
\q2 eƒe lɔlɔ̃ si meʋãna o la dzi, 
\q1  
\v 19 be wòaɖe wo tso ku ƒe asi me, 
\q2 eye wòana woatsi agbe le dɔŋɔli. 
\b  
\q1  
\v 20 Míele lalam le mɔ kpɔm na Yehowa, 
\q2 eyae nye míaƒe xɔname kple akpoxɔnu. 
\q1  
\v 21 Míaƒe dziwo le dzidzɔ kpɔm le eya amea me, 
\q2 elabena mieka ɖe eƒe ŋkɔ kɔkɔe la dzi. 
\q1  
\v 22 O! Yehowa, na wò lɔlɔ̃ si meʋãna o la, 
\q2 nanɔ mía dzi abe ale si míetsɔ míaƒe 
\q2 mɔkpɔkpɔ da ɖe dziwò ene. 
\c 34  
\cl Psalmo 34 
\d David ƒe ha. Ekpa ha sia esime wòdo aɖaʋatɔ eɖokui le Abimelek ŋkume, eye wònyae wòdzo. 
\q1  
\v 1 Mado Yehowa ɖe dzi ɣe sia ɣi; 
\q2 eye eƒe kafukafu anɔ nye nu me ɖaa. 
\q1  
\v 2 Nye luʋɔ aƒo adegbe le Yehowa me, 
\q2 ame siwo le veve sem la nesee ne woakpɔ dzidzɔ. 
\q1  
\v 3 Mido kɔkɔ Yehowa kplim; 
\q2 mina míawɔ ɖeka ado eƒe ŋkɔ ɖe dzi. 
\b  
\q1  
\v 4 Meyɔ Yehowa, eye wòtɔ nam heɖem tso nye vɔvɔ̃wo katã me. 
\q1  
\v 5 Ame siwo tsɔ woƒe ŋku da ɖe edzi la aklẽ, 
\q2 ŋukpe matsyɔ mo na wo o. 
\q1  
\v 6 Hiãtɔ sia yɔe, eye Yehowa ɖo toe, 
\q2 heɖee le eƒe xaxawo katã me. 
\q1  
\v 7 Yehowa ƒe dɔlawo ƒua asaɖa anyi ƒoa xlã 
\q2 ame siwo vɔ̃nɛ, eye wòɖea wo. 
\b  
\q1  
\v 8 Miɖɔe kpɔ, ne miakpɔe be Yehowa ƒe dɔ me nyo; 
\q2 woayra ŋutsu si be ɖe eya amea me. 
\q1  
\v 9 Mivɔ̃ Yehowa, mi eƒe ame kɔkɔewo, 
\q2 elabena naneke mehiãa ame siwo vɔ̃nɛ la o. 
\q1  
\v 10 Dɔ awu dzatawo, eye woagbɔdzɔ, 
\q2 gake ame siwo dia Yehowa ya la, kesinɔnu aɖeke mahiã wo o. 
\q1  
\v 11 Miva, vinyewo, miɖo tom, 
\q2 ne mafia Yehowavɔvɔ̃ mi. 
\q1  
\v 12 Mia dometɔ siwo lɔ̃ agbe, 
\q2 eye miedi be miakpɔ ŋkekenyui geɖewo la, 
\q1  
\v 13 mikpɔ miaƒe aɖewo dzi nyuie tso vɔ̃ ŋuti, 
\q2 eye miaƒe nuyiwo tso aʋatsokaka ŋuti. 
\q1  
\v 14 Mite ɖa le vɔ̃ gbɔ, eye miawɔ nu nyui, 
\q2 midi ŋutifafa, eye miati eyome. 
\b  
\q1  
\v 15 Yehowa ƒe ŋku le ame dzɔdzɔewo ŋu, 
\q2 eye eƒe towo le woƒe ɣlidodo ŋu; 
\q1  
\v 16 ke Yehowa klẽa ŋku ɖe nu vɔ̃ɖi wɔlawo be wòaɖe wo ɖa 
\q2 le anyigba dzi, eye womagaɖo ŋku wo dzi akpɔ o. 
\b  
\q1  
\v 17 Ame dzɔdzɔewo do ɣli, 
\q2 Yehowa see, eye wòɖe wo le woƒe xaxawo katã me. 
\q1  
\v 18 Yehowa tsɔ ɖe ame siwo ƒe dzi gbã gudugudu la gbɔ, 
\q2 eye wòɖea ame siwo ƒe gbɔgbɔ wogbã ƒu anyi. 
\b  
\q1  
\v 19 Ame dzɔdzɔe ƒe fukpekpewo sɔ gbɔ ŋutɔ, 
\q2 gake Yehowa ɖenɛ le wo katã me; 
\q1  
\v 20 ekpɔa eƒe ƒuwo katã ta, 
\q2 eye womaŋe wo dometɔ aɖeke o. 
\b  
\q1  
\v 21 Dzɔgbevɔ̃e awu ame vɔ̃ɖi, 
\q2 eye woabu fɔ ame dzɔdzɔewo ƒe futɔwo. 
\q1  
\v 22 Yehowa ɖea eƒe dɔlawo, 
\q2 eye womabu fɔ ame siwo katã sinɛ tsona la o. 
\c 35  
\cl Psalmo 35 
\d David ƒe ha. 
\q1  
\v 1 O! Yehowa, wɔ avu kple ame siwo le avu wɔm kplim; 
\q2 wɔ aʋa kple ame siwo le aʋa wɔm kplim. 
\q1  
\v 2 Tso, tsɔ akpoxɔnu kple wò akɔtatsyɔnu, eye nàxɔ nam. 
\q1  
\v 3 Tsɔ akplɔ nueveetɔ kple nuɖekɛtɔ ɖe yonyemetilawo ŋuti. 
\q2 Gblɔ na nye luʋɔ be, 
\q2 “Nyee nye wò xɔname.” 
\b  
\q1  
\v 4 Ame siwo le nye agbe yome tim la, 
\q2 ŋukpe kple vlododo nelé wo, 
\q1 eye ame siwo le nugbe ɖom ɖe nye gbegblẽ ŋu la, 
\q2 gbegblẽ netrɔ va woawo ŋutɔ dzi. 
\q1  
\v 5 Wonenɔ abe bli ƒe atsa si ya lɔ ɖe nu ene, 
\q2 eye Yehowa ƒe dɔla nenya wo ɖe du nu; 
\q1  
\v 6 woƒe mɔ dzi nedo viviti, ahanɔ ɖiɖim, 
\q2 eye Yehowa ƒe dɔla neti wo yome. 
\b  
\q1  
\v 7 Esi nyemewɔ naneke wo o, 
\q2 gake woɖo ɖɔ ɖi nam, eye woɖe ʋe ɖi nam ta la, 
\q1  
\v 8 gbegblẽ neƒo ɖe wo dzi kpoyi, 
\q2 ɖɔ si woɖo nam la neɖe woawo ŋutɔ, 
\q2 eye woage dze ʋe si woɖe ɖi nam la me aƒaƒã ɖe afi ma. 
\q1  
\v 9 Ekema nye luʋɔ atso aseye le Yehowa me, 
\q2 eye wòadzɔ dzi le eƒe xɔname ŋuti. 
\q1  
\v 10 Nye ameti blibo la katã mado ɣli be, 
\q2 “O! Yehowa, ame kae sɔ kpli wò? 
\q1 Wò ame si ɖe ame beliwo tso 
\q2 ame siwo sesẽ wu wo la ƒe asi me, 
\q1 eye nèɖe hiãtɔwo kple ame dahewo tso 
\q2 ame siwo ha wo la ƒe asi me.” 
\b  
\q1  
\v 11 Ɖasefo ŋutasẽlawo zɔ va ŋgɔgbe, 
\q2 eye wobia biabiam tso nu 
\q2 siwo ŋuti nyemenya naneke le o. 
\q1  
\v 12 Wotsɔ vɔ̃ ɖo nyui teƒe nam, 
\q2 eye wogble nye luʋɔ ɖe nuxaxa me. 
\q1  
\v 13 Gake ne wodze dɔ la, 
\q2 metaa akpanya, eye metsɔa nutsitsidɔ bɔbɔa ɖokuinyee. 
\q2 Ne womeɖo nye gbedodoɖa ŋuti nam o la, 
\q1  
\v 14 menɔa yiyim kpokpokpo le nuxaxa me abe xɔ̃nye 
\q2 alo nɔviŋutsu fam mele ene. 
\q1 Medea mo to abe danye ƒe ku fam mele ene. 
\q1  
\v 15 Gake ne mekli nu la, 
\q2 woƒoa ƒu koa nu hahaha, 
\q2 eye ne mele vo me la, futɔwo va ɖea to ɖem. 
\q2 Woɖea alɔme le ŋunye madzudzɔmadzudzɔe. 
\q1  
\v 16 Woɖua fewu le ŋunye vevesesetɔe, 
\q2 eye woɖua aɖukli ɖe ŋunye abe mawumavɔ̃lawo ene. 
\b  
\q1  
\v 17 O! Aƒetɔ, va se ɖe ɣe ka ɣi nànɔ te akpɔ wo ase ɖo? 
\q2 Ɖe nye agbe tso woƒe nu gbegblẽwo me, 
\q2 ɖe nye agbe xɔasi tso dzata siawo ƒe asi me. 
\q1  
\v 18 Ekema mada akpe na wò le ameha gã la dome, 
\q2 eye makafu wò le ame gbogbowo dome. 
\q1  
\v 19 Mègana ame siwo nye nye futɔwo la nakpɔ dziɖuɖu 
\q2 ƒe dzidzɔ ɖe ŋunye yakatɔe o, 
\q1 eye mègana ame siwo lé fum susumanɔmetɔe la 
\q2 nate ŋku ɖem kple vevesese o. 
\q1  
\v 20 Womeƒoa nu ŋutifafatɔe o, 
\q2 ke boŋ woɖoa alakpa ƒe amenutsonyawo ɖi ɖe 
\q2 ame siwo le anyigba dzi kpoo la ŋuti. 
\q1  
\v 21 Wokea woƒe nu baa ɖe ŋutinye hegblɔna be, 
\q2 “Ɛhɛ̃! Ɛhɛ̃! Míawo ŋutɔ míekpɔe kple míaƒe ŋkuwo.” 
\b  
\q1  
\v 22 O! Yehowa, èkpɔ esia, eya ta mègazi ɖoɖoe o. 
\q2 O! Aƒetɔ, mèganɔ adzɔge nam o. 
\q1  
\v 23 Nyɔ, tso nàʋli tanye! 
\q2 Wɔ avu ɖe nunye, 
\q2 nye Mawu kple nye Aƒetɔ. 
\q1  
\v 24 Tso afia nam le wò dzɔdzɔenyenye la ta, 
\q2 O! Yehowa, nye Mawu, 
\q2 mègana woakpɔ dziɖuɖu ƒe dzidzɔ ɖe ŋutinye o. 
\q1  
\v 25 Mègana woabu be, 
\q2 “Ɛhɛ̃, esia tututu dim míele” o. 
\q2 Alo agblɔ be, “Míemii agbagbee” o. 
\b  
\q1  
\v 26 Ame siwo katã le dzidzɔ kpɔm tso nye xaxa ŋuti la, 
\q2 ŋukpe nelé wo, eye woatɔtɔ; 
\q2 na be ame siwo kɔ wo ɖokuiwo dzi ɖe ŋutinye la 
\q2 nata ŋukpe kple vlododo abe avɔ ene. 
\q1  
\v 27 Ke ame siwo dzɔ dzi be nètso afia nam la 
\q2 nedo dzidzɔɣli kple aseyetsoɣli. 
\q2 Wonenɔ gbɔgblɔm ɖaa be, 
\q1 “Woado Yehowa, ame si dzɔa dzi le eƒe dɔla 
\q2 ƒe dedinɔnɔ ŋu la ɖe dzi.” 
\b  
\q1  
\v 28 Nye aɖe aƒo nu le wò dzɔdzɔenyenye ŋuti, 
\q2 eye wòadzi wò kafukafuha ɖaa. 
\c 36  
\cl Psalmo 36 
\d David, Yehowa ƒe dɔla, ƒe ha na hɛnɔ la. 
\q1  
\v 1 Yehowa ƒe gbedeasi aɖe le nye dzi me tso 
\q2 ame vɔ̃ɖi ƒe nu vɔ̃ wɔwɔ ŋuti. 
\q2 Mawuvɔvɔ̃ aɖeke mele woƒe ŋkuwo me o. 
\b  
\q1  
\v 2 Elabena le eya ŋutɔ ŋkume, 
\q2 wòvivi nu me na eɖokui ale gbegbe be 
\q1 mete ŋu kpɔ eƒe nu vɔ̃ dze sii 
\q2 alo wòagbe nu le egbɔ o. 
\q1  
\v 3 Eƒe numenyawo vɔ̃ɖi, 
\q2 henye beble sɔŋ, eye wòdzudzɔ nuwɔwɔ ɖe nunya me 
\q2 kple nu nyui wɔwɔ. 
\q1  
\v 4 Eɖoa nu vɔ̃ɖi le eƒe aba dzi, 
\q2 etsɔa eɖokui dea asi na nu si nye vɔ̃, 
\q2 eye megbea nu si nye nu gbegblẽ o. 
\b  
\q1  
\v 5 O! Yehowa, wò lɔlɔ̃ kɔ ɖatɔ dziƒowo ke, 
\q2 eye wò nuteƒewɔwɔ tɔ dziŋgɔli ke. 
\q1  
\v 6 Wò dzɔdzɔenyenye le abe to gãwo ene, 
\q2 eye wò afiatsotso le abe tɔ goglo ene. 
\q2 O! Yehowa, èkpɔa amegbetɔwo kple lãwo siaa ta. 
\q1  
\v 7 Wò lɔlɔ̃ si meʋãna o la xɔ asi loo! 
\q2 Ame siwo ŋuti bubu le 
\q2 kple ame siwo ŋuti mele o, 
\q1 le amegbetɔviwo dome siaa kpɔa sitsoƒe 
\q2 le wò aʋala ƒe vɔvɔli te. 
\q1  
\v 8 Wò aƒemenu gbogboawo nye nuɖuɖu na wo, 
\q2 eye nènaa tsi wo wonona tso wò dzidzɔtɔsisi la me. 
\q1  
\v 9 Elabena gbɔwòe agbe ƒe tsitsetse la le, 
\q2 eye wò kekeli mee míekpɔa kekeli le. 
\b  
\q1  
\v 10 Yi edzi nàɖe wò lɔlɔ̃ afia ame siwo nya wò, 
\q2 eye nàɖe wò dzɔdzɔenyenye afia 
\q2 ame siwo ƒe dzi to mɔ ɖeka. 
\q1  
\v 11 Dadalawo megaɖo afɔ dzinye, 
\q2 alo ame vɔ̃ɖiwo ƒe asi nanyam o. 
\q1  
\v 12 Kpɔ ale si nu vɔ̃ɖi wɔlawo dze anyi ɖe anyigbae ɖa; 
\q2 wotutu wo ƒu anyi, eye womete ŋu fɔ o! 
\c 37  
\cl Psalmo 37 
\d David ƒe ha. 
\q1  
\v 1 Mègadzo nyanyanya le ame vɔ̃ɖiwo ta, 
\q2 alo aʋã ŋu nu tovo wɔlawo o 
\q1  
\v 2 elabena esusɔ vie woayrɔ abe gbe ene, 
\q2 eye abe gbe mumu ene la, woaku wo atsɔ aƒu gbe. 
\b  
\q1  
\v 3 Ɖo dzi ɖe Yehowa ŋu, eye nàwɔ nyui; 
\q2 nɔ anyigba la dzi, eye nàɖu eƒe nu nyuiwo le dziɖeɖi me. 
\q1  
\v 4 Yehowa ƒe nu nenyo ŋuwò ekema ana nu 
\q2 siwo wò dzi di la wò. 
\b  
\q1  
\v 5 Tsɔ wò mɔwo gblẽ ɖe Yehowa ƒe asi me; 
\q2 ɖo dzi ɖe eŋu, eye awɔ esia na wò. 
\q1  
\v 6 Ana wò dzɔdzɔenyenye nàdze abe ŋdikekeli ene, 
\q2 eye wò dzɔdzɔenyenye ƒe mɔ abe ŋdɔkutsuɣe ene. 
\b  
\q1  
\v 7 Zi kpoo le Yehowa ŋkume, 
\q2 eye nànɔ eƒe asinu kpɔm le dzigbɔɖi me. 
\q1 Ne amewo ƒe mɔwo dze edzi na wo, 
\q2 eye wote ŋu wɔ nu vɔ̃ɖi siwo woɖo la, 
\q2 mègavɔ̃ nàdzo nyanyanya o. 
\b  
\q1  
\v 8 Ɖe asi le dziku ŋu, eye nàtrɔ megbe de wò dɔmedzoe, 
\q2 ŋɔ megadzi wò o, 
\q2 elabena nu vɔ̃ɖi me ko wòakplɔ wò ayii. 
\q1  
\v 9 Woatsrɔ̃ ame vlowo 
\q2 gake ame siwo tsɔ woƒe mɔkpɔkpɔ de 
\q2 Yehowa me la, anyi anyigba la ƒe dome. 
\b  
\q1  
\v 10 Esusɔ vie ko ame vɔ̃ɖi la maganɔ anyi o, 
\q2 togbɔ be àdi wo hã la, màkpɔ wo o. 
\q1  
\v 11 Ke ame fafawo anyi anyigba la ƒe dome, 
\q2 eye dzi adzɔ wo le ŋutifafa gbogbo la ta. 
\b  
\q1  
\v 12 Ame vɔ̃ɖiwo ɖo nugbe ɖe 
\q2 ame dzɔdzɔewo ŋu heɖu aɖukli ɖe wo ŋuti. 
\q1  
\v 13 Ke Aƒetɔ la le ame vɔ̃ɖiwo kom, 
\q2 elabena enya be woƒe ŋkeke la gbɔna. 
\b  
\q1  
\v 14 Ame vɔ̃ɖiwo ɖe woƒe yi, 
\q2 eye wohe woƒe dati me be woada hiãtɔ 
\q1 kple ame dahe aƒu anyi, 
\q2 eye woawu ame siwo ƒe zɔzɔme to mɔ ɖeka. 
\q1  
\v 15 Gake woƒe yiwo aŋɔ woawo ŋutɔ ƒe dziwo, 
\q2 eye woƒe datiwo aŋe. 
\b  
\q1  
\v 16 Nu ʋɛ si le ame dzɔdzɔewo si la nyo wu 
\q2 kesinɔnu gbogbo siwo le ame vɔ̃ɖiwo si, 
\q1  
\v 17 elabena woaŋe ame vɔ̃ɖiwo ƒe ŋusẽ, 
\q2 ke Yehowa alé ame dzɔdzɔewo ɖe te. 
\b  
\q1  
\v 18 Ame siwo ŋuti fɔɖiɖi mele o la 
\q2 ƒe ŋkekewo le nyanya na Yehowa, 
\q2 eye woƒe domenyinu anɔ anyi tegbetegbe. 
\q1  
\v 19 Le ŋkeke vɔ̃wo dzi la, womalũ xɛ o; 
\q2 le dɔŋɔli la, nuɖuɖu ado agbogbo na woawo ya. 
\b  
\q1  
\v 20 Ke ame vɔ̃ɖi ya atsrɔ̃. 
\q2 Yehowa ƒe futɔwo anɔ abe gbe ƒe seƒoƒo ene, 
\q1 woanya kpɔ nyuie, gake wo nu ava yi, 
\q2 woabu abe dzudzɔ ene. 
\b  
\q1  
\v 21 Ame vɔ̃ɖi doa nugbana, eye mexea fea o, 
\q2 ke ame dzɔdzɔe ya naa nu faa. 
\q1  
\v 22 Ame siwo Yehowa yra la anyi anyigba la ƒe dome, 
\q2 ke ame siwo wòƒo fi de la, woaɖe wo ɖa. 
\b  
\q1  
\v 23 Ŋutsu si ƒe mɔwo dze Yehowa ŋu la, 
\q2 elia ke eƒe afɔɖeɖewo; 
\q1  
\v 24 ne ekli nu hã la, madze anyi o 
\q2 elabena Yehowa tsɔ eƒe asi lée ɖe te. 
\b  
\q1  
\v 25 Tsã la, menye ɖevi, ke azɔ la metsi, 
\q2 gake womegble ame dzɔdzɔe aɖeke ɖi mekpɔ kpɔ loo, 
\q2 alo wo viwo nabia abolo hafi aɖu o. 
\q1  
\v 26 Woawo boŋ vea ame nu ɣe sia ɣi, 
\q2 eye wodoa nugbana na amewo faa; 
\q2 eya ta wo viwo axɔ yayra. 
\b  
\q1  
\v 27 Tsri nu vɔ̃ɖi, eye nàwɔ nyui 
\q2 ekema ànɔ anyigba dzi tegbetegbe. 
\q1  
\v 28 Elabena Yehowa lɔ̃a nu dzɔdzɔe wɔlawo, 
\q2 eye magblẽ eƒe nuteƒewɔlawo ɖi o. 
\b  
\q1 Akpɔ wo ta tegbee, 
\q2 ke ame vɔ̃ɖi ƒe dzidzimeviwo ya woatsrɔ̃ wo. 
\q1  
\v 29 Ame dzɔdzɔe anyi anyigba la ƒe dome, 
\q2 eye wòanɔ edzi tegbee. 
\b  
\q1  
\v 30 Nunyanya doa go tso ame dzɔdzɔe ƒe nu me, 
\q2 eye eƒe aɖe gblɔa nu si le eteƒe. 
\q1  
\v 31 Eƒe Mawu ƒe se le eƒe dzi me, 
\q2 eya ta eƒe afɔ meɖiɖina o. 
\b  
\q1  
\v 32 Ame vɔ̃ɖiwo de xa ɖi na ame dzɔdzɔewo, 
\q2 eye wole woƒe ku dim; 
\q1  
\v 33 gake Yehowa matsɔ wo agblẽ ɖe woƒe ŋusẽ te, 
\q2 alo wòaɖe mɔ be, woabu fɔ wo ne wokplɔ wo va ʋɔnui o. 
\b  
\q1  
\v 34 Lala nàkpɔ Yehowa ƒe asinu, 
\q2 eye nàlé eƒe mɔ ɖe asi. 
\q1 Ado wò ɖe dzi be nànyi anyigba la ƒe dome. 
\q2 Ne woatsrɔ̃ ame vɔ̃ɖiwo la, àkpɔ eteƒe. 
\b  
\q1  
\v 35 Mekpɔ ame vɔ̃ɖi, 
\q2 ŋutasẽla aɖe wòda ama nyuie 
\q2 abe ati dama si dzɔ kple anyigba la ene. 
\q1  
\v 36 Gake eteƒe medidi o ko, enu va yi, eye megali o; 
\q2 togbɔ be medii hã la, nyemeke ɖe eŋuti o. 
\b  
\q1  
\v 37 Bu ame maɖifɔ la ŋu, 
\q2 eye nàlé ŋku ɖe ame dzɔdzɔewo ŋu, 
\q2 elabena ŋgɔgbe li na ŋutifafamewo katã. 
\q1  
\v 38 Ke woatsrɔ̃ nu vɔ̃ wɔlawo katã, 
\q2 eye woaɖe ame vɔ̃ɖi la ɖa. 
\b  
\q1  
\v 39 Ame dzɔdzɔewo ƒe xɔxɔ atso Yehowa gbɔ, 
\q2 eye eyae nye woƒe mɔ sesẽ le xaxaɣeyiɣiwo me. 
\q1  
\v 40 Ke Yehowa kpena ɖe wo ŋu, eye wòɖea wo tso dzɔgbevɔ̃e me; 
\q2 eɖea wo tso ame vɔ̃ɖiwo ƒe asi me, 
\q2 eye wòkpena ɖe wo ŋu, 
\q2 elabena eyae wosi tso. 
\c 38  
\cl Psalmo 38 
\d David ƒe ha. Kukuɖeɖe. 
\q1  
\v 1 O! Yehowa, mègaka mo nam le wò dziku me, 
\q2 alo ahe to nam le wò dɔmedzoe helĩhelĩ me o, 
\q1  
\v 2 elabena wò aŋutrɔwo ƒo ɖem, 
\q2 eye wò asi sẽ ɖe dzinye. 
\q1  
\v 3 Wò dziku helĩhelĩ la wɔe be ŋusẽ aɖeke megale menye o; 
\q2 nye ƒuwo tugu le nye nu vɔ̃ ta. 
\q1  
\v 4 Nye dzidada kɔ gbɔ tanye abe agba kpekpe si 
\q2 nyemate ŋu atsɔ o la ene. 
\b  
\q1  
\v 5 Nye abiwo ƒaƒã hele ʋeʋẽm 
\q2 le nye bometsitsi ƒe nu vɔ̃ ta. 
\q1  
\v 6 Wobɔbɔm ɖe anyi, eye woɖi gbɔ̃m, 
\q2 eye ŋkeke blibo la, mele yiyim le nuxaxa me. 
\q1  
\v 7 Vevesese manyagblɔ aɖe xɔ nye ame blibo la me, 
\q2 eye ŋusẽ aɖeke megale nye ameti blibo la ŋu o. 
\q1  
\v 8 Megbɔdzɔ, hegba gudugudu, 
\q2 eye mele ŋeŋem le nye dzi ƒe vevesese ta. 
\b  
\q1  
\v 9 O! Aƒetɔ, nye dzimedidiwo katã le ŋkuwò me, 
\q2 eye nye hũɖeɖewo meɣla ɖe wò o. 
\q1  
\v 10 Nye dzi le tsotsom kpokpokpo, 
\q2 ŋusẽ vɔ le ŋunye, eye nyemegate ŋu le nu kpɔm o. 
\q1  
\v 11 Le nye abiawo ta, 
\q2 xɔ̃nyewo kple nye zɔhɛwo ƒo asa nam, 
\q2 eye nye aƒelikawo hã le adzɔge nam. 
\q1  
\v 12 Ame siwo le nye agbe yome tim la tre mɔ nam, 
\q2 ame siwo di be yewoawɔ nuvevim la 
\q2 le nu ƒom tso nye gbegblẽ ŋuti; 
\q2 ŋkeke blibo la wole ɖoɖo wɔm ɖe alakpadada ŋu. 
\b  
\q1  
\v 13 Mele abe tokunɔ si mate ŋu ase nu o la ene, 
\q2 eye mele abe aɖetututɔ si mate ŋu aƒo nu o la ene. 
\q1  
\v 14 Mele abe ame si mesea nu o la ene 
\q2 kple ame si mate ŋu atsɔ eƒe nu aɖo nya aɖeke ŋu o la ene. 
\q1  
\v 15 O! Yehowa, mele asiwò nu kpɔm, 
\q2 O! Aƒetɔ, nye Mawu, atɔ nam godoo. 
\q1  
\v 16 Elabena megblɔ be, “Mègana be woakpɔ dziɖuɖu ƒe dzidzɔ ɖe ŋutinye, 
\q2 alo woado wo ɖokui ɖe dzi ɖe ŋutinye ne nye afɔ ɖiɖi o.” 
\b  
\q1  
\v 17 Esusɔ vie ko madze anyi, 
\q2 eye nye vevesese la le edzi ɖaa. 
\q1  
\v 18 Meʋu nye dzidada me, 
\q2 eye nye nu vɔ̃ ɖe fu nam. 
\q1  
\v 19 Ame geɖewoe nye nye futɔ gãwo, 
\q2 eye ame siwo lé fum susumanɔmetɔe la sɔ gbɔ ŋutɔ. 
\q1  
\v 20 Ame siwo tsɔ vɔ̃ ɖo nyui siwo mewɔ teƒe la 
\q2 ƒo ɖi nye ŋkɔ, 
\q2 esi meti nu si nyo la yome. 
\b  
\q1  
\v 21 O! Yehowa, mègagblẽm ɖi o, 
\q2 O! Nye Mawu, mèganɔ adzɔge nam o. 
\q1  
\v 22 Va kaba, nàɖem, 
\q2 O! Aƒetɔ, nye Ɖela. 
\c 39  
\cl Psalmo 39 
\d David ƒe ha na hɛnɔ Yedutun. 
\q1  
\v 1 Megblɔ be, “Malé ŋku ɖe nye mɔwo ŋu, 
\q2 akpɔ nye aɖe dzi be mawɔ nu vɔ̃ o, 
\q1 eye zi ale si ame vɔ̃ɖi la gale ŋkunye me la, 
\q2 made ga nye nu.” 
\q1  
\v 2 Gake esi mezi ɖoɖoe li kpoo, 
\q2 eye nyemele nya nyui aɖeke gblɔm o hã la, 
\q2 nye vevesese do ga ɖe edzi. 
\q1  
\v 3 Nye dzi xɔ dzo ɖe dɔ me nam; 
\q2 esi mele ŋugble dem la, exɔ dzo ɖe edzi; 
\q2 tete meƒo nu kple nye aɖe. 
\b  
\q1  
\v 4 “O! Yehowa, fia nye agbe ƒe nuwuwu 
\q2 kple ŋkeke ale si manɔ agbee lam; 
\q2 eye na manya ale si nye agbe le du dzii. 
\q1  
\v 5 Èwɔ nye ŋkekewo wole abe asi ƒe kekeme ko ene, 
\q2 eye nye agbenɔɣi menye naneke le ŋkuwò me o. 
\q2 Amegbetɔ ɖe sia ɖe ƒe agbe le abe ƒuƒu ko ene. \qs Sela\qs* 
\b  
\q1  
\v 6 “Amegbetɔ le yiyim, le gbɔgbɔm, 
\q2 ke vɔvɔli ko wònye. 
\q1 Ele agbagba dzem, gake wo katã nye nu dzodzro 
\q2 Eli kɔ kesinɔnuwo gleglegle, 
\q2 gake menya ame si ƒe asi me woayi ɖo o. 
\b  
\q1  
\v 7 “Aƒetɔ, ke azɔ la, nu ka makpɔ mɔ na? 
\q2 Nye mɔkpɔkpɔ le mewò. 
\q1  
\v 8 Ɖem tso nye vodadawo katã me, 
\q2 eye mègawɔm mazu alɔmeɖenu na yakamewo o. 
\q1  
\v 9 Mezi ɖoɖoe, nyemake nu o, 
\q2 elabena wòe wɔ esia. 
\q1  
\v 10 Ɖe wò tohehe si le dzinye la ɖa; 
\q2 wò asi va dzinye kple ŋusẽ ale metsi anyigba. 
\q1  
\v 11 Èkaa mo, eye nèhea to na amewo ɖe woƒe nu vɔ̃wo ta; 
\q2 ègblẽa woƒe kesinɔnuwo dome abe agbagblaʋui ene, 
\q2 ale amegbetɔ ɖe sia ɖe le abe ƒuƒu ko ene. \qs Sela.\qs* 
\b  
\q1  
\v 12 “O! Yehowa, se nye gbedodoɖa, 
\q2 nye ɣlidodo hena kpekpeɖeŋu nede to me na wò; 
\q2 mègado toku nye avifafa o. 
\q1 Amedzro kple mɔzɔla menye le gbɔwò 
\q2 abe ale si fofonyewo katã nɔ ene. 
\q1  
\v 13 Ɖe ŋku ɖa le ŋunye, ale be magakpɔ dzidzɔ hafi mayi, 
\q2 eye nyemaganɔ anyi o.” 
\c 40  
\cl Psalmo 40 
\d David ƒe ha na hɛnɔ la. 
\q1  
\v 1 Mele mɔ kpɔm na Yehowa le dzigbɔɖi blibo me; 
\q2 etrɔ ɖe ŋutinye, eye wòse nye ɣlidodo. 
\q1  
\v 2 Ehem do goe tso ʋe dziŋɔ me, 
\q2 eye wòɖem tso ba finyafinya me, 
\q1 hetsɔ nye afɔ ɖo agakpe dzi, 
\q2 eye wòna meli ke ɖe afi si metɔ ɖo. 
\q1  
\v 3 Etsɔ ha yeye de nunye si nye kafukafuha na míaƒe Mawu la. 
\q2 Ame geɖewo akpɔe, 
\q2 woavɔ̃e, eye woaɖo dzi ɖe Yehowa ŋu. 
\b  
\q1  
\v 4 Woayra ame si ɖoa dzi ɖe Yehowa ŋu, 
\q2 ame si mekpɔa dadalawo ƒe asinu, 
\q2 alo kplɔa ame siwo dze alakpalegbawo yome o. 
\q1  
\v 5 O! Yehowa, nye Mawu, 
\q2 wò nukunu siwo nèwɔ la sɔ gbɔ loo! 
\q1 Ɖoɖo geɖe siwo nèwɔ ɖe mía ŋu la, 
\q2 ame aɖeke mate ŋu axlẽ wo afia wò o. 
\q1 Ne ɖe wòanye be maƒo nu le wo ŋu, 
\q2 eye maxlẽ wo afia la, nyemate ŋui o, 
\q2 elabena wosɔ gbɔ akpa. 
\b  
\q1  
\v 6 Mèdi vɔsa kple nunana, 
\q2 alo bia numevɔsa kple akpedavɔsa o, 
\q2 ke boŋ èʋu nye towo be mase wò gbe, 
\q1  
\v 7 eya ta meɖo ŋu be, 
\q2 “Nyee nye si meva; 
\q2 agbalẽ mee woŋlɔe ɖo tso ŋutinye. 
\q1  
\v 8 Medi be mawɔ wò lɔlɔ̃nu, 
\q2 O! Nye Mawu, woŋlɔ wò se la ɖe nye dzi me.” 
\b  
\q1  
\v 9 O! Yehowa, meɖe gbeƒã wò dzɔdzɔenyenye le ameha gã la dome, 
\q2 eye abe ale si nènya ene la, nyememia nye nu o. 
\q1  
\v 10 Nyemeɣla wò dzɔdzɔenyenye ɖe nye dzi me o, 
\q2 ke boŋ meƒo nu le wò nuteƒewɔwɔ kple ɖeɖe ŋuti. 
\q1 Nyemeɣla wò lɔlɔ̃ 
\q2 kple wò nyateƒe la ɖe ameha gã la o. 
\b  
\q1  
\v 11 O! Yehowa, mègate wo nublanuikpɔkpɔ o, 
\q2 ke boŋ na be wò lɔlɔ̃ kple wò nyateƒe nakpɔ tanye ɖaa, 
\q1  
\v 12 elabena fukpekpe siwo mele xexlẽ o la ɖe to ɖem, 
\q2 nye nu vɔ̃wo wu tsɔtsɔ nam 
\q2 eye nyemegate ŋu le nu kpɔm o. 
\q1 Wosɔ gbɔ wu nye taɖa, 
\q2 eye dzi ɖe le ƒonye. 
\q1  
\v 13 O! Yehowa, nedze ŋuwò be nàɖem; 
\q2 O! Yehowa, va kaba nàɖem. 
\b  
\q1  
\v 14 Ŋu nekpe ame siwo katã le nye agbe dim ne woaɖe ɖa la; 
\q2 woƒe mo netsi dãa, 
\q1 eye ame siwo katã le nye gbegblẽ dim la 
\q2 negbugbɔ ɖe megbe kple ŋukpe. 
\q1  
\v 15 Ame siwo le gbɔgblɔm ɖe ŋunye be, 
\q2 “Ehɛ̃! Ehɛ̃!” la ƒe ŋukpe newɔ moya na wo. 
\q1  
\v 16 Ke ame siwo katã dia wò la akpɔ dzidzɔ, 
\q2 eye woatso aseye akpɔ dzidzɔ le mewò. 
\q1 Ame siwo lɔ̃a wò ɖeɖe la negblɔ ɖaa be, 
\q2 “Mido Yehowa ɖe dzi!” 
\b  
\q1  
\v 17 Ke nye la, meda ahe, eye hiã le tu yem, 
\q2 O! Aƒetɔ, ɖo ŋku dzinye. O! Nye Mawu, 
\q1 wòe nye nye kpeɖeŋutɔ kple nye xɔname, 
\q2 mègahe ɖe megbe o. 
\c 41  
\cl Psalmo 41 
\d David ƒe ha na hɛnɔ la. 
\q1  
\v 1 Woayra ame si tsɔ ɖe le eme na ame dahewo, 
\q2 Yehowa aɖee le xaxaɣi. 
\q1  
\v 2 Yehowa adzɔ eŋu, eye wòakpɔ eƒe agbe ta. 
\q2 Yehowa ayrae le anyigba dzi, 
\q2 eye matsɔe ade asi na eƒe futɔwo ƒe didi o. 
\q1  
\v 3 Yehowa anɔ kplii le dɔba dzi, eye wòana lãmesesẽe, 
\q2 afɔe tso dɔba dzi. 
\b  
\q1  
\v 4 Megblɔ be, “O! Yehowa, 
\q2 kpɔ nublanui nam, yɔ dɔm, 
\q2 elabena mewɔ nu vɔ̃ ɖe ŋuwò.” 
\q1  
\v 5 Nye futɔwo le gbɔgblɔm tso ŋunye fewuɖutɔe be, 
\q2 “Ɣe ka ɣi gɔ̃e wòle kuku ge ne eƒe ŋkɔ natsrɔ̃?” 
\q1  
\v 6 Ne ame aɖe ɖi tsa va be yeakpɔm ɖa la, 
\q2 edaa alakpa, eƒe dzi ƒoa ameŋugblẽnyawo nu ƒu, 
\q2 eye wòdoa go yina kakanɛ. 
\b  
\q1  
\v 7 Nye futɔwo katã le dalĩ dom le ŋutinye, 
\q2 eye wole nu vɔ̃ɖiwo susum tso ŋutinye le gbɔgblɔm be, 
\q1  
\v 8 “Dɔléle vɔ̃ɖi aɖe dze edzi, 
\q2 magatso le afi si wòmlɔ la akpɔ gbeɖe o.” 
\q1  
\v 9 Xɔ̃nye si tsi metoa nye kplii dome o, 
\q2 ame si dzi meka ɖo, 
\q2 eye wòɖua nu kplim la kɔ eƒe afɔkpodzi dzi ɖe ŋutinye. 
\b  
\q1  
\v 10 O! Yehowa, ke wò ya kpɔ nye nublanui, 
\q2 kɔm ɖe dzi be maɖo teƒe na wo. 
\q1  
\v 11 Menya be èkpɔ ŋudzedze le ŋutinye, 
\q2 elabena nye ketɔ meɖu dzinye o. 
\q1  
\v 12 Le nye nuteƒewɔwɔ ta la, èlém ɖe asi, 
\q2 eye nètsɔm ɖo wò ŋkume tegbetegbe. 
\b  
\b  
\q1  
\v 13 Woakafu Yehowa, Israel ƒe Mawu la 
\q2 tso mavɔ me yi mavɔ me. 
\qc Neva eme, ɛ̃, neva eme. 
\c 42  
\ms1 Agbalẽ evelia 
\mr Psalmowo 42–72 
\cl Psalmo 42 
\d Korah ƒe viwo ƒe ha na hɛnɔ la. 
\q1  
\v 1 Ale si zinɔ ƒe ve me ƒunae ɖe tɔʋuwo ŋu la, 
\q2 O! Mawu, nenemae nye luʋɔ le diwòm. 
\q1  
\v 2 Tsikɔ le nye luʋɔ wum ɖe Mawu ŋu, 
\q2 ɖe Mawu gbagbe la ŋu. 
\q2 Ɣe ka ɣi mayi aɖado go Mawu? 
\q1  
\v 3 Nye aɖatsiwo zu nuɖuɖu nam zã kple keli, 
\q2 evɔ amewo le gbɔgblɔm nam ŋkeke blibo la be, 
\q2 “Afi ka wò Mawu la le?” 
\q1  
\v 4 Nu siawo dzi meɖo ŋkue esi meyi ɖokuinye me. 
\q2 Tsã la, nyee kplɔa amehawo; 
\q2 menɔa ŋgɔ kplɔa wo yina ɖe gbedoxɔ me, 
\q1 eye dzidzɔɣli kple kafukafuhawo dea dzi 
\q2 le ŋkekenyuiɖulawo dome kɔtɔɔ. 
\q1  
\v 5 O! Nye luʋɔ, nu ka ŋuti nèle nu xam? 
\q2 Nu ka ta nètsi dzodzodzoe le menye ɖo? 
\q1 Tsɔ wò mɔkpɔkpɔ da ɖe Mawu dzi, 
\q2 elabena magakafui, 
\q1 eya ame si nye nye Ɖela 
\q2 kple nye Mawu. 
\q1  
\v 6 Nye luʋɔ le nu xam le menye, 
\q2 eya ta maɖo ŋku dziwò le Yɔdanyigba dzi, 
\q2 le Hermon tame ke kple Mizar to dzi. 
\q1  
\v 7 Tɔ goglo yɔa tɔ goglo le wò tsitsetsewo ƒe howɔwɔ me; 
\q2 wò tsitsotsoewo kple tsi kpakawo ŋe tsyiɔ dzinye. 
\q1  
\v 8 Le ŋkeke me la, Yehowa ɖoa eƒe lɔlɔ̃ ɖem, 
\q2 le zã me la eƒe ha nɔa nunyeme, 
\q2 eye wònyea gbedodoɖa na nye agbe ƒe Mawu la. 
\q1  
\v 9 Megblɔ na Mawu, nye Agakpe la be, 
\q2 “Nu ka ta nèŋlɔm be ɖo? 
\q1 Nu ka ta manɔ yiyim, anɔ nu xam 
\q2 le nye futɔwo ƒe teteɖeanyi ta ɖo?” 
\q1  
\v 10 Nye ƒuwo le veve sem, eye nye ketɔwo 
\q2 le alɔme ɖem le ŋunye, 
\q1 le gbɔgblɔm nam ŋkeke blibo la be, 
\q2 “Afi ka wò Mawu la le?” 
\q1  
\v 11 O! Nye luʋɔ, nu ka ta nèle nu xam ɖo? 
\q2 Nu ka ta nètsi dzodzodzoe le menye ɖo? 
\q1 Tsɔ wò mɔkpɔkpɔ da ɖe Mawu dzi, 
\q2 elabena magakafui, 
\q2 eya ame si nye nye Ɖela kple nye Mawu. 
\c 43  
\cl Psalmo 43 
\q1  
\v 1 O! Mawu, tso afia nam, 
\q2 eye nàʋli tanye le mawumavɔ̃lawo dome, 
\q2 ɖem tso ame vɔ̃ɖiwo kple ameblelawo ƒe asi me. 
\q1  
\v 2 Wòe nye Mawu, nye mɔ sesẽ. 
\q2 Nu ka ta nègbem ɖo? 
\q1 Nu ka ta manɔ yiyim, anɔ nu xam 
\q2 le nye futɔwo ƒe teteɖeanyi ta ɖo? 
\q1  
\v 3 Ɖo wò kekeli kple nyateƒe ɖa, ne woakplɔm; 
\q2 na woakplɔm ayi ɖe wò to kɔkɔe la dzi, afi si nènɔna. 
\q1  
\v 4 Ekema mayi ɖe Mawu ƒe vɔsamlekpui ŋgɔ, 
\q2 Mawu si nye nye aseyetsotso kple nye dzidzɔ. 
\q2 O! Mawu, nye Mawu, makafu wò kple kasaŋku. 
\b  
\q1  
\v 5 O! Nye luʋɔ, nu ka ta nèle nu xam ɖo? 
\q2 Nu ka ta nètsi dzodzodzoe le menye ɖo? 
\q1 Tsɔ wò mɔkpɔkpɔ da ɖe Mawu dzi, 
\q2 elabena magakafui, 
\q2 eya ame si nye nye Ɖela kple nye Mawu. 
\c 44  
\cl Psalmo 44 
\d Korah ƒe viwo ƒe nufiameha na hɛnɔ la. 
\q1  
\v 1 O! Mawu, míawo ŋutɔ míesee 
\q2 kple míaƒe towo, nu siwo mía fofowo gblɔ na 
\q2 mí tso nu siwo nèwɔ na wo le woƒe ɣeyiɣiwo me le blema. 
\q1  
\v 2 Ètsɔ wò asi nya dukɔwo, 
\q2 eye nètsɔ mía fofowo ɖo wo teƒe. 
\q1 Ègbã dukɔwo gudugudu, 
\q2 ke èna mía fofowo ya dzi ɖe edzi. 
\q1  
\v 3 Anyigba mesu wo si to 
\q2 woawo ŋutɔ ƒe yi dzi loo, 
\q1 alo woawo ŋutɔ ƒe alɔe ɖu dzi na wo o, 
\q2 ke boŋ wò nuɖusi, 
\q1 wò alɔ kple wò mo ƒe kekelie xɔ na wo, 
\q2 elabena èlɔ̃ wo. 
\b  
\q1  
\v 4 Wòe nye nye Fia kple nye Mawu, 
\q2 wòe he dziɖuɖuwo vɛ na Yakob. 
\q1  
\v 5 To dziwò míetutu míaƒe futɔwo do ɖe megbe, 
\q2 eye to wò ŋkɔ me míenya avuzi le míaƒe futɔwo dzi. 
\q1  
\v 6 Nyemeɖo ŋu ɖe nye aŋutrɔ ŋu o, 
\q2 eye nye yi mehe dziɖuɖu vɛ nam o, 
\q1  
\v 7 ke boŋ èna míeɖu míaƒe ketɔwo dzi, 
\q2 eye nèna ŋukpe lé míaƒe adikatɔwo. 
\q1  
\v 8 Míetsɔ Mawu ƒo adegbe ŋkeke blibo la, 
\q2 eye míakafu wò ŋkɔ tegbetegbe. \qs Sela\qs* 
\q1  
\v 9 Ke azɔ la, ègbe mí, eye nèbɔbɔ mí ɖe anyi; 
\q2 azɔ la, mègadona kple míaƒe aʋakɔwo o. 
\q1  
\v 10 Èna míegbugbɔ ɖe megbe le míaƒe futɔwo ŋgɔ, 
\q2 eye míaƒe ketɔwo ha mí. 
\q1  
\v 11 Ètsɔ mí na be woavuvu mí abe alẽwo ene, 
\q2 eye nèkaka mí ɖe dukɔwo dome. 
\q1  
\v 12 Ètsɔ wò dukɔ la dzra ho kpɔtsɔe 
\q2 eye mèkpɔ naneke le wo dzadzra me o. 
\b  
\q1  
\v 13 Ètsɔ mí wɔ vlodonu na míaƒe aƒelikawo, 
\q2 eye míezu alɔmeɖenu kple nu ɖikokoe na ame siwo ƒo xlã mí. 
\q1  
\v 14 Ètsɔ mí wɔ lodonu le dukɔwo dome, 
\q2 eye amewo ʋuʋua ta ɖe mía ŋu ne wokpɔ mí. 
\q1  
\v 15 Nye vlododo le ŋkunye me ŋkeke blibo la, 
\q2 eye ŋukpe tsyɔa mo nam, 
\q1  
\v 16 ne vlodolawo, fewuɖulawo le nunye ɖiam, 
\q2 elabena futɔ la ɖoe kplikpaa be yeabia hlɔ̃m. 
\b  
\q1  
\v 17 Togbɔ be míeŋlɔ wò be, 
\q2 alo da alakpa le wò nubabla la me o hã 
\q2 la, èna nu siawo katã va mía dzi. 
\q1  
\v 18 Míaƒe dziwo metrɔ le yowòme o, 
\q2 eye míaƒe afɔwo hã metra le wò mɔ dzi o. 
\q1  
\v 19 Gake ègbã mí gudugudu hegble mí ɖe amegaxiwo dome, 
\q2 eye nètsɔ viviti tsiɖitsiɖi tsyɔ mía dzi. 
\b  
\q1  
\v 20 Nenye ɖe míeŋlɔ míaƒe Mawu ŋkɔ be, 
\q2 alo ke míaƒe abɔwo na dzromawu aɖe la, 
\q1  
\v 21 ɖe Mawu manya esi wònya 
\q2 dzimenu ɣaɣlawo katã oa? 
\q1  
\v 22 Gake le tawò la, míekpɔa ku ŋkeke blibo la, 
\q2 eye wobua mí abe alẽ siwo wokplɔ yina wuwu ge la ene. 
\b  
\q1  
\v 23 Nyɔ, O Aƒetɔ! Nu ka ta nèle alɔ̃ dɔm ɖo? 
\q2 Fɔ! Mègagbe mí ɖikaa o. 
\q1  
\v 24 Nu ka ta nèɣla wò mo, 
\q2 eye nèŋlɔ míaƒe hiãkame kple teteɖeanyi be ɖo? 
\b  
\q1  
\v 25 Wohe mí ƒu ke me, 
\q2 eye míaƒe ŋutilã lé ɖe anyigba. 
\q1  
\v 26 Tso, nàxɔ na mí, 
\q2 ɖe mí le wò lɔlɔ̃ si meʋãna o la ta. 
\c 45  
\cl Psalmo 45 
\d Korah ƒe viwo ƒe nufiameha si nye srɔ̃ɖeha na hɛnɔ la, ne woadzi ɖe dzogbenya ƒe gbeɖiɖi nu. 
\q1  
\v 1 Nya nyuiwo le fiefiem le nye dzi me 
\q2 esi mele ha sia kpam na fia la, 
\q2 eye nye aɖee nye nuŋlɔla adodoea ƒe nuŋlɔti. 
\b  
\q1  
\v 2 Èdze ɖeka wu ŋutsuwo katã, 
\q2 wotsɔ amenuveve si ami na wò nuyi, 
\q2 elabena Mawu yra wò tegbee. 
\b  
\q1  
\v 3 O! Kalẽtɔ, tsɔ wò yi ta ɖe ali, 
\q2 eye nàtsɔ wò atsyɔ̃ kple gãnyenye ata. 
\q1  
\v 4 Do sɔ dziɖuɖutɔe le wò fianyenye me. 
\q2 Le nyateƒe, ɖokuibɔbɔ kple dzɔdzɔenyenye me, 
\q2 na wò nuɖusi naɖe wò nuwɔwɔ dziŋɔwo afia. 
\q1  
\v 5 Na wò aŋutrɔ ɖaɖɛwo naŋɔ fia la ƒe futɔwo ƒe dzi, 
\q2 eye na dukɔwo nadze anyi ɖe wò afɔ nu. 
\q1  
\v 6 O! Mawu, wò fiazikpui ali ke tso mavɔ me yi ɖe mavɔ me, 
\q2 wò fiaɖuƒe la ƒe tsiamiti anye nuteƒewɔwɔ ƒe atikplɔ. 
\q1  
\v 7 Èlɔ̃ dzɔdzɔenyenye, eye nètsri nu vɔ̃ɖi wɔwɔ; 
\q2 eya ta Mawu, wò Mawu la 
\q1 ɖo wò nèkɔ gbɔ fia bubuwo ta to dzidzɔkpɔkpɔ 
\q2 ƒe amisisi na wò me. 
\q1  
\v 8 Kotoklobo, lifi kple atike ʋeʋĩ le ya ɖem le wò awuwo me. 
\q2 Kasaŋkuwo na nèle aseye tsom le wò nyiɖufiasawo me. 
\q1  
\v 9 Fiavinyɔnuwo le wò nyɔnu bubumewo dome, 
\q2 eye fiasrɔ̃ si do Ofir Sikanuwo la nɔ wò nuɖusime. 
\b  
\q1  
\v 10 O! Vinyɔnu, ɖo to, nàbu eŋu, eye nàƒu to anyi. 
\q2 Ŋlɔ wò dukɔ kple fofowò ƒe aƒe la be. 
\q1  
\v 11 Wò tugbedzedze wɔ dɔ ɖe fia la dzi ŋutɔ, 
\q2 eya ta de bubu eŋu, elabena eyae nye wò aƒetɔ. 
\q1  
\v 12 Tiro vinyɔnu atsɔ nunana vɛ, 
\q2 eye ŋutsu kesinɔtɔwo ava bia amenuveve tso gbɔwò. 
\q1  
\v 13 Fiavinyɔnu la nye keklẽ sɔŋ le eƒe xɔ me; 
\q2 eye wotsɔ sika lé ɖe eƒe awu legbe ƒe teƒeteƒewo keŋ. 
\q1  
\v 14 Edo awu legbe si wolɔ̃ kple ka, 
\q2 eye wokplɔe va fia la gbɔe; 
\q1 eƒe dɔlanyɔnu siwo menya ŋutsu o la kplɔe ɖo, 
\q2 eye wokplɔ wo vɛ na wò. 
\q1  
\v 15 Wokplɔ wo ge ɖe eme le dzidzɔkpɔkpɔ kple aseyetsotso me, 
\q2 ale woge ɖe fiasã la me. 
\b  
\q1  
\v 16 Mía viŋutsuwo axɔ ɖe mía fofowo teƒe, 
\q2 eye míawɔ wo fiaviwo le anyigba la katã dzi. 
\b  
\q1  
\v 17 Mana woaɖo ŋku dziwò le dzidzimewo katã me, 
\q2 eya ta dukɔwo akafu wò tso mavɔ me yi ɖe mavɔ me. 
\c 46  
\cl Psalmo 46 
\d Korah ƒe viwo ƒe ha na hɛnɔ la, ne woadzi ɖe \tl alamot\tl* ƒe gbeɖiɖi nu. 
\q1  
\v 1 Mawue nye míaƒe sitsoƒe kple ŋusẽ, 
\q2 xɔnametɔ si li ɖaa kpli mí le xaxawo me. 
\q1  
\v 2 Eya ta ne anyigba gli le zi dzi hã la, míavɔ̃ o, 
\q2 ne towo ho ɖadze atsiaƒu me, 
\q1  
\v 3 eye atsiaƒutsi ɖe gbe lɔ futukpɔ ɖe nu, 
\q2 ale be towo dzo kpekpekpe 
\q2 le eƒe howɔwɔ ta hã la, míavɔ̃ o. \qs Sela\qs* 
\b  
\q1  
\v 4 Tɔsisi aɖe li, 
\q2 esi ƒe tsiwo doa dzidzɔ na Mawu ƒe du, 
\q2 teƒe kɔkɔe, afi si Dziƒoʋĩtɔ la nɔna. 
\q1  
\v 5 Mawu le afi ma, eya ta mamu adze anyi o. 
\q2 Mawu akpe ɖe eŋu ne ŋu ke teti. 
\q1  
\v 6 Hoowɔwɔ ɖo dukɔwo me, fiaɖuƒewo mu; 
\q2 ekɔ eƒe gbe dzi, tete anyigba lolo. 
\b  
\q1  
\v 7 Yehowa, Dziƒoʋakɔwo ƒe Aƒetɔ la li kpli mí, 
\q2 Yakob ƒe Mawu la nye míaƒe mɔ sesẽ. \qs Sela\qs* 
\b  
\q1  
\v 8 Miva kpɔ Yehowa ƒe dɔwɔwɔwo ɖa, 
\q2 miva kpɔ gbegblẽ si wòhe va anyigba dzi la ɖa. 
\q1  
\v 9 Ena aʋawɔwɔ nu tso va se ɖe keke anyigba ƒe mlɔenu ke; 
\q2 eŋe da, eye wòfli akplɔ, 
\q2 hetɔ dzo akpoxɔnuwo. 
\q1  
\v 10 “Ɖe dzi ɖi, eye nànya be nyee nye Mawu. 
\q2 Woadom ɖe dzi le dukɔwo dome, 
\q2 eye woadom ɖe dzi le anyigba dzi.” 
\b  
\q1  
\v 11 Yehowa Dziƒoʋakɔwo ƒe Aƒetɔ la li kpli mí, 
\q2 Yakob ƒe Mawu la nye míaƒe mɔ sesẽ. \qs Sela.\qs* 
\c 47  
\cl Psalmo 47 
\d Korah ƒe viwo ƒe ha na hɛnɔ la. 
\q1  
\v 1 Miƒo asikpe, mi dukɔwo katã. 
\q2 Mitso aseye ɖe Mawu ŋu kple ɣli. 
\b  
\q1  
\v 2 Ŋɔdzi le Yehowa Dziƒoʋĩtɔ la ŋu ale gbegbe, 
\q2 eyae nye Fiagã ɖe anyigba la katã dzi! 
\q1  
\v 3 Ebɔbɔ dukɔwo ɖe mía te, 
\q2 eye wòtsɔ anyigbadzitɔwo de míaƒe afɔ te. 
\q1  
\v 4 Etia míaƒe domenyinu na mí si nye dada na Yakob, 
\q2 ame si wòlɔ̃. \qs Sela\qs* 
\b  
\q1  
\v 5 Mawu yi dzi kple aseyetsotso, 
\q2 Yehowa yi dzi kple kpẽ ƒe ɖiɖi. 
\q1  
\v 6 Midzi kafukafuhawo na Mawu, 
\q2 midzi kafukafuhawo; 
\q1 midzi kafukafuhawo na míaƒe Fia la, 
\q2 midzi kafukafuhawo, 
\q1  
\v 7 elabena Mawue nye Fia ɖe anyigba blibo la dzi, 
\q2 midzi kafukafuha nɛ. 
\b  
\q1  
\v 8 Mawu ɖu fia ɖe dukɔwo dzi. 
\q2 Mawu nɔ anyi ɖe eƒe fiazikpui kɔkɔe la dzi. 
\q1  
\v 9 Dukɔwo ƒe bubumewo ɖi anyi 
\q2 abe Abraham ƒe Mawu la ƒe amewo ene, 
\q1 elabena anyigbadzifiawo nye Mawu tɔ, 
\q2 elabena wodo eya amea ɖe dzi bobobo. 
\c 48  
\cl Psalmo 48 
\d Korah ƒe viwo ƒe ha. 
\q1  
\v 1 Yehowa lolo, eye eya koe dze kafukafu 
\q2 le míaƒe Mawu la ƒe du me, le eƒe to kɔkɔe la dzi. 
\b  
\q1  
\v 2 Zion to la kɔkɔ henya kpɔ ale gbegbe, 
\q2 eye wònye dzudzɔdonu na anyigba blibo la. 
\q2 Fia gã la ƒe du, si le abe Zafon to kɔkɔe la ene. 
\q1  
\v 3 Mawu le eƒe fiasãwo me, 
\q2 eye wòɖe eɖokui fia abe eƒe mɔ sesẽ ene. 
\b  
\q1  
\v 4 Fiawo ƒo woƒe aʋakɔwo nu ƒu, 
\q2 hezɔ ɖe edzi ɖekae, 
\q1  
\v 5 ke esi wokpɔe la, woƒe nu ku, 
\q2 ŋɔdzi lé wo eye wosi dzo. 
\q1  
\v 6 Dzidzi ƒo wo, eye wose veve 
\q2 abe nyɔnu si le ku lém la ene. 
\q1  
\v 7 Egbã wo gudugudu 
\q2 abe ale si ɣedzeƒeya gbã Tarsis tɔdziʋuwo ene. 
\b  
\q1  
\v 8 Abe ale si míese ene la, 
\q2 nenemae míekpɔe le Yehowa, 
\q1 Dziƒoʋakɔwo ƒe Aƒetɔ la 
\q2 kple míaƒe Mawu la ƒe du mee. 
\q1 Mawu na wòanɔ dedie 
\q2 tegbetegbe. \qs Sela\qs* 
\b  
\q1  
\v 9 O! Mawu, míedea ŋugble le wò lɔlɔ̃ si meʋãna o la ŋu 
\q2 le wò gbedoxɔ me. 
\q1  
\v 10 O! Mawu, wò kafukafu de keke anyigba la ƒe mlɔenu 
\q2 ke abe wò ŋkɔ ene. 
\q2 Wò nuɖusi ɖua fia le dzɔdzɔenyenye me. 
\q1  
\v 11 Zion to kpɔ dzidzɔ, 
\q2 eye Yuda ƒe kɔƒewo 
\q2 le aseye tsom le wò afiatsotso ta. 
\b  
\q1  
\v 12 Mizɔ Zion to la ŋu godoo, 
\q2 mizɔ ƒo xlãe, eye mixlẽ eƒe xɔ tsralawo, 
\q1  
\v 13 ne miakpɔ kpo si woƒo ɖe eƒe gliwo ŋu. 
\q2 Mikpɔ eƒe fiasãwo nyuie ne míatsɔe atu xoe 
\q2 na dzidzime si gbɔna, 
\q1  
\v 14 elabena Mawu siae nye míaƒe Mawu 
\q2 tso mavɔ me yi ɖe mavɔ me; 
\q2 eyae anye mía kplɔla yi ɖase ɖe nuwuwu. 
\c 49  
\cl Psalmo 49 
\d Korah ƒe viwo ƒe ha na hɛnɔ la. 
\q1  
\v 1 Mi anyigbadzitɔwo katã, mise esia; 
\q2 mi xexemetɔwo katã miƒu to anyi, 
\q1  
\v 2 mi ame dzodzrowo kple amegãwo, 
\q2 ame dahewo kple kesinɔtɔwo siaa. 
\q1  
\v 3 Nye nu agblɔ nunya ƒe nyawo, 
\q2 eye nya siwo ado tso nye dzi me la ahe gɔmesese vɛ. 
\q1  
\v 4 Maƒu to anyi ɖe lododo ŋu, 
\q2 eye mato adzo kple nye kasaŋku. 
\b  
\q1  
\v 5 Nu ka ta mavɔ̃ ne ŋkeke vɔ̃wo va, 
\q2 ne ame vɔ̃ɖi, ameblelawo ƒo xlãm, 
\q1  
\v 6 ame siwo ɖoa dzi ɖe woƒe kesinɔnuwo ŋu, 
\q2 eye wotsɔa woƒe nukpɔkpɔ gbogboawo nɔa adegbe ƒom ɖo? 
\q1  
\v 7 Ame aɖeke mate ŋu aɖe nɔvia ƒe agbe 
\q2 alo atsɔ ga aƒle etae le Mawu gbɔ o. 
\q1  
\v 8 Agbeƒlega menye ga sue o, 
\q2 eye ga home aɖeke made enu be 
\q1  
\v 9 amea nanɔ agbe tegbee, 
\q2 eye makpɔ ku o. 
\q1  
\v 10 Ame sia ame kpɔe be nunyala kuna; 
\q2 bometsilawo kple abunɛtɔwo siaa tsrɔ̃na, 
\q2 eye wogblea woƒe kesinɔnuwo ɖi na ame bubuwo. 
\q1  
\v 11 Togbɔ be anyigbawo le wo 
\q2 si woŋlɔ woƒe ŋkɔwo ɖe wo dzi hã la, 
\q1 woƒe yɔdowo anye woƒe aƒe tegbee, 
\q2 eye woanye woƒe nɔƒe tso dzidzime yi dzidzime. 
\b  
\q1  
\v 12 Togbɔ be kesinɔnu geɖewo 
\q2 le amegbetɔ si hã la, manɔ agbe tegbee o, 
\q2 ɖeko wòle abe gbemelã siwo tsrɔ̃na ene. 
\b  
\q1  
\v 13 Esia nye nu si dzɔna ɖe 
\q2 ame siwo ɖo ŋu ɖe wo ɖokuiwo ŋu la dzi. 
\q1 Aleae wòanɔ na wo yomedzela 
\q2 siwo dea woƒe nyagbɔgblɔwo dzi. \qs Sela\qs* 
\q1  
\v 14 Woayi tsiẽƒe abe alẽwo ene, 
\q2 eye woanye nuɖuɖu na ku. 
\q1 Ame dzɔdzɔe aɖu wo dzi le ŋdi, 
\q2 woƒe ŋutilãwo aƒaƒã ɖe yɔdo me, 
\q2 eye woate ɖa xaa tso woƒe xɔ gã dranyiwo gbɔ. 
\q1  
\v 15 Ke Mawu aɖe nye agbe tso ku me, 
\q2 eye wòaxɔm ɖe eɖokui gbɔ. \qs Sela\qs* 
\q1  
\v 16 Ne ame aɖe zu kesinɔtɔ la, 
\q2 megawɔ moya na wò o, 
\q2 ne eƒe aƒe ƒe atsyɔ̃ dzi ɖe edzi la, megawɔ nuku na wò o, 
\q1  
\v 17 elabena ne eku la, matsɔ naneke ɖe asi o, 
\q2 eƒe atsyɔ̃ gɔ̃ hã mayi yɔ me kplii o. 
\q1  
\v 18 Togbɔ be ebu eɖokui ame si woyra, 
\q2 eye amewo kafui esi nu le edzi dzem nɛ hã la, 
\q1  
\v 19 ayi aɖawɔ ɖeka kple fofoa ƒe dzidzime 
\q2 si magakpɔ agbe ƒe kekeli akpɔ o. 
\b  
\q1  
\v 20 Ame si si kesinɔnuwo le, evɔ gɔmesese mele esi o la 
\q2 le abe gbemelã si tsrɔ̃ la ene. 
\c 50  
\cl Psalmo 50 
\d Asaf ƒe ha. 
\q1  
\v 1 Mawu ŋusẽtɔ, Yehowa ƒo nu heyɔ takpekpe na 
\q2 anyigba la tso agudzedze va se ɖe esime ɣe ɖo to. 
\q1  
\v 2 Mawu klẽ tso Zion 
\q2 le eƒe anidzedze blibo la me. 
\q1  
\v 3 Míaƒe Mawu la gbɔna, 
\q2 ahom le tutum le eŋgɔ, 
\q2 dzo le nu bim le eŋgɔ, eye mazi ɖoɖoe o. 
\q1  
\v 4 Eɖi ʋɔnu, eye wòyɔ dziƒo 
\q2 kple anyigba ne wòadrɔ̃ ʋɔnu eƒe dukɔ, 
\q1  
\v 5 “Miƒo nye ame kɔkɔewo nu ƒu nam, 
\q2 ame siwo bla nu kplim kple akpedavɔsa.” 
\q1  
\v 6 Dziƒo ɖe gbeƒã eƒe dzɔdzɔenyenye, 
\q2 elabena Mawu ŋutɔe nye ʋɔnudrɔ̃la. \qs Sela\qs* 
\b  
\q1  
\v 7 “See, o nye dukɔ, mele nu ƒo ge, 
\q2 O! Israel, maɖu ɖasefo ɖe ŋuwò, 
\q2 elabena nyee nye Mawu, wò Mawu la. 
\q1  
\v 8 Nyemeka mo na wò ɖe wò akpedavɔsa 
\q2 alo numevɔsa siwo le ŋkunye me ɖaa la ta o. 
\q1  
\v 9 Nyemehiã nyitsu tso wò nyikpo me, 
\q2 alo gbɔ̃wo tso wò gbɔ̃kpo me o, 
\q1  
\v 10 elabena avemelãwo katã tɔnye wonye, 
\q2 kple nyi siwo le togbɛ akpewo dzi. 
\q1  
\v 11 Menya xevi ɖe sia ɖe si le towo dzi, 
\q2 eye nuwɔwɔ ɖe sia ɖe si le gbe me la tɔnyee wonye. 
\q1  
\v 12 Ne dɔe le wuyem la, nyemagblɔe na wò o, 
\q2 elabena xexea me kple nu siwo katã le eme la nye tɔnye. 
\q1  
\v 13 Ɖe meɖua nyilã 
\q2 alo noa gbɔ̃wo ƒe ʋua? 
\b  
\q1  
\v 14 “Mitsɔ akpedavɔsawo na Mawu, 
\q2 eye mixe miaƒe adzɔgbeɖefewo na Dziƒoʋĩtɔ la. 
\q1  
\v 15 Miyɔm le xaxagbe, 
\q2 maɖe mi, eye miade bubu ŋutinye.” 
\p  
\v 16 Ke Mawu le gbɔgblɔm na ame vɔ̃ɖi la be: 
\q1 “Mɔ ka nèkpɔ be nàxlẽ nye sewo afia, 
\q2 alo alé nye nubabla la ɖe nu? 
\q1  
\v 17 Wò la èlé fu nye nufiame, 
\q2 eye nètsɔ nye nyawo ƒu gbe ɖe megbe. 
\q1  
\v 18 Ne èkpɔ fiafitɔ la, èwɔa ɖeka kplii, 
\q2 eye nèdea ha kple ahasitɔwo. 
\q1  
\v 19 Nya vlowo doa go le nuwò, 
\q2 eye wò aɖe blea ame. 
\q1  
\v 20 Ègblɔa nya tsia tsitre ɖe nɔviwò ŋu, 
\q2 eye nèƒoa ɖi dawòvi ŋutsu. 
\q1  
\v 21 Nu siawoe nye nu siwo nèwɔ hafi mezi ɖoɖoe, 
\q2 eye nèsusu be ɖeko mele abe ye ene, 
\q1 gake maka mo na wò, 
\q2 eye mado asi ɖe mo na wò. 
\b  
\q1  
\v 22 “Bu esia ŋuti, wò ame si ŋlɔ Mawu be, 
\q2 ne menye nenema o la, mavuvu wò kakɛkakɛ, 
\q2 eye ame aɖeke maxɔ wò le asinye o. 
\q1  
\v 23 Ame si na akpedavɔsa la, 
\q2 de bubu ŋunye, eye wòta mɔ be 
\q2 mafia Mawu ƒe ɖeɖee.” 
\c 51  
\cl Psalmo 51 
\d David ƒe ha na hɛnɔ la. Ekpa ha sia esime wòwɔ ahasi kple Batseba, eye Nyagblɔɖila Natan va egbɔ. 
\q1  
\v 1 O! Mawu, kpɔ nye nublanui le wò lɔlɔ̃ si meʋãna o la ta. 
\q2 Le wò dɔmenyo sɔgbɔ la nu, tutu nye dzidadawo ɖa. 
\q1  
\v 2 Klɔ nye vodadawo katã ɖa, eye nàle tsi nam 
\q2 ŋunye nakɔ tso nye nu vɔ̃wo me. 
\b  
\q1  
\v 3 Elabena menya nye dzidadawo, 
\q2 eye nye nu vɔ̃wo le nye ŋkume ɖaa. 
\q1  
\v 4 Ŋuwò, wò ko ŋu mewɔ nu vɔ̃ ɖo, 
\q2 eye nu si nye vɔ̃ le wò ŋkume la mewɔ, 
\q1 eya ta ne èle nu ƒom la, woaɖee afia be tɔwò dzɔ, 
\q2 eye ne ètso afia la, woagblɔ be ele eteƒe. 
\q1  
\v 5 Vavã, wodzim ɖe nu vɔ̃ me, 
\q2 eye nu vɔ̃ me danye fɔ nye fu ɖo. 
\q1  
\v 6 Vavã, nyateƒe si tso dzi me ke la nèdina; 
\q2 èfia nunyam le ememe ke. 
\b  
\q1  
\v 7 Klɔ ŋutinye kple kakle, eye ŋunye aɖi; 
\q2 le tsi nam, eye mafu tititi wu aklala. 
\q1  
\v 8 Na mase dzidzɔkpɔkpɔ kple aseyetsotso, 
\q2 ne nye ƒu siwo nèŋe la nakpɔ dzidzɔ. 
\q1  
\v 9 Ɣla wò mo ɖe nye nu vɔ̃wo, 
\q2 eye nàtutu nye vodadawo katã ɖa. 
\b  
\q1  
\v 10 O! Mawu, wɔ dzi dzadzɛ aɖe nam, 
\q2 eye nàgbugbɔ gbɔgbɔ si li ke la de menye. 
\q1  
\v 11 Mègatsɔm ƒu gbe le wò ŋkume, 
\q2 alo nàxɔ wò Gbɔgbɔ Kɔkɔe la le asinye o. 
\q1  
\v 12 Gbugbɔ ɖeɖekpɔkpɔ ƒe dzidzɔ de menye, 
\q2 eye nàna gbɔgbɔ si le klalo la be wòalém ɖe asi. 
\b  
\q1  
\v 13 Ekema mafia wò mɔwo dzidalawo, 
\q2 eye nu vɔ̃ wɔlawo atrɔ ava gbɔwò. 
\q1  
\v 14 O! Mawu, ɖem tso ʋukɔkɔɖi ƒe nu vɔ̃ me, 
\q2 wò Mawu si ɖem, eye nye aɖe adzi ha 
\q2 le wò dzɔdzɔenyenye ŋu. 
\q1  
\v 15 O! Aƒetɔ, ke nye nuyiwo, 
\q2 eye nye nu aɖe gbeƒã wò kafukafu. 
\q1  
\v 16 Mèdia vɔsa o, anye ne metsɔe na wò; 
\q2 numevɔsa hã medoa dzidzɔ na wò o. 
\q1  
\v 17 Vɔsa siwo nye Mawu tɔe nye gbɔgbɔ si wogbã. 
\q2 O! Mawu, màdo vlo dzi si gbã hetugu la o. 
\b  
\q1  
\v 18 Na nu nadze edzi na Zion le wò didi nyui la nu, 
\q2 eye nàɖo Yerusalem ƒe gliwo te. 
\q1  
\v 19 Ekema dzɔdzɔenyenyevɔsawo 
\q2 kple numevɔsa blibowo ava gbɔwò, 
\q1 ado dzidzɔ na wò, eye woatsɔ nyitsuwo asa vɔe 
\q2 le wò vɔsamlekpui dzi. 
\c 52  
\cl Psalmo 52 
\d David ƒe nufiameha na hɛnɔ la. Ekpa ha sia esi Edomtɔ, Doeg yi ɖagblɔ na Saul be, “David yi ɖe Ahimelek ƒe aƒe me.” 
\q1  
\v 1 Nu ka ta nètsɔ nu vɔ̃ɖi le adegbe ƒom, wò kalẽtɔ? 
\q2 Nu ka wɔ nèle adegbe ƒom ŋkeke blibo la, 
\q2 wò ame si nye ŋunyɔnu le Mawu ƒe ŋkume? 
\q1  
\v 2 Wò aɖe le gbegblẽ ɖom; 
\q2 èle abe hɛ ɖaɖɛ ene, wò alakpatɔ. 
\q1  
\v 3 Èlɔ̃ vɔ̃ wu nyui, 
\q2 èlɔ̃ alakpa wu nyateƒetoto. \qs Sela\qs* 
\q1  
\v 4 O! Wò alakpaɖe, 
\q2 èlɔ̃ nya gbegblẽwo sɔŋ ko! 
\b  
\q1  
\v 5 Vavã, Mawu hã aƒu wò anyi ɖe gbegblẽ mavɔ me. 
\q2 Mawu ahe wò ado goe tso wò agbadɔ me, 
\q2 aho wò kple ke tso agbagbeawo ƒe anyigba dzi. \qs Sela\qs* 
\q1  
\v 6 Ame dzɔdzɔewo akpɔe, eye woavɔ̃; 
\q2 woakoe ahagblɔ be, 
\q1  
\v 7 “Kpɔ ɖa, ŋutsu si metsɔ Mawu wɔ eƒe mɔ sesẽ o, 
\q2 ke boŋ wòtsɔ eƒe dzi ɖo eƒe kesinɔnu gbogboawo ŋu, 
\q2 eye wòkpɔ ŋusẽ hegblẽ ame bubuwo dome lae nye esi!” 
\b  
\q1  
\v 8 Ke nye la, mele abe amiti si le tsetsem le Mawu ƒe aƒe me la ene. 
\q2 Meɖo dzi ɖe Mawu ƒe lɔlɔ̃ si meʋãna o 
\q2 la ŋu tso mavɔ me yi ɖe mavɔ me. 
\q1  
\v 9 Makafu wò tegbee le nu si nèwɔ la ta; 
\q2 matsɔ nye mɔkpɔkpɔ ade wò ŋkɔ me, 
\q1 elabena wò ŋkɔ nyo. 
\q2 Makafu wò le wò ame kɔkɔewo ŋkume. 
\c 53  
\cl Psalmo 53 
\d David ƒe ha na hɛnɔ la. Woadzii ɖe nublanuigbe me. 
\q1  
\v 1 Bometsila gblɔ le eƒe dzi me be, 
\q2 “Mawu aɖeke meli o.” 
\q1 Wonye ame baɖawo, woƒe mɔwo hã nye nu tovowo, 
\q2 ame aɖeke meli si wɔa nu nyui o. 
\b  
\q1  
\v 2 Mawu lé ŋku ɖe amegbetɔviwo ŋu tso dziƒo, 
\q2 ne wòakpɔe ɖa be ame aɖe se nu gɔme alo di Mawu hã. 
\q1  
\v 3 Ke ame sia ame trɔ megbe dee, 
\q2 wo katã tim wɔ nu tovo; 
\q1 ame ɖeka hɔ̃ɔ hã meli si wɔa nu nyui o, 
\q2 ɖeka pɛ hã meli o. 
\b  
\q1  
\v 4 Ɖe ame vɔ̃ɖiwo, 
\q2 ame siwo vuvu nye dukɔ abe ale si woɖua aboloe ene, 
\q1 eye womeyɔa Mawu o la 
\q2 ava srɔ̃ nu gbe aɖe gbea? 
\q1  
\v 5 Woawoe ma ŋɔdzi lé, evɔ ŋɔdzinu aɖeke meli hafi o. 
\q2 Mawu gbã ƒu ɖe lãme na ame siwo tso ɖe mia ŋu la; 
\q2 ena ŋukpe lé wo, elabena Mawu gbe wo. 
\b  
\q1  
\v 6 O! Xɔname neva tso Zion na Israel! 
\q2 Ne Mawu gaɖo eƒe dukɔ ƒe nunyonamewo te la, 
\q2 Yakob netso aseye, eye Israel nekpɔ dzidzɔ! 
\c 54  
\cl Psalmo 54 
\d David ƒe ha na hɛnɔ la. Woadzii ɖe kasaŋku ŋu. David kpa ha sia esi Zifitɔwo yi Saul gbɔ gblɔ nɛ be, “Ɖe David meva ɣla ɖe mía dome oa?” 
\q1  
\v 1 Ɖem, O! Mawu, ɖem kple wò ŋkɔ, 
\q2 tsɔ wò ŋusẽ tso afia nam. 
\q1  
\v 2 O! Mawu, se nye gbedodoɖa, 
\q2 eye nàƒu to anyi ɖe nye numenyawo ŋu. 
\b  
\q1  
\v 3 Amedzrowo tso ɖe ŋunye, 
\q2 ŋutasẽlawo ti nye agbe yome, 
\q2 ame siwo mebua Mawu ɖe naneke me o. \qs Sela\qs* 
\b  
\q1  
\v 4 Mawu nye nye xɔnametɔ vavã, 
\q2 Aƒetɔ lae nye ame si lém ɖe asi. 
\b  
\q1  
\v 5 Vɔ̃ negbugbɔ va ame siwo le ŋunye gblẽm la dzi, 
\q2 tsrɔ̃ wo le wò nuteƒewɔwɔ ta. 
\b  
\q1  
\v 6 Masa lɔlɔ̃nuvɔsa na wò, 
\q2 O! Yehowa, makafu wò ŋkɔ, elabena enyo. 
\q1  
\v 7 Eɖem tso nye xaxawo katã me, 
\q2 eye nye ŋkuwo kpɔ ale si woɖu nye futɔwo dzii. 
\c 55  
\cl Psalmo 55 
\d David ƒe nufiameha na hɛnɔ la. Woadzii ɖe kasaŋku ŋu. 
\q1  
\v 1 O! Mawu, ɖo to nye gbedodoɖa, 
\q2 mègado toku nye kokoƒoƒo o. 
\q2  
\v 2 Ɖo tom, eye nàtɔ nam. 
\q1 Nye tamesusuwo ɖea fu nam, eye metɔtɔna, 
\q2  
\v 3 ne mese futɔ la ƒe gbe, 
\q2 alo ne ame vɔ̃ɖi la tro ŋku ɖem. 
\q1 Elabena wohe fukpekpe va dzinye, 
\q2 eye wogblɔa nya vɔ̃wo ɖe ŋunye le woƒe dɔmedzoe me. 
\b  
\q1  
\v 4 Nye dzi le nu xam vevie le menye; 
\q2 ku ƒe ŋɔdzi ɖe to ɖem. 
\q1  
\v 5 Vɔvɔ̃ kple dzodzo nyanyanya lém, 
\q2 eye ŋɔdzi gbagba blam. 
\q1  
\v 6 Megblɔ be, 
\q2 “O! Ɖe wònye aʋala le asinye abe ahɔnɛ ene la, 
\q2 anye ne madzo aɖadzudzɔ le teƒe aɖe. 
\q1  
\v 7 Madzo ayi keke gbegbe, 
\q2 aɖanɔ afi ma. \qs Sela\qs* 
\q1  
\v 8 Maɖe abla ayi ɖe nye bebeƒe, 
\q2 ate ɖe aga tso ya sesẽwo kple ahom gbɔ.” 
\b  
\q1  
\v 9 O! Aƒetɔ, tɔtɔ ame vɔ̃ɖiwo, 
\q2 tɔtɔ woƒe nyagbɔgblɔwo, elabena mekpɔ ŋutasesẽ 
\q2 kple ʋunyaʋunya le dua me. 
\q1  
\v 10 Zã kple keli wole tatam le eƒe gliwo dzi, 
\q2 eye nugbeɖoɖo kple hiãkame le eme. 
\q1  
\v 11 Ŋusẽ siwo gblẽa nu la le dɔ wɔm le dua me; 
\q2 ŋutasesẽ kple alakpadada medzona le eƒe ablɔ dzi o. 
\b  
\q1  
\v 12 Ne futɔe le dzu yem la, mate ŋu atsɔe; 
\q2 ne ketɔe kɔ eɖokui ɖe dzi ɖe ŋunye la, mate ŋu aɣla ɖee, 
\q1  
\v 13 gake wò, ŋutsu abe nye ene, 
\q2 xɔ̃nye vevi kple nye kpeɖeŋutɔ, 
\q1  
\v 14 nye kple ame si dome habɔbɔ vivi aɖe nɔ, 
\q2 eye míezɔna aduadu le amehawo dome le gbedoxɔ me lae. 
\b  
\q1  
\v 15 Ku neƒo ɖe nye ketɔwo dzi kpoyi; 
\q2 woneyi yɔdo me agbagbe, 
\q2 elabena nu vɔ̃ɖi wɔwɔ xɔ aƒe ɖe wo dome. 
\b  
\q1  
\v 16 Ke meyɔ Mawu, 
\q2 eye wòtɔ nam, heɖem. 
\q1  
\v 17 Fiẽ, ŋdi kple ŋdɔ 
\q2 medo ɣli le xaxame, eye wòse nye gbe. 
\q1  
\v 18 Eɖem tso aʋa si le edzi yim kplim la me le dedinɔnɔ me, 
\q2 togbɔ be ame geɖewo tso ɖe ŋutinye hã. 
\q1  
\v 19 Mawu, ame si le fiazikpui dzi tegbee la asee, 
\q2 eye wòabɔbɔ wo ɖe anyi, \qs Sela\qs* 
\q1 ame siwo gbe tɔtrɔ le woƒe mɔwo dzi, 
\q2 eye womevɔ̃a Mawu o lae. 
\b  
\q1  
\v 20 Nye zɔhɛ wɔ avu 
\q2 kple exɔlɔ̃wo hegblẽ kɔ ɖo na eƒe nubabla. 
\q1  
\v 21 Eƒe nuƒo zrɔ̃ dredredre abe notsi kpekpe ene, 
\q2 evɔ aʋawɔwɔ le eƒe dzi me; 
\q1 eƒe numenyawo zrɔ̃ wu ami, 
\q2 gake wonye yi siwo woɖe le aku me lé ɖe asi. 
\b  
\q1  
\v 22 Tsɔ wò dzimaɖiwo da ɖe Yehowa dzi, eye akpɔ tawò, 
\q2 elabena mana ame dzɔdzɔe la nadze anyi akpɔ gbeɖe o. 
\q1  
\v 23 O! Mawu, ke wò la, 
\q2 àhe ame vɔ̃ɖiwo ayi yɔdo me. 
\q1 Ŋutsu hlɔ̃dolawo kple ameblelawo manɔ agbe 
\q2 wòade agbemeŋkeke siwo nèna wo la ƒe afã hã o. 
\b  
\q1 Ke nye la, wò ko dzi meka ɖo. 
\c 56  
\cl Psalmo 56 
\d David ƒe nufiameha na hɛnɔ la. Woadzii ɖe “Ahɔnɛ si dzo ɖe logoti dzi le didiƒe ke” la ƒe gbeɖiɖi nu. Ekpa ha sia esi Filistitɔwo lée le Gat. 
\q1  
\v 1 Kpɔ nye nublanui, O! Mawu, 
\q2 elabena amegbetɔwo ti yonyeme kple ŋkubiã; 
\q2 ŋkeke blibo la wole yonyeme kutɔkutɔe. 
\q1  
\v 2 Ame siwo le ŋunye gblẽm la ti yonyeme ŋkeke blibo la, 
\q2 eye wo dometɔ geɖewo tso ɖe ŋunye kple dada. 
\b  
\q1  
\v 3 Maka ɖe dziwò ne vɔvɔ̃ ɖom. 
\q2  
\v 4 Wò Mawu si ƒe nya mekafu, 
\q1 Mawu si dzi meka ɖo; nyemavɔ̃ akpɔ o. 
\q2 Nu ka amegbetɔ, ŋutilã kple ʋu, awɔm ma? 
\b  
\q1  
\v 5 Ŋkeke blibo la wotrɔa gbo nye nyawo, 
\q2 ɣe sia ɣi wole nugbe ɖom be woawɔ nuvevim. 
\q1  
\v 6 Woɖo babla, wole ŋu tsam, 
\q2 hele ŋku lém ɖe nye afɔɖeɖewo ŋu, 
\q2 eye wotsi dzi ɖe nye agbetsɔtsrɔ̃ ŋuti. 
\q1  
\v 7 Ɖe woƒe vɔ̃ɖinyenye ta la, megana mɔ woasi o; 
\q2 O! Mawu, he dukɔwo ƒu anyi le wò dɔmedzoe me. 
\b  
\q1  
\v 8 Ŋlɔ nye konyifafa da ɖi; 
\q2 lé nye aɖatsiwo ɖe agbalẽ dzi; 
\q2 ɖe womele wò nyaŋlɔɖiwo me xoxo oa? 
\q1  
\v 9 Ekema nye futɔwo atrɔ adzo, ne meyɔ wò be nàxɔ nam. 
\q2 To esia me la, manya be Mawu nye tɔnye. 
\b  
\q1  
\v 10 Mawu, ame si ƒe nya mekafu, 
\q2 Yehowa ame si ƒe nya mekafu. 
\q1  
\v 11 Mawu, ame si dzi meka ɖo; nyemavɔ̃ o. 
\q2 Nu ka amegbetɔ ate ŋu awɔm? 
\b  
\q1  
\v 12 O! Mawu, meɖe adzɔgbe na wò, 
\q2 eya ta maxe adzɔgbeɖefe na wò. 
\q1  
\v 13 Elabena èɖem tso ku me, 
\q2 eye nèna be nye afɔwo hã magaɖiɖi o, 
\q1 ne mate ŋu azɔ le Mawu ŋkume 
\q2 le agbagbeawo ƒe anyigba dzi. 
\c 57  
\cl Psalmo 57 
\d David ƒe ha na hɛnɔ la. Woadzii ɖe “Mègagblẽ nu o” ƒe gbeɖiɖi nu. Ekpa ha sia esi wòsi le Saul nu yi ɖabe ɖe agado aɖe me. 
\q1  
\v 1 Kpɔ nye nublanui, O! Mawu, kpɔ nye nublanui, 
\q2 elabena wò mee nye luʋɔ kpɔ sitsoƒe le. 
\q1 Wò aʋala ƒe vɔvɔli te mabe ɖo va se ɖe 
\q2 esime gbegblẽ la nu nava yi. 
\b  
\q1  
\v 2 Mawu, Dziƒoʋĩtɔ lae medo ɣli na, 
\q2 Mawu si wɔa ɖoɖo si wòwɔ ɖe ŋunye la dzi. 
\q1  
\v 3 Edɔ xɔnametɔ tso dziƒo, eye wòxɔ nam heka mo na 
\q2 ame siwo le yonyeme tim kutɔkutɔe. \qs Sela\qs* 
\q2 Mawu dɔ eƒe lɔlɔ̃ kple eƒe nuteƒewɔwɔ ɖa. 
\b  
\q1  
\v 4 Mele dzatawo dome, 
\q2 memlɔ lã lénuwo dome, 
\q1 amegbetɔ siwo ƒe aɖuwo nye akplɔwo kple aŋutrɔwo, 
\q2 eye woƒe aɖewo nye yi ɖaɖɛwo. 
\b  
\q1  
\v 5 Medo wò ɖe dzi, O Mawu, gbɔ dziƒowo ŋu, 
\q2 na wò ŋutikɔkɔe naklẽ ɖe anyigba blibo la dzi. 
\b  
\q1  
\v 6 Woɖo ɖɔ ɖi na nye afɔ, 
\q2 ena mete ɖe anyi kple nuxaxa. 
\q1 Woɖe ʋe ɖe mɔ dzi nam, 
\q2 gake woawo ŋutɔ ge dze eme. \qs Sela\qs* 
\b  
\q1  
\v 7 Nye dzi li ke sesĩe, O Mawu, 
\q2 nye dzi li ke sesĩe, 
\q2 eya ta madzi ha aƒo saŋku. 
\q1  
\v 8 Nyɔ, nye luʋɔ! 
\q2 Nyɔ, kasaŋku kple gasaŋku! 
\q2 Mana fɔŋli nanyɔ! 
\b  
\q1  
\v 9 O! Aƒetɔ, makafu wò le dukɔwo dome, 
\q2 eye madzi ha na wò le dukɔwo dome, 
\q1  
\v 10 elabena wò lɔlɔ̃ keke ta, 
\q2 yi ɖatɔ dziƒo ke, eye wò nuteƒewɔwɔ yi ɖatɔ dziŋgɔli. 
\b  
\q1  
\v 11 Medo wò ɖe dzi, O Mawu, gbɔ dziƒowo ŋu, 
\q2 na wò ŋutikɔkɔe naklẽ ɖe anyigba blibo la dzi. 
\c 58  
\cl Psalmo 58 
\d David ƒe nufiameha na hɛnɔ la. Woadzii ɖe “Mègagblẽ nu o” ƒe gbeɖiɖi nu. 
\q1  
\v 1 Ɖe mi dziɖulawo mietoa nyateƒea? 
\q2 Ɖe mietsoa afia dzɔdzɔe na amewoa? 
\q1  
\v 2 Ao, nu madzɔmadzɔ wɔwɔ boŋ míeɖo ɖe miaƒe dziwo me, 
\q2 eye míaƒe asiwo wɔa ŋutasẽnu le anyigba dzi. 
\b  
\q1  
\v 3 Ame vɔ̃ɖiwo tra mɔ tso keke woƒe vidzĩ me ke, 
\q2 eye tso wo dadawo ƒe dɔ me ke, 
\q2 wodze aglã, hedaa alakpa. 
\q1  
\v 4 Woƒe aɖi le abe da ƒe aɖi ene. 
\q2 Egale abe ƒli si xe nu eƒe to me ene, 
\q1  
\v 5 eye ne gbesala ɖe gbe nɛ la, mewɔa edzi o; 
\q2 aleke gbegbee dzotɔ la bi ɖe gbesasa mee hã la, mesenɛ o. 
\b  
\q1  
\v 6 O, Mawu, ŋe aɖu ɖe nu me na wo, 
\q2 O, Yehowa, tu tsyo na dzata la! 
\q1  
\v 7 Wo nu neyi abe tsi si si va yi la ene. 
\q2 Ne wovu woƒe dawo me la, 
\q2 woƒe aŋutrɔwo nu netsi. 
\q1  
\v 8 Wole abe abɔbɔ si va yi, eye etoƒe bu la ene. 
\q2 Wonenɔ abe fu gege ene, be womakpɔ ɣe o. 
\b  
\q1  
\v 9 Hafi miaƒe zewo nase ŋutidzo si wodo ɖe wo te ŋkɔ, 
\q2 eɖanye mumua, alo ƒuƒua o, 
\q2 woakplɔ ame vɔ̃ɖi la adzoe. 
\q1  
\v 10 Ame dzɔdzɔewo akpɔ dzidzɔ, 
\q2 ne wole hlɔ̃ biam ɖe wo nu, 
\q1 eye wole woƒe afɔwo klɔm ɖe 
\q2 ame vɔ̃ɖiwo ƒe ʋu me. 
\q1  
\v 11 Ekema amewo agblɔ be, 
\q2 “Vavã, wogale eteƒe ɖom na ame dzɔdzɔe, 
\q2 eye Mawu aɖe li si drɔ̃a ʋɔnu anyigba vavã.” 
\c 59  
\cl Psalmo 59 
\d David ƒe nufiameha na hɛnɔ la. Woadzii ɖe “Mègagblẽ nu o” ƒe gbeɖiɖi nu. Ekpa ha sia esi Saul dɔ amewo be woadzɔ eƒe aƒe ŋu, eye ne edo go la, woawui. 
\q1  
\v 1 O! Mawu, ɖem tso nye futɔwo ƒe asi me; 
\q2 kpɔ tanye le ame siwo tso ɖe ŋutinye la ta. 
\q1  
\v 2 Ɖem tso nu vlo wɔlawo ƒe asi me 
\q2 eye nàxɔm tso hlɔ̃dolawo ƒe asi me. 
\b  
\q1  
\v 3 Kpɔ ale si wode xa ɖi nam lae ɖa! 
\q2 Ame nyanyrawo ɖo nugbe ɖe ŋunye, 
\q2 evɔ la, O Yehowa, nyemedze agɔ, 
\q2 alo wɔ nu vɔ̃ aɖeke o. 
\q1  
\v 4 Nyemeda vo aɖeke o, 
\q2 evɔ wole klalo be woadze dzinye. 
\q2 Tso, nàxɔ nam; kpɔ xaxa si me mele la ɖa! 
\q1  
\v 5 O! Yehowa, Mawu Ŋusẽkatãtɔ, 
\q2 Israel ƒe Mawu, nyɔ nàhe to na dukɔwo, 
\q2 mègakpɔ nublanui na ametatrɔla vɔ̃ɖi siawo o. \qs Sela\qs* 
\b  
\q1  
\v 6 Wotrɔ gbɔ le fiẽ me le gbe tem abe avuwo ene, 
\q2 eye wole tsaglãla tsam le dua me. 
\q1  
\v 7 Kpɔ nu si wotu tso woƒe nu me la ɖa, 
\q1 wotu nyawo tso woƒe nuyiwo me le gbɔgblɔm be, 
\q2 “Ame ka ate ŋu aɖo to mí?” 
\q1  
\v 8 O! Yehowa, wò koe le wo kom, 
\q2 èɖe alɔme le dukɔ mawo katã ŋu. 
\b  
\q1  
\v 9 O! Nye ŋusẽ, mele nuwò kpɔm. 
\q2 O! Mawu, wòe nye nye mɔ sesẽ, 
\q2  
\v 10 nye Mawu lɔlɔ̃tɔ. 
\b  
\q1 Mawu adze ŋgɔ nam, eye ana makpɔ dziɖuɖu ƒe dzidzɔ 
\q2 ɖe nye ketɔwo dzi. 
\q1  
\v 11 Gake mègawu wo o, 
\q2 O! Aƒetɔ, míaƒe akpoxɔnu, 
\q2 ne menye nenema o la, nye amewo aŋlɔ be. 
\q1 Le wò ŋusẽ me, na woatsa tsaglãla, 
\q2 eye nàhe wo aƒu anyi. 
\q1  
\v 12 Nya sia nya si doa le wo nu la nye nu vɔ̃, 
\q2 woƒe dada nazu abe mɔ ene aɖe wo, 
\q2 Le fiƒodenya kple alakpanya siwo wogblɔ ta la, 
\q2  
\v 13 fia wo kple dziku, 
\q2 fia wo va se ɖe esime womaganɔ anyi o. 
\q1 Ekema woanya va se ɖe anyigba la ƒe mlɔenu ke, be 
\q2 Mawue nye fia ɖe Yakob dzi. \qs Sela\qs* 
\b  
\q1  
\v 14 Wotrɔ gbɔ le fiẽ me, le gbe tem abe avuwo ene, 
\q2 eye wole tsaglãla tsam le dua me. 
\q1  
\v 15 Wole tsatsam le nuɖuɖu dim, 
\q2 eye ne womeɖi ƒo o la, wonɔa wòwóm. 
\q1  
\v 16 Ke nye la, madzi wò ŋusẽ ƒe ha, 
\q2 eye le ŋdi me la, madzi ha le wò lɔlɔ̃ ŋuti, 
\q1 elabena wòe nye nye mɔ sesẽ, 
\q2 kple nye sitsoƒe le xaxaɣiwo. 
\b  
\q1  
\v 17 O! Nye ŋusẽ, mele kafukafuha dzim na wò. 
\q2 O! Mawu, wòe nye nye mɔ sesẽ kple nye Mawu si dzi meka ɖo. 
\c 60  
\cl Psalmo 60 
\d David ƒe ha na hɛnɔ la. Woadzii ɖe “Nubabla ƒe Dzogbenya” ƒe gbeɖiɖi nu. David kpa nufiameha sia esi wòwɔ aʋa kple Aram Naharaim kple Aram Zobah, kpe ɖe esi Yoab trɔ gbɔ tso aʋa le Dze Balime, afi si wòwu Edomtɔ akpe wuieve (12,000) le la ŋu. 
\q1  
\v 1 O! Mawu, ègbe mí, èti kpo dze mía dzi, 
\q2 eye nèdo dɔmedzoe ɖe mía ŋu, 
\q2 eya ta gbugbɔ mí ɖo te! 
\q1  
\v 2 Èʋuʋu anyigba la, eye nèfee wòle nuvo, 
\q2 eya ta gatre eƒe gbagbãƒeawo, elabena ele ʋuʋum. 
\q1  
\v 3 Èna ɣeyiɣi sesẽwo tu wò dukɔ la, 
\q2 eye nèna wain mí míeno mu hele yiyim sɔgɔsɔgɔsɔgɔ. 
\q1  
\v 4 Ke hena ame siwo vɔ̃a wò la, 
\q2 èkɔ aflaga dzi be wòanye akpoxɔnu ɖe 
\q2 woƒe aŋutrɔ ŋu. \qs Sela\qs* 
\b  
\q1  
\v 5 Xɔ na mí, eye nàɖe mí kple wò nuɖusi, 
\q2 be ame siwo nèlɔ̃ la nakpɔ xɔxɔ. 
\q1  
\v 6 Mawu ƒo nu tso eƒe kɔkɔeƒe la be; 
\q2 “Le dziɖuɖu me, mama Sekem, 
\q2 eye madzidze Sukɔt Balime hã. 
\q1  
\v 7 Gilead nye tɔnye, Manase hã tɔnyee. 
\q2 Nye gakukue nye Efraim, 
\q2 eye Yuda nye nye fiatikplɔ. 
\q1  
\v 8 Moab nye nye asiklɔgba, 
\q2 meɖe nye tokota ƒu gbe ɖe Edom dzi, 
\q2 eye medo dziɖuɖuɣli ɖe Filistia ta.” 
\b  
\q1  
\v 9 Ame ka akplɔm ayi du si ŋu 
\q2 woɖo gli sesẽ ƒo xlãe la me? 
\q2 Ame ka akplɔm ayi Edom? 
\q1  
\v 10 O! Mawu, ɖe menye wòe o la, 
\q2 wò ame si gbe mí, eye mègadona 
\q2 kple míaƒe aʋakɔwo lae oa? 
\q1  
\v 11 Kpe ɖe mía ŋu, ɖe míaƒe futɔwo ŋuti, 
\q2 elabena amegbetɔ ƒe kpekpeɖeŋu mele ɖeke me o. 
\q1  
\v 12 To Mawu dzi, míaɖu dzi, 
\q2 eye míafanya míaƒe futɔwo ɖe anyigba. 
\c 61  
\cl Psalmo 61 
\d David ƒe ha na hɛnɔ la. Woadzii ɖe kasaŋku ŋu. 
\q1  
\v 1 Se nye ɣlidodo, O Mawu, 
\q2 eye nàlé to ɖe nye gbedodoɖa ŋu. 
\b  
\q1  
\v 2 Meyɔ wò tso anyigba ƒe mlɔenu, 
\q2 meyɔ wò, esi nu te nye dzi ŋu belibelibeli; 
\q2 azɔ kplɔm yi ɖe agakpe si kɔ wum la dzi, 
\q1  
\v 3 elabena wòe nye nye sitsoƒe 
\q2 kple mɔ sesẽ, le futɔ la ta. 
\b  
\q1  
\v 4 Medi vevie be manɔ wò agbadɔ me tegbee, 
\q2 eye mabe ɖe wò aʋala ƒe fafaƒe. \qs Sela\qs* 
\q1  
\v 5 O! Mawu, èse nye adzɔgbeɖeɖewo, 
\q2 eye nètsɔ ame siwo vɔ̃a wò ŋkɔ la ƒe domenyinu nam. 
\b  
\q1  
\v 6 Dzi fia la ƒe agbemeŋkekewo ɖe edzi nɛ, 
\q2 eƒe ƒewo nasɔ gbɔ be wòakpɔ dzidzime geɖewo. 
\q1  
\v 7 Neɖu fia le Mawu ŋkume tegbee, 
\q2 eye na wò lɔlɔ̃ kple nuteƒewɔwɔ nakpɔ eta. 
\b  
\q1  
\v 8 Ekema madzi kafukafuha na wò ŋkɔ tegbee, 
\q2 eye maxe nye adzɔgbeɖefewo gbe sia gbe. 
\c 62  
\cl Psalmo 62 
\d David ƒe ha na Hɛnɔ Yedutun. 
\q1  
\v 1 Mawu me ko nye luʋɔ kpɔ gbɔɖeme le, 
\q2 eye eya ko gbɔ nye xɔxɔ tsona. 
\q1  
\v 2 Eya koe nye nye agakpe, 
\q2 nye xɔxɔ kple nye mɔ sesẽ, eya ta nyemaʋã akpɔ gbeɖe o. 
\b  
\q1  
\v 3 Va se ɖe ɣe ka ɣi nànɔ ame ɖeka ƒoƒo dzi? 
\q2 Ɖe mi katã mialé ame si le abe gli gbagbã 
\q2 kple kpɔ si le mumum ene la aƒu anyia? 
\q1  
\v 4 Woɖoe vavã be yewoatutui tso 
\q2 eƒe nɔƒe kɔkɔ la, elabena wolɔ̃a alakpadada. 
\q1 Wotsɔa woƒe nuwo gblɔa yayranyawoe, 
\q2 ke fiƒode le woƒe dzi me. \qs Sela\qs* 
\b  
\q1  
\v 5 O! Nye luʋɔ, gbɔ ɖe eme le Mawu ɖeka ko me, 
\q2 elabena eya gbɔ nye mɔkpɔkpɔ tso. 
\q1  
\v 6 Eya hɔ̃ɔ koe nye nye agakpe, 
\q2 nye xɔxɔ kple nye mɔ sesẽ, 
\q2 eya ta nyemaʋuʋu o. 
\q1  
\v 7 Nye xɔxɔ kple bubu ku ɖe Mawu ŋu, 
\q2 eyae nye nye agakpe sesẽ kple nye sitsoƒe. 
\q1  
\v 8 O! Mi dukɔwo, miɖo dzi ɖe eŋu ɣe sia ɣi; 
\q2 mitsɔ miaƒe hiahiãwo kɔ ɖe edzi, 
\q2 elabena Mawue nye míaƒe sitsoƒe. \qs Sela\qs* 
\b  
\q1  
\v 9 Vavã, ƒuƒu ko ame gbɔlowo nye, 
\q2 eye alakpa nye ame siwo nye ame ŋkutawo, 
\q1 elabena ne woda wo le nudanu dzi la, 
\q2 tofloko ko wonye, 
\q2 eye wo katã ƒuƒu ko wonye. 
\q1  
\v 10 Migaɖo ŋu ɖe amebaba ŋu, 
\q2 alo akpɔ dzidzɔ ɖe nu siwo wofi la ŋuti o. 
\q1 Togbɔ be wò kesinɔnuwo dzi ɖe edzi hã la, 
\q2 mègatsɔ wò dzi da ɖe wo dzi o. 
\b  
\q1  
\v 11 Mawu gblɔ nya ɖeka, 
\q2 eye mese nu eve le eme be, 
\q1 “Wò, O Mawu, ɖeka koe sesẽ, 
\q2  
\v 12 eye O Aƒetɔ, wò la lɔlɔ̃ bɔ ɖe asiwò. 
\q1 Vavã, àɖo eteƒe na ame 
\q2 sia ame ɖe nu si wòwɔ la nu.” 
\c 63  
\cl Psalmo 63 
\d David ƒe ha. Ekpae esi wòle Yuda gbegbe. 
\q1  
\v 1 O! Mawu, wòe nye nye Mawu, 
\q2 mele diwòm vevie; 
\q1 tsikɔ le nye luʋɔ wum ɖe ŋuwò, 
\q2 nye ameti blibo la mele diwòm, 
\q1 le kuɖiɖinyigba si ƒu kplakplakpla, 
\q2 eye tsi aɖeke meli o la dzi. 
\b  
\q1  
\v 2 Mekpɔ wò le kɔkɔeƒe la, 
\q2 eye mekpɔ wò ŋusẽ kple wò ŋutikɔkɔe. 
\q1  
\v 3 Esi wò lɔlɔ̃ nyo wu agbe ta la, 
\q2 nye nuyiwo ado wò ɖe dzi. 
\q1  
\v 4 Makafu wò, zi ale si mele agbe, 
\q2 eye mado nye asiwo ɖe dzi le wò ŋkɔ me. 
\q1  
\v 5 Nye luʋɔ aɖi ƒo abe nuɖuɖu nyuitɔ kekeakee wòɖu ene; 
\q2 hadzidzi anɔ nu nam, eye nye nu adzi kafukafuhawo na wò. 
\b  
\q1  
\v 6 Le nye aba dzi, meɖoa ŋku dziwò, 
\q2 mebua ŋutiwò le nye ŋunɔɣi le zã me. 
\q1  
\v 7 Esi nènye nye xɔnametɔ ta la, 
\q2 madzi ha le wò aʋala ƒe vɔvɔli te. 
\q1  
\v 8 Nye luʋɔ ku ɖe ŋuwò goŋgoŋgoŋ, 
\q2 eye wò ɖusibɔ lém ɖe te. 
\b  
\q1  
\v 9 Woatsrɔ̃ ame siwo le nye agbe yome tim, 
\q2 woayi ɖe keke anyigba la ƒe tume ke. 
\q1  
\v 10 Woatsɔ wo ade asi na yi, 
\q2 eye woazu nuɖuɖu na amegaxiwo. 
\b  
\q1  
\v 11 Ke fia la akpɔ dzidzɔ le Mawu me; 
\q2 ame siwo katã kaa atam le Mawu ƒe ŋkɔ me la akafui, 
\q2 ke woamia nu na alakpatɔwo. 
\c 64  
\cl Psalmo 64 
\d David ƒe ha na hɛnɔ la. 
\q1  
\v 1 O! Mawu, ɖo tom, esi meɖe nye kuxiwo na wò; 
\q2 kpɔ nye agbe ta tso futɔ siwo le ŋɔdzi dom nam la ƒe asi me. 
\b  
\q1  
\v 2 Ɣlam tso ame vɔ̃ɖiwo ƒe nugbeɖoɖo 
\q2 kple ame vlo mawo ƒe howɔwɔ me. 
\q1  
\v 3 Wonyrea woƒe aɖewo abe yi ene, 
\q2 eye wodzidzea woƒe nyawo ɖe ame dzi 
\q2 abe aŋutrɔ siwo nu aɖi le la ene. 
\q1  
\v 4 Wodea xa hedaa aŋutrɔ ame maɖifɔ la, 
\q2 eye wodanɛ zi ɖeka vɔvɔ̃manɔŋutɔe. 
\b  
\q1  
\v 5 Wodea dzi ƒo na wo nɔewo 
\q2 le woƒe nu vɔ̃ɖi ɖoɖowo me, 
\q1 woƒoa nu tso ale si woatre mɔ ɖe vivime 
\q2 la ŋuti gblɔna be, “Ame kae le ekpɔ ge?” 
\q1  
\v 6 Woɖoa nu vɔ̃ɖi hegblɔna le eŋuti be, 
\q2 “Míewɔ ɖoɖo deŋgɔ la vɔ!” 
\q2 Vavãe, ame ƒe susu kple dzi me nye ayenuwɔƒe, 
\q1  
\v 7 gake Mawu ada aŋutrɔ wo 
\q2 eye wòalɔ wo zi ɖeka kpoyi woamu adze anyi. 
\q1  
\v 8 Ana woawo ŋutɔ ƒe aɖe nade wo nya me 
\q2 eye wòahe wo ade tsɔtsrɔ̃ me. 
\q2 Ame siwo katã akpɔ wo la aʋuʋu ta ɖe wo ŋu fewuɖutɔe. 
\q1  
\v 9 Tete vɔvɔ̃ aɖo amegbetɔƒomea katã; 
\q2 woado Mawu ƒe dɔwɔwɔwo ɖe dzi, 
\q2 eye woade ŋugble le nu si wòwɔ la ŋuti. 
\b  
\q1  
\v 10 Ame dzɔdzɔe akpɔ dzidzɔ le Yehowa me, eye wòasii atso. 
\q2 Ame siwo katã dza le woƒe dzi me la akafui! 
\c 65  
\cl Psalmo 65 
\d David ƒe ha na hɛnɔ la. 
\q1  
\v 1 O! Mawu, kafukafu le lalawòm le Zion; 
\q2 wòe míaxe míaƒe adzɔgbeɖefewo na. 
\q1  
\v 2 O! Wò ame si sea gbedodoɖa, 
\q2 gbɔwòe amewo katã ava. 
\q1  
\v 3 Esi nu vɔ̃ do agba ɖe mía dzi la, 
\q2 ètsɔ míaƒe dzidadawo ke mí. 
\q1  
\v 4 Woayra ame siwo nètia, 
\q2 eye nèkplɔ wo vɛ be woanɔ wò xɔxɔnuwo! 
\q1 Ètsɔ wò aƒe me, 
\q2 wò gbedoxɔ kɔkɔe la me nu nyuiwo ɖi ƒoe na mí. 
\b  
\q1  
\v 5 Èna ŋuɖoɖo mí to dzɔdzɔenyenye ƒe ŋɔdzidɔwo me, 
\q2 O, Mawu míaƒe xɔnametɔ, 
\q1 anyigba ƒe mlɔenu ke, 
\q2 kple atsiaƒu siwo le didiƒe ke la katã ƒe mɔkpɔkpɔ. 
\q1  
\v 6 Wò ame si na towo va dzɔ to wò ŋusẽ me, 
\q2 eye nètsɔ ŋusẽ bla ali dzii, 
\q1  
\v 7 wò ame si tsi atsiaƒu ƒe hoowɔwɔ 
\q2 kple ƒutsotsoe dzeagbowo 
\q2 kpakple dukɔwo ƒe ʋunyaʋunyawo nu. 
\q1  
\v 8 Ame siwo le didiƒe la vɔ̃ wò nukunuwo; 
\q2 èna dzidzɔhawo ɖi tso afi si ɣe dzena tsona 
\q2 kple afi si wòɖoa to ɖo. 
\b  
\q1  
\v 9 Èlé be na anyigba, 
\q2 de aɖui wòsui nyuie, eye nède tsii fũu. 
\q1 Tsi yɔ Mawu ƒe tɔʋuwo banaa, 
\q2 ne wòana bli eƒe dukɔ, 
\q2 elabena nenema nèɖoe. 
\q1  
\v 10 Ède tsi eƒe boliƒowo, 
\q2 eye nègbã kpoteƒewo wozu sɔsɔe. 
\q1 Ètsɔ agbafie bɔbɔ anyigba lae, 
\q2 eye nèyra eƒe nukuwo. 
\q1  
\v 11 Ètsɔ wò kesinɔnu gbogboawo ɖo atsyɔ̃e na ƒe la, 
\q2 eye wò agblekekewo yɔ gbagba. 
\q1  
\v 12 Lãnyiƒe siwo le gbegbe la yɔ gbagba, 
\q2 eye wotsɔ aseyetsotso ta na togbɛwo. 
\q1  
\v 13 Gbe damawo dzi yɔ fũu kple lãhawo, 
\q2 eye balimewo ƒe afi sia afi yɔ kple bli; 
\q2 wo katã do dzidzɔɣli, eye wodzi ha. 
\c 66  
\cl Psalmo 66 
\d Ha na hɛnɔ la. 
\q1  
\v 1 Mi anyigbawo katã mido ɣli, 
\q2 mitso aseye ɖe Mawu ŋu! 
\q1  
\v 2 Midzi eƒe ŋkɔ ƒe ŋutikɔkɔe ƒe ha; 
\q2 mikafu Mawu ƒe gãnyenye! 
\q1  
\v 3 Migblɔ na Mawu be, 
\q2 “Wò dɔwɔwɔwo dziŋɔ loo! 
\q1 Wò ŋusẽ tri akɔ ale gbegbe be, 
\q2 wò futɔwo de ta agu na wò. 
\q1  
\v 4 Anyigba la katã de ta agu na wò, 
\q2 wole kafukafuha dzim na wò, 
\q2 wole kafukafuha dzim na wò ŋkɔ.” \qs Sela\qs* 
\b  
\q1  
\v 5 Va, nàkpɔ nu si Mawu wɔ, 
\q2 ale si le amegbetɔwo ta wòwɔ ŋɔdzidɔ geɖewo! 
\q1  
\v 6 Etrɔ atsiaƒu wòzu anyigba ƒuƒui, 
\q2 wozɔ afɔ to tsi la titina; 
\q2 miva míatso aseye le eya amea me. 
\q1  
\v 7 Ele fia ɖum kple eƒe ŋusẽ tegbee, 
\q2 eƒe ŋku le dukɔwo ta kpɔm, 
\q2 aglãdzela aɖeke megatso ɖe eŋuti o. \qs Sela\qs* 
\b  
\q1  
\v 8 O! Mi dukɔwo, mikafu míaƒe Mawu la; 
\q2 mina eƒe kafukafu nade dzi woase. 
\q1  
\v 9 Eyae kpɔ míaƒe agbe ta, 
\q2 eye mena míaƒe afɔ ɖiɖi o. 
\q1  
\v 10 Elabena O Mawu, wòe do mí kpɔ, 
\q2 wòe lolõ mí abe klosalo ene. 
\q1  
\v 11 Wòe de mí gaxɔ me, 
\q2 eye nèdo agba ɖe megbe na mí. 
\q1  
\v 12 Èna amewo zɔ míaƒe ta dzi, 
\q2 eye míeto dzo me kple tɔ me, 
\q1 gake èkplɔ mí va anyigba 
\q2 si dzi nuwo do agbogbo ɖo fũu. 
\b  
\q1  
\v 13 Mava wò gbedoxɔ me kple numevɔsa, 
\q2 eye maxe nye adzɔgbeɖefewo na wò, 
\q1  
\v 14 adzɔgbe siwo nye nuyi ɖe, 
\q2 eye nye nu ɖe gbeƒã wo, esi meɖo xaxa me. 
\q1  
\v 15 Matsɔ lã damiwo kple agbowo asa numevɔe na wò, 
\q2 hekpe ɖe nyitsuwo kple gbɔ̃wo ŋuti. \qs Sela\qs* 
\b  
\q1  
\v 16 Miva se, mí ame siwo katã vɔ̃a Mawu; 
\q2 mina magblɔ nu siwo wòwɔ nam la na mi. 
\q1  
\v 17 Metsɔ nye nu do ɣli nɛ, 
\q2 eƒe kafukafu le nye aɖe dzi. 
\q1  
\v 18 Ɖe mena nɔƒe nu vɔ̃ le nye dzi me la, 
\q2 ne Aƒetɔ la meɖo tom o, 
\q1  
\v 19 gake Mawu ɖo tom vavã, 
\q2 eye wòse nye gbe le gbedodoɖa me. 
\q1  
\v 20 Woakafu Mawu, ame si medo toku nye gbedodoɖa, 
\q2 alo te eƒe lɔlɔ̃ ɖa le gbɔnye o! 
\c 67  
\cl Psalmo 67 
\d Ha na hɛnɔ la. Woadzii ɖe kasaŋku ŋu. 
\q1  
\v 1 Mawu, ve mía nu, eye nàyra mí, 
\q2 na wò mo naklẽ ɖe mía dzi, \qs Sela\qs* 
\q1  
\v 2 Ale be woanya wò mɔwo le anyigba dzi 
\q2 kple wò xɔxɔ le dukɔwo dome. 
\b  
\q1  
\v 3 O! Mawu, dukɔwo akafu wò, 
\q2 anyigbadzidukɔwo katã akafu wò. 
\q1  
\v 4 Dukɔwo akpɔ dzidzɔ, adzi ha, atso aseye, 
\q2 elabena èɖu dukɔwo dzi le dzɔdzɔenyenye me, 
\q2 eye nèkplɔ anyigbadzidukɔwo. \qs Sela\qs* 
\q1  
\v 5 Mawu, dukɔwo katã akafu wò; 
\q2 wòe dukɔwo katã akafu. 
\b  
\q1  
\v 6 Ekema anyigba ana woaxa eƒe nukuwo fũu, eye Mawu, 
\q2 míaƒe Mawu la ayra mí. 
\q1  
\v 7 Mawu ayra mí, eye anyigba 
\q2 ƒe mlɔenutɔwo katã avɔ̃e. 
\c 68  
\cl Psalmo 68 
\d David ƒe ha na hɛnɔ la. 
\q1  
\v 1 Mawu tso, na wò futɔwo naka hlẽ, 
\q2 na wò ketɔwo nasi le nuwò. 
\q1  
\v 2 Gbɔ wo ɖa abe ale si ya gbɔa dzudzɔ dzonae ene. 
\q2 Abe ale si yɔkumi lolõna le dzo nu ene la, 
\q2 nenema ame vɔ̃ɖiwo atsrɔ̃e le Mawu ŋkume. 
\q1  
\v 3 Ke ame dzɔdzɔewo ya akpɔ dzidzɔ, 
\q2 atso aseye le Mawu ŋkume; 
\q2 na woakpɔ dzidzɔ, eye woatu aglo. 
\b  
\q1  
\v 4 Midzi ha na Mawu, 
\q2 midzi kafukafuha na eƒe ŋkɔ, 
\q2 mido ame si le lilikpowo dzi gbɔna la ɖe dzi, 
\q2 eŋkɔe nye Yehowa, eye mitso aseye le eŋgɔ; 
\q1  
\v 5 eya ame si nye tɔ na tɔmanɔsitɔwo, 
\q2 ahosiwo ta ʋlila, eye wònye Mawu si le enɔƒe kɔkɔe la. 
\q1  
\v 6 Mawu kplɔa ame siwo tsi akogo la dea ƒomewo me, 
\q2 enana ablɔɖe gamenɔlawo, eye wodzia dzidzɔhawo. 
\q2 Ke ame dzeaglãwo la, egblẽa wo ɖe kuɖiɖinyigba dzi. 
\b  
\q1  
\v 7 O! Mawu, ne èdo dze wò dukɔ la ŋgɔ, 
\q2 hezɔ to gbegbe la, \qs Sela\qs* 
\q1  
\v 8 anyigba ʋuʋu, dziƒowo dza tsi bɔbɔbɔ le Mawu, 
\q2 si nɔ Sinai la ŋkume, le Mawu, 
\q2 Israel ƒe Mawu la ŋkume. 
\q1  
\v 9 O! Mawu, èna tsi dza fũu, 
\q2 eye nèna wò domenyinu si nu ti kɔ na 
\q2 belibelibeli la gakpɔ ŋusẽ. 
\q1  
\v 10 Mawu, wò amewo yi ɖanɔ edzi, 
\q2 eye tso wò nu gbogboawo me, èna nu ame dahewo. 
\b  
\q1  
\v 11 Aƒetɔ ɖe gbeƒã nya la, 
\q2 eye ameha gã aɖe do ɣli kplii be, 
\q1  
\v 12 “Fiawo kple aʋakɔwo, misi kaba, 
\q2 elabena amewo le afunyinuwo ham le asaɖawo me. 
\q1  
\v 13 Esi miele alɔ̃ dɔm le lãkpowo dome la, 
\q2 wotsɔ klosalo fa ɖe nye ahɔnɛ ƒe aʋala ŋu, 
\q2 eye wotsɔ sika si le keklẽm la fa ɖe eƒe fuwo ŋuti.” 
\q1  
\v 14 Esi Ŋusẽkatãtɔ la kaka anyigbadzifiawo hlẽ la, 
\q2 enɔ abe tsikpee dza ɖe Zalmɔn dzi ene. 
\b  
\q1  
\v 15 Basan towo ƒe dzedzeme 
\q2 kple kɔkɔme nya kpɔ ŋutɔ; 
\q2 to tsaklitsakliwo Basan toawo nye. 
\q1  
\v 16 O! To tsaklitsakliwo, 
\q2 nu ka ta mietsɔ ŋuʋaʋã ƒe ŋku 
\q1 le to si Mawu tia be wòanye yeƒe fiazikpui ƒe nɔƒe 
\q2 kple Yehowa ŋutɔ ƒe nɔƒe tegbee la kpɔmii? 
\q1  
\v 17 Mawu ƒe tasiaɖamwo nye akpe nanewo 
\q2 kple akpe teƒe akpewo; 
\q2 Aƒetɔ la tso Sinai va ɖo eƒe teƒe kɔkɔe la. 
\q1  
\v 18 Esi nèlia yi dzi la, ètɔ ka aboyomewo hekplɔ dzoe, 
\q2 èxɔ nunana tso amewo gbɔ, 
\q1 tso aglãdzelawo gɔ̃ hã gbɔ, be wò, 
\q2 O! Yehowa Mawu, àte ŋu anɔ afi ma. 
\b  
\q1  
\v 19 Kafukafu woana Aƒetɔ, Mawu míaƒe Ɖela, 
\q2 ame si tsɔa míaƒe agbawo gbe sia gbe. \qs Sela\qs* 
\q1  
\v 20 Míaƒe Mawu nye Mawu si xɔna na ame; 
\q2 ɖeɖe tso ku me vana to Aƒetɔ Yehowa ko dzi. 
\q1  
\v 21 Vavã, Mawu agbã ta na eƒe futɔwo 
\q2 kple dzodome na ame siwo gale woƒe nu vɔ̃wo dzi yim. 
\q1  
\v 22 Aƒetɔ la gblɔ be, 
\q2 “Makplɔ wo vɛ tso Basan; 
\q2 makplɔ wo ado goe tso atsiaƒu ƒe gogloƒe ke, 
\q1  
\v 23 be nàklɔ afɔ ɖe wò futɔwo ƒe ʋu me, 
\q2 eye wò avuwo ƒe aɖewo hã nakpɔ wo tɔ gome.” 
\b  
\q1  
\v 24 O! Mawu, wole míaƒe azɔlime kpɔm, 
\q2 wole ale si nye Mawu 
\q2 kple fianye zɔ ge ɖe kɔkɔeƒe lae la kpɔm. 
\q1  
\v 25 Woɖo ɖe fli me, hadzilawo le ŋgɔgbe, 
\q2 hafialawo ɖo, eye ɖetugbi siwo 
\q2 le axatsɛ ƒom la tsɔ wo ɖe dome. 
\q1  
\v 26 Mikafu Mawu le ameha gã la dome. 
\q2 Mikafu Yehowa le Israelviwo ƒe takpekpe me. 
\q1  
\v 27 Kpɔ ɖa, Benyamin ƒe to si nye suetɔ lae le ŋgɔ na wo, 
\q2 Yuda ƒe dumegã gbogboawo le afi ma, 
\q2 eye Zebulon kple Naftali ƒe amegãwo hã le afi ma. 
\b  
\q1  
\v 28 O! Mawu, yɔ wò ŋusẽ vɛ; 
\q2 O! Mawu, ɖe wò ŋusẽ fia mí abe tsã ene. 
\q1  
\v 29 Le wò Yerusalem gbedoxɔ ta la, 
\q2 fiawo atsɔ nunanawo vɛ na wò. 
\q1  
\v 30 Blu ɖe lã wɔadã siwo le aƒlawo me 
\q2 kple nyitsuwo ƒe ha siwo le dukɔwo ƒe nyiviwo dome la ta. 
\q1 Netsɔ klosalokɔ gãwo vɛ le ɖokuibɔbɔ me. 
\q2 Kaka dukɔ siwo aʋawɔwɔ doa dzidzɔ na. 
\q1  
\v 31 Ame dɔdɔwo atso Egipte ava, 
\q2 eye Kus abɔbɔ eɖokui ɖe Mawu te. 
\b  
\q1  
\v 32 O! Mi anyigbadzifiaɖuƒewo, 
\q2 midzi ha na Mawu, 
\q2 midzi kafukafuha na Aƒetɔ la, \qs Sela\qs* 
\q1  
\v 33 Eya ame si nɔ blemalilikpowo dzi, 
\q2 eye wòɖe gbe kple gbe sesẽ aɖe. 
\q1  
\v 34 Miɖe gbeƒã Mawu ƒe ŋusẽ, 
\q2 ame si ƒe atsyɔ̃ le Israel dzi, 
\q2 eye eƒe ŋusẽ le dziŋgɔli ŋu. 
\q1  
\v 35 O! Mawu, ŋɔdzi le ŋuwò le wò kɔkɔeƒe la; 
\q2 Israel ƒe Mawu la na ŋusẽ 
\q2 kple ŋutete eƒe dukɔ la. 
\b  
\q1 Woakafu Mawu! 
\c 69  
\cl Psalmo 69 
\d David ƒe ha na hɛnɔ la. Woadzii ɖe “Dzogbenya” ƒe gbeɖiɖi nu. 
\q1  
\v 1 Mawu, ɖem, 
\q2 elabena tsi ɖɔ ɖe ŋunye va se ɖe nye kɔgbɔ ke. 
\q1  
\v 2 Meɖo ba yi ɖe tome ke, 
\q2 afi si afɔɖoƒe mele o. 
\q1 Meɖo tɔ goglowo me; 
\q2 tsi ɖɔ to tanye. 
\q1  
\v 3 Medo ɣli be woaxɔ nam, 
\q2 ale nu ti kɔ nam, eye nye ve me hã ƒu kplakplakpla. 
\q1 Mekpɔ mɔ na Mawu ʋuu, 
\q2 eye ɖeɖi te nye ŋkuwo ŋu. 
\q1  
\v 4 Ame siwo lé fum ɖe nanekemawɔmawɔ ta la 
\q2 sɔ gbɔ wu nye taɖa. 
\q1 Amewo lé fum yakatsyɔ, 
\q2 eye woti yonyeme be woatsrɔ̃m. 
\q1 Ale meɖo nu si nyemefi o la eteƒe dzizizitɔe. 
\b  
\q1  
\v 5 O! Mawu, ènya nye bometsitsi, 
\q2 eye nye fɔɖiɖi mele ɣaɣla ɖe wò o. 
\b  
\q1  
\v 6 O! Aƒetɔ, Yehowa Ŋusẽkatãtɔ, 
\q2 mègana ame siwo ƒe mɔkpɔkpɔ 
\q2 le mewò la naɖu ŋukpe le tanye o. 
\q1 O! Israel ƒe Mawu, ame siwo le diwòm la, 
\q2 mègana ŋu nakpe wo le tanye o. 
\q1  
\v 7 Tawòe wodo vlom ɖo, 
\q2 eye ŋukpe tsyɔ mo nam. 
\q1  
\v 8 Menye amedzro na nye ŋutɔ nɔvinye ŋutsuwo 
\q2 kple ame manyamanya na danyevi ŋutsuwo. 
\q1  
\v 9 Elabena lɔlɔ̃ na wò aƒe zu dzo ge ɖe menye, 
\q2 eye ame siwo dzu wò la ƒe dzudzu va dzinye. 
\q1  
\v 10 Esi mefa avi, tsi nu dɔ la, 
\q2 vlododo boŋ wozu nam; 
\q1  
\v 11 esi meta akpanya la, 
\q2 mezu nu ɖikokoe na amewo. 
\q1  
\v 12 Ame siwo nɔ anyi ɖe agbo nu la ɖe alɔme le ŋunye, 
\q2 eye ahamulawo kekeake hã kpa ha dem. 
\b  
\q1  
\v 13 O! Yehowa, medo gbe ɖa na wò le wò amenuveɣi; 
\q2 O! Mawu, le wò lɔlɔ̃ gã la ta, 
\q2 tɔ nam kple wò xɔname si medana le edzi o. 
\q1  
\v 14 Ɖem tso agbi me, 
\q2 mègana mayi to o, 
\q1 ɖem le ame siwo lé fum la ƒe asi me, 
\q2 tso tɔ goglowo me. 
\q1  
\v 15 Mègana tsi naɖɔ to tanye, 
\q2 alo gogloƒe namim, eye ʋe globo natu eƒe nu ɖe dzinye o. 
\b  
\q1  
\v 16 O! Yehowa, tɔ nam, le wò lɔlɔ̃ deto la ta, 
\q2 eye trɔ ɖe ŋutinye le wò nublanuikpɔkpɔ gã la ta. 
\q1  
\v 17 Mègaɣla wò mo ɖe wò dɔla o; 
\q2 ke boŋ tɔ nam kaba, elabena meɖo xaxa me. 
\q1  
\v 18 Te ɖe ŋunye, eye nàxɔ nam, 
\q2 ɖem le nye ketɔwo ta. 
\b  
\q1  
\v 19 Ènya ale si wodo vlom, 
\q2 ɖi gbɔ̃m, eye wodo ŋu kpem; 
\q2 nye futɔwo katã le ŋkuwò me. 
\q1  
\v 20 Vlododo na nye dzi gbã, 
\q2 eye mezu xɔnamemanɔsitɔ; 
\q1 mekpɔ mɔ na babadoname, 
\q2 gake ɖeke meli o. 
\q1 Mekpɔ mɔ na akɔfalawo, 
\q2 gake nyemekpɔ ɖeke o. 
\q1  
\v 21 Wotsɔ veve de nye nuɖuɖu me, 
\q2 eye esi tsikɔ wum la, wotsɔ aha tsitsi nam be mano. 
\b  
\q1  
\v 22 Woƒe kplɔ̃ si woɖo na wo la nezu mɔ na wo; 
\q2 nezu teƒeɖoɖo kple mɔ na wo. 
\q1  
\v 23 Woƒe ŋkuwo dzi nedo viviti be, 
\q2 womagate ŋu akpɔ nu o, 
\q2 eye na woƒe dzi me naɖo kpo tegbee. 
\q1  
\v 24 Trɔ wò dziku kɔ ɖe wo dzi, 
\q2 eye nàna wò dɔmedzoe helĩhelĩ nalé wo. 
\q1  
\v 25 Woƒe nɔƒe neɖi gbɔlo; 
\q2 mègana be ame aɖeke neganɔ woƒe agbadɔwo me o. 
\q1  
\v 26 Elabena woti ame siwo ŋu nède abii la yome, 
\q2 eye wole nu ƒom le ame siwo nèwɔ nuvevii la ƒe vevesese ŋu. 
\q1  
\v 27 Bu fɔ wo, eye nàgabu fɔ wo ɖe edzi; 
\q2 mègana woakpɔ gome le wò xɔname me o. 
\q1  
\v 28 Tutu woƒe ŋkɔwo ɖa le agbegbalẽ la me, 
\q2 eye mègana woaŋlɔ woƒe ŋkɔ ɖe 
\q2 ame dzɔdzɔewo dome o. 
\b  
\q1  
\v 29 Mele vevesese kple nuxaxa me; 
\q2 O! Mawu, na wò xɔname natɔ kpɔ ƒo xlãm. 
\b  
\q1  
\v 30 Matsɔ hadzidzi akafu Mawu ƒe ŋkɔ, 
\q2 eye madoe ɖe dzi kple akpedada. 
\q1  
\v 31 Esia adze Yehowa ŋu wu nyi, 
\q2 eye wòado dzidzɔ nɛ wu nyitsu 
\q2 kple eƒe dzowo kpakple eƒe afɔkliwo. 
\q1  
\v 32 Hiãtɔwo akpɔe ahatso aseye, 
\q2 eye mi ame siwo dia Mawu la, 
\q2 míaƒe dziwo nenɔ agbe ɖaa! 
\q1  
\v 33 Yehowa ɖoa to hiãtɔwo, 
\q2 eye medoa vlo eƒe ame siwo le aboyome o. 
\b  
\q1  
\v 34 Dziƒo kple anyigba nekafui, 
\q2 atsiaƒuwo kple nu siwo katã ʋãna le wo me, 
\q1  
\v 35 elabena Mawu aɖe Zion, 
\q2 eye wòagbugbɔ Yuda ƒe duwo atso. 
\q1 Ekema amewo aɖanɔ afi ma, axɔe wòazu wo tɔ; 
\q2  
\v 36 eƒe dɔlawo ƒe viwo atsɔe anyi domee, 
\q2 eye ame siwo lɔ̃ eƒe ŋkɔ la anɔ afi ma. 
\c 70  
\cl Psalmo 70 
\d David ƒe ha na hɛnɔ la. Kukuɖeɖe. 
\q1  
\v 1 O! Mawu, netsɔ nàɖem; 
\q2 O! Yehowa, va kaba nàxɔ nam. 
\b  
\q1  
\v 2 Ŋukpe kple tɔtɔ neva ame siwo 
\q2 le nye agbe yome tim la dzi. 
\q1 Ame siwo le nye gbegblẽ dim la 
\q2 negbugbɔ ɖe megbe kple ŋukpe. 
\q1  
\v 3 Na be ame siwo le gbɔgblɔm be, 
\q2 “Ɛhɛ̃! Ɛhɛ̃!” la 
\q2 natrɔ megbe adzo kple ŋukpe. 
\q1  
\v 4 Ke ame siwo dia wò la netso aseye; 
\q2 woakpɔ dzidzɔ le mewò, 
\q1 eye ame siwo lɔ̃a wò xɔname la negblɔ ɖaa be, 
\q2 “Woado Mawu ɖe dzi ɖaa!” 
\b  
\q1  
\v 5 Ke nye la, O Mawu, meda ahe, eye hiã tum, 
\q2 eya ta va gbɔnye kaba. 
\q1 O! Yehowa, mègahe ɖe megbe o, 
\q2 elabena wòe nye nye xɔnametɔ kple nye Ɖela. 
\c 71  
\cl Psalmo 71 
\q1  
\v 1 O! Yehowa, mewòe mebe ɖo, 
\q2 mègana ŋu nakpem akpɔ gbeɖe o. 
\q1  
\v 2 Xɔ nam, eye nàɖem le wò dzɔdzɔenyenye la ta; 
\q2 trɔ wò to ɖe gbɔnye, eye nàxɔ nam. 
\q1  
\v 3 Nye sitsoƒe ƒe agakpe, 
\q2 afi si mate ŋu abe ɖo ɣe sia ɣi. 
\q1 Ɖe gbe be woaxɔ nam, 
\q2 elabena wòe nye nye agakpe kple mɔ sesẽ. 
\q1  
\v 4 O! Nye Mawu, ɖem tso ame vɔ̃ɖiwo ƒe asi me, 
\q2 eye nàɖem tso nu tovo wɔlawo 
\q2 kple ŋutasẽlawo ƒe fego me. 
\q1  
\v 5 Elabena tso ɣe aɖe ɣi ke, wòe nye nye mɔkpɔkpɔ 
\q2 kple nye dzideƒo tso nye ɖekakpuime ke, 
\q2 O! Aƒetɔ Yehowa. 
\q1  
\v 6 Tso nye dzigbe ke, 
\q2 wò ko ŋu meku ɖo, 
\q1 elabena wòe ɖem tso danye ƒe dɔ me, 
\q2 eya ta makafu wò ɖaa. 
\q1  
\v 7 Mezu nu maɖinu na ame geɖewo, 
\q2 gake wòe nye nye mɔ sesẽ. 
\q1  
\v 8 Wò kafukafu yɔ nye nu me, 
\q2 eye meɖea gbeƒã wò atsyɔ̃ŋkeke blibo la. 
\q1  
\v 9 Mègatsɔm ƒu gbe, ne meku amegã o, 
\q2 eye mègagblẽm ɖi ne ŋusẽ vɔ le ŋunye o. 
\q1  
\v 10 Elabena nye futɔwo ƒo nu tsi tsitre ɖe ŋunye, 
\q2 eye ame siwo le lalam be yewoawum la, 
\q2 wɔ ɖeka ɖo nugbe ɖe ŋunye. 
\q1  
\v 11 Wogblɔ be, “Mawu gblẽe ɖi, míti eyome, 
\q2 míalée, elabena ame aɖeke mava axɔ nɛ o.” 
\q1  
\v 12 O! Mawu, mèganɔ adzɔge tso gbɔnye o, 
\q2 O! Nye Mawu, va kaba nàxɔ nam. 
\q1  
\v 13 Na be nunyetsolawo natsrɔ̃ kple ŋukpe, 
\q2 eye nàna be vlododo kple ŋukpe natsyɔ 
\q2 ame siwo di be yewoawɔ nuvevim la dzi. 
\q1  
\v 14 Ke nye ya la, mɔkpɔkpɔ anɔ asinye ɖaa, 
\q2 eye makafu wò, agakafu wò ɖe edzi. 
\q1  
\v 15 Nye nu aɖe gbeƒã wò dzɔdzɔenyenye 
\q2 kple wò xɔname ŋkeke blibo la, 
\q2 togbɔ be nyemenya eƒe kpekpeme o hã. 
\q1  
\v 16 Mava aɖe gbeƒã wò nu dzɔatsuwo, 
\q2 O Aƒetɔ Yehowa. 
\q1 Maɖe gbeƒã wò dzɔdzɔenyenye, 
\q2 wò ɖeka tɔ ko. 
\q1  
\v 17 O! Mawu; tso nye ɖekakpuime ke, 
\q2 nèfia num, eye va se ɖe egbe la, 
\q2 mele gbeƒã ɖem wò nu dzɔatsuwo. 
\q1  
\v 18 O! Mawu, ne metsi, 
\q2 ƒo wɔ hã la, mègagblẽm ɖi o, 
\q1 va se ɖe esime maɖe gbeƒã wò ŋusẽ 
\q2 na dzidzime si ava dzɔ 
\q2 kple wò ŋusẽ na ame siwo woava dzi. 
\q1  
\v 19 O! Mawu, wò dzɔdzɔenyenye yi ɖatɔ dziŋgɔli ke, 
\q2 wò ame si wɔ nu dzɔatsu geɖewo. 
\q2 O! Mawu, ame kae le abe wò ene? 
\q1  
\v 20 Togbɔ be èna mekpɔ xaxa geɖe kple vevesese hã la, 
\q2 àgaɖo nye agbe te, eye àva kplɔm 
\q2 ado goe tso anyigba ƒe tume ke. 
\q1  
\v 21 Àdzi nye bubu ɖe edzi, 
\q2 eye àgafa akɔ nam. 
\b  
\q1  
\v 22 O! Nye Mawu, makafu wò kple kasaŋku 
\q2 le wò nuteƒewɔwɔ ta; 
\q1 madzi kafukafuha na wò kple gasaŋku, 
\q2 O! Israel ƒe Kɔkɔetɔ. 
\q1  
\v 23 Nye nuyiwo ado dzidzɔɣli, 
\q2 ne mele kafukafuhawo dzim na wò, 
\q2 nye ame si nèɖe. 
\q1  
\v 24 Nye aɖe agblɔ wò dzɔdzɔenyenye 
\q2 ƒe dɔwo ŋkeke blibo la, 
\q1 elabena ŋukpe kple tɔtɔ va 
\q2 ame siwo di be yewoawɔ nuvevim la dzi. 
\c 72  
\cl Psalmo 72 
\d Ha na Solomo. 
\q1  
\v 1 O! Mawu, tsɔ wò afia nyui tsotso do na fia la, 
\q2 kple wò dzɔdzɔenyenye na fiavi la. 
\q1  
\v 2 Adrɔ̃ ʋɔnu na wò dukɔ la le dzɔdzɔenyenye me, 
\q2 eye wòatso afia nyui na ame siwo ƒe dzi gbã la. 
\b  
\q1  
\v 3 Towo atsɔ kesinɔnuwo vɛ na wò dukɔ, 
\q2 eye togbɛwo atsɔ dzɔdzɔenyenye ƒe kutsetse vɛ na wo. 
\q1  
\v 4 Aʋli ame siwo ƒe dzi gbã la ta, 
\q2 axɔ na hiãtɔwo ƒe viwo, 
\q2 eye wòagbã ameteɖetola la nyanyanya. 
\q1  
\v 5 Zi ale si ɣe kple ɣleti li la, 
\q2 anɔ te le dzidzimewo katã me. 
\q1  
\v 6 Anɔ abe tsidzadza ɖe anyigba si dzi woƒo gbe le 
\q2 kple agbafie si dza ɖe anyigba hede tsii ene. 
\q1  
\v 7 Ame dzɔdzɔewo ayi ŋgɔ le eƒe ɣeyiɣiwo me, 
\q2 eye kesinɔnuwo ado agbogbo va se ɖe esime ɣleti magaɖi o. 
\b  
\q1  
\v 8 Aɖu fia tso atsiaƒu ƒe go sia dzi ayi go kemɛ dzi, 
\q2 tso tɔsisi to ase ɖe anyigba la ƒe mlɔenuwo ke. 
\q1  
\v 9 Dukɔ siwo le gbegbe la ade ta agu nɛ, 
\q2 eye eƒe futɔwo aɖuɖɔ ʋuʋudedi. 
\q1  
\v 10 Tarsis fia kple didiƒe ƒutatɔwo ahe adzɔ vɛ nɛ, 
\q2 eye Sieba kple Seba fiawo atsɔ nunanawo vɛ nɛ. 
\q1  
\v 11 Fiawo katã ade ta agu nɛ, 
\q2 eye dukɔwo katã asubɔe, 
\q1  
\v 12 elabena aɖe hiãtɔ si le avi fam 
\q2 kple wɔmenɔ si xɔnametɔ aɖeke meli na o. 
\q1  
\v 13 Akpɔ nublanui na ame gblɔewo kple hiãtɔwo, 
\q2 eye wòaɖe ame dahewo tso ku me. 
\q1  
\v 14 Aɖe wo le teteɖeanyi kple ŋutasesẽ me, 
\q2 elabena woƒe ʋu xɔ asi le eŋkume. 
\b  
\q1  
\v 15 Fia la nenɔ agbe tegbee! 
\q2 Wonetsɔ Seba sika nɛ. 
\q1 Amewo nedo gbe ɖa ɖe eta ɖaa, 
\q2 eye wòayra ŋkeke blibo la. 
\q1  
\v 16 Bli nedo agbogbo ɖe anyigba la katã dzi; 
\q2 eye neʋã ɖe togbɛwo katã dzi. 
\q1 Blitiawo netri abe Lebanontɔwo ene, 
\q2 eye woanɔ abe gbe le gbedzi ene. 
\q1  
\v 17 Eƒe ŋkɔ nenɔ anyi ɖaa, 
\q2 eye nenɔ anyi zi ale si ɣe le keklẽm. 
\b  
\q1 Woayra dukɔwo katã to eya amea dzi, 
\q2 eye woayɔe be yayratɔ. 
\b  
\b  
\q1  
\v 18 Woakafu Yehowa Mawu, 
\q2 Israel ƒe Mawu la, 
\q2 eya ame si ko wɔa nu dzɔatsuwo. 
\q1  
\v 19 Woakafu eƒe ŋkɔ si ŋu ŋutikɔkɔe 
\q2 le la tso mavɔ me yi ɖe mavɔ me; 
\q1 eƒe ŋutikɔkɔe neyɔ anyigba blibo la dzi. 
\qc Amen, ɛ̃, Amen. 
\b  
\b  
\q1  
\v 20 Esiawo wu Yese ƒe vi, David ƒe gbedodoɖawo nu. 
\c 73  
\ms1 Agbalẽ etɔ̃lia 
\mr Psalmowo 73–89 
\cl Psalmo 73 
\d Asaf ƒe ha. 
\q1  
\v 1 Vavã, Mawu wɔ nyui na Israel 
\q2 kple ame siwo dza le woƒe dzi me. 
\q1  
\v 2 Ke nye la, nye afɔ ɖiɖi kloe, 
\q2 eye esusɔ vie ko medze anyi. 
\q1  
\v 3 Elabena mebiã ŋu ɖokuiŋudzela esi mekpɔ 
\q2 ale si nu le edzi dzem na ame vɔ̃ɖiwoe. 
\b  
\q1  
\v 4 Hiãkame aɖeke mele wo dzi o, 
\q2 eye wole lãmesẽ kple dedinɔnɔ me. 
\q1  
\v 5 Wovo tso agba siwo tena ɖe amewo dzi la me, 
\q2 eye amegbetɔwo ƒe hiãtuame aɖeke mele wo dzi o. 
\q1  
\v 6 Eya ta dada nye woƒe kɔga, 
\q2 eye wodo nu vɔ̃ɖi wɔwɔ abe awu ene. 
\q1  
\v 7 Dzidada dona tso woƒe dzi si ku atri la me, 
\q2 eye seɖoƒe meli na woƒe susu ƒe nu vɔ̃ɖiwo ɖoɖo o. 
\q1  
\v 8 Woɖua fewu, ƒoa nu vlodoametɔe, 
\q2 eye le woƒe dada me la, woklẽa ŋku ɖe amewo be woabɔbɔ na wo. 
\q1  
\v 9 Woƒe nuwo xɔ dziƒo wɔ wo tɔe, 
\q2 eye woƒe aɖewo xɔ anyigba wòzu wo tɔ. 
\q1  
\v 10 Eya ta woƒe amewo trɔ ɖe wo gbɔ, 
\q2 eye wono tsi fũu. 
\q1  
\v 11 Wogblɔ be, “Aleke Mawu awɔ anya? 
\q2 Ɖe nunya le Dziƒoʋĩtɔ la sia?” 
\b  
\q1  
\v 12 Aleae ame vɔ̃ɖiwo le, 
\q2 wole ablɔɖe me ɣe sia ɣi, eye wodzia woƒe kesinɔnuwo ɖe edzi. 
\b  
\q1  
\v 13 Nyateƒee, dzodzro ko wònye be mewɔ nye dzi dzadzɛ, 
\q2 eye dzodzroe meklɔ nye asi ɖe fɔmaɖimaɖi me. 
\q1  
\v 14 Mekpea fu ŋkeke blibo la, 
\q2 eye ŋdi sia ŋdi wohea to nam. 
\b  
\q1  
\v 15 Ɖe megblɔ be, 
\q2 “Ale maƒo nui nye si” la, 
\q2 anye ne mede viwòwo asi. 
\q1  
\v 16 Enye teteɖeanyi gã aɖe te menɔ 
\q2 esi medze agbagba be mase nu siawo gɔme, 
\q1  
\v 17 va se ɖe esime mege ɖe Mawu ƒe Kɔkɔeƒe la, 
\q2 tete mese afi si woawu nu ɖo la gɔme. 
\b  
\q1  
\v 18 Vavã, ètsɔ wo ɖo didiƒe, 
\q2 eye nètsɔ wo xlã ɖe anyi wogblẽ keŋkeŋ. 
\q1  
\v 19 Aleke wohetsrɔ̃ kpata ale, 
\q2 ŋɔdzi kplɔ wo dzoe kaba ŋutɔ! 
\q1  
\v 20 O! Aƒetɔ, abe ale si drɔ̃e nɔna ne 
\q2 ame nyɔ tso alɔ̃ me ene la, 
\q2 do vlo wo abe drɔ̃e manyatalenu ene. 
\b  
\q1  
\v 21 Esi nye dzi bi ɖe dɔ me nam, 
\q2 eye nye gbɔgbɔ se veve la, 
\q1  
\v 22 mezu bometsila kple numanyala, 
\q2 eye mele abe lã tagbɔkukutɔ ene le ŋkuwò me. 
\b  
\q1  
\v 23 Ke mele gbɔwò ɣe sia ɣi, 
\q2 eye nèlé nye ɖusibɔ ɖe asi. 
\q1  
\v 24 Èkplɔm le wò aɖaŋudede nu, 
\q2 eye àkplɔm emegbe ayi wò ŋutikɔkɔe mee. 
\q1  
\v 25 Ame kae le dziƒo nam, negbe wò ko? 
\q2 Naneke mele anyigba si medi kpe ɖe ŋuwò o. 
\q1  
\v 26 Nye ŋutilã kple nye dzi nu ava yi, 
\q2 gake Mawue nye nye dzi ƒe ŋusẽ 
\q2 kple nye gomekpɔkpɔ tegbetegbe. 
\b  
\q1  
\v 27 Ame siwo le adzɔge tso gbɔwò la atsrɔ̃, 
\q2 elabena ètsrɔ̃ ame siwo katã meto nyateƒe na wo o. 
\q1  
\v 28 Ke nye ya la, enyo be mate ɖe Mawu ŋu. 
\q2 Aƒetɔ Yehowae mewɔ nye sitsoƒee, 
\q2 maxlẽ wò nuwɔwɔwo katã afia. 
\c 74  
\cl Psalmo 74 
\d Asaf ƒe nufiameha. 
\q1  
\v 1 O! Mawu, nu ka ŋuti nègble mí ɖi ɖikaa? 
\q2 Nu ka ta wò dɔmedzoe bi ɖe wò alẽ siwo le wò lãnyiƒe ŋuti? 
\q1  
\v 2 Ɖo ŋku ame siwo nèƒle le blema, 
\q2 dukɔ si nye wò domenyinu, 
\q2 ame siwo nèɖe kple Zion, to afi si nènɔ la dzi. 
\q1  
\v 3 Trɔ ɖe gli siwo gbã ɖikaɖika la ŋu, 
\q2 gbegblẽ siawoe futɔ la he va wò teƒe kɔkɔe lae. 
\b  
\q1  
\v 4 Wò futɔwo le gbe ɖem le afi si nèdo go mí le; 
\q2 wova tsi woƒe aflaga ɖe teƒe la be wòanye dzesi anɔ afi ma. 
\q1  
\v 5 Wole nu wɔm abe ŋutsu siwo lé fia ɖe asi 
\q2 le ave dodowo me be woalã atiwo ene. 
\q1  
\v 6 Wotsɔ woƒe fiawo kple yiwo dza aɖaŋu 
\q2 siwo wowɔ ɖe gliawo ŋu. 
\q1  
\v 7 Wotɔ dzo wò kɔkɔeƒe la wòbi va anyigba, 
\q2 eye wodo gu teƒe si wò Ŋkɔ nɔna. 
\q1  
\v 8 Wogblɔ le woƒe dzi me be, 
\q2 “Míagbã wo gudugudu!” 
\q1 Wotɔ dzo teƒe sia teƒe si wosubɔa Mawu le, 
\q2 le anyigba dzi. 
\b  
\q1  
\v 9 Womegawɔa nukunu aɖeke na mí o; 
\q2 womegblẽ nyagblɔɖila aɖeke ɖi o 
\q2 eye mía dometɔ aɖeke menya ɣeyiɣi si nu sia nu ava yi o. 
\q1  
\v 10 O! Mawu, ɣe ka ɣi futɔ la aɖu fewu 
\q2 le ŋuwò ase ɖo? 
\q2 Ɖe ketɔ la ado vlo wò ŋkɔ tegbeea? 
\q1  
\v 11 Nu ka ta nèhe wò asi, wò nuɖusi ɖe megbe ɖo? 
\q2 Ɖe wò asi doe le wò awu te, eye nàtsrɔ̃ wo! 
\b  
\q1  
\v 12 Ke wò la, O Mawu, wòe nye fianye tso blema ke; 
\q2 wòe tsɔ ɖeɖe va anyigba la dzi. 
\b  
\q1  
\v 13 Wòe tsɔ wò ŋusẽ ma atsiaƒu, 
\q2 eye nègbã tɔmelã dziŋɔwo ƒe ta le tsiwo me. 
\q1  
\v 14 Wòe gbã Leviatan ƒe ta, 
\q2 eye nètsɔe wɔ nuɖuɖui na gbemelãwo. 
\q1  
\v 15 Wòe ʋu nu le tsitsetsewo 
\q2 kple tɔʋuwo nu wosi bababa, 
\q2 eye wòe na tɔ siwo sina ɖaa la mie. 
\q1  
\v 16 Ŋkeke nye tɔwò, eye zã hã tɔwòe; 
\q2 wòe wɔ ɣe kple ɣleti. 
\q1  
\v 17 Wòe ɖo liƒo na anyigba, 
\q2 eye wòe wɔ vuvɔŋɔli kple dzomeŋɔli. 
\b  
\q1  
\v 18 O! Yehowa, ɖo ŋku ale si futɔ la do vlo wò 
\q2 kple ale si bometsilawo ɖe alɔme le wò ŋkɔ ŋuti la dzi. 
\q1  
\v 19 Mègatsɔ wò akpakpa ƒe agbe de asi na lãwɔadãwo o, 
\q2 eye mègaŋlɔ wò hiãtɔwo ƒe gbe be ɖikaa o. 
\q1  
\v 20 Tsɔ ɖe le wò nubabla la me, 
\q2 elabena ŋutasesẽ ƒe wɔnawo yɔ anyigba la ƒe ɣaɣlɛƒewo fũu. 
\q1  
\v 21 Mègana ame siwo wote ɖe anyi la 
\q2 nate gbugbɔɖemegbe kple ŋukpe o; 
\q2 ke boŋ ame dahewo kple hiãtɔwo nekafu wò ŋkɔ. 
\q1  
\v 22 O! Mawu, tso eye nàʋli wò bubu ta; 
\q2 ɖo ŋku ale si bometsilawo le alɔme ɖem 
\q2 le ŋuwò ŋkeke blibo lae dzi. 
\q1  
\v 23 Mègado toku wò futɔwo ƒe ʋunyaʋunyawɔwɔ, 
\q2 kple wò ketɔwo ƒe howɔwɔ si le dzi dem ɖaa la o. 
\c 75  
\cl Psalmo 75 
\d Asaf ƒe ha na hɛnɔ la, ne woadzii ɖe “Mègagblẽ nu o” ƒe gbeɖiɖi nu. 
\q1  
\v 1 O! Mawu, míeda akpe na wò, 
\q2 míeda akpe na wò, elabena wò ŋkɔ tsɔ ɖe mía gbɔ, 
\q2 eye amewo le wò nukunuwo xlẽm fia. 
\b  
\q1  
\v 2 Ègblɔ be, “Meɖo ɣeyiɣi da ɖi, 
\q2 elabena nyee adrɔ̃ ʋɔnu le dzɔdzɔenyenye me. 
\q1  
\v 3 Ne anyigba kple edzinɔlawo ʋuʋu kpekpekpe la, 
\q2 nyee léa eƒe sɔtiwo ɖe asi sesĩe. \qs Sela\qs* 
\q1  
\v 4 Megblɔ na ɖokuiŋudzelawo be, 
\q2 ‘Midzudzɔ dada,’ 
\q1 eye na ame vɔ̃ɖi be, 
\q2 ‘Mègakɔ wò dzo ɖe dzi o. 
\q1  
\v 5 Mègakɔ wò dzowo ɖe dzi ɖe dziƒo ŋu o, 
\q2 eye mègahe ve hafi nànɔ nu ƒom o.’ ” 
\b  
\q1  
\v 6 Dodoɖedzi metsoa ɣedzeƒe, 
\q2 ɣetoɖoƒe alo gbegbe vana na ame o, 
\q1  
\v 7 ke boŋ Mawue nye afiatsola, 
\q2 eɖea ame sia le zi dzi, 
\q2 eye wòdoa ame kemɛ ɖe dzi. 
\q1  
\v 8 Kplu aɖe le Yehowa ƒe asi me, 
\q2 wain si lɔ fu ɖe nu, eye wotsɔ nu ʋeʋĩ tɔtɔe la le eme; 
\q1 ekui na ame vɔ̃ɖi siwo le anyigba dzi, 
\q2 wonoe, no ahaƒã si le egɔme la hã ƒiaƒiaƒia. 
\b  
\q1  
\v 9 Ke nye la, manɔ esia gblɔm ɖaa be; 
\q2 madzi kafukafuha na Yakob ƒe Mawu la; 
\q1  
\v 10 maŋe ame vɔ̃ɖiwo ƒe dzowo, 
\q2 ke woado ame dzɔdzɔewo ƒe dzowo ɖe dzi. 
\c 76  
\cl Psalmo 76 
\d Asaf ƒe ha na hɛnɔ la. Woadzii ɖe kasaŋku ŋu. 
\q1  
\v 1 Wonya Mawu le Yuda, 
\q2 eye eƒe ŋkɔ lolo le Israel. 
\q1  
\v 2 Eƒe agbadɔ le Salem, 
\q2 eye eƒe nɔƒe le Zion. 
\q1  
\v 3 Afi ma wòŋe aŋutrɔ bibiwo, 
\q2 akpoxɔnuwo kple yiwo le, nu siwo nye aʋawɔnuwo. \qs Sela\qs* 
\b  
\q1  
\v 4 Keklẽ geɖe ƒo xlã wò, 
\q2 eye nènya kpɔ sãsãsã wu to siwo me adelã le fũu la. 
\q1  
\v 5 Woha kalẽtɔwo, wodɔ woƒe alɔ̃ mamlɛtɔ; 
\q2 aʋawɔla siawo dometɔ ɖeka pɛ 
\q2 hã magate ŋu akɔ eƒe asiwo dzi o. 
\q1  
\v 6 O! Yakob ƒe Mawu, esi nèblu ko la, 
\q2 sɔ kple tasiaɖam siaa tɔ ɖe teƒe ɖeka. 
\b  
\q1  
\v 7 Wò ko wòle be woavɔ̃. 
\q2 Ame ka ate ŋu anɔ te ɖe nuwò ne èdo dɔmedzoe? 
\q1  
\v 8 Èɖe gbeƒã wò afiatsotso tso dziƒo, 
\q2 anyigba vɔ̃, eye wòzi ɖoɖoe. 
\q1  
\v 9 O! Mawu, esi nètso be yeatso afia, 
\q2 aɖe anyigba la ƒe hiãtɔwo la, 
\q2 nu sia nu zi ɖoɖoe. \qs Sela\qs* 
\q1  
\v 10 Vavã, wò dziku helĩhelĩ ɖe amewo ŋu, 
\q2 he kafukafu vɛ na wò, eye ame siwo tsi agbe 
\q2 le wò dziku la megbe la dze akɔ anyi. 
\b  
\q1  
\v 11 Miɖe adzɔgbe na Yehowa, miaƒe Mawu la, 
\q2 eye mixe adzɔgbeɖefeawo; 
\q1 anyigba siwo katã ƒo xlã mi la 
\q2 netsɔ nunanawo vɛ na Ame si wòle be woavɔ̃ la. 
\q1  
\v 12 Etsi dziɖulawo ƒe gbɔgbɔ nu; 
\q2 anyigbadzifiawo katã vɔ̃nɛ. 
\c 77  
\cl Psalmo 77 
\d Asaf ƒe ha na Hɛnɔ Yedutun. 
\q1  
\v 1 Medo ɣli na Mawu be wòaxɔ nam; 
\q2 medo ɣli na Mawu be wòaɖo tom. 
\q1  
\v 2 Esi meɖo xaxa me la, medi Aƒetɔ la; 
\q2 le zã me la, meke nye abɔwo me, gake ɖeɖi mete wo ŋu o, 
\q2 eye nye luʋɔ gbe akɔfafaxɔxɔ. 
\b  
\q1  
\v 3 O! Mawu, meɖo ŋku dziwò, eye meɖe hũu. 
\q2 Mele ŋeŋem, eye nu te nye gbɔgbɔ ŋu. \qs Sela\qs* 
\q1  
\v 4 Èna nye ŋkuwo gbe miamia; 
\q2 fuɖeɖewo sɔ gbɔ ale gbegbe be 
\q2 nyemate ŋu aƒo nu o. 
\q1  
\v 5 Mebu gbe aɖe gbe ŋkekewo 
\q2 kple blemaƒewo ŋu. 
\q1  
\v 6 Tete meɖo ŋku ha siwo medzina le zã me la dzi. 
\q2 Nye dzi gbã, eye nye gbɔgbɔ bia be: 
\b  
\q1  
\v 7 “Ɖe Aƒetɔ la agbe ame tegbetegbea? 
\q2 Ɖe magave ame nu akpɔ oa? 
\q1  
\v 8 Ɖe eƒe lɔlɔ̃ si meʋãna o la vɔ tegbetegbea? 
\q2 Ɖe eƒe ŋugbedodo vɔ hena ɣeyiɣiawo katã? 
\q1  
\v 9 Ɖe Mawu ŋlɔ nublanuikpɔkpɔ bea? 
\q2 Ɖe wòɖo asi eƒe dɔmenyonyo dzi le dɔmedzoe ta?” \qs Sela\qs* 
\b  
\q1  
\v 10 Tete megblɔ be, 
\q2 “Dziƒoʋĩtɔ la ƒe nuɖusi ƒe ƒewo ko maƒo koko na.” 
\q1  
\v 11 Maɖo ŋku Yehowa ƒe nuwɔwɔwo dzi, 
\q2 ɛ̃, maɖo ŋku nukunu siwo nèwɔ le blema la dzi. 
\q1  
\v 12 Made ŋugble le wò dɔwɔwɔwo katã ŋu, 
\q2 eye mabu ta me le wò nuwɔwɔ dzɔatsuwo ŋu. 
\b  
\q1  
\v 13 O! Mawu, wò mɔwo le kɔkɔe 
\q2 mawu kae lolo abe míaƒe Mawu la ene? 
\q1  
\v 14 Wòe nye Mawu si wɔ nukunuwo, 
\q2 eye nèɖe wò ŋusẽ fia le dukɔwo dome. 
\q1  
\v 15 Ètsɔ wò abɔ sesẽ la ɖe wò dukɔ la, 
\q2 ame siwo nye Yakob kple Yosef ƒe dzidzimeviwo. \qs Sela\qs* 
\b  
\q1  
\v 16 O! Mawu, tsiwo kpɔ wò, 
\q2 tsiwo kpɔ wò, eye woŋe, 
\q2 gogloƒewo ke hã dzo nyanyanya. 
\q1  
\v 17 Lilikpo ɖuɖu tsi bababa, 
\q2 dziŋgɔli ɖe gbe, eye wò aŋutrɔwo klẽ dzo bibibi, yi gagbɔ. 
\q1  
\v 18 Wose wò gbeɖeɖe le yali me, 
\q2 wò dzikedzo klẽ ɖe xexea me, 
\q2 eye anyigba ʋuʋu hedzo nyanyanya. 
\q1  
\v 19 Wò mɔ to atsiaƒu me, eye wò toƒe 
\q2 le tɔ gãwo me, gake womekpɔa wò afɔteƒe o. 
\b  
\q1  
\v 20 Èkplɔ wò dukɔ abe alẽha ene, 
\q2 to Mose kple Aron ƒe asiwo dzi. 
\c 78  
\cl Psalmo 78 
\d Asaf ƒe nufiameha. 
\q1  
\v 1 O! Nye dukɔ, mise nye nufiame, 
\q2 eye miɖo to nye numenyawo. 
\q1  
\v 2 Make nye nu, aƒo nu le lododowo me. 
\q2 Magblɔ nu siwo le ɣaɣla, 
\q2 nu siwo li tso blema ke. 
\q1  
\v 3 Nu siwo míese, eye míenya, 
\q2 nu siwo mía fofowo tsɔ tu xoe na mí. 
\q1  
\v 4 Míawo míaɣlae ɖe mía viwo o, 
\q2 ke boŋ míagblɔ Yehowa ƒe dɔwɔwɔ 
\q2 siwo dze na kafukafu, 
\q1 eƒe ŋusẽ kple nukudɔ 
\q2 siwo wòwɔ la na megbeviwo. 
\q1  
\v 5 Ewɔ ɖoɖowo na Yakob, 
\q2 eye wòɖo se anyi ɖe Israel, 
\q1 se siwo ŋu wòde se na 
\q2 mía fofowo be woafia wo viwo, 
\q1  
\v 6 ale be dzidzime megbetɔwo hã nanya wo, 
\q2 eye vi siwo womedzi haɖe o hã nanya wo, 
\q2 ne woawo hã nafia wo viwo. 
\q1  
\v 7 Ekema woatsɔ woƒe mɔkpɔkpɔ ada ɖe Mawu dzi, 
\q2 eye womaŋlɔ eƒe nuwɔwɔwo be o, 
\q2 ke boŋ woalé eƒe sewo me ɖe asi. 
\q1  
\v 8 Ke womanɔ abe wo fofo kɔlialiatɔwo, 
\q2 dzidzime dzeaglã, 
\q1 ame siwo ƒe dzi meku ɖe Mawu ŋu o, 
\q2 eye woƒe gbɔgbɔ meto nyateƒe nɛ o la ene o. 
\b  
\q1  
\v 9 Togbɔ be aŋutrɔwo le Efraimtɔwo si hã la, 
\q2 wotrɔ megbe si dzo le aʋakpegbe. 
\q1  
\v 10 Womelé Mawu ƒe nubabla me ɖe asi o, 
\q2 eye wogbe be yewomanɔ agbe ɖe eƒe se la nu o. 
\q1  
\v 11 Woŋlɔ nu si wòwɔ la be, 
\q2 esiwo nye nukunu siwo wòɖe fia wo. 
\q1  
\v 12 Ewɔ nukunu le wo fofowo ŋkume 
\q2 le Egiptenyigba dzi, 
\q2 le Zoan nuto me. 
\q1  
\v 13 Ema atsiaƒu, hekplɔ wo to emee, 
\q2 eye wòna tsi la tɔ dzɔ kã abe glikpɔ ene. 
\q1  
\v 14 Etsɔ lilikpo kplɔ woe le ŋkeke me, 
\q2 eye wòtsɔ dzo keklẽ kplɔ woe le zã me. 
\q1  
\v 15 Efe agakpe me le gbegbe, 
\q2 eye wòna tsi wo wòsɔ gbɔ 
\q2 abe atsiaƒumetsiwo ene. 
\q1  
\v 16 Ena tsi do tso agakpe me 
\q2 eye tsi la si bababa abe tɔsisiwo ene. 
\b  
\q1  
\v 17 Ke woyi edzi gawɔ nu vɔ̃ ɖe eŋu, 
\q2 eye wodze aglã ɖe Dziƒoʋĩtɔ la ŋu le gbedzi. 
\q1  
\v 18 Wotsɔ woƒe lɔlɔ̃nu te Mawu kpɔ, 
\q2 esi wobia nuɖuɖu si le wo dzrom vevie. 
\q1  
\v 19 Woƒo nu tsi tsitre ɖe Mawu ŋu be, 
\q2 “Ɖe Mawu ate ŋu aɖo kplɔ̃ na mí le gbedzia? 
\q1  
\v 20 Esi wòtsɔ nu ƒo agakpe la, tsi do bababa, 
\q2 eye tɔʋuwo si kplakplakpla. 
\q1 Gake ɖe wòate ŋu ana nuɖuɖu mía? 
\q2 Ate ŋu ana lã eƒe dukɔa?” 
\q1  
\v 21 Esi Yehowa se wo ŋkɔ la, dzi kui vevie; 
\q2 eƒe dzo bi ɖe Yakob ŋu, 
\q2 eye eƒe dɔmedzoe de dzi ɖe Israel ŋu, 
\q1  
\v 22 elabena womexɔ Mawu dzi se, 
\q2 alo ka ɖe eƒe xɔname dzi o. 
\q1  
\v 23 Ke hã la, eɖe gbe na lilikpowo le dzi, 
\q2 eye wòʋu dziƒo ƒe ʋɔtruwo, 
\q1  
\v 24 ena mana dza tso dziƒo na dukɔ la be woaɖu, 
\q2 eye wòna bli wo tso dziƒo. 
\q1  
\v 25 Amegbetɔ ɖu mawudɔlawo ƒe nuɖuɖu, 
\q2 eye wòɖo nuɖuɖu si sinu wohiã la ɖe wo. 
\q1  
\v 26 Etu ka ɣedzeƒeya tso dziƒo, 
\q2 eye wòkplɔ dzigbeya kple eƒe ŋusẽ. 
\q1  
\v 27 Ena lã dza ɖe wo dzi abe ʋuʋudedi ene, 
\q2 eye xe dzodzoewo abe ƒutake ene. 
\q1  
\v 28 Ena woge dze woƒe asaɖa me, 
\q2 eye woƒo xlã woƒe agbadɔwo. 
\q1  
\v 29 Ale woɖui ʋuu heɖi ƒo taŋ, 
\q2 elabena ewɔ nu si dzrom wole la dzi na wo. 
\q1  
\v 30 Ke hafi nuɖuɖu si wodzro la navɔ, 
\q2 eye esi wògale nu me na wo ko la, 
\q1  
\v 31 Mawu ƒe dɔmedzoe bi ɖe wo ŋu; 
\q2 ewu ame sesẽwo le wo dome, 
\q2 eye wòlã Israel ɖekakpuiwo ƒu anyi. 
\b  
\q1  
\v 32 To nu siawo katã gbɔ hã la, 
\q2 wogayi nu vɔ̃ wɔwɔ dzi, 
\q1 eye togbɔ be ewɔ nukunuwo hã la, 
\q2 womexɔe se o. 
\q1  
\v 33 Ale wòna woƒe ŋkekewo wu nu nanekemakpɔkpɔe, 
\q2 eye woƒe ƒewo wu nu le ŋɔdzi me. 
\q1  
\v 34 Ɣe sia ɣi si ke Mawu wu wo ko la, 
\q2 wodinɛ, eye wogatrɔna ɖe eŋu kple vevidodo. 
\q1  
\v 35 Woɖoa ŋku edzi be Mawue nye woƒe Agakpe, 
\q2 eye Mawu Dziƒoʋĩtɔ lae nye woƒe Ɖela. 
\q1  
\v 36 Ke emegbe la, wotsɔa woƒe nu flunɛ, 
\q2 eye wotsɔa woƒe aɖe daa alakpa nɛ. 
\q1  
\v 37 Woƒe dziwo meku ɖe eŋu vavã o, 
\q2 eye womewɔ eƒe nubabla dzi le nyateƒe me o. 
\q1  
\v 38 Gake ekpɔ nublanui na wo; 
\q2 etsɔ woƒe vodadawo ke wo, eye metsrɔ̃ wo o. 
\q1 Zi geɖe la, eɖoa asi eƒe dziku dzi, 
\q2 eye menaa eƒe dɔmedzoe katã bina o. 
\q1  
\v 39 Eɖo ŋku edzi be ŋutilã ko wonye, 
\q2 eye wonye ya si ƒona yina gake megatrɔna gbɔna o. 
\b  
\q1  
\v 40 Zi nenie womedze aglã ɖe eŋu le gbedzi, 
\q2 eye womedo vevesese nɛ le kuɖiɖinyigba dzi o! 
\q1  
\v 41 Enuenu wotea Mawu kpɔna, 
\q2 eye wodoa dziku na Israel ƒe Kɔkɔetɔ la. 
\q1  
\v 42 Womeɖo ŋku eƒe ŋusẽ dzi, 
\q2 gbe si gbe wòɖe wo tso ŋutasẽla ƒe asi me, 
\q1  
\v 43 gbe si gbe wòɖe eƒe nukudzesiwo fia 
\q2 le Egipte kple eƒe nukudɔwo fia le Zoan nuto me o. 
\q1  
\v 44 Etrɔ woƒe tɔsisiwo wozu ʋu, 
\q2 eye womete ŋu no woƒe tɔʋumetsi o. 
\q1  
\v 45 Eɖo togbato ƒe ha gã aɖe ɖe wo dome, 
\q2 woɖu wo kple akpɔkplɔwo wogblẽ woƒe nuwo. 
\q1  
\v 46 Etsɔ woƒe nukuwo na ʋetrawo 
\q2 kple woƒe kutsetsewo na ʋetsuviwo. 
\q1  
\v 47 Egblẽ woƒe waingblewo kple kpetsi, 
\q2 eye woƒe gbotiwo kple tsidzadza sesẽ. 
\q1  
\v 48 Etsɔ woƒe nyihawo na kpetsi, 
\q2 eye wòtsɔ woƒe lãhawo na dzikedzo. 
\q1  
\v 49 Eɖo eƒe dɔmedzoe nyanyra, 
\q2 dziku helĩhelĩ, xaxa kple fuwɔame, 
\q2 siwo nye mawudɔla siwo gblẽa nu la ɖe wo. 
\q1  
\v 50 Eɖe mɔ ɖi na eƒe dɔmedzoe; 
\q2 meɖe woƒe agbe tso ku me o, 
\q2 ke boŋ etsɔ wo de asi na dɔvɔ̃. 
\q1  
\v 51 Ewu Egiptetɔwo ƒe ŋgɔgbevi 
\q2 siwo nye woƒe ŋutsunyenye 
\q2 ƒe kutsetse gbãtɔwo le Ham gbadɔwo te. 
\q1  
\v 52 Gake ekplɔ eƒe dukɔ la abe lãhawo ene, 
\q2 eye wòkplɔ wo abe alẽwo ene to gbedzi. 
\q1  
\v 53 Ekplɔ wo le dedinɔnɔ me, ale be womevɔ̃ o, 
\q2 gake ƒu la tsyɔ woƒe futɔwo dzi. 
\q1  
\v 54 Ale wòkplɔ wo va eƒe anyigba kɔkɔe la ƒe liƒo dzi, 
\q2 va tonyigba si eƒe nuɖusi xɔ la gbɔ. 
\q1  
\v 55 Enya dukɔwo le wo ŋgɔ, 
\q2 eye wòma woƒe anyigba na wo be 
\q1 wòanye woƒe domenyinu, 
\q2 eye wòna Israel ƒe toawo nɔ woƒe aƒewo me. 
\b  
\q1  
\v 56 Ke wote Mawu kpɔ, 
\q2 wodze aglã ɖe Dziƒoʋĩtɔ la ŋu, 
\q2 eye womelé eƒe sewo me ɖe asi o. 
\q1  
\v 57 Abe wo fofowo ene la, 
\q2 womeɖo to o, wowɔ nu dzimaxɔsetɔe, 
\q1 eye wole abe dati doagblɔ ene, 
\q2 elabena womate ŋu aka ɖe wo dzi o. 
\q1  
\v 58 Wotsɔ woƒe nuxeƒewo do dɔmedzoe nɛ, 
\q2 eye woƒe legbawo na ŋuʋaʋã tso le eya amea me. 
\q1  
\v 59 Esi Mawu se wo ŋkɔ la, dzi kui vevie ŋutɔ, 
\q2 eye wògbe Israel keŋkeŋ. 
\q1  
\v 60 Ale wògblẽ agbadɔ si le Silo la ɖi, 
\q2 agbadɔ si wòtu ɖe amegbetɔwo dome. 
\q1  
\v 61 Eɖo nubablaɖaka si nye eƒe ŋusẽ la ɖe aboyome, 
\q2 eye wòtsɔ eƒe atsyɔ̃nu de asi na futɔ la. 
\q1  
\v 62 Etsɔ eƒe dukɔ de asi na yi, 
\q2 eye wòdo dɔmedzoe vevie ɖe 
\q2 eƒe domenyinu la ŋu. 
\q1  
\v 63 Ena dzo fia eƒe ɖekakpuiwo, 
\q2 eye womedzi srɔ̃ɖeha na eƒe ɖetugbiwo o. 
\q1  
\v 64 Wotsɔ woƒe nunɔlawo de asi na yi, 
\q2 eye avi bu ɖe woƒe ahosiwo. 
\b  
\q1  
\v 65 Tete Aƒetɔ la nyɔ tso alɔ̃ me abe ale si aha kɔna 
\q2 le mo na ame si no wain mu la ene. 
\q1  
\v 66 Enya eƒe futɔwo do ɖe megbe, 
\q2 eye wòdo ŋukpe mavɔ wo. 
\q1  
\v 67 Emegbe la, wògbe nu le Yosef ƒe agbadɔwo gbɔ, 
\q2 eye metia Efraim ƒe to la o. 
\q1  
\v 68 Ke boŋ etia Yuda ƒe to la, 
\q2 esi nye Zion to si wòlɔ̃na vevie. 
\q1  
\v 69 Etu eƒe kɔkɔeƒe la abe kɔkɔƒe ene, 
\q2 eye abe anyigba si wòli kee tegbetegbe ene. 
\q1  
\v 70 Etia David dɔla, 
\q2 eye wòɖee le alẽkpo me; 
\q1  
\v 71 tso alẽkplɔdɔ me, eye wòkplɔe vɛ be wòakplɔ eƒe dukɔ, 
\q2 Yakob kple eƒe domenyinu, Israel. 
\q1  
\v 72 David kpɔ wo dzi le dzi dzɔdzɔe me, 
\q2 eye wòkplɔ wo le aɖaŋu me. 
\c 79  
\cl Psalmo 79 
\d Asaf ƒe ha. 
\q1  
\v 1 O! Mawu, dukɔwo nye zi ɖe wò domenyinu la dzi, 
\q2 wodo gu wò gbedoxɔ kɔkɔe la, 
\q2 eye wogbã Yerusalem wòzu anyiglagoe. 
\q1  
\v 2 Wotsɔ wò dɔlawo ƒe kukuawo 
\q2 na dziƒoxewo abe nuɖuɖu ene, 
\q1 eye wotsɔ wò ame kɔkɔeawo ƒe ŋutilã 
\q2 na anyigbadzilã wɔadãwo. 
\q1  
\v 3 Wokɔ woƒe ʋu ɖi abe tsi ene ƒo xlã Yerusalem, 
\q2 eye ame aɖeke meli aɖi ame kukuawo o. 
\q1  
\v 4 Míezu fewuɖunu na míaƒe aƒelikawo, 
\q2 eye míezu alɔmeɖenu kple vlodonu na ame siwo ƒo xlã mí. 
\b  
\q1  
\v 5 O! Yehowa, va se ɖe ɣe ka ɣi? 
\q2 Ɖe nàdo dɔmedzoe tegbeea? 
\q2 Va se ɖe ɣe ka ɣi wò ŋuʋaʋã abi abe dzo ene? 
\q1  
\v 6 Trɔ wò dziku helĩhelĩ la kɔ ɖe dukɔ 
\q2 siwo menya wò o la dzi 
\q2 kple fiaɖuƒe siwo meyɔa wò ŋkɔ o la dzi. 
\q1  
\v 7 Elabena wovuvu Yakob, 
\q2 eye wogbã eƒe denyigba. 
\b  
\q1  
\v 8 Mègawɔ na mí ɖe mía fofowo ƒe nu vɔ̃ nu o; 
\q2 na wò nublanuikpɔkpɔ nava do go mí kaba, 
\q2 elabena míeɖo xaxa gã aɖe me. 
\q1  
\v 9 O! Mawu, mía Ɖela, 
\q2 kpe ɖe mía ŋu le wò ŋkɔ ƒe bubu ta. 
\q1 Ɖe mí, eye nàtsɔ míaƒe nu vɔ̃wo 
\q2 ake mí le wò ŋkɔ la ta. 
\q1  
\v 10 Nu ka ŋuti dukɔwo agblɔ be, 
\q2 “Afi ka woƒe Mawu la le?” 
\b  
\q1 Le míawo ŋutɔ ƒe ŋkume, na dukɔwo nanya be, 
\q2 èbia hlɔ̃ na wò dɔla siwo ƒe ʋu wokɔ ɖi. 
\q1  
\v 11 Aʋaléleawo ƒe ŋeŋe neɖo gbɔwò, 
\q2 tsɔ wò asi ƒe ŋusẽ ɖe 
\q2 ame siwo wotso kufia na. 
\q1  
\v 12 O! Aƒetɔ, ɖo vlo, si míaƒe aƒelikawo 
\q2 do wò la teƒe na wo zi adre. 
\q1  
\v 13 Ekema mí wò dukɔ, 
\q2 wò lãnyiƒe ƒe alẽwo akafu wò tegbee, 
\q1 eye tso dzidzime yi dzidzime 
\q2 míaɖe wò kafukafu afia. 
\c 80  
\cl Psalmo 80 
\d Asaf ƒe ha na hɛnɔ la. Woadzii ɖe “Nubabla ƒe Dzogbenya” ƒe gbeɖiɖi nu. 
\q1  
\v 1 O, Israel ƒe Kplɔla, ɖo to mí, 
\q2 wò ame si kplɔ Yosef ƒe dzidzimeviwo abe lãha ene; 
\q1 wò ame si nɔ anyi ɖe kerubiwo titina gli, 
\q2 klẽ  
\v 2 le Efraim, Benyamin kple Manase ŋgɔ. 
\q1 Nyɔ wò ŋusẽ, 
\q2 va nàxɔ na mí. 
\b  
\q1  
\v 3 O! Mawu, gaɖo mí te; 
\q2 na wò mo naklẽ ɖe mía dzi, 
\q2 be míakpɔ xɔxɔ. 
\b  
\q1  
\v 4 O! Yehowa, Mawu Ŋusẽkatãtɔ, 
\q2 va se ɖe ɣe ka ɣi wò dɔmedzoe abi ɖe 
\q2 wò dukɔ ƒe gbedodoɖa ŋu? 
\q1  
\v 5 Èna aɖatsibolo wo woɖu, 
\q2 eye nèna aɖatsi wo wono taŋtaŋ. 
\q1  
\v 6 Ètsɔ mí wɔ dzrewɔnui na míaƒe aƒelikawo, 
\q2 eye míaƒe futɔwo ɖe alɔme le mía ŋu. 
\b  
\q1  
\v 7 O! Mawu, Ŋusẽkatãtɔ, gaɖo mí te; 
\q2 na wò mo naklẽ ɖe mía dzi, 
\q2 be míakpɔ xɔxɔ. 
\b  
\q1  
\v 8 Ètsɔ wainka tso Egipte, 
\q2 ènya dukɔwo, eye nèdoe. 
\q1  
\v 9 Èdzra eŋuti ɖo nyuie, 
\q2 eye wòto ke hevu tsyɔ anyigba. 
\q1  
\v 10 Edo vɔvɔli ɖe towo tame 
\q2 eye wòɖe alɔ de sedati kɔkɔwo tame. 
\q1  
\v 11 Eɖe alɔ yi ɖe keke ƒuta ke, 
\q2 eye eƒe kewo yi ɖe keke Frat tɔsisi la nu ke. 
\b  
\q1  
\v 12 Nu ka ŋuti nègbã kpɔ le eŋu, 
\q2 ale be ame siwo to afi ma yi la fɔ wain tsetsewo? 
\q1  
\v 13 Gbehawo nya avuzi le edzi, 
\q2 eye gbemelãwo ɖui. 
\q1  
\v 14 Trɔ va mía gbɔ, O Mawu, Ŋusẽkatãtɔ! 
\q2 Do kɔ ɖa tso dziƒo, eye nàkpɔ nu! 
\q1 Kpɔ wainka sia ta, 
\q2  
\v 15 ke si wò nuɖusi do, 
\q2 viŋutsu si wò ŋutɔ nèhe wòtsi. 
\b  
\q1  
\v 16 Wolã wò wainka, 
\q2 wotɔ dzoe, eye wò mokaname na wò amewo tsrɔ̃. 
\q1  
\v 17 Wò asi nenɔ ŋutsu si le wò nuɖusime, 
\q2 amegbetɔvi si nènyi na ɖokuiwò la dzi. 
\q1  
\v 18 Ekema míatrɔ le yowòme o; 
\q2 gbɔ agbe mí, eye míayɔ wò ŋkɔ. 
\b  
\q1  
\v 19 O! Yehowa, Mawu Ŋusẽkatãtɔ, gaɖo mí te; 
\q2 na wò mo nàklẽ ɖe mía dzi be míakpɔ xɔxɔ. 
\c 81  
\cl Psalmo 81 
\d Asaf ƒe ha na hɛnɔ la. Woadzii ɖe \tl gitit\tl* ƒe gbeɖiɖi nu. 
\q1  
\v 1 Midzi ha, mikpɔ dzidzɔ ɖe Mawu, míaƒe ŋusẽ la ŋu, 
\q2 eye mitso aseye kple ɣli ɖe Yakob ƒe Mawu la ŋu! 
\q1  
\v 2 Mido ha ɖa, xatsɛwo neɖi, 
\q2 miƒo kasaŋku kple gakasaŋku siwo ƒe gbe me kɔ. 
\b  
\q1  
\v 3 Miku lãdzokpẽwo le Dzinu Yeye dzi 
\q2 kple ne dzinu sɔ tegblẽe le míaƒe ŋkekenyuiɖugbe. 
\q1  
\v 4 Esia nye se na Israel kple ɖoɖo na Yakob ƒe Mawu la. 
\q1  
\v 5 Esi Mawu tso ɖe Egiptetɔwo ŋu la, 
\q2 eɖoe anyi be wòanye se na Yosef, 
\b  
\q1 afi si míese gbegbɔgblɔ si gɔme míese o la le: 
\b  
\q1  
\v 6 Egblɔ be, “Meɖe agba la ɖa le woƒe abɔta, 
\q2 eye woɖe woƒe asiwo ɖa le kusi la ŋuti. 
\q1  
\v 7 Mieyɔm le miaƒe xaxa me, eye mexɔ na mi. 
\q2 Metɔ na mi le dziɖegbelilikpo la me. 
\q2 Medo mi kpɔ le Meriba tsi la gbɔ. \qs Sela\qs* 
\q1  
\v 8 Mísee, o nye dukɔ, maxlɔ̃ nu mi. 
\q2 O! Israel, nenye ɖe nàɖo tom ɖe! 
\q1  
\v 9 Dzromawu aɖeke maganɔ dowòme o; 
\q2 màgade ta agu na mawu tutɔ aɖeke o. 
\q1  
\v 10 Nyee nye Yehowa, wò Mawu, 
\q2 ame si kplɔ wò do goe tso Egipte. 
\q2 Ke wò nu baa, eye mana wòayɔ. 
\b  
\q1  
\v 11 “Ke nye dukɔ meɖo to nye gbe o; 
\q2 Israel gbe, mebɔbɔ eɖokui nam o, 
\q1  
\v 12 eya ta meɖe asi le wo ŋu na 
\q2 woƒe dzi sesẽwo, ne woadze nu 
\q2 siwo woawo ŋutɔ ɖo la yome. 
\b  
\q1  
\v 13 “Ɖe wònye nye dukɔ aɖo tom, 
\q2 eye Israel nazɔ nye mɔwo dzi la, 
\q1  
\v 14 aleke nyemahabɔbɔ woƒe futɔwo ɖe anyii kaba, 
\q2 eye nyemahakɔ nye asiwo dzi ɖe woƒe ketɔwo ŋui o! 
\q1  
\v 15 Ame siwo lé fu Yehowa la ada alakpa le eŋkume, 
\q2 eye woƒe tohehe anɔ anyi tegbee. 
\q1  
\v 16 Ke míaɖu bliwɔ nyuitɔ, 
\q2 eye matsɔ kpetomenyitsi aɖi ƒoe na mi.” 
\c 82  
\cl Psalmo 82 
\d Asaf ƒe ha. 
\q1  
\v 1 Mawu nɔ zi me na takpekpe gã la, 
\q2 eye wòdrɔ̃ ʋɔnu le “mawuwo” dome. 
\b  
\q1  
\v 2 “Va se ɖe ɣe ka ɣi miaʋli ame baɖa la ta, 
\q2 eye miatso afia ade ame vɔ̃ɖi la dzi?” \qs Sela\qs* 
\q1  
\v 3 “Miʋli ame gblɔewo kple tsyɔ̃eviwo ta, 
\q2 eye miwɔ dɔmenyo na hiãtɔwo kple ame siwo wote ɖe to. 
\q1  
\v 4 Mixɔ na ame gblɔewo kple hiãtɔwo, 
\q2 eye miɖe wo tso ame vɔ̃ɖiwo ƒe asi me. 
\b  
\q1  
\v 5 “Womenya naneke o, womese naneke gɔme o. 
\q2 Wole zɔzɔm le blukɔ me, 
\q2 eye anyigba ƒe agunuwo katã ʋuʋu. 
\b  
\q1  
\v 6 “Megblɔ be, ‘Mawuwoe mienye; 
\q2 mi katã mienye Dziƒoʋĩtɔ la ƒe viŋutsuwo’, 
\q1  
\v 7 gake miaku abe amegbetɔwo ko ene 
\q2 eye miatsi aʋa abe fia ɖe sia ɖe ko ene.” 
\b  
\q1  
\v 8 O! Mawu, tso, eye nàdrɔ̃ ʋɔnu anyigba la 
\q2 elabena dukɔwo katã nye wò domenyinu. 
\c 83  
\cl Psalmo 83 
\d Asaf ƒe ha. 
\q1  
\v 1 O! Mawu, mègazi kpi o, 
\q2 O! Mawu, mègazi ɖoɖoe o, 
\q2 mèganɔ anyi kpoo o. 
\q1  
\v 2 Kpɔ ale si wò futɔwo le nyanyram ɖa, 
\q2 kpɔ ale si wò ketɔwo kɔ ta dzii ɖa. 
\q1  
\v 3 Wole nu baɖa ɖom ɖe wò dukɔ ŋu le ayeme, 
\q2 eye woɖo nugbe ɖe ame siwo nèlɔ̃na la ŋu. 
\q1  
\v 4 Wogblɔ be, “Miva, míatsrɔ̃ wo, be womaganye dukɔ o, 
\q2 eye womagaɖo ŋku Israel ƒe ŋkɔ dzi akpɔ gbeɖe o.” 
\b  
\q1  
\v 5 Wotsɔ tameɖoɖo ɖeka de adaŋu, 
\q2 eye wobla ɖe ŋuwò, 
\q1  
\v 6 ame siwo le Edom ƒe agbadɔwo me, 
\q2 Ismaelitɔwo, Moabtɔwo, Hagritɔwo, 
\q1  
\v 7 Gebalitɔwo, Amonviwo, Amalekitɔwo, 
\q2 Filistitɔwo kple ame siwo tso Tiro. 
\q1  
\v 8 Asiria gɔ̃ hã kpe ɖe wo ŋu, 
\q2 be wòado alɔ Lot ƒe dzidzimeviwo. \qs Sela\qs* 
\b  
\q1  
\v 9 Wɔ wo abe ale si nèwɔ Midian, 
\q2 Sisera kple Yabin le Kison tɔsisi la to ene, 
\q1  
\v 10 ame siwo tsrɔ̃ le Endor, 
\q2 eye wole abe gbeɖuɖɔ ene le anyigba. 
\q1  
\v 11 Wɔ woƒe bubumewo abe Oreb kple Zeb ene, 
\q2 eye woƒe dumegãwo abe Zeba kple Zalmuna ene, 
\q1  
\v 12 ame siwo gblɔ be, 
\q2 “Mina míaxɔ Mawu ƒe lãnyiƒewo.” 
\b  
\q1  
\v 13 O! Nye Mawu, wɔ wo abe betsyo 
\q2 kple blitsa si ya lɔ ɖe nu ene. 
\q1  
\v 14 Abe ale si dzo biaa ave, 
\q2 alo dzo ƒe aɖe tɔa dzo towo ene la, 
\q1  
\v 15 nenemae nàti wo yomee kple wò ya sesẽ, 
\q2 eye nàdo ŋɔdzi na wo kple wò ahom. 
\q1  
\v 16 Tsɔ ŋukpe tsyɔ mo na wo, 
\q2 ale be amewo nadi wò ŋkɔ, O Yehowa. 
\b  
\q1  
\v 17 Na ŋukpe nalé wo, 
\q2 woƒe mo natsi dãa, eye wonetsrɔ̃ le ŋukpe me. 
\q1  
\v 18 Na woanya be wò, ame si ŋkɔe nye Yehowa la, 
\q2 wò koe nye Dziƒoʋĩtɔ la ɖe anyigba blibo la dzi. 
\c 84  
\cl Psalmo 84 
\d Korah ƒe viwo ƒe ha na hɛnɔ la. Woadzii ɖe \tl gitit\tl* ƒe gbeɖiɖi nu. 
\q1  
\v 1 O! Yehowa, Dziƒoʋakɔwo ƒe Aƒetɔ, 
\q2 wò nɔƒe dzeani loo! 
\q1  
\v 2 Yehowa, wò xɔxɔnuwo 
\q2 le nye luʋɔ dzrom kutɔkutɔe. 
\q1 Nye dzi kple ŋutilã 
\q2 le vivi dom ɖe Mawu gbagbe la ŋu. 
\q1  
\v 3 O! Yehowa, Dziƒoʋakɔwo ƒe Aƒetɔ, 
\q2 Fianye kple Mawunye, 
\q1 sagbadre gɔ̃ hã kpɔ nɔƒe, 
\q2 eye atsutsrɔe wɔ atɔ na eɖokui, 
\q1 afi si wòatsɔ viawo ada ɖo, 
\q2 be wòate ɖe wò vɔsamlekpui la ŋu. 
\q1  
\v 4 Woayra ame siwo nɔa wò aƒe me la, 
\q2 elabena wole kafuwòm ɖaa. \qs Sela\qs* 
\b  
\q1  
\v 5 Woayra ame siwo ƒe ŋusẽ le mewò, 
\q2 ame siwo ƒe dzi ku ɖe xɔsemɔzɔzɔ ŋuti. 
\q1  
\v 6 Ne woto Baka Balime la, 
\q2 wowɔnɛ wòzua tsidzɔƒewo, 
\q2 eye kelemetsi tsyɔa edzi kple yayra. 
\q1  
\v 7 Wole azɔli dzi tso ŋusẽ me yi ŋusẽ me va se ɖe 
\q2 esime wo dometɔ ɖe sia ɖe nado ɖe Mawu ŋkume le Zion. 
\b  
\q1  
\v 8 Yehowa, Mawu Ŋusẽkatãtɔ; 
\q2 O! Yakob ƒe Mawu, 
\q2 ɖo to nye gbedodoɖa. \qs Sela\qs* 
\q1  
\v 9 O! Mawu, nye kɔ nàkpɔ míaƒe akpoxɔnu, 
\q2 eye nakpɔ wò amesiamina la kple amenuveve. 
\b  
\q1  
\v 10 Ŋkeke ɖeka le wò xɔxɔnu nyo wu akpe le afi aɖe; 
\q2 enyo be manye agbonudzɔla 
\q1 le Mawu ƒe aƒe me wu be manɔ 
\q2 ame vɔ̃ɖi ƒe agbadɔ me, 
\q1  
\v 11 elabena Yehowa Mawue nye ɣe kple akpoxɔnu. 
\q2 Yehowae naa amenuveve kple bubu, 
\q1 eye metea nu nyui ame siwo fɔɖiɖi 
\q2 mele woƒe zɔzɔme ŋu o. 
\b  
\q1  
\v 12 O! Yehowa, Dziƒoʋakɔwo ƒe Aƒetɔ, 
\q2 woayra ŋutsu si ɖoa dzi ɖe ŋuwò la. 
\c 85  
\cl Psalmo 85 
\d Korah ƒe viwo ƒe ha na hɛnɔ la. 
\q1  
\v 1 O! Yehowa, èɖe amenuveve fia wò anyigba; 
\q2 ègaɖo Yakob ƒe nunyonamewo te. 
\q1  
\v 2 Ètsɔ wò dukɔ la ƒe vodada kee, 
\q2 eye nètsyɔ nu woƒe nu vɔ̃wo katã dzi. \qs Sela\qs* 
\q1  
\v 3 Èɖe asi le wò dzikudodo helĩhelĩ ŋuti 
\q2 eye nèdzudzɔ dɔmedzoe kaɖikaɖi dodo. 
\b  
\q1  
\v 4 O! Mawu, míaƒe Ɖela, gaɖo mí te, 
\q2 míaƒe nu meganɔ dzi kum na wò o. 
\q1  
\v 5 Ɖe nàdo dɔmedzoe ɖe mía ŋu ɖikaa? 
\q2 Ɖe nàdidi wò dɔmedzoe la 
\q2 wòazɔ ato dzidzimewo katã mea? 
\q1  
\v 6 Màgagbɔ agbe mí, 
\q2 be wò dukɔ nàkpɔ dzidzɔ ɖe ŋuwò oa? 
\q1  
\v 7 O! Yehowa, ɖe wò lɔlɔ̃ si meʋãna o la fia mí, 
\q2 eye nàna wò xɔname mí. 
\b  
\q1  
\v 8 Maɖo to ase nya si Yehowa Mawu agblɔ; 
\q2 edo ŋutifafa ƒe ŋugbe na eƒe dukɔ, 
\q1 eƒe ame kɔkɔewo, gake ɖeko mègana 
\q2 woatrɔ ayi bometsitsi gbɔ o. 
\q1  
\v 9 Vavã eƒe ɖeɖe tsɔ ɖe ame siwo vɔ̃nɛ la gbɔ, 
\q2 ale be eƒe ŋutikɔkɔe nanɔ míaƒe anyigba dzi. 
\b  
\q1  
\v 10 Lɔlɔ̃ kple nuteƒewɔwɔ do go wo nɔewo, 
\q2 eye dzɔdzɔenyenye kple ŋutifafa gbugbɔ nu na wo nɔewo. 
\q1  
\v 11 Nuteƒewɔwɔ mie tso anyigba me, 
\q2 eye dzɔdzɔenyenye do mo ɖa kpɔ anyigba tso dziƒo. 
\q1  
\v 12 Yehowa ana nu si nyo la mí vavã, 
\q2 eye míaƒe anyigba atse eƒe ku. 
\q1  
\v 13 Dzɔdzɔenyenye le eŋgɔ, 
\q2 eye wòle mɔ tam na eƒe afɔtoƒewo. 
\c 86  
\cl Psalmo 86 
\d David ƒe gbedodoɖa. 
\q1  
\v 1 Ɖo tom, O Yehowa, eye nàtɔ nam, 
\q2 elabena meda ahe, eye hiã tum. 
\q1  
\v 2 Kpɔ nye agbe ta, 
\q2 elabena metsɔ ɖokuinye na wò. 
\q1 Wòe nye nye Mawu, 
\q2 eya ta ɖe wò dɔla si ɖo dzi ɖe ŋuwò. 
\q1  
\v 3 O! Aƒetɔ, kpɔ nye nublanui, 
\q2 elabena mele yɔwòm ŋkeke blibo la. 
\q1  
\v 4 O! Aƒetɔ, tsɔ dzidzɔ vɛ na wò dɔla, 
\q2 elabena wòe medo nye luʋɔ ɖe dzi na. 
\b  
\q1  
\v 5 O! Aƒetɔ, ènyo, eye nètsɔna kena, 
\q2 lɔlɔ̃ bɔ ɖe asiwò na ame siwo katã yɔa wò. 
\q1  
\v 6 O! Yehowa, se nye gbedodoɖa, 
\q2 eye nàlé to ɖe nye nublanuiɣli ŋu. 
\q1  
\v 7 Le nye xaxagbe, mayɔ wò elabena àtɔ nam. 
\q1  
\v 8 O! Aƒetɔ aɖeke megale mawuawo dome abe wò ene o; 
\q2 nuwɔna aɖeke mesɔ kple tɔwò o. 
\q1  
\v 9 O! Aƒetɔ, dukɔ siwo katã nèwɔ la ava asubɔ 
\q2 le ŋkuwò me, eye woatsɔ ŋutikɔkɔe ana wò ŋkɔ. 
\q1  
\v 10 Elabena èlolo, eye nèwɔ nu dzɔatsuwo; 
\q2 wò koe nye Mawu. 
\b  
\q1  
\v 11 O! Yehowa, fia wò mɔm, 
\q2 eye mazɔ le wò nyateƒe la me; 
\q1 tsɔ dzi si to mɔ ɖeka la nam, 
\q2 ale be mavɔ̃ wò ŋkɔ. 
\q1  
\v 12 Makafu wò, O Aƒetɔ, nye Mawu, 
\q2 kple nye dzi blibo. 
\q2 Mado wò ŋkɔ ɖe dzi tegbee, 
\q1  
\v 13 elabena wò lɔlɔ̃ nam lolo ŋutɔ, 
\q2 eye nèɖem tso keke tsiẽƒe ʋĩi ke. 
\b  
\q1  
\v 14 O! Mawu, dadalawo tso ɖe ŋunye, 
\q2 ŋutasẽlawo ƒe ha ti nye agbe yome, 
\q2 eye wonye ŋutsu siwo mebu wò ɖe naneke me o. 
\q1  
\v 15 O! Aƒetɔ, ke wò la, 
\q2 Mawu si kpɔa nublanui, 
\q1 eye wòvea ame nu lae nènye, 
\q2 mèdoa dɔmedzoe kabakaba o, 
\q2 lɔlɔ̃ bɔ ɖe asiwò, eye nèwɔa nuteƒe. 
\q1  
\v 16 Trɔ ɖe ŋutinye, eye nàkpɔ nublanui nam; 
\q2 na wò ŋusẽ wò dɔla, eye nàɖe viwò ŋutsu nuteƒewɔla. 
\q1  
\v 17 Ɖe wò nyuiwɔwɔ ƒe dzesi fiam, 
\q2 be nye futɔwo nakpɔe, eye ŋu nakpe wo, 
\q2 elabena o Yehowa, wòe kpe ɖe ŋunye, eye nèfa akɔ nam. 
\c 87  
\cl Psalmo 87 
\d Korah ƒe viwo ƒe ha. 
\q1  
\v 1 Eɖo eƒe agunu anyi ɖe to Kɔkɔe la dzi. 
\q1  
\v 2 Yehowa lɔ̃ Zion ƒe agbowo 
\q2 wu Yakob ƒe nɔƒewo katã. 
\b  
\q1  
\v 3 O! Mawu ƒe du, 
\q2 wogblɔ nu nyui geɖewo tso ŋuwò. \qs Sela\qs* 
\q1  
\v 4 “Maŋlɔ Rahab kple Babilon ƒe ŋkɔ ɖe 
\q2 ame siwo nyam la dome, 
\q1 nenema kee nye Filistia kple Tiro hekpe ɖe Kus ŋuti, 
\q2 magblɔ be, ‘Wodzi esia le Zion.’ ” 
\q1  
\v 5 Vavã, woagblɔ le Zion ŋu be, 
\q2 “Wodzi esia kple ekemɛ le afi ma, 
\q2 eye Dziƒoʋĩtɔ la ŋutɔ aɖo egɔme anyi.” 
\q1  
\v 6 Yehowa aŋlɔ ɖe dukɔwo ƒe agbalẽ me be, 
\q2 “Wodzi esia le Zion.” \qs Sela\qs* 
\b  
\q1  
\v 7 Ne wole ha dzim la, woadzi ha be, 
\q2 “Nye agunuwo katã le mewò.” 
\c 88  
\cl Psalmo 88 
\d Korah ƒe viwo ƒe ha na hɛnɔ la. Enye nufiameha si Ezrahitɔ Heman kpa; woadzii ɖe \tl Mahalat Leanot\tl* ƒe gbeɖiɖi nu. 
\q1  
\v 1 O! Yehowa, Mawu si ɖem, 
\q2 mele ɣli dom le ŋkuwò me zã kple keli. 
\q1  
\v 2 Nye gbedodoɖa nede gbɔwò, 
\q2 ƒu to anyi ɖe nye kokoƒoƒo ŋu, 
\q1  
\v 3 elabena nye luʋɔ yɔ fũu kple xaxawo, 
\q2 eye nye agbe ɖo kudo nu. 
\b  
\q1  
\v 4 Wobum ɖe ame siwo yi aʋlime la dome; 
\q2 mele abe ŋutsu si si ŋusẽ mele o la ene. 
\q1  
\v 5 Woɖem ɖe aga da ɖe ame kukuwo dome, 
\q2 eye mele abe ame siwo wowu wole yɔdo me la ene, 
\q1 ame siwo dzi miagaɖo ŋkui o, 
\q2 eye woɖe wo ɖa le wò dzikpɔkpɔ te. 
\b  
\q1  
\v 6 Ètsɔm de ʋe goglotɔ me, 
\q2 yi ɖe keke viviti tsiɖitsiɖi me. 
\q1  
\v 7 Wò dziku helĩhelĩ le dzinye vevie, 
\q2 eye nètsɔ wò ƒutsotsoewo tsyɔ dzinye. \qs Sela\qs* 
\q1  
\v 8 Èxɔ xɔ̃nye veviwo le asinye, 
\q2 eye nètsɔm wɔ ŋunyɔnu na wo. 
\q1 Ètsɔm da ɖe xaxɛƒe, nyemate ŋu asi o, 
\q2  
\v 9 eye nuxaxa wɔe be nye ŋkuwo dzi tsyɔ. 
\b  
\q1 O! Yehowa, mele yɔwòm gbe sia gbe, 
\q2 eye meke nye abɔwo me na wò. 
\q1  
\v 10 Ɖe nàte ŋu aɖe wò nukunuwo afia ame kukua? 
\q2 Ɖe ame siwo ku la ate ŋu atsi tsitre akafu wòa? \qs Sela\qs* 
\q1  
\v 11 Ɖe woaɖe gbeƒã wò lɔlɔ̃ le yɔdo me 
\q2 kple wò nuteƒewɔwɔ le tsiẽƒea? 
\q1  
\v 12 Ɖe woanya nu le wò nukunuwo ŋu le viviti me, 
\q2 alo le wò dzɔdzɔenyenyedɔwo ŋu le anyigba manyamanya dzia? 
\b  
\q1  
\v 13 Ke wò, o Yehowae, 
\q2 mele ɣli dom na be nàxɔ nam, 
\q2 eye le ŋdi me la, nye gbedodoɖa neva gbɔwò. 
\q1  
\v 14 O! Yehowa, nu ka ta nègbem, 
\q2 eye nèɣla wò mo ɖem ɖo? 
\b  
\q1  
\v 15 Tso nye ɖekakpuime ke, mekpe hiã, 
\q2 eye meɖo kudo nu, 
\q1 mekpe fu le wò ŋɔdzidodowo ta, 
\q2 eye dzi ɖe le ƒonye. 
\q1  
\v 16 Wò dziku helĩhelĩ tsyɔ dzinye, 
\q2 eye wò ŋɔdzi gblẽ donyeme. 
\q1  
\v 17 Woƒo xlãm ŋkeke blibo la abe tsiɖɔɖɔ ene, 
\q2 eye wonye tsyɔ dzinye. 
\q1  
\v 18 Èɖe nye zɔhɛwo kple xɔ̃nyewo ɖa le ŋunye, 
\q2 eye vivitie nye xɔ̃nye si tsɔ ɖe gbɔnye. 
\c 89  
\cl Psalmo 89 
\d Ezrahitɔ Etan ƒe nufiameha. 
\q1  
\v 1 Madzi ha le Mawu ƒe lɔlɔ̃ gã la ŋu ɖaa, 
\q1 matsɔ nye nu aɖe gbeƒã wò 
\q2 nuteƒewɔwɔ tso dzidzime yi dzidzime. 
\q1  
\v 2 Maɖe gbeƒã be wò lɔlɔ̃ li ke tegbee, 
\q2 eye nèɖo wò nuteƒewɔwɔ anyi ɖe dziƒo ŋutɔŋutɔ. 
\q1  
\v 3 Ègblɔ be, “Mebla nu kple nye ame tiatia, 
\q2 meka atam na David, nye dɔla be, 
\q1  
\v 4 ‘Maɖo wò ƒome anyi tegbee, 
\q2 eye mana wò fiazikpui nali ke na dzidzimewo katã.’ ” \qs Sela\qs* 
\b  
\q1  
\v 5 O! Yehowa, dziƒowo le wò nukunuwo kafum, 
\q2 kple wò nuteƒewɔwɔ hã 
\q2 le ame kɔkɔewo ƒe hame. 
\q1  
\v 6 Elabena ame kae le dziŋgɔli me 
\q2 si woatsɔ asɔ kple Yehowa? 
\q1 Le nu gbagbe siwo le dziƒo dome la, 
\q2 kae le abe Yehowa ene? 
\q1  
\v 7 Le ame kɔkɔewo ƒe adaŋudeha me la ŋɔdzi le Mawu ŋu ŋutɔ, 
\q2 ŋɔdzi le eŋu wu ame siwo katã ƒo xlãe. 
\q1  
\v 8 O! Yehowa, Dziƒoʋakɔwo ƒe Mawu, ame kae ɖi wò? 
\q2 O! Yehowa, wò la, ŋusẽtɔe nènye, eye wò nuteƒewɔwɔ ƒo xlã wò. 
\b  
\q1  
\v 9 Wòe ɖu atsiaƒu ƒe agbodzedze dzi, 
\q2 ne ƒutsotsoewo le dzi dem la, ènana wodzea akɔ anyi. 
\q1  
\v 10 Ègbã Rahab gudugudu abe 
\q2 ame siwo wowu la dometɔ ɖeka ene, 
\q2 eye nètsɔ wò abɔ sesẽ kaka wò futɔwo. 
\q1  
\v 11 Dziƒowo nye tɔwò, anyigba hã tɔwòe; 
\q2 wòe wɔ xexea me kple emenuwo katã. 
\q1  
\v 12 Wòe wɔ anyiehe kple dziehe; 
\q2 ne Tabɔr kple Hermon se wò ŋkɔ ko la, 
\q2 wodzia ha, tsoa aseye. 
\q1  
\v 13 Wotsɔ ŋusẽ de wò abɔ me, 
\q2 eye wò asi sesẽ, wò nuɖusi de dzi. 
\b  
\q1  
\v 14 Woli wò fiazikpui anyi ɖe dzɔdzɔenyenye kple ʋɔnudɔdrɔ̃ dzi, 
\q2 eye lɔlɔ̃ kple nuteƒewɔwɔ le zɔzɔm le ŋgɔwò. 
\q1  
\v 15 Woayra ame siwo srɔ̃ ale si woakafu wòe, 
\q2 eye wozɔna le wò mo ƒe kekeli me, O Yehowa. 
\q1  
\v 16 Wotsoa aseye le wò ŋkɔ me ŋkeke blibo la, 
\q2 eye wokpɔa dodoɖedzi le wò dzɔdzɔenyenye me. 
\q1  
\v 17 Elabena wòe nye woƒe ŋutikɔkɔe kple ŋusẽ, 
\q2 eye to wò amenuveve me, nèkɔ míaƒe dzo ɖe dzi. 
\q1  
\v 18 Vavã, míaƒe akpoxɔnu nye Yehowa tɔ, 
\q2 miaƒe fia nye Israel ƒe Kɔkɔetɔ la. 
\b  
\q1  
\v 19 Ɣe aɖe ɣi la, èƒo nu na wò 
\q2 ame kɔkɔewo le ŋutega me be, 
\q1 “Metrɔ ŋusẽ kɔ ɖe kalẽtɔ aɖe dzi; 
\q2 medo ɖekakpui aɖe ɖe dzi le nye amewo dome. 
\q1  
\v 20 Meke ɖe David, nye dɔla 
\q2 ŋu, eye mesi ami nɛ kple nye ami kɔkɔe. 
\q1  
\v 21 Nye asi alée ɖe asi, 
\q2 le nyateƒe me, nye alɔ ado ŋusẽe. 
\q1  
\v 22 Futɔ aɖeke mazi edzi wòadzɔ ga nɛ o, 
\q2 eye ame vɔ̃ɖi aɖeke matee ɖe to o. 
\q1  
\v 23 Mafanya eƒe futɔwo le eŋgɔ, 
\q2 eye maƒo ame siwo tso ɖe eŋu la aƒu anyi. 
\q1  
\v 24 Nye lɔlɔ̃ si meʋãna o la anɔ anyi kplii, 
\q2 eye woakɔ eƒe dzo ɖe dzi to nye ŋkɔ dzi. 
\q1  
\v 25 Makɔ eƒe asi dzi ɖe atsiaƒu dzi, 
\q2 eye eƒe nuɖusi ɖe tɔsisiwo dzi. 
\q1  
\v 26 Ayɔm be, ‘Wòe nye Fofonye, nye Mawu, 
\q2 nye Agakpe kple Ɖela.’ 
\q1  
\v 27 Matsɔe awɔ nye ŋgɔgbevi 
\q2 kple fia si wodo ɖe dzi wu 
\q2 le anyigbadzifiawo katã dome. 
\q1  
\v 28 Malé nye lɔlɔ̃ nɛ me ɖe asi ɖaa, 
\q2 eye nye nubabla kplii mada 
\q2 le edzi akpɔ gbeɖe o. 
\q1  
\v 29 Maɖo eƒe ƒome anyi tegbee, 
\q2 eye zi ale si dziƒo li la, 
\q2 nenema ke eƒe fiazikpui hã anɔ anyii. 
\b  
\q1  
\v 30 “Ne viawo gblẽ nye sewo ɖi, 
\q2 eye womewɔ nye ɖoɖowo dzi o, 
\q1  
\v 31 ne woda le nye sedede dzi, 
\q2 eye wogbe nye gbeɖeɖewo dzi wɔwɔ la, 
\q1  
\v 32 ekema matsɔ ati ahe to na woe ɖe 
\q2 woƒe nu vɔ̃wo ta, eye matsɔ ƒoƒo ahe to 
\q2 na wo ɖe woƒe vodadawo ta, 
\q1  
\v 33 gake nyemaxɔ nye lɔlɔ̃ le esi, 
\q2 alo ada le nye nuteƒewɔwɔ dzi o. 
\q1  
\v 34 Nyemagbe nye nubabla la dzi wɔwɔ o, 
\q2 eye nyematrɔ nu si nye nu gblɔ la o. 
\q1  
\v 35 Meta nye kɔkɔenyenye zi ɖeka 
\q2 hena ɣeyiɣiwo katã be, 
\q2 nyemada alakpa na David o. 
\q1  
\v 36 Ke boŋ eƒe ƒome anɔ anyi tegbee, 
\q2 eye eƒe fiazikpui ali ke 
\q2 le nye ŋkume abe ɣe ene. 
\q1  
\v 37 Woaɖoe anyi ɖaa abe ɣleti, 
\q2 ɖasefo nuteƒewɔla si le dziŋgɔli ŋu ene.” \qs Sela\qs* 
\b  
\q1  
\v 38 Gake ègbe, èdo vlo, eye nèdo dɔmedzoe ɖe wò 
\q2 amesiamina ŋu vevie. 
\q1  
\v 39 Ète fli ɖe nu si nèbla kple wò dɔla me, 
\q2 eye nèdo gu eƒe fiakuku, tsɔe ƒu gbe ɖe ke me. 
\q1  
\v 40 Ègbã eƒe gliwo, 
\q2 eye nèwɔ eƒe mɔ sesẽwo wozu aƒedo. 
\q1  
\v 41 Ame siwo katã to afi ma la hae, 
\q2 eye wòzu alɔmeɖenu na eƒe aƒelikawo. 
\q1  
\v 42 Èdo eƒe futɔwo ƒe nuɖusi ɖe dzi, 
\q2 eye nèna eƒe ketɔwo katã tso aseye. 
\q1  
\v 43 Èna eƒe yi nu tsi, eye mèkpe ɖe eŋu 
\q2 le aʋawɔwɔ me o. 
\q1  
\v 44 Èna eƒe ŋutikɔkɔe wu enu, 
\q2 eye nètsɔ eƒe fiazikpui ƒu gbe ɖe anyigba. 
\q1  
\v 45 Èɖe eƒe ɖekakpuimeŋkekewo dzi kpɔtɔ, 
\q2 eye nètsɔ ŋukpe tsyɔ nɛ abe avɔ ene. \qs Sela\qs* 
\b  
\q1  
\v 46 O! Yehowa va se ɖe ɣe ka ɣie? 
\q2 Ɖe nàɣla ɖokuiwò tegbea? 
\q2 Ɣe ka ɣi wò dziku abi abe dzo ene ase ɖo? 
\q1  
\v 47 Ɖo ŋku ale si nye agbe le du dzii la dzi. 
\q2 Tofloko kae nye si, nèwɔ amegbetɔviwo na! 
\q1  
\v 48 Amegbetɔ kae anɔ agbe, eye maku o, 
\q2 alo aɖe eɖokui tso tsiẽƒe ƒe ŋusẽ me? \qs Sela\qs* 
\q1  
\v 49 O! Aƒetɔ, afi ka wò lɔlɔ̃ gã tsãtɔ le, 
\q2 wò lɔlɔ̃ si nye atam nèka na David 
\q2 le wò nuteƒewɔwɔ me la le? 
\q1  
\v 50 Aƒetɔ, ɖo ŋku ale si woɖu fewu le wò dɔla ŋuti 
\q2 kple ale si nye dzi tsɔ dukɔwo ƒe vlodoame la dzi. 
\q1  
\v 51 O! Yehowa, ɖo ŋku vlodoame si wò futɔwo tsɔ 
\q2 le alɔme ɖem le wò amesiamina ƒe 
\q2 afɔɖeɖe ɖe sia ɖe ŋuti la dzi. 
\b  
\b  
\q1  
\v 52 Woakafu Yehowa tegbetegbee! 
\qc Amen, ɛ̃, Amen. 
\c 90  
\ms1 Agbalẽ enelia 
\mr Psalmowo 90–106 
\cl Psalmo 90 
\d Mose, Mawu ƒe ame ƒe gbedodoɖa. 
\q1  
\v 1 Yehowa, wòe nye míaƒe sitsoƒe 
\q2 le dzidzimewo katã me. 
\q1  
\v 2 Hafi towo nava dzɔ, 
\q2 alo hafi nàwɔ anyigba kple xexea me, 
\q2 tso mavɔ me yi ɖe mavɔ me, wò koe nye Mawu. 
\b  
\q1  
\v 3 Ènana amegbetɔwo gatrɔna zua kewɔ, eye nègblɔna be, 
\q2 “O! Amegbetɔviwo, mitrɔ zu kewɔ.” 
\q1  
\v 4 Elabena ƒe akpewo le ŋkuwò me 
\q2 le abe etsɔ ŋkeke si va yi la ene, 
\q2 alo abe ŋudzɔɣi le zã me ene. 
\q1  
\v 5 Èkplɔa amewo dzonae to ku me; 
\q2 wole abe gbe mumu le ŋdi me ene. 
\q1  
\v 6 Togbɔ be emie le ŋdi yeyee hã la, 
\q2 le fiẽ me la, eƒu, eye wòku. 
\b  
\q1  
\v 7 Wò dɔmedzoe la tsrɔ̃ mí 
\q2 eye wò dɔmedzoe do ŋɔdzi na mí. 
\q1  
\v 8 Ètsɔ míaƒe vodadawo ɖo wò ŋkume 
\q2 kple míaƒe nu vɔ̃ siwo míewɔ 
\q2 le ɣaɣlaƒe la ɖo wò mo ƒe kekeli nu. 
\q1  
\v 9 Míaƒe ŋkekewo katã nu va yi le wò dziku ta, 
\q2 eye míewu míaƒe ƒewo nu kple ŋeŋe. 
\q1  
\v 10 Míaƒe agbemeŋkekewo le ƒe blaadre, 
\q2 alo blaenyi, gake ne ŋusẽ gale mía ŋutie nye ema, 
\q1 elabena woƒe didi nye fuɖename kple aɖukliɖuɖu; 
\q2 wo nu va yi kaba, eye míedzo. 
\q1  
\v 11 Ame kae nya wò dɔmedzoe ƒe ŋusẽ? 
\q2 Elabena wò dziku nu sẽ abe ale si woavɔ̃ wòe ene. 
\q1  
\v 12 Fia ale si míaxlẽ míaƒe ŋkekewo dedie la mí, 
\q2 ale be dzi si me dziƒonunya le la nasu mía si. 
\b  
\q1  
\v 13 O! Yehowa, bɔbɔ wò asi! Va se ɖe ɣe ka ɣi? 
\q2 Kpɔ nublanui na wò dɔlawo. 
\q1  
\v 14 Tsɔ wò lɔlɔ̃ si meʋãna o la ɖi ƒoe na 
\q2 mí le ŋdi me, be míadzi ha kple dzidzɔ, 
\q2 eye míatso aseye le míaƒe ŋkekewo katã me. 
\q1  
\v 15 Na míatso aseye, ɖe ŋkeke siwo katã nètu nu kpli mí 
\q2 kple ƒe siwo katã me nèhe fukpekpe va mía dzi la ta. 
\q1  
\v 16 Na woaɖe wò dɔwɔwɔwo afia wò dɔlawo 
\q2 kple wò atsyɔ̃ afia wo viwo. 
\b  
\q1  
\v 17 Aƒetɔ, míaƒe Mawu, na wò amenuveve nanɔ mía dzi, 
\q2 eye nàli ke míaƒe asinudɔwo na mí, ɛ̃, 
\q2 míaƒe asinudɔwo, nàna woali ke nyuie. 
\c 91  
\cl Psalmo 91 
\q1  
\v 1 Ame si nɔ Dziƒoʋĩtɔ la ƒe bebeƒe la 
\q2 agbɔ ɖe eme le Ŋusẽkatãtɔ la ƒe vɔvɔli te. 
\q1  
\v 2 Magblɔ na Yehowa be, “Eyae nye nye sitsoƒe kple nye mɔ sesẽ, 
\q2 nye Mawu si ŋu meku ɖo.” 
\b  
\q1  
\v 3 Vavã, aɖe wò le xevimɔtrela ƒe mɔ 
\q2 kple dɔvɔ̃ dziŋɔ me. 
\q1  
\v 4 Atsɔ eƒe fuwo atsyɔ dziwò, 
\q2 àkpɔ sitsoƒe le eƒe aʋala te, 
\q1 eye eƒe nuteƒewɔwɔ anye wò akpoxɔnu 
\q2 kple mɔxenu aƒo xlã wò. 
\q1  
\v 5 Màvɔ̃ zãmeŋɔdzi alo aŋutrɔ si le ʋɔ lũm le ŋkeke me, 
\q1  
\v 6 dɔvɔ̃ si le tsatsam le viviti me, 
\q2 alo dɔxɔleameŋu si le nu gblẽm le ŋdɔ la o. 
\q1  
\v 7 Akpe adze anyi ɖe axawò, 
\q2 eye akpe ewo ɖe wò nuɖusime, 
\q2 ke wò la, mate ɖe ŋuwò o. 
\q1  
\v 8 Ɖeko nàkpɔe kple wò ŋkuwo, 
\q2 eye àkpɔ ale si woahe to na ame vɔ̃ɖiwoe. 
\b  
\q1  
\v 9 Ne ètsɔ Dziƒoʋĩtɔ la, Yehowa, 
\q2 ame si nye nye sitsoƒe wɔ nɔwòƒee la, 
\q1  
\v 10 ekema dzɔgbevɔ̃e maɖi kpe wò o, 
\q2 eye gbegblẽ mate ɖe wò agbadɔ ŋu o, 
\q1  
\v 11 elabena ade se na eƒe dɔlawo tso ŋutiwò, 
\q2 be woakpɔ tawò le wò mɔwo katã dzi. 
\q1  
\v 12 Woakɔ wò ɖe woƒe asiwo me, 
\q2 be màtsɔ wò afɔ axlã ɖe kpe aɖeke o. 
\q1  
\v 13 Àɖo afɔ dzata kple ƒli dzi, eye ànya avuzi 
\q2 le dzata dziŋɔ kple da vɔ̃ɖi dzi. 
\b  
\q1  
\v 14 Yehowa be, “Maɖee, elabena elɔ̃m, 
\q2 madzɔ eŋu, elabena enya nye ŋkɔ. 
\q1  
\v 15 Ayɔm, eye matɔ nɛ; 
\q2 manɔ anyi kplii le xaxa me, 
\q2 maɖee, eye made bubu eŋuti. 
\q1  
\v 16 Matsɔ agbe didi aɖi ƒo nɛ, 
\q2 eye maɖe nye xɔxɔ afiae.” 
\c 92  
\cl Psalmo 92 
\d Ha si wokpa. Hadzidzi. Na Dzudzɔgbe ŋkeke la. 
\q1  
\v 1 Enyo be woakafu Yehowa, 
\q2 eye woadzi ha na wò ŋkɔ, o Dziƒoʋĩtɔ, 
\q1  
\v 2 ne woaɖe gbeƒã wò lɔlɔ̃ le ŋdi me 
\q2 kple wò nuteƒewɔwɔ le fiẽ me, 
\q1  
\v 3 ɖe ka ewo gakasaŋku 
\q2 kple kasaŋku ƒe gbe vivi nu. 
\b  
\q1  
\v 4 O! Yehowa, èna mekpɔ dzidzɔ le wò nuwɔnawo ta. 
\q2 Medzi ha tso aseye le wò asinudɔwo ta. 
\q1  
\v 5 O! Yehowa, wò dɔwɔwɔwo lolo loo, 
\q2 aleke wò susuwo me goglo ale? 
\q1  
\v 6 Numanyala menya esia o, 
\q2 eye bometsilawo mese egɔme o, 
\q1  
\v 7 be togbɔ be ame vɔ̃ɖi tsi mlɔmlɔmlɔ abe gbe ene, 
\q2 eye nu tovo wɔlawo ƒo se hã la, 
\q2 woatsrɔ̃ wo gbidigbidi. 
\b  
\q1  
\v 8 Ke wò, o Yehowa, woado wò ɖe dzi tegbetegbe. 
\b  
\q1  
\v 9 Vavã, wò futɔwo, o Yehowa, 
\q2 atsrɔ̃ le nyateƒe me, 
\q2 eye nu vlo wɔlawo katã aka ahlẽ gbẽe. 
\q1  
\v 10 Èkɔ nye dzo ɖe dzi abe to tɔ ene, 
\q2 eye nèkɔ ami nyuitɔwo ɖe dzinye. 
\q1  
\v 11 Nye ŋkuwo kpɔ ale si woɖu nye ketɔwo dzii, 
\q2 eye nye towo se ale si wonya avuzi 
\q2 le nye futɔ vɔ̃ɖiwo dzii. 
\b  
\q1  
\v 12 Ame dzɔdzɔewo atsi abe ale si deti tsinae ene, 
\q2 woatsi akɔ abe Lebanon ƒe sedati ene; 
\q1  
\v 13 ati siwo wodo ɖe Yehowa ƒe aƒe me, 
\q2 woatsi nyuie le míaƒe Mawu la ƒe xɔxɔnu. 
\q1  
\v 14 Aleke gbegbe wotsii hã la, 
\q2 woaganɔ tsetsem, eye woƒe aŋgbawo ada ama, eye womalũ xɛ o. 
\q1  
\v 15 Woaɖe gbeƒã be, “Yehowae nye dzɔdzɔetɔ; 
\q2 eyae nye nye Agakpe, eye vɔ̃ɖinyenye aɖeke mele eme o.” 
\c 93  
\cl Psalmo 93 
\q1  
\v 1 Yehowa le fia ɖum, eta gãnyenye, 
\q2 Yehowa ta gãnyenye, eye ŋusẽ le esi. 
\q2 Eli ke xexea me, maʋã o. 
\q1  
\v 2 Woɖo wò fiazikpui anyi tso blema ke, 
\q2 eye nèli tso mavɔ me ke. 
\b  
\q1  
\v 3 Atsiaƒuwo dze agbo, o Yehowa, 
\q2 atsiaƒuwo le ɣli dom, 
\q1 atsiaƒuwo dze agbo, 
\q2 eye woƒe tsotsoewo le ŋeŋem. 
\q1  
\v 4 Ke ètri akɔ wu tɔsisi gãwo ƒe gbeɖeɖe, 
\q2 ètri akɔ wu atsiaƒu ƒe agbodzedze, ɛ̃, 
\q2 Yehowa le dziƒo tri akɔ. 
\b  
\q1  
\v 5 Wò sewo le te goŋgoŋgoŋ; 
\q2 O! Yehowa, kɔkɔenyenye ɖo atsyɔ̃ 
\q2 na wò aƒe ɣeawo katã ɣi. 
\c 94  
\cl Psalmo 94 
\q1  
\v 1 O! Yehowa, Mawu si biaa hlɔ̃, 
\q2 O! Mawu si biaa hlɔ̃, klẽ. 
\q1  
\v 2 Tso, o xexea me ƒe Ʋɔnudrɔ̃la, 
\q2 ɖo nu si dadalawo wɔ la teƒe na wo. 
\q1  
\v 3 O! Yehowa, va se ɖe ɣe ka ɣi 
\q2 ame vɔ̃ɖi la atso aseye? 
\b  
\q1  
\v 4 Wole nya tovowo gblɔm, 
\q2 eye dada yɔ ame vɔ̃ɖiwo katã me fũu. 
\q1  
\v 5 O! Yehowa, wogbã wò dukɔ la nyanyanya, 
\q2 wote wò domenyinu la ɖe to. 
\q1  
\v 6 Wowu ahosiwo kple amedzrowo, 
\q2 eye wowu tsyɔ̃eviwo hã. 
\q1  
\v 7 Wogblɔ be, “Yehowa mele ekpɔm o, 
\q2 Yakob ƒe Mawu la metsɔ ɖeke le eme o.” 
\b  
\q1  
\v 8 Mikpɔ nyuie, mi gegeme siwo le dukɔ la me, 
\q2 mi bometsilawo, ɣe ka ɣi miadze nunya? 
\q1  
\v 9 Ɖe eya ame si wɔ to la mase nu oa? 
\q2 Ɖe eya ame si wɔ ŋku la makpɔ nu oa? 
\q1  
\v 10 Ɖe eya ame si hea to na dukɔwo la mahe to oa? 
\q2 Ɖe eya ame si fiaa nu ame la, ahiã na nunya? 
\q1  
\v 11 Yehowa nya amegbetɔ ƒe susu, 
\q2 eye wònya be tofloko ko wònye. 
\b  
\q1  
\v 12 O, Yehowa, woayra ame si nèhe to na, 
\q2 ame si nèfia nui tso wò se la me, 
\q1  
\v 13 eye nèna gbɔdzɔe tso dzɔgbevɔ̃eŋkekewo me, 
\q2 va se ɖe esime wòɖe ʋe na ame vɔ̃ɖiwo. 
\q1  
\v 14 Elabena Yehowa magbe eƒe dukɔ la o, 
\q2 eye magblẽ eƒe domenyinu ɖi o. 
\q1  
\v 15 Woagaɖo ʋɔnudɔdrɔ̃ anyi ɖe dzɔdzɔenyenye dzi, 
\q2 eye ame siwo katã ƒe dzi to mɔ ɖeka la adze eyome. 
\b  
\q1  
\v 16 Ame ka atso ɖe ame vɔ̃ɖiwo ŋu nam? 
\q2 Ame ka atsi tsitre ɖe nu tovo wɔlawo ŋu ɖe nunye? 
\q1  
\v 17 Ɖe menye Yehowae kpe ɖe ŋunye o la, 
\q2 anye ne eteƒe madidi o la, manɔ ɖoɖoezizi me le tsiẽƒe. 
\q1  
\v 18 Esi medo ɣli be, 
\q2 “Nye afɔ le ɖiɖim” la, wò lɔlɔ̃, 
\q2 O! Yehowa, de megbe nam. 
\q1  
\v 19 Esi dzitsitsi yɔ menye la, 
\q2 wò akɔfaname he dzidzɔ vɛ na nye luʋɔ. 
\b  
\q1  
\v 20 Ɖe fiazikpui madzɔmadzɔ 
\q2 si hea hiãkame vɛ to 
\q2 eƒe sededewo me la ate ŋu ade ha kpli wòa? 
\q1  
\v 21 Wowɔa ɖeka ɖe ame dzɔdzɔewo ŋu, 
\q2 eye wotsoa kufia na ame maɖifɔ. 
\q1  
\v 22 Gake Yehowae nye nye mɔ sesẽ, 
\q2 nye Mawu kple agakpe si nye nye sitsoƒe. 
\q1  
\v 23 Aɖo woƒe nu vɔ̃wo teƒe na wo, 
\q2 eye wòatsrɔ̃ wo le woƒe vɔ̃ɖinyenye ta, ɛ̃, 
\q2 Yehowa, míaƒe Mawu la atsrɔ̃ wo. 
\c 95  
\cl Psalmo 95 
\q1  
\v 1 Miva, mina míatso aseye ɖe Yehowa ŋu, 
\q2 eye míado dzidzɔɣli ɖe míaƒe xɔxɔ ƒe Agakpe la ŋu. 
\q1  
\v 2 Mina míado ɖe eŋkume kple akpedada, 
\q2 eye míadoe ɖe dzi to saŋku kple hadzidzi me. 
\b  
\q1  
\v 3 Elabena Yehowae nye Mawu gã la, 
\q2 eye wònye fiagã si ƒo mawuwo katã ta. 
\q1  
\v 4 Anyigba ƒe gogloƒewo le eƒe asi me, 
\q2 eye towo ƒe tsutsueƒe ke hã nye etɔ. 
\q1  
\v 5 Atsiaƒu hã nye etɔ, 
\q2 elabena eyae wɔe, eye eƒe asie wɔ anyigba ƒuƒui hã. 
\b  
\q1  
\v 6 Miva, mina míabɔbɔ ade ta agu nɛ, 
\q2 eye mina míadze klo ɖe 
\q2 Yehowa, mía Wɔla la ƒe ŋkume. 
\q1  
\v 7 Elabena eyae nye míaƒe Mawu, 
\q2 eye míenye amewo le eƒe lãnyiƒe, 
\q2 kple lãha le eƒe dzikpɔkpɔ te. 
\b  
\q1 Egbe, ne miese eƒe gbe la, 
\q1  
\v 8 migasẽ miaƒe dzi me abe ale si miewɔ le Meriba 
\q2 kple ale si miewɔ gbe ma gbe le Masa le gbea dzi ene o. 
\q1  
\v 9 Afi mae mia fofowo, 
\q2 togbɔ be wokpɔ nu si mewɔ hã la, 
\q2 wodom kpɔ, eye wotem kpɔ le. 
\q1  
\v 10 Medo dɔmedzoe ɖe dzidzime ma ŋu ƒe blaene sɔŋ, 
\q2 megblɔ be, “Wonye ame siwo ƒe dzi tra mɔ, 
\q2 eye womenya nye mɔwo o.” 
\q1  
\v 11 Ale le nye dɔmedzoe me, meka atam be, 
\q2 “Womayi ɖe nye dzudzɔ la me gbeɖe o.” 
\c 96  
\cl Psalmo 96 
\q1  
\v 1 Midzi ha yeye na Yehowa; 
\q2 Mi anyigbawo katã, midzi ha na Yehowa. 
\q1  
\v 2 Midzi ha na Yehowa, mikafu eƒe ŋkɔ; 
\q2 miɖe gbeƒã eƒe xɔxɔ gbe sia gbe. 
\q1  
\v 3 Miɖe eƒe Ŋutikɔkɔefia le dukɔwo dome 
\q2 kple eƒe nukudɔwo fia le anyigbadzitɔwo katã dome. 
\b  
\q1  
\v 4 Elabena Yehowa lolo, 
\q2 eye wòdze kafukafu ŋutɔ; 
\q2 ele be woavɔ̃e wu mawuwo katã. 
\q1  
\v 5 Dukɔwo ƒe mawuwo nye legbawo, 
\q2 ke Yehowae wɔ dziƒowo. 
\q1  
\v 6 Atsyɔ̃ kple gãnyenye le eŋgɔ, 
\q2 eye ŋusẽ kple ŋutikɔkɔe le eƒe kɔkɔeƒe la me. 
\b  
\q1  
\v 7 O! Mi dukɔwo ƒe ƒomewo, 
\q2 mitsɔ ŋutikɔkɔe kple ŋusẽ na Yehowa. 
\q1  
\v 8 Mitsɔ ŋutikɔkɔe si dze eƒe ŋkɔ la nɛ, 
\q2 eye mitsɔ vɔsanuwo va eƒe xɔxɔnuwoe. 
\q1  
\v 9 Misubɔ Yehowa le eƒe kɔkɔenyenye ƒe atsyɔ̃ me, 
\q2 eye anyigba katã nedzo nyanyanya le eŋkume. 
\q1  
\v 10 Migblɔ le dukɔwo dome be, “Yehowae le fia ɖum.” 
\q2 Eɖo xexea me gɔme anyi goŋgoŋgoŋ, mate ŋu aʋã o; 
\q2 eye adrɔ̃ ʋɔnu amewo ameŋkumemakpɔmakpɔtɔe. 
\b  
\q1  
\v 11 Mina dziƒowo natso aseye, anyigba nekpɔ dzidzɔ, 
\q2 atsiaƒu kple emenuwo katã neɖe gbe, 
\q1  
\v 12 eye gbegbe kple emenuwo katã netso aseye. 
\q2 Ekema avemetiwo adzi ha atso aseye; 
\q1  
\v 13 woadzi ha le Yehowa ŋgɔ, elabena egbɔna, 
\q2 eye wògbɔna ʋɔnu drɔ̃ ge. 
\q1 Adrɔ̃ ʋɔnu xexea me le dzɔdzɔenyenye me 
\q2 kple dukɔwo le nyateƒe me. 
\c 97  
\cl Psalmo 97 
\q1  
\v 1 Yehowa le fia ɖum, anyigba nekpɔ dzidzɔ, 
\q2 eye ƒutadu siwo le didiƒe ke la netso aseye. 
\q1  
\v 2 Lilikpowo kple blukɔ tsiɖitsiɖi ƒo xlãe, 
\q2 eye dzɔdzɔenyenye kple afia nyui tsotso nye 
\q2 eƒe fiazikpui ƒe gɔmeɖokpe. 
\q1  
\v 3 Dzo le bibim le eŋgɔ, 
\q2 eye wòle eƒe futɔwo fiam le akpa sia akpa. 
\q1  
\v 4 Eƒe dzikedzo si akaɖi ɖe xexea me, 
\q2 eye anyigba kpɔe heʋuʋu heyeheye. 
\q1  
\v 5 Towo lolo abe yɔkumi ene le Yehowa ŋgɔ, ɛ̃, 
\q2 le anyigba ƒe Aƒetɔ la ŋkume. 
\q1  
\v 6 Dziƒowo le gbeƒã ɖem eƒe dzɔdzɔenyenye, 
\q2 eye dukɔwo katã kpɔ eƒe ŋutikɔkɔe. 
\b  
\q1  
\v 7 Ŋukpe lé aklamakpakpɛsubɔlawo katã, 
\q2 ame siwo tsɔa legbawo ƒoa adegbee, 
\q2 ke misubɔe, mi mawuwo katã! 
\b  
\q1  
\v 8 Zion see, dzi dzɔe, eye Yuda ƒe kɔƒewo hã tso aseye 
\q2 le wò afia nyui tsotsowo ta, o Yehowa. 
\q1  
\v 9 O! Yehowa, wò koe nye Dziƒoʋĩtɔ ɖe anyigba la katã dzi, 
\q2 eye wodo wò ɖe dzi gbɔ mawuwo katã ta sãsãsã. 
\q1  
\v 10 Mi ame siwo lɔ̃a Yehowa la, mitsri vɔ̃, 
\q2 elabena edzɔa etɔ siwo wɔa nuteƒe la ƒe agbe ŋuti, 
\q2 eye wòɖea woƒe agbe tso ame vɔ̃ɖiwo ƒe asi me. 
\q1  
\v 11 Kekeli klẽna ɖe ame dzɔdzɔewo dzi, eye dzidzɔkpɔkpɔ yɔa 
\q2 ame siwo ƒe dzi to mɔ ɖeka la ƒe dziwo me. 
\q1  
\v 12 Mi ame dzɔdzɔewo, mitso aseye le Yehowa me, 
\q2 eye mikafu eƒe ŋkɔ kɔkɔe la. 
\c 98  
\cl Psalmo 98 
\d Hadzidzi. 
\q1  
\v 1 Midzi ha yeye na Yehowa, elabena ewɔ nu dzɔatsuwo; 
\q2 eƒe nuɖusi kple eƒe abɔ kɔkɔe la wɔ ɖeɖedɔ nɛ. 
\q1  
\v 2 Yehowa na wonya eƒe ɖeɖe, eye wòklo nu 
\q2 le eƒe dzɔdzɔenyenye dzi na dukɔwo. 
\q1  
\v 3 Eɖo ŋku eƒe lɔlɔ̃ 
\q2 kple nuteƒewɔwɔ dzi na Israel ƒe aƒe la, 
\q1 eye anyigba ƒe mlɔenu ke hã 
\q2 kpɔ míaƒe Mawu la ƒe ɖeɖe. 
\b  
\q1  
\v 4 Mi anyigbawo katã, 
\q2 mido dzidzɔɣli na Yehowa, 
\q2 migli kple hadzidzi kple saŋkuƒoƒo. 
\q1  
\v 5 Midzi ha na Yehowa kple kasaŋku, 
\q2 mitsɔ kasaŋku, hadzidzi, 
\q1  
\v 6 kpẽkuku kple lãdzokuku 
\q2 kpakple dzidzɔɣli do ɖe Yehowa, fia la ŋkume. 
\b  
\q1  
\v 7 Mina atsiaƒu kple nu siwo katã le eme la nado ɣli, 
\q2 anyigba kple edzinɔlawo katã hã. 
\q1  
\v 8 Mina tɔsisiwo naƒo asikpe, 
\q2 eye towo katã nadzi ha ɖekae le dzidzɔkpɔkpɔ ta. 
\q1  
\v 9 Wonedzi ha le Yehowa ŋkume, 
\q2 elabena eva ʋɔnu drɔ̃ ge anyigba la. 
\q1 Adrɔ̃ ʋɔnu anyigba la le dzɔdzɔenyenye me 
\q2 kple dukɔwo ameŋkumemakpɔmakpɔtɔe. 
\c 99  
\cl Psalmo 99 
\q1  
\v 1 Yehowa le fia ɖum, dukɔwo nedzo nyanyanya, 
\q2 enɔ eƒe fiazikpui dzi gli le kerubiwo dome, 
\q2 anyigba neʋuʋu. 
\q1  
\v 2 Yehowa nye gã le Zion, 
\q2 ekɔ gbɔ dukɔwo katã ta. 
\q1  
\v 3 Wonekafu wò ŋkɔ gã, 
\q2 dziŋɔ la, eya amea le kɔkɔe. 
\b  
\q1  
\v 4 Fia la nye ŋusẽtɔ, 
\q2 elɔ̃a afia nyui tsotso, 
\q1 wò la, èɖo dzɔdzɔenyenye anyi, 
\q2 eye nèwɔ nu si le dzɔdzɔe le Yakob me. 
\q1  
\v 5 Mido Yehowa, míaƒe Mawu la 
\q2 ɖe dzi, eye mide ta agu ɖe eƒe afɔ nu, 
\q2 elabena eya amea le kɔkɔe. 
\b  
\q1  
\v 6 Mose kple Aron le eƒe nunɔlawo dome; 
\q2 Samuel le ame siwo yɔ eƒe ŋkɔ la dome; 
\q2 woyɔ Yehowa ŋkɔ, eye wòtɔ na wo. 
\q1  
\v 7 Eƒo nu na wo tso lilikpo dodo me, 
\q2 eye wolé se kple ɖoɖo siwo wòtsɔ na wo la me ɖe asi. 
\b  
\q1  
\v 8 O! Yehowa, míaƒe Mawu, wòe tɔ na wo; 
\q2 togbɔ be èhe to na wo 
\q1 le woƒe nu tovowo ta hã la, 
\q2 ènye tsɔtsɔke ƒe Mawu na Israel. 
\q1  
\v 9 Mido Yehowa, miaƒe Mawu la ɖe dzi, 
\q2 eye misubɔe le eƒe to kɔkɔe la dzi, 
\q2 elabena Yehowa, míaƒe Mawu la le kɔkɔe. 
\c 100  
\cl Psalmo 100 
\d Hadzidzi Akpedaha. 
\q1  
\v 1 Mi anyigbawo katã, 
\q2 mido dzidzɔɣli ɖe Yehowa ŋu. 
\q1  
\v 2 Misubɔ Yehowa kple dzidzɔ, 
\q2 eye mitsɔ aseyetsohawo do ɖe eŋkume. 
\q1  
\v 3 Minyae be Yehowae nye Mawu. 
\q2 Eyae wɔ mí, eye míenye etɔ, 
\q2 eƒe amewo kple alẽwo le eƒe lãnyiƒe míenye. 
\b  
\q1  
\v 4 Mige ɖe eƒe agbowo me kple akpedada, 
\q2 eƒe xɔxɔnuwo kple kafukafu; 
\q2 mida akpe nɛ, eye mikafu eƒe eŋkɔ. 
\q1  
\v 5 Elabena Yehowa nyo, eye eƒe lɔlɔ̃ li ɖaa; 
\q2 nenema kee eƒe nuteƒewɔwɔ hã nɔa anyi 
\q2 tso dzidzime yi dzidzime. 
\c 101  
\cl Psalmo 101 
\d David ƒe ha. 
\q1  
\v 1 O! Yehowa, madzi ha le wò lɔlɔ̃ 
\q2 kple afia nyui tsotso ŋuti, 
\q2 eye madzi kafukafuha na wò. 
\q1  
\v 2 Makpɔ nyuie be menɔ agbe si ŋu mokaka mele o, 
\q2 eya ta gbe ka gbe nàva asrãm kpɔ? 
\b  
\q1 Mazɔ le aƒenye me 
\q2 kple dzi si ŋuti mokaka mele o. 
\q1  
\v 3 Nyematsɔ nu si me vɔ̃ le la aɖo nye ŋkume o. 
\b  
\q2 Metsri xɔsemanɔsitɔwo ƒe nuwɔnawo, 
\q2 womalé ɖe ŋunye o. 
\q1  
\v 4 Ame siwo ƒe dzi to vo la, ate ɖa xaa tso gbɔnye, 
\q2 kadodo aɖeke mele nye kple nu vɔ̃ɖi dome o. 
\b  
\q1  
\v 5 Made ga nu na ame si ƒo ɖi ehavi ƒe ŋkɔ le bebeme, 
\q2 eye ame si ŋku gã le esi 
\q1 eye wòdana le dzi me la, 
\q2 eya nyematɔ ɖe egbɔ o. 
\b  
\q1  
\v 6 Nye ŋku anɔ nuteƒewɔlawo ŋu 
\q2 le anyigba dzi, be woanɔ anyi kplim. 
\q1 Ame si fɔɖiɖi mele eƒe zɔzɔme ŋu o la, 
\q2 anye nye nunɔla. 
\b  
\q1  
\v 7 Ame si nye ameblela la, manɔ aƒenye me o, 
\q2 eye ame si daa alakpa la matsi tsitre ɖe ŋkunye me o. 
\b  
\q1  
\v 8 Ŋdi sia ŋdi la, mana ame vɔ̃ɖi siwo 
\q2 le anyigba dzi la nazi ɖoɖoe. 
\q1 Maɖe nu tovo wɔla ɖe sia ɖe ɖa 
\q2 le Yehowa ƒe du la me. 
\c 102  
\cl Psalmo 102 
\d Hiãtɔ aɖe ƒe gbedodoɖa, esi nu te eŋu, eye wòfa konyi le Yehowa ŋkume. 
\q1  
\v 1 O! Yehowa, se nye gbedodoɖa, 
\q2 eye nye kokoƒoƒo hena kpekpeɖeŋu neɖo gbɔwò. 
\q1  
\v 2 Mègaɣla wò ŋkume ɖem, 
\q2 ne mele xaxa me o. 
\q1 Trɔ wò to ɖe gbɔnye, 
\q2 eye ne meyɔ wò la, nàtɔ nam kaba. 
\b  
\q1  
\v 3 Elabena nye ŋkekewo nu va yi abe dzudzɔ ene, 
\q2 eye nye ƒuwo xɔ dzo hẽe abe dzokpo ene. 
\q1  
\v 4 Nye dzi xɔ abi, eye wòyrɔ abe gbe ene. 
\q2 Meŋlɔ nye nuɖuɖu gɔ̃ hã be. 
\q1  
\v 5 Le nye ŋeŋe sesĩe ta la, 
\q2 meɖi ku zu ƒu ɖeɖe. 
\q1  
\v 6 Mele abe ʋlukuku si le gbegbe ene, 
\q2 alo abe ʋlukuku si le gli gbagbãwo tome ene. 
\q1  
\v 7 Mele ŋu le aba dzi, 
\q2 eye mele abe xevi si tsi akogo le xɔ tame ene. 
\q1  
\v 8 Nye futɔwo le alɔme ɖem 
\q2 le ŋunye ŋkeke blibo la, 
\q1 eye ame siwo tso ɖe ŋunye 
\q2 la tsɔ nye ŋkɔ wɔ ɖiŋudonui. 
\q1  
\v 9 Elabena meɖu dzowɔ abe nuɖuɖu ene, 
\q2 eye metsɔ aɖatsi tɔtɔ nye nunonoe, 
\q1  
\v 10 le wò dziku helĩhelĩ la ta 
\q2 elabena èdom ɖe dzi, 
\q2 eye nètsɔm ƒu gbe ɖe adzɔge. 
\q1  
\v 11 Nye ŋkekewo le abe fiẽ ƒe vɔvɔli ene, 
\q2 eye meyrɔ abe gbe ene. 
\b  
\q1  
\v 12 O! Yehowa, wò la èle fia ɖum tegbetegbe, 
\q2 eye wò ŋkɔxɔxɔ li tso dzidzime yi dzidzime. 
\q1  
\v 13 Ke wò la àtso, 
\q2 akpɔ nublanui na Zion, 
\q1 elabena ɣeyiɣi de be nàve enu, ɛ̃, 
\q2 ɣeyiɣi ɖoɖi la de. 
\q1  
\v 14 Elabena eƒe kpewo xɔ asi le wò dɔlawo gbɔ, 
\q2 eye eƒe ʋuʋudedi gɔ̃ hã ʋãa 
\q2 nublanuikpɔkpɔ le wo me. 
\q1  
\v 15 Dukɔwo avɔ̃ Yehowa ƒe ŋkɔ, 
\q2 eye anyigbadzifiawo katã ade bubu wò ŋutikɔkɔe ŋu. 
\q1  
\v 16 Elabena Yehowa agbugbɔ Zion atso, 
\q2 eye wòado le eƒe ŋutikɔkɔe me. 
\q1  
\v 17 Aɖo hiãtɔwo ƒe gbedodoɖa ŋu, 
\q2 eye mado vlo woƒe kokoƒoƒo o. 
\b  
\q1  
\v 18 Miŋlɔ esia ɖi hena dzidzime siwo ava dzɔ, 
\q2 ale be ame siwo womedzi haɖe o 
\q2 la nakafu Yehowa be: 
\q1  
\v 19 “Yehowa kpɔ nu tso eƒe kɔkɔeƒe la, 
\q2 eye wòkpɔ anyigba tso dziƒo, 
\q1  
\v 20 be wòase gamenɔlawo ƒe ŋeŋe, 
\q2 eye wòaɖe ga ame siwo wotso kufia na.” 
\q1  
\v 21 Ale woaɖe gbeƒã Yehowa ƒe ŋkɔ le Zion 
\q2 kple eƒe kafukafu le Yerusalem, 
\q1  
\v 22 ne dukɔwo kple fiaɖuƒewo 
\q2 ƒo ƒu be woasubɔ Yehowa. 
\b  
\q1  
\v 23 Eŋe nye ŋusẽ le nye agbemɔ dzi, 
\q2 eye wòɖe nye ŋkekewo dzi kpɔtɔ, 
\q1  
\v 24 eya ta megblɔ be, “O! Nye Mawu, 
\q2 mègakplɔm dzoe le nye ŋkekewo ƒe titina o, 
\q2 wò ame si ƒe ƒewo li tso dzidzime yi dzidzime. 
\q1  
\v 25 Le gɔmedzedzea me la, èɖo anyigba ƒe agunu anyi, 
\q2 eye dziƒowo nye wò asinudɔwɔwɔ. 
\q1  
\v 26 Woatsrɔ̃, ke wò ya ànɔ anyi ɖaa; 
\q2 woanyunyɔ abe avɔ ene, 
\q1 eye àɖɔli wo abe avɔ ene 
\q2 ahatsɔ wo aƒu gbe. 
\q1  
\v 27 Ke wò la, ègale ale si nènɔ, 
\q2 eye wò ƒewo mawu enu akpɔ o. 
\q1  
\v 28 Wò dɔlawo ƒe viwo anɔ ŋkuwò me, 
\q2 eye woaɖo woƒe dzidzimeviwo anyi le ŋkuwò me.” 
\c 103  
\cl Psalmo 103 
\d David ƒe ha. 
\q1  
\v 1 O! Nye luʋɔ, kafu Yehowa; 
\q2 nu siwo katã le menye la, 
\q2 mikafu eƒe ŋkɔ kɔkɔe la. 
\q1  
\v 2 O! Nye luʋɔ, kafu Yehowa, 
\q2 eye mègaŋlɔ nu nyui siwo katã 
\q2 wòwɔ na wò la be o. 
\q1  
\v 3 Ame si tsɔ wò vodadawo katã kea wò, 
\q2 eye wòdaa gbe le wò dɔlélewo katã ŋu. 
\q1  
\v 4 Ame si ɖea wò agbe tso ʋe me, 
\q2 eye wòtsɔa lɔlɔ̃ kple nublanuikpɔkpɔ ɖɔna na wò. 
\q1  
\v 5 Ame si tsɔa nu nyuiwo ɖia ƒo na wò didiwo, 
\q2 ale be wò ɖekakpuinyenye gaɖoa yeye me abe hɔ̃ tɔ ene. 
\b  
\q1  
\v 6 Yehowa lɔ̃a nu dzɔdzɔe wɔwɔ, 
\q2 eye wòtsoa afia na ame siwo katã wote ɖe anyi. 
\b  
\q1  
\v 7 Ena Mose nya eƒe mɔwo, 
\q2 eye wòna Israelviwo nya eƒe nuwɔwɔwo. 
\q1  
\v 8 Yehowa kpɔa nublanui, eye wòvea ame nu, 
\q2 medoa dɔmedzoe kabakaba o, eye lɔlɔ̃ bɔ ɖe esi. 
\q1  
\v 9 Metsɔa nya ɖe ame ŋu ɣe sia ɣi, 
\q2 alo léa dɔmedzoe ɖi ɖikaa o. 
\q1  
\v 10 Mewɔna na mí ɖe míaƒe nu vɔ̃wo nu, 
\q2 alo ɖoa eteƒe na mí ɖe míaƒe vodadawo nu o. 
\q1  
\v 11 Elabena abe ale si dziƒo kɔ tso anyigba gbɔe ene la, 
\q2 nenemae eƒe lɔlɔ̃ loloe na ame siwo vɔ̃nɛ. 
\q1  
\v 12 Abe ale si ɣedzeƒe didii tso ɣetoɖoƒe gbɔ ene la, 
\q2 nenemae wòte míaƒe dzidadawo ɖa tso mía gbɔe. 
\b  
\q1  
\v 13 Abe ale si fofo ƒe dɔ me trɔna ɖe viawo ŋuti ene la, 
\q2 nenemae Yehowa kpɔa nublanui na ame siwo vɔ̃nɛ, 
\q1  
\v 14 elabena enya ale si wowɔ mí, 
\q2 eye eɖo ŋku edzi be ʋuʋudedi ko míenye. 
\q1  
\v 15 Amegbetɔ ƒe ŋkekewo le abe gbe ene, 
\q2 edzena abe seƒoƒo le gbedzi ene; 
\q1  
\v 16 ya ƒona toa edzi, eye meganɔa anyi o, 
\q2 womegaɖoa ŋku eteƒe gɔ̃ hã dzi o. 
\q1  
\v 17 Gake tso mavɔ me yi ɖe mavɔ me, Yehowa ƒe lɔlɔ̃ li 
\q2 kple ame siwo vɔ̃nɛ, eye eƒe dzɔdzɔenyenye nɔa anyi 
\q2 kple wo viwo ƒe viwo 
\q1  
\v 18 kpakple ame siwo léa eƒe nubabla me ɖe asi, 
\q2 eye woɖoa ŋku edzi wɔna ɖe eƒe sewo dzi. 
\b  
\q1  
\v 19 Yehowa ɖo eƒe fiazikpui anyi ɖe dziƒo, 
\q2 eye eƒe fiaɖuƒe le wo katã dzi ɖum. 
\b  
\q1  
\v 20 Mi eƒe dɔlawo, mikafu Yehowa, 
\q2 mi ŋusẽtɔ siwo wɔa eƒe lɔlɔ̃nu, 
\q2 eye miewɔa eƒe nya dzi. 
\q1  
\v 21 Mikafu Yehowa, 
\q2 mi eƒe dziƒoʋakɔwo katã, 
\q2 mi eƒe dɔla siwo wɔa eƒe lɔlɔ̃nu. 
\q1  
\v 22 Mikafu Yehowa, 
\q2 mi eƒe dɔwɔwɔwo katã, 
\q2 le afi sia afi, le eƒe dziɖuɖu te. 
\b  
\q1 O! Nye luʋɔ, kafu Yehowa. 
\c 104  
\cl Psalmo 104 
\q1  
\v 1 O! Luʋɔnye, kafu Yehowa. 
\b  
\q1 O! Yehowa, nye Mawu, èlolo loo; 
\q2 èɖo atsyɔ̃, eye nèta gãnyenye. 
\b  
\q1  
\v 2 Etsyɔ kekeli abe avɔ ene, 
\q2 ehe dziƒo me abe avɔgbadɔ ene, 
\q1  
\v 3 eye wòɖo eƒe dziƒoxɔwo ƒe sɔtiwo 
\q2 ƒe agunu anyi ɖe woƒe tsiwo dzi. 
\q1 Etsɔ lilikpowo wɔ eƒe tasiaɖam, 
\q2 eye wònɔ ya ƒe aʋalawo dzi. 
\q1  
\v 4 Yae nye eƒe dɔtsɔlawo, 
\q2 eye dzo ƒe aɖewo nye eƒe dɔlawo. 
\b  
\q1  
\v 5 Eɖo anyigba anyi ɖe eƒe gɔmeɖokpe dzi, 
\q2 eya ta maʋã akpɔ gbeɖe o. 
\q1  
\v 6 Ètsɔ gogloƒewo tsyɔ nɛ abe avɔ ene, 
\q2 eye tsiawo tɔ ɖe toawo tame. 
\q1  
\v 7 Ke esi nèblu la, tsiawo si, 
\q2 eye esi nèɖe gbe la, wolé du tsɔ. 
\q1  
\v 8 Wosi to towo tame, 
\q2 heva to balimewo, va ɖo teƒe si nètia na wo la. 
\q1  
\v 9 Èɖo liƒo si dzi womate ŋu adze to o la na wo, 
\q2 eye womagakaka axɔ anyigba dzi akpɔ gbeɖe o. 
\b  
\q1  
\v 10 Ena tsitsetsewo kɔ ɖe agawo me, 
\q2 eye wosi to towo dome. 
\q1  
\v 11 Wonaa tsi gbemelãwo, 
\q2 eye wotsia gbetedziwo ƒe tsikɔwuame nu. 
\q1  
\v 12 Dziƒoxeviwo wɔa atɔ ɖe tsisisiawo to, 
\q2 eye wodzia ha le atilɔwo dzi. 
\q1  
\v 13 Edea tsi towo tso eƒe xɔ dzigbemetɔ me; 
\q2 eƒe dɔ ƒe kutsetse ɖia ƒo na anyigba. 
\q1  
\v 14 Ena gbe mie na nyihawo, 
\q2 eye wòƒãa nuku na amegbetɔ be wòaxa, 
\q2 ale wòna nuɖuɖu do tso anyigba la me na wo; 
\q1  
\v 15 wain si doa dzidzɔ na ame ƒe dzi, 
\q2 ami si ana be eƒe mo nanɔ keklẽm 
\q2 kple abolo si alé eƒe dzi ɖe te. 
\q1  
\v 16 Wode tsi Yehowa ƒe atiawo nyuie, 
\q2 Lebanon ƒe sedati siwo wòdo. 
\q1  
\v 17 Afi mae xeviwo wɔ woƒe atɔwo ɖo, 
\q2 eye aŋɔɣi wɔ eƒe nɔƒe ɖe gbotiwo me. 
\q1  
\v 18 To kɔkɔwo nye gbemegbɔ̃wo tɔ, 
\q2 eye agakpewo tome zu bebeƒe na hlɔ̃madɛwo. 
\b  
\q1  
\v 19 Ɣleti dea vovototo ɣeyiɣiwo dome, 
\q2 eye ɣe nya ɣeyiɣi si wòaɖo to. 
\q1  
\v 20 Ètsɔ viviti vɛ, eye wòzu zã, ale lã siwo katã 
\q2 le ave me la doa go. 
\q1  
\v 21 Dzatawo ɖea gbe na nuléle, 
\q2 eye wodia woƒe nuɖuɖu tso Mawu gbɔ. 
\q1  
\v 22 Ɣe dzena, eye wotrɔna dzona ɖamlɔa woƒe dowo me. 
\q1  
\v 23 Tete ame do go yi dɔ me, 
\q2 yi ɖe eƒe dɔ gbɔ va se ɖe fiẽ. 
\b  
\q1  
\v 24 O! Yehowa, wò dɔwɔwɔwo sɔ gbɔ loo! 
\q2 Èwɔ wo katã le nunya deto me, 
\q2 anyigba dzi yɔ fũu kple wò nuwɔwɔwo. 
\q1  
\v 25 Atsiaƒue nye ekem, elolo hekeke, 
\q2 lã siwo mele xexlẽme o la yɔe, 
\q1 nenema kee nye nu gbagbe bubuwo hã, 
\q2 suewo kple gãwo siaa. 
\q1  
\v 26 Meliwo zɔa edzi yina, 
\q2 gagbɔna, eye afii mae boso si nèwɔ la hã le. 
\b  
\q1  
\v 27 Esiawo katã le asiwò nu kpɔm be 
\q2 nàna nuɖuɖu yewo le wo naɣi. 
\q1  
\v 28 Ne èna wo la, woƒonɛ ƒu; 
\q2 eye ne èʋu wò asi la, ètsɔa nu nyui ɖia ƒo na wo. 
\q1  
\v 29 Ke ne èɣla wò mo la, 
\q2 ŋɔdzi léa wo, eye ne èxɔ woƒe gbɔgbɔ le wo si la, 
\q2 wokuna, trɔna zua kewɔ. 
\q1  
\v 30 Ne èdɔ wò Gbɔgbɔ ɖa la, 
\q2 wodzɔna, eye nèwɔa anyigba ƒe ŋkume yeyee. 
\b  
\q1  
\v 31 Yehowa ƒe ŋutikɔkɔe nenɔ anyi tegbee. 
\q2 Yehowa nekpɔ dzidzɔ le eƒe dɔwɔwɔwo ŋu, 
\q1  
\v 32 eya ame si do mo ɖe anyigba dzi, eye anyigba dzo nyanyanya; 
\q2 eya ame si ka asi towo ŋu, eye wotu dzudzɔ. 
\b  
\q1  
\v 33 Madzi ha na Yehowa le nye agbemeŋkekewo katã me, 
\q2 eye zi ale si mele agbe la, 
\q2 madzi kafukafuha na nye Mawu la. 
\q1  
\v 34 Nye ŋugbledede nedze eŋu, 
\q2 esi mele dzidzɔ kpɔm le Yehowa me. 
\q1  
\v 35 Ke nu vɔ̃ wɔlawo netsrɔ̃ ɖa le anyigba dzi, 
\q2 eye ame vɔ̃ɖiwo maganɔ anyi o. 
\b  
\q1 O! Luʋɔnye, kafu Yehowa. 
\b  
\q1 Mikafu Yehowa. 
\c 105  
\cl Psalmo 105 
\q1  
\v 1 Mida akpe na Yehowa, 
\q2 miyɔ eƒe ŋkɔ, eye miɖe gbeƒã nu 
\q2 siwo wòwɔ la le dukɔwo dome. 
\q1  
\v 2 Midzi ha nɛ, midzi kafukafuha nɛ, 
\q2 miɖe gbeƒã eƒe nukunuwɔwɔwo. 
\q1  
\v 3 Miƒo adegbe le eƒe ŋkɔ kɔkɔe la ŋu, 
\q2 mina ame siwo dia Yehowa la ƒe dzi natso aseye. 
\q1  
\v 4 Midi Yehowa, mibia eƒe ŋusẽ, 
\q2 midi eƒe ŋkume ɖaa. 
\b  
\q1  
\v 5 Miɖo ŋku nukunu siwo wòwɔ, 
\q2 eƒe dzesiwo kple eƒe ʋɔnudɔdrɔ̃wo dzi. 
\q1  
\v 6 O! Eƒe dɔla Abraham ƒe dzidzimeviwo. 
\q2 O! Yakob ƒe viwo, ame siwo wòtia. 
\q1  
\v 7 Eyae nye Yehowa, míaƒe Mawu la, 
\q2 eƒe ʋɔnudɔdrɔ̃ xɔ anyigba la katã dzi la me. 
\b  
\q1  
\v 8 Eɖoa ŋku eƒe nubabla 
\q2 kple se siwo wòde 
\q2 na dzidzime akpewo la dzi ɖaa, 
\q1  
\v 9 eyae nye nu si wòbla kple Abraham 
\q2 kple atam si wòka na Isak. 
\q1  
\v 10 Eɖo kpe edzi na Yakob abe sedede ene, 
\q2 eye na Israel abe nubabla mavɔ ene be, 
\q1  
\v 11 “Wòe matsɔ Kanaanyigba la na, 
\q2 abe wò domenyinu ene.” 
\b  
\q1  
\v 12 Ke esi wonye ame ʋɛ aɖewo ko, 
\q2 womesɔ gbɔ o, 
\q2 eye wonye amedzrowo le anyigba dzi la, 
\q1  
\v 13 wotsa tso dukɔ me yi dukɔ me, 
\q2 tso fiaɖuƒe ɖeka me yi bubu me. 
\q1  
\v 14 Meɖe mɔ be ame aɖeke nate wo ɖe anyi o, 
\q2 le wo ta, wòka mo na fiawo be, 
\q1  
\v 15 “Migaka asi nye amesiaminawo ŋu o, 
\q2 eye migawɔ nu vevi nye nyagblɔɖilawo o.” 
\b  
\q1  
\v 16 Ena dɔ to ɖe anyigba la dzi, 
\q2 eye wògblẽ woƒe nuɖuɖukpɔtsoƒewo katã, 
\q1  
\v 17 ke edɔ ŋutsu aɖe si woyɔna be Yosef, 
\q2 ame si wodzra abe kluvi ene la ɖe wo ŋgɔ. 
\q1  
\v 18 Wode kunyowu afɔ nɛ, 
\q2 wode abi eŋu, eye wotsɔ gakɔsɔkɔsɔ de kɔ nɛ, 
\q1  
\v 19 va se ɖe esime nya si wògblɔ ɖi la va eme, 
\q2 eye va se ɖe esime Yehowa ƒe nya 
\q2 naɖo kpe edzi, be nya si wògblɔ la nye nyateƒe. 
\q1  
\v 20 Fia la dɔ ame woyi ɖaɖee le game, 
\q2 eye dukɔ la dziɖula na ablɔɖee. 
\q1  
\v 21 Etsɔe ɖo amegãe ɖe eƒe aƒe nu, 
\q2 eye wònye eƒe nunɔamesiwo katã dzikpɔla, 
\q1  
\v 22 be wòade dɔ asi na eƒe dɔnunɔlawo ale si dze eŋu, 
\q2 eye wòafia nunya eƒe dumegãwo. 
\b  
\q1  
\v 23 Ale Israel ge ɖe Egiptenyigba dzi, 
\q2 eye Yakob nɔ Hamnyigba dzi abe amedzro ene. 
\q1  
\v 24 Yehowa na eƒe dukɔ la dzi ɖe edzi, 
\q2 eye wòna wosɔ gbɔ fũu akpa na woƒe futɔwo, 
\q1  
\v 25 ame siwo ƒe dzi wòtrɔ be woalé fu eƒe dukɔ la, 
\q2 eye woaɖo nugbe ɖe eƒe dɔlawo ŋu. 
\q1  
\v 26 Edɔ Mose, eƒe dɔla kple Aron, eƒe ame tiatia ɖa. 
\q1  
\v 27 Wowɔ eƒe dzesi gãwo le wo dome 
\q2 kple eƒe nukunuwo le Hamnyigba dzi. 
\q1  
\v 28 Eɖo viviti ɖa, eye anyigba la dzi do blukɔ 
\q2 elabena ɖe wometsi tsitre ɖe eƒe nyawo ŋu oa? 
\q1  
\v 29 Ena woƒe tsiwo trɔ zu ʋu, 
\q2 eye to esia me woƒe tɔmelãwo ku. 
\q1  
\v 30 Ena woƒe anyigba la dzi yɔ fũu kple akpɔkplɔwo, 
\q2 esiwo ge ɖe woƒe dumegãwo ƒe xɔgãwo me ke. 
\q1  
\v 31 Eƒo nu, eye tagbatsutsu kple togbato ƒe ha gã aɖe va xɔ 
\q2 woƒe dukɔ la katã me. 
\q1  
\v 32 Etrɔ woƒe tsidzadza wòzu kpetsi, 
\q2 eye dzikedzo kpe ɖe eŋuti 
\q2 le woƒe anyigba blibo la dzi. 
\q1  
\v 33 Eƒo woƒe wainkawo kple gbotiwo ƒu anyi, 
\q2 eye wòmu ati siwo le woƒe dukɔ me la ƒu anyi. 
\q1  
\v 34 Eƒo nu, eye ʋetsuviwo va ƒo ɖi, 
\q2 nenema kee nye abɔ gbogbo aɖewo hã; 
\q1  
\v 35 woɖu numiemie mumu ɖe sia ɖe le woƒe anyigba la dzi, 
\q2 eye woɖu nuku ɖe sia ɖe si le bo dzi hã. 
\q1  
\v 36 Emegbe la, eƒo ŋgɔgbevi siwo katã 
\q2 le woƒe anyigba dzi la ƒu anyi, 
\q2 esiwo nye woƒe ŋutsunyenye ƒe kutsetse gbãtɔwo. 
\q1  
\v 37 Ke ekplɔ Israel do goe, wodo agba kple klosalo kple sika, 
\q2 eye ame beli aɖeke menɔ woƒe toawo dome o. 
\q1  
\v 38 Egipte kpɔ dzidzɔ esi wodo go dzo, 
\q2 elabena Israel ƒe ŋɔdzi lé wo. 
\b  
\q1  
\v 39 Ekeke lilikpo ɖe wo dzi abe avɔ ene, 
\q2 eye wòna dzo wo be wòanye akaɖi na wo le zã me. 
\q1  
\v 40 Wobiae, eye wòna tegliwo woɖu, 
\q2 eye wòtsɔ dziƒobolo ɖi ƒo na woe. 
\q1  
\v 41 Eʋu agakpe la, tsi do na wo bababa, 
\q2 eye wòsi to gbegbe la abe tɔsisi ene. 
\b  
\q1  
\v 42 Elabena eɖo ŋku eƒe ŋugbe kɔkɔe si wòdo na 
\q2 eƒe dɔla Abraham la dzi. 
\q1  
\v 43 Ekplɔ eƒe dukɔ la do goe kple aseyetsotso, 
\q2 eƒe ame tiatiawo kple dzidzɔɣli. 
\q1  
\v 44 Etsɔ dukɔwo ƒe anyigbawo na wo, 
\q2 eye nu si ame bubuwo ku kutri kpɔ la 
\q2 va zu domenyinu na wo. 
\q1  
\v 45 Ale be woalé eƒe ɖoɖowo me ɖe asi, 
\q2 eye woawɔ eƒe sewo dzi. 
\b  
\q1 Mikafu Yehowa. 
\c 106  
\cl Psalmo 106 
\q1  
\v 1 Mikafu Yehowa. 
\b  
\q1 Mida akpe na Yehowa, 
\q2 elabena eƒe dɔ me nyo, eye eƒe lɔlɔ̃ li ɖaa. 
\b  
\q1  
\v 2 Ame kae ate ŋu aɖe gbeƒã Yehowa ƒe nu dzɔatsu 
\q2 siwo wòwɔ alo akafui wòade go? 
\q1  
\v 3 Woayra ame siwo léa dzɔdzɔenyenye me ɖe asi, 
\q2 ame siwo wɔa nu si nyo la ɣe sia ɣi. 
\b  
\q1  
\v 4 O! Yehowa, ɖo ŋku dzinye ne èle wò dukɔ la nu vem, 
\q2 va kpe ɖe ŋunye ne èle wo ɖem, 
\q1  
\v 5 be nye hã makpɔ gome le wò ame tiatiawo ƒe dzidzedzekpɔkpɔ me, 
\q2 be makpɔ dzidzɔ kple wò dukɔ la, 
\q2 eye mawɔ ɖeka kple wò domenyinu la, akafu wò. 
\b  
\q1  
\v 6 Míewɔ nu vɔ̃ abe mía fofowo ke ene; 
\q2 míewɔ nu tovo, eye míewɔ nu vɔ̃ɖi. 
\q1  
\v 7 Esi mía fofowo nɔ Egipte la, 
\q2 womebu wò nukunuwo ŋu o; 
\q2 womeɖo ŋku wò dɔmenyo gbogboawo dzi o, 
\q1 ke boŋ wodze aglã le ƒu la to, 
\q2 le Ƒu Dzĩ la to, 
\q1  
\v 8 gake eɖe wo le eƒe ŋkɔ la ta, 
\q2 be wòana woanya eƒe ŋusẽ triakɔ la. 
\q1  
\v 9 Eblu ɖe Ƒu Dzĩ la ta, eye wòmie; 
\q2 ale wòkplɔ wo to ƒugɔme abe tagba ƒuƒui ene. 
\q1  
\v 10 Eɖe wo tso futɔ la ƒe asi me, 
\q2 eye ketɔ la ƒe asimee wòxɔ wo le. 
\q1  
\v 11 Tsi la ŋe tsyɔ wo yometilawo dzi, 
\q2 eye ɖeka pɛ gɔ̃ hã metsi agbe o. 
\q1  
\v 12 Tete woxɔ eƒe ŋugbedodowo dzi se, 
\q2 eye wodzi ha kafui. 
\b  
\q1  
\v 13 Kasia woŋlɔ nu si wòwɔ la be xoxo, 
\q2 eye womelala xɔ aɖaŋu tso egbɔ o. 
\q1  
\v 14 Le gbea dzi la, wodzro nu vevie, 
\q2 eye le gbegbe la, wote Mawu kpɔ. 
\q1  
\v 15 Ale wòtsɔ nu si biam wole la na wo, 
\q2 gake eɖo dɔvɔ̃ ɖe wo dome. 
\b  
\q1  
\v 16 Woʋã ŋu Mose kple Aron le asaɖa la me, 
\q2 ame si ŋuti wokɔ na Yehowa. 
\q1  
\v 17 Anyigba ke nu mi Datan, 
\q2 eye wòɖi Abiram kple eyomedzelawo agbagbe. 
\q1  
\v 18 Dzo va fia wo yomedzelawo, 
\q2 eye dzo ƒe aɖewo fia ame vɔ̃ɖiawo. 
\q1  
\v 19 Wowɔ nyivi le Horeb to la gbɔ, 
\q2 eye wosubɔ legba si wowɔ kple ga. 
\q1  
\v 20 Wotsɔ woƒe Ŋutikɔkɔe ɖɔli nyitsu si ɖua gbe. 
\q1  
\v 21 Woŋlɔ Mawu si ɖe wo la be, 
\q2 Mawu si wɔ nu gãwo na wo le Egipte 
\q1  
\v 22 kple dzesiwo le Hamnyigba dzi 
\q2 kple ŋɔdzinuwo le Ƒu Dzĩ la to. 
\q1  
\v 23 Eya ta wògblɔ be, yele wo tsrɔ̃ ge. 
\q2 Ɖe Mose, eƒe ame tiatia la 
\q1 metsi tsitre ɖe gbagbãƒe la hexe mɔ na 
\q2 eƒe dziku helĩhelĩ la o la, anye ne etsrɔ̃ wo. 
\b  
\q1  
\v 24 Wodo vlo anyigba dzeani la, 
\q2 eye womexɔ eƒe ŋugbedodo dzi se o. 
\q1  
\v 25 Wolĩ liʋĩliʋĩ le woƒe agbadɔwo me, 
\q2 eye womeɖo to Yehowa o. 
\q1  
\v 26 Eya ta wòdo eƒe asiwo ɖe dzi ka atam na wo 
\q2 be yele nana ge wo katã natsrɔ̃ ɖe gbea dzi, 
\q1  
\v 27 woƒe dzidzimeviwo atsi dukɔwo dome, 
\q2 eye yeakaka wo ɖe anyigbawo dzi. 
\b  
\q1  
\v 28 Wotsɔ Baal Peor ƒe kɔkuti ku kɔ na wo ɖokuiwo, 
\q2 eye woɖu nu siwo wotsɔ sa vɔ̃e na mawu siwo me agbe mele o. 
\q1  
\v 29 Wotsɔ woƒe nu vɔ̃ɖiawo do dɔmedzoe na Yehowa, 
\q2 eye dɔvɔ̃ gbã gboo ɖe wo dome. 
\q1  
\v 30 Gake Finehas tsi tsitre hetso nya me, 
\q2 tete dɔvɔ̃ la nu tso. 
\q1  
\v 31 Wobu esia dzɔdzɔenyenye nɛ 
\q2 hena dzidzime mavɔ siwo ava dzɔ. 
\q1  
\v 32 Le Meriba tsiawo gbɔ, 
\q2 wodo dɔmedzoe na Yehowa, 
\q2 eye Mose kpɔ nya le woawo ta. 
\q1  
\v 33 Elabena wodze aglã ɖe Mawu ƒe Gbɔgbɔ ŋuti, 
\q2 eye nya vlowo ge le Mose nu. 
\b  
\q1  
\v 34 Wometsrɔ̃ ameawo abe ale si Yehowa de se na wo ene o, 
\q1  
\v 35 ke boŋ wotsaka kple dukɔwo, 
\q2 eye wosrɔ̃ woƒe kɔnyinyiwo. 
\q1  
\v 36 Wosubɔ woƒe legbawo, 
\q2 esi zu mɔ me woge ɖo. 
\q1  
\v 37 Wotsɔ woƒe ŋutsuviwo 
\q2 kple woƒe nyɔnuviwo sa vɔe na gbɔgbɔ vɔ̃wo. 
\q1  
\v 38 Wokɔ ʋu maɖifɔ ɖi, 
\q2 wo viŋutsuwo kple wo vinyɔnuwo ƒe ʋu, 
\q1 ame siwo wotsɔ sa vɔe na Kanaan legbawo, 
\q2 eye wotsɔ woƒe ʋu gblẽ kɔ ɖo na anyigba la. 
\q1  
\v 39 Woƒo ɖi wo ɖokuiwo to nu si wowɔ la me, 
\q2 eye to woƒe nuwɔnawo me, 
\q2 wotsɔ wo ɖokuiwo wɔ gbolowoe, 
\q1  
\v 40 eya ta Yehowa do dɔmedzoe ɖe eƒe dukɔ ŋuti, 
\q2 eye wònyɔ ŋu eƒe domenyinu. 
\b  
\q1  
\v 41 Etsɔ wo de asi na dukɔwo, 
\q2 eye woƒe futɔwo ɖu fia ɖe wo dzi. 
\q1  
\v 42 Woƒe futɔwo te wo ɖe to, 
\q2 eye wotsɔ wo de woƒe ŋusẽ te. 
\q1  
\v 43 Eɖe wo zi geɖe, 
\q2 gake woɖoe kplikpaa be yewoadze aglã, 
\q1 eye wovɔ le eme keŋkeŋ 
\q2 le woƒe nu vɔ̃ me. 
\q1  
\v 44 Ke ekpɔ woƒe hiã la ɖa, 
\q2 esi wòse woƒe ɣlidodo; 
\q1  
\v 45 le wo ta, eɖo ŋku eƒe nubabla la dzi, 
\q2 eye wòɖe asi le eƒe tameɖoɖo ŋu le eƒe lɔlɔ̃ gã la ta. 
\q1  
\v 46 Ena ame siwo katã ɖe aboyo wo 
\q2 la kpɔ nublanui na wo. 
\b  
\q1  
\v 47 O! Yehowa, míaƒe Mawu, 
\q2 ɖe mí, eye nàƒo mía nu ƒu tso dukɔwo dome, 
\q1 be míada akpe na wò ŋkɔ kɔkɔe la, 
\q2 eye míaƒo adegbe le wò kafukafu ŋu. 
\b  
\b  
\q1  
\v 48 Woakafu Yehowa, Israel ƒe Mawu la, 
\q2 tso mavɔ me yi mavɔ me. 
\b  
\q1 Dukɔ blibo la nàgblɔ be, “Amen!” 
\b  
\q1 Mikafu Yehowa. 
\c 107  
\ms1 Agbalẽ atɔ̃lia 
\mr Psalmowo 107–150 
\cl Psalmo 107 
\q1  
\v 1 Mida akpe na Yehowa, 
\q2 elabena enyo, eye eƒe lɔlɔ̃ li ɖaa. 
\b  
\q1  
\v 2 Ame siwo Yehowa ɖe la negblɔ esia; 
\q2 ame siwo wòɖe tso futɔ la ƒe asi me, 
\q1  
\v 3 ame siwo nu wòƒo ƒui tso anyigbawo dzi, 
\q2 tso ɣedzeƒe kple ɣetoɖoƒe, anyiehe kple dziehe. 
\b  
\q1  
\v 4 Ame aɖewo tsa tsaglãla le gbedzi kple gbedadaƒo, 
\q2 eye womekpɔ mɔ si woato ayi du aɖe si me woanɔ la o. 
\q1  
\v 5 Dɔ kple tsikɔ wu wo, 
\q2 eye nu te woƒe luʋɔ ŋu le wo me. 
\q1  
\v 6 Tete wodo ɣli yɔ Yehowa le woƒe xaxa la me, 
\q2 eye wòɖe wo le woƒe hiã la me. 
\q1  
\v 7 Ekplɔ wo tẽe yi 
\q2 ɖe du aɖe si me woanɔ. 
\q1  
\v 8 Woneda akpe na Yehowa le eƒe lɔlɔ̃ si meʋãna o 
\q2 la ta kple eƒe nukudɔ siwo wòwɔna na amewo la ta. 
\q1  
\v 9 Elabena etsɔa nu nyuiwo ɖia ƒoe na 
\q2 ame siwo dɔ kple tsikɔ le wuwum. 
\b  
\q1  
\v 10 Ame aɖewo nɔ viviti kple blukɔ tsiɖitsiɖi me, 
\q2 gamenɔla siwo le fu kpem le gakɔsɔkɔsɔwo me, 
\q1  
\v 11 elabena wodze aglã ɖe Mawu ƒe nyawo ŋuti, 
\q2 eye wodo vlo Dziƒoʋĩtɔ la ƒe aɖaŋudede. 
\q1  
\v 12 Eya ta wòtsɔ wo de asi na dɔ sesẽ wɔwɔ, 
\q2 womu sɔgɔsɔgɔsɔgɔ, eye ame aɖeke meli akpe ɖe wo ŋu o. 
\q1  
\v 13 Tete wodo ɣli na Yehowa le woƒe xaxa la me, 
\q2 eye wòɖe wo le woƒe hiã la me. 
\q1  
\v 14 Eɖe wo le viviti kple blukɔ tsiɖitsiɖitsiɖi la me, 
\q2 eye wòtso woƒe gakɔsɔkɔsɔwo. 
\q1  
\v 15 Woneda akpe na Yehowa le eƒe lɔlɔ̃ si meʋãna o 
\q2 la ta kple eƒe nukudɔ siwo wòwɔna na amewo la ta, 
\q1  
\v 16 elabena eŋe akɔbligbowo, 
\q2 eye wòlã gayibɔ ƒe gametiwo me. 
\b  
\q1  
\v 17 Wo dometɔ aɖewo zu bometsilawo to 
\q2 woƒe aglãdzenuwo wɔwɔ me, 
\q2 eye wokpe fu le woƒe dzidadawo ta. 
\q1  
\v 18 Wonyɔ ŋu nuɖuɖu ɖe sia ɖe, 
\q2 eye woɖo ku ƒe agbowo nu. 
\q1  
\v 19 Wodo ɣli na Yehowa le woƒe xaxa la me, 
\q2 eye wòɖe wo le woƒe hiã la me. 
\q1  
\v 20 Edɔ eƒe nya ɖa, eye wòyɔ dɔ wo, 
\q2 heɖe wo tso tsiẽƒe. 
\q1  
\v 21 Woneda akpe na Yehowa le eƒe lɔlɔ̃ si meʋãna o 
\q2 la ta kple eƒe nukudɔ siwo wòwɔna na amewo la ta. 
\q1  
\v 22 Wonesa akpedavɔ nɛ, 
\q2 eye woaɖe eƒe dɔwɔwɔwo afia to aseyetsohawo me. 
\b  
\q1  
\v 23 Ame aɖewo le meli me zɔ atsiaƒu dzi, 
\q2 wonye asitsalawo le tɔ gãwo dzi. 
\q1  
\v 24 Wokpɔ Yehowa ƒe dɔwɔwɔwo, 
\q2 wokpɔ eƒe nukudɔwo le atsiaƒu gɔme, 
\q1  
\v 25 elabena eƒo nu, elɔ ahom kɔ ɖe ƒu la dzi, 
\q2 eye eƒe tsotsoewo dze agbo. 
\q1  
\v 26 Woyi dziƒo boo, eye wogadze eme 
\q2 le gogloƒe ke, ale le woƒe agbe ƒe xaxa me, 
\q2 woƒe dzideƒo lolo gbana. 
\q1  
\v 27 Wole mumum sɔgɔsɔgɔsɔgɔ, 
\q2 le nu klim abe ame siwo mu aha ene, 
\q2 eye womegale naneke gɔme sem o. 
\q1  
\v 28 Tete wodo ɣli na Yehowa le woƒe xaxa la me, 
\q2 eye wòɖe wo le woƒe hiã la me. 
\q1  
\v 29 Etsi ahom la nu wòzi ɖoɖoe abe dalĩ dom wole ene, 
\q2 eye ƒutsotsoeawo hã ɖo to kpoo. 
\q1  
\v 30 Wokpɔ dzidzɔ esi wòdze kɔ anyi, 
\q2 eye wòkplɔ wo va se ɖe 
\q2 esime wova ɖo afi si wodi be yewoanɔ. 
\q1  
\v 31 Woneda akpe na Yehowa le eƒe lɔlɔ̃ si meʋãna o la ta 
\q2 kple eƒe nukudɔ siwo wòwɔna na amewo la ta. 
\q1  
\v 32 Wonedoe ɖe dzi le dukɔ la ƒe ƒuƒoƒo me, 
\q2 eye woakafui le dumegãwo ƒe takpekpe me. 
\b  
\q1  
\v 33 Etrɔ tɔsisiwo wozu gbegbe 
\q2 kple tsidzɔƒewo wozu kuɖiɖinyigba, 
\q1  
\v 34 eye agbledeƒe zu dzeƒi le ame siwo 
\q2 le teƒe ma ƒe nu vɔ̃ɖi wɔwɔ ta. 
\q1  
\v 35 Etrɔ gbegbe wòzu tɔʋu, 
\q2 eye kuɖiɖinyigba zu tsidzɔƒe; 
\q1  
\v 36 afi mae wòkplɔ dɔwuitɔwo be woava nɔ, 
\q2 eye wotso du si me woanɔ. 
\q1  
\v 37 Woƒã nukuwo ɖe agble me, 
\q2 wode waingblewo, eye wotse ku geɖe hena xaxa. 
\q1  
\v 38 Eyra wo, eye woƒe xexlẽme dzi ɖe edzi ŋutɔ. 
\q2 Nenema ke mena woƒe lãhawo dzi ɖe kpɔtɔ o. 
\b  
\q1  
\v 39 Tete wozu ʋɛ, wobɔbɔ wo ɖe anyi le teteɖeanyi, 
\q2 dzɔgbevɔ̃e kple nuxaxa me; 
\q1  
\v 40 eye eya ame si trɔa vlododo kɔna ɖe ame ŋkutawo dzi la, 
\q2 wɔe be wole tsaglãla tsam le gbegbe afi si mɔtoƒe aɖeke mele o. 
\q1  
\v 41 Ke ekɔ hiãtɔwo ɖe dzi tso woƒe hiã me, 
\q2 eye wòna woƒe ƒome dzi ɖe edzi abe lãhawo ene. 
\q1  
\v 42 Ame dzɔdzɔe kpɔe, 
\q2 eye wòkpɔ dzidzɔ, gake ame vɔ̃ɖiwo katã mia woƒe nu. 
\b  
\q1  
\v 43 Ame si nye nunyala la, 
\q2 neɖo to nu siawo, eye wòabu Yehowa ƒe lɔlɔ̃ deto la ŋuti. 
\c 108  
\cl Psalmo 108 
\d Hadzidzi. David ƒe ha. 
\q1  
\v 1 O! Mawu, nye dzi le te goŋgoŋgoŋ. 
\q2 Madzi ha, aƒo saŋku kple nye luʋɔ blibo. 
\q1  
\v 2 Saŋku kple kasaŋku, 
\q2 minyɔ! Manyɔ fɔŋli. 
\q1  
\v 3 O! Yehowa, makafu wò le dukɔwo dome, 
\q2 eye madzi ha le ŋuwò le anyigbadzitɔwo dome, 
\q1  
\v 4 elabena wò lɔlɔ̃ de blibo, 
\q2 hekɔ wu dziƒowo, eye wò nuteƒewɔwɔ yi ɖatɔ lilikpowo. 
\q1  
\v 5 O! Mawu, woado wò ɖe dzi agbɔ dziƒowo ŋu, 
\q2 eye na wò ŋutikɔkɔe naxɔ anyigba blibo la dzi. 
\b  
\q1  
\v 6 Ɖe mí, eye nàkpe ɖe mía ŋu kple wò nuɖusibɔ, 
\q2 be ame siwo nèlɔ̃ vevie la nakpɔ ɖeɖe. 
\q1  
\v 7 Mawu ƒo nu tso eƒe kɔkɔeƒe la be, 
\q2 “Mama Sekem le dziɖuɖu me, 
\q2 eye madzidze Sukɔt Balime. 
\q1  
\v 8 Gilead nye tɔnye, Manase hã tɔnyee; 
\q2 nye gakukue nye Efraim, 
\q2 eye Yuda nye nye fiatikplɔ. 
\q1  
\v 9 Moab nye nye tsiletɔkpo, 
\q2 matsɔ nye atokota aƒu gbe ɖe Edom dzi, 
\q2 eye mado dziɖuɖuɣli ɖe Filistia ŋu.” 
\b  
\q1  
\v 10 Ame ka akplɔm ayi du sesẽ la mee? 
\q2 Ame ka akplɔm ayi Edom? 
\q1  
\v 11 O! Mawu, ɖe menye wòe oa? 
\q2 Nu ka wɔ nègbe mí, 
\q2 eye mègadona kple míaƒe aʋakɔwo o? 
\q1  
\v 12 Kpe ɖe mía ŋu ɖe míaƒe futɔwo ŋuti, 
\q2 elabena èna amegbetɔ ƒe kpekpeɖeŋu mele nemi hã me o. 
\q1  
\v 13 Ne Mawu le mía dzi la, míaɖu dzi, 
\q2 eye wòafanya míaƒe futɔwo ɖe eƒe afɔ te. 
\c 109  
\cl Psalmo 109 
\d David ƒe ha na hɛnɔ la. 
\q1  
\v 1 O! Mawu, wò ame si mekafu, 
\q2 mègazi ɖoɖoe o, 
\q1  
\v 2 elabena ame vɔ̃ɖiwo kple alakpatɔwo, 
\q2 ke woƒe nuwo ɖe ŋutinye, 
\q2 eye wogblɔ nya ɖe ŋunye kple alakpaɖewo. 
\q1  
\v 3 Wotsɔ fulényawo ƒo xlãm; 
\q2 wotso ɖe ŋunye nanekemawɔmawɔe. 
\q1  
\v 4 Wotsɔ fɔbubu nam ɖe nye lɔlɔ̃ teƒe, 
\q2 ke nye la, ame si doa gbe ɖa vevie lae menye. 
\q1  
\v 5 Wotsɔ vɔ̃ ɖo nyui teƒe nam, 
\q2 eye wotsɔ fuléle ɖo nye lɔlɔ̃ teƒe. 
\b  
\q1  
\v 6 Tia ame vɔ̃ɖi aɖe wòatso ɖe eŋu; 
\q2 eye na amenutsola natsi tsitre ɖe eƒe nuɖusime. 
\q1  
\v 7 Ne wodrɔ̃ ʋɔnui la, 
\q2 woneɖe agɔdzedze nɛ, 
\q2 eye eƒe gbedodoɖawo nebu fɔe. 
\q1  
\v 8 Eƒe ŋkekewo nenɔ ʋɛ 
\q2 eye ame bubu naxɔ eƒe amekplɔdɔ awɔ. 
\q1  
\v 9 Viawo nezu tsyɔ̃eviwo, 
\q2 eye srɔ̃a nezu ahosi. 
\q1  
\v 10 Viawo nenɔ tsaglãla tsam, anɔ nu biam; 
\q2 wonenya wo do goe le woƒe aƒe gbagbãwo me. 
\q1  
\v 11 Fetɔ aɖe nexɔ eƒe nunɔmesiwo katã, 
\q2 eye amedzrowo neha nu siwo wòwɔ dɔ kpɔ. 
\q1  
\v 12 Ame aɖeke megave enu loo, 
\q2 alo akpɔ nublanui na eƒe tsyɔ̃eviwo o. 
\q1  
\v 13 Eƒe dzidzimeviwo netsrɔ̃, 
\q2 eye woaɖe woƒe ŋkɔwo ɖa le dzidzime si gbɔna la me. 
\q1  
\v 14 Woneɖo ŋku fofoawo ƒe vodadawo dzi 
\q2 le Yehowa ŋkume, eye womegatutu dadaa 
\q2 ƒe nu vɔ̃ ɖa akpɔ gbeɖe o. 
\q1  
\v 15 Woƒe nu vɔ̃wo nenɔ Yehowa ŋkume ɖaa, 
\q2 ale be wòaɖe woƒe ŋkɔ ɖa le anyigba dzi, 
\q1  
\v 16 elabena mebu dɔmenyowɔwɔ ŋuti kpɔ o, 
\q2 ke boŋ eƒo hiãtɔ, 
\q2 ame dahe kple ame si ƒe dzi gbã la ƒu anyi woku. 
\b  
\q1  
\v 17 Elɔ̃a ɖiŋudodo, eya ta ɖiŋudodo neva eya ŋutɔ ƒe ta dzi; 
\q2 amewo yayra medoa dzidzɔ nɛ o, 
\q2 eya ta yayra nete ɖa xaa tso eya ŋutɔ gbɔ. 
\q1  
\v 18 Etsɔ ɖiŋudodo do abe awu ene, 
\q2 wòge ɖe eƒe lãme abe tsi ene, 
\q2 eye wòɖo eƒe ƒuwo me abe ami ene, 
\q1  
\v 19 eya ta netae abe avɔ ene, 
\q2 eye nebla ali dzi nɛ abe alidziblaka ene tegbetegbe. 
\q1  
\v 20 Esia nenye fe si Yehowa axe na nunyetsolawo 
\q2 kple ame siwo gblɔa nya vɔ̃ ɖe ŋutinye. 
\b  
\q1  
\v 21 Ke wò la, o Aƒetɔ Yehowa, 
\q2 wɔ nyui nam le wò ŋkɔ la ta, 
\q2 ɖem le wò lɔlɔ̃ si wɔa nyui la ta, 
\q1  
\v 22 elabena hiãtɔ kple ame dahe menye, 
\q2 eye nye dzi xɔ abi le menye. 
\q1  
\v 23 Nunye yi abe vɔvɔli le fiẽ me ene 
\q2 eye woʋuʋum abe ʋetsuvi ene. 
\q1  
\v 24 Le nutsitsidɔ ta la, 
\q2 nye klowo zu belie, 
\q2 eye meɖi ku glaglaglã. 
\q1  
\v 25 Mezu alɔmeɖenu na nunyetsolawo, 
\q2 eye woʋuʋua ta ne wokpɔm. 
\b  
\q1  
\v 26 O! Yehowa, nye Mawu, 
\q2 kpe ɖe ŋunye, ɖem le wò lɔlɔ̃ la ta. 
\q1  
\v 27 O! Yehowa, wonenya be to wò asi dzie nèwɔ esia. 
\q1  
\v 28 Woaƒo fi ade ame, ke wò la àyra ame, 
\q2 ne wotso ɖe ŋunye la, ŋu akpe wo, 
\q2 ke wò dɔla ya atso aseye. 
\q1  
\v 29 Nunyetsolawo ado vlododo abe awu ene, 
\q2 eye wòata ŋukpe abe avɔ ene. 
\b  
\q1  
\v 30 Matsɔ nye nu ado Yehowa ɖe dzi, 
\q2 eye le ameha gã la dome, makafui, 
\q1  
\v 31 elabena etsi tsitre ɖe hiãtɔ la ƒe nuɖusime, 
\q2 be yeaɖe eƒe agbe tso ame siwo bu fɔ̃e la ƒe asi me. 
\c 110  
\cl Psalmo 110 
\d David ƒe ha. 
\q1  
\v 1 Yehowa gblɔ na nye Aƒetɔ la be, 
\b  
\q1 “Nɔ anyi ɖe nye nuɖusime, 
\q2 va se ɖe esime matsɔ wò futɔwo 
\q2 awɔ wò afɔɖodzinui.” 
\b  
\q1  
\v 2 Yehowa adidi wò ŋusẽ ƒe fiatikplɔ ɖe edzi tso Zion, 
\q2 eye àɖu fia le wò futɔwo dome. 
\q1  
\v 3 Wò aʋakɔwo alɔ̃ faa ade megbe na wò le wò aʋakpegbe. 
\q2 Ànɔ atsyɔ̃ɖoɖo kɔkɔe, 
\q1 si do go tso fɔŋli ƒe dɔ me ke la me, 
\q2 axɔ wò ɖekakpuimezãmu. 
\b  
\q1  
\v 4 Yehowa ka atam, 
\q2 eye matrɔ eƒe susu akpɔ o, be 
\q1 “Wòe nye nunɔla tegbee, 
\q2 le Melkizedek ƒe ɖoɖo la nu.” 
\b  
\q1  
\v 5 Aƒetɔ la le wò nuɖusime, 
\q2 agbã fiawo nyanyanya le eƒe dɔmedzoeŋkeke la dzi. 
\q1  
\v 6 Adrɔ̃ ʋɔnu dukɔwo, eye wòali kɔ woƒe kukuawo, 
\q2 nenema ke wòagbã dziɖulawo le anyigba blibo la dzi. 
\q1  
\v 7 Ano tsi le tɔʋu si le mɔto la me, 
\q2 eya ta afɔ eƒe ta dzi. 
\c 111  
\cl Psalmo 111 
\q1  
\v 1 Mikafu Yehowa. 
\b  
\q1 Mado Yehowa ɖe dzi kple nye dzi blibo 
\q2 le ame dzɔdzɔewo ƒe adaŋudeha me kple amehawo dome. 
\b  
\q1  
\v 2 Yehowa ƒe dɔwɔwɔwo lolo kpem; 
\q2 ame siwo wodoa dzidzɔ na la bua wo ŋuti. 
\q1  
\v 3 Ŋutikɔkɔe kple atsyɔ̃ nye eƒe nuwɔwɔwo, 
\q2 eye eƒe dzɔdzɔenye li tegbee. 
\q1  
\v 4 Ena woɖo ŋku eƒe nukudɔwo dzi; 
\q2 Yehowa nye amenuvela kple nublanuikpɔla. 
\q1  
\v 5 Enaa nuɖuɖu ame siwo vɔ̃nɛ, 
\q2 eye wòɖoa ŋku eƒe nubabla dzi tegbetegbe. 
\b  
\q1  
\v 6 Eɖe eƒe dɔwɔwɔwo ƒe ŋusẽ fia eƒe dukɔ la 
\q2 eye wòtsɔ dukɔ bubuwo ƒe anyigba na wo. 
\q1  
\v 7 Eƒe asinudɔwɔwɔwo le eteƒe, eye wodzɔ; 
\q2 nenema ke woate ŋu aka ɖe eƒe sewo hã dzii, 
\q1  
\v 8 elabena wole te tso mavɔ me yi ɖe mavɔ me, 
\q2 eye wòde sewo le nuteƒewɔwɔ kple dzɔdzɔenyenye me. 
\q1  
\v 9 Eɖo ɖeɖe ɖi na eƒe dukɔ, 
\q2 eɖo eƒe nubabla anyi tegbee, 
\q2 eye eƒe ŋkɔ le kɔkɔe; ŋɔdzi hã le eŋu. 
\b  
\q1  
\v 10 Yehowa vɔvɔ̃e nye nunya ƒe gɔmedzedze, 
\q2 eye ame siwo katã léa eƒe sewo me ɖe asi 
\q2 la, gɔmesese nyui sua wo si. 
\q2 Eya tɔe nye kafukafu tegbee. 
\c 112  
\cl Psalmo 112 
\q1  
\v 1 Mikafu Yehowa. 
\b  
\q1 Woayra ŋutsu si vɔ̃a Yehowa, 
\q2 eye wòkpɔa dzidzɔ vevie le eƒe sewo ŋu. 
\b  
\q1  
\v 2 Viawo anye ŋusẽtɔwo le anyigba la dzi, 
\q2 eye woayra dzi dzɔdzɔetɔwo ƒe dzidzime. 
\q1  
\v 3 Kesinɔnu kple nu nyuiwo le eƒe aƒe me, 
\q2 eye eƒe dzɔdzɔenyenye nɔa anyi ɖikaa. 
\q1  
\v 4 Le viviti me gɔ̃ hã la, 
\q2 kekeli klẽna na ame dzɔdzɔewo, 
\q1 nenema ke wònɔna na ame si vea ame nu, 
\q2 kpɔa nublanui, eye wòwɔa nu dzɔdzɔe. 
\q1  
\v 5 Nyui ava na ame si nyoa dɔ me, doa nugbana faa, 
\q2 eye wòwɔa eƒe nuwo to mɔ dzɔdzɔe dzi. 
\b  
\q1  
\v 6 Vavã, maʋã akpɔ o; 
\q2 woaɖo ŋku ame dzɔdzɔe dzi tegbee. 
\q1  
\v 7 Mavɔ̃ na nya vɔ̃ sese o, 
\q2 eƒe dzi li ke, eye wòkana ɖe Yehowa dzi. 
\q1  
\v 8 Mavɔ̃ naneke o, elabena dzi le eƒo; 
\q2 eye mlɔeba la, akpɔ eƒe futɔwo ta ɖa le dziɖuɖu me. 
\q1  
\v 9 Ema eƒe kesinɔnuwo na ame dahewo fũu, 
\q2 eƒe dzɔdzɔenyenye li tegbee, 
\q2 eye woakɔ eƒe dzo ɖe dzi bobobo le bubu me. 
\b  
\q1  
\v 10 Ame vɔ̃ɖi akpɔe, eye dzi akui, 
\q2 aɖu aɖukli, avɔ le eme keŋkeŋkeŋ. 
\q2 Ame vɔ̃ɖiwo ƒe dzimedidiwo azu tofloko. 
\c 113  
\cl Psalmo 113 
\q1  
\v 1 Mikafu Yehowa. 
\b  
\q1 O! Mi Yehowa ƒe dɔlawo, 
\q2 mikafui, mikafu Yehowa ƒe ŋkɔ. 
\q1  
\v 2 Woakafu Yehowa ƒe ŋkɔ 
\q2 tso fifia yi ɖe mavɔ me ke. 
\q1  
\v 3 Woakafu Yehowa ƒe ŋkɔ 
\q2 tso ɣeyiɣi si ɣe adze va se ɖe esi wòaɖo to ɖe afi si wòɖoa to ɖo. 
\b  
\q1  
\v 4 Yehowa nye gã ɖe dukɔwo katã dzi, 
\q2 eye eƒe ŋutikɔkɔe gbɔ dziƒowo ta. 
\q1  
\v 5 Ame kae le abe Yehowa, 
\q2 míaƒe Mawu la ene, ame si nɔ anyi ɖe fiazikpui dzi le dziƒo, 
\q2  
\v 6 eye wòbɔbɔ be yeakpɔ dziƒowo kple anyigba ɖa? 
\b  
\q1  
\v 7 Efɔ ame dahe ɖe tsitre tso ke me, 
\q2 eye wòfɔ hiãtɔ ɖe dzi tso dzowɔ me; 
\q1  
\v 8 hetsɔ wo ɖo dumegãwo xa, 
\q2 ɛ̃, woƒe dumegãwo xa. 
\q1  
\v 9 Ame si na konɔ nɔa eƒe aƒe me, 
\q2 hekpɔa dzidzɔ abe viwo dada ene. 
\b  
\q1 Mikafu Yehowa. 
\c 114  
\cl Psalmo 114 
\q1  
\v 1 Esi Israel do go tso Egipte, 
\q2 esi Yakob ƒe aƒe la do go 
\q2 tso gbe bubu gblɔlawo dome la, 
\q1  
\v 2 Yuda zu Mawu ƒe kɔkɔeƒe, 
\q2 eye Israel zu eƒe fiaɖuƒe. 
\b  
\q1  
\v 3 Atsiaƒu kpɔe, eye wòsi dzo, 
\q2 Yɔdan tɔsisi hã te yi megbe. 
\q1  
\v 4 Towo ti kpo abe agbowo ene, 
\q2 eye togbɛwo abe alẽviwo ene. 
\b  
\q1  
\v 5 O! Atsiaƒu, nu ka ta nèsi ɖo, 
\q2 O! Yɔdan tɔsisi, nu ka ta nète yi megbe ɖo? 
\q1  
\v 6 Mi towo, nu ka ta mieti kpo abe agbowo ene, 
\q2 eye mi togbɛwo abe alẽviwo ene ɖo? 
\b  
\q1  
\v 7 O! Anyigba, dzo nyanyanya le Aƒetɔ la ŋkume, 
\q2 le Yakob ƒe Mawu la ŋkume, 
\q1  
\v 8 eya ame si trɔ agakpe wòzu tɔʋu 
\q2 kple agakpe sesẽ wòzu tsidzɔƒe. 
\c 115  
\cl Psalmo 115 
\q1  
\v 1 Menye míawoe o, o Yehowa, menye míawoe o, 
\q2 ke boŋ ŋutikɔkɔe la nye wò ŋkɔ tɔ, 
\q2 le wò lɔlɔ̃ kple nuteƒewɔwɔ ta. 
\b  
\q1  
\v 2 Nu ka ta dukɔwo le gbɔgblɔm be, 
\q2 “Afi ka woƒe Mawu la le?” 
\q1  
\v 3 Míaƒe Mawu la le dziƒo, 
\q2 eye nu sia nu si dze eŋu lae wòwɔna, 
\q1  
\v 4 gake woawo ya ƒe legbawo nye klosalo kple sika, 
\q2 eye amegbetɔ ƒe asiwoe wɔ wo, 
\q1  
\v 5 eya ta nu li na wo, 
\q2 gake womate ŋu aƒo nu o, ŋku li na wo, 
\q2 gake womate ŋu akpɔ nu o; 
\q1  
\v 6 to li na wo, 
\q2 gake womesea nu o, ŋɔti li na wo, 
\q2 gake womeʋẽa nu sena o; 
\q1  
\v 7 asi li na wo, 
\q2 gake wometea nu kpɔna o, afɔ li na wo, 
\q2 gake womate ŋu azɔ loo, alo aƒo nu to ve me o. 
\q1  
\v 8 Ame siwo wɔ wo la, anɔ abe woawo ke ene, 
\q2 eye nenema kee nye ame siwo tsɔ woƒe mɔkpɔkpɔ da ɖe wo dzi. 
\q1  
\v 9 O! Israel ƒe aƒe, ɖo dzi ɖe Yehowa ŋu, 
\q2 eyae nye wò kpeɖeŋutɔ kple akpoxɔnu. 
\q1  
\v 10 O! Aron ƒe aƒe, 
\q2 ɖo dzi ɖe Yehowa ŋu, 
\q2 eyae nye wò kpeɖeŋutɔ kple akpoxɔnu. 
\q1  
\v 11 Mi ame siwo vɔ̃nɛ, miɖo dzi ɖe Yehowa ŋu, 
\q2 eyae nye miaƒe kpeɖeŋutɔ kple akpoxɔnu. 
\b  
\q1  
\v 12 Yehowa ɖo ŋku mía dzi, 
\q2 eya ta ayra mí. 
\q1 Ayra Israel ƒe aƒe la, 
\q2 ayra Aron ƒe aƒe la, 
\q1  
\v 13 ayra ame siwo vɔ̃a Yehowa, 
\q2 suewo kple gãwo siaa. 
\b  
\q1  
\v 14 Yehowa nana miadzi ɖe edzi, 
\q2 miawo ŋutɔwo kple mia viwo. 
\q1  
\v 15 Yehowa neyra mi, 
\q2 eya dziƒo kple anyigba Wɔla. 
\b  
\q1  
\v 16 Dziƒo kɔkɔtɔ nye Yehowa, 
\q2 Wɔla la tɔ, ke etsɔ anyigba na amegbetɔ. 
\q1  
\v 17 Menye ame kukuwoe kafua Yehowa o, 
\q2 menye ame siwo zi ɖoɖoe le aʋlimee o; 
\q1  
\v 18 ke boŋ mí ame siwo doa Yehowa 
\q2 ɖe dzi fifia kple ɖaasi lae. 
\b  
\q1 Mikafu Yehowa. 
\c 116  
\cl Psalmo 116 
\q1  
\v 1 Melɔ̃ Yehowa, elabena ese nye gbe; 
\q2 ese nye avifafa be wonekpɔ nublanui nam. 
\q1  
\v 2 Esi wòtrɔ to ɖe gbɔnye ta la, 
\q2 mayɔe zi ale si mele agbe. 
\b  
\q1  
\v 3 Ku ƒe kawo blam, eye tsiẽƒe ƒe vevesese va dzinye. 
\q2 Hiã tum, eye nuxaxa va dzinye. 
\q1  
\v 4 Tete meyɔ Yehowa ƒe ŋkɔ be, 
\q2 “O! Yehowa, ɖem!” 
\b  
\q1  
\v 5 Yehowa nye amenuvetɔ kple dzɔdzɔetɔ; 
\q2 míaƒe Mawu la yɔ fũu kple nublanuikpɔkpɔ. 
\q1  
\v 6 Yehowa kpɔa ame siwo fa tu le dzi me la ta; 
\q2 esi menɔ hiahiã gã aɖe me la, eɖem le eme. 
\b  
\q1  
\v 7 O! Luʋɔnye, gagbɔ ɖe eme, 
\q2 elabena Yehowa nyo dɔ me na wò. 
\b  
\q1  
\v 8 O! Yehowa, wòe ɖe nye luʋɔ tso ku me, 
\q2 nye ŋkuwo tso aɖatsi si me, 
\q2 nye afɔwo tso anyidzedze me; 
\q1  
\v 9 be mate ŋu azɔ le Yehowa ŋkume 
\q2 le agbagbeawo ƒe anyigba dzi. 
\b  
\q1  
\v 10 Mexɔe se, eya ta megblɔ be, 
\q2 “Wokaa hiãm ŋutɔ.” 
\q1  
\v 11 Eye le nye moya me, megblɔ be, 
\q2 “Amegbetɔwo katã nye aʋatsokalawo.” 
\b  
\q1  
\v 12 Aleke mawɔ aɖo dɔmenyo 
\q2 siwo katã Yehowa wɔ nam la teƒe nɛ? 
\b  
\q1  
\v 13 Makɔ xɔxɔ ƒe kplu la ɖe dzi, 
\q2 eye mayɔ Yehowa ƒe ŋkɔ. 
\q1  
\v 14 Maxe nye adzɔgbeɖefe na Yehowa 
\q2 le eƒe dukɔ blibo la ŋkume. 
\b  
\q1  
\v 15 Eƒe ame kɔkɔewo ƒe ku nye nu xɔasi 
\q2 le Yehowa ŋkume. 
\q1  
\v 16 O! Yehowa, menye wò dɔla vavã, 
\q2 wò dɔlae menye, 
\q1 wò subɔla ƒe viŋutsue menye, 
\q2 eye nèɖem tso nye gakɔsɔkɔsɔ siwo blam la me. 
\b  
\q1  
\v 17 Masa akpedavɔ na wò, 
\q2 eye mayɔ Yehowa ƒe ŋkɔ. 
\q1  
\v 18 Maxe nye adzɔgbeɖefe na Yehowa, 
\q2 le eƒe dukɔ blibo la ŋkume, 
\q1  
\v 19 le Yehowa ƒe aƒe ƒe xɔxɔnuwo, 
\q2 le mia dome, o Yerusalem. 
\b  
\q1 Mikafu Yehowa. 
\c 117  
\cl Psalmo 117 
\q1  
\v 1 Mi dukɔwo katã, mikafu Yehowa; 
\q2 midoe ɖe dzi, mi ame siwo katã le anyigba dzi. 
\q1  
\v 2 Elabena eƒe lɔlɔ̃ na mí sɔ gbɔ ŋutɔ, 
\q2 eye Yehowa ƒe nuteƒewɔwɔ li tegbee. 
\b  
\q1 Mikafu Yehowa. 
\c 118  
\cl Psalmo 118 
\q1  
\v 1 Mida akpe ne Yehowa, 
\q2 elabena eƒe dɔ me nyo, eye eƒe lɔlɔ̃ li ɖaa. 
\b  
\q1  
\v 2 Israel negblɔ be; 
\q2 “Eƒe lɔlɔ̃ li ɖaa.” 
\q1  
\v 3 Aron ƒe aƒe la negblɔ be; 
\q2 “Eƒe lɔlɔ̃ li ɖaa.” 
\q1  
\v 4 Ame siwo vɔ̃a Yehowa la negblɔ be, 
\q2 “Eƒe lɔlɔ̃ li ɖaa.” 
\b  
\q1  
\v 5 Le nye vevesese me, medo ɣli yɔ Yehowa, 
\q2 etɔ nam, eye wòɖe gam. 
\q1  
\v 6 Yehowa li kplim, eya ta nyemavɔ̃ o. 
\q2 Nu ka amegbetɔ awɔm? 
\q1  
\v 7 Yehowa li kplim, eyae nye nye xɔnametɔ. 
\q2 Makpɔ nye futɔwo ta ɖa le dziɖuɖu me. 
\b  
\q1  
\v 8 Enyo be woatsɔ Yehowa awɔ sitsoƒee 
\q2 wu, be woaɖo ŋu ɖe amegbetɔ ŋu. 
\q1  
\v 9 Enyo be woatsɔ Yehowa awɔ sitsoƒee wu, be 
\q2 woaɖo ŋu ɖe dumegãwo ŋu. 
\q1  
\v 10 Dukɔwo katã ɖe to ɖem, 
\q2 gake le Yehowa ƒe ŋkɔ me, 
\q2 metsrɔ̃ wo katã. 
\q1  
\v 11 Woɖe to ɖem, 
\q2 gake le Yehowa ƒe ŋkɔ me, 
\q2 metsrɔ̃ wo katã. 
\q1  
\v 12 Woƒo kɔ ɖe ŋunye abe anyiwo ene, 
\q2 gake wo nu va yi kaba abe ŋuvedzo ene; 
\q2 ɛ̃, Yehowa ƒe ŋkɔ mee metsrɔ̃ wo le. 
\q1  
\v 13 Wotu asim do ɖe megbe, 
\q2 eye medze anyi kloe, 
\q2 gake Yehowa xɔ nam. 
\q1  
\v 14 Yehowae nye nye ŋusẽ kple nye ha, 
\q2 eye wòzu nye xɔname. 
\b  
\q1  
\v 15 Aseyetsotso kple dziɖuɣli le ɖiɖim 
\q2 le ame dzɔdzɔewo ƒe agbadɔ me be, 
\q1 “Yehowa ƒe nuɖusi wɔ nu dzɔatsuwo! 
\q2  
\v 16 Yehowa ƒe nuɖusi le dzi bobobo! 
\q2 Yehowa ƒe nuɖusi wɔ nu dzɔatsuwo!” 
\q1  
\v 17 Nyemaku o, 
\q2 ke boŋ manɔ agbe, 
\q2 eye maɖe gbeƒã nu siwo Yehowa wɔ. 
\q1  
\v 18 Yehowa he to nam vevie, 
\q2 gake metsɔm de asi na ku o. 
\q1  
\v 19 Miʋu dzɔdzɔenyenye ƒe agbowo nam, 
\q2 mage ɖe eme, eye mada akpe na Yehowa. 
\q1  
\v 20 Esiae nye Yehowa ƒe agbo, 
\q2 afi si dzɔdzɔetɔwo ato age ɖe eme. 
\q1  
\v 21 Mada akpe na wò, 
\q2 elabena èɖo tom, eye nèzu nye xɔname. 
\b  
\q1  
\v 22 Kpe si xɔtulawo gbe la, 
\q2 eyae va zu dzogoedzikpe. 
\q1  
\v 23 Yehowae wɔ esia, 
\q2 eye wònye nukunu le míaƒe ŋkume. 
\q1  
\v 24 Esia nye ŋkeke si Yehowa wɔ, 
\q2 mina míakpɔ dzidzɔ, atso aseye le eme. 
\b  
\q1  
\v 25 O! Yehowa, ɖe mí, o Yehowa, 
\q2 na wòadze edzi na mí dzro. 
\b  
\q1  
\v 26 Woayra ame si gbɔna le Yehowa ƒe ŋkɔ me. 
\q2 Míeyra wò tso Yehowa ƒe aƒe me. 
\q1  
\v 27 Yehowae nye Mawu, 
\q2 eye wòna eƒe kekeli klẽ ɖe mía dzi. 
\q1 Mitsɔ miaƒe atilɔwo ɖe asi ne 
\q2 miage ɖe ŋkekenyuiɖulawo ƒe 
\q2 hame ayi ɖe keke vɔsamlekpui la ƒe dzowo gbɔ. 
\b  
\q1  
\v 28 Wòe nye nye Mawu, eya ta mada akpe na wò; 
\q2 wòe nye nye Mawu, eya ta mado wò ɖe dzi. 
\b  
\q1  
\v 29 Mida akpe na Yehowa, elabena eƒe dɔ me nyo, 
\q2 eye eƒe lɔlɔ̃ li tegbetegbe. 
\c 119  
\cl Psalmo 119 
\qa א Aleph 
\q1  
\v 1 Woayra ame siwo kpɔtsɔtsɔ mele woƒe mɔwo ŋu o, 
\q2 ame siwo zɔna ɖe Yehowa ƒe se la nu. 
\q1  
\v 2 Woayra ame siwo léa eƒe ɖoɖowo me ɖe asi, 
\q2 eye wodinɛ kple woƒe dzi blibo. 
\q1  
\v 3 Womewɔa vɔ̃ aɖeke o; 
\q2 ke boŋ wozɔna le eƒe mɔwo dzi. 
\q1  
\v 4 Èwɔ se siwo dzi wòle be 
\q2 woawɔ ɖo blibo la da ɖi. 
\q1  
\v 5 O! Ɖe nye mɔwo li ke sesĩe 
\q2 le wò sewo dzi wɔwɔ me la, anyo ŋutɔ. 
\q1  
\v 6 Ekema ŋu makpem ne mebu wò sewo katã ŋu o. 
\q1  
\v 7 Makafu wò le dzi dzɔdzɔe me, 
\q2 ne mele wò se dzɔdzɔeawo srɔ̃m. 
\q1  
\v 8 Mawɔ ɖe wò sededewo dzi, 
\q2 eya ta mègagblẽm ɖi keŋkeŋ o. 
\qa ב Beth 
\q1  
\v 9 Aleke ɖekakpui awɔ, 
\q2 be eƒe mɔ dzi nanɔ dzadzɛe ɣe sia ɣi? 
\q2 To agbenɔnɔ ɖe wò nya la nu mee. 
\q1  
\v 10 Madi wò kple nye dzi blibo, 
\q2 eya ta mègana matra tso wò sewo gbɔ o. 
\q1  
\v 11 Meɣla wò nya ɖe nye dzi me, 
\q2 be nyemawɔ nu vɔ̃ ɖe ŋuwò o. 
\q1  
\v 12 O! Yehowa, woakafu wò ɖaa; 
\q2 fia wò sededewom. 
\q1  
\v 13 Matsɔ nye nu axlẽ se siwo katã 
\q2 do tso wò nu me la afia. 
\q1  
\v 14 Melé wò ɖoɖowo me ɖe asi dzidzɔtɔe, 
\q2 abe ale si ame kpɔa dzidzɔ ɖe 
\q2 kesinɔnu gbogbowo ŋu ene. 
\q1  
\v 15 Mede ŋugble le wò ɖoɖowo ŋu, 
\q2 eye melé ŋku ɖe wò mɔwo ŋu. 
\q1  
\v 16 Wò sededewo doa dzidzɔ nam, 
\q2 nyemaŋlɔ wò nya la be o. 
\qa ג Gimel 
\q1  
\v 17 Wɔ nyui na wò dɔla, be manɔ agbe. 
\q2 Mawɔ wò nya la dzi. 
\q1  
\v 18 Ʋu nye ŋkuwo be makpɔ 
\q2 nukunuwo le wò se la me. 
\q1  
\v 19 Amedzroe menye le anyigba dzi, 
\q2 eya ta mègaɣla wò sededewo ɖem o. 
\q1  
\v 20 Nu te nye luʋɔ ŋu, 
\q2 le wò sewo yometiti ɣe sia ɣi ta. 
\q1  
\v 21 Èka mo na dadalawo, 
\q2 ame siwo woƒo fi de, 
\q2 eye wotra tso wò sewo gbɔ. 
\q1  
\v 22 Ɖe ŋukpe kple vlododo ɖa le ŋunye, 
\q2 elabena melé wò sewo me ɖe asi. 
\q1  
\v 23 Togbɔ be dziɖulawo nɔ anyi ɖe teƒe ɖeka, 
\q2 eye wole ŋunye gblẽm hã la, 
\q2 wò dɔla ade ŋugble le wò sededewo ŋu. 
\q1  
\v 24 Wò ɖoɖowo dzɔa dzi nam; 
\q2 wonye nye aɖaŋuɖolawo. 
\qa ד Daleth 
\q1  
\v 25 Wotsɔm mlɔ anyigba le ke me, 
\q2 kpɔ nye agbe ta le wò nya la nu. 
\q1  
\v 26 Mexlẽ nye mɔwo fia, eye nèɖo tom. 
\q2 Fia wò sededewom. 
\q1  
\v 27 Na mase wò sewo ƒe nufiafia gɔme; 
\q2 ekema made ŋugble le wò nukunuwo ŋu. 
\q1  
\v 28 Nuxaxa na nye luʋɔ gbɔdzɔ; 
\q2 do ŋusẽm le wò nya la nu. 
\q1  
\v 29 Ɖem le alakpamɔwo dzi, 
\q2 eye nàve nunye to wò se la dzi. 
\q1  
\v 30 Metia nyateƒe ƒe mɔ, 
\q2 eye nye dzi ku ɖe wò sewo ŋu. 
\q1  
\v 31 Meku ɖe wò sewo ŋu vevie, 
\q2 o Yehowa, eya ta mègana ŋu nakpem o. 
\q1  
\v 32 Mele du dzi le wò sewo ƒe mɔ dzi, 
\q2 elabena èna nye dzi gbɔ ɖe me. 
\qa ה He 
\q1  
\v 33 O, Yehowa, fia ale si madze wò sededewo yomee lam, 
\q2 ekema malé wo me ɖe asi va se ɖe nuwuwu. 
\q1  
\v 34 Na gɔmesesem, ekema malé wò se la me ɖe asi, 
\q2 eye mawɔ edzi kple nye dzi blibo. 
\q1  
\v 35 Dam ɖe wò sededewo ƒe mɔ dzi, 
\q2 elabena afi ma mekpɔa dzidzɔ le. 
\q1  
\v 36 Trɔ nye dzi ɖe wò sewo ŋu, 
\q2 ke menye ɖe ɖokuitɔdidi ƒe viɖe ŋu o. 
\q1  
\v 37 Ɖe nye ŋku ɖa le nu maɖinuwo ŋu, 
\q2 eye nàɖe nye agbe le wò nya la nu. 
\q1  
\v 38 Wɔ wò ŋugbedodo la dzi na wò dɔla, 
\q2 ale be woavɔ̃ wò. 
\q1  
\v 39 Ɖe ŋukpe si vɔ̃m mele la ɖa, 
\q2 elabena wò sewo nyo. 
\q1  
\v 40 Mele wò sewo dim vevie ŋutɔ! 
\q2 Le wò dzɔdzɔenyenye ta, ɖe nye agbe. 
\qa ו Waw 
\q1  
\v 41 O! Yehowa, wò lɔlɔ̃ si meʋãna o 
\q2 la neva gbɔnye; 
\q1 nenema kee nye wò xɔname hã 
\q2 le wò ŋugbedodo la nu, 
\q1  
\v 42 ekema maɖo eŋu na ame si le alɔme ɖem le ŋunye, 
\q2 elabena meka ɖe wò nya dzi. 
\q1  
\v 43 Mègaɖe nyateƒe ƒe nya la le nye nu me o, 
\q2 elabena meda nye mɔkpɔkpɔ ɖe wò sewo dzi. 
\q1  
\v 44 Mawɔ ɖe wò se la dzi ɣe sia ɣi, 
\q2 tso mavɔ me yi ɖe mavɔ me. 
\q1  
\v 45 Mazɔ le ablɔɖe me, 
\q2 elabena medi wò ɖoɖowo yomemɔ. 
\q1  
\v 46 Maƒo nu tso wò sewo ŋu 
\q2 le fiawo ŋkume, eye ŋu makpem o. 
\q1  
\v 47 Wò sededewo doa dzidzɔ nam, 
\q2 elabena melɔ̃a wo. 
\q1  
\v 48 Medo nye asiwo ɖe dzi na wò sedede siwo melɔ̃ la, 
\q2 eye mede ŋugble le wò sededewo ŋu. 
\qa ז Zayin 
\q1  
\v 49 Ɖo ŋku nya si nègblɔ na wò dɔla la dzi, 
\q2 elabena ètsɔ mɔkpɔkpɔ de menye. 
\q1  
\v 50 Esiae nye nye akɔfafa le nye fukpekpe me, 
\q2 be wò ŋugbedodo ɖe nye agbe. 
\q1  
\v 51 Dadalawo ɖua fewu le ŋunye faa, 
\q2 gake nyemetrɔ le wò se la yome o. 
\q1  
\v 52 O! Yehowa, meɖo ŋku wò blemasewo dzi, 
\q2 elabena mekpɔa akɔfafa le wo me. 
\q1  
\v 53 Ŋɔdzi lém le ame vɔ̃ɖiwo ta, 
\q2 ame siwo gbe nu le wò se la gbɔ. 
\q1  
\v 54 Afi sia afi si medze la, 
\q2 wò sewo nyea nye ha ƒe tanya. 
\q1  
\v 55 O! Yehowa, le zã me la, meɖoa ŋku wò ŋkɔ dzi, 
\q2 eye malé wò sewo me ɖe asi. 
\q1  
\v 56 Esia nye tɔnye gome, 
\q2 elabena mewɔa wò ɖoɖowo dzi. 
\qa ח Heth 
\q1  
\v 57 O! Yehowa, wòe nye nye gomekpɔkpɔ, 
\q2 eya ta medo ŋugbe be mawɔ ɖe wò nyawo dzi. 
\q1  
\v 58 Medi wò ŋkume kple nye dzi blibo, 
\q2 eya ta ve nunye le wò ŋugbedodo la nu. 
\q1  
\v 59 Melé ŋku ɖe nye mɔwo ŋu, 
\q2 eye metrɔ nye afɔ ɖe wò nuɖoanyiwo ŋu. 
\q1  
\v 60 Maɖe abla, nyemahe ɖe megbe o, 
\q2 be mawɔ ɖe wò sededewo dzi. 
\q1  
\v 61 Togbɔ be ame vɔ̃ɖiwo blam kple ka hã la, 
\q2 nyemaŋlɔ wò sewo be o. 
\q1  
\v 62 Mefɔ le zãtitina be mada akpe 
\q2 na wò ɖe wò se dzɔdzɔeawo ta. 
\q1  
\v 63 Menye xɔ̃ na ame siwo katã vɔ̃a wò 
\q2 kple ame siwo katã dze wò sewo yome. 
\q1  
\v 64 O! Yehowa, anyigba dzi yɔ fũu 
\q2 kple wò lɔlɔ̃, eya ta fia wò sededewom. 
\qa ט Teth 
\q1  
\v 65 O! Yehowa, wɔ nyui na wò dɔla 
\q2 le wò nya la nu. 
\q1  
\v 66 Fia nunya kple afia nyui tsotsom, 
\q2 elabena mexɔ wò sededewo dzi se. 
\q1  
\v 67 Hafi woava aka hiãm la, 
\q2 metra mɔ, ke azɔ la, meɖo to wò nya la. 
\q1  
\v 68 Wò la, ènyo, eye nu si nèwɔ la hã nyo, 
\q2 eya ta fia wò sededewom. 
\q1  
\v 69 Togbɔ be dadalawo tsɔ alakpa sisi ɖe ŋunye keŋ hã la, 
\q2 melé wò sewo me ɖe asi kple nye dzi blibo. 
\q1  
\v 70 Woƒe dzi ku atri, eye megasea naneke o, 
\q2 ke nye la, mekpɔa dzidzɔ ɖe wò se la ŋu. 
\q1  
\v 71 Enyo be woka hiãm, 
\q2 ale be mate ŋu asrɔ̃ wò sededewo. 
\q1  
\v 72 Se siwo do tso wò nu me la xɔ asi nam wu 
\q2 sika kple klosalo akpewo. 
\qa י Yodh 
\q1  
\v 73 Wò asie wɔm, eye wò asimee medo tso; 
\q2 tsɔ gɔmesese nam, be masrɔ̃ wò sededewo. 
\q1  
\v 74 Na ame siwo vɔ̃a wò la nakpɔ dzidzɔ ne wokpɔm, 
\q2 elabena metsɔ nye mɔkpɔkpɔ da ɖe wò nya la dzi. 
\q1  
\v 75 O! Yehowa, menya be wò sewo le dzɔdzɔe, 
\q2 eye le wò dzɔdzɔenyenye la me, nèka hiãm. 
\q1  
\v 76 Na be wò lɔlɔ̃ si meʋãna o la nanye nye akɔfafa, 
\q2 le ŋugbe si nèdo na wò dɔla la ta. 
\q1  
\v 77 Wò dɔmenyo neɖiɖi ɖe dzinye, be manɔ agbe, 
\q2 elabena wò se lae nye nye dzidzɔ. 
\q1  
\v 78 Na ŋu nakpe dadala, 
\q2 le esi wòwɔ vɔ̃ ɖe ŋunye, nye nanekemawɔmawɔe; 
\q2 ke nye la, made ŋugble le wò ɖoɖowo ŋu. 
\q1  
\v 79 Na ame siwo vɔ̃a wò la natrɔ ɖe ŋunye, 
\q2 ame siwo se wò nuɖoanyiwo gɔme. 
\q1  
\v 80 Na kpɔtsɔtsɔ manɔ nye dzi ŋuti ɖe wò sededewo ŋu o, 
\q2 ale be ŋu makpem o. 
\qa כ Kaph 
\q1  
\v 81 Nu ti kɔ na nye luʋɔ le wò ɖeɖedidi vevie ta, 
\q2 gake metsɔ nye mɔkpɔkpɔ da ɖe wò nya la dzi. 
\q1  
\v 82 Nu te nye ŋkuwo ŋu, 
\q2 le mɔkpɔkpɔ na wò ŋugbedodo la ta. 
\q2 Megblɔ be, “Ɣe ka ɣi nàfa akɔ nam?” 
\q1  
\v 83 Togbɔ be mele abe waingolo 
\q2 le dzudzɔ me ene hã la, 
\q2 nyemeŋlɔ wò sededewo be o. 
\q1  
\v 84 Va se ɖe ɣe ka ɣi wò dɔla alala? 
\q2 Ɣe ka ɣi nàhe to na yonyemetilawo? 
\q1  
\v 85 Dadalawo ɖe ʋe ɖi nam, 
\q2 nu si tsi tsitre ɖe wò se la ŋu. 
\q1  
\v 86 Wò sededewo katã nye nu si dzi woaka ɖo; 
\q2 kpe ɖe ŋunye, 
\q2 elabena amewo ti yonyeme susumanɔmetɔe. 
\q1  
\v 87 Esusɔ vie woɖem ɖa le anyigba dzi kloe, 
\q2 gake nyemeŋlɔ wò ɖoɖowo be o. 
\q1  
\v 88 Le wò lɔlɔ̃ la ta, kpɔ nye agbe ta, 
\q2 eye maɖo to se siwo do tso wò nu me. 
\qa ל Lamedh 
\q1  
\v 89 O! Yehowa, wò nya la nye nya mavɔ, 
\q2 eli ke goŋgoŋgoŋ ɖe dziƒo. 
\q1  
\v 90 Wò nuteƒewɔwɔ li le dzidzimewo katã; 
\q2 wòe ɖo anyigba gɔme anyi, eye wòli ke ɖaa. 
\q1  
\v 91 Wò sewo gali va se ɖe egbe, 
\q2 elabena wòe nuwo katã subɔna. 
\q1  
\v 92 Nenye ɖe wò se la menye nye dzidzɔ o la, 
\q2 anye ne metsrɔ̃ le nye hiãkame me. 
\q1  
\v 93 Nyemaŋlɔ wò ɖoɖowo be o, 
\q2 elabena èkpɔ nye agbe ta to wo dzi. 
\q1  
\v 94 Ɖem, elabena tɔwò menye, 
\q2 elabena medi wò ɖoɖowo ƒe mɔ. 
\q1  
\v 95 Ame vɔ̃ɖiwo le lalam be woatsrɔ̃m, 
\q2 ke nye la, madzro wò sewo me. 
\q1  
\v 96 Mekpɔ seɖoƒe na nu de blibo ɖe sia ɖe, 
\q2 gake wò sededewo ya la, seɖoƒe meli na wo o. 
\qa מ Mem 
\q1  
\v 97 O, ale gbegbe mehelɔ̃ wò se lae! 
\q2 Medea ŋugble le eŋuti ŋkeke blibo la. 
\q1  
\v 98 Wò sededewo wɔm nunyalae wu nye futɔwo katã, 
\q2 elabena wole gbɔnye ɖaa. 
\q1  
\v 99 Gɔmesese su asinye wu nye nufialawo katã, 
\q2 elabena medea ŋugble le wò ɖoɖowo ŋu. 
\q1  
\v 100 Gɔmesese le asinye wu dumegãwo, 
\q2 elabena mewɔ ɖe wò ɖoɖowo dzi. 
\q1  
\v 101 Meɖe nye afɔ ɖa le mɔ vɔ̃ ɖe sia ɖe dzi, 
\q2 ale be mawɔ ɖe wò nya la dzi. 
\q1  
\v 102 Nyemedzo le wò sewo gbɔ o, 
\q2 elabena wò ŋutɔe fia num. 
\q1  
\v 103 Wò nyawo vivia nunye ŋutɔ, 
\q2 eye wovivina le nye nu me wu anyitsi nyuitɔ! 
\q1  
\v 104 Gɔmesese su asinye to wò sewo dzi, 
\q2 eya ta metsri mɔ gɔglɔ̃ ɖe sia ɖe. 
\qa נ Nun 
\q1  
\v 105 Wò nya la nye akaɖi na nye afɔ 
\q2 kple kekeli na nye mɔ. 
\q1  
\v 106 Meka atam, eye meɖo kpe edzi be, 
\q2 wò se dzɔdzɔewo yome ko manɔ. 
\q1  
\v 107 Mekpe fu geɖe, 
\q2 eya ta o Yehowa, 
\q1 kpɔ nye agbe ta, 
\q2 le wò nya la nu. 
\q1  
\v 108 O! Yehowa, xɔ kafukafu si nye nu dzra ɖo ɖi la, 
\q2 eye nàfia wò sewom. 
\q1  
\v 109 Togbɔ be metsɔ nye agbe ɖo nye asiƒome enuenu hã la, 
\q2 nyemaŋlɔ wò se la be o. 
\q1  
\v 110 Ame vɔ̃ɖi la tre mɔ nam, 
\q2 gake nyemetra tso wò nuɖoanyiwo gbɔ o. 
\q1  
\v 111 Wò ɖoɖowo nye nye domenyinu tegbee, 
\q2 elabena wonye nye dzi ƒe dzidzɔ. 
\q1  
\v 112 Nye dzi ku ɖe wò sededewo dzi 
\q2 wɔwɔ ŋu va se ɖe nuwuwu. 
\qa ס Samekh 
\q1  
\v 113 Melé fu susuevetɔwo, 
\q2 gake melɔ̃ wò se la. 
\q1  
\v 114 Wòe nye nye sitsoƒe kple nye akpoxɔnu, 
\q2 metsɔ nye mɔkpɔkpɔ de wò nya la me. 
\q1  
\v 115 Mite ɖa le gbɔnye, mi nu vlo wɔlawo, 
\q2 be mate ŋu alé nye Mawu ƒe sewo me ɖe asi! 
\q1  
\v 116 Lém ɖe asi le wò ŋugbedodo la nu, 
\q2 ekema manɔ agbe, eye mègana ŋu nakpem 
\q2 le nye mɔkpɔkpɔ me o. 
\q1  
\v 117 Lém ɖe te, ekema makpɔ ɖeɖe, 
\q2 eye ɣe sia ɣi made bubu wò sededewo ŋu. 
\q1  
\v 118 Ègbe nu le ame siwo katã tra mɔ tso 
\q2 wò sededewo gbɔ la gbɔ, 
\q2 elabena woƒe alakpadada nye nu dzodzro. 
\q1  
\v 119 Ègbe nu le ame vɔ̃ɖi siwo katã 
\q2 le anyigba dzi la gbɔ abe gbeɖuɖɔ ene, 
\q2 eya ta melɔ̃ wò nuɖoanyiwo. 
\q1  
\v 120 Nye lãme le ƒoƒom 
\q2 le vɔvɔ̃ na wò ta, 
\q2 eye nye mo wɔ yaa le wò sewo ta. 
\qa ע Ayin 
\q1  
\v 121 Mewɔ nu si dzɔ kple nu si le eteƒe, 
\q2 eya ta mègaɖe asi le ŋunye na 
\q2 ame siwo tem ɖe anyi la o. 
\q1  
\v 122 Kpɔ wò dɔla la ƒe dedinɔnɔ gbɔ, 
\q2 mègana dadalawo natem ɖe to o. 
\q1  
\v 123 Nu te nye ŋkuwo ŋu le wò ɖeɖedidi ta. 
\q1  
\v 124 Wɔ nu kple wò dɔla le wò lɔlɔ̃ ta, 
\q2 eye nàfia wò sededewom. 
\q1  
\v 125 Wò dɔlae menye, 
\q2 eya ta na sidzedzem, be mase wò nuɖoanyiwo gɔme. 
\q1  
\v 126 O! Yehowa, ɣeyiɣi de na wò be nàɖe afɔ, 
\q2 elabena wole wò sewo tum. 
\q1  
\v 127 Elabena melɔ̃ wò sewo wu 
\q2 sika kple sika nyuitɔ. 
\q1  
\v 128 Eye esi mebu wò ɖoɖowo katã be wole dzɔdzɔe ta la, 
\q2 metsri mɔ gɔglɔ̃ ɖe sia ɖe. 
\qa פ Pe 
\q1  
\v 129 Wò sewo nye nuku, 
\q2 eya ta meɖo to wo. 
\q1  
\v 130 Kekeli vana ne woʋu go wò nyawo, 
\q2 eye nugɔmesese sua ame gblɔewo gɔ̃ hã si. 
\q1  
\v 131 Meke nu ɖe te hele gbɔgbɔm fuxefuxe, 
\q2 le wò sewo dim vevie. 
\q1  
\v 132 Trɔ ɖe ŋunye, eye nàkpɔ nye nublanui 
\q2 abe ale si nèwɔnɛ ɖaa na 
\q2 ame siwo lɔ̃a wò ŋkɔ la ene. 
\q1  
\v 133 Na maɖe afɔ le wò nya la nu, 
\q2 eye mègana nu vɔ̃ aɖeke naɖu dzinye o. 
\q1  
\v 134 Ɖem tso amewo ƒe teteɖeanyi me, 
\q2 be mawɔ ɖe wò ɖoɖowo dzi. 
\q1  
\v 135 Na wò mo naklẽ na wò dɔla, 
\q2 eye nàfia wò sededewom. 
\q1  
\v 136 Aɖatsi le sisim le nye ŋkuwo me abe tɔʋu ene, 
\q2 elabena womewɔ wò sewo dzi o. 
\qa צ Tsadhe 
\q1  
\v 137 O! Yehowa, wò la, dzɔdzɔetɔe nènye, 
\q2 eye wò sewo hã le dzɔdzɔe. 
\q1  
\v 138 Nu siwo nèɖo anyi hã la le dzɔdzɔe, 
\q2 woaka ɖe wo dzi ɖikeke manɔmee. 
\q1  
\v 139 Dzo si metsɔ ɖe ŋuwò la na megbɔdzɔ, 
\q2 elabena nye futɔwo gbe nu le wò nyawo gbɔ. 
\q1  
\v 140 Wodo wò ŋugbedodowo katã kpɔ nyuie, 
\q2 eye wò dɔla lɔ̃ wo ŋutɔ. 
\q1  
\v 141 Togbɔ be wodo vlom, 
\q2 eye nyemele ɖeke me o hã la, 
\q2 nyemeŋlɔ wò ɖoɖowo be o. 
\q1  
\v 142 Wò dzɔdzɔenyenye li tso mavɔ me yi ɖe mavɔ me, 
\q2 eye wò se la hã nye nyateƒe. 
\q1  
\v 143 Fukpekpe kple xaxa va dzinye, 
\q2 gake wò sededewo doa dzidzɔ nam. 
\q1  
\v 144 Wò nuɖoanyiwo le dzɔdzɔe ɖaa, 
\q2 eya ta na gɔmesesem, be manɔ agbe. 
\qa ק Qoph 
\q1  
\v 145 O! Yehowa, mele yɔwòm kple nye dzi blibo, 
\q2 eya ta tɔ nam, eye mawɔ wò sededewo dzi. 
\q1  
\v 146 Wòe meyɔ, xɔ nam, 
\q2 eye malé wò ɖoɖoawo me ɖe asi. 
\q1  
\v 147 Mefɔ hafi ŋu ke, eye medo ɣli be woaxɔ nam, 
\q2 ke metsɔ nye mɔkpɔkpɔ da ɖe wò nya la dzi. 
\q1  
\v 148 Nye ŋkuwo le te le zã blibo la katã me, 
\q2 be made ŋugble le wò ŋugbedodowo ŋu. 
\q1  
\v 149 Se nye gbe, le wò lɔlɔ̃ la ta, 
\q2 O! Yehowa, ɖe nye agbe, 
\q2 le wò sewo ƒe ɖoɖo nu. 
\q1  
\v 150 Ame siwo le nu vɔ̃ɖiwo ɖom la gogo, 
\q2 gake wodidi tso wò se la gbɔ. 
\q1  
\v 151 O! Yehowa, ètsɔ ɖe gbɔnye ɖe! 
\q2 Wò sededewo katã hã nye nyateƒe. 
\q1  
\v 152 Mesrɔ̃ nu tso wò se la me gbe aɖe gbe ke, 
\q2 be èɖo wo gɔme anyi be woanɔ anyi 
\q2 tso mavɔ me yi ɖe mavɔ me. 
\qa ר Resh 
\q1  
\v 153 Kpɔ nye hiãtuame ɖa, eye nàɖem, 
\q2 elabena nyemeŋlɔ wò se la be o. 
\q1  
\v 154 Ʋli tanye, eye nàɖem, 
\q2 kpɔ nye agbe ta le wò ŋugbedodo la nu. 
\q1  
\v 155 Ɖeɖe le adzɔge na ame vɔ̃ɖiwo, 
\q2 elabena womedia wò sededewo ƒe mɔ o. 
\q1  
\v 156 O! Yehowa, wò nublanuikpɔkpɔ sɔ gbɔ, 
\q2 eya ta kpɔ nye agbe ta le wò sewo nu. 
\q1  
\v 157 Futɔ siwo ti yonyeme la sɔ gbɔ ŋutɔ, 
\q2 gake nyemetrɔ le wò ɖoɖowo yome o. 
\q1  
\v 158 Menyɔ ŋu xɔsemanɔsitɔwo, 
\q2 elabena womewɔa wò nya la dzi o. 
\q1  
\v 159 Kpɔ ale si melɔ̃ wò sewoe ɖa; 
\q2 eya ta o Yehowa, 
\q2 kpɔ nye agbe ta le wò lɔlɔ̃ la ta. 
\q1  
\v 160 Wò nyawo katã nye nyateƒe, 
\q2 eye wò dzɔdzɔenyenye ƒe sewo katã nye se mavɔwo. 
\qa ש Sin kple Shin 
\q1  
\v 161 Dziɖulawo tia nye agbe yome susumanɔŋutɔe, 
\q2 gake nye dzi dzo nyanyanya le wò nya la ta. 
\q1  
\v 162 Mekpɔ dzidzɔ le wò ŋugbedodo la me 
\q2 abe ame si ke ɖe afunyinu gbogbo aɖe ŋu ene. 
\q1  
\v 163 Metsri, eye menyɔ ŋu alakpa, 
\q2 ke melɔ̃ wò se la. 
\q1  
\v 164 Mekafua wò zi adre le ŋkeke me, 
\q2 le wò se dzɔdzɔeawo ta. 
\q1  
\v 165 Ame siwo lɔ̃a wò se la, 
\q2 kpɔa ŋutifafa gã aɖe, 
\q2 eye naneke mawɔ wo woakli nu o. 
\q1  
\v 166 O! Yehowa, mele wò xɔxɔ lalam, 
\q2 eye manɔ wò sededewo yome. 
\q1  
\v 167 Mawɔ ɖe wò nuɖoanyiwo dzi, 
\q2 elabena melɔ̃ wo ŋutɔ. 
\q1  
\v 168 Mawɔ ɖe wò sewo kple ɖoɖowo dzi, 
\q2 elabena nye mɔwo katã le nyanya na wò. 
\qa ת Taw 
\q1  
\v 169 O! Yehowa, nye ɣlidodo nede gbɔwò, 
\q2 tsɔ gɔmesese nam le wò nya la nu. 
\q1  
\v 170 Nye gbedodoɖawo nede gbɔwò; 
\q2 ɖem le wò ŋugbedodo la ta. 
\q1  
\v 171 Nye nuyiwo negbã go kple kafukafu, 
\q2 elabena èfia wò sededewom. 
\q1  
\v 172 Nye aɖe adzi ha le wò nya la ŋu, 
\q2 elabena wò sededewo katã le dzɔdzɔe. 
\q1  
\v 173 Wò asi nenɔ klalo akpe ɖe ŋunye, 
\q2 elabena metia wò sewo. 
\q1  
\v 174 O! Yehowa, wò xɔname le dzroyem vevie ŋutɔ, 
\q2 elabena wò se lae nye nye dzidzɔ. 
\q1  
\v 175 Na manɔ agbe, ne makafu wò, 
\q2 eye na wò sewo nalém ɖe te. 
\q1  
\v 176 Metra mɔ abe alẽ bubu ene. 
\q2 Di wò dɔla la, 
\q2 elabena nyemeŋlɔ wò sededewo be o. 
\c 120  
\cl Psalmo 120 
\d Mɔzɔha. 
\q1  
\v 1 Meyɔ Yehowa le nye xaxa me, eye wòtɔ nam. 
\q1  
\v 2 O! Yehowa, ɖem, 
\q2 tso aʋatsonuyiwo kple alakpaɖewo ƒe asi me. 
\b  
\q1  
\v 3 O! Alakpaɖe, nu ka wòawɔ na wò, 
\q2 eye nu ka wòatsɔ akpee na wò? 
\q1  
\v 4 Atsɔ aʋawɔla ƒe aŋutrɔ ɖaɖɛwo ahe to na 
\q2 wòe kpe ɖe yɔkuti ƒe dzoka xɔxɔwo ŋuti. 
\b  
\q1  
\v 5 Baba nam be mele Mesek, 
\q2 eye mele Kedar ƒe agbadɔwo me! 
\q1  
\v 6 Menɔ ame siwo lé fu ŋutifafa 
\q2 la dome wòdidi fũu akpa. 
\q1  
\v 7 Ŋutifafamee menye, 
\q2 gake ne meƒo nu la, woawo kpea aʋa. 
\c 121  
\cl Psalmo 121 
\d Mɔzɔha. 
\q1  
\v 1 Mewu mo dzi ɖe togbɛawo ŋu, 
\q2 afi ka nye xɔname atso ava? 
\q1  
\v 2 Nye xɔname atso Yehowa, 
\q2 ame si wɔ dziƒo kple anyigba la gbɔ. 
\b  
\q1  
\v 3 Mana wò afɔ naɖiɖi o, 
\q2 eya ame si dzɔa ŋuwò la madɔ akɔlɔ̃e o. 
\q1  
\v 4 Vavã, eya ame si dzɔa Israel ŋu la, 
\q2 madɔ akɔlɔ̃e loo, alo adɔ alɔ̃ o. 
\b  
\q1  
\v 5 Yehowae nye tawòkpɔla, 
\q2 Yehowae nye wò vɔvɔli le wò nuɖusime 
\q1  
\v 6 eya ta ɣe maɖu wò le ŋkeke me loo, 
\q2 alo ɣleti le zã me o. 
\b  
\q1  
\v 7 Yehowa aɖe wò le vɔ̃wo katã me, 
\q2 eye wòakpɔ wò agbe ta. 
\q1  
\v 8 Yehowa adzɔ wò vava kple wò dzodzo ŋuti, 
\q2 fifia yi ɖase mavɔmavɔ me. 
\c 122  
\cl Psalmo 122 
\d David ƒe mɔzɔha. 
\q1  
\v 1 Mekpɔ dzidzɔ kple ame siwo gblɔ nam be, 
\q2 “Mina míayi Yehowa ƒe aƒe me.” 
\q1  
\v 2 O! Yerusalem, 
\q2 míaƒe afɔwo le wò agbowo nu. 
\b  
\q1  
\v 3 Wotso Yerusalem, eye nèle abe du si tsyia ɖe 
\q2 wo nɔewo nu ene. 
\q1  
\v 4 Afi ma to vovovoawo yina, 
\q2 Yehowa ƒe toawo, be woakafu Yehowa, 
\q2 le ɖoɖo si wòna Israel nu. 
\q1  
\v 5 Afi ma woɖo ʋɔnudrɔ̃zikpuiwo ɖo, 
\q2 David ƒe aƒe la ƒe fiazikpuiwo. 
\b  
\q1  
\v 6 Mido gbe ɖa, abia ŋutifafa na Yerusalem be, 
\q2 “Ame siwo lɔ̃ wò la nenɔ dedie. 
\q1  
\v 7 Ŋutifafa nenɔ wò gliwo me 
\q2 kple dedinɔnɔ le wò fiasãwo me.” 
\q1  
\v 8 Le nɔvinye ŋutsuwo kple xɔ̃nyewo ta, magblɔ be, 
\q2 “Ŋutifafa nenɔ mewò.” 
\q1  
\v 9 Le Yehowa, 
\q2 míaƒe Mawu la ƒe aƒe la ta, madi dzidzedze na wò. 
\c 123  
\cl Psalmo 123 
\d Mɔzɔha. 
\q1  
\v 1 Mewu mo dzi na wò, 
\q2 wò ame si ƒe fiazikpui le dziƒo. 
\q1  
\v 2 Abe ale si kluviwo kpɔa woƒe aƒetɔ ƒe asinu 
\q2 kple kosiviwo ƒe ŋku nɔa woƒe aƒenɔ ƒe asinu kpɔmii ene la, 
\q1 nenemae míele Yehowa, míaƒe Mawu la 
\q2 ƒe asinu kpɔmii, va se ɖe esime wòakpɔ nublanui na mí. 
\b  
\q1  
\v 3 O! Yehowa, kpɔ nublanui na mí, 
\q2 O! Kpɔ míaƒe nublanui, 
\q2 elabena míenɔ te ɖe vlododo nu eteƒe didi. 
\q1  
\v 4 Míetsɔ dadalawo ƒe alɔmeɖeɖe gbogboawo, 
\q2 eye míenɔ te ɖe ɖokuiŋudzelawo 
\q2 ƒe vlodoame gbogboawo nu eteƒe didi. 
\c 124  
\cl Psalmo 124 
\d David ƒe mɔzɔha. 
\q1  
\v 1 Ne menye Yehowae le mía dzi o la, 
\q2 Israel negblɔ be, 
\q1  
\v 2 “Ɖe menye Yehowae le mía dzi o la, 
\q2 esi amegbetɔwo tso ɖe mía ŋu, 
\q1  
\v 3 eye woƒe dɔmedzoe bi ɖe mía ŋu la, 
\q2 anye ne womi mí agbagbee, 
\q1  
\v 4 anye ne tsi ɖe mí 
\q2 hesi to mía dzi, 
\q1  
\v 5 anye ne tɔ dzeagbowo 
\q2 kplɔ mí dzoe.” 
\b  
\q1  
\v 6 Woakafu Yehowa, 
\q2 ame si meɖe mɔ be woavuvu mí kple woƒe aɖu o. 
\q1  
\v 7 Míesi abe xevi si do le mɔtrela ƒe mɔka me la ene; 
\q2 mɔka la tso, eye míesi dzo. 
\q1  
\v 8 Míaƒe xɔname le Yehowa, 
\q2 dziƒo kple anyigba Wɔla la gbɔ. 
\c 125  
\cl Psalmo 125 
\d Mɔzɔha. 
\q1  
\v 1 Ame siwo ɖoa dzi ɖe Yehowa ŋu la 
\q2 le abe Zion to si meʋãna o, 
\q2 eye wònɔa anyi ɖikaa la ene. 
\q1  
\v 2 Abe ale si towo ƒo xlã Yerusalem ene la, 
\q2 nenema Yehowa ƒo xlã eƒe dukɔ lae, 
\q2 tso fifia yi ɖe mavɔ me. 
\b  
\q1  
\v 3 Ame vɔ̃ɖiwo ƒe fiatikplɔ manɔ anyigba si 
\q2 woka na ame dzɔdzɔewo la dzi o, 
\q1 ne menye nenema o la, 
\q2 ame dzɔdzɔewo ava tsɔ woƒe asi awɔ nu vɔ̃ɖii. 
\b  
\q1  
\v 4 O! Yehowa, wɔ nyui na nu nyui wɔlawo, 
\q2 ame siwo ƒe dzi to mɔ ɖeka. 
\q1  
\v 5 Ke ame siwo trɔ ɖe mɔ gɔglɔ̃ dzi la, 
\q2 Yehowa atsɔ wo aƒu gbe, kpe ɖe nu vɔ̃ɖi wɔlawo ŋu. 
\b  
\q1 Ŋutifafa nenɔ Israel dzi. 
\c 126  
\cl Psalmo 126 
\d Mɔzɔha. 
\q1  
\v 1 Esi Yehowa kplɔ aboyomeyilawo gbɔe va Zion la, 
\q2 míenɔ abe drɔ̃ekulawo ene. 
\q1  
\v 2 Nukoko yɔ míaƒe nu me fũu, 
\q2 eye dzidzɔhawo yɔ míaƒe aɖewo dzi. 
\q1 Tete wogblɔ le dukɔwo dome be, 
\q2 “Yehowa wɔ nu gã na wo ameawo.” 
\q1  
\v 3 Nyateƒee, Yehowa wɔ nu gãwo na mí, 
\q2 eya ta dzidzɔ yɔ mía me. 
\b  
\q1  
\v 4 O! Yehowa, gaɖo míaƒe nunyonamewo te, 
\q2 abe tɔʋu si le Gbegbe ene. 
\q1  
\v 5 Ame siwo ƒã nu kple aɖatsi la, 
\q2 axa nu kple dzidzɔhawo. 
\q1  
\v 6 Ame si do go le nukuwo ƒãm kple aɖatsi la 
\q2 atrɔ agbɔ kple dzidzɔhawo, atsɔ lu bablawo agbɔe. 
\c 127  
\cl Psalmo 127 
\d Solomo ƒe mɔzɔha. 
\q1  
\v 1 Ne Yehowa metu xɔ o la, 
\q2 etulawo le agbagba dzem dzodzro. 
\q1 Ne Yehowa medzɔ du la ŋu o la, 
\q2 dzodzroe dua ŋu dzɔlawo le ŋudzɔ. 
\q1  
\v 2 Dzodzroe miefɔna kaba le ŋdi, 
\q2 henɔa agbagba dzem 
\q1 le nu si miaɖu la ŋuti va se ɖe fiẽ, 
\q2 ke ame siwo wòlɔ̃na la, 
\q2 enana wodɔa alɔ̃ ɖina ɖe eme. 
\b  
\q1  
\v 3 Viŋutsuwo nye domenyinu tso Yehowa gbɔ, 
\q2 eye viwo nye fetu tso eya amea gbɔ. 
\q1  
\v 4 Viŋutsu siwo ame aɖe dzi le eƒe ɖekakpuime la, 
\q2 le abe aŋutrɔ le kalẽtɔ si ene. 
\q1  
\v 5 Woayra ŋutsu si ƒe daku me wole fũu. 
\q2 Ŋu makpe wo o, 
\q2 ne woawo kple futɔwo wɔ avu le agbo la me. 
\c 128  
\cl Psalmo 128 
\d Mɔzɔha. 
\q1  
\v 1 Woayra ame siwo vɔ̃a Yehowa, 
\q2 ame siwo zɔna le eƒe mɔwo dzi. 
\q1  
\v 2 Àɖu wò ŋutɔ wò dɔwɔwɔ ƒe kutsetse, 
\q2 eye yayra kple dzidzedze anye tɔwò gome. 
\q1  
\v 3 Srɔ̃wò anɔ abe wainka si tse kplanyaa la ene anɔ aƒewò me; 
\q2 viwò ŋutsuwo anɔ abe amitiɖɔmi ene le wò kplɔ̃ ŋu godoo. 
\q1  
\v 4 Kpɔ ɖa, aleae woyraa 
\q2 ŋutsu si vɔ̃a Yehowa lae. 
\b  
\q1  
\v 5 Yehowa neyra wò tso Zion le wò agbemeŋkekewo katã me, 
\q2 eye àkpɔ Yerusalem ƒe dzidzedze. 
\q1  
\v 6 Ànɔ agbe akpɔ viwòwo ƒe viwo. 
\q2 Ŋutifafa nenɔ Israel dzi. 
\c 129  
\cl Psalmo 129 
\d Mɔzɔha. 
\q1  
\v 1 Wotem ɖe anyi ale gbegbe tso nye ɖekakpuime ke. 
\q2 Israel negblɔ be, 
\q1  
\v 2 “Wotem ɖe anyi ale gbegbe tso nye ɖekakpuime ke, 
\q2 gake womeɖu dzinye o. 
\q1  
\v 3 Agbleŋlɔlawo ŋlɔ nye dzimegbe, 
\q2 eye woɖe boliƒowo wodidi, 
\q1  
\v 4 gake Yehowa nye dzɔdzɔetɔ, 
\q2 etso kam tso ame vɔ̃ɖiwo ƒe babla me.” 
\b  
\q1  
\v 5 Na be ame siwo katã tsri Zion la, 
\q2 nagbugbɔ ɖe megbe kple ŋukpe. 
\q1  
\v 6 Na be woanɔ abe gbe si wotsɔ gbã xɔe ene, 
\q2 gbe si yrɔna, hafi ayi miemie ge. 
\q1  
\v 7 Ale gbetsola mate ŋu atsoe alɔ ɖe asime loo, 
\q2 alo ame si le elɔm la, nayi elɔ ge ɖe abɔdome o. 
\q1  
\v 8 Ame siwo to afi ma yi la megagblɔ be, 
\q2 “Yehowa ƒe yayra nenɔ dziwò; 
\q2 míeyra wò le Yehowa ƒe ŋkɔ me” o. 
\c 130  
\cl Psalmo 130 
\d Mɔzɔha. 
\q1  
\v 1 O! Yehowa, mele koko ƒom na wò tso nye dzi me ke. 
\q1  
\v 2 O! Aƒetɔ, ɖo to nye gbe. 
\q2 Wò to nenɔ te nàse nye nublanuiɣli. 
\b  
\q1  
\v 3 O! Yehowa, ne àlé amewo 
\q2 ƒe nu vɔ̃wo ɖe agbalẽ me ada ɖi la, 
\q2 O! Aƒetɔ, ame ka ate ŋu anɔ te? 
\q1  
\v 4 Ke wò la, tsɔtsɔke le gbɔwò, 
\q2 eya ta wovɔ̃a wò ɖo. 
\b  
\q1  
\v 5 Mele Yehowa ƒe asinu kpɔm, 
\q2 nye luʋɔ le lalam, 
\q2 eye metsɔ nye mɔkpɔkpɔ da ɖe eƒe nya dzi. 
\q1  
\v 6 Nye luʋɔ le lalam na Aƒetɔ la wu 
\q2 ale si zãɖialawo kpɔa mɔ na ŋu ƒe keke; 
\q2 mebe wu ale si zãɖialawo kpɔa mɔ na ŋu ƒe keke. 
\b  
\q1  
\v 7 O! Israel, tsɔ wò mɔkpɔkpɔ da ɖe Yehowa dzi, 
\q2 elabena lɔlɔ̃ matrɔ le Yehowa si, 
\q2 eye ɖeɖe blibo le eya amea gbɔ. 
\q1  
\v 8 Eya ŋutɔ aɖe Israel 
\q2 tso eƒe nu vɔ̃wo katã me. 
\c 131  
\cl Psalmo 131 
\d David ƒe Mɔzɔha. 
\q1  
\v 1 O! Yehowa, dada mele nye dzi me o, 
\q2 eye ŋku gã hã mele tanye o. 
\q1 Nyemetsɔa ɖeke le nya gãwo me loo, 
\q2 alo ƒoa ta ɖe nu siwo wɔ nuku nam akpa la me o, 
\q1  
\v 2 gake mena nye luʋɔ zi ɖoɖoe, 
\q2 heli kpoo abe ale si ɖevi si ɖi no la nɔa dadaa ƒe akɔnu ene, 
\q2 eye nye luʋɔ le abe ɖevi si ɖi no la ene. 
\b  
\q1  
\v 3 O! Israel, tsɔ wò mɔkpɔkpɔ da ɖe Yehowa dzi, 
\q2 tso fifia yi ɖase ɖe mavɔmavɔ me ke. 
\c 132  
\cl Psalmo 132 
\d Mɔzɔha. 
\q1  
\v 1 O! Yehowa, ɖo ŋku David 
\q2 kple fukpekpe siwo katã me wòto la dzi. 
\b  
\q1  
\v 2 Eka atam na Yehowa, eye wòɖe adzɔgbe 
\q2 na Yakob ƒe Ŋusẽtɔ la be, 
\q1  
\v 3 “Nyemage ɖe aƒenye me, 
\q2 alo aɖamlɔ nye aba dzi o. 
\q1  
\v 4 Nyemana nye ŋkuwo nadɔ alɔ̃, 
\q2 alo nye aɖaba nadɔ akɔlɔ̃e o, 
\q1  
\v 5 va se ɖe esime mekpɔ teƒe na Yehowa 
\q2 kple nɔƒe na Yakob ƒe ŋusẽtɔ la.” 
\b  
\q1  
\v 6 Míesee le Efrata, eye míedo goe le Yaar gbegbe be, 
\q1  
\v 7 “Mina míayi ɖe enɔƒe, 
\q2 mina míade ta agu ɖe eƒe afɔɖodzinu ŋgɔ. 
\q1  
\v 8 O! Yehowa, tso, ne nàva wò gbɔɖemeƒe, 
\q2 wò kple wò ŋusẽ ƒe nubablaɖaka la gbɔ. 
\q1  
\v 9 Wò nunɔlawo nedo dzɔdzɔenyenye ƒe awu, 
\q2 eye wò ame kɔkɔewo nedzi ha le dzidzɔkpɔkpɔ ta.” 
\b  
\q1  
\v 10 Le David, wò dɔla ta la, 
\q2 mègagbe wò amesiamina la o. 
\b  
\q1  
\v 11 Yehowa ka atam na David; 
\q2 eka atam vavã si matu o la be, 
\q1 “Matsɔ wò ŋutɔ wò dzidzimevi aɖo fiae ɖe wò fiazikpui dzi. 
\q1  
\v 12 Nenema ke ne viwò ŋutsuwo lé nye nubabla 
\q2 kple nye se siwo mefia wo me ɖe asi la, 
\q1 ekema wo viwo anɔ wò fiazikpui dzi tso 
\q2 mavɔ me yi ɖe mavɔ me.” 
\b  
\q1  
\v 13 Elabena Yehowa tia Zion, 
\q2 eye wòtiae be wòanye ye nɔƒe be, 
\q1  
\v 14 “Esia nye nye gbɔɖemeƒe tso 
\q2 mavɔ me yi ɖe mavɔ me, 
\q1 afi siae manɔ fiazikpui dzi le gli, 
\q2 elabena nye ŋutɔe tiae.” 
\q1  
\v 15 Matsɔ nu nyui geɖewo ayrae, 
\q2 eye matsɔ nuɖuɖu aɖi ƒoe na eƒe ame dahewo. 
\q1  
\v 16 Mado xɔxɔ ƒe awu na eƒe nunɔlawo, 
\q2 eye eƒe ame kɔkɔewo adzi ha le dzidzɔkpɔkpɔ ta tegbetegbe. 
\b  
\q1  
\v 17 “Le afi sia, mana dzo nado na David, 
\q2 eye masi akaɖi aɖo anyi na nye amesiamina la. 
\q1  
\v 18 Matsɔ ŋukpe ado na eƒe futɔwo, 
\q2 ke fiakuku si anɔ eƒe ta la, anɔ keklẽm.” 
\c 133  
\cl Psalmo 133 
\d David ƒe Mɔzɔha. 
\q1  
\v 1 Aleke wohenyo, eye wòvivinae, 
\q2 ne nɔviwo nɔ teƒe ɖeka le ɖekawɔwɔ me! 
\b  
\q1  
\v 2 Ele abe ami xɔasi si wokɔ ɖe ta me, 
\q2 eye wòtsra va kɔ ɖe ge me ene, 
\q1 ɛ̃, etsra kɔ ɖe Aron ƒe ge me hetsyɔ ɖe 
\q2 eƒe awu ƒe kɔme. 
\q1  
\v 3 Ele abe Hermon zãmue 
\q2 le dzadzam ɖe Zion to dzi ene, 
\q1 elabena afi mae Yehowa kɔ yayra 
\q2 kple agbe gɔ̃ hã ɖo tegbetegbe. 
\c 134  
\cl Psalmo 134 
\d Mɔzɔha. 
\q1  
\v 1 Mikafu Yehowa, mi eƒe dɔlawo katã, 
\q2 mi ame siwo subɔna 
\q2 le Yehowa ƒe aƒe me le zã me. 
\q1  
\v 2 Mido miaƒe asiwo ɖe dzi 
\q2 le kɔkɔeƒe la me, eye mikafu Yehowa. 
\b  
\q1  
\v 3 Yehowa, dziƒo kple anyigba Wɔla, 
\q2 neyra mi tso Zion. 
\c 135  
\cl Psalmo 135 
\q1  
\v 1 Mikafu Yehowa. 
\b  
\q1 Mikafu Yehowa ƒe ŋkɔ, 
\q2 mikafui, mi Yehowa ƒe dɔlawo. 
\q1  
\v 2 Mi ame siwo subɔna le Yehowa ƒe aƒe me, 
\q2 le míaƒe Mawu la ƒe xɔxɔnuwo. 
\b  
\q1  
\v 3 Mikafu Yehowa, 
\q2 elabena Yehowa nyo; 
\q1 midzi ha na eƒe ŋkɔ, 
\q2 elabena esia vivina. 
\q1  
\v 4 Elabena Yehowa tia Yakob be wòanye ye tɔ, 
\q2 eye wòtia Israel be wòanye yeƒe domenyinu xɔasi la. 
\b  
\q1  
\v 5 Menya be Yehowa lolo, 
\q2 eye míaƒe Aƒetɔ la lolo wu mawuwo katã. 
\q1  
\v 6 Yehowa wɔa nu sia nu si dze eŋu 
\q2 le dziƒo kple anyigba, 
\q2 le atsiaƒuwo me kple woƒe gogloƒewo katã. 
\q1  
\v 7 Enaa lilikpo hona tso anyigba ƒe mlɔenu ke, 
\q2 edɔa dzikedzo be wòava kple tsidzadza, 
\q2 eye wòɖea yaƒoƒo ɖe go tso eƒe nudzraɖoƒewo. 
\b  
\q1  
\v 8 Eƒo Egipte ƒe ŋgɔgbeviwo ƒu anyi; 
\q2 amegbetɔwo kple lãwo siaa ƒe ŋgɔgbeviwo. 
\q1  
\v 9 O! Egipte, edɔ eƒe dzesiwo 
\q2 kple nukunuwo ɖo ɖe mía dome, 
\q2 ɖe Farao kple eƒe dɔlawo katã ŋu. 
\q1  
\v 10 Eƒo dukɔ geɖewo ƒu anyi, 
\q2 eye wòwu fia sesẽwo. 
\q1  
\v 11 Ewu Sixɔn, Amoritɔwo ƒe fia, 
\q2 Ɔg, Basantɔwo ƒe fia 
\q2 kple Kanaan fiawo katã, 
\q1  
\v 12 eye wòtsɔ woƒe anyigba wɔ domenyinu, 
\q2 na eƒe dukɔ Israel. 
\b  
\q1  
\v 13 O! Yehowa, wò ŋkɔ li tegbetegbe, 
\q2 o Yehowa, èxɔ ŋkɔ le dzidzimewo katã me. 
\q1  
\v 14 Elabena Yehowa atso afia na eƒe dukɔ, 
\q2 eye wòakpɔ nublanui na eƒe dɔlawo. 
\b  
\q1  
\v 15 Dukɔwo ƒe legbawo nye klosalo kple sika, 
\q2 amegbetɔ ƒe asinudɔwɔwɔwo wonye. 
\q1  
\v 16 Nu li na wo, gake womeƒoa nu o, ŋku li na wo 
\q2 gake womekpɔa nu o, 
\q1  
\v 17 to li na wo, gake womesea nu loo, 
\q2 alo gbɔna to woƒe nu me o. 
\q1  
\v 18 Ame siwo wɔ wo la anɔ abe woawo ke ene, 
\q2 eye nenema kee nye ame siwo katã ɖoa dzi ɖe wo ŋu. 
\b  
\q1  
\v 19 O! Israel ƒe aƒe, mikafu Yehowa, 
\q2 O! Aron ƒe aƒe, mikafu Yehowa, 
\q1  
\v 20 O! Levi ƒe aƒe, mikafu Yehowa, 
\q2 eye mi ame siwo vɔ̃nɛ la, mikafu Yehowa. 
\q1  
\v 21 Woakafu Yehowa tso Zion, 
\q2 eya ame si nɔ Yerusalem. 
\b  
\q1 Mikafu Yehowa! 
\c 136  
\cl Psalmo 136 
\q1  
\v 1 Mida akpe na Yehowa, elabena enyo. 
\qr Eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 2 Mida akpe na mawuwo dzi Mawu la, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 3 Mida akpe na aƒetɔwo dzi Aƒetɔ la, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\b  
\q1  
\v 4 Eya ɖeka hɔ̃ɔ koe wɔa nukunu dzɔatsuwo, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 5 Eya ame si tsɔ eƒe nugɔmesese wɔ dziƒowoe, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 6 Ame si keke anyigba ɖe tsiwo dzi, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 7 Ame si wɔ nu keklẽ gãwo, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 8 Be ɣe naɖu ŋkeke dzi, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 9 Be ɣleti kple ɣletiviwo naɖu zã dzi, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\b  
\q1  
\v 10 Eya ame si ƒo Egiptetɔwo ƒe ŋgɔgbeviwo ƒu anyi, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 11 Eye wòkplɔ Israel do goe le wo dome, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 12 Kple asi sesẽ kple abɔ si wòdo ɖe dzi, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\b  
\q1  
\v 13 Eya ame si ma Ƒu Dzĩ la ɖe eve, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 14 Eye wòkplɔ Israel to eƒe titina, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 15 Ke ekplɔ Farao kple eƒe aʋakɔ la de Ƒu Dzĩ la me, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\b  
\q1  
\v 16 Eya ame si kplɔ eƒe dukɔ la to gbedzi, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\b  
\q1  
\v 17 Ame si ƒo fia gãwo ƒu anyi, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 18 Eye wòwu fia sesẽwo, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 19 Sixɔn, Amoritɔwo ƒe fia, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa 
\q1  
\v 20 kple Ɔg, Basantɔwo ƒe fia, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 21 Eye wòtsɔ woƒe anyigba wɔ domenyinu, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 22 Domenyinu na eƒe dɔla, Israel, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\b  
\q1  
\v 23 Eya ame si ɖo ŋku mía dzi, 
\q2 esime wobɔbɔ mí ɖe anyi, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 24 Eye wòɖe mí tso míaƒe futɔwo ƒe asi me, 
\qr elabena eƒe lɔlɔ̃ li ɖaa. 
\q1  
\v 25 Eya ame si naa nuɖuɖu nu gbagbe ɖe sia ɖe, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\b  
\q1  
\v 26 Mida akpe na Dziƒo Mawu la, 
\qr Elabena eƒe lɔlɔ̃ li ɖaa. 
\c 137  
\cl Psalmo 137 
\q1  
\v 1 Babilonia tɔsisiwo toe míenɔ, 
\q2 hɛnɔ avi fam, 
\q2 esi míeɖo ŋku Zion dzi. 
\q1  
\v 2 Míetsɔ míaƒe kasaŋkuwo ku 
\q2 amuti siwo le afi ma, 
\q1  
\v 3 elabena afi mae ame siwo ɖe 
\q2 aboyo mí la bia ha tso mía si le; 
\q1 ame siwo wɔ fu mí la bia 
\q2 dzidzɔhawo tso mía si hegblɔ be, 
\q2 “Midzi Zion hawo dometɔ ɖeka na mí!” 
\b  
\q1  
\v 4 Aleke miadzi Yehowa ƒe hawo 
\q2 le dzronyigba dzi? 
\q1  
\v 5 O! Yerusalem, ne meŋlɔ wò be la, 
\q2 nye nuɖusibɔ nèŋlɔ eƒe ŋusẽ be, 
\q1  
\v 6 eye nye aɖe nelé ɖe nye nu me, 
\q2 ne nyemeɖo ŋku dziwò o, 
\q1 ne nyemebu Yerusalem, 
\q2 nye dzidzɔ kɔkɔtɔ kekeake o. 
\b  
\q1  
\v 7 O! Yehowa, ɖo ŋku nu si Edomtɔwo wɔ la dzi, 
\q2 gbe si gbe wogbã Yerusalem. 
\q1 Wodo ɣli be, “Mimui ƒu anyi, 
\q2 migbãe, va se ɖe eƒe gɔmeɖokpewo dzi ke!” 
\q1  
\v 8 O! Babilonia vinyɔnu, 
\q2 woɖo wò ɖi na tsɔtsrɔ̃, 
\q1 woayra ame si aɖo nu si nèwɔ 
\q2 mí la teƒe na wò, 
\q1  
\v 9 ame si alé wò vidzĩwo 
\q2 axlã ɖe agakpewo. 
\c 138  
\cl Psalmo 138 
\d David ƒe ha. 
\q1  
\v 1 O! Yehowa, makafu wò kple nye dzi blibo; 
\q2 madzi wò kafukafuha le mawuwo ŋkume. 
\q1  
\v 2 Made ta agu do ɖe wò gbedoxɔ kɔkɔe la gbɔ, 
\q2 eye makafu wò ŋkɔ, 
\q1 le wò lɔlɔ̃ kple nuteƒewɔwɔ ta, 
\q2 elabena èkɔ, wò ŋkɔ kple wò nya 
\q2 gbɔ nu sia nu ta sãsãsã. 
\q1  
\v 3 Ètɔ nam esi meyɔ wò, eye nède dzi ƒo nam, 
\q2 hedo ŋusẽ nye dzi. 
\b  
\q1  
\v 4 O! Yehowa, anyigbadzifiawo katã akafu wò, 
\q2 ne wose wò numenya. 
\q1  
\v 5 Na woadzi ha le Yehowa ƒe mɔwo ŋu, 
\q2 elabena Yehowa ƒe ŋutikɔkɔe lolo. 
\b  
\q1  
\v 6 Togbɔ be Yehowa le dzi me ke hã la, ekpɔa ame dahewo gbɔ, 
\q2 ke edzea si dadala tso adzɔge. 
\q1  
\v 7 Togbɔ be mele zɔzɔm le xaxa me hã la, 
\q2 èkpɔ nye agbe ta, eye nèkɔ wò asi dzi do ɖe 
\q1 nye futɔwo ƒe dɔmedzoe ŋu, 
\q2 hetsɔ wò nuɖusi xɔ nam. 
\q1  
\v 8 Yehowa ana eƒe ta me si wòɖo ɖe ŋunye la nava eme. 
\q2 O! Yehowa, wò lɔlɔ̃ li ɖaa, 
\q2 mègagblẽ wò asinudɔwɔwɔwo ɖi o. 
\c 139  
\cl Psalmo 139 
\d David ƒe ha na hɛnɔ la. 
\q1  
\v 1 O! Yehowa, èdzro menye, eye nènyam. 
\q1  
\v 2 Ènya nye anyinɔnɔ kple nye tsitretsitsi, 
\q2 eye nènya nye susuwo tso adzɔge ke. 
\q1  
\v 3 Ènya nye godoɣi kple nye anyimlɔɣi, 
\q2 ale nènya nye mɔwo katã nyuie. 
\q1  
\v 4 O! Yehowa, hafi nya aɖe nava nye aɖe dzi la, 
\q2 ènya nya la katã xoxo. 
\q1  
\v 5 Ètsɔm ɖe tome, 
\q2 le megbe kple ŋgɔ siaa, eye nèɖo wò asi dzinye. 
\q1  
\v 6 Nunya sia wɔ nuku nam akpa, 
\q2 nyemate ŋu aɖo afi ma o, 
\q2 elabena ekɔkɔ nam akpa. 
\b  
\q1  
\v 7 Afi ka madzo le wò Gbɔgbɔ la gbɔ ayi? 
\q2 Afi ka masi atso wò ŋkume ayi? 
\q1  
\v 8 Ne meyi dziƒo la, èle afi ma, 
\q2 ne meɖo nye mlɔƒe ɖe gogloƒewo hã la, èle afi ma. 
\q1  
\v 9 Ne medzo yi yame le fɔŋli ƒe aʋalawo dzi, 
\q2 ne meyi ɖanɔ atsiaƒu ƒe mlɔenu ke hã la, 
\q1  
\v 10 wò asi akplɔm, 
\q2 eye wò nuɖusi além ɖe asi sesĩe. 
\q1  
\v 11 Ne megblɔ be, “Vavã, viviti la ana maɣla, 
\q2 eye kekeli azu zã aƒo xlãm” la, 
\q1  
\v 12 viviti la gɔ̃ hã mado blukɔ na wò o, 
\q2 zã aklẽ na wò abe ŋkeke ene, 
\q2 elabena viviti le na wò abe kekeli ene. 
\b  
\q1  
\v 13 Elabena wòe wɔ nye ememe ke; 
\q2 eye nèlém ƒo ƒu ɖe danye ƒe dɔ me. 
\q1  
\v 14 Mekafu wò, elabena èwɔm ŋɔdzitɔe kple nukutɔe. 
\q2 Wò dɔwɔwɔwo nye nukunu, 
\q2 menya esia nyuie. 
\q1  
\v 15 Nye ameti blibo la, mele ɣaɣla ɖe wò o, 
\q2 esi nèwɔm le ɣaɣlaƒe. 
\q1 Esi wolɔ̃m ɖe wo nɔewo me 
\q2 le anyigba ƒe gogloƒe la, 
\q1  
\v 16 wò ŋkuwo kpɔ ale si menye ʋukɔe. 
\q2 Ŋkeke siwo katã woɖo nam la, 
\q1 woŋlɔ wo ɖe wò agbalẽ me 
\q2 hafi ŋkeke gbãtɔ dze egɔme. 
\q1  
\v 17 O! Mawu, wò susuwo xɔ asi nam ŋutɔ! 
\q2 Wò susuwo sɔ gbɔ loo! 
\q1  
\v 18 Ne mebe maxlẽ wo la, 
\q2 woasɔ gbɔ wu ke. 
\q1 Ne menyɔ tso alɔ̃ me la, 
\q2 megale gbɔwò ko. 
\b  
\q1  
\v 19 O! Mawu, negbe ɖe nàtsrɔ̃ ame vɔ̃ɖiwo hafi! 
\q2 Mite ɖa le gbɔnye, mi hlɔ̃dolawo! 
\q1  
\v 20 Woƒoa nu tso ŋutiwò kple susu baɖa, 
\q2 wò futɔwo wɔa wò ŋkɔ ŋu dɔ yakayaka. 
\q1  
\v 21 O! Yehowa, ɖe nyemelé fu ame siwo lé fu wò, 
\q2 eye menyɔ ŋu ame siwo tso ɖe ŋuwò oa? 
\q1  
\v 22 Fuléle koe le asinye na wo, 
\q2 eye mebu wo nye ketɔwoe. 
\q1  
\v 23 Dzro menye, o Mawu, eye nànya nye dzi; 
\q2 dom kpɔ, eye nànya nye susu si tsi dzodzodzoe. 
\q1  
\v 24 Kpɔe ɖa be mɔtatra aɖe le menye hã, 
\q2 eye nàkplɔm to mɔ mavɔtɔ la dzi. 
\c 140  
\cl Psalmo 140 
\d David ƒe ha na hɛnɔ la. 
\q1  
\v 1 O! Yehowa, ɖem tso ame vɔ̃ɖiwo ƒe asi me 
\q2 eye dzɔ ŋunye le ŋutsu ŋutasẽlawo ta, 
\q1  
\v 2 ame siwo ɖoa nu vɔ̃ɖiwo ɖe woƒe dzi me, 
\q2 eye wodoa aʋa gbe sia gbe. 
\q1  
\v 3 Wonyre woƒe aɖewo wole ɖaɖam abe da tɔ ene, 
\q2 eye da ƒe aɖi le woƒe nuyiwo ŋu. \qs Sela\qs* 
\b  
\q1  
\v 4 O! Yehowa, ɖem tso ame vɔ̃ɖiwo ƒe asi me, 
\q2 dzɔ nye agbe ŋu le ŋutsu ŋutasẽlawo ta, 
\q2 ame siwo ɖo be woaɖe afɔ le tenye. 
\q1  
\v 5 Dada tre mɔ da ɖe ɣaɣlaƒe nam, 
\q2 woɖo ɖɔ, keke eme da ɖi nam 
\q2 eye wotre azãwo da ɖe nye toƒe. \qs Sela\qs* 
\b  
\q1  
\v 6 O! Yehowa, megblɔ na wò be, 
\q2 “Wòe nye nye Mawu.” 
\q1 See, o Yehowa, 
\q2 se nye nublanuiɣli. 
\q1  
\v 7 O! Aƒetɔ Yehowa, nye Ɖela sesẽ, 
\q2 ame si ɖɔ gakuku nam le aʋakpegbe. 
\q1  
\v 8 O! Yehowa, mègana ame vɔ̃ɖiwo ƒe didi nava eme na wo o, 
\q2 eye mègana woƒe ɖoɖowo nadze edzi na wo o, 
\q2 ne menye nenema o la, woanɔ dadam. \qs Sela\qs* 
\b  
\q1  
\v 9 Na fukpekpe si ame siwo ɖe to ɖem 
\q2 ƒe nuyiwo he vɛ la, nanye tsyɔ woƒe ta dzi. 
\q1  
\v 10 Na dzoka xɔxɔwo nadza ɖe wo dzi; 
\q2 wonetsɔ wo ƒu gbe ɖe dzo me 
\q2 kple ʋe globowo me, eye womegafɔ akpɔ gbeɖe o. 
\q1  
\v 11 Ŋutsu ameŋugblẽlawo megali ke ɖe anyigba dzi o, 
\q2 eye gbegblẽ neva ŋutsu ŋutasẽlawo dzi. 
\b  
\q1  
\v 12 Menya be Yehowa tsoa afia na ame dahewo, 
\q2 eye wòxɔa nya ɖe hiãtɔwo nu. 
\q1  
\v 13 Ame dzɔdzɔewo akafu wò ŋkɔ vavã, 
\q2 eye dzi dzɔdzɔetɔwo anɔ ŋkuwò me ɖaa. 
\c 141  
\cl Psalmo 141 
\d David ƒe ha. 
\q1  
\v 1 O! Yehowa, mele yɔwòm, va gbɔnye kaba. 
\q2 Se nye gbe, ne meyɔ wò. 
\q1  
\v 2 Nye gbedodoɖa neva gbɔwò abe dzudzɔ ʋeʋĩ ene, 
\q2 eye na be nye asi siwo medo ɖe dzi la, nanɔ 
\q2 na wò abe fiẽvɔsa ene. 
\b  
\q1  
\v 3 O! Yehowa, ɖo dzɔla nye nu ŋu, 
\q2 eye nɔ ŋudzɔ ɖe nye nuyi ƒe ʋɔtru ŋu. 
\q1  
\v 4 Mègana be woahe nye dzi ɖe nu vɔ̃ɖi ŋuti, 
\q2 be mayi gome kpɔ ge 
\q1 le nu vɔ̃ɖi wɔwɔ me kple ŋutsu, 
\q2 nu vɔ̃ɖi wɔlawo o, eye mègaɖe mɔ be maɖu woƒe nuɖuɖu viviwo o. 
\b  
\q1  
\v 5 Na ame dzɔdzɔe naƒom, enye dɔmenyo wòwɔ nam, 
\q2 na wòaka mo nam, enye ami wòsi ɖe ta nam. 
\q1 Nye ta magbe exɔxɔ o. 
\q2 Gake nye gbedodoɖa tsia tsitre ɖe ame vɔ̃ɖiwo ƒe wɔnawo ŋu ɖaa, 
\q1  
\v 6 woatutu woƒe dziɖulawo tso togbɛwo dzi aƒu agame, 
\q2 eye ame vɔ̃ɖiwo anya be megblɔ nye nyawo memie ɖe eteƒe. 
\q1  
\v 7 Woagblɔ be, “Abe ale si ame ŋlɔa nu hedzoboa anyigbae ene la, 
\q2 nenemae woakaka míaƒe ƒuwoe ɖe yɔdowo nu.” 
\b  
\q1  
\v 8 O! Aƒetɔ Yehowa, meda nye ŋkuwo ɖe dziwò, 
\q2 mewòe mebe ɖo, mègatsɔm na ku o. 
\q1  
\v 9 Ɖem le mɔ siwo wotre nam la me, 
\q2 tso mɔkli si nu tovo wɔlawo ɖo ɖi la me. 
\q1  
\v 10 Na ame vɔ̃ɖiwo naɖo woawo ŋutɔ ƒe ɖɔwo me, 
\q2 ne matso eme ayi le dedinɔnɔ me. 
\c 142  
\cl Psalmo 142 
\d David ƒe nufiameha esi wònɔ agado me. Gbedodoɖa. 
\q1  
\v 1 Medo ɣli na Yehowa sesĩe, 
\q2 eye mekɔ nye gbe dzi na Yehowa be wòakpɔ nye nublanui. 
\q1  
\v 2 Metrɔ nye nuxaxawo kɔ ɖe eŋkume, 
\q2 eye metrɔ nye vevesesewo kɔ ɖe eya amea gbɔ. 
\b  
\q1  
\v 3 Ne nu ti kɔ na nye gbɔgbɔ le menye la, 
\q2 wò koe nya nye mɔ. 
\q1 Ŋutsuwo tre mɔ 
\q2 ɖe mɔ si metona la dzi nam. 
\q1  
\v 4 Trɔ ɖe nye ɖusime ne nàkpɔ; 
\q2 ame aɖeke metsɔ ɖeke le eme nam o. 
\q1 Bebeƒe aɖeke meli nam o, 
\q2 eye ame aɖeke metsɔ ɖeke le eme nam o. 
\b  
\q1  
\v 5 O! Yehowa, wòe mele ɣli dom na. 
\q2 Megblɔ be, “Wòe nye nye sitsoƒe, 
\q2 kple nye gome le agbagbeawo ƒe anyigba dzi.” 
\b  
\q1  
\v 6 Ɖo to nye ɣlidodo, 
\q2 elabena meɖo xaxa me ŋutɔ. 
\q1 Ɖem tso ame siwo le yonyeme tim la ƒe asi me, 
\q2 elabena wosesẽ nam akpa. 
\q1  
\v 7 Ɖem tso nye gaxɔ me, 
\q2 be makafu wò ŋkɔ. 
\q1 Ekema ame dzɔdzɔewo aɖe to ɖem, 
\q2 le wò nyui si nèwɔ nam la ta. 
\c 143  
\cl Psalmo 143 
\d David ƒe ha. 
\q1  
\v 1 O! Yehowa, se nye gbedodoɖa, 
\q2 lé to ɖe nye nublanuiɣli ŋu, 
\q1 eye nàxɔ nam le wò nuteƒewɔwɔ 
\q2 kple dzɔdzɔenyenye ta. 
\q1  
\v 2 Mègabu fɔ wò dɔla o, 
\q2 elabena amegbetɔ aɖeke 
\q2 mele dzɔdzɔe le ŋkuwò me o. 
\q1  
\v 3 Futɔ la ti yonyeme, 
\q2 egbãm ɖe anyigba, 
\q1 eye wòna menɔ viviti me abe 
\q2 ame siwo ku xoxo va yi la ene. 
\q1  
\v 4 Nu te nye gbɔgbɔ ŋu le menye, 
\q2 eye nye dzi wɔ yaa le menye. 
\q1  
\v 5 Meɖo ŋku blemaŋkekeawo dzi, 
\q2 hede ŋugble le wò dɔwɔwɔwo katã ŋuti, 
\q2 eye mebu nu siwo wò asiwo wɔ la ŋuti. 
\q1  
\v 6 Mekeke nye abɔwo me na wò, 
\q2 eye nye luʋɔ ƒe ve me ƒu ɖe ŋuwò 
\q2 abe kuɖiɖinyigba ene. \qs Sela\qs* 
\b  
\q1  
\v 7 O! Yehowa, tɔ nam kaba, 
\q2 elabena nu te nye gbɔgbɔ ŋu. 
\q1 Mègaɣla wò mo ɖem o, 
\q2 ne menye nenema o la, 
\q2 manɔ abe ame siwo yi aʋlime ene. 
\q1  
\v 8 Na ŋdi natsɔ wò lɔlɔ̃ si meʋãna o 
\q2 la ƒe nya vɛ nam, 
\q2 elabena dziwòe meka ɖo. 
\q1 Fia mɔ si mato lam, 
\q2 elabena wòe medo nye luʋɔ ɖe dzi na. 
\q1  
\v 9 O! Yehowa, ɖem tso nye futɔwo ƒe asi me, 
\q2 elabena mewòe mebe ɖo. 
\q1  
\v 10 Fiam ale si mawɔ wò lɔlɔ̃nu, 
\q2 elabena wòe nye nye Mawu; 
\q1 na wò Gbɔgbɔ nyui la nakplɔm 
\q2 to anyigba sɔsɔe dzi. 
\b  
\q1  
\v 11 O! Yehowa, le wò ŋkɔ la ta, 
\q2 kpɔ nye agbe ta, 
\q1 le wò dzɔdzɔenyenye ta, 
\q2 ɖem le xaxa me. 
\q1  
\v 12 Le wò lɔlɔ̃ si meʋãna o la ta, mia nu na nye futɔwo; 
\q2 tsrɔ̃ nye ketɔwo katã, 
\q2 elabena wò dɔlae menye. 
\c 144  
\cl Psalmo 144 
\d David ƒe ha. 
\q1  
\v 1 Woakafu Yehowa, nye Agakpe la, 
\q2 ame si fia aʋawɔwɔ nye asi kple asibidɛwo. 
\q1  
\v 2 Enye nye Mawu lɔlɔ̃tɔ kple nye mɔ sesẽ, 
\q2 nye sitsoƒe kple nye xɔnametɔ kpakple nye akpoxɔnu, 
\q1 nye Mawu si me mebe ɖo, 
\q2 ame si bɔbɔ nye dukɔ ɖe tenye. 
\b  
\q1  
\v 3 O! Yehowa, nu kae nye amegbetɔ be nètsɔ ɖe le eme nɛ 
\q2 kple amegbetɔvi be nèbua eŋuti? 
\q1  
\v 4 Amegbetɔ le abe gbɔgbɔ ko ene, 
\q2 eye eƒe ŋkekewo le abe vɔvɔli si va yina kaba la ene. 
\b  
\q1  
\v 5 O! Yehowa, dze wò dziƒowo ne nàɖi va, 
\q2 eye nàka asi towo ŋu, be woatu dzudzɔ. 
\q1  
\v 6 Dɔ dzikedzo ɖa woakaka futɔwo, 
\q2 da wò aŋutrɔ, eye nàtsrɔ̃ wo. 
\q1  
\v 7 Do wò asi ɖa tso dziƒo nàxɔ nam, 
\q2 eye nàɖem tso tsi sesẽwo 
\q2 kple amedzrowo ƒe asi me, 
\q1  
\v 8 ame siwo ƒe nu me yɔ fũu kple alakpa, 
\q2 eye woƒe nuɖusi blea ame. 
\b  
\q1  
\v 9 O! Mawu, madzi ha yeye na wò, 
\q2 matsɔ kasaŋku, ka ewo tɔ aƒo ha na wò, 
\q1  
\v 10 wò ame si na dziɖuɖu fiawo, 
\q2 eye nèɖe wo dɔla David tso yi vɔ̃ɖi ƒe asi me. 
\b  
\q1  
\v 11 Xɔ nam, eye nàɖem tso amedzrowo ƒe asi me, 
\q2 ame siwo ƒe nu me yɔ fũu kple alakpa, 
\q2 eye woƒe nuɖusi blea ame. 
\b  
\q1  
\v 12 Ekema mía viŋutsuwo 
\q2 le woƒe ɖekakpuime, 
\q2 anɔ abe ati siwo wode tsii nyuie ene, 
\q1 eye mía vinyɔnuwo anɔ abe sɔti si ŋu 
\q2 wota nu ɖo hetsɔ ɖo atsyɔ̃e na fiasã ene. 
\q1  
\v 13 Míaƒe avawo ayɔ fũu 
\q2 kple nuku vovovowo. 
\q1 Míaƒe alẽwo adzi ɖe edzi le akpewo 
\q2 kple akpe ewowo me le míaƒe lãnyiƒewo. 
\q1  
\v 14 Nenema ke míaƒe nyiwo atsɔ agba kpekpewo vɛ. 
\q2 Ale gli gbagbã maganɔ anyi o, 
\q1 aboyomeyiyi maganɔ anyi o, 
\q2 eye xaxa ƒe avifafa magaɖi le míaƒe mɔtatawo dzi azɔ o. 
\q1  
\v 15 Woayra dukɔ si wòava eme na alea le nyateƒe me; 
\q2 Woayra dukɔ si ƒe Mawue nye Yehowa. 
\c 145  
\cl Psalmo 145 
\d David ƒe kafukafuha. 
\q1  
\v 1 Mado wò ɖe dzi, nye Mawu, fia la. 
\q2 Makafu wò ŋkɔ tso mavɔ me yi ɖe mavɔ me. 
\q1  
\v 2 Makafu wò gbe sia gbe, 
\q2 eye mado wò ŋkɔ ɖe dzi tso mavɔ me yi ɖe mavɔ me. 
\b  
\q1  
\v 3 Gãe nye Yehowa, eye eya koe dze na kafukafu, 
\q2 elabena ame aɖeke mate ŋu anya 
\q2 eƒe gãnyenye ƒe goglome o. 
\q1  
\v 4 Dzidzime ɖeka akafu wò dɔwɔwɔwo 
\q2 na dzidzime bubu, eye woatu xo 
\q2 le wò nu dzɔatsuwo ŋu. 
\q1  
\v 5 Woaƒo nu le wò gãnyenye 
\q2 ƒe atsyɔ̃ɖoɖo ƒe ŋutikɔkɔe ŋuti, 
\q2 eye made ŋugble le wò dɔwɔwɔ wɔnukuwo ŋuti. 
\q1  
\v 6 Woaƒo nu le wò ŋɔdzidɔwɔwɔwo ƒe ŋusẽ ŋuti, 
\q2 eye maɖe gbeƒã wò nuwɔwɔ dzɔatsuwo. 
\q1  
\v 7 Woaɖu wò nyuiwɔwɔ gbogboawo ƒe azã, 
\q2 eye woadzi ha atso aseye le wò dzɔdzɔenyenye ŋuti. 
\b  
\q1  
\v 8 Yehowa nye amenuvela kple nublanuikpɔla; 
\q2 medoa dɔmedzoe kabakaba o, eye lɔlɔ̃ bɔ ɖe esi. 
\b  
\q1  
\v 9 Yehowa nyoa dɔ me na ame sia ame, 
\q2 eye wòkpɔa nublanui na ame siwo katã wòwɔ. 
\q1  
\v 10 O! Yehowa, ame siwo katã nèwɔ la akafu wò, 
\q2 eye wò ame kɔkɔewo ado wò ɖe dzi. 
\q1  
\v 11 Woaƒo nu le wò fiaɖuƒe la ƒe ŋutikɔkɔe ŋu, 
\q2 eye woagblɔ nya tso wò ŋusẽ ŋuti, 
\q1  
\v 12 ale be amewo katã nanya wò nuwɔwɔ dzɔatsuwo 
\q2 kple wò fiaɖuƒe ƒe ŋutikɔkɔe ƒe atsyɔ̃. 
\q1  
\v 13 Wò fiaɖuƒe la nye fiaɖuƒe mavɔ, 
\q2 eye wò fiaɖuɖu anɔ anyi le dzidzimewo katã me. 
\b  
\q1 Yehowa awɔ nuteƒe le eƒe ŋugbedodowo katã me, 
\q2 eye wòaɖe lɔlɔ̃ afia ame siwo katã wòwɔ. 
\q1  
\v 14 Yehowa léa ame siwo katã dze anyi la ɖe asi, 
\q2 eye wòfɔa ame siwo katã wobɔbɔ ɖe anyi la ɖe dzi. 
\q1  
\v 15 Ŋkuwo katã le wò asinu kpɔm, 
\q2 eye nèna nuɖuɖu wo le enaɣi. 
\q1  
\v 16 Èʋu wò asiwo me, eye nètsɔ nu gbagbe 
\q2 ɖe sia ɖe ƒe nu si wòdi la nɛ. 
\b  
\q1  
\v 17 Yehowa nye dzɔdzɔetɔ le eƒe mɔwo katã dzi, 
\q2 eye wòlɔ̃a eƒe nu siwo katã wòwɔ. 
\q1  
\v 18 Yehowa tsɔ ɖe ame siwo yɔnɛ la gbɔ, 
\q2 ame siwo katã yɔnɛ le nyateƒe me. 
\q1  
\v 19 Ewɔa ame siwo vɔ̃nɛ la ƒe dzimedidiwo na wo, 
\q2 esea woƒe ɣlidodo, eye wòɖea wo. 
\q1  
\v 20 Yehowa kpɔa ame siwo katã lɔ̃nɛ la ta, 
\q2 gake atsrɔ̃ ame vɔ̃ɖiwo katã. 
\b  
\q1  
\v 21 Nye nu agblɔ Yehowa ƒe kafukafu. 
\q2 Nu gbagbe ɖe sia ɖe nekafu eƒe ŋkɔ kɔkɔe la 
\q2 tso mavɔ me yi ɖe mavɔ me. 
\c 146  
\cl Psalmo 146 
\q1  
\v 1 Mikafu Yehowa. 
\b  
\q1 O! luʋɔnye, kafu Yehowa. 
\b  
\q1  
\v 2 Makafu Yehowa le nye agbemeŋkekewo katã me. 
\q2 Madzi kafukafuha na nye Mawu la, zi ale si mele agbe. 
\q1  
\v 3 Migaɖo dzi ɖe dziɖulawo ŋu o, 
\q2 eye migaka ɖe amegbetɔ kodzogbea, 
\q2 si mate ŋu axɔ na ame o la dzi o. 
\q1  
\v 4 Ne woƒe gbɔgbɔ do go 
\q2 le wo me la, wogatrɔna zua kewɔ, 
\q1 gbe ma gbe ke woƒe ɖoɖo 
\q2 siwo katã wowɔ la zua tofloko. 
\q1  
\v 5 Woayra ame si ƒe xɔnametɔ nye Yakob ƒe Mawu la, 
\q2 eye eƒe mɔkpɔkpɔ le Yehowa, eƒe Mawu la me. 
\b  
\q1  
\v 6 Eya ame si wɔ dziƒo kple anyigba, 
\q2 atsiaƒu kple nu siwo katã le eme, 
\q2 Yehowa nye nuteƒewɔla tegbetegbe. 
\q1  
\v 7 Etsoa afia na ame siwo wote ɖe anyi, 
\q2 eye wònaa nuɖuɖu dɔwuitɔwo. 
\q1 Yehowae naa ablɔɖe gamenɔlawo. 
\q2  
\v 8 Yehowa ʋua ŋku na ŋkuagbãtɔwo, 
\q1 Yehowa fɔa ame siwo wote ɖe anyi la ɖe dzi, 
\q2 Yehowa lɔ̃a ame dzɔdzɔewo ƒe nya. 
\q1  
\v 9 Yehowa kpɔa amedzrowo ta, 
\q2 eye wònye tsyɔ̃eviwo kple ahosiwo hã ta kpɔla. 
\q2 Ke etɔtɔa ame vɔ̃ɖiwo ƒe mɔwo. 
\b  
\q1  
\v 10 Yehowa le fia ɖum tso mavɔ me yi ɖe mavɔ me. 
\q2 O! Zion, wò Mawu la aɖu fia le dzidzimewo katã me. 
\b  
\q1 Mikafu Yehowa. 
\c 147  
\cl Psalmo 147 
\q1  
\v 1 Mikafu Yehowa. 
\b  
\q1 Aleke mehenyoe be woadzi kafukafuha na míaƒe Mawu la o! 
\q2 Aleke wòhevivina, eye wòdze be woakafui! 
\b  
\q1  
\v 2 Yehowa gbugbɔ tso Yerusalem du la, 
\q2 eye wòkplɔ Israel ƒe aboyomewo gbɔe. 
\q1  
\v 3 Eda gbe le ame siwo ƒe dzi gbã la ŋu, 
\q2 eye wòbla woƒe abiwo na wo. 
\q1  
\v 4 Eyae ɖo xexlẽme na ɣletiviwo, 
\q2 eye wòyɔa ɖe sia ɖe ƒe ŋkɔ. 
\q1  
\v 5 Gãe nye míaƒe Aƒetɔ la, 
\q2 eye eƒe ŋusẽ tri akɔ ŋutɔ, 
\q2 seɖoƒe meli na eƒe gɔmesese o. 
\q1  
\v 6 Yehowa kpɔa ame siwo bɔbɔa wo ɖokui la dzi, 
\q2 ke etsɔ ame vɔ̃ɖi ya xlã ɖe anyigba. 
\b  
\q1  
\v 7 Midzi ha na Yehowa kple akpedada, 
\q2 eye miƒo ha na míaƒe Mawu la kple kasaŋku. 
\b  
\q1  
\v 8 Etsɔa lilikpo xea yamee, 
\q2 eye wònana tsi dzana ɖe anyigba la dzi hewɔnɛ be 
\q2 gbe miena ɖe togbɛwo dzi. 
\q1  
\v 9 Enaa nuɖuɖu nyiwo 
\q2 kple akpaviã siwo le xɔxlɔ̃m nɛ. 
\b  
\q1  
\v 10 Eƒe dzidzɔ mele sɔ ƒe ŋusẽ me loo, 
\q2 alo amegbetɔ ƒe afɔ me o; 
\q1  
\v 11 ke boŋ Yehowa ƒe dzidzɔkpɔkpɔ le ame siwo vɔ̃nɛ la me, 
\q2 ame siwo tsɔa woƒe mɔkpɔkpɔ dana ɖe eƒe lɔlɔ̃ si meʋãna o la dzi. 
\b  
\q1  
\v 12 O! Yerusalem, do Yehowa ɖe dzi, 
\q2 O! Zion, kafu wò Mawu la, 
\q1  
\v 13 elabena eyae glã wò agbowo ƒe gametiwo, 
\q2 eye wòyra ame siwo le mewò. 
\b  
\q1  
\v 14 Ena ŋutifafa le wò liƒowo dzi, 
\q2 eye wòtsɔ mɔlu nyuitɔ ɖi ƒo na wòe. 
\q1  
\v 15 Eɖo eƒe sedede ɖe anyigba la dzi, 
\q2 eye eƒe nya kaka kple du ɖo teƒewo. 
\q1  
\v 16 Ekaka tsikpe abe ɖetifu ene, 
\q2 eye wòkaka afu abe dzofi ene. 
\q1  
\v 17 Eɖo kpetsi ɖe anyigba abe kpekui ene. 
\q2 Ame ka ate ŋu anɔ te ɖe wò ya fafɛ la nu? 
\q1  
\v 18 Edɔ eƒe nya ɖa, eye wòlolo wo. 
\q2 Ede ŋusẽ eƒe yawo me, eye tsiwo de asi sisi me. 
\b  
\q1  
\v 19 Eɖe eƒe nya fia Yakob eye wòɖe eƒe sewo 
\q2 kple sededewo fia Israel. 
\q1  
\v 20 Mewɔ esia na dukɔ bubu aɖeke o, 
\q2 eye womenya eƒe sewo o. 
\b  
\q1 Mikafu Yehowa. 
\c 148  
\cl Psalmo 148 
\q1  
\v 1 Mikafu Yehowa. 
\b  
\q1 Mikafu Yehowa tso dziƒowo, 
\q2 mikafui le kɔkɔƒewo le dzi me. 
\q1  
\v 2 Mi eƒe dɔlawo katã mikafui, 
\q2 dziƒoʋakɔwo hã mikafui. 
\q1  
\v 3 Ɣe kple ɣleti nekafui, 
\q2 mikafui, mi ɣletivi keklẽwo. 
\q1  
\v 4 Mi dziƒo kɔkɔtɔwo, mikafui, 
\q2 eye mi tsi siwo le alilĩa tame hã mikafui. 
\b  
\q1  
\v 5 Wo katã nekafu Yehowa ƒe ŋkɔ, 
\q2 elabena eɖe gbe, eye wova dzɔ. 
\q1  
\v 6 Etsɔ wo ɖo wo nɔƒe tso mavɔ me yi ɖe mavɔ me, 
\q2 ede se si nu mayi akpɔ gbeɖe o. 
\b  
\q1  
\v 7 Mikafu Yehowa tso anyigba, 
\q2 mi nuwɔwɔ gã siwo le atsiaƒu me kple gogloƒewo katã. 
\q1  
\v 8 Dzikedzo kple kpetsi, 
\q2 tsikpe kple lilikpowo, ahomya si wɔ eƒe lɔlɔ̃nu, 
\q1  
\v 9 mi towo kple togbɛwo katã, 
\q2 atikutsetsetiwo kple sedatiwo katã, 
\q1  
\v 10 gbemelãwo kple nyiwo katã, 
\q2 nuwɔwɔ suewo kple xe dzodzoewo, 
\q1  
\v 11 anyigbadzifiawo kple dukɔwo katã, 
\q2 mi dumegãwo kple dziɖula siwo katã le anyigba dzi, 
\q1  
\v 12 ɖekakpuiwo kple ɖetugbiwo, 
\q2 ame tsitsiwo kple ɖeviwo siaa nekafui. 
\b  
\q1  
\v 13 Mikafu Yehowa ƒe ŋkɔ, 
\q2 elabena eƒe ŋkɔ ɖeɖe koe de dzi, 
\q2 eye eƒe atsyɔ̃ le anyigba kple dziƒowo tame. 
\q1  
\v 14 Ena dzo aɖe do na eƒe dukɔ, 
\q2 esi nye Israel, 
\q1 eƒe ame kɔkɔewo katã ƒe kafukafu, 
\q2 ame siwo tsɔ ɖe eƒe dzi gbɔ. 
\b  
\q1 Mikafu Yehowa. 
\c 149  
\cl Psalmo 149 
\q1  
\v 1 Mikafu Yehowa. 
\b  
\q1 Midzi ha yeye na Yehowa, 
\q2 midzi eƒe kafukafuha le ame kɔkɔewo ƒe asaɖa me. 
\b  
\q1  
\v 2 Israel nekpɔ dzidzɔ le woƒe Wɔla me, 
\q2 Zionviwo netso aseye ɖe woƒe fia la ŋu. 
\q1  
\v 3 Wonekafu eƒe ŋkɔ kple ɣeɖuɖu, 
\q2 eye woneƒo ha nɛ kple asiʋuiwo kple kasaŋku. 
\q1  
\v 4 Elabena Yehowa do dzidzɔ ɖe eƒe dukɔ ŋu, 
\q2 eye wòtsɔ ɖeɖe ɖɔ na ame gblɔewo. 
\q1  
\v 5 Ame kɔkɔewo nekpɔ dzidzɔ le eƒe bubu me, 
\q2 eye woadzi ha kple dzidzɔ le woƒe abawo dzi. 
\b  
\q1  
\v 6 Mawu kafukafu nenɔ woƒe nu me, 
\q2 eye wòanye yi nuevee anɔ woƒe asiwo me, 
\q1  
\v 7 ne woatsɔ abia hlɔ̃ dukɔwo, 
\q2 eye woatsɔe ahe toe na amewo, 
\q1  
\v 8 ne woabla woƒe fiawo kple gakɔsɔkɔsɔ, 
\q2 eye woade kunyowu woƒe bubumewo, 
\q1  
\v 9 ne woawɔ fɔ si wobu wo, woŋlɔ da ɖi ɖe wo ŋu la dzi. 
\q2 Esia nye eƒe ame kɔkɔewo katã ƒe ŋutikɔkɔe. 
\b  
\q1 Mikafu Yehowa. 
\c 150  
\cl Psalmo 150 
\q1  
\v 1 Miakafu Yehowa. 
\b  
\q1 Mikafu Mawu le eƒe Kɔkɔeƒe la me. 
\q2 Mikafui le eƒe dziƒo sesẽ la me. 
\q1  
\v 2 Mikafui le eƒe ŋusẽdɔwo ta. 
\q2 Mikafui le eƒe gãnyenye si ƒo wo katã ta la ta. 
\q1  
\v 3 Mitsɔ kpẽkuku kafui. 
\q2 Mitsɔ saŋku kple kasaŋku kafui. 
\q1  
\v 4 Mikafui kple asiʋui kple ɣeɖuɖu. 
\q2 Mikafui kple kasaŋkuƒoƒo kple dzekuku. 
\q1  
\v 5 Mikafui kple ayawagba eve 
\q2 siwo wotsɔna nɔa wo nɔewo ƒomii. 
\q1 Ɛ̃, mikafui kple ayawagba eve 
\q2 siwo ƒe gbe ɖina sesĩe. 
\b  
\q1  
\v 6 Nu sia nu si me gbɔgbɔ le la, nekafu Yehowa. 
\b  
\q1 Mikafu Yehowa!