\v 12 Cuando estaba en \w angustia|strong="H6887"\w*, \w oró|strong="H2470"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* su \nd ʼElohim\nd* y se humilló \w grandemente|strong="H3966"\w* \w ante|strong="H6440"\w* el \nd ʼElohim\nd* \w de|strong="H6440"\w* sus antepasados.  
\v 13 \w Cuando|strong="H3588"\w* \add Manasés\add* \w oró|strong="H6419"\w*, \w Él|strong="H1931"\w* \w fue|strong="H1931"\w* movido \w por|strong="H3588"\w* \w la|strong="H1931"\w* \w súplica|strong="H8467"\w*, \w escuchó|strong="H8085"\w* \w su|strong="H1931"\w* clamor \w y|strong="H3588"\w* \w lo|strong="H1931"\w* devolvió \w a|strong="H3068"\w* Jerusalén, \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w reino|strong="H4438"\w*. \w Y|strong="H3068"\w* \w Manasés|strong="H4519"\w* \w reconoció|strong="H3045"\w* \w que|strong="H3588"\w* \w solo|strong="H1931"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w es|strong="H1931"\w* \nd ʼElohim\nd*.   
\p
\v 14 Después \w de|strong="H8269"\w* \w esto|strong="H3651"\w*, construyó \w el|strong="H3605"\w* \w muro|strong="H2346"\w* \w exterior|strong="H2435"\w* \w de|strong="H8269"\w* \w la|strong="H3605"\w* \w Ciudad|strong="H5892"\w* \w de|strong="H8269"\w* \w David|strong="H1732"\w*, en \w el|strong="H3605"\w* valle al \w occidente|strong="H4628"\w* \w de|strong="H8269"\w* Gihón, y hasta \w la|strong="H3605"\w* entrada \w de|strong="H8269"\w* \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* \w de|strong="H8269"\w* \w los|strong="H3605"\w* Peces, \w alrededor|strong="H5437"\w* \w de|strong="H8269"\w* Ofel. Elevó \w el|strong="H3605"\w* \w muro|strong="H2346"\w* \w a|strong="H3068"\w* \w gran|strong="H3966"\w* altura y colocó \w jefes|strong="H8269"\w* del \w ejército|strong="H2428"\w* en \w todas|strong="H3605"\w* las \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w* \w de|strong="H8269"\w* \w Judá|strong="H3063"\w*.   
\p
\v 15 \w Quitó|strong="H5493"\w* \w los|strong="H3605"\w* \tl ʼelohim\tl* extraños, \w el|strong="H3605"\w* ídolo de \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd* y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w altares|strong="H4196"\w* \w que|strong="H3605"\w* construyó \w en|strong="H5493"\w* \w la|strong="H3605"\w* Montaña de \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd* y \w en|strong="H5493"\w* Jerusalén. \w Los|strong="H3605"\w* \w echó|strong="H7993"\w* \w fuera|strong="H2351"\w* de \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w*.  
\v 16 \w Después|strong="H5921"\w* reconstruyó \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w y|strong="H5921"\w* \w ofreció|strong="H2076"\w* \w en|strong="H5921"\w* \w él|strong="H5921"\w* \w sacrificios|strong="H2077"\w* \w de|strong="H5921"\w* paz \w y|strong="H5921"\w* \w de|strong="H5921"\w* gratitud. Ordenó \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w que|strong="H5921"\w* sirviera \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w el|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 17 Sin embargo, el \w pueblo|strong="H5971"\w* siguió \w ofreciendo|strong="H2076"\w* \w sacrificios|strong="H2076"\w* \w en|strong="H5750"\w* los lugares \w altos|strong="H1116"\w*, \w aunque|strong="H7535"\w* \w solo|strong="H7535"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* su \nd ʼElohim\nd*.   
\p
\v 18 \w Los|strong="H5921"\w* demás \w hechos|strong="H1697"\w* \w de|strong="H5921"\w* \w Manasés|strong="H4519"\w*, sus súplicas \w a|strong="H3068"\w* su \nd ʼElohim\nd* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w Palabras|strong="H1697"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w videntes|strong="H2374"\w* \w que|strong="H5921"\w* \w le|strong="H5921"\w* \w hablaron|strong="H1696"\w* \w en|strong="H5921"\w* \w Nombre|strong="H8034"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w* ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w ciertamente|strong="H2005"\w* están escritos \w en|strong="H5921"\w* \w las|strong="H5921"\w* crónicas \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w Reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\v 19 Su \w oración|strong="H8605"\w* \w y|strong="H5921"\w* \w cómo|strong="H5921"\w* fue atendido, \w todo|strong="H3605"\w* su \w pecado|strong="H2403"\w*, su infidelidad \w y|strong="H5921"\w* \w los|strong="H5921"\w* sitios \w donde|strong="H5921"\w* \w edificó|strong="H1129"\w* \w lugares|strong="H4725"\w* \w altos|strong="H1116"\w* \w y|strong="H5921"\w* erigió Aseras \w y|strong="H5921"\w* otras imágenes talladas \w antes|strong="H6440"\w* \w de|strong="H5921"\w* humillarse, \w ciertamente|strong="H2005"\w* están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* crónicas \w de|strong="H5921"\w* \w los|strong="H5921"\w* videntes.  
\v 20 \w Manasés|strong="H4519"\w* descansó \w con|strong="H5973"\w* sus antepasados y lo \w sepultaron|strong="H6912"\w* \w en|strong="H5973"\w* su propia \w casa|strong="H1004"\w*. Su \w hijo|strong="H1121"\w* Amón \w reinó|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w*.   
\s1 Reinado de Amón en Judá  
\p
\v 21 Amón tenía 22 \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* \w dos|strong="H8147"\w* \w años|strong="H8141"\w* en Jerusalén.  
\v 22 Practicó \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* ante \nd \+w Yavé|strong="H3068"\+w*\nd*, como su padre \w Manasés|strong="H4519"\w*, pues Amón \w ofreció|strong="H2076"\w* \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ídolos|strong="H6456"\w* \w de|strong="H5869"\w* talla \w que|strong="H3605"\w* su padre \w Manasés|strong="H4519"\w* estableció, y les \w sirvió|strong="H5647"\w*.  
\v 23 \w Pero|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H1931"\w* humilló \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w como|strong="H3588"\w* \w se|strong="H1931"\w* humilló \w su|strong="H1931"\w* padre \w Manasés|strong="H4519"\w*, \w sino|strong="H3588"\w* Amón \w aumentó|strong="H7235"\w* \w su|strong="H1931"\w* culpa.   
\p
\v 24 Sus esclavos \w conspiraron|strong="H7194"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* asesinaron \w en|strong="H5921"\w* su propia \w casa|strong="H1004"\w*.  
\v 25 Pero \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w mató|strong="H5221"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H5921"\w* \w conspiraron|strong="H7194"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* Amón \w y|strong="H5921"\w* proclamó \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w Josías|strong="H2977"\w* \w como|strong="H5921"\w* \w rey|strong="H4428"\w*.   
\c 34  
\s1 Reinado de Josías en Judá  
\p
\v 1 \w Josías|strong="H2977"\w* tenía \w ocho|strong="H8083"\w* \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* 31 \w años|strong="H8141"\w* en Jerusalén.  
\v 2 \w Hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w recto|strong="H3477"\w* ante \nd \+w Yavé|strong="H3068"\+w*\nd* y \w anduvo|strong="H3212"\w* \w en|strong="H5493"\w* los \w caminos|strong="H1870"\w* \w de|strong="H5869"\w* \w David|strong="H1732"\w* su antepasado, \w sin|strong="H3808"\w* \w apartarse|strong="H5493"\w* \w ni|strong="H3808"\w* \w a|strong="H3068"\w* la \w derecha|strong="H3225"\w* \w ni|strong="H3808"\w* \w a|strong="H3068"\w* la \w izquierda|strong="H8040"\w*.   
\p
\v 3 \w El|strong="H1931"\w* \w año|strong="H8141"\w* octavo \w de|strong="H4480"\w* \w su|strong="H1931"\w* \w reinado|strong="H4427"\w*, cuando \w era|strong="H8141"\w* \w todavía|strong="H5750"\w* \w muchacho|strong="H5288"\w*, \w comenzó|strong="H2490"\w* \w a|strong="H3068"\w* buscar \w al|strong="H4480"\w* \nd ʼElohim\nd* \w de|strong="H4480"\w* \w David|strong="H1732"\w* \w su|strong="H1931"\w* antepasado. \w El|strong="H1931"\w* \w año|strong="H8141"\w* 12 \w empezó|strong="H2490"\w* \w a|strong="H3068"\w* purificar \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* y Jerusalén \w de|strong="H4480"\w* \w los|strong="H1931"\w* lugares \w altos|strong="H1116"\w*, las Aseras, \w los|strong="H1931"\w* \w ídolos|strong="H6456"\w* \w de|strong="H4480"\w* talla y las \w imágenes|strong="H4541"\w* \w de|strong="H4480"\w* \w fundición|strong="H4541"\w*.  
\v 4 Demolieron \w en|strong="H5921"\w* su \w presencia|strong="H6440"\w* \w los|strong="H5921"\w* \w altares|strong="H4196"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* baales \w y|strong="H5921"\w* destrozó \w las|strong="H5921"\w* \w imágenes|strong="H4541"\w* \w del|strong="H5921"\w* sol \w que|strong="H5921"\w* había \w en|strong="H5921"\w* \w ellos|strong="H5921"\w*. \w Quebró|strong="H7665"\w* \w las|strong="H5921"\w* Aseras, \w los|strong="H5921"\w* \w ídolos|strong="H6456"\w* \w de|strong="H5921"\w* talla \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w imágenes|strong="H4541"\w* \w de|strong="H5921"\w* \w fundición|strong="H4541"\w*. \w Las|strong="H5921"\w* redujo \w a|strong="H3068"\w* polvo, \w el|strong="H5921"\w* cual esparció \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w sepulcros|strong="H6913"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* ofrecieron \w sacrificios|strong="H2076"\w* \w a|strong="H3068"\w* \w ellas|strong="H5921"\w*.  
\v 5 \w Además|strong="H5921"\w* \w quemó|strong="H8313"\w* \w los|strong="H5921"\w* \w huesos|strong="H6106"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w sobre|strong="H5921"\w* sus \w altares|strong="H4196"\w* \w y|strong="H5921"\w* purificó así \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* Jerusalén.  
\v 6 \w En|strong="H5704"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5704"\w* \w Manasés|strong="H4519"\w*, Efraín, \w Simeón|strong="H8095"\w* \w y|strong="H5704"\w* Neftalí \w y|strong="H5704"\w* sus \w alrededores|strong="H5439"\w*,  
\v 7 \w destruyó|strong="H5422"\w* \w los|strong="H3605"\w* \w altares|strong="H4196"\w*, destrozó las Aseras y \w los|strong="H3605"\w* \w ídolos|strong="H6456"\w* de talla y \w los|strong="H3605"\w* redujo \w a|strong="H3068"\w* polvo. Taló \w todos|strong="H3605"\w* las imágenes \w del|strong="H4196"\w* sol por \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra de \w Israel|strong="H3478"\w* y regresó \w a|strong="H3068"\w* Jerusalén.   
\p
\v 8 \w El|strong="H1121"\w* \w año|strong="H8141"\w* 18 \w de|strong="H1121"\w* su \w reinado|strong="H4427"\w*, después \w que|strong="H1121"\w* \w limpió|strong="H2891"\w* la tierra y la \w Casa|strong="H1004"\w*, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* Safán, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Azalía, \w a|strong="H3068"\w* \w Maasías|strong="H4641"\w*, \w gobernador|strong="H8269"\w* \w de|strong="H1121"\w* la \w ciudad|strong="H5892"\w*, y \w a|strong="H3068"\w* Joa, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Joacaz, cronista, \w que|strong="H1121"\w* repararan la \w Casa|strong="H1004"\w* \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* su \nd ʼElohim\nd*.   
\p
\v 9 Fueron al \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w* \w Hilcías|strong="H2518"\w* y le \w dieron|strong="H5414"\w* \w el|strong="H3605"\w* \w dinero|strong="H3701"\w* recaudado en \w la|strong="H8104"\w* \w Casa|strong="H1004"\w* \w de|strong="H5414"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H3605"\w* \w los|strong="H3427"\w* \w levitas|strong="H3881"\w* porteros \w de|strong="H5414"\w* \w la|strong="H8104"\w* entrada recibieron \w de|strong="H5414"\w* \w mano|strong="H3027"\w* \w de|strong="H5414"\w* \w los|strong="H3427"\w* \w de|strong="H5414"\w* \w Manasés|strong="H4519"\w*, Efraín, \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w resto|strong="H7611"\w* \w de|strong="H5414"\w* \w Israel|strong="H3478"\w*, \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w* y \w Benjamín|strong="H1144"\w* y \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5414"\w* Jerusalén.  
\v 10 \w Lo|strong="H5921"\w* entregaron \w en|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w hacían|strong="H6213"\w* \w la|strong="H5921"\w* \w obra|strong="H4399"\w*, \w los|strong="H5921"\w* encargados \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, quienes \w lo|strong="H5921"\w* \w daban|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* obreros \w que|strong="H5921"\w* \w trabajaban|strong="H6213"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w para|strong="H5921"\w* reparar \w y|strong="H5921"\w* restaurar \w la|strong="H5921"\w* \w Casa|strong="H1004"\w*.  
\v 11 \w También|strong="H7843"\w* \w daban|strong="H5414"\w* \w a|strong="H3068"\w* los ebanistas y los constructores \w para|strong="H5414"\w* que \w compraran|strong="H7069"\w* piedra \w de|strong="H5414"\w* cantería y \w madera|strong="H6086"\w*, \w para|strong="H5414"\w* las armazones y las vigas \w de|strong="H5414"\w* los edificios destruidos \w por|strong="H5414"\w* los \w reyes|strong="H4428"\w* \w de|strong="H5414"\w* \w Judá|strong="H3063"\w*.   
\p
\v 12 \w Estos|strong="H3605"\w* \w hombres|strong="H1121"\w* \w procedían|strong="H6213"\w* \w con|strong="H5921"\w* fidelidad \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w obra|strong="H4399"\w*. Fueron designados \w para|strong="H5921"\w* dirigirlos Jahat \w y|strong="H5921"\w* \w Abdías|strong="H5662"\w*, \w levitas|strong="H3881"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Merari|strong="H4847"\w*, \w y|strong="H5921"\w* \w Zacarías|strong="H2148"\w* \w y|strong="H5921"\w* Mesulam, \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w los|strong="H1121"\w* coatitas, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w levitas|strong="H3881"\w* expertos \w en|strong="H5921"\w* \w instrumentos|strong="H3627"\w* musicales.  
\v 13 Supervisaban también \w a|strong="H3068"\w* \w los|strong="H5921"\w* cargadores \w y|strong="H5921"\w* dirigían \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w hacían|strong="H6213"\w* \w la|strong="H5921"\w* \w obra|strong="H4399"\w* \w en|strong="H5921"\w* \w cualquier|strong="H3605"\w* aspecto. \w De|strong="H5921"\w* \w los|strong="H5921"\w* \w levitas|strong="H3881"\w* \w había|strong="H6213"\w* \w escribas|strong="H5608"\w*, funcionarios \w y|strong="H5921"\w* \w porteros|strong="H7778"\w*.   
\p
\v 14 Al sacar el \w dinero|strong="H3701"\w* \w que|strong="H3027"\w* era llevado \w a|strong="H3068"\w* la \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*, el \w sacerdote|strong="H3548"\w* \w Hilcías|strong="H2518"\w* \w halló|strong="H4672"\w* el Rollo de la \w Ley|strong="H8451"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd* dada \w por|strong="H3027"\w* \w medio|strong="H3027"\w* de \w Moisés|strong="H4872"\w*.  
\v 15 \w Hilcías|strong="H2518"\w* \w habló|strong="H6030"\w* al \w escriba|strong="H5608"\w* Safán: ¡\w Hallé|strong="H4672"\w* el Rollo \w de|strong="H5414"\w* la \w Ley|strong="H8451"\w* \w de|strong="H5414"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w dada|strong="H5414"\w* \w por|strong="H5414"\w* medio \w de|strong="H5414"\w* Moisés!   
\p
\v 16 Safán llevó \w el|strong="H3605"\w* Rollo \w al|strong="H4428"\w* \w rey|strong="H4428"\w* y le informó: Tus esclavos \w hicieron|strong="H6213"\w* \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* \w les|strong="H1992"\w* fue encomendado.  
\v 17 Sacaron \w el|strong="H5921"\w* \w dinero|strong="H3701"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* \w halló|strong="H4672"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* entregaron \w en|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* encargados \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w hacían|strong="H6213"\w* \w la|strong="H5921"\w* \w obra|strong="H4399"\w*.  
\v 18 El \w escriba|strong="H5608"\w* Safán informó también \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: El \w sacerdote|strong="H3548"\w* \w Hilcías|strong="H2518"\w* me \w entregó|strong="H5414"\w* un rollo. \w Y|strong="H3068"\w* Safán \w leyó|strong="H7121"\w* en él \w delante|strong="H6440"\w* del \w rey|strong="H4428"\w*.   
\p
