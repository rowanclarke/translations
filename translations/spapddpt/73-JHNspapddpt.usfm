\p
\v 1 \wj \+w En|strong="G1519"\+w* verdad, \+w en|strong="G1519"\+w* verdad \+w les|strong="G1565"\+w* \+w digo|strong="G3004"\+w*: \+w El|strong="G3588"\+w* \+w que|strong="G3588"\+w* \+w no|strong="G3361"\+w* \+w entra|strong="G1525"\+w* \+w por|strong="G1223"\+w* \+w la|strong="G3588"\+w* \+w puerta|strong="G2374"\+w* \+w en|strong="G1519"\+w* \+w el|strong="G3588"\+w* redil \+w de|strong="G1519"\+w* \+w las|strong="G3588"\+w* \+w ovejas|strong="G4263"\+w*, \+w pero|strong="G2532"\+w* \+w se|strong="G2532"\+w* mete \+w por|strong="G1223"\+w* \+w otro|strong="G3588"\+w* lugar es \+w ladrón|strong="G2812"\+w* \+w y|strong="G2532"\+w* asaltante.\wj*  
