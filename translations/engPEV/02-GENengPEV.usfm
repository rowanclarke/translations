\p \w The|strong="H6440"\w* \w water|strong="H4325"\w* \w was|strong="H1961"\w* still going \w down|strong="H6440"\w*, \w and|strong="H3967"\w* \w on|strong="H5921"\w* \w the|strong="H6440"\w* 1st \w day|strong="H2320"\w* \w of|strong="H8141"\w* \w the|strong="H6440"\w* \w new|strong="H2320"\w* \w year|strong="H8141"\w*, \w Noah|strong="H5146"\w* \w took|strong="H5493"\w* \w off|strong="H5493"\w* \w some|strong="H2009"\w* \w of|strong="H8141"\w* \w the|strong="H6440"\w* roof \w from|strong="H5493"\w* \w the|strong="H6440"\w* big boat \w and|strong="H3967"\w* \w looked|strong="H7200"\w* \w around|strong="H5921"\w*. \w He|strong="H5921"\w* could \w see|strong="H7200"\w* \w that|strong="H7200"\w* \w the|strong="H6440"\w* \w ground|strong="H6440"\w* \w was|strong="H1961"\w* getting \w dry|strong="H2717"\w*.  
