\id EST - Fakai Translation
\h Esta
\toc1 Ran-u Esta
\toc2 Esta
\toc3 Esta
\mt2 Ran-u
\mt1 Esta
\c 1
\s1 Na ruute̱ U-re̱n Vasti u̱-kit
\p 
\v 1 No̱m-tu̱ no̱me̱ ya da-u̱ Zarake̱s\f + \fr 1:1 \ft u̱t-Ibra: Ahasurus.\f* o̱ye̱ u̱r-faru̱k, u̱t-dak u̱t-shik u̱t-shishin u̱ ta'er [127] du̱gu̱ Indiya m-ha u̱ Kus.
\v 2 U̱ da-u o̱ Faru̱k Zarake̱s o̱ye̱ pora-du̱ u̱r-faru̱k du̱ bo̱-u yat-o̱ u̱ sar m-ja u̱r-be̱b ne̱ sok u̱ Susha.
\v 3 U̱ hak-yu̱ u-tu̱tu̱rse̱ yu̱ u̱r-faru̱k, se̱ wa bu̱n mo̱ro̱g-du̱ re̱-du̱ no̱m-u̱ u̱t-re̱ tu̱-yat-to̱ wa u̱ to̱k-ne̱ wa ne̱. Wa bu̱n karma-ne̱ u̱ i-yate̱ dak-u̱ Pasiya u̱ Midiya, u̱ i-yate̱ gas-u o̱ ne̱ e̱ o̱ u̱ku̱n be̱e̱t.
\p 
\v 4 Mo̱ro̱g-du̱ tumb m-te̱ m-roog u̱t-shik u̱t-jwu̱u̱r 180 wa ko̱se̱ tat-u̱ kwu̱m-u̱t wa tu̱ u̱r-faru̱k, u̱ o̱gu̱r yat-de̱ wa ne̱, u̱ fu̱u̱bse̱-u̱t wa ne̱.
\v 5 Da-u̱ ho̱-u̱t to̱ arke̱, se̱ faru̱k Zarake̱s zo̱ng mo̱ro̱g-du̱ u-re̱ u̱ u̱t-ne̱t u̱t-be̱e̱t, u̱ bo̱-u̱ Susha u̱ o̱tte̱ sar m-ja u̱r-be̱b ne̱ sok, du̱gu̱ i-yate̱ m-ha ne̱t-u̱t re̱k-to̱ ne̱, na tumb m-te̱ m-roog u̱t ta'er u̱-me̱ be-du̱ na se̱rte̱ u̱s-te u̱-do̱ u̱ pyu̱-u̱ faru̱k.
\v 6 Na no̱mu̱g kat-du̱ u-bu Faru̱k u̱t-u̱k tu̱ kus-u̱t pus-to̱ u̱ tu̱ bu̱-mu̱ u̱t-ran ne̱, tu̱msu̱ na gu̱g to̱ u̱ ho-u̱s pus-se̱ su̱ so̱-se̱, u̱ kwat-yu̱ m-baku̱t ne̱ yu̱ na su̱bge̱ u̱r-bo̱ngo̱ tu̱msu̱ pora-tu̱ o̱ró u̱ kwam-tu̱ shik ne̱ tu̱ bu̱-mu̱ u̱t-ro u̱ tu̱ pus-to̱ ne̱, na cin to̱ u̱ kat-du̱ u-bu faru̱k. U̱n dam-u̱t kat-du̱ u-bu faru̱k u̱t-taar tu̱ m-baku̱t u̱t-go̱ u̱t-go̱ tu̱ shik sok.
\v 7 Na mo̱k-te̱ u̱t-ne̱t ke̱ u̱-me̱ ko̱k-tu̱ m-bu̱ tu̱ u̱t-kwam tu̱ shik-u̱ tu̱ kwam-tu̱ shikne̱ tu̱ bu̱-mu̱ u̱t-ro, tu̱msu̱ na haatu̱n ke̱ u̱r-faru̱k u-tát, u̱ka kwu̱m-tu̱ faru̱k.
\v 8 Remu̱ bo̱r-u̱t faru̱k na yu̱' ko̱wan wa swa u̱ka wa o̱tte̱ u̱t-sa, remu̱ u̱zu̱ faru̱k yaag u̱t-bo̱r u̱du̱ a no̱mu̱ wa pama e̱ ya ko̱wan u̱ka wa o̱tte̱ u̱t-sa.
\p 
\v 9 U̱ te̱k-u̱ da-u o̱, U-re̱n Vasti zo̱ngte̱ ne̱ta-ne̱ mo̱ro̱g-du̱ re̱-du̱ no̱m u̱t-re̱ u̱ pyu̱-u̱ Faru̱k Zarake̱s.
\p 
\v 10 U̱ ho̱-du̱ u̱t-ta'er, u̱ da-u̱ Faru̱k Zarake̱s o̱o̱ge̱ u̱ ho̱-du̱ ke̱ ne̱, se̱ wa no̱me̱ a-to̱mu̱ wa man ne̱ u̱t-ne̱t u̱t-ta'er u̱t-bo̱r tu̱ no̱mu̱ wa u̱s-pama, Me̱human, u̱ Bizta, u̱ Harbona, u̱ Bigta, Abagta, u̱ Ze̱tar, u̱ Karkas ne̱,
\v 11 wa zu̱ e̱ hatu̱n U-re̱n Vasti, u̱du̱ wa m-wa u̱ to̱p-du̱ u̱r-faru̱k-u̱ wa ne̱ u̱ hi-u̱r wa, remu̱ wa ko̱ste̱ zwarru̱ u-shu̱ wa u̱du̱ tu̱-yat-to̱, remu̱ wa ne̱ta so̱-wa wa sok.
\v 12 Da-u̱ a-to̱mu̱ faru̱k hu̱u̱te̱ u̱t-bo̱r wa, U-re̱n Vasti gu̱gu̱m u̱r-haan. Se̱ faru̱k naas jab so̱k u̱s-ryab ne̱.
\p 
\v 13 Za naas u-da, se̱ faru̱k no̱m u̱s-rem u̱ ya-m-nap i yadu̱ wa u̱s-rem ne̱, i nape̱ bo̱r-tu̱ ne̱t-tu̱ Pasiya, remu̱ u̱zu̱ ko̱-uyan da wu̱n no̱m u̱s-remu̱ u̱ a-nap-mu̱ u̱t-bo̱r ne̱.
\v 14 Dim-tu̱ i-yate̱ faru̱k to̱ o̱ye̱ Karshe̱na, Shetar, Admata, Tarshis, Me̱re̱s, Marse̱na, u̱ Me̱mukan, ayan-ne̱ o̱ye̱ tu̱-yat-to̱ ne̱t-tu̱ Pasiya u̱ Midiya-ne̱. U̱ na shu̱'u̱te̱ faru̱k ne̱ u-da u-be̱e̱t u̱n o̱ tu̱msu̱ m-shu̱p u̱ o̱g-u̱t yat-to̱ ne̱ u̱-me̱ u-dak.
\p 
\v 15 Se̱ faru̱k shit wa u̱zu̱ <<¿Remu̱ u̱t-bo̱r yan o̱ na do̱'e̱ no̱mu̱ U-re̱n Vasti? Wa do̱ro̱g u̱t-bo̱r yu̱ yu̱-Yat-ya a-to̱mu̱ Faru̱k Zarake̱s ya'e̱ wa da.>>
\p 
\v 16 Me̱mukan shu̱s u̱ shu̱ faru̱k tu̱msu̱ u̱ shu̱ tu̱-yat-to̱, <<U-re̱n Vasti no̱ng no̱mu̱ za kame̱ da, za u̱du̱ faru̱k de̱ u̱ war-wa da m-ha tu̱-yat-to̱ ne̱ u̱t-be̱e̱t, tu̱msu̱ u̱du̱ u̱t-ne̱t u̱t-be̱e̱t u̱ i o̱ me̱ faru̱k-u̱r Faru̱k Zarake̱s u̱r-be̱e̱t.
\v 17 Remu̱ u̱zu̱ no̱m-u̱ u-re̱n no̱me̱ u̱t-shu̱'u̱t u̱s-nap u̱du̱ ko̱ ne̱ta he̱, e̱ shu̱'u̱t a-za yadu̱ m-ze̱g u̱du̱ campa-u̱t e̱ ne̱, <Faru̱k Zarake̱s zu̱ na haatu̱n U-re̱n Vasti u̱-shu̱ wa, wa zu̱, <<U̱m za u̱ haan u̱du̱ wa da.>> Remu̱ iya, a se̱ in no̱mu̱g no̱mu̱ campa-u̱t in ware̱ in da.>
\v 18 U̱ kanda ho̱-u̱r rinde̱ aru̱k, ne̱ta-tu̱ tu̱-yat-to̱ faru̱k-u̱ tu̱-yat-to̱ Pasiya u̱ Midiya-ne̱ a e̱ ho̱ge̱ no̱mu̱ u-re̱n no̱me̱, tu̱msu̱ e̱ do̱'e̱ no̱mu̱ campa-u̱t e̱ rem-su̱ u̱s-ju̱ru̱m u̱ka wa nomte̱. Tu̱msu̱ do̱'e̱ haatu̱n u̱s-ju̱ru̱m u̱ ko̱b-du̱ shu̱'u̱t-du̱ m-yar ne̱.
\p 
\v 19 <<Remu̱ iya, a mu̱ne̱ u̱zu̱ no̱ngu̱ faru̱k u̱r-zwar, yage̱ wa no̱m u̱t-bo̱r tu̱ u̱r-faru̱k tu̱msu̱ yage̱ na no̱m u̱s-pan u̱ bo̱r-tu̱ Pasiya u̱ Midiya-ne̱, tu̱ na za u̱t-pas da, tu̱msu̱ u̱zu̱ U-ren Vasti zamu̱n u̱ cwadu̱ shu̱ faru̱k Zarake̱s da, tu̱msu̱ yage̱ faru̱k-u̱ yase̱ waku̱n o̱g-du̱ u̱r-faru̱k u̱du̱ waku̱n wu̱ ze̱ge̱ wu̱n.
\v 20 Da-u̱ ko̱wan ho̱ge̱ do̱nse̱-du̱ faru̱k no̱me̱ u̱-me̱ gas-u̱ wa o̱tte̱ u̱r-faru̱k u-be̱e̱t, tu̱msu̱ ne̱ta-ne̱ do̱'e̱ yadu̱ m-ze̱g u̱du̱ campa-u̱t e̱ du̱gu̱ ne̱ta yat-o̱ u̱ m-ha wu̱ re̱k-wa ne̱.>>
\p 
\v 21 Se̱ faru̱k u̱ tu̱-yat-to̱ wa ne̱ e̱ ho̱g u̱r-zwar du̱ rem-u̱s se̱ so̱k, se̱ faru̱k no̱m u̱ka Me̱mukan zu̱tte̱ wa no̱m.
\v 22 Se̱ wa tomot u̱s-pan m-ha ko̱yu̱he̱ gas-ya u̱ dak-u̱ u̱r-faru̱k-u̱ wa u-be̱e̱t, ko̱yu̱he̱ gas-ya u̱ su̱wa pan-se̱ tu̱msu̱ ko̱tu̱he̱ ne̱t-to̱ u̱ rem-u̱r e̱, u̱zu̱ ko̱ campa he̱ no̱m u̱r-faru̱k u̱ bu-u wa.
\c 2
\s1 Esta shu̱'u̱te̱ U-re̱n
\p 
\v 1 Da-u̱ jab-u̱ Faru̱k Zarake̱s tore̱, se̱ wa baku̱s Vasti u̱ no̱m-u̱ wa no̱me̱ ne̱ tu̱msu̱ u̱ bo̱r-tu̱ na no̱me̱ u̱ mo̱t-u̱t wa ne̱.
\v 2 Se̱ e̱ke̱n u̱ te̱k-u̱ a no̱mu̱ faru̱k m-to̱k i o̱ye̱ u̱t-mo̱r u̱ wa ne̱ e̱ zu̱, <<Yage̱ na kwu̱mu̱ faru̱k ya-u̱t-gwu̱p i so̱-ye̱ i nape̱ campa da.
\v 3 Yage̱ faru̱k wa i-yate̱ du̱gu̱ ko̱-u̱-he̱ gas-o̱ u̱-me̱ u-dak, u̱ remu̱ e̱ haatu̱n ya-u̱t-gwu̱p i o̱ so̱-ye̱ i nape̱ campa-ne̱ da, u-bu u̱ na nomte̱ u̱r-cu̱n du̱ ya-u̱t-gwu̱p faru̱k\f + \fr 2:3 \ft u-bu u̱ na nomte̱ u̱r-cu̱n du̱ ya-u̱t-gwu̱p faru̱k (wata o̱ na foge̱ Harem).\f* u̱ bo̱-u̱ Susha u̱ o̱tte̱ sar m-ja u̱r-be̱b ne̱ sok. Yage̱ na wa Hegai wa shu̱'u̱t man faru̱k, wu̱ shu̱'u̱te̱ wa-gwat-du̱ ya-u̱t-gwu̱p faru̱k i nape̱ campa-ne̱ da, u̱ shu̱'u̱t u̱zu̱ wa wa'ag u̱n no̱m u̱s-mang u̱ no̱o̱g-mu̱ mangu̱ u-war u̱ka wa o̱tte̱ u̱t-sa.
\v 4 Se̱ gwu̱p wu̱ cite̱ faru̱k wa kabu̱ wa wa shu̱'u̱t u-re̱n ba Vasti.>> Se̱ rem-u̱s se̱ no̱me̱ faru̱k u̱r-zwar, wa dor se̱.
\p 
\v 5 Waku̱n o̱ro u̱ku̱n ne̱t-u̱ Yahuda wa o̱ m-yu̱ u̱ bo̱-u̱ Susha u̱ o̱tte̱ sar u̱ m-ja u̱r-be̱b ne̱ sok. Wa o̱o̱n du̱gu̱ ko̱-u̱r Banyamin. Na zu̱ wa Modekai. Wa'-u̱ Jir, Jir o̱g wa'-u̱ Shimi, Shimi wa'-u̱ Kis.
\v 6 U̱s-hak u-tát su̱ arke̱ wa o̱ teku̱ ne̱t-tu̱ Faru̱k Nebukanezar kabne̱ du̱gu̱ Urusharima m-ha Babira, i na kabne̱ ko̱-u̱r Jekoniya ne̱ faru̱k-u̱ Yahuda.
\v 7 Modekai o̱tte̱ du̱-dim-u̱ wa'-u̱ hu̱no̱ u̱so-u wa ya-du̱ u̱r-gwu̱p de̱ o̱ so̱-de̱ so̱k na zu̱ wa, Hadassa, tu̱msu̱ na zu̱ Esta. Da-u̱ i mate̱ wa mare̱, Modekai ku̱b wa u̱ bu-u wa wa shu̱'u̱t u̱ka wa'-u̱ wa.
\p 
\v 8 Da-u̱ na no̱me̱ do̱nse̱-du̱ bo̱r-u̱t faru̱k, na haatu̱n ya-u̱t-gwu̱p u-tát u̱ bo̱-u̱ Susha u̱ o̱tte̱ sar u̱ m-ja u̱r-be̱b ne̱ sok na zu̱ u̱ Hagai u̱ ha gwat-du̱ e̱. Tu̱msu̱ Esta o̱ teku̱ i na kabne̱ m-ha u̱ pyu̱-u̱ faru̱k, Hegai wa shu̱'u̱t wa gwat-du̱ e̱.
\v 9 Esta cite̱ Hagai so̱k wa kwu̱mu̱g hyu̱-m pus-mo̱ u̱du̱ wa. Za naas uda wu̱n kwu̱mnu̱ wa no̱m u̱t-re̱ u̱ no̱o̱g-mu̱ mang u̱ u-war ne̱. U̱ na zo̱nge̱ u̱ remu̱ Esta na yu̱' wa ya'ag u̱t-gwu̱p ta-e̱r du̱gu̱ pyu̱-u̱ Faru̱k se̱ na ku̱b wa na toot wa u̱ be-du̱ ze̱ge̱ u̱r-zwar u̱ be-du̱ na cinte̱ ya-u̱t-gwu̱p-u̱ faru̱k.
\p 
\v 10 Esta waru̱g u̱zu̱ wa-Yahuda wa o̱o̱ge̱ da tu̱msu̱ bu-u wan o̱ wa rwu̱tu̱n da remu̱ u̱zu̱ Modekai hoste̱ wa waru̱ waku̱n.
\v 11 Ko̱ mu̱ne̱ Modekai hu̱ u-shu̱ u̱ dim ne̱ u̱ dapu̱s kat-du̱ u-bu be-du̱ na cinte̱ ya-u̱t-gwu̱p remu̱ wa hyan u̱ka Esta o̱tte̱ tu̱msu̱ wa hyan no̱mu̱ do̱'e̱ kwu̱m-du̱ wa.
\p 
\v 12 Ko̱wu̱he̱ gwu̱pwa wu̱ nape̱ campa da na yu̱' wa m-gyu̱p m-gan u̱ wa shu̱'u̱t u̱ faru̱k ne̱. Kanda na kab gwu̱p m-ha u̱ yu̱n-u Faru̱k Zarake̱s, se̱ wa no̱ng u̱s-pyat u̱s-o̱p u̱s-yu̱r u̱ mangu̱ u-war, u̱s-pyat u̱s-shishin na o̱ tamu̱ wa m-no̱o̱g, tu̱msu̱ u̱s-pyat u̱s-shishin na o̱ tamu̱ wa m-no̱o̱g mu̱ wu̱s u-haku̱n.
\v 13 Da da-u̱ teye̱ u̱ wa do̱te̱ u̱ cwadu̱ pyu̱-u̱ faru̱k, na yu̱ wa u̱r-ke̱r wa du̱st no̱mu̱ wa o̱o̱ge̱ u̱ssa u-be̱e̱t du̱gu̱ bu-u̱ na cinte̱ ne̱ta-ne̱ m-cwa u̱du̱ Faru̱k.
\v 14 M-rim wa do̱'e̱ m-ha u̱-ku̱n, u̱r-wu̱n wa mu̱u̱n u̱ o̱ko̱n gas-o̱ u̱ be-du̱ na cinte̱ ya-u̱t-gwu̱p i Faru̱k, i o̱o̱ge̱ u̱ ko̱m-u̱t Shaasgaz, wu̱ o̱o̱ge̱ man faru̱k wu̱ gote̱ ne̱ta-tu̱ u̱s-kit i faru̱k rooge̱ u̱ e̱ ne̱. Wu̱n zaar u̱t-mu̱u̱n da se̱ bit-u̱k u̱zu̱ cikte̱ faru̱k wa fagu̱ wu̱n u̱ dim-u̱r ró.
\p 
\v 15 Da da-u Esta byu̱r-ne̱ (wu̱ Modekai kabne̱ wa shu̱'u̱t wa'-u̱ wa, gwu̱p-u̱ hu̱no-u̱ u̱so wa Abiher) u̱ wa do̱te̱ cwadu̱ du̱ faru̱k, Esta shu̱k-u̱t o̱ko̱n da se̱ no̱mu Hagai man faru̱k wa gwat-du̱ bu-u̱ na cinte̱ ya-u̱t-gwu̱p i Faru̱k waru̱ wa. Tu̱msu̱ wa kum hyu̱-m pusmo̱ u̱du̱ ko̱wan wu̱ hyane̱ wa.
\v 16 Na ku̱b Esta m-ha u̱du̱ Faru̱k Zarake̱s u̱ pyu̱-u̱ wa u̱ pyat-yu̱ na foge̱ Tibet (pyat-yu̱ u-o̱p yu̱ Yahuda-ne̱)\f + \fr 2:16 \ft u̱ ogor-tu̱ uno̱ da-o̱ pyat-yu̱ Tibet ya o̱ te̱k-u̱ mo̱t-du̱ pyat-yu̱ o̱p u-yu̱r (Disamba) m-ha mo̱t-du̱ pyat-yu̱ u-gan (Janairu).\f*, u̱ hak-yu̱ u-ta'er yu̱ faru̱k-u̱r wa.
\p 
\v 17 Faru̱k o̱ cwan-u̱t Esta m-ze̱g ko̱wu̱he̱ gwu̱p wa. Wa o cwan-u̱t wa so̱k tu̱msu̱ wa kum hyu̱-m pusmo̱ u̱du̱ wa m-ze̱g ya-u̱t-gwu̱p be̱e̱t. Remu̱ iya wa wa'u̱ Esta to̱p-du̱ u̱r-faru̱k wa zu̱ wa o̱ u-re̱n u̱ka Vasti.
\v 18 Se̱ faru̱k no̱m mo̱ro̱g-du̱ re̱-du̱ no̱m-u u̱t-re̱, u̱ ya-du̱ Esta m-ze̱g. Wa bu̱n i-yate̱ pyu̱-u̱ wa u̱ to̱k-ne̱ wa ne̱ be̱e̱t tu̱msu̱ wa yu̱' u̱r-hure̱ u̱s-gas u̱s-be̱e̱t tu̱msu̱ wa no̱mu̱ u̱t-ne̱t u-nya u-tát u̱ka kwu̱m-tu̱ faru̱k-u̱r wa.
\s1 Modekai gwu̱u̱g fat-u̱r Faru̱k
\p 
\v 19 Da-u̱ na o̱ye̱ u̱ kargu̱sse̱ ya-u̱t-gwu̱p-u̱ da-u yu̱ru̱m-se̱, Modekai o̱ shu̱'u̱t u̱ is-u̱ bu-u faru̱k.
\v 20 Esta wargu̱ waku̱n u̱zu̱ wa-Yahuda wa o̱o̱ge̱ da tu̱msu̱ u̱ bu-u̱ wa ko̱ du̱gu̱ ko̱-u̱r wande̱ wa rwu̱tu̱n da, u̱ka Modekai zu̱tte̱ wa no̱m. Wa re̱ u-shu̱ do̱rru̱ no̱m-u̱ Modekai waru̱ wa da-u̱ wa o̱ re̱k-de̱.
\p 
\v 21 Da-u̱ Modekai o̱ u̱ shu̱'u̱t u̱ is-u̱ bu-u faru̱k, se̱ to̱ko̱n ne̱t-to̱ i-yate̱ faru̱k i o̱ e'-du̱ is-u̱ bu-u faru̱k, Bigtan u̱ Te̱re̱s e̱ no̱ng u̱s-ryab u̱ Faru̱k Zarake̱s ne̱, har e̱ zo̱ngte̱ e̱ u̱t-sa e̱ ho̱ wa.
\v 22 Modekai hog no̱m-u̱t yo̱-to̱ tu̱ u̱n zo̱nge̱ u̱t-no̱m, wa ware̱ U-re̱n Esta. Se̱ Esta waru̱ faru̱k u̱zu̱ Modekai wa ho̱ge̱ no̱mu̱ u̱n zo̱nge̱ u̱t-no̱m.
\v 23 Da-u̱ na gwate̱ se̱ na nu̱p u̱zu̱ rem-u̱s Modekai nip-to̱ se̱ na tu̱r u̱t-ne̱t u̱t-yu̱r u-kan. Faru̱k yaag u̱t-bo̱r u̱zu̱ na no̱m u̱s-pan su̱ rem-u̱s se̱ u-me̱ u̱t-ran tu̱ cu̱n-du̱ u̱s-rem u̱-shu̱ faru̱k.
\c 3
\s1 Haman zo̱ngte̱ ho̱du̱ Yahuda-ne̱
\p 
\v 1 Da da-u̱ arke̱, Faru̱k Zarake̱s yu̱' Haman wa'-u̱ Hamedata m-ze̱g, ne̱t-u̱ Agagite, wa yu̱ns wa m-pas tu̱-yat-to̱ faru̱k be̱e̱t.
\v 2 To̱k-ne̱ faru̱k be̱e̱t e̱ do̱'e̱ u̱t-he̱ u̱t-jwu̱n u̱ shu̱ Haman e̱ ya' wa m-ze̱g, remu̱ u̱zu̱ faru̱k zu̱u̱g na no̱m-u̱ wa iya da-u̱ wa o̱ aru̱k. Se̱di Modekai gu̱gu̱m ya-du̱ wa m-ze̱g.
\p 
\v 3 Se̱ to̱k-ne̱ faru̱k i o̱ye̱ u̱ ees u̱ is-u̱ faru̱k e̱ shit Modekai, u̱zu̱ <<¿Yan-o̱ wa'e̱ bo̱ yaag faru̱k m-ze̱g u̱ bo̱r-tu̱ wa ya'e̱ da?>>
\v 4 E̱ no̱m u̱s-rem u̱ wa ne̱ ko̱du̱he̱ ho̱-de̱, se̱di wa hen wa gu̱gu̱m u̱t-e̱r. Se̱ u̱n waru̱ Haman no̱mu̱ no̱me̱ remu̱ u̱n hyan no̱m-u̱ wa do̱'e̱ no̱mu̱ Modekai, ko̱ wu̱n u̱ ho̱gu̱ o̱n-u̱r wa ko̱ ba shu̱'u̱t u̱zu̱ wa zu̱u̱g ne̱t-u̱ Yahuda wa o̱ye̱.
\p 
\v 5 Da-u̱ Haman hyane̱ u̱zu̱ Modekai he̱e̱g u̱t-jwu̱n wa yu̱' wa m-ze̱g da, se̱ wa no̱m jab so̱k.
\v 6 Da-u̱ Haman nape̱ u̱zu̱ Modekai ne̱t-u̱ Yahuda wa, se̱ wa zu̱ Modekai ko̱rge̱ na ho̱ wa u̱ war-wa da, wa zu̱ na ho̱ Yahuda-ne̱ be̱e̱t i o̱ye̱ u̱ faru̱k-u̱r Zarake̱s.
\p 
\v 7 U̱ te̱k-u̱ hak-su̱ o̱p u̱s-yu̱r su̱ Faru̱k Zarake̱s, u̱ pyat-yu̱ na foge̱ Nisan wato pyat-yu̱ u-nas (pyat-yu̱ u̱r-taku̱n yu̱ Yahuda-ne̱)\f + \fr 3:7 \ft u̱ ogor-tu̱ uno̱ da-o̱ wata pyat-yu̱ u-nas (Afriru).\f* u̱n no̱m u-gwe̱mbi u̱ shu̱ Haman na du̱g u̱r-ho̱ u̱ u-pyat ne̱. Se̱ du̱k-tu̱ he̱e̱n u̱ pyat-yu̱ na foge̱ Adar wato pyat-yu̱ u-ta'er (pyat-yu̱ o̱p u-yu̱r yu̱ Yahuda-ne̱)\f + \fr 3:7 \ft u̱ ogor-tu̱ uno̱ da-o̱ wata pyat-yu̱ u-tu̱t (Maris).\f*.
\p 
\v 8 Se̱ Haman zu̱ Faru̱k Zarake̱s, <<To̱ko̱n ne̱t-to̱ o̱rò u̱ bu̱rgu̱sse̱ u̱ te̱k-u̱ ne̱t-u̱t rò u̱ te̱k-u̱ dak u̱r-faru̱k-u̱ rò ko̱ u-yan u̱ e̱ o̱ m-sha u̱r-ko̱b u̱-me̱ ne̱t-u̱t rò e̱ yaag m-sek u̱ bo̱r-u̱t faru̱k da. Remu̱ iya kamu̱g u̱ faru̱k ho̱g o̱n-u̱r u̱n da.
\v 9 A mu̱ne̱ u̱zu̱ no̱ng faru̱k u̱r-zwar, yage̱ u̱ bo̱r-tu̱ rwu̱n u̱zu̱ na ho̱ru̱sse̱ u̱n, tu̱msu̱ u̱m do̱'e̱ wadu̱ kwam-u̱t pus-to̱ tu̱ o̱tte̱ no-mu̱ u̱t-kwano u̱t-zo̱ngu u̱t-ko̱k u̱t-tu̱t u̱ u̱t-zo̱ngu tu̱ kwaz-tu̱ u̱t-yu̱r u̱ o̱p [350,000] u̱-me̱ cu̱n-du̱ faru̱k remu̱ campa-ne̱ i kabe̱ no̱m-du̱ mo̱ ank-mo̱.>>
\p 
\v 10 Se̱ faru̱k ku̱b kwat-yu̱ o̱ye̱ m-wa u̱ jow wa. Kwat-yu̱ o̱tte̱ nap-su̱ u̱r-faru̱k u̱ do̱m-u̱ ya. Wa yase̱ ya u̱du̱ Haman. Haman wa o̱o̱ge̱ wa'-u̱ Hamedata, ne̱t-u̱ Agagite, hu̱u̱b-u̱ yo̱-o̱ Yahuda-ne̱.
\v 11 Faru̱k zu̱ Haman, <<Cin shik tu̱msu̱ bo̱ no̱me̱ ne̱t-u̱t to̱ u̱ka bo̱ tonte̱.>>
\p 
\v 12 Se̱ u̱ ho̱-du̱ o̱p u̱t-tu̱t u̱ pyat-yu̱ na foge̱ Nisan (pyat-yu̱ u̱r-taku̱n yu̱ Yahuda-ne̱) \f + \fr 3:12 \ft u̱ ogor-tu̱ uno̱ da-o̱ wata pyat-yu̱ u-nas. O̱p u̱t-ta'er u̱ pyat-yu̱ u-nas (17 Afriru).\f*se̱ na fog a-u̱s-ge̱n u̱ faru̱k ne̱, e̱ no̱m u̱s-ge̱n m-ha me̱ ko̱du̱he̱ ko̱-de̱ tu̱msu̱ m-ha u̱du̱ Wa-u-dak ko̱-u̱-he̱ gas-o̱ u̱-me̱ u̱t-ne̱t u̱t-be̱e̱t u̱ka Haman yu̱te̱ u̱t-bo̱r u̱du̱ to̱k-ne̱ faru̱k yu̱-Yat-ya u̱t-ne̱t ne̱. Na no̱m u̱s-ge̱n u̱ dim-u̱r Faru̱k Zarake̱s u̱ hi-u̱r wa u̱ wa-du̱ kom-u̱ wa ne̱.
\v 13 Na yase̱ ran-tu̱ u̱s-ge̱n u̱du̱ to̱k-ne̱ faru̱k-u̱ e̱ yase̱ u̱ dak-u wa u-be̱e̱t, no̱mu̱ na zu̱ye̱ u̱-me̱ u̱s-pan ya u̱ ho̱-du̱ o̱p u̱t-tu̱t u̱ pyat-yu̱ o̱p u-yu̱r, wata u̱ ho̱-du̱ u̱t-ta'er u̱ pyat-yu̱ u-tu̱t yu̱ na foge̱ Adar\f + \fr 3:13 \ft u̱ ogor-tu̱ uno̱ wata pyat-yu̱ u-tu̱t. U̱t-ta'er u̱ pyat-yu̱ u-tu̱t. (7 Maris).\f*, na do̱'e̱ ho̱du̱ Yahuda-ne̱ i re̱k-e̱ u̱t-ne̱ta ne̱ be̱e̱t, u̱ campa-ne̱, u̱ ya-u̱t-gwu̱p, u̱ ya-u̱t-zwar ne̱ na ho̱ e̱ be̱e̱t na o̱nk no̱m-tu̱ e̱ o̱tte̱ u̱t-be̱e̱t.
\v 14 No̱mu̱ o̱ye̱ m-pan u̱-me̱ u-ran na wa'u̱ o̱ shu̱'u̱t u̱t-bo̱r ko̱he̱ne̱, na no̱m u̱r-do̱nse̱ u̱du̱ u̱t-ne̱t u̱t-be̱e̱t u̱-me̱ u-dak rem u̱zu̱ ko̱wan shu̱'u̱t u̱s-zo̱ng ne̱ u̱ ho̱-u̱r re̱.
\p 
\v 15 U̱ka faru̱k yu̱te̱ u̱t-bo̱r, se̱ ne̱t-tu̱ o̱o̱ge̱ m-sak do̱m-u̱ jwaak e̱ ku̱b ran-tu̱ u̱s-pan m-ho̱ m-ho̱r m-cwa u̱-me̱ bo̱-u̱ Susha u̱ o̱tte̱ sar m-ja u̱r-be̱b ne̱ sok. Faru̱k e̱ Haman da-u̱ e̱ shu̱'u̱te̱ e̱ o̱ swadu̱ ke̱, se̱di ne̱t-tu̱ bo̱-u̱ Susha u-be̱e̱t e̱ o̱ te̱k u-gwu̱z.
\c 4
\s1 Modekai zu̱ Esta se̱ge̱ wa
\p 
\v 1 Da-u̱ Modekai kume̱ zu̱n-mu̱ no̱mu̱ no̱me̱ u-be̱e̱t, se̱ wa kees u̱t-kus tu̱ u-war, u̱ remu̱ namu̱ jab. Se̱ wa wu̱' cwu̱-tu̱ namu̱ jab m-cwa-ne̱, se̱ wa aru̱k m-cwa u-bo̱ wa o̱ u̱s-kan m-yat sok.
\v 2 Se̱di da-u̱ wa tene̱ is u-bu u̱ faru̱k, na yaag wa aru̱k m-cwa u̱-me̱ u-bu da rem u̱zu̱ waku̱n zaar wu̱ do̱'e̱ cwadu̱ bu-u faru̱k-u̱ ku̱s-tu̱ namu̱ jab ne̱ da.
\v 3 Ko̱he̱ne̱ u̱ dak-u̱t faru̱k u-be̱e̱t u̱ be-du̱ bo̱r-u̱t wa te̱ye̱ u-be̱e̱t, se̱ Yahuda-ne̱ no̱m u̱s-kan m-yat sok u̱ namu̱ jab ne̱ tu̱msu̱ u-swaat ne̱, u̱t-ne̱t u-tát u̱-me̱ u̱n e̱ wu̱ kus-tu̱ namu̱ jab e̱ re̱t u̱-me̱ m-cwa.
\p 
\v 4 Da-u̱ ya-u̱t-gwu̱p u̱r-shu̱-e̱ i o̱ye̱ no̱mu̱ U-re̱n Esta m-to̱k e̱ haan e̱ waru̱ wa mo̱t-u̱t Modekai, se̱ Esta no̱m namu̱ jab so̱k. Se̱ Esta tomtu̱ u̱t-kus u̱ Modekai swase̱ kus-tu̱ namu̱ jab, se̱di Modekai o̱nkte̱ da.
\v 5 Se̱ Esta o̱tte̱ to̱k wu̱ na zu̱ye̱ Hatak, wu̱ faru̱k ya'u̱ wa. Se̱ Esta fog wa, Esta zu̱, <<Do̱'e̱ bo̱ hyan u̱zu̱ yan-o̱ kume̱ Modekai tu̱msu̱ bo̱ shit wu̱n u̱zu̱ yan-o̱ kume̱ wa tu̱msu̱ u̱zu̱ yan-o̱ wa o̱tte̱ u̱ namu̱ jab.>>
\p 
\v 6 Se̱ Hatak do̱'e̱ u̱du̱ Modekai u̱ be-du̱ m-zu̱n u̱-do̱ u-bo̱ u̱-shu̱ is-yu̱ cwadu̱ pyu̱-u̱ faru̱k.
\v 7 Modekai waru̱ wu̱n no̱mu̱ no̱me̱ u-be̱e̱t. Wa waru̱ Hatak shik-u̱ Haman no̱m-te̱ e̱s-du̱ u̱s-rem u̱zu̱ wa u̱t-hu̱u̱t be-du̱ u̱r-cu̱nu̱ faru̱k, a mu̱ne̱ u̱zu̱ na ho̱o̱g Yahuda-ne̱ be̱e̱t.
\v 8 Modekai yasu̱ Hatak bo̱r-tu̱ na pane̱ u̱ Susha tu̱ zu̱ye̱ na ho̱ Yahuda-ne̱ be̱e̱t. Modekai kon Hatak u̱zu̱ wa ko̱se̱ Esta ran-tu̱ bo̱r-u̱ to̱ wa waru̱ wa u̱zu̱ wa do̱'e̱ u̱du̱ Faru̱k wa kon wa, wa no̱m u̱s-ko̱n u̱ remu̱ ne̱t-u̱t wa.
\p 
\v 9 Se̱ Hatak mu u̱du̱ Esta wa waru̱ wa no̱m-u̱ Modekai zu̱ye̱.
\v 10 Se̱ Esta waru̱ Hatak u̱zu̱ wa mu wa waru̱ Modekai u̱zu̱,
\v 11 <<Bo̱r-tu̱ o̱ró tu̱ ha-mu̱ hyan-du̱ faru̱k, tu̱msu̱ i-yate̱ wa u̱ ne̱t-u̱t wa ne̱ u̱t-be̱e̱t e̱ nak u̱ mo̱t-tu̱ bo̱r-u ya ne̱. Ko̱wana u̱r-cwa u̱du̱ faru̱k za faru̱k-u̱ fag wa na ho̱ wa. Fu̱n-ya u-gan u̱ war-ya yu̱ ne̱t de̱te̱ u̱t-ku̱su̱m a mu̱ne̱ faru̱k nabu̱g ko̱m-yu̱ m-baku̱t yu̱ u̱r-faru̱k-u̱ wa u̱du̱ ne̱t. U̱ ya-o̱ teeg m-roog u̱r-shik u̱ o̱p u̱ faru̱k fu̱gte̱ me̱ u̱ pyu̱-u̱ wa.>>
\p 
\v 12 Da-u̱ na waru̱ Modekai no̱m-u̱ Esta zu̱ye̱,
\v 13 Modekai mutu̱ Esta u-nu wa zu̱, <<A-bo̱ gwat u̱zu̱ bo̱ u̱t-ku̱su̱m rem u̱zu̱ bo̱ o̱ shu̱'u̱t u̱-me̱ bu-u faru̱k da. A mu̱ne̱ u̱zu̱ na hog Yahuda-ne̱ be̱e̱t na da yagu̱ bo̱ da.
\v 14 Remu̱ u̱zu̱ a bo̱ hose̱ u̱s-ram gwu̱du̱ Yahuda-ne̱ do̱'e̱ rwu̱u̱n u̱ yaku̱n fu̱n-ya, tu̱msu̱ bo̱ u̱ bu-u no̱ ne̱ u-be̱e̱t na do̱'e̱ ho̱du̱ no̱ be̱e̱t. ¿Wana nape̱ ko̱ jiya remu̱ go̱-du̱ uno̱ da-o̱ wa'e̱ na du̱g-u̱t bo̱ u-re̱n?>>
\p 
\v 15 Esta no̱m to̱m u̱du̱ Modekai, u̱zu̱,
\v 16 <<De̱'e̱ bo̱ kargu̱sse̱ Yahuda-ne̱ i o̱ye̱ u̱ Susha, e̱ no̱m u-swa'at u̱ remu̱ ri. A no̱ re̱ ko no̱ swa da m-roog u̱t-tu̱t m-gyu̱p u-ho̱ ne̱. Me̱ u̱ ya-u̱t-gwu̱p-u̱ ri ne̱ it u̱t-no̱m u̱ka no̱ nomte̱. Da-u̱ na tase̱, me̱ u̱t-ha u̱du̱ faru̱k, ko̱ ba shu̱'u̱te̱ u̱zu̱ pas-du̱ u̱t-bo̱r de̱. A shu̱'u̱te̱ u̱zu̱ m-mar, se̱di m-mar.>>
\p 
\v 17 Modekai aru̱k wa no̱m no̱m-u̱ Esta zu̱ye̱ wa no̱m.
\c 5
\s1 Ko̱n-u̱s Esta u̱du̱ faru̱k
\p 
\v 1 U̱ ho̱-du̱ tu̱tu̱rse̱ Esta wu̱' u̱t-kus tu̱ u-re̱n. Wa to u̱ kur-u̱ me̱ m-gwat pyu̱, Faru̱k o̱ u̱ shu̱'u̱t u̱ pora-du̱ u̱r-faru̱k, du̱ o̱ye̱ m-gwat is-yu̱ u̱r-cwa.
\v 2 Da-u̱ faru̱k hyane̱ U-re̱n Esta u̱ ees u̱-shu̱ pyu̱-u̱ faru̱k no̱m u̱r-so̱ so̱k, se̱ wa nu̱b ko̱m-yu̱ m-bak-u̱t yu̱ bu̱-mu̱ u̱t-rò yu̱ u̱r-faru̱k yu̱ o̱ye̱ u̱ ko̱m-u̱t wa. Tu̱msu̱ Esta haan se̱ wa tu̱m ko̱m-yu̱ u̱r-faru̱k.
\p 
\v 3 Se̱ faru̱k shit, <<¿Yan-o̱, U-re̱n Esta? ¿Yan-o̱ bo̱ u̱t-sa? Ko̱ u̱zu̱ u̱k u̱r-faru̱k o̱ bo̱ u̱t-sa, me̱ ya'u̱ bo̱ o̱.>>
\p 
\v 4 Esta zu̱, <<A mu̱ne̱ u̱zu̱ no̱nge̱ faru̱k u̱r-zwar yage̱ faru̱k-u̱ haan ya-o̱ u̱r-ko̱t u̱ Haman ne̱, u̱r-mo̱ro̱g du̱ re̱-du̱ no̱m u̱t-re̱ u̱m zo̱nge̱ bo̱.>>
\p 
\v 5 Se̱ faru̱k zu̱, <<Na haatu̱n Haman u̱ ana za wa'as remu̱ it nomot no̱m-u̱ Esta zu̱ye̱.>>
\p Se̱ faru̱k e̱ Haman do̱'e̱ u̱du̱ mo̱ro̱g-du̱ Esta zo̱nge̱.
\v 6 Da-u̱ e̱ o̱ye̱ swa-u̱ ke̱, faru̱k shit Esta, <<¿U̱ da-o̱ yan-o̱ bo̱ u̱t-sa? Na ya'u̱ bo̱ o̱. ¿U̱ da-o̱ yan-o̱ o̱o̱ge̱ ko̱n-u̱s ró? Ko̱ da u̱k u̱r-faru̱k-u̱ ri o̱, na ya'u̱ bo̱.>>
\p 
\v 7 Esta o̱nk wa zu̱, <<Ko̱n-u̱s ri u̱ no̱m-u̱ u̱m u̱t-sa ne̱ ya:
\v 8 A mu̱ne̱ u̱zu̱ no̱ng faru̱k u̱r-zwar tu̱msu̱ a mu̱ne̱ u̱zu̱ u̱m kwu̱mu̱g hyu̱-m pusmo̱ u̱du̱ faru̱k wa o̱nk ko̱n-u̱s ri tu̱msu̱ wa no̱mu̱ me̱ no̱m-u̱ u̱m u̱t-sa, yage̱ faru̱k-u̱ Haman u̱ haan u-sot u̱du̱ u̱r-mo̱ro̱g du̱ u̱m zo̱nge̱ no̱. Da-u o̱ u̱m do̱'e̱ o̱nku̱ shu̱t-u̱r u̱r-faru̱k.>>
\s1 Haman zo̱ngte̱ ho̱du̱ Modekai
\p 
\v 9 Haman aru̱k m-rwu̱ u̱r-so̱ da-u̱ wa yage̱ be-du̱ u̱r-mo̱ro̱g! Se̱di da-u̱ wa hyane̱ Modekai u̱ shu̱'u̱t u̱ is-yu̱ pyu̱-u̱ faru̱k, wa yu̱nge̱ wa ko̱se̱ ho̱g-du̱ u-gye̱r u̱-shu̱ wa da, se̱ Haman no̱m jab so̱k.
\v 10 M-ha iyane̱, Haman aru̱k m-mu̱ u̱ u-bu wa rest jab-u̱ wa.
\p Se̱ wa-to̱mu̱-u̱ hu̱u̱b-u̱t wa u̱ ne̱ta wa Zere̱s, u̱zu̱ e̱ haan.
\v 11 Haman no̱mu̱g hi-u̱t yat-to̱ u̱du̱ u̱n remu̱ tat-u̱ kwu̱m-u̱t wa u̱ tat-u̱ ya'ag-u̱ wa ne̱, u̱s-fu̱n u̱s-be̱e̱t su̱ faru̱k yu̱te̱ wu̱n m-ze̱g, tu̱msu̱ u̱ka na yu̱te̱ wa m-sek m-ze̱g u̱t-ne̱t u̱t-be̱e̱t u̱ tu̱-yat-to̱ faru̱k ne̱.
\v 12 Se̱ Haman sur m-zu̱, <<Me̱ wa u-gan wu̱ U-re̱n Esta bane̱ m-haan u̱ faru̱k ne̱ u̱du̱ u̱r-mo̱ro̱g du̱ wa bane̱. Tu̱msu̱ wa banu̱g me̱ u̱ faru̱k ne̱ u-sot.>>
\v 13 Se̱ Haman zu̱, <<To̱ no̱m-to̱ u̱t-be̱e̱t to̱ zaar o̱kon no̱mo̱ u̱du̱ ri da, a mu̱ne̱ u̱m o̱ hyan-du̱ ne̱t-u̱ Yahuda-ne̱ Modekai u̱ shu̱'u̱t u̱ is-yu̱ pyu̱-u̱ faru̱k.>>
\p 
\v 14 Ne̱ta wa Zere̱s u̱ hu̱u̱b-u̱t wa ne̱ u̱t-be̱e̱t, e̱ zu̱ wa, <<Yage̱ na yu̱nu̱s u-kan yu̱ tarru̱ u̱t-ne̱t yu̱ wu̱ru̱m ya te̱ye̱ daag-su̱ m-ha u̱t-shik u̱t-yu̱r u̱ o̱p [50]. U-sot u̱r-wu̱n bo̱ no̱m u̱s-rem u̱ faru̱k ne̱ u̱zu̱ na tar Modekai u-kan. Se̱ no̱ faru̱k ha u̱ mo̱ro̱g-du̱ re̱-du̱ no̱m-u̱t-re̱ u̱ te̱k-u̱ ho̱g-du̱ u̱r-zwar.>> Se̱ Haman ho̱g u̱r-zwar so̱k se̱ wa zu̱ na yu̱nu̱s u-kan yu̱ tarru̱ u̱t-ne̱t.
\c 6
\s1 Faru̱k yaag Modekai m-sek
\p 
\v 1 U̱ gyu̱p-m mo̱ faru̱k kerge̱ m-roog da. Se̱ wa wu̱' na hatu̱n ran-tu̱ cu̱n-du̱ u̱s-rem tu̱ ogor-tu̱ faru̱k-u̱r wa, u̱ na karu̱nte̱ u̱-shu̱ wa.
\v 2 Se̱ na bit m-pan u̱ku̱n u̱zu̱ Modekai upuste̱ no̱m-u̱ Bigtan ne̱ e̱ Te̱re̱s o̱o̱ge̱ u̱t-sa e̱ no̱m, tu̱-yat-to̱ Faru̱k i o̱o̱ge̱ e-du̱ is-yu̱ u-bu. I zo̱ngte̱ remu̱ e̱ ho-u̱t Faru̱k Zarake̱s.
\p 
\v 3 Faru̱k shit, <<¿Yan go̱-du̱ u̱r-o̱g de̱ ko̱ m-sek mo̱ na do̱'e̱ ya-du̱ Modekai?>>
\p No̱m-u̱ i o̱o̱ge̱ u̱r-kot u̱ wu̱n ne̱ shase̱, <<Na no̱ngu̱ wu̱n o̱ku̱n da.>>
\p 
\v 4 Faru̱k zu̱, <<¿Wana o̱o̱ge̱ ku̱n u̱-do̱ u̱-me̱ kat-du̱ u-bu?>> U̱ da-u o̱ Haman cwaag u̱-me̱ kat-du̱ u-bu u̱ o̱o̱ge̱ u̱-do̱ u̱ pyu̱-u̱ faru̱k. Wa o̱ u̱t-sa wa no̱m u̱s-rem u̱ faru̱k ne̱ u̱ka na de̱te̱ su̱rgu̱sse̱ Modekai u̱ do̱m-u̱ u-kan yu̱ wa zo̱nge̱ u̱ remu̱ wa.
\p 
\v 5 Ne̱t-tu̱ o̱o̱ge̱ wu̱n ne̱ zu̱, <<Haman o̱ ees u̱-me̱ kur-u̱ kwu̱p-du̱ u̱s-rem.>>
\p Faru̱k shu̱s wa zu̱, <<Cwatu̱n wu̱n u̱-me̱.>>
\p 
\v 6 Da-u̱ Haman cwaye̱ u̱-me̱, faru̱k shit wa, <<¿Yan-o̱ na do̱'e̱ no̱mu̱ ne̱t wu̱ faru̱k o̱o̱ge̱ u̱r-so̱ u̱zu̱ wa ya' wa m-sek?>>
\p Se̱ Haman nom u̱s-dorog u̱ hi-u̱r wa, <<¿Wana o̱o̱ge̱ u̱-ku̱n wu̱ faru̱k do̱'e̱ yadu̱ m-sek m-pas me̱?>>
\v 7 Se̱ Haman zu̱ faru̱k, <<In di u̱zu̱ waku̱n o̱ró wu̱ bo̱ do̱'e̱ yadu̱ m-sek,
\v 8 yage̱ na hatu̱n to̱ggo̱-yu̱ u̱r-faru̱k yu̱ faru̱k tame̱ u̱t-wa, u-jwaak ne̱ yu̱ faru̱k tamte̱ m-sak, yu̱ o̱tte̱ u̱t-u̱k go̱-du̱ tu̱ u̱r-faru̱k u̱ do̱m-u̱ hi-u̱r ya.
\v 9 Yage̱ na yase̱ waku̱n u̱ te̱k-u̱ i-yate̱ faru̱k wu̱ zu̱ge̱ m-sek. Yage̱ e̱ wa-u̱ wu̱ faru̱k o̱o̱ge̱ u̱t-sa wa ya' wa m-sek. Tu̱msu̱ wa sak u-jwaak na kab wa m-cwa u̱-me̱ fu̱n-su̱ me̱ u-bo̱, na war u̱-shu̱ ne̱t-u̱ wa u̱zu̱, <Gwat no̱m-u̱ na no̱me̱ ne̱t wu̱ faru̱k o̱o̱ge̱ u̱t-sa wa ya' wa m-sek!> >>
\p 
\v 10 Faru̱k zu̱ Haman, <<Do̱'e̱ bo̱ no̱m m-ho̱r m-ho̱r! Bu̱ kab to̱ggo̱-u ri u̱ jwaak-u ri ne̱, tu̱msu̱ bo̱ no̱m no̱m-u̱ bo̱ zu̱ye̱ na no̱m! Bo̱ no̱mu̱ Modekai iya, ne̱t-u̱ Yahuda, wu̱ o̱o̱ge̱ u̱ shu̱'u̱t u̱ is-yu̱ cwadu̱ pyu̱. Tass o̱ku̱n no̱mo̱ ka bo̱ u̱t-to̱ u̱ te̱k-u̱ no̱m-u̱ bo̱ zu̱ye̱ da.>>
\p 
\v 11 Se̱ Haman kabu̱n u-to̱ggo̱ u-jwaak ne̱. Wa wa'u̱ Modekai, wa ku̱b wa m-cwa u̱-me̱ fu̱n-su̱ u-bo̱, wa u̱t-war u̱-shu̱ wa, <<Gwatu̱n no̱m-u̱ na no̱me̱ wu̱ faru̱k o̱o̱ge̱ u̱t-sa wa ya' wa m-sek!>>
\p 
\v 12 Da tase̱ Modekai aru̱k m-mu̱ u̱ fu̱n-yu̱ bu-u faru̱k, se̱ Haman aru̱k m-mu̱ m-so̱m u̱ me̱n-u̱t rim-to̱ ne̱. Wa hog m-'e̱ sok.
\v 13 Se̱ Haman waru̱ Zere̱s ne̱ta wa u̱ hu̱u̱b-u̱t wa ne̱ no̱mu̱ na no̱me̱ wa u-be̱e̱t u̱ ho̱-u̱r re̱. Se̱ ne̱ta wa u̱ hu̱u̱b-u̱t wa ne̱, e̱ zu̱ wa, <<Modekai, ne̱t wu̱ wa'e̱ bo̱ ho̱g-du̱ m-'e̱, ne̱t-u̱ Yahuda wa. Bo̱ zaaru̱ ke̱ru̱ re̱-du̱ Modekai m-gag da. Wa re̱ bo̱ m-gag!>>
\p 
\v 14 Da-u̱ u̱n o̱ te̱k-u̱ no̱mu̱ wa u̱s-rem, se̱ te̱k-u̱ tu̱-yat-to̱ faru̱k haan e̱ ku̱b Haman m-ha u̱ be-du̱ re̱-du̱ no̱m u̱t-re̱ u̱ Esta zo̱nge̱.
\c 7
\s1 Na su̱rgu̱sse̱ Haman
\p 
\v 1 Se̱ faru̱k ne̱ e̱ Haman aru̱k m-ha u̱ be-du̱ re̱-du̱ no̱m u̱t-re̱ U-re̱n Esta bane̱.
\v 2 Da-u̱ u̱n o̱ te̱k-u̱ swadu̱ ke̱, faru̱k sur m-shu̱'u̱t, <<U-re̱n Esta, ¿yan-o̱ o̱o̱ge̱ ko̱n-u̱s ró? Na ya'u̱ bo̱ o̱. ¿Yan-o̱ o̱o̱ge̱ ko̱n-u̱s ró? Me̱ ya'u̱ bo̱ ko̱ da u̱k u̱r-faru̱k-u̱ ri o̱, me̱ ya'u̱ bo̱ o̱.>>
\p 
\v 3 U-re̱n Esta zu̱, <<A mu̱ne̱ u̱zu̱ u̱m kwu̱mu̱g hyu̱-m pusmo̱ u̱du̱ faru̱k, tu̱msu̱ a mu̱ne̱ u̱zu̱ no̱ng faru̱k u̱r-zwar wa ya' me̱ ko̱n-u̱s ri. U̱m u̱s-ko̱n u̱zu̱ fat-u̱r ri u̱ fat-tu̱ ne̱t-u̱t ri ne̱ kum u̱t-pos.
\v 4 Remu̱ u̱zu̱ me̱ u̱ ne̱t-u̱t ri ne̱ na bu̱pu̱ste̱ it u̱du̱ i do̱'e̱ ho̱du̱ it, u̱t-pan, u̱ na hast it. A-za mu̱ne̱ u̱zu̱ na bu̱pu̱ste̱ it sha-mu̱ to̱k-ne̱, u̱m da zu̱t o̱kon da, rem u̱zu̱ da shu̱'u̱te̱ no̱m-u yat-o̱ u̱ do̱'e̱ e̱kse̱ Faru̱k da.>>
\p 
\v 5 Faru̱k Zarake̱s shit U-re̱n Esta, <<¿Wana do̱'e̱ no̱m-du̱ go̱-du̱ o̱ no̱m-o̱? ¿Wana ne̱t-u̱ wa wu̱ do̱'e̱ u̱t-jaru̱n wa tam bo̱?>>
\p 
\v 6 Esta zu̱, <<Ne̱t wu̱ o̱o̱ge̱ hu̱u̱b-u̱ yo̱-wa it u̱ ya Haman ne̱t-u̱ yo̱-wa!>>
\p Haman hog u-gye̱r so̱k da-u̱ wa o̱o̱ge̱ ees u̱-shu̱ faru̱k e̱ U-re̱n Esta.
\v 7 Se̱ faru̱k yu̱ne̱ u̱ te̱k-u̱ namu̱ jab. Wa yage̱ ke̱ wa aru̱k m-cwa me̱ be-du̱ na se̱rte̱ u̱s-te u̱ pyu̱-u̱ faru̱k. Se̱di Haman, wa ees wa o̱ ko̱n-du̱ U-re̱n Esta wa guu fat-u̱r wa, remu̱ u̱zu̱ wa nak no̱m-u yo̱-o̱ u̱ faru̱k do̱'e̱ no̱mu̱ wa.
\p 
\v 8 Da-u̱ Faru̱k mu̱u̱ne̱ be-du̱ na se̱rte̱ u̱s-te du̱ pyu̱-u̱ Faru̱k wa o̱ m-cwa u-me̱ pyu̱, Haman he̱e̱g u̱-do̱mu̱ u̱r-wu̱ndi u̱ Esta o̱tte̱ m-ru̱t.
\p Se̱ faru̱k no̱m u̱t-jar m-yat, wa zu̱, <<¿Wa o̱ u̱ssa wa no̱mu̱ U-re̱n Esta u̱r-ryapu̱k u̱ ana u̱-me̱ u-pada, u̱ hyan-mu̱ is-u̱ ri?>>
\p Za naas u-da faru̱k no̱m u̱s-rem, ne̱t-tu̱ o̱o̱ge̱ u̱r-ko̱t u̱ wu̱n ne̱ e̱ taku̱s shu̱-u Haman.
\v 9 Se̱ Harbona, wagan u̱ te̱k-u̱ a no̱mu̱ faru̱k m-ank, wa shu̱s zu̱, <<Haman shirge̱ u-kan yu̱ no̱me̱ m-ja mu̱ daag-su̱ m-ha u̱t-shik u̱t-yu̱r u̱ o̱p [50] u̱-me̱ bu-u wa. Wa zo̱ngte̱ ya u̱ remu̱ wa tu̱ru̱t Modekai, wu̱ guu fat-du̱ faru̱k.>>
\p Faru̱k shu̱s wa zu̱, <<Su̱rgu̱ssu̱n Haman u̱ kan-u ya.>>
\v 10 Se̱ u̱n su̱rgu̱sse̱ Haman u̱-do̱mu̱ u-kan yu̱ wa zo̱nge̱ u̱ remu̱ Modekai. Se̱ namu̱ jab faru̱k ciz.
\c 8
\s1 U̱t-bo̱r u̱ remu̱ Yahuda-ne̱ se̱gte̱ hi-u̱r e̱
\p 
\v 1 U̱ gandi ho̱-u̱r re̱ Faru̱k Zarake̱s yase̱ U-re̱n Esta no̱m-u̱ u̱t-kom-u̱ Haman u-be̱e̱t, hu̱u̱b-u̱ yo̱-wa Yahuda-ne̱. Modekai haan u̱-shu̱ faru̱k, rem u̱zu̱ Esta waru̱g u̱ka wa o̱tte̱ u̱t-mo̱r u̱ wa ne̱.
\v 2 Se̱ faru̱k host kwat-yu̱ ge̱r-u̱ wa, yu̱ wa o̱nke̱ du̱gu̱-du̱ Haman, wa yase̱ Modekai. Tu̱msu̱ Esta wu̱' wa gwat-u̱ wa no̱m-tu̱ Haman o̱tte̱ u̱t-be̱e̱t.
\p 
\v 3 Esta sur m-no̱m u̱s-ko̱n u̱du̱ faru̱k, wa he u-dak u̱ na-u̱s wa. Esta no̱m u̱s-ko̱n m-is ne̱ u̱ wa hast no̱m-u̱t yo̱-to̱ tu̱ Haman wa-Agagite shire̱ m-ha u̱du̱ Yahuda-ne̱.
\v 4 Tu̱msu̱ faru̱k nu̱b ko̱m-yu̱ m-bak-u̱t wa u̱du̱ Esta: se̱ wa yu̱ne̱ wa ees u̱-shu̱ faru̱k.
\p 
\v 5 Esta zu̱, <<A mu̱ne̱ u̱zu̱ no̱mu̱g faru̱k u̱r-zwar, tu̱msu̱ a u̱m kume̱ hyu̱-m pusmo̱ u̱du̱ wa, tu̱msu̱ a wa hyane̱ u̱zu̱ no̱ng u̱r-zwar, tu̱msu̱ a wa ho̱ge̱ zwar-u̱r ri. Yage̱ wa no̱m u̱t-bo̱r tu̱ do̱'e̱ bargu̱sse̱ bo̱r-u̱t Haman wa'-u̱ Hamedata, ne̱t-u̱ ko̱-du̱ Agagite, tu̱ wa no̱me̱ u̱zu̱ na ho̱ru̱sse̱ ne̱t-tu̱ Yahuda-ne̱ u̱-me̱ dak-tu̱ u̱r-faru̱k-u̱ ró.
\v 6 ¿Re̱ne̱ o̱ u̱m de̱te̱ kere̱ du̱ u̱r-ees u̱m hyan no̱m-u yo̱-o̱ u̱ he̱e̱n u̱du̱ ne̱t-u̱t ri? ¿Re̱ne̱ o̱ u̱m do̱te̱ kere̱ du̱ hyan-du̱ mar-mu̱ ne̱t-tu̱ u-bu ri?>>
\p 
\v 7 Faru̱k Zarake̱s zu̱ U-re̱n Esta ne̱ e̱ Modekai ne̱t-u̱ Yahuda, <<Rem u̱zu̱ Haman he̱se̱te̱ Yahuda-ne̱, u̱m yaste̱ no̱m-u̱ u̱t-kom-u̱ Haman u̱du̱ Esta, tu̱msu̱ na su̱rgu̱sse̱ wu̱n u-kan.
\v 8 U̱ da-o̱ sur m-pan to̱ku̱n bo̱r-to̱ u̱ dim-du̱ faru̱k-u̱ ees-mu̱ Yahuda-ne̱ u̱ka cittu̱ bo̱. Tu̱msu̱ bo̱ rake̱ ran-u̱t to̱ u̱ kwat-yu̱ faru̱k, remu̱ u̱zu̱ no̱m-u̱ na pane̱ u-be̱e̱t u̱ dim-du̱ faru̱k tu̱msu̱ na rake̱ to̱ u̱ kwat-yu̱ faru̱k waku̱n zaar wu̱ do̱'e̱ swase̱ o̱ da.>>
\p 
\v 9 Za naas u-da se̱ na fog ya-u̱s-panu̱ faru̱k ne̱. Na no̱ng iya u̱ ho̱-du̱ u̱r-shik u̱t-tu̱t u̱ pyat-yu̱ na foge̱ Sivan (pyat-yu̱ u-tu̱t yu̱ Yahuda-ne̱).\f + \fr 8:9 \ft u̱ ogor-tu̱ uno̱ da-o̱ wata pyat-yu̱ u-shishin (25 Yuni). \f* U̱n pu̱n bo̱r-u̱t Modekai m-ha du̱ Yahuda-ne̱, tu̱msu̱ m-ha tu̱-yat-to̱ ne̱, u̱ faru̱k-u̱t yat-to̱ ne̱ tu̱msu̱ u̱ i na o̱ m-ho̱g-u̱ e̱ ne̱ u̱t-gas u̱t-kwaz u̱t-shishin u̱t-ta'er [127] du̱gu̱ Indiya m-ha Kus ne̱. Na pu̱n ran-u̱t to̱ tu̱msu̱ u̱-me̱ u̱ pan-u̱s e̱ tu̱msu̱ u̱ rem-tu̱ ne̱t-tu̱ gas-u o̱ u̱t-be̱e̱t, u̱ dame̱ u̱s-pan ne̱ u̱ rem-du̱ Yahuda-ne̱.
\v 10 Modekai nom u̱s-pan u̱ dim-du̱ Faru̱k Zarake̱s, se̱ na rake̱ ran-tu̱ na pane̱ to̱ u̱ kwat-yu̱ faru̱k. Na yase̱ a-u̱s-to̱m-u̱ Faru̱k ne̱, e̱ su̱k u̱ jwaak i ze̱ge̱ m-so̱m i o̱o̱ge̱ go̱-u̱r yat-de̱ i na dage̱ u̱ remu̱ to̱m-su̱ faru̱k.
\p 
\v 11 Faru̱k yu̱' Yahuda-ne̱ i ko̱ bo̱-u̱ he̱ne̱ u̱r-ke̱r e̱ same̱ hi-u̱t e̱, remu̱ e̱ guut fat-u̱t e̱. Na yu̱' e̱ u̱r-ke̱r e̱ ho̱, e̱ pan, tu̱msu̱ e̱ ho̱ru̱sse̱ ko̱ i he̱ karma-ne̱ i m-gag du̱gu̱ ko̱-yu̱-he̱ gas-ya i do̱'e̱ he̱e̱se̱ u̱n m-dum ko̱ ya'ag-u̱ u̱n u̱ ne̱ta-u̱t u̱n ne̱. Tu̱msu̱ e̱ o̱nk cwu̱-tu̱ hu̱u̱b-tu̱ m-gag u̱ u̱n ne̱.
\v 12 Ho̱-du̱ na este̱ u̱zu̱ ne̱t-tu̱ Yahuda-ne̱ no̱m iya u̱-me̱ gas-su̱ Faru̱k Zarake̱s o̱tte̱ u̱r-faru̱k de̱ o̱ ho̱-du̱ o̱p u̱t-tu̱t u̱ pyat-yu̱ na foge̱ Adar (pyat-yu̱ o̱p u-yu̱r yu̱ Yahuda-ne̱)\f + \fr 8:12 \ft u̱ ogor-tu̱ uno̱ da-o̱ wato pyat-yu̱ u-tu̱t (7 Maris).\f*.
\v 13 Ran-tu̱ na pane̱ na rake̱ to̱ na tomot to̱ u̱ka u̱t-bo̱r u̱s-gas u̱t-be̱e̱t. Tu̱msu̱ na karu̱nte̱ to̱ u̱-shu̱ ne̱t ne̱, u̱ remu̱ Yahuda-ne̱ e̱ zo̱ng e̱ to̱p no̱m-u̱ hu̱u̱b-u̱t yo̱-to̱ e̱ no̱mu̱ u̱n u̱ ho̱-u̱r re̱.
\p 
\v 14 Faru̱k yu̱' ne̱t-tu̱ hu̱u̱te̱ ran-u̱t to̱ u̱-me̱ u̱s-gas u̱r-ke̱r e̱ da m-ho̱r-m-ho̱r u̱ do̱m-u̱ jwaak-u̱ i m-so̱m faru̱k. Tu̱msu̱ ran-tu̱ na pane̱ to̱ na tom-u̱t to̱ u̱ na karu̱nte̱ to̱ u̱-me̱ bo̱-u yat-o̱ u̱ o̱tte̱ sar m-ja u̱r-be̱b ne̱ sok u̱ Susha.
\p 
\v 15 Se̱ Modekai yage̱ shu̱ faru̱k, m-wa u̱ cwu̱-tu̱ u̱r-faru̱k ne̱ tu̱ o̱tte̱ sha-mu̱ bu̱mu̱ u̱t-ran u̱ mu̱ pus-mo̱ ne̱, na wa'u̱ wa u̱r-to̱p du̱ yat-de̱ du̱ u̱r-faru̱k du̱ na no̱me̱ u̱ kwam-tu̱ shik tu̱ bu̱-mu̱ u̱t-rò u̱ hi-u̱r wa. Tu̱msu̱ na wa'u̱ wa to̱ggo̱ yat-ya yu̱ u̱s-ke̱e̱r yu̱ bu̱-m jaz-mo̱. Tu̱msu̱ bo̱-u̱ Susha u-be̱e̱t o̱ ku̱b jar-tu̱ u̱r-so̱.
\v 16 Yahuda-ne̱ i o̱ me̱n-tu̱ Susha e̱ nom u̱r-so̱, tu̱msu̱ e̱ yu̱' u̱n m-sek.
\v 17 U̱-me̱ ko̱yu̱he̱ gas-ya tu̱msu̱ u̱ ko̱-u̱-he̱ bo̱-o̱, be-du̱ bo̱r-tu̱ Faru̱k tote̱ u̱r-be̱e̱t, ne̱t-tu̱ Yahuda-ne̱ nom u̱r-so̱. Tu̱msu̱ e̱ bu̱n u̱r-mo̱ro̱g du̱ re̱-du̱ no̱m u̱t-re̱ u̱r-so̱ ne̱ tu̱msu̱ ho̱-du̱ u̱r-hure̱ ne̱. Tu̱msu̱ ne̱t-tu̱ u-dak u-tát e̱ baru̱m Yahuda-ne̱ u̱ hi-u̱r e̱, rem u̱zu̱ e̱ o̱ ho̱g-du̱ gye̱r-u̱ no̱m-u̱ Yahuda-ne̱ do̱'e̱ no̱mu̱ u̱n.
\c 9
\s1 Re̱-du̱ u̱r-ko̱rro Yahuda-ne̱
\p 
\v 1 U̱ ho̱-du̱ o̱p u̱t-tu̱t u̱ pyat-yu̱ na foge̱ Adar (pyat-yu̱ o̱p u-yu̱r yu̱ Yahuda-ne̱)\f + \fr 9:1 \ft u̱ ogor-tu̱ uno̱ da-o̱ wato pyat-yu̱ u-tu̱t (7 Maris).\f* bo̱r-tu̱ faru̱k wa'e̱ ho̱-du̱ teeg u̱zu̱ na no̱m no̱m-u̱ faru̱k zu̱ye̱. U̱ gandi ho̱-du̱ u̱r-gan de̱ hu̱u̱b-u̱t yo̱-to̱ Isra-ne̱ e̱ o̱ u̱t-gwat e̱ re Yahuda-ne̱ m-gag. Se̱di no̱m-tu̱ bargu̱sse̱, Isra-ne̱ e̱ muye̱ e̱ re hu̱u̱b-u̱t yo̱-to̱ e̱ tu̱ gu̱gme̱ e̱ m-gag.
\v 2 Yahuda-ne̱ kargu̱sse̱ hi-u̱t e̱ u̱-me̱ bo̱-u̱ e̱ u̱-me̱ gas-su̱ Faru̱k Zarake̱s o̱tte̱ u̱r-faru̱k u̱s-be̱e̱t u̱ remu̱ e̱ he̱se̱te̱ wu̱ o̱o̱ge̱ u̱ssa wa ho̱nse̱ e̱ u-be̱e̱t. Se̱di waku̱n kerge̱ u̱t-zu̱ wa no̱m ees-u̱r yo̱-de̱ u̱ e̱ ne̱ da, rem u̱zu̱ kowan o̱ u̱ ho̱g-du̱ u-gye̱r u̱ he̱e̱se̱ u̱n m-dum.
\v 3 Tu̱msu̱ ne̱t-u̱t yat-to̱ tu̱ u̱s-gas u̱s-be̱e̱t u̱ tu̱-yat-to̱ faru̱k ne̱ u̱ ne̱t-tu̱ na o̱o̱ge̱ ho̱g-du̱ e̱ ne̱ be̱e̱t u̱-me̱ u̱s-gas u̱s-be̱e̱t e̱ se̱ge̱ Yahuda-ne̱, remu̱ u̱zu̱ e̱ o̱ ho̱g-du̱ gye̱r-u Modekai.
\v 4 Modekai shu̱'u̱te̱ ne̱t-u̱ yat-wa u̱-me̱ pyu̱-u̱ faru̱k; na hog dim-u̱r wa u̱-me̱ u̱s-gas u̱s-be̱e̱t. Wa shu̱'u̱t ne̱t wa-u̱r-be̱b sok.
\p 
\v 5 Se̱ Yahuda-ne̱ re u-shu̱ u̱ gandi ho̱-du̱ u̱r-gan tu̱msu̱ e̱ he̱e̱se̱ ketu̱rru̱ hu̱u̱b-u̱t yo̱-to̱ e̱ u̱ van-u̱s e̱. E̱ nom no̱m-u̱ e̱ u̱t-sa u-be̱e̱t u̱ hu̱u̱b-u̱t yo̱-to̱ e̱ ne̱, e̱ ho̱ru̱sse̱ tu̱msu̱ e̱ hast hu̱u̱b-u̱t yo̱-to̱ e̱ u̱t-be̱e̱t.
\v 6 U̱-me̱ Susha bo̱-u yat-o̱ u̱ o̱tte̱ sar m-ja u̱r-be̱b ne̱ sok, Yahuda-ne̱ ho u̱t-ne̱t u̱t-ko̱k u̱t-tan [500].
\v 7 U̱ te̱k-u̱ ne̱t-tu̱ e̱ ho̱ye̱ u̱ dame̱ u̱ yaag-u̱ Haman ne̱. Dim-u̱t e̱ o̱o̱ge̱ Parasadata, Dafon, Asapata,
\v 8 Porata, Adariya, Aridata,
\v 9 Paramasata, Arisayi, Aridayi, u̱ Bayizata,
\v 10 yaag o̱p i Haman wa'-u̱ Hamedata, hu̱u̱b-u̱ yo̱-o̱ Yahuda-ne̱. Se̱di e̱ kabu̱g cwu̱-u̱t u̱n da.
\p 
\v 11 Se̱ na waru̱ faru̱k tat-u̱ ne̱t-tu̱ na ho̱ye̱ u̱-me̱ bo̱-u Susha u̱ o̱tte̱ sar u̱ m-ja u̱r-be̱b ne̱ sok u̱ gandi ho̱-u̱r re̱.
\v 12 Se̱ faru̱k zu̱ U-re̱n Esta, <<Yahuda-ne̱ ho̱o̱g u̱t-ne̱t u̱t-ko̱k u̱t-tan [500] u̱-me̱ bo̱-u̱ Susha u̱ o̱tte̱ sar u̱ m-ja u̱r-be̱b ne̱ sok u̱ war-o̱, u̱ dame̱ yaag-u̱ Haman ne̱ o̱p. U̱ da-o̱ du̱ u̱n nomte̱ iya u̱ ane̱ war-o̱, ¿re̱-o̱ de̱te̱ u̱t-shu̱'u̱t u̱ gas-su̱ kuse̱ ne̱? Se̱di da-o̱, ¿Yan-o̱ kuse̱ u̱ bo̱ u̱t-sa? Yan-o̱ ko̱n-u̱s ró tu̱msu̱ me̱ no̱mu̱ bo̱ o̱.>>
\p 
\v 13 Esta shu̱s wa zu̱, <<A mu̱ne̱ zu̱ no̱mu̱g faru̱k u̱r-zwar, ya' Yahuda-ne̱ i o̱o̱ge̱ u̱-me̱ Susha u̱r-ke̱r u-sot tu̱msu̱ e̱ no̱m no̱m-u̱ bo̱ zu̱ na no̱m. Bo̱ ya' u̱r-ke̱r u̱zu̱ birig-tu̱ ya'ag-u̱ Haman o̱p na su̱rgu̱sse̱ to̱ u-kan.>>
\p 
\v 14 Se̱ faru̱k ees, na wu̱' u̱r-do̱nse̱ u̱-me̱ Susha. Se̱ u̱n su̱rgu̱sse̱ biru̱k-tu̱ ya'ag-u̱ Haman o̱p.
\v 15 Se̱ Yahuda-ne̱ i me̱ Susha e̱ karu̱g u̱r-be u̱r-gan u̱ ho̱-du̱ o̱p u̱t-nas u̱ pyat-yu̱ na foge̱ Adar (pyat-yu̱ o̱p u-yu̱r yu̱ Yahuda-ne̱)\f + \fr 9:15 \ft u̱ ogor-tu̱ da-o̱ na zu̱ pyat-yu̱ u-tu̱t (8 Maris).\f* tu̱msu̱ e̱ sur m-ho̱ ne̱t-ne̱ u̱t-ko̱k u̱t-tu̱t [300], tu̱msu̱ e̱ kabu̱g kwu̱m-u̱t u̱n da.
\p 
\v 16 Da tase̱ tu̱msu̱, Yahuda-ne̱ i kuse̱ u̱ gas-u̱ faru̱k o̱tte̱ tu̱msu̱ e̱ karu̱g u̱ remu̱ e̱ guut hi-u̱r e̱ u̱ remu̱ e̱ kum-u̱t u̱r-hure̱ du̱gu̱-du̱ hu̱u̱b-u̱t yo̱-to̱ e̱. U̱n ho ne̱t-ne̱ u̱t-zo̱ngu u̱t-shik u̱t-tu̱t u̱ o̱p u̱t-tan [75,000], se̱di u̱n tamu̱g no̱m-tu̱ u̱t-kom-u̱ u̱n da.
\v 17 Na no̱mu̱g iya u̱ gas-u̱ o̱ u-be̱e̱t tu̱msu̱ u̱ ho̱-du̱ o̱p u̱t-tu̱t u̱ pyat-yu̱ na foge̱ Adar (pyat-yu̱ o̱p u-yu̱r yu̱ Yahuda-ne̱)\f + \fr 9:17 \ft u̱ ogor-tu̱ uno̱ da-o̱ na zu̱ pyat-yu̱ u-tu̱t (7 Maris).\f* tu̱msu̱ ho̱-du̱ o̱p u̱t-nas se̱ u̱n hure̱ u̱n muude̱ ho̱-du̱ re̱-du̱ no̱m u̱t-re̱ u̱ ho̱-du̱ u̱r-so̱ ne̱.
\s1 Mo̱ro̱g-du̱ Purim
\p 
\v 18 Yahuda-ne̱ i o̱o̱ge̱ u̱-me̱ Susha, iya tu̱msu̱, e̱ karu̱g u̱ ho̱-du̱ o̱p u̱t-tu̱t u̱ ho̱-du̱ u̱t-o̱p u̱t-nas ne̱, tu̱msu̱ iya u̱ ho̱-du̱ o̱p u̱t-tan u̱n hure̱ se̱ u̱n muut ho̱-u̱r re̱ ho̱-du̱ u̱r-so̱ u̱ re̱-du̱ no̱m-u̱t-re̱ ne̱.
\p 
\v 19 O̱ wa'e̱ Yahuda-ne̱ i o̱o̱ge̱ shu̱'u̱t u̱-me̱ bo̱-tu̱ u̱r-do̱g e̱ ship-u̱t ho̱-du̱ o̱p u̱t-nas u̱ pyat-yu̱ na foge̱ Adar (pyat-yu̱ o̱p u-yu̱r yu̱ Yahuda-ne̱)\f + \fr 9:19 \ft u̱ ogor-tu̱ uno̱ da-o̱ wato pyat-yu̱ u-tu̱t (8 Maris).\f* de̱ shu̱'u̱t ho̱-du̱ u̱r-so̱ u̱ ho̱-du̱ re̱-du̱ no̱m u̱t-re̱ ne̱, tu̱msu̱ de̱ shu̱'u̱t ho̱-du̱ u-nya u̱du̱ o̱ru̱-u̱t u̱n ne̱.
\p 
\v 20 Modekai pu̱n no̱m-u̱t to̱ wa tomot u̱t-ran u̱du̱ Yahuda-ne̱ i o̱o̱ge̱ m-ra u̱t-mo̱r ne̱, u̱-me̱ gas-u̱ Faru̱k Zarake̱s o̱tte̱ u̱r-faru̱k u-be̱e̱t.
\v 21 Wa waru̱ u̱n u̱zu̱ e̱ nom u̱r-so̱ u̱ ho̱-du̱ o̱p u̱t-nas u̱ ho̱-du̱ o̱p u̱t-tan ne̱ u̱ pyat-yu̱ na foge̱ Adar (pyat-yu̱ o̱p u̱t-yu̱r yu̱ Yahuda-ne̱)\f + \fr 9:21 \ft u̱ ogor-tu̱ uno̱ da-o̱ wato pyat-yu̱ u-tu̱t. (7 Maris).\f* ko̱yu̱he̱ hak-ya.
\v 22 Wa waru̱ Yahuda-ne̱ u̱zu̱ e̱ no̱m so̱-du̱ ho̱-u̱t to̱ u̱ re̱-du̱ no̱m u̱t-re̱ ne̱ u̱r-so̱ ne̱ tu̱msu̱ u̱ no̱mu̱ o̱r-u̱t e̱ ne̱ u-nya u̱ no̱m u̱t-re̱ ne̱ tu̱msu̱ e̱ no̱mu̱ i o̱ u̱-me̱ u̱r-ko̱b u-nya. Din-de̱ de̱ o̱o̱ge̱ mo̱ro̱g-du̱ u̱r-so̱ da-u̱ Yahuda-ne̱ kume̱ u̱r-hure̱ du̱gu̱-du̱ hu̱u̱b-u̱t yo̱-to̱ e̱.
\p 
\v 23 Se̱ Yahuda-ne̱ ees u̱zu̱ e̱ do̱'e̱ re̱-du̱ u-shu̱ u̱t-no̱m iya ko̱yu̱he̱ hak-ya u̱ka e̱ taktu̱n, u̱ no̱m-du̱ no̱m-u̱ Modekai panu̱ e̱ ne̱.
\v 24 Haman wa'-u̱ Hamedata ne̱t-u̱ Agagite, hu̱u̱b-u̱ yo̱-o̱ Yahuda-ne̱, wa no̱ng dorog-su̱ no̱mu yo̱-o̱ u̱du̱ Yahuda-ne̱ u̱zu̱ na ho̱ru̱sse̱ e̱. Tu̱msu̱ na hast e̱ u̱ ho̱-du̱ e̱ cine̱ u̱zu̱ na ho̱ru̱sse̱ Yahuda-ne̱ u̱ fu̱n-yu̱ gwu̱n-du̱ u-gwe̱mbi (yu̱ na foge̱ Purim).
\v 25 Se̱di da-u̱ Esta haane̱ u̱ shu̱ faru̱k, se̱ faru̱k pu̱n u̱t-ran u̱zu̱ no̱mu yo̱-o̱ Haman dorge̱ no̱mu̱ Yahuda-ne̱ u̱ o̱ mu u̱-do̱mu̱ hi-u̱r wa. Se̱ Haman u̱ ya'ag-u̱ wa ne̱ na su̱rgu̱sse̱ e̱ u̱-do̱m u-kan.
\v 26 Rem iya o̱ wu̱te̱ na fog-u̱t ho̱-tu̱ u̱r-so̱ to̱ Purim. Yahuda-ne̱ fak ho̱-u̱t to̱ Furim, rem u̱zu̱ Fur de̱ o̱ gom-du̱ gwu̱n-du̱ u-gwe̱mbi. U̱ remu̱ no̱m-u̱ u̱n hyane̱ ne̱ tu̱msu̱ u̱ no̱m-u̱ kume̱ u̱n ne̱.
\v 27 Se̱ Yahuda-ne̱ i o̱o̱ge̱ u̱-me dak-u o̱ be̱e̱t u̱n ees u̱zu̱ u̱n kab ho̱-u̱t to̱ to̱ shu̱'u̱t u-kim u̱du̱ u̱n m-ha ya'ag-u̱ u̱n ne̱ u̱ dame̱ i barme̱ Yahuda-ne̱. U̱n ku̱b u̱zu̱ u̱n zaaru̱ yagu̱ no̱m-du̱ so̱-du̱ ho̱-tu̱ u̱t-yu̱r u̱ to̱ ko̱yu̱he̱ hak-ya da, u̱ka na iiste̱ e̱ ne̱.
\v 28 Tunto̱ ho̱-to̱ na do̱'e̱ baksu̱ to̱ tu̱msu̱ na shipto̱ du̱gu̱ uno̱ cara-o̱ m-ha o̱ku̱n cara-o̱ tu̱msu̱ ko̱-u̱-he̱ bo̱-o̱, tu̱msu̱ u̱ ko̱yu̱he̱ gas-ya m-ha bo̱-u̱t yat-to̱ ne̱. Tunto̱ ho̱-tu̱ Purim to̱ na zaar u̱ yagu̱ no̱m-du̱ so̱-du̱ ho̱-u̱t to̱ u̱du̱ Yahuda-ne̱ da, ko̱ u̱zu̱ u̱ ho̱-u̱t to̱ ka u̱t-to̱ u̱-me̱ ko̱-u̱t u̱n.
\p 
\v 29 U-re̱n Esta, gwu̱p-u̱ Abiher, u̱ dame̱ Modekai ne̱ ne̱t-u̱ Yahuda, e̱ pu̱n u-ran u̱ o̱tte̱ u̱r-be̱b so̱k u̱ remu̱ na egu̱sse̱ ran u-yu̱ru̱mse̱ u̱ mo̱ttu̱ mo̱ro̱g-du̱ Purim ne̱.
\v 30 Se̱ Modekai tomot u̱t-ran m-ha u̱du̱ Yahuda-ne̱ u̱-me̱ gas-su̱ Faru̱k Zarake̱s o̱tte̱ u̱r-faru̱k u-ko̱k u-gan u̱ kwaz-tu̱ u̱t-yu̱r u̱s-ta'e̱r [127] u̱-me̱ ran-u̱t to̱ na waru̱ Yahuda-ne̱ gom-tu̱ ru̱s-du̱ jab-u̱ shu̱'u̱t-du̱ m-yar ne̱.
\v 31 Remu̱ na egu̱sse̱ ho̱-tu̱ Purim u̱ da-u̱ kame̱, u̱ka Modekai ne̱t-u̱ Yahuda u̱ U-re̱n Esta yaste̱ u̱n u̱t-bo̱r, u̱ka tu̱msu̱ u̱n egu̱sse̱ hi-du̱ war-e̱ u̱ ko̱-u̱t u̱n ne̱ u̱zu̱ u̱n ship ho̱-tu̱ u-swaat u̱ ho̱-tu̱ namu̱ jab ne̱.
\v 32 Se̱ bo̱r-tu̱ Esta pane̱ u̱ mo̱ttu̱ so̱-du̱ Purim ne̱, tu̱msu̱ na cin to̱ u̱-me̱ ran-u̱ u̱r-cu̱n.
\c 10
\s1 Be̱b-u̱r Mo̱rdekai
\p 
\v 1 Faru̱k Zarake̱s wu̱' na to̱p shik-u̱ tar u̱-me̱ gas-su̱ wa o̱tte̱ u-be̱e̱t, tu̱msu̱ m-ha i o̱ shu̱'u̱t u̱ dak-tu̱ o̱o̱ge̱ u̱-te̱k m-sa e̱ top shik-u̱ tar ko̱'e̱.
\v 2 A-u̱s-ge̱n Faru̱k panu̱g no̱m-u̱t yat-to̱ tu̱ Faru̱k no̱me̱ u̱ da-u̱ wa o̱o̱ge̱ u̱r-faru̱k. Tu̱msu̱ e̱ pu̱n tat-u̱ re̱ u-shu̱ Modekai u̱ka wa shu̱'u̱te̱ remu̱ zu̱ Faru̱k yaag wa m-sek. A-u̱s-ge̱n ne̱ pu̱n no̱m-u̱t to̱ u̱t-be̱e̱t u̱-me̱ u̱t-ran u̱ mo̱ttu̱ no̱mu̱ Faru̱k-tu̱ Midiya u̱ Pasiya ne̱ no̱me̱.
\v 3 Modekai ne̱t-u̱ Yahuda, wa o̱o̱ge̱ wu̱ do̱rne̱ Faru̱k Zarake̱s u̱r-be̱b. U̱-me̱ ne̱t-tu̱ Yahuda-ne̱ u̱n yu̱' wa m-ze̱g. Modekai shu̱'u̱t ne̱t-u̱ yat-wa u̱-me̱ Yahuda-ne̱, rem u̱zu̱ wu̱n no̱ng m-ank u̱ remu̱ ho̱g-du̱ u̱r-zwar du̱ ne̱t-u̱t wu̱n tu̱msu̱ wu̱n nom u̱s-rem u̱ remu̱ shu̱'u̱t-du̱ m-yar u̱ Yahuda-ne̱ be̱e̱t.
