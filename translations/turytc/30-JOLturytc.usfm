\id JOL - Yorumsuz Türkçe Çeviri (YTC) 
\h YOEL 
\toc1 YOEL 
\toc2 YOEL 
\toc3 YOEL 
\mt1 YOEL  
\c 1  
\p
\v 1 Petuel oğlu Yoel'e gelen Yahve'nin\f + \fr 1:1 \ft “Yahve” Tanrı’nın asıl ismidir, diğer çevirilerde bazen “RAB=EFENDİ” (tamamı büyük harflerle) olarak çevrilir.\f* sözü.   
\q1
\v 2 Ey ihtiyarlar,  
\q2 duyun bunu, memleketin bütün sakinleri dinleyin!  
\q1 Sizin günlerinizde ya da atalarınızın günlerinde  
\q2 hiç böylesi oldu mu?   
\q1
\v 3 Çocuklarınıza bunu anlatın,  
\q2 çocuklarınız kendi çocuklarına,  
\q2 onların çocukları da başka kuşaklara anlatsınlar.   
\q1
\v 4 Çekirgenin bıraktığını büyük çekirge yedi.  
\q2 Büyük çekirgenin bıraktığını küçük çekirge yedi.  
\q2 Onun bıraktığını tırtıl yedi.   
\p
\v 5 Ey sarhoşlar, ayılın da ağlayın!  
\q2 Ey şarap içenler, hepiniz, tatlı şarap yüzünden yas tutun,  
\q2 çünkü ağzınızdan kesildi.   
\q1
\v 6 Çünkü ülkemin üzerine güçlü ve sayılamaz bir ulus çıktı.  
\q2 Onun dişleri aslan dişleri,  
\q2 onda dişi aslan azı dişleri var.   
\q1
\v 7 Asmamı harap etti,  
\q2 incir ağacımı soydu.  
\q2 Kabuğunu soyup attı.  
\q2 Dalları ağardı.   
\q1
\v 8 Gençliğinin kocası için çul giymiş  
\q2 el değmemiş bir kız gibi yas tut!   
\q1
\v 9 Yahve'nin evinden ekmek sunusu ve dökmelik sunu kesildi.  
\q2 Yahve'nin hizmetkârları olan kâhinler yas tutuyor.   
\q1
\v 10 Tarla harap oldu.  
\q2 Toprak yas tutuyor, çünkü buğday yok oldu,  
\q2 yeni şarap kurudu, yağ cılızlaştı.   
\q1
\v 11 Ey çiftçiler, utanın!  
\q2 Ey bağcılar, buğday ve arpa için ağıt yakın;  
\q2 çünkü tarlanın ürünü yok oldu.   
\q1
\v 12 Asma kurudu, incir ağacı kurudu;  
\q2 nar ağacı, palmiye ağacı da, elma ağacı,  
\q2 tarlanın bütün ağaçları kurudu;  
\q2 çünkü sevinç insanoğullarından kayboldu.   
\q1
\v 13 Ey kâhinler, çul giyin ve yas tutun!  
\q2 Ey sunak hizmetkârları, ağıt yakın.  
\q1 Ey Tanrım'ın\f + \fr 1:13 \ft “Tanrı” olarak tercüme edilen İbranice kelime “אֱלֹהִ֑ים” (Elohim)’dir.\f* hizmetkârları gelin, bütün gece çulda yatın,  
\q2 çünkü Tanrınız'ın evinden ekmek sunusu ve dökmelik sunu kesildi.   
\q1
\v 14 Orucu kutsal sayın.  
\q2 Toplantıya çağırın.  
\q2 Yaşlıları ve ülkenin bütün sakinlerini Tanrınız Yahve'nin evine toplayın da  
\q2 Yahve'ye feryat edin.   
\q1
\v 15 Vay o güne!  
\q2 Çünkü Yahve'nin günü yakındır,  
\q2 Her Şeye Gücü Yeten'den bir yıkım gelecek.   
\q1
\v 16 Gözlerimizin önünden yiyecek,  
\q2 Tanrımız'ın evinden sevinç ve neşe kesilmedi mi?   
\q1
\v 17 Tohumlar toprak kesikleri altında çürüyor.  
\q2 Tahıl ambarları boş kalıyor.  
\q2 Ambarlar yıkılıyor, çünkü buğday kalmadı.   
\q1
\v 18 Hayvanlar nasıl inliyor!  
\q2 Sığır sürüleri şaşkın, çünkü otlakları yok.  
\q2 Koyun sürüleri de perişan oldu.   
\q1
\v 19 Ey Yahve, sana feryat ediyorum,  
\q2 çünkü ateş çölün otlaklarını yiyip bitirdi,  
\q2 alev de bütün kır ağaçlarını yaktı.   
\q1
\v 20 Evet, kırın hayvanları soluyarak sana sesleniyor,  
\q2 çünkü derelerin suyu kurudu,  
\q2 ateş de çölün otlaklarını yiyip bitirdi.   
\c 2  
\q1
\v 1 Siyon'da boru çalın,  
\q2 kutsal dağımda uyarı sesi verin!  
\q1 Ülkenin bütün sakinleri titresin,  
\q2 çünkü Yahve'nin günü geliyor,  
\q2 çünkü yakındır:   
\q1
\v 2 Karanlık ve kasvet günü, bulut ve koyu karanlık günü.  
\q1 Dağlara yayılan şafak gibi, büyük ve güçlü bir halk;  
\q2 benzeri hiç olmadı,  
\q2 onlardan sonra da çok kuşakların yıllarında bir daha olmayacak.   
\q1
\v 3 Önlerinde ateş yiyip bitiriyor,  
\q2 arkalarında alev yakıyor.  
\q1 Ülke önlerinde Aden bahçesi gibi,  
\q2 arkalarında ıssız bir çöl.  
\q1 Evet, onlardan kaçıp kurtulan kimse de yok.   
\q1
\v 4 Görünüşleri atların görünümü gibi,  
\q2 atlılar gibi de koşuyorlar.   
\q1
\v 5 Dağların tepelerinde savaş arabalarının gürültüsü gibi,  
\q2 anızı yiyip bitiren ateş alevinin gürültüsü gibi,  
\q2 savaş düzenine girmiş güçlü bir halk gibi sıçrıyorlar.   
\q1
\v 6 Onların karşısında halklar sıkıntı içindeler.  
\q2 Bütün yüzler soluyor.   
\q1
\v 7 Yiğitler gibi koşuyorlar.  
\q2 Savaşçılar gibi sura tırmanıyorlar.  
\q2 Her biri kendi safında yürüyor ve sırasından sapmıyor.   
\q1
\v 8 Birbirini itmiyorlar.  
\q2 Her biri kendi yolunda yürüyor.  
\q2 Savunmaları deliyorlar,  
\q2 ama saflarını bozmuyorlar.   
\q1
\v 9 Kente hücum ediyorlar.  
\q2 Sur üzerinde koşuyorlar.  
\q2 Evlerin içine tırmanıyorlar.  
\q2 Hırsızlar gibi pencerelerden giriyorlar.   
\q1
\v 10 Yer önlerinde sarsılıyor.  
\q2 Gökler titriyor.  
\q2 Güneş ve ay kararıyor,  
\q2 yıldızlar da ışıltılarını geri çekiyor.   
\q1
\v 11 Yahve ordusunun önünde sesiyle gürlüyor,  
\q2 çünkü O'nun güçleri çok büyüktür;  
\q2 çünkü O'nun buyruğuna uyan O, güçlüdür;  
\q2 çünkü Yahve'nin günü büyük ve çok korkunçtur,  
\q2 ve buna kim dayanabilir?   
\q1
\v 12 “Şimdi bile” diyor Yahve,  
\q2 “Bütün yüreğinizle, oruçla, ağlayışla ve yasla bana dönün.”   
\q1
\v 13 Giysilerinizi değil, yüreğinizi yırtın  
\q2 ve Tanrınız Yahve'ye dönün;  
\q2 çünkü O lütufkârdır, merhametlidir,  
\q2 Öfkelenmekte yavaştır, sevgi dolu iyiliği boldur  
\q2 ve felaket göndermekten vazgeçer.   
\q1
\v 14 Kim bilir? Belki döner de vazgeçer ve arkasında bereket,  
\q2 Tanrınız Yahve için bir ekmek sunusu ve dökmelik sunu bırakır.   
\q1
\v 15 Siyon'da boru çalın!  
\q2 Orucu kutsal kılın.  
\q2 Toplantıya çağırın.   
\q1
\v 16 Halkı toplayın.  
\q2 Toplantıyı kutsayın.  
\q2 İhtiyarları toplayın.  
\q2 Çocukları ve emzikte olanları toplayın.  
\q2 Güvey odasından, gelin de gerdeğinden çıksın.   
\q1
\v 17 Yahve'nin hizmetkârları olan kâhinler, eyvanla sunak arasında ağlayıp desinler,  
\q2 “Ey Yahve, halkını esirge, kendi mirasını aşağılanmaya verme ki,  
\q2 uluslar onlara hakim olmasın.  
\q1 Halklar arasında neden ‘Onların Tanrıları nerede?’ denilsin?”   
\q1
\v 18 O zaman Yahve ülkesi için kıskanç oldu  
\q2 ve halkına acıdı.   
\q1
\v 19 Yahve halkına yanıt verdi:  
\q2 “İşte,\f + \fr 2:19 \ft “İşte”, “הִנֵּה” kelimesinden gelir ve bakmak, farkına varmak, gözlemlemek, görmek veya dik dik bakmak anlamına gelir. Genellikle bir ünlem olarak kullanılır.\f* sana buğday, yeni şarap ve yağ göndereceğim,  
\q2 onlarla doyacaksınız;  
\q2 artık sizi uluslar arasında aşağılatmayacağım.   
\q1
\v 20 Ama kuzey ordusunu senden uzaklaştıracağım,  
\q2 onu çorak ve ıssız bir ülkeye,  
\q2 onun önünü doğu denizine,  
\q2 onun arkasını batı denizine süreceğim;  
\q2 ve pis kokusu yükselecek,  
\q2 ve kötü kokusu yükselecek.”  
\q1 Gerçekten o, büyük işler yaptı.   
\q1
\v 21 Ey diyar, korkma.  
\q2 Sevin ve coş, çünkü Yahve büyük işler yaptı.   
\q1
\v 22 Ey kır hayvanları, korkmayın;  
\q2 çünkü çölün otlakları yeşeriyor,  
\q2 ağaç meyvesini veriyor.  
\q2 İncir ağacı ve asma gücünü veriyor.   
\q1
\v 23 Öyleyse sevinin, ey Siyon'un çocukları,  
\q2 ve Tanrınız Yahve'yle coşun;  
\q2 çünkü size ilk yağmuru tam ölçüsünde veriyor,  
\q2 ve öncesinde olduğu gibi yağmuru,  
\q2 ilk yağmuru ve son yağmuru sizin için yağdırıyor.   
\q1
\v 24 Harman yerleri buğdayla dolacak,  
\q2 tekneler de yeni şarap ve yağla taşacak.   
\q1
\v 25 Size sürüyle uçan çekirgenin,  
\q2 büyük çekirgenin, küçük çekirgenin ve tırtılın, aranıza gönderdiğim  
\q2 büyük ordumun yediği yılları geri vereceğim.   
\q1
\v 26 Bolca yiyip doyacaksınız,  
\q2 sizin için şaşılası şeyler yapan Tanrınız Yahve'nin adını öveceksiniz.  
\q2 Halkım bir daha asla hayal kırıklığına uğramayacak.   
\q1
\v 27 Ben'im İsrael'in arasında olduğumu,  
\q2 Tanrınız Yahve olduğumu,  
\q2 ve başka kimsenin olmadığını bileceksiniz.  
\q2 Halkım bir daha asla hayal kırıklığına uğramayacak.   
\q1
\v 28 Ondan sonra, Ruhum'u bütün insanların üzerine dökeceğim.  
\q2 Oğullarınız ve kızlarınız peygamberlik edecek.  
\q2 Yaşlılarınız düşler görecek.  
\q2 Gençleriniz görümler görecek.   
\q1
\v 29 Ve o günlerde erkek ve kadın hizmetçilerin üzerine de  
\q2 Ruhum'u dökeceğim.   
\q1
\v 30 Göklerde ve yerde belirtiler göstereceğim:  
\q2 Kan, ateş ve duman direkleri.   
\q1
\v 31 Yahve'nin büyük ve korkunç günü gelmeden önce  
\q2 güneş karanlığa, ay kana dönecek.   
\q1
\v 32 Öyle olacak ki, her kim Yahve'nin adını çağırırsa kurtulacak;  
\q2 çünkü Yahve'nin söylediği gibi,  
\q2 Siyon Dağı'nda ve Yeruşalem'de kaçıp kurtulanlar,  
\q2 geride kalanlar arasında Yahve'nin çağırdığı kimseler olacak.   
\c 3  
\q1
\v 1 “Çünkü işte, o günlerde ve o zamanda,  
\q2 Yahuda ve Yeruşalem'in sürgünlerini geri getirdiğimde,   
\q1
\v 2 bütün ulusları toplayacağım,  
\q2 ve onları Yehoşafat Vadisi'ne indireceğim;  
\q2 ve orada halkım ve mirasım olan İsrael için, onu uluslar arasında dağıttıkları için onları yargılayacağım.  
\q2 Onlar ülkemi böldüler,   
\q1
\v 3 ve halkım için kura çektiler,  
\q2 ve fahişeye ücreti için erkek çocuğu verdiler,  
\q2 ve içebilsinler diye şarap karşılığında bir kız sattılar.”   
\q1
\v 4 “Hem de siz benim için nesiniz,  
\q2 ey Sur ve Sayda ve bütün Filist bölgeleri?  
\q1 Siz bana karşılık mı ödeyeceksiniz?  
\q2 Ve eğer bana karşılığını ödeyecek olursanız,  
\q2 ben karşılığını hemen ve çabucak kendi başınıza döndüreceğim.   
\q1
\v 5 Çünkü gümüşümü ve altınımı aldın,  
\q2 en değerli hazinelerimi tapınaklarına götürdün,   
\q1
\v 6 Yahuda'nın çocuklarını ve Yeruşalem'in çocuklarını  
\q2 kendi sınırlarından uzaklaştırmak için  
\q2 Grekler'in oğullarına sattınız.   
\q1
\v 7 İşte, onları sattığın yerden harekete geçireceğim,  
\q2 karşılığını kendi başınıza ödeyeceğim;   
\q1
\v 8 oğullarını ve kızlarını Yahuda'nın çocuklarının eline satacağım,  
\q2 onlar da onları uzak bir ulusa, Şevalılar'a satacaklar,  
\q2 çünkü Yahve böyle söyledi.”   
\q1
\v 9 Uluslar arasında şunu ilan edin:  
\q2 “Savaşa hazırlanın!  
\q2 Yiğitleri harekete geçirin.  
\q1 Bütün savaşçılar yaklaşsın.  
\q2 Yukarı çıksınlar.   
\q1
\v 10 Sabanlarınızı kılıçlara, bağcı bıçaklarınızı mızraklara döndürün.  
\q2 Zayıf olan, 'Ben güçlüyüm' desin.   
\q1
\v 11 Çabuk gelin, ey çevredeki uluslar, toplanın.”  
\q1 Ey Yahve, yiğitlerini oraya indir.   
\q1
\v 12 “Uluslar harekete geçip Yehoşafat Vadisi'ne çıksınlar;  
\q2 çünkü orada oturup çevredeki bütün ulusları yargılayacağım.   
\q1
\v 13 Orağı sallayın,  
\q2 çünkü hasat olgunlaştı.  
\q2 Gelin, çiğneyin, çünkü şarap teknesi doldu, tekneler taşıyor,  
\q2 çünkü kötülükleri büyüktür.”   
\q1
\v 14 Kalabalıklar, Karar Vadisi'nde kalabalıklar!  
\q2 Çünkü Karar Vadisi'nde Yahve'nin günü yakındır.   
\q1
\v 15 Güneş ve ay karardı,  
\q2 yıldızlar da ışıltılarını geri çekti.   
\q1
\v 16 Yahve Siyon'dan kükreyecek, Yeruşalem'den gürleyecek;  
\q2 gökler de yeryüzü de sarsılacak;  
\q2 ama Yahve, halkına sığınak, İsrael'in çocuklarına kale olacak.   
\q1
\v 17 “Böylece, kutsal dağım Siyon'da oturan  
\q2 Tanrınız Yahve'nin Ben olduğumu bileceksiniz.  
\q1 O zaman Yeruşalem kutsal olacak,  
\q2 ve bir daha ondan yabancı geçmeyecek.   
\q1
\v 18 O gün dağlar tatlı şarap damlatacak,  
\q2 tepeler süt akıtacak,  
\q2 Yahuda'nın bütün derelerinde sular akacak;  
\q2 Yahve'nin evinden bir kaynak çıkacak,  
\q2 ve Şittim Vadisi'ni sulayacak.   
\q1
\v 19 Mısır ıssız kalacak,  
\q2 Edom da Yahuda'nın çocuklarına yaptıkları zorbalık yüzünden  
\q2 ıssız bir çöl olacak, çünkü ülkelerinde suçsuz kanı döktüler.   
\q1
\v 20 Ama Yahuda daima,  
\q2 Yeruşalem de kuşaktan kuşağa oturulacak yer olacak.   
\q1
\v 21 Onların temizlemediğim kanlarını temizleyeceğim,  
\q2 çünkü Yahve Siyon'da oturuyor.”   