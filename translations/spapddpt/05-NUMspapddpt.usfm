\v 13 \wj \+w con|strong="H5921"\+w* \+w él|strong="H5921"\+w* \+w y|strong="H5921"\+w* su \+w descendencia|strong="H2233"\+w*, \+w el|strong="H5921"\+w* \+w Pacto|strong="H1285"\+w* \+w del|strong="H5921"\+w* \+w sacerdocio|strong="H3550"\+w* \+w perpetuo|strong="H5769"\+w*, \+w porque|strong="H5921"\+w* \+w él|strong="H5921"\+w* \+w fue|strong="H1961"\+w* celoso \+w por|strong="H5921"\+w* su \+nd ʼElohim\+nd* \+w e|strong="H3068"\+w* hizo sacrificio \+w que|strong="H5921"\+w* apacigua \+w por|strong="H5921"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w*.\wj*   
\p
\v 14 \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* del \w israelita|strong="H3478"\w* \w que|strong="H1121"\w* fue asesinado con la \w madianita|strong="H4084"\w* \w era|strong="H1121"\w* \w Zimri|strong="H2174"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Salu|strong="H5543"\w*, \w jefe|strong="H5387"\w* \w de|strong="H1121"\w* una \w familia|strong="H1004"\w* \w de|strong="H1121"\w* la tribu \w de|strong="H1121"\w* \w Simeón|strong="H8099"\w*.  
