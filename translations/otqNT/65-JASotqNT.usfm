\id JAS  
\h AR SANTIAGO 
\toc1 AR SANTIAGO Ar he̱ꞌmi bi ꞌyotꞌa ar Santiago 
\toc2 AR SANTIAGO 
\toc3 Stg. 
\mt1 AR SANTIAGO 
\mt2 Ar he̱ꞌmi bi ꞌyotꞌa ar Santiago 
\c 1  
\s1 Ar nze̱ngwa 
\p  
\v 1 Dar Santiago, ár ꞌbe̱gogi Jö ne ar tsi Hmu Hesukristo, di ze̱ngwaꞌihu̱ gatho nuꞌahu̱ yá ꞌbe̱toꞌihu̱ nuꞌu̱ ꞌre̱tꞌamayoho yá tꞌu̱ ar Israel ha gatho ya ha̱i xka mfonthu̱. 
\s1 Ar hoga mfödi unga Jö 
\p  
\v 2 Ma tsi kuhu̱, njohyahu̱ núꞌmu̱ gi thohu̱ tsa̱ntꞌö ya thogi. 
\p  
\v 3 Gi pöhu̱ nuꞌmu̱ ntsꞌa̱tꞌahu̱ ri ñꞌemu̱ihu̱, ma da hñuxa ri tsꞌe̱tihu̱. 
\p  
\v 4 Umba ri mu̱ihu̱ da nheki ri tsꞌe̱tihu̱ ha nöꞌö gi pe̱hu̱, ne gi ñöxu̱ xiñho, hinte gi kꞌathu̱. 
\p  
\v 5 Nuꞌmu̱ nꞌaꞌahu̱ gi kꞌathu̱ ar mfödi, ꞌya̱fu̱ Jö ne da ꞌraꞌahu̱, ngetho nöꞌö xa unga nze̱ye̱ ne hingi ñösꞌahu̱. 
\p  
\v 6 Ñꞌemu̱ihu̱ gi ꞌya̱fu̱, hingi yomihu̱. Ngetho nöꞌö togo yomi, ñhe̱hwi nuyá mpu̱ntsꞌi ar döñho̱nthe xa tuxta ar ndöhi, mawa di manu̱. 
\p  
\v 7 Nuꞌu̱ togo njapꞌu̱, yo di benga ja tema da umba ar tsi Hmu. 
\p  
\v 8 Nöꞌö togo yótꞌa ár mfeni, hingi ꞌyo nꞌadar ꞌñu. 
\p  
\v 9 Nunar tsi ku hyoya, dá njohya xi numansu Jö. 
\p  
\v 10 Ha nöꞌö togo pe̱ꞌsa yá mꞌe̱tsꞌi, dá njohya xi hyo̱ma ha̱i Jö, ngetho nöꞌö ngu ár ndo̱ni nꞌar do̱ni, ma da thotho. 
\p  
\v 11 Ngetho nu xta bo̱xa ar hyadi ne da patꞌi, ar do̱ni da ꞌyotꞌi, da da̱ ár ndo̱ni ne da mꞌe̱ta ár nza̱tho. Njapꞌu̱tho nöꞌö togo the̱ ya ñho, da mꞌe̱ta madeda yá mꞌe̱tsꞌi. 
\s1 Ga tse̱thu̱ ya tsꞌa̱ti 
\p  
\v 12 Nza̱tho nunar ñꞌo̱ho̱ da tho xiñho núꞌmu̱ tsꞌa̱ti. Ngetho nu xta tho nunar tsꞌa̱tinu̱, ma da hñönga ar te ngu ar nthöhö xi ñötꞌwa Jö gatho nuꞌu̱ togo mödi. 
\p  
\v 13 Nuꞌmu̱ nꞌa tsꞌa̱ti da ꞌyo̱tꞌa nöꞌö hingi ho, yo ma da ꞌñenö go tsa̱ta Jö, ngetho Jö hingi tsa̱ da tsꞌa̱ti da ꞌyo̱tꞌa nöꞌö hingi ho, ne hinto tsa̱tꞌö. 
\p  
\v 14 Nꞌa ngu nꞌa tsꞌa̱ti núꞌmu̱ hár mfenise̱ tsitsꞌi da ꞌyo̱tꞌa nöꞌö ne ár ndoꞌyo. 
\p  
\v 15 Nunar mfeninu̱, ngu nꞌar ꞌbe̱hñö ñꞌu̱, da ꞌrogi ar tsꞌoki, ne xta ꞌyo̱tꞌe, da ꞌyo̱nga ar ndöte. 
\p  
\v 16 Ma tsi hmöka kuhu̱, yo gi ꞌbe̱hu̱ ar ꞌñu. 
\p  
\v 17 Gatho ya hogantꞌuni xa xiñho, bi e mhetsꞌi, bi pe̱hna ar Dada togo ár me̱ti ar ñotꞌi. Nöꞌö hingi mponi, ne hingi pa̱ta ár mfeni, ngu mponga ar xudi. 
\p  
\v 18 Go bi neꞌö bi jaju̱ da ntehu̱ manꞌagi har mhö majöni da o̱xu̱, ne da nugagihu̱ ngu ar ꞌbe̱tꞌo sofo ma da nju̱xa mꞌe̱fa. 
\s1 Nuꞌu̱ togo o̱tꞌa ngu mönga ar hoga mhö 
\p  
\v 19 Jange tsi kuhu̱, xoju̱ xiñho ri guhu̱ gi ꞌyo̱hu̱, hinge dama gi thöhu̱, ne hingi mbo̱ ri kwe̱hu̱ ngutꞌa. 
\p  
\v 20 Ngetho nöꞌö togo mbo̱ ár kwe̱, hingi pe̱ nöꞌö ne Jö da me̱fi. 
\p  
\v 21 Jange hye̱hu̱pꞌu̱ gatho nöꞌö hingi ho ne gatho nuya tsꞌomfeni. Pe̱ꞌsu̱ nꞌar hogamu̱i gi hñöñhu̱ ar hoga mhö xi tꞌutꞌahu̱. Nunar mhönu̱ tsa̱ da po̱ꞌahu̱. 
\p  
\v 22 Ne gi ꞌyo̱thu̱ nöꞌö mönga ar hoga mhö, hinge ho̱nse̱ gi ꞌyo̱xthu̱. Nuꞌmu̱ hingi ꞌyo̱thu̱, gi ntsꞌokse̱hu̱. 
\p  
\v 23 Ngetho nuꞌmu̱ nꞌa da ꞌyo̱xa ar mhö, ne hinda ꞌyo̱ꞌte, ñhe̱hwi nꞌa handase̱ ár hmi har ñhe. 
\p  
\v 24 Nöꞌö xi wadi xi hyanda ár hmi ne bi ma, mꞌe̱fa bi pumhni tengu ár hmi. 
\p  
\v 25 Ha nöꞌö togo huxa ár da̱ har ꞌbe̱pate xi hoga ma mu̱ihu̱, hingar döni, umba ár mu̱i te̱ni da ꞌyo̱tꞌa nöꞌö mö, ne njapꞌu̱ nza̱tho gatho nöꞌö o̱tꞌe. 
\p  
\v 26 Nuꞌmu̱ nꞌa enö xa honga Jö, ne hingi tsa̱ da gotꞌa ár ne, ntsꞌokse̱, ne gatho nór ꞌbe̱fi honga Jö, hinter mꞌe̱pꞌu̱ꞌö. 
\p  
\v 27 Nunar thongajö xintꞌaxi ne hinte pe̱ꞌsa ya ja̱xtꞌi hár nthandi Jö ar Dada, gehnu̱ ma ga xiꞌahu̱: Tso̱ñhu̱ ya tsi hyoyabötsi ne ya ꞌranxu tho ar kꞌatꞌi, ne gi ntsuñhu̱ hinda ja̱xtꞌa ri mꞌu̱ihu̱ gi me̱wihu̱ ar ximha̱i. 
\c 2  
\s1 Hingi hwanthu̱ ꞌra 
\p  
\v 1 Ma tsi kuhu̱, dá nheki nuna ri ñꞌemu̱ihu̱ gi pe̱ꞌsfu̱ ma tsi Hmuhu̱ Hesukristo, yo gi hwanthu̱ togo gi zohu̱. 
\p  
\v 2 Ngetho nuꞌmu̱ ha ri mhuntsꞌihu̱ da zo̱nga nꞌar ku di hö ya kꞌaxtꞌamfoꞌye̱ ne ya hoga he, ꞌme̱fa da zo̱nga manꞌar tsi hyoya ku di he ꞌra ya tsi nju̱mfo, 
\p  
\v 3 ne gi numañhohu̱ nuna hö ar nza̱tho he, ne gi ꞌñembabihu̱: Hñuxnu̱ ha ya hoga nthutsꞌi. Ha gi ꞌñembabihu̱ nunar tsi hyoya: ꞌBa̱pꞌu̱tho. Nuꞌmu̱ gi ne gi hñudi, hñupꞌu̱ har ha̱i. 
\p  
\v 4 Hage hingi hwanthu̱ njapꞌu̱ ya ku ꞌmu̱, ne gi te̱ñhu̱ ya mfeni hingi ho. 
\p  
\v 5 Ma tsi hmöka kuhu̱, di ne gi ꞌyo̱xu̱ nöꞌö ma ga xiꞌahu̱: Hage hinxi hwahna Jö nuya hyoya jawa har ximha̱i da me̱ꞌsa nze̱ye̱ ar jamfi, ne da yu̱tꞌa hár tsꞌu̱tꞌwi xi ñötꞌwabi nuꞌu̱ togo mödi. 
\p  
\v 6 Ha nuꞌahu̱ xka hyomfu̱ ar hñö nöꞌö ar tsi hyoya. Hage hingo nuꞌu̱ pe̱ꞌsa yá mꞌe̱tsꞌi togo jaꞌahu̱ gi thohu̱ ar tsꞌomꞌu̱i, ne gehyu̱ togo tsixꞌahu̱ ma da ꞌba̱pꞌahu̱ ha ya tsꞌu̱tꞌwi. 
\p  
\v 7 Ha hinga gehyu̱ togo tsamba ar hoga thuhu bi mhatꞌahu̱ nꞌehe. 
\p  
\v 8 Nuꞌmu̱ xa majöni gi o̱thu̱ ngu enga ar ꞌbe̱pate xa döta ár nsu, gi te̱ñhu̱ ꞌmu̱ ngu enga hár Tꞌofo Jö: Mö ri ñꞌohu̱ ngu gi mhöse̱. Njapꞌu̱ gi o̱thu̱ xiñho ꞌmu̱. 
\p  
\v 9 Ha nuꞌmu̱ gi hwanthu̱ ri ñꞌohu̱, gi o̱thu̱ ar tsꞌoki, ne xka tsꞌojwu̱ ar ꞌbe̱pate, ꞌñudi gar tsꞌoktehu̱. 
\p  
\v 10 Nuꞌmu̱ nꞌa umba ár mu̱i da ꞌyo̱tꞌa gatho ngu mönga ha ya ꞌbe̱pate, ne nuꞌmu̱ da tsꞌoka nꞌa xe̱nitho, da tho̱xa xo̱ge. 
\p  
\v 11 Ngetho getꞌö togo bi ꞌñenö: Yo gi tsimba ár nthöti maꞌra, getꞌö xi ꞌñenö nꞌehe: Yo gi ñhote. Ngetho nuꞌmu̱ hingi tsimba ár nthöti manꞌa, ha gi hote, njapꞌu̱ xka tsꞌokwa yá ꞌbe̱pate Jö. 
\p  
\v 12 Jange ꞌbu̱hu̱ ne gi ñöhu̱ ngu nuꞌu̱ ma da thöꞌspa majöni har ꞌraꞌyo ꞌbe̱pate xi hoga ma mu̱ihu̱. 
\p  
\v 13 Har thöxamajöni hinda ma da mꞌe̱ꞌspa ar nhwëki nuꞌu̱ togo himbi me̱ꞌsa ar nhwëki. Ha nunar nhwëki töpa ár nsu ar thöxamajöni. 
\s1 Ar ñꞌemu̱ise̱ hinter me̱ꞌö nuꞌmu̱ hingi pe̱wi ya hoga ꞌbe̱fi 
\p  
\v 14 Ma tsi kuhu̱, te da ma̱xa nꞌar ku da ꞌñenö pe̱ꞌsa ar ñꞌemu̱i ne hinte nheki yá hoga ꞌbe̱fi. Hanja da tsa̱ da mpo̱ nꞌa nuꞌmu̱ ho̱nse̱ di mpe̱ꞌsa ar ñꞌemu̱i. 
\p  
\v 15 Xiꞌmu̱ nꞌar ku ar ñꞌo̱ho̱ wa ar ꞌbe̱hñö, hinte kö ár dutu, ne hinte pe̱ꞌsa te da zi hyaxꞌmu̱, 
\p  
\v 16 ha nuꞌahu̱ gi ꞌñembabihu̱: Di möhu̱ ter entho, ñhexu̱ xiñho ne niñöhu̱, ne hingi umfu̱ tema honga ár ndoꞌyo, tema ñho gi umfu̱ ꞌmu̱. 
\p  
\v 17 Njapꞌu̱ ar ñꞌemu̱i nꞌehe, nuꞌmu̱ hingi pe̱wi ya hoga ꞌbe̱fi, hinter me̱ꞌö. 
\p  
\v 18 Tsa̱ da ꞌñenga nꞌa: Nuꞌge gi pe̱ꞌsa ar ñꞌemu̱i, ha nuga di pe̱ꞌsa ya hoga ꞌbe̱fi. Utka ri ñꞌemu̱i hinte pe̱wi ya hoga ꞌbe̱fi, ne nuga ga utꞌa ma ñꞌemu̱i di pe̱wi ya hoga ꞌbe̱fi. 
\p  
\v 19 Gi jamfi nꞌada Jö ꞌbu̱i. Xiñhoꞌö. Njapꞌu̱ nuya tsꞌondöhi jamfi nꞌehe, ne xa nhwötꞌi ntsu. 
\p  
\v 20 Xa xka ꞌbe̱ ri mfeni. Hamꞌu̱ ma gi pödi, nunar ñꞌemu̱i, nuꞌmu̱ hingi pe̱wi ar hoga ꞌbe̱fi, hinter me̱ꞌö. 
\p  
\v 21 Ma palehu̱ ar Abra bi nhu hinte ma tsꞌoki mi tu, ngetho bi ꞌyo̱tꞌa ar hoga ꞌbe̱fi núꞌmu̱ mi da̱twa Jö ar Isa ár tꞌu̱, ngu nꞌar mꞌo̱ñho̱. 
\p  
\v 22 Ha hingi handi, ar ñꞌemu̱i bi mpe̱fi mahye̱giwi ya hoga ꞌbe̱fi, ne bi japi bi nxo̱ge núꞌmu̱ mi tꞌo̱tꞌa ya hoga ꞌbe̱fi. 
\p  
\v 23 Njapꞌu̱ bi thogi ngu enga hár Tꞌofo Jö habu̱ enö: Ar Abra bi ñꞌemu̱i Jö ne bi nhu hinte ma tsꞌoki mi tu, ne bi nsipabi ár ñꞌowi Jö. 
\p  
\v 24 Hyanthu̱ ꞌmu̱, nuya jöꞌi numañho Jö ngetho o̱tꞌa ya hoga ꞌbe̱fi, hinge ho̱nse̱ thandwa ár ñꞌemu̱i. 
\p  
\v 25 Njapꞌu̱ ar Rahab mar tsꞌoꞌbe̱hñö, bi nhu hinte ma tsꞌoki mi tu, ngetho bi umba ar tsa̱ya̱ yá mꞌe̱hni, ne bi koꞌsa ha manꞌar ꞌñu. 
\p  
\v 26 Ngetho jangu ar ndoꞌyo, nuꞌmu̱ kꞌatꞌwabi ar hñö xi du, njapꞌu̱tho ar ñꞌemu̱i nꞌehe, nuꞌmu̱ hingi pe̱wi ya hoga ꞌbe̱fi hinter me̱ꞌö. 
\c 3  
\s1 Nöꞌö pe̱ ma nehu̱ 
\p  
\v 1 Tsi kuhu̱, yo xa gi hoñhu̱ gi ñꞌutatehu̱ nze̱ye̱ꞌihu̱, ngetho gi pöhu̱ ma da thobgagihu̱ nöꞌö ar pa da thöxamajöni. 
\p  
\v 2 Ngetho gatho di tsꞌokwabihu̱ Jö. Nuꞌmu̱ di ꞌbu̱ nꞌa hinte tsꞌokwa Jö núꞌmu̱ ñö, nöꞌö xa ꞌbu̱i xiñho, ne pe̱ꞌsa ar tsꞌe̱di da zöma xo̱ge ár ndoꞌyo. 
\p  
\v 3 Nuju̱ di tutwabihu̱ ya bo̱jö ha yá ne ya fani, ne da ꞌyo̱tkagihu̱. Njapꞌu̱ di e̱thu̱ gatho ár ndoꞌyo. 
\p  
\v 4 Nuya motsa nꞌehe, mödi nda döta ne di nto̱xkwi ya ꞌyomndöhi, tꞌe̱tꞌa tsixa nꞌar tsi tꞌu̱lo ntꞌe̱, ne e̱tꞌa habu̱ da ne nuꞌu̱ e̱tꞌi. 
\p  
\v 5 Njapꞌu̱ ma nehu̱ nꞌehe, gehnu̱ nꞌár tsi xe̱ni ma ndoꞌyohu̱, ne tsa̱ da ꞌyo̱tꞌa ya döta ꞌbe̱fi. Hangu ár döta ar mboza tsa̱ da tso̱ nꞌar tsi tꞌu̱lo tsibi. 
\p  
\v 6 Ne numa nehu̱ gehnu̱ nꞌar tsibi. Ja ñuxhnu̱ ya tsꞌoki jawa har ximha̱i. Nunar nenu̱ huxa ha ma ndoꞌyohu̱, xi tsꞌomba ár mꞌu̱i gatho nöꞌö xi hyoka Jö. Gese̱ ár tsibi ar ꞌbe̱xui tso̱ nunar tsibinu̱. 
\p  
\v 7 Ngetho gatho ya zuꞌwe ja har ximha̱i, ya tsꞌintsꞌu̱, ya kꞌeñö ne nuya zuꞌwe ja har ñho̱nthe, xi tsa̱ xi zönda ar jöꞌi. 
\p  
\v 8 Ha hinjoꞌo nꞌar jöꞌi xi zönda ár ne. Ngu nꞌar hñeni hingi tsa̱ da mꞌa̱ꞌmi, xa ñuxa ar ꞌñethi hote. 
\p  
\v 9 Getnu̱ di nsundahu̱ Jö ar Dada, ne getnu̱ di tsañhu̱ ya jöꞌi di hñöxa Jö. 
\p  
\v 10 Nꞌadar ne habu̱ po̱nga ar nsunda ne ar ntsꞌani ꞌmu̱. Ma tsi kuhu̱, yo gi njahu̱pꞌu̱. 
\p  
\v 11 Hage nꞌadar po̱the habu̱ po̱nga ar uthe ne ar júthe. 
\p  
\v 12 Tsi kuhu̱, hage nꞌár ꞌba̱i ar iuxi tsa̱ da unga ya ꞌro nju̱ka ar nziki, wa nꞌár ꞌba̱i ar obxi da unga ya iuxi. 
\s1 Ar mfödi di ꞌñe mhetsꞌi 
\p  
\v 13 Nöꞌö togo ja ri mfödihu̱ ne xiñho ár mfeni, ñꞌuhu̱ ri hoga ꞌbe̱fihu̱ da nheki gi pe̱ꞌsu̱ nꞌar hogamu̱i, hingi ñꞌexu̱. 
\p  
\v 14 Ha nuꞌmu̱ gi gese̱hu̱, ne gi benthu̱ ar tuhni ha ri mu̱ihu̱, yo gi exa ri nsuhu̱ gi eñhu̱ gi pe̱ꞌsu̱ ar hoga mfödi, ne hingi njapꞌu̱. 
\p  
\v 15 Ngetho nunar mfödinu̱ gi te̱ñhu̱, himbi pe̱hna Jö. Gehnu̱ ár me̱ti ar ximha̱i, xi bense̱ ya jöꞌi, ne go unga ar tsꞌondöhi. 
\p  
\v 16 Ngetho nu habu̱ ja ar gese̱ ne ya tuhni, nunu̱ hinte janu̱ ar hogamꞌu̱i, ho̱nse̱ nöꞌö xi ntsꞌotho. 
\p  
\v 17 Ha nunar hoga mfödi di ꞌñe mhetsꞌi, mꞌe̱tꞌo xintꞌaxi, hingi honga ar tuhni, di mönga ar hogamhö, ar hogajöꞌi. Di hwëka maꞌra, ne o̱tꞌa nꞌar hoga ꞌbe̱fi, hindi ñꞌöntꞌu̱tho, gatho umba ár mu̱i o̱tꞌa xiñho. 
\p  
\v 18 Ne nuꞌu̱ togo pe̱ꞌsa ar hogamu̱i o̱tꞌa ar hoga ꞌbe̱fi, ma da hñönga nꞌar mꞌu̱i ter entho. 
\c 4  
\s1 Ar ntsixkwi ya meximha̱i 
\p  
\v 1 Habu̱ di ꞌñe ya tuhni ne ya ntꞌu̱tsate gi pe̱ꞌsu̱. Hage hinge di ꞌñe ngetho te gatho gi nehu̱, ne gathoyu̱ nxintꞌa ha ri mfenihu̱. 
\p  
\v 2 Gi hyo̱ju̱ ne hingi pe̱ꞌsu̱. ꞌBu̱tho gi ñhohu̱ ne gi ñöꞌspabihu̱ yá ñho maꞌra, ne hingi tsa̱ gi tsu̱hu̱ nöꞌö gi nehu̱. Xa gi ntuñhu̱ ne gi weñhu̱, ha hingi tiñhu̱ nöꞌö gi te̱ñhu̱. Hinte gi pe̱ꞌsu̱ ngetho hingi a̱fu̱ Jö. 
\p  
\v 3 Ha nuꞌmu̱ gi a̱hu̱ hingi tꞌaꞌahu̱, ngetho gi a̱hu̱ ngu ne ri tsꞌomfenihu̱. 
\p  
\v 4 Gi ñhe̱hwihu̱ nꞌar jöꞌi ka ár nthöti. Wa hingi pöhu̱ nöꞌö togo ntsixkwi ar ximha̱i nto̱xkwi Jö. Nu togo ne da ntsixkwi ar ximha̱i, ho̱twa ár xu̱tha Jö. 
\p  
\v 5 Wa gi beñhu̱ hinter me̱ꞌö te mönga hár Tꞌofo Jö habu̱ enö: Nunár Hñö Jö xi japi ꞌbu̱ ha ma mu̱ihu̱, xa tuse̱ mökagihu̱. 
\p  
\v 6 Ha nöꞌö xa hwëgagihu̱ ár mfa̱tsꞌi, jange enö njawa: Jö nto̱xkwi ya ñꞌetsꞌi, ne fa̱xa nuꞌu̱ ꞌyo ntsꞌa̱ꞌmtho. 
\p  
\v 7 ꞌYo̱thwu̱ Jö, yo gi ñhe̱hu̱ da döꞌahu̱ ar tsꞌondöhi, ne da ꞌwege da maꞌö. 
\p  
\v 8 Kwathu̱ gi hyoñhu̱ Jö, ne da watꞌi da hyoñꞌahu̱ nꞌehe. Nuꞌahu̱ xka ꞌyo̱thu̱ ar tsꞌoki, xu̱ju̱ ri ꞌye̱hu̱. Ne nuꞌahu̱ gi yótꞌa ri mfenihu̱, jafu̱ da tꞌaxka nꞌagitho. 
\p  
\v 9 Dá du ri mu̱ihu̱ gi nzoñhu̱. Dá the ri thedehu̱ da zo̱ ar tsꞌoni. Dá the ri johyahu̱, da zo̱pꞌahu̱ ar dumu̱i. 
\p  
\v 10 Ntsꞌa̱ꞌmhu̱ hár nthandi ar tsi Hmu, ne go da ꞌñesꞌahu̱ ri nsuhu̱. 
\s1 Hinga theñhu̱ ya ku 
\p  
\v 11 Tsi kuhu̱, yo gi nthentehu̱ nꞌa ngu nꞌa. Ngetho nuꞌu̱ togo o̱tꞌa njapꞌu̱, po̱ntho thenga ya ꞌbe̱pate ne embabi hinter me̱ꞌu̱. Hingi ne da ꞌyo̱te, ne go neꞌu̱ da hñöꞌspa majöni ya ꞌbe̱pate. 
\p  
\v 12 Nꞌase̱ togo xi unga ya ꞌbe̱pate, geꞌö togo tsa̱ da unga ar mpo̱ho̱, wa da japa ya jöꞌi da mꞌe̱di. Xiꞌge, togoꞌi gi ꞌya̱pa ár mfe̱i manꞌa. 
\s1 Hyoñhu̱ gi ꞌbe̱tꞌohu̱ Jö 
\p  
\v 13 Ha gi o̱hu̱pya, nuꞌahu̱ gi exu̱ ri nsuhu̱ gi eñhu̱: Nupya wa xudi ga möhu̱ ha nꞌar hnini, ne ga ꞌbu̱hu̱nu̱ nꞌa nje̱ye̱, ga mpa̱hu̱ ne ga töhu̱ ya bojö. 
\p  
\v 14 Ho̱nse̱ hingi pöhmöhu̱ tema da tho xudi. Ngetho ter me̱ꞌö ri tehu̱. Ha hingi ñhe̱hwihu̱ ar ꞌbo̱ngui, nꞌa tsi tu̱i da nheki ne da mꞌe̱tho manꞌagi. 
\p  
\v 15 Nöꞌö xiñho gi ꞌñeñhu̱: Nuꞌmu̱ njapꞌu̱ ne ar tsi Dada ne da hmiju̱ ar te, ga o̱thu̱ nuna ne nuyu̱. 
\p  
\v 16 Nuꞌmu̱ hingi eñhu̱ njapꞌu̱, gi exa ri nsuhu̱, ne gatho nöꞌö hingi etꞌa Jö mꞌe̱tꞌo, hingi ho. 
\p  
\v 17 Ha nöꞌö pödi da ꞌyo̱tꞌa nöꞌö xiñho ne hingi o̱tꞌe, tsꞌokwa Jö. 
\c 5  
\s1 Tsꞌohna nuꞌu̱ pe̱ꞌsa ya ñho ne toꞌma ya hyoya 
\p  
\v 1 ꞌYo̱hu̱pya, nuꞌahu̱ gi pe̱ꞌsu̱ nze̱ye̱ ri ñhohu̱, nzoñhu̱ ne xa gi mahu̱, ngetho xa ma gi thohu̱ ar hyoya ne ar thuhu. 
\p  
\v 2 Nuya ri ñhohu̱ xi ꞌyatho, ne xi zida ya zuꞌwe nuya ri hehu̱. 
\p  
\v 3 Nuya ri kꞌaxtꞌi ne ri tꞌaxbojöhu̱ xi zida ar ha̱i, gehyu̱ ma da da̱majöni gi njahu̱pꞌu̱. Nuya ri ñhohu̱ xka kwathu̱ nuya ngöxapayu̱, po̱ntho xka munsu̱ ya tsibi, ma gi ntsötꞌase̱hu̱. 
\p  
\v 4 Nuya ꞌbe̱fi xi ꞌyo̱tꞌa ri ꞌbe̱gohu̱, ka̱xa Jö gi kahu̱ ne hingi juthwu̱. Ne yá mhafi xi ꞌyo̱ ar tsi Hmu togo xa pe̱ꞌsa ar tsꞌe̱di. 
\p  
\v 5 Xka ꞌbu̱hu̱wa har ximha̱i ngu xka nehu̱, ne xka ꞌyo̱thu̱ ngu xi ne ri mfenihu̱. Ne xa xka noju̱, po̱ntho ngu nꞌar me̱ti xi tꞌe̱ntꞌi da tho. 
\p  
\v 6 Xka hñuꞌsu̱ ne xka hyohu̱ nunar tsi hogajöꞌi ñhe̱tho. 
\s1 Pe̱ꞌsu̱ ar tsꞌe̱ti ne gi ꞌya̱fu̱ Jö 
\p  
\v 7 Jange tsi kuhu̱, pe̱ꞌsu̱ ar tsꞌe̱ti, to̱ꞌmhu̱ ar pa da ꞌñepꞌu̱ ar tsi Hmu. Jangu ar wöhi to̱ꞌmi da da̱ ar ꞌbe̱tꞌo ꞌye, wa nuna ta̱ mꞌe̱fa, ne da ndu̱i da mpotꞌi, ne ja da nxofo. 
\p  
\v 8 Hö, pe̱ꞌsu̱ ar tsꞌe̱ti ne tse̱ta ri mu̱ihu̱, ngetho ar tsi Hmu ꞌba̱pꞌu̱tho da ehe. 
\p  
\v 9 Tsi kuhu̱, yo xa gi nga̱xtehu̱ te gatho gi ho̱xu̱ ri kuhu̱. Nuꞌmu̱ hinꞌö, ma da tꞌe̱kꞌahu̱ ri mfe̱ihu̱, ngetho nöꞌö togo ma da hñöxa majöni, ꞌba̱ ar ꞌñu da ehe. 
\p  
\v 10 Tsi kuhu̱, pe̱ꞌsu̱ ngu nꞌar ntꞌuti gi te̱mfu̱ yá tsꞌe̱ti yá mꞌe̱hni ar tsi Hmu bi mömpꞌu̱ ár mhö. Te̱ñhu̱ hanja bi thoꞌu̱ ya dumu̱i. 
\p  
\v 11 Nuju̱ di nuhu̱ nza̱tho nuꞌu̱ tho ya thogi. Xka ꞌyo̱hu̱ tengu mi pe̱ꞌsa ar tsꞌe̱ti ar Hob, ne xka pöhu̱ tema ngötsꞌi bi umba ar tsi Hmu, ngetho xa döta ár nhwëki ne ár hogamu̱i. 
\p  
\v 12 Ho̱nse̱ nöꞌö xa di te̱tꞌahu̱ tsi kuhu̱, hinte gi ꞌñethu̱ made, ngu ar mhetsꞌi wa ar ximha̱i. Nöꞌö gi eñhu̱ hö, di njapꞌu̱, ha nöꞌö gi eñhu̱ hinꞌö, hinꞌö. Yo ma da thusꞌa ri mfe̱ihu̱. 
\p  
\v 13 Nuꞌmu̱ ja te tupꞌa ri mu̱ihu̱, ꞌya̱fu̱ Jö. Ha nuꞌmu̱ gi johyahu̱, tuthwu̱ Jö. 
\p  
\v 14 Ha nuꞌmu̱ gi hñeñhu̱, zoñhu̱ ya ndö har nijö da ꞌya̱pa Jö gi thixu̱, ne da gosꞌahu̱ ar nziki da e po̱ta ar tsi Hmu. 
\p  
\v 15 Nuꞌmu̱ da tꞌa̱pa Jö ne di ñꞌemu̱i, go gehnu̱ japi da dixa ar da̱thi, ne ar tsi Hmu da gu̱tsꞌi. Ha nuꞌmu̱ xi ꞌyo̱tꞌa nꞌar tsꞌoki, da mpumbabi. 
\p  
\v 16 Nda̱hu̱ ri tsꞌokihu̱ nꞌa ngu nꞌa, mhathwu̱ Jö nꞌa ngu nꞌa, ne da tsa̱ gi thixu̱. Nu ár hoga ntꞌa̱di nꞌar hogajöꞌi, xa te gatho tsa̱ da ꞌyo̱tꞌe. 
\p  
\v 17 Ar Elia mar ñꞌo̱ho̱ mi tho ya tsꞌomfeni nguju̱ nꞌehe. Ne bi zitꞌa ár mu̱i bi ꞌya̱pa Jö hinge nda ꞌwöi, ne himbi ꞌwö xo̱ge ar ximha̱i hñu nje̱ye̱ ne ꞌrato nzönö. 
\p  
\v 18 Bi mengi bi ꞌya̱pa Jö, ne bi ꞌwöi manꞌagi, ha nunar ha̱i bi mengi bi unga ár sofo. 
\p  
\v 19 Tsi kuhu̱, nuꞌmu̱ gi koꞌsu̱ nꞌar ku xki ꞌbe̱ ar ꞌñu majöni, 
\p  
\v 20 pöhu̱ nöꞌö togo da japa nꞌar tsꞌokte da zopꞌu̱ ár tsꞌoꞌñu, ma da japi da kꞌontꞌa ár pa ndi ma har ꞌbe̱xui, ne xi mpunga nze̱ye̱ ya tsꞌoki.