\s1 Superscription  
\p
\v 1  \w This|strong="H1697"\w* \w is|strong="H3068"\w* \w the|strong="H3068"\w* \w word|strong="H1697"\w* \w of|strong="H1121"\w* \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w which|strong="H3068"\w* \w was|strong="H3068"\w* revealed \w to|strong="H3478"\w* \w Hosea|strong="H1954"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Beeri \w during|strong="H3117"\w* \w the|strong="H3068"\w* \w time|strong="H3117"\w* \w when|strong="H1961"\w* \w Uzziah|strong="H5818"\w*, \w Jotham|strong="H3147"\w*, Ahaz, \w and|strong="H1121"\w* \w Hezekiah|strong="H2396"\w* \w ruled|strong="H4428"\w* \w Judah|strong="H3063"\w*, \w and|strong="H1121"\w* \w during|strong="H3117"\w* \w the|strong="H3068"\w* \w time|strong="H3117"\w* \w when|strong="H1961"\w* \w Jeroboam|strong="H3379"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Joash|strong="H3101"\w* \w ruled|strong="H4428"\w* \w Israel|strong="H3478"\w*.   
\s1 Symbols of Sin and Judgment: The Prostitute and Her Children  
\p
\v 2  \w When|strong="H3588"\w* \w the|strong="H3588"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w first|strong="H8462"\w* \w spoke|strong="H1696"\w* \w through|strong="H3212"\w* \w Hosea|strong="H1954"\w*, \w he|strong="H3588"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w him|strong="H3947"\w*, “\w Go|strong="H3212"\w* \w marry|strong="H3947"\w* \w a|strong="H3068"\w* \w prostitute|strong="H2181"\w* \w who|strong="H3068"\w* \w will|strong="H3068"\w* \w bear|strong="H3212"\w* illegitimate \w children|strong="H3206"\w* conceived \w through|strong="H3212"\w* prostitution, \w because|strong="H3588"\w* \w the|strong="H3588"\w* nation \w continually|strong="H2181"\w* \w commits|strong="H2181"\w* spiritual prostitution \w by|strong="H3068"\w* turning \w away|strong="H3947"\w* \w from|strong="H3947"\w* \w the|strong="H3588"\w* \nd \+w Lord|strong="H3068"\+w*\nd*.”  
\v 3  \w So|strong="H3947"\w* Hosea \w married|strong="H3947"\w* \w Gomer|strong="H1586"\w*, \w the|strong="H3947"\w* \w daughter|strong="H1323"\w* \w of|strong="H1121"\w* \w Diblaim|strong="H1691"\w*. \w Then|strong="H3947"\w* she \w conceived|strong="H2029"\w* \w and|strong="H1121"\w* \w gave|strong="H3205"\w* \w birth|strong="H3205"\w* \w to|strong="H3212"\w* \w a|strong="H3068"\w* \w son|strong="H1121"\w* \w for|strong="H1121"\w* \w him|strong="H3205"\w*.  
\v 4  \w Then|strong="H3588"\w* \w the|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w said|strong="H7121"\w* \w to|strong="H3478"\w* \w Hosea|strong="H7121"\w*, “\w Name|strong="H8034"\w* \w him|strong="H7121"\w* ‘\w Jezreel|strong="H3157"\w*,’ \w because|strong="H3588"\w* \w in|strong="H5921"\w* \w a|strong="H3068"\w* \w little|strong="H4592"\w* \w while|strong="H5750"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w punish|strong="H6485"\w* \w the|strong="H5921"\w* \w dynasty|strong="H1004"\w* \w of|strong="H1004"\w* \w Jehu|strong="H3058"\w* \w on|strong="H5921"\w* \w account|strong="H5921"\w* \w of|strong="H1004"\w* \w the|strong="H5921"\w* \w bloodshed|strong="H1818"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* valley \w of|strong="H1004"\w* \w Jezreel|strong="H3157"\w*, \w and|strong="H3478"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w put|strong="H7673"\w* \w an|strong="H7673"\w* \w end|strong="H7673"\w* \w to|strong="H3478"\w* \w the|strong="H5921"\w* \w kingdom|strong="H4468"\w* \w of|strong="H1004"\w* \w Israel|strong="H3478"\w*.  
\v 5  \w At|strong="H3478"\w* \w that|strong="H3117"\w* \w time|strong="H3117"\w*, \w I|strong="H3117"\w* \w will|strong="H1961"\w* \w destroy|strong="H7665"\w* \w the|strong="H3117"\w* military \w power|strong="H3478"\w* \w of|strong="H3117"\w* \w Israel|strong="H3478"\w* \w in|strong="H3478"\w* \w the|strong="H3117"\w* \w valley|strong="H6010"\w* \w of|strong="H3117"\w* \w Jezreel|strong="H3157"\w*.”   
\p
\v 6  \w She|strong="H3588"\w* \w conceived|strong="H2029"\w* \w again|strong="H5750"\w* \w and|strong="H3478"\w* \w gave|strong="H3205"\w* \w birth|strong="H3205"\w* \w to|strong="H3478"\w* \w a|strong="H3068"\w* \w daughter|strong="H1323"\w*. \w Then|strong="H5375"\w* \w the|strong="H3588"\w* \nd Lord\nd* \w said|strong="H7121"\w* \w to|strong="H3478"\w* \w him|strong="H3205"\w*, “\w Name|strong="H8034"\w* \w her|strong="H5375"\w* ‘\w No|strong="H3808"\w* \w Pity|strong="H7355"\w*’ (\w Lo-Ruhamah|strong="H3819"\w*) \w because|strong="H3588"\w* \w I|strong="H3588"\w* \w will|strong="H3478"\w* \w no|strong="H3808"\w* \w longer|strong="H5750"\w* \w have|strong="H7355"\w* \w pity|strong="H7355"\w* \w on|strong="H7355"\w* \w the|strong="H3588"\w* \w nation|strong="H1004"\w* \w of|strong="H1004"\w* \w Israel|strong="H3478"\w*. \w For|strong="H3588"\w* \w I|strong="H3588"\w* \w will|strong="H3478"\w* \w certainly|strong="H3588"\w* \w not|strong="H3808"\w* \w forgive|strong="H5375"\w* \w their|strong="H5375"\w* guilt.  
\v 7  \w But|strong="H3808"\w* \w I|strong="H3808"\w* \w will|strong="H3068"\w* \w have|strong="H7355"\w* \w pity|strong="H7355"\w* \w on|strong="H3068"\w* \w the|strong="H3068"\w* \w nation|strong="H1004"\w* \w of|strong="H1004"\w* \w Judah|strong="H3063"\w*. \w I|strong="H3808"\w* \w will|strong="H3068"\w* \w deliver|strong="H3467"\w* \w them|strong="H7355"\w* \w by|strong="H3068"\w* \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w their|strong="H3068"\w* \w God|strong="H3068"\w*; \w I|strong="H3808"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w deliver|strong="H3467"\w* \w them|strong="H7355"\w* \w by|strong="H3068"\w* \w the|strong="H3068"\w* \w warrior|strong="H4421"\w*’s \w bow|strong="H7198"\w*, \w by|strong="H3068"\w* \w sword|strong="H2719"\w*, \w by|strong="H3068"\w* \w military|strong="H4421"\w* \w victory|strong="H3467"\w*, \w by|strong="H3068"\w* chariot \w horses|strong="H5483"\w*, \w or|strong="H3808"\w* \w by|strong="H3068"\w* chariots.”   
\p
\v 8  \w When|strong="H1121"\w* she \w had|strong="H3205"\w* \w weaned|strong="H1580"\w* ‘No Pity’ (\w Lo-Ruhamah|strong="H3819"\w*) she \w conceived|strong="H2029"\w* \w again|strong="H2029"\w* \w and|strong="H1121"\w* \w gave|strong="H3205"\w* \w birth|strong="H3205"\w* \w to|strong="H3205"\w* another \w son|strong="H1121"\w*.  
\v 9  \w Then|strong="H1961"\w* \w the|strong="H3588"\w* \nd Lord\nd* \w said|strong="H7121"\w*: “\w Name|strong="H8034"\w* \w him|strong="H7121"\w* ‘\w Not|strong="H3808"\w* \w My|strong="H1961"\w* \w People|strong="H5971"\w*’ (\w Lo-Ammi|strong="H3818"\w*), \w because|strong="H3588"\w* \w you|strong="H3588"\w* \w are|strong="H5971"\w* \w not|strong="H3808"\w* \w my|strong="H1961"\w* \w people|strong="H5971"\w* \w and|strong="H5971"\w* \w I|strong="H3588"\w* \w am|strong="H1961"\w* \w not|strong="H3808"\w* \w your|strong="H3588"\w* \w God|strong="H3808"\w*.”   
\s1 The Restoration of Israel  
\p
\v 10  However, in the future the number of the people of Israel will be like the sand of the sea which can be neither measured nor numbered. Although it was said to them, “You are not my people,” it will be said to them, “You are children of the living God!”  
\v 11  Then the people of Judah and the people of Israel will be gathered together. They will appoint for themselves one leader, and will flourish in the land. Certainly, the day of Jezreel will be great!   
\c 2  
\p
\v 1  \w Then|strong="H1961"\w* \w you|strong="H3808"\w* \w will|strong="H1961"\w* call \w your|strong="H3808"\w* brother, “\w My|strong="H1961"\w* \w People|strong="H5971"\w*” (\w Ammi|strong="H5971"\w*)! \w You|strong="H3808"\w* \w will|strong="H1961"\w* call \w your|strong="H3808"\w* sister, “Pity” (Ruhamah)!   
\s1 Idolatrous Israel Will Be Punished Like a Prostitute  
\q1
\v 2  Plead earnestly \w with|strong="H3117"\w* \w your|strong="H7760"\w* mother  
\q1 (\w for|strong="H3588"\w* \w she|strong="H3588"\w* \w is|strong="H3117"\w* \w not|strong="H3588"\w* \w my|strong="H7760"\w* wife, \w and|strong="H1121"\w* \w I|strong="H3588"\w* am \w not|strong="H3588"\w* \w her|strong="H7760"\w* husband),  
