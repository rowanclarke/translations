\v 21 \w Es|strong="G3739"\w* \w necesario|strong="G1163"\w*, \w pues|strong="G3767"\w*, \w que|strong="G3588"\w* \w de|strong="G1722"\w* \w los|strong="G3588"\w* varones \w que|strong="G3588"\w* anduvieron \w con|strong="G1722"\w* \w nosotros|strong="G2249"\w* durante \w todo|strong="G3956"\w* \w el|strong="G3588"\w* \w tiempo|strong="G5550"\w* \w cuando|strong="G1722"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w* \w Jesús|strong="G2424"\w* estuvo \w entre|strong="G1722"\w* \w nosotros|strong="G2249"\w*,  
\v 22 \w a|strong="G2193"\w* partir \w del|strong="G3588"\w* bautismo \w de|strong="G3588"\w* \w Juan|strong="G2491"\w* \w hasta|strong="G2193"\w* \w el|strong="G3588"\w* \w día|strong="G2250"\w* cuando \w fue|strong="G1096"\w* tomado arriba \w de|strong="G3588"\w* \w entre|strong="G2193"\w* \w nosotros|strong="G2249"\w*, \w uno|strong="G1520"\w* \w de|strong="G3588"\w* \w éstos|strong="G3778"\w* \w sea|strong="G1096"\w* \w testigo|strong="G3144"\w* \w con|strong="G4862"\w* \w nosotros|strong="G2249"\w* \w de|strong="G3588"\w* \w su|strong="G3588"\w* resurrección.   
\p
\v 23 Propusieron a \w dos|strong="G1417"\w*: a \w José|strong="G2501"\w*, \w llamado|strong="G2564"\w* Barsabás, a \w quien|strong="G3739"\w* apodaban \w Justo|strong="G2459"\w*, \w y|strong="G2532"\w* a \w Matías|strong="G3159"\w*.  
\v 24 \w Después|strong="G2532"\w* \w de|strong="G1537"\w* \w hablar|strong="G3004"\w* \w con|strong="G1537"\w* \w Dios|strong="G2962"\w*, \w dijeron|strong="G3004"\w*: \add Tú\add*, \w Señor|strong="G2962"\w*, conocedor \w de|strong="G1537"\w* \w los|strong="G3588"\w* corazones \w de|strong="G1537"\w* \w todos|strong="G3956"\w*, muestra \w a|strong="G1537"\w* \w quién|strong="G3739"\w* \w de|strong="G1537"\w* \w estos|strong="G3778"\w* \w dos|strong="G1417"\w* \w te|strong="G4771"\w* escogiste  
\v 25 \w para|strong="G1519"\w* \w tomar|strong="G2983"\w* \w el|strong="G3588"\w* \w lugar|strong="G5117"\w* \w en|strong="G1519"\w* \w este|strong="G3778"\w* \w ministerio|strong="G1248"\w* \w y|strong="G2532"\w* apostolado, \w del|strong="G3588"\w* \w cual|strong="G3739"\w* cayó \w Judas|strong="G2455"\w* \w para|strong="G1519"\w* \w irse|strong="G4198"\w* \w a|strong="G1519"\w* \w su|strong="G3588"\w* \w propio|strong="G2398"\w* \w lugar|strong="G5117"\w*.   
\p
\v 26 \w Les|strong="G1909"\w* \w echaron|strong="G1325"\w* \w suertes|strong="G2819"\w*. \w La|strong="G3588"\w* \w suerte|strong="G2819"\w* \w cayó|strong="G4098"\w* \w sobre|strong="G1909"\w* \w Matías|strong="G3159"\w* \w y|strong="G2532"\w* fue incorporado \w con|strong="G3326"\w* \w los|strong="G3588"\w* 11 apóstoles.   
\c 2  
\s1 Día de Pentecostés  
\p
\v 1 \w Cuando|strong="G1722"\w* \w se|strong="G2532"\w* cumplió \w el|strong="G3588"\w* \w día|strong="G2250"\w* \w de|strong="G1722"\w* \w Pentecostés|strong="G4005"\w*, estaban \w todos|strong="G3956"\w* reunidos \w en|strong="G1722"\w* \w un|strong="G3588"\w* lugar.  
\v 2 \w De|strong="G1537"\w* repente \w vino|strong="G1096"\w* \w del|strong="G3588"\w* \w cielo|strong="G3772"\w* \w un|strong="G3588"\w* estruendo, \w como|strong="G5618"\w* \w una|strong="G3588"\w* ráfaga \w de|strong="G1537"\w* viento impetuoso \w que|strong="G3588"\w* llenó \w toda|strong="G3650"\w* \w la|strong="G3588"\w* \w casa|strong="G3624"\w* \w donde|strong="G3757"\w* estaban \w sentados|strong="G2521"\w*.  
\v 3 \w Se|strong="G2532"\w* \w les|strong="G1909"\w* distribuyeron \w lenguas|strong="G1100"\w*\f + \fr 2:3 \ft En un sentido lengua es sinónimo de idioma.\f* \w como|strong="G5616"\w* \w de|strong="G1909"\w* \w fuego|strong="G4442"\w* \w que|strong="G2532"\w* posaron \w sobre|strong="G1909"\w* \w cada|strong="G1538"\w* \w uno|strong="G1520"\w* \w de|strong="G1909"\w* ellos.  
\v 4 \w Todos|strong="G3956"\w* fueron \w llenos|strong="G4130"\w* \w del|strong="G3588"\w* \w Espíritu|strong="G4151"\w* Santo, \w y|strong="G2532"\w* comenzaron a \w hablar|strong="G2980"\w* \w en|strong="G3588"\w* diferentes \w lenguas|strong="G1100"\w*, \w según|strong="G2531"\w* \w el|strong="G3588"\w* \w Espíritu|strong="G4151"\w* les concedía \w hablar|strong="G2980"\w*.   
\p
\v 5 Había varones \w judíos|strong="G2453"\w* \w piadosos|strong="G2126"\w* \w que|strong="G3588"\w* vivían \w en|strong="G1722"\w* Jerusalén procedentes \w de|strong="G1722"\w* \w toda|strong="G3956"\w* \w nación|strong="G1484"\w* \w bajo|strong="G5259"\w* \w el|strong="G3588"\w* \w cielo|strong="G3772"\w*.  
\v 6 \w Después|strong="G2532"\w* \w de|strong="G3588"\w* \w este|strong="G3778"\w* \w estruendo|strong="G5456"\w*, \w la|strong="G3588"\w* \w multitud|strong="G4128"\w* concurrió. \w Se|strong="G1096"\w* confundió, \w porque|strong="G3754"\w* oían \w que|strong="G3754"\w* \w cada|strong="G1538"\w* \w uno|strong="G1520"\w* les \w hablaba|strong="G2980"\w* \w en|strong="G3588"\w* \w su|strong="G3588"\w* \w propia|strong="G2398"\w* \w lengua|strong="G1258"\w*.   
\p
\v 7 \w Se|strong="G2532"\w* maravillaban. \w Se|strong="G2532"\w* asombraban \w y|strong="G2532"\w* \w decían|strong="G3004"\w*: Observen, ¿\w no|strong="G3756"\w* \w son|strong="G1510"\w* \w galileos|strong="G1057"\w* \w todos|strong="G3956"\w* \w estos|strong="G3778"\w* \w que|strong="G3588"\w* \w hablan|strong="G2980"\w*?  
\v 8 ¿\w Cómo|strong="G4459"\w*, \w pues|strong="G2532"\w*, \w los|strong="G3588"\w* oímos, \w cada|strong="G1538"\w* \w uno|strong="G3739"\w* \w de|strong="G1722"\w* \w nosotros|strong="G2249"\w*, \w en|strong="G1722"\w* \w nuestra|strong="G3588"\w* \w propia|strong="G2398"\w* \w lengua|strong="G1258"\w* \w con|strong="G1722"\w* \w la|strong="G3588"\w* \w cual|strong="G3739"\w* nacimos:  
\v 9 \w partos|strong="G3934"\w*, \w medos|strong="G3370"\w*, \w elamitas|strong="G1639"\w* \w y|strong="G2532"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* habitamos \w Mesopotamia|strong="G3318"\w*, \w Judea|strong="G2449"\w* \w y|strong="G2532"\w* \w también|strong="G2532"\w* Capadocia, Ponto \w y|strong="G2532"\w* Asia,  
\v 10 Frigia, Panfilia, Egipto \w y|strong="G2532"\w* \w las|strong="G3588"\w* \w regiones|strong="G3313"\w* \w de|strong="G2596"\w* Libia frente \w a|strong="G2596"\w* Cirene, \w y|strong="G2532"\w* \w los|strong="G3588"\w* forasteros \w romanos|strong="G4514"\w*,  
\v 11 tanto \w judíos|strong="G2453"\w* \w como|strong="G2532"\w* \w prosélitos|strong="G4339"\w*, \w cretenses|strong="G2912"\w* \w y|strong="G2532"\w* árabes, \w los|strong="G3588"\w* oímos \w que|strong="G3588"\w* \w hablan|strong="G2980"\w* \w en|strong="G3588"\w* nuestras \w lenguas|strong="G1100"\w* \w las|strong="G3588"\w* maravillosas obras \w de|strong="G3588"\w* \w Dios|strong="G2316"\w*?   
\p
\v 12 Estaban \w todos|strong="G3956"\w* asombrados \w y|strong="G2532"\w* \w perplejos|strong="G1280"\w*. \w Se|strong="G4314"\w* preguntaban unos \w a|strong="G4314"\w* otros: ¿\w Qué|strong="G5101"\w* significa \w esto|strong="G3778"\w*?   
\p
\v 13 \w Otros|strong="G2087"\w*, \w en|strong="G3754"\w* \w son|strong="G1510"\w* \w de|strong="G1161"\w* burla, \w decían|strong="G3004"\w*: ¡Están embriagados!   
\s1 Primer mensaje de Pedro  
