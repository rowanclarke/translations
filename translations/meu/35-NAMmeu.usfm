\id NAM .01, Nahum 1, Motu, PNG, RTWP 12/92 
\h NAHUMU 
\toc1 NAHUMU 
\toc2 NAHUMU 
\mt1 NAHUMU  
\c 1  
\s1 Iehova ena badu toadia  
\p
\v 1 Maduna metauna Nineve latanai; Nahumu, tau Elkoso, ena mata-hanai bukana.   
\b  
\q1
\v 2 Iehova na vaḡeḡe bona hadava Diravana,  
\q2 Iehova na dava e hadavamu mai baduna ida.  
\q1 Iehova ese ana inai taudia e hadava henidiamu;  
\q2 ia inaina e badu henidiamu.   
\q1
\v 3 Iehova ena badu na se vara haraḡamu,  
\q2 ena goada na herea;  
\q1 Iehova ese kerere taudia maorodia basine gwaurai,  
\q2 lasi ona lasi vaitani.  
\b  
\q1 lena dala na koe-hirihiri ai bona lai gubana ai,  
\q2 ori na ia aena ḡahuna.   
\q1
\v 4 Ia ese davara e gwau heniamu, e hakororoamu,  
\q2 sinavai iboudiai e hakororodiamu;  
\q1 Basan bona Karamele e geaka-geakamu,  
\q2 Lebanon burena e maraimu.   
\q1
\v 5 Ia vairanai ororo e heude-heudemu,  
\q2 bona ororo komutadia e vevemu;  
\q1 ia vairanai tano na e vahumu,  
\q2 tanobada mai inoholaina taudia iboudiai ida danu.   
\b  
\q1
\v 6 lena badu vairanai daika baine gini?  
\q2 Ena badu garaḡarana ai daika baine haheauka?  
\q1 Ena badu na e seia dobimu lahi na heto;  
\q2 haga nadidia ia ese e hapararadiamu.   
\q1
\v 7 Iehova na namo,  
\q2 ia na gabu aukana hekwakwanai dinana ai;  
\q2 enai e roho maurimu taudia na e dibadiamu.   
\q1
\v 8 A utu-utu badana amo  
\q2 ia ese ana inai taudia bame ha-uredia vaitani,  
\q1 bona inaina na baine hahavadia  
\q2 ela bona dibura lalonai.   
\q1
\v 9 Dahaka o lalo hatalaiamu, Iehova ihadikana?  
\q2 Ia ese inaina baine habuadia tari vaitani.  
\q2 Ia ese ia inaina basine hadava henidia nega harua.   
\q1
\v 10 Au giniginidia heromedia na heheto e aradia oremu,  
\q2 eiava rei kakoro na heto.   
\q1
\v 11 Iehova ihadikana dalana e lalo hatalaia  
\q2 bona kara dika e hahealolaia tauna ta oiemu amo se lasi a?   
\b  
\q1
\v 12 Iehova ini e gwau tomamu:  
\q2 Ena be idia na gogoada bona huhutuma,  
\q2 to bae henege daure bona bae puki oho.  
\q1 Ena be vada na hahisihisimu,  
\q2 to basina hahisihisimu lou.   
\q1
\v 13 Harihari iena madluna oi paḡamu ai na baina hakwaidua,  
\q2 bona iḡuimu varodia baina hamotudia.   
\b  
\q1
\v 14 Iehova ese oi vada e haḡanilaimu, e tomu:  
\q2 Ini amo oi ladamu basine hesiriu;  
\q1 emu dirava edia dubu lalona amo  
\q2 e koroa bona e hahelaria kaivakukudia baina negedia daure;  
\q1 oiemu guri baina ḡeia,  
\q2 badina be oi na dika rohoroho.   
\b  
\q1
\v 15 A itaia, hari namodia e mailaidiamu tauna,  
\q2 maino e harorolaiamu tauna,  
\q2 aena na ororo ai.  
\q1 Iuda e, emu aria ba kara,  
\q2 emu gwauhamata anidia ba kara,  
\q1 badina be kara dika tauna ese nega ta ai basine tuari henimu lou,  
\q2 ia na vada e henege daure vaitani.   
\c 2  
\s1 Nineve ena darere herevadia  
\q1
\v 1 Ihamakohimu tauna ese vada e tuari henimumu,  
\q2 maḡu ba gimadia, dala ba itaia tao;  
\q1 emu rami ba hekasilaia,  
\q2 goadamu idoinai ba heḡaeḡaelaia.   
\q1
\v 2 (Badina be Iehova ese Iakob siahuna e havaraia loumu,  
\q2 Israel siahuna heḡereḡerena;  
\q1 badina be dadidadi taudia ese vada e dadihaidia,  
\q2 bona rigidia na vada e hadihakia vaitani.)   
\b  
\q1
\v 3 Iena goada taudia edia kesi na kakakaka,  
\q2 ena tuari taudia ese dabua kakakakadia vada e hahedokilai.  
\q1 Kariota e haboudia hegaeḡaemu negana ai  
\q2 idia na e hwuru-hururumu, lahi na heto;  
\q2 hosi na e hare loamu.   
\q1
\v 4 Kariota na ariara ai e heau lalo-dikamu,  
\q2 hanua ariaradia ai e heau laomu e heau maimu;  
\q1 e kiama-kiamamu kede na heheto,  
\q2 e kinoa laomu kevaru na heto.   
\q1
\v 5 Tuari biagudia na e boiridiamu,  
\q2 laodia ai e hetutuhimu;  
\q1 maḡu e heau heniamu,  
\q2 vaḡoma vada e haheḡaeḡaea.   
\q1
\v 6 Sinavai ihadai-ahudia vada e kehodia,  
\q2 pavapava ena ruma ai kudoudia e hetahamu;   
\q1
\v 7 pavapava hahinena na ena dabua vada e hahedokidia oho,  
\q2 vada e laohaia,  
\q1 ena hesiai kekenidia na e rohe ahumu,  
\q2 e taimu pune na heheto,  
\q2 e tai hevalemu.   
\q1
\v 8 Nineve na ranuna e aru ohomu gohuna na heto;  
\q2 e boi lolomu, e tomu “A gini, a gini”,  
\q2 a ta se gini kerehaimu.   
\q1
\v 9 \it Silver\it* ba dadia!  
\q2 \it Gold\it* ba dadia!  
\q1 Kohu namodia na asi dokodia,  
\q2 ḡau herea-daedia na momo herea.   
\b  
\q1
\v 10 Hahevahu! Haheḡagae! Hahebua-tari!  
\q2 Kudou e hetahamu; tui e tabubu-tabubumu;  
\q1 koekoe iboudia e hisihisimu;  
\q2 vaira iboudiai e laboramu.   
\q1
\v 11 Leona ena guri na edeseni ai?  
\q2 leona natuna edia kohua na edeseni ai?  
\q1 leona ese damuna e vareailaia gabuna,  
\q2 natuna e noholaiamu bena ta ese se hamarerediamu gabuna,  
\q2 be edeseni ai?   
\q1
\v 12 Leona ese vamu e darea sisisisi, natuna adia,  
\q2 bona damuna gadona e koria, advana adia;  
\q1 ena kohua na damuna amo  
\q2 bona ena guri na vamu amo  
\q2 e hahonudia.   
\p
\v 13 Iehova Sabaota na e tomu: A itaia, lau ese na tuari henimumu; emu kariota na baina doudia, kwalahu ai baela; dare ese emu leona natudia baine ha-oredia; oi damumu na tanobada amo baina negea daure, bona emu gwaukau taudia eredia na basie hekamonai lou.   
\c 3  
\s1 Nineve ihabua-tarina  
\q1
\v 1 Rara hebubu hanuana, madi ihabaina!  
\q2 Koikoi bona dadidadi ḡaudia ai e honu honu daemu;  
\q2 dadidadi karadia na asi dokodia.   
\q1
\v 2 Hekwadi varona bona ava-keikei reḡedia e daemu;  
\q2 hosi bona kariota e heau lalo-dikamu.   
\q1
\v 3 Hosi gui taudia e tata laomu,  
\q2 dare e hururu-hururumu, io e kiama-kiamamu;  
\q1 hutuma bada e masemu,  
\q2 mase tau-anidia na e hasenudiamu,  
\q1 mase tau-anidia na asi dokodia,  
\q2 ediai e hetutuhimu.   
\b  
\q1
\v 4 Ini na ariara hahinena ena ariara karadia momo-herea daidiai,  
\q2 mai hairaina bona mai ena mea dikadia,  
\q1 ena ariara karadia amo basileia idau-idau e dibaḡanidiamu,  
\q2 bona ena mea karadia amo bese ulau-idau e hahekwakwanaidiamu.   
\q1
\v 5 Iehova Sabaota na e tomu:  
\q2 A itaia, lau ese na inai henimumu,  
\q2 bona vairamu na ramimu amo baina ḡovaia ahu.  
\q1 Bese idau-idau baina haheitalaidia, oi na gagaemu mo,  
\q2 basileia idau-idau emu hemarai baina haheitalaidia.   
\q1
\v 6 Lau ese miro amo baina hodomu, baina dadaraimu,  
\q2 bona hamue ḡauna ai baina halaomu.   
\q1
\v 7 Bae itamu taudia iboudiai na bae lagagalaimu, baeto,  
\q2 Nineve vada e vahu; daika ese baine tailaia?  
\q2 Ia tauna ihalona taudia na edeseni ai baina tahudia?   
\b  
\q1
\v 8 Oi ese Tebe o hereaia a?  
\q2 Ia na Nilo sinavaina isena ai e daia,  
\q1 ranu ese e ḡeḡea ahuva,  
\q2 ia inaina ilao-ahudia ḡauna na davara,  
\q2 bona ena maḡu na ranu.   
\q1
\v 9 Etiopia na ena goada,  
\q2 bona Aigupto danu, asi hetoana;  
\q2 Put bona Libia taudia ese e kahaia.   
\b  
\q1
\v 10 Ḡau tamona, vada e abia oho,  
\q2 mai iḡuina ida e laohaia;  
\q1 ena memero maraḡidia na e huaridia patapata,  
\q2 ariara iboudiai doridia ai;  
\q1 ena taunimanima namodia, e matauraidia taudia, na  
\q2 mari amo e abidia,  
\q1 bona ena lohia badadia na  
\q2 auri gadeadia amo e ḡuidia.   
\q1
\v 11 Oi danu ba kekero,  
\q2 matamu bae madai-madai;  
\q1 roho-mauri gabuna do ba tahua,  
\q2 inaimu amo ba roho mauri totona.   
\q1
\v 12 Emu kohoro iboudiai na suke audia na heheto,  
\q2 huahuadia e dobi matama negana ai;  
\q1 bema haheude-heudedia,  
\q2 idia na ianidia taudia ududia ai bema moru.   
\q1
\v 13 A itaia, emu tuari oreadia na hahine na heheto,  
\q2 oi bogaragimu ai.  
\q1 Emu tano ikoukoudia na e hekeho vaitani, oi inaimu vairadiai;  
\q2 emu kahitao audia na lahi ese vada e aradia ore.   
\b  
\q1
\v 14 Ranu ba utua, ba hekou ahu negana ranuna,  
\q2 emu maḡu ba ha-aukadia;  
\q1 raro gabuna baola, raro ba kuia,  
\q2 raro mauana bavabia.   
\q1
\v 15 Unuseni ai lahi ese baine hamasemu,  
\q2 dare ese baine gwadamu mase,  
\q2 baine animu ore kwadi na heto.  
\b  
\q1 Ba hutuma, kwadi na heto;  
\q2 ba hutuma, rei kwadidla na heheto.   
\q1
\v 16 Emu hoihoi taudia o hahohodia,  
\q2 idia ese guba hisiudia e hereadia;  
\q1 kwadi ese hanina e toi roromu,  
\q2 e roho laomu.   
\q1
\v 17 Emu hanua lohiadia na rei kwadidia na heheto,  
\q2 emu toretore taudia na kwadi tabatabadia na heheto;  
\q1 era ai e helaimu,  
\q2 keru dinana ai,  
\q1 a dina e daemu negana ai e roho laomu,  
\q2 tau ta asi dibana idia na edeseni ai.   
\b  
\q1
\v 18 Asuria pavapavana e,  
\q2 emu mamoe ireḡudia taudia na e mahutamu,  
\q2 emu lohia taudia na e mahuta hedavauhemu,  
\q1 emu taunimanima na ororo ai e karoho rohorohomu,  
\q2 asi ihaheboudia tauna ta.   
\q1
\v 19 Emu hisihisi na asi ihanamona dalana,  
\q2 beromu na dika herea;  
\q1 oi harimu e kamonaimu taudia iboudiai ese  
\q2 imadia na e patapata henimumu.  
\q1 Badina be oiemu hahedika karadia asi dokodia be  
\q2 daika ese se mamia toho a?   