\v 35 \w Y|strong="H3068"\w* \w ellos|strong="H1992"\w* en \w su|strong="H1992"\w* \w reino|strong="H4438"\w* y en tu \w mucho|strong="H7227"\w* \w bien|strong="H2898"\w* \w que|strong="H3808"\w* \w les|strong="H1992"\w* \w diste|strong="H5414"\w*, y en la tierra \w espaciosa|strong="H7342"\w* y \w pingüe|strong="H8082"\w* \w que|strong="H3808"\w* \w entregaste|strong="H5414"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w ellos|strong="H1992"\w*, \w no|strong="H3808"\w* te \w sirvieron|strong="H5647"\w*, \w ni|strong="H3808"\w* \w se|strong="H3808"\w* convirtieron \w de|strong="H6440"\w* \w sus|strong="H1992"\w* \w malas|strong="H7451"\w* \w obras|strong="H4611"\w*.
