\p 
\v 56 \w La|strong="H5921"\w* mujer refinada \w y|strong="H5921"\w* delicada \w entre|strong="H5921"\w* ustedes, \w que|strong="H3808"\w* \w nunca|strong="H3808"\w* \w probó|strong="H5254"\w* poner \w la|strong="H5921"\w* planta \w de|strong="H5921"\w* su \w pie|strong="H7272"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w por|strong="H5921"\w* delicadeza \w y|strong="H5921"\w* refinamiento, \w será|strong="H3808"\w* hostil \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* varón \w de|strong="H5921"\w* su \w regazo|strong="H2436"\w*, su \w hijo|strong="H1121"\w*, su \w hija|strong="H1323"\w*,
\v 57 \w su|strong="H3588"\w* placenta \w que|strong="H3588"\w* \w sale|strong="H3318"\w* \w de|strong="H3588"\w* \w entre|strong="H3588"\w* sus piernas \w y|strong="H3588"\w* sus \w hijos|strong="H1121"\w* \w que|strong="H3588"\w* \w dé|strong="H3588"\w* \w a|strong="H3068"\w* luz. \w Pues|strong="H3588"\w* se \w los|strong="H1121"\w* comerá \w a|strong="H3068"\w* escondidas \w por|strong="H3588"\w* \w la|strong="H3588"\w* carencia \w de|strong="H3588"\w* \w todo|strong="H3605"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* asedio \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* angustia \w con|strong="H3588"\w* \w la|strong="H3588"\w* \w cual|strong="H3588"\w* \w te|strong="H3588"\w* oprimirá tu enemigo \w en|strong="H3588"\w* tus \w ciudades|strong="H8179"\w*.
\p 
\v 58 \w Si|strong="H3808"\w* \w no|strong="H3808"\w* tienes \w el|strong="H3605"\w* cuidado \w de|strong="H1697"\w* cumplir \w todas|strong="H3605"\w* las \w Palabras|strong="H1697"\w* \w de|strong="H1697"\w* \w esta|strong="H2063"\w* \w Ley|strong="H8451"\w* \w escritas|strong="H3789"\w* en \w este|strong="H2088"\w* rollo, para temer \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w Nombre|strong="H8034"\w* \w glorioso|strong="H3513"\w* y temible, \nd \w Yavé|strong="H3068"\w*\nd* \w tu|strong="H6213"\w* \nd ʼElohim\nd*,
\v 59 entonces \nd \w Yavé|strong="H3068"\w*\nd* aumentará \w de|strong="H7451"\w* manera asombrosa tus \w enfermedades|strong="H2483"\w* y las \w de|strong="H7451"\w* tus descendientes, \w enfermedades|strong="H2483"\w* severas y duraderas, y perniciosas y crónicas.
\v 60 Traerá sobre ti \w todas|strong="H3605"\w* las enfermedades \w de|strong="H6440"\w* \w Egipto|strong="H4714"\w* \w de|strong="H6440"\w* las cuales \w temiste|strong="H3025"\w*, y se pegarán \w a|strong="H3068"\w* ti.
\v 61 \nd \w Yavé|strong="H3068"\w*\nd* \w también|strong="H1571"\w* traerá \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w toda|strong="H3605"\w* \w enfermedad|strong="H2483"\w* \w y|strong="H1571"\w* \w todo|strong="H3605"\w* azote \w que|strong="H3808"\w* \w no|strong="H3808"\w* están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w esta|strong="H2063"\w* \w Ley|strong="H8451"\w* \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* seas destruido.
\p 
\v 62 \w Así|strong="H3588"\w*, \w después|strong="H1961"\w* \w de|strong="H3588"\w* ser tan \w numeroso|strong="H7230"\w* \w como|strong="H3588"\w* las \w estrellas|strong="H3556"\w* del \w cielo|strong="H8064"\w*, quedarán \w pocos|strong="H4592"\w* \w en|strong="H3588"\w* número \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w no|strong="H3808"\w* \w obedeciste|strong="H8085"\w* \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*.
\p 
\v 63 \w Sucederá|strong="H1961"\w* \w que|strong="H5921"\w* \w así|strong="H3651"\w* \w como|strong="H1961"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w se|strong="H1961"\w* gozó \w en|strong="H5921"\w* ustedes \w para|strong="H5921"\w* hacerles \w bien|strong="H3190"\w* \w y|strong="H5921"\w* multiplicarlos, \w así|strong="H3651"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w se|strong="H1961"\w* gozará \w en|strong="H5921"\w* ustedes \w para|strong="H5921"\w* arruinarlos \w y|strong="H5921"\w* \w destruirlos|strong="H8045"\w*. \w Serán|strong="H1961"\w* arrancados \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w a|strong="H3068"\w* \w la|strong="H5921"\w* cual entran \w para|strong="H5921"\w* tomarla \w como|strong="H1961"\w* posesión.
\p 
\v 64 Entonces \nd \w Yavé|strong="H3068"\w*\nd* te dispersará \w por|strong="H5704"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w*, \w desde|strong="H5704"\w* un \w extremo|strong="H7097"\w* \w de|strong="H5704"\w* \w la|strong="H3605"\w* tierra \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w otro|strong="H7097"\w*, \w y|strong="H5704"\w* \w allí|strong="H8033"\w* \w servirás|strong="H5647"\w* \w a|strong="H3068"\w* otros \tl ʼelohim\tl* \w que|strong="H3808"\w* \w ni|strong="H3808"\w* tú \w ni|strong="H3808"\w* tus antepasados \w conocieron|strong="H3045"\w*: \w al|strong="H5704"\w* \w palo|strong="H6086"\w* \w y|strong="H5704"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* piedra.
\v 65 \w Entre|strong="H3808"\w* \w aquellas|strong="H1992"\w* \w naciones|strong="H1471"\w* \w no|strong="H3808"\w* hallarás \w reposo|strong="H4494"\w* \w ni|strong="H3808"\w* \w habrá|strong="H1961"\w* \w descanso|strong="H4494"\w* \w para|strong="H5414"\w* la planta \w de|strong="H5414"\w* tu \w pie|strong="H7272"\w*, \w pues|strong="H1961"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w te|strong="H5869"\w* \w dará|strong="H5414"\w* \w allí|strong="H8033"\w* un \w corazón|strong="H3820"\w* tembloroso, desfallecimiento \w de|strong="H5414"\w* \w ojos|strong="H5869"\w* y angustia \w de|strong="H5414"\w* \w alma|strong="H5315"\w*.
\p 
\v 66 \w Tendrás|strong="H1961"\w* tu \w vida|strong="H2416"\w* \w como|strong="H1961"\w* algo \w que|strong="H3808"\w* pende \w delante|strong="H5048"\w* \w de|strong="H5048"\w* ti. \w Estarás|strong="H1961"\w* temeroso \w de|strong="H5048"\w* \w noche|strong="H3915"\w* y \w de|strong="H5048"\w* \w día|strong="H3119"\w*, y \w no|strong="H3808"\w* \w tendrás|strong="H1961"\w* seguridad \w de|strong="H5048"\w* tu \w vida|strong="H2416"\w*.
\p 
\v 67 \w Por|strong="H5414"\w* la \w mañana|strong="H1242"\w* dirás: ¡\w Quién|strong="H4310"\w* \w me|strong="H4310"\w* \w diera|strong="H5414"\w* \w que|strong="H4310"\w* fuera la noche! \w Y|strong="H3068"\w* en la noche dirás: ¡\w Quién|strong="H4310"\w* \w me|strong="H4310"\w* \w diera|strong="H5414"\w* \w que|strong="H4310"\w* fuera la \w mañana|strong="H1242"\w*! Esto sucederá \w por|strong="H5414"\w* \w el|strong="H4310"\w* \w terror|strong="H6343"\w* con \w el|strong="H4310"\w* \w cual|strong="H4310"\w* serás atemorizado, y \w por|strong="H5414"\w* \w el|strong="H4310"\w* espectáculo \w que|strong="H4310"\w* \w verán|strong="H7200"\w* tus \w ojos|strong="H5869"\w*.
\p 
\v 68 \nd \w Yavé|strong="H3068"\w*\nd* te hará regresar \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w* \w en|strong="H5750"\w* naves \w por|strong="H1870"\w* el \w camino|strong="H1870"\w* del cual yo te dije: \w Nunca|strong="H3808"\w* \w más|strong="H5750"\w* \w volverás|strong="H7725"\w*. \w Allí|strong="H8033"\w* serán ofrecidos \w en|strong="H5750"\w* venta \w a|strong="H3068"\w* sus enemigos \w como|strong="H5750"\w* esclavos y esclavas, y \w no|strong="H3808"\w* habrá quien los compre.
\c 29
\s1 Bondad y justicia de Yavé
\p 
\v 1 \w Estas|strong="H6213"\w* son las Palabras del Pacto \w que|strong="H3605"\w* \nd \w Yavé|strong="H3068"\w*\nd* mandó \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w que|strong="H3605"\w* celebrara con \w los|strong="H3605"\w* hijos \w de|strong="H5869"\w* \w Israel|strong="H3478"\w* en \w la|strong="H3605"\w* tierra \w de|strong="H5869"\w* Moab, además del Pacto \w que|strong="H3605"\w* estableció con \w ellos|strong="H3605"\w* en Horeb.
\p 
\v 2 Moisés convocó \w a|strong="H3068"\w* todo Israel y \w les|strong="H1992"\w* dijo: Ustedes \w vieron|strong="H7200"\w* todo \w lo|strong="H1992"\w* \w que|strong="H1992"\w* \nd \w Yavé|strong="H3068"\w*\nd* hizo ante \w sus|strong="H1992"\w* \w ojos|strong="H5869"\w* en la tierra \w de|strong="H5869"\w* Egipto, \w a|strong="H3068"\w* Faraón, \w a|strong="H3068"\w* todos \w sus|strong="H1992"\w* esclavos y \w a|strong="H3068"\w* toda \w su|strong="H1992"\w* tierra,
\v 3 las grandes pruebas \w que|strong="H3808"\w* \w vieron|strong="H7200"\w* sus \w ojos|strong="H5869"\w*, las señales \w y|strong="H5704"\w* los grandes prodigios.
\v 4 Pero \w hasta|strong="H5921"\w* hoy \nd \w Yavé|strong="H3068"\w*\nd* \w no|strong="H3808"\w* \w les|strong="H5921"\w* dio corazón \w para|strong="H5921"\w* entender, \w ni|strong="H3808"\w* ojos \w para|strong="H5921"\w* mirar, \w ni|strong="H3808"\w* oídos \w para|strong="H5921"\w* escuchar.
\v 5 \w Yo|strong="H3588"\w* \w los|strong="H3588"\w* conduje \w por|strong="H3588"\w* \w el|strong="H3588"\w* desierto 40 años. Sus ropas \w no|strong="H3808"\w* \w se|strong="H3045"\w* desgastaron sobre ustedes, \w y|strong="H3588"\w* \w su|strong="H3588"\w* sandalia \w no|strong="H3808"\w* \w se|strong="H3045"\w* desgastó \w en|strong="H3588"\w* \w su|strong="H3588"\w* pie.
\v 6 No comieron pan, ni bebieron vino ni licor, para \w que|strong="H2088"\w* sepan \w que|strong="H2088"\w* Yo soy \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*.
\p 
\v 7 Cuando llegaron \w a|strong="H3068"\w* este lugar, Sehón, rey \w de|strong="H5414"\w* Hesbón, y Og, rey \w de|strong="H5414"\w* Basán, salieron contra nosotros \w para|strong="H5414"\w* luchar, y los derrotamos.
\v 8 Tomamos su tierra y \w la|strong="H8104"\w* dimos como heredad \w a|strong="H3068"\w* Rubén, Gad, y \w la|strong="H8104"\w* media tribu \w de|strong="H1697"\w* Manasés.
\p 
\v 9 Así \w que|strong="H3117"\w* guarden las Palabras \w de|strong="H6440"\w* este Pacto y practíquenlas para \w que|strong="H3117"\w* prosperen en \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3117"\w* hagan.
\v 10 Hoy todos ustedes están \w delante|strong="H5704"\w* \w de|strong="H5704"\w* \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*: los jefes \w de|strong="H5704"\w* sus tribus, ancianos, oficiales \w y|strong="H5704"\w* todos los hombres \w de|strong="H5704"\w* Israel,
\v 11 sus pequeños y esposas, y \w el|strong="H5973"\w* extranjero \w que|strong="H3117"\w* está dentro \w de|strong="H5973"\w* su campamento, desde \w el|strong="H5973"\w* leñador \w hasta|strong="H3117"\w* \w el|strong="H5973"\w* aguador,
\v 12 \w para|strong="H4616"\w* \w que|strong="H1931"\w* entres en \w el|strong="H1931"\w* Pacto con \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, y en \w su|strong="H1931"\w* juramento \w que|strong="H1931"\w* \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd* hace \w hoy|strong="H3117"\w* \w contigo|strong="H5971"\w*,
\v 13 para confirmarte hoy como pueblo suyo, y \w que|strong="H3808"\w* Él sea tu \nd ʼElohim\nd* \w tal|strong="H2063"\w* como te habló \w a|strong="H3068"\w* ti y como juró \w a|strong="H3068"\w* tus antepasados: Abraham, Isaac y Jacob.
\p 
\v 14 \w No|strong="H3588"\w* solo \w con|strong="H5973"\w* ustedes hago \w este|strong="H5975"\w* Pacto \w y|strong="H3588"\w* \w este|strong="H5975"\w* juramento.
\v 15 \w Ciertamente|strong="H3588"\w* lo hago \w con|strong="H3588"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w están|strong="H3427"\w* aquí \w con|strong="H3588"\w* nosotros hoy \w en|strong="H3588"\w* presencia \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* nuestro \nd ʼElohim\nd* \w y|strong="H3588"\w* también \w con|strong="H3588"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* \w están|strong="H3427"\w* aquí \w con|strong="H3588"\w* nosotros hoy.
\p 
\v 16 Porque ustedes saben \w cómo|strong="H5973"\w* estuvimos \w en|strong="H5973"\w* la tierra \w de|strong="H5973"\w* Egipto, \w cómo|strong="H5973"\w* pasamos \w en|strong="H5973"\w* medio \w de|strong="H5973"\w* las naciones por las cuales pasaron,
\v 17 y vieron \w sus|strong="H1992"\w* repugnancias y \w sus|strong="H1992"\w* ídolos \w de|strong="H5973"\w* palo, piedra, plata y oro \w que|strong="H6435"\w* \w tienen|strong="H1992"\w* \w consigo|strong="H5973"\w*.
\p 
\v 18 \w No|strong="H3588"\w* \w sea|strong="H1961"\w* \w que|strong="H3588"\w* \w esté|strong="H2063"\w* \w entre|strong="H3588"\w* ustedes un hombre \w o|strong="H3068"\w* una mujer, una familia \w o|strong="H3068"\w* tribu, cuyo \w corazón|strong="H3820"\w* \w se|strong="H1961"\w* aparte hoy \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* nuestro \nd ʼElohim\nd* \w para|strong="H4616"\w* \w ir|strong="H3212"\w* \w a|strong="H3068"\w* servir \w a|strong="H3068"\w* \w los|strong="H1961"\w* \tl ʼelohim\tl* \w de|strong="H3588"\w* esas naciones.
\p \w No|strong="H3588"\w* \w sea|strong="H1961"\w* \w que|strong="H3588"\w* \w esté|strong="H2063"\w* \w entre|strong="H3588"\w* ustedes una raíz \w que|strong="H3588"\w* produzca hiel \w y|strong="H3588"\w* ajenjo,
\v 19 \w y|strong="H3588"\w* suceda \w que|strong="H3588"\w* \w al|strong="H8478"\w* oír las palabras \w de|strong="H3588"\w* \w esta|strong="H2088"\w* imprecación, \w se|strong="H1931"\w* congratule \w en|strong="H3588"\w* \w su|strong="H1931"\w* corazón \w y|strong="H3588"\w* diga: Tendré paz, \w aunque|strong="H3588"\w* ande \w en|strong="H3588"\w* \w la|strong="H1931"\w* obstinación \w de|strong="H3588"\w* mi corazón, \w para|strong="H3588"\w* destruir \w lo|strong="H1931"\w* regado \w con|strong="H3588"\w* \w lo|strong="H1931"\w* seco.
\p 
\v 20 \nd \w Yavé|strong="H3068"\w*\nd* no \w estará|strong="H3605"\w* dispuesto \w a|strong="H3068"\w* perdonarlo, sino \w la|strong="H3605"\w* ira \w de|strong="H7451"\w* \nd \w Yavé|strong="H3068"\w*\nd* y su celo arderán \w contra|strong="H3478"\w* \w aquel|strong="H2088"\w* hombre. \w Todas|strong="H3605"\w* las maldiciones \w escritas|strong="H3789"\w* en \w este|strong="H2088"\w* rollo caerán sobre \w él|strong="H3605"\w*, y \nd \w Yavé|strong="H3068"\w*\nd* borrará su nombre \w de|strong="H7451"\w* debajo del cielo.
\v 21 \nd \w Yavé|strong="H3068"\w*\nd* \w lo|strong="H1931"\w* apartará para mal \w de|strong="H1121"\w* entre \w todas|strong="H1755"\w* las tribus \w de|strong="H1121"\w* Israel \w conforme|strong="H1931"\w* \w a|strong="H3068"\w* \w todas|strong="H1755"\w* las maldiciones del Pacto escrito en \w el|strong="H1931"\w* rollo \w de|strong="H1121"\w* \w esta|strong="H1931"\w* Ley.
\p 
\v 22 De manera \w que|strong="H3808"\w* cuando \w la|strong="H3605"\w* generación venidera de sus hijos \w que|strong="H3808"\w* \w se|strong="H3808"\w* levanten después de ustedes y \w los|strong="H3605"\w* extranjeros \w que|strong="H3808"\w* lleguen de tierras lejanas, al ver las plagas de esa tierra y las enfermedades con las cuales \w la|strong="H3605"\w* aflija \nd \w Yavé|strong="H3068"\w*\nd*, digan:
\v 23 ¡\w Toda|strong="H3605"\w* su tierra \w está|strong="H2063"\w* quemada \w con|strong="H5921"\w* azufre \w y|strong="H5921"\w* sal! ¡\w No|strong="H6213"\w* hay siembra ni germinación! ¡\w El|strong="H5921"\w* pasto \w no|strong="H6213"\w* crece \w en|strong="H5921"\w* \w ella|strong="H3605"\w*, \w como|strong="H4100"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* destrucción \w de|strong="H5921"\w* Sodoma \w y|strong="H5921"\w* Gomorra, \w de|strong="H5921"\w* Adma \w y|strong="H5921"\w* \w de|strong="H5921"\w* Zeboim, \w que|strong="H4100"\w* \nd \w Yavé|strong="H3068"\w*\nd* destruyó \w en|strong="H5921"\w* su ira \w y|strong="H5921"\w* \w en|strong="H5921"\w* su \w furor|strong="H2750"\w*!
\v 24 Todas \w las|strong="H5921"\w* naciones dirán: ¿\w Por|strong="H5921"\w* \w qué|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* trató \w así|strong="H5973"\w* \w a|strong="H3068"\w* \w esta|strong="H5921"\w* tierra? ¿\w Qué|strong="H5921"\w* significa \w el|strong="H5921"\w* ardor \w de|strong="H5921"\w* \w esta|strong="H5921"\w* enorme \w ira|strong="H3318"\w*?
\p 
\v 25 \w Se|strong="H3045"\w* les responderá: \w Porque|strong="H3808"\w* abandonaron el Pacto de \nd \w Yavé|strong="H3068"\w*\nd*, el \nd ʼElohim\nd* de sus antepasados, \w que|strong="H3808"\w* Él hizo con ellos cuando los sacó de la tierra de Egipto,
\v 26 fueron \w y|strong="H5921"\w* sirvieron \w a|strong="H3068"\w* otros \tl ʼelohim\tl* \w y|strong="H5921"\w* \w se|strong="H1931"\w* inclinaron ante \w ellos|strong="H1931"\w*, \tl ʼelohim\tl* \w que|strong="H1931"\w* \w no|strong="H5921"\w* conocieron, \w los|strong="H5921"\w* cuales \w Él|strong="H1931"\w* \w no|strong="H5921"\w* \w les|strong="H5921"\w* asignó.
\v 27 \w Por|strong="H5921"\w* eso \w la|strong="H5921"\w* \w ira|strong="H2534"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* ardió \w contra|strong="H5921"\w* \w esta|strong="H2088"\w* tierra \w para|strong="H5921"\w* traer \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w* todas \w las|strong="H5921"\w* maldiciones escritas \w en|strong="H5921"\w* \w este|strong="H2088"\w* rollo,
\v 28 \w y|strong="H5704"\w* \w con|strong="H5704"\w* ira, furor \w y|strong="H5704"\w* gran indignación, \nd \w Yavé|strong="H3068"\w*\nd* \w los|strong="H1121"\w* desarraigó \w de|strong="H5704"\w* su propia tierra \w y|strong="H5704"\w* \w los|strong="H1121"\w* echó \w en|strong="H5704"\w* \w otra|strong="H6213"\w* tierra, \w como|strong="H5704"\w* se ve hoy.
\p 
\v 29 Las cosas secretas pertenecen \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* nuestro \nd ʼElohim\nd*, pero las reveladas son para nosotros y nuestros hijos para siempre, \w a|strong="H3068"\w* fin de que cumplamos todas las palabras de esta Ley.
\c 30
\s1 Bendición y restauración
\p 
\v 1 \w Sucederá|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* lleguen \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w* \w todas|strong="H3605"\w* estas \w cosas|strong="H1697"\w*, \w la|strong="H5921"\w* \w bendición|strong="H1293"\w* \w y|strong="H3588"\w* \w la|strong="H5921"\w* \w maldición|strong="H7045"\w* \w que|strong="H3588"\w* acabo \w de|strong="H5921"\w* \w presentar|strong="H7725"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*, \w y|strong="H3588"\w* tú cambies \w de|strong="H5921"\w* mente \w en|strong="H5921"\w* medio \w de|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* adonde \w te|strong="H5921"\w* esparza \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*,
