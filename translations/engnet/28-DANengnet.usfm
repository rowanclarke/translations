\v 8 \w Now|strong="H4430"\w* let \w the|strong="H3606"\w* \w king|strong="H4430"\w* \w issue|strong="H6966"\w* \w a|strong="H3068"\w* written interdict \w so|strong="H1768"\w* \w that|strong="H1768"\w* \w it|strong="H4481"\w* cannot be altered, \w according|strong="H4481"\w* \w to|strong="H5705"\w* \w the|strong="H3606"\w* law \w of|strong="H4481"\w* \w the|strong="H3606"\w* Medes \w and|strong="H4430"\w* Persians, \w which|strong="H1768"\w* cannot be changed.
\v 9 \w So|strong="H1768"\w* \w King|strong="H4430"\w* Darius \w issued|strong="H7560"\w* \w the|strong="H1768"\w* \w written|strong="H7560"\w* interdict.
\p 
\v 10 When Daniel realized \w that|strong="H3606"\w* \w a|strong="H3068"\w* \w written|strong="H7560"\w* decree \w had|strong="H4430"\w* been \w issued|strong="H7560"\w*, \w he|strong="H6903"\w* entered \w his|strong="H3606"\w* home, where \w the|strong="H3606"\w* windows \w in|strong="H4430"\w* \w his|strong="H3606"\w* upper room opened toward Jerusalem. Three times daily \w he|strong="H6903"\w* \w was|strong="H4430"\w* kneeling \w and|strong="H4430"\w* offering prayers \w and|strong="H4430"\w* thanks \w to|strong="H4430"\w* \w his|strong="H3606"\w* God \w just|strong="H6903"\w* \w as|strong="H3606"\w* \w he|strong="H6903"\w* \w had|strong="H4430"\w* been accustomed \w to|strong="H4430"\w* do previously.
\v 11 \w Then|strong="H1768"\w* \w those|strong="H1768"\w* officials \w who|strong="H1768"\w* \w had|strong="H1768"\w* gone \w to|strong="H5922"\w* \w the|strong="H3606"\w* king \w came|strong="H5954"\w* \w by|strong="H3118"\w* collusion \w and|strong="H1005"\w* found \w Daniel|strong="H1841"\w* \w praying|strong="H6739"\w* \w and|strong="H1005"\w* asking \w for|strong="H5922"\w* help \w before|strong="H6925"\w* \w his|strong="H5922"\w* God.
