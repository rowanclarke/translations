\v 34 \w Porque|strong="H3588"\w*, \w vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w* ʼElohim\nd* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*, \w que|strong="H3588"\w* \w me|strong="H3588"\w* detuvo \w de|strong="H3588"\w* hacerte \w mal|strong="H7489"\w* \w a|strong="H3068"\w* ti, \w porque|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3884"\w* \w te|strong="H3588"\w* hubieras apresurado \w a|strong="H3068"\w* venir \w a|strong="H3068"\w* encontrarte conmigo, \w a|strong="H3068"\w* \w la|strong="H3588"\w* luz del alba \w no|strong="H3884"\w* \w le|strong="H1242"\w* iba \w a|strong="H3068"\w* \w quedar|strong="H3498"\w* \w a|strong="H3068"\w* \w Nabal|strong="H5037"\w* \w ni|strong="H5704"\w* un \w meante|strong="H8366"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w pared|strong="H7023"\w*.
\p 
\v 35 \w David|strong="H1732"\w* \w recibió|strong="H3947"\w* \w de|strong="H6440"\w* \w mano|strong="H3027"\w* \w de|strong="H6440"\w* ella lo \w que|strong="H3027"\w* le \w llevó|strong="H3947"\w* y le dijo: \w Sube|strong="H5927"\w* \w a|strong="H3068"\w* tu \w casa|strong="H1004"\w* en \w paz|strong="H7965"\w*. \w Ciertamente|strong="H8085"\w* atendí tu \w voz|strong="H6963"\w* y acepté tu petición.
\p 
\v 36 Abigail volvió \w a|strong="H3068"\w* \w Nabal|strong="H5037"\w*, \w y|strong="H5921"\w* miró \w que|strong="H1931"\w* celebraba un \w banquete|strong="H4960"\w* \w en|strong="H5921"\w* \w su|strong="H1931"\w* \w casa|strong="H1004"\w*, \w como|strong="H5921"\w* \w el|strong="H1931"\w* \w banquete|strong="H4960"\w* \w de|strong="H5921"\w* un \w rey|strong="H4428"\w*. \w El|strong="H1931"\w* \w corazón|strong="H3820"\w* \w de|strong="H5921"\w* \w Nabal|strong="H5037"\w* \w estaba|strong="H2009"\w* \w alegre|strong="H2896"\w* \w y|strong="H5921"\w* \w estaba|strong="H2009"\w* \w muy|strong="H3966"\w* borracho, \w por|strong="H5921"\w* \w lo|strong="H1931"\w* \w cual|strong="H1931"\w* \w ella|strong="H1931"\w* \w no|strong="H3808"\w* \w le|strong="H1931"\w* informó, \w ni|strong="H3808"\w* poco \w ni|strong="H3808"\w* \w mucho|strong="H3966"\w*, \w hasta|strong="H5704"\w* \w que|strong="H1931"\w* amaneció.
\v 37 \w Aconteció|strong="H1961"\w* \w que|strong="H1931"\w* \w por|strong="H1697"\w* \w la|strong="H1931"\w* \w mañana|strong="H1242"\w*, \w cuando|strong="H1961"\w* \w el|strong="H1931"\w* efecto del \w vino|strong="H3196"\w* \w había|strong="H1961"\w* pasado \w de|strong="H1697"\w* \w Nabal|strong="H5037"\w*, \w su|strong="H1931"\w* esposa \w le|strong="H1931"\w* informó estas \w cosas|strong="H1697"\w*. \w Su|strong="H1931"\w* \w corazón|strong="H3820"\w* desmayó \w en|strong="H3318"\w* \w él|strong="H1931"\w* y \w se|strong="H1961"\w* \w quedó|strong="H1961"\w* \w como|strong="H1961"\w* una piedra.
\v 38 \w Cuando|strong="H3117"\w* pasaron \w como|strong="H1961"\w* \w diez|strong="H6235"\w* \w días|strong="H3117"\w*, \nd \w Yavé|strong="H3068"\w*\nd* \w hirió|strong="H5062"\w* \w a|strong="H3068"\w* \w Nabal|strong="H5037"\w*, y \w éste|strong="H1961"\w* \w murió|strong="H4191"\w*.
\p 
\v 39 \w Cuando|strong="H3588"\w* \w David|strong="H1732"\w* \w oyó|strong="H8085"\w* \w que|strong="H3588"\w* \w Nabal|strong="H5037"\w* \w murió|strong="H4191"\w*, \w dijo|strong="H1696"\w*: ¡\w Bendito|strong="H1288"\w* sea \nd \w Yavé|strong="H3068"\w*\nd*, Quien \w juzgó|strong="H7379"\w* \w la|strong="H3588"\w* \w causa|strong="H7379"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w afrenta|strong="H2781"\w* \w que|strong="H3588"\w* \w Nabal|strong="H5037"\w* \w me|strong="H3588"\w* hizo, \w y|strong="H3588"\w* preservó del \w mal|strong="H7451"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* esclavo! \nd \w Yavé|strong="H3068"\w*\nd* devolvió \w así|strong="H3588"\w* \w la|strong="H3588"\w* \w maldad|strong="H7451"\w* \w de|strong="H3588"\w* \w Nabal|strong="H5037"\w* sobre \w su|strong="H3588"\w* propia \w cabeza|strong="H7218"\w*.
\p \w Y|strong="H3068"\w* \w David|strong="H1732"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w hablar|strong="H1696"\w* \w con|strong="H3588"\w* Abigail \w para|strong="H3588"\w* \w tomarla|strong="H3947"\w* \w como|strong="H3588"\w* esposa.
\v 40 \w Cuando|strong="H5650"\w* los esclavos de \w David|strong="H1732"\w* \w fueron|strong="H1732"\w* \w a|strong="H3068"\w* Abigail en la montaña Carmelo, le \w dijeron|strong="H1696"\w*: \w David|strong="H1732"\w* nos \w envió|strong="H7971"\w* \w a|strong="H3068"\w* ti, \w porque|strong="H1732"\w* quiere tomarte como esposa.
\p 
\v 41 Ella se \w levantó|strong="H6965"\w*, se postró rostro en tierra y dijo: \w Aquí|strong="H2009"\w* \w está|strong="H6965"\w* tu esclava, para ser la esclava que lave los \w pies|strong="H7272"\w* de los esclavos de \w mi|strong="H2009"\w* \tl ʼadón\tl*.
\v 42 Luego Abigail \w se|strong="H1961"\w* \w levantó|strong="H6965"\w* rápidamente \w y|strong="H5921"\w* montó \w en|strong="H5921"\w* un \w asno|strong="H2543"\w*, \w y|strong="H5921"\w* llevó \w cinco|strong="H2568"\w* \w doncellas|strong="H5291"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* atendían. \w Siguió|strong="H3212"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w mensajeros|strong="H4397"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w y|strong="H5921"\w* \w fue|strong="H1961"\w* su esposa.
\v 43 \w David|strong="H1732"\w* \w tomó|strong="H3947"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* Ahinoam de \w Jezreel|strong="H3157"\w*, \w y|strong="H1571"\w* las \w dos|strong="H8147"\w* \w fueron|strong="H1961"\w* esposas suyas.
\v 44 \w Por|strong="H5414"\w* su parte, \w Saúl|strong="H7586"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* su \w hija|strong="H1323"\w* Mical, esposa \w de|strong="H1121"\w* \w David|strong="H1732"\w*, \w a|strong="H3068"\w* \w Palti|strong="H6406"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Lais|strong="H3919"\w*, natural \w de|strong="H1121"\w* Galim.
\c 26
\s1 En el campamento de Zif
\p 
\v 1 \w Los|strong="H5921"\w* zifeos llegaron \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* \w en|strong="H5921"\w* \w Gabaa|strong="H1390"\w* \w y|strong="H5921"\w* dijeron: ¿\w No|strong="H3808"\w* \w está|strong="H5921"\w* \w David|strong="H1732"\w* \w escondido|strong="H5641"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* colina \w de|strong="H5921"\w* Haquila frente \w a|strong="H3068"\w* Jesimón?
\p 
\v 2 Entonces \w Saúl|strong="H7586"\w* se \w levantó|strong="H6965"\w*, bajó \w a|strong="H3068"\w* la región despoblada de Zif y llevó consigo \w a|strong="H3068"\w* 3.000 hombres escogidos de \w Israel|strong="H3478"\w* para buscar \w a|strong="H3068"\w* \w David|strong="H1732"\w* en la región despoblada de Zif.
\v 3 \w Saúl|strong="H7586"\w* acampó \w en|strong="H5921"\w* \w la|strong="H5921"\w* colina \w de|strong="H5921"\w* Haquila, \w la|strong="H5921"\w* \w cual|strong="H3588"\w* \w está|strong="H3427"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w camino|strong="H1870"\w* frente \w a|strong="H3068"\w* Jesimón. \w David|strong="H1732"\w* \w estaba|strong="H3427"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* región despoblada \w cuando|strong="H3588"\w* entendió \w que|strong="H3588"\w* \w Saúl|strong="H7586"\w* salió \w a|strong="H3068"\w* perseguirlo \w en|strong="H5921"\w* \w la|strong="H5921"\w* región despoblada.
\v 4 \w Envió|strong="H7971"\w* \w espías|strong="H7270"\w* \w y|strong="H3588"\w* \w supo|strong="H3045"\w* \w con|strong="H3588"\w* certeza \w que|strong="H3588"\w* \w Saúl|strong="H7586"\w* llegó.
