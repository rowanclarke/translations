\p
\v 1  \w Now|strong="H3847"\w* \w when|strong="H3318"\w* \w Mordecai|strong="H4782"\w* \w became|strong="H3318"\w* \w aware|strong="H3045"\w* \w of|strong="H5892"\w* \w all|strong="H3605"\w* \w that|strong="H3045"\w* \w had|strong="H4782"\w* \w been|strong="H3605"\w* \w done|strong="H6213"\w*, \w he|strong="H6213"\w* \w tore|strong="H7167"\w* \w his|strong="H3605"\w* garments \w and|strong="H1419"\w* \w put|strong="H3847"\w* \w on|strong="H3847"\w* \w sackcloth|strong="H8242"\w* \w and|strong="H1419"\w* ashes. \w He|strong="H6213"\w* \w went|strong="H3318"\w* \w out|strong="H3318"\w* \w into|strong="H8432"\w* \w the|strong="H3605"\w* \w city|strong="H5892"\w*, \w crying|strong="H2199"\w* \w out|strong="H3318"\w* \w in|strong="H6213"\w* \w a|strong="H3068"\w* \w loud|strong="H1419"\w* \w and|strong="H1419"\w* \w bitter|strong="H4751"\w* \w voice|strong="H2201"\w*.  
\v 2  \w But|strong="H3588"\w* \w he|strong="H3588"\w* \w went|strong="H4428"\w* \w no|strong="H6440"\w* further \w than|strong="H3588"\w* \w the|strong="H6440"\w* \w king|strong="H4428"\w*’s \w gate|strong="H8179"\w*, \w for|strong="H3588"\w* \w no|strong="H6440"\w* \w one|strong="H3588"\w* \w was|strong="H4428"\w* permitted \w to|strong="H5704"\w* enter \w the|strong="H6440"\w* \w king|strong="H4428"\w*’s \w gate|strong="H8179"\w* \w clothed|strong="H3830"\w* \w in|strong="H4428"\w* \w sackcloth|strong="H8242"\w*.  
\v 3  \w Throughout|strong="H3605"\w* \w each|strong="H3605"\w* \w and|strong="H4428"\w* \w every|strong="H3605"\w* \w province|strong="H4082"\w* \w where|strong="H4725"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w*’s \w edict|strong="H1697"\w* \w and|strong="H4428"\w* \w law|strong="H1881"\w* \w were|strong="H1697"\w* announced \w there|strong="H3605"\w* \w was|strong="H1697"\w* \w considerable|strong="H1419"\w* \w mourning|strong="H4553"\w* \w among|strong="H7227"\w* \w the|strong="H3605"\w* \w Jews|strong="H3064"\w*, along \w with|strong="H1697"\w* \w fasting|strong="H6685"\w*, \w weeping|strong="H1065"\w*, \w and|strong="H4428"\w* \w sorrow|strong="H4553"\w*. \w Sackcloth|strong="H8242"\w* \w and|strong="H4428"\w* ashes \w were|strong="H1697"\w* characteristic \w of|strong="H4428"\w* \w many|strong="H7227"\w*.  
\v 4  \w When|strong="H7971"\w* Esther’s \w female|strong="H5291"\w* attendants \w and|strong="H7971"\w* \w her|strong="H7971"\w* \w eunuchs|strong="H5631"\w* \w came|strong="H3847"\w* \w and|strong="H7971"\w* \w informed|strong="H5046"\w* \w her|strong="H7971"\w* \w about|strong="H5921"\w* \w Mordecai|strong="H4782"\w*’s behavior, \w the|strong="H5921"\w* \w queen|strong="H4436"\w* \w was|strong="H5291"\w* overcome \w with|strong="H3847"\w* \w anguish|strong="H2342"\w*. \w Although|strong="H3808"\w* \w she|strong="H5921"\w* \w sent|strong="H7971"\w* garments \w for|strong="H5921"\w* \w Mordecai|strong="H4782"\w* \w to|strong="H7971"\w* \w put|strong="H3847"\w* \w on|strong="H5921"\w* \w so|strong="H7971"\w* \w that|strong="H3808"\w* \w he|strong="H3808"\w* could \w remove|strong="H5493"\w* \w his|strong="H7971"\w* \w sackcloth|strong="H8242"\w*, \w he|strong="H3808"\w* \w would|strong="H5291"\w* \w not|strong="H3808"\w* \w accept|strong="H6901"\w* \w them|strong="H5921"\w*.  
\v 5  \w So|strong="H7121"\w* Esther \w called|strong="H7121"\w* \w for|strong="H5921"\w* \w Hathach|strong="H2047"\w*, \w one|strong="H2088"\w* \w of|strong="H4428"\w* \w the|strong="H6440"\w* \w king|strong="H4428"\w*’s \w eunuchs|strong="H5631"\w* \w who|strong="H4428"\w* \w had|strong="H4428"\w* been \w placed|strong="H5975"\w* \w at|strong="H5921"\w* \w her|strong="H5921"\w* \w service|strong="H5975"\w*, \w and|strong="H4428"\w* \w instructed|strong="H6680"\w* \w him|strong="H6440"\w* \w to|strong="H5921"\w* \w find|strong="H3045"\w* \w out|strong="H5921"\w* \w the|strong="H6440"\w* \w cause|strong="H7121"\w* \w and|strong="H4428"\w* \w reason|strong="H6440"\w* \w for|strong="H5921"\w* \w Mordecai|strong="H4782"\w*’s behavior.  
