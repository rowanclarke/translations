\v 10 Car \w on|strong="H3808"\w* \w voit|strong="H7200"\w* \w que|strong="H7200"\w* \w les|strong="H7200"\w* sages meurent; \w le|strong="H7200"\w* fou \w et|strong="H7200"\w* l'insensé périssent également, \w et|strong="H7200"\w* \w laissent|strong="H3808"\w* \w leurs|strong="H7200"\w* biens \w à|strong="H7200"\w* d'autres.
\v 11 \w Ils|strong="H3162"\w* pensent \w que|strong="H3588"\w* \w leurs|strong="H5800"\w* maisons dureront éternellement, \w et|strong="H7200"\w* \w leurs|strong="H5800"\w* demeures d'âge \w en|strong="H7200"\w* âge; \w ils|strong="H3162"\w* \w ont|strong="H3162"\w* donné \w leurs|strong="H5800"\w* noms \w à|strong="H7200"\w* \w leurs|strong="H5800"\w* terres.
\v 12 Mais l'\w homme|strong="H8034"\w* \w ne|strong="H8034"\w* peut demeurer \w dans|strong="H5921"\w* \w son|strong="H7121"\w* éclat; \w il|strong="H1004"\w* \w est|strong="H8034"\w* rendu \w semblable|strong="H1004"\w* \w aux|strong="H7121"\w* \w bêtes|strong="H1004"\w* \w qui|strong="H1755"\w* périssent.
\v 13 Telle est \w la|strong="H3885"\w* voie \w sur|strong="H3885"\w* laquelle ils \w se|strong="H1077"\w* fient; \w et|strong="H1077"\w* \w leurs|strong="H1077"\w* successeurs \w se|strong="H1077"\w* plaisent \w à|strong="H3885"\w* \w leurs|strong="H1077"\w* discours.
\v 14 \w Ils|strong="H6310"\w* \w sont|strong="H1870"\w* poussés \w au|strong="H1870"\w* Sépulcre \w comme|strong="H1870"\w* \w un|strong="H1870"\w* troupeau; \w la|strong="H6310"\w* mort \w se|strong="H1870"\w* repaîtra d'\w eux|strong="H6310"\w*; \w les|strong="H1870"\w* justes domineront sur \w eux|strong="H6310"\w* \w au|strong="H1870"\w* matin; \w leur|strong="H1870"\w* beauté \w sera|strong="H1870"\w* consumée \w dans|strong="H1870"\w* \w le|strong="H6310"\w* Sépulcre, loin \w de|strong="H1870"\w* \w leurs|strong="H6310"\w* habitations.
\v 15 Mais Dieu rachètera \w mon|strong="H7462"\w* âme \w de|strong="H6629"\w* \w la|strong="H4194"\w* main \w du|strong="H4194"\w* \w Sépulcre|strong="H7585"\w*, quand \w il|strong="H1242"\w* \w me|strong="H4194"\w* prendra \w à|strong="H7462"\w* lui. (Sélah.)
\v 16 \w Ne|strong="H3027"\w* crains \w point|strong="H3027"\w*, \w quand|strong="H3588"\w* \w un|strong="H3947"\w* \w homme|strong="H3027"\w* s'enrichit, \w quand|strong="H3588"\w* \w la|strong="H3947"\w* gloire \w de|strong="H3027"\w* \w sa|strong="H3947"\w* \w maison|strong="H3947"\w* s'accroît.
\v 17 \w Car|strong="H3588"\w*, \w en|strong="H3588"\w* mourant, \w il|strong="H3588"\w* n'emportera \w rien|strong="H3372"\w*; \w sa|strong="H3588"\w* \w gloire|strong="H3519"\w* \w ne|strong="H3519"\w* descendra \w pas|strong="H3372"\w* \w après|strong="H1004"\w* \w lui|strong="H1004"\w*.
\v 18 \w Que|strong="H3588"\w* \w dans|strong="H3808"\w* \w sa|strong="H3947"\w* vie \w il|strong="H3588"\w* rende \w son|strong="H3947"\w* \w âme|strong="H3519"\w* heureuse, \w qu|strong="H3588"\w*'\w on|strong="H3588"\w* \w te|strong="H3808"\w* loue \w parce|strong="H3808"\w* \w que|strong="H3588"\w* \w tu|strong="H3588"\w* \w te|strong="H3808"\w* \w fais|strong="H3588"\w* \w du|strong="H3947"\w* bien,
\v 19 \w Tu|strong="H3588"\w* iras pourtant vers \w la|strong="H3588"\w* génération \w de|strong="H5315"\w* \w tes|strong="H1288"\w* pères, \w qui|strong="H5315"\w* \w ne|strong="H2416"\w* reverront jamais \w la|strong="H3588"\w* lumière.
\v 20 \w L|strong="H3068"\w*'\w homme|strong="H7200"\w* \w qui|strong="H1755"\w* \w est|strong="H1755"\w* \w en|strong="H7200"\w* honneur \w et|strong="H7200"\w* \w qui|strong="H1755"\w* n'\w a|strong="H3068"\w* \w pas|strong="H3808"\w* d'intelligence, devient \w semblable|strong="H3808"\w* \w aux|strong="H3808"\w* \w bêtes|strong="H7200"\w* \w qui|strong="H1755"\w* périssent.
