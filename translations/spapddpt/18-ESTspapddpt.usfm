\p 
\v 1 \w A|strong="H3068"\w* \w los|strong="H1992"\w* 13 \w días|strong="H3117"\w* del \w mes|strong="H2320"\w* \w duodécimo|strong="H8147"\w*, \w el|strong="H1931"\w* \w mes|strong="H2320"\w* \w de|strong="H1697"\w* Adar, \w cuando|strong="H3117"\w* \w la|strong="H1931"\w* orden del \w rey|strong="H4428"\w* y \w su|strong="H1931"\w* edicto estaban \w a|strong="H3068"\w* punto \w de|strong="H1697"\w* ejecutarse, \w el|strong="H1931"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w los|strong="H1992"\w* \w enemigos|strong="H8130"\w* \w de|strong="H1697"\w* \w los|strong="H1992"\w* \w judíos|strong="H3064"\w* \w esperaban|strong="H7663"\w* prevalecer sobre \w ellos|strong="H1992"\w*, sucedió \w lo|strong="H1931"\w* contrario: \w Que|strong="H1931"\w* \w los|strong="H1992"\w* \w judíos|strong="H3064"\w* prevalecieron sobre \w los|strong="H1992"\w* \w que|strong="H1931"\w* \w los|strong="H1992"\w* odiaban.
\v 2 \w En|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* \w provincias|strong="H4082"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* Asuero \w los|strong="H5921"\w* \w judíos|strong="H3064"\w* \w se|strong="H5921"\w* congregaron \w en|strong="H5921"\w* sus \w ciudades|strong="H5892"\w* \w para|strong="H5921"\w* \w echar|strong="H5307"\w* \w mano|strong="H3027"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H3588"\w* \w procuraban|strong="H1245"\w* \w su|strong="H3588"\w* desgracia, \w y|strong="H3588"\w* \w nadie|strong="H3808"\w* pudo resistirlos, \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w temor|strong="H6343"\w* \w de|strong="H5921"\w* \w ellos|strong="H3027"\w* \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w pueblos|strong="H5971"\w*.
