\id ECC - Kuna, San Blas - Bible -Panama 2014 (DBL -2014)
\h Eclesiastés
\toc1 Bab-Gayaburbagi-Sunmakleged-Garda
\toc2 Eclesiastés
\toc3 Ecl
\mt1 BAB-GAYABURBAGI-SUNMAKLEGED-GARDA
\mt2 ECLESIASTÉS
\imt2 GEBE-SOGLENAID
\imt1 Garda-nug
\ip \it Bab-Gayaburbagi-Sunmakleged-Garda.\it* We-garda, Griego-gayabali, \it Ekklesíaʼye\it* bileged. Hebreo-gayabardina, \it Qoheletʼye\it* bileged. We-gaya-sogbogwadi, “gayaburbagi-sunmaklegedye” sogleged, degine, “igar-itolealile, iduakwaa sunmakedye.” De-ukinbali, “dule-danar-ambikuedgi-sunmakedye,” soglebalid.
\is1 Bab-Gayaburbagi-Sunmakleged-Gardagi weyob sunmaklenaid
\ip Dule-we-garda-narmaksadi, dule-Bab-gayaburbagi-sunmakedid. Israel-yargi, Jerusalén-neggweburgi David-machi-Salomón reyga megisad. We-dule, undargus-neg-dakdanikidba sunmaknaid. Ibmar-nue-durdaksadba sunmaked, bela ibmar-e-arganagwar-ebusadba sunmaked. We-dule, magar itosad, “Bab-Dummadi bonisuli dule-imaksanad, degi-inigwele, dule na dukin boni-amiddamarye.” Degisoggu, bela we-napneggi ibmar-guedi, wile-itolegeddibe, weligwar-itolegeddibe, gwen nabirsurye, binsarsunna ibmar-guye soged.
\ip We-garda bergunaidgine, soged: Bab-Dummad-dobee-nanaed bur biriginedye. Bela ibmar-baramilegedi, ase bergusiye.
\ip We-gardagine, weyob ilemakar sunmaklenaid:
\io1 1. Dule-Bab-gayaburbagi-sunmaked e-san-gusadgi sunmaked (1:1–2:26).
\io1 2. We-napneggi-dulemar-gudiid (3:1–12:8).
\io1 3. Sunmaklesad-e-burba (12:9-14).
\ip Be itogua.
\c 1
\ms1 1. DULE-BAB-GAYABURBAGI-SUNMAKED E-SAN-GUSADGI SUNMAKED
\mr (1:1–2:26)
\s1 Bela ibmar binsarsunna imakleged
\p 
\v 1 Odurdaked-Saila David-machi, Jerusalén-neggweburgi-reyga-megisadi, weyob sogsagusad:
\b
\q1 
\v 2 “We-napneggi-ibmar-imaklegedi, binsarsunna imakleged,
\q2 bela igarga gwen gusulid.”
\b
\q1 
\v 3 Dule we-napneggi na gandikidba-alamakdiile,
\q2 ¿ibu-nued egi amioe? Ibmar-nued amiosuli.
\q1 
\v 4 Dulemar gwalulemamaid. Bamaladdi burgwemamaid.
\q2 Ar napnegdi amba gannar naid.
\q1 
\v 5 Dad-ibeler nakwiardaed, argwatedabalid.
\q2 Na-bia-nakwiardaedse gannar gwae-gwae naddabalid, gannar nakwidabaligar.
\q1 
\v 6 Burwa-goledi, dad-nakwed-argan-nuedsik gollardaed,
\q2 geb sorbali, dad-nakwed-argan-sapiledsik aibiliddaed.
\q1 Deyobi, burwa-goledi, gwen bogigusuli,
\q2 gannar-gannar bipirmakdiguad.
\q1 
\v 7 Bela diwarmar demarse nomaid,
\q2 degi-inigwele, demardi gwen engudasulid.
\q1 Diwarmar na bia gwalulemai, ase gannar aibirsibalid,
\q2 adi, agi gannar nodagegar.
\q1 
\v 8 Bela we-ibmargi-sunmaklegedi, budar-itoleged uked,
\q2 gwen egi bar sunmaklebidasulid.
\q1 Ibya, ibmar-dakedi gwen geggusulid,
\q2 uaya, ibmar-itogedi gwen geggusulid.
\q1 
\v 9 Bato ibmar-gusadi, gannar gunonibaloed.
\q2 Bato ibmar-imaklesadi, gannar imaklenonibaloed.
\q2 We-napneggine, ibmar-gwapid sated.
\q1 
\v 10 Dule-gwensak, sokardibe:
\q2 “Be dakena, wedi ibmar-gwapidid.”
\q1 Ar we-ibmardi, bato gusgu gudiguad,
\q2 anmar-idu-gudigusmalad-abargi bato gudiguad.
\q1 
\v 11 Ibmar-epenne-gusmaladi, bela ielesad.
\q2 Dule-yoedse-gwalulemaloedi, bela ibmar-yoedse-guoedi, iemarmogoed.
\s1 Dule-Sunmakedi, e-san-gusadgi sunmaked
\p 
\v 12 Ani, an emar-odurdakedid, an Israel-yargi, Jerusalén-neggweburgi reyga mai gusad.
\p 
\v 13 An nue-binsaed-nikadba bela we-napneggi-ibmar-imakleged-e-burba-baraminai, degi, egi nergunai an gusad. Bab-Dummad dulemarga we-arbaed-dummad uksad, adi, egi arbadii gumalagar.
\v 14 Bela we-napneggi ibmar-imaklegedi, an daksad. Bela a-ibmarmar binsarsunna imakleged, gwage-nunmaked ukbalid.
\q1 
\v 15 Ibmar-doperegwadi, geg bar gannar innikii gued.
\q2 Ibmar-satedi, geg ebisleged.
\p 
\v 16 An binsadii gualid: “Emide, an wegi dule-nug-nikadga gunonikid. Jerusalén-neggweburgi an-idu-dummagan-megismaladba an bur nue-binsaed-nikaa gued. Anyobi, dule-baid bela-bela nue-binsaed-nikaa, bela ibmar-wisi megdisulid.
\p 
\v 17 ”An ulubgi bela-bela wisgubigualid, nue-binsaed-nikaguedi, wede ibi obarleye. Deginbali, an magar-itobiguarbalid, binsaedsuli-ibmar-imaklegedi, wede ibi obarlebarye, degi, yogasaar-sunmaklegedi, ibi obarlebarye.
\p ”Geb an wisgunonikid, amba we-ibmarse-bakale, gwage-nunmaked ukbalid.
\q1 
\v 18 Napiragwa, ar bela-bela nue-binsaed-nikaguedi, bur bule bonigan ukbalid.
\q2 Ar dule bur bule ibmar-wisguedi, bur bule naibid itobalid.”
\c 2
\s1 Ibmar-isgana-imaklegedgi-yeer-itolegedi, ibnuedsulid
\p 
\v 1 An-gwagegi an sogsa gusad: “Emigindi, ibmar-galagwensuli-imakedgi-yeer-itolegedi, an imakdii guoye, an nue-yeer-itodii gubaloye.” Ar amba deyob gudiguedi, binsarsunna imaklebalid.
\v 2 Alledi, binsa goelleged an daked. Ibmar-galagwensuli-imakedgi-yeer-itogedi, ¿ibiga gue? Ibmarga gusuli.
\p 
\v 3 Geb an wisgubigualid, vino-gobedgi bule an magar neg-itodii guodibe, degi, binsaed-satedyobi galagwensuli ibmar-imakdii guodibe. Adi, an wisguega, dule we-napneggi sikwas-dula-gudiguedgi, na e-ibmar-imakdiidgi ibi-nued amie.
\p 
\v 4 An we-ibmar-dummagan imaksad: Negmar an sobsad, uva-nainu-dummagan an nasiksabalid.
\v 5 An-nainugine, bukidar ibmar-gullemalad an digsad, dutumar an digsabalid. Sapi-san-nabir-gullemalad akar-akar an digsabalid.
\v 6 Amar-ogegala, dii-sabogega yaa-dummagan an akwisbalid.
\p 
\v 7 An bukidar mai-machergan, degi, mai-omegan baksad. Maimar-an-neggi-gwalulesmalad an nikusbalid. Jerusalén-neggweburgi-an-idu-dummagan-megismaladba, an bur bule molimar-bebe-nikad nikusad, degi, sibad-wawaadmar an nikusbalid.
\p 
\v 8 An ormar, degi, manimar ichesur nikusad. Rey-bamalad-e-ibmar-nuegan an susad, degi, dule-yar-bamaladgi-bukwamalad-e-ibmar-nuegan an susbalid. Machergan-anga-namakmalad, degi, omegan-anga-namakmalad an nikusgusad. An wergudiidbali, an ome-baigan-bukidar nikusbalid.
\p 
\v 9 Jerusalénʼgi-an-idu-dummaganga-megismaladi, anyobi nug-dummarbaa nikussurmalad. Deginbali, anyobi nue-binsaed-nikaa gussurmarbalid.
\v 10 Bela an-ibmar-imakbigusadi, an imaksad. Bela ibmar-galagwensuli-imakedgi-yeer-itogedi, an itosbalid. Bela an-arbasadgi an wergudii gusad. We-ibmarmar-imaksadgi an yeer itosad.
\p 
\v 11 Geb sorbali, bela-ibmar-imaksadgi an binsadii gusad. Bela ibmar-imakega an dummad-arbadigusadgi, an binsadii gusbalid. An bela we-ibmarmar dakalid, bela wedi, binsarsunna imaklegedi, degi, gwage-nunmaked ukbalidi, egi ibmar-nued amilesurbalid.
\s1 Bela dulemar burgwemaloedbiid
\p 
\v 12 Geb sorbali, an binsadii gualid, nue-binsaed-nikagued, wede ibi obarlege, binsaedsuli-ibmar-imakleged, ibi obarlebali, degi, yogasaar-sunmakleged, ibi obarlebali. Ar dule rey-sorba-megnonikoedi, ¿ibu-ibmar-baid imaknonikosunna? Ibmar-baid-imaked sate. Ar ade, bato bela ibmar imaklesad.
\p 
\v 13 An daknonikid, ar igi neg-meegwad negsichidba bur nued gue. Deyobi, nue-binsaed-nikagued, yogasaar-sunmaklegedba bur nuedid.
\q1 
\v 14 Dule-binsaed-ibed, magasar neg daked.
\q2 Dule-binsaedsuliddina, aku neg daked.
\p An daknonibalid, bela dulemar burgwedsemarbalid.
\v 15 Geb degine, an sogdesunnad: “Dule-binsaedsulid-burgwedyobi an burgwemogoed. Degisoggu, ¿ibiga an binsaed-ibedga gubisunna?” Degisoggu, an daknonibalid, we-ibmar binsarsunna imaklebali.
\p 
\v 16 Ar dulemar, dule-binsaed-ibedgi, degi, dule-binsaedsulidgi bar binsaosurmalad. Ar birgamar-namaidba bela iedmaloed. Dule-binsaed-ibed, dule-binsaedsulidyobi burgwemogoed.
\p 
\v 17 Degisoggu, an we-napneggi-gudiidi, isdar an itononisunnad. Ar ade, bela we-napneggine ibmar-imakleged nabir anga nosulid. Ar bela we-ibmarmar binsarsunna imakleged, gwage-nunmaked ukbalid.
\p 
\v 18 Deginbali, we-napneggi arbaed-dummad-an-imaksadi, gwen-nabir an daknonisurbalid. Ar bela arbaed-dummad-an-imaksadi, dule-an-sorba-megnonikoedga an obegergebed.
\p 
\v 19 An-sorba dule-reyga-megnonikoedi, binsaed-ibedga guodibe, binsaedsulidga guodibe, amba bai daklegosulid. Degi-inigwele, dummad-an-arbasadgi-ibmar-nikusadi, degi, binsaed-nikaguedgi-an-ibmar-imaksadgi-ibmar-nikusadi, we-reygadga gunonikoed. Ar we-ibmarmar binsarsunna imaklebalid.
\p 
\v 20 We-napneggine, an dummad-arbasad-ulale, an gwen nabir itononisurbalid.
\v 21 Ar gwen-gwen-dulemar, ibmar-nikuega e-binsaed-nikad ebudamalad, ibmar-nikuega e-ibmar-wisid ebudamalad, degi, ibmar-nikuega e-ibmar-durdaksad ebudamalad.
\p Ar sorbardi, dule-gwen-arbassulidga bela e-ibmar-nikuedi, obegoed. Ar weyob ibmar-guedi, gwen nabirsulid. We-ibmarmar, binsarsunna imaklebalid.
\p 
\v 22 Dule we-napneggi arbaed-dummad-imakedgi, surbinsa-alamaknaidgi, degi, bukib-binsaed-abalagi-alamaknaidgi, ¿ibu-ibmar-nued egi nikue? Sate.
\v 23 Ar dulega bane-bane wile-itogedbi, degi, arbaed-dummad-imakedbi neg naid. Mutikidse-bakale, gwen obunnosulid. We-ibmarmar binsarsunna imaklebalid.
\p 
\v 24 Degisoggu, unnila masgunnedgi-yeer-itogedi, gobedgi-yeer-itogedi, degi, e-arbaedgi-yeer-itogedi, dulega bur-nued gued. An daksabalid, we-ibmala Bab-Dummadgi danibali.
\p 
\v 25 Ar Bab-Dummad dulegi-nabir-binsasulile, ¿doa nabir mas-gunnoe? ¿Doa yeer itobaloe?
\p 
\v 26 Bab-Dummad dule-yeerdakedga, binsaed-nikagued uked, ibmar-nue-wisi imaked, degi, yeer-itoged ega ukbalid. Ar dule-isganagardina, ibmar-onmakedgi-arbaed ega uked. Adi, sorbali, we-ibmar dule-yeerdakedga ukegar. Ar we-ibmarmar binsarsunna imaklebalid, degi, gwage-nunmaked ukbalid.
\c 3
\ms1 2. WE-NAPNEGGI-DULEMAR-GUDIID
\mr (3:1–12:8)
\s1 Ibmar-imaklegega bela e-ibagan nikad
\p 
\v 1 Ibmar-imaklegega bela e-wachi nikad. We-napneggine, ibmar-imaklegega bela e-ibagan nikabalid:
\q1 
\v 2 Gwaluleged-e-iba nikad,
\q2 burgwileged-e-iba nikabalid.
\q1 Ibmar-gwag-digleged-e-iba nikad,
\q2 ibmar-gwag-ungeleged-e-iba nikabalid.
\q1 
\v 3 Oburgwileged-e-iba nikad,
\q2 onuguleged-e-iba nikabalid.
\q1 Ibmar-earileged-e-iba nikad,
\q2 ibmar-sobleged-e-iba nikabalid.
\q1 
\v 4 Boleged-e-iba nikad,
\q2 alleleged-e-iba nikabalid.
\q1 Dule-burgwisadba wile-itoleged-e-iba nikad,
\q2 yeer-itogedba gwirleged-e-iba nikabalid.
\q1 
\v 5 Akwamar-osamakleged-e-iba nikad,
\q2 akwamar-weleged-e-iba nikabalid.
\q1 Angaagwar-imakleged-e-iba nikad,
\q2 degimaloye-sogleged-e-iba nikabalid.
\q1 
\v 6 Ibmar-imaklebienad-e-iba nikad,
\q2 ibmar-imaklebisulid-e-iba nikabalid.
\q1 Ibmar-saboleged-e-iba nikad,
\q2 ibmar-mileged-e-iba nikabalid.
\q1 
\v 7 Ibmar-esirmakleged-e-iba nikad,
\q2 ibmar-makleged-e-iba nikabalid.
\q1 Sunmaklesulid-e-iba nikad,
\q2 sunmakleged-e-iba nikabalid.
\q1 
\v 8 Sabguleged-e-iba nikad,
\q2 isdar-dakleged-e-iba nikabalid.
\q1 Bila-onoleged-e-iba nikad,
\q2 neg-bogidik-naguleged-e-iba nikabalid.
\s1 Arbaedgi alamaknaiguedi, binsaledid
\p 
\v 9 Ar dule arbaedgi alamaknaiguedi, ¿ibu-nued egi nikue?
\p 
\v 10 An daksad, Bab-Dummadi dulemarga arbaed-dummad uksad, adi, arbaedgi alamaknai gumalagar.
\v 11 Bab-Dummad e-iba-sogedba bela ibmar-yeerdakle imaksad. Deginbali, dule nabir epenne-ibmar-gusmalad-magar-itogega, degi, yoedse-ibmar-guoed-magar-itogega imaksabalid. Degi-inigwele, dule, bela Bab-Dummad negasailagi-ibmar-imaksad, degi, yoedse-ibmar-imakoed wissulid.
\p 
\v 12 An wisdo, dule na dula-gudiidgine wergudiguedba, degi, ibmar-nued-imakdiguedba, bur ibmar-nued-baidi, sated.
\v 13 An wisbalid, nabir-masgundiguedi, nabir-gobdiguedi, degi, dummad-arbasadgi-yeer-itodiguedi, Bab-Dummad dulega uksabalid.
\v 14 Amba an wisbalid, bela-Bab-Dummad-ibmar-imaksadi, degisadegu gued. Na e-ibmar-obinnisadgi ibmar-baid geg nasikleged, geg bar osulolebalid. Bab-Dummad bela deyob imaksad, adi, dulemar e-dobekwaa nanamalagar.
\q1 
\v 15 Emi ibmar-bukwadi, bato dikasurgus bukwad.
\q2 Ibmar-gunonikoedi, bato gudiid.
\q2 Bab-Dummad gannar-ibmar-guega imaked.
\s1 Igar-innikigwadba ibmar imaklesulid
\p 
\v 16 We-napneggine ibmar-baid an daksabalid: Igar-itolegedgi, igar-isgana imakleged. Igar-innikigwad-imaklegedgi, igar-isgana imakleged.
\p 
\v 17 Geb an binsadsunnad:
\p “Bab-Dummad dule-nuedga igar itogoye, degi, dule-isganaga igar itobaloye. Ar ade, bela-ibmar-guedga, igar-itoleged-iba nikaye. Bela-ibmar-imaklegedga igar-itoleged-iba nikabarye.”
\p 
\v 18 An dulemargi binsasbalid: “Bab-Dummad dule-wilubdaknaiye, adi, dulemar na magar itomalagarye, emarde, ibdurganyob gumarye.
\v 19 Dulemar ibdurganmaryob bergumarmogad. Ebobela ega igar yopira maid. Ebobela na yopira burgwemalad. Ebobela dulagudiguega bunnodigued abeged. Degisoggu, dule ibdurgangi obinsulid. Ar napiragwa, bela wemar gwen nabirsulid,
\v 20 degi, bela napa-urba megmaloed.
\q1 Bela napagi danimalad,
\q2 bela gannar napaga binyemarbaloed.
\p 
\v 21 ”¿Ar doa wissunna, dule-e-burba niba naddae? ¿Ar doa wissunna, ibdurgan-e-burbadi neg-urba aideddae?”
\p 
\v 22 An daksasunnad, dule, e-arbaedgi-wergudiguedba bur ibmar-nued-imaked sated. Ade, arbaed-igar ega uklesad. E-burgwisad-sorba ibmar-guoed-dakega, ¿doa we-dule-burgwisad gannar-dagega imakoe?
\c 4
\s1 Dulemar-mesagwar-imakledimalad
\p 
\v 1 An dakdebalid, we-napneggine, dule-mesagwar-imakledimalad yaisulid. Dule-mesagwar-gudimaladi bodidii an daksad, dule-gadi-gadi-e-gwage-imakedi sate gudimalad. Dule-mesagwar-gudimaladi, dule-gadi-gadi-e-gwage-imakedi sate gudimalad. Dule-wemar-mesagwar-imakdimaladi, gangued nikamalad.
\p 
\v 2 Degidbali an binsaded, dule-burgwismaladi, dula-gudimaladba bur weligwar gumalad.
\v 3 Ar degi-inigwele, amba yoo-gwalulemaladdi, bur bule wemarba weligwar gumalad. Ar ade, we-napneggi ibmar-isgana-imaklemalad amba yoo dakmalad.
\p 
\v 4 An daksabalid, arbaed-dummad-imakedi, degi, ibmar-imakedba-nasgumaiguedi, nobed uked.
\p Wedi binsarsunna imaklebalid, gwage-nunmaked ukbalid.
\q1 
\v 5 Dule-binsaedsulid, gwen arbasuli
\q2 ukudmaad burgwidoed.
\q1 
\v 6 Sikwas-obunnolegedi, doggus-obicha-arbaedba bur nuedid.
\q2 Ar doggus-arbaedi, gwage-nunmaked uked.
\s1 Bulakwaa-arbaed gargangued uked
\p 
\v 7 We-napneggi, ibmar-binsarsunna-imakleged-baid an dakdebalid:
\p 
\v 8 Dule-wargwenad mimmigansuli gudiid, degi, gwenadgansuli gudibalid, bipisaar arbaed indakdisulid. Bato-ibmar-nikadi amba yeer-itosulid, bur bule ibmar nikubied. Gwen binsasurbalid, doaga ede alamaknai. Gwen werguedgi binsasurbalid.
\p Wedi binsarsunna imaklebalid, arbaed-dummad gued.
\q1 
\v 9 Dule-ebogwad, dule-wargwenadba bur nuedid.
\q2 Ar na e-arbadiidgi bur bule ibmar-nuegan nikumalad.
\q1 
\v 10 Ar gwensak aimukudele, baid ogwichoed.
\q2 Ar dule walagwen-gudiiddi, aimukudele, dummad-wilegoed,
\q2 ar dule-baid-e-ogwisgued sateoed.
\q1 
\v 11 Ar dule-ebogwad na walikaa megmalale, na muchub-muchub uee imakmaloed.
\q2 Ar dule walagwen-megerdi, ¿igi na uee itogoe?
\q1 
\v 12 Dule walagwenale, sunna dule-baidse galakued.
\q2 Ar ebogwardina, sunna dule-baid-abin ganna gwisgumalad.
\q2 Dub-giapaa-bipirmakaledi, irgwensuli itirsulid.
\s1 Sapingwa-gued, binsaed-nikagued
\q1 
\v 13 Sapingwa-wilesakwagwad binsaed-ibed-gudiid, bur nuedid, rey-sered binsaedsuli-gudiidba.
\q2 Ar we-reyde, dule-ega-binsaed-uked bar abesulid.
\p 
\v 14 Ar we-sapingwa, esgaryagi-mellesii gusdibe, e-yargine wilesakwaa gwalulesdibe,
\v 15 degi-inigwele, we-napneggine an daksad, we-sapingwa rey-sorba reyga-megnonikile, dulemala eba nanai damalad.
\p 
\v 16 Ar amba dule-bukidar we-sapingwa-gebe-reyga-megidedgi eba nagusdamar-inigwele, degite, dule-danimarmogoedi amba we-rey gwen yeer dakosurmarmogad.
\p Amba we-ibmala binsarsunna imaklebalid, gwage-nunmaked ukbalid.
\c 5
\s1 Ibmar-imakoye-sogsad imakergebed
\p 
\v 1 Bab-Dummadse-goled-negse be nadele, mer be yogasaar ibmar imako. Agi ibmar-odurdaklenaid-itoged bur nuedid, dule-binsaedsurmalad Bab-Dummadga ibmar-ogumakar-ukedba. Ar we-dulemardi, ibmar-isgana-imaknanaid aku-itodamalad.
\q1 
\v 2 Bab-Dummad-asabin, mer be ibmar sogdebin imako,
\q2 deginbali, mer be gwae-gwae binsabalo.
\q1 Ar Bab-Dummaddi nibneggi maid, bedi, napneggi gudiid.
\q2 Degisoggu, nue-itoakwaa be ibmar sogo.
\q1 
\v 3 Ar dule-gadi-bukib-binsaedi, gabmaile, gadi gwayedaed.
\q2 Dule-gadi-sunmakedi, yogasaar sunmakdaed.
\p 
\v 4 Bab-Dummadga be ibmar-imakoye-ise-sogar-sogsale, gwae be imako. Ar Bab-Dummad dule-binsaedsulidamalad nabir-dakdasulid. Be ibmar-imakoye-ise-sogar-sogsad, be imake.
\q1 
\v 5 Ibmar-imakoye-ise-sogar-soged-sogsadba, degi, imaksulidba,
\q2 ibmar-imakoye-ise-sogar-soged-sogsulid bur nuedid.
\p 
\v 6 Mer be-gwabin-duku isguega-be-imaked be imako. Geb sorbali, dule-Bab-gayaburba-berbegedga mer be sogo, an ibmar-sogbisulid sogsaye, an noar sunmaksaye. Ar noar be sunmaksadba, binsarsunna Bab-Dummad be ourwoed. Binsarsunna be-ibmar-imaksad be-ibe-obelogega imakoed.
\v 7 Degisoggu, bukidar-ibmar-binsarsunna-imakleged-abargi, bukidar-gwayed-abargi, degi, bukidar-yogasaar-sunmakleged-abargi, bur be Bab-Dummad-dobekwaa nanae.
\s1 Ibmar-bukidar-nikuleged binsarsunna gued
\p 
\v 8 Yar-gwensakgi, dule-dummad dule-wileged-sabsur-imake be dakalile, degi, dulemarga igar-nabolegedi innikigwadba imaksuli be dakalile, mer be geger dako. Ar weyob ibmar-gued, ade, dule-dummad eba-bur-dummad-e-bendaked nikad. Deginbali, dule-baid-eba-bur-dummad, eba-bur-dummagan-e-bendaked nikamogad.
\v 9 Weyob-ibmar-guedi, ¿ibu-nued yar-naid egi nikue? ¿Reyde, nainugi-arbamalad-bendakega mai? Eye, bendakega maina.
\p 
\v 10 Ar dule-manibina-sulibinsa-itogedi, bur bule mani-nikubidaed. Ar dule-ibmar-nueganbina-sulibinsa-itogedi, bur bule ibmar-abedaed. Amba we-ibmarmardi binsarsunna imaklebalid.
\p 
\v 11 Ar mani-bukidar-nikulegele, mani bur bule oeledabalid. Mani-ibed unnila mani-e-wagarbi dakoed egi buu-nasoed. Ibmar-nued egi nikuosulid.
\p 
\v 12 Arbaed-dule, immediki mas-gundibe, wilubba mas-gunbardibe, bonisuli gabdiid. Dule-mani-ibeddina, doggus-mani-nikadba gwen nue gabdisulid.
\p 
\v 13 We-napneggine, boni-dummad an daksad: Dule mani-bukidar-sabogele, egi aibinega gued.
\v 14 Degi, ibmar-uklegedgi yogasaar-mani-ebulegedba mani yoggued. A-ular, we-dule, machi-nikunonikile, e-machiga bar mani obegosulid.
\v 15 Ar igi we-napnegse aidenoniki, deyobi, gannar nabaloed. Ar igi we-napnegse uka-swiri noniki, deyobi, e-dummad-arbasadgi-ibmar-nikusadi gwen sedosulid.
\p 
\v 16 We-ibmar, boni-dummadbalid. Ar igi-dule napnegse aidenoniki, deyobi, gannar nabaloed. Ar dule arbaed-dummad-imakedgi, ¿ibi nued amie? Sate.
\v 17 Deginbali, ar we-dulede, we-napneggine wile-itogedgi, arbaed-dummad-imakedgi, bonigan-abalagi, degi, sae-itogedgi mas-gundiid.
\p 
\v 18 Weyob an daknonikid: We-napneggi-gudiidgi masgunned bur-nuedid, gobed bur-nuedid, degi, arbaed-dummad-imakdiidgi yeer-itodigued bur-nuedid. Ar weyob Bab-Dummad abesad, we anmarga uklesad.
\v 19 Deginbali, Bab-Dummad, ar doaga mani-bukidar uke, degine, ibmar-nuegan-bukidar ukbali, deyobi, a-dulega, we-ibmarmar-uklesadgi-werguega imakbalid, deginbali, egi masgunnega imakbalid, egi gobega imakbalid. Ar weyob-dulega-guedi, Bab-Dummad uksad.
\p 
\v 20 Ar Bab-Dummad weligwar dule-imaksoggu, dule, we-napneggi-sikwas-gudiidgi dogdar bukib binsasulid.
\c 6
\s1 Dule binsarsunna we-napneggi gudiid
\p 
\v 1 We-napneggine, dulemar-abargi we-boni nue-nika an daksad:
\v 2 Bab-Dummadi, abar-dulemarga ibmar-bukidar uked, mani-bukidar-nikuega imaked, deginbali, dule-nug-odummogega imakbalid. Degidbali, we-dulemar na ibmar-abegedba nikued. Degi-inigwele, Bab-Dummad, we-dule e-ibmar-nikuedgi-werguega imaksulid, aka dule-bamalad e-ibmargi-werguega imaked. Weyob-ibmar-guedi, gwen nabirsulid, boni-dummad dakleged.
\p 
\v 3 Ar dule-gwensak mimmigan dulatar-nikadibe (100), degine, birga-undar-gudii gusbardibe, ar ibmar-nuegangi-wergudigussuli-burgwisale, yogasaar-diglesale, an sogdo, bur mimmi-gwensak-burgwar-aidenonikir, bur we-duleba nuedye.
\p 
\v 4 Ar we-mimmi-burgwar-aidenonikid gwen neg daksasulid, degine, negsichigi megidapid. Deyob negsichigi-megidapidgi gwen bar egi binsaledsurbalid.
\v 5 We-mimmide, gwen dad-ibeler-daksasulid, gwen neg-wisgussulid.
\v 6 Degi-inigwele, we-mimmi, dule birga-milibo-gudigusadba (2,000), degi, gwen-ibmar-nuegangi-wergussur-gusadba, bur bogidikid nue-nikusad. ¿Ar bela dulemar bergunonikile, burgwed-negse bela naedsemarsursi? Bela naedsemalad.
\p 
\v 7 Dulemar mas-gunnegala arbaedginbi alamakdidamalad, degi-inigwele, e-ukuddi gwen bergusurbalid.
\p 
\v 8 Ar dule-binsaed-ibed, ¿ibuginbi dule-binsaedsulidgi-obinsisunna?
\p Ar dule-wileged, nabir-bonigan-abin-gwisgudiidgi, ¿ibi-nued egi amimosunna? Ar e-bogwad na yopira bonigangi obindimalad.
\p 
\v 9 Ibmar-sanakwa-daklegedi, ibmar-ulubginbi-abelegedba bur nuedid. Ar we-ibmar gwen nabirsurbalid.
\q1 
\v 10 Ibmar-gudiidi bato e-nug nika gudiid, ar bato wisgulesad, we, dule gue.
\q2 Deginbali, dule, gege dule-bur-eba-niga-gandikidbogwa urwed.
\q1 
\v 11 Gadi-sunmaklegedgine, yogasaar sunmakleged.
\q2 Ar we-ibmargi, ¿ibu-ibmar-nued egi amilesunna?
\p 
\v 12 Degisoggu, we-napneggi wis sikwas-gudiidgine, dule wissulid, ibu ega nued noe. Degisoggu, we-napneggi, unnila sikwas-gudigued, gwen nabirsulid. Ar dule-gudiid, burwa-goleyob sikwas-buu nasoed. Ar dule burgwisad-sorba, ¿doa ega sogosunna, igi neg guoye?
\c 7
\s1 Binsaed-nikagued, binsaedsulidaed
\q1 
\v 1 Ina-wawadikidba nug-nued-nikuleged, bur nuedid.
\q2 Gwaluleged-ibaba burgwed-iba, bur nuedid.
\q1 
\v 2 Iba-dummad-nonaidse-ataknaedba dule-burgwisadse-ataknaed, bur nuedid.
\p Ar dule bela burgwedsegad, degisoggu, dulemar-dula-gudimalad, burgwedgi binsadii gumalawilubbinad.
\q1 
\v 3 Allelegedba boleged bur nuedid.
\q2 Ar boleged amba wile-ito emar-imak-inigwele, gadi-gadi gwage-imakbalid.
\q1 
\v 4 Dule-binsaed-ibed, dule-burgwis-naidse-ataknadele, binsaed-nikaa daed.
\q2 Dule-binsaedsuliddina, ataknadele, unnila dodogedginbi binsadaed.
\q1 
\v 5 Dule-binsaedsulid yamo emar-ogannogedba,
\q2 dule-binsaed-ibed emarga sabsur-ibmar-soged, bur nuedid.
\p 
\v 6 Dule-binsaedsulidaed-e-alledi, ikomar-gummakder doos-doos-gotedaeyobid, yog-berguar naddaed.
\q1 
\v 7 Sabsur-ibmar-imakleged dule-binsaed-ibed-oichoged.
\q2 Ibmargi-bennuklegar-binsaed-galeged, dule-binsaed-ibed-e-gwage oichobalid.
\q1 
\v 8 Ibmar-gebe-imaklegedba, ibmar-nagase-obeloleged, bur nuedid.
\q2 Dule-na-san-dummarba-imakdiidba, dule-na-ulubgi-bargaagwar-gudiid, bur nuedid.
\q1 
\v 9 Mer urwed begi-obinega be imako,
\q2 ar urweddi, dule-binsaedsulidaedgadid.
\p 
\v 10 Mer be sogo, ibiga ibagan-nasmalad bur nuegan gusye. Weyob-sunmaklegedi, binsaed-ibegan-sunmakedsulid.
\p 
\v 11 Dulemar-we-napneggi-gudimalad binsaed-nikagued-nikale, nuedid. Degine, nainu-nikabalile, doggus bur nuedid.
\v 12 Binsaed-nikagued emar-bendaked, mani-nikued emar-bendakmogad. Degi-inigwele, binsaed-nikagued bur biriginedid, ar adi, nuedgi-sered-megega dule-imaked.
\p 
\v 13 Bab-Dummad-ibmar-imaksad be dakena: Ar Bab-Dummad ibmar-dopere-imaksadi, ¿doa bar inniki imakosunna?
\v 14 Bega ibagan-nuegan-nonikile, egi be werguo. Amba bega ibagan-isgana-nonibalile, Bab-Dummadgi-danibarye be binsabalo. Ar dule wissulid, ibagan-danikoedi, igi danibali.
\p 
\v 15 Wegi-wile-itodiidgi an we-ibmar belagus dakdanikid: Dule-nuegan, ibmar-inniki-imakdiid-ular, sabsur-ibitodimalad. Ar dule-isganamardina, ibmar-isgana-imaked-inigwele, aka bur undar-seredi megmalad.
\q1 
\v 16 Mer doggus be wilub-obicha an dule-innikigwadye be sogo.
\q2 Mer doggus be wilub-obicha binsaed-ibed na be sao.
\q2 Abakalegi na be dukin oitoalile.
\b
\q1 
\v 17 Mer doggus dule-isganaga na be imako,
\q2 mer dule-binsaedsulidga na be imakbalo.
\q2 ¿Ar ibiga na be durbas burgwed aminonikosunna?
\b
\q1 
\v 18 Mer doggus wilub-obicha na be dao,
\q2 wilubba na be gudii guoed.
\q1 Ar dule, Bab-Dummad-dobekwaa-gudiile,
\q2 bela ega ibmar nueganbi gudoed.
\b
\q1 
\v 19 Dulemar-bulegan-ambegid (10) neggwebur-semaladba,
\q2 binsaed-nikagued dule-binsaed-ibed-ogannoged, bur nuedid.
\q1 
\v 20 Dule, bela-belad-innikidaedi, bela-belad-ibmar-nued-imakdibalidi,
\q2 gwen bipisaale isgudisurbalidi, we-napneggine, sated.
\p 
\v 21 Mer yogasaar-sunmaklegedba be aibiro. Adi, be-mai-begi-ichakwa-sunmaked, be itogosulid.
\v 22 Ar be nue-wismogad, emargi-ichakwa be sunmaksamogad.
\s1 Ibmar-gued-e-burbamar baramilenaid
\p 
\v 23 Binsaed-ibed-dulega an guoye na sogsagusanad, bela we-ibmar an-binsaed-nikadba an baraminai gusanad. Degi-inigwele, amba bela an ibmar magar-itosulid.
\v 24 Bela-ibmar-guedi yeer angi gangu noed, amba an magasar-itosulid. ¿Doa we-ibmar bela baramiosunna?
\p 
\v 25 Degisoggu, binsaed-nued-bar-amiega an guarsunnad, ulub-nagasega ibmar-gumaid-bar-amiega an gualid. Degidbali an neg-daknonikid, dule-isgana-gued binsaedsulidaedid, degine, binsaedsulidaedi, igar-gwen-nabirsulidid.
\p 
\v 26 Deginbali, we-ibmar bur boni-dummad an daknonibalid: Ome-isgana, burgwedba bur bule boni uked. We-ome-e-gwage-naidi, sakiyob emar-gaed, e-swidamala, esgoro-dubyob emar-edinned. Ar dule Bab-Dummadbaligwa-gudidibe, we-omese galegosurguoed. Isgued-duledina, we-omese ibitogoed.
\p 
\v 27 Bab-Dummad-gayaburba-barsoged sogded: “Bela an ibmar-sog-soggwen baraminai-gusgua, an weyob ogwinmaknonisunnad:
\p 
\v 28 ”An ibmar-amidiidi, amba an yoo baramied. An dula-miligwenad-abargine (1,000), dule-machered-amidiidi, an wargwen aminonikid. Ome-nued-gwensakdina, wargwensaale gwen an amissurgusad.
\p 
\v 29 ”Degisoggu, unnila webi an magar-itonikid: Bab-Dummad dule-imaksadi, dule-bonisuli imaksanad. Degi-inigwele, dule na e-daedba, dukin na bonigan-amisad.”
\c 8
\p 
\v 1 ¿Doa-dule binsaed-ibedyob gue? ¿Doa-dule bela-ibmar-wisid gudii? Dule, binsaed-nued-nikadbali, e-daklegedi, weligwar-dakleged, degine, e-daedi, nued dabalid.
\s1 Reyba-ibsaed
\p 
\v 2 Degisoggu, an bega soged: Rey-e-ibmar-sogmaidbali be ibsao, ar Bab-Dummad-asabinni deyob-imakoye be sogsad.
\v 3 Melle be rey-asabin-gwichidgi gwae-gwae-nodebin sao. Mer ibmar-isgana-imakedgi be binsabalo. Ar ade, rey na e-ibmar-imakbiedba ibmar imaked.
\v 4 Ar rey-e-sunmakedi gargangued nikad, degisoggu, ¿doa ese golosunna ibu be imaknaiye?
\p 
\v 5 Ar dule rey-sogedba daele, gwen akar-guosulid. Dule-binsaed-ibedi na wisid, sana reyba ibsaoe, degine, igi imakbaloe.
\v 6 Ar bela-ibmar-imaklegedi, e-ibagan nikad. Degine, igi ibmar-imaklebaloed-igar nikabalid. Degi-inigwele, dulega, we-ibmar, boni-dummad gued:
\v 7 Bonigan-egi-gwisgunonikoed wissulid, degine, dule-ega-ibmar-guoed-soged satebalid.
\v 8 Dule burgwed-bargaegala, gargangued nikasulid, na degisadegu-gudiguega, gargangued nikasurbalid. Ar burgwed-igargine, gege dule wakinned, dule-isganase-bakale, gege wakinned.
\s1 Ibmar-yogasaar-imakleged
\p 
\v 9 An we-napneggi ibmar-gued bela-bela an nue-wisgubiguargua, an daknonikid: Imbagwenale, dule, e-maiga dule-baid-imakele, ega boniga gunonidaed.
\v 10 Degine, an daksabalid, dule-isganamar-burgwisale, iba-dummad-abalagi digledaed. Degine, dulemar Babse-goled-negse-nanadimaladdina, na e-neggweburgi-gudigusmaladgi ielededaed, gwen bar egi binsaledasulid. We-ibmar gwen-nabirsulid.
\p 
\v 11 Dule-isgana ibmar-isgana-imaksale, abgayala ega igar nabolesulile, dulemar binsaddamalad, igar-isgana-imakleger, akarsurye. Degisoggu, ibmar-isgana-imakedgi aka gatik burguddamalad.
\p 
\v 12 Dule-isgana bali-bali isguedginbi-alamakdiidi, sunna undar gudii gubalid. An wisbalid, dule-Bab-Dummad-dobekwaa-gudiidi, degi, e-nug-odummodibalidi, bur nued gudii guoed.
\v 13 Dule-isganamargardina, bela ega ibmar boniga gudoed. Ar unnila sikwas gudii gumaloed, waa-yogguddaeyob gumaloed. Ar we-dulemar, Bab-Dummad-dobekwaa gudisurmalad.
\p 
\v 14 We-napneggi galagwensuli ibmar gued, degine, igarsuli ibmar gubalid. Imbagwenale, dulemar-inniki-gudimalad dule-isganayob ega ibmar guddaed. Degine, dule-isganagardina, imbagwenale ega ibmar nueganbi naddaed. An sogdo, we-ibmar gwen nabirsurbarye.
\p 
\v 15 Degisoggu, an soged: Wergudii gumarsun. Ar anmar we-napneggi-gudiidgi Bab-Dummad-anmarga-ibmar-uksadbali, bur mas-gundii gumarsun, gobdii gumarbarsun, wergudii gumarbarsun. Ar galitodiid-sorba, we-ibmarbi wis anmarga besad. Ar we-ibmar-birgi ibmar-baid sulid.
\p 
\v 16 We-napneggi binsaed-nued-balamiegala, degine, we-napneggi-ibmar-gued-balamiegala, ise-dakale an imaknai gualid. Degidbali, ibginedse-bakale, nue bar an gabdisulid.
\v 17 Geb deyobi, Bab-Dummad-we-napneggi-ibmar-imaksad an daknonikid. Ar dule Bab-Dummad-bela-ibmar-imaksad bela magar itogosulid. Ibmar-magar-itogegala, aisaar alamaknai guoenad, degite, baramiosurguoed. Ar amba, dule-binsaed-nikarbad sogdibe, an magar-neg-itoye, degi-inigwele, nagase amba magar-itosurmogad.
\c 9
\s1 Bela dulemar igar-soggwennase bergusiid
\p 
\v 1 Bela we-ibmarmar-wisguegala, an egi alamaknai gualid. Wegi an daknonikid, dule-innikidamalad-e-ibmar-imakmaladi, degi, dule-binsaed-ibegan-e-ibmar-imakmaladi, Bab-Dummad-e-argan-yaurgi siid. Anmar amba wissulid sabgued, ibu obare, sae-emar-daked, ibu-obarbali. Amba, anmar-asabinni we-ibmar oyole-inigwele, magar-itolesurdaed.
\v 2 Bela dulemar yopira guedbimalad:
\q1 Dule-innikidaeddibe, dule-ichakwadaeddibe,
\q2 amba yopira burgwedsemalad.
\q1 Dule-nueddibe, dule-isganadibe,
\q2 amba yopira burgwedsemalad.
\q1 Dule-swilidikiddibe, dule-swilidiksuliddibe,
\q2 amba yopira burgwedsemalad.
\q1 Dule-ibmar-ogumakar-ukeddibe, dule-ibmar-ogumakar-uksuliddibe,
\q2 amba yopira burgwedsemalad.
\q1 Dule-ibmar-nued-imakdeddibe, dule-ibmar-isgana-imakdeddibe,
\q2 amba yopira burgwedsemalad.
\q1 Dule-ibmar-ise-sogar-imakeddibe, dule-ibmar-ise-sogar-imaksuliddibe,
\q2 amba yopira burgwedsemalad.
\p 
\v 3 We-napneggi, ibmar-imakleged-abargi, we-ibmar gwen nabir nosulid: Bela dulemar na yopira guedsemalad. Deginbali, dule e-gwagegine, ibmar-isganaginbi binsadiid. Dule-gudiidi, unnila galagwensuli binsadiid. Ar bela burgwemaloedbiid.
\v 4 Degisoggu, dule na dule-bamalad-abargi dula-garmakdiir, wis nubin itoged.
\q1 Agala an soged:
\q2 Rey-burgwedba, dule-belagwad-dulagudigued, bur nuedid.
\p 
\v 5 Ar dulemar amba dula-gudimaladi, e-burgwemaloed na wismalad. Dule-burgwismaladdina bar ibmar-abemaisurmalad, ar bar-itomaisurmalad. Deginbali, gwen egi bar-binsalesurbalid.
\v 6 Ar e-daedi, e-sabguedi, e-sae-itogedi, ibmarbina-sulibinsa-itogedi, burgwisadgi, bergusiid. Ar we-napneggi, gannar weyob-guoedgi-binsaodeeye bar binsamaiosulid.
\p 
\v 7 ¡Weligwaledgi mas be gunne! ¡Yeer-itogedgi vino be gobbali! Ar Bab-Dummad be-ibmar-imaksadi, yeer be-ibe daksad.
\v 8 Na be mor-dagudikmaladbi yodigu guo, gwallu-wawad nonogi be magakwaa-gudigu guo.
\v 9 Na be ome-bela-bela-abegedbogwa, bane-bane wergudii gusun. Ar Bab-Dummad, we-napneggi sikwas-gudiguega be-imaksad. We-napneggi, ibagan-gwen-nabir-nanamaisursoggu, na be wegi wergudii gusun. We-napneggi-alamakdiid-nukad, we-werguedi wis bega uklesad.
\v 10 Ibu-ibmar-imaked bega uklenonikile, imakedse be sao, melle be imaksuli guo. Ar be burgwisardi bar arbaosulid, ibmar-wisguleged-igar surbalid, degi, binsaed-nikagued-igar surbalid.
\s1 Garganguedba binsaed-nikaa-ibmar-imakleged bur nuedid
\p 
\v 11 We-napneggi an negdaknonibalid:
\q1 Abarmaklegedgi-bengulegedgi dule-sabsur-abarmakedbi emargi obinsulid.
\q2 Bila-onolegedgi dule-gargangued-nikadbi emargi obinsulid.
\q1 Dule-binsaed-ibedbi mas gunsulid.
\q2 Dule-ibmar-wisirbaadbi mani-ibedga gusulid.
\q2 Dule-nue-garda-wismaladbi e-bina soglesulid.
\q1 Ar bela dulemarga, imbagwenale, ibagan-nued ega nonidaed,
\q2 imbagwenale, ibagan-isgana ega nonidabalid.
\p 
\v 12 Deginbali, an daksabalid, dule na e-burgoed-ibagan wissurbalid. Uamar-sakigi-galedamaladyob gued, sikwimar-galedamaladyob gued. Ar dulemar ukiagwar boniganse galeardamogad.
\p 
\v 13 We-napneggi an we-ibmar-daksabalid, egi an nue-durdaksabalid:
\v 14 Neggwebur-bipigwadi dulemar-iche-nika an daksad. A-neggweburgine, rey-buledi neggwebur-suega e-sordamarbo ebiris ambikunoni gusad. We-rey, e-sordamarbo, neggweburgi-dogega dikarba napa arsanyob onakwismalad.
\p 
\v 15 We-neggweburgine, dule-wileged gudiid. We-dulede, dule-binsaed-ibedid. We-dule, e-binsaed-nikadbali, neggwebur-bendaksa gusad. Degi-inigwele, dulemala we-dulegi gwen binsassurmalad.
\p 
\v 16 Andi sogdo: “Dule-wileged-e-binsaed-nikad isdar-daklege-inigwele, deginbali, e-sunmaked itolebisuli-inigwele, ‘ar garganguedba binsaed-nikaa-ibmar-imaklegedi, bur nuedye.’ ”
\q1 
\v 17 Dule-binsaedsulidamalad-e-dummad binnasuli-sunmakedba,
\q2 dule-binsaed-ibed-binnasdikii-sunmaked bur nabir itoleged.
\q1 
\v 18 Gingimarba, binsaed-nikagued bur sunsogedid.
\q2 Ar dule ibmar-soggwengi wis nosale, bela ibmar oichoged.
\c 10
\s1 Binsaed-nikagued sunmaknaid
\q1 
\v 1 Gukur-burgwaled neg-nunu-yapanne imaked,
\q2 degidbali, ina-wawa-sobed-ibe ina-wawadikid oichoged.
\q1 Deyobi, gaya-isgana-sunmakleged, bela dule-binsaed-ibed-e-sunmaked oichoged,
\q2 e-nug-nued oichobalid.
\b
\q1 
\v 2 Dule-binsaed-ibed-e-gwage ibmar-nued-imakedgi binsaed.
\q2 Dule-binsaedsulidaed-e-gwagedina, ibmar-isgana-imakedgi binsaed.
\b
\q1 
\v 3 Dule-binsaedsulidaed, ar ibu imakalile, e-ibmar-imakedgi magasar na oyoged,
\q2 ede, dule-binsaedsulidye.
\b
\q1 
\v 4 Dule-sapin-dummad-negsemaid bese ulualile, mer be abin-imakdebin sao.
\q2 Ar san-bargaagwar-imaklegedi, bukidar ibmar-noar-imakleged bargaed.
\b
\p 
\v 5 We-napneggi-gudiidgine, an daksabalid, sapin-dummagan-negsemamaidi, weyob ibmar noar-imakdimalad:
\v 6 Dule-binsaedsulidaedgala, aka arbaed-nuegan ukleged. Ar dule-bur-nabir-binsamaladgardina, arbaed-baisulid ega ukleged.
\v 7 An daksabalid, dule-maiga-gudimaladi, moli-birgi-sii gudidamalad. Ar dule-nuga-nikamaladdina, maiga-gudiiyob nagab galitodidamalad.
\b
\q1 
\v 8 Dule yaa-matusur-akwisdibe, sunna egi argwaned.
\q2 Dule gagan-matusulid-eminaidibe, sunna dubgi warmaked.
\b
\q1 
\v 9 Dule, akwa mamarye-sogdibe, sunna akwagi nailikgued.
\q2 Dule sapan mamarye-sogdibe, sunna e-dargagi makleged.
\b
\q1 
\v 10 Ar akan e-nugar-berguddibe, e-nugar ebillesurbardibe, ibmar-sikegala, sabsur achiklegergebed.
\q2 Binsaed-nikaguedgi ibmar-imaklegedi, nuekwagwadgi-ibmar-imaklegedi, ibmar-nued amileged.
\b
\q1 
\v 11 Ar naibe gar-ogoledba-ododoleged-iduar, dule-ega-gar-ogoledgi warmaksadibe,
\q2 dule gwen egi bar mani amiosulid.
\b
\q1 
\v 12 Dule-binsaed-ibed-e-sunmaked yeer itoledaed,
\q2 dule-binsaedsulidaed-e-sunmakeddina, na dukin egi aibined.
\q1 
\v 13 Dule-binsaedsulidaed gebe sunmakdele, e-gaya-miedi, gwen nabir sunmaksulid.
\q2 Deyob gaya-nuedsuli e-sunmaked obeloddaed.
\q2 
\v 14 Degite, sunmaknaigusale, gayaburbamar suli-suli amisulid.
\b
\q1 Dule neg-guoed gwen wissulid.
\q2 Yoedse ibmar-danibaloed gwen-wissurbalid.
\q2 Ar dule, we-ibmar, gwen wisguosulid.
\b
\q1 
\v 15 Dule-binsaedsulidaed, arbaedgi baisursunna yegued.
\q2 Neggweburse-naed-igarbela wissurbalid.
\b
\q1 
\v 16 Rey amba nuchukwagwar, neggwebur, wilesdakledaed.
\q2 Degine, e-sapingan-dummaganmoga, unnila wakdaradba iba-onogedgi arbadidamalad,
\q2 deyob osedoddamalad.
\b
\q1 
\v 17 Neggwebur-e-rey dule-nuga-nikaddibe, we-neggweburgi ise-nued binsalesad.
\q2 Degine, e-sapin-dummagandina, e-wachiba na mas-gunmalad,
\q1 deyob na niga-ogannomalad.
\q2 Mumguega ambikusurmalad.
\b
\q1 
\v 18 Wiedba neg-uas-nudaklesulile, neg-uas ayariddaed,
\q2 degine, wiedgi-neg-soblesadbali, neg maluddaed.
\b
\q1 
\v 19 Wergulegegala, masgulleged-iba onoleged, yeer-itolegegala, vino goblebalid.
\q2 We-ibmar-imakegala, mani abeleged.
\b
\q1 
\v 20 Reygi mer be ichakwa sunmako,
\q2 mer egi be ichakwa binsabalo.
\q1 Deginbali, dule-mani-ibedgine, mer egi be arbakee isdar sunmakbalo.
\q2 Ar sikwimar-gudidiid sunna be-barsoged,
\q1 ar sikwimarde sakan-nika nanaed,
\q2 degisoggu, baisursunna gayamar berbeged.
\c 11
\s1 Binsaed-nikadgi-itoakwaa-ibmar-imakleged ibnuedid
\q1 
\v 1 Diaki be-madu be mete,
\q2 yoedsega be gannar amioed.
\b
\q1 
\v 2 Be-ibmar-nikad, dule-walaguglega (7) be uke, dule-walabaabakadse (8) ega be ukodibe.
\q2 Ar yoedsega we-napneggi bonigan-gwisgunonikoed be wissulid.
\b
\q1 
\v 3 Mogirmar gudure-naddibe,
\q2 dii wiardaed.
\q1 Sapi dad-nakwed-argan-sapiledsik ailaddibe,
\q2 dad-nakwed-argan-nuedsik ailaddibe,
\q2 ar agi megodo.
\b
\q1 
\v 4 Dule unnila burwa-goledginbi atakdidibe,
\q2 ibmar-gwag digosurguoed.
\q1 Dule mogirmarginbi atakdidibe,
\q2 ibmar-gwag weosurguoed.
\p 
\v 5 Ar be wissulid, bia burwamar naddae. Be wissurbalid, igi mimmi sapidukugi-mege, degi, igi dungumaidabali. Degisoggu, ar bela Bab-Dummad-e-ibmar-imaked-bursunna, igi be wisguosunna. Geg be wisgued.
\p 
\v 6 Wakudaryala ibmar-gwag be digo, sedogidbali, be baid digbalo. Ar be wissulid, biti bur bega nabir igarga gudoe, wakudaryala-diglesaddibe, sedo-diglesaddibe. Ar wisgulesulid, biti nabir igarga gudodibe. Ar ebobela sanmakdebalodibe.
\p 
\v 7 Neg-meegwadi yeer emar-imaked. Dad-ibeler-gaedi weligwar emar-imaked.
\v 8 Amba dule undar seredi-megye-sogele, degine, e-ibagangi wergudigus-inigwele, ebinsao, ibagan-bulegan-bukidar itodii gubaloed. Deginbali, bela ibmar-danikoedi, gwen nabirsulid.
\s1 Be-Bab-Dummad-be-obinnisad be ebinsao
\p 
\v 9 Machi-sapin, sapingwa-guedgi gatik be werguo. Nuchukwagwadgi na be yeer-itodii imako. Be-gwage-itogedba na be ibmar imako, be-ibyagwar-neg-dakdiidba na be ibmar-imakbiedba imako. Degi-inigwele, be ebinsao, Bab-Dummad ar bela be ibmar-imaked, wilubdaknonikoed.
\p 
\v 10 Degisoggu, urwed be iego, ibmar-isgana-imaked be iebalo. Be ebinsao, ar sapingudanikidgine, degi, sapingwagwadgine, amba aku neg-itoleged-ibaganad. Ar we-igar gwen-nabirsulid.
\c 12
\s1 Sered-ugakgusadgi egi-ibmar-guoed
\q1 
\v 1 Sapingwa-gudiidgi Bab-Dummad-be-obinnisad be ebinsao.
\q2 Ibagan-bulegan-danikoed-idu, Bab-Dummad be ebinsao.
\q1 Ar birgamar-bulegan-nonikile, be sognonikoed:
\q2 “An-seredgussoggu, ibmar-nuegangi bar an wergudisurye.”
\q1 
\v 2 Dad-ibeler-gaed bar be itogosulid-iduale,
\q2 Bab-Dummad-be-obinnisad be ebinsao.
\q1 Nii-gaed bar be daksuliguoed-iduale,
\q2 Bab-Dummad-be-obinnisad be ebinsao.
\q1 Niisgwamar-gaed bar be daksuliguoed-iduale,
\q2 Bab-Dummad-be-obinnisad be ebinsao.
\q1 Bega dii-dummad-wisad-sorba, gannar mogirmar-nagunonikoedyob-guoed-iduale,
\q2 Bab-Dummad-be-obinnisad be ebinsao.
\q1 
\v 3 Ibagwengine, be-argan, neggi-nakulemaladyob-gued wawanmakdoed,
\q2 be-mali, bila-onomalad-dulemaryob-gued nollomakdoed.
\q1 Be-nugarmar ibmar-gwag-naged-akwamaryob-gued,
\q2 ichegusadbali, bar ibmar bayogosulid.
\q1 Be-ibya, yawagak-seniganaba-atakmaladyob-gued,
\q2 bar atakosulid.
\q1 
\v 4 Be-uaya, yawagak-neg-imbamaryob-gued, atudoed.
\q2 Bega ibmar-gwag-naged-akwamar-goled, boggumai gudoed.
\q1 Bega sikwimar-namaked bergudoed,
\q2 bela namakmalad bar be itogosulid.
\q1 
\v 5 Neg-matusulidgi-nanalegedgi be dobe itononikoed,
\q2 igarba-bonisar-nanalegedgi dobe be itononibaloed.
\q1 Be-sailagia, ibmar-durba-sibudiksiiyob osibumakdoed.
\q2 Ses-nanaeyob arbaed-dummad be nanadii guoed.
\q1 Ibmar-gullegedi, bar bega nued-gulle gunonikosulid.
\q2 Ar ade, dule degisadegu-yoggued-negse nadapid,
\q1 bar gannar dagegarsulid.
\q2 Bega-dule-bomaladdi, galimba-ebiris obiryamakdoed.
\b
\q1 
\v 6 Mani-dub-itired-idu, or-nog-mared-idu,
\q2 Bab-Dummad-be-obinnisad be ebinsao.
\q1 Dii-weenaidgi mete-mared-idu, dii-weed-bipirmaknaid-bibisged-idu,
\q2 Bab-Dummad-be-obinnisad be ebinsao.
\q1 
\v 7 Ar napagi be danisoggu, napaga be gannar binnidoed.
\q2 Be-burbadi gannar Bab-Dummadse naoed.
\q2 Ar Bab-Dummad bega burba-uksadid.
\b
\q1 
\v 8 Odurdaked-saila weyob soged:
\q2 “We-napneggi-ibmar-imaklegedi, binsarsunna imakleged,
\q2 bela igarga gwen gusulid.”
\ms1 3. SUNMAKLESAD-E-BURBA
\mr (12:9-14)
\p 
\v 9 Odurdaked-saila, binsaed-ibedbar-inigwele, dulemar-odurdakdii gusbalid. Bela nue-ibmar-balaminai gualid, sogedba balaminai gusad. Deginbali, binsaed-nuegan-narmaksad bukidar ilemaknai gusbalid.
\v 10 Odurdaked-saila gayaburba-nuegan ise-amiar imaksagusad. Degine, gayaburba-nuegan innikigwadba narmaksa gusad.
\p 
\v 11 Dule-binsaed-ibegan-e-sunmakedi, gammi ur-semaidaebayobi, emar-nied. E-binsaed-nuegan-onmaksadi, buarmar-neg-ganikidyob gued. We-binsaed-nuegan, Bab-Dummadgi danikid.
\v 12 Machi, egi be binsabaliga napi an bega sogbargwelo: Gardamar-bukidar-narmakleged berguosulid, degine, gardamar-doggus-durdaklegedi, dulega geg-gued uked.
\p 
\v 13 We-ibmar-sunmaklesad, wese bergunonisunnad: Unnila be Bab-Dummad-dobekwaa-gudii nanao, e-Igarmar-Mamaidba be ibsao. Ar dulega, we-ibmarbi unnila ibnuedga gued.
\v 14 Ar ibmar-nued-imaklesadi, ibmar-isgana-imaklesadi, Bab-Dummad bela wilubdaknonikoed. Amba ibmar dukuar-imaklesdibe, bela wilubdakbaloed.
