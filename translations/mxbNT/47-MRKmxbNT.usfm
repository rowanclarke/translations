\id MRK  
\h San Marcos 
\toc1 To̱ꞌon yóꞌo kía̱n ni̱ taa San Marcos, ña̱ káꞌa̱n saꞌa̱ Jesús 
\toc2 San Marcos 
\toc3 Mr. 
\mt1 To̱ꞌon yóꞌo kía̱n ni̱ taa San Marcos, ña̱ káꞌa̱n saꞌa̱ Jesús 
\c 1  
\s1 Diꞌa ni̱ kuu, dá ni̱ ka̱sáꞌá kásto̱ꞌon Juan ña̱ kasaa̱ Jesús 
\p  
\v 1 Diꞌa ni̱ ka̱sáꞌá to̱ꞌon va̱ꞌa saꞌa̱ Jesucristo, na̱ kúú de̱ꞌe Ndios.  
\v 2 Isaías ni̱ sa̱ kuu iin profeta, táꞌa̱n na̱ sa̱ ka̱sto̱ꞌon xíꞌín ña̱yuu ña̱ ni̱ kaꞌa̱n mií Ndios xíꞌín ná. Diꞌa kuaꞌa̱n to̱ꞌon ni̱ taa na: 
\q1 Ná koꞌi̱n tandaꞌí iin ta̱a kuió no̱ó koꞌo̱n noo̱ yo̱ꞌó kasto̱ꞌon ra to̱ꞌon yuꞌu̱ xíꞌín ña̱yuu, 
\q1 dá ná kandei nduu na̱ kueídóꞌo na ña̱ kía̱n koꞌo̱n kaꞌo̱n xíꞌín ná. 
\q1  
\v 3 Kayuꞌú ta̱a ñoó noo̱ kúú yukú ichí: 
\q1 “Kandei nduu ndo̱ natiin ndó satoꞌo yo̱ Ndios, ta ná konó ndó iin ichí ndaa̱ noo̱ ná.” 
\p  
\v 4 Ta miía̱n ndaa̱ dión ni̱ kuu, chi̱ ni̱ ka̱sáꞌá iin ta̱a naní Juan dákodo̱ ndúta̱ ná ña̱yuu ini ta̱kui̱í iin xíán noo̱ kúú yukú i̱chí. Ta kásto̱ꞌon na xíꞌín ña̱yuu ña̱ ná nandikó iní na̱ saꞌa̱ kua̱chi kée na, dá ná ki̱ꞌo káꞌano ini Ndios sa̱ꞌá kua̱chi na, dá ná kuu kodo̱ ndúta̱ ná. 
\p  
\v 5 Ta kua̱ꞌá nda̱ꞌo ña̱yuu ndéi ñoo Jerusalén xíꞌín na̱ ndéi dao ka̱ ñoo kuálí ñóꞌo chí kuendá Judea ni̱ saꞌa̱n na̱ ni̱ seídóꞌo na to̱ꞌon dánaꞌa̱ Juan. Ta ni̱ naꞌo̱ na̱ kua̱chi na noo̱ Ndios. Ta kúú ni̱ da̱kódo̱ ndúta̱ ñaá Juan ini yu̱ta naní Jordán. 
\p  
\v 6 Ta dáꞌo̱n ni̱ sa̱ ndixi Juan ni̱ ka̱va̱ꞌa xíꞌín ídi̱ camello. Ta iin cincho ñíi̱ sa̱ ndíko̱ ti̱i na. Ta sa̱ seí na̱ ti̱ka xíꞌín ndu̱dí yukú.  
\v 7 Ta sa̱ ka̱sto̱ꞌon na xíꞌín ña̱yuu, ta kaá na̱ xíꞌín ná: 
\p ―Sa̱tá yuꞌu̱ ve̱i iin na̱ ndáya̱ꞌi cháá ka̱ o̱ du̱ú yuꞌu̱, chi̱ ni ko̱ káni vía̱n nakuii̱n ndei yuꞌu̱ ndaxíí yóꞌo̱ ndisa̱ ná.  
\v 8 Chi̱ yuꞌu̱ dákodo̱ ndúta̱ ñaá xíꞌín ta̱kui̱í, tído no̱ón kúú na̱ dákodo̱ ndúta̱ ñaá xíꞌín na̱ kúú Espíritu ii̱ Ndios ―kaá na̱. 
\s1 Diꞌa ni̱ kuu tá ni̱ sodo̱ ndúta̱ Jesús 
\p  
\v 9 Ta tein kuu̱ dáá ñóó ni̱ keta Jesús ñoo naní Nazaret, ña̱ nákaa̱ kuendá Galilea, kuaꞌa̱n na̱ noo̱ nákaa̱ yu̱ta Jordán. Ta ñoó ni̱ da̱kódo̱ ndúta̱ ñaá Juan.  
\v 10 Tá ni̱ ke̱ta Jesús ini ta̱kui̱í, kúú ni̱ xini na̱ ni̱ nono̱ induú. Ta kúú ni̱ na̱xino̱ na̱ kúú Espíritu Ndios sata̱ ná, ta káa na̱ táto̱ꞌon káa iin paloma.  
\v 11 Ta nda̱ induú tái̱ ni̱ kaꞌa̱n Ndios xíꞌín Jesús: 
\p ―Yoꞌó kúú de̱ꞌe mani̱ yuꞌu̱. Ta nátaꞌan nda̱ꞌo inii̱ xiníi̱ yo̱ꞌó ―kaá na̱. 
\s1 Diꞌa ni̱ kuu tá ni̱ kaꞌán ña̱ uꞌu̱ mií no̱ó dátu̱úán Jesús 
\p  
\v 12 Tá ni̱ ndiꞌi ñoó, dá ndáka Espíritu Ndios Jesús kuaꞌa̱n na̱ noo̱ kúú yukú ichí.  
\v 13 Ta uu̱ diko kuu̱ ni̱ sa̱ káa̱ na̱ ñoó. Ta ni̱ sa̱ káa̱ na̱ tein kirí víchi̱ dee̱n. Dá ni̱ xirndodó ñaá ña̱ uꞌu̱. Ta ni̱ ka̱sáa̱ dao ángel ni̱ kii noo̱ Ndios, ni̱ chi̱ndeé ná Jesús. 
\s1 Diꞌa ni̱ kuu tá ni̱ ka̱sáꞌá dánaꞌa̱ Jesús sa̱ꞌá to̱ꞌon va̱ꞌa Ndios 
\p  
\v 14 Tá ni̱ tiin ra Juan ni̱ sadi ra̱ veꞌe ka̱a, dá ni̱ kee Jesús kuaꞌa̱n na̱ chí kuendá Galilea kasto̱ꞌon na saꞌa̱ to̱ꞌon va̱ꞌa, ña̱ káꞌa̱n saꞌa̱ ndi kee ña̱yuu, dá ndu̱ꞌu na ti̱xi ndáꞌa̱ Ndios,  
\v 15 ta kaá na̱: 
\p ―Sa̱ ni̱ kasa̱ndaá vá hora, sa̱ ni̱ ku̱yati va ña̱ ndu̱ꞌu ña̱yuu ti̱xi ndáꞌa̱ Ndios. ¡Nandikó iní ndo̱ sa̱ꞌá kua̱chi kée ndó, ta kandísa ndó xíꞌín ndinoꞌo ini ndo̱ to̱ꞌon va̱ꞌa Ndios! ―kaá na̱. 
\s1 Diꞌa ni̱ kuu, dá ni̱ kana Jesús komi̱ ta̱a tíin ti̱yaká ña̱ kanoo ra xíꞌín ná 
\p  
\v 16 Ta noo̱ xíka Jesús kuaꞌa̱n na̱ yúꞌu̱ ta̱ñoꞌo̱ naní Galilea, ñoó ni̱ xini na̱ iin ta̱a naní Simón xíꞌín ñani ra̱ Andrés. Ta ñóꞌo ra chíkaa̱ ra̱ ñóno̱ rá ini ta̱kui̱í, chi̱ kúú rá ta̱a tíin ti̱yaká.  
\v 17 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Ná kíi̱ ndo̱ ná koꞌo̱ kanoo ndó xíꞌín yuꞌu̱, dá ná dánaꞌi̱ noo̱ ndo̱ taó ndó ña̱yuu tein kua̱chi na táto̱ꞌon kée ndó taó ndó ti̱yaká ini ta̱kui̱í. 
\p  
\v 18 Ta kúú vitíꞌón vá ni̱ da̱nkoo ra ñóno̱ rá. Ta kúú ni̱ kee ra kuaꞌa̱n ra̱ kanoo ra xíꞌín Jesús. 
\p  
\v 19 Ta noo̱ xíka Jesús kuaꞌa̱n na̱ cháá ka̱ chí noo̱ ñoó, kúú ni̱ xini na̱ nákaa̱ iin ta̱a naní Jacobo xíꞌín ñani ra̱ Juan, ta kúú rá de̱ꞌe ta̱ naní Zebedeo. Ta ñóꞌo ra ini barco nákoto ra̱ ñóno̱ rá.  
\v 20 Dá ni̱ kana ñaá ná. Dá ni̱ da̱nkoo ra tatá ra̱ Zebedeo ini barco xíꞌín ndidaá ka̱ ni ta̱a kéchóon noo̱ tatá ra̱. Dá ni̱ kee ra kuaꞌa̱n ra̱ kanoo ra xíꞌín ná. 
\s1 Diꞌa ni̱ kuu tá ni̱ ndu̱va̱ꞌa Jesús iin ta̱a nákaa̱ iin espíritu kini 
\p  
\v 21 Dá ni̱ na̱sáa̱ Jesús ñoo Capernaum xíꞌín ta̱a ñoó. Dá tá ni̱ kasa̱ndaá kuu̱ nániꞌi̱ ndée̱ na̱ Israel, dá ni̱ ku̱ꞌu Jesús ini veꞌe noo̱ nátaka na̱ ñoo ñoó. Dá ni̱ ka̱sáꞌá ná dánaꞌa̱ na̱.  
\v 22 Kúú ni̱ naá vá iní ña̱yuu ñoó sa̱ꞌá ña̱ dánaꞌa̱ Jesús, chi̱ ko̱ kée na táto̱ꞌon kée ta̱a dánaꞌa̱ ley Moisés, dá chi̱ dánaꞌa̱ na̱ táto̱ꞌon ki̱ꞌo kée iin na̱ néꞌe choon. 
\p  
\v 23 Ta ini veꞌe ñoó nákaa̱ iin ta̱a nákaa̱ iin espíritu kini. Ta kúú ni̱ꞌi nda̱ꞌo ni̱ ka̱yuꞌú espíritu kini ñoó, ta kaáa̱n: 
\p  
\v 24 ―¿Ndi ki̱án ndóꞌo ní xíꞌín nduꞌu̱, Jesús, na̱ ñoo Nazaret? ¿Á ve̱i ní dánaá ní nduꞌu̱? Sa̱ náꞌá vá yuꞌu̱ ndá yoo kúú mií ní, chi̱ mií ní kúú na̱ ii̱ ni̱ kii noo̱ Ndios. 
\p  
\v 25 Dá ni̱ da̱náni ñaá Jesús, ta kaá na̱ xíꞌán: 
\p ―¡Kadi yúꞌo̱n! ¡Kuaꞌán keta kíi̱ ini ta̱a xaa̱n! 
\p  
\v 26 Ta kúú vitíꞌón ni̱ saꞌání yi̱ꞌí espíritu kini ta̱a ñoó. Ta kúú ni̱ꞌi nda̱ꞌo ni̱ ka̱yuꞌán, dá ni̱ ketaan kuaꞌa̱n. 
\p  
\v 27 Ta kúú ni̱ naá vá iní ndidaá kúú ña̱yuu ñoó, dá ni̱ ka̱sáꞌá ná ndátóꞌón táꞌan ná: 
\p ―¿Ndi kuaꞌa̱n vía̱n yóꞌo? Na̱ ndeé ka̱ vía̱n káꞌano ta̱ndeé iní sa̱á dánaꞌa̱ ta̱a káa, chi̱ xíꞌín choon kómí rá saꞌándá ra̱ choon noo̱ espíritu kini, ta kúú seídóꞌo ñaa̱n ―kaá na̱. 
\p  
\v 28 Ta kúú kaon nda̱ꞌo ni̱ ka̱ndaa̱ ini ndidaá ña̱yuu ndéi ñoo kuálí ñóꞌo chí kuendá Galilea saꞌa̱ ña̱ ndato ni̱ kee Jesús. 
\s1 Diꞌa ni̱ kuu tá ni̱ ndu̱va̱ꞌa Jesús ñá kúú xi̱do Simón Pedro 
\p  
\v 29 Tá ni̱ keta Jesús veꞌe ñoó, dá ni̱ kee na kuaꞌa̱n na̱ veꞌe Simón xíꞌín Andrés, ta ndáka taꞌani na Jacobo xíꞌín Juan kuaꞌa̱n na̱.  
\v 30 Ta kánduꞌu̱ xi̱do Simón noo̱ xíto, ta kaꞌí nda̱ꞌo ndóꞌán kée kueꞌe̱ dáa̱. Dá ni̱ ka̱sto̱ꞌon ña̱yuu xíꞌín Jesús ña̱ kúꞌa̱n.  
\v 31 Dá ni̱ na̱tuu yati na noo̱ kánduꞌa̱n. Kúú ni̱ tiin na ndáꞌa̱n. Kúú ni̱ nda̱neꞌe ñaá ná. Ta kúú vitíꞌón vá ni̱ ya̱ꞌa kueꞌe̱ dáa̱ ñoó. Ta kúú ni̱ ka̱sáꞌá váán kénduua̱n ña̱ kasáꞌan na. 
\s1 Kua̱ꞌá nda̱ꞌo ña̱yuu ni̱ ndu̱va̱ꞌa Jesús 
\p  
\v 32 Sa̱ ni̱ keta va ndi̱ndii, ta sa̱ kuaꞌa̱n kuaá vá kuu̱ dáá ñóó, dá ndáka ña̱yuu ndidaá na̱ kúꞌu̱ xíꞌín na̱ ñóꞌo espíritu kini ni̱ ka̱sáa̱ na̱ noo̱ Jesús.  
\v 33 Sa̱ꞌá ño̱ó ni̱ chití yéꞌé veꞌe ñoó ni̱ na̱taka ndidaá na̱ ñoo ñoó.  
\v 34 Ta kúú kua̱ꞌá nda̱ꞌo ña̱yuu ndóꞌo iin rá iin kueꞌe̱ ni̱ ndu̱va̱ꞌa na, ta kua̱ꞌá nda̱ꞌo espíritu kini ni̱ taó ná. Ta ko̱ sónó vá ná ña̱ kaꞌa̱n espíritu kini ñoó, chi̱ náꞌá vá ñá ndá yoo kúú ná. 
\s1 Diꞌa ni̱ kuu tá ni̱ nda̱tóꞌón Jesús xíꞌín tatá Ndios iin xíán no̱ó ko̱ íin ndéi 
\p  
\v 35 Ta naꞌa nda̱ꞌo ni̱ nda̱ko̱o Jesús, chi̱ íin naá i̱í vá. Dá ni̱ keta na ñoo ñoó kuaꞌa̱n na̱ iin xíán no̱ó ko̱ íin ndéi. Ta ñoó ni̱ kaꞌa̱n na̱ xíꞌín tatá Ndios.  
\v 36 Dá ni̱ kee Simón xíꞌín dao ka̱ ta̱ néꞌe táꞌan xíꞌín rá kuaꞌa̱n ra̱ nandukú ñaá rá.  
\v 37 Dá tá ni̱ na̱níꞌi̱ ñaá rá, dá ni̱ kaa ra̱ xíꞌín ná: 
\p ―Ndidaá ña̱yuu nándukú ná mií ní. 
\p  
\v 38 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Ná koꞌo̱ dao ka̱ xíán noo̱ yati yóꞌo, dá ná dánaꞌa̱ taꞌani yuꞌu̱ no̱ó ña̱yuu ndéi ñoó, chi̱ sa̱ꞌá choon yóꞌo ve̱i yuꞌu̱ ―kaá na̱. 
\p  
\v 39 Ta ni̱ xi̱onoo na iin níí kúú kuendá Galilea ni̱ da̱náꞌa̱ na̱ ini ndidaá veꞌe noo̱ nátaka na̱ Israel, ta ni̱ taó ná espíritu kini ñóꞌo ini ña̱yuu. 
\s1 Diꞌa ni̱ kuu tá ni̱ ndu̱va̱ꞌa Jesús iin ta̱a ndóꞌo kueꞌe̱ téíꞌi̱ ñíi̱ 
\p  
\v 40 Kúú ni̱ ka̱sáa̱ iin ta̱a ndóꞌo kueꞌe̱ téíꞌi̱ ñíi̱ noo̱ Jesús. Kúú ni̱ sa̱ kuíi̱n xi̱tí rá noo̱ ná, dá ni̱ kaa ra̱ xíꞌín ná: 
\p ―Tá kóni̱ ní, kuu va nduvii ní ñíi̱í ―kaá ra̱. 
\p  
\v 41 Ta sa̱ꞌá ña̱ ni̱ kuꞌu̱ ini Jesús saꞌa̱ rá, sa̱ꞌá ño̱ó ni̱ chi̱nóo na ndáꞌa̱ ná sata̱ rá, dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Jaa̱n, kóni̱i̱. Ná nduvií ñíi̱o̱n. 
\p  
\v 42 Dá tá ni̱ ndiꞌi ni̱ kaꞌa̱n na̱, kúú vitíꞌón diꞌa ni̱ nda̱ñóꞌó niꞌini kueꞌe̱ téíꞌi̱ ndóꞌo ra. Ta kúú ni̱ ka̱ndo̱o vii vá ñíi̱ rá. 
\p  
\v 43 Dá tá ko̱ ñáꞌa̱ tandaꞌá ñaá ná koꞌo̱n ra̱, dá ni̱ saꞌanda na̱ choon noo̱ rá,  
\v 44 ta kaá na̱ xíꞌín rá: 
\p ―Kuaꞌán, tído o̱ sa̱ nákanón xíꞌín ni iin tóꞌón ña̱yuu ña̱ ni̱ keei xíꞌón. Diꞌa kuaꞌán naꞌa̱ miíón no̱ó ta̱ duti̱. Ta kuaꞌán doko̱ ña̱ꞌa noo̱ Ndios sa̱ꞌá ña̱ ni̱ ka̱ndo̱o viio̱n noo̱ ná, táto̱ꞌon ki̱ꞌo saꞌándá ley Moisés choon, dá ná kandaa̱ ini ra̱ ña̱ sa̱ ni̱ ndu̱viio̱n ―ka̱á na̱. 
\p  
\v 45 Tído ko̱ ní kée taꞌon ta̱a ñoó táto̱ꞌon ni̱ taꞌa̱nda̱ choon noo̱ rá. Diꞌa ni̱ ka̱sáꞌá nákani va ra ña̱ ni̱ kee Jesús xíꞌín rá kuaꞌa̱n ra̱. Sa̱ꞌá ño̱ó ko̱ ku̱ú ka̱ ku̱ꞌu túu Jesús ni iin ka̱ ñoo. Nda̱dá yuꞌú ñoo no̱ó ko̱ó ka̱ ña̱yuu ndéi va sa̱ káa̱ na̱. Ta va̱ꞌará ndeí kúú míí vá ndéi ña̱yuu, tído ve̱i na noo̱ nákaa̱ Jesús. 
\c 2  
\s1 Diꞌa ni̱ kuu, dá ni̱ ndu̱va̱ꞌa Jesús iin ta̱a ni̱ na̱tií saꞌa̱ 
\p  
\v 1 Tá ni̱ ya̱ꞌa dao kuu̱, dá ni̱ na̱ndió ko̱o tuku Jesús ñoo Capernaum. Tá ni̱ ka̱ndaa̱ ini ña̱yuu ña̱ ni̱ ndi̱sáa̱ Jesús veꞌe na,  
\v 2 kúú kua̱ꞌá nda̱ꞌo na ni̱ na̱taka ñoó. Ta ko̱ ní kéta ka̱ veꞌe ñoó kañoꞌo na. Ta kúú nda̱ sata̱ véꞌe ndíta ña̱yuu seídóꞌo na to̱ꞌon dánaꞌa̱ Jesús. 
\p  
\v 3 Dá ni̱ ka̱sáa̱ dao ka̱ ña̱yuu xíꞌín iin ta̱a ni̱ na̱tií saꞌa̱, ta yíꞌi ñaá komi̱ ta̱a ni̱ ka̱sáa̱ ra̱.  
\v 4 Tído ko̱ ní kúu taꞌon ku̱ꞌu ra xíꞌín ta̱ kúꞌu̱ ñoó ini veꞌe noo̱ nákaa̱ Jesús, chi̱ kua̱ꞌá nda̱ꞌo ña̱yuu ñóꞌo. Sa̱ꞌá ño̱ó ni̱ da̱káa ñaá rá dini̱ véꞌe. Dá ni̱ sonó rá iin yái̱. Dá ni̱ kuu ni̱ da̱nóo ra xi̱to kánóo ta̱ kúꞌu̱ ñoó ini veꞌe noo̱ ió Jesús. 
\p  
\v 5 Tá ni̱ xini Jesús ña̱ kándéé ini ñaá rá, dá ni̱ kaa na̱ xíꞌín ta̱ ko̱ ku̱ú kaka ñoó: 
\p ―De̱ꞌe lóꞌo̱, sa̱ ni̱ ndoo va kua̱chón ―ka̱á na̱. 
\p  
\v 6 Ta kúú ñoó ndéi dao ta̱a dánaꞌa̱ ley Moisés seídóꞌo ra. Dá ni̱ ka̱sáꞌá nákani kuáchi̱ ini ra̱:  
\v 7 “Ta, ¿ndiva̱ꞌa káꞌa̱n ta̱a káa dión? Ta̱a káa kúú ra̱ yáꞌa káꞌa̱n ndava̱ꞌa xíꞌín Ndios. Chi̱ ni iin tóꞌón taꞌon ta̱a o̱ kúu dándóo kua̱chi ña̱yuu. Iin tóꞌón dini̱ mií vá Ndios kúú na̱ kuu kee dión.” 
\p  
\v 8 Tído vitíꞌón diꞌa va ni̱ ka̱ndaa̱ ini Jesús ña̱ ki̱ꞌo dión nákani ini ra̱. Dá ni̱ nda̱to̱ꞌón ñaá ná: 
\p ―¿Ndiva̱ꞌa nákani ini ndo̱ dión?  
\v 9 ¿Ndí ki̱án ko̱ úꞌu̱ cháá ka̱ kaꞌi̱n xíꞌín ta̱a ko̱ ku̱ú kaka yóꞌo, káꞌán ndó? “Sa̱ ni̱ ndoo va kua̱chón”, o kaꞌi̱n xíꞌín rá, “Ndakuii̱n ndichi, ta nakiꞌin xi̱to̱n kaneꞌe kuaꞌa̱n nóꞌo̱n.”  
\v 10 Tído viti dá ná koꞌi̱n dánaꞌi̱ noo̱ ndo̱ ña̱ kómí ndisa na̱ ni̱ nduu ta̱a ña̱yuu yóꞌo choon ña̱ dándóo na kua̱chi kómí ña̱yuu ndéi ñayuú yóꞌo. 
\p Dá ni̱ kaa na̱ xíꞌín ta̱ ni̱ na̱tií saꞌa̱ ñoó: 
\p  
\v 11 ―Ta káꞌi̱n xíꞌín yo̱ꞌó viti. Ndakuii̱n ndichi, ta nakiꞌin xi̱to̱n, ta kuaꞌán nóꞌo̱n veꞌón. 
\p  
\v 12 Ta kúú ni̱ na̱kuíi̱n ndichi ra̱. Dá ni̱ na̱kiꞌin ra xi̱to no̱ó ni̱ sa̱ nóo ra néꞌe ra ni̱ kiꞌin ra kuaꞌa̱n ra̱ no̱ó ña̱yuu kuáꞌa̱ ñoó. Ta kúú ndidaá vá ná ni̱ naá iní. Ta kúú ni̱ ka̱sáꞌá ná kékáꞌano na Ndios, ta kaá na̱ diꞌa: 
\p ―Ni iin kuu̱ ko̱ xi̱nío̱ iin ña̱ꞌa ndato táto̱ꞌon ni̱ xinio̱ kuu̱ víti ―kaá na̱. 
\s1 Diꞌa ni̱ kuu tá ni̱ kana Jesús iin ta̱a naní Leví Mateo ña̱ kanoo ra xíꞌín ná 
\p  
\v 13 Tá ni̱ ndiꞌi ni̱ kuu dión, dá ni̱ na̱ndió ko̱o tuku Jesús kuaꞌa̱n na̱ yuꞌú ta̱ñoꞌo̱. Ta kúú kua̱ꞌá nda̱ꞌo ña̱yuu ni̱ na̱tuu yati ñaá. Dá ni̱ ka̱sáꞌá ná dánaꞌa̱ na̱ noo̱ ná sá xíka na kuaꞌa̱n na̱.  
\v 14 Ta noo̱ yáꞌa na kuaꞌa̱n na̱ ñoó, kúú ni̱ xini na̱ ió iin ta̱a naní Leví, de̱ꞌe ta̱ naní Alfeo, ta ió ra̱ kíꞌin ya̱ꞌi ra sa̱ꞌá ñóꞌo̱. Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Nakíi̱, ná koꞌo̱ kanoón xíꞌín yuꞌu̱. 
\p Dá ni̱ na̱kuíi̱n ndichi ra̱. Dá ni̱ kee ra kuaꞌa̱n ra̱ kanoo ra xíꞌín ná. 
\p  
\v 15 Diꞌa ni̱ kuu tein noo̱ ió Jesús sásáꞌan na xíꞌín Leví ñoó ini veꞌe ra. Ta kua̱ꞌá nda̱ꞌo ta̱a kíꞌin ya̱ꞌi sa̱ꞌá ñóꞌo̱ xíꞌín dao ka̱ ña̱yuu kaá ra̱ kómí kua̱chi ni̱ sa̱ ndei xíꞌín Jesús. Ta ndéi taꞌani ta̱a xíonoo xíꞌín ná, chi̱ kua̱ꞌá nda̱ꞌo ña̱yuu ndíko̱ ñaá.  
\v 16 Tá ni̱ xini ta̱ fariseo xíꞌín dao ta̱a dánaꞌa̱ ley Moisés ña̱ sásáꞌan dáó Jesús xíꞌín ta̱ kíꞌin ya̱ꞌi sa̱ꞌá ñóꞌo̱, xíꞌín ña̱yuu, táꞌa̱n na̱ kaá ra̱ kúú na̱ kini ñoó, dá ni̱ kaa ra̱ xíꞌín ta̱ xíonoo xíꞌín Jesús: 
\p ―¿Ndi kuaꞌa̱n ña̱ yóꞌo? ¿Ndiva̱ꞌa sásáꞌan ri maestro ndo̱ꞌó xíꞌín ta̱ kíꞌin ya̱ꞌi sa̱ꞌá ñóꞌo̱, xíꞌín dao ka̱ ña̱yuu kómí kua̱chi yóꞌo? ―kaá ra̱. 
\p  
\v 17 Tá ni̱ seídóꞌo Jesús ña̱ ni̱ kaꞌa̱n ra̱ dión, dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Na̱ ió va̱ꞌa ko̱ xínñóꞌó taꞌon na ta̱ ketátá ñaá. Sa̱va̱ꞌa na̱ kúꞌu̱ va kúú na̱ xínñóꞌó ñaá. Ta dión taꞌani yuꞌu̱, ko̱ véi taꞌon yuꞌu̱ ná kanai na̱ káꞌán ña̱ kúú ná ña̱yuu ndaa̱. Diꞌa ve̱i yuꞌu̱ kanai na̱ nákoni ña̱ kómí ná kua̱chi ―kaá na̱. 
\s1 Dánaꞌa̱ Jesús ña̱ kúú ná táto̱ꞌon iin tono̱ 
\p  
\v 18 Iin kuu̱, dá ni̱ sa̱ ndei ta̱ sa̱ xi̱onoo xíꞌín Juan, na̱ sa̱ da̱kódo̱ ndúta̱ ña̱yuu, ni̱ sa̱ neꞌe ii̱ rá xíꞌín ta̱ fariseo. Dá ni̱ ka̱sáa̱ dao ña̱yuu noo̱ nákaa̱ Jesús. Dá ni̱ nda̱to̱ꞌón ñaá ná: 
\p ―¿Ndiva̱ꞌa ko̱ néꞌe ii̱ ta̱ xíonoo xíꞌín mií ní táto̱ꞌon néꞌe ii̱ ta̱ fariseo xíꞌín ta̱ sa̱ xi̱onoo xíꞌín Juan? 
\p  
\v 19 Dá ni̱ kaa Jesús xíꞌín ná: 
\p ―¿Á káꞌán ndó ña̱ kánian kaneꞌe ii̱ ña̱yuu ni̱ na̱taka noo̱ ió vikó tándaꞌa̱ nani ió i̱í vá tono̱ xíꞌín ná? Ko̱ó, chi̱ xía̱n nani ió i̱í tono̱ xíꞌín ná, ta o̱ kúu taꞌon kaneꞌe ii̱ ná.  
\v 20 Tído kasandaá iin kuu̱, dá nakiꞌin ra tono̱ kandaka ra koꞌo̱n ra̱. Nda̱ daá ví, dá kía̱n kánian kaneꞌe ii̱ ña̱yuu ñoó. 
\s1 Dánaꞌa̱ Jesús ña̱ ko̱ nákiꞌin táꞌan taꞌon ña̱ dánaꞌa̱ na̱ xíꞌín ña̱ dánaꞌa̱ ta̱ fariseo 
\p  
\v 21 ’Ta ko̱ íin taꞌon nákoto no̱ó ni̱ ndata̱ iin doꞌo̱no̱ yatá xíꞌín iin táꞌí dáꞌo̱n sa̱á. Dá chi̱ tá ná nakata na doꞌo̱no̱ ñoó, ta kúú natiꞌin va dáꞌo̱n sa̱á ñóó, ta kúú víꞌí ka̱ ví ndata̱ doꞌo̱no̱ yatá ñóó. 
\p  
\v 22 ’Ta ko̱ íin taꞌon taán vino sa̱á ini ñíi̱ yatá. Dá chi̱ tá ná kee na dión, dá kía̱n dákaꞌándí vino sa̱á ñíi̱ yatá ñoó, ta kúú ndiꞌi vino ñoó kuita̱, ta kúú tu̱ú oon va ñíi̱ ñoó. Sa̱ꞌá ño̱ó va̱ꞌa cháá ka̱ ná taán yó vino sa̱á ini ñíi̱ sa̱á ―kaá Jesús. 
\s1 Diꞌa kuaꞌa̱n ña̱ ni̱ da̱náꞌa̱ Jesús sa̱ꞌá kuu̱ nániꞌi̱ ndée̱ na̱ Israel 
\p  
\v 23 Ta tein iin kuu̱ nániꞌi̱ ndée̱ na̱ Israel, chíkaꞌanda Jesús kuaꞌa̱n na̱ no̱ñóꞌo̱ noo̱ káa tirió. Kúú ni̱ ka̱sáꞌá ta̱ xíonoo xíꞌín ná tóꞌon ra yoko tirió, ta seí ra̱ noni̱án kuaꞌa̱n ra̱.  
\v 24 Dá ni̱ kaa ta̱ fariseo xíꞌín Jesús: 
\p ―¿Ndiva̱ꞌa kée ta̱ xíonoo xíꞌín ní ña̱ ko̱ kánian kee ra tein kuu̱ nániꞌi̱ ndée̱ yo̱? 
\p  
\v 25 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―¿Á ko̱ óon taꞌon káꞌi ndoꞌó ña̱ ni̱ kee David tá sa̱ naꞌá tá ndaꞌí ni̱ kuiko na xíꞌín ta̱ sa̱ xi̱onoo xíꞌín ná?  
\v 26 Chi̱ kaáa̱n ña̱ ni̱ ku̱ꞌu na veꞌe Ndios. Ta daá ñóó kúú ta̱a naní Abiatar duti̱ kúú no̱ó. Ta ni̱ seí David pan, ña̱ dóko̱ ta̱ duti̱ noo̱ Ndios, ña̱ ko̱ kánian keí ña̱yuu óon, chi̱ sa̱va̱ꞌa ta̱ duti̱ kuu keí ñá. Ta nda̱ ta̱ xíonoo xíꞌín David ñoó ni̱ xi̱ꞌo na ni̱ seí. 
\p  
\v 27 Dá ni̱ kaa taꞌani Jesús xíꞌín rá: 
\p ―Kuu̱ nániꞌi̱ ndée̱ yo̱ ni̱ ka̱va̱ꞌan Ndios ña̱ kakuuan iin ña̱ va̱ꞌa no̱ó ña̱yuu. Tído ko̱ ní káva̱ꞌa taꞌon Ndios ña̱yuu kekáꞌano na kuu̱ nániꞌi̱ ndée̱ yo̱ táto̱ꞌon ki̱ꞌo kée ndoꞌó.  
\v 28 Ta viti kanaꞌá ndó ña̱ ió choon noo̱ ndáꞌa̱ na̱ ni̱ nduu ta̱a ñayuú yóꞌo ña̱ dándáki na tein kuu̱ nániꞌi̱ ndée̱ yo̱ ―kaá Jesús káꞌa̱n na̱ saꞌa̱ mií ná. 
\c 3  
\s1 Diꞌa ni̱ kuu tá ni̱ ndu̱va̱ꞌa Jesús iin ta̱a ni̱ na̱tií ndáꞌa̱ 
\p  
\v 1 Dá ni̱ ku̱ꞌu tuku Jesús ini veꞌe noo̱ nátaka na̱ Israel. Ta ñoó nákaa̱ iin ta̱a ni̱ na̱tií ndáꞌa̱.  
\v 2 Ta ndíta ta̱ fariseo nání rá Jesús, ná kande̱ꞌá á nduva̱ꞌa ñaá ná kuu̱ nániꞌi̱ ndée̱ ná. Dión, dá niꞌi̱ rá ndí koo dátai̱ kua̱chi ra Jesús no̱ó ta̱ néꞌe choon. 
\p  
\v 3 Dá ni̱ kaa Jesús xíꞌín ta̱a ni̱ na̱tií ndáꞌa̱ ñoó: 
\p ―Nakuii̱n ndichi, ta ka̱kuíi̱n me̱ꞌí yóꞌo. 
\p  
\v 4 Dá ni̱ kaa na̱ xíꞌín dao ka̱ ta̱a ñoó: 
\p ―¿Ndá ki̱án kuu kee yó kuu̱ nániꞌi̱ ndée̱ yo̱? ¿Á kee yó ña̱ va̱ꞌa o á kee yó ña̱ kini? ¿Á dáka̱kió iin ña̱yuu o kaꞌání yó ná? Kaꞌa̱n ndo̱ ná nde̱ꞌá ―kaá na̱. 
\p Tído ni iin tóꞌón rá ko̱ ní káꞌa̱n.  
\v 5 Dá ni̱ kao̱ noo Jesús ni̱ sa̱ nde̱ꞌé dee̱n ná ta̱a ndíta ñoó. Dá ni̱ kixia̱n ni̱ ku̱ndaꞌí ini na̱ saꞌa̱ rá, chi̱ káxí nda̱ꞌo nío̱ rá. Dá ni̱ kaa na̱ xíꞌín ta̱ kúꞌu̱ ndáꞌa̱ ñoó: 
\p ―Ná dákaa̱ ndáꞌo̱n xaa̱n. 
\p Tá ni̱ na̱da̱káa̱ ra̱ ndáꞌa̱ rá, kúú ni̱ ndu̱va̱ꞌa vaan. 
\p  
\v 6 Dá ni̱ ka̱nkuei ta̱ fariseo ñoó kuaꞌa̱n ra̱. Ta ni̱ ka̱sáꞌá ndátóꞌón kueꞌé ra̱ xíꞌín ra̱ kuendá rey Herodes ñoó ndi kee ra, dá kaꞌání rá Jesús. 
\s1 Diꞌa ni̱ kuu tá ni̱ sa̱ káa̱ Jesús yuꞌú ta̱ñoꞌo̱ 
\p  
\v 7 Dá ni̱ kee tuku Jesús kuaꞌa̱n na̱ xíꞌín ta̱ xíonoo xíꞌín ná yuꞌú ta̱ñoꞌo̱. Ta kua̱ꞌá nda̱ꞌo ña̱yuu ndéi kuendá Galilea xíꞌín na̱ ndéi ñoo kuálí ñóꞌo chí kuendá Judea tákuei sata̱ ná kuaꞌa̱n na̱,  
\v 8 xíꞌín na̱ ndéi ñoo káꞌano Jerusalén, xíꞌín na̱ ndéi kuendá Idumea, xíꞌín na̱ ndéi iin ka̱ xoo yu̱ta Jordán, xíꞌín na̱ ndéi ñoo Tiro xíꞌín na̱ ndéi ñoo Sidón, chi̱ sa̱ꞌá ña̱ ni̱ niꞌi̱ tóꞌon na sa̱ꞌá ña̱ꞌa ndato kée Jesús, sa̱ꞌá ño̱ó kua̱ꞌá nda̱ꞌo ña̱yuu tákuei ñaá kuaꞌa̱n na̱. 
\p  
\v 9 Ta kúú ni̱ kaꞌa̱n Jesús xíꞌín ta̱ xíonoo xíꞌín ná ña̱ ná kenduu ra̱ iin barco kakaa̱ na̱, dá ná o̱ dándútí ñaá ña̱yuu kuáꞌa̱ ñoó.  
\v 10 Chi̱ sa̱ꞌá ña̱ ni̱ ndu̱va̱ꞌa na kua̱ꞌá ña̱yuu, sa̱ꞌá ño̱ó ndidaá kúú na̱ kúꞌu̱ kátai̱ táꞌan ve̱i sata̱ ná, dá kako̱ꞌon na dáꞌo̱n Jesús, dá ná nduva̱ꞌa na. 
\p  
\v 11 Ta tá ni̱ xini ñaá ña̱yuu ñóꞌo espíritu kini, ta kúú sa̱ kui̱ta xi̱tí ná noo̱ Jesús. Dá ni̱ ka̱sáꞌá káyuꞌú espíritu kini ñoó, ta kaáa̱n: 
\p ―Mií ní kúú de̱ꞌe Ndios. 
\p  
\v 12 Tído ni̱ saꞌanda Jesús choon noo̱án ña̱ ná dáꞌa ni kaꞌa̱n ndá yoo kúú ná no̱ó ña̱yuu ñoó. 
\s1 Diꞌa ni̱ kuu tá ni̱ ka̱xi Jesús uxi̱ uu̱ ta̱a kanoo xíꞌín ná 
\p  
\v 13 Ndiꞌi, dá ni̱ kaa Jesús dini̱ iin yúku̱ íin ñoó. Dá ni̱ kana na ndidaá kúú ta̱a ni̱ na̱taꞌan ini na̱, ta ni̱ na̱tuu yati ra noo̱ ió na̱.  
\v 14 Dá tein ro̱ón ni̱ ka̱xi na uxi̱ uu̱ ta̱a kanoo xíꞌín ná. Ta ta̱a yóꞌo kakuu ra̱ tandaꞌá Jesús koꞌo̱n dánaꞌa̱ to̱ꞌon va̱ꞌa no̱ó ña̱yuu,  
\v 15 ta koo taꞌani choon noo̱ ndáꞌa̱ rá ña̱ nduva̱ꞌa ra na̱ kúꞌu̱, ta taó rá espíritu kini ñóꞌo ini ña̱yuu. 
\p  
\v 16 Iin ta̱a yóꞌo naní Simón. Ta ni̱ chi̱naní ñaá ná Pedro.  
\v 17 Ta iin ka̱ ra̱ kúú de̱ꞌe Zebedeo naní Jacobo xíꞌín ñani ra̱, ra̱ naní Juan. Ta ni̱ chi̱naní ñaá ná Boanerges. To̱ꞌon yóꞌo kóni̱ kaa de̱ꞌe ña̱ kaꞌándí, chi̱ ni̱ꞌi dini̱ rá.  
\v 18 Ta iin ka̱ ra̱ naní Andrés, xíꞌín ra̱ naní Felipe, xíꞌín ra̱ naní Bartolomé, xíꞌín ra̱ naní Mateo, xíꞌín ra̱ naní Tomás, xíꞌín ra̱ naní Jacobo, ta̱ kúú de̱ꞌe Alfeo, xíꞌín ra̱ naní Tadeo, xíꞌín ra̱ naní Simón, táꞌa̱n ra̱ ni̱ sa̱ kuu kuendá ta̱ cananista,  
\v 19 xíꞌín ra̱ naní Judas Iscariote, táꞌa̱n ra̱ ni̱ kasa̱ndaá ni̱ na̱ki̱ꞌo Jesús noo̱ ndáꞌa̱ ra̱ xiní uꞌu̱ ñaá. 
\p Tá ni̱ ndiꞌi ñoó, dá ni̱ ndu̱ꞌu na ini iin veꞌe. 
\s1 Diꞌa ni̱ kuu tá ni̱ kaa dao ta̱a ña̱ taó Jesús espíritu kini kée ña̱ uꞌu̱ 
\p  
\v 20 Ta tuku va kua̱ꞌá ña̱yuu ni̱ ndi̱tútí ñoó. Ta ni ko̱ nóno̱ vá Jesús kasáꞌan na xíꞌín ta̱a xíonoo xíꞌín ná.  
\v 21 Tá ni̱ niꞌi̱ tóꞌon na̱ veꞌe Jesús ña̱ ndóꞌo na, dá ni̱ kee na kuaꞌa̱n na̱ nakua̱ka ñaá ná kandaka na noꞌo̱ na̱, dá chi̱ ni̱ na̱dana va na, káꞌán ná. 
\p  
\v 22 Dá ni̱ kaa dao ta̱a dánaꞌa̱ ley Moisés, táꞌa̱n ra̱ ni̱ kii ñoo Jerusalén, ña̱ Beelzebú, táꞌa̱n ña̱ kúú satoꞌo espíritu kini, ño̱ó vá kía̱n nákaa̱ ini Jesús, ta ño̱ó kía̱n xíꞌo choon noo̱ ná, sa̱ꞌá ño̱ó kándéé ná taó na̱ espíritu kini ñóꞌo ini ña̱yuu, kaá ra̱. 
\p  
\v 23 Dá ni̱ kana Jesús ta̱a ni̱ kaꞌa̱n dión ñoó, dá ni̱ ka̱sáꞌá ná dákíꞌin táꞌan na dao ña̱ꞌa xíꞌín ña̱ dánaꞌa̱ na̱, ta kaá na̱ xíꞌín rá: 
\p ―¿Ndi kee ví satoꞌo espíritu kini taó ñá miíán ini ña̱yuu, káꞌán ndó?  
\v 24 Kanaꞌá ndó ña̱ tá naá táꞌan iin rey xíꞌín ña̱yuu dándáki ra, dá kía̱n naá vá choon néꞌe ra.  
\v 25 Ta tá táꞌa̱nda̱ táꞌan ña̱yuu ndéi ini iin veꞌe, dá kía̱n naá vá noo̱ ndéi na.  
\v 26 Ta ki̱ꞌo dión taꞌani ndoꞌo ña̱ uꞌu̱ kúú no̱ó tá ná kasáꞌá na̱á táꞌan xíꞌín ña̱ kéchoon noo̱án. Chi̱ kasáꞌá taꞌa̱nda̱ táꞌan miíán, dá kía̱n o̱ káka ka̱ choon néꞌan, chi̱ sa̱ ni̱ kasa̱ndaá hora ña̱ kía̱n ndiꞌi noo̱án. 
\p  
\v 27 ’Ta ni iin tóꞌón ta̱a o̱ kúu ku̱ꞌu veꞌe iin ta̱a ndakí, ta taó rá ña̱ꞌa ñóꞌo veꞌe ra, tá dinñóꞌó ka̱ ná o̱ kátó ñaá rá. Miía̱n ndúsa̱ kee ra dión xíꞌín rá, dá kuu taó rá ña̱ꞌa ñóꞌo veꞌe ra.  
\v 28 Miía̱n ndaa̱ ná kaꞌi̱n xíꞌín ndó ña̱ kuu va kuꞌu̱ káꞌano ini Ndios sa̱ꞌá ndi ndáa mií vá kua̱chi kée ña̱yuu, ta saꞌa̱ ndidaá kúú to̱ꞌon kini káꞌa̱n ndava̱ꞌa na̱ saꞌa̱ Ndios.  
\v 29 Tído ndi ndáa na̱ ya̱ꞌa káꞌa̱n ndava̱ꞌa na saꞌa̱ na̱ kúú Espíritu ii̱ Ndios, no̱ón kúú na̱ ni iin kuu̱ ta̱ꞌón o̱ kúu kuꞌu̱ káꞌano ini Ndios saꞌa̱ ná. No̱ón kúú na̱ iin íchi̱ o̱ ndóo kua̱chi noo̱ Ndios ―kaá Jesús. 
\p  
\v 30 Dión ni̱ kaa na̱, dá chi̱ ni̱ kaa ta̱a ñoó ña̱ nákaa̱ espíritu kini ini na̱. 
\s1 Diꞌa ni̱ kuu tá ni̱ ka̱sáa̱ na̱ veꞌe Jesús nándukú ñaá ná 
\p  
\v 31 Dá ni̱ ka̱sáa̱ naná Jesús xíꞌín ñani na̱. Ta ni̱ sa̱ kui̱ta na sata̱ véꞌe. Dá ni̱ kaa na̱ xíꞌín ña̱yuu ndéi ñoó ña̱ ná kaꞌa̱n na̱ xíꞌín Jesús keta na sata̱ véꞌe. 
\p  
\v 32 Dá ni̱ kaa ña̱yuu ndéi díi̱n Jesús ñoó xíꞌín ná: 
\p ―Naná ní xíꞌín ñani ní ndíta na sata̱ véꞌe nándukú ná mií ní. 
\p  
\v 33 Dá ni̱ kaa Jesús xíꞌín ná: 
\p ―Ná kasto̱ꞌon ndaa̱i̱ xíꞌín ndó ndá yoo kúú nanái̱, ta ndá yoo kúú ñanii̱ xíꞌín ki̱ꞌoi ―kaá na̱. 
\p  
\v 34 Ta kúú ni̱ sa̱ nde̱ꞌé ná no̱ó ña̱yuu ndéi noo̱ ná ñóó. Dá ni̱ kaa na̱: 
\p ―Na̱ yóꞌo kúú nanái̱, kúú ñanii̱, kúú ki̱ꞌoi.  
\v 35 Chi̱ ndidaá na̱ kée ña̱ kóni̱ Ndios, no̱ón kúú ñanii̱, kúú ki̱ꞌoi, kúú nanái̱ ―kaá na̱. 
\c 4  
\s1 Diꞌa kuaꞌa̱n ña̱ ni̱ na̱kani Jesús saꞌa̱ iin ta̱a xíti tata 
\p  
\v 1 Ni̱ ka̱sáa̱ tuku Jesús yuꞌú ta̱ñoꞌo̱, dá ni̱ ka̱sáꞌá ná dánaꞌa̱ na̱ no̱ó ña̱yuu. Ta sa̱ꞌá ña̱ ni̱ na̱taka kua̱ꞌá nda̱ꞌo na, sa̱ꞌá ño̱ó ni̱ kaa Jesús ini barco, kirá kánóo no̱ó ta̱ñoꞌo̱. Dá ni̱ sa̱ ko̱o na ió na̱ ini ra̱. Ta ndéi ña̱yuu ñoó yuꞌú ta̱ñoꞌo̱ seídóꞌo na.  
\v 2 Dá ni̱ ka̱sáꞌá Jesús dákíꞌin táꞌan na dao ña̱ꞌa xíꞌín to̱ꞌon dánaꞌa̱ na̱, ta kaá na̱: 
\p  
\v 3 ―Kueídóꞌo va̱ꞌa ndó ña̱ koꞌi̱n kaꞌi̱n xíꞌín ndó. Iin ta̱a xíti ni̱ kee ra kuaꞌa̱n ra̱ kuti ra tata no̱ñóꞌo̱ rá.  
\v 4 Ta sa̱ꞌá ña̱ ni̱ koon niꞌini ra tata ñoó, sa̱ꞌá ño̱ó dao ña ni̱ kue̱i yuꞌú íchi̱. Ta kúú ni̱ ka̱sáa̱ laa, ta kúú ni̱ seí vá ría̱n.  
\v 5 Ta dao ka̱ tata ñoó ni̱ kue̱i tein yuu̱ noo̱ ndéi cháá ñóꞌo̱. Sa̱ꞌá ño̱ó kúú yachi̱ va ni̱ xita̱a̱n, chi̱ ko̱ ní kuéi taꞌon ña noo̱ kúú ñoꞌó ndéé.  
\v 6 Tído, tá ni̱ xi̱nko̱o ndi̱ndii, ta kúú ni̱ dii vaan. Ta sa̱ꞌá ña̱ ko̱ó yo̱ꞌan, sa̱ꞌá ño̱ó ni̱ ichi̱ vaan. 
\p  
\v 7 ’Ta kúú dao ka̱ tata ñoó ni̱ kue̱i tein ta̱ꞌíón. Ta ni̱ saꞌano dáó ñá xíꞌín ta̱ꞌíón ñoó, sa̱ꞌá ñoó ni̱ ku̱yatá váán ni̱ kee rá. Sa̱ꞌá ño̱ó ko̱ ní xi̱ꞌo taꞌan vaan noni̱án. 
\p  
\v 8 ’Ta kúú dao ka̱ tata ni̱ kue̱i noo̱ kúú ñoꞌó va̱ꞌa. Kúú kua̱ꞌá nda̱ꞌo noni̱ ni̱ xi̱ꞌoan, chi̱ ni̱ xita̱a̱n, ta ni̱ saꞌano va̱ꞌan. Ta kúú ió dao tata ñoó ni̱ xi̱ꞌo oko̱ uxi̱ noni̱. Ta dao ka̱a̱n ni̱ xi̱ꞌo oni̱ diko noni̱. Ta dao ka̱a̱n ni̱ xi̱ꞌo iin ciento noni̱ ―kaá Jesús. 
\p  
\v 9 Dá ni̱ kaa taꞌani na: 
\p ―¡Ndi ndáa ndoꞌó ió do̱ꞌo, ta kúú kueídóꞌo va̱ꞌa ndó! ―kaá na̱. 
\s1 Yóꞌo nákani Jesús ndiva̱ꞌa dákíꞌin táꞌan na dao ña̱ꞌa xíꞌín to̱ꞌon dánaꞌa̱ na̱ 
\p  
\v 10 Dá tá ni̱ ka̱ndo̱o iin tóꞌón Jesús íin ná, dá ni̱ nda̱to̱ꞌón ñaá ta̱ xíonoo xíꞌín ná xíꞌín dao ka̱ ña̱yuu ndíta yati ñoó ndi dándáki to̱ꞌon ni̱ na̱kani na xíꞌín ná ñóó.  
\v 11 Dá ni̱ kaa Jesús: 
\p ―Noo̱ ndo̱ꞌó vá ni̱ xi̱ꞌo Ndios ña̱ kandaa̱ ini ndo̱ ña̱ náꞌá mií ná sa̱ꞌá ndi kée na dándáki na. Tído no̱ó na̱ ko̱ ñáꞌa̱ ndu̱ꞌu ti̱xi ndáꞌa̱ Ndios, dákíꞌin táꞌan yuꞌu̱ dao ña̱ꞌa xíꞌín to̱ꞌon dánaꞌi̱, dá ná xi̱nko̱o noo̱ káꞌa̱n tuti ii̱ Ndios, chi̱ diꞌa kaáa̱n:  
\v 12 “Ta va̱ꞌará ndidaá ka̱ vía̱n ndéꞌé ná, tído o̱ kándaa̱ taꞌon ini na̱ ndi kóni̱ kaaa̱n. Ta va̱ꞌará ndidaá ka̱ vía̱n ná kueídóꞌo na, tído o̱ kátóni̱ taꞌon ini na̱, dá ná dáꞌa ni nandió kuéi na noo̱ Ndios, dá kía̱n ná o̱ kíꞌo káꞌano ini na̱ saꞌa̱ kua̱chi na.” 
\s1 Nákani Jesús ndi dándáki ña̱ ni̱ da̱náꞌa̱ na̱ saꞌa̱ ta̱a xíti tata 
\p  
\v 13 Dá ni̱ kaa taꞌani Jesús xíꞌín rá: 
\p ―¿Á ko̱ ní kándaa̱ taꞌon ini ndo̱ ndi dándáki ña̱ ni̱ na̱kanii xíꞌín ndó? ¿Ndi kee ndó, dá kandaa̱ ini ndo̱ saꞌa̱ cháá ka̱ ña̱ꞌa dákíꞌin táꞌin xíꞌín to̱ꞌon dánaꞌi̱ noo̱ ndo̱, tá dáá? 
\p  
\v 14 ’Ta̱a xíti tata ñoó kúú ta̱a xíonoo dánaꞌa̱ to̱ꞌon Ndios.  
\v 15 Ta yuꞌú íchi̱ noo̱ ni̱ kue̱i dao tata ñoó kúú ña̱yuu seídóꞌo to̱ꞌon Ndios. Tído tá ndíꞌi seídóꞌo naa̱n, ta kúú kásaa̱ ña̱ uꞌu̱, ta dítá váán to̱ꞌon ni̱ seídóꞌo na.  
\v 16 Ta tein yuu̱ noo̱ ni̱ kue̱i dao ka̱ tata ñoó kúú ña̱yuu seídóꞌo to̱ꞌon Ndios, ta mií hora seídóꞌo naa̱n, nátiin va̱ꞌa naa̱n xíꞌa̱n kádii̱ iní na̱.  
\v 17 Tído ko̱ ta̱ꞌón yo̱ꞌan ini nío̱ ná, sa̱ꞌá ño̱ó ko̱ ndíta toon na xíꞌín to̱ꞌon Ndios. Chi̱ tá kásáꞌá ndoꞌo na ta̱ndóꞌó, o tá kéndava̱ꞌa ña̱yuu xíꞌín ná sa̱ꞌá ña̱ kándísa na to̱ꞌon ñoó, ta kúú dánkoo na ña̱.  
\v 18 Ta tein ta̱ꞌíón noo̱ ni̱ kue̱i dao ka̱ tata ñoó kúú ña̱yuu seídóꞌo to̱ꞌon Ndios,  
\v 19 tído kásáꞌá ná ndíꞌi cháá ka̱ ini na̱ sa̱ꞌá ña̱ ió ñayuú yóꞌo, ta kátoó na̱ koo kuíká ná. Ta ndíꞌi taꞌani ini na̱ sa̱ꞌá dao ka̱ ña̱ꞌa. Ta ndidaá ñóó kedaá xíꞌín ná, dá kásáꞌá ná kuꞌichi̱ ini na̱ xiní na̱ to̱ꞌon Ndios, ta kúú ná táto̱ꞌon iin tata ko̱ xíꞌo noni̱. 
\p  
\v 20 ’Tído no̱ñóꞌo̱ va̱ꞌa noo̱ ni̱ kue̱i dao ka̱ tata ñoó kúú ña̱yuu seídóꞌo to̱ꞌon Ndios xíꞌín ndinoꞌo ini na̱, ta kándísa naa̱n. Dao no̱ón kúú táto̱ꞌon tata, ña̱ ni̱ xi̱ꞌo oko̱ uxi̱ noni̱. Ta dao ka̱ na̱ kúú táto̱ꞌon tata, ña̱ ni̱ xi̱ꞌo oni̱ diko noni̱. Ta dao ka̱ na̱ kúú táto̱ꞌon tata, ña̱ ni̱ xi̱ꞌo iin ciento noni̱, chi̱ kée na ña̱ kóni̱ Ndios ―kaá na̱. 
\s1 Diꞌa kuaꞌa̱n ña̱ ni̱ da̱náꞌa̱ Jesús sa̱ꞌá ña̱ kúú ña̱ ndaa̱ Ndios 
\p  
\v 21 Dá ni̱ da̱kíꞌin táꞌan tuku Jesús iin ka̱ ña̱ꞌa xíꞌín to̱ꞌon ni̱ da̱náꞌa̱ na̱, ta kaá na̱: 
\p ―Tá néꞌe yó iin íti̱ tóo̱n, ¿á chikani ndei yó iin ki̱di noo̱án o chikani yóa̱n ti̱xi iin xi̱to? Ko̱ó, iin íti̱ tóo̱n kánian chinóo yó ra̱ iin noo̱ dikó, dá ná katoo̱n ra̱ iin níí kúú xíán.  
\v 22 Dá chi̱ ndidaá vá ña̱ dáꞌi noo̱ ndo̱ viti, kasandaá natu̱uan. Ta ndidaá vá ña̱ꞌa ñóꞌo de̱ꞌé viti, daí ña̱ natu̱uan.  
\v 23 Ta ndi ndáa ndoꞌó ió do̱ꞌo, ta kúú kueídóꞌo va̱ꞌa ndó ―ka̱á na̱. 
\p  
\v 24 Dá ni̱ kaa taꞌani Jesús: 
\p ―Kueídóꞌo va̱ꞌa ndó to̱ꞌon káꞌi̱n xíꞌín ndó viti, chi̱ táto̱ꞌon ki̱ꞌo kaon ió nduu ndo̱ natiin ndóa̱n, ki̱ꞌo dión ki̱ꞌo Ndios ña̱ noo̱ ndo̱, ta ki̱ꞌo cháá ka̱ na̱án noo̱ ndo̱ o̱ du̱ú ña̱ ni̱ seídóꞌo ndó,  
\v 25 dá chi̱ na̱ ni̱ na̱tiin ndisa to̱ꞌon na, no̱ón kúú na̱ niꞌi̱ cháá ka̱ ña̱ kandaa̱ ini na̱. Tído na̱ ko̱ ní nátiin to̱ꞌon na, no̱ón kúú na̱ nandodó diꞌa va lúꞌu̱ ña̱ ni̱ seídóꞌo na. 
\s1 Yóꞌo ni̱ da̱náꞌa̱ Jesús saꞌa̱ ndi ki̱ꞌo ndukuaꞌa̱ ña̱yuu ti̱xi ndáꞌa̱ Ndios 
\p  
\v 26 Dá ni̱ kaa taꞌani Jesús: 
\p ―Táto̱ꞌon ki̱ꞌo dándáki Ndios ña̱yuu na̱ kíán táto̱ꞌon ndóꞌo iin tata ni̱ chiꞌi iin ta̱a no̱ñóꞌo̱ rá,  
\v 27 chi̱ sa̱kuaá kídi̱ ta̱a ñoó, ta naꞌa ndáko̱o ra. Ta nduú ñoó kaꞌándí noo̱ tata ñoó, ta sá sáꞌanoan kuaꞌa̱n. Tído ko̱ kándaa̱ taꞌon ini ra̱ ndi kuu sáꞌanoan.  
\v 28 Dá chi̱ mií vá ñóꞌo̱ ñoó dákuáꞌano ña. Dinñóꞌó xíta̱a̱n kíán yuku̱, dá xínko̱o yokoa̱n, dá chítí yokoa̱n xíꞌín noni̱.  
\v 29 Dá tá ni̱ chi̱chian, dá kuaꞌa̱n ra̱ kaꞌanda ra̱án, chi̱ ni̱ kasa̱ndaá kuu̱ nataán váꞌa raa̱n ―kaá na̱. 
\s1 Yóꞌo ni̱ da̱náꞌa̱ tuku Jesús saꞌa̱ ndí ki̱ꞌo ndukuaꞌa̱ ña̱yuu ti̱xi ndáꞌa̱ Ndios 
\p  
\v 30 Dá ni̱ kaa tuku Jesús: 
\p ―¿Ndí ki̱án dáó kúú xíꞌín to̱ꞌon kée Ndios dándáki na ña̱yuu na̱, káꞌán ndó? Ta, ¿ndá ki̱án dákíꞌin táꞌin xíꞌán, dá kandaa̱ ini ndo̱ sa̱ꞌán?  
\v 31 Kíán táto̱ꞌon iin tata naní mostaza, ña̱ kúú tata pálí cháá ka̱ noo̱ dao ka̱ tata chíꞌi yó no̱ñóꞌo̱ yo̱.  
\v 32 Tído tá ni̱ xita̱a̱n, ta kúú sáꞌano náꞌano cháá ka̱a̱n o̱ du̱ú dao ka̱ yuku̱. Ta náꞌano nda̱ꞌo ndáꞌán, sa̱ꞌá ño̱ó kúu káva̱ꞌa laa táka̱ ri̱ ti̱xi káti̱án ―kaá na̱. 
\p  
\v 33 Ta ki̱ꞌo dión ni̱ da̱kíꞌin táꞌan Jesús kua̱ꞌá nda̱ꞌo ña̱ꞌa xíꞌín to̱ꞌon ni̱ da̱náꞌa̱ na̱, ki̱ꞌo kándaa̱ ini ña̱yuu ñoó.  
\v 34 Ta ko̱ ní dánaꞌa̱ taꞌon na tá ko̱ ní sá dákíꞌin táꞌan na dao ña̱ꞌa xíꞌín to̱ꞌon dánaꞌa̱ na̱. Tído tá ni̱ kana xoo mií ná kuaꞌa̱n na̱, dá ni̱ na̱kani na xíꞌín ta̱ xíonoo xíꞌín ná ndi dándáki ña̱ ni̱ da̱náꞌa̱ na̱. 
\s1 Diꞌa ni̱ kuu tá ni̱ saꞌanda Jesús choon no̱ó tachi̱ xíꞌín ta̱ñoꞌo̱ 
\p  
\v 35 Tá ni̱ kuaá kuu̱ dáá ñóó, dá ni̱ kaa Jesús xíꞌín ta̱ xíonoo xíꞌín ná: 
\p ―Ná koꞌo̱ chikaꞌanda yo̱ iin ka̱ xoo yuꞌú ta̱ñoꞌo̱. 
\p  
\v 36 Tá ni̱ ndiꞌi ni̱ kaꞌa̱n ta̱a xíonoo xíꞌín ná ndisáꞌán xíꞌín ña̱yuu kuáꞌa̱ ñoó, dá ni̱ kaa ra ini barco noo̱ nákaa̱ na̱. Ta ni̱ sa̱rkuei dao ka̱ barco noo̱ ñóꞌo cháá ka̱ ña̱yuu kuaꞌa̱n na̱ noo̱ kuaꞌa̱n Jesús.  
\v 37 Ta kúú noo̱ kuaꞌa̱n na̱ ñoó ni̱ ka̱sáꞌá vá kána tachi̱ dée̱n. Sa̱ꞌá ño̱ó ni̱ ka̱sáꞌá ko̱kee ta̱kui̱í ini barco ñoó. Ta kúú sa̱ kuaꞌa̱n kutí vá ini ra̱ xíꞌín ta̱kui̱í.  
\v 38 Ta kúú kánduꞌu̱ Jesús kídi̱ na̱ ini ra̱ noo̱ nónó chí sata̱ diꞌa ra. Ta yíꞌi iin dáꞌo̱n dini̱ ná kánduꞌu̱ ná. 
\p Dá ni̱ da̱ndóto ñaá ta̱ xíonoo xíꞌín ná ñóó, dá kaá ra̱: 
\p ―¡Maestro! ¿Á ko̱ saꞌání taꞌon ni mií ní ña̱ kuuo̱? 
\p  
\v 39 Dá ni̱ nda̱kuíi̱n ndichi Jesús. Dá ni̱ saꞌanda na̱ choon no̱ó tachi̱ xíꞌín ta̱ñoꞌo̱, ta kaá na̱: 
\p ―¡Katuu! Tádi̱ kooón. 
\p Ta kúú ni̱ sa̱ tuu va tachi̱, ta ni̱ na̱káa̱ tádi̱ vá ta̱ñoꞌo̱. 
\p  
\v 40 Dá ni̱ kaa na̱ xíꞌín ta̱a ñoó: 
\p ―Ta, ¿ndiva̱ꞌa yuꞌú téí ndo̱? ¿Á ko̱ kándéé taꞌon iní ndo̱ yuꞌu̱, nda̱ni? 
\p  
\v 41 Kúú ni̱ yu̱ꞌú nda̱ꞌo ra. Dá ni̱ ka̱sáꞌá rá ndátóꞌón táꞌan rá: 
\p ―¿Ndá yoo ví kúú na̱ yóꞌo, chi̱ nda̱ tachi̱ xíꞌín ta̱ñoꞌo̱ seídóꞌo choon saꞌanda na̱? ―kaá ra̱. 
\c 5  
\s1 Diꞌa ni̱ kuu tá ni̱ taó Jesús espíritu kini ñóꞌo ini iin ta̱a 
\p  
\v 1 Dá ni̱ saa̱ na̱ iin ka̱ xoo ta̱ñoꞌo̱ noo̱ kúú kuendá Gadara diꞌa.  
\v 2 Dá tá ni̱ noo na barco ñoó, dá ni̱ keta iin ta̱a ñóꞌo espíritu kini ini káo̱ no̱ó ñóꞌo ndi̱i ve̱i ra niꞌi̱ ñaá rá.  
\v 3 Dá chi̱ ini káo̱ noo̱ ñóꞌo ndi̱i ñoó ió ra̱. Ta ni iin tóꞌón ña̱yuu ko̱ kándeé koꞌoni ñaá ná, ta ni cadena ko̱ kándeé kandiko̱ ra̱,  
\v 4 chi̱ sa̱ kuaꞌa̱ vá taꞌándá soꞌóní na̱ saꞌa̱ rá xíꞌín ndáꞌa̱ rá xíꞌín cadena, xíꞌín ka̱a viti. Tído vaá óon va kándéé rá dákuáchi ra cadena ñoó, ta saꞌándá ra̱ ka̱a ñoó, chi̱ ndakí nda̱ꞌo ra. Ta ni iin tóꞌón ña̱ꞌa kée ña̱yuu ko̱ kándeé xíꞌín rá.  
\v 5 Ta nduú ñoó xíonoo ra dini̱ yúku̱ káyuꞌú rá xíꞌín tein káo̱ ndi̱i ñoó, ta dárkueꞌe̱ ra̱ mií rá xíꞌín yuu̱. 
\p  
\v 6 Ta kúú xíká vá ni̱ xini ra̱ ña̱ ve̱i Jesús. Ta kúú ni̱ ka̱nkono ra ni̱ saa̱ ra̱ ni̱ sa̱ kuíi̱n xi̱tí rá noo̱ ná.  
\v 7 Ta kúú ni̱ꞌi nda̱ꞌo ni̱ ka̱yuꞌú espíritu kini nákaa̱ ini ra̱, ta kaáa̱n: 
\p ―¿Ndi ki̱án ndóꞌo ní xíꞌín yuꞌu̱, Jesús, mií ní na̱ kúú de̱ꞌe Ndios ndáya̱ꞌi? ¡Noo̱ míí Ndios seí ndaꞌíi̱ noo̱ ní ña̱ ná dáꞌa ni dándóꞌo naní ní yuꞌu̱! 
\p  
\v 8 Dión ni̱ kaáa̱n, chi̱ diꞌa ni̱ kaa Jesús xíꞌán: 
\p ―¡Espíritu kini, dáyaa̱ ta̱a xaa̱n! 
\p  
\v 9 Dá ni̱ nda̱to̱ꞌón ñaá Jesús: 
\p ―¿Ndi nanón? 
\p Dá ni̱ kaa espíritu kini ñoó: 
\p ―Legión naníí, chi̱ kua̱ꞌá nda̱ꞌo kúú nduꞌu̱. 
\p  
\v 10 Dá ni̱ seí ndaꞌí ña̱ noo̱ Jesús ña̱ ná dáꞌa ni tandaꞌá ñaá ná koꞌa̱n iin ka̱ xíán.  
\v 11 Ta yati yúku̱ íin ñoó ñóꞌo kua̱ꞌá nda̱ꞌo kochí sásáꞌan rí.  
\v 12 Dá ni̱ seí ndaꞌí espíritu kini ñoó noo̱ Jesús: 
\p ―Konó ní ná koꞌo̱n ndu̱ ndu̱ꞌu ndu ini kochí káa ―kaáa̱n. 
\p  
\v 13 Dá ni̱ sonó Jesús noo̱án. Dá ni̱ ka̱nkuei espíritu kini ñóꞌo ini ta̱a ñoó. Dá ni̱ saꞌa̱n ni̱ ndu̱ꞌan ini kochí ñoó. Ta kúú rí táto̱ꞌon uu̱ mil. Kúú ni̱ taxí táꞌan ndi ndiꞌi rí kuaꞌa̱n ri̱ yuꞌú daꞌo̱. Dá ni̱ kue̱i ndava̱ꞌa rí ini ta̱ñoꞌo̱ ñoó. Ta kúú ni̱ ka̱ndaa ri̱, dá ni̱ xiꞌi̱ ri̱. 
\p  
\v 14 Dá ni̱ kee ndidaá ta̱a ndáka kochí ñoó taxí táꞌan ra kuaꞌa̱n nóꞌo̱ ra̱ kasto̱ꞌon ra xíꞌín ña̱yuu ndéi ñoo ra̱, xíꞌín na̱ ndéi yúku̱ saꞌa̱ ña̱ ni̱ kuu dión. Dá ni̱ ka̱nkuei ña̱yuu ñoó kuaꞌa̱n na̱ kande̱ꞌé ná ndi ki̱án ni̱ kuu.  
\v 15 Tá ni̱ saa̱ ña̱yuu ñoó noo̱ íin Jesús, dá ni̱ xini na̱ ña̱ ió ta̱a sa̱ ndoꞌo nío̱ ni̱ sa̱ kee kua̱ꞌá nda̱ꞌo espíritu kini ñoó. Ta kúú sa̱ ndíxi va ra dáꞌo̱n ió ra̱. Ta sa̱ iin ta̱a ió va̱ꞌa kúú rá. Ta kúú ni̱ yu̱ꞌú nda̱ꞌo na. 
\p  
\v 16 Ta ña̱yuu ni̱ xini ña̱ ni̱ kuu dión kúú na̱ ni̱ na̱kani xíꞌín dao ka̱ ña̱yuu ña̱ ni̱ ndoꞌo ta̱a ni̱ sa̱ ñoꞌo espíritu kini ñoó xíꞌín ña̱ ni̱ ndoꞌo kochí ñoó. 
\p  
\v 17 Dá ni̱ ka̱sáꞌá ná seí ndaꞌí na̱ noo̱ Jesús ña̱ ná koꞌo̱n na̱ iin ka̱ xíán.  
\v 18 Tá kuaꞌa̱n Jesús kaa na ini barco ñoó, dá ni̱ seí ndaꞌí ta̱a ni̱ sa̱ ñoꞌo espíritu kini ñoó noo̱ ná ña̱ ná konó ná koꞌo̱n ra̱ xíꞌín ná.  
\v 19 Tído ko̱ ní xíin taꞌon na. Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Nandió ko̱ón kuaꞌán nóꞌo̱n veꞌón noo̱ ndéi táꞌón, ta nakanón xíꞌín ná saꞌa̱ ndidaá ña̱ náꞌano ni̱ kee satoꞌo yo̱ Ndios xíꞌón, ta nakani taꞌánón xíꞌín ná táto̱ꞌon ki̱ꞌo ni̱ kuꞌu̱ ini na̱ sa̱ꞌo̱n ―ka̱á na̱. 
\p  
\v 20 Dá ni̱ na̱kiꞌin ra kuaꞌa̱n nóꞌo̱ rá. Ta kúú ni̱ ka̱sáꞌá rá nákani ra sa̱ꞌá ña̱ ndato ni̱ kee Jesús xíꞌín rá no̱ó ña̱yuu ndéi kuendá Decápolis. Ta ndidaá na̱ ni̱ seídóꞌo ña̱ ni̱ na̱kani ra, kúú ni̱ naá nda̱ꞌo iní na̱. 
\s1 Diꞌa ni̱ ndoꞌo de̱ꞌe diꞌí iin ta̱a naní Jairo xíꞌín ña̱ ni̱ ndoꞌo iin ñáꞌa̱ ndóꞌo kueꞌe̱ tái̱ nii̱ 
\p  
\v 21 Dá ni̱ chi̱kaꞌanda Jesús xíꞌín ta̱a xíonoo xíꞌín ná kuaꞌa̱n na̱ iin ka̱ xoo ta̱ñoꞌo̱. Ta kúú sa̱ kua̱ꞌá nda̱ꞌo ña̱yuu ni̱ na̱taka ndéi yuꞌú ta̱ñoꞌo̱ ñoó. Tá ni̱ noo Jesús ini barco, dá ni̱ sa̱ kuíi̱n na̱ íin na yuꞌú ta̱ñoꞌo̱ ñoó.  
\v 22 Dá ni̱ ka̱sáa̱ iin ta̱a naní Jairo, táꞌa̱n ra̱ dándáki veꞌe noo̱ nátaka na̱ Israel ndéi ñoo ñoó. Tá ni̱ xini ra̱ Jesús, kúú ni̱ sa̱ kuíi̱n xi̱tí rá noo̱ ná.  
\v 23 Dá ni̱ ka̱sáꞌá rá seí ndaꞌí ra̱ noo̱ ná, ta kaá ra̱: 
\p ―Sa̱ xíꞌi̱ va de̱ꞌe diꞌíi̱. Nakíi̱ ní ná koꞌo̱ chinóo ní ndáꞌa̱ ní sata̱ xí, dá ná nduva̱ꞌa xi, dá ná o̱ ku̱ú xi. 
\p  
\v 24 Dá ni̱ kee Jesús kuaꞌa̱n na̱ xíꞌín rá. Ta kua̱ꞌá nda̱ꞌo ña̱yuu ni̱ kee kuaꞌa̱n xíꞌín ná, ta dándútí ná Jesús kuaꞌa̱n na̱.  
\v 25 Ta tein ña̱yuu kuáꞌa̱ ñoó nákaa̱ iin ñáꞌa̱ ndóꞌo kueꞌe̱ tái̱ nii̱, ta sa̱ ni̱ xi̱no uxi̱ uu̱ kuia̱ ndóꞌán dión.  
\v 26 Ta sa̱ ndoꞌo nda̱ꞌo níma̱n, chi̱ noo̱ kua̱ꞌá nda̱ꞌo ta̱a kétátá ni̱ saꞌa̱n. Ta sa̱ ni̱ da̱ndíꞌi vaán di̱ꞌón néꞌe va̱ꞌán ni̱ chi̱ya̱ꞌavián ra̱ kétátá ñoó. Tído ni iin tóꞌón taꞌon ra ko̱ ní kándeé nduva̱ꞌán. Víꞌí ka̱ ví ndóꞌán. 
\p  
\v 27 Tído tá ni̱ ka̱ndaa̱ inia̱n ña̱ kándéé Jesús nduva̱ꞌa na na̱ kúꞌu̱, dá ni̱ ndu̱ndééán ni̱ ku̱ꞌán tein ña̱yuu kuáꞌa̱ ñoó. Dá ni̱ na̱tuu yatián sata̱ Jesús, ta kúú ni̱ ka̱ko̱ꞌon ndáꞌa̱n dáꞌo̱n ná.  
\v 28 Dión ni̱ keeán, dá chi̱ ni̱ na̱kani inia̱n ña̱ sa̱va̱ꞌa rá dáꞌo̱n óon Jesús ná kako̱ꞌán, ta kúú nduva̱ꞌa vaán.  
\v 29 Ta kúú vitíꞌón diꞌa va ni̱ na̱tuu nii̱ ñoó. Ta kúú ni̱ ka̱ndaa̱ inia̱n ña̱ ni̱ ndu̱va̱ꞌa vaán no̱ó kueꞌe̱ ndóꞌán. 
\p  
\v 30 Ta kúú ni̱ ka̱ndaa̱ va ini Jesús ña̱ ni̱ ndu̱va̱ꞌa iin ña̱yuu ni̱ kee ndée̱ ná. Dá ni̱ na̱ndió ko̱o na ni̱ sa̱ nde̱ꞌé ná no̱ó ña̱yuu kuáꞌa̱ ve̱i sata̱ ná ñoó. Dá ni̱ nda̱to̱ꞌón ñaá ná: 
\p ―¿Ndá yoo ni̱ ka̱ko̱ꞌon ndáꞌa̱ dáꞌa̱ma̱í? 
\p  
\v 31 Dá ni̱ kaa ta̱ xíonoo xíꞌín ná ñóó: 
\p ―Ndéꞌé vá mií ní, dión ví ña̱yuu kuáꞌa̱ ve̱i yóꞌo dándútí ñaá. Sa̱ꞌá ño̱ó, ¿ndiva̱ꞌa ndáto̱ꞌón ní ndá yoo ni̱ ka̱ko̱ꞌon ndáꞌa̱ ñaá? 
\p  
\v 32 Tído ni̱ sa̱ nde̱ꞌé va̱ꞌa Jesús noo̱ ndidaá ña̱yuu ñoó, dá ná kande̱ꞌá ndá yoo ni̱ ka̱ko̱ꞌon ñaá.  
\v 33 Sa̱ náꞌá vá ñáꞌa̱ ñoó ña̱ ni̱ ndu̱va̱ꞌán sa̱ꞌá ña̱ ni̱ ka̱ko̱ꞌán dáꞌo̱n Jesús. Ta va̱ꞌará yuꞌúa̱n, ta ndéi̱ ni̱noán, tído ni̱ saꞌa̱n ni̱ sa̱ kuíi̱n xi̱tíán noo̱ ná, ta ni̱ na̱kani ndaa̱a̱n xíꞌín ná ña̱ ni̱ keeán. 
\p  
\v 34 Dá ni̱ kaa Jesús xíꞌán: 
\p ―De̱ꞌe diꞌíi̱, ni̱ ndu̱va̱ꞌón sa̱ꞌá ña̱ kándéé inóo̱n yuꞌu̱. Ta viti, kuaꞌán nóꞌo̱n veꞌón xíꞌa̱n ió va̱ꞌa inóo̱n, chi̱ ni̱ ndu̱va̱ꞌón no̱ó kueꞌe̱ ni̱ sa̱ ndoꞌón. 
\p  
\v 35 Ta kúú káꞌa̱n i̱íó Jesús íin na, kúú sa̱ ni̱ ka̱sáa̱ va dao ta̱a ni̱ kii veꞌe Jairo, táꞌa̱n ra̱ dándáki veꞌe noo̱ nátaka na̱ ñoo ñoó. Dá ni̱ kaa ra̱ xíꞌín Jairo ñoó: 
\p ―Sa̱ ni̱ xiꞌi̱ va de̱ꞌe diꞌí ní. Ná dáꞌa ka̱ ní dátaꞌán ní maestro xaa̱n. 
\p  
\v 36 Tá ni̱ seídóꞌo Jesús ña̱ ni̱ kaꞌa̱n ra̱ dión, dá ni̱ kaa na̱ xíꞌín Jairo: 
\p ―O̱ sa̱ yúꞌóo̱n. Sa̱va̱ꞌa yuꞌu̱ kandeé inóo̱n ―kaá na̱. 
\p  
\v 37 Ta kúú ko̱ ní sónó taꞌon Jesús noo̱ dao ka̱ ña̱yuu ña̱ koꞌo̱n na̱ xíꞌín ná veꞌe ta̱a ñoó, sa̱va̱ꞌa Pedro xíꞌín Jacobo xíꞌín ñani ra̱ naní Juan va ndáka na kuaꞌa̱n na̱.  
\v 38 Dá tá ni̱ saa̱ na̱ ni̱ ku̱ꞌu na veꞌe Jairo, kúú ni̱ xini na̱ ña̱ nína vaa̱ nda̱ꞌo ña̱yuu ndéíꞌi̱ na̱ ndéi na, ta ndaꞌí káyuꞌú ná saꞌa̱ tadiꞌí ñoó.  
\v 39 Dá ni̱ kaa Jesús xíꞌín ná: 
\p ―¿Ndiva̱ꞌa nína vaa̱ téí ndo̱? Ta, ¿ndiva̱ꞌa ndéíꞌi̱ téí ndo̱ ndéi ndó? Chi̱ ko̱ ní xíꞌi̱ taꞌon xi, kídi̱ va xi ―kaá na̱. 
\p  
\v 40 Tído ni̱ saki̱ ndaa va ñaá ña̱yuu ñoó. Dá ni̱ saꞌanda Jesús choon ña̱ ná kankuei ndidaá ná sata̱ véꞌe. Dá ni̱ kana na tatá tadiꞌí ñoó xíꞌín naná xi̱ xíꞌín ndin oni̱ ka̱ ta̱a ndáka na kuaꞌa̱n na̱ ñoó. Dá ni̱ ku̱ꞌu na noo̱ kánduꞌu̱ xí.  
\v 41 Dá ni̱ tiin Jesús ndáꞌa̱ xí. Dá ni̱ kaa na̱: 
\p ―Talita, cumi ―ka̱á na̱. To̱ꞌon yóꞌo kóni̱ kaa: Diꞌí lóꞌo̱, káꞌi̱n xíꞌón, ndako̱o. 
\p  
\v 42 Ta kúú vitíꞌón diꞌa vá ni̱ nda̱ko̱o xi. Ta kúú ni̱ ka̱sáꞌá xíka xi xíonoo xi. Ta uxi̱ uu̱ kuia̱ ió xi. Tá ni̱ xini ña̱yuu ñoó, kúú ni̱ naá nda̱ꞌo iní na̱.  
\v 43 Tído ni̱ saꞌanda Jesús choon no̱ó na̱ veꞌe xi ná o̱ sa̱ nákani na xíꞌín ni iin tóꞌón ña̱yuu sa̱ꞌá ña̱ ni̱ kuu dión. Dá ni̱ kaa na̱ xíꞌín ná ña̱ ná ki̱ꞌo na ña̱ꞌa kasáꞌan xi. 
\c 6  
\s1 Diꞌa ni̱ ndoꞌo Jesús tá ni̱ na̱ndió ko̱o na ni̱ na̱sáa̱ na̱ ñoo Nazaret 
\p  
\v 1 Dá ni̱ keta Jesús ñoo ñoó, dá ni̱ kee na kuaꞌa̱n nóꞌo̱ ná ñoo mií ná, ta tákuei ñaá ta̱a xíonoo xíꞌín ná kuaꞌa̱n ra̱.  
\v 2 Tá ni̱ kasa̱ndaá kuu̱ nániꞌi̱ ndée̱ na̱ Israel, dá ni̱ ku̱ꞌu na ini veꞌe noo̱ nátaka na̱ ñoo ñoó. Dá ni̱ ka̱sáꞌá ná dánaꞌa̱ na̱. Ta ndéi kua̱ꞌá nda̱ꞌo ña̱yuu seídóꞌo ñaá ná, ta ni̱ naá vá ini na̱ ndéꞌé ñaá ná, ta kaá na̱: 
\p ―¿Ndeí ni̱ ka̱ti̱ꞌa ta̱a káa ña̱ dánaꞌa̱ ra̱? ¿Ndeí ni̱ niꞌi̱ ta̱ káa ña̱ ndi̱chí náꞌá rá, xíꞌín ña̱ kándéé rá kée ra ña̱ ndato xíꞌín ña̱yuu?  
\v 3 ¿Á o̱ du̱ú ta̱ túxí yíto̱ vá kúú ra̱ káa, chi̱ de̱ꞌe María kúú rá, ta ñani ra̱ kúú Jacobo xíꞌín José, xíꞌín Judas, xíꞌín Simón viti? ¿Á o̱ du̱ú ki̱ꞌo ra̱ káa ndéi tein yó yóꞌo? ―kaá ña̱yuu ñoó. 
\p Sa̱ꞌá ño̱ó ko̱ ní nákoni ñaá ná. 
\p  
\v 4 Dá ni̱ kaa Jesús: 
\p ―Ndeí kúú mií vá ió ña̱ñóꞌó ña̱yuu noo̱ nduꞌu̱, na̱ kúú profeta. Tído na̱ ñoo mií ndú, xíꞌín na̱ kúú táꞌan ndu, xíꞌín na̱ veꞌe ndu, no̱ón diꞌa kúú na̱ káñóꞌó ñaá ―kaá na̱. 
\p  
\v 5 Sa̱ꞌá ño̱ó ko̱ ní kúu taꞌon kee na ña̱ꞌa náꞌano xíꞌín na̱ ñoo mií ná, sa̱va̱ꞌa sata̱ dao na̱ kúꞌu̱ vá ni̱ chi̱nóo na ndáꞌa̱ ná, dá ni̱ ndu̱va̱ꞌa na.  
\v 6 Kúú ni̱ naá vá iní Jesús xiní na̱, chi̱ ko̱ ní xíin taꞌon na̱ ñoo mií ná kandísa ñaá ná. Dá ni̱ kee na kuaꞌa̱n na̱. Dá ni̱ ka̱sáꞌá ná xíonoo na dánaꞌa̱ na̱ dao ka̱ ñoo ñóꞌo yati ñoó. 
\s1 Yóꞌo ni̱ saꞌanda Jesús choon no̱ó ta̱a xíonoo xíꞌín ná ña̱ koꞌo̱n ra̱ dánaꞌa̱ ra̱ to̱ꞌon va̱ꞌa saꞌa̱ Ndios 
\p  
\v 7 Tá ni̱ ndiꞌi, dá ni̱ kana na ndin uxi̱ uu̱ ta̱a xíonoo xíꞌín ná ñóó. Dá ni̱ ka̱sáꞌá ná tándaꞌá ná uu̱ rá uu̱ ra̱ kuaꞌa̱n ra̱ kanoo ra dánaꞌa̱ ra̱. Ta ni̱ xi̱ꞌo na choon noo̱ rá ña̱ kandeé rá taó rá espíritu kini ñóꞌo ini ña̱yuu.  
\v 8 Ta ni̱ kaa taꞌani na xíꞌín rá: 
\p ―Ni iin ña̱ꞌa o̱ sa̱ kóo ini ndo̱ kaneꞌe ndó koꞌo̱n ndo̱ íchi̱. Sa̱va̱ꞌa iin tóꞌón yíto̱, kirá katuu va ndó, kaneꞌe ndó koꞌo̱n ndo̱. O̱ sa̱ káneꞌe ndó léka̱ ndo̱, ni pan, ta ni di̱ꞌón o̱ sa̱ káneꞌe ndó koꞌo̱n ndo̱.  
\v 9 Sa̱va̱ꞌa ndisa̱ yíꞌi ndó kayiꞌi ndó koꞌo̱n ndo̱, ta ná dáꞌa ni kaneꞌe ndó iin ka̱ kotó nada̱on ndó ―kaá na̱. 
\p  
\v 10 Dá ni̱ kaa taꞌani na xíꞌín rá: 
\p ―Ta ndi ndáa mií vá veꞌe ni̱ saa̱ ndo̱ ni̱ ku̱ꞌu ndó, sa̱va̱ꞌa ñoó ni kandei ndó nda̱ ná kasandaá kuu̱ kankuei ndó koꞌo̱n ndo̱ iin ka̱ ñoo.  
\v 11 Tído tá ni̱ saa̱ ndo̱ iin ñoo no̱ó ko̱ ní xíin na natiin va̱ꞌa na ndo̱ꞌó, ta ko̱ ní xíin na kueídóꞌo na to̱ꞌon dánaꞌa̱ ndo̱, dá kía̱n tá kuaꞌa̱n ndo̱ kankuei ndó ñoo ñoó, kidi niꞌini ndó ño̱ya̱ká íin saꞌa̱ ndo̱, ta ño̱ó kía̱n náꞌa̱ ña̱ ko̱ nátaꞌan ini Ndios xiní na̱ na̱ ñoo ñoó. Miía̱n ndaa̱ ná kaꞌi̱n xíꞌín ndó ña̱ tá ná kasandaá kuu̱ keyíko̱ Ndios saꞌa̱ ndidaá ña̱yuu, dá kía̱n kaꞌí cháá ka̱ ndoꞌo na̱ ñoo ñoó o̱ du̱ú ña̱yuu kíni ni̱ sa̱ ndei ñoo Sodoma xíꞌín ñoo Gomorra ―kaá na̱. 
\p  
\v 12 Dá ni̱ kee ra kuaꞌa̱n ra̱. Dá ni̱ ka̱sáꞌá rá kásto̱ꞌon ra xíꞌín ña̱yuu ña̱ ná nandikó iní na̱ saꞌa̱ kua̱chi kée na.  
\v 13 Ta kúú kua̱ꞌá nda̱ꞌo espíritu kini ni̱ taó rá, ta ni̱ chi̱kodó rá sití dini̱ kua̱ꞌá na̱ kúꞌu̱, dá ni̱ ndu̱va̱ꞌa na. 
\s1 Diꞌa ni̱ kuu tá ni̱ xiꞌi̱ Juan, na̱ sa̱ da̱kódo̱ ndúta̱ ña̱yuu 
\p  
\v 14 Kúú ni̱ niꞌi̱ tóꞌon rey Herodes saꞌa̱ Jesús, dá chi̱ ndeí kúú míí vá káꞌa̱n ña̱yuu saꞌa̱ ná. Chi̱ dao ña̱yuu ñoó kaá diꞌa: “Ni̱ na̱taki va Juan, na̱ sa̱ da̱kódo̱ ndúta̱ ña̱yuu, ta no̱ón kúú Jesús, sa̱ꞌá ño̱ó kándéé ná kée na ña̱ꞌa ndato.”  
\v 15 Ta dao ka̱ na̱ kaá ña̱ profeta Elías kúú ná. Ta dao ka̱ na̱ ka̱á ña̱ kúú ná iin profeta, o ndá ndi kuu kúú ná iin profeta ni̱ sa̱ io sa̱ naꞌá, kaá na̱. 
\p  
\v 16 Tído tá ni̱ seídóꞌo rey Herodes ñoó ña̱ káꞌa̱n na̱ dión, dá ni̱ kaa ra̱: 
\p ―Ta̱a yóꞌo kúú Juan, táꞌa̱n ra̱ ni̱ saꞌanda yuꞌu̱ diko̱. Tído ni̱ na̱taki va ra. 
\p  
\v 17 Dión ni̱ kaa Herodes, chi̱ mií rá ni̱ saꞌanda choon, dá ni̱ tiin soldado Juan. Dá ni̱ soꞌoni ñaá rá xíꞌín cadena. Dá ni̱ chi̱káa̱ ñaá rá veꞌe ka̱a, chi̱ ki̱ꞌo dión kóni̱ Herodías, ñá ni̱ sa̱ kuu ñadiꞌí ñani ra̱ naní Felipe, tído ni̱ na̱kiꞌin ñaá rá kakuuán ñadiꞌí ra̱.  
\v 18 Ta sa̱ꞌá ña̱ ni̱ kaa Juan xíꞌín rá ña̱ kua̱chi káꞌano kíán ña̱ ió ra̱ xíꞌín ñadiꞌí ñani ra̱,  
\v 19 sa̱ꞌá ño̱ó ni̱ xini uꞌu̱ ñaá Herodías, ta kóni̱a̱n kaꞌání ñaáán. Tído ko̱ níꞌi̱ taꞌan vaán ndí keeán, dá ná kuu Juan,  
\v 20 dá chi̱ yuꞌú va Herodes kaꞌání ñaá rá, chi̱ náꞌá vá rá ña̱ ta̱ ndaa̱, ta̱ kéchóon noo̱ Ndios kúú ná. Sa̱ꞌá ño̱ó ndaá vá ñaá rá noo̱ Herodías. Ta va̱ꞌará ni̱ kutúú iní ra̱ ni̱ kee to̱ꞌon ni̱ kaꞌa̱n na̱, tído kátoó ra̱ kueídóꞌo ñaá rá. 
\p  
\v 21 Ta tein víko̱ ni̱ na̱xi̱no Herodes kuia̱ rá, dá ni̱ niꞌi̱ Herodías ndí keeán, dá kuu Juan. Chi̱ ni̱ na̱taka ta̱a dándáki xíꞌín Herodes, xíꞌín ta̱a saꞌándá choon noo̱ soldado, xíꞌín ndidaá ta̱a ndáya̱ꞌi ni̱ kii chí kuendá Galilea, ta ndéi ra sásáꞌan ra xíꞌín Herodes.  
\v 22 Ta kúú ñoó ni̱ ku̱ꞌu de̱ꞌe diꞌí Herodías. Dá ni̱ sa̱rsáꞌá xí. Ta kúú ni̱ na̱taꞌan ini Herodes ni̱ kee xi, ta ni̱ na̱taꞌan taꞌani ini ndidaá ta̱ ndéi sásáꞌan xíꞌín rá ñóó. Dá ni̱ kaa rey Herodes ñoó xíꞌín xí: 
\p ―Tá ná kako̱n ndí ku̱ú míí váa̱n kóno̱n noo̱í viti, ta kúú ki̱ꞌo vei ña̱ noo̱o̱n ―kaá ra̱. 
\p  
\v 23 Dá ni̱ xi̱ꞌo ra to̱ꞌon ra noo̱ xí, ta kaá ra̱: 
\p ―Miía̱n ndaa̱ ndisa ki̱ꞌoi ndidaá mií vá ña̱ꞌa xíko̱n noo̱í, chi̱ iói̱ ki̱ꞌoi nda̱ iin ñeꞌe noo̱ dándákii noo̱o̱n ―kaá ra̱. 
\p  
\v 24 Dá ni̱ keta xi kankono xi kuaꞌa̱n xi̱ ndato̱ꞌón xí naná xi Herodías: 
\p ―¿Ndí ki̱án kaka̱i̱ viti? 
\p Dá ni̱ kaa naná xi: 
\p ―Kuaꞌán kako̱n dini̱ Juan, ta̱ sa̱ da̱kódo̱ ndúta̱ ña̱yuu ―kaáa̱n. 
\p  
\v 25 Dá kánkono xi ni̱ ndu̱ꞌu tuku xi noo̱ ió rey Herodes. Dá ni̱ kaa xi̱ xíꞌín rá: 
\p ―Vitíꞌón kuií kóni̱ yuꞌu̱ ña̱ ki̱ꞌo ní iin koꞌo̱ ná kakaa̱ dini̱ Juan, ta̱ sa̱ da̱kódo̱ ndúta̱ ña̱yuu, noo̱í. 
\p  
\v 26 Kúú ni̱ ku̱ndaꞌí nda̱ꞌo ini ra̱, tído sa̱ꞌá ña̱ ni̱ xi̱ꞌo ra to̱ꞌon ra noo̱ xí, ta sa̱ꞌá ña̱ ni̱ seídóꞌo ta̱a ndéi xíꞌín rá ña̱ ni̱ kaꞌa̱n ra̱ dión, sa̱ꞌá ño̱ó ko̱ ní kúu taꞌon kaa ra̱ ña̱ ko̱ó.  
\v 27 Ta kúú vitíꞌón ni̱ saꞌanda ra̱ choon noo̱ soldado ra̱ ña̱ ná koꞌo̱n ra̱ kaꞌanda ra̱ diko̱ Juan, ta ná kaneꞌe ra dini̱ ná kii ra.  
\v 28 Dá ni̱ saꞌa̱n ta̱a ñoó ni̱ saꞌanda ra̱ diko̱ Juan noo̱ nákaa̱ na̱ ini veꞌe ka̱a. Dá ni̱ chi̱káa̱ ra̱ dini̱ ná ini iin koꞌo̱ néꞌe raa̱n ni̱ ka̱sáa̱ ra̱. Dá ni̱ xi̱ꞌo raa̱n noo̱ tadiꞌí ñoó. Dá ni̱ xi̱ꞌo xia̱n noo̱ naná xi Herodías. 
\p  
\v 29 Tá ni̱ niꞌi̱ tóꞌon ta̱ xíonoo xíꞌín Juan ña̱ ni̱ xiꞌi̱ na̱, dá ni̱ saꞌa̱n ra̱ ni̱ na̱kiꞌin ra yikí ko̱ño na̱. Ta néꞌe raa̱n ni̱ saꞌa̱n ra̱ ni̱ da̱ndúxi ra. 
\s1 Diꞌa ni̱ kuu tá ni̱ xi̱ꞌo Jesús ña̱ꞌa ni̱ sa̱sáꞌan oꞌo̱n mil ta̱a 
\p  
\v 30 Dá ni̱ na̱kiꞌin táꞌan tuku ta̱a xíonoo xíꞌín Jesús xíꞌín míí ná. Dá ni̱ ka̱sáꞌá rá nákani ra xíꞌín ná saꞌa̱ ndidaá kúú ña̱ ni̱ kee ra, xíꞌín saꞌa̱ ndidaá ña̱ ni̱ da̱náꞌa̱ ra̱ no̱ó ni̱ saꞌa̱n ra̱. 
\p  
\v 31 Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Nakíi̱ ndo̱, ná koꞌo̱ iin ka̱ xíán naniꞌi̱ ndée̱ yo̱ no̱ó ko̱ íin ndéi. 
\p Dión ni̱ kaa na̱, dá chi̱ kúú kuaꞌa̱n, kúú ve̱i kúu kua̱ꞌá nda̱ꞌo ña̱yuu kásaa̱ na̱ noo̱ Jesús, sa̱ꞌá ño̱ó ko̱ nóno̱ vá ná kasáꞌan na.  
\v 32 Dá ni̱ kaa na xíꞌín ta̱a xíonoo xíꞌín ná ini iin barco, dá ni̱ kanxoo na kuaꞌa̱n na̱ iin xíán no̱ó ko̱ íin ndéi.  
\v 33 Tído kuaꞌa̱ vá ña̱yuu ni̱ xini ña̱ kuaꞌa̱n na̱, ta ni̱ na̱koni va na Jesús. Ta kúú ni̱ kee ña̱yuu ndéi ndidaá kúú ñoo ñóꞌo yati ñoó xíka sáꞌá ná kuaꞌa̱n na̱ niꞌi̱ ñaá ná. Ta kúú sa̱ ndéi diꞌa va ña̱yuu ñoó ndáti na tá ni̱ saa̱ Jesús.  
\v 34 Dá tá ni̱ keta Jesús ini barco ñoó, kúú ni̱ xini na̱ ña̱ kua̱ꞌá nda̱ꞌo ña̱yuu ndéi ndáti ñaá. Ta kúú ni̱ kuꞌu̱ nda̱ꞌo ini na̱ saꞌa̱ ná, chi̱ ndéi na táto̱ꞌon ndéi léko, kirí ko̱ íin ndáka, ki̱ꞌo dión ndéi na. Dá ni̱ ka̱sáꞌá Jesús dánaꞌa̱ na̱ kua̱ꞌá nda̱ꞌo ña̱ꞌa no̱ó ña̱yuu kuáꞌa̱ ñoó. 
\p  
\v 35 Dá tá ni̱ ini, dá ni̱ na̱tuu yati ñaá ta̱ xíonoo xíꞌín ná. Dá ni̱ kaa ra̱ xíꞌín ná: 
\p ―Ko̱ ta̱ꞌón veꞌe ndíta yati yóꞌo, ta sa̱ ni̱ ini va.  
\v 36 Kaꞌanda ní choon no̱ó ña̱yuu yóꞌo ña̱ ná koꞌo̱n na̱ veꞌe túu ndíta káa xíꞌín ñoo kuálí túu ñóꞌo káa, dá ná kuiin na ña̱ꞌa keí ná, chi̱ ko̱ ta̱ꞌón ña̱ꞌa keí ná yóꞌo. 
\p  
\v 37 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Ki̱ꞌo ni mií ndó ña̱ꞌa ná kasáꞌan na. 
\p Dá ni̱ kaa ra̱: 
\p ―¿Á kóni̱ ní ña̱ koꞌo̱n ndu̱ kuiin ndu pan xíꞌín di̱ꞌón, ki̱ꞌo níꞌi̱ ña̱yuu kéchóon na uu̱ ciento kuu̱, dá ki̱ꞌo ndua̱n noo̱ ná kasáꞌan na? 
\p  
\v 38 Dá ni̱ kaa Jesús: 
\p ―¿Ndidaá pan néꞌe va̱ꞌa ndó? Kuaꞌán ndo̱ kande̱ꞌé ndó. 
\p Dá ni̱ saꞌa̱n ra̱ ni̱ sa̱ nde̱ꞌé rá. Dá ni̱ kaa ra̱ xíꞌín ná: 
\p ―Oꞌo̱n kúú pan, ta uu̱ kúú ti̱yaká ―kaá ra̱. 
\p  
\v 39 Dá ni̱ saꞌanda Jesús choon ña̱ ná kande̱i tá tuꞌu tá tuꞌu na̱ noo̱ i̱tá kuíi̱ ñoó.  
\v 40 Dá ni̱ sa̱ nde̱i ña̱yuu ñoó. Táto̱ꞌon iin ciento kúú iin iin tuꞌu na̱, ta dao ka̱ tuꞌu kúú uu̱ diko uxi̱.  
\v 41 Dá ni̱ tiin Jesús ndin oꞌo̱n pan xíꞌín ndin nduú ti̱yaká ñóó. Dá ni̱ na̱neꞌe noo̱ ná chí induú. Dá ni̱ na̱ki̱ꞌo na ndivéꞌe noo̱ Ndios. Dá ni̱ saꞌanda na̱ pan ñoó. Dá ni̱ xi̱ꞌo naa̱n no̱ó ta̱ xíonoo xíꞌín ná. Dá ni̱ dasá ráa̱n noo̱ iin rá iin ña̱yuu ñoó. Dión taꞌani ni̱ kee na xíꞌín ndin nduú ti̱yaká ñóó.  
\v 42 Dá ni̱ sa̱sáꞌan ndidaá ña̱yuu ñoó nda̱ ni̱ ndi̱noo va̱ꞌa ini na̱.  
\v 43 Tá ni̱ ndiꞌi, dá ni̱ da̱kútí ta̱ xíonoo xíꞌín Jesús uxi̱ uu̱ ti̱yika̱ xíꞌín táꞌí pan, xíꞌín táꞌí ti̱yaká ña̱ ni̱ ka̱ndo̱o noo̱ ni̱ sa̱sáꞌan ña̱yuu ñoó.  
\v 44 Ta oꞌo̱n mil ni̱ sa̱ kuu ta̱a ni̱ sa̱sáꞌan ni̱ kee Jesús. 
\s1 Diꞌa ni̱ kuu tá ni̱ xika Jesús no̱ó ta̱ñoꞌo̱ 
\p  
\v 45 Tá ni̱ ndiꞌi, dá ni̱ saꞌanda Jesús choon no̱ó ta̱a xíonoo xíꞌín ná ña̱ ná kaa ra ini barco, ta ná chikaꞌanda ra koꞌo̱n ra̱ no̱ó ta̱ñoꞌo̱, dá ná saa̱ ra̱ ñoo naní Betsaida. Dá ni̱ ka̱ndo̱o Jesús ni̱ kaꞌa̱n na̱ ndisáꞌán xíꞌín ña̱yuu kuáꞌa̱ ñoó.  
\v 46 Tá ni̱ ndiꞌi ni̱ kaꞌa̱n na̱ ndisáꞌán, dá ni̱ kee na kuaꞌa̱n na̱ dini̱ iin yúku̱ íin ñoó kaꞌa̱n na̱ xíꞌín Ndios. 
\p  
\v 47 Tá sa̱ ni̱ kuaá vá, ta kúú du̱ú ni̱ taꞌi̱ dáo ió barco noo̱ ñóꞌo ta̱a xíonoo xíꞌín ná ñoó kuaꞌa̱n ra̱ no̱ó ta̱ñoꞌo̱. Ta kúú nákaa̱ iin tóꞌón i̱í vá Jesús no̱ñóꞌo̱.  
\v 48 Kúú ni̱ xini na̱ ña̱ ndóꞌo nío̱ rá dákáka ndáꞌa̱ rá barco ñoó, chi̱ kána nda̱ꞌo tachi̱ chí xoo no̱ó kuaꞌa̱n ra̱. 
\p Dá tá ni̱ kundikí, kúú ni̱ ku̱yati Jesús no̱ó kuaꞌa̱n ra̱, chi̱ xíka sáꞌá ná kuaꞌa̱n na̱ no̱ó ta̱kui̱í ñoó, ta sá yáꞌa na kuaꞌa̱n na̱ chí noo̱.  
\v 49 Tído tá ni̱ xini ra̱ ña̱ xíka Jesús kuaꞌa̱n na̱ no̱ó ta̱kui̱í ñóó, dá ni̱ kaꞌán rá ña̱ kúú ná iin íꞌíná. Sa̱ꞌá ño̱ó ni̱ꞌi nda̱ꞌo ni̱ ka̱yuꞌú rá,  
\v 50 chi̱ ndidaá vá rá ni̱ xini ñaá, ta kúú ni̱ yu̱ꞌú nda̱ꞌo ra. Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Ndeé koo ini ndo̱. O̱ sa̱ yuꞌú ndo̱, dá chi̱ mií vá yuꞌu̱ kúúí ―ka̱á na̱. 
\p  
\v 51 Dá ni̱ kaa na ini barco noo̱ ñóꞌo ra ñoó. Ta kúú ni̱ sa̱ tuu vá tachi̱ ñoó. Kúú ni̱ naá vá iní ra̱, ta ni̱ yu̱ꞌú ra̱,  
\v 52 dá chi̱ ko̱ kándaa̱ i̱í vá ini ra̱ ndi dándáki ña̱ ndato ni̱ kee na ni̱ da̱ndukuaꞌa̱ ná pan ñoó, chi̱ ndadí i̱í vá ña̱xintóni̱ rá. 
\s1 Diꞌa ni̱ kuu tá ni̱ ndu̱va̱ꞌa Jesús na̱ kúꞌu̱ ndéi kuendá Genesaret 
\p  
\v 53 Dá tá ni̱ ndiꞌi ni̱ chi̱kaꞌanda na̱ no̱ó ta̱ñoꞌo̱, dá ni̱ saa̱ na̱ noo̱ kúú kuendá Genesaret. Dá ni̱ soꞌoni na̱ barco yuꞌú ta̱ñoꞌo̱.  
\v 54 Tá ni̱ ka̱nkuei na ini barco ñoó, ta kúú ndidaá ña̱yuu ndéi ñoó ni̱ na̱koni ñaá.  
\v 55 Ta kúú ni̱ taxí táꞌan ña̱yuu ñoó iin rá iin ñoo ni̱ saꞌa̱n na̱ ni̱ na̱kiꞌin na ña̱yuu kúꞌu̱ kándodó noo̱ xíto néꞌe na ni̱ saa̱ na̱ no̱ó ni̱ ka̱ndaa̱ ini na̱ nákaa̱ Jesús. 
\p  
\v 56 Ta ndeí kúú míí vá noo̱ kásandaá Jesús, ñoo kuálí o ñoo náꞌano o yukú ichí kíán, ta kúú chíndei ña̱yuu ñoó na̱ kúꞌu̱ ná yuꞌú íchi̱, ta seí ndaꞌí na̱ noo̱ Jesús ña̱ ná konó ná dákoꞌo̱n ndáꞌa̱ ná yuꞌú kotó na̱. Ta kúú ndidaá vá na̱ ni̱ da̱kóꞌo̱n ndáꞌa̱ yuꞌú kotó na̱ ni̱ ndu̱va̱ꞌa. 
\c 7  
\s1 Yóꞌo ni̱ da̱náꞌa̱ Jesús ña̱ kánian kee yó ña̱ kóni̱ Ndios, ta o̱ du̱ú ña̱ kóni̱ ta̱a 
\p  
\v 1 Kúú ni̱ na̱tuu yati ta̱ fariseo xíꞌín dao ta̱a dánaꞌa̱ ley Moisés noo̱ Jesús. Ta ta̱a yóꞌo kúú ra̱ ni̱ kii ñoo Jerusalén.  
\v 2 Kúú ni̱ xini ra̱ ña̱ ko̱ ní nákata taꞌon ta̱a xíonoo xíꞌín Jesús ndáꞌa̱ rá xíꞌín ña̱ñóꞌó, dá kasáꞌan ra. Chi̱ ko̱ ní kée ra táto̱ꞌon ki̱ꞌo ni̱ da̱náꞌa̱ ta̱ sáꞌano ñoo ra̱ tá sata̱. Sa̱ꞌá ño̱ó ni̱ da̱tái̱ kua̱chi ñaá rá,  
\v 3 dá chi̱ ta̱ fariseo xíꞌín ndidaá ka̱ na̱ Israel tíin toon na táto̱ꞌon ni̱ sa̱ kee ta̱ sáꞌano ñoo na̱ tá sata̱, chi̱ dinñóꞌó kánian nakata na ndáꞌa̱ ná xíꞌín ña̱ñóꞌó, dá kasáꞌan na.  
\v 4 Ta dión taꞌani kée na tá ndúsaa̱ na̱ sáꞌa̱n na̱ noo̱ yáꞌi, chi̱ ko̱ sásáꞌan taꞌon na tá ná o̱ nákata na ndáꞌa̱ ná xíꞌín ña̱ñóꞌó. Ta ió kua̱ꞌá ka̱ ví ña̱ꞌa kée na táto̱ꞌon ni̱ da̱náꞌa̱ ta̱ sáꞌano ñoo na̱, chi̱ nákata taꞌani na vaso na̱ xíꞌín ña̱ñóꞌó, xíꞌín ti̱ndoꞌo̱ ná, xíꞌín koꞌo̱ ka̱a na̱, xíꞌín ki̱di na̱. 
\p  
\v 5 Sa̱ꞌá ño̱ó ni̱ nda̱to̱ꞌón ta̱ fariseo xíꞌín ta̱ dánaꞌa̱ ley Moisés ñoó Jesús, ta kaá ra̱: 
\p ―¿Ndiva̱ꞌa ko̱ kée ta̱ xíonoo xíꞌín mií ní táto̱ꞌon ni̱ da̱náꞌa̱ ta̱ sáꞌano ñoo yo̱ tá sata̱? Chi̱ ko̱ nákata ra ndáꞌa̱ rá xíꞌín ña̱ñóꞌó, dá kasáꞌan ra. 
\p  
\v 6 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Ta̱a uu̱ noo̱ vá kúú ndoꞌó. Ndaa̱ va ni̱ kaꞌa̱n profeta Isaías saꞌa̱ ndo̱ꞌó, chi̱ diꞌa ni̱ taa na: 
\q1 Táꞌa̱n ña̱yuu ndéi viti kékáꞌano na yuꞌu̱ xíꞌín yúꞌu̱ óon va na, 
\q1 tído xíꞌín nío̱ ná, ko̱ kóni̱ taꞌon na yuꞌu̱. 
\q1  
\v 7 Ko̱ ndáya̱ꞌi taꞌon ña̱ ndáño̱ꞌo na yuꞌu̱, 
\q1 dá chi̱ ña̱ dánaꞌa̱ na̱ kúú ña̱ ni̱ ndaki ini ña̱xintóni̱ ta̱a va, 
\q1 ta káꞌa̱n na̱ ña̱ choon ni̱ saꞌanda Ndios kíán. 
\m  
\v 8 Chi̱ ndo̱ꞌó kúú na̱ dánkoo xoo choon saꞌándá Ndios, ta ndíꞌi cháá ka̱ ini ndo̱ kée ndó choon saꞌándá ta̱a, chi̱ ndíꞌi nda̱ꞌo ini ndo̱ nákata ndó ti̱ndoꞌo̱ ndo̱, xíꞌín vaso ndo̱, ta ndíꞌi taꞌani ini ndo̱ kée ndó cháá ka̱ ña̱ꞌa kuaꞌa̱n táto̱ꞌon kuaꞌa̱n ña̱ yóꞌo. 
\p  
\v 9 Dá ni̱ kaa taꞌani na: 
\p ―Chi̱ dánkoo xoo ndó choon saꞌándá Ndios, ta ndíꞌi cháá ka̱ ini ndo̱ kée ndó choon ni̱ ndaki ini mií ndó.  
\v 10 Dá chi̱ diꞌa kaá ley Moisés: “Koo ña̱ñóꞌó ndó noo̱ tatá ndo̱ xíꞌín noo̱ naná ndo̱”, ta “Ndi ndáa mií vá ña̱yuu ni̱ ya̱ꞌa ni̱ kaꞌa̱n ndava̱ꞌa xíꞌín tatá na̱ o xíꞌín naná na̱, na̱ yóꞌo kúú na̱ kánian kuu.”  
\v 11 Tído ndoꞌó kúú ra̱ káꞌa̱n ña̱ kuu va kaꞌa̱n iin ña̱yuu xíꞌín tatá na̱, xíꞌín naná na̱: “O̱ kúu taꞌon chindeéí mií ní xíꞌín ña̱ꞌa néꞌe va̱ꞌi, chi̱ sa̱ ni̱ kaꞌi̱n ña̱ ki̱ꞌoi ña̱ noo̱ Ndios.”  
\v 12 Ta ndoꞌó kúú ra̱ káꞌa̱n ña̱ ndi ndáa na̱ káꞌa̱n dión, no̱ón kúú na̱ ko̱ káni ka̱a̱n ña̱ chindeé ná tatá na̱ xíꞌín naná na̱.  
\v 13 Ta dión kée ndó dátu̱ú ndó choon ni̱ saꞌanda Ndios xíꞌín ña̱ ni̱ ndaki ini mií ndó. Ta kua̱ꞌá ka̱ ví ña̱ꞌa kuaꞌa̱n táto̱ꞌon kuaꞌa̱n ña̱ yóꞌo kía̱n kée ndó ―kaá Jesús xíꞌín rá. 
\p  
\v 14 Dá ni̱ na̱ndió ko̱o Jesús ni̱ kana na ña̱yuu kuáꞌa̱ ñoó, dá ni̱ kaa na̱: 
\p ―Kueídóꞌo va̱ꞌa ndó ña̱ koꞌi̱n kaꞌi̱n xíꞌín ndó, dá katóni̱ va̱ꞌa ini ndo̱.  
\v 15 Ni iin ña̱ꞌa seí ndo̱ ko̱ dáyako̱ ñaá noo̱ Ndios, chi̱ ña̱ kini kánkuei nío̱ ndo̱, ño̱ó vá kía̱n dáyako̱ ndo̱ꞌó noo̱ Ndios.  
\v 16 Ta ndi ndáa ndoꞌó ió do̱ꞌo, dá kía̱n kueídóꞌo va̱ꞌa ndó ―kaá na̱. 
\p  
\v 17 Dá ni̱ kana xoo na tein ña̱yuu kuáꞌa̱ ñoó. Dá ni̱ ku̱ꞌu na ini iin veꞌe. Dá ni̱ nda̱to̱ꞌón ñaá ta̱a xíonoo xíꞌín ná ndi dándáki to̱ꞌon ni̱ da̱kíꞌin táꞌan na ni̱ kaꞌa̱n na̱ xíꞌín ña̱yuu ñoó.  
\v 18 Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―¿Á dión taꞌani ko̱ kátóni̱ taꞌon ini ndo̱ꞌó? ¿Á ko̱ kándaa̱ taꞌon ini ndo̱ ña̱ ni iin ña̱ꞌa seí ña̱yuu ko̱ dáyako̱ ñaá noo̱ Ndios?  
\v 19 Dá chi̱ o̱ du̱ú nío̱ ná ko̱kee ña̱ꞌa seí na̱. Ini ti̱xi va na kuaꞌa̱n. Ta kúú tá ni̱ ndiꞌi, dá kuaꞌa̱n na̱ sata̱ véꞌe tatá náa̱n. 
\p Dión ni̱ kaa Jesús, dá ná kandaa̱ ini ra̱ ña̱ ni iin ña̱ꞌa seí yo̱ ko̱ dáyako̱ ñaá noo̱ Ndios. 
\p  
\v 20 Ta ni̱ kaa taꞌani Jesús xíꞌín rá: 
\p ―Ña̱ kini kánkuei ini nío̱ ña̱yuu, ño̱ó vá kía̱n dáyako̱ ñaá noo̱ Ndios.  
\v 21 Dá chi̱ nda̱ ma̱á ini nío̱ vá ná ve̱i ña̱ kini nákani ini na̱ kee na, dá kee na kua̱chi xíꞌín na̱ ko̱ kúú ñadiꞌí na̱ o yíi̱ ná, ta kée na ña̱ kaꞌan noo̱ xíꞌín ñíi̱ ná, ta saꞌání ná ña̱yuu,  
\v 22 ta kíꞌin kuíꞌíná ná ña̱ꞌa, ta kátoó na̱ ña̱ꞌa ió noo̱ dao ka̱ na̱, ta ió ña̱ xíxi ini na̱, ta ndúkú ná ña̱ dándaꞌí na̱ dao ka̱ ña̱yuu, ta ni lúꞌu̱ ví ko̱ chítuu ini na̱ kée na ña̱ kini, ta uꞌu̱ ini na̱, ta ndéineꞌe táꞌan na, ta chíndaya̱ꞌi na mií ná, ta kúú ná na̱ ko̱ xíkaꞌan noo̱.  
\v 23 Ta ndidaá ña̱ yóꞌo kía̱n kánkuei nda̱ ma̱á nío̱ ná, ta dáyako̱ ñaá noo̱ Ndios. 
\s1 Diꞌa ni̱ kuu tá ni̱ ndu̱va̱ꞌa Jesús de̱ꞌe diꞌí iin ñáꞌa̱ tu̱kú 
\p  
\v 24 Dá ni̱ keta Jesús ñoo ñoó, dá ni̱ kee na kuaꞌa̱n na̱ xíꞌín ta̱a xíonoo xíꞌín ná chí kuendá ñoo Tiro xíꞌín ñoo Sidón. Tá ni̱ saa̱ na̱ ñoó, dá ni̱ ku̱ꞌu na ini iin veꞌe, chi̱ ko̱ kóni̱ taꞌon na ña̱ kandaa̱ ini ña̱yuu ña̱ ni̱ ka̱sáa̱ na̱ ñoo ñoó. Tído ko̱ ní kúu taꞌon chide̱ꞌé na̱,  
\v 25 dá chi̱ yachi̱ vá ni̱ ka̱ndaa̱ ini iin ñáꞌa̱ ña̱ ió na̱ ñoó. Ta nákaa̱ iin espíritu kini ini de̱ꞌe diꞌáa̱n. Ta kúú ni̱ ka̱sáa̱a̱n noo̱ nákaa̱ Jesús, kúú ni̱ sa̱ kuíi̱n xi̱tíán noo̱ ná.  
\v 26 Ta kúúán iin ñáꞌa̱ káꞌa̱n to̱ꞌon griego, chi̱ iin ñoo nákaa̱ chí kuendá Sirofenicia diꞌa kúú ñooa̱n. Dá ni̱ seí ndaꞌí ña̱ noo̱ Jesús ña̱ ná taó ná espíritu kini nákaa̱ ini de̱ꞌe diꞌáa̱n.  
\v 27 Dá ni̱ kaa Jesús xíꞌán: 
\p ―Konó ná kasáꞌan takuálí nda̱ ná ndinoo va̱ꞌa ini xi̱, dá chi̱ ko̱ váꞌa taꞌon kuio ndaa yo̱ pan noo̱ ndáꞌa̱ xí, ta ki̱ꞌo yóa̱n no̱ó ti̱na. 
\p  
\v 28 Dá ni̱ kaa ñáꞌa̱ ñoó xíꞌín ná: 
\p ―Ndaa̱ káꞌa̱n ní, tatá. Tído seí va ti̱na yúchi̱ pan, ña̱ kuéi ti̱i mesa kée takuálí. 
\p  
\v 29 Dá ni̱ kaa Jesús xíꞌán: 
\p ―Va̱ꞌa ni̱ kaꞌo̱n, sa̱ꞌá ño̱ó kuaꞌán nóꞌo̱ veꞌón viti, dá chi̱ sa̱ ni̱ keta va espíritu kini ña̱ ni̱ sa̱ káa̱ ini de̱ꞌe diꞌóo̱n kuaꞌa̱n ―kaá na̱. 
\p  
\v 30 Dá ni̱ keeán kuaꞌa̱n nóꞌa̱n. Tá ni̱ na̱sáa̱a̱n veꞌán, kúú sa̱ kánduꞌu̱ va̱ꞌa va de̱ꞌe diꞌáa̱n noo̱ xíto, chi̱ sa̱ ni̱ keta va espíritu kini ña̱ ni̱ sa̱ káa̱ ini xi̱ kuaꞌa̱n. 
\s1 Diꞌa ni̱ kuu tá ni̱ ndu̱va̱ꞌa Jesús iin ta̱a ko̱ tái̱ do̱ꞌo, ta káꞌa̱n tata̱ ra̱ 
\p  
\v 31 Dá ni̱ keta Jesús no̱ñóꞌo̱ kuendá ñoo Tiro diꞌa. Dá ni̱ chi̱kaꞌanda na̱ ñoo Sidón xíꞌín ñoo ñóꞌo chí kuendá Decápolis kuaꞌa̱n na̱. Dá ni̱ na̱sáa̱ na̱ yuꞌú ta̱ñoꞌo̱ naní Galilea.  
\v 32 Ta ñoó ndáka dao ña̱yuu iin ta̱a ko̱ tái̱ do̱ꞌo, ta̱ káꞌa̱n tata̱ ni̱ saa̱ na̱. Dá ni̱ seí ndaꞌí na̱ noo̱ Jesús ña̱ ná chinóo na ndáꞌa̱ ná dini̱ rá, dá ná nduva̱ꞌa ra. 
\p  
\v 33 Dá ni̱ taó xóo Jesús ta̱a yóꞌo no̱ó ko̱ó ña̱yuu ndéi. Dá ni̱ tuu na dini̱ ndáꞌa̱ ná yái̱ do̱ꞌo ra. Dá ni̱ da̱ndáxi na dini̱ ndáꞌa̱ ná xíꞌín ta̱di̱í na̱, dá ni̱ da̱kóꞌo̱n na̱án noo̱ yáa̱ ta̱a ñoó.  
\v 34 Dá ni̱ na̱nde̱ꞌé ná chí induú, kúú ni̱ saka̱ ini na̱. Dá ni̱ kaa na̱: 
\p ―¡Efata! ―To̱ꞌon yóꞌo kóni̱ kaa: ¡Nono̱ viti! 
\p  
\v 35 Kúú vitíꞌón vá ni̱ na̱tai̱ do̱ꞌo ra, ta ni̱ ke̱xoo ña̱ kedaá xíꞌín yáa̱ rá, ta kúú ni̱ na̱kaꞌa̱n va̱ꞌa va ra. 
\p  
\v 36 Dá ni̱ saꞌanda Jesús choon no̱ó ña̱yuu ñoó ña̱ ná o̱ sa̱ kóo ini na̱ kaꞌa̱n na̱ xíꞌín ni iin tóꞌón ña̱yuu sa̱ꞌá ña̱ ndato ni̱ kee na xíꞌín ta̱a ñoó. Ta va̱ꞌará ndidaá ka̱ ví ni̱ saꞌanda na̱ choon no̱ó ña̱yuu ñoó ña̱ ná o̱ sa̱ káꞌa̱n na̱, tído víꞌí ka̱ ví ni̱ dasá tóꞌon ñaá ña̱yuu ñoó.  
\v 37 Ta kúú ni̱ naá va iní ña̱yuu ñoó xiní na̱ ña̱ ni̱ kee Jesús dión, dá kaá na̱: 
\p ―Va̱ꞌa nda̱ꞌo kée na ndidaá ña̱ꞌa. Chi̱ kándéé ná nátai̱ do̱ꞌo ña̱yuu ko̱ tái̱ do̱ꞌo, ta nda̱ na̱ kúú ñíꞌi̱ kándéé ná ná kaꞌa̱n ―ka̱á na̱. 
\c 8  
\s1 Diꞌa ni̱ kuu tá ni̱ xi̱ꞌo Jesús ña̱ꞌa ni̱ sa̱sáꞌan komi̱ mil ña̱yuu 
\p  
\v 1 Ta tein kuu̱ dáá ñóó ni̱ ndi̱tútí kua̱ꞌá nda̱ꞌo ña̱yuu. Ta ko̱ ta̱ꞌón ña̱ꞌa kasáꞌan na. Dá ni̱ kana Jesús ta̱a xíonoo xíꞌín ná. Dá ni̱ kaa na̱ xíꞌín rá: 
\p  
\v 2 ―Kúꞌu̱ nda̱ꞌo inii̱ sa̱ꞌá ña̱yuu yóꞌo, chi̱ sa̱ ni̱ xi̱no oni̱ kuu̱ ndéi na xíꞌín yuꞌu̱, ta ni ko̱ó ka̱ ña̱ꞌa kasáꞌan ná.  
\v 3 Tído tá ná tandaꞌí na̱ noꞌo̱ na̱ veꞌe na tá ko̱ ñáꞌa̱ kasáꞌan na, oon ni ví kuu yi̱ꞌí na̱ íchi̱, chi̱ xíká nda̱ꞌo ni̱ kii dao na. 
\p  
\v 4 Dá ni̱ kaa ta̱ xíonoo xíꞌín ná ñoó: 
\p ―¿Ndeí kiꞌin yó kua̱ꞌá pan ki̱ꞌo yó keí ña̱yuu kuaꞌa̱ káa, chi̱ yukú ichí vá kía̱n yóꞌo? 
\p  
\v 5 Dá ni̱ nda̱to̱ꞌón ñaá Jesús: 
\p ―¿Ndidaá pan néꞌe ndó? 
\p Dá ni̱ kaa ra̱: 
\p ―Usa̱ kíán. 
\p  
\v 6 Dá ni̱ saꞌanda Jesús choon ña̱ ná kande̱i ña̱yuu ñoó no̱ñóꞌo̱. Dá ni̱ tiin na ndin usa̱ pan ñoó. Dá ni̱ na̱ki̱ꞌo na ndivéꞌe noo̱ Ndios. Dá ni̱ saꞌanda na̱án. Dá ni̱ xi̱ꞌo naa̱n no̱ó ta̱ xíonoo xíꞌín ná ñóó. Dá ni̱ dasá ráa̱n noo̱ iin rá iin ña̱yuu kuáꞌa̱ ñoó.  
\v 7 Ta néꞌe taꞌani ra cháá ti̱yaká. Ta kúú ni̱ na̱ki̱ꞌo taꞌani Jesús ndivéꞌe noo̱ Ndios saꞌa̱ ri̱. Dá ni̱ xi̱ꞌo na ri̱ no̱ó ta̱ xíonoo xíꞌín ná ñóó. Dá ni̱ dasá rá ri̱ no̱ó ña̱yuu kuáꞌa̱ ñoó.  
\v 8 Dá ni̱ sa̱sáꞌan ndidaá ná nda̱ no̱ó ni̱ ndi̱noo va̱ꞌa ini na̱. Tá ni̱ ndiꞌi ni̱ sa̱sáꞌan na, dá ni̱ da̱kútí ta̱ xíonoo xíꞌín Jesús usa̱ ti̱yika̱ xíꞌín ña̱ ni̱ ka̱ndo̱o no̱ó ni̱ sa̱sáꞌan na.  
\v 9 Táto̱ꞌon komi̱ mil ni̱ sa̱ kuu ña̱yuu ni̱ sa̱sáꞌan ñoó. Dá ni̱ kaꞌa̱n Jesús ndisáꞌán xíꞌín ña̱yuu kuáꞌa̱ ñoó.  
\v 10 Dá ni̱ kaa na ini barco xíꞌín ta̱a xíonoo xíꞌín ná. Dá ni̱ kiꞌin na kuaꞌa̱n na̱. Dá ni̱ kasa̱ndaá na̱ iin ka̱ xoo ta̱ñoꞌo̱ noo̱ kúú kuendá Dalmanuta. 
\s1 Yóꞌo ni̱ xika̱ ta̱ fariseo ña̱ ná kee Jesús iin ña̱ ndato chí induú 
\p  
\v 11 Kúú ni̱ ka̱sáa̱ dao ta̱ fariseo. Dá ni̱ ka̱sáꞌá rá ndátóꞌón ndichí ra̱ Jesús, chi̱ ni̱ xika̱ ra̱ ña̱ kee na iin ña̱ ndato chí induú, dá korndodó ñaá rá, dá ná kande̱ꞌá á miía̱n ndaa̱ ni̱ kii na noo̱ Ndios.  
\v 12 Dá kúú konó oon ví ni̱ kixia̱n ni̱ saka̱ ini na̱. Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―¿Ndiva̱ꞌa xíka̱ na̱ ndéi tiempo viti ña̱ keei iin ña̱ ndato? Miía̱n ndaa̱ ná kaꞌi̱n xíꞌín ndó ña̱ o̱ kée taꞌon yuꞌu̱ ni iin ña̱ ndato no̱ó ndo̱ꞌó ―kaá na̱. 
\p  
\v 13 Dá ni̱ da̱nkoo na ta̱a ñoó, dá ni̱ kaa tuku na ini barco xíꞌín ta̱ xíonoo xíꞌín ná. Dá ni̱ kee na kuaꞌa̱n na̱ iin ka̱ xoo ta̱ñoꞌo̱. 
\s1 Diꞌa kuaꞌa̱n ña̱ ni̱ da̱náꞌa̱ Jesús saꞌa̱ ña̱ ko̱ váꞌa dánaꞌa̱ ta̱ fariseo 
\p  
\v 14 Tído ni̱ na̱ndodó vá ta̱ xíonoo xíꞌín Jesús kaneꞌe ra pan koꞌo̱n ra̱. Sa̱va̱ꞌa iin tóꞌón dini̱ vá pan nákaa̱ néꞌe ra kuaꞌa̱n ra̱ ini barco ñoó.  
\v 15 Dá ni̱ saꞌanda Jesús choon noo̱ rá, ta kaá na̱ xíꞌín rá: 
\p ―Kandaa ndo̱ mií ndó xíꞌín ña̱ dákuita̱ ta̱chí pan, ña̱ kéchóon ta̱ fariseo xíꞌín ta̱ kuendá rey Herodes ―kaá na̱. 
\p  
\v 16 Kúú ni̱ ka̱sáꞌá ndátóꞌón táꞌan mií rá: 
\p ―Sa̱ꞌá ña̱ ko̱ ní sá neꞌe yó pan kixió, sa̱ꞌá ño̱ó káꞌa̱n na̱ dión xíꞌá ―kaá ra̱. 
\p  
\v 17 Kúú ni̱ ka̱ndaa̱ va ini Jesús ña̱ ni̱ kaꞌa̱n ra̱ dión. Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―¿Ndiva̱ꞌa ndátóꞌón ndó saꞌa̱ pan ve̱i ndó? ¿Á ko̱ kándaa̱ i̱í vá ini ndo̱, ta á ko̱ kátóni̱ taꞌon ini ndo̱? ¿Á ndadí i̱í vá ña̱xintóni̱ ndo̱?  
\v 18 Ió noo̱ ndo̱, tído, ¿á ko̱ túu taꞌan vaan? Ta ió do̱ꞌo ndó, tído, ¿á ko̱ tái̱ taꞌan vaan? ¿Á ko̱ ndúsaa̱ taꞌon ini ndo̱ ña̱ ni̱ keei?  
\v 19 Chi̱ tá ni̱ saꞌanda yuꞌu̱ pan ni̱ seí ndin oꞌo̱n mil ta̱a ñoó, ¿ndidaá ti̱yika̱ ni̱ da̱kútí ndó xíꞌín yúchi̱ pan ña̱ ni̱ ka̱ndo̱o ñoó? 
\p Dá ni̱ kaa ra̱: 
\p ―Uxi̱ uu̱ ra̱. 
\p  
\v 20 Dá ni̱ kaa tuku Jesús xíꞌín rá: 
\p ―Ta, ¿ndidaá ti̱yika̱ ni̱ da̱kútí ndó xíꞌín yúchi̱ usa̱ pan ni̱ xi̱ꞌo yuꞌu̱ ni̱ seí ndin komi̱ mil ña̱yuu ñoó? 
\p Dá ni̱ kaa ra̱: 
\p ―Usa̱ ra̱. 
\p  
\v 21 Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―¿Á ko̱ kándaa̱ i̱í ví ini ndo̱, tá dáá? ―kaá na̱. 
\s1 Diꞌa ni̱ kuu tá ni̱ ndu̱va̱ꞌa Jesús iin ta̱a ko̱ túu noo̱ 
\p  
\v 22 Tá ni̱ saa̱ Jesús xíꞌín ta̱a xíonoo xíꞌín ná ñoo naní Betsaida, kúú ni̱ ka̱sáa̱ ña̱yuu xíꞌín iin ta̱a ko̱ túu noo̱. Dá ni̱ seí ndaꞌí na̱ noo̱ Jesús ña̱ ná kako̱ꞌon ndáꞌa̱ ñaá ná.  
\v 23 Dá ni̱ tiin Jesús ndáꞌa̱ rá, dá ndáka ñaá ná kuaꞌa̱n na̱ nda̱ noo̱ kúú yuꞌú ñoo ñoó. Dá ni̱ tu̱u ndaa na̱ ta̱di̱í na̱ nduchí nóó ra̱. Dá ni̱ chi̱nóo na ndáꞌa̱ ná dini̱ rá. Dá ni̱ nda̱to̱ꞌón ñaá ná: 
\p ―¿Á sa̱ ni̱ na̱tu̱u cháá noo̱o̱n viti? 
\p  
\v 24 Dá ni̱ na̱nde̱ꞌé rá, dá ni̱ kaa ra̱: 
\p ―Xiní vai ta̱a káa, tído táto̱ꞌon ndáa yíto̱ vá, ki̱ꞌo dión ndáa ra xíonoo ra, xiníi̱. 
\p  
\v 25 Dá ni̱ chi̱nóo tuku Jesús ndáꞌa̱ ná sata̱ nduchí nóó ra̱. Dá tá ni̱ na̱nde̱ꞌé tuku ra, kúú sa̱ ni̱ na̱tu̱u va̱ꞌa noo̱ rá. Sa̱ ndidaá kúú vá ña̱ꞌa ndato xiní va̱ꞌa ra, kaá ra̱.  
\v 26 Dá ni̱ saꞌanda Jesús choon noo̱ rá, ta kaá na̱: 
\p ―Ná dáꞌa ni ndu̱ꞌón ñoo káa, ta o̱ sa̱ nákanón xíꞌín ni iin tóꞌón ña̱yuu ndéi ñoó ña̱ ni̱ keei xíꞌón ―kaá na̱. 
\s1 Diꞌa ni̱ kuu tá ni̱ kaa Pedro ña̱ Jesús kúú Cristo, na̱ ni̱ ta̱ndaꞌá Ndios kasaa̱ dáka̱ki ñaá 
\p  
\v 27 Dá ni̱ kee Jesús kuaꞌa̱n na̱ xíꞌín ta̱a xíonoo xíꞌín ná ñoo kuálí ñóꞌo yati ñoo Cesarea Filipo. Ta íchi̱ no̱ó kuaꞌa̱n na̱ ñoó, kúú ni̱ nda̱to̱ꞌón ñaá Jesús, ta kaá na̱ xíꞌín rá: 
\p ―¿Ndá yoo kúú yuꞌu̱, kaá ña̱yuu ñoó? 
\p  
\v 28 Dá ni̱ kaa ta̱ xíonoo xíꞌín ná: 
\p ―Dao na̱ kaá ña̱ kúú ní Juan, na̱ sa̱ da̱kódo̱ ndúta̱ ña̱yuu. Ta dao ka̱ na̱ ka̱á ña̱ kúú ní profeta Elías. Ta dao ka̱ na̱ ka̱á ña̱ kúú ní iin ka̱ profeta. 
\p  
\v 29 Dá ni̱ nda̱to̱ꞌón tuku ñaá Jesús, ta kaá na̱: 
\p ―Ta ndoꞌó viti, ¿ndá yoo kúú yuꞌu̱, kaá ndo̱ꞌó? 
\p Dá ni̱ kaa Pedro xíꞌín ná: 
\p ―Mií ní kúú Cristo, na̱ dáka̱ki ñaá. 
\p  
\v 30 Tído ni̱ saꞌanda Jesús choon no̱ó ta̱ xíonoo xíꞌín ná ña̱ ná o̱ sa̱ kóo ini ra̱ kaꞌa̱n ra̱ xíꞌín ni iin tóꞌón ña̱yuu ndá yoo kúú ná. 
\s1 Yóꞌo ni̱ ka̱sto̱ꞌon Jesús xíꞌín ta̱a xíonoo xíꞌín ná ndí ki̱án ndoꞌo na, dá kuu na̱ 
\p  
\v 31 Dá ni̱ ka̱sáꞌá Jesús dánaꞌa̱ na̱ no̱ó ta̱ xíonoo xíꞌín ná ña̱ kánian ndoꞌo naní nío̱ na̱ ni̱ nduu ta̱a ñayuú yóꞌo, chi̱ kuñóꞌó ñaá ta̱ sáꞌano ñoo, xíꞌín ta̱ duti̱ sakua̱ꞌa̱, xíꞌín ta̱a dánaꞌa̱ ley Moisés, ta kánian kuu na̱. Tído tá ná ya̱ꞌa oni̱ kuu̱, dá nataki na̱.  
\v 32 Yóꞌo kía̱n ni̱ kaꞌa̱n ndaa̱ Jesús táto̱ꞌon ndoꞌo mií ná cháá ka̱ chí noo̱. Dá ni̱ taó xóo ñaá Pedro. Dá ni̱ ka̱sáꞌá dána̱ni ñaá rá sa̱ꞌá ña̱ ni̱ kaꞌa̱n na̱ dión.  
\v 33 Tído ni̱ na̱ndió ko̱o Jesús ni̱ sa̱ nde̱ꞌé ná noo̱ ndíta dao ka̱ ta̱ xíonoo xíꞌín ná. Dá ni̱ da̱náni na Pedro, ta kaá na̱ xíꞌín rá: 
\p ―Kuaꞌán kuxoo noo̱í, dá chi̱ kéeón táto̱ꞌon kée ña̱ uꞌu̱, chi̱ ko̱ nákani ino̱n sa̱ꞌá ña̱ kóni̱ Ndios, diꞌa nákani ino̱n táto̱ꞌon ki̱ꞌo nákani ini ta̱a va ―kaá na̱. 
\s1 Yóꞌo ni̱ ka̱sto̱ꞌon Jesús ndí ki̱án kánian kee ña̱yuu tá kóni̱ na̱ kanoo na xíꞌín ná 
\p  
\v 34 Dá ni̱ kana Jesús ta̱a xíonoo xíꞌín ná, xíꞌín dao ka̱ ña̱yuu ñoó, dá ni̱ kaa na̱ xíꞌín ná: 
\p ―Ndi ndáa ndo̱ꞌó káꞌán kanoo xíꞌín yuꞌu̱, dá kía̱n kánian dánkoo ndó ña̱ kóni̱ mií ndó, ta natiin ndó cruz, ña̱ kía̱n ió ndo̱ kuu ndo̱ sa̱ꞌí, ta ndiko̱ ndo̱ yuꞌu̱, ná koꞌo̱.  
\v 35 Chi̱ ndi ndáa na̱ kóni̱ dáka̱ki na mií ná ñayuú yóꞌo, no̱ón kúú na̱ kuu diꞌa. Tído ndi ndáa na̱ xíꞌo mií ña̱ kuu na̱ saꞌa̱ yúꞌu̱, o saꞌa̱ to̱ꞌon va̱ꞌa dánaꞌi̱, no̱ón kúú na̱ niꞌi̱ ña̱ ka̱ki na.  
\v 36 Dá chi̱, ¿ndi ki̱án va̱ꞌa niꞌi̱ ña̱yuu tá ná kandeé ná niꞌi̱ ná ndidaá ña̱ kui̱ká ió ñayuú yóꞌo, ta naá vá ná noo̱ Ndios?  
\v 37 Ta, ¿ndí ki̱án kúú ña̱ꞌa ndáya̱ꞌi cháá ka̱ tá o̱ du̱ú ña̱ niꞌi̱ ná ña̱ kataki chíchí ná, káꞌán ndó? 
\p  
\v 38 ’Ta ndi ndáa ña̱yuu ná xíkaꞌan noo̱ sa̱ꞌá yuꞌu̱ o sa̱ꞌá to̱ꞌin no̱ó ña̱yuu kini, no̱ó ña̱yuu kómí kua̱chi ndéi tiempo yóꞌo, dá kía̱n kakaꞌan taꞌani no̱ó na̱ ni̱ nduu ta̱a ñayuú yóꞌo saꞌa̱ ña̱yuu ñoó tá ná kasandaá kuu̱ nandió ko̱o na xíꞌín ndidaá ndée̱ ndato ni̱ xi̱ꞌo tatá Ndios noo̱ ná, xíꞌín ndidaá ángel kéchóon noo̱ ná ―kaá na̱. 
\c 9  
\p  
\v 1 Dá ni̱ kaa taꞌani Jesús xíꞌín rá: 
\p ―Miía̱n ndaa̱ ná kaꞌi̱n xíꞌín ndó ña̱ ió dao ndoꞌó, na̱ ndíta yóꞌo, o̱ ku̱ú taꞌon ndó nda̱ ná koni ndo̱ ndi ki̱ꞌo dándáki Ndios xíꞌín ndidaá kúú choon néꞌe ná ―kaá na̱. 
\s1 Diꞌa ni̱ kuu tá ni̱ na̱yeꞌe̱ ndaa noo̱ Jesús xíꞌín dáꞌo̱n ná 
\p  
\v 2 Tá ni̱ ya̱ꞌa iño̱ kuu̱, dá ni̱ kee Jesús ndáka na Pedro, xíꞌín Jacobo, xíꞌín Juan kuaꞌa̱n na̱ dini̱ iin yúku̱ dikó íin ñoó. Ta ñoó ni̱ na̱da̱on na táto̱ꞌon káa na no̱ó ta̱a ñoó.  
\v 3 Kúú ni̱ na̱yeꞌe̱ ndaa dáꞌo̱n ná. Ta kúú ni̱ ndu̱ku̱xí kachi̱án táto̱ꞌon ki̱ꞌo ndéꞌé yiꞌo̱. Ta ni iin ña̱yuu nákata dáꞌo̱n ndéi ñayuú yóꞌo ko̱ kándeé taꞌon dándúkuxía̱n táto̱ꞌon ki̱ꞌo ndato kuxí ni̱ nduu dáꞌo̱n Jesús.  
\v 4 Dá ni̱ naꞌa̱ noo̱ profeta Elías xíꞌín Moisés, ta ndíta na ndátóꞌón ná xíꞌín Jesús.  
\v 5 Dá ni̱ kaa Pedro xíꞌín Jesús: 
\p ―Va̱ꞌa kúú ndéi nduꞌu̱ yóꞌo, maestro. Ná kava̱ꞌa ndu oni̱ ti̱yaꞌó. Iian ná koo mií ní, ta iian ná koo Moisés, ta iin ka̱a̱n ná koo Elías. 
\p  
\v 6 Dión ni̱ kaa ra̱, chi̱ ko̱ náꞌá taꞌon ra ndí ki̱án káꞌa̱n ra̱ sa̱ꞌá ña̱ ni̱ yu̱ꞌú ra̱.  
\v 7 Kúú ni̱ na̱xino̱ iin viko̱. Ta kúú ni̱ chi̱káti̱án noo̱ ndíta na. Ta tein viko̱ ñoó ni̱ kaꞌa̱n tachi̱ Ndios: 
\p ―Ta yóꞌo kúú de̱ꞌe mani̱ yuꞌu̱. Kueídóꞌo ndó to̱ꞌon káꞌa̱n xi̱ ―kaá na̱. 
\p  
\v 8 Tá ni̱ na̱nde̱ꞌé tuku ra, kúú sa̱ ko̱ó ka̱ va ta̱a ñoó ndíta. Nda̱dá iin tóꞌón míí vá Jesús íin. 
\p  
\v 9 Ta noo̱ ko̱noo na kuaꞌa̱n na̱ ndi̱ka yúku̱ ñoó, dá ni̱ saꞌanda Jesús choon no̱ó ta̱a ni̱ saꞌa̱n xíꞌín ná ñoó ña̱ ná o̱ sa̱ kóo ini ra̱ nakani ra xíꞌín ni iin tóꞌón ña̱yuu sa̱ꞌá ña̱ ni̱ xini ra̱ dini̱ yúku̱ ñoó nda̱ ná kasandaá kuu̱ nataki na̱ ni̱ nduu ta̱a ñayuú yóꞌo.  
\v 10 Sa̱ꞌá ño̱ó ko̱ ní nákani taꞌon ra sa̱ꞌán. Dá ni̱ ka̱sáꞌá ndátóꞌón míí rá kuaꞌa̱n ra̱ ndi kuaꞌa̱n ña̱ ni̱ kaꞌa̱n Jesús ña̱ nataki na̱.  
\v 11 Dá ni̱ nda̱to̱ꞌón ñaá rá: 
\p ―¿Ndiva̱ꞌa káꞌa̱n ta̱a dánaꞌa̱ ley Moisés ña̱ dinñóꞌó ka̱ kánian kii profeta Elías, dá kasaa̱ na̱ dáka̱ki ñaá? 
\p  
\v 12 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Ndaa̱ va ña̱ dinñóꞌó ka̱ kánian kii Elías ndeyíko̱ na̱ ndidaá ña̱ꞌa. Ta, ¿á ko̱ náꞌá taꞌon ndó ña̱ káꞌa̱n taꞌani tuti ii̱ Ndios ña̱ kánian ndoꞌo nda̱ꞌo nío̱ na̱ ni̱ nduu ta̱a ñayuú yóꞌo, ta kenóo nda̱ꞌo ñaá ña̱yuu?  
\v 13 Tído yuꞌu̱ kúú na̱ ka̱á ña̱ sa̱ ni̱ kixi va Elías, ta ni̱ kee ra xíꞌín ná táto̱ꞌon ki̱ꞌo ni̱ kaꞌán rá kee ra, chi̱ ki̱ꞌo dión káꞌa̱n tuti ii̱ Ndios saꞌa̱ ná ―ka̱á Jesús. 
\s1 Diꞌa ni̱ kuu tá ni̱ ndu̱va̱ꞌa Jesús iin tayií nákaa̱ espíritu kini 
\p  
\v 14 Tá ni̱ na̱xino̱ na̱ no̱ó ni̱ ka̱ndo̱o dao ka̱ ta̱a xíonoo xíꞌín ná, kúú ni̱ xini na̱ kua̱ꞌá nda̱ꞌo ña̱yuu ndíta noo̱ ndéi ra. Ta ndíta taꞌani dao ta̱a dánaꞌa̱ ley Moisés dándichi̱ ñaá rá.  
\v 15 Tá ni̱ xini ña̱yuu ñoó ña̱ ve̱i Jesús, kúú ni̱ naá vá iní na̱ ndéꞌé ñaá ná. Dá ni̱ kee na taxí táꞌan na kuaꞌa̱n na̱ kaꞌa̱n na̱ ndisáꞌán xíꞌín ná. 
\p  
\v 16 Dá ni̱ nda̱to̱ꞌón Jesús ta̱a xíonoo xíꞌín ná: 
\p ―¿Ndá saꞌa̱ dándichi̱ táꞌan ndó xíꞌín ta̱a dánaꞌa̱ ley Moisés káa? 
\p  
\v 17 Dá ni̱ kaa iin ta̱a nákaa̱ tein ña̱yuu kuáꞌa̱ ñoó xíꞌín ná: 
\p ―Maestro, yóꞌo néꞌi de̱ꞌi ni̱ ka̱sáa̱i̱, dá chi̱ nákaa̱ espíritu kini ini xi̱, ta ni̱ ka̱ndo̱o ñíꞌi̱ xi̱ kéean.  
\v 18 Ndeí kúú míí vá noo̱ nákaa̱ xi̱, ta tíin ñaá espíritu kini yóꞌo, ta dánkao ñaáán nda̱ no̱ñóꞌo̱, ta kánkuei chiꞌi̱o̱n yúꞌu̱ xí, ta chíchi táꞌan no̱ꞌo xi, ta kúyito xi̱ kéean. Sa̱ ni̱ seí ndaꞌávíi̱ no̱ó ta̱a xíonoo xíꞌín ní ña̱ ná taó ráa̱n, tído ko̱ ní kándeé taꞌon ra ―kaá ra̱. 
\p  
\v 19 Dá ni̱ kaa Jesús xíꞌín ta̱a xíonoo xíꞌín ná: 
\p ―¡Nandeé ka̱ vía̱n ña̱yuu ko̱ kándísa kúú ndoꞌó! ¿Ndidaá ka̱ ví kooi xíꞌín ndó, dá kandeé ini ndo̱ yuꞌu̱? Ta, ¿ndidaá ka̱ ví ki̱ꞌo ndeé inii̱ saꞌa̱ ndo̱? Kaneꞌe ndó xi̱ ná kii ndó ―kaá na̱. 
\p  
\v 20 Dá néꞌe ña̱yuu ñoó tayií lóꞌo̱ ñoó ni̱ ka̱sáa̱ na̱ noo̱ íin Jesús. Dá tá ni̱ xini espíritu kini ñoó Jesús, ta kúú ni̱ saꞌání yi̱ꞌí va ñaáán, ta kúú ni̱ ka̱nkao xi nda̱ no̱ñóꞌo̱ ni̱ keean, ta ni̱ da̱ndió tuú ñaáán. Ta kúú kánkuei chiꞌi̱o̱n yúꞌu̱ xí.  
\v 21 Dá ni̱ nda̱to̱ꞌón Jesús tatá xi: 
\p ―¿Ndá oon ni̱ ka̱sáꞌá ndóꞌo xi dión? 
\p Dá ni̱ kaa ra̱: 
\p ―Nda̱á leé va xi ni̱ ka̱sáꞌá ndóꞌo xi dión.  
\v 22 Ta kua̱ꞌá nda̱ꞌo taꞌándá dánkao ñaá espíritu kini yóꞌo noo̱ kéi̱ ñóꞌo̱, no̱ó ta̱kui̱í viti, dá chi̱ kaꞌání ñaáán kóni̱a̱n. Tá kandeé ní nduva̱ꞌa ní xi̱, dá kía̱n kuꞌu̱ ini ní sa̱ꞌá nduꞌu̱, ta chindeé ní nduꞌu̱. 
\p  
\v 23 Dá ni̱ kaa Jesús: 
\p ―Ná dáꞌa ni kaꞌo̱n, “tá kandeé ní nduva̱ꞌa ní xi̱”, chi̱ ndidaá vá ña̱ꞌa kuu kee yuꞌu̱ xíꞌín ña̱yuu kándéé iní ñaá. 
\p  
\v 24 Kúú ni̱ ka̱yuꞌú tatá xi: 
\p ―Kándéé iníi̱ mií ní. Ta chindeé ní yuꞌu̱ ná kandeé cháá ka̱ iníi̱ mií ní ―kaá ra̱. 
\p  
\v 25 Tá ni̱ xini Jesús ña̱ ni̱ ka̱sáꞌá nátaka kua̱ꞌá nda̱ꞌo ña̱yuu, dá ni̱ saꞌanda na̱ choon noo̱ espíritu kini ñoó, ta kaá na̱: 
\p ―¡Espíritu kini, espíritu kéñíꞌi̱, espíritu kédóꞌó! ¡Yuꞌu̱ saꞌándá choon noo̱o̱n! ¡Kuaꞌán keta kíi̱ ini tayií xaa̱n! ¡Ta o̱ sa̱ nándió ko̱o ka̱o̱n ndu̱ꞌón ini xi̱! ―kaá na̱ xíꞌán. 
\p  
\v 26 Dá ni̱ ka̱yuꞌú kóꞌóán. Ta kúú tuku va ni̱ saꞌání yi̱ꞌí ñaáán. Dá ví ni̱ ketaan kuaꞌa̱n ini xi̱. Ta kúú táto̱ꞌon kánduꞌu̱ iin ndi̱i, ki̱ꞌo dión ni̱ na̱ndúꞌu̱ xí ni̱ kee espíritu kini ñoó. Sa̱ꞌá ño̱ó kua̱ꞌá nda̱ꞌo ña̱yuu ñoó káꞌa̱n ña̱ ni̱ xiꞌi̱ va xi.  
\v 27 Dá ni̱ tiin Jesús ndáꞌa̱ xí. Dá ni̱ nda̱neꞌe ñaá ná. Ta kúú ni̱ na̱kuíi̱n ndichi xi. 
\p  
\v 28 Tá ni̱ ndiꞌi, dá ni̱ ku̱ꞌu Jesús ini iin veꞌe íin ñoó. Dá ni̱ nda̱to̱ꞌón ñaá ta̱a xíonoo xíꞌín ná: 
\p ―¿Ndiva̱ꞌa ko̱ ní kándeé nduꞌu̱ taó ndú espíritu kini ñoó? 
\p  
\v 29 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Tá ná o̱ káka̱ ndo̱ ña̱ mani̱ noo̱ Ndios, ta ná o̱ káneꞌe ii̱ ndo̱, dá kía̱n o̱ kándeé taꞌon ndó taó ndóa̱n, chi̱ ña̱ kini nda̱ꞌo kíán ―kaá na̱. 
\s1 Yóꞌo ni̱ ka̱sto̱ꞌon tuku Jesús xíꞌín ta̱a xíonoo xíꞌín ná ndí ki̱án ndoꞌo na, dá kuu na̱ 
\p  
\v 30 Dá ni̱ keta Jesús xíꞌín ta̱a xíonoo xíꞌín ná ñoó, dá ni̱ kee na kuaꞌa̱n na̱ chí kuendá Galilea diꞌa. Ta ko̱ kóni̱ taꞌon Jesús ña̱ kandaa̱ ini dao ka̱ ña̱yuu ndeí koꞌo̱n na̱,  
\v 31 chi̱ kóni̱ na̱ dánaꞌa̱ na̱ sa̱va̱ꞌa no̱ó ta̱a xíonoo xíꞌín ná ñoó, ta diꞌa ni̱ kaa na̱ xíꞌín rá: 
\p ―Koꞌo̱n iin ta̱a naki̱ꞌo ra na̱ ni̱ nduu ta̱a ñayuú yóꞌo noo̱ ndáꞌa̱ ta̱ tu̱kú, dá kaꞌání ñaá rá. Tído ti̱xi kuu̱ óni̱, ta kúú nataki va na ―kaá na̱. 
\p  
\v 32 Tído ko̱ kátóni̱ taꞌon ini ra̱ ndiva̱ꞌa káꞌa̱n na̱ dión, chi̱ yuꞌú ra̱ ndato̱ꞌón ñaá rá. 
\s1 Yóꞌo ni̱ da̱náꞌa̱ Jesús sa̱ꞌá ndi ndáa ra kúú ta̱ ndáya̱ꞌi cháá ka̱ noo̱ Ndios 
\p  
\v 33 Dá ni̱ saa̱ na̱ ñoo káꞌano naní Capernaum. Ta noo̱ ndéi na ini iin veꞌe, dá ni̱ nda̱to̱ꞌón Jesús ta̱a xíonoo xíꞌín ná: 
\p ―¿Ndá saꞌa̱ ndátóꞌón kuáchi̱ ndo̱ ve̱i ndó íchi̱ ñoó? ―kaá na̱. 
\p  
\v 34 Tído ni iin tóꞌón rá ko̱ ní kaꞌa̱n, dá chi̱ no̱ó ve̱i ra íchi̱ ñoó ndátóꞌón kuáchi̱ ra̱ saꞌa̱ ndi ndáa ra kúú ta̱a ndáya̱ꞌi cháá ka̱ tein mií rá.  
\v 35 Dá ni̱ sa̱ ko̱o Jesús. Dá ni̱ kana na ta̱ xíonoo xíꞌín ná ñóó. Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Ndi ndáa ndoꞌó kátoó kakuu ta̱a kandaya̱ꞌi kuiin noo̱, dá kía̱n kasandaá ndo̱ kakuu ndó na̱ íin sata̱ kuií, ta koni kuáchí ndó noo̱ ndidaá ka̱ na̱ ―ka̱á na̱. 
\p  
\v 36 Dá ni̱ tiin Jesús ndáꞌa̱ iin tayií lóꞌo̱. Dá ni̱ chi̱kani ñaá ná no̱ó ta̱a xíonoo xíꞌín ná ñóó. Dá ni̱ nda̱neꞌe ndaa ñaá ná. Dá ni̱ kaa na̱: 
\p  
\v 37 ―Ndi ndáa miíó ña̱yuu natiin va̱ꞌa iin ta lóꞌo̱ táto̱ꞌon kúú ta yóꞌo sa̱ꞌá ña̱ kúú ná kuendá yuꞌu̱, dá kía̱n nda̱ mií vá yuꞌu̱ ni̱ na̱tiin va̱ꞌa na. Ta na̱ ni̱ na̱tiin va̱ꞌa yuꞌu̱, nda̱ tatá Ndios ni̱ na̱tiin na, chi̱ mií ná ni̱ ta̱ndaꞌá yuꞌu̱ ve̱ii ñayuú yóꞌo ―kaá na̱. 
\s1 Kaá Jesús ña̱ ña̱yuu ko̱ na̱á xíꞌín ná, no̱ón kúú na̱ ndíta xoo mií ná 
\p  
\v 38 Dá ni̱ kaa Juan xíꞌín ná: 
\p ―Maestro, ni̱ xini nduꞌu̱ iin ta̱a taó espíritu kini xíꞌín kuu̱ mií ní. Tído ko̱ xíonoo taꞌon ra xíꞌín yó, sa̱ꞌá ño̱ó ni̱ chi̱tuu va nduꞌu̱ ra̱. 
\p  
\v 39 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Ná dáꞌa ni chituu ndó ra̱, dá chi̱ ndi ndáa miíó ña̱yuu kée ña̱ ndato xíꞌín kuu̱ yúꞌu̱, no̱ón kúú na̱ o̱ kúu taꞌon kaꞌa̱n ndava̱ꞌa na sa̱ꞌí.  
\v 40 Chi̱ na̱ ko̱ na̱á xíꞌá, no̱ón kúú na̱ ndíta xoo yó.  
\v 41 Ta ndi ndáa miíó ña̱yuu naki̱ꞌo, va̱ꞌará iin yáxi̱ lóꞌo̱ ta̱kui̱í ná koꞌo ndó saꞌa̱ ña̱ kúú ndó kuendá yuꞌu̱, na̱ kúú Cristo, ta kúú miía̱n ndaa̱ kuiti káꞌi̱n xíꞌín ndó ña̱ nandió néꞌe Ndios ña̱ va̱ꞌa noo̱ ná ―kaá Jesús. 
\s1 Miía̱n ndúsa̱ kandaa yo̱ mií yó, dá chi̱ oon ni ví ya̱ꞌa iin ka̱ na̱ kee na kua̱chi saꞌa̱ yo̱ 
\p Dá ni̱ kaa taꞌani Jesús: 
\p  
\v 42 ―Ndi ndáa mií vá ña̱yuu ni̱ ka̱ndeé ni̱ da̱káꞌa̱n kue̱ꞌé takuálí kándísa yuꞌu̱ ña̱ ná ya̱ꞌa xi kee xi kua̱chi, no̱ón kúú na̱ va̱ꞌa cháá ka̱ ná kandiko̱ yuu̱ molino diko̱ ná, ta ná dáke̱ta ñaá ná ini ta̱ñoꞌo̱.  
\v 43 Tá yáꞌa ndó kée ndó kua̱chi xíꞌín ndáꞌa̱ ndo̱, dá kía̱n kaꞌanda ndo̱ iin xooan. Chi̱ va̱ꞌa cháá ka̱ ví ña̱ ku̱ꞌu ndó noo̱ ió Ndios xíꞌín iin xoo ndáꞌa̱ ndo̱, ta o̱ du̱ú ka̱a̱n koꞌo̱n ndo̱ xíꞌín ndin nduú xoo ndáꞌa̱ ndo̱ indayá noo̱ kéi̱ ñóꞌo̱, táꞌa̱n ña̱ ni iin kuu̱ o̱ ndáꞌo̱,  
\v 44 noo̱ ñóꞌo ti̱ku̱dí seí ñaá, kirí ko̱ xíꞌi̱, dá ri ñóꞌo̱ kei̱ ñoó, ni iin kuu̱ o̱ ndáꞌo̱ ña̱.  
\v 45 Tá yáꞌa ndó kée ndó kua̱chi xíꞌín saꞌa̱ ndo̱, dá kía̱n kaꞌanda ndo̱ iin xooan. Chi̱ va̱ꞌa cháá ka̱ ña̱ ku̱ꞌu ndó xíꞌín iin xoo saꞌa̱ ndo̱ noo̱ ió Ndios, ta o̱ du̱ú ka̱a̱n koꞌo̱n ndo̱ xíꞌín ndin nduú xoo saꞌa̱ ndo̱ indayá noo̱ kéi̱ ñóꞌo̱, táꞌa̱n ña̱ ni iin kuu̱ o̱ ndáꞌo̱,  
\v 46 noo̱ ñóꞌo ti̱ku̱dí seí ñaá, kirí ko̱ xíꞌi̱, dá ri ñóꞌo̱ kéi̱ ñoó, ni iin kuu̱ o̱ ndáꞌo̱ ña̱.  
\v 47 Ta tá yáꞌa ndó kée ndó kua̱chi xíꞌín iin nduchí nóó ndo̱, dá kía̱n taó ndóa̱n. Chi̱ va̱ꞌa cháá ka̱ ña̱ ku̱ꞌu ndó xíꞌín iin xoo nduchí nóó ndo̱ noo̱ ió Ndios dándáki na, ta o̱ du̱ú ka̱a̱n koꞌo̱n ndo̱ xíꞌín ndin nduú nduchí nóó ndo̱ indayá,  
\v 48 noo̱ ñóꞌo ti̱ku̱dí seí ñaá, kirí ko̱ xíꞌi̱, dá ri ñóꞌo̱ kéi̱ ñoó, ni iin kuu̱ o̱ ndáꞌo̱ ña̱. 
\p  
\v 49 ’Chi̱ ndidaá vá ña̱yuu kando̱o vii kee ñii̱ xíꞌín ñóꞌo̱, ta ndidaá ña̱ꞌa dóko̱ ná noo̱ Ndios kando̱o vii kee ñii̱.  
\v 50 Ta iin ña̱ va̱ꞌa kúú ñii̱, tído tá ni̱ ndiꞌi ña̱ oꞌo̱va̱a̱n, ¿ndi koo keeá, dá keꞌoꞌo̱va̱ tuku yóa̱n? Choꞌon ini ndo̱ kechóon va̱ꞌa ndó táto̱ꞌon kéchóon va̱ꞌa ñii̱, dá koni ndo̱ kandei va̱ꞌa ndó xíꞌín iin ndó xíꞌín iin ka̱ ndo̱ ―kaá Jesús. 
\c 10  
\s1 Diꞌa kuaꞌa̱n ña̱ ni̱ da̱náꞌa̱ Jesús saꞌa̱ ña̱ ko̱ váꞌa dánkoo ta̱a ñadiꞌí ra̱ 
\p  
\v 1 Dá ni̱ keta Jesús ñoo ñoó kuaꞌa̱n na̱ xíꞌín ta̱ xíonoo xíꞌín ná. Dá ni̱ ya̱ꞌa na noo̱ kúú kuendá Judea. Dá ni̱ kasa̱ndaá na̱ iin ka̱ xoo yu̱ta naní Jordán. Ta ñóó ni̱ na̱taka tuku ña̱yuu noo̱ Jesús. Dá ni̱ da̱náꞌa̱ tuku na táto̱ꞌon ki̱ꞌo kée na.  
\v 2 Dá ni̱ na̱tuu yati dao ta̱ fariseo noo̱ íin na, dá ni̱ kaꞌán rá dátu̱ú ñaá rá no̱ó ña̱yuu ñoó. Sa̱ꞌá ño̱ó ni̱ nda̱to̱ꞌón ñaá rá: 
\p ―¿Á kuu dánkoo iin ta̱a ñadiꞌí ra̱? 
\p  
\v 3 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―¿Ndí ni̱ saꞌanda Moisés choon noo̱ ndo̱ sa̱ꞌá ña̱ yóꞌo? 
\p  
\v 4 Dá ni̱ kaa ta̱ fariseo xíꞌín ná: 
\p ―Ni̱ sonó vá Moisés ña̱ kuu va ki̱ꞌo iin ta̱a iin tuti noo̱ ñadiꞌí ra̱ ña̱ káꞌa̱n ña̱ kóni̱ ra̱ kaꞌanda táꞌan ra xíꞌán. Ndiꞌi daá, dá kuu va dánkoo ñaá rá. 
\p  
\v 5 Dá ni̱ kaa Jesús: 
\p ―Sa̱ꞌá ña̱ káxí nda̱ꞌo nío̱ ndo̱, sa̱ꞌá ño̱ó ni̱ sonó Moisés noo̱ ndo̱ ña̱ kuu kee ndó dión,  
\v 6 tído nda̱ míí saꞌa̱, tá kuu̱ ni̱ ka̱va̱ꞌa Ndios ndidaá ña̱ꞌa, “nda̱ daá vá ni̱ ka̱va̱ꞌa na iin ta̱a xíꞌín iin ñáꞌa̱”.  
\v 7 “Sa̱ꞌá ño̱ó kánian dánkoo ta̱a tatá ra̱ xíꞌín naná ra̱, dá nakiꞌin táꞌan ra xíꞌín ñadiꞌí ra̱,  
\v 8 dá kía̱n nduu na nda̱dá iin tóꞌón vá.” Ta ko̱ kúú ka̱ na̱ uu̱, nda̱dá iin tóꞌón vá kúú ná.  
\v 9 Ta mií Ndios kúú na̱ ni̱ da̱kíꞌin táꞌan ñaá, sa̱ꞌá ño̱ó ni iin tóꞌón ña̱yuu ko̱ kánian kaꞌanda táꞌan na ―ka̱á na̱. 
\p  
\v 10 Dá tá ni̱ ndi̱sáa̱ na̱ veꞌe noo̱ ndéi na, dá ni̱ nda̱to̱ꞌón ñaá ta̱ xíonoo xíꞌín ná ndi kóni̱ kaa ña̱ ni̱ kaꞌa̱n na̱.  
\v 11 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Ndi ndáa miíó ta̱a ni̱ da̱nkoo ñadiꞌí ra̱, ta ni̱ ta̱ndáꞌa̱ rá xíꞌín iin ka̱ ñáꞌa̱, ro̱ón kúú ra̱ yáꞌa kée kua̱chi xíꞌín iin ka̱ ñáꞌa̱ ñoó noo̱ Ndios.  
\v 12 Ta ndi ndáa mií vá ñáꞌa̱ ni̱ da̱nkoo yíi̱a̱n, ta ni̱ ta̱ndáꞌa̱n xíꞌín iin ka̱ ta̱a, dá kía̱n yáꞌa taꞌanián kéeán kua̱chi xíꞌín iin ka̱ ta̱a ñoó noo̱ Ndios ―kaá na̱. 
\s1 Yóꞌo ni̱ xika̱ Jesús ña̱ mani̱ saꞌa̱ takuálí noo̱ Ndios 
\p  
\v 13 Ta ndáka ña̱yuu ñoó takuálí ve̱i na noo̱ Jesús, dá ná chinóo na ndáꞌa̱ ná dini̱ xí. Tído ni̱ ka̱sáꞌá ta̱a xíonoo xíꞌín ná dána̱ni ra ña̱yuu ñoó.  
\v 14 Ta ko̱ ní nátaꞌan taꞌon ini Jesús tá ni̱ xini na̱ ña̱ kée ra dión. Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Konó ndó noo̱ takuálí xaa̱n ná kii xi noo̱ yúꞌu̱. Ná dáꞌa ni chituu ndó xi̱, dá chi̱ ña̱yuu kándéé ini tatá Ndios táto̱ꞌon kándéé ini takuálí xaa̱n tatá xi̱, no̱ón kúú na̱ ñóꞌo ti̱xi ndáꞌa̱ Ndios.  
\v 15 Miía̱n ndaa̱ ná kaꞌi̱n xíꞌín ndó ña̱ ndi ndáa na̱ ko̱ kándía ña̱ dándáki ñaá Ndios táto̱ꞌon ki̱ꞌo kándía takuálí ña̱ dándáki ñaá tatá xi̱, no̱ón kúú na̱ o̱ ko̱ní ndu̱ꞌu na ti̱xi ndáꞌa̱ Ndios ―ka̱á Jesús. 
\p  
\v 16 Dá ni̱ nomi na takuálí ñoó. Dá ni̱ chi̱nóo na ndáꞌa̱ ná dini̱ xí. Dá ni̱ xika̱ na̱ ña̱ mani̱ noo̱ Ndios saꞌa̱ xí. 
\s1 Diꞌa ni̱ kaꞌa̱n Jesús xíꞌín iin ta̱a kui̱ká 
\p  
\v 17 Dá ni̱ na̱kiꞌin tuku Jesús íchi̱ kuaꞌa̱n na̱, dá kánkono iin ta̱a ni̱ saa̱ ra̱ ni̱ sa̱ kuíi̱n xi̱tí rá noo̱ ná. Dá ni̱ kaa ra̱ xíꞌín ná: 
\p ―Maestro va̱ꞌa kúú ní. Ta, ¿ndí ki̱án kánian kee yuꞌu̱, dá ni̱ꞌí ña̱ kataki chíchíí? 
\p  
\v 18 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―¿Ndiva̱ꞌa káꞌa̱n yo̱ꞌó ña̱ kúú yuꞌu̱ iin na̱ va̱ꞌa? Ta ni iin tóꞌón ña̱yuu ko̱ kúú na̱ va̱ꞌa. Sa̱va̱ꞌa iin tóꞌón dini̱ Ndios vá kúú na̱ va̱ꞌa.  
\v 19 “Sa̱ náꞌá vá yoꞌó ndi kuaꞌa̱n choon ni̱ saꞌanda Ndios: o̱ sa̱ kéeón kua̱chi xíꞌín iin ñáꞌa̱, ñá ko̱ kúú ñadiꞌóo̱n, ta o̱ sa̱ kaꞌánóo̱n ndi̱i, ta o̱ sa̱ kíꞌin kuíꞌínón, ta o̱ sa̱ káꞌo̱n ña̱ to̱ꞌón, ta o̱ sa̱ dándaꞌávóo̱n ña̱yuu, ta koo ña̱ñóꞌó noo̱ tatóo̱n xíꞌín noo̱ nanóo̱n” ―kaá na̱. 
\p  
\v 20 Dá ni̱ kaa ta̱a ñoó: 
\p ―Nda̱ lóꞌo̱ vei ni̱ ka̱sáꞌá seídóꞌi ndidaá choon yóꞌo, maestro. 
\p  
\v 21 Dá ni̱ kuꞌu̱ ini Jesús saꞌa̱ rá, dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Nda̱dá iin tóꞌón vá ña̱ꞌa kómani̱ keeón viti, tá dáá. Kuaꞌán di̱kó ndiꞌón ña̱ꞌa ió noo̱o̱n. Ta dasón di̱ꞌón ñoó no̱ó na̱ kúndaꞌí, dá kía̱n kono̱n koo kui̱kón chí induú. Dá kisón kanoón xíꞌín yuꞌu̱. 
\p  
\v 22 Tá ni̱ seídóꞌo ra ña̱ ni̱ kaꞌa̱n Jesús, kúú nda̱á ndaꞌí va ni̱ kuu ini ra̱, dá ni̱ nda̱kuíi̱n ra̱ kuaꞌa̱n ra̱ xíꞌa̱n kúndaꞌí ini ra̱, chi̱ ta̱ kui̱ká nda̱ꞌo kúú rá. 
\s1 Diꞌa kuaꞌa̱n ña̱ ni̱ da̱náꞌa̱ Jesús sa̱ꞌá na̱ kui̱ká 
\p  
\v 23 Dá ni̱ na̱nde̱ꞌé Jesús noo̱ ndidaá ña̱yuu ni̱ kao̱ noo ndíta ñoó. Dá ni̱ kaa na̱ xíꞌín ta̱ xíonoo xíꞌín ná ñóó: 
\p ―¡Nandeé ka̱ ví kuáchi̱ kíán, dá ndu̱ꞌu na̱ kómí ña̱ kui̱ká ti̱xi ndáꞌa̱ Ndios! 
\p  
\v 24 Ni̱ naá vá iní ta̱ xíonoo xíꞌín ná tá ni̱ sei̱do̱ꞌo ra ña̱ ni̱ kaꞌa̱n na̱ dión. Tído ni̱ na̱ndió ko̱o tuku Jesús ni̱ kaꞌa̱n na̱: 
\p ―¡Nandeé ka̱ ví kuáchi̱, dá ndu̱ꞌu na̱ kándéé téí iní ña̱ kui̱ká ná ti̱xi ndáꞌa̱ Ndios!  
\v 25 Kaon cháá ka̱ chikaꞌanda iin camello yái̱ iin ión tu̱kú o̱ du̱ú ña̱ ndu̱ꞌu iin na̱ kui̱ká ti̱xi ndáꞌa̱ Ndios ―kaá na̱. 
\p  
\v 26 Tá ni̱ seídóꞌo ra to̱ꞌon yóꞌo, kúú kaꞌí ka̱ ví ni̱ naá iní ra̱. Dá ni̱ ka̱sáꞌá ndáto̱ꞌón táꞌan ra: 
\p ―¿Ndá yoo ni̱ꞌí ña̱ ka̱ki na, tá dáá? ―kaá ra̱. 
\p  
\v 27 Dá ni̱ na̱nde̱ꞌé ñaá Jesús, dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Ni iin tóꞌón taꞌon ña̱yuu o̱ kándeé kee dión, sa̱va̱ꞌa Ndios kúú na̱ kándeé kee dión, dá chi̱ ndidaá táꞌa̱n va ña̱ꞌa kándeé ná kee na. 
\p  
\v 28 Dá ni̱ kaa Pedro xíꞌín ná: 
\p ―Kande̱ꞌé ní, chi̱ nduꞌu̱ kúú ra̱ ni̱ da̱nkoo ndiꞌi ndidaá kúú ña̱ꞌa ió noo̱ ndú, ta xíonoo ndu xíꞌín mií ní. 
\p  
\v 29 Dá ni̱ kaa Jesús: 
\p ―Miía̱n ndaa̱ ná káꞌi̱n xíꞌín ndó, ndi ndáa miíó na̱ ni̱ da̱nkoo veꞌe na, o ñani na̱, o ki̱ꞌo na, o kuꞌu̱ na̱, o tatá na̱ xíꞌín naná na̱, o de̱ꞌe na, o ñóꞌo̱ ná saꞌa̱ yúꞌu̱ o saꞌa̱ to̱ꞌon va̱ꞌa dánaꞌi̱,  
\v 30 no̱ón kúú na̱ naniꞌi̱ iin ciento ka̱ ña̱ꞌa tiempo viti sa̱ꞌá ña̱ ni̱ da̱nkoo na, chi̱ niꞌi̱ ná kua̱ꞌá ka̱ veꞌe, xíꞌín kua̱ꞌá ka̱ ñani, xíꞌín kua̱ꞌá ka̱ ki̱ꞌo, xíꞌín kua̱ꞌá ka̱ kuꞌu̱, xíꞌín kua̱ꞌá ka̱ naná, xíꞌín kua̱ꞌá ka̱ de̱ꞌe, xíꞌín kua̱ꞌá ka̱ ñóꞌo̱, va̱ꞌará ndoꞌo naní nío̱ ná kee dao ña̱yuu. Tído cháá ka̱ chí noo̱, dá natiin na ña̱ kataki chíchí ná.  
\v 31 Tído kua̱ꞌá nda̱ꞌo ña̱yuu kúú no̱ó ñayuú yóꞌo, no̱ón diꞌa kúú na̱ kakuu noo̱ ndíꞌi kuií noo̱ Ndios. Ta na̱ kúú noo̱ ndíꞌi kuií noo̱ ña̱yuu ñayuú yóꞌo, no̱ón diꞌa kakuu na̱ nakuita no̱ó noo̱ Ndios tiempo daá ñóó. 
\s1 Yóꞌo ni̱ ka̱sto̱ꞌon tuku Jesús xíꞌín ta̱a xíonoo xíꞌín ná ndí ki̱án ndoꞌo na, dá kuu na̱ 
\p  
\v 32 Dá ni̱ kee Jesús ko̱kaa na kuaꞌa̱n na̱ íchi̱ kuaꞌa̱n ñoo Jerusalén, ta xió no̱ó na̱ kuaꞌa̱n na̱ no̱ó ta̱ xíonoo xíꞌín ná. Ta naá vá iní ra̱ kuaꞌa̱n ra̱ xíꞌín ná, ta tákuei yuꞌú ñaá rá kuaꞌa̱n ra̱. Dá ni̱ taó xóo tuku Jesús ndin uxi̱ uu̱ ta̱a ñoó tein dao ka̱ ña̱yuu ñoó. Dá ni̱ ka̱sáꞌá ná nákani na xíꞌín rá sa̱ꞌá ndí ki̱án ndoꞌo na: 
\p  
\v 33 ―Kande̱ꞌé ndó, chi̱ viti kía̱n ko̱kaa yó kuaꞌa̱n yo̱ ñoo Jerusalén. Ta koꞌo̱n iin ta̱a naki̱ꞌo ra na̱ ni̱ nduu ta̱a ñayuú yóꞌo noo̱ ndáꞌa̱ ta̱ duti̱ sakua̱ꞌa̱, xíꞌín noo̱ ndáꞌa̱ ta̱a dánaꞌa̱ ley Moisés. Ta ro̱ón kúú ra̱ kando̱o ña̱ kánian kuu na̱. Dá naki̱ꞌo ñaá rá noo̱ ndáꞌa̱ ta̱ tu̱kú.  
\v 34 Dá kedi̱ki ndaa ñaá rá, ta kani ñaá rá, ta tuu ndaa di̱í ñaá rá, dá kaꞌání ñaá rá. Tído ti̱xi kuu̱ óni̱, dá nataki na̱ ―kaá na̱. 
\s1 Diꞌa ni̱ kuu tá ni̱ xika̱ Juan xíꞌín Jacobo iin ña̱ mani̱ noo̱ Jesús 
\p  
\v 35 Dá ni̱ na̱tuu yati Jacobo xíꞌín Juan, ra̱ kúú de̱ꞌe Zebedeo, noo̱ íin Jesús. Dá ni̱ kaa ra̱ xíꞌín ná: 
\p ―Maestro, kóni̱ nduꞌu̱ ña̱ kee ní iin ña̱ mani̱ xíka̱ nduꞌu̱ noo̱ ní. 
\p  
\v 36 Dá ni̱ nda̱to̱ꞌón ñaá Jesús: 
\p ―¿Ndí ki̱án keei xíꞌín ndó, kóni̱ ndo̱? 
\p  
\v 37 Dá ni̱ kaa ra̱ xíꞌín ná: 
\p ―Konó ní ná kande̱i ndu díi̱n ní noo̱ ndato téí náyeꞌe̱ ndaa noo̱ koo ní dándáki ní. Iin nduꞌu̱ ná koo xoo kuáꞌa ní, ta iin ka̱ ndu̱ ná koo xoo íti ní. 
\p  
\v 38 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Ko̱ náꞌá taꞌon ndó ndí ki̱án xíka̱ ndo̱. ¿Á ió ndo̱ꞌó ña̱ koꞌo ndó kirá ova̱ koꞌo yuꞌu̱? ¿Á ió taꞌani ndó ña̱ kodo̱ ndúta̱ ndo̱ táto̱ꞌon ki̱ꞌo kodo̱ ndúta̱ yuꞌu̱ xíꞌín ña̱ ndoꞌi? 
\p  
\v 39 Dá ni̱ kaa ra̱ xíꞌín ná: 
\p ―Ió vá nduꞌu̱ ña̱ ndoꞌo ndu dión. 
\p Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Miía̱n ndaa̱ ndisa koꞌo ndoꞌó kirá ova̱ koꞌo yuꞌu̱, ta kodo̱ ndúta̱ taꞌani ndó xíꞌín ña̱ ndoꞌo naní nío̱ ndo̱ táto̱ꞌon ki̱ꞌo ndoꞌo yuꞌu̱.  
\v 40 Tído ña̱ kande̱i ndó xoo kuáꞌa yuꞌu̱ o xoo íti yuꞌu̱, o̱ du̱ú choon saꞌándá yuꞌu̱ kíán. Chi̱ ño̱ó kía̱n ki̱ꞌo Ndios no̱ó na̱ ni̱ ka̱xi mií ná kande̱i ñoó ―kaá na̱. 
\p  
\v 41 Dá tá ni̱ sei̱do̱ꞌo uxi̱ ka̱ ta̱a ñoó ña̱ ni̱ xika̱ Jacobo xíꞌín Juan noo̱ Jesús, kúú ni̱ ka̱ryíí nda̱ꞌo ra xíꞌín rá.  
\v 42 Dá ni̱ kana Jesús ndidaá rá, dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Sa̱ náꞌá vá ndó táto̱ꞌon ki̱ꞌo kée ta̱ néꞌe choon dándáki ra ñoo ñóꞌo ñayuú yóꞌo, chi̱ kéndúsa̱ ra̱ xíꞌín ña̱yuu kueídóꞌo ñaá ná. Ta ra̱ néꞌe choon náꞌano, saꞌándá ra̱ choon no̱ó ña̱yuu ñóꞌo ti̱xi ndáꞌa̱ rá.  
\v 43 Tído ko̱ káni taꞌan vaan kee ndó dión tein mií ndó. Chi̱ ndi ndáa ndoꞌó kátoó kakuu iin ta̱a ndáya̱ꞌi tein mií ndó, dá kía̱n kánian koni kuáchí diꞌa ndó noo̱ dao ka̱ ndo̱.  
\v 44 Ta ndi ndáa ndoꞌó kátoó kakuu noo̱, dá kía̱n kánian koni kuáchí diꞌa ndó noo̱ ndidaá ka̱ ndo̱.  
\v 45 Chi̱ ko̱ ní kásaa̱ taꞌon na̱ ni̱ nduu ta̱a ñayuú yóꞌo ña̱ koni kuáchí diꞌa ña̱yuu noo̱ ná. Diꞌa ni̱ ka̱sáa̱ na̱ koni kuáchí diꞌa na no̱ó ña̱yuu, ta naki̱ꞌo na mií ná kuu na̱, ta dión, dá di̱tá ná ndidaá ña̱yuu ti̱xi ndáꞌa̱ ña̱ kánian ndoꞌo na sa̱ꞌá kua̱chi kée na ―kaá Jesús. 
\s1 Diꞌa ni̱ kuu, dá ni̱ ndu̱va̱ꞌa Jesús iin ta̱a ko̱ túu noo̱ naní Bartimeo 
\p  
\v 46 Dá ni̱ saa̱ na̱ iin ñoo naní Jericó. Dá tá ni̱ keta na ñoo ñoó kuaꞌa̱n na̱ xíꞌín ta̱ xíonoo xíꞌín ná, kúú kua̱ꞌá nda̱ꞌo ña̱yuu tákuei kuaꞌa̱n sata̱ ná. Ta ió iin ta̱a ko̱ túu noo̱ naní Bartimeo, ra̱ kúú de̱ꞌe ra̱ naní Timeo. Ta yuꞌú íchi̱ ñoó ió ra̱ sáti ra.  
\v 47 Tá ni̱ sei̱do̱ꞌo ra ña̱ ve̱i Jesús, na̱ ñoo Nazaret, kúú ni̱ ka̱sáꞌá káyuꞌú rá: 
\p ―¡Jesús, de̱ꞌe na̱ veꞌe rey David, kuꞌu̱ ini ní sa̱ꞌí! 
\p  
\v 48 Ta kúú kua̱ꞌá nda̱ꞌo ña̱yuu ni̱ ka̱sáꞌá dána̱ni ñaá ná, dá ná kutádi̱ rá, káꞌán ná. Tído ni̱ꞌi cháá ka̱ ni̱ ka̱sáꞌá káyuꞌú rá: 
\p ―¡De̱ꞌe na̱ veꞌe rey David, kuꞌu̱ ini ní sa̱ꞌí! 
\p  
\v 49 Dá ni̱ sa̱ tuu tóo Jesús, dá ni̱ saꞌanda na̱ choon no̱ó ña̱yuu ñoó ña̱ ná kaꞌa̱n na̱ xíꞌín ta̱a ñoó saa̱ ra̱ noo̱ ná. 
\p Dá ni̱ kaa ña̱yuu ñoó xíꞌín rá: 
\p ―Ndeé koo ino̱n, ta nakuii̱n ndichi, chi̱ kána Jesús káa yo̱ꞌó koꞌo̱n. 
\p  
\v 50 Dá ni̱ da̱kána ra kotó ra̱. Kúú ni̱ na̱kuii̱n ndichi ra̱. Dá ni̱ kee ra kuaꞌa̱n ra̱ noo̱ íin Jesús.  
\v 51 Dá ni̱ nda̱to̱ꞌón ñaá ná: 
\p ―¿Ndí ki̱án kóno̱n keei xíꞌón? 
\p Dá ni̱ kaa ta̱ ko̱ túu noo̱ ñoó: 
\p ―Maestro, kóni̱i̱ ña̱ natu̱u noo̱í. 
\p  
\v 52 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Kuaꞌán viti, chi̱ sa̱ꞌá ña̱ kándéé ino̱n yuꞌu̱, sa̱ꞌá ño̱ó ni̱ ndu̱va̱ꞌón. 
\p Ta kúú vitíꞌón diꞌa ni̱ na̱tu̱u noo̱ rá. Ta kúú ni̱ kee ra tákaa ra Jesús kuaꞌa̱n ra̱. 
\c 11  
\s1 Diꞌa ni̱ kuu, dá ni̱ ku̱ꞌu Jesús ñoo káꞌano Jerusalén 
\p  
\v 1 Kúú ni̱ ku̱yati na ñoo Jerusalén, chi̱ sa̱ ni̱ kasa̱ndaá yati na ñoo naní Betfagé xíꞌín ñoo naní Betania. Ta ñoó kúú noo̱ néꞌe táꞌan yati xíꞌín iin yúku̱ naní Olivos. Dá ni̱ saꞌanda Jesús choon no̱ó uu̱ ta̱ xíonoo xíꞌín ná,  
\v 2 ta kaá na̱ xíꞌín rá: 
\p ―Kuaꞌán ndo̱ ñoo lóꞌo̱ nákaa̱ chí noo̱ káa. Tá ni̱ saa̱ ndo̱ ni̱ ku̱ꞌu ndó káa, dá naniꞌi̱ ndo̱ noo̱ ndíko̱ iin burro, kirí ko̱ ñáꞌa̱ kandodó ná. Tá ni̱ na̱níꞌi̱ ndo̱ rí, dá ndaxí ndó ri̱ kandaka ndó kii ndó.  
\v 3 Tá ndáa na̱ ndáto̱ꞌón ñáá: “¿Ndiva̱ꞌa ndáxí ndó ri̱?”, dá kaa ndo̱ xíꞌín ná: “Dá chi̱ xínñóꞌó satoꞌo ndu̱ rí, ndiꞌi daá, dá tandaꞌá ná ndu̱ kii ndu ndaka ndu ri̱”, kaa ndo̱ ―ka̱á Jesús xíꞌín rá. 
\p  
\v 4 Dá ni̱ kee ra kuaꞌa̱n ra̱. Ta kúú ni̱ na̱níꞌi̱ rá noo̱ ndíko̱ burro ñoó yati yéꞌé veꞌe íin yuꞌú íchi̱ ñoó. Dá ni̱ ndaxí rá ri̱.  
\v 5 Tá ni̱ xini dao ña̱yuu ndíta ñoó, dá ni̱ nda̱to̱ꞌón ñaá ná: 
\p ―¿Ndiva̱ꞌa ndáxí ndó burro xaa̱n? 
\p  
\v 6 Dá ni̱ kaa ra̱ táto̱ꞌon ki̱ꞌo ni̱ kaꞌa̱n Jesús xíꞌín rá. Dá ni̱ sonó vá ná néꞌe ra burro ñoó kuaꞌa̱n ra̱.  
\v 7 Ta ndáka ra ri̱ ni̱ saa̱ ra̱ noo̱ ió Jesús, dá ni̱ chi̱kodó rá kotó ra̱ sata̱ ri̱. Dá ni̱ kaa Jesús kanóo na kuaꞌa̱n na̱. 
\p  
\v 8 Dá ni̱ ka̱sáꞌá kua̱ꞌá nda̱ꞌo ña̱yuu chíndei na kotó na̱ me̱ꞌí íchi̱ no̱ó ve̱i Jesús ñoó. Ta dao ka̱ na̱ ni̱ saꞌanda ndáꞌa̱ yíto̱, dá ni̱ chi̱ndei naa̱n íchi̱ no̱ó ya̱ꞌa na ñoó. 
\p  
\v 9 Ta ña̱yuu xió no̱ó kuaꞌa̱n noo̱ Jesús xíꞌín ña̱yuu tákuei ve̱i chí sata̱ ná ni̱ ka̱sáꞌá káyuꞌú ná: 
\p ―¡Ná natiin Ndios ña̱ñóꞌó! ¡Na̱ káꞌano kúú na̱ yóꞌo, chi̱ ve̱i na xíꞌín choon satoꞌo yo̱ Ndios!  
\v 10 ¡Na̱ káꞌano kúú na̱ yóꞌo, chi̱ ve̱i na dándáki na ñoo yo̱ táto̱ꞌon ni̱ da̱ndáki ñaá rey David tá sa̱ naꞌá! ¡Ná natiin Ndios ña̱ñóꞌó nda̱ noo̱ ió na̱ noo̱ dikó! ―ka̱á ña̱yuu ñoó. 
\p  
\v 11 Dá ni̱ ku̱ꞌu Jesús ñoo Jerusalén. Dá ni̱ saꞌa̱n na̱ veꞌe ño̱ꞌo káꞌano. Tá ni̱ ndiꞌi ni̱ sa̱ nde̱ꞌé ná ndidaá ña̱ꞌa ió ñoó, dá ni̱ kee na kuaꞌa̱n na̱ ñoo naní Betania xíꞌín ndin uxi̱ uu̱ ta̱a xíonoo xíꞌín ná, chi̱ sa̱ ni̱ ini va. 
\s1 Diꞌa ni̱ ndoꞌo iin ta̱ño̱ꞌó ni̱ kee Jesús 
\p  
\v 12 Tá ni̱ tu̱u noo̱ iin ka̱ kuu̱ ñoó, dá ni̱ ka̱nkuei na ñoo Betania kuaꞌa̱n na̱. Dá ndaꞌí ni̱ ka̱sáꞌá kuíko Jesús.  
\v 13 Ta kúú ni̱ xini xíká vá ná íin iin ta̱ño̱ꞌó, ta ndato kuíi̱ íin ndáꞌa̱ ra̱. Dá ni̱ kee na kuaꞌa̱n na̱ noo̱ íin rá, ná kande̱ꞌá á íin ti̱ño̱ꞌó keí ná. Tído tá ni̱ saa̱ na̱ ni̱ sa̱ nde̱ꞌé ná, kúú ko̱ ta̱ꞌón ti̱ño̱ꞌó íin noo̱ ra̱. Sa̱va̱ꞌa ndáꞌa̱ óon va rá íin, chi̱ ko̱ ñáꞌa̱ taꞌon kasandaá yoo̱ kuiin rí.  
\v 14 Dá ni̱ kaa Jesús xíꞌín ta̱ño̱ꞌó ñoó: 
\p ―¡Ni iin kuu̱ ka̱ ná o̱ ke̱í ni iin tóꞌón ña̱yuu kui̱ꞌi yo̱ꞌó! 
\p Ta kúú ni̱ seídóꞌo va ta̱ xíonoo xíꞌín ná ña̱ dión ni̱ kaa na̱. 
\s1 Diꞌa ni̱ kuu tá ni̱ taó ndíꞌi Jesús ta̱ díkó xíꞌín ta̱ xíin kuaꞌa̱n ra̱ sata̱ véꞌe ño̱ꞌo káꞌano 
\p  
\v 15 Tá ni̱ ndiꞌi, dá ni̱ na̱sáa̱ na̱ ñoo Jerusalén. Dá ni̱ ku̱ꞌu na yéꞌé veꞌe ño̱ꞌo káꞌano. Dá ni̱ ka̱sáꞌá ná taó ndíꞌi na ta̱ díkó xíꞌín ta̱ xíin kuaꞌa̱n ra̱ sata̱ véꞌe. Kúú ni̱ da̱kuéi na ndidaá mesa noo̱ ndéi ta̱a náda̱on di̱ꞌón. Kúú ni̱ sata niꞌini na téi̱ kándíꞌi ta̱a ndéi díkó paloma.  
\v 16 Kúú ko̱ ní sónó taꞌon na ña̱ chikaꞌanda ni iin tóꞌón ña̱yuu ini yéꞌé veꞌe ño̱ꞌo ñoó xíꞌín ña̱ꞌa néꞌe na kuaꞌa̱n na̱. 
\p  
\v 17 Ta kúú ñoó ni̱ ka̱sáꞌá Jesús dánaꞌa̱ na̱ no̱ó ña̱yuu ñoó, ta kaá na̱: 
\p ―¿Á ko̱ ndúsaa̱ taꞌon ini ndo̱ ña̱ diꞌa va kaá tuti ii̱ Ndios: “Veꞌe yuꞌu̱ kúú iin veꞌe noo̱ kánian nataka ña̱yuu ndéi iin níí kúú ñayuú, dá kaꞌa̱n na̱ xíꞌín yuꞌu̱”, kaáa̱n? Tído ndoꞌó kúú na̱ ndéi kéean táto̱ꞌon iin káo̱ ta̱ kui̱ꞌíná ―kaá na̱. 
\p  
\v 18 Tá ni̱ niꞌi̱ tóꞌon ta̱a dánaꞌa̱ ley Moisés xíꞌín ta̱ duti̱ sakua̱ꞌa̱ ña̱ ni̱ kee na dión, dá ni̱ ka̱sáꞌá rá ndúkú rá ndi kee ra, dá kaꞌání ñaá rá. Tído yuꞌú ra̱, chi̱ ndidaá kúú vá ña̱yuu ñoó ni̱ naá iní seídóꞌo na ña̱ dánaꞌa̱ Jesús.  
\v 19 Dá tá ni̱ kuaá kuu̱ dáá ñóó, dá ni̱ keta Jesús ñoo Jerusalén kuaꞌa̱n na̱ xíꞌín ta̱a xíonoo xíꞌín ná. 
\s1 Diꞌa kuaꞌa̱n ña̱ ni̱ da̱náꞌa̱ Jesús sa̱ꞌá ta̱ño̱ꞌó ni̱ da̱ꞌíchi̱ na̱ ñoó 
\p  
\v 20 Tá ni̱ tu̱u noo̱ iin ka̱ kuu̱, dá ni̱ ya̱ꞌa yati na noo̱ íin ta̱ño̱ꞌó ñóó, kúú ni̱ xini ta̱a xíonoo xíꞌín ná ña̱ nda̱ yo̱ꞌo ví rá ni̱ ichi̱.  
\v 21 Dá ni̱ ndu̱sáa̱ ini Pedro ña̱ ni̱ kaꞌa̱n Jesús xíꞌín yíto̱ ñoó. Dá ni̱ kaa ra̱: 
\p ―Maestro, káa chi̱, ta̱ño̱ꞌó, kirá ni̱ da̱tái̱ chiꞌan mií ní káa, ni̱ ichi̱ va rá. 
\p  
\v 22 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Kandeé káꞌano iní ndo̱ Ndios.  
\v 23 Miía̱n ndaa̱ kuiti ná kaꞌi̱n xíꞌín ndó; ndi ndáa ndoꞌó ni̱ kuu va ná kaꞌa̱n xíꞌín yúku̱ káa: “Kuxoo, ta kuaꞌán dáke̱tón miíón ini ta̱ñoꞌo̱ káa”, ta torá ko̱ nákani kuáchi̱ ini ndo̱, ta kándísa ndaa̱ ndo̱ ña̱ ki̱ꞌo dión koo, dá kía̱n kasandaá ndisa va ña̱ ni̱ kaꞌa̱n ndo̱.  
\v 24 Sa̱ꞌá ño̱ó káꞌi̱n ña̱ ndidaá kúú vá ña̱ꞌa ná kaka̱ ndo̱ noo̱ Ndios, ta kándeé káꞌano ini ndo̱ ná, ta kúú niꞌi̱ ndisa va ndóa̱n.  
\v 25 Tído tá tein káꞌa̱n ndo̱ xíꞌín Ndios, kuꞌu̱ káꞌano ini ndo̱ saꞌa̱ ña̱yuu naá táꞌan xíꞌín ndó, dá kía̱n nda̱ tatá ndo̱ Ndios, na̱ ió induú, ki̱ꞌo káꞌano taꞌani ini na̱ sa̱ꞌá kua̱chi mií ndó.  
\v 26 Chi̱ tá ná o̱ kúꞌu̱ káꞌano ini ndo̱ sa̱ꞌá ña̱yuu ñoó, dá kía̱n ni tatá Ndios, na̱ ió induú, o̱ kúꞌu̱ káꞌano taꞌon ini sa̱ꞌá kua̱chi mií ndó ―kaá Jesús. 
\s1 Yóꞌo ni̱ nda̱to̱ꞌón ta̱ fariseo Jesús ndá yoo ni̱ xi̱ꞌo choon noo̱ ná 
\p  
\v 27 Dá ni̱ ka̱sáa̱ tuku Jesús xíꞌín ta̱a xíonoo xíꞌín ná ñoo Jerusalén. Dá ni̱ ka̱sáꞌá ná xíonoo na noo̱ íin veꞌe ño̱ꞌo káꞌano ñoó. Dá ni̱ na̱tuu yati ta̱ duti̱ sakua̱ꞌa̱, xíꞌín ta̱ dánaꞌa̱ ley Moisés xíꞌín ta̱ sáꞌano ñoo.  
\v 28 Dá ni̱ nda̱to̱ꞌón rá Jesús: 
\p ―¿Ndá choon néꞌe ní ña̱ nákaa̱ ní kée ní diꞌa? Ta, ¿ndá yoo ni̱ xi̱ꞌo choon yóꞌo noo̱ ní ña̱ kee nía̱n? ―kaá ra̱. 
\p  
\v 29 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Ta ná ndato̱ꞌón taꞌani yuꞌu̱ ndo̱ꞌó saꞌa̱ iin ña̱ꞌa. Tá ni̱ ka̱ti̱ꞌa ndó ni̱ na̱ndió néꞌe ndóa̱n, dá kasto̱ꞌon yuꞌu̱ xíꞌín ndó ndá yoo ni̱ xi̱ꞌo choon noo̱í ña̱ kéei ña̱ yóꞌo.  
\v 30 ¿Ndá yoo ni̱ xi̱ꞌo choon noo̱ Juan ña̱ sa̱ da̱kódo̱ ndúta̱ ná ña̱yuu? ¿Á Ndios ni̱ xi̱ꞌoan, o ta̱a? Kaꞌa̱n ndo̱ ná kande̱ꞌá ―kaá na̱. 
\p  
\v 31 Dá ni̱ ka̱sáꞌá ndátóꞌón táꞌan mií rá ndíta ra: 
\p ―Tá ná kaa yo̱ ña̱ Ndios ni̱ xi̱ꞌo ñaá, dá kía̱n kaa ra̱ xíꞌá: “¿Ndiva̱ꞌa ko̱ ní kándísa ndó ña̱ ni̱ da̱náꞌa̱ ra̱, tá dáá?”  
\v 32 Tído, o̱ kúu taꞌon kaa yo̱ ña̱ ta̱a ni̱ xi̱ꞌo ñaá. 
\p Dión ni̱ kaa ra̱, chi̱ yuꞌú ra̱ kée ña̱yuu kuáꞌa̱ ñoó. Chi̱ ndidaá vá no̱ón kándísa ña̱ miía̱n ndaa̱ ndisa Juan ni̱ sa̱ kuu iin profeta ni̱ ta̱ndaꞌá Ndios ni̱ kii.  
\v 33 Dá ni̱ kaa ra̱ xíꞌín Jesús: 
\p ―Ko̱ náꞌá taꞌon nduꞌu̱ ndá yoo ni̱ xi̱ꞌo choon noo̱ Juan. 
\p Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Ta ni yuꞌu̱ o̱ kásto̱ꞌon taꞌon xíꞌín ndó ndá yoo ni̱ xi̱ꞌo choon noo̱í ña̱ kéei ndidaá ña̱ yóꞌo ―kaá na̱. 
\c 12  
\s1 Diꞌa kuaꞌa̱n ña̱ ni̱ na̱kani Jesús sa̱ꞌá ña̱ ni̱ ndoꞌo iin satoꞌo uva 
\p  
\v 1 Dá ni̱ ka̱sáꞌá Jesús dákíꞌin táꞌan na dao ña̱ꞌa xíꞌín to̱ꞌon dánaꞌa̱ na̱, ta kaá na̱: 
\p ―Iin kuu̱ ni̱ da̱ndée iin ta̱a yitó uva no̱ñóꞌo̱ rá. Ta ni̱ chi̱káa̱ ra̱ korráa̱n. Dá ni̱ ka̱va̱ꞌa ra noo̱ koꞌóní ndúta̱ uva ñoó. Ta ni̱ ka̱va̱ꞌa taꞌani ra iin veꞌe dikó noo̱ kanóo ra̱ kandaa uva ñoó. 
\p ’Dá ni̱ di̱kó ndodó ra̱án noo̱ dao ka̱ ta̱a kéchóon. Dá ni̱ kee ra kuaꞌa̱n xíká rá.  
\v 2 Dá tá ni̱ xi̱nko̱o tiempo taꞌa̱nda̱ uva ñoó, dá ni̱ saꞌanda ra̱ choon noo̱ iin mozo ra̱ ña̱ ná koꞌo̱n ra̱ noo̱ ndéi ta̱ kéchóon ñoó natiin ra uva, kirí kánian niꞌi̱ rá.  
\v 3 Tído tá ni̱ saa̱ mozo ñoó, dá ni̱ nda̱kuei ta̱ kéchóon noo̱ uva ñoó ni̱ kani ñaá rá. Ta ni iin ña̱ꞌa ko̱ ní xi̱ꞌo ra kaneꞌe mozo ñoó noꞌo̱ ra̱.  
\v 4 Dá ni̱ na̱ndió ko̱o tuku satoꞌo ñoó ni̱ saꞌanda ra̱ choon noo̱ iin ka̱ mozo ra̱ kuaꞌa̱n ra̱. Tído tá ni̱ saa̱ ra̱ noo̱ ndéi ta̱ kéchóon ñoó, dá ni̱ nda̱kuei tuku ra ni̱ kani ñaá rá xíꞌín yuu̱, ta ni̱ da̱rkueꞌe̱ ra̱ dini̱ rá, ta ni̱ nde̱ineꞌe ñaá rá.  
\v 5 Dá ni̱ na̱ndió ko̱o tuku satoꞌo ñoó ni̱ saꞌanda ra̱ choon noo̱ iin ka̱ mozo kuaꞌa̱n ra̱. Tído tá ni̱ saa̱ ra̱, dá ni̱ saꞌání ñaá ta̱ kéchóon ñoó. Ndiꞌi daá, dá ni̱ saꞌanda satoꞌo ñoó choon noo̱ kuaꞌa̱ ka̱ mozo kuaꞌa̱n ra̱. Tído dao ra ni̱ kani ra, ta dao ka̱ ra̱ ni̱ saꞌání rá. 
\p  
\v 6 ’Ta nda̱dá iin tóꞌón vá ña̱yuu kámani̱ chindaꞌá rá koꞌo̱n. Ta yóꞌo kúú iin tóꞌón dini̱ de̱ꞌe mani̱ rá. Kúú ni̱ saꞌanda ra̱ choon noo̱ xí kuaꞌa̱n xi̱, chi̱ diꞌa ni̱ kaa ra̱: “Ndá ndi kuu koo va ña̱ñóꞌó rá no̱ó de̱ꞌi”, kaá ra̱.  
\v 7 Tído tá ni̱ saa̱ xi̱, ta kúú ni̱ ka̱sáꞌá ndátóꞌón kueꞌé ta̱ kéchóon ñoó: “Ta̱a káa kúú ra̱ natiin ndidaá kúú ñóꞌo̱ yóꞌo noo̱ tatá xi̱. Kóꞌo̱ kaꞌání yó xi̱, dá ná kando̱o ndiꞌi ñóꞌo̱ yóꞌo noo̱ mií yó”, kaá ra̱.  
\v 8 Dá ni̱ tiin ñaá rá. Ta kúú ni̱ saꞌání ñaá rá. Dá ni̱ da̱kána ñaá rá nda̱ sata̱ korrá noo̱ káa yitó uva ñóó.  
\v 9 Ta, ¿ndí ki̱án kee satoꞌo uva ñoó viti, káꞌán ndó? Kasaa̱ ra̱, dá kaꞌání ndíꞌi ra ta̱ kéchóon ñoó, dá di̱kó ndodó ra̱ ñóꞌo̱ noo̱ káa yitó uva ñóó noo̱ dao ka̱ ta̱ kéchóon. 
\p  
\v 10 ’¿Á ko̱ óon taꞌon kaꞌi ndó tuti ii̱ Ndios? Chi̱ diꞌa kaáa̱n: 
\q1 Ta yuu̱ ni̱ ka̱ñóꞌó ta̱ káva̱ꞌa veꞌe, 
\q1 ño̱ó diꞌa va ni̱ kasa̱ndaá kakuu yuu̱ tito̱. 
\q1  
\v 11 Dión ni̱ kee satoꞌo yo̱ Ndios xíꞌín yuu̱ ñoó. 
\q1 Sa̱ꞌá ño̱ó iin ña̱ꞌa ndato nda̱ꞌo kíán noo̱ yo̱. 
\p  
\v 12 Dá ni̱ kaꞌán ta̱ néꞌe choon ñoó tiin ra Jesús kadi ra̱ veꞌe ka̱a, chi̱ ni̱ ka̱ndaa̱ va ini ra̱ ña̱ saꞌa̱ mií vá rá ni̱ na̱kani na to̱ꞌon yóꞌo. Tído yuꞌú va ra kée ña̱yuu kuáꞌa̱ ñoó. Sa̱ꞌá ño̱ó ni̱ da̱nkoo ra Jesús, dá ni̱ kee ra kuaꞌa̱n ra̱. 
\s1 Diꞌa ni̱ kuu tá ni̱ kaꞌán dao ta̱a dátu̱ú rá Jesús 
\p  
\v 13 Tá ni̱ ndiꞌi, dá ni̱ ta̱ndaꞌá rá dao ka̱ ta̱ fariseo xíꞌín dao ka̱ ta̱ kuendá Herodes ña̱ ná koꞌo̱n ra̱ noo̱ Jesús, ta nandukú rá ña̱ dátu̱ú ñaá rá, dá ná ya̱ꞌa na noo̱ kaꞌa̱n na̱.  
\v 14 Dá tá ni̱ saa̱ ra̱ noo̱ nákaa̱ Jesús, dá ni̱ kaa ra̱ xíꞌín ná: 
\p ―Maestro, náꞌá vá nduꞌu̱ ña̱ kúú ní iin na̱ ndaa̱. Ta ko̱ yu̱ꞌú ní ni iin tóꞌón ña̱yuu, chi̱ ko̱ néꞌe ní ta̱ndíni ndá yoo kúú iin rá iin ña̱yuu, á ndáya̱ꞌi na o ko̱ó. Diꞌa dánaꞌa̱ ndaa̱ ní íchi̱ Ndios noo̱ ndidaá ña̱yuu. Sa̱ꞌá ño̱ó, ¿ndi kaá mií ní? ¿Á va̱ꞌa ni kée yó chíya̱ꞌi yó saꞌa̱ ñóꞌo̱ yo̱ no̱ó ra̱ kúú kuendá César o ko̱ó? ―kaá ra̱. 
\p  
\v 15 Tído ni̱ ka̱ndaa̱ va ini Jesús ña̱ kúú rá ta̱a uu̱ noo̱, ta kátoó ra̱ dátu̱ú ñaá rá. Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―¿Ndiva̱ꞌa ndúkú ndó ña̱ ya̱ꞌi no̱ó to̱ꞌon káꞌi̱n? Tei tóo ndó iin di̱ꞌón, ña̱ chíya̱ꞌi ndó saꞌa̱ ñóꞌo̱ ndo̱, dá ná kande̱ꞌá. 
\p  
\v 16 Dá ni̱ xi̱ꞌo tóo ra iin di̱ꞌón ka̱a noo̱ ná. Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―¿Ndá naꞌáná kía̱n ndáꞌa̱ noo̱ di̱ꞌón yóꞌo? Ta, ¿ndá kuu̱ kía̱n ndáꞌa̱ noo̱án yóꞌo? 
\p Dá ni̱ kaa ra̱: 
\p ―Naꞌáná César kíán xíꞌín kuu̱ rá. 
\p  
\v 17 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Naki̱ꞌo ndó ña̱ kúú ña̱ꞌa César noo̱ rá, tá dáá, ta naki̱ꞌo ndó ña̱ kúú ña̱ꞌa Ndios noo̱ ná. 
\p Ta kúú ni̱ naá vá ini ta̱a ñoó sa̱ꞌá ña̱ ni̱ kaꞌa̱n na̱ dión. 
\s1 Diꞌa kuaꞌa̱n ña̱ ni̱ da̱náꞌa̱ Jesús ña̱ miía̱n ndaa̱ nataki na̱ ni̱ xiꞌi̱ 
\p  
\v 18 Dá ni̱ ka̱sáa̱ dao ta̱ saduceo noo̱ Jesús. Ta ko̱ kándísa taꞌon ra ña̱ nataki na̱ ni̱ xiꞌi̱. Dá ni̱ nda̱to̱ꞌón ñaá rá: 
\p  
\v 19 ―Maestro, diꞌa kaá iin ley ni̱ taa Moisés: “Tá ni̱ xiꞌi̱ iin ta̱a, ta ko̱ ní sá io de̱ꞌe yií ra̱ xíꞌín ñadiꞌí ra̱, dá kía̱n kánian nakiꞌin ñaá ñani ra̱ tandaꞌa̱ rá xíꞌán, dá kía̱n koo iin de̱ꞌe yií nakiꞌin kuu̱ ñani ra̱.”  
\v 20 Ta viti, ni̱ sa̱ ndei usa̱ ñani. Ta kúú ni̱ ta̱ndáꞌa̱ ta̱ kúú no̱ó ñoó, tído ni̱ xiꞌi̱ va ra, ta ko̱ ta̱ꞌón de̱ꞌe yií ra̱ ní sá io xíꞌín ñadiꞌí ra̱.  
\v 21 Sa̱ꞌá ño̱ó ni̱ ta̱ndáꞌa̱ ñani ra̱ xíꞌán. Tído ni̱ xiꞌi̱ taꞌani ta̱ kúú uu̱ ñoó, ta ko̱ ní sá io tuku de̱ꞌe yií ra̱ xíꞌán. Ta kúú dión taꞌani ni̱ ndoꞌo ta̱ kúú oni̱.  
\v 22 Ta dión taꞌani ni̱ ndoꞌo ndin usa̱ ñani ñoó, chi̱ ni̱ xiꞌi̱ ndiꞌi ra, ta ni iin ra ko̱ ní sá io de̱ꞌe yií xíꞌán. Tá ni̱ ndiꞌi, dá ni̱ xiꞌi̱ taꞌani mií ñáꞌa̱ ñoó.  
\v 23 Sa̱ꞌá ño̱ó, tá ná kasandaá kuu̱ nataki na̱ ni̱ xiꞌi̱, ¿ndi káa iin ta̱a ñoó kakuu yíi̱ ñáꞌa̱ ñoó, chi̱ ndin usa̱ va ra ni̱ sa̱ kuu yíi̱a̱n? ―kaá ra̱. 
\p  
\v 24 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Ko̱ náꞌá taꞌon ndó ndí ki̱án káꞌa̱n ndo̱, chi̱ ko̱ kékuendá taꞌon ndó ña̱ káꞌa̱n tuti ii̱ Ndios, ta ni ko̱ nákoni taꞌon ndó choon káꞌano ió noo̱ ndáꞌa̱ ná.  
\v 25 Dá chi̱ tá ná kasandaá kuu̱ nataki ña̱yuu ni̱ xiꞌi̱, o̱ kóo ka̱ ña̱ tandaꞌa̱ ná, ta o̱ kíꞌo ka̱ na̱ de̱ꞌe diꞌí na̱ tandaꞌa̱ xí, dá chi̱ táto̱ꞌon ki̱ꞌo ndéi ángel induú, nda̱ ki̱ꞌo dión vá kandei na.  
\v 26 Tído viti ná koꞌi̱n kasto̱ꞌin xíꞌín ndó ña̱ miía̱n ndaa̱ nataki na̱ ni̱ xiꞌi̱. ¿Á ko̱ óon taꞌon kaꞌi ndó to̱ꞌon ni̱ taa Moisés? Chi̱ tein kéi̱ yitó táka̱ lóꞌo̱ ñoó, dá ni̱ kaa Ndios diꞌa xíꞌín ná: “Yuꞌu̱ kúú Ndios noo̱ Abraham, ta yuꞌu̱ kúú Ndios noo̱ Isaac, ta yuꞌu̱ taꞌani kúú Ndios noo̱ Jacob.”  
\v 27 Dión ni̱ kaa na̱, dá chi̱ ko̱ kúú taꞌon na Ndios no̱ó na̱ ni̱ xiꞌi̱, diꞌa no̱ó na̱ takí vá kúú ná Ndios, chi̱ ndidaá vá ña̱yuu ndéi takí noo̱ ná. Sa̱ꞌá ño̱ó yáꞌa nda̱ꞌo ndoꞌó sa̱ꞌá ña̱ ko̱ kándísa ndó ña̱ nataki na̱ ni̱ xiꞌi̱ ―kaá na̱. 
\s1 Yóꞌo dánaꞌa̱ Jesús ndi káa choon ndáya̱ꞌi cháá ka̱ ni̱ saꞌanda Ndios keeá 
\p  
\v 28 Dá ni̱ na̱tuu yati iin ta̱a dánaꞌa̱ ley Moisés, ta ni̱ sei̱do̱ꞌo ra ña̱ ni̱ kaꞌa̱n Jesús xíꞌín ta̱ saduceo ñoó. Kúú ni̱ ka̱tóni̱ ini ra̱ ña̱ va̱ꞌa nda̱ꞌo ni̱ na̱ndió néꞌe na ña̱ ni̱ nda̱to̱ꞌón ñaá rá sa̱ꞌá na̱ ni̱ xiꞌi̱. Sa̱ꞌá ño̱ó ni̱ nda̱to̱ꞌón ñaá rá: 
\p ―¿Ndi káa iin choon ndáya̱ꞌi cháá ka̱ noo̱ ndidaá ka̱ choon ni̱ saꞌanda Ndios keeá? 
\p  
\v 29 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Choon ndáya̱ꞌi cháá ka̱ noo̱ ndidaá ka̱ choon ni̱ saꞌanda Ndios keeá kía̱n kaáa̱n diꞌa: “Kueídóꞌo ndoꞌó, na̱ ñoo Israel. Ndios, na̱ kúú satoꞌo yo̱, iin tóꞌón dini̱ mií vá ná kúú Ndios.  
\v 30 Koni̱ ndo̱ satoꞌo yo̱ Ndios xíꞌín ndinoꞌo nío̱ ndo̱, xíꞌín ndinoꞌo ini mií ndó, xíꞌín ndidaá ña̱xintóni̱ ndo̱, ta xíꞌín ndidaá kúú ndée̱ ndo̱.” Ña̱ yóꞌo kúú choon ndáya̱ꞌi cháá ka̱ ni̱ saꞌanda Ndios keeá.  
\v 31 Ta ña̱ kúú uu̱ kía̱n sá kíꞌin táꞌan xíꞌín ña̱ yóꞌo, chi̱ diꞌa kaáa̱n: “Kuꞌu̱ ini ndo̱ sa̱ꞌá ña̱yuu xi̱ꞌín ndó táto̱ꞌon ki̱ꞌo ndóꞌo ndó xíꞌín mií ndó.” Ta ko̱ó ka̱ choon ndáya̱ꞌi cháá ka̱ noo̱ ndin nduú choon yóꞌo ―kaá na̱. 
\p  
\v 32 Dá ni̱ kaa ta̱a dánaꞌa̱ ley Moisés ñoó xíꞌín ná: 
\p ―Va̱ꞌa nda̱ꞌo ni̱ kaꞌa̱n ní, maestro. Ndaa̱ kuití ni̱ kaꞌa̱n ní ña̱ iin tóꞌón dini̱ vá kúú Ndios. Ta ko̱ó ka̱ iin ka̱ Ndios, sa̱va̱ꞌa iin tóꞌón dini̱ miíó ná kúú ná.  
\v 33 Ta ndáya̱ꞌi cháá ka̱ ña̱ koni̱ yo̱ Ndios xíꞌín ndinoꞌo nío̱ yo̱, xíꞌín ndidaá ña̱xintóni̱ yo̱, xíꞌín ndinoꞌo ini miíá, xíꞌín ndidaá kúú ndée̱ yo̱, ta kuꞌu̱ ini yo̱ sa̱ꞌá ña̱yuu xi̱ꞌín yó táto̱ꞌon ki̱ꞌo ndóꞌo yó xíꞌín mií yó. Ta ña̱ yóꞌo kía̱n ndáya̱ꞌi cháá ka̱ o̱ du̱ú ndidaá ka̱ ña̱ꞌa dákei̱ yo̱ noo̱ Ndios, o ndidaá ka̱ ña̱ꞌa dóko̱ yo̱ noo̱ ná ―ka̱á ra̱. 
\p  
\v 34 Tá ni̱ seídóꞌo Jesús ña̱ va̱ꞌa nda̱ꞌo yíko̱ ni̱ kaꞌa̱n ra̱, dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Nda̱dá cháá vá kámani̱, ta kuu ndu̱ꞌu yoꞌó ti̱xi ndáꞌa̱ Ndios ―kaá na̱. 
\p Ta kúú ni iin tóꞌón ka̱ ra̱ ko̱ ní xi̱ꞌo ndeé iní natuu ndato̱ꞌón rá Jesús saꞌa̱ dao ka̱ ña̱ꞌa. 
\s1 Diꞌa kuaꞌa̱n ña̱ ni̱ da̱náꞌa̱ Jesús saꞌa̱ Cristo, na̱ dáka̱ki ñaá 
\p  
\v 35 Nákaa̱ Jesús dánaꞌa̱ na̱ yéꞌé veꞌe ño̱ꞌo káꞌano ñoó, dá ni̱ kaa na̱ xíꞌín ña̱yuu ñoó: 
\p ―¿Ndiva̱ꞌa dánaꞌa̱ ta̱a dánaꞌa̱ ley Moisés ña̱ tein na̱ veꞌe rey David kixi Cristo, na̱ dáka̱ki ñaá?  
\v 36 Chi̱ diꞌa va ni̱ kaa mií David tá ni̱ na̱kutí ná xíꞌín Espíritu ii̱ Ndios: 
\q1 Diꞌa ni̱ kaa satoꞌo yo̱ Ndios xíꞌín na̱ kúú satoꞌi̱: 
\q1 “Kako̱o yoꞌó xoo kuáꞌa yuꞌu̱ 
\q1 nda̱á ná kasandaá kuu̱ nataán ndíꞌii 
\q1 ta̱ xiní uꞌu̱ ñaá ti̱xi sa̱ꞌo̱n.” 
\m  
\v 37 Mií David kaá ña̱ satoꞌo na̱ kúú Cristo, sa̱ꞌá ño̱ó, ¿ndiva̱ꞌa dánaꞌa̱ ra̱ ña̱ kii Cristo tein na̱ veꞌe na, tá dáá? ―kaá Jesús. 
\p Kádii̱ nda̱ꞌo ini ña̱yuu kuáꞌa̱ ñoó ndéi na seídóꞌo na ña̱ dánaꞌa̱ Jesús. 
\s1 Diꞌa kuaꞌa̱n ña̱ ni̱ kaꞌa̱n Jesús sa̱ꞌá ña̱ kini kée ta̱ dánaꞌa̱ ley Moisés 
\p  
\v 38 Dá ni̱ kaa taꞌani Jesús noo̱ dánaꞌa̱ na̱ no̱ó ña̱yuu ñoó: 
\p ―Koo ini ndo̱ kandaa ndo̱ mií ndó no̱ó ta̱a dánaꞌa̱ ley Moisés, dá chi̱ kátoó ra̱ kandixi ra daꞌón náni̱, ta kóni̱ ra̱ ña̱ kaꞌa̱n ña̱yuu ndisáꞌán xíꞌín rá xíꞌín ña̱ñóꞌó noo̱ xíonoo ra noo̱ yáꞌi.  
\v 39 Ta kátoó taꞌani ra kandei ra noo̱ téi̱ kúú no̱ó ini veꞌe noo̱ nátaka na̱ ñoo yo̱, ta kátoó taꞌani ra kandei ra téi̱ kúú no̱ó noo̱ ndéi ta̱ ndáya̱ꞌi sásáꞌan ra noo̱ ió víko̱.  
\v 40 Ta xío ndaa ra̱ veꞌe na̱ kuáa̱n. Ta sa̱ꞌá ña̱ kóni̱ ra̱ ña̱ kaꞌa̱n va̱ꞌa ña̱yuu saꞌa̱ rá, sa̱ꞌá ño̱ó naꞌá xíka̱ taꞌi̱ rá noo̱ Ndios. Ta̱ yóꞌo kúú ra̱ yaꞌi nda̱ꞌo chiya̱ꞌi ra noo̱ Ndios sa̱ꞌá ña̱ kée ra dión ―kaá na̱. 
\s1 Diꞌa ni̱ kee iin ñaꞌá kuáa̱n kúndaꞌí 
\p  
\v 41 Ió Jesús yati noo̱ taán ña̱yuu di̱ꞌón ini sato̱, ña̱ dóko̱ ná noo̱ Ndios ini yéꞌé ño̱ꞌo káꞌano ñoó, ta ndéꞌé ná ndi kée iin rá iin ña̱yuu ñoó taán na̱ di̱ꞌón ñoó. Ta kua̱ꞌá nda̱ꞌo na̱ kui̱ká taán kua̱ꞌá nda̱ꞌo di̱ꞌón.  
\v 42 Dá ni̱ ka̱sáa̱ taꞌani iin ñaꞌá kuáa̱n kúndaꞌí. Ta kúú ni̱ taáán uu̱ di̱ꞌón ka̱a kuálí. Kúú cháá nda̱ꞌo ndáya̱ꞌi ña. 
\p  
\v 43 Dá ni̱ kana Jesús ta̱ xíonoo xíꞌín ná, dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Miía̱n ndaa̱ ná kaꞌi̱n xíꞌín ndó ña̱ ñaꞌá kuáa̱n kúndaꞌí káa ni̱ taán kuaꞌa̱ cháá ka̱ di̱ꞌón noo̱ ndidaá ka̱ ña̱yuu káa,  
\v 44 dá chi̱ ndidaá na̱ káa ni̱ taán ña̱ kándo̱o noo̱ vá ná. Tído ñáꞌa̱ káa, va̱ꞌará kúndaꞌí vía̱n, ni̱ taán ndíꞌán ña̱ néꞌe va̱ꞌán katakia̱n ―ka̱á na̱. 
\c 13  
\s1 Yóꞌo kúú noo̱ dánaꞌa̱ Jesús ña̱ naá vá veꞌe ño̱ꞌo káꞌano 
\p  
\v 1 Tá ni̱ keta Jesús yéꞌé veꞌe ño̱ꞌo káꞌano ñoó, dá ni̱ kaa iin ta̱a xíonoo xíꞌín ná: 
\p ―Maestro, kande̱ꞌé ní, ki̱ꞌo dión ví náꞌano yuu̱ káa, ta ki̱ꞌo dión ví ñóchí káa veꞌe ño̱ꞌo káꞌano káa. 
\p  
\v 2 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―¿Á ñóchí nda̱ꞌo káa veꞌe ño̱ꞌo káꞌano káa, xinóo̱n? Tído kanaꞌón ña̱ ni iin tóꞌón yuu̱ káa o̱ kándo̱o kandodó táꞌan, chi̱ koon ndiꞌi vaan ―kaá na̱. 
\s1 Kásto̱ꞌon Jesús ndí ki̱án koo, dá naá ñayuú yóꞌo 
\p  
\v 3 Dá ni̱ sa̱ ko̱o Jesús ndi̱ka yúku̱ naní Olivos chí xoo noo̱ túu íin veꞌe ño̱ꞌo káꞌano ñoó. Dá ni̱ nda̱to̱ꞌón xoo ñaá Pedro xíꞌín Jacobo xíꞌín Juan xíꞌín Andrés: 
\p  
\v 4 ―Kasto̱ꞌon ní xíꞌín nduꞌu̱ ndá oon koo dión. Ta, ¿ndí ki̱án koo tá kuaꞌa̱n xi̱nko̱o ndidaá ña̱ yóꞌo? 
\p  
\v 5 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Kandaa ndo̱ mií ndó, dá ná o̱ dándaꞌí ñaá ni iin tóꞌón ña̱yuu.  
\v 6 Chi̱ kua̱ꞌá nda̱ꞌo ta̱a kasaa̱, ta kechóon ra kuu̱ yúꞌu̱, ta kaa ra̱: “Yuꞌu̱ kúú Cristo, na̱ dáka̱ki ñaá.” Ta kua̱ꞌá nda̱ꞌo ña̱yuu kandeé rá dándaꞌí ra̱.  
\v 7 Tá ni̱ ka̱ndaa̱ ini ndo̱ ña̱ saꞌání táꞌan iin ñoo xíꞌín iin ka̱ ñoo, ta ni̱ niꞌi̱ tóꞌon ndó ña̱ naá táꞌan dao ka̱ ñoo ñóꞌo xíká, tído ná dáꞌa ni yu̱ꞌú ndo̱, dá chi̱ ki̱ꞌo dión káni vaan koo, tído ko̱ ñáꞌa̱ taꞌon kasandaá kuu̱ noo̱ ndíꞌí.  
\v 8 Chi̱ ndakuei dao nación na̱á táꞌan xíꞌín dao ka̱ nación, ta kasáꞌá na̱á táꞌan taꞌani ta̱ néꞌe choon ndéi iin rá iin ñoo náꞌano. Ta yóꞌo yóꞌo va kasáꞌá ni̱ꞌi nda̱ꞌo ta̱an. Ta yóꞌo rá yóꞌo taꞌani kasáꞌá koo tama̱. Ta ña̱ yóꞌo kía̱n koo, dá kasáꞌá ndoꞌo cháá ka̱ nío̱ ña̱yuu ndéi ñayuú yóꞌo. 
\p  
\v 9 ’Tído ndoꞌó, kandaa ndo̱ mií ndó, chi̱ kasáꞌá ña̱yuu naki̱ꞌo na ndo̱ꞌó noo̱ ndáꞌa̱ ta̱ néꞌe choon. Ta kani na ndo̱ꞌó ini veꞌe noo̱ nátaka na̱. Ta kandaka na ndo̱ꞌó koꞌo̱n na̱ no̱ó ta̱ néꞌe choon náꞌano, no̱ó ta̱ kúú rey viti sa̱ꞌá ña̱ kúú ndó kuendá yuꞌu̱. Dión koo, dá niꞌi̱ ndo̱ ki̱ꞌo ndó kuendá saꞌa̱ yúꞌu̱ no̱ó ta̱ néꞌe choon náꞌano.  
\v 10 Tído miía̱n ndúsa̱ kánian kanoo ña̱yuu dánaꞌa̱ na̱ to̱ꞌon va̱ꞌa saꞌa̱ yúꞌu̱ iin níí kúú ñayuú dinñóꞌó ka̱, dá kasandaá kuu̱ noo̱ ndíꞌí.  
\v 11 Tído, tá ndáka na ndo̱ꞌó ni̱ saa̱ na̱ ni̱ na̱ki̱ꞌo na no̱ó ta̱ néꞌe choon, o̱ sa̱ ndíꞌi ini ndo̱ sa̱ꞌá to̱ꞌon kaꞌa̱n ndo̱, ta o̱ sa̱ nákani ini ndo̱. Sa̱va̱ꞌa to̱ꞌon niꞌi̱ ndo̱ noo̱ Ndios, ño̱ó oon va kía̱n kaꞌa̱n ndo̱. Chi̱ o̱ du̱ú mií taꞌon ndó kaꞌa̱n. Espíritu ii̱ Ndios va kúú na̱ kaꞌa̱n. 
\p  
\v 12 ’Ta iin ñani naki̱ꞌo ra ñani mií rá no̱ó ta̱ néꞌe choon, dá kaꞌání ñaá rá. Ta dión taꞌani kee na̱ kúú tatá xíꞌín de̱ꞌe ra. Ta ndakuei taꞌani dao de̱ꞌe na̱á ra̱ xíꞌín tatá ra̱, dá kaꞌání ñaá rá.  
\v 13 Chi̱ kasáꞌá koni uꞌu̱ ndidaá ña̱yuu ndo̱ꞌó sa̱ꞌá ña̱ kúú ndó kuendá yuꞌu̱. Tído ndidaá na̱ ni̱ xi̱ꞌo ndeé iní ni̱ sa̱ ndita ndaa̱ xíꞌíi̱n nda̱ noo̱ ndíꞌí kuií, no̱ón kúú na̱ niꞌi̱ ña̱ ka̱ki na. 
\p  
\v 14 ’Tá ni̱ xini ndo̱ ió ña̱ kini dáyako̱ ñaá, ña̱ ni̱ kaꞌa̱n profeta Daniel saꞌa̱, noo̱ ko̱ kánian kooan, dá kía̱n na̱ ndéi chí Judea ná kuino kíi̱ ná koꞌo̱n na̱ nda̱ dini̱ yúku̱. (Ndi ndáa ndoꞌó, na̱ káꞌi ña̱ yóꞌo, nataꞌí iní ndo̱ sa̱ꞌán, dá kandaa̱ ini ndo̱.)  
\v 15 Ta na̱ kándodó dini̱ véꞌe kuu̱ dáá ñóó, ko̱ kánian ndu̱ꞌu na veꞌe na nakiꞌin na ña̱ꞌa na kaneꞌe na koꞌo̱n na̱.  
\v 16 Dá ri na̱ ñóꞌo yúku̱, ko̱ kánian nandió kuéi na noꞌo̱ na̱ nakiꞌin na kotó na̱.  
\v 17 Ta, ¡ndaꞌí kúu ví na̱ ñáꞌa̱ ñóꞌo de̱ꞌe, ta ndaꞌí kúu taꞌani ví na̱ ndéi taleé chíchí tein kuu̱ dáá ñóó!  
\v 18 Kaka̱ ndo̱ ña̱ mani̱ noo̱ Ndios, dá ná dáꞌa ni ndoꞌo ndó dión tein yoo̱ vi̱xi.  
\v 19 Chi̱ kuu̱ dáá kakuu iin kuu̱ noo̱ ndoꞌo naní nío̱ ña̱yuu. Dá chi̱ nda̱ ni̱ ka̱sáꞌá vá saꞌa̱ ñayuú, ta nda̱ viti ko̱ óon taꞌon ndoꞌo ña̱yuu táto̱ꞌon ki̱ꞌo ndoꞌo na tein kuu̱ dáá ñóó. Ta ni iin kuu̱ ka̱ o̱ kóo dión.  
\v 20 Tído tá ko̱ ní chítuu satoꞌo yo̱ Ndios ta̱ndóꞌó ve̱i koo tein kuu̱ dáá ñóó, dá kía̱n ndiꞌi va ña̱yuu ñoó na̱á. Tído sa̱ꞌá ña̱ kúꞌu̱ ini na̱ sa̱ꞌá ña̱yuu ni̱ ka̱xi mií ná, sa̱ꞌá ño̱ó chituu na ta̱ndóꞌó koo tein kuu̱ dáá ñóó. 
\p  
\v 21 ’Tá kaꞌa̱n iin ña̱yuu xíꞌín ndó: “Kande̱ꞌé ndó, yóꞌo nákaa̱ Cristo, na̱ dáka̱ki ñaá”, o tá kaa na̱ xíꞌín ndó: “Kande̱ꞌé ndó, chi̱ káa nákaa̱ na̱”, ná dáꞌa ni kandía ndó.  
\v 22 Chi̱ ndakuei dao ta̱a to̱ꞌón, ta kaa ra̱ ña̱ mií rá kúú Cristo. Ta ndakuei taꞌani profeta to̱ꞌón. Ta kee ra ña̱ꞌa ndato, xíꞌín ña̱ꞌa náꞌano, dá dándaꞌí ra̱ ña̱yuu. Ta kúú nda̱ ña̱yuu ni̱ ka̱xi mií Ndios ndukú rá dándaꞌí ra̱.  
\v 23 Sa̱ꞌá ño̱ó kaon koo ndó, chi̱ sa̱ ni̱ da̱tíꞌai ndo̱ꞌó tá ko̱ ñáꞌa̱ koo dión. 
\s1 Diꞌa koo, dá nandió ko̱o tuku Jesús kii na ñayuú yóꞌo 
\p  
\v 24 Dá ni̱ kaa taꞌani Jesús: 
\p ―Tein kuu̱ dáá ñóó, tá ni̱ ndiꞌi ni̱ sa̱ io ta̱ndóꞌó káꞌano ñoó, dá nakuiin naá ndi̱ndii, ta ni yoo̱ ka̱ o̱ tóo̱n.  
\v 25 Dá kue̱i ti̱ñoo̱ ñóꞌo induú káa, ta kidi niꞌini ña̱ náꞌano ñóꞌo induú.  
\v 26 Dá ví koni ndo̱ na̱ ni̱ nduu ta̱a ñayuú yóꞌo kii na tein viko̱, ta ndato nayeꞌe̱ ndaa na̱ noo̱ kii na xíꞌín ndidaá choon kómí ná.  
\v 27 Ta kaꞌanda na̱ choon noo̱ ángel ve̱i xíꞌín ná koꞌo̱n na̱ nakuaka na ndidaá kúú ña̱yuu ni̱ ka̱xi mií ná ndéi ndin komi̱ xoo tachi̱, chi̱ koꞌo̱n na̱ noo̱ xíká cháá ka̱ noo̱ kúú no̱ñóꞌo̱ yóꞌo, ta koꞌo̱n taꞌani na noo̱ kúú noo̱ xíká cháá ka̱ induú dá nditútí ná noo̱ Jesús. 
\p  
\v 28 ’Kaneꞌe ndó kuendá táto̱ꞌon kée ta̱ño̱ꞌó. Tá ni̱ ndu̱yúta̱ noo̱ ra̱, ta ve̱i nóma̱ yúta̱ kuálí ra̱, kúú sa̱ náꞌá vá yó ña̱ sa̱ ni̱ ku̱yati yoo̱ koon dai̱.  
\v 29 Ta dión taꞌani, tá ni̱ xini ndo̱ ni̱ ka̱sáꞌá kúu ta̱ndóꞌó yóꞌo, dá kía̱n kanaꞌá ndó ña̱ sa̱ ni̱ ku̱yati va kuu̱ nandió ko̱oi kasaa̱i̱. 
\p  
\v 30 ’Miía̱n ndaa̱ kuiti ná kaꞌi̱n xíꞌín ndó ña̱ o̱ ku̱ú taꞌon ña̱yuu ndéi tiempo daá nda̱ ná koo ndidaá ña̱ yóꞌo.  
\v 31 Induú káa xíꞌín no̱ñóꞌo̱ yóꞌo naá váán. Tído to̱ꞌon káꞌi̱n, o̱ yáꞌa taꞌan vaan. 
\p  
\v 32 ’Tído ni ko̱ íin taꞌon náꞌá ndá kuu̱ kakian, o ndá hora kooan, ta ni ángel ndéi induú ko̱ náꞌá, ta ni na̱ kúú de̱ꞌe Ndios ko̱ náꞌá, chi̱ iin tóꞌón dini̱ míí vá tatá Ndios kúú na̱ náꞌá.  
\v 33 Sa̱ꞌá ño̱ó kañoꞌo ini ndo̱, ta kaꞌa̱n ndo̱ xíꞌín Ndios, chi̱ ko̱ náꞌá taꞌon ndó ndá oon koo dión. 
\p  
\v 34 ’Chi̱ kíán táto̱ꞌon ki̱ꞌo ndóꞌo iin ta̱a kuaꞌa̱n xi̱ká. Tá ko̱ ñáꞌa̱ kana ra koꞌo̱n ra̱, dá ni̱ da̱nkoo tóo ra veꞌe ra noo̱ ndáꞌa̱ ta̱a kéchóon noo̱ rá. Dá ni̱ xi̱ꞌo ra choon noo̱ iin rá iin ra. Dá ni̱ saꞌanda taꞌani ra choon no̱ó ta̱a ndaá yéꞌé rá ña̱ ná kañoꞌo ini ra̱.  
\v 35 Ki̱ꞌo dión taꞌani kañoꞌo ini ndo̱, chi̱ ko̱ náꞌá taꞌon ndó ndá oon nandió ko̱o tuku na̱ kúú satoꞌo ndo̱ kasaa̱ na̱. Chi̱ oon ni ví kasaa̱ na̱ tá ni̱ kuaá, o kasaa̱ na̱ dao ñoó, o kasaa̱ na̱ tá ni̱ kana chéli, o kasaa̱ na̱ tá ni̱ tu̱u noo̱.  
\v 36 Chi̱ iin ndakána va kasaa̱ na̱, sa̱ꞌá ño̱ó kañoꞌo ini ndo̱, dá kía̱n ná dáꞌa ni natiin na ndo̱ꞌó ndéi ndó kídi̱ ndo̱.  
\v 37 Ña̱ káꞌi̱n xíꞌín ndoꞌó yóꞌo, káꞌi̱n xíꞌín ndidaá kúú ña̱yuu ña̱ ná kañoꞌo ini na̱ ―kaá Jesús. 
\c 14  
\s1 Yóꞌo ni̱ nda̱tóꞌón kueꞌé ta̱ néꞌe choon ndi kee ra, dá tiin ra Jesús 
\p  
\v 1 Ta kómani̱ vá uu̱ ka̱ kuu̱, dá koo víko̱ pascua, dá seí na̱ Israel pan ko̱ ní kíꞌin táꞌan xíꞌín ña̱ dákuita̱ ta̱chí ñaá. Kúú ni̱ ka̱sáꞌá ndátóꞌón mañá ndidaá ta̱ duti̱ sakua̱ꞌa̱ xíꞌín ta̱a dánaꞌa̱ ley Moisés ndi koo kee ra, dá tiin ra Jesús, dá ná kaꞌání ñaá ta̱ néꞌe choon.  
\v 2 Dá ni̱ kaa ra̱: 
\p ―Ná dáꞌa ni tiin yó ra̱ tein víko̱, dá chi̱ ndakuei ña̱yuu nakui̱na vaa̱ na̱ kiꞌin na saꞌa̱ rá ―kaá ra̱. 
\s1 Diꞌa ni̱ kuu tá ni̱ kuei iin ñáꞌa̱ ndutá támi sáꞌa̱n dini̱ Jesús 
\p  
\v 3 Ta nákaa̱ Jesús ñoo Betania noo̱ kúú veꞌe iin ta̱a naní Simón, táꞌa̱n ra̱ ni̱ sa̱ ndoꞌo kueꞌe̱ téíꞌi̱. Ta noo̱ ió Jesús mesa, kúú ni̱ ka̱sáa̱ iin ñáꞌa̱, ta néꞌán iin ti̱ndoꞌo̱ lóꞌo̱ ni̱ ka̱va̱ꞌa xíꞌín yuu̱ dío̱n naní alabastro. Ta ñoó ñóꞌo ndutá támi sáꞌa̱n naní nardo. Ta ndutá yaꞌi nda̱ꞌo kúú rá. Ta kúú ni̱ taꞌávíán diko̱ ti̱ndoꞌo̱ ñoó, dá ni̱ kuei ndiꞌán ra̱ dini̱ Jesús.  
\v 4 Ta kúú ni̱ xido̱ nda̱ꞌo ini dao ta̱a ndéi ñoó, dá ni̱ ka̱sáꞌá rá ndátóꞌón táꞌan mií rá ndéi ra: 
\p ―¿Ndiva̱ꞌa dánaá oon ñáꞌa̱ káa ndutá támi sáꞌa̱n káa?  
\v 5 Ta va̱ꞌa ka̱ ví ní di̱kó yó ra̱, chi̱ yaꞌi rá táto̱ꞌon ki̱ꞌo níꞌi̱ iin ña̱yuu kéchóon na oni̱ ciento kuu̱, dá chindeé yó na̱ kúndaꞌí xíꞌín di̱ꞌón ñoó, ní kúu ―kaá ra̱. 
\p Sa̱ꞌá ño̱ó ni̱ ka̱sáꞌá rá dána̱ni ra ñáꞌa̱ ñoó. 
\p  
\v 6 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―O̱ sa̱ dána̱ni ndó ñáꞌa̱ yóꞌo. ¿Ndiva̱ꞌa dátaꞌán ndo̱án? Chi̱ ña̱ va̱ꞌa va kía̱n ni̱ keeán xíꞌín yuꞌu̱.  
\v 7 Chi̱ daá ndéi va ña̱yuu kúndaꞌí xíꞌín ndoꞌó, ta kuu va chindeé ndó na̱ ndá hora káꞌán mií ndó. Tído yuꞌu̱, o̱ kóo kuií taꞌoin xíꞌín ndó.  
\v 8 Ñáꞌa̱ yóꞌo kúú ñá xíꞌo ndiꞌi táto̱ꞌon ki̱ꞌo sáa̱ ndée̱a̱n noo̱í, chi̱ ni̱ kuei ñá ndutá támi sáꞌa̱n dini̱í, ta ki̱ꞌo dión ni̱ kenduua̱n yikí ko̱ñoi̱ táto̱ꞌon ki̱ꞌo kooi ndu̱xii.  
\v 9 Miía̱n ndaa̱ ná kaꞌi̱n xíꞌín ndó ña̱ ndeí kúú míí vá noo̱ dánaꞌa̱ na̱ to̱ꞌon va̱ꞌa sa̱ꞌí iin níí kúú ñayuú yóꞌo, nakani taꞌani na ña̱ ni̱ kee ñáꞌa̱ yóꞌo xíꞌín yuꞌu̱, dá ná kañoꞌo ini ña̱yuu sa̱ꞌá ña̱ ni̱ keeán ―ka̱á Jesús. 
\s1 Diꞌa ni̱ kuu, dá ni̱ ka̱ndo̱o Judas ña̱ naki̱ꞌo ra Jesús noo̱ ndáꞌa̱ ta̱ duti̱ kúú no̱ó 
\p  
\v 10 Dá ni̱ kee Judas Iscariote, táꞌa̱n ra̱ nákaa̱ tein ndin uxi̱ uu̱ ta̱a xíonoo xíꞌín Jesús, kuaꞌa̱n ra̱ di̱kó rá Jesús no̱ó ta̱ duti̱ sakua̱ꞌa̱.  
\v 11 Tá ni̱ sei̱do̱ꞌo ta̱ duti̱ ñoó ña̱ ni̱ kaꞌa̱n Judas xíꞌín rá, kúú ni̱ kadii̱ nda̱ꞌo ini ra̱. Dá ni̱ ka̱ndo̱o ra ña̱ ki̱ꞌo ra di̱ꞌón noo̱ rá. Dá ni̱ ka̱sáꞌá ndúkú Judas ndí koo kee ra, dá naki̱ꞌo ra Jesús noo̱ ndáꞌa̱ ro̱ón. 
\s1 Diꞌa ni̱ kuu tá ni̱ sa̱díni Jesús noo̱ ndíꞌí kuií xíꞌín ta̱ xíonoo xíꞌín ná 
\p  
\v 12 Tá ni̱ kasa̱ndaá kuu̱ mií no̱ó, ña̱ kúú víko̱ noo̱ seí na̱ Israel pan, táꞌa̱n ña̱ ko̱ ní kíꞌin táꞌan xíꞌín ña̱ dákuita̱ ta̱chía̱n, ta saꞌání na̱ léko kuendá víko̱ pascua, dá ni̱ nda̱to̱ꞌón ñaá ta̱ xíonoo xíꞌín Jesús: 
\p ―¿Ndeí kóni̱ ní koꞌo̱n nduꞌu̱ kenduu ndu̱ ña̱ kadíni yó kuendá pascua? 
\p  
\v 13 Dá ni̱ saꞌanda na̱ choon no̱ó uu̱ ta̱ xíonoo xíꞌín ná ñóó, ta kaá na̱ xíꞌín rá: 
\p ―Kuaꞌán ndo̱ ñoo káꞌano káa. Ta káa nakiꞌin táꞌan ndó xíꞌín iin ta̱a ndío yoo ñóꞌo ta̱kui̱í kuaꞌa̱n ra̱. Ta kúú karkuei ndó ra̱ koꞌo̱n ndo̱.  
\v 14 Dá tá ni̱ saa̱ ra̱ ni̱ ndu̱ꞌu ra ini veꞌe, dá kaa ndo̱ xíꞌín ta̱a kúú satoꞌo veꞌe ñoó: “Diꞌa kaá maestro nduꞌu̱: ¿Ndi káa iin cuarto ki̱ꞌo ní noo̱ kadínii̱ kuendá víko̱ pascua xíꞌín ta̱ xíonoo xíꞌíín?” kaa ndo̱ xíꞌín rá.  
\v 15 Dá ná dánaꞌa̱ ra̱ iin cuarto káꞌano kánóo dikó, ta sa̱ ió nduu vaan. Ta ñoó kenduu ndo̱ ña̱ꞌa ná kadíni yó ―kaá Jesús. 
\p  
\v 16 Dá ni̱ kee uu̱ ta̱a ñoó kuaꞌa̱n ra̱. Dá tá ni̱ saa̱ ra̱ ñoo ñoó, kúú ni̱ ndoꞌo ra táto̱ꞌon káa rá ió ña̱ ni̱ kaꞌa̱n Jesús xíꞌín rá. Ta ñoó ni̱ kenduu ra̱ ña̱ kadíni na kuendá víko̱ pascua. 
\p  
\v 17 Dá tá ni̱ kuaá ñóó, dá ni̱ ka̱saa̱ Jesús xíꞌín ndin uxi̱ uu̱ ta̱ xíonoo xíꞌín ná veꞌe ñoó.  
\v 18 Dá ni̱ sa̱ ndei na mesa. Ta tein sásáꞌan na ñoó, dá ni̱ kaa Jesús: 
\p ―Miía̱n ndaa̱ ná kaꞌi̱n xíꞌín ndó ña̱ iin mií vá ndoꞌó, ta̱ sásáꞌan dáó xíꞌín yuꞌu̱, naki̱ꞌo ñaá noo̱ ndáꞌa̱ ta̱a xiní uꞌu̱ ñaá ―kaá na̱. 
\p  
\v 19 Dá ni̱ ka̱sáꞌá kúndaꞌí nda̱ꞌo ini ra̱. Dá ni̱ kaa iin rá iin ra xíꞌín ná: 
\p ―¿Á yuꞌu̱ kúúí, tatá? 
\p  
\v 20 Dá ni̱ kaa Jesús: 
\p ―Iin ta̱a nákaa̱ tein ndin uxi̱ uu̱ ndo̱ kúú rá. Táꞌa̱n ra̱ dáke̱ta dáó ndáꞌa̱ xíꞌín yuꞌu̱ ini koꞌo̱, ro̱ón kúú rá.  
\v 21 Ta miía̱n ndaa̱ ndoꞌo na̱ ni̱ nduu ta̱a ñayuú yóꞌo táto̱ꞌon ki̱ꞌo káꞌa̱n tuti ii̱ Ndios. Tído ndaꞌí va ta̱a naki̱ꞌo ñaá noo̱ ndáꞌa̱ ta̱a xiní uꞌu̱ ñaá. Va̱ꞌa cháá ka̱ vía̱n ní xi̱o dáꞌa ni kaki ta̱a ñoó, ní kúu ―kaá na̱. 
\p  
\v 22 Ta tein noo̱ sásáꞌan na ñoó, dá ni̱ tiin Jesús pan. Dá ni̱ na̱ki̱ꞌo na ndivéꞌe noo̱ Ndios. Dá ni̱ saꞌanda dao naa̱n, dá ni̱ xi̱ꞌo naa̱n no̱ó ta̱a ñoó. Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Keí ndo̱án, chi̱ ña̱ xaa̱n kúú yikí ko̱ñoi̱. 
\p  
\v 23 Dá ni̱ tiin na copa. Dá tá ni̱ ndiꞌi ni̱ na̱ki̱ꞌo na ndivéꞌe noo̱ Ndios, dá ni̱ xi̱ꞌo na ra̱ no̱ó ta̱ xíonoo xíꞌín ná, ta ndidaá vá rá ni̱ xiꞌi lúꞌu̱ lúꞌu̱ ra̱.  
\v 24 Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Ndúta̱ xaa̱n kúú nii̱ yuꞌu̱, kirá dáxi̱nko̱o ña̱ ni̱ ka̱ndo̱o Ndios kee na xíꞌín ña̱yuu na̱, ta kuita̱ ra̱ sa̱ꞌá kua̱chi kua̱ꞌá ña̱yuu.  
\v 25 Miía̱n ndaa̱ ná kaꞌi̱n xíꞌín ndó ña̱ o̱ nándió ko̱o ka̱i̱ koꞌi ndutá uva yóꞌo nda̱ ná kasandaá kuu̱, dá koꞌo sa̱ái̱ ndutá uva noo̱ ió Ndios dándáki na. 
\s1 Yóꞌo ni̱ kaꞌa̱n Jesús ña̱ ndata̱ Pedro saꞌa̱ ná 
\p  
\v 26 Dá tá ni̱ ndiꞌi ni̱ kekáꞌano na Ndios xíꞌín iin yaa, dá ni̱ kee na kuaꞌa̱n na̱ dini̱ yúku̱ naní Olivos. 
\p  
\v 27 Dá ni̱ kaa Jesús xíꞌín ta̱ xíonoo xíꞌín ná: 
\p ―Ndidaá vá ndoꞌó dánkoo ndava̱ꞌa ñaá sa̱kuaá víti, dá chi̱ diꞌa kaá tuti ii̱ Ndios: “Dárkueꞌe̱ kaꞌí yuꞌu̱ ta̱a ndáka léko, ta kúú ndi ndiꞌi va léko kuita̱ no̱ó koꞌo̱n.”  
\v 28 Tído tá ni̱ ndiꞌi ni̱ na̱takii̱, dá kuió no̱ói̱ noo̱ ndo̱ koꞌi̱n chí Galilea diꞌa, dá kasandaá ndo̱ ―kaá na̱. 
\p  
\v 29 Dá ni̱ kaa Pedro: 
\p ―Va̱ꞌará ná dánkoo ndava̱ꞌa ndidaá ta̱a yóꞌo mií ní, tído yuꞌu̱, o̱ kée taꞌoin dión. 
\p  
\v 30 Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Miía̱n ndaa̱ ná kaꞌi̱n xíꞌón ña̱ sa̱kuaá víti, tá ko̱ ñáꞌa̱ taꞌon kana chéli taꞌándá kúú uu̱, ta kúú sa̱ oni̱ va taꞌándá ndato̱n sa̱ꞌá yuꞌu̱. 
\p  
\v 31 Ta kúú ni̱ ndu̱ndéé Pedro kaꞌa̱n ra̱, ta kaá ra̱: 
\p ―Va̱ꞌará ná kánian kuu nduúi̱ xíꞌín ní, tído o̱ ndáta̱ taꞌoin saꞌa̱ ní ―kaá ra̱. 
\p Ta kúú ki̱ꞌo dión taꞌani ni̱ kaa ndidaá ka̱ ta̱ xíonoo xíꞌín ná ñóó. 
\s1 Diꞌa ni̱ kuu tá ni̱ ni̱ nda̱tóꞌón Jesús xíꞌín Ndios iin noo̱ naní Getsemaní 
\p  
\v 32 Ni̱ ndiꞌi, dá ni̱ saa̱ na̱ noo̱ naní Getsemaní. Dá ni̱ kaa Jesús xíꞌín ta̱ xíonoo xíꞌín ná: 
\p ―Yóꞌo ni kandei tóo ndó, dá ná koꞌi̱n kaꞌi̱n xíꞌín Ndios, dá kasaa̱i̱ ―ka̱á na̱. 
\p  
\v 33 Dá ni̱ kee Jesús ndáka na Pedro xíꞌín Jacobo xíꞌín Juan kuaꞌa̱n na̱. Dá ni̱ kixia̱n ni̱ ku̱ndaꞌí nda̱ꞌo ini Jesús, ta ni̱ ka̱sáꞌá ndóꞌo nda̱ꞌo nío̱ ná.  
\v 34 Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Ndaꞌí nda̱ꞌo kúu inii̱. Sa̱ nda̱á ndi̱i va kúúí xiníi̱. Yóꞌo ni kandei tóó ndó, ta kañoꞌo ini ndo̱ ―kaá na̱. 
\p  
\v 35 Dá ni̱ kee Jesús kuaꞌa̱n na̱ lúꞌu̱ ka̱ chí noo̱. Dá ni̱ sa̱ kuíi̱n xi̱tí ná, ta ni̱ xino̱ ví taan na̱ nda̱ no̱ñóꞌo̱. Dá ni̱ xika̱ na̱ noo̱ Ndios ña̱ tá ná kuu, dá ná o̱ yáꞌa na ña̱ ve̱i ndoꞌo na ñoó.  
\v 36 Ta diꞌa kuaꞌa̱n ña̱ ni̱ kaa na̱: 
\p ―Tatá lóꞌo̱ miíi̱, ndidaá kúú vá ña̱ꞌa kuu kee mií ní. Di̱tá ní yuꞌu̱ noo̱ ndutá ova̱, ña̱ kúú ña̱ ndoꞌo nío̱í. Tído ná dáꞌa ni kakuuan táto̱ꞌon ki̱ꞌo kóni̱ yuꞌu̱. Ná kakuuan táto̱ꞌon ki̱ꞌo kóni̱ mií ní ―kaá na̱. 
\p  
\v 37 Tá ni̱ na̱ndió ko̱o na ni̱ ndi̱sáa̱ na̱ noo̱ ndéi ndin oni̱ ta̱a kuaꞌa̱n xíꞌín ná ñoó, kúú sa̱ kídi̱ va ra ndéi ra. Dá ni̱ kaa na̱ xíꞌín Simón Pedro: 
\p ―Simón, ¿á kídi̱ vóón? ¿Á ko̱ xi̱ꞌo ndeé taꞌon inóo̱n kañoꞌo inóo̱n, va̱ꞌará iin hora?  
\v 38 Kañoꞌo ini ndo̱, ta kaꞌa̱n ndo̱ xíꞌín Ndios, dá ná dáꞌa ni kexíxi ña̱ kini xíꞌín ndó. Chi̱ sa̱ ió nduu nío̱ ndo̱ kee ndó ña̱ kóni̱ Ndios. Tído ña̱ kóni̱ ñíi̱ ndo̱ kía̱n chituu ñaá ―kaá na̱. 
\p  
\v 39 Dá ni̱ saꞌa̱n tuku na ni̱ kaꞌa̱n na̱ xíꞌín Ndios táto̱ꞌon ki̱ꞌo ni̱ kaꞌa̱n na̱ xíꞌín ná taꞌándá mií no̱ó.  
\v 40 Dá tá ni̱ ndi̱sáa̱ na̱ noo̱ ndéi oni̱ ta̱a ñoó, kúú sa̱ kídi̱ tuku va ra ndéi ra, chi̱ saꞌání nda̱ꞌo ñaá ña̱ ma̱ꞌánó. Ta ko̱ níꞌi̱ vá rá ndí ki̱án kaꞌa̱n ra̱ xíꞌín ná.  
\v 41 Ta kúú taꞌándá kúú oni̱ ni̱ ndi̱sáa̱ Jesús ni̱ saꞌa̱n na̱ ni̱ kaꞌa̱n na̱ xíꞌín Ndios. Dá ni̱ kaa na̱ xíꞌín ta̱a ñoó: 
\p ―¡Kudi̱ ndo̱ viti! ¡Ta naniꞌi̱ ndée̱ ndo̱ viti! Cháá dión ka̱ ni ná kakia̱n kudi̱ ndo̱, chi̱ sa̱ ni̱ kasa̱ndaá va hora ña̱ naki̱ꞌo ra na̱ ni̱ nduu ta̱a ñayuú yóꞌo noo̱ ndáꞌa̱ ta̱a kómí kua̱chi.  
\v 42 ¡Ndakuei ndó, ná koꞌo̱ viti! Chi̱ sa̱ kúyati ta̱a ve̱i naki̱ꞌo yuꞌu̱ noo̱ ndáꞌa̱ ta̱ kómí kua̱chi ―kaá na̱. 
\s1 Diꞌa ni̱ kuu tá ni̱ tiin ra Jesús kandaka ra koꞌo̱n ra̱ no̱ó ta̱ néꞌe choon 
\p  
\v 43 Kúú káꞌa̱n i̱í vá Jesús íin na, kúú sa̱ ni̱ ka̱sáa̱ va Judas, iin ra̱ kúú kuendá ndin uxi̱ uu̱ ta̱ xíonoo xíꞌín ná. Ta kua̱ꞌá nda̱ꞌo ta̱a ve̱i xíꞌín rá. Dao ra néꞌe espada, ta dao ka̱ ra̱ néꞌe yíto̱. Chi̱ ve̱i ra xíꞌín choon ni̱ saꞌanda ta̱ duti̱ sakua̱ꞌa̱, xíꞌín ta̱a dánaꞌa̱ ley Moisés, xíꞌín ta̱ sáꞌano ñoo.  
\v 44 Sa̱ ni̱ ka̱sto̱ꞌon va Judas xíꞌín ta̱a ñoó ndi kee ra dánaꞌa̱ ra̱ ndá yoo kúú Jesús, chi̱ diꞌa ni̱ kaa ra̱: 
\p ―Ta̱a ni̱ chitóí noo̱ ñoó, ro̱ón kúú tiin ndó kandaka ndó koꞌo̱n ndo̱, ta kandaa va̱ꞌa ndó ra̱ ―kaá ra̱. 
\p  
\v 45 Dá tá ni̱ na̱tuu yati Judas noo̱ íin Jesús, dá ni̱ kaa ra̱ xíꞌín ná: 
\p ―Nákaa̱ ní, maestro. 
\p Dá ni̱ chitó rá noo̱ ná.  
\v 46 Dá ni̱ na̱tuu ta̱a kuaꞌa̱ ñoó ni̱ tiin ra Jesús. 
\p  
\v 47 Ta kúú iin ta̱a íin xíꞌín Jesús ni̱ taó rá espada ra̱. Ta kúú ni̱ chi̱tóꞌo̱n ra̱ do̱ꞌo iin ta̱a kéchóon no̱ó ta̱ duti̱ kúú no̱ó.  
\v 48 Dá ni̱ kaa Jesús xíꞌín ta̱a kuaꞌa̱ ñoó: 
\p ―¿Á ta̱ kui̱ꞌíná vá kée ndó yuꞌu̱ kúúí, sa̱ꞌá ño̱ó ve̱i ndó xíꞌín espada xíꞌín yíto̱ tiin ndó yuꞌu̱?  
\v 49 Ta ndidaá kuu̱ vá ni̱ sa̱ káa̱i̱ xíꞌín ndó yéꞌé ño̱ꞌo káꞌano sa̱ da̱náꞌi̱ noo̱ ndo̱, ta ko̱ ní tíin taꞌon ndó yuꞌu̱. Tído ndidaá ña̱ yóꞌo kúu viti, dá ná xi̱nko̱o to̱ꞌon káꞌa̱n tuti ii̱ Ndios ―kaá na̱. 
\p  
\v 50 Ta kúú ndidaá vá ta̱ xíonoo xíꞌín ná ni̱ da̱nkoo ndava̱ꞌa ñaá, ta ni̱ xino ra kuaꞌa̱n ra̱. 
\s1 Diꞌa ni̱ ndoꞌo iin tayií ni̱ ka̱nkono kuaꞌa̱n 
\p  
\v 51 Ta sata̱ ña̱yuu kuáꞌa̱ ñoó tákaa iin tayií kuaꞌa̱n xi. Ta sa̱va̱ꞌa iin sábana va ndíxi xi kuaꞌa̱n xi̱. Kúú ni̱ tiin taꞌani ñaá rá.  
\v 52 Tído ni̱ da̱yáa̱ xi̱ sábana ñoó. Ta kúú nda̱á ni̱ ka̱nkono vichí xí kuaꞌa̱n xi̱. 
\s1 Diꞌa ni̱ kuu tá ni̱ sa̱ íin Jesús noo̱ mií ta̱ duti̱ kúú no̱ó 
\p  
\v 53 Dá néꞌe ra Jesús ni̱ saa̱ ra̱ noo̱ ió mií ta̱ duti̱ kúú no̱ó. Dá ni̱ na̱taka taꞌani ndidaá kúú ta̱ duti̱ sakua̱ꞌa̱, xíꞌín ta̱ sáꞌano ñoo, xíꞌín ta̱a dánaꞌa̱ ley Moisés.  
\v 54 Ta Pedro, nda̱á xíká xíká tákaa ra kuaꞌa̱n ra. Dá ni̱ saa̱ ra̱ ni̱ ku̱ꞌu ra noo̱ kúú yéꞌé veꞌe ta̱ duti̱ kúú no̱ó ñóó. Dá ni̱ sa̱ ko̱o ra ió ra̱ noo̱ ndéi ta̱a ndaá yéꞌé ñóó, chi̱ ndéi ra nádaa̱ rá noo̱ kéi̱ ñóꞌo̱. 
\p  
\v 55 Ta ra̱ duti̱ sakua̱ꞌa̱ ñoó xíꞌín ndidaá ka̱ ta̱ néꞌe choon ndéi ra ndúkú rá ta̱a kaꞌa̱n kua̱chi saꞌa̱ Jesús, dá kuu naki̱ꞌo ñaá rá noo̱ ndáꞌa̱ ta̱ romano, dá kaꞌání ñaá rá. Tído ko̱ ní níꞌi̱ taꞌon ra ndí ki̱án kakuu kua̱chi na.  
\v 56 Chi̱ kua̱ꞌá nda̱ꞌo ta̱a ni̱ ka̱va̱ꞌa ña̱ to̱ꞌón ni̱ kaꞌa̱n ra̱ saꞌa̱ Jesús. Tído ko̱ ní nákiꞌin táꞌan taꞌon to̱ꞌon, ña̱ ni̱ kaꞌa̱n ra̱ saꞌa̱ ná. 
\p  
\v 57 Dá ni̱ nda̱kuei dao ka̱ ta̱a ndúkú rá kua̱chi kaꞌa̱n ra̱ saꞌa̱ Jesús, ta kaá ra̱: 
\p  
\v 58 ―Nduꞌu̱ kúú ra̱ ni̱ seídóꞌo ña̱ ni̱ kaa ta̱a xaa̱n diꞌa: “Koꞌi̱n nakani ndiꞌii veꞌe ño̱ꞌo káꞌano yó, ña̱ ni̱ ka̱va̱ꞌa ndáꞌa̱ ta̱a. Ta kúú ti̱xi oni̱ kuu̱, ta kúú kava̱ꞌi iin ka̱ veꞌe ño̱ꞌo sa̱á, tído o̱ du̱ú ña̱ káva̱ꞌa ndáꞌa̱ ta̱a kakian” ―kaá ra̱. 
\p  
\v 59 Tído ko̱ ní nákiꞌin táꞌan taꞌon ña̱ ni̱ kaꞌa̱n ra̱ saꞌa̱ ná. 
\p  
\v 60 Dá ni̱ nda̱kuíi̱n ndichi mií ta̱ kúú duti̱ kúú no̱ó me̱ꞌí noo̱ ndéi ra ñoó. Dá ni̱ nda̱to̱ꞌón rá Jesús: 
\p ―¿Ndiva̱ꞌa ko̱ káꞌo̱n chindeéón miíón? ¿Á ña̱ ndaa̱ kía̱n káꞌa̱n kua̱chi ta̱a káa sa̱ꞌo̱n o ko̱ó? 
\p  
\v 61 Tído tádi̱ óon va íin Jesús, ni iin to̱ꞌon ko̱ ní kaꞌa̱n na̱. 
\p Dá ni̱ na̱ndió ko̱o tuku mií ta̱ duti̱ kúú no̱ó ñóó ni̱ nda̱to̱ꞌón ñaá rá: 
\p ―¿Á yoꞌó kúú Cristo, na̱ dáka̱ki ñaá? ¿Á de̱ꞌe Ndios, na̱ ii̱, kúú yoꞌó? 
\p  
\v 62 Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Jaa̱n, ñaá kúú yuꞌu̱, ta koni ndo̱ na̱ ni̱ nduu ta̱a ñayuú yóꞌo nako̱o na xoo kuáꞌa Ndios noo̱ ió na̱ dándáki na. Ta koni taꞌani ndó na̱ kii na tein viko̱ tánee induú ―kaá na̱. 
\p  
\v 63 Dá ni̱ ndatá ta̱ duti̱ kúú no̱ó ñóó dáꞌo̱n ndíxi ra sa̱ꞌá ña̱ ni̱ xido̱ ini ra̱. Dá ni̱ kaa ra̱: 
\p ―¿Ndá choon kuu ka̱ yo̱ cháá ka̱ ta̱a kaꞌa̱n kua̱chi saꞌa̱ rá?  
\v 64 Chi̱ sa̱ ni̱ seídóꞌo vá míí ndó ña̱ ni̱ kaꞌa̱n ndava̱ꞌa ra saꞌa̱ Ndios. ¿Ndí ki̱án nátaꞌan ini ndo̱ keeá xíꞌín rá viti? ―kaá ra̱. 
\p Dá ni̱ ka̱ndo̱o ndidaá ta̱a ndéi ñoó ña̱ kánian kuu Jesús sa̱ꞌá ña̱ ni̱ kaꞌa̱n na̱ dión.  
\v 65 Dá ni̱ ka̱sáꞌá túu ndaa di̱í ñaá dao ra. Ta ni̱ da̱dáꞌi ra noo̱ ná xíꞌín iin dáꞌo̱n, dá ni̱ kani ñaá rá, ta kaá ra̱ xíꞌín ná: 
\p ―Nakoni ini ndi ndá yoo ni̱ kani ñaá ―kaá ra̱. 
\p Ta nda̱ ra̱ ndíta ndaá yéꞌé ñoó ni̱ kani daꞌa̱nda̱ noo̱ ná. 
\s1 Diꞌa ni̱ kuu tá ni̱ ndata̱ Pedro saꞌa̱ Jesús oni̱ taꞌándá 
\p  
\v 66 Ta yéꞌé veꞌe nino̱ ñoó ió i̱í vá Pedro. Dá ni̱ ka̱sáa̱ iin ñáꞌa̱ kéchóon noo̱ mií ta̱ duti̱ kúú no̱ó ñoó.  
\v 67 Dá tá ni̱ xinia̱n ió Pedro nádaa̱ rá noo̱ kéi̱ ñóꞌo̱ ñoó, kúú ni̱ sa̱ nde̱ꞌé va̱ꞌa ñaáán, dá ni̱ kaaa̱n xíꞌín rá: 
\p ―Xíonoo taꞌani yoꞌó xíꞌín Jesús, ta̱ ñoo Nazaret, ¿daá ko̱ó? 
\p  
\v 68 Tído ni̱ ndata̱ vá rá, ta kaá ra̱: 
\p ―Ko̱ náꞌá taꞌon yuꞌu̱ ta̱a ñoó, ta ni ko̱ kándaa̱ taꞌon inii̱ ndá saꞌa̱ káꞌo̱n xíꞌíín. 
\p Dá ni̱ kee ra kuaꞌa̱n ra̱ chí noo̱ kúú yéꞌé diꞌa. Tá ni̱ saa̱ ra̱ ñoó, ta kúú ni̱ kana va chéli.  
\v 69 Ta kúú ni̱ xini tuku va ñáꞌa̱ ñoó noo̱ íin Pedro. Dá ni̱ ka̱sáꞌá káꞌa̱n xíꞌín dao ka̱ ña̱yuu ndíta ñoó: 
\p ―Ta̱a yóꞌo kúú kuendá Jesús. 
\p  
\v 70 Ta kúú tuku va ni̱ ndata̱ rá. 
\p Ta lúꞌu̱ ka̱ tóó, kúú ni̱ kaꞌa̱n dao ka̱ ña̱yuu ndíta ñoó xíꞌín rá: 
\p ―Miía̱n ndaa̱ kuiti kuendá Jesús kúú yoꞌó, chi̱ ta̱ kuendá Galilea taꞌani kúúón. Dá chi̱ táto̱ꞌon káꞌa̱n ro̱ón, dión káꞌo̱n. 
\p  
\v 71 Dá ni̱ ka̱sáꞌá káꞌa̱n ndava̱ꞌa Pedro, ta kaá ra̱: 
\p ―Náꞌá Ndios ña̱ ko̱ náꞌá taꞌon yuꞌu̱ ta̱a káꞌa̱n ndo̱ saꞌa̱ ñoó ―kaá ra̱. 
\p  
\v 72 Ta kúú ni̱ kana va chéli taꞌándá kúú uu̱. Dá ví ni̱ ndi̱sáa̱ ini ra̱ to̱ꞌon ni̱ kaꞌa̱n Jesús xíꞌín rá, chi̱ diꞌa ni̱ kaa na̱: “Tá ko̱ ñáꞌa̱ kana chéli taꞌándá kúú uu̱, ta kúú sa̱ ndata̱ yo̱ꞌó sa̱ꞌá yuꞌu̱ oni̱ taꞌándá”, kaá na̱. Tá ni̱ ndi̱sáa̱ ini ra̱ to̱ꞌon yóꞌo, kúú ndaꞌí nda̱ꞌo ni̱ saki ra. 
\c 15  
\s1 Diꞌa ni̱ kuu tá ni̱ sa̱ íin Jesús no̱ó ta̱a naní Pilato 
\p  
\v 1 Dá tá ni̱ tu̱u noo̱, sa̱ ni̱ ka̱ndo̱o va ta̱ duti̱ sakua̱ꞌa̱, xíꞌín ta̱ sáꞌano ñoo, xíꞌín ta̱a dánaꞌa̱ ley Moisés xíꞌín ndidaá ka̱ ní ta̱ néꞌe choon ndi ki̱ꞌo kee ra xíꞌín Jesús. Dá ni̱ kató ñaá rá ndáka ra ni̱ saa̱ ra̱ ni̱ na̱ki̱ꞌo ra no̱ó ta̱ néꞌe choon romano naní Pilato.  
\v 2 Dá ni̱ nda̱to̱ꞌón Pilato Jesús: 
\p ―¿Á yoꞌó kúú rey no̱ó na̱ Israel? 
\p Dá ni̱ kaa Jesús xíꞌín rá: 
\p ―Tá dión kaá mií ní ―kaá na̱. 
\p  
\v 3 Ta ndéi ta̱ duti̱ sakua̱ꞌa̱ dátai̱ kua̱chi ñaá rá sa̱ꞌá kua̱ꞌá nda̱ꞌo ña̱ꞌa.  
\v 4 Dá ni̱ nda̱to̱ꞌón tuku ñaá Pilato ñoó, ta kaá ra̱: 
\p ―¿Á ni iin ña̱ꞌa o̱ káꞌa̱n yo̱ꞌó chindeéón miíón? Ta dión ví kua̱ꞌá ña̱ꞌa dátai̱ kua̱chi ñaá ta̱a káa. 
\p  
\v 5 Ta va̱ꞌará dión ni̱ kaa ra̱, tído ni iin to̱ꞌon ko̱ ní kaꞌa̱n Jesús. Sa̱ꞌá ño̱ó ni̱ naá vá iní ra̱. 
\s1 Diꞌa ni̱ kuu, dá ni̱ saꞌanda Pilato choon ña̱ ná karkaa Jesús ndi̱ka cruz 
\p  
\v 6 Tein iin iin víko̱ pascua dáyaa̱ Pilato iin ta̱a nákaa̱ veꞌe ka̱a, táꞌa̱n ra̱ kándo̱o na̱ ñoo Israel saꞌa̱.  
\v 7 Daá ñóó nákaa̱ iin ta̱a naní Barrabás veꞌe ka̱a, ta ñóꞌo taꞌani dao ka̱ ta̱a kíꞌin táꞌan xíꞌín rá saꞌání rá ndi̱i. Ro̱ón kúú ta̱a ni̱ nda̱kuei ni̱ na̱á xíꞌín ta̱ néꞌe choon romano.  
\v 8 Dá ni̱ ka̱sáa̱ kua̱ꞌá nda̱ꞌo ña̱yuu noo̱ Pilato. Dá ni̱ ka̱sáꞌá xíka̱ na̱ noo̱ rá ña̱ ná dáyaa̱ ra̱ iin ta̱a nákaa̱ veꞌe ka̱a, táto̱ꞌon ki̱ꞌo kée ra tein iin rá iin víko̱ pascua.  
\v 9 Dá ni̱ kaa ra̱ xíꞌín ña̱yuu ñoó: 
\p ―¿Á kóni̱ ndo̱ ña̱ dáyaa̱i̱ na̱ kúú rey no̱ó na̱ Israel yóꞌo? 
\p  
\v 10 Dión ni̱ kaa ra̱ chi̱ ni̱ ka̱ndaa̱ va ini ra̱ ña̱ sa̱ꞌá ña̱ uꞌu̱ ini vá ta̱ duti̱ sakua̱ꞌa̱ ñoó, sa̱ꞌá ño̱ó ni̱ na̱ki̱ꞌo ñaá rá noo̱ ndáꞌa̱ rá.  
\v 11 Tído ni̱ da̱káꞌa̱n kue̱ꞌé ta̱ duti̱ sakua̱ꞌa̱ ñoó ña̱yuu kuáꞌa̱ ñoó, dá ni̱ xika̱ na̱ ña̱ va̱ꞌa cháá ka̱ Barrabás ná dáyaa̱ ra̱.  
\v 12 Dá ni̱ nda̱to̱ꞌón ñaá Pilato, ta kaá ra̱: 
\p ―¿Ndí ki̱án kóni̱ ndo̱ kee yuꞌu̱ xíꞌín ta̱a chínaní ndó kúú rey no̱ó na̱ Israel yóꞌo, tá dáá? 
\p  
\v 13 Dá ni̱ ka̱yuꞌú ña̱yuu kuáꞌa̱ ñoó: 
\p ―¡Chirkaa ní ra̱ ndi̱ka cruz! 
\p  
\v 14 Dá ni̱ kaa Pilato: 
\p ―¿Ndí ki̱án kini ni̱ ya̱ꞌa ta̱a yóꞌo ni̱ kee ra? 
\p Tído kúú ni̱ꞌi cháá ka̱ ví ni̱ ka̱sáꞌá káyuꞌú ña̱yuu kuáꞌa̱ ñoó: 
\p ―¡Chirkaa ní ra̱ ndi̱ka cruz! 
\p  
\v 15 Ta sa̱ꞌá ña̱ kóni̱ Pilato kando̱o va̱ꞌa ra no̱ó ña̱yuu kuáꞌa̱ ñoó, sa̱ꞌá ño̱ó ni̱ da̱yáa̱ ra̱ Barrabás. Dá tá ni̱ ndiꞌi ni̱ kani soldado Jesús xíꞌín chirrión, dá ni̱ na̱ki̱ꞌo ñaá Pilato noo̱ ndáꞌa̱ rá, dá ná koꞌo̱n ra̱ chirkaa ñaá rá ndi̱ka cruz. 
\p  
\v 16 Dá ni̱ na̱kiꞌin ñaá soldado ndáka ra kuaꞌa̱n ra̱ nda̱ ma̱á ini veꞌe chóon ta̱ romano. Dá ni̱ na̱da̱taká ra̱ ndidaá ka̱ soldado kúú kuendá ra̱.  
\v 17 Dá ni̱ da̱kuíꞌino ñaá rá iin dáꞌo̱n kuaꞌá to̱ón, ta ni̱ chi̱nóo ra iin corona ni̱ ka̱va̱ꞌa xíꞌín ío̱n dini̱ ná.  
\v 18 Dá ni̱ ka̱sáꞌá rá kée ra ña̱ kékáꞌano ñaá rá: 
\p ―Na̱ káꞌano kúú mií ní, na̱ kúú rey no̱ó na̱ Israel ―ka̱á ra̱. 
\p  
\v 19 Ta ni̱ kani ra iin ta̱ñi̱í dini̱ ná, ta ni̱ tu̱u ndaa di̱í ñaá rá. Ta ni̱ sa̱ kui̱ta xi̱tí rá noo̱ ná kée ra ña̱ kékáꞌano ñaá rá.  
\v 20 Tá ni̱ ndiꞌi ni̱ kedi̱ki ndaa ñaá rá, dá ni̱ di̱tá rá dáꞌo̱n kuaꞌá to̱ón ndíxi na ñoó. Dá ni̱ na̱da̱kuíꞌino ñaá rá dáꞌo̱n míí ná. Dá ví ni̱ taó ñaá rá ndáka ra kuaꞌa̱n ra̱ chirkaa ra ndi̱ka cruz. 
\s1 Diꞌa ni̱ kuu tá ni̱ chi̱rkaa ra Jesús ndi̱ka cruz 
\p  
\v 21 Ta noo̱ ndáka ñaá rá kuaꞌa̱n ra̱, ñoó ni̱ na̱kiꞌin táꞌan ra xíꞌín iin ta̱a naní Simón, ta̱ kuendá Cirene. Ta de̱ꞌe ra naní Alejandro xíꞌín Rufo. Ta̱ yóꞌo kúú ra̱ ko̱ndii ni̱ saꞌa̱n yúku̱. Kúú ni̱ kendúsa̱ soldado xíꞌín rá ña̱ ná kado̱kó ra̱ cruz Jesús koꞌo̱n ra̱.  
\v 22 Ta ndáka ñaá rá ni̱ saa̱ ra̱ iin xíán noo̱ naní Gólgota. To̱ꞌon yóꞌo kóni̱ kaa yikí lásá dini̱ ndi̱i. 
\p  
\v 23 Ñoó, dá ni̱ xi̱ꞌo ra vino ni̱ da̱taká táꞌan xíꞌín ndutá ova̱ koꞌo Jesús, tído ko̱ ní xíin taꞌon na koꞌo na ra̱.  
\v 24 Dá tá ni̱ ndiꞌi ni̱ chi̱rkaa ñaá rá ndi̱ka cruz, dá ni̱ sa̱ ndei ra ni̱ sa̱dikí ra̱ suerte xíꞌín dáꞌo̱n ná, dá ná kande̱ꞌá ndi ndáa dáꞌo̱n kánian niꞌi̱ iin rá iin ra. 
\p  
\v 25 Táto̱ꞌon ka̱ ii̱n dataa̱n ni̱ chi̱rkaa ra Jesús ndi̱ka cruz.  
\v 26 Ta ndáꞌa̱ iin tabla dini̱ cruz ñoó, ta káꞌa̱n ndá saꞌa̱ kía̱n tákaa na ñoó. Ta diꞌa kaáa̱n: “Ta̱a yóꞌo kúú rey no̱ó na̱ Israel.”  
\v 27 Dá ni̱ chi̱rkuei taꞌani ra uu̱ ta̱ kui̱ꞌíná ndi̱ka dao ka̱ cruz. Iin ra tákaa xoo kuáꞌa na̱, ta iin ka̱ ra̱ tákaa xoo íti na̱.  
\v 28 Ta xíꞌín ña̱ yóꞌo dá ni̱ xi̱nko̱o noo̱ káꞌa̱n tuti ii̱ Ndios, chi̱ diꞌa kaáa̱n: “Ni̱ na̱da̱kíꞌin táꞌan dáó ñaá rá xíꞌín ta̱ kómí kua̱chi.” 
\p  
\v 29 Ta ña̱yuu chíkaꞌanda kuaꞌa̱n noo̱ tákaa Jesús ñoó kédi̱ki ñaá ná, ta kaó na̱ dini̱ ná kénóo na Jesús, ta kaá na̱: 
\p ―¡Maáki̱ ri̱! Kaá yo̱ꞌó ña̱ nakani ndiꞌón veꞌe ño̱ꞌo káꞌano Ndios. Ta kúú ti̱xi oni̱ va kuu̱ nduva̱ꞌón ña̱, kaáo̱n.  
\v 30 Ño̱ó nda̱ni, dáka̱ki miíón viti. Kuaꞌán noo kíi̱ ndi̱ka cruz xaa̱n ná kande̱ꞌá. 
\p  
\v 31 Ta dión taꞌani kédi̱ki ñaá ta̱ duti̱ sakua̱ꞌa̱ xíꞌín ta̱a dánaꞌa̱ ley Moisés, ta ndátóꞌón rá ndíta rá: 
\p ―Dao ka̱ va ña̱yuu sa̱ ka̱ndeé rá sa̱ da̱káki ra, tído ko̱ kándeé taꞌon ra dáka̱ki ra mií rá viti.  
\v 32 ¡Kaá ra̱ ña̱ kúú rá Cristo, na̱ dáka̱ki ñaá! ¡Ta kaá ra̱ ña̱ kúú rá rey no̱ó na̱ ñoo yo̱! ¡Ná noo kíi̱ rá ndi̱ka cruz káa, dá ná nakoni yo̱ rá, dá ná kandísa yó ra̱! ―ka̱á ra̱ ndíta ra. 
\p Ta kána̱ꞌá taꞌani nda̱ uu̱ ta̱a tákuei iin iin xoo díi̱n ná ñóó xíꞌín ná. 
\s1 Diꞌa ni̱ kuu tá ni̱ xiꞌi̱ Jesús 
\p  
\v 33 Tá ni̱ kasa̱ndaá ka̱xuu̱, dá ni̱ na̱kuíi̱n naá iin níí kúú ñayuú nda̱ ka̱ oni̱ sa̱ꞌini.  
\v 34 Dá tá ni̱ kasa̱ndaá ka̱ oni̱ ñoó, kúú ni̱ꞌi nda̱ꞌo ni̱ ka̱yuꞌú Jesús, ta kaá na̱: 
\p ―Eloi, Eloi, ¿lama sabactani? ―To̱ꞌon yóꞌo kía̱n kóni̱ kaa: Ndios miíi̱, Ndios miíi̱, ¿ndiva̱ꞌa ni̱ da̱yáa̱ ndáꞌa̱ ní yuꞌu̱? 
\p  
\v 35 Tá ni̱ sei̱do̱ꞌo dao ka̱ ta̱a ndíta ñoó ña̱ ni̱ kaꞌa̱n na̱ dión, dá ni̱ kaa ra̱: 
\p ―Kueídóꞌo ndó, chi̱ kána ra profeta Elías. 
\p  
\v 36 Kúú ni̱ ka̱nkono iin ta̱a ni̱ saꞌa̱n ra̱ ni̱ da̱ndáxi ra iin táꞌí dáꞌo̱n xíꞌín vino iá. Dá ni̱ soꞌoni ra̱án dini̱ iin ta̱ñi̱í. Dá ni̱ chi̱rnee raa̱n yúꞌu̱ Jesús, dá ná koꞌo na ra̱. Dá ni̱ kaa ra̱: 
\p ―Ná dáꞌa ni kee ndo dión. Ná kandati yó, dá ná kande̱ꞌá á kasaa̱ Elías dánóo ñaá ná ―kaá ra̱. 
\p  
\v 37 Ta kúú ni̱ꞌi nda̱ꞌo ni̱ ka̱yuꞌú Jesús, dá ni̱ xiꞌi̱ na̱.  
\v 38 Ta kúú mií dáá vá ni̱ ndata̱ dao dáꞌo̱n tákaa ndadí ini veꞌe ño̱ꞌo káꞌano. Ni̱ keean nda̱ yúꞌa̱n ni̱no, ta kúú nda̱ yúꞌa̱n nino̱ ni̱ xino̱ no̱ó ni̱ ndata̱ ñá. 
\p  
\v 39 Ta mií ta̱a dándáki soldado íin noo̱ tákaa Jesús ñoó. Kúú ni̱ xini ra̱ táto̱ꞌon ni̱ ka̱yuꞌú ná tá ni̱ xiꞌi̱ na̱, dá ni̱ kaa ra̱: 
\p ―¡Miía̱n ndaa̱ ndisa de̱ꞌe Ndios ni̱ sa̱ kuu ta̱a yóꞌo! 
\p  
\v 40 Ta xíká vá ndíta dao na̱ ñáꞌa̱ ndéꞌé ná ña̱ ni̱ ndoꞌo Jesús. Ta tein no̱ón nákaa̱ María Magdalena, xíꞌín María naná José xíꞌín Jacobo, ta̱ lóꞌo̱ cháá ka̱. Nákaa̱ taꞌani iin ka̱ ñáꞌa̱ naní Salomé.  
\v 41 Ta na̱ ñáꞌa̱ yóꞌo kúú na̱ ni̱ sa̱ xi̱onoo xíꞌín Jesús, ta sa̱ chi̱ndeé ñaá ná tá ni̱ sa̱ io na̱ chí kuendá Galilea. Ta ndéi kuaꞌa̱ taꞌani dao ka̱ na̱ ñáꞌa̱ tákuei Jesús ni̱ saa̱ na̱ ñoo Jerusalén. 
\s1 Diꞌa ni̱ kuu, dá ni̱ ndu̱xi Jesús 
\p  
\v 42 Sa̱ ni̱ ini va kuu̱ dáá, ña̱ kía̱n mií kuu̱ kénduu na̱ Israel ña̱ꞌa keí ná taa̱n, chi̱ sa̱ kuaꞌa̱n kasandaá va kuu̱ nániꞌi̱ ndée̱ ná.  
\v 43 Ió iin ta̱a naní José, ta kúú rá ta̱ ñoo Arimatea. Ta kúú rá iin ta̱a ndáya̱ꞌi tein ta̱ néꞌe choon no̱ó na̱ Israel. Ta ndáti taꞌani ra ña̱ kasaa̱ Ndios dándáki na ñayuú yóꞌo. Ro̱ón kúú ra̱ ni̱ xi̱ꞌo ndeé iní ni̱ ku̱ꞌu ra noo̱ nákaa̱ Pilato. Dá ni̱ xika̱ ra̱ noo̱ Pilato ña̱ ná naki̱ꞌo ra yikí ko̱ño Jesús noo̱ rá.  
\v 44 Kúú ni̱ naá vá iní Pilato tá ni̱ ka̱ndaa̱ ini ra̱ ña̱ sa̱ ni̱ xiꞌi̱ va Jesús. Dá ni̱ kana ra ta̱ dándáki soldado ñoó. Dá ni̱ nda̱to̱ꞌón ñaá rá, á ndaa̱ ña̱ sa̱ ni̱ xiꞌi̱ va na.  
\v 45 Dá ni̱ kaa ta̱ dándáki soldado ñoó ña̱ sa̱ ni̱ xiꞌi̱ va na. Dá ni̱ saꞌanda Pilato choon ña̱ ná naki̱ꞌo ra yikí ko̱ño Jesús noo̱ José.  
\v 46 Dá ni̱ saꞌa̱n José ñoó ni̱ xiin na iin sábana sa̱á. Dá ni̱ da̱nóo ra yikí ko̱ño Jesús ndi̱ka cruz. Dá ni̱ na̱chi̱tuú ñaá rá xíꞌín sábana ñoó. Dá ni̱ saꞌa̱n ra̱ ni̱ chi̱káa̱ ñaá rá ini iin yái̱ káꞌano ni̱ ka̱va̱ꞌa ndi̱ka iin káo̱. Dá ni̱ da̱kui̱ó tuú ra̱ iin yuu̱ chi̱káꞌano ni̱ sadi ra̱ yéꞌán.  
\v 47 Ta ni̱ xini va María Magdalena xíꞌín María naná José no̱ó ni̱ chi̱káa̱ ñaá rá. 
\c 16  
\s1 Diꞌa ni̱ kuu tá ni̱ na̱taki Jesús 
\p  
\v 1 Tá ni̱ ya̱ꞌa kuu̱ nániꞌi̱ ndée̱ na̱ Israel, dá ni̱ saꞌa̱n María Magdalena, xíꞌín Salomé, xíꞌín María naná Jacobo ni̱ xiin na ndutá támi sáꞌa̱n kaneꞌe na koꞌo̱n na̱ chiꞌi na yikí ko̱ño Jesús, káꞌán ná.  
\v 2 Ta naꞌa va̱ꞌa kuu̱ mií no̱ó kásáꞌá saꞌa̱ semana, dá ni̱ kee na kuaꞌa̱n na̱ yái̱ noo̱ nákaa̱ yikí ko̱ño Jesús. Ta kúú du̱ú ni̱ xi̱nko̱o va ndi̱ndii.  
\v 3 Ta kúú ndátóꞌón ná kuaꞌa̱n na̱ íchi̱ ñoó, ta kaá na̱: 
\p ―¿Ndá yoo ví niꞌi̱ yo̱ di̱tá yuu̱ ndadí yúꞌu̱ yái̱ ñoó? 
\p  
\v 4 Tído tá ni̱ saa̱ yati na, kúú ni̱ xini va na ña̱ sa̱ ni̱ ku̱xoo va yuu̱ káꞌano ni̱ sa̱ ndadi yúꞌu̱ yái̱ ñoó.  
\v 5 Dá tá ni̱ ku̱ꞌu na inia̱n, kúú ni̱ xini na̱ ió iin tayií chí xoo kuáꞌa diꞌa. Ta ndíxi xi iin dáꞌo̱n kuxí chi̱káni̱. Ta kúú ni̱ yu̱ꞌú nda̱ꞌo na̱ ñáꞌa̱ ñoó.  
\v 6 Dá ni̱ kaa xi̱ xíꞌín ná: 
\p ―Ná dáꞌa ni yu̱ꞌú ndo̱, chi̱ sa̱ náꞌá váí ña̱ nándukú ndó Jesús, na̱ ñoo Nazaret, na̱ ni̱ sa̱rkaa ndi̱ka cruz. Tído ni̱ na̱taki va na. Kande̱ꞌé ndó no̱ó ni̱ chi̱nóo ñaá rá. Ko̱ó ka̱ na̱ nákaa̱ yóꞌo.  
\v 7 Kuaꞌán kíi̱ ndo̱ kasto̱ꞌon ndó xíꞌín Pedro, xíꞌín dao ka̱ ta̱a xíonoo xíꞌín ná ña̱ kuió no̱ó Jesús koꞌo̱n na̱ noo̱ rá chí Galilea diꞌa. Ta nda̱ ñoó ví, dá koni ñaá rá táto̱ꞌon ki̱ꞌo ni̱ sa̱ kaꞌa̱n na̱ xíꞌín rá ―kaá ángel ñoó. 
\p  
\v 8 Dá ni̱ ka̱nkuei na yái̱ ñoó taxí táꞌan na kuaꞌa̱n na̱. Kúú nda̱á ndéi̱ ni̱no oon na kuaꞌa̱n na̱, chi̱ ni̱ yu̱ꞌú nda̱ꞌo na. Ño̱ó nda̱ni ko̱ ní nákani na xíꞌín ni iin tóꞌón ña̱yuu íchi̱ no̱ó kuaꞌa̱n na̱ ñoó. 
\s1 Diꞌa ni̱ kuu tá ni̱ naꞌa̱ noo̱ Jesús noo̱ María Magdalena 
\p  
\v 9 Tá ni̱ na̱taki Jesús naꞌa kuu̱ dáá ñóó, ña̱ kúú kuu̱ mií no̱ó kásáꞌá saꞌa̱ semana, dá ni̱ naꞌa̱ noo̱ ná dinñóꞌó noo̱ María Magdalena, táꞌa̱n ñá ni̱ sa̱ ñoꞌo usa̱ espíritu kini ni̱ taó ná ñoó.  
\v 10 Dá ni̱ keeán kuaꞌa̱n noo̱ ndéi ta̱a xíonoo xíꞌín ná. Tá ni̱ saa̱a̱n noo̱ ndéi ra, ndaꞌí ndéíꞌi̱ rá ndéi ra. Dá ni̱ ka̱sto̱ꞌán xíꞌín rá ña̱ ni̱ xinia̱n Jesús.  
\v 11 Tá ni̱ sei̱do̱ꞌo ra ña̱ ni̱ na̱taki Jesús, chi̱ sa̱ ni̱ xini va ñaá ñáꞌa̱ ñoó, kúú ko̱ ní kándísa taꞌon ñaá rá. 
\s1 Diꞌa ni̱ kuu tá ni̱ naꞌa̱ noo̱ Jesús no̱ó uu̱ ta̱a xíonoo xíꞌín ná 
\p  
\v 12 Tá ni̱ ndiꞌi ñoó, dá ni̱ naꞌa̱ noo̱ Jesús no̱ó uu̱ ta̱a xíonoo xíꞌín ná noo̱ xíka ra kuaꞌa̱n ra̱ íchi̱ kuaꞌa̱n chí yúku̱. Tído sa̱ ni̱ na̱da̱on va na to̱ꞌon sa̱ kaa na.  
\v 13 Tído tá ni̱ na̱koni ñaá rá, dá ni̱ saꞌa̱n ra̱ ni̱ ka̱sto̱ꞌon ra xíꞌín dao ka̱ ta̱a xíonoo xíꞌín ná ñoó. Tído kúú tuku va ko̱ ní xíin ro̱ón kandísa ra. 
\s1 Diꞌa ni̱ kuu tá ni̱ xi̱ꞌo Jesús choon no̱ó ta̱ xíonoo xíꞌín ná 
\p  
\v 14 Tá ni̱ ndiꞌi ñoó, dá ví ni̱ naꞌa̱ noo̱ Jesús noo̱ ndin uxi̱ iin ta̱ xíonoo xíꞌín ná noo̱ ndéi ra sásáꞌan ra. Dá ni̱ da̱náni ñaá ná sa̱ꞌá ña̱ ko̱ ní kándísa ra xíꞌín sa̱ꞌá ña̱ káxí nío̱ rá, chi̱ ko̱ ní xíin ra kandísa ra ña̱ ni̱ xini dao ka̱ ña̱yuu ñoó ña̱ ni̱ na̱taki na̱.  
\v 15 Dá ni̱ kaa na̱ xíꞌín rá: 
\p ―Kuaꞌán ndo̱ kanoo ndó iin níí kúú ñayuú dánaꞌa̱ ndo̱ sa̱ꞌá to̱ꞌon va̱ꞌa ña̱ káꞌa̱n sa̱ꞌí noo̱ ndidaá kúú ña̱yuu.  
\v 16 Ta ndi ndáa na̱ ni̱ ka̱ndísa ñaá, ta ni̱ sodo̱ ndúta̱ ná, no̱ón kúú na̱ dáka̱ki Ndios. Tído na̱ ko̱ ní xíin kandísa to̱ꞌon va̱ꞌa yóꞌo, no̱ón kúú na̱ kando̱o kakomí kua̱chi noo̱ Ndios.  
\v 17 Ta ña̱yuu ni̱ ka̱ndísa to̱ꞌon va̱ꞌa yóꞌo, no̱ón kúú na̱ ni̱ꞌí ña̱ kandeé ná kee na ña̱ náꞌano. Chi̱ xíꞌín kuu̱ yuꞌu̱ kandeé ná taó ná espíritu kini ñóꞌo ini ña̱yuu. Ta kati̱ꞌa na kaꞌa̱n na̱ dao ka̱ yúꞌu̱, ña̱ ko̱ ní dákuáꞌa na.  
\v 18 Ta va̱ꞌará ni̱ tiin ndakána na iin koo̱, ta kúú ko̱ ta̱ꞌón ña̱ꞌa ndoꞌo na kee rí. Ta va̱ꞌará ni̱ xiꞌi ndakána na iin ña̱ꞌa dee̱n, ta kúú ko̱ ta̱ꞌón ña̱ꞌa ndoꞌo na keean. Tá ná chinóo na ndáꞌa̱ ná sa̱tá na̱ kúꞌu̱, ta kúú nduva̱ꞌa va na ―kaá Jesús. 
\s1 Diꞌa ni̱ kuu tá ni̱ nana Jesús kuaꞌa̱n nóꞌo̱ ná induú 
\p  
\v 19 Tá ni̱ ndiꞌi ni̱ kaꞌa̱n satoꞌo yo̱ Jesús to̱ꞌon yóꞌo, dá ni̱ kee na ko̱nana na kuaꞌa̱n nóꞌo̱ ná induú. Kúú ni̱ na̱ko̱o na xoo kuáꞌa Ndios. 
\p  
\v 20 Dá ni̱ kee ta̱a xíonoo xíꞌín ná ñóó kuaꞌa̱n ra̱ dánaꞌa̱ ra̱ to̱ꞌon va̱ꞌa sa̱ꞌá Jesús ndidaá kúú ñoo. Ta kúú sa̱ chi̱ndeé vá ñaá míí satoꞌo yo̱ Jesús, ta ni̱ naꞌa̱ na̱ ña̱ ndaa̱ kía̱n ni̱ kaꞌa̱n ra̱, chi̱ ni̱ xi̱ꞌo na ña̱ kandeé rá kee ra ña̱ꞌa ndato. Dión ná koo.