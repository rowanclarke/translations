\c 1  
\s1 Poei-oep Boeih  
\p
\v 1 \w Jerusalem|strong="H3389"\w* \w manghai|strong="H4428"\w* \w David|strong="H1732"\w* \w capa|strong="H1121"\w* kah \w thuituenkung|strong="H6953"\w* \w ol|strong="H1697"\w*.  
\v 2 A \w honghi|strong="H1892"\w*, a \w honghi|strong="H1892"\w* ni. \w Thuituenkung|strong="H6953"\w* loh, “A \w honghi|strong="H1892"\w*, a \w honghi|strong="H1892"\w*, a \w honghi|strong="H1892"\w* \w boeih|strong="H3605"\w* ni,” a \w ti|strong="H0559"\w*.  
\v 3 \w Khohmik|strong="H8121"\w* \w hmuiah|strong="H8478"\w* a \w thakthae|strong="H5998"\w* \w bangla|strong="H7578"\w* \w a|strong="H9909"\w* \w thakthaenah|strong="H5999"\w* \w cungkuem|strong="H3605"\w* \w lamloh|strong="H9996"\w* \w hlang|strong="H0120"\w* \w taengah|strong="H9997"\w* \w balae|strong="H4100"\w* a \w rhoeikhangnah|strong="H3504"\w*.  
