\id ISA  
\h  ĽIsaia 
\toc1 Ko E Tohi  Ľae PalŇćfita Ko  ĽIsaia 
\toc2  ĽIsaia 
\toc3  ĽIsa 
\mt2 KO E TOHI  
\mt3  ĽAE PALŇĆFITA KO  
\mt1  ĽISAIA  
\cl KO E VAHE  
\c 1  
\cd \it 1  ĽOku lńĀunga  Ľa  ĽIsaia  Ľi he angatu Ľu  Ľa Siuta. 5 Pea tangi ia  Ľi he Ľenau mamahi. 10  ĽOku ne valoki Ľi  Ľenau ngńĀue kotoa pńď. 16  ĽOku ne enginaki  Ľaki  Ľae ngaahi tala Ľofa mo ne faka Ľilo  Ľae houhau ke nau fakatomala. 21  ĽI he Ľene mamahi koe Ľuhi ko  Ľenau angakovi,  Ľoku ne fakahńĀ  Ľae ngaahi fakamaau  Ľae  ĽOtua. 25  ĽOku ne faka Ľilo  Ľae  Ľofa, 28 Mo ne fakahńĀ  Ľae faka Ľauha ki he angakovi.\it*  
\p
\v 1 Ko e me Ľa na Ľe hńĀ mai kia  ĽIsaia koe foha  Ľo  ĽAmosi,  Ľaia na Ľa ne mamata  Ľoku kau ki Siuta mo SelŇęsalema  Ľi he ngaahi  Ľaho  Ľo  ĽUsia, mo Sotame, mo  ĽAhasi, pea mo Hesekaia, koe ngaahi tu Ľi  Ľo Siuta.   
\q1
\v 2 Mou fanongo,  Ľae ngaahi langi,  
\q2 pea fakafanongo mo mńĀmani:  
\q2 he  Ľoku folofola  Ľa Sihova,  
\q1 ‚ÄúKuo u fafanga mo tauhi  Ľae fńĀnau,  
\q2 pea kuo nau angatu Ľu kiate au.   
\q1
\v 3 ‚ÄĆ ĽOku  Ľilo  Ľe he pulu  Ľaia  Ľoku  Ľa Ľana ia,  
\q2 pea mo e  Ľasi  Ľae fale manu  Ľo  Ľene  Ľeiki:  
\q2 ka  Ľoku  Ľikai  Ľilo  Ľe  ĽIsileli,  
\q2  Ľoku  Ľikai tokanga  Ľa hoku kakai.‚ÄĚ   
\q1
\v 4 Oiau!  ĽAe pule Ľanga angakovi,  
\q2 ko e kakai mńĀfasia  Ľi he hia,  
\q2 ko e hako fai me Ľa kovi,  
\q2 ko e fńĀnau  Ľoku fakahala:  
\q1 kuo nau li Ľaki  Ľa Sihova,  
\q2 kuo nau fakahouhau Ľi  Ľae tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli,  
\q2 kuo nau fakaholomui.   
\q1
\v 5 Ko e hńĀ  Ľe toe te Ľia ai  Ľakimoutolu?  
\q2  ĽE tupulaki pe ho Ľomou angatu Ľu:  
\q1  Ľoku mahaki  Ľae  Ľulu kotoa pńď,  
\q2 pea vaivai mo e loto kotoa pńď.   
\q1
\v 6 Mei he  Ľaofi va Ľe  Ľo a Ľu ki he  Ľulu  Ľoku  Ľikai ha haohaoa  Ľi ai;  
\q2 ka ko e lavea, mo e volu, mo e pala kovi:  
\q2  Ľoku te Ľeki ai fakama Ľopo, pe nono Ľo, pe fe Ľauaki  Ľae lolo faito Ľo.   
\q1
\v 7 Kuo lala homou fonua,  
\q2 kuo vela homou ngaahi kolo  Ľi he afi:  
\q2 pea ko homou fonua,  
\q2  Ľoku kai  Ľo  Ľosi  Ľe he kakai muli  Ľi homou  Ľao,  
\q2 pea  Ľoku lala ia,  
\q2  Ľo hangńď kuo faka Ľauha  Ľe he kau muli.   
\q1
\v 8 Pea kuo tuku  Ľae  Ľofefine  Ľo Saione  Ľo hangńď ko e fale si Ľi  Ľi he ngoue vaine,  
\q2  Ľo hangńď ko e fale le Ľo  Ľi he ngoue kukumipa,  
\q2  Ľo hangńď ko e kolo kuo kńĀpui  Ľe he tau.   
\q1
\v 9 Ka ne  Ľikai tuku kiate kitautolu  Ľe Sihova  Ľoe ngaahi kautau ha tokosi Ľi,  
\q2 pehńď, kuo tau hangńď ko Sotoma,  
\q2 pea kuo tau tatau mo Komola.   
\q1
\v 10 Fanongo ki he folofola  Ľa Sihova,  Ľakimoutolu  Ľae kau pule  Ľo Sotoma;  
\q2 fakafanongo ki he fono  Ľa hotau  ĽOtua,  Ľakimoutolu ko e kakai  Ľo Komola.   
\q1
\v 11 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚ÄúKo e hńĀ hono  Ľaonga  Ľo ho Ľomou ngaahi feilaulau lahi kiate au?  
\q2 Kuo u fiu  Ľi he feilaulau  Ľaki  Ľae fanga sipitangata, mo e ngako  Ľoe manu sino;  
\q2 pea  Ľoku  Ľikai te u fiemńĀlie  Ľi he toto  Ľoe fanga pulu,  
\q2 pe ko e fanga lami,  
\q2 pe ko e fanga kosi tangata.   
\q1
\v 12 ‚ÄĆ ĽOka mou ka ha Ľu ke fakahńĀ  Ľakimoutolu  Ľi hoku  Ľao,  
\q2 ko hai kuo ne fekau ke  Ľomi  Ľae me Ľa ni  Ľi homou nima, ke malaki hoku ngaahi potu tapu?   
\q1
\v 13 ‚ÄĆ ĽOua na Ľa toe  Ľomi  Ľae ngaahi feilaulau ta Ľe Ľaonga;  
\q2 ko e me Ľa fakalielia kiate au  Ľae tutu  Ľoe  Ľakau namu lelei;  
\q2 ko e ngaahi mńĀhina fo Ľou mo e ngaahi  Ľaho tapu, mo e ui ke fakataha,  Ľoku  Ľikai te u fa Ľa kńĀtaki;  
\q2 pea na Ľa mo e fakataha ke lotu ko e angahala ia.   
\q1
\v 14 ‚ÄĆ ĽOku fehi Ľa  Ľa hoku laumńĀlie ki ho Ľomou ngaahi mńĀhina fo Ľou mo ho Ľomou ngaahi kńĀtoanga:  
\q2 ko e me Ľa fakamamahi ia kiate au;  
\q2 kuo u fiu  Ľi hono kńĀtaki.   
\q1
\v 15 ‚ÄĆ ĽOka mou ka mafao homou nima, te u fufŇę hoku fofonga  Ľiate kimoutolu:  
\q2  Ľio,  Ľoka mou ka hŇę  Ľo liunga lahi,  Ľe  Ľikai te u fanongo:  
\q2 he  Ľoku pito homou nima  Ľi he toto.   
\q1
\v 16 ‚ÄúFufulu  Ľakimoutolu,  Ľo ngaohi ke mou ma Ľa;  
\q2 hiki ke mama Ľo meiate au  Ľae kovi  Ľo ho Ľomou faianga;  
\q2 tuku  Ľae fai kovi;   
\q2
\v 17 ‚ÄĆ ĽAko ke mou fai lelei:  
\q2 kumi ki he angatonu,  
\q2 tokoni  Ľakinautolu kuo fakamńĀlohia,  
\q2 fakamaau ki he tamai mate,  
\q2 langomaki Ľi  Ľae fefine kuo mate hono husepńĀniti.‚ÄĚ   
\q1
\v 18 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚ÄúMou ha Ľu, pea ke tau alea fakataha:  
\q2 he neongo  Ľae tatau  Ľo ho Ľomou angahala mo e kula Ľaho Ľaho,  Ľe hoko ia ke hinehina  Ľo hangńď ko e  Ľuha hinaekiaki;  
\q2 kapau  Ľoku kulokula ia  Ľo hangńď ko e kulamŇęmŇę,  Ľe tatau ia mo e fulufulu Ľi sipi.   
\q1
\v 19 Kapau te mou loto ki ai mo talangofua,  
\q2 te mou kai hono lelei  Ľoe fonua:   
\q2
\v 20 Ka  Ľi ho Ľomou talangata Ľa mo angatu Ľu,  Ľe  Ľauha ai  Ľakimoutolu  Ľi he heletńĀ:  
\q2 he kuo folofola pehńď  Ľae fofonga  Ľo Sihova.‚ÄĚ   
\b  
\q1
\v 21 Hono  Ľikai liliu fau  Ľae kolo na Ľe angatonu ko e fa Ľa fe Ľauaki!  
\q2 Na Ľe fonu ia  Ľi he fakamaau; na Ľe nofo ai  Ľae mńĀ Ľoni Ľoni;  
\q2 ka  Ľoku  Ľi ai ni  Ľae kau fakapŇć.   
\q1
\v 22 Kuo hoko ho Ľo siliva ko e ta Ľe Ľaonga,  
\q2 mo ho Ľo uaine kuo hu Ľi  Ľaki  Ľae vai:   
\q1
\v 23 ‚ÄĆ ĽOku angatu Ľu homou hou Ľeiki, pea kaume Ľa mo e kau kaiha Ľa:  
\q2  Ľoku nau manako kotoa pńď ki he ngaahi foaki,  Ľonau muimui ki he totongi:  
\q2  Ľoku  Ľikai te nau fakamaau ki he tamai mate,  
\q2 pea  Ľoku  Ľikai a Ľu kiate kinautolu  Ľae mamahi  Ľae fefine kuo mate hono husepńĀniti.   
\q1
\v 24 Ko ia  Ľoku pehńď  Ľe he  ĽEiki,  
\q2 ko Sihova  Ľoe ngaahi kautau,  
\q1 ko e Toko Taha MńĀfimafi  Ľo  ĽIsileli,  
\q2 ‚Äú ĽIo, te u fakafiemńĀlie Ľi au  Ľiate kinautolu  Ľoku angatu Ľu mai,  
\q2 pea te u totongi  Ľe au ki hoku ngaahi fili.   
\q1
\v 25 Pea  Ľe toe ala hoku nima kiate koe,  
\q2 pea fakama Ľa mo Ľoni ho Ľo  Ľuli,  
\q2 pea  Ľave mo ho Ľo kovi kotoa pńď:   
\q1
\v 26 Pea te u toe fakanofo ho Ľo kau fakamaau  Ľo hangńď ko ia  Ľi mu Ľa,  
\q2 pea mo ho Ľo kau fakakaukau poto  Ľo hangńď ko ia  Ľi he kamata Ľanga:  
\q1 pea hili ia  Ľe ui koe, ‚ÄėKo e kolo mńĀ Ľoni Ľoni,  
\q2 ko e kolo angatonu.‚Äô   
\q1
\v 27 ‚ÄĆ ĽE huhu Ľi  Ľa Saione  Ľaki  Ľae fakamaau,  
\q2 mo  Ľene kakai ului  Ľaki  Ľae mńĀ Ľoni Ľoni.‚ÄĚ   
\q1
\v 28 Pea  Ľe faka Ľauha fakataha  Ľae kau talangata Ľa mo e angahala,  
\q2 pea  Ľe  Ľauha  Ľakinautolu  Ľoku li Ľaki  Ľa Sihova.   
\q1
\v 29 He te nau mńĀ  Ľi he ngaahi  Ľakau na Ľa mou holi ki ai,  
\q2 pea te mou puputu Ľu  Ľi he ngaahi ngoue kuo mou fili.   
\q1
\v 30 He te mou tatau mo e  Ľakau kuo mae hono lau,  
\q2 pea hangńď ko e ngoue  Ľoku  Ľikai hano vai.   
\q1
\v 31 Pea  Ľe tatau  Ľae mńĀlohi mo e kńĀkńĀ,  
\q2 pea mo  Ľene ngńĀue  Ľo hangńď ko e kalofiama,  
\q1 pea te na vela fakataha,  
\q2 pea  Ľe  Ľikai tńĀmate Ľi ia  Ľe ha tokotaha.‚ÄĚ   
\c 2  
\cd \it 1  ĽOku kikite  Ľa  ĽIsaia ki he hoko mai  Ľae pule Ľanga  Ľo Kalaisi. 6  ĽOku liaki  Ľe he  ĽOtua koe Ľuhi ko e angakovi. 18  ĽOku ne enginaki ke manavahńď, koe Ľuhi ko e ngńĀue mńĀlohi  Ľoe mńĀfimafi  Ľae  ĽOtua.\it*  
\p
\v 1 Ko e folofola na Ľe hńĀ mai kia  ĽIsaia ko e foha  Ľo  ĽAmosi  Ľoku kau ki Siuta mo SelŇęsalema.   
\q1
\v 2 Pea  Ľe hoko  Ľi he ngaahi  Ľaho  Ľamui,  Ľe fokotu Ľuma Ľu  Ľae mo Ľunga  Ľoe fale  Ľo Sihova  Ľi he tumutumu  Ľoe ngaahi mo Ľunga,  
\q2  Ľe hiki hake ia ke mńĀ Ľolunga  Ľi he ngaahi mo Ľunga;  
\q2 pea  Ľe tafe ki ai  Ľae ngaahi pule Ľanga kotoa pńď.   
\q1
\v 3 Pea  Ľe  Ľalu  Ľae kakai tokolahi mo nau pehńď,  
\q2 ‚ÄúMou ha Ľu, ke tau  Ľalu hake ki he mo Ľunga  Ľo Sihova,  
\q2 ki he fale  Ľoe  ĽOtua  Ľo Sńďkope;  
\q2 pea te ne akonaki Ľi  Ľakitautolu  Ľi hono ngaahi hala,  
\q2 pea te tau  Ľa Ľeva  Ľi hono ngaahi hala:  
\q1 koe Ľuhi  Ľe  Ľalu atu  Ľi Saione  Ľae fono,  
\q2 pea mo e folofola  Ľa Sihova mei SelŇęsalema.   
\q1
\v 4 Pea te ne fakamaau  Ľi he lotolotonga  Ľoe ngaahi pule Ľanga,  
\q2 mo ne valoki Ľi  Ľae kakai tokolahi:  
\q2 pea te nau tuki  Ľa  Ľenau ngaahi heletńĀ ko e ngaahi huo,  
\q2 pea mo honau ngaahi tao ko e ngaahi hele  Ľauhani:  
\q1  Ľe  Ľikai hiki  Ľe ha pule Ľanga  Ľae heletńĀ ki ha pule Ľanga,  
\q2 pea  Ľe  Ľikai te nau toe ako ki he tau.   
\b  
\q1
\v 5 ‚ÄĆ ĽAe fale  Ľo Sńďkope, mou ha Ľu, ke tau  Ľa Ľeva  Ľi he maama  Ľo Sihova.   
\q1
\v 6 Ko e mo Ľoni kuo ke li Ľaki ho Ľo kakai ko e fale  Ľo Sńďkope,  
\q2 koe Ľuhi kuo fakatokolahi  Ľakinautolu mei he potu hahake,  
\q2 pea  Ľoku ai honau kikite  Ľo hangńď ko e kakai Filisitia,  
\q2 pea  Ľoku nau fakafiemńĀlie Ľi  Ľakinautolu  Ľi he fńĀnau  Ľae kakai muli.   
\q1
\v 7 ‚ÄĆ ĽOku fonu foki  Ľa honau fonua  Ľi he siliva mo e koula,  
\q2 pea  Ľoku  Ľikai hano ngata Ľanga  Ľo  Ľenau koloa;  
\q1 pea  Ľoku fonu foki  Ľa honau fonua  Ľi he fanga hoosi,  
\q2 pea  Ľoku  Ľikai hano ngata Ľanga  Ľo  Ľenau saliote;   
\q1
\v 8 ‚ÄĆ ĽOku pito foki  Ľa honau fonua  Ľi he ngaahi tamapua;  
\q2  Ľoku nau lotu ki he ngńĀue  Ľa honau nima,  
\q2  Ľaia kuo ngaohi  Ľe honau louhi Ľi nima:   
\q1
\v 9 Pea  Ľoku punou  Ľae tangata lńĀuvale,  
\q2 pea mo e  Ľeiki  Ľoku ne fakavaivai ia:  
\q2 pea  Ľe  Ľikai te ke fakamolemole  Ľakinautolu.   
\q1
\v 10 Ke ke hŇę ki he  Ľana Ľi maka,  
\q2 mo fakafufŇę koe  Ľi he efu,  
\q1  Ľi he manavahńď kia Sihova,  
\q2 mo e nńĀunau  Ľo  Ľene mńĀfimafi.   
\q1
\v 11 ‚ÄĆ ĽE fakavaivai  Ľae mata laukau  Ľoe tangata,  
\q2 pea  Ľe fakahifo ki lalo mo e fielahi  Ľae kakai,  
\q2 ka ko Sihova pe  Ľe hiki hake  Ľi he  Ľaho ko ia.   
\q1
\v 12 He ko e  Ľaho  Ľo Sihova  Ľoe ngaahi kautau  Ľe hoko kiate kinautolu kotoa pńď  Ľoku laukau mo fielahi,  
\q2 pea kiate kinautolu kotoa pńď kuo hiki hake;  
\q2 pea  Ľe fakavaivai Ľi hifo ia:   
\q2
\v 13 Pea ki he ngaahi sita kotoa pńď  Ľo Lepanoni,  Ľoku hako mo mńĀ Ľolunga,  
\q2 pea ki he ngaahi oke kotoa pńď  Ľo Pesani,   
\q2
\v 14 Pea ki he ngaahi mo Ľunga mńĀ Ľolunga kotoa pńď,  
\q2 pea ki he ngaahi tafungofunga kotoa pńď kuo hiki hake,   
\q2
\v 15 Pea ki he ngaahi fale mńĀ Ľolunga kotoa pńď,  
\q2 pea ki he ngaahi puke kotoa pńď kuo  ĽńĀa Ľi,   
\q2
\v 16 Pea ki he ngaahi vaka kotoa pńď  Ľo Tasisi,  
\q2 pea ki he ngaahi me Ľa fakatńĀtńĀ kotoa pńď  Ľoku matamatalelei.   
\q1
\v 17 Pea  Ľe tuku hifo ai  Ľae fie Ľeiki  Ľae tangata,  
\q2 pea  Ľe fakavaivai Ľi mo e fielahi  Ľae kakai:  
\q2 ka ko Sihova pe  Ľe hiki hake  Ľi he  Ľaho ko ia.   
\q1
\v 18 Pea  Ľe faka Ľauha  Ľe ia  Ľae ngaahi tamapua kotoa pńď,   
\q1
\v 19 Pea te nau hŇę ki he ngaahi  Ľana maka,  
\q2 mo e ngaahi luo  Ľi he kelekele,  
\q2  Ľi he manavahńď kia Sihova,  
\q2 mo e nńĀunau  Ľo  Ľene mńĀfimafi,  
\q2  Ľoka tu Ľu hake ia ke lulu fakamanavahńď Ľi  Ľa mńĀmani.   
\q1
\v 20 ‚ÄĆ ĽI he  Ľaho ko ia  Ľe lńę  Ľe he tangata ki he ngaahi mole mo e fanga peka,  
\q2  Ľa  Ľene ngaahi tamapua siliva,  
\q2 mo  Ľene ngaahi tamapua koula,  
\q2  Ľaia na Ľe taki taha ngaohi ma Ľana ke lotu ki ai;   
\q1
\v 21 Ke nau  Ľalu ki he ngaahi  Ľana maka,  
\q2 pea mo e tumutumu  Ľoe ngaahi maka hangatńĀmaki,  
\q2  Ľi he manavahńď kia Sihova,  
\q2 pea mo e nńĀunau  Ľo  Ľene mńĀfimafi,  
\q2  Ľoka tu Ľu hake ia ke lulu fakamanavahńď Ľi  Ľa mńĀmani.   
\q1
\v 22 Tuku ho Ľomou falala ki he tangata,  Ľaia  Ľoku  Ľi hono ava Ľi ihu  Ľa  Ľene mńĀnava:  
\q2 he ko e hńĀ ha me Ľa  Ľoku fa Ľa fai  Ľe ia?   
\c 3  
\cd \it 1 Ko e maveuveu lahi  Ľoku hoko  Ľi he angahala, 9 Ko e pau Ľu  Ľae kakai. 12 Ko e fakamńĀlohi mo e manumanu  Ľae kau pule. 16 Ko e ngaahi tautea  Ľe hoko koe Ľuhi ko e laukau  Ľae kakai fefine.\it*  
\q1
\v 1 Vakai, he ko e  ĽEiki ko Sihova  Ľoe ngaahi kautau,  Ľoku ne to Ľo atu mei SelŇęsalema pea mo Siuta  Ľae falala Ľanga mo e tokoni,  
\q2  Ľae tokoni kotoa pńď  Ľoe me Ľakai,  
\q2 mo e tokoni kotoa pńď  Ľoe vai,   
\q1
\v 2 Ko e tangata mńĀlohi,  
\q2 pea mo e tangata tau,  
\q2 ko e fakamaau,  
\q2 pea mo e palŇćfita,  
\q2  Ľae fakamńĀkukanga,  
\q2 pea mo e mńĀtu Ľa,   
\q1
\v 3 Ko e  Ľeikitau  Ľae toko nimangofulu,  
\q2 pea mo e tangata ongoongolelei,  
\q2 pea mo e tangata akonaki poto,  
\q2 pea mo e tangata poto  Ľi he faiva,  
\q2 pea mo e tangata lea mńĀlie.   
\q1
\v 4 Pea te u fakanofo  Ľae tamaiki ko honau hou Ľeiki,  
\q2 pea  Ľe pule kiate kinautolu  Ľae kau valevale.   
\q1
\v 5 Pea  Ľe fefakamamahi Ľaki  Ľae kakai  Ľiate kinautolu,  
\q2 pea mo honau kaungńĀ Ľapi:  
\q1  Ľe anga fielahi  Ľae tamasi Ľi ki he motu Ľa,  
\q2 mo e angakovi kiate ia  Ľoku ongoongolelei.   
\q1
\v 6 Pea  Ľe puke  Ľe ha tangata  Ľa hono tokoua  Ľi he fale  Ľo  Ľene tamai,  
\q2  Ľo ne pehńď, ‚Äú ĽOku  Ľiate koe  Ľae ngaahi kofu,  
\q2 ke ke hoko ko homau pule,  
\q2 pea to Ľo  Ľe ho nima  Ľa  Ľemau mala Ľia ni:‚ÄĚ   
\q1
\v 7 ‚ÄĆ ĽI he  Ľaho ko ia te ne fuakava,  Ľo pehńď, ‚Äú ĽE  Ľikai te u hoko ko e fakamo Ľui;  
\q2 he  Ľoku  Ľikai ha mńĀ pe ha kofu  Ľi hoku fale:  
\q2  Ľoua na Ľa ngaohi au ko e pule  Ľoe kakai.‚ÄĚ   
\q1
\v 8 He kuo mala Ľia  Ľa SelŇęsalema, pea kuo hinga mo Siuta:  
\q2 he ko honau  Ľelelo mo  Ľenau faianga  Ľoku kovi kia Sihova,  
\q1 ke fakahouhau Ľi  Ľae fofonga  Ľo  Ľene  Ľafio.   
\q1
\v 9 Ko e anga  Ľo honau mata ko e faka Ľilonga  Ľonautolu;  
\q2 pea  Ľoku nau fakahńĀ  Ľa  Ľenau angahala  Ľo hangńď ko Sotoma,  
\q2  Ľoku  Ľikai te nau fufŇę ia.  
\q2  ĽE mala Ľia honau laumńĀlie!  
\q2 He kuo nau fakahoko  Ľae kovi kiate kinautolu.   
\q1
\v 10 Mou pehńď ki he mńĀ Ľoni Ľoni, ‚ÄúE hoko pe  Ľae lelei:‚Äô  
\q2 he te nau kai  Ľae fua  Ľo  Ľenau faianga.   
\q1
\v 11 ‚ÄĆ ĽE mala Ľia  Ľae angahala!  
\q2  ĽE hoko  Ľae kovi kiate ia:  
\q2 he ko e totongi  Ľo hono nima  Ľe ange kiate ia.   
\q1
\v 12 Ka ko hoku kakai, kuo fakamńĀlohi Ľi  Ľakinautolu  Ľe he tamaiki,  
\q2 pea  Ľoku pule Ľi  Ľakinautolu  Ľe he kau fefine.  
\q2  ĽE hoku kakai,  Ľoku fakahala Ľi koe  Ľe ho Ľo kau takimu Ľa,  
\q2  Ľonau fakakehe  Ľae  Ľalu Ľanga  Ľo ho ngaahi hala.   
\q1
\v 13 ‚ÄĆ ĽOku tu Ľu hake  Ľa Sihova ke folofola,  
\q2  Ľoku tu Ľu ia ke fakamaau  Ľae kakai.   
\q1
\v 14 ‚ÄĆ ĽE fakamaau  Ľe Sihova  Ľae kau mńĀtu Ľa  Ľo hono kakai,  
\q2 pea mo honau hou Ľeiki:  
\q2 ‚Äúhe kuo mou kai  Ľo  Ľosi  Ľae ngoue vaine;  
\q2  Ľoku  Ľi homou fale  Ľae koloa kuo fa Ľao mei he kakai masiva.   
\q1
\v 15 ‚ÄĆ ĽOku pehńď  Ľe Sihova ko e  ĽEiki  Ľoe ngaahi kautau,  
\q2 ‚ÄúKo e hńĀ hono  Ľuhinga  Ľo ho Ľomou ta Ľomia  Ľa hoku kakai,  Ľo momosi  Ľae mata  Ľoe masiva?‚ÄĚ   
\q1
\v 16 Pea  Ľoku pehńď  Ľe Sihova, ‚ÄúKoe Ľuhi  Ľoku fielahi  Ľae ngaahi  Ľofefine  Ľo Saione,  
\q2 mo nau  Ľa Ľeva fakamofutofuta mo e mata holi kovi,  
\q2 mo  Ľalu fakatekiteki pe,  
\q2 mo fakapakihi honau va Ľe:   
\q1
\v 17 Ko ia  Ľe taa Ľi  Ľe he  ĽEiki  Ľae tumu Ľaki  Ľoe ngaahi  Ľofefine  Ľo Saione  Ľaki  Ľae pala,  
\q2 pea  Ľe fakatelefua Ľi  Ľakinautolu  Ľe Sihova.‚ÄĚ   
\p
\v 18 ‚ÄĆ ĽI he  Ľaho ko ia  Ľe to Ľo  Ľe Sihova  Ľiate kinautolu  Ľae teunga tatangi  Ľo honau va Ľe, mo e me Ľa fau  Ľoe  Ľulu, mo  Ľenau teunga  Ľo hangńď ko e mńĀhina,  
\v 19 ‚ÄĆ ĽAe kahoa, pea mo e ngaahi vesa, pea mo e ngaahi pŇęlou,  
\v 20 ‚ÄĆ ĽAe ngaahi tatńĀ, pea mo e teunga  Ľo honau va Ľe, mo e ngaahi fua mo e  Ľai Ľanga kakala, pea mo e ngaahi hau ki honau telinga,  
\v 21 ‚ÄĆ ĽAe ngaahi mama, mo e teunga  Ľoe ihu,  
\v 22 Mo e tuului  Ľo honau kofu, pea mo e kofutu Ľa, pea mo e ngaahi pulupulu, pea mo e ngaahi kato pa Ľanga,  
\v 23 ‚ÄĆ ĽAe ngaahi sio Ľata, pea mo e kofu lineni, pea mo e ngaahi kofu  Ľoe  Ľulu, pea mo e ngaahi pŇęlou.   
\q1
\v 24 Pea  Ľe hoko  Ľo pehńď,  Ľe fetongi  Ľaki  Ľae namu kakala  Ľae namukŇę;  
\q2 pea  Ľe fetongi  Ľaki  Ľae no Ľo lelei  Ľae no Ľo mahae;  
\q2 pea  Ľe liliu  Ľae  Ľulu lau lelei ko e tula;  
\q2 pea  Ľe fetongi  Ľae kofu fatafata  Ľaki  Ľae kofu  Ľoe tauanga Ľa;  
\q2 pea  Ľe fetongi  Ľaki  Ľae hoihoifua  Ľae fohia  Ľi he la ĽńĀ.   
\q1
\v 25 ‚ÄĆ ĽE tŇć ho kau tangata  Ľi he heletńĀ,  
\q2 mo ho Ľo kau mńĀlohi  Ľi he tau.   
\q1
\v 26 Pea  Ľe mamahi mo tangi hono ngaahi matapńĀ;  
\q2 pea  Ľi he Ľene lala te ne nofo  Ľi he kelekele.   
\c 4  
\cd \it 1‚Äď6  ĽI he kovi lahi,  Ľe hoko  Ľae pule  Ľa Kalaisi ko e hŇęfanga.\it*  
\p
\v 1 Pea  Ľi he  Ľaho ko ia  Ľe puke  Ľe he fefine  Ľe toko fitu ki he tangata  Ľe tokotaha,  Ľonau pehńď, ‚ÄúTe mau kai  Ľemau mńĀ  Ľamautolu, pea kofu Ľaki homau ngaahi kofu: kae kehe ke ui  Ľakimautolu  Ľi ho hingoa, pea to Ľo atu ai homau manukia.‚ÄĚ   
\p
\v 2 ‚ÄĆ ĽI he  Ľaho ko ia  Ľe toulekeleka mo ongoongolelei  Ľae va Ľa  Ľo Sihova, pea  Ľe lelei lahi mo matamatalelei  Ľae fua  Ľoe fonua kiate kinautolu kuo hao  Ľi  ĽIsileli,  
\v 3 Pea  Ľe hoko  Ľo pehńď, ko ia kuo toe  Ľi Saione, pea mo ia  Ľoku nofo  Ľi SelŇęsalema,  Ľe ui ia ko e mńĀ Ľoni Ľoni,  Ľio, ko kinautolu kotoa pńď kuo tohi  Ľi he kakai mo Ľui  Ľo SelŇęsalema:  
\v 4 ‚ÄĆ ĽOka hili  Ľae fufulu  Ľe Sihova  Ľae  Ľuli  Ľoe ngaahi  Ľofefine  Ľo Saione, pea hili  Ľene fakama Ľa  Ľae toto  Ľo SelŇęsalema mei he lotolotonga  Ľo ia,  Ľaki  Ľae laumńĀlie  Ľoe fakamaau, pea mo e laumńĀlie  Ľoe vela.  
\v 5 Pea  Ľe fakatupu  Ľe Sihova  Ľi he nofo Ľanga kotoa pńď  Ľoe mo Ľunga ko Saione, pea ki hono ngaahi fakataha,  Ľae  Ľao mo e  Ľohuafi  Ľi he  Ľaho, pea mo e maama  Ľoe afi ulo  Ľi he pŇć: pea  Ľe fakamalu  Ľaki  Ľae nńĀunau  Ľae me Ľa kotoa pńď.  
\v 6 Pea  Ľe  Ľi ai  Ľae fale ko e malumalu Ľanga  Ľi he  Ľaho mei he pupuha, pea ko e potu hŇęfanga, pea ko e malu Ľanga mei he afńĀ mo e  Ľuha.   
\c 5  
\cd \it 1  ĽOku fakahńĀ  Ľe he  ĽOtua  Ľi he lea fakatńĀtńĀ ki he ngoue vaine  Ľoku totonu  Ľa  Ľene tautea fakamamahi. 8 Ko  Ľene tautea ki he manumanu, 11 Mo e holi kovi, 13 Mo e angakovi, 20 Pea mo e fai ta Ľetotonu. 26 Ko e ngaahi me Ľa  Ľoku tautea  Ľaki  Ľe he  ĽOtua.\it*  
\p
\v 1 ‚ÄúKo eni te u hiva ki hoku  Ľofa Ľanga  Ľaki  Ľae hiva,  Ľo ia  Ľoku ou mamana ki ai,  Ľoku kau ki he Ľene ngoue vaine.  
\q2  ĽOku ma Ľu  Ľe hoku  Ľofa Ľanga  Ľae ngoue vaine  Ľi he mo Ľunga kelekele mo Ľui:   
\q1
\v 2 Pea na Ľa ne  ĽńĀ Ľi ia,  
\q2 mo fetuku mei ai  Ľae ngaahi maka,  
\q2 pea ne tŇć  Ľi ai  Ľae ngaahi vaine lelei lahi,  
\q2 mo ne langa  Ľae fale le Ľo ki ai,  
\q2 pea na Ľe ngaohi foki  Ľi ai  Ľae tata Ľo Ľanga uaine:  
\q1 pea ne  Ľamanaki  Ľe tupu ai  Ľae ngaahi kńĀlepi,  
\q2 ka na Ľe tupu ai  Ľae kńĀlepi vao pe.   
\q1
\v 3 ‚ÄúPea ko eni  Ľae kakai  Ľo SelŇęsalema, mo e kau tangata  Ľo Siuta,  
\q2  Ľoku ou kŇćlenga ke mou fakamaau kiate au mo  Ľeku ngoue vaine.   
\q1
\v 4 Ko e hńĀ mo ha me Ľa  Ľe fa Ľa fai ki he Ľeku ngoue vaine,  Ľoku te Ľeki te u fai ki ai?  
\q2 Ko e hńĀ kuo u  Ľamanaki ki he tupu ai  Ľae ngaahi kńĀlepi, ka kuo tupu pe  Ľae fua kona?   
\q1
\v 5 Pea ko eni; te u fakahńĀ kiate kimoutolu  Ľaia te u fai ki he Ľeku ngoue vaine:  
\q2 te u to Ľo mei ai  ĽńĀ hono  ĽńĀ, pea  Ľe keina ia  Ľo  Ľosi;  
\q2 pea  Ľe holoki  ĽńĀ hono maka, pea  Ľe malaki hifo ia:   
\q1
\v 6 Pea te u li Ľaki ia:  
\q2  Ľe  Ľikai  Ľauhani ia, pe keli;  
\q2 ka e tupu  Ľi ai  Ľae ngaahi  Ľakau talatala:  
\q2 pea te u fekau foki ki he ngaahi  Ľao ke  Ľoua na Ľa  Ľuha ki ai.   
\q1
\v 7 He ko e ngoue vaine  Ľa Sihova  Ľoe ngaahi kautau, ko e fale  Ľo  ĽIsileli ia,  
\q2 pea ko e kau tangata  Ľo Siuta, ko  Ľene  Ľakau toulekeleka:  
\q2 pea na Ľa ne  Ľamanaki ki he fakamaau, kae vakai ko e fakamńĀlohi;  
\q2 ki he mńĀ Ľoni Ľoni, kae vakai ko e tangi.‚ÄĚ   
\q1
\v 8 ‚ÄĆ ĽE mala Ľia  Ľakinautolu  Ľoku fakahoko  Ľae fale ki he fale,  
\q2  Ľonau ai  Ľae  Ľapi ki he  Ľapi, ke  Ľoua na Ľa toe ha potu,  
\q2 koe Ľuhi ke mńĀ Ľolunga taha pe  Ľakinautolu  Ľi he fonua!   
\q1
\v 9 Na Ľe pehńď  Ľe Sihova  Ľoe ngaahi kautau ki hoku telinga, ‚ÄúKo e mo Ľoni  Ľe lahi  Ľae fale  Ľe lala,  
\q2  Ľio,  Ľe  Ľikai kakai  Ľae ngaahi fale lahi mo lelei.   
\q1
\v 10 He ko e ngoue vaine, ko e  Ľeka  Ľe hongofulu hono lahi,  Ľe ma Ľu mei ai  Ľae pate pe taha,  
\q2 pea ko e homa  Ľe taha  Ľoe tenga,  Ľe utu mei ai ha efa pe taha.‚ÄĚ   
\q1
\v 11 ‚ÄĆ ĽE mala Ľia  Ľakinautolu  Ľoku tu Ľu hengihengi hake, ke kumi ki he kava mńĀlohi;  
\q2 pea nofo  Ľo a Ľu ki he pŇć, kae Ľoua ke nau kona  Ľi he uaine!   
\q1
\v 12 Pea  Ľoku  Ľi he Ľenau ngaahi kńĀtoanga  Ľae ha Ľape, mo e vaiole, mo e lali, mo e mimiha, mo e uaine:  
\q2 ka  Ľoku  Ľikai te nau tokanga ki he ngńĀue  Ľa Sihova,  
\q2 pe vakai ki he ngńĀue  Ľa hono nima.   
\q1
\v 13 Ko ia kuo  Ľave pŇćpula ai  Ľa hoku kakai, koe Ľuhi  Ľoku  Ľikai  Ľiate kinautolu  Ľae  Ľilo:  
\q2 pea kuo fiekaia honau kau tangata ongoongo,  
\q2 pea mo honau tokolahi  Ľoku mate fieinu.   
\q1
\v 14 Ko ia kuo fakalahi ai  Ľa heli  Ľe ia,  
\q2 mo fakamanga lahi  Ľaupito hono ngutu:  
\q2 pea  Ľe  Ľalu hifo ki ai honau mńĀlohi, mo honau tokolahi, mo  Ľenau laukau, mo ia  Ľoku fiefia.   
\q1
\v 15 Pea  Ľe fakahifo ki lalo  Ľae lńĀuvale,  
\q2 pea  Ľe fakavaivai Ľi mo e tangata mńĀlohi,  
\q2 pea  Ľe hifo ki lalo  Ľae mata  Ľoe fielahi:   
\q1
\v 16 Ka e hiki hake  Ľa Sihova  Ľoe ngaahi kautau  Ľi he fakamaau,  
\q2 pea  Ľe fakaongoongolelei Ľi  Ľae  ĽOtua mńĀ Ľoni Ľoni  Ľi he angatonu.   
\q1
\v 17 Pea  Ľe toki kai  Ľae fanga lami  Ľo hangńď ko  Ľenau anga,  
\q2 pea  Ľe kai  Ľe he muli  Ľae ngaahi potu lala  Ľoe kakai koloa Ľia.   
\q1
\v 18 ‚ÄĆ ĽE mala Ľia  Ľakinautolu  Ľoku fusi  Ľae angahala  Ľaki  Ľae afo  Ľoe va Ľinga,  
\q2 pea fai hala  Ľo hangńď ko e maea mńĀlohi:   
\q1
\v 19 ‚ÄĆ ĽAkinautolu  Ľoku pehńď, ‚ÄúTuku ke ne fai vave, pea fakato Ľoto Ľo  Ľene ngńĀue, ke tau mamata ki ai:  
\q2 pea tuku ke  Ľunu Ľunu mai pea ha Ľu  Ľae tu Ľutu Ľuni  Ľae tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli,  
\q2 koe Ľuhi ke tau  Ľilo ki ai!‚ÄĚ   
\q1
\v 20 ‚ÄĆ ĽE mala Ľia  Ľakinautolu  Ľoku ui  Ľae kovi ko e lelei, mo e lelei ko e kovi;  
\q2  Ľoku ui  Ľae po Ľuli ko e maama,  
\q2 mo e maama ko e po Ľuli;  
\q1  Ľoku ui  Ľae kona ko e melie,  
\q2 mo e melie ko e kona!   
\q1
\v 21 ‚ÄĆ ĽE mala Ľia  Ľakinautolu  Ľoku poto  Ľi honau mata  Ľonautolu,  
\q2 mo kinautolu  Ľoku pehńď  Ľoku nau fai fakapotopoto!   
\q1
\v 22 ‚ÄĆ ĽE mala Ľia  Ľakinautolu  Ľoku mńĀlohi ke inu uaine,  
\q2 mo e kau tangata mńĀlohi ke felingi Ľaki  Ľae kava mńĀlohi:   
\q1
\v 23 ‚ÄĆ ĽAkinautolu  Ľoku fakatonuhia Ľi  Ľae angahala koe Ľuhi ko e totongi,  
\q2  Ľonau to Ľo  Ľae me Ľa totonu  Ľae mńĀ Ľoni Ľoni meiate ia!   
\q1
\v 24 Ko ia, hangńď  Ľoku keina  Ľe he afi  Ľae veve,  
\q2 pea faka Ľauha  Ľe he ulo afi  Ľae louveve,  
\q2  Ľe popo pehńď honau aka,  
\q2 pea  Ľe puna hake honau fisi  Ľo hangńď ko e efu:  
\q1 koe Ľuhi kuo nau li Ľaki  Ľae fono  Ľa Sihova  Ľoe ngaahi kautau,  
\q2 pea kuo nau fehi Ľa ki he folofola  Ľae tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli.   
\q1
\v 25 Ko ia kuo tupu ai  Ľae houhau  Ľo Sihova ki hono kakai,  
\q2 pea kuo ne mafao hono nima kiate kinautolu, pea kuo ne taa Ľi  Ľakinautolu:  
\q1 pea na Ľe tetetete  Ľae ngaahi mo Ľunga,  
\q2 pea na Ľe haehae honau  Ľanga Ľanga  Ľi he ngaahi hala  Ľoe kolo.  
\q1 Pea neongo  Ľa eni kotoa pńď  Ľoku te Ľeki ai ke ta Ľofi hono houhau,  
\q2 ka  Ľoku kei mafao hono nima.   
\q1
\v 26 Pea te ne hiki hake  Ľae fuka ki he ngaahi pule Ľanga mei he mama Ľo,  
\q2 pea te ne sese Ľe  Ľakinautolu mei he ngata Ľanga  Ľo mńĀmani:  
\q2 pea vakai te nau ha Ľu vave mo fakato Ľoto Ľo:   
\q1
\v 27 ‚ÄĆ ĽE  Ľikai vaivai pe humu ha taha  Ľiate kinautolu,  
\q2  Ľe  Ľikai ha taha  Ľe tulemohe pe mohe  
\q2 pea  Ľe  Ľikai vete  Ľae no Ľo  Ľi honau konga loto,  
\q2 pe motu  Ľae nono Ľo  Ľo honau topuva Ľe:   
\q1
\v 28 ‚ÄĆ ĽOku mńĀsila  Ľenau ngaahi ngahau,  
\q2 pea kuo teke  Ľenau kaufana kotoa pńď;  
\q1  Ľe fakatatau ki he maka afi  Ľae pesipesi  Ľo  Ľenau fanga hoosi,  
\q2 pea ko  Ľenau ngaahi saliote  Ľe hangńď ko e  Ľahiohio:   
\q1
\v 29 Te nau ngungulu  Ľo hangńď ko e laione,  
\q2 te nau ngungulu  Ľo hangńď ko e fanga laione mui,  
\q1  Ľio, te nau ngungulu,  
\q2 pea puke  Ľae me Ľakai, pea te nau vete ia,  
\q2 pea  Ľe  Ľikai ha taha te ne ta Ľofi.   
\q1
\v 30 Pea  Ľi he  Ľaho ko ia te nau tangi kiate kinautolu  Ľo hangńď ko e  Ľu Ľulu  Ľoe tahi:  
\q2 pea kapau  Ľoku sio ha tokotaha ki he fonua, vakai ko e fakapo Ľuli mo e mamahi,  
\q2 pea kuo fakapo Ľuli  Ľae maama  Ľi he langi.   
\c 6  
\cd \it 1 Ko e hńĀ mai  Ľae nńĀunau  Ľo Sihova kia  ĽIsaia. 5  ĽOku manavahńď ai ia, pea fakamńĀlohi ia ki he Ľene ngńĀue. 9  ĽOku ne fakahńĀ  Ľae paongata Ľa  Ľae kakai ki he Ľenau mala Ľia. 13 Ko e toenga kakai  Ľe mo Ľui.\it*  
\p
\v 1 ‚ÄĆ ĽI he ta Ľu na Ľe pekia ai  Ľae tu Ľi ko  ĽUsia ne u mamata kia Sihova  Ľoku  Ľafio  Ľi hono  Ľafio Ľanga, kuo mńĀ Ľolunga mo hiki hake, pea ko hono kofu tŇćtŇćlofa na Ľe fonu ai  Ľae falelotu lahi.  
\v 2 Pea na Ľe tu Ľu  Ľi  Ľolunga  Ľae Selafimi: na Ľe taki ono hona kapakau; na Ľa ne fakapulou  Ľaki hono mata  Ľae ua, pea ne  Ľufi Ľufi  Ľaki hono va Ľe  Ľae ua, pea ne puna  Ľaki  Ľae ua.  
\v 3 Pea na Ľa na lea fetńĀliaki,  Ľo pehńď,  
\q1 ‚Äú ĽOku mńĀ Ľoni Ľoni,  Ľoku mńĀ Ľoni Ľoni,  Ľoku mńĀ Ľoni Ľoni,  Ľa Sihova  Ľoe ngaahi kautau:  
\q2  Ľoku fonu  Ľa mńĀmani kotoa pńď  Ľi hono nńĀunau.‚ÄĚ   
\p
\v 4 Pea na Ľe ngaueue  Ľae ngaahi pou  Ľoe matapńĀ  Ľi he le Ľo  Ľo ia na Ľe ui, pea na Ľe fakafonu  Ľae fale  Ľi he  Ľohuafi.   
\p
\v 5 ¬∂ Pea ne u toki pehńď, ‚ÄúKuo u mala Ľia au! He kuo u  Ľauha; koe Ľuhi ko e tangata loungutu ta Ľema Ľa au, pea  Ľoku ou nofo  Ľi he lotolotonga  Ľoe kakai loungutu ta Ľema Ľa: he kuo mamata  Ľa hoku mata ki he Tu Ľi, ko Sihova  Ľoe ngaahi kautau.‚ÄĚ  
\v 6 Pea na Ľe toki puna mai  Ľae tokotaha  Ľoe Selafimi kiate au, na Ľe  Ľi hono nima  Ľae malala Ľi afi,  Ľaia na Ľa ne to Ľo  Ľaki  Ľae hikofi mei he feilaulau Ľanga.  
\v 7 Pea na Ľa ne ai ia ki hoku ngutu, mo ne pehńď, ‚ÄúVakai kuo tau  Ľae me Ľa ni ki ho loungutu; pea kuo to Ľo  Ľo  Ľave ho Ľo hia, pea kuo fakama Ľa ho Ľo angahala.‚ÄĚ  
\v 8 Pea ne u fanongo foki ki he le Ľo  Ľo Sihova, na Ľe pehńď, ‚ÄúKo hai te u fekau, pea ko hai  Ľe  Ľalu ma Ľamautolu?‚ÄĚ  
\p Pea ne u toki pehńď, ‚ÄúKo au eni; ke ke fekau au.‚ÄĚ   
\p
\v 9 ¬∂ Pea na Ľa ne pehńď, ‚Äú ĽAlu, pea tala ki he kakai ni,  
\q1  ĽOku mou fanongo mo Ľoni,  
\q2 kae  Ľikai ongo Ľi;  
\q1 pea  Ľoku mou mamata pau,  
\q2 kae  Ľikai  Ľilo Ľi.   
\q1
\v 10 Ngaohi ke fangapesi  Ľae loto  Ľoe kakai ni,  
\q2 pea ngaohi ke mamafa honau telinga,  
\q1 pea tńĀpuni honau mata;  
\q1 telia na Ľa nau mamata  Ľaki honau mata,  
\q2 pea fanongo  Ľaki honau telinga,  
\q2 pea  Ľilo  Ľaki honau loto,  
\q2 pea liliu, pea hoko  Ľo mo Ľui.‚ÄĚ   
\q1
\v 11 Pea ne u toki pehńď, ‚Äú ĽE Sihova,  Ľe fńďfńď hono fuoloa?‚ÄĚ  
\p Pea na Ľa ne pehńď mai,  
\q1 ‚ÄúKe  Ľoua ke lala  Ľae ngaahi kolo  Ľo  Ľikai ha tokotaha ke nofo ai,  
\q2 pea  Ľikai ha tangata  Ľi he ngaahi fale,  
\q2 pea lala  Ľaupito  Ľae fonua,   
\q2
\v 12 Pea ke  Ľoua ke  Ľave  Ľe Sihova  Ľae kakai,  
\q2 pea hoko  Ľae li Ľaki lahi ki he fonua.   
\q1
\v 13 Ka e  Ľi ai  Ľae vahe  Ľe hongofulu,  
\q2 pea  Ľe toe foki ia, pea  Ľe keina ia;  
\q1 ka e hangńď ko e  Ľakau ko e teili, pea hangńď ko e oke,  Ľoka tńĀ hifo  Ľoku kei tu Ľu hono aka:  
\q2  Ľe pehńď  Ľe hoko  Ľae hako mńĀ Ľoni Ľoni ko e aka  Ľoe pule Ľanga.‚ÄĚ   
\c 7  
\cd \it 1  ĽOku fakafiemńĀlie Ľi  Ľe  ĽIsaia  Ľa  ĽAhasi,  Ľi he Ľene puputu Ľu  Ľi he manavahńď kia Lesini mo Peka. 10 Kuo tuku kia  ĽAhasi ke fili ha faka Ľilonga, ka  Ľi he Ľene fakafisinga ki ai, na Ľa ne ma Ľu  Ľae faka Ľilonga, ko e tala Ľofa kia Kalaisi. 17  ĽOku fakahńĀ  Ľe ha Ľu hono tautea mei  ĽAsilia.\it*  
\p
\v 1 Pea na Ľe hoko  Ľo pehńď  Ľi he ngaahi  Ľaho  Ľo  ĽAhasi ko e foha  Ľo Sotame, ko e foha  Ľo  ĽUsia, ko e tu Ľi  Ľo Siuta, na Ľe  Ľalu hake ki SelŇęsalema,  Ľa Lesini ko e tu Ľi  Ľo Silia, mo Peka ko e foha  Ľo Lemalia, ko e tu Ľi  Ľo  ĽIsileli, ke tau Ľi ia ka na Ľe  Ľikai te na fa Ľa lava ia.  
\v 2 Pea na Ľe fakahńĀ ki he fale  Ľo Tevita,  Ľo pehńď,  ĽOku kau fakataha  Ľa Silia mo  ĽIfalemi. Pea na Ľe ngaueue hono loto, mo e loto  Ľo hono kakai,  Ľo hangńď  Ľoku lŇęluu Ľi  Ľe he matangi  Ľae ngaahi  Ľakau  Ľoe vao.  
\v 3 Pea na Ľe toki pehńď  Ľe Sihova kia  ĽIsaia, ‚Äú ĽAlu atu  Ľo fakafetaulaki kia  ĽAhasi,  Ľa koe mo Siasasupe ko ho foha,  Ľi he ngata Ľanga  Ľoe tafe Ľanga  Ľoe vai taupotu ki  Ľolunga  Ľi he hala lahi  Ľoe ngoue  Ľae tangata fakama Ľa kofu;  
\v 4 Pea te ke pehńď kiate ia, Tokanga, pea ke fiemńĀlie;  Ľoua  Ľe manavahńď, pea  Ľoua na Ľa vaivai ho loto ki he potu Ľi toume  Ľoe ongo tŇęhulu  Ľoku kohu ni, ki he  Ľita lahi  Ľo Lesini pea mo Silia, pea mo e foha  Ľo Lemalia.  
\v 5 Koe Ľuhi kuo fakakaukau ki he kovi ke fai kiate koe,  Ľe Silia, mo  ĽIfalemi, pea mo e foha  Ľo Lemalia,  Ľo pehńď,  
\v 6 Ke tau  Ľalu  Ľo tau Ľi  Ľa Siuta, pea fakamamahi Ľi, pea ke tau ngaohi ke ava hono potu mo Ľotautolu, pea fokotu Ľu ha tu Ľi  Ľi ai,  Ľio,  Ľae foha  Ľo Tapeale:  
\v 7 ‚ÄĆ ĽOku pehńď  Ľe he  ĽEiki ko Sihova, ‚Äú ĽE  Ľikai tu Ľuma Ľu ia, pea  Ľe  Ľikai hoko ia.  
\v 8 He ko e  Ľulu  Ľo Silia ko Tamasikusi, pea ko e  Ľulu  Ľo Tamasikusi ko Lesini; pea  Ľi he te Ľeki ke kakato  Ľae ta Ľu  Ľe onongofulu ma nima  Ľe maumau Ľi  Ľa  ĽIfalemi, ke  Ľoua na Ľa kei ai hano kakai.  
\v 9 Pea ko e  Ľulu  Ľo  ĽIfalemi ko Samńďlia, pea ko e  Ľulu  Ľo Samńďlia  Ľae foha  Ľo Lemalia. Kapau  Ľe  Ľikai te mou tui, ko e mo Ľoni  Ľe  Ľikai te mou tu Ľuma Ľu.  
\v 10 Pea na Ľe toe folofola  Ľa Sihova kia  ĽAhasi,  Ľo pehńď,  
\v 11 ‚ÄúKe ke kole ha faka Ľilonga meia Sihova ko ho  ĽOtua; kole ia mei he loloto, pe mei he langi  Ľi  Ľolunga.‚ÄĚ  
\v 12 Ka na Ľe pehńď  Ľe  ĽAhasi, ‚Äú ĽE  Ľikai te u kole, pea  Ľe  Ľikai te u  Ľahi Ľahi kovi kia Sihova.‚ÄĚ  
\v 13 Pea na Ľa ne pehńď, ‚ÄúFanongo mai,  Ľae fale  Ľo Tevita; He ko e me Ľa si Ľi ke ke fakafiu Ľi  Ľae tangata, ka te ke fakafiu Ľi mo hoku  ĽOtua foki?  
\v 14 Ko ia ko Sihova pe te ne  Ľatu kiate koe  Ľae faka Ľilonga; Vakai,  Ľe tuitu Ľia  Ľae tńĀupo Ľou, pea  Ľe fńĀ Ľele Ľi  Ľae tama, pea  Ľe ui hono huafa ko  ĽImanuela.  
\v 15 Te ne kai  Ľae pota mo e honi, koe Ľuhi ke ne  Ľilo ke si Ľaki  Ľae kovi, pea fili  Ľae lelei.  
\v 16 ‚ÄĆ ĽI he te Ľeki ke  Ľilo  Ľe he tamasi Ľi ke si Ľaki  Ľae kovi, pea fili  Ľae lelei,  Ľe mole mei he fonua  Ľoku ke fehi Ľa ki ai  Ľa hono ongo tu Ľi  Ľe toko ua.   
\p
\v 17 ¬∂ ‚Äú ĽE fakahoko e Sihova kiate koe, pea ki ho Ľo kakai, pea ki he fale  Ľo ho Ľo tamai,  Ľae ngaahi  Ľaho  Ľoku te Ľeki ai hano tatau, talu  Ľae  Ľaho na Ľe mahu Ľi  Ľa  ĽIfalemi mei Siuta,  Ľio,  Ľae tu Ľi  Ľo  ĽAsilia.  
\v 18 Pea  Ľi he  Ľaho ko ia,  Ľe ui  Ľe Sihova ke ha Ľu  Ľae lango mei he vaitafe  Ľi he ngaahi ngata Ľanga  Ľo  ĽIsipite, pea mo e pi  Ľoku  Ľi he fonua ko  ĽAsilia.  
\v 19 Pea te nau ha Ľu, pea  Ľe nofo  Ľakinautolu kotoa pńď  Ľi he ngaahi tele Ľa li Ľaki; pea  Ľi he ngaahi  Ľana maka, pea  Ľi he ngaahi  Ľakau talatala kotoa pńď, mo e ngaahi  Ľakau kotoa pńď.  
\v 20 ‚ÄĆ ĽI he  Ľaho ko ia  Ľe fafai  Ľe Sihova  Ľaki  Ľae tele kuo ma Ľu  Ľi he totongi,  Ľiate kinautolu  Ľi he tu Ľa vaitafe,  Ľio,  Ľae tu Ľi  Ľo  ĽAsilia,  Ľae  Ľulu pea mo e fulufulu  Ľoe va Ľe: pea te ne faka Ľosi mo e kava foki.  
\v 21 Pea  Ľe hoko  Ľi he  Ľaho ko ia,  Ľe tauhi  Ľe ha tangata  Ľae pulu mui fefine, mo e sipi  Ľe ua;  
\v 22 Pea  Ľe pehńď,  Ľi he lahi  Ľoe hu Ľahuhu  Ľe ma Ľu mei ai, ko ia te ne kai pota, he ko e pota mo e hone  Ľe kai  Ľekinautolu fulipńď  Ľoku toe  Ľi he fonua.  
\v 23 Pea  Ľe hoko  Ľi he  Ľaho ko ia  Ľo pehńď, ko e potu kotoa pńď na Ľe  Ľi ai  Ľae vaine  Ľe afe  Ľo tatau mo e konga siliva  Ľe afe,  Ľe tupu  Ľi ai  Ľae  Ľakau talatala mo e talatala ĽńĀmoa.  
\v 24 ‚ÄĆ ĽE ha Ľu ki ai  Ľae kakai mo e ngaahi ngahau mo e kaufana; koe Ľuhi  Ľe  Ľufi Ľufi  Ľae fonua kotoa pńď  Ľaki  Ľae  Ľakau talatala mo e talatala ĽńĀmoa.  
\v 25 Pea  Ľi he ngaahi mńĀ Ľolunga kotoa pńď  Ľe keli  Ľaki  Ľae huo,  Ľe  Ľikai hoko ki ai  Ľae manavahńď ki he  Ľakau talatala: ka ko e potu ia ke  Ľave ki ai  Ľae fanga pulu, pea ke moloki ia  Ľe he fanga sipi.‚ÄĚ   
\c 8  
\cd \it 1  ĽOku ne kikite ia Maha-sala-hase-pase,  Ľe fakavaivai Ľi  Ľa Silia mo  ĽIsileli  Ľe  ĽAsilia. 5 Pea mo Siuta foki ko e me Ľa  Ľi he Ľenau ta Ľetui. 9  ĽOku  Ľikai fa Ľa ta Ľofi  Ľae ngaahi tautea  Ľae  ĽOtua. 11  ĽE fiemńĀlie  Ľakinautolu  Ľoku manavahńď ki he  ĽOtua. 19  ĽE lahi  Ľae mamahi ki he kau tauhi tamapua.\it*  
\p
\v 1 Pea na Ľe toe pehńď  Ľe Sihova kiate au, ‚ÄúTo Ľo kiate koe ha takainga lahi, pea tohi  Ľi ai  Ľaki ha peni  Ľae tangata  Ľae me Ľa  Ľoku kau kia Maha-sala-hase-pase.  
\v 2 Pea na Ľaku to Ľo kiate au  Ľae kau fakamo Ľoni angatonu ke tohi, ko  ĽUlia ko e taula Ľeiki, mo Sakalia ko e foha  Ľo Sepelikaia.‚ÄĚ  
\v 3 Pea ne u  Ľalu ki he palŇćfita fefine; pea na Ľe tuitu Ľia ia, pea fanau Ľi  Ľae tama, Pea na Ľe toki pehńď  Ľe Sihova kiate au, ‚ÄúUi hono hingoa ko ‚ÄėMaha-sala-hase-pase.‚Äô  
\v 4 Koe Ľuhi  Ľi he kei vale  Ľae tamasi Ľi ke lea, ‚ÄėKo  Ľeku tamai,‚Äô mo ‚Äė Ľeku fa Ľńď,‚Äô  Ľe  Ľave  Ľi he  Ľao  Ľoe tu Ľi  Ľo  ĽAsilia  Ľae koloa  Ľo Tamasikusi mo e vete taua  Ľo Samńďlia.   
\p
\v 5 ¬∂ Pea na Ľe toe folofola foki  Ľa Sihova kiate au,  Ľo pehńď,  
\v 6 ‚ÄúKo e me Ľa  Ľi he li Ľaki  Ľe he kakai ni  Ľae ngaahi vai  Ľo Siloa  Ľoku tafetafemńĀlie, pea  Ľoku nau fiefia  Ľia Lesini mo e foha  Ľo Lemalia;  
\v 7 Ko ia foki, vakai,  Ľoku  Ľomi  Ľe Sihova kiate kinautolu  Ľae ngaahi vai  Ľoe vaitafe,  Ľoku mńĀlohi pea lahi,  Ľio,  Ľae tu Ľi  Ľo  ĽAsilia mo hono mńĀlohi kotoa pńď: pea te ne  Ľalu hake ki hono tafe Ľanga vai kotoa pńď, pea  Ľe lŇćmaki Ľi  Ľae ngaahi kauvai kotoa pńď:  
\v 8 Pea te ne  Ľoho  Ľi Siuta; pea fetńĀfeaki ia  Ľo mafola,  Ľo a Ľu hake ia ki he kia; pea ko e folahi  Ľo hono kapakau  Ľe fe Ľunga mo e mńĀukupu  Ľo ho fonua,  ĽE  ĽImanuela.‚ÄĚ   
\p
\v 9 ¬∂ Mou kau fakataha,  Ľakimoutolu  Ľae kakai, pea  Ľe laiki  Ľakimoutolu; pea fakafanongo,  Ľakimoutolu  Ľae ngaahi fonua kotoa pńď  Ľoku mama Ľo: nono Ľo  Ľakimoutolu, pea  Ľe momosi  Ľakimoutolu; nono Ľo  Ľakimoutolu, pea  Ľe li Ľaki  Ľakimoutolu.  
\v 10 Mou fakakaukau fakataha, ka e hoko ko e me Ľa noa pe ia; mou alea, ka e  Ľikai tu Ľuma Ľu ia: he  Ľoku  Ľiate kimautolu  Ľae  ĽOtua.   
\p
\v 11 ¬∂ He na Ľe folofola pehńď  Ľa Sihova kiate au  Ľi he nima mńĀlohi, mo ne akonaki Ľi au ke  Ľoua na Ľaku  Ľalu  Ľi he hala  Ľoe kakai ni,  Ľo ne pehńď,  
\v 12 ‚ÄĆ ĽOua na Ľa mou pehńď, ‚ÄúKo e tau, kiate kinautolu kotoa pńď  Ľoku pehńď ki ai  Ľae kakai ni, ko e tau, pea  Ľoua  Ľe manavahńď ki he Ľenau fakamanavahńď Ľi, pea  Ľoua na Ľa mou ilifia.  
\v 13 Mou fakatapui pe  Ľa Sihova  Ľoe ngaahi kautau; pea tuku ke hoko ia ko ho Ľomou manavahńď Ľanga, pea mou ilifia  Ľiate ia.  
\v 14 Pea  Ľe hoko ia ko e hŇęfanga malu; ka ko e maka tŇękia Ľanga, pea ko e maka faka Ľita ki he fale fakatou Ľosi  Ľo  ĽIsileli, ko e tauhele mo e heleanga ki he kakai  Ľo SelŇęsalema.  
\v 15 Pea ko e tokolahi  Ľiate kinautolu te nau tohumuhumu, pea hinga, pea laiki, mo tauhele, pea tou Ľia  Ľakinautolu.  
\v 16 Fakama Ľopo Ľopo  Ľae fakamo Ľoni, pulusi  Ľae fono ma Ľa  Ľeku kau ńĀkonga.  
\v 17 Pea te u tatali kia Sihova,  Ľaia  Ľoku fufŇę hono fofonga mei he fale  Ľo Sńďkope, pea te u  Ľamanaki kiate ia.  
\v 18 Vakai, ko au mo e fńĀnau kuo foaki  Ľe Sihova kiate au, kuo mau hoko ko e ngaahi faka Ľilonga pea mo e ngaahi me Ľa fakaofo  Ľi  ĽIsileli, meia Sihova  Ľoe ngaahi kautau,  Ľaia  Ľoku  Ľafio  Ľi he mo Ľunga ko Saione.‚ÄĚ   
\p
\v 19 ¬∂ Pea  Ľoka nau ka pehńď mai kiate kimoutolu, ‚ÄúKumi kiate kinautolu  Ľoku ai  Ľae ngaahi laumńĀlie kovi, pea ki he ngaahi kikite  Ľoku mapu mo femuhumuhu Ľi:  Ľikai  Ľoku totonu ke kumi  Ľe he kakai ki honau  ĽOtua?  ĽOku totonu końĀ  Ľenau si Ľaki  Ľae mo Ľui kae kumi ki he mate?  
\v 20 Kumi ki he fono pea ki he fakamo Ľoni: kapau  Ľe  Ľikai te nau lea  Ľo hangńď ko e folofola ni,  Ľoku pehńď koe Ľuhi  Ľoku  Ľikai ha maama  Ľiate kinautolu.  
\v 21 Pea te nau  Ľalu  Ľi ai,  Ľi he mamahi mo e fiekaia, pea  Ľe hoko  Ľo pehńď,  Ľi he Ľenau fiekaia, te nau tangi, pea kape Ľi honau tu Ľi mo honau  ĽOtua, pea sio ki  Ľolunga.  
\v 22 Pea te nau sio ki he kelekele; pea vakai ko e mamahi, mo e fakapo Ľuli, mo e ninimo, mo e ongosia; pea  Ľe kapusi  Ľakinautolu ki he fakapo Ľuli.‚ÄĚ   
\c 9  
\cd \it 1 Ko e fiefia  Ľi he lolotonga  Ľae mamahi,  Ľi he pule mo e  Ľalo Ľi  Ľo Kalaisi, 8 Ko e tautea ki  ĽIsileli koe Ľuhi ko  Ľenau fielahi, 13 Mo  Ľenau mńĀlualoi, 18 Pea mo honau loto fefeka.\it*  
\p
\v 1 Ka ko eni,  Ľe  Ľikai kei  Ľi ai ha fakapo Ľuli  Ľi he fonua na Ľe mamahi:  Ľi he kuonga  Ľi mu Ľa na Ľa ne fakavaivai Ľi  Ľae fonua  Ľo Sepuloni mo e fonua  Ľo Nafitali, ka kuo ne fakalelei ia  Ľi he kuonga ki mui;  Ľio,  Ľi he hala  Ľoe tahi,  Ľi he tu Ľa Sioatani,  Ľi KńĀleli  Ľoe ngaahi pule Ľanga.   
\p
\v 2 Ko e kakai na Ľe  Ľa Ľeva  Ľi he po Ľuli kuo mamata ki he maama lahi:  
\q2 ko kinautolu na Ľe nofo  Ľi he fonua  Ľoe  Ľata  Ľoe mate, kuo ulo kiate kinautolu  Ľae maama.   
\q1
\v 3 Kuo ke fakatokolahi  Ľae pule Ľanga,  
\q2 pea fakalahi mo  Ľenau fiefia:  
\p  Ľoku nau fiefia  Ľi ho  Ľao  Ľo hangńď ko e fiefia  Ľi he ututa Ľu, pea hangńď ko e fiefia  Ľae kakai  Ľi he Ľenau tufa  Ľae koloa kuo vete.  
\v 4 He kuo ke fesi Ľi  Ľae ha Ľamo  Ľo  Ľene kavenga, pea mo e tokotoko  Ľoku ai ki hono uma, mo e me Ľa tńĀ  Ľa hono fili,  Ľo hangńď ko ia ne fai  Ľi he  Ľaho  Ľo Mitiane.  
\v 5 He ko e tau kotoa pńď  Ľoe tangata tau  Ľoku  Ľi he longoa Ľa fakamaveuveu, mo e ngaahi kofu kuo tńĀkai  Ľi he toto; ka e hoko eni  Ľi he vela mo e fefie  Ľoe afi.  
\v 6 He kuo fanau Ľi kiate kitautolu  Ľae tamasi Ľi, kuo foaki kiate kitautolu  Ľae foha: pea  Ľe  Ľi hono uma  Ľae pule: pea  Ľe ui hono huafa ko Fakaofo, ko  ĽAkonaki, ko e  ĽOtua MńĀfimafi, ko e Tamai Ta Ľengata, ko e  ĽEiki  Ľoe Melino.  
\v 7 ‚ÄĆ ĽI he tupu  Ľo  Ľene pule mo e melino  Ľe  Ľikai hano ngata Ľanga,  Ľi he nofo Ľanga  Ľo Tevita, pea  Ľi hono pule Ľanga, ke fakatonutonu ia, pea ke fokotu Ľuma Ľu ia  Ľi he fakamaau pea mo e angatonu mei he  Ľaho ni  Ľo ta Ľengata. Ko e  Ľofa  Ľa Sihova  Ľoe ngaahi kautau te ne fai  Ľae me Ľa ni.   
\p
\v 8 ¬∂ Na Ľe fekau  Ľe Sihova  Ľae lea kia Sńďkope,  
\q2 pea kuo tŇć ia ki  ĽIsileli.   
\q1
\v 9 Pea  Ľe  Ľilo  Ľe he kakai kotoa pńď,  
\q2  Ľio,  Ľe  ĽIfalemi mo ia  Ľoku nofo  Ľi Samńďlia,  Ľaia  Ľoku pehńď  Ľi he laukau mo e mńĀlohi  Ľoe loto,   
\q1
\v 10 ‚ÄúKuo tŇć ki lalo  Ľae maka Ľumea,  
\q2 ka te mau langa  Ľaki  Ľae maka kuo tńĀ:  
\q1 kuo tu Ľusi ki lalo  Ľae ngaahi sukamino,  
\q2 ka te mau fetongi  Ľaki ia  Ľae ngaahi sita.‚ÄĚ   
\q1
\v 11 Ko ia  Ľe fokotu Ľu  Ľe Sihova kia Lesini hono ngaahi fili,  
\q2 pea fakakau fakataha hono ngaahi fili;   
\q2
\v 12 ‚ÄĆ ĽAe kau Silia  Ľi he potu hahake,  
\q2 pea mo e kau Filisitia  Ľi he lulunga;  
\q2 pea te nau keina  Ľa  ĽIsileli  Ľaki  Ľae ngutu kuo fakamanga.  
\q1 Pea neongo  Ľae me Ľa ni kotoa pńď  Ľoku  Ľikai ta Ľofi hono houhau,  
\q2 ka  Ľoku kei mafao hono nima.   
\q1
\v 13 He  Ľoku  Ľikai tafoki mai  Ľae kakai kiate ia  Ľoku taa Ľi  Ľakinautolu,  
\q2  Ľoku  Ľikai te nau kumi kia Sihova  Ľoe ngaahi kautau.   
\q1
\v 14 Ko ia  Ľe tu Ľusi  Ľe Sihova mei  ĽIsileli  Ľae  Ľulu mo e iku,  
\q2  Ľae va Ľa mo e tefito,  Ľi he  Ľaho pe taha.   
\q1
\v 15 Ko e motu Ľa mo ia  Ľoku ongoongolelei, ko e  Ľulu ia;  
\q2 pea ko e palŇćfita  Ľoku ako  Ľaki  Ľae loi, ko e iku ia.   
\q1
\v 16 He ko e kau takimu Ľa  Ľoe kakai ni  Ľoku nau fakahala Ľi  Ľakinautolu;  
\q2 pea  Ľe  Ľauha  Ľakinautolu kuo takiekina  Ľiate kinautolu.   
\q1
\v 17 Ko ia  Ľe  Ľikai fiemńĀlie  Ľa Sihova  Ľi honau kau talavou,  
\q2 pe  Ľalo Ľofa ki he Ľenau kau tamai mate mo e kau fefine kuo mate honau husepńĀniti:  
\q1 he ko e mńĀlualoi mo e fai kovi  Ľakinautolu kotoa pńď,  
\q2 pea  Ľoku lea vale  Ľae ngutu kotoa pńď.  
\q1 Pea neongo  Ľae me Ľa ni kotoa pńď  Ľoku  Ľikai ta Ľofi hono houhau,  
\q2 ka  Ľoku kei mafao hono nima.   
\q1
\v 18 He  Ľoku vela  Ľae angahala  Ľo hangńď ko e afi;  
\q2  Ľe keina ia  Ľae ngaahi  Ľakau talatala,  
\q2 pea  Ľe tutu  Ľi he matolu  Ľoe vao lahi,  
\q2 pea te nau  Ľalu hake  Ľo hangńď ko e puna hake  Ľoe  Ľohuafi.   
\q1
\v 19 Ko e me Ľa  Ľi he houhau  Ľo Sihova  Ľoe ngaahi kautau  Ľoku fakapo Ľuli ai  Ľae fonua,  
\q2 pea ko e kakai te nau hangńď ko e fefie  Ľoe afi:  
\q2  Ľe  Ľikai mamae ha tangata  Ľe tokotaha ki hono tokoua.   
\q1
\v 20 Pea te ne hamusi  Ľi he potu to Ľomata Ľu, kae fiekaia;  
\q2 pea te ne kai  Ľi he potu to Ľohema, ka e  Ľikai te nau mńĀkona:  
\q1  Ľe kai  Ľe he tangata taki taha  Ľae kakano  Ľo hono nima  Ľo Ľona:   
\q2
\v 21 Ko Manase, kia  ĽIfalemi; mo  ĽIfalemi, kia Manase:  
\q1 pea ko kinaua fakatou Ľosi te na kau fakataha ke fakamamahi Ľi  Ľa Siuta.  
\q2 Pea neongo  Ľae me Ľa ni kotoa pńď  Ľoku  Ľikai ta Ľofi hono houhau, ka  Ľoku kei mafao hono nima.   
\c 10  
\cd \it 1 Ko e mala Ľia  Ľae kau pule kakaha. 5 Ko  ĽAsilia, ko e me Ľa tńĀ ki he kau mńĀlualoi,  Ľe mafesifesi ia koe Ľuhi ko  Ľene laukau. 20  ĽE fakamo Ľui hono toe  Ľo  ĽIsileli. 24  ĽOku fakafiemńĀlie Ľi  Ľa  ĽIsileli  Ľi he fakahńĀ  Ľa hono fakamo Ľui mei  ĽAsilia.\it*  
\p
\v 1 ‚ÄĆ ĽE mala Ľia  Ľakinautolu  Ľoku fokotu Ľu  Ľae fono ta ĽemńĀ Ľoni Ľoni, pea  Ľoku tohi  Ľae mamahi  Ľaia kuo nau tu Ľutu Ľuni;  
\v 2 Ke fakaafe  Ľae masiva mei he fakamaau, pea fa Ľao  Ľae totonu mei he masiva  Ľo hoku kakai, ke nau kńĀkaa Ľi  Ľae kau fefine kuo mate honau husepńĀniti, pea ke nau kaiha Ľa mei he tamai mate!  
\v 3 Pea ko e hńĀ te mou fai  Ľi he  Ľaho  Ľoe  Ľa Ľahi, pea  Ľi he faka Ľauha  Ľaia  Ľe ha Ľu mei he mama Ľo? Te mou kumi  Ľae tokoni meia hai? Pea te mou tuku  Ľi fńď  Ľa homou nńĀunau?  
\v 4 ‚ÄĆ ĽI he ta Ľema Ľu au te nau hoko ko e pŇćpula ki he pŇćpula, pea mo Ľulaloa kiate kinautolu kuo fakamo Ľulaloa. Pea neongo  Ľae me Ľa ni kotoa pńď  Ľoku  Ľikai ta Ľofi hono houhau, ka  Ľoku kei mafao hono nima.   
\p
\v 5 ¬∂  ĽE mala Ľia  Ľae tangata  Ľo  ĽAsilia, ko e me Ľa tńĀ  Ľo  Ľeku tuputńĀmaki, pea ko e tokotoko  Ľi honau nima ko hoku houhau ia.  
\v 6 Te u fekau ia ki he pule Ľanga mńĀlualoi, pea ki he kakai  Ľoku ou houhau ki ai te u tuku kiate ia ha fekau, ke  Ľave  Ľae koloa, pea  Ľave mo e me Ľakai, pea ke molomoloki  Ľakinautolu  Ľo hangńď ko e pelepela  Ľoe ngaahi hala.  
\v 7 Ka ko eni,  Ľoku  Ľikai ko hono loto ia, pea  Ľoku  Ľikai ke mahalo pehńď  Ľa hono loto; ka  Ľoku  Ľi hono loto ke tu Ľusi mo faka Ľauha  Ľae ngaahi pule Ľanga lahi.  
\v 8 He  Ľoku ne pehńď, ‚Äú ĽIkai ko e ngaahi tu Ľi mo Ľoni  Ľae ngaahi  Ľeiki  Ľoku  Ľiate au?  
\v 9 ‚ÄĆ ĽIkai  Ľoku tatau  Ľa Kalino mo Kalikimisi?  ĽIkai  Ľoku tatau  Ľa Hamate mo  ĽApati?  ĽIkai  Ľoku tatau  Ľa Samńďlia mo Tamasikusi?  
\v 10 ‚ÄĆ ĽO hangńď ko e  Ľilo  Ľa hoku nima  Ľae ngaahi pule Ľanga  Ľoe kau tamapua,  Ľaia na Ľe lahi hake ki SelŇęsalema mo Samńďlia  Ľenau ngaahi tamapua;  
\v 11 ‚ÄĆ ĽO hangńď ko ia kuo u fai ki Samńďlia mo  Ľene ngaahi tamapua,  Ľikai te u fai pehńď foki ki SelŇęsalema mo  Ľene ngaahi tamapua?‚ÄĚ  
\v 12 Ko ia  Ľe hoko  Ľo pehńď, ‚Äú ĽOka fakakakato  Ľe he  ĽEiki  Ľa  Ľene ngńĀue kotoa  Ľi he mo Ľunga ko Saione pea mo SelŇęsalema, te u tautea  Ľae futa  Ľoe loto mńĀlohi  Ľoe tu Ľi  Ľo  ĽAsilia, pea mo e hihiki  Ľo hono mata fielahi.‚ÄĚ  
\v 13 He  Ľoku ne pehńď, ‚Äú ĽI he mńĀlohi  Ľo hoku nima kuo u fai eni, pea  Ľi he Ľeku poto; he  Ľoku ou fai fakapotopoto: pea kuo u to Ľo  Ľae ngaahi fakangatangata  Ľoe kakai, pea kaiha Ľasia mo  Ľenau koloa, pea kuo u fakamo Ľulaloa  Ľae kakai  Ľo hangńď ko ia  Ľoku taau mo e tangata to Ľa:  
\v 14 Pea kuo  Ľilo  Ľe hoku nima  Ľae koloa  Ľae kakai  Ľo hangńď ko ha pununga: pea hangńď ko ha taha  Ľoku tńĀnaki  Ľae ngaahi fo Ľi manu  Ľoku pehńď  Ľa  Ľeku tńĀnaki  Ľa mńĀmani kotoa pńď; pea na Ľe  Ľikai ha taha te ne ue Ľi  Ľae kapakau, pe fakamanga  Ľae ngutu, pe faka Ľasi.‚ÄĚ  
\v 15 ‚ÄĆ ĽE fielahi  Ľae toki kiate ia  Ľoku ne tńĀ  Ľaki ia? Pe fielahi  Ľae kili kiate ia  Ľoku ne fetohoaki ia?  ĽO hangńď ka tńĀ mai  Ľae  Ľakau kiate ia  Ľoku ne to Ľo ia, pea hangńď ka hiki hake  Ľe he tokotoko kiate ia  Ľoku ne to Ľo ia.  
\v 16 Ko ia  Ľe fekau atu  Ľe Sihova, ko e  ĽEiki  Ľoe ngaahi kautau,  Ľae tutue ki honau kakai sino; pea te ne tutu ke vela  Ľa hono nńĀunau  Ľo hangńď ko e kakaha  Ľae afi.  
\v 17 Pea ko e maama  Ľo  ĽIsileli  Ľe hoko ia ko e afi, pea ko hono tokotaha mńĀ Ľoni Ľoni ko e ulo afi, pea  Ľe kakaha ia pea faka Ľauha  Ľi he  Ľaho pe taha hono ngaahi  Ľakau talatala mo e talatala ĽńĀmoa;  
\v 18 Pea  Ľe faka Ľauha  Ľae lelei  Ľoe vao lahi  Ľo ia, pea mo  Ľene ngoue  Ľoku fua,  Ľae laumńĀlie mo e sino fakatou Ľosi; pea te nau hangńď ko e tangata to Ľo fuka kuo pongia.  
\v 19 Pea ko hono toe  Ľoe  Ľakau  Ľoe vao lahi ko ia te nau tokosi Ľi, ko ia  Ľe fa Ľa tohi ia  Ľe ha tamasi Ľi.   
\p
\v 20 ¬∂ Pea  Ľe hoko  Ľi he  Ľaho ko ia  Ľo pehńď, ko hono toe  Ľo  ĽIsileli, pea mo kinautolu kuo hao  Ľi he fale  Ľo Sńďkope,  Ľe  Ľikai te nau toe falala kiate ia na Ľe taa Ľi  Ľakinautolu; ka e falala mo Ľoni kia Sihova, ko e tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli.  
\v 21 ‚ÄĆ ĽE foki mai hono toe,  Ľio,  Ľae toe  Ľo Sńďkope, ki he  ĽOtua MńĀfimafi.  
\v 22 He neongo  Ľae tatau  Ľa ho Ľo kakai,  ĽE  ĽIsileli, mo e  Ľone Ľone  Ľoe tahi, ka e foki mai pe hono toe: kuo pau ke hoko  Ľae faka Ľauha  Ľe fonu mahua  Ľi he fai totonu.  
\v 23 He ko Sihova ko e  ĽEiki  Ľoe ngaahi kautau te ne fai  Ľae faka Ľauha kuo kotofa,  Ľi he lotolotonga  Ľoe fonua kotoa pńď.   
\p
\v 24 ¬∂ Ko ia  Ľoku pehńď  Ľe Sihova ko e  ĽEiki  Ľoe ngaahi kautau, ‚Äú ĽE hoku kakai  Ľaia  Ľoku nofo  Ľi Saione,  Ľoua  Ľe manavahńď ki he tangata  ĽAsilia: te ne taa Ľi koe  Ľaki  Ľae me Ľa tńĀ, pea hiki hake hono tokotoko kiate koe, ka  Ľe hangńď ko ia na Ľe fai  Ľi  ĽIsipite.  
\v 25 Koe Ľuhi  Ľe toetoe si Ľi pea  Ľe ngata  Ľa hoku tuputńĀmaki, pea mo hoku houhau, ka te u faka Ľauha  Ľakinautolu.  
\v 26 Pea  Ľe hiki hake  Ľe Sihova  Ľoe ngaahi kautau  Ľae me Ľa tautea  Ľo hangńď ko e faka Ľauha  Ľa Mitiane  Ľi he maka ko Olepi: pea tatau mo  Ľene tokotoko na Ľe ai ki he tahi,  Ľe pehńď  Ľa  Ľene hiki hake ia  Ľo hangńď ko ia na Ľe fai ki  ĽIsipite.  
\v 27 Pea  Ľe hoko pehńď,  Ľi he  Ľaho ko ia,  Ľe to Ľo  Ľene kavenga mei ho uma, mo  Ľene ha Ľamonga mei ho kia, pea  Ľe maumau Ľi  Ľae ha Ľamonga mei homou uma.‚ÄĚ  
\v 28 Kuo ha Ľu ia ki  ĽAiata, kuo  Ľalu atu ia ki Mikiloni; kuo ne tńĀnaki  Ľene ngaahi saliote  Ľi Mikimasi:  
\v 29 Kuo nau laka  Ľi he potu fńĀsi Ľi: kuo nau nofo  Ľi Kepa;  Ľoku manavahńď  Ľa Lama; pea kuo hola  Ľa Kipea  Ľo Saula.  
\v 30 ‚ÄĆ ĽE  Ľofefine  Ľo Kalimi, hiki hake ho le Ľo: fai ke ongo atu ia ki Leisi,  ĽE  ĽAnatoti masiva.  
\v 31 Kuo  Ľave  Ľa Matemena;  Ľoku fakataha  Ľakinautolu  Ľe he kakai  Ľe Kepime ke nau hola.  
\v 32 Te ne nofo pe ia  Ľi he  Ľaho ni  Ľi Nope: te ne lulululu hono nima ki he mo Ľunga  Ľoe  Ľofefine  Ľo Saione,  Ľae mo Ľunga  Ľo SelŇęsalema.  
\v 33 Vakai, ko e  ĽEiki, ko Sihova  Ľoe ngaahi kautau, te ne tu Ľusi  Ľae va Ľa  Ľaki  Ľae manavahńď lahi: pea ko kinautolu  Ľoku mńĀ Ľolunga  Ľe tńĀ hifo, pea ko e fielahi  Ľe fakavaivai Ľi.  
\v 34 Pea te ne tu Ľusi ki lalo  Ľae ngaahi potu  Ľakau matolu  Ľoe vao lahi  Ľaki  Ľae ukamea, pea  Ľe tŇć ki lalo  Ľa Lepanoni  Ľi ha taha mńĀlohi.   
\c 11  
\cd \it 1 Ko e pule Ľanga fakamelino  Ľoe va Ľa mei he aka  Ľo Sese. 10 Ko e toe  Ľomi  Ľa  ĽIsileli, mo e ui  Ľoe kakai Senitaile.\it*  
\q1
\v 1 Pea  Ľe tupu hake ha tokotoko mei he tefito  Ľo Sese,  
\q2 pea  Ľe tupu ha Va Ľa mei hono ngaahi aka:   
\q1
\v 2 Pea  Ľe nofo  Ľiate ia  Ľae LaumńĀlie  Ľo Sihova,  
\q2  Ľae laumńĀlie  Ľoe poto mo e fa Ľa  Ľilo,  
\q2  Ľae laumńĀlie  Ľoe akonaki mo e mńĀlohi,  
\q2  Ľae laumńĀlie  Ľoe  Ľilo pea mo e manavahńď kia Sihova;   
\q1
\v 3 Pea  Ľe  Ľilo vave  Ľe ia  Ľae manavahńď kia Sihova:  
\q1 pea  Ľe  Ľikai te ne fakamaau  Ľi he vakai  Ľa hono fofonga,  
\q2 pe valoki  Ľo hangńď ko e fanongo  Ľa hono telinga:   
\q1
\v 4 Ka  Ľi he mńĀ Ľoni Ľoni te ne fakamaau  Ľae masiva,  
\q2 pea valoki  Ľi he ta ĽefilifilimńĀnako ma Ľa e angavaivai  Ľoe fonua:  
\q1 pea te ne taa Ľi  Ľa mńĀmani  Ľaki  Ľae me Ľa tńĀ  Ľo hono fofonga,  
\q2 pea te ne tńĀmate  Ľae angakovi  Ľaki  Ľae mńĀnava  Ľo hono loungutu.   
\q1
\v 5 Pea ko e no Ľo  Ľo hono kongaloto  Ľae mńĀ Ľoni Ľoni,  
\q2 pea ko e nono Ľo  Ľo hono no Ľotanga vala  Ľae mo Ľoni.   
\q1
\v 6 Pea  Ľe toki nofo fakataha  Ľae ulofi mo e lami,  
\q2 pea  Ľe tokoto fakataha  Ľae lńďpati mo e  Ľuhiki Ľi kosi;  
\q2 pea  Ľe fakataha  Ľae  Ľuhiki Ľi pulu mo e laione mui pea mo e manu fafanga;  
\q2 pea  Ľe tataki  Ľakinautolu  Ľe ha tamasi Ľi si Ľi.   
\q1
\v 7 Pea  Ľe kai fakataha  Ľae pulu fefine mo e pea;  
\q2 pea  Ľe tokoto fakataha honau  Ľuhiki:  
\q2 pea  Ľe kai  Ľe he laione  Ľae kau  Ľoe koane  Ľo hangńď ko e pulu.   
\q1
\v 8 Pea ko e tamasi Ľi  Ľoku kei huhu te ne va Ľinga  Ľi he luo  Ľoe ngata,  
\q2 pea ko e tamasi Ľi kuo fakamavae te ne  Ľai hono nima ki he  Ľana  Ľoe ngata fekai.   
\q1
\v 9 ‚ÄĆ ĽE  Ľikai te nau fakamamahi pe faka Ľauha  Ľi ha potu  Ľo hoku mo Ľunga mńĀ Ľoni Ľoni:  
\q2 koe Ľuhi  Ľe fonu  Ľa mńĀmani  Ľi he  Ľilo Ľi  Ľo Sihova,  
\q2  Ľo hangńď  Ľoku  Ľufi Ľufi  Ľe he ngaahi vai  Ľae kilisi tahi.   
\p
\v 10 ¬∂ Pea  Ľi he  Ľaho ko ia  Ľe  Ľi ai  Ľae aka  Ľo Sese,  Ľaia  Ľe tu Ľu ko e fuka  Ľae kakai:  Ľe kumi ki ai  Ľae ngaahi Senitaile: pea  Ľe lelei  Ľaupito  Ľa hono mńĀlŇćlŇć Ľanga.  
\v 11 Pea  Ľe hoko  Ľo pehńď  Ľi he  Ľaho ko ia,  Ľe toe ai  Ľe Sihova hono nima ko hono liunga ua ke fakamo Ľui  Ľae toenga  Ľo hono kakai,  Ľaia  Ľe fakatoe, mei  ĽAsilia, pea mo  ĽIsipite, pea mo Patolose, pea mo Kusi, pea mo  ĽIlami, pea mei Saina, pea mei Hamate, pea mei he ngaahi motu  Ľoe tahi.  
\v 12 Pea te ne fokotu Ľu ha fuka ki he ngaahi pule Ľanga, pea te ne fakataha  Ľae kau li Ľaki  Ľo  ĽIsileli, pea tńĀnaki fakataha  Ľae kau vetekina  Ľo Siuta mei he vahe  Ľe fńĀ  Ľo mńĀmani.  
\v 13 Pea  Ľe mole  Ľae meheka meia  ĽIfalemi, pea  Ľe faka Ľauha mo e ngaahi fili  Ľo Siuta:  Ľe  Ľikai kei fehi Ľa  Ľa  ĽIfalemi kia Siuta, pea ko Siuta  Ľe  Ľikai te ne fakamamahi Ľi  Ľa  ĽIfalemi.  
\v 14 Ka te na puna ki he lulunga  Ľi he uma  Ľoe kakai Filisitia; pea te na fa Ľao mo e potu hahake: te nau  Ľene ai honau nima ki  ĽItomi mo Moape; pea  Ľe talangofua kiate kinautolu  Ľae fńĀnau  Ľa  ĽAmoni.  
\v 15 Pea  Ľe faka Ľauha  Ľaupito  Ľe Sihova  Ľae  Ľelelo  Ľoe tahi  Ľo  ĽIsipite; pea te ne lulululu hono nima ki he vaitafe  Ľaki  Ľene matangi lahi, pea  Ľe taa Ľi  Ľe ia  Ľi hono manga Ľivai  Ľe fitu, pea  Ľe  Ľalu ta Ľeviku ai  Ľae kakai.  
\v 16 Pea  Ľe  Ľi ai  Ľae hala motu Ľa ki he toenga  Ľo hono kakai,  Ľaia  Ľe toe  Ľi  ĽAsilia,  Ľo hangńď ko ia ne ma Ľu  Ľe  ĽIsileli  Ľi he  Ľaho na Ľe  Ľalu hake ai ia mei he fonua ko  ĽIsipite.   
\c 12  
\cd \it 1‚Äď6 Ko e fakafeta Ľi fakafiefia  Ľae angatonu  Ľi he ngaahi  Ľalo Ľofa  Ľae  ĽOtua.\it*  
\p
\v 1 Pea  Ľi he  Ľaho ko ia te ke pehńď, ‚Äú ĽE Sihova, te u fakafeta Ľi kiate koe: he neongo ne ke houhau, ka kuo ke fakafiemńĀlie Ľi au.  
\v 2 Vakai, ko e  ĽOtua ko hoku fakamo Ľui te u falala, ka e  Ľikai manavahńď: he ko e  ĽEiki ko Sihova ko hoku mńĀlohi ia mo  Ľeku hiva; pea kuo hoko foki ia ko hoku fakamo Ľui.‚ÄĚ  
\v 3 Ko ia te mou  Ľutu  Ľae vai  Ľi he fiefia mei he ngaahi matavai  Ľoe mo Ľui.  
\v 4 Pea  Ľi he  Ľaho ko ia te mou pehńď, ‚ÄúFakafeta Ľi kia Sihova, ui ki hono huafa, fakahńĀ  Ľene ngaahi ngńĀue  Ľi he  Ľao  Ľoe kakai, fakamatala kuo hiki hake hono huafa.  
\v 5 Hiva kia Sihova; he kuo ne fai  Ľae ngaahi me Ľa lelei  Ľaupito:  Ľoku  Ľilo ia  Ľe mńĀmani kotoa pńď.  
\v 6 Kalanga pea mavava  Ľi he fiefia,  Ľa koe  Ľoku nofo  Ľi Saione: he  Ľoku lahi  Ľae tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli  Ľoku  Ľiate koe.‚ÄĚ   
\c 13  
\cd \it 1  ĽOku tńĀnaki  Ľe Sihova  Ľae ngaahi kongakau  Ľo hono houhau. 6  ĽOku ne fakamana Ľi ke faka Ľauha  Ľa Papilone  Ľaki  Ľae kakai  Ľo Mitia. 19 Ko e faka Ľauha  Ľo Papilone.\it*  
\p
\v 1 Ko e tala mamafa  Ľoku kau ki Papilone,  Ľaia na Ľe mamata ki ai  Ľe  ĽIsaia ko e foha  Ľo  ĽAmosi.  
\v 2 MOU fokotu Ľu  Ľae fuka  Ľi he mo Ľunga mńĀ Ľolunga, hiki hake  Ľae le Ľo kiate kinautolu, ta Ľalo  Ľaki  Ľae nima, ke nau hŇę  Ľi he ngaahi matapńĀ  Ľoe hou Ľeiki.  
\v 3 Kuo u fekau ki he Ľeku kau mńĀ Ľoni Ľoni, kuo u ui foki  Ľeku kau mńĀlohi koe Ľuhi ko hoku houhau,  Ľio,  Ľakinautolu  Ľoku fiefia he Ľeku mńĀfimafi.  
\v 4 Ko e longoa Ľa  Ľoe tokolahi  Ľi he ngaahi mo Ľunga,  Ľo hangńď ko e kakai lahi; ko e longoa Ľa lahi  Ľoe ngaahi pule Ľanga,  Ľio,  Ľoe ngaahi pule Ľanga kuo tńĀnaki fakataha: he  Ľoku fakataha  Ľe Sihova  Ľae ngaahi kautau  Ľo  Ľene kongakau ki he tau.  
\v 5 ‚ÄĆ ĽOku nau ha Ľu mei he fonua mama Ľo, mei he ngata Ľanga  Ľoe langi,  Ľio, ko Sihova, mo e mahafu  Ľo hono houhau, ke faka Ľauha  Ľae fonua kotoa pńď.   
\p
\v 6 ¬∂ Mou tangilńĀulau  Ľakimoutolu; he  Ľoku ofi  Ľae  Ľaho  Ľo Sihova;  Ľe ha Ľu ia  Ľo hangńď ko e faka Ľauha mei he MńĀfimafi.  
\v 7 Ko ia  Ľe vaivai ai  Ľae nima kotoa pńď, pea  Ľe molŇę mo e loto  Ľoe tangata kotoa pńď:  
\v 8 Pea te nau manavahńď:  Ľe puke  Ľakinautolu  Ľe he mamahi mo e ongosia; te nau langa  Ľo hangńď ko e fefine  Ľoku fńĀ Ľele: te nau fe Ľofa Ľaki;  Ľe tatau honau mata mo e ulo  Ľoe afi.  
\v 9 Vakai,  Ľoku ha Ľu  Ľae  Ľaho  Ľo Sihova,  Ľoku mamafa  Ľi he tu ĽutńĀmaki pea mo e houhau lahi, ke faka Ľauha  Ľae fonua: pea te ne tńĀmate Ľi  Ľae kakai angahala mei ai.  
\v 10 He ko e ngaahi fetu Ľu  Ľoe langi mo e ngaahi fa Ľahinga fetu Ľu  Ľi ai  Ľe  Ľikai te nau  Ľomi  Ľenau maama;  Ľe fakapo Ľuli  Ľae la ĽńĀ  Ľi he Ľene hopo hake, pea  Ľe  Ľikai ulo atu  Ľae maama  Ľoe mńĀhina.  
\v 11 Pea te u tautea  Ľa mńĀmani koe Ľuhi ko  Ľenau hia, pea mo e kakai angakovi koe Ľuhi ko  Ľenau angahala; pea te u pule ke ngata  Ľae fielahi  Ľoe laukau, pea te u lńę ki lalo  Ľae fie Ľeiki  Ľoe kakai fakamana.  
\v 12 Te u ngaohi ke mahu Ľinga hake  Ľae tangata  Ľi he koula lelei;  Ľio,  Ľe mahu Ľinga hake  Ľae tangata  Ľi he koula lelei  Ľo  ĽOfeli.  
\v 13 Ko ia te u lulululu ai  Ľae ngaahi langi, pea  Ľe hiki mo mńĀmani mei hono potu,  Ľi he houhau  Ľo Sihova  Ľoe ngaahi kautau, pea  Ľi he  Ľaho  Ľo hono houhau vela.  
\v 14 Pea  Ľe tatau ia mo e  Ľanitelope kuo tulia, pea hangńď ko e fanga sipi  Ľoka  Ľikai ha tangata ke tńĀnaki fakataha:  Ľe tafoki taki taha  Ľae tangata ki hono kakai, pea hola taki taha ki hono fonua.  
\v 15 Ko kinautolu kotoa pńď  Ľoku mo Ľua  Ľe hoka Ľi ke  Ľasi; pea  Ľe tŇć  Ľi he heletńĀ  Ľakinautolu kotoa pńď  Ľoku kau mo kinautolu.  
\v 16 ‚ÄĆ ĽE laiki  Ľenau fńĀnau  Ľi honau  Ľao;  Ľe vete  Ľa honau ngaahi fale, pea  Ľe tohotoho  Ľa honau ngaahi uaifi.  
\v 17 Vakai, te u hiki hake  Ľae kakai  Ľo Mitia ke tau Ľi  Ľakinautolu,  Ľe  Ľikai te nau tokanga ki he siliva; pea ko e koula,  Ľe  Ľikai te nau manako ki ai.  
\v 18 ‚ÄĆ ĽE laikina  Ľae kau talavou  Ľaki  Ľenau ngaahi kaufana; pea  Ľe  Ľikai te nau  Ľofa ki he fua  Ľoe manńĀva; pea  Ľe  Ľikai fakamo Ľui  Ľe honau mata  Ľae fńĀnau tupu.   
\p
\v 19 ¬∂ Pea ko Papilone, ko e lelei lahi  Ľoe ngaahi pule Ľanga, ko e toulekeleka  Ľoe laukau  Ľae kakai  Ľo Kalitia,  Ľe tatau ia mo e faka Ľauha  Ľa Sotoma mo Komola  Ľe he  ĽOtua.  
\v 20 ‚ÄĆ ĽE  Ľikai  Ľaupito toe kakai ia,  Ľe  Ľikai nofo  Ľi ai ha kakai mei he to Ľutangata ki he to Ľutangata: pea  Ľe  Ľikai fokotu Ľu  Ľe ha tangata  ĽAlepea  Ľae fale fehikitaki  Ľi ai; pea  Ľe  Ľikai ngaohi  Ľi ai  Ľe he kau tauhi sipi hanau loto ĽńĀ.  
\v 21 Ka e tokoto  Ľi ai  Ľae ngaahi manu kaivao  Ľoe potu lala; pea  Ľe fonu honau ngaahi fale  Ľi he ngaahi manu fakalielia; pea  Ľe nofo ai  Ľae ngaahi lulu, pea  Ľe me Ľe ai  Ľae fa Ľahi kehe  Ľoe vao.  
\v 22 Pea  Ľe tangi  Ľi honau ngaahi fale li Ľaki  Ľae fanga manu kaivao  Ľoe  Ľotu motu, pea mo e ngaahi talńĀkoni  Ľi honau ngaahi fale faka Ľei Ľeiki: pea kuo ofi  Ľae hokosia  Ľa hono kuonga, pea  Ľe  Ľikai fakalŇćloa hono ngaahi  Ľaho.   
\c 14  
\cd \it 1 Ko e  Ľalo Ľofa fakamo Ľui  Ľae  ĽOtua kia  ĽIsileli. 4 Ko  Ľenau vikiviki fiefia ki Papilone. 24 Ko e tu Ľutu Ľuni  Ľae  ĽOtua ki  ĽAsilia. 29  ĽOku fakamana ki Filisitia.\it*  
\p
\v 1 Koe Ľuhi  Ľe  Ľalo Ľofa  Ľa Sihova kia Sńďkope, pea te ne fili  Ľa  ĽIsileli,  Ľe fokotu Ľu  Ľakinautolu  Ľi honau fonua: pea  Ľe fakataha mo kinautolu  Ľae kakai muli, pea te nau pikitai ki he fale  Ľo Sńďkope.  
\v 2 Pea  Ľe tataki  Ľakinautolu  Ľe he kakai,  Ľo  Ľomi  Ľakinautolu ki honau potu: pea  Ľe ma Ľu  Ľakinautolu  Ľe he fale  Ľo  ĽIsileli  Ľi he fonua  Ľo Sihova ko e kau tamaio Ľeiki mo e kau kaunanga: pea te nau fakapŇćpula Ľi  Ľakinautolu, na Ľa nau pŇćpula ki ai; pea te nau pule Ľi  Ľakinautolu na Ľe fakamńĀlohi Ľi  Ľakinautolu.  
\v 3 Pea  Ľe hoko  Ľo pehńď,  Ľi he  Ľaho ko ia  Ľe foaki kiate koe  Ľae mńĀlŇćlŇć mei ho Ľo mamahi, mo ho Ľo manavahńď, pea mei he pŇćpula mamahi  Ľaia na Ľa mou mo Ľulaloa ki ai.   
\p
\v 4 ¬∂ Te ke to Ľo hake  Ľae lea mamafa ni ki he tu Ľi  Ľo Papilone,  Ľo pehńď, ‚ÄúHono  Ľikai kuo si Ľaki  Ľaia na Ľe pule fakamńĀlohi! hono  Ľikai kuo si Ľaki  Ľae kolo na Ľe fa Ľa kumi koula!  
\v 5 Kuo fesi Ľi  Ľe Sihova  Ľae tokotoko  Ľoe angakovi, pea mo e faka Ľilonga  Ľoe kau pule.  
\v 6 Ko ia na Ľe taa Ľi  Ľae kakai  Ľi he tuputńĀmaki  Ľaki  Ľae tautea ta Ľetuku, ko ia na Ľe pule Ľi  Ľae ngaahi pule Ľanga  Ľi he  Ľita, kuo fakatanga Ľi ia, pea  Ľoku  Ľikai ta Ľofi  Ľe ha taha.  
\v 7 ‚ÄĆ ĽOku mńĀlŇćlŇć  Ľa mńĀmani kotoa pńď, pea fiemńĀlie:  Ľoku nau kamata hiva fiefia.  
\v 8 ‚ÄĆ ĽIo,  Ľoku fiefia  Ľiate koe  Ľae ngaahi  Ľakau ko e paini, pea mo e ngaahi sita  Ľo Lepanoni,  Ľonau pehńď, Talu ho Ľo tŇć ki lalo koe, kuo  Ľikai ha Ľu kiate kimautolu ha tangata ta Ľanga.  
\v 9 ‚ÄĆ ĽOku ngaue  Ľa hńďtesi mei lalo ma Ľau ke fakafetaulaki kiate koe  Ľi ho ha Ľu:  Ľoku ne ue Ľi  Ľae mate ma Ľau,  Ľio,  Ľae kau tu Ľu ki mu Ľa kotoa pńď  Ľo mńĀmani; kuo ne fokotu Ľu mei honau nofo Ľanga  Ľae ngaahi tu Ľi kotoa pńď  Ľoe ngaahi pule Ľanga.  
\v 10 ‚ÄĆ ĽE lea  Ľakinautolu kotoa pńď  Ľo pehńď kiate koe, ‚ÄúKuo ke hoko  Ľo vaivai  Ľo hangńď ko kimautolu ni? Kuo ke hoko  Ľo tatau mo kimautolu ni?‚ÄĚ  
\v 11 Kuo fakahifo ho Ľo laukau ki he fa Ľitoka, pea mo e longoa Ľa  Ľo ho Ľo ngaahi me Ľa lea: kuo fofola  Ľi lalo  Ľiate koe  Ľae fanga kelemutu, pea kafu  Ľaki koe  Ľae fanga kelemutu.  
\v 12 ‚Äú ĽE LusifńĀ, ko e foha  Ľoe pongipongi! Hono  Ľikai tŇć hifo koe mei he langi! Hono  Ľikai tu Ľusi ki lalo koe ki he kelekele,  Ľa koe ne ke fakavaivai Ľi  Ľae ngaahi pule Ľanga!‚ÄĚ  
\v 13 He na Ľa ke pehńď  Ľi ho loto, ‚ÄúTe u  Ľalu hake ki he langi, te u fokotu Ľu ke mńĀ Ľolunga hake  Ľa hoku nofo Ľanga  Ľi he ngaahi fetu Ľu  Ľoe  ĽOtua: pea te u nofo  Ľi he mo Ľunga  Ľoe fakataha Ľanga,  Ľi he ngaahi potu tokelau:  
\v 14 Te u  Ľalu hake ke mńĀ Ľolunga  Ľi he ngaahi  Ľao; te u tatau mo ia  Ľoku mńĀ Ľolunga taha pe.‚ÄĚ  
\v 15 ‚ÄúKa e hifo koe ki lalo ki he fa Ľitoka, ki he kaokao  Ľoe luo.  
\v 16 Ko kinautolu  Ľe mamata kiate koe te nau sio fakamama Ľu kiate koe, pea fakalaulauloto kiate koe,  Ľo pehńď, ‚ÄėKo e tangata końĀ eni na Ľe ngaohi ke tetetete ai  Ľa mńĀmani,  Ľaia na Ľe lulululu  Ľae ngaahi pule Ľanga;  
\v 17 ‚ÄĆ ĽAia na Ľa ne ngaohi  Ľa mńĀmani ke hangńď ko ha toafa, pea ne faka Ľauha hono ngaahi kolo;  Ľaia na Ľe  Ľikai fakaava  Ľae fale  Ľo  Ľene kau pŇćpula?‚Äô‚ÄĚ  
\v 18 ‚ÄĆ ĽOku takoto  Ľi he nńĀunau  Ľae tu Ľi kotoa pńď  Ľoe ngaahi pule Ľanga,  Ľio,  Ľakinautolu kotoa pńď, taki taha  Ľi hono fale.  
\v 19 Ka kuo lńę koe mei ho fonualoto  Ľo hangńď ko e va Ľa fakalielia, pea hangńď ko e kofu  Ľokinautolu kuo tńĀmate Ľi,  Ľaia kuo hoka Ľi  Ľaki  Ľae heletńĀ,  Ľaia  Ľoku  Ľalu hifo ki he ngaahi maka  Ľoe luo; pea hangńď ko e  Ľanga Ľanga kuo malamalaki  Ľi he lalo va Ľe.  
\v 20 ‚ÄĆ ĽE  Ľikai fai fakataha ho tanu mo kinautolu, koe Ľuhi kuo ke faka Ľauha ho fonua, pea tńĀmate Ľi mo ho Ľo kakai:  Ľe  Ľikai  Ľaupito ongoongolelei  Ľae hako  Ľoe fai me Ľa kovi.  
\v 21 Teu Ľi  Ľae fakapŇć ki he Ľene fńĀnau koe Ľuhi ko e hia  Ľa  Ľenau ngaahi tamai; ke  Ľoua na Ľa nau tu Ľu hake, pe ma Ľu  Ľae fonua, pe  Ľufi Ľufi  Ľaki  Ľae funga  Ľo mńĀmani  Ľae ngaahi kolo.  
\v 22 He  Ľoku pehńď  Ľe Sihova  Ľoe ngaahi kautau, ‚ÄúTe u tu Ľu hake kiate kinautolu, pea tu Ľusi mei Papilone  Ľae hingoa, mo hono toenga \add kakai\add*, mo e foha, pea mo e fńĀnau  Ľa hono foha,  Ľoku pehńď  Ľe Sihova.  
\v 23 ‚ÄĆ ĽOku pehńď foki  Ľe Sihova  Ľoe ngaahi kautau, Te u ngaohi ia ko e potu  Ľoe pitani, mo e ngaahi luo vai; pea te u tafi kitu Ľaniu ia  Ľaki  Ľae me Ľa tafi  Ľoe faka Ľauha.‚ÄĚ   
\p
\v 24 ¬∂ Kuo fuakava  Ľa Sihova  Ľoe ngaahi kautau,  Ľo pehńď, ‚ÄúKo e mo Ľoni  Ľe hoko  Ľo hangńď ko ia kuo u fifili ki ai, pea hangńď ko ia kuo u tu Ľutu Ľuni, ko ia pe  Ľe tu Ľu ma Ľu:  
\v 25 Ke u laiki  Ľae tangata  ĽAsilia  Ľi hoku fonua pea te u malaki hifo ia  Ľi hoku ngaahi mo Ľunga: pea  Ľe toki mahu Ľi  Ľiate kinautolu  Ľa  Ľene ha Ľamonga, pea hiki mo  Ľene kavenga mei honau uma.  
\v 26 Ko eni  Ľae me Ľa kuo tu Ľutu Ľuni ki mńĀmani kotoa pńď: pea ko eni  Ľae nima kuo mafao atu ki he ngaahi pule Ľanga kotoa pńď.‚ÄĚ  
\v 27 He kuo finangalo ki ai  Ľa Sihova  Ľoe ngaahi kautau, pea ko hai te ne ta Ľofi ia? Pea kuo mafao atu hono nima, pea ko hai te ne fakafoki ia?  
\v 28 ‚ÄĆ ĽI he ta Ľu na Ľe pekia ai  Ľae tu Ľi ko  ĽAhasi na Ľe fakahńĀ  Ľae tala mamafa ni.   
\p
\v 29 ¬∂ ‚Äú ĽOua na Ľa ke fiefia,  Ľe Filisitia kotoa, koe Ľuhi kuo fesi Ľi  Ľae me Ľa tńĀ  Ľo ia na Ľa ne taa Ľi koe: koe Ľuhi  Ľe tupu mai mei he tefito  Ľoe ngata  Ľae ngata fekai lahi, pea ko hono fua  Ľo ia ko e ngata vela  Ľoku puna.  
\v 30 Pea  Ľe mńĀkona  Ľae  Ľuluaki fńĀnau  Ľae paea, pea  Ľe tokoto  Ľi he fiemńĀlie  Ľae masiva: pea te u tńĀmate Ľi ho tefito  Ľaki  Ľae honge, pea te ne taa Ľi ho toenga\add kakai\add*.  
\v 31 Tangi,  Ľae matapńĀ, tńĀngiloa,  Ľae kolo;  Ľa koe, ko Filisitia kotoa, kuo mole  Ľi he manavahńď: koe Ľuhi  Ľe ha Ľu mei he tokelau  Ľae  Ľohuafi, pea  Ľe  Ľikai he ha tokotaha  Ľi he Ľene ngaahi kautau.  
\v 32 Pea ko e hńĀ ha lea  Ľe tali  Ľaki  Ľe ha tokotaha ki he kau talafekau mei he pule Ľanga?  ĽA eni, Kuo langa hake  Ľe Sihova  Ľa Saione, pea  Ľe falala ki ai  Ľae kau masiva  Ľa hono kakai.‚ÄĚ   
\c 15  
\cd \it 1‚Äď9 Ko e mala Ľia  Ľo Moape.\it*  
\p
\v 1 Ko e tala mamafa  Ľoku kau ki Moape. Koe Ľuhi kuo faka Ľauha  Ľa  ĽAla-Moape  Ľi he pŇć, pea fakalongo pńď ia; koe Ľuhi kuo faka Ľauha  Ľa Kili Moape  Ľi he pŇć, pea fakalongo pńď ia;  
\v 2 Kuo  Ľalu ia ki Pasiti, pea ki Tiponi, ko e ngaahi potu mńĀ Ľolunga, ke tangi:  ĽE tangilńĀulau  Ľa Moape kia Nipo, pea kia Mitipa:  Ľe tula honau  Ľulu kotoa pńď, pea  Ľe kosi  Ľae kava kotoa pńď.  
\v 3 Te nau nono Ľo  Ľaki  Ľae tauanga Ľa  Ľi honau ngaahi hala: pea tangilńĀulau kotoa pńď, pea tangi lahi  Ľi honau tu Ľa fale, pea  Ľi honau ngaahi hala.  
\v 4 Pea  Ľe tangi  Ľa Hesiponi, mo  ĽIliale:  Ľe ongo Ľi honau le Ľo  Ľo a Ľu ki Sehasi: ko ia  Ľe kalanga ai  Ľae kautau to Ľo mahafu  Ľo Moape;  Ľe mamahi ai ia  Ľi he Ľene mo Ľui.  
\v 5 ‚ÄĆ ĽE tangi hoku loto koe Ľuhi ko Moape;  Ľe  Ľalu ki Soa  Ľene kau hola,  Ľo hangńď ha pulu kuo tolu ta Ľu:  Ľoku nau tangi  Ľi he Ľenau  Ľalu hake ki Luhiti;  Ľio,  Ľi he hala  Ľo Holonaimi te nau kalanga  Ľaki  Ľae tangi  Ľoe faka Ľauha.  
\v 6 Koe Ľuhi  Ľe lala  Ľae ngaahi vai  Ľo Nimilimi: he kuo mae  Ľae mohuku mŇćmoa, pea kuo  Ľikai  Ľae mohuku mata, pea  Ľoku  Ľikai ha me Ľa lau ma Ľui Ľui.  
\v 7 Ko ia ko e koloa lahi kuo nau ma Ľu, pea mo ia kuo nau tńĀnaki, te nau  Ľave ki he vaitafe  Ľoe ngaahi uilou.  
\v 8 He kuo takatakai  Ľe he tangi  Ľae ngata Ľanga  Ľo Moape; kuo a Ľu  Ľene kalanga ki Ekelemi, pea mo e tangilńĀulau  Ľo ia ki Pealimi.  
\v 9 ‚ÄĆ ĽE fonu  Ľae ngaahi vai  Ľo Timoni  Ľi he toto: he te u toe  Ľomi  Ľae kovi ki Timoni,  Ľae fanga laione kiate ia  Ľoku hao  Ľi Moape, pea ki hono toe  Ľoe fonua.   
\c 16  
\cd \it 1  ĽOku enginaki kia Moape ke talangofua ki he pule  Ľa Tevita. 6  ĽOku fakamana Ľi  Ľa Moape koe Ľuhi ko  Ľene laukau. 9  ĽOku  Ľofa mamahi  Ľae palŇćfita kiate ia. 12 Ko e fakamaau  Ľa Moape.\it*  
\p
\v 1 Ke mou fekau ke  Ľave  Ľae lami ki he pule  Ľoe fonua mei Sila  Ľo a Ľu ki he toafa, ki he mo Ľunga  Ľoe  Ľofefine  Ľo Saione.  
\v 2 Koe Ľuhi  Ľe hangńď ko e manu he  Ľoku kapusi mei hono pununga,  Ľe pehńď  Ľae  Ľofefine  Ľo Moape  Ľi he ngaahi potu mamaha  Ľa  ĽAlinoni.  
\v 3 Mou fakakaukau, fai fakapotopoto; ngaohi ho ĽatńĀ ke hangńď ko e pŇć  Ľi he ho ĽatńĀmńĀlie; fufŇę  Ľae kau  ĽńĀuhńď;  Ľoua na Ľa fakahńĀ  Ľaia  Ľoku  Ľalu hńďhńď.  
\v 4 Tuku ke nofo kiate koe  Ľa  Ľeku kau  ĽńĀuhńď,  Ľe Moape; ke ke hoko ko e unga Ľanga kiate kinautolu mei he mata  Ľoe kaiha Ľa: he kuo ngata  Ľaia  Ľoku fakamńĀlohi, kuo tuku  Ľae kaiha Ľa, kuo  Ľauha  Ľae kau fakamamahi mei he fonua.  
\v 5 Pea  Ľe fokotu Ľuma Ľu  Ľae nofo Ľanga  Ľoe tu Ľi  Ľi he  Ľalo Ľofa: pea te ne nofo ai  Ľi he mo Ľoni  Ľi he fale fehikitaki  Ľo Tevita,  Ľo fai  Ľae fakamaau, pea kumi ki he angatonu, mo fakavave  Ľae mńĀ Ľoni Ľoni.   
\p
\v 6 ¬∂ Kuo mau fanongo ki he laukau  Ľa Moape;  Ľoku laukau  Ľaupito ia:  Ľio  Ľi he Ľene fielahi, mo  Ľene laukau, mo  Ľene  Ľita: ka ko e me Ľa ta Ľe Ľaonga  Ľene ngaahi loi.  
\v 7 Ko ia  Ľe tńĀngiloa  Ľa Moape koe Ľuhi ko Moape,  Ľe tangi  Ľae kakai kotoa pńď: te mou mamahi koe Ľuhi ko e ngaahi tu Ľunga  Ľo Kili-Haleseti; he ko e mo Ľoni kuo taa Ľi  Ľakinautolu.  
\v 8 He kuo mae  Ľae ngoue  Ľo Hesiponi, pea mo e vaine  Ľo Sipima: kuo fesi Ľi hifo  Ľe he hou Ľeiki  Ľoe hiteni  Ľa hono ngaahi  Ľakau lelei, kuo nau ha Ľu ki Sesa, na Ľa nau  Ľalu fano  Ľi he toafa: kuo mafola atu hono ngaahi va Ľa, kuo nau ika  Ľi he tahi.  
\v 9 Ko ia te u tangi  Ľi he tangi  Ľo Sesa koe Ľuhi ko e vaine  Ľo Sipima: te u fakaviviku koe  Ľaki hoku lo Ľimata,  ĽE Hesiponi, mo  ĽIliale: he kuo  Ľosi  Ľae kalanga koe Ľuhi ko e ngaahi fua  Ľoe fa Ľahita Ľu mafana pea mo ho Ľo ututa Ľu.  
\v 10 Kuo to Ľo  Ľo mole  Ľae fiefia, mo e nekeneka mei he  Ľapi mahu; pea  Ľe  Ľikai ha hiva, pe ha kalanga  Ľe fai  Ľi he ngaahi ngoue vaine:  Ľe  Ľikai toe malaki ha uaine  Ľe he kau malaki  Ľi he ngaahi tata Ľo Ľanga; kuo u pule ke tuku  Ľenau kalanga fiefia.  
\v 11 Ko ia  Ľe tangi  Ľa hoku fatu  Ľo hangńď ko ha ha Ľape koe Ľuhi ko Moape, mo hoku to Ľoto Ľonga koe Ľuhi ko Kili-Haleseti.  
\v 12 Pea  Ľe hoko  Ľo pehńď,  Ľoka hńĀ mai kuo ongosia  Ľa Moape  Ľi he potu mńĀ Ľolunga, pea te ne ha Ľu ki hono potu tapu ke hŇę; ka e  Ľikai te ne lava Ľi.  
\v 13 Ko eni  Ľae folofola kuo folofola Ľaki  Ľe Sihova, ki Moape talu  Ľae kuonga ko ia.  
\v 14 Ka ko eni kuo folofola  Ľa Sihova,  Ľo pehńď, ‚Äú ĽI he te Ľeki kakato  Ľae ta Ľu  Ľe tolu, hangńď ko e ta Ľu  Ľo ha taha  Ľoku ngńĀue kae totongi,  Ľe fakavaivai Ľi  Ľae nńĀunau  Ľo Moape, mo e fu Ľu tokolahi  Ľoku  Ľi ai; pea  Ľe si Ľi  Ľaupito pea vaivai  Ľa hono toenga.‚ÄĚ   
\c 17  
\cd \it 1  ĽOku fakamana Ľi  Ľa Silia mo  ĽIsileli. 6  ĽE liaki  Ľae tauhi tamapua  Ľe he toe  Ľoe kakai. 9  ĽE fakamamahi Ľi hono to Ľo koe Ľuhi ko  Ľenau anga ta Ľelotu. 12 Ko e mala Ľia  Ľae ngaahi fili  Ľo  ĽIsileli.\it*  
\p
\v 1 Ko e tala mamafa  Ľoku kau ki Tamasikusi. ‚ÄúVakai kuo to Ľo atu  Ľa Tamasikusi ke  Ľoua na Ľa kei kolo ia, ka e hoko ia ko e potu tu Ľunga fale maumau.  
\v 2 Kuo li Ľaki  Ľae ngaahi kolo  Ľo  ĽAloeli:  Ľe  Ľoe fanga manu ia, pea te nau tokoto ai, pea  Ľe  Ľikai ha taha ke fakamanavahńď Ľi  Ľakinautolu.  
\v 3 ‚ÄĆ ĽOku pehńď  Ľe Sihova  Ľoe ngaahi kautau,  ĽE ngata  Ľae kolo  Ľi  ĽIfalemi, mo e pule Ľanga  Ľo Tamasikusi, pea mo e toenga kakai  Ľo Silia: te nau hangńď ko e ongoongolelei  Ľoe fńĀnau  Ľa  ĽIsileli.  
\v 4 Pea  Ľi he  Ľaho ko ia  Ľe hoko  Ľo pehńď,  Ľe fakasi Ľisi Ľi  Ľae ongoongolelei  Ľo Sńďkope, pea  Ľe faka Ľa Ľau ke tutue  Ľae ngako  Ľo hono sino.  
\v 5 Pea  Ľe hangńď ia ko e tńĀnaki  Ľe he tangata ututa Ľu  Ľene koane, pea tu Ľusi hono fua  Ľaki hono nima; pea  Ľe hangńď ia ko ia  Ľoku tńĀnaki  Ľae fua  Ľi he tele Ľa  Ľo Lifeimi.   
\p
\v 6 ¬∂ ‚ÄúKa e fakatoe  Ľi ai  Ľae fua  Ľoe vaine,  Ľo hangńď ko e lulululu  Ľae  Ľakau ko e  Ľolive, ko e fo Ľi fua  Ľe ua pe tolu  Ľi  Ľolunga  Ľi he va Ľa taupotu ki  Ľolunga, ko e fńĀ pe nima  Ľi he ngaahi va Ľa taukakapa  Ľo ia  Ľoku fua,  Ľoku pehńď  Ľe Sihova ko e  ĽOtua  Ľo  ĽIsileli.  
\v 7 ‚ÄĆ ĽI he  Ľaho ko ia  Ľe hanga hake  Ľae tangata ki hono Tupu Ľanga, pea  Ľe tokanga  Ľa hono mata ki he tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli.  
\v 8 Pea  Ľe  Ľikai te ne sio ki he ngaahi feilaulau Ľanga, ko e ngńĀue  Ľa hono nima, pe tokanga ki he me Ľa kuo ngaohi  Ľe hono louhi Ľi nima, ki he ngaahi vao tapu, pe ko e ngaahi tamapua.   
\p
\v 9 ¬∂ ‚Äú ĽI he  Ľaho ko ia  Ľe tatau hono ngaahi kolo mńĀlohi mo ha va Ľa kuo li Ľaki, mo ha va Ľa mńĀ Ľolunga,  Ľaia na Ľa nau tuku koe Ľuhi ko e fńĀnau  Ľa  ĽIsileli: pea  Ľe  Ľi ai  Ľae faka Ľauha.  
\v 10 Ko e me Ľa  Ľi ho Ľo fakangalongalo Ľi  Ľae  ĽOtua  Ľo ho Ľo mo Ľui, pea ta Ľemanatu ki he maka  Ľo ho mńĀlohi, ko ia te ke tŇć  Ľae ngaahi  Ľakau toulekeleka, pea tŇć mo ia  Ľae ngaahi  Ľakau mei he fonua kehe:  
\v 11 ‚ÄĆ ĽI he  Ľaho ko ia te ke ngaohi ho Ľo  Ľakau ke tupu, pea  Ľi he pongipongi te ke ngaohi ho Ľo tenga ke mo Ľui: ka e hoko  Ľae ututa Ľu ko e fokotu Ľunga  Ľi he  Ľaho  Ľoe mamahi, ko e mamahi ta Ľe Ľiaiha Ľamanaki lelei.   
\p
\v 12 ¬∂ ‚Äú ĽE mala Ľia  Ľae fakataha lahi  Ľoe kakai tokolahi,  Ľoku longoa Ľa  Ľo hangńď ko e  Ľu Ľulu  Ľoe tahi; pea  Ľi he fe Ľohofi  Ľoe ngaahi pule Ľanga,  Ľoku  Ľoho  Ľo hangńď ko e  Ľoho  Ľoe ngaahi vai lahi  Ľaupito!  
\v 13 ‚ÄĆ ĽE fe Ľohofi  Ľae ngaahi pule Ľanga  Ľo hangńď ko e  Ľoho  Ľoe ngaahi vai lahi: ka e lolomi  Ľakinautolu\add  Ľe he  ĽOtua\add*, pea te nau hola ki he mama Ľo, pea  Ľe tulia  Ľakinautolu  Ľo hangńď ko e mohuku mŇćmoa  Ľoe ngaahi mo Ľunga  Ľoku vilingia  Ľi he matangi, pea hangńď ko e fisi Ľi Ľakau  Ľi he  Ľao  Ľoe  Ľahiohio.  
\v 14 Pea vakai ko e ongosia  Ľi he efiafi po Ľuli; pea  Ľi he te Ľeki hoko  Ľae pongipongi kuo  Ľikai ia. Ko eni  Ľae  Ľinasi  Ľokinautolu  Ľoku fakamńĀlohi Ľi  Ľakitautolu, mo e  Ľinasi  Ľokinautolu  Ľoku kaiha Ľasi Ľi  Ľakitautolu.‚ÄĚ   
\c 18  
\cd \it 1  ĽE faka Ľauha  Ľe he  ĽOtua  Ľae kakai  ĽItiopea  Ľi he Ľene  Ľofa ki hono kakai. 7 Ko ia  Ľe hoko ai  Ľae  Ľulu Ľi ki he siasi.\it*  
\p
\v 1 ‚ÄĆ ĽE  Ľa koe! Ko e fonua  Ľoku lolofa ai  Ľae kapakau,  Ľaia  Ľoku tu Ľu kitu Ľa  Ľi he vaitafe  Ľo  ĽItiopea:  
\v 2 ‚ÄĆ ĽA koe  Ľoku kouna atu  Ľene kau talafekau  Ľi he tahi,  Ľi he ngaahi vaka papailusi  Ľi he fukahi vai,  Ľo pehńď,  ĽAlu,  Ľakimoutolu  Ľae kau talafekau ve Ľe vave, ki he pule Ľanga lŇćloa mo lafalafa, ki he kakai fakamanavahńď talu mei honau kamata Ľanga  Ľo a Ľu ki heni; ko e pule Ľanga kuo fua  Ľaki  Ľae afo pea fa Ľa molomoloki,  Ľaia kuo maumau  Ľe he ngaahi vaitafe!  
\v 3 ‚ÄĆ ĽAkimoutolu  Ľae kakai kotoa pńď  Ľo mńĀmani, mo kimoutolu  Ľoku nofo  Ľi he funga fonua, mou vakai,  Ľoka fokotu Ľu  Ľe ia ha fuka  Ľi he ngaahi mo Ľunga; pea  Ľi he ifi  Ľe ia  Ľae kelea, mou fanongo.  
\v 4 He na Ľe pehńď  Ľe Sihova kiate au, ‚ÄúTe u mńĀlŇćlŇć, pea te u tokanga Ľi hoku fale  Ľo hangńď ko e mafana hili  Ľae  Ľuha, pea hangńď ko ha  Ľao  Ľoe hahau  Ľi he  Ľaho  Ľoe ututa Ľu.‚ÄĚ  
\v 5 ‚ÄĆ ĽI he te Ľeki ai hoko  Ľae ututa Ľu,  Ľaia  Ľoku haohaoa ai hono fua, pea  Ľoku faka Ľa Ľau ke momoho  Ľae kńĀlepi mei hono fisi, te ne fakatou tu Ľusi  Ľae ngaahi huli  Ľaki  Ľae hele tu Ľusi, pea  Ľave mo tu Ľusi hifo  Ľae ngaahi va Ľa.  
\v 6 ‚ÄĆ ĽE tuku fakataha ia ki he manupuna  Ľoe ngaahi mo Ľunga, pea ki he fanga manu fekai  Ľoe kelekele: ko e ngaahi manupuna te nau kai ai  Ľi he fa Ľahita Ľu mafana, pea  Ľe kai ai  Ľae manu fekai kotoa pńď  Ľoe kelekele  Ľi he fa Ľahita Ľu momoko.   
\p
\v 7 ¬∂  ĽI he kuonga ko ia  Ľe  Ľomi kia Sihova  Ľoe ngaahi kautau,  Ľae me Ľa foaki mei he fonua lŇćloa mo lafalafa, pea mei he kakai fakamanavahńď talu mei honau tupu Ľanga  Ľo a Ľu mai; ko e pule Ľanga kuo fua  Ľaki  Ľae afo pea fa Ľa molomoloki,  Ľaia kuo maumau Ľi  Ľe he ngaahi vaitafe; ki he potu  Ľoe huafa  Ľo Sihova  Ľoe ngaahi kautau, ki he mo Ľunga ko Saione.‚ÄĚ   
\c 19  
\cd \it 1 Ko e maveuveu  Ľo  ĽIsipite. 11 Ko e vale  Ľo honau hou Ľeiki. 18 Ko e ui  Ľo  ĽIsipite ki ho siasi. 23 Ko e fefuakava Ľaki  Ľa  ĽIsipite, mo  ĽAsilia, mo  ĽIsileli.\it*  
\p
\v 1 Ko e tala mamafa  Ľoku kau ki  ĽIsipite. Vakai,  Ľoku heka  Ľa Sihova  Ľi he  Ľao ngaholo,  Ľo hńĀ Ľele ki  ĽIsipite: pea  Ľe tetetete  Ľae ngaahi tamapua  Ľo  ĽIsipite  Ľi hono  Ľao, pea  Ľe vaivai  Ľae loto  Ľo  ĽIsipite  Ľi loto  Ľiate ia.  
\v 2 Pea te u fakafehi Ľa  Ľae kakai  ĽIsipite ki he kakai  ĽIsipite: pea  Ľe tau  Ľae tangata taki taha kotoa pńď ki hono tokoua, pea taki taha ki hono kaungńĀ Ľapi;  Ľae kolo ki he kolo, mo e pule Ľanga ki he pule Ľanga.  
\v 3 Pea  Ľe vaivai  Ľae laumńĀlie  Ľo  ĽIsipite  Ľi he lotolotonga  Ľo ia; pea te u maumau Ľi  Ľae fakakaukau  Ľa Ľana: pea te nau kumi ki he ngaahi tamapua, pea ki he kau fiemana, pea kiate kinautolu  Ľoku ai  Ľae ngaahi laumńĀlie kovi, pea ki he kau kikite.  
\v 4 Pea  Ľoku pehńď  Ľe he  ĽEiki, ko Sihova  Ľoe ngaahi kautau, Te u tuku atu  Ľae kakai  Ľo  ĽIsipite ki he nima  Ľo ha  Ľeiki  Ľoku fakamamahi; pea  Ľe pule Ľi  Ľakinautolu  Ľe ha tu Ľi  Ľoku fai mńĀlohi.  
\v 5 Pea  Ľe maha  Ľae ngaahi vai mei he tahi, pea  Ľe faka Ľa Ľau ke mŇćmoa  Ľae vaitafe.  
\v 6 Pea te nau fakanamukŇę Ľi  Ľae ngaahi vaitafe; pea ko e ngaahi vai  Ľoku mou fa Ľaki ki ai  Ľe fakamaha pea  Ľe mŇćmoa:  Ľe mae  Ľae ngaahi kaho mo e falaki.  
\v 7 Ko e ngoue  Ľi he ve Ľe vai,  Ľi he ngutu  Ľoe ngaahi vai, pea mo e ngaahi me Ľa kotoa pńď  Ľoku tŇętuu Ľi  Ľi he ve Ľe vai,  Ľe mae,  Ľe mole, pea  Ľikai.  
\v 8 ‚ÄĆ ĽE mamahi foki  Ľae kau toutai ika, pea  Ľe lńĀunga mo kinautolu kotoa pńď  Ľoku taumńĀta Ľu  Ľi he ngaahi vai, pea  Ľe vaivai mo kinautolu  Ľoku lafo kupenga ki he ngaahi vai.  
\v 9 Pea ko kinautolu foki  Ľoku ngaohi  Ľae tupenu lelei, pea mo kinautolu  Ľoku lalanga  Ľae tupenu vavanga,  Ľe faka Ľa Ľau ke vaivai.  
\v 10 Pea  Ľe maumau Ľi  Ľae ngaahi tu Ľutu Ľuni  Ľokinautolu  Ľoku ngaohi  Ľae ngaahi matapńĀ mo e anovai ki he ika.   
\p
\v 11 ¬∂ Ko e mo Ľoni ko e kau vale  Ľae hou Ľeiki  Ľo Soani, ko e fakakaukau  Ľoe kau poto  Ľo Felo kuo hoko ia ko e fakakaukau vale: ko e hńĀ  Ľoku mou pehńď ai kia Felo, Ko au ko e foha  Ľoe poto, ko e hako  Ľoe ngaahi tu Ľi  Ľi mu Ľa?  
\v 12 ‚ÄĆ ĽOku  Ľi fńď  Ľakinautolu?  ĽOku  Ľi fńď ho Ľo kau tangata poto? Tuku ke nau fakahńĀ atu ni kiate koe, pea tuku ke nau  Ľilo pe ko e hńĀ  Ľae finangalo  Ľo Sihova  Ľoe ngaahi kautau ki  ĽIsipite,  
\v 13 Kuo hoko  Ľo vale  Ľae hou Ľeiki  Ľo Soani, kuo kńĀkaa Ľi  Ľae hou Ľeiki  Ľo Nofi; pea kuo nau fakahala  Ľa  ĽIsipite  Ľae mńĀlohi Ľanga  Ľo hono ngaahi fa Ľahinga.  
\v 14 Kuo tuku  Ľe Sihova ki honau lotolotonga ha laumńĀlie talangata Ľa: pea kuo nau fakahala Ľi  Ľa  ĽIsipite  Ľi he Ľene ngaahi ngńĀue kotoa pńď,  Ľo hangńď ko e tasipa  Ľae tangata konńĀ  Ľi he Ľene lua.  
\v 15 Pea  Ľe  Ľikai ha ngńĀue ki  ĽIsipite,  Ľe fa Ľa fai  Ľe he  Ľulu pe ko e iku,  Ľe he va Ľa pe ko e tefito.  
\v 16 ‚ÄĆ ĽE tatau  Ľa  ĽIsipite  Ľi he  Ľaho ko ia mo e kau fefine: pea  Ľe tetetete mo manavahńď ia koe Ľuhi ko e lulululu  Ľoe nima  Ľo Sihova  Ľoe ngaahi kautau,  Ľaia te ne lulululu kiate kinautolu.  
\v 17 Pea  Ľe hoko  Ľae fonua ko Siuta ko e ilifia Ľanga ki  ĽIsipite, pea ko kinautolu kotoa pńď  Ľoku lea ki ai  Ľe tetetete, koe Ľuhi ko e tu Ľutu Ľuni  Ľa Sihova  Ľoe ngaahi kautau,  Ľaia kuo ne fakakaukau ki ai.   
\p
\v 18 ¬∂  ĽI he  Ľaho ko ia  Ľe lea  Ľaki  Ľae lea fakaKńďnani  Ľe he kolo  Ľe nima  Ľi he fonua ko  ĽIsipite, pea te nau fuakava kia Sihova  Ľoe ngaahi kautau; pea  Ľe ui  Ľae kolo  Ľe taha, ‚ÄúKo e kolo  Ľoe faka Ľauha.‚ÄĚ  
\v 19 ‚ÄĆ ĽI he  Ľaho ko ia  Ľe  Ľai  Ľae feilaulau Ľanga kia Sihova  Ľi he loto fonua  Ľo  ĽIsipite, pea mo ha pou kia Sihova  Ľi hono ngata Ľanga.  
\v 20 Pea  Ľe hoko ia ko e faka Ľilonga pea ko e fakamo Ľoni kia Sihova  Ľoe ngaahi kautau  Ľi he fonua ko  ĽIsipite: he te nau tangi kia Sihova koe Ľuhi ko e kau fakamńĀlohi, pea te ne fekau kiate kinautolu ha fakamo Ľui, ko e tokotaha  Ľoku lahi, pea te ne fakamo Ľui  Ľakinautolu.  
\v 21 Pea  Ľe  Ľilo Ľi  Ľa Sihova  Ľe  ĽIsipite, pea  Ľe  Ľilo  Ľe he kakai  ĽIsipite  Ľa Sihova  Ľi he  Ľaho ko ia, pea te nau fai  Ľae feilaulau mo e foaki;  Ľio, te nau fuakava  Ľaki ha fuakava kia Sihova, pea fai ki ai.  
\v 22 Pea  Ľe taa Ľi  Ľe Sihova  Ľa  ĽIsipite: te ne taa Ľi pea fakamo Ľui: pea te nau toe tafoki kia Sihova, pea te ne tali  Ľa  Ľenau hŇę, pea te ne fakamo Ľui  Ľakinautolu.   
\p
\v 23 ¬∂  ĽI he  Ľaho ko ia  Ľe ai ha hala motu Ľa mei  ĽIsipite ki  ĽAsilia, pea  Ľe ha Ľu  Ľae kau  ĽAsilia ki  ĽIsipite, pea  Ľe  Ľalu  Ľae kakai  ĽIsipite ki  ĽAsilia, pea  Ľe fai fakataha  Ľae kakai  ĽIsipite mo e kakai  ĽAsilia.  
\v 24 ‚ÄĆ ĽI he  Ľaho ko ia  Ľe lau ko hono toko tolu  Ľa  ĽIsileli fakataha mo  ĽIsipite mo  ĽAsilia,  Ľio, ko e tńĀpuaki  Ľi he loto fonua:  
\v 25 ‚ÄĆ ĽAia  Ľe tńĀpuaki  Ľe Sihova  Ľoe ngaahi kautau,  Ľo pehńď, ‚ÄėKe monŇę Ľia  Ľa  ĽIsipite ko hoku kakai, pea mo  ĽAsilia ko e ngńĀue  Ľa hoku nima, pea mo  ĽIsileli ko hoku tofi Ľa.‚Äô‚ÄĚ   
\c 20  
\cd \it 1‚Äď6 Ko e fakatńĀtńĀ  Ľoku fakahńĀ  Ľae pŇćpula lahi  Ľa  ĽIsipite mo  ĽItiopea.\it*  
\p
\v 1 ‚ÄĆ ĽI he ta Ľu na Ľe ha Ľu ai  Ľa Tatani ki  ĽAsitoti, (i he kuonga na Ľe fekau ia  Ľe Sakone ko e tu Ľi  Ľo  ĽAsilia,)  Ľo ne tau Ľi  Ľa  ĽAsitoti, pea lava Ľi ia;  
\v 2 ‚ÄĆ ĽI he kuonga pe ko ia na Ľe folofola  Ľa Sihova kia  ĽIsaia ko e foha  Ľo  ĽAmosi,  Ľo pehńď, ‚Äú ĽAlu  Ľo vete  Ľae tauanga Ľa mei ho Ľo no Ľotanga vala, pea to Ľo  Ľae topuva Ľe mei ho va Ľe. Pea na Ľa ne fai ia,  Ľo  Ľeve Ľeva ta Ľehakofu pea ta Ľetopuva Ľe.  
\v 3 Pea na Ľe pehńď  Ľe Sihova,  ĽO hangńď kuo  Ľeve Ľeva telefua pea ta Ľehatopuva Ľe  Ľa  Ľeku tamaio Ľeiki ko  ĽIsaia  Ľi he ta Ľu  Ľe tolu ko e faka Ľilonga mo e me Ľa fakaofo ki  ĽIsipite pea ki  ĽItiopea;  
\v 4 ‚ÄĆ ĽE pehńď  Ľae taki pŇćpula  Ľe he tu Ľi  Ľo  ĽAsilia  Ľae kakai  Ľo  ĽIsipite, pea mo e kakai pŇćpula  Ľo  ĽItiopea,  Ľae talavou mo e mńĀtu Ľa,  Ľae telefua mo e ta Ľehatopuva Ľe,  Ľio,  Ľi he ta Ľekofu honau kongaloto, ko e fakamńĀ  Ľoe kakai  ĽIsipite.  
\v 5 Pea te nau manavahńď pea mńĀ ki  ĽItiopea ko  Ľenau  Ľamanaki, pea mo  ĽIsipite ko honau vikiviki Ľanga.  
\v 6 Pea  Ľe pehńď  Ľae tangata  Ľoe fonua ni  Ľi he  Ľaho ko ia, ‚ÄėVakai  Ľoku pehńď  Ľemau  Ľamanaki,  Ľaia na Ľa mau hola ki ai ke ma Ľu  Ľae tokoni ke mau hao ai mei he tu Ľi  Ľo  ĽAsilia: pea  Ľe fńďfńď końĀ  Ľemau hao?‚Äô‚ÄĚ   
\c 21  
\cd \it 1  ĽI he mamahi  Ľae palŇćfita  Ľi he pŇćpula  Ľa hono kakai,  Ľoku ne mamata  Ľi he me Ľa hńĀ mai ki he fakahinga  Ľo Papilone  Ľe he kakai Mitia mo e kakai  Ľo Pesia. 11  ĽI he fehi Ľa  Ľa  ĽItomi ki he palŇćfita,  Ľoku ue Ľi ia ki he fakatomala. 13 Ko e kuonga kuo kotofa ki he mamahi  Ľo  ĽAlepea.\it*  
\p
\v 1 Ko e tala mamafa  Ľoku kau ki he toafa  Ľoe tahi.  ĽO hangńď  Ľoku  Ľasi  Ľi he feitu Ľu tonga  Ľae ngaahi  Ľahiohio;  Ľoku pehńď  Ľae ha Ľu ia mei he toafa, mei he fonua fakamanavahńď.  
\v 2 ‚ÄĆ ĽOku fakahńĀ mai kiate au  Ľae me Ľa hńĀ mai fakamanavahńď;  Ľoku fai kńĀkńĀ  Ľe he kńĀkńĀ, pea kuo veteki  Ľe ia  Ľoku vete.  ĽE  ĽIlami, ke ke  Ľalu hake:  ĽE Mitia, ke ke fai  Ľae kńĀpui; he kuo u faka Ľosi  Ľene ngaahi mamahi kotoa pńď.  
\v 3 Ko ia kuo fonu ai  Ľi he mamahi hoku kongaloto: kuo kuku au  Ľe he mamahi,  Ľo hangńď ko e mamahi  Ľae fefine  Ľoku langńĀ: na Ľaku mapelu  Ľi he fanongo ki ai; pea ne u manavahńď  Ľi he sio ki ai.  
\v 4 ‚ÄĆ ĽOku tateme hoku mafu,  Ľoku ilifia  Ľi he manavahńď: kuo ne liliu  Ľae pŇć  Ľo  Ľeku fiefia ko e manavahńď kiate au.  
\v 5 ‚ÄúTeuteu  Ľae keinanga Ľanga, le Ľo  Ľi he fale le Ľo, pea kai, mo inu: mou tu Ľu hake  Ľae ngaahi hou Ľeiki, pea tńĀkai  Ľae fakaŇę.‚ÄĚ  
\v 6 He kuo pehńď  Ľae folofola  Ľa Sihova kiate au, ‚Äú ĽAlu,  Ľo fakanofo ha tangata le Ľo, ke ne fakahńĀ  Ľaia  Ľoku ne mamata ki ai.  
\v 7 Pea na Ľa ne mamata ki he saliote mo e ongo tangata heka hoosi, ko e saliote mo e ngaahi  Ľasi, pea mo e saliote mo e fanga kńĀmeli; pea na Ľa ne fanongo  Ľi he tokanga lahi:‚ÄĚ  
\v 8 Pea na Ľa ne kalanga,  Ľo hangńď ko e laione: ‚ÄúKo hoku  ĽEiki,  Ľoku ou tu Ľuma Ľu aipńď  Ľi he fale le Ľo  Ľi he  Ľaho, pea  Ľoku ou nofo  Ľi hoku potu le Ľo  Ľi he ngaahi pŇć kotoa pńď:  
\v 9 Pea vakai,  Ľoku ha Ľu  Ľae saliote mo e kau tangata, mo e ongo tangata heka hoosi.‚ÄĚ Pea na Ľa ne lea  Ľo pehńď mai, ‚ÄúKuo hinga  Ľa Papilone, kuo hinga; pea kuo ne laiki ki he kelekele  Ľae fakatńĀtńĀ kotoa pńď  Ľo hono ngaahi  Ľotua  Ľoku tongi.‚ÄĚ  
\v 10 ‚ÄĆ ĽOiauńď!  ĽAe me Ľa kuo u haha, pea mo e uite  Ľo hoku haha Ľanga: ko ia kuo u fanongo meia Sihova  Ľoe ngaahi kautau, ko e  ĽOtua  Ľo  ĽIsileli, ko ia kuo u fakahńĀ kiate koe.   
\p
\v 11 ¬∂ Ko e tala mamafa  Ľoku kau ki Toma.  ĽOku ne ui kiate au mei Seia,  Ľae tangata le Ľo, ‚Äú ĽOku fńďfńď  Ľae pŇć?  ĽAe tangata le Ľo,  Ľoku fńďfńď  Ľae pŇć?‚ÄĚ  
\v 12 Na Ľe pehńď  Ľe he tangata le Ľo, ‚Äú ĽOku ha Ľu  Ľae pongipongi, pea mo e pŇć foki: kapau te mou fehu Ľi, mou fehu Ľi: tafoki, ha Ľu.‚ÄĚ   
\p
\v 13 ¬∂ Ko e tala mamafa  Ľoku kau ki  ĽAlepea.  ĽI he vao lahi  Ľi  ĽAlepea, te mou mohe,  Ľakimoutolu ko e kaunga fononga  Ľo Tetanimi.  
\v 14 Na Ľe  Ľomi  Ľe he kakai  Ľoe fonua ko Tima  Ľae vai kiate ia na Ľe fieinu, na Ľa nau tokoni  Ľaki  Ľenau mńĀ  Ľakinautolu na Ľe hola.  
\v 15 He na Ľa nau hola mei he ngaahi heletńĀ, mei he heletńĀ kuo to Ľo, pea mei he kaufana kuo teke, pea mo e ngaahi mamahi  Ľoe tau.  
\v 16 He kuo pehńď  Ľae folofola  Ľae  ĽEiki kiate au, ‚Äú ĽI he te Ľeki ai kakato ha ta Ľu  Ľe taha, hangńď ko e ngaahi ta Ľu  Ľo ha taha  Ľoku ngńĀue kae totongi,  Ľe ngata  Ľo  Ľosi  Ľae lelei kotoa pńď  Ľo Keta:  
\v 17 Pea  Ľe fakatokosi Ľi hono toe  Ľoe lau  Ľoe kau tangata fana,  Ľi he kau tangata mńĀlohi  Ľoe fńĀnau  Ľo Keta: he kuo folofola  Ľa Sihova ko e  ĽOtua  Ľo  ĽIsileli.‚ÄĚ   
\c 22  
\cd \it 1  ĽOku mamahi  Ľae palŇćfita  Ľi he tau Ľi  Ľa SelŇęsalema  Ľe he kakai  Ľo Pesia. 8  ĽOku ne valoki Ľi honau poto fakatangata mo e fiefia fakamaama. 15  ĽOku ne kikite ki he masiva  Ľa Sepina. 20 Pea ko hono fetongi ko Iliakimi,  Ľo ne fakatńĀtńĀ ki he pule Ľanga  Ľo Kalaisi.\it*  
\p
\v 1 Ko e tala mamafa  Ľoku kau ki he tele Ľa  Ľoe me Ľa hńĀ mai. Ko e hńĀ kuo hoko kiate koe, koe Ľuhi ke  Ľalu ai ho Ľo kakai kotoa pńď ki he ngaahi tu Ľa fale?  
\v 2 ‚ÄĆ ĽA koe  Ľoku ke fonu  Ľi he longoa Ľa, ko e kolo maveuveu, ko e kolo  Ľoe fakavńĀ: ko ho Ľo kakai kuo mate na Ľe  Ľikai mate  Ľi he heletńĀ, pe mate  Ľi he tau.  
\v 3 Kuo hola fakataha ho Ľo kau pule kotoa pńď, kuo ha Ľisia  Ľakinautolu  Ľe he kau tangata fana: ko kinautolu kotoa pńď  Ľoku  Ľilo  Ľiate koe kuo ha Ľi fakataha,  Ľakinautolu kuo hola mei he mama Ľo.  
\v 4 Ko ia na Ľaku pehńď, sio kehe meiate au; te u tangi mamahi,  Ľoua na Ľa  Ľahi Ľahi ke fakafiemńĀlie Ľi au, koe Ľuhi ko e maumau  Ľoe  Ľofefine  Ľo hoku kakai.  
\v 5 He ko e  Ľaho  Ľoe mamahi ia, mo e malaki hifo, pea mo e faingata Ľa, koe Ľuhi ko e  ĽEiki ko Sihova  Ľoe ngaahi kautau  Ľi he tele Ľa  Ľoe me Ľa hńĀ mai,  Ľi he maumau Ľi  Ľae ngaahi  ĽńĀ maka, pea mo e tangi ki he ngaahi mo Ľunga.  
\v 6 Pea na Ľe to Ľo  Ľe  ĽIlami  Ľae hŇćfangahau mo e ngaahi saliote  Ľae tangata mo e tangata heka hoosi, pea to Ľo  Ľe Kili  Ľae kofu  Ľoe fakaŇę.  
\v 7 Pea  Ľe pehńď,  Ľe fonu ho ngaahi tele Ľa lelei  Ľi he ngaahi saliote, pea  Ľe fakatńď  Ľae kautau heka hoosi  Ľi he matapńĀ.  
\v 8 Pea  Ľe tatala  Ľae me Ľa  Ľufi Ľufi  Ľo Siuta, pea te ke vakai  Ľi he  Ľaho ko ia ki he mahafutau  Ľi he fale  Ľoe vao lahi.  
\v 9 Pea te mou mamata ki he ngaahi ava  Ľi he Kolo  Ľo Tevita, koe Ľuhi  Ľoku lahi ia: pea te mou tńĀnaki fakataha  Ľae ngaahi vai ki he luo vai ki lalo.  
\v 10 Pea kuo mou lau  Ľae ngaahi fale  Ľo SelŇęsalema, pea kuo mou veteki  Ľae ngaahi fale ke fakamńĀlohi  Ľaki  Ľae  ĽńĀ maka.  
\v 11 Pea te mou ngaohi  Ľae keli  Ľi he vaha Ľa  Ľoe ongo  ĽńĀ maka ki he vai  Ľoe luo vai motu Ľa: ka  Ľoku te Ľeki te mou vakai kiate ia  Ľaia na Ľe ngaohi ia, pe faka Ľapa Ľapa kiate ia  Ľaia na Ľe fakatupu ia  Ľi mu Ľa  Ľaupito.  
\v 12 Pea  Ľi he  Ľaho ko ia na Ľe ui  Ľe he  ĽEiki ko Sihova  Ľoe ngaahi kautau ke tangi, pea ke tangilńĀulau, pea ke fafai  Ľae  Ľulu, pea ke vala  Ľaki  Ľae tauanga Ľa.  
\v 13 Pea vakai na Ľe  Ľi ai  Ľae fiemńĀlie mo e fiefia, ko e tńĀmate Ľi  Ľoe fanga pulu, mo e tńĀmate Ľi  Ľoe fanga sipi, mo e kai  Ľae kakano, mo e inu uaine: ke tau kai mo inu; he ko e  Ľapongipongi te tau mate.  
\v 14 Pea na Ľe fakahńĀ  Ľe Sihova  Ľoe ngaahi kautau ki hoku telinga, Ko e mo Ľoni  Ľe  Ľikai te mou ma Ľa  Ľi he hia ni kae Ľoua ke mou mate,  Ľoku pehńď  Ľe he  ĽEiki ko Sihova  Ľoe ngaahi kautau.   
\p
\v 15 ¬∂  ĽOku pehńď  Ľe he  ĽEiki ko Sihova  Ľoe ngaahi kautau, ‚Äú ĽAlu, ke ke hoko ki he tangata tauhi koloa ni,  Ľio, kia Sepina,  Ľaia  Ľoku pule ki he fale, pea ke pehńď,  
\v 16 Ko e hńĀ  Ľoku ke ma Ľu  Ľi heni? Pea ko hai  Ľoku ke ma Ľu  Ľi heni? Koe Ľuhi kuo ke tńĀ mo Ľou  Ľi heni ha fonualoto,  Ľo hangńď ko ia  Ľoku tńĀ mo Ľona ha fonualoto  Ľi he mńĀ Ľolunga, pea  Ľoku tongi ha nofo Ľanga mo Ľona  Ľi he maka?  
\v 17 Vakai,  Ľe  Ľave koe  Ľe Sihova  Ľi he fakapŇćpula fakamanavahńď, pea ko e mo Ľoni te ne ta Ľomia koe.  
\v 18 Ko e mo Ľoni te ne foki mai pea lńę mńĀlohi koe  Ľo hangńď ko ha me Ľa fuopotopoto ki ha fonua lahi: pea te ke mate ai, pea  Ľe hoko  Ľi ai  Ľa ho Ľo ngaahi saliote lelei ko e fakamńĀ  Ľoe fale  Ľo ho Ľo  Ľeiki.  
\v 19 Pea te u kapusi koe mei ho Ľo potu, pea te ne toho hifo koe mei ho pule Ľanga.‚ÄĚ   
\p
\v 20 ¬∂ Pea  Ľe hoko  Ľo pehńď  Ľi he  Ľaho ko ia, te u ui  Ľeku tamaio Ľeiki ko Iliakimi ko e foha  Ľo Hesekaia:  
\v 21 Pea te u fakakofu Ľaki ia  Ľa ho kofu tŇćtŇćlofa, pea te u fakamńĀlohi  Ľaki ia ho no Ľo, pea te u tuku ho Ľo pule ki hono nima: pea te ne hoko ko e tamai ki he kakai  Ľo SelŇęsalema, pea ki he fale  Ľo Siuta.  
\v 22 Pea ko e ki  Ľoe fale  Ľo Tevita te u ai ki hono uma; ko ia te ne to Ľo, pea  Ľe  Ľikai tńĀpuni  Ľe ha taha; pea te ne tńĀpuni, pea  Ľe  Ľikai to Ľo  Ľe ha taha.  
\v 23 Pea te u fakama Ľu ia  Ľo hangńď ha fa Ľo  Ľi ha potu  Ľoku ma Ľu; pea te ne hoko ko e nofo Ľanga lelei lahi ki he fale  Ľo  Ľene tamai.  
\v 24 Pea te nau tautau  Ľiate ia  Ľae lelei kotoa pńď  Ľoe fale  Ľo  Ľene tamai, ko e hako mo e fńĀnau,  Ľae ngaahi ipu si Ľi kotoa pńď, mei he kihi Ľi ipu inu,  Ľo a Ľu ki he ngaahi ipu kehe kotoa pńď.  
\v 25 ‚ÄĆ ĽOku pehńď  Ľe Sihova  Ľoe ngaahi kautau,  Ľi he  Ľaho ko ia  Ľe to Ľo  Ľae fa Ľo na Ľe fakama Ľu ki he potu ma Ľu, pea  Ľe tu Ľusi ki lalo, pea homo ia; pea ko e kavenga na Ľe  Ľi ai  Ľe tu Ľusi ke motu; he kuo folofola pehńď  Ľa Sihova.   
\c 23  
\cd \it 1 Kae faka Ľauha mamahi  Ľo Taia. 17 Ko  Ľenau foki mamahi mai.\it*  
\p
\v 1 Ko e tala mamafa  Ľoku kau ki Taia. Tangi,  Ľakimoutolu  Ľae ngaahi vaka  Ľo Tasisi; he kuo li Ľaki ia, ko ia  Ľoku  Ľikai ai ha fale, pe ha hŇę ki loto:  Ľoku fakahńĀ ia kiate kinautolu mei he fonua ko Kitimi.  
\v 2 Mou fakalongo pe,  Ľakimoutolu  Ľae kakai  Ľoe motu;  Ľa koe kuo fakama Ľume Ľa Ľi  Ľe he kakai fakatau  Ľo Saitoni,  Ľakinautolu  Ľoku fa Ľa folau  Ľi he tahi.  
\v 3 Ko  Ľene koloa ko e tupu  Ľoe tenga  Ľi Sihoa  Ľi he ve Ľe vai lahi, mo e ututa Ľu mei he vaitafe; pea ko e fakatau Ľanga ia  Ľoe ngaahi pule Ľanga.  
\v 4 Ke mńĀ  Ľa koe,  ĽE Saitoni: he kuo lea  Ľae tahi,  Ľio,  Ľae mńĀlohi  Ľoe tahi,  Ľo pehńď, ‚Äú ĽOku  Ľikai te u langa, pe fanau Ľi  Ľae fńĀnau, pea  Ľoku  Ľikai te u tauhi ha kau talavou, pe akonaki Ľi ha kau ta Ľahine.‚ÄĚ  
\v 5 ‚ÄĆ ĽO hangńď ko e ongoongo na Ľe kau ki  ĽIsipite,  Ľe pehńď  Ľenau mamahi lahi  Ľi he ongoongo  Ľo Taia.  
\v 6 ‚ÄĆ ĽAlu hake  Ľakimoutolu ki Tasisi; tangilńĀulau,  Ľakimoutolu ko e kakai  Ľoe motu.  
\v 7 Ko ho Ľomou \add kolo \add*fakafiefia  Ľa eni,  Ľaia na Ľe tu Ľu  Ľi he ngaahi  Ľaho  Ľi mu Ľa? Ko hono va Ľe  Ľo Ľona te ne  Ľave ia ki he mama Ľo ke  ĽńĀunofo ai.  
\v 8 Ko hai kuo ne tu Ľutu Ľuni  Ľae me Ľa ni ki Taia, ko e kolo na Ľe fa Ľa fakanofo  Ľae ngaahi pule, ko hono kakai fakatau ko e hou Ľeiki, pea ko kinautolu  Ľoku fefakatau Ľaki  Ľi ai ko e kau ongoongo  Ľi mńĀmani?  
\v 9 Ko Sihova  Ľoe ngaahi kautau kuo ne tu Ľutu Ľuni ki ai, ke fakamńĀ  Ľae laukau  Ľoe nńĀunau kotoa pńď, pea ke fakamatavalea Ľi  Ľae kakai ongoongo kotoa pńď  Ľo mńĀmani.  
\v 10 ‚ÄĆ ĽE  Ľofefine  Ľo Tasisi, ke ke  Ľalu  Ľi ho fonua  Ľo hangńď ha vaitafe kuo maumau Ľi hono kauvai.  
\v 11 Na Ľa ne mafao hono nima  Ľi he tahi, na Ľa ne lulululu  Ľae ngaahi pule Ľanga: kuo tuku mai  Ľe Sihova ha fekau  Ľoku kau ki he kolo fakatau, ke maumau Ľi hono ngaahi potu mńĀlohi.  
\v 12 Pea na Ľa ne pehńď,  ĽE  Ľikai te ke toe fiefia,  Ľa koe ko e ta Ľahine kuo ta Ľomia,  Ľae  Ľofefine  Ľo Saitoni: ke ke tu Ľu hake,  Ľalu atu ki Kitimi; pea na Ľa mo ia  Ľe  Ľikai te ke ma Ľu  Ľi ai ha mńĀlŇćlŇć.  
\v 13 Vakai ki he fonua  Ľoe kakai  Ľo Kalitia; na Ľe  Ľikai ko ha kakai  Ľakinautolu, ka  Ľi he Ľene toki langa Ľi ia ma Ľanautolu  Ľoku nofo  Ľi he toafa  Ľe he kakai  Ľo  ĽAsilia: ko kinautolu ia na Ľa nau fokotu Ľu hono ngaahi fale le Ľo, mo nau langa hake hono ngaahi fale faka Ľei Ľeiki; ka na Ľa ne  Ľomi ia ki he faka Ľauha.  
\v 14 Tangi,  Ľakimoutolu  Ľae ngaahi vaka  Ľo Tasisi: he kuo maumau Ľi ho potu mńĀlohi.  
\v 15 Pea  Ľe hoko  Ľo pehńď  Ľi he  Ľaho ko ia,  Ľe fakangalo  Ľa Taia  Ľi he ta Ľu  Ľe fitungofulu,  Ľo hangńď ko e ngaahi  Ľaho  Ľo ha tu Ľi  Ľe taha: pea hili  Ľae ta Ľu  Ľe fitungofulu  Ľe hiva  Ľa Taia  Ľo hangńď ko e fefine angahala.  
\v 16 To Ľo ha ha Ľape mo ke fe Ľalu Ľaki  Ľi he kolo,  Ľa koe ko e fefine angahala na Ľe fakangalo hifo; tńĀ  Ľae me Ľa tńĀ ke ongo mńĀlie, hiva  Ľaki  Ľae ngaahi hiva lahi, koe Ľuhi ke fakamanatu Ľi koe.   
\p
\v 17 ¬∂ Pea  Ľe hoko  Ľo pehńď hili  Ľae ta Ľu  Ľe fitungofulu,  Ľe  Ľa Ľahi  Ľa Sihova ki Taia, pea  Ľe foki ia ki he Ľene totongi, pea te ne fai hala mo e ngaahi pule Ľanga kotoa pńď  Ľo mńĀmani  Ľoku  Ľi he funga  Ľoe kelekele.  
\v 18 Ka ko  Ľene koloa mo ia  Ľoku ne ma Ľu  Ľe fakatapui ma Ľa Sihova:  Ľe  Ľikai tńĀnaki pe fakama Ľopo Ľopo ia; he ko  Ľene koloa  Ľe  Ľanautolu ia  Ľoku nofo  Ľi he  Ľao  Ľo Sihova, ke mahu  Ľae kai, pea tolonga  Ľae kofu.   
\c 24  
\cd \it 1 Ko e tautea fakamamahi mei he  ĽOtua ki he fonua. 13 Ko e toenga kakai  Ľe fakamńĀlŇć kiate ia  Ľi he fiefia. 16 Ko e  ĽOtua te ne hakeaki Ľi hono pule Ľanga.\it*  
\p
\v 1 Vakai,  Ľoku fakamaha  Ľe Sihova  Ľae fonua, mo fakalala ia, mo ne fulihi ia, pea fakamovetevete  Ľa hono kakai.  
\v 2 Pea  Ľe pehńď pe, hangńď ko ia  Ľoku  Ľi he kakai,  Ľe pehńď pe ki he taula Ľeiki; hangńď ko e tamaio Ľeiki,  Ľe pehńď pe ki he Ľene  Ľeiki; hangńď ko e kaunanga,  Ľe pehńď pe ki he Ľene  Ľeiki fefine; hangńď ko e tangata fakatau mai,  Ľe pehńď pe ki he tangata fakatau atu; hangńď ko ia  Ľoku tali  Ľae nono,  Ľe pehńď pe ki he tangata kole; hangńď ko ia  Ľoku  Ľi he tangata ma Ľu totongi nŇć pa Ľanga,  Ľe pehńď  Ľi he tangata  Ľoku  Ľatu  Ľae totongi nŇć pa Ľanga kiate ia.  
\v 3 ‚ÄĆ ĽE fakamaha  Ľaupito  Ľae fonua, pea faka Ľauha ia: he kuo folofola Ľaki  Ľe Sihova  Ľae folofola ni.  
\v 4 ‚ÄĆ ĽOku mamahi  Ľae fonua pea mae ia,  Ľoku vaivai  Ľa mńĀmani pea  Ľoku mae,  Ľoku vaivai  Ľae kakai fie Ľeiki  Ľoe fonua.  
\v 5 Kuo  Ľuli Ľi foki  Ľae fonua  Ľi hono kakai; koe Ľuhi kuo nau maumau Ľi  Ľae ngaahi fono,  Ľo liliu  Ľae tu Ľutu Ľuni,  Ľo maumau Ľi  Ľae fuakava ta Ľengata.  
\v 6 Ko ia kuo  Ľauha ai  Ľae fonua  Ľi he mala Ľia, pea ko kinautolu  Ľoku nofo ai  Ľoku nau mamahi: ko ia kuo tutu ai  Ľae kakai  Ľo mńĀmani, pea  Ľoku toe  Ľae tangata tokosi Ľi pe.  
\v 7 ‚ÄĆ ĽOku mamahi  Ľae uaine fo Ľou,  Ľoku vaivai  Ľae vaine,  Ľoku to Ľe  Ľakinautolu kotoa pńď na Ľe loto fiefia.  
\v 8 Kuo ngata  Ľae fakafiefia  Ľoe ngaahi lali, kuo  Ľosi  Ľae longoa Ľa  Ľokinautolu na Ľe fiefia, kuo ngata  Ľae fakafiefia  Ľoe ha Ľape.  
\v 9 ‚ÄĆ ĽE  Ľikai te nau kei inu uaine mo e hiva;  Ľe kona  Ľae kava mńĀlohi kiate kinautolu  Ľoku inu ia.  
\v 10 Kuo maumau Ľi hifo  Ľae kolo  Ľoe maveuveu: kuo tńĀpuni  Ľae ngaahi fale kotoa pńď, koe Ľuhi ke  Ľoua na Ľa hŇę ki ai ha tangata.  
\v 11 ‚ÄĆ ĽOku ai  Ľae tangi ki he uaine  Ľi he ngaahi hala; kuo fakapo Ľuli  Ľae fiefia kotoa pńď, kuo mole  Ľae fiefia  Ľi he fonua.  
\v 12 Kuo tuku  Ľi he kolo  Ľae faka Ľauha, pea kuo taa Ľi ke lailai hono ngaahi matapńĀ.   
\p
\v 13 ¬∂  ĽOku hoko  Ľo pehńď ki he kakai  Ľoe loto fonua,  Ľe ai  Ľo hangńď ko e lulululu  Ľoe  Ľakau ko e  Ľolive, pea hangńď ko e toenga kńĀlepi  Ľoka hili hono tńĀnaki mei he vaine.  
\v 14 Te nau hiki hake honau le Ľo, te nau hiva koe Ľuhi ko e mńĀ Ľolunga  Ľa Sihova, te nau kalanga mei he tahi.  
\v 15 Ko ia ke mou fakaongoongolelei Ľi  Ľa Sihova  Ľi he ngaahi afi,  Ľio,  Ľae huafa  Ľo Sihova ko e  ĽOtua  Ľo  ĽIsileli  Ľi he ngaahi  Ľotu motu  Ľoe tahi.   
\p
\v 16 ¬∂ Kuo mau fanongo ki he ngaahi hiva mei he ngata Ľanga  Ľo mńĀmani,  Ľio, ko e fakaongolelei ki he mńĀ Ľoni Ľoni. Ka na Ľaku pehńď,  ĽA  Ľeku tutue,  Ľa  Ľeku tutue;  Ľe mala Ľia au! Kuo fai kńĀkńĀ  Ľae kau fai ta Ľetotonu;  Ľio, kuo fai kńĀkńĀ lahi  Ľaupito  Ľae kakai fai ta Ľetotonu.  
\v 17 ‚ÄĆ ĽOku  Ľiate koe  Ľae ilifia, mo e luo, pea mo e tauhele,  Ľa koe  Ľoku nofo  Ľi mńĀmani.  
\v 18 Pea  Ľe hoko  Ľo pehńď, ko ia  Ľoku hola mei he longoa Ľa  Ľoe ilifia  Ľe tŇć ki he luo; pea ko ia  Ľoku  Ľalu hake mei he loto luo  Ľe mo Ľua ia  Ľi he tauhele: he kuo to Ľo  Ľae ngaahi matapńĀ  Ľi  Ľolunga, pea  Ľoku ngalulu  Ľae ngaahi tu Ľunga  Ľo mńĀmani.  
\v 19 Kuo maumau hifo  Ľaupito  Ľa mńĀmani, kuo  Ľauha  Ľaupito  Ľae fonua, kuo ngalulu lahi  Ľaupito  Ľa mńĀmani.  
\v 20 ‚ÄĆ ĽE tasipesipa  Ľa mńĀmani  Ľo hangńď ko e tangata konńĀ,  Ľe hiki ia  Ľo hangńď ko ha fale si Ľi, pea  Ľe mamafa ki ai  Ľa  Ľene angahala; pea  Ľe hinga ia, pea  Ľe  Ľikai toetu Ľu.  
\v 21 Pea  Ľe hoko  Ľo pehńď  Ľi he  Ľaho ko ia,  Ľe tautea  Ľe Sihova  Ľoe ngaahi kautau  Ľae kakai  Ľeiki  Ľoku  Ľi  Ľolunga, pea  Ľi he mńĀmani  Ľae ngaahi tu Ľi  Ľo mńĀmani.  
\v 22 Pea  Ľe tńĀnaki fakataha  Ľakinautolu,  Ľo hangńď  Ľoku tńĀnaki  Ľae kau pŇćpula ki he luo, pea  Ľe tńĀpuni  Ľi he fale fakapŇćpula, pea hili  Ľae ngaahi  Ľaho lahi  Ľe  Ľaahi Ľi  Ľakinautolu.  
\v 23 Pea  Ľe toki puputu Ľu  Ľae mńĀhina, pea  Ľe mńĀ mo e la ĽńĀ, koe Ľuhi  Ľe pule  Ľa Sihova  Ľoe ngaahi kautau  Ľi hono mńĀfimafi  Ľi he mo Ľunga ko Saione, pea  Ľi SelŇęsalema, pea  Ľe ongoongolelei ia  Ľi he  Ľao  Ľoe mńĀtu Ľa  Ľo hono kakai.   
\c 25  
\cd \it 1  ĽOku fakamńĀlŇć ki he  ĽEiki  Ľe he palŇćfita, koe Ľuhi ko  Ľene ngaahi fakamaau, 6 Pea ki hono ngaahi tńĀpuaki fakamo Ľui, 9 Pea koe Ľuhi ko  Ľene fakamo Ľui lahi mo mńĀlohi.\it*  
\p
\v 1 ‚ÄĆ ĽE Sihova, ko koe ko hoku  ĽOtua; te u fakahikihiki Ľi koe, te u fakamńĀlŇć ki ho huafa; he kuo ke fai  Ľae ngaahi me Ľa fakaofo; ko ho Ľo ngaahi tu Ľutu Ľuni  Ľi mu Ľa ko e angatonu mo e mo Ľoni.  
\v 2 He kuo ke liliu  Ľae kolo ko e fokotu Ľunga  Ľoto Ľota;  Ľae kolo na Ľe ai hono  ĽńĀ ko e tu Ľunga fale kuo maumau:  Ľae nofo Ľanga faka Ľei Ľeiki  Ľoe kakai muli ke lala:  Ľe  Ľikai  Ľaupito toe langa ia.  
\v 3 Ko ia  Ľe fakaongoongolelei Ľi koe  Ľe he kakai mńĀlohi,  Ľe manavahńď kiate koe  Ľae kolo  Ľoe ngaahi pule Ľanga fakailifia.  
\v 4 He na Ľa ke hoko ko e tokoni ki he kakai paea, ko e mńĀlohi ki he masiva  Ľi he Ľene mamahi, ko e hŇęfanga mei he afńĀ, ko e malumalu mei he pupuha  Ľoka tatau  Ľae tu Ľoni matangi  Ľoe kakai fakailifia mo e afńĀ  Ľoku fa Ľaki ki he  ĽńĀ maka.  
\v 5 Te ke  Ľohifo ki lalo  Ľae longoa Ľa  Ľoe kakai muli,  Ľo hangńď ko e la ĽńĀ  Ľi he potu mŇćmoa;  Ľio, ke pupuha  Ľi he malu  Ľo ha  Ľao;  Ľe fakavaivai Ľi  Ľae va Ľa  Ľoe kakai fakamanavahńď.   
\p
\v 6 ¬∂ Pea  Ľe teuteu  Ľe Sihova  Ľoe ngaahi kautau  Ľi he mo Ľunga ni  Ľae kńĀtoanga  Ľae ngaahi me Ľa lelei ki he kakai kotoa pńď, ko e kńĀtoanga  Ľoe uaine motu Ľa,  Ľoe ngaahi me Ľa momona  Ľoku fonu  Ľi he ngako  Ľoe hui, mo e uaine motu Ľa kuo ma Ľa  Ľaupito.  
\v 7 Pea te ne maumau Ľi  Ľi he mo Ľunga ni  Ľae  Ľufi Ľufi  Ľoku fakapulou  Ľaki  Ľae mata  Ľoe kakai kotoa pńď, pea mo e pŇęlou kuo fofola ki he ngaahi pule Ľanga kotoa pńď.  
\v 8 Te ne faka Ľauha  Ľaupito  Ľae mate  Ľi he mńĀlohi; pea  Ľe holoholo  Ľe he  ĽEiki ko Sihova  Ľae ngaahi lo Ľimata mei he mata kotoa pńď; pea ko e valoki  Ľo hono kakai te ne to Ľo mei he fonua kotoa pńď: he kuo folofola pehńď  Ľa Sihova.   
\p
\v 9 ¬∂ Pea  Ľe fai  Ľae lea  Ľo pehńď  Ľi he  Ľaho ko ia, ‚ÄúVakai, ko hotau  ĽOtua eni; na Ľa tau tatali kiate ia, pea te ne fakamo Ľui  Ľakitautolu: ko eni  Ľa Sihova; na Ľa tau tatali kiate ia, pea te tau fiefia mo nekeneka  Ľi he Ľene fakamo Ľui.‚ÄĚ  
\v 10 Koe Ľuhi  Ľe nofoma Ľu  Ľae nima  Ľo Sihova  Ľi he mo Ľunga ni, pea  Ľe molomoloki hifo  Ľiate ia  Ľa Moape,  Ľio,  Ľo hangńď  Ľoku molomoloki  Ľae mohuku mŇćmoa  Ľi he tu Ľunga  Ľoto Ľota.  
\v 11 Pea te ne mafao atu hono nima ki he lotolotonga  Ľokinautolu,  Ľo hangńď ko e mafao  Ľae nima  Ľo ha taha  Ľoku kakau: pea te ne  Ľohifo  Ľene laukau fakataha mo e ngaahi filio Ľi  Ľo hono nima.  
\v 12 Pea ko e fale mńĀ Ľolunga  Ľoe puke  Ľo ho Ľo ngaahi  ĽńĀ maka te ne  Ľohifo,  Ľo fakatoka lafalafa ki lalo, pea  Ľomi ki he kelekele,  Ľio, ki he efu.   
\c 26  
\cd \it 1 Ko e hiva ke langa Ľi  Ľae fa Ľaki ki he  ĽOtua, 5 Koe Ľuhi ko  Ľene ngaahi tautea, 12 Pea mo  Ľene  Ľofa ki hono kakai. 20 Ko e enginaki ke tatali ki he  ĽOtua.\it*  
\p
\v 1 ‚ÄĆ ĽI he  Ľaho ko ia  Ľe hiva  Ľaki  Ľae hiva ni  Ľi he fonua ki Siuta;  
\q1 ‚Äú ĽOku tau ma Ľu  Ľae kolo mńĀlohi;  
\q2  Ľe tu Ľutu Ľuni \add  Ľe he  ĽOtua \add* Ľae fakamo Ľui ki hono ngaahi  ĽńĀ mo hono ngaahi puke.   
\q1
\v 2 Mou to Ľo  Ľae ngaahi matapńĀ,  
\q2 koe Ľuhi ke hŇę ai  Ľae pule Ľanga mńĀ Ľoni Ľoni  Ľaia  Ľoku tauhi  Ľae mo Ľoni.   
\q1
\v 3 Te ke tauhi ia  Ľi he melino haohaoa,  Ľaia  Ľoku fa Ľaki hono loto kiate koe:  
\q2 koe Ľuhi  Ľoku ne falala kiate koe.   
\q1
\v 4 Mou falala kia Sihova  Ľo lauikuonga:  
\q2 he  Ľoku  Ľi he  ĽEiki ko Sihova  Ľae mńĀfimafi ta Ľengata.   
\q1
\v 5 He  Ľoku ne  Ľomi ki lalo  Ľakinautolu  Ľoku nofo  Ľi he mńĀ Ľolunga;  
\q2  Ľoku ne fakamo Ľulaloa  Ľae kolo mńĀ Ľolunga,  
\q2  Ľoku ne fakamo Ľulaloa ia,  
\q2  Ľio, ki he kelekele  Ľoku ne  Ľomi ia ki he efu.   
\q1
\v 6 ‚ÄĆ ĽE malaki hifo ia  Ľaki  Ľae va Ľe,  
\q2  Ľio,  Ľae va Ľe  Ľoe paea,  
\q2 pea mo e laka  Ľae masiva.‚ÄĚ   
\q1
\v 7 Ko e hala  Ľoe angatonu ko e mńĀ Ľoni Ľoni ia:  Ľa koe, ko e fungani mńĀ Ľoni Ľoni,  Ľoku ke fakamamafa  Ľae hala  Ľoe angatonu.   
\q1
\v 8 ‚ÄĆ ĽIo, kuo mau tatali kiate koe,  ĽE Sihova,  Ľi he hala  Ľo ho Ľo ngaahi fakamaau;  Ľoku holi  Ľa homau laumńĀlie ki ho huafa, pea  Ľi he fakamanatu kiate koe.  
\v 9 Kuo u holi  Ľi hoku laumńĀlie kiate koe  Ľi he pŇć;  Ľio, te u kumi vave kiate koe  Ľaki  Ľa hoku laumńĀlie  Ľi loto  Ľiate au: he ka  Ľi he fonua  Ľa ho Ľo ngaahi fakamaau,  Ľe toki ako  Ľae kakai  Ľo mńĀmani ki he mńĀ Ľoni Ľoni.  
\v 10 Ke hńĀ  Ľae  Ľalo Ľofa ki he angakovi, ka e  Ľikai te ne ako ki he mńĀ Ľoni Ľoni:  Ľi he fonua  Ľoe angatonu te ne fai kńĀkńĀ, pea  Ľe  Ľikai te ne mamata ki he mńĀfimafi  Ľa Sihova.  
\v 11 ‚ÄĆ ĽE Sihova,  Ľoka hiki hake ho nima,  Ľe  Ľikai te nau mamata: ka te nau mamata, pea te nau mńĀ koe Ľuhi ko e meheka ki ho Ľo kakai;  Ľio,  Ľe  Ľauha  Ľi he afi  Ľa ho ngaahi fili.   
\p
\v 12 ¬∂  ĽE Sihova te ke tu Ľutu Ľuni  Ľae fiemńĀlie ma Ľanautolu: he kuo ke fai  Ľe koe  Ľa  Ľemau ngaahi ngńĀue kotoa pńď  Ľiate kimautolu.  
\v 13 ‚ÄĆ ĽE Sihova ko homau  ĽOtua, kuo pule Ľi  Ľakimoutolu  Ľe he ngaahi  Ľeiki kehe: ka e talu mei heni te mau takua ho huafa  Ľo Ľou.  
\v 14 Kuo nau mate,  Ľe  Ľikai te nau mo Ľui; kuo nau pekia,  Ľe  Ľikai te nau toetu Ľu: ko ia kuo ke  Ľa Ľahi mo faka Ľauha Ľi  Ľakinautolu, pea kuo ke fakangata honau fakamanatu kotoa pńď.  
\v 15 Kuo ke fakatokolahi  Ľae pule Ľanga,  ĽE Sihova, kuo ke fakatokolahi  Ľae pule Ľanga: kuo fakaongolelei Ľi koe: kuo ke fakamanatu  Ľae ngaahi ngata Ľanga kotoa pńď  Ľoe fonua.  
\v 16 ‚ÄĆ ĽE Sihova,  Ľi he tu ĽutńĀmaki kuo mau  Ľa Ľahi kiate koe, na Ľa mau lilingi  Ľae lotu  Ľi he hoko ho Ľo tautea kiate kimautolu.  
\v 17 Hangńď  Ľoku mamahi ha fefine feitama,  Ľoka faka Ľa Ľau ke ofi  Ľene fńĀ Ľele, pea  Ľoku tangi  Ľi he Ľene langńĀ: kuo pehńď  Ľakimautolu  Ľi ho  Ľao,  ĽE Sihova.  
\v 18 Na Ľa mau tuitu Ľia, na Ľa mau mamahi,  Ľo hangńď kuo mau fanau Ľi  Ľae matangi; na Ľe  Ľikai te mau fai ha fakamo Ľui  Ľi he fonua; pea  Ľoku te Ľeki ke hinga  Ľae kakai  Ľo mńĀmani.  
\v 19 ‚ÄĆ ĽE mo Ľui  Ľa ho Ľo kakai mate, te nau toetu Ľu fakataha mo hoku sino mate ni. Mou  Ľa  Ľo hiva,  Ľakimoutolu  Ľoku nofo  Ľi he efu: he  Ľoku tatau ho Ľo hahau mo e hahau  Ľoe mohuku mata, pea  Ľe pu Ľaki  Ľe he kelekele  Ľae mate.   
\p
\v 20 ¬∂ Ha Ľu,  Ľa hoku kakai, pea hŇę ki homou ngaahi loki, pea tńĀpuni ho matapńĀ kiate koe: fufŇę koe  Ľo fuoloa si Ľi, kae Ľoua ke mole atu  Ľae houhau.  
\v 21 He vakai,  Ľoku hńĀ Ľele  Ľa Sihova mei hono potu ke tautea  Ľae kakai  Ľo mńĀmani koe Ľuhi ko  Ľenau hia: pea  Ľe fakahńĀ  Ľe he fonua hono toto, pea  Ľe  Ľikai toe  Ľufi Ľufi hono kakai kuo tńĀmate Ľi.   
\c 27  
\cd \it 1 Ko e tokanga  Ľae  ĽOtua ki he Ľene ngoue vaine. 7  ĽOku fai kehekehe  Ľa  Ľene tńĀkitala mo  Ľene ngaahi tautea. 12 Ko e siasi  Ľoe Siu mo e Senitaile.\it*  
\p
\v 1 ‚ÄĆ ĽI he  Ľaho ko ia  Ľe tautea  Ľe Sihova  Ľae levaiatani ko e ngata mńĀlohi,  Ľaki  Ľene heletńĀ mńĀsila mo lahi mo mńĀlohi,  Ľio,  Ľae levaiatani ko e ngata pikopiko; pea te ne tńĀmate Ľi mo e talńĀkoni  Ľoku  Ľi he tahi.  
\v 2 ‚ÄĆ ĽI he  Ľaho ko ia mou hiva kiate ia, ko e ngoue vaine  Ľoe uaine kulokula.  
\v 3 ‚ÄúKo au ko Sihova  Ľoku ou tauhi ia: te u fakaviviku ia  Ľi he kuonga kotoa pńď: telia na Ľa maumau Ľi ia  Ľe ha taha, te u tauhi ia  Ľi he  Ľaho mo e pŇć.  
\v 4 ‚ÄĆ ĽOku  Ľikai  Ľiate au  Ľae houhau: ko hai te ne fokotu Ľu kiate au  Ľae ngaahi  Ľakau talatala mo e talatala ĽńĀmoa  Ľi he tau? Te u  Ľalu  Ľo  Ľasi  Ľiate kinautolu, te u tutu fakataha  Ľakinautolu.  
\v 5 Tuku ke ne puke mai ki hoku mńĀlohi, koe Ľuhi ke ne fakalelei mo au pea te ne fakalelei mo au.‚ÄĚ  
\v 6 Te ne ngaohi ke aka  Ľakinautolu  Ľoku ha Ľu ia Sńďkope:  Ľe fisi mo moto  Ľa  ĽIsileli, pea fakafonu  Ľae funga  Ľo mńĀmani  Ľaki  Ľae fua.   
\p
\v 7 ¬∂ Kuo ne taa Ľi ia,  Ľo hangńď ko  Ľene taa Ľi  Ľakinautolu na Ľe taa Ľi ia? Pea kuo tńĀmate Ľi ia  Ľo hangńď ko e tńĀmate Ľi  Ľakinautolu kuo tńĀmate Ľi  Ľiate ia?  
\v 8 ‚ÄĆ ĽI ho Ľo fekau atu ia na Ľa ke fuofua kiate ia  Ľae fakamaau:  Ľoku ne ta Ľofi  Ľa  Ľene afńĀ  Ľi he  Ľaho  Ľoe matangi hahake.  
\v 9 Ko ia ko e me Ľa ni  Ľe fakama Ľa ai  Ľae hia  Ľa Sńďkope; pea te ne ma Ľu  Ľae fua kotoa pńď ke  Ľave  Ľene angahala;  Ľoka ngaohi  Ľe ia  Ľae ngaahi maka kotoa pńď  Ľoe  Ľesifeilaulau Ľanga ke hangńď ko e ngaahi maka hinehina  Ľaia kuo momosi,  Ľe  Ľikai tu Ľu ki  Ľolunga ai  Ľae ngaahi  Ľakau fakamalumalu mo e ngaahi tamapua.  
\v 10 Ka e lala  Ľae kolo kuo teuteu ki he tau,  Ľe li Ľaki  Ľae nofo Ľanga, pea  Ľe tuku ia  Ľo hangńď ko e toafa:  Ľe kai ai  Ľae pulu mui, pea te ne tokoto  Ľi ai,  Ľo ne keina  Ľae ngaahi va Ľa litolito  Ľi ai.  
\v 11 ‚ÄĆ ĽOka mae  Ľa hono ngaahi va Ľa,  Ľe fesi Ľi ia:  Ľe ha Ľu  Ľae kau fefine  Ľo tutu ia: he ko e kakai ta Ľe Ľilo ia: ko ia ia na Ľa ne ngaohi  Ľakinautolu  Ľe  Ľikai te ne  Ľalo Ľofa kiate kinautolu, pea ko ia na Ľa ne fakafuofua  Ľakinautolu  Ľe  Ľikai te ne fakahńĀ ha  Ľofa kiate kinautolu.   
\p
\v 12 ¬∂ Pea  Ľe hoko  Ľo pehńď  Ľi he  Ľaho ko ia,  Ľe lohu Ľi  Ľe Sihova hono ngaahi fua, \add  Ľo fai \add*mei he tafe Ľanga  Ľoe ngaahi vaitafe  Ľo a Ľu ki he vaitafe  Ľo  ĽIsipite, pea  Ľe tńĀnaki  Ľakimoutolu  Ľo tautau tokotaha,  Ľakimoutolu ko e fńĀnau  Ľo  ĽIsileli.  
\v 13 Pea  Ľe hoko  Ľo pehńď  Ľi he  Ľaho ko ia,  Ľe ifi  Ľae me Ľa lea lahi, pea  Ľe ha Ľu  Ľakinautolu na Ľe meimei mate  Ľi  ĽAsilia, pea mo e kau  ĽńĀuhńď  Ľi he fonua ko  ĽIsipite, pea  Ľe lotu kia Sihova  Ľi he mo Ľunga tapu  Ľi SelŇęsalema.   
\c 28  
\cd \it 1  ĽOku fakamana Ľi  Ľe he palŇćfita  Ľa  ĽIfalemi  Ľi he  Ľenau laukau mo e konńĀ. 5  ĽE tupu ki mu Ľa hono toe  Ľi he pule Ľanga  Ľo Kalaisi. 7  ĽOku ne valoki  Ľenau hala, 9 Mo  Ľenau ta Ľefieako, 14 Mo  Ľenau fakafiemńĀlie. 16 Ko e fakahńĀ  Ľo Kalaisi ko e tu Ľunga mo Ľoni. 18  ĽE  Ľahi Ľahi Ľi honau mńĀlohi. 25  ĽOku ue Ľi  Ľakinautolu ke tokanga ki he tauhi lelei  Ľae  ĽOtua.\it*  
\p
\v 1 Mala Ľia ki he tatńĀ  Ľoe laukau, ki he kau konńĀ  Ľo  ĽIfalemi,  Ľakinautolu  Ľoku hangńď ko e fisi Ľi Ľakau mae  Ľa  Ľenau toulekeleka ongoongolelei! Kiate kinautolu  Ľoku nofo  Ľi he  Ľulu  Ľoe vanu kelekele mo Ľui  Ľonautolu  Ľoku konńĀ  Ľi he uaine!  
\v 2 Vakai,  Ľoku  Ľi he  ĽEiki ha tokotaha mńĀfimafi mo mńĀlohi,  Ľo hangńď ko e taufa  Ľuha maka,  Ľo hangńď ko e afńĀ fulikele,  Ľo hangńď ko e tafe hifo  Ľae ngaahi vai lahi  Ľoku tafe mńĀlohi, te ne tńĀ hifo ki he kelekele  Ľaki hono nima.  
\v 3 Ko e tatńĀ  Ľoe laukau,  Ľae kakai konńĀ  Ľo  ĽIfalemi,  Ľe molomoloki  Ľi he lalo va Ľe:  
\v 4 Pea ko e toulekeleka ongoongolelei,  Ľaia  Ľoku  Ľi he  Ľulu  Ľoe vanu kelekele mo Ľui,  Ľe hoko ia ko e fisi Ľi Ľakau mae, pea hangńď ko e fua tupu vave  Ľi he te Ľeki hoko  Ľae fa Ľahita Ľu mafana:  Ľaia  Ľoku toli leva  Ľe ia  Ľoku mamata ki ai, pea  Ľi he Ľene  Ľi hono nima  Ľoku ne kai leva ia  Ľo  Ľosi.   
\p
\v 5 ¬∂  ĽI he  Ľaho ko ia  Ľe hoko  Ľa Sihova  Ľoe ngaahi kautau ko e tatńĀ ongoongolelei, pea ko e pale fakasanisani, ki hono toe  Ľo hono kakai,  
\v 6 Pea ko e laumńĀlie  Ľoe fakamaau kiate ia  Ľoku nofo ke fakamaau, pea ko e mńĀlohi kiate kinautolu  Ľoku fakafoki  Ľae tau ki he matapńĀ.   
\p
\v 7 ¬∂ Ka kuo nau hńď  Ľi he uaine, pea koe Ľuhi ko e inu mńĀlohi kuo nau hńď mei he hala; kuo hńď  Ľae taula Ľeiki pea mo e palŇćfita  Ľi he inu mńĀlohi,  Ľoku nau mo Ľua ki he uaine, kuo nau hńď mei he hala ko e me Ľa  Ľi he inu mńĀlohi;  Ľoku ninimo honau mata,  Ľoku nau humu  Ľi he fakamaau.  
\v 8 He  Ľoku fonu  Ľae ngaahi keinanga Ľanga kotoa pńď  Ľi he lua mo e fakalielia, ko ia  Ľoku  Ľikai ha potu  Ľoku ma Ľa.   
\p
\v 9 ¬∂ Te ne ako kia hai  Ľae  Ľilo? Pea ko hai te ne akonaki Ľi ke ne  Ľilo  Ľa  Ľene akonaki? Ko kinautolu kuo fakamavae mei he hu Ľahuhu, pea kuo to Ľo mei he huhu.  
\v 10 He kuo  Ľai  Ľae fekau ki he fekau,  Ľae fekau ki he fekau;  Ľae  Ľotu lea ki he  Ľotu lea,  Ľae  Ľotu lea ki he  Ľotu lea; ko e si Ľi  Ľi heni pea si Ľi  Ľi hena:  
\v 11 He te ne lea mo Ľoni  Ľaki ki he kakai ni  Ľae loungutu fakale Ľole Ľovale pea mo e  Ľelelo kehe.  
\v 12 ‚ÄĆ ĽAia na Ľa ne pehńď kiate kinautolu, Ko eni  Ľae mńĀlŇćlŇć te ke fakamńĀlŇćlŇć  Ľaki  Ľae kakai ongosia; pea ko eni  Ľae fakafiemńĀlie; ka na Ľa nau fakaongotuli.  
\v 13 Ka na Ľe  Ľiate kinautolu  Ľae folofola  Ľa Sihova ko e fekau ki he fekau, ko e fekau ki he fekau; ko e  Ľotu lea ki he  Ľotu lea, ko e  Ľotu lea ki he  Ľotu lea; ko e si Ľi  Ľi heni, pea si Ľi  Ľi hena; koe Ľuhi ke nau  Ľalu ai, pea hinga fakaholomui, pea mafesifesi pea tauhele Ľi, pea mo Ľua ai  Ľakinautolu.   
\p
\v 14 ¬∂ Ko ia mou fanongo ki he folofola  Ľa Sihova,  Ľakimoutolu  Ľae kau tangata paetaku  Ľoku pule  Ľae kakai ni  Ľoku  Ľi SelŇęsalema.  
\v 15 Koe Ľuhi kuo mou pehńď, ‚ÄúKuo mau fuakava mo e mate, pea kuo mau fe Ľofo Ľofani mo heli;  Ľoka hńĀ mai  Ľae tautea faka Ľauha,  Ľe  Ľikai a Ľu mai ia kiate kimautolu: he kuo mau hŇęfanga  Ľaki  Ľae loi, pea kuo mau fufŇę  Ľakimautolu  Ľi he kńĀkńĀ:‚ÄĚ  
\v 16 Ko ia  Ľoku pehńď  Ľe he  ĽEiki ko Sihova, ‚ÄúVakai,  Ľoku ou  Ľai  Ľi Saione  Ľae maka tu Ľunga;  Ľae maka kuo  Ľahi Ľahi Ľi, ko e fungani maka tuliki, ko e tu Ľunga ma Ľu: ko ia  Ľoku tui kiate ia  Ľe  Ľikai puputu Ľu ia.  
\v 17 Te u  Ľai foki  Ľae fakamaau ki he afo fua, mo e mńĀ Ľoni Ľoni ki he me Ľa fakatotonu: pea ko e  Ľuha maka te ne tafi ke mole  Ľae hŇęfanga  Ľoe loi, pea  Ľe lŇćmaki Ľi  Ľe he ngaahi vai  Ľae toitoi Ľanga.   
\p
\v 18 ¬∂ ‚ÄúPea  Ľe maumau Ľi ho Ľomou fuakava mo e mate, pea  Ľe  Ľikai tu Ľu homou loto taha mo heli;  Ľoka hńĀ mai  Ľae tautea faka Ľauha,  Ľe toki malaki hifo ai  Ľakimoutolu.  
\v 19 Pea  Ľi he Ľene hńĀ atu te mou mo Ľua ai; he te ne  Ľalu atu  Ľi he pongipongi mo e pongipongi,  Ľio,  Ľi he  Ľaho mo e pŇć: pea na Ľa mo  Ľene  Ľu Ľulu mai pe  Ľe tupu ai  Ľae ilifia.  
\v 20 He  Ľoku nounou  Ľae mohenga ki he tokoto  Ľi ai: pea  Ľoku lausi Ľi  Ľae kafu ke ne fakakafu  Ľaki ia.  
\v 21 ‚ÄĆ ĽE tu Ľu hake  Ľa Sihova  Ľo hangńď ko  Ľene  Ľi he mo Ľunga ko Pilasimi, te ne houhau  Ľo hangńď ko ia  Ľi he tele Ľa  Ľo Kipione, koe Ľuhi ke ne fai  Ľene ngńĀue,  Ľa  Ľene ngńĀue fakaofo; ke ne fakahoko  Ľa  Ľene ngńĀue, ko  Ľene ngńĀue fo Ľou.  
\v 22 Ko ia ke  Ľoua na Ľa mou manuki, telia na Ľa ngaohi homou ha Ľi ke mńĀlohi: he kuo u fanongo  Ľi he  ĽEiki ko Sihova  Ľoe ngaahi kautau,  Ľe fai  Ľae faka Ľauha,  Ľio, kuo tu Ľutu Ľuni ki mńĀmani kotoa pńď.   
\p
\v 23 ¬∂ ‚ÄúMou fakatokanga, pea fanongo ki hoku le Ľo; fanongo, pea fakaongo ki he Ľeku lea.  
\v 24 He  Ľoku fakahinohino  Ľae huo toho  Ľe he tangata kelingoue  Ľi he  Ľaho kotoa pńď ke tŇętuu Ľi?  ĽOku ne langa Ľi pea fakamolŇę  Ľae ngaahi konga  Ľoe kelekele?  
\v 25 ‚ÄĆ ĽOka fakamolemole  Ľae funga  Ľo ia,  Ľikai  Ľoku ne tŇętuu Ľi mama Ľo  Ľae ngaahi tili, pea tŇętuu Ľi  Ľae kumino, pea ai mo e uite lelei, mo e pa Ľale kuo tu Ľutu Ľuni, pea mo e lae  Ľi honau potu?  
\v 26 He  Ľoku ako ia ke poto  Ľe hono  ĽOtua, pea  Ľoku ne akonaki Ľi ia.  
\v 27 He  Ľoku  Ľikai haha  Ľae tili  Ľaki  Ľae me Ľa haha, pea  Ľoku  Ľikai fakatakamilo  Ľae saliote ki he kumino; ka  Ľoku tńĀ ke ngangana  Ľae tili  Ľaki  Ľae  Ľakau, pea mo e kumino  Ľaki  Ľae tokotoko.  
\v 28 ‚ÄĆ ĽOku fakavolu  Ľae uite ki he mńĀ koe Ľuhi  Ľoku  Ľikai te ne fie haha ma Ľuaipńď ia, pe momosi ia  Ľaki  Ľae teka  Ľo hono saliote, pe fakavolu ia  Ľaki hono kau tangata heka hoosi.  
\v 29 ‚ÄĆ ĽOku ha Ľu foki eni meia Sihova  Ľoe ngaahi kautau,  Ľaia  Ľoku fakamanavahńď  Ľi he fakahinohino, pea lelei lahi  Ľi he ngńĀue.‚ÄĚ   
\c 29  
\cd \it 1 Ko e tautea mamafa  Ľae  ĽOtua ki SelŇęsalema. 7  ĽAe ta Ľefiu  Ľa hono ngaahi fili. 9 Ko e vale, mo e mńĀlualoi lahi  Ľoe kakai Siu. 13 Ko e tala Ľofa  Ľoe fakama Ľa ki he anga faka Ľotua.\it*  
\p
\v 1 Ko e mala Ľia ki  ĽAliela, ki  ĽAliela,  Ľae kolo na Ľe nofo ai  Ľa Tevita! Fakalahi  Ľae tau ki he tau; tuku ke nau tńĀmate Ľi  Ľae ngaahi feilaulau.  
\v 2 Ka te u fakamamahi Ľi  Ľa  ĽAliela, pea  Ľe  Ľi ai  Ľae ongosia mo e mamahi: pea  Ľe pehńď ia kiate au  Ľo hangńď ko e potu  Ľoe feilaulau Ľanga.  
\v 3 Pea te u takatakai koe pea kńĀpui koe  Ľaki  Ľae mo Ľunga, pea te u langa  Ľae ngaahi kolo kiate koe.  
\v 4 Pea  Ľe fakavaivai Ľi koe, pea te ke lea mei he kelekele, pea  Ľe mńĀ Ľulalo ho le Ľo mei he efu, pea  Ľe tatau ho le Ľo mo ha taha  Ľoku  Ľiate ia ha laumńĀlie kovi, mei he kelekele, pea  Ľe fafana ho le Ľo mei he efu.  
\v 5 Pea ko e tokolahi  Ľo ho Ľo kau muli te nau hangńď ko e efuefu momo iiki, pea mo e tokolahi  Ľoe kakai fakamanavahńď te nau hangńď ko e kafukafu  Ľoku mole atu:  Ľio,  Ľe hoko fakafokifńĀ ia  Ľi he kemo pe taha.  
\v 6 ‚ÄĆ ĽE  Ľa Ľahi kiate koe  Ľe Sihova  Ľoe ngaahi kautau  Ľaki  Ľae mana, pea mo e mofuike, mo e longoa Ľa lahi,  Ľaki  Ľae matangi lahi mo e afńĀ, pea mo e ulo  Ľoe afi faka Ľauha.   
\p
\v 7 ¬∂ Pea ko e tokolahi  Ľoe ngaahi pule Ľanga kotoa pńď  Ľoku tau Ľi  Ľa  ĽAliela,  Ľio, ko kinautolu kotoa pńď  Ľoku tau Ľi ia mo  Ľene kolo, pea  Ľoku fakamamahi Ľi ia, te nau hangńď ko ha misi, pe ko e me Ľa hńĀ mai  Ľi he pŇć.  
\v 8 ‚ÄĆ ĽO hangńď ko e misi  Ľae tangata fiekaia, pea vakai,  Ľoku hangńď  Ľoku ne kai; pea  Ľoka  ĽńĀ ia,  Ľoku ngaongao hono laumńĀlie: pe hangńď ko e misi  Ľa ha tangata fieinu, pea vakai, hangńď  Ľoku inu ia; ka  Ľoku ne  Ľaa, pea vakai,  Ľoku vaivai ia, pea  Ľoku ne holi:  Ľe pehńď pe  Ľae tokolahi  Ľoe ngaahi pule Ľanga kotoa pńď,  Ľoku tau Ľi  Ľae mo Ľunga ko Saione.   
\p
\v 9 ¬∂ Mou tatali, pea ofo; mou kalanga, pea tangi:  Ľoku nau konńĀ, kae  Ľikai  Ľi he uaine;  Ľoku nau tasipa, kae  Ľikai  Ľi he inu mńĀlohi.  
\v 10 He kuo lilingi  Ľe Sihova kiate kimoutolu  Ľae laumńĀlie  Ľoe mohe ma Ľu, pea kuo tńĀpuni homou mata: kuo ne fakapulou  Ľae kau palŇćfita mo ho Ľomou kau pule mo e kau kikite.  
\v 11 Pea ko e me Ľa hńĀ mai kotoa pńď kuo hoko kiate kimoutolu  Ľo tatau mo e ngaahi lea  Ľo ha tohi kuo tńĀpuni,  Ľoku  Ľange  Ľe ha tangata ki ha tokotaha  Ľoku poto,  Ľo pehńď, ‚Äú ĽOku ou kole kiate koe, ke ke lau  Ľae me Ľa ni,‚ÄĚ pea  Ľoku ne pehńď, ‚Äú ĽOku  Ľikai te u fa Ľa fai ia he kuo ma Ľu ia;‚ÄĚ  
\v 12 Pea  Ľoku  Ľatu  Ľae tohi kiate ia  Ľoku  Ľikai poto,  Ľo pehńď,  ĽOku ou kole kiate koe, ke ke lau  Ľae me Ľa ni: pea  Ľoku ne pehńď, ‚Äú ĽOku  Ľikai te u poto.‚ÄĚ   
\p
\v 13 ¬∂ Ko ia ne pehńď ai  Ľe Sihova, ko e me Ľa  Ľi he  Ľunu Ľunu mai  Ľae kakai ni kiate au  Ľaki honau ngutu, pea faka Ľapa Ľapa kiate au  Ľaki honau loungutu, ka kuo mama Ľo honau loto  Ľiate au, pea ko  Ľenau manavahńď kiate au  Ľoku tupu ia mei he ngaahi fekau  Ľae tangata pe:  
\v 14 Ko ia, vakai, te u fai leva ha ngńĀue fakaofo ki he kakai ni,  Ľio,  Ľae ngńĀue fakaofo mo lahi: he ko e poto  Ľo  Ľenau kau tangata poto  Ľe  Ľauha ia, pea ko e  Ľilo  Ľo  Ľenau kau tangata fakamńĀkukanga  Ľe fufŇę ia.  
\v 15 ‚ÄĆ ĽE mala Ľia  Ľakinautolu  Ľoku  Ľahi Ľahi lahi ke fufŇęnaki honau loto meia Sihova, pea  Ľoku fai  Ľi he po Ľuli  Ľenau ngaahi ngńĀue, pea  Ľoku nau pehńď, ‚ÄúKo hai  Ľoku mamata kiate kitautolu? Pea ko hai  Ľoku ne  Ľilo Ľi  Ľakitautolu?‚ÄĚ  
\v 16 Ko e mo Ľoni ko ho Ľomou fulifulihi  Ľae ngaahi me Ľa  Ľe tatau mo e  Ľumea  Ľoe tangata ngaohi ipu: he  Ľe lea pehńď końĀ  Ľae me Ľa kuo ngaohi kiate ia na Ľa ne fakatufunga Ľi, na Ľe  Ľikai te ne ngaohi au? Pe,  Ľe pehńď  Ľae me Ľa kuo ngaohi kiate ia na Ľe ngaohi ia, na Ľe  Ľikai ha Ľane  Ľilo?  
\v 17 ‚ÄĆ ĽIkai  Ľoku toetoe si Ľi pea  Ľe liliu  Ľa Lepanoni ke hoko ko e ngoue fua mo Ľui, pea ko e ngoue fua  Ľe tatau ia mo e vao  Ľakau?   
\p
\v 18 ¬∂ Pea  Ľi he  Ľaho ko ia  Ľe fanongo  Ľae tuli ki he ngaahi lea  Ľoe tohi, pea  Ľe mamata  Ľae mata  Ľoe kui mei he kakapu, pea mei he po Ľuli.  
\v 19 Pea  Ľe  ĽńĀsili ai  Ľae fiefia  Ľae angavaivai  Ľia Sihova, pea ko e masiva  Ľi he kakai te nau fiefia  Ľi he tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli.  
\v 20 He kuo mole  Ľae tokotaha na Ľe fakamńĀlohi, pea kuo  Ľauha mo e tangata manuki, pea kuo tu Ľusi ke motu  Ľakinautolu  Ľoku lama ke fai kovi.  
\v 21 ‚ÄĆ ĽOku nau fakahalaia ha tangata  Ľi he kupu Ľi lea, pea  Ľoku nau tau  Ľae tauhele kiate ia  Ľoku valoki  Ľi he matapńĀ, pea fakaafe  Ľae angatonu  Ľi he me Ľa ta Ľe Ľaonga.  
\v 22 Ko ia  Ľoku pehńď ai  Ľe Sihova,  Ľaia na Ľa ne huhu Ľi  Ľa  ĽEpalahame, ki he fale  Ľo Sńďkope,  Ľe  Ľikai mńĀ  Ľa Sńďkope, pea  Ľe  Ľikai liliu  Ľo tea hono mata.  
\v 23 Ka  Ľi he Ľene mamata ki he Ľene fńĀnau, ko e ngńĀue  Ľa hoku nima,  Ľi he lotolotonga  Ľo ia, te nau faka Ľapa Ľapa ki hoku huafa, pea faka Ľapa Ľapa ki he tokotaha mńĀ Ľoni Ľoni  Ľo Sńďkope, pea manavahńď ki he  ĽOtua  Ľo  ĽIsileli.  
\v 24 Pea ko kinautolu foki na Ľe hala  Ľi he laumńĀlie te nau hoko  Ľo  Ľilo, pea ko kinautolu na Ľe lńĀunga te nau ma Ľu  Ľae akonaki.   
\c 30  
\cd \it 1  ĽOku valoki  Ľe he palŇćfita  Ľae kakai  Ľi he Ľenau fa Ľaki ki  ĽIsipite  Ľo ta Ľetokanga ki he folofola  Ľae  ĽOtua. 18 Ko e  Ľalo Ľofa  Ľae  ĽOtua ki hono siasi. 27 Ko e houhau  Ľoe  ĽOtua, mo e fiefia  Ľae kakai  Ľi he faka Ľauha  Ľo  ĽAsilia.\it*  
\p
\v 1 ‚ÄĆ ĽOku pehńď  Ľe Sihova,  ĽE mala Ľia  Ľae fńĀnau talangata Ľa,  Ľaia  Ľoku fakakaukau kae  Ľikai  Ľiate au; pea  Ľoku  Ľufi Ľufi  Ľaki  Ľae me Ľa  Ľufi Ľufi; ka  Ľoku  Ľikai  Ľi hoku laumńĀlie, koe Ľuhi ke nau fakalahi  Ľae angahala ki he angahala  
\v 2 ‚ÄĆ ĽOku nau fononga ke  Ľalu hifo ki  ĽIsipite ke fakamńĀlohi  Ľakinautolu  Ľi he mńĀlohi  Ľo Felo, pea ke fa Ľaki ki he malu  Ľo  ĽIsipite; ka na Ľe  Ľikai te nau fehu Ľi ki hoku fofonga!  
\v 3 Ko ia  Ľe hoko  Ľae mńĀlohi  Ľo Felo ko homou manga, pea ko e falala ki he malu  Ľo  ĽIsipite ko homou maveuveu.  
\v 4 He ko hono ngaahi hou Ľeiki na Ľe  Ľi Soani, pea na Ľe ha Ľu  Ľene kau talafekau ki Hanesi.  
\v 5 Na Ľa nau mńĀ kotoa pńď  Ľi he kakai na Ľe ta Ľe Ľaonga kiate kinautolu, na Ľe  Ľikai ko ha tokoni pe ko e  Ľaonga, ka ko e fakamńĀ pea mo e ongokovi.  
\v 6 Ko e kavenga  Ľoe ngaahi manu  Ľoku  Ľave ki he potu tonga: ki he fonua  Ľoe mamahi mo e ongosia,  Ľaia  Ľoku ha Ľu mei ai  Ľae laione mui mo e laione motu Ľa,  Ľae ngata fekai pea mo e ngata afi  Ľoku puna, te nau fua  Ľenau koloa  Ľi he uma  Ľoe fanga  Ľasi mui, mo  Ľenau ngaahi me Ľa  Ľi he hula  Ľoe fanga kńĀmeli, ki ha kakai  Ľe  Ľikai  Ľaonga kiate kinautolu.  
\v 7 He ko e me Ľa va Ľinga pea ta Ľe Ľaonga,  Ľae tokoni mei he kakai  Ľo  ĽIsipite, ko ia kuo u kalanga  Ľi he me Ľa ni, Ko honau mńĀlohi ke nofo pe.   
\p
\v 8 ¬∂ Te ke  Ľalu ni  Ľo tohi ia  Ľi honau  Ľao  Ľi he palepale, pea tohi ia  Ľi ha tohi koe Ľuhi ko e kuonga ki mui  Ľo ta Ľengata pea ta Ľengata.  
\v 9 ‚ÄĆ ĽO pehńď, ko e kakai angatu Ľu eni, ko e fńĀnau loi, ko e fńĀnau  Ľoku  Ľikai fie fanongo ki he fono  Ľa Sihova:  
\v 10 ‚ÄĆ ĽOku nau pehńď ki he kau kikite,  Ľoua na Ľa mamata, pea ki he kau palŇćfita,  Ľoua  Ľe fakahńĀ kiate kimautolu  Ľae ngaahi me Ľa totonu; lea  Ľaki kiate kimautolu  Ľae ngaahi me Ľa mńĀlie, kikite  Ľaki  Ľae ngaahi kńĀkńĀ:  
\v 11 Tu Ľu ki he  ĽatńĀ mei he hala, afe atu mei he hala, tuku ke mole  Ľi hotau  Ľao  Ľae tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli.  
\v 12 Ko ia  Ľoku pehńď  Ľe he tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli, Ko e me Ľa  Ľi ho Ľomou fehi Ľa ki he folofola ni, pea falala ki he fakamńĀlohi mo e mio Ľi, mo fa Ľaki ki ai:  
\v 13 Ko ia  Ľe hoko kiate kimoutolu  Ľae hia ni  Ľo hangńď  Ľae foa Ľi ha  ĽńĀ maka  Ľoku teitei hinga,  Ľo hangńď ko ha mafahi  Ľi ha  ĽńĀ mńĀ Ľolunga  Ľoku hoko hono maumau fakafokifńĀ  Ľi ha kemo pe taha.  
\v 14 Pea te ne maumau ia  Ľo hangńď ko e maumau  Ľae ipu  Ľoe tufunga ngaohi ipu  Ľaia kuo foa Ľi  Ľo lailai;  Ľe  Ľikai te ne ta Ľofi: ko ia  Ľe  Ľikai  Ľilo  Ľi hono pńĀ  Ľo ia ha konga ke vela  Ľi he ve Ľe afi, pe  Ľutu  Ľaki ha vai mei he luo.  
\v 15 He  Ľoku pehńď  Ľe he  ĽEiki ko Sihova, ko e tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli;  ĽI he tafoki mo e nofo pe te mou mo Ľui ai;  Ľi he angavaivai mo e tui  Ľe ai homou mńĀlohi: ka na Ľe  Ľikai te mou loto ki ai.  
\v 16 Ka na Ľa mou pehńď, ‚Äú ĽE  Ľikai; ka te mau hola  Ľi he fanga hoosi; ko ia te mou hola:‚ÄĚ pea, ‚ÄúTe mau heka  Ľi he ve Ľe vave; ko ia  Ľe ve Ľe vave foki mo kinautolu  Ľoku tuli  Ľakimoutolu.‚ÄĚ  
\v 17 ‚ÄĆ ĽE hola  Ľae toko taha afe  Ľi he valoki  Ľo ha tokotaha;  Ľi he valoki  Ľoe toko nima te mou hola ai: kae Ľoua ke tuku  Ľakimoutolu  Ľo hangńď ko ha  Ľakau faka Ľilonga  Ľi he tumutumu  Ľo ha mo Ľunga, pea hangńď ko ha fuka  Ľi he tafungofunga.   
\p
\v 18 ¬∂ Pea ko ia  Ľe tatali ai  Ľa Sihova, koe Ľuhi ke ne  Ľalo Ľofa kiate kimoutolu, pea ko ia  Ľe fakahikihiki Ľi ia, koe Ľuhi ke ne  Ľalo Ľofa kiate kimoutolu: he ko Sihova ko e  ĽOtua ia  Ľoe fakamaau:  Ľoku monŇę Ľia  Ľakinautolu kotoa pńď  Ľoku tatali kiate ia.  
\v 19 Koe Ľuhi  Ľe nofo  Ľae kakai  Ľi Saione  Ľi SelŇęsalema:  Ľe  Ľikai te ke toe tangi: te ne fai lelei lahi kiate koe  Ľi he le Ľo  Ľo ho Ľo tangi;  Ľi he Ľene fanongo ki ai, te ne talia koe.  
\v 20 Pea neongo  Ľae  Ľatu kiate koe  Ľe Sihova  Ľae mńĀ  Ľoe ongosia, pea mo e vai  Ľoe mamahi, ka e  Ľikai toe  Ľave ho Ľo kau akonaki ki ha tuliki, ka e mamata  Ľe ho mata ki ho Ľo kau akonaki.  
\v 21 Pea ka ke ka afe ki he to Ľomata Ľu, pea  Ľi ho Ľo afe ki he to Ľohema,  Ľe fanongo  Ľe ho telinga ki ha lea mei ho tu Ľa,  Ľo pehńď, ‚ÄúKo eni  Ľae hala, ke ke  Ľalu  Ľi ai.‚ÄĚ  
\v 22 Te mou fakalielia Ľi foki  Ľae  Ľufi Ľufi  Ľo ho Ľo ngaahi tamapua siliva kuo tongitongi, pea mo e teunga  Ľo ho Ľo ngaahi tamapua koula kuo haka: te ke li Ľaki  Ľakinautolu  Ľo hangńď ko ha kofu fakalielia; te ke pehńď ki ai, ‚Äú ĽAlu koe  Ľi heni.‚ÄĚ  
\v 23 Pea te ne toki foaki  Ľae  Ľuha ki ho Ľo ngaahi tenga, koe Ľuhi ke ke tŇętuu Ľi ki he kelekele; mo e mńĀ ko e fua  Ľoe kelekele, pea  Ľe lahi ia pea mahu: pea  Ľi he  Ľaho ko ia  Ľe kai  Ľe ho fanga manu  Ľi he ngaahi potu  Ľata ĽatńĀ.  
\v 24 Pea ko e fanga pulu mo e fanga  Ľasi mui  Ľoku fakamolŇę  Ľae kelekele, te nau kai  Ľae me Ľakai lelei,  Ľaia kuo fakama Ľa  Ľaki  Ľae fohe mo e lńę.  
\v 25 Pea  Ľe  Ľi ai  Ľi he ngaahi mo Ľunga mńĀ Ľolunga kotoa pńď, pea  Ľi he ngaahi tafungofunga mńĀ Ľolunga kotoa pńď,  Ľae ngaahi vai mo e vaitafe  Ľi he  Ľaho  Ľoe tńĀmate Ľi lahi,  Ľoka hinga  Ľae ngaahi fale mńĀ Ľolunga.  
\v 26 Pea  Ľe tatau  Ľae maama  Ľoe mńĀhina mo e maama  Ľoe la ĽńĀ, pea  Ľe liunga fitu hono lahi hake  Ľoe maama  Ľoe la ĽńĀ,  Ľo hangńď ko e maama  Ľoe  Ľaho  Ľe fitu,  Ľi he  Ľaho  Ľoku nono Ľo ai  Ľe Sihova  Ľae lavea  Ľo hono kakai, pea fakamo Ľui  Ľae volu  Ľo honau te Ľia.   
\p
\v 27 ¬∂ Vakai,  Ľoku ha Ľu  Ľae huafa  Ľo Sihova mei he mama Ľo,  Ľoku vela  Ľi hono houhau, pea  Ľoku mamafa  Ľae kavenga  Ľo ia:  Ľoku fonu hono mu Ľa fofonga  Ľi he houhau, pea hangńď ko e afi faka Ľauha hono  Ľelelo.  
\v 28 Pea ko  Ľene mńĀnava,  Ľoku hangńď ko e vaitafe  Ľoku lŇćfia,  Ľe hake ia  Ľo a Ľu ki he kia, ke lńę ki  Ľolunga  Ľae ngaahi pule Ľanga  Ľaki  Ľae fohe  Ľoe mala Ľia: pea  Ľe ai ha me Ľa ta Ľofi  Ľi he ngao  Ľoe kakai, ke fakahala Ľi  Ľakinautolu.  
\v 29 Te mou fai ha hiva,  Ľo hangńď ko e pŇć  Ľoka fai ai  Ľae fakataha mńĀ Ľoni Ľoni; pea ma Ľu mo e fiefia  Ľoe loto,  Ľo hangńď ha taha  Ľoku  Ľalu mo e me Ľa ifi ke ha Ľu ki he mo Ľunga  Ľo Sihova, ki he Toko Taha MńĀfimafi  Ľo  ĽIsileli.  
\v 30 Pea  Ľe fakaongo atu  Ľe Sihova hono le Ľo mńĀlohi, pea  Ľe fakahńĀ  Ľae tuku hifo  Ľa hono nima,  Ľaki  Ľae mńĀsila  Ľo hono houhau, pea mo e ulo  Ľoe afi faka Ľauha,  Ľaki  Ľae veteki, mo e afńĀ, mo e  Ľuha maka.  
\v 31 Ko e le Ľo  Ľo Sihova  Ľe tńĀ hifo ai  Ľae kakai  Ľo  ĽAsilia,  Ľaia na Ľe tńĀ  Ľaki honau tokotoko.  
\v 32 Pea ko e potu kotoa pńď  Ľe  Ľalu ia ki ai,  Ľe  Ľi ai  Ľae me Ľa tńĀ  Ľoe tautea,  Ľaia  Ľe ai mamafa  Ľe Sihova kiate ia:  Ľe  Ľalu mo ia  Ľae ngaahi lali iiki mo e ha Ľape: pea  Ľi he ngaahi tau fakamanavahńď te ne tau Ľi  Ľakinautolu.  
\v 33 He kuo tu Ľutu Ľuni  Ľi mu Ľa  Ľa Tofeti;  Ľio, kuo teuteu ia ma Ľa e tu Ľi; kuo ne ngaohi ia ke loloto pea laulahi: ko e fokotu Ľunga ia  Ľoe afi mo e fefie lahi:  Ľoku tutu ia  Ľe he mńĀnava  Ľa Sihova,  Ľo hangńď ko e sulifa  Ľoku tafe.   
\c 31  
\cd \it 1  ĽOku fakahńĀ  Ľe he palŇćfita  Ľae vale mo e tu ĽutńĀmaki  Ľoe fa Ľaki ki  ĽIsipite kae li Ľaki  Ľae  ĽOtua. 6  ĽOku ne enginaki ke liliu. 8  ĽOku ne fakahńĀ  Ľae hinga  Ľo  ĽAsilia.\it*  
\q1
\v 1 ‚ÄĆ ĽE mala Ľia  Ľakinautolu  Ľoku  Ľalu hifo ki  ĽIsipite ke kumi  Ľae tokoni;  
\q2 pea fa Ľaki ki he fanga hoosi,  
\q2 mo falala ki he ngaahi saliote, koe Ľuhi  Ľoku nau tokolahi;  
\q2 pea  Ľi he kau tangata heka hoosi, koe Ľuhi  Ľoku nau mńĀlohi  Ľaupito;  
\q2 ka  Ľoku  Ľikai te nau vakai ki he tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli,  
\q2 pe kumi kia Sihova!   
\q1
\v 2 Ka  Ľoku ne poto foki mo ia, pea te ne fakahoko mai  Ľae kovi,  
\q2 pea  Ľe  Ľikai fakafoki  Ľene ngaahi folofola: ka te ne tu Ľu hake ki he fale  Ľoe fai kovi,  
\q2 pea kiate kinautolu  Ľoku tokoni ki he kau fai kovi.   
\q1
\v 3 Ko eni, ko e tangata pe  Ľae kau  ĽIsipite, ka  Ľoku  Ľikai ko e  ĽOtua;  
\q2 pea ko e kakano pe  Ľa  Ľenau fanga hoosi, ka  Ľoku  Ľikai ke laumńĀlie.  
\q1  ĽOku mafao atu  Ľe Sihova hono nima,  Ľe hinga ia  Ľaia na Ľe tokoni,  
\q2 pea ko ia na Ľe ma Ľu  Ľae tokoni  Ľe tŇć ki lalo,  
\q2 pea te na vaivai fakataha.   
\q1
\v 4 He kuo folofola pehńď  Ľe Sihova kiate au,  
\q1 ‚Äú ĽO hangńď ko e ngungulu  Ľoe laione mo e laione mui  Ľi he Ľene kai,  
\q2  Ľoka fakataha  Ľae kau tauhi kotoa pńď ke fai mo ia,  
\q2  Ľe  Ľikai te ne manavahńď ki honau le Ľo,  
\q2 pe fakavaivai ia koe Ľuhi ko honau tokolahi:  
\q2  Ľe pehńď  Ľae hńĀ Ľele hifo  Ľa Sihova  Ľoe ngaahi kautau ke fai  Ľae tau, ma Ľa e mo Ľunga ko Saione, pea mo hono tafungofunga.   
\q1
\v 5 ‚ÄĆ ĽO hangńď ko e puna  Ľae fanga manu,  Ľe fakahaofi pehńď  Ľe Sihova  Ľoe ngaahi kautau  Ľa SelŇęsalema:  
\q2  Ľi he Ľene malu Ľi te ne fakamo Ľui ia;  
\q2 pea  Ľi he Ľene hńĀ Ľele atu te ne fakahaofi ia.‚ÄĚ   
\q1
\v 6 Tafoki  Ľakimoutolu kiate ia  Ľaia kuo angatu Ľu  Ľaupito ki ai  Ľae fńĀnau  Ľa  ĽIsileli.  
\v 7 Pea  Ľi he  Ľaho ko ia  Ľe li Ľaki  Ľe he tangata kotoa pńď  Ľene ngaahi tamapua siliva, pea mo  Ľene ngaahi tamapua koula,  Ľaia kuo ngaohi  Ľe homou nima kiate kimoutolu ko e angahala.   
\p
\v 8 ¬∂ ‚ÄúPea  Ľe toki tŇć  Ľae tangata  ĽAsilia  Ľi he heletńĀ, kae  Ľikai  Ľo ha tangata mńĀlohi;  
\q2 pea  Ľe kai ia  Ľe he heletńĀ, kae  Ľikai  Ľo ha tangata me Ľa vale:  
\q1 ka te ne hola mei he heletńĀ,  
\q2 pea  Ľe vaivai  Ľene kau talavou.   
\q1
\v 9 Pea  Ľi he manavahńď te ne  Ľalu ki hono potu mńĀlohi,  
\q2 pea  Ľe manavahńď hono ngaahi hou Ľeiki ki he fuka,‚ÄĚ  
\q1  Ľoku pehńď  Ľe Sihova,  Ľaia  Ľoku  Ľi Saione  Ľene afi,  
\q2 pea  Ľoku  Ľi SelŇęsalema  Ľene ngoto Ľumu vela.   
\c 32  
\cd \it 1 Ko e ngaahi tńĀpuaki  Ľoe pule Ľanga  Ľa Kalaisi. 9  ĽOku fakahńĀ  Ľae faka Ľauha. 15  ĽOku faka Ľilo  Ľe hoko  Ľae fakamo Ľui.\it*  
\q1
\v 1 Vakai  Ľe pule ha tu Ľi  Ľi he mńĀ Ľoni Ľoni,  
\q2 pea  Ľe pule mo e ngaahi hou Ľeiki  Ľi he fai angatonu.   
\q1
\v 2 Pea  Ľe  Ľi ai  Ľae tangata  Ľo hangńď ko e toitoi Ľanga mei he matangi,  
\q2 mo e hŇęfanga mei he afńĀ;  
\q2 pea hangńď ko e ngaahi vaitafe  Ľi he potu mŇćmoa,  
\q2  Ľo hangńď ko e malumalu  Ľo ha maka lahi  Ľi he fonua  Ľoku puhengia.   
\q1
\v 3 Pea  Ľe  Ľikai nenefu  Ľae mata  Ľokinautolu  Ľoku  Ľaa,  
\q2 pea  Ľe fakafanongo  Ľae telinga  Ľokinautolu  Ľoku ongo.   
\q1
\v 4 Pea ko e loto  Ľoe  Ľohonoa  Ľe tokanga pea ma Ľu  Ľae  Ľilo,  
\q2 pea ko e  Ľelelo  Ľoku le Ľole Ľovale  Ľe lea vave mo totonu.   
\q1
\v 5 ‚ÄĆ ĽE  Ľikai toe ui  Ľae angakovi ko e angalelei,  
\q2 pe pehńď ko e fa Ľa foaki  Ľaia  Ľoku manumanu.   
\q1
\v 6 He ko e tangata vale te ne lea vale,  
\q2 pea  Ľe ngńĀue kovi hono loto,  
\q2 ke fai kńĀkńĀ,  
\q2 pea lea hala kia Sihova,  
\q2 ke fakamaha  Ľae laumńĀlie  Ľoe fiekaia,  
\q2 pea ta Ľofi  Ľe ia  Ľae inu mei he fieinua.   
\q1
\v 7 Ko e ngaahi me Ľa ngńĀue  Ľoe angakovi  Ľoku kovi:  
\q2  Ľoku ne fakakaukau kovi ke fakafihi  Ľae masiva  Ľaki  Ľae lea loi,  
\q2 pea ke mio Ľi  Ľae lea totonu  Ľae masiva  Ľi he fakamaau.   
\q1
\v 8 Ka ko e angalelei  Ľoku ne fakakaukau ki he ngaahi me Ľa lelei;  
\q2 pea  Ľi he ngaahi me Ľa lelei  Ľe fokotu Ľuma Ľu ia.   
\q1
\v 9 Mou tu Ľu hake,  Ľakimoutolu  Ľae kau fefine  Ľoku nofo fakafiemńĀlie; fanongo ki hoku le Ľo,  
\q2  Ľakimoutolu  Ľae ngaahi  Ľofefine ta Ľetokanga; fakafanongo ki he Ľeku lea.   
\q1
\v 10 Te mou ongosia  Ľi he ngaahi  Ľaho mo e ta Ľu lahi,  Ľakimoutolu  Ľae kau fefine ta Ľetokanga:  
\q2 koe Ľuhi  Ľe  Ľikai hoko  Ľae ngaohi  Ľoe vaine,  
\q2  Ľe  Ľikai hoko hono tńĀnaki.   
\q1
\v 11 Ke tetetete,  Ľakimoutolu  Ľae kau fefine  Ľoku fakafiemńĀlie;  
\q2 ke mamahi,  Ľakimoutolu  Ľoku ta Ľetokanga:  
\q2 vete homou kofu, fakatelefua  Ľakimoutolu,  
\q2 pea nono Ľo  Ľae tauanga Ľa ki homou no Ľotanga vala.   
\q1
\v 12 Te nau lńĀunga koe Ľuhi ko e mata  Ľoe huhu, pea ki he ngaahi ngoue lelei,  
\q2 pea ki he vaine fua.   
\q1
\v 13 ‚ÄĆ ĽE tupu hake  Ľae ngaahi  Ľakau talatala mo e talatala ĽńĀmoa  Ľi he fonua  Ľo hoku kakai;  
\q2  Ľio,  Ľi he ngaahi fale fakafiefia kotoa pńď  Ľi he kolo  Ľoe fiefia:   
\q1
\v 14 Koe Ľuhi kuo li Ľaki  Ľae ngaahi fale faka Ľei Ľeiki;  
\q2 ko e kolo  Ľoe tokolahi kuo si Ľaki;  
\q2  Ľe hoko  Ľae ngaahi puke mo e ngaahi fale mńĀ Ľolunga ko e ngaahi  Ľana  Ľo ta Ľengata,  
\q2 ko e fiefia Ľanga  Ľoe fanga  Ľasi kaivao,  
\q2 ko e keinanga Ľanga  Ľoe fanga manu;   
\q1
\v 15 Kae Ľoua ke hua Ľi hifo kiate kitautolu  Ľae laumńĀlie mei  Ľolunga,  
\q2 pea hoko  Ľae toafa ko e ngoue fa Ľa fua,  
\q2 pea lau  Ľae ngoue fa Ľa fua ko e vao  Ľakau.   
\q1
\v 16 Pea  Ľe toki nofo  Ľae fakamaau  Ľi he toafa,  
\q2 pea nofo  Ľae mńĀ Ľoni Ľoni  Ľi he ngoue fa Ľa fua.   
\q1
\v 17 Pea ko e ngńĀue  Ľoe mńĀ Ľoni Ľoni ko e melino ia;  
\q2 pea ko e fua  Ľoe mńĀ Ľoni Ľoni ko e fiemńĀlie mo e nofo lelei  Ľo ta Ľengata.   
\q1
\v 18 Pea  Ľe nofo  Ľa hoku kakai  Ľi he nofo Ľanga  Ľoe melino,  
\q2 pea  Ľi he ngaahi fale tu Ľuma Ľu,  
\q2 pea  Ľi he ngaahi mńĀlŇćlŇć Ľanga  Ľoe fiemńĀlie;   
\q1
\v 19 Ka e tŇć  Ľae  Ľuha maka, pea  Ľe fakahinga  Ľae vao  Ľakau;  
\q2 pea  Ľe fakamo Ľulaloa  Ľaupito  Ľae kolo.   
\q1
\v 20 ‚ÄĆ ĽOku monŇę Ľia  Ľakimoutolu  Ľoku tŇętuu Ľi  Ľi he ve Ľe vai kotoa pńď,  
\q2 pea fekau atu ki ai  Ľae va Ľe  Ľoe pulu mo e  Ľasi.   
\c 33  
\cd \it 1 Ko e houhau  Ľoe  ĽOtua ki he ngaahi fili  Ľae siasi. 13 Ko e monŇę Ľia  Ľoe angafaka Ľotua.\it*  
\q1
\v 1 Ke mala Ľia  Ľa koe  Ľoku ke fakamńĀlohi, ka na Ľe  Ľikai fakamńĀlohi Ľi koe;  
\q2  Ľa koe  Ľoku fai kńĀkńĀ, ka na Ľe  Ľikai ke kńĀkaa Ľi koe!  
\q1  ĽOka ke ka tuku ho Ľo fakamńĀlohi,  Ľe toki fakamńĀlohi Ľi koe;  
\q2 pea ka  Ľosi ho Ľo fai kńĀkńĀ,  Ľe toki kńĀkaa Ľi koe.   
\b  
\q1
\v 2 ‚ÄĆ ĽE Sihova, ke ke  Ľalo Ľofa kiate kimautolu; kuo mau tatali kiate koe:  
\q2 ke ke hoko ko homau mńĀlohi  Ľi he pongipongi kotoa pńď,  
\q2  Ľio, ko homau fakamo Ľui  Ľi he kuonga  Ľoe mamahi.   
\q1
\v 3 ‚ÄĆ ĽI he longoa Ľa  Ľoe tokolahi na Ľe hola  Ľae kakai;  
\q2  Ľi ho Ľo tu Ľu hake  Ľa Ľau, na Ľe veteki  Ľae ngaahi pule Ľanga.   
\q1
\v 4 Ka e tńĀnaki ho Ľomou koloa  Ľoe vete  Ľo hangńď ko e tńĀnaki  Ľe he  Ľunufe:  
\q2  Ľo hangńď ko e fehŇćpoaki  Ľoe ngaahi he Ľe te ne lele kiate kinautolu.   
\q1
\v 5 Kuo hiki hake  Ľa Sihova; he kuo  Ľafio ia  Ľi  Ľolunga:  
\q2 kuo ne fakafonu  Ľa Saione  Ľaki  Ľae fakamaau mo e angatonu.   
\q1
\v 6 Pea  Ľe hoko  Ľae poto mo e  Ľilo ko e mńĀlohi  Ľo ho kuonga, mo e mńĀlohi  Ľoe fakamo Ľui:  
\q2 ko e manavahńď kia Sihova ko  Ľene koloa ia.   
\q1
\v 7 Vakai, ko  Ľenau kau to Ľa,  Ľe tangi  Ľitu Ľa:  
\q2  Ľe tangi mamahi  Ľae kau faifekau  Ľoe melino.   
\q1
\v 8 Kuo vaoa  Ľae ngaahi hala motu Ľa,  
\q2 kuo  Ľikai ha tangata fononga:  
\q2 kuo ne maumau Ľi  Ľae fuakava,  
\q2 kuo ne fehi Ľa ki he ngaahi kolo,  
\q2  Ľoku  Ľikai te ne manavahńď ki ha tangata  Ľe taha.   
\q1
\v 9 ‚ÄĆ ĽOku mamahi  Ľae fonua pea vaivai:  
\q2 kuo mńĀ  Ľa Lepanoni, kuo tńĀ hifo ia:  
\q2  Ľoku tatau mo e potu vao  Ľa Saloni; pea  Ľoku fakangangana  Ľae ngaahi fua  Ľo Pesani mo Kameli.   
\q1
\v 10 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚Äúte u tu Ľu hake ni:  
\q2 te u hiki hake ni au ki  Ľolunga,  
\q2 pea  Ľe hakeaki Ľi ni au.   
\q1
\v 11 Te mou tuitu Ľia ko e kafukafu,  
\q2 te mou fanau Ľi ko e veve:  
\q2 ko ho Ľomou mńĀnava,  Ľo hangńď ko e afi, te ne faka Ľauha  Ľakimoutolu.   
\q1
\v 12 Pea  Ľe tutu  Ľae kakai  Ľo hangńď ko e vela  Ľoe lahe:  
\q2  Ľo hangńď ko e  Ľakau talatala kuo tutu Ľu ke vela  Ľi he afi.   
\q1
\v 13 Fanongo,  Ľakimoutolu  Ľoku mama Ľo, ki he me Ľa kuo u fai;  
\q2 pea  Ľilo mo kimoutolu  Ľoku ofi, ki hoku mńĀlohi.‚ÄĚ   
\q1
\v 14 ‚ÄĆ ĽOku manavahńď  Ľae kau angahala  Ľi Saione;  
\q2 kuo pukea  Ľi he ilifia  Ľae kau mńĀlualoi.  
\q1 ‚ÄúKo hai  Ľiate kitautolu  Ľe nofo  Ľi he afi faka Ľauha?  
\q2 Ko hai  Ľiate kitautolu  Ľe nofo  Ľi he vela ta Ľengata?‚ÄĚ   
\q1
\v 15 Ko ia  Ľoku  Ľeve Ľeva  Ľi he mńĀ Ľoni Ľoni,  
\q2 mo lea totonu;  
\q2 ko ia  Ľoku fehi Ľa ki he koloa  Ľoe fakamńĀlohi,  
\q2  Ľoku tupe Ľi hono nima mei he puke  Ľae koloa  Ľoku ma Ľu ta Ľetotonu,  
\q2  Ľoku tńĀpuni hono telinga mei he fanongo ki he toto,  
\q2 pea fakamohe hono mata ke  Ľoua na Ľa mamata ki he kovi;   
\q1
\v 16 ‚ÄĆ ĽE nofo ia  Ľi he mńĀ Ľolunga:  
\q2 ko hono potu unga Ľanga ko e ngaahi kolo maka mńĀ Ľolunga:  
\q2  Ľe foaki kiate ia  Ľae mńĀ;  
\q2 pea te ne ma Ľu mo Ľoni  Ľe ia  Ľene vai.   
\q1
\v 17 ‚ÄĆ ĽE mamata ho mata ki he tuli  Ľi hono nńĀunau:  
\q2  Ľe sio ia ki he fonua  Ľaia  Ľoku mama Ľo atu.   
\q1
\v 18 ‚ÄĆ ĽE fakalaulauloto  Ľa ho loto ki he ilifia.  
\q2 Kofa ĽńĀ  Ľae tangata tohi?  
\q2 Kofa ĽńĀ ia  Ľae tangata fakamamafa me Ľa?  
\q2 Kofa ĽńĀ ia na Ľe lau  Ľae ngaahi fale mńĀ Ľolunga?   
\q1
\v 19 ‚ÄĆ ĽE  Ľikai te ke mamata ki he kakai  Ľoku lili,  
\q2 ha kakai  Ľoe lea  Ľilongata Ľa  Ľoku  Ľikai te ke fa Ľa ongo Ľi;  
\q2  Ľo ha  Ľelelo le Ľo vale,  Ľoku  Ľikai te ke fa Ľa  Ľilo.   
\q1
\v 20 Vakai ki Saione, ko e kolo  Ľo  Ľetau ngaahi kńĀtoanga mamalu:  
\q2  Ľe mamata ho mata ki SelŇęsalema ko e nofo Ľanga fiemńĀlie,  
\q2 ko e fale fehikitaki  Ľe  Ľikai veteki;  
\q1  Ľe  Ľikai hiki  Ľo ta Ľengata ha pou  Ľe taha  Ľi ai,  
\q2 pea  Ľe  Ľikai motu hano afo  Ľe taha  Ľo Ľona.   
\q1
\v 21 Ka e  Ľiate kitautolu  Ľa Sihova nńĀunau Ľia,  
\q2 ko e potu  Ľoe ngaahi vaitafe laulahi mo e ngaahi mangamanga Ľi vai;  
\q2  Ľaia  Ľe  Ľikai  Ľalu  Ľi ai ha vakafokotu Ľu mo e ngaahi fohe,  
\q2 pea  Ľe  Ľikai  Ľalu  Ľi ai ha vaka lahi.   
\q1
\v 22 He ko Sihova ko hotau fakamaau,  
\q2 ko Sihova ko hotau fai fono,  
\q2 ko Sihova ko hotau tu Ľi;  
\q2 te ne fakamo Ľui  Ľakitautolu.   
\b  
\q1
\v 23 Kuo tukuange ho Ľo ngaahi maea;  
\q2 na Ľe  Ľikai te nau fakatu Ľuma Ľu honau fanńĀ,  
\q2 na Ľe  Ľikai te nau fa Ľa fofola  Ľae lńĀ:  
\q1  Ľi he kuonga ko ia  Ľe tufa  Ľae koloa lahi,  
\q2  Ľe  Ľave  Ľe he ketu  Ľae koloa  Ľi he vete.   
\b  
\q1
\v 24 Pea  Ľe  Ľikai pehńď  Ľe kinautolu  Ľoku nofo ai, ‚Äú ĽOku ou mahaki:‚ÄĚ  
\q2  Ľe fakamolemole  Ľae hia  Ľokinautolu  Ľoku nofo ai.   
\c 34  
\cd \it 1 Ko e ngaahi tautea  Ľoku tautea  Ľaki  Ľe he  ĽOtua  Ľae ngaahi fili  Ľa hono siasi. 11 Ko e  Ľauha  Ľo hono ngaahi fili. 16 Ko hono mo Ľoni  Ľoe kikite ni.\it*  
\q1
\v 1 Ha Ľu ke ofi,  Ľakimoutolu  Ľae ngaahi pule Ľanga,  Ľo fanongo; pea fakafanongo,  Ľakimoutolu  Ľae kakai:  
\q2 tuku ke fanongo  Ľa mńĀmani,  
\q2 mo ia kotoa pńď  Ľoku  Ľi ai;  
\q2  Ľa mńĀmani, mo e ngaahi me Ľa kotoa pńď  Ľoku tupu mei ai.   
\q1
\v 2 He  Ľoku  Ľi he ngaahi pule Ľanga kotoa pńď  Ľae tuputńĀmaki  Ľa Sihova,  
\q2 mo hono houhau lahi  Ľoku  Ľi honau ngaahi kongakau kotoa pńď:  
\q1 kuo ne faka Ľauha mńĀlie  Ľakinautolu,  
\q2 kuo ne tukuange  Ľakinautolu ke tńĀmate Ľi.   
\q1
\v 3 Mo  Ľenau mate foki  Ľe lńę kitu Ľa,  
\q2 pea  Ľe  Ľalu hake  Ľae namuhńĀhńĀ mei honau  Ľanga Ľanga,  
\q2 pea  Ľe molŇę  Ľo vai  Ľae ngaahi mo Ľunga  Ľi honau toto.   
\q1
\v 4 Pea  Ľe vela  Ľo vai  Ľae ngaahi kautau kotoa pńď  Ľoe langi,  
\q2 pea  Ľe tńĀkai  Ľae ngaahi langi  Ľo hangńď ko e takainga pepa:  
\q2 pea  Ľe tŇć ki lalo  Ľa honau tokolahi,  
\q2  Ľo hangńď ko e ngangana  Ľoe lau mei he vaine, pea tatau mo e fiki  Ľoku tŇć mei he  Ľakau ko e fiki.   
\q1
\v 5 He kuo to Ľo  Ľa  Ľeku heletńĀ  Ľi he langi:  
\q2 Vakai,  Ľe  Ľalu hifo ia ki Itumia,  
\q2 pea ki he kakai  Ľo hoku houhau, ke totongi.   
\q1
\v 6 Kuo fonu  Ľae heletńĀ  Ľa Sihova  Ľi he toto,  
\q2 kuo pani ia  Ľi he ngako, pea  Ľi he toto  Ľoe fanga lami mo e fanga kosi,  
\q2  Ľi he ngako  Ľoe kofuua  Ľoe fanga sipitangata:  
\q2 he  Ľoku  Ľia Sihova  Ľae feilaulau  Ľi Posela,  
\q2 pea mo e tńĀmate Ľi lahi  Ľi he fonua ko Itumia.   
\q1
\v 7 Pea  Ľe  Ľalu hifo mo kinautolu  Ľae fanga liimi,  
\q2 mo e fanga pulu fakataha mo e fanga pulu tangata;  
\q2 pea  Ľe konńĀ honau fonua  Ľi he toto,  
\q2 pea  Ľe koloa Ľia  Ľae kelekele  Ľi he ngako.   
\q1
\v 8 He ko e  Ľaho ia  Ľoe houhau  Ľo Sihova,  
\q2 pea ko e ta Ľu  Ľoe ngaahi totongi kiate ia  Ľoku fakahaofi  Ľa Saione.   
\q1
\v 9 Pea  Ľe liliu  Ľae ngaahi vaitafe  Ľo ia ko e pulu,  
\q2 pea mo e efu  Ľo ia ko e sulifa,  
\q2 pea ko e fonua ko ia  Ľe hoko ko e pulu vela.   
\q1
\v 10 ‚ÄĆ ĽE  Ľikai fu Ľifu Ľi ia  Ľi he pŇć pe  Ľi he  Ľaho;  
\q2  Ľe  Ľalu hake ta Ľengata  Ľae kohu mei ai:  
\q2  Ľe lala ia mei he to Ľutangata ki he to Ľutangata;  
\q2  Ľe  Ľikai fou ai ha taha  Ľo ta Ľengata pea ta Ľengata.   
\q1
\v 11 Ka e ma Ľu ia  Ľe he komolaniti pea mo e pitane;  
\q2  Ľe nofo ai  Ľae lulu mo e leveni:  
\q1 pea te ne falŇć ki ai  Ľae afo  Ľae faka Ľauha,  
\q2 pea mo e fua  Ľoe faka Ľosi Ľosi.   
\q1
\v 12 Te nau ui honau hou Ľeiki ki he pule Ľanga, ka e  Ľikai ha taha  Ľi ai,  
\q2 pea ko e me Ľa noa pe hono hou Ľeiki kotoa pńď.   
\q1
\v 13 Pea  Ľe tutu  Ľae  Ľakau talatala  Ľi hono ngaahi fale faka Ľei Ľeiki,  
\q2 ko e  Ľakau veli mo e  Ľakau talatala  Ľi hono ngaahi kolo:  
\q2 pea  Ľe hoko ia ko e nofo Ľanga  Ľoe fanga talńĀkoni,  
\q2 pea ko e potu  Ľoe fanga lulu.   
\q1
\v 14 ‚ÄĆ ĽE fetaulaki  Ľae manu fekai  Ľoe toafa mo e manu fekai  Ľoe motu,  
\q2 pea  Ľe tangi  Ľae sataia ki hono toko ua;  
\q1 pea  Ľe mńĀlŇćlŇć ai  Ľae lulu  Ľoku tangi,  
\q2 pea  Ľilo ai mo Ľona ha mńĀlŇćlŇć Ľanga.   
\q1
\v 15 ‚ÄĆ ĽE ngaohi  Ľi ai  Ľe he motu Ľa lulu hono pununga,  
\q2 pea fakatŇć, pea fŇćfoa Ľi, pea tńĀnaki ki hono malumalu:  
\q2  Ľe tńĀnaki foki  Ľi ai  Ľae ngaahi volita, taki taha mo hono hoa.   
\q1
\v 16 Kumi  Ľakimoutolu  Ľi he tohi  Ľa Sihova, pea lau;  
\q2  Ľe  Ľikai ha taha  Ľi he ngaahi me Ľa ni  Ľe ta Ľehoko,  
\q2  Ľe  Ľikai masiva ha taha  Ľi hono hoa:  
\q2 he kuo fekau ia  Ľe hoku ngutu,  
\q2 pea ko hono laumńĀlie kuo tńĀnaki  Ľe ia  Ľakinautolu.   
\q1
\v 17 Pea kuo ne talotalo  Ľe ia ma Ľanautolu,  
\q2 pea ko hono nima kuo vahe Ľi ia kiate kinautolu  Ľaki  Ľae afo:  
\q2 te nau ma Ľu ia  Ľo lauikuonga,  
\q2 pea te nau nofo ai mei he to Ľutangata ki he to Ľutangata.   
\b  
\c 35  
\cd \it 1 Ko e monŇę Ľia fakafiefia  Ľoe pule Ľanga  Ľo Kalaisi. 3  ĽOku ma Ľu  Ľae tokoni  Ľe he vaivai;  Ľi he lelei mo e tńĀpuaki  Ľoe ongoongolelei.\it*  
\q1
\v 1 ‚ÄĆ ĽE fiefia  Ľae toafa mo e potu lala koe Ľuhi ko kinautolu,  
\q2 pea  Ľe fiefia  Ľae potu li Ľaki, pea fisi  Ľo hangńď ko e lose.   
\q1
\v 2 ‚ÄĆ ĽE fisi lahi ia,  
\q2 pea fiefia  Ľi he fiefia mo e hiva:  
\q2  Ľe foaki ki ai  Ľae nńĀunau  Ľo Lepanoni,  
\q2 ko e lelei  Ľo Kameli mo Saloni:  
\q2 te nau mamata ki he nńĀunau  Ľo Sihova,  
\q2 mo e lelei lahi  Ľo hotau  ĽOtua.   
\q1
\v 3 Mou tokoni ki he nima vaivai,  
\q2 pea poupou  Ľae tui  Ľoku fengatali Ľaki.   
\q1
\v 4 Ke ke pehńď kiate kinautolu  Ľoku loto manavasi Ľi, ‚ÄúKe mou mńĀlohi,  
\q2  Ľoua  Ľe manavahńď:  
\q2 vakai,  Ľe hńĀ Ľele mai homou  ĽOtua mo e tautea,  
\q2  Ľio,  Ľae  ĽOtua  Ľaki  Ľae totongi;  
\q2 te ne hńĀ Ľele mai  Ľo fakamo Ľui  Ľakimoutolu.‚ÄĚ   
\q1
\v 5 Pea  Ľe toki faka ĽńĀ  Ľae mata  Ľoe kui,  
\q2 pea  Ľe fakaava mo e telinga  Ľoe tuli.   
\q1
\v 6 Pea  Ľe toki hopohopo  Ľae tangata ketu  Ľo hangńď ko e hainite,  
\q2 pea  Ľe hiva  Ľae  Ľelelo  Ľoe noa:  
\q2 koe Ľuhi  Ľe tupu  Ľi he toafa  Ľae ngaahi vai,  
\q2 mo e ngaahi vaitafe  Ľi he potu lala.   
\q1
\v 7 Pea  Ľe hoko  Ľae kelekele mŇćmoa ko e anovai,  
\q2 mo e fonua fieinu ko e ngaahi matavai:  
\q2 pea ko e nofo Ľanga  Ľoe fanga talńĀkoni,  Ľi he potu na Ľe taki taha tokoto ai,  Ľe tupu ai  Ľae mohuku mo e kaho mo e mohuku  Ľoe ano.   
\q1
\v 8 Pea  Ľe  Ľi ai  Ľae hala motu Ľa, pea mo e hala,  
\q2 pea  Ľe ui ia ‚ÄėKo e Hala  Ľoe MńĀ Ľoni Ľoni;‚Äô  
\q1  Ľe  Ľikai  Ľalu ai  Ľae ta Ľema Ľa;  
\q2 ka e tuku ia kiate kinautolu ni:  
\q2 pea neongo ko e vale  Ľae kakai fononga  Ľe  Ľikai te nau hńď ai.   
\q1
\v 9 ‚ÄĆ ĽE  Ľikai  Ľi ai ha laione,  
\q2 pea  Ľe  Ľikai  Ľalu hake ki ai ha manu fekai,  
\q2  Ľe  Ľikai  Ľilo ia  Ľi ai;  
\q2 ka  Ľe  Ľeve Ľeva ai  Ľae kakai kuo huhu Ľi:   
\q1
\v 10 Pea  Ľe foki mai  Ľae kakai kuo huhu Ľi  Ľe Sihova,  
\q2  Ľo ha Ľu ki Saione mo e ngaahi hiva,  
\q2 mo e fiefia ta Ľengata  Ľi honau  Ľulu:  
\q1 te nau ma Ľu  Ľae fiefia mo e nekeneka,  
\q2 pea  Ľe puna atu  Ľae mamahi mo e to Ľe.‚ÄĚ   
\c 36  
\cd \it 1  ĽOku lau  Ľa Senakalipe ki Siuta. 4  ĽOku fekau atu  Ľa Lapisake  Ľe Senakalipe, pea  Ľi he ngaahi kńĀkńĀ  Ľoku ne fakaloto Ľi  Ľae kakai ke nau angatu Ľu. 22  ĽOku fakahńĀ  Ľene ngaahi lea kia Hesekaia.\it*  
\p
\v 1 Na Ľe hoko  Ľo pehńď  Ľi hono ta Ľu  Ľe hongofulu ma fńĀ  Ľoe pule  Ľa Hesekaia, na Ľe ha Ľu  Ľa Senakalipe ko e tu Ľi  Ľo  ĽAsilia ki he ngaahi kolo kotoa pńď  Ľo Siuta na Ľe teu ki he tau, pea ne lava Ľi  Ľakinautolu.  
\v 2 Pea na Ľe fekau atu  Ľe he tu Ľi  Ľo  ĽAsilia  Ľa Lapisake mei Lakisi ki SelŇęsalema kia Hesekaia mo e kongakau tokolahi mo ia. Pea na Ľa ne tu Ľu  Ľi he ve Ľevai taupotu ki  Ľolunga  Ľi he hala lahi  Ľoe ngoue  Ľae tangata fakama Ľa kofu.  
\v 3 Pea na Ľe toki ha Ľu kiate ia  Ľa Iliakimi, ko e foha  Ľo Hilikia,  Ľaia na Ľe pule  Ľi he fale, pea mo Sepina ko e tangata tohi, mo Soa, ko e foha  Ľo  ĽAsafi, ko e matńĀpule tohi.   
\p
\v 4 ¬∂ Pea pehńď  Ľe Lapisake kiate kinautolu, Mou pehńď kia Hesekaia, ‚Äú ĽOku pehńď  Ľe he tu Ľi lahi, ko e tu Ľi  Ľo  ĽAsilia, Ko e hńĀ końĀ  Ľae falala Ľanga ni  Ľoku ke falala ki ai?‚ÄĚ  
\v 5 Kuo ke pehńď  Ľe koe, (ka ko e lea ta Ľe Ľaonga,) ‚Äú ĽOku  Ľiate au  Ľae fakakaukau mo e mńĀlohi ki he tau: ka  Ľoku ke falala kia hai, ke ke angatu Ľu ai kiate au?  
\v 6 Vakai,  Ľoku ke fa Ľaki ki he tokoni  Ľoe kaho mafesi ni, ko  ĽIsipite;  Ľaia  Ľi he fa Ľaki ki ai ha tangata,  Ľe  Ľasi ia ki hono nima, pea  Ľe lavea ia:  Ľoku pehńď  Ľa Felo ko e tu Ľi  Ľo  ĽIsipite kiate kinautolu kotoa pńď  Ľoku falala kiate ia.‚ÄĚ  
\v 7 Ka  Ľi ho Ľo pehńď mai kiate au, ‚Äú ĽOku mau falala kia Sihova ko homau  ĽOtua:  Ľikai kuo li Ľaki  Ľe Hesekaia hono ngaahi potu mńĀ Ľolunga pea mo hono ngaahi feilaulau Ľanga pea ne pehńď ki Siuta, mo SelŇęsalema, ‚ÄėTe mou lotu  Ľi he  Ľao  Ľoe feilaulau Ľanga ni?‚Äô  
\v 8 Ko ia  Ľoku ou fekau kiate ko e ke ke  Ľomi  Ľae ngaahi me Ľa fakamo Ľoni, ki hoku  Ľeiki ko e tu Ľi  Ľo  ĽAsilia, pea te u foaki atu  Ľae hoosi  Ľe ua afe,  Ľo kapau te ke fa Ľa fakaheka  Ľe koe ha kau tangata ki ai.  
\v 9 Pea ka kuo pehńď,  Ľe fńďfńď ho Ľo fakafoki  Ľae mata  Ľo ha  Ľeikitau  Ľoku si Ľi hifo  Ľi he ngaahi tamaio Ľeiki  Ľo  Ľeku  Ľeiki, pea falala ki  ĽIsipite ke ma Ľu mei ai  Ľae ngaahi saliote mo e kau tangata heka hoosi?  
\v 10 Pea kuo u ha Ľu eni ki he fonua ni ke tau Ľi pea faka Ľauha ia ka e ta Ľekau ki ai  Ľa Sihova? Na Ľe pehńď mai  Ľe Sihova kiate au, ‚Äė ĽAlu hake ki he fonua ni, pea faka Ľauha ia.‚Äô‚ÄĚ   
\p
\v 11 ¬∂ Pea na Ľe toki pehńď  Ľe Iliakimi mo Sepina pea mo Soa kia Lapisake, ‚Äú ĽOku mau kole kiate koe, ke ke lea ki ho Ľo kau tamaio Ľeiki  Ľi he lea fakaSilia; he  Ľoku mau  Ľilo ia: kae Ľoua  Ľe lea kiate kimautolu  Ľi he lea fakaSiu,  Ľi he telinga  Ľoe kakai  Ľoku tu Ľu  Ľi he  ĽńĀ.   
\p
\v 12 ¬∂ Ka na Ľe pehńď  Ľe Lapisake, ‚ÄúKuo fekau au  Ľe he Ľeku  Ľeiki ki ho  Ľeiki pea mo koe ke lea  Ľaki  Ľae ngaahi lea ni?  ĽIkai kuo ne fekau au ki he kau tangata  Ľoku nofo  Ľi he  ĽńĀ, ke nau kai honau kinoha Ľa, pea inu honau tu Ľutata, fakataha mo kimoutolu?  
\v 13 Pea na Ľe toki tu Ľu hake  Ľa Lapisake, pea kalanga ia  Ľi he le Ľo lahi  Ľi he lea fakaSiu,  Ľo pehńď, Mou fanongo ki he lea  Ľae tu Ľi lahi,  Ľae tu Ľi lahi  Ľo  ĽAsilia.  
\v 14 ‚ÄĆ ĽOku pehńď  Ľe he tu Ľi,  Ľoua na Ľa tuku  Ľa Hesekaia ke kńĀkaa Ľi  Ľakimoutolu; koe Ľuhi  Ľe  Ľikai te ne fa Ľa fakamo Ľui  Ľakimoutolu.  
\v 15 Pea  Ľoua na Ľa tuku  Ľa Hesekaia ke ne fakaloto Ľi  Ľakimoutolu ke mou falala kia Sihova,  Ľo pehńď, ‚ÄėKo e mo Ľoni  Ľe fakamo Ľui  Ľakitautolu  Ľe Sihova:‚Äô  Ľe  Ľikai tukuange  Ľae kolo ni ki he nima  Ľoe tu Ľi  Ľo  ĽAsilia.  
\v 16 ‚ÄĆ ĽOua na Ľa fanongo kia Hesekaia: he  Ľoku pehńď  Ľe he tu Ľi  Ľo  ĽAsilia, Mou fakalelei mo au  Ľaki ha foaki, pea ha Ľu kitua ĽńĀ kiate au: pea kai taki taha  Ľi he Ľene vaine, pea taki taha  Ľi he Ľene  Ľakau ko e fiki, pea taki taha inu  Ľae vai  Ľo  Ľene puha vai.  
\v 17 Kae  Ľoua ke u ha Ľu  Ľo  Ľave  Ľakimoutolu ki ha fonua  Ľoku hangńď ko homou fonua, ko e fonua  Ľoe uite mo e uaine, ko e fonua  Ľoe mńĀ mo e ngoue vaine.  
\v 18 Vakai telia na Ľa fakaloto Ľi  Ľakimoutolu  Ľe Hesekaia,  Ľo pehńď, ‚Äė ĽE fakamo Ľui  Ľakitautolu  Ľe Sihova.‚Äô  ĽOku ai ha  Ľotua  Ľoe ngaahi pule Ľanga kuo ne fakamo Ľui hono fonua mei he nima  Ľoe tu Ľi  Ľo  ĽAsilia?  
\v 19 ‚ÄĆ ĽOku  Ľi fńď  Ľae ngaahi  Ľotua  Ľo Hamati mo  ĽAapati?  ĽOku  Ľi fńď  Ľae ngaahi  Ľotua  Ľo Sifaveimi? Pea kuo nau fakamo Ľui  Ľa Samńďlia mei hoku nima?  
\v 20 Ko hai  Ľi he ngaahi  Ľotua kotoa pńď  Ľoe ngaahi fonua ni, kuo fakamo Ľui honau fonua mei hoku nima, koe Ľuhi ke fakamo Ľui  Ľe Sihova  Ľa SelŇęsalema mei hoku nima?‚ÄĚ  
\v 21 Ka na Ľa nau fakalongo pe, pea  Ľikai ha lea si Ľi kiate ia: he na Ľe pehńď  Ľae fekau  Ľae tu Ľi, ‚Äú ĽOua na Ľa talia ia.‚ÄĚ  
\v 22 Pea na Ľe toki ha Ľu kia Hesekaia  Ľa Iliakimi, ko e foha  Ľo Hilikia,  Ľaia na Ľe pule  Ľi he fale, mo Sepina ko e tangata tohi, mo Soa, ko e foha  Ľo  ĽAsafi, ko e matńĀpule tohi, kuo mahae honau kofu, pea na Ľe tala kiate ia  Ľae ngaahi lea  Ľa Lapisake.   
\c 37  
\cd \it 1  ĽI he mamahi  Ľa Hesekaia  Ľoku ne fekau kia  ĽIsaia ke hŇęfia  Ľakinautolu. 6  ĽOku fakafiemńĀlie Ľi  Ľakinautolu  Ľe  ĽIsaia. 8  ĽI he  Ľalu  Ľa Senakalipe ke tau Ľi  Ľa Tilaka,  Ľoku ne  Ľatu  Ľae tohi kapekape kia Hesekaia. 14 Ko e lotu  Ľa Hesekaia. 21 Ko e kikite  Ľa  ĽIsaia ki he laukau mo e faka Ľauha  Ľa Senakalipe, pea mo e lelei  Ľo Saione. 36  ĽOku taa Ľi  Ľe he  ĽńĀngelo  Ľae kautau  Ľo  ĽAsilia. 37  ĽOku tńĀmate Ľi  Ľa Senakalipe  Ľe hono ongo foha  Ľi Ninive.\it*  
\p
\v 1 Pea na Ľe hoko  Ľo pehńď,  Ľi he fanongo  Ľa Hesekaia ki ai, na Ľa ne haehae hono kofu, pea kofu Ľaki ia  Ľae tauanga Ľa, pea  Ľalu ki he fale  Ľo Sihova.  
\v 2 Pea ne fekau  Ľa Iliakimi,  Ľaia na Ľe pule  Ľi he fale, mo Sepina ko e tangata tohi, pea mo e mńĀtu Ľa  Ľi he kau taula Ľeiki, kuo kofu Ľaki  Ľae tauanga Ľa, kia  ĽIsaia ko e palŇćfita, ko e foha  Ľo  ĽAmosi.  
\v 3 Pea nau pehńď kiate ia, ‚Äú ĽOku pehńď  Ľe Hesekaia, Ko e  Ľaho ni ko e  Ľaho  Ľoe mamahi, mo e valoki, pea mo e kapekape: he kuo hokosia  Ľae  Ľaho ke fńĀ Ľele, ka  Ľoku  Ľikai pńĀ mńĀlohi ke fanau Ľi.  
\v 4 Hei Ľilo  Ľe fanongo nai  Ľe Sihova ko ho  ĽOtua ki he ngaahi lea  Ľa Lapisake,  Ľaia kuo fekau  Ľe he tu Ľi  Ľo  ĽAsilia ko hono  Ľeiki ke valoki  Ľaki  Ľae  ĽOtua mo Ľui, pea  Ľe tautea  Ľae ngaahi lea  Ľaia kuo fanongo ki ai  Ľe Sihova ko ho  ĽOtua: ko e hiki hake ho Ľo hŇę koe Ľuhi ko e kakai  Ľoku kei toe.‚ÄĚ  
\v 5 Ko ia na Ľe ha Ľu  Ľae kau tamaio Ľeiki  Ľa Hesekaia kia  ĽIsaia.   
\p
\v 6 ¬∂ Pea na Ľe pehńď  Ľe  ĽIsaia kiate kinautolu, ‚ÄúTe mou lea  Ľo pehńď ki homou  Ľeiki,  ĽOku pehńď  Ľe Sihova,  ĽOua na Ľa ke manavahńď ki he ngaahi lea kuo ke fanongo ki ai,  Ľaia kuo kapekape  Ľaki kiate au  Ľe he kau tamaio Ľeiki  Ľoe tu Ľi  Ľa  ĽAsilia.  
\v 7 Vakai, te u fakahŇę kiate ia ha laumńĀlie, pea te ne fanongo ki he ongoongo, pea foki ki hono fonua  Ľo Ľona; pea te u pule ke tŇć ia  Ľi he heletńĀ  Ľi hono fonua  Ľo Ľona.‚ÄĚ   
\p
\v 8 ¬∂ Na Ľe foki  Ľa Lapisake, pea  Ľilo  Ľoku tau  Ľae tu Ľi  Ľo  ĽAsilia mo Lipina: he kuo ne fanongo kuo ha Ľu ia mei Lakisi.  
\v 9 Pea na Ľa ne fanongo ki he tala na Ľe kau kia Tilaka ko e tu Ľi  Ľo  ĽItiopea,  Ľo pehńď, ‚Äė ĽOku ha Ľu ia ke tau Ľi koe.‚Äô Pea  Ľi he Ľene fanongo ki ai, na Ľa ne fekau atu  Ľae kau talafekau kia Hesekaia,  Ľo pehńď,  
\v 10 ‚ÄúKe pehńď ho Ľomou lea kia Hesekaia ko e tu Ľi  Ľo Siuta,  Ľoua na Ľa tuku  Ľa ho  ĽOtua,  Ľaia  Ľoku ke fa Ľaki ki ai, ke kńĀkaa Ľi koe,  Ľo pehńď, ‚Äė ĽE  Ľikai tukuange  Ľa SelŇęsalema ki he nima  Ľoe tu Ľi  Ľo  ĽAsilia.‚Äô  
\v 11 Vakai, kuo ke fanongo ki he me Ľa kuo fai  Ľe he ngaahi tu Ľi  Ľo  ĽAsilia ki he ngaahi fonua kotoa pńď  Ľi he faka Ľauha  Ľaupito  Ľakinautolu; pea  Ľe fakamo Ľui koe?  
\v 12 Kuo fakamo Ľui  Ľe he ngaahi  Ľotua  Ľoe ngaahi pule Ľanga  Ľakinautolu na Ľe faka Ľauha  Ľe he Ľeku ngaahi tamai, ko Kosani, mo Holani, mo Lesefi, mo e fńĀnau  Ľa Iteni  Ľaia na Ľe  Ľi Tilasa?  
\v 13 ‚ÄĆ ĽOku  Ľi fńď  Ľae tu Ľi  Ľo Hamati, pea mo e tu Ľi  Ľo  ĽAapati, pea mo e tu Ľi  Ľoe kolo ko Sifaveimi, mo Hena, mo Iva?‚ÄĚ   
\p
\v 14 ¬∂ Pea na Ľe ma Ľu  Ľe Hesekaia  Ľae tohi mei he nima  Ľoe kau talafekau, pea lau ia: pea na Ľe  Ľalu hake  Ľa Hesekaia ki he fale  Ľo Sihova,  Ľo ne folahi ia  Ľi he  Ľao  Ľo Sihova.  
\v 15 Pea na Ľe hŇę  Ľa Hesekaia kia Sihova,  Ľo pehńď,  
\v 16 ‚Äú ĽE Sihova  Ľoe ngaahi kautau, ko e  ĽOtua  Ľo  ĽIsileli,  Ľaia  Ľoku  Ľafio  Ľi he vaha Ľa  Ľoe ongo Selupi, ko koe ko e  ĽOtua,  Ľio, ko koe tokotaha pe,  Ľi he ngaahi pule Ľanga  Ľo mńĀmani: ko koe na Ľe ngaohi  Ľae langi mo mńĀmani.  
\v 17 Fakaongo mai ho fofonga,  Ľe Sihova, pea fanongo; faka ĽńĀ,  Ľe Sihova, ho fofonga, pea ke  Ľafio Ľi: pea fanongo ki he lea kotoa pńď  Ľa Senakalipe,  Ľaia kuo fekau ke valoki  Ľaki  Ľae  ĽOtua mo Ľui.  
\v 18 Ko e mo Ľoni,  ĽE Sihova, ko e ngaahi tu Ľi  Ľo  ĽAsilia kuo nau faka Ľauha  Ľae ngaahi pule Ľanga kotoa pńď, mo honau ngaahi fonua,  
\v 19 Pea kuo lńę honau ngaahi  Ľotua ki he afi: he na Ľe  Ľikai ko ha  Ľotua  Ľakinautolu, ka ko e ngńĀue  Ľae nima  Ľoe tangata, ko e  Ľakau mo e maka: ko ia kuo nau faka Ľauha ai  Ľakinautolu.  
\v 20 Ko ia,  ĽE Sihova ko homau  ĽOtua, fakahaofi  Ľakimautolu mei hono nima, koe Ľuhi ke  Ľilo  Ľe he ngaahi pule Ľanga kotoa pńď  Ľo mńĀmani ko koe ko Sihova,  Ľio, ko koe tokotaha pe.‚ÄĚ   
\p
\v 21 ¬∂ Pea na Ľe toki fekau  Ľe  ĽIsaia ko e foha  Ľo  ĽAmosi kia Hesekaia,  Ľo pehńď, ‚Äú ĽOku pehńď  Ľe Sihova ko e  ĽOtua  Ľo  ĽIsileli, ko e me Ľa  Ľi ho Ľo hŇę kiate au koe Ľuhi ko Senakalipe ko e tu Ľi  Ľo  ĽAsilia:  
\v 22 Ko eni  Ľae lea  Ľaia kuo folofola Ľaki  Ľe Sihova  Ľoku kau kiate ia; ‚ÄėKo e ta Ľahine, ko e  Ľofefine  Ľo Saione, kuo fehi Ľa kiate koe, pea kata manuki kiate koe: ko e  Ľofefine  Ľo SelŇęsalema, kuo ne kalokalo hono  Ľulu kiate koe.  
\v 23 Ko hai ia kuo ke manuki Ľi mo kape Ľi? Pea kuo ke hiki hake ho le Ľo kia hai, pea hiki mo ho mata ki  Ľolunga?  ĽIo, ki he tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli.  
\v 24 Kuo ke manuki Ľi  Ľe ho Ľo kau tamaio Ľeiki  Ľa Sihova, pea kuo ke pehńď,  ĽI he tokolahi  Ľo  Ľeku ngaahi saliote kuo u ha Ľu ki he mńĀ Ľolunga  Ľoe mo Ľunga, ki he tafa Ľaki  Ľo Lepanoni, pea te u tu Ľusi ki lalo  Ľae ngaahi sita mńĀ Ľolunga  Ľo ia, pea mo e ngaahi  Ľakau ko e fea lelei  Ľo ia: pea te u hŇę ki he mńĀ Ľolunga  Ľo hono ngaahi ngata Ľanga, mo e vao  Ľakau  Ľo hono Kameli.  
\v 25 Kuo u keli, pea inu vai, pea kuo u fakamaha  Ľaki hoku  Ľaofi va Ľe  Ľae ngaahi vaitafe kotoa pńď  Ľoe ngaahi kolo kuo kńĀpui  Ľe he tau.  
\v 26 ‚ÄĆ ĽIkai kuo ke fanongo fuoloa, kuo u fai ia  Ľe au; pea  Ľi he ngaahi kuonga  Ľi mu Ľa, na Ľaku tu Ľutu Ľuni ki ai? ko eni, kuo u fakahoko ia, koe Ľuhi ke ke liliu  Ľae ngaahi kolo kuo teu tau, ko e ngaahi tu Ľunga fale kuo  Ľauha.  
\v 27 Ko ia na Ľe mńĀlohi si Ľi pe ho Ľonau kakai, na Ľa nau manavahńď pea puputu Ľu: na Ľa nau hangńď ko e mohuku  Ľoe ngoue, pea hangńď ko e  Ľakau mata,  Ľo hangńď ko e mohuku  Ľi he tu Ľa fale, pea hangńď ko e uite kuo mahunu  Ľi he te Ľeki ke tupu hake.  
\v 28 Ka  Ľoku ou  Ľilo ho nofo Ľanga, pea mo ho Ľo  Ľalu kitu Ľa, mo ho Ľo hŇę ki fale, mo ho Ľo  Ľita kiate au.  
\v 29 Ko e me Ľa  Ľi he  Ľalu hake ki hoku fofonga ho Ľo  Ľita kiate au, mo ho Ľo fielahi, ko ia te u  Ľai  Ľeku mńĀta Ľu ki ho ava Ľi ihu, mo  Ľeku me Ľa ta Ľofi  Ľi ho loungutu, pea te u fakafoki koe  Ľi he hala ko ia  Ľaia ne ke ha Ľu ai.  
\v 30 Pea ko e faka Ľilonga eni kiate koe, Te mou kai  Ľi he ta Ľu ni  Ľaia  Ľoku tupu  Ľiate ia pe; pea  Ľi hono ua  Ľoe ta Ľu  Ľaia  Ľoku tupu mei ai: pea  Ľi hono tolu  Ľoe ta Ľu te mou tŇętuu Ľi, pea tu Ľusi mai, pea tŇć  Ľae ngaahi ngoue vaine, pea kai  Ľae ngaahi fua  Ľo ia.  
\v 31 Pea ko e toe  Ľoe fale  Ľo Siuta, kuo hao  Ľe toe aka ki lalo, pea fua  Ľi  Ľolunga:  
\v 32 Koe Ľuhi  Ľe  Ľalu  Ľi SelŇęsalema ha toenga kakai, pea ko kinautolu kuo hao  Ľi he mo Ľunga ko Saione: ko e  Ľofa  Ľa Sihova  Ľoe ngaahi kautau te ne fai  Ľae me Ľa ni.  
\v 33 Ko ia  Ľoku pehńď  Ľae folofola  Ľa Sihova  Ľaia  Ľoku kau ki he tu Ľi  Ľo  ĽAsilia, ‚Äė ĽE  Ľikai te ne ha Ľu ki he kolo ni, pe fana Ľi ha ngahau ki ai, pe ha Ľu ki ai  Ľaki  Ľae ngaahi fakaŇę pe fokotu Ľu ha tetanu ki ai.  
\v 34 ‚ÄĆ ĽOku pehńď  Ľe Sihova,  ĽI he hala na Ľa ne ha Ľu ai,  Ľi he hala ko ia te ne foki atu ai, pea  Ľe  Ľikai te ne ha Ľu ki he kolo ni.  
\v 35 He te u malu Ľi  Ľae kolo ni  Ľo fakamo Ľui ia koe Ľuhi ko au, pea koe Ľuhi ko  Ľeku tamaio Ľeiki ko Tevita.‚Äô‚ÄĚ   
\p
\v 36 ¬∂ Pea na Ľe toki  Ľalu atu  Ľae  ĽńĀngelo  Ľo Sihova,  Ľo ne taa Ľi  Ľi he nofo Ľanga tau  Ľoe kau  ĽAsilia  Ľae tokotaha kilu mńĀ toko valu mano ma toko nima afe: pea  Ľi he tu Ľu hengihengi hake  Ľae kakai, vakai, kuo nau mate, ko e  Ľanga Ľanga kotoa pńď.   
\p
\v 37 ¬∂ Ko ia na Ľe  Ľalu ai  Ľa Senakalipe ko e tu Ľi  Ľo  ĽAsilia,  Ľo ne  Ľalu,  Ľo foki atu, pea nofo  Ľi Ninive.  
\v 38 Pea na Ľe hoko  Ľo pehńď, lolotonga  Ľene lotu  Ľi he fale  Ľo Nisiloki ko hono  Ľotua, na Ľe taa Ľi ia  Ľe hono ongo foha ko  ĽAtilameleki mo Salisa  Ľaki  Ľae heletńĀ pea ne na hao ki he fonua ko  ĽAminia pea na Ľe pule hono foha ko  ĽAsahatoni ko hono fetongi.   
\c 38  
\cd \it 1  ĽI he ma Ľu  Ľe Hesekaia  Ľae tala ke ne mate,  Ľoku fakatolotolonga  Ľene mo Ľui  Ľi he Ľene lotu. 8  ĽOku foki ki mui  Ľae la ĽńĀ ko e fakamo Ľoni  Ľoe tala Ľofa ko ia. 9 Ko  Ľene hiva fakafeta Ľi.\it*  
\p
\v 1 ‚ÄĆ ĽI he ngaahi  Ľaho ko ia na Ľe mahaki  Ľa Hesekaia  Ľo meimei mate. Pea na Ľe ha Ľu  Ľa  ĽIsaia ko e palŇćfita ko e foha  Ľo  ĽAmosi, pea ne pehńď kiate ia, ‚Äú ĽOku pehńď  Ľe Sihova, Teuteu ho fale: he te ke mate, pea  Ľikai mo Ľui.‚ÄĚ  
\v 2 Pea na Ľe toki tafoki  Ľa Hesekaia  Ľo hanga hono mata ki he holisi  Ľoe fale, pea lotu kia Sihova,  
\v 3 Pea ne pehńď, ‚Äú ĽE Sihova,  ĽOku ou kole kiate koe, ke ke manatu ki he anga  Ľo  Ľeku  Ľeve Ľeva  Ľi ho  Ľao  Ľi he mo Ľoni pea mo e loto haohaoa, pea kuo u fai  Ľaia  Ľoku lelei  Ľi ho  Ľao.‚ÄĚ Pea na Ľe tangi mamahi  Ľa Hesekaia.   
\p
\v 4 ¬∂ Pea toki hoko  Ľae folofola  Ľa Sihova kia  ĽIsaia,  Ľo pehńď,  
\v 5 ‚Äú ĽAlu,  Ľo tala kia Hesekaia,  ĽOku pehńď  Ľe Sihova, ko e  ĽOtua  Ľo Tevita ko ho Ľo tamai, kuo u fanongo ki ho Ľo hŇę, kuo u mamata ki ho Ľo lo Ľimata: vakai, te u fakalahi  Ľaki ho Ľo ngaahi  Ľaho  Ľae ta Ľu  Ľe hongofulu ma nima.  
\v 6 Pea te u fakamo Ľui koe mo e kolo ni mei he nima  Ľoe tu Ľi  Ľo  ĽAsilia: pea te u malu Ľi  Ľae kolo ni.  
\v 7 Pea ko e faka Ľilonga eni kiate koe meia Sihova, ki he Ľene fai  Ľe Sihova  Ľae me Ľa ni  Ľaia kuo ne folofola ki ai;  
\v 8 Vakai, te u toe  Ľomi ki mui  Ľae  Ľata  Ľoe ngaahi tikeli,  Ľaia kuo  Ľalu hifo  Ľi he me Ľa faka Ľilonga la ĽńĀ  Ľo  ĽAhasi, ko e vahe  Ľe hongofulu. Pea na Ľe foki ki mui  Ľae la ĽńĀ  Ľi he tikeli  Ľe hongofulu,  Ľae ngaahi vahe ko ia  Ľaia kuo  Ľalu hifo ai ia.‚ÄĚ   
\p
\v 9 ¬∂ Ko e tohi \add eni \add*e Hesekaia ko e tu Ľi  Ľo Siuta,  Ľi he hili  Ľa hono mahaki, pea kuo mo Ľui ia mei hono mahaki;  
\v 10 Na Ľaku pehńď  Ľi he tu Ľusi  Ľa hoku ngaahi  Ľaho, ‚ÄúTe u  Ľalu hifo ki he matapńĀ  Ľoe fonualoto:  
\q2 kuo fa Ľao  Ľiate au hono toe  Ľo hoku ngaahi ta Ľu.‚ÄĚ   
\q1
\v 11 Na Ľaku pehńď, ‚Äú ĽE  Ľikai te u mamata kia Sihova,  
\q2  Ľio, ko Sihova,  Ľi he fonua  Ľoe mo Ľui:  
\q2  Ľe  Ľikai te u toe mamata ki he tangata fakataha mo e kakai  Ľo mńĀmani.   
\q1
\v 12 Kuo  Ľalu hoku ngaahi ta Ľu,  
\q2 pea kuo  Ľave ia  Ľiate au  Ľo hangńď ko e fale fehikitaki  Ľoe tauhi sipi:  
\q1 na Ľaku tu Ľusi  Ľeku mo Ľui  Ľo hangńď ko e tangata lalanga tupenu:  
\q2 te ne tu Ľusi ke motu au  Ľi he faka Ľau Ľausino:  
\q2 mei he  Ľaho  Ľo a Ľu ki he pŇć  Ľoku ke faka Ľosi au.   
\q1
\v 13 Na Ľaku lau ki he pongipongi,  
\q2 koe Ľuhi  Ľo hangńď ko e laione te ne fesi Ľi pehńď hoku ngaahi hui kotoa pńď:  
\q2 mei he  Ľaho  Ľo a Ľu ki he pŇć  Ľoku ke fai ke faka Ľosi au.   
\q1
\v 14 ‚ÄĆ ĽO hangńď ko e kaleni pe ko e sualo, na Ľe pehńď  Ľeku lea:  
\q2 ne u tangi  Ľo hangńď ko e lupe:  
\q2 kuo vaivai hoku mata  Ľi he sio ki  Ľolunga:  
\q2  ĽE Sihova, kuo u ta Ľomia;  
\q2 ke ke langomaki Ľi au.‚ÄĚ   
\q1
\v 15 Ko e hńĀ te u lea aki?  
\q2 Kuo tala Ľofa ia kiate au, pea kuo ne fai ki ai:  
\q2 te u  Ľalu  Ľi he angavaivai  Ľi hoku ngaahi ta Ľu kotoa pńď koe Ľuhi ko e mamahi  Ľa hoku laumńĀlie.   
\q1
\v 16 ‚ÄĆ ĽE Sihova,  Ľi he ngaahi me Ľa ni  Ľoku mo Ľui ai  Ľae tangata,  
\q2 pea  Ľi he ngaahi me Ľa ni kotoa pńď  Ľoku ai  Ľae mo Ľui  Ľa hoku laumńĀlie:  
\q2 kuo pehńď ho Ľo fakamo Ľui au, pea ngaohi au ke u mo Ľui.   
\q1
\v 17 Vakai, ne u ma Ľu  Ľae mamahi lahi ko e fetongi  Ľoe fiemńĀlie:  
\q2 ka  Ľi ho Ľo  Ľofa ki hoku laumńĀlie kuo ke fakamo Ľui ia mei he luo  Ľoe faka Ľauha:  
\q2 he kuo ke lńę  Ľeku ngaahi hia kotoa pńď ki ho tu Ľa.   
\q1
\v 18 He  Ľoku  Ľikai fa Ľa fakamńĀlŇć kiate koe  Ľae fa Ľitoka,  
\q2  Ľoku  Ľikai fa Ľa fakaongoongolelei Ľi koe  Ľe he mate:  
\q1 ko kinautolu  Ľoku  Ľalu hifo ki he luo  Ľoku  Ľikai te nau fa Ľa  Ľamanaki ki he mo Ľoni.   
\q1
\v 19 Ko e kakai mo Ľui, ko e kakai mo Ľui, ko ia  Ľe fakamńĀlŇć kiate koe,  
\q2  Ľo hangńď ko ia  Ľoku ou fai  Ľi he  Ľaho ni:  Ľe fakahńĀ ho Ľo mo Ľoni  Ľe he tamai ki he fńĀnau.   
\q1
\v 20 Na Ľe tatali  Ľe Sihova ke fakamo Ľui au:  
\q2 ko ia te mau hiva  Ľaki  Ľeku ngaahi hiva  Ľi he me Ľa faiva  Ľi he  Ľaho kotoa pńď  Ľo  Ľemau mo Ľui  Ľi he fale  Ľo Sihova.   
\p
\v 21 He na Ľe pehńď  Ľe  ĽIsaia, ‚ÄúTuku ke nau to Ľo  Ľae ngaahi fiki, pea  Ľai ia ko e pulusi ki he hala, pea te ne mo Ľui.‚ÄĚ   
\q1
\v 22 Pea ne pehńď foki  Ľe Hesekaia, ‚ÄúKo e hńĀ  Ľae faka Ľilonga te u  Ľalu hake ai ki he fale  Ľo Sihova?‚ÄĚ   
\c 39  
\cd \it 1 Ko e fekau  Ľo Melotaki-Palatani, ke  Ľa Ľahi kia Hesekaia koe Ľuhi ko e me Ľa mana, pea  Ľoku fakahńĀ kiate ia  Ľa  Ľene koloa. 3  ĽI he  Ľilo ia  Ľe  ĽIsaia,  Ľoku ne fakahńĀ  Ľae fakapŇćpula  Ľi Papilone.\it*  
\p
\v 1 ‚ÄĆ ĽI he kuonga ko ia na Ľe  Ľave  Ľe Melotaki-Palatani ko e foha  Ľo Palatani, ko e tu Ľi  Ľo Papilone,  Ľae ngaahi tohi mo e me Ľa foaki kia Hesekaia: he kuo ne fanongo na Ľe mahaki ia, pea kuo mo Ľui.  
\v 2 Pea na Ľe fiefia ai  Ľa Hesekaia, pea na Ľa ne fakahńĀ  Ľae fale  Ľo  Ľene ngaahi me Ľa mahu Ľinga,  Ľae siliva, mo e koula, mo e ngaahi me Ľa namu kakala, mo e lolo mahu Ľinga, mo e fale kotoa  Ľo  Ľene mahafutau, pea mo ia kotoa pńď na Ľe  Ľilo  Ľi hono ngaahi tukunga koloa: na Ľe  Ľikai ha me Ľa  Ľi hono fale, pe  Ľi hono pule Ľanga kotoa pńď, na Ľe ta ĽefakahńĀ  Ľe Hesekaia kiate kinautolu.   
\p
\v 3 ¬∂ Pea na Ľe toki ha Ľu  Ľa  ĽIsaia ko e palŇćfita ki he tu Ľi ko Hesekaia, pea pehńď kiate ia, ‚ÄúKo e hńĀ  Ľae lea  Ľae kau tangata ni? Pea na Ľa nau ha Ľu mei fńď kiate koe?‚ÄĚ Pea pehńď  Ľe Hesekaia, ‚ÄúKuo nau ha Ľu mei he fonua mama Ľo kiate au,  Ľio, mei Papilone.  
\v 4 Pea pehńď  Ľe ia, Ko e hńĀ kuo nau mamata ai  Ľi ho fale? Pea pehńďange  Ľe Hesekaia, ‚ÄúKo ia kotoa pńď  Ľi hoku fale kuo nau mamata ki ai:  Ľoku  Ľikai ha me Ľa  Ľi he Ľeku koloa kuo u ta ĽefakahńĀ kiate kinautolu.‚ÄĚ  
\v 5 Pea na Ľe toki pehńď  Ľe  ĽIsaia kia Hesekaia, ‚ÄúFanongo ki he folofola  Ľa Sihova  Ľoe ngaahi kautau:  
\v 6 Vakai,  Ľoku pehńď  Ľe Sihova,  ĽE ha Ľu  Ľae ngaahi  Ľaho,  Ľe fetuku ki Papilone  Ľae me Ľa kotoa pńď  Ľoku  Ľi ho fale, pea mo ia kuo tńĀnaki  Ľe ho Ľo ngaahi tamai  Ľo a Ľu ki he  Ľaho ni:  Ľe  Ľikai ha me Ľa  Ľe toe.  
\v 7 Pea ko ho ngaahi foha  Ľe tupu  Ľiate koe,  Ľaia te ke fakatupu, te nau  Ľave; pea te nau hoko ko e kau talifekau  Ľi he fale faka Ľei Ľeiki  Ľoe tu Ľi  Ľo Papilone.‚ÄĚ  
\v 8 Pea na Ľe toki pehńď  Ľe Hesekaia kia  ĽIsaia, ‚Äú ĽOku lelei  Ľae folofola  Ľa Sihova  Ľaia kuo ke lea  Ľaki.‚ÄĚ Pea na Ľa ne toe pehńď, ‚ÄúKoe Ľuhi  Ľe  Ľi hoku ngaahi  Ľaho  Ľo Ľoku  Ľae melino mo e mo Ľoni.‚ÄĚ   
\c 40  
\cd \it 1 Ko e fakahńĀ  Ľae ongolelei. 5 Ko e malanga  Ľa Sione Papitaiso. 9 Ko e malanga  Ľae kau  Ľaposetolo 12 Ko e palŇćfita  Ľi he mńĀfimafi  Ľae  ĽOtua, 18 Pea mo  Ľene lelei lahi taha, 26  ĽOku ne fakafiemńĀlie Ľi  Ľae kakai.\it*  
\p
\v 1 ‚ÄĆ ĽOku pehńď  Ľe homou  ĽOtua, ‚ÄúMou fakafiemńĀlie Ľi, mou fakafiemńĀlie Ľi  Ľa hoku kakai.  
\v 2 ‚ÄúLea fakafiemńĀlie ki SelŇęsalema, pea kalanga kiate ia, kuo ngata  Ľene tau, kuo fakamolemole  Ľene hia: he kuo fai  Ľae totongi ke liunga ua kiate ia mei he nima  Ľo Sihova  Ľi he Ľene hia kotoa pńď.‚ÄĚ   
\p
\v 3 ¬∂ Ko e le Ľo  Ľo ia  Ľoku kalanga  Ľi he toafa,  
\q2 ‚ÄúTeuteu  Ľae hala  Ľo Sihova, fakatonutonu  Ľae hala lahi  Ľi he toafa ma Ľa hotau  ĽOtua.‚ÄĚ   
\q1
\v 4 ‚ÄĆ ĽE hakeaki Ľi  Ľae ngaahi luo kotoa pńď,  
\q2 pea  Ľe holoki  Ľae ngaahi mo Ľunga me Ľe tafungofunga kotoa pńď:  
\q2 pea  Ľe fakatonutonu  Ľae pikopiko,  
\q2 pea  Ľe fakatokalelei  Ľae ngaahi potu  Ľoku tokakovi:   
\q1
\v 5 Pea  Ľe fakahńĀ  Ľae nńĀunau  Ľo Sihova,  
\q2 pea  Ľe mamata ki ai  Ľae kakai kotoa pńď:  
\q2 he kuo folofola pehńď  Ľae fofonga  Ľo Sihova.‚ÄĚ  
\v 6 Na Ľe pehńď  Ľe he le Ľo, ‚ÄúKalanga.‚ÄĚ  
\q2 Pea na Ľa ne pehńď, ‚ÄúKo e hńĀ te u kalanga  Ľaki?‚ÄĚ  
\q1 ‚ÄúKo e mohuku  Ľae kakano kotoa pńď,  
\q2 pea ko e nńĀunau kotoa pńď  Ľo ia  Ľoku tatau mo e fisi  Ľoe ngoue.   
\q1
\v 7 ‚ÄĆ ĽOku faka Ľa Ľau ke mŇćmoa  Ľae mohuku,  
\q2  Ľoku mae  Ľae fisi Ľi Ľakau:  
\q2 koe Ľuhi  Ľoku angi ki ai  Ľae matangi  Ľa Sihova:  
\q2 tńĀ ko e mo Ľoni ko e mohuku  Ľae kakai.   
\q1
\v 8 ‚ÄĆ ĽOku faka Ľa Ľau ke mŇćmoa  Ľae mohuku,  
\q2  Ľoku mae  Ľae fisi Ľi Ľakau:  
\q2 ka e tolonga  Ľo ta Ľengata  Ľae folofola  Ľa hotau  ĽOtua.‚ÄĚ   
\b  
\p
\v 9 ¬∂  ĽA koe,  Ľoku  Ľomi  Ľae ongoongolelei ki Saione,  Ľalu hake koe ki he mo Ľunga mńĀ Ľolunga;  
\q2  Ľa koe,  Ľoku  Ľomi  Ľae ongoongolelei ki SelŇęsalema,  
\q2 hiki hake ho le Ľo  Ľi he mńĀlohi;  
\q2 hiki hake ia  Ľoua  Ľe manavahńď;  
\q2 ke ke pehńď ki he ngaahi kolo  Ľo Siuta, ‚ÄúVakai ki homou  ĽOtua!‚ÄĚ   
\q1
\v 10 Vakai,  Ľe hńĀ Ľele mai  Ľae  ĽEiki ko Sihova  Ľi he mńĀlohi,  
\q2 pea  Ľe pule hono nima mo Ľona:  
\q2 vakai,  Ľoku  Ľiate ia hono totongi,  
\q2 pea  Ľoku  Ľi hono  Ľao  Ľa  Ľene ngńĀue.   
\q1
\v 11 Te ne fafanga  Ľene fanga sipi  Ľo hangńď ko e tauhi:  
\q2 te ne tńĀnaki  Ľae fanga lami  Ľaki hono nima,  
\q2 pea fua  Ľakinautolu  Ľi hono fatafata,  
\q2 pea tataki fakafiemńĀlie  Ľakinautolu  Ľoku feitama.   
\b  
\q1
\v 12 Ko hai kuo ne fua  Ľae ngaahi vai  Ľi hono  Ľaofi nima,  
\q2 pea fuofua  Ľae langi  Ľaki  Ľae hanga,  
\q2 pea fakakńĀtoa  Ľae efuefu  Ľoe fonua  Ľi he me Ľa fuofua,  
\q2 pea kuo fakamamafa  Ľae ngaahi mo Ľunga  Ľi he me Ľa fakamamafa,  
\q2 pea mo e ngaahi tafungofunga  Ľi he me Ľa fakatatau?   
\q1
\v 13 Ko hai kuo ne fakahinohino  Ľae LaumńĀlie  Ľo Sihova,  
\q2 pea hoko ko  Ľene akonaki ke fakahinohino ia?   
\q1
\v 14 Ko hai na Ľa na fakakaukau mo ia,  
\q2 koe Ľuhi ke ne fakapoto Ľi ia,  
\q2 pe ako kiate ia  Ľi he hala  Ľoe fakamaau,  
\q2 pe ko hai na Ľa ne akonaki Ľi ia  Ľi he  Ľilo,  
\q2 pea fakahńĀ kiate ia  Ľae hala  Ľoe  Ľilo Ľilo?   
\q1
\v 15 Vakai,  Ľoku tatau  Ľae ngaahi pule Ľanga mo e tulutńĀ  Ľoe ipu vai,  
\q2 pea  Ľoku lau ia  Ľo hangńď ko e efuefu iiki  Ľoe me Ľa fakatatau:  
\q2 vakai,  Ľoku ne to Ľo hake  Ľae ngaahi motu  Ľo hangńď ko e me Ľa si Ľi  Ľaupito.   
\q1
\v 16 Pea  Ľoku si Ľi  Ľa Lepanoni ke tutu,  
\q2 pea  Ľoku si Ľi  Ľae fanga manu  Ľi ai ki ha feilaulau tutu.   
\q1
\v 17 ‚ÄĆ ĽOku hangńď ko e me Ľa noa pe  Ľae ngaahi pule Ľanga kotoa pńď  Ľi hono  Ľao;  
\q2 pea  Ľoku lau ia kiate ia ko e si Ľi hifo  Ľi he me Ľa noa pe, mo e va Ľinga.   
\q1
\v 18 Pea te mou fakatatau kia hai  Ľae  ĽOtua?  
\q2 Pe ko e hńĀ ha fakatńĀtńĀ te mou fakatatau kiate ia?   
\q1
\v 19 ‚ÄĆ ĽOku haka  Ľe he tangata tufunga ha tamapua,  
\q2 pea ko e tufunga koula  Ľoku  Ľufi Ľufi ia  Ľaki  Ľae koula,  
\q2 pea  Ľoku ne ngaohi  Ľae kahoa fihifihi  Ľaki  Ľae siliva   
\q1
\v 20 Ko ia  Ľoku lahi  Ľene masiva pea  Ľoku  Ľikai ha Ľane feilaulau,  Ľoku ne fili ha  Ľakau  Ľe  Ľikai popo;  
\q2  Ľoku ne kumi kiate ia ha tufunga poto ke fokotu Ľu ha tamapua kuo tńĀ  Ľaia  Ľe  Ľikai ue Ľi.   
\b  
\q1
\v 21 Kuo ta Ľe Ľilo  Ľekimoutolu?  
\q2 Na Ľe  Ľikai te mou fanongo?  
\q2  ĽIkai kuo fakahńĀ kiate kimoutolu mei he kamata Ľanga?  
\q2  ĽIkai kuo mou  Ľilo talu mei he  Ľai  Ľae tu Ľunga  Ľo mńĀmani?   
\q1
\v 22 Ko ia ia  Ľoku  Ľafio  Ľi he takatakai  Ľo mńĀmani,  
\q2 pea ko e kakai  Ľoku nofo ai  Ľoku tatau kiate ia mo e fanga he Ľe;  
\q2 ko ia ia  Ľoku ne fofola  Ľae ngaahi langi  Ľo hangńď ko e puipui,  
\q2 pea folahi ia  Ľo hangńď ko e fale fehikitaki ke nofo ai:   
\q2
\v 23 Ko ia  Ľoku ne fakahifo ki lalo  Ľae hou Ľeiki ke  Ľikai;  
\q2  Ľoku ne ngaohi  Ľae kau fakamaau  Ľoe fonua ko e va Ľinga.   
\q1
\v 24 ‚ÄĆ ĽIo,  Ľe  Ľikai tŇć  Ľakinautolu;  
\q2  Ľio,  Ľe  Ľikai tŇętuu Ľi  Ľakinautolu:  
\q2  Ľio,  Ľe  Ľikai aka  Ľi he kelekele honau tefito:  
\q2 pea te ne ifi kiate kinautolu, pea te nau mae,  
\q2 pea  Ľe  Ľave  Ľakinautolu  Ľe he  Ľahiohio  Ľo hangńď ko e veve.   
\b  
\q1
\v 25 ‚Äú ĽOku pehńď  Ľe he tokotaha mńĀ Ľoni Ľoni,  
\q2 Pea te mou fakatatau au kia hai, pe te u tatau mo hai?   
\q1
\v 26 Hiki hake homou mata ki  Ľolunga,  
\q2 pea vakai pe ko hai kuo ne fakatupu  Ľae ngaahi me Ľa ni,  
\q2  Ľaia  Ľoku ne lau mo taki kitu Ľa honau tokolahi;  
\q2  Ľoku ne ui  Ľakinautolu kotoa pńď  Ľi honau hingoa  Ľi he lahi  Ľo hono mńĀfimafi,  
\q2 koe Ľuhi  Ľoku mńĀlohi ia  Ľi he mńĀfimafi,  
\q2  Ľoku  Ľikai ha taha  Ľoku ta ĽehńĀmai.   
\q1
\v 27 Ko e hńĀ  Ľoku ke pehńď,  Ľe Sńďkope,  
\q2 pea ke pehńď,  ĽE  ĽIsileli,  
\q2 ‚ÄúKuo fufŇę hoku hala meia Sihova,  
\q2 pea kuo ta Ľetokanga  Ľa hoku  ĽOtua ki hoku fakamaau?‚ÄĚ   
\p
\v 28 ¬∂ ‚Äú ĽIkai na Ľa ke  Ľilo?  
\q2  ĽIkai na Ľa ke fanongo,  
\q2 ko Sihova ko e  ĽOtua ta Ľengata ia,  
\q2 ko e Tupu Ľanga  Ľoe ngaahi ngata Ľanga  Ľo mńĀmani,  Ľoku  Ľikai pongia ia,  
\q2 pea  Ľoku  Ľikai vaivai?  
\q2  ĽOku ta Ľefa Ľa Ľilo Ľi  Ľa  Ľene  Ľilo.   
\q1
\v 29 ‚ÄĆ ĽOku ne foaki  Ľae mńĀlohi ki he vaivai;  
\q2 pea kiate kinautolu  Ľoku  Ľikai ha Ľanau mńĀlohi  Ľoku ne fakatupu  Ľae mńĀlohi.   
\q1
\v 30 ‚ÄĆ ĽIo  Ľe pongia  Ľae fńĀnau tupu pea vaivai,  
\q2 pea  Ľe hinga  Ľaupito mo e kau talavou:   
\q2
\v 31 Ka ko kinautolu  Ľoku tatali kia Sihova  Ľe fakafo Ľou honau mńĀlohi;  
\q2 te nau puna hake  Ľaki  Ľae kapakau  Ľo hangńď ko e fanga  Ľikale;  
\q2 te nau lele ka e  Ľikai vaivai;  
\q2 pea te nau  Ľeve Ľeva, kńĀ  Ľe  Ľikai pongia.‚ÄĚ   
\c 41  
\cd \it 1  ĽOku ako  Ľe he  ĽOtua ki hono kakai,  Ľi he Ľene  Ľalo Ľofa ki hono siasi, 10 Mo  Ľene ngaahi tala Ľofa, 21 Pea ki he va Ľinga  Ľoe ngaahi tamapua.\it*  
\q1
\v 1 ‚Äú ĽAe ngaahi motu, mou fakalongo pńď  Ľi hoku  Ľao;  
\q2 pea tuku ke fakafo Ľou  Ľe he kakai honau mńĀlohi:  
\q1 tuku ke nau ha Ľu ke ofi;  
\q2 pea toki tuku ke nau lea:  
\q2 ke tau  Ľunu Ľunu ke ofi ki he fakamaau.   
\q1
\v 2 Ko hai na Ľa ne fokotu Ľu  Ľae tangata mńĀ Ľoni Ľoni mei he potu hahake,  
\q2  Ľo ui ia ki hono va Ľe,  
\q2 pea foaki  Ľae ngaahi pule Ľanga  Ľi hono  Ľao,  
\q2 pe ngaohi ia ke pule ki he ngaahi tu Ľi?  
\q2 Na Ľa ne foaki  Ľakinautolu  Ľo hangńď ko e efu ki he Ľene heletńĀ,  
\q2 pea hangńď ko e veve kuo vilingia ki he Ľene kaufana.   
\q1
\v 3 Na Ľa ne tulia  Ľakinautolu,  
\q2 pea  Ľalu fiemńĀlie pe;  
\q2  Ľio,  Ľi he hala na Ľe  Ľikai fou ai hono va Ľe.   
\q1
\v 4 Ko hai kuo ngńĀue mo fai ia,  
\q2  Ľo ne ui  Ľae to Ľutangata mei he kamata Ľanga?  
\q2 Ko au ko Sihova, ko e  Ľuluaki pea mo e kimui; ko au ia.   
\b  
\q1
\v 5 Na Ľe mamata  Ľe he ngaahi motu, pea manavahńď;  
\q2 na Ľe manavahńď  Ľae ngaahi ngata Ľanga  Ľo mńĀmani,  
\q2  Ľonau  Ľunu Ľunu mai, pea ha Ľu.   
\q1
\v 6 Na Ľe tokoni taki taha ki hono kaungńĀ Ľapi;  
\q2 pea pehńď taki taha ki hono tokoua, ‚ÄúKe ke lototo Ľa.‚ÄĚ   
\q1
\v 7 Ko ia na Ľe tokoni  Ľae tufunga  Ľakau ki he tufunga koula,  
\q2 pea mo ia  Ľoku fakamolemole  Ľaki  Ľae hamala  Ľaia na Ľa ne taa Ľi ki he fakalalango,  
\q2  Ľo pehńď, ‚ÄúKuo  Ľosi‚ÄĚ hono teu ki he fakahoko:  
\q2 pea ne fakama Ľu ia  Ľaki  Ľae ngaahi fa Ľo, ke  Ľoua na Ľa ngaue ia.   
\q1
\v 8 Ka ko koe,  ĽE  ĽIsileli, ko  Ľeku tamaio Ľeiki,  
\q2  ĽE Sńďkope  Ľa koe kuo u fili,  
\q2 ko e hako  Ľo  ĽEpalahame ko hoku kńĀinga.   
\q2
\v 9 ‚ÄĆ ĽA koe kuo u to Ľo mei he ngata Ľanga  Ľo mńĀmani,  
\q2 pea ui mei he kau tangata tu Ľu ki mu Ľa  Ľi ai,  
\q2 pea kuo u pehńď kiate koe, ‚ÄėKo koe ko  Ľeku tamaio Ľeiki;‚Äô kuo u fili koe, ka na Ľe  Ľikai li Ľaki koe.   
\q1
\v 10 ‚ÄĆ ĽOua na Ľa ke manavahńď; he  Ľoku ou  Ľiate koe:  
\q2  Ľoua  Ľe loto vaivai; he ko au ko ho  ĽOtua,  
\q2 te u fakamńĀlohi koe;  
\q2  Ľio, te u tokoni koe;  
\q2  Ľio, te u poupou hake koe  Ľaki  Ľae nima to Ľomata Ľu  Ľo  Ľeku angatonu.   
\q1
\v 11 Vakai, ko kinautolu kotoa pńď na Ľe  Ľita kiate koe te nau mńĀ pea puputu Ľu:  
\q2 te nau hangńď ko e me Ľa noa pe; pea  Ľe  Ľauha mo kinautolu  Ľoku fai kovi kiate koe.   
\q1
\v 12 Te ke kumi  Ľakinautolu, ka e  Ľikai  Ľilo Ľi  Ľakinautolu,  
\q2  Ľio,  Ľakinautolu na Ľe fai mo koe:  
\q2 ko kinautolu  Ľoku tau Ľi koe te nau hangńď ko e me Ľa noa pe,  
\q2 pea hangńď ha me Ľa  Ľoku  Ľikai.   
\q1
\v 13 He ko au ko Sihova ko ho  ĽOtua te u puke ho nima to Ľomata Ľu,  
\q2  Ľo pehńď kiate koe, ‚Äė ĽOua  Ľe manavahńď;  
\q2 te u tokoni koe.‚Äô   
\q1
\v 14 ‚ÄĆ ĽOua na Ľa manavahńď  Ľa koe, ko e kelemutu ko Sńďkope,  
\q2 pea mo kimoutolu  Ľae kau tangata  Ľo  ĽIsileli;  
\q2  ĽOku pehńď  Ľe Sihova, ko ho huhu Ľi,  
\q2 ko e tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli, te u tokoni kiate koe.   
\q1
\v 15 Vakai, te u ngaohi kiate koe ha me Ľa haha fo Ľou  Ľoku mńĀsila pea nifo:  
\q2 te ke haha  Ľae ngaahi mo Ľunga,  
\q2 pea taa Ľi ke iiki,  
\q2 pea ngaohi  Ľae ngaahi tafungofunga  Ľo hangńď ko e veve vilingia.   
\q1
\v 16 Te ke tui Ľi  Ľakinautolu,  
\q2 pea ko e matangi te ne puneekina  Ľakinautolu,  
\q2 pea ko e  Ľahiohio te ne vetekina  Ľakinautolu:  
\q1 pea te ke fiefia ko e  Ľia Sihova,  
\q2 pea vikiviki  Ľi he tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli.   
\q1
\v 17 ‚ÄĆ ĽOka kumi  Ľe he masiva mo e paea  Ľae vai, pea  Ľoku  Ľikai ia,  
\q2 pea  Ľoku vaivai honau  Ľelelo  Ľi he fieinu,  
\q1 Ko au ko Sihova te u fanongo kiate kinautolu,  
\q2 Ko au ko e  ĽOtua  Ľo  ĽIsileli  Ľe  Ľikai te u li Ľaki  Ľakinautolu.   
\q1
\v 18 Te u fakaava  Ľae ngaahi vaitafe  Ľi he ngaahi potu mńĀ Ľolunga,  
\q2 pea mo e ngaahi matavai  Ľi he ngaahi tele Ľa:  
\q2 te u ngaohi  Ľae toafa ko e anovai,  
\q2 pea mo e fonua mŇćmoa ko e ngaahi matavai.   
\q1
\v 19 Te u tŇć  Ľi he toafa  Ľae sita,  Ľae  Ľakau ko e sita, pea mo e maile, pea mo e  Ľakau lolo;  
\q2 te u tŇć fakataha  Ľi he toafa lala  Ľae  Ľakau ko e fea, pea mo e paini, pea mo e  Ľakau ko e pokasi:   
\q1
\v 20 Koe Ľuhi ke nau mamata, pea ongo Ľi, pea tokanga, pea  Ľilo fakataha,  
\q2 ko e nima  Ľo Sihova kuo ne fai  Ľae me Ľa ni,  
\q2 pea kuo fakatupu ia  Ľe he tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli.   
\q1
\v 21 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚ÄúFakahńĀ ho Ľomou me Ľa;‚ÄĚ  
\q2  Ľoku pehńď  Ľe he Tu Ľi  Ľo Sńďkope, ‚Äú ĽOmi ho Ľomou lea mamafa.‚ÄĚ   
\q1
\v 22 ‚ÄúTuku ke nau  Ľomi ia, pea fakahńĀ kiate kimautolu pe ko e hńĀ  Ľe hoko:  
\q2 tuku ke nau fakahńĀ  Ľae ngaahi me Ľa mu Ľa, pe ko e hńĀ ia,  
\q2 ke mau fifili ki ai, pea  Ľilo mo hono fakamo Ľoni  Ľo ia;  
\q2 pe fakahńĀ kiate kimautolu  Ľae ngaahi me Ľa  Ľe ha Ľu  Ľamui.   
\q1
\v 23 FakahńĀ  Ľae ngaahi me Ľa  Ľe hoko  Ľamui,  
\q2 ke mau  Ľilo ko e ngaahi  Ľotua  Ľakimoutolu:  
\q1  Ľio, fai lelei, pe fai kovi,  
\q2 ke mau ilifia,  
\q2 pea mamata fakataha ki ai.   
\q1
\v 24 Vakai,  Ľoku si Ľi hifo  Ľakimoutolu  Ľi he me Ľa  Ľoku  Ľikai,  
\q2 pea ko ho Ľomou ngńĀue ko e me Ľa noa pe:  
\q2  Ľoku fakalielia ia  Ľaia  Ľoku ne fili  Ľakimoutolu.   
\b  
\q1
\v 25 ‚ÄúKuo u fokotu Ľu ha tokotaha mei he potu tokelau, pea  Ľe ha Ľu ia:  
\q2 talu mei he hopo  Ľae la ĽńĀ te ne ui ki hoku huafa:  
\q2 pea te ne molomoloki  Ľae hou Ľeiki  Ľo hangńď ko e lahe kuo hakaluku,  
\q2 pea hangńď  Ľoku molomoloki  Ľe he tangata ngaohi ipu  Ľae  Ľumea.   
\q1
\v 26 Ko hai kuo ne fakahńĀ mei he kamata Ľanga, ke mau  Ľilo ia?  
\q2 Pea  Ľi mu Ľa, ke mau pehńď ai, ‚Äė ĽOku mo Ľoni  Ľae me Ľa ni?‚Äô  
\q1 Ko e mo Ľoni,  Ľoku  Ľikai ha tokotaha na Ľe tomu Ľa tala ia,  
\q2 ko e mo Ľoni,  Ľoku  Ľikai ha taha na Ľe fakahńĀ ia,  
\q2  Ľio, na Ľe  Ľikai ha tokotaha te ne fanongo ki ho Ľomou ngaahi lea.   
\q1
\v 27 Ne u fuofua pehńď ki Saione, ‚ÄėVakai, vakai kiate kinautolu:‚Äô  
\q2 pea ne u foaki ki SelŇęsalema ha tokotaha  Ľoku  Ľomi  Ľae ongoongolelei.   
\q1
\v 28 He na Ľaku mamata, ka na Ľe  Ľikai ha tangata;  
\q2  Ľio,  Ľiate kinautolu, pea na Ľe  Ľikai ha fakahinohino, pea  Ľi he Ľeku  Ľeke kiate kinautolu, na Ľe  Ľikai te nau tali  Ľaki ha momo Ľi lea.   
\q1
\v 29 Vakai, ko e va Ľinga kotoa pńď  Ľa  Ľenau ngńĀue:  
\q2 ko e matangi mo e va Ľinga  Ľa  Ľenau ngaahi tamapua kuo haka.   
\c 42  
\cd \it 1 Ko e ngńĀue  Ľa Kalaisi, kuo teu  Ľaki ia  Ľae angavaivai mo e loto ma Ľu. 5 Ko e tala Ľofa  Ľae  ĽOtua kiate ia. 10 Ko e enginaki ke fakamńĀlŇć ki he  ĽOtua koe Ľuhi ko e ongoongolelei. 17  ĽOku ne valoki  Ľae kakai  Ľi he Ľenau ta Ľetui.\it*  
\q1
\v 1 ‚ÄúVakai ki he Ľeku tamaio Ľeiki,  Ľaia  Ľoku ou poupou;  
\q2  Ľaia kuo u fili, pea  Ľoku fiefia  Ľiate ia hoku laumńĀlie;  
\q2 kuo u tuku hoku laumńĀlie kiate ia:  
\q2 te ne fakahńĀ  Ľae fakamaau ki he ngaahi Senitaile.   
\q1
\v 2 ‚ÄĆ ĽE  Ľikai te ne tangi,  
\q2 pe hiki hake hono le Ľo,  
\q2 pe fakaongo atu ia  Ľi he hala.   
\q1
\v 3 ‚ÄĆ ĽE  Ľikai te ne fesi Ľi ha kaho kuo volu,  
\q2 pe tńĀmate Ľi  Ľae maama  Ľoku kohu:  
\q2 te ne  Ľomi  Ľae fakamaau ki he mo Ľoni.   
\q1
\v 4 ‚ÄĆ ĽE  Ľikai te ne vaivai pe manavasi Ľi,  
\q2 kae Ľoua ke ne fokotu Ľu  Ľae fakamaau  Ľi mńĀmani:  
\q2 pea  Ľe tatali  Ľae ngaahi motu ki he Ľene fono.‚ÄĚ   
\q1
\v 5 ‚ÄĆ ĽOku pehńď  Ľe he  ĽOtua ko Sihova,  
\q2  Ľaia na Ľa ne fakatupu  Ľae ngaahi langi, pea folahi atu ia;  
\q2 ko ia na Ľe mafola atu  Ľae fonua, pea mo ia  Ľoku tupu ai;  
\q2 ko ia  Ľoku foaki  Ľae mńĀnava ki he kakai  Ľi he funga  Ľo ia, mo e laumńĀlie kiate kinautolu  Ľoku  Ľeve Ľeva  Ľi ai:   
\q1
\v 6 ‚ÄúKo au ko Sihova na Ľaku ui koe  Ľi he mńĀ Ľoni Ľoni,  
\q2 pea te u puke ho nima,  
\q2 pea tauhi koe,  
\q2 pea foaki koe ko e fuakava  Ľoe kakai,  
\q2 ko e maama ki he ngaahi Senitaile;   
\q2
\v 7 Ke faka ĽńĀ  Ľae mata  Ľoe kui,  
\q2 ke  Ľomi  Ľae kau pŇćpula mei he fale fakapŇćpula,  
\q2 pea ko kinautolu  Ľoku nofo  Ľi he po Ľuli mei he fale fakapŇćpula.   
\b  
\q1
\v 8 ‚ÄúKo au ko Sihova:  
\q2 ko hoku huafa ia:  
\q2 pea ko hoku nńĀunau  Ľe  Ľikai te u foaki ki ha taha,  
\q2 pe ko hoku fakamńĀlŇć ki he ngaahi tamapua kuo tongi.   
\q1
\v 9 Vakai, kuo hoko  Ľae ngaahi me Ľa mu Ľa,  
\q2 pea  Ľoku ou fakahńĀ  Ľae ngaahi me Ľa fo Ľou:  
\q2  Ľi he te Ľeki ke hoko  Ľoku ou fakahńĀ ia kiate kimoutolu.   
\q1
\v 10 Hiva kia Sihova  Ľaki  Ľae hiva fo Ľou,  
\q2 pea mo hono fakamńĀlŇć mei he ngata Ľanga  Ľo mńĀmani,  
\q2  Ľakimoutolu  Ľoku  Ľalu hifo ki he tahi,  
\q2 pea mo ia kotoa pńď  Ľoku  Ľi ai;  
\q2  Ľae ngaahi motu, mo e kakai  Ľoku nofo ai.   
\q1
\v 11 Tuku ke hiki hake honau le Ľo  Ľe he toafa mo e ngaahi kolo,  
\q2  Ľae ngaahi nofo Ľanga  Ľoku  Ľi Keta:  
\q2 tuku ke hiva  Ľae ngaahi kakai  Ľoe maka,  
\q2 tuku ke nau kalanga mei he tumutumu  Ľoe ngaahi mo Ľunga.   
\q1
\v 12 Tuku ke nau  Ľatu  Ľae ongoongolelei kia Sihova,  
\q2 pea fakahńĀ hono fakamńĀlŇć  Ľi he ngaahi motu.   
\q1
\v 13 ‚ÄĆ ĽE hńĀ Ľele atu  Ľa Sihova  Ľo hangńď ko e tangata mńĀlohi  Ľaupito,  
\q2 te ne ue Ľi hono houhau  Ľo hangńď ko e tangata  Ľoku to Ľa lahi:  
\q2 te ne kalanga,  
\q2  Ľio,  Ľo kalanga mńĀlohi,  
\q2 te ne lava Ľi hono ngaahi fili.   
\b  
\q1
\v 14 ‚ÄúKuo fuoloa mo  Ľeku fakalongo pe;  
\q2 na Ľaku nofo pe,  Ľo ta Ľofi au:  
\q2 ka te u tangi ni  Ľo hangńď ha fefine langńĀ; te u faka Ľauha mo maumau Ľi hifo fakataha.   
\q1
\v 15 Te u ngaohi ke lala  Ľae ngaahi mo Ľunga mo e potu tafungofunga,  
\q2 pea fakamŇćmoa  Ľae ngaahi  Ľakau iiki;  
\q2 pea te u ngaohi  Ľae ngaahi vaitafe ko e ngaahi motu,  
\q2 pea te u fakamŇćmoa mo e ngaahi anovai.   
\q1
\v 16 Pea te u  Ľomi  Ľae kui  Ľi he hala na Ľe  Ľikai te nau  Ľilo;  
\q2 te u tataki  Ľakinautolu  Ľi he ngaahi hala na Ľe  Ľikai te nau  Ľilo ki ai:  
\q2 te u ngaohi  Ľae po Ľuli ko e maama  Ľi honau  Ľao,  
\q2 mo e ngaahi me Ľa pikopiko ke totonu.  
\q2 Ko e ngaahi me Ľa ni te u fai kiate kinautolu,  
\q2 ka e  Ľikai li Ľaki  Ľakinautolu.   
\b  
\q1
\v 17 ‚Äú ĽE fakafoki ki mui  Ľakinautolu,  
\q2  Ľe mńĀ lahi,  Ľakinautolu  Ľoku falala ki he ngaahi tamapua kuo tongi,  
\q2  Ľakinautolu  Ľoku pehńď ki he ngaahi fakatńĀtńĀ kuo haka,  
\q2 ‚ÄėKo homau  Ľotua  Ľakimoutolu.‚Äô   
\q1
\v 18 ‚ÄúFanongo,  Ľakimoutolu  Ľoku tuli;  
\q2 pea sio,  Ľakimoutolu  Ľoku kui,  
\q2 koe Ľuhi ke mou  ĽńĀ.   
\q1
\v 19 Ko hai  Ľoku kui, ka ko  Ľeku tamaio Ľeiki?  
\q2 Pe tuli,  Ľo hangńď ko  Ľeku talafekau  Ľaia na Ľaku fekau?  
\q2 Ko hai  Ľoku kui  Ľo hangńď ko ia  Ľoku haohaoa,  
\q2 pea kui  Ľo hangńď ko e tamaio Ľeiki  Ľa Sihova?   
\q1
\v 20 ‚ÄĆ ĽOku ke mamata ki he ngaahi me Ľa lahi, ka  Ľoku  Ľikai te ke tokanga Ľi ia;  
\q2  Ľo fakaava  Ľae telinga, ka  Ľoku  Ľikai te ke fanongo.   
\q1
\v 21 ‚ÄĆ ĽOku fiemńĀlie lahi  Ľa Sihova koe Ľuhi ko  Ľene mńĀ Ľoni Ľoni  Ľa Ľana; te ne hakeaki Ľi  Ľae fono,  
\q2 pea ngaohi ke ongoongolelei ia.   
\q1
\v 22 Ka ko e kakai eni kuo fa Ľao  Ľenau ngaahi me Ľa, pea kuo vetea  Ľakinautolu;  
\q2 kuo mo Ľua  Ľakinautolu kotoa pńď  Ľi he ngaahi luo,  
\q2 pea kuo fufŇę  Ľakinautolu  Ľi he ngaahi fale fakapŇćpula:  
\q1  Ľoku pau ke pŇćpula  Ľakinautolu, pea  Ľe  Ľikai ha taha ke fakamo Ľui;  
\q2 kuo fa Ľao  Ľakinautolu, pea  Ľoku  Ľikai pehńď  Ľe ha taha, ‚ÄėKe toe  Ľomi.‚Äô   
\q1
\v 23 Ko hai  Ľiate kimoutolu te ne tokanga ki he me Ľa ni?  
\q2 Ko hai te ne fakafanongo pea ongo Ľi  Ľi he kuonga  Ľe hoko mai?   
\q1
\v 24 Ko hai na Ľe tuku  Ľa Sńďkope ke vetea,  
\q2 pea mo  ĽIsileli ki he kau kaiha Ľa?  
\q2  ĽIkai ko Sihova,  Ľaia kuo tau fai hala ki ai?  
\q2 He na Ľe  Ľikai te nau fie  Ľeve Ľeva  Ľi hono ngaahi hala,  
\q2 pea na Ľe  Ľikai te nau talangofua ki he Ľene fono.   
\q1
\v 25 Ko ia kuo ne lilingi kiate ia  Ľae kakaha  Ľo hono houhau,  
\q2 pea mo e mńĀlohi  Ľoe tau:  
\q2 pea kuo ne tutu ia  Ľo takatakai, ka na Ľe  Ľikai te ne fa Ľa  Ľilo;  
\q2 pea na Ľe vela ia, ka na Ľe  Ľikai tokanga hono loto ki ai.‚ÄĚ   
\c 43  
\cd \it 1  ĽOku fakafiemńĀlie Ľi  Ľe Sihova  Ľae siasi  Ľaki  Ľene ngaahi tala Ľofa. 8  ĽOku ne tala ki he kakai ke nau fakamo Ľoni ki he Ľene mńĀfimafi. 14  ĽOku ne fakahńĀ kiate kinautolu  Ľae faka Ľauha  Ľa Papilone, 18 Pea fakamanavahńď  Ľa  Ľene fakamo Ľui  Ľa hono kakai. 22  ĽOku ne valoki  Ľae kakai  Ľi he Ľenau kovi lahi.\it*  
\q1
\v 1 Ka ko eni,  Ľoku pehńď  Ľe Sihova  Ľaia na Ľa ne ngaohi koe,  ĽE Sńďkope,  
\q2 pea ko ia na Ľe fakafuofua koe,  ĽE  ĽIsileli,  
\q1 ‚Äú ĽOua  Ľe manavahńď: he kuo u huhu Ľi koe,  
\q2 kuo u ui koe  Ľaki ho hingoa;  
\q2  Ľoku  Ľa Ľaku koe.   
\q1
\v 2 ‚ÄĆ ĽOka ke ka  Ľalu  Ľi he vai, te u  Ľiate koe;  
\q2 pea  Ľi he ngaahi vaitafe,  Ľe  Ľikai te ke melemo ai:  
\q1  Ľoka ke ka  Ľalu  Ľi he afi,  Ľe  Ľikai te ke vela;  
\q2 pea  Ľe  Ľikai  Ľalu hake  Ľiate koe  Ľae ulo afi.   
\q1
\v 3 He ko au ko Sihova ko ho  ĽOtua,  
\q2 ko e tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli,  
\q2 ko ho Fakamo Ľui:  
\q1 na Ľaku foaki  Ľa  ĽIsipite ko ho huhu Ľi,  
\q2  Ľa  ĽItiopea mo Sipa ma Ľau.   
\q1
\v 4 Ko e me Ľa  Ľi ho Ľo mahu Ľinga  Ľi hoku  Ľao, ko ia na Ľa ke ongoongolelei ai,  
\q2 pea kuo u  Ľofa kiate koe:  
\q2 ko ia te u foaki  Ľae kau tangata koe Ľuhi ko koe,  
\q2 pea mo e kakai koe Ľuhi ko ho Ľo mo Ľui.   
\q1
\v 5 ‚ÄĆ ĽOua  Ľe manavahńď: he  Ľoku ou  Ľiate koe:  
\q2 te u  Ľomi ho hako mei hahake,  
\q2 pea tńĀnaki ko e mei he lulunga;   
\q1
\v 6 Te u pehńď ki he tokelau, ‚ÄėTukuange,‚Äô  
\q2 pea ki he potu tonga, ‚Äė ĽOua  Ľe ta Ľofi:‚Äô  
\q2  Ľomi hoku ngaahi foha mei he mama Ľo,  
\q2 mo hoku ngaahi  Ľofefine mei he ngaahi ngata Ľanga  Ľo mńĀmani;   
\q1
\v 7 ‚ÄĆ ĽIo,  Ľakinautolu kotoa pńď  Ľoku ui  Ľaki hoku huafa:  
\q2 he kuo fakatupu ia ke u ongoongolelei ai:  
\q2 na Ľaku fakafuofua ia,  
\q2  Ľio, na Ľaku ngaohi ia.‚ÄĚ   
\b  
\q1
\v 8 Omi  Ľae kakai kui  Ľoku mata,  
\q2 pea mo e tuli  Ľoku telinga.   
\q1
\v 9 Ke tńĀnaki fakataha  Ľae ngaahi pule Ľanga kotoa pńď,  
\q2 pea ke fakataha  Ľae kakai:  
\q1 ko hai  Ľiate kinautolu te ne fakahńĀ  Ľae me Ľa ni,  
\q2 pea fakahńĀ kiate kitautolu  Ľae ngaahi me Ľa mu Ľa?  
\q1 Tuku ke nau  Ľomi  Ľa  Ľenau kau fakamo Ľoni, koe Ľuhi ke nau tonuhia:  
\q2 pe tuku ke nau fanongo, pea pehńď, ‚ÄúKo e mo Ľoni ia.‚ÄĚ   
\b  
\q1
\v 10 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚ÄúKo  Ľeku kau fakamo Ľoni  Ľakimoutolu,  
\q2 pea ko  Ľeku tamaio Ľeiki  Ľaia kuo u fili:  
\q2 koe Ľuhi ke mou  Ľilo pea tui kiate au,  
\q2 pea  Ľilo pau ko au ia:  
\q1 na Ľe  Ľikai ha  ĽOtua kuo fakatupu  Ľi mu Ľa  Ľiate au,  
\q2 pea  Ľe  Ľikai ha taha kimui.   
\q1
\v 11 Ko au,  Ľio ko au, ko Sihova;  
\q2 pea  Ľoku  Ľikai mo ha fakamo Ľui ka ko au pe.   
\q1
\v 12 Kuo u fakahńĀ, pea kuo u fakamo Ľui, pea kuo u fakahinohino,  
\q2  Ľi he  Ľikai ha  Ľotua kehe  Ľiate kimoutolu:  
\q1 ko ia  Ľoku pehńď  Ľe Sihova, ‚Äúko  Ľeku kau fakamo Ľoni  Ľakimoutolu,  
\q2 Ko au pe ko e  ĽOtua.‚ÄĚ   
\q1
\v 13 ‚ÄĆ ĽIo,  Ľi he te Ľeki ai  Ľae  Ľaho ko au ia,  
\q2 pea  Ľoku  Ľikai ha taha te ne fa Ľa fakamo Ľui mei hoku nima:  
\q2 te u ngńĀue, pea ko hai te ne ta Ľofi au?   
\p
\v 14 ¬∂  ĽOku pehńď  Ľe Sihova, ko homou huhu Ľi, ko e tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli; Ko e me Ľa  Ľiate kimoutolu kuo u fekau ki Papilone, pea kuo  Ľomi ki lalo honau hou Ľeiki, pea mo e kakai Kalitia,  Ľaia  Ľoku  Ľi he ngaahi vaka  Ľenau tangi.  
\v 15 Ko au ko Sihova, ko homou tokotaha mńĀ Ľoni Ľoni, ko e Tupu Ľanga  Ľo  ĽIsileli, ko homou Tu Ľi.   
\p
\v 16 ‚ÄĆ ĽOku pehńď  Ľe Sihova,  Ľaia  Ľoku ngaohi  Ľae  Ľalu Ľanga  Ľi he moana,  
\q2 pea mo e hala  Ľi he ngaahi vai lahi;   
\q1
\v 17 ‚ÄĆ ĽAia  Ľoku  Ľomi  Ľae saliote mo e hoosi,  
\q2  Ľae kongakau mo e mńĀlohi:  
\q2 te nau tokoto fakataha,  Ľe  Ľikai te nau tu Ľu ki  Ľolunga:  
\q2 kuo nau  Ľauha, kuo fu Ľifu Ľi  Ľakinautolu  Ľo hangńď ko e filo  Ľoe maama.   
\q1
\v 18 ‚Äú ĽOua na Ľa mou manatu ki he ngaahi me Ľa mu Ľa,  
\q2 pe tokanga ki he ngaahi me Ľa motu Ľa.   
\q1
\v 19 Vakai, te u fai ha me Ľa fo Ľou;  
\q2  Ľe tupu hake ni ia;  
\q2 pea  Ľikai te mou  Ľilo ia?  
\q2  ĽIo, te u ngaohi ha hala  Ľi he potu lala,  
\q2 mo e ngaahi vaitafe  Ľi he toafa.   
\q1
\v 20 ‚ÄĆ ĽE faka Ľapa Ľapa kiate au  Ľae fanga manu  Ľoe vao,  
\q2  Ľae talńĀkoni mo e ngaahi lulu:  
\q1 koe Ľuhi  Ľoku ou foaki  Ľae vai  Ľi he potu lala, mo e vaitafe  Ľi he toafa,  
\q2 ke  Ľatu  Ľae inu ki hoku kakai kuo u fili.   
\q1
\v 21 Kuo u ngaohi  Ľae kakai ni ma Ľaku;  
\q2 te nau fakahńĀ hoku ongoongolelei.   
\q1
\v 22 Ka na Ľe  Ľikai te ke ui kiate au,  ĽE Sńďkope;  
\q2 ka kuo ke fiu  Ľiate au,  ĽE  ĽIsileli.   
\q1
\v 23 ‚ÄĆ ĽOku te Ľeki te ke  Ľomi  Ľae fanga lami  Ľo ho Ľo ngaahi feilaulau tutu;  
\q2 pea te Ľeki ai te ke faka Ľapa Ľapa  Ľaki ho Ľo ngaahi feilaulau.  
\q1 Na Ľe  Ľikai te u fekau ke ke tauhi au  Ľaki ha me Ľa foaki,  
\q2 pe fakaongosia koe  Ľi he  Ľomi  Ľae me Ľa namu kakala.   
\q1
\v 24 ‚ÄĆ ĽOku te Ľeki te ke fakatau ma Ľaku  Ľae  Ľakau namu kakala  Ľaki ha pa Ľanga,  
\q2 pea  Ľoku te Ľeki te ke fakamńĀkona au  Ľaki  Ľae ngako  Ľo ho Ľo ngaahi feilaulau;  
\q1 ka kuo ke ta Ľomia au  Ľaki ho Ľo ngaahi hia,  
\q2 kuo ke fakafiu Ľi au  Ľi ho Ľo ngaahi fai kovi.   
\q1
\v 25 Ko au,  Ľio ko au ia,  Ľaia  Ľoku tńĀmate Ľi ho Ľo ngaahi hia koe Ľuhi ko au,  
\q2 pea  Ľe  Ľikai te u manatu ho Ľo ngaahi angahala.   
\q1
\v 26 Fakamanatu Ľi au:  
\q2 ke tau fefakamaau Ľaki:  
\q2 fai ho Ľo fakamatala,  
\q2 koe Ľuhi ke ke tonuhia.   
\q1
\v 27 Kuo fai hala ho Ľo  Ľuluaki tamai,  
\q2 pea kuo talangata Ľa kiate au ho Ľo kau akonaki.   
\q1
\v 28 Pea kuo fakalielia Ľi  Ľe ho ngaahi hou Ľeiki hoku fale tapu,  
\q2 ko ia te u tuku  Ľa Sńďkope ki he mala Ľia,  
\q2 pea ko  ĽIsileli ki he valoki.‚ÄĚ   
\c 44  
\cd \it 1  ĽOku fakafiemńĀlie Ľi  Ľe he  ĽOtua  Ľae siasi  Ľaki  Ľene ngaahi tala Ľofa. 7 Ko e va Ľinga  Ľae ngaahi tamapua, 9 Mo e vale  Ľokinautolu  Ľoku ngaohi tamapua. 21  ĽOku ne enginaki ke fakamńĀlŇć ki he  ĽOtua koe Ľuhi ko  Ľene huhu Ľi mo  Ľene mńĀfimafi.\it*  
\b  
\p
\v 1 Ka ko eni, fanongo,  ĽE Sńďkope ko  Ľeku tamaio Ľeiki;  
\q2 mo  ĽIsileli,  Ľa koe kuo u fili:   
\q1
\v 2 ‚ÄĆ ĽOku pehńď  Ľe Sihova  Ľaia na Ľa ne ngaohi koe,  
\q2 pea na Ľe fakafuofua koe mei he manńĀva,  
\q2  Ľaia te ne tokoni Ľi koe;  
\q1 ‚Äú ĽOua  Ľe manavahńď,‚ÄĚ  ĽE Sńďkope, ko  Ľeku tamaio Ľeiki:  
\q2 pea mo koe, ko Sesuluni,  Ľa koe kuo u fili.   
\q1
\v 3 He te u lilingi  Ľae vai kiate ia  Ľoku fieinu,  
\q2 pea mo e vai lahi ki he kelekele mŇćmoa:  
\q1 pea te u hua Ľi hoku laumńĀlie ki ho hako,  
\q2 mo  Ľeku tńĀpuaki ki ho Ľo fńĀnau:   
\q1
\v 4 Pea te nau tupu hake  Ľo hangńď  Ľoku  Ľi he mohuku,  
\q2  Ľo hangńď ko e ngaahi uilou  Ľi he ve Ľe vaitafe.   
\q1
\v 5 ‚ÄĆ ĽE pehńď  Ľe ha tokotaha, ‚Äú ĽOku  Ľo Sihova au;‚ÄĚ  
\q2 pea ko e tokotaha  Ľe ui  Ľaki  Ľae hingoa ko Sńďkope;  
\q2 pea ko e tokotaha te ne tohi  Ľaki hono nima kia Sihova,  
\q2 pea fakahingoa fo Ľou ia  Ľaki  Ľae hingoa  Ľo  ĽIsileli.   
\b  
\q1
\v 6 ‚ÄĆ ĽOku pehńď  Ľe Sihova ko e Tu Ľi  Ľo  ĽIsileli,  
\q2 pea ko hono huhu Ľi ko Sihova  Ľoe ngaahi kautau;  
\q1 ‚ÄúKo au ko e  Ľuluaki, pea ko au pe ko e ki mui;  
\q2 pea  Ľoku  Ľikai ha  ĽOtua mo au.‚ÄĚ   
\q1
\v 7 Pea ko hai,  Ľo hangńď ko au,  
\q2  Ľe ui,  
\q2 pea  Ľe fakahńĀ ia,  
\q2 pea  Ľe fakatonutonu ia ma Ľaku,  
\q2 hili  Ľeku fakanofo  Ľae kakai  Ľi mu Ľa?  
\q1 Pea ko e ngaahi me Ľa  Ľoku ha Ľu ni, pea mo ia  Ľe hoko,  
\q2 tuku ke nau fakahńĀ kiate kinautolu.   
\q1
\v 8 ‚ÄĆ ĽOua te mou manavahńď,  
\q2 pea  Ľoua  Ľe lilika:  
\q1  Ľikai kuo u fakahńĀ kiate koe mei he kuonga ko ia,  
\q2 pea kuo fanongonongo ia?  
\q1  ĽIo, ko  Ľeku kau fakamo Ľoni  Ľakimoutolu.  
\q2  ĽOku ai ha  ĽOtua mo au?  
\q1  ĽIo,  Ľoku  Ľikai ha  ĽOtua;  
\q2  Ľoku  Ľikai te u  Ľilo ha taha.‚ÄĚ   
\q1
\v 9 Ko e va Ľinga  Ľakinautolu kotoa pńď  Ľoku ngaohi  Ľae tamapua kuo tongi;  
\q2 pea  Ľe  Ľikai  Ľaonga  Ľae ngaahi me Ľa  Ľoku nau fiefia ai;  
\q2 pea ko e kau fakamo Ľoni  Ľakinautolu kiate kinautolu;  Ľoku  Ľikai te nau mamata, pe  Ľilo, koe Ľuhi ke nau mńĀ ai.   
\q1
\v 10 Ko hai kuo ne fakafuofua ha  Ľotua,  
\q2 pe ngaohi ha tamapua kuo tongi  Ľoku  Ľaonga ki ha me Ľa  Ľe taha?   
\q1
\v 11 Vakai,  Ľe mńĀ  Ľene ngaahi kaume Ľa kotoa pńď:  
\q2 pea ko e kau ngńĀue,  Ľoku  Ľoe tangata  Ľakinautolu:  
\q1 tuku ke tńĀnaki fakataha  Ľakinautolu,  
\q2 tuku ke nau tu Ľu hake;  
\q2 ka te nau manavahńď,  
\q2 pea te nau mńĀ fakataha.   
\q1
\v 12 Ko e tufunga ukamea  
\q2  Ľoku ne ngńĀue Ľaki  Ľae me Ľa fakaŇę  Ľi he malala,  
\q2 pea fakafuofua ia  Ľaki  Ľae ngaahi hamala,  
\q2 pea  Ľoku ngaohi ia  Ľaki  Ľae mńĀlohi  Ľo hono nima:  
\q1  Ľio,  Ľoku fiekaia ia,  
\q2 pea kuo tei  Ľosi hono mńĀlohi:  
\q1  Ľoku ta Ľeinu ia ha vai,  
\q2 pea  Ľoku vaivai.   
\q1
\v 13 ‚ÄĆ ĽOku mafao  Ľe he tufunga  Ľakau  Ľene me Ľa fuofua;  
\q2  Ľoku ne faka Ľilonga ia  Ľaki ha afo;  
\q2  Ľoku ne fakatau ia  Ľaki  Ľae ngaahi tele,  
\q2 pea  Ľoku ne faka Ľilonga ia  Ľaki  Ľae me Ľa fua,  
\q2 pea ngaohi ia ko e fakatńĀtńĀ ki he tangata,  
\q2  Ľo hangńď ko e toulekeleka  Ľoe tangata;  
\q2 koe Ľuhi ke nofo ia  Ľi he fale.   
\q1
\v 14 ‚ÄĆ ĽOku ne tńĀ hifo  Ľae ngaahi sita,  
\q2 pea to Ľo  Ľae saipalesi pea mo e  Ľoke,  
\q2  Ľaia  Ľoku ne fakamńĀlohi ma Ľana  Ľi he ngaahi  Ľakau  Ľoe vao:  
\q1  Ľoku ne tŇć  Ľae  Ľasi,  
\q2 pea  Ľoku mo Ľui ia  Ľi he  Ľuha.   
\q1
\v 15 Pea  Ľe hoko ia ko e fefie ki he tangata:  
\q2 pea te ne to Ľo mei ai, pea fakamafana ia;  
\q2  Ľio,  Ľoku ne tutu ia, pea ta Ľo  Ľae mńĀ;  
\q1  Ľio,  Ľoku ne ngaohi ha  Ľotua, pea lotu ki ai;  
\q2  Ľoku ne ngaohi ia ko e tamapua kuo tongi, pea fo Ľohifo ki ai.   
\q1
\v 16 ‚ÄĆ ĽOku ne tutu hono konga  Ľi he afi;  
\q2  Ľoku ne teuteu  Ľaki hono konga  Ľae kakano ki he kai;  
\q2  Ľoku ne tunu  Ľae kakano, pea mńĀkona ai:  
\q1  Ľio,  Ľoku ne mumŇę,  
\q2 pea ne pehńď, ‚ÄúKo eni, kuo u mńĀfana, kuo u mamata ki he afi:‚ÄĚ   
\q1
\v 17 Pea ko hono toe  Ľo ia  Ľoku ne ngaohi  Ľaki ha  Ľotua,  
\q2  Ľio, ko  Ľene tamapua kuo tongi:  
\q1  Ľoku ne fo Ľohifo  Ľo hŇę ki ai,  
\q2 pea lotu ki ai, pea ne pehńď, ‚ÄúFakamo Ľui au, he ko koe ko hoku  Ľotua.‚ÄĚ   
\q1
\v 18 ‚ÄĆ ĽOku te Ľeki te nau fanongo pe  Ľilo  
\q2 he kuo ne tńĀpuni honau mata, ke  Ľoua te nau mamata;  
\q2 mo honau loto, ko ia  Ľoku nau ta Ľe Ľilo ai.   
\q1
\v 19 Pea  Ľoku  Ľikai ha tokotaha  Ľoku tokanga  Ľi hono loto,  
\q2 pea  Ľoku  Ľikai ha  Ľilo pe ha fakakaukau ke pehńď,  
\q2 ‚ÄúKuo u tutu hono konga  Ľi he afi;  
\q2  Ľio, pea kuo u ta Ľo mńĀ  Ľi hono malala  Ľo ia;  
\q2 kuo u tunu ai  Ľae kanomate, pea kai ia;  
\q2 pea te u ngaohi hono toe ko e me Ľa fakalielia?  
\q2 He te u fo Ľohifo ki he sino  Ľoe  Ľakau?‚ÄĚ   
\q1
\v 20 ‚ÄĆ ĽOku ne kai  Ľae efuefu:  
\q2 ko e loto kńĀkńĀ kuo ne fakaafe ia,  
\q2 ko ia  Ľoku  Ľikai te ne fa Ľa fakamo Ľui hono laumńĀlie,  
\q2 pe pehńď, ‚Äú ĽIkai ko e loi  Ľoku  Ľi hoku nima to Ľomata Ľu?‚ÄĚ   
\q1
\v 21 Manatu Ľi  Ľae ngaahi me Ľa ni,  ĽE Sńďkope mo  ĽIsileli;  
\q2 he ko  Ľeku tamaio Ľeiki koe:  
\q2 Na Ľaku fakafuofua koe;  
\q2 ko koe ko  Ľeku tamaio Ľeiki:  
\q2  ĽE  ĽIsileli,  Ľo  Ľikai te ke ngalo  Ľiate au.   
\q1
\v 22 Kuo u tńĀmate Ľi ho Ľo ngaahi hia,  Ľo hangńď ko e  Ľao matolu,  
\q2 pea hangńď ko e  Ľao,  Ľa ho Ľo ngaahi angahala:  
\q2 tafoki mai kiate au; he kuo u huhu Ľi koe.   
\b  
\q1
\v 23 Hiva,  Ľakimoutolu  Ľae ngaahi langi he kuo fai ia  Ľe Sihova:  
\q2 kalanga,  Ľakimoutolu  Ľae ngaahi potu mńĀ Ľulalo  Ľo mńĀmani:  
\q2 ke hńĀ homou hiva,  Ľae ngaahi mo Ľunga,  Ľa koe ko e vao  Ľakau, pea mo e  Ľakau kotoa pńď  Ľi ai:  
\q2 he kuo huhu Ľi  Ľe Sihova  Ľa Sńďkope,  
\q2 pea kuo ne fakaongoongolelei ia  Ľi  ĽIsileli.   
\q1
\v 24 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ko ho huhu Ľi,  
\q2 pea ko ia na Ľe fakafuofua koe mei he manńĀva,  
\q1 ‚ÄúKo au ko Sihova kuo u ngaohi  Ľae me Ľa kotoa pńď;  
\q2 kuo u folahi tokotaha pe  Ľae ngaahi langi;  
\q2  Ľoku fofola atu  Ľa mńĀmani  Ľe au pe;   
\q1
\v 25 Ko au ia  Ľoku ta Ľofi  Ľae ngaahi faka Ľilonga  Ľoe kau loi,  
\q2 pea fakavale Ľi  Ľae kau kikite;  
\q1 mo fakafoki  Ľae kau tangata poto,  
\q2 pea  Ľoku ngaohi  Ľa  Ľenau  Ľilo ko e vale;   
\q1
\v 26 Ko ia  Ľoku fokotu Ľuma Ľu  Ľae lea  Ľa  Ľene tamaio Ľeiki,  
\q2 pea fakamo Ľoni ki he akonaki  Ľo  Ľene kau talafekau;  
\q1  Ľaia  Ľoku pehńď ki SelŇęsalema, ‚Äė ĽE fakakakai koe;‚Äô  
\q2 pea ki he ngaahi kolo  Ľo Siuta, ‚Äė ĽE langa  Ľakimoutolu,‚Äô  
\q2 pea ‚ÄėTe u toe fokotu Ľu  Ľae ngaahi potu maumau  Ľi ai:‚Äô   
\q1
\v 27 ‚ÄĆ ĽAia  Ľoku pehńď ki he loloto, ‚ÄėKe mŇćmoa koe,‚Äô  
\q2 pea, ‚ÄėTe u fakamaha ho Ľo ngaahi vaitafe;‚Äô   
\q1
\v 28 ‚ÄĆ ĽAia  Ľoku pehńď kia Kolesi, ‚ÄėKo hoku tauhi ia, pea te ne fai hoku finangalo kotoa pńď:‚Äô  
\q2  Ľio,  Ľo ne pehńď ki SelŇęsalema, ‚Äė ĽE langa koe;‚Äô  
\q2 pea ki he falelotu lahi,  ĽE ai ho tu Ľunga.‚Äô‚ÄĚ   
\c 45  
\cd \it 1  ĽOku ui  Ľae  ĽOtua kia Kolesi koe Ľuhi ko hono siasi. 5  ĽOku ne fekau ke talangofua ko e me Ľa  Ľi he Ľene MńĀfimafi. 20  ĽOku ne fakamo Ľoni  Ľae va Ľinga  Ľoe ngaahi tamapua  Ľaki hono mńĀlohi fakamo Ľui.\it*  
\p
\v 1 ‚ÄĆ ĽOku pehńď  Ľe Sihova ki he Ľene pani, kia Kolesi,  Ľaia kuo u puke ki hono nima to Ľomata Ľu, ke fakavaivai  Ľae ngaahi pule Ľanga  Ľi hono  Ľao; pea te u vete  Ľae no Ľotanga vala  Ľoe ngaahi tu Ľi, ke fakaava  Ľi hono  Ľao  Ľae ngaahi matapńĀ louua pea  Ľe  Ľikai tńĀpuni  Ľae ngaahi matapńĀ;   
\q1
\v 2 ‚ÄúTe u mu Ľomu Ľa  Ľiate koe,  
\q2 pea ngaohi  Ľae ngaahi potu pikopiko ke totonu:  
\q1 te u laiki  Ľae ngaahi matapńĀ palasa,  
\q2 pea tu Ľusi ke motu  Ľae ngaahi ukamea fakama Ľu:   
\q1
\v 3 Pea te u foaki kiate koe  Ľae koloa  Ľoe po Ľuli,  
\q2 mo e koloa fufŇę  Ľoe ngaahi potu lilo,  
\q1 koe Ľuhi ke ke  Ľilo ko au, ko Sihova,  Ľaia  Ľoku ui koe  Ľaki ho hingoa,  
\q2 ko au ko e  ĽOtua  Ľo  ĽIsileli.   
\q1
\v 4 Koe Ľuhi ko Sńďkope ko  Ľeku tamaio Ľeiki,  
\q2 mo  ĽIsileli kuo u fili,  
\q1 kuo u ui  Ľaki koe ho hingoa:  
\q2 kuo u fakahingoa koe,  
\q2 ka  Ľoku te Ľeki te ke  Ľilo au.   
\b  
\p
\v 5 ¬∂ Ko au ko Sihova, pea  Ľoku  Ľikai mo ha taha,  
\q2  Ľoku  Ľikai ha  ĽOtua mo au:  
\q1 na Ľaku fakakofu Ľi koe,  
\q2 ka  Ľoku te Ľeki te ke  Ľilo au:   
\q1
\v 6 Koe Ľuhi ke nau  Ľilo mei he hopo Ľangala ĽńĀ,  
\q2 pea mei he lulunga,  
\q1  Ľoku  Ľikai ha taha mo au.  
\q2 Ko au ko Sihova, pea  Ľoku  Ľikai mo ha taha.   
\q1
\v 7 Kuo u ngaohi  Ľae maama,  
\q2 pea fakatupu mo e po Ľuli:  
\q1  Ľoku ou fakahoko  Ľae melino,  
\q2 pea fakatupu mo e tau:  
\q1 ko au ko Sihova  
\q2  Ľoku ou fai  Ľae ngaahi me Ľa ni kotoa pńď.   
\q1
\v 8 Mapee hifo,  Ľakimoutolu  Ľae ngaahi langi mei  Ľolunga,  
\q2 pea tuku ke lilingi  Ľe he ngaahi  Ľao  Ľae mńĀ Ľoni Ľoni:  
\q1 tuku ke fakamanga  Ľae kelekele, pea tuku ke tupu ai  Ľae mo Ľui,  
\q2 pea tuku ke tupu fakataha mo e angatonu;  
\q1 ko au ko Sihova kuo u fakatupu ia.   
\q1
\v 9 ‚ÄĆ ĽE mala Ľia ia  Ľaia  Ľoku fekuki mo hono Tupu Ľanga!  
\q2 Tuku ke fai  Ľe he konga ipu maumau mo e ngaahi konga ipu maumau  Ľoe kelekele.  
\q1  ĽE pehńď  Ľe he  Ľumea kiate ia  Ľoku ne fakafuofua ia, ‚ÄúKo e hńĀ kuo ke ngaohi?‚ÄĚ  
\q2 Pe ko ho Ľo ngńĀue, ‚Äú ĽOku  Ľikai hano nima?‚ÄĚ   
\q1
\v 10 ‚ÄĆ ĽE mala Ľia ia  Ľoku pehńď ki he Ľene tamai, ‚ÄúKo e hńĀ kuo ke fakatupu?‚ÄĚ  
\q2 Pe ki he fefine, ‚ÄúKo e hńĀ ia kuo ke fanau Ľi?‚ÄĚ   
\q1
\v 11 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ko e tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli,  
\q2 mo hono Tupu Ľanga,  
\q1 ‚ÄúFehu Ľi kiate au  Ľi he ngaahi me Ľa  Ľe hoko  Ľoku kau ki hoku ngaahi foha,  
\q2 pea  Ľi he ngaahi ngńĀue  Ľa hoku nima mou fekau mai kiate au.   
\q1
\v 12 Kuo u ngaohi  Ľa mńĀmani, pea fakatupu mo e tangata  Ľi ai:  
\q2 ko au, kuo u folahi  Ľe hoku nima  Ľae ngaahi langi,  
\q2 pea kuo u fekau ki honau tokolahi kotoa pńď.   
\q1
\v 13 ‚ÄĆ ĽOku pehńď  Ľe Sihova  Ľoe ngaahi kautau, ‚Äúkuo u fokotu Ľu hake ia  Ľi he mńĀ Ľoni Ľoni,  
\q2 pea te u fakahinohino hono ngaahi hala kotoa pńď:  
\q1 te ne langa  Ľeku kolo,  
\q2 pea te ne tukuange  Ľeku ngaahi pŇćpula,  
\q2 ka e  Ľikai koe Ľuhi ko e fakatau, pe ko e totongi.   
\q1
\v 14 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚Äú ĽE ha Ľu kiate koe  Ľae ngńĀue  Ľa  ĽIsipite,  
\q2 mo e koloa  Ľa  ĽItiopea,  
\q2 pea mo e kakai Sipa, ko e kau tangata lalahi,  
\q2 pea  Ľe  Ľa Ľau  Ľakinautolu:  
\q1 te nau muimui  Ľiate koe;  
\q2  Ľi he ukamea fihifihi te nau a Ľu mai,  
\q2 pea te nau tŇć ki lalo kiate koe,  
\q1 te nau kole kiate koe,  Ľo pehńď,  
\q2 ‚ÄėKo e mo Ľoni  Ľoku  Ľiate koe  Ľae  ĽOtua; pea  Ľoku  Ľikai mo ha tokotaha,  
\q2  Ľoku  Ľikai mo ha  ĽOtua.‚Äô‚ÄĚ   
\q1
\v 15 Ko e mo Ľoni ko koe ko e  ĽOtua  Ľoku ke fufŇę koe,  
\q2  ĽE  ĽOtua  Ľo  ĽIsileli, ko e Fakamo Ľui.‚ÄĚ   
\q1
\v 16 Te nau mńĀ,  
\q2 pea puputu Ľu,  Ľakinautolu kotoa pńď:  
\q2  Ľe tutuku fakataha  Ľi he maveuveu  Ľakinautolu  Ľoku ngaohi tamapua.   
\q1
\v 17 Ka e fakamo Ľui  Ľa  ĽIsileli  Ľia Sihova  Ľaki  Ľae mo Ľui ta Ľengata:  
\q2  Ľe  Ľikai te mou mńĀ pe puputu Ľu  Ľo lauikuonga pea ta Ľengata.   
\q1
\v 18 He  Ľoku pehńď  Ľe Sihova  Ľaia na Ľa ne ngaohi  Ľae ngaahi langi;  
\q2 ko e  ĽOtua pe  Ľaia na Ľe fakafuofua  Ľa mńĀmani mo fakatupu ia;  
\q2 kuo ne fokotu Ľuma Ľu ia, na Ľe  Ľikai te ne ngaohi ke ta Ľe Ľaonga ia,  
\q2 na Ľa ne fakafuofua ia ke nofo ai  Ľae kakai:  
\q1 ‚Äúko au ko Sihova:  
\q2 pea  Ľoku  Ľikai mo ha tokotaha.   
\q1
\v 19 Na Ľe  Ľikai te u lea  Ľi he lilo,  
\q2  Ľi ha potu fakapo Ľuli  Ľo mńĀmani:  
\q1 na Ľe  Ľikai te u pehńď ta Ľe Ľaonga ki he hako  Ľo Sńďkope, ‚ÄėKumi kiate au:‚Äô  
\q2 Ko au ko Sihova  Ľoku ou lea  Ľaki  Ľae mńĀ Ľoni Ľoni,  
\q2  Ľoku ou fakahńĀ  Ľae ngaahi me Ľa  Ľoku totonu.‚ÄĚ   
\b  
\q1
\v 20 ‚ÄúFakataha  Ľakimoutolu pea ha Ľu;  
\q2  Ľunu Ľunu mai ke ofi  Ľakimoutolu kuo hao  Ľi he ngaahi pule Ľanga:  
\q2  Ľoku  Ľikai ha  Ľilo  Ľiate kinautolu  Ľoku fokotu Ľu  Ľae  Ľakau  Ľo  Ľenau tamapua kuo tongi,  
\q2 pea hŇę ki he  Ľotua  Ľoku  Ľikai fa Ľa fakamo Ľui.   
\q1
\v 21 Mou tala, pea  Ľomi ke ofi  Ľakinautolu,  
\q2  Ľio, tuku ke nau fakakaukau fakataha:  
\q1 ko hai kuo ne fakahńĀ  Ľae me Ľa ni mei he kuonga  Ľi mu Ľa?  
\q2 Ko hai kuo ne tala ia mei he kuonga ko ia?  
\q2  ĽIkai ko au ko Sihova?  
\q1 Pea  Ľoku  Ľikai mo ha  ĽOtua mo au; ko e  ĽOtua angatonu pea ko e Fakamo Ľui;  
\q2  Ľoku  Ľikai ha taha mo au.   
\b  
\q1
\v 22 ‚ÄúSio mai kiate au pea mou mo Ľui ai,  Ľae ngaahi ngata Ľanga kotoa pńď  Ľo mńĀmani:  
\q2 he ko au pe ko e  ĽOtua, pea  Ľoku  Ľikai mo ha taha.   
\q1
\v 23 Kuo u fuakava  Ľiate au pe,  
\q2 kuo  Ľalu atu  Ľae folofola  Ľi hoku fofonga  Ľi he mńĀ Ľoni Ľoni, pea  Ľe  Ľikai foki ia,  
\q1  ĽE peluki  Ľae tui kotoa pńď kiate au,  
\q2  Ľe fuakava mo e  Ľelelo kotoa pńď.   
\q1
\v 24 Ko e mo Ľoni,  
\q2  Ľe pehńď  Ľe ha tokotaha,  
\q2 ‚Äė ĽOku ou ma Ľu  Ľae mńĀ Ľoni Ľoni mo e mńĀlohi  Ľia Sihova:‚Äô‚ÄĚ  
\q1  Ľio,  Ľe ha Ľu kiate ia  Ľae kakai;  
\q2 pea ko kinautolu kotoa pńď  Ľoku  Ľita kiate ia  Ľe mńĀ.   
\q1
\v 25 ‚ÄĆ ĽE tonuhia  Ľia Sihova  Ľae hako kotoa pńď  Ľo  ĽIsileli,  
\q2 pea te nau vikiviki ai.   
\c 46  
\cd \it 1 Na Ľe  Ľikai fa Ľa fakamo Ľui  Ľakinautolu  Ľae ngaahi tamapua  Ľo Papilone. 3  ĽOku fakamo Ľui  Ľe he  ĽOtua  Ľa hono kakai  Ľo a Ľu ki he ngata Ľanga. 5  ĽOku  Ľikai tatau  Ľae ngaahi tamapua mo e mńĀlohi  Ľoe  ĽOtua, 12 Pe ki he fakamo Ľui ni.\it*  
\q1
\v 1 ‚ÄĆ ĽOku fo Ľohifo  Ľa Peli,  
\q2 pea tulolo  Ľa Nipo,  
\q1 na Ľe heka  Ľi he ngaahi manu  Ľae ngaahi tamapua,  
\q2 pea  Ľi he fanga pulu:  
\q1 na Ľe mńĀfasia ho Ľomou ngaahi saliote;  
\q2  Ľi hono fakaheka kuo ongosia ai  Ľae manu.   
\q1
\v 2 ‚ÄĆ ĽOku nau tulolo,  Ľoku nau punou fakataha;  
\q2 na Ľe  Ľikai te nau fa Ľa fua  Ľae kavenga,  
\q2 ka kuo hoko  Ľo pŇćpula  Ľakinautolu.   
\b  
\q1
\v 3 ‚ÄúFanongo kiate au,  Ľae fale  Ľo Sńďkope,  
\q2 pea mo hono toe kotoa pńď  Ľoe fale  Ľo  ĽIsileli,  
\q1  Ľaia na Ľaku fua mei he fatu,  
\q2  Ľaia  Ľoku fua mei he manńĀva.   
\q1
\v 4 Pea  Ľo a Ľu ki ho Ľo motu Ľa ko au ia;  
\q2 pea  Ľo a Ľu ki he  ĽuluhinńĀ te u fua koe:  
\q1 kuo u ngaohi, pea te u fua ia;  
\q2  Ľio, te u fua, pea te u fakamo Ľui.   
\b  
\q1
\v 5 ‚ÄúTe mou fakatatau au kia hai, pea te u tatau mo hai,  
\q2  Ľio te mou fakatatau au kia hai, koe Ľuhi ke mńĀ tatau mo ia?   
\q1
\v 6 ‚ÄĆ ĽOku laku  Ľae koula mei he kato,  
\q2 pea fakamamafa  Ľae siliva  Ľi he me Ľa fakatatau,  
\q1 pea fakakau  Ľae tufunga koula;  
\q2 pea  Ľoku ne ngaohi ia ko e  Ľotua:  
\q1  Ľoku nau punou hifo,  
\q2  Ľio,  Ľoku nau lotu.   
\q1
\v 7 ‚ÄĆ ĽOku nau fua ia  Ľi he uma,  
\q2  Ľoku nau hapahapai ia, pea fokotu Ľu ia  Ľi hono potu, pea  Ľoku ne tu Ľu;  
\q2 pea  Ľe  Ľikai te ne  Ľalu mei hono potu:  
\q1  Ľio,  Ľe kalanga ha tokotaha kiate ia, ka  Ľoku  Ľikai te ne tali,  
\q2 pe fakamo Ľui ia mei he Ľene tu ĽutńĀmaki.   
\b  
\q1
\v 8 ‚ÄúManatu Ľi  Ľae me Ľa ni, pea fakahńĀ ko e kau tangata  Ľakimoutolu:  
\q2 toe manatu ki ai,  Ľakimoutolu  Ľae kau angahala.   
\q1
\v 9 Manatu ki he ngaahi  Ľuluaki me Ľa  Ľi mu Ľa:  
\q2 he ko au ko e  ĽOtua, pea  Ľoku  Ľikai ha taha kehe;  
\q2 Ko au ko e  ĽOtua, pea  Ľoku  Ľikai ha tokotaha  Ľe tatau mo au,   
\q1
\v 10 Ke fakahńĀ  Ľae iku Ľanga mei he kamata Ľanga,  
\q2 pea mei he ngaahi kuonga  Ľi mu Ľa  Ľae ngaahi me Ľa  Ľoku te Ľeki ke fai,  
\q1  Ľo pehńď,  ĽE tu Ľuma Ľu  Ľeku tu Ľutu Ľuni,  
\q2 pea te u fai  Ľeku fa Ľiteliha kotoa pńď:   
\q1
\v 11 ‚ÄĆ ĽO ui  Ľae manupuna  Ľoku fekai mei he potu hahake,  
\q2  Ľae tangata  Ľoku ne fai ki he Ľeku fekau mei he fonua mama Ľo:  
\q1  Ľio, kuo u fakahńĀ ia,  
\q1 pea te u fakahoko ia;  
\q2 kuo u tu Ľutu Ľuni ki ai,  
\q2 pea te u fai ia.   
\q1
\v 12 Fanongo kiate au,  Ľakimoutolu  Ľoku loto mńĀlohi,  
\q2  Ľakimoutolu  Ľoku mama Ľo mo e mńĀ Ľoni Ľoni:   
\q1
\v 13 ‚ÄĆ ĽOku ou  Ľomi ke ofi  Ľeku mńĀ Ľoni Ľoni;  
\q2  Ľe  Ľikai mama Ľo ia,  
\q2 pea mo  Ľeku fakamo Ľui  Ľe  Ľikai tatali ia:  
\q1 pea te u tuku  Ľae fakamo Ľui  Ľi Saione,  
\q2 ma Ľa  ĽIsileli ko hoku nńĀunau.   
\b  
\c 47  
\cd \it 1 Ko e fakamaau  Ľae  ĽOtua ki Papilone mo Kalitia, 6 Koe Ľuhi ko  Ľenau ta Ľe Ľofa, 7 Mo e laukau, 10 Mo  Ľenau fakafe Ľiloaki, 11 Pea  Ľe  Ľikai fa Ľa ta Ľofi ia.\it*  
\q1
\v 1 ‚Äú ĽAlu hifo, pea nofo  Ľi he efuefu,  ĽE  Ľofefine tńĀupo Ľou  Ľo Papilone,  
\q2 nofo  Ľi he kelekele:  ĽE  Ľofefine  Ľoe kakai Kalitia,  
\q2  Ľoku  Ľikai ha nofo Ľanga faka Ľei Ľeiki:  Ľe  Ľikai toe ui koe ko e hoihoifua mo e ngalingali  Ľeiki.   
\q1
\v 2 To Ľo  Ľae ngaahi maka momosi, pea momosi  Ľae koane:  
\q2 to Ľo  Ľae pŇęlou  Ľo ho lou Ľulu, vete ho kofu tŇćtŇćlofa, to Ľo  Ľae  Ľufi Ľufi  Ľo ho va Ľe,  
\q2 a Ľa  Ľi he ngaahi vaitafe.   
\q1
\v 3 ‚ÄĆ ĽE to Ľo  Ľae  Ľufi Ľufi  Ľo ho Ľo telefua,  
\q2  Ľio,  Ľe hńĀ ho Ľo mńĀ:  
\q1 te u tautea,  
\q2  Ľe  Ľikai te u fakafetaulaki kiate koe  Ľo hangńď ko ha tangata.‚ÄĚ   
\q1
\v 4 Pea ko hotau huhu Ľi, ko hono huafa ko Sihova  Ľoe ngaahi kautau,  
\q2 ko e tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli.   
\q1
\v 5 ‚ÄúNofo fakalongo pńď koe, pea ke  Ľalu ki he fakapo Ľuli,  
\q2  ĽE  Ľofefine  Ľoe kakai Kalitia:  
\q1  Ľe  Ľikai toe ui koe,  
\q2 Ko e fefine Ľeiki  Ľoe ngaahi pule Ľanga.   
\b  
\q1
\v 6 Na Ľaku houhau ki hoku kakai,  
\q2 kuo u faka Ľuli hoku tofi Ľa,  
\q2 pea  Ľatu  Ľakinautolu ki ho nima:  
\q1 na Ľe  Ľikai te ke fakahńĀ hao kńĀtaki  Ľofa ki ai;  
\q2 kuo ke ai ke fakamamafa ho Ľo ha Ľamonga ki he kau mńĀtu Ľa.   
\b  
\q1
\v 7 Pea na Ľa ke pehńď, ‚ÄėTe u hoko ko e fefine Ľeiki  Ľo lauikuonga:‚Äô  
\q2 ko ia na Ľe  Ľikai te ke tokanga  Ľi ho loto ki he ngaahi me Ľa ni,  
\q2 pea na Ľe  Ľikai te ke manatu ki he iku Ľanga  Ľo ia.   
\q1
\v 8 ‚ÄúKo ia ke ke fanongo ki he me Ľa ni,  Ľa koe  Ľoku ke mo Ľulaloa ki he ngaahi me Ľa fakafiefia fakamaama,  
\q2  Ľoku ke nofo fakafiemńĀlie,  
\q1  Ľoku ke pehńď  Ľi ho loto,  
\q2 ‚ÄėKo au, pea  Ľoku  Ľikai ha taha mo au:  
\q2  Ľe  Ľikai te u nofo  Ľo hangńď ko e fefine kuo mate hono husepńĀniti,  
\q2 pea  Ľe  Ľikai te u  Ľilo Ľi  Ľae mole  Ľae fńĀnau:‚Äô   
\q1
\v 9 Ka ko e ongo me Ľa ni  Ľe ua  Ľe hoko kiate koe  Ľi he kemo,  Ľi ha  Ľaho pe taha,  
\q2  Ľae mole  Ľae fńĀnau, mo e mate  Ľo ho husepńĀniti:  
\q1  Ľe hoko ia  Ľo lahi kiate koe,  
\q2 koe Ľuhi ko hono lahi  Ľo ho Ľo fai kńĀkńĀ,  
\q2 pea koe Ľuhi ko hono lahi  Ľo ho Ľo fiemana.   
\q1
\v 10 He kuo ke fa Ľaki ki ho Ľo angakovi:  
\q2 kuo ke pehńď, ‚Äė ĽOku  Ľikai mamata  Ľe ha taha kiate au.‚Äô  
\q1 Ko ho Ľo poto mo ho Ľo  Ľilo, kuo na fakahala Ľi koe;  
\q2 pea kuo ke pehńď  Ľi ho loto, ‚ÄėKo au, pea  Ľoku  Ľikai ha taha mo au.‚Äô   
\q1
\v 11 Ko ia  Ľe hoko ai  Ľae kovi kiate koe.  
\q2 E  Ľikai te ke  Ľilo pe  Ľoku tupu mei fe ia.  
\q1 Pea  Ľe tŇć kiate koe  Ľae tautea;  
\q2  Ľe  Ľikai te ke fa Ľa ta Ľofi ia:  
\q1 pea  Ľe hoko fakafokifńĀ  Ľae faka Ľauha kiate koe,  
\q2  Ľaia  Ľe  Ľikai te ke  Ľilo.   
\b  
\q1
\v 12 ‚ÄúKe ke tu Ľu ni mo ho Ľo ngaahi ngńĀue kńĀkńĀ,  
\q2 pea mo hono lahi  Ľo ho Ľo ngaahi fiemana,  
\q2  Ľaia kuo ke ngńĀue ai talu ho Ľo kei si Ľi;  
\q1  Ľo kapau  Ľe  Ľaonga ia kiate koe,  
\q2  Ľo kapau te ke fa Ľa lava Ľi ia.   
\q1
\v 13 ‚ÄĆ ĽOku ke ongosia  Ľi hono tokolahi  Ľo ho Ľo kau fakahinohino.  
\q2 Tuku ke tu Ľu hake ni  Ľae kau kikite ki he langi, mo e kau sio fetu Ľu, mo e kau fakaila me Ľa mei he mńĀhina, pea fakamo Ľui koe mei he ngaahi me Ľa ni  Ľe hoko kiate koe.   
\q1
\v 14 Vakai, te nau hangńď ko e kau Ľi koane;  
\q2  Ľe tutu  Ľakinautolu  Ľi he afi;  
\q2  Ľe  Ľikai te nau fakamo Ľui  Ľakinautolu mei he mńĀlohi  Ľoe ulo:  
\q1  Ľe  Ľikai toe ha malala ke mumŇę ai,  
\q2 pe ha afi ke nofo ki ai.   
\q1
\v 15 ‚ÄĆ ĽE pehńď  Ľakinautolu kiate koe  Ľaia kuo mou ngńĀue mo ia,  
\q2  Ľio, ko ho Ľo kau fakatau, talu ho Ľo kei si Ľi: te nau afe taki taha ki hono potu;  
\q2  Ľe  Ľikai ha taha te ne fakamo Ľui koe.   
\b  
\c 48  
\cd \it 1 Na Ľe fakahńĀ  Ľe he  ĽOtua  Ľene ngaahi kikite ke faka Ľilo ki he kakai  Ľa  Ľenau angatu Ľu, na Ľa ne mu Ľaki  Ľafio Ľi. 9  ĽOku ne fakamo Ľui  Ľakinautolu koe Ľuhi ko  Ľene  Ľafio. 12  ĽOku ne enginaki ke nau talangofua koe Ľuhi ko hono mńĀlohi mo  Ľene pule Ľi. 16  ĽOka ne mamahi  Ľi he Ľenau fakatoupńękoi. 20  ĽOku ne fakamo Ľui hono kakai mei Papilone  Ľi he Ľene mńĀfimafi.\it*  
\q1
\v 1 ‚ÄúFanongo ki he me Ľa ni,  ĽE fale  Ľo Sńďkope,  
\q2  Ľa koe  Ľoku ui  Ľaki  Ľae hingoa  Ľo  ĽIsileli,  
\q2 pea kuo ha Ľu mei he ngaahi matavai  Ľo Siuta,  
\q1  Ľakimoutolu  Ľoku fuakava  Ľi he huafa  Ľo Sihova,  
\q2 pea lea ki he  ĽOtua  Ľo  ĽIsileli,  
\q2 ka  Ľoku  Ľikai  Ľi he mo Ľoni, pe  Ľi he mńĀ Ľoni Ľoni.   
\q1
\v 2 He  Ľoku nau lau  Ľoku nau  Ľoe kolo mńĀ Ľoni Ľoni,  
\q2 pea fa Ľaki  Ľakinautolu ki he  ĽOtua  Ľo  ĽIsileli;  
\q2 ko hono huafa ko Sihova  Ľoe ngaahi kautau.   
\q1
\v 3 Kuo u fakahńĀ  Ľae ngaahi me Ľa mu Ľa mei he kamata Ľanga;  
\q2 pea na Ľa nau  Ľalu atu mei hoku fofonga, pea ne u fakahńĀ ia;  
\q2 na Ľaku fai fakafokifńĀ ia, pea hoko ia.   
\q1
\v 4 Koe Ľuhi na Ľaku  Ľilo  Ľoku ke paongata Ľa,  
\q2 pea ko e uoua ukamea ho kia,  
\q2 pea palasa ho fo Ľi la Ľńď;   
\q1
\v 5 Kuo u fakahńĀ ia kiate koe mei he kamata Ľanga;  
\q2  Ľi he te Ľeki ai hoko ia na Ľaku fakahńĀ ia kiate koe:  
\q2 telia na Ľa ke pehńď, ‚ÄėKuo fai  Ľe he Ľeku tamapua,  Ľae ngaahi me Ľa ko ia, mo  Ľeku tamapua kuo tongi, mo  Ľeku tamapua kuo haka kuo fekau ki ai.‚Äô   
\q1
\v 6 Kuo ke tomu Ľa fanongo,  
\q2 pea vakai kuo hoko  Ľae me Ľa ni kotoa pńď;  
\q2 pea  Ľe  Ľikai te ke fakahńĀ ia?  
\b  
\q1 ‚ÄúKuo u fakahńĀ atu mei he kuonga ni,  Ľae ngaahi me Ľa fo Ľou,  
\q2  Ľio,  Ľae ngaahi me Ľa lilo, pea na Ľe  Ľikai te ke  Ľilo ki ai.   
\q1
\v 7 ‚ÄĆ ĽOku fakatupu ni ia, kae  Ľikai mei he kamata Ľanga;  
\q2  Ľio,  Ľi mu Ľaange  Ľi he  Ľaho  Ľaia na Ľe  Ľikai te ke fanongo ki ai,  
\q2 telia na Ľa ke pehńď, ‚ÄúVakai, na Ľaku  Ľilo ia.‚ÄĚ   
\q1
\v 8 Ko e mo Ľoni na Ľe  Ľikai te ke fanongo,  
\q2  Ľio, na Ľe  Ľikai te ke  Ľilo;  
\q2  Ľio, mei he kuonga ko ia na Ľe  Ľikai ke fakaava ho telinga:  
\q1 he na Ľaku  Ľilo te ke fai kńĀkńĀ lahi,  
\q2 pea na Ľe ui koe ko e maumau fono mei he manńĀva.   
\q1
\v 9 Koe Ľuhi ko hoku huafa te u ta Ľofi hoku houhau,  
\q2 pea koe Ľuhi ko  Ľeku ongoongolelei te u ta Ľofi au meiate koe,  
\q2 ke  Ľoua na Ľaku tu Ľusi  Ľaupito koe.   
\q1
\v 10 Vakai; kuo u fakama Ľa koe,  
\q2 kae  Ľikai  Ľaki  Ľae siliva;  
\q2 kuo u fili koe mei he afi  Ľoe mamahi.   
\q1
\v 11 Koe Ľuhi ko au,  
\q2  Ľio, koe Ľuhi ko au, te u fai ia:  
\q1 he ko e hńĀ  Ľe fakalielia ai  Ľa hoku huafa?  
\q2 Pea  Ľe  Ľikai te u foaki hoku nńĀunau ki ha tokotaha kehe.   
\q1
\v 12 ‚ÄúFanongo kiate au,  Ľe Sńďkope pea mo  ĽIsileli,  
\q2  Ľa koe kuo u ui;  
\q1 ko au ia;  
\q2 ko au ko e  Ľuluaki,  
\q2 pea ko au foki ko e kimui.   
\q1
\v 13 Kuo  Ľai  Ľe hoku nima  Ľae tu Ľunga  Ľo mńĀmani,  
\q2 pea kuo u hanga  Ľae ngaahi langi  Ľaki hoku nima to Ľomata Ľu:  
\q2  Ľo kau ka ui ki ai,  Ľoku nau tu Ľu hake fakataha.   
\q1
\v 14 ‚ÄúMou fakataha,  Ľakimoutolu kotoa pńď, pea fanongo;  
\q2 ko hai  Ľiate kinautolu kuo ne fakahńĀ  Ľae ngaahi me Ľa ui?  
\q1 Kuo  Ľofa  Ľa Sihova kiate ia: te ne fai  Ľene fa Ľiteliha ki Papilone,  
\q2 pea  Ľe  Ľi he kakai Kalitia  Ľa hono nima.   
\q1
\v 15 Ko au,  Ľio, ko au, kuo u folofola;  
\q2 kuo u ui kiate ia:  
\q1 kuo u  Ľomi ia,  
\q2 pea te ne ngaohi ke lelei hono hala.   
\q1
\v 16 ‚ÄúMou ha Ľu ke ofi kiate au, fanongo ki he me Ľa ni;  
\b  
\q1 ‚Äútalu  Ľae kamata Ľanga na Ľe  Ľikai te u lea  Ľi he lilo;  
\q2 talu  Ľae kuonga na Ľe  Ľi ai ia,  Ľoku  Ľi ai au.‚ÄĚ  
\b  
\q1 Pea ko e  ĽEiki ko Sihova,  
\q2 mo hono LaumńĀlie, kuo na fekau au.   
\b  
\q1
\v 17 ‚ÄĆ ĽOku pehńď  Ľe Sihova,  
\q2 ko ho Huhu Ľi,  
\q2 ko e tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli;  
\q1 ‚ÄúKo au ko Sihova ko ho  ĽOtua,  
\q2  Ľaia  Ľoku akonaki Ľi koe ke  Ľaonga,  
\q2 pea ko ia  Ľoku tataki koe  Ľi he hala  Ľoku totonu ke ke  Ľalu ai.   
\q1
\v 18 ‚ÄĆ ĽAmusiaange  Ľe au kuo ke tokanga ki he Ľeku ngaahi fekau!  
\q2 Ka ne pehńď kuo hangńď ko e vaitafe ho Ľo fiemńĀlie,  
\q2 pea tatau ho Ľo mńĀ Ľoni Ľoni mo e ngaahi peau  Ľoe tahi:   
\q1
\v 19 Pea ko ho hako foki kuo hangńď ko e  Ľone Ľone,  
\q2 pea ko e fua  Ľo ho manńĀva  Ľo hangńď ko e kilikili  Ľoe matńĀtahi;  
\q2 pea  Ľe  Ľikai tu Ľusi pe faka Ľauha hono hingoa mei hoku  Ľao.   
\q1
\v 20 ‚ÄĆ ĽAlu atu  Ľakimoutolu mei Papilone,  
\q2 mou hola mei he kakai Kalitia,  
\q1 mou fakahńĀ  Ľaki  Ľae lea  Ľoe hiva,  
\q2 tala  Ľae me Ľa ni, lea  Ľaki ia  Ľo a Ľu ki he ngata Ľanga  Ľo mńĀmani;  
\q2 mou pehńď, ‚ÄúKuo huhu Ľi  Ľe Sihova  Ľa  Ľene tamaio Ľeiki ko Sńďkope.‚ÄĚ   
\b  
\q1
\v 21 Pea na Ľe  Ľikai te nau masiva inu  Ľi he Ľene tataki  Ľakinautolu  Ľi he ngaahi toafa:  
\q2 na Ľa ne pule ke tafe atu  Ľae vai mei he maka ma Ľanautolu:  
\q2 na Ľa ne foa Ľi  Ľae maka, pea na Ľe mapuna mei ai  Ľae vai.   
\b  
\q1
\v 22 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚Äú Ľoku  Ľikai ha fiemńĀlie ki he kakai angahala.‚ÄĚ   
\c 49  
\cd \it 1  ĽI he fekau  Ľa Kalaisi ki he kakai Siu,  Ľoku ne lńĀunga kiate kinautolu. 5  ĽOku fekau ia mo e ngaahi tala Ľofa lelei ki he kakai Senitaile. 13  ĽOku ta Ľengata  Ľae  Ľofa  Ľae  ĽOtua ki hono siasi. 18 Ko e toe langa  Ľoe siasi ki hono mu Ľaki lelei. 24 Ko e fakamo Ľui lahi mei he nofo fakapŇćpula.\it*  
\q1
\v 1 Fanongo,  ĽE ngaahi motu, kiate au;  
\q2 pea fakafanongo,  Ľakimoutolu  Ľae kakai mei he mama Ľo;  
\q1 Kuo ui  Ľe Sihova kiate au mei he manńĀva;  
\q2 mei he fatu  Ľo  Ľeku fa Ľńď kuo ne lea  Ľaki hoku hingoa.   
\q1
\v 2 Pea kuo ne ngaohi hoku ngutu  Ľo hangńď ko e heletńĀ mńĀsila;  
\q2  Ľi he malumalu  Ľo hono nima kuo ne fufŇę au,  
\q1 pea ngaohi au ko e ngahau ngingila;  
\q2 kuo ne fakafufŇę au  Ľi hono  Ľai Ľanga ngahau;   
\q1
\v 3 Pea ne pehńď kiate au, ‚ÄúKo koe,  
\q2  ĽE  ĽIsileli, ko  Ľeku tamaio Ľeiki te u ongoongolelei  Ľiate koe.‚ÄĚ   
\q1
\v 4 Pea ne u pehńď, ‚ÄúKuo u ngńĀue ta Ľe Ľaonga:  
\q2 kuo u faka Ľosi noa pe  Ľeku mńĀlohi, pea ta Ľe Ľaonga:  
\q1 ka  Ľoku mo Ľoni  Ľoku  Ľia Sihova  Ľeku fakamaau,  
\q2 pea  Ľi hoku  ĽOtua  Ľa  Ľeku ngńĀue.‚ÄĚ   
\q1
\v 5 Pea ko eni,  Ľoku pehńď  Ľe Sihova  Ľaia na Ľa ne fakafuofua au mei he manńĀva ke hoko ko  Ľene tamaio Ľeiki,  
\q2 ke toe  Ľomi  Ľa Sńďkope kiate ia,  
\q2 Kapau  Ľe  Ľikai tńĀnaki  Ľa  ĽIsileli,  
\q2 ka te u ongoongolelei  Ľi he  Ľao  Ľo Sihova,  
\q2 pea  Ľe hoko  Ľa hoku  ĽOtua ko hoku mńĀlohi.   
\q1
\v 6 Pea na Ľa ne pehńď, ‚ÄúKo e me Ľa si Ľi ke ke hoko ko  Ľeku tamaio Ľeiki ke toe fokotu Ľu  Ľae ngaahi fa Ľahinga  Ľo Sńďkope,  
\q2 pea ke fakailiili  Ľae kakai  Ľo  ĽIsileli kuo fakahaofi:  
\q1 pea te u foaki foki koe ko e maama ki he kakai Senitaile,  
\q2 koe Ľuhi ke ke hoko ko hoku fakamo Ľui  Ľo a Ľu ki he ngata Ľanga  Ľo mńĀmani.‚ÄĚ   
\q1
\v 7 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ko e Huhu Ľi  Ľo  ĽIsileli, pea mo hono tokotaha mńĀ Ľoni Ľoni,  
\q2 kiate ia  Ľoku fehi Ľa ki ai  Ľae tangata, kiate ia  Ľoku fakalili Ľa ki ai  Ľae pule Ľanga, ki he tamaio Ľeiki  Ľae kau pule,  
\q1 ‚Äú ĽE mamata pea tu Ľu hake  Ľae ngaahi tu Ľi,  
\q2  Ľe lotu  Ľae ngaahi hou Ľeiki,  
\q2 koe Ľuhi ko Sihova  Ľaia  Ľoku angatonu, pea mo e tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli,  Ľaia kuo ne fili koe.‚ÄĚ   
\q1
\v 8 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚Äú ĽI he kuonga tu Ľutu ĽumńĀlie kuo u fanongo kiate koe,  
\q2 pea  Ľi he  Ľaho fakamo Ľui kuo u tokoni kiate koe:  
\q1 pea te u malu Ľi koe, pea foaki koe ko e fuakava  Ľoe kakai,  
\q2 ke fokotu Ľuma Ľu  Ľa mńĀmani, ke ngaohi ke toe kakai  Ľae ngaahi  Ľapi li Ľaki;   
\q1
\v 9 Koe Ľuhi ke ke pehńď ki he kau pŇćpula, ‚Äė ĽAlu atu;‚Äô  
\q2 kiate kinautolu  Ľoku  Ľi he po Ľuli, ‚ÄėFakahńĀ  Ľakimoutolu.‚Äô  
\q1 Te nau kai  Ľi he ngaahi hala,  
\q2 pea  Ľe  Ľi he ngaahi potu mńĀ Ľolunga kotoa pńď  Ľa  Ľenau me Ľakai.   
\q1
\v 10 ‚ÄĆ ĽE  Ľikai te nau fiekaia pe fieinu;  
\q2 pea  Ľe  Ľikai te Ľia  Ľakinautolu  Ľe he pupuha pe  Ľe he la ĽńĀ:  
\q2 he ko ia  Ľoku  Ľalo Ľofa kiate kinautolu te ne tataki  Ľakinautolu,  
\q2  Ľio, te ne fakahinohino  Ľakinautolu ki he ngaahi matavai.   
\q1
\v 11 Pea te u ngaohi hoku ngaahi mo Ľunga kotoa pńď ko e hala,  
\q2 pea  Ľe hakeaki Ľi  Ľa hoku ngaahi hala motu Ľa.   
\q1
\v 12 Vakai,  Ľe ha Ľu  Ľakinautolu mei he tokelau pea mei he lulunga;  
\q2 pea mo kinautolu ni mei he fonua ko Sinimi.   
\q1
\v 13 Hiva,  Ľae ngaahi langi; pea ke fiefia,  ĽE mńĀmani;  
\q2 pea ke pńĀ mai  Ľi he hiva,  Ľae ngaahi mo Ľunga:  
\q1 he kuo fakafiemńĀlie Ľi  Ľe Sihova  Ľa hono kakai,  
\q2 pea te ne  Ľalo Ľofa ki hono kakai mamahi.   
\q1
\v 14 Ka na Ľe pehńď  Ľe Saione, ‚ÄúKuo li Ľaki au  Ľe Sihova,  
\q2 pea kuo fakangalongalo Ľi au  Ľe hoku  ĽEiki.‚ÄĚ   
\q1
\v 15 ‚Äú ĽE fa Ľa fakangalongalo Ľi  Ľe ha fefine  Ľene tama  Ľoku huhu,  
\q2 ke ne ta Ľe Ľofa ai ki he tama  Ľa hono manńĀva?  
\q1  ĽIo, te nau fa Ľa fakangalo nai,  
\q2 ka e  Ľikai te u fakangalongalo Ľi koe.   
\q1
\v 16 Vakai, kuo u tohi tongi koe  Ľi hoku  Ľaofi nima;  
\q2  Ľoku  Ľi hoku  Ľao ma Ľuaipńď  Ľa ho Ľo ngaahi  ĽńĀ.   
\q1
\v 17 ‚ÄĆ ĽE fai vave ho Ľo fńĀnau;  
\q2 ko ho ngaahi fili pea mo kinautolu na Ľe fakamasiva Ľi koe te nau  Ľalu  Ľiate koe.   
\q1
\v 18 Hiki hake ho mata  Ľo sio takatakai, pea vakai:  
\q2 ko kinautolu kotoa pńď  Ľoku tńĀnaki fakataha  Ľakinautolu, ke ha Ľu kiate koe.  
\q1  ĽOku pehńď  Ľe Sihova, ‚Äú ĽOku ou mo Ľui, pea te ke fakakofu Ľi koe  Ľaki  Ľakinautolu kotoa pńď,  Ľo hangńď ko e me Ľa teunga,  
\q2 pea nono Ľo ia kiate koe,  Ľo hangńď ko ia  Ľoku fai  Ľe he ta Ľahine ta Ľane.   
\q1
\v 19 ‚ÄúHe ko ho ngaahi potu maumau mo ta Ľekakai,  
\q2 pea mo e fonua  Ľo ho Ľo faka Ľauha,  
\q1  Ľe hoko ni  Ľo lausi Ľi koe Ľuhi ko e kakai,  
\q2 pea ko kinautolu na Ľe folo hifo koe te nau mama Ľo atu.   
\q1
\v 20 Ko e fńĀnau te ke ma Ľu, hili  Ľae mole  Ľiate koe  Ľae taha, te nau pehńď  Ľi ho telinga,  
\q2 ‚Äė ĽOku si Ľi  Ľae potu ni kiate au:  
\q2 faka Ľata ĽatńĀ  Ľae potu ke u nofo ai.‚Äô   
\q1
\v 21 Pea te ke toki pehńď  Ľi ho loto, ‚ÄúKo hai kuo ne fakatupu kiate au  Ľakinautolu ni, kae vakai kuo mole  Ľiate au  Ľeku fńĀnau,  
\q2 pea  Ľoku ou masiva, ko e pŇćpula, mo e li Ľaki?  
\q1 Pea ko hai kuo ne tauhi  Ľakinautolu ni?  
\q2 Vakai, na Ľe li Ľaki au tokotaha pe; ko kinautolu ni, na Ľa nau  Ľi fńď?‚ÄĚ   
\q1
\v 22 ‚ÄĆ ĽOku pehńď  Ľe he  ĽEiki ko Sihova, ‚ÄúVakai, te u hiki hake hoku nima ki he kakai Senitaile,  
\q2 pea fokotu Ľu  Ľeku fuka ki he kakai:  
\q1 pea te nau  Ľomi ho ngaahi foha  Ľi honau nima,  
\q2 mo ho ngaahi  Ľofefine  Ľe fua  Ľi honau uma.   
\q1
\v 23 Pea  Ľe hoko  Ľae ngaahi tu Ľi ko ho Ľo ngaahi tamai ke tauhi fńĀnau,  
\q2 pea ko e ngaahi tu Ľi fefine ko ho Ľo ngaahi fale ke tauhi ho Ľo fńĀnau:  
\q1 te nau punou hifo kiate koe  Ľaki honau mata ki he kelekele,  
\q2 pea  Ľemo  Ľae efu  Ľo ho va Ľe;  
\q1 pea te ke  Ľilo ko au ko Sihova:  
\q2 pea  Ľe  Ľikai mńĀ  Ľakinautolu  Ľoku tatali  Ľiate au.‚ÄĚ   
\q1
\v 24 ‚ÄĆ ĽE to Ľo  Ľae koloa kuo vetea mei he mńĀlohi,  
\q2 pe tukuange  Ľae pŇćpula totonu?   
\q1
\v 25 Ka  Ľoku pehńď  Ľe Sihova, ‚Äú ĽIo ko e ngaahi pŇćpula  Ľoe kakai mńĀlohi  Ľe fa Ľao,  
\q2 pea  Ľe tuku atu  Ľae koloa kuo vete  Ľe he kakai fakamanavahńď:  
\q1 koe Ľuhi te u fai mo ia  Ľoku fai mo koe,  
\q2 pea te u fakamo Ľui ho Ľo fńĀnau.   
\q1
\v 26 Pea te u fafanga  Ľakinautolu  Ľoku fakamńĀlohi Ľi koe  Ľaki honau sino  Ľonautolu;  
\q2 pea te nau konńĀ  Ľi honau toto,  Ľo hangńď ha uaine fo Ľou:  
\q1 pea  Ľe  Ľilo  Ľe he kakai kotoa pńď, Ko au ko Sihova ko ho Fakamo Ľui,  
\q2 mo ho Huhu Ľi, ko e Toko Taha MńĀfimafi  Ľo Sńďkope.‚ÄĚ   
\c 50  
\cd \it 1  ĽOku fakahńĀ  Ľe Kalaisi ko e li Ľaki  Ľoe kakai Siu  Ľoku  Ľikai totonu ke tuku kiate ia. 2 Ko  Ľene fa Ľa fakamo Ľui. 5 Ko  Ľene talangofua  Ľi he ngńĀue ko ia, 7 Pea  Ľi he Ľene foaki ki he tokoni ko ia. 10 Ko e enginaki ke falala ki he  ĽOtua, kae  Ľikai kiate kitautolu.\it*  
\q1
\v 1 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚ÄúKofa ĽńĀ ia  Ľae tohi  Ľoe fakamavae  Ľo ho Ľo fa Ľńď,  Ľaia kuo u tukuange?  
\q2 Pea ko hai  Ľiate kimoutolu na Ľe totonu ke u totongi ki ai kuo u fakatau  Ľakimoutolu ki ai?  
\q1 Vakai, ko e me Ľa  Ľi ho Ľomou ngaahi hia kuo mou fakatau  Ľakimoutolu,  
\q2 pea ko e me Ľa  Ľi ho Ľomou ngaahi angahala ko ia kuo tukuange ai ho Ľomou fa Ľńď.   
\q1
\v 2 Ko e hńĀ,  Ľi he Ľeku ha Ľu, na Ľe  Ľikai ai ha tangata?  
\q2  ĽI he Ľeku ui, na Ľe  Ľikai ha taha ke lea mai?  
\q1 He kuo fakanounou hoku nima, koe Ľuhi ke  Ľoua na Ľa fa Ľa huhu Ľi ia?  
\q2 Pe  Ľoku  Ľikai haku mńĀlohi ke fakamo Ľui?  
\q1 Vakai,  Ľi he Ľeku valoki  Ľoku ou fakamŇćmoa  Ľae tahi,  
\q2  Ľoku ou liliu  Ľae ngaahi vaitafe ko e toafa:  
\q2 kuo namua Ľa  Ľenau ngaahi ika, pea mate  Ľi he fieinu koe Ľuhi  Ľoku  Ľikai ha vai.   
\q1
\v 3 ‚ÄĆ ĽOku ou fakakofu Ľaki  Ľae langi  Ľae fakapo Ľuli,  
\q2 pea  Ľoku ou ngaohi  Ľae tauanga Ľa ko honau kofu.‚ÄĚ   
\q1
\v 4 Kuo foaki kiate au  Ľe he  ĽEiki ko Sihova  Ľae  Ľelelo  Ľoe poto,  
\q2 koe Ľuhi ke u  Ľilo ke lea  Ľaki ha lea  Ľi he kuonga totonu kiate ia  Ľoku vaivai:  
\q1  Ľoku ne  Ľa  Ľi he pongipongi kotoa pńď,  
\q2 ke ne fafangu hoku telinga ke ongo Ľi  Ľo hangńď ko e poto.   
\q1
\v 5 Kuo fakaava  Ľe he  ĽEiki ko Sihova  Ľa hoku telinga,  
\q2 pea na Ľe  Ľikai te u angatu Ľu,  
\q2 pe foki kimui.   
\q1
\v 6 Ne u  Ľatu hoku tu Ľa ki he kau taa Ľi,  
\q2 pea mo hoku kou Ľahe kiate kinautolu na Ľe fusi  Ľae kava:  
\q2 na Ľe  Ľikai te u fufŇę hoku mata mei he mńĀ mo e  Ľa Ľanu.   
\q1
\v 7 He ko e  ĽEiki ko Sihova ko hoku tokoni;  
\q2 ko ia  Ľe  Ľikai ai te u puputu Ľu:  
\q1 ko ia kuo u ngaohi hoku mata ke hangńď ko e maka afi,  
\q2 pea  Ľoku ou  Ľilo  Ľe  Ľikai te u mńĀ.   
\q1
\v 8 ‚ÄĆ ĽOku ofi mai  Ľaia  Ľoku ne fakatonuhia Ľi au;  
\q2 ko hai te ne fai mo au?  
\q1 Ke ma tutu Ľu fakataha:  
\q2 ko hai  Ľoku fakafili kiate au?  
\q2 Tuku ke ne  Ľunu Ľunu mai.   
\q1
\v 9 Vakai,  Ľe tokoni Ľi au  Ľe he  ĽEiki ko Sihova;  
\q2 ko hai ia te ne fakahalaia au?  
\q1 Vakai, te nau hoko  Ľo motu Ľa  Ľo hangńď ko e kofu;  
\q2  Ľe kai  Ľo  Ľosi  Ľakinautolu  Ľe he ane.   
\q1
\v 10 Ko hai  Ľiate kimoutolu  Ľoku manavahńď kia Sihova,  
\q2 pea talangofua ki he le Ľo  Ľo  Ľene tamaio Ľeiki,  
\q1  Ľoku  Ľeve Ľeva  Ľi he po Ľuli,  
\q2 pea  Ľoku  Ľikai ma Ľu ha maama?  
\q1 Tuku ke ne falala ki he huafa  Ľo Sihova,  
\q2 pea fa Ľaki ki hono  ĽOtua.   
\q1
\v 11 Vakai,  Ľakimoutolu kotoa pńď  Ľoku tutu  Ľae afi,  
\q2 pea kńĀpui  Ľakimoutolu  Ľaki  Ľae ngaahi kalofiama:  
\q1 mou  Ľeve Ľeva  Ľi he maama  Ľo ho Ľomou afi,  
\q2 pea  Ľi he ngaahi kalofiama kuo mou tutu,  
\q1 ka te mou ma Ľu eni  Ľi hoku nima;  
\q1 te mou tokoto hifo  Ľi he mamahi.   
\c 51  
\cd \it 1 Ko e enginaki, ke falala kia Sisu  Ľo hangńď ko  ĽEpalahame, 3 Koe Ľuhi ko  Ľene ngaahi tala Ľofa lelei, 4 Mo  Ľene fakamo Ľui mńĀ Ľoni Ľoni, 7 Mo e matengofua  Ľae tangata. 9  ĽOku fakahaofi  Ľe Kalaisi  Ľaki hono nima mńĀ Ľoni Ľoni  Ľa hono kakai mei he manavahńď ki he tangata. 17  ĽOku ne mamahi  Ľi he ngaahi mamahi  Ľa SelŇęsalema, 21 Pea  Ľoku ne faka Ľilo  Ľae fakamo Ľui.\it*  
\q1
\v 1 ‚ÄúFanongo kiate au,  Ľakimoutolu  Ľoku muimui ki he mńĀ Ľoni Ľoni,  
\q2  Ľakimoutolu  Ľoku kumi kia Sihova:  
\q1 vakai ki he maka na Ľe tńĀ mei ai  Ľakimoutolu,  
\q2 pea ki he ava  Ľoe luo na Ľe keli  Ľakimoutolu mei ai.   
\q1
\v 2 Vakai kia  ĽEpalahame ko ho Ľomou tamai,  
\q2 pea kia Sela na Ľa ne fua  Ľakimoutolu:  
\q1 he na Ľaku ui ia tokotaha pe,  
\q2 pea tńĀpuaki ia,  
\q2 pea u fakatokolahi ia.   
\q1
\v 3 Koe Ľuhi  Ľe fakafiemńĀlie Ľi  Ľe Sihova  Ľi Saione:  
\q2 te ne fakafiemńĀlie Ľi hono ngaahi potu lala kotoa pńď;  
\q2 pea te ne ngaohi hono toafa ke hangńď ko Iteni,  
\q2 pea ko hono potu li Ľaki  Ľo hangńď ko e ngoue  Ľa Sihova;  
\q1  Ľe  Ľilo  Ľi ai  Ľae fiefia mo e nekeneka,  
\q2 ko e fakafeta Ľi, pea mo e le Ľo  Ľoe Saame.   
\b  
\q1
\v 4 ‚ÄúFanongo kiate au,  Ľa hoku kakai,  
\q2 pea tokanga kiate au,  Ľa hoku pule Ľanga:  
\q1 koe Ľuhi  Ľe  Ľalu atu  Ľiate au ha fono,  
\q2 pea te u ngaohi  Ľeku fakamaau ke nofo ko e maama  Ľoe kakai.   
\q1
\v 5 ‚ÄĆ ĽOku ofi  Ľeku mńĀ Ľoni Ľoni;  
\q2 kuo  Ľalu atu  Ľeku fakamo Ľui,  
\q2 pea  Ľe fakamaau  Ľe hoku nima  Ľae kakai;  
\q1  Ľe tatali kiate au  Ľae ngaahi motu,  
\q2 pea te nau falala ki hoku nima.   
\q1
\v 6 Hiki hake homou mata ki he ngaahi langi,  
\q2 pea sio ki he mńĀmani  Ľi lalo:  
\q1 koe Ľuhi  Ľe mole fakafokifńĀ  Ľae ngaahi langi  Ľo hangńď ko e  Ľohuafi,  
\q2 pea  Ľe faka Ľau  Ľo motu Ľa  Ľa mńĀmani  Ľo hangńď ko e kofu,  
\q2 pea  Ľe mate foki mo kinautolu  Ľoku nofo ai:  
\q1 ka  Ľoku tolonga ta Ľengata  Ľa  Ľeku fakamo Ľui,  
\q2 pea  Ľe  Ľikai ngata  Ľeku mńĀ Ľoni Ľoni.   
\b  
\q1
\v 7 ‚ÄúFanongo kiate au,  Ľakimoutolu  Ľoku  Ľilo  Ľae mńĀ Ľoni Ľoni,  
\q2  Ľae kakai  Ľoku  Ľi honau loto  Ľa  Ľeku fono;  
\q1  Ľoua te mou manavahńď ki he valoki  Ľae kakai,  
\q2 pea  Ľoua te mou ilifia  Ľi he Ľenau lau Ľikovi.   
\q1
\v 8 Koe Ľuhi  Ľe kai  Ľo  Ľosi  Ľakinautolu  Ľe he ane  Ľo hangńď ko e kofu,  
\q2 pea  Ľe kai  Ľakinautolu  Ľe he  Ľuanga  Ľo hangńď ko e fulufulu Ľi sipi:  
\q1 ka  Ľoku tolonga ta Ľengata  Ľa  Ľeku mńĀ Ľoni Ľoni,  
\q2 pea ko  Ľeku fakamo Ľui mei he to Ľutangata ki he to Ľutangata.‚ÄĚ   
\b  
\q1
\v 9 Ke ke  ĽńĀ, ke ke  ĽńĀ,  Ľai  Ľae mńĀlohi,  ĽE nima  Ľo Sihova;  
\q2 ke ke  ĽńĀ,  Ľo hangńď ko e ngaahi  Ľaho  Ľi mu Ľa,  
\q2  Ľi he ngaahi to Ľutangata  Ľi mu Ľa.  
\q1  ĽIkai ko koe ia na Ľe tu Ľusi  Ľa Lehapi,  
\q2 pea na Ľe taa Ľi  Ľae talńĀkoni?   
\q1
\v 10 ‚ÄĆ ĽIkai ko koe ia kuo ke fakamŇćmoa  Ľae tahi,  
\q2  Ľae ngaahi vai  Ľoe fu Ľu moana;  
\q2  Ľa koe kuo ngaohi  Ľae ngaahi loloto  Ľoe tahi koe hala ke  Ľalu ai  Ľae kakai kuo huhu Ľi?   
\q1
\v 11 Ko ia,  Ľe toe foki mai  Ľae kakai kuo huhu Ľi  Ľe Sihova,  
\q2 pea ha Ľu mo e hiva ki Saione;  
\q2 pea  Ľe  Ľi honau  Ľulu  Ľae fiefia  Ľo ta Ľengata:  
\q1 te nau ma Ľu  Ľae fiefia mo e nekeneka;  
\q2 pea  Ľe puna atu  Ľae mamahi mo e tangi.   
\b  
\q1
\v 12 ‚ÄúKo au,  Ľio, ko au ia,  Ľoku fakafiemńĀlie Ľi koe:  
\q2 ko hai koe, ke ke manavahńď ki ha tangata  Ľaia  Ľe mate,  
\q2 pea ki he foha  Ľoe tangata  Ľaia  Ľe ngaohi  Ľo hangńď ko e mohuku;   
\q1
\v 13 Pea  Ľoku ke fakangalongalo Ľi  Ľa Sihova ko ho tupu Ľanga,  
\q2  Ľaia kuo ne fofola  Ľae ngaahi langi,  
\q2 pea ai mo e ngaahi tu Ľunga  Ľo mńĀmani;  
\q1 pea kuo ke manavahńď ma Ľuaipńď  Ľi he  Ľaho kotoa pńď koe Ľuhi ko e  Ľita  Ľo ia  Ľoku fakamńĀlohi,  
\q2  Ľo hangńď  Ľoku ne te u ke faka Ľauha?  
\q2 Pea kofa ĽńĀ ia  Ľae lili  Ľoe fakamńĀlohi?   
\q1
\v 14 ‚ÄĆ ĽOku lele to Ľoto Ľo  Ľae pŇćpula ke vete ia,  
\q2 pea ke  Ľoua na Ľa mate ia  Ľi he luo,  
\q2 pea ke  Ľoua na Ľa  Ľosi  Ľene mńĀ.   
\q1
\v 15 Ka ko au ko Sihova ko ho  ĽOtua, na Ľaku vaeua  Ľae tahi,  
\q2  Ľaia na Ľe  Ľu Ľulu hono peau:  
\q2 ko hono huafa ko Sihova  Ľoe ngaahi kautau.   
\q1
\v 16 Pea kuo u  Ľai  Ľeku ngaahi lea ki ho ngutu,  
\q2 pea kuo u fufŇę koe  Ľaki  Ľae malumalu  Ľo hoku nima,  
\q1 koe Ľuhi ke u tŇć  Ľae ngaahi langi,  
\q2 pea  Ľai mo e ngaahi tu Ľunga  Ľo mńĀmani,  
\q2 pea pehńď ki Saione, Ko koe ko hoku kakai.‚Äô‚ÄĚ   
\b  
\q1
\v 17 Ke ke  ĽńĀ, ke ke  ĽńĀ,  
\q2 Tu Ľu hake,  ĽE SelŇęsalema,  
\q2  Ľa koe kuo inu  Ľi he nima  Ľo Sihova  Ľae ipu  Ľo hono houhau;  
\q1 kuo ke inu  Ľae efe  Ľoe ipu  Ľoe tetetete,  
\q2 pea tatau ia.   
\q1
\v 18 ‚ÄĆ ĽOku  Ľikai ha taha ke fakahinohino ia  Ľi he ngaahi foha kotoa pńď kuo ne fanau Ľi;  
\q2 pea  Ľoku  Ľikai ha ni Ľihi  Ľoku puke ki hono nima  Ľi he ngaahi foha kotoa pńď kuo ne tauhi.   
\q1
\v 19 Kuo hoko  Ľae me Ľa ni  Ľe ua kiate koe;  
\q2 ko hai  Ľe mamahi koe Ľuhi ko koe?  
\q1 Ko e maumau,  
\q2 mo faka Ľauha,  
\q2 mo e honge, mo e heletńĀ:  
\q2 te u fakafiemńĀlie Ľi koe  Ľia hai?   
\q1
\v 20 Kuo pongia ho Ľo ngaahi foha,  
\q2  Ľoku nau tokoto  Ľi he  Ľulu  Ľoe ngaahi hala kotoa pńď,  
\q2  Ľo hangńď ko e pulu tangata  Ľoku hehengi  Ľi he kupenga:  
\q1  Ľoku nau fonu  Ľi he houhau  Ľo Sihova,  
\q2 mo e valoki mei ho  ĽOtua.   
\q1
\v 21 Ko ia fanongo ki he me Ľa ni,  Ľa koe ko e mahaki,  
\q2 mo e konńĀ, kae  Ľikai  Ľi he uaine:   
\q1
\v 22 ‚ÄĆ ĽOku pehńď ho  ĽEiki ko Sihova,  
\q2 pea ko ho  ĽOtua  Ľoku langomaki Ľi  Ľa hono kakai,  
\q1 ‚ÄúVakai, kuo u to Ľo mei ho nima  Ľae ipu  Ľoe tetetete,  
\q2  Ľio,  Ľae efe  Ľoe ipu  Ľo hoku houhau;  
\q2  Ľe  Ľikai te ke toe inu ia;   
\q1
\v 23 Ka te u  Ľai ia ki he nima  Ľonautolu  Ľoku fakamamahi Ľi koe;  
\q2  Ľakinautolu kuo pehńď ki ho laumńĀlie, ‚ÄėPunou hifo, ka mau laka atu:‚Äô  
\q2 pea kuo ke fakatokoto ho sino  Ľo hangńď ko e kelekele,  
\q2 pea hangńď ko e hala, kiate kinautolu na Ľe  Ľalu ai.‚ÄĚ   
\c 52  
\cd \it 1  ĽOku fakaloto Ľi  Ľe Kalaisi  Ľae siasi ke tui ki hono huhu Ľi lahi. 7 Ke ma Ľu  Ľae kau faifekau  Ľo ia. 9 Ke fiefia  Ľi hono mńĀlohi  Ľo ia, 11 Pea ke fakahaofi  Ľakinautolu mei he fakapŇćpula. 13  ĽE hakeaki Ľi  Ľae pule Ľanga  Ľo Kalaisi.\it*  
\q1
\v 1 Ke ke  ĽńĀ, ke ke  ĽńĀ;  Ľai ho mńĀlohi,  ĽE Saione;  
\q2  Ľai ho ngaahi kofu matamatalelei,  ĽE SelŇęsalema,  Ľae kolo mńĀ Ľoni Ľoni:  
\q2 koe Ľuhi  Ľe  Ľikai toe hŇę kiate koe  Ľae ta Ľekamu mo e ta Ľema Ľa.   
\q1
\v 2 Tupe Ľi koe mei he efu;  
\q2 tu Ľu hake, pea nofo hifo,  ĽE SelŇęsalema:  
\q2 vete koe mei he ngaahi ha Ľi  Ľo ho kia,  ĽE  Ľofefine pŇćpula  Ľo Saione.   
\q1
\v 3 He  Ľoku pehńď  Ľe Sihova, ‚ÄúKuo mou fakatau  Ľakimoutolu ta Ľehatotongi;  
\q2 pea  Ľe huhu Ľi  Ľakimoutolu ta Ľehapa Ľanga.   
\b  
\q1
\v 4 He  Ľoku pehńď  Ľe he  ĽEiki ko Sihova,  
\q1 ‚ÄúNa Ľe  Ľalu hifo  Ľi mu Ľa  Ľa hoku kakai ki  ĽIsipite ke nofo ai;  
\q2 pea na Ľe fakamńĀlohi Ľi ta Ľetotonu  Ľakinautolu  Ľe he kakai  ĽAsilia.   
\b  
\q1
\v 5 ‚ÄúPea ko eni,‚ÄĚ  Ľoku pehńď  Ľe Sihova, ‚ÄúKo e hńĀ  Ľoku ou ma Ľu ni,  
\q2 koe Ľuhi  Ľoku  Ľave ta Ľehano Ľuhinga  Ľa hoku kakai?  
\q1 Ko kinautolu  Ľoku pule kiate kinautolu  Ľoku nau fakaioho mamahi  Ľakinautolu,  Ľoku pehńď  Ľe Sihova,  
\q2 pea  Ľoku kapea ma Ľu pe  Ľi he  Ľaho kotoa pńď  Ľa hoku huafa.   
\q1
\v 6 Ko ia  Ľe  Ľilo ai  Ľa hoku huafa  Ľe hoku kakai:  
\q2 Pea te nau  Ľilo  Ľi he  Ľaho ko ia, Ko au ia  Ľoku folofola.  
\q2 ‚ÄúVakai, ko au ia.   
\b  
\q1
\v 7 Hono  Ľikai faka Ľofo Ľofa  Ľi he ngaahi mo Ľunga  Ľae va Ľe  Ľo ia  Ľoku  Ľomi  Ľae ongoongolelei,  
\q2  Ľaia  Ľoku fakahńĀ  Ľae melino;  
\q2  Ľaia  Ľoku  Ľomi  Ľae ongoongolelei  Ľoe lelei,  
\q2 mo ne fakahńĀ  Ľae fakamo Ľui;  
\q2  Ľaia  Ľoku pehńď ki Saione, ‚Äú ĽOku pule  Ľa ho  ĽOtua!‚ÄĚ   
\q1
\v 8 ‚ÄĆ ĽE hiki hake  Ľae le Ľo  Ľo ho kau tangata le Ľo;  
\q2 pea  Ľe fakataha honau le Ľo  Ľonau hiva:  
\q2 he te nau mamata ko e mata ki he mata,  Ľoka toe  Ľomi  Ľe Sihova  Ľa Saione.   
\q1
\v 9 Ke hńĀ mai  Ľi he fiefia,  
\q2 hiva fakataha,  Ľakimoutolu  Ľae ngaahi potu lala  Ľo SelŇęsalema,  
\q2 he kuo fakafiemńĀlie Ľi  Ľe Sihova  Ľa hono kakai,  
\q2 kuo ne huhu Ľi  Ľa SelŇęsalema.   
\q1
\v 10 Kuo fakahńĀ  Ľe Sihova  Ľa hono nima  Ľi he  Ľao  Ľoe ngaahi pule Ľanga kotoa pńď;  
\q2 pea  Ľe mamata  Ľe he ngaahi ngata Ľanga kotoa pńď  Ľo mńĀmani  Ľae fakamo Ľui  Ľa hotau  ĽOtua.   
\b  
\q1
\v 11 ‚ÄĆ ĽAlu  Ľakimoutolu,  Ľalu  Ľakimoutolu, mou  Ľalu atu mei ai,  Ľoua  Ľe ala ki ha me Ľa ta Ľema Ľa;  
\q2  Ľalu  Ľakimoutolu mei he lotolotonga  Ľo ia;  
\q2 ke ma Ľa  Ľakimoutolu  Ľoku mou fua  Ľae ngaahi ipu  Ľa Sihova.   
\q1
\v 12 Koe Ľuhi  Ľe  Ľikai te mou  Ľalu atu fakavave,  
\q2 pe  Ľalu  Ľi he hola:  
\q1 he ko Sihova  Ľe mu Ľomu Ľa  Ľiate kimoutolu;  
\q2 pea ko e  ĽOtua  Ľo  ĽIsileli  Ľe muimui  Ľiate kimoutolu.   
\b  
\q1
\v 13 Vakai,  Ľe fai fakapotopoto  Ľa  Ľeku tamaio Ľeiki,  
\q2  Ľe hakeaki Ľi ia pea fakaongolelei,  
\q2 pea te ne mńĀ Ľolunga  Ľaupito.   
\q1
\v 14 ‚ÄĆ ĽO hangńď na Ľe ofo  Ľae tokolahi kiate ia,  
\q2 he liliu  Ľo kovi hono fofonga  Ľo lahi hake  Ľi he tangata kotoa pńď, mo hono sino  Ľo lahi hake  Ľi he ngaahi foha  Ľoe tangata.   
\q1
\v 15 Ko ia te ne taufu Ľi  Ľae ngaahi pule Ľanga lahi;  
\q2  Ľe tńĀpuni  Ľe he ngaahi tu Ľi honau fofonga kiate ia:  
\q2 he ko ia na Ľe  Ľikai fakahńĀ kiate kinautolu te nau mamata ki ai;  
\q2 pea ko ia na Ľe  Ľikai te nau fanongo ki ai te nau tokanga Ľi.   
\c 53  
\cd \it 1‚Äď12  ĽI he lńĀunga  Ľae palŇćfita ki he ta Ľetui,  Ľoku ne fakahńĀ  Ľae ngaahi mamahi  Ľo Kalaisi pea mo hono mahu Ľinga  Ľo ia.\it*  
\q1
\v 1 Ko hai kuo ne tui ki he  Ľemau ongoongo?  
\q2 Pea kuo fakahńĀ kia hai  Ľae nima  Ľo Sihova?   
\q1
\v 2 He te ne tupu hake  Ľi hono  Ľao  Ľo hangńď ko e  Ľakau matengofua,  
\q2 pea hangńď ko e aka mei he kelekele mŇćmoa:  
\q1  Ľoku  Ľikai ha sino lelei pe ha toulekeleka  Ľiate ia,  
\q2 pea ka tau ka mamata kiate ia,  Ľoku  Ľikai ha faka Ľofo Ľofa ke tau manako ai kiate ia.   
\q1
\v 3 ‚ÄĆ ĽOku fehi Ľanekina ia pea li Ľaki  Ľe he tangata;  
\q2 ko e tangata  Ľoe ngaahi mamahi,  
\q1 pea maheni ai mo e loto mamahi:  
\q2 pea hangńď na Ľa tau fufŇę hotau mata meiate ia;  
\q1 kuo manuki ia,  
\q2 pea na Ľe  Ľikai te tau tokanga kiate ia.   
\q1
\v 4 Ko e mo Ľoni kuo ne to Ľo kiate ia  Ľa  Ľetau ngaahi vaivai,  
\q2  Ľo ne fua  Ľetau ngaahi mamahi:  
\q1 ka na Ľa tau mahalo kuo tautea mo taa Ľi ia mei he  ĽOtua,  
\q2 pea mamahi Ľia.   
\q1
\v 5 Ka na Ľe lavea ia koe Ľuhi ko  Ľetau ngaahi angahala,  
\q2 na Ľe fakavolu ia koe Ľuhi ko  Ľetau ngaahi hia:  
\q1 na Ľe  Ľiate ia  Ľae tautea koe Ľuhi ke tau fiemńĀlie;  
\q2 pea  Ľi hono ngaahi tńĀ  Ľoku tau mo Ľui ai.   
\q1
\v 6 Kuo tau hńď kotoa pńď  Ľo hangńď ko e fanga sipi;  
\q2 kuo tau afe taki taha kotoa pńď ki hono hala;  
\q2 pea kuo hilifaki kiate ia  Ľe Sihova  Ľae hia  Ľatautolu kotoa pńď.   
\q1
\v 7 Na Ľe fakamńĀlohia,  
\q2 pea na Ľe mamahi ia, ka na Ľe  Ľikai te ne mafa Ľa hono fofonga:  
\q1  Ľoku tataki ia  Ľo hangńď ko e lami ke tńĀmate Ľi,  
\q2 pea hangńď ko e sipi  Ľoku noa  Ľi he  Ľao  Ľoe tangata kosi,  
\q2 pea na Ľe  Ľikai mafa Ľa hono fofonga.   
\q1
\v 8 Na Ľe  Ľave ia mei he fale fakapŇćpula, pea mei he fakamaau:  
\q2 pea ko hai te ne fakahńĀ hono tupu Ľanga?  
\q2 He na Ľe tu Ľusi ia mei he fonua  Ľoe mo Ľui:  
\q2 na Ľe te Ľia ia koe Ľuhi ko e angahala  Ľa hoku kakai.   
\q1
\v 9 Pea na Ľe tu Ľutu Ľuni hono tanu Ľanga mo e kakai angahala,  
\q2 pea fakataha mo e ma Ľume Ľa  Ľi he Ľene pekia;  
\q1 koe Ľuhi na Ľe  Ľikai te ne fai kovi,  
\q2 pea na Ľe  Ľikai ha kńĀkńĀ  Ľi hono fofonga.   
\b  
\q1
\v 10 Ka na Ľe finangalo  Ľa Sihova ke fakavolu ia;  
\q2 kuo ne tuku kiate ia  Ľae mamahi:  
\q1  Ľoka ke ka ngaohi hono laumńĀlie ko e feilaulau koe Ľuhi ko e hia,  
\q2 te ne mamata ki hono hako,  
\q1 te ne fakatolotolonga hono ngaahi  Ľaho,  
\q2 pea ko e finangalo  Ľo Sihova  Ľe monŇę Ľia ia  Ľi hono nima.   
\q1
\v 11 He te ne vakai ki he fua  Ľoe mamahi lahi  Ľo hono laumńĀlie,  
\q2 pea fiemńĀlie ai ia:  
\q1  Ľi he  Ľilo kiate ia  Ľe fakatonuhia  Ľe he Ľeku tamaio Ľeiki mńĀ Ľoni Ľoni  Ľae tokolahi;  
\q2 he te ne fua  Ľenau ngaahi hia.   
\q1
\v 12 Ko ia te u vahe Ľi kiate ia ha  Ľinasi fakataha mo e kakai ongoongo,  
\q2 pea te ne vahevahe  Ľae koloa fakataha mo e kakai mńĀlohi;  
\q1 koe Ľuhi na Ľa ne lilingi hono laumńĀlie ki he mate:  
\q2 pea na Ľe lau ia fakataha mo e kau angahala;  
\q1 pea na Ľa ne fua  Ľae hia  Ľoe toko lahi,  
\q2 pea ne hŇęfekina  Ľae kakai angahala.   
\c 54  
\cd \it 1 Koe Ľuhi ke fiemńĀlie  Ľae Senitaile,  Ľoku kikite  Ľae palŇćfita ki hono lahi  Ľoe siasi, 4 Mo  Ľenau nofo malu, 6 Mo e mo Ľoni  Ľo  Ľenau hao mei he mamahi, 11 Mo  Ľenau tupu ki mu Ľa, 15 Mo honau fakahaofi mo Ľoni.\it*  
\q1
\v 1 ‚ÄúHiva,  Ľae pa Ľa,  Ľa koe na Ľe  Ľikai te ke fńĀnau;  
\q2 ke ke hiva, pea kalanga le Ľo lahi,  Ľa koe na Ľe  Ľikai te ke langńĀ  Ľi ha tamasi Ľi:‚ÄĚ  
\q2 he  Ľoku pehńď  Ľe Sihova, ‚Äú ĽOku tokolahi hake  Ľae fńĀnau  Ľae li Ľaki  Ľi he fńĀnau  Ľoe fefine kuo mali.   
\q1
\v 2 Fakalahi  Ľae potu  Ľo ho fale fehikitaki,  
\q2 pea tuku ke nau fofola  Ľae puipui  Ľo ho ngaahi nofo Ľanga:  
\q2  Ľoua  Ľe ta Ľofi, fakalŇćloa ho Ľo ngaahi afo, pea tutuki ke ma Ľu ho Ľo ngaahi tuki poupou;   
\q1
\v 3 He te ke  Ľalu atu ki he nima to Ľomata Ľu, pea ki he to Ľohema;  
\q2 pea  Ľe ma Ľu  Ľa ho hako  Ľae ngaahi Senitaile,  
\q2 pea  Ľe fakakakai  Ľae ngaahi kolo na Ľe lala.   
\b  
\q1
\v 4 ‚Äú ĽOua  Ľe manavahńď; koe Ľuhi  Ľe  Ľikai te ke mńĀ:  
\q2 pea  Ľoua na Ľa ke puputu Ľu koe Ľuhi  Ľe  Ľikai fakamaa Ľi koe:  
\q1 he te ke fakangalo Ľi  Ľae mńĀ  Ľo ho Ľo kei talavou,  
\q2 pea  Ľe  Ľikai te ke toe manatu ki he valoki  Ľo ho Ľo nofo taka pe  Ľi he mate ho husepńĀniti.   
\q1
\v 5 He ko ho Tupu Ľanga kuo fakamaau mo koe; ko Sihova  Ľoe ngaahi kautau ko hono huafa ia;  
\q2 pea ko ho Huhu Ľi ko e tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli;  
\q2  Ľe ui ia ko e  ĽOtua  Ľo mńĀmani kotoa pńď.   
\q1
\v 6 He kuo ui koe  Ľe Sihova  Ľo hangńď ko e fefine li Ľaki pea mamahi  Ľi hono laumńĀlie,  
\q2 pea hangńď ko e uaifi  Ľi he Ľene kei si Ľi, ka kuo li Ľaki,‚ÄĚ  Ľoku pehńď  Ľe ho  ĽOtua.   
\b  
\q1
\v 7 ‚Äú ĽI he kihi Ľi fuoloa si Ľi kuo u li Ľaki koe;  
\q2 ka  Ľi he ngaahi  Ľalo Ľofa lahi te u tńĀnaki koe.   
\q1
\v 8 ‚ÄĆ ĽI he houhau si Ľi na Ľaku fufŇę hoku fofonga meiate koe  Ľi he kemo pe;  
\q2 ka  Ľi he  Ľofa ta Ľengata te u  Ľalo Ľofa kiate koe,  Ľoku pehńď  Ľe Sihova ko ho Huhu Ľi.   
\b  
\q1
\v 9 ‚ÄúHe  Ľoku tatau  Ľae me Ľa ni kiate au mo e ngaahi vai  Ľo Noa:  
\q2  Ľo hangńď kuo u fuakava  Ľe  Ľikai toe lŇćmaki  Ľa mńĀmani  Ľaki  Ľae ngaahi vai  Ľo Noa;  
\q2  Ľoku pehńď  Ľeku fuakava  Ľe  Ľikai te u houhau kiate koe, pe valoki Ľi koe.   
\q1
\v 10 Koe Ľuhi  Ľe mole  Ľae ngaahi mo Ľunga,  
\q2 pea hiki mo e ngaahi tafungofunga;  
\q1 ka ko  Ľeku  Ľofa  Ľe  Ľikai mole meiate koe,  
\q2 pea  Ľe  Ľikai hiki  Ľae fuakava  Ľo  Ľeku melino,  
\q2  Ľoku pehńď  Ľe Sihova  Ľaia  Ľoku  Ľalo Ľofa kiate koe.   
\b  
\q1
\v 11 ‚Äú ĽA koe koe mamahi, pea vilingia  Ľi he matangi, pea ta ĽefiemńĀlie,  
\q2 vakai, te u  Ľai ho Ľo ngaahi maka  Ľi he lanu lelei,  
\q2 pea  Ľai ho Ľo ngaahi tu Ľunga  Ľaki  Ľae ngaahi safaia.   
\q1
\v 12 Pea te u ngaohi ho ngaahi matapńĀ sio Ľata  Ľaki  Ľae  Ľakete,  
\q2 pea mo ho ngaahi matapńĀ  Ľaki  Ľae kapunikale,  
\q2 pea mo ho ngaahi ngata Ľanga  Ľaki  Ľae ngaahi maka mahu Ľinga.   
\q1
\v 13 Pea  Ľe akonaki Ľi  Ľe Sihova ho Ľo fńĀnau kotoa pńď;  
\q2 pea  Ľe lahi  Ľae fiemńĀlie  Ľi ho Ľo fńĀnau.   
\q1
\v 14 ‚ÄĆ ĽE fokotu Ľuma Ľu koe  Ľi he mńĀ Ľoni Ľoni:  
\q2 te ke mama Ľo mo e fakamńĀlohia;  
\q2 koe Ľuhi  Ľe  Ľikai te ke manavahńď:  
\q2 pea mei he ilifia;  
\q2 koe Ľuhi  Ľe  Ľikai ha Ľu ia  Ľo ofi kiate koe.   
\q1
\v 15 Vakai, ko e mo Ľoni te nau tńĀnaki fakataha, ka e  Ľikai  Ľiate au:  
\q2 ko ia kotoa pńď  Ľe fakataha ko e fili kiate koe  Ľe hinga koe Ľuhi ko koe.   
\b  
\q1
\v 16 ‚ÄúVakai, kuo u fakatupu  Ľae tufunga ukamea  Ľaia  Ľoku tapili  Ľae malala  Ľi he afi,  
\q2 pea  Ľoku  Ľomi  Ľae me Ľa fakatufunga ki he Ľene ngńĀue;  
\q2 pea kuo u fakatupu  Ľae faka Ľauha ke faka Ľauha Ľi.   
\q1
\v 17 ‚ÄĆ ĽE  Ľikai monŇę Ľia ha mahafutau kuo ngaohi ke tau Ľi koe;  
\q2 pea ko e  Ľelelo kotoa pńď  Ľe lea kovi kiate koe te ke fakamala Ľia  Ľi he fakamaau.  
\q1 Ko eni  Ľae tofi Ľa  Ľoe kau tamaio Ľeiki  Ľa Sihova,  
\q2 pea  Ľoku meiate au  Ľenau mńĀ Ľoni Ľoni,‚ÄĚ  Ľoku pehńď  Ľe Sihova.   
\c 55  
\cd \it 1  ĽOku ako  Ľe he palŇćfita  Ľaki  Ľae ngaahi tala Ľofa  Ľa Kalaisi, ki he tui, 6 Pea ki he fakatomala. 8 Ko e monŇę Ľia  Ľakinautolu  Ľoku tui.\it*  
\q1
\v 1 ‚ÄúVakai mai,  Ľakimoutolu kotoa pńď  Ľoku fieinu, ha Ľu ki he ngaahi vai,  
\q2 pea mo ia  Ľoku  Ľikai ha Ľane pa Ľanga; mou ha Ľu,  Ľo fakatau, pea kai;  
\q2  Ľio, ha Ľu  Ľo fakatau uaine mo e hu Ľahuhu ta Ľehapa Ľanga pea ta Ľehatotongi.   
\q1
\v 2 Ko e hńĀ  Ľoku mou  Ľatu ai  Ľae pa Ľanga ki he me Ľa  Ľoku  Ľikai ko e mńĀ?  
\q2 Mo ho Ľomou ngńĀue ki he me Ľa  Ľoku  Ľikai fakamńĀkona?  
\q1 Mou fanongo  Ľo tokanga kiate au, pea mou kai  Ľaia  Ľoku lelei,  
\q2 pea tuku ke fiefia homou laumńĀlie  Ľi he me Ľakai lelei lahi.   
\q1
\v 3 Fakatokanga Ľi homou telinga, pea ha Ľu kiate au fanongo,  
\q2 pea  Ľe mo Ľui homou laumńĀlie,  
\q2 pea te u fai  Ľae fuakava ta Ľengata mo kimoutolu,  Ľio,  Ľae ngaahi  Ľalo Ľofa tu Ľuma Ľu kia Tevita.   
\q1
\v 4 Vakai, kuo u foaki ia ko e fakamo Ľoni ki he kakai,  
\q2 ko e takimu Ľa mo e pule ki he kakai.   
\q1
\v 5 Vakai, te ke ui  Ľae pule Ľanga  Ľoku  Ľikai te ke  Ľilo ni,  
\q2 pea ko e ngaahi pule Ľanga  Ľoku  Ľikai te nau  Ľilo koe te nau lele kiate koe  
\q2 koe Ľuhi ko Sihova ko ho  ĽOtua,  
\q2 pea koe Ľuhi ko e tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli;  
\q2 he kuo ne fakaongoongolelei Ľi koe.‚ÄĚ   
\b  
\q1
\v 6 Mou kumi kia Sihova  Ľi he lolotonga  Ľoku fa Ľa  Ľilo ia,  
\q2 ui kiate ia  Ľi he Ľene kei ofi:   
\q1
\v 7 Tuku ke li Ľaki  Ľe he angahala hono hala,  
\q2 mo e tangata ta ĽemńĀ Ľoni Ľoni  Ľene ngaahi mahalo:  
\q1 pea tuku ke ne foki kia Sihova, pea te ne  Ľalo Ľofa kiate ia;  
\q2 pea ki hotau  ĽOtua, he te ne fakamolemole  Ľo lahi  Ľaupito.   
\q1
\v 8 He  Ľoku pehńď  Ľe Sihova, ‚Äú ĽOku  Ľikai ko ho Ľomou ngaahi mahalo  Ľa  Ľeku mahalo,  
\q2 pea  Ľoku  Ľikai ko homou ngaahi hala  Ľa hoku ngaahi hala.   
\q1
\v 9 He  Ľoku hangńď  Ľoku mńĀ Ľolunga hake  Ľae ngaahi langi mei he mńĀmani,  
\q2  Ľoku pehńď hono mńĀ Ľolunga  Ľo hoku ngaahi hala,  
\q2 pea mo  Ľeku mahalo  Ľi ho Ľomou ngaahi mahalo.   
\q1
\v 10 Pea hangńď  Ľoku  Ľalu hifo  Ľae  Ľuha, mo e  Ľuha hinehina mei he langi,  
\q2 pea  Ľikai toe foki ki ai, ka  Ľoku fakaviviku  Ľae kelekele,  
\q2 pea ngaohi ia ke tupu mo fua,  
\q2 koe Ľuhi ke  Ľomi mei ai  Ľae tenga ki he tangata tŇętuu Ľi, pea mo e mńĀ kiate ia  Ľoku kai.   
\q1
\v 11 ‚ÄĆ ĽE pehńď  Ľeku folofola  Ľaia  Ľoku  Ľalu atu  Ľi hoku fofonga:  
\q2  Ľe  Ľikai foki ta Ľefua kiate au,  
\q2 ka e lava Ľi ia  Ľaia  Ľoku ou fa Ľiteliha ki ai,  
\q2 pea  Ľe monŇę Ľia ia  Ľi he me Ľa  Ľoku ou fekau ia ki ai.   
\q1
\v 12 He te mou  Ľalu atu  Ľi he fiefia,  
\q2 pea  Ľe taki atu  Ľakimoutolu  Ľi he fiemńĀlie:  
\q1  Ľe pńĀ  Ľae hiva  Ľi homou  Ľao mei he ngaahi mo Ľunga mo e potu tafungofunga,  
\q2 pea  Ľe pasipasi nima  Ľe he ngaahi  Ľakau kotoa pńď  Ľoe vao.   
\q1
\v 13 ‚ÄĆ ĽE tupu hake  Ľae  Ľakau ko e fea ko e fetongi  Ľoe  Ľakau talatala,  
\q2 pea  Ľe tupu  Ľae maile ko e fetongi  Ľoe talatala ĽńĀmoa:  
\q1 pea  Ľe hoko ia ko e me Ľa fakamanatu kia Sihova,  
\q2 ko e faka Ľilonga ta Ľengata  Ľaia  Ľe  Ľikai  Ľauha.‚ÄĚ   
\c 56  
\cd \it 1  ĽOku enginaki  Ľae palŇćfita ki he mńĀ Ľoni Ľoni. 3  ĽOku faka Ľilo  Ľe mafola ia  Ľi he ta ĽefilifilimńĀnako ki he tangata. 9  ĽOku ne valoki  Ľae kau le Ľo  Ľoku kui.\it*  
\p
\v 1 ‚ÄĆ ĽOku pehńď  Ľe Sihova,  
\q1 ‚ÄúTauhi  Ľae fakamaau,  
\q2 pea fai mńĀ Ľoni Ľoni:  
\q1 he  Ľoku ofi  Ľae ha Ľu  Ľa  Ľeku fakamo Ľui,  
\q2 pea mo e fakahńĀ  Ľo  Ľeku mńĀ Ľoni Ľoni.   
\q1
\v 2 ‚ÄĆ ĽOku monŇę Ľia  Ľae tangata  Ľoku fai  Ľae me Ľa ni,  
\q2 pea mo e foha  Ľoe tangata  Ľoku puke ki ai;  
\q1  Ľaia  Ľoku tauhi  Ľae  Ľaho tapu ta Ľefaka Ľuli ia,  
\q2 pea  Ľoku ta Ľofi hono nima mei he fai kovi kotoa pńď.‚ÄĚ   
\q1
\v 3 Ke  Ľoua foki na Ľa lea  Ľae foha  Ľoe muli,  Ľaia kuo ne fakahoko ia kia Sihova,  Ľo pehńď,  
\q2 ‚ÄúKuo vahe Ľi  Ľaupito au  Ľe Sihova mei hono kakai:‚ÄĚ  
\q2 pea  Ľoua na Ľa pehńď  Ľe he  Ľiunoke, ‚ÄúVakai, ko e  Ľakau mŇćmoa au.‚ÄĚ   
\b  
\q1
\v 4 He  Ľoku pehńď  Ľe Sihova, ‚ÄúKi ho ngaahi  Ľiunoke  Ľoku tauhi  Ľeku ngaahi SńĀpate,  
\q2 pea  Ľoku fili  Ľae ngaahi me Ľa  Ľoku ou fiemńĀlie ai,  
\q2 pea puke ki he Ľeku fuakava.   
\q1
\v 5 ‚ÄĆ ĽIo, te u foaki kiate kinautolu  Ľi hoku fale pea  Ľi hoku loto ĽńĀ ha potu, pea mo ha hingoa lelei lahi  Ľi he ngaahi foha mo e ngaahi  Ľofefine:  
\q2 te u foaki kiate kinautolu ha hingoa ta Ľengata,  Ľaia  Ľe  Ľikai  Ľauha.   
\q1
\v 6 Pea mo e ngaahi foha  Ľoe muli,  Ľoku fakahoko  Ľakinautolu kia Sihova, ke tauhi ia,  
\q2 pea ke  Ľofa ki he huafa  Ľo Sihova, ke hoko ko  Ľeku kau tamaio Ľeiki,  
\q1 ko kinautolu kotoa pńď  Ľoku tauhi  Ľae  Ľaho tapu kae  Ľikai faka Ľuli ia,  
\q2 pea  Ľoku puke ma Ľu ki he Ľeku fuakava;   
\q1
\v 7 ‚ÄĆ ĽIo, ko kinautolu te u  Ľomi ki hoku mo Ľunga tapu,  
\q2 pea te u fakafiefia Ľi  Ľakinautolu  Ľi hoku falelotu:  
\q2  Ľe ma Ľu  Ľi hoku feilaulau Ľanga  Ľa  Ľenau ngaahi feilaulau tutu mo  Ľenau ngaahi feilaulau;  
\q2 koe Ľuhi  Ľe ui hoku fale ko e falelotu ki he kakai fulipńď.‚ÄĚ   
\q1
\v 8 ‚ÄĆ ĽOku pehńď  Ľe he  ĽEiki ko Sihova,  Ľaia  Ľoku tńĀnaki  Ľae kau li Ľaki  Ľo  ĽIsileli,  
\q2 ‚ÄúKa te u toe tńĀnaki mo ha ni Ľihi kiate ia fakataha mo kinautolu kuo u tńĀnaki kiate ia.‚ÄĚ   
\b  
\q1
\v 9 Mou ha Ľu ke keina,  
\q2  Ľakimoutolu kotoa pńď  Ľae fanga manu  Ľoe ngoue,  
\q2  Ľio,  Ľakimoutolu  Ľae fanga manu kotoa pńď  Ľoe vao.   
\q1
\v 10 ‚ÄĆ ĽOku kui hono kau tangata le Ľo:  
\q2  Ľoku vale kotoa pńď,  
\q1 ko e fanga kulńę noa  Ľakinautolu kotoa pńď,  
\q2  Ľoku  Ľikai te nau fa Ľa kalou;  
\q2  Ľoku mohe, pea tokoto hifo,  Ľo manako ki he mohe.   
\q1
\v 11 ‚ÄĆ ĽIo, ko e fanga kulńę  Ľuakai,  
\q2  Ľoku  Ľikai  Ľaupito mńĀkona,  
\q1 pea ko e kau tauhi ta Ľe Ľilo  Ľakinautolu:  
\q2  Ľoku nau vakai kotoa pńď ki honau hala taki taha,  
\q2 ke ma Ľu me Ľa mei hono potu.   
\q1
\v 12 ‚ÄĆ ĽOku nau pehńď, ‚ÄúHa Ľu  Ľakimoutolu te u  Ľomi  Ľae uaine,  
\q2 pea te tau inu ke tau fonu  Ľi he inu mńĀlohi;  
\q2 pea  Ľe tatau  Ľae  Ľapongipongi mo e  Ľaho ni,  
\q2 pea  Ľe lahi hake ia.‚ÄĚ   
\c 57  
\cd \it 1  ĽOku monŇę Ľia  Ľae pekia  Ľoe mńĀ Ľoni Ľoni. 3  ĽOku valoki  Ľe he  ĽOtua  Ľae kakai Siu  Ľi he Ľenau fai hala  Ľi he tauhi tamapua. 13  ĽOku ne faka Ľilo  Ľae  Ľalo Ľofa ki he kakai  Ľoku fakatomala.\it*  
\q1
\v 1 ‚ÄĆ ĽOku pekia  Ľae kakai mńĀ Ľoni Ľoni,  
\q2 ka  Ľoku  Ľikai tokanga ki ai  Ľe ha tangata:  
\q1 pea  Ľoku  Ľave  Ľae kakai lotu mo Ľoni,  
\q2 ka  Ľe  Ľikai  Ľilo  Ľe ha taha  Ľoku  Ľave  Ľae kakai mńĀ Ľoni Ľoni mei he kovi.   
\q1
\v 2 Te ne hŇę  Ľi he fiemńĀlie:  
\q2 te nau mńĀlŇćlŇć  Ľi honau ngaahi mohenga,  
\q2  Ľakinautolu  Ľoku  Ľeve Ľeva  Ľi he angatonu.   
\b  
\q1
\v 3 ‚ÄúKae  Ľunu Ľunu mai ki heni,  Ľakimoutolu  Ľae ngaahi tama  Ľae fefine fiemana,  
\q2 ko e hako  Ľoe tonofefine mo e fe Ľauaki.   
\q1
\v 4 ‚ÄĆ ĽOku mou manuki kia hai?  
\q2  ĽOku fakamanga homou ngutu kia hai,  
\q2 pea fakatete Ľe  Ľae  Ľelelo?  
\q1  ĽIkai ko e fńĀnau  Ľakimoutolu  Ľoe angatu Ľu,  
\q2 ko e hako  Ľoe loi,   
\q1
\v 5 ‚ÄĆ ĽOku fakavela  Ľaki  Ľakimoutolu  Ľae ngaahi tamapua  
\q2  Ľi he lolo  Ľakau mo Ľui kotoa pńď,  
\q1  Ľo tńĀmate Ľi  Ľae fńĀnau tupu  Ľi he ngaahi tele Ľa,  
\q2  Ľi he lalo lilifa?   
\q1
\v 6 ‚ÄĆ ĽOku  Ľi he ngaahi maka molemole  Ľoe vaitafe  Ľa ho  Ľinasi;  
\q2 ko ia,  Ľio, ko ia foki ko ho  Ľinasi:  
\q1  Ľio, kuo ke lilingi ki ai  Ľae feilaulau inu,  
\q2 kuo ke  Ľatu ki ai  Ľae feilaulau kai.  
\q2 Pea te u ma Ľu końĀ  Ľae fiemńĀlie  Ľi he ngaahi me Ľa ni?   
\q1
\v 7 Kuo ke  Ľai ho mohenga  Ľi he mo Ľunga mńĀ Ľolunga:  
\q2  Ľio, na Ľa ke  Ľalu hake ki ai ke fai ho Ľo feilaulau.   
\q1
\v 8 Pea  Ľi he tu Ľa matapńĀ mo e tu Ľa pou kuo ke fokotu Ľu ho Ľo fakamanatu:  
\q2 he kuo ke li Ľaki au mńĀ ha taha kehe,  
\q2 pea kuo ke  Ľalu hake,  
\q1 kuo ke fakalahi ho mohenga,  
\q2 pea fai  Ľae fuakava mo kinautolu;  
\q2 na Ľa ke manako ki honau mohenga  Ľi he potu na Ľa ke mamata ki ai.   
\q1
\v 9 Pea ne ke  Ľalu ki he tu Ľi mo e me Ľa tńĀkai,  
\q2 pea na Ľe fakalahi ho Ľo ngaahi me Ľa namu kakala,  
\q1 pea fekau ki he mama Ľo ho Ľo kau talafekau,  
\q2 pea ne ke fakalielia Ľi koe  Ľo a Ľu ki heli.   
\q1
\v 10 Kuo ke ongosia  Ľi hono lahi  Ľo ho hala;  
\q2 ka na Ľe  Ľikai te ke pehńď, ‚Äė ĽOku  Ľikai ha  Ľamanaki:‚Äô  
\q1 kuo ke  Ľilo  Ľae mo Ľui  Ľa ho nima;  
\q2 ko ia na Ľe  Ľikai te ke mamahi ai.   
\q1
\v 11 ‚ÄúPea ko hai kuo ke ilifia mo manavahńď ki ai  
\q2 koe Ľuhi ke ke loi,  
\q2 kae  Ľikai te ke manatu kiate au, pe tokanga loto ki ai?  
\q1  ĽIkai kuo u fakalongo pńď  Ľo fuoloa,  
\q2 pea na Ľe  Ľikai te ke manavahńď kiate au?   
\q1
\v 12 Te u fakahńĀ ho Ľo mńĀ Ľoni Ľoni, pea mo ho Ľo ngńĀue;  
\q2 koe Ľuhi  Ľe  Ľikai te nau  Ľaonga kiate koe.   
\q1
\v 13 ‚ÄĆ ĽOka ke ka tangi,  
\q2 tuku ke fakamo Ľui koe  Ľe ho Ľo kakai tokolahi:  
\q1 ka e  ĽńĀvea  Ľakinautolu kotoa pńď  Ľe he matangi;  
\q2  Ľe  Ľave  Ľakinautolu  Ľe he va Ľinga:  
\q1 ka ko ia  Ľoku falala kiate au te ne ma Ľu  Ľae fonua,  
\q2 pea nofo  Ľi hoku mo Ľunga tapu;‚ÄĚ   
\b  
\q1
\v 14 Pea  Ľe pehńď  Ľe ia, ‚ÄúMou laku hake, mou laku hake, teuteu  Ľae hala,  
\q2 to Ľo  Ľae tŇękia Ľanga mei he hala  Ľo hoku kakai.   
\q1
\v 15 He  Ľoku pehńď  Ľe he tokotaha lahi mo mńĀ Ľolunga  Ľaia  Ľoku  Ľafio  Ľi he ta Ľengata,  
\q2 ko hono huafa ko e MńĀ Ľoni Ľoni;  
\q1  ĽOku ou nofo  Ľi he potu mńĀ Ľolunga mo mńĀ Ľoni Ľoni,  
\q2 pea  Ľiate ia foki  Ľoku loto fakatomala mo angavaivai,  
\q2 ke fakamo Ľui  Ľae loto  Ľokinautolu  Ľoku fakatomala.   
\q1
\v 16 Koe Ľuhi  Ľe  Ľikai te u fai ma Ľuaipńď, pea  Ľe  Ľikai te u houhau ma Ľuaipńď:  
\q2 koe Ľuhi  Ľe vaivai  Ľae laumńĀlie  Ľi hoku  Ľao,  
\q2 pea mo e ngaahi laumńĀlie kuo u ngaohi.   
\q1
\v 17 He na Ľaku houhau koe Ľuhi ko e hia  Ľo  Ľene manumanu, pea te Ľia ia:  
\q2 na Ľaku fufŇę au, pea ne u houhau,  
\q2 pea na Ľe  Ľalu talangata Ľa ia  Ľi he hala  Ľo hono loto.   
\q1
\v 18 Kuo u vakai ki hono ngaahi hala, pea te u fakamo Ľui ia:  
\q2 te u tataki foki ia,  
\q2 pea toe  Ľatu  Ľae ngaahi fakafiemńĀlie kiate ia mo  Ľene kau mamahi.   
\q1
\v 19 ‚ÄĆ ĽOku ou fakatupu  Ľae fua  Ľoe loungutu;  
\q2 FiemńĀlie, fiemńĀlie kiate ia  Ľoku kei mama Ľo, pea kiate ia  Ľoku ofi,‚ÄĚ  
\q2  Ľoku pehńď  Ľe Sihova; ‚Äúpea te u fakamo Ľui ia.‚ÄĚ   
\q1
\v 20 Ka  Ľoku tatau  Ľae angakovi mo e tahi hou,  Ľoku  Ľikai fa Ľa tokalelei ia,  
\q2  Ľoku laku hake  Ľe hono ngaahi peau  Ľae pelepela mo e  Ľuli.   
\q1
\v 21 ‚ÄĆ ĽOku pehńď  Ľe hoku  ĽOtua, ‚Äú ĽOku  Ľikai ha fiemńĀlie ki he angahala.‚ÄĚ   
\c 58  
\cd \it 1  ĽI he fekau  Ľae palŇćfita ke valoki  Ľae mńĀlualoi, 3  ĽOku fakahńĀ  Ľae  Ľaukai loi mo e  Ľaukai mo Ľoni. 8  ĽOku ne fakahńĀ  Ľae ngaahi tala Ľofa  Ľoku  Ľoe anga faka Ľotua, 13 Pea ki he tauhi  Ľae  Ľaho tapu.\it*  
\q1
\v 1 ‚ÄúTangi kalanga,  Ľoua  Ľe ta Ľofi,  
\q2 hiki hake ho le Ľo  Ľo hangńď ko e me Ľalea,  
\q1 pea fakahńĀ ki hoku kakai  Ľenau angahala,  
\q2 pea ki he fale  Ľo Sńďkope  Ľenau ngaahi hia.   
\q1
\v 2 Ka  Ľoku nau kumi  Ľi he  Ľaho kotoa pńď kiate au,  
\q2 pea fiefia  Ľi he  Ľilo ki hoku ngaahi hala,  
\q1  Ľo hangńď ko e pule Ľanga na Ľe fai mńĀ Ľoni Ľoni,  
\q2 pea ta Ľeli Ľaki  Ľae tu Ľutu Ľuni  Ľa honau  ĽOtua:  
\q1  Ľoku nau kole kiate au  Ľae ngaahi tu Ľutu Ľuni  Ľoe angatonu;  
\q2  Ľoku nau fiefia  Ľi he  Ľunu Ľunu atu ki he  ĽOtua.   
\q1
\v 3 ‚ÄĆ ĽOku nau pehńď, ‚ÄėKo e hńĀ kuo mau  Ľaukai, ka  Ľoku  Ľikai te ke  Ľafio Ľi?  
\q2 Ko e hńĀ kuo mau fakamamahi ai homau laumńĀlie, pea  Ľoku  Ľikai te ke tokanga Ľi?‚Äô  
\b  
\q1 ‚ÄúVakai  Ľi he  Ľaho  Ľo ho Ľomou  Ľaukai  Ľoku mou  Ľilo  Ľae fiemńĀlie,  
\q2 pea pule ke fai ho Ľomou ngńĀue kotoa pńď.   
\q1
\v 4 Vakai,  Ľoku mou  Ľaukai ke fakakikihi mo alea lalahi,  
\q2 pea ke tńĀ  Ľaki  Ľae nima  Ľoe angahala:  
\q2  Ľe  Ľikai te mou  Ľaukai  Ľo hangńď ko e  Ľaho ni, ke ngaohi ke ongo homou le Ľo ki  Ľolunga.   
\q1
\v 5 ‚ÄĆ ĽOku pehńď końĀ  Ľae  Ľaukai kuo u fili?  
\q2 Ko e  Ľaho ke fakamamahi  Ľe he tangata hono laumńĀlie?  
\q1 Ko e me Ľa ia ke mapelu ki lalo hono  Ľulu  Ľo hangńď ko e kaho,  
\q2 pea ke fofola  Ľae tauanga Ľa mo e efuefu ki lalo  Ľiate ia?  
\q2 Te ke ui  Ľae me Ľa ni ko e  Ľaukai,  
\q2 pea ko e  Ľaho fakatu Ľotu Ľamelie kia Sihova?   
\b  
\q1
\v 6 ‚Äú ĽIkai ko eni  Ľae  Ľaukai kuo u fili?  
\q2 Ke vete  Ľae ngaahi no Ľo  Ľoe angahala,  
\q2 ke vete  Ľae ngaahi kavenga mamafa,  
\q2 pea ke tukuange  Ľae kau tamaio Ľeiki,  
\q2 pea ke motumotuhi  Ľae ngaahi ha Ľamonga kotoa pńď?   
\q1
\v 7 ‚ÄĆ ĽIkai ko e me Ľa ke tufaki ho Ľo mńĀ ki he fiekaia,  
\q2 pea ke  Ľomi  Ľae masiva kuo lńę kitu Ľa ki ho fale?  
\q1  ĽOka ke ka mamata ki he telefua,  
\q2 ke fakakofu ia;  
\q2 pea  Ľoua na Ľa ke fufŇę koe mei ho sino  Ľo Ľou?   
\q1
\v 8 Ka pehńď  Ľe toki ulo atu ho Ľo maama  Ľo hangńď ko e pongipongi,  
\q2 pea  Ľe tupu vave ho Ľo mo Ľui lelei:  
\q1 pea  Ľe mu Ľomu Ľa  Ľi ho  Ľao  Ľa ho Ľo mńĀ Ľoni Ľoni;  
\q2 pea  Ľe muimui  Ľiate koe  Ľae nńĀunau  Ľo Sihova.   
\q1
\v 9 Pea te ke toki ui pea  Ľe tali  Ľe Sihova;  
\q2 te ke kalanga, pea te ne pehńď, ‚ÄėKo au eni.‚Äô  
\b  
\q1 ‚ÄúKapau te ke to Ľo mei ho  Ľao  Ľae ha Ľamonga,  
\q2  Ľae tuhutuhu  Ľoe nima,  
\q2 mo e lea ta Ľe Ľaonga.   
\q1
\v 10 Pea kapau te ke tangaki ho laumńĀlie ki he fiekaia,  
\q2 pea fafanga  Ľae laumńĀlie  Ľoku mamahi;  
\q1 pea  Ľe toki  Ľalu hake ho maama  Ľi he fakapo Ľuli,  
\q2 pea tatau  Ľae fakapo Ľuli mo e ho ĽatńĀmńĀlie:   
\q1
\v 11 Pea  Ľe fakahinohino koe  Ľe Sihova ma Ľuaipńď,  
\q2 pea  Ľe fakainu ho laumńĀlie  Ľoka  Ľikai ha vai,  
\q2 pea  Ľe fakamńĀlohi ho ngaahi hui:  
\q1 pea te ke hangńď ko e ngoue  Ľoku fakaviviku,  
\q2 pea hangńď ko e matavai mo Ľui,  
\q2  Ľoku tupu ma Ľuaipńď hono vai.   
\q1
\v 12 Pea ko kinautolu  Ľoku  Ľiate koe te nau toe langa  Ľae ngaahi potu lala:  
\q2 te ke fokotu Ľu hake  Ľae tu Ľunga  Ľoe ngaahi to Ľutangata lahi;  
\q1 pea  Ľe ui koe, ko e fakalelei  Ľoe potu  ĽńĀ kuo maumau,  
\q2 mo e toe fakapapa  Ľoe hala ke  Ľalu ai  Ľae kakai.   
\b  
\q1
\v 13 ‚ÄúKapau te ke ta Ľofi ho va Ľe  Ľi he  Ľaho tapu,  
\q2 pea  Ľoua na Ľa fai ki ho loto  Ľi hoku  Ľaho mńĀ Ľoni Ľoni;  
\q1 pea ke ui  Ľae  Ľaho tapu ko e fakafiefia,  
\q2 ko e  Ľaho mńĀ Ľoni Ľoni  Ľo Sihova, ko e ongoongolelei;  
\q2 pea faka Ľapa Ľapa ki ai,  
\q2  Ľo ta Ľefai ki ho ngaahi hala,  
\q2  Ľo ta Ľefai ki ho loto,  
\q2 pea ta Ľelea Ľaki  Ľae ngaahi lea  Ľa Ľau:   
\q1
\v 14 Pehńď, te ke toki fiefia koe  Ľia Sihova;  
\q2 pea te u ngaohi koe ke ke heka  Ľi he ngaahi potu mńĀ Ľolunga  Ľo mńĀmani,  
\q2 pea te u fafanga  Ľaki koe  Ľae tofi Ľa  Ľo Sńďkope ko ho Ľo tamai:‚ÄĚ  
\q2 he kuo folofola pehńď  Ľae fofonga  Ľo Sihova.   
\c 59  
\cd \it 1 Ko e anga fakamala Ľia  Ľoe angahala. 3 Ko e ngaahi angahala  Ľae kakai Siu. 9 Ko e tu ĽutńĀmaki  Ľoku tupu mei he angahala. 16  ĽOku  Ľi he  ĽOtua pe  Ľae fakamo Ľui. 20  ĽAe fuakava  Ľoe Huhu Ľi.\it*  
\q1
\v 1 Vakai,  Ľoku  Ľikai fakanounou  Ľae nima  Ľo Sihova, ke ne ta Ľefa Ľafakamo Ľui;  
\q2 pea  Ľoku  Ľikai mamafa hono fofonga, ke ne ta Ľefa Ľaongo Ľi.   
\q1
\v 2 Ka ko ho Ľomou ngaahi hia kuo fakamavae  Ľakimoutolu mo homou  ĽOtua,  
\q2 pea  Ľi ho Ľomou angahala kuo ne fakafufŇę hono fofonga meiate kimoutolu,  
\q2 koe Ľuhi  Ľe  Ľikai te ne fanongo,   
\q1
\v 3 He kuo faka Ľuli homou nima  Ľaki  Ľae toto,  
\q2 mo homou louhi Ľi nima  Ľaki  Ľae fai kovi;  
\q1 kuo lea loi homou loungutu,  
\q2 kuo pu Ľaki  Ľe homou  Ľelelo  Ľae kovi.   
\q1
\v 4 ‚ÄĆ ĽOku  Ľikai ui ha taha ki he angatonu,  
\q2 pe lea ha ni Ľihi ki he mo Ľoni,  
\q1  Ľoku nau fa Ľaki ki he va Ľinga,  
\q2 pea lea loi;  
\q1  Ľoku nau tuitu Ľia  Ľi he fai kovi,  
\q2 pea nau fanau Ľi  Ľae angahala.   
\q1
\v 5 ‚ÄĆ ĽOku nau fŇćfoa Ľi  Ľae fua  Ľoe ngata fekai,  
\q2 pea fi  Ľae matamata kupenga  Ľoe hina:  
\q1 ko ia  Ľoku ne kai honau fua  Ľe mate,  
\q2 pea ko ia kuo laiki  Ľoku ha Ľu mei ai  Ľae ngata fekai.   
\q1
\v 6 ‚ÄĆ ĽE  Ľikai hoko ko e ngaahi kofu  Ľenau matamata kupenga,  
\q2 pea  Ľe  Ľikai te nau  Ľufi Ľufi  Ľakinautolu  Ľaki  Ľenau ngaahi ngńĀue:  
\q1 he ko  Ľenau ngaahi ngńĀue ko e ngńĀue  Ľae angahala,  
\q2 pea  Ľoku  Ľi honau nima  Ľae ngńĀue fakamńĀlohi.   
\q1
\v 7 ‚ÄĆ ĽOku lele honau va Ľe ki he kovi,  
\q2 pea  Ľoku nau fai to Ľoto Ľo ke lilingi  Ľae toto  Ľoe ta Ľehalaia:  
\q1 ko  Ľenau ngaahi mahalo ko e ngaahi mahalo  Ľoe angahala;  
\q2  Ľoku  Ľi honau ngaahi hala  Ľae maumau mo e faka Ľauha.   
\q1
\v 8 Ko e hala  Ľoe melino  Ľoku  Ľikai te nau  Ľilo Ľi;  
\q2 pea  Ľoku  Ľikai ha angatonu  Ľi honau ngaahi  Ľalu Ľanga:  
\q1 kuo nau ngaohi kiate kinautolu  Ľae ngaahi hala pikopiko:  
\q2 ko ia  Ľe  Ľalu ai  Ľe  Ľikai te ne  Ľilo ha fiemńĀlie.   
\q1
\v 9 ‚ÄúKo ia  Ľoku mama Ľo ai meiate kitautolu  Ľae fakamaau,  
\q2 pea  Ľoku  Ľikai hoko mai  Ľae angatonu:  
\q1  Ľoku tau tatali ki he maama, kae vakai ko e fakapo Ľuli;  
\q2 ki he maama lahi, ka  Ľoku tau  Ľeve Ľeva  Ľi he po Ľuli.   
\q1
\v 10 ‚ÄĆ ĽOku tau tautaufńĀ ki he  ĽńĀ  Ľo hangńď ko e kui,  
\q2 pea  Ľoku tau tautaufńĀ  Ľo hangńď  Ľoku  Ľikai hatau mata:  
\q1  Ľoku tau humu  Ľi he ho ĽatńĀmńĀlie  Ľo hangńď ha po Ľuli;  
\q2  Ľoku tau  Ľi he ngaahi potu lala  Ľo hangńď ko e kakai mate.   
\b  
\q1
\v 11 ‚ÄĆ ĽOku tau tangi kotoa pńď  Ľo tatau mo e fanga pea,  
\q2 pea  Ľoku tangi mamahi  Ľo hangńď ko e kulukulu,  
\q2  Ľoku tau kumi ki he fakamaau, ka  Ľoku  Ľikai;  
\q2 ki he fakamo Ľui, ka  Ľoku mama Ľo ia  Ľiate kitautolu.   
\b  
\q1
\v 12 He kuo fakalahi  Ľemau ngaahi talangata Ľa  Ľi ho  Ľao,  
\q2 pea  Ľoku talatalaaki Ľi  Ľakitautolu  Ľe he Ľetau ngaahi angahala:  
\q1 he  Ľoku  Ľiate kitautolu  Ľetau ngaahi talangata Ľa;  
\q2 pea ko  Ľetau ngaahi angahala,  
\q2  Ľoku tau  Ľilo ia;   
\q1
\v 13 Ko e me Ľa  Ľi he angatu Ľu mo e lohiaki Ľi kia Sihova,  
\q2 mo e  Ľalu mei hotau  ĽOtua,  
\q2  Ľo lea ki he fakamńĀlohi mo e fakaaoao,  
\q2  Ľi he mahalo  Ľaki mo e fakahńĀ mei he loto  Ľae ngaahi lea loi.   
\q1
\v 14 Pea kuo foki ki mui  Ľae fakamaau,  
\q2 pea  Ľoku  Ľi he mama Ľo  Ľae angatonu:  
\q1 he kuo hinga  Ľae mo Ľoni  Ľi he hala,  
\q2 pea  Ľoku  Ľikai fa Ľa hŇę ki ai  Ľae faitotonu.   
\q1
\v 15 ‚ÄĆ ĽIo, kuo mole  Ľae mo Ľoni;  
\q2 pea  Ľoku lau ko e faha  Ľaia kuo afe mei he kovi:  
\q1 pea na Ľe  Ľafio ki ai  Ľa Sihova,  
\q2 pea na Ľe kovi ia ki hono fofonga  Ľi he  Ľikai ai ha fakamaau.‚ÄĚ   
\q1
\v 16 ‚ÄúPea na Ľa ne  Ľafio Ľi  Ľoku  Ľikai ai ha tangata,  
\q2 pea ofo ia  Ľi he  Ľikai ha fakalaloa:  
\q1 ko ia na Ľe  Ľomi  Ľe hono nima  Ľae fakamo Ľui kiate ia;  
\q2 pea ko  Ľene mńĀ Ľoni Ľoni, na Ľe tokoni ia kiate ia.   
\q1
\v 17 He na Ľa ne  Ľai  Ľae mńĀ Ľoni Ľoni  Ľo hangńď ko e kofu fatafata,  
\q2 pea mo e tatńĀ  Ľoe fakamo Ľui ki hono fofonga;  
\q1 pea ne ai  Ľae teunga  Ľoe houhau ko e kofu,  
\q2 pea na Ľa ne kofu Ľaki  Ľae loto faivelenga  Ľo hangńď ko e kofutu Ľa.‚ÄĚ   
\q1
\v 18 ‚ÄĆ ĽO fakatatau ki he Ľenau ngaahi faianga,  
\q2  Ľe pehńď  Ľene totongi,  
\q2  Ľaki  Ľae houhau ki he kau angatu Ľu,  
\q2  Ľae totongi ki hono ngaahi fili;  
\q2 ki he ngaahi motu te ne fakatatau  Ľae totongi.   
\q1
\v 19 Ko ia te nau manavahńď ai ki he huafa  Ľo Sihova mei he lulunga,  
\q2 pea mo hono nńĀunau mei he hopo Ľangala ĽńĀ.  
\q1  ĽOka  Ľoho mai  Ľae fili  Ľo hangńď ko e vaitafe lahi,  
\q2  Ľe hiki hake  Ľe he LaumńĀlie  Ľo Sihova ha fuka kiate ia.   
\b  
\q1
\v 20 Pea  Ľoku pehńď  Ľe Sihova,  ĽE ha Ľu  Ľae Huhu Ľi ki Saione,  
\q2 pea kiate kinautolu  Ľoku tafoki mei he talangata Ľa  Ľia Sńďkope.   
\q1
\v 21 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚ÄúKa ko au, ko  Ľeku fuakava eni mo kinautolu; Ko hoku laumńĀlie  Ľaia  Ľoku  Ľiate koe, pea mo  Ľeku ngaahi lea kuo u  Ľai ki ho ngutu,  Ľe  Ľikai  Ľalu  Ľi ho ngutu, pe mei he ngutu  Ľo ho hako, pe mei he ngutu  Ľoe hako  Ľo ho hako,  Ľoku pehńď  Ľe Sihova, ngata mei heni  Ľo a Ľu  Ľo ta Ľengata.‚ÄĚ   
\c 60  
\cd \it 1 Ko e lelei  Ľoe siasi  Ľi hono fakatokolahi  Ľaupito mei he kakai Senitaile, 15 Pea mo e ngaahi tńĀpuaki lahi hili  Ľae mamahi fuonounou.\it*  
\q1
\v 1 ‚ÄúTu Ľu hake, pea ulo; he kuo hoko mai ho Ľo maama,  
\q2 pea kuo hńĀ hake  Ľiate koe  Ľae nńĀunau  Ľo Sihova,   
\q1
\v 2 He vakai,  Ľe  Ľufi Ľufi  Ľe he po Ľuli  Ľa mńĀmani,  
\q2 mo e po Ľuli matolu  Ľae kakai:  
\q1 ka e hopo hake  Ľa Sihova kiate koe,  
\q2 pea  Ľe hńĀ hono nńĀunau  Ľiate koe.   
\q1
\v 3 Pea  Ľe ha Ľu  Ľae kakai Senitaile ki ho Ľo maama,  
\q2 mo e ngaahi tu Ľi ki he maama lahi  Ľo ho Ľo  Ľalu hake.   
\b  
\q1
\v 4 ‚ÄúHiki hake ho mata  Ľo sio takatakai, pea mamata:  
\q2  Ľoku nau tńĀnaki fakataha  Ľakinautolu kotoa pńď,  
\q2  Ľoku nau ha Ľu kiate koe:  
\q1  Ľe ha Ľu ho ngaahi foha mei he mama Ľo,  
\q2 pea  Ľe fa Ľaki ki ho vakavaka ho ngaahi  Ľofefine.   
\q1
\v 5 Pea te ke toki mamata, pea tńĀnaki fakataha,  
\q2 pea  Ľe manavahńď ho loto, pea  Ľe fakalahi ia;  
\q1 koe Ľuhi  Ľe fakatafoki kiate koe  Ľae koloa  Ľoe tahi,  
\q2  Ľe ha Ľu kiate koe  Ľae koloa  Ľoe ngaahi Senitaile.   
\q1
\v 6 ‚ÄĆ ĽE  Ľufi Ľufi  Ľaki koe  Ľae fanga kńĀmeli lahi,  
\q2 ko e fanga kńĀmeli  Ľo Mitiani mo  ĽEfaa;  
\q1  Ľakinautolu kotoa pńď mei Sipa te nau ha Ľu:  
\q2 te nau  Ľomi  Ľae koula mo e me Ľa namu kakala;  
\q2 pea te nau fakahńĀ  Ľae ongoongolelei  Ľo Sihova.   
\q1
\v 7 ‚ÄĆ ĽE tńĀnaki kiate koe  Ľae fanga manu kotoa pńď  Ľo Keta,  
\q2  Ľae fanga sipitangata  Ľo Nepeoti te nau tokoni kiate koe:  
\q1 te u fiemńĀlie  Ľi he  Ľohake ia ki hoku feilaulau Ľanga,  
\q2 pea te u fakaongoongolelei  Ľae fale  Ľo hoku nńĀunau.   
\b  
\q1
\v 8 ‚ÄúKo hai  Ľakinautolu na  Ľoku puna  Ľo hangńď ha  Ľao,  
\q2 pea hangńď ko e fanga kulukulu ki honau ngaahi matapńĀ?   
\q1
\v 9 Ko e mo Ľoni  Ľe tatali kiate koe  Ľae  Ľotu motu,  
\q2 pea  Ľe mu Ľomu Ľa  Ľae ngaahi vaka  Ľo Tasisi,  
\q1 ke  Ľomi ho ngaahi foha mei he mama Ľo,  
\q2  Ľa  Ľenau siliva mo  Ľenau koula fakataha mo kinautolu,  
\q1 ki he huafa  Ľo Sihova ko ho  ĽOtua,  
\q2 pea ki he tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli,  
\q2 koe Ľuhi kuo ne fakaongoongolelei Ľi koe.   
\b  
\q1
\v 10 ‚ÄúPea  Ľe toe langa ho  Ľa  Ľe he ngaahi foha  Ľoe muli,  
\q2 pea  Ľe tauhi kiate koe honau ngaahi tu Ľi:  
\q1 he na Ľaku taa Ľi koe  Ľi hoku houhau,  
\q2 ka  Ľi he Ľeku  Ľofa kuo u  Ľalo Ľofa kiate koe.   
\q1
\v 11 Ko ia  Ľe ava ma Ľuaipńď ho ngaahi matapńĀ;  Ľe  Ľikai tńĀpuni ia  Ľi he  Ľaho pe  Ľi he pŇć; koe Ľuhi ke  Ľomi kiate koe  Ľae koloa  Ľoe ngaahi pule Ľanga, pea ke  Ľomi mo honau ngaahi tu Ľi.   
\q1
\v 12 He ko e kakai mo e pule Ľanga  Ľe  Ľikai tauhi kiate koe  Ľe  Ľauha ia;  Ľio,  Ľe lala  Ľaupito  Ľae ngaahi pule Ľanga ko ia.   
\b  
\q1
\v 13 ‚Äú ĽE  Ľomi kiate koe  Ľae nńĀunau  Ľo Lepanoni,  Ľae  Ľakau ko e fea, mo e  Ľakau ko e paini, fakataha mo e pokesi, ke teuteu  Ľaki  Ľae potu  Ľo hoku fale tapu; pea te u ngaohi  Ľae potu  Ľo hoku tu Ľunga va Ľe ke nńĀunau Ľia.   
\q1
\v 14 Pea ko e ngaahi foha  Ľokinautolu na Ľe fakamamahi Ľi koe, te nau ha Ľu  Ľo hŇę kiate koe;  
\q2 pea ko kinautolu na Ľe fehi Ľa kiate koe te nau punou  Ľakinautolu ki ho  Ľaofiva Ľe;  
\q1 pea te nau ui koe, Ko e kolo  Ľa Sihova,  
\q2 Ko e Saione  Ľoe tokotaha mńĀ Ľoni Ľoni  Ľo  ĽIsileli.   
\b  
\q1
\v 15 ‚ÄúKo e me Ľa  Ľi he li Ľaki koe mo e fehi Ľa kiate koe,  
\q2 koe Ľuhi  Ľikai fou ha tangata  Ľiate koe,  
\q1 te u ngaohi koe ko e lelei ta Ľengata,  
\q2 ko e fiefia Ľanga  Ľoe to Ľutangata toko lahi.   
\q1
\v 16 Pea te ke huhu  Ľi he hu Ľahuhu  Ľoe ngaahi Senitaile,  
\q2 pea mimisi  Ľi he huhu  Ľoe ngaahi tu Ľi:  
\q1 pea te ke  Ľilo ko au ko Sihova ko ho Fakamo Ľui,  
\q2 mo ho Huhu Ľi,  
\q2 ko e Toko Taha MńĀfimafi  Ľo Sńďkope.   
\q1
\v 17 Te u  Ľomi  Ľae koula ko e fetongi  Ľoe palasa,  
\q2 pea te u  Ľomi  Ľae siliva ko e fetongi  Ľoe ukamea,  
\q2 pea ko e palasa ko e fetongi  Ľoe  Ľakau,  
\q2 pea ko e ukamea ko e fetongi  Ľoe maka:  
\q1 pea te u ngaohi ho kau fakamaau ko e melino,  
\q2 pea mo ho kau pule ko e mńĀ Ľoni Ľoni.   
\q1
\v 18 ‚ÄĆ ĽE  Ľikai toe fanongo ki ha fakamńĀlohi  Ľi ho fonua,  
\q2  Ľae maumau pe  Ľae faka Ľauha  Ľi ho ngata Ľanga;  
\q1 he te ke ui ho ngaahi  ĽńĀ koe Fakamo Ľui,  
\q2 mo ho ngaahi matapńĀ ko e FakamńĀlŇć.   
\q1
\v 19 ‚ÄĆ ĽE  Ľikai toe hoko  Ľae la ĽńĀ ko ho Ľo maama  Ľi he  Ľaho;  
\q2 pe ko e ulo  Ľoe mńĀhina ko e maama kiate koe:  
\q1 ka e hoko  Ľa Sihova ko e maama ta Ľengata kiate koe,  
\q2 pea ko ho nńĀunau  Ľa ho  ĽOtua.   
\q1
\v 20 ‚ÄĆ ĽE  Ľikai toe tŇć hifo ho Ľo la ĽńĀ,  
\q2 pea  Ľe  Ľikai toe fufŇę  Ľe ia ho Ľo mńĀhina:  
\q1 koe Ľuhi  Ľe hoko  Ľa Sihova ko ho Ľo maama ta Ľengata,  
\q2 pea  Ľe ngata  Ľae ngaahi  Ľaho  Ľo ho Ľo mamahi.   
\q1
\v 21 Pea  Ľe mńĀ Ľoni Ľoni foki  Ľa ho Ľo kakai kotoa pńď;  
\q2 te nau ma Ľu  Ľae fonua  Ľo ta Ľengata,  
\q2 ko e va Ľa na Ľaku tŇć,  
\q2 ko e ngńĀue  Ľa hoku nima,  
\q2 koe Ľuhi ke u ongoongolelei ai.   
\q1
\v 22 ‚ÄĆ ĽE hoko  Ľae tokotaha  Ľoku si Ľi ko e toko afe,  
\q2 mo e tokotaha  Ľoku iiki ko e pule Ľanga mńĀlohi:  
\q2 ko au ko Sihova te u fakavave ia  Ľi hono kuonga.‚ÄĚ   
\c 61  
\cd \it 1 Ko e ngńĀue  Ľa Kalaisi. 4  ĽAe tu Ľu ki mu Ľa, 7 Mo e ngaahi tńĀpuaki  Ľoe kakai tui.\it*  
\q1
\v 1 ‚ÄĆ ĽOku  Ľiate au  Ľae LaumńĀlie  Ľoe  ĽEiki ko Sihova;  
\q2 koe Ľuhi kuo fakanofo au  Ľe Sihova ke u malanga Ľaki  Ľae ongoongolelei ki he angamalŇę;  
\q1 kuo ne fekau au ke nono Ľo  Ľae loto mafesi,  
\q2 ke fakahńĀ  Ľae tau ĽatńĀina ki he kau pŇćpula,  
\q2 pea ke fakaava  Ľae fale fakapŇćpula kiate kinautolu kuo ha Ľisia;   
\q1
\v 2 Ke fakahńĀ  Ľae ta Ľu lelei  Ľo Sihova,  
\q2 pea ko e  Ľaho  Ľoe houhau  Ľo hotau  ĽOtua;  
\q2 ke fakafiemńĀlie Ľi  Ľakinautolu kotoa pńď  Ľoku mamahi;   
\q1
\v 3 Ke  Ľatu  Ľae fiefia kiate kinautolu  Ľoku mamahi  Ľi Saione,  
\q2 ke  Ľatu kiate kinautolu  Ľae hoihoifua ko e fetongi  Ľoe efuefu,  
\q2  Ľae lolo  Ľoe fiefia ko e fetongi  Ľoe mamahi,  
\q1  Ľae kofu  Ľoe fakamńĀlŇć ko e fetongi  Ľoe laumńĀlie kuo mafesi;  
\q2 ke ui  Ľakinautolu ko e ngaahi  Ľakau  Ľoe mńĀ Ľoni Ľoni,  
\q2 na Ľe tŇć  Ľe Sihova,  
\q2 koe Ľuhi ke ongoongolelei ai ia.   
\q1
\v 4 Pea te nau langa  Ľaia na Ľe mu Ľaki maumau,  
\q2 te nau toe fokotu Ľu  Ľaia na Ľe faka Ľauha fuoloa,  
\q1 pea te nau fakafo Ľou  Ľae ngaahi kolo kuo li Ľaki,  
\q2 ko e maumau  Ľoe to Ľutangata toko lahi.   
\q1
\v 5 Pea  Ľe tu Ľu  Ľae kau muli  Ľo fafanga ho Ľomou fanga manu,  
\q2 pea  Ľe hoko  Ľae fńĀnau  Ľae muli ko ho Ľomou kau tangata ngoue mo ho Ľomou kau tauhi vaine.   
\q1
\v 6 Ka e fakahingoa  Ľakimoutolu ko e ngaahi Taula Ľeiki  Ľa Sihova:  
\q2  Ľe ui  Ľakimoutolu  Ľe he kakai ko e kau Faifekau  Ľa hotau  ĽOtua:  
\q1 te mou kai  Ľae koloa  Ľae kakai Senitaile,  
\q2 pea  Ľi he Ľenau ongoongolelei  Ľe polepole ai  Ľakimoutolu.   
\q1
\v 7 Koe Ľuhi ko ho Ľomou mńĀ te mou ma Ľu  Ľae totongi ke liunga ua,  
\q2 pea  Ľe fetongi  Ľaki ho Ľomou fakamaa Ľi  Ľae fiefia  Ľi honau tofi Ľa;  
\q1 he te mou ma Ľu ke liunga ua hake  Ľae tofi Ľa  Ľi honau fonua  
\q2 pea temou fiefia ai  Ľo ta Ľengata.   
\q1
\v 8 ‚ÄúHe ko au ko Sihova  Ľoku ou  Ľofa ki he fakamaau,  
\q2  Ľoku ou fehi Ľa ki he kaiha Ľa ke feilaulau tutu  Ľaki;  
\q1 pea te u fakahinohino  Ľenau ngńĀue  Ľi he mo Ľoni,  
\q2 pea te u fai  Ľae fuakava ta Ľengata mo kinautolu.   
\q1
\v 9 Pea  Ľe  Ľilo honau hako  Ľe he kakai Senitaile,  
\q2 pea mo  Ľenau fńĀnau  Ľi he kakai:  
\q1 ko kinautolu kotoa pńď  Ľoku mamata kiate kinautolu,  
\q2 te nau fakahńĀ  Ľakinautolu ko e hako kuo tńĀpuaki Ľi  Ľe Sihova.‚ÄĚ   
\q1
\v 10 Te u fiefia lahi  Ľia Sihova,  Ľe nekeneka hoku laumńĀlie  Ľi hoku  ĽOtua:  
\q2 he kuo ne fakakofu Ľaki au  Ľae kofu  Ľoe fakamo Ľui,  
\q1 kuo ne  Ľufi Ľufi  Ľaki au  Ľae kofu tŇćtŇćlofa  Ľoe mńĀ Ľoni Ľoni,  
\q2  Ľo hangńď ko e tangata ta Ľane  Ľoku teu Ľi  Ľaki ia  Ľae ngaahi me Ľa teunga,  
\q2 pea hangńď  Ľoku teu Ľi  Ľaki  Ľe he ta Ľahine fakama Ľu hono ngaahi maka koloa.   
\q1
\v 11 ‚ÄĆ ĽO hangńď  Ľoku tupu mei he kelekele hono moto,  
\q2 pea mo e ngoue  Ľoku ne fakatupu hake  Ľae ngaahi me Ľa  Ľoku tŇętuu Ľi ki ai;  
\q2  Ľe pehńď,  Ľe pule  Ľe he  ĽEiki ko Sihova ke tupu hake  Ľae mńĀ Ľoni Ľoni mo e fakamńĀlŇć  Ľi he  Ľao  Ľoe ngaahi pule Ľanga kotoa pńď.   
\c 62  
\cd \it 1 Ko e holi fakamńĀtoato  Ľae palŇćfita ke fokotu Ľuma Ľu  Ľae siasi  Ľi he ngaahi tala Ľofa  Ľae  ĽOtua. 5 Ko e ngńĀue  Ľae kau faifekau ( Ľa ia  Ľoku ue Ľi  Ľakinautolu ki ai)  Ľi he malanga Ľaki  Ľae ongoongolelei, 10 Mo e teu Ľi  Ľae kakai ki ai.\it*  
\q1
\v 1 Koe Ľuhi ko Saione  Ľe  Ľikai te u fakalongo pe,  
\q2 pea koe Ľuhi ko SelŇęsalema  Ľe  Ľikai te u mńĀlŇćlŇć,  
\q1 kae Ľoua ke ulo atu  Ľa  Ľene mńĀ Ľoni Ľoni  Ľo hangńď ko e maama lahi,  
\q2 pea mo  Ľene fakamo Ľui  Ľo hangńď ko e maama  Ľoku ulo.   
\q1
\v 2 Pea  Ľe mamata  Ľae ngaahi Senitaile ki ho Ľo mńĀ Ľoni Ľoni,  
\q2 mo e ngaahi tu Ľi kotoa pńď ki ho nńĀunau;  
\q1 pea  Ľe ui  Ľaki koe  Ľae hingoa fo Ľou,  
\q2  Ľaia  Ľe fakahńĀ  Ľe he folofola  Ľa Sihova.   
\q1
\v 3 Pea te ke hoko foki ko e tatńĀ  Ľoe nńĀunau  Ľi he nima  Ľo Sihova,  
\q2 mo e pale fakatu Ľi  Ľi he nima  Ľo ho  ĽOtua,   
\q1
\v 4 ‚ÄĆ ĽE  Ľikai toe ui koe ‚Äúko e Li Ľaki;‚ÄĚ  
\q2 pea  Ľe  Ľikai toe ui ho fonua ‚Äúko e Lala:‚ÄĚ  
\q1 ka e ui koe ‚Äúko Hefisipa,‚ÄĚ  
\q2 mo ho fonua ‚Äúko Piula:‚ÄĚ  
\q1 he  Ľoku fiefia  Ľa Sihova  Ľiate koe,  
\q2 pea  Ľe fai  Ľae ta Ľane  Ľi ho fonua.   
\q1
\v 5 Hangńď  Ľoku mali  Ľae talavou mo e tńĀupo Ľou,  
\q2  Ľe pehńď  Ľae mali ho ngaahi foha mo koe:  
\q1 pea hangńď  Ľoku fiefia  Ľae tangata ta Ľane  Ľi he ta Ľahine,  
\q2  Ľe pehńď  Ľae fiefia  Ľa ho  ĽOtua  Ľiate koe.   
\q1
\v 6 Kuo u fekau  Ľae kau tangata le Ľo ki ho ngaahi  ĽńĀ,  ĽE SelŇęsalema,  
\q2 pea  Ľe  Ľikai te nau fakalongo pńď  Ľi he  Ľaho pe  Ľi he pŇć;  
\q1 ko kimoutolu  Ľoku fakahńĀ  Ľa Sihova,  Ľoua  Ľe fakalongo pe,   
\q2
\v 7 Pea  Ľoua na Ľa tuku kiate ia ha fiemńĀlie,  
\q2 kae Ľoua ke fokotu Ľuma Ľu  Ľe ia  Ľa SelŇęsalema, pea ke ne ngaohi ia ko e ongoongolelei  Ľi mńĀmani.   
\b  
\q1
\v 8 Kuo fuakava  Ľe Sihova  Ľi hono nima to Ľomata Ľu,  
\q2 pea  Ľi he nima  Ľo hono mńĀlohi,  
\q1 ‚ÄúKo e mo Ľoni  Ľe  Ľikai te u toe foaki ho Ľo uite ko e me Ľakai ki ho ngaahi fili;  
\q2 pea  Ľe  Ľikai inu  Ľe he ngaahi foha  Ľoe muli  Ľi ho Ľo uaine,  Ľaia kuo ke ngńĀue ke ma Ľu:   
\q1
\v 9 Ka ko kinautolu kuo tńĀnaki ia te nau kai ia, pea fakamńĀlŇć kia Sihova;  
\q2 pea ko kinautolu kuo  Ľomi fakataha ia te nau inu ia  Ľi he ngaahi loto  ĽńĀ  Ľo hoku mńĀ Ľoni Ľoni.   
\b  
\q1
\v 10 HŇę atu, hŇę atu  Ľi he ngaahi matapńĀ;  
\q2 teuteu  Ľae hala  Ľoe kakai;  
\q1 fokotu Ľu hake, fokotu Ľu hake  Ľae hala mńĀ Ľolunga;  
\q2 tńĀnaki mei ai  Ľae ngaahi maka;  
\q2 fokotu Ľu  Ľae fuka ma Ľa  Ľe kakai.   
\q1
\v 11 Vakai, kuo folofola  Ľa Sihova  Ľo a Ľu ki he ngata Ľanga  Ľo mńĀmani,  
\q2 ‚ÄúMou pehńď ki he  Ľofefine  Ľo Saione,  
\q2 ‚ÄėVakai,  Ľoku ha Ľu ho Ľo fakamo Ľui;  
\q1 vakai,  Ľoku  Ľiate ia hono totongi,  
\q2 pea  Ľi hono  Ľao  Ľa  Ľene ngńĀue.‚Äô‚ÄĚ   
\q1
\v 12 Pea te nau ui  Ľakinautolu, ‚ÄúKo e kakai mńĀ Ľoni Ľoni,  
\q2 Ko e kakai kuo huhu Ľi  Ľe Sihova:‚ÄĚ  
\q1 pea  Ľe ui koe, ‚ÄúKo e  Ľofeina,  
\q2 Ko e kolo ta Ľeli Ľaki.‚ÄĚ   
\c 63  
\cd \it 1  ĽOku fakahńĀ  Ľe Kalaisi  Ľa  Ľene  Ľafio, 2 Mo  Ľene lava Ľi hono ngaahi fili, 7 Pea mo  Ľene  Ľalo Ľofa ki hono siasi. 10  ĽI hono houhau totonu  Ľoku ne manatu ki he Ľene  Ľalo Ľofa lahi. 15  ĽOku fakahńĀ  Ľe he siasi  Ľa  Ľene tui  Ľi he Ľene hŇę mo  Ľene lńĀunga.\it*  
\q1
\v 1 Ko hai eni  Ľoku ha Ľu mei  ĽItomi,  
\q2 mo e kofu kulokula mei Posila?  
\q1  ĽA eni  Ľoku nńĀunau Ľia hono kofu,  
\q2  Ľo ne hńĀ Ľele  Ľi he lahi  Ľo hono mńĀlohi?  
\q1 ‚ÄúKo au ia  Ľoku folofola  Ľi he mńĀ Ľoni Ľoni,  
\q2 ko e mńĀfimafi ke fakamo Ľui.‚ÄĚ   
\q1
\v 2 Ko e hńĀ  Ľoku kulokula ai ho ngaahi kofu,  
\q2 pea tatau ho ngaahi kofu mo ia  Ľoku molomoloki  Ľi he tata Ľo Ľanga uaine?   
\b  
\q1
\v 3 ‚ÄúKuo u molomoloki tokotaha pe  Ľae tata Ľo Ľanga  Ľoe uaine;  
\q2 pea na Ľe  Ľikai kau ha tokotaha kiate au:  
\q1 ne u molomoloki  Ľakinautolu  Ľi he Ľeku  Ľita,  
\q2 pea moe Ľi  Ľakinautolu  Ľi hoku houhau lahi;  
\q1 pea kuo pani hoku kofu Ľaki honau toto,  
\q2 pea ne u ngaohi ke lanu hoku ngaahi kofu kotoa pńď.   
\q1
\v 4 He  Ľoku  Ľi hoku loto  Ľae  Ľaho  Ľoe fai totongi,  
\q2 pea kuo hokosia  Ľae ta Ľu  Ľo hoku huhu Ľi.   
\q1
\v 5 Pea ne u vakai, pea na Ľe  Ľikai ha taha ke tokoni;  
\q1 pea ne u ofo  Ľi he  Ľikai ha taha ke poupou hake:  
\q2 ko ia na Ľe  Ľomi  Ľe hoku nima  Ľo Ľoku  Ľae fakamo Ľui kiate au;  
\q2 pea ko hoku houhau, na Ľa ne poupou au.   
\q1
\v 6 Pea ne u molomoloki  Ľae kakai  Ľi hoku houhau,  
\q2 pea ngaohi ke nau konńĀ  Ľi he houhau lahi,  
\q2 pea ne u  Ľomi  Ľenau mńĀlohi ki he kelekele.‚ÄĚ   
\b  
\q1
\v 7 Te u fakahńĀ  Ľae ngaahi  Ľalo Ľofa  Ľa Sihova,  
\q2 mo e ngaahi fakamńĀlŇć  Ľa Sihova,  
\q2  Ľo hangńď ko ia kotoa pńď kuo foaki  Ľe Sihova kiate kitautolu,  
\q1 pea mo e angalelei lahi ki he fale  Ľo  ĽIsileli,  
\q2  Ľaia kuo ne foaki kiate kinautolu  Ľo hangńď ko  Ľene ngaahi  Ľalo Ľofa,  
\q2  Ľo fakatatau mo hono lahi  Ľaupito  Ľo  Ľene  Ľalo Ľofa ongongofua.   
\q1
\v 8 He na Ľa ne pehńď, ‚ÄúKo e mo Ľoni ko hoku kakai  Ľakinautolu,  
\q2 ko e fńĀnau  Ľe  Ľikai te nau loi;‚ÄĚ  
\q2 pea na Ľe hoko ia ko honau Fakamo Ľui.   
\q1
\v 9 ‚ÄĆ ĽI he Ľenau mamahi kotoa pńď na Ľe mamahi ia,  
\q2 pea ko e  ĽńĀngelo  Ľo hono  Ľao na Ľa ne fakamo Ľui  Ľakinautolu:  
\q1  Ľi he Ľene  Ľofa mo  Ľene manava Ľofa na Ľa ne huhu Ľi  Ľakinautolu:  
\q2 pea ne to Ľo hake  Ľakinautolu,  
\q2 mo fua  Ľakinautolu  Ľi he ngaahi  Ľaho kotoa pńď  Ľi mu Ľa.   
\q1
\v 10 Ka na Ľa nau angatu Ľu,  
\q2 pea fakamamahi ki hono LaumńĀlie MńĀ Ľoni Ľoni:  
\q1 ko ia na Ľe liliu ai ia ko honau fili,  
\q2 pea na Ľa ne tau Ľi  Ľakinautolu.   
\b  
\q1
\v 11 Pea na Ľa ne manatu ki he ngaahi  Ľaho  Ľi mu Ľa,  
\q2 kia MŇćsese, mo hono kakai,  Ľo ne pehńď,  
\q1 ‚Äú ĽOku  Ľi fńď ia na Ľe  Ľomi  Ľakinautolu mei he tahi, fakataha mo e tauhi  Ľo  Ľene fanga sipi?  
\q2  ĽOku  Ľi fńď ia  Ľaia na Ľe  Ľai kiate ia hono LaumńĀlie mńĀ Ľoni Ľoni?   
\q1
\v 12 ‚ÄĆ ĽAia na Ľe tataki  Ľakinautolu  Ľaki  Ľae nima to Ľomata Ľu  Ľo MŇćsese,  Ľaki  Ľa hono nima nńĀunau Ľia,  
\q2  Ľo vahe Ľi  Ľae vai  Ľi honau  Ľao,  
\q2 ke ngaohi mo Ľona ha huafa ta Ľengata?   
\q1
\v 13 ‚ÄĆ ĽAia na Ľe tataki  Ľakinautolu  Ľi he moana,  
\q2  Ľo hangńď ko e hoosi  Ľi he toafa,  
\q2 koe Ľuhi ke  Ľoua te nau tŇękia?‚ÄĚ   
\q1
\v 14 ‚ÄĆ ĽO hangńď ko e  Ľalu hifo  Ľae fanga manu ki he vaha Ľa mo Ľunga,  
\q2 na Ľe ngaohi ia  Ľe he LaumńĀlie  Ľo Sihova ke mńĀlŇćlŇć:  
\q2 na Ľe pehńď ho Ľo tataki  Ľa ho Ľo kakai, ke ngaohi mo Ľou ha huafa ongoongolelei.   
\q1
\v 15 ‚ÄĆ ĽAfio hifo mei he langi,  
\q2 pea vakai mei he  Ľafio Ľanga  Ľo ho Ľo mńĀ Ľoni Ľoni pea mo ho nńĀunau:  
\q1 kofa ĽńĀ ia ho Ľo  Ľofa mo ho Ľo mńĀfimafi,  
\q2  Ľae ngaue  Ľo ho Ľo manava Ľofa pea mo ho Ľo ngaahi  Ľalo Ľofa kiate au? Kuo ke ta Ľofi ia?   
\q1
\v 16 Ko e mo Ľoni ko  Ľemau tamai koe,  
\q2 neongo  Ľoku ta Ľe Ľilo  Ľakimautolu  Ľe  ĽEpalahame,  
\q2 pea ta Ľetokanga Ľi  Ľakimautolu  Ľe  ĽIsileli:  
\q1 ko koe,  ĽE Sihova, ko  Ľemau tamai,  
\q2 ko homau huhu Ľi; talu mei mu Ľa  Ľoku ta Ľetupu  Ľa ho huafa.   
\q1
\v 17 ‚ÄĆ ĽE Sihova, ko e hńĀ kuo ke tuku ai  Ľakimautolu ke mau hńď mei ho ngaahi hala,  
\q2 pea fakafefeka homau loto ke  Ľoua te mau manavahńď kiate koe?  
\q1 Toe tafoki mai koe Ľuhi ko ho Ľo kau tamaio Ľeiki,  
\q2 ko e ngaahi fa Ľahinga  Ľo ho tofi Ľa.   
\q1
\v 18 Kuo ma Ľu fuonounou pe ia  Ľe he kakai  Ľa ho Ľo mńĀ Ľoni Ľoni:  
\q2 kuo molomoloki  Ľe homau ngaahi fili  Ľa ho fale tapu.   
\q1
\v 19 ‚ÄĆ ĽOku  Ľa Ľau  Ľakimautolu: na Ľe  Ľikai  Ľaupito te ke pule Ľi  Ľakinautolu;  
\q2 na Ľe  Ľikai ui  Ľaki  Ľakinautolu  Ľa ho huafa.   
\c 64  
\cd \it 1  ĽOku hŇę  Ľae siasi ke hńĀ  Ľae mńĀlohi  Ľoe  ĽOtua. 5  ĽI he manatu ki he  Ľalo Ľofa  Ľoe  ĽOtua,  Ľoku fakahńĀ ia  Ľae kovi  Ľoe loto ta Ľeliliu. 9  ĽOku lńĀunga ia  Ľi he Ľenau mamahi.\it*  
\q1
\v 1 TaumaińĀ ke ke hae Ľi  Ľae ngaahi langi,  
\q2 koe Ľuhi ke ke hńĀ Ľele hifo,  
\q2 koe Ľuhi ke tafe hifo  Ľae ngaahi mo Ľunga  Ľi ho Ľo  Ľafio mai.   
\q1
\v 2 ‚ÄĆ ĽO hangńď  Ľoku ulo  Ľae afi vela,  
\q2  Ľoku ngaohi  Ľe he afi  Ľae vai ke lili,  
\q1 ke pehńď ho Ľo fakahńĀ ho huafa ki ho ngaahi fili,  
\q2 koe Ľuhi ke tetetete  Ľae ngaahi pule Ľanga  Ľi ho  Ľao!   
\q1
\v 3 ‚ÄĆ ĽI ho Ľo fai  Ľae ngaahi me Ľa fakamanavahńď  Ľaia na Ľe  Ľikai te nau  Ľamanaki ki ai,  
\q2 na Ľa ke hńĀ Ľele hifo, na Ľe tafe hifo  Ľae ngaahi mo Ľunga  Ľi ho  Ľao  Ľi ho Ľo  Ľafio mai.   
\q1
\v 4 He talu  Ľae kamata Ľanga  Ľo mńĀmani  Ľoku te Ľeki fanongo,  
\q2 pe ongo Ľi  Ľe he telinga,  
\q2 pe mamata  Ľe ha mata, ki ha  ĽOtua mo koe,  
\q2  Ľaia kuo ne fai  Ľae ngaahi me Ľa pehńď ni ma Ľanautolu  Ľoku tatali kiate ia.   
\q1
\v 5 ‚ÄĆ ĽOku ke fakafetaulaki kiate ia  Ľoku fiefia pea fai mńĀ Ľoni Ľoni,  
\q2 kiate kinautolu  Ľoku manatu kiate koe  Ľi ho ngaahi hala:  
\q1 vakai,  Ľoku ke houhau; he kuo mau fai angahala:  
\q2 ka  Ľoku tu Ľuma Ľu \add  Ľena\add*,  
\q2 pea te mau mo Ľui.   
\q1
\v 6 ‚ÄĆ ĽOku mau tatau kotoa pńď mo e ta Ľema Ľa,  
\q2 pea  Ľoku tatau  Ľemau mńĀ Ľoni Ľoni kotoa pńď mo e ngaahi konga holoholo fakalielia;  
\q1 pea  Ľoku mau mae kotoa pńď  Ľo hangńď ko e lou Ľakau;  
\q2 pea ko  Ľemau ngaahi hia,  Ľo hangńď ko e matangi, kuo ne  ĽńĀvea  Ľakimautolu.   
\q1
\v 7 Pea  Ľoku  Ľikai ha taha  Ľoku ui ki ho huafa,  
\q2 pe ue Ľi  Ľe ia ia ke puke kiate koe:  
\q1 he kuo ke fufŇę ho fofonga  Ľiate kimautolu,  
\q2 pea kuo faka Ľauha  Ľakimautolu, koe Ľuhi ko  Ľemau ngaahi hia.   
\b  
\q1
\v 8 Ka ko eni,  ĽE Sihova, ko koe ko  Ľemau tamai;  
\q2 ko e  Ľumea  Ľakimautolu, pea ko homau ngaohi koe:  
\q2 pea ko e ngńĀue  Ľa ho nima  Ľakimautolu kotoa pńď.   
\q1
\v 9 ‚ÄĆ ĽOua na Ľa ke houhau lahi,  ĽE Sihova,  
\q2 pe manatu ma Ľuaipńď ki he hia:  
\q1 vakai, pea  Ľafio Ľi,  Ľoku mau kole kiate koe,  
\q2 he ko ho Ľo kakai  Ľakimautolu kotoa pńď.   
\q1
\v 10 Kuo hoko ko e toafa  Ľa ho Ľo ngaahi kolo mńĀ Ľoni Ľoni,  
\q2 ko e potu li Ľaki  Ľa Saione,  
\q2 kuo  Ľauha  Ľa SelŇęsalema.   
\q1
\v 11 Kuo vela  Ľi he afi  Ľa homau fale matamata  Ľeiki mo mńĀ Ľoni Ľoni,  
\q2  Ľaia na Ľe fakamńĀlŇć ai kiate koe  Ľa  Ľemau ngaahi tamai:  
\q2 pea kuo maumau  Ľemau ngaahi me Ľa lelei kotoa pńď.   
\q1
\v 12 Te ke ta Ľofi koe,  ĽE Sihova, koe Ľuhi ko e ngaahi me Ľa ni?  
\q2 Te ke fakalongo pe, pea fakamamahi lahi  Ľakimautolu?   
\c 65  
\cd \it 1 Ko e ui  Ľoe kakai Senitaile. 2 Kuo li Ľaki  Ľae kakai Siu, ko e me Ľa  Ľi he Ľenau ta Ľetui, mo e lotu ki he tamapua, mo e mńĀlualoi. 8 Ko e toenga kakai  Ľe mo Ľui. 11 Ko e ngaahi tautea ki he angakovi, mo e ngaahi tńĀpuaki ki ho anga faka Ľotua. 17 Ko e monŇę Ľia  Ľoe SelŇęsalema fo Ľou.\it*  
\q1
\v 1 ‚Äú ĽOku kumi kiate au  Ľakinautolu na Ľe  Ľikai te nau fehu Ľi kiate au;  
\q2 kuo  Ľilo au  Ľekinautolu na Ľe  Ľikai kumi kiate au:  
\q2 na Ľaku pehńď, ‚ÄėVakai kiate au, vakai kiate au,‚Äô ki he pule Ľanga na Ľe  Ľikai ke ui  Ľaki hoku huafa.   
\q1
\v 2 Kuo u mafao atu hoku nima  Ľi he  Ľaho kotoa ki he kakai angatu Ľu,  
\q2  Ľaia  Ľoku  Ľeve Ľeva  Ľi he hala  Ľoku  Ľikai lelei,  
\q2  Ľo hangńď ko  Ľenau ngaahi filio Ľi:   
\q1
\v 3 Ko e kakai  Ľoku fakahouhau kiate au ma Ľuaipńď ki hoku fofonga;  
\q2  Ľoku fai feilaulau  Ľi he ngaahi ngoue,  
\q2 pea  Ľoku tutu  Ľae me Ľa namu kakala  Ľi he ngaahi  Ľesi maka Ľumea;   
\q1
\v 4 ‚ÄĆ ĽAkinautolu  Ľoku nofo  Ľi he ngaahi tanu Ľanga,  
\q2 pea  Ľi he ngaahi fale mńĀ Ľolunga,  
\q1  Ľoku kai  Ľae kakano  Ľoe puaka,  
\q2 pea ko e vaihŇę  Ľoe ngaahi me Ľa fakalielia  Ľoku  Ľi he  Ľenau ngaahi ipu;   
\q1
\v 5 ‚ÄĆ ĽAkinautolu  Ľoku pehńď, ‚ÄėTu Ľu tokotaha pe koe,  
\q2  Ľoua  Ľe ha Ľu ke ofi kiate au;  
\q2 he  Ľoku ou mńĀ Ľoni Ľoni hake  Ľiate koe.‚Äô  
\q1 Ko e  Ľohuafi  Ľakinautolu ni  Ľi hoku fofonga,  
\q2 ko e afi  Ľoku ulo  Ľi he  Ľaho kotoa pńď.   
\q1
\v 6 ‚ÄúVakai,  Ľoku tohi  Ľi hoku  Ľao:  
\q2  ĽE  Ľikai te u fakalongo pe,  
\q2 ka te u totongi,  
\q2  Ľio,  Ľe ai  Ľae totongi ki honau fatafata.   
\q1
\v 7 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚ÄúKo ho Ľomou angahia, mo e angahala  Ľa ho Ľomou ngaahi tamai fakataha,  
\q2  Ľakinautolu kuo tutu  Ľae me Ľa namu kakala  Ľi he ngaahi mo Ľunga,  
\q2 pea kape kiate au  Ľi he ngaahi potu tafungofunga:  
\q2 ko ia te u fua  Ľa  Ľenau mu Ľaki ngńĀue ki honau fatafata.   
\q1
\v 8 ‚ÄĆ ĽOku pehńď  Ľe Sihova,  
\q1 ‚Äú ĽO hangńď  Ľoku  Ľilo  Ľae uaine fo Ľou  Ľi he fuhi,  
\q2 pea  Ľoku pehńď  Ľe ha taha, ‚Äė Ľoua  Ľe faka Ľauha ia; he  Ľoku  Ľi ai ha tńĀpuaki;‚Äô  
\q1 te u fai pehńď koe Ľuhi ko  Ľeku kau tamaio Ľeiki,  
\q2 koe Ľuhi ke  Ľoua na Ľaku faka Ľauha  Ľakinautolu kotoa pńď.   
\q1
\v 9 Pea te u  Ľomi ha hako meia Sńďkope,  
\q2 pea mei Siuta ha taha ke ma Ľu hoku ngaahi mo Ľunga:  
\q1 pea  Ľe ma Ľu ia  Ľe hoku kakai fili,  
\q2 pea  Ľe nofo ai  Ľa  Ľeku kau tamaio Ľeiki.   
\q1
\v 10 Pea  Ľe hoko  Ľa Saloni ko e loto  ĽńĀ  Ľae fanga sipi,  
\q2 pea ko e tele Ľa  Ľo  ĽAkoli ko e tokoto Ľanga  Ľoe fanga manu,  
\q2 ma Ľa hoku kakai  Ľaia kuo kumi kiate au.   
\q1
\v 11 ‚ÄúKa ko kimoutolu kuo mou li Ľaki  Ľa Sihova,  
\q2 kuo fakangalongalo Ľi hoku mo Ľunga tapu,  
\q2  Ľoku mou teuteu ha keinanga Ľanga ma Ľa Kata,  
\q2 pea  Ľoku  Ľatu  Ľae feilaulau inu kia Meni.   
\q1
\v 12 Ko ia te u lau ai  Ľakimoutolu ki he heletńĀ,  
\q2 pea te mou punou kotoa pńď ki he tńĀmate Ľi:  
\q1 koe Ľuhi  Ľi he Ľeku ui, na Ľe  Ľikai te mou tali;  
\q2  Ľi he Ľeku lea, na Ľe  Ľikai te mou fanongo;  
\q1 ka na Ľa mou fai kovi  Ľi hoku  Ľao,  
\q2 mo fili  Ľaia na Ľe  Ľikai te u fiemńĀlie ai.   
\b  
\q1
\v 13 Ko ia  Ľoku pehńď  Ľe he  ĽOtua ko Sihova,  
\q1 ‚ÄúVakai,  Ľe kai  Ľe he Ľeku kau tamaio Ľeiki,  
\q2 ka te mou fiekaia:  
\q1 vakai,  Ľe inu  Ľe he Ľeku kau tamaio Ľeiki,  
\q2 ka te mou fieinua:  
\q1 vakai,  Ľe fiefia  Ľeku kau tamaio Ľeiki,  
\q2 ka e mńĀ  Ľakimoutolu.   
\q1
\v 14 Vakai,  Ľe hivehiva  Ľeku kau tamaio Ľeiki koe Ľuhi ko e fiefia  Ľoe loto,  
\q2 ka te mou tangi koe Ľuhi ko e mamahi  Ľoe loto,  
\q2 pea  Ľe tangilńĀulau  Ľi he mamahi  Ľoe laumńĀlie.   
\q1
\v 15 Pea te mou tuku homou hingoa ko e fakamamahi kiate kinautolu kuo u fili:  
\q2 koe Ľuhi  Ľe tńĀmate Ľi  Ľakimoutolu  Ľe he  ĽEiki ko Sihova,  
\q1 pea ui  Ľene kau tamaio Ľeiki  Ľaki ha hingoa kehe:   
\q2
\v 16 Koe Ľuhi ko ia  Ľoku ne tńĀpuaki ia  Ľi he fonua te ne tńĀpuaki ia  Ľi he  ĽOtua  Ľoe mo Ľoni;  
\q2 pea ko ia  Ľoku fuakava  Ľi he fonua te ne fuakava  Ľi he  ĽOtua  Ľoe mo Ľoni;  
\q1 koe Ľuhi kuo fakangalo  Ľae ngaahi mu Ľaki mamahi,  
\q2 pea koe Ľuhi kuo fakafufŇę ia mei hoku fofonga.   
\b  
\q1
\v 17 ‚ÄúVakai, he  Ľoku ou fakatupu  Ľae ngaahi langi fo Ľou pea mo e fonua fo Ľou:  
\q2 pea  Ľe  Ľikai manatu  Ľaia na Ľe  Ľi mu Ľa,  
\q2 pe ai ha manatu loto ki ai.   
\q1
\v 18 Ka ke fiefia  Ľakimoutolu pea nekeneka  Ľo ta Ľengata  Ľi he me Ľa  Ľoku ou fakatupu:  
\q2 he vakai,  Ľoku ou ngaohi  Ľa SelŇęsalema ko e fiefia Ľanga,  
\q2 pea ke fiefia  Ľa hono kakai.   
\q1
\v 19 Pea te u fiefia ia SelŇęsalema,  
\q2 pea nekeneka  Ľi hoku kakai:  
\q1 pea  Ľe  Ľikai ha toe fanongo ki ha le Ľo  Ľoe tangi  Ľiate ia,  
\q2 pe ko e le Ľo  Ľoe tangi mamahi.   
\b  
\q1
\v 20 ‚Äú ĽE  Ľikai toe  Ľai  Ľi ai ha tamasi Ľi  Ľoku mo Ľui fuonounou,  
\q2 pe ko ha tangata motu Ľa  Ľoku ta Ľekakato hono ngaahi  Ľaho:  
\q1 he ko ia  Ľe mate  Ľi hono teau ta Ľu  Ľe mate ko e tamasi Ľi pe;  
\q2 pea ko e tangata angahala  Ľoku mate  Ľi hono teau ta Ľu  Ľe mala Ľia ia.   
\q1
\v 21 Pea te nau langa  Ľae ngaahi fale, pea nofo ai;  
\q2 pea te nau tŇć  Ľae ngaahi vaine, pea kai  Ľae fua  Ľo ia.   
\q1
\v 22 ‚ÄĆ ĽE  Ľikai te nau langa, kae nofo ai ha taha kehe;  
\q2  Ľe  Ľikai te nau tŇć, kae kai  Ľe ha taha kehe:  
\q1 he  Ľoku hangńď ko e ngaahi  Ľaho  Ľoe  Ľakau  Ľoku pehńď  Ľae ngaahi  Ľaho  Ľo hoku kakai,  
\q2 pea  Ľe lelei Ľia fuoloa  Ľae kakai kuo u fili  Ľi he ngńĀue  Ľa honau nima.   
\q1
\v 23 ‚ÄĆ ĽE  Ľikai te nau ngńĀue ta Ľe Ľaonga,  
\q2 pe fanau Ľi ki he mamahi;  
\q1 he ko e hako  Ľakinautolu kuo monŇę Ľia  Ľia Sihova,  
\q2 pea mo  Ľenau fńĀnau fakataha mo kinautolu.   
\q1
\v 24 Pea  Ľe hoko  Ľo pehńď,  Ľi he te Ľeki te nau ui, te u tali;  
\q2 pea  Ľi he lolotonga  Ľenau lea, te u ongo Ľi.   
\q1
\v 25 ‚ÄĆ ĽOku pehńď  Ľe Sihova,  
\q2 ‚Äú ĽE kai fakataha  Ľae ulofi mo e lami,  
\q2 pea  Ľe kai  Ľe he laione  Ľae kau  Ľoe koane  Ľo hangńď ko e pulu:  
\q2 pea ko e me Ľakai  Ľoe ngata ko e efu.  
\q2  ĽE  Ľikai te nau fakamamahi pe faka Ľauha  Ľi \add ha potu  Ľo \add*hoku mo Ľunga mńĀ Ľoni Ľoni kotoa pńď.‚ÄĚ   
\c 66  
\cd \it 1 Ke tauhi  Ľae  ĽOtua lńĀngilangi  Ľi he angavaivai mo e mo Ľoni 5  ĽOku ne fakafiemńĀlie ki he angavaivai  Ľaki  Ľae to Ľutangata fakaofo, 10 Pea mo e ngaahi tńĀpuaki ki he siasi. 15 Ko e fakamaau mńĀsila  Ľae  ĽOtua ki he kakai angahala. 19  ĽE ma Ľu  Ľe he Senitaile  Ľae siasi mńĀ Ľoni Ľoni, 24 Pea te nau mamata ki he fakamala Ľia  Ľoe kakai angahala.\it*  
\q1
\v 1 ‚ÄĆ ĽOku pehńď  Ľe Sihova,  
\q1 ‚ÄúKo hoku  Ľafio Ľanga  Ľae langi, pea ko hoku tu Ľu Ľanga va Ľe  Ľa mńĀmani:  
\q2 kofa ĽńĀ ia  Ľae fale  Ľoku mou langa kiate au?  
\q2 Pea kofa ĽńĀ ia  Ľae potu  Ľo  Ľeku mńĀlŇćlŇć?   
\q1
\v 2 He  Ľoku pehńď  Ľe Sihova, ‚ÄúKo e ngaahi me Ľa na kotoa pńď na Ľe ngaohi  Ľe hoku nima,  
\q2 pea kuo  Ľi ai pe  Ľae ngaahi me Ľa ko ia:  
\q1 ka te u vakai ki he tangata ni,  
\q2  Ľio, kiate ia  Ľoku masiva pea  Ľoku loto fakatomala mo Ľoni,  
\q2 pea  Ľoku tetetete  Ľi he Ľeku folofola.   
\q1
\v 3 Ko ia  Ľoku ne tńĀmate Ľi  Ľae pulu  Ľoku hangńď ia kuo ne tńĀmate Ľi ha tangata;  
\q2 ko ia  Ľoku ne feilaulau  Ľaki ha lami,  Ľo hangńď kuo ne tu Ľusi ke motu  Ľae kia  Ľoe kulńę;  
\q2 ko ia  Ľoku ne  Ľatu ha feilaulau,  Ľoku hangńď kuo ne  Ľatu  Ľae toto  Ľoe puaka;  
\q2 ko ia  Ľoku ne tutu  Ľae me Ľa namu kakala,  Ľo hangńď kuo ne tńĀpuaki ha tamapua.  
\q1  ĽIo, kuo nau fili honau ngaahi hala,  
\q2 pea  Ľoku fiefia honau laumńĀlie  Ľi he Ľenau ngaahi me Ľa fakalielia.   
\q1
\v 4 Pea ko au foki te u tu Ľutu Ľuni  Ľenau ngaahi mamahi,  
\q2 pea ko e me Ľa  Ľoku nau manavahńď ki ai te u  Ľomi kiate kinautolu;  
\q1 koe Ľuhi  Ľi he Ľeku ui, na Ľe  Ľikai tali  Ľe ha tokotaha  Ľi he Ľeku lea,  
\q2 na Ľe  Ľikai te nau fanongo,  
\q1 kńĀ na Ľa nau fai kovi  Ľi hoku  Ľao,  
\q2 pea na Ľa nau fili  Ľaia na Ľe  Ľikai te u fiemńĀlie ai.‚ÄĚ   
\b  
\q1
\v 5 Fanongo ki he folofola  Ľa Sihova,  
\q2  Ľakimoutolu  Ľoku tetetete ki he Ľene folofola;  
\q1 ‚ÄúKo homou ngaahi kńĀinga na Ľe fehi Ľa kiate kimoutolu,  
\q2  Ľo kapusi kitu Ľa  Ľakimoutolu koe Ľuhi ko hoku huafa,  
\q1 na Ľa nau pehńď, ‚ÄėKe ongoongolelei Ľia  Ľa Sihova:  
\q2 ka e  Ľafio ia ko homou fakafiefia,‚Äô  
\q2 pea  Ľe mńĀ  Ľakinautolu.   
\q1
\v 6 Ko e le Ľo  Ľoe longoa Ľa mei he kolo,  
\q2 ko e le Ľo mei he falelotu lahi,  
\q2 ko e le Ľo  Ľo Sihova  Ľaia  Ľoku ne totongi totonu ki hono ngaahi fili.   
\b  
\q1
\v 7 ‚Äú ĽI he te Ľeki ai ke langńĀ, na Ľa ne fńĀ Ľele Ľi,  
\q2  Ľi he te Ľeki ai ke mamahi ia, na Ľe fńĀ Ľele Ľi ia  Ľae tamasi Ľi tangata.   
\q1
\v 8 Ko hai kuo ne fanongo ki ha me Ľa pehńď?  
\q2 Ko hai kuo ne mamata ki he ngaahi me Ľa pehńď?  
\q1  ĽE fa Ľa ngaohi  Ľa mńĀmani ke fanau Ľi  Ľi he  Ľaho pe taha?  
\q2 Pe  Ľe fanau Ľi fakafokifńĀ ha pule Ľanga?  
\q1 He na Ľe kamata langa pe  Ľa Saione,  
\q2 pea fanau Ľi leva  Ľa  Ľene fńĀnau.   
\q1
\v 9 ‚ÄĆ ĽOku pehńď  Ľe Sihova, He te u  Ľomi ke fanau Ľi, ka e  Ľikai te u ngaohi ke fńĀ Ľele?‚ÄĚ  ĽOku pehńď  Ľe ho  ĽOtua,  
\q2 He te u ngaohi ke fńĀnau,  
\q2 kae tńĀpuni \add  Ľae manńĀva\add*?   
\q1
\v 10 ‚ÄúKe fiefia  Ľakimoutolu mo SelŇęsalema, pea nekeneka mo ia,  Ľakimoutolu kotoa pńď  Ľoku  Ľofa kiate ia:  
\q2 mou fiefia  Ľi he fiefia mo ia,  Ľakimoutolu kotoa pńď  Ľoku mamahi koe Ľuhi ko ia:   
\q1
\v 11 Koe Ľuhi ke mou huhu, pea mńĀkona  Ľi he hu Ľahuhu  Ľo  Ľene fakafiemńĀlie?  
\q2 Koe Ľuhi ke mou mimisi,  
\q2 pea fiefia  Ľi hono lahi  Ľo hono nńĀunau.   
\b  
\q1
\v 12 He  Ľoku pehńď  Ľe Sihova, ‚ÄúVakai, te u tuku  Ľae melino kiate ia  Ľo hangńď ko e vaitafe,  
\q2 pea ko e nńĀunau  Ľoe Senitaile  Ľo hangńď ko e vaitafe laulahi:  
\q2 pea te mou toki huhu,  
\q1  Ľe fua  Ľakimoutolu  Ľi hono vakavaka,  
\q2 pea lulululu  Ľe hono ongo tui.   
\q1
\v 13 ‚ÄĆ ĽO hangńď ko e tokotaha  Ľoku fakafiemńĀlie ki ai  Ľene fa Ľńď,  
\q2  Ľe pehńď  Ľeku fakafiemńĀlie kiate koe;  
\q2 pea  Ľe fakafiemńĀlie Ľi  Ľakimoutolu  Ľi SelŇęsalema.‚ÄĚ   
\q1
\v 14 Pea ka mou ka mamata ki he me Ľa ni,  Ľe fiefia homou loto,  
\q2 pea mo Ľui homou hui  Ľo hangńď ko e  Ľakau mata:  
\q1 pea  Ľe hńĀ  Ľae nima  Ľo Sihova ki he Ľene kau tamaio Ľeiki,  
\q2 mo hono houhau ki hono ngaahi fili.   
\q1
\v 15 Kae vakai,  Ľe hńĀ Ľele mai  Ľa Sihova mo e afi,  
\q2 pea hangńď ko e  Ľahiohio  Ľa  Ľene ngaahi saliote,  
\q1 ke  Ľatu hono houhau  Ľi he mńĀlohi,  
\q2 pea mo  Ľene valoki  Ľaki  Ľae ulo  Ľoe afi.   
\q1
\v 16 Koe Ľuhi  Ľe fai  Ľe Sihova mo e kakano kotoa pńď  Ľaki  Ľae afi mo  Ľene heletńĀ:  
\q2 pea ko e tokolahi  Ľe tńĀmate Ľi  Ľe Sihova.   
\p
\v 17 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚Äú ĽE  Ľauha fakataha,  Ľakinautolu  Ľoku teuteu mo fakama Ľa  Ľakinautolu  Ľi he ngoue  Ľi he tu Ľa \add  Ľakau  Ľe taha \add* Ľi he lotolotonga,  Ľo kai  Ľae kakano  Ľoe puaka, pea mo e me Ľa fakalielia, pea mo e kumńĀ.   
\p
\v 18 ‚ÄúHe  Ľoku ou  Ľilo  Ľenau ngaahi ngńĀue pea mo  Ľenau ngaahi mahalo:  Ľe hoko  Ľo pehńď, te u tńĀnaki  Ľae ngaahi pule Ľanga kotoa pńď mo e lea kehekehe kotoa pńď; pea te nau ha Ľu,  Ľo mamata ki hoku nńĀunau.   
\p
\v 19 ‚ÄúPea te u ai ha faka Ľilonga  Ľiate kinautolu, pea te u fekau  Ľakinautolu  Ľoku hao  Ľiate kinautolu ki he ngaahi pule Ľanga, ki Tasisi, mo Puli, mo Luti,  Ľakinautolu  Ľoku teke  Ľae kaufana, ki Tupale, mo Savani, ki he ngaahi motu mama Ľo,  Ľaia  Ľoku te Ľeki ai ke fanongo ki hoku ongoongo, pea te Ľeki ai ke mamata ki hoku nńĀunau; pea te nau fakahńĀ hoku nńĀunau ki he kakai Senitaile.   
\p
\v 20 Pea  Ľoku pehńď  Ľe Sihova, te nau  Ľomi homou ngaahi kńĀinga kotoa pńď ko e feilaulau kia Sihova mei he pule Ľanga kotoa pńď  Ľi he fanga hoosi, pea  Ľi he ngaahi me Ľa teka, pea  Ľi he me Ľa fata, pea  Ľi he fanga miuli, pea  Ľi he fanga manu ve Ľe vave, ki hoku mo Ľunga tapu ko SelŇęsalema,  Ľo hangńď na Ľe  Ľomi  Ľe he fńĀnau  Ľo  ĽIsileli  Ľae feilaulau  Ľi he ipu ma Ľa ki he fale  Ľo Sihova.   
\p
\v 21 Pea  Ľoku pehńď  Ľe Sihova, ‚ÄúTe u fokotu Ľu  Ľiate kinautolu foki  Ľae kau taula Ľeiki pea mo e kau Livai.‚ÄĚ   
\p
\v 22 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚Äú ĽO hangńď ko e tu Ľuma Ľu  Ľi hoku  Ľao,  Ľae ngaahi langi fo Ľou pea mo e maama fo Ľou,  Ľaia te u ngaohi,  Ľe pehńď  Ľae tu Ľuma Ľu  Ľo homou hako mo homou hingoa.  
\v 23 Pea  Ľoku pehńď  Ľe Sihova, ‚Äú ĽE ha Ľu  Ľae kakai kotoa pńď ke lotu  Ľi hoku  Ľao, mei he mńĀhina fo Ľou  Ľe taha  Ľo a Ľu ki he mńĀhina fo Ľou  Ľe taha, pea mei he  Ľaho tapu  Ľe taha  Ľo a Ľu ki he  Ľaho tapu  Ľe taha.  
\v 24 ‚ÄúPea te nau  Ľalu atu, pea sio ki he ngaahi  Ľanga Ľanga  Ľoe kakai na Ľe angatu Ľu kiate au: koe Ľuhi  Ľe  Ľikai mate honau  Ľuanga, pea  Ľe  Ľikai tńĀmate Ľi  Ľenau afi; pea te nau hoko ko e fehi Ľanekina ki he kakai kotoa pńď.‚ÄĚ   