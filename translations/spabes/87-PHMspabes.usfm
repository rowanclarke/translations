\p
\v 11 \w En|strong="G3588"\w* \w otro|strong="G3739"\w* tiempo \w él|strong="G3588"\w* \w te|strong="G4771"\w* fue inútil, \w pero|strong="G1161"\w* \w ahora|strong="G3570"\w* \w es|strong="G3739"\w* \w útil|strong="G2173"\w* \w tanto|strong="G3739"\w* para \w ti|strong="G3739"\w* \w como|strong="G2532"\w* para \w mí|strong="G3588"\w*.   
\p
\v 12 \w Te|strong="G4771"\w* \w lo|strong="G3588"\w* envío \w de|strong="G3588"\w* vuelta. Recíbelo como si recibieras \w mi|strong="G1699"\w* propio corazón.   
\p
\v 13 \w Yo|strong="G1473"\w* hubiera querido retenerlo \w conmigo|strong="G1722"\w*, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w me|strong="G1683"\w* sirviera \w en|strong="G1722"\w* \w tu|strong="G4771"\w* lugar mientras estoy preso \w por|strong="G1722"\w* \w el|strong="G3588"\w* \w evangelio|strong="G2098"\w*.   
\p
\v 14 \w Pero|strong="G1161"\w* \w no|strong="G3361"\w* \w quise|strong="G2309"\w* \w hacer|strong="G4160"\w* \w nada|strong="G3762"\w* \w sin|strong="G5565"\w* \w tu|strong="G4771"\w* consentimiento, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w tu|strong="G4771"\w* buena obra \w no|strong="G3361"\w* \w fuera|strong="G1510"\w* \w por|strong="G2596"\w* obligación, \w sino|strong="G1161"\w* \w por|strong="G2596"\w* \w tu|strong="G4771"\w* propia voluntad.   
\p
\v 15 Tal vez \w por|strong="G1223"\w* \w esto|strong="G3778"\w* \w se|strong="G4314"\w* apartó \w de|strong="G1223"\w* ti \w por|strong="G1223"\w* un \w tiempo|strong="G5610"\w*, \w para|strong="G2443"\w* \w que|strong="G2443"\w* lo recibas \w para|strong="G2443"\w* \w siempre|strong="G1223"\w*,   
\p
\v 16 \w ya|strong="G2089"\w* \w no|strong="G3756"\w* \w como|strong="G5613"\w* esclavo, \w sino|strong="G1161"\w* \w como|strong="G5613"\w* \w más|strong="G1161"\w* \w que|strong="G2532"\w* esclavo: \w como|strong="G5613"\w* hermano amado. \w Él|strong="G1161"\w* lo \w es|strong="G3756"\w* \w mucho|strong="G3756"\w* \w para|strong="G1722"\w* mí, \w pero|strong="G1161"\w* \w cuánto|strong="G4214"\w* \w más|strong="G1161"\w* \w para|strong="G1722"\w* ti, tanto humanamente \w como|strong="G5613"\w* \w en|strong="G1722"\w* \w el|strong="G1161"\w* \w Señor|strong="G2962"\w*.   
\p
\v 17 Así \w que|strong="G3767"\w*, \w si|strong="G1487"\w* \w me|strong="G1473"\w* \w tienes|strong="G2192"\w* \w por|strong="G5613"\w* \w compañero|strong="G2844"\w*, recíbelo \w como|strong="G5613"\w* \w me|strong="G1473"\w* recibirías \w a|strong="G5613"\w* mí.   
\p
\v 18 \w Si|strong="G1487"\w* \w te|strong="G4771"\w* hizo \w algún|strong="G5100"\w* daño, \w o|strong="G2228"\w* \w si|strong="G1487"\w* \w te|strong="G4771"\w* \w debe|strong="G3784"\w* \w algo|strong="G5100"\w*, cárgalo \w a|strong="G1161"\w* mi cuenta.   
\p
\v 19 \w Yo|strong="G1473"\w*, \w Pablo|strong="G3972"\w*, \w escribo|strong="G1125"\w* \w esto|strong="G3588"\w* \w con|strong="G2532"\w* \w mi|strong="G1699"\w* propia \w mano|strong="G5495"\w*: \w yo|strong="G1473"\w* \w lo|strong="G3588"\w* pagaré. \w Por|strong="G3754"\w* \w no|strong="G3361"\w* \w decirte|strong="G3004"\w* \w que|strong="G3754"\w* \w tú|strong="G4771"\w* mismo \w me|strong="G1473"\w* \w debes|strong="G4359"\w* \w aun|strong="G2532"\w* \w tu|strong="G4771"\w* propia vida.   
\p
\v 20 \w Sí|strong="G3483"\w*, hermano, dame \w este|strong="G3588"\w* favor \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w*. Anima \w mi|strong="G3588"\w* corazón \w en|strong="G1722"\w* \w Cristo|strong="G5547"\w*.   
\p
\v 21 \w Te|strong="G4771"\w* \w escribo|strong="G1125"\w* \w confiando|strong="G3982"\w* \w en|strong="G3588"\w* \w tu|strong="G4771"\w* \w obediencia|strong="G5218"\w*, \w sabiendo|strong="G1492"\w* \w que|strong="G3754"\w* \w harás|strong="G4160"\w* \w aun|strong="G2532"\w* \w más|strong="G2532"\w* \w de|strong="G5228"\w* \w lo|strong="G3588"\w* \w que|strong="G3754"\w* \w digo|strong="G3004"\w*.   
\p
\v 22 \w Al|strong="G3588"\w* mismo tiempo, \w prepárame|strong="G2090"\w* \w también|strong="G2532"\w* \w alojamiento|strong="G3578"\w*, \w porque|strong="G1063"\w* \w espero|strong="G1679"\w* \w que|strong="G3754"\w* \w por|strong="G1223"\w* \w las|strong="G3588"\w* \w oraciones|strong="G4335"\w* \w de|strong="G1223"\w* ustedes les seré concedido.   
\p
\v 23 \w Te|strong="G4771"\w* saluda \w Epafras|strong="G1889"\w*, \w mi|strong="G3588"\w* compañero \w de|strong="G1722"\w* prisión \w en|strong="G1722"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w*.   
