\p
\v 15 \w This|strong="G3778"\w* \w you|strong="G3739"\w* \w know|strong="G1492"\w*, \w that|strong="G3754"\w* \w all|strong="G3956"\w* \w those|strong="G3588"\w* \w in|strong="G1722"\w* \w Asia|strong="G3588"\w* \w have|strong="G2532"\w* \w been|strong="G1510"\w* turned away \w from|strong="G2532"\w* \w me|strong="G1473"\w*,\f + \fr 1:15 \ft ‘Turn away’ is in the passive voice; someone was working against Paul, with success.\f* \w including|strong="G2532"\w* \w Phygellus|strong="G5436"\w* \w and|strong="G2532"\w* \w Hermogenes|strong="G2061"\w*.  
\v 16 \w May|strong="G2532"\w* \w the|strong="G2532"\w* \w Lord|strong="G2962"\w* \w grant|strong="G1325"\w* \w mercy|strong="G1656"\w* \w to|strong="G2532"\w* \w the|strong="G2532"\w* \w household|strong="G3624"\w* \w of|strong="G2532"\w* \w Onesiphorus|strong="G3683"\w*, \w because|strong="G3754"\w* \w he|strong="G2532"\w* \w often|strong="G4178"\w* refreshed \w me|strong="G1325"\w* \w and|strong="G2532"\w* \w was|strong="G3588"\w* \w not|strong="G3756"\w* \w ashamed|strong="G1870"\w* \w of|strong="G2532"\w* \w my|strong="G1325"\w* chain;\f + \fr 1:16 \ft Although Paul was granted the privilege of having his own house (Acts 28:16), he wore a chain.\f*  
\v 17 rather, \w when|strong="G2532"\w* \w he|strong="G2532"\w* \w arrived|strong="G1096"\w* \w in|strong="G1722"\w* \w Rome|strong="G4516"\w* \w he|strong="G2532"\w* \w searched|strong="G2212"\w* \w diligently|strong="G4709"\w* \w for|strong="G1722"\w* \w me|strong="G1473"\w* \w until|strong="G2532"\w* \w he|strong="G2532"\w* \w found|strong="G2147"\w* \w me|strong="G1473"\w*  
\v 18 (\w may|strong="G2532"\w* \w the|strong="G1722"\w* \w Lord|strong="G2962"\w* \w grant|strong="G1325"\w* \w to|strong="G2532"\w* \w him|strong="G3588"\w* \w to|strong="G2532"\w* \w find|strong="G2147"\w* \w mercy|strong="G1656"\w* \w from|strong="G3844"\w* \w the|strong="G1722"\w* \w Lord|strong="G2962"\w* \w in|strong="G1722"\w* \w that|strong="G3588"\w* \w Day|strong="G2250"\w*); \w you|strong="G4771"\w* \w also|strong="G2532"\w* \w know|strong="G1097"\w* \w very|strong="G2532"\w* \w well|strong="G2532"\w* \w in|strong="G1722"\w* \w how|strong="G3745"\w* \w many|strong="G3745"\w* ways \w he|strong="G2532"\w* \w served|strong="G1247"\w* \w in|strong="G1722"\w* \w Ephesus|strong="G2181"\w*.   
\c 2  
\s1 Be strengthened  
\m
\v 1 \w So|strong="G3767"\w* \w you|strong="G4771"\w*, \w my|strong="G1722"\w* \w son|strong="G5043"\w*, \w be|strong="G3588"\w* \w strengthened|strong="G1743"\w* \w by|strong="G1722"\w* \w the|strong="G1722"\w* \w grace|strong="G5485"\w* \w that|strong="G3588"\w* \w is|strong="G3588"\w* \w in|strong="G1722"\w* \w Christ|strong="G5547"\w* \w Jesus|strong="G2424"\w*.  
\v 2 \w Also|strong="G2532"\w*, \w the|strong="G2532"\w* \w things|strong="G3778"\w* \w that|strong="G3739"\w* \w you|strong="G3739"\w* \w have|strong="G2532"\w* heard \w from|strong="G3844"\w* \w me|strong="G1473"\w* \w among|strong="G3844"\w* \w many|strong="G4183"\w* \w witnesses|strong="G3144"\w*, \w commit|strong="G3908"\w* \w the|strong="G2532"\w* \w same|strong="G3778"\w* \w to|strong="G2532"\w* \w faithful|strong="G4103"\w* \w men|strong="G3778"\w* \w who|strong="G3739"\w* \w will|strong="G1510"\w* \w be|strong="G1510"\w* \w competent|strong="G2425"\w* \w to|strong="G2532"\w* \w teach|strong="G1321"\w* \w others|strong="G2087"\w* \w also|strong="G2532"\w*.\f + \fr 2:2 \ft The future of the Church depends on this.\f*   
\p
\v 3 \w You|strong="G5613"\w* therefore \w are|strong="G5547"\w* \w to|strong="G2424"\w* endure \w hardship|strong="G4777"\w* \w as|strong="G5613"\w* \w a|strong="G5613"\w* \w good|strong="G2570"\w* \w soldier|strong="G4757"\w* \w of|strong="G2424"\w* \w Jesus|strong="G2424"\w* \w Christ|strong="G5547"\w*.\f + \fr 2:3 \ft When we complain about our circumstances, are we forgetting that we are soldiers?\f*  
