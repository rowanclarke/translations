\id SNG
\h Pieśń nad Pieśniami
\toc1 Pieśń nad Pieśniami
\toc2 Pieśń nad Pieśniami
\toc3 Pnp
\mt1 Pieśń nad Pieśniami
\c 1
\m 
\v 1 Pieśń nad pieśniami Salomona.
\m 
\v 2 Niech mnie pocałuje pocałunkami swoich ust. Twoja miłość bowiem jest lepsza od wina.
\m 
\v 3 Z powodu wonności twoich olejków twoje imię \add jest jak\add* rozlany olejek; dlatego miłują cię dziewice.
\m 
\v 4 Pociągnij mnie, \add a\add* pobiegniemy za tobą. Król wprowadził mnie \add do\add* swoich komnat. Będziemy się cieszyć i radować tobą, będziemy pamiętać o twojej miłości bardziej niż o winie. Miłują cię prawi.
\m 
\v 5 Czarna jestem, ale piękna, o córki Jerozolimy, jak namioty Kedaru, jak zasłony Salomona.
\m 
\v 6 Nie patrzcie na mnie, że jestem czarna, gdyż słońce mnie opaliło. Synowie mojej matki rozgniewali się na mnie, postawili mnie na straży winnic; a mojej własnej winnicy nie ustrzegłam.
\m 
\v 7 Powiedz mi \add ty\add*, którego miłuje moja dusza, gdzie wypasasz, gdzie dajesz swojej \add trzodzie\add* odpocząć w południe. Czemu bowiem mam być jak błądząca przy trzodach twoich towarzyszy?
\m 
\v 8 Jeśli nie wiesz, najpiękniejsza wśród kobiet, to idź śladem trzody i paś swoje koźlątka przy szałasach pasterzy.
\m 
\v 9 Przyrównam cię, moja umiłowana, do zaprzęgu rydwanów faraona.
\m 
\v 10 Twoje lica są piękne, ozdobione klejnotami, \add a\add* twoja szyja – łańcuchami.
\m 
\v 11 Uczynimy ci złote klejnoty nakrapiane srebrem.
\m 
\v 12 Dopóki król jest przy \add swoim\add* stole, mój nard rozsiewa swoją woń.
\m 
\v 13 \add Jak\add* wiązka mirry jest dla mnie mój miły, spoczywa na moich piersiach.
\m 
\v 14 Mój miły jest dla mnie \add jak\add* grono cyprysu pośród winnic w En-Gedi.
\m 
\v 15 O jaka ty jesteś piękna, moja umiłowana! O jaka ty jesteś piękna! Twoje oczy są \add jak oczy\add* gołębicy.
\m 
\v 16 O jaki ty jesteś piękny, mój umiłowany, i jak miły! Łoże nasze się zieleni.
\m 
\v 17 Belki naszego domu są cedrowe, a nasze stropy – cyprysowe.
\c 2
\m 
\v 1 Jestem różą Saronu i lilią dolin.
\m 
\v 2 Jak lilia między cierniami, tak moja umiłowana między pannami.
\m 
\v 3 Jak jabłoń między leśnymi drzewami, tak mój miły między młodzieńcami. Z wielkim pragnieniem usiadłam w jego cieniu, a jego owoc \add jest\add* słodki memu podniebieniu.
\m 
\v 4 Wprowadził mnie do komnaty biesiadnej, a jego chorągwią nade mną jest miłość.
\m 
\v 5 Pokrzepcie mnie bukłakami, posilcie mnie jabłkami, bo jestem chora z miłości.
\m 
\v 6 Jego lewa ręka pod moją głową, a jego prawa ręka mnie obejmuje.
\m 
\v 7 Zaklinam was, córki Jerozolimy, na sarny i łanie polne: Nie budźcie mego umiłowanego i nie przerywajcie \add jego\add* snu, dopóki nie zechce.
\m 
\v 8 Głos mego umiłowanego! Oto idzie, skacząc po górach, a podskakując po pagórkach.
\m 
\v 9 Mój umiłowany podobny jest do sarny albo młodego jelenia. Oto stoi za naszym murem, zagląda przez okna, patrzy przez kraty.
\m 
\v 10 Mój umiłowany odezwał się i powiedział mi: Wstań, moja umiłowana, moja piękna, i chodź!
\m 
\v 11 Oto bowiem minęła zima, deszcz ustał i przeszedł.
\m 
\v 12 Kwiatki pokazały się na ziemi, nadszedł czas śpiewania i głos synogarlicy słychać w naszej ziemi.
\m 
\v 13 Drzewo figowe już wypuściło swoje niedojrzałe figi, a kwitnąca winorośl wydaje swoją woń. Wstań, moja umiłowana, moja piękna, i chodź!
\m 
\v 14 Moja gołębico, \add mieszkająca\add* w skalnych szczelinach, w stromych kryjówkach, ukaż mi swoją twarz, daj mi usłyszeć swój głos, gdyż twój głos jest słodki i twoja twarz piękna.
\m 
\v 15 Schwytajcie nam lisy, małe lisy, które psują winnice, ponieważ nasze winnice kwitną.
\m 
\v 16 Mój umiłowany \add jest\add* mój, a ja jestem jego. Pasie on wśród lilii.
\m 
\v 17 Nim zaświta dzień i znikną cienie, zawróć, mój umiłowany, bądź jak sarna albo młode jelenie na górach Beter.
\c 3
\m 
\v 1 Na swoim łożu wśród nocy szukałam tego, którego miłuje moja dusza. Szukałam go, ale go nie znalazłam.
\m 
\v 2 Wstanę więc już i obiegnę miasto, po ulicach i placach będę szukać tego, którego miłuje moja dusza. Szukałam go, ale nie znalazłam.
\m 
\v 3 Znaleźli mnie strażnicy, którzy obchodzili miasto, i \add spytałam\add*: Widzieliście tego, którego miłuje moja dusza?
\m 
\v 4 A gdy ledwie od nich odeszłam, zaraz znalazłam tego, którego miłuje moja dusza. Uchwyciłam go i nie puszczę, aż go wprowadzę do domu mojej matki, do pokoju mojej rodzicielki.
\m 
\v 5 Zaklinam was, córki Jerozolimy, na sarny i łanie polne: Nie budźcie mego umiłowanego i nie przerywajcie \add jego\add* snu, dopóki nie zechce.
\m 
\v 6 Kim jest ta, która wyłania się z pustyni jak słupy dymu, owiana wonią mirry i kadzidła oraz wszelkim wonnym proszkiem od kupca?
\m 
\v 7 Oto łoże Salomona, dokoła którego \add stoi\add* sześćdziesięciu dzielnych wojowników spośród dzielnych Izraela.
\m 
\v 8 Wszyscy trzymają miecz, wyćwiczeni w boju. Każdy z nich ma swój miecz u boku przez wzgląd na strach nocny.
\m 
\v 9 Król Salomon uczynił sobie lektykę z drzewa Libanu.
\m 
\v 10 Jej słupki uczynił ze srebra, jej pokład ze złota, podniebienie z purpury, a wnętrze wyścielone miłością córek Jerozolimy.
\m 
\v 11 Wyjdźcie, córki Syjonu, i popatrzcie na króla Salomona w koronie, którą ukoronowała go jego matka w dniu jego zaręczyn i w dniu radości jego serca.
\c 4
\m 
\v 1 O jaka ty jesteś piękna, moja umiłowana! O jaka ty jesteś piękna! Twoje oczy między twymi kędziorkami są \add jak oczy\add* gołębicy; twoje włosy są jak stado kóz, które widać na górze Gileadu.
\m 
\v 2 Twoje zęby są jak stado strzyżonych \add owiec\add*, gdy wychodzą z kąpieli; wszystkie mają bliźnięta i nie ma żadnej niepłodnej wśród nich.
\m 
\v 3 Twoje wargi \add są\add* jak nić purpurowa, a twoja wymowa pełna wdzięku. Twoje skronie \add są\add* jak połówki granatu między twymi kędziorkami.
\m 
\v 4 Twoja szyja \add jest\add* jak wieża Dawida, zbudowana na zbrojownię, na której tysiąc puklerzy zawieszono, wszystko to tarcze dzielnych wojowników.
\m 
\v 5 Twoje piersi są jak dwoje bliźniaczych sarniąt, które pasą się między liliami.
\m 
\v 6 Nim zaświta dzień i znikną cienie, wejdę na górę mirry i na pagórek kadzidła.
\m 
\v 7 Cała \add jesteś\add* piękna, moja umiłowana, i nie ma w tobie żadnej skazy.
\m 
\v 8 Przyjdź ze mną z Libanu, \add moja\add* oblubienico, \add przyjdź\add* ze mną z Libanu. Spójrz ze szczytu \add góry\add* Amana, ze szczytu \add góry\add* Senir i Hermon, z jaskiń lwów i z gór lampartów.
\m 
\v 9 Zachwyciłaś moje serce, moja siostro, \add moja\add* oblubienico! Zachwyciłaś moje serce jednym twoim okiem i jednym łańcuszkiem na twojej szyi.
\m 
\v 10 Jakże piękna jest twoja miłość, moja siostro, \add moja\add* oblubienico! Jak daleko lepsza jest twoja miłość od wina, a woń twoich olejków od wszystkich innych wonności!
\m 
\v 11 Z twoich warg ocieka miód \add jak\add* z plastrów, \add moja\add* oblubienico! Miód i mleko pod twoim językiem, a woń twoich szat jest jak woń Libanu.
\m 
\v 12 \add Jesteś\add* zamkniętym ogrodem, moja siostro, \add moja\add* oblubienico; źródłem zamkniętym, zdrojem zapieczętowanym.
\m 
\v 13 Twoje pędy to sad \add drzew\add* granatu z wybornym owocem cyprysu i nardu;
\m 
\v 14 Nard i szafran, tatarak i cynamon, ze wszelkimi drzewami, kadzidło, mirra i aloes, ze wszelkimi wybornymi wonnościami.
\m 
\v 15 Źródło ogrodów, zdrój żywych wód, które płyną z Libanu!
\m 
\v 16 Powstań, wietrze północny, i przyjdź, wietrze z południa, powiej przez mój ogród, by się rozpłynęły jego wonności. Niech przyjdzie mój umiłowany do swego ogrodu i niech je swoje rozkoszne owoce.
\c 5
\m 
\v 1 Wszedłem do mojego ogrodu, moja siostro, \add moja\add* oblubienico. Zbierałem moją mirrę z moimi wonnościami; zjadłem mój plaster z moim miodem, piję moje wino z moim mlekiem. Jedzcie, przyjaciele, pijcie, a pijcie obficie, moi mili.
\m 
\v 2 Ja śpię, ale moje serce czuwa. \add Oto\add* głos mego umiłowanego, który puka i \add mówi\add*: Otwórz mi, moja siostro, moja umiłowana, moja gołębico, moja nieskalana. Moja głowa bowiem jest pełna rosy, moje kędziory – kropli nocy.
\m 
\v 3 Zdjęłam już swoją suknię, jakże mam ją wkładać? Umyłam swoje nogi, jakże mam je pobrudzić?
\m 
\v 4 Mój umiłowany wsunął swoją rękę przez otwór, a moje wnętrze poruszyło się we mnie.
\m 
\v 5 Wstałam, aby otworzyć mojemu umiłowanemu, a oto z moich rąk kapała mirra, z moich palców mirra spływała na uchwyt zasuwy.
\m 
\v 6 Otworzyłam mojemu umiłowanemu, lecz mój umiłowany \add już\add* odszedł i zniknął. Moja dusza zasłabła na jego głos. Szukałam go, ale nie znalazłam, wołałam go, ale mi nie odpowiedział.
\m 
\v 7 Znaleźli mnie strażnicy, którzy obchodzili miasto; pobili mnie i zranili, strażnicy murów zabrali mi zasłonę.
\m 
\v 8 Zaklinam was, córki Jerozolimy: Jeśli znajdziecie mojego umiłowanego, to powiedzcie mu, że jestem chora z miłości.
\m 
\v 9 Czym przewyższa twój umiłowany \add innych\add* umiłowanych, o najpiękniejsza wśród kobiet? Czym przewyższa twój umiłowany \add innych\add* umiłowanych, że tak nas zaklinasz?
\m 
\v 10 Mój umiłowany jest biały i rumiany, i najznakomitszy spośród dziesięciu tysięcy.
\m 
\v 11 Jego głowa jest \add jak\add* najczystsze złoto; jego kędziory faliste, czarne jak kruk.
\m 
\v 12 Jego oczy są jak gołębice nad strumieniami wody, \add jakby\add* umyte w mleku, osadzone w swej oprawie.
\m 
\v 13 Jego policzki jak grządka wonności, \add jak\add* pachnące kwiatki; jego wargi jak lilie ociekające wyborną mirrą.
\m 
\v 14 Jego ręce \add jak\add* złote pierścienie wysadzone berylem; jego tors \add jak\add* jasna kość słoniowa pokryta szafirem.
\m 
\v 15 Jego nogi \add jak\add* słupy z marmuru, postawione na szczerozłotych podstawkach; jego oblicze \add jak\add* Liban, wyborne jak cedry.
\m 
\v 16 Jego usta przesłodkie i jest on cały przepiękny. Taki jest mój umiłowany i taki jest mój przyjaciel, córki Jerozolimy.
\c 6
\m 
\v 1 Dokąd poszedł twój umiłowany, o najpiękniejsza wśród kobiet? Dokąd się zwrócił twój umiłowany, abyśmy szukali go wraz z tobą?
\m 
\v 2 Mój umiłowany zstąpił do swojego ogrodu między grządki wonności, aby paść w ogrodach i zbierać lilie.
\m 
\v 3 Ja należę do mego umiłowanego, a mój umiłowany \add należy\add* do mnie; pasie on wśród lilii.
\m 
\v 4 Piękna jesteś, moja umiłowana, jak Tirsa; urodziwa jak Jerozolima; groźna jak wojsko \add z\add* chorągwiami.
\m 
\v 5 Odwróć ode mnie swoje oczy, gdyż one mnie urzekają. Twoje włosy są jak stado kóz, które schodzą z Gileadu.
\m 
\v 6 Twoje zęby są jak stado owiec, które wychodzą z kąpieli, wszystkie mają bliźnięta, a nie ma żadnej niepłodnej wśród nich.
\m 
\v 7 Twoje skronie między twoimi kędziorkami są jak połówki granatu.
\m 
\v 8 Sześćdziesiąt jest królowych i osiemdziesiąt nałożnic, a dziewic bez liku.
\m 
\v 9 \add Lecz\add* moja gołębica, moja nieskalana, jest jedna; jedynaczka u swojej matki, bez skazy u swojej rodzicielki. Widziały ją córki i nazwały ją błogosławioną, także królowe i nałożnice, i chwaliły ją, \add mówiąc\add*:
\m 
\v 10 Kim jest ta, która pokazuje się jak zorza poranna, piękna jak księżyc, czysta jak słońce, groźna jak uszykowane wojsko z chorągwiami?
\m 
\v 11 Zeszłam do ogrodu orzechów, aby patrzeć na owoce \add rosnące\add* w dolinach, by zobaczyć, czy winorośl kwitnie i czy granaty wypuszczają pączki.
\m 
\v 12 Nim się zorientowałam, moja dusza wsadziła mnie jakby w rydwany książąt mego ludu.
\m 
\v 13 Zawróć, zawróć, Szulamitko; zawróć, zawróć, abyśmy mogli na ciebie patrzeć. Cóż widzicie w Szulamitce? \add Widzimy\add* jakby oddziały wojenne.
\c 7
\m 
\v 1 Jak piękne są twoje nogi w sandałach, córko książęca! Linia twoich bioder jest jak klejnot, jak dzieło rąk rzemieślnika.
\m 
\v 2 Twój pępek jest \add jak\add* okrągła czasza, której nie brakuje napoju. Twój brzuch jest \add jak\add* stóg pszenicy okolony liliami.
\m 
\v 3 Twoje piersi są jak dwoje sarniąt, bliźniąt.
\m 
\v 4 Twoja szyja jest jak wieża z kości słoniowej; twoje oczy jak sadzawki Cheszbonu przy bramie Bat-Rabbim; twój nos jak wieża Libanu zwrócona w stronę Damaszku.
\m 
\v 5 Twoja głowa na tobie jak Karmel, a włosy twojej głowy jak purpura. Król \add na twój widok\add* jest \add jakby\add* przywiązany w \add swoich\add* krużgankach.
\m 
\v 6 Jakże piękna jesteś i jak miła, o miłości przerozkoszna!
\m 
\v 7 Twój wzrost jest podobny do palmy, a twoje piersi do kiści \add winogron\add*.
\m 
\v 8 Powiedziałem: Wejdę na palmę i uchwycę się jej gałęzi. Niech twoje piersi będą jak kiście winorośli, a woń twojego oddechu jak \add zapach\add* jabłek;
\m 
\v 9 Twoje usta jak wyborne wino, które mile spływa po podniebieniu i sprawia, że wargi śpiących mówią.
\m 
\v 10 Ja \add należę\add* do mojego umiłowanego i do mnie \add zwraca się\add* jego pożądanie.
\m 
\v 11 Chodź, mój umiłowany, wyjdźmy w pole \add i\add* przenocujemy we wsiach.
\m 
\v 12 Rankiem wstaniemy \add i pójdziemy\add* do winnic, zobaczymy, czy kwitnie winorośl, czy otworzyły się już pączki, czy już kwitną granaty. Tam cię obdarzę swoją miłością.
\m 
\v 13 Mandragory wydają \add swoją\add* woń, a przed naszymi drzwiami są wszelkie wyborne owoce, nowe i stare, które przechowałam dla ciebie, mój umiłowany.
\c 8
\m 
\v 1 O gdybyś był dla mnie jak brat, który ssał piersi mojej matki! Wtedy spotykałabym cię na dworze, całowałabym cię, a nie byłabym wzgardzona.
\m 
\v 2 Powiodłabym cię i wprowadziła do domu swojej matki, gdzie byś mnie uczył. A ja dałabym ci do picia wino korzenne, moszcz ze swoich granatów.
\m 
\v 3 Jego lewa ręka byłaby pod moją głową, a prawa ręka objęłaby mnie.
\m 
\v 4 Zaklinam was, córki Jerozolimy: Nie budźcie mego umiłowanego ani nie przerywajcie \add jego snu\add*, dopóki on nie zechce.
\m 
\v 5 Kim jest ta, która wyłania się z pustyni, wsparta na swym umiłowanym? Pod jabłonią cię wzbudziłam. Tam cię urodziła twoja matka, tam cię urodziła twoja rodzicielka.
\m 
\v 6 Przyłóż mnie do swego serca jak pieczęć, jak pieczęć na swoim ramieniu. Miłość bowiem jest silna jak śmierć, zawiść twarda jak grób. Jej żar \add jak\add* żar ognia i \add jak\add* żarliwy płomień.
\m 
\v 7 Wielkie wody nie zdołają zagasić miłości ani rzeki jej zatopić. Choćby ktoś oddał cały majątek swego domu za taką miłość, byłby z pewnością wzgardzony.
\m 
\v 8 Mamy małą siostrę, która jeszcze nie ma piersi. Cóż uczynimy z naszą siostrą w dniu, w którym będą o nią zabiegać?
\m 
\v 9 Jeśli jest murem, zbudujemy na niej srebrny pałac; a jeśli drzwiami, oprawimy ją deskami z cedru.
\m 
\v 10 Ja \add jestem\add* murem, a moje piersi jak wieże. Odtąd byłam w jego oczach jak ta, która znalazła pokój.
\m 
\v 11 Salomon miał winnicę w Baal-Hamon, \add którą\add* najął stróżom; każdy miał przynosić za jej owoc tysiąc srebrników.
\m 
\v 12 Ale moja winnica, którą mam, \add jest\add* przede mną. Miej ty sobie tysiąc srebrników, Salomonie, a dwieście \add niech wezmą\add* ci, którzy strzegą jej owocu.
\m 
\v 13 O ty, która mieszkasz w ogrodach, przyjaciele słuchają twego głosu; daj mi go usłyszeć.
\m 
\v 14 Pospiesz się, mój umiłowany, i bądź podobny do sarny albo młodego jelenia na górach wonności. 
