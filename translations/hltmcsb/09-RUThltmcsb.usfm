\v 3 \w Te\w* \w vaengah|strong="H9999"\w* \w aka\w* \w tlan|strong="H1350"\w* koi \w taengah|strong="H9997"\w*, “\w Mamih|strong="H9900"\w* \w kah\w* \w manuca|strong="H0251"\w* \w Elimelekh|strong="H0458"\w* \w khohmuen|strong="H7704"\w* \w kah\w* \w lo|strong="H2513"\w* \w aka\w* \w yoi|strong="H4376"\w* \w Noami|strong="H5281"\w* \w tah\w* \w Moab|strong="H4124"\w* \w kho|strong="H7704"\w* \w lamkah|strong="H4480"\w* \w ha\w* \w bal|strong="H7725"\w* \w coeng\w*.  
