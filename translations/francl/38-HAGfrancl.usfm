\p \w J|strong="H03068"\w*’\w ébranlerai|strong="H07493"\w* \w les|strong="H07493"\w* \w cieux|strong="H08064"\w* \w et|strong="H03063"\w* \w la|strong="H03063"\w* \w terre|strong="H00776"\w* ;  
\v 22 \w je|strong="H05315"\w* \w renverserai|strong="H02015"\w* \w le|strong="H03381"\w* \w trône|strong="H03678"\w* \w des|strong="H03381"\w* \w royaumes|strong="H04467"\w*, \w je|strong="H05315"\w* \w détruirai|strong="H08045"\w* \w la|strong="H03381"\w* \w puissance|strong="H01369"\w* \w des|strong="H03381"\w* \w royaumes|strong="H04467"\w* \w des|strong="H03381"\w* \w nations|strong="H01471"\w* ; \w je|strong="H05315"\w* \w renverserai|strong="H02015"\w* \w les|strong="H02015"\w* \w chars|strong="H04818"\w* \w et|strong="H08045"\w* \w ceux|strong="H00582"\w* \w qui|strong="H01471"\w* \w les|strong="H02015"\w* \w montent|strong="H07392"\w* ; \w les|strong="H02015"\w* \w chevaux|strong="H05483"\w* \w avec|strong="H03381"\w* \w leurs|strong="H02015"\w* \w cavaliers|strong="H07392"\w* \w tomberont|strong="H03381"\w*, \w par|strong="H03027"\w* l’\w épée|strong="H02719"\w* \w les|strong="H02015"\w* \w uns|strong="H00376"\w* \w des|strong="H03381"\w* \w autres|strong="H00312"\w*.  
\v 23 \w En|strong="H03117"\w* \w ce|strong="H01931"\w* \w jour-là|strong="H01931"\w*, — \w oracle|strong="H04853"\w* \w de|strong="H01121"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w*, \w je|strong="H03117"\w* \w te|strong="H03068"\w* \w prendrai|strong="H03947"\w*, \w Zorobabel|strong="H02216"\w*, \w fils|strong="H01121"\w* \w de|strong="H01121"\w* Salathiel, \w mon|strong="H07760"\w* \w serviteur|strong="H05650"\w*, — \w oracle|strong="H04853"\w* \w de|strong="H01121"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd*, \w et|strong="H03117"\w* \w je|strong="H03117"\w* \w ferai|strong="H07760"\w* \w de|strong="H01121"\w* \w toi|strong="H03068"\w* \w comme|strong="H03117"\w* \w un|strong="H01121"\w* \w cachet|strong="H02368"\w*\f + \fr 2:23 \ft 23. \ft \+it Comme un cachet\+it* : le cachet ou sceau a une grande importance chez les Orientaux : il atteste le droit du possesseur et certifie ses volontés. Dieu aura soin de Zorobabel comme d’une chose de grand prix ; il en fera l’instrument de ses volontés, l’agent fidèle de ses décrets envers son peuple et envers le monde entier, il s’appropriera comme son œuvre privilégiée l’œuvre de son serviteur.\f* ; \w car|strong="H03588"\w* \w je|strong="H03117"\w* t’\w ai|strong="H03068"\w* \w élu|strong="H00972"\w*, — \w oracle|strong="H04853"\w* \w de|strong="H01121"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w des|strong="H03068"\w* \w armées|strong="H06635"\w*.   