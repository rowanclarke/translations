\v 1 \w CUANDO|strong="H3588"\w* \w Israel|strong="H3478"\w* \w era|strong="H1121"\w* \w muchacho|strong="H5288"\w*, \w yo|strong="H3588"\w* lo amé, \w y|strong="H3588"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w* \w llamé|strong="H7121"\w* \w a|strong="H3068"\w* mi \w hijo|strong="H1121"\w*.
