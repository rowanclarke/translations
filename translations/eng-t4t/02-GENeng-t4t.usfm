\c 4
\s1 God punished Adam and Eve’s oldest son Cain for killing his younger brother Abel
\p 
\v 1 Adam ◄\w had|strong="H3068"\w* sex/slept► \w with|strong="H3068"\w* \w his|strong="H3068"\w* wife \w Eve|strong="H2332"\w*, \w and|strong="H3068"\w* she \w became|strong="H3205"\w* \w pregnant|strong="H2029"\w* \w and|strong="H3068"\w* \w gave|strong="H3205"\w* \w birth|strong="H3205"\w* \w to|strong="H3068"\w* \w a|strong="H3068"\w* \w son|strong="H3205"\w* whom she named \w Cain|strong="H7014"\w*, \add which sounds like the word that means ‘produce’\add*, \w because|strong="H3068"\w*, she said, “\w By|strong="H3068"\w* \w Yahweh|strong="H3068"\w*’s help \w I|strong="H3045"\w* \w have|strong="H3068"\w* \w produced|strong="H3205"\w* \w a|strong="H3068"\w* \w son|strong="H3205"\w*.” Some time later she \w gave|strong="H3205"\w* \w birth|strong="H3205"\w* \w to|strong="H3068"\w* another \w son|strong="H3205"\w*, \w and|strong="H3068"\w* she named \w him|strong="H3205"\w* Abel.
\p 
\v 2 \add After those boys grew up\add*, \w Abel|strong="H1893"\w* ◄tended/\w took|strong="H1961"\w* care \w of|strong="H3205"\w*► \w sheep|strong="H6629"\w* \w and|strong="H6629"\w* goats, \w and|strong="H6629"\w* \w Cain|strong="H7014"\w* \w became|strong="H3205"\w* \w a|strong="H3068"\w* farmer.
\v 3 \w One|strong="H1961"\w* \w day|strong="H3117"\w* \w Cain|strong="H7014"\w* harvested \w some|strong="H7093"\w* \w of|strong="H3068"\w* \w the|strong="H3068"\w* crops \w he|strong="H3117"\w* \w had|strong="H3068"\w* \w grown|strong="H1961"\w* \w and|strong="H3068"\w* \w brought|strong="H1961"\w* \w them|strong="H1961"\w* \w to|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w as|strong="H3117"\w* \w a|strong="H3068"\w* \w gift|strong="H4503"\w* \w for|strong="H3068"\w* \w him|strong="H3068"\w*,
\v 4 \w and|strong="H3068"\w* \w Abel|strong="H1893"\w* took \w from|strong="H3068"\w* \w his|strong="H3068"\w* \w flock|strong="H6629"\w* some \w of|strong="H3068"\w* \w the|strong="H3068"\w* first \w lambs|strong="H6629"\w* \w that|strong="H1931"\w* \w had|strong="H3068"\w* \w been|strong="H3068"\w* born \add and killed them\add* \w and|strong="H3068"\w*, \w as|strong="H1571"\w* \w a|strong="H3068"\w* \w gift|strong="H4503"\w*, gave \w to|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w the|strong="H3068"\w* fatty parts, \add which were the best parts\add*. \w Yahweh|strong="H3068"\w* \w was|strong="H3068"\w* \w pleased|strong="H8159"\w* \w with|strong="H3068"\w* \w Abel|strong="H1893"\w* \w and|strong="H3068"\w* \w his|strong="H3068"\w* \w offering|strong="H4503"\w*,
\v 5 \w but|strong="H3808"\w* \w he|strong="H3808"\w* \w was|strong="H3808"\w* \w not|strong="H3808"\w* \w pleased|strong="H8159"\w* \w with|strong="H6440"\w* \w Cain|strong="H7014"\w* \w and|strong="H6440"\w* \w his|strong="H6440"\w* \w offering|strong="H4503"\w*. \w So|strong="H3808"\w* \w Cain|strong="H7014"\w* \w became|strong="H2734"\w* \w very|strong="H3966"\w* \w angry|strong="H2734"\w*, \w and|strong="H6440"\w* \w his|strong="H6440"\w* \w face|strong="H6440"\w* \w looked|strong="H8159"\w* dejected.
\v 6 \w Yahweh|strong="H3068"\w* said \w to|strong="H3068"\w* \w Cain|strong="H7014"\w*, “◄\w You|strong="H6440"\w* \w should|strong="H3068"\w* \w not|strong="H5307"\w* \w be|strong="H3068"\w* \w angry|strong="H2734"\w*!/\w Why|strong="H4100"\w* \w are|strong="H4100"\w* \w you|strong="H6440"\w* \w angry|strong="H2734"\w*?► [RHQ] ◄\w You|strong="H6440"\w* \w should|strong="H3068"\w* \w not|strong="H5307"\w* scowl \w like|strong="H5307"\w* \w that|strong="H3068"\w*!/\w Why|strong="H4100"\w* \w do|strong="H3068"\w* \w you|strong="H6440"\w* scowl \w like|strong="H5307"\w* \w that|strong="H3068"\w*?► [RHQ]
\v 7 If \w you|strong="H3808"\w* \w had|strong="H3808"\w* \w done|strong="H3190"\w* what \w was|strong="H3808"\w* \w right|strong="H4910"\w* (\w OR|strong="H3068"\w*, if \w you|strong="H3808"\w* \w do|strong="H3190"\w* what \w is|strong="H2403"\w* \w right|strong="H4910"\w*) [RHQ], \w I|strong="H3808"\w* would accept \w your|strong="H3190"\w* \w offering|strong="H2403"\w*. \w But|strong="H3808"\w* if \w you|strong="H3808"\w* \w do|strong="H3190"\w* \w not|strong="H3808"\w* \w do|strong="H3190"\w* what \w is|strong="H2403"\w* \w right|strong="H4910"\w*, \add your desire to\add* \w sin|strong="H2403"\w* \add is ready to attack you like a wild animal that\add* [PRS] crouches outside \w the|strong="H3808"\w* \w doorway|strong="H6607"\w*, \add ready to spring on its victim\add* [MET]. \add Your desire to\add* \w sin|strong="H2403"\w* wants \w to|strong="H3808"\w* \w control|strong="H4910"\w* \w you|strong="H3808"\w*, \w but|strong="H3808"\w* \w you|strong="H3808"\w* \w must|strong="H3808"\w* ◄\w control|strong="H4910"\w*/\w not|strong="H3808"\w* obey► \w it|strong="H3808"\w*.”
\p 
\v 8 \w But|strong="H1961"\w* \w one|strong="H1961"\w* day, \w Cain|strong="H7014"\w* said \w to|strong="H1961"\w* \w his|strong="H6965"\w* younger brother \w Abel|strong="H1893"\w*, “\w Let|strong="H1961"\w*’s \w go|strong="H6965"\w* \w for|strong="H7704"\w* \w a|strong="H3068"\w* walk \w in|strong="H6965"\w* \w the|strong="H6965"\w* \w fields|strong="H7704"\w*.” \add So they went together\add*. \w And|strong="H6965"\w* \w when|strong="H1961"\w* they \w were|strong="H1961"\w* \w in|strong="H6965"\w* \w the|strong="H6965"\w* \w countryside|strong="H7704"\w*, suddenly \w Cain|strong="H7014"\w* \w attacked|strong="H6965"\w* \w Abel|strong="H1893"\w* \w and|strong="H6965"\w* \w killed|strong="H2026"\w* \w him|strong="H2026"\w*.
\v 9 \add Later, even though\add* \w Yahweh|strong="H3068"\w* \add knew what Cain had done\add*, \w he|strong="H3068"\w* said \w to|strong="H3068"\w* \w Cain|strong="H7014"\w*, “\add Do you know\add* \w where|strong="H3808"\w* \w Abel|strong="H1893"\w*, \w your|strong="H3068"\w* younger brother, \w is|strong="H3068"\w*?”
\p \w Cain|strong="H7014"\w* replied, “\w No|strong="H3808"\w*, \w I|strong="H3045"\w* \w do|strong="H3068"\w* \w not|strong="H3808"\w* \w know|strong="H3045"\w*. ◄\w My|strong="H8104"\w* \w job|strong="H3808"\w* \w is|strong="H3068"\w* \w not|strong="H3808"\w* \w to|strong="H3068"\w* \w guard|strong="H8104"\w* \w my|strong="H8104"\w* younger brother!/\w Am|strong="H3068"\w* \w I|strong="H3045"\w* supposed \w to|strong="H3068"\w* \w take|strong="H8104"\w* \w care|strong="H8104"\w* \w of|strong="H3068"\w* \w my|strong="H8104"\w* younger brother?►” [RHQ]
\v 10 \w Yahweh|strong="H3068"\w* said, “\w You|strong="H6213"\w* have \w done|strong="H6213"\w* \w a|strong="H3068"\w* \w terrible|strong="H6213"\w* \w thing|strong="H4100"\w* [RHQ]! \w So|strong="H6213"\w* now \add it is as though\add* \w your|strong="H6213"\w* younger brother’s \w voice|strong="H6963"\w* \w is|strong="H4100"\w* \w crying|strong="H6817"\w* \w to|strong="H6213"\w* \w me|strong="H6963"\w* \w from|strong="H4480"\w* \w the|strong="H6213"\w* ground, demanding \w that|strong="H4480"\w* \w his|strong="H6213"\w* \w death|strong="H1818"\w* \w must|strong="H1818"\w* \w be|strong="H6963"\w* avenged.
\v 11 \w You|strong="H3947"\w* \w have|strong="H3027"\w* killed \w your|strong="H3947"\w* younger brother, \w and|strong="H3027"\w* \w the|strong="H3947"\w* ground \w has|strong="H3027"\w* soaked \w up|strong="H3947"\w* \w his|strong="H3947"\w* \w blood|strong="H1818"\w*. \w So|strong="H4480"\w* \w now|strong="H6258"\w* \w I|strong="H6258"\w* \w will|strong="H3027"\w* expel \w you|strong="H3947"\w* \w from|strong="H4480"\w* \w this|strong="H6258"\w* land \w and|strong="H3027"\w* curse \w your|strong="H3947"\w* efforts \w to|strong="H3027"\w* produce crops.
\v 12 \w You|strong="H5414"\w* \w will|strong="H1961"\w* \w till|strong="H5647"\w* \w the|strong="H3588"\w* ground \w to|strong="H1961"\w* \w plant|strong="H5414"\w* crops, \w but|strong="H3588"\w* \w the|strong="H3588"\w* ground \w will|strong="H1961"\w* \w produce|strong="H5414"\w* very few [HYP] crops. \w And|strong="H3254"\w* \w you|strong="H5414"\w* \w will|strong="H1961"\w* \w continually|strong="H5128"\w* \w wander|strong="H5128"\w* \w around|strong="H5128"\w* \w the|strong="H3588"\w* earth, \w and|strong="H3254"\w* \w not|strong="H3808"\w* \w have|strong="H1961"\w* \w any|strong="H5414"\w* \w place|strong="H5414"\w* \w to|strong="H1961"\w* live permanently.”
\v 13 \w Cain|strong="H7014"\w* replied, “\w You|strong="H5375"\w* \w are|strong="H3068"\w* punishing me \w more|strong="H1419"\w* \w then|strong="H5375"\w* \w I|strong="H3068"\w* can \w endure|strong="H5375"\w*.
\v 14 \w You|strong="H6440"\w* \w are|strong="H3117"\w* \w about|strong="H1961"\w* \w to|strong="H1961"\w* \w expel|strong="H1644"\w* \w me|strong="H6440"\w* \w from|strong="H6440"\w* \w the|strong="H3605"\w* \w ground|strong="H6440"\w* \add that I have been cultivating\add*, \w and|strong="H3117"\w* \w I|strong="H2005"\w* \w will|strong="H1961"\w* \w no|strong="H4672"\w* longer \w be|strong="H1961"\w* able \w to|strong="H1961"\w* \w come|strong="H1961"\w* ◄\w into|strong="H5921"\w* \w your|strong="H3605"\w* \w presence|strong="H6440"\w*/\w and|strong="H3117"\w* talk \w with|strong="H5921"\w* \w you|strong="H6440"\w*►. Furthermore, \w I|strong="H2005"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w continually|strong="H3605"\w* \w wandering|strong="H5110"\w* \w around|strong="H5921"\w* \w the|strong="H3605"\w* earth \w with|strong="H5921"\w* \w no|strong="H4672"\w* \w place|strong="H1961"\w* \w to|strong="H1961"\w* \w live|strong="H3117"\w* permanently, \w and|strong="H3117"\w* \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* sees \w me|strong="H6440"\w* \w will|strong="H1961"\w* \w kill|strong="H2026"\w* \w me|strong="H6440"\w*.”
\v 15 \w But|strong="H5221"\w* \w Yahweh|strong="H3068"\w* \w said|strong="H3651"\w* \w to|strong="H3068"\w* \w him|strong="H5221"\w*, “\w No|strong="H1115"\w*, \w that|strong="H3605"\w* \w will|strong="H3068"\w* \w not|strong="H1115"\w* \w happen|strong="H4672"\w*. \w I|strong="H7760"\w* \w will|strong="H3068"\w* \w put|strong="H7760"\w* \w a|strong="H3068"\w* \w mark|strong="H7760"\w* \w on|strong="H7760"\w* \w you|strong="H3605"\w* \w to|strong="H3068"\w* warn \w anyone|strong="H3605"\w* \w who|strong="H3605"\w* sees \w you|strong="H3605"\w* \w that|strong="H3605"\w* \add I will punish him severely if\add* \w he|strong="H3651"\w* \w kills|strong="H5221"\w* \w you|strong="H3605"\w*. \w I|strong="H7760"\w* \w will|strong="H3068"\w* \w punish|strong="H5221"\w* \w that|strong="H3605"\w* person \w seven|strong="H7659"\w* \w times|strong="H7659"\w* \w as|strong="H3068"\w* severely \w as|strong="H3068"\w* \w I|strong="H7760"\w* \w am|strong="H3068"\w* punishing \w you|strong="H3605"\w*.” \w Then|strong="H3651"\w* \w Yahweh|strong="H3068"\w* \w put|strong="H7760"\w* \w a|strong="H3068"\w* \w mark|strong="H7760"\w* \w on|strong="H7760"\w* \w Cain|strong="H7014"\w*’s forehead.
\v 16 \w So|strong="H3318"\w* \w Cain|strong="H7014"\w* \w left|strong="H3318"\w* \w Yahweh|strong="H3068"\w* \w and|strong="H3068"\w* \w went|strong="H3318"\w* \w to|strong="H3318"\w* \w live|strong="H3427"\w* \w in|strong="H3427"\w* \w the|strong="H6440"\w* \w land|strong="H6440"\w* called \w Nod|strong="H5113"\w*, \add which means ‘wandering’\add*, \w which|strong="H3068"\w* \w was|strong="H3068"\w* \w east|strong="H6926"\w* \w of|strong="H3068"\w* \w Eden|strong="H5731"\w*.
\s1 The descendants of Cain
\p 
\v 17 Some \w time|strong="H1961"\w* \w later|strong="H1961"\w*, \w Cain|strong="H7014"\w* ◄\w had|strong="H1961"\w* sex/slept► \w with|strong="H3045"\w* \w his|strong="H7121"\w* wife, \w and|strong="H1121"\w* \w she|strong="H7121"\w* \add became pregnant and\add* \w gave|strong="H3205"\w* \w birth|strong="H3205"\w* \w to|strong="H1961"\w* \w a|strong="H3068"\w* \w son|strong="H1121"\w*, \w whom|strong="H7121"\w* \w she|strong="H7121"\w* \w named|strong="H7121"\w* \w Enoch|strong="H2585"\w*. \w Then|strong="H1961"\w* \w Cain|strong="H7014"\w* \w started|strong="H1961"\w* \w to|strong="H1961"\w* \w build|strong="H1129"\w* \w a|strong="H3068"\w* \w city|strong="H5892"\w*, \w and|strong="H1121"\w* \w he|strong="H7121"\w* \w named|strong="H7121"\w* \w the|strong="H3205"\w* \w city|strong="H5892"\w* ‘\w Enoch|strong="H2585"\w*’, \w the|strong="H3205"\w* \w same|strong="H8034"\w* \w name|strong="H8034"\w* \w that|strong="H3045"\w* \w his|strong="H7121"\w* \w son|strong="H1121"\w* \w had|strong="H1961"\w*.
\v 18 \w Enoch|strong="H2585"\w* \add grew up and married and\add* \w became|strong="H3205"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H3205"\w* \w a|strong="H3068"\w* \w son|strong="H3205"\w* whom he named \w Irad|strong="H5897"\w*. When \w Irad|strong="H5897"\w* \add grew up he\add* \w became|strong="H3205"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H3205"\w* \w a|strong="H3068"\w* \w son|strong="H3205"\w* whom he named \w Mehujael|strong="H4232"\w*. \w Mehujael|strong="H4232"\w* \add grew up and\add* \w became|strong="H3205"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H3205"\w* \w a|strong="H3068"\w* \w son|strong="H3205"\w* whom he named Methuselah. Methuselah \add grew up and\add* \w became|strong="H3205"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H3205"\w* \w Lamech|strong="H3929"\w*.
