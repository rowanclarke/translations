\v 22  \w Jesus|strong="G2424"\w* \w replied|strong="G3004"\w*, “\w If|strong="G1437"\w* \w I|strong="G1473"\w* \w want|strong="G2309"\w* \w him|strong="G3588"\w* \w to|strong="G4314"\w* live \w until|strong="G2193"\w* \w I|strong="G1473"\w* \w come|strong="G2064"\w* \w back|strong="G4314"\w*, \w what|strong="G5101"\w* concern \w is|strong="G3588"\w* \w that|strong="G3588"\w* \w of|strong="G2424"\w* \w yours|strong="G4771"\w*? \w You|strong="G4771"\w* \w follow|strong="G2064"\w* \w me|strong="G1473"\w*!”  
