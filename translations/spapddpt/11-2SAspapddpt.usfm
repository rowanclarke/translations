\v 30 \w Joab|strong="H3097"\w* también \w volvió|strong="H7725"\w* \w de|strong="H5971"\w* perseguir \w a|strong="H3068"\w* Abner. \w Cuando|strong="H5650"\w* pasó revista \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* ejército, \w faltaron|strong="H6485"\w* \w de|strong="H5971"\w* \w los|strong="H3605"\w* esclavos \w de|strong="H5971"\w* \w David|strong="H1732"\w* 19 hombres y \w Asael|strong="H6214"\w*.
\v 31 Pero los esclavos de \w David|strong="H1732"\w* \w hirieron|strong="H5221"\w* \w a|strong="H3068"\w* 360 hombres de \w Benjamín|strong="H1144"\w* dirigidos por Abner, quienes \w murieron|strong="H4191"\w*.
\v 32 \w Llevaron|strong="H5375"\w* \w a|strong="H3068"\w* \w Asael|strong="H6214"\w* y \w lo|strong="H3605"\w* \w sepultaron|strong="H6912"\w* \w en|strong="H6912"\w* \w el|strong="H3605"\w* \w sepulcro|strong="H6913"\w* de su padre \w que|strong="H3605"\w* estaba \w en|strong="H6912"\w* Belén. Después \w Joab|strong="H3097"\w* y sus hombres \w caminaron|strong="H3212"\w* \w toda|strong="H3605"\w* aquella \w noche|strong="H3915"\w* hasta \w que|strong="H3605"\w* les amaneció \w en|strong="H6912"\w* \w Hebrón|strong="H2275"\w*.
\c 3
\s1 Hijos de David nacidos en Hebrón
\p 
\v 1 La \w guerra|strong="H4421"\w* entre la \w casa|strong="H1004"\w* de \w Saúl|strong="H7586"\w* y la \w casa|strong="H1004"\w* de \w David|strong="H1732"\w* \w fue|strong="H1961"\w* larga, pero \w David|strong="H1732"\w* \w se|strong="H1961"\w* fortalecía, mientras la \w casa|strong="H1004"\w* de \w Saúl|strong="H7586"\w* \w se|strong="H1961"\w* debilitaba cada vez más.
\p 
\v 2 \w A|strong="H3068"\w* \w David|strong="H1732"\w* le \w nacieron|strong="H3205"\w* \w hijos|strong="H1121"\w* en \w Hebrón|strong="H2275"\w*: Su \w primogénito|strong="H1060"\w* \w fue|strong="H1961"\w* Amnón, \w de|strong="H1121"\w* Ahinoam \w jezreelita|strong="H3159"\w*,
\v 3 su \w segundo|strong="H4932"\w* Quileab, \w de|strong="H1121"\w* Abigail, la \w que|strong="H1121"\w* fue esposa \w de|strong="H1121"\w* \w Nabal|strong="H5037"\w* \w el|strong="H1121"\w* \w carmelita|strong="H3761"\w*, \w el|strong="H1121"\w* \w tercero|strong="H7992"\w* Absalón, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Maaca, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Talmai, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Gesur,
\v 4 \w el|strong="H1121"\w* \w cuarto|strong="H7243"\w* Adonías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Haggit, \w el|strong="H1121"\w* \w quinto|strong="H2549"\w* Sefatías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Abital,
\v 5 y el \w sexto|strong="H8345"\w* \w Itream|strong="H3507"\w*, de Egla, esposa de \w David|strong="H1732"\w*. Estos le \w nacieron|strong="H3205"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* en \w Hebrón|strong="H2275"\w*.
\s1 Asesinado Abner por parte del vengador de la sangre
\p 
\v 6 Durante el transcurso de la \w guerra|strong="H4421"\w* entre la \w casa|strong="H1004"\w* de \w Saúl|strong="H7586"\w* y la \w casa|strong="H1004"\w* de \w David|strong="H1732"\w*, Abner \w se|strong="H1961"\w* fortalecía en la \w casa|strong="H1004"\w* de \w Saúl|strong="H7586"\w*.
\v 7 \w Saúl|strong="H7586"\w* tuvo una \w concubina|strong="H6370"\w* \w llamada|strong="H8034"\w* Rizpa, \w hija|strong="H1323"\w* de Aja. Entonces Is-boset le dijo \w a|strong="H3068"\w* Abner: ¿\w Por|strong="H4069"\w* \w qué|strong="H1323"\w* te uniste \w a|strong="H3068"\w* la \w concubina|strong="H6370"\w* de mi padre?
\p 
\v 8 Abner \w se|strong="H5921"\w* irritó muchísimo \w por|strong="H5921"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w de|strong="H5921"\w* Is-boset \w y|strong="H5921"\w* dijo: ¿Soy \w yo|strong="H6213"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* un \w perro|strong="H3611"\w* \w que|strong="H3808"\w* pertenece \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*? \w Hasta|strong="H5921"\w* \w hoy|strong="H3117"\w* muestro favor \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Saúl|strong="H7586"\w* \w tu|strong="H6213"\w* padre, \w a|strong="H3068"\w* sus hermanos \w y|strong="H5921"\w* amigos, \w de|strong="H5921"\w* \w manera|strong="H1697"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w te|strong="H5921"\w* entregué \w en|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w*. ¿\w Y|strong="H3068"\w* \w ahora|strong="H3117"\w* \w me|strong="H5921"\w* echas \w en|strong="H5921"\w* cara un \w asunto|strong="H1697"\w* \w de|strong="H5921"\w* mujeres?
\p 
\v 9 \w Así|strong="H3541"\w* \w haga|strong="H6213"\w* \nd ʼElohim\nd* \w a|strong="H3068"\w* Abner \w y|strong="H3588"\w* \w aún|strong="H3254"\w* \w le|strong="H3254"\w* \w añada|strong="H3254"\w*, \w si|strong="H3588"\w* \w lo|strong="H6213"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w juró|strong="H7650"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w no|strong="H6213"\w* \w lo|strong="H6213"\w* obtengo \w para|strong="H3588"\w* \w él|strong="H3588"\w*,
\v 10 \w al|strong="H5921"\w* \w traspasar|strong="H5674"\w* \w el|strong="H5921"\w* \w reino|strong="H4467"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Saúl|strong="H7586"\w* \w y|strong="H5921"\w* confirmar \w el|strong="H5921"\w* \w trono|strong="H3678"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w sobre|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w desde|strong="H5704"\w* \w Dan|strong="H1835"\w* \w hasta|strong="H5704"\w* Beerseba.
\p 
\v 11 Is-boset \w no|strong="H3808"\w* \w pudo|strong="H3201"\w* \w responder|strong="H7725"\w* \w a|strong="H3068"\w* Abner \w porque|strong="H3808"\w* le \w temía|strong="H3372"\w*.
\p 
\v 12 Entonces Abner \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w para|strong="H5973"\w* decirle \w de|strong="H8478"\w* parte \w de|strong="H8478"\w* \w él|strong="H5973"\w*: ¿\w De|strong="H8478"\w* \w quién|strong="H4310"\w* \w es|strong="H3027"\w* \w la|strong="H3605"\w* tierra? \w Y|strong="H3068"\w* \w que|strong="H4310"\w* también \w le|strong="H5973"\w* dijeran: \w Haz|strong="H3772"\w* \w pacto|strong="H1285"\w* \w conmigo|strong="H5973"\w*, y \w ciertamente|strong="H2009"\w* \w mi|strong="H2009"\w* \w mano|strong="H3027"\w* \w estará|strong="H3605"\w* \w contigo|strong="H5973"\w* \w para|strong="H5973"\w* \w que|strong="H4310"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* se vuelva \w a|strong="H3068"\w* \w ti|strong="H5973"\w*.
\p 
\v 13 \w Y|strong="H3068"\w* \w él|strong="H3588"\w* respondió: \w Bien|strong="H2896"\w*, \w yo|strong="H3588"\w* \w haré|strong="H3772"\w* \w pacto|strong="H1285"\w* \w contigo|strong="H6440"\w*, \w pero|strong="H3588"\w* una \w cosa|strong="H1697"\w* \w te|strong="H3588"\w* pido: \w No|strong="H3808"\w* \w verás|strong="H7200"\w* mi semblante \w sin|strong="H3808"\w* \w que|strong="H3588"\w* primero traigas \w a|strong="H3068"\w* Mical, \w hija|strong="H1323"\w* \w de|strong="H3588"\w* \w Saúl|strong="H7586"\w*, \w cuando|strong="H3588"\w* vengas \w a|strong="H3068"\w* verme.
\v 14 \w David|strong="H1732"\w* \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* Is-boset, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w* y dijo: Devuélveme mi esposa Mical, \w a|strong="H3068"\w* quien desposé conmigo \w por|strong="H5414"\w* 100 \w prepucios|strong="H6190"\w* \w de|strong="H1121"\w* \w filisteos|strong="H6430"\w*.
\p 
\v 15 Entonces Is-boset \w envió|strong="H7971"\w* \w a|strong="H3068"\w* quitársela \w a|strong="H3068"\w* \add su esposo\add*, \w Paltiel|strong="H6409"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Lais.
\v 16 Pero su esposo \w salió|strong="H3212"\w* \w con|strong="H5704"\w* ella. \w Caminaba|strong="H3212"\w* \w y|strong="H5704"\w* \w lloraba|strong="H1058"\w* detrás \w de|strong="H5704"\w* ella \w hasta|strong="H5704"\w* Bahurim, donde Abner le dijo: ¡\w Anda|strong="H3212"\w*, devuélvete! \w Y|strong="H3068"\w* él regresó.
\p 
\v 17 Abner \w consultó|strong="H1245"\w* \w con|strong="H5973"\w* \w los|strong="H5921"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*: \w En|strong="H5921"\w* tiempos \w pasados|strong="H1961"\w* ustedes buscaban \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w fuera|strong="H1961"\w* su \w rey|strong="H4428"\w*.
\v 18 \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, háganlo, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* habló \w a|strong="H3068"\w* \w David|strong="H1732"\w*: \wj \w Por|strong="H3588"\w* \w medio|strong="H3027"\w* \w de|strong="H3588"\w* mi esclavo \w David|strong="H1732"\w* \w libraré|strong="H3467"\w* \w a|strong="H3068"\w* mi \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w* \w y|strong="H3588"\w* \w todos|strong="H3605"\w* sus enemigos.\wj*
\p 
\v 19 Abner \w habló|strong="H1696"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* hijos \w de|strong="H5869"\w* \w Benjamín|strong="H1144"\w*. Luego \w él|strong="H3605"\w* \w mismo|strong="H1571"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w Hebrón|strong="H2275"\w* para decirle \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H1571"\w* \w parecía|strong="H5869"\w* \w bien|strong="H2896"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* \w Israel|strong="H3478"\w* \w y|strong="H1571"\w* \w a|strong="H3068"\w* \w la|strong="H1571"\w* \w casa|strong="H1004"\w* \w de|strong="H5869"\w* \w Benjamín|strong="H1144"\w*.
\v 20 Abner fue con 20 hombres \w a|strong="H3068"\w* \w David|strong="H1732"\w* en \w Hebrón|strong="H2275"\w*.
\p Éste \w hizo|strong="H6213"\w* un \w banquete|strong="H4960"\w* para Abner y sus hombres.
\p 
\v 21 Abner dijo \w a|strong="H3068"\w* \w David|strong="H1732"\w*: Me \w levantaré|strong="H6965"\w*, \w iré|strong="H3212"\w* y reuniré \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* para \w mi|strong="H5315"\w* \tl ʼadón\tl* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* y \w que|strong="H3605"\w* hagan un \w pacto|strong="H1285"\w* contigo \w a|strong="H3068"\w* fin de \w que|strong="H3605"\w* tú reines sobre \w todo|strong="H3605"\w* \w lo|strong="H6908"\w* \w que|strong="H3605"\w* desea tu \w corazón|strong="H5315"\w*.
\p Así \w David|strong="H1732"\w* \w despidió|strong="H7971"\w* \w a|strong="H3068"\w* Abner, y éste se \w fue|strong="H3212"\w* \w en|strong="H3212"\w* \w paz|strong="H7965"\w*.
\p 
\v 22 \w Los|strong="H5973"\w* esclavos \w de|strong="H3588"\w* \w David|strong="H1732"\w* \w y|strong="H3588"\w* \w Joab|strong="H3097"\w* llegaron \w de|strong="H3588"\w* una incursión \w y|strong="H3588"\w* llevaron \w consigo|strong="H5973"\w* un \w gran|strong="H7227"\w* botín. \w Pero|strong="H3588"\w* Abner \w no|strong="H3588"\w* \w estaba|strong="H2009"\w* \w con|strong="H5973"\w* \w David|strong="H1732"\w* \w en|strong="H5973"\w* \w Hebrón|strong="H2275"\w*, \w pues|strong="H3588"\w* lo \w despidió|strong="H7971"\w* \w y|strong="H3588"\w* \w él|strong="H5973"\w* se \w fue|strong="H3212"\w* \w en|strong="H5973"\w* \w paz|strong="H7965"\w*.
\v 23 Cuando \w Joab|strong="H3097"\w* \w llegó|strong="H3212"\w* con \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w ejército|strong="H6635"\w* \w que|strong="H1121"\w* estaba con \w él|strong="H3605"\w*, informaron \w a|strong="H3068"\w* \w Joab|strong="H3097"\w*: Abner, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Ner|strong="H5369"\w*, \w vino|strong="H3212"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, y \w él|strong="H3605"\w* \w lo|strong="H3605"\w* \w despidió|strong="H7971"\w*, y se \w fue|strong="H3212"\w* \w en|strong="H3212"\w* \w paz|strong="H7965"\w*.
\p 
\v 24 Entonces \w Joab|strong="H3097"\w* \w fue|strong="H3212"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* y dijo: ¿\w Qué|strong="H4100"\w* \w hiciste|strong="H6213"\w*? ¡\w Ciertamente|strong="H2009"\w* Abner \w vino|strong="H3212"\w* \w a|strong="H3068"\w* ti! ¿\w Por|strong="H2088"\w* \w qué|strong="H4100"\w* \w lo|strong="H4100"\w* dejaste \w ir|strong="H3212"\w*? ¡\w Ya|strong="H3068"\w* \w salió|strong="H3212"\w*!
\v 25 ¡\w Tú|strong="H6213"\w* \w sabes|strong="H3045"\w* \w que|strong="H3588"\w* Abner, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Ner|strong="H5369"\w*, vino \w a|strong="H3068"\w* engañarte \w para|strong="H3588"\w* \w saber|strong="H3045"\w* adónde vas \w y|strong="H3588"\w* \w de|strong="H3588"\w* dónde vienes, \w y|strong="H3588"\w* \w saber|strong="H3045"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3588"\w* \w haces|strong="H6213"\w*!
\p 
\v 26 Cuando \w Joab|strong="H3097"\w* \w salió|strong="H3318"\w* \w de|strong="H5973"\w* la presencia \w de|strong="H5973"\w* \w David|strong="H1732"\w*, \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w tras|strong="H5973"\w* Abner, y \w lo|strong="H3808"\w* devolvieron desde \w el|strong="H5973"\w* pozo \w de|strong="H5973"\w* Sira, pero \w David|strong="H1732"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w supo|strong="H3045"\w*.
\v 27 Cuando Abner regresó \w a|strong="H3068"\w* \w Hebrón|strong="H2275"\w*, \w Joab|strong="H3097"\w* lo llamó aparte \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H1818"\w* la \w puerta|strong="H8179"\w* para \w hablarle|strong="H1696"\w* \w en|strong="H8432"\w* privado. \w Allí|strong="H8033"\w* lo \w hirió|strong="H5221"\w* por la quinta costilla, \w de|strong="H1818"\w* modo que \w murió|strong="H4191"\w*, \w a|strong="H3068"\w* causa \w de|strong="H1818"\w* la \w sangre|strong="H1818"\w* \w de|strong="H1818"\w* \w Asael|strong="H6214"\w*, hermano \w de|strong="H1818"\w* \w Joab|strong="H3097"\w*.
\p 
\v 28 Cuando \w David|strong="H1732"\w* \w supo|strong="H8085"\w* \w esto|strong="H3651"\w*, dijo: ¡Yo \w y|strong="H5355"\w* mi \w reino|strong="H4467"\w* somos inocentes ante \nd \w Yavé|strong="H3068"\w*\nd* \w para|strong="H5703"\w* \w siempre|strong="H5769"\w* \w de|strong="H5973"\w* la \w sangre|strong="H1818"\w* \w de|strong="H5973"\w* Abner, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Ner|strong="H5369"\w*!
\v 29 ¡Recaiga \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w Joab|strong="H3097"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* su padre! ¡\w Que|strong="H5921"\w* nunca \w falte|strong="H3772"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* \w Joab|strong="H3097"\w* uno \w que|strong="H5921"\w* padezca flujo, \w que|strong="H5921"\w* sea \w leproso|strong="H6879"\w*, \w que|strong="H5921"\w* \w se|strong="H5921"\w* apoye \w en|strong="H5921"\w* muleta, \w que|strong="H5921"\w* muera \w a|strong="H3068"\w* \w espada|strong="H2719"\w* \w o|strong="H3068"\w* \w que|strong="H5921"\w* carezca \w de|strong="H5921"\w* \w pan|strong="H3899"\w*!
\p 
\v 30 Así \w Joab|strong="H3097"\w* \w y|strong="H5921"\w* Abisai su hermano asesinaron \w a|strong="H3068"\w* Abner, \w porque|strong="H5921"\w* \w él|strong="H5921"\w* dio \w muerte|strong="H4191"\w* \w a|strong="H3068"\w* \w Asael|strong="H6214"\w*, hermano \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*, durante \w la|strong="H5921"\w* \w batalla|strong="H4421"\w* \w en|strong="H5921"\w* \w Gabaón|strong="H1391"\w*.
\p 
\v 31 Después \w David|strong="H1732"\w* dijo \w a|strong="H3068"\w* \w Joab|strong="H3097"\w* y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* estaba con \w él|strong="H3605"\w*: ¡Rasguen sus ropas, átense tela áspera y hagan duelo \w por|strong="H6440"\w* Abner! \w Y|strong="H3068"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w iba|strong="H1980"\w* detrás del féretro.
\v 32 \w Sepultaron|strong="H6912"\w* \w a|strong="H3068"\w* Abner \w en|strong="H6912"\w* \w Hebrón|strong="H2275"\w*. \w El|strong="H3605"\w* \w rey|strong="H4428"\w* \w alzó|strong="H5375"\w* su \w voz|strong="H6963"\w* y \w lloró|strong="H1058"\w* \w junto|strong="H5971"\w* \w al|strong="H4428"\w* \w sepulcro|strong="H6913"\w* \w de|strong="H5971"\w* Abner. \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* también \w lloró|strong="H1058"\w*.
\s1 Endecha de David por Abner
\p 
\v 33 El \w rey|strong="H4428"\w* pronunció esta endecha \w por|strong="H4428"\w* Abner:
\q1 ¿Tenía que \w morir|strong="H4191"\w* Abner como muere un \w insensato|strong="H5036"\w*?
\q1 
\v 34 Tus \w manos|strong="H3027"\w* \w no|strong="H3808"\w* \w estaban|strong="H5971"\w* atadas,
\q1 \w Ni|strong="H3808"\w* impedidos tus \w pies|strong="H7272"\w* \w con|strong="H5921"\w* grillos.
\q1 \w Más|strong="H3254"\w* bien, \w como|strong="H5921"\w* \w el|strong="H5921"\w* \w que|strong="H3808"\w* \w cae|strong="H5307"\w* \w ante|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w iniquidad|strong="H5766"\w*, así \w caíste|strong="H5307"\w* tú.
\p \w Y|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w volvió|strong="H3254"\w* \w a|strong="H3068"\w* llorar \w por|strong="H5921"\w* \w él|strong="H5921"\w*.
\p 
\v 35 Después \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* fue \w a|strong="H3068"\w* rogar \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w que|strong="H3588"\w* comiera ese \w día|strong="H3117"\w*, \w pero|strong="H3588"\w* \w David|strong="H1732"\w* \w juró|strong="H7650"\w*: \w Así|strong="H3541"\w* \w me|strong="H3588"\w* \w haga|strong="H6213"\w* \nd ʼElohim\nd* \w y|strong="H3588"\w* \w aun|strong="H5750"\w* \w me|strong="H3588"\w* \w añada|strong="H3254"\w* \w si|strong="H3588"\w* \w yo|strong="H3588"\w* pruebo \w pan|strong="H3899"\w* \w o|strong="H3068"\w* \w cualquier|strong="H3605"\w* \w otra|strong="H5750"\w* \w cosa|strong="H3605"\w* \w antes|strong="H6440"\w* \w que|strong="H3588"\w* \w se|strong="H5971"\w* oculte \w el|strong="H3588"\w* \w sol|strong="H8121"\w*.
\p 
\v 36 \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* supo \w esto|strong="H6213"\w*, y \w lo|strong="H6213"\w* vio con \w agrado|strong="H3190"\w*. \w Todo|strong="H3605"\w* cuanto \w hacía|strong="H6213"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w parecía|strong="H5869"\w* \w bien|strong="H2896"\w* \w al|strong="H4428"\w* \w pueblo|strong="H5971"\w*.
\v 37 \w Así|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w entendió|strong="H3045"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w que|strong="H3588"\w* \w la|strong="H1931"\w* \w muerte|strong="H4191"\w* \w de|strong="H3588"\w* Abner, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Ner|strong="H5369"\w*, \w no|strong="H3808"\w* provino del \w rey|strong="H4428"\w*.
\p 
\v 38 \w El|strong="H3588"\w* \w rey|strong="H4428"\w* dijo \w a|strong="H3068"\w* sus esclavos: ¿\w No|strong="H3808"\w* \w saben|strong="H3045"\w* ustedes \w que|strong="H3588"\w* un \w jefe|strong="H8269"\w* \w y|strong="H3588"\w* un \w gran|strong="H1419"\w* hombre \w cayó|strong="H5307"\w* \w hoy|strong="H3117"\w* \w en|strong="H3588"\w* \w Israel|strong="H3478"\w*?
\v 39 \w Y|strong="H3068"\w* \w yo|strong="H4480"\w*, aunque fui \w ungido|strong="H4886"\w* como \w rey|strong="H4428"\w*, fui benévolo, mientras \w que|strong="H4480"\w* esa gente, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Sarvia, fueron \w más|strong="H4480"\w* duros \w que|strong="H4480"\w* \w yo|strong="H4480"\w*. ¡\w Que|strong="H4480"\w* \nd \w Yavé|strong="H3068"\w*\nd* retribuya \w al|strong="H4480"\w* malhechor según su perversidad!
\c 4
\s1 Asesinado Is-boset
\p 
\v 1 \w Cuando|strong="H3588"\w* Is-boset, \w el|strong="H3588"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Saúl|strong="H7586"\w*, \w supo|strong="H8085"\w* \w que|strong="H3588"\w* Abner \w murió|strong="H4191"\w* \w en|strong="H3588"\w* \w Hebrón|strong="H2275"\w*, sus \w manos|strong="H3027"\w* se debilitaron \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* fue perturbado.
\v 2 \w El|strong="H5921"\w* \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Saúl|strong="H7586"\w* \w tenía|strong="H1961"\w* \w dos|strong="H8147"\w* \w hombres|strong="H1121"\w* \w que|strong="H3588"\w* \w eran|strong="H1961"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* bandas. Uno \w se|strong="H1961"\w* \w llamaba|strong="H8034"\w* \w Baana|strong="H1196"\w* \w y|strong="H1571"\w* \w el|strong="H5921"\w* \w otro|strong="H8145"\w*, Recab, \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Rimón beerotita, \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Benjamín|strong="H1144"\w*. Beerot \w era|strong="H1961"\w* \w también|strong="H1571"\w* considerada \w como|strong="H3588"\w* \w de|strong="H5921"\w* \w Benjamín|strong="H1144"\w*,
\v 3 \w pues|strong="H2088"\w* \w los|strong="H1961"\w* beerotitas \w huyeron|strong="H1272"\w* \w a|strong="H3068"\w* Gitaim \w y|strong="H5704"\w* viven \w allí|strong="H8033"\w* \w como|strong="H1961"\w* forasteros \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.
\p 
\v 4 Jonatán, \w hijo|strong="H1121"\w* \w de|strong="H2568"\w* \w Saúl|strong="H7586"\w*, \w tuvo|strong="H1961"\w* un \w hijo|strong="H1121"\w* \w lisiado|strong="H5223"\w* \w de|strong="H2568"\w* \w los|strong="H1121"\w* \w pies|strong="H7272"\w*, quien \w tenía|strong="H1961"\w* \w cinco|strong="H2568"\w* \w años|strong="H8141"\w* \w cuando|strong="H1961"\w* llegaron las noticias \w de|strong="H2568"\w* \w Jezreel|strong="H3157"\w* acerca \w de|strong="H2568"\w* \w Saúl|strong="H7586"\w* y Jonatán. Su madre \w de|strong="H2568"\w* crianza lo \w tomó|strong="H5375"\w* y \w huyó|strong="H5127"\w*. Pero mientras huía apresuradamente, \w él|strong="H5307"\w* \w cayó|strong="H5307"\w* y \w quedó|strong="H1961"\w* cojo. Su \w nombre|strong="H8034"\w* \w era|strong="H1961"\w* Mefi-boset.
\p 
\v 5 Recab y Baanaos, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Rimón beerotita, \w fueron|strong="H3212"\w* y \w entraron|strong="H3212"\w* al mediodía \w en|strong="H3212"\w* \w casa|strong="H1004"\w* \w de|strong="H1121"\w* Is-boset mientras dormía \w la|strong="H1931"\w* siesta.
\v 6 Entraron \w hasta|strong="H5704"\w* el interior \w de|strong="H5704"\w* la \w casa|strong="H1004"\w* \w como|strong="H5704"\w* \w para|strong="H5704"\w* llevar \w trigo|strong="H2406"\w*. \w Lo|strong="H2007"\w* \w hirieron|strong="H5221"\w* \w por|strong="H5704"\w* la quinta costilla, \w y|strong="H5704"\w* \w luego|strong="H5704"\w* Recab \w y|strong="H5704"\w* \w Baana|strong="H1196"\w* huyeron.
\p 
\v 7 Cuando \w entraron|strong="H3212"\w* \w en|strong="H5921"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w*, \w él|strong="H1931"\w* \w estaba|strong="H7901"\w* \w acostado|strong="H7901"\w* \w en|strong="H5921"\w* \w su|strong="H1931"\w* lecho \w en|strong="H5921"\w* \w la|strong="H1931"\w* alcoba, \w donde|strong="H5921"\w* \w lo|strong="H1931"\w* \w hirieron|strong="H5221"\w* \w y|strong="H5921"\w* \w mataron|strong="H5221"\w*. \w Luego|strong="H1931"\w* \w lo|strong="H1931"\w* decapitaron, \w tomaron|strong="H3947"\w* \w su|strong="H1931"\w* \w cabeza|strong="H7218"\w* \w y|strong="H5921"\w* \w caminaron|strong="H3212"\w* \w por|strong="H5921"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w* \w del|strong="H5921"\w* Arabá \w toda|strong="H3605"\w* \w la|strong="H1931"\w* \w noche|strong="H3915"\w*.
\v 8 Llevaron la \w cabeza|strong="H7218"\w* \w de|strong="H1121"\w* Is-boset \w a|strong="H3068"\w* \w David|strong="H1732"\w* en \w Hebrón|strong="H2275"\w*, y dijeron \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: \w Aquí|strong="H2009"\w* \w está|strong="H2088"\w* la \w cabeza|strong="H7218"\w* \w de|strong="H1121"\w* Is-boset, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* tu enemigo \w Saúl|strong="H7586"\w*, quien atentaba contra tu \w vida|strong="H5315"\w*. \nd \w Yavé|strong="H3068"\w*\nd* \w dio|strong="H5414"\w* \w hoy|strong="H3117"\w* \w a|strong="H3068"\w* \w mi|strong="H2009"\w* \tl ʼadón\tl* \w el|strong="H1121"\w* \w rey|strong="H4428"\w* \w venganza|strong="H5360"\w* \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w* y \w de|strong="H1121"\w* su \w descendencia|strong="H2233"\w*.
\p 
\v 9 Pero \w David|strong="H1732"\w* \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* Recab y \w Baana|strong="H1196"\w*, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Rimón beerotita: ¡\w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w que|strong="H1121"\w* rescató \w mi|strong="H6030"\w* \w vida|strong="H5315"\w* \w de|strong="H1121"\w* \w toda|strong="H3605"\w* adversidad!
\v 10 \w Si|strong="H3588"\w* al \w que|strong="H3588"\w* \w me|strong="H3588"\w* informó: \w ciertamente|strong="H3588"\w* \w Saúl|strong="H7586"\w* \w murió|strong="H4191"\w*, \w lo|strong="H1931"\w* detuve \w y|strong="H3588"\w* ordené \w que|strong="H3588"\w* \w lo|strong="H1931"\w* \w mataran|strong="H4191"\w* \w en|strong="H3588"\w* \w Siclag|strong="H6860"\w* \w en|strong="H3588"\w* \w pago|strong="H5414"\w* \w por|strong="H3588"\w* \w la|strong="H1931"\w* noticia, \w aunque|strong="H3588"\w* \w se|strong="H1961"\w* creía portador \w de|strong="H3588"\w* buenas noticias,
\v 11 ¡\w cuánto|strong="H3588"\w* \w más|strong="H3588"\w* \w a|strong="H3068"\w* ustedes, hombres perversos \w que|strong="H3588"\w* asesinaron \w a|strong="H3068"\w* un hombre \w justo|strong="H6662"\w* \w en|strong="H5921"\w* \w su|strong="H3588"\w* propio lecho \w y|strong="H3588"\w* \w en|strong="H5921"\w* \w su|strong="H3588"\w* misma \w casa|strong="H1004"\w*! ¿\w No|strong="H3808"\w* \w demandaré|strong="H1245"\w* \w ahora|strong="H6258"\w* \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w de|strong="H4480"\w* \w él|strong="H5921"\w* \w de|strong="H4480"\w* \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H4480"\w* ustedes, \w al|strong="H5921"\w* eliminarlo \w de|strong="H4480"\w* \w la|strong="H5921"\w* tierra?
\p 
\v 12 \w David|strong="H1732"\w* dio \w orden|strong="H6680"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* jóvenes, \w y|strong="H5921"\w* éstos \w los|strong="H5921"\w* \w mataron|strong="H2026"\w*. \w Les|strong="H5921"\w* cortaron \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w y|strong="H5921"\w* \w los|strong="H5921"\w* \w pies|strong="H7272"\w*. \w A|strong="H3068"\w* \w ellos|strong="H3027"\w* \w los|strong="H5921"\w* \w colgaron|strong="H8518"\w* \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w estanque|strong="H1295"\w* \w de|strong="H5921"\w* \w Hebrón|strong="H2275"\w*. Luego \w tomaron|strong="H3947"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* Is-boset \w y|strong="H5921"\w* \w la|strong="H5921"\w* enterraron \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w sepulcro|strong="H6913"\w* \w de|strong="H5921"\w* Abner \w en|strong="H5921"\w* \w Hebrón|strong="H2275"\w*.
\c 5
\s1 David, rey de Israel
\p 
\v 1 Entonces \w todas|strong="H3605"\w* las \w tribus|strong="H7626"\w* de \w Israel|strong="H3478"\w* \w fueron|strong="H1732"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* en \w Hebrón|strong="H2275"\w* y dijeron: ¡\w Aquí|strong="H2005"\w* estamos, \w hueso|strong="H6106"\w* tuyo y \w carne|strong="H1320"\w* tuya!
\v 2 Antes, \w cuando|strong="H1571"\w* \w Saúl|strong="H7586"\w* \w era|strong="H1961"\w* nuestro \w rey|strong="H4428"\w*, \w eras|strong="H1961"\w* tú quien \w nos|strong="H5921"\w* sacabas \w y|strong="H1571"\w* \w nos|strong="H5921"\w* devolvías \w en|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w y|strong="H1571"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w te|strong="H5921"\w* dijo: \wj Tú \w apacentarás|strong="H7462"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w* \w y|strong="H1571"\w* \w serás|strong="H1961"\w* \w el|strong="H5921"\w* jefe \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.\wj*
\p 
\v 3 Cuando \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w ancianos|strong="H2205"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w fueron|strong="H1732"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w en|strong="H5921"\w* \w Hebrón|strong="H2275"\w*, \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w* \w hizo|strong="H3772"\w* un \w pacto|strong="H1285"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* \w Hebrón|strong="H2275"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w Y|strong="H3068"\w* \w ungieron|strong="H4886"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w como|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.
\p 
\v 4 \w David|strong="H1732"\w* comenzó \w a|strong="H3068"\w* reinar cuando tenía 30 \w años|strong="H8141"\w* y \w reinó|strong="H4427"\w* 40 \w años|strong="H8141"\w*.
\v 5 \w En|strong="H5921"\w* \w Hebrón|strong="H2275"\w* \w reinó|strong="H4427"\w* \w sobre|strong="H5921"\w* \w Judá|strong="H3063"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w* \w y|strong="H5921"\w* \w seis|strong="H8337"\w* \w meses|strong="H2320"\w*, \w y|strong="H5921"\w* \w en|strong="H5921"\w* Jerusalén \w reinó|strong="H4427"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w Judá|strong="H3063"\w* 33 \w años|strong="H8141"\w*.
\p 
\v 6 \w El|strong="H3588"\w* \w rey|strong="H4428"\w* marchó \w con|strong="H3588"\w* sus hombres \w a|strong="H3068"\w* Jerusalén contra \w los|strong="H3427"\w* \w jebuseos|strong="H2983"\w* \w que|strong="H3588"\w* \w habitaban|strong="H3427"\w* \w en|strong="H3588"\w* aquella tierra, quienes hablaron \w a|strong="H3068"\w* \w David|strong="H1732"\w*: \w No|strong="H3808"\w* \w podrás|strong="H3808"\w* entrar \w acá|strong="H2008"\w*, \w pues|strong="H3588"\w* hasta \w los|strong="H3427"\w* \w ciegos|strong="H5787"\w* \w y|strong="H3588"\w* \w los|strong="H3427"\w* cojos \w te|strong="H3588"\w* rechazarían \w y|strong="H3588"\w* gritarían: ¡\w David|strong="H1732"\w* \w no|strong="H3808"\w* puede entrar \w acá|strong="H2008"\w*!
\v 7 Pero \w David|strong="H1732"\w* capturó \w la|strong="H1931"\w* fortaleza de \w Sion|strong="H6726"\w*, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w Ciudad|strong="H5892"\w* de \w David|strong="H1732"\w*.
\p 
\v 8 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w David|strong="H1732"\w* dijo: \w El|strong="H1931"\w* \w que|strong="H1931"\w* quiera atacar \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w jebuseos|strong="H2983"\w*, suba \w por|strong="H5921"\w* \w el|strong="H1931"\w* túnel \w del|strong="H5921"\w* acueducto \w y|strong="H5921"\w* llegue \w hasta|strong="H5921"\w* \w los|strong="H5921"\w* cojos \w y|strong="H5921"\w* \w ciegos|strong="H5787"\w*, \w a|strong="H3068"\w* quienes \w el|strong="H1931"\w* \w alma|strong="H5315"\w* \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w aborrece|strong="H8130"\w*. \w Por|strong="H5921"\w* \w lo|strong="H1931"\w* \w cual|strong="H1931"\w* \w se|strong="H1931"\w* dice: ¡\w Ni|strong="H3808"\w* \w ciegos|strong="H5787"\w* \w ni|strong="H3808"\w* cojos entrarán \w en|strong="H5921"\w* \w la|strong="H1931"\w* \w Casa|strong="H1004"\w*!
\p 
\v 9 \w David|strong="H1732"\w* vivió \w en|strong="H4480"\w* la fortaleza y la \w llamó|strong="H7121"\w* \w Ciudad|strong="H5892"\w* \w de|strong="H4480"\w* \w David|strong="H1732"\w*. Luego \w edificó|strong="H1129"\w* \w alrededor|strong="H5439"\w*, \w desde|strong="H4480"\w* \w el|strong="H3427"\w* muro \w hacia|strong="H4480"\w* \w adentro|strong="H1004"\w*.
\v 10 \w David|strong="H1732"\w* se engrandecía cada vez más, \w porque|strong="H1732"\w* \nd \w Yavé|strong="H3068"\w* ʼElohim\nd* \w de|strong="H5973"\w* las huestes estaba \w con|strong="H5973"\w* \w él|strong="H5973"\w*.
\p 
\v 11 \w Hiram|strong="H2438"\w*, \w rey|strong="H4428"\w* de \w Tiro|strong="H6865"\w*, \w envió|strong="H7971"\w* \w embajadores|strong="H4397"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*, con \w madera|strong="H6086"\w* de cedro, ebanistas y canteros para los muros, quienes \w edificaron|strong="H1129"\w* la \w casa|strong="H1004"\w* de \w David|strong="H1732"\w*.
\p 
\v 12 \w David|strong="H1732"\w* \w entendió|strong="H3045"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w lo|strong="H5921"\w* \w había|strong="H3588"\w* \w establecido|strong="H3559"\w* \w como|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w había|strong="H3588"\w* exaltado \w su|strong="H3588"\w* \w reino|strong="H4467"\w* \w por|strong="H5921"\w* amor \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*.
\p 
\v 13 Después \w que|strong="H1121"\w* salió \w de|strong="H5750"\w* \w Hebrón|strong="H2275"\w*, \w David|strong="H1732"\w* \w tomó|strong="H3947"\w* otras \w concubinas|strong="H6370"\w* y esposas \w en|strong="H5750"\w* Jerusalén, y le \w nacieron|strong="H3205"\w* \w más|strong="H5750"\w* \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*.
\v 14 Estos son los \w nombres|strong="H8034"\w* de los que le nacieron en Jerusalén: \w Samúa|strong="H8051"\w*, \w Sobab|strong="H7727"\w*, Natán, \w Salomón|strong="H8010"\w*,
\v 15 \w Ibhar|strong="H2984"\w*, Elisúa, Nefeg, Jafía,
\v 16 Elisama, Eliada y Elifelet.
\p 
\v 17 \w Cuando|strong="H3588"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* \w oyeron|strong="H8085"\w* \w que|strong="H3588"\w* \w David|strong="H1732"\w* fue \w ungido|strong="H4886"\w* \w como|strong="H3588"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w todos|strong="H3605"\w* \w subieron|strong="H5927"\w* \w en|strong="H5921"\w* \w busca|strong="H1245"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*. \w David|strong="H1732"\w* \w lo|strong="H5921"\w* \w supo|strong="H8085"\w* \w y|strong="H3588"\w* bajó \w a|strong="H3068"\w* \w la|strong="H5921"\w* fortaleza.
\v 18 Los \w filisteos|strong="H6430"\w* llegaron y se desplegaron por el \w valle|strong="H6010"\w* de Refaim.
\p 
\v 19 \w David|strong="H1732"\w* \w consultó|strong="H7592"\w* \w entonces|strong="H3588"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: ¿Subo contra \w los|strong="H3588"\w* \w filisteos|strong="H6430"\w*? ¿\w Los|strong="H3588"\w* entregarás \w en|strong="H3588"\w* mi \w mano|strong="H3027"\w*?
\p \w Y|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* respondió \w a|strong="H3068"\w* \w David|strong="H1732"\w*: \wj \w Sube|strong="H5927"\w*, \w porque|strong="H3588"\w* \w ciertamente|strong="H3588"\w* \w entregaré|strong="H5414"\w* \w a|strong="H3068"\w* \w los|strong="H3588"\w* \w filisteos|strong="H6430"\w* \w en|strong="H3588"\w* tu \w mano|strong="H3027"\w*.\wj*
\p 
\v 20 \w David|strong="H1732"\w* \w fue|strong="H1931"\w* \w a|strong="H3068"\w* Baal-perazim \w y|strong="H5921"\w* \w allí|strong="H8033"\w* \w los|strong="H5921"\w* derrotó, \w y|strong="H5921"\w* dijo: ¡\nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H5921"\w* abrió brecha \w entre|strong="H5921"\w* mis enemigos \w como|strong="H5921"\w* corriente impetuosa! \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w llamó|strong="H7121"\w* \w aquel|strong="H1931"\w* \w lugar|strong="H4725"\w* Baal-perazim.
\v 21 Ellos \w dejaron|strong="H5800"\w* \w allí|strong="H8033"\w* sus \w ídolos|strong="H6091"\w*, y \w David|strong="H1732"\w* y sus hombres se los \w llevaron|strong="H5375"\w*.
\p 
\v 22 Los \w filisteos|strong="H6430"\w* volvieron \w a|strong="H3068"\w* \w subir|strong="H5927"\w* y se desplegaron \w por|strong="H5750"\w* el \w valle|strong="H6010"\w* \w de|strong="H5750"\w* Refaim.
\p 
\v 23 \w David|strong="H1732"\w* \w consultó|strong="H7592"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, y Él le dijo: \wj \w No|strong="H3808"\w* \w subas|strong="H5927"\w*, \w sino|strong="H3808"\w* rodéalos por detrás, y sal \w a|strong="H3068"\w* ellos frente \w a|strong="H3068"\w* las balsameras.\wj*
\v 24 \wj \w Cuando|strong="H3588"\w* \w oigas|strong="H8085"\w* \w el|strong="H3588"\w* \w ruido|strong="H6963"\w* \w de|strong="H3588"\w* marcha \w en|strong="H3588"\w* las copas \w de|strong="H3588"\w* las balsameras, \w te|strong="H3588"\w* apresurarás, \w porque|strong="H3588"\w* \w entonces|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w saldrá|strong="H3318"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti \w para|strong="H3588"\w* herir al \w ejército|strong="H4264"\w* \w de|strong="H3588"\w* \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w*.\wj*
\p 
\v 25 \w David|strong="H1732"\w* \w hizo|strong="H6213"\w* \w como|strong="H5704"\w* \nd \w Yavé|strong="H3068"\w*\nd* le \w ordenó|strong="H6680"\w*, \w y|strong="H5704"\w* derrotó \w a|strong="H3068"\w* los \w filisteos|strong="H6430"\w* \w desde|strong="H5704"\w* Geba \w hasta|strong="H5704"\w* \w Gezer|strong="H1507"\w*.
\c 6
\s1 El traslado del Arca
\p 
\v 1 \w David|strong="H1732"\w* \w volvió|strong="H3254"\w* \w a|strong="H3068"\w* reunir \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* escogidos \w de|strong="H5750"\w* \w Israel|strong="H3478"\w*: 30.000.
\p 
\v 2 Entonces \w David|strong="H1732"\w* \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w y|strong="H5921"\w* \w salió|strong="H3212"\w* \w a|strong="H3068"\w* Baala \w de|strong="H5921"\w* Judá \w con|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5921"\w* tenía \w consigo|strong="H5921"\w*, \w para|strong="H5921"\w* \w subir|strong="H5927"\w* \w desde|strong="H5921"\w* \w allí|strong="H8033"\w* \w el|strong="H5921"\w* Arca \w de|strong="H5921"\w* \nd ʼElohim\nd*, \w la|strong="H5921"\w* cual es \w llamada|strong="H8034"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w Nombre|strong="H8034"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes, \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* cual \w están|strong="H3427"\w* \w los|strong="H3427"\w* \w querubines|strong="H3742"\w*.
\v 3 Pusieron \w el|strong="H1121"\w* Arca \w de|strong="H1121"\w* \nd ʼElohim\nd* en una carroza \w nueva|strong="H2319"\w*, y se la \w llevaron|strong="H5375"\w* \w de|strong="H1121"\w* la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* Abinadab \w que|strong="H1121"\w* \w estaba|strong="H1004"\w* en la colina.
\p Uza y Ahío, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Abinadab, conducían la carroza \w nueva|strong="H2319"\w*
\v 4 y la sacaron \w con|strong="H5973"\w* \w el|strong="H5973"\w* Arca \w de|strong="H6440"\w* \nd ʼElohim\nd* \w de|strong="H6440"\w* la \w casa|strong="H1004"\w* \w de|strong="H6440"\w* Abinadab que \w estaba|strong="H1004"\w* \w en|strong="H5973"\w* la colina. Ahío \w iba|strong="H1980"\w* \w delante|strong="H6440"\w* \w del|strong="H5973"\w* Arca.
