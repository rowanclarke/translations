\m
\v 33 Entonces el rey se turbó, y subióse \w a|strong="H3068"\w* la sala de la puerta, y lloró; y yendo, decía así: ¡Hijo mío Absalom, hijo mío, hijo mío Absalom! ¡Quién me diera que muriera yo en lugar de ti, Absalom, hijo mío, hijo mío!   
\c 19
\m
\v 1 \w Y|strong="H3068"\w* \w DIERON|strong="H5414"\w* aviso \w a|strong="H3068"\w* Joab: He \w aquí|strong="H3541"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w llora|strong="H1058"\w*, \w y|strong="H5921"\w* hace duelo \w por|strong="H5921"\w* Absalom.   
\m
\v 2 \w Y|strong="H3068"\w* volvióse aquel día \w la|strong="H5921"\w* victoria \w en|strong="H5921"\w* luto \w para|strong="H5921"\w* todo \w el|strong="H5921"\w* pueblo; \w por|strong="H5921"\w*­\w que|strong="H5921"\w* oyó decir \w el|strong="H5921"\w* pueblo aquel día \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* tenía dolor \w por|strong="H5921"\w* su hijo.   
\m
\v 3 Entróse \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w en|strong="H5921"\w* \w la|strong="H1931"\w* ciudad escondidamente, \w como|strong="H3588"\w* suele entrar \w a|strong="H3068"\w* escondidas \w el|strong="H1931"\w* pue­blo avergonzado \w que|strong="H3588"\w* ha huído \w de|strong="H5921"\w* \w la|strong="H1931"\w* batalla.   
\m
\v 4 Mas \w el|strong="H1931"\w* rey, cubierto \w el|strong="H1931"\w* rostro, clamaba en alta voz: ¡Hijo \w mío|strong="H5971"\w* Absalom, Absalom, hijo \w mío|strong="H5971"\w*, hijo \w mío|strong="H5971"\w*!   
\m
\v 5 \w Y|strong="H3068"\w* entrando Joab en casa \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, díjole: Hoy has avergonzado \w el|strong="H1121"\w* \w rostro|strong="H6440"\w* \w de|strong="H6440"\w* todos tus siervos, \w que|strong="H1121"\w* han hoy librado tu vida, y la vida \w de|strong="H6440"\w* tus \w hijos|strong="H1121"\w* y \w de|strong="H6440"\w* tus hijas, y la vida \w de|strong="H6440"\w* tus esposas, y la vida \w de|strong="H6440"\w* tus concubinas,   
\m
\v 6 Amando \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w que|strong="H3117"\w* \w te|strong="H5315"\w* aborrecen, y aborreciendo \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w que|strong="H3117"\w* \w te|strong="H5315"\w* aman: \w porque|strong="H6440"\w* \w hoy|strong="H3117"\w* has declarado \w que|strong="H3117"\w* \w nada|strong="H3605"\w* \w te|strong="H5315"\w* importan tus príncipes y \w siervos|strong="H5650"\w*; pues \w hoy|strong="H3117"\w* echo \w de|strong="H6440"\w* ver \w que|strong="H3117"\w* \w si|strong="H6440"\w* Absalom viviera, bien \w que|strong="H3117"\w* \w nosotros|strong="H3605"\w* \w todos|strong="H3605"\w* estuviéramos \w hoy|strong="H3117"\w* muertos, \w entonces|strong="H3117"\w* \w te|strong="H5315"\w* contentaras.   
\m
\v 7 Levántate \w pues|strong="H3588"\w* \w ahora|strong="H3117"\w*, \w y|strong="H3588"\w* sal fuera, \w y|strong="H3588"\w* halaga \w a|strong="H3068"\w* tus \w siervos|strong="H5650"\w*: \w por|strong="H3588"\w*­\w que|strong="H3588"\w* juro \w por|strong="H3588"\w* \w el|strong="H3588"\w* SEÑOR, \w que|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3588"\w* sales, ni \w aun|strong="H3588"\w* uno quede conti­go esta noche; \w y|strong="H3588"\w* \w de|strong="H3588"\w* esto \w te|strong="H5869"\w* pesa­rá \w más|strong="H3588"\w* \w que|strong="H3588"\w* \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* males \w que|strong="H3588"\w* \w te|strong="H5869"\w* \w han|strong="H4191"\w* sobrevenido desde tu mocedad \w hasta|strong="H3117"\w* \w ahora|strong="H3117"\w*.   
\m
\v 8 \w Entonces|strong="H3588"\w* \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w el|strong="H5921"\w* rey, \w y|strong="H3588"\w* sentóse \w a|strong="H3068"\w* \w la|strong="H5921"\w* puerta; \w y|strong="H3588"\w* fue declara­do \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* pueblo, \w diciendo|strong="H1696"\w*: He aquí \w el|strong="H5921"\w* rey \w está|strong="H2063"\w* sentado \w a|strong="H3068"\w* \w la|strong="H5921"\w* puer­ta. \w Y|strong="H3068"\w* vino \w todo|strong="H3605"\w* \w el|strong="H5921"\w* pueblo \w delante|strong="H5921"\w* \w del|strong="H5921"\w* rey; \w mas|strong="H3588"\w* Israel \w había|strong="H3588"\w* huído, \w cada|strong="H3605"\w* uno \w a|strong="H3068"\w* sus estancias.   
\m
\v 9 \w Y|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* porfiaba en \w todas|strong="H3605"\w* las tribus \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, dicien­do: \w El|strong="H3605"\w* \w rey|strong="H4428"\w* nos ha librado \w de|strong="H6440"\w* mano \w de|strong="H6440"\w* nuestros enemigos, y \w él|strong="H3605"\w* nos ha salvado \w de|strong="H6440"\w* mano \w de|strong="H6440"\w* \w los|strong="H3427"\w* filisteos; y \w ahora|strong="H2009"\w* había huído \w de|strong="H6440"\w* \w la|strong="H3605"\w* tierra \w por|strong="H6440"\w* miedo \w de|strong="H6440"\w* Absalom.   
\m
\v 10 \w Y|strong="H3068"\w* Absalom, \w a|strong="H3068"\w* \w quien|strong="H3605"\w* habíamos ungido \w sobre|strong="H5921"\w* \w nosotros|strong="H3605"\w*, \w es|strong="H1931"\w* muerto \w en|strong="H5921"\w* \w la|strong="H1931"\w* batalla. ¿\w Por|strong="H5921"\w* \w qué|strong="H4480"\w* \w pues|strong="H6258"\w* \w os|strong="H4480"\w* estáis \w ahora|strong="H6258"\w* quedos \w en|strong="H5921"\w* orden \w a|strong="H3068"\w* hacer volver \w al|strong="H5921"\w* \w rey|strong="H4428"\w*?   
\m
\v 11 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H4428"\w* envió \w a|strong="H3068"\w* Sadoc \w y|strong="H5921"\w* \w a|strong="H3068"\w* Abiatar sacerdotes, diciendo: Hablad \w a|strong="H3068"\w* \w los|strong="H5921"\w* ancianos \w de|strong="H5921"\w* Judá, \w y|strong="H5921"\w* decidles: ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* seréis vosotros \w los|strong="H5921"\w* postreros \w en|strong="H5921"\w* \w volver|strong="H7725"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w a|strong="H3068"\w* su casa, \w ya|strong="H6258"\w* \w que|strong="H4100"\w* \w la|strong="H5921"\w* palabra \w de|strong="H5921"\w* todo Israel ha venido \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \add de volverle\add* \w a|strong="H3068"\w* su casa?   
\m
\v 12 Vosotros \w sois|strong="H1961"\w* mis hermanos; mis huesos y \w mi|strong="H1961"\w* carne \w sois|strong="H1961"\w*: ¿\w por|strong="H1697"\w* \w qué|strong="H4100"\w* \w pues|strong="H1961"\w* \w seréis|strong="H1961"\w* vosotros \w los|strong="H3605"\w* pos­treros en \w volver|strong="H7725"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*?   
\m
\v 13 Asimismo diréis \w a|strong="H3068"\w* Amasa: ¿\w No|strong="H1961"\w* \w eres|strong="H1961"\w* tú también \w hueso|strong="H6106"\w* mío y \w carne|strong="H1320"\w* mía? Así me haga Dios, y así me añada, \w si|strong="H1961"\w* \w no|strong="H1961"\w* \w fueres|strong="H1961"\w* gene­ral del ejército delante de \w mí|strong="H1961"\w* \w para|strong="H1961"\w* siempre, en lugar de Joab.   
\m
\v 14 \w Así|strong="H3541"\w* inclinó \w el|strong="H3605"\w* corazón \w de|strong="H8478"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* varones \w de|strong="H8478"\w* Judá, \w como|strong="H1961"\w* \add el\add* \w de|strong="H8478"\w* un solo hombre, \w para|strong="H1961"\w* \w que|strong="H3808"\w* enviasen \add a decir\add* \w al|strong="H8478"\w* \w rey|strong="H6213"\w*: Vuelve \w tú|strong="H6213"\w*, \w y|strong="H3541"\w* \w todos|strong="H3605"\w* tus siervos.   
\m
