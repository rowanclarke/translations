\v 18 \w A|strong="G4160"\w* \w good|strong="G2570"\w* \w tree|strong="G1186"\w* \w cannot|strong="G1410"\w* \w produce|strong="G4160"\w* \w evil|strong="G4190"\w* \w fruits|strong="G2590"\w*, \w nor|strong="G3761"\w* \w can|strong="G1410"\w* \w a|strong="G4160"\w* rotten \w tree|strong="G1186"\w* \w produce|strong="G4160"\w* \w good|strong="G2570"\w* \w fruits|strong="G2590"\w*.  
