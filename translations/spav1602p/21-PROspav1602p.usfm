\v 34 \w Porque|strong="H3588"\w* \w los|strong="H3588"\w* celos \add son\add* \w el|strong="H3588"\w* \w furor|strong="H2534"\w* del \w hombre|strong="H1397"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w perdonará|strong="H2550"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w venganza|strong="H5359"\w*.   
