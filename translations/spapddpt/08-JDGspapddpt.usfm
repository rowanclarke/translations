\v 15 Pero cuando \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w clamaron|strong="H2199"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w Él|strong="H1121"\w* les \w levantó|strong="H6965"\w* un libertador: Ehud, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Gera|strong="H1617"\w*, benjaminita, un \w hombre|strong="H1121"\w* zurdo, \w por|strong="H3027"\w* \w medio|strong="H3027"\w* \w de|strong="H1121"\w* quien \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w enviaron|strong="H7971"\w* un \w presente|strong="H4503"\w* \w a|strong="H3068"\w* \w Eglón|strong="H5700"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Moab|strong="H4124"\w*.
\v 16 Ehud \w se|strong="H5921"\w* \w hizo|strong="H6213"\w* un puñal \w de|strong="H5921"\w* \w dos|strong="H8147"\w* filos \w de|strong="H5921"\w* 45 centímetros \w de|strong="H5921"\w* largo \w y|strong="H5921"\w* \w lo|strong="H5921"\w* ató \w a|strong="H3068"\w* su cintura \w debajo|strong="H8478"\w* \w de|strong="H5921"\w* sus \w ropas|strong="H4055"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w lado|strong="H3409"\w* \w derecho|strong="H3225"\w*.
\v 17 Le entregó el \w presente|strong="H4503"\w* \w a|strong="H3068"\w* \w Eglón|strong="H5700"\w*, \w rey|strong="H4428"\w* de \w Moab|strong="H4124"\w*, quien era un hombre \w muy|strong="H3966"\w* obeso.
\v 18 \w Aconteció|strong="H1961"\w* \w que|strong="H5971"\w*, \w cuando|strong="H1961"\w* terminó \w de|strong="H5971"\w* ofrecer el \w presente|strong="H4503"\w*, \w despidió|strong="H7971"\w* \w a|strong="H3068"\w* la \w gente|strong="H5971"\w* \w que|strong="H5971"\w* lo \w llevó|strong="H5375"\w*.
\v 19 Pero \w él|strong="H1931"\w* regresó \w desde|strong="H4480"\w* \w los|strong="H5921"\w* \w ídolos|strong="H6456"\w* \w que|strong="H4480"\w* \w estaban|strong="H5975"\w* \w en|strong="H5921"\w* \w Gilgal|strong="H1537"\w*, \w y|strong="H5921"\w* dijo: Oh \w rey|strong="H4428"\w*, \w tengo|strong="H5921"\w* un mensaje secreto \w para|strong="H5921"\w* \w ti|strong="H4480"\w*. \w Y|strong="H3068"\w* \w él|strong="H1931"\w* dijo: ¡Guarden silencio! \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H4480"\w* \w lo|strong="H1931"\w* atendían \w salieron|strong="H3318"\w*.
\p 
\v 20 Entonces Ehud \w fue|strong="H1931"\w* \w a|strong="H3068"\w* \w él|strong="H1931"\w* cuando \w estaba|strong="H3427"\w* \w sentado|strong="H3427"\w* \w solo|strong="H1931"\w* \w en|strong="H5921"\w* \w su|strong="H1931"\w* sala \w de|strong="H5921"\w* verano. \w Y|strong="H3068"\w* Ehud dijo: \w Tengo|strong="H5921"\w* un mensaje \w de|strong="H5921"\w* \nd ʼElohim\nd* \w para|strong="H5921"\w* \w ti|strong="H5921"\w*. \w Y|strong="H3068"\w* \w él|strong="H1931"\w* \w se|strong="H1931"\w* \w levantó|strong="H6965"\w* \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w trono|strong="H3678"\w*.
\v 21 Entonces Ehud alargó su \w mano|strong="H3027"\w* \w izquierda|strong="H8040"\w*, \w tomó|strong="H3947"\w* \w el|strong="H5921"\w* puñal \w de|strong="H5921"\w* su \w muslo|strong="H3409"\w* \w derecho|strong="H3225"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w lo|strong="H5921"\w* hundió \w en|strong="H5921"\w* \w el|strong="H5921"\w* vientre.
\v 22 \w La|strong="H1571"\w* empuñadura entró \w tras|strong="H1157"\w* \w la|strong="H1571"\w* \w hoja|strong="H3851"\w*, \w y|strong="H1571"\w* \w la|strong="H1571"\w* grasa \w se|strong="H3808"\w* \w cerró|strong="H5462"\w* \w tras|strong="H1157"\w* ella. Ehud \w no|strong="H3808"\w* \w sacó|strong="H3318"\w* \w el|strong="H3588"\w* puñal \w de|strong="H3588"\w* \w su|strong="H3588"\w* vientre, \w y|strong="H1571"\w* \w se|strong="H3808"\w* \w le|strong="H1157"\w* \w salieron|strong="H3318"\w* \w los|strong="H3588"\w* excrementos.
\v 23 \w Cerró|strong="H5462"\w* y trancó las \w puertas|strong="H1817"\w* de la sala tras él y \w salió|strong="H3318"\w* al corredor.
\p 
\v 24 \w Cuando|strong="H5650"\w* \w salió|strong="H3318"\w*, llegaron \w los|strong="H1931"\w* esclavos del rey. Pero al \w ver|strong="H7200"\w* las \w puertas|strong="H1817"\w* de \w la|strong="H1931"\w* sala trancadas, dijeron: Probablemente \w está|strong="H1931"\w* atendiendo \w sus|strong="H1931"\w* necesidades \w en|strong="H3318"\w* \w la|strong="H1931"\w* \w cámara|strong="H2315"\w* fresca.
\v 25 Esperaron impacientemente \w hasta|strong="H5704"\w* quedar desconcertados. \w Como|strong="H5704"\w* \w él|strong="H5307"\w* no \w abría|strong="H6605"\w* las \w puertas|strong="H1817"\w* \w de|strong="H5704"\w* la sala, \w tomaron|strong="H3947"\w* la llave \w y|strong="H5704"\w* abrieron, \w y|strong="H5704"\w* ¡ahí \w estaba|strong="H2009"\w* su \tl ʼadón\tl* \w caído|strong="H5307"\w* \w en|strong="H5704"\w* tierra, \w muerto|strong="H4191"\w*!
\p 
\v 26 Pero \w mientras|strong="H5704"\w* \w ellos|strong="H1931"\w* \w se|strong="H1931"\w* demoraron, Ehud \w escapó|strong="H4422"\w*, \w pasó|strong="H5674"\w* \w más|strong="H5704"\w* allá \w de|strong="H5704"\w* \w los|strong="H1931"\w* \w ídolos|strong="H6456"\w* \w y|strong="H5704"\w* \w se|strong="H1931"\w* colocó \w a|strong="H3068"\w* salvo \w en|strong="H5704"\w* Seirat.
\v 27 \w Aconteció|strong="H1961"\w* \w que|strong="H4480"\w* \w cuando|strong="H1961"\w* \w entró|strong="H3381"\w*, resonó \w la|strong="H1931"\w* \w corneta|strong="H7782"\w* \w en|strong="H4480"\w* \w la|strong="H1931"\w* región montañosa \w de|strong="H4480"\w* Efraín, y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w bajaron|strong="H3381"\w* \w con|strong="H5973"\w* \w él|strong="H1931"\w* \w de|strong="H4480"\w* \w la|strong="H1931"\w* región montañosa.
\p \w Él|strong="H1931"\w* iba \w al|strong="H4480"\w* frente \w de|strong="H4480"\w* \w ellos|strong="H1931"\w*
\v 28 \w y|strong="H3588"\w* les dijo: ¡Síganme, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w entregó|strong="H5414"\w* \w a|strong="H3068"\w* sus enemigos, \w los|strong="H7291"\w* moabitas, \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w*! \w Bajaron|strong="H3381"\w* tras \w él|strong="H3588"\w*, \w tomaron|strong="H3920"\w* \w los|strong="H7291"\w* vados del \w Jordán|strong="H3383"\w* hacia \w Moab|strong="H4124"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w dejaron|strong="H5414"\w* \w pasar|strong="H5674"\w* \w a|strong="H3068"\w* \w ninguno|strong="H3808"\w*.
\v 29 \w En|strong="H5221"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w mataron|strong="H5221"\w* \w como|strong="H1931"\w* 10.000 hombres \w de|strong="H6256"\w* \w los|strong="H3605"\w* moabitas, \w todos|strong="H3605"\w* hombres \w robustos|strong="H2428"\w* y \w valientes|strong="H2428"\w*. \w Ninguno|strong="H3808"\w* \w escapó|strong="H4422"\w*.
\v 30 \w Así|strong="H1931"\w* \w Moab|strong="H4124"\w* \w fue|strong="H1931"\w* subyugado \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w bajo|strong="H8478"\w* \w la|strong="H1931"\w* \w mano|strong="H3027"\w* \w de|strong="H8478"\w* \w Israel|strong="H3478"\w*. \w Y|strong="H3068"\w* \w la|strong="H1931"\w* tierra \w reposó|strong="H8252"\w* 80 \w años|strong="H8141"\w*.
\p 
\v 31 \w Después|strong="H1961"\w* \w de|strong="H1121"\w* \add Ehud\add*, \w Samgar|strong="H8044"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Anat, \w fue|strong="H1961"\w* \add juez\add*. \w Mató|strong="H5221"\w* \w a|strong="H3068"\w* 600 \w filisteos|strong="H6430"\w* \w con|strong="H1571"\w* una quijada \w de|strong="H1121"\w* buey. \w Él|strong="H1931"\w* \w también|strong="H1571"\w* libró \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*.
\c 4
\s1 Los jueces Débora y Barac
\p 
\v 1 Pero después \w que|strong="H1121"\w* \w murió|strong="H4191"\w* Ehud, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* volvieron \w a|strong="H3068"\w* \w hacer|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* \w delante|strong="H5869"\w* \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 2 \nd \w Yavé|strong="H3068"\w*\nd* \w los|strong="H3427"\w* entregó en \w mano|strong="H3027"\w* \w de|strong="H8269"\w* \w Jabín|strong="H2985"\w*, \w rey|strong="H4428"\w* \w de|strong="H8269"\w* \w Canaán|strong="H3667"\w*, \w quien|strong="H1931"\w* \w reinaba|strong="H4428"\w* en Hazor. \w El|strong="H1931"\w* \w comandante|strong="H8269"\w* \w de|strong="H8269"\w* \w su|strong="H1931"\w* \w ejército|strong="H6635"\w* \w era|strong="H1931"\w* \w Sísara|strong="H5516"\w*, \w quien|strong="H1931"\w* \w vivía|strong="H3427"\w* en Haroset-goim.
\v 3 \w Entonces|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w clamaron|strong="H6817"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w porque|strong="H3588"\w* \w aquél|strong="H1931"\w* \w tenía|strong="H1931"\w* 900 carruajes \w de|strong="H3588"\w* \w hierro|strong="H1270"\w*. Durante 20 \w años|strong="H8141"\w* oprimió \w con|strong="H3588"\w* crueldad \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*.
\p 
\v 4 En \w ese|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w Débora|strong="H1683"\w*, una \w profetisa|strong="H5031"\w*, esposa \w de|strong="H6256"\w* Lapidot, \w juzgaba|strong="H8199"\w* en \w Israel|strong="H3478"\w*.
\v 5 Acostumbraba sentarse \w bajo|strong="H8478"\w* \w la|strong="H1931"\w* palmera \w de|strong="H8478"\w* \w Débora|strong="H1683"\w*, \w entre|strong="H8478"\w* \w Ramá|strong="H7414"\w* y Bet-ʼEl, \w en|strong="H8478"\w* \w la|strong="H1931"\w* región montañosa \w de|strong="H8478"\w* Efraín, y \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H8478"\w* \w Israel|strong="H3478"\w* acudían \w a|strong="H3068"\w* \w ella|strong="H1931"\w* para \w que|strong="H1931"\w* \w los|strong="H3427"\w* juzgara.
\p 
\v 6 Ella \w mandó|strong="H6680"\w* \w a|strong="H3068"\w* \w llamar|strong="H7121"\w* \w a|strong="H3068"\w* \w Barac|strong="H1301"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Abinoam, \w de|strong="H5973"\w* Cedes-neftalí, y \w le|strong="H5973"\w* dijo: Mira, \nd \w Yavé|strong="H3068"\w*\nd*, \w el|strong="H5973"\w* \nd ʼElohim\nd* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w*, \w mandó|strong="H6680"\w*: \wj \w Vé|strong="H3212"\w* y marcha hacia la montaña \w Tabor|strong="H8396"\w*. \w Toma|strong="H3947"\w* \w contigo|strong="H5973"\w* 10.000 \w hombres|strong="H1121"\w* \w de|strong="H5973"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* Neftalí y \w de|strong="H5973"\w* \w los|strong="H1121"\w* \w de|strong="H5973"\w* \w Zabulón|strong="H2074"\w*.\wj*
\v 7 \wj Yo atraeré \w a|strong="H3068"\w* \w Sísara|strong="H5516"\w*, \w jefe|strong="H8269"\w* del \w ejército|strong="H6635"\w* \w de|strong="H8269"\w* \w Jabín|strong="H2985"\w*, con sus carruajes y su \w multitud|strong="H1995"\w* al \w arroyo|strong="H5158"\w* \w de|strong="H8269"\w* Cisón y lo \w entregaré|strong="H5414"\w* en tu \w mano|strong="H3027"\w*.\wj*
\p 
\v 8 Entonces \w Barac|strong="H1301"\w* \w le|strong="H5973"\w* respondió: \w Si|strong="H3808"\w* tú \w vas|strong="H3212"\w* \w conmigo|strong="H5973"\w*, yo \w iré|strong="H3212"\w*. Pero \w no|strong="H3808"\w* \w iré|strong="H3212"\w* \w si|strong="H3808"\w* tú \w no|strong="H3808"\w* \w vas|strong="H3212"\w* \w conmigo|strong="H5973"\w*.
\p 
\v 9 \w Y|strong="H3068"\w* \w ella|strong="H5921"\w* contestó: \w Ciertamente|strong="H3588"\w* \w iré|strong="H3212"\w* \w contigo|strong="H5973"\w*, \w pero|strong="H3588"\w* \w la|strong="H5921"\w* \w gloria|strong="H8597"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* jornada \w que|strong="H3588"\w* emprendes \w no|strong="H3808"\w* \w será|strong="H1961"\w* tuya, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* entregará \w a|strong="H3068"\w* \w Sísara|strong="H5516"\w* \w en|strong="H5921"\w* \w las|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* una mujer. \w Débora|strong="H1683"\w* \w se|strong="H1961"\w* \w levantó|strong="H6965"\w* \w y|strong="H3588"\w* \w fue|strong="H1961"\w* \w con|strong="H5973"\w* \w Barac|strong="H1301"\w* \w a|strong="H3068"\w* Cedes.
\v 10 \w Barac|strong="H1301"\w* convocó \w a|strong="H3068"\w* \w Zabulón|strong="H2074"\w* y \w a|strong="H3068"\w* Neftalí \w en|strong="H5973"\w* Cedes, y \w subió|strong="H5927"\w* \w con|strong="H5973"\w* 10.000 hombres que siguieron sus pasos. \w Débora|strong="H1683"\w* \w subió|strong="H5927"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w*.
\p 
\v 11 Ahora bien, \w Heber|strong="H2268"\w*, \w el|strong="H1121"\w* ceneo, se había separado \w de|strong="H5704"\w* \w los|strong="H1121"\w* ceneos descendientes \w de|strong="H5704"\w* Hobab, \w suegro|strong="H2859"\w* \w de|strong="H5704"\w* \w Moisés|strong="H4872"\w*, \w y|strong="H5704"\w* desplegó sus tiendas \w hasta|strong="H5704"\w* \w el|strong="H1121"\w* robledal \w de|strong="H5704"\w* Zanaim, \w que|strong="H5704"\w* está junto \w a|strong="H3068"\w* Cedes.
\p 
\v 12 Se le informó \w a|strong="H3068"\w* \w Sísara|strong="H5516"\w* \w que|strong="H3588"\w* \w Barac|strong="H1301"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Abinoam, \w subió|strong="H5927"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* montaña \w Tabor|strong="H8396"\w*.
\v 13 \w Sísara|strong="H5516"\w* reunió \w todos|strong="H3605"\w* sus carruajes, 900 carruajes \w de|strong="H5971"\w* \w hierro|strong="H1270"\w*, y \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* estaba con \w él|strong="H3605"\w*, desde Haroset-goim hasta \w el|strong="H3605"\w* \w arroyo|strong="H5158"\w* \w de|strong="H5971"\w* Cisón.
\p 
\v 14 \w Entonces|strong="H3117"\w* \w Débora|strong="H1683"\w* dijo \w a|strong="H3068"\w* \w Barac|strong="H1301"\w*: ¡\w Levántate|strong="H6965"\w*, \w porque|strong="H3588"\w* \w este|strong="H2088"\w* \w es|strong="H2088"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w cuando|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w entregó|strong="H5414"\w* \w a|strong="H3068"\w* \w Sísara|strong="H5516"\w* \w en|strong="H3588"\w* tu \w mano|strong="H3027"\w*! ¿\w No|strong="H3808"\w* \w salió|strong="H3318"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti? \w Y|strong="H3068"\w* \w Barac|strong="H1301"\w* bajó \w de|strong="H3588"\w* \w la|strong="H3588"\w* montaña \w Tabor|strong="H8396"\w* \w con|strong="H3588"\w* 10.000 hombres detrás \w de|strong="H3588"\w* \w él|strong="H3588"\w*.
\v 15 \nd \w Yavé|strong="H3068"\w*\nd* destrozó \w a|strong="H3068"\w* \w Sísara|strong="H5516"\w* \w con|strong="H5921"\w* \w todos|strong="H3605"\w* sus carruajes \w y|strong="H5921"\w* \w todo|strong="H3605"\w* su \w ejército|strong="H4264"\w* \w a|strong="H3068"\w* filo \w de|strong="H5921"\w* \w espada|strong="H2719"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w Barac|strong="H1301"\w*. \w Y|strong="H3068"\w* \w Sísara|strong="H5516"\w*, \w después|strong="H5921"\w* \w de|strong="H5921"\w* bajarse \w del|strong="H5921"\w* carruaje, \w huyó|strong="H5127"\w* \w a|strong="H3068"\w* \w pie|strong="H7272"\w*.
\p 
\v 16 Pero \w Barac|strong="H1301"\w* \w persiguió|strong="H7291"\w* \w los|strong="H3605"\w* carruajes \w y|strong="H5704"\w* \w al|strong="H5704"\w* \w ejército|strong="H4264"\w* \w hasta|strong="H5704"\w* Haroset-goim. \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w ejército|strong="H4264"\w* \w de|strong="H5704"\w* \w Sísara|strong="H5516"\w* \w cayó|strong="H5307"\w* \w a|strong="H3068"\w* filo \w de|strong="H5704"\w* \w espada|strong="H2719"\w* \w hasta|strong="H5704"\w* \w no|strong="H3808"\w* \w quedar|strong="H7604"\w* \w ni|strong="H3808"\w* uno.
\v 17 \w Sísara|strong="H5516"\w* \w huyó|strong="H5127"\w* \w a|strong="H3068"\w* \w pie|strong="H7272"\w* hasta \w la|strong="H3588"\w* tienda \w de|strong="H3588"\w* \w Jael|strong="H3278"\w*, esposa \w de|strong="H3588"\w* \w Heber|strong="H2268"\w* ceneo, \w porque|strong="H3588"\w* \w había|strong="H3588"\w* \w paz|strong="H7965"\w* \w entre|strong="H3588"\w* \w Jabín|strong="H2985"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Hazor, \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w Heber|strong="H2268"\w* ceneo.
\p 
