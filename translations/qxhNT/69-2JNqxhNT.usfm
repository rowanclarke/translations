\id 2JN 2jnpnq.sfm Panao Quechua
\h 2 SAN JUAN
\toc1 San Juan cartacushan 2
\toc2 2 SAN JUAN
\toc3 2Jn
\mt1 San Juan cartacushan 2
\io1 Tantiyacunanchipaj:
\ip Juan cay cartata isquirbiran. Paypita musyayta munar, San Juan librupa jallarinanta liguinqui. Juan pïman cartacushantapis sumaj mana musyanchichu. Waquin yarpan juc mama-warmiman cartacushanta. Waquinna yarpan jutucaj irmänucunaman cartacushanta. Pïman carpis, sumaj willapänanpaj cartacuran.
\io1 Juan isquirbiran:
\io2 Llaquipashanpita, cushicushanpita, llaquipänacunanpita: \ior 2 San Juan 1.1–6\ior*.
\io2 Waquin runa llutanta tantiyachicushanpita, pantachicujcunata mana pachächinanpita, imaćhüpis mana yanapänanpita: \ior 2 San Juan 1.7–11\ior*.
\io2 Watucuj aywayta munashanpita: \ior 2 San Juan 1.12–13\ior*.
\c 1
\s1 Juan wamayashan
\p 
\v 1 Mamallau mama, wawantiquiman cartacallämü.\f * \fr 1:1 \ft «Mama, wawa» nir juc marcaćhu irmänucunapaj tincuchiypa riman. «Mama» nir mayur irmänupaj riman: «wawa» nir irmänucunallapaj.\f* Ima allish Tayta Diosninchi acracushcashunqui maquinćhu cawanayquipaj. Mayur irmänu car, waquin irmänucunawan-ima cartacamü. Paycunawan llapanï Tayta Diosninchipa shiminta ćhasquicush caycar, jamcunatapis llapan shungüwan llaquij.
\v 2 Tayta Diosninchipa shimin shungunchiman ćhayasha. Imaypis mana jungashunnachu. Chaymi llapaniquita llaquij.
\v 3 Tayta Diosninchipis, Wawan Washäcuj Jesúspis yanapayculläshunqui. Llaquipayculläshunqui. Allilla cawaycachilläshunqui. Chaynuy cawachimäshun shiminta wiyacunanchipäpis, llaquinacunanchipäpis.
\s1 Llaquipänacuypita tantiyachishan
\p 
\v 4 Waquin juturpashayqui irmänunchicuna tincuptï, willamaran: «Irmänunchicuna Tayta Diosninchipa shungun munashannuy llaquipänacurcaycan» nir. Willamaptin, sumaj-sumaj cushicushcä. Chaynuy cawananchipaj Tayta Diosninchi shiminta musyachicur tantiyachimanchi.
\v 5 Mamallau mama, cananga mañacushayqui. Jucninchi-jucninchipis sumaj llaquipänacärishun. Cartacamushäćhu mana juc-niraj willapatachu willapaycämuj; manchäga unaypita-pacha Tayta Diosninchipa shiminta wiyashallanchita.
\v 6 Llaquipänacujcuna Tayta Diosninchipa shiminta llapanta ćharcunman. Llaquipänacur cawananchipaj unaypita-pacha wiyashcanchi.
\p 
\v 7 Cay pachaćhu achcaj runa pantachicur purircaycan: «Jesús mana runachu caran. Mana Washäcujninchichu caran» nir. Pantachicujcunawan Jesústa ticrapujcuna chayta riman.
\v 8 Pantachishunayquipita maygantapis ama ćhasquipanquichu. Manchäga Jesúspa shiminta willapäcushanchisi yangallapaj canga. Ćhasquipar-imarga, Tayta Diosninchi tarichimänanchi cashantapis mana ćhasquishunpächu.
\p 
\v 9 Pipis Washäcuj Jesúspa shiminta mana wiyacur jucta ćhasquipar, mana Tayta Diosninchipa maquinćhüchu cawan. Wiyacujcunam ichanga Tayta Diosninchipa maquinćhu, Wawan Jesúspa maquinćhu cawan.
\p 
\v 10 Pipis juc willapata willapäcuycar ćhayapushuptiqui, ama jamachinquichu. Ama: «Wasi caycällan» ninquipishchu.
\v 11 «Wasi caycällan» nir ćhasquiparga, juyu rurashancunamanpis jaticaycanqui.
\s1 Cartapa ushyanan
\p 
\v 12 Willapänajpaj achcaraj caycan. Ichanga isquirbiyllapa llapanta mana isquirbimümanchu. Manchäga watucuj shamurna, llapanta willapäshayqui. Tincur, cushish juturpäshunpaj. Pishiycashantapis llapanta willapäshayqui.
\p 
\v 13 Ñañayquipis Tayta Diosninchi acracushpan llapan wawantin wamayäshunqui.\f * \fr 1:13 \ft Unay runacuna marcacunatapis, juturaj irmänucunatapis mama-warmiwan-yupay tincuchij. Canancamanpis waquin ricsin: «Iglesia madre» nir.\f* Chayllana.
