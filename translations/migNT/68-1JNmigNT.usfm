\id 1JN
\h 1 Juan
\toc1 YA'A KUU CARTA ƗƗN JA NI CHAA SAN JUAN APOSTOL NUU TAKA ÑAYƗVƗ KAKANDIJA
\toc2 1 Juan
\toc3 1 Jn.
\mt2 LA PRIMERA EPISTOLA UNIVERSAL DE SAN JUAN APOSTOL
\mt1 YA'A KUU CARTA ƗƗN JA NI CHAA SAN JUAN APOSTOL NUU TAKA ÑAYƗVƗ KAKANDIJA
\c 1
\s1 Tu̱'un máá‑yá ni̱ jini̱ Juan
\p 
\v 1 Tu̱'un kájani‑ri̱ kúu tu̱'un máá I'a̱ ni̱ i̱o onde̱ xnáñúú. Te ni̱ ka̱jini so̱'o‑ri̱ ni̱ ka'a̱n‑ya̱. Te ni̱ kajini̱‑ri̱ nuu̱‑yá jíín ndúchi‑rí. Te ni̱ ka̱ké'é‑rí‑ya̱ jíín ndá'a‑rí. Te máá‑yá kúu tu̱'un kuchaku̱‑yo̱.
\v 2 Te I'a̱‑ún chakú‑yo̱ sá'a‑ya̱, ni̱ kenda ndiji̱n‑ya̱. Te ni̱ kajini̱‑ri̱ nuu̱‑yá. Te kájani ndaa̱‑ri̱ tu̱'un‑ya̱. Te kákastu̱'ún‑rí nuu̱‑ro̱ ndasa kuchaku̱‑ro̱ nɨ́ɨ́ káni jíná'an‑ró sá'a‑ya̱. Chi ni̱ kanchaa̱‑ya̱ jíín máá Táa̱‑yo̱ Dios. Te ni̱ kenda ndiji̱n‑ya̱ núu̱‑yo̱.
\v 3 Ja̱ ní kajini̱‑ri̱ jíín já ní kajini so̱'o‑ri̱‑ún, yu̱án kákastu̱'ún‑rí nuu̱‑ro̱, náva̱'a suni máá‑ró, ɨɨn núú‑ni koo ini̱‑ro̱ jíín‑rí. Te máá‑rí, ɨɨn núú‑ni ká'i̱o ini̱‑ri̱ jíín máá Táa̱‑yo̱ Dios jíín Sé'e‑ya̱ Jesucristo.
\v 4 Te tu̱'un yá'a káchaa‑ri̱ nuu̱‑ro̱ náva̱'a kusɨɨ̱ xáa̱n iní‑ro̱ jíná'an‑ró.
\s1 Ja̱ ndíi ncháa̱ Dios jíín já jánchaa̱‑ya̱ kuáchi‑yó
\p 
\v 5 Te ya̱'á kúu tu̱'un ni̱ ka̱jini so̱'o‑ri̱ ni̱ ka'a̱n‑ya̱. Te tu̱'un‑ún kájani‑ri̱ nuu̱‑ro̱: Máá Dios kúu luz. Te nuu̱ ncháá máá‑yá, tú kutɨ na̱ ñu̱ñáa íó.
\v 6 Nú káka'a̱n‑yo̱ já ɨ́ɨn núú‑ni ká'i̱o ini̱‑yo̱ jíín‑yá, te kájika kuu‑yó íchi ñúñáa. Yúan‑na te káxndá'ú‑yo̱, te tú káka'a̱n ndaa̱‑yo̱.
\v 7 Ko nú kájika‑yó íchi ñúndiji̱n nátu̱'un máá‑yá kánchaa̱‑ya̱ ñúndiji̱n, yúan‑na te ɨɨn núú‑ni ká'i̱o ini̱‑yo̱ jíín‑yá. Te nɨñi̱ máá Sé'e‑ya̱ Jesucristo nda'va̱ ta̱ká kua̱chi‑yó.
\v 8 Nú káka'a̱n‑yo̱ já tú na̱ kua̱chi kándi̱so‑yó, te káxndá'ú‑yo̱ máá‑yó já súan, te tú ñú'un tu̱'un ndaa̱ ini̱‑yo̱.
\v 9 Te máá‑yá, I'a̱ skíkuu, I'a̱ va̱'a kúu‑ya̱. Ja̱ yúán nú nakani ndaa̱‑yo̱ kuáchi‑yó, te sá'a‑ya̱ túká'nu ini̱ nuu̱ kuáchi‑yó, te sándoo‑ya̱ yóó kuanchaa̱‑ya̱ táká ja̱ ñáá ñú'un ini̱‑yo̱.
\v 10 Te nú ka'a̱n‑yo̱ já tú na̱ kua̱chi ní kásá'a‑yó, te nátu̱'un kánasá'a‑yó‑yá ɨɨn I'a̱ ká'a̱n tu̱'un tú'ún, te tu̱'un máá‑yá na̱ tú ñú'un ini̱‑yo̱.
\c 2
\p 
\v 1 Súchi̱, ta̱ká tu̱'un yá'a cháa‑ri̱ nuu̱‑ro̱, náva̱'a ma̱ sá'a‑ró kuáchi jíná'an‑ró. Ko nú ndé ɨɨn‑ró sá'a kua̱chi, te íó ɨɨn I'a̱ ká'a̱n ja'a̱‑yo̱ núu̱ máá Táa̱‑yo̱ Dios. Jesucristo, I'a̱ ndaa̱ kúu‑ya̱.
\v 2 Te onde̱ jíín nɨñí máá‑yá jánchaa̱ ta̱ká kua̱chi‑yó jíná'an‑yó. Te nasu̱ máá ɨ́ɨn kua̱chi máá‑yó, chi̱ suni jánchaa̱ kua̱chi nɨ́ɨ́ ñúyɨ́vɨ.
\v 3 Nú skíkuu‑yó tíñu tá'ú‑yá nuu̱‑yo̱, yúan‑na te jiní ndaa̱‑yo̱ já kájini̱‑yo̱‑yá.
\v 4 Te nú ɨɨn cha̱a ka'a̱n‑de: Ruu̱, chi̱ jiní‑ri̱‑ya̱. Te nú tú skíkuu‑de tiñu tá'ú‑yá, cha̱a yúan, cha̱a xndá'ú kúu‑de, te tú ñú'un tu̱'un ndaa̱ ini̱‑de.
\v 5 Ko cha̱a skíkuu tu̱'un‑ya̱, ja̱ndáa̱ ja̱ iní máá‑de ni̱ yija va̱'a tu̱'un kúndá'ú ini̱ Dios. Ja̱ yúán kájini̱‑yo̱ nú kánchaa̱‑yo̱ jíín‑yá xí túu.
\v 6 Nú ká'a̱n ɨɨn cha̱a ja̱ ncháá‑de jíín‑yá, kánúú káka‑de nátu̱'un ni̱ jika máá‑yá.
\s1 Tu̱'un jáá tá'ú tíñu nuu̱‑yo̱
\p 
\v 7 Ñáni̱ máni̱, nasu̱ tíñu jáá tá'ú‑rí nuu̱‑ro̱, chi̱ tiñu ja̱ á káñava̱'a‑ró ondé ni̱ kejá'á kúu. Te tiñu‑ún ja̱ tá'ú‑rí nuu̱‑ro̱ kúu tu̱'un ni̱ ka̱jini so̱'o‑ró ondé kɨvɨ̱ ní kejá'á.
\v 8 Ko suni tá'ú‑rí ɨɨn tiñu jáá núu̱‑ro̱, ja̱ kúu tu̱'un ndaa̱ íó ini̱ máá‑yá jíín iní máá‑ró. Chi ñu̱ñáa, a já'a kua'a̱n. Te stúu̱n máá luz ndija nuu̱‑yo̱ vína.
\v 9 Nú ɨɨn cha̱a jíto u'u̱‑de ñani̱‑de, cha̱a‑ún kándee‑de ñu̱ñáa, va̱sa a ká'a̱n‑de ja̱ kánchaa̱‑de ñu̱ndiji̱n.
\v 10 Cha̱a ja̱ kúndá'ú ini̱‑de ñani̱‑de, kándee‑de ñu̱ndiji̱n. Te tú náyu̱'ú ni ɨɨn ña̱yɨvɨ sá'a‑de.
\v 11 Ko cha̱a jíto u'u̱‑de ñani̱‑de, kándee‑de ñu̱ñáa. Te ñu̱ñáa jíka‑de, te tú jiní‑de ndé nuu̱ kí'i̱n‑de. Chi ni̱ kukuáá‑de ni̱ sá'a ñu̱ñáa‑ún.
\v 12 Súchi̱ jíná'an‑ró, cháa‑ri̱ tutu̱ yá'a nuu̱‑ro̱ chi ja̱ sɨkɨ́ Jesucristo te ni̱ sá'a Dios tu̱ká'nu ini̱‑ya̱ núu̱ táká kua̱chi‑ró.
\v 13 Róó táa̱ jíná'an‑ró, cháa‑ri̱ tutu̱ nuu̱‑ro̱, chi̱ kájini̱‑ro̱ I'a̱ kúu onde̱ xnáñúú. Róó cha̱a súchí jíná'an‑ró, cháa‑ri̱ tutu̱ nuu̱‑ro̱, chi̱ a ni̱ kundéé‑ró jíín kuí'na̱. Súchi̱, cháa‑ri̱ tutu̱ nuu̱‑ro̱, chi̱ kájini̱‑ro̱ núu̱ máá Táa̱‑yo̱ Dios.
\v 14 Róó táa̱ jíná'an‑ró, cháa‑ri̱ tutu̱ nuu̱‑ro̱, chi̱ kájini̱‑ro̱ I'a̱ kúu onde̱ xnáñúú. Róó cha̱a súchí jíná'an‑ró, cháa‑ri̱ tutu̱ nuu̱‑ro̱, chi̱ ká'i̱o ni̱'in‑ró, te tu̱'un Dios ñú'un ini̱‑ro̱, te a ni̱ ka̱kundéé‑ró jíín kuí'na̱.
\v 15 Ma̱ kóo mani̱‑ro̱ jíín ñúyɨ́vɨ, ni ta̱ká ndatíñu ja̱ íó ini̱ ñu̱yɨ́vɨ. Chi̱ nú ndé ɨɨn cha̱a mani̱‑dé jíín ñúyɨ́vɨ, te tú kúu koo mani̱‑dé jíín máá Táa̱‑yo̱ Dios.
\v 16 Chi ta̱ká ja̱ íó ini̱ ñu̱yɨ́vɨ kúu modo yúkú já kaní ini̱ máá‑yó, jíín já kaní ini̱ nduchi‑yo, jíín já sávixi̱‑yo̱ máá‑yó. Yu̱án násu̱ ondé nuu̱ máá Táa̱‑yo̱ Dios va̱i, chi̱ cuenta ñu̱yɨ́vɨ kákuu.
\v 17 Te naa ñúyɨ́vɨ jíín táká ja̱ kákani̱ ini̱‑yo̱. Ko cha̱a sá'a ja̱ kúu ini̱ máá Dios, kundii̱‑de nɨ́ɨ́ káni.
\s1 Cha̱a jíto u'u̱ Cristo
\p 
\v 18 Súchi̱, a kua̱ndɨ'ɨ kɨvɨ̱. Te a ni̱ ka̱jini tu̱'un‑ró já kíi máá já xíin tíñu jíto u'u̱ Cristo. Te onde̱ vina, a ni̱ kenda tɨnɨ̱ ña̱yɨvɨ kájito u'u̱‑ya̱. Te ja̱ yúán kájini̱‑yo̱ já á kua̱ndɨ'ɨ kɨvɨ̱.
\v 19 Nuu̱ máá‑yó ní kenda‑i kája'a̱n‑i. Ko nasu̱ tá'an‑yó kákuu‑i. Chi̱ nú tá'an‑yó kákuu‑i, kendo̱o ndija‑i jíín‑yó núú. Ko ni̱ kenda‑i kája'a̱n‑i náva̱'a kuni̱ ndiji̱n‑yo̱ núu̱‑í ja̱ násu̱ tá'an‑yó kákuu‑i.
\v 20 Ko máá I'a̱ ii̱, ni̱ ji'i‑yá róó jíín Espíritu Santo. Te kájini̱‑ro̱ táká tu̱'un.
\v 21 Nasu̱ cháa‑ri̱ tutu̱ yá'a nuu̱‑ro̱ já nátu̱'un tú kájuku̱'un ini̱‑ro̱ jíín tú'un ndaa̱, chi̱ sua kájuku̱'un ini̱‑ro̱ jíín, jiní‑ri̱, chi̱ tú kutɨ ní ɨɨn tu̱'un tú'ún íó nuu̱ tú'un ndaa̱.
\v 22 Ndé ja̱ xíin tú'un xndá'ú, suu ja̱ tú játu̱'un ja̱ Jesús kúu máá Cristo. Yu̱án kúu ja̱ jíto u'u̱ Cristo, chi̱ tú játu̱'un ja̱ kúu máá Táa̱‑yo̱ Dios jíín Sé'e‑ya̱.
\v 23 Ta̱ká cha̱a tú játu̱'un‑de máá Sé'e, suni tú ká'i̱in‑de jíín máá I'a̱ kúu Táa̱. Te cha̱a játu̱'un‑de máá Sé'e, suni ká'i̱in‑de jíín máá I'a̱ kúu Táa̱.
\v 24 Núsáá te tu̱'un ni̱ ka̱jini so̱'o‑ró ondé xnáñúú, ná kéndo̱o tu̱'un‑ún ini̱‑ro̱ jíná'an‑ró. Te nú jíín‑ró kánchaa̱ tu̱'un ni̱ ka̱jini so̱'o‑ró ondé xnáñúú‑ún, yúan‑na te suni kuxiu̱kú máá‑ró jíín máá Táa̱‑yo̱ jíín Sé'e‑ya̱.
\v 25 Te ya̱'á kúu tu̱'un ni̱ keyu'u‑yá nuu̱‑yo̱: Ja̱ kúchaku̱‑yo̱ nɨ́ɨ́ káni.
\v 26 Tu̱'un yá'a cháa‑ri̱ tutu̱ nuu̱‑ro̱ já kástu̱'ún‑rí cuenta sɨkɨ̱ ñáyɨvɨ kándúkú xndá'ú róó jíná'an‑ró.
\v 27 Ko ni̱ ji'i‑yá róó jíín Espíritu Santo, te kánchaa̱ máá Espíritu ini̱‑ro̱ jíná'an‑ró. Te tú kájinu ñú'ún‑ró já stá'a̱n ni ɨɨn ña̱yɨvɨ núu̱‑ro̱, chi̱ máá Espíritu kúu ja̱ stá'a̱n ta̱ká tu̱'un nuu̱‑ro̱, te stá'a̱n tu̱'un ndaa̱, tú xndá'ú kutɨ. Núsáá te kuxiu̱kú‑ró jíín‑yá, nátu̱'un ni̱ stá'a̱n máá Espíritu nuu̱‑ro̱.
\v 28 Te vina súchi̱, ná kúxiu̱kú ní'in‑ró jíín‑yá, náva̱'a nú ni̱ kenda ndiji̱n‑ya̱, te ma̱ yú'ú‑yo̱, ni ma̱ kúka nuu̱‑yo̱ núu̱‑yá kɨvɨ̱ ncháa̱‑ya̱.
\v 29 Te nú kájini̱‑ro̱ já I'a̱ ndaa̱ kúu‑ya̱, te suni ná kuní‑ro̱ já táká ña̱yɨvɨ kásátiñu ndaa̱, onde̱ nuu̱ máá‑yá ni̱ ka̱kaku‑i.
\c 3
\s1 Tu̱'un se̱'e Dios
\p 
\v 1 Ná kúná'án‑ró sɨkɨ́ máá Táa̱‑yo̱, ndasa ni̱ kundá'ú xaa̱n iní‑ya̱ yóó, ja̱ ná kúnání‑yó sé'e Dios. Te yu̱án kákuu ndija‑yó. Ja̱ yúán tú jiní ña̱yɨvɨ ñúyɨ́vɨ núu̱‑yo̱, chi̱ tú ní jiní‑i nuu̱ máá‑yá.
\v 2 Ñáni̱ máni̱, vina a kákuu‑yó sé'e Dios, te té cha'a̱n‑ga̱ kuni̱‑yo̱ ndasa koo‑yó. Ko a kájini̱‑yo̱ já nú ni̱ kenda ndiji̱n‑ya̱, te nduu‑yó nátu̱'un káa máá‑yá. Chi̱ kuni̱‑yo̱ núu̱‑yá ndasa káa‑ya̱.
\v 3 Te ta̱ká cha̱a ja̱ súan káñukuu ini̱‑de‑ya̱, sándoo‑de máá‑de nátu̱'un íó ndoo máá‑yá.
\v 4 Cha̱a sá'a kua̱chi, suni stɨ́vɨ́‑de ley, chi kua̱chi‑ún kúu ja̱ síjíta ley.
\v 5 Te kájini̱‑ro̱ já ní kenda ndiji̱n‑ya̱ náva̱'a nda'va̱‑ya̱ kuáchi‑yó. Te tú na̱ kua̱chi ndíso‑ya̱.
\v 6 Ña̱yɨvɨ kánchaa̱ jíín‑yá, tú sá'a‑i kua̱chi. Te ña̱yɨvɨ sá'a kua̱chi, tú ní ndé'é‑i nuu̱‑yá, ni tú ní jiní‑i nuu̱‑yá.
\v 7 Súchi̱ jíná'an‑ró, ni ɨɨn‑de ma̱ xndá'ú‑de róó. Cha̱a sá'a tiñu ndaa̱, cha̱a ndaa̱ kúu‑de, nátu̱'un I'a̱ ndaa̱ kúu máá‑yá.
\v 8 Te cha̱a sá'a kua̱chi, se̱'e kui'na̱ kúu‑de. Chi̱ kui'na̱, sá'a kua̱chi va̱i onde̱ xnáñúú. Ja̱ yúán ní kii Se̱'e Dios ja̱ xnáa‑yá ta̱ká tiñu sá'a kui'na̱.
\v 9 Cha̱a kúu se̱'e Dios, na̱ tú sá'a‑de kua̱chi, chi̱ tata̱‑ya̱ kánchaa̱ ini̱‑de. Te ma̱ kúu sá'a‑de kua̱chi, chi se̱'e Dios kúu‑de.
\s1 Tu̱'un se̱'e kui'na̱
\p 
\v 10 Súan ná kuní‑yo̱ ndéja̱ kúu se̱'e Dios jíín sé'e kui'na̱. Ta̱ká cha̱a ja̱ tú sá'a‑de tiñu ndaa̱, jíín já tú kúndá'ú ini̱‑de ñani̱‑de, nasu̱ sé'e Dios kúu‑de.
\v 11 Chi ya̱'á kúu tu̱'un ja̱ ní ka̱jini tu̱'un‑ró ondé xnáñúú: Ja̱ ná kúndá'ú ini̱‑yo̱ tá'an‑yó.
\v 12 Te ma̱ sá'a‑yó nátu̱'un ni̱ sá'a Caín, ja̱ ní kuu‑de se̱'e kui'na̱, te ni̱ ja'ni‑dé ñani̱‑de. Te naja̱ ní ja'ni‑dé ñani̱‑de. Kua̱chi ja̱ máni tiñu ñáá ni̱ sá'a‑de, te ñani̱‑de ni̱ sá'a tiñu ndaa̱.
\v 13 Ma̱ nánaa iní‑ro̱ ñáni̱, te nú ña̱yɨvɨ ñúyɨ́vɨ jíto u'u̱‑i róó jíná'an‑ró.
\v 14 A kájini̱‑yo̱ já á ni̱ ka̱ku‑yó já kúu̱‑yo̱, te ni̱ naja̱'a‑yó núu̱ kúchaku̱‑yo̱, chi̱ kákundá'ú ini̱‑yo̱ ñaní‑yo̱. Te cha̱a ja̱ tú kundá'ú ini̱‑de ñani̱‑de, cha̱a‑ún kándee‑de nuu̱ kúu̱‑de.
\v 15 Cha̱a jíto u'u̱ ñani̱, cha̱a já'ni ndɨ́yi kúu‑de. Te a kájini̱‑ro̱ já ní ɨɨn cha̱a já'ni ndɨ́yi, ma̱ náni'i̱n tá'u̱ kútɨ‑dé kuchaku̱‑de nɨ́ɨ́ káni.
\v 16 Ja̱ yúán jiní‑yo̱ ndasa sá'a tu̱'un kúndá'ú ini̱. Chi̱ Cristo, ni̱ ji'i̱‑ya̱ já yóó. Te máá‑yó, suni súan jínu ñú'ún kúu̱‑yo̱ já tá'an‑yó.
\v 17 Ko cha̱a ja̱ kúká‑de jíín ndátíñu ja̱ íó ini̱ ñu̱yɨ́vɨ, nú jiní‑de tá'a̱n ñani̱‑de tu̱ndó'o, te nú sáxi̱i‑de onde̱ jíín iní añú‑de, núsáá te á ncháá tu̱'un kúndá'ú ini̱ Dios ini̱‑de xí túu.
\v 18 Súchi̱, ma̱ kúndá'ú ini̱‑yo̱ jíín tú'un ká'a̱n‑ni‑yó, ni jíín yú'u‑yo, chi̱ sua ná kúndá'ú ndija ini̱‑yo̱ ondé jíín tíñu kásá'a‑yó.
\v 19 Ja̱ yúán te kuni̱‑yo̱ já kákuu‑yó sé'e tu̱'un ndaa̱, te kundaa̱ ini̱ añú‑yo̱ núu̱‑yá,
\v 20 nú añú‑yo̱ kána jíín núu̱‑yo̱. Chi̱ Dios, ñá'nu‑ga̱ kúu‑ya̱ vásá añú‑yo̱, te jiní ndɨ'ɨ‑ya̱ táká na̱ún kúu.
\v 21 Súchi̱ máni̱, nú añú‑yo̱ tú náku̱xndíi sɨkɨ̱‑yo̱, yúan‑na te tuká yú'ú‑yo̱ núu̱ Dios,
\v 22 te ta̱ká na̱ún kájika̱n‑yo̱ núu̱‑yá, te kua̱'a‑ya̱ núu̱‑yo̱, chi̱ kájandatu̱‑yo̱ táká tiñu tá'ú‑yá nuu̱‑yo̱. Te kásá'a‑yó táká tiñu ja̱ kúsɨɨ̱ iní‑ya̱ jíín.
\v 23 Te ya̱'á kúu tiñu tá'ú‑yá: Ja̱ ná kándíja‑yó núu̱ Sé'e‑ya̱ Jesucristo, te ná kúndá'ú ini̱‑yo̱ tá'an‑yó nátu̱'un ni̱ tá'ú‑yá tiñu nuu̱‑yo̱.
\v 24 Te ta̱ká ña̱yɨvɨ skíkuu tiñu tá'ú‑yá, káxiu̱kú‑i jíín Dios, te Dios kánchaa̱‑ya̱ jíín‑i. Te jíín tú'un yá'a kájini̱‑yo̱ já ncháá máá‑yá jíín‑yó jíín máá Espíritu ja̱ ní ja̱'a‑ya̱ núu̱‑yo̱.
\c 4
\s1 Modo kuni̱‑yo̱ sɨ́ɨn sɨ́ɨn tu̱'un
\p 
\v 1 Ñáni̱ máni̱, ma̱ kándíja‑ró táká tu̱'un. Chi̱ ná kóto nchaa̱‑ro̱ táká tu̱'un te nú onde̱ nuu̱ Dios va̱i xí túu. Chi̱ kua'a̱ ñáyɨvɨ kájani tu̱'un tú'ún, ni̱ kenda koyo‑i ini̱ ñu̱yɨ́vɨ.
\v 2 Jíín tú'un yá'a ná kuní‑ro̱ ndéja̱ kúu máá Espíritu Dios: Ta̱ká tu̱'un ja̱ ká'a̱n ndaa̱ ja̱ ní kii Jesucristo jíín yíkɨ kúñu‑ya̱, te suu onde̱ nuu̱ Dios va̱i.
\v 3 Te ta̱ká tu̱'un ja̱ tú ká'a̱n ndaa̱ ja̱ ní kii Jesucristo jíín yíkɨ kúñu‑ya̱, nasu̱ núu̱ Dios va̱i. Te yu̱án kúu tu̱'un jíto u'u̱ Cristo, ja̱ ní ka̱jini tu̱'un‑ró já kíi, te vina a kándee ini̱ ñu̱yɨ́vɨ.
\v 4 Súchi̱ jíná'an‑ró, se̱'e Dios kákuu‑ró. Te ni̱ kundéé‑ró jíín yúán. Chi̱ ñá'nu‑ga̱ kúu I'a̱ kánchaa̱ ini̱ máá‑ró nasu̱ yúán já kánchaa̱ ini̱ ña̱yɨvɨ ñúyɨ́vɨ.
\v 5 Máá‑i kákuu se̱'e ñu̱yɨ́vɨ. Ja̱ yúán káka'a̱n‑i tu̱'un ñu̱yɨ́vɨ. Te ña̱yɨvɨ ñúyɨ́vɨ jíni so̱'o tu̱'un káka'a̱n‑i.
\v 6 Máá‑yó kákuu se̱'e Dios. Te cha̱a jiní nuu̱ Dios, jíni ná'ín‑de tu̱'un ká'a̱n‑yo̱. Ko ña̱yɨvɨ já násu̱ sé'e Dios kúu‑i, tú jíni ná'ín‑i tu̱'un ká'a̱n‑yo̱. Ja̱ yúán kájini̱‑yo̱ ndasa káa tu̱'un ndaa̱ jíín tú'un ñáá.
\s1 Dios kúu máá tú'un kúndá'ú ini̱
\p 
\v 7 Ñáni̱ máni̱, ná kúndá'ú ini̱‑yo̱ tá'an‑yó, chi tu̱'un kúndá'ú ini̱, onde̱ nuu̱ Dios va̱i. Te ta̱ká ña̱yɨvɨ kúndá'ú ini̱ tá'an, se̱'e Dios kúu‑i, te jiní‑i nuu̱ Dios.
\v 8 Te cha̱a ja̱ tú kúndá'ú ini̱‑de tá'an‑de, tú jiní‑de nuu̱ Dios, chi̱ Dios kúu máá tú'un kúndá'ú ini̱.
\v 9 Súan ni̱ kenda ndiji̱n ndasa kúndá'ú ini̱ Dios yóó. Chi ni̱ tájí‑yá Se̱'e‑ya̱, va̱sa máá tú'ún‑ni‑i íó. Te ni̱ kii Se̱'e‑ya̱‑ún ini̱ ñu̱yɨ́vɨ yá'a, náva̱'a jíín máá‑yá te kuchaku̱‑yo̱.
\v 10 Súan íó tu̱'un kúndá'ú ini̱, chi va̱sa tú ní kákumani̱‑yo̱ jíín Dios, ko ni̱ kundá'ú ini̱‑ya̱ yóó. Te ni̱ tájí‑yá Se̱'e‑ya̱ ní kii, náva̱'a kuanchaa̱‑ya̱ táká kua̱chi‑yó jíín nɨñí‑yá.
\v 11 Ñáni̱ máni̱, nú súan kúndá'ú ini̱ Dios yóó, te suni súan nɨ́nɨ ná kúndá'ú ini̱‑yo̱ tá'an‑yó núsáá.
\v 12 Ni ɨɨn cha̱a, tú ní jiní kutɨ‑dé nuu̱ Dios. Ko nú kúndá'ú ini̱‑yo̱ tá'an‑yó, te Dios ncháá‑ya̱ jíín‑yó, te tu̱'un kúndá'ú ini̱‑ya̱, a ni̱ yija va̱'a ini̱‑yo̱.
\v 13 Ja̱ yúán kájini̱‑yo̱ já ncháá‑yo̱ jíín‑yá. Te ncháá‑ya̱ jíín‑yó. Chi ni̱ ja̱'a‑ya̱ Espíritu‑ya̱ núu̱‑yo̱.
\v 14 Te a ni̱ kajini̱‑yo̱, te káka'a̱n ndaa̱‑yo̱, já máá Táa̱‑yo̱ Dios ni̱ tájí‑yá Se̱'e‑ya̱ ní kii ja̱ náma‑ya̱ ñáyɨvɨ ñúyɨ́vɨ.
\v 15 Nú ndé ña̱yɨvɨ ká'a̱n ndaa̱ ja̱ Sé'e Dios kúu Jesús, yúan‑na te ncháá Dios jíín máá‑i, te máá‑i jíín Dios.
\v 16 Te yóó, a ni̱ kajini̱‑yo̱, te ni̱ ka̱kandíja‑yó já Dios kúndá'ú ini̱‑ya̱ yóó. Chi̱ Dios kúu tu̱'un kúndá'ú ini̱. Te cha̱a kúndá'ú ini̱ tá'an, ncháá‑de jíín Dios. Te Dios ncháá‑ya̱ jíín‑de.
\v 17 Súan yíja va̱'a tu̱'un kúndá'ú ini̱‑yo̱, náva̱'a ma̱ yú'ú‑yo̱ kɨvɨ́ kíi juicio, chi̱ nátu̱'un káa máá‑yá, suni súan kánda̱a máá‑yó iní ñu̱yɨ́vɨ yá'a.
\v 18 Tu̱'un kúndá'ú ini̱, tú ndíso tu̱'un yú'ú. Chi̱ nú kúndá'ú ndija ini̱‑yo̱, te a ni̱ jinu tu̱'un yú'ú kua'a̱n. Chi tu̱'un yú'ú ndíso tu̱ndó'o. Chi̱ nú yú'ú ɨɨn ña̱yɨvɨ, chá'a̱n‑ga̱ yija va̱'a‑i jíín tú'un kúndá'ú ini̱.
\v 19 Te yóó, mani̱‑yo̱ jíín‑yá, chi ni̱ kundá'ú ini̱‑ya̱ yóó xna'a̱n‑ga̱.
\v 20 Nú ɨɨn cha̱a ká'a̱n‑de: Ruu̱, chi̱ mani̱‑rí jíín Dios. Te nú jíto u'u̱‑de ñani̱‑de, chaa̱ xndá'ú kúu‑de nú súan. Chi cha̱a ja̱ tú kúndá'ú ini̱‑de ñani̱‑de ja̱ á ni̱ jini̱‑de nuu̱, ndasa kuu kumani̱‑dé jíín Dios ja̱ tú jiní‑de nuu̱‑yá núsáá.
\v 21 Te ni̱ tá'ú‑yá tiñu yá'a nuu̱‑yo̱: Cha̱a mani̱ jíín Dios, suni ná kúndá'ú ini̱‑de ñani̱‑de.
\c 5
\s1 Jíín tú'un kándíja te kundéé‑yó
\p 
\v 1 Nú ndé ña̱yɨvɨ kándíja‑i ja̱ Jesús kúu Cristo, Se̱'e Dios kúu‑i, núsáá te ña̱yɨvɨ kúmani̱ jíín máá I'a̱ kúu Táa̱, suni kúmani̱‑í jíín Sé'e‑ya̱.
\v 2 Nú mani̱‑yo̱ jíín Dios te jándatu̱‑yo̱ táká tiñu tá'ú‑yá, yu̱án kájini̱‑yo̱ já maní‑yo̱ jíín táká se̱'e Dios.
\v 3 Chi ja̱ maní‑yo̱ jíín Dios kúu ja̱ ná kuándatu̱‑yo̱ tíñu tá'ú‑yá, chi̱ tiñu tá'ú‑yá tú ve̱e.
\v 4 Chi ta̱ká ña̱yɨvɨ kákuu se̱'e Dios, kundéé‑i jíín ñúyɨ́vɨ, chi tu̱'un kándíja‑yó kúu fuerza ja̱ kúndéé‑yó jíín ñúyɨ́vɨ.
\v 5 Ndéja̱ kúu ja̱ kúndéé jíín ñúyɨ́vɨ, suu ña̱yɨvɨ kándíja ja̱ Jesús kúu Se̱'e Dios, ña̱yɨvɨ‑ún kúu‑i.
\v 6 I'a̱ yá'a kúu Jesucristo, ni̱ kii‑ya̱ jíín ndúcha jíín nɨñí. Nasu̱ máá ɨ́ɨn jíín ndúcha, chi̱ jíín ndúcha jíín nɨñí. Te máá Espíritu ká'a̱n ndaa̱ ya̱'á, chi̱ Espíritu kúu tu̱'un ndaa̱.
\v 7 Chi̱ íó uni̱ ja̱ ká'a̱n ndaa̱ ini̱ andɨ́vɨ́. Máá I'a̱ kúu Táa̱, máá Sé'e, jíín máá Espíritu Santo kákuu‑ya̱. Te ndenúní I'a̱ yá'a, ɨɨn‑ni‑ya̱ kúu.
\v 8 Te íó uni̱ ja̱ ká'a̱n ndaa̱ ini̱ ñu̱yɨ́vɨ. Espíritu, jíín ndúcha, jíín nɨñí kákuu, te ndenúní ya̱'á, ɨɨn‑ni káka'a̱n.
\v 9 Nú játá'ú‑yó tú'un káka'a̱n ndaa̱ cha̱a, naga̱ ni̱ kuu jíín tú'un ká'a̱n ndaa̱ Dios, ja̱ ñá'nu‑ga̱ kúu, chi tu̱'un ká'a̱n ndaa̱ Dios kúu tu̱'un Se̱'e‑ya̱.
\v 10 Cha̱a kándíja nuu̱ Sé'e Dios, a jiní ndaa̱ máá‑de. Te cha̱a tú kándíja nuu̱ Dios, nátu̱'un násá'a‑de‑ya̱ ɨ́ɨn I'a̱ xndá'ú, chi̱ tú kándíja‑de tu̱'un ni̱ ka'a̱n ndaa̱ Dios ja̱ ní jani‑ya̱ tú'un Se̱'e‑ya̱.
\v 11 Te ya̱'á kúu tu̱'un ndaa̱‑ún: Ni̱ ja̱'a Dios tu̱'un ja̱ kúchaku̱‑yo̱ nɨ́ɨ́ káni, te Se̱'e‑ya̱ kúu I'a̱ ndíso tu̱'un kuchaku̱‑yo̱.
\v 12 Cha̱a kándíja nuu̱ Sé'e‑ya̱, a ni̱ ni'i̱n tá'u̱‑dé kuchaku̱‑de. Ko cha̱a tú kándíja nuu̱ Sé'e‑ya̱, tú ní ní'i̱n tá'u̱‑dé kuchaku̱‑de.
\v 13 Tu̱'un yá'a cháa‑ri̱ nuu̱ róó, ña̱yɨvɨ kákandíja nuu̱ Sé'e Dios, náva̱'a ná kuní‑ro̱ já á ni̱ kani'i̱n tá'u̱‑ro̱ kúchaku̱‑ro̱ nɨ́ɨ́ káni, náva̱'a kandíja va̱'a‑ró núu̱ Sé'e Dios.
\v 14 Ja̱ yá'á chúndéé iní‑yo̱ ká'a̱n‑yo̱ jíín‑yá, chi̱ nú jikán‑yo̱ ɨ́ɨn ndatíñu nuu̱‑yá nátu̱'un kuní máá‑yá, te jíni ná'ín‑yá tu̱'un ká'a̱n‑yo̱.
\v 15 Te nú kájini̱‑yo̱ já jíni ná'ín‑yá tu̱'un ká'a̱n‑yo̱ na̱ún ndatíñu kájika̱n‑yo̱. Núsáá te a kájini̱‑yo̱ já ní'i̱n‑yo̱ já ní kajika̱n‑yo̱‑ún.
\v 16 Nú ɨɨn ña̱yɨvɨ jiní‑i sá'a ñani̱‑i kua̱chi ja̱ násu̱ kuáchi kuu̱‑de kúu, te ná ká'a̱n nda̱'ú‑i jíín‑yá, te kua̱'a‑ya̱ tú'un kuchaku̱‑de. Ko máni nuu̱ cháa ja̱ násu̱ kuáchi kuu̱‑de kásá'a‑de, áchí‑ri̱. Ió kua̱chi ja̱ kúu̱‑de, ko nasu̱ já'a̱ yúán ká'a̱n‑ri̱ ja̱ ká'a̱n nda̱'ú‑yo̱ jíín‑yá.
\v 17 Ta̱ká tiñu káñáá kúu kua̱chi. Ko íó kua̱chi ja̱ násu̱ kuáchi kuu̱‑i kúu.
\v 18 Kájini̱‑yo̱ já ñáyɨvɨ kákuu se̱'e Dios, tú sá'a‑i kua̱chi. Chi̱ ɨɨn se̱'e Dios ndíto va̱'a‑i máá‑i. Te kui'na̱, ma̱ kúu ké'é‑ún‑i.
\v 19 Te kájini̱‑yo̱ já sé'e Dios kákuu‑yó. Te kui'na̱ kúu ja̱ tɨ́ɨn so̱'o nɨ́ɨ́ ñúyɨ́vɨ.
\v 20 Ko a kájini̱‑yo̱ já ní kii Se̱'e Dios. Te kájuku̱'un ini̱‑yo̱ ní sá'a‑ya̱, náva̱'a kuni̱‑yo̱ núu̱ máá I'a̱ ndaa̱. Te a káxiu̱kú‑yó jíín máá I'a̱ ndaa̱, máá Sé'e‑ya̱ Jesucristo kúu‑ya̱. Máá‑yá kúu ndija Dios ndaa̱, te máá‑yá kúu I'a̱ kuchaku̱‑yo̱ nɨ́ɨ́ káni sá'a‑ya̱.
\v 21 Súchi̱, ná kúxio‑ró núu̱ ndosó. Súan ná kóo. Amén.
