\id JAS - Biblica® Open Finnish Living News New Testament
\h Jaakobin Kirje
\toc1 Jaakobin kirje
\toc2 Jaakobin kirje
\toc3 Jaak.
\mt1 Jaakobin Kirje
\c 1
\p 
\v 1 \add Lähettäjä:\add* Jumalan ja Herran Jeesuksen Kristuksen palvelija Jaakob.
\p \add Vastaanottajat:\add* Hajallaan asuvat juutalaiskristityt.
\s1 Vaikeudet luonteen kasvattajina
\p 
\v 2 Rakkaat veljet, onko elämässänne paljon vaikeuksia kiusausten takia? Olkaa siitä vain iloisia,
\v 3 sillä kun elämä on vaikeaa, teidän kärsivällisyytenne voi kasvaa.
\v 4 Ja antakaa sen kasvaa! Älkää yrittäkö paeta vaikeuksianne! Sillä kun saatte lisää kärsivällisyyttä, teistä tulee ehjiä ihmisiä ja kykenette säilyttämään mielenrauhanne ja rohkeutenne kaikissa elämän tilanteissa.
\p 
\v 5 Jos haluatte tietää, mikä on Jumalan tahto jossakin asiassa, kysykää häneltä. Hän vastaa mielellään ja antaa runsain mitoin viisautta kaikille, jotka sitä häneltä pyytävät, eikä moiti ketään.
\v 6 Mutta kun pyydätte, odottakaa myös saavanne, sillä jos epäilette, olette epävakaisia kuin aallot, joita tuuli heittelee.
\v 7-8 Jokainen ratkaisunne on silloin epävarma: yhtenä päivänä ajattelette yhtä, toisena toista. Jos ette rukoile uskoen, älkää myöskään odottako saavanne vastausta Herralta.
\p 
\v 9 Kristitty, jolla ei tässä maailmassa ole arvostettua asemaa, saa olla iloinen siitä, että hän on Herran silmissä arvokas.
\v 10-11 Mutta rikkaan pitäisi muistaa, ettei hänen varallisuutensa tee Herraan vaikutusta. Ihmisen käy kuin kukan, jonka kesän hehkuva aurinko kuivattaa ja jonka kauneus pian katoaa. Hän kuolee ja joutuu jättämään taakseen monet kiireensä.
\p 
\v 12 Onnellinen se ihminen, joka kestää kiusauksen. Hän saa palkinnokseen elämän, jonka Jumala on luvannut kaikille, jotka häntä rakastavat.
\v 13 Ja muistakaa, että kun teille tulee halu tehdä syntiä, kiusaus ei tule Jumalalta, sillä Jumala ei koskaan kehota ihmistä mihinkään väärään.
\v 14 Kiusaukset syntyvät ihmisen omista pahoista ajatuksista ja toiveista.
\v 15 Pahat ajatukset johtavat tekoihin, ja lopulta synnistä seuraa kuolemanrangaistus Jumalalta.
\v 16 Älkää siis eksykö, rakkaat kristityt!
\s1 Kaiken hyvän antaja
\p 
\v 17 Kaiken hyvän ja täydellisen antaja on Jumala, valon luoja. Hänen valonsa on ikuista ja muuttumatonta.
\v 18 Omasta vapaasta tahdostaan Jumala antoi meille uuden elämän sanassaan, joka on totuus. Näin meistä tuli Jumalan perheen esikoisia.
\p 
\v 19 Rakkaat veljet, älkää unohtako, että on parempi kuunnella kuin puhua. On myös hyvä olla kiivastumatta,
\v 20 sillä suuttuessaan ihminen ei tee sitä, mitä Jumala tahtoo.
\p 
\v 21 Luopukaa siis kaikesta, mikä on elämässänne väärää – ulkonaista tai sisäistä – ja iloitkaa nöyrästi sanomasta, joka on vallannut sydämemme ja voi pelastaa meidät.
\p 
\v 22 Sanoma Kristuksesta on tarkoitettu elämässä toteutettavaksi eikä ainoastaan kuultavaksi. Älkää siis pettäkö itseänne!
\v 23 Jos ihminen vain kuulee sanoman, mutta ei tottele sitä, hän on kuin mies, joka on katsonut peiliin,
\v 24 mutta otettuaan muutaman askeleen ei enää muista, minkä näköinen oli.
\v 25 Se taas, joka todella haluaa tietää, mikä Kristuksen tahto on, ja oppia tuntemaan sitä yhä syvällisemmin, myös elää sen mukaan. Jumala siunaa silloin kaiken, mitä hän tekee.
\p 
\v 26 Ihminen, joka sanoo olevansa kristitty, mutta ei hillitse terävää kieltään, pettää itseään, eikä hänen hurskautensa ole paljonkaan arvoista.
\v 27 Jumala haluaa meidän olevan niitä, jotka pysyvät uskollisina hänelle, pitävät huolta yksinäisistä ja apua tarvitsevista\f + \fr 1:27 \ft Sananmukaisesti: »menevät katsomaan orpoja ja leskiä heidän ahdistuksessaan».\f* eivätkä anna maailman saastan liata itseään.
\c 2
\s1 Ei puolueellisuutta
\p 
\v 1 Rakkaat kristityt, kuinka te voitte väittää olevanne Jeesuksen Kristuksen, kirkkauden Herran, omia, jos suositte rikkaita ja halveksitte köyhiä?
\v 2 Seurakuntanne kokoukseen saattaa tulla joku, jolla on yllään hienot vaatteet ja sormissa kalliit kultasormukset. Samalla kertaa sinne tulee myös köyhä huonoissa vaatteissa.
\v 3 Te pyöritte rikkaan ympärillä ja tarjoatte hänelle parasta istumapaikkaa. Köyhälle sanotte: »Saat seistä siinä, jos haluat, tai istua lattialla.»
\v 4 Tällainen käytös tekee koko uskonne kyseenalaiseksi – oletteko ollenkaan kristittyjä? – ja osoittaa, että toimintaanne ohjaavat väärät vaikuttimet.
\p 
\v 5 Kuulkaa, rakkaat veljet! Jumalan valitsemat köyhät ovat rikkaita uskoessaan Jeesukseen, sillä Jumalan valtakunta kuuluu heille – Jumala on luvannut sen kaikille, jotka häntä rakastavat.
\v 6 Ja kuitenkin, kun ajattelemme noita kahta vierasta, te halveksitte köyhää! Ettekö muista, että rikkaat usein sortavat teitä ja haastavat teidät oikeuteen?
\v 7 Samoin monet heistä puhuvat halveksivasti Kristuksesta, jonka jalon nimen mukaan teitä kutsutaan kristityiksi.
\p 
\v 8 On hyvä, jos tottelette Herramme käskyä: »Rakasta ja auta lähimmäistäsi aivan yhtä paljon kuin rakastat itseäsi ja pidät huolta itsestäsi.»
\v 9 Mutta te rikotte tämän Herran lain silloin, kun suositte rikkaita ja liehittelette heitä. Se on syntiä.
\p 
\v 10 Ihminen, joka muuten noudattaa Jumalan lakia, mutta tekee yhden pienen rikkeen, on yhtä syyllinen kuin se, joka on rikkonut lain jokaisen kohdan.
\v 11 Sillä Jumala, joka sanoi, ettet saa ottaa toisen miehen vaimoa, sanoi myös, ettet saa murhata. Vaikket siis olekaan tehnyt aviorikosta, mutta olet murhaaja, olet rikkonut koko Jumalan lain ja olet läpikotaisin syyllinen hänen edessään.
\v 12 Koska Kristus on sinut vapauttanut, puhu ja tee, niin kuin hän tahtoo.
\v 13 Jos et armahda toisia, miten voit ajatella, että sinut armahdetaan? Mutta jos armahdat muita, silloin Jumalan armo on sinua kohtaan suurempi kuin hänen tuomionsa.
\s1 Usko ja toiminta
\p 
\v 14 Rakkaat veljet, teidän ei kannata sanoa, että uskotte Herraan ja olette kristittyjä, jos ette osoita sitä auttamalla toisia. Pelastaako sellainen usko ketään?
\v 15 Teillä saattaa olla ystävä, joka tarvitsee ruokaa ja vaatteita,
\v 16 ja te sanotte hänelle: »Näkemiin nyt ja Jumalan siunausta. Varo, ettet vilustu ja muista syödä hyvin» – antamatta kuitenkaan hänelle vaatteita ja ruokaa. Mitä hyötyä hänelle siitä on?
\p 
\v 17 Huomaatte siis, että usko ei voi olla vaikuttamatta elämäntapaanne. Usko, josta ei seuraa oikeita tekoja, on kuollutta ja hyödytöntä.
\v 18 Joku saattaakin nyt sanoa: »Sinä väität, että tie Jumalan yhteyteen kulkee uskon kautta eikä siihen saa lisätä mitään. Mutta minun mielestäni hyvät teotkin ovat tärkeitä, sillä jos ihmisen elämästä ei mitenkään näy hänen uskonsa – mitä sellainen usko on? Minun uskoni näkyy siitä, mitä teen.»
\p 
\v 19 Onko joukossanne vielä sellaisia, joiden mielestä pelkkä Jumalan olemassaolon uskominen riittää? Muistakaa, että sen demonitkin uskovat – niin että vapisevat pelosta!
\v 20 Etkö tajua, ihminen, että uskosi on yhtä tyhjän kanssa, ellet myös tee sitä, mitä Jumala tahtoo sinun tekevän? Usko, josta ei seuraa hyviä tekoja, ei ole todellista uskoa.
\p 
\v 21 Etkö muista, että Jumala hyväksyi esi-isämme Aabrahamin sen vuoksi, mitä hän teki? Hänhän tahtoi totella Jumalaa, vaikka se olisi merkinnyt hänen poikansa Iisakin uhraamista.
\v 22 Hän luotti Jumalaan siinä määrin, että oli valmis tekemään mitä ikinä Jumala häneltä pyysi. Hänen uskonsa ja tekonsa vaikuttivat yhdessä. Ne kuuluivat erottamattomasti yhteen.
\p 
\v 23 Tapahtui kuten Raamattu sanoo: Aabraham uskoi Jumalaa ja Jumala hyväksyi hänet. Häntä kutsuttiin jopa »Jumalan ystäväksi».
\v 24 Näette siis, että merkitystä on vain sellaisella uskolla, joka ilmenee tekoina. Sellainen usko tekee ihmisen Jumalalle kelpaavaksi.
\v 25 Toinen esimerkki tästä on Raahab, prostituoitu. Hän auttoi Israelin kansaa piilottamalla kaksi tiedustelijaa ja lähettämällä heidät turvallisesti matkaan. Hän pelastui tämän tekonsa tähden.
\v 26 Aivan niin kuin ruumis on kuollut, jos siinä ei ole henkeä, samoin usko on kuollut, ellei se tule näkyviin oikeina tekoina.
\c 3
\s1 Kielen hillitseminen
\p 
\v 1 Rakkaat veljet, älkää olko kärkkäitä huomauttamaan toisille heidän vioistaan\f + \fr 3:1 \ft Sananmukaisesti: »monien (teistä) ei pidä tulla mestareiksi (opettajiksi)».\f*, sillä jokainen meistä on usein väärässä. Kun me toisten opettajat, joiden pitäisi olla asioista perillä, teemme väärin, saamme ankaramman rangaistuksen kuin muut ihmiset.
\p 
\v 2 Jos joku kykenee hillitsemään kielensä, se osoittaa, että hän pystyy hallitsemaan itsensä täysin kaikissa muissakin suhteissa.
\v 3 Suuren hevosen saa kääntymään ja menemään, minne ajaja haluaa, kun sen suussa on pienet kuolaimet.
\v 4 Ja pieni peräsin kääntää suuren laivan kovassa tuulessakin sinne, minne perämies haluaa sen ohjata.
\p 
\v 5 Myös kieli on pieni elin, mutta kuinka valtavaa tuhoa se voi saada aikaan! Suuri metsä voi syttyä tuleen pienestä kipinästä.
\v 6 Kieli on kuin tulenliekki. Se on täynnä pahuutta, ja se myrkyttää koko ihmisen. Helvetistä on peräisin se tuli, joka voi sytyttää koko elämämme roihuaviin tuhon ja onnettomuuden liekkeihin.
\p 
\v 7 Ihmiset ovat opettaneet tai voivat opettaa jokaista eläintä tai lintua ja jokaista matelijaa ja kalaa,
\v 8 mutta ihmisen kieltä ei kukaan pysty kesyttämään. Se on aina valmis syöksemään kuolettavaa myrkkyään.
\v 9 Välillä se ylistää Taivaan Isää, välillä se taas kiroaa ihmisiä, jotka Jumala on luonut kuvakseen.
\v 10 Siten siunaus ja kirous tulevat samasta suusta. Rakkaat veljet, tämä ei varmastikaan ole oikein!
\v 11 Pulppuaako samasta lähteestä ensin makeaa vettä ja sitten karvasta?
\v 12 Voidaanko viikunapuusta poimia oliiveja tai viiniköynnöksestä viikunoita? Eihän makeaa vettä voida nostaa suolaisesta lammikosta.
\v 13 Olette viisaita, jos elätte jatkuvasti hyvää tehden, ja todella viisasta on olla itsestään ylpeilemättä.
\v 14 Jos kerskutte viisaudestanne ja hyvyydestänne, vaikka olette katkeria, kateellisia ja itsekkäitä, niin puhutte vastoin totuutta.
\v 15 Jumalan mielen mukaiseen viisauteen eivät kuulu kateus ja itsekkyys. Ne kuuluvat tähän maailmaan ja ovat syntisen minämme ja saatanan aikaansaannosta.
\v 16 Siellä, missä on kateutta ja itsekästä kunnianhimoa, vallitsee epäjärjestys ja kaikenlainen paha.
\p 
\v 17 Se viisaus, joka tulee taivaasta, on ensiksikin puhdasta ja hiljaisen lempeää. Se rakastaa rauhaa ja on ystävällistä. Se antaa sijaa keskustelulle ja katsoo toisten parasta. Siitä tulvii armahtavaa rakkautta ja hyvyyttä. Se on ehdotonta, rehellistä ja vilpitöntä.
\v 18 Missä on kylvetty rauhan siementä, siellä on satona hyvyys.
\c 4
\s1 Mistä riidat syntyvät?
\p 
\v 1 Miksi olette keskenänne erimielisiä ja riitaisia? Ettekö siksi, että teidän sisimmässänne taistelee kokonainen pahojen halujen armeija?
\v 2 Te tahdotte saada sellaista, mitä teillä ei ole, ja olette valmiit vaikka tappamaan saadaksenne, mitä haluatte. Tavoittelette sellaista, mitä toisilla on, mutta kun se ei ole saatavissanne, te riitelette ja kilpailette riistääksenne sen heiltä. Miksi teillä sitten ei ole sitä, mitä haluatte? Koska ette pyydä Jumalalta.
\v 3 Ja kun pyydätte, ette saa, sillä tavoitteenne on väärä: omien mielitekojenne täyttäminen.
\p 
\v 4 Te olette kuin uskoton vaimo, joka rakastaa miehensä vihollisia. Ettekö ymmärrä, että ystävystyminen Jumalan vihollisten – tämän maailman pahojen halujen – kanssa tekee teistä Jumalan vihollisia? Minä sanon vielä uudelleen, että jos tahdotte nauttia siitä, mikä maailmassa on pahaa, ette voi olla Jumalan ystäviä.
\p 
\v 5 Mitä ajattelette Raamatun tarkoittavan sanoessaan, että Jumalan Pyhä Henki, joka asuu meissä, haluaa myös jatkuvasti hallita meitä kaikessa?
\v 6 Häneltä saamme lisää voimaa pahojen halujen vastustamiseen. Sanoohan Raamattu, että Jumala antaa voimaa nöyrille, mutta vastustaa ylpeitä ja ylimielisiä.
\p 
\v 7 Antakaa siis itsenne nöyrästi Jumalalle. Vastustakaa saatanaa, niin hän pakenee luotanne. Tulkaa lähelle Jumalaa, niin hänkin tulee lähelle teitä.
\v 8 Syntiset, luopukaa siitä, mikä on väärää. Antakaa yksin Jumalan täyttää sydämenne ja tehdä siitä puhdas ja hänelle uskollinen.
\v 9 Itkekää pahuuttanne! Teillä on täysi syy olla murheellisia sen vuoksi, mitä olette tehneet. Muuttukoon naurunne itkuksi ja ilonne mielipahaksi!
\v 10 Sitten kun tunnette arvottomuutenne Jumalan edessä, hän rohkaisee ja auttaa teitä.
\p 
\v 11 Älkää arvostelko toisianne, rakkaat veljet, älkääkä puhuko pahaa toisistanne. Jos niin teette, kapinoitte Jumalan lakia vastaan. Sehän käskee meitä rakastamaan toinen toistamme ja kieltää meitä tuomitsemasta veljeämme. Sinun päätettävissäsi ei ole, onko tämä laki oikea vai väärä: sinun on toteltava.
\v 12 Vain Jumala, joka lain sääti, osaa tuomita meidät oikein. Yksin hänen vallassaan on päättää pelastumisestamme tai tuhoutumisestamme. Mitä oikeutta sinulla siis on tuomita tai arvostella toisia?
\p 
\v 13 Kuulkaa, te, jotka sanotte: »Tänään tai huomenna menemme siihen ja siihen kaupunkiin, viivymme siellä vuoden ja perustamme menestyvän liikeyrityksen.»
\v 14 Mistä te tiedätte, mitä huomenna tapahtuu? Teidän maanpäällinen elämännehän on yhtä epävarma kuin aamun sumu: nyt se näkyy, mutta pian se on jo haihtunut.
\v 15 Näin teidän pikemminkin tulisi sanoa: »Jos Herra tahtoo, niin elämme ja teemme sitä ja sitä.»
\v 16 Muussa tapauksessa ylpeilette omista suunnitelmistanne, eikä sellainen itsevarmuus miellytä Jumalaa.
\p 
\v 17 Muistakaa, että on syntiä jättää tekemättä se, minkä tietää olevan oikein.
\c 5
\s1 Varoituksia rikkaille
\p 
\v 1 Kuulkaa, te rikkaat, teidän on nyt aika itkeä ja valittaa, koska teitä odottavat suuret vaikeudet.
\v 2 Rikkautenne on pian mennyttä ja hienot vaatteenne vain koinsyömiä lumppuja.
\v 3 Teidän kultanne ja hopeanne katoaa, mutta se on kuitenkin todistuksena teitä vastaan ja syö teidän lihaanne kuin tuli. Tällaista te olette koonneet itsellenne edessä olevan tuomiopäivän varalle.
\p 
\v 4 Kuunnelkaa! Eikö korviinne kantaudu niiden työmiesten valitus, joille kuuluvan palkan te olette anastaneet? Heidän huutonsa on Herra kuullut.
\v 5 Te olette viettäneet aikanne täällä maan päällä huvitellen ja mielihalujanne tyydyttäen, mutta nyt te joudutte tilille.
\v 6 Olette tuominneet ja surmanneet rehellisen miehen, joka ei voinut puolustautua teitä vastaan.
\s1 Herran paluun odotusta
\p 
\v 7 Mutta te, rakkaat veljet, jotka odotatte Herran paluuta, olkaa kärsivällisiä kuin maanviljelijä, joka odottaa sateiden tulevan ajallaan ja arvokkaan satonsa kypsyvän.
\v 8 Olkaa siis kärsivällisiä ja rohkeita, sillä Herra tulee kohta.
\v 9 Älkää moittiko toisianne, veljet. Oletteko itse arvostelun yläpuolella? Katsokaa: suuri tuomari tulee! Hän on jo pian täällä. Jättäkää tuomitseminen hänelle.\f + \fr 5:9 \ft Sisältyy ajatukseen.\f*
\p 
\v 10 Ottakaa esimerkkiä siitä, kuinka Herran profeetat kestivät kärsimyksiä.
\v 11 Tiedämme heidän olevan nyt onnellisia, koska he silloin pysyivät hänelle uskollisina, vaikka saivatkin sen tähden paljon kärsiä. Job on hyvä esimerkki miehestä, joka murheiden keskellä luotti jatkuvasti Herraan. Jobin kokemukset osoittavat, että kaikki, mitä Herra antaa meille tapahtua, koituu meidän parhaaksemme. Me olemme kaikesta huolimatta hänen hyvässä hoidossaan.
\p 
\v 12 Mutta ennen kaikkea, rakkaat veljet, älkää vannoko taivaan, maan tai minkään muunkaan nimeen. Sanokaa vain yksinkertaisesti »on» tai »ei», niin ette tee syntiä eikä teitä tuomita.
\s1 Apua kärsiville ja sairaille
\p 
\v 13 Jos joku teistä kärsii jostakin, rukoilkoon. Jos joku on onnellinen, niin ylistäköön siitä Herraa.
\v 14 Jos joku teistä on sairas, kutsukoon luokseen seurakunnan vanhimmat. Näiden tehtävä on rukoilla sairaan puolesta, voidella häntä öljyllä ja pyytää Herraa parantamaan hänet.
\v 15 Jos he rukoilevat uskoen, Herra tekee sairaan terveeksi, ja jos hänen omallatunnollaan on syntiä, Herra antaa hänelle anteeksi.
\p 
\v 16 Tunnustakaa syntinne toisillenne ja rukoilkaa toistenne puolesta, että parantuisitte. Jumalan mielen mukaisen ihmisen rukouksella on suuri voima, ja se tuottaa ihmeellisiä tuloksia.
\v 17 Elia oli samanlainen ihminen kuin mekin, mutta kun hän pyysi hartaasti, ettei tulisi sadetta, niin seuraavaan kolmeen ja puoleen vuoteen ei ollenkaan satanut.
\v 18 Sitten hän rukoili taas ja pyysi, että sataisi. Silloin alkoi sataa kaatamalla, ja pellot muuttuivat vihreiksi ja puutarhat rupesivat tuottamaan satoa.
\p 
\v 19 Rakkaat veljet, jos joku teistä on menettänyt uskonsa Herraan ja joku toinen saa hänet jälleen ymmärtämään totuuden,
\v 20 niin se, joka auttaa eksyneen takaisin Jumalan yhteyteen, on pelastanut hänen sielunsa kuolemasta ja auttanut häntä saamaan monet syntinsä anteeksi.
