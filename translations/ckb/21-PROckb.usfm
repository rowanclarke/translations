\id PRO - Biblica® Open Kurdi Sorani Standard Version
\h پەندەکانی سلێمان
\toc1 پەندەکانی سلێمان
\toc2 پەندەکانی سلێمان
\toc3 پەندەکان
\mt1 پەندەکانی سلێمان
\c 1
\s1 پێشەکی: ئامانج و بابەت
\p 
\v 1 پەندەکانی سلێمانی کوڕی داود، پاشای ئیسرائیل،
\q1 
\v 2 بۆ زانینی دانایی و تەمبێکردن،
\q2 بۆ پەیبردن بە وشەکانی تێگەیشتن،
\q1 
\v 3 بۆ وەرگرتنی تەمبێکردن و وریایی،
\q2 ڕاستودروستی و دادپەروەری و ڕاستەڕێیی،
\q1 
\v 4 بۆ بەخشینی ژیری بە ساویلکە،
\q2 بە لاویش زانیاری و سەلیقە\f + \fr 1:4 \ft سەلیقە: کارکردن بە لێکدانەوە و ئارامی. هەروەها ڕازگری و پاراستنی نهێنی.‏\f*،
\q1 
\v 5 (دانا گوێی لێ دەگرێت و فێربوونی زیاد دەبێت،
\q2 تێگەیشتووش ڕاوێژی باشی دەست دەکەوێت،)
\q1 
\v 6 بۆ تێگەیشتنی پەند و نموونە،
\q2 قسەی دانایان و مەتەڵەکانیان.
\b
\q1 
\v 7 لەخواترسی سەرەتای زانیارییە،
\q2 بەڵام گێلەکان سووکایەتی بە دانایی و تەمبێکردن دەکەن.
\s1 هاندان بۆ دەستگرتن بە دانایی
\s2 ئاگادارکردنەوە لە دژی فریودان
\q1 
\v 8 ڕۆڵە، گوێ لە تەمبێکردنی باوکت بگرە و
\q2 فێرکردنی دایکت پشتگوێ مەخە،
\q1 
\v 9 چونکە تاجەگوڵینەی نیعمەتن بۆ سەرت،
\q2 گەردانەن بۆ ملت.
\b
\q1 
\v 10 ڕۆڵە، ئەگەر گوناهباران فریویان دایت،
\q2 ڕازی مەبە.
\q1 
\v 11 ئەگەر گوتیان: «لەگەڵمان وەرە،
\q2 بۆسە بۆ خوێنڕشتن بنێینەوە،
\q2 بەبێ هۆ بۆ بێتاوانێک خۆمان مات بکەین،
\q1 
\v 12 وەک جیهانی مردووان بە زیندووێتی هەڵیانلووشین و
\q2 بە ساغی وەک ئەوانەی لە گۆڕ دەنرێن.
\q1 
\v 13 هەموو گەنجینەیەکی بەهادار دەدۆزینەوە و
\q2 ماڵمان پڕ دەکەین لە دەستکەوت.
\q1 
\v 14 پشکی خۆت هەڵبدە ناومان،
\q2 بە هەموومان یەک کیسەمان دەبێت.»
\q1 
\v 15 ڕۆڵە، لەگەڵیان بە ڕێگادا مەڕۆ،
\q2 پێیەکانت قەدەغە بکە لە ڕێڕەوەکانیان،
\q1 
\v 16 چونکە پێیەکانیان بەرەو خراپە ڕادەکەن،
\q2 بۆ خوێنڕشتن پەلە دەکەن.
\q1 
\v 17 بێ سوودە دانانەوەی تۆڕ
\q2 لەبەرچاوی هەموو باڵدارێک.
\q1 
\v 18 بۆ خوێنی خۆیان بۆسەیان ناوەتەوە،
\q2 خۆیان تەنها بۆ گیانی خۆیان ماتداوە.
\q1 
\v 19 ئاوایە ڕێچکەی هەموو ئەوانەی بەدوای دەستکەوتی ناڕەواوەن،
\q2 سەری خاوەنی دەخوات.
\s1 ئاگادارکردنەوە لە ڕەتکردنەوەی دانایی
\q1 
\v 20 دانایی لە کۆڵان هاوار دەکات،
\q2 لە گۆڕەپانەکان دەنگ بەرز دەکاتەوە،
\q1 
\v 21 لە شەقامە قەرەباڵغەکاندا بانگ دەکات،
\q2 لە دەروازەی شارەکاندا قسەی خۆی دەکات:
\b
\q1 
\v 22 «هەتا کەی ئەی ساویلکەکان حەز لە ساویلکەیی دەکەن؟
\q2 هەتا کەی گاڵتەجاڕان بە گاڵتەکردن دڵخۆش دەبن،
\q2 گێلەکانیش ڕقیان لە زانیاری دەبێتەوە؟
\q1 
\v 23 بگەڕێنەوە کاتێک سەرزەنشتتان دەکەم!
\q2 ئینجا ڕۆحی خۆمتان بەسەردا دەڕێژم،
\q2 وشەکانی خۆمتان پێ دەناسێنم.
\q1 
\v 24 بەڵام بانگهێشتم کردن، ڕەتتان کردەوە،
\q2 دەستم درێژکرد، کەس گوێی پێنەدا،
\q1 
\v 25 هەموو ڕاوێژێکی منتان پشتگوێ خست،
\q2 سەرزەنشتی منتان وەرنەگرت،
\q1 
\v 26 جا منیش لە کارەساتتان پێدەکەنم.
\q2 گاڵتە دەکەم کە ترستان لێ نیشت،
\q1 
\v 27 کە ترستان وەک گەردەلوول لێ نیشت و
\q2 وێرانیتان وەک ڕەشەبا هاتە سەر و
\q2 تەنگانە و ناخۆشی بەسەرتانی دادا.
\b
\q1 
\v 28 «ئینجا بانگم دەکەن، بەڵام من وەڵام نادەمەوە،
\q2 بە پەرۆشییەوە بەدوامدا دەگەڕێن بەڵام نامدۆزنەوە.
\q1 
\v 29 لەبەر ئەوەی ڕقیان لە زانیاری بووەوە،
\q2 لەخواترسییان هەڵنەبژارد،
\q1 
\v 30 لەبەر ئەوەی ڕاوێژی منیان وەرنەگرت،
\q2 بە سووکییەوە تەماشای هەموو سەرزەنشتەکانی منیان کرد،
\q1 
\v 31 بۆیە لە بەرهەمی ڕێگای خۆیان دەخۆن،
\q2 لە بەری پیلانەکانیان تێر دەبن،
\q1 
\v 32 چونکە هەڵگەڕانەوەی ساویلکەکان دەیانکوژێت،
\q2 بێباکی گێلەکان لەناویان دەبات.
\q1 
\v 33 بەڵام ئەوەی گوێ لە من بگرێت بە ئاسوودەیی نیشتەجێ دەبێت،
\q2 لە ترسی خراپە دەحەسێتەوە.»
\c 2
\s1 سوودی دانایی
\q1 
\v 1 ڕۆڵە، ئەگەر قسەکانم وەربگریت،
\q2 فەرمانەکانم لەلای خۆت هەڵبگریت،
\q1 
\v 2 هەتا گوێ بدەیتە دانایی و
\q2 دڵت بدەیتە تێگەیشتن،
\q1 
\v 3 ئەگەر بانگی پەیبردن بکەیت و
\q2 دەنگ بۆ تێگەیشتن هەڵبڕیت،
\q1 
\v 4 ئەگەر وەک زیو داوات کرد و
\q2 وەک خشڵی شاردراوە بەدوایدا گەڕایت،
\q1 
\v 5 ئەوسا لە واتای لەخواترسی دەگەیت و
\q2 ناسینی خودا دەدۆزیتەوە،
\q1 
\v 6 چونکە یەزدان دانایی دەبەخشێت،
\q2 زانیاری و تێگەیشتنیش لە دەمی ئەوە.
\q1 
\v 7 دانایی تەواو بۆ سەرڕاستەکان هەڵدەگرێت و
\q2 قەڵغانە بۆ ئەوانەی ڕێگای تەواوەتی دەگرنەبەر،
\q1 
\v 8 بۆ چاودێری ڕێچکەی دادپەروەری و
\q2 پاراستنی ڕێگای خۆشەویستانی.
\b
\q1 
\v 9 ئینجا ڕاستودروستی و دادپەروەری و ڕاستەڕێیی تێدەگەیت،
\q2 هەموو ڕێڕەوێکی چاک،
\q1 
\v 10 لەبەر ئەوەی دانایی دێتە ناو دڵتەوە و
\q2 زانیاریش دەبێتە خۆشی دەروونت،
\q1 
\v 11 سەلیقە دەتپارێزێت و
\q2 تێگەیشتن چاودێریت دەکات.
\b
\q1 
\v 12 دانایی لە ڕێگای خراپەکاران ڕزگارت دەکات،
\q2 لەو کەسانەی قسەی خوار دەکەن،
\q1 
\v 13 ئەوانەی ڕێچکەی ڕاستیان بەرداوە
\q2 تاکو بە ڕێگای تاریکیدا بڕۆن،
\q1 
\v 14 ئەوانەی دڵخۆشن بە خراپەکردن،
\q2 دڵشاد دەبن بە خواروخێچیێتی خراپە،
\q1 
\v 15 ئەوانەی ڕێچکەکانیان چەوتن،
\q2 گەوجن لە ڕێڕەویان.
\b
\q1 
\v 16 هەروەها دانایی لە ژنی بەدڕەوشت ڕزگارت دەکات،
\q2 لە ژنی داوێنپیسی زمانلووس،
\q1 
\v 17 ئەوەی وازی لە مێردی گەنجییەتی هێناوە و
\q2 پەیمانەکەی لەبەردەم خودای لەبیر کردووە.
\q1 
\v 18 بێگومان ماڵەکەی بەرەو خوارەوە دەچێت بۆ مردن و
\q2 ڕێڕەوەکانی بەرەو دنیای مردووانە.
\q1 
\v 19 هەموو ئەوانەی بچنە لای ناگەڕێنەوە و
\q2 ناگەنە ڕێچکەی ژیان.
\b
\q1 
\v 20 کەواتە بە ڕێگای پیاوچاکاندا بڕۆ و
\q2 ڕێچکەی ڕاستودروستان بپارێزە،
\q1 
\v 21 چونکە سەرڕاستان لە خاکەکە\f + \fr 2:21 \ft مەبەستی خاکی بەڵێندراوە بە ئیبراهیم.‏\f* نیشتەجێ دەبن و
\q2 تەواوەکان تێیدا دەمێننەوە،
\q1 
\v 22 بەڵام خراپەکاران لە خاکەکە دەبڕێنەوە و
\q2 ناپاکانیش تێیدا ڕیشەکێش دەکرێن.
\c 3
\q1 
\v 1 ڕۆڵە، فێرکردنەکەم لەبیر مەکە،
\q2 فەرمانەکانم لەناو دڵتدا هەڵبگرە،
\q1 
\v 2 چونکە ڕۆژگاری درێژ و
\q2 ساڵانی ژیان و ئاشتیت بۆ زیاد دەکات.
\b
\q1 
\v 3 با خۆشەویستی نەگۆڕ و دڵسۆزی لێت جیا نەبنەوە،
\q2 بە ملتەوە گرێیان بدە،
\q2 لەسەر پەڕەی دڵت بیاننووسە.
\q1 
\v 4 ئینجا پەسەندی و نازناوی چاک بەدەستدەهێنیت
\q2 لەلای خودا و خەڵک.
\b
\q1 
\v 5 پڕ بەدڵ پشت بە یەزدان ببەستە و
\q2 بە تێگەیشتوویی خۆت پشت ئەستوور مەبە.
\q1 
\v 6 لە هەموو ڕێگاکانت بیناسە،
\q2 ئەویش ڕێچکەکانت ڕاست دەکات.
\b
\q1 
\v 7 لەبەرچاوی خۆت، خۆت بە دانا مەزانە،
\q2 لە یەزدان بترسە و لە بەدکاری بەدووربە.
\q1 
\v 8 دەبێتە تەندروستی بۆ لەشت و
\q2 خۆراک بۆ ئێسقانەکانت.
\b
\q1 
\v 9 بە سامانت ڕێزی یەزدان بگرە،
\q2 بە یەکەمین بەرهەمی هەموو خەرمانەکانت.
\q1 
\v 10 ئەمبارەکەت پڕ دەبێت هەتا تێری،
\q2 قەڕابەکەت سەرڕێژ دەبێت لە شەرابی نوێ.
\b
\q1 
\v 11 ڕۆڵەکەم، بە سووکی تەماشای تەمبێکردنی یەزدان مەکە،
\q2 ڕقت لە سەرزەنشتی ئەو نەبێتەوە،
\q1 
\v 12 چونکە ئەوەی یەزدان خۆشیبوێ تەمبێی دەکات و
\q2 وەک باوکێک بە کوڕ دڵخۆش دەبێت.
\b
\q1 
\v 13 خۆزگە دەخوازرێ بەو کەسەی دانایی دەدۆزێتەوە و
\q2 بەو کەسەی تێگەیشتن بەدەستدەهێنێت،
\q1 
\v 14 چونکە قازانجی لە قازانجی زیو باشترە و
\q2 بەرهەمیشی لە زێڕ.
\q1 
\v 15 لە یاقووت بەهادارترە و
\q2 هەرچی ئارەزووی دەکەیت نابێتە هاوتای.
\q1 
\v 16 تەمەنی درێژ لە دەستی ڕاستیدایە و
\q2 دەوڵەمەندی و ڕێزیش لە دەستی چەپی.
\q1 
\v 17 ڕێگاکانی ڕێگای خۆشحاڵین و
\q2 هەموو ڕێڕەوەکانی ئاشتین.
\q1 
\v 18 درەختی ژیانە بۆ ئەوانەی خۆیان پێوە گرتووە،
\q2 خۆزگە دەخوازرێت بەوانەی پێی پابەند دەبن.
\b
\q1 
\v 19 یەزدان بە دانایی زەوی دامەزراند،
\q2 بە تێگەیشتنیش ئاسمانی چەسپاند.
\q1 
\v 20 بە زانیاری ئەو قووڵاییەکان شەق بوون،
\q2 هەورەکان شەونمیان دڵۆپاند.
\b
\q1 
\v 21 ڕۆڵە، دەست بە دانایی تەواو و سەلیقەوە بگرە،
\q2 ئەمانە لەبەرچاوت دوورنەکەونەوە،
\q1 
\v 22 دەبنە ژیان بۆ تۆ،
\q2 ملوانکە بۆ جوانی گەردنت.
\q1 
\v 23 ئەوسا بە ئاسوودەیی بە ڕێگای خۆتدا دەڕۆیت و
\q2 ساتمە ناکەیت و ناکەویت.
\q1 
\v 24 کاتێک ڕادەکشێیت بێ ترسیت،
\q2 ڕادەکشێیت و خەوت خۆش دەبێت.
\q1 
\v 25 نە لە بەڵای کتوپڕ دەترسیت و
\q2 نە لە ماڵی بەدکاران کە وێران دەبێت،
\q1 
\v 26 چونکە یەزدان دەبێتە پشتیوانت و
\q2 پێت لە پێوەبوون دەپارێزێت.
\b
\q1 
\v 27 دەستی چاکە مەگرەوە لەوانەی شایستەی چاکەن،
\q2 کاتێک لە تواناتدایە بیکەیت.
\q1 
\v 28 بە کەس\f + \fr 3:28 \ft کەس: لە زمانی عیبری ئەم وشەیە بەم واتایانە دێت: (نزیکەکەت، برادەر، دراوسێ، هاوکار، هاوڕێ، هاوڵاتی). بڕوانە دواوتار 15‏:2 و \xt لۆقا 10‏:29‏\xt*\ft ‏.‏\f* مەڵێ:
\q2 «بڕۆ، دواتر وەرەوە، بەیانی دەتدەمێ،»
\q2 لە کاتێکدا ئەو شتەت پێیە.
\q1 
\v 29 پیلانی خراپ لە دژی دراوسێکەت مەگێڕە،
\q2 لە کاتێکدا ئەو بە دڵنیاییەوە لەلات جێنشین بووە.
\q1 
\v 30 لەخۆڕایی دژایەتی کەسێک مەکە،
\q2 ئەگەر خراپەی لەگەڵتدا نەکرد.
\b
\q1 
\v 31 بەغیلی بە پیاوی ستەمکار مەبە،
\q2 هیچ ڕێگایەکی ئەو هەڵمەبژێرە،
\q1 
\v 32 چونکە لەلای یەزدان مرۆڤی قەڵپ قێزەونە،
\q2 بەڵام نهێنی خۆی لەلای سەرڕاستانە.
\q1 
\v 33 نەفرەتی یەزدان لەسەر ماڵی بەدکارە،
\q2 بەڵام ماڵی ڕاستودروستان بەرەکەتدار دەکات.
\q1 
\v 34 هەرچەندە گاڵتە بە گاڵتەجاڕان دەکات،
\q2 بەڵام نیعمەت دەداتە بێفیزەکان.
\q1 
\v 35 داناکان ڕێزداری بە میرات دەگرن،
\q2 بەڵام گێلەکان شەرمەزاری هەڵدەگرن.
\c 4
\s1 دەستپێکی دانایی
\q1 
\v 1 ئەی کوڕینە، گوێ لە تەمبێکردنی باوک بگرن،
\q2 سەرنج بدەن بۆ زانینی تێگەیشتن.
\q1 
\v 2 من شتی چاکتان فێر دەکەم،
\q2 بۆیە فێرکردنەکانی من پشتگوێ مەخەن.
\q1 
\v 3 کاتێک کوڕی باوکم بووم،
\q2 ناسک و تاقانە لەلای دایکم،
\q1 
\v 4 فێری دەکردم و پێی دەگوتم:
\q2 «با دڵت لەسەر قسەی من بێت،
\q2 ئەگەر فەرمانەکانم بپارێزیت، دەژیت.
\q1 
\v 5 دانایی بەدەستبهێنە، تێگەیشتن بەدەستبهێنە،
\q2 قسەکانی دەمم لەبیر مەکە و لێیان لامەدە.
\q1 
\v 6 واز لە دانایی مەهێنە، دەتپارێزێت،
\q2 خۆشتبوێت، چاودێریت دەکات.
\q1 
\v 7 ئەمە دەستپێکی داناییە: دانایی بەدەستبهێنە،
\q2 بە هەموو دەستکەوتەکانت، تێگەیشتن بەدەستبهێنە.
\q1 
\v 8 ڕێزی بگرە، بەرزت دەکاتەوە،
\q2 لە ئامێزی بگرە، شکۆدارت دەکات.
\q1 
\v 9 تاجەگوڵینەی نیعمەت دەخاتە سەرت،
\q2 تاجی شکۆمەندیت پێ دەبەخشێت.»
\b
\q1 
\v 10 ڕۆڵە، گوێ بگرە و قسەکانم وەربگرە،
\q2 جا تەمەنت درێژ دەبێت.
\q1 
\v 11 ڕێگای داناییم پیشاندایت،
\q2 بۆ ڕێڕەوە ڕاستەکان ڕێنماییم کردیت.
\q1 
\v 12 لە ڕۆیشتندا هەنگاوت کورت نابێت،
\q2 لە ڕاکردنیشدا پێت هەڵناکەوێت.
\q1 
\v 13 دەست بە تەمبێکردنەوە بگرە\f + \fr 4:13 \ft بە تەمبێکردن ڕازی بە.‏\f* و دەست شل مەکە،
\q2 بیپارێزە، چونکە ژیانتە.
\q1 
\v 14 مەچووە سەر ڕێگەی بەدکاران،
\q2 بە ڕێگای خراپەکاراندا مەڕۆ.
\q1 
\v 15 خۆتی لێ لابدە و پێیدا مەڕۆ،
\q2 لێی دووربکەوە و تێپەڕە،
\q1 
\v 16 چونکە خەویان لێ ناکەوێت ئەگەر خراپە نەکەن،
\q2 خەویان دەزڕێت ئەگەر یەکێک نەخەن.
\q1 
\v 17 نانی خراپە دەخۆن و
\q2 شەرابی ستەمکاری دەخۆنەوە.
\b
\q1 
\v 18 ڕێچکەی ڕاستودروستان وەک ڕووناکی بەرەبەیانە،
\q2 ڕووناکتر و ڕووناکتر دەبێت هەتا دەبێتە ڕۆژی تەواو.
\q1 
\v 19 بەڵام ڕێگای بەدکاران وەک تاریکستانە،
\q2 نازانن پێیان لە چی هەڵدەکەوێت.
\b
\q1 
\v 20 ڕۆڵە، سەرنج بدە وشەکانم،
\q2 گوێ بۆ قسەکانم شل بکە.
\q1 
\v 21 لەبەرچاوت دوورنەکەونەوە،
\q2 لە ناخی دڵت بیانپارێزە،
\q1 
\v 22 چونکە ژیانن بۆ ئەو کەسەی دەیاندۆزێتەوە،
\q2 دەرمانە بۆ هەموو لەشی.
\q1 
\v 23 لە سەرووی هەموو چاودێرییەکەوە دڵت بپارێزە،
\q2 چونکە دڵ سەرچاوەی ژیانە.
\q1 
\v 24 خواری لە دەمت داماڵە و
\q2 چەوتی لە لێوانت دووربخەوە.
\q1 
\v 25 با چاوەکانت تەماشای پێشت بکەن و
\q2 پێڵووەکانت ڕێک بۆ بەردەمت بێت.
\q1 
\v 26 ڕێڕەوی بەرپێت خۆش بکە،
\q2 هەموو ڕێگاکانت دەچەسپێن.
\q1 
\v 27 بەلای ڕاست یان چەپدا لامەدە،
\q2 پێت لە خراپە دووربخەوە.
\c 5
\s1 ئاگادارکردنەوە لە داوێنپیسی
\q1 
\v 1 ڕۆڵە، سەرنج بدە داناییم،
\q2 گوێ بۆ تێگەیشتنم شل بکە،
\q1 
\v 2 تاکو سەلیقەت بپارێزیت و
\q2 لێوەکانت ئاگایان لە زانیاری بێت،
\q1 
\v 3 چونکە لێوەکانی ژنی داوێنپیس هەنگوینیان لێ دەتکێت،
\q2 قسەی لە ڕۆن لووسترە.
\q1 
\v 4 بەڵام کۆتاییەکەی وەک زەقنەبووت تاڵە،
\q2 وەک شمشێری دوو دەم تیژە.
\q1 
\v 5 پێیەکانی بەرەو خوار دەبنەوە بۆ مردن،
\q2 هەنگاوەکانی پەیوەستن بە جیهانی مردووانەوە.
\q1 
\v 6 سەرنج ناداتە ڕێچکەی ژیان،
\q2 هەنگاوەکانی خوارە بەڵام ئەو نازانێت.
\b
\q1 
\v 7 ئەی کوڕینە، ئێستاش گوێم لێ بگرن،
\q2 لە قسەی دەمم خۆتان لامەدەن.
\q1 
\v 8 ڕێگای خۆتی لێ دووربخەوە،
\q2 لە دەرگای ماڵەکەی نزیک مەبەوە،
\q1 
\v 9 نەوەک شکۆمەندیت بە خەڵکی دیکە بدەیت و
\q2 ساڵانی تەمەنت بە کەسی دڵڕەق،
\q1 
\v 10 نەوەک بێگانەکان لە توانات تێر بن و
\q2 بەری ماندووبوونت بۆ ماڵی نامۆیەک بڕوات.
\q1 
\v 11 لە کۆتایی ژیانتدا دەناڵێنیت،
\q2 کاتێک گۆشت و جەستەت لەناودەچێت.
\q1 
\v 12 دەڵێیت: «چۆن ڕقم لە تەمبێکردن دەبووەوە،
\q2 دڵم گاڵتەی بە سەرزەنشت دەهات.
\q1 
\v 13 گوێڕایەڵی ئەوانە نەبووم کە ڕێنماییان دەکردم و
\q2 گوێم بۆ مامۆستاکانم شل نەکرد.
\q1 
\v 14 کەمێکی مابوو بکەومە ناو هەموو خراپەیەکەوە،
\q2 لەناو کۆڕ و کۆمەڵدا.»
\b
\q1 
\v 15 لە ئەمباراوی خۆت ئاو بخۆوە،
\q2 لە ئاوی هەڵقوڵاوی بیرەکەت.
\q1 
\v 16 ئایا کانییەکانت بڕژێتە سەر شەقامەکان،
\q2 جۆگەی ئاو بێت لە گۆڕەپانەکان؟
\q1 
\v 17 با تەنها بۆ تۆ بێت،
\q2 بێگانەت لەگەڵدا نەبێت.
\q1 
\v 18 با کانیاوەکەت بەرەکەتدار بێت،
\q2 بە هاوسەری گەنجییەتیت دڵخۆش بە.
\q1 
\v 19 ئاسکێکی خۆشەویست و مامزێکی شۆخ و شەنگ،
\q2 با هەموو کاتێک مەمکەکانی تێرت بکەن،
\q2 بە خۆشەویستی ئەو هەمیشە وێڵ بیت.
\q1 
\v 20 کوڕی خۆم، ئیتر بۆچی وێڵی ژنی بەدڕەوشت دەبیت؟
\q2 بۆچی ژنی داوێنپیس لە باوەش دەگریت؟
\b
\q1 
\v 21 ڕێگاکانی مرۆڤ لەبەرچاوی یەزدانە،
\q2 هەموو ڕێڕەوەکانی هەڵدەسەنگێنێت.
\q1 
\v 22 بەدکار بە تاوانەکانی خۆیەوە پێوەبوو،
\q2 بە داوی گوناهەکانی خۆیەوە دەبێت.
\q1 
\v 23 لەبەر نەبوونی تەمبێکردن دەمرێت،
\q2 لەبەر زۆری دەبەنگییەکەی سەرگەردان دەبێت.
\c 6
\q1 
\v 1 ڕۆڵە، ئەگەر بووی بە کەفیلی دراوسێکەت،
\q2 ئەگەر لەگەڵ بێگانەیەک تەوقەت کرد\f + \fr 6:1 \ft تەوقەکردن بە مەبەستی ڕێککەوتن بەبێ هیچ بەڵگەنامەیەک.‏\f*،
\q1 
\v 2 ئەگەر بە داوی قسەکانی دەمتەوە بوویت،
\q2 بە قسەی دەمی خۆت پێوە بوویت،
\q1 
\v 3 ڕۆڵە، ئەمە بکە و فریای خۆت بکەوە،
\q2 چونکە ژێردەستەی دراوسێکەت بوویت،
\q2 بڕۆ، خۆت نزم بکەرەوە و لە هاوڕێکەت بپاڕێوە.
\q1 
\v 4 خەو مەدە چاوەکانت و
\q2 پێڵووەکانت خەواڵوو نەبن.
\q1 
\v 5 وەک مامز خۆت لە دەست ڕاوچی دەرباز بکە،
\q2 وەک چۆلەکە لە تەڵەی ڕاوچی.
\b
\q1 
\v 6 ئەی تەمبەڵ، بڕۆ لای مێروولە،
\q2 بڕوانە ڕێگاکانی و ببە بە دانا.
\q1 
\v 7 بێ ئەوەی پێشەوا و
\q2 کوێخا و فەرمانڕەوای هەبێت،
\q1 
\v 8 بەڵام لە هاویندا نانی خۆی ئەمبار دەکات و
\q2 لە کاتی دروێنەدا خۆراکی خۆی کۆدەکاتەوە.
\b
\q1 
\v 9 ئەی تەمبەڵ، هەتا کەی پاڵدەدەیتەوە؟
\q2 کەی لە خەوەکەت هەڵدەستی؟
\q1 
\v 10 کەمێک خەوتن، کەمێک خەواڵووبوون،
\q2 کەمێکیش دەست تێکنان بۆ ڕاکشان،
\q1 
\v 11 ئینجا هەژاریت وەک چەتە دێت،
\q2 نەبوونیشت وەک چەکدار.
\b
\q1 
\v 12 کەسی هیچوپووچ، پیاوی چەواشەکار،
\q2 بە زمان خواری ڕەفتار دەکات،
\q2 
\v 13 چاوی دەقوچێنێت و
\q2 بەپێی ئاماژە دەکات و
\q2 بە پەنجە دەریدەبڕێت،
\q2 
\v 14 فێڵ لە دڵیدایە،
\q2 خراپە دادەهێنێت،
\q2 هەموو کاتێک ناکۆکی دەوروژێنێت.
\q1 
\v 15 لەبەر ئەوە لەپڕ لێی دەقەومێت،
\q2 لەناکاو دەشکێت و چارەسەری نییە.
\b
\q1 
\v 16 شەش شت هەن یەزدان ڕقی لێیانە،
\q2 حەوتیش\f + \fr 6:16 \ft دەربڕینێکی عیبرییە بۆ دووپاتکردنەوە بۆ ژمارە حەوت.‏\f* قێزەونە لەلای:
\q3 
\v 17 چاوی بەفیز،
\q3 زمانی درۆزن،
\q3 دەستێک کە خوێنی بێتاوانی ڕشتبێت،
\q3 
\v 18 دڵێک پیلانی خراپ دابهێنێت،
\q3 پێیەک بە پەلە بەرەو خراپەکاری ڕابکات،
\q3 
\v 19 شایەتی درۆزن درۆ بڵاو بکاتەوە و
\q3 وروژێنەری ناکۆکی نێوان برایان.
\s1 ئاگادارکردنەوە لە داوێنپیسی
\q1 
\v 20 ڕۆڵە، ڕاسپاردەکانی باوکت بەجێبگەیەنە و
\q2 فێرکردنەکانی دایکت پشتگوێ مەخە.
\q1 
\v 21 هەمیشە بە دڵتەوە گرێیان بدە و
\q2 بە گەردنی خۆتەوە هەڵیانواسە.
\q1 
\v 22 لە هاتوچۆکردنتدا ڕێنماییت دەکەن،
\q2 لە ڕاکشانت چاودێریت دەکەن و
\q2 کە خەبەریشت بووەوە دەتدوێنن،
\q1 
\v 23 چونکە ئەم ڕاسپاردانە چران و
\q2 ئەم فێرکردنەش ڕووناکییە،
\q2 سەرزەنشتی تەمبێکردنیش ڕێگای ژیانە،
\q1 
\v 24 بۆ ئەوەی لە ژنی بەدڕەوشت بتپارێزێت،
\q2 لە زمانلووسی داوێنپیس.
\b
\q1 
\v 25 لە دڵەوە ئارەزووی جوانییەکەی مەکە،
\q2 با بە برژانگەکانی نەتبات،
\q1 
\v 26 چونکە ژنی لەشفرۆش وا دەکات پێویستیت بە نانێک بێت،
\q2 بەڵام ژنی بەمێرد گیانی گرانبەهات ڕاودەکات.
\q1 
\v 27 ئایا کەس دەتوانێت ئاگر لە باوەش بگرێت و
\q2 جلەکانی نەسووتێت؟
\q1 
\v 28 یان بەسەر پشکۆدا بڕوات و
\q2 پێیەکانی داغ نەبێت؟
\q1 
\v 29 ئاوایە ئەوەی بچێتە لای ژنی کەسێکی دیکە،
\q2 هەرکەسێک دەستی لێ بدات بێ سزا نابێت.
\b
\q1 
\v 30 سووکایەتی بە دز ناکرێت کە دزی دەکات
\q2 بۆ خۆتێرکردن کاتێک کە برسییە.
\q1 
\v 31 هەرچەندە کە لێی ئاشکرا بوو دەبێت حەوت قات بداتەوە،
\q2 ئەگەر هەموو ماڵی خۆشی لەسەر دانابێت.
\q1 
\v 32 بەڵام ئەوەی داوێنپیسی لەگەڵ ژنێک بکات تێنەگەیشتووە،
\q2 هەرکەسێک وا بکات خۆی دەفەوتێنێت.
\q1 
\v 33 تووشی لێدان و سەرشۆڕی دەبێت و
\q2 شەرمەزارییەکەی ناسڕێتەوە،
\q1 
\v 34 چونکە ئیرەیی پیاو دەوروژێنێت،
\q2 لە ڕۆژی تۆڵەدا دەست ناگێڕێتەوە،
\q1 
\v 35 چاوی لە هیچ قەرەبووێک نییە،
\q2 بە دیاری ڕازی نابێت، ئەگەر بۆشی زیاد بکەیت.
\c 7
\s1 ئاگادارکردنەوە لە ژنی داوێنپیس
\q1 
\v 1 ڕۆڵە، گوێڕایەڵی قسەکانم بە و
\q2 ڕاسپاردەکانم لەلای خۆت هەڵبگرە،
\q1 
\v 2 ڕاسپاردەکانم بەجێبگەیەنە، دەژیت،
\q2 فێرکردنەکانیشم وەک گلێنەی چاوت بپارێزە.
\q1 
\v 3 بە پەنجەکانتەوە گرێیان بدە،
\q2 لەسەر پەڕەی دڵت بیاننووسە.
\q1 
\v 4 بە دانایی بڵێ: «تۆ خوشکی منی،»
\q2 بە تێگەیشتنیش بڵێ: «تۆ خزمی منی.»
\q1 
\v 5 بۆ ئەوەی لە ژنی بەدڕەوشت بتپارێزن،
\q2 لە ژنی داوێنپیسی زمانلووس.
\b
\q1 
\v 6 لە پەنجەرەی ماڵەکەمەوە
\q2 لەو دیوی کڵاوڕۆژنەکەمەوە\f + \fr 7:6 \ft وەک پەنجەرەیە، دەلاقەیەکە بۆ هاتوچۆی هەوا و گێڕانەوەی تیشکی خۆر.‏\f* ڕوانیم،
\q1 
\v 7 لەناو ساویلکەکاندا بینیم،
\q2 لەناو کوڕاندا سەرنجم دا گەنجێکی تێنەگەیشتوو.
\q1 
\v 8 لە شەقامەکە پەڕییەوە و لایدا لای ژنە بەدڕەوشتەکە،
\q2 ڕێگای ماڵی ئەوی دەگرتەبەر،
\q1 
\v 9 لە زەردەپەڕی ئێواران کاتی ئاوابوونی خۆر،
\q2 لەژێر تاریکایی شەو.
\b
\q1 
\v 10 ئەوەتا ژنێک بەرەوپیری چوو،
\q2 لە بەرگی لەشفرۆشێکی فێڵبازدا بوو.
\q1 
\v 11 (ئەم ژنە بە دەنگەدەنگ و سەرکێشە،
\q2 پێیەکانی لە ماڵی خۆی گیرنابێت.
\q1 
\v 12 پێیەکی لە شەقام و پێیەکی لە گۆڕەپانەکانە،
\q2 لە هەموو پەنایەک بۆسە دەنێتەوە.)
\q1 
\v 13 گەنجەکەی گرت و ماچی کرد،
\q2 بێ ئابڕووانە پێی گوت:
\b
\q1 
\v 14 «قوربانی هاوبەشیم\f + \fr 7:14 \ft قوربانی هاوبەشی: ئەم قوربانییە هاودەمی قوربانی سووتاندن بوو. تەنها یەک کەس هەڵدەستا بە دابینکردنی ئەم قوربانییە، بەڵام لەگەڵ خەڵکی دیکە بەشی زۆری ئەم قوربانییەیان لەبەردەم خودا دەخوارد وەک هێمایەک بۆ پێکەوە ژیان. بڕوانە \xt لێڤییەکان 7‏:11‏-15.‏\xt*\ft ‏\f* لەسەرە،
\q2 ئەمڕۆ نەزرەکانی\f + \fr 7:14 \ft نەزر: کارەکە پابەند دەکەیت بە مەرجێکەوە. داوا دەکەیت ئەگەر خودا کارێکت بۆ ئەنجام بدات، ئەوا تۆش ئەو کارەی بۆ ئەنجام دەدەی کە پابەندت کردووە بە مەرجەکەوە. بڕوانە \xt سەرژمێری 21‏:2‏\xt*\ft ‏.‏\f* خۆمم بەجێهێنا،
\q1 
\v 15 بۆیە بۆ دیدەنیت هاتمە دەرەوە،
\q2 بۆ دیداری ڕووی تۆ و بۆ دۆزینەوەت.
\q1 
\v 16 نوێنم لەسەر قەرەوێڵەکەم ڕاخستووە،
\q2 کەتانی ڕەنگاوڕەنگی میسری،
\q1 
\v 17 نوێنەکەم بۆنخۆش کردووە
\q2 بە موڕ و ئەلوا\f + \fr 7:17 \ft ڕووەکێکی دڕکاوییە وەک سەباڕ، شلەیەکی تێدایە بۆ پێست باشە.‏\f* و دارچین\f + \fr 7:17 \ft لەو جۆرە بۆنوبەرامانە بوونە کە بۆ بۆنخۆشکردن بەکارهێنراون.‏\f*.
\q1 
\v 18 وەرە هەتا بەیانی ئەوین بنۆشین،
\q2 بە خۆشەویستی چێژ وەربگرین،
\q1 
\v 19 چونکە مێردەکەم لە ماڵەوە نییە،
\q2 چووەتە ڕێگایەکی دوور.
\q1 
\v 20 کیسە زیوی لەگەڵ خۆی بردووە،
\q2 هەتا مانگ نەبێت بە چواردە ناگەڕێتەوە ماڵ.»
\b
\q1 
\v 21 بە زۆری مەکرەکانی لەخشتەی برد،
\q2 بە قسە لووسەکانی زەوقی هەستاند.
\q1 
\v 22 لەناکاو بەدوایدا ڕۆیشت،
\q2 وەک گایەک بۆ سەربڕین ببردرێت،
\q2 وەک مامز دەکەوێتە ناو تەڵە،
\q1 
\v 23 هەتا تیرێک جەرگی ببڕێت،
\q2 وەک پەلەکردنی باڵدار بۆ داو،
\q2 کە نازانێ بۆ گیانی خۆیەتی.
\b
\q1 
\v 24 ئەی کوڕینە، ئێستاش گوێم لێ بگرن،
\q2 سەرنج بدەنە قسەکانی دەمم.
\q1 
\v 25 با دڵت بەرەو ڕێگاکانی ئەو ژنە لانەدات،
\q2 لە ڕێبازەکانی گومڕا مەبە،
\q1 
\v 26 چونکە زۆرن ئەوانەی بە برینداری بەریداونەتەوە،
\q2 هەموو ئەوانەی بە دەستی کوژراون کۆمەڵی گەورەن.
\q1 
\v 27 ماڵەکەی ڕێگای جیهانی مردووانە،
\q2 شۆڕبوونەوەیە بۆ ژوورەکانی مەرگ.
\c 8
\s1 بانگەوازی دانایی
\q1 
\v 1 ئایا دانایی بانگەواز ناکات؟
\q2 ئەی تێگەیشتن دەنگی خۆی هەڵنابڕێت؟
\q1 
\v 2 لەسەر لووتکەی بەرزاییەکان،
\q2 لەسەر ڕێگاکان، لە چواڕیانەکان ڕادەوەستێت.
\q1 
\v 3 لەلای دەروازەی شارەکان،
\q2 لەبەردەم دەرگاکان، هاوار دەکات:
\q1 
\v 4 «ئەی خەڵکینە، بۆ ئێوە بانگ دەکەم،
\q2 دەنگم بۆ ئادەمیزادە.
\q1 
\v 5 ساویلکەکان، فێری ژیری بن،
\q2 گێلەکان، فێری تێگەیشتن بن.
\q1 
\v 6 گوێ بگرن، چونکە باسی شتی بەرزتان بۆ دەکەم،
\q2 کردنەوەی لێوەکانم بۆ ڕاستەڕێییە.
\q1 
\v 7 ڕاستگۆیی وێردی دەممە،
\q2 خراپەش قێزەونە بۆ لێوەکانم.
\q1 
\v 8 قسەکانی دەمم هەموو ڕاستودروستن،
\q2 هیچ فێڵ یان خواروخێچی تێدا نییە.
\q1 
\v 9 هەموو ڕێکن لای کەسی تێگەیشتوو،
\q2 ڕاستەڕێیە لای ئەوانەی زانیاری دەدۆزنەوە.
\q1 
\v 10 تەمبێکردن لە من وەربگرن نەک زیو،
\q2 زانیاریش زیاتر لە زێڕی پوختەکراو،
\q1 
\v 11 چونکە دانایی لە یاقووت\f + \fr 8:11 \ft یاقووت: گەوهەری سووری تۆخ.‏\f* باشترە،
\q2 هەرچی ئارەزووی دەکەیت نابێتە هاوتای.
\b
\q1 
\v 12 «من داناییم، لەگەڵ ژیریدا نیشتەجێم،
\q2 زانیاری و سەلیقەم هەیە.
\q1 
\v 13 ئەوەی لەخواترس بێت، ڕقی لە خراپە دەبێت،
\q2 من ڕقم لە لووتبەرزی و خۆبەزلزانییە،
\q2 لە ڕێگای خراپ و لە قسەی بە فێڵە.
\q1 
\v 14 ڕاوێژ و دانایی تەواو هی منن،
\q2 تێگەیشتن هی منە، هێز هی منە.
\q1 
\v 15 بە منەوە پاشاکان پاشایەتی دەکەن و
\q2 فەرمانڕەوایان بە ڕاستودروستی یاسا دەردەکەن.
\q1 
\v 16 بە منەوە میرەکان میرایەتی دەکەن،
\q2 بەگەکان و هەموو ئەوانەی بە ڕاستودروستی دادوەری دەکەن.
\q1 
\v 17 من ئەوانەم خۆشدەوێت کە منیان خۆشدەوێ،
\q2 ئەوانەش کە بە پەرۆشەوە بەدوامدا دەگەڕێن، دەمدۆزنەوە.
\q1 
\v 18 دەوڵەمەندی و ڕێزداری لەلای منە،
\q2 ڕاستودروستی\f + \fr 8:18 \ft مەبەستی لە بەرهەمی ڕاستودروستە.‏\f* و ئەو سامانەی کە دەمێنێتەوە.
\q1 
\v 19 بەرهەمی من لە زێڕ باشترە، لە زێڕی بێگەردیش،
\q2 دەغڵیشم لە زیوی پوختەکراو باشترە.
\q1 
\v 20 بە ڕێچکەی ڕاستودروستیدا دەڕۆم،
\q2 لەسەر ڕێبازی دادپەروەری،
\q1 
\v 21 تاکو سامان بکەمە میرات بۆ ئەوانەی منیان خۆشدەوێت و
\q2 ئەمبارەکانیان پڕ بکەم.
\b
\q1 
\v 22 «یەزدان لە سەرەتای بەدیهێنانەکەی منی دروستکرد،
\q2 هەر لە کۆنەوە لەپێش کارەکانی.
\q1 
\v 23 لە ئەزەلەوە من دامەزراوم،
\q2 لە سەرەتاوە، لەپێش زەوی.
\q1 
\v 24 هێشتا زەریاکان نەببوون من بەدیهێنراوم،
\q2 هێشتا کانییە پڕ ئاوەکان نەبوون.
\q1 
\v 25 پێش ئەوەی چیاکان بچەسپێن،
\q2 پێش گردەکان، من بەدیهێنراوم،
\q1 
\v 26 هێشتا نە زەوی و نە پانتاییەکانی دروستکردبوو،
\q2 نە سەرەتای خۆڵی زەوی.
\q1 
\v 27 کاتێک کە ئاسمانی جێگیر کرد من لەوێ بووم،
\q2 کاتێک کە هێڵی ئاسۆی بەسەر قووڵاییدا کێشا،
\q1 
\v 28 کاتێک کە هەوری لە ئاسمان ڕاگرت و
\q2 سەرچاوەی قووڵاییەکانی چەسپاند،
\q1 
\v 29 کاتێک کە سنووری بۆ دەریا کێشا
\q2 بۆ ئەوەی ئاوەکان فەرمانی ئەو نەشکێنن،
\q2 کاتێک کە بناغەی زەوی داڕشت.
\q1 
\v 30 لەگەڵ ئەو وەستایەکی لێزان بووم،
\q2 ڕۆژبەڕۆژ شادمانی ئەو بووم،
\q2 هەمیشە لەبەردەمیدا دڵخۆش بووم،
\q1 
\v 31 لە زەوییە ئاوەدانەکەی دڵخۆش دەبووم،
\q2 لەگەڵ ئادەمیزاد شادمان بووم.
\b
\q1 
\v 32 «ئەی کوڕینە، ئێستاش گوێم لێ بگرن،
\q2 خۆزگە دەخوازرێ بەوانەی ڕێگای من دەپارێزن.
\q1 
\v 33 گوێ لە تەمبێکردن بگرن و دانا بن،
\q2 پشت گوێی مەخەن.
\q1 
\v 34 خۆزگە دەخوازرێ بەو کەسەی گوێم لێ دەگرێت،
\q2 ڕۆژبەڕۆژ لەلای دەرگاکەم ئاگادارە،
\q2 لەلای دەروازەی دەرگاکەم ئێشک دەگرێت،
\q1 
\v 35 چونکە ئەوەی من بدۆزێتەوە، ژیان دەدۆزێتەوە،
\q2 ڕەزامەندی یەزدانیش بەدەستدەهێنێت.
\q1 
\v 36 بەڵام ئەوەی من نەدۆزێتەوە زیان بە خۆی دەگەیەنێت،
\q2 هەموو ئەوانەی ڕقیان لە منە، مردنیان خۆشدەوێت.»
\c 9
\s1 بانگەوازی دانایی و گێلایەتی
\q1 
\v 1 دانایی خانووی خۆی بنیاد ناوە،
\q2 حەوت\f + \fr 9:1 \ft لەوانەیە ژمارە حەوت بۆ هێمای تەواوەتی و ڕێکوپێکی ماڵەکە بەکارهاتووە. بڕوانە \xt ئاشکراکردن 1‏:19‏\xt*\ft ‏.‏\f* کۆڵەکەکەی داتاشیوە.
\q1 
\v 2 سەربڕدراوەکەی سەربڕیوە و شەرابەکەی تێکەڵ کردووە،
\q2 هەروەها خوانەکەی ئامادە کردووە.
\q1 
\v 3 کەنیزەکانی خۆی ناردووە و بانگ دەکات،
\q2 لەسەر بەرزاییەکانی شار:
\q1 
\v 4 «کێ ساویلکەیە، با ڕوو لێرە بکات!»
\q2 بە تێنەگەیشتووش دەڵێت:
\q1 
\v 5 «وەرن، لە نانی من بخۆن و
\q2 لەو شەرابەی تێکەڵم کردووە بخۆنەوە.
\q1 
\v 6 واز لە ساویلکەیی بهێنن و بژین،
\q2 بە ڕێگای تێگەیشتندا بڕۆن.»
\b
\q1 
\v 7 ئەوەی گاڵتەجاڕ تەمبێ بکات شەرمەزاری دەست دەکەوێت،
\q2 ئەوەی بەدکار سەرزەنشت بکات خۆی لەکەدار دەکات.
\q1 
\v 8 سەرزەنشتی گاڵتەجاڕ مەکە، نەوەک ڕقی لێت بێتەوە؛
\q2 سەرزەنشتی دانا بکە، تۆی خۆشدەوێت.
\q1 
\v 9 ڕێنمایی دانا بکە، داناتر دەبێت،
\q2 کەسێکی ڕاستودروست فێر بکە، زاناتر دەبێت.
\b
\q1 
\v 10 لەخواترسی سەرەتای داناییە،
\q2 ناسینی خودای پیرۆزیش تێگەیشتنە،
\q1 
\v 11 چونکە بە دانایی ڕۆژگارت زیاد دەکات،
\q2 ساڵانی ژیانت پتر دەبێت.
\q1 
\v 12 ئەگەر دانا بیت، داناییەکەت پاداشتت دەداتەوە؛
\q2 ئەگەر گاڵتەجاڕ بیت، تەنها لەسەر خۆت دەکەوێت.
\b
\q1 
\v 13 گێلایەتی وەک خاتوونێکی بە بۆڵەبۆڵە،
\q2 ساویلکەیە و هیچ شتێک نازانێت.
\q1 
\v 14 لە بەردەرگای ماڵەکەی دادەنیشێت،
\q2 لەسەر کورسییەک لە بەرزترین شوێنی شار،
\q1 
\v 15 بۆ بانگکردنی ڕێبوارەکان،
\q2 ئەوانەی لە ڕێچکەی خۆیان دەڕۆن:
\q1 
\v 16 «کێ ساویلکەیە، با ڕوو لێرە بکات!»
\q2 بە تێنەگەیشتووش دەڵێت:
\q1 
\v 17 «ئاوی دزراو شیرینە،
\q2 نانی بە دزی بەتامە.»
\q1 
\v 18 بەڵام ئەوان نازانن، خێوەکان لەوێن،
\q2 میوانەکانی نەزانیش لەناو جەرگەی جیهانی مردوواندان.
\c 10
\s1 پەندەکانی سلێمان
\p 
\v 1 پەندەکانی سلێمان:
\q1 کوڕی دانا باوکی شاد دەکات،
\q2 بەڵام کوڕی گێل دڵتەنگییە بۆ دایکی.
\b
\q1 
\v 2 بێ سوودە گەنجینەی داهاتی ناڕەوایی،
\q2 بەڵام ڕاستودروستی فریادەکەوێت لە مردن.
\b
\q1 
\v 3 یەزدان ناهێڵێت ڕاستودروستان تووشی برسیێتی بن،
\q2 بەڵام ئارەزووی بەدکاران بەتاڵ دەکاتەوە.
\b
\q1 
\v 4 دەستی تەمبەڵ دەبێتە هۆی هەژاری،
\q2 بەڵام دەستی کۆڵنەدەر دەوڵەمەندی بەدواوەیە.
\b
\q1 
\v 5 ئەوەی لە هاوین کۆدەکاتەوە، کوڕێکی وریایە،
\q2 بەڵام ئەو کوڕەی لە کاتی دروێنەدا دەخەوێت، مایەی شەرمەزارییە.
\b
\q1 
\v 6 بەرەکەت بۆ سەر ڕاستودروستانە،
\q2 بەڵام دەمی بەدکاران توندڕەوی دەشارێتەوە.
\b
\q1 
\v 7 یادکردنەوەی ڕاستودروستان بۆ بەرەکەتە،
\q2 بەڵام ناوی بەدکاران دەڕزێت.
\b
\q1 
\v 8 ئەوەی دڵی دانا بێت فەرمان وەردەگرێت،
\q2 بەڵام گێلی زۆربڵێ وێران دەبێت.
\b
\q1 
\v 9 ئەوەی ڕێگای ڕاست بگرێت ئاسوودە دەبێت،
\q2 بەڵام ئەوەی ڕێگای خوار بگرێت لێی ئاشکرا دەبێت.
\b
\q1 
\v 10 چاوقوچان دەبێتە هۆی ئازار،
\q2 گێلی زۆربڵێش دەکەوێت.
\b
\q1 
\v 11 دەمی کەسی ڕاستودروست سەرچاوەی ژیانە،
\q2 بەڵام دەمی بەدکاران توندڕەوی دەشارێتەوە.
\b
\q1 
\v 12 ڕق ناکۆکی دەوروژێنێت،
\q2 بەڵام خۆشەویستی هەموو یاخیبوونێک دادەپۆشێت.
\b
\q1 
\v 13 لە لێوەکانی تێگەیشتوو دانایی هەیە،
\q2 کوتەکیش بۆ پشتی تێنەگەیشتووانە.
\b
\q1 
\v 14 داناکان زانیاری کۆدەکەنەوە،
\q2 بەڵام دەمی گێل فەوتانێکی نزیکە.
\b
\q1 
\v 15 سامانی دەوڵەمەند شاری قەڵابەندیەتی،
\q2 بەڵام فەوتانی هەژاران نەدارییانە.
\b
\q1 
\v 16 کرێی کەسی ڕاستودروست ژیانە،
\q2 بەڵام داهاتی بەدکار گوناهە.
\b
\q1 
\v 17 ئەوەی چاوی لە تەمبێکردنە لەسەر ڕێچکەی ژیانە،
\q2 بەڵام ئەوەی واز لە سەرزەنشت بهێنێت گومڕا دەبێت.
\b
\q1 
\v 18 ئەوەی ڕق بشارێتەوە لێوەکانی درۆ دەکەن،
\q2 ئەوەی بوختان بڵاو بکاتەوە گێلە.
\b
\q1 
\v 19 قسەی زۆر بێ گوناه نابێت،
\q2 بەڵام ئەوەی زمانی خۆی بگرێت وریایە.
\b
\q1 
\v 20 زمانی کەسی ڕاستودروست زیوی پوختەکراوە،
\q2 بەڵام دڵی بەدکاران کەم بەهایە.
\b
\q1 
\v 21 لێوەکانی کەسی ڕاستودروست ڕابەرایەتی زۆر کەس دەکەن،
\q2 بەڵام گێلەکان بە تێنەگەیشتوویی دەمرن.
\b
\q1 
\v 22 بەرەکەتی یەزدان دەوڵەمەندی بەدواوەیە و
\q2 هیچ زەحمەتێکیش ناخاتە پاڵی.
\b
\q1 
\v 23 وەک پێکەنینە بۆ گێل بەدکاری کردن،
\q2 بەڵام دانایی بۆ کەسی تێگەیشتوو.
\b
\q1 
\v 24 ئەوەی بەدکار لێی دەترسێت، بەسەری دێت،
\q2 ئەوەی ڕاستودروستانیش ئارەزووی دەکەن، پێیان دەبەخشرێت.
\b
\q1 
\v 25 وەک تێپەڕبوونی گەردەلوول خراپەکاریش ئاوا نامێنێت،
\q2 بەڵام کەسی ڕاستودروست هەتاهەتایە جێگیر دەبێت.
\b
\q1 
\v 26 وەک سرکە بۆ ددان و دووکەڵ بۆ چاو،
\q2 کەسی تەمبەڵیش بۆ ئەوانەی دەینێرن ئاوایە.
\b
\q1 
\v 27 لەخواترسی ڕۆژانی ژیانت زیاد دەکات،
\q2 بەڵام ساڵانی بەدکاران کورت دەبێت.
\b
\q1 
\v 28 هیوای ڕاستودروستان خۆشییە،
\q2 بەڵام ئاواتی بەدکاران لەناودەچێت.
\b
\q1 
\v 29 ڕێگای یەزدان پەناگایە بۆ ئەوانەی ڕێگای ڕاست بگرن،
\q2 بەڵام لەناوچوونە بۆ ئەوانەی خراپە دەکەن.
\b
\q1 
\v 30 کەسی ڕاستودروست هەرگیز نالەقێت،
\q2 بەڵام خراپەکاران لە خاکەکە نیشتەجێ نابن.
\b
\q1 
\v 31 دەمی کەسی ڕاستودروست دانایی لێ دەڕوێت،
\q2 بەڵام زمانی درۆودەلەسە دەبڕدرێتەوە.
\b
\q1 
\v 32 لێوەکانی کەسی ڕاستودروست پەسەندیی دەزانن،
\q2 بەڵام دەمی بەدکاران درۆودەلەسە.
\b
\c 11
\q1 
\v 1 تەرازووی لاسەنگ لەلای یەزدان قێزەونە،
\q2 بەڵام ئارەزووی لە کێشی دروستە.
\b
\q1 
\v 2 کە لووتبەرزی هات، ڕیسواییش دێت،
\q2 بەڵام لەگەڵ بێفیزەکان دانایی دێت.
\b
\q1 
\v 3 ڕاستیی سەرڕاستەکان ڕێنماییان دەکات،
\q2 بەڵام خواری ناپاکان سەری خۆیان دەخوات.
\b
\q1 
\v 4 بێ سوودە سامان لە ڕۆژی تووڕەیی،
\q2 بەڵام ڕاستودروستی فریادەکەوێت لە مردن.
\b
\q1 
\v 5 ڕاستودروستی ڕێگا بۆ کەسی بێ کەموکوڕی ئاسان دەکات،
\q2 بەڵام بەدکار بە بەدکاری خۆی دەگلێت.
\b
\q1 
\v 6 ڕاستودروستی سەرڕاستەکان فریایان دەکەوێت،
\q2 بەڵام ناپاکان گرفتاری ئارەزووەکانیان دەبن.
\b
\q1 
\v 7 بە مردنی بەدکار ئومێدی دەبڕێت،
\q2 هیوای پاڵەوانانیش لەناودەچێت.
\b
\q1 
\v 8 کەسی ڕاستودروست لە تەنگانەدا دەرباز دەبێت و
\q2 بەدکار دەگرێتەوە.
\b
\q1 
\v 9 کەسی دووڕوو بە دەمی دراوسێکەی لەناودەبات،
\q2 بەڵام ڕاستودروستان بە زانیاری دەرباز دەبن.
\b
\q1 
\v 10 بە سەرکەوتنی ڕاستودروستان شار شادمان دەبێت،
\q2 بە لەناوچوونی بەدکارانیش هاواری خۆشییە.
\b
\q1 
\v 11 بە بەرەکەتی سەرڕاستەکان شار بەرز دەبێتەوە،
\q2 بەڵام بە دەمی بەدکاران وێران دەبێت.
\b
\q1 
\v 12 ئەوەی سووکایەتی بە دراوسێکەی بکات تێنەگەیشتووە،
\q2 بەڵام کەسی تێگەیشتوو بێدەنگ دەبێت.
\b
\q1 
\v 13 دەمشڕ نهێنی ئاشکرا دەکات،
\q2 بەڵام مرۆڤی دڵسۆز شت دادەپۆشێت.
\b
\q1 
\v 14 بێ ڕاوێژ گەل دەکەوێت،
\q2 بەڵام سەرکەوتن بە زۆری ئامۆژگارانە.
\b
\q1 
\v 15 ئەوەی ببێتە کەفیلی بێگانە بێگومان تووشی خراپە دەبێت،
\q2 بەڵام ئەوەی ڕەتی دەکاتەوە دەست بداتە کارێکی لەو شێوەیە، ئاسوودەیە.
\b
\q1 
\v 16 ئافرەتی نەرمونیان ڕێزی دەست دەکەوێت،
\q2 بەڵام کەسی زۆردار تەنها سامان.
\b
\q1 
\v 17 مرۆڤی بە بەزەیی چاکە لەگەڵ خۆی دەکات،
\q2 بەڵام دڵڕەق خۆی ماندوو دەکات.
\b
\q1 
\v 18 خراپەکار کرێیەکەی قەڵبە،
\q2 بەڵام چێنەری ڕاستودروست پاداشتی مسۆگەرە.
\b
\q1 
\v 19 بێگومان ڕاستودروست ژیان بەدەستدەهێنێت،
\q2 بەڵام ئەوەی شوێن خراپە دەکەوێت، مردنی دەستدەکەوێت.
\b
\q1 
\v 20 قێزی یەزدان لە دڵخراپانە،
\q2 ڕەزامەندیشی بۆ ڕێ تەواوانە.
\b
\q1 
\v 21 بێگومان بەدکار بێ سزا نابێت،
\q2 بەڵام نەوەی ڕاستودروستان دەرباز دەبن.
\b
\q1 
\v 22 وەک خەزێمی زێڕە بە لووتی بەرازەوە،
\q2 ئافرەتی جوانی بێ ئەقڵ.
\b
\q1 
\v 23 ئارەزووی ڕاستودروستان تەنها چاکەیە،
\q2 بەڵام هیوای بەدکاران لە تووڕەییە.
\b
\q1 
\v 24 هەیە بڵاو دەکاتەوە، بۆی زیاد دەکرێت،
\q2 هەیە لە ڕادەبەدەر دەستی پێوە دەگرێت، بەڵام نەدار دەبێت.
\b
\q1 
\v 25 چاوتێر دەوڵەمەند دەبێت،
\q2 ئاوگێڕیش ئاوی دەدرێتێ.
\b
\q1 
\v 26 ئەوەی گەنم ئەمبار دەکات و نایفرۆشێت گەل نەفرەتی لێ دەکات،
\q2 بەڵام بەرەکەت بۆ سەری فرۆشیارە.
\b
\q1 
\v 27 ئەوەی پەرۆشە بۆ چاکە ڕەزامەندی دەست دەکەوێت،
\q2 بەڵام ئەوەی بەدوای خراپەدا بگەڕێت خراپە دێتە ڕێی.
\b
\q1 
\v 28 ئەوەی پشت بە دەوڵەمەندی خۆی ببەستێت دەکەوێت،
\q2 ڕاستودروستانیش وەک گەڵا دەپشکوێن.
\b
\q1 
\v 29 ئەوەی ماڵی خۆی ماندوو بکات میراتی با دەبێت،
\q2 گێلیش دەبێتە نۆکەری دانا.
\b
\q1 
\v 30 بەروبوومی کەسی ڕاستودروست درەختی ژیانە،
\q2 ئەوەی خەڵک دەباتەوە دانایە.
\b
\q1 
\v 31 ئەگەر کەسی ڕاستودروست لەسەر زەوی پاداشت دەکرێت،
\q2 ئەی چەند زیاتر خراپەکار و گوناهبار!
\b
\c 12
\q1 
\v 1 ئەوەی حەز لە تەمبێکردن بکات حەز لە زانیاری دەکات،
\q2 بەڵام ئەوەی ڕقی لە سەرزەنشت بێت دەبەنگە.
\b
\q1 
\v 2 پیاوچاک ڕەزامەندی یەزدان بەدەستدەهێنێت،
\q2 بەڵام کەسی تەڵەکەباز تاوانبار دەکرێت.
\b
\q1 
\v 3 مرۆڤ بە بەدکاری ناچەسپێت،
\q2 ڕیشەی ڕاستودروستانیش نالەقێت.
\b
\q1 
\v 4 ئافرەتی خانەدان تاجی سەری مێردەکەیەتی،
\q2 بەڵام ئافرەتی شەرمەزار وەک کلۆرییە لەناو ئێسقانەکانی.
\b
\q1 
\v 5 پلانی ڕاستودروستان دادپەروەرییە،
\q2 بەڵام ڕاوێژی بەدکاران هەڵخەڵەتێنەرە.
\b
\q1 
\v 6 قسەی بەدکاران بۆسەی خوێنڕشتنە،
\q2 دەمی سەرڕاستان فریایان دەکەوێت.
\b
\q1 
\v 7 بەدکاران وەردەگەڕێنەوە و نامێنن،
\q2 بەڵام ماڵی ڕاستودروستان دەچەسپێت.
\b
\q1 
\v 8 مرۆڤ بەپێی وریاییەکەی ستایش دەکرێت،
\q2 بەڵام ئەوەی دڵخراپە ڕیسوا دەبێت.
\b
\q1 
\v 9 باشترە ساکار بیت و خزمەتکارت هەبێت
\q2 لەوەی خۆت گەورە دەربخەیت بەڵام نانت نەبێت.
\b
\q1 
\v 10 کەسی ڕاستودروست بایەخ بە ئاژەڵەکەی دەدات،
\q2 بەڵام بەزەیی بەدکاران دڵڕەقییە.
\b
\q1 
\v 11 ئەوەی ئیش لە زەوی خۆیدا بکات، تێر نان دەبێت،
\q2 بەڵام ئەوەی دوای هیچوپووچی بکەوێت، تێنەگەیشتووە.
\b
\q1 
\v 12 بەدکار حەز لە قازانجی خراپەکاران دەکات،
\q2 ڕیشەی ڕاستودروستان بەروبووم دەدات.
\b
\q1 
\v 13 خراپەکار دەکەوێتە تەڵەی زمانە یاخییەکەی،
\q2 بەڵام کەسی ڕاستودروست لە تەنگانە دەرباز دەبێت.
\b
\q1 
\v 14 مرۆڤ لە بەروبوومی دەمی تێر چاکە دەبێت،
\q2 پاداشتی ماندووبوونی دەستەکانی وەردەگرێتەوە.
\b
\q1 
\v 15 ڕێگای گێل لەبەرچاوی خۆی ڕاستە،
\q2 بەڵام دانا گوێگری ئامۆژگارییە.
\b
\q1 
\v 16 گێل دەستبەجێ تووڕەیی دەردەبڕێت،
\q2 بەڵام داپۆشەری سووکایەتی ژیرە.
\b
\q1 
\v 17 ئەو شایەتەی کە بە ڕاستگۆیی دەدوێت، ڕاستودروستی ڕادەگەیەنێت،
\q2 بەڵام شایەتی ناڕاست درۆ دەکات.
\b
\q1 
\v 18 قسەی هەڵەشانە وەک زەبری شمشێرە،
\q2 بەڵام زمانی دانایان چاکبوونەوەیە\f + \fr 12:18 \ft چاکبوونەوەیە لە برین و ئازار.‏\f*.
\b
\q1 
\v 19 لێوی ڕاستگۆ هەتاهەتایە دەچەسپێت،
\q2 بەڵام زمانی درۆ هەتا چاوتروکانێکە.
\b
\q1 
\v 20 ساختە لە دڵی ئەوانەیە کە پیلانی خراپە دەنێنەوە،
\q2 بەڵام دڵخۆشی بۆ ڕاوێژکارانی ئاشتییە.
\b
\q1 
\v 21 کەسی ڕاستودروست تووشی هیچ ناخۆشییەک نابێت،
\q2 بەڵام بەدکاران پڕ دەبن لە خراپە.
\b
\q1 
\v 22 قێزی یەزدان لە لێوی درۆیە،
\q2 بەڵام ئەوانەی بە ڕاستگۆیی کار دەکەن جێی ڕەزامەندی ئەون.
\b
\q1 
\v 23 مرۆڤی ژیر زانیارییەکەی دەپارێزێت،
\q2 دڵی گێلەکانیش گێلایەتی دەردەبڕێت.
\b
\q1 
\v 24 دەستی تێکۆشەر فەرمانڕەوایەتی دەکات،
\q2 بەڵام دەستی تەمبەڵ لەژێر بێگاریدا دەبێت.
\b
\q1 
\v 25 نیگەرانی لە دڵی مرۆڤدا دەیچەمێنێتەوە،
\q2 بەڵام قسەی خۆش شادمانی دەکات.
\b
\q1 
\v 26 کەسی ڕاستودروست ڕاوێژی چاک دەداتە هاوڕێکەی،
\q2 بەڵام ڕێگای خراپەکاران گومڕایان دەکات.
\b
\q1 
\v 27 مرۆڤی تەمبەڵ نێچیری خۆی ناگرێت،
\q2 بەڵام مرۆڤی تێکۆشەر نرخی سامانەکەی دەدات.
\b
\q1 
\v 28 لە ڕێچکەی ڕاستودروستی ژیان هەیە،
\q2 ڕێگای ڕێڕەوەکانی بەرەو نەمرییە.
\b
\c 13
\q1 
\v 1 کوڕی دانا تەمبێکردنی باوکی وەردەگرێت،
\q2 بەڵام گاڵتەجاڕ گوێ لە سەرزەنشت ناگرێت.
\b
\q1 
\v 2 مرۆڤ لە بەروبوومی دەمی چاکە دەخوات،
\q2 ناپاکانیش ئارەزوویان توندوتیژییە.
\b
\q1 
\v 3 ئەوەی ئاگای لە دەمی بێت گیانی خۆی دەپارێزێت،
\q2 بەڵام ئەوەی زمان درێژی دەکات لەناودەچێت.
\b
\q1 
\v 4 گیانی تەمبەڵ ئارەزوو دەکات و هیچی دەست ناکەوێت،
\q2 بەڵام گیانی تێکۆشەر سەرکەوتوو دەبێت.
\b
\q1 
\v 5 کەسی ڕاستودروست ڕقی لە قسەی درۆیە،
\q2 بەدکاریش ڕیسوایی و شەرمەزاری دەهێنێت.
\b
\q1 
\v 6 ڕاستودروستی ئەو کەسە دەپارێزیت کە ڕێگای ڕاستە،
\q2 خراپەش گوناهبار سەرەوژێر دەکات.
\b
\q1 
\v 7 هەیە خۆی بە دەوڵەمەند دەردەخات و هیچی نییە،
\q2 هەشە خۆی بە هەژار دەردەخات و سامانی زۆری هەیە.
\b
\q1 
\v 8 لەوانەیە مرۆڤ بە سامانەکەی گیانی خۆی بکڕێتەوە،
\q2 بەڵام هەژار گوێی لە هەڕەشە نابێت.
\b
\q1 
\v 9 ڕووناکی ڕاستودروستان دەگەشێتەوە،
\q2 بەڵام چرای بەدکاران دەکوژێتەوە.
\b
\q1 
\v 10 لە لووتبەرزییەوە تەنها ناکۆکی پەیدادەبێت،
\q2 بەڵام لەگەڵ ڕاوێژکاران دانایی.
\b
\q1 
\v 11 ماڵێک بە ناپاکی پەیداکرابێت، کەم دەکات،
\q2 بەڵام ئەوەی بە کاری دەست کۆدەبێتەوە، زیاد دەکات.
\b
\q1 
\v 12 ئومێدی درێژکراوە دڵ نەخۆش دەکات،
\q2 ئارەزووی بەدیهاتووش درەختی ژیانە.
\b
\q1 
\v 13 ئەوەی سووکایەتی بە فێرکردنەکە\f + \fr 13:13 \ft مەبەستی لە فێرکردنی تەوراتی موسایە.‏\f* بکات خۆی لەناودەبات،
\q2 بەڵام ئەوەی ڕێزی بۆ ڕاسپاردەکە هەبێت پاداشتی دەدرێتەوە.
\b
\q1 
\v 14 فێرکردنەکانی دانا کانی ژیانە،
\q2 بۆ دوورکەوتنەوە لە داوی مردن.
\b
\q1 
\v 15 تێگەیشتنی باش پەسەندی بەدەستدەهێنێت،
\q2 بەڵام ڕێگای ناپاکان سەختە.
\b
\q1 
\v 16 هەموو کەسێکی ژیر بە زانیارییەوە کار دەکات،
\q2 بەڵام نەزان گێلایەتی بڵاو دەکاتەوە.
\b
\q1 
\v 17 نێردراوی بەدکار دەکەوێتە خراپەوە،
\q2 پەیامبەری دەستپاکیش چاکبوونەوە دەهێنێت.
\b
\q1 
\v 18 هەژاری و ڕیسوایی بۆ ئەوانەیە تەمبێکردن بەلاوە دەنێن،
\q2 بەڵام ئەوەی سەرزەنشت لەگوێدەگرێت ڕێزدار دەبێت.
\b
\q1 
\v 19 ئارەزووی بەدیهاتوو خۆشییە بۆ گیان،
\q2 بەڵام گێل وا دەزانێت کە لادان لە خراپە شتێکی قێزەونە.
\b
\q1 
\v 20 ئەوەی لەگەڵ دانایان دەڕوات دەبێتە دانا،
\q2 هاوڕێی گێلەکانیش زیانی پێدەگات.
\b
\q1 
\v 21 خراپە دوای گوناهباران دەکەوێت،
\q2 بەڵام ڕاستودروستان بە چاکە پاداشت دەدرێنەوە.
\b
\q1 
\v 22 پیاوچاک میرات بۆ نەوەکانی\f + \fr 13:22 \ft عیبری، کوڕی کوڕ.‏\f* بەجێدەهێڵێت،
\q2 سامانی گوناهبارانیش بۆ ڕاستودروست هەڵدەگیردرێت.
\b
\q1 
\v 23 لەوانەیە زەویی بەیاری\f + \fr 13:23 \ft زەوی نەکێڵدراو و ئامادە بۆ کێڵان.‏\f* هەژاران خواردنی زۆری تێدابێت،
\q2 بەڵام لەبەر نادادپەروەری دەبردرێت.
\b
\q1 
\v 24 ئەوەی ڕێگا لە کوتەک بگرێت ڕقی لە کوڕەکەیەتی،
\q2 بەڵام ئەوەی خۆشیبوێت گرنگی بە تەمبێکردنی دەدات.
\b
\q1 
\v 25 کەسی ڕاستودروست دەخوات و تێر دەبێت،
\q2 بەڵام سکی بەدکاران هەر برسی دەبێت.
\b
\c 14
\q1 
\v 1 ژنی دانا ماڵی خۆی بنیاد دەنێت،
\q2 گێلیش بە دەستی خۆی کاولی دەکات.
\b
\q1 
\v 2 ئەوەی ڕاستەڕێیەکەی خۆی بگرێت لەخواترسە،
\q2 بەڵام ئەوەی ڕێگای خۆی خوار بکاتەوە سووکایەتی پێ دەکات.
\b
\q1 
\v 3 گێل بە قسەکانی خۆی تووشی گۆچانی سزادان دەبێت،
\q2 بەڵام دانایان لێوەکانیان دەیانپارێزن.
\b
\q1 
\v 4 کە مانگا نەبێت ئاخوڕ بەتاڵە،
\q2 دروێنەی زۆریش بە هێزی گایە.
\b
\q1 
\v 5 شایەتی دەستپاک درۆ ناکات،
\q2 بەڵام شایەتی درۆزن درۆ بڵاو دەکاتەوە.
\b
\q1 
\v 6 گاڵتەجاڕ داوای دانایی دەکات و نایدۆزێتەوە،
\q2 بەڵام زانیاری بۆ تێگەیشتوو ئاسانە.
\b
\q1 
\v 7 لەبەردەم کەسی گێل دووربکەوە،
\q2 چونکە لە لێوەکانی زانیاری نابیستیت.
\b
\q1 
\v 8 دانایی ژیر تێگەیشتنی ڕێگای خۆیەتی،
\q2 بەڵام گێلایەتی گێلەکان فریودانە.
\b
\q1 
\v 9 گێلەکان گاڵتە بە تاوان دەکەن،
\q2 بەڵام لەنێو سەرڕاستان ڕەزامەندی خودا دەدۆزرێتەوە.
\b
\q1 
\v 10 هەر دڵێک تاڵیێتی گیانی خۆی دەزانێت،
\q2 کەسیش لە خۆشییەکەیدا بەشداری ناکات.
\b
\q1 
\v 11 ماڵی بەدکارەکان کاول دەبێت،
\q2 بەڵام ڕەشماڵی سەرڕاستان گەشە دەکات.
\b
\q1 
\v 12 ڕێگا هەیە لەبەرچاوی مرۆڤ ڕاست دیارە،
\q2 بەڵام کۆتاییەکەی بەرەو مردنە.
\b
\q1 
\v 13 بگرە لە پێکەنینیشدا دڵ تەنگ دەبێت،
\q2 لەوانەیە کۆتایی خۆشیش خەم بێت.
\b
\q1 
\v 14 کەسی ڕاڕا لە ڕێگای خۆی تێر دەبێت،
\q2 پیاوچاکیش لەوەی کە هەیەتی.
\b
\q1 
\v 15 ساویلکە بە هەموو قسەیەک بڕوا دەکات،
\q2 بەڵام ژیر دەڕوانێتە هەنگاوەکانی خۆی.
\b
\q1 
\v 16 کەسی دانا لە خودا دەترسێت و لە خراپە لادەدات،
\q2 بەڵام گێل سەرگەرمە و پشت ئەستوورە.
\b
\q1 
\v 17 کەسی هەڵەشە ڕەفتاری گێلانە دەکات،
\q2 پیاوی تەڵەکەبازیش مایەی ڕقە.
\b
\q1 
\v 18 ساویلکەکان میراتگری گێلایەتین،
\q2 بەڵام ژیرەکان سەریان بە زانیاری دەڕازێنرێتەوە.
\b
\q1 
\v 19 بەدکاران لەبەردەم پیاوچاکان دەچەمێنەوە،
\q2 خراپەکارانیش لە بەردەرگای کەسی ڕاستودروست.
\b
\q1 
\v 20 هەژار تەنانەت دراوسێکەشی ڕقی لێی دەبێتەوە،
\q2 بەڵام دەوڵەمەند دۆستی زۆرە.
\b
\q1 
\v 21 ئەوەی سووکایەتی بە دراوسێکەی بکات گوناه دەکات،
\q2 بەڵام خۆزگە دەخوازرێ بەوەی لەگەڵ هەژاران میهرەبانە.
\b
\q1 
\v 22 ئایا وێڵ نابن ئەوانەی پیلانی خراپە دادەڕێژن؟
\q2 بەڵام خۆشەویستی نەگۆڕ و دڵسۆزی لەگەڵ ئەوانەیە کە پلانی چاکە دادەڕێژن.
\b
\q1 
\v 23 لە هەموو ماندووبوونێک سوود هەیە،
\q2 بەڵام تەنها قسەی لێوان بێت بەرەو نەبوونییە.
\b
\q1 
\v 24 دەوڵەمەندی تاجی دانایانە،
\q2 بەڵام گێلایەتی نادانایان دەڕازێنێتەوە.
\b
\q1 
\v 25 شایەتی ڕاستگۆ دەربازکەری خەڵکە،
\q2 بەڵام ئەوەی درۆ بڵاو دەکاتەوە تەفرەدەرە.
\b
\q1 
\v 26 ئەوەی لە یەزدان بترسێت دڵنیاییەکی بەهێزی هەیە،
\q2 بۆ کوڕەکانیشی دەبێتە پەناگا.
\b
\q1 
\v 27 لەخواترسی کانی ژیانە،
\q2 بۆ دوورکەوتنەوە لە داوی مردن.
\b
\q1 
\v 28 زۆری گەل شکۆمەندییە بۆ پاشا،
\q2 بەڵام نەمانی گەل شکستی میرە.
\b
\q1 
\v 29 ئەوەی درەنگ تووڕە بێت باش تێدەگات،
\q2 بەڵام ئەوەی هەڵەشە بێت گێلایەتی دەردەخات.
\b
\q1 
\v 30 دڵی ئارام ژیان بە جەستە دەبەخشێت،
\q2 بەڵام ئیرەیی ئێسک کلۆر دەکات.
\b
\q1 
\v 31 ئەوەی ستەم لە هەژار بکات سووکایەتی بە دروستکەرەکەی دەکات،
\q2 بەڵام ئەوەی لەگەڵ نەدار میهرەبانە ڕێز لە خودا دەگرێت.
\b
\q1 
\v 32 خراپەکار بە خراپەکانی خۆی دەکەوێنرێت،
\q2 بەڵام کەسی ڕاستودروست لە مردنیشی پەناگای هەیە.
\b
\q1 
\v 33 دانایی لەناو دڵی کەسی تێگەیشتوو دەحەسێتەوە،
\q2 هەروەها گێلەکان تەنانەت ناواخنیشیان دەزانرێت.
\b
\q1 
\v 34 ڕاستودروستی نەتەوە بەرز دەکاتەوە،
\q2 بەڵام گوناه شەرمەزاری گەلانە.
\b
\q1 
\v 35 ڕەزامەندی پاشا بۆ خزمەتکاری وریایە،
\q2 بەڵام تووڕەبوونی لە خزمەتکاری شەرمەزارە.
\b
\c 15
\q1 
\v 1 وەڵامی نەرم تووڕەیی دەڕەوێنێتەوە،
\q2 بەڵام قسەی بریندارکەر ڕق دەوروژێنێت.
\b
\q1 
\v 2 زمانی دانایان زانیاری دەڕازێنێتەوە،
\q2 بەڵام دەمی دەبەنگەکان گێلایەتی لێ هەڵدەقوڵێت.
\b
\q1 
\v 3 چاوی یەزدان لە هەموو جێگایەکە،
\q2 چاودێری بەدکاران و پیاوچاکان دەکات.
\b
\q1 
\v 4 هێمنی زمان درەختی ژیانە،
\q2 بەڵام خوارکردنەوەی تێکشکانی ڕۆحە.
\b
\q1 
\v 5 گێل سووکایەتی بە تەمبێکردنی باوکی دەکات،
\q2 بەڵام ئەوەی چاوی لە سەرزەنشت بێت ژیر دەبێت.
\b
\q1 
\v 6 لە ماڵی کەسی ڕاستودروست گەنجینەی گەورە هەیە،
\q2 بەڵام داهاتی بەدکار پشێوییە.
\b
\q1 
\v 7 لێوی دانایان زانیاری بڵاو دەکەنەوە،
\q2 بەڵام دڵی گێلەکان ئاوا نییە.
\b
\q1 
\v 8 قوربانی بەدکاران قێزەونە لەلای یەزدان،
\q2 بەڵام نوێژی سەرڕاستان خۆشحاڵی دەکات.
\b
\q1 
\v 9 قێزی یەزدان لە ڕێگای بەدکارە،
\q2 بەڵام ئەوەی خۆشدەوێت کە دوای ڕاستودروستی کەوتووە.
\b
\q1 
\v 10 تەمبێی سەخت بۆ لەڕێ لادەرە،
\q2 ئەوەی ڕقی لە سەرزەنشتە دەمرێت.
\b
\q1 
\v 11 جیهانی مردووان و لەناوچوون\f + \fr 15:11 \ft لەناوچوون: عیبری: \tl ئەبەدۆن‏\tl*. لە پەیمانی نوێ، ئەم وشە بە واتای (لەناوبەر) هاتووە، بڕوانە \xt ئاشکراکردن 11‏:9‏\xt*\ft ‏.‏\f* لەبەردەم یەزدانن،
\q2 لەوەش زیاتر دڵی ئادەمیزاد!
\b
\q1 
\v 12 گاڵتەجاڕ ئەو کەسەی خۆشناوێت کە سەرزەنشتی دەکات،
\q2 بۆ لای دانایان ناچێت.
\b
\q1 
\v 13 دڵی شادمان ڕوو خۆشدەکات،
\q2 بەڵام بە دڵتەنگی ڕۆح تێکدەشکێت.
\b
\q1 
\v 14 دڵی تێگەیشتوو بەدوای زانیاریدا دەگەڕێت،
\q2 بەڵام دەمی گێلەکان لەسەر گێلایەتی دەلەوەڕێت.
\b
\q1 
\v 15 هەموو ڕۆژانی ستەملێکراو سەختە،
\q2 بەڵام دڵخۆش هەمیشە لەسەر خوانی شادییە.
\b
\q1 
\v 16 باشترە کەمت هەبێت لەگەڵ لەخواترسی
\q2 لە گەنجینەی گەورە لەگەڵ سەرلێشێوان.
\b
\q1 
\v 17 باشترە سەوزە خواردن لەو شوێنەی خۆشەویستی لێیە
\q2 لە گایەکی قەڵەو و ڕقی لەگەڵ بێت.
\b
\q1 
\v 18 کەسی سەرگەرم ناکۆکی دەوروژێنێت،
\q2 بەڵام کەسی هێمن دوژمنایەتی ئارام دەکاتەوە.
\b
\q1 
\v 19 ڕێگای تەمبەڵ وەک پەرژینی دڕکە،
\q2 بەڵام ڕێگای سەرڕاستان تەخت کراوە.
\b
\q1 
\v 20 کوڕی دانا باوکی شاد دەکات،
\q2 بەڵام گێل دایکی خۆی ڕیسوا دەکات.
\b
\q1 
\v 21 گێلایەتی خۆشییە بۆ کەسی تێنەگەیشتوو،
\q2 بەڵام کەسی تێگەیشتوو بە ڕێکی ڕەفتار دەکات.
\b
\q1 
\v 22 پلان بەبێ ڕاوێژ پووچەڵ دەبێت،
\q2 بەڵام بە زۆری ڕاوێژکاران سەردەکەوێت.
\b
\q1 
\v 23 دڵخۆشییە بۆ مرۆڤ وەڵامی گونجاو،
\q2 قسەش لە کاتی خۆیدا چەند باشە!
\b
\q1 
\v 24 ڕێچکەی ژیان بۆ کەسی وریا بەرەو سەرەوەیە،
\q2 بۆ ئەوەی لە دابەزین بەرەو جیهانی مردووان بیپارێزێت.
\b
\q1 
\v 25 یەزدان ماڵی لووتبەرزان ڕیشەکێش دەکات،
\q2 بەڵام سنووری ماڵی بێوەژن دەچەسپێنێ.
\b
\q1 
\v 26 قێزی یەزدان لە پیلانی بەدە،
\q2 بەڵام قسەی شیرین پاکە.
\b
\q1 
\v 27 ئەوەی بەدوای دەستکەوتی ناڕەواوە بێت ماڵی خۆی تێکدەدات،
\q2 بەڵام ئەوەی ڕقی لە بەرتیل ببێتەوە دەژیێت.
\b
\q1 
\v 28 دڵی کەسی ڕاستودروست بیر لە وەڵام دەکاتەوە،
\q2 بەڵام دەمی بەدکاران خراپەی لێ هەڵدەڕژێت.
\b
\q1 
\v 29 یەزدان لە بەدکاران دوورە،
\q2 بەڵام گوێی لە نوێژی ڕاستودروستان دەبێت.
\b
\q1 
\v 30 ڕووناکی چاو دڵ خۆش دەکات،
\q2 مژدەش ئێسک تەندروست دەکات.
\b
\q1 
\v 31 ئەوەی گوێ لە سەرزەنشتی بەرەو ژیان بگرێت
\q2 لەناو دانایان نیشتەجێ دەبێت.
\b
\q1 
\v 32 پشتگوێخەری تەمبێکردن گیانی خۆی ڕیسوا دەکات،
\q2 بەڵام ئەوەی گوێ لە سەرزەنشت دەگرێت تێگەیشتنی دەستدەکەوێت.
\b
\q1 
\v 33 لەخواترسیی مرۆڤ بەرەو دانایی دەبات،
\q2 پێش ڕێزلێنانیش بێفیزییە.
\b
\c 16
\q1 
\v 1 پلانەکانی دڵ هی مرۆڤە،
\q2 بەڵام وەڵامدانەوەی زمان لە یەزدانەوەیە.
\b
\q1 
\v 2 هەموو ڕێگاکانی مرۆڤ لەبەرچاوی خۆی بێگەردن،
\q2 بەڵام یەزدان پاڵنەرەکان هەڵدەسەنگێنێت.
\b
\q1 
\v 3 کارەکانت بە یەزدان بسپێرە،
\q2 پلانەکانت جێگیر دەبێت.
\b
\q1 
\v 4 یەزدان بۆ مەبەستی خۆی هەموو شتێکی دروستکردووە،
\q2 تەنانەت بەدکاریش بۆ ڕۆژی بەڵا.
\b
\q1 
\v 5 یەزدان قێزی لە هەموو دڵ بەفیزێکە،
\q2 بێگومان سزادانی لەسەر تێناپەڕێت.
\b
\q1 
\v 6 بە خۆشەویستی نەگۆڕ و دڵسۆزی کەفارەت\f + \fr 16:6 \ft ئەم قوربانییەی کە تووڕەیی خودا لادەدات.‏\f* بۆ تاوان دەکرێت،
\q2 بە لەخواترسیش دوورکەوتنەوە لە خراپە.
\b
\q1 
\v 7 ئەگەر ڕەفتاری مرۆڤ مایەی ڕەزامەندی یەزدان بێت،
\q2 وا دەکات تەنانەت دوژمنەکانیشی لەگەڵیدا ئاشت ببنەوە.
\b
\q1 
\v 8 باشترە کەمت هەبێت بە ڕاستودروستییەوە
\q2 لەوەی داهاتێکی زۆری بە ناڕەوا.
\b
\q1 
\v 9 دڵی مرۆڤ پلان بۆ ڕێگای خۆی دادەنێت،
\q2 بەڵام یەزدان هەنگاوەکانی ئاراستە دەکات.
\b
\q1 
\v 10 قسەی پاشا وەک سروشە\f + \fr 16:10 \ft ‏فەرموودەیەکی خودایە کە لە ڕێگای ڕۆحی پیرۆزەوە بۆ مرۆڤ هاتبێت.‏\f*،
\q2 دەبێ لە دادوەریدا دەمی ناپاکی نەکات.
\b
\q1 
\v 11 قەپان و تەرازووی دادپەروەر لە یەزدانەوەیە،
\q2 هەموو کێشێکی ناو کیسە کاری ئەوە.
\b
\q1 
\v 12 قێزی پاشایان لە خراپەکردنە،
\q2 چونکە بە ڕاستودروستی تەخت دەچەسپێت.
\b
\q1 
\v 13 ڕەزامەندی پاشایان لێوی ڕاستودروستە،
\q2 کەسی ڕاستگۆیان خۆشدەوێت.
\b
\q1 
\v 14 تووڕەیی پاشا وەک فریشتەی مەرگە،
\q2 بەڵام کەسی دانا هێمنی دەکاتەوە.
\b
\q1 
\v 15 ڕووناکی ڕووی پاشا ژیانی تێدایە،
\q2 ڕەزامەندیشی وەک هەورە بارانی بەهارە.
\b
\q1 
\v 16 دەستکەوتنی دانایی چەند لە زێڕ باشترە،
\q2 دەستکەوتنی تێگەیشتنیش لە زیو پەسەندترە.
\b
\q1 
\v 17 ڕێگای سەرڕاستان دوورکەوتنەوەیە لە خراپە،
\q2 ئەوەی ڕێگای خۆی بپارێزێت گیانی خۆی دەپارێزێت.
\b
\q1 
\v 18 لەپێش شکان لووتبەرزییە،
\q2 لەپێش ڕووخانیش ڕۆحزلییە.
\b
\q1 
\v 19 باشترە بێفیز بیت و لەگەڵ ستەملێکراوان بیت،
\q2 لە دابەشکردنی دەستکەوت لەگەڵ لووتبەرزان.
\b
\q1 
\v 20 ئەوەی بایەخ بە ئامۆژگاری بدات چاکەی دەست دەکەوێت،
\q2 ئەوەی پشت بە یەزدان ببەستێت خۆزگەی پێ دەخوازرێت.
\b
\q1 
\v 21 ئەوەی لە دڵدا دانا بێت پێی دەگوترێت تێگەیشتوو،
\q2 شیرینی لێوەکانیش فێربوون زیاد دەکات.
\b
\q1 
\v 22 وریایی سەرچاوەی ژیانە بۆ خاوەنەکەی،
\q2 بەڵام گێلەکان بە گێلایەتی خۆیان سزا دەدرێن.
\b
\q1 
\v 23 دڵی کەسی دانا ڕێنمایی دەمی دەکات و
\q2 بەسەر لێوان فێربوون زیاد دەکات.
\b
\q1 
\v 24 قسەی جوان شانەی هەنگوینە،
\q2 بۆ دەروون شیرینە و بۆ ئێسک چاکبوونەوەیە.
\b
\q1 
\v 25 ڕێگا هەیە لەبەرچاوی مرۆڤ ڕاست دیارە،
\q2 بەڵام کۆتاییەکەی بەرەو مردنە.
\b
\q1 
\v 26 نەوسی کرێکار بۆ خۆی ڕەنج دەدات،
\q2 برسیێتییەکەی پاڵی پێوەدەنێت.
\b
\q1 
\v 27 کەسی دڵڕەش کای کۆن بە با دەکات\f + \fr 16:27 \ft عیبری: هەڵکەندنی خراپە.‏\f* و
\q2 لەسەر لێوەکانیشی ئاگری کڵپەدارن.
\b
\q1 
\v 28 کەسی درۆزن دووبەرەکی دەوروژێنێت و
\q2 دەمشڕ دۆستی نزیک لە یەکتر جیا دەکاتەوە.
\b
\q1 
\v 29 کەسی توندڕەو دراوسێی خۆی تەفرە دەدات و
\q2 بە ڕێگایەکدا دەیبات کە باش نییە.
\b
\q1 
\v 30 ئەوەی چاو دەقوچێنێت پیلان بۆ درۆ دادەڕێژێت،
\q2 ئەوەی لێوی دەکرۆژێت خراپە بە ئەنجام دەگەیەنێت.
\b
\q1 
\v 31 ڕیش سپیێتی تاجی شانازییە،
\q2 لە ڕێگای ڕاستودروستییەوە دەستدەکەوێت.
\b
\q1 
\v 32 ئەوەی درەنگ تووڕە بێت لە پاڵەوان باشترە،
\q2 ئەوەی بەسەر خۆیدا زاڵ بێت باشترە لەوەی شارێک دەگرێت.
\b
\q1 
\v 33 تیروپشک هەڵدەدرێتە کۆش،
\q2 بەڵام هەموو بڕیارێکی لەلایەن یەزدانەوەیە.
\b
\c 17
\q1 
\v 1 باشترە پارووێکی وشک بە ئارامییەوە
\q2 لە ماڵێکی پڕ لە خوانی ئامادەکراو، بە ناکۆکی.
\b
\q1 
\v 2 بەندەی وریا بەسەر کوڕی شەرمەزاردا زاڵ دەبێت و
\q2 لەگەڵ برایانی میرات بەشدەکات.
\b
\q1 
\v 3 بۆتە\f + \fr 17:3 \ft دەفرێکی کانزایی سەختە بۆ تواندنەوەی کانزای دیکە تێیدا بەکاردێت.‏\f* بۆ زیوە و کوورە بۆ زێڕ،
\q2 یەزدانیش دڵ تاقی دەکاتەوە.
\b
\q1 
\v 4 بەدکار گوێ لە لێوی خراپ دەگرێت،
\q2 درۆزنیش گوێ دەداتە زمانی گرفتخواز.
\b
\q1 
\v 5 ئەوەی گاڵتە بە هەژار بکات سووکایەتی بە دروستکەرەکەی دەکات،
\q2 ئەوەی بە بەڵا دڵی خۆشبێت بێ سزا دەرناچێت.
\b
\q1 
\v 6 منداڵی منداڵ تاجی پیرانە،
\q2 شانازی کوڕانیش دایک و باوکانن.
\b
\q1 
\v 7 قسەی نەستەق لە گێل ناوەشێتەوە،
\q2 لەوەش زیاتر قسەی درۆ لە میر.
\b
\q1 
\v 8 بەرتیل بەردی گرانبەهایە لەبەرچاوی خاوەنەکەی،
\q2 ڕوو لە هەر لایەک بکات سەردەکەوێت.
\b
\q1 
\v 9 ئەوەی تاوان دادەپۆشێت پەرە بە خۆشەویستی دەدات،
\q2 بەڵام ئەوەی باسی بابەتەکە بکاتەوە دۆستی نزیک لە یەکتر جیا دەکاتەوە.
\b
\q1 
\v 10 سەرزەنشتکردنێک بۆ تێگەیشتوو
\q2 قووڵترە لە سەد جار دارکاریکردن بۆ گێل.
\b
\q1 
\v 11 کەسی خراپ تەنها داواکاری یاخی بوونە،
\q2 لەبەر ئەوە نێردراوێکی دڵڕەقی بۆ دەنێردرێت.
\b
\q1 
\v 12 باشترە تووشی دەڵەورچێکی سک سووتاو بیت،
\q2 نەک گێلێک لە گێلایەتییەکەی خۆی.
\b
\q1 
\v 13 ئەوەی پاداشتی چاکە بە خراپە بداتەوە،
\q2 خراپە ماڵی بەرنادات.
\b
\q1 
\v 14 دەستپێکردنی ناکۆکی وەک تەقینی بەنداوە،
\q2 جا پێش ئەوەی ناکۆکییەکە بتەقێتەوە وازی لێبهێنە.
\b
\q1 
\v 15 بێتاوانکردنی خراپەکار و تاوانبارکردنی ڕاستودروست،
\q2 هەردووک قێزەونن لەلای یەزدان.
\b
\q1 
\v 16 بۆچی پارە بکەوێتە دەست پیاوی گێل؟
\q2 کە ئارەزووی نییە بۆ کڕینی دانایی!
\b
\q1 
\v 17 برادەر هەموو کاتێک خۆشەویستی خۆی دەردەبڕێت،
\q2 براش بۆ تەنگانە لەدایک دەبێت.
\b
\q1 
\v 18 کەسی تێنەگەیشتوو تەوقە دەکات\f + \fr 17:18 \ft تەوقەکردن بە مەبەستی ڕێککەوتن بەبێ هیچ بەڵگەنامەیەک.‏\f* و
\q2 بە تەواوی دەبێتە کەفیلی دراوسێکەی.
\b
\q1 
\v 19 ئەوەی حەز لە ناکۆکی بکات حەز لە گوناه دەکات،
\q2 ئەوەی دەرگای خۆی بڵند بکات داوای شکان دەکات.
\b
\q1 
\v 20 ئەوەی دڵخراپ بێت چاکە نایەتە ڕێی،
\q2 ئەوەی زمان خوار بێت تووشی خراپە دەبێت.
\b
\q1 
\v 21 ئەوەی گێلی ببێت تووشی خەفەت دەبێت،
\q2 باوکی ڕۆڵەی دەبەنگیش دڵخۆشی نابینێت.
\b
\q1 
\v 22 دڵی شادمان تەندروستی دەبەخشێت،
\q2 بەڵام ڕۆحی تێکشکاو ئێسک وشک دەکات.
\b
\q1 
\v 23 بەدکار بە نهێنی بەرتیل وەردەگرێت
\q2 تاکو ڕێچکەی دادپەروەری خوار بکاتەوە.
\b
\q1 
\v 24 کەسی تێگەیشتوو چاوی لەسەر داناییە،
\q2 بەڵام گێل چاودەبڕێتە ئەوپەڕی زەوی.
\b
\q1 
\v 25 کوڕی گێل خەمە بۆ باوکی و
\q2 تاڵییە بۆ ئەو دایکەی لێی بووە.
\b
\q1 
\v 26 پێبژاردن بە کەسی ڕاستودروست باش نییە،
\q2 هەروەها دارکاریکردنی کەسی خانەدان لەبەر دەستپاکی.
\b
\q1 
\v 27 ئەوەی قسەی خۆی ڕاگرێت خاوەن زانیارییە،
\q2 ئەوەی ڕۆح ئارام بێت پیاوی تێگەیشتنە.
\b
\q1 
\v 28 تەنانەت گێلیش کە بێدەنگ بێت بە دانا دادەنرێت،
\q2 ئەوەی لێویشی لێک نەکاتەوە بە تێگەیشتوو.
\b
\c 18
\q1 
\v 1 کەسی دوورەپەرێز دوای ئارەزووی خۆی کەوتووە،
\q2 بە ڕووی هەموو داناییەکی تەواودا دەتەقێتەوە.
\b
\q1 
\v 2 گێل خۆشی لە تێگەیشتن نابینێت،
\q2 بەڵکو بە پەخشکردنی ئەوەی لە دڵیدایە.
\b
\q1 
\v 3 بە هاتنی خراپەکار سووکایەتیش دێت،
\q2 لەگەڵ شەرمەزاریش ڕیسوایی.
\b
\q1 
\v 4 قسەی دەمی مرۆڤ ئاوێکی قووڵە،
\q2 بەڵام سەرچاوەی دانایی کانیاوێکی هەڵقوڵاوە.
\b
\q1 
\v 5 نە لایەنگری خراپەکار باشە،
\q2 نە بێبەشکردنی ڕاستودروست لە دادپەروەری.
\b
\q1 
\v 6 لێوەکانی کەسی گێل دەیهێننە ناو ناکۆکییەوە،
\q2 دەمی بانگی لێدان دەکات.
\b
\q1 
\v 7 دەمی گێل دەبێتە هۆی لەناوچوونی،
\q2 لێوەکانیشی تەڵەن بۆ گیانی.
\b
\q1 
\v 8 قسەکانی دەمشڕ وەک پارووی بەتامە،
\q2 شۆڕ دەبێتەوە ناو ورگ.
\b
\q1 
\v 9 ئەوەی سست بێت لە کارەکەی
\q2 برای وەستای وێرانکردنە.
\b
\q1 
\v 10 ناوی یەزدان قوللەیەکی بەهێزە،
\q2 کەسی ڕاستودروست بۆ ئەوێ ڕادەکات و پەناگیر دەبێت.
\b
\q1 
\v 11 سامانی دەوڵەمەند شاری قەڵابەندیەتی،
\q2 وەک شوورایەکی بڵندە بە خەیاڵی ئەو.
\b
\q1 
\v 12 پێش شکستهێنان دڵی مرۆڤ بەفیزە،
\q2 بەڵام پێش ڕێزلێنان بێفیزە.
\b
\q1 
\v 13 ئەوەی وەڵامی شتێک بداتەوە پێش بیستنی
\q2 دەبێتە مایەی گێلایەتی و شەرمەزاری بۆی.
\b
\q1 
\v 14 ڕۆحی مرۆڤ بەرگەی نەخۆشی دەگرێت،
\q2 بەڵام ڕۆحی تێکشکاو کێ بەرگەی دەگرێت؟
\b
\q1 
\v 15 دڵی پیاوی تێگەیشتوو زانیاری وەردەگرێت،
\q2 گوێی دانایانیش داوای زانینی لێ دەکات.
\b
\q1 
\v 16 دیاری مرۆڤ ڕێگای خۆش دەکات و
\q2 بەرەو ئامادەبوونی گەورە پیاوانی دەبات.
\b
\q1 
\v 17 ئەوەی یەکەم جار سکاڵا بکات لەوە دەچێت ڕاست بێت،
\q2 هەتا نزیکەکەی دێت و لێی دەکۆڵێتەوە.
\b
\q1 
\v 18 تیروپشک ناکۆکی دەبڕێنێتەوە و
\q2 بەهێزەکان لە یەکتر جیا دەکاتەوە.
\b
\q1 
\v 19 خراپە دەرهەق بە برا، ئاشتکردنەوەی لە شاری قەڵابەند سەختترە،
\q2 ناکۆکیش وەک شمشیرەی\f + \fr 18:19 \ft شمشیر، پارچە دارێک بووە لە جیاتی قوفڵ لە دواوەی دەرگا بە شێوەی ئاسۆیی دانراوە بۆ داخستنی دەرگا.‏\f* دەروازەی قەڵایە.
\b
\q1 
\v 20 لە بەروبوومی دەمی مرۆڤ سکی تێردەبێت،
\q2 لە دروێنەی لێوەکانی خۆی تێر دەخوات.
\b
\q1 
\v 21 مردن و ژیان بە دەست زمانە،
\q2 ئەوەی حەزی لێی بێت بەروبوومەکەی دەخوات.
\b
\q1 
\v 22 ئەوەی ژنێکی دەست بکەوێت خێرێکی دەست دەکەوێت،
\q2 ڕەزامەندی یەزدانیش بەدەستدەهێنێت.
\b
\q1 
\v 23 هەژار بۆ بەزەیی دەپاڕێتەوە،
\q2 بەڵام دەوڵەمەند بە ڕەقی وەڵام دەداتەوە.
\b
\q1 
\v 24 پیاو برادەری زۆر بێت خۆی گرفتار دەکات،
\q2 بەڵام دۆستێک هەیە لە برا نزیکترە.
\b
\c 19
\q1 
\v 1 هەژارێک ڕێگای تەواوەتی گرتبێت
\q2 باشترە لەوەی زمان خوار و گێلە.
\b
\q1 
\v 2 دڵگەرمی بەبێ زانیاری باش نییە و
\q2 ئەوەی پەلە بە پێیەکانی بکات بە هەڵەدا دەچێت.
\b
\q1 
\v 3 مرۆڤ بە گێلایەتییەکەی ڕێگای خۆی وێران دەکات،
\q2 کەچی دڵی لە دژی یەزدان هەڵدەچێت.
\b
\q1 
\v 4 دەوڵەمەندیێتی برادەری زۆر پەیدا دەکات،
\q2 بەڵام هەژار برادەرەکەشی لێی جیا بووەتەوە.
\b
\q1 
\v 5 شایەتی درۆزن بێ سزا نابێت،
\q2 ئەوەی درۆ پەخش دەکات دەرباز نابێت.
\b
\q1 
\v 6 زۆر کەس هەوڵی بەدەستهێنانی ڕەزامەندی میر دەدەن،
\q2 هەمووش دۆستی پیاوی بەخشندەن.
\b
\q1 
\v 7 پیاو هەژار بێت براکانی خۆشی ڕقیان لێی دەبێتەوە،
\q2 لەوەش زیاتر هاوڕێیەکانی لێی دوور دەکەونەوە!
\q1 بە پاڕانەوەکانی دوایان دەکەوێت،
\q2 بەڵام بێ سوودە.
\b
\q1 
\v 8 ئەوەی دانایی دەست بکەوێت خۆی خۆشدەوێت،
\q2 ئەوەی بایەخ بە تێگەیشتن بدات چاکە دەدۆزێتەوە.
\b
\q1 
\v 9 شایەتی درۆزن بێ سزا نابێت،
\q2 ئەوەی درۆ پەخش بکات لەناودەچێت.
\b
\q1 
\v 10 گێل خۆشگوزەرانیی لێ ناوەشێتەوە،
\q2 لەوەش زیاتر دەسەڵاتداربوونی کۆیلە بەسەر میرانەوە.
\b
\q1 
\v 11 وریایی مرۆڤ تووڕەبوونی خاودەکاتەوە،
\q2 شانازیشی لێبوردنە لە یاخیبوون.
\b
\q1 
\v 12 هەڵچوونی پاشا وەک نەڕەی شێرە،
\q2 بەڵام ڕەزامەندییەکەی وەک شەونمە بەسەر گیاوە.
\b
\q1 
\v 13 کوڕی گێل ماڵوێرانی باوکیەتی،
\q2 ناکۆکی ژنیش دڵۆپەکردنی بەردەوامە.
\b
\q1 
\v 14 ماڵ و سامان میراتی باوکانە،
\q2 بەڵام ژنی وریا لەلایەن یەزدانەوەیە.
\b
\q1 
\v 15 تەمبەڵی خەوی قووڵ دەهێنێت،
\q2 کەسی سست برسی دەبێت.
\b
\q1 
\v 16 ئەوەی ڕاسپاردە\f + \fr 19:16 \ft تەوراتی موسا.‏\f* بپارێزێت گیانی خۆی دەپارێزێت،
\q2 بەڵام ئەوەی بە سووکی بڕوانێتە ڕێگای خۆی لەناودەچێت.
\b
\q1 
\v 17 ئەوەی بەزەیی بە هەژاردا بێتەوە قەرز بە یەزدان دەدات،
\q2 ئەویش پاداشتی چاکەکەی دەداتەوە.
\b
\q1 
\v 18 کوڕەکەت تەمبێ بکە ئەوەندەی ئومێدی تێدایە،
\q2 مەبە هۆکاری مردنی.
\b
\q1 
\v 19 ئەوەی زۆر تووڕە بێت بەرگەی ئەنجامەکەی دەگرێت،
\q2 چونکە ئەگەر جارێک فریای بکەویت دەبێت دووبارەی بکەیتەوە.
\b
\q1 
\v 20 گوێ لە ڕاوێژ بگرە و تەمبێکردن وەربگرە،
\q2 بۆ ئەوەی دانا بیت لە دواڕۆژت.
\b
\q1 
\v 21 مرۆڤ پلانی زۆری لە دڵدایە،
\q2 بەڵام تەنها ڕاوێژی یەزدان دەچەسپێت.
\b
\q1 
\v 22 ئارەزووی مرۆڤ لە خۆشەویستی نەگۆڕە،
\q2 هەژار لە پیاوی درۆزن باشترە.
\b
\q1 
\v 23 لەخواترسی بۆ ژیانە،
\q2 بە تێری دەنوێت و خراپە بەسەری ناکاتەوە.
\b
\q1 
\v 24 تەمبەڵ دەست دەخاتە ناو قاپ،
\q2 تەنانەت بۆ دەمیشی نابات.
\b
\q1 
\v 25 لە گاڵتەجاڕ بدە و ساویلکە ژیر دەبێت،
\q2 تێگەیشتوو سەرزەنشت بکە زانیاری تێدەگات.
\b
\q1 
\v 26 ئەوەی باوکی تاڵان بکات و دایکی دەربکات،
\q2 کوڕێکە مایەی شەرمەزاری و ڕیسوایی.
\b
\q1 
\v 27 ڕۆڵە، ئەگەر وازت لە گوێگرتن لە ڕاوێژ هێنا،
\q2 لە وتەکانی زانیاری گومڕا دەبیت.
\b
\q1 
\v 28 شایەتی دڵڕەش گاڵتە بە دادپەروەری دەکات،
\q2 دەمی بەدکارانیش تاوان قووت دەدات.
\b
\q1 
\v 29 سزا بۆ گاڵتەجاڕەکان ئامادەکراوە،
\q2 لێدانیش بۆ پشتی گێلەکان.
\b
\c 20
\q1 
\v 1 شەراب گاڵتەجاڕە و مەستی غەڵبەغەڵب دەکات،
\q2 ئەوەی پێی وێڵ بێت دانا نییە.
\b
\q1 
\v 2 هەڵچوونی پاشا وەک نەڕەی شێرە،
\q2 ئەوەی تووڕەیی بکات لە دژی گیانی خۆی تاوان دەکات.
\b
\q1 
\v 3 وازهێنان لە ناکۆکی ڕێزدارییە بۆ پیاو،
\q2 بەڵام هەموو گێلێک هەڵیدەگیرسێنێت.
\b
\q1 
\v 4 لە زستاندا تەمبەڵ زەوی ناکێڵێت،
\q2 بۆیە لە کاتی دروێنەدا داوای بەرهەم دەکات و دەستی ناکەوێت.
\b
\q1 
\v 5 پلان لە دڵی مرۆڤدا ئاوێکی قووڵە،
\q2 بەڵام تێگەیشتوو دەریدەهێنێت.
\b
\q1 
\v 6 زۆر کەس بانگەشەی خۆشەویستی نەگۆڕ دەکەن،
\q2 بەڵام کەسی جێگای متمانە کێ دەیدۆزێتەوە؟
\b
\q1 
\v 7 کەسی ڕاستودروست بە ڕێگای تەواوی خۆیدا دەڕوات،
\q2 دوای خۆی خۆزگە بە منداڵەکانی دەخوازرێت.
\b
\q1 
\v 8 پاشای دانیشتوو لەسەر تەختی دادوەری،
\q2 بە چاوەکانی هەموو خراپەیەک شەن دەکات.
\b
\q1 
\v 9 کێیە دەڵێت: «دڵی خۆمم بێگەرد ڕاگرت،
\q2 پاک بوومەوە لە گوناهم»؟
\b
\q1 
\v 10 دوو کێش و دوو پێوانەی لاسەنگ\f + \fr 20:10 \ft بەکارهێنانی دوو کێشی جیاواز، یەکێک بۆ کڕین و یەکێک بۆ فرۆشتن.‏\f*،
\q2 هەردووکیان قێزەونن لەلای یەزدان.
\b
\q1 
\v 11 تەنانەت منداڵیش بە کردارەکانی دەناسرێت،
\q2 ئاخۆ کردەوەکەی پاک و ڕاستە.
\b
\q1 
\v 12 گوێ کە دەبیستێت و چاو کە دەبینێت،
\q2 یەزدان دروستکەری هەردووکیانە.
\b
\q1 
\v 13 حەز لە خەو مەکە نەوەک هەژار بیت،
\q2 چاوت کراوە بێت و تێر نان بە.
\b
\q1 
\v 14 کڕیار دەڵێت: «خراپە، خراپە!»
\q2 بەڵام کە ڕۆیشت شانازی پێوە دەکات.
\b
\q1 
\v 15 زێڕ هەیە و یاقووت\f + \fr 20:15 \ft یاقووت: گەوهەری سووری تۆخ.‏\f* زۆرە،
\q2 بەڵام لێوی زانیاری گەوهەرێکی بەهادارە.
\b
\q1 
\v 16 ئەگەر کەسێک بووە کەفیلی نامۆیەک کەواکەی لێ وەربگرە،
\q2 لەبەر بێگانەکە بارمتەی لێ وەربگرە.
\b
\q1 
\v 17 بەتامە بۆ مرۆڤ نانی بە فێڵ،
\q2 بەڵام دواتر دەمی پڕ دەبێت لە چەو.
\b
\q1 
\v 18 پلانەکان بە ئامۆژگاری دێنە دی،
\q2 بە ڕاوێژ بجەنگە.
\b
\q1 
\v 19 دەمشڕ نهێنی ئاشکرا دەکات،
\q2 بۆیە تێکەڵی چەنەباز مەبە.
\b
\q1 
\v 20 ئەوەی نەفرەت لە دایک و باوکی بکات،
\q2 لەناو جەرگەی تاریکیدا چرای دەکوژرێتەوە.
\b
\q1 
\v 21 میراتێک لە سەرەتای ژیان و بە زوویی دەست بکەوێت
\q2 لە کۆتاییدا بێ بەرەکەت دەبێت.
\b
\q1 
\v 22 مەڵێ: «خراپە بە خراپە دەدەمەوە.»
\q2 چاوەڕێی یەزدان بکە ڕزگارت دەکات.
\b
\q1 
\v 23 یەزدان قێزی لە بەکارهێنانی دوو کێشی جیاواز دەبێتەوە،
\q2 تەرازووی لاسەنگ باش نییە.
\b
\q1 
\v 24 هەنگاوەکانی مرۆڤ لە یەزدانەوەیە،
\q2 ئیتر مرۆڤ چۆن لە ڕێگای خۆی تێدەگات؟
\b
\q1 
\v 25 تەڵەیە بۆ مرۆڤ بە سەرەڕۆیی نەزرێک تەرخان بکات،
\q2 ئینجا پاش نەزرەکە پرسوڕا بکات.
\b
\q1 
\v 26 پاشای دانا بەدکاران شەن دەکات،
\q2 بە جەنجەڕ بەسەریاندا دێت.
\b
\q1 
\v 27 چرای یەزدان ڕۆحی مرۆڤ دەپشکنێت،
\q2 هەروەها هەموو ناخی دەروونیش.
\b
\q1 
\v 28 خۆشەویستی نەگۆڕ و دڵسۆزی پاشا دەپارێزن،
\q2 بە خۆشەویستی نەگۆڕ تەختی دەچەسپێت.
\b
\q1 
\v 29 شانازی لاوان هێزیانە،
\q2 ڕیش سپیێتیش شکۆمەندی پیرانە.
\b
\q1 
\v 30 برینی لێدان خراپە پاک دەکاتەوە،
\q2 لێدانی قامچیش ناخی دەروون.
\b
\c 21
\q1 
\v 1 دڵی پاشا لەناو دەستی یەزدان جۆگەی ئاوە،
\q2 بۆ کوێ بیەوێت ئاراستەی دەکات.
\b
\q1 
\v 2 هەموو ڕێگاکانی مرۆڤ لەبەرچاوی خۆی ڕاستە،
\q2 بەڵام یەزدان دڵەکان هەڵدەسەنگێنێت.
\b
\q1 
\v 3 کارکردن بە ڕاستودروستی و دادپەروەری
\q2 لەلای یەزدان لە قوربانی سەربڕین پەسەندترە.
\b
\q1 
\v 4 چاوی بەفیز و دڵی لەخۆبایی،
\q2 ئەمانە چرای بەدکارانن و گوناهن.
\b
\q1 
\v 5 بێگومان پلانی مرۆڤی تێکۆشەر بەرەو پڕییە،
\q2 هەموو هەڵەشەییەکیش بەرەو نەبوونییە.
\b
\q1 
\v 6 کۆکردنەوەی سامان بە زمانی درۆ
\q2 هەڵمە دەڕەوێتەوە و تەڵەی مردنە.
\b
\q1 
\v 7 زۆرداری بەدکارەکان ڕایاندەماڵێت،
\q2 چونکە ڕەتیان کردەوە دادپەروەری بکەن.
\b
\q1 
\v 8 ڕێگای پیاوی تاوانبار خوارە،
\q2 بەڵام کەسی پاک کرداری ڕاستە.
\b
\q1 
\v 9 باشترە لە گۆشەی سەربانێک نیشتەجێ بیت،
\q2 نەک ماڵێکی هاوبەش لەگەڵ ژنێکی شەڕانی.
\b
\q1 
\v 10 کەسی بەدکار ئارەزووی خراپە دەکات،
\q2 دراوسێکەی بەزەیی لێی نابینێت.
\b
\q1 
\v 11 بە سزادانی گاڵتەجاڕ ساویلکە دانا دەبێت،
\q2 بە فێرکردنی داناش زانیاری وەردەگرێت.
\b
\q1 
\v 12 خودای ڕاستودروست سەرنج دەداتە ماڵی خراپەکار،
\q2 خراپەکاران لە خراپە سەرەوژێر دەکات.
\b
\q1 
\v 13 ئەوەی گوێی خۆی لە هاواری هەژاران کەڕ بکات،
\q2 ئەویش هاوار دەکات و وەڵام نادرێتەوە.
\b
\q1 
\v 14 دیاری بە نهێنی تووڕەیی سارد دەکاتەوە،
\q2 بەرتیلی ناو باخەڵیش هەڵچوونی توند.
\b
\q1 
\v 15 ئەنجامدانی دادپەروەری دڵخۆشی ڕاستودروستانە،
\q2 بەڵام تۆقاندنی بەدکارانە.
\b
\q1 
\v 16 پیاو لە ڕێگای وریایی وێڵ بێت
\q2 لەناو کۆمەڵی مردووان پاڵدەداتەوە.
\b
\q1 
\v 17 ئەوەی حەزی لە ڕابواردن بێت هەژار دەبێت،
\q2 ئەوەی حەز لە شەراب و ڕۆن بکات دەوڵەمەند نابێت.
\b
\q1 
\v 18 بەدکار دەبێتە قوربانی بۆ کەسی ڕاستودروست،
\q2 ناپاکانیش بۆ سەرڕاستان.
\b
\q1 
\v 19 باشترە لە چۆڵەوانی نیشتەجێ بیت،
\q2 نەک لەگەڵ ئافرەتێکی شەڕانی و تووڕە.
\b
\q1 
\v 20 گەنجینەی خۆراکی باش و ڕۆن لە ماڵی کەسی دانا هەیە،
\q2 بەڵام کەسی گێل هەڵدەلووشێت.
\b
\q1 
\v 21 ئەوەی دوای ڕاستودروستی و خۆشەویستی نەگۆڕ بکەوێت،
\q2 ژیان و ڕاستودروستی و ڕێزداری دەدۆزێتەوە.
\b
\q1 
\v 22 پیاوی دانا بە شاری پاڵەوانەکاندا هەڵدەگەڕێت و
\q2 قەڵا پشتبەستەکەیان وێران دەکات.
\b
\q1 
\v 23 ئەوەی دەم و زمانی خۆی بپارێزێت،
\q2 خۆی لە تەنگانە دەپارێزێت.
\b
\q1 
\v 24 لووتبەرز و لەخۆبایی بە گاڵتەجاڕ ناودەبردرێت،
\q2 بە لێشاوی لووتبەرزییەوە ڕەفتار دەکات.
\b
\q1 
\v 25 ئارەزووی کەسی تەمبەڵ دەیکوژێت،
\q2 چونکە دەستەکانی ئیش ڕەت دەکەنەوە،
\q1 
\v 26 بە درێژایی ڕۆژ تامەزرۆی ئارەزووە،
\q2 بەڵام کەسی ڕاستودروست دەبەخشێت و دەستی پێوە ناگرێت.
\b
\q1 
\v 27 قوربانی بەدکاران قێزەونە،
\q2 لەوەش زیاتر ئەگەر بە نیازێکی خراپەوە بیکات!
\b
\q1 
\v 28 شایەتی درۆزن لەناودەچێت،
\q2 بەڵام شایەتیی گوێگری وریا دەچەسپێت.
\b
\q1 
\v 29 پیاوی بەدکار ناوچەوانی خۆی گرژ دەکات،
\q2 بەڵام سەرڕاست ئاگای لە ڕێگای خۆیەتی.
\b
\q1 
\v 30 دانایی و تێگەیشتن و ڕاوێژ نییە
\q2 لە دژی یەزدان سەربکەوێت.
\b
\q1 
\v 31 ئەسپ ئامادەیە بۆ ڕۆژی جەنگ،
\q2 بەڵام ڕزگاری لە یەزدانەوەیە.
\b
\c 22
\q1 
\v 1 ناوبانگی چاک لە دەوڵەمەندی گەورە خوازراوترە،
\q2 ڕێزیش لە زێڕ و زیو باشترە.
\b
\q1 
\v 2 دەوڵەمەند و هەژار لەمەدا یەکدەگرنەوە،
\q2 دروستکەری هەردووکیان یەزدانە.
\b
\q1 
\v 3 ژیر خراپە دەبینێت و خۆی دەشارێتەوە،
\q2 بەڵام ساویلکە مل پێوەدەنێت و سزا دەدرێ.
\b
\q1 
\v 4 پاداشتی بێفیزی و لەخواترسی
\q2 دەوڵەمەندی و ڕێزداری و ژیانە.
\b
\q1 
\v 5 چقڵ و تەڵە لە ڕێگای پیاوی خواردایە،
\q2 بەڵام ئەوەی خۆی بپارێزێت لێی دوور دەکەوێتەوە.
\b
\q1 
\v 6 منداڵ لەسەر ئەو ڕێگایە ڕابهێنە کە پێویستە بیگرێت،
\q2 پیریش بێت لێی لا نادات.
\b
\q1 
\v 7 دەوڵەمەند بەسەر هەژاردا حوکم دەکات،
\q2 قەرزاریش کۆیلەی خاوەن قەرزە.
\b
\q1 
\v 8 ئەوەی ناڕەوایی بچێنێت دروێنەی خراپە دەکات،
\q2 کوتەکی تووڕەییشی دەفەوتێت.
\b
\q1 
\v 9 ئەوەی چاوتێر بێت بەرەکەتدار دەبێت،
\q2 چونکە لە نانی خۆی دەداتە هەژار.
\b
\q1 
\v 10 گاڵتەجاڕ دەربکە، ناکۆکی دەڕوات،
\q2 دووبەرەکی و ڕیسواییش نامێنێت.
\b
\q1 
\v 11 ئەوەی حەزی لە دڵپاکی بێت و قسەی شیرین بێت،
\q2 پاشا دەبێتە دۆستی.
\b
\q1 
\v 12 چاوی یەزدان چاودێری زانیاری دەکات،
\q2 بەڵام قسەی ناپاکان سەرەوژێر دەکات.
\b
\q1 
\v 13 تەمبەڵ دەڵێت: «شێرێک لە دەرەوەیە!
\q2 ئەگەر بچمە گۆڕەپانەکان دەکوژرێم!»
\b
\q1 
\v 14 دەمی ژنی بەدڕەوشت چاڵێکی قووڵە،
\q2 ئەوەی بەر تووڕەیی یەزدان بکەوێت دەکەوێتە ناوی.
\b
\q1 
\v 15 گێلی بە دڵی منداڵەوە گرێدراوە،
\q2 بەڵام گۆچانی تەمبێکردن دووری دەخاتەوە لێی.
\b
\q1 
\v 16 ئەوەی زۆرداری لە هەژار بکات بۆ ئەوەی بۆ خۆی زیاد بکات و
\q2 ئەوەی بە دەوڵەمەند ببەخشێت، بێگومان هەردووکیان بەرەو نەبوونییە.
\s1 قسەی دانایان
\q1 
\v 17 گوێ شل بکە و قسەی دانایان ببیستە،
\q2 دڵت بدە زانیاری من،
\q1 
\v 18 چونکە جوانە ئەگەر لە ناختدا هەڵیبگریت و
\q2 تێکڕا لەسەر لێوەکانت بچەسپێن.
\q1 
\v 19 بۆ ئەوەی پشتبەستنت بە یەزدان بێت،
\q2 ئەمڕۆ تۆ فێر دەکەم، بەڵێ تۆ.
\q1 
\v 20 ئایا سی پەندم بۆ نەنووسیوی
\q2 سەبارەت بە ڕاوێژ و زانیاری،
\q1 
\v 21 بۆ ئەوەی دروستی قسەی ڕاستیت فێر بکەم،
\q2 هەتا وەڵامە ڕاستییەکان بدەیتەوە ئەوانەی کە تۆیان ناردووە؟
\b
\q1 
\v 22 هەژار تاڵان مەکە لەبەر هەژارییەکەی و
\q2 نەبوون وردوخاش مەکە لە دادگا،
\q1 
\v 23 چونکە یەزدان بەرگری لە کێشەکەیان دەکات و
\q2 ئەوانەی تاڵانیان دەکەن گیانیان تاڵان دەکات.
\b
\q1 
\v 24 مەبە برادەری کەسی تووڕە،
\q2 هاوڕێیەتی کەسی هەڵچوو مەکە،
\q1 
\v 25 نەوەک لە ڕێچکەی ئەوان ڕابێیت،
\q2 خۆت تووشی تەڵە بکەیت.
\b
\q1 
\v 26 لەوانە مەبە کە تەوقە دەکەن\f + \fr 22:26 \ft تەوقەکردن بە مەبەستی ڕێککەوتن بەبێ هیچ بەڵگەنامەیەک.‏\f*،
\q2 دەستەبەری قەرزی خەڵک مەکە.
\q1 
\v 27 ئەگەر نەتبوو بیدەیتەوە،
\q2 بۆچی نوێنەکەی ژێرت ببردرێت.
\b
\q1 
\v 28 سنووری کۆن مەگوازەوە،
\q2 ئەوەی باوباپیرانت دایانناوە.
\b
\q1 
\v 29 ئایا ئەو کەسەت بینیوە بە دەستوبردە لە کارەکەی؟
\q2 لەبەردەم پاشاکان ڕادەوەستێت\f + \fr 22:29 \ft کارکردن لەنێو دەستەی خزمەتکارانی پاشا.‏\f*،
\q2 نەک لەبەردەم خەڵکی بێ ناوبانگ.
\c 23
\q1 
\v 1 کە دانیشتی لەگەڵ فەرمانڕەوایەک نان بخۆیت،
\q2 باش وردبەرەوە لەوەی لەپێشتە،
\q1 
\v 2 چەقۆیەکیش لەناو گەرووت دابنێ،
\q2 ئەگەر تۆ نەوسنی.
\q1 
\v 3 ئارەزووی خواردنە خۆشەکانی مەکە،
\q2 چونکە ئەم نانە بە مەبەستی هەڵخەڵەتاندنە.
\b
\q1 
\v 4 خۆت ماندوو مەکە بۆ ئەوەی دەوڵەمەند بیت،
\q2 بە تێگەیشتنەوە وازی لێ بهێنە.
\q1 
\v 5 چاو لە دەوڵەمەندی دەبڕیت و نییە،
\q2 چونکە بێگومان باڵ دەگرێت،
\q2 وەک هەڵۆ بەرەو ئاسمان دەفڕێت.
\b
\q1 
\v 6 نانی کەسی بەرچاوتەنگ مەخۆ،
\q2 ئارەزووی خواردنە خۆشەکانی مەکە.
\q1 
\v 7 لەبەر ئەوەی جۆرە کەسێکە
\q2 هەردەم بیری لەلای تێچوونەکانە،
\q1 پێت دەڵێت: «بخۆ و بنۆشە.»
\q2 بەڵام دڵی لەگەڵت نییە.
\q1 
\v 8 ئەو پارووەی خواردووتە دەیڕشێنیتەوە و
\q2 قسە شیرینەکانت بە با دەدەیت.
\b
\q1 
\v 9 قسە بۆ گێل مەکە،
\q2 چونکە گاڵتەی بە دانایی قسەکانت دێت.
\q1 
\v 10 سنوورە کۆنەکان مەگوازەوە،
\q2 هەروەها مەچووە ناو کێڵگەی هەتیوان،
\q1 
\v 11 چونکە ئەوەی دەیانپارێزێت بە توانایە،
\q2 ئەو بەرگری لە کێشەکەیان دەکات لە دژی تۆ.
\b
\q1 
\v 12 دڵت ئاراستەی فێربوون بکە و
\q2 گوێشت بەرەو قسەی زانیاری.
\b
\q1 
\v 13 ڕێگری لە تەمبێکردنی منداڵ مەکە،
\q2 ئەگەر بە گۆچان لێی بدەیت نامرێت.
\q1 
\v 14 تۆ بە گۆچان لێی بدەیت،
\q2 گیانی لە مردن دەرباز دەبێت.
\b
\q1 
\v 15 ڕۆڵە، ئەگەر دڵت دانایە،
\q2 منیش دڵم خۆش دەبێت.
\q1 
\v 16 ناخم شادمان دەبێت،
\q2 کە لێوەکانت ڕاستییەکان دەڵێن.
\b
\q1 
\v 17 دڵت ئیرەیی بە گوناهباران نەبات،
\q2 بەڵکو بە درێژایی ڕۆژ بە پەرۆش بە بۆ لەخواترسی.
\q1 
\v 18 بێگومان دواڕۆژت دەبێت،
\q2 ئومێدی تۆ نابڕێت.
\b
\q1 
\v 19 ڕۆڵە، تۆ گوێ بگرە و دانا بە،
\q2 دڵت بەرەو ڕێگای ڕاستی ئاراستە بکە.
\q1 
\v 20 لەوانە مەبە کە شەراب زۆر دەخۆنەوە،
\q2 یان ئەوانەی گۆشت زۆر دەخۆن،
\q1 
\v 21 چونکە مەیخۆر و زۆر خۆر هەژار دەبن،
\q2 ئەوەی زۆر بخەوێت پینەوپەڕۆ لەبەر دەکات.
\b
\q1 
\v 22 گوێ لە باوکت بگرە کە تۆی خستووەتەوە،
\q2 دایکت کە پیر بوو گاڵتەی پێ مەکە.
\q1 
\v 23 ڕاستی بکڕە و مەیفرۆشە،
\q2 هەروەها دانایی و تەمبێکردن و تێگەیشتن.
\q1 
\v 24 باوکی کەسی ڕاستودروست زۆر دڵخۆش دەبێت،
\q2 ئەوەی کوڕێکی دانای ببێت پێی شادمان دەبێت.
\q1 
\v 25 با دایک و باوکت شادمان بن،
\q2 ئەوەی تۆی بووە دڵخۆش بێت.
\b
\q1 
\v 26 ڕۆڵە، دڵی خۆتم بدەرێ،
\q2 با چاوەکانت لەسەر ڕێگاکانم بێت،
\q1 
\v 27 چونکە لەشفرۆش چاڵێکی قووڵە و
\q2 ژنی داوێنپیس بیرێکی تەنگە.
\q1 
\v 28 تەنانەت ئەویش وەک چەتە لە بۆسەدا دەبێت،
\q2 ناپاک\f + \fr 23:28 \ft ناپاکی هاوسەریێتی.‏\f* لەنێو خەڵک زۆر دەکات.
\b
\q1 
\v 29 واوەیلا بۆ کێیە؟ پەژارەیی بۆ کێیە؟
\q2 ناکۆکی بۆ کێیە؟ سکاڵاکردن بۆ کێیە؟
\q2 برینی بەخۆڕایی بۆ کێیە؟ چاو سووربوونەوە بۆ کێیە؟
\q1 
\v 30 بۆ ئەوانەی بە دیار شەرابەوە لەنگەر دەگرن،
\q2 ئەوانەی شەرابی تێکەڵاو تاقی دەکەنەوە.
\q1 
\v 31 تەماشای شەراب مەکە بە ڕەنگی سووری،
\q2 کە لەناو جام پڕشنگی داوە،
\q2 بە سووکی دەچێتە خوارەوە!
\q1 
\v 32 لە کۆتاییەکەی وەک مار دەتگەزێت و
\q2 وەک توولەمار پێتەوەدەدات.
\q1 
\v 33 چاوەکانت شتی نامۆ دەبینن و
\q2 وڕێنەی سەیر و سەمەرە دەکەیت.
\q1 
\v 34 وەک یەکێک دەبیت لەناو دڵی دەریا پاڵکەوتبێت،
\q2 یان وەک یەکێک بەسەر دارئاڵای کەشتییەوە پاڵکەوتبێت.
\q1 
\v 35 دەڵێی: «لێیان دام، ئازارم نەبوو!
\q2 کوتامیان، نەمزانی!
\q1 کەی بە هۆش خۆم دێمەوە،
\q2 هەتا بەردەوام بم و بخۆمەوە؟»
\b
\c 24
\q1 
\v 1 ئیرەیی بە پیاوخراپان مەبە،
\q2 ئارەزوو مەکە لەگەڵیاندا بیت،
\q1 
\v 2 چونکە دڵیان پیلانی زۆرداری دەکێشێت و
\q2 لێوەکانیان باسی گرفتنانەوە دەکەن.
\b
\q1 
\v 3 بە دانایی ماڵ بنیاد دەنرێت،
\q2 بە تێگەیشتنیش دەچەسپێت،
\q1 
\v 4 بە زانیاریش ژوورەکان پڕ دەبن
\q2 لە هەموو گەنجینەیەکی بە نرخ و جوان.
\b
\q1 
\v 5 پیاوی دانا بەتوانایە،
\q2 کەسی زانا هێزی زیاد دەبێت.
\q1 
\v 6 بێگومان بە ڕاوێژەوە شەڕ دەکەیت،
\q2 سەرکەوتنیش بە زۆری ئامۆژگارانە.
\b
\q1 
\v 7 دانایی بەرزە بۆ گێل،
\q2 لە کۆڕی ناو دەروازەدا\f + \fr 24:7 \ft مەبەست لە کۆڕی خەڵکی شارە بۆ گفتوگۆ سەبارەت بە پرسە گرنگەکان.‏\f* دەمی لێک ناکاتەوە.
\b
\q1 
\v 8 ئەوەی بیر لە خراپە بکاتەوە،
\q2 بە تەڵەکەباز ناودەبردرێت.
\q1 
\v 9 پیلانی گێلایەتی گوناهە،
\q2 خەڵک قێزیان لە گاڵتەجاڕە.
\b
\q1 
\v 10 ئەگەر ورە بەردەیت لە ڕۆژی تەنگانە،
\q2 بێ هێزیت!
\b
\q1 
\v 11 ئەوانە دەرباز بکە کە بۆ مردن دەبردرێن و
\q2 لەوانەی بۆ سەربڕین پاڵخراون، کەمتەرخەم مەبە.
\q1 
\v 12 ئەگەر بڵێی: «ئەوەتا ئەمەم نەزانیوە،»
\q2 ئایا هەڵسەنگێنەری دڵەکان تێناگات؟
\q1 ئەوەی گیانت دەپارێزێت ئایا نازانێت؟
\q2 ئایا سزای مرۆڤ بەپێی کردەوەکانی ناداتەوە؟
\b
\q1 
\v 13 ڕۆڵە، هەنگوین بخۆ، چونکە باشە و
\q2 شیلەی هەنگوین لە گەرووت شیرینە،
\q1 
\v 14 هەروەها بزانە دانایی بۆ گیانت بەم جۆرەیە.
\q2 ئەگەر دانایی بدۆزیتەوە دواڕۆژت دەبێت و
\q2 ئومێدبڕ نابیت.
\b
\q1 
\v 15 وەک خراپەکار خۆت مەڵاس مەدە بۆ ماڵی کەسی ڕاستودروست،
\q2 هەڵمەکوتە سەر جێی حەسانەوەی،
\q1 
\v 16 چونکە کەسی ڕاستودروست حەوت جار دەکەوێت و هەڵدەستێتەوە،
\q2 بەڵام کارەسات بەدکاران تێکدەشکێنێت.
\b
\q1 
\v 17 بە ساتمەکردنی دوژمنت شاد مەبە،
\q2 بە کەوتنیشی دڵت خۆش نەبێت،
\q1 
\v 18 نەوەک یەزدان ببینێت و بەلایەوە خراپ بێت،
\q2 جا تووڕەیی خۆی لێ بگێڕێتەوە.
\b
\q1 
\v 19 مەراق لە خراپەکاران مەخۆ،
\q2 ئیرەیی بە بەدکاران مەبە،
\q1 
\v 20 چونکە خراپەکار دواڕۆژی نابێت و
\q2 چرای بەدکاران دەکوژێتەوە.
\b
\q1 
\v 21 ڕۆڵە، لە یەزدان و پاشا بترسە،
\q2 تێکەڵی یاخیبووەکان مەبە،
\q1 
\v 22 چونکە بەڵایان لەپڕ دێت،
\q2 بەڵای هەردووکیان کێ دەیزانێت؟
\s1 قسەی دیکەی دانایان
\p 
\v 23 هەروەها ئەمەش قسەی دانایانە:
\q1 لایەنگریکردن لە دادوەری باش نییە.
\q1 
\v 24 ئەوەی بە بەدکار بڵێت: «تۆ بێتاوانی،»
\q2 گەلان نەفرەتی لێ دەکەن و نەتەوەکان تاوانباری دەکەن.
\q1 
\v 25 بەڵام ئەوانەی بەدکار تاوانبار دەکەن دەکەونە خۆشی و
\q2 بەرەکەتی باشیان بەسەردا دەڕژێت.
\b
\q1 
\v 26 وەڵامی ڕاست
\q2 وەک ماچی لێوە.
\b
\q1 
\v 27 کاروباری خۆت لە دەرەوە ڕاپەڕێنە و
\q2 لە کێڵگەکەت ئامادەی بکە،
\q2 دوای ئەمە ماڵی خۆت بنیاد بنێ.
\b
\q1 
\v 28 بەبێ هۆ لە دژی دراوسێکەت شایەتی مەدە،
\q2 بە لێوەکانت فێڵ مەکە.
\q1 
\v 29 مەڵێ: «چی لێکردووم، ئاوای لێ دەکەم،
\q2 سزای ئەو پیاوە بەپێی کردەوەکەی دەدەمەوە.»
\b
\q1 
\v 30 بەلای کێڵگەی پیاوی تەمبەڵ تێپەڕیم،
\q2 بەلای ڕەزەمێوی کەسی تێنەگەیشتووش.
\q1 
\v 31 چقڵ هەمووی داگرتبوو،
\q2 گەزگەزکە هەمووی داپۆشی بوو،
\q2 کەڵەکە بەردەکانی ڕووخابوو.
\q1 
\v 32 تەماشام کرد و لە دڵی خۆمدا لێکم دایەوە،
\q2 بینیم و وانەم لێ وەرگرت:
\q1 
\v 33 کەمێک خەوتن، کەمێک خەواڵووبوون،
\q2 کەمێکیش دەست تێکنان بۆ ڕاکشان،
\q1 
\v 34 ئینجا هەژاریت وەک چەتە دێت،
\q2 نەبوونیشت وەک چەکدار.
\c 25
\s1 پەندەکانی دیکەی سلێمان
\p 
\v 1 ئەمانەش هەر پەندی سلێمانن کە پیاوەکانی حەزقیای پاشای یەهودا نووسیویانەتەوە:
\q1 
\v 2 شکۆمەندیی خودا لە شاردنەوەی بابەتدایە،
\q2 شکۆمەندیی پاشایانیش لە لێکۆڵینەوەی بابەتدایە.
\q1 
\v 3 هەروەک ئاسمان بۆ بەرزییە و زەوی بۆ قووڵییە،
\q2 دڵی پاشایانیش ناپشکنرێت.
\b
\q1 
\v 4 خڵت لە زیو داماڵە،
\q2 ئەو کاتە دەتوانرێت کەرەستەی لێ دروستبکرێت.
\q1 
\v 5 بەدکار لەبەردەم پاشا داماڵە،
\q2 بە ڕاستودروستی تەختەکەی دەچەسپێت.
\b
\q1 
\v 6 لەبەردەم پاشا خۆت بەرز مەکەرەوە،
\q2 لە شوێنی گەورە پیاوان ڕامەوەستە.
\q1 
\v 7 وا چاکترە پێت بگوترێت: «سەربکەوە بۆ ئێرە،»
\q2 نەک لەلای میر تەریق بیتەوە.
\b
\q1 ئەوەی بە چاوی خۆت بینیت،
\q2 
\v 8 خێرا مەیبە بۆ دادگا،
\q1 چونکە لە کۆتاییەکەی چی دەکەیت
\q2 ئەگەر دراوسێکەت شەرمەزاری کردیت؟
\b
\q1 
\v 9 کە باسی کێشەکەت دەکەیت لەگەڵ دراوسێکەت،
\q2 نهێنی خەڵکی دیکە مەدرکێنە،
\q1 
\v 10 نەوەک گوێگرێک شەرمەزارت بکات،
\q2 جا ناوە زڕاوەکەت لێ نابێتەوە.
\b
\q1 
\v 11 سێوێکی زێڕە و لە زیو گیراوە،
\q2 ئەو قسەیەی لە کاتی خۆیدا دەکرێت.
\q1 
\v 12 وەک گوارەی زێڕە و خشڵی زێڕی بێگەردە،
\q2 سەرزەنشتی دانا بۆ گوێی بیسەر.
\b
\q1 
\v 13 وەک ساردی بەفرە لە ڕۆژی دروێنەدا،
\q2 نوێنەری دەستپاک بۆ ئەوانەی دەینێرن،
\q2 دڵی گەورەکانی فێنک دەکاتەوە.
\q1 
\v 14 هەور و بای بێ بارانە،
\q2 ئەوەی شانازی بە دیاری بکات و نەیبەخشێت.
\b
\q1 
\v 15 بە نەسرەوتن فەرمانڕەوا قایل دەکرێت،
\q2 زمانی نەرمیش ئێسک دەشکێنێت.
\b
\q1 
\v 16 ئەگەر هەنگوینت دۆزییەوە بەگوێرەی پێویست بیخۆ،
\q2 ئەگینا پڕ دەبیت و دەیڕشێنیتەوە.
\q1 
\v 17 بە کەمی پێت لە ماڵی دراوسێکەت دابنێ،
\q2 ئەگینا لێت تێر دەبێت و ڕقی لێت دەبێتەوە.
\b
\q1 
\v 18 وەک کوتەک و شمشێر و تیری تیژە،
\q2 ئەوەی شایەتی درۆ لەسەر دراوسێکەی بدات.
\q1 
\v 19 وەک ددانی کلۆر و قاچی لەجێ چووە،
\q2 پشتبەستن بە ناپاک لە ڕۆژی تەنگانەدا.
\q1 
\v 20 وەک داکەندنی بەرگ لە ڕۆژی سەرمادا،
\q2 یان سرکەیە بەسەر سۆدەدا،\f + \fr 25:20 \ft لە تێکەڵکردنی سرکە و سۆدەدا کارلێکی کیمیایی ڕوودەدات، هەڵدەچێت و ئۆکسجینی لێ دەردەچێت.‏\f*
\q2 چڕینی گۆرانی بۆ دڵتەنگ.
\b
\q1 
\v 21 ئەگەر دوژمنەکەت برسی بوو نانی دەرخوارد بدە،
\q2 ئەگەر تینووی بوو ئاوی بدەرێ.
\q1 
\v 22 بەمە پشکۆ لەسەر سەری کەڵەکە دەکەیت،\f + \fr 25:22 \ft بەم کارە شەرمەزار دەبێت و پەشیمانی دەکەیتەوە.‏\f*
\q2 یەزدانیش پاداشتت دەداتەوە.
\b
\q1 
\v 23 بای باکوور باران دەهێنێت،
\q2 زمانی پاشملەش ڕووی گرژ.
\b
\q1 
\v 24 باشترە لە گۆشەی سەربانێک نیشتەجێ بیت،
\q2 نەک ماڵێکی هاوبەش لەگەڵ ژنێکی شەڕانی.
\b
\q1 
\v 25 وەک ئاوی ساردە بۆ گیانێکی شەکەت،
\q2 هەواڵی خۆش لە وڵاتێکی دوور.
\q1 
\v 26 وەک کانییەکی لێڵ و بیرێکی بۆگەنە،
\q2 ئەو کەسە ڕاستودروستەی لەبەردەم بەدکار کۆڵ دەدات.
\b
\q1 
\v 27 زۆر خواردنی هەنگوین باش نییە،
\q2 ڕێزدار نابێت ئەوەی داوای ڕێزلێنان بۆ خۆی دەکات.
\b
\q1 
\v 28 وەک شارێکی ڕووخاوی بێ شوورایە،
\q2 ئەو پیاوەی بەسەر خۆیدا زاڵ نەبێت.
\c 26
\q1 
\v 1 وەک بەفر لە هاوین و باران لە کاتی دروێنەدا،
\q2 ئاواش ڕێزلێنان لە گێل ناوەشێتەوە.
\q1 
\v 2 وەک چۆلەکەی فڕیو و پەڕەسێلکەی باڵگرتوو،
\q2 ئاواشە نەفرەت بەبێ هۆ نایێت.
\q1 
\v 3 قامچی بۆ ئەسپ و لغاو بۆ گوێدرێژە،
\q2 کوتەکیش بۆ پشتی گێلەکانە.
\q1 
\v 4 وەڵامی گێل مەدەوە بەپێی گێلایەتییەکەی،
\q2 نەوەک تۆش وەک ئەوت لێ بێت.
\q1 
\v 5 وەڵامی گێل بدەوە بەپێی گێلایەتییەکەی،
\q2 نەوەک لەبەرچاوی خۆی ببێت بە دانا.
\q1 
\v 6 وەک بڕینەوەی قاچەکانی خۆیەتی و نۆشینی ستەمە،
\q2 ئەوەی بە دەستی گێل پەیام بنێرێت.
\q1 
\v 7 وەک شۆڕبوونەوەی قاچەکانی گۆجە،
\q2 پەند لە دەمی گێلەکان.
\q1 
\v 8 وەک گرێدانی بەرد بە بەردەقانییەوە،
\q2 ئەوەی ڕێز لە گێل دەگرێت.
\q1 
\v 9 وەک دڕکە لە دەستی سەرخۆش،
\q2 پەند لە دەمی گێلەکان.
\q1 
\v 10 وەک تیرهاوێژێکە کوێرانە لە خەڵک بگرێت،
\q2 بەکرێگری گێل و ڕێبوار.
\q1 
\v 11 وەک سەگ بگەڕێتەوە سەر ڕشانەوەکەی،
\q2 گێلیش گێلایەتییەکەی دووبارەی دەکاتەوە.
\q1 
\v 12 کەست بینیوە لەبەرچاوی خۆی دانا بێت؟
\q2 گێل لەو زیاتر ئومێدی پێ دەکرێت.
\b
\q1 
\v 13 تەمبەڵ دەڵێت: «شێر لەسەر ڕێگایە،
\q2 نەڕەشێر لەنێو گۆڕەپانەکانە.»
\q1 
\v 14 دەرگا لەسەر ڕێزە دەسووڕێتەوە،
\q2 تەمبەڵیش لەناو نوێنەکەی.
\q1 
\v 15 تەمبەڵ دەست دەخاتە ناو قاپ،
\q2 زەحمەتە بۆی بیباتە ناو دەمی.
\q1 
\v 16 تەمبەڵ لەبەرچاوی خۆی داناترە لە حەوت کەس
\q2 کە وەڵامی ژیرانە دەدەنەوە.
\b
\q1 
\v 17 وەک گرتنی سەگێکە بە گوێیەکانی
\q2 ئەوەی ڕێبوارە و خۆی دەخاتە ناو ناکۆکییەکەوە کە هی ئەو نییە.
\b
\q1 
\v 18 وەک شێتێک
\q2 پشکۆ و تیری مەرگ بهاوێژێت،
\q1 
\v 19 ئاوایە ئەوەی فێڵ لە دراوسێکەی بکات و
\q2 بڵێت: «تەنها گاڵتەم کرد!»
\b
\q1 
\v 20 دار نەبێت ئاگر دەکوژێتەوە،
\q2 دەمشڕ نەبێت دووبەرەکی نامێنێت.
\q1 
\v 21 خەڵووز بۆ پشکۆ و دار بۆ ئاگرە،
\q2 پیاوی شەڕانگێزیش بۆ ورووژاندنی ناکۆکییە.
\q1 
\v 22 قسەکانی دەمشڕ وەک پارووی بەتامە،
\q2 شۆڕ دەبێتەوە ناو ورگ.
\b
\q1 
\v 23 وەک گۆزەی گڵینی داپۆشراوە بە خڵتی زیو
\q2 قسەی شیرین لە دڵێکی خراپەوە.
\q1 
\v 24 قین لە دڵ بە لێوەکانی خۆی دەشارێتەوە،
\q2 بەڵام لە ناخیدا فڕوفێڵ دادەنێتەوە.
\q1 
\v 25 ئەگەر قسەی شیرینی کرد باوەڕی پێ مەکە،
\q2 چونکە حەوت شتی قێزەون لە دڵیدایە.
\q1 
\v 26 هەرچەندە بە فێڵ قینی خۆی بشارێتەوە،
\q2 خراپەی لەناو کۆمەڵدا ئاشکرا دەبێت.
\q1 
\v 27 ئەوەی چاڵێک هەڵکەنێت خۆی تێی دەکەوێت،
\q2 ئەوەی بەردێک گلۆر بکاتەوە بەرەو خۆی دەگەڕێتەوە.
\q1 
\v 28 زمانی درۆ ڕقی لەوانە دەبێتەوە کە برینداریان دەکات،
\q2 زمانی لووسیش وێرانکاری دەکات.
\b
\c 27
\q1 
\v 1 شانازی بە سبەینێ مەکە،
\q2 چونکە نازانی ڕۆژ چی لێ دەکەوێتەوە.
\b
\q1 
\v 2 با نامۆ ستایشت بکات نەک دەمی خۆت،
\q2 بێگانە نەک لێوەکانت.
\b
\q1 
\v 3 بەرد قورسە و لم بە سەنگە،
\q2 بەڵام تووڕەیی گێل لە هەردووکیان قورسترە.
\b
\q1 
\v 4 هەڵچوون توندوتیژە و تووڕەیی لێشاوە،
\q2 بەڵام کێ لەبەردەم ئیرەیی خۆ ڕادەگرێت؟
\b
\q1 
\v 5 سەرزەنشتی ئاشکرا
\q2 لە خۆشەویستی شاردراوە باشترە.
\b
\q1 
\v 6 برینی دۆست دڵسۆزییە،
\q2 بەڵام ماچی دوژمن بە فێڵە.
\b
\q1 
\v 7 کەسی تێر پێ لە هەنگوین دەنێت،
\q2 بەڵام بۆ برسی هەموو تاڵێتییەک شیرینە.
\b
\q1 
\v 8 وەک چۆلەکەی وێڵبوو لە هێلانەکەی،
\q2 ئاوایە مرۆڤی وێڵ لە هەواری خۆی.
\b
\q1 
\v 9 بۆن و بخورد دڵ خۆش دەکەن،
\q2 شیرینی برادەریش لە پەرۆشی ڕاوێژە.
\b
\q1 
\v 10 واز لە برادەرەکانی خۆت و باوکت مەهێنە،
\q2 لە ڕۆژی لێقەومانت مەچووە ماڵی برات،
\q2 دراوسێی نزیک لە برای دوور باشترە.
\b
\q1 
\v 11 ڕۆڵە، دانا بە و دڵم خۆش بکە،
\q2 بۆ ئەوەی وەڵامی ئەوانە بدەمەوە کە لۆمەم دەکەن.
\b
\q1 
\v 12 ژیر خراپە دەبینێت و خۆی دەشارێتەوە،
\q2 بەڵام ساویلکە مل پێوەدەنێت و سزا دەدرێ.
\b
\q1 
\v 13 ئەگەر کەسێک بووە کەفیلی نامۆیەک کەواکەی لێ وەربگرە\f + \fr 27:13 \ft وەرگرتنی جلوبەرگ وەک بارمتە نەریت بووە.‏\f*،
\q2 لەبەر بێگانەکە بارمتەی لێ وەربگرە.
\b
\q1 
\v 14 ئەوەی بە دەنگی بەرز داوای بەرەکەت بۆ دراوسێکەی بکات لە بەیانی زوودا،
\q2 بە نەفرەت بۆی ئەژمارد دەکرێت.
\b
\q1 
\v 15 دڵۆپەکردنی بەردەوام لە ڕۆژی باران،
\q2 هەروەک ئافرەتی شەڕانییە.
\q1 
\v 16 ئەوەی دەستەمۆی بکات، با دەستەمۆ دەکات،
\q2 بە دەستی ڕاستی زەیت دەگرێت.
\b
\q1 
\v 17 ئاسن بە ئاسن تیژ دەکرێت و
\q2 مرۆڤیش ڕووی برادەرەکەی تیژ دەکات.\f + \fr 27:17 \ft کاریگەری لەسەر بەرامبەرەکەی دەبێت لە بیرکردنەوە و بڕیاردان.‏\f*
\b
\q1 
\v 18 ئەوەی چاودێری دار هەنجیرێک بکات بەرەکەی دەخوات،
\q2 ئەوەی گەورەکەی خۆی بپارێزێت ڕێزی دەگیرێت.
\b
\q1 
\v 19 وەک لە ئاودا وێنەدانەوەی ڕوو دەبینرێت،
\q2 ئاواش دڵی مرۆڤ وێنەی مرۆڤەکە دەداتەوە.
\b
\q1 
\v 20 جیهانی مردووان و لەناوچوون تێر نابن،
\q2 هەروەها چاوی مرۆڤیش تێر نابێت.
\b
\q1 
\v 21 بۆتە بۆ زیوە و کوورە بۆ زێڕ،
\q2 مرۆڤیش بە دەمی ستایشکەرەکەی تاقی دەکرێتەوە.
\b
\q1 
\v 22 هەرچەندە گێل لەناو هاون بکوتی،
\q2 لەگەڵ دانەوێڵە بە دەسکە هاون،
\q2 گێلایەتییەکەی لێی جیا نابێتەوە.
\b
\q1 
\v 23 باش حاڵی مێگەلەکانت بزانە،
\q2 دڵت هەر لەلای ڕانە مەڕەکانت بێت،
\q1 
\v 24 چونکە دەوڵەمەندی هەتاسەر نییە،
\q2 تاجیش نەوە بە نەوە بەردەوام نابێت.
\q1 
\v 25 کاتێک کا نامێنێت و گیا دەردەکەوێت،
\q2 گیاوگۆڵی شاخان کۆدەکرێنەوە،
\q1 
\v 26 بەرخەکان بۆ جلوبەرگ و
\q2 گیسکەکانیش بۆ نرخی کێڵگە.
\q1 
\v 27 بەپێی پێویست شیری بزنیشت دەبێت
\q2 کە بەشی خواردنی خۆت و خێزانەکەت و بژێوی کەنیزەکانت دەکات.
\b
\c 28
\q1 
\v 1 بەدکار بێ ئەوەی کەس ڕاوی بنێت هەڵدێت،
\q2 بەڵام ڕاستودروست وەک بەچکە شێر چاونەترسە.
\b
\q1 
\v 2 کە یاخیبوون لە خاکێک هەبێت میری زۆر دەبێت،
\q2 بەڵام فەرمانڕەوایەکی تێگەیشتوو و زانا نیشتیمان بەرقەرار دەکات.
\b
\q1 
\v 3 ئەو سەرکردەیەی هەژاران بچەوسێنێتەوە،
\q2 وەک بارانێکی بەخوڕە هیچ خۆراکێک ناهێڵێتەوە.
\b
\q1 
\v 4 ئەوانەی واز لە تەورات\f + \fr 28:4 \ft فێرکردن.‏\f* دەهێنن ستایشی بەدکار دەکەن،
\q2 بەڵام پارێزەرانی تەورات دژایەتییان دەکەن.
\b
\q1 
\v 5 پیاوخراپان لە دادپەروەری تێناگەن،
\q2 بەڵام ئەوانەی ڕوو لە یەزدان دەکەن تەواو تێدەگەن.
\b
\q1 
\v 6 باشترە هەژار ڕێگای تەواوەتی گرتبێت،
\q2 لە دەوڵەمەند کە ڕێگاکان خواردەکاتەوە.
\b
\q1 
\v 7 ئەوەی تەورات بپارێزێت کوڕێکی تێگەیشتووە،
\q2 بەڵام هاوڕێی دەستبڵاوان باوکی خۆی ڕیسوا دەکات.
\b
\q1 
\v 8 ئەوەی بە سوو و بازاڕگرانکردن سامانی خۆی زۆر بکات،
\q2 بۆ یەکێکی کۆدەکاتەوە کە بەزەیی بە نەداران دێتەوە.
\b
\q1 
\v 9 ئەوەی گوێی دابخات لە بیستنی فێرکردنەکەم،
\q2 تەنانەت نوێژەکەشی قێزەونە.
\b
\q1 
\v 10 ئەوەی سەرڕاستان بەرەو ڕێگای خراپە ببات،
\q2 دەکەوێتە ئەو چاڵەوە کە خۆی هەڵیکەندووە،
\q2 بەڵام ئەوانەی کە بێ کەموکوڕین میراتی باشیان بەردەکەوێت.
\b
\q1 
\v 11 دەوڵەمەند لەبەرچاوی خۆی دانایە،
\q2 بەڵام هەژاری تێگەیشتوو دەیپشکنێت.
\b
\q1 
\v 12 لە سەرکەوتنی ڕاستودروستان شانازییەکی گەورە هەیە،
\q2 بەڵام لە هەستانی بەدکاران خەڵکی خۆیان دەشارنەوە.
\b
\q1 
\v 13 ئەوەی گوناهەکانی خۆی بشارێتەوە سەرناکەوێت،
\q2 بەڵام دانپێدانەر و وازلێهێنەر بەر بەزەیی دەکەوێت.
\b
\q1 
\v 14 خۆزگە دەخوازرێ بە کەسێک بەردەوام لە یەزدان بترسێت،
\q2 بەڵام ئەوەی دڵی خۆی ڕەق بکات دەکەوێتە خراپەوە.
\b
\q1 
\v 15 وەک شێرێکی بە نەڕەنەڕ و ورچێکی هەڵچووە،
\q2 فەرمانڕەوای بەدکار بەسەر گەلی نەدارەوە.
\b
\q1 
\v 16 فەرمانڕەوای ناتێگەیشتوو زۆرداری زۆر دەکات،
\q2 بەڵام ئەوەی ڕقی لە دەستکەوتی ناڕەوا بێت تەمەن درێژ دەبێت.
\b
\q1 
\v 17 ئەوەی خوێنی کەسێکی لە مل بێت
\q2 هەتا ڕۆژی مردنی هەڵاتوو دەبێت.
\q2 با کەس پشتیوانی نەکات.
\b
\q1 
\v 18 ئەوەی بە ڕێگای تەواویدا بڕوات ڕزگار دەبێت،
\q2 بەڵام ئەوەی ڕێگاکانی خوار بکات لەپڕ دەکەوێت.
\b
\q1 
\v 19 ئەوەی ئیش لە زەوی خۆیدا بکات تێر نان دەبێت،
\q2 بەڵام ئەوەی دوای هیچوپووچی بکەوێت تێر هەژاری دەبێت.
\b
\q1 
\v 20 کەسی دڵسۆز بەرەکەتی زۆرە،
\q2 بەڵام ئەوەی بە پەلە بێت بۆ دەوڵەمەندی بێ سزا نابێت.
\b
\q1 
\v 21 لایەنگری باش نییە،
\q2 بەڵام مرۆڤ بۆ لەتە نانێک گوناه دەکات.
\b
\q1 
\v 22 کەسی بەرچاوتەنگ بە پەلەیە بۆ دەوڵەمەندی،
\q2 بەڵام نازانێت نەبوونی بۆ دێت.
\b
\q1 
\v 23 ئەوەی کەسێک سەرزەنشت بکات لە کۆتاییدا پەسەندتر دەبێت
\q2 لەوەی زمانلووسی دەکات.
\b
\q1 
\v 24 ئەوەی دایک و باوکی تاڵان بکات و
\q2 بڵێت: «ئەمە گوناه نییە!»
\q2 ئەو کەسە هاوبەشی کاولکارانە.
\b
\q1 
\v 25 چاوبرسی ناکۆکی دەوروژێنێت،
\q2 بەڵام ئەوانەی پشت بە یەزدان دەبەستن سەرکەوتوو دەبن.
\b
\q1 
\v 26 ئەوەی پشت بە بیرکردنەوەی خۆی ببەستێت گێلە،
\q2 بەڵام ئەوەی بە ڕێگای داناییدا بڕوات دەرباز دەبێت.
\b
\q1 
\v 27 ئەوەی بە هەژار ببەخشێت نەبوون نابێت،
\q2 بەڵام ئەوەی ڕووی لێ وەرگێڕێت نەفرەتی زۆر دەبێت.
\b
\q1 
\v 28 بە هەستانی بەدکاران خەڵکی خۆیان دەشارنەوە،
\q2 بەڵام بە لەناوچوونیان ڕاستودروستان سەردەکەون.
\b
\c 29
\q1 
\v 1 ئەوەی زۆر سەرزەنشت بکرێت و هەر کەللەڕەق بێت،
\q2 لەناکاو تێکدەشکێت و چارەسەریشی نابێت.
\b
\q1 
\v 2 کاتێک ڕاستودروستان زۆر بن گەل دڵخۆش دەبێت،
\q2 کە بەدکار فەرمانڕەوا بێت گەل دەناڵێنێت.
\b
\q1 
\v 3 ئەوەی حەز لە دانایی بکات باوکی دڵخۆش دەکات،
\q2 هاوڕێی لەشفرۆشانیش سامان بەفیڕۆ دەدات.
\b
\q1 
\v 4 پاشا بە دادوەری وڵات ڕادەگرێت،
\q2 بەڵام ئەوانەی بەدوای پارە بکەون وێرانی دەکەن.
\b
\q1 
\v 5 ئەو کەسەی لەگەڵ دراوسێکەی زمانلووسی بکات
\q2 داو لەبەرپێی دەنێتەوە.
\b
\q1 
\v 6 لە گوناهی پیاوخراپ تەڵە هەیە،
\q2 بەڵام کەسی ڕاستودروست گۆرانی دەڵێت و دڵخۆش دەبێت.
\b
\q1 
\v 7 کەسی ڕاستودروست گرنگی بە مافی هەژار دەدات،
\q2 بەڵام بەدکار ئەو گرنگییە تێناگات.
\b
\q1 
\v 8 گاڵتەجاڕان شار دەخەنە ئاژاوەوە،
\q2 بەڵام دانایان تووڕەیی کپ دەکەنەوە.
\b
\q1 
\v 9 ئەگەر پیاوێکی دانا گێلێک بداتە دادگا،
\q2 گێلەکە تووڕە بێت یان گاڵتەی پێ بێت ئاشتی نابێت.
\b
\q1 
\v 10 خوێنڕێژان ڕقیان لە کەسی دروست دەبێتەوە،
\q2 بەڵام سەرڕاستان ژیانی دەپارێزن.
\b
\q1 
\v 11 گێل هەرچی تووڕەیی لە دڵدایە دەریدەبڕێت،
\q2 بەڵام دانا خۆی دەگرێت.
\b
\q1 
\v 12 ئەگەر فەرمانڕەوایەک گوێ لە قسەی درۆ بگرێت،
\q2 هەموو خزمەتکارەکانی دەبنە بەدکار.
\b
\q1 
\v 13 هەژار لەگەڵ زۆردار لەمەدا لە یەکتری دەچن:
\q2 یەزدان ڕووناکی بە چاوی هەردووکیان دەدات.
\b
\q1 
\v 14 ئەگەر پاشایەک بە ڕاستی دادوەری هەژاران بکات،
\q2 تەختەکەی هەتاهەتایە دەچەسپێت.
\b
\q1 
\v 15 داری تەمبێکردن دانایی دەبەخشێت،
\q2 بەڵام منداڵ جڵەوی بەربدرێت دایکی خۆی شەرمەزار دەکات.
\b
\q1 
\v 16 کاتێک بەدکاران گەشە دەکەن گوناه زۆر دەبێت،
\q2 بەڵام ڕاستودروستان کەوتنیان دەبینن.
\b
\q1 
\v 17 کوڕەکەت تەمبێ بکە دەتحەسێنێتەوە،
\q2 چێژ دەداتە گیانت.
\b
\q1 
\v 18 بەبێ سروش\f + \fr 29:18 \ft فەرموودەیەکی خودایە کە لە ڕێگای ڕۆحی پیرۆزەوە بۆ مرۆڤ هاتبێت.‏\f* گەل بەڕەڵا دەبێت،
\q2 بەڵام ئەوەی تەورات پەیڕەو بکات خۆزگەی پێ دەخوازرێت.
\b
\q1 
\v 19 خزمەتکار تەنها بە قسە تەمبێ نابێت،
\q2 هەرچەندە تێدەگات، بەڵام گوێی ناداتێ.
\b
\q1 
\v 20 ئەو کەسەت بینیوە بە پەلەیە لە قسەکانی؟
\q2 گێل لەو زیاتر ئومێدی پێ دەکرێت.
\b
\q1 
\v 21 ئەوەی خزمەتکارەکەی لە منداڵییەوە بە ناز ڕابگرێت،
\q2 لە کۆتاییدا لێی هەڵدەگەڕێتەوە.
\b
\q1 
\v 22 کەسی تووڕە ناکۆکی دەوروژێنێت،
\q2 کەسی هەڵچووش گوناهی زۆرە.
\b
\q1 
\v 23 لووتبەرزی مرۆڤ خۆی نزم دەکاتەوە،
\q2 بەڵام بێفیز ڕێزدار دەبێت.
\b
\q1 
\v 24 هاوبەشی دز ڕقی لە خۆی دەبێتەوە،
\q2 سوێند دەخوات و دانی پێدا نانێت.
\b
\q1 
\v 25 ترسی مرۆڤ تەڵە دەنێتەوە،
\q2 بەڵام ئەوەی پشت بە یەزدان ببەستێت پەناگیر دەبێت.
\b
\q1 
\v 26 زۆر کەس داوای ڕەزامەندی فەرمانڕەوایان دەکەن،
\q2 بەڵام مرۆڤ لەلایەن یەزدانەوە دادپەروەری بەدەستدەهێنێت.
\b
\q1 
\v 27 قێزی ڕاستودروستان لە کەسی ناڕەوایە،
\q2 قێزی بەدکاریش لەوەیە کە ڕێگای ڕاستە.
\c 30
\s1 قسەی ئاگور
\p 
\v 1 قسەکانی ئاگوری کوڕی یاقە ئەم سروشە لەخۆ دەگرێت.
\q1 ئەم پیاوە بە ئیتیێلی\f + \fr 30:1 \ft ئیتیێل: بڕوانە \xt نەحەمیا 11‏:7‏\xt*\ft ‏.‏\f* ڕاگەیاند:
\b
\q1 ئەی خودایە، من شەکەتم،
\q2 بەڵام دەتوانم بەسەریدا زاڵ بم.
\b
\q1 
\v 2 «من لە هەموو مرۆڤێک دەبەنگترم،
\q2 تێگەیشتنی مرۆڤانەم نییە.
\q1 
\v 3 فێری دانایی نەبووم و
\q2 ناسینی خودای پیرۆزم نییە.
\q1 
\v 4 کێ بەرزبووەوە بۆ ئاسمان و هاتە خوارەوە؟
\q2 کێ بای لەناو هەردوو لەپی خۆی کۆکردەوە؟
\q1 کێ ئاوی لەناو جلدا پێچایەوە؟
\q2 کێ هەموو لایەکی زەوی دامەزراند؟
\q1 ناوی چییە؟ ناوی کوڕەکەی چییە؟
\q2 ئەگەر دەیزانیت پێم بڵێ!
\b
\q1 
\v 5 «هەموو وشەیەکی خودا بێگەردە،
\q2 قەڵغانە بۆ ئەوانەی پەنای بۆ دەبەن.
\q1 
\v 6 هیچ شتێک بۆ وشەکانی زیاد مەکە،
\q2 نەوەک سەرزەنشتت بکات و بە درۆزن دەربچیت.
\b
\q1 
\v 7 «ئەی یەزدان، دوو شتم لێ داوا کردیت،
\q2 لێمی قەدەغە مەکە پێش مردنم:
\q1 
\v 8 شتی پووچ و قسەی درۆم لێ دووربخەوە،
\q2 هەژاری یان دەوڵەمەندیم مەدەرێ،
\q2 بەڵام نانی پێویستی خۆم پێ بدە،
\q1 
\v 9 نەوەک تێر بم و نکۆڵیت لێبکەم و
\q2 بڵێم: ”یەزدان کێیە؟“
\q1 یان نەوەک هەژار بم و دزی بکەم و
\q2 ناوی خودای خۆم بێ ڕێز بکەم.
\b
\q1 
\v 10 «بوختان بە خزمەتکار مەکە لەلای گەورەکەی،
\q2 نەوەک نەفرەتت لێ بکات و تاوانبار بیت.
\b
\q1 
\v 11 «نەوەیەک هەیە نەفرەت لە باوکی دەکات و
\q2 دایکی پیرۆز ناکات.
\q1 
\v 12 نەوەیەک هەیە لە ڕوانگەی خۆی پاکە،
\q2 بەڵام خۆی نەشوشتووەتەوە لە پیسوپۆخڵییەکەی.
\q1 
\v 13 نەوەیەک هەیە چەند چاو لە هەوراز و
\q2 بەرز دەڕوانێت.
\q1 
\v 14 نەوەیەک هەیە ددانەکانی شمشێرن و
\q2 کاکیلەکانی چەقۆن،
\q1 بۆ خواردنی کڵۆڵەکان لەسەر زەوی و
\q2 نەدارەکان لەنێو خەڵکی.
\b
\q1 
\v 15 «زەروو\f + \fr 30:15 \ft زەروو یان زێروو، جۆرە کرمێکی مشەخۆرە، هەروەها لە چارەسەرکردنی نەخۆشی بۆ مژینی خوێن بەکاردێت.‏\f* دوو کچی هەیە،
\q2 هاوار دەکەن: ”بێنە، بێنە!“
\b
\q1 «سێ شت هەن تێر نابن،
\q2 چوارەمیش ناڵێت، ”بەسە!“:
\q1 
\v 16 جیهانی مردووان و منداڵدانی نەزۆک و
\q2 زەوییەک تێر ئاو نەبێت و
\q2 ئاگرێک هەرگیز نەڵێت: ”بەسە!“
\b
\q1 
\v 17 «ئەو چاوەی گاڵتە بە باوکی بکات و
\q2 سووکایەتی بە گوێڕایەڵی بکات بۆ دایک،
\q1 قەلەڕەشەکانی دۆڵ هەڵیدەکۆڵن و
\q2 بێچووە سیسارکە کەچەڵ دەیخۆن.
\b
\q1 
\v 18 «سێ شت هەن زۆر سەیرن بۆ من،
\q2 چوارەمیش تێناگەم:
\q1 
\v 19 ڕێگای هەڵۆ لە ئاسمان،
\q2 ڕێگای مار لەسەر بەرد،
\q1 ڕێگای کەشتی لەناو جەرگەی دەریا و
\q2 ڕێگای پیاویش لەگەڵ کچ.
\b
\q1 
\v 20 «ئەمە هەڵسوکەوتی ژنی داوێنپیسە:
\q2 دەخوات\f + \fr 30:20 \ft مەبەست لێی جووت دەبێت.‏\f* و دەمی دەسڕێتەوە و
\q2 دەڵێت: ”خراپەم نەکردووە!“
\b
\q1 
\v 21 «زەوی لەژێر سێ شتدا دەلەرزێت و
\q2 لەژێر چوارەمیش ناتوانێت بەرگە بگرێت،
\q1 
\v 22 خزمەتکارێک کە بووبێتە پاشا،
\q2 گێلێک کە تێر نان بێت،
\q1 
\v 23 ئافرەتێک بێ ناز بێت و مێرد بکات،
\q2 کەنیزەیەک ببێت بە میراتگری خاتوونەکەی.
\b
\q1 
\v 24 «چوار شت هەن لەسەر زەوی بچووکن
\q2 بەڵام لە دانایان داناترن:
\q1 
\v 25 مێروولەکان بوونەوەرێکی بێهێزن،
\q2 بەڵام لە هاویندا خواردنی خۆیان ئەمبار دەکەن.
\q1 
\v 26 گۆڕهەڵکەنەکان گیانلەبەرێکی بێ توانان،
\q2 بەڵام لەناو بەرد لانەکانیان دروستدەکەن.
\q1 
\v 27 کوللەکان پاشایان نییە،
\q2 بەڵام هەموویان پۆل پۆل دەجوڵێن.
\q1 
\v 28 مارمێلکە بەدەست دەگیردرێت،
\q2 بەڵام لە کۆشکی پاشادا دەبینرێت.
\b
\q1 
\v 29 «سێ شت هەن هەنگاویان سەنگینە و
\q2 چوارەمیش ڕۆیشتنی سەنگینە:
\q1 
\v 30 شێر کە پاڵەوانی هەموو گیاندارەکانە،
\q2 لە ڕووی هیچ شتێک ناگەڕێتەوە،
\q1 
\v 31 کەڵەشێری بە فیز، تەگە،
\q2 پاشایەکیش لە سەرکردایەتی لەشکرەکەی.
\b
\q1 
\v 32 «ئەگەر گێلایەتیت کرد بە خۆهەڵکێشانت،
\q2 یان پیلانی خراپت نایەوە،
\q2 دەستت بخەرە سەر دەمت!
\q1 
\v 33 چونکە وەک چۆن شیر بهەژێنیت کەرەی لێ دەردەچێت و
\q2 لووت بهەژێنیت خوێنی لێ دێت،
\q2 تووڕەییش بهەژێنیت ناکۆکی لێ پێدا دەبێت.»
\c 31
\s1 قسەی لەموئێلی پاشا
\p 
\v 1 قسەی لەموئێلی پاشا، ئەو سروشەی کە دایکی فێری کرد:
\q1 
\v 2 گوێ بگرە ڕۆڵە! گوێ بگرە، ڕۆڵەی هەناوم!
\q2 گوێ بگرە ڕۆڵە، ڕۆڵەی نەزرەکانم!
\q1 
\v 3 هێزت مەدە ژنان،
\q2 ڕێگاکانیشت مەدە ژنانی لەناوبەری پاشایان.
\b
\q1 
\v 4 ئەی لەموئێل، بۆ پاشایان نییە،
\q2 بۆ پاشایان نییە شەراب بنۆشن،
\q2 بۆ میرانیش نییە ئارەزووی ئارەق بکەن،
\q1 
\v 5 نەوەک بخۆنەوە و یاسا لەبیر بکەن،
\q2 مافی ستەملێکراوان زەوت بکەن.
\q1 
\v 6 ئارەق بدە بەوەی لەناودەچێت،
\q2 شەرابیش بەوانەی دەروونیان تاڵە.
\q1 
\v 7 با بخواتەوە و هەژارییەکەی لەبیر بکات،
\q2 ئیتر ماندووبوونەکەی نایەتەوە یاد.
\b
\q1 
\v 8 بەرگری لە مافی ئەو کەسانە بکە کە ناتوانن داوای مافەکانیان بکەن،
\q2 بۆ مافی هەموو دەربەدەران.
\q1 
\v 9 دەمت بکەرەوە و بە ڕاستودروستی دادوەری بکە،
\q2 پارێزگاری لە مافی کڵۆڵان و نەداران بکە.
\s1 بەشی کۆتایی\f + \fr 31:9 \ft هەر دێڕە هەڵبەستێک لە بەشی کۆتاییدا بە پیتێک دەستپێدەکات، بەپێی ڕیزبەندی ئەلفبێی عیبری.‏\f*: ژنی خانەدان
\q1 
\v 10 کێ ژنی خانەدانی دەست دەکەوێت؟
\q2 نرخی لە یاقووت\f + \fr 31:10 \ft یاقووت: گەوهەری سووری تۆخ.‏\f* گرانترە.
\q1 
\v 11 مێردەکەی بە تەواوی پشتی پێ دەبەستێت و
\q2 لە هیچی کەم نابێت.
\q1 
\v 12 ژنەکە بە درێژایی ژیانی
\q2 چاکە دێنێتە سەر ڕێی نەک خراپە.
\q1 
\v 13 خوری و کەتان هەڵدەبژێرێت،
\q2 بە دوو دەستی پەرۆشەوە ئیش دەکات.
\q1 
\v 14 وەک کەشتی بازرگان وایە،
\q2 خۆراکی خۆی لە دوورەوە دەهێنێت.
\q1 
\v 15 هێشتا شەوە لە خەو هەڵدەستێت،
\q2 خواردن بۆ ماڵەوە ئامادە دەکات و
\q2 ئەرک بۆ کارەکەرەکان دیاری دەکات.
\q1 
\v 16 لە کێڵگەیەک ورد دەبێتەوە و دەیکڕێت،
\q2 بە قازانجی دەستی ڕەزەمێوێک دەچێنێت.
\q1 
\v 17 ناوقەدی توند دەبەستێت و
\q2 بازووی لێ هەڵدەکات.
\q1 
\v 18 دەبینێت بازرگانییەکەی چاکە،
\q2 بە شەو چرای ناکوژێتەوە.
\q1 
\v 19 خوری بە بازوویەوە دەئاڵێنێت و
\q2 تەشی لەناو لەپیدایە.
\q1 
\v 20 دەستەکانی بۆ کڵۆڵ دەکاتەوە و
\q2 دەست درێژ دەکات بۆ نەداران.
\q1 
\v 21 ترسی ماڵەکەی نییە لە بەفر،
\q2 چونکە هەموو ماڵەکەی بەرگی ئاڵیان\f + \fr 31:21 \ft بەرگی گەرم و ڕەنگ ئاڵ بووە، هەروەک لە کوردی پێی دەگوترێ قەستۆر یان پەستەک.‏\f* لەبەردایە.
\q1 
\v 22 چەرچەف بۆ نوێنەکەی دروستدەکات،
\q2 کەتانی ناسک و ڕیسی ئەرخەوانی لەبەر دەکات.
\q1 
\v 23 مێردی لە دەروازەکانی شاردا ناسراوە،
\q2 لەوێ لەگەڵ پیرانی شارەکە دادەنیشێت.
\q1 
\v 24 ژنەکە کراسی کەتان دروستدەکات و دەیفرۆشێت،
\q2 پشتێن بۆ بازرگانان\f + \fr 31:24 \ft عیبری: کەنعانییەکان، بە مەبەستی بازرگانی گەڕۆک.‏\f* دابین دەکات.
\q1 
\v 25 هێز و ڕێز بەرگی ئەون،
\q2 پێدەکەنێت بۆ ڕۆژانی ئاییندە.
\q1 
\v 26 دەمی بە دانایی دەکاتەوە و
\q2 فێرکردنەکانی میهرەبانی لەسەر زمانییەتی.
\q1 
\v 27 چاودێری هاتوچۆی ماڵومنداڵەکەی دەکات،
\q2 نانی تەمبەڵی ناخوات.
\q1 
\v 28 منداڵەکانی هەڵدەستن و خۆزگەی پێ دەخوازن،
\q2 مێردەکەشی ستایشی دەکات:
\q1 
\v 29 «زۆر ژن خانەدان بوونە،
\q2 بەڵام تۆ لە سەرووی هەموویانی.»
\q1 
\v 30 شۆخ و شەنگی فریودەرە و جوانی پووچە،
\q2 بەڵام ئەو ئافرەتەی لە یەزدان بترسێت، ستایش دەکرێت.
\q1 
\v 31 ڕەنجی شانی خۆی پێ بدەن و
\q2 با کردەوەکانی لەبەر دەروازەکانی شاردا ستایشی بکەن.
