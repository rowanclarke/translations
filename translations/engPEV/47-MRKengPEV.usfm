\v 60 \w The|strong="G2532"\w* big boss \w of|strong="G2532"\w* \w the|strong="G2532"\w* Jewish ceremonies \w stood|strong="G3588"\w* \w up|strong="G1519"\w* \w in|strong="G1519"\w* \w the|strong="G2532"\w* meeting \w and|strong="G2532"\w* \w said|strong="G3004"\w* \w to|strong="G1519"\w* \w Jesus|strong="G2424"\w*, “\w All|strong="G2532"\w* \w those|strong="G3588"\w* \w people|strong="G3004"\w* \w said|strong="G3004"\w* \w that|strong="G3588"\w* \w you|strong="G4771"\w* \w did|strong="G2532"\w* bad \w things|strong="G3778"\w*. \w You|strong="G4771"\w* heard \w them|strong="G3588"\w*. \w What|strong="G5101"\w* \w do|strong="G5101"\w* \w you|strong="G4771"\w* \w say|strong="G3004"\w*?”  
\v 61 \w But|strong="G1161"\w* \w Jesus|strong="G3004"\w* didn’\w t|strong="G3588"\w* answer \w him|strong="G3588"\w*. \w He|strong="G2532"\w* \w just|strong="G2532"\w* \w kept|strong="G4623"\w* \w his|strong="G2532"\w* mouth shut.  
\p \w Then|strong="G2532"\w* \w that|strong="G3588"\w* boss \w said|strong="G3004"\w*, “\w All|strong="G2532"\w* \w right|strong="G3756"\w*, \w tell|strong="G3004"\w* \w us|strong="G3004"\w* \w this|strong="G3588"\w*. \w Are|strong="G1510"\w* \w you|strong="G4771"\w* \w the|strong="G2532"\w* \w Christ|strong="G5547"\w*, \w that|strong="G3588"\w* special \w man|strong="G3762"\w* \w that|strong="G3588"\w* \w God|strong="G3004"\w* promised \w to|strong="G2532"\w* send \w to|strong="G2532"\w* save \w us|strong="G3004"\w*? \w Are|strong="G1510"\w* \w you|strong="G4771"\w* \w the|strong="G2532"\w* \w son|strong="G5207"\w* \w of|strong="G5207"\w* \w God|strong="G3004"\w*?” \fig The Jewish leaders blamed Jesus in their court|src="cn01815b.tif" size="col" copy="1996 David C. Cook" ref="14:61" \fig*   
\p
\v 62 \w Jesus|strong="G2424"\w* \w said|strong="G3004"\w*, “\w Yes|strong="G1161"\w*, \w I|strong="G1473"\w* \w am|strong="G1510"\w*. \w I|strong="G1473"\w*’m \w God|strong="G3004"\w*’s special \w man|strong="G5207"\w* \w from|strong="G1537"\w* \w heaven|strong="G3772"\w*. \w And|strong="G2532"\w* \w one|strong="G3588"\w* \w day|strong="G3588"\w*, \w you|strong="G3708"\w* mob \w will|strong="G1510"\w* \w all|strong="G2532"\w* \w see|strong="G3708"\w* \w me|strong="G1473"\w* \w sitting|strong="G2521"\w* \w there|strong="G2532"\w* \w in|strong="G2532"\w* \w heaven|strong="G3772"\w* \w on|strong="G1537"\w* \w the|strong="G2532"\w* \w right-hand|strong="G1188"\w* \w side|strong="G1188"\w* \w of|strong="G1537"\w* \w God|strong="G3004"\w*, \w the|strong="G2532"\w* \w powerful|strong="G1411"\w* \w one|strong="G3588"\w*. \w And|strong="G2532"\w* \w you|strong="G3708"\w* \w will|strong="G1510"\w* \w also|strong="G2532"\w* \w see|strong="G3708"\w* \w me|strong="G1473"\w* \w come|strong="G2064"\w* back \w here|strong="G1510"\w* \w in|strong="G2532"\w* \w the|strong="G2532"\w* \w clouds|strong="G3507"\w*.”\x * \xo 14:62 \xt Psalm 110:1; Daniel 7:13\x*   
\p
\v 63-64 Then that big boss of the Jewish ceremonies got so angry that he tore his clothes and said to the Jewish leaders, “Did you hear that? This man said that he is the same as God. We don’t need anyone to say anything more. We heard it ourselves. So what do you reckon, did he break our law?”  
\p They all said, “He did. He broke our law. He’s got to die.”\x * \xo 14:63-64 \xt Leviticus 24:16\x*   
\p
\v 65 \w Some|strong="G5100"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w people|strong="G4383"\w* \w in|strong="G2532"\w* \w that|strong="G3588"\w* meeting \w spat|strong="G1716"\w* \w on|strong="G3004"\w* \w Jesus|strong="G3004"\w*. \w They|strong="G2532"\w* tied \w a|strong="G2532"\w* rag across \w his|strong="G2983"\w* eyes \w so|strong="G2532"\w* \w that|strong="G3588"\w* \w he|strong="G2532"\w* couldn’\w t|strong="G3588"\w* see, \w then|strong="G2532"\w* \w they|strong="G2532"\w* hit \w him|strong="G3588"\w* \w with|strong="G2532"\w* \w their|strong="G2532"\w* \w hands|strong="G4475"\w* \w and|strong="G2532"\w* \w said|strong="G3004"\w*, “Hey. \w You|strong="G3004"\w* reckon \w that|strong="G3588"\w* \w God|strong="G3004"\w* \w gives|strong="G3004"\w* \w you|strong="G3004"\w* power \w to|strong="G2532"\w* know \w things|strong="G3588"\w*, \w so|strong="G2532"\w* \w tell|strong="G3004"\w* \w us|strong="G3004"\w*, \w who|strong="G3588"\w* hit \w you|strong="G3004"\w*?” \w Then|strong="G2532"\w* \w the|strong="G2532"\w* guards grabbed \w Jesus|strong="G3004"\w* \w and|strong="G2532"\w* hit \w him|strong="G3588"\w*.   
\s1 Peter said, “I don’t know Jesus”  
\p
\v 66-67 All this time, Peter sat next to the fire in the yard of the big boss of the Jewish ceremonies. One of the girls that worked in that house came along and saw Peter there. She looked at him and said, “I think you were with Jesus, the man from Nazareth.”   
\p
\v 68 \w But|strong="G1161"\w* \w Peter|strong="G1831"\w* \w said|strong="G3004"\w*, “\w No|strong="G2532"\w*. \w I|strong="G2532"\w* don’\w t|strong="G3588"\w* \w know|strong="G1492"\w* \w what|strong="G5101"\w* \w you|strong="G4771"\w* \w are|strong="G3588"\w* \w talking|strong="G3004"\w* \w about|strong="G1519"\w*.” \w Then|strong="G2532"\w* \w Peter|strong="G1831"\w* \w went|strong="G1831"\w* \w back|strong="G1519"\w* \w to|strong="G1519"\w* \w the|strong="G2532"\w* gate \w of|strong="G2532"\w* \w that|strong="G3588"\w* yard. \w Just|strong="G2532"\w* \w then|strong="G2532"\w* \w a|strong="G2532"\w* chook yelled \w out|strong="G1831"\w*. \fig Peter said that he wasn’t one of Jesus’s mob|src="tlc-105.tif" size="col" ref="14:68" \fig*   
\p
\v 69 \w That|strong="G3754"\w* girl \w saw|strong="G3708"\w* \w Peter|strong="G2532"\w* \w at|strong="G1537"\w* \w the|strong="G2532"\w* gate \w and|strong="G2532"\w* started \w to|strong="G2532"\w* \w tell|strong="G3004"\w* \w the|strong="G2532"\w* \w people|strong="G1510"\w*, “\w This|strong="G3778"\w* \w man|strong="G3778"\w* \w is|strong="G1510"\w* \w one|strong="G3588"\w* \w of|strong="G1537"\w* \w Jesus|strong="G3004"\w*’s mob.”   
\p
\v 70 \w But|strong="G1161"\w* \w again|strong="G3825"\w* \w Peter|strong="G4074"\w* \w said|strong="G3004"\w*, “\w No|strong="G2532"\w*, \w I|strong="G2532"\w*’m \w not|strong="G1510"\w*.”  
\p \w A|strong="G2532"\w* \w little|strong="G3398"\w* bit \w later|strong="G3326"\w* \w those|strong="G3588"\w* \w people|strong="G1510"\w* \w there|strong="G2532"\w* \w at|strong="G1537"\w* \w that|strong="G3588"\w* gate \w said|strong="G3004"\w* \w to|strong="G2532"\w* \w Peter|strong="G4074"\w*, “\w You|strong="G4771"\w* \w talk|strong="G2981"\w* like \w the|strong="G2532"\w* \w Galilee|strong="G1057"\w* \w people|strong="G1510"\w* \w talk|strong="G2981"\w*, \w and|strong="G2532"\w* \w Jesus|strong="G3004"\w* \w is|strong="G1510"\w* \w from|strong="G1537"\w* \w Galilee|strong="G1057"\w*, \w so|strong="G2532"\w* \w you|strong="G4771"\w* \w have|strong="G2532"\w* \w to|strong="G2532"\w* \w be|strong="G1510"\w* \w one|strong="G3588"\w* \w of|strong="G1537"\w* \w his|strong="G2532"\w* \w followers|strong="G3588"\w*.”   
\p
\v 71 \w Peter|strong="G2532"\w* got really \w wild|strong="G2532"\w*, \w and|strong="G2532"\w* \w he|strong="G2532"\w* \w said|strong="G3004"\w*, “\w I|strong="G3739"\w*’m \w telling|strong="G3004"\w* \w you|strong="G3739"\w*, \w I|strong="G3739"\w* don’\w t|strong="G3588"\w* \w know|strong="G1492"\w* \w that|strong="G3754"\w* \w man|strong="G3778"\w*. \w I|strong="G3739"\w* don’\w t|strong="G3588"\w* \w know|strong="G1492"\w* \w what|strong="G3739"\w* \w you|strong="G3739"\w* \w are|strong="G3588"\w* \w talking|strong="G3004"\w* \w about|strong="G3754"\w*. \w God|strong="G3004"\w* \w knows|strong="G1492"\w* \w that|strong="G3754"\w* \w this|strong="G3778"\w* \w is|strong="G3588"\w* \w true|strong="G3588"\w*, \w or|strong="G2532"\w* \w if|strong="G2532"\w* \w not|strong="G3756"\w*, \w he|strong="G2532"\w* \w can|strong="G3004"\w* kill \w me|strong="G3004"\w*.”   
\p
\v 72 \w Straight|strong="G2117"\w* away, \w that|strong="G3754"\w* chook yelled \w out|strong="G1537"\w* \w again|strong="G1208"\w*. \w Then|strong="G2532"\w* \w Peter|strong="G4074"\w* remembered \w the|strong="G2532"\w* \w words|strong="G4487"\w* \w Jesus|strong="G2424"\w* \w said|strong="G3004"\w* \w to|strong="G2532"\w* \w him|strong="G3588"\w* \w before|strong="G4250"\w*, “Tonight \w you|strong="G3754"\w* \w will|strong="G2532"\w* \w tell|strong="G3004"\w* \w people|strong="G3004"\w* \w that|strong="G3754"\w* \w you|strong="G3754"\w* don’\w t|strong="G3588"\w* \w know|strong="G1537"\w* \w me|strong="G1473"\w*. \w You|strong="G3754"\w* \w will|strong="G2532"\w* \w say|strong="G3004"\w* \w that|strong="G3754"\w* 3 \w times|strong="G5151"\w*, \w and|strong="G2532"\w* \w then|strong="G2532"\w* \w a|strong="G5613"\w* chook \w will|strong="G2532"\w* yell \w out|strong="G1537"\w* 2 \w times|strong="G5151"\w*.” \w When|strong="G5613"\w* \w Peter|strong="G4074"\w* remembered \w these|strong="G3588"\w* \w words|strong="G4487"\w*, \w he|strong="G2532"\w* \w was|strong="G3588"\w* \w very|strong="G2532"\w* sad, \w and|strong="G2532"\w* \w he|strong="G2532"\w* \w cried|strong="G5455"\w* \w a|strong="G5613"\w* lot.   
\c 15  
\s1 The men of the Jewish Leaders Council took Jesus to the judge  
\p
\v 1 \w Early|strong="G4404"\w* \w in|strong="G2532"\w* \w the|strong="G2532"\w* \w morning|strong="G4404"\w*, \w the|strong="G2532"\w* \w men|strong="G4245"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* Jewish Leaders \w Council|strong="G4892"\w* talked \w with|strong="G3326"\w* \w each|strong="G3326"\w* \w other|strong="G3588"\w* \w about|strong="G2424"\w* \w what|strong="G3588"\w* \w they|strong="G2532"\w* \w will|strong="G2532"\w* \w do|strong="G4160"\w* \w with|strong="G3326"\w* \w Jesus|strong="G2424"\w*. \w That|strong="G3588"\w* \w council|strong="G4892"\w* mob \w were|strong="G3588"\w* \w the|strong="G2532"\w* bosses \w of|strong="G2532"\w* \w the|strong="G2532"\w* Jewish ceremonies, \w and|strong="G2532"\w* \w the|strong="G2532"\w* law teachers, \w and|strong="G2532"\w* \w the|strong="G2532"\w* \w elders|strong="G4245"\w*. \w They|strong="G2532"\w* \w tied|strong="G1210"\w* \w Jesus|strong="G2424"\w*’s \w hands|strong="G3860"\w* \w together|strong="G4824"\w*, \w and|strong="G2532"\w* \w they|strong="G2532"\w* \w took|strong="G2532"\w* \w him|strong="G3588"\w* \w over|strong="G3860"\w* \w to|strong="G2532"\w* \w the|strong="G2532"\w* big government boss. \w His|strong="G4160"\w* name \w was|strong="G3588"\w* \w Pilate|strong="G4091"\w*. \w They|strong="G2532"\w* asked \w him|strong="G3588"\w* \w to|strong="G2532"\w* judge \w Jesus|strong="G2424"\w*.  
\v 2 \w So|strong="G2532"\w* \w Pilate|strong="G4091"\w* \w asked|strong="G1905"\w* \w Jesus|strong="G3004"\w*, “\w Are|strong="G1510"\w* \w you|strong="G4771"\w* \w the|strong="G2532"\w* big boss over \w the|strong="G2532"\w* \w Jewish|strong="G2453"\w* nation?”  
\p \w Jesus|strong="G3004"\w* \w said|strong="G3004"\w*, “\w Those|strong="G3588"\w* \w are|strong="G1510"\w* \w your|strong="G2532"\w* \w words|strong="G2532"\w*.”   
\p
\v 3 \w The|strong="G2532"\w* bosses \w of|strong="G2532"\w* \w the|strong="G2532"\w* Jewish ceremonies blamed \w Jesus|strong="G2532"\w*, \w and|strong="G2532"\w* \w they|strong="G2532"\w* told Pilate \w he|strong="G2532"\w* \w did|strong="G2532"\w* \w a|strong="G2532"\w* lot \w of|strong="G2532"\w* bad \w things|strong="G3588"\w*, \w but|strong="G2532"\w* \w Jesus|strong="G2532"\w* didn’\w t|strong="G3588"\w* \w say|strong="G2532"\w* anything.  
\v 4 \w Then|strong="G1161"\w* \w Pilate|strong="G4091"\w* \w said|strong="G3004"\w* \w to|strong="G3004"\w* \w him|strong="G3588"\w*, “\w They|strong="G1161"\w* \w are|strong="G3588"\w* \w saying|strong="G3004"\w* lots \w of|strong="G3588"\w* bad \w things|strong="G3588"\w* \w about|strong="G3588"\w* \w you|strong="G4771"\w*. Why don’\w t|strong="G3588"\w* \w you|strong="G4771"\w* \w say|strong="G3004"\w* \w something|strong="G3708"\w* \w for|strong="G1161"\w* \w yourself|strong="G4771"\w*?”   
\p
\v 5 \w But|strong="G1161"\w* \w Jesus|strong="G2424"\w* \w said|strong="G1161"\w* \w nothing|strong="G3762"\w*, \w and|strong="G1161"\w* \w Pilate|strong="G4091"\w* \w was|strong="G3588"\w* really shocked. \fig Pilate asked Jesus questions, but Jesus said nothing|src="8k JesusB4Pilate.tif" size="col" ref="15:5" \fig*   
\p
\v 6 \w Every|strong="G2596"\w* year, \w at|strong="G2596"\w* \w the|strong="G1161"\w* ceremony \w time|strong="G3739"\w* \w called|strong="G3739"\w* Passover, Pilate always did something special \w for|strong="G1161"\w* \w the|strong="G1161"\w* people \w in|strong="G2596"\w* Jerusalem. \w He|strong="G1161"\w* \w let|strong="G1161"\w* \w one|strong="G1520"\w* \w prisoner|strong="G1198"\w* \w go|strong="G3739"\w* free \w from|strong="G2596"\w* \w the|strong="G1161"\w* jail.   
\p
\v 7-8 At this Passover time, some of the Jerusalem people came to Pilate and asked him to let a prisoner go free, like he always did. They came up to Pilate while Jesus was still there. At the same time, there was a murderer in jail there. His name was Barabbas. Before that time, Barabbas and his mob fought against the government and killed some of the government people, so the soldiers grabbed him and put him in jail.   
\p
\v 9-11 Pilate knew that the bosses of the Jewish ceremonies were jealous of Jesus, and that was the only reason why they brought him to Pilate. They wanted Pilate to kill him. So when those Jerusalem people asked Pilate to let a prisoner go free, Pilate said, “All right, how about I let Jesus go? You reckon he says that he is your big boss. What do you reckon, will I let him go?”  
\p But the ceremony bosses got all those people to be angry with Jesus, and those people told Pilate, “No. Not him. We want you to let Barabbas go free.”   
\p
\v 12 \w Pilate|strong="G4091"\w* \w said|strong="G3004"\w*, “\w So|strong="G3767"\w* \w what|strong="G5101"\w* \w do|strong="G4160"\w* \w you|strong="G3739"\w* \w want|strong="G2309"\w* \w me|strong="G3004"\w* \w to|strong="G3004"\w* \w do|strong="G4160"\w* \w with|strong="G4160"\w* \w this|strong="G3588"\w* \w man|strong="G3739"\w* \w that|strong="G3739"\w* \w you|strong="G3739"\w* \w Jewish|strong="G2453"\w* \w people|strong="G4160"\w* \w call|strong="G3004"\w* \w your|strong="G4160"\w* big boss?”   
\p
\v 13 \w They|strong="G1161"\w* \w all|strong="G1161"\w* yelled, “Kill \w him|strong="G3588"\w*. Nail \w him|strong="G3588"\w* \w to|strong="G1161"\w* \w a|strong="G1161"\w* cross \w and|strong="G1161"\w* \w let|strong="G1161"\w* \w him|strong="G3588"\w* die \w there|strong="G1161"\w*.”   
\p
\v 14 \w Pilate|strong="G4091"\w* \w said|strong="G3004"\w*, “\w Why|strong="G5101"\w*? \w What|strong="G5101"\w* \w did|strong="G4160"\w* \w he|strong="G1161"\w* \w do|strong="G4160"\w* \w that|strong="G3588"\w* \w was|strong="G3588"\w* \w so|strong="G1161"\w* \w bad|strong="G2556"\w*?”  
\p \w But|strong="G1161"\w* \w they|strong="G1161"\w* didn’\w t|strong="G3588"\w* listen. \w They|strong="G1161"\w* yelled \w even|strong="G1161"\w* louder, “Kill \w him|strong="G3588"\w*. Nail \w him|strong="G3588"\w* \w to|strong="G3004"\w* \w a|strong="G4160"\w* cross.”   
\p
\v 15 \w Pilate|strong="G4091"\w* didn’\w t|strong="G3588"\w* \w want|strong="G1014"\w* \w that|strong="G2443"\w* \w mob|strong="G3793"\w* \w to|strong="G2443"\w* \w get|strong="G2532"\w* \w wild|strong="G2532"\w*, \w so|strong="G2443"\w* \w he|strong="G2532"\w* \w did|strong="G4160"\w* \w what|strong="G3588"\w* \w they|strong="G2532"\w* \w wanted|strong="G1014"\w*. \w He|strong="G2532"\w* \w let|strong="G1161"\w* Barabbas \w go|strong="G2532"\w* \w out|strong="G2532"\w* \w of|strong="G2532"\w* jail, \w and|strong="G2532"\w* \w he|strong="G2532"\w* told \w his|strong="G4160"\w* Roman soldiers \w to|strong="G2443"\w* hit \w Jesus|strong="G2424"\w* \w a|strong="G2532"\w* lot \w with|strong="G2532"\w* whips. \w After|strong="G1161"\w* \w they|strong="G2532"\w* finished whipping \w him|strong="G3588"\w*, \w Pilate|strong="G4091"\w* told \w them|strong="G3588"\w* \w to|strong="G2443"\w* nail \w Jesus|strong="G2424"\w* \w to|strong="G2443"\w* \w a|strong="G2532"\w* cross \w and|strong="G2532"\w* leave \w him|strong="G3588"\w* \w to|strong="G2443"\w* die.   
\s1 The soldiers made fun of Jesus  
\p
