\p
\v 7 Cuando \w él|strong="G3588"\w* apareció, \w los|strong="G3588"\w* \w judíos|strong="G2453"\w* \w que|strong="G3588"\w* habían bajado \w de|strong="G3588"\w* Jerusalén \w lo|strong="G3588"\w* rodearon \w de|strong="G3588"\w* pie para presentar \w muchas|strong="G4183"\w* acusaciones graves, \w las|strong="G3588"\w* \w cuales|strong="G3739"\w* \w no|strong="G3756"\w* \w podían|strong="G2480"\w* probar.   
\p
\v 8 \w Pablo|strong="G3972"\w* se defendió: \w Nada|strong="G5100"\w* malo hice \w contra|strong="G1519"\w* \w la|strong="G3588"\w* \w Ley|strong="G3551"\w* \w de|strong="G1519"\w* \w los|strong="G3588"\w* \w judíos|strong="G2453"\w*, \w ni|strong="G3777"\w* \w contra|strong="G1519"\w* \w el|strong="G3588"\w* \w Templo|strong="G2411"\w*, \w ni|strong="G3777"\w* \w contra|strong="G1519"\w* \w César|strong="G2541"\w*.   
\p
\v 9 \w Pero|strong="G1161"\w* \w Festo|strong="G5347"\w*, \w al|strong="G3588"\w* \w querer|strong="G2309"\w* otorgar \w un|strong="G3588"\w* favor \w a|strong="G1519"\w* \w los|strong="G3588"\w* \w judíos|strong="G2453"\w*, respondió \w a|strong="G1519"\w* \w Pablo|strong="G3972"\w*: ¿\w Quieres|strong="G2309"\w* subir \w a|strong="G1519"\w* Jerusalén \w y|strong="G1161"\w* ser \w juzgado|strong="G2919"\w* \w de|strong="G4012"\w* \w esto|strong="G3778"\w* \w allí|strong="G1563"\w* \w delante|strong="G1909"\w* \w de|strong="G4012"\w* \w mí|strong="G3588"\w*?   
\p
\v 10 \w Pablo|strong="G3972"\w* respondió: \w Estoy|strong="G1510"\w* \w en|strong="G1909"\w* \w pie|strong="G2476"\w* \w ante|strong="G1909"\w* \w el|strong="G3588"\w* tribunal \w de|strong="G1909"\w* \w César|strong="G2541"\w* \w donde|strong="G3757"\w* \w debo|strong="G1163"\w* ser \w juzgado|strong="G2919"\w*. \w En|strong="G1909"\w* \w nada|strong="G3762"\w* agravié \w a|strong="G1909"\w* \w los|strong="G3588"\w* \w judíos|strong="G2453"\w*, \w como|strong="G5613"\w* \w tú|strong="G4771"\w* \w sabes|strong="G1921"\w* muy \w bien|strong="G2570"\w*.  
