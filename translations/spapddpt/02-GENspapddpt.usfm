\q1 \wj \+w El|strong="H3605"\+w* frío y \+w el|strong="H3605"\+w* calor, \+w el|strong="H3605"\+w* \+w verano|strong="H7019"\+w* y \+w el|strong="H3605"\+w* invierno, \wj*  
\q1 \wj \+w Y|strong="H3068"\+w* \+w el|strong="H3605"\+w* \+w día|strong="H3117"\+w* y \+w la|strong="H3605"\+w* \+w noche|strong="H3915"\+w*.\wj*   
\c 9  
\s1 Pacto de \nd ʼElohim\nd* con Noé  
\p
\v 1 \nd ʼElohim\nd* \w bendijo|strong="H1288"\w* \w a|strong="H3068"\w* \w Noé|strong="H5146"\w* y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w*, y les dijo: \wj Sean fecundos y multiplíquense y llenen la tierra.\wj*  
\v 2 \wj \+w El|strong="H5921"\+w* \+w temor|strong="H4172"\+w* \+w y|strong="H5921"\+w* pavor \+w de|strong="H5921"\+w* ustedes \+w sea|strong="H1961"\+w* \+w sobre|strong="H5921"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H5921"\+w* \+w animales|strong="H2416"\+w* \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra, \+w sobre|strong="H5921"\+w* \+w todas|strong="H3605"\+w* \+w las|strong="H5921"\+w* \+w aves|strong="H5775"\+w* \+w del|strong="H5921"\+w* \+w cielo|strong="H8064"\+w*, \+w sobre|strong="H5921"\+w* \+w todo|strong="H3605"\+w* \+w lo|strong="H5921"\+w* \+w que|strong="H5921"\+w* \+w se|strong="H1961"\+w* mueve \+w en|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra \+w y|strong="H5921"\+w* \+w sobre|strong="H5921"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H5921"\+w* peces \+w del|strong="H5921"\+w* \+w mar|strong="H3220"\+w*. \+w En|strong="H5921"\+w* sus \+w manos|strong="H3027"\+w* \+w son|strong="H1961"\+w* entregados.\wj*  
\v 3 \wj \+w Todo|strong="H3605"\+w* \+w lo|strong="H1931"\+w* \+w que|strong="H1931"\+w* \+w se|strong="H1961"\+w* mueve y \+w vive|strong="H2416"\+w* les \+w servirá|strong="H1961"\+w* \+w de|strong="H5414"\+w* alimento, y también \+w la|strong="H1931"\+w* \+w hierba|strong="H6212"\+w* \+w verde|strong="H3418"\+w*. \+w Se|strong="H1961"\+w* \+w lo|strong="H1931"\+w* \+w di|strong="H5414"\+w* \+w todo|strong="H3605"\+w*.\wj*   
\p
\v 4 \wj Solo \+w no|strong="H3808"\+w* comerán \+w carne|strong="H1320"\+w* con su \+w vida|strong="H5315"\+w* \+w que|strong="H3808"\+w* es su \+w sangre|strong="H1818"\+w*,\wj*  
\v 5 \wj pues \+w ciertamente|strong="H1875"\+w* \+w demandaré|strong="H1875"\+w* \+w la|strong="H3605"\+w* \+w sangre|strong="H1818"\+w* \+w de|strong="H1818"\+w* ustedes. \+w La|strong="H3605"\+w* \+w demandaré|strong="H1875"\+w* \+w de|strong="H1818"\+w* \+w mano|strong="H3027"\+w* \+w de|strong="H1818"\+w* \+w todo|strong="H3605"\+w* \+w ser|strong="H5315"\+w* \+w vivo|strong="H2416"\+w*. \+w De|strong="H1818"\+w* \+w mano|strong="H3027"\+w* del hombre y \+w de|strong="H1818"\+w* \+w cualquier|strong="H3605"\+w* hermano suyo \+w demandaré|strong="H1875"\+w* \+w la|strong="H3605"\+w* \+w vida|strong="H5315"\+w* del hombre.\wj*   
\p
\v 6 \wj \+w El|strong="H3588"\+w* \+w que|strong="H3588"\+w* derrame \+w sangre|strong="H1818"\+w* \+w de|strong="H3588"\+w* hombre, \+w su|strong="H3588"\+w* \+w sangre|strong="H1818"\+w* \+w será|strong="H6213"\+w* derramada \+w por|strong="H3588"\+w* \+w los|strong="H3588"\+w* hombres, \+w porque|strong="H3588"\+w* \+w a|strong="H3068"\+w* \+w imagen|strong="H6754"\+w* \+w de|strong="H3588"\+w* \+nd ʼElohim\+nd* \+w hizo|strong="H6213"\+w* \+nd \+w ʼEL|strong="H3588"\+w*\+nd* al hombre.\wj*  
\v 7 \wj \+w Y|strong="H3068"\+w* ustedes, sean fructíferos y multiplíquense. Reprodúzcanse en la tierra y multiplíquense en ella.\wj*   
\p
\v 8 \nd ʼElohim\nd* habló \w a|strong="H3068"\w* \w Noé|strong="H5146"\w* y \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w que|strong="H1121"\w* estaban con \w él|strong="H1121"\w*:  
\v 9 \wj Miren, Yo establezco mi \+w Pacto|strong="H1285"\+w* con ustedes, y después de ustedes, con sus descendientes,\wj*  
\v 10 \wj y con \+w todo|strong="H3605"\+w* \+w ser|strong="H5315"\+w* \+w vivo|strong="H2416"\+w* \+w que|strong="H3605"\+w* está con ustedes: \+w aves|strong="H5775"\+w*, ganado y \+w todos|strong="H3605"\+w* \+w los|strong="H3605"\+w* \+w animales|strong="H2416"\+w* terrestres \+w que|strong="H3605"\+w* están con ustedes, \+w todos|strong="H3605"\+w* \+w los|strong="H3605"\+w* \+w que|strong="H3605"\+w* \+w salieron|strong="H3318"\+w* del \+w arca|strong="H8392"\+w*, \+w todos|strong="H3605"\+w* \+w los|strong="H3605"\+w* \+w animales|strong="H2416"\+w* de \+w la|strong="H3605"\+w* tierra.\wj*   
\p
\v 11 \wj \+w Estableceré|strong="H6965"\+w*, \+w pues|strong="H1961"\+w*, \+w mi|strong="H1961"\+w* \+w Pacto|strong="H1285"\+w* con ustedes: \+w Ya|strong="H3068"\+w* \+w no|strong="H3808"\+w* \+w será|strong="H1961"\+w* aniquilada \+w alguna|strong="H3605"\+w* \+w carne|strong="H1320"\+w* \+w por|strong="H5750"\+w* las \+w aguas|strong="H4325"\+w* del \+w diluvio|strong="H3999"\+w*. \+w Ya|strong="H3068"\+w* \+w no|strong="H3808"\+w* \+w habrá|strong="H1961"\+w* \+w diluvio|strong="H3999"\+w* \+w para|strong="H1961"\+w* \+w destruir|strong="H7843"\+w* \+w la|strong="H3605"\+w* tierra.\wj*   
\p
\v 12 \w Y|strong="H3068"\w* \nd ʼElohim\nd* dijo: \wj Les \+w doy|strong="H5414"\+w* \+w esta|strong="H2063"\+w* señal del \+w Pacto|strong="H1285"\+w* entre \+w Yo|strong="H5315"\+w* y ustedes y \+w todo|strong="H3605"\+w* \+w ser|strong="H5315"\+w* \+w viviente|strong="H2416"\+w* \+w que|strong="H3605"\+w* \+w está|strong="H2063"\+w* con ustedes, \+w por|strong="H5769"\+w* \+w generaciones|strong="H1755"\+w* \+w perpetuas|strong="H5769"\+w*: \wj*  
\v 13 \wj \+w Pondré|strong="H5414"\+w* \+w mi|strong="H1961"\+w* \+w arco|strong="H7198"\+w* en las \+w nubes|strong="H6051"\+w* y \+w será|strong="H1961"\+w* la señal del \+w Pacto|strong="H1285"\+w* entre Yo y la tierra.\wj*  
\v 14 \wj \+w Pues|strong="H7200"\+w* \+w sucederá|strong="H1961"\+w* \+w que|strong="H5921"\+w* \+w cuando|strong="H1961"\+w* Yo cubra \+w la|strong="H5921"\+w* tierra \+w con|strong="H5921"\+w* \+w nubes|strong="H6051"\+w*, entonces \+w aparecerá|strong="H7200"\+w* \+w el|strong="H5921"\+w* \+w arco|strong="H7198"\+w* \+w en|strong="H5921"\+w* \+w las|strong="H5921"\+w* \+w nubes|strong="H6051"\+w*,\wj*  
\v 15 \wj y me acordaré \+w de|strong="H5750"\+w* \+w mi|strong="H1961"\+w* \+w Pacto|strong="H1285"\+w* \+w entre|strong="H3808"\+w* \+w Yo|strong="H5315"\+w* y ustedes y \+w todo|strong="H3605"\+w* \+w ser|strong="H5315"\+w* \+w viviente|strong="H2416"\+w* \+w de|strong="H5750"\+w* \+w toda|strong="H3605"\+w* \+w carne|strong="H1320"\+w*. \+w No|strong="H3808"\+w* \+w habrá|strong="H1961"\+w* \+w más|strong="H5750"\+w* \+w aguas|strong="H4325"\+w* \+w de|strong="H5750"\+w* \+w diluvio|strong="H3999"\+w* \+w para|strong="H1961"\+w* \+w destruir|strong="H7843"\+w* \+w a|strong="H3068"\+w* \+w todo|strong="H3605"\+w* \+w ser|strong="H5315"\+w* \+w vivo|strong="H2416"\+w*.\wj*   
\p
\v 16 \wj \+w Cuando|strong="H1961"\+w* \+w el|strong="H5921"\+w* \+w arco|strong="H7198"\+w* \+w aparezca|strong="H7200"\+w* \+w en|strong="H5921"\+w* \+w las|strong="H5921"\+w* \+w nubes|strong="H6051"\+w*, \+w lo|strong="H5921"\+w* \+w miraré|strong="H7200"\+w* \+w para|strong="H5921"\+w* recordar \+w el|strong="H5921"\+w* \+w Pacto|strong="H1285"\+w* \+w eterno|strong="H5769"\+w* \+w entre|strong="H5921"\+w* \+nd ʼElohim\+nd* \+w y|strong="H5921"\+w* \+w todo|strong="H3605"\+w* \+w ser|strong="H5315"\+w* \+w viviente|strong="H2416"\+w* \+w de|strong="H5921"\+w* \+w toda|strong="H3605"\+w* \+w carne|strong="H1320"\+w* \+w que|strong="H5921"\+w* \+w está|strong="H1961"\+w* \+w sobre|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra.\wj*   
\p
\v 17 Luego \nd ʼElohim\nd* dijo \w a|strong="H3068"\w* \w Noé|strong="H5146"\w*: \wj \+w Esta|strong="H2063"\+w* \+w es|strong="H2063"\+w* \+w la|strong="H5921"\+w* señal \+w del|strong="H5921"\+w* \+w Pacto|strong="H1285"\+w* \+w que|strong="H5921"\+w* establezco \+w entre|strong="H5921"\+w* Yo \+w y|strong="H5921"\+w* \+w toda|strong="H3605"\+w* \+w carne|strong="H1320"\+w* \+w que|strong="H5921"\+w* hay \+w sobre|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra.\wj*   
\s1 Cam  
\p
\v 18 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Noé|strong="H5146"\w* \w que|strong="H4480"\w* \w salieron|strong="H3318"\w* \w del|strong="H4480"\w* \w arca|strong="H8392"\w* \w fueron|strong="H1961"\w* \w Sem|strong="H8035"\w*, Cam y Jafet (y Cam \w es|strong="H1931"\w* \w el|strong="H1931"\w* padre \w de|strong="H4480"\w* \w Canaán|strong="H3667"\w*).  
\v 19 \w Estos|strong="H3605"\w* \w tres|strong="H7969"\w* fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Noé|strong="H5146"\w*, y \w de|strong="H1121"\w* \w éstos|strong="H3605"\w* fue poblada \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra.   
\p
\v 20 \w Noé|strong="H5146"\w* \w comenzó|strong="H2490"\w* \w a|strong="H3068"\w* labrar la tierra y \w plantó|strong="H5193"\w* una \w viña|strong="H3754"\w*.  
\v 21 \w Bebió|strong="H8354"\w* \w vino|strong="H3196"\w*, \w se|strong="H4480"\w* embriagó y \w se|strong="H4480"\w* desnudó \w dentro|strong="H8432"\w* \w de|strong="H4480"\w* su tienda.   
\p
\v 22 Cam, padre de \w Canaán|strong="H3667"\w*, \w vio|strong="H7200"\w* la \w desnudez|strong="H6172"\w* de su padre y lo \w declaró|strong="H5046"\w* \w afuera|strong="H2351"\w* \w a|strong="H3068"\w* sus \w dos|strong="H8147"\w* hermanos.   
\p
\v 23 Entonces \w Sem|strong="H8035"\w* \w y|strong="H5921"\w* Jafet \w tomaron|strong="H3947"\w* \w la|strong="H5921"\w* \w ropa|strong="H8071"\w* \w y|strong="H5921"\w* \w se|strong="H5921"\w* \w la|strong="H5921"\w* \w pusieron|strong="H7760"\w* \w ambos|strong="H8147"\w* \w sobre|strong="H5921"\w* sus \w hombros|strong="H7926"\w*. \w Caminaron|strong="H3212"\w* \w hacia|strong="H5921"\w* atrás \w y|strong="H5921"\w* \w cubrieron|strong="H3680"\w* \w la|strong="H5921"\w* \w desnudez|strong="H6172"\w* \w de|strong="H5921"\w* su padre. Sus \w rostros|strong="H6440"\w* estaban vueltos \w hacia|strong="H5921"\w* atrás \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w vieron|strong="H7200"\w* \w la|strong="H5921"\w* \w desnudez|strong="H6172"\w* \w de|strong="H5921"\w* su padre.   
\p
\v 24 Al despertar \w de|strong="H1121"\w* su embriaguez, \w Noé|strong="H5146"\w* \w supo|strong="H3045"\w* \w lo|strong="H6213"\w* \w que|strong="H3045"\w* le \w hizo|strong="H6213"\w* su \w hijo|strong="H1121"\w* \w menor|strong="H6996"\w*  
\v 25 y dijo:  
\q1 Maldito \w sea|strong="H1961"\w* \w Canaán|strong="H3667"\w*.  
\q1 \w Será|strong="H1961"\w* esclavo de \w los|strong="H1961"\w* esclavos de sus hermanos.   
\p
\v 26 Luego dijo:  
\q1 \w Bendito|strong="H1288"\w* \w sea|strong="H1961"\w* \nd \+w Yavé|strong="H3068"\+w*, ʼElohim\nd* de \w Sem|strong="H8035"\w*,  
\q1 \w Y|strong="H3068"\w* \w sea|strong="H1961"\w* \w Canaán|strong="H3667"\w* su esclavo.   
\q1
\v 27 Ensanche \nd ʼElohim\nd* \w a|strong="H3068"\w* Jafet,  
\q1 \w Y|strong="H3068"\w* viva en las tiendas de \w Sem|strong="H8035"\w*  
\q1 \w Y|strong="H3068"\w* \w sea|strong="H1961"\w* \w Canaán|strong="H3667"\w* su esclavo.   
\p
\v 28 \w Noé|strong="H5146"\w* \w vivió|strong="H2421"\w* 350 \w años|strong="H8141"\w* después del \w diluvio|strong="H3999"\w*.   
\p
\v 29 \w Los|strong="H3605"\w* \w días|strong="H3117"\w* de \w Noé|strong="H5146"\w* \w fueron|strong="H1961"\w* 950 \w años|strong="H8141"\w*, y \w murió|strong="H4191"\w*.   
\c 10  
\s1 Descendencia de Sem, Cam y Jafet  
\p
\v 1 Estos son \w los|strong="H1121"\w* descendientes \w de|strong="H1121"\w* \w Sem|strong="H8035"\w*, Cam y Jafet, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Noé|strong="H5146"\w*, \w a|strong="H3068"\w* quienes les \w nacieron|strong="H3205"\w* \w hijos|strong="H1121"\w* después del \w diluvio|strong="H3999"\w*.   
\p
\v 2 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Jafet: \w Gomer|strong="H1586"\w*, \w Magog|strong="H4031"\w*, Madai, \w Javán|strong="H3120"\w*, \w Tubal|strong="H8422"\w*, \w Mesec|strong="H4902"\w* y Tiras.   
\p
\v 3 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Gomer|strong="H1586"\w*: Askenaz, Rifat y Togarma.   
\p
\v 4 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Javán|strong="H3120"\w*: Elisha, \w Tarsis|strong="H8659"\w*, Kitim y Dodanim.   
\p
\v 5 \w A|strong="H3068"\w* partir de estos fueron pobladas las costas, cada uno en sus territorios, según su \w lengua|strong="H3956"\w*, por sus \w familias|strong="H4940"\w* en sus \w naciones|strong="H1471"\w*.   
\p
\v 6 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cam: Cus, Mizraim, Fut y \w Canaán|strong="H3667"\w*.   
\p
\v 7 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cus: \w Seba|strong="H7614"\w*, \w Havila|strong="H2341"\w*, Sabta, Raama y Sabteca.  
\p \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Raama: \w Seba|strong="H7614"\w* y \w Dedán|strong="H1719"\w*.   
\p
\v 8 Cus también \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Nimrod, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w comenzó|strong="H2490"\w* \w a|strong="H3068"\w* ser \w poderoso|strong="H1368"\w* en \w la|strong="H1931"\w* tierra.  
\v 9 \w Él|strong="H1931"\w* \w fue|strong="H1961"\w* intrépido \w cazador|strong="H6718"\w* enfrentado \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \w Por|strong="H5921"\w* \w esto|strong="H3651"\w* \w se|strong="H1961"\w* dice:  
\q1 \w Como|strong="H1961"\w* Nimrod, intrépido \w cazador|strong="H6718"\w* enfrentado \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 10 El \w principio|strong="H7225"\w* de su \w reino|strong="H4467"\w* \w fue|strong="H1961"\w* Babel, Erec, Acad y Calne, en tierra de Sinar.  
\v 11 \w Salió|strong="H3318"\w* \w de|strong="H4480"\w* \w aquella|strong="H1931"\w* tierra, y \w al|strong="H4480"\w* ser fortalecido, \w edificó|strong="H1129"\w* \w Nínive|strong="H5210"\w*, \w Ciudad|strong="H5892"\w* Rehobot, Cala  
\v 12 y Resen, entre \w Nínive|strong="H5210"\w* y Cala, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* una \w ciudad|strong="H5892"\w* \w grande|strong="H1419"\w*.   
\p
\v 13 Mizraim \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* Ludim, \w a|strong="H3068"\w* Anamim, \w a|strong="H3068"\w* Lehabim, \w a|strong="H3068"\w* Naftuhim,  
\v 14 \w a|strong="H3068"\w* Patrusim, \w a|strong="H3068"\w* Casluhim, de \w donde|strong="H8033"\w* \w salieron|strong="H3318"\w* los \w filisteos|strong="H6430"\w*, y \w a|strong="H3068"\w* Caftorim.   
\p
\v 15 \w Canaán|strong="H3667"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Sidón|strong="H6721"\w*, su \w primogénito|strong="H1060"\w*, \w a|strong="H3068"\w* Het,  
\v 16 al \w jebuseo|strong="H2983"\w*, al amorreo al gergeseo,  
\v 17 al \w heveo|strong="H2340"\w*, al araceo, al sineo,  
\v 18 al arvadeo, al zemareo y al hemateo.  
\p Después se dispersaron las \w familias|strong="H4940"\w* de los \w cananeos|strong="H3669"\w*.  
\v 19 \w La|strong="H1366"\w* frontera del \w cananeo|strong="H3669"\w* iba \w desde|strong="H5704"\w* \w Sidón|strong="H6721"\w* \w en|strong="H5704"\w* dirección \w a|strong="H3068"\w* \w Gerar|strong="H1642"\w*, \w hasta|strong="H5704"\w* \w Gaza|strong="H5804"\w*, \w y|strong="H5704"\w* \w en|strong="H5704"\w* dirección \w de|strong="H5704"\w* \w Sodoma|strong="H5467"\w*, \w Gomorra|strong="H6017"\w*, Adma \w y|strong="H5704"\w* Zeboim, \w hasta|strong="H5704"\w* \w Lasa|strong="H3962"\w*.   
\p
\v 20 Estos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Cam por sus \w familias|strong="H4940"\w* y sus lenguas, sus territorios y sus \w naciones|strong="H1471"\w*.   
\p
\v 21 \w También|strong="H1571"\w* \w le|strong="H1931"\w* \w nacieron|strong="H3205"\w* \w hijos|strong="H1121"\w* \w a|strong="H3068"\w* \w Sem|strong="H8035"\w*, padre \w de|strong="H1121"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Heber|strong="H5677"\w*, \w y|strong="H1571"\w* hermano \w mayor|strong="H1419"\w* \w de|strong="H1121"\w* Jafet.  
\v 22 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Sem|strong="H8035"\w* fueron \w Elam|strong="H5867"\w*, Asur, Arfaxad, \w Lud|strong="H3865"\w* y Aram.   
\p
\v 23 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aram fueron \w Uz|strong="H5780"\w*, \w Hul|strong="H2343"\w*, Geter y Mas.   
\p
\v 24 Arfaxad \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Sala|strong="H7974"\w*, y \w Sala|strong="H7974"\w* \w engendró|strong="H3205"\w* \w a|strong="H3068"\w* \w Heber|strong="H5677"\w*.   
