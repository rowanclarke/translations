\id SNG  
\ide UTF8
\h ON LAL SOLOMON 
\toc1 On Lal Solomon 
\toc2 On Lal Solomon 
\toc3 Ols 
\mt1 ON LAL SOLOMON  
\is1 Tukakinyen Book In ON LAL SOLOMON  
\ip Oasr on in lungse onkosr simla in book se inge, ma sie mukul el onkakin nu sin sie mutan su el lungse, ac oayapa mutan sac el onkakin nu sin mukul sac. In kutu leng ke Ma Simusla uh, book se inge pangpang “On Lun On uh,” oana fahk mu “On Ma Kato Emeet,” mweyen pa inge kas ma sikyak emeet in book uh.  
\ip Yurin mwet Jew, on inge lumweyuk nu ke lungse lun God nu sin mwet lal; ac mwet Christian uh luma mu ma ke lungse lun Christ nu sin Church.  
\is1 Takla Lun Koanon Book Se Inge  
\io1 On Soko Meet 1:1—2:7  
\io1 On Soko Aklukwa 2:8—3:5  
\io1 On Soko Aktolkwe 3:6—5:1  
\io1 On Soko Akakosr 5:2—6:3  
\io1 On Soko Aklimekosr 6:4—8:4  
\io1 On Soko Akonkosr 8:5–14  
\c 1  
\p
\v 1 Pa inge on ma kato emeet, ma Solomon el orala.\f + \fr 1:1 \fk ma Solomon el orala: \ft ku pac in lungasyukla ouinge: ma simla kacl Solomon.\f*   
\s1 On Soko Meet  
\sp Verse Lun Mutan Se  
\q1
\v 2 Nga ke kom in arulana ngokla mutuk;  
\q2 Lungse lom uh los liki na wain uh.   
\q1
\v 3 Oasr foul na keng se keim;  
\q2 Ke pacl inem ac fwack uh, nga sifil pacna esamak foul keng sac.  
\q2 Wangin mutan ku in kutongya lungse la nu sum.   
\q1
\v 4 Usyu nga in wi kom, ac kut ac fah kaingla;  
\q2 Kom in tokosra luk ac pwenyuwot nu infukil sum.  
\q1 Kut ac fah tukeni ac arulana engan,  
\q2 Nga yukin lungse lom uh yohk liki kutena ma.  
\q2 Pwaye sin mutan uh in lungse kom!   
\q1
\v 5 Mutan Jerusalem, nga ne sroalsroal tuh nga oasku.  
\q2 Nga sroalsroal oana lohm nuknuk in acn mwesis Kedar,  
\q2 Tuh nga kato oana lisrlisr inkul fulat sel Solomon.   
\q1
\v 6 Nimet pilesreyu mu nga sroalsroal,  
\q2 Mweyen faht uh pa tuhneyula uh.  
\q1 Tamulel luk elos tuh kasrkusrak sik  
\q2 Ac sap nga orekma ke ima in grape.  
\q2 Na wangin pacl luk in karinginyu sifacna.   
\q1
\v 7 Kom su nga lungse yohk, fahkma nu sik,  
\q2 Kom ac pwen un sheep nutum an in mongo oya?  
\q2 Elos ac mongla ya ke pacl faht uh fol ke infulwen len uh?  
\q1 Efu ku ngan suk kom  
\q2 Inmasrlon un sheep nutin mwet shepherd ngia?   
\sp Verse Lun Mukul Se  
\q1
\v 8 Ya kom tia etu acn sac, kom su oasku liki mutan nukewa?  
\q1 Fahla ukweot na un sheep uh  
\q2 Twe konauk acn nani nutum an in mongo we  
\q2 Apkuran nu ke lohm nuknuk sin mwet shepherd ngia.   
\q1
\v 9 Kom su nga lungse na pwaye, lumom arulana kato  
\q2 Oana horse mutan ma amakin chariot okoal Tokosra Egypt.   
\q1
\v 10 Aunsifom oaskulana ke oan likintupom uh,  
\q2 Ac putati sisken kwawom oana wek saok uh.   
\q1
\v 11 Kut ac fah orala soko sein gold ah lom,  
\q2 Ac nawela ke mwe yun silver.   
\sp Verse Lun Mutan Se  
\q1
\v 12 Ke tokosra luk el oan infukil sel,  
\q2 Ono keng keik uh nwakla in lohm uh ke foul wo.   
\q1
\v 13 Ke mukul kawuk luk el elongak iniwuk,  
\q2 El oana sie nwana keng orekla ke myrrh.   
\q1
\v 14 El su saok sik el oana sie ros inima uh  
\q2 Su farngelik inima grape in acn Engedi.   
\sp Verse Lun Mukul Se  
\q1
\v 15 Mutan saok sik, kom arulana oasku,  
\q2 Motom saromrom ke ngetnget in lungse lom!   
\sp Verse Lun Mutan Se  
\q1
\v 16 Mukul kawuk luk, kom kato na pwaye sik,  
\q2 Nga arulana pwar sum!  
\q1 Mah folfol uh pa ac fah mwe oan kiuktal.   
\q2
\v 17 Sak cedar pa srulun loaloa nu ke lohm sesr,  
\q1 Ac sak cypress pa ac srulun siling lasr uh.   
\c 2  
\q1
\v 1 Ros inima se na in acn Sharon pa nga,  
\q2 Oana sie ros kiuf infahlfal uh.   
\sp Verse Lun Mukul Se  
\q1
\v 2 Oana sie ros kiuf inmasrlon kokul uh,  
\q2 Ouinge el su saok sik inmasrlon mutan uh.   
\sp Verse Lun Mutan Se  
\q1
\v 3 Oana soko sak apple inmasrlon sak inima uh,  
\q2 Ouinge lumweyen el su saoklana sik inmasrlon mukul saya uh.  
\q1 Nga lungse na muta ye lulin sak apple soko inge.  
\q2 Ke nga ema fahko kac uh arulana emwem.   
\q1
\v 4 El usyula nu in acn in orek kufwa lal  
\q2 Ac olak flag in lungse lal fuk.   
\q1
\v 5 Folokonak ku luk ke raisin,  
\q2 Ac akwoyela ikok ke apple uh!  
\q2 Nga kuf na pwaye ke nunkeyen lungse lom.   
\q1
\v 6 Nga ilung lac paol lasa,  
\q2 Ac lac paol layot kafisyuyang nu yorol.   
\q1
\v 7 Kowos mutan Jerusalem, wulema nu sik  
\q2 Ke inen kosro mui ac kato inima uh,  
\q2 Lah kowos fah tia oru kutena ma in lusrong pacl in pwar lasr uh.   
\s1 On Soko Aklukwa  
\sp Verse Lun Mutan Se  
\q1
\v 8 Nga lohng pusren el su nga lungse.  
\q1 El kasrma srosro fineol uh,  
\q2 El yume tupalma inging uh nu yuruk.   
\q1
\v 9 Kawuk luk ah el oana soko kosro gazelle,  
\q2 Oana soko deer fusr mukul.  
\q1 El a tu pesinka uh.  
\q1 El ngetma ke winto ah,  
\q2 Ac yoryor ke lisrlisr wasengseng uh.   
\q1
\v 10 Ma se luk ah el kasma nu sik.  
\sp Verse Lun Mukul Se  
\q1 Fahsru, kuiyuk,  
\q2 Kom su oaskulana, fahsru kital som.   
\q1
\v 11 Pacl mihsrisr uh safla; ac af uh wanginla;   
\q2
\v 12 Ros uh fokla yen nukewa inimae.  
\q1 Inge pacl in on;  
\q2 Pusren wuleoa uh lohngyuk in acn sesr.   
\q1
\v 13 Fokinsak fig uh mutawauk in mwesrla;  
\q2 Foulin ros ke grape uh akkengyela acn uh.  
\q1 Fahsru, kom su saok sik,  
\q2 Kom su oaskulana sik, fahsru wiyu.   
\q1
\v 14 Kom oana sie wuleoa su muta  
\q2 In luf pe fulu uh.  
\q1 Nga ke liye ngetnget oasku se lom an;  
\q2 Nga ke lohngak pusra kato se lom.   
\b  
\q1
\v 15 Ros ke ima in grape lasr uh farngelik tari,  
\q2 Kut enenu in sruokya kosro fox srisrik uh meet liki elos kunausla ima lasr uh.   
\sp Verse Lun Mutan Se  
\q1
\v 16 Ma na luk pa mukul se nga lungse, ac nga ma na lal.  
\q1 El mukena kite un kosro natul uh inmasrlon ros kiuf uh   
\q2
\v 17 Nwe ke na engyengsrik in lotu uh tuhme,  
\q2 Ac lohsr uh wanginla.  
\q1 Folokla, kom su saok sik, kasrla oana soko gazelle mui,  
\q2 Oana soko deer mukul el kasrusr ke tohktok lun eol uh.   
\c 3  
\q1
\v 1 Fong nukewa ke nga oan fin mwe oan kiuk uh  
\q2 Nga nunkal su nga lungse yohk;  
\q2 Nga sokol, ac tia ku in konalak.   
\q1
\v 2 Nga ac tukakek ac som forfor in siti uh;  
\q2 Nga ac fahsr sasla inkanek nukewa  
\q1 Ac sokol su nga lungse yohk.  
\q2 Na nga sokol, ac tia ku in konalak.   
\q1
\v 3 Mwet topang su forfor taran siti uh elos liyeyuyak.  
\q2 Na nga siyuk selos, “Kowos tiana liye kawuk se luk ah?”   
\q1
\v 4 Nga tufahna som lukelos, na nga konalak.  
\q1 Nga sruokilya ac tia lungse fuhlella  
\q2 Nwe ke na nga pwanulla nu in lohm sin nina kiuk,  
\q2 Nu infukil se na nga tuh isusla we.   
\b  
\q1
\v 5 Mutan Jerusalem, kowos in wulema nu sik  
\q2 Ke inen kosro mui ac kato inima uh,  
\q2 Lah kowos fah tia lusrong pacl in pwar lasr uh.   
\s1 On Soko Aktolkwe  
\sp Verse Lun Mutan Se  
\q1
\v 6 Mea se fosryak yen mwesis uh me, oana sru in kulasr soko,  
\q2 Ac keng fohlo oana foulin myrrh ac franku  
\q2 Ma mwet kuka uh kukakin?   
\q1
\v 7 Solomon el a tuku ingo — utuk na el fin mwe muta lal uh;  
\q2 Mwet mweun onngoul pa atlol tuku.  
\q2 Elos pa solse ma ku oemeet inmasrlon mwet mweun lun Israel.   
\q1
\v 8 Elos nukewa pisrla ke orekmakinyen cutlass;  
\q2 Elos mwet na pah ke mweun uh.  
\q1 Kais sie selos us cutlass natul,  
\q2 Akola na nu ke kutena mwe lokoalok ma ac sikyak ke fong.   
\q1
\v 9 Utuk Tokosra Solomon fin sie mwe muta fulat,  
\q2 Su orekla ke sak ma wo oemeet Lebanon.   
\q1
\v 10 Kosrusru kac uh nukla ke silver,  
\q2 Ac nuknuk akul uh ke gold oan fac.  
\q1 Ma loeyen mwe muta uh nukla ke nuknuk sroninmutuk,  
\q2 Su tutalla arulana wo sin mutan Jerusalem.   
\q1
\v 11 Mutan in Zion, fahsru liyel Tokosra Solomon.  
\q1 El sunya tefuro se su nina kial tuh oakiya fin sifal  
\q2 Ke len in marut lal,  
\q2 Ke len in engan ac pwar lal.   
\c 4  
\sp Verse Lun Mukul Se  
\q1
\v 1 Mutan saok sik, kom kato na pwaye!  
\q1 Motom efal oana mutun sie wuleoa ye nuknuk minini afinyen motom.  
\q1 Aunsifom sroalsroal ac srosro oana un nani uh  
\q2 Ke ac putati fineol Gilead me.   
\q1
\v 2 Wihsum fasrfasr oana sheep  
\q2 Ma tufahna kalkulla ac owola.  
\q1 Tia soko selos fulukla;  
\q2 Nufonna arulana fas, ac kais soko oasr lainya.   
\q1
\v 3 Ngoasrom oana sie ropin srusra;  
\q2 Arulana kato ke pacl kom kaskas uh.  
\q1 Likintupom srusrsrusrame ye nuknuk minini lisringyen motom an.   
\q1
\v 4 Kwawom raraun ac fwel  
\q2 Oana tower lal David,  
\q2 Naweyukla ke soko ah in walwal ma oasr tausin mwe loang sripsripi kac.   
\q1
\v 5 Titi lom uh oana gazelle fusr lukwa,  
\q2 Oana deer fak uh ke eltal mongo inmasrlon kiuf uh.   
\q1
\v 6 Nga ac som ac muta fin inging in myrrh uh,  
\q2 Oayapa fin inging in mwe keng,  
\q2 Nwe ke na engyengsrik in lotu uh tuhme,  
\q2 Ac lohsr uh wanginla.   
\q1
\v 7 Kom su saoklana sik, kom arulana kato,  
\q2 Arulana fwel monum nufon!   
\b  
\q1
\v 8 Mutan su nga ako se, fahsru liki Fineol in acn Lebanon;  
\q2 Fahsru wiyu liki acn loessula Lebanon.  
\q1 Oatui liki Fineol Amana,  
\q2 Liki Eol Senir ac Eol Hermon,  
\q2 Fahsru liki acn ma lufin lion ac leopard oan we.   
\q1
\v 9 Mutan su nga ako in payuk se, ngetnget se lom an  
\q2 Ac ah soko kom wulu an,  
\q2 Arulana usla insiuk!   
\q1
\v 10 Mutan saok kiuk,  
\q2 Nga arulana pwar ke lungse lom uh.  
\q1 Lungse lom uh wo liki wain uh;  
\q2 Ono keng lom uh wo fohlo liki kain in mwe keng nukewa.   
\q1
\v 11 Mutan saok sik, ngoasrom emwem oana honey;  
\q2 Loum oana milk ac honey nu sik.  
\q1 Nuknuk lom uh keng oana foulin sak cedar Lebanon me.   
\q1
\v 12 Mutan se su arulana saok sik, el oana sie ima ma oan yen lukma,  
\q2 Sie ima kalkalyak, ac sie unon in kof kaul nu sin mwet saya,   
\q2
\v 13 Yen sak uh kapak arulana wo we.  
\q1 Elos kapak oana ima in sak pomegranate,  
\q2 Ac oswe fahko su arulana wo.  
\q1 Pacl nukewa pus sunun sak keng inge: henna, nard,   
\q2
\v 14 Saffron, calamus, ac cinnamon,  
\q2 Ac kain in mwe keng nukewa.  
\q1 Myrrh ac aloes wi pac kap we  
\q2 Wi kain in ono ma arulana keng.   
\q1
\v 15 Kof uh unonak ac aksroksrokye ima uh,  
\q2 Ac infacl srisrik sororror we,  
\q2 Ac kof uh asrma liki Fineol Lebanon.   
\sp Verse Lun Mutan Se  
\q1
\v 16 Tukakek, Eng Epang me.  
\q1 Eng Eir me, tuhme nu ke ima luk;  
\q2 Nwakla yen engyen uh ke foul keng.  
\q1 Lela mukul se su saok sik in tuku nu ke ima lal  
\q2 Ac mongo ke fokinsak wolana we.   
\c 5  
\sp Verse Lun Mukul Se  
\q1
\v 1 Mutan se su saok sik, su nga ako in payuk se,  
\q2 Nga utyak nu in ima luk.  
\q1 Nga kunsani mwe akkeng luk wi myrrh;  
\q2 Nga engankin eman honey luk  
\q3 ma oan in nien honey uh;  
\q2 Ac nga nim wain ac milk nimuk.  
\s1 Verse Lun Un Mutan Uh  
\q1 Komtal mwet kawuk luo an, mongo ac nim  
\q2 Nwe ke na komtal mutkakinya lungse lomtal!   
\s1 On Soko Akakosr  
\s1 Verse Lun Mutan Se  
\q1
\v 2 Ke nga oan in motul, insiuk ngetnget na.  
\q1 Oana ngan lohng mu el su nga lungse el towol srungul uh.  
\s1 Verse Lun Mukul Se  
\q1 Ikasla nga in utyak, mutan su saok sik,  
\q2 Kom su kuiyuk, ac oana wuleoa nutik.  
\q1 Insifuk sroksroki ke aunfong,  
\q2 Ac aunsifuk olalaek ke ohu uh.   
\s1 Verse Lun Mutan Se  
\q1
\v 3 Nga sarukla nuknuk luk ah tari;  
\q2 Mwe mea nga in sifil nuknukyang?  
\q1 Nga ohlla niuk tari;  
\q2 Mwe mea ngan sifil akfohkfokyela?   
\b  
\q1
\v 4 El su nga pwar se el isongang paol nu in mutunoa,  
\q2 Ac nga pulakin pwar na yohk insiuk.  
\v 5 Nga tukakek in ikasla elan utyak.  
\q1 Pouk mosrweyukla ke myrrh,  
\q2 Ac kufinpouk ke sronin myrrh  
\q2 Ke nga saplakang nu ke mwe ikak ke srungul uh.   
\q1
\v 6 Nga ikasla srungul uh nu sel su nga lungse,  
\q2 Tuh el nu som tari.  
\q1 Nga lukunna mulalla ke nga tia lohngak pusracl!  
\q1 Nga sokol tuh tia ku in konalak;  
\q2 Nga pangnol, a el tia topukyu.   
\b  
\q1
\v 7 Mwet topang su forfor taran siti uh elos liyeyuyak.  
\q2 Elos puokyuwi ac kanteyuwi;  
\q2 Mwet liyaung pot uh elos tulakunla nuknuk se ma afinyu.   
\q1
\v 8 Kowos mutan Jerusalem, wulema nu sik  
\q2 Lah kowos fin konauk el su nga lungse,  
\q2 Kowos ac fahkang nu sel lah nga kuf na pwaye ke nunkeyal.   
\s1 Verse Lun Un Mutan Uh  
\q1
\v 9 Kom su oaskulana inmasrlon mutan uh,  
\q2 Ya mukul se ingan sie liki na mukul nukewa?  
\q1 Mea se arulana wo kacl uh  
\q2 Ku kut in orek wulela nu sum kac?   
\s1 Verse Lun Mutan Se  
\q1
\v 10 Mukul se nga lungse inge el ku ac fokoko finsroa;  
\q2 Inmasrlon mukul nukewa, wangin sie oana el.   
\q1
\v 11 Mutal oana wolana lun gold uh;  
\q2 Aunsifal makoskos  
\q2 Ac sroalsroal oana sie won raven.   
\q1
\v 12 Atronmutal kato oana wuleoa sisken sie unon in kof,  
\q2 Wuleoa ma fasrfasr oana milk, ac tu pe infacl srisrik uh.   
\q1
\v 13 Foulin likintupal keng oana sie ima  
\q2 Ma sessela ke mahsrik ac ma keng uh.  
\q1 Ngoasrol oana kiuf uh,  
\q2 Ma sroksrok ke sronin myrrh.   
\q1
\v 14 Wo lumweyen paol,  
\q2 Ac el ringkin ring ma yunla ke wek saok.  
\q1 Manol fwel oana fweliyen ivory  
\q2 Ma naweyuk ke eot sapphire.   
\q1
\v 15 Nial oana sru orekla ke eot alabaster  
\q2 Ma loangeyukyak ke gold.  
\q1 Woiyen lumahl oana Fineol in acn Lebanon,  
\q2 Ac ku oana sak cedar we.   
\q1
\v 16 Emwem oalul ke nga ngok uh,  
\q2 Ac nga lungse ma nukewa kacl.  
\q1 Mutan Jerusalem,  
\q2 Pa inge luman kawuk luk su nga lungse.   
\c 6  
\sp Verse Lun Un Mutan Uh  
\q1
\v 1 Kom su kato oemeet inmasrlon mutan uh,  
\q2 Mukul se kom lungse ingan som nu oya?  
\q1 Fahkma nu sesr lah el fahsr nu ya,  
\q2 Kut in mau ku in kasrekom sokolak.   
\sp Verse Lun Mutan Se  
\q1
\v 2 Kuiyuk el som nu ke ima lal,  
\q2 Yen sak keng uh kapak we.  
\q1 El som kite un sheep natul in ima sac,  
\q2 Ac kinkin ros kiuf.   
\q1
\v 3 Mukul se nga lungse inge ma na luk, ac nga ma na lal.  
\q2 El mukena kite un kosro natul inmasrlon ros kiuf uh.   
\s1 On Soko Aklimekosr  
\sp Verse Lun Mukul Se  
\q1
\v 4 Mutan saok sik, kom arulana oasku oana acn Jerusalem,  
\q2 Kom kato oana siti fulat Tirzah,  
\q2 Oaskuiyom mwe kaksak ac arulana insewowo in liyeyuk.   
\q1
\v 5 Furokla motom likiyu;  
\q2 Ngetma lom an oru nga kofla in oru kutena ma.  
\q1 Aunsifom sroalsroal ac srosro oana un nani uh  
\q2 Ke ac putati fineol Gilead me.   
\q1
\v 6 Wihsum fasrfasr oana sheep  
\q2 Ma tufahna kalkulla ac owola.  
\q1 Tia soko selos fulukla;  
\q2 Nufonna arulana fas, ac kais soko oasr lainya.   
\q1
\v 7 Likintupom srusrsrusrame ye nuknuk minini lisringyen motom an.   
\q1
\v 8 Mansis finne oasr kasra onngoul ac mutan kulansap oalngoul kial tokosra,  
\q2 Wi mutan fusr puspis saya su tia ku in oekyukla.   
\q1
\v 9 Tusruktu mutan sefanna pa nga lungse uh,  
\q2 El arulana wo ac kato, oana sie wuleoa.  
\q1 El mutan sefanna nutin nina kial uh,  
\q2 Ac nina kial el kuloel.  
\q1 Mutan nukewa liyal ac kaksakunul;  
\q2 Kasra ac mutan kulansap kien tokosra elos yuk on in kaksak kacl.   
\b  
\q1
\v 10 Su mutan se inge, ku ngetngeta uh oana kalmen lotu uh?  
\q1 El arulana oasku ac saromrom,  
\q2 Ac srekuti oana faht uh ku malem uh.   
\q1
\v 11 Nga oatula inmasrlon sak almond uh  
\q2 In tuh liye sak fusr ma kap infahlfal uh,  
\q2 Ac liye sra sasu ke mah orak uh,  
\q2 Ac ros ma farengelik ke sak pomegranate.   
\q1
\v 12 Nga rrarakkom oru nga tufalak ke lungse luk uh,  
\q2 Oana sie mwet utuk chariot ke el ac rarala nu ke mweun uh.   
\sp Verse Lun Mutan Uh  
\q1
\v 13 Mutan fusr Shulam se ingan, foloko, foloko,  
\q1 Tuh nga in ku in tuni kom.  
\sp Verse Lun Mutan Se  
\q1 Efu ku kom lungse tuniyu  
\q2 Ke nga tacn inmasrlon mwet su takla tacn inge?   
\c 7  
\sp Verse Lun Mukul Se  
\q1
\v 1 Fisrak mutan, mutan fusr na kato se pa kom an!  
\q2 Niom arulana oasku in fahluk lom an.  
\q1 Finyepom uh raraun  
\q2 Oana ma mwet usrnguk ke tufahlfal uh orala.   
\q1
\v 2 Futom oana sie ahlu pol  
\q2 Ma wain keng uh tia wi lisr loac uh.  
\q1 Kapin siom oana tohktok in wheat se  
\q2 Ma ros kiuf uh raunela.   
\q1
\v 3 Titi lom uh oana deer fak lukwa,  
\q2 Ku kosro gazelle lukwa.   
\q1
\v 4 Inkwawom oana sie tower naweyukla ke ivory.  
\q1 Atronmotom oana lulu in kof in siti Heshbon  
\q2 Su oan sisken mutunpot lun siti pwengpeng sac.  
\q1 Infwem kato oana tower lun Lebanon  
\q2 Su tuyak suwohs ac tawi acn Damascus.   
\q1
\v 5 Kom pusrukak sifom nu lucng oana Fineol Carmel.  
\q2 Aunsifom pirakla ac saromrom oana nuknuk musresre na wowo;  
\q2 Katoiya uh ku in akmunasyela sie tokosra.   
\q1
\v 6 Kom arulana kato ac oasku;  
\q2 Lungse lom nu sik arulana akpwaryeyu.   
\q1
\v 7 Kom loes oasriksrik oana soko sak palm,  
\q2 Ac titi lom an oana ungin fokin palm uh.   
\q1
\v 8 Nga ac fanukya palm soko uh  
\q2 Ac filiya pouk ke fahko kac uh.  
\q1 Titi lom oana ungin grape uh sik,  
\q2 Ac momong lom uh keng oana foulin apple uh.   
\q1
\v 9 Ac oalum oana wain ma wo oemeet uh.  
\sp Verse Lun Mutan Se  
\q1 Fin ouinge, lela wain uh in sororla nu yurin el su saok sik,  
\q2 Ac kahkla fin ngoasrol ac wihsel.   
\q1
\v 10 Nga ma na lun el su nga lungse, ac el mwelyu na.   
\q1
\v 11 Fahsru, kom su saok sik. Lela kut in illa nu inimae  
\q2 Ac motullana we.   
\q1
\v 12 Kut ac fah toang na tukakek ac som nu ke ima in grape,  
\q2 Ac liye lah elos mutawauk in kapak,  
\q2 Ac liye lah ros uh mutawauk in farengelik,  
\q2 Ac oayapa in liye lah sak pomegranate oasr ros kac.  
\q1 Na nga ac fah akkalemye lungse luk nu sum uh e we.   
\q1
\v 13 Kom ac ku na in ngokak foul keng ke ros mandrake uh,\f + \fr 7:13 \fk mandrake: \ft Liye kalmac ke Kalmen Kutu Kas.\f*  
\q2 Ac fokinsak wowo nukewa pa na oan sisken srungul in lohm uh.  
\q1 Ku na safla luk, nga elosak kain mwe insewowo nukewa nu sum.   
\c 8  
\q1
\v 1 Nga ke in tamulel se luk pa kom,  
\q2 Ac in nina kiuk ah pa katiti kom ke titi lal uh,  
\q1 Na nga fin sun kom inkanek uh,  
\q2 Nga lukun ngokya motom ac mwet uh ac tia suk lah efu.   
\q1
\v 2 Nga lukun uskomla nu lohm sin nina kiuk,  
\q2 Kom in tuh luti nu sik ouiyen lungse uh.  
\q1 Nga lukun sot pac wain keng ac wo emah uh nu sum,  
\q2 Ac kom ac pula sronin pomegranate sunuk uh.   
\b  
\q1
\v 3 Nga ilung lac paol lasa,  
\q2 Ac lac paol layot kafisyuyang nu yorol.   
\b  
\q1
\v 4 Wulema nu sik, mutan Jerusalem,  
\q2 Lah kowos fah tia oru kutena ma in lusrong pacl in pwar lasr uh.   
\s1 On Soko Akonkosr  
\sp Verse Lun Un Mutan Uh  
\q1
\v 5 Su mutan se fahsru yen mwesis ah me,  
\q2 Fungfungla ke mwet se ma el lungse yohk?  
\sp Verse Lun Mutan Se  
\q1 Nga okaskomyak ye sak apple soko ah,  
\q2 Yen se ma kom tuh isusla we ah.   
\q1
\v 6 Kaliya insiom tuh in tia lungse kutena mwet sayuk;  
\q2 Nimet kom kafisya sie pacna mwet nu iniwom sayuk.  
\q1 Lungse uh ku, oana misa;  
\q2 Ac nunkeyen lungse uh fokoko oana kulyuk uh.  
\q1 Lungse ac ngutyak oana sie e firir  
\q2 Ac lalelik oana sie e lulap ma ac liksreni esukak acn uh.   
\q1
\v 7 Kof uh tia ku in fwela,  
\q2 Ac wangin pac sronot ku in konela.  
\q1 Tusruktu mwet se fin ke molela lungse ke kasrpal,  
\q2 Nunak in sufan mukefanna pa el ac eis kac uh.   
\sp Mwet Lin Mutan Sac  
\q1
\v 8 Oasr tamtael fusr se wiasr,  
\q2 Ac srakna srik tetel.  
\q1 Mea kut ac oru nu sel  
\q2 Fin oasr mukul ke payuk sel?   
\q1
\v 9 El fin oana sie pot  
\q2 Na kut ac musaela sie tower silver fac.  
\q1 Ac el fin oana sie srungul  
\q2 Na kut ac fah nawella ke sak cedar.   
\sp Verse Lun Mutan Se  
\q1
\v 10 Pot soko pa nga,  
\q2 Ac titi luk uh pa tower kac.  
\q1 Mukul se nga lungse uh etu lah ke nga welul uh  
\q2 Nga konauk insewowo ac misla.   
\sp Verse Lun Mukul Se  
\q1
\v 11 Oasr ima in grape se lal Solomon  
\q2 In acn se pangpang Baal Hamon.  
\q1 Oasr mwet ima ma orekmakin acn sac,  
\q2 Ac kais sie selos moli nu sel ke sie tausin ipin mani silver.   
\q1
\v 12 Solomon, eis ipin silver tausin lom an,  
\q2 Ac sang luofoko nu sin mwet ima uh.  
\q1 A funu nga, oasr ima in grape luk sefacna!   
\b  
\q1
\v 13 Mutan saok sik, lela nga in lohng pusrem inima uh me,  
\q2 Mwet kawuk luk elos soano in lohng ke kom ac kaskas.   
\sp Verse Lun Mutan Se  
\q1
\v 14 Kuiyuk, yume nu yuruk oana soko gazelle,  
\q2 Oana soko deer mukul fusr fineol uh, yen mahsrik keng uh kap we.   