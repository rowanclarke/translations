\c 5  
\s1 Esther Te Manghai Taengla Cet  
\p
\v 1 A \w hnin|strong="H3117"\w* \w thum|strong="H7992"\w* \w dongah|strong="H9999"\w* tah \w Esther|strong="H0635"\w* loh \w manghai|strong="H4438"\w* himbai a \w bai|strong="H3847"\w* \w tih|strong="H9999"\w* \w manghai|strong="H4428"\w* \w im|strong="H1003"\w* \w hmai|strong="H5227"\w* kah, \w manghai|strong="H4428"\w* \w im|strong="H1003"\w* \w vongup|strong="H2691"\w* kah a \w ken|strong="H6442"\w* \w ah|strong="H9996"\w* \w pai|strong="H5975"\w*. Te \w vaengah|strong="H9999"\w* \w manghai|strong="H4428"\w* tah \w im|strong="H1003"\w* \w thohka|strong="H6607"\w* \w hmai|strong="H5227"\w*, \w manghai|strong="H4438"\w* \w im|strong="H1003"\w* \w kah|strong="H9996"\w* \w a|strong="H9909"\w* \w manghai|strong="H4438"\w* \w ngolkhoel|strong="H3678"\w* \w dongah|strong="H5921"\w* \w ngol|strong="H3427"\w*.  
