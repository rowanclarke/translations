\v 19 ¡Haya un tratado \w entre|strong="H5921"\w* tú \w y|strong="H5921"\w* \w yo|strong="H2009"\w*, \w como|strong="H5921"\w* \w hubo|strong="H2009"\w* \w entre|strong="H5921"\w* \w mi|strong="H5921"\w* padre \w y|strong="H5921"\w* tu padre! \w Mira|strong="H2009"\w*, \w te|strong="H5921"\w* \w envío|strong="H7971"\w* un obsequio \w de|strong="H5921"\w* \w plata|strong="H3701"\w* \w y|strong="H5921"\w* \w oro|strong="H2091"\w*. ¡\w Vé|strong="H3212"\w* \w y|strong="H5921"\w* rompe tu tratado \w con|strong="H5921"\w* \w Baasa|strong="H1201"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* aparte \w de|strong="H5921"\w* \w mí|strong="H5921"\w*!
