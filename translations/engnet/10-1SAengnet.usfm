\p
\v 19  \w So|strong="H7971"\w* \w Saul|strong="H7586"\w* \w sent|strong="H7971"\w* \w messengers|strong="H4397"\w* \w to|strong="H7971"\w* \w Jesse|strong="H3448"\w* \w and|strong="H1121"\w* said, “\w Send|strong="H7971"\w* \w me|strong="H7971"\w* \w your|strong="H7971"\w* \w son|strong="H1121"\w* \w David|strong="H1732"\w*, \w who|strong="H1121"\w* \w is|strong="H1121"\w* \w out|strong="H7971"\w* \w with|strong="H1732"\w* \w the|strong="H7971"\w* \w sheep|strong="H6629"\w*.  
