\id TIT - Biblica® Open Igbo Contemporary Bible 2020
\h Taịtọs
\toc1 Taịtọs
\toc2 Taịtọs
\toc3 Taị
\mt1 Taịtọs
\c 1
\p 
\v 1 Akwụkwọ ozi a si nʼaka m, Pọl, odibo Chineke, na onyeozi Jisọs Kraịst, onye ahọpụtara ime ka okwukwe ndị Chineke, na nghọta banyere ịmara eziokwu ahụ na-eduba na ndụ ịsọpụrụ Chineke gaa nʼihu,
\v 2 nke a dabere nʼolileanya maka ndụ ebighị ebi, nke Chineke onye na-adịghị agha ụgha kwerelarị na nkwa tupu mmalite nke oge.
\v 3 Mgbe oge imezu nkwa ahụ ruru, o mere ka okwu ya pụta ìhè site na nkwusa oziọma, nke e nyefere m nʼaka idebe, dị ka Chineke Onye nzọpụta anyị si nye ya nʼiwu.
\b
\p 
\v 4 Ọ bụ gị Taịtọs, ezi nwa m nwoke nʼime okwukwe nke anyị nwekọrọ.
\b
\p Ka amara na udo nke sitere na Chineke bụ Nna, na Kraịst Jisọs Onye nzọpụta anyị dịrị gị.
\b
\s1 Ọrụ dịrị Taịtọs
\p 
\v 5 Ahapụrụ m gị na Kriit ka i dozie ihe ụfọdụ a na-edozibeghị, ka ị họpụtakwa ndị okenye nʼobodo niile, dị ka m siri nye gị nʼiwu.
\v 6 Ọ ga-abụ onye a na-enweghị ihe ịta ụta, ọ ga-abụ onye na-alụ otu nwanyị. Ụmụ ya bụ ndị kwere ekwe, ndị ama na ha anaghị ebi ndụ ọjọọ, maọbụ na-eme isiike.
\v 7 Ebe ọ bụ na onye nlekọta nʼahụ ihe banyere chọọchị Chineke, ọ ga-abụ onye na-enweghị ihe ịta ụta. Ọ gaghị abụ onye nganga, onye na-ewe iwe ọkụ, onye na-aṅụbiga mmanya oke, onye na-alụ ọgụ mgbe niile, onye hụrụ ego nʼanya.
\v 8 Ọ ga-abụ onye na-anabata ndị ọbịa, na onye na-ahụ ezi ihe nʼanya. Ọ ga-abụ onye na-akwanyere onwe ya ugwu, ezi mmadụ ụzọ ya kwụ ọtọ, onye dị nsọ, na onyeisi zuruoke.
\v 9 Ọ ga-abụkwa onye jidesiri oziọma ahụ nke kwesiri ntụkwasị obi aka ike dịka eziri ya. Nke ga-eme ka o nwe ike gbaa ndị ọzọ ume site na ozizi ahụ nke zuruoke, nakwa ịtụ ndị ahụ na-eguzogide ya mmehie ha nʼihu.
\s1 Igbochi ndị ozizi ụgha
\p 
\v 10 Nʼihi na e nwere ọtụtụ mmadụ ndị na-ekweghị, ndị na-ekwu okwu efu, na ndị aghụghọ, nke ka nke, ndị si nʼotu ndị obibi ugwu pụta.
\v 11 Aghaghị ịkwụsị ha maka na ha na-akụzi ihe ha ekwesighị ikuzi nʼihi ego, si otu ahụ na-eme ka ọtụtụ ezinaụlọ gbasaa.
\v 12 Ọ bụ otu onye nʼime ha, onye bụkwa onye amụma ha kwuru okwu banyere ha sị, “Ndị Kriit niile bụ ndị ụgha. Ha kwara obi nʼazụ dị ka anụ ọhịa jọrọ njọ. Ha bụ ndị umengwụ nwere akpịrị ogologo.”
\v 13 Nʼezie, okwu a bụ eziokwu. Nʼihi nke a, baara ha mba nʼolu ike banyere mmehie ha ka ha nwee ike zuo oke nʼokwukwe,
\v 14 ka ha kwụsị ige ntị nʼakụkọ ifo ndị Juu na-akọ, maọbụ iwu nke ndị jụrụ ịnabata eziokwu nyere.
\v 15 Ihe niile dị ọcha nʼebe ndị dị ọcha nọ, o nweghị ihe ọbụla dị ọcha nʼebe ndị rụrụ arụ na ndị na-ekweghị ekwe nọ. Nʼihi na uche ha na akọnuche ha rụrụ arụ.
\v 16 Ha na-ekwupụta na ha maara Chineke, ma ha ji omume ha na-agọnarị ya. Ha bụkwa ndị na-akpọ mmadụ ibe ha asị, ndị isiike, na ndị na-adịghị ike nʼezi ọrụ ọbụla.
\c 2
\s1 Ezi ozizi na ezi agwa
\p 
\v 1 Nʼakụkụ nke gị, na-akụzi ihe kwesiri eziokwu nke okwukwe.
\v 2 Gwa ndị okenye nwoke ka ha nwee anya udo, ka ha nwee akọnuche zuruoke, ka ha bụrụ ndị kwesiri nsọpụrụ, ndị okwukwe ha siri ike, ndị na-ahụ ibe ha nʼanya, na ndị nwekwara ntachiobi.
\p 
\v 3 Nʼotu aka ahụ, gwa ndị okenye nwanyị ka ha na-eme omume dị ka ụmụ nwanyị dị nsọ. Ka ha ghara ịbụ ndị na-agba asịrị maọbụ ohu nke ịṅụbiga mmanya oke. Kama ha na-akụzi ihe dị mma.
\v 4 Ha ga-esi otu a kuziere ụmụ agbọghọ ka ha ga-esi hụ di ha na ụmụ ha nʼanya.
\v 5 Ka ha bụrụkwa ndị akọnuche ha zuruoke, ndị dị ọcha nʼobi, ndị na-edozi ezinaụlọ di ha, ndị na-eme ebere, ndị na-edo onwe ha nʼokpuru di ha, ka onye ọbụla ghara ikwulu okwu Chineke.
\p 
\v 6 Nʼotu ụzọ ahụ kwa, gbaakwa ụmụ okorobịa ume ka ha jide onwe ha.
\v 7 Nʼihe niile ị na-eme, mee onwe gị ihe ịma atụ ndị ọzọ ga na-eṅomi nʼime ezi omume. Na nkuzi gị niile, gosikwa izuoke na ikwesi ntụkwasị obi.
\v 8 Ka ozi gị bụrụ nke kwụ ọtọ mmadụ apụghị ịma ikpe, ka ihere mee onye na-agbagha gị okwu, ebe ọ bụ na onweghi ihe ọjọọ ọ ga-ekwu gbasara anyị.
\p 
\v 9 Gwa ndị ohu ka ha na-erubere ndị nwe ha isi, ka ha na-eme ihe ga-atọ onyenwe ha ụtọ mgbe niile. Ka ha hapụ ịsa ndị nwe ha okwu,
\v 10 ka ha ghara izu ohi, kama ka ha gosi na ha bụ ndị kwesiri ntụkwasị obi. Nʼụzọ dị otu a, ha ga-ewetara ihe anyị na-akụzi maka Chineke Onye nzọpụta anyị otuto nʼihe niile ha na-eme.
\p 
\v 11 Nʼihi na Chineke emela ka amara ya nke wetaara mmadụ niile nzọpụta pụta ìhè.
\v 12 Ọ bụkwa amara a na-akụziri anyị ka anyị jụ ndụ asọpụrụghị Chineke na nke ịgbaso ọchịchọ ọjọọ dị nʼụwa, kama ka anyị bie ndụ dị ka ndịisi zuruoke na ndụ ezi omume, nakwa ịtụ egwu Chineke nʼọgbọ nke oge a.
\v 13 Otu a ka anyị ga-esi na-eche olileanya anyị dị ngọzị bụ ọbịbịa nke otuto nke Chineke anyị dị ukwuu, na Onye nzọpụta anyị bụ Jisọs Kraịst.
\v 14 Ọ bụ ya jiri onwe ya chụọ aja nʼihi anyị, ka ọ gbapụta anyị site nʼajọ omume anyị niile, na ido ndị ga-abụ ndị nke ya ọcha nye onwe ya, ndị ọ na-agụ agụụ ime ihe dị mma mgbe niile.
\p 
\v 15 Na-akụzi ihe ndị a, werekwa ha na-adụ ndị gị ọdụ site nʼikike niile i nwere. Werekwa ha na-atụ ha mmehie ha nʼihu. Ka mmadụ ọbụla ghara ilelị gị anya.
\c 3
\s1 Ime ihe dị mma
\p 
\v 1 Chetara ndị nke gị ka ha doo onwe ha nʼokpuru ndịisi na ndị ọchịchị, ka ha rubere ha isi, dịkwa njikere ịrụ ọrụ ọma ọbụla.
\v 2 Gwa ha ka ha ghara ikwulu onye ọbụla, ka ha gharakwa ịlụ ọgụ, kama, ka ha bụrụ enyi mmadụ niile, na-egosikwa ịdị nwayọọ ha nʼebe mmadụ niile nọ.
\p 
\v 3 Nʼihi na mbụ, anyị onwe anyị bụ ndị nzuzu, ndị na-enupu isi, na ndị na-enweghị uche. Anyị bụ ohu agụụ ihe ọjọọ, na ihe ụtọ dị iche iche. Anyị biri ndụ obi ọjọọ na ekworo, na ịkpọrịta onwe anyị asị.
\v 4 Ma mgbe obiọma na ịhụnanya Chineke Onye nzọpụta anyị pụtara ihe,
\v 5 ọ zọpụtara anyị, ma ọ bụghị nʼihi ezi ihe ndị anyị mere, kama ọ bụ site nʼebere ya. Ọ zọpụtara anyị site na nsacha nke ịmụ ọzọ na nnwogharị nke Mmụọ Nsọ,
\v 6 onye ọ wụsara anyị nʼuju site nʼOnye nzọpụta anyị bụ Jisọs Kraịst,
\v 7 ka ọ bụrụ na ebe e sitere nʼamara gụọ anyị dịka ndị ezi omume, anyị ga-abụ ndị nketa, ndị nwere olileanya ndụ ebighị ebi.
\v 8 Okwu a kwesiri ntụkwasị obi, ọ ga-amasị m ma i kwusie ihe ndị a ike, ka ndị kweere na Chineke, lezie anya nʼịrụ ezi ọrụ. Ihe ndị a dị mma na-abakwara mmadụ uru.
\p 
\v 9 Ma zere ịrụ ụka nzuzu na ịgụ agbụrụ ọmụmụ, esemokwu niile, na ọgụ niile ndị mmadụ na-alụ banyere iwu. Ihe ndị a niile abaghị uru ọbụla, ha bụ ihe efu.
\v 10 Gbasara onye na-akpa oke, ị dụchaa ya ọdụ ihe dịka otu ugboro maọbụ abụọ, leghara ya anya.
\v 11 Ebe ị ma na onye dị otu a bụ onye ndahie na onye ajọọ omume, o jirila aka ya maa onwe ya ikpe.
\b
\s1 Okwu mmechi
\p 
\v 12 Ana m akwado izitere gị Atemas maọbụ Taịkikọs. Gbalịa bịakwute m na Nikopolis, maka nʼebe ahụ ka m kpebiri ịnọ nʼoge oyi.
\v 13 Gbaa mbọ zipụ Zenas bụ onye ọkaikpe, na Apọlọs, ngwangwa nʼije ha. Hụkwa na ha ji ihe niile dị ha mkpa.
\b
\p 
\v 14 Nʼihi na ọ dị mkpa ka ndị anyị mụta inyere ndị niile chọrọ enyemaka ha aka. Ọ bụ nke a ga-eme ka ha bụrụ ndị na-amị mkpụrụ.
\b
\p 
\v 15 Ndị niile mụ na ha nọ nʼebe a na-ekele gị.
\p Kelekwara anyị ndị niile hụrụ anyị nʼanya nʼime okwukwe.
\b
\p Ka amara dịnyere unu niile.
