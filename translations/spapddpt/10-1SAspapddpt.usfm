\p 
\v 20 \w Samuel|strong="H8050"\w* acercó \w a|strong="H3068"\w* las \w tribus|strong="H7626"\w* de \w Israel|strong="H3478"\w*, y fue seleccionada \w la|strong="H3605"\w* \w tribu|strong="H7626"\w* de \w Benjamín|strong="H1144"\w*.
\v 21 Luego acercó \w a|strong="H3068"\w* la \w tribu|strong="H7626"\w* \w de|strong="H1121"\w* \w Benjamín|strong="H1144"\w* según sus \w familias|strong="H4940"\w*, y \w fue|strong="H3808"\w* designada la \w familia|strong="H4940"\w* \w de|strong="H1121"\w* Matri. \w De|strong="H1121"\w* ella \w Saúl|strong="H7586"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Cis|strong="H7027"\w*, \w fue|strong="H3808"\w* seleccionado, pero cuando \w lo|strong="H3808"\w* \w buscaron|strong="H1245"\w*, \w no|strong="H3808"\w* \w fue|strong="H3808"\w* \w hallado|strong="H4672"\w*.
\v 22 Entonces \w consultaron|strong="H7592"\w* \w otra|strong="H5750"\w* vez \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: ¿\w Ese|strong="H1931"\w* varón ya llegó \w aquí|strong="H2009"\w*?
\p \w Y|strong="H3068"\w* respondió \nd \w Yavé|strong="H3068"\w*\nd*: \wj Ahí \w está|strong="H1931"\w*, \w escondido|strong="H2244"\w* entre \w el|strong="H1931"\w* equipo militar.\wj*
\p 
\v 23 \w Corrieron|strong="H7323"\w* y \w lo|strong="H3605"\w* sacaron \w de|strong="H5971"\w* \w allí|strong="H8033"\w*. Cuando \w se|strong="H5971"\w* presentó \w en|strong="H8432"\w* \w medio|strong="H8432"\w* del \w pueblo|strong="H5971"\w*, vieron \w que|strong="H5971"\w* \w de|strong="H5971"\w* \w los|strong="H3605"\w* \w hombros|strong="H7926"\w* \w para|strong="H3320"\w* \w arriba|strong="H4605"\w* era más \w alto|strong="H1361"\w* \w que|strong="H5971"\w* \w todos|strong="H3605"\w*.
\v 24 \w Samuel|strong="H8050"\w* dijo \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w*: ¿\w Vieron|strong="H7200"\w* \w al|strong="H4428"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* eligió? \w En|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w nadie|strong="H3605"\w* hay \w como|strong="H3588"\w* \w él|strong="H3588"\w*.
\p \w Entonces|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* exclamó: ¡\w Viva|strong="H2421"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w*!
\p 
\v 25 Luego \w Samuel|strong="H8050"\w* explicó al \w pueblo|strong="H5971"\w* \w los|strong="H3605"\w* procedimientos del \w reino|strong="H4410"\w* y \w los|strong="H3605"\w* \w escribió|strong="H3789"\w* en \w el|strong="H3605"\w* rollo \w que|strong="H5971"\w* presentó \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*. Después \w Samuel|strong="H8050"\w* \w despidió|strong="H7971"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, \w cada|strong="H3605"\w* uno \w a|strong="H3068"\w* su \w casa|strong="H1004"\w*.
\p 
\v 26 \w Saúl|strong="H7586"\w* \w fue|strong="H3212"\w* \w también|strong="H1571"\w* \w a|strong="H3068"\w* su \w casa|strong="H1004"\w* \w en|strong="H5973"\w* \w Gabaa|strong="H1390"\w*, \w y|strong="H1571"\w* algunos hombres \w valientes|strong="H2428"\w* cuyos corazones \nd ʼElohim\nd* \w tocó|strong="H5060"\w* \w fueron|strong="H3212"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w*.
\v 27 Pero algunos \w hombres|strong="H1121"\w* \w perversos|strong="H1121"\w* dijeron: ¿\w Cómo|strong="H4100"\w* \w nos|strong="H4100"\w* \w va|strong="H3068"\w* \w a|strong="H3068"\w* \w salvar|strong="H3467"\w* \w éste|strong="H2088"\w*? \w Lo|strong="H4100"\w* despreciaron y \w no|strong="H3808"\w* le llevaron algún \w presente|strong="H4503"\w*. Pero \w él|strong="H1121"\w* disimuló.
\c 11
\s1 Derrota de los amonitas
\p 
\v 1 Nahas amonita \w subió|strong="H5927"\w* \w y|strong="H5921"\w* acampó \w contra|strong="H5921"\w* \w Jabes|strong="H3003"\w* \w de|strong="H5921"\w* \w Galaad|strong="H1568"\w*. \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* hombres \w de|strong="H5921"\w* \w Jabes|strong="H3003"\w* dijeron \w a|strong="H3068"\w* Nahas: Pacten \w con|strong="H5921"\w* \w nosotros|strong="H3605"\w* \w y|strong="H5921"\w* \w les|strong="H5921"\w* \w serviremos|strong="H5647"\w*.
\p 
\v 2 Nahas amonita \w les|strong="H5921"\w* respondió: \w Con|strong="H5921"\w* \w esta|strong="H2063"\w* condición pactaré \w con|strong="H5921"\w* ustedes: \w Que|strong="H5921"\w* \w a|strong="H3068"\w* \w cada|strong="H3605"\w* uno \w de|strong="H5921"\w* ustedes \w les|strong="H5921"\w* saque \w el|strong="H5921"\w* \w ojo|strong="H5869"\w* \w derecho|strong="H3225"\w*, \w y|strong="H5921"\w* \w ponga|strong="H7760"\w* \w esta|strong="H2063"\w* \w afrenta|strong="H2781"\w* \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*.
\p 
\v 3 \w Entonces|strong="H3117"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* de \w Jabes|strong="H3003"\w* le dijeron: \w Danos|strong="H7503"\w* \w siete|strong="H7651"\w* \w días|strong="H3117"\w* para \w que|strong="H3117"\w* \w enviemos|strong="H7971"\w* \w mensajeros|strong="H4397"\w* por \w todo|strong="H3605"\w* \w el|strong="H3605"\w* territorio de \w Israel|strong="H3478"\w*, y si no hay \w quien|strong="H3605"\w* nos libre, nos rendiremos \w a|strong="H3068"\w* ti.
\p 
\v 4 Cuando \w los|strong="H3605"\w* \w mensajeros|strong="H4397"\w* llegaron \w a|strong="H3068"\w* \w Gabaa|strong="H1390"\w* \w de|strong="H5971"\w* \w Saúl|strong="H7586"\w*, \w dijeron|strong="H1697"\w* estas \w palabras|strong="H1697"\w* \w a|strong="H3068"\w* oídos del \w pueblo|strong="H5971"\w*, y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w alzó|strong="H5375"\w* su \w voz|strong="H6963"\w* y \w lloró|strong="H1058"\w*.
\v 5 Aconteció \w que|strong="H3588"\w* \w Saúl|strong="H7586"\w* llegaba \w del|strong="H4480"\w* \w campo|strong="H7704"\w* tras \w los|strong="H3588"\w* \w bueyes|strong="H1241"\w*, \w y|strong="H3588"\w* preguntó: ¿\w Qué|strong="H3588"\w* le pasa \w al|strong="H4480"\w* \w pueblo|strong="H5971"\w*? ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* \w llora|strong="H1058"\w*? \w Y|strong="H3068"\w* le \w hablaron|strong="H1697"\w* las \w palabras|strong="H1697"\w* \w de|strong="H4480"\w* \w los|strong="H3588"\w* hombres \w de|strong="H4480"\w* \w Jabes|strong="H3003"\w*.
\p 
\v 6 Cuando \w él|strong="H5921"\w* \w oyó|strong="H8085"\w* estas \w palabras|strong="H1697"\w*, \w el|strong="H5921"\w* \w Espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd* vino poderosamente \w sobre|strong="H5921"\w* \w Saúl|strong="H7586"\w*, \w y|strong="H5921"\w* su ira \w se|strong="H5921"\w* encendió muchísimo.
\v 7 \w Tomó|strong="H3947"\w* un \w par|strong="H6776"\w* \w de|strong="H5921"\w* \w bueyes|strong="H1241"\w*, \w los|strong="H5921"\w* cortó \w en|strong="H5921"\w* trozos \w y|strong="H5921"\w* \w los|strong="H5921"\w* repartió \w por|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* territorio \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w por|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* \w mensajeros|strong="H4397"\w* \w que|strong="H5921"\w* decían: \w Así|strong="H3541"\w* \w se|strong="H5921"\w* \w hará|strong="H6213"\w* \w con|strong="H5921"\w* \w los|strong="H5921"\w* \w bueyes|strong="H1241"\w* \w del|strong="H5921"\w* \w que|strong="H5921"\w* \w no|strong="H6213"\w* \w salga|strong="H3318"\w* tras \w Saúl|strong="H7586"\w* \w y|strong="H5921"\w* \w Samuel|strong="H8050"\w*. \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w temor|strong="H6343"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w*, \w y|strong="H5921"\w* \w salieron|strong="H3318"\w* \w como|strong="H5921"\w* un solo hombre.
\v 8 Les pasó revista en Bezec: \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w eran|strong="H1961"\w* 300.000, y \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w* 30.000.
\p 
\v 9 \w Y|strong="H3068"\w* dijeron \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w mensajeros|strong="H4397"\w* \w que|strong="H1961"\w* llegaron: \w Así|strong="H3541"\w* dirán \w a|strong="H3068"\w* \w los|strong="H1961"\w* hombres de \w Jabes|strong="H3003"\w* de \w Galaad|strong="H1568"\w*: \w Mañana|strong="H4279"\w*, al calentar el \w sol|strong="H8121"\w*, \w serán|strong="H1961"\w* librados. \w Los|strong="H1961"\w* \w mensajeros|strong="H4397"\w* \w fueron|strong="H1961"\w* \w y|strong="H3541"\w* lo informaron \w a|strong="H3068"\w* \w los|strong="H1961"\w* hombres de \w Jabes|strong="H3003"\w*, \w y|strong="H3541"\w* ellos \w se|strong="H1961"\w* alegraron.
\v 10 Entonces \w los|strong="H3605"\w* \w de|strong="H5869"\w* \w Jabes|strong="H3003"\w* les dijeron \add a los amonitas\add*: \w Mañana|strong="H4279"\w* \w saldremos|strong="H3318"\w* \w a|strong="H3068"\w* ustedes, y \w hagan|strong="H6213"\w* con \w nosotros|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* les parezca \w bien|strong="H2896"\w*.
\p 
\v 11 \w En|strong="H5704"\w* la madrugada \w Saúl|strong="H7586"\w* \w dispuso|strong="H7760"\w* \w al|strong="H5704"\w* \w pueblo|strong="H5971"\w* \w en|strong="H5704"\w* \w tres|strong="H7969"\w* \w escuadrones|strong="H7218"\w*. \w Entre|strong="H8432"\w* las \w tres|strong="H7969"\w* \w y|strong="H5704"\w* las seis \w de|strong="H5704"\w* la \w mañana|strong="H1242"\w* entraron \w en|strong="H5704"\w* \w medio|strong="H8432"\w* del \w campamento|strong="H4264"\w* \w y|strong="H5704"\w* atacaron \w a|strong="H3068"\w* \w los|strong="H1961"\w* amonitas \w hasta|strong="H5704"\w* \w el|strong="H4264"\w* calor del \w día|strong="H3117"\w*, \w y|strong="H5704"\w* \w el|strong="H4264"\w* resto \w fue|strong="H1961"\w* dispersado \w sin|strong="H3808"\w* \w que|strong="H3808"\w* quedaran \w dos|strong="H8147"\w* \w de|strong="H5704"\w* ellos \w juntos|strong="H3162"\w*.
\p 
\v 12 Entonces \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* preguntó \w a|strong="H3068"\w* \w Samuel|strong="H8050"\w*: ¿\w Quiénes|strong="H4310"\w* son \w los|strong="H5921"\w* \w que|strong="H4310"\w* preguntaban \w si|strong="H5921"\w* \w reinará|strong="H4427"\w* \w Saúl|strong="H7586"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*? ¡Entréguennos \w a|strong="H3068"\w* esos hombres \w para|strong="H5921"\w* \w que|strong="H4310"\w* \w los|strong="H5921"\w* matemos!
\p 
\v 13 \w Saúl|strong="H7586"\w* dijo: \w Ninguno|strong="H3808"\w* \w morirá|strong="H4191"\w* \w hoy|strong="H3117"\w*, \w porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* dio liberación \w en|strong="H3588"\w* \w Israel|strong="H3478"\w*.
\p 
\v 14 \w Samuel|strong="H8050"\w* dijo al \w pueblo|strong="H5971"\w*: Vengan, \w vayamos|strong="H3212"\w* \w a|strong="H3068"\w* \w Gilgal|strong="H1537"\w* y renovemos \w allí|strong="H8033"\w* el \w reino|strong="H4410"\w*.
\v 15 Así \w que|strong="H5704"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w Gilgal|strong="H1537"\w*, \w y|strong="H5704"\w* confirmaron \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* \w como|strong="H5704"\w* \w rey|strong="H4427"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w en|strong="H5704"\w* \w Gilgal|strong="H1537"\w*. \w Allí|strong="H8033"\w* ofrecieron \w sacrificios|strong="H2077"\w* \w de|strong="H6440"\w* paz \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w Saúl|strong="H7586"\w* \w y|strong="H5704"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* tuvieron \w gran|strong="H3966"\w* regocijo.
\c 12
\s1 Exhortación de Samuel
\p 
\v 1 Entonces \w Samuel|strong="H8050"\w* dijo \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*: \w Ciertamente|strong="H2009"\w* \w escuché|strong="H8085"\w* su \w voz|strong="H6963"\w* \w en|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \w me|strong="H5921"\w* dijeron. Constituí un \w rey|strong="H4428"\w* \w que|strong="H5921"\w* \w reine|strong="H4427"\w* \w sobre|strong="H5921"\w* ustedes.
\v 2 \w Ahora|strong="H6258"\w*, miren, su \w rey|strong="H4428"\w* marcha \w al|strong="H5704"\w* frente \w de|strong="H6440"\w* ustedes. \w Yo|strong="H2009"\w* \w ya|strong="H2088"\w* soy anciano \w y|strong="H5704"\w* canoso, \w y|strong="H5704"\w* \w también|strong="H2088"\w* mis \w hijos|strong="H1121"\w* \w están|strong="H2088"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ustedes. \w Desde|strong="H5704"\w* \w mi|strong="H2009"\w* \w juventud|strong="H5271"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w* \w yo|strong="H2009"\w* \w anduve|strong="H1980"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ustedes.
\v 3 \w Aquí|strong="H2005"\w* estoy, testifiquen \w contra|strong="H5048"\w* \w mí|strong="H6030"\w* en presencia \w de|strong="H5048"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w y|strong="H7794"\w* \w de|strong="H5048"\w* su \w ungido|strong="H4899"\w*, \w si|strong="H2005"\w* \w tomé|strong="H3947"\w* \w el|strong="H4310"\w* \w buey|strong="H7794"\w* \w o|strong="H3068"\w* \w el|strong="H4310"\w* \w asno|strong="H2543"\w* \w de|strong="H5048"\w* alguno, \w si|strong="H2005"\w* calumnié \w a|strong="H3068"\w* alguien, \w si|strong="H2005"\w* agravié \w a|strong="H3068"\w* alguno, \w o|strong="H3068"\w* \w si|strong="H2005"\w* \w de|strong="H5048"\w* algún modo acepté soborno ante lo \w cual|strong="H4310"\w* cerré mis \w ojos|strong="H5869"\w*. Yo se lo restituiré.
\p 
\v 4 Entonces dijeron: \w Nunca|strong="H3808"\w* nos calumniaste, \w ni|strong="H3808"\w* agraviaste, \w ni|strong="H3808"\w* \w tomaste|strong="H3947"\w* \w algo|strong="H3972"\w* de \w mano|strong="H3027"\w* de algún hombre.
\p 
\v 5 \w Y|strong="H3068"\w* \w él|strong="H3588"\w* \w les|strong="H3972"\w* dijo: \nd \w Yavé|strong="H3068"\w*\nd* \w es|strong="H2088"\w* \w testigo|strong="H5707"\w* contra ustedes \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w ungido|strong="H4899"\w* \w es|strong="H2088"\w* \w testigo|strong="H5707"\w* \w hoy|strong="H3117"\w*, \w que|strong="H3588"\w* \w nada|strong="H3808"\w* \w hallaron|strong="H4672"\w* \w en|strong="H3588"\w* mi \w mano|strong="H3027"\w*.
\p \w Ellos|strong="H3027"\w* respondieron: \w Es|strong="H2088"\w* \w testigo|strong="H5707"\w*.
\p 
\v 6 \w Samuel|strong="H8050"\w* dijo al \w pueblo|strong="H5971"\w*: \nd \w Yavé|strong="H3068"\w*\nd* es \w el|strong="H6213"\w* \w que|strong="H5971"\w* designó \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* Aarón, \w Quien|strong="H6213"\w* \w sacó|strong="H5927"\w* \w a|strong="H3068"\w* sus antepasados \w de|strong="H5971"\w* la tierra \w de|strong="H5971"\w* \w Egipto|strong="H4714"\w*.
\v 7 \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, estén quietos, \w para|strong="H3320"\w* \w que|strong="H6258"\w* \w yo|strong="H6213"\w* razone con ustedes \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* sobre \w todos|strong="H3605"\w* \w los|strong="H3605"\w* actos justos \w que|strong="H6258"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w hizo|strong="H6213"\w* con ustedes y con sus antepasados.
\p 
\v 8 \w Después|strong="H3427"\w* \w que|strong="H2088"\w* \w Jacob|strong="H3290"\w* entró \w en|strong="H3318"\w* \w Egipto|strong="H4714"\w*, sus antepasados \w clamaron|strong="H2199"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, y \nd \w Yavé|strong="H3068"\w*\nd* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* y \w a|strong="H3068"\w* Aarón, quienes \w sacaron|strong="H3318"\w* \w a|strong="H3068"\w* sus antepasados de \w Egipto|strong="H4714"\w*, y \w los|strong="H3427"\w* establecieron \w en|strong="H3318"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*.
\p 
\v 9 Pero \w ellos|strong="H3027"\w* se \w olvidaron|strong="H7911"\w* \w de|strong="H8269"\w* \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*, y Él los entregó en \w mano|strong="H3027"\w* \w de|strong="H8269"\w* \w Sísara|strong="H5516"\w*, \w jefe|strong="H8269"\w* del \w ejército|strong="H6635"\w* \w de|strong="H8269"\w* Hazor, en \w mano|strong="H3027"\w* \w de|strong="H8269"\w* los \w filisteos|strong="H6430"\w*, y en \w mano|strong="H3027"\w* del \w rey|strong="H4428"\w* \w de|strong="H8269"\w* \w Moab|strong="H4124"\w*, quienes \w pelearon|strong="H3898"\w* contra \w ellos|strong="H3027"\w*.
\v 10 \w Entonces|strong="H3588"\w* \w ellos|strong="H3027"\w* \w clamaron|strong="H2199"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: \w Pecamos|strong="H2398"\w*, abandonamos \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w y|strong="H3588"\w* servimos \w a|strong="H3068"\w* \w los|strong="H3588"\w* baales \w y|strong="H3588"\w* \w a|strong="H3068"\w* Astarot. ¡\w Líbranos|strong="H5337"\w* \w ahora|strong="H6258"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* nuestros enemigos, \w y|strong="H3588"\w* \w te|strong="H3588"\w* \w serviremos|strong="H5647"\w*!
\v 11 \nd \w Yavé|strong="H3068"\w*\nd* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w Jerobaal|strong="H3378"\w*, Bedán, Jefté y \w Samuel|strong="H8050"\w*, y \w los|strong="H3427"\w* \w libró|strong="H5337"\w* de \w mano|strong="H3027"\w* de sus enemigos de \w alrededor|strong="H5439"\w* y vivieron con seguridad.
\p 
\v 12 \w Pero|strong="H3588"\w* \w cuando|strong="H3588"\w* \w vieron|strong="H7200"\w* \w que|strong="H3588"\w* Nahas, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Amón, venía \w contra|strong="H5921"\w* ustedes, \w me|strong="H5921"\w* dijeron: \w No|strong="H3808"\w*. Un \w rey|strong="H4428"\w* \w reinará|strong="H4427"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*, \w aun|strong="H3808"\w* \w cuando|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w su|strong="H3588"\w* \nd ʼElohim\nd* \w era|strong="H1121"\w* \w su|strong="H3588"\w* \w Rey|strong="H4428"\w*.
