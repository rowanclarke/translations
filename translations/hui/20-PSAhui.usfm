\q1
\v 11 I̱ tinginini dere ko ngubi bidarume  
\q2 i̱naga damene nenegeru i̱ni kogoria ibua nahaya.  
\q1 I̱ one waneiginirubi ti kaundianiore haruruni ndobe.   
\q1
\v 12 I̱naga waitigi bu karume  
\q2 i̱ gonoha delonaga gono wu kagoni ndobe.  
\q1 Agali i̱ mo ko halu bole karume  
\q2 i̱ bo wahami̱ya laga bialu ka.  
\q1 Horo bibahendengi tigua  
\q2 i̱hondo mana ko hangu bulene manda bialu haga kagoni.   
\b  
\q1
\v 13 I̱ hale tuluhe ale howa  
\q2 tigua bi lararu hale habe nahe ko.  
\q1 I̱naga bi ndibulo wahene ale howa  
\q2 ne hariga ha̱ lalu bi labe nahe ko.   
\q1
\v 14 I̱ agali hale tuluhe haraligobi howa  
\q2 tigua bi lararu i̱na ladai bibe naheore kogoni.   
\b  
\q1
\v 15 Anduane Homogo-o i̱na í̠hondo mini mbiraore wu kogoni.  
\q1 Anduane Homogo i̱naga Ngode Datagaliwabeore-o  
\q2 í̠na i̱naga bi larogo ladai biaga kegoni.   
\q1
\v 16 Waitigi bu karume wai hanalu i̱ bope holenaga  
\q2 mine bi lelo nahelabe.  
\q1 I̱ emene pilope harogola  
\q2 ti turu helo nahelabe laro.   
\q1
\v 17 I̱ tandaga timbuni handaabo halu kogome  
\q2 i̱ pilolene kawareore ngagoni.   
\b  
\q1
\v 18 I̱na ko bialu haruru í̠hondo latagi hai harugoni.\x + \xo 38.18 \xt Iba 32.5, 2 Ko 7.9-10\x*  
\q1 I̱ni mana liahe birudarunaga dara timbuniore ho kogoni.   
\q1
\v 19 I̱ waitigi dewaore hongo gibihe bu ka.  
\q1 I̱ bame handabe manga haga karu  
\q2 ti dewaore daga labenahe ka.   
\q1
\v 20 I̱na mana bayale hangu bialu kogola  
\q2 tigua i̱hondo mana ko biadai biaga kagoni.  
\q1 I̱na mana bayale ngago talialu bialu kogola  
\q2 tigua i̱ baba bameore mo waitigi haga kagoni.   
\b  
\q1
\v 21 Anduane Homogo-o í̠na i̱ yu wanahabe laro.\x + \xo 38.21 \xt Iba 22.19, 35.22\x*  
\q1 I̱naga Ngode Datagaliwabe-o i̱ helo wahalu kaundia nahabe.   
\q1
\v 22 Anduane Homogo-o i̱ Pele Ngiaga í̠ni hanguore kego  
\q2 i̱ biamogo bule abaleore ibabe.   
\c 39  
\s1 Agali mbira ibuha genda yu howa bi lenego  
\q1
\v 1 I̱na bi lo wirugo ogo,\x + \xo 39.1 \xt Iba 141.3, Kl 4.5, Ya 3.2\x*  
\q1 I̱nime bi ko loligo  
\q2 mana berogobi baya hangu mamage howa bialu holebero.  
\q1 Agali mana ko biaga i̱ koria kaware kangi  
\q2 i̱na ti baba bi mbira nalolebero, larugoni.   
\q1
\v 2 I̱na i̱naga ne hariga ndibulo howa  
\q2 bi mbira nale haru.  
\q1 Bi bayalenaga lalubi mbira nale dege harugoni.  
\q1 Anigoyu i̱ha genda timbuniore ngelo hene.   
\q1
\v 3 I̱na mini tumutumu bu harugoni.  
\q1 I̱na mitangitangi bialu haabo hewagola  
\q2 i̱naga miniha mo ko haiore hene.  
\q1 Ai i̱na i̱naga ne hariga ndibu lowa ndo  
\q2 i̱na bi lolebero manda biru.   
\q1
\v 4 I̱na Anduane Homogohondo hale halu lalu,\x + \xo 39.4 \xt Iba 90.12\x*  
\q2 Anduane Homogo-o i̱naga holeneha i̱ mali agira agima holeberobe.  
\q1 I̱ angi homoliyadabe.  
\q2 I̱ dindini holene tubagi dege wiaruabe be ludabe  
\q2 i̱ni langibe, laru.   
\b  
\q1
\v 5 I̱naga holene tigimandi hangu ngeledegonida.\x + \xo 39.5 \xt Iba 62.9, 90.4, 144.4\x*  
\q1 Í̠naga deni i̱naga holene emene ogoni  
\q2 nagaloneoredane hendede.  
\q1 Wali agali bibahendenaga holene lu ndo  
\q2 mbiralime ne harigaha buhe̱ halu mbira hangu latagi hagagobi dege nga.   
\q1
\v 6 Ni daragola ina mbiralinaga munini ale kama.  
\q1 Dindini mbirale bayale wini ngaru mule biabe erekuibi bia bialu howa  
\q2 bame nagalone bialu haga.  
\q1 Iname mbirale dewaore mo mogo bialu kamagoyu  
\q2 ái ibu holebirabe manda nabi kama.   
\b  
\q1
\v 7 Ai Anduane Homogo-o i̱na agilenaga mini dunubia ho holiyabe.  
\q1 Í̠na hangu i̱ biamogo bibelo lowa  
\q2 i̱na í̠nihondo mini dunubia ho kogoni.   
\q1
\v 8 Í̠na i̱ pele ngialu i̱na ko biruru domo wahabe.  
\q1 Agali ko mini nawi ale karume  
\q2 i̱ hondo oba halu mege bialu helo nahelabe.   
\q1
\v 9 I̱na i̱naga ne hariga ndibu lowa  
\q2 bi mbira nale holebero.  
\q1 Ogonaga irane i̱na tandaga uruni narogo  
\q2 í̠nime i̱hondo ibilaridagonaga bi nalolebero.   
\q1
\v 10 Ainde i̱ lone nababe laro.  
\q1 Í̠na i̱ pani ngirigome  
\q2 ai homabeheore kogoni ndobe.   
\q1
\v 11 Wali agalime mana ko birarunaga í̠na pani mirili.  
\q1 Bombome aga labolabo nalu budabaga biagadagua  
\q2 í̠na inanaga mbirale hameledamaru mo wahai haga kegoni.  
\q1 Heneneore larogo wali agali bibahendenaga ne harigaha buhe̱ halu mbira hangu  
\q2 latagi hagagobi dege ka.   
\b  
\q1
\v 12 Anduane Homogo-o i̱naga bi larogo hale habe.  
\q1 I̱na bi lalu kogoni baya hangu hale ho habe.  
\q1 I̱na dugu bialu koria de iba ibirago hondowa  
\q2 í̠na i̱ biamogo bibe.  
\q1 I̱naga mamaliru ti nde dindi ogoria tigi mbira hangu halu homayadagua  
\q2 i̱nibi nde dindi ogoria tigimandi hangu holeberogo  
\q2 í̠ manda biaiho kegoni.   
\q1
\v 13 I̱ lone mo tandaga nahe  
\q2 emene hangu nde i̱naga bu miniha dungulo holiya helabe laro.  
\q1 Mani i̱ homalu nde dindi ogo wahalu poliyadago  
\q2 ani helabe laro.   
\c 40  
\s1 Anduane Homogonaga mini yaraga halu iba gana lenego ogo  
\q1
\v 1 Anduane Homogo ibugua i̱ biamogo bilonaga  
\q2 i̱ mini dege dindi nahe ema nabi haru.  
\q1 Ani hewaria nde  
\q2 ibugua i̱na bi larugo hale halu biamogo biya.   
\q1
\v 2 I̱ gundu uli gibi hiriribiha pilo wiwaria\x + \xo 40.2 \xt Iba 27.5, 69.2, Yar 38.6, 38.10-13\x*  
\q2 ibugua hale halu gililo miya.  
\q1 Uli unuraore lumburaha homole yupe halu hewaria  
\q2 ibugua i̱ gililo miya.  
\q1 Ibugua i̱ gililo muwa ege to̱le̱ni mo heya ho helalu  
\q2 i̱ yo pialu poliya ani biya.   
\q1
\v 3 Ibugua i̱na iba gana gahenge mbira\x + \xo 40.3 \xt Iba 32.7, 33.3, 64.9\x*  
\q2 i̱nanaga Ngode Datagaliwabe kagonaga mini yaraga halu loliya lawai haya.  
\q1 Ani biyaego hondowa wali agali dewaoreme mini wialu  
\q2 ti Anduane Homogohondo mini mbiraore wulebira.   
\b  
\q1
\v 4 Wali agali Anduane Homogohondo mini mbiraore wuwa\x + \xo 40.4 \xt Iba 84.12, 125.5\x*  
\q2 mbirale tara gime wabiniru mitangi nahe  
\q2 mbirale uruniale mitangi haga karume biagadagua nabiaga karu  
\q1 ti turuho ka.   
\q1
\v 5 Anduane Homogo inanaga Ngode Datagaliwabe-o\x + \xo 40.5 \xt Iba 71.15, 139.17-18, Ais 55.8-9\x*  
\q2 í̠na inanaga mbirale dewaore gibi bia haga birigoni.  
\q1 Í̠ aleore mende nahe manda bidama.  
\q1 Iname bima lama hama polomadagonaga dewaore  
\q2 í̠naga miniha magoyu kegoni.  
\q1 Hama ibirimahayagibi walia hama ibirigoni.  
\q1 Í̠na inanaga bia hama ibirigoni manda bialu howa  
\q2 ina daga au loabe tobahe gibiore bia harigoni mandabu kama.   
\b  
\q1
\v 6 Ogoni bia harigonaga iname í̠hondo turu halu mbirale lomabu ngulenegobi\x + \xo 40.6 \xt Ais 1.11, Yar 6.20, Mai 6.6-8\x*\x + \xo 40.6 \xt Hi 10.5-7\x*  
\q2 mbirale homa hende loma delagane dabuni bo delo ngulenegobi  
\q2 uruni alego í̠ hame nalagayagoni.  
\q1 Inanaga ko domabelo lowa mbirale mbira bo delo ngulenegobi  
\q2 í̠ hame nalaga degeyagoni.  
\q1 I̱na í̠naga bi larego hale halu buliyanaga  
\q2 í̠na i̱naga hale kira wabuwa dugua ho heledegoni.   
\q1
\v 7 Í̠na ani bidego manda buwa i̱na buliya damenego  
\q2 í̠naga mbugani \w mana\w* lo ngegonidagua  
\q2 i̱na bule kogoni laru.   
\q1
\v 8 I̱naga Ngode Datagaliwabe-o\x + \xo 40.8 \xt Iba 37.31, 2 Ko 3.3\x*  
\q2 i̱na í̠na hame ledegodaguaore bule turuho kogoni.  
\q1 Í̠naga bi mana lo ngeru  
\q2 i̱na i̱naga bu habaneha mo hengedogoni.   
\b  
\q1
\v 9 Anduane Homogo í̠naga wali agali mo ngoaiho bereagoria  
\q2 i̱na ina kamaru pele ngiaga í̠ kego lalu  
\q2 bi baya turubi ogoni ti hale hai helo lamiru.  
\q1 I̱na bi ogoni dege lalu kone lairi naholeberogo í̠ manda bidegoni.   
\q1
\v 10 Anduane Homogo í̠na wali agali pele miaga kegonaga bi te\x + \xo 40.10 \xt Iba 89.1, Ab 20.20, 20.27\x*  
\q2 ogoniore i̱ni yu donge nahe lamiru.  
\q1 Í̠na biamogo biaabo hariligonagabi  
\q2 í̠ mini bilinahe kegonagabi wali agali lamiaabo haru.  
\q1 Í̠naga wali agali bibahende mo ngoaiho bereagoria  
\q2 Anduane Homogohanda ina handaya haho wiaabo halu  
\q2 gubalini haho wiaabo haga ka lalu  
\q2 i̱na yu donge nahe lamiaiore haru.   
\b  
\q1
\v 11 Anduane Homogo-o í̠na i̱ dara howa biamogo bulene nawi howa  
\q2 dara howa biamogo biaabo hariligoni.  
\q2 Ogoninaga biairi naholebeda lo manda bido.  
\q1 Í̠naga gubalini holenemebi mini bilinahe holenemebi  
\q2 i̱ yani ho wiaabo kegola  
\q2 i̱ bayale karulapeore holoboda lo manda bido.   
\s1 Ngode Datagaliwabehanda biamogo bilonaga bi lenego ogo  
\r (Iba Gana 70)  
\q1
\v 12 Genda bulene tara tara dewaore\x + \xo 40.12 \xt Iba 18.5, 38.4, 65.3\x*  
\q2 i̱ kogoria bu payabu ngagola kogoni.  
\q1 Genda bulene dewaore wu mabu bupe kagola  
\q2 i̱ dombeneha kogoni.  
\q1 Genda bulene uruni daga aulole nalabehe dewaore ngagoni.  
\q1 Mana ko i̱na bigi birurume  
\q2 i̱ni bope henego kogoni.  
\q1 I̱ni ko uruni birugome i̱ mininaga de au henego  
\q2 mbirale bayuwa handabe nahe kogoni.  
\q1 I̱na ko biruruni dagalabe nahe  
\q2 i̱ninaga haguaneni mandari li bu karubi ndo gibiore birugoni.  
\q1 I̱naga miniha hongo mbira naheore pirilipe ho wahenego kogoni.   
\q1
\v 13 Ani bidane kogo Anduane Homogo-o í̠na i̱ pele ngibe.  
\q1 Áyu ogoniore i̱ mo wia.   
\q1
\v 14 Agali marume i̱ bo wahole manda bialu karu  
\q2 í̠na ti bope halu tinaga miniha mo talola howa  
\q2 mini burugulo helabelo hamelo kogoni.  
\q1 I̱ genda timbuni yu kogo hondowa  
\q2 wali agali maru ti turu haga ka.  
\q1 Wali agali urunibi biaga karu  
\q2 í̠na bo badai bialu tinaga mini ti taga ho helo  
\q2 bope habelo hamelo ko.   
\q1
\v 15 Wali agali urunime i̱naga mini lahiralu i̱ mege biaga karuore  
\q2 í̠na ti mo taga haho wiaabo habelo hameledo.  
\q1 Í̠na ani berego handalu tini taga halu  
\q2 tini mana bialu hayadago mitangi budai bilo  
\q2 mo taga habelo hamelo kogoni.   
\b  
\q1
\v 16 Wali agali maru í̠ keria ibiraru  
\q2 ti bibahende turuho helo hameledo.  
\q1 Í̠na ti pele mirigonaga turu howa ka̱i̱ lalu karume  
\q2 Anduane Homogo ibu gibi daligaore ka lai helo hameledo.   
\b  
\q1
\v 17 Anduane Homogo-o i̱ ko yagibanoni hongo naheore kogoni.  
\q1 Í̠ ani kogonigoyu  
\q2 í̠na i̱ embeda nahe mitangi bu kegoni.  
\q1 Í̠ i̱naga Ngode Datagaliwabebi i̱naga pele ngiagabi kegonigo  
\q2 i̱ pele ngule áyu ogoni abale ibabe laro.   
\c 41  
\s1 Agali mbira warago bo wuwa Anduane Homogohondo bi lenego ogo  
\q1
\v 1 Yagibano karu mitangi bialu biamogo biaga karu\x + \xo 41.1 \xt Min 14.21\x*  
\q2 ti turubiore holebira.  
\q1 Uruni tiha genda timbuni tagira ibirangi  
\q2 Anduane Homogohanda ti biamogo bulebira.   
\q1
\v 2 Anduane Homogohanda ti biamogo bialu\x + \xo 41.2 \xt Iba 27.12\x*  
\q2 handayaho holebira.  
\q1 Ibugua ti dindini turu ho helo  
\q2 baya hangu handayaho holebira.  
\q1 Tinaga waitigi karume mo ko helo  
\q2 ibugua ti yupe naholebira.   
\q1
\v 3 Wali agali uruni ti warago timbuni bo ngangi  
\q2 Anduane Homogo ibugua handayaho haabo holebira.  
\q1 Anduane Homogohanda ti warago bararu mo dabi halu  
\q2 bayale helo mo hongo holebira.   
\b  
\q1
\v 4 I̱na bi ogodagua laru.  
\q1 Anduane Homogo-o i̱na í̠hondo ko timbuniore birugoni.  
\q1 I̱na ani birugo í̠na i̱ dara howa biamogo bialu  
\q2 i̱ha warago timbuni ngago mo dabi habe.   
\q1
\v 5 I̱naga waitigi karume i̱hondo bi tandagabi lalu kagoni.  
\q1 Tigua lalu, Ibu abale homa nabirago  
\q2 ina embedaho wahami̱ya, laga bialu ka.   
\q1
\v 6 Agali i̱ warago bo ngoria de hondo ibirarume  
\q2 dara hetingi howa hondo ibaga.  
\q1 I̱ warago ko timbuni bo ngogonaga te hale holene hame laga.  
\q1 Hale halu tagira puwa bibahendeha  
\q2 i̱naga warago ogoninaga te loyogo laga.   
\q1
\v 7 I̱ handabe manga haga karume  
\q2 i̱ warago ogoninaga hagarere bi lagalaga bialu haga.  
\q1 Tigua mitangi bialu  
\q2 ko timbuniore mbirame i̱ mo ko haragonida lo mitangi biaga.   
\b  
\q1
\v 8 Tigua lalu,  
\q1 Warago ko tara mbirame minidagonigo  
\q2 ibu lone heyulene nawi homolebira, laga bialu kagoni.   
\q1
\v 9 I̱naga nenegeore mbira henego\x + \xo 41.9 \xt 2 Sml 15.12, Iba 55.12-13, 55.20, Yar 20.10, Md 26.23, Mg 14.20, Lg 22.21, Yo 13.18\x*  
\q2 iya haru mandagi ibagabu halu  
\q2 tomobi mandagi nalu biraga henego ogoni ibuguabi nde  
\q2 i̱ handabe manga dege halu handa tara haya.   
\b  
\q1
\v 10 Anduane Homogo-o ainde í̠na i̱ dara howa biamogo bialu  
\q2 i̱naga warago ngogo mo dabi habe.  
\q1 I̱naga waitigi biarume i̱hondo biyarunaga pani  
\q2 i̱na biadai buliya ani bibe.   
\q1
\v 11 Waitigi bu karume i̱ bope nahayagua nde  
\q2 í̠na i̱ gubaliniore ho kedalo mandabu holebero.   
\q1
\v 12 I̱na mbirale beroru tigabi bialu koria de hondowa  
\q2 í̠na i̱ biamogo bulebere.  
\q1 I̱ í̠niha haparaho holiya  
\q2 í̠na i̱ handayaho haabo holebere.   
\b  
\q1
\v 13 Anduane Homogo Isaraele wali agalinaga Ngode Datagaliwabe kago  
\q2 ibunaga mini áyu ogoni yaraga holene nga.\x + \xo 41.13 \xt Iba 106.48\x*  
\q1 Wali agali mani hama polobadarumebi  
\q2 ani dege bialu haabo helo.  
\q1 Aniore bilo laro.   
\ms1 MBUGA MENDE  
\mr (Iba Gana 42-72)  
\c 42  
\s1 Agali mbira dindi taraha haru pu henegome Ngode Datagaliwabehondo bi lenego ogo  
\q1
\v 1 Nogo meme ale mini dia gabuame iba noa howa hége lebola ho yalu\x + \xo 42.1 \xt Iba 119.131\x* \fig Nogo meme ale mini dia gabuame iba noa howa ... iba libule porago ... piaganedagua Ngode Datagaliwabe-o i̱ í̠ kegoria ha paraho hole ibulene hameore lo ko.|src="HK 2f.tif" size="2" ref="(42.1)" \fig*  
\q2 iba libule porago hendehende gerai piaganedagua  
\q1 Ngode Datagaliwabe-o i̱ í̠ kegoria haparaho hole ibulene hameore lo ko.   
\q1
\v 2 Ngode Datagaliwabe í̠ holenehe kegoni.\x + \xo 42.2 \xt Iba 42.11, 43.5, 63.1, 143.6, Yar 10.10, Dan 6.26, Md 26.63, Lm 9.26\x*  
\q1 Iba noa biradagua i̱naga minime í̠ kegoria haparaho holeneore hamelo kogoni.  
\q1 I̱na í̠ kego de handalu  
\q2 í̠naga mini yaraga hole angi ibuliyadabe.   
\q1
\v 3 Mbiraga horombebi i̱ dugu biaabo halu\x + \xo 42.3 \xt Iba 80.5\x*  
\q2 tomo nane tomo i̱ninaga de iba no paliruli.  
\q1 Horo bibahendengi wali agali i̱naga waitigi karume i̱hondo,  
\q2 Í̠naga Ngode Datagaliwabe hayuagoni agoha kabe, laabo haga.   
\b  
\q1
\v 4 Ala bialu haruligo mitangi budai berodagua nde\x + \xo 42.4 \xt 1 Sml 1.15, Yob 30.16, Iba 95.2, 100.4, Ais 30.29\x*  
\q2 i̱naga gubaliniha tandagaore bialu habe naharagola haruli.  
\q1 Wali agali maru heba wabuni Ngode Datagaliwabenaga andaha pole poramaligobi  
\q2 ti maha ibilo i̱na haru bamba haruligobi nde  
\q2 mitangiore halu ko.  
\q1 Wali agali turuhe damene wabuni buyu pialu  
\q2 iba ganaru lagalaga bialu  
\q2 Ngode Datagaliwabenaga mini yaraga hagahaga bima ibunaga andaha pole poramaligoore  
\q2 mitangi haabo halu ko.   
\q1
\v 5 Ai nde áyu i̱ore miniha turu naheore haabo kogoni aginagadabe.\x + \xo 42.5 \xt Iba 9.1, 38.6, Md 26.38\x*  
\q1 I̱naga miniha genda bialu lungulungu biaruagoni agiorenagadabe.  
\q1 Ani biaruagoni bilo  
\q2 i̱na i̱naga Ngode Datagaliwabeni mini hanaho holebero.  
\q1 I̱naga Pele Ngiagabi i̱naga Ngode Datagaliwabebi kagonaga mini  
\q2 i̱na lone mo yaraga holebero.   
\q1
\v 6-7 I̱ i̱ninaga dindini hewaria bo ba tagi haya handala dindi taraha o pu kogoni koria\x + \xo 42.6-7 \xt Iba 69.1-2, 88.7, Yna 2.3\x*  
\q2 i̱naga gubaliniha tandagaore bialu tumbudu biragola kogoni.  
\q1 Ani biragola i̱naga mitangi mo tiga bialu  
\q2 Ngode Datagaliwabe kagohayagi pelaruli.  
\q1 Ibugua dara bulenego iba yaribu bu yu ibilaradagua  
\q2 i̱naga mini dara buleneme bu dambi haga.  
\q1 Genda tara tara bulenego Hari Hemono howabi Hari Misa howabi  
\q2 iba dugutagi halu ue lama Yodanaha pugulupebe biradagua biragola  
\q2 birama iralu i̱ namu labehe kogoni.   
\q1
\v 8 Ani kogonigo Anduane Homogo gubalini haho wiaabo haga kago\x + \xo 42.8 \xt Iba 16.7, 57.3, 63.6, 149.5\x*  
\q2 ibugua horongi ibunaga gubalini holene ogoni walia helo hameledo.  
\q1 Ibugua ani birago hondowa  
\q2 i̱na mbiraga iba gana lo mialu  
\q2 i̱ holene ngiagane tene Ngode Datagaliwabe kago  
\q2 ibuhondo bi ogoni lolene hameledo.   
\b  
\q1
\v 9 I̱naga waitigirume bolilono i̱naga mo wiaga Ngode Datagaliwabe kagohondo,  
\q1 Í̠na i̱ aginaga embedaho waharibe, laro.  
\q1 I̱naga waitigi karume i̱ bo hengedo waharagola  
\q2 tandaga narogo naabo holiya kego aginagabe.   
\q1
\v 10 Tigua i̱hondo, Í̠naga Ngode Datagaliwabe hayuago agoha kabe, lalu  
\q2 mege biaabo haragome i̱ore hengedope haabo haragola kogoni.   
\b  
\q1
\v 11 Ai nde áyu i̱ore miniha turu naheore haabo kogoni aginagadabe.  
\q1 I̱naga miniha genda bialu lungulungu biaruagoni agiorenagadabe.  
\q1 Ani biaruagoni bilo  
\q2 i̱na i̱naga Ngode Datagaliwabeni mini hanaho holebero.  
\q1 I̱na i̱naga Pele Ngiagabi i̱naga Ngode Datagaliwabebi kagonaga mini  
\q2 i̱na lone mo yaraga holebero.   
\c 43  
\s1 Agali mbira dindi taraha haru pu henegome Ngode Datagaliwabehondo bi lenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o í̠ erembira ngialu piaga karume\x + \xo 43.1 \xt 1 Sml 24.15, Iba 5.6, 26.1, 38.12\x*  
\q2 i̱ bope hole manda bialu ka.  
\q1 Tini koore howa tinaga bi ke̱ halu la hole bialu kago  
\q2 i̱na mana tigabi bialu kogo tigua hendelo  
\q1 í̠na mo walia habe.  
\q1 Í̠na i̱ biamogo bialu agali ko uruninaga giha howa yamibe laro.   
\q1
\v 2 Í̠nime hangu i̱ handayaho haga kegonigo  
\q2 irane aginaga í̠na i̱ mo embedaho kebe.  
\q1 I̱naga waitigi bu karume i̱ bope halu  
\q2 i̱naga mini mo ko haga kagonaga  
\q2 i̱ tandaga haabo haruligo irane agibe.   
\b  
\q1
\v 3 I̱ heyalu Hari Saiono í̠ninaga hari loma bia hene wedagoria  
\q2 tigatiga puabo halu poliyabi\x + \xo 43.3 \xt Iba 36.9\x*  
\q2 í̠ninaga anda í̠ kegoria ibuliyabi  
\q1 í̠na í̠ninaga wá holenemebi henene lolenemebi i̱ haru haabo habelo hameledo.   
\q1
\v 4 Ngode Datagaliwabe-o í̠ninaga lomabu delaga dabu bu heledagoria polebero.  
\q1 Í̠na i̱ mo turu halu miniha dungulo helariligodago  
\q2 anidagua bibe laro.  
\q1 I̱naga Ngode Datagaliwabe í̠ore kegoni.  
\q1 I̱na ngida ale balu í̠naga mini yaraga halu  
\q2 iba ganaru lalu holebero.   
\b  
\q1
\v 5 Ai nde áyu i̱ore miniha turu naheore haabo kogoni aginagadabe.  
\q1 I̱naga miniha genda bialu lungulungu biaruagoni agiorenagadabe.  
\q1 Ani biaruagoni bilo  
\q2 i̱na i̱naga Ngode Datagaliwabeni mini hanaho holebero.  
\q1 I̱na i̱naga Pele Ngiagabi  
\q1 i̱naga Ngode Datagaliwabebi kagonaga mini  
\q2 i̱na lone mo yaraga holebero.   
\c 44  
\s1 Isaraele wali agalime ti biamogo bia lalu Ngode Datagaliwabehondo bi lenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o í̠na biabe hongoheore bialu harigo  
\q2 inanaga haleme hale harimagoni.\x + \xo 44.1 \xt Har 12.26-27, Iba 78.3\x*  
\q1 Ina mamali ala dindini heneyarume bamba heneyangi  
\q2 í̠ni binigo te inahondo langiya.   
\q1
\v 2 Í̠na dindi aba ala ogoria hene hearu bo taliatagi halu\x + \xo 44.2 \xt Iba 78.55, 80.8\x*  
\q2 inanaga mamaliru dindi ogoriani haru íbu helariya.  
\q1 Wali agali tara tara bu hearume biyagonaga í̠na ti pani mialu  
\q2 inanaga mamaliru biamogo bialu mo dewa halu bayale helo helariya.   
\q1
\v 3 Inanaga mamaliru tigua wai bialu howa  
\q2 tininaga wai biaganeme dindi ogo karulene ndo.\x + \xo 44.3 \xt Man 8.17, Yos 24.12\x*  
\q1 Tininaga hongome wai buwa wayali hene ndoore.  
\q1 Í̠nime ti gubalini ho howa  
\q2 í̠naga wá holene helarigomebi  
\q2 í̠naga hongoni howa ti wayali ho hene.   
\b  
\q1
\v 4 I̱naga Kinibi i̱naga Ngode Datagaliwabebi í̠ore kegoni.  
\q1 Í̠nime bi ledegola Yagabanaga hameigini karume wai bialu wayali haga.   
\q1
\v 5 Í̠naga hongoni howa iname waitigi bu karu bo batagitagi beramali.  
\q1 Ina í̠naga minini howa waitigi bope halu wayali haramali.   
\q1
\v 6 I̱naga danda timu yandareru wia ngogo\x + \xo 44.6 \xt Iba 33.16, Hos 1.7\x*  
\q2 urunime i̱na wai bialu wayali harodalo manda nabiore kogoni.  
\q1 Wai bialu ayu tibu yu ha kogonigo  
\q2 ogonimebi i̱ wayali holiyanaga biamogo nabiaga manda bidogoni.   
\q1
\v 7 Mbirale urunime ndo í̠na ina biamogo birigola  
\q2 waitigi bope harima.  
\q1 Waitigime ina handabe manga ho hearia  
\q2 í̠na ti bope haga bialu mo taga harigoni.   
\q1
\v 8 I̱name Ngode Datagaliwabe í̠ninaga mini dege yaraga halu  
\q2 í̠na birigonaga ka̱i̱ lalu haabo holeberema.   
\b  
\q1
\v 9 Ani birigoyu ai í̠na ina mo nagalone halu erembira ngirigoni.  
\q1 Inanaga ami agaliru heba í̠ wai nape.  
\q2 Anidagua bialu kego irane aginagabe.   
\q1
\v 10 Í̠na ogonidagua birigome inanaga waitigiru ibiyagola  
\q2 ina ibida pirimagoni.  
\q1 Ibida pirimagola tigua inanaga mbirale wimaru  
\q2 mo yalu piai haya.   
\q1
\v 11 Tigua nogo sibi bo wahagadagua  
\q2 ina bo homelelo ale helarigoni.  
\q1 Inane dindini hemaria í̠na ina bo taliatagi halu  
\q2 wali agali dindi tara tarani bu hearu  
\q2 ti dege dombeneha hama pelarigoni ndobe.   
\q1
\v 12 Í̠naga wali agali biaru wali agali dindi tara tarani bu hearunaga garabaya biabe ale bialu helo pelarigoni.  
\q1 Dindi tarani hearu tigua í̠ yolo emene hangu bigi biyagome  
\q2 í̠na muni timbuni namo yi kegoni.   
\b  
\q1
\v 13 Í̠na ogonidagua birigola  
\q2 wali agali ina baba mandagi haga karume  
\q2 ina hondo mege bialu ka.  
\q1 Wali agali bu hama pedarume inahondo oba haga birago  
\q2 í̠na ina mo taga helo birigoni.   
\q1
\v 14 Í̠na wali agali dindi tara taraha karu mo heya harigola  
\q2 tigua ina mini lalu mo taga halu ka.  
\q1 Inaha mbirale mbira biragola  
\q2 tigua ina hondo oba halu kagoni.   
\q1
\v 15-16 Agalime i̱hondo mege bialu bi koru lalu kagola  
\q2 i̱ tagabi howa handa dindi ho kogoni.  
\q1 I̱naga waitigirubi agali i̱ handabe manga haga karubi  
\q2 i̱na ti handarodagua i̱naga miniha mo ko halu  
\q2 i̱ taga timbuni ho kogoni ndobe.   
\b  
\q1
\v 17 Ngode Datagaliwabe-o iname í̠ embeda nahe howa  
\q2 í̠naga habo nalolene bi lowini biagobi  
\q2 mo habo nale kama.  
\q1 Ani birimagola mbirale genda uruni inaha anda ibiragoni.   
\q1
\v 18 Iname í̠ erembira ngialu pu nabi\x + \xo 44.18 \xt Yob 23.11\x*  
\q2 í̠naga harigani polenegobi yu wanahe kamagoni ndobe.   
\q1
\v 19 Ina ani bialu kamagoyu í̠na ina gabua tara tara haga ngagoha helowa\x + \xo 44.19 \xt Iba 23.4\x*  
\q2 arumaha homolene ngagoria helaridagoni.   
\b  
\q1
\v 20-21 Iname inanaga Ngode Datagaliwabe kago erembira mialu puwa\x + \xo 44.20-21 \xt Iba 139.1, Yar 17.10\x*  
\q2 mbirale gime wabini ngaruhondo bi pupu wialu henedale nde  
\q2 í̠nime manda bidele.  
\q1 Ina bu kamarunaga miniha wia do hene ngamaru bibahende  
\q2 í̠ni manda biai ho kegonigo í̠ ani manda bidele.   
\q1
\v 22 Ina í̠ninaga wali agaliore kamagonaga\x + \xo 44.22 \xt Lm 8.36\x*  
\q2 tigua ina bo wahalu haabo kagoni.  
\q1 Tigua ina handalu karia  
\q2 nogo sibi ale dege bo waholene ale kamaria hendedagoni.   
\b  
\q1
\v 23 Anduane Homogo-o í̠ abale heyabe.  
\q1 Aguanaga paliahondo kebe.  
\q1 Ina wahalu erembira ngialu puabo nahabe.\x + \xo 44.23 \xt Iba 35.23, 78.65\x*   
\q1
\v 24 Irane aginaga ha do ho kebe.  
\q1 Agali bu karume ina mo ko haragola  
\q2 ina tandaga timbuni halu genda dewaore yu kamago embeda nahabe.   
\b  
\q1
\v 25 Ina dindini pilo ibira halu  
\q2 inanaga tingini homene ale dindi himuni wima pedemagoni ndobe.   
\q1
\v 26 Ngode Datagaliwabe-o abale heyalu  
\q2 ina biamogo bule ibabe.  
\q1 Í̠naga gubalini haabo holene ngegome ina mitangi bialu  
\q2 ina homoligo abale pele ngibe laro.   
\c 45  
\s1 Kini ibu wali dabu biyangi iba gana la henego ogo  
\q1
\v 1 Bi bayale maru i̱naga miniha yu ko.  
\q1 I̱na iba gana ogoni podo yuwa kini kagohondo mulene manda bido.  
\q1 Beba bayale gili biaganaga peni ale howa  
\q2 i̱naga hégeme bi bayale lalu ko.   
\b  
\q1
\v 2 Í̠ agali bayaore kegoni.  
\q1 Agali mende í̠ ale naheore.  
\q2 Í̠na bi laga biriligo baya tigabiore larili.  
\q2 Ngode Datagaliwabehanda í̠ mo bayale halu haabo kagome  
\q2 í̠ ogonibi kegoni.   
\q1
\v 3 Í̠ kini timbuni hongoheore kegoni.  
\q2 Í̠ baya burugule tara howa mini lene timbuni kegoni.  
\q1 Í̠naga wai biagane ayu tibu yaganeha yuwa  
\q2 wai bule manda manda bu habe.   
\b  
\q1
\v 4 Í̠ kini dunini mbira mini leneore kegoni.  
\q2 Í̠na henene lolene ngagobi  
\q2 mana tigabi dege bulene ngagobi  
\q1 ogoni wayali helonaga wai bule í̠naga nogo hosini biralu pobe.  
\q1 Í̠na wai hongo howa beregome í̠ni wayali holebere.   
\q1
\v 5 Í̠naga timu de bi̱a̱o̱le ngerume  
\q2 waitigi bu karunaga gubalinini bolomogo biaga ngegoni.  
\q1 Í̠na dindi tara taranaga hameigini karu baba wai bialu  
\q2 bope haregola ti í̠ andaneha hai holebira.   
\b  
\q1
\v 6 Ngode Datagaliwabe-o í̠ kini haluhe haabo haga kegoni.\x + \xo 45.6 \xt Iba 93.2, 98.9\x*\x + \xo 45.6 \xt Hi 1.8-9\x*  
\q2 Wali agali í̠na hondo hene karu  
\q2 mana tigabi ngagoria helo haru haga kegoni.   
\q1
\v 7 Í̠ mana tigabi bulene ngago hamelowa\x + \xo 45.7 \xt Iba 11.7\x*  
\q2 mana ko ngago manga haga kegoni.  
\q1 Irane ogoninaga í̠naga Ngode Datagaliwabe ibugua í̠ dabo helene.  
\q1 Dabo helalu kini maru karu turu hagadagua ndo  
\q2 ti bolangua halu í̠naga haguaneni weli odo wiyagola  
\q2 í̠ mo turu taraore ho helene.   
\q1
\v 8 Í̠naga aga bayale luni biagimbu bu kegoni  
\q2 nga baya taraore mini \w muwe\w* kasiala ngabini mbauleda.  
\q1 Kini andagaru nogo elebeninaga ne gayaneme mo yáribia halu  
\q2 anda uruniha tigua í̠ mo turu holenaga ngida aleru lalu kagoni.   
\q1
\v 9 Kini waneru wali mini lene berearu heba í̠ andagaha biru hayua.  
\q2 Í̠naga gi tigahayagi kuini wali ibu bedagoni.  
\q2 Ibu ngolo Obira dindi tawame yári wabini ngaru karulo beda.   
\b  
\q1
\v 10 Kini one wandari mabuage-o  
\q2 i̱na bi o larogo hale halu manda bibe.  
\q1 Í̠ damene bu karubi wali agali maru bu karubi mitangi budai nabibe.   
\q1
\v 11 Í̠na ogonidagua bialu í̠ wandari bayaleoreda de hondowa  
\q2 kini ibugua í̠ gubalini timbuni ho holebira.  
\q1 Ibu í̠naga agali haguane ka manda buwa  
\q2 í̠na ibunaga bi larago hale halu birulene nga.   
\q1
\v 12 Taia wali agali bu karume  
\q2 í̠ mo turu holene aleru yalu ibulebira.  
\q1 Wali agali homogo karumebi í̠ mo turu holene marubi yalu ibalu  
\q2 í̠hondo mulebira.   
\b  
\q1
\v 13 Kininaga wandari mabuage biago kini andaga tamu hobaneha bedago  
\q2 ibu baya gibiore mbira bedagoni.  
\q1 Ibu aga baya taraore pu ngolo aleme wabini mo karulo bedagoni.   
\b  
\q1
\v 14 Wandari o biago ibu aga baya taraore ogoni karula howa  
\q2 tigua ibu kini berearia haru halu piya.  
\q1 Wandari maru ibu baba biraga berearubi  
\q2 ti haru kini andaga pole haru piya.   
\q1
\v 15 Tigua turu timbuni halu bu miniha dungulo howa  
\q2 kini andaga anda piai haya.   
\b  
\q1
\v 16 Kini-o í̠ igini dewaore holebiraru  
\q2 tigua í̠ mamaliru henedagoria kini ha aribia holebira.  
\q1 Í̠na ti mini leneore helowa  
\q2 tigua wali agali dindi bibahendeha karu haru helo helolebere.   
\q1
\v 17 Í̠ mini lene timbuni kego lalu i̱na iba gana ogoni latagi harogola\x + \xo 45.17 \xt Iba 138.4, Mal 1.11\x*  
\q2 wali agali mani holobadarume  
\q2 í̠ mitangi biaabo holebira.  
\q1 Ani mitangi bialu wali agali bibahende bu karume  
\q2 í̠naga mini yaraga ho haabo holebira.   
\c 46  
\s1 Ngode Datagaliwabe ibuni ina heba kagonigo ogo  
\q1
\v 1 Ngode Datagaliwabe ibu inanaga ha do hagabi ina hongo ngiagabi ka.\x + \xo 46.1 \xt Iba 62.7-8, 91.2, 142.5\x*  
\q1 Gendabi tara tara handaga beremangi  
\q2 ina biamogo bule ibu hapara howa  
\q2 manda mandabuore haga kagoni.   
\q1
\v 2 Ibu ani kago manda buwa ina gi naholeberema.  
\q1 Dindi dumbirumbi biyaguabi hari wedaruninaga pinipodo baga bialu  
\q2 iba solowara hanunini podopai hayaguabi  
\q2 ina gi naholeberema.   
\q1
\v 3 Iba solowararume iba tangu bahalu togo layaguabi\x + \xo 46.3 \xt Iba 93.3-4, Yar 5.22, Md 7.25\x*  
\q2 iba ue timbuni lagimbu biyaguabi  
\q2 iba hai ngoda timbuni wiame hayaguabi  
\q2 ina gi naholeberema.  
\q1 Iba yaribu bu yu puíbu bialu hari wedaru mo emabi haga biyaguabi  
\q2 ina gi naholeberema.   
\b  
\q1
\v 4 Ibaore mbira porago iba ogonime\x + \xo 46.4 \xt Iba 48.1, 48.8\x*  
\q2 Ngode Datagaliwabenaga tano Yarusaleme mo turu halu  
\q2 Ngode Datagaliwabe Daligaorene Daliga kago ibuni hangu haga  
\q2 anda loma buwa habagi ho helene kagobi  
\q2 mo turu haga iba ogoni pora.   
\q1
\v 5 Ngode Datagaliwabe ibu tano odagoniha kagome\x + \xo 46.5 \xt Yol 2.27, Seb 3.15, Seg 8.3\x*  
\q2 tano ogoni mo ko halu bo ereba naholeorebira.  
\q1 Egabi lole muna biraore ibunime ibalu  
\q2 tano ogoni biamogo bulebira.   
\q1
\v 6 Hameigini tara tara paluyu pedarume\x + \xo 46.6 \xt Yos 2.9, 2.24, Iba 2.1\x*  
\q2 gi gibi howa duru ala lalu holebira.  
\q1 Handame haga kini bu karubi  
\q2 wali agali tigua haru haga karubi  
\q2 bibahende bo purogo lelolebira.  
\q1 Ngode Datagaliwabehanda bi timbuni hari kulu laradagua laragola  
\q2 dindi bibahendeni wali agali bibahende bu karuni  
\q2 bo haeala baga bialu ereba hai helolebira.   
\b  
\q1
\v 7 Anduane Homogo Hongo Haiheore kago ibuni ina heba ka.  
\q1 Yagabanaga Ngode Datagaliwabe ibuni inanaga ha do hagane kagoni.   
\b  
\q1
\v 8 Anduane Homogohanda bigi biyadago de handami̱ya  
\q2 bibahende ibai hadaba.  
\q1 Anduane Homogo ibugua dindi bibahendeni mbirale mogolo handabehe binidaru  
\q2 de handadaba.   
\q1
\v 9 Dindi bibahendeni wai bialu karu  
\q2 ibugua mo hundia haga kagoni.  
\q1 Agalinaga danda minu podaki halu  
\q2 yandare podo gingirulo baga bialu  
\q2 humbi yiniyaru yamuwa irani mo delaga kagoni.   
\q1
\v 10 Ibugua lalu, Wai nabilimu.\x + \xo 46.10 \xt Man 4.35, 1 Kin 18.36-39, Ais 2.11, 2.17\x*  
\q2 Ngode Datagaliwabe i̱ore kogonigo manda bilimu, lalu ka.  
\q1 Dindi bibahendeoreha wali agali paluyu pedarume i̱naga mini tini kaha howa  
\q2 mo yaraga hagahaga bialu kagola kogoni  
\q2 tíni manda bilimu, lalu kagoni.   
\b  
\q1
\v 11 Anduane Homogo Hongo Haiheore kago ibuni ina heba ka.  
\q1 Yagabanaga Ngode Datagaliwabe ibuni inanaga ha do hagane kagoni.   
\c 47  
\s1 Ngode Datagaliwabe ibu haru haga daligaore kagonigo ogo  
\q1
\v 1 Wali agali bu kamiru bibahendeme  
\q2 Ngode Datagaliwabehondo turu halu gi habe bo midaba.  
\q1 Turu howa ibunaga mini mo yaraga halu  
\q2 iba gana dalimu lo midaba.   
\q1
\v 2 Anduane Homogo Daligaorene Daliga gibiore kagohondo  
\q2 iname gi habehe kamagoni.  
\q1 Ibu kini timbuni gibiore howa  
\q2 wali agali dindi bibahendeni bu kamaru de handa gimbu buwa haru kagoni.   
\q1
\v 3 Iname wali agali maru karu bope halu  
\q2 wayali holoma̱ya ibugua ina mo wayali helaya.  
\q1 Hameigini tara tara palu ngaru  
\q2 iname de hondo howa haru holoma̱ya helayagoni.   
\q1
\v 4 Ina dindi kamagonibi ibugua dege, Tí ogoria hadaba, lalu  
\q2 mo ngiyagoria bu kama.  
\q1 Ibugua ina gubalini howa ani mo ngiyagome  
\q2 ina nde dindi bayaore ogoriani howa  
\q2 miniha turu halu yangalo kamagoni.   
\b  
\q1
\v 5 Ngode Datagaliwabe ibu handame haga kini howa  
\q2 ibuninaga biragane dagiani birule iraga haragoni.  
\q1 Anduane Homogo ibu ani iraga harago hondowa  
\q2 wali agalime turuore gibi howa  
\q2 bi timbuni ga̱ lowa ladaga daga bialu mbelo biguliru bibe̱ laga biragoni.   
\q1
\v 6 Ngode Datagaliwabenaga mini yaraga halu  
\q2 ibuhondo iba gana lo midaba.  
\q1 Inanaga kini ibu hangu kago ibunaga mini yaraga halu  
\q2 iba gana lo midaba.   
\q1
\v 7 Ngode Datagaliwabe ibu wali agali dindi bibahendeni bu karunaga kini kago  
\q2 ibunaga mini mo yaraga halu iba gana laga bialu halimu.   
\b  
\q1
\v 8 Ngode Datagaliwabe ibu kini kago howa kininaga biragane dagia loma bia heneni biruwa  
\q2 ibugua mana tigabi dege lalu biraga.  
\q1 Ogoriani biruwa ibugua hameigini tara tara dindi bibahendeni bu kamaru haru haga kagoni.   
\q1
\v 9 Hameigini bibahende dindi tara tarani karunaga haru haga dameneru bibahendebi  
\q2 Abarahamanaga Ngode Datagaliwabe hene kago ogoni ibunaga wali agali bu karubi heba  
\q2 ti mandagi mo ngoaiho haga.  
\q1 Ngode Datagaliwabe ibu ami hongohe dindini bu karubi ndo  
\q2 hongo gibiorehe howa haru haga ka.  
\q1 Ibu haru haga hongohe daligaore kagoni.   
\c 48  
\s1 Saiono tano Ngode Datagaliwabenaga winigo ogo  
\q1
\v 1 Anduane Homogo ibu mini leneore kagonigo  
\q2 ibunaga mini yaraga holene nga.  
\q1 Ngode Datagaliwabenaga tano ngagoria anda puwa  
\q2 ibunaga hari loma bia hene ngagoria  
\q2 ibunaga mini yaraga hami̱ya.   
\q1
\v 2 Ngode Datagaliwabenaga hari loma bia hene ogoni\x + \xo 48.2 \xt Md 5.35\x*  
\q2 daliga timbuniore bayale nga.  
\q1 Dindi abene uyurahayagi Saiono tano ogoni kini dunini kagonaga ngago lalu  
\q2 wali agali dindi bibahendeha karume turu timbuni ho kagoni.   
\q1
\v 3 Ngode Datagaliwabenaga tano ogoniha wai anda ibiragola  
\q2 ibugua wali agali ibu heba haga karu abale biamogo bialu  
\q2 ti bayale haga ka.   
\b  
\q1
\v 4 Bamba kini tara tara bu hearume mo mogo bialu  
\q2 Saiono tanoha hearu baba wai bule ibiya.   
\q1
\v 5 Ti ibalu tano biago de hondowa mogolo handaya.  
\q2 Mogolo hondowa gi halu ibida pugupugu biai haya.   
\q1
\v 6 Ti mogo timbuni lalu walime gali taba honole\x + \xo 48.6 \xt Har 15.15, Hos 13.13\x*  
\q2 tandaga timbuniore hagagobi hayagoni.   
\q1
\v 7 Puyabu timbuniore ni tagira ibiragohayagi howa ibiragome  
\q2 Tasisi tanonaga iba sibi timbuni bu ngaru bo gingirulo wahai hagadagua  
\q2 Ngode Datagaliwabe ibugua waitigi uruni bo amo lai hayagoni.   
\b  
\q1
\v 8 Ngode Datagaliwabehanda bamba biniyago  
\q2 ina haleme hale ho harimagoni.  
\q1 Anduane Homogo Hongo Haiheore kagome  
\q2 ibuninaga tanoha mbirale uruni biniyago  
\q2 ai ina deme handai harima.  
\q1 Ibugua ibunaga tano ogoni mo hongo haragome  
\q2 bayale wiaabo holebira.   
\b  
\q1
\v 9 Ngode Datagaliwabe-o ina í̠naga andaha biruwa  
\q2 í̠naga gubalini haabo holene mana ngego mitangi bialu bedema.   
\q1
\v 10 Wali agali dindi bibahendeha bu karume  
\q2 í̠naga mini yaraga halu kagoni.  
\q1 Í̠ mini leneore kegonaga dindi bibahendeha  
\q2 wali agali karume loyogo leda.  
\q1 Í̠na í̠naga mana tigabi ngegome  
\q2 wali agali bu karu handayaho haga kegoni.   
\q1
\v 11 Hari Saiononi wali agali bu karu  
\q2 ti bibahende turu hai helo helabe.  
\q1 Wali agali tinime mana biragobi  
\q2 í̠na tigatiga ngadaguaore mo tale biaga kegoni.  
\q1 Yuda dindiha tano ngaruha karu ti bibahende turu hai helo helabe.   
\b  
\q1
\v 12 Ngode Datagaliwabenaga wali agaliru  
\q2 tígua Hari Saiono kagoria tanonaga ege pabe kadagua pu mabu bilimu.  
\q1 Pu mabu bialu pabe daligani mamagealinaga anda lu bima iraga halu bu heledaru  
\q2 bibahende dagalai halimu.   
\q1
\v 13 Tígua Saiononaga ege pabe kagobi anda hongohe bu karubi  
\q2 bayuwa handa kia bu helalimu.  
\q1 Wali agali mani holobadaru te lamulenaga baya hanguore handalimu.   
\q1
\v 14 Tígua mani holobadaruhondo ogodagua lamilimu.\x + \xo 48.14 \xt Ais 58.11\x*  
\q1 Ngode Datagaliwabe ibu inanagaore kagoni.  
\q1 Ibu inanaga Ngode Datagaliwabeore haluhe haabo holebira.  
\q1 Horo bibahendengi ibugua bamba halu  
\q2 ina hariga poloma̱yago walia halu  
\q2 haaboboore holebira, lalu lamilimu.   
\c 49  
\s1 Wali agali munihabi dabudabuhabi minipe karu ti mini nawi kago ogo  
\q1
\v 1 Wali agali bibahendeme bi o larogo hale halimu.  
\q1 Tí wali agali dindini bu kamiru bibahendeoreme  
\q2 i̱na bi larogo hale hole hale miaho halimu.   
\q1
\v 2 Wali agali timbuni mini lenebi mini nalenebi  
\q2 homogobi yagibanobi tí bibahendeme  
\q2 i̱na bi o larogo baya hanguore hale halimu.   
\q1
\v 3 I̱naga bu miniha mitangi bulene bayale hangu palu to̱ledago.  
\q1 I̱na mini gigabiwi holenenaga bi loleberogo  
\q2 ogoni tí wále helonaga lolebero.   
\q1
\v 4 I̱na pigane bi yobage lowa ala lolebero.  
\q1 Lalu howa ngida balu iba ganabi lalu  
\q2 bi yobage larugonaga irane mo walia halu langulebero.   
\b  
\q1
\v 5 Mbirale gibi hiriribi wigi bidangi\x + \xo 49.5 \xt Yob 31.24, Iba 52.7, Mg 10.24\x*  
\q2 i̱ gi naharuli.  
\q1 Waitigime i̱ bole lowa hoyu mabu biyaguabi  
\q2 i̱ gi naharuli.   
\q1
\v 6 Agali ko biaga karume dindi dabudabu dewa wuwa mine halu lalu,  
\q1 Ai homogo karulapeore kogoda, lowa  
\q2 dindi dabudabu urunini hanaho howa  
\q2 tininaga mini mo yaraga haga karume  
\q2 i̱ bole manda biaga ka.  
\q1 Ti ani bialu kago helowa i̱ ti hondowa gi naharuli.   
\q1
\v 7 Mbirali mbirame ibuninaga holenego munime yolo bibe nahe ngagoni manda bidama.\x + \xo 49.7 \xt Yob 36.18-19\x*  
\q1 Ibugua muni wiyadagome Ngode Datagaliwabehondo  
\q2 i̱ nahome holego í̠ muni ngerogo  
\q2 labe nahe ka manda bidama.  
\q1 Ani nabibeheore nga.   
\q1
\v 8 Ani bibe nahedagoni irane\x + \xo 49.8 \xt Iba 16.10, 22.29, 89.48\x*  
\q2 wali agalinaga holene buhe̱naga yolo gibi daligaorene daligago  
\q2 yolo bibe naheore nga.  
\q1 Ibugua Ngode Datagaliwabe yolo mule manda bulubadagoni nakarulapeore holebira.   
\q1
\v 9 Ibu homa nabi dére haaboore holego lalu  
\q2 Ngode Datagaliwabe munime yolo nabibeheore holebira.   
\b  
\q1
\v 10 Wali agali mbirale mandabi mini gigabiwi karubi  
\q2 homaga birane hendedama.  
\q1 Mini nawibi lulu alebi bibahende homa dege birane hendedama.  
\q1 Tigua mbirale dindini howa ilu wialu hayaruni  
\q2 tinaga aguanene holebiraru ti helo ngelalu  
\q2 tini homaga birane hendedamagoni.   
\q1
\v 11 Ala dindini hayangi tininaga dindini hayagonigo  
\q2 ai homalu pialu howa tinaga dindi anda tene homali biago bu hinalu  
\q2 homali biagoniha haaboore holebira.   
\q1
\v 12 Mbirali mini lene timbuni heneyaguabi  
\q2 homa anda ibidangi yo pialu pobe nahe holebira.  
\q1 Ani nabibeheore nga.  
\q1 Homa anda ibidangi nogo biango homagadagua homolebira.   
\b  
\q1
\v 13 Wali agali tini hangu howa karulape kama manda bialu karu  
\q2 tihondo agi birabe handami̱ya.  
\q1 Tininaga mbirale ngagoria mini hanaho karu homolebirago de handami̱ya.   
\q1
\v 14 Wali agali urunibi karu ti nogo sibi homagadagua homalu  
\q2 Homa ibu tinaga haru haga haguane holebira.  
\q1 Ti homaragola tinaga tingini abale togo bialu  
\q2 tinaga dindi haraligo yu wahalu  
\q2 tinaga dinini kaundiaore humbirini andaha polebira.  
\q1 Anidagua bigi birago hondowa  
\q2 wali agali mini tigabiwi karu ti turu halu holene nga.   
\q1
\v 15 Anigo Ngode Datagaliwabehanda i̱ gini mulebira.\x + \xo 49.15 \xt Iba 16.10-11, 73.24, Hos 13.14\x*  
\q1 Ibugua homolenenaga hongome i̱ yani nahelo  
\q2 pele ngulebira.   
\b  
\q1
\v 16 Wali agali mbirali ibunaga dabudabu dewa wiatago halu ibu homogo hayagua  
\q2 ogonidagua biragonaga í̠ mini dege dindi ho nahabe.   
\q1
\v 17 Ibu homalu ibunaga mbirale wiyadaruni\x + \xo 49.17 \xt Iba 17.14, 1 Ti 6.7\x*  
\q2 ibuni yalu napolebira.  
\q1 Dabudabu ilu wiyadarume  
\q2 tinaga anduane homaliha anda poradagua  
\q2 tibi homaliha dege anda porama nalolebira.   
\q1
\v 18 Ibu dindini kangi ibu turu howa dungulo kayaguabi  
\q2 ibu erekui biabe bialu mbirale dewa mo wiragola  
\q2 marume ibunaga mini yaraga halu ibu bayaore awadaga handalu kayaguabi   
\q1
\v 19 mbirali homogo ogoni ibubi homalu  
\q2 ibunaga mama mamali ala homalu peneru aruma haho wiaabo hagaha kadagua  
\q2 ibunibi ogoniha dege pu holebira.   
\q1
\v 20 Mbirali mini lene timbuni heneyaguabi  
\q2 homa anda ibidangi yo pialu ibida pobe nahe holebira.  
\q1 Ani nabibeheore nga.  
\q1 Homa anda ibidangi nogo biango homagadagua dege homolebira.   
\c 50  
\s1 Ngode Datagaliwabehanda wali agali dabaki bulebirago ogo  
\q1
\v 1 Ngode Datagaliwabe Hongo Haiheore Anduane Homogo kago  
\q2 ibugua bi laragoni.  
\q1 Wali agali ni tagira ibiragohayagi karubi  
\q2 ni paliragohayagi karubi dindi bibahendeha  
\q2 ibugua ti olalu kagoni.   
\q1
\v 2 Ngode Datagaliwabe ibu Saiono tano dunini dindi bayaleoreni howa  
\q2 ibugua ibunaga wá holene taraore biago  
\q2 wá haame halu kagoni.   
\b  
\q1
\v 3 Inanaga Ngode Datagaliwabe o ibaruagoni.  
\q1 Ibu ebero lalu panigi ibaruagoni.  
\q1 Mbirale ngaru dai helonaga ira dene ala bamba halu  
\q2 puyabu timbuni iba dalu dindi guni heba  
\q2 ibuha ho mabu bialu ibarua.   
\q1
\v 4 Ibugua dindibi hari daligabi olowa  
\q2 libuhondo lamialu lalu,  
\q1 I̱naga wali agalime bialu hayarunaga dabaki berogo  
\q2 hondole ibidaba, laruagoni.   
\q1
\v 5 Ngode Datagaliwabehanda lalu,  
\q1 I̱naga wali agali i̱nihondo mini mbiraorewi karu  
\q2 tigua i̱hondo nogo bo lomabu delalu howa  
\q2 i̱nila habo nalolene bi lo wiyaru  
\q2 ti i̱ni heba mandagi holoma̱ya mo mogo bialu ibidaba, laruagoni.   
\q1
\v 6 Hari daligame latagi halu lalu,\x + \xo 50.6 \xt Iba 75.7, 97.6\x*  
\q1 Ngode Datagaliwabe ibu tigabiore ka.  
\q1 Ibugua tigatiga dabaki biaga ka leda.   
\b  
\p
\v 7 Ngode Datagaliwabehanda lalu,  
\q1 I̱naga wali agali bu kamiru-o  
\q2 bi loleberogo bayuwa hale halimu.  
\q1 Isaraele wali agaliru-o  
\q2 i̱na tíhondo bi lolene yidogo  
\q2 tígua ko birimiru latagi holebero.  
\q1 I̱ni hangu Ngode Datagaliwabe howa  
\q2 tínaga Ngode Datagaliwabeore kogoni.   
\q1
\v 8 I̱na tígua lomabu yalu ibirimigonaga ndo dago bero.  
\q1 Horo bibahendengi tígua loma irani dai helaga bialu kamigoni  
\q2 i̱nime de hondo kogoni.   
\q1
\v 9 I̱na tínaga nogo pabeha nogo bulumaga memeru wangabe kago  
\q2 i̱ yamulenego burupalia nabi kogoni.   
\q1
\v 10 Nogo gabua irabuha haga karubi  
\q2 dindi hari daosini dewaore daga labe nahe ngaruha nogo bulumaga karubi  
\q2 bibahendeore i̱ninaga kago ndobe.   
\q1
\v 11 Ega gabua bedaru bibahendebi  
\q2 dindi bibahendeni ema bialu piaga bedarubi  
\q2 uruni bibahende ininagaore beda.   
\b  
\q1
\v 12 I̱ tomo garibilo koyagua\x + \xo 50.12 \xt Iba 24.1, 1 Ko 10.26\x*  
\q2 tíhondo mbira ngi nalolebero.  
\q1 Dindi bibahende ngagobi ogoniha wini ngarubi  
\q2 bibahende i̱ninagaore wiai ka.   
\q1
\v 13 I̱ bulumaga wangabenaga mbirini naga kobe  
\q2 be nogo memenaga darama naga kobe.  
\q1 Uruni ale i̱ nanagaore ndobe.   
\q1
\v 14 Tígua i̱hondo ka̱i̱ore lalu lolene nga.  
\q1 Uruniale tígua i̱nihondo lomabu ngulene karulape nga.  
\q1 Ngode Datagaliwabe Daligaorene Daliga kogo  
\q2 i̱nihondo mbirale mbira ngule lalubi lo wirimigo damene  
\q2 nguleneore ngagoni.   
\q1
\v 15 Tígua tíniha genda tagira ibirangi\x + \xo 50.15 \xt Iba 91.15, 107.6, 107.13, 107.19, Seg 13.9\x*  
\q2 i̱ni abale olalimu.  
\q1 Olaramigola i̱na hale halu tí biamogo bulebero.  
\q1 I̱na tí biamogo berogola  
\q2 tígua i̱naga mini yaraga halu holeberemi, lalu layagoni.   
\b  
\q1
\v 16 Ngode Datagaliwabehanda wali agali mana ko biaga karuhondo bi ogodagua laragoni.  
\q1 Tígua i̱naga mana lo wini ngoru bame lo payapaya bialu  
\q2 habo nalolene bi lo ngagonaga tebi lalu kamigo aginaga laramibe.   
\q1
\v 17 I̱na tí mo tiga buliya ha nabi\x + \xo 50.17 \xt Neh 9.26, Lm 2.21-22\x*  
\q2 tígua i̱naga bi mo wahalu haabo kamigoni.   
\q1
\v 18 Tígua agali page biaga karu lola howa  
\q2 abale mo nenege haga kami.  
\q1 Wali agali kayu yama ibaga biaga karu baba  
\q2 mandagi ibagabu haga kami.   
\b  
\q1
\v 19 Tígua ne harigaha howa ke̱ holene lalu  
\q2 bi ko dege lalu haabo haga kamigoni ndobe.   
\q1
\v 20 Tí damene bu karu baba godi lalu  
\q2 tí ai̱ya igini bameore mege bialu kamigoni.   
\q1
\v 21 Tígua anidagua bialu kamigonaga\x + \xo 50.21 \xt Iba 90.8, Ais 55.8-9, 57.11, Lm 2.4\x*  
\q2 i̱na bi mbira nale harugoni ndobe.  
\q1 I̱ ani hewagola tígua mandabu handalu hemiria  
\q2 i̱ nde tí ale dege kabe toba harimi.  
\q1 Ani birimigonaga i̱na tí dago berogoni.  
\q1 I̱na tí panigi handalimulo ko birimiru latagi holebero.   
\b  
\q1
\v 22 Wali agali i̱hondo erembira ngiaga kamiru  
\q2 tí bi o larogo hale hadaba.  
\q1 Tígua hale naharimiyagua nde tíha mo ko holene anda ibiragola  
\q2 tí biamogo bulene mbirali naholebiraore.   
\q1
\v 23 Mbiralime i̱hondo ka̱i̱ lalu lomabu ngialu kago\x + \xo 50.23 \xt Iba 27.6\x*  
\q2 ibugua i̱naga mini yaraga halu haga kagoni.  
\q1 Wali agali i̱naga bi hale halu i̱ andaneha haga karu  
\q2 ti i̱na pele mulebero, laragoni.   
\c 51  
\s1 Ko binigo domo wahelonaga Ngode Datagaliwabehondo bi lenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o gubalini haho wiaabo haga kego\x + \xo 51.1 \xt 2 Sml 12.1-15\x*\x + \xo 51.1 \xt Iba 109.26, Ais 43.25, Ab 3.19, Kl 2.14\x*  
\q2 í̠na i̱ore dara howa biamogo bibe.  
\q1 Í̠na wali agali dara nahabeheorego dara hagayagodago  
\q1 i̱ dara halu ko biruru domo wahabe.   
\q1
\v 2 I̱na ko biruru bibahende domo wahalu\x + \xo 51.2 \xt Ais 1.16, Yar 4.14, Hi 9.14\x*  
\q2 i̱ dodo nahe helabe.   
\b  
\q1
\v 3 Ko ngubiore birulo manda bialu\x + \xo 51.3 \xt Ais 59.12\x*  
\q2 miniha tagaore biaabo haragola haruli.   
\q1
\v 4 I̱na ko biruruni í̠hondo birugoni.\x + \xo 51.4 \xt 2 Sml 12.13, Lg 15.21, Lm 3.4\x*  
\q1 Mendealihondo biru lole ndo í̠hondoore birugoni.  
\q1 Í̠naga deni ko ngubiore birugoni.  
\q1 Ani birugonaga í̠na i̱hondo i̱ mana pugualu  
\q2 ko birigo pani nolene nga larego nde  
\q2 tigatiga labehedaguaore larego  
\q2 i̱ balolene henge nawiore manda bido.   
\q1
\v 5 I̱ pigane i̱ ai̱yahanda taba hanayangi howa\x + \xo 51.5 \xt Yob 15.14, Eb 2.3\x*  
\q2 ko hangu bialu haho winigo áyubi bialu dege kogoni.  
\q1 I̱ ai̱yanaga tombeha biruwabi mini kowi dege biraru.   
\b  
\q1
\v 6 Í̠na henene hangu lagabi  
\q2 miniha ko do nahebi kago hondowa turu haga kegoni.\x + \xo 51.6 \xt Iba 15.2, Min 2.6, Ya 1.5\x*  
\q1 Ani biaga kego í̠naga mini giga buleneme  
\q2 i̱naga miniha to̱lotagi helabe.   
\q1
\v 7 Dodo nahe holiya ko biruru domo wahabe.\x + \xo 51.7 \xt Dag 19.18, Ais 1.18, Hi 9.19\x*  
\q2 Bu miniha peweleore holiya i̱ wayawaya bia habe.   
\q1
\v 8 Bi baya turubiru halu mbira hale holiyanaga henge ngialu\x + \xo 51.8 \xt Iba 35.10, Ais 35.10, Yol 1.16\x*  
\q2 i̱na ko biruru domo wahabe.  
\q1 Í̠na i̱ hengedo mbaralo wahalu  
\q2 i̱naga kuniru minu bu̱ larigoyu  
\q2 i̱ lone heyalu turuho holebero.   
\q1
\v 9 I̱na ko ngubi biruruni í̠ de handa tara howa\x + \xo 51.9 \xt Yar 16.17\x*  
\q2 í̠na bibahendeore domo wahai habe.   
\b  
\q1
\v 10 Ngode Datagaliwabe-o i̱naga bu habaneha mini gahenge wabu wia habe.\x + \xo 51.10 \xt Iba 78.37, Md 5.8, Ab 15.9, Eb 2.10\x*  
\q1 Í̠naga bi larego hale halu bua holenego gahenge i̱ha wabu wia habe.   
\q1
\v 11 Í̠na i̱ kodago wahalu pu lowa bo batagi holeni.\x + \xo 51.11 \xt 2 Kin 13.23, Ais 63.10-11, Yar 7.15\x*  
\q2 Í̠naga Dinini tigabi i̱ha heledego tagira peloleni.   
\q1
\v 12 Pele ngini kogoni manda buwa turu ho haruligo\x + \xo 51.12 \xt Iba 13.5\x*  
\q2 turu biagoni ereba hayago lone ngiadai bibe.  
\q1 Bi larego hale halu biaga holiya biamogo bibe.   
\q1
\v 13 Ani beregola i̱na ko biaga karuhondo\x + \xo 51.13 \xt Iba 22.27, Ab 9.21-22\x*  
\q2 í̠naga bi lo ngedagua tihondo lawai holiya.  
\q1 Lawai harogola hale halu  
\q2 tigua í̠ni keria dai bulebirago bilo.   
\b  
\q1
\v 14 I̱na ko birurunaga homolenego hame naledogo\x + \xo 51.14 \xt 2 Sml 12.9, Iba 35.28, 71.15\x*  
\q2 Ngode Datagaliwabe-o i̱ pele ngibe.  
\q1 Ani beregola i̱na turu halu  
\q2 í̠ tigabi biaga ke lalu wali agali bi mana lamuliya.   
\q1
\v 15 I̱na í̠naga bi mana loliyabi  
\q2 Anduane Homogo í̠nime lamogo bibe.\x + \xo 51.15 \xt Har 4.15, Iba 9.14\x*  
\q1 Ani berego handalu i̱na í̠naga mini mo yaraga holebero.   
\b  
\q1
\v 16 Í̠na mbirale bo lomabu ngilo hame lagadale  
\q2 i̱na bo lomabu ngidolego\x + \xo 51.16 \xt Iba 40.6\x*  
\q2 ai í̠ hame nalagayago.  
\q1 Mbirale ngabi í̠ nga habelo lowa  
\q2 bo lomabu delaga dabuni delarogomebi  
\q2 í̠ mo turu nahagaya.  
\q1 Aniyagodago i̱na í̠hondo loma ngiradagua i̱ni í̠hondo ngerogoni.   
\q1
\v 17 Ngode Datagaliwabe-o í̠naga bi larego hale halu biaore bule lalu\x + \xo 51.17 \xt Iba 34.18\x*  
\q2 i̱ni áyu ngerogoni.  
\q1 I̱ni mo yadindi halu bu mini henene beregedalu i̱ni ngerogola  
\q2 í̠na nayamia nabulebere manda buwa áyu ngerogoni.   
\b  
\q1
\v 18 Ngode Datagaliwabe-o Saiono tano podope hayadago  
\q2 wali agali karu dara halu biamogo bibe.  
\q1 Yarusaleme wai pabe biago podo bagabu ibira ho ngago  
\q2 waitigi anda ibuligo  
\q1 í̠na ege pabe ogoni lone biadai bibe.   
\q1
\v 19 Anidagua bu howa mbirale bo lomabu ngulene ngadagua ngirimayaguabi  
\q2 mbirale bo lomabu delaga dabuni delarimayaguabi  
\q2 í̠ turu holebere.  
\q1 Nogo bulumaga wangaberubi í̠naga bo lomabu delaga dabuni bo deloleberema.   
\c 52  
\s1 Mana ko ngago hondowa turu haga karu ti lulu ale kago ogo  
\q1
\v 1 Agali timbuni hongohe tingiho kego\x + \xo 52.1 \xt 1 Sml 22.9-10\x*  
\q2 í̠nime mana ko bialu kegonaga turu howa mine haabo harego irane aginagabe.  
\q1 Ogonibi biaga kego  
\q2 Ngode Datagaliwabenaga deni í̠ koorene ko biaga kegoni.  
\q1 Ngode Datagaliwabe ibu mini bilinahe howa  
\q2 wali agali urunibihondo dara haabo haga kagoni.   
\q1
\v 2 Í̠na horo bibahendengi mendeali kago mo ko holene hangu manda bialu haga kegoni.\x + \xo 52.2 \xt Iba 50.19, 59.7, 64.3\x*  
\q1 Í̠naga hége leda ne gadele ale howa  
\q2 wali agali mende kago podaga kegoni ndobe.  
\q1 Ke̱ howa lolene hangu wai hanalu haabo harili.   
\q1
\v 3 Í̠na mana ko bulenego hame lalu  
\q2 mana bayale bulenego manga halu haga ke.  
\q1 Ke̱ holene damenego turu haga howa  
\q2 bi henene lolenego manga haga kegoni.   
\q1
\v 4 Í̠ ke̱ hagaore kegoni.  
\q1 Í̠na bi ko laregome  
\q2 wali agali karu mo tandaga haabo haga kegoni.   
\b  
\q1
\v 5 Ngode Datagaliwabehanda í̠ni andagaha bederia  
\q2 mo ko howa bo gililo batagi holebira.  
\q1 Ibugua í̠ wali agali dindi ogoria karu baba  
\q2 nahabelo bo waholebira.   
\q1
\v 6 Wali agali bayale tigabi bu karume  
\q2 í̠ha mbirale uruni birago hondowa  
\q2 ti gi timbuni ho holebira.  
\q1 Tigua í̠ hondo oba halu lalu,   
\q1
\v 7 Agali o kagome Ngode Datagaliwabehanda ibu biamogo bialu\x + \xo 52.7 \xt Iba 49.6\x*  
\q2 mo hongo helo ibuha hana nahe ka.  
\q1 Ibugua ibunaga muni mbirale ngaru hangu mo teneho howa  
\q2 mana ko bialu kogome i̱ biamogo biragola  
\q2 karulape holebero lo manda biaga kago de handa, lolebira.   
\b  
\q1
\v 8 Anigo i̱ ogonibi ndo kogoni.  
\q1 I̱ Ngode Datagaliwabenaga anda haneni  
\q2 ira olibe haradagua bidogoni.  
\q1 Ngode Datagaliwabe ibugua i̱ gubalini ho haabo haga kagonaga  
\q2 i̱na ibuhondo mini mbiraore wu haabo kogoni.   
\q1
\v 9 Ngode Datagaliwabe-o í̠na i̱ biamogo bialu haga kegonaga  
\q2 i̱na í̠hondo ka̱i̱ laabo holebero.  
\q1 Í̠naga wali agalirunaga deni howa  
\q2 i̱na í̠naga mini yaraga halu  
\q2 Ngode Datagaliwabehanda bayaleore biaga kagoni lalu latagi halu holebero.   
\c 53  
\s1 Wali agali mini kowinaga mana ogo  
\r (Iba Gana 14)  
\q1
\v 1 Wali agali mitangi yole biaga karume\x + \xo 53.1 \xt Iba 10.4, 14.1\x*\x + \xo 53.1 \xt Lm 3.10-12\x*  
\q2 tini miniha mandabu donge halu  
\q1 Ngode Datagaliwabe ogoni nahe laga ka.  
\q1 Wali agali mini urunibi wu karuni  
\q2 tini ko ngubi habane nabuleneore howa  
\q2 ko tara tara ngaru bima polenaga ani lalu ka.  
\q1 Mana tigabi hangu biaga mbirali naheore.   
\b  
\q1
\v 2 Ngode Datagaliwabehanda dahuliya andaga howa handadali halu\x + \xo 53.2 \xt 2 Bit 15.2, 19.3, Iba 33.13\x*  
\q2 wali agali bibahende bu karu de handai howa  
\q1 mbirali miniwi galone manda biagabi  
\q1 Ngode Datagaliwabe kalo manda bu hagabi  
\q2 au haga bidabe hondole handadali ho ka.   
\q1
\v 3 Ani handalu hearia mbirali naheore  
\q2 ti bibahende ko biai hene ogobi dege dege hoyu pearia hendeda.  
\q1 Hariga tigatiga polene wiadagua pene mbirali naheore  
\q2 bibahende putagi halu piai hene dege hearia hendene.  
\q1 Mana tigabi hangu biaga mbira naheore.  
\q1 Mbiraorebi mbira naheoreya.   
\b  
\q1
\v 4 Ngode Datagaliwabehanda lalu,  
\q1 Wali agali ko biaga uruni ti mini nawidabe.  
\q1 Ti galone mbira manda nabiagadabe.  
\q1 Wali agali ko biaga urunime  
\q2 i̱naga wali agali bameore ti tomo naradagua budu nalu kagoni.  
\q1 Ani bialu howa tigua i̱hondo bi mbira nalagaore kagoni, laragoni.   
\b  
\q1
\v 5 Ani bialu ha kagoyu Ngode Datagaliwabe ibugua  
\q2 ti mo gi timbuni taraore holebira.  
\q1 Abale ti gi ogonibi nahenedagua gi ho helo  
\q2 irane ibugua tínaga waitigi karu bo wahai halu  
\q2 tinaga kuni dindini hora nahe bu payapayabu ngelolebira.  
\q1 Ibugua wali agali uruni ti erembira miai hayagome  
\q2 ai ti mo ko howa bo wahai holebira.   
\b  
\q1
\v 6 I̱na Isaraele wali agali bibahende pele ngialu haru dai biai helo  
\q2 Ngode Datagaliwabehanda mbirali Saiono howa ibi nalara.  
\q1 Ngode Datagaliwabe ibugua ibunaga wali agali biamogo biragola  
\q2 ti bayuwa ho dungulo halu  
\q1 tigua mbirale bigi biraru bayale hangu haga birago hondowa  
\q2 tini turuore au holobadabe.   
\c 54  
\s1 Mbiralime Ngode Datagaliwabehanda biamogo bilonaga bi lenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o í̠naga hongome\x + \xo 54.1 \xt 1 Sml 23.19, 26.1\x*  
\q2 i̱ pele ngialu gi mibe.  
\q1 Í̠naga hongo timbunihe kegome  
\q2 i̱ golope hene holiya golope habe.   
\q1
\v 2 Ngode Datagaliwabe-o í̠na i̱naga bi larogo hale habe.  
\q1 I̱na bi larogo hale habelo hame ledogoni.   
\q1
\v 3 Agali minehe karu tigua i̱la wai bule íbu kagoni ndobe.  
\q1 Agali uruni ti wali agali maru bo wahole hamelo kagoni.  
\q1 Agali ko biaga uruni tigua Ngode Datagaliwabe  
\q2 í̠ nagalonedalo manda biaga kagoni.   
\b  
\q1
\v 4 Ngode Datagaliwabe ibunime i̱ biamogo biagaore kagoni ndobe.  
\q1 Anduane Homogo ibunime i̱ mo wialu  
\q2 hotali wiagane humbi ale haradagua biaga kagoni.   
\q1
\v 5 Ngode Datagaliwabehanda i̱naga waitigirume mana ko i̱hondo bialu hayaru  
\q2 tiniha daibu wiai helo.  
\q1 Ngode Datagaliwabe í̠ mini bilinahe kegome  
\q2 i̱naga waitigi karuni bo wahai habe.   
\b  
\q1
\v 6 Anduane Homogo-o i̱na í̠hondo turu howa  
\q2 mbirale ngoru lomabu ngule kogoni.  
\q1 Í̠ bayaleore kegonaga i̱na ka̱i̱ timbuniore larogoni.   
\q1
\v 7 I̱ha genda timbuni anda ibiyagola\x + \xo 54.7 \xt Iba 59.10\x*  
\q2 í̠na i̱ biamogo bialu harigoni.  
\q1 Í̠na i̱naga waitigi hearu bo waharigo  
\q2 i̱ de handarugoni.   
\c 55  
\s1 Mbiralime ibunaga nenege heagome ibu nde lenegonaga Ngode Datagaliwabehondo bi lenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o í̠na i̱naga bi larogo hale habe.  
\q1 I̱na dugu bialu bi larogo hale naholenaga hale pai nahabe.   
\q1
\v 2 Aiore i̱naga bi larogo baya hangu hale howa ladai bibe.  
\q2 Genda i̱ha ngagome i̱ni bope holene tiga birane hendedo.   
\q1
\v 3 Waitigi bu karume i̱ mo ko holenaga  
\q2 bi hongo howaore lalu kagoni ndobe.  
\q1 Agali ko karu tigua i̱ bopeore hole kagola  
\q2 i̱naga bu miniha mo ko henego kogoni.  
\q1 Tigua keba timbuni haragome  
\q2 i̱ha genda dewaore mo wiaga.   
\b  
\q1
\v 4 I̱ ti hondowa gi timbuni halu\x + \xo 55.4 \xt Iba 18.4-5, 116.3\x*  
\q2 i̱ni miniha homolenenaga gi holene íbu ngagoni.   
\q1
\v 5 I̱ ani giho kogola i̱naga tingini duru laragoni.  
\q2 Gi holene timbunime i̱ bope kagola kogoni ndobe.   
\q1
\v 6 Anigo i̱na ogodagua laro,\x + \xo 55.6 \xt Yob 3.13\x*  
\q1 Ainde i̱ babagane halu polene ega aleore hoa ho kogoni.  
\q1 I̱ ogonibi kole i̱na yagalo yu pialu  
\q2 mini ibilo dindi mbiraha ha̱lo birule manda bidole.   
\q1
\v 7 Yagalo yu pialu dindi kaundiaha  
\q2 wali agali mbira nahaga ngagoha puwa  
\q2 haabo hole manda bidole ndobe.   
\q1
\v 8 Iba dalu puyaburu hongoheore ibiragola  
\q2 i̱ abale yagalalu puwa bira do ho kole.   
\b  
\q1
\v 9 Anduane Homogo-o i̱na tanoha agali maru gungu bialu karia hendedogo  
\q2 í̠na tinaga bi larago mo luluya halu  
\q2 ti bo ereba hai habe.   
\q1
\v 10 Mbiraga horombebi tigua tanonaga ege pabe bidagoria  
\q2 daligani puíbu bialu haga ka.  
\q1 Wali agali tano ogoniha bu karume  
\q2 mana ko dewa mo ko holene ngaru biaabo haga kagoni.   
\q1
\v 11 Tano ogoniha wali agali bu karume  
\q2 tini bagabaga bialu mbirale ngarubi mo ko haga ka.  
\q1 Hariga gebage ngagoriabi ngoai haga hamanibi  
\q2 wali agali bu karume mendeali kago bame bime bope haga bialu  
\q2 tinaga mbirale yu kago yamule mo hondo haga bialu ka.   
\b  
\q1
\v 12 I̱ waitigi mbira kagome i̱hondo bi ko laede hayagua  
\q2 i̱na bi uruni lelo wahabehe ko.  
\q1 I̱ handabe manga haga kagome i̱ hondo oba halu mege biyagua  
\q2 i̱na ibu i̱ nahendelo bira do habehe kogoni.   
\q1
\v 13 Ai ani ndo o biyaruni í̠na birigoni.\x + \xo 55.13 \xt 2 Sml 15.12, Iba 41.9\x*  
\q1 Í̠ i̱naga nenegeore howa  
\q2 i̱la haabo haga kegoni ndobe.  
\q1 Iya haru haabo haga berebali ndobe.   
\q1
\v 14 Bamba iyane haru mandagi ibagabu halu te bayaleru lalu  
\q2 wali agali maru heba Ngode Datagaliwabenaga anda biago heagoria mandagi haribagoni ndobe.   
\q1
\v 15 I̱naga waitigi bu karunaga minihabi ti andagahabi  
\q2 mana ko dewaore wu to̱leda.  
\q1 Ti homolene tu ndo wene kaore abale homalu  
\q2 homene dininiru pu hagagoha piai helo hamelo kogoni.   
\b  
\q1
\v 16 I̱na Anduane Homogo i̱ninaga Ngode Datagaliwabehanda biamogo bilonaga olalu haabo kogoni.  
\q2 Ibugua i̱ pele ngialu mo wulebira.   
\q1
\v 17 Gendame i̱ bo hengedalu haabo kagonaga\x + \xo 55.17 \xt Iba 92.2, Ab 10.3, 10.30\x*  
\q2 i̱na egerebagi horombe mbiragabi ibuhondo dugu bu mialu haabo haruli.  
\q1 I̱na bi larogola ibugua hale holebira.   
\q1
\v 18 Waitigi dewaoreme i̱la wai bialu haga karu helowa  
\q2 ibunime i̱ bayale mo wialu haru dai bigi bulebira.   
\q1
\v 19 Tigua ibuhondo gi nahaga howa  
\q2 ko biyarunaga mini beregedolene manga haga ka.  
\q1 Ngode Datagaliwabe ibu kini henego áyubi haabo kagoni howa  
\q1 ibugua i̱naga bi lamerogo hale halu  
\q2 waitigi karu bope hai howa wayali holebira.   
\b  
\q1
\v 20 I̱naga nenege ala henego ogoni  
\q2 ibugua ibuninaga nenege bu karu baba wai bialu haya.  
\q1 Ibu baba buleore lalu bi abale lo wiyaru mo habolaya.   
\q1
\v 21 Ibunaga ne harigaha bi bayale dendebi lalu\x + \xo 55.21 \xt Iba 12.2, 28.3, 59.7, Min 5.3-4\x*  
\q2 miniha i̱la waitigi haya.  
\q1 Ibunaga bime i̱ miniha dungulo helaga biyagoyu  
\q2 bi ogoni ayu tibu ne gadeleore ale howa bo podaga nga.   
\b  
\q1
\v 22 Í̠ genda yu keruni bibahende\x + \xo 55.22 \xt Iba 15.5, 37.5, 1 Pi 5.7\x*  
\q2 Anduane Homogo ibunaga giha mo yaholene nga.  
\q1 Ibugua í̠naga genda uruni mo yalu  
\q2 í̠ mo hongo holebira.  
\q1 Anduane Homogo ibugua agali ko bu karume  
\q2 mana tigabi biaga karu bibahende mo ko helo yupe naholebira.   
\b  
\q1
\v 23 Ngode Datagaliwabe-o í̠na agali ko mendeali homelo bo wahaga bu karubi  
\q2 ke̱ halu mo hondo haga karubi  
\q1 ti holene ha maro nabi hongohe kaore dege  
\q2 homaliha ereba hai helo bo talu pelai habe laro.  
\q1 I̱ nde í̠hondo mini mbiraore hongohe wu haabo holebero.   
\c 56  
\s1 Agali mini mbiraorewime Ngode Datagaliwabehondo bi lenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o í̠na i̱ dara howa biamogo bibe.\x + \xo 56.1 \xt 1 Sml 21.13-15\x*  
\q1 Agali bu karume i̱ talima ibaga bialu bo wahole kagoni.  
\q1 Waitigime i̱ mo ko hole manda bialu haabo kagoni.   
\q1
\v 2 Waitigi karume egerebagi howa i̱ bole bialu heane  
\q2 alendo haga bialu haabo kagoni ndobe.  
\q1 Ti dewalioreme i̱ baba waitigi ho ka.   
\q1
\v 3 Anduane Homogo Daligaorene Daliga kego-o\x + \xo 56.3 \xt 1 Sml 30.6, 2 Bit 20.3\x*  
\q2 i̱ha gi holene anda ibirangi  
\q2 i̱na í̠hondo mini mbiraore wialu haabo haruli.   
\q1
\v 4 I̱na Ngode Datagaliwabehondo mini mbiraore wu kogome\x + \xo 56.4 \xt Iba 118.6, Ais 31.3, Hi 13.6\x*  
\q2 mbirale ngaru hondowa i̱ gi naharuli.  
\q1 I̱na ibunaga bi henene lo ngaru mitangi bialu  
\q2 ibunaga mini yaraga haabo halu kogoni.  
\q1 Agali karume i̱hondo bulene mbira nawigo agi bulubadabe.   
\b  
\q1
\v 5 I̱na mbira bule kogola  
\q2 waitigi karume mo ko hole manda biaabo haga ka.  
\q1 Tigua i̱ mo tandaga hole hariga taya bialu haabo ka.   
\q1
\v 6 Ti mo ngoai halu ha do howa  
\q2 i̱na mbira bule bialu koria de yu howa  
\q2 tigua i̱ bo wahole hamelalu ani biaabo haga ka.   
\q1
\v 7 Ngode Datagaliwabe-o tigua mana ko bialu kagonaga pani nelo mibe.  
\q1 Í̠na tihondo keba timbuni howa bope habe.   
\b  
\q1
\v 8 I̱naga genda yu kogobi bu miniha mo ko hene kogobi  
\q2 í̠ manda bu kegoni.  
\q1 I̱na dugu birugonaga de iba ibiyago  
\q2 í̠na í̠naga iba beha berelo kegoni.  
\q1 Í̠na uruni mitangi bu haabo howa  
\q2 í̠naga mbugaha gilibu ngegoni.   
\q1
\v 9 I̱na í̠ olarongi i̱naga waitigi ibida piai holebira.\x + \xo 56.9 \xt Iba 56.4, Lm 8.31\x*  
\q1 Ngode Datagaliwabe-o ti ani biragola  
\q2 i̱na mbira manda bidogoore ogo  
\q2 í̠na i̱hayagi haabo kegoni mandabu kogoni.   
\q1
\v 10 I̱na Ngode Datagaliwabenaga bi henene lo ngaru mitangi bialu  
\q2 ibu mini yaraga halu kogoni.  
\q1 I̱na Anduane Homogonaga bi lo ngarunaga  
\q2 ibu mini yaraga halu kogoni.   
\q1
\v 11 I̱na ibuhondo mini mbiraore wu kogome\x + \xo 56.11 \xt Iba 56.4\x*  
\q2 mbirale ngaru hondowa gi naholebero.  
\q1 Agali uruni tigua i̱hondo mbira bulene nawigo agi bulubadabe.   
\b  
\q1
\v 12 Ngode Datagaliwabe-o i̱na mbira bule lalu í̠hondo lo wirugoni biaore bulebero.  
\q1 I̱na í̠hondo turu howa  
\q2 ka̱i̱ lolenaga loma mbira ngulebero.   
\q1
\v 13 Irane i̱ homole hewaria í̠na pele ngialu mo wirigonagabi  
\q2 waitigirume i̱ bope nahelo i̱ handaya halu biamogo birigonagabi  
\q1 i̱na loma ogoni ani ngulebero.  
\q1 Ngode Datagaliwabe-o í̠ heba ibagabu kogome  
\q2 i̱na í̠naga wá holene ngegoria í̠naga deni haaboore holebero.   
\c 57  
\s1 Ngode Datagaliwabehondo biamogo bia lalu bi lenego ogo  
\q1
\v 1 Ngode Datagaliwabe-o í̠na i̱hondo dara howa biamogo bibe.\x + \xo 57.1 \xt 1 Sml 22.1, 24.3\x*\x + \xo 57.1 \xt Iba 56.1, 63.7, Ais 26.20\x*  
\q1 Í̠na i̱ handayaho habelo í̠ni keria eberogoni.  
\q1 Ega bawalime igini babaganeha tongo bidagola bayale biragadagua  
\q2 i̱ í̠niha kogola bayale holebero.  
\q1 Dalu puyabubi timbuniore ibagadagua  
\q2 i̱ mo ko holene íbu ngago ereba hai helonaga  
\q2 i̱ í̠ni andaneha haabo holebero.   
\b  
\q1
\v 2 I̱na Ngode Datagaliwabe Daligaorene Daliga kagohondo  
\q2 i̱ biamogo bia lole olalu haabo haruli.  
\q1 Ibugua mbirale bibahende i̱ha tubagiho kogo damene ngiai haga ka.\x + \xo 57.2 \xt Iba 38.8\x*   
\q1
\v 3 Ibugua dahuliya andagaha howa i̱naga bi larogo hale halu i̱ pele ngulebira.  
\q1 Ibugua agali i̱ mo ko hole karu bope hai holebira.  
\q1 Ngode Datagaliwabehanda ibunaga gubalini haabo holenebi  
\q2 mini bilinahe holenebi i̱ walia halu  
\q2 ibugua i̱ yu wahalu napolebiraore.   
\b  
\q1
\v 4 Laiono gabuame wali agali bo nole nendebu hagadagua\x + \xo 57.4 \xt Iba 55.21, 64.3, Min 30.14\x*  
\q2 i̱ koria waitigirume ho mabu bu kagoni.  
\q1 Tinaga ne timu yandareru ale taraore ho ka.  
\q1 Tinaga hége wai biaga ayu tibu ne gadele ale ho ka.   
\b  
\q1
\v 5 Ngode Datagaliwabe-o í̠ni timbuniore dunini kego  
\q2 wali agali handai helo  
\q2 hari daligani mo walia habe.  
\q1 Dindi bibahendeha í̠naga wá holenebi mini lene holenebi  
\q2 panigi mo walia ho ngelabe.   
\b  
\q1
\v 6 Waitigi bu karume i̱ delo gono wia do ho kagome  
\q2 i̱ genda timbuni yu kogoni.  
\q1 Tigua hariga i̱ polenego uli tombo wu kagoha  
\q2 gabua pilagadagua i̱ pilelo winigo  
\q2 uli ogoniha tini pilai haya.   
\b  
\q1
\v 7 Ngode Datagaliwabe-o i̱na mini bilinahe howa\x + \xo 57.7 \xt Iba 108.1\x*  
\q2 í̠hondo mini mbiraore hongohe wu kogonigo  
\q2 i̱na iba ganaru lalu í̠naga mini yaraga halu holebero.   
\q1
\v 8 I̱ni padogoria heyuwa  
\q2 i̱na ngida aleru barogome  
\q2 ni tagira ibilo mo heya holebero.   
\q1
\v 9 Anduane Homogo-o i̱na dindi tara tara ngaruha pu howa  
\q2 í̠hondo ka̱i̱ laabo holebero.  
\q1 Hameigini tara tarabu karuha pialu  
\q2 i̱na í̠naga mini yaraga hama polebero.   
\q1
\v 10 Anduane Homogo-o í̠naga gubalini haabo holene emene ndoore\x + \xo 57.10 \xt Iba 36.5, 103.11, 108.4\x*  
\q2 hari daliga elahe wu kegoni.  
\q1 Í̠naga mini bilinahe ngego timbuni yangale howa  
\q2 hari mindini elahe wu kegoni.   
\q1
\v 11 Ngode Datagaliwabe-o í̠ni timbuniore dunini kego  
\q2 wali agalime handai helo  
\q2 hari daligani mo walia habe.  
\q1 Dindi bibahendeha í̠naga wá holenebi mini lene holenebi  
\q2 panigi mo walia ho ngelabe.   
\c 58  
\s1 Ko biaga karu pani mibe lalu Ngode Datagaliwabehondo bi lenego ogo  
\q1
\v 1 Agali haguane bu kamiru-o tígua godi hale halu howa  
\q2 bi tigabi lolene ngadagua laramilibe.  
\q1 Tígua wali agali bibahende tigatiga dabaki biaga kamibe.   
\q1
\v 2 Ani ndoore. Tínaga miniha ko bulene hangu wu to̱latagi ho kamigoni ndobe.  
\q1 Tígua dindi bibahendeha wali agali bu karu homelo  
\q2 bo wahaga biaga kamigoni.   
\b  
\q1
\v 3 Mini kowi karume dindini ibagabu kangi  
\q2 ko dege biaabo haga kagoni.  
\q1 Ti ai̱yahanda ti taba hanayangi howa  
\q2 ke̱ dege halu henego áyubi anidagua dege bialu haabo ka.   
\q1
\v 4 Tinaga bi larago damene bibahende nogombi taranaga tomia ale ka.  
\q1 Tinaga hale tuluho wahene nogombi ale howa  
\q2 bi larago mbira hale habe nahe ka.   
\q1
\v 5 Agali maru manda timbunibi karume  
\q2 nogombi heyalu mali lilonaga iba gana laragola  
\q2 nogombime hale nahagadagua ko biaga uruni ti hale nahaga ka.  
\q1 Agali manda timbunibirume nogombi heyalu mali lilonaga pilipe laragola hale nahagdagua  
\q2 agali uruni ti hale nahagaore ka.   
\b  
\q1
\v 6 Ngode Datagaliwabe-o agali ko uruni bo wahai habe.  
\q1 Anduane Homogo-o agali uruni ti laiono gabua kebahe agali hayaga ale kago  
\q2 tinaga ne bo gingirulo baga bialu ne bibahende dugu wahai habe.   
\q1
\v 7 Iba dindini ibira haragola abale yo bialu ereba hagadagua  
\q2 agali ko uruni ereba hai helabe.  
\q1 Datani gahenge harigani anda harago geme hengedaragola gaulai hagadagua  
\q2 agali ko uruni bo hengedai habe.   
\q1
\v 8 Gangade dindiha biralu homaragola ngu biagadaguabi\x + \xo 58.8 \xt Yob 3.16\x*  
\q2 waneigini gali ai̱ya tombeha bedaore homenego  
\q2 taba hanaragola wá nahende  
