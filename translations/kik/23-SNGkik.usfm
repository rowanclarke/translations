\id SNG - Biblica® Open Kikuyu Holy Word of God
\h Rwĩmbo
\toc1 Rwĩmbo rũrĩa Rwega mũno
\toc2 Rwĩmbo
\toc3 Rwĩ
\mt1 RWĨMBO RŨRĨA RWEGA MŨNO
\c 1
\p 
\v 1 Rũrũ nĩruo rwĩmbo rwa Solomoni rũrĩa rwega gũkĩra nyĩmbo ciothe.
\sp Mwendwa
\q1 
\v 2 Ta nĩamumunye na mamumunya ma kanua gake:
\q2 nĩ ũndũ wendo waku nĩ mwega gũkĩra ndibei.
\q1 
\v 3 Mũtararĩko wa maguta macio wĩhakĩte nĩ mwega;
\q2 rĩĩtwa rĩaku no ta mũtararĩko wa maguta manungi wega magĩitanĩrĩrio.
\q2 Na nokĩo wendetwo nĩ airĩtu!
\q1 
\v 4 Ndũkandige, nĩtũthiĩ nawe; reke twĩhĩke!
\q2 Mũthamaki nĩandoonyie nyũmba ciake cia thĩinĩ.
\sp Arata
\q1 Tũgũcanjamũka na tũkene nĩ ũndũ waku;
\q2 tũrĩkumagia wendo waku gũkĩra ndibei.
\sp Mwendwa
\q1 Kaĩ marĩ na kĩhooto gĩa gũkwenda-ĩ!
\b
\q1 
\v 5 Niĩ ndĩ mũirũ, no ndĩ mũthaka,
\q2 inyuĩ aarĩ a Jerusalemu,
\q2 njirĩte o ta hema cia Kedari,\f + \fr 1:5 \ft Andũ a Kedari maarĩ Arabu arĩa maatũũraga gũkuhĩ na Edomu, na hema ciao ciatumagwo na guoya wa mbũri njirũ.\f*
\q2 ngaagĩra o ta itambaya cia gũcuuria hema cia Solomoni.
\q1 
\v 6 Tigai kũndora nĩ ũndũ ndĩ mũirũ,
\q2 tondũ njirĩte nĩ kũhĩa nĩ riũa.
\q1 Ariũ a maitũ nĩmandakarĩire,
\q2 makĩndua mũrori wa mĩgũnda ya mĩthabibũ;
\q2 no mũgũnda wakwa wa mĩthabibũ nĩndĩũrekereirie.
\q1 
\v 7 Atĩrĩrĩ, wee nyendete, ta njĩra harĩa ũrarĩithĩria rũũru rwaku rwa mbũri,
\q2 njĩĩra harĩa ũkwarahia ngʼondu ciaku mĩaraho.
\q1 Ingĩikara atĩa ta mũtumia mũhumbe maitho
\q2 ndũũru-inĩ cia arata aku?
\sp Arata
\q1 
\v 8 We mũthaka kũrĩ andũ-a-nja othe, akorwo ndũũĩ-rĩ,
\q2 umagara ũrũmĩrĩre makinya ma ngʼondu,
\q1 ũkarĩithĩrie tũũri twaku
\q2 hakuhĩ na hema cia arĩithi.
\sp Mwendani
\q1 
\v 9 Wee, mwendwa wakwa-rĩ, ngũgerekanagia na mbarathi ya mũgoma
\q2 yohereirwo ngaari ĩmwe ya ngaari cia ita rĩa Firaũni.
\q1 
\v 10 Makai maku-rĩ, mathakarĩirwo mũno nĩ icũhĩ cia matũ,
\q2 nayo ngingo yaku ĩkaagĩrĩrwo nĩ mĩgathĩ ya tũhiga twa goro.
\q1 
\v 11 Tũgũgũthondekera icũhĩ cia matũ cia thahabu,
\q2 ciohanĩtio na tũbungo twa betha.
\sp Mwendwa
\q1 
\v 12 Rĩrĩa mũthamaki aarĩ metha-inĩ yake-rĩ,
\q2 maguta makwa manungi wega maiyũrĩtie mũtararĩko wamo kũu.
\q1 
\v 13 Mwendwa wakwa harĩ niĩ-rĩ, ahaana ta koohe ka manemane\f + \fr 1:13 \ft Manemane nĩ mahuti manungaga wega maacinwo na mwaki, na monekaga Ethiopia, Irathĩro-rĩa-Gatagatĩ, na India.\f*
\q2 gakomeire gatagatĩ ka nyondo ciakwa.
\q1 
\v 14 Mwendwa wakwa harĩ niĩ-rĩ, nĩ ta kamanja ka mahũa ma mũhanuni
\q2 kuuma mĩgũnda-inĩ ya mĩthabibũ ya Eni-Gedi.\f + \fr 1:14 \ft Eni-Gedi nĩ handũ haarĩ maaĩ werũ-inĩ, na haarĩ mwena wa ithũĩro wa Iria rĩa Cumbĩ, naho nĩhakũraga mahuti maingĩ manungi wega.\f*
\sp Mwendani
\q1 
\v 15 Hĩ! Kaĩ wee mwendwa wakwa ũkĩrĩ mũthaka-ĩ!
\q2 Hĩ, ti-itherũ ũrĩ mũthaka!
\q2 Maitho maku magĩrĩte o ta ma ndutura.
\sp Mwendwa
\q1 
\v 16 Hĩ! Kaĩ wee mwendwa wakwa ũkĩrĩ mũthaka-ĩ!
\q2 Kaĩ ũkĩrĩ wa kwendeka-ĩ!
\q2 Na ũrĩrĩ witũ nĩ ta nyeki ĩrĩa nduru.
\sp Mwendani
\q1 
\v 17 Mĩratho ya nyũmba iitũ nĩ ya mĩtarakwa;
\q2 nayo mĩitĩrĩro yayo nĩ ya mĩkarakaba.
\c 2
\sp Mwendwa
\q1 
\v 1 Niĩ ndĩ ihũa rĩa Sharoni,
\q2 ningĩ gĩtoka gĩa ituamba-inĩ.\f + \fr 2:1 \ft Gĩtuamba-inĩ gĩa Kĩrĩma gĩa Karimeli nĩ gwakũraga mahũa ma mĩmera ĩtarĩ mĩraihu, na maarĩ ma rangi mwerũ, kana wa ndathi, kana wa ngoikoni.\f*
\sp Mwendani
\q1 
\v 2 O ta gĩtoka kĩrĩ mĩigua-inĩ-rĩ,
\q2 nĩguo mwendwa wakwa atariĩ arĩ gatagatĩ ka airĩtu arĩa angĩ.
\sp Mwendwa
\q1 
\v 3 O ta mũtĩ wa mũtunda ũrĩ mĩtĩ-inĩ ya gĩthaka-rĩ,
\q2 nĩguo mũnyendi atariĩ arĩ gatagatĩ ka aanake arĩa angĩ.
\q1 Ngenagĩra gũikara kĩĩgunyĩ-inĩ gĩake,
\q2 namo matunda make ngĩmacama njiguaga marĩ mũrĩo.
\q1 
\v 4 Nĩandoonyetie nyũmba nene ĩrĩa ĩrĩĩagĩrwo iruga,
\q2 nayo bendera ĩrĩa ahaicĩtie igũrũ rĩakwa nĩ wendo.
\q1 
\v 5 Njĩkĩrai hinya na thabibũ iria nyũmithie,
\q2 mũnjerũhĩrie hinya na matunda,
\q2 nĩ ũndũ ndĩ mũcuce nĩ wendo.
\q1 
\v 6 Guoko gwake kwa ũmotho akũigĩte rungu rwa mũtwe wakwa,
\q2 nakuo guoko gwake kwa ũrĩo gũkaahĩmbĩria.
\q1 
\v 7 Inyuĩ aarĩ a Jerusalemu, ndamwĩhĩtithia na thiiya,
\q2 na mĩgoma ya thwariga cia werũ-inĩ atĩrĩ:
\q1 Mũtikoimbuthũre wendo o na kana mũwarahũre,
\q2 o nginya wĩrirĩrie kwarahũka guo mwene.
\b
\q1 
\v 8 Ta thikĩrĩria, ũcio nĩ mwendwa wakwa!
\q2 Ta rora! Ĩĩ nĩwe ũyũ ũroka,
\q1 akĩrũgaga akĩrĩire irĩma-inĩ,
\q2 arooka agĩtũrũhaga tũrĩma-inĩ.
\q1 
\v 9 Mwendwa wakwa ahaana ta thiiya, kana ta thwariga ĩrĩa nyanake.
\q2 Ta kĩrore! Nĩwe ũũrĩa ũrũngiĩ thuutha wa rũthingo rwitũ,
\q1 ararorera ndirica-inĩ,
\q2 agacũthĩrĩria mĩanya-inĩ.
\q1 
\v 10 Mwendwa wakwa aaririe akĩnjĩĩra atĩrĩ,
\q2 “Mũrata wakwa, o wee mũthaka,
\q2 ũkĩra tũthiĩ.
\q1 
\v 11 Atĩrĩrĩ! Hĩndĩ ya heho nĩ thiru;
\q2 nayo mbura nĩĩkĩĩte ĩgatiga kuura.
\q1 
\v 12 Nĩ hĩndĩ mahũa marakunũka thĩ;
\q2 ihinda rĩa kũina nĩikinyu,
\q1 mĩgambo ya ndutura
\q2 nĩĩraiguuo bũrũri-inĩ witũ.
\q1 
\v 13 Mũkũyũ-rĩ, nĩũrutĩte ngũyũ cia mbere;\f + \fr 2:13 \ft Kũu Isiraeli mĩkũyũ yaciaraga maita meerĩ mwaka.\f*
\q2 mĩthabibũ ĩrĩa ĩratumũra kĩro nĩĩraruta mũtararĩko wayo wega.
\q1 Ũkĩra, ũka mũrata wakwa;
\q2 o wee wakwa mũthaka, ũkĩra tũthiĩ.”
\sp Mwendani
\q1 
\v 14 Ndutura yakwa wee ũrĩ mĩatũka-inĩ ya rwaro rwa ihinga,
\q2 kũu ciĩhitho-inĩ cia hurũrũka cia irĩma,
\q1 nyonia ũthiũ waku,
\q2 ta reke njigue mũgambo waku;
\q1 nĩ ũndũ mũgambo waku nĩ mwororo,
\q2 na ũthiũ waku nĩ mũthaka.
\q1 
\v 15 Tũnyitĩrei mbwe,
\q2 o tũbwe tũu tũnini,
\q1 tũrĩa tũthũkagia mĩgũnda ya mĩthabibũ,
\q2 o mĩthabibũ ĩyo iitũ ĩratumũra kĩro.
\sp Mwendwa
\q1 
\v 16 Mwendwa wakwa nĩ wakwa na niĩ ndĩ wake;
\q2 arĩithagia kũrĩa kũrĩ itoka.
\q1 
\v 17 Hũndũka nginya rĩrĩa kũrĩĩrura,
\q2 nacio ciĩruru ciirĩrie.
\q1 Hũndũka mwendwa wakwa,
\q2 tuĩka ta thiiya,
\q1 kana ta thwariga nyanake,
\q2 ĩrĩ irĩma-inĩ cia Betheri.
\b
\c 3
\q1 
\v 1 Ũtukũ wothe ndĩ ũrĩrĩ-inĩ wakwa
\q2 ndĩracaragia ũcio ngoro yakwa yendete;
\q2 ndĩramũcaririe, no ndinamuona.
\q1 
\v 2 Nĩngũũkĩra thiĩ ngacangacange itũũra-inĩ inene,
\q2 hungure njĩra-inĩ ciarĩo na nja ciarĩo;
\q1 thiĩ ngeethe ũcio ngoro yakwa yendete.
\q2 Nĩ ũndũ ũcio ngĩmũcaria, no ndiigana kũmuona.
\q1 
\v 3 Arangĩri nĩmanyonire,
\q2 magĩthiũrũrũka itũũra-inĩ rĩu inene.
\q2 Ngĩmooria atĩrĩ, “Nĩmuonete ũrĩa ngoro yakwa yendete?”
\q1 
\v 4 O ndamahĩtũka o ũguo,
\q2 nĩguo ndonire ũrĩa ngoro yakwa yendete.
\q1 Ngĩmũnyiita na ndiamũrekirie,
\q2 o nginya ngĩmũtoonyia nyũmba ya maitũ,
\q2 ngĩmũtoonyia kanyũmba ga thĩinĩ ka ũrĩa wanjiarire.
\q1 
\v 5 Inyuĩ aarĩ a Jerusalemu, ndamwĩhĩtithia na thiiya,
\q2 na mĩgoma ya thwariga cia werũ-inĩ atĩrĩ:
\q1 Mũtikoimbuthũre wendo o na kana mũwarahũre,
\q2 o nginya wĩrirĩrie kwarahũka guo mwene.
\b
\q1 
\v 6 Nũũ ũyũ ũroka ambatĩte oimĩte werũ-inĩ
\q2 ahaana ta itu rĩa ndogo,
\q1 arĩ mũtararĩko wa manemane na ũbani,
\q2 iria ithondeketwo na mahuti mothe manungi wega ma mwonjoria?
\q1 
\v 7 Atĩrĩrĩ! Nĩ ngaari ya gũkuua Solomoni,
\q2 yumagarĩtio nĩ njamba cia ita mĩrongo ĩtandatũ,
\q2 iria ndĩĩe mũno cia Isiraeli,
\q1 
\v 8 othe meeohete hiũ cia njora,
\q2 na othe marĩ na ũũgĩ wa mbaara,
\q1 o ũmwe wao eyohete rũhiũ rwa njora,
\q2 ehaarĩirie nĩ ũndũ wa imakania iria ingĩũka ũtukũ.
\q1 
\v 9 Mũthamaki Solomoni nĩethondekeire ngaari ya kũmũkuuaga;
\q2 amĩakĩte na mĩtĩ ya kuuma Lebanoni.
\q1 
\v 10 Itugĩ ciayo atumithĩtie cia betha,
\q2 naguo mwĩtiiro wayo nĩ wa thahabu,
\q1 gĩtĩ kĩayo kĩgemetio na gĩtambaya kĩa rangi wa ndathi,
\q2 mwena wa thĩinĩ wayo ũgemetio na wendo
\q2 nĩ aarĩ a Jerusalemu.
\q1 
\v 11 Inyuĩ aarĩ a Zayuni ta kiumei,
\q2 mwĩrorere Mũthamaki Solomoni ekĩrĩte thũmbĩ,
\q2 thũmbĩ ĩrĩa nyina aamwĩkĩrire
\q1 mũthenya wake wa kũhikania,
\q2 mũthenya o ũrĩa ngoro yake yakeneire.
\c 4
\sp Mwendani
\q1 
\v 1 Hĩ, kaĩ wee mwendwa wakwa ũkĩrĩ mũthaka-ĩ!
\q2 Ĩĩ ti-itherũ ũrĩ mũthaka!
\q2 Maitho maku mahaana ta ma ndutura makĩonerwo hau taama-inĩ ũcio ũkũhumbĩrĩte ũthiũ.
\q1 Njuĩrĩ yaku no ta rũũru rwa mbũri\f + \fr 4:1 \ft Mbũri ciarĩ njirũ-ci ta njuĩrĩ.\f*
\q2 rũgĩikũrũka Kĩrĩma-inĩ kĩa Gileadi.
\q1 
\v 2 Magego maku mahaana ta rũũru rwa ngʼondu ciarĩkia kũmurwo guoya o ũguo,
\q2 ikĩambata ciumĩte gũthambio.
\q1 O ĩmwe yacio ĩrĩ na ihatha rĩayo;
\q2 hatirĩ o na ĩmwe yacio ĩrĩ iiki.
\q1 
\v 3 Mĩromo yaku ĩhaana ta uuthi mũtune;
\q2 kanua gaku kagĩrĩte mũno.
\q1 Thĩa ciaku ihaana ta ciatũ igĩrĩ cia itunda rĩa mũkomamanga,
\q2 ikĩonerwo hau taama-inĩ ũcio ũkũhumbĩrĩte ũthiũ.
\q1 
\v 4 Ngingo yaku ĩhaana ta mũthiringo ũrĩa mũraihu wa Daudi,
\q2 wakĩtwo wega mũno;
\q1 nakuo gũgacuurio ngo ngiri,
\q2 na ciothe nĩ ngo cia njamba cia ita.
\q1 
\v 5 Nyondo ciaku cierĩ ihaana ta ciana igĩrĩ cia thiiya,
\q2 ikahaana ciana cia mahatha cia thiiya
\q2 ikĩrĩa itoka-inĩ.
\q1 
\v 6 Nĩngũthiĩ kĩrĩma-inĩ kĩa manemane,
\q2 na nginye karĩma-inĩ ka ũbani,
\q1 njikare kuo nginya kũrĩĩrura,
\q2 nacio ciĩruru ciirĩrie.
\q1 
\v 7 Wee mwendwa wakwa ũrĩ mũthaka biũ;
\q2 ndũrĩ na kameni o na kanini.
\b
\q1 
\v 8 Ũka tũthiĩ nawe, mũhiki wakwa, tuume Lebanoni,
\q2 nĩtũthiĩ nawe tuume Lebanoni.
\q1 Harũrũka uume gacũmbĩrĩ-inĩ ka Amana,
\q2 ũkiume kĩrĩma gĩa Seniru, o gacũmbĩrĩ ka Herimoni,
\q1 uume kũu imamo-inĩ cia mĩrũũthi,
\q2 ũkiume irĩma-inĩ icio cia ngarĩ.
\q1 
\v 9 Nĩũtahĩte ngoro yakwa, wee mwarĩ wa maitũ, o wee mũhiki wakwa;
\q2 nĩũtahĩte ngoro yakwa
\q1 na irora o rĩmwe rĩa maitho maku,
\q2 na ithaga rĩmwe rĩa mũgathĩ waku wa ngingo.
\q1 
\v 10 Wee mwarĩ wa maitũ, o we mũhiki wakwa, kaĩ wendo waku nĩ wa gũkenerwo-ĩ!
\q2 Ĩĩ wendo waku nĩ wa gũkenania mũno gũkĩra ndibei,
\q2 naguo mũtararĩko wa maguta maku nĩ mwega kũrĩ wa mahuti mothe marĩa manungi wega!
\q1 
\v 11 Wee mũhiki wakwa, mĩromo yaku ĩtaatagia mũrĩo ta magua ma ũũkĩ;
\q2 iria na ũũkĩ irĩ rungu rwa rũrĩmĩ rwaku.
\q2 Mũtararĩko mwega wa nguo ciaku no ta ũrĩa wa Lebanoni.
\q1 
\v 12 Wee mwarĩ wa maitũ, o wee mũhiki wakwa, ũhaana ta mũgũnda mũirigĩre,
\q2 ũkahaana ta gĩthima kĩirigĩre,\f + \fr 4:12 \ft Ithima nĩciakunĩkagwo nĩgeetha maaĩ matikagĩe gĩko.\f* na ta itherũkĩro rĩa maaĩ ihingĩrĩrie.
\q1 
\v 13 Thuuna ciaku nĩ ta mũgũnda wa mĩtĩ ya mĩkomamanga
\q2 ĩ na matunda mega mũno,
\q2 ũrĩ na mĩhanuni, na mĩtĩ ĩrĩa yumaga uundi,
\q2 
\v 14 ĩkoima uundi na manjano,
\q2 na irago na mĩndarathini,
\q2 hamwe na mũtĩ o wothe wa ũbani,
\q2 na manemane na thubiri,
\q2 na mahuti mothe marĩa manungi wega mũno.
\q1 
\v 15 Wee-rĩ, ũrĩ itherũkĩro rĩa maaĩ rĩrĩ mũgũnda,
\q2 ũrĩ gĩthima kĩa maaĩ megũtherera,
\q2 maikũrũkĩte moimĩte Lebanoni.\f + \fr 4:15 \ft Kĩrĩma kĩa Lebanoni kĩarĩ na ira (tharunji) rĩrĩa rĩatwekaga rĩkaiyũria tũrũũĩ maaĩ.\f*
\sp Mwendwa
\q1 
\v 16 Wee rũhuho rwa gathigathini ũkĩra,
\q2 nawe rũhuho rwa gũthini-rĩ, ũka!
\q1 Hurutanaai mũgũnda-inĩ wakwa,
\q2 nĩguo mũtararĩko waguo ũhunje kũndũ kũraya.
\q1 Mwendwa wakwa nĩatoonye mũgũnda-inĩ wake,
\q2 na arĩe matunda maguo o macio mega mũno.
\c 5
\sp Mwendani
\q1 
\v 1 Wee mwarĩ wa maitũ o wee mũhiki wakwa, nĩndoka mũgũnda-inĩ wakwa;
\q2 nĩnjookanĩrĩirie manemane makwa na mahuti makwa marĩa mangĩ manungi wega.
\q1 Nĩndĩĩte magua makwa, o na ũũkĩ wakwa;
\q2 nĩnyuĩte ndibei yakwa, o na iria rĩakwa.
\sp Arata
\q1 Inyuĩ arata-rĩ, rĩai na mũnyue;
\q2 inyuĩ mwendaine-rĩ, nyuai nginya mũiganie.
\sp Mwendwa
\q1 
\v 2 Ndĩrarĩ toro, no ngoro yakwa nĩĩreiguĩte.
\q2 Ta thikĩrĩria! Mwendwa wakwa nĩararingaringa mũrango, akiugaga atĩrĩ:
\q1 “Mwarĩ wa maitũ, wee mwendwa wakwa, wee ndutura yakwa,
\q2 o wee wakwa ũtarĩ kaũcuuke-rĩ, hingũrĩra.
\q1 Mũtwe wakwa nĩũihũgĩtio nĩ ime,
\q2 njuĩrĩ yakwa ĩkaiyũra ireera rĩa ũtukũ.”
\q1 
\v 3 Nĩndutĩte nguo yakwa ya igũrũ:
\q2 no nginya ndĩmĩĩhumbe rĩngĩ?
\q1 Ningĩ nĩndĩthambĩte magũrũ:
\q2 no nginya ndĩmekĩre gĩko rĩngĩ?
\q1 
\v 4 Mwendwa wakwa araikirie guoko gwake kamwanya-inĩ ka mũrango,
\q2 nayo ngoro yakwa ĩrambĩrĩria kũmwĩrirĩria.
\q1 
\v 5 Ndĩrokĩra kũhingũrĩra mwendwa wakwa,
\q2 moko makwa magĩtaataga manemane,
\q1 nacio ciara ciakwa ikanyũrũrũkia manemane,
\q2 nyiitĩro-inĩ ya mũrango.
\q1 
\v 6 Ndĩrahingũrĩire mwendwa wakwa,
\q2 no mwendwa wakwa ndararĩ ho, nĩarathiĩte;
\q2 Nayo ngoro yakwa ĩroorwo nĩ hinya nĩ ũndũ wake gũthiĩ.
\q1 Ndĩramwethire, no ndinamuona.
\q2 Ndĩramwĩtire, no ndananjĩtĩka.
\q1 
\v 7 Arangĩri maranyona
\q2 magĩthiũrũrũka itũũra-inĩ rĩu inene.
\q1 Nao marahũũrire, marandihangia;
\q2 marandunya nguo yakwa ya igũrũ,
\q2 arangĩri acio a thingo!
\q1 
\v 8 Inyuĩ aarĩ aya a Jerusalemu, ndamwĩhĩtithia atĩrĩ:
\q2 mũngĩona mwendwa wakwa-rĩ,
\q1 mũkũmwĩra atĩa?
\q2 Mwĩrei atĩ ndĩ mũcuce nĩ wendo.
\sp Arata
\q1 
\v 9 Wee mũthaka gũkĩra andũ-a-nja arĩa angĩ othe-rĩ,
\q2 mwendwa waku aagĩrĩte agakĩra endwa arĩa angĩ na kĩ?
\q1 Mwendwa waku akĩrĩte endwa arĩa angĩ nakĩ,
\q2 nĩguo ũtwĩhĩtithie ũguo?
\sp Mwendwa
\q1 
\v 10 Mwendwa wakwa nĩ mũthaka na agatunĩha,
\q2 nĩekũũranĩte harĩ arũme ngiri ikũmi.
\q1 
\v 11 Mũtwe wake ũhaana ta thahabu theru mũno;
\q2 njuĩrĩ yake ĩrĩ na mĩkumba,
\q2 na ĩkaira ta ihuru.
\q1 
\v 12 Maitho make mahaana ta ma ndutura
\q2 ciũmbĩte tũrũũĩ-inĩ,
\q1 mahaana ta mathambĩtio na iria,
\q2 o ta maigĩtwo wega makaagĩrĩra ta mathaga.
\q1 
\v 13 Makai make namo mahaana ta tũmĩgũnda
\q2 tũtumanĩte mahuti manungi wega magĩtararĩka.
\q1 Mĩromo yake no ta itoka igũita manemane.
\q1 
\v 14 Moko make mahaana ta thanju cia thahabu,
\q2 itheecereirwo tũhiga-inĩ tũrĩa twĩtagwo thumarati;
\q1 mwĩrĩ wake ũhaana ta mũguongo ũrĩa mũnyorokie,
\q2 ũgemetio na yakuti ĩrĩa theru.
\q1 
\v 15 Magũrũ make matariĩ ta itugĩ cia mahiga ma mũthemba wa marimari,
\q2 ihaandĩrĩirwo itina-inĩ cia thahabu ĩrĩa therie.
\q1 Maũthĩ make matariĩ ta Lebanoni,
\q2 agathakara ta mĩtarakwa yakuo.
\q1 
\v 16 Kanua gake akĩaria karĩ mũrĩo mũno;
\q2 we nĩ wa kwendeka biũ.
\q1 Atĩrĩrĩ, ũyũ nĩwe mwendwa wakwa,
\q2 ũyũ nĩwe mũrata wakwa, inyuĩ aarĩ a Jerusalemu.
\c 6
\sp Arata
\q1 
\v 1 Wee mũthaka gũkĩra andũ-a-nja arĩa angĩ othe-rĩ,
\q2 mwendwa waku athiĩte kũ?
\q1 Mwendwa waku arorire na kũ,
\q2 nĩguo tũmũcarie nawe?
\sp Mwendwa
\q1 
\v 2 Mwendwa wakwa aikũrũkire mũgũnda-inĩ wake,
\q2 o tũmĩgũnda-inĩ tũrĩa tũtumanĩte mahuti marĩa manungi wega,
\q1 athiĩte kũrĩithia kũu mĩgũnda-inĩ,
\q2 agĩtuaga mahũa ma itoka.
\q1 
\v 3 Niĩ ndĩ wa mwendwa wakwa, nake nĩ wakwa;
\q2 we arĩithagia itoka-inĩ.
\sp Mwendani
\q1 
\v 4 Wee mwendwa wakwa, ũrĩ mũthaka, o ta bũrũri wa Tiriza,\f + \fr 6:4 \ft Itũũra rĩa Tiriza nĩrĩo Jeroboamu aathuurire rĩtuĩke itũũra inene rĩa Ũthamaki wa Gathigathini.\f*
\q2 ũrĩ wa kwendeka o ta Jerusalemu,
\q2 na ũkamakania o ta ita rĩrĩ na bendera.
\q1 
\v 5 Wĩhũgũre na kũngĩ, ũtige kũndora;
\q2 maitho maku nĩmarahoota.
\q1 Njuĩrĩ yaku no ta rũũru rwa mbũri
\q2 rũgĩikũrũka Kĩrĩma kĩa Gileadi.
\q1 
\v 6 Magego maku mahaana ta rũũru rwa ngʼondu
\q2 ikĩambata ciumĩte gũthambio.
\q1 O ĩmwe yacio ĩrĩ na ihatha rĩayo,
\q2 hatirĩ o na ĩmwe yacio ĩrĩ iiki.
\q1 
\v 7 Thĩa ciaku ihaana ta ciatũ igĩrĩ cia itunda rĩa mũkomamanga,
\q2 ikĩonerwo hau taama-inĩ ũcio ũkũhumbĩrĩte ũthiũ.
\q1 
\v 8 No gũkorwo na atumia athamaki mĩrongo ĩtandatũ,
\q2 na thuriya mĩrongo ĩnana,
\q2 na airĩtu gathirange matangĩtarĩka;
\q1 
\v 9 no ndutura yakwa, ũcio wakwa ũtarĩ ũcuuke-rĩ, gũtirĩ ũngĩ mahaanaine,
\q2 nowe mũirĩtu wa nyina wiki,
\q2 o we gĩtũnio kĩa ũcio mũmũciari.
\q1 Airĩtu maamuonire makĩmwĩta mũrathime;
\q2 nao atumia athamaki o na thuriya makĩmũkumia.
\sp Arata
\q1 
\v 10 Nũũ ũyũ ũroimĩra ta ruoro rũgĩtema,
\q2 athakarĩte ta mweri, na agathera ta riũa,
\q2 arĩ na ũkengu ta wa njata irũrũnganĩte?
\sp Mwendani
\q1 
\v 11 Nĩndĩraikũrũkire mũgũnda wa mĩkombokombo,
\q2 ngarore tũmĩtĩ tũrĩa tũmerete kũu gĩtuamba-inĩ,
\q1 nĩguo nyone kana mĩthabibũ nĩĩthundũrĩte,
\q2 o na kana mĩkomamanga nĩĩrutĩte kĩro.
\q1 
\v 12 O na itanamenya ũrĩa gũtariĩ-rĩ,
\q2 merirĩria ma ngoro yakwa marandwara
\q2 gatagatĩ-inĩ ka ngaari cia mũthamaki cia ita cia andũ aitũ.
\sp Arata
\q1 
\v 13 Cooka, cooka, wee Mũshulamu;
\q2 cooka, cooka, nĩgeetha tũkwĩrorere!
\sp Mwendani
\q1 Mũkwenda kwĩrorera Mũshulamu ũyũ nĩkĩ,
\q2 taarĩ rwĩmbo rwa Mahanaimu mũreerorera?
\b
\c 7
\q1 
\v 1 We mwarĩ ũyũ wa mũnene,
\q2 ĩ magũrũ maku mekĩrĩtwo iraatũ ti mathaka!
\q1 Magũrũ maku mathakarĩte makahaana ta mathaga,
\q2 marĩa mathondeketwo nĩ moko ma mũbundi mũũgĩ.
\q1 
\v 2 Mũkonyo waku nĩ ta kaihũri ga gĩthiũrũrĩ
\q2 karĩa gataagaga ndibei ningie.
\q1 Njohero yaku ĩhaana ta kĩhumbu kĩa ngano ngonyore,
\q2 gĩthiũrũrũkĩirio nĩ itoka.
\q1 
\v 3 Nyondo ciaku ihaana ciana igĩrĩ cia thiiya,
\q2 ikahaana mahatha ma thiiya.
\q1 
\v 4 Ngingo yaku ĩhaana ta mũthiringo mũraihu wakĩtwo na mĩguongo.
\q1 Maitho maku nĩ ta tũria twa Heshiboni,
\q2 hakuhĩ na kĩhingo kĩa Bathi-Rabimu.
\q1 Iniũrũ rĩaku rĩhaana ta mũthiringo mũraihu wa Lebanoni
\q2 ũrĩa ũrorete na mwena wa Dameski.
\q1 
\v 5 Mũtwe waku ũkũhumbaga tanji ta Kĩrĩma gĩa Karimeli.
\q2 Nacio njuĩrĩ ciaku ciirĩte ikahaana ta rangi wa ndathi;
\q2 mũthamaki aikaraga ta oohereirwo tũmĩcuha-inĩ twacio.
\q1 
\v 6 Wee wendo, kaĩ wee ũrĩ mũthaka na wa gũkenania-ĩ!
\q2 Maũndũ maku nĩmagũkenania!
\q1 
\v 7 Kĩrũgamo gĩaku kĩrũngarĩte ta mũtĩ wa mũkĩndũ,
\q2 nacio nyondo ciaku ihaana ta imanjĩka cia matunda.
\q1 
\v 8 Ndoigire atĩrĩ, “Nĩngũhaica mũtĩ ũyũ wa mũkĩndũ;
\q2 nĩngũtua matunda maguo.”
\q1 Nyondo ciaku irotuĩka ta imanjĩka cia thabibũ,
\q2 nayo mĩhũmũ yaku ĩtararĩke wega ta matunda,
\q2 
\v 9 nako kanua gaku gatuĩke ta ndibei ĩrĩa njega mũno.
\sp Mwendwa
\q1 Ndibei ĩyo ĩrokinyĩra mwendwa wakwa,
\q2 na ĩmerũke wega ĩrĩ gatagatĩ ka mĩromo na magego.
\q1 
\v 10 Niĩ ndĩ wa mwendwa wakwa,
\q2 nake nĩ niĩ eriragĩria.
\q1 
\v 11 Mwendwa wakwa, ũka, nĩtũthiĩ mĩgũnda-inĩ,
\q2 nĩtũthiĩ tũkaraarĩrĩre tũtũũra-inĩ.
\q1 
\v 12 Nĩtũrooke gũthiĩ tene mĩgũnda-inĩ ya mĩthabibũ
\q2 tũkarore kana mĩthabibũ nĩmĩthundũku,
\q1 na kana nĩĩcanũrĩte kĩro kĩayo,
\q2 o na kana mĩkomamanga nĩĩrutĩte kĩro:
\q2 kũu nĩkuo ngaakũheera wendo wakwa.
\q1 
\v 13 Matunda ma mandarĩki nĩmaratararĩka,
\q2 na mũrango-inĩ gwitũ kũrĩ na matunda ma mĩthemba yothe marĩa mega mũno,
\q1 ma mũgethano o na mangĩ maikaru,
\q2 marĩa ngũigĩire, wee mwendwa wakwa.
\b
\c 8
\q1 
\v 1 Naarĩ korwo no ũtuĩke ta mũrũ wa maitũ,
\q2 ũrĩa wongire nyondo cia maitũ!
\q1 Hĩndĩ ĩyo, ingĩgũtũnga nja,
\q2 ndaakũmumunya,
\q2 na gũtirĩ mũndũ o na ũrĩkũ ũngĩĩmena.
\q1 
\v 2 Ingĩgũtongoria,
\q2 ngũtware nyũmba ya maitũ,
\q2 ũcio wandutire maũndũ.
\q1 Ingĩkũhe ndibei ĩrĩa njamithie wega ũnyue,
\q2 o yo ngogoyo ya mĩkomamanga yakwa.
\q1 
\v 3 Guoko gwake kwa ũmotho akũigĩte rungu rwa mũtwe wakwa,
\q2 nakuo guoko gwake kwa ũrĩo gũkaahĩmbĩria.
\q1 
\v 4 Inyuĩ aarĩ a Jerusalemu, ndamwĩhĩtithia atĩrĩ:
\q2 Mũtikoimbuthũre wendo o na kana mũwarahũre,
\q2 o nginya wĩrirĩrie kwarahũka guo mwene.
\sp Arata
\q1 
\v 5 Nũũ ũyũ ũroka ambatĩte oimĩte werũ-inĩ,
\q2 etiiranĩtie na mwendwa wake?
\sp Mwendwa
\q1 Rungu-inĩ rwa mũtĩ wa matunda nĩho ndakwarahũrire ũrĩ toro;
\q2 hau nĩho nyũkwa aagĩĩrĩire nda yaku,
\q2 o hau nĩho ũcio warĩ na ruo rwa kũrũmwo aagũciarĩire.
\q1 
\v 6 Njĩkĩra ta mũhũũri ngoro-inĩ yaku,
\q2 ũũhũũre ta mũhũũri guoko-inĩ gwaku;
\q1 amu wendo ũrĩ hinya o ta gĩkuũ,
\q2 ũiru waguo ũmĩtie ngoro o ta mbĩrĩra.
\q1 Ũcinaga o ta mwaki ũrakana,
\q2 na o ta rũrĩrĩmbĩ rũnene mũno rwa Jehova.
\q1 
\v 7 Maaĩ maingĩ matingĩhota kũhoria wendo;
\q2 njũũĩ itingĩhota kũũthereria.
\q1 Korwo mũndũ no aheane
\q2 ũtonga wothe wa nyũmba yake nĩ ũndũ wa wendo-rĩ,
\q2 no kũnyũrũrio ũngĩnyũrũrio o biũ.
\sp Arata
\q1 
\v 8 Nĩtũrĩ na kairĩtu ka maitũ,
\q2 nako gatiumĩtie nyondo.
\q1 Tũgeka atĩa nĩ ũndũ wa kairĩtu kau gaitũ,
\q2 mũthenya ũrĩa gagaatuĩka ga kũũrio?
\q1 
\v 9 Korwo nĩ rũthingo-rĩ,
\q2 tũngĩaka mĩthiringo mĩraihu na igũrũ ya betha igũrũ rĩako.
\q1 Korwo nĩ mũrango-rĩ,
\q2 tũngĩkahingĩrĩria na mbaũ cia mũtarakwa.
\sp Mwendwa
\q1 
\v 10 Niĩ ndĩ rũthingo,
\q2 nacio nyondo ciakwa ihaana ta mĩthiringo mĩraihu na igũrũ.
\q1 Nĩ ũndũ ũcio maitho-inĩ make-rĩ,
\q2 nduĩkĩte o ta mũndũ ũtũmaga aiganĩre.
\q1 
\v 11 Solomoni aarĩ na mũgũnda wa mĩthabibũ kũu Baali-Hamoni;
\q2 mũgũnda ũcio wa mĩthabibũ akĩũkomborithia kũrĩ akombori.
\q1 O mũndũ aarĩ arehage cekeri 1,000\f + \fr 8:11 \ft nĩ ta kilo ikũmi na ĩmwe na nuthu (11.5)\f* cia betha
\q2 nĩ ũndũ wa maciaro maguo.
\q1 
\v 12 No mũgũnda wakwa wa mĩthabibũ nĩ wakwa o niĩ nyiki;
\q2 cekeri icio 1,000 nĩ ciaku wee Solomoni;
\q2 nacio cekeri 200\f + \fr 8:12 \ft nĩ ta kilo igĩrĩ na robo (2.25)\f* nĩ cia arĩa marĩmagĩra maciaro maguo.
\sp Mwendani
\q1 
\v 13 Atĩrĩrĩ, wee ũikaraga mĩgũnda-inĩ
\q2 hamwe na arata a thiritũ yaku,
\q2 reke o na niĩ njigue mũgambo waku.
\sp Mwendwa
\q1 
\v 14 Umagara na ihenya mwendwa wakwa,
\q2 ũtuĩke ta thiiya,
\q1 kana ta thwariga nyanake
\q2 ĩrĩ irĩma-inĩ iria ĩrĩ mahuti manungi wega.
