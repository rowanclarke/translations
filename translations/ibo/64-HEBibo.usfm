\id HEB - Biblica® Open Igbo Contemporary Bible 2020 
\h Ndị Hibru 
\toc1 Ndị Hibru 
\toc2 Ndị Hibru 
\toc3 Hib 
\mt1 Ndị Hibru 
\c 1  
\s1 Okwu Chineke site nʼỌkpara ya 
\p  
\v 1 Na mgbe ochie, Chineke gwara nna nna anyị ha okwu nʼoge dị iche iche site nʼọnụ ndị amụma, na site nʼụzọ ndị ọzọ dị iche iche.  
\v 2 Ma nʼoge ikpeazụ ndị a, ọ gwala anyị okwu site nʼọnụ Ọkpara ya, onye o nyefere ihe niile nʼaka. Ọ bụ site nʼaka ya ka o siri kee ụwa niile na ihe dị nʼime ya.  
\v 3 Ọ na-enwupụta ebube ya na-anọchitekwa anya ụdịdị ya, ebe o ji okwu ya dị ike na-ejikọta ihe niile. Mgbe ọ sachapụrụ ma hichapụkwa mmehie niile, ọ nọdụrụ nʼaka nri nke Onye dị ukwuu, dị elu nʼeluigwe.  
\v 4 Ya mere, ọ bụrụla onye dị ukwu karịa ndị mmụọ ozi dị ka aha e nyere ya si dị elu karịa nke ha. 
\s1 Ịdị ukwuu nke Ọkpara Chineke 
\p  
\v 5 Onye nʼetiti ndị mmụọ ozi ka ọ gwarala sị, 
\q1 “Ị bụ Ọkpara m. 
\q2 Taa abụrụla m Nna gị”\f + \fr 1:5 \ft \xt Abụ 2:7\f*? 
\m Maọbụ ọzọkwa, 
\q1 “Aga m abụrụ ya Nna, 
\q2 ya onwe ya ga-abụkwara m Nwa”\f + \fr 1:5 \ft \xt 2Sa 7:14; 1Ih 17:13\f*? 
\m  
\v 6 Ọzọkwa, mgbe o mere ka nwa mbụ ya bịa nʼụwa, o nyere iwu sị, 
\q1 “Ka ndị mmụọ ozi Chineke niile fee ya ofufe.”\f + \fr 1:6 \ft \xt Dit 32:43\f* 
\m  
\v 7 O kwukwara banyere ndị mmụọ ozi ya, ọ sịrị, 
\q1 “Ọ na-eme ndị mmụọ ozi ya ka ha bụrụ ikuku, 
\q2 na-emekwa ndị na-ejere ya ozi ka ha bụrụ ire ọkụ.”\f + \fr 1:7 \ft \xt Abụ 104:4\f* 
\m  
\v 8 Ma banyere Ọkpara ahụ, ọ sịrị, 
\q1 “Ocheeze gị, O Chineke, ga-adịgide ruo mgbe ebighị ebi. 
\q2 Mkpara omume ziri ezi ka mkpara alaeze gị ga-abụ. 
\q1  
\v 9 Ị hụrụ ezi omume nʼanya ma kpọọ ihe ọjọọ asị. 
\q2 Nʼihi nke a, Chineke, nke bụ Chineke gị, emeela ka ịdị elu karịa ndị ibe gị niile 
\q2 site na ite gị mmanụ nke ọṅụ.”\f + \fr 1:9 \ft \xt Abụ 45:6,7\f* 
\m  
\v 10 Ọ sịkwara, 
\q1 “Na mmalite, Onyenwe anyị, ọ bụ gị tọrọ ntọala ụwa, 
\q2 eluigwe bụkwa ọrụ aka gị. 
\q1  
\v 11 Ha ga-ala nʼiyi, ma gị onwe gị ga-anọgide. 
\q2 Ha niile ga-aka nka dịka uwe. 
\q1  
\v 12 Ị ga-apịakọta ha, 
\q2 gbanwee ha dị ka akwa. 
\q1 Ma gị onwe gị enweghị mgbanwe. 
\q2 Ọnụọgụgụ afọ gị agaghị enwe ọgwụgwụ ruo mgbe ebighị ebi.”\f + \fr 1:12 \ft \xt Abụ 102:25-27\f* 
\m  
\v 13 O nweela mmụọ ozi ọbụla ọ sịrị, 
\q1 “Nọdụ ala nʼaka nri m 
\q2 ruo mgbe m ga-eme ndị iro gị 
\q2 ihe mgbakwasị ụkwụ nye ụkwụ gị”\f + \fr 1:13 \ft \xt Abụ 110:1\f*? 
\m  
\v 14 Ndị mmụọ ozi niile, ha abụghị mmụọ ndị na-ejere Chineke ozi, ndị a na-ezipụ ka ha jee ozi nʼihi ndị ahụ ga-eketa nzọpụta? 
\c 2  
\s1 Ịdọ aka na ntị banyere ige ntị 
\p  
\v 1 Ya mere, anyị aghaghị ilezi anya nke ọma banyere ihe anyị nụrụla, ka anyị hapụ isi na ha wezuga onwe anyị.  
\v 2 Nʼihi na ọ bụrụ na ozi ahụ e ziri site na ndị mmụọ ozi dị ire, ọ bụrụkwa na njehie maọbụ nnupu isi ọbụla natara ahụhụ kwesiri ya.  
\v 3 Anyị ga-esi aṅaa gbanarị ntaramahụhụ ma ọ bụrụ na anyị eleghara oke nzọpụta ahụ anya? Ọ bụ Onyenwe anyị kwupụtara ya, bụkwa nke ndị nụrụ ya gbaara anyị ama banyere ya.  
\v 4 Chineke nʼonwe ya tụkwasịrị ịgba ama nke ya, site nʼịrụ ọrụ ebube na ọrụ ịrịbama, na ọrụ ịtụnanya dị iche iche, nakwa ikesa ọtụtụ onyinye nke Mmụọ Nsọ, dị ka ọchịchọ ya siri dị. 
\s1 E mere ka Jisọs dịrị ka ụmụnna ya 
\p  
\v 5 Ọ dịghị mgbe Chineke nyere ndị mmụọ ozi ike ịchị elu ụwa a. Anyị na-ekwu banyere ụwa gaje ịbịa abịa.  
\v 6 Otu onye agbaala akaebe nʼebe ọzọ, 
\q1 “Gịnị ka mmadụ bụ i ji na-eche banyere ha? 
\q2 Gịnị ka nwa nke mmadụ bụ iji na-elekọta ya? 
\q1  
\v 7 Nʼihi na i mere ka ha dị ala nwantakịrị nʼebe ndị mmụọ ozi nọ; 
\q2 i jikwa ebube na nsọpụrụ kpube ya nʼisi dịka okpueze, 
\q2  
\v 8 dokwaa ihe niile nʼokpuru ụkwụ ya.”\f + \fr 2:8 \ft \xt Abụ 8:4-6\f* 
\m Mgbe o mere ka ihe niile dịrị nʼokpuru ya, o nwekwaghị ihe ọbụla ọ hapụrụ itinye nʼokpuru ya. Ma otu ọ dị, anyị ahụbeghị ka e doro ihe niile nʼokpuru ya.  
\v 9 Ma anyị na-ahụ Jisọs bụ onye e mere ka ọ dị ala nwantakịrị oge karịa ndị mmụọ ozi, ma ugbu a ejirila ebube na nsọpụrụ kpukwasị ya nʼisi, nʼihi ahụhụ ọnwụ nke ọ hụrụ, ka o site nʼamara Chineke detụ ọnwụ ire nʼihi mmadụ niile. 
\p  
\v 10 Ebe e sitere na ya kpọbata ọtụtụ ụmụ nʼebube, o ziri ezi ka Chineke, onye ihe niile dịrị na onye kere ihe niile, mee ka onyeisi nzọpụta ha bụrụ onye zuruoke site nʼahụhụ ọ hụrụ.  
\v 11 Onye ahụ na-eme mmadụ ka ọ dị nsọ, na ndị ahụ e mere ka ha dị nsọ si nʼotu ezinaụlọ. Nʼihi ya, ihere adịghị eme ya ịkpọ ha ụmụnna ya.  
\v 12 Ọ sịrị, 
\q1 “Aga m ekwupụta aha gị nye ụmụnna m, 
\q2 nʼetiti nzukọ ka m ga-anọ bụọrọ gị abụ otuto.”\f + \fr 2:12 \ft \xt Abụ 22:22\f* 
\m  
\v 13 Ọzọkwa, 
\q1 “Aga m atụkwasị obi m na ya.”\f + \fr 2:13 \ft \xt Aịz 8:17\f* 
\m Ọzọkwa, ọ sịrị, 
\q1 “Lee mụ onwe m, na ụmụ ndị Chineke nyere m.”\f + \fr 2:13 \ft \xt Aịz 8:18\f* 
\p  
\v 14 Ebe ọ bụ na ụmụ ndị ahụ ketara oke na anụ ahụ na ọbara, ya onwe ya sooro ha keta oke nʼụdịdị ahụ, ka o site nʼọnwụ ya laa onye ahụ nwere ike ọnwụ nʼiyi, onye ahụ bụ ekwensu.  
\v 15 Ma tọpụ ndị ahụ niile egwu nke ọnwụ mere ka ha bụrụ ohu na ndụ ha niile.  
\v 16 Nʼihi na nʼezie, ọ bụghị ndị mmụọ ozi ka ọ na-enyere aka kama ọ bụ ụmụ ụmụ Ebraham.  
\v 17 Nʼihi nke a, e mere ka o yie ụmụnna ya nʼihe niile, ka o nwe ike ghọọ onyeisi nchụaja kwesiri ntụkwasị obi ma na nke nwere obi ebere nʼijere Chineke ozi, ka o nweekwa ike chụọ aja ikpuchi mmehie mmadụ niile.  
\v 18 Ebe ọ bụ na ya onwe ya tara ahụhụ mgbe a na-anwa ya ọnwụnwa, o nwekwara ike inyere ndị a na-anwa ọnwụnwa aka. 
\c 3  
\s1 Jisọs dị ukwuu karịa Mosis 
\p  
\v 1 Ya mere, ụmụnna m dị nsọ, ndị so keta oke nʼọkpụkpọ eluigwe ahụ, ka echiche unu dịgide naanị na Jisọs. Onyeisi ozi na onyeisi nchụaja nke okwukwe anyị.  
\v 2 O kwesiri ntụkwasị obi nye onye ahụ họpụtara ya dịka Mosis si bụrụ onye kwesiri ntụkwasị obi nʼije ozi ya nʼụlọ Chineke.  
\v 3 Ma Jisọs nwere ugwu na nsọpụrụ karịa Mosis, dịka onye na-ewu ụlọ si enwe ugwu na nsọpụrụ karịa ụlọ o wuru.  
\v 4 Nʼihi na ụlọ ọbụla nwere onye wuru ya, maọbụ Chineke na-ewu ihe niile.  
\v 5 Mosis kwesiri ntụkwasị obi dịka odibo nʼụlọ Chineke nʼihe niile,\f + \fr 3:5 \ft \xt Ọnụ 12:7\f* sịkwa otu a gbaa ama banyere ihe ndị a ga-ekwu nʼọdịnihu.  
\v 6 Ma otu ọ dị, Kraịst kwesiri ntụkwasị obi dịka ọkpara nke na-elekọta ụlọ ya. Anyị gabụkwanụ ụlọ ya ma ọ bụrụ na anyị ejidesie okwukwe anyị ike ya na olileanya nke anyị ji anya isi. 
\s1 Ịdọ aka na ntị banyere ekweghị ekwe 
\p  
\v 7 Ya mere, dị ka Mmụọ Nsọ na-asị, 
\q1 “Ọ bụrụ na unu anụ olu ya taa, 
\q2  
\v 8 unu emela ka obi unu sie ike, 
\q1 dị ka unu mere nʼoge nnupu isi 
\q2 mgbe oge ọnwụnwa nʼime ọzara, 
\q1  
\v 9 ebe nna nna unu ha nọrọ nwa m ọnwụnwa. 
\q2 Ọ bụ ezie na ha hụrụ akaọrụ m iri afọ anọ ndị a. 
\q1  
\v 10 Nʼihi nke a, ewere m iwe megide ọgbọ ahụ. 
\q2 Asịrị m, ‘Obi ha na-akpafu akpafu mgbe niile. 
\q2 Ha amatabeghị ụzọ m niile.’ 
\q1  
\v 11 Ya mere, aṅụrụ m iyi nʼiwe m, sị, 
\q2 ‘Ha agaghị abanye nʼizuike m ma ọlị.’ ”\f + \fr 3:11 \ft \xt Abụ 95:7-11\f* 
\p  
\v 12 Lezienụ anya, ụmụnna m, ka ajọ omume niile na ekweghị ekwe niile nke obi ghara ịdị nʼime onye ọbụla nʼetiti unu, nke ga-eme ka unu site nʼiso Chineke dị ndụ tụgharịa.  
\v 13 Kama, na-agbanụ onwe unu ume kwa ụbọchị niile dịka a kpọrọ ụbọchị ahụ Taa. Ka a hapụ inwekwa onye ọbụla a ga-esite nʼaghụghọ nke mmehie mee ka obi ya sie ike.  
\v 14 Anyị bụ ndị anyị na Kraịst ga-eso kekọrịta oke ma ọ bụrụ na anyị ga-ejidesi ya ike bụ ntụkwasị obi ahụ anyị nwere site na mmalite ruo ọgwụgwụ.  
\v 15 Dị ka e kwuru ya, 
\q1 “Taa, ọ bụrụ na unu anụ olu ya. 
\q2 Unu emela ka obi unu sie ike, 
\q2 dịka unu mere nʼoge nnupu isi.”\f + \fr 3:15 \ft \xt Abụ 95:7,8\f* 
\p  
\v 16 Olee ndị bụ ndị ahụ nụrụ ma nupu isi? Ọ bụ na ọ bụghị ndị niile ahụ Mosis dupụtara site nʼala Ijipt?  
\v 17 Ọ bụkwa olee ndị ka o wesoro iwe iri afọ anọ? Ọ bụ na ọ bụghị ndị ahụ mehiere. Ndị ahụ ahụ ha dara nʼọzara?  
\v 18 Olee ndị ahụ ọ ṅụụrụ iyi na ha agaghị aba nʼizuike ya? Ọ bụ na ha abụghị ndị ahụ nupuuru ya isi?  
\v 19 Ugbu a, anyị maara na ha enweghị ike ịbanye, nʼihi na ha bụ ndị na-ekweghị ekwe. 
\c 4  
\s1 Ụbọchị izuike nye ndị nke Chineke 
\p  
\v 1 Ya mere, ebe ọ bụ na nkwa nke ịba nʼizuike ya ka ghere oghe, ka anyị kpachapụ anya hụ na o nweghị onye ọbụla a ga-ahụta dịka onye etozughị ya.  
\v 2 Nʼihi na-eziela anyị oziọma ahụ, dị ka ezikwara ha: ma oziọma ahụ ha nụrụ abaraghị ha uru nʼihi na ha ejighị okwukwe nara ya.  
\v 3 Ma anyị bụ ndị kweere na-abanye nʼebe izuike ahụ, dị ka Chineke si kwuo, 
\q1 “Aṅụrụ m iyi nʼiwe m, 
\q2 ‘Ha agaghị abanye nʼizuike m ma ọlị.’ ”\f + \fr 4:3 \ft \xt Abụ 95:11\f* 
\m O kwuru nke a nʼagbanyeghị na ọ rụchaala ọrụ ya site na ntọala ụwa.  
\v 4 Nʼihi nʼotu ebe, o nweela ihe o kwuru banyere ụbọchị nke asaa site nʼokwu ndị a: “Chineke zuru ike site nʼọrụ ya niile, nʼụbọchị nke asaa.”\f + \fr 4:4 \ft \xt Jen 2:2\f* 
\v 5 Ma nʼebe a kwa, e kwuru, “Ha agaghị abanye nʼebe izuike m ma ọlị.”\f + \fr 4:5 \ft \xt Abụ 95:11\f* 
\p  
\v 6 Ebe ọ bụ na ohere dịịrị ụfọdụ mmadụ ịbanye nʼime ya, ma ndị ahụ buru ụzọ nata oziọma ahụ abanyeghị nʼihi nnupu isi.  
\v 7 O wepụtara ụbọchị ọzọ nke ọ kpọrọ Taa, o sitere nʼọnụ Devid kwuo okwu ahụ e kwurula ihe banyere nʼoge gara aga sị, 
\q1 “Taa, ọ bụrụ na unu anụ olu ya, 
\q2 unu emela ka obi unu sie ike.”\f + \fr 4:7 \ft \xt Abụ 95:7,8\f* 
\m  
\v 8 Nʼihi na a sị na Joshua nyere ha ezumike, ọ gaghị ekwu banyere ụbọchị ọzọ.  
\v 9 Otu ụbọchị izuike fọdụrụ nye ndị nke Chineke.  
\v 10 Nʼihi na onye ọbụla banyere nʼezumike ya esitela nʼọrụ nke ya onwe ya nwee izuike dị ka Chineke siri banye nʼizuike nke ya.  
\v 11 Ya mere, ka anyị mee ka ike anyị ha, ka anyị banye nʼebe izuike ahụ, ka ọ hapụ ịdịkwa onye ọbụla nke na-agaghị aba nʼihi ịṅomi ekweghị ekwe ha. 
\p  
\v 12 Nʼihi na okwu Chineke dị ndụ dịkwa nkọ. Ọ dị nkọ karịa mma ihu abụọ ọbụla. Ọ na-adụba ruo na-ikewa mkpụrụobi na mmụọ, ma rukwaa na ebe nkwonkwo na ụmị kewakwara onwe ha. Ọ na-enyocha ọchịchọ na echiche obi ndị mmadụ.  
\v 13 Ọ dịghị ihe ọbụla nʼime ihe niile e kere eke pụrụ izo onwe ya site nʼebe Chineke nọ. Ihe niile ghere oghe, ma gbarakwa ọtọ nʼihu anya ya. Ọ bụ nʼihu ya ka anyị niile ga-aza ajụjụ banyere ndụ anyị niile. 
\s1 Jisọs onyeisi nchụaja anyị 
\p  
\v 14 Ebe ọ bụ na anyị nwere onyeisi nchụaja dị ukwuu, onye nke gaferela nʼeluigwe, Jisọs Ọkpara Chineke, ka anyị jidesienụ okwukwe anyị ike.  
\v 15 Nʼihi na anyị nwere onyeisi nchụaja nke nwere ike ịghọta adịghị ike anyị. A nwara ya ọnwụnwa nʼụzọ niile dị ka a na-anwa anyị taa. Ma, o meghị mmehie nʼụzọ ọbụla mgbe a nwara ya.  
\v 16 Ya mere, ka anyị bịaruo ocheeze amara ahụ nso na-atụghị egwu, ka anyị si otu a nata ebere, ma chọtakwa amara nke ga-enyere anyị aka nʼoge mkpa. 
\c 5  
\p  
\v 1 A na-esite nʼetiti ndị mmadụ họrọ onyeisi nchụaja ọbụla, ka ọ nnọchite anya ndị mmadụ nʼihe banyere ife Chineke, ka ọ na-eche onyinye na-achụkwa aja maka mmehie dị iche iche.  
\v 2 Ebe ọ bụ na ya onwe ya bụ onye na-adịghị ike, ọ pụrụ iji nwayọọ na-emeso ndị na-amaghị ihe na ndị na-ejehie ụzọ omume.  
\v 3 Nʼihi nke a, ọ ghaghị ịchụ aja maka mmehie nke onwe ya na nke ndị mmadụ.  
\v 4 O nweghị onye na-ewere ugwu a nʼonwe ya, kama ọ bụ Chineke na-akpọ dịka o si kpọọ Erọn. 
\p  
\v 5 Nʼotu aka ahụ kwa, Kraịst enyeghị onwe ya ebube nke ịbụ onyeisi nchụaja, kama Chineke sịrị ya, 
\q1 “Ị bụ Ọkpara m. 
\q2 Taa abụrụla m Nna gị.”\f + \fr 5:5 \ft \xt Abụ 2:7\f* 
\m  
\v 6 Nʼebe ọzọ, o kwuru, 
\q1 “Dị ka usoro Melkizedek si dị, 
\q2 ị bụ onye nchụaja ruo mgbe ebighị ebi.”\f + \fr 5:6 \ft \xt Abụ 110:4\f* 
\p  
\v 7 Mgbe ọ ka dị ndụ nʼanụ ahụ, o ji oke olu na anya mmiri kpee ekpere rịọkwa arịrịọ nye onye ahụ pụrụ ịzọpụta ya site nʼọnwụ. A nụkwara olu ya nʼihi ndụ nrube isi na mweda nʼala ya.  
\v 8 Ọ bụ ezie na ọ bụ Ọkpara ma ọ mụtara irube isi site nʼahụhụ ọ tara.  
\v 9 Ma mgbe e mere ka o zuo oke, ọ ghọrọ isi nke nzọpụta ebighị ebi nye ndị niile na-erubere ya isi.  
\v 10 Ebe Chineke mere ya onyeisi nchụaja nʼusoro Melkizedek. 
\s1 Ịdọ aka na ntị banyere ịdapụ nʼokwukwe 
\p  
\v 11 Ọ dị ọtụtụ ihe ọzọ anyị nwere ikwu banyere ya, ma o siri ike ịkọwa ya nʼihi na unu adịghị amụta ihe ọsịịsọ.  
\v 12 Nʼezie, ugbu a, unu kwesiri ịbụ ndị ozizi nye ndị ọzọ, ma unu ka nọ na-achọ onye ga-ezikwa unu ụkpụrụ mbụ nke okwu Chineke. Unu na-achọ mmiri ara kama nri siri ike.  
\v 13 Onye ọbụla nke na-aṅụ ara, ka bụ nwantakịrị, ọ matabeghị ozizi banyere ezi omume.  
\v 14 Nri dị ike dịrị ndị tozuru oke, ndị siterela nʼihe ha na-eme zụọ onwe ha ịchọpụta ihe dị iche nʼetiti ezi ihe na ajọ ihe. 
\c 6  
\p  
\v 1 Ya bụ ka anyị na-aga nʼihu nʼihe mmụta zuru ezu, ka anyị gharakwa ịnọgide nʼihe mmụta mbụ ahụ nke anyị nwere banyere Kraịst. Anyị agaghị alaghachi azụ ịtọ ntọala nchegharị ọzọ site nʼọrụ ndị nwụrụ anwụ nʼokwukwe nʼebe Chineke nọ,  
\v 2 na-akụzi banyere ime baptizim na ibikwasị aka nʼisi na onyinye nke Mmụọ Nsọ, na mbilite nʼọnwụ na ikpe ebighị ebi.  
\v 3 Anyị ga-eme nke a ma Chineke kwe. 
\p  
\v 4 Ma ọ dịghị mfe ịkpọghachi ndị dara ada ọzọ, bụ ndị natarala ihe ahụ na mbụ, ndị detụkwara onyinye amara dị iche iche nke si nʼeluigwe bịa ire, ndị ketakwara oke Mmụọ Nsọ,  
\v 5 ndị detụkwara ịdị mma nke okwu Chineke ahụ ire na ike nke ụwa na-abịa,  
\v 6 ma mesịa dahie nʼonwe ha, ọ bụ ihe siri ike ịkpọghachite ha ruo nchegharị. Ha na akpọgidekwa Ọkpara Chineke nʼobe ọzọ, na emenyekwa ya ihere nʼihu ọha mmadụ.  
\v 7 Nʼihi na ala ahụ nke na-amị mmiri na-ezokwasị nʼelu ya mgbe niile, na-amịpụta mkpụrụ bara ụba nye ndị e ji maka ha kọọ ya, na-enweta ngọzị nʼaka Chineke.  
\v 8 Ma ọ bụrụ na o puo naanị ogwu na ahịhịa, ọ baghị uru ọbụla. Kama, ọ ga-abụ ihe a bụrụ ọnụ, nke ọgwụgwụ ya ga-abụ ịkpọ ya ọkụ. 
\p  
\v 9 Ma ọ bụ ezie na anyị na-ekwu otu a, ezi ndị enyi m, anyị nwere ntụkwasị obi maka ihe dị ezi mma banyere unu, bụ ihe ndị ha na nzọpụta so bịa.  
\v 10 Chineke abụghị onye na-ekpe ikpe nʼezighị ezi. Ọ gaghị echefu ọrụ niile unu rụrụ ya. Ọ gaghị echefu ịhụnanya niile unu gosiri nʼihi ya site nʼịgara ndị nsọ ozi, dịka unu na-aga nʼihu na-emekwa.  
\v 11 Anyị chọrọ ka onye ọbụla nʼime unu nọgidesie ike nʼotu ịnụ ọkụ nʼobi ahụ ruo ọgwụgwụ ihe niile, ka unu nwee olileanya inwezu ihe niile unu na-atụ anya ya mgbe oge ruru.  
\v 12 Anyị achọghị ka unu bụrụ ndị umengwụ, kama ka unu bụrụ ndị na-eṅomi ndụ ahụ jiri okwukwe na ntachiobi nweta ihe ahụ e kwere na nkwa. 
\s1 Chineke adịghị agbanwe uche ya 
\p  
\v 13 Mgbe Chineke kwere Ebraham nkwa, o ji onwe ya ṅụọ iyi, nʼihi na ọ dịghị onye ọzọ dị ukwuu karịa ya,  
\v 14 na-asị, “Nʼezie aga m agọzi gị, nyekwa gị ọtụtụ ụmụ ụmụ.”\f + \fr 6:14 \ft \xt Jen 22:17\f* 
\v 15 Ebraham nwere ndidi, natakwa ihe e kwere ya na nkwa. 
\p  
\v 16 Ụmụ mmadụ na-eji ndị ka ha ukwuu ṅụọ iyi, iyi aṅụrụ nʼụzọ dị otu a na-eme ka ihe e kwuru guzosie ike ma wezugakwa ịrụ ụka niile nʼetiti mmadụ.  
\v 17 Ya mere, mgbe Chineke chọrọ igosi ndị ahụ ga-eketa nkwa ahụ, ụdịdị izuzu ya, o jiri ịṅụ iyi mee ka o doo ha anya na izuzu ya adịghị agbanwe agbanwe.  
\v 18 Ka ọ ga-abụ site nʼihe abụọ na-enweghị mgbanwe, nke na-agaghị ekwe omume izi Chineke dịka onye ụgha, anyị bụ ndị gbara ọsọ ndụ ga-enweta agbamume siri ike iji jide olileanya e dobeere anyị.  
\v 19 Anyị nwere olileanya a dị ka arịlịka nke mkpụrụobi nke guzosiri ike ma bụrụkwa nke e chekwara. Ọ na-abanye nʼime ime ebe nchụaja ahụ nʼazụ akwa mgbochi  
\v 20 ebe Jisọs onye buru anyị ụzọ, abanyela nʼihi anyị; ọ ghọlara anyị onyeisi nchụaja ruo mgbe ebighị ebi dị ka usoro Melkizedek si dị. 
\c 7  
\s1 Melkizedek onye nchụaja 
\p  
\v 1 Melkizedek a bụ eze Salem, bụrụkwa onye nchụaja Chineke Onye kachasị ihe niile elu. Ọ zutere Ebraham mgbe o si na mmeri o meriri ọtụtụ ndị eze ahụ na-alọghachi, gọziekwa ya.  
\v 2 Ebraham nyekwara ya otu ụzọ nʼime ụzọ iri nke ihe niile. Ihe mbụ aha ya pụtara bụ, “eze ezi omume,” ọzọkwa bụ “eze nke Salem,” nke pụtara, “eze udo.”  
\v 3 O nweghị nna, o nwekwaghị nne, nke ọ na-enwe agbụrụ. O nweghị mmalite nke ụbọchị a mụrụ ya, maọbụ ọgwụgwụ ndụ, e mere ya dị ka Ọkpara Chineke. Ọ na-anọgide bụrụ onye nchụaja ruo mgbe ebighị ebi. 
\p  
\v 4 Leenụ otu o siri bụrụ onye dị ukwuu, ọ bụladị Ebraham bụ nna nna anyị nyere ya otu ụzọ nʼime ụzọ iri site nʼihe ọ kwatara nʼagha!  
\v 5 Ma otu ọ dị, iwu kwadoro ka ụmụ Livayị bụ ndị ghọrọ ndị nchụaja na-anakọta otu ụzọ nʼime ụzọ iri site nʼaka ndị ọzọ, ya bụ, site nʼaka ndị ụmụnna ha ndị Izrel, nʼagbanyeghị na ụmụnna ha ndị ahụ bụkwa ụmụ ụmụ Ebraham.  
\v 6 Ma nwoke a bụ onye na-esiteghị nʼagbụrụ naara otu ụzọ nʼụzọ iri site nʼaka Ebraham ma gọziekwa ya bụ onye ahụ nke natara nkwa ahụ.  
\v 7 O nweghị ịrụrịta ụka ọbụla dị ya, na onye dị ukwuu na-agọzi onye dị nta.  
\v 8 Nʼotu aka ahụ, ndị na-anata otu ụzọ nʼụzọ iri bụ mmadụ na-anwụ anwụ, ma nʼaka nke ọzọ, onye na-anata ya bụ onye ahụ e kwupụtara na ọ na-adị ndụ.  
\v 9 Mmadụ pụrụ isi na Livayị onye natara otu ụzọ nʼụzọ iri kwụrụ otu ụzọ nʼụzọ iri nke ya site nʼaka Ebraham.  
\v 10 Nʼihi na mgbe Melkizedek zutere ya, ọ ka nọ nʼafọ nna nna ya. 
\s1 Jisọs dị ka Melkizedek 
\p  
\v 11 Ọ bụrụ na a pụrụ ime ka mmadụ zuo oke site nʼọnọdụ ndị nchụaja ndị Livayị, nʼihi na ọ bụ site nʼiwu e nyere ndị mmadụ ka e ji hiwee ọnọdụ ndị nchụaja. Olee uru ọ bara ka onye nchụaja ọzọ bịa, dị ka usoro Melkizedek si dị, na-abụghị dị ka usoro nke Erọn?  
\v 12 Ebe a gbanwere ọnọdụ ndị nchụaja, nʼotu aka ahụ, a ghaghị ịgbanwekwa iwu.  
\v 13 Nʼihi na onye ahụ e kwuru ihe ndị a banyere ya sitere nʼagbụrụ ọzọ, nke ọ dịbeghị onye ọbụla sitere na ya rụrụ ọrụ dị nʼebe ịchụ aja.  
\v 14 Ọ bụ ihe a mara nke ọma na Onyenwe anyị si nʼagbụrụ Juda pụta, Mosis nʼonwe ya akpọtụghị agbụrụ ahụ aha mgbe ọ na-ekwu banyere ndị nchụaja.  
\v 15 E meela ka a ghọta okwu anyị na-ekwu nke ọma, mgbe onye nchụaja ọzọ yiri Melkizedek pụtara.  
\v 16 Onye ghọrọ onye nchụaja ma ọ bụghị site nʼusoro iwu nke ọmụmụ ndị nchụaja, kama site nʼike dị na ndụ nke na-apụghị ịla nʼiyi.  
\v 17 Nʼihi na-agbara akaebe banyere ya, sị, 
\q1 “Gị onwe gị, bụ onye nchụaja ruo mgbe ebighị ebi, 
\q2 dị ka usoro Melkizedek si dị.”\f + \fr 7:17 \ft \xt Abụ 110:4\f* 
\p  
\v 18 Nʼotu aka ahụ, e wezugala usoro iwu ochie ahụ nʼihi adịghị ike ya na nʼihi abaghị uru ya  
\v 19 (nʼihi na iwu ahụ emeghị ka ihe ọbụla zuo oke), ma nʼaka nke ọzọ, e webatala olileanya ka mma, bụ nke anyị na-esite na ya bịaruo Chineke nso. 
\p  
\v 20 Ma e ji ịṅụ iyi mee ka ọnọdụ onyeisi nchụaja a guzosie ike. O nweghị iyi a ṅụrụ mgbe ndị ọzọ ghọrọ ndị nchụaja.  
\v 21 Ma onye nke a ghọrọ onye nchụaja site nʼịṅụ iyi mgbe onye ahụ gwara ya, 
\q1 “Onyenwe anyị aṅụọla iyi, 
\q2 ọ gaghị agbanwe obi ya, 
\q2 ‘Ị bụ onye nchụaja ruo mgbe ebighị ebi.’ ”\f + \fr 7:21 \ft \xt Abụ 110:4\f* 
\m  
\v 22 Nʼihi nke a, Jisọs aghọọla onye na-akwagide ọgbụgba ndụ ka mma. 
\p  
\v 23 Ihe ọzọ, ndị nchụaja nke ochie ahụ dị ọtụtụ nʼọnụọgụgụ nʼihi na ọnwụ gbochiri ha ịga nʼihu nʼọrụ ha.  
\v 24 Ya mere, ebe ọ na-adị ndụ ruo mgbe ebighị ebi, ọ na-abụkwa onyeisi nchụaja mgbe niile.  
\v 25 Ya mere o nwere ike ịzọpụta ruo mgbe niile ndị ahụ na-abịakwute Chineke site na ya, nʼihi na ọ na-adị ndụ ruo mgbe niile ịrịọ arịrịọ nʼihi ha. 
\p  
\v 26 Ya mere, ọ dị mkpa na anyị ga-enwe onyeisi nchụaja dị otu a, bụ onye dị nsọ, na onye na-enweghị ntụpọ, na onye dị ọcha, na onye e kewapụrụ site nʼebe ndị mmehie nọ, ma buliekwa ya elu karịa nʼeluigwe.  
\v 27 Ọ dịghị ka ndịisi nchụaja ndị ọzọ, nʼihi na ọ dịghị mkpa na ọ ga-achụ aja kwa ụbọchị, nʼihi mmehie nke aka ya, na nʼihi mmehie nke ndị ọzọ. Naanị otu aja nke dịrị mgbe niile ka ọ chụrụ maka mmehie mgbe o weere onwe ya nye dị ka aja.  
\v 28 Nʼihi na iwu na-ahọpụta dị ka ndịisi nchụaja ndị mmadụ na-adịghị ike. Ma okwu nke ịṅụ iyi ahụ, nke na-eso iwu nʼazụ, họpụtara Ọkpara, onye e mere ka o zuo oke ruo mgbe ebighị ebi. 
\c 8  
\s1 Onyeisi nchụaja nke ọgbụgba ndụ ọhụrụ 
\p  
\v 1 Isi okwu dị nʼihe niile anyị na-ekwu bụ nke a, na anyị nwere onyeisi nchụaja dị otu a, bụ onye na-anọdụ ala nʼaka nri nke ocheeze onye ahụ kachasị ihe niile elu nʼeluigwe.  
\v 2 Onye na-eje ozi nʼebe nsọ ahụ, bụ ezi ụlọ ikwu ahụ Onyenwe anyị ji aka ya wuo, ọ bụghị mmadụ wuru ya. 
\p  
\v 3 A họpụtara onyeisi nchụaja ọbụla ka ọ na-achụ aja na-enyekwa onyinye. Nʼihi nke a, o kwesikwara ka ọ nwee ihe ọ ga-eji na-achụ aja.  
\v 4 A sịkwarị na ọ nọ nʼụwa, o garaghị a bụ onye nchụaja nʼihi na e nwere ndị nchụaja na-achụ aja dị ka usoro iwu si dị.  
\v 5 Ha na-eje ozi nʼebe nsọ ahụ nke bụ oyiyi na onyinyo banyere ihe nke dị nʼeluigwe. Ọ bụ nke a mere e ji dọọ Mosis aka na ntị mgbe ọ na-akwado iwu ụlọ ikwu ahụ, “Lezie anya hụ na i mere ihe niile nʼusoro dị ka e si gosiri gị nʼelu ugwu.”\f + \fr 8:5 \ft \xt Ọpụ 25:40\f* 
\v 6 Ma otu ọ dị, ọ natara ọrụ ije ozi karịrị nke ha, dị ka onye ogbugbo nke ọgbụgba ndụ dị elu karịa nke ochie, ebe ọgbụgba ndụ nke ọhụrụ a o mere ka ọ dịrị nʼetiti ya na mmadụ dabeere na nkwa dị mma karịa. 
\p  
\v 7 Ọ bụrụ na ọgbụgba ndụ ochie ahụ zuruoke, ọ garaghị aba uru ka achọwa ọgbụgba ndụ ọzọ.  
\v 8 Ma Chineke chọpụtara ezughị oke ha mgbe ọ sịrị, 
\q1 “Lee, oge na-abịa, ka Onyenwe anyị kwupụtara, 
\q2 mgbe m ga-eme ka ọgbụgba ndụ ọhụrụ 
\q1 dịrị nʼetiti mụ na ụlọ Izrel, 
\q2 nakwa ụlọ Juda. 
\q1  
\v 9 Ọ bụghị ụdị ọgbụgba ndụ 
\q2 mụ na nna nna ha gbara, 
\q1 mgbe m jidere ha nʼaka 
\q2 site nʼala Ijipt dupụta ha, 
\q1 nʼihi na ha anọgideghị bụrụ ndị kwesiri ntụkwasị obi idebe ọgbụgba ndụ m. 
\q2 Nʼihi ya, echepụrụ ihu m nʼebe ha nọ, 
\q2 ka Onyenwe anyị kwupụtara. 
\q1  
\v 10 Ma nke a bụ ọgbụgba ndụ m ga-eme ka ọ dịrị nʼetiti mụ onwe m na ụlọ Izrel, 
\q2 mgbe oge ndị ahụ gasịrị, otu a ka Onyenwe anyị kwubiri. 
\q1 Aga m etinye iwu m nʼime uche ha, 
\q2 dekwasị ya nʼobi ha. 
\q1 Aga m abụ Chineke ha, 
\q2 ha onwe ha ga-abụkwa ndị m. 
\q1  
\v 11 Ọ dịghị onye ọbụla nʼetiti ha ga-akụziri onye agbataobi ya ihe, 
\q2 maọbụ otu onye asị ibe ya, ‘Mara Onyenwe anyị,’ 
\q1 nʼihi na ha niile ga-ama onye m bụ, 
\q2 site nʼonye dịkarịsịrị nta ruo nʼonye dịkarịsịrị ukwuu. 
\q1  
\v 12 Nʼihi na aga m agbaghara ajọ omume ha, 
\q2 agaghị m echetakwa mmehie ha niile ọzọ.”\f + \fr 8:12 \ft \xt Jer 31:31-34\f* 
\p  
\v 13 Mgbe o kwuru okwu banyere ọgbụgba ndụ ọhụrụ, ọ pụtara na nke ochie ahụ abụrụla ihe gabigara agabiga. Ihe dị ochie nke gabigara ga-emesịa ghara ịdịkwa. 
\c 9  
\s1 Ebe ofufe nke ụwa na nke eluigwe 
\p  
\v 1 Ọgbụgba ndụ nke mbụ nwere usoro ofufe na ebe nsọ nke ụwa nke a e jiri aka wuo.  
\v 2 E guzobere ụlọ ikwu. Nʼọnụụlọ nke mbụ nʼụlọ ikwu ahụ, e nwere ihe ịdọba iheọkụ, na tebul, na achịcha e doro nsọ. Aha ọnụụlọ nke mbụ a bụ Ebe Nsọ.  
\v 3 Nʼazụ akwa mgbochi nke abụọ ka e nwere ọnụụlọ a na-akpọ Ebe Kachasị Nsọ,  
\v 4 nke nwere ebe ịchụ aja mgbaisiọma\f + \fr 9:4 \ft Maọbụ, \fqa ihe ndị bekee na-akpọ insensi\f* e ji ọlaedo wuo, na igbe ọgbụgba ndụ ahụ nke e jiri ọlaedo machie ahụ ya niile. Ihe dị nʼime ite ahụ bụ mánà na mkpanaka Erọn nke ahụ puputara ahịhịa, ya na mbadamba nkume e dekwasịrị iwu ọgbụgba ndụ.  
\v 5 Ihe dị nʼelu igbe a bụ cherubim nke ebube ya, na-ekpuchite oche amara ahụ. Ma anyị enweghị ike ịkọwacha ihe niile ndị a nʼozuzu oke ugbu a. 
\p  
\v 6 Mgbe e doro ihe niile ndị a nʼusoro, onye nchụaja na-abata mgbe ọbụla nʼime ọnụụlọ nke mbụ nke ụlọ ikwu a. Nʼebe a ka ọ na-arụ ọrụ o ketara ịrụ.  
\v 7 Ma ọ bụ naanị onyeisi nchụaja na-abanye nʼime ọnụụlọ nsọ nke abụọ, naanị otu ugboro nʼafọ. Ọ na-ejikwa ọbara na-aba nʼebe ahụ, iji chụọ aja maka onwe ya na nʼihi mmehie ndị mmadụ mere na-amaghị ama.  
\v 8 Site na nke a, Mmụọ Nsọ na-egosi na ụzọ e si abanye nʼEbe Kachasị Nsọ ahụ bụ ihe na a ka apụtabeghị ihe, ebe ọ bụ na ụlọ ikwu nke mbụ ahụ ka na-eguzo.  
\v 9 Nke a bụ ihe ilu banyere oge ugbu a. Site na nhazi nke a, onyinye na aja niile a na-achụ enweghị ike ime ka akọnuche onye na-efe ofufe zuo oke.  
\v 10 Kama ha bụ naanị usoro iwu metụtara ihe oriri na ihe ọṅụṅụ na ụdị baptizim dị iche iche nke anụ ahụ, bụ nke e nyere ka a na-eme ya ruo mgbe a ga-edozigharị ihe niile. 
\s1 Ọbara nke Kraịst 
\p  
\v 11 Mgbe Kraịst bịara dị ka onyeisi nchụaja nke ezi ihe ahụ dị ugbu a, site nʼụlọ ikwu dị ukwuu zuruoke nke a na-ejighị aka mee, nke na-esoghị nʼihe e kere eke,  
\v 12 o jighị ọbara ụmụ ewu na nke ụmụ ehi banye nʼebe ahụ, kama o ji ọbara nke ya onwe ya banye nʼEbe ahụ Kachasị Nsọ naanị otu mgbe, jiri ya wetara anyị niile mgbapụta ebighị ebi.  
\v 13 Ma ọ bụrụ na ọbara ewu na nke oke ehi dị iche iche, ya na ntụ nwa agbọghọ ehi, nke e fekwasịrị ndị rụrụ arụ, pụrụ ido ha nsọ, meekwa ka ha dị ọcha nʼelu ahụ.  
\v 14 Ọbara Kraịst onye sitere na Mmụọ dị ebighị ebi were onwe ya chụọrọ Chineke aja nʼenweghị ntụpọ ọbụla, ọ ga-esi aṅaa ghara ịsachapụ omume ruru unyi nke akọnuche anyị, ka anyị nwee ike ife Chineke dị ndụ. 
\p  
\v 15 Nʼihi nke a, ọ bụ onye ogbugbo nke ọgbụgba ndụ ọhụrụ, ka ndị a kpọrọ site na ya nata ihe nketa ebighị ebi ahụ bụ nke e kwere ha na nkwa. A pụrụ ime nke a nʼihi ọ nwụọla ọnwụ gbapụta ụmụ mmadụ site nʼikpe ọmụma nke mmehie ha mere nʼokpuru ọgbụgba ndụ nke mbụ ahụ. 
\p  
\v 16 Ọ bụrụ na mmadụ ekee ekpe mgbe ọ nọ ndụ, a na-ebu ụzọ achọpụta ma onye kere ekpe ahụ ọ nwụọla.  
\v 17 Ekpe na-amalite ịdị ire mgbe onye kere ekpe ahụ nwụrụ, nʼihi na ihe mmadụ kere nʼekpe anaghị adị ire mgbe onye kere ya ka dị ndụ.  
\v 18 Ọ bụ nke a mere ọ bụladị ọgbụgba ndụ ochie ahụ jiri bụrụ ihe na-adịghị ire ruokwa mgbe ọbara batara na ya.  
\v 19 Mgbe Mosis kwupụtachara ndị mmadụ iwu ahụ, o weere ọbara ụmụ ehi na ewu, ya na mmiri, ogbo uhie na hisọp fesaa nʼakwụkwọ iwu ahụ nakwa nʼelu mmadụ niile.  
\v 20 Na-ekwu, “Nke a bụ ọbara ọgbụgba ndụ ahụ nke Chineke nyere unu iwu.”\f + \fr 9:20 \ft \xt Ọpụ 24:8\f* 
\v 21 Nʼotu aka ahụ, o fesakwara ọbara ahụ nʼelu ụlọ ikwu na nʼelu ihe niile dị nʼụlọ ikwu, bụ ihe niile e ji efe ofufe.  
\v 22 Nʼikwu eziokwu, dịka iwu si dị, ọ dịghị ihe ọbụla nke a na-adịghị eji ọbara edo ọcha. Ọ bụrụ na a wụsịghị ọbara, mgbaghara mmehie adịghị. 
\s1 Aja Kraịst chụrụ na-ewepụ mmehie 
\p  
\v 23 O kwesiri ka e si otu a mee ka ihe ndị a yiri ihe ndị dị nʼeluigwe dị ọcha, ma ihe ndị dị nʼeluigwe nʼonwe ha kwesiri ka e nye ha aja dị mma karịa.  
\v 24 Nʼihi na ọ bụghị nʼebe nsọ nke mmadụ jiri aka wuo, nke yiri nke dị nʼeluigwe, ka Kraịst banyere, kama ọ banyere nʼime eluigwe nʼonwe ya, bụ ebe ọ na-anọchite anya anyị ugbu a nʼihu Chineke.  
\v 25 Ọ banyeghị na ya ka o were onwe ya chụọ aja ọtụtụ ugboro, dị ka onyeisi nchụaja na-eji ọbara na-abụghị nke ya na-abanye nʼEbe ahụ Kachasị Nsọ kwa afọ.  
\v 26 Ọ bụrụ na o si otu a dịrị, ọ gaara abụ onye na-ahụ ahụhụ mgbe kemgbe e kere ụwa. Ma, dị ka o si dị, ọ bịara naanị otu ugboro nʼọgwụgwụ oge ndị a, iwezuga mmehie site nʼiji onwe ya chụọ aja.  
\v 27 Dị ka ọ bụ ihe a kwadooro mmadụ ọbụla ịnwụ naanị otu ugboro, ma e mesịa ikpe esochie,  
\v 28 otu a ka e si chụọ Kraịst dị ka aja naanị otu ugboro iwepụ mmehie ọtụtụ mmadụ. Ọ ga-abịaghachi nke ugboro abụọ, ma ọ bụghị nʼihi ibu mmehie, kama ọ bụ nʼihi iweta nzọpụta nye ndị ahụ niile na-eche ọbịbịa ya. 
\c 10  
\s1 Kraịst chụrụ aja naanị otu ugboro 
\p  
\v 1 Iwu ahụ bụ naanị onyinyo na-egosi ihe ọma gaje ịbịa. Nʼihi ya, o zughị oke nʼonwe ya isite nʼaja ndị ahụ a na-achụ mgbe mgbe kwa afọ, mee ka ndị ahụ na-abịaru nso ife ofufe zuo oke.  
\v 2 Ma ọ bụghị otu a, ọ bụ na a gabeghị akwụsị ịchụ aja ndị a? Ọ bụrụ na a sachapụla njọ ndị na-efe ofufe na mbụ, akọnuche ha agaghịkwa ama ha ikpe mmehie ha.  
\v 3 Ma nke bụ eziokwu bụ na ihe aja ndị a na-eme bụ ichetara ha mmehie ha kwa afọ niile.  
\v 4 Nʼihi na ọ bụ ihe na-apụghị ime eme na ọbara oke ehi na nke ụmụ ewu dị iche iche ga-asachapụ mmehie. 
\p  
\v 5 Ya mere mgbe Kraịst bịara nʼụwa, ọ sịrị, 
\q1 “Aja na onyinye abụghị ihe ị chọrọ 
\q2 kama ị kwadoro ahụ nye m. 
\q1  
\v 6 Aja nsure ọkụ na aja a chụrụ maka mmehie, 
\q2 ha abụghị ihe dị ezi mma nye gị. 
\q1  
\v 7 Mgbe ahụ ka m sịrị, ‘Lee, abịala m Chineke m, ime ihe ị na-achọ. 
\q2 Nke a bụkwa ihe e dere banyere m nʼime akwụkwọ mpịakọta.’ ”\f + \fr 10:7 \ft \xt Abụ 40:6-8\f* 
\m  
\v 8 O kwuru na mbụ, “Aja dị iche iche, na onyinye, na aja nsure ọkụ na aja mmehie adịghị atọ gị ụtọ, ha adịghịkwa amasị gị” (a chụrụ aja ndị a dịka iwu si dị).  
\v 9 O kwukwara ọzọ, “Lee abịala m ime uche gị.” Ọ kagburu aja nke mbụ ahụ ma were aja nke abụọ dochie nʼọnọdụ ya.  
\v 10 Site nʼime uche Chineke, e mere ka anyị dị nsọ site nʼaja Jisọs Kraịst ji onwe ya chụọ naanị otu ugboro. 
\s1 Aja Kraịst chụrụ zubigara oke 
\p  
\v 11 Onye nchụaja ọbụla na-eguzo kwa ụbọchị na-efe ofufe, na-achụkwa otu aja ahụ ugboro ugboro, bụ aja nke na-enweghị ike ịsachapụ mmehie.  
\v 12 Ma mgbe Kraịst chụchara naanị otu aja ahụ, otu ugboro nʼihi mmehie niile, ọ nọdụrụ ala nʼaka nri Chineke.  
\v 13 Ebe ahụ ka ọ nọ ugbu a na-eche ka ndị iro ya niile bụrụ ihe mgbakwasị ụkwụ ya.  
\v 14 Nʼihi na o sitela nʼotu aja mee ka ndị ahụ a na-eme ka ha dịrị nsọ zuo oke mgbe niile. 
\p  
\v 15 Mmụọ nsọ na-agbakwara anyị ama banyere ihe ndị a mgbe o buru ụzọ kwuo: 
\q1  
\v 16 “Nke a bụ ọgbụgba ndụ ahụ mụ na ha ga-agba 
\q2 mgbe oge ndị ahụ gasịrị, ka Onyenwe anyị kwuru. 
\q1 Aga m etinye iwu m nʼobi ha. 
\q2 Aga m edekwasịkwa ha nʼuche ha.”\f + \fr 10:16 \ft \xt Jer 31:33\f* 
\m  
\v 17 O kwukwara sị, 
\q1 “Agaghị m echetakwa mmehie ha 
\q2 na mmebi iwu ha niile ọzọ.”\f + \fr 10:17 \ft \xt Jer 31:34\f* 
\m  
\v 18 Ya mere, ebe ọ bụ na a gbagharala mmehie ndị a, ọ dịkwaghị mkpa ịchụ ajọ ọzọ maka mgbaghara mmehie. 
\s1 Ọkpụkpọ oku banyere inwe mkpebi 
\p  
\v 19 Nʼihi nke a, ụmụnna m, ebe anyị nwere nkwuwa okwu ịbanye nʼEbe Kachasị Nsọ site nʼọbara Jisọs,  
\v 20 bụ ụzọ ọhụrụ nke o meghere nye anyị, nke dị ọhụrụ ma dịkwa ndụ site nʼakwa mgbochi ahụ nke bụ ahụ ya,  
\v 21 ebe anyị nwekwara onye nchụaja dị ukwuu, nke na-elekọta ụlọ Chineke,  
\v 22 ka anyị bịaruo nso site nʼobi dị ọcha, na ntụkwasị obi zuru ezu nke okwukwe, ka anyị bụrụ ndị a sachara obi ha site nʼakọnuche rụrụ arụ, ka anyị bụrụkwa ndị e ji mmiri dị ezigbo ọcha sachaa ahụ anyị.  
\v 23 Ya mere, ka anyị jidesie nkwupụta nke olileanya anyị ike, nʼihi na onye ahụ kwere nkwa kwesiri ntụkwasị obi.  
\v 24 Ka anyị tụgharịa uche otu anyị ga-esi kpalie ibe anyị nʼịhụnanya na ezi ọrụ.  
\v 25 Ka anyị gharakwa ichefu nzukọ anyị dị ka ụfọdụ na-eme, kama ka anyị na-agbarịta onwe anyị ume, karịsịa, ugbu a ụbọchị ahụ na-abịa nso. 
\s1 Ịdọ aka na ntị banyere mmehie 
\p  
\v 26 Ọ bụrụ na anyị akpachapụ anya na-anọgide na mmehie mgbe anyị matachara eziokwu ahụ, o nwekwaghị aja ọzọ fọdụrụ a ga-achụ banyere mmehie niile.  
\v 27 Kama naanị ikpe dị oke egwu, nke ga-adị ka ọkụ na-ere ike ike, nke ga-erechapụ ndị niile bụ ndị iro.  
\v 28 Onye ọbụla dara iwu Mosis, na-anwụ na-enweghị ebere, site nʼakaebe mmadụ abụọ maọbụ atọ gbara megide ya.  
\v 29 Ọ bụrụ na ọ dị otu a, olee ụdị ahụhụ unu chere na a ga-enye onye lelịrị Ọkpara Chineke, gịnị ka a ga-eme onye merụrụ ọbara nke ọgbụgba ndụ nke e ji doo ya nsọ, na onye kpasuru mmụọ nke amara ahụ iwe?  
\v 30 Nʼihi na anyị maa onye ahụ kwurunụ, “Ịbọ ọbọ dịrị m, aga m akwụghachi,”\f + \fr 10:30 \ft \xt Dit 32:35\f* ọzọkwa, “Onyenwe anyị ga-ekpe ndị ya ikpe.”\f + \fr 10:30 \ft \xt Dit 32:36; Abụ 135:14\f* 
\v 31 Ọ bụ ihe dị oke egwu ịdaba nʼaka Chineke dị ndụ. 
\p  
\v 32 Ma chetakwanụ ụbọchị mbụ ndị ahụ, mgbe unu natachara ìhè, unu nọgidesikwara ike nʼagbanyeghị oke ahụhụ niile unu tara.  
\v 33 Mgbe ụfọdụ, a kparịrị unu nʼihu ọha, unu natakwara mkpagbu. Nʼoge ọzọ, unu soro ndị e si otu a mesoo mmeso.  
\v 34 Unu were obi ebere soro ndị nọ nʼụlọ mkpọrọ taa ahụhụ, unu jikwa ọṅụ nabata ya mgbe a nakọrọchara unu ihe niile unu nwere, nʼihi na unu onwe unu matara na unu nwere ihe ka mma, nke na-anọgide.  
\v 35 Ya mere, unu ahapụkwala ntụkwasị obi unu ahụ, nʼihi na ọ na-eweta ụgwọ ọrụ dị ukwuu. 
\p  
\v 36 Nʼihi ya, unu kwesiri inwe ndidi ka ọ ga-abụ na mgbe unu mere uche Chineke unu ga-anata ihe e kwere na nkwa.  
\v 37 Nʼihi, 
\q1 “Na oge na-adịghị anya, 
\q2 onye ahụ nke na-abịa ga-abịa 
\q2 ọ gaghị anọkwa ọdụ.” 
\m  
\v 38 Ma, 
\q1 “Onye ezi omume nkem ga-esite nʼokwukwe dị ndụ. 
\q2 Mkpụrụobi m agaghị e nwee mmasị 
\q2 nʼime onye ọbụla na-alaghachi azụ.”\f + \fr 10:38 \ft \xt Hab 2:3,4\f* 
\m  
\v 39 Ma anyị abụghị ndị na-alaghachi azụ si otu a laa nʼiyi. Kama anyị dịnyere ndị nwere okwukwe, bụrụkwa ndị a zọpụtara. 
\c 11  
\s1 Okwukwe 
\p  
\v 1 Ugbu a, okwukwe bụ inwe obi ike banyere ihe ndị a na-ele anya ha na inwe owuweanya banyere ihe a na-ahụbeghị anya.  
\v 2 Nʼihi na ọ bụ site nʼokwukwe ka e ji gbaara ndị ochie ama. 
\p  
\v 3 Ọ bụ site nʼokwukwe ka anyị ji ghọta na e mere ụwa na ihe niile anyị na-ahụ anya site nʼokwu Chineke. Nʼihi nke a, ihe anyị na-ahụ anya ugbu a bụ ihe e mere site nʼihe anyị na-adịghị ahụ anya. 
\s2 Ebel 
\p  
\v 4 Ebel sitere nʼokwukwe chụọ aja dị mma nye Chineke karịa aja nke Ken chụrụ; nke e si na ya gụnye ya nʼonye ezi omume. Chineke kwuru okwu banyere onyinye ya. Ma ugbu a, ọ bụ ezie na ọ nwụọlarị ma ọ ka na-ekwu okwu site nʼokwukwe. 
\p  
\v 5 E sitere nʼokwukwe kupu Enọk nke pụtara na ọ nwụghị anwụ, a hụkwaghị ya ọzọ nʼihi na Chineke akpọrọla ya.\f + \fr 11:5 \ft \xt Jen 5:24\f* Ma tupu e kuru ya, e mere ka anyị mara na ọ mere ihe masịrị Chineke.  
\v 6 Ọ bụ ihe siri ike mmadụ ime ihe ga-atọ ya ụtọ ma ọ bụrụ na onye ahụ enweghị okwukwe. Nʼihi na onye na-abịakwute Chineke nso aghaghị ikwe na ọ dị. Na ọ bụkwa onye na-akwụghachi onye ọbụla na-achọsi ya ike ụgwọ. 
\s2 Noa 
\p  
\v 7 Site nʼokwukwe, Noa, onye nke a dọrọ aka na ntị gbasara ihe ndị a na-ahụbeghị anya, gere ntị ma ruo ụgbọ mmiri maka nzọpụta nke ezinaụlọ ya. Site na nke a, ọ mara ụwa ikpe, ma bụrụ onye nketa nke ezi omume sitere nʼokwukwe. 
\s2 Ebraham na Sera 
\p  
\v 8 Site nʼokwukwe, Ebraham rubere isi mgbe a kpọrọ ya ka ọ hapụ, gaa nʼala ahụ nke ọ ga-enweta dịka ihe nketa. Ọ gawara nʼamaghị ebe ọ na-aga.  
\v 9 Okwukwe ka o jiri biri dịka ọbịa nʼala ahụ e kwere ya na nkwa, na-ebi nʼụlọ ikwu, ya na Aịzik na Jekọb, bụ ndị e kwere ya na ha otu nkwa ahụ.  
\v 10 Nʼihi na ọ na-ele anya ala ahụ nke nwere ntọala, nke onye tụrụ atụmatụ ya ma wuokwa ya bụ Chineke.  
\v 11 Site nʼokwukwe ọ natara ike ọmụmụ. Ọ bụ ezie na ọ gafeela oge ịmụta nwa, ọ bụladị Sera nʼonwe ya bụ nwanyị aga, nʼihi na ọ gụrụ onye ahụ kwere ya nkwa dị ka onye kwesiri ntụkwasị obi.  
\v 12 Ya mere site nʼotu onye a, onye a gụrụ dị ka onye nwụrụ anwụ ka e si nweta ụmụ ndị ọnụọgụgụ ha dị ka kpakpando dị na mbara eluigwe, dị ka aja dị nʼakụkụ osimiri. 
\p  
\v 13 Ndị a niile nwere okwukwe nwụrụ na-anataghị nkwa ahụ, ma site nʼebe dị anya ha hụrụ ma nabatakwa nkwa ndị a. Ha kwupụtakwara na ha bụ ndị ọbịa na ndị mba ọzọ nʼụwa.  
\v 14 Ndị na-ekwu otu a na-ezipụta na ha na-ele anya obodo nke aka ha.  
\v 15 Ọ bụrụ na ha na-eche echiche banyere obodo nke ha hapụrụ, ha gaara enwe ohere ịlaghachi azụ.  
\v 16 Ma otu ọ dị, ha na-elesi anya ike maka obodo ahụ ka mma, bụ nke dị nʼeluigwe. Ya mere, ọ dịghị eme Chineke ihere ka a kpọ ya Chineke ha, nʼihi na o dozielara ha ebe obibi. 
\p  
\v 17 Site nʼokwukwe Ebraham ji Aịzik chụọ aja mgbe a nwalere ya. Onye ahụ natara ihe ndị ahụ e kwere nkwa, dị njikere iji otu nwa ahụ o nwere chụọ aja,  
\v 18 ọ bụ ezie na Chineke kwuru maka ya, “Ọ bụ site nʼAịzik ka a ga-akpọ mkpụrụ gị aha.”\f + \fr 11:18 \ft \xt Jen 21:12\f* 
\v 19 Ebraham chere na Chineke pụrụ ime ka onye nwụrụ anwụ site nʼọnwụ bilie, dịka ihe ịma atụ otu ahụ ka o mekwara, nʼihi na ọ nataghachikwara ya. 
\p  
\v 20 Ọ bụ okwukwe ka Aịzik jiri nye Jekọb na Ịsọ ngọzị banyere ihe dị nʼihu. 
\s2 Jekọb na Josef 
\p  
\v 21 Ọ bụ okwukwe ka Jekọb ji gọzie ụmụ Josef nʼotu nʼotu tupu ọ nwụọ. Ọ kpọrọ isiala dịka ọ dabere nʼelu mkpanaka ya. 
\p  
\v 22 Nʼọgwụgwụ ndụ ya, Josef sitere nʼokwukwe kwuo banyere ọpụpụ ụmụ Izrel ma nyekwa ntụziaka banyere olili ọkpụkpụ ya. 
\s2 Mosis 
\p  
\v 23 Okwukwe ka nne na nna Mosis ji zobe ya ọnwa atọ mgbe a mụrụ ya, nʼihi na ha hụrụ na ọ bụ nwa mara mma. Ha atụkwaghị egwu iwu eze ala Ijipt bụ Fero nyere. 
\p  
\v 24 Site nʼokwukwe, Mosis e kweghị aza nwa ada Fero mgbe o tolitere.  
\v 25 Ọ họọrọ isoro ụmụ Chineke keta oke na mmegbu ha karịa inwe aṅụrị nke mmehie.  
\v 26 O kpebiri na ọ bụ ihe karịchara mma ịhụ ahụhụ nʼihi Kraịst, kama inweju akụ niile nke Ijipt afọ. Nʼihi na o nwere olileanya maka ụgwọ ọrụ dị nʼihu.  
\v 27 Okwukwe ka ọ ji hapụ Ijipt. Ọ tụghị egwu iwe eze, ma ọ tachịrị obi ya dịka ọ hụrụ onye ahụ a na-apụghị ịhụ anya.  
\v 28 O sitekwara nʼokwukwe debe Mmemme Ngabiga. O fesara ọbara ka onye mbibi nke ụmụ nwoke mbụ, hapụ ịmetụ ụmụ nwoke mbụ ndị Izrel aka. 
\p  
\v 29 Ha gafere Osimiri Uhie site nʼokwukwe dị ka a ga-asị na ọ bụ ala efu. Ma mgbe ndị Ijipt nwara ime nke a, mmiri lomiri ha niile. 
\s2 Rehab 
\p  
\v 30 Mgbidi Jeriko dara mgbe ha jiri okwukwe gaa ya gburugburu ụbọchị asaa. 
\p  
\v 31 Site nʼokwukwe, Rehab nwanyị akwụna esoghị ndị nnupu isi laa nʼiyi nʼihi na ọ nabatara ndị bịara inyochapụta obodo ahụ nʼudo. 
\s2 Ọtụtụ ndị okwukwe ọzọ 
\p  
\v 32 Olee ihe ọzọ m ga-ekwu? Oge ga-agwụnahụ m ikwu gbasara Gidiọn, na Barak, na Samsin, na Jefta, na Devid, na Samuel na ndị amụma,  
\v 33 ndị sitere nʼokwukwe merie ọtụtụ alaeze, kpeekwa ikpe nkwụmọtọ, natakwa nkwa e kwere, ndị mechiri ọnụ ọdụm.  
\v 34 Ha menyụrụ ọkụ dị egwu, gbanarị mma agha, nweta ike site nʼadịghị ike. Ha ghọkwara ndị dị ike nʼagha, chụlaa usuu ndị agha ndị mba ọzọ.  
\v 35 Ụmụ nwanyị natara ndị ha nwụrụ anwụ, site na mbilite nʼọnwụ. Ndị ọzọ naara ntaramahụhụ, ha jụrụ ịnata mgbapụta ka ha nwee ike nata mbilite nʼọnwụ ka mma.  
\v 36 E ji ụfọdụ mere ihe ọchị, tiekwa ha ihe otiti, ọ bụladị ike ha agbụ na ịtụ ha mkpọrọ.  
\v 37 A tụrụ ụfọdụ nkume, kwọbie ụfọdụ abụọ. E ji mma agha gbuo ụfọdụ. Ụfọdụ yi akpụkpọ ewu na akpụkpọ atụrụ jegharịa. Ụfọdụ bụkwa ndị dara ụkpa. A kpagburu ụfọdụ, ma mejọọkwa ndị ọzọ.  
\v 38 Ha wagharịrị nʼọzara na nʼugwu, nʼọgba nkume na nʼọnụ ala. Nʼanya ụwa, a gụrụ ha nʼihe efu. 
\p  
\v 39 A gbaara ezigbo ama nʼisi ndị a niile nʼihi okwukwe ha, ma ha anataghị ihe ahụ e kwere ha na nkwa.  
\v 40 Otu ọ dị, Chineke akwadoberela anyị ihe kaara anyị mma, ka a ghara ime ka ha zuo oke ma e wepụ anyị. 
\c 12  
\s1 Kraịst bụ ihe nlere anya nye anyị 
\p  
\v 1 Ya mere, anyị nwere oke igwe ndị ama dị otu a gbara anyị gburugburu, nʼihi nke a, ka anyị wepụ ihe ọbụla nke na-adọghachi anyị azụ dịka ibu arọ, ya na mmehie niile nọdebere anyị nsọ karịa. Ka anyị werekwa ntachiobi gbaa ọsọ nke chere anyị nʼihu.  
\v 2 Ka anyị na-elegide Jisọs anya, onye mbụ na onye na-eme ka okwukwe anyị zuo oke, onye jiri nʼihi ọṅụ e debere nʼihu ya, die ahụhụ na ihe ihere nke obe, ọ nọdụ nʼaka nri nke ocheeze Chineke.  
\v 3 Tuleenụ nʼobi unu gbasara onye ahụ tachịrị obi na nkwụgide sitere nʼaka ndị mmehie, ka ike ghara ịgwụ unu maọbụ obi unu adaa mba. 
\s1 Ụzọ Chineke si azụ ụmụ ya 
\p  
\v 4 Nʼime ọgụ nke unu na-alụso mmehie, unu eguzogideghị ruo nʼọnọdụ nke iwufu ọbara unu.  
\v 5 Unu echefuola okwu nkasiobi ahụ, nke e jiri gbaa unu ume dịka ụmụ, 
\q1 “Nwa m ewela ịdọ aka na ntị nke Onyenwe anyị dịka ihe dị mfe, mgbe ọ na-ata gị ahụhụ 
\q2 maọbụ daa mba mgbe ọ na-abara gị mba. 
\q1  
\v 6 Nʼihi na onye Onyenwe anyị hụrụ nʼanya ka ọ na-abara mba. 
\q2 Ọ bụkwa onye ọ nabatara dị ka nwa ya, ka ọ na-apịa ụtarị.”\f + \fr 12:6 \ft \xt Ilu 3:11,12\f* 
\p  
\v 7 Tachie obi, mụta ihe site nʼahụhụ. Nʼihi na Chineke na-emeso unu mmeso dị ka nna ọbụla hụrụ ụmụ ya nʼanya si emeso ha mmeso. Nwata ọbụla adịghị nke nna ya na-adịghị abara mba.  
\v 8 Ya mere ọ bụrụ na a dịghị abara unu mba dịka esi bara ndị ọzọ, unu abụghị ụmụ kama unu bụ ndị amụtara nʼịkwa iko.  
\v 9 Dịka ịma atụ, ndị bụ nna anyị site nʼanụ ahụ na-apịa anyị ụtarị mgbe ọbụla anyị nupuru isi. Ma nke a adịghị egbochi anyị ịsọpụrụ ha. O kwesikwaghị ka anyị rubere Nna nke mmụọ isi karịa ma dịkwa ndụ? Anyị mee nke a, anyị ga-adị ndụ.  
\v 10 Ha na-azụ anyị nwa oge nta dị ka ha si tụpụta nʼuche ha. Ma ọ na-azụ anyị nʼihi ọdịmma anyị. Ọ na-achọ ka anyị keta oke nʼịdị nsọ ya.  
\v 11 Mgbe ọbụla a na-ezi anyị ihe site nʼinye anyị ahụhụ, ọ na-abụrụ anyị ihe mwute nʼoge ahụ, ọ bụghịkwa ihe ọṅụ. Ma e mesịa, ọ na-eweta udo na ndụ ezi omume nye ndụ ahụ azụrụ nʼime ya. 
\p  
\v 12 Ya mere, setịpụ aka gị ahụ ike gwụrụ. Guzosie ike nʼụkwụ gị ahụ na-ama jijiji.  
\v 13 Debenụ ụkwụ unu nʼụzọ ziri ezi,\f + \fr 12:13 \ft \xt Ilu 4:26\f* ka ụkwụ na-adịghị ike ghara ịda ngwụrọ, kama ka o nwe ọgwụgwọ. 
\s1 Ndụmọdụ na ịdọ aka na ntị 
\p  
\v 14 Gbalịsie ike mee ka gị na mmadụ niile biri nʼudo ya na ndụ dị nsọ, e wepụ ya, o nweghị onye pụrụ ịhụ Onyenwe anyị.  
\v 15 Hụkwanụ na o nweghị onye ga-ahapụ inweta amara Chineke, na o nwekwaghị onye ga-epupụta dịka mgbọrọgwụ ilu weta nsogbu a ga-esi nʼime ya merụọ ọtụtụ mmadụ.  
\v 16 Hụnụ na o nweghị onye na-ebi ndụ ruru unyi maọbụ onye nke na-enweghị nsọpụrụ dịka Ịsọ, onye nke rere ọnọdụ ọmụmụ ya nʼihi otu efere nri.  
\v 17 Dịka unu maara, o mechara chọọ ka o keta ngọzị ahụ, ma a jụrụ ya nʼihi na o nweghị ohere nchegharị. Ọ bụ ezie na o jiri anya mmiri chọsie ya ike. 
\s1 Ugwu nke Ụjọ na Ugwu nke Ọnụ 
\p  
\v 18 Unu abịarughị nʼugwu nke a pụrụ ịmetụ aka, nke na-ere ọkụ, na ọchịchịrị na itiri na oke ifufe,  
\v 19 na ụda opi ike, maọbụ olu na-ekwu okwu, nke ndị nụrụ ya rịọrọ ka ọ kwụsị ịgwa ha.  
\v 20 Nʼihi na ha enweghị ike ịnagide ihe e nyere nʼiwu, “A sịkwarị na anụmanụ ọbụla emetụ ugwu ahụ ahụ, a ga-eji nkume tugbuo ya.”\f + \fr 12:20 \ft \xt Ọpụ 19:12,13\f* 
\v 21 Nʼezie, ihe ahụ anya hụrụ dị oke egwu na Mosis sịrị, “Ana m ama jijiji nʼihi ụjọ.”\f + \fr 12:21 \ft \xt Dit 9:19\f* 
\p  
\v 22 Ma unu abịaruola nʼugwu Zayọn, bụ obodo Chineke dị ndụ, Jerusalem nke eluigwe ahụ. Unu abịakwutela puku kwụrụ puku ndị mmụọ ozi a na-apụghị ịgụta ọnụ zukọrọ nʼọṅụ.  
\v 23 Unu abịala nʼụlọ nzukọ nke onye ahụ ebu ụzọ mụpụta bụ ndị e dere aha ha nʼeluigwe. Unu abịakwutela Chineke, onye ga-ekpe mmadụ niile ikpe, unu abịakwutela mmụọ ndị ezi omume e mere ka ha bụrụ ndị zuruoke.  
\v 24 Unu abịakwutela Jisọs onye ogbugbo nke ọgbụgba ndụ ọhụrụ, bịakwutekwa ọbara e fesara nke na-ekwu okwu dị mma karịa nke ọbara Ebel kwuru. 
\p  
\v 25 Gbalịsienụ ike ihu na unu ajụghị onye ahụ na-ekwu okwu. Nʼihi na ọ bụrụ na ha agbanarịghị ya, bụ onye ahụ dọrọ ha aka na ntị nʼelu ụwa, anyị agaghị agbanarị onye ahụ si nʼeluigwe na-adọ anyị aka na ntị.  
\v 26 Nʼoge ahụ, olu ya mere ka ụwa ma jijiji, ma ugbu a, ọ kwela nkwa, sị, “Otu mgbe ọzọ fọdụrụ, ọ bụghị naanị ụwa ka m ga-eme ka ọ maa jijiji kama aga m emekwa ka eluigwe maa jijiji.”\f + \fr 12:26 \ft \xt Heg 2:6\f* 
\v 27 Okwu a bụ, “Otu mgbe ọzọ fọdụrụ,” na-egosi mwepụ nke ihe na-ama jijiji dịka ihe e kere eke, iji hụ na nke na-anaghị ama jijiji ga-adị. 
\p  
\v 28 Ya mere, ebe anyị na-anata alaeze nke na-apụghị ịgbanwe, ka anyị jiri obi ekele, egwu na nsọpụrụ fee Chineke ofufe nʼụzọ ọ ga-anabata.  
\v 29 Nʼihi na Chineke anyị bụ ọkụ na-erepịa erepịa.\f + \fr 12:29 \ft \xt Dit 4:24\f* 
\c 13  
\s1 Ihe ga-atọ Chineke ụtọ 
\p  
\v 1 Ka ịhụnanya unu nwere nʼetiti unu na-adịgide.  
\v 2 Unu echefula ịnabata ndị ọbịa, nʼihi na ụfọdụ ndị mere nke a lekọtara ndị mmụọ ozi ma ha amataghị.  
\v 3 Chetanụ ndị nọ nʼụlọ mkpọrọ dị ka a ga-asị na unu so ha nọdụ nʼụlọ mkpọrọ. Chetakwanụ ndị a na-ata ahụhụ, dịka a ga-asị na unu onwe unu so ha na-ahụ ahụhụ nʼahụ unu. 
\p  
\v 4 Ka ọlụlụ dị na nwunye bụrụ ihe onye ọbụla na-akwanyere ugwu, ka ihe ndina unu bụrụkwa nke a na-emerụghị emerụ. Nʼihi na Chineke ga-ekpe ndị na-akwa iko na ndị ụrụ ikpe.  
\v 5 Debenụ ndụ unu pụọ nʼịhụnanya nke ego, ka afọ ju unu nʼihe unu nwere, nʼihi na o kwuola, 
\q1 “Agaghị m ahapụ gị. 
\q2 O nwekwaghị mgbe m ga-eji gbakụta gị azụ.”\f + \fr 13:5 \ft \xt Dit 31:6\f* 
\m  
\v 6 Ya mere anyị pụrụ iji obi ike na-atụghị egwu kwuo, 
\q1 “Onyenwe anyị bụ onye na-enyere m aka. Agaghị m atụ egwu. 
\q2 Gịnị ka mmadụ pụrụ ime m?”\f + \fr 13:6 \ft \xt Abụ 118:6,7\f* 
\p  
\v 7 Chetanụ ndịisi unu, ndị gwara unu okwu Chineke. Tuleenụ otu ndụ siri dị, na-eṅomikwanụ okwukwe ha.  
\v 8 Otu Jisọs Kraịst dị ụnyaahụ, ka ọ dị taa, otu a ka ọ ga-adịgidekwa ruo mgbe ebighị ebi. 
\p  
\v 9 Unu ekwela ka e jiri ozizi ọhụrụ nke dịkwa iche duhie unu. Nʼihi na ọ bụ ihe dị mma ka e were amara mee ka obi sie ike, ọ bụghị site nʼidebe iwu banyere nri nke na-enweghị uru ọ bara ndị na-edebe ya.  
\v 10 Anyị nwere ebe ịchụ aja, ebe ndị niile na-eje ozi ha nʼụlọ ikwu a enweghị ike iri aja a chụrụ nʼelu ya. 
\p  
\v 11 Onyeisi nchụaja na-ewebata ọbara ụmụ anụ ndị ahụ nʼEbe Kachasị Nsọ dịka aja maka mmehie, ma a na-erepịa anụ ahụ ha ọkụ na mpụga ụlọ ikwu.  
\v 12 Nʼotu aka ahụ, Jisọs nʼonwe ya tara ahụhụ na mpụga ọnụ ụzọ ama obodo ka o jiri ọbara ya mee ka ndị nke ya dị nsọ.  
\v 13 Ya mere, ka anyị gakwuru ya nʼazụ ụlọ ikwu soro ya die mkparị o diri.  
\v 14 Nʼihi na ụwa abụghị ụlọ anyị, ma anyị na-ele anya obodo nke gaje ịbịa. 
\p  
\v 15 Site na ya, ka anyị na-achụrụ Chineke aja otuto mgbe niile, nke bụ mkpụrụ egbugbere ọnụ nke na-ekwupụta aha ya.  
\v 16 Unu echefula ime ihe ọma, meekwanụ ka ndị ọzọ soro unu kekọọ ihe unu nwere. Nke a bụ ụdị aja na-atọ Chineke ụtọ. 
\p  
\v 17 Ka unu na-ekwenyere ndị ndu unu, dokwaanụ onwe unu nʼokpuru ha. Nʼihi na ọrụ ha bụ ịhụ maka mkpụrụobi unu dịka ndị ga-aza azịza. Meenụ nke a ka ha were ọṅụ na-eje ozi ha, ma ọ bụghị site nʼobi mwute nʼihi na nke a agaghị abara unu uru. 
\p  
\v 18 Na-ekperenụ anyị ekpere, nʼihi na o doro anyị anya na anyị nwere akọnuche dị ọcha na-achọkwa ibi ndụ nwere ugwu nʼụzọ niile.  
\v 19 Ana m arịọsị unu ya ike, ka unu mee nke a, ka m nwee ike ịlọghachikwute unu ọsịịsọ. 
\s1 Ekele na ekpere ikpeazụ 
\p  
\v 20 Ugbu a ka Chineke nke udo, onye ahụ sitere nʼọbara ọgbụgba ndụ ebighị ebi ahụ kpọghachite Onyenwe anyị Jisọs, Onye ọzụzụ atụrụ ukwuu ahụ, site nʼọnwụ,  
\v 21 mee ka unu zuo oke nʼezi ihe ọma niile ọbụla, nke ga-enyere unu aka ime ihe ọ na-achọ. Ka ọ rụpụta nʼetiti anyị ihe ndị ahụ niile na-atọ ya ụtọ site na Jisọs Kraịst, onye otuto niile dịrị ruo mgbe niile ebighị ebi. Amen. 
\b  
\b  
\p  
\v 22 Ụmụnna m, arịọọ m unu, ka unu were ntachiobi nụrụ okwu agbamume m gwara unu nʼime akwụkwọ a na-etoghị ogologo. 
\b  
\p  
\v 23 Ana m eme ka unu mata na nwanna anyị Timoti esitela nʼụlọ mkpọrọ pụta. Mụ na ya ga-esoro bịa leta unu ma ọ bụrụ na ọ bịa nʼebe a na mgbe na-adịghị anya. 
\b  
\p  
\v 24 Keleerenụ m ndịisi unu niile na ndị nsọ niile. 
\p Ndị si Itali na-ezitere unu ekele ha. 
\b  
\p  
\v 25 Ka amara dịnyere unu niile.