\v 5 \w In|strong="H5020"\w* addition, \w the|strong="H4481"\w* \w gold|strong="H1722"\w* \w and|strong="H1722"\w* \w silver|strong="H3702"\w* items \w of|strong="H4481"\w* God's \w Temple|strong="H1005"\w*, \w which|strong="H1768"\w* \w Nebuchadnezzar|strong="H5020"\w* \w took|strong="H5312"\w* \w from|strong="H4481"\w* \w the|strong="H4481"\w* \w Temple|strong="H1005"\w* \w in|strong="H5020"\w* \w Jerusalem|strong="H3390"\w* \w and|strong="H1722"\w* \w brought|strong="H2987"\w* \w to|strong="H1946"\w* Babylon, must \w also|strong="H4481"\w* \w be|strong="H1005"\w* \w returned|strong="H8421"\w* \w to|strong="H1946"\w* \w the|strong="H4481"\w* \w Temple|strong="H1005"\w* \w in|strong="H5020"\w* \w Jerusalem|strong="H3390"\w* \w and|strong="H1722"\w* placed \w there|strong="H1768"\w*.
\p 
\v 6 \w These|strong="H4481"\w* \w are|strong="H1768"\w* \w my|strong="H4481"\w* instructions \w to|strong="H4481"\w* \w you|strong="H1768"\w*, \w Tattenai|strong="H8674"\w*, \w governor|strong="H6347"\w* \w of|strong="H4481"\w* \w the|strong="H4481"\w* province west \w of|strong="H4481"\w* \w the|strong="H4481"\w* Euphrates, \w Shethar-bozenai|strong="H8370"\w*, \w and|strong="H1934"\w* \w your|strong="H1768"\w* fellow officials, \w and|strong="H1934"\w* officials \w of|strong="H4481"\w* \w the|strong="H4481"\w* province: Stay \w far|strong="H7352"\w* \w away|strong="H7352"\w* \w from|strong="H4481"\w* \w there|strong="H8536"\w*!
