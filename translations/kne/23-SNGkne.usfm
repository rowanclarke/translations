\s1 Din Kantan Di Babai  
\sr (2:8-13)  
\q1
\v 8 Madngek din laylaydek ay lalaki.  
\q2 Doy managtagtag sin dontog ay omali.   
\q1
\v 9 Kaman bomaro ay ogsa.  
\q2 Sin dingding di beey mi, pinmipika  
\q3 ay mantintining sin tawa.   
\q1
\v 10 Kananan sak-en, “Bomangon ka.  
\q2 Napintas ka, laylaydek sik-a.  
\q3 Omali ka ta mankoyog ta.   
\q1
\v 11 Enggay nalabas di timpon di teg-in,  
\q2 nakdeng di pinag-oodan.   
\q1
\v 12 Enggay ginmabay din sabsabong isnan daga,  
\q2 et dinomteng di pinagkakanta.   
\q1
\v 13 Din lames di igos yan enggay naom da,  
\q2 din manbongbonga ay obas yan mansengseng-ew da.  
\q1 Napintas ay laylaydek, omali ka,  
\q2 omali ka ta mankoyog ta.”  
\v 14   
\v 15   
\v 16   
\v 17    
