\v 32 Entonces \w Jeremías|strong="H3414"\w* \w tomó|strong="H3947"\w* \w otro|strong="H5750"\w* \w rollo|strong="H4039"\w* \w y|strong="H5921"\w* \w lo|strong="H1697"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* Baruc, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Nerías, \w el|strong="H5921"\w* \w escriba|strong="H5608"\w*, \w el|strong="H5921"\w* cual \w escribió|strong="H3789"\w* \w en|strong="H5921"\w* \w él|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* \w Jeremías|strong="H3414"\w* \w todas|strong="H3605"\w* \w las|strong="H1992"\w* \w Palabras|strong="H1697"\w* \w del|strong="H5921"\w* \w rollo|strong="H4039"\w* \w que|strong="H5921"\w* \w Joacim|strong="H3079"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, consumió \w en|strong="H5921"\w* \w el|strong="H5921"\w* fuego. \w Además|strong="H5921"\w* \w añadió|strong="H3254"\w* \w muchas|strong="H7227"\w* otras \w Palabras|strong="H1697"\w* \w semejantes|strong="H1992"\w*.   
\c 37  
\s1 El profeta Jeremías en la mazmorra  
\p
\v 1 \w En|strong="H8478"\w* \w lugar|strong="H8478"\w* \w de|strong="H8478"\w* \w Conías|strong="H3659"\w*, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* \w Joacim|strong="H3079"\w*, \w reinó|strong="H4427"\w* Sedequías, \w hijo|strong="H1121"\w* \w de|strong="H8478"\w* \w Josías|strong="H2977"\w*, \w al|strong="H4428"\w* cual \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H8478"\w* Babilonia, constituyó \w como|strong="H8478"\w* \w rey|strong="H4428"\w* \w en|strong="H8478"\w* la tierra \w de|strong="H8478"\w* \w Judá|strong="H3063"\w*.  
\v 2 Pero \w ni|strong="H3808"\w* \w él|strong="H1931"\w*, \w ni|strong="H3808"\w* \w sus|strong="H1931"\w* esclavos, \w ni|strong="H3808"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* \w la|strong="H1931"\w* tierra \w escucharon|strong="H8085"\w* las \w Palabras|strong="H1697"\w* \w que|strong="H1931"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w por|strong="H1697"\w* \w medio|strong="H3027"\w* del \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w*.   
