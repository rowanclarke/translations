\id EST - Biblica® Open Kurdi Sorani Standard Version
\h ئەستێر
\toc1 ئەستێر
\toc2 ئەستێر
\toc3 ئەستێر
\mt1 ئەستێر
\c 1
\s1 لابردنی ڤەشتیی شاژن
\p 
\v 1 ئەم ڕووداوانە لە سەردەمی پاشایەتی ئەحەشوێرۆش بوو، ئەو ئەحەشوێرۆشەی کە لە هیندستانەوە هەتا کوش\f + \fr 1:1 \ft هەرێمێک بوو لە سەرووی ڕووباری نیل.‏\f* فەرمانڕەوایەتی سەد و بیست و حەوت هەرێمی دەکرد.
\v 2 لەو کاتەدا ئەحەشوێرۆشی پاشا لەسەر تەختی پاشایەتییەکەی دادەنیشت کە لە قەڵای شوش بوو.
\v 3 لە ساڵی سێیەمی پاشایەتییەکەی، خوانێکی سازکرد بۆ هەموو سەرکردە و کاربەدەستەکانی. سەرکردەکانی سوپای فارس و ماد و میر و فەرمانڕەوای هەرێمەکان تێیدا ئامادە بوون.
\p 
\v 4 ماوەی سەد و هەشتا ڕۆژ پاشا دەوڵەمەندیی و بێ هاوتایی پاشایەتییەکەی و شکۆ و مەزنیی خۆی نیشان دا.
\v 5 پاش تێپەڕینی ئەو ماوەیە، پاشا بۆ ماوەی حەوت ڕۆژ خوانێکی بۆ هەموو چین و توێژێکی خەڵک سازکرد، ئەوانەی لە قەڵای شوش دەژیان، لە باخچەی داخراوی کۆشکی پاشا.
\v 6 گۆڕەپانەکە بە پەردەی سپی و مۆری کەتان ڕازێنرابووەوە، بە گوریسی کەتانی سپی و گوریسی قوماشی ئەرخەوانی لەناو بازنەی زیو هەڵواسرابوو، لەسەر کۆڵەکەی مەڕمەڕ. سەکۆیەکان لە زێڕ و زیو دروستکرابوون، زەوییەکە بە بەردی حەلان و مەڕمەڕ و دوڕ و بەردی گرانبەها شۆستەی بۆ دروستکرابوو.
\v 7 خواردنەوەش بە جامی زێڕینی جۆراوجۆر پێشکەش دەکرا، شەرابی شاهانەش بەقەد بەخشندەیی پاشا زۆر بوو.
\v 8 پاشا فەرمانی بە لێپرسراوانی کۆشک کرد کەس گلەیی لە خواردنەوە نەبێت، هەرکەسە بەگوێرەی ویستی خۆی بێت.
\p 
\v 9 هەروەها ڤەشتیی شاژنیش لە کۆشکی شاهانەی ئەحەشوێرۆشی پاشا خوانێکی بۆ ئافرەتان سازکرد.
\p 
\v 10 لە ڕۆژی حەوتەم کاتێک ئەحەشوێرۆشی پاشا بە شەراب مەست بوو، فەرمانی کرد بەو حەوت کاربەدەستەی\f + \fr 1:10 \ft کاربەدەستێکی تایبەت بووە و خەسێنراوە.‏\f* کە خزمەتیان دەکرد، واتا مێهومان و بیزتا و حەرڤۆنا و بیگتا و ئەڤەگتا و زێتەر و کەرکەس،
\v 11 کە ڤەشتیی شاژن بە تاجی شاهانەکەوە بهێنن بۆ بەردەم پاشا، بۆ ئەوەی جوانییەکەی پیشانی گەل و سەرکردەکان بدرێت، چونکە ڕوخساری جوان بوو.
\v 12 بەڵام کاتێک کاربەدەستەکان فەرمانەکەی پاشایان پێ ڕاگەیاند، ڤەشتیی شاژن ڕازی نەبوو بێت. لەبەر ئەوە پاشا زۆر ڕقی هەستا و لە تووڕەیی خۆیدا گڕی گرت.
\p 
\v 13 نەریتی پاشا وا بوو ڕاوێژ بە شارەزایانی یاسا و دادوەری بکات. ئیتر پاشا پرسی بەو دانایانە کرد کە شارەزای ڕۆژگارن،
\v 14 ئەوانەی لێی نزیک بوون ئەمانە بوون: کەرشەنا، شیتار، ئەدماتا، تەرشیش، مەرەس، مەرسەنا، مەموخان، کە حەوت سەرکردەی فارس و مادی بوون و هەمیشە چاویان بە پاشا دەکەوت، بەرزترین پلە و پایەیان هەبوو لە پاشایەتییەکەدا.
\p 
\v 15 پاشا پرسیاری کرد: «بەپێی یاسا چی لە شاژنە ڤەشتی بکرێت؟ لەبەر ئەوەی گوێڕایەڵی ئەو فەرمانەی ئەحەشوێرۆشی پاشای نەبوو کە کاربەدەستەکان پێیان ڕاگەیاند.»
\p 
\v 16 مەموخان لەبەردەم پاشا و سەرکردەکان گوتی: «شاژنە ڤەشتی بە تەنها هەڵەی دەرهەق بە پاشا نەکردووە، بەڵکو دەرهەق بە هەموو سەرکردەکان و هەموو ئەو گەلانەی کە لە هەرێمەکانی ئەحەشوێرۆش پاشادان،
\v 17 چونکە هەواڵی شاژن بە هەموو ژنەکان دەگاتەوە و بەو شێوەیە بێزیان لە مێردەکانیان دەبێتەوە، دەگوترێت: ”ئەحەشوێرۆشی پاشا فەرمانی دا شاژنە ڤەشتی بهێننە بەردەمی، کەچی ئەو نەهاتووە.“
\v 18 هەروەها هەر ئەمڕۆ خانمەکانی فارس و مادی کە هەواڵی شاژنیان پێ گەیشتووەتەوە هەمان شت بە هەموو سەرکردەکانی پاشا دەڵێن، بەمەش بێزلێبوونەوە و تووڕەیی بڵاو دەبێتەوە.
\p 
\v 19 «لەبەر ئەوە ئەگەر پاشا پێی خۆشە، با بڕیارێکی شاهانە لەلای خۆیەوە دەربکات و بڕیارەکە لە یاساکانی فارس و مادی بنووسرێت بۆ ئەوەی دەستکاری نەکرێت، بەوەی کە نابێت چیتر ڤەشتی بێتە بەردەم ئەحەشوێرۆش پاشا. پاشاش پلەی شاژنیێتی بە یەکێکی چاکتر لەو بدات.
\v 20 بەو شێوەیە فەرمانەکەی پاشا لەناو هەموو شانشینە مەزنەکە ڕادەگەیەنرێت، هەموو ژنانیش بە ڕێزەوە هەڵسوکەوت لەگەڵ مێردەکانیان دەکەن، لە گەورەیانەوە هەتا بچووکیان.»
\p 
\v 21 پاشا و سەرکردەکان ئەو قسەیەیان پێ باش بوو، پاشا بەپێی قسەکەی مەموخانی کرد.
\v 22 نامەی بۆ هەموو هەرێمەکان و هەموو گەلەکانی پاشایەتییەکەی نارد، هەریەکە و بە زمان و ڕێنووسی خۆیان و ڕایگەیاند کە دەبێت هەموو پیاوێک گەورەی ماڵەکەی خۆی بێت و بە زمانی نەتەوەکەی خۆی ئەم بڕیارە ڕابگەیەنێت.
\c 2
\s1 هەڵبژاردنی ئەستێر وەک شاژن
\p 
\v 1 پاش ئەوەی تووڕەیی ئەحەشوێرۆشی پاشا دامرکایەوە، پاشا ڤەشتی و ڕەفتارەکەی و ئەو بڕیارەی کە لە دژی دەریکرد بەبیری هاتەوە.
\v 2 ئینجا ئەوانەی خزمەتی پاشایان دەکرد پێشنیاریان کرد: «با بگەڕێن بۆ کچانی پاکیزە و ڕوخسار جوان بۆ پاشا،
\v 3 با پاشا بریکار دابنێت لەناو هەموو هەرێمەکانی شانشینەکەیدا تاکو هەموو کچە پاکیزە و جوانەکان لە حەرەمسەرای قەڵای شوش کۆبکەنەوە. با لەژێر سەرپەرشتی هێگەیدا بن، کە کاربەدەستی\f + \fr 2:3 \ft کاربەدەستێکی تایبەت بووە و خەسێنراوە.‏\f* پاشا و بەرپرسی حەرەمسەراکەیە، هەروەها با بۆنوبەرامیان پێ بدرێت.
\v 4 ئینجا ئەو کچەش کە پاشا پەسەندی دەکات، با ببێتە شاژن و شوێنی ڤەشتی بگرێتەوە.» پاشا ئەو قسەیەی پێ باش بوو، کاری پێکرد.
\p 
\v 5 لەو کاتە لەناو قەڵای شوش پیاوێکی جولەکە هەبوو لە هۆزی بنیامین بوو، ناوی مۆردەخای کوڕی یائیری کوڕی شیمعی کوڕی قیش بوو.
\v 6 یەکێک بوو لەو ڕاپێچکراوانەی نەبوخودنەسری پاشای بابل لە ئۆرشەلیمەوە ڕاپێچی کردبوون، لەنێو ئەو ڕاپێچکراوانەی یەهۆیاکینی پاشای یەهودایان لەگەڵ بوو.
\v 7 مۆردەخای ئامۆزایەکی هەبوو بە ناوی هەدەسا، خۆی پەروەردەی کردبوو، چونکە نە باوکی هەبوو نە دایک. ئەم کچە بە ئەستێر ناسراوبوو، کچێکی نازدار و ڕوخسار جوان بوو، پاش مردنی دایک و باوکی مۆردەخای کردییە کچی خۆی.
\p 
\v 8 بە بیستنی فەرمانەکەی پاشا و یاساکەی بۆ کۆکردنەوەی کچانی زۆر لە قەڵای شوش و سپاردنیان بە دەستی هێگەی، ئەستێریش بردرایە کۆشکی پاشا و بە هێگەیی بەرپرسی حەرەمسەرا سپێردرا.
\v 9 کچە لەبەرچاوی هێگەی پەسەند بوو و بە دڵی بوو. لەبەر ئەوە دەستبەجێ بۆن و کەلوپەلی جوانکاری و خواردنی تایبەتی پێدا. هەروەها حەوت خزمەتکاری هەڵبژێردراوی لە کۆشکی پاشا پێدا، ئینجا ئەو و خزمەتکارەکانی بۆ باشترین شوێنی حەرەمسەرا گواستەوە.
\p 
\v 10 ئەستێر هیچی لەبارەی ڕەگەز و ڕەچەڵەکی ئاشکرا نەکرد، چونکە مۆردەخای ڕایسپاردبوو کە ئەوە نەکات.
\v 11 مۆردەخای هەموو ڕۆژێک لەبەردەم حەوشەی حەرەمسەرا دەهات و دەچوو، بۆ ئەوەی بزانێت ئەستێر چۆنە و ئاگاداربێت لەوەی چی بەسەردێت.
\p 
\v 12 بەگوێرەی یاسای پەیڕەوکراو بۆ ئافرەتان هەر کچێک ساڵێکی تەواوی لە ئاراییشت و ئامادەکاری بەسەردەبرد: شەش مانگ بە زەیتی موڕ، شەش مانگیش بە بۆن و کەرەستەی دیکەی جوانکاری. ئینجا لەدوای ئەوە نۆرەی دەهات بچێتە لای ئەحەشوێرۆشی پاشا.
\v 13 بەم شێوەیە بۆ لای پاشا دەچوو، هەرچی دەویست پێی دەدرا، بۆ ئەوەی لە حەرەمسەراوە لەگەڵ خۆی بیباتە کۆشکی پاشا.
\v 14 ئێوارە دەچووە ژوورەوە و بەیانی بۆ بەشێکی دیکەی حەرەمسەرا دەگەڕایەوە، بۆ ژێر سەرپەرشتی شەعەشگەزی کاربەدەستی پاشا و بەرپرسی کەنیزەکان. جارێکی دیکە نەدەچووە ژوورەوە بۆ لای پاشا، تەنها ئەگەر پاشا پێی دڵخۆش بووایە و بە ناوی خۆیەوە بانگی بکردایە.
\p 
\v 15 کاتێک نۆرەی ئەستێر هات، کچی ئەبیحەیلی مامی مۆردەخای، ئەوەی مۆردەخای کردییە کچی خۆی، بۆ ئەوەی بچێتە ژوورەوە بۆ لای پاشا، هیچ شتێکی داوا نەکرد جگە لەوەی هێگەیی کاربەدەستی پاشا و بەرپرسی حەرەمسەرا پێشنیاری کردبوو. هەرکەسێکیش ئەستێری ببینیایە دەچووە دڵییەوە.
\v 16 ئەستێر لە مانگی دە بردرایە ژوورەوە بۆ لای ئەحەشوێرۆش پاشا لە کۆشکی شاهانە، لە مانگی تێڤێت، لە حەوتەمین ساڵی پاشایەتییەکەی.
\p 
\v 17 پاشا ئەستێری لە هەموو ژنەکان زیاتر خۆشویست، لە هەموو پاکیزەکانی دیکە زیاتر پەسەندی کرد و چووە دڵییەوە. تاجی شاهانەی لەسەر سەری دانا و لە شوێنی ڤەشتی کردییە شاژن.
\v 18 ئینجا پاشا خوانێکی گەورەی بۆ هەموو سەرکردە و خزمەتکارەکانی سازکرد وەک رێزگرتنێک لە ئەستێر، پشووی لە هەرێمەکاندا ڕاگەیاند و بەقەد بەخشندەیی پاشا دیاری بەخشرا.
\s1 ئاشکراکردنی پیلانێک لەلایەن مۆردەخای
\p 
\v 19 کاتێک پاکیزەکان بۆ جاری دووەم کۆکرانەوە، مۆردەخای لەلای دەروازەی پاشا دانیشتبوو.
\v 20 ئەستێریش هەروەک مۆردەخای ڕایسپاردبوو هیچ شتێکی لەبارەی ڕەگەز و ڕەچەڵەکی ئاشکرا نەکردبوو، چونکە ئەستێر هەروەک ئەو ڕۆژانەی مۆردەخای بەخێوی دەکرد بە قسەی ئەو دەجوڵایەوە.
\p 
\v 21 لەو ڕۆژانەدا لە کاتێکدا مۆردەخای لە دەروازەی پاشا دانیشتبوو، بیگتانا و تەرەش کە دوو ئەفسەری پاشا بوون لەو ئەفسەرانەی پاسەوانیێتی دەروازەکەیان دەکرد، تووڕە بوون و پیلانیان گێڕا کە دەستیان بۆ ئەحەشوێرۆش پاشا درێژ بکەن.
\v 22 بەڵام مۆردەخای بەو کارەی زانی و بە شاژنە ئەستێری گەیاند، ئەویش بە ناوی مۆردەخایەوە بە پاشای گوت.
\v 23 کاتێک بابەتەکە لێی کۆڵڕایەوە و زانییان کە ڕاستە، هەردووکیان لە دار دران. ئەو ڕووداوەش لەبەردەم پاشا لە پەڕتووکی کاروباری ڕۆژانە تۆمار کرا.
\c 3
\s1 پیلانی هامان بۆ لەناوبردنی جولەکەکان
\p 
\v 1 پاش ئەم ڕووداوانە، ئەحەشوێرۆشی پاشا هامانی کوڕی هەمەداسای ئەگاگی\f + \fr 3:1 \ft ئەگاگ، پاشای عەمالێق، لە سەردەمی پێغەمبەر موسا دوژمنی جولەکە بووە. بڕوانە \xt دەرچوون 17‏:14 و یەکەم ساموئێل 15‏:20‏\xt*\ft ‏.‏\f* گەورە کرد و بەرزی کردەوە، پایەیەکی بەرزتری لە پایەی هەموو سەرکردەکانی دیکە پێ بەخشی کە لەگەڵین.
\v 2 هەموو کاربەدەستەکانی پاشا کە لەلای دەروازەی پاشاوەن بەپێی فەرمانی پاشا سەریان بۆ هامان دادەنەواند و کڕنۆشیان بۆ دەبرد، بەڵام مۆردەخای سەری بۆ دانەدەنەواند و کڕنۆشی بۆ نەدەبرد.
\p 
\v 3 لەبەر ئەوە خزمەتکارەکانی پاشا ئەوانەی لە دەروازەکەی پاشادا بوون بە مۆردەخایان گوت: «بۆچی سەرپێچی فەرمانی پاشا دەکەیت؟»
\v 4 ڕۆژ لەدوای ڕۆژ قسەیان لەگەڵ دەکرد، بەڵام ئەو هەر گوێی لێ نەدەگرتن. لەبەر ئەوە بە هامانیان گوت بۆ ئەوەی بزانن ئەو قسەیەی مۆردەخای خۆی ڕادەگرێت، چونکە پێی ڕاگەیاندبوون کە ئەو جولەکەیە.
\p 
\v 5 جا کە هامان بینی مۆردەخای سەری بۆ دانانەوێنێت و کڕنۆشی بۆ نابات، زۆر تووڕە بوو.
\v 6 بە تەنها کوشتنی مۆردەخای بەلاوە کەم بوو، چونکە زانی مۆردەخای لە چ نەتەوەیەکە. هامان بەدوای ئەوە دەگەڕا هەموو نەتەوەکەی مۆردەخای، بە واتا هەموو جولەکەکان، کە لە شانشینی ئەحەشوێرۆش بوون لەناویان ببات.
\p 
\v 7 لە مانگی یەک کە مانگی نیسانە، لە ساڵی دوازدەیەمینی ئەحەشوێرۆشی پاشا، لەبەردەم هامان تیروپشکیان دەکرد کە پێی دەگوترا \tl پور‏\tl*، بۆ هەڵبژاردنی ڕۆژ و مانگێک. تیروپشک کەوتە سەر مانگی دوازدە، واتا مانگی ئادار.
\p 
\v 8 ئینجا هامان بە ئەحەشوێرۆش پاشای گوت: «نەتەوەیەک هەیە لەنێو هەموو نەتەوەکانی هەرێمەکانی پاشایەتییەکە پەرتەوازەن و بە جیاواز دەژین. نەریتەکانیان لەگەڵ نەریتی هەموو نەتەوەکان جیاوازترە و یاساکانی پاشا جێبەجێ ناکەن. بۆ پاشا باش نییە لێیان بگەڕێت بە ئاسوودەیی دانیشن.
\v 9 ئەگەر پاشا پێی باشە با فەرمانێک بۆ لەناوبردنیان دەربکرێت، منیش دە هەزار تالنت\f + \fr 3:9 \ft دە هەزار تالنت: نزیکەی 345 تەن.‏\f* زیو دەدەمە دەست خەزنەدارانی پاشا بۆ گەنجینەی شاهانە.»
\p 
\v 10 ئینجا پاشا ئەو ئەنگوستیلەیەی لە دەستی خۆی داکەند کە مۆری شاهانەی پێوە بوو، دایە هامانی کوڕی هەمەداسای ئەگاگی دوژمنی جولەکەکان.
\v 11 پاشا بە هامانی گوت: «زیوەکە بۆ خۆت بێت، چیشت پێ باشە ئاوا لە نەتەوەکە بکە.»
\p 
\v 12 لە سێزدەی مانگی یەک خامەی نهێنییەکانی\f + \fr 3:12 \ft ڕازپۆش.‏\f* پاشا بانگ کران، هەموو ئەوەی هامان فەرمانی پێیدان نووسرایەوە بۆ میرەکانی پاشا و پارێزگارەکانی هەرێمە جیاوازەکان و سەرکردەکانی نەتەوە جیاکان، هەر هەرێمە و بە ڕێنووسی خۆی و هەر نەتەوەیە و بە زمانی خۆی. نامەکانیش بە ناوی ئەحەشوێرۆش پاشاوە نووسراون و بە ئەنگوستیلەکەی ئەویش مۆر کران.
\v 13 بە دەستی پەیامبەرەکانیشدا نامەکان بۆ هەموو هەرێمەکانی پاشا نێردران و تێیاندا فەرمانی دابوو کە لە یەک ڕۆژ، لە سێزدەی مانگی دوازدە، واتا لە مانگی ئادار هەموو جولەکەکان بە گەنج و پیر و ژن و منداڵەوە قڕ بکرێن و بکوژرێن و لەناو ببردرێن، کەلوپەلەکانیشیان بە تاڵان ببردرێن.
\v 14 وێنەی نووسراوەکەش وەک فەرمانێک درایە هەموو هەرێمەکان و لەناو هەموو نەتەوەکان بڵاوکرایەوە بۆ ئەوەی خۆیان بۆ ئەم ڕۆژە ئامادە بکەن.
\p 
\v 15 هەروەک پاشا فەرمانی کرد پەیامبەرەکان بە پەلە ڕۆیشتن، هەروەها ئەو فەرمانە لە قەڵای شوشیش درا. پاشا و هامان بۆ خواردنەوە دانیشتن، بەڵام شاری شوش شڵەژا.
\c 4
\s1 مۆردەخای داوای یارمەتی لە ئەستێر دەکات
\p 
\v 1 پاش ئەوەی مۆردەخای هەموو ئەو کردەوانەی زانی کە کران، جلەکەی دادڕی و جلوبەرگی گوشی\f + \fr 4:1 \ft کاتی دەرکەوتنی نیشانەی کارەساتێک جلوبەرگی لە گوش دروستکردووە و لەبەری کردووە.‏\f* پۆشی و خۆڵەمێشی بەسەر خۆیدا کرد، چووە دەرەوە بۆ ناوەڕاستی شار و هاوارێکی گەورە و تاڵی کرد.
\v 2 بەڵام تەنها چووە بەردەم دەروازەی پاشا، چونکە ڕێگا بە کەس نەدەدرا بە پۆشینی جلوبەرگی گوشەوە بچێتە ناو دەروازەی پاشا.
\v 3 هەروەها هەر هەرێمێک فەرمانەکەی پاشا و یاساکەی پێ دەگەیشت، لەنێو جولەکەکان دەبووە شیوەنێکی گەورە و ڕۆژووگرتن، گریان و لاواندنەوە. زۆریان جلوبەرگی گوشیان دەپۆشی و لەناو خۆڵەمێش ڕادەکشان.
\p 
\v 4 کاتێک کەنیزەکانی ئەستێر و کاربەدەستەکانی چوونە ژوورەوە و باسی مۆردەخایان بۆی کرد، شاژن زۆر دڵتەنگ بوو. دەستە جلێکی نارد بۆ ئەوەی لە جیاتی جلوبەرگی گوش لەبەری بکرێت، بەڵام ئەو پەسەندی نەکرد.
\v 5 پاشان ئەستێر هەتاخی بانگکرد، کە یەکێک لە کاربەدەستەکانی پاشا بۆ خزمەتکردنی تەرخان کرابوو و فەرمانی پێ کرد بچێتە لای مۆردەخای، بزانێت ئەمە چییە و لەسەر چییە.
\p 
\v 6 ئیتر هەتاخ چووە دەرەوە بۆ لای مۆردەخای لە مەیدانی شارەکە، ئەوەی لەبەردەم دەروازەی پاشایە.
\v 7 مۆردەخای هەموو ئەو شتانەی پێ ڕاگەیاند کە بەسەری هاتبوو، هەروەها ئەو بڕە زیوەی کە هامان گوتبووی بۆ لەناوبردنی جولەکەکان بیداتە گەنجینەی پاشا.
\v 8 وێنەیەکیشی لەو فەرمانە نووسراوە دایێ کە لە شوشەوە بۆ لەناوبردنیان دەرکرابوو، بۆ ئەوەی پیشانی ئەستێری بدات و بابەتەکەی بۆ ڕوون بکاتەوە، هەروەها پێی گوت کە ڕێنمایی ئەستێر بکات تاکو بچێتە ژوورەوە بۆ لای پاشا و لە پێناوی نەتەوەکەی لێی بپاڕێتەوە و داوای بەزەیی لێ بکات.
\p 
\v 9 هەتاخ گەڕایەوە و قسەکانی مۆردەخای بە ئەستێر ڕاگەیاند.
\v 10 ئەستێریش هەتاخی ڕاسپاردەوە بە مۆردەخای بڵێت:
\v 11 «هەموو کاربەدەستەکانی پاشا و هەموو نەتەوەکانی هەرێمەکانی پاشا دەزانن، کە هەر پیاوێک یان هەر ژنێک بچێتە ژوورەوە بۆ لای پاشا بەبێ ئەوەی بانگ بکرێتە دیوانەکەی ناوەوە، یەک یاسای بەسەردا دەسەپێنرێت، ئەویش مردنە، تەنها ئەو کەسە نەبێت کە پاشا داردەستە زێڕینەکەی خۆی بۆ درێژ دەکات، ئەو کەسە دەژیێت. منیش سی ڕۆژە بانگ نەکراوم بۆ ئەوەی بچمە ژوورەوە بۆ لای پاشا.»
\p 
\v 12 کاتێک قسەکەی ئەستێریان بە مۆردەخای ڕاگەیاند،
\v 13 ئەویش ئەم وەڵامەی بۆ ناردەوە: «وا مەزانە کە تۆ لە ماڵی پاشادا بەدەر لە هەموو جولەکەکان دەرباز دەبیت،
\v 14 چونکە ئەگەر تۆ لەم کاتەدا بێدەنگ بیت، یارمەتی و دەربازبوون لە شوێنێکی دیکە بۆ جولەکەکان سەرهەڵدەدات، بەڵام خۆت و ماڵی باوکت لەناو دەبردرێن. هەروەها کێ دەزانێت، لەوانەیە بۆ کاتێکی وەک ئەمە بە پلەی پاشایەتی گەیشتوویت؟»
\p 
\v 15 ئینجا ئەستێر ئەم وەڵامەی بۆ مۆردەخای ناردەوە:
\v 16 «بڕۆ هەموو جولەکەکانی ناو شوش کۆبکەرەوە، لە پێناوی من ڕۆژوو بگرن. سێ شەو و سێ ڕۆژ هیچ مەخۆن و هیچ مەخۆنەوە. خۆم و کەنیزەکانم بە هەمان شێوە ڕۆژوو دەگرین. دوای ئەوە بە پێچەوانەی یاسا دەچمە ژوورەوە بۆ لای پاشا. ئەگەر لەناویش چووم، با لەناوبچم.»
\p 
\v 17 ئیتر مۆردەخای چوو هەموو ئەو شتانەی کرد کە ئەستێر ڕایسپاردبوو.
\c 5
\s1 سزادانی هامان
\p 
\v 1 لە سێیەمین ڕۆژ ئەستێر جلوبەرگی شاهانەی لەبەرکرد و لە دیوانەکەی ناوەوەی کۆشکی پاشا بەرامبەر دیوەخانی پاشا ڕاوەستا، پاشاش لە دیوەخانەکە لە بەرامبەر دەروازەکە لەسەر تەختەکەی دانیشتبوو.
\v 2 کاتێک پاشا ئەستێری شاژنی بینی لە دیوانەکەدا ڕاوەستاوە، دڵی پێی خۆشبوو و داردەستە زێڕینەکەی دەستی بۆ ئەستێر درێژکرد. ئەستێریش چووە پێشەوە و دەستی لەسەری داردەستەکە دا.
\p 
\v 3 ئینجا پاشا پێی گوت: «شاژنە ئەستێر، چیتە و داواکاریت چییە؟ هەتا داوای نیوەی شانشینەکەش بکەیت پێت دەدرێت.»
\p 
\v 4 ئەستێر گوتی: «ئەگەر پاشا پێی خۆشە، با ئەمڕۆ پاشا لەگەڵ هامان بێنە ئەو خوانەی کە بۆم ئامادە کردووی.»
\p 
\v 5 پاشاش گوتی: «بە پەلە هامان بهێنن بۆ ئەوەی داواکەی ئەستێر جێبەجێ بکات.»
\p ئینجا پاشا و هامان چوون بۆ ئەو خوانەی کە ئەستێر ئامادەی کردبوو.
\v 6 پاشا لە کاتی شەراب خواردنەوە بە ئەستێری گوت: «بابەتەکەت چییە؟ پێت دەدرێت. داواکارییەکەت چییە؟ تەنانەت داوای نیوەی شانشینەکەش بکەیت، پێت دەدرێت.»
\p 
\v 7 ئەستێر وەڵامی دایەوە و گوتی: «بابەتەکەم و داواکارییەکەم ئەمەیە:
\v 8 ئەگەر پاشا لێم ڕازی بێت و پێی خۆش بێت بابەتەکەم و داواکارییەکەم بۆ جێبەجێ بکات، با سبەینێ پاشا لەگەڵ هامان بێتە ئەو خوانەی کە بۆیان ئامادە دەکەم، ئەو کاتە وەڵامی پرسیارەکەی پاشا دەدەمەوە.»
\s1 ڕقی هامان لە مۆردەخای
\p 
\v 9 ئەو ڕۆژە هامان بە شادی و دڵخۆشییەوە چووە دەرەوە. بەڵام کاتێک هامان لە دەروازەی پاشا مۆردەخای بینی لەبەری هەڵنەستا و خۆی تێکنەدا، زۆر ڕقی لە مۆردەخای هەستا.
\v 10 بەڵام هامان خۆی گرت و گەڕایەوە ماڵەوە.
\p هامان دۆستەکانی و زەرەشی ژنی بانگکرد،
\v 11 شانازی بە زۆری دەوڵەمەندی و زۆری کوڕەکانی کرد، هەروەها چۆن پاشا ڕێزی لێی ناوە و پایەی بەرزکردووەتەوە لەسەر سەرکردە و کاربەدەستەکانی دیکەی.
\v 12 هەروەها هامان گوتی: «تەنانەت شاژنە ئەستێر جگە لە من کەسی دیکەی لەگەڵ پاشا بۆ ئەو خوانە داوەت نەکردووە کە ئامادەی کردووە، بۆ سبەینێ منیشی لەگەڵ پاشا داوەت کردووە.
\v 13 بەڵام ئەمانە هەموویان هیچ بەهایەکیان لەلای من نییە، هەر کاتێک مۆردەخای جولەکە دەبینم لە دەروازەی پاشادا دانیشتووە.»
\p 
\v 14 زەرەشی ژنی و هەموو دۆستەکانی پێیان گوت: «با دارێک بە بەرزی پەنجا باڵ ئامادە بکرێت، بەیانی بە پاشا بڵێ کە فەرمان بدات مۆردەخای لەو دارە بدرێت. پاشان بە خۆشییەوە لەگەڵ پاشا بڕۆ سەر خوانەکە.» هامان ئەو قسەیەی پێ باش بوو، فەرمانی دا دارەکە ئامادە بکرێت.
\c 6
\s1 ڕێزگرتن لە مۆردەخای
\p 
\v 1 ئەو شەوە پاشا خەوی زڕا. فەرمانی دا پەڕتووکی پوختەی مێژووی\f + \fr 6:1 \ft مەبەست لە تۆماری ڕووداوەکانی پاشایەتی خۆیەتی.‏\f* بۆ بهێنن و بۆی بخوێننەوە.
\v 2 بینرا ئەوەی تێدا نووسراوە کە مۆردەخای لەبارەی بیگتانا و تەرەشەوە ئاشکرای کردبوو، دوو لەو ئەفسەرانەی پاشا، کە پاسەوانی دەروازەکە بوون و ویستیان دەستیان بۆ ئەحەشوێرۆش پاشا درێژ بکەن.
\p 
\v 3 پاشا پرسیاری کرد: «چ ڕێز و گەورەییەک بەرامبەر بەمە بۆ مۆردەخای کراوە؟»
\p خزمەتکارەکانی پاشا ئەوانەی لەبەردەستی بوون گوتیان: «هیچی بۆ نەکراوە.»
\p 
\v 4 پاشا گوتی: «کێ لە دیوانەکەیە؟» لەو کاتەدا هامان هاتبووە ناو دیوانەکەی دەرەوەی کۆشکی پاشا، بۆ ئەوەی بە پاشا بڵێت مۆردەخای لەو دارە بدات کە بۆی ئامادە کردبوو.
\p 
\v 5 خزمەتکارەکانی پاشا وەڵامیان دایەوە: «وا هامان لە دیوانەکە ڕاوەستاوە.»
\p پاشاش فەرمانی دا: «با بێتە ژوورەوە.»
\p 
\v 6 کە هامان هاتە ژوورەوە، پاشا لێی پرسی: «چی بۆ پیاوێک بکرێت پاشا پێی خۆش بێت ڕێزی لێ بگرێت؟»
\p هامان لە دڵی خۆیدا گوتی: «لە من زیاتر کێ هەیە پاشا پێی خۆش بێت ڕێزی لێ بگرێت؟»
\v 7 ئیتر هامان وەڵامی پاشای دایەوە: «بۆ ئەو پیاوەی کە پاشا پێی خۆشە ڕێزی لێ بگرێت،
\v 8 با ئەو جلوبەرگە شاهانەیەی کە پاشا لەبەری دەکات و ئەو ئەسپەی کە پاشا سواری دەبێت، لەگەڵ ئەو تاجەی شاهانە کە لەسەر سەری ئەسپەکە دادەنرێت بهێنرێ.
\v 9 ئینجا با جلوبەرگەکە و ئەسپەکە بدرێنە پیاوێک لە میرانی سەرکردەی پاشا، بۆ ئەوەی لەبەری ئەو پیاوەی بکات کە پاشا پێی خۆشە ڕێزی لێ بگرێت، لە شەقامەکانی شار بە سواری ئەسپەکە بیگەڕێنن و لەبەردەمیەوە هاوار بکەن و بڵێن: ”ئاوا بۆ ئەو پیاوە دەکرێت کە پاشا پێی خۆش بێت ڕێزی لێ بگرێت!“»
\p 
\v 10 پاشا بە هامانی گوت: «بە پەلە بڕۆ هەروەک گوتت جلوبەرگ و ئەسپەکە ببە، هەموو ئەو شتانەی پێشنیارت کرد بۆ مۆردەخای جولەکە بیکە، ئەوەی لە دەروازەی پاشا دانیشتووە. هیچیان فەرامۆش مەکە لەوەی کە گوتت.»
\p 
\v 11 هامان جلوبەرگەکە و ئەسپەکەی برد. جلەکەی لەبەر مۆردەخای کرد و لە شەقامەکانی شار بە سواری ئەسپەکەی گەڕاندی، لەبەردەمی هاواری دەکرد و دەیگوت: «ئاوا بۆ ئەو پیاوە دەکرێت کە پاشا پێی خۆش بێت ڕێزی لێ بگرێت!»
\p 
\v 12 پاشان مۆردەخای گەڕایەوە بۆ دەروازەی پاشا. بەڵام هامان خێرا بە لاواندنەوە و سەرشۆڕییەوە گەڕایەوە ماڵەکەی.
\v 13 هامان هەموو ئەوەی بەسەری هات بۆ زەرەشی ژنی و بۆ دۆستەکانی گێڕایەوە.
\p ڕاوێژکارەکانی و زەرەشی ژنی پێیان گوت: «کەوتنی تۆ لەبەردەم مۆردەخای دەستی پێکرد. لەبەر ئەوەی ئەو لە ڕەچەڵەکی جولەکەیە، تۆ ناتوانیت لە دژی بووەستیتەوە، تۆ لەبەردەمی ئەو دەڕووخێیت!»
\v 14 لە کاتێکدا کە هێشتا قسەیان لەگەڵ دەکرد، کاربەدەستەکانی پاشا پەیدا بوون بۆ ئەوەی بە پەلە هامان ببەن بۆ ئەو خوانەی کە ئەستێر ئامادەی کردبوو.
\c 7
\s1 سزادانی هامان
\p 
\v 1 ئینجا پاشا و هامان چوونە داوەتەکەی ئەستێری شاژن.
\v 2 لە ڕۆژی دووەم کاتێک شەرابیان دەخواردەوە، دیسان پاشا پرسیاری لە ئەستێر کرد: «ئەی شاژن، چیت دەوێت؟ پێت دەدرێت. داواکارییەکەت چییە؟ تەنانەت داوای نیوەی شانشینەکەش بکەیت، پێت دەدرێت.»
\p 
\v 3 شاژنە ئەستێر وەڵامی دایەوە و گوتی: «ئەی پاشا، ئەگەر لێم ڕازی بیت، پاشا پێی خۆش بێت، ژیانم ڕزگار بکە. ئەوە بابەتەکەمە. نەتەوەکەم ڕزگار بکە. ئەمە داواکارییەکەمە،
\v 4 چونکە خۆم و نەتەوەکەم لەلایەن کەسێکەوە بۆ لەناوبردن و کوشتن و قڕکردن فرۆشراوین. ئەگەر ئێمە تەنها وەک کۆیلە و کەنیزە بفرۆشراینایە من دەنگم نەدەکرد، چونکە ئەمە نابێتە تەنگانەیەک پاشای پێ بێزار بکرێت.»
\p 
\v 5 ئینجا ئەحەشوێرۆشی پاشا لە شاژنە ئەستێری پرسی: «ئەو کەسە کێیە و لەکوێیە؟ چۆن بوێری ئەوەی هەیە کارێکی وا بکات؟»
\p 
\v 6 ئەستێر گوتی: «ئەوە ناحەزەکەمانە، دوژمنمانە، هامانی خراپەکار!»
\p هامان لەبەردەم پاشا و شاژن تۆقی.
\v 7 پاشا بە تووڕەییەوە دەستی لە شەراب خواردنەوەکە هەڵگرت و ڕووەو باخچەکەی کۆشک ڕۆیشت. هامانیش ڕاوەستا و بۆ ڕزگاربوونی ژیانی خۆی لە شاژنە ئەستێر پاڕایەوە، چونکە زانی کە پاشا بڕیاری داوە لە سێدارەی بدات.
\p 
\v 8 لەو کاتەی پاشا لە باخچەی کۆشکەوە گەڕایەوە هۆڵی خوانەکە، هامان خۆی بەسەر ئەو سەکۆیەدا دابوو کە ئەستێر لەسەری دادەنیشت.
\p پاشا گوتی: «ئایا لاساری بەرامبەر بە شاژنیش دەکات، لەنێو ماڵەکەم و لەگەڵیشمدایە؟»
\p هەرکە فەرمانەکە لە دەمی پاشا دەرچوو، دەم و چاوی هامانیان داپۆشی.
\v 9 ئینجا حەرڤۆنا، کە یەکێک بوو لەو کاربەدەستانەی خزمەتی پاشایان دەکرد، گوتی: «لە ماڵی هامان دارێک هەیە بەرزییەکەی پەنجا باڵە\f + \fr 7:9 \ft پەنجا باڵە: نزیکەی 23 مەتر.‏\f*، هامان بۆ مۆردەخای ئامادە کردووە، کە قسەیەکی چاکی گەیاندە پاشا.»
\p پاشا گوتی: «هامان لەو دارە بدەن!»
\v 10 بەو شێوەیە هامانیان لەو دارە دا کە بۆ مۆردەخای ئامادە کردبوو. پاشان تووڕەیی پاشا دامرکایەوە.
\c 8
\s1 فەرمانی پاشا سەبارەت بە جولەکەکان
\p 
\v 1 لەو ڕۆژە ئەحەشوێرۆشی پاشا سامانی هامانی دوژمنی جولەکەکانی دایە ئەستێری شاژن. مۆردەخای هاتە بەردەم پاشا، چونکە ئەستێر پێی گوتبوو کە خزمی ئەوە.
\v 2 هەروەها پاشا ئەنگوستیلەکەی لە دەستی خۆی داکەند کە لە هامانی سەندبووەوە و دایە مۆردەخای. ئەستێریش مۆردەخای کردە بریکاری سامانەکەی هامان.
\p 
\v 3 ئەستێر جارێکی دیکە لەگەڵ پاشا قسەی کرد. خۆی خستە بەر پێیەکانی و گریا و لێی پاڕایەوە بۆ ئەوەی پیلانەکەی هامانی ئەگاگی هەڵبوەشێنێتەوە کە لە دژی جولەکەکان دایڕشتبوو.
\v 4 ئینجا پاشا داردەستە زێڕینەکەی بۆ ئەستێر درێژکرد، ئەستێر هەستا و لەبەردەم پاشا ڕاوەستا.
\p 
\v 5 گوتی: «ئەی پاشا، ئەگەر تۆ ڕازی بیت، ئەگەر منت بە دڵە و دەبینیت کە داواکارییەکەم ڕەوایە، ئەگەر من لەلای تۆ پەسەندم، تکایە داوای نووسینی فەرمانێک بکە بۆ هەڵوەشاندنەوەی ئەو پیلانەی هامانی کوڕی هەمەداسای ئەگاگی دایڕشتبوو. ئەو نامەی نووسیبوو بۆ ئەوەی جولەکەکان لە هەموو هەرێمەکانی پاشا لەناوببردرێن.
\v 6 ئەوسا چۆن دەتوانم تەماشای ئەو کارەساتە بکەم کە تووشی نەتەوەکەم دەبێت؟ چۆن دەتوانم تەماشای لەناوچوونی ڕەگەزەکەم بکەم؟»
\p 
\v 7 ئەحەشوێرۆش پاشا وەڵامی شاژنە ئەستێر و مۆردەخای جولەکەی دایەوە: «لەبەر ئەوەی هامان دەستدرێژی کردە سەر جولەکە، سامانەکەی ئەوم دایە ئەستێر، لە داریان دا.
\v 8 ئێوەش ئەوەی پێتان باشە بە ناوی پاشاوە بۆ جولەکەکانی بنووسن، بە ئەنگوستیلەکەی پاشا مۆری بکەن، چونکە ئەو نووسینەی بە ناوی پاشاوە دەنووسرێت و بە ئەنگوستیلەکەی مۆر بکرێت هەڵناوەشێنرێتەوە.»
\p 
\v 9 لەو کاتە، لە بیست و سێی سێ، واتا مانگی سیڤان، خامەی نهێنییەکانی\f + \fr 8:9 \ft ڕازپۆشەکانی.‏\f* پاشا بانگ کران. هەموو ئەو شتانەی کە مۆردەخای فەرمانی پێ کردن بۆ جولەکە و میر و پارێزگار و سەرکردەکانی هەرێمەکان نووسییان، سەد و بیست و حەوت هەرێم بوون، لە هیندستانەوە هەتا کوش، بۆ هەر هەرێمێک بە زمان و ڕێنووسی خۆی، بۆ جولەکەکانیش بە زمان و ڕێنووسی خۆیان.
\v 10 مۆردەخای ئەو نامانەی بە ناوی ئەحەشوێرۆش پاشاوە نووسی و بە ئەنگوستیلەکەی پاشا مۆری کردن، بە پەیامبەرەکاندا ناردی، کە سواری ئەسپە تیژڕەوە ڕەسەنەکانی پاشا ببوون.
\p 
\v 11 ئەو فەرمانەی پاشا مافی ئەوەی بە جولەکەکانی هەموو شارێک دابوو کۆببنەوە بۆ ئەوەی بەرگری لە خۆیان بکەن و هەر هێزێکی چەکدار لە هەر نەتەوە و هەرێمێک بێت هێرشیان بکاتە سەر لەناوی ببەن، بیانکوژن و قڕیان بکەن، بە ژن و منداڵەکانیشیانەوە، ئەوەی هەشیانە تاڵانی بکەن.
\v 12 ئەو ڕۆژە لەناو هەموو هەرێمەکانی ئەحەشوێرۆشی پاشا دیاریکراوە، لە سێزدەی دوازدە، واتا لە مانگی ئادار.
\v 13 وێنەیەک لەو فەرمانە کە وەک یاسا دەرکرابوو لەنێو هەموو هەرێم و گەلەکان بڵاو کرایەوە، بۆ ئەوەی جولەکەکان ئامادە بن بۆ ئەو ڕۆژە تاکو تۆڵە لە دوژمنەکانیان بستێننەوە.
\p 
\v 14 پەیامبەرەکان هەروەک پاشا فەرمانی پێ کردبوون، بە سواری ئەسپی شاهانە بە پەلە و خێرا ڕۆیشتن. هەروەها فەرمانەکە لە قەڵای شوشیش دەرچوو.
\p 
\v 15 ئینجا مۆردەخای بە بەرگی شاهانەی مۆر و سپییەوە لەبەردەم پاشا هاتە دەرەوە، تاجێکی گەورەی زێڕین لەسەر ناوچەوانی بوو، کەوایەکی ئەرخەوانی لە کشمیر دروستکراویشی لەسەر شان بوو. شادی و خۆشی شاری شوشی گرتەوە.
\v 16 ڕووناکی بۆ جولەکەکان درەوشایەوە، پڕبوون لە خۆشی و شادی و هەستکردن بە ڕێز.
\v 17 جا لە هەر هەرێم و شارێک کە فەرمانەکەی پاشا و یاساکەیان پێ دەگەیشت، دەبووە شادی و خۆشی بۆ جولەکەکان، خوانیان دەڕازاندەوە و ئاهەنگیان دەگێڕا. زۆریش لە نەتەوەکانی دیکە بوونە جولەکە، چونکە زۆر لە جولەکە دەترسان.
\c 9
\s1 سەرکەوتنی جولەکەکان
\p 
\v 1 لە سێزدەی دوازدە، واتا لە مانگی ئادار، کاتی جێبەجێکردنی قسە و فەرمانەکەی پاشا هات. لەو ڕۆژەدا کە دوژمنەکانی جولەکەکان چاوەڕوان بوون تێیدا بەسەریاندا زاڵ بن، بەڵام دۆخەکە لە دژیان هەڵگەڕایەوە بە شێوەیەک کە جولەکەکان بەسەر ناحەزەکانیاندا زاڵ بوون.
\v 2 جولەکەکان لە هەموو هەرێمەکانی ئەحەشوێرۆشی پاشا لەناو شارەکانیان کۆبوونەوە، بۆ ئەوەی هێرش بکەنە سەر ئەوانەی دەیانویست خراپەیان بەرامبەر بکەن. بەڵام کەس لەبەردەمیان خۆی ڕانەگرت، چونکە خەڵک زۆر لێیان ترسان.
\v 3 هەموو سەرکردەکانی هەرێمەکان، میر و پارێزگار و لێپرسراوەکانی پاشاش یارمەتی جولەکەکانیان دەدا، چونکە ترسی مۆردەخای لەسەریان نیشتبوو.
\v 4 مۆردەخای لە کۆشکی پاشا پلەیەکی گەورەی هەبوو، ناوبانگی لەناو هەموو هەرێمەکان بڵاوببووەوە، بەردەوام بەهێز دەبوو.
\p 
\v 5 جولەکەکان بە شمشێر لە هەموو دوژمنەکانیان دا، کوشتیانن و لەناویانبردن، ئەوەی ویستیان بە ناحەزەکانیان کرد.
\v 6 جولەکەکان لە قەڵای شوش پێنج سەد پیاویان کوشت و لەناویانبردن.
\v 7 هەروەها ئەوانەشیان کوشت: پەرشەنداتا، دەلفۆن، ئەسپاتا،
\v 8 پۆراتا، ئەدەلیا، ئەریداتا،
\v 9 پەرمەشتا، ئەریسەی، ئەریدەی و ڤەیزاتا،
\v 10 کە دە کوڕەکەی هامانی کوڕی هەمەداسای دوژمنی جولەکەکان بوون، بەڵام دەستیان بۆ تاڵانی درێژ نەکرد.
\p 
\v 11 لەو ڕۆژەدا ژمارەی کوژراوەکان لە قەڵای شوش هێنرایە بەردەستی پاشا.
\v 12 جا پاشا بە شاژنە ئەستێری گوت: «جولەکەکان لە قەڵای شوش پێنج سەد پیاویان لەگەڵ دە کوڕەکەی هامان کوشتووە و لەناویانبردوون. ئایا دەبێت لە هەرێمەکانی دیکەی پاشادا چییان کردبێت؟ ئێستاش بابەتەکەت چییە؟ پێت دەدرێت. چ داواکارییەکی دیکەت هەیە؟ بۆت جێبەجێ دەکرێت.»
\p 
\v 13 ئەستێریش گوتی: «ئەگەر پاشا ڕازی بێت، با سبەینێش لە قەڵای شوش کارەکەی ئەمڕۆیان بکەنەوە، هەروەها با تەرمی هەر دە کوڕەکەی هامان لە دار بدرێن.»
\p 
\v 14 ئینجا پاشا فەرمانی دا ئەوە بکەن. لە شوش فەرمان دەرکرا و تەرمی هەر دە کوڕەکەی هامان لە دار دران.
\v 15 پاشان جولەکەکانی ناو شوش لە چواردەی ئادار دووبارە کۆبوونەوە، سێ سەد پیاویان لە شوش کوشت، بەڵام دەستیان بۆ تاڵانی درێژ نەکرد.
\p 
\v 16 هەروەها جولەکەکانی دیکەش کە لە هەرێمەکانی پاشادا بوون، کۆبوونەوە بۆ بەرگریکردن لە خۆیان و ڕزگاربوونیان لە دوژمنەکانیان. حەفتا و پێنج هەزار کەسیان لە ناحەزەکانیان کوشت، بەڵام دەستیان بۆ تاڵانی درێژ نەکرد.
\v 17 ئەمە لە سێزدەی ئادار ڕوویدا، لە چواردەی مانگ پشوویان دا و کردیانە ئاهەنگگێڕان و خۆشی.
\p 
\v 18 بەڵام جولەکەکانی ناو شوش لە سێزدە و چواردەی مانگ کۆبوونەوە و لە پازدەی مانگ پشوویان دا و کردیانە ڕۆژی ئاهەنگ و خۆشی.
\p 
\v 19 لەبەر ئەوە ئەو جولەکانەی لە دەشت و گوندە بچووکەکان دەژیان چواردەی مانگی ئاداریان کردە شادی و ئاهەنگگێڕان و خواردنیان بە دیاری بۆ یەکتر دەنارد.
\s1 جەژنی پوریم
\p 
\v 20 ئینجا مۆردەخای ئەم ڕووداوانەی تۆمار کرد و چەندین نامەی نارد بۆ هەموو جولەکەکانی ناو هەموو هەرێمەکانی ئەحەشوێرۆشی پاشا، بە دوور و نزیکەوە،
\v 21 بۆ ئەوەی فەرزی بکات لەسەریان کە هەموو ساڵێک لە چواردە و پازدەی مانگی ئادار ئاهەنگ بگێڕن،
\v 22 چونکە ئەوە ئەو کاتەیە جولەکەکان لە دوژمنەکانیان ڕزگار بوون، ئەو مانگەیە کە شیوەنیان بووە خۆشی و هاواریان بووە پێکەنین. مۆردەخای داوای لێکردن ئەوە ببێتە جەژنێک و خوان بڕازێننەوە و دڵخۆش بن و دیاری پێشکەش بە یەکتری بکەن، هەروەها دیاری پێشکەش بە هەژاران بکەن.
\p 
\v 23 ئیتر جولەکەکان داواکارییەکەی مۆردەخایان پەسەند کرد، بەردەوام بوون لەو ئاهەنگگێڕانەی دەستیان پێی کردبوو.
\v 24 هامانی کوڕی هەمەداسای ئەگاگی دوژمنی هەموو جولەکەکان پیلانی گێڕا بۆ ئەوەی جولەکەکان لەناو ببات، \tl پوری‏\tl* فڕێدا، واتا تیروپشکی کرد، بۆ ئەوەی قڕیان بکات و لەناویان ببات.
\v 25 بەڵام کاتێک ئەستێر چووە ژوورەوە بۆ بەردەم پاشا، پاشا بە نووسراوێک فەرمانی دا، ئەو پیلانە خراپەی کە هامان لە دژی جولەکەکان دایڕشتبوو هەڵبگەڕێتەوە بۆ سەر خۆی، خۆی و کوڕەکانی لە دار دران.
\v 26 لەبەر ئەوە ئەو ڕۆژانە ناونران پوریم لەسەر ناوی \tl پور‏\tl*. لەبەر هەموو وشەکانی ئەم نامەیە و ئەوەی بینییان و بەسەریان هات،
\v 27 جولەکەکان پەسەندیان کرد و کردیانە نەریت، خۆیان و نەوەکانیان و ئەوانەشی دەچنە پاڵیان پەیڕەویان کرد، بۆ ئەوەی لە یاد نەکرێن، هەمیشە لەو دوو ڕۆژەدا بەپێی ئەوەی کە نووسراوە و لە کاتی خۆیاندا هەموو ساڵێک ئاهەنگ بگێڕن.
\v 28 هەروەها ئەم ڕۆژانە یادیان بکرێتەوە، لەنێو هەموو نەوە و هۆز و هەرێمێک و لە هەموو شارێک ئاهەنگیان بۆ ساز بکرێت. ڕۆژانی پوریم هەرگیز لەنێو جولەکەکان لەبیر نەکرێن و ناشبێت لەلایەن نەوەکانیانەوە لە یاد بکرێت.
\p 
\v 29 ئینجا شاژنە ئەستێری کچی ئەبیحەیل لەگەڵ مۆردەخای جولەکە بە هەموو دەسەڵاتێکەوە نامەیەکی دیکەیان نووسی بۆ پشتڕاستکردنەوەی ئەم نامەیەی دووەم کە سەبارەت بە پوریم بوو.
\v 30 مۆردەخای نامەکانی بۆ هەموو جولەکەکانی ناو سەد و بیست و حەوت هەرێمەکەی شانشینی ئەحەشوێرۆش نارد، وێڕای هیوای شادی ئارامییان بۆ جولەکەکان،
\v 31 بۆ چەسپاندنی دوو ڕۆژەکەی پوریم لە کاتی دیاریکراوی خۆی. هەروەک مۆردەخای جولەکە و شاژنە ئەستێر داوایان لێیان کرد، ئەوانیش بۆ خۆیان و نەوەکانیان پەسەندیان کرد کە بەڕۆژوو بن و شین بگێڕن.
\v 32 فەرمانەکەی ئەستێر ڕێنماییەکانی پوریمی دووپات کردەوە و لە پەڕتووکێکدا تۆمار کرا.
\c 10
\s1 گەورەیی مۆردەخای
\p 
\v 1 ئەحەشوێرۆشی پاشا سەرانەی بەسەر شانشینەکە و دوورگەکانی دەریاشدا سەپاند.
\v 2 هەموو کاری دەسەڵاتەکەی و تواناکەی، هەروەها هەموو کاروبارەکانی و گەورەیی مۆردەخای کە پاشا پایەی بەرز کردەوە، لە پەڕتووکی کاروباری ڕۆژانەی پاشاکانی مادی و فارس تۆمار کراون.
\v 3 مۆردەخای جولەکە لەدوای ئەحەشوێرۆشی پاشاوە بە پلەی دووەم دەهات، لەنێو جولەکەکانیش گەورە بوو، لەلای برا جولەکەکانی زۆر ڕێزدار بوو، چونکە داوای چاکەی بۆ نەتەوەکەی دەکرد و بەرگری لە بەرژەوەندییە گشتییەکانیان دەکرد.
