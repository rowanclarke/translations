\c 6  
\s1 Maelhmai Then Dang Pawh  
\p
\v 1 \w Te\w* \w lamloh|strong="G1564"\w* \w thoo|strong="G1831"\w* \w tih|strong="G2532"\w* \w amah|strong="G0846"\w* \w tolrhum|strong="G3968"\w* \w la|strong="G1519"\w* \w a\w* \w caeh|strong="G2064"\w* \w vaengah|strong="G2532"\w* \w a|strong="G0846"\w* \w hnukbang|strong="G3101"\w* \w rhoek \w*\w loh \w*\w a\w* \w vai|strong="G0190"\w* \w uh\w*.  
