\v 13 \w But|strong="H3588"\w* \w instead|strong="H3588"\w* \w of|strong="H6629"\w* \w doing|strong="H8354"\w* \w that|strong="H3588"\w*, \w you|strong="H3588"\w* \w were|strong="H6629"\w* \w happy|strong="H8057"\w* \w and|strong="H6629"\w* celebrating;  
