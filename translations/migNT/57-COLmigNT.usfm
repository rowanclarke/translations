\id COL
\h Colosenses
\toc1 YA'A KUU CARTA JA NI CHAA SAN PABLO APOSTOL NUU ÑAYƗVƗ ÑUU COLOSAS
\toc2 Colosenses
\toc3 Col.
\mt2 LA EPISTOLA DEL APOSTOL SAN PABLO A LOS COLOSENSES
\mt1 YA'A KUU CARTA JA NI CHAA SAN PABLO APOSTOL NUU ÑAYƗVƗ ÑUU COLOSAS
\c 1
\p 
\v 1 Máá‑rí Pablo kúu apóstol Jesucristo, chi̱ súan ni̱ jata'a̱n ini̱ Dios. Te jíín ñaní‑yo̱ Timoteo,
\v 2 káchaa‑ri̱ tutu̱ yá'a nuu̱ ñáyɨvɨ ndóo, jíín núu̱ ñaní‑yo̱ kákandíja nuu̱ Cristo ja̱ káxiu̱kú‑i ini̱ ñuu̱ Colosas. Tu̱'un luu jíín tú'un kuaká'nu ini̱ íó ini̱ máá Táa̱‑yo̱ Dios, jíín iní máá Jíto'o̱‑yo̱ Jesucristo, ná kóo jíín‑ró jíná'an‑ró.
\s1 Tu̱'un ni̱ jika̱n ta'u̱ Pablo nuu̱ Dios ja'a̱ máá‑i
\p 
\v 3 Nene̱ kájika̱n ta'u̱‑rí ja'a̱ róó jíná'an‑ró. Te kánakuatá'ú‑rí nuu̱ Dios Táa̱ Jito'o̱‑yo̱ Jesucristo.
\v 4 Chi ni̱ ka̱jini tu̱'un‑ri̱ róó ja̱ kákandíja va̱'a‑ró núu̱ Cristo Jesús, jíín ndasa kájito ndá'ú‑ro̱ núu̱ táká ña̱yɨvɨ ndóo,
\v 5 chi̱ káñukuu ini̱‑ro̱ ní'i̱n‑ro̱ já yíva̱'a onde̱ andɨ́vɨ́. Tu̱'un yúan a ni̱ ka̱jini tu̱'un‑ró, chi̱ súan ká'a̱n ndaa̱ tu̱'un va̱'a.
\v 6 Chi tu̱'un‑ún, a ni̱ jaa̱ nuu̱‑ro̱ jíná'an‑ró, nátu̱'un nuu̱ nɨ́ɨ́ ñúyɨ́vɨ, chi̱ ní'i̱n tíñu te ndeá kua'a̱n, suni nátu̱'un ni̱ sá'a jíín‑ró ondé kɨvɨ̱ ní ka̱jini so̱'o‑ró. Te ni̱ ka̱juku̱'un ndija ini̱‑ro̱ tú'un luu íó ini̱ Dios,
\v 7 nátu̱'un ni̱ kutu̱'a‑ró ní sá'a Epafras. Mozo ta'a̱n jíín‑yó kúu‑de. Te kúmani̱‑yo̱ jíín‑de. Te cha̱a‑ún játíñu va̱'a‑de nuu̱ Cristo ja̱ sɨkɨ́ róó jíná'an‑ró.
\v 8 Cha̱a‑ún, ni̱ kastu̱'ún‑de tu̱'un‑ró núu̱‑rí ndasa kákundá'ú ini̱ tá'an‑ró sá'a Espíritu.
\v 9 Ja̱ yúán rúu̱ jíná'an‑ri̱, suni tú kájukuiñi̱‑ri̱ ja̱ kájika̱n ta'u̱‑rí ja'a̱‑ro̱ núu̱‑yá onde̱ kɨvɨ̱ ní ka̱jini tu̱'un‑ri̱ tu̱'un‑ún. Te kájika̱n‑ri̱ nuu̱‑yá já ná kuní ndɨ'ɨ‑ró ndasa játa'a̱n ini̱ máá‑yá, te ná kuní‑ro̱ táká tu̱'un ndíchí jíín tú'un júku̱'un va̱'a ini̱‑ro̱ sá'a Espíritu,
\v 10 náva̱'a ná káka kuu luu‑ró, nátu̱'un kuní máá Jíto'o̱‑yo̱, te ná kúsɨɨ̱ vá'a ini̱‑ya̱ sá'a‑ró jíín táká‑ni, te na̱ni tiñu va̱'a jíku‑ró jíín, ná ní'i̱n tíñu, te ná júku̱'un‑ga̱ ini̱‑ro̱ sɨkɨ́ Dios.
\v 11 Te va̱'a téyíí ná yíja ta̱ká fuerza‑ya̱ iní‑ro̱, nátu̱'un káa fuerza luu máá‑yá, náva̱'a ná kóo sɨɨ̱ iní‑ro̱, te ká'nu koo ini̱‑ro̱, te kua̱ndéé iní‑ro̱.
\v 12 Ná nákuatá'ú‑ró núu̱ máá Táa̱‑yo̱ Dios ja̱ ní chi'i‑ya̱ fuerza yóó náva̱'a ni'i̱n tá'a̱n‑yo̱ tá'u̱‑yo̱ jíín ñáyɨvɨ ndóo ja̱ ká'i̱in‑i nuu̱ ndíi ncháa̱.
\v 13 Chi ni̱ ndiñi'in máá‑yá yóó ini̱ nda'a fuerza ñu̱ñáa, te ni̱ xndɨ́vɨ‑ya̱ yóó ini̱ ñuu̱ nuu̱ tá'ú tíñu Se̱'e‑ya̱, I'a̱ maní‑yá jíín.
\v 14 Te Se̱'e‑ya̱‑ún, chi ni̱ na̱kuaan‑ya̱ yóó jíín nɨñí‑yá. Te ni̱ sá'a‑ya̱ túká'nu ini̱‑ya̱ núu̱‑yo̱ jíín kuáchi‑yó.
\s1 Muestra Dios kúu Jesús
\p 
\v 15 Te Se̱'e‑ya̱‑ún kúu muestra Dios, I'a̱ tú jiní ndiji̱n‑yo̱ núu̱. Te xna̱ñúú‑gá Se̱'e‑ún, vásá táká ndatíñu ja̱ ní sá'a‑ya̱.
\v 16 Chi̱ jíín máá Sé'e‑ya̱‑ún kúu ja̱ ní kuva̱'a ta̱ká ndatíñu ja̱ ká'i̱o andɨ́vɨ́, jíín já ká'i̱o ini̱ ñu̱yɨ́vɨ já jiní‑yo̱ núu̱ jíín já tú jiní‑yo̱ núu̱, kúu nuu̱ tá'ú tíñu, kúu nuu̱ kúñá'nu, kúu ja̱ kátɨ̱ɨn xini̱, kúu ja̱ kándi̱so tíñu. Ndɨ'ɨ ni̱ kuva̱'a ni̱ sá'a Dios jíín máá‑yá, te kúu cuenta máá‑yá.
\v 17 Máá‑yá íó xna'a̱n‑ga̱ vásá ní kuva̱'a ta̱ká ndatíñu, te ta̱ká ndatíñu tɨ́ɨn ni̱'in máá‑yá.
\v 18 Te máá‑yá kúu xini̱ tɨ́ku'ni̱, te nátu̱'un yikɨ kúñu‑ya̱ kúu‑ún. Máá‑yá kúu nuu̱ kéjá'á, te máá‑yá ni̱ nachaku̱ xna'a̱n‑ga̱ ma̱'ñú ndɨ́yi, náva̱'a kuñá'nu‑ga̱‑ya̱ núu̱ táká‑ni.
\v 19 Chi ni̱ kusɨɨ̱ iní máá Dios ja̱ ñú'un tá'an ká'nu‑ni‑ya̱ jíín máá Sé'e‑ya̱,
\v 20 náva̱'a naketá'an ta̱ká‑ni jíín Dios sá'a‑ya̱ jíín máá Sé'e‑ya̱. Te jíín nɨñí Sé'e‑ya̱, I'a̱ ni̱ ndo'o jika̱ cruz, te ná kóo paz sá'a‑ya̱ sɨkɨ́ máá já ká'i̱o ini̱ ñu̱yɨ́vɨ jíín já ká'i̱o andɨ́vɨ́.
\v 21 Te suni súan ni̱ sá'a Se̱'e‑ya̱ jíín‑ró, chi̱ sɨ́ɨn sɨkɨ̱ ní ka'i̱in‑ró sáá, chi ni̱ ka̱jito u'u̱‑ro̱‑yá, te máni tiñu ñáá ni̱ ka̱sá'a‑ró núú. Ko vina a ni̱ naskétá'an‑ya̱ róó jíín Dios.
\v 22 Ya̱'á ní sá'a‑ya̱ jíín yíkɨ kúñu‑ya̱ já ní ji'i̱, náva̱'a nasándoo‑ya̱ róó, te ma̱ kúnchaa̱ cha'a̱n róó, ni ma̱ kána jíín Dios nuu̱‑ro̱ hora stá'a̱n‑ya̱ róó nuu̱ Dios.
\v 23 Súan sá'a‑ya̱ nú kuiñi ni̱'in‑ró, te kandíja ndija‑ró, te ni ma̱ nása̱ma ini̱‑ro̱ jíín tú'un va̱'a káñukuu ini̱‑ro̱ já ní ka̱jini so̱'o‑ró. Chi tu̱'un‑ún a ni̱ jicha̱ nɨ́ɨ́ ñúyɨ́vɨ chíi andɨ́vɨ́. Te ruu̱ Pablo kúu cha̱a játíñu sɨkɨ̱ tú'un‑ún.
\s1 Sátiñu Pablo ja'a̱ ñáyɨvɨ sɨ́ɨn nación
\p 
\v 24 Te kúsɨɨ̱ iní‑ri̱ vina, chi̱ ndó'o‑ri̱ ja̱ sɨkɨ́ róó jíná'an‑ró. Te skíkuu yikɨ kúñu‑ri̱ ja̱ kúmani̱‑gá ndo'o Cristo ini̱ tɨku'ni̱ máá‑yá, ja̱ kúu yikɨ kúñu‑ya̱,
\v 25 te suni játíñu‑ri̱ nuu̱‑ún, chi̱ súan ni̱ chaa Dios tiñu sɨkɨ̱‑rí ja'a̱ róó, náva̱'a ná ká'a̱n ndɨ'ɨ‑ri̱ tu̱'un Dios jíín‑ró.
\v 26 Yu̱án kúu máá tú'un sa̱'í ja̱ ní yisa̱'í onde̱ ná ni̱ kejá'á kuiá aná'án jíín ñáyɨvɨ. Ko vina a ni̱ stá'a̱n ndiji̱n‑ya̱ tú'un‑ún nuu̱ táká ña̱yɨvɨ ndóo máá‑yá.
\v 27 Chi̱ máá Dios súan ni̱ kuni̱‑ya̱ stá'a̱n‑ya̱ núu̱ ñáyɨvɨ‑ún, ndasa kúká káa tu̱'un luu ja̱ ndíso tu̱'un sa̱'í yá'a, kua'a̱n nuu̱ ñáyɨvɨ sɨ́ɨn nación. Te tu̱'un‑ún kúu máá Cristo kándee ini̱‑ro̱, jíín já káñukuu ini̱‑ro̱ núu̱ lúu kánchaa̱‑ya̱.
\v 28 Te tu̱'un I'a̱‑ún kúu ja̱ kájani‑ri̱, te kákana jíín‑rí nuu̱ táká ña̱yɨvɨ. Te jíín tú'un ndíchí kástá'a̱n ñúkúún‑rí nuu̱‑í náva̱'a ná yíja va̱'a ta̱ká‑i kuiñi‑i nuu̱ Cristo Jesús sá'a‑ri̱.
\v 29 Te ja̱ sɨkɨ́ yúán sátiñu‑ri̱. Te ni̱'in sátiñu‑ri̱ jíín fuerza máá‑yá. Te máá fuerza‑ya̱‑ún kúu ja̱ sátiñu téyíí jíín‑rí.
\c 2
\p 
\v 1 Chi̱ kuní‑ri̱ ja̱ ná kuní‑ro̱ ndasa ndɨ́'ɨ xaa̱n iní‑ri̱ ja̱ sɨkɨ́ róó jíín sɨkɨ́ táká ña̱yɨvɨ ká'i̱o ini̱ ñuu̱ Laodicea, jíín sɨkɨ́ táká ña̱yɨvɨ tú kájini̱ kutɨ núu̱‑rí ndasa káa‑ri̱,
\v 2 náva̱'a ná ndúndéé iní añú‑i, te ɨɨn nuu̱ kúnchaka mani̱ tá'an‑i, te ná júku̱'un ndɨ'ɨ ini̱‑i ta̱ká tu̱'un luu‑ya̱, náva̱'a kuni̱‑i tu̱'un sa̱'í máá Táa̱‑yo̱ Dios te yu̱án kúu cuenta Cristo.
\v 3 Chi̱ ini̱ nda'a máá‑yá yísa̱'í ta̱ká yaka̱ tu̱'un ndíchí, jíín tú'un ja̱ júku̱'un ini̱‑yo̱ sá'a.
\v 4 Te tu̱'un yá'a ká'a̱n‑ri̱ jíín‑ró jíná'an‑ró, náva̱'a tú ni ɨɨn cha̱a xndá'ú‑de róó, ja̱ kándíja‑ró ɨngá tu̱'un tɨ́ɨn yátá.
\v 5 Chi va̱sa kándee jíká máá‑rí, ko nátu̱'un kándee‑ri̱ jíín‑ró, te kúsɨɨ̱ iní‑ri̱ te ndé'é‑rí tiñu va̱'a kásá'a‑ró, chi̱ ni̱'in kákandíja‑ró núu̱ Cristo.
\v 6 Chi̱ nátu̱'un ni̱ ka̱jatá'ú‑ró máá Jíto'o̱‑yo̱ Jesucristo, súan ná káka‑ró jíín‑yá núsáá.
\v 7 Ná nákuiki̱n yo'o‑ro iní‑ya̱. Te ná skuá'nu tá'an‑ró sɨkɨ́‑yá. Te ná yíja va̱'a‑ró jíín tú'un kándíja, nátu̱'un ni̱ kutu̱'a‑ró. Te ná ndeá‑ga̱‑ro̱ jíín tú'un‑ún, onde̱ jíín tú'un nakuatá'ú‑ró núu̱‑yá.
\s1 Ini̱ nda'a Cristo ncháá ta̱ká‑ni
\p 
\v 8 Koto va̱'a‑ró máá‑ró, náva̱'a tú xndá'ú ni ɨɨn ña̱yɨvɨ róó, jíín sɨkɨ́ tú'un ndíchí ñáá, jíín tú'un vixi̱ sáni, nátu̱'un íó tani̱nu cha̱a, modo kásá'a‑de ini̱ ñu̱yɨ́vɨ yá'a te tú kásá'a‑de ja̱ kuní Cristo.
\v 9 Chi̱ jíín máá‑yá, te ini̱ yikɨ kúñu máá‑yá, ncháá ndɨ'ɨ ta̱ká‑ni ndasa káa Dios.
\v 10 Te ká'i̱o chítú‑ró jíín Cristo. Te máá‑yá tɨ́ɨn xini̱ táká ja̱ tá'ú tíñu, jíín táká ja̱ kándi̱so tíñu.
\v 11 Te suni jíín máá‑yá ni̱ kaxɨtɨ̱ ndúu̱‑ro̱, ko nasu̱ jíín ndá'a ní káxɨtɨ̱ ndúu̱‑ro̱. Te ni̱ chaxio‑ya̱ táká kua̱chi ndíso máá‑ró, chi̱ Cristo nátu̱'un ni̱ xɨtɨ ndúu̱‑ya̱ róó.
\v 12 Chi̱ ɨɨn núú‑ni ni̱ kayu̱ji‑ró jíín‑yá nuu̱ ní ka̱janducha‑ro, te suni yúan ni̱ ka̱nachaku̱‑ro̱ jíín‑yá, chi ni̱ ka̱kandíja‑ró tíñu sá'a Dios ja̱ ní naschakú‑ya̱ Jesús ma̱'ñú ndɨ́yi.
\v 13 Ko róó, tú káxɨtɨ̱ ndúu̱‑ro̱ núú, te a ni̱ kaji'i̱‑ro̱ ní sá'a ta̱ká kua̱chi‑ró. Ko ɨɨn ká'nu‑ni ni̱ ka̱nachaku̱‑ro̱ jíín Cristo ni̱ sá'a Dios. Te ni̱ sá'a‑ya̱ túká'nu ini̱ nuu̱ táká ja̱ ní ka̱sáña'mu‑ró.
\v 14 Te ni̱ nda'va̱‑ya̱ acta ja̱ tɨ́ɨn suku̱n‑yo̱ te jíto u'u̱ yóó núú. Te ni̱ skána‑ya̱, chi̱ nátu̱'un ni̱ stɨ́ɨn‑ya̱‑ún jíín ndúyu ka̱a jika̱ cruz.
\v 15 Te ni̱ tevíchí‑yá ta̱ká ja̱ kátá'ú tíñu jíín já kándi̱so tíñu, te ni̱ kiñi'in ndiji̱n‑ya̱, te ni̱ ka̱kuka nuu̱. Chi ni̱ kundéé‑yá jíín, ni̱ sá'a máá cruz.
\v 16 Ja̱ yúán ma̱ kuá'a‑ró tú'un ja̱ náku̱xndíi ni ɨɨn‑i sɨkɨ̱‑ro̱, cuenta sɨkɨ̱ já yee, xí já jí'i, xí cuenta kɨvɨ̱ íó viko, xí já núkoso̱ yóo̱, xí sɨkɨ́ kɨvɨ́ ndéta̱tú.
\v 17 Chi yu̱án kúu nátu̱'un ɨɨn kuanda'u̱ ta̱ká ndatíñu chaa̱ kuee̱‑ga̱, ko máá jándáa̱ kúu ja̱ cuenta máá Cristo.
\v 18 Ma̱ kuá'a‑ró tú'un ja̱ ní ɨɨn ña̱yɨvɨ kasú‑i nuu̱ tá'u̱‑ro̱. Chi̱ kásá'a‑i ja̱ súchí iní máá‑i, te káchiñú'ún‑i ta̱ká ndajá'a̱‑yá. Te kákɨ̱vɨ nduu̱‑i jíín tú'un ja̱ tú ní kájini̱ ndiji̱n‑i, te máni kásávixi̱ sáni‑i máá‑i. Chi̱ yúkú xiní máá‑i.
\v 19 Te tú ká'i̱in ni̱'in‑i jíín máá I'a̱ kúu xini̱. Chi̱ máá‑yá kúu ja̱ skuá'nu yikɨ kúñu, chi̱ skée máá‑ún túchi, te ñútá'an sá'a máá túchi, te já'nu máá sá'a Dios.
\v 20 Chi̱ nú ni̱ kaji'i̱‑ro̱ jíín Cristo sɨkɨ̱ táká tani̱nu ini̱ ñu̱yɨ́vɨ, te naja̱ kajika‑ga̱‑ro̱ nátu̱'un kájika ña̱yɨvɨ ñúyɨ́vɨ. Te naja̱ kájandatu̱‑ro̱ núu̱ tú'un yá'a:
\v 21 Ma̱ tɨ́ɨn‑ró, ni ma̱ ké'é‑ró, ni ma̱ kée‑ro, áchí.
\v 22 Chi ta̱ká tu̱'un‑ún nini kájatíñu máá, te ndɨ'ɨ‑ni naa. Chi̱ máni tu̱'un, máni tani̱nu ja̱ ní jani sáni ini̱ ña̱yɨvɨ kúu‑ún.
\v 23 Kájani ndija ini̱‑i ja̱ tú'un ndíchí kúu‑ún, chi̱ stétuu‑ún‑i ja̱ ní'in chiñú'ún‑i, te sá'a ja̱ sásúchí iní, te ni̱'in ndónda máá sɨkɨ́ yíkɨ kúñu, ko tú ní'i̱n tíñu kutɨ já kasú nuu̱ já kuní máá‑i.
\c 3
\p 
\v 1 Núsáá te nú ni̱ ka̱nachaku̱‑ro̱ jíín Cristo, te va'a̱‑ga̱ ná ndúkú‑ró tú'un andɨ́vɨ́, nuu̱ kánchaa̱ Cristo ichi ndává'a Dios.
\v 2 Ná káni ini̱‑ro̱ sɨkɨ́ tú'un ká'i̱o ichi ándɨ́vɨ́, nasu̱ sɨkɨ́ tú'un ká'i̱o ini̱ ñu̱yɨ́vɨ.
\v 3 Chi̱ a ni̱ kaji'i̱‑ro̱, te vida‑ro̱, a yísa̱'í, jíín Cristo ini̱ Dios.
\v 4 Te Cristo, I'a̱ kúu vida‑ro̱‑ún, te nú kenda ndiji̱n‑ya̱, yúan‑na te suni luu kenda koyo ndiji̱n‑ro̱ jíín‑yá.
\s1 Cha̱a tú'ú jíín cháa jáá
\p 
\v 5 Ná kasú‑ro̱ iní yikɨ kúñu‑ró já káa yúkú, náva̱'a ma̱ sá'a téné, ma̱ kóo chá'án, ma̱ káni ñáá ini̱, ma̱ ndío ini̱, chi̱ ɨɨn‑ni kúu‑ún jíín já chíñú'ún ndosó.
\v 6 Chi ja̱ sɨkɨ́ táká tiñu yúan kúu ja̱ kití ini̱ Dios, te ndonda‑ya̱ sɨkɨ́ ñáyɨvɨ ní'in ini̱.
\v 7 Te suni jíín tíñu‑ún ni̱ ka̱jika‑ró núú, ná ni̱ ka̱sá'a‑ró súan.
\v 8 Ko vina ná sía̱‑ro̱ táká tu̱'un yá'a núsáá: Tu̱'un kití ini̱, tu̱'un xaa̱n iní, tu̱'un káñáá, tú'un ká'a̱n sɨkɨ̱ tá'an, jíín tú'un chá'án kénda yu'u‑ro.
\v 9 Ma̱ xndá'ú tá'an‑ró, chi̱ a ni̱ chaxio‑ró cháa tú'ú‑ún kua'a̱n‑de jíín táká tiñu ni̱ sá'a‑de.
\v 10 Te ni̱ nuku̱'un‑ró cháa jáá. Chi cha̱a‑ún kua̱juku̱'un ini̱‑de, kua̱ndujáá‑de, nátu̱'un káa máá‑yá ja̱ ní sá'a‑ya̱‑dé.
\v 11 Te yúan tú íó sɨ́ɨn ña̱yɨvɨ ñúu̱ Grecia jíín ñáyɨvɨ judío, ni ja̱ ní xɨtɨ́ ndúu̱, te ni ja̱ tú ní xɨtɨ́ ndúu̱, ni ja̱ sɨ́ɨn yu'u, te ni ja̱ kúu ña̱yɨvɨ escita, ni ja̱ sátiñu sáni, te ni ja̱ jíka kuu ndicha̱‑na̱, chi̱ Cristo kúu ndɨ'ɨ‑ni, te yí'i‑ya̱ iní ta̱ká‑yo̱.
\v 12 Chi ni̱ ka̱ji Dios róó. Te ña̱yɨvɨ ndóo ja̱ maní‑yá jíín kákuu‑ró. Núsáá te nɨ́nɨ kúndá'ú ini̱‑ro̱ tá'an‑ró, te kumani̱‑ro̱ jíín tá'an‑ró, te koo súchí iní‑ro̱, koo paciencia‑ro̱.
\v 13 Kua̱ndéé iní‑ro̱ jíín tá'an‑ró, te sá'a‑ró túká'nu ini̱ nú jikín nuu̱‑ro̱ sɨkɨ́ tá'an‑ró. Chi̱ nátu̱'un ni̱ sá'a Cristo tu̱ká'nu ini̱‑ya̱ núu̱‑ro̱, te suni súan sá'a‑ró jíná'an‑ró.
\v 14 Te ja̱ kánúú xáa̱n‑gá nuu̱ táká tu̱'un yá'a kúu tu̱'un kundá'ú ini̱ tá'an. Chi tu̱'un yúan kúu ja̱ skétá'an ta̱ká‑ni jíín já síyíja va̱'a.
\v 15 Te tu̱'un vindáa̱ vinené ja̱ ndíso máá Dios, ná kútɨɨn añú‑ro̱. Chi ja̱ yúán ní kana‑ya̱ xiní‑ro̱ ndúu‑ró ɨ́ɨn‑na̱ ña̱yɨvɨ. Te suni ná nákuatá'ú‑ró jíná'an‑ró.
\v 16 Te tu̱'un Cristo ná kútú ndɨ́'ɨ ini̱‑ro̱, jíín ndɨ́'ɨ tu̱'un ndíchí. Te stá'a̱n‑ro̱ núu̱ tá'an‑ró. Te ka'a̱n nda̱'ú‑ro̱ jíín‑i jíín salmo, jíín yáa̱ máá‑yá, jíín yáa̱ Espíritu. Te ichi iní añú‑ro̱ ná káta luu‑ró núu̱ máá Jíto'o̱‑yo̱.
\v 17 Te ta̱ká tiñu kásá'a‑ró, nú ja̱ ká'a̱n‑ro̱, xí já sá'a‑ró kúu, ta̱ká ná sá'a‑ró jíín sɨ́'vɨ́ máá Jíto'o̱‑yo̱ Jesús. Te ná nákuatá'ú‑ró núu̱ máá Táa̱‑yo̱ Dios sá'a Jesús.
\s1 Tiñu kánúú skíkuu cha̱a jáá
\p 
\v 18 Róó ñasɨ́'ɨ́, kuandatu̱‑ro̱ núu̱ yíi máá‑ró jíná'an‑ró, chi̱ súan játa'a̱n ini̱ máá Jíto'o̱‑yo̱.
\v 19 Róó yii jíná'an‑ró, ná kundá'ú ini̱‑ro̱ ñásɨ́'ɨ́‑ro̱. Te ma̱ ndúu ua̱‑ro̱ jíín‑ña.
\v 20 Róó se̱'e jíná'an‑ró, ta̱ká tiñu kuandatu̱‑ro̱ núu̱ táa̱‑ro̱, nuu̱ náa̱‑ro̱. Chi̱ súan kúsɨɨ̱ iní máá Jíto'o̱‑yo̱ sá'a.
\v 21 Róó táa̱ jíná'an‑ró, ma̱ skití ini̱‑ro̱ sé'e‑ró jíná'an‑i, náva̱'a tú kukuí'a̱ ini̱‑i.
\v 22 Róó mozo jíná'an‑ró, ta̱ká tiñu kuandatu̱‑ro̱ núu̱ patrón‑ro̱ ñúyɨ́vɨ yá'a. Ma̱ sá'a‑ró tíñu ja̱ kúsɨɨ̱ iní ña̱yɨvɨ ndé'é‑i nuu̱, chi̱ sua koo ndaa̱ añú‑ro̱ sá'a‑ró, te kuandatu̱‑ro̱ núu̱ Dios.
\v 23 Te ta̱ká tiñu kásá'a‑ró, koo ini̱ koo añú‑ro̱ sá'a‑ró. Kani ini̱‑ro̱ já núu̱ máá Jíto'o̱‑yo̱ kájatíñu‑ró, nasu̱ núu̱ ñáyɨvɨ.
\v 24 Chi̱ a jiní‑ro̱ já máá Jíto'o̱‑yo̱ kuá'a va̱'a‑ya̱ tá'u̱‑ro̱ já kúu ya̱'u‑ró. Chi̱ nuu̱ máá Jíto'o̱‑yo̱ Jesucristo kájatíñu‑ró.
\v 25 Ko ña̱yɨvɨ sá'a tiñu ñáá nduta'u̱ túku‑i ja̱ ní sá'a‑i‑ún, chi̱ tú ncháá nuu̱‑yá‑i.
\c 4
\p 
\v 1 Róó patrón jíná'an‑ró, sá'a va̱'a‑ró jíín mozo‑ro̱. Te ɨɨn nuu̱ kóto‑ró núu̱‑í. Chi̱ a kájini̱‑ro̱ já súni káñava̱'a‑ró máá patrón‑ro̱ ándɨ́vɨ́.
\v 2 Ma̱ júkuiñi̱‑ro̱ já jikán ta'u̱‑ro̱. Te ná nákuatá'ú‑ró, te koo ndito ini̱‑ro̱ jíín tú'un‑ún.
\v 3 Te suni hora‑ún kaka̱n ta'u̱‑ro̱ já'a̱‑rí jíná'an‑ri̱, náva̱'a ná kúña Dios ichi káni‑ri̱ tu̱'un, náva̱'a kuu ka'a̱n‑ri̱ tu̱'un sa̱'í Cristo, chi ja̱ sɨkɨ́ tú'un‑ún kúu ja̱ kándee‑ri̱ veka̱a,
\v 4 chi̱ kuní‑ri̱ ká'a̱n ndiji̱n‑ri̱ nátu̱'un kánúú ká'a̱n‑ri̱.
\v 5 Kaka kuu ñúkúún‑ró jíín ñáyɨvɨ ká'i̱in sɨ́ɨn sɨkɨ̱, te ma̱ stɨ́vɨ́‑ró tiempo.
\v 6 Te nene̱ ka'a̱n asu̱n‑ro̱, ná já'a̱n ñii̱ tú'un ká'a̱n‑ro̱, náva̱'a kuni̱‑ro̱ ndasa kánúú xndíó káni‑ró tú'un nuu̱ ɨ́ɨn ɨɨn‑i.
\s1 Tu̱'un ndéé ni̱ chaa Pablo nuu̱‑í
\p 
\v 7 Ta̱ká tiñu sá'a‑ri̱ ná kástu̱'ún Tíquico nuu̱‑ro̱ jíná'an‑ró, chi̱ ɨɨn ñani̱ sátiñu jíín‑rí nuu̱ máá Jíto'o̱‑yo̱ kúu‑de, te bueno játíñu‑de nuu̱‑yá, te mani̱‑yo̱ jíín‑de.
\v 8 Te ja̱ yúán tájí‑rí cha̱a yá'a jaa̱‑de nuu̱‑ro̱, náva̱'a ná kuní‑ro̱ ndasa kua'a̱n tiñu kákuu‑ri̱ jíín, te ndundéé iní añú‑ro̱ sá'a‑de.
\v 9 Suni tájí‑rí Onésimo, te mani̱‑rí jíín‑de, chi̱ ñani̱ kándíja va̱'a kúu‑de, te tá'an máá‑ró kúu‑de. Te ta̱ká ja̱ kúu ichi yá'a, ná kástu̱'ún‑de nuu̱‑ro̱ jíná'an‑ró, ndasa íó.
\v 10 Aristarco, cha̱a kándee ta'a̱n jíín‑rí veka̱a yá'a, sándéé iní‑ro̱ áchí‑de. Te suni súan ká'a̱n Marcos, saji̱n Bernabé, te sɨkɨ̱ cháa‑ún, a ni̱ tá'ú‑rí tiñu nuu̱‑ro̱. Te nú kujaa̱‑de nuu̱‑ro̱, te kuatá'ú‑ró‑de.
\v 11 Te suni súan ká'a̱n Jesús, cha̱a nání Justo. Cha̱a ni̱ kaxɨtɨ̱ ndúu̱ kákuu cha̱a‑ún. Máni cha̱a yá'a kákuu cha̱a káchindéé tá'an‑de jíín‑rí sɨkɨ̱ ñúu̱ nuu̱ tá'ú Dios tiñu, te íó ndéé iní‑ri̱ kásá'a‑de.
\v 12 Suni sándéé iní‑ro̱ áchí Epafras, cha̱a kúu tá'an máá‑ró, te mozo Cristo kúu‑de, te nene̱ jítú iní‑de jikán ta'u̱‑dé ja'a̱‑ro̱ jíná'an‑ró, náva̱'a ná yíja‑ró kuíñi‑ró, te náva̱'a ná skíkuu ndɨ'ɨ‑ró tíñu kuní máá Dios.
\v 13 Chi̱ ná ká'a̱n ndaa̱‑ri̱ tu̱'un‑de nuu̱‑ro̱, ja̱ xáa̱n jítú iní‑de ja̱ kúu róó jíná'an‑ró, jíín já kúu ña̱yɨvɨ ñúu̱ Laodicea, jíín já kúu ña̱yɨvɨ ñúu̱ Hierápolis.
\v 14 Lucas, cha̱a táná, ja̱ maní‑yo̱ jíín‑de, jíín Demas, káka'a̱n‑de ja̱ ná sándéé iní‑ro̱.
\v 15 Ná sándéé iní ñani̱‑yo̱, cha̱a káxiu̱kú iní ñuu̱ Laodicea, kachi̱‑ro̱ kúni‑de. Suni súan ka'a̱n‑ro̱ jíín Ninfas, jíín tɨ́ku'ni̱ íó ve'e‑de.
\v 16 Te nú ni̱ kuu ni̱ ka̱ka'u‑ró carta yá'a, te suni ná ká'u tɨku'ni̱ ñuu̱ Laodicea sá'a‑ró. Te róó, suni ná ká'u‑ró ɨngá ja̱ ndíi ichi ñúu̱ Laodicea.
\v 17 Te kastu̱'ún‑ró núu̱ Arquipo: Ná ndúkú ndéé‑de skíkuu‑de tiñu ni̱ chaa máá Jíto'o̱‑yo̱ sɨkɨ́‑dé, achi̱‑ro̱ kúni‑de.
\v 18 Nda'a máá rúu̱ Pablo, ni̱ chaa‑ri̱ tu̱'un yá'a ja̱ ná sándéé iní‑ro̱. Te nuku̱'un ini̱‑ro̱ jíná'an‑ró já kándee‑ri̱ veka̱a. Te tu̱'un luu íó ini̱ máá‑yá, ná kóo jíín‑ró jíná'an‑ró. Súan ná kóo. Amén.
