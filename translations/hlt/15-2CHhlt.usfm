\v 5 Te \w vaengah|strong="H9999"\w* \w Israel|strong="H3478"\w* \w manghai|strong="H4428"\w* loh \w tonghma|strong="H5030"\w* rhoek \w te|strong="H0853"\w* \w hlang|strong="H0376"\w* \w ya|strong="H3967"\w* \w li|strong="H0702"\w* a \w coi|strong="H6908"\w* \w tih|strong="H9999"\w* \w amih|strong="H9908"\w* \w te|strong="H0413"\w*, “\w Ramothgilead|strong="H7433"\w* \w ah|strong="H0413"\w* \w caemtloek|strong="H4421"\w* \w la|strong="H9997"\w* na \w lo|strong="H1980"\w* \w aya|strong="H9994"\w*? Ka \w paa|strong="H2308"\w* mai aya?,” a \w ti|strong="H0559"\w* nah.  
\p Te \w dongah|strong="H9999"\w*, “\w Cet|strong="H5927"\w* sih, \w Pathen|strong="H0430"\w* loh \w manghai|strong="H4428"\w* \w kut|strong="H3027"\w* \w ah|strong="H9996"\w* m'\w paek|strong="H5414"\w* bitni,” a \w ti|strong="H0559"\w* na uh.   
