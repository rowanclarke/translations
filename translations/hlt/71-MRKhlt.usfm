\v 11 \x - \xo 6.11 \xt Cael 13. 51.\x*\x - \xo 6.11 \xt Luk 10. 4-11.\x* \wj \+w Nangmih|strong="G5209"\+w* aka \+w doe|strong="G1209"\+w* \+w pawt|strong="G3361"\+w* tih \+w nangmih|strong="G5216"\+w* kah ol aka \+w hnatun|strong="G0191"\+w* \+w pawt|strong="G3366"\+w* \+w hmuen|strong="G5117"\+w* \+w te|strong="G3739"\+w* \+w tah|strong="G0302"\+w*, te \+w lamkah|strong="G1564"\+w* loh na \+w nong|strong="G1607"\+w* uh vaengah \+w na|strong="G5216"\+w* \+w kho|strong="G4228"\+w* \+w hmuikah|strong="G5270"\+w* \+w tangdik|strong="G5522"\+w* \+w te|strong="G3588"\+w* \+w khoek|strong="G1621"\+w* uh lamtah \+w amih|strong="G0846"\+w* taengah \+w laipai|strong="G3142"\+w* la om saeh,” \wj* a \w ti|strong="G3004"\w* nah.   
\p
\v 12 Te \w daengah|strong="G2532"\w* \w cet|strong="G1831"\w* uh tih tholh \w yut|strong="G3340"\w* \w ham|strong="G2443"\w* a \w hoe|strong="G2784"\w* uh.  
\v 13 \x - \xo 6.13 \xt Jas 5. 14.\x* \w Rhaithae|strong="G1140"\w* khaw \w Gmuep|strong="G4183"\w* a \w haek|strong="G1544"\w* uh. Aka \w tlo|strong="G0732"\w* \w khaw|strong="G2532"\w* \w situi|strong="G1637"\w* neh a \w hluk|strong="G0218"\w* uh \w tih|strong="G2532"\w* \w muep|strong="G4183"\w* \w hoeih|strong="G2323"\w* uh.   
\s1 Johan A Rhaih  
\p
\v 14 \x - \xo 6.14 \xt Mat 16. 14; Mrk 8. 28; Luk 9. 19.\x* \w Jesuh|strong="G2424"\w* \w ming|strong="G3686"\w* \w tah|strong="G3588"\w* \w mingpha|strong="G5318"\w* \w coeng|strong="G1096"\w* \w tih|strong="G1063"\w* \w Herod|strong="G2264"\w* \w manghai|strong="G0935"\w* \w loh|strong="G3588"\w* a \w yaak|strong="G0191"\w* \w vaengah|strong="G2532"\w*, “\w Tui|strong="G0907"\w* aka nuem \w Johan|strong="G2491"\w* \w tah|strong="G3588"\w* \w duek|strong="G3498"\w* \w lamkah|strong="G1537"\w* \w thoo|strong="G1453"\w* coeng. \w Te|strong="G5124"\w* \w dongah|strong="G2532"\w* \w a|strong="G0846"\w* \w khuikah|strong="G1722"\w* \w thaomnah|strong="G1411"\w* \w loh|strong="G3588"\w* a \w tueng|strong="G1754"\w* pah,” a \w ti|strong="G3004"\w* uh.   
\p
\v 15 \w Tedae|strong="G1161"\w* a \w tloe|strong="G0243"\w* rhoek loh, “\w Elijah|strong="G2243"\w* \w ni|strong="G2076"\w*,” a \w ti|strong="G3004"\w* uh.  
\p A \w tloe|strong="G0243"\w* rhoek \w bal|strong="G1161"\w* loh, “\w Tonghma|strong="G4396"\w* rhoek \w khuikah|strong="G3588"\w* \w tonghma|strong="G4396"\w* \w pakhat|strong="G1520"\w* \w van|strong="G5613"\w* \w coini|strong="G3754"\w*,” a \w ti|strong="G3004"\w* uh.   
\p
