\c 6
\p 
\v 1 Où \w est|strong="H1730"\w* \w allé|strong="H1980"\w* \w ton|strong="H5973"\w* bien-aimé, ô \w la|strong="H1980"\w* \w plus|strong="H1980"\w* \w belle|strong="H3303"\w* \w des|strong="H1980"\w* \w femmes|strong="H3303"\w*? \w De|strong="H1980"\w* \w quel|strong="H3303"\w* \w côté|strong="H6437"\w* \w est|strong="H1730"\w* \w allé|strong="H1980"\w* \w ton|strong="H5973"\w* bien-aimé? Nous \w le|strong="H1980"\w* \w chercherons|strong="H1245"\w* \w avec|strong="H5973"\w* \w toi|strong="H5973"\w*.
\v 2 \w Mon|strong="H7462"\w* \w bien-aimé|strong="H7462"\w* \w est|strong="H1730"\w* \w descendu|strong="H3381"\w* \w dans|strong="H3381"\w* \w son|strong="H3381"\w* verger, \w au|strong="H3381"\w* \w parterre|strong="H6170"\w* \w des|strong="H3381"\w* plantes \w aromatiques|strong="H1314"\w*, \w pour|strong="H3381"\w* \w paître|strong="H7462"\w* \w son|strong="H3381"\w* troupeau \w dans|strong="H3381"\w* \w les|strong="H7462"\w* vergers, \w et|strong="H3381"\w* \w pour|strong="H3381"\w* \w cueillir|strong="H3950"\w* \w des|strong="H3381"\w* \w lis|strong="H7799"\w*.
\v 3 \w Je|strong="H3068"\w* suis \w à|strong="H7462"\w* \w mon|strong="H7462"\w* \w bien-aimé|strong="H7462"\w*, \w et|strong="H7462"\w* \w mon|strong="H7462"\w* \w bien-aimé|strong="H7462"\w* \w est|strong="H1730"\w* \w à|strong="H7462"\w* moi; il paît \w son|strong="H7462"\w* troupeau parmi \w les|strong="H7462"\w* \w lis|strong="H7799"\w*.
\v 4 Ma bien-aimée, tu es \w belle|strong="H3303"\w* \w comme|strong="H5000"\w* \w Thirtsa|strong="H8656"\w*, \w agréable|strong="H5000"\w* \w comme|strong="H5000"\w* \w Jérusalem|strong="H3389"\w*, redoutable \w comme|strong="H5000"\w* \w les|strong="H3389"\w* armées qui marchent enseignes déployées.
\v 5 \w Détourne|strong="H5437"\w* \w de|strong="H5869"\w* \w moi|strong="H4480"\w* \w tes|strong="H5869"\w* \w yeux|strong="H5869"\w*; qu'\w ils|strong="H1992"\w* \w ne|strong="H5869"\w* \w me|strong="H5869"\w* \w regardent|strong="H5869"\w* \w point|strong="H5869"\w*, car \w ils|strong="H1992"\w* \w me|strong="H5869"\w* \w troublent|strong="H7292"\w*. \w Tes|strong="H5869"\w* \w cheveux|strong="H8181"\w* \w sont|strong="H1992"\w* \w comme|strong="H5869"\w* \w un|strong="H5437"\w* \w troupeau|strong="H5739"\w* \w de|strong="H5869"\w* \w chèvres|strong="H5795"\w* \w suspendues|strong="H1570"\w* \w aux|strong="H1568"\w* flancs \w de|strong="H5869"\w* \w Galaad|strong="H1568"\w*.
\v 6 \w Tes|strong="H5927"\w* \w dents|strong="H8127"\w* sont \w comme|strong="H3605"\w* \w un|strong="H5927"\w* \w troupeau|strong="H5739"\w* \w de|strong="H5927"\w* \w brebis|strong="H7353"\w* \w qui|strong="H3605"\w* \w remontent|strong="H5927"\w* \w du|strong="H5927"\w* lavoir, \w qui|strong="H3605"\w* sont \w toutes|strong="H5927"\w* deux \w à|strong="H5927"\w* deux: \w il|strong="H5927"\w* n'\w en|strong="H5927"\w* manque aucune.
\v 7 Ta \w joue|strong="H7541"\w* est comme une \w moitié|strong="H6400"\w* \w de|strong="H6400"\w* \w grenade|strong="H7416"\w*, sous \w ton|strong="H1157"\w* \w voile|strong="H6777"\w*.
\v 8 Il \w y|strong="H1992"\w* \w a|strong="H3068"\w* \w soixante|strong="H8346"\w* \w reines|strong="H4436"\w*, \w et|strong="H8346"\w* quatre-vingts \w concubines|strong="H6370"\w*, \w et|strong="H8346"\w* \w des|strong="H4557"\w* vierges \w sans|strong="H5959"\w* \w nombre|strong="H4557"\w*: ma colombe, ma parfaite, est unique.
\v 9 \w Elle|strong="H1931"\w* \w est|strong="H1931"\w* l'unique \w de|strong="H1323"\w* \w sa|strong="H7200"\w* \w mère|strong="H7200"\w*, l'unique \w de|strong="H1323"\w* \w celle|strong="H3205"\w* \w qui|strong="H1931"\w* l'\w a|strong="H3068"\w* \w enfantée|strong="H3205"\w*; \w les|strong="H7200"\w* \w jeunes|strong="H7200"\w* \w filles|strong="H1323"\w* l'\w ont|strong="H1931"\w* \w vue|strong="H7200"\w*, \w et|strong="H7200"\w* l'\w ont|strong="H1931"\w* dite bienheureuse; \w les|strong="H7200"\w* \w reines|strong="H4436"\w* \w et|strong="H7200"\w* \w les|strong="H7200"\w* \w concubines|strong="H6370"\w* l'\w ont|strong="H1931"\w* \w louée|strong="H1984"\w*.
\v 10 \w Qui|strong="H4310"\w* \w est|strong="H4310"\w* celle \w qui|strong="H4310"\w* \w apparaît|strong="H8259"\w* \w comme|strong="H3644"\w* \w l|strong="H2063"\w*'\w aube|strong="H7837"\w* \w du|strong="H8259"\w* jour, \w belle|strong="H3303"\w* \w comme|strong="H3644"\w* \w la|strong="H8259"\w* \w lune|strong="H3842"\w*, \w pure|strong="H1249"\w* \w comme|strong="H3644"\w* \w le|strong="H2063"\w* \w soleil|strong="H2535"\w*, redoutable \w comme|strong="H3644"\w* \w les|strong="H2063"\w* armées \w qui|strong="H4310"\w* marchent enseignes déployées?
\v 11 \w Je|strong="H3068"\w* suis \w descendu|strong="H3381"\w* \w au|strong="H7200"\w* verger \w des|strong="H7200"\w* noyers, \w pour|strong="H3381"\w* \w voir|strong="H7200"\w* \w les|strong="H7200"\w* fruits \w qui|strong="H5158"\w* mûrissent \w dans|strong="H7200"\w* \w la|strong="H7200"\w* \w vallée|strong="H5158"\w*; \w pour|strong="H3381"\w* \w voir|strong="H7200"\w* \w si|strong="H7200"\w* \w la|strong="H7200"\w* \w vigne|strong="H1612"\w* \w pousse|strong="H6524"\w*, \w et|strong="H7200"\w* \w si|strong="H7200"\w* \w les|strong="H7200"\w* \w grenadiers|strong="H7416"\w* \w fleurissent|strong="H5132"\w*.
\v 12 \w Je|strong="H3068"\w* \w ne|strong="H3808"\w* \w sais|strong="H3045"\w*, mais \w mon|strong="H3045"\w* affection \w m|strong="H5315"\w*'\w a|strong="H3068"\w* \w rendu|strong="H7760"\w* \w semblable|strong="H3808"\w* \w aux|strong="H5971"\w* \w chars|strong="H4818"\w* d'Aminadab.
\v 13 Reviens, reviens, ô Sulamithe! Reviens, reviens, et que nous te contemplions! Pourquoi contemplez-vous la Sulamithe comme une danse de deux troupes?
\c 7
\p 
\v 1 Fille \w de|strong="H7725"\w* prince, \w que|strong="H7725"\w* \w tes|strong="H7725"\w* pieds \w sont|strong="H2372"\w* beaux \w dans|strong="H7725"\w* \w ta|strong="H7725"\w* chaussure! \w Le|strong="H7725"\w* contour \w de|strong="H7725"\w* \w tes|strong="H7725"\w* hanches \w est|strong="H4264"\w* \w comme|strong="H7725"\w* \w un|strong="H7725"\w* collier travaillé \w de|strong="H7725"\w* \w la|strong="H7725"\w* main d'\w un|strong="H7725"\w* excellent ouvrier.
\v 2 \w Ton|strong="H3027"\w* sein \w est|strong="H3027"\w* \w une|strong="H3027"\w* coupe arrondie, pleine d'\w un|strong="H3027"\w* vin aromatisé; \w ton|strong="H3027"\w* \w ventre|strong="H3409"\w* \w est|strong="H3027"\w* \w un|strong="H3027"\w* tas \w de|strong="H3027"\w* blé entouré \w de|strong="H3027"\w* lis.
\v 3 Tes deux mamelles sont comme deux faons jumeaux d'une gazelle.
\v 4 Ton cou est \w comme|strong="H8147"\w* une tour d'ivoire, tes yeux \w sont|strong="H8147"\w* \w les|strong="H8147"\w* viviers \w en|strong="H8147"\w* Hesbon, près de \w la|strong="H8147"\w* porte de Bath-Rabbim; ton visage est \w comme|strong="H8147"\w* \w la|strong="H8147"\w* tour du Liban, \w qui|strong="H8147"\w* regarde \w vers|strong="H8147"\w* Damas.
\v 5 \w Ta|strong="H5921"\w* \w tête|strong="H6440"\w* \w est|strong="H5869"\w* élevée \w comme|strong="H5869"\w* \w le|strong="H6440"\w* Carmel, \w et|strong="H6440"\w* \w les|strong="H6440"\w* \w cheveux|strong="H6440"\w* \w de|strong="H6440"\w* \w ta|strong="H5921"\w* \w tête|strong="H6440"\w* \w sont|strong="H5869"\w* \w comme|strong="H5869"\w* \w de|strong="H6440"\w* \w l|strong="H6440"\w*'écarlate. \w Un|strong="H6440"\w* \w roi|strong="H6440"\w* serait enchaîné \w par|strong="H6440"\w* \w tes|strong="H6440"\w* boucles.
\v 6 \w Que|strong="H4428"\w* \w tu|strong="H5921"\w* es belle, \w et|strong="H4428"\w* \w que|strong="H4428"\w* \w tu|strong="H5921"\w* es agréable, \w mon|strong="H4428"\w* \w amour|strong="H5921"\w* \w et|strong="H4428"\w* \w mes|strong="H5921"\w* délices!
\v 7 Ta taille est semblable à un palmier, et \w tes|strong="H4100"\w* mamelles à \w des|strong="H3302"\w* grappes de raisins.
\v 8 \w J|strong="H3068"\w*'ai \w dit|strong="H2063"\w*: \w Je|strong="H3068"\w* monterai sur \w le|strong="H2063"\w* \w palmier|strong="H8558"\w*, et \w je|strong="H2063"\w* saisirai \w ses|strong="H7699"\w* branches; \w que|strong="H2063"\w* \w les|strong="H2063"\w* \w mamelles|strong="H7699"\w* \w soient|strong="H7699"\w* pour moi comme \w des|strong="H7699"\w* grappes \w de|strong="H6967"\w* vigne, et \w le|strong="H2063"\w* parfum \w de|strong="H6967"\w* ton souffle comme \w l|strong="H2063"\w*'odeur \w des|strong="H7699"\w* pommes,
\v 9 \w Et|strong="H5927"\w* \w ton|strong="H5927"\w* palais \w comme|strong="H1961"\w* \w le|strong="H5927"\w* bon \w vin|strong="H5927"\w* \w qui|strong="H5927"\w* coule \w en|strong="H5927"\w* faveur \w de|strong="H5927"\w* \w mon|strong="H1961"\w* \w bien-aimé|strong="H1961"\w*, \w et|strong="H5927"\w* \w qui|strong="H5927"\w* \w fait|strong="H5927"\w* parler \w les|strong="H5927"\w* lèvres \w de|strong="H5927"\w* \w ceux|strong="H1961"\w* \w qui|strong="H5927"\w* dorment.
