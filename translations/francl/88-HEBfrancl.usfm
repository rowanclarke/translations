\v 21 \w vous|strong="G5210"\w* \w rende|strong="G1473"\w* \w capables|strong="G2675"\w* \w de|strong="G1722"\w* \w toute|strong="G3956"\w* \w bonne|strong="G1722"\w* œuvre \w pour|strong="G1519"\w* \w l|strong="G3739"\w*’\w accomplissement|strong="G4160"\w* \w de|strong="G1722"\w* \w sa|strong="G1722"\w* \w volonté|strong="G2307"\w*, \w en|strong="G1722"\w* \w opérant|strong="G4160"\w* \w en|strong="G1722"\w* \w vous|strong="G5210"\w* \w ce|strong="G3739"\w* \w qui|strong="G3588"\w* \w est|strong="G3588"\w* \w agréable|strong="G2101"\w* \w à|strong="G1519"\w* \w ses|strong="G1722"\w* yeux, \w par|strong="G1223"\w* \w Jésus-Christ|strong="G1722"\w*, \w auquel|strong="G3739"\w* \w soit|strong="G5547"\w* \w la|strong="G1722"\w* \w gloire|strong="G1391"\w* \w dans|strong="G1722"\w* \w les|strong="G1722"\w* \w siècles|strong="G1519"\w* \w des|strong="G1722"\w* \w siècles|strong="G1519"\w* ! Amen !
