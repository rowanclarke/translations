\v 23 \w Había|strong="H1961"\w* 96 \w granadas|strong="H7416"\w* \w en|strong="H5921"\w* \w cada|strong="H3605"\w* hilera. \w Sobre|strong="H5921"\w* \w la|strong="H5921"\w* malla \w alrededor|strong="H5439"\w* \w del|strong="H5921"\w* capitel \w había|strong="H1961"\w* un total \w de|strong="H5921"\w* 100 \w granadas|strong="H7416"\w*.   
\p
